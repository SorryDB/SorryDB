import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem aime_1983_p1 (x y z w : ℕ) (ht : 1 < x ∧ 1 < y ∧ 1 < z) (hw : 0 ≤ w)
    (h0 : Real.log w / Real.log x = 24) (h1 : Real.log w / Real.log y = 40)
    (h2 : Real.log w / Real.log (x * y * z) = 12) : Real.log w / Real.log z = 60 := by
  have hx_log : Real.log ↑x ≠ 0 := (Real.log_pos (by positivity)).ne.symm
  have hy_log : Real.log ↑y ≠ 0 := (Real.log_pos (by positivity)).ne.symm
  have hxyz_log : Real.log (↑x * ↑y * ↑z) ≠ 0 := (Real.log_pos (by positivity)).ne.symm
  have hw_nz : Real.log ↑w ≠ 0 := by
    have : Real.log ↑w = 24 * Real.log ↑x := by field_simp [hx_log] at h0; linarith
    have : 0 < Real.log ↑x := Real.log_pos (by positivity)
    linarith
  have hx : Real.log ↑x = Real.log ↑w / 24 := by field_simp [hx_log] at h0; field_simp [h0]; linarith
  have hy : Real.log ↑y = Real.log ↑w / 40 := by field_simp [hy_log] at h1; field_simp [h1]; linarith
  have hxyz' : Real.log (↑x * ↑y * ↑z) = Real.log ↑w / 12 := by field_simp [hxyz_log] at h2; field_simp [h2]; linarith
  have hz : Real.log ↑z = Real.log ↑w / 60 := by
    rw [Real.log_mul (by positivity) (by positivity), Real.log_mul (by positivity) (by positivity)] at hxyz'
    rw [hx, hy] at hxyz'; field_simp [hw_nz] at hxyz' ⊢; linarith
  rw [hz]; field_simp [hw_nz]

