theorem card_of_slice (A: Set G) : ∃ φ : G →+ ZMod 2, Nat.card { x | x ∈ A ∧ φ x = 1 } ≥ (Nat.card A-1) / 2 := by
  let n := Nat.card A
  cases' Nat.eq_zero_or_pos n with h h
  · simp [h]
    exact ⟨0, by simp⟩
  · have : Nonempty A := Nat.card_pos.mp h
    let x := Classical.choice this
    obtain ⟨φ, hφ⟩ := exists_ne_zero (ZMod 2) x
    refine ⟨φ, ?_⟩
    rw [← card_of_dual_constrained x hφ, Nat.le_div_iff_mul_le zero_lt_two]
    exact Nat.card_le_of_subset fun y hy => ⟨hy.1, hy.2⟩
```
