import LeanCamCombi.Mathlib.Probability.HasLaw
import Mathlib.Probability.IdentDistrib
import Mathlib.Probability.ProductMeasure

/-!
# Bernoulli random variables

This file defines the binomial random distribution on a set. For a set `u : Set őĻ` and `p` between
`0` and `1`, this is the measure on `Set őĻ` such that each `i ‚ąą u` belongs to the random set with
probability `p`, and each `i ‚ąČ u` doesn't belong to it.

## Notation

`Ber(u, p)` is the product of `p`-Bernoulli distributions on `u`.

## TODO

Add the characteristic predicate for a random variable to follow the Bernoulli distribution.
-/

open MeasureTheory Measure unitInterval
open scoped Finset

namespace ProbabilityTheory
variable {őĻ ő© : Type*} {m : MeasurableSpace ő©} {X Y : ő© ‚Üí Set őĻ} {s u : Set őĻ} {i j : őĻ} {p q : I}
  {P : Measure ő©}

variable (u p) in
/-- The binomial distribution with parameter `p` on the set `u : Set V` is the measure on `Set V`
such that each element of `u` is taken with probability `p`, and the elements outside of `u` are
never taken. -/
noncomputable def bernoulliOn : Measure (Set őĻ) :=
  .comap (fun s i ‚Ü¶ i ‚ąą s) <| infinitePi fun i ‚Ü¶
    toNNReal p ‚ÄĘ dirac (i ‚ąą u) + toNNReal (ŌÉ p) ‚ÄĘ dirac False

@[inherit_doc] scoped notation "Ber(" u ", " p ")" => bernoulliOn u p

instance : IsProbabilityMeasure Ber(u, p) :=
  MeasurableEquiv.setOf.symm.measurableEmbedding.isProbabilityMeasure_comap <| .of_forall fun P ‚Ü¶
    ‚ü®{a | P a}, rfl‚ü©

variable (u p) in
lemma bernoulliOn_eq_map :
    Ber(u, p) = .map (fun p ‚Ü¶ {i | p i})
      (infinitePi fun i ‚Ü¶ toNNReal p ‚ÄĘ dirac (i ‚ąą u) + toNNReal (ŌÉ p) ‚ÄĘ dirac False) :=
  MeasurableEquiv.setOf.comap_symm

lemma bernoulliOn_apply (S : Set (Set őĻ)) :
    Ber(u, p) S = (infinitePi fun a ‚Ü¶ toNNReal p ‚ÄĘ dirac (a ‚ąą u) + toNNReal (ŌÉ p) ‚ÄĘ dirac False)
      ((fun t a ‚Ü¶ a ‚ąą t) '' S) := by
  convert MeasurableEquiv.setOf.symm.measurableEmbedding.comap_apply ..

lemma bernoulliOn_apply' (S : Set (Set őĻ)) :
    Ber(u, p) S = (infinitePi fun a ‚Ü¶ toNNReal p ‚ÄĘ dirac (a ‚ąą u) + toNNReal (ŌÉ p) ‚ÄĘ dirac False)
      ((fun p ‚Ü¶ {a | p a}) ‚ĀĽ¬Ļ' S) := by
  convert MeasurableEquiv.setOf.symm.comap_apply ..

variable (u) in
@[simp] lemma bernoulliOn_zero : Ber(u, 0) = dirac ‚ąÖ := by simp [bernoulliOn_eq_map]

variable (u) in
@[simp] lemma bernoulliOn_one : Ber(u, 1) = dirac u := by simp [bernoulliOn_eq_map]

section Countable
variable [Countable őĻ]

-- TODO: Does this hold if `őĻ` isn't countable? Note: the current proof only needs `u` cocountable,
-- but we don't bother doing this minigeneralisation.
lemma bernoulliOn_ae_subset : ‚ąÄŠĶź s ‚ąāBer(u, p), s ‚äÜ u := by
  classical
  change _ = _
  simp only [Set.compl_setOf, Set.not_subset_iff_exists_mem_notMem, Set.setOf_exists, Set.setOf_and,
    measure_iUnion_null_iff]
  rintro a
  by_cases ha : a ‚ąą u
  ¬∑ simp [*]
  calc
    Ber(u, p) ({s | a ‚ąą s} ‚ą© {s | a ‚ąČ u})
    _ = Ber(u, p) {s | a ‚ąą s} := by simp [ha]
    _ = infinitePi (fun a ‚Ü¶ toNNReal p ‚ÄĘ dirac (a ‚ąą u) + toNNReal (ŌÉ p) ‚ÄĘ dirac False)
            (cylinder {a} {fun _ ‚Ü¶ True}) := by
      rw [bernoulliOn_apply']
      congr!
      ext
      simp [funext_iff]
    _ = 0 := by simp [infinitePi_cylinder _ (.singleton _), ha]

end Countable

variable (u p) in
-- TODO: Generalise to countable `őĻ` and finite `u`. See the TODO on `infinitePi_pi`.
@[simp] lemma bernoulliOn_singleton [Finite őĻ] (hsu : s ‚äÜ u) :
    Ber(u, p) {s} = toNNReal p ^ s.ncard * toNNReal (ŌÉ p) ^ (u \ s).ncard := by
  classical
  cases nonempty_fintype őĻ
  lift u to Finset őĻ using Set.toFinite _
  calc
    Ber(u, p) {s}
    _ = ‚ąŹ i, ((if i ‚ąą u ‚ÜĒ i ‚ąą s then (toNNReal p : ENNReal) else 0) +
          if i ‚ąą s then 0 else (toNNReal (ŌÉ p) : ENNReal)) := by
      simp [bernoulliOn_apply, Set.image_singleton, Set.indicator]
      simp [ENNReal.smul_def]
    _ = ‚ąŹ i ‚ąą u, (if i ‚ąą s then (toNNReal p : ENNReal) else (toNNReal (ŌÉ p) : ENNReal)) := by
      rw [‚Üź Finset.prod_subset u.subset_univ (by
        simpa +contextual [ite_add_ite, ‚Üź ENNReal.coe_add] using fun _ ‚Ü¶ mt (@hsu _))]
      simp +contextual [ite_add_ite]
    _ = toNNReal p ^ s.ncard * toNNReal (ŌÉ p) ^ (‚ÜĎu \ s).ncard := by
      simp [Finset.prod_ite, ‚Üź Set.ncard_coe_finset, Set.setOf_and,
        Set.inter_eq_right.2 hsu, ‚Üź Set.compl_setOf, Set.diff_eq_compl_inter, Set.inter_comm]

/-! ### Bernoulli random variables -/

variable (X u p P) in
/-- A random variable `X : ő© ‚Üí Set őĻ` is `p`-bernoulli on a set `u : Set őĻ` if its distribution is
the product over `u` of `p`-bernoulli random variables. -/
abbrev IsBernoulliOn : Prop := HasLaw X Ber(u, p) P

lemma isBernoulliOn_congr (hXY : X =ŠĶź[P] Y) : IsBernoulliOn X u p P ‚ÜĒ IsBernoulliOn Y u p P :=
  hasLaw_congr hXY

lemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ‚ąą u) (hj : j ‚ąą u) :
    IdentDistrib (fun ŌČ ‚Ü¶ i ‚ąą X ŌČ) (fun ŌČ ‚Ü¶ j ‚ąą X ŌČ) P P where
  aemeasurable_fst := by fun_prop
  aemeasurable_snd := by fun_prop
  map_eq := by simp only [‚Üź Measure.map_map (by fun_prop) (by fun_prop), hX]; rfl
