theorem card_of_slice (A: Set G) : ∃ φ : G →+ ZMod 2, Nat.card { x | x ∈ A ∧ φ x = 1 } ≥ (Nat.card A-1) / 2 := by
  classical
  by_cases hA : Nat.card A ≤ 1
  · use 0
    omega
  · push_neg at hA
    have : ∃ x ∈ A, x ≠ 0 := by
      by_contra h
      push_neg at h
      have : A ⊆ {0} := fun x hx => by simpa using h x hx
      have : Nat.card A ≤ 1 := Nat.card_mono (Set.toFinite _) this
