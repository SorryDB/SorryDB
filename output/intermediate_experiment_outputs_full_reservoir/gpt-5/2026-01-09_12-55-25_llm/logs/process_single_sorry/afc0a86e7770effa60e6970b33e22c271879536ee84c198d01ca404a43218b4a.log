def bind_R {Y} [OmegaQuasiBorelSpace Y] (α : RX X) (k : X → RX Y) : RX Y where
  val := {
    toFun r :=
      match RandomSplit.φ r with
      | (r₁, r₂) => α r₁ >>= (k · r₂)
    monotone' := by
      intro r s hrs
      cases hrs
      exact le_rfl
    map_ωSup' := by
      intro c
      have hc : ∀ n, c n = c 0 := fun n => (c.monotone (Nat.zero_le n)).symm
      rw [show ωSup c = c 0 from rfl]
      symm
      let f : R →o Option Y := {
        toFun := fun r => match RandomSplit.φ r with | (r₁, r₂) => α r₁ >>= (k · r₂)
        monotone' := by
          intro r s hrs
          cases hrs
          exact le_rfl
      }
      change ωSup (c.map f) = f (c 0)
      have : c.map f = Chain.const (f (c 0)) := by
        ext n
        simp [hc]
      rw [this]
      apply ωSup_const
  }

  property := by
      classical
      have hφ : IsHom (RandomSplit.φ (inst := inst✝¹)) :=
        isHom_of_measurable (f := RandomSplit.φ (inst := inst✝¹))
          (RandomSplit.measurable_φ (inst := inst✝¹))
      have hG : IsHom (fun p : R × R => α p.1 >>= fun x => k x p.2) := by
        have hα : IsHom (fun p : R × R => α p.1) := isHom_comp α.2 Prod.isHom_fst
        change IsHom (fun p : R × R => Option.elim (α p.1) none (fun x => k x p.2))
        refine QuasiBorelSpace.Option.isHom_elim hα ?_ ?_
        · exact isHom_const
        ·
          change IsHom
            ((fun q : (RX Y) × R => q.1 q.2) ∘ (fun q : (R × R) × X => (k q.2, q.1.2)))
          refine isHom_comp (hf := OmegaHom.isHom_eval) ?_
          refine Prod.isHom_mk ?_ ?_
          ·
            have hk : IsHom k := by infer_instance
            exact isHom_comp hk Prod.isHom_snd
          ·
            fun_prop
      have hmain :
          IsHom ((fun p : R × R => α p.1 >>= fun x => k x p.2) ∘ (RandomSplit.φ (inst := inst✝¹))) :=
        isHom_comp hG hφ
      simpa [Function.comp] using hmain
