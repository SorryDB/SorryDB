    · exact ⟨by linarith [hσ₂.1], by linarith [hσ₂.2]⟩
    · exact Set.Icc_subset_Icc le_rfl (by linarith [hσ₂.2])
    · nlinarith [hlog, hc.1, hc.2]
  have h₅ : riemannZeta.Sigma T x σ₂ 1 ≤ ε₄ I (max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x₀) / I.R))) x σ₂ K T := by
    apply corollary_3_12
    · exact K
