    · rfl
    · nlinarith [hlog, hc.1, hc.2]
    · exact I.ZDB
  calc
    Eψ x ≤ riemannZeta.zeroes_sum (Set.Ioo 0 1) (Set.Ioo (-T) T) (fun ρ ↦ ‖x^(ρ - 1) / ρ‖) + ε₁ x T := h₁
    _ ≤ (riemannZeta.Sigma T x 0 0.9 + riemannZeta.Sigma T x 0.9 σ₂ + riemannZeta.Sigma T x σ₂ 1) + ε₁ x T := by gcongr
    _ ≤ ε₂ I x 0.9 T + ε₃ I x 0.9 σ₂ N T + ε₄ I (max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x₀) / I.R))) x σ₂ K T + ε₁ x T := by
      gcongr
    _ = ε I x₀ σ₂ c N K := by rfl
