      "\n  intro x hx\n  have hT : ∃ T, T > max 51 (log x) ∧ T < (x^(1/2) - 2)/5 := by\n    use sqrt x / 3\n    constructor\n    · nlinarith [Real.sqrt_pos.mpr (by linarith : 0 < x), Real.log_le_sub_one_of_pos (by linarith : 0 < x)]\n    · nlinarith [Real.sqrt_pos.mpr (by linarith : 0 < x), pow_two_nonneg (sqrt x)]\n  obtain ⟨T, hT1, hT2⟩ := hT\n  have hT3 : T > 3 * log x := by\n    nlinarith [Real.log_le_sub_one_of_pos (by linarith : 0 < x)]\n  have hT4 : T < sqrt x / 3 := by\n    nlinarith\n  calc\n    Eψ x ≤ riemannZeta.zeroes_sum (Set.Ioo 0 1) (Set.Ioo (-T) T) (fun ρ ↦ ‖x^(ρ - 1) / ρ‖) + ε₁ x T := proposition_3_4 (by linarith [Real.exp_pos 50]) (by constructor <;> linarith)\n    _ ≤ ε I x₀ σ₂ c N K := by\n      have h1 : riemannZeta.zeroes_sum (Set.Ioo 0 1) (Set.Ioo (-T) T) (fun ρ ↦ ‖x^(ρ - 1) / ρ‖) ≤\n        riemannZeta.Sigma T x 0 0.9 + riemannZeta.Sigma T x 0.9 σ₂ + riemannZeta.Sigma T x σ₂ 1 := by\n          simp [riemannZeta.Sigma]\n          apply le_of_eq\n          congr\n          ext1\n          ring\n      calc\n        _ ≤ (ε₂ I x 0.9 T) + (ε₃ I x 0.9 σ₂ N T) + (ε₄ I (max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x) / I.R))) x σ₂ K T) := by\n          gcongr\n          · exact proposition_3_6 I (by constructor <;> norm_num) (by linarith)\n          · exact proposition_3_8 I x (by constructor <;> norm_num) (by constructor <;> linarith) (by simp [Set.Icc, Set.Ioc]; intros; linarith) (by linarith)\n          · exact corollary_3_12 I K (by constructor <;> linarith) (by rfl) (by linarith) I.ZDB\n        _ ≤ ε I x₀ σ₂ c N K := by\n          simp [ε, ε₁, ε₂, ε₃, ε₄]\n          have h_mono : x ≥ x₀ → log x ≥ log x₀ := Real.log_le_log (by linarith) (by linarith)\n          have h_t0 : max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x) / I.R)) ≥ max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x₀) / I.R)) := by\n            apply max_le_max\n            · rfl\n            · apply Real.exp_le_exp.mpr\n              apply Real.sqrt_le_sqrt\n              apply div_le_div <;> nlinarith [h_mono