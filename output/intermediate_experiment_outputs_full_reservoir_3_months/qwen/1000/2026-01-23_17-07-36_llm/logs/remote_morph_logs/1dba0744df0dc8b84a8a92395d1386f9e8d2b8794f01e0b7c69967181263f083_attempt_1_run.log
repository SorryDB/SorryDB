import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  use fun k => (k : ℝ), fun k => (k + 28 : ℝ), 71
  constructor
  · intro k hk
    norm_num
  constructor
  · intro k hk
    norm_num
  constructor
  · simp [Finset.sum_range_succ, Finset.sum_const, nsmul_eq_mul]
    norm_num
  ext x
  simp only [Set.mem_iUnion, Set.mem_Ioc, h₁, exists_prop, Finset.mem_Icc, Nat.cast_le, Nat.cast_lt,
    Nat.cast_add, Nat.cast_one, Nat.cast_zero, Nat.cast_succ, Nat.cast_ofNat]
  constructor
  · intro hx
    obtain ⟨h₁, h₂⟩ := hx
    have h₃ : ∃ k : ℕ, k ≤ 70 ∧ (k : ℝ) < x ∧ x ≤ (k + 28 : ℝ) := by
      have h₄ : ∃ k : ℕ, k ≤ 70 ∧ (k : ℝ) < x := by
        by_contra! h
        have h₅ : ∀ k : ℕ, k ≤ 70 → x ≤ k := by
          intro k hk
          specialize h k hk
          linarith
        have h₆ : x ≤ 1 := h₅ 1 (by norm_num)
        have h₇ : x ≤ 70 := h₅ 70 (by norm_num)
        have h₈ : ∑ k ∈ Finset.Icc 1 70, (k : ℝ) / (x - k) < 5 / 4 := by
          calc
            ∑ k ∈ Finset.Icc 1 70, (k : ℝ) / (x - k)
              = ∑ k ∈ Finset.Icc 1 70, (k : ℝ) / (x - k) := rfl
            _ < 5 / 4 := by
              apply lt_of_sub_pos
              sorry
        linarith
      obtain ⟨k, hk₁, hk₂⟩ := h₄
      use k
      constructor
      · exact hk₁
      constructor
      · exact hk₂
      · sorry
    obtain ⟨k, hk₁, hk₂, hk₃⟩ := h₃
    exact ⟨k, by norm_num, hk₂, hk₃⟩
  · intro hx
    obtain ⟨k, hk₁, hk₂, hk₃⟩ := hx
    constructor
    · intro h
      obtain ⟨n, hn₁, hn₂⟩ := h
      have h₄ : (n : ℝ) = x := by rw [hn₂]
      have h₅ : (k : ℝ) < (n : ℝ) := by linarith
      have h₆ : (n : ℝ) ≤ (k + 28 : ℝ) := by linarith
      have h₇ : n ≤ k + 28 := by exact_mod_cast h₆
      have h₈ : k < n := by exact_mod_cast h₅
      have h₉ : n ≤ 70 := by
        calc
          n ≤ k + 28 := h₇
          _ ≤ 70 + 28 := by gcongr <;> linarith
          _ = 98 := by norm_num
      sorry
    · sorry
