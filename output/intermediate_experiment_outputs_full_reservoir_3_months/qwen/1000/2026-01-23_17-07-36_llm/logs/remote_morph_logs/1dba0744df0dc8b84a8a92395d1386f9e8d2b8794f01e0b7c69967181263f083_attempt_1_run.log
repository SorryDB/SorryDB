import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  use fun k => (k : ℝ), fun k => (k + 28 : ℝ), 71
  constructor
  · intro k hk
    norm_num
  constructor
  · intro k hk
    norm_num
  constructor
  · simp [Finset.sum_range_succ, Finset.sum_const, nsmul_eq_mul]
    norm_num
  ext x
  simp only [Set.mem_iUnion, Set.mem_Ioc, exists_prop, h₁, Finset.mem_Icc, Nat.cast_le, Nat.cast_lt,
    Nat.cast_add, Nat.cast_one, Nat.cast_zero, Nat.cast_succ, Nat.cast_ofNat]
  constructor
  · intro hx
    obtain ⟨hx1, hx2⟩ := hx
    have h : ∃ k : ℕ, k ≤ 70 ∧ (k : ℝ) < x ∧ x ≤ (k + 28 : ℝ) := by
      use ⌊x⌋₊
      have h1 : (⌊x⌋₊ : ℝ) ≤ x := Nat.floor_le (le_of_lt (by
        contrapose! hx1
        use ⌊x⌋₊
        simp_all))
      have h2 : x < (⌊x⌋₊ + 1 : ℝ) := Nat.lt_floor_add_one x
      have h3 : (⌊x⌋₊ : ℝ) ≤ 70 := by
        contrapose! hx1
        use ⌊x⌋₊
        simp_all
      have h4 : (⌊x⌋₊ : ℝ) ≥ 1 := by
        contrapose! hx1
        use ⌊x⌋₊
        simp_all
      exact ⟨by linarith, by linarith, by linarith⟩
    exact h
  · rintro ⟨k, hk1, hk2, hk3⟩
    constructor
    · intro n hn
      have h1 : (n : ℝ) = x → False := by
        intro h
        rw [h] at hk2 hk3
        norm_cast at hk2 hk3
        omega
      exact h1
    · have h : ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k) ≥ 5 / 4 := by
        calc
          ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)
            = ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k) := rfl
          _ ≥ 5 / 4 := by
            apply le_of_sub_nonneg
            have h1 : x > (k : ℝ) := by linarith
            have h2 : x ≤ (k + 28 : ℝ) := by linarith
            have h3 : k ≤ 70 := by linarith
            have h4 : k ≥ 0 := by linarith
            norm_num
      exact h
