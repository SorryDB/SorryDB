theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  apply Fintype.card_congr
  use fun ⟨⟨x, y, z⟩, h⟩ ↦ ⟨⟨y, x, -z⟩, by
    simp only [S, Set.mem_setOf_eq] at h ⊢
    exact ⟨by linarith [h], h.2.2, h.2.1⟩ ⟩
  constructor
  · intro ⟨⟨x, y, z⟩, h⟩ hx
    simp only [T, U, Set.mem_setOf_eq] at hx ⊢
    simp only [Subtype.forall, Prod.forall, exists_prop, Subtype.exists, and_imp] at hx ⊢
    have h1 : (x - y) + z > 0 := hx
    have h2 : -z > 0 := by
      nlinarith [h.1]
    exact h2
  · use fun ⟨⟨x, y, z⟩, h⟩ ↦ ⟨⟨y, x, -z⟩, by
      simp only [S, Set.mem_setOf_eq] at h ⊢
      exact ⟨by linarith [h], h.2.2, h.2.1⟩ ⟩
    constructor
    · intro ⟨⟨x, y, z⟩, h⟩ hx
      simp only [T, U, Set.mem_setOf_eq] at hx ⊢
      simp only [Subtype.forall, Prod.forall, exists_prop, Subtype.exists, and_imp] at hx ⊢
      have h1 : z > 0 := hx
      have h2 : (y - x) + (-z) > 0 := by
        nlinarith [h.1]
      exact h2
    · intro x
      ext
      · rfl
      · rfl
      · rfl
