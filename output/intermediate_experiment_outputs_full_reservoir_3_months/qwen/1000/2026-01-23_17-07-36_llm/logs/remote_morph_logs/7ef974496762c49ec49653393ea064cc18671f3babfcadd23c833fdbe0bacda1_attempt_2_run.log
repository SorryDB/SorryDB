/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  refine' Metric.uniformContinuous_iff.mpr fun ε εpos ↦ _
  obtain ⟨l, hl⟩ := hf εpos
  have lpos : 0 < l := IsRelDenseWith.pos hl
  use l
  intro x y hxy
  have : |x - y| < l := by
    rw [abs_sub_lt_iff] at hxy
    exact hxy.2
  obtain ⟨t, ht₀, ht₁⟩ := hl x
  have : ‖f (x + t) - f x‖ ≤ ε := ht₁
  have : ‖f (y + t) - f y‖ ≤ ε := by
    have := hl y
    obtain ⟨t', ht'₀, ht'₁⟩ := this
    exact ht'₁
  calc
    ‖f x - f y‖
      = ‖f x - f (x + t) + f (x + t) - f (y + t) + f (y + t) - f y‖ := by ring_nf
    _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (y + t)‖ + ‖f (y + t) - f y‖ := by
        simpa using norm_add_le _ _
    _ ≤ ε + ‖f (x + t) - f (y + t)‖ + ε := by
        gcongr
    _ = 2 * ε + ‖f (x + t) - f (y + t)‖ := by ring
    _ ≤ 2 * ε + 0 := by
        have : x + t = y + t := by
          linarith [ht₀, ht₀, this]
        simp_all
    _ = 2 * ε := by ring
