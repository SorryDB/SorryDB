/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  refine' Metric.uniformContinuous_iff.mpr fun ε εpos ↦ _
  obtain ⟨l, hl⟩ := hf εpos
  have lpos : 0 < l := IsRelDenseWith.pos hl
  use l
  intro x y hxy
  have : |x - y| < l := by simpa [abs_sub_lt_iff] using hxy
  obtain ⟨t, ht, hft⟩ := hl x
  have h1 : ‖f (x + t) - f x‖ ≤ ε := hft
  have h2 : ‖f (y + t) - f y‖ ≤ ε := (hf εpos).imp (fun _ ↦ id) y |>.choose_spec
  calc
    ‖f x - f y‖ = ‖f (x + t) - f (y + t) + (f y - f (y + t)) + (f (x + t) - f x)‖ := by
      ring_nf
    _ ≤ ‖f (x + t) - f (y + t)‖ + ‖f y - f (y + t)‖ + ‖f (x + t) - f x‖ := by
      simpa using norm_add_le _ _
    _ ≤ 0 + ε + ε := by
      gcongr
      · exact (norm_nonneg _).trans (by linarith)
      · exact h2
      · exact h1
    _ = 2 * ε := by ring
  -- Adjust to get ε instead of 2ε by using ε/2 initially
  have := hf (ε / 2) (half_pos εpos)
  obtain ⟨l, hl⟩ := this
  have lpos : 0 < l := IsRelDenseWith.pos hl
  use l
  intro x y hxy
  have : |x - y| < l := by simpa [abs_sub_lt_iff] using hxy
  obtain ⟨t, ht, hft⟩ := hl x
  have h1 : ‖f (x + t) - f x‖ ≤ ε / 2 := hft
  have h2 : ‖f (y + t) - f y‖ ≤ ε / 2 := (hf (ε / 2) (half_pos εpos)).imp (fun _ ↦ id) y |>.choose_spec
  calc
    ‖f x - f y‖ = ‖(f x - f (x + t)) + (f (x + t) - f (y + t)) + (f (y + t) - f y)‖ := by
      ring_nf
