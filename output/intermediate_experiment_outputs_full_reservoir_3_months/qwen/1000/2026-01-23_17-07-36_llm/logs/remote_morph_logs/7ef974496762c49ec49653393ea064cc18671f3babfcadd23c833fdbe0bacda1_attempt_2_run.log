/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  intro ε εpos
  obtain ⟨l, hl⟩ := hf εpos
  have lpos := IsRelDenseWith.pos hl
  use l
  intro x y hxy
  have := hl x
  obtain ⟨t, ht₀, htl, hft⟩ := this
  calc
    ‖f y - f x‖
      = ‖f (x + t + (y - x - t)) - f (x + t - t)‖ := by congr 1; ring
    _ ≤ ‖f (x + t + (y - x - t)) - f (x + t)‖ + ‖f (x + t) - f (x + t - t)‖ := by
        simpa [sub_eq_add_neg] using norm_sub_le _ _
    _ ≤ ε + ε := by
        gcongr
        · exact hft (x + t + (y - x - t) - (x + t))
        · exact hft (x + t - t)
    _ = 2 * ε := by ring
  -- Adjust for the actual ε by using ε/2 initially
  have := hf (ε / 2) (half_pos εpos)
  obtain ⟨l, hl⟩ := this
  have lpos := IsRelDenseWith.pos hl
  use l
  intro x y hxy
  have := hl x
  obtain ⟨t, ht₀, htl, hft⟩ := this
  calc
    ‖f y - f x‖
      ≤ ‖f y - f (x + t)‖ + ‖f (x + t) - f x‖ := norm_sub_le _ _
    _ ≤ ε / 2 + ε / 2 := by
        gcongr
        · have : y = (x + t) + (y - x - t) := by ring
          rw [this]
          exact hft (y - x - t)
        · exact hft (-t)
    _ = ε := by ring
