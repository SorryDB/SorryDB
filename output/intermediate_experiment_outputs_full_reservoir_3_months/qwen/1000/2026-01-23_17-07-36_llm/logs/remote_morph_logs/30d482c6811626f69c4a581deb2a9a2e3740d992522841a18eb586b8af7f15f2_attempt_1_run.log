    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  have h1 : n - 1 < S.length := exp_needs_n_min_one_calls S h
  have h2' : n - 1 < S.length := known_needs_n_min_one_calls S h2
  have h3 : v S k ≤ S.length := by
    apply Nat.le_of_sub_nonneg
    simp [v, List.countP_le_length]
  omega
