lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
    obtain ⟨ s, hs ⟩ := heq;
    rw [hs];
    have h_edge_eq : (p.snd.edgeSet).image (Sym2.map s) = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := by
      have h_edges_eq : (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edges = List.map (Sym2.map s) p.snd.edges := by
        induction' p.snd with u v w h p ih
        · rfl
        · simp [*, Sym2.map_mk]
        · simp [*, Sym2.map_mk]
      simp [edgeSet, h_edges_eq, List.map_toFinset]
    rw [← h_edge_eq]
    exact Finset.card_image_of_injective _ (Sym2.map_injective s.injective)
```
