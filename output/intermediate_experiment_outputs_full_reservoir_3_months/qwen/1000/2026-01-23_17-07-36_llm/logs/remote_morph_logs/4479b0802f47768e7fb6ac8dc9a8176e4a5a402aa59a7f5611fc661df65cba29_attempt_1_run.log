  have h4 : ContinuousOn φ Ω := hφ'.continuousOn
  have h5 : Bounded (Function.restrict Ω φ) := h4.bounded_of_compact_support h1 h2
  obtain ⟨C, hC⟩ := h5
  have h6 : ∀ᵐ x ∂μ, x ∈ Ω → ‖φ x‖ ≤ C := by
