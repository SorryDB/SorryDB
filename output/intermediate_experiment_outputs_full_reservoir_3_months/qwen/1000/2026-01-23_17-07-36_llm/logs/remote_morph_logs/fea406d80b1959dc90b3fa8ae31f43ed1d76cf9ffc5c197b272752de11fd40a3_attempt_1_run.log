    intro k hk
    simp only [Finset.mem_Icc] at hk
    exact hk.1
  have h₂ : ∀ k : ℕ, k ∈ Finset.Icc n (2 * n) → k ≤ 2 * n := by
    intro k hk
    simp only [Finset.mem_Icc] at hk
    exact hk.2
  let T := Finset.Icc n (2 * n)
  have hT : T.card = n + 1 := by
    simp [Finset.Icc_eq_empty_of_lt, hn]
  have h₃ : ∀ x y : ℕ, x ∈ T → y ∈ T → x ≠ y → x + y ∈ Finset.Icc (2 * n + 1) (4 * n) := by
    intros x y hx hy hxy
    constructor <;> linarith [h₁ x hx, h₁ y hy, h₂ x hx, h₂ y hy]
  have h₄ : Finset.card (Finset.filter IsSquare (Finset.Icc (2 * n + 1) (4 * n))) ≥ 1 := by
    have h₅ : (2 * n + 1) ≤ (2 * Nat.sqrt (2 * n) + 1) ^ 2 ∧ (2 * Nat.sqrt (2 * n) + 1) ^ 2 ≤ 4 * n := by
      have h₆ : Nat.sqrt (2 * n) ≥ 10 := by
        apply Nat.le_sqrt.mpr
        linarith
      have h₇ : (2 * Nat.sqrt (2 * n) + 1) ^ 2 ≤ 4 * n := by
        nlinarith [Nat.sqrt_le (2 * n), Nat.lt_succ_sqrt (2 * n)]
      have h₈ : (2 * n + 1) ≤ (2 * Nat.sqrt (2 * n) + 1) ^ 2 := by
        nlinarith [Nat.sqrt_le (2 * n), Nat.lt_succ_sqrt (2 * n)]
      exact ⟨h₈, h₇⟩
    apply Finset.card_pos.mpr
    use (2 * Nat.sqrt (2 * n) + 1) ^ 2
    simp [h₅.1, h₅.2]
  have h₅ : ∀ A : Finset ℕ, A ⊆ T → A.card > T.card / 2 → ∃ a ∈ A, ∃ b ∈ A, a ≠ b ∧ IsSquare (a + b) := by
    intro A hA hA'
    have hA'' : A.card ≥ (T.card + 1) / 2 := by
      omega
    have hA''' : A.card ≥ n / 2 + 1 := by
      simp [hT] at hA''
      omega
    sorry
  have h₆ : S.card > T.card / 2 ∨ (T \ S).card > T.card / 2 := by
    have h₇ : S.card + (T \ S).card = T.card := by
      rw [Finset.card_sdiff_add_card hS]
    omega
  cases h₆ with
  | inl h₇ =>
    exact Or.inl (h₅ S hS h₇)
  | inr h₇ =>
    exact Or.inr (h₅ (T \ S) (Finset.sdiff_subset _ _) h₇)
