theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  have h₁ : ∀ k : ℕ, k ∈ Finset.Icc n (2 * n) → k ≥ n := fun k hk ↦ Finset.mem_Icc.mp hk |>.1
  have h₂ : ∀ k : ℕ, k ∈ Finset.Icc n (2 * n) → k ≤ 2 * n := fun k hk ↦ Finset.mem_Icc.mp hk |>.2
  let T := Finset.Icc n (2 * n)
  have hT : T.card = n + 1 := by
    rw [Finset.Icc_eq_empty_of_lt (by linarith : n ≤ 2 * n)]
    simp [Finset.Icc_card, hn]
  have hST : S ⊆ T := hS
  have hTcomp : T \ S ⊆ T := Finset.sdiff_subset _ _
  have hcard : S.card + (T \ S).card = T.card := by
    rw [← Finset.card_union_add_card_inter, Finset.union_sdiff_cancel hST]
