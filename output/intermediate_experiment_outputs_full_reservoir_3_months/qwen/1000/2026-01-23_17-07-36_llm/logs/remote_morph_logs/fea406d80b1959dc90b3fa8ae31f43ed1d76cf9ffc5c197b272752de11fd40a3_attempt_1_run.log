import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  have h₁ : Finset.Icc n (2 * n) = S ∪ (Finset.Icc n (2 * n) \ S) := by
    ext x
    simp [Finset.mem_union, Finset.mem_diff, hS]
  have h₂ : Finset.card (Finset.Icc n (2 * n)) = n + 1 := by
    simp [Finset.card_Icc, hn]
  have h₃ : Finset.card S + Finset.card (Finset.Icc n (2 * n) \ S) ≥ n + 1 := by
    rw [← h₂, ← Finset.card_union_add_card_inter]
    simp [h₁]
    exact Nat.le_add_right _ _
  have h₄ : Finset.card S ≥ (n + 1) / 2 ∨ Finset.card (Finset.Icc n (2 * n) \ S) ≥ (n + 1) / 2 := by
    omega
  cases' h₄ with hS_large hT_large
  ·
    have h₅ : ∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b) := by
      apply exists_distinct_pair_sum_is_square_of_large_set
      exact hS_large
      exact hn
    exact Or.inl h₅
  ·
    have h₅ : ∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S, a ≠ b ∧ IsSquare (a + b) := by
      apply exists_distinct_pair_sum_is_square_of_large_set
      exact hT_large
      exact hn
    exact Or.inr h₅
