import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  have h₁ : ∀ k : ℕ, k ∈ Finset.Icc n (2 * n) → k ≥ n := by
    intro k hk
    simp_all [Finset.mem_Icc]
  have h₂ : ∀ k : ℕ, k ∈ Finset.Icc n (2 * n) → k ≤ 2 * n := by
    intro k hk
    simp_all [Finset.mem_Icc]
  let T := Finset.Icc n (2 * n)
  have hT : T.card = n + 1 := by
    simp [Finset.Icc_eq_empty_of_lt, hn]
  have h₃ : ∀ a b : ℕ, a ∈ T → b ∈ T → a < b → a + b ≤ 4 * n := by
    intro a b ha hb hab
    have h₄ : a ≤ 2 * n := h₂ a ha
    have h₅ : b ≤ 2 * n := h₂ b hb
    linarith
  have h₄ : ∀ a b : ℕ, a ∈ T → b ∈ T → a < b → a + b ≥ 2 * n + 1 := by
    intro a b ha hb hab
    have h₅ : a ≥ n := h₁ a ha
    have h₆ : b ≥ n := h₁ b hb
    linarith
  have h₅ : ∃ m : ℕ, m * m ∈ Set.Icc (2 * n + 1) (4 * n) := by
    use Nat.ceil (Real.sqrt (2 * n + 1))
    have h₆ : (Nat.ceil (Real.sqrt (2 * n + 1)) : ℝ) ≥ Real.sqrt (2 * n + 1) := by
      apply Nat.le_ceil
    have h₇ : (Nat.ceil (Real.sqrt (2 * n + 1)) : ℝ) < Real.sqrt (2 * n + 1) + 1 := by
      apply Nat.lt_ceil_add_one
    have h₈ : (Nat.ceil (Real.sqrt (2 * n + 1)) : ℝ) ^ 2 ≥ 2 * n + 1 := by
      nlinarith [Real.sqrt_nonneg (2 * n + 1), Real.sq_sqrt (show (0 : ℝ) ≤ 2 * n + 1 by positivity)]
    have h₉ : (Nat.ceil (Real.sqrt (2 * n + 1)) : ℝ) ^ 2 < (Real.sqrt (2 * n + 1) + 1) ^ 2 := by
      nlinarith
    have h₁₀ : (Real.sqrt (2 * n + 1) + 1) ^ 2 ≤ 4 * n + 1 := by
      nlinarith [Real.sqrt_nonneg (2 * n + 1), Real.sq_sqrt (show (0 : ℝ) ≤ 2 * n + 1 by positivity),
        hn]
    have h₁₁ : (Nat.ceil (Real.sqrt (2 * n + 1)) : ℝ) ^ 2 ≤ 4 * n := by
      nlinarith
    exact ⟨by exact_mod_cast h₈, by exact_mod_cast h₁₁⟩
  cases' h₅ with m hm
  have h₆ : m * m ≥ 2 * n + 1 := hm.1
  have h₇ : m * m ≤ 4 * n := hm.2
  have h₈ : ∃ a b : ℕ, a ∈ T ∧ b ∈ T ∧ a < b ∧ a + b = m * m := by
    use m * m - 2 * n, 2 * n
    constructor
    · have h₉ : m * m - 2 * n ≥ n := by
        omega
      have h₁₀ : m * m - 2 * n ≤ 2 * n := by
        omega
      simp [Finset.mem_Icc, h₉, h₁₀]
    · constructor
      · simp [Finset.mem_Icc]
        omega
      · constructor
        · omega
        · omega
  cases' h₈ with a h₈
  cases' h₈ with b h₈
  cases' h₈ with ha h₈
  cases' h₈ with hb h₈
  cases' h₈ with hab hsum
  by_cases h₉ : a ∈ S
  · by_cases h₁₀ : b ∈ S
    · left
      exact ⟨a, h₉, b, h₁₀, ne_of_lt hab, hsum ▸ rfl⟩
    · right
      have h₁₁ : a ∈ T \ S := by
        simp [ha, h₉]
      have h₁₂ : b ∈ T \ S := by
        simp [hb, h₁₀]
      exact ⟨a, h₁₁, b, h₁₂, ne_of_lt hab, hsum ▸ rfl⟩
  · right
    have h₁₁ : a ∈ T \ S := by
      simp [ha, h₉]
    have h₁₂ : b ∈ T \ S := by
      simp [hb]
      by_contra h₁₃
      apply h₉
      simp_all
    exact ⟨a, h₁₁, b, h₁₂, ne_of_lt hab, hsum ▸ rfl⟩
