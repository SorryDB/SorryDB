lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have h1 : x.val ∈ val_image A X1 := ⟨x, hx, rfl⟩
  rw [h] at h1
  obtain ⟨y, hy, hy'⟩ := h1
  have : y = x := Subtype.ext hy'
  rw [this] at hy
  exact hy
```
