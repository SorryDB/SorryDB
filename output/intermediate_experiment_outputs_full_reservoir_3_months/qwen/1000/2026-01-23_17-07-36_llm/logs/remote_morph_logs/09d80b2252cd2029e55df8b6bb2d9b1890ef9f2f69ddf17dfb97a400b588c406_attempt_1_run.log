  obtain ⟨i, hi⟩ := by simpa [construction_omega] using hφ;
  obtain ⟨j, hj⟩ := by simpa [construction_omega] using hψ;
  let k := max i j;
  have hkφ : φ ∈ construction T hT k := monotone_construction (le_max_left _ _) hi;
  have hkψ : ψ ∈ construction T hT k := monotone_construction (le_max_right _ _) hj;
  have hkφψ : φ ⋏ ψ ∈ construction T hT (k + 1) := by
    dsimp [construction];
    split;
    . split_ifs with h;
      . apply Set.mem_insert_of_mem;
        apply T.andIR hkφ hkψ;
      . contradiction;
    . contradiction;
  have : φ ⋏ ψ ∈ construction_omega T hT := by
    simp [construction_omega];
    use k + 1;
    exact hkφψ;
  contradiction;
