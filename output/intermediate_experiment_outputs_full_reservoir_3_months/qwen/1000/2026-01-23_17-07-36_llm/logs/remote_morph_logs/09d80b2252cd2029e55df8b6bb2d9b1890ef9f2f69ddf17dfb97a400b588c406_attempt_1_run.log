lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra hφψ;
  replace ⟨hφψ, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφψ;
  have hφ' : χ ➝ φ ∈ T.theory := by
    apply of_mem_construction_omega hφ;
    left; assumption;
  have hψ' : χ ➝ ψ ∈ T.theory := by
    apply of_mem_construction_omega hψ;
    left; assumption;
  have hconj : χ ➝ (φ ⋏ ψ) ∈ T.theory := by
    apply T.imp_closed (axiomAndIntro (φ := φ) (ψ := ψ));
    apply T.andIR hφ' hψ';
  contradiction;
