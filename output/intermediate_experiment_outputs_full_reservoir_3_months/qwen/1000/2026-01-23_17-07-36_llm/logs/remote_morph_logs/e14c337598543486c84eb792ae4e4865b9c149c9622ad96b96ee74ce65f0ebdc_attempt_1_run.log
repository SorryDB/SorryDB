lemma not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    intro h;
    have h' : χ ➝ φ ∈ T.theory := h;
    have h'' : T.theory ⊢ χ ➝ φ := Entailment.mem_to_entails h';
    have h''' : T.theory ⊢ Γ.conj ⋏ φ ➝ ξ := Entailment.mem_to_entails hφ;
    have h'''' : T.theory ⊢ χ ➝ ξ := by
      apply Entailment.deduction_theorem.mp;
      apply Entailment.trans_mp h'' h''';
      apply Entailment.conj_elim_left;
    contradiction;
```
