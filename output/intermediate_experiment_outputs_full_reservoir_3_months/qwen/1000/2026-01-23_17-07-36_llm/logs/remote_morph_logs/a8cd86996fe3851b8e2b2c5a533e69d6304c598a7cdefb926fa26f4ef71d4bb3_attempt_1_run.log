  have h_bdd' : ∃ M : ℝ, ∀ n, (‖·‖ : E → ℝ) (f n) ≤ M := h_bdd
  obtain ⟨M, hM⟩ := h_bdd
  have hφ_nonneg : 0 ≤ (‖·‖ : E → ℝ) := fun _ ↦ norm_nonneg _
  have hφ_bdd : ∃ M : ℝ, ∀ n, (‖·‖ : E → ℝ) (f n) ≤ M := ⟨M, hM⟩
  obtain ⟨g, hg_conv, hg_approx⟩ := komlos_convex hφ_nonneg hφ_bdd
  have h_cauchy : CauchySeq g := by
