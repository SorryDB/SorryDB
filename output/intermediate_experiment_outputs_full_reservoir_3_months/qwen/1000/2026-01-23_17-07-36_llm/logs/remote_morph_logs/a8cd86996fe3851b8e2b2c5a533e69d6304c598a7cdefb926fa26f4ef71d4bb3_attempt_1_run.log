lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) :=
  by
    have hφ_nonneg : ∀ x : E, 0 ≤ ‖x‖ := norm_nonneg
    have hφ_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M := h_bdd
    obtain ⟨g, hg_conv, hg_approx⟩ := komlos_convex hφ_nonneg hφ_bdd
    refine ⟨g, 0, hg_conv, ?_⟩
    have h_cauchy : CauchySeq g := by
      intro ε εpos
      obtain ⟨N, hN⟩ := hg_approx ε εpos
      use N
      intro n hn m hm
      calc
        ‖g n - g m‖
          = ‖(2 : ℝ) • ((1 / 2 : ℝ) • (g n + g m)) - g n - g m‖ := by
            simp [two_smul, add_comm, sub_eq_add_neg, neg_add_rev]
        _ ≤ 2 * ‖(1 / 2 : ℝ) • (g n + g m) - (g n + g m) / 2‖ := by
            simp [norm_smul, mul_comm]
        _ = 0 := by simp
        _ < ε := by linarith
    exact cauchySeq_tendsto_of_complete h_cauchy
```
