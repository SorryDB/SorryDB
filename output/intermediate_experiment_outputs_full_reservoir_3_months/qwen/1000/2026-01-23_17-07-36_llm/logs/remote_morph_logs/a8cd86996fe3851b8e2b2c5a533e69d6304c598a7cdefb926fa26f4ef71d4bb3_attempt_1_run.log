lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) :=
  have h_bdd' : ∃ M, ∀ n, (fun x : E ↦ ‖x‖^2) (f n) ≤ M := by
    obtain ⟨M, hM⟩ := h_bdd
    refine ⟨M^2, fun n ↦ ?_⟩
    exact pow_le_pow_left (norm_nonneg _) (hM n) 2
  obtain ⟨g, hg_conv, hg_approx⟩ := komlos_convex (φ := fun x ↦ ‖x‖^2)
    (by intro x; exact sq_nonneg ‖x‖) h_bdd'
  have h_cauchy : CauchySeq g := by
    intro ε εpos
    obtain ⟨N, hN⟩ := hg_approx (ε^2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    have h_mid : ‖(2 : ℝ)⁻¹ • (g n + g m)‖^2 ≥ 0 := by positivity
    calc
      ‖g n - g m‖^2
        = 2 * ‖g n‖^2 + 2 * ‖g m‖^2 - 4 * ‖(2 : ℝ)⁻¹ • (g n + g m)‖^2 := by
          simp [norm_add_sq, norm_sub_sq, ← mul_assoc]
          ring
      _ < 2 * (A + 1 / (n + 1)) + 2 * (A + 1 / (m + 1)) - 4 * (A - ε^2 / 4) := by
          gcongr
          · exact hg_approx (ε^2 / 4) (by positivity) n m hn hm
          · exact hg_approx (ε^2 / 4) (by positivity) n m hn hm
          · exact le_of_lt (by linarith [hg_approx (ε^2 / 4) (by positivity) n m hn hm])
      _ ≤ ε^2 := by
          have : 1 / (n + 1) ≤ ε^2 / 4 := by
            apply (div_le_div_iff (by positivity) (by positivity)).mpr
            nlinarith [hN n hn, hN m hm]
          have : 1 / (m + 1) ≤ ε^2 / 4 := by
            apply (div_le_div_iff (by positivity) (by positivity)).mpr
            nlinarith [hN n hn, hN m hm]
          nlinarith
      _ = ε^2 := by rfl
    exact (norm_sub_lt_iff.mpr (by nlinarith)).mpr (by nlinarith)
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete h_cauchy
  exact ⟨g, x, hg_conv, hx⟩
