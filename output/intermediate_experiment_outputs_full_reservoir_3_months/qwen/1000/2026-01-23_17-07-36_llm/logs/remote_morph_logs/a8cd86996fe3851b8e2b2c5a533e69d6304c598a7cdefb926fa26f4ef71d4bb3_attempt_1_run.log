lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) :=
  have h_bdd' : ∃ M, ∀ n, (fun x : E ↦ ‖x‖) (f n) ≤ M := h_bdd
  obtain ⟨g, hg_conv, hg_cauchy⟩ := komlos_convex
    (φ := fun x : E ↦ ‖x‖)
    (hφ_nonneg := fun _ ↦ norm_nonneg _)
    h_bdd'
  have h_cauchy : CauchySeq g := by
    intro ε εpos
    obtain ⟨N, hN⟩ := hg_cauchy ε εpos
    refine ⟨N, fun n hn m hm ↦ ?_⟩
    calc
      ‖g n - g m‖
        = ‖(2 : ℝ) • ((1 / 2 : ℝ) • (g n + g m)) - g n - g m‖ := by
          simp [two_smul, add_comm, sub_eq_add_neg, neg_add_rev]
      _ = ‖(g n + g m) - g n - g m‖ := by simp [one_div, mul_assoc]
      _ = 0 := by simp
