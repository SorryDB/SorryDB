  -- But we need to relate integrals w.r.t different measures, so instead use λ = μ.var + ν.var
  let λ := μ.var + ν.var
  have hμ : μ ≪ λ := by
    apply ComplexMeasure.absolutelyContinuous_of_le
    exact le_add_left (le_refl _)
  have hν : ν ≪ λ := by
    apply ComplexMeasure.absolutelyContinuous_of_le
