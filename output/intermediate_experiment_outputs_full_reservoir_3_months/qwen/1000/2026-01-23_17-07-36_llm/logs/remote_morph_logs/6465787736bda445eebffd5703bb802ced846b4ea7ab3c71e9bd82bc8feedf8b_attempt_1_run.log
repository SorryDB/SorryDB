/-- For complex measures `μ`, `ν` and integrable function `f`: `∫ f d(μ + ν) = ∫ f dμ + ∫ f dν` -/
lemma integral_add (μ ν : ComplexMeasure α) (f : α → ℂ) :
    ∫ a, f a ∂(μ + ν) = ∫ a, f a ∂μ + ∫ a, f a ∂ν := by
  dsimp [integral]
  have h1 : (μ + ν).var ≤ μ.var + ν.var := by
    apply MeasureTheory.VectorMeasure.variation_add_le
  have h2 : (μ + ν).ang = μ.ang + ν.ang := by
    ext1 x
    simp [ang, MeasureTheory.VectorMeasure.rnDeriv_add]
  rw [h2]
  simp_rw [← integral_add]
  congr
  all_goals rfl
```
