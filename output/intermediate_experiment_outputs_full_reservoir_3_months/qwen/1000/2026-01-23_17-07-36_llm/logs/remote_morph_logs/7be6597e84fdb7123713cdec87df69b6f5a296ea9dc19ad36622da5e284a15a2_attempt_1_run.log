lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  -- Every element of the internal tangent space is represented by some plot p : Eucl n → X with p 0 = x
  -- and some vector w : Eucl n. In a fine diffeological vector space, every smooth map is smooth in the usual sense.
  -- We can reduce any such plot to a linear path using the fine structure.
