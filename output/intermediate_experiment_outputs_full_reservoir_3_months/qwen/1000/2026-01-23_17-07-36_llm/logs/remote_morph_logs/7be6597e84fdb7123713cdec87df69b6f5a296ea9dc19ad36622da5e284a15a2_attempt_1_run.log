    InternalTangentSpace.lof p w = v := by
    apply Quotient.inductionOn v
    intro z
    refine ⟨⟨z, 0⟩, rfl⟩
  -- Now p.1.2 : Eucl p.1.1 → X is a plot with p.1.2 0 = x, and since X has the fine diffeology,
  -- p.1.2 is smooth in the usual sense (i.e., C^∞).
  have h : DSmoothMap (Eucl p.1.1) X := p.2.1.dsmooth
