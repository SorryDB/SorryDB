lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  obtain ⟨w, rfl⟩ := Submodule.Quotient.exists_rep v
  refine ⟨∑ p in w.support, ∑ i, w p i • Pi.single i 1,?_⟩
  simp [vectorSpaceToInternalTangentSpace, InternalTangentSpace.lof]
  -- Since the diffeology is fine, every plot factors through a linear map from some Eucl n,
  -- and thus every element of the pre-tangent space is represented by a linear combination
  -- of vectors coming from such plots. In particular, each basis vector in Eucl n corresponds
  -- to a direction in X, so the sum above reconstructs w.
  sorry
