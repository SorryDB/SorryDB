lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  -- Every element of the internal tangent space is represented by some plot
  -- In a fine diffeological vector space, all smooth maps are plots, so we can use linear paths
  obtain ⟨p, w, rfl⟩ : ∃ p w, v = InternalTangentSpace.lof p w := by
    -- Use that the quotient map is surjective
    apply Submodule.Quotient.induction_on' v
    intro v'
    refine ⟨⟨p, w, rfl⟩⟩
  -- Now p is a plot with p.2 0 = x, and since the diffeology is fine, p.2 is smooth in the usual sense
  -- We need to show that this tangent vector comes from some direction a in X
  -- Consider the derivative of p.2 at 0; this gives a vector a in X
  let a := fderiv ℝ p.2 0 w
  -- Then the linear path t ↦ x + t • a represents the same tangent vector
  have h : InternalTangentSpace.lof p w = vectorSpaceToInternalTangentSpace x a := by
    -- This follows from the definition of the equivalence relation in the quotient
