lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  -- Every element of the internal tangent space is represented by some plot
  -- Since X has the fine diffeology, every smooth map from Euclidean space is smooth in the usual sense
  -- In particular, any plot p : Eucl n → X with p 0 = x is smooth in the usual sense
  -- The tangent space is generated by derivatives of such plots at 0
  -- But in a fine diffeological vector space, every such derivative comes from a linear path
  obtain ⟨w, hw⟩ := Submodule.Quotient.exists_rep v
  -- w is an element of PreInternalTangentSpace x
  -- which is a direct sum over pointed plots
  -- So w is a finite sum of elements from various Eucl n
  -- We can reduce to the case of a single generator using linearity
  -- and then use the fact that in fine diffeology, any smooth curve is determined by its derivative
  sorry
