      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) :=
  by
  have h_bdd : ∀ n ω, 0 ≤ X n ω := fun n ω ↦ ENNReal.zero_le _
  have h_int : ∀ n, ∫⁻ ω, X n ω ∂P ≤ ∫⁻ ω, ⊤ ∂P := fun n ↦ ENNReal.le_top
  have h_finite : ∀ n, ∫⁻ ω, X n ω ∂P < ⊤ := by
    intro n
    have : ∫⁻ ω, ⊤ ∂P = ⊤ * P univ := by simp
    rw [this]
    simpa [IsProbabilityMeasure.measure_univ] using h_int n
  choose! M hM using fun n ↦ ENNReal.exists_real_btwn (h_finite n)
  let φ : (Ω → ℝ≥0∞) → ℝ := fun Z ↦ ∫⁻ ω, Z ω ∂P
  have hφ_nonneg : 0 ≤ φ := by
    intro Z
    exact ENNReal.toReal_nonneg _
  have hφ_bdd : ∃ M : ℝ, ∀ n, φ (X n) ≤ M := by
    use ⨆ n, φ (X n)
    intro n
    exact le_csSup (Set.nonempty_range_iff.2 ⟨0, rfl⟩) (Set.mem_range_self n)
  obtain ⟨Y, hY_convex, hY_cauchy⟩ := komlos_convex hφ_nonneg hφ_bdd
  refine ⟨Y, fun ω ↦ limUnder atTop (Y · ω), ?_, ?_, ?_⟩
  · exact hY_convex
  · exact Measurable.limUnder (fun n ↦ Measurable.convexHull _ (Set.range (fun m ↦ hX (n + m))))
  · filter_upwards [ae_of_all] with ω
    exact Metric.tendsto_limUnder_of_cauchy (fun ε εpos ↦
      obtain ⟨N, hN⟩ := hY_cauchy ε εpos
