lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) :=
  by
  have h_bdd : ∀ n ω, 0 ≤ X n ω := fun n ω ↦ ENNReal.zero_le _
  have h_integrable : ∀ n, ∫⁻ ω, X n ω ∂P ≤ ⊤ := fun n ↦ by
    exact ENNReal.ae_measurable.le_top (hX n).ae_measurable
  have h_convex : ∀ n, Convex ℝ≥0∞ (Set.range fun m ↦ X (n + m)) := by
    intro n; exact convex_convexHull _ _
  have h_seq : ∀ n, ∃ Y_n : Ω → ℝ≥0∞,
      (Y_n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧
      Measurable Y_n ∧
      ∀ᵐ ω ∂P, ∃ l, Tendsto (fun k ↦ Y_n ω) atTop (𝓝 l) := by
    intro n
    let φ : (Ω → ℝ≥0∞) → ℝ≥0∞ := fun f ↦ ∫⁻ ω, f ω ∂P
    have hφ_nonneg : ∀ f, 0 ≤ φ f := fun f ↦ ENNReal.zero_le _
    have hφ_bdd : ∃ M : ℝ≥0∞, ∀ m, φ (X (n + m)) ≤ M := by
      use ⊤
      intro m
      exact ENNReal.ae_measurable.le_top (hX (n + m)).ae_measurable
    obtain ⟨Y_n, hY_n_mem, hY_n_tendsto⟩ := komlos_convex hφ_nonneg hφ_bdd
    refine ⟨Y_n, hY_n_mem, ?_, ?_⟩
    · -- Measurability of Y_n follows from being in convex hull of measurable functions
      exact Measurable.convexHull_of_measurableSet (Set.range fun m ↦ X (n + m))
        (Set.countable_range _) (fun m ↦ hX (n + m))
    · -- Pointwise convergence almost everywhere follows from Komlos lemma for integrals
      sorry
  sorry
