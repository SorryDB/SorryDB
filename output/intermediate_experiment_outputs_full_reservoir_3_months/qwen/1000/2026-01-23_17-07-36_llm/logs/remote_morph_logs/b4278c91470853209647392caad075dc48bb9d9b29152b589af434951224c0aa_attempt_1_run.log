lemma bfc_bounded (x y : H) {C : ℝ} {f : (spectrum ℂ a) → ℂ}  (hf_bounded : ∀ x, ‖f x‖ ≤ C)
    (hX : @Measurable _ _ (borel (spectrum ℂ a)) _ f) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
  have h₁ := ComplexMeasure.integral_bound_of_norm_le_const
    (cfc_toComplexMeasure ha x y) f C hf_bounded hX
  calc
    ‖(cfc_toComplexMeasure ha x y).integral f‖
      ≤ (cfc_toComplexMeasure ha x y).variation Set.univ * C := h₁
    _ ≤ (‖x‖ * ‖y‖) * C := by
        exact mul_le_mul_of_nonneg_right (cfc_variation_toComplexMeasure_bounded ha x y) (by positivity)
    _ = ‖x‖ * ‖y‖ * C := by ring
```
