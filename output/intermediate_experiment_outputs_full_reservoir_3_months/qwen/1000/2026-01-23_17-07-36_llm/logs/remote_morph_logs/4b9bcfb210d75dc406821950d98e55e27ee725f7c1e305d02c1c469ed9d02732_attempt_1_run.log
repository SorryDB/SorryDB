lemma isDiagonalisable_iff_span_isGroupLikeElem_eq_top [IsAffine G] :
    IsDiagonalisable (Spec R) G ↔ Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤ :=
  ⟨fun ⟨A, _, e, _, _⟩ ↦ by
    have : Γ(G, ⊤) ≃ₐ[R] MonoidAlgebra R (Multiplicative A) := by
      refine AlgEquiv.symm (e.hom.asOver (Spec R)).toAlgEquiv
    rw [← this.submodule_span_map_eq_top]
    simp [Submodule.map_span, Set.image_preimage_eq_inter_range, Set.range_subset_iff,
      IsGroupLikeElem_monoidAlgebra_iff]
    ext x
    simp [this.apply_symm_apply],
   fun h ↦ by
    have : ∃ (A : Type u) (_ : AddCommGroup A),
        Γ(G, ⊤) ≃ₐ[R] MonoidAlgebra R (Multiplicative A) := by
      apply exists_group_like_basis R G h
    obtain ⟨A, _inst, e⟩ := this
    refine ⟨A, _inst, (asIso <| e.toSchemeIso).symm, ?_, ?_⟩
    · infer_instance
    · infer_instance⟩
