instance piLeft {k M ι : Type*} [Ring k] [AddCommGroup M] [Module k M]
    [LE ι] (M_ : ι → Submodule k M) [IsFilterComplete M_] (α : Type*) :
    IsFilterComplete fun i ↦ Submodule.pi Set.univ fun _ : α ↦ M_ i :=
  { h : ∀ x : (α → M), (∀ i, ∃ j, x ∈ (Submodule.pi Set.univ fun _ : α ↦ M_ j)) → ∃ i, x ∈ Submodule.pi Set.univ fun _ : α ↦ M_ i :=
    fun x hx ↦ by
      have h' : ∀ a : α, ∀ i, ∃ j, x a ∈ M_ j := fun a i ↦ (hx i).choose_spec a
      choose f hf using fun a i ↦ (h' a i),
      have hf' : ∀ a, x a ∈ ⨅ i, M_ i := fun a ↦ (isFilterComplete_iff.1 ‹IsFilterComplete M_› _ fun i ↦ ⟨f a i, hf a i⟩),
      exact ⟨_, fun a ↦ hf' a⟩ }
```
