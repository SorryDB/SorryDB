import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  haveI : CompactSpace M := ‹CompactSpace M›
  apply DiscreteTopology.of_open_singleton
  intro χ
  apply isOpen_iff_mem_nhds.mpr
  intro x
  simp only [nhds_fun, nhds_pi, Filter.pi_basis, Set.mem_univ, forall_true_left]
  refine ⟨{x}, ?_, ?_⟩
  · exact isOpen_singleton_iff.mpr (by infer_instance)
  · simp
```
