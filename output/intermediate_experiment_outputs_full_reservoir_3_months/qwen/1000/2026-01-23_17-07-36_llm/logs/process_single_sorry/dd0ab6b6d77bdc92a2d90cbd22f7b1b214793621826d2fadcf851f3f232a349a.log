def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    have : E.measureOf' w₁ = E.measureOf' (w₁ ∩ w₂) := by
      rw [Set.inter_eq_left.mpr h]
    rw [this]
    have : E.measureOf' (w₁ ∩ w₂) = E.measureOf' w₁ * E.measureOf' w₂ := by
      apply E.m_Inter'
      · exact Set.measurableSet_inter (Set.measurableSet_of_subset_right h Set.univ_measurableSet) Set.univ_measurableSet
      · exact Set.univ_measurableSet
    rw [this]
    calc
      ‖(E.measureOf' w₁ * E.measureOf' w₂) x‖ = ‖E.measureOf' w₁ (E.measureOf' w₂ x)‖ := by simp [ContinuousLinearMap.comp_apply]
      _ ≤ ‖E.measureOf' w₁‖ * ‖E.measureOf' w₂ x‖ := by apply ContinuousLinearMap.le_op_norm
      _ ≤ 1 * ‖E.measureOf' w₂ x‖ := by
        have : IsOrthogonalProjection (E.measureOf' w₁) := E.isOrthogonalProjection' w₁
        have : ‖E.measureOf' w₁‖ ≤ 1 := by
          rw [IsOrthogonalProjection] at this
          cases' this with h1 h2
          rw [← h1]
          exact OperatorNorm.idempotent_le_one (E.measureOf' w₁) h1
        linarith
      _ = ‖E.measureOf' w₂ x‖ := by simp
