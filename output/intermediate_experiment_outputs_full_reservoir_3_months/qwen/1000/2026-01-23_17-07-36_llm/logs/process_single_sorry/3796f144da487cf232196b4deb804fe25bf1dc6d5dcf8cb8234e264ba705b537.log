def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same => sorry
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive (by
        intro h_eq
        have h_u_ne_v : u ≠ v := by
          intro h_contra
          apply h_exhaustive
          rw [h_contra]
          simp
        exact h_u_ne_v)))[0]'(by
        have h_nonempty : List.length (ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive (by
          intro h_eq
          have h_u_ne_v : u ≠ v := by
            intro h_contra
            apply h_exhaustive
            rw [h_contra]
            simp
          exact h_u_ne_v)) > 0 := by
          cases dstep.prod.val.rhs with
          | nil =>
            apply Nat.succ_pos
          | cons _ _ =>
            apply Nat.succ_pos
        exact Nat.pos_of_ne_zero (by
          intro h_zero
          rw [List.length_eq_zero] at h_zero
          contradiction))
