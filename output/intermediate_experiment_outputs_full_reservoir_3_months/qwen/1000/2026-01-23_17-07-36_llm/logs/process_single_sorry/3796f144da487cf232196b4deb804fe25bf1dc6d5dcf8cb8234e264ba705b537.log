            exact h_v_no_vars symbol (by simp_all)
          have h_u'_has_var : ∃ symbol ∈ u', Sum.isLeft symbol := by
            have h_dstep_var : Sum.inl dstep.prod.val.lhs ∈ u := dstep.var_in_u
            rw [← h_uv_eq] at h_dstep_var
            simp_all
          contradiction
        have h_nodes_nonempty : List.length (ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive _) > 0 := by
          cases dstep.prod.val.rhs with
          | nil => contradiction
          | cons _ _ => simp_all
        exact h_nodes_nonempty.ne.symm).fst
