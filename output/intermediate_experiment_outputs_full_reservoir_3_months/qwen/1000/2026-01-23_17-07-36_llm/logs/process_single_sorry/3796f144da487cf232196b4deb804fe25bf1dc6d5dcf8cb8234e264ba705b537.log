def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same => sorry
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive (by
        intro h_eq
        have h_u_has_var : ∃ symbol ∈ u, Sum.isLeft symbol := by
          have h_start : u.len = 1 := h_starts_in_1
          have h_u_eq : u = [u.get ⟨0, by simp [h_start]⟩] := by
            apply Word.eq_of_length_eq_one h_start
          rw [h_u_eq]
          use u.get ⟨0, by simp [h_start]⟩
          simp [h_u_eq]
        have h_v_no_var : ¬ ∃ symbol ∈ v, Sum.isLeft symbol := by
          intro h
          cases' h with symbol h_mem
          exact h_exhaustive symbol h_mem
        rw [h_eq] at h_u_has_var
        contradiction)))[0]'(by
        have h_nonempty : List.length (ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive _) > 0 := by
          cases' cfd with h_same dstep' derivation' sound'
          · contradiction
          · simp [ContextFreeDerivation.collectDerivationTreeNodes]
            -- The list contains at least the node for the root variable
            apply Nat.succ_pos
        exact Nat.pos_of_ne_zero (by linarith)).fst
