  | none, _ => Q  -- P is infinity, so P + Q = Q
  | _, none => P  -- Q is infinity, so P + Q = P
  | some (xâ‚پ, yâ‚پ), some (xâ‚‚, yâ‚‚) =>
    if xâ‚پ = xâ‚‚ then
      if yâ‚پ + yâ‚‚ + E.val.aâ‚پ*xâ‚پ + E.val.aâ‚ƒ = 0 then
        -- P and Q are negatives of each other
        MordellWeilGroup.infinity E
      else
        -- Point doubling
        match MordellWeilGroup.slope E P Q with
        | none => MordellWeilGroup.infinity E
        | some s =>  -- Changed خ» to s (for slope)
          let W := E.val
          let xâ‚ƒ := s^2 + W.aâ‚پ*s - W.aâ‚‚ - xâ‚پ - xâ‚‚
          let yâ‚ƒ := s*(xâ‚پ - xâ‚ƒ) - yâ‚پ - W.aâ‚پ*xâ‚ƒ - W.aâ‚ƒ
          MordellWeilGroup.mk_point E xâ‚ƒ yâ‚ƒ (by
            have hâ‚پ : yâ‚پ^2 + W.aâ‚پ*xâ‚پ*yâ‚پ + W.aâ‚ƒ*yâ‚پ = xâ‚پ^3 + W.aâ‚‚*xâ‚پ^2 + W.aâ‚„*xâ‚پ + W.aâ‚† := P.on_curve xâ‚پ yâ‚پ rfl
            have hâ‚‚ : yâ‚‚^2 + W.aâ‚پ*xâ‚‚*yâ‚‚ + W.aâ‚ƒ*yâ‚‚ = xâ‚‚^3 + W.aâ‚‚*xâ‚‚^2 + W.aâ‚„*xâ‚‚ + W.aâ‚† := Q.on_curve xâ‚‚ yâ‚‚ rfl
            have hs : s = (3*xâ‚پ^2 + 2*W.aâ‚‚*xâ‚پ + W.aâ‚„ - W.aâ‚پ*yâ‚پ) / (2*yâ‚پ + W.aâ‚پ*xâ‚پ + W.aâ‚ƒ) := by
              simp_all [MordellWeilGroup.slope]
            rw [hs] at *
            field_simp [hâ‚پ, hâ‚‚] at *
            ring_nf at *
            nlinarith)
