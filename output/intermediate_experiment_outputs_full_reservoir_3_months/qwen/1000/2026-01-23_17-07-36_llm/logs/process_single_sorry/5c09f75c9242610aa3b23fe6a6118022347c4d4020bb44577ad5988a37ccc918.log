      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  constructor\n  · exact hfg\n  · simp only [clap_def, if_true]\n    have h1 := lineMap_eq_iff f g hfg (interAlong f t) (interAlong g t)\n    simp at h1\n    have h2 := interBtw f ⟨g, hfg⟩\n    have h3 := interBtw g ⟨f, hfg.symm⟩\n    simp at h2 h3\n    have h4 : t ≠ t := by\n      have h5 : (interBtw f ⟨g, hfg⟩).invFun t ≠ (interBtw g ⟨f, hfg.symm⟩).invFun t := by\n        apply (interBtw f ⟨g, hfg⟩).injective\n        apply (interBtw g ⟨f, hfg.symm⟩).injective\n        simp\n        have h6 : Odd n := hn\n        have h7 : Even (n - 1) := by\n          cases' h6 with k hk\n          rw [hk]\n          simp\n        have h8 : Fin.rev t ≠ t := by\n          apply Fin.rev_ne_self_of_odd\n          exact h7\n        contradiction\n      contradiction\n    contradiction",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, if_true]\n  have h1 := lineMap_eq_iff f g hfg\n    (interAlong f t) (interAlong g t)\n  simp at h1\n  aesop",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp_all [clap_def]\n  have h₁ := lineMap_eq_iff f g hfg\n    (interAlong f t) (interAlong g (Fin.rev t))\n  have h₂ := lineMap_eq_iff g f hfg.symm\n    (interAlong g (Fin.rev t)) (interAlong f t)\n  simp_all\n  <;> aesop",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, Bool.cond_true]\n  have h₁ := lineMap_eq_iff f g hfg\n    (interAlong f (Fin.rev t)) (interAlong g (Fin.rev t))\n  have h₂ := lineMap_eq_iff f g hfg\n    (interAlong f t) (interAlong g t)\n  simp_all [Fin.rev_involutive]\n  <;> aesop",
      "\n  use fun i => ⟨i, i.val % 2 = 0⟩\n  intro f g hfg\n  constructor\n  · intro h\n    apply hfg\n    rw [h]\n  · intro t\n    have h₁ : (interBtw f ⟨g, hfg⟩ : Fin (n - 1)) = interBtw f ⟨g, hfg⟩ := rfl\n    have h₂ : (interBtw g ⟨f, hfg.symm⟩ : Fin (n - 1)) = interBtw g ⟨f, hfg.symm⟩ := rfl\n    simp only [clap_def, Fin.rev_apply, Fin.val_rev, Fin.val_add, Fin.val_sub, Fin.val_zero]\n    have hn' : Odd n := hn\n    have h_even_odd : (f.val % 2 = 0) ≠ (g.val % 2 = 0) ∨ (f.val % 2 = 0) = (g.val % 2 = 0) := by\n      by_cases h : f.val % 2 = 0 <;> by_cases h' : g.val % 2 = 0 <;> simp_all\n    cases' h_even_odd with h_diff h_same\n    · have : (if f.val % 2 = 0 then t else Fin.rev t) ≠ (if g.val % 2 = 0 then t else Fin.rev t) := by\n        simp_all\n      contrapose! this\n      apply lineMap_eq_iff\n      simp_all\n    · have : (if f.val % 2 = 0 then t else Fin.rev t) = (if g.val % 2 = 0 then t else Fin.rev t) := by\n        simp_all\n      have : (interAlong f (if f.val % 2 = 0 then t else Fin.rev t)) =\n             (interAlong g (if g.val % 2 = 0 then t else Fin.rev t)) → False := by\n        intro h_inter\n        have h_inter_f : interBtw f ⟨g, hfg⟩ = if f.val % 2 = 0 then t else Fin.rev t := by\n          apply interBtw.injective\n          simp_all\n        have h_inter_g : interBtw g ⟨f, hfg.symm⟩ = if g.val % 2 = 0 then t else Fin.rev t := by\n          apply interBtw.injective\n          simp_all\n        have h_sum : (interBtw f ⟨g, hfg⟩).val + (interBtw g ⟨f, hfg.symm⟩).val = n - 2 := by\n          have : (interBtw f).toFun.bijective := (interBtw f).bijective\n          have : (interBtw g).toFun.bijective := (interBtw g).bijective\n          have : Fintype.card {j // f ≠ j} = n - 1 := by\n            simp [Fintype.card_subtype_compl, Fintype.card_fin]\n          have : Fintype.card {j // g ≠ j} = n - 1 := by\n            simp [Fintype.card_subtype_compl, Fintype.card_fin]\n          have : (interBtw f ⟨g, hfg⟩).val + (interBtw g ⟨f, hfg.symm⟩).val = n - 2 := by\n            have : (interBtw f ⟨g, hfg⟩).val = (interBtw g ⟨f, hfg.symm⟩).val := by\n              apply Eq.symm\n              apply Eq.symm\n              have : (interBtw f).symm (interBtw f ⟨g, hfg⟩) = ⟨g, hfg⟩ := by\n                simp\n              have : (interBtw g).symm (interBtw g ⟨f, hfg.symm⟩) = ⟨f, hfg.symm⟩ := by\n                simp\n              sorry\n            sorry\n          exact this\n        have h_parity : (interBtw f ⟨g, hfg⟩).val % 2 ≠ (interBtw g ⟨f, hfg.symm⟩).val % 2 := by\n          rw [← h_sum]\n          have : (n - 2) % 2 = 1 := by\n            have : n % 2 = 1 := hn'.out\n            omega\n          omega\n        have h_t_parity : t.val % 2 = (Fin.rev t).val % 2 := by\n          have : (Fin.rev t).val = n - 2 - t.val := by\n            simp [Fin.rev]\n          rw [this]\n          have : (n - 2 - t.val) % 2 = (n - 2) % 2 - t.val % 2 := by\n            omega\n          rw [this]\n          have : (n - 2) % 2 = 1 := by\n            have : n % 2 = 1 := hn'.out\n            omega\n          omega\n        have h_contra : (interBtw f ⟨g, hfg⟩).val % 2 = (interBtw g ⟨f, hfg.symm⟩).val % 2 := by\n          cases' h_same with h_same h_same <;> simp_all\n        contradiction\n      apply this\n      apply lineMap_eq_iff.mp\n      simp_all",
      "\n  use fun i => ⟨i, i.val % 2 = 0⟩\n  intro f g hfg\n  constructor\n  · intro h\n    apply hfg\n    rw [h]\n  · intro t\n    have h₁ : (interBtw f ⟨g, hfg⟩).val + (interBtw g ⟨f, hfg.symm⟩).val = n - 2 := by\n      have := interBtw f\n      have := interBtw g\n      simp_all [Fin.equiv_fin_of_card_eq]\n      omega\n    have h₂ : (clap (f.val % 2 = 0) t).val + (clap (g.val % 2 = 0) t).val ≠ n - 2 := by\n      rw [clap_def]\n      split_ifs <;> simp_all [Fin.rev_def]\n      all_goals\n        have hn' : n % 2 = 1 := Odd.mod_two hn\n        omega\n    intro h\n    have h₃ := lineMap_eq_iff f g hfg _ _\n    simp_all",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, Bool.cond_true]\n  have h1 := lineMap_eq_iff f g hfg\n    (interAlong f (Fin.rev t)) (interAlong g (Fin.rev t))\n  have h2 := lineMap_eq_iff f g hfg\n    (interAlong f t) (interAlong g t)\n  simp_all [Fin.rev_involutive]\n  <;> aesop",
      "\n  use fun i => ⟨i, i.val % 2 = 0⟩\n  intro f g hfg\n  constructor\n  · intro h\n    apply hfg\n    rw [h]\n  · intro t\n    have h_odd : Odd n := hn\n    simp only [clap_def, Fin.rev] at *\n    have key : (f.val + t.val) % n ≠ (g.val + t.val) % n := by\n      intro h\n      have : f.val % n = g.val % n := by omega\n      have : f = g := by\n        apply Fin.eq_of_veq\n        exact Nat.mod_eq_of_lt (Fin.is_lt f) ▸ Nat.mod_eq_of_lt (Fin.is_lt g) ▸ this\n      contradiction\n    have h_inter : interAlong f (if f.val % 2 = 0 then t else Fin.rev t) ≠ interAlong g (if g.val % 2 = 0 then t else Fin.rev t) := by\n      apply interAlong.injective\n      have hf : (interBtw f ⟨g, hfg⟩).val = (if f.val % 2 = 0 then t else Fin.rev t).val := by\n        sorry\n      have hg : (interBtw g ⟨f, hfg.symm⟩).val = (if g.val % 2 = 0 then t else Fin.rev t).val := by\n        sorry\n      sorry\n    exact lineMap_eq_iff _ _ hfg _ _ |>.mpr ⟨h_inter, by sorry⟩ |>.elim",
      "\n  use fun i => (i, (i.val % 2 = 0))\n  intro f g hfg\n  constructor\n  · intro h\n    apply hfg\n    exact congr_arg Fin.val h\n  · intro t\n    simp only [clap_def, Fin.rev]\n    have h₁ : (interBtw f ⟨g, hfg⟩).val + (interBtw g ⟨f, hfg.symm⟩).val = n - 2 := by\n      have h₁ := interBtw f\n      have h₂ := interBtw g\n      have h₃ := interBtw.injective\n      have h₄ := interBtw.surjective\n      have h₅ := interBtw.bijective\n      have h₆ := interBtw.symm_apply_apply ⟨g, hfg⟩\n      have h₇ := interBtw.symm_apply_apply ⟨f, hfg.symm⟩\n      have h₈ : (interBtw f ⟨g, hfg⟩).val < n - 1 := by\n        apply Fin.is_lt\n      have h₉ : (interBtw g ⟨f, hfg.symm⟩).val < n - 1 := by\n        apply Fin.is_lt\n      have h₁₀ : (interBtw f ⟨g, hfg⟩).val ≠ (interBtw g ⟨f, hfg.symm⟩).val := by\n        intro h\n        have h₁₁ := lineMap_eq_iff f g hfg (interAlong f (interBtw f ⟨g, hfg⟩)) (interAlong g (interBtw g ⟨f, hfg.symm⟩))\n        simp_all\n      omega\n    have h₂ : (f.val % 2 = 0) = (g.val % 2 = 0) → False := by\n      intro h\n      have h₃ : (f.val + g.val) % 2 = 0 := by\n        omega\n      have h₄ : n % 2 = 1 := by\n        exact hn.neg_one_pow\n      have h₅ : (n - 1) % 2 = 0 := by\n        omega\n      have h₆ : (interBtw f ⟨g, hfg⟩).val + (interBtw g ⟨f, hfg.symm⟩).val = n - 2 := by\n        exact h₁\n      have h₇ : ((interBtw f ⟨g, hfg⟩).val + t.val) % (n - 1) ≠ ((interBtw g ⟨f, hfg.symm⟩).val + (n - 2 - t.val)) % (n - 1) := by\n        intro h\n        have h₈ : (interBtw f ⟨g, hfg⟩).val + t.val ≡ (interBtw g ⟨f, hfg.symm⟩).val + (n - 2 - t.val) [MOD (n - 1)] := by\n          simpa [Nat.ModEq] using h\n        have h₉ : (interBtw f ⟨g, hfg⟩).val + (interBtw g ⟨f, hfg.symm⟩).val ≡ n - 2 [MOD (n - 1)] := by\n          simpa [Nat.ModEq] using h₁\n        have h₁₀ : 2 * t.val ≡ 0 [MOD (n - 1)] := by\n          simpa [Nat.ModEq, h₉] using h₈\n        have h₁₁ : t.val ≡ 0 [MOD (n - 1)] := by\n          apply Nat.ModEq.mul_left_cancel' (Nat.coprime_two_of_odd (by omega))\n          simpa [Nat.ModEq] using h₁₀\n        have h₁₂ : t.val = 0 := by\n          apply Nat.mod_eq_of_lt\n          apply Fin.is_lt\n        have h₁₃ : (interBtw f ⟨g, hfg⟩).val = (interBtw g ⟨f, hfg.symm⟩).val := by\n          simpa [h₁₂] using h\n        exact h₁₀ h₁₃\n      exact h₇\n    have h₃ : (f.val % 2 = 0) ≠ (g.val % 2 = 0) := by\n      apply h₂\n    cases' (f.val % 2 = 0) with hf hf <;> cases' (g.val % 2 = 0) with hg hg <;> simp_all\n    <;> apply lineMap_eq_iff.mp\n    <;> simp_all",
      "\n  use fun i => (i, true)\n  intro f g hfg\n  constructor\n  · exact hfg\n  · intro t\n    simp only [clap_def, if_true]\n    have h := lineMap_eq_iff f g hfg (interAlong f t) (interAlong g t)\n    simp at h\n    have h' := h.1\n    simp at h'\n    aesop",
      "\n  use fun i => (i, true)\n  intro f g hfg t\n  simp_all [clap_def]\n  have h₁ := lineMap_eq_iff f g hfg\n    (interAlong f t) (interAlong g t)\n  simp_all\n  <;> aesop",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, Fin.rev]\n  have h₁ : (interBtw f ⟨g, hfg⟩ : Fin (n - 1)) ≠ (interBtw g ⟨f, hfg.symm⟩ : Fin (n - 1)) := by\n    apply Fin.ne_of_lt\n    have h₂ : (interBtw f ⟨g, hfg⟩ : ℕ) < n - 1 := Fin.isLt _\n    have h₃ : (interBtw g ⟨f, hfg.symm⟩ : ℕ) < n - 1 := Fin.isLt _\n    omega\n  have h₂ : interAlong f (interBtw f ⟨g, hfg⟩) ≠ interAlong g (interBtw g ⟨f, hfg.symm⟩) := by\n    intro h\n    apply h₁\n    exact (interAlong f).injective (by simpa using h)\n  simp_all [lineMap_eq_iff, hfg]",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, Fin.rev_apply, ne_eq, Prod.mk.injEq]\n  constructor\n  · exact hfg\n  · intro h\n    have h₁ := lineMap_eq_iff f g hfg\n      (interAlong f (clap true t)) (interAlong g (clap true t))\n    simp_all",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, Bool.cond_true_eq]\n  have h₁ := lineMap_eq_iff f g hfg\n    (interAlong f t) (interAlong g (Fin.rev t))\n  have h₂ := lineMap_eq_iff f g hfg\n    (interAlong f (Fin.rev t)) (interAlong g t)\n  simp_all [Fin.rev_involutive]\n  <;> aesop",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, if_true]\n  have h1 := lineMap_eq_iff f g hfg (interAlong f t) (interAlong g t)\n  simp_all\n  <;> aesop",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, if_true]\n  have h₁ := lineMap_eq_iff f g hfg\n    (interAlong f t) (interAlong g t)\n  simp_all\n  <;> aesop",
      "\n  use fun i => (i, true)\n  intro f g hfg\n  constructor\n  · exact hfg\n  · intro t\n    simp only [clap_def, Bool.true]\n    have h₁ := lineMap_eq_iff f g hfg (interAlong f t) (interAlong g t)\n    simp at h₁\n    have h₂ := interBtw f ⟨g, hfg⟩\n    have h₃ := interBtw g ⟨f, hfg.symm⟩\n    simp at h₂ h₃\n    intro h\n    have h₄ := h₁.mp h\n    simp at h₄\n    have h₅ : t = interBtw f ⟨g, hfg⟩ := h₄.1\n    have h₆ : t = interBtw g ⟨f, hfg.symm⟩ := h₄.2\n    have h₇ : interBtw f ⟨g, hfg⟩ = interBtw g ⟨f, hfg.symm⟩ := Eq.trans h₅ h₆.symm\n    have h₈ : (interBtw f).symm (interBtw f ⟨g, hfg⟩) = (interBtw g).symm (interBtw g ⟨f, hfg.symm⟩) := by\n      rw [h₇]\n    simp at h₈\n    have h₉ : ⟨g, hfg⟩ = ⟨f, hfg.symm⟩ := by\n      apply (interBtw f).injective\n      rw [← (interBtw f).apply_symm_apply, ← (interBtw g).apply_symm_apply, h₇]\n    simp at h₉\n    exact hfg h₉.1",
      "\n  use fun i => (i, (i.val % 2 = 0))\n  intro f g hfg\n  constructor\n  · intro h\n    apply hfg\n    exact congr_arg Fin.val h\n  · intro t\n    have h_odd : Odd n := hn\n    have h_ne : (f : ℕ) ≠ (g : ℕ) := by\n      intro h\n      apply hfg\n      exact Fin.ext h\n    simp only [clap_def, Fin.rev]\n    have h_inter : ∀ i j (hij : i ≠ j), interBtw i ⟨j, hij⟩ ≠ interBtw j ⟨i, hij.symm⟩ := by\n      intro i j hij\n      have h_bij : Function.Bijective (interBtw i) := (interBtw i).bijective\n      have h_bij' : Function.Bijective (interBtw j) := (interBtw j).bijective\n      intro h_eq\n      have h_map : lineMap (points i).1 (points i).2 (interAlong i (interBtw i ⟨j, hij⟩)).1 =\n        lineMap (points j).1 (points j).2 (interAlong j (interBtw j ⟨i, hij.symm⟩)).1 :=\n        by rw [← lineMap_eq_iff _ _ hij _ _, h_eq]\n      have h_contra : False := by\n        have h_same := lineMap_eq_iff _ _ hij _ _\n        simp_all\n      contradiction\n    have h_parity : (f.val % 2 = 0) ≠ (g.val % 2 = 0) ∨ (f.val % 2 = 0) = (g.val % 2 = 0) := by\n      tauto\n    cases' h_parity with h_parity h_parity <;> simp_all [Fin.rev_apply]\n    <;> intro h_eq\n    <;> have h_inter_eq := lineMap_eq_iff _ _ hfg _ _\n    <;> simp_all\n    <;> have h_fin : (interBtw f ⟨g, hfg⟩ : Fin (n - 1)) = (interBtw g ⟨f, hfg.symm⟩ : Fin (n - 1)) := by\n      apply Eq.symm\n      apply Eq.symm\n      simp_all\n    <;> have h_contra : False := h_inter _ _ hfg h_fin\n    <;> contradiction",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, Bool.cond_true]\n  have h1 := lineMap_eq_iff f g hfg\n    (interAlong f (Fin.rev t)) (interAlong g (Fin.rev t))\n  have h2 := lineMap_eq_iff f g hfg\n    (interAlong f t) (interAlong g t)\n  simp_all [Fin.rev_involutive]\n  <;> aesop",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp only [clap_def, Bool.cond_true_eq]\n  have h₁ : interAlong f (Fin.rev t) ≠ interAlong g t := by\n    intro h\n    have h₂ := lineMap_eq_iff f g hfg (interAlong f (Fin.rev t)) (interAlong g t)\n    simp_all [Fin.rev_involutive]\n  exact (lineMap_eq_iff f g hfg _ _).mp (by simp_all) |>.elim",
      "\n  use fun i => ⟨i, i.val % 2 = 0⟩\n  intro f g hfg\n  constructor\n  · intro h\n    apply hfg\n    simp_all\n  · intro t\n    intro h\n    have h₁ := lineMap_eq_iff _ _ hfg _ _\n    simp_all [clap_def]\n    <;> aesop",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp_all [clap_def]\n  have h1 : (interBtw f ⟨g, hfg⟩ : Fin (n - 1)) ≠ (interBtw g ⟨f, hfg.symm⟩ : Fin (n - 1)) := by\n    have h_odd : Odd n := hn\n    have h_ne : n - 1 ≠ 0 := by omega\n    have h_inj : Function.Injective (interBtw f) := (interBtw f).injective\n    have h_inj' : Function.Injective (interBtw g) := (interBtw g).injective\n    intro h_eq\n    have h_contra : f = g := by\n      apply Fin.eq_of_veq\n      have h_val : (interBtw f ⟨g, hfg⟩).val = (interBtw g ⟨f, hfg.symm⟩).val := by\n        simp_all\n      have h_val' : (interBtw f ⟨g, hfg⟩).val + (interBtw g ⟨f, hfg.symm⟩).val = n - 2 := by\n        have h_total : ∀ i : Fin n, ∑ j in {k | k ≠ i}, 1 = n - 1 := by\n          intro i\n          simp [Finset.card_erase]\n        have h_symm : ∀ i j (hij : i ≠ j), (interBtw i ⟨j, hij⟩).val + (interBtw j ⟨i, hij.symm⟩).val = n - 2 := by\n          intro i j hij\n          have h_perm : (interBtw i) ∘ Equiv.ofBijective (fun k : {l // l ≠ i} => ⟨(k : Fin n), by aesop⟩) (by aesop) =\n            Equiv.refl (Fin (n - 1)) := by\n            ext k\n            simp\n          sorry\n        exact h_symm f g hfg\n      omega\n    contradiction\n  exact (lineMap_eq_iff f g hfg _ _).mp (by aesop) |>.symm ▸ h1 ▸ by aesop",
      "\n  use fun i => (i, true)\n  intro f g hfg t\n  simp_all [clap_def]\n  have h1 : interAlong f t ≠ interAlong g t := by\n    intro h\n    have h2 := lineMap_eq_iff f g hfg (interAlong f t) (interAlong g t)\n    simp_all\n  exact h1",
      "\n  use fun i => ⟨i, true⟩\n  intro f g hfg t\n  simp [clap_def]\n  have h1 := lineMap_eq_iff f g hfg (interAlong f t) (interAlong g t)\n  simp at h1\n  aesop",
      "\n  use fun i => ⟨i, (i : ℕ) % 2 = 0⟩\n  intro f g hfg\n  constructor\n  · intro h\n    apply hfg\n    rw [← Fin.ext_iff] at h\n    exact h\n  · intro t\n    have h₁ : (interBtw f ⟨g, hfg⟩ : Fin (n - 1)) ≠ (interBtw g ⟨f, hfg.symm⟩ : Fin (n - 1)) := by\n      intro h\n      have h₂ := lineMap_eq_iff f g hfg (interAlong f (interBtw f ⟨g, hfg⟩)) (interAlong g (interBtw g ⟨f, hfg.symm⟩))\n      simp_all\n    have h₂ : (clap ((f : ℕ) % 2 = 0) t : Fin (n - 1)) = (clap ((g : ℕ) % 2 = 0) t : Fin (n - 1)) → False := by\n      cases' Nat.even_or_odd (f : ℕ) with hf hf <;> cases' Nat.even_or_odd (g : ℕ) with hg hg <;>\n        simp_all [clap_def, Fin.rev_involutive, Fin.rev_eq_iff]\n      all_goals\n        omega\n    have h₃ := lineMap_eq_iff f g hfg (interAlong f (clap ((f : ℕ) % 2 = 0) t)) (interAlong g (clap ((g : ℕ) % 2 = 0) t))\n    simp_all",
