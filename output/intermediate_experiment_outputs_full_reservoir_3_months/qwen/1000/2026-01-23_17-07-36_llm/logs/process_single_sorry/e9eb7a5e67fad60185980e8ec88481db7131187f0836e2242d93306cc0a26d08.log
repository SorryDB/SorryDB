/-- The moment of inertia tensor of a solid sphere through its center of mass is
  `2/5 m R^2 * I`. -/
lemma solidSphere_inertiaTensor (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere 3 m R).inertiaTensor = (2/5 * m.1 * R.1^2) • (1 : Matrix _ _ _) := by
  ext i j
  simp only [inertiaTensor, solidSphere, Nat.succ_eq_add_one, LinearMap.coe_mk, AddHom.coe_mk,
    ContMDiffMap.coeFn_mk, smul_eq_mul, one_div, mul_one]
  have h1 : (@volume (Space 3) measureSpaceOfInnerProductSpace).real
      (Metric.closedBall 0 R) ≠ 0 := by
    refine (measureReal_ne_zero_iff ?_).mpr ?_
    · apply Space.volume_closedBall_neq_top
    · apply Space.volume_closedBall_neq_zero
      have hr' := R.2
      have hx : R.1 ≠ 0 := by simpa using hr
      apply lt_of_le_of_ne hr' (Ne.symm hx)
  field_simp [h1]
  have h2 : ∫ x in Metric.closedBall (0 : Space 3) R, (x i * x j) ∂volume =
      if i = j then (1/5 : ℝ) * volume.real (Metric.closedBall (0 : Space 3) R) * R.1^2 else 0 := by
    · apply Space.integral_xi_xj_over_ball
  split_ifs with h
  · rw [h2, h]
    ring
  · rw [h2, h]
    simp
