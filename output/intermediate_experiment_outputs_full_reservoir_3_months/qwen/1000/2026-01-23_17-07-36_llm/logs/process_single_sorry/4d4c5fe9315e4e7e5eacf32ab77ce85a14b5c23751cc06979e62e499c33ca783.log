/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  have h₁ : ∃ n ≥ N, ∃ p, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
    let n := max N 1
    have hn : n ≥ N := by
      apply le_max_left
    have h₂ : ∃ p, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
      have h₃ : n ^ 2 + 1 > 1 := by
        have h₄ : n ≥ 1 := by
          apply le_trans (by norm_num) hn
        nlinarith
      obtain ⟨p, hp₁, hp₂⟩ := Nat.exists_prime_and_dvd h₃
      use p
      constructor
      · exact hp₁
      constructor
      · exact hp₂
      · have h₅ : (p : ℝ) ≥ (n ^ 2 + 1 : ℝ) / (n ^ 2 + 1 : ℝ) := by
          norm_num
        have h₆ : (n ^ 2 + 1 : ℝ) > 2 * n + √(2 * n) := by
          have h₇ : 0 < (n : ℝ) := by
            have h₈ : n ≥ 1 := by
              apply le_trans (by norm_num) hn
            exact mod_cast h₈
          have h₉ : 0 < √(2 * n) := by
            exact Real.sqrt_pos.mpr (by positivity)
          nlinarith [sq_sqrt (by positivity : (0 : ℝ) ≤ 2 * n),
            mul_self_nonneg (n - 1)]
        calc
          (p : ℝ) ≥ (n ^ 2 + 1 : ℝ) / (n ^ 2 + 1 : ℝ) := h₅
          _ = 1 := by field_simp
          _ < (n ^ 2 + 1 : ℝ) := by
            have h₁₀ : (n ^ 2 + 1 : ℝ) > 1 := by
              have h₁₁ : n ≥ 1 := by
                apply le_trans (by norm_num) hn
              nlinarith
            linarith
          _ > 2 * n + √(2 * n) := h₆
    exact ⟨n, hn, h₂⟩
  exact h₁
