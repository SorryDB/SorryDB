@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  have h₁ : ∃ n ≥ N, ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
    use 2 * N + 1
    constructor
    · linarith
    · have h₂ : (2 * N + 1 : ℕ) ^ 2 + 1 > 0 := by positivity
      have h₃ : ∃ p : ℕ, Nat.Prime p ∧ p ∣ (2 * N + 1) ^ 2 + 1 := by
        apply Nat.exists_prime_and_dvd
        exact h₂
      obtain ⟨p, hp₁, hp₂⟩ := h₃
      use p
      constructor
      · exact hp₁
      · constructor
        · exact hp₂
        · have h₄ : (p : ℝ) ≥ ((2 * N + 1) ^ 2 + 1 : ℝ) / ((2 * N + 1) ^ 2 + 1 : ℝ) := by
            norm_cast
            apply Nat.le_of_dvd
            · positivity
            · exact hp₂
          have h₅ : (p : ℝ) > 2 * (2 * N + 1) + √(2 * (2 * N + 1)) := by
            have h₆ : (p : ℝ) ≥ ((2 * N + 1) ^ 2 + 1 : ℝ) := by
              exact_mod_cast Nat.le_of_dvd (by positivity) hp₂
            have h₇ : ((2 * N + 1) ^ 2 + 1 : ℝ) > 2 * (2 * N + 1) + √(2 * (2 * N + 1)) := by
              nlinarith [sq_sqrt (show (0 : ℝ) ≤ 2 * (2 * N + 1) by positivity),
                sq_nonneg (√(2 * (2 * N + 1)) - 1)]
            linarith
          exact h₅
  exact h₁
