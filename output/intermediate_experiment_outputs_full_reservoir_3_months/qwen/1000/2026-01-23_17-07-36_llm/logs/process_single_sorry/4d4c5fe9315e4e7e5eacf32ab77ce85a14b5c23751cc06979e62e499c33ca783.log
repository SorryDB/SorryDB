      "\n  intro N\n  have h₁ : ∃ n ≥ N, ∃ p, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by\n    use 2 * N + 1\n    constructor\n    · linarith\n    · have h₂ : (2 * N + 1) ^ 2 + 1 > 0 := by positivity\n      have h₃ : ∃ p, Nat.Prime p ∧ p ∣ (2 * N + 1) ^ 2 + 1 := by\n        apply Nat.exists_prime_and_dvd\n        exact h₂\n      obtain ⟨p, hp₁, hp₂⟩ := h₃\n      use p\n      constructor\n      · exact hp₁\n      · constructor\n        · exact hp₂\n        · have h₄ : (p : ℝ) ≥ ((2 * N + 1) ^ 2 + 1 : ℝ) / ((2 * N + 1) ^ 2 + 1 : ℝ) := by\n            norm_cast\n            apply Nat.cast_le_of_lt_succ\n            apply Nat.lt_succ_of_le\n            exact Nat.le_of_dvd (by positivity) hp₂\n          have h₅ : ((2 * N + 1) ^ 2 + 1 : ℝ) > (2 * (2 * N + 1) + Real.sqrt (2 * (2 * N + 1))) ^ 2 := by\n            nlinarith [Real.sqrt_nonneg (2 * (2 * N + 1)), sq_sqrt (show 0 ≤ (2 * (2 * N + 1) : ℝ) by positivity)]\n          nlinarith [h₅]\n  exact h₁",
      "\n  intro N\n  have h₁ : ∃ n ≥ N, ∃ p, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by\n    let n := 2 * N * N\n    use n\n    constructor\n    · nlinarith\n    · have h₂ : n ^ 2 + 1 > 1 := by\n        nlinarith\n      obtain ⟨p, hp, hpd⟩ := Nat.exists_prime_and_dvd h₂\n      use p\n      constructor\n      · exact hp\n      constructor\n      · exact hpd\n      · have h₃ : (p : ℝ) ≥ √(n ^ 2 + 1) := by\n          apply le_sqrt_of_sq_le\n          norm_cast\n          nlinarith [Nat.Prime.pos hp]\n        have h₄ : √(n ^ 2 + 1) > 2 * n + √(2 * n) := by\n          apply lt_sqrt_of_sq_lt\n          nlinarith [sq_sqrt (show 0 ≤ (2 * n : ℝ) by positivity)]\n        linarith\n  exact h₁",
