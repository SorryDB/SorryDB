import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  have h₁ : ∃ n ≥ N, ∃ p, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
    use 2 * N + 1
    constructor
    · linarith
    · have h₂ : (2 * N + 1 : ℕ) ^ 2 + 1 > 0 := by positivity
      obtain ⟨p, hp, hpd⟩ := Nat.exists_prime_and_dvd ((2 * N + 1 : ℕ) ^ 2 + 1)
      use p
      constructor
      · exact hp
      · constructor
        · exact hpd
        · have h₃ : (p : ℝ) ≥ (2 * N + 1 : ℝ) ^ 2 + 1 := by
            exact_mod_cast Nat.le_of_dvd (by positivity) hpd
          have h₄ : (2 * N + 1 : ℝ) ^ 2 + 1 > 2 * (2 * N + 1) + Real.sqrt (2 * (2 * N + 1)) := by
            nlinarith [Real.sqrt_nonneg (2 * (2 * N + 1)), sq_sqrt (show (0 : ℝ) ≤ 2 * (2 * N + 1) by positivity)]
          linarith
  exact h₁
