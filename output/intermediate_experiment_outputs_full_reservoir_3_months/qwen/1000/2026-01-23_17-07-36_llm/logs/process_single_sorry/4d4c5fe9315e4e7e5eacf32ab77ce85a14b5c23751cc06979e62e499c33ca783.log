open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  have h₁ : ∃ n ≥ N, ∃ p, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
    use 2 * N + 1
    constructor
    · linarith
    · have h₂ : (2 * N + 1 : ℕ) ^ 2 + 1 > 0 := by positivity
      have h₃ : ∃ p, Nat.Prime p ∧ p ∣ (2 * N + 1) ^ 2 + 1 := by
        apply Nat.exists_prime_and_dvd
        exact h₂
      obtain ⟨p, hp₁, hp₂⟩ := h₃
      use p
      constructor
      · exact hp₁
      constructor
      · exact hp₂
      · have h₄ : (p : ℝ) ≥ ((2 * N + 1) ^ 2 + 1 : ℝ) / ((2 * N + 1) ^ 2 + 1).minFac := by
          exact_mod_cast Nat.le_of_dvd (by positivity) hp₂
        have h₅ : ((2 * N + 1) ^ 2 + 1 : ℝ) / ((2 * N + 1) ^ 2 + 1).minFac ≥ (2 * N + 1 : ℝ) := by
          apply (le_div_iff (by positivity)).mpr
          nlinarith [Nat.minFac_pos ((2 * N + 1) ^ 2 + 1)]
        have h₆ : (2 * N + 1 : ℝ) > 2 * (2 * N + 1) + √(2 * (2 * N + 1)) → False := by
          intro h
          nlinarith [Real.sqrt_nonneg (2 * (2 * N + 1)), Real.sq_sqrt (show (0 : ℝ) ≤ 2 * (2 * N + 1) by positivity)]
        nlinarith [Real.sqrt_nonneg (2 * (2 * N + 1)), Real.sq_sqrt (show (0 : ℝ) ≤ 2 * (2 * N + 1) by positivity)]
  exact h₁
