      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    intro x hx\n    rw [← hB N hN] at hx\n    exact le_sSup_iff.mp hx |>.imp id (fun _ => hN)\n  have h_eq' : B N hN = {N} := by\n    apply Set.ext\n    intro x\n    simp only [Set.mem_singleton_iff]\n    have h_mem : x ∈ D.carrier := h_sub ‹_›\n    have h_unique : x = N := by\n      rw [← h_eq]\n      simp [SetLike.ext_iff]\n      aesop\n    aesop\n  contradiction",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    rw [← h_eq]\n    simp only [SetLike.coe_injective, SetLike.coe_setOf, Set.mem_iUnion, exists_prop,\n      Set.mem_setOf_eq, and_true, exists_and_right, Subtype.exists]\n    intro x hx\n    rcases hx with ⟨M', hM', rfl⟩\n    exact hM'\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_sSup_eq' : sSup (B N hN) = sSup {N} := by\n    rw [← h_eq, SetLike.ext_iff] at h_sub\n    have h_subset : B N hN ⊆ {N} := by\n      intro x hx\n      have h_x_in_D : x ∈ D := h_sub hx\n      have h_x_le_N : x ≤ N := le_sSup_of_mem hN (by simp [hx])\n      have h_N_le_x : N ≤ x := by\n        have h_x_in_ref : x ∈ refinement B hB hB' hB'' := by\n          simp [refinement, hx]\n        have h_ref_eq_D : refinement B hB hB' hB'' = D := h_eq.symm ▸ rfl\n        rw [h_ref_eq_D] at h_x_in_ref\n        have h_x_ge_N : N ≤ x := by\n          apply le_sSup\n          simp [h_x_in_ref]\n        exact h_x_ge_N\n      exact le_antisymm h_x_le_N h_N_le_x\n    have h_eq_set : B N hN = {N} := by\n      ext x\n      constructor\n      · intro hx\n        exact h_subset hx\n      · intro hx\n        simp at hx\n        rw [hx]\n        have h_N_in_B : N ∈ B N hN := by\n          rw [← h_sSup_eq]\n          apply le_sSup\n          simp\n        exact h_N_in_B\n    rw [h_eq_set]\n  simp at h_sSup_eq'\n  contradiction",
      "by\n  have h_le : D ≤ refinement B hB hB' hB'' := refinement_le B hB hB' hB''\n  refine ⟨h_le, ?_⟩\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_ref : IsRefinement (refinement B hB hB' hB'') D := h_le\n  have h_mem : N ∈ D := hN\n  rcases h_ref h_mem with ⟨C, hC_sub, hC_eq⟩\n  have h_carrier_eq : (refinement B hB hB' hB'').carrier = ⋃ N, ⋃ hN, B N hN := rfl\n  have h_C_eq : C = B N hN := by\n    ext x\n    simp only [Set.mem_iUnion, exists_prop, and_imp, Set.mem_setOf_eq]\n    constructor\n    · intro hx\n      rcases hx with ⟨M', hM', hx'⟩\n      rcases hM' with ⟨M'', hM'', hx''⟩\n      subst_vars\n      aesop\n    · intro hx\n      use N, hN, hx\n  rw [h_C_eq] at hC_eq\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  rw [h_sSup_eq] at hC_eq\n  have h_singleton : B N hN = {N} := by\n    apply Set.ext\n    intro x\n    simp only [Set.mem_singleton_iff]\n    constructor\n    · intro hx\n      have h_le_x : x ≤ N := le_sSup hx\n      have h_ge_x : N ≤ x := by\n        rw [← hC_eq]\n        apply le_sSup\n        simp only [h_C_eq, Set.mem_iUnion, exists_prop, and_imp, Set.mem_setOf_eq]\n        use N, hN, hx\n      exact le_antisymm h_ge_x h_le_x\n    · intro hx\n      rw [hx]\n      have h_nonempty : B N hN ≠ ∅ := by\n        intro h_empty\n        rw [h_empty] at h_ne\n        simp at h_ne\n      exact Set.nonempty_of_ne_empty h_nonempty\n  contradiction",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    rw [← h_eq]\n    simp only [SetLike.coe_mk, Set.mem_iUnion, exists_prop, and_imp]\n    intro x hx\n    exact ⟨N, hN, hx⟩\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_sSup_eq' : sSup (B N hN) = sSup {N} := by rw [h_eq, Set.iUnion_eq_iUnion₂] at *; simp_all\n  have h_contra : B N hN = {N} := by\n    apply sSup_indep_eq_singleton_of_sSup_eq\n    · exact hB' N hN\n    · exact (sSupIndep.indep_singleton.mpr (D.not_bot_mem hN))\n    · exact h_sSup_eq.symm.trans h_sSup_eq'\n  exact h_ne h_contra",
      "by\n  refine' ⟨refinement_le B hB hB' hB'', _⟩\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_mem : N ∈ D := hN\n  have h_ref : D ≤ refinement B hB hB' hB'' := refinement_le B hB hB' hB''\n  have h_sub : B N hN ⊆ D.carrier := by\n    intro x hx\n    rw [Set.mem_iUnion, Set.mem_iUnion]\n    exact ⟨N, hN, hx⟩\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_inj : (refinement B hB hB' hB'').carrier = ⋃ N, ⋃ hN, B N hN := rfl\n  rw [← h_sSup_eq] at h_sub\n  have h_contra : B N hN = {N} := by\n    apply Set.ext\n    intro x\n    simp\n    intro hx\n    have h_x_in_D : x ∈ D := by\n      rw [h_inj] at *\n      simp at *\n      aesop\n    have h_x_le_N : x ≤ N := le_sSup hx\n    have h_N_le_x : N ≤ x := by\n      have h_x_in_ref : x ∈ refinement B hB hB' hB'' := by\n        rw [h_inj]\n        simp\n        aesop\n      have h_ref_eq : D = refinement B hB hB' hB'' := h_eq\n      rw [h_ref_eq] at h_x_in_D\n      have h_x_eq_N : x = N := by\n        apply le_antisymm\n        · exact h_x_le_N\n        · have h_N_in_ref : N ∈ refinement B hB hB' hB'' := by\n            rw [h_inj]\n            simp\n            aesop\n          have h_disj : Disjoint x N := by\n            apply (refinement B hB hB' hB'').sSupIndep.disjoint_of_ne\n            · exact h_x_in_ref\n            · exact h_N_in_ref\n            · intro h_eq\n              rw [h_eq] at hx\n              simp at hx\n              aesop\n          have h_N_le_x : N ≤ x := by\n            apply le_of_disjoint_sup_eq_top\n            · exact h_disj\n            · rw [← h_sSup_eq]\n              apply sSup_le\n              intro y hy\n              have h_y_in_ref : y ∈ refinement B hB hB' hB'' := by\n                rw [h_inj]\n                simp\n                aesop\n              have h_y_eq_N : y = N := by\n                apply le_antisymm\n                · exact le_sSup hy\n                · have h_N_in_ref : N ∈ refinement B hB hB' hB'' := by\n                    rw [h_inj]\n                    simp\n                    aesop\n                  have h_disj : Disjoint y N := by\n                    apply (refinement B hB hB' hB'').sSupIndep.disjoint_of_ne\n                    · exact h_y_in_ref\n                    · exact h_N_in_ref\n                    · intro h_eq\n                      rw [h_eq] at hy\n                      simp at hy\n                      aesop\n                  have h_N_le_y : N ≤ y := by\n                    apply le_of_disjoint_sup_eq_top\n                    · exact h_disj\n                    · rw [← h_sSup_eq]\n                      apply sSup_le\n                      intro z hz\n                      simp at hz\n                      aesop\n                  exact h_N_le_y\n              rw [h_y_eq_N]\n              exact le_rfl\n          exact h_N_le_x\n      exact h_x_eq_N\n    exact h_x_eq_N\n  contradiction",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h => _\n  rcases H with ⟨N, hN, hBN⟩\n  have h1 : B N hN ⊆ D.carrier := by\n    intro x hx\n    rw [Set.mem_iUnion]\n    exact ⟨N, hN, hx⟩\n  have h2 : D.carrier ⊆ B N hN := by\n    intro x hx\n    rw [← h] at hx\n    simp only [Set.mem_iUnion, Set.mem_iUnion₂] at hx\n    rcases hx with ⟨M', hM', x_in_B⟩\n    have h_eq : M' = N := by\n      have h_sSup_eq : sSup (B M' hM') = sSup (B N hN) := by\n        rw [hB M' hM', hB N hN]\n        exact (sSup_induced_eq_of_subset D.sSupIndep' h1 h2).symm\n      sorry\n    subst h_eq\n    exact x_in_B\n  have h3 : B N hN = {N} := by\n    ext x\n    constructor\n    · intro hx\n      have h4 : x ≤ N := le_sSup hx\n      have h5 : N ≤ x := by\n        have h6 : N = sSup (B N hN) := hB N hN\n        rw [h6]\n        apply le_sSup hx\n      exact le_antisymm h5 h4\n    · intro hx\n      rw [Set.mem_singleton_iff] at hx\n      rw [hx]\n      have h7 : N ∈ B N hN := by\n        have h8 : N = sSup (B N hN) := hB N hN\n        have h9 : sSupIndep (B N hN) := hB' N hN\n        have h10 : ⊥ ∉ B N hN := hB'' N hN\n        exact sSupIndep.mem_of_eq_top h9 h8 h10\n      exact h7\n  contradiction",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h => _\n  rcases H with ⟨N, hN, hNB⟩\n  have h1 : N ∈ D := hN\n  have h2 : N = sSup (B N hN) := hB N hN\n  have h3 : sSupIndep (B N hN) := hB' N hN\n  have h4 : ⊥ ∉ B N hN := hB'' N hN\n  rw [← h2] at h\n  simp_all [Set.ext_iff]",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h => _\n  rcases H with ⟨N, hN, hBN⟩\n  have h_eq : B N hN = {N} := by\n    rw [← h]\n    simp [Set.ext_iff]\n    intro x\n    constructor\n    · intro hx\n      obtain ⟨M', hM', rfl⟩ := Set.mem_iUnion.mp hx\n      obtain ⟨hM'_in_D, e⟩ := Set.mem_iUnion.mp hM'\n      rw [← e] at hM'_in_D\n      have := hB M' hM'_in_D\n      rw [this] at hM'_in_D\n      simp_all\n    · intro hx\n      simp_all\n  exact hBN h_eq",
