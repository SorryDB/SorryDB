      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_mem : N ∈ D := hN\n  have h_ref : D ≤ refinement B hB hB' hB'' := refinement_le B hB hB' hB''\n  have h_sub : B N hN ⊆ refinement B hB hB' hB'' := by\n    intro x hx\n    simp only [Set.mem_iUnion, Set.mem_iUnion2]\n    exact ⟨N, hN, hx⟩\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  rw [← h_sSup_eq]\n  have h_in_ref : N ∈ refinement B hB hB' hB'' := by\n    rw [Set.mem_iUnion, Set.mem_iUnion2]\n    exact ⟨N, hN, by aesop⟩\n  have h_eq_B : B N hN = {N} := by\n    apply Set.ext\n    intro x\n    constructor\n    · intro hx\n      have h_x_le_N : x ≤ N := le_sSup hx\n      have h_N_le_x : N ≤ x := by\n        have h_x_in_ref : x ∈ refinement B hB hB' hB'' := h_sub hx\n        have h_x_eq_N : x = N := by\n          rw [← h_eq] at h_x_in_ref\n          aesop\n        rw [h_x_eq_N]\n        rfl\n      exact le_antisymm h_x_le_N h_N_le_x\n    · intro hx\n      simp only [Set.mem_singleton_iff] at hx\n      rw [hx]\n      have h_N_in_B : N ∈ B N hN := by\n        rw [← h_sSup_eq]\n        exact le_sSup_self\n      exact h_N_in_B\n  contradiction",
      "by\n  refine' ⟨refinement_le B hB hB' hB'', _⟩\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    rw [← h_eq]\n    simp only [SetLike.coe, DirectSumDecomposition.refinement, Set.mem_iUnion]\n    intro x hx\n    obtain ⟨M', hM', rfl⟩ := hx\n    exact hM'\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_sSup_eq' : sSup (B N hN) = sSup {N} := by\n    rw [← h_eq, DirectSumDecomposition.refinement] at *\n    simp only [SetLike.coe, Set.iUnion, Set.mem_iUnion]\n    aesop\n  rw [sSup_singleton] at h_sSup_eq'\n  have h_eq_set : B N hN = {N} := by\n    apply le_antisymm\n    · intro x hx\n      have h_le : x ≤ N := by\n        rw [← h_sSup_eq]\n        apply le_sSup hx\n      have h_ge : N ≤ x := by\n        rw [← h_sSup_eq']\n        apply le_sSup\n        simp only [Set.mem_singleton_iff]\n        aesop\n      exact (le_antisymm h_le h_ge).symm ▸ Set.mem_singleton x\n    · intro x hx\n      simp only [Set.mem_singleton_iff] at hx\n      rw [hx]\n      have h_mem : N ∈ B N hN := by\n        rw [← h_sSup_eq]\n        apply le_sSup_iff.mpr\n        intro y hy\n        aesop\n      aesop\n  contradiction",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h => _\n  rcases H with ⟨N, hN, hNe⟩\n  have h1 : B N hN ⊆ D.carrier := by\n    intro x hx\n    rw [Set.mem_iUnion, Set.mem_iUnion]\n    exact ⟨N, hN, hx⟩\n  have h2 : D.carrier ⊆ B N hN := by\n    intro x hx\n    rw [← h] at hx\n    simp only [Set.mem_iUnion, Set.mem_iUnion] at hx\n    rcases hx with ⟨M', hM', hx'⟩\n    have h3 : M' = N := by\n      apply D.sSupIndep'.disjoint_sSup_eq_of_mem hx' hM'\n      intro y hy\n      simp only [Set.mem_singleton_iff] at hy\n      rw [hy]\n      exact le_rfl\n    rw [h3] at hx'\n    exact hx'\n  exact hNe (Set.Subset.antisymm h1 h2)",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    rw [← h_eq]\n    simp only [SetLike.coe, DirectSumDecomposition.refinement, Set.mem_iUnion]\n    intro x hx\n    obtain ⟨M', hM', rfl⟩ := Set.mem_iUnion.mp hx\n    exact hM'\n  have h_eq' : B N hN = {N} := by\n    apply Set.ext\n    intro x\n    simp\n    intro hx\n    have h_mem : x ∈ D := h_sub hx\n    have h_disj : Disjoint x N := by\n      apply D.sSupIndep'.disjoint_of_ne\n      · exact h_mem\n      · exact hN\n      · intro h_eq''\n        rw [h_eq''] at hx\n        simp_all\n    have h_le : x ≤ N := by\n      rw [hB N hN]\n      apply le_sSup hx\n    have h_bot : x = ⊥ := Disjoint.eq_bot_of_le h_disj h_le\n    contradiction\n  contradiction",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    rw [← h_eq]\n    simp only [SetLike.coe_mk, Set.mem_iUnion, exists_prop, and_imp]\n    intro x hx\n    exact ⟨N, hN, hx⟩\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_sSup_eq' : sSup (B N hN) = sSup {N} := by rw [h_eq, Set.iUnion_eq_iff] at *; aesop\n  rw [sSup_singleton] at h_sSup_eq'\n  exact h_ne (by ext x; constructor <;> intro hx <;> simp_all)",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    rw [← h_eq]\n    simp only [SetLike.coe, DirectSumDecomposition.refinement, Set.mem_iUnion]\n    intro x hx\n    obtain ⟨M', hM', hM''⟩ := hx\n    exact hM''\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_sSup_eq' : sSup (B N hN) = sSup {N} := by\n    rw [← h_eq, DirectSumDecomposition.refinement] at *\n    simp_all [Set.iUnion, Set.sUnion, Set.mem_iUnion]\n  rw [sSup_singleton] at h_sSup_eq'\n  rw [h_sSup_eq'] at h_sSup_eq\n  have h_eq_set : B N hN = {N} := by\n    apply le_antisymm\n    · intro x hx\n      have h_le : x ≤ N := by\n        rw [← h_sSup_eq]\n        apply le_sSup hx\n      have h_ge : N ≤ x := by\n        rw [← h_sSup_eq']\n        apply le_sSup\n        simp_all\n      exact le_antisymm h_le h_ge\n    · intro x hx\n      simp_all\n  exact h_ne h_eq_set",
