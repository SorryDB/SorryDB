theorem getElem_flatten_aux₂ (L : List (List α)) (i : Nat) (h : i < L.flatten.length) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    have hj : j < L.length := getElem_flatten_aux₁ L i h
    let k := i - (L.take j).flatten.length
    k < L[j].length := by
  have h1 : (L.take j).flatten.length = (L.take j).map length.sum := by
    simp [sum_eq_foldl, map_length_flatten]
  have h2 : (L.take j).map length.sum = (L.map length).take j.sum := by
    simp [map_take]
  rw [h1, h2] at *
  have h3 : (L.map length).partialSums[j] = (L.map length).take j.sum := by
    simp [getElem_partialSums]
  have h4 : (L.map length).partialSums[j] ≤ i := by
    apply Nat.not_lt.mp
    intro h5
    have h6 : (L.map length).partialSums.findIdx (· > i) ≤ j := by
      apply findIdx_le_of_mem
      simp [h5]
    omega
  have h5 : i < (L.map length).partialSums[j + 1] := by
    apply findIdx_spec
    simp
  have h6 : (L.map length).partialSums[j + 1] = (L.map length).partialSums[j] + L[j].length := by
    simp [getElem_partialSums, take_succ, sum_cons]
  omega
