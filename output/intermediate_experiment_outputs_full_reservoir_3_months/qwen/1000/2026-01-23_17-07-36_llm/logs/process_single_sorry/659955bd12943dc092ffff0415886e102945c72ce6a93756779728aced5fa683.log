      "\n  have h₁ : p ≠ 0 := Nat.Prime.ne_zero h.out\n  have h₂ : p ≠ 1 := Nat.Prime.ne_one h.out\n  have h₃ : ∃ x : ZMod p, x ^ 2 = -1 := by\n    have h₄ : p % 4 = 1 := hp\n    have h₅ : p.Prime := h.out\n    have h₆ : (-1 : ZMod p) ^ ((p - 1) / 2) = 1 := by\n      rw [ZMod.pow_card_sub_one_eq_one]\n      · simp [h₁]\n      · omega\n    exact ZMod.exists_sq_eq_neg_one_of_prime_of_mod_four_eq_one h₅ h₄\n  obtain ⟨x, hx⟩ := h₃\n  let S := { (a, b) : ℕ × ℕ | a ^ 2 + b ^ 2 = p }\n  have h₄ : S.Nonempty := by\n    apply Set.nonempty_of_mem\n    use (x.val : ℕ), 1\n    rw [← Nat.cast_inj]\n    · rw [Nat.cast_add, Nat.cast_pow, Nat.cast_pow]\n      simp [hx, ZMod.natCast_zmod_eq_zero_iff_dvd]\n    · positivity\n  obtain ⟨a, b, hab⟩ := Set.nonempty.mp h₄\n  exact ⟨a, b, hab⟩",
