import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have h1 : (n - 3 : ℝ) < 2 * d / p := by
    have h_lower : ∀ i : Fin n, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) > (n - 3) * dist (P i) (P (i + 1)) := by
      intro i
      have h_convex : ∀ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) > dist (P i) (P (i + 1)) := by
        intro j hj
        have h_angle : (∡ (P (i - 1)) (P i) (P j)).sign = 1 := hP i j (by simp_all [Finset.mem_diff]) (by simp_all [Finset.mem_diff])
        have h_triangle : dist (P i) (P j) + dist (P j) (P (i + 1)) > dist (P i) (P (i + 1)) := by
          apply dist_triangle_lt
          intro h_eq
          simp_all [EuclideanGeometry.oangle_eq_zero_iff]
        linarith [dist_pos.mpr (by intro h; simp_all [EuclideanGeometry.oangle_eq_zero_iff])]
      calc
        ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j)
          > ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P (i + 1)) := by
            apply Finset.sum_lt_sum
            · intro j hj
              exact h_convex j hj
            · use i + 2
              simp_all [Finset.mem_diff]
        _ = (n - 3) * dist (P i) (P (i + 1)) := by
            simp [Finset.sum_const, Finset.card_erase_le, hn]
    calc
      2 * d = ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := by
        rw [hd]; field_simp
      _ > ∑ i, (n - 3) * dist (P i) (P (i + 1)) := by
        apply Finset.sum_lt_sum
        · intro i _
          exact h_lower i
        · use 0
          simp_all
      _ = (n - 3) * p := by
        rw [hp]; simp [Finset.mul_sum]
      _ = (n - 3) * ↑p := by rfl
    apply lt_of_sub_pos
    field_simp
    linarith
  have h2 : (2 * d / p : ℝ) < ↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ - 2 := by
    have h_upper : ∀ i j : Fin n, i ≠ j → i ≠ j - 1 → i ≠ j + 1 → dist (P i) (P j) < p := by
      intro i j hij h1 h2
      have h_path : dist (P i) (P j) ≤ ∑ k in Finset.Ico (i : ℕ) (j : ℕ), dist (P k) (P (k + 1)) := by
        apply dist_le_Ico_sum_of_cyclic
        assumption
      have h_sum : ∑ k in Finset.Ico (i : ℕ) (j : ℕ), dist (P k) (P (k + 1)) < p := by
        apply Finset.sum_lt_sum_of_subset_of_ne
        · apply Finset.Ico_subset_univ
        · use i
          simp_all
      linarith
    have h_count : (∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, 1) = n * (n - 3) := by
      simp [Finset.sum_const, Finset.card_erase_le, hn]
    calc
      2 * d = ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := by
        rw [hd]; field_simp
      _ < ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, p := by
        apply Finset.sum_lt_sum
        · intro i _
          apply Finset.sum_lt_sum
          · intro j hj
            apply h_upper
            · intro h
              simp_all
            · intro h
              simp_all
            · intro h
              simp_all
          · use i + 2
            simp_all
        · use 0
          simp_all
      _ = n * (n - 3) * p := by
        rw [h_count]; simp [Finset.sum_const]
    apply lt_of_sub_pos
    field_simp
    nlinarith [Nat.floor_eq_iff.mpr ⟨by nlinarith, by nlinarith⟩]
  exact ⟨h1, h2⟩
