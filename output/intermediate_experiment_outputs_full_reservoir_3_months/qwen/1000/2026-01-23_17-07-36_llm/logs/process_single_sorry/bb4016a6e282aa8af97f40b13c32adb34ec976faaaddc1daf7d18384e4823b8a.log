      "\n  have h1 : (n - 3 : ℝ) < 2 * d / p := by\n    have : (0 : ℝ) < p := by\n      apply Finset.sum_pos\n      · intro i _\n        exact dist_pos.mpr (by\n          have : P i ≠ P (i + 1) := by\n            intro h\n            have := hP i (i + 1)\n            simp_all [Fin.val_add, Fin.val_one, Fin.val_sub, Nat.succ_le_iff]\n          exact this)\n      · exact Finset.nonempty_univ\n    rw [← hp, ← hd]\n    field_simp [this.ne']\n    refine' lt_of_sub_pos _\n    field_simp\n    ring_nf\n    nlinarith [Nat.sub_pos_of_lt hn]\n  have h2 : (2 * d / p : ℝ) < ↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ - 2 := by\n    have : (0 : ℝ) < p := by\n      apply Finset.sum_pos\n      · intro i _\n        exact dist_pos.mpr (by\n          have : P i ≠ P (i + 1) := by\n            intro h\n            have := hP i (i + 1)\n            simp_all [Fin.val_add, Fin.val_one, Fin.val_sub, Nat.succ_le_iff]\n          exact this)\n      · exact Finset.nonempty_univ\n    rw [← hp, ← hd]\n    field_simp [this.ne']\n    refine' lt_of_sub_pos _\n    field_simp\n    ring_nf\n    nlinarith [Nat.floor_le (by positivity : (0 : ℝ) ≤ n),\n      Nat.lt_floor_add_one (by positivity : (0 : ℝ) ≤ (n : ℝ) / 2),\n      Nat.lt_floor_add_one (by positivity : (0 : ℝ) ≤ (n + 1 : ℝ) / 2)]\n  exact ⟨h1, h2⟩",
      "\n  have h1 : (n - 3 : ℝ) < 2 * d / p := by\n    have h_lower : ∀ i : Fin n, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) > (n - 3) * dist (P i) (P (i + 1)) := by\n      intro i\n      have h_convex : ∀ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) > dist (P i) (P (i + 1)) := by\n        intro j hj\n        have h_angle : (∡ (P (i - 1)) (P i) (P j)).sign = 1 := hP i j (by simp_all [Finset.mem_diff]) (by simp_all [Finset.mem_diff])\n        have h_triangle : dist (P i) (P j) + dist (P j) (P (i + 1)) > dist (P i) (P (i + 1)) := by\n          apply dist_triangle_lt\n          intro h_eq\n          simp_all [EuclideanGeometry.oangle_eq_zero_iff]\n        linarith [dist_pos.mpr (by intro h; simp_all [EuclideanGeometry.oangle_eq_zero_iff])]\n      calc\n        ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j)\n          > ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P (i + 1)) := by\n            apply Finset.sum_lt_sum\n            · intro j hj\n              exact h_convex j hj\n            · use i + 2\n              simp_all [Finset.mem_diff]\n        _ = (n - 3) * dist (P i) (P (i + 1)) := by\n            simp [Finset.sum_const, Finset.card_erase_le, hn]\n    calc\n      2 * d = ∑ i, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) := by\n        rw [hd]; field_simp\n      _ > ∑ i, (n - 3) * dist (P i) (P (i + 1)) := by\n        apply Finset.sum_lt_sum\n        · intro i _\n          exact h_lower i\n        · use 0\n          simp_all\n      _ = (n - 3) * p := by\n        rw [hp]; simp [Finset.mul_sum]\n      _ = (n - 3) * ↑p := by rfl\n    apply lt_of_sub_pos\n    field_simp\n    linarith\n  have h2 : (2 * d / p : ℝ) < ↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ - 2 := by\n    have h_upper : ∀ i j : Fin n, i ≠ j → i ≠ j - 1 → i ≠ j + 1 → dist (P i) (P j) < p := by\n      intro i j hij h1 h2\n      have h_path : dist (P i) (P j) ≤ ∑ k in Finset.Ico (i : ℕ) (j : ℕ), dist (P k) (P (k + 1)) := by\n        apply dist_le_Ico_sum_o