        intro i j
        have h_path : dist (P i) (P j) ≤ ∑ k in Finset.Ico (min i j) (max i j), dist (P k) (P (k + 1)) := by
          apply dist_le_path
        have h_bound : ∑ k in Finset.Ico (min i j) (max i j), dist (P k) (P (k + 1)) ≤ p := by
          apply Finset.sum_le_sum_of_subset_of_nonneg
          · intro k hk
            simp only [Finset.mem_Ico, Finset.mem_univ, true_and] at hk
            simp
          · intro k _ _
            apply dist_nonneg
        linarith
      calc
        2 * d = ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := by
          rw [hd]
          field_simp
        _ ≤ ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, p := by
          apply Finset.sum_le_sum
          intro i _
          apply Finset.sum_le_sum
          intro j hj
          exact max_dist i j
        _ = (∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, 1) * p := by
          simp [Finset.sum_mul]
        _ = n * (n - 3) * p := by
          rw [total_pairs]
        _ < (↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ - 2) * p := by
          have h_floor : ↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ = n * (n - 1) / 2 := by
            cases' mod_two_eq_zero_or_one n with h_even h_odd
            · rw [h_even, Nat.cast_add, Nat.cast_mul, Nat.cast_two]
              field_simp
              ring
            · rw [h_odd, Nat.cast_add, Nat.cast_mul, Nat.cast_two]
              field_simp
              ring
          rw [h_floor]
          apply lt_of_sub_pos
          field_simp
          ring_nf
          nlinarith
    apply lt_of_sub_pos
    field_simp
    nlinarith
  exact ⟨h1, h2⟩
