import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have h1 : (n - 3 : ℝ) < 2 * d / p := by
    have : (0 : ℝ) < p := by
      apply Finset.sum_pos
      · intro i _
        exact dist_pos.mpr (by
          have : P i ≠ P (i + 1) := by
            intro h
            have := hP i (i + 1)
            simp_all [Fin.succ_ne_self]
          exact this)
      · exact Finset.nonempty_univ
    rw [← hp]
    apply lt_of_sub_pos
    field_simp
    ring_nf
    norm_cast
    have : (n - 3 : ℕ) * p < 2 * d := by
      clear h1
      have : ∀ i : Fin n, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) > (n - 3 : ℕ) * dist (P i) (P (i + 1)) := by
        intro i
        have : Finset.card (Finset.univ \ {i - 1, i, i + 1}) = n - 3 := by
          rw [Finset.card_sdiff]
          · simp [Finset.card_univ, Finset.card_insert_of_not_mem, Finset.card_singleton]
            have : i - 1 ≠ i := by
              intro h
              have : (i : ℕ) - 1 = i := by simpa using congr_arg (fun x => (x : ℕ)) h
              omega
            have : i + 1 ≠ i := by
              intro h
              have : (i : ℕ) + 1 = i := by simpa using congr_arg (fun x => (x : ℕ)) h
              omega
            have : i - 1 ≠ i + 1 := by
              intro h
              have : (i : ℕ) - 1 = i + 1 := by simpa using congr_arg (fun x => (x : ℕ)) h
              omega
            simp_all
          · simp
        have : ∀ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) > dist (P i) (P (i + 1)) := by
          intro j hj
          have : j ≠ i - 1 ∧ j ≠ i ∧ j ≠ i + 1 := by
            simp_all
          have : (∡ (P (i - 1)) (P i) (P j)).sign = 1 := hP i j (by simp_all) (by simp_all)
          have : dist (P i) (P j) > dist (P i) (P (i + 1)) := by
            sorry
          exact this
        calc
          ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j)
            > ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P (i + 1)) := Finset.sum_lt_sum this (by simp)
          _ = (n - 3 : ℕ) * dist (P i) (P (i + 1)) := by
            simp [this]
      calc
        (n - 3 : ℕ) * p = (n - 3 : ℕ) * ∑ i, dist (P i) (P (i + 1)) := by rw [hp]
        _ = ∑ i, (n - 3 : ℕ) * dist (P i) (P (i + 1)) := by simp [Finset.mul_sum]
        _ < ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := Finset.sum_lt_sum this (by simp)
        _ = 2 * d := by rw [hd]; ring
    exact mod_cast this
  have h2 : (2 * d / p : ℝ) < ↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ - 2 := by
    sorry
  exact ⟨h1, h2⟩
