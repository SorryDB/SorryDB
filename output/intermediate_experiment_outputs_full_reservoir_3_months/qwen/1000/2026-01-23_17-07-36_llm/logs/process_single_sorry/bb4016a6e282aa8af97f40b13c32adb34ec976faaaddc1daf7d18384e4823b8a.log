      "\n  have h1 : (n - 3 : ℝ) < 2 * d / p := by\n    have : (p : ℝ) > 0 := by\n      refine' Finset.sum_pos (fun i _ => dist_pos.mpr _) _\n      · intro h\n        exact absurd h (by simp [sub_eq_add_neg, add_assoc, add_left_comm])\n      · exact Finset.nonempty_univ\n    apply lt_of_sub_pos\n    field_simp\n    rw [← sub_pos]\n    have : (2 * d : ℝ) = ∑ i, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) := by\n      rw [hd]\n      ring\n    rw [this]\n    clear this\n    have : ∀ i, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) > (n - 3 : ℝ) * dist (P i) (P (i + 1)) := by\n      intro i\n      have : (Finset.univ \\ {i - 1, i, i + 1}).card = n - 3 := by\n        rw [Finset.card_sdiff]\n        · simp [Finset.card_univ, Finset.card_insert_of_not_mem, Finset.card_singleton]\n          omega\n        · simp [Finset.mem_univ]\n      have : ∀ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) > dist (P i) (P (i + 1)) := by\n        intro j hj\n        have : j ≠ i - 1 ∧ j ≠ i ∧ j ≠ i + 1 := by\n          simp [Finset.mem_sdiff, Finset.mem_univ] at hj\n          tauto\n        have : dist (P i) (P j) > dist (P i) (P (i + 1)) := by\n          apply lt_of_not_ge\n          intro h\n          have : (∡ (P (i - 1)) (P i) (P j)).sign = 1 := hP i j (by tauto) (by tauto)\n          have : (∡ (P (i - 1)) (P i) (P (i + 1))).sign = 1 := hP i (i + 1) (by simp) (by simp)\n          have : (∡ (P (i - 1)) (P i) (P j)) = (∡ (P (i - 1)) (P i) (P (i + 1))) + (∡ (P (i + 1)) (P i) (P j)) := by\n            apply oangle_add\n            · intro h\n              have : j = i + 1 := by\n                apply Fin.eq_of_veq\n                simp_all\n              contradiction\n            · intro h\n              have : j = i - 1 := by\n                apply Fin.eq_of_veq\n                simp_all\n              contradiction\n          rw [this] at this\n          simp_all\n        exact this\n      calc\n        ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j)\n          > ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P (i + 1)) := Finset.sum_lt_sum this (by simp)\n        _ = (n - 3 : ℝ) * dist (P i) (P (i + 1)) := by\n          simp [Finset.sum_const, this]\n    calc\n      (∑ i, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j)) - (n - 3 : ℝ) * p\n        = ∑ i, (∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) - (n - 3 : ℝ) * dist (P i) (P (i + 1))) := by\n          simp [hp, Finset.sum_sub_distrib, Finset.mul_sum]\n        > 0 := by\n          apply Finset.sum_pos\n          · intro i _\n            exact sub_pos.mpr (this i)\n          · exact Finset.nonempty_univ\n  have h2 : (2 * d / p : ℝ) < ↑⌊↑n / 2⌋ * ↑⌊(↑n + 1) / 2⌋ - 2 := by\n    have : (p : ℝ) > 0 := by\n      refine' Finset.sum_pos (fun i _ => dist_pos.mpr _) _\n      · intro h\n        exact absurd h (by simp [sub_eq_add_neg, add_assoc, add_left_comm])\n      · exact Finset.nonempty_univ\n    apply lt_of_sub_pos\n    field_simp\n    rw [← sub_pos]\n    have : (2 * d : ℝ) = ∑ i, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) := by\n      rw [hd]\n      ring\n    rw [this]\n    clear this\n    have : ∀ i j, i ≠ j → dist (P i) (P j) ≤ p := by\n      intro i j hij\n      have : dist (P i) (P j) ≤ ∑ k in Finset.Ico i.val j.val, dist (P k) (P (k + 1)) ∨\n          dist (P i) (P j) ≤ ∑ k in Finset.Ico j.val i.val, dist (P k) (P (k + 1)) := by\n        apply le_total_of_le_of_le\n        · apply dist_le_of_path\n          intro k hk\n          simp_all\n        · apply dist_le_of_path\n          intro k hk\n          simp_all\n      cases' this with h h <;>\n        calc\n          dist (P i) (P j) ≤ ∑ k in Finset.Ico i.val j.val, dist (P k) (P (k + 1)) ∨\n              dist (P i) (P j) ≤ ∑ k in Finset.Ico j.val i.val, dist (P k) (P (k + 1)) := by\n            tauto\n          _ ≤ p := by\n            apply le_of_sub_nonneg\n            simp_all [hp]\n            apply Finset.sum_le_sum_of_subset_of_nonneg\n            · apply F