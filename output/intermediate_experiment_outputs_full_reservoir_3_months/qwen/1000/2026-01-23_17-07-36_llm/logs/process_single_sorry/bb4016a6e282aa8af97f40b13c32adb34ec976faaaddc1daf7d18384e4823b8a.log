    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have h1 : (n - 3 : ℝ) < 2 * d / p := by
    apply lt_of_sub_pos
    field_simp
    norm_cast
    have key : ∀ i : Fin n, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) > (n - 3) * dist (P i) (P (i + 1)) := by
      intro i
      have h_convex : ∀ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) > dist (P i) (P (i + 1)) := by
        intro j hj
        have h_not_adj : j ≠ i - 1 ∧ j ≠ i ∧ j ≠ i + 1 := by
          simp only [Finset.mem_diff, Finset.mem_univ, true_and, ne_eq, not_false_eq_true] at hj
          tauto
        exact by
          have h_angle : (∡ (P (i - 1)) (P i) (P j)).sign = 1 := hP i j h_not_adj.1 h_not_adj.2.1
          have h_triangle : dist (P i) (P j) + dist (P j) (P (i + 1)) > dist (P i) (P (i + 1)) := by
            apply dist_triangle_lt
            intro h_eq
            simp_all
          linarith [dist_nonneg (P i) (P j), dist_nonneg (P j) (P (i + 1))]
      calc
        ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j)
