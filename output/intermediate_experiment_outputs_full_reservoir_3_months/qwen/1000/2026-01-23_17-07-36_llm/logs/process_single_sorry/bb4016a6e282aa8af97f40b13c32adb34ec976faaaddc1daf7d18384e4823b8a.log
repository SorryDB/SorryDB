        field_simp
      _ > ∑ i, (n - 3) * dist (P i) (P (i + 1)) := by
        apply Finset.sum_lt_sum
        · intro i _
          exact key i
        · use 0
          simp
      _ = (n - 3) * ∑ i, dist (P i) (P (i + 1)) := by
        simp [Finset.mul_sum]
      _ = (n - 3) * p := by
        rw [hp]
  have h2 : (2 * d / p : ℝ) < ↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ - 2 := by
    have key_upper : 2 * d < (↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ - 2) * p := by
