      "\n  have h1 : 0 < p := by\n    apply Nat.cast_pos.mpr\n    exact Nat.pos_of_ne_zero fun h => by simp_all [Nat.succ_le_iff]\n  have h2 : 0 < d := by\n    apply Nat.cast_pos.mpr\n    exact Nat.pos_of_ne_zero fun h => by\n      simp_all [Nat.succ_le_iff]\n      have h3 : n ≥ 4 := by linarith\n      have h4 : Finset.card (Finset.univ : Finset (Fin n)) = n := by simp\n      have h5 : Finset.card (Finset.univ \\ {0, 1, 2}) ≥ 1 := by\n        rw [Finset.card_sdiff]\n        swap; decide\n        omega\n      omega\n  constructor\n  · apply lt_of_sub_pos\n    field_simp\n    nlinarith [h1, h2]\n  · apply lt_of_sub_pos\n    field_simp\n    nlinarith [h1, h2, Nat.floor_le (by positivity : (0 : ℝ) ≤ n / 2),\n      Nat.floor_le (by positivity : (0 : ℝ) ≤ (n + 1) / 2)]",
