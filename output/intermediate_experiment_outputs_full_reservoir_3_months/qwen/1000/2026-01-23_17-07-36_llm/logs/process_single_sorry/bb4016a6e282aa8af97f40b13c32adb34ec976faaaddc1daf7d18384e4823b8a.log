      "\n  have h1 : (n - 3 : ℝ) < 2 * d / p := by\n    have h_lower : ∀ i : Fin n, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) > (n - 3) * dist (P i) (P (i + 1)) := by\n      intro i\n      have h_convex : ∀ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) > dist (P i) (P (i + 1)) := by\n        intro j hj\n        have h_ne : j ≠ i - 1 ∧ j ≠ i ∧ j ≠ i + 1 := by\n          simp only [Finset.mem_diff, Finset.mem_univ, true_and, ne_eq, not_false_eq_true] at hj\n          tauto\n        have h_angle : (∡ (P (i - 1)) (P i) (P j)).sign = 1 := hP i j h_ne.1 h_ne.2.1\n        have h_triangle : dist (P i) (P j) + dist (P j) (P (i + 1)) > dist (P i) (P (i + 1)) := by\n          apply dist_triangle_lt\n          intro h_eq\n          have h_collinear : (∡ (P (i - 1)) (P i) (P j)).sign = 0 := by\n            rw [← sub_eq_zero] at h_eq\n            simp_all [EuclideanGeometry.oangle_eq_zero_iff]\n          linarith\n        linarith\n      calc\n        ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j)\n          > ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P (i + 1)) := by\n            apply Finset.sum_lt_sum\n            · intro j hj\n              exact h_convex j hj\n            · use i + 2\n              simp only [Finset.mem_diff, Finset.mem_univ, true_and, ne_eq, not_false_eq_true]\n              norm_num\n              omega\n          _ = (n - 3) * dist (P i) (P (i + 1)) := by\n            simp [Finset.sum_const, Finset.card_erase_of_mem, Finset.card_erase_of_mem, Finset.card_univ]\n            <;> omega\n    calc\n      2 * d = ∑ i, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) := by\n        rw [hd]\n        field_simp\n      _ > ∑ i, (n - 3) * dist (P i) (P (i + 1)) := by\n        apply Finset.sum_lt_sum\n        · intro i _\n          exact h_lower i\n        · use 0\n          simp\n      _ = (n - 3) * p := by\n        rw [hp]\n        simp [Finset.mul_sum]\n      _ = (n - 3) * ↑p := by\n        rfl\n      _ = ↑((n - 3) * p) := by\n        rfl\n    apply lt_of_sub_pos\n    field_simp\n    linarith\n  have h2 : (2 * d / p : ℝ) < ↑⌊(n : ℝ) / 2⌋ * ↑⌊(n + 1 : ℝ) / 2⌋ - 2 := by\n    have h_upper : ∀ i : Fin n, ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) < (n - 3) * (∑ k, dist (P k) (P (k + 1))) / 2 := by\n      intro i\n      have h_bound : ∀ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j) < ∑ k, dist (P k) (P (k + 1)) / 2 := by\n        intro j hj\n        have h_ne : j ≠ i - 1 ∧ j ≠ i ∧ j ≠ i + 1 := by\n          simp only [Finset.mem_diff, Finset.mem_univ, true_and, ne_eq, not_false_eq_true] at hj\n          tauto\n        have h_path : dist (P i) (P j) ≤ ∑ k in Finset.Ico (i.val) (j.val), dist (P k) (P (k + 1)) ∨\n            dist (P i) (P j) ≤ ∑ k in Finset.Ico (j.val) (i.val), dist (P k) (P (k + 1)) := by\n          apply le_total_of_le_of_le\n          · apply dist_le_of_path\n            intro k hk\n            simp_all\n          · apply dist_le_of_path\n            intro k hk\n            simp_all\n        cases' h_path with h_path h_path <;>\n          calc\n            dist (P i) (P j) ≤ ∑ k in Finset.Ico (i.val) (j.val), dist (P k) (P (k + 1)) := h_path\n            _ ≤ ∑ k, dist (P k) (P (k + 1)) := by\n              apply Finset.sum_le_sum_of_subset_of_nonneg\n              · apply Finset.Ico_subset_univ\n              · intro k _ _\n                apply dist_nonneg\n            _ = p := by\n              rw [hp]\n            _ < p / 2 + p / 2 := by\n              linarith\n            _ = p := by\n              ring\n            _ = ∑ k, dist (P k) (P (k + 1)) := by\n              rw [hp]\n      calc\n        ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, dist (P i) (P j)\n          < ∑ j ∈ Finset.univ \\ {i - 1, i, i + 1}, (∑ k, dist (P k) (P (k + 1))) / 2 := by\n            apply Finset.sum_lt_sum\n            · intro j hj\n              exact h_bound j hj\n            · use i + 2\n              simp only [Finset.mem_diff, Finset.mem_univ, true_and, ne