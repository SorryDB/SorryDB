theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        let prefix_len := (List.take idx (l.map List.length)).sum
        let idx' := ⟨prefix_len + idx1, by
          calc
            prefix_len + idx1
              = (List.take idx (l.map List.length)).sum + idx1 := rfl
            _ < (List.take idx (l.map List.length)).sum + l1.length := Nat.add_lt_add_left hidx1 _
            _ ≤ (List.take idx (l.map List.length)).sum + l1.length + (List.drop (idx + 1) (l.map List.length)).sum := Nat.le_add_right _ _
            _ = (l.set idx l1).flatten.length := by
                rw [List.flatten_eq_bind, List.bind_set, List.bind_take, List.bind_drop]
                simp [List.sum_map_length_bind, List.length_bind, List.sum_take_add_sum_drop]
        ⟩
        refine' ⟨idx', _, _⟩
        · rw [list_set_flatten _ _ _ hidx, List.eraseIdx_insertIdx_cancel hidx1]
        · rw [list_set_flatten _ _ _ hidx]
          simp [List.getElem_insertIdx_self hidx1]
