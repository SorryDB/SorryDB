-- exercise 1.4.i
noncomputable def NatIso_inverse {α β : Type*} [C : Category α] [D : Category β]
    {F G : Functor α β} (η : NaturalTransformation F G) (h : IsNatIso η) :
    NaturalTransformation G F where
  arrow X := by
    have := h X
    rw [iso_iff_isIso] at this
    choose f hf using this
    exact f.inv

  naturality {X Y} f := by
    have hx := h X
    have hy := h Y
    rw [iso_iff_isIso] at hx hy
    cases' Classical.choose_spec hx with _ hx'
    cases' Classical.choose_spec hy with _ hy'
    simp_all [NaturalTransformation.naturality, ← comp_assoc, hx'.inv_comp_eq, hy'.comp_inv_eq]
```
