        rw [← Finset.filter_union_filter_neg_eq, Finset.card_union_add_card_inter]
        simp [Finset.filter_inter_filter, Finset.filter_empty]
      cases' Nat.even_or_odd (i : ℕ) with hi hi <;> simp_all [hi]
    · simp [Finset.filter_card]
      have h_total_count : ∑ i : Fin n, 2 = 2 * n := by simp
      rw [← h_total_count]
      apply Finset.sum_congr rfl
      intro i _
      have h_preimage : (Finset.univ.filter (fun j => c j = i)).card = 4 := h i
      cases' Nat.even_or_odd (i : ℕ) with hi hi <;> simp_all [hi]
  obtain ⟨S, hS_color, hS_card⟩ := h_partition
  use S
