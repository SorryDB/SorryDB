import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  classical
  let U := Finset.univ : Finset (Fin (4 * n))
  have hU : U.card = 4 * n := by simp
  have hc : ∀ i : Fin n, (Finset.filter (fun j => c j = i) U).card = 4 := by
    intro i
    rw [Finset.filter_eq', h]
  have hsum : ∑ i in U, ((i : ℕ) + 1) = ∑ i in U, (i : ℕ) + ∑ i in U, 1 := by
    simp [Finset.sum_add_distrib]
  have hsum' : ∑ i in U, (i : ℕ) = (4 * n) * (4 * n - 1) / 2 := by
    simp [Finset.sum_Ico_eq_sum_range, Finset.sum_range_id]
  have hsum'' : ∑ i in U, 1 = 4 * n := by simp
  have htotal : ∑ i in U, ((i : ℕ) + 1) = (4 * n) * (4 * n + 1) / 2 := by
    rw [hsum, hsum', hsum'']
    ring
  have h_even : Even ((4 * n) * (4 * n + 1) / 2) := by
    cases' Nat.even_or_odd (4 * n) with h4n h4n <;> simp_all [Nat.even_mul, Nat.even_add]
  obtain ⟨T, hT⟩ := exists_subset_sum_eq_half_of_even_total (by simp_all)
  use T
  constructor
  · exact hT
  · intro i
    have hTi : (Finset.filter (fun j => c j = i) U).card = 4 := hc i
    have hTic : (Finset.filter (fun j => c j = i) T).card +
        (Finset.filter (fun j => c j = i) Tᶜ).card = 4 := by
      rw [← Finset.filter_union_filter_compl, Finset.union_compl_self, Finset.filter_univ, hTi]
    suffices (Finset.filter (fun j => c j = i) T).card = 2 by
      simpa [Finset.mem_compl] using this
    have hsymm : (Finset.filter (fun j => c j = i) T).card =
        (Finset.filter (fun j => c j = i) Tᶜ).card := by
      apply Eq.symm
      apply Eq.symm
      have hsumT : ∑ j in Finset.filter (fun j => c j = i) T, ((j : ℕ) + 1) +
          ∑ j in Finset.filter (fun j => c j = i) Tᶜ, ((j : ℕ) + 1) =
          ∑ j in Finset.filter (fun j => c j = i) U, ((j : ℕ) + 1) := by
        rw [← Finset.sum_union, Finset.filter_union_filter_compl, Finset.union_compl_self,
          Finset.filter_univ]
        exacts [Finset.disjoint_filter_filter_compl _ _, rfl]
      have hsumT' : ∑ j in Finset.filter (fun j => c j = i) T, ((j : ℕ) + 1) =
          ∑ j in Finset.filter (fun j => c j = i) Tᶜ, ((j : ℕ) + 1) := by
        apply Eq.symm
        apply Eq.symm
        have hsumT'' : ∑ j in Finset.filter (fun j => c j = i) T, ((j : ℕ) + 1) +
            ∑ j in Finset.filter (fun j => c j = i) Tᶜ, ((j : ℕ) + 1) =
            2 * ∑ j in Finset.filter (fun j => c j = i) T, ((j : ℕ) + 1) := by
          rw [← hT, ← Finset.sum_sdiff, Finset.sdiff_eq_inter_compl, Finset.sum_union,
