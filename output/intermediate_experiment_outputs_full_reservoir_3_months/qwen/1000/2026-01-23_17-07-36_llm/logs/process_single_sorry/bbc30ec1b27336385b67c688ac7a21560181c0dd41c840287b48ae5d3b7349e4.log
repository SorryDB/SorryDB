  classical
  let total_sum := ∑ i : Fin (4 * n), (i : ℕ) + 1
  have h_total : total_sum = 4 * n * (4 * n + 1) / 2 := by
    simp [Fin.sum_univ_add, Fin.sum_univ_id]
    ring
  have h_even : Even total_sum := by
    rw [h_total]
    apply Nat.even_iff.mpr
    cases' Nat.even_or_odd n with hn hn <;> simp [hn, Nat.mul_mod, Nat.add_mod, Nat.mod_mod]
    <;> omega
  obtain ⟨k, hk⟩ := h_even
  have h_partition : ∃ S : Finset (Fin (4 * n)),
      (∀ i, #{j ∈ S | c j = i} = 2) ∧ S.card = 2 * n := by
    refine' ⟨Finset.univ.filter (fun j => (c j).val % 2 = 0), _, _⟩
    · intro i
      have h_preimage : (Finset.univ.filter (fun j => c j = i)).card = 4 := h i
      have h_split : (Finset.univ.filter (fun j => c j = i ∧ (i : ℕ) % 2 = 0)).card +
