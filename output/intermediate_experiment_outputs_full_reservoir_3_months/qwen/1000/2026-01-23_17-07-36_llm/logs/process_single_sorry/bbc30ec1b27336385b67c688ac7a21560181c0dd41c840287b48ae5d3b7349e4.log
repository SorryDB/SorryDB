  · have h_sum_S : ∑ i ∈ S, (i : ℕ) + 1 = total_sum / 2 := by
      have h_sum_compl : ∑ i ∈ Sᶜ, (i : ℕ) + 1 = total_sum - ∑ i ∈ S, (i : ℕ) + 1 := by
        rw [← Finset.sum_union_add_sum_inter, Finset.union_compl_self, Finset.sum_univ]
        simp [Finset.inter_compl_self]
      rw [hk] at h_sum_compl
      omega
    rw [h_sum_S, hk]
    omega
  · exact hS_color
