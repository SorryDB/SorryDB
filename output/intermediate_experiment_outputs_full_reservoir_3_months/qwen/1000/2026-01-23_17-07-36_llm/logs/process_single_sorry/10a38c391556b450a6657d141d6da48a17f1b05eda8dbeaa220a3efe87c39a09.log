def functor (c : ℤ) : FintypeCat ⥤ LightProfinite where
  obj Si := component Si c
  map := fun {X Y} f => FintypeCat.toLightProfinite.map (Set.imageFactorization (fun a => Finsupp.comp a f) (by
    intro a ha
    simp only [set, Finsupp.mem_support_iff, Finsupp.comp_apply, Set.mem_setOf_eq]
    have : ∑ i ∈ (Finsupp.comp a f).support, |(Finsupp.comp a f) i| ≤ ∑ j ∈ a.support, |a j| := by
      calc
        ∑ i ∈ (Finsupp.comp a f).support, |(Finsupp.comp a f) i|
          = ∑ i ∈ (Finsupp.comp a f).support, |∑ j in {j | f j = i ∧ j ∈ a.support}, a j| := by
            simp [Finsupp.comp_apply, Finset.sum_ite, Finset.sum_const, Nat.cast_id]
        _ ≤ ∑ i ∈ (Finsupp.comp a f).support, ∑ j in {j | f j = i ∧ j ∈ a.support}, |a j| := by
            apply Finset.sum_le_sum
            intro i _
            exact abs_sum_le_sum_abs _ _
        _ = ∑ j ∈ a.support, |a j| := by
            rw [Finset.sum_comm]
            apply Finset.sum_bij
            · intro j hj
              use f j
              simp [hj]
            · intro j hj
              simp [hj]
            · intro i _ j hj k hk h
              simp_all
            · intro j hj
              use j
              simp [hj]
    linarith))
  map_id := by
    ext1
    rfl
  map_comp := by
    ext1
    rfl
