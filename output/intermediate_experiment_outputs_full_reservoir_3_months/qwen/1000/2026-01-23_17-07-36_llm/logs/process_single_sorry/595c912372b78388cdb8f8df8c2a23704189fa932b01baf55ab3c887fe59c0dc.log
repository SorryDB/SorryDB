lemma biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero :
  biasedUpdateState net x i ≠ x → biasedLocalField net x i ≠ 0 → biasedEnergyDiff net x i < 0 := by
  intro h₁ h₂
  rw [biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField]
  have h₃ : (biasedUpdateState net x i i).toReal - (x i).toReal ≠ 0 := by
    intro h₃
    apply h₁
    ext j
    by_cases hj : j = i <;> simp_all [Function.update_same, Function.update_noteq]
  have h₄ : ((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i > 0 := by
    cases' lt_or_gt_of_ne h₂ with h₂ h₂ <;>
    cases' lt_or_gt_of_ne h₃ with h₃ h₃ <;>
    simp_all [biasedUpdateState, biasedLocalField, HopfieldState.toReal] <;>
    nlinarith
  nlinarith
```
