theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro h
    haveI : IsAlgClosed L := h.isAlgClosed
    exact isAlgClosure_iff.2 ⟨inferInstance, Algebra.isAlgebraic_of_finite _⟩
  · intro h
    have : ∀ n : ℕ, (n : K) ≠ 0 → IsCyclotomicExtension {n} K L := by
      intro n hn
      haveI : CharP K p := FiniteField.charP K
      have : ¬p ∣ n := by
        intro hpn
