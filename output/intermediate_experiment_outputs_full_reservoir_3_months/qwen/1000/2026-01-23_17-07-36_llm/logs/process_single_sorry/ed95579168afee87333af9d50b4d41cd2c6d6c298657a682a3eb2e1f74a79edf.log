theorem eq_of_mem_fixedPoints : fixedPoints (secondInvo k) = singletonFixedPoint k := by
  simp only [fixedPoints, IsFixedPt, secondInvo, secondInvo_fun,
    singletonFixedPoint, Prod.mk_one_one, Finset.coe_singleton]
  ext t
  constructor
  · intro ht
    simp at ht
    obtain ⟨⟨⟨x, y, z⟩, hS⟩, hU⟩ := t
    simp_all only [Prod.mk.injEq, Subtype.mk.injEq]
    have h1 : x - y + z = x := by linarith
    have h2 : 2 * y - z = z := by linarith
    have h3 : y = z := by linarith
    rw [h3] at h1
    have h4 : x = y := by linarith
    rw [h4, h3] at hS
    simp_all only [S, Set.mem_setOf_eq, gt_iff_lt]
    have : 4 * y * y + y ^ 2 = 4 * k + 1 := by linarith
    have : 5 * y ^ 2 = 4 * k + 1 := by linarith
    have : y = 1 := by
      have : y > 0 := by linarith
      have : y ≤ k := by nlinarith
      interval_cases y <;> norm_num at this ⊢ <;> nlinarith
    subst this
    have : x = 1 := by linarith
    subst this
    have : z = 1 := by linarith
    subst this
    simp_all
