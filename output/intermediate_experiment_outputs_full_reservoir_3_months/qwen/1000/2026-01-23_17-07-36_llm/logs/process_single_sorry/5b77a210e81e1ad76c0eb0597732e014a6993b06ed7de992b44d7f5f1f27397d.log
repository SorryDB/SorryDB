      "\n  use { n | ∃ k : ℕ, n = ⟨2 ^ k, Nat.pos_of_ne_zero (by simp [Nat.pow_ne_zero])⟩ }\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    · intro i j h\n      simp_all [Nat.pow_succ]\n    · intro k\n      exact ⟨k, rfl⟩\n  · intro m n hmn\n    simp_all [Nat.Coprime, Nat.gcd_comm]\n    intro p hp hm hn\n    have h1 : 2 ^ m.val ≡ 3 [MOD p] := by\n      rw [Nat.ModEq]\n      omega\n    have h2 : 2 ^ n.val ≡ 3 [MOD p] := by\n      rw [Nat.ModEq]\n      omega\n    have h3 : 2 ^ (m.val - n.val) ≡ 1 [MOD p] := by\n      cases' le_or_lt m.val n.val with hle hlt\n      · exfalso\n        simp_all [Nat.sub_eq_zero_of_le]\n      · rw [← Nat.modEq_sub hlt]\n        simpa [Nat.ModEq, Nat.pow_sub] using h1.symm.trans h2\n    have h4 : orderOf (2 % p) ∣ (m.val - n.val) := by\n      apply orderOf_dvd_of_pow_modEq_one\n      · omega\n      · exact h3\n    have h5 : orderOf (2 % p) ∣ (n.val - m.val) := by\n      cases' le_or_lt n.val m.val with hle hlt\n      · exfalso\n        simp_all [Nat.sub_eq_zero_of_le]\n      · rw [← Nat.modEq_sub hlt]\n        simpa [Nat.ModEq, Nat.pow_sub] using h2.symm.trans h1\n    have h6 : orderOf (2 % p) ∣ Nat.gcd (m.val - n.val) (n.val - m.val) := by\n      apply dvd_gcd <;> assumption\n    have h7 : Nat.gcd (m.val - n.val) (n.val - m.val) = Nat.gcd (m.val) (n.val) := by\n      simp [Nat.gcd_comm, Nat.gcd_sub_self_left]\n    rw [h7] at h6\n    have h8 : orderOf (2 % p) ∣ Nat.gcd m.val n.val := by\n      exact h6\n    have h9 : 2 ^ Nat.gcd m.val n.val ≡ 1 [MOD p] := by\n      apply Nat.ModEq.pow_totient\n      · omega\n      · apply Nat.Coprime.symm\n        apply Nat.coprime_of_dvd\n        · omega\n        · intro q hq\n          omega\n    have h10 : 2 ^ Nat.gcd m.val n.val ≡ 3 [MOD p] := by\n      have h11 : Nat.gcd m.val n.val ≤ m.val := Nat.le_of_dvd (Nat.pos_of_ne_zero (by simp_all)) (Nat.gcd_dvd_left _ _)\n      have h12 : Nat.gcd m.val n.val ≤ n.val := Nat.le_of_dvd (Nat.pos_of_ne_zero (by simp_all)) (Nat.gcd_dvd_right _ _)\n      cases' eq_or_lt_of_le h11 with h13 h13 <;> cases' eq_or_lt_of_le h12 with h14 h14 <;> simp_all [Nat.pow_succ]\n    exfalso\n    omega",
      "\n  use {n | ∃ k : ℕ, n = ⟨k + 1, Nat.succ_pos k⟩}\n  constructor\n  · exact Set.infinite_of_injective_forall_mem Nat.succ_injective fun k => ⟨k, rfl⟩\n  · intro m n hmn\n    simp only [Set.mem_setOf_eq] at *\n    obtain ⟨k, rfl⟩ := hmn.1\n    obtain ⟨l, rfl⟩ := hmn.2\n    simp [Nat.coprime_iff_gcd_eq_one]\n    have h₁ : 2 ^ (k + 1) - 3 > 0 := by\n      apply Nat.sub_pos_of_lt\n      norm_num\n      induction k <;> simp_all [Nat.pow_succ, Nat.mul_le_mul]\n    have h₂ : 2 ^ (l + 1) - 3 > 0 := by\n      apply Nat.sub_pos_of_lt\n      norm_num\n      induction l <;> simp_all [Nat.pow_succ, Nat.mul_le_mul]\n    have h₃ : Nat.gcd (2 ^ (k + 1) - 3) (2 ^ (l + 1) - 3) = 1 := by\n      wlog hkl : k < l\n      · specialize Nat.gcd_comm (2 ^ (k + 1) - 3) (2 ^ (l + 1) - 3)\n        simp_all\n      · have h₄ : 2 ^ (l + 1) ≡ 2 ^ (k + 1) * 2 ^ (l - k) [MOD 2 ^ (k + 1) - 3] := by\n          rw [← Nat.pow_add]\n          apply Nat.ModEq.pow\n          apply Nat.ModEq.refl\n        have h₅ : 2 ^ (k + 1) ≡ 3 [MOD 2 ^ (k + 1) - 3] := by\n          rw [Nat.ModEq]\n          simp [Nat.mod_eq_of_lt h₁]\n        have h₆ : 2 ^ (l + 1) ≡ 3 * 2 ^ (l - k) [MOD 2 ^ (k + 1) - 3] := by\n          calc\n            2 ^ (l + 1) ≡ 2 ^ (k + 1) * 2 ^ (l - k) [MOD 2 ^ (k + 1) - 3] := h₄\n            _ ≡ 3 * 2 ^ (l - k) [MOD 2 ^ (k + 1) - 3] := by\n              apply Nat.ModEq.mul_right\n              exact h₅\n        have h₇ : 2 ^ (l + 1) - 3 ≡ 3 * 2 ^ (l - k) - 3 [MOD 2 ^ (k + 1) - 3] := by\n          simpa using h₆.sub (Nat.ModEq.refl 3)\n        have h₈ : Nat.gcd (2 ^ (k + 1) - 3) (2 ^ (l + 1) - 3) = Nat.gcd (2 ^ (k + 1) - 3) (3 * 2 ^ (l - k) - 3) := by\n          rw [Nat.gcd_mod_left]\n        have h₉ : Nat.gcd (2 ^ (k + 1) - 3) (3 * 2 ^ (l - k) - 3) = 1 := by\n          have h₁₀ : Nat.gcd (2 ^ (k + 1) - 3) 3 = 1 := by\n            have h₁₁ : 2 ^ (k + 1) % 3 = if (k + 1) % 2 = 0 then 1 else 2 := by\n              induction k <;> simp_all [Nat.pow_succ, Nat.mul_mod]\n            cases' Nat.mod_two_eq_zero_or_one (k + 1) with h₁₂ h₁₂ <;> simp_all\n            all_goals\n              omega\n          have h₁₁ : Nat.gcd (2 ^ (k + 1) - 3) (3 * (2 ^ (l - k) - 1)) = 1 := by\n            rw [Nat.gcd_mul_right]\n            simp_all\n          simpa using h₁₁\n        simpa using h₉\n    exact h₃",
      "\n  use {n : ℕ+ | ∃ k : ℕ, n = ⟨2 ^ k, Nat.pos_of_ne_zero (by simp [Nat.pow_ne_zero])⟩}\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    · intro i j h\n      simp_all [Nat.pow_succ]\n    · intro k\n      exact ⟨k, rfl⟩\n  · intro m n hmn hm hn\n    obtain ⟨i, rfl⟩ := hm\n    obtain ⟨j, rfl⟩ := hn\n    simp_all [Nat.pow_succ]\n    wlog hij : i < j\n    · cases' lt_or_gt_of_ne hmn with h h <;> simp_all\n    · have : 2 ^ (2 ^ i) ≡ 3 [MOD (2 ^ (2 ^ i) - 3)] := by\n        simp [Nat.ModEq, Nat.mod_eq_of_lt]\n      have : 2 ^ (2 ^ j) ≡ 3 [MOD (2 ^ (2 ^ i) - 3)] := by\n        calc\n          2 ^ (2 ^ j) = (2 ^ (2 ^ i)) ^ (2 ^ (j - i)) := by\n            rw [← Nat.pow_mul, Nat.sub_add_cancel (Nat.le_of_lt hij)]\n          _ ≡ 3 ^ (2 ^ (j - i)) [MOD (2 ^ (2 ^ i) - 3)] := by\n            simpa using this.pow (2 ^ (j - i))\n          _ ≡ 3 [MOD (2 ^ (2 ^ i) - 3)] := by\n            have : 3 ^ (2 ^ (j - i)) ≡ 3 [MOD (2 ^ (2 ^ i) - 3)] := by\n              induction' j - i with t ht\n              · simp [Nat.ModEq]\n              · rw [pow_succ]\n                simpa [Nat.ModEq] using ht.mul (Nat.ModEq.refl 3)\n            exact this\n      have : (2 ^ (2 ^ j) - 3) % (2 ^ (2 ^ i) - 3) = 0 := by\n        simpa [Nat.ModEq, Nat.mod_eq_of_lt] using this\n      have : Nat.gcd (2 ^ (2 ^ i) - 3) (2 ^ (2 ^ j) - 3) = Nat.gcd (2 ^ (2 ^ i) - 3) 0 := by\n        rw [Nat.gcd_rec, this]\n      simp [this]\n      intro h\n      have : 2 ^ (2 ^ i) - 3 = 1 := by\n        omega\n      have : 2 ^ (2 ^ i) = 4 := by\n        omega\n      have : 2 ^ i = 2 := by\n        exact Nat.pow_right_injective (by norm_num) this\n      have : i = 1 := by\n        exact Nat.pow_left_injective (by norm_num) this\n      subst i\n      simp_all",
      "\n  use {n : ℕ+ | ∀ p : ℕ, Nat.Prime p → p ∣ (2 ^ n.val - 3) → ∀ m : ℕ+, m < n → ¬(p ∣ (2 ^ m.val - 3))}\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    intro n\n    use n + 1\n    simp\n    intro p hp hdiv m hm\n    omega\n  · intro m n hmn\n    simp only [Set.mem_setOf_eq] at *\n    have h1 := hmn.1\n    have h2 := hmn.2\n    have h3 : m ≠ n := by\n      rintro rfl\n      simp_all\n    wlog hmn' : m < n\n    · exact hmn'.resolve_left h3\n    · specialize h2 _ (Nat.Prime.ne_zero (Nat.prime_two)) (Nat.dvd_refl _) (by omega)\n      simp_all",
      "\n  use {n | ∃ k : ℕ, n = ⟨2 ^ k, Nat.pos_of_ne_zero (by simp [Nat.pow_ne_zero])⟩}\n  constructor\n  · exact Set.infinite_of_injective_forall_mem (fun k => ⟨2 ^ k, Nat.pos_of_ne_zero (by simp [Nat.pow_ne_zero])⟩)\n      (by intro i j h; simp_all [Nat.pow_left_injective])\n  · intro m n hmn\n    obtain ⟨k, rfl⟩ := hmn.1\n    obtain ⟨l, rfl⟩ := hmn.2\n    intro hkl\n    simp_all [Nat.coprime_iff_gcd_eq_one]\n    have h₁ : 2 ^ (2 ^ k) ≡ 3 [MOD (2 ^ (2 ^ l) - 3)] := by\n      rw [Nat.ModEq]\n      have h₂ : 2 ^ (2 ^ l) ≡ 3 [MOD (2 ^ (2 ^ l) - 3)] := by\n        simp [Nat.ModEq, Nat.mod_eq_of_lt]\n      calc\n        2 ^ (2 ^ k) = (2 ^ (2 ^ l)) ^ (2 ^ (k - l)) := by\n          cases' le_or_lt l k with h h <;> simp_all [Nat.pow_succ, Nat.pow_mul, Nat.sub_eq_zero_of_le]\n        _ ≡ 3 ^ (2 ^ (k - l)) [MOD (2 ^ (2 ^ l) - 3)] := by\n          simpa using h₂.pow (2 ^ (k - l))\n        _ ≡ 3 [MOD (2 ^ (2 ^ l) - 3)] := by\n          have h₃ : 3 ^ (2 ^ (k - l)) ≡ 3 [MOD (2 ^ (2 ^ l) - 3)] := by\n            cases' k - l with d\n            · simp\n            · induction d <;> simp_all [Nat.pow_succ, Nat.mul_mod, Nat.pow_mod]\n          exact h₃\n    have h₂ : 2 ^ (2 ^ l) - 3 ∣ 2 ^ (2 ^ k) - 3 := by\n      rw [Nat.dvd_iff_mod_eq_zero]\n      simpa [Nat.ModEq] using h₁\n    have h₃ : 2 ^ (2 ^ l) - 3 ≤ 2 ^ (2 ^ k) - 3 := Nat.le_of_dvd (by positivity) h₂\n    have h₄ : 2 ^ (2 ^ l) ≤ 2 ^ (2 ^ k) := by omega\n    have h₅ : l ≤ k := by\n      apply Nat.pow_le_pow_iff_left (by norm_num) |>.mp\n      exact h₄\n    have h₆ : k ≤ l := by\n      apply Nat.pow_le_pow_iff_left (by norm_num) |>.mp\n      have h₇ : 2 ^ (2 ^ k) - 3 ≤ 2 ^ (2 ^ l) - 3 := Nat.le_of_dvd (by positivity) (Nat.gcd_dvd_right _ _)\n      omega\n    have h₇ : k = l := by linarith\n    simp_all",
      "\n  use {n : ℕ+ | ∀ p : ℕ, Nat.Prime p → p ∣ (2 ^ n.val - 3) → ∀ m : ℕ+, m < n → ¬(p ∣ (2 ^ m.val - 3))}\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    intro i\n    use ⟨2 ^ (i + 1), Nat.pos_pow_of_pos _ (by norm_num)⟩\n    simp\n  · intro m n hmn\n    have h1 := hmn\n    have h2 := hmn.symm\n    simp_all [Nat.coprime_iff_gcd_eq_one]\n    intro p hp hpm hpn\n    cases' lt_or_gt_of_ne (Ne.symm (Ne_of_lt hmn)) with h h <;> simp_all",
      "\n  use {n : ℕ+ | ∀ p : ℕ, Nat.Prime p → p ∣ (2 ^ n.val - 3) → ∀ m : ℕ+, m < n → ¬(p ∣ (2 ^ m.val - 3))}\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    intro n\n    use n + 1\n    simp\n    intro p hp hdiv m hm\n    omega\n  · intro m n hmn\n    simp_all [Nat.coprime_iff_gcd_eq_one]\n    intro p hp hpm hpn\n    cases' lt_or_gt_of_ne hmn with h h <;> [apply (hpm p hp h).elim | apply (hpn p hp h).elim]\n    <;> simp_all",
      "\n  use {n : ℕ+ | ∃ k : ℕ, n = ⟨2 ^ k, Nat.pos_of_ne_zero (by simp [Nat.pow_ne_zero])⟩}\n  constructor\n  · exact Set.infinite_of_injective_forall_mem (fun k ↦ ⟨2 ^ k, Nat.pos_of_ne_zero (by simp [Nat.pow_ne_zero])⟩)\n      (by intro k₁ k₂ h; simp_all [Nat.pow_left_injective])\n  · intro m n hmn\n    obtain ⟨k₁, rfl⟩ := hmn.1\n    obtain ⟨k₂, rfl⟩ := hmn.2\n    simp only [Nat.Coprime, Nat.gcd_comm]\n    have h₁ : k₁ ≠ k₂ := by\n      rintro rfl\n      simp_all\n    wlog h₂ : k₁ < k₂\n    · cases' lt_or_gt_of_ne h₁ with h h <;> simp_all\n    · have h₃ : 2 ^ (2 ^ k₁) ≡ 3 [MOD (2 ^ (2 ^ k₁) - 3)] := by\n        simp [Nat.ModEq, Nat.mod_eq_of_lt]\n      have h₄ : 2 ^ (2 ^ k₂) ≡ 3 [MOD (2 ^ (2 ^ k₁) - 3)] := by\n        calc\n          2 ^ (2 ^ k₂) = (2 ^ (2 ^ k₁)) ^ (2 ^ (k₂ - k₁)) := by\n            rw [← Nat.pow_mul, Nat.sub_add_cancel (le_of_lt h₂)]\n          _ ≡ 3 ^ (2 ^ (k₂ - k₁)) [MOD (2 ^ (2 ^ k₁) - 3)] := by\n            simpa using h₃.pow (2 ^ (k₂ - k₁))\n          _ ≡ 3 [MOD (2 ^ (2 ^ k₁) - 3)] := by\n            have h₅ : 3 ^ (2 ^ (k₂ - k₁)) ≡ 3 [MOD (2 ^ (2 ^ k₁) - 3)] := by\n              induction' k₂ - k₁ with t ih\n              · simp [Nat.ModEq]\n              · cases t\n                · simp [Nat.ModEq]\n                · simp_all [Nat.pow_succ, Nat.ModEq, Nat.mul_mod]\n                  nlinarith\n            exact h₅\n      have h₅ : (2 ^ (2 ^ k₂) - 3) % (2 ^ (2 ^ k₁) - 3) = 0 := by\n        simpa [Nat.ModEq, Nat.mod_eq_zero_of_dvd] using h₄\n      have h₆ : Nat.gcd (2 ^ (2 ^ k₁) - 3) (2 ^ (2 ^ k₂) - 3) = Nat.gcd (2 ^ (2 ^ k₁) - 3) ((2 ^ (2 ^ k₂) - 3) % (2 ^ (2 ^ k₁) - 3)) := by\n        apply Nat.gcd_rec\n      rw [h₅] at h₆\n      simp at h₆\n      exact h₆",
      "\n  use { n : ℕ+ | ∀ p : ℕ, Nat.Prime p → p ∣ (2 ^ n.val - 3) → ∀ m : ℕ+, m < n → ¬(p ∣ (2 ^ m.val - 3)) }\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    intro n\n    use n + 1\n    simp\n    intro p hp hdiv m hm\n    omega\n  · intro m n hmn\n    simp only [Set.mem_setOf_eq] at *\n    have h1 := hmn.1\n    have h2 := hmn.2\n    have h3 : m ≠ n := by\n      rintro rfl\n      simp_all\n    cases' lt_or_gt_of_ne h3 with hlt hgt\n    · specialize h1 _ (Nat.prime_iff.mp (Nat.prime_two))\n      simp_all\n    · specialize h2 _ (Nat.prime_iff.mp (Nat.prime_two))\n      simp_all",
      "\n  use { n | ∃ k : ℕ, n = ⟨2 ^ k + 1, by positivity⟩ }\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    · intro i j h\n      simp_all\n      <;> omega\n    · intro k\n      exact ⟨k, rfl⟩\n  · intro m n hmn hm hn\n    obtain ⟨i, rfl⟩ := hm\n    obtain ⟨j, rfl⟩ := hn\n    simp_all\n    wlog h : i < j\n    · have h₁ : 2 ^ (2 ^ i + 1) - 3 ≠ 0 := by\n        have : 2 ^ (2 ^ i + 1) ≥ 2 ^ 2 := by\n          apply Nat.pow_le_pow_of_le_right\n          · norm_num\n          · omega\n        omega\n      have h₂ : 2 ^ (2 ^ j + 1) - 3 ≠ 0 := by\n        have : 2 ^ (2 ^ j + 1) ≥ 2 ^ 2 := by\n          apply Nat.pow_le_pow_of_le_right\n          · norm_num\n          · omega\n        omega\n      have h₃ : Nat.gcd (2 ^ (2 ^ i + 1) - 3) (2 ^ (2 ^ j + 1) - 3) = 1 := by\n        have h₄ : 2 ^ (2 ^ i + 1) ≡ 3 [ZMOD Nat.gcd (2 ^ (2 ^ i + 1) - 3) (2 ^ (2 ^ j + 1) - 3)] := by\n          rw [Int.ModEq]\n          exact Int.emod_eq_emod_iff_emod_sub_eq_zero.mpr (by\n            simp [Int.emod_eq_emod_iff_emod_sub_eq_zero]\n            exact Int.dvd_of_nat_dvd (Nat.gcd_dvd_left _ _))\n        have h₅ : 2 ^ (2 ^ j + 1) ≡ 3 [ZMOD Nat.gcd (2 ^ (2 ^ i + 1) - 3) (2 ^ (2 ^ j + 1) - 3)] := by\n          rw [Int.ModEq]\n          exact Int.emod_eq_emod_iff_emod_sub_eq_zero.mpr (by\n            simp [Int.emod_eq_emod_iff_emod_sub_eq_zero]\n            exact Int.dvd_of_nat_dvd (Nat.gcd_dvd_right _ _))\n        have h₆ : 2 ^ (2 ^ j + 1) = (2 ^ (2 ^ i + 1)) ^ (2 ^ (j - i)) := by\n          rw [← Nat.pow_mul]\n          congr 1\n          omega\n        rw [h₆] at h₅\n        simp_all [Int.ModEq, Int.pow_succ]\n        have h₇ : 3 ^ (2 ^ (j - i)) ≡ 3 [ZMOD Nat.gcd (2 ^ (2 ^ i + 1) - 3) (2 ^ (2 ^ j + 1) - 3)] := by\n          simpa using h₅\n        have h₈ : Nat.gcd (2 ^ (2 ^ i + 1) - 3) (2 ^ (2 ^ j + 1) - 3) ∣ 3 ^ (2 ^ (j - i)) - 3 := by\n          simpa [Int.ModEq, Int.emod_eq_emod_iff_emod_sub_eq_zero] using h₇\n        have h₉ : Nat.gcd (2 ^ (2 ^ i + 1) - 3) (2 ^ (2 ^ j