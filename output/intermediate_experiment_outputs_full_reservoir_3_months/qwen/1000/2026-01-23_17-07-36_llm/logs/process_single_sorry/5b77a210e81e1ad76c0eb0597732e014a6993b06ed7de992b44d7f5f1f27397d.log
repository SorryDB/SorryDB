      "\n  use { n | ∃ k : ℕ, n = ⟨k + 1, Nat.succ_pos k⟩ }\n  constructor\n  · exact Set.infinite_of_injective_forall_mem (fun k => ⟨k + 1, Nat.succ_pos k⟩) (by simp) (by simp)\n  · intro m n hmn\n    obtain ⟨k, rfl⟩ := hmn.1\n    obtain ⟨l, rfl⟩ := hmn.2\n    simp only [Nat.cast_add, Nat.cast_one, Nat.cast_succ, Nat.add_sub_cancel]\n    have hkl : k ≠ l := by\n      rintro rfl\n      simp_all\n    wlog hkl' : k < l\n    · cases' lt_or_gt_of_ne hkl with h h <;> simp_all\n    · have : (2 ^ (k + 1) - 3).gcd (2 ^ (l + 1) - 3) = 1 := by\n        have h1 : 2 ^ (k + 1) ≡ 3 [MOD (2 ^ (k + 1) - 3)] := by\n          simp [Nat.ModEq, Nat.mod_eq_of_lt]\n        have h2 : 2 ^ (l + 1) ≡ 3 [MOD (2 ^ (k + 1) - 3)] := by\n          calc\n            2 ^ (l + 1) = 2 ^ (k + 1 + (l - k)) := by rw [Nat.add_sub_assoc (Nat.succ_le_succ (Nat.zero_le k))]\n            _ = 2 ^ (k + 1) * 2 ^ (l - k) := by rw [pow_add]\n            _ ≡ 3 * 2 ^ (l - k) [MOD (2 ^ (k + 1) - 3)] := by simpa using h1.mul_right (2 ^ (l - k))\n        have h3 : 3 * 2 ^ (l - k) ≡ 3 [MOD (2 ^ (k + 1) - 3)] := by\n          have h4 : 2 ^ (k + 1) - 3 ∣ 3 * (2 ^ (l - k) - 1) := by\n            have h5 : 2 ^ (k + 1) ≡ 3 [MOD (2 ^ (k + 1) - 3)] := by\n              simp [Nat.ModEq, Nat.mod_eq_of_lt]\n            have h6 : 2 ^ (l + 1) ≡ 3 [MOD (2 ^ (k + 1) - 3)] := by\n              calc\n                2 ^ (l + 1) = 2 ^ (k + 1 + (l - k)) := by rw [Nat.add_sub_assoc (Nat.succ_le_succ (Nat.zero_le k))]\n                _ = 2 ^ (k + 1) * 2 ^ (l - k) := by rw [pow_add]\n                _ ≡ 3 * 2 ^ (l - k) [MOD (2 ^ (k + 1) - 3)] := by simpa using h5.mul_right (2 ^ (l - k))\n            have h7 : 3 * 2 ^ (l - k) ≡ 3 [MOD (2 ^ (k + 1) - 3)] := by\n              have h8 : 2 ^ (l + 1) - 3 ≡ 0 [MOD (2 ^ (k + 1) - 3)] := by\n                simpa [Nat.ModEq, Nat.mod_eq_of_lt] using h6\n              simpa [Nat.ModEq, Nat.mod_eq_of_lt] using h8\n            simpa [Nat.ModEq, Nat.mod_eq_of_lt] using h7\n          simpa [Nat.ModEq, N