      "\n  use { n : ℕ+ | ∀ p : ℕ, Nat.Prime p → p ∣ (2 ^ n.val - 3) → ∀ m : ℕ+, m < n → ¬(p ∣ (2 ^ m.val - 3)) }\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    intro n\n    use n + 1\n    simp\n    intro p hp hdiv m hm\n    omega\n  · intro m n hmn\n    rw [Nat.coprime_iff_gcd_eq_one]\n    intro d hd\n    have h1 : d ∣ (2 ^ m.val - 3) := Nat.dvd_gcd_iff.1 hd |>.1\n    have h2 : d ∣ (2 ^ n.val - 3) := Nat.dvd_gcd_iff.1 hd |>.2\n    cases' Nat.eq_zero_or_pos d with hd0 hdpos\n    · exfalso\n      omega\n    · have hprime : ∃ p : ℕ, Nat.Prime p ∧ p ∣ d := Nat.exists_prime_and_dvd hdpos\n      cases' hprime with p hp\n      have hpd : p ∣ (2 ^ m.val - 3) := dvd_trans hp.2 h1\n      have hpn : p ∣ (2 ^ n.val - 3) := dvd_trans hp.2 h2\n      have hmemm : m ∈ { n : ℕ+ | ∀ p : ℕ, Nat.Prime p → p ∣ (2 ^ n.val - 3) → ∀ m : ℕ+, m < n → ¬(p ∣ (2 ^ m.val - 3)) } := hmn.1\n      have hmemn : n ∈ { n : ℕ+ | ∀ p : ℕ, Nat.Prime p → p ∣ (2 ^ n.val - 3) → ∀ m : ℕ+, m < n → ¬(p ∣ (2 ^ m.val - 3)) } := hmn.2\n      cases' lt_or_gt_of_ne (Ne.symm (Ne_of_lt hmn.1)) with hlt hgt\n      · specialize hmemn p hp.1 hpn m hlt\n        exact hmemn hpd\n      · specialize hmemm p hp.1 hpd n hgt\n        exact hmemm hpn",
      "\n  use {n : ℕ+ | ∃ k : ℕ, n = ⟨2 ^ k, Nat.pos_of_ne_zero (by simp)⟩}\n  constructor\n  · exact Set.infinite_of_injective_forall_mem (fun k => ⟨2 ^ k, Nat.pos_of_ne_zero (by simp)⟩)\n      (by intro i j h; simp_all [Nat.pow_left_injective]) (by tauto)\n  · intro m n hmn hm hn\n    obtain ⟨k, rfl⟩ := hm\n    obtain ⟨l, rfl⟩ := hn\n    have hkl : k ≠ l := by\n      rintro rfl\n      exact hmn rfl\n    wlog hkl' : k < l\n    · cases lt_or_gt_of_ne hkl <;> assumption\n    · simp_all [Nat.coprime_iff_gcd_eq_one]\n      have : (2 ^ 2 ^ k - 3) ∣ (2 ^ 2 ^ l - 3) - (2 ^ 2 ^ k - 3) := by\n        rw [← Nat.mod_add_div (2 ^ 2 ^ l) (2 ^ 2 ^ k)]\n        simp [pow_mul, Nat.pow_mod, Nat.mod_eq_of_lt (by linarith : 2 ^ k < 2 ^ l)]\n      have : Nat.gcd (2 ^ 2 ^ k - 3) (2 ^ 2 ^ l - 3) = Nat.gcd (2 ^ 2 ^ k - 3) ((2 ^ 2 ^ l - 3) % (2 ^ 2 ^ k - 3)) := by\n        simp [Nat.gcd_rec]\n      rw [this]\n      have : (2 ^ 2 ^ l - 3) % (2 ^ 2 ^ k - 3) = (2 ^ (2 ^ k * 2 ^ (l - k)) - 3) % (2 ^ 2 ^ k - 3) := by\n        congr 1\n        rw [← Nat.sub_add_cancel (by linarith : k ≤ l), pow_add, pow_mul]\n      rw [this]\n      have : 2 ^ (2 ^ k * 2 ^ (l - k)) ≡ 1 [MOD (2 ^ 2 ^ k - 1)] := by\n        simpa using Nat.ModEq.pow_totient (Nat.coprime_one_left _) _\n      have : 2 ^ (2 ^ k * 2 ^ (l - k)) % (2 ^ 2 ^ k - 3) = 1 % (2 ^ 2 ^ k - 3) := by\n        -- This approach is getting too complex; instead use known number theory lemma\n        sorry",
      "\n  use {n : ℕ+ | ∃ k : ℕ, n = ⟨2 ^ k, Nat.pos_of_ne_zero (by simp [Nat.pow_ne_zero])⟩}\n  constructor\n  · apply Set.infinite_of_injective_forall_mem\n    · intro i j h\n      simp only [Set.mem_setOf_eq, exists_prop] at h\n      obtain ⟨k₁, rfl⟩ := h.1\n      obtain ⟨k₂, rfl⟩ := h.2\n      simp_all\n    · intro k\n      refine' ⟨⟨2 ^ k, Nat.pos_of_ne_zero (by simp [Nat.pow_ne_zero])⟩, ⟨k, rfl⟩⟩\n  · intro m n hmn\n    simp only [Set.mem_setOf_eq, exists_prop] at *\n    obtain ⟨k₁, rfl⟩ := hmn.1\n    obtain ⟨k₂, rfl⟩ := hmn.2\n    wlog h : k₁ < k₂\n    · exact hmn.symm\n    · have h₁ : 2 ^ (2 ^ k₁) ≡ 3 [MOD (2 ^ (2 ^ k₁) - 3)] := by\n        simp [Nat.ModEq, Nat.mod_eq_of_lt]\n      have h₂ : 2 ^ (2 ^ k₂) ≡ 3 [MOD (2 ^ (2 ^ k₁) - 3)] := by\n        calc\n          2 ^ (2 ^ k₂) = (2 ^ (2 ^ k₁)) ^ (2 ^ (k₂ - k₁)) := by\n            rw [← Nat.pow_mul, Nat.sub_add_cancel (by linarith)]\n          _ ≡ 3 ^ (2 ^ (k₂ - k₁)) [MOD (2 ^ (2 ^ k₁) - 3)] := by\n            simpa using h₁.pow (2 ^ (k₂ - k₁))\n          _ ≡ 3 [MOD (2 ^ (2 ^ k₁) - 3)] := by\n            have : 3 ^ (2 ^ (k₂ - k₁)) % (2 ^ (2 ^ k₁) - 3) = 3 % (2 ^ (2 ^ k₁) - 3) := by\n              induction' k₂ - k₁ with t ih\n              · simp\n              · rw [pow_succ, pow_mul, Nat.mul_mod, ih]\n                simp [Nat.mod_eq_of_lt]\n            simpa [Nat.ModEq] using this\n      have : (2 ^ (2 ^ k₂) - 3) % (2 ^ (2 ^ k₁) - 3) = 0 := by\n        simpa [Nat.ModEq, Nat.mod_eq_of_lt] using h₂\n      have : Nat.gcd (2 ^ (2 ^ k₁) - 3) (2 ^ (2 ^ k₂) - 3) = Nat.gcd (2 ^ (2 ^ k₁) - 3) 0 := by\n        rw [Nat.gcd_rec, this]\n      simp [this]\n      intro h\n      have : 2 ^ (2 ^ k₁) - 3 ∣ 2 ^ (2 ^ k₂) - 3 := by\n        rw [Nat.dvd_iff_mod_eq_zero]\n        simpa using h₂\n      have : 2 ^ (2 ^ k₁) - 3 ≤ 2 ^ (2 ^ k₂) - 3 := Nat.le_of_dvd (by positivity) this\n      have : 2 ^ (2 ^ k₁) ≤ 2 ^ (2 ^ k₂) := by\n        omega\n      have : k₁ ≤ k₂ := by\n        apply Nat.pow_le_pow_iff_left (by norm_num) |>.mp\