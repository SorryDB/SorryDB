    (hέΓΒ : ┬υέΙΑ x, f x = 0) (hέΓΓ : έΙΑ x, |f x| έΚν 1) : έΙΑ x, |g x| έΚν 1 := by
  intro x
  have hέΓΔ : έΙΔ xέΓΑ, f xέΓΑ έΚι 0 := by
    push_neg at hέΓΒ
    exact hέΓΒ
  obtain έθρxέΓΑ, hxέΓΑέθσ := hέΓΔ
  have hέΓΕ := hέΓΑ xέΓΑ x
  rw [abs_le] at hέΓΓ
  have hέΓΖ := hέΓΓ (xέΓΑ + x)
  have hέΓΗ := hέΓΓ (xέΓΑ - x)
  rw [abs_le] at *
  constructor <;> nlinarith [hέΓΖ.1, hέΓΖ.2, hέΓΗ.1, hέΓΗ.2, hέΓΕ, hxέΓΑ]
