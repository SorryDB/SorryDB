      "\n  have h_support_finite : Set.Finite (Module.support A M ∩ {p | p.1.primeHeight = 1}) :=\n    Module.IsTorsion.finite_primeHeight_one_support hMT\n  obtain ⟨t, ht⟩ : ∃ t : Finset (PrimeSpectrum A),\n      ↑t = Module.support A M ∩ {p | p.1.primeHeight = 1} :=\n    Set.Finite.exists_finset_eq h_support_finite\n  let S := ⨅ p ∈ t, p.1.primeCompl\n  have hS : IsDomain (Localization S) ∧ IsPrincipalIdealRing (Localization S) :=\n    HeightOneLocalizationIsPID.isPrincipalIdealRing_localization A t.subset_cast _ t.nonempty_of_ne_empty\n      (by rwa [Set.eq_empty_iff_forall_notMem] at ht; simp_all)\n  cases' hS with hS_domain hS_pid\n  have hM_localized : Module.Finite (Localization S) (LocalizedModule S M) :=\n    LocalizedModule.finite A M S\n  have hM_torsion_localized : Module.IsTorsion (Localization S) (LocalizedModule S M) :=\n    LocalizedModule.isTorsion A M S\n  have h_structure : ∃ (ι : Type u) (_ : Fintype ι) (q : ι → Ideal (Localization S))\n      (_ : ∀ i, q i ≠ ⊥) (e : ι → ℕ) (_ : ∀ i, 0 < e i),\n      LocalizedModule S M ≃ₗ[Localization S] (i : ι) → Localization S ⧸ q i ^ e i :=\n    Module.IsTorsion.structure_theorem_pid hS_pid hM_localized hM_torsion_localized\n  rcases h_structure with ⟨ι, hι, q, hq, e, he, h_equiv⟩\n  have h_q_height_one : ∀ i, (q i).primeHeight = 1 := by\n    intro i\n    have hqi_nonzero : q i ≠ ⊥ := hq i\n    have hqi_prime : (q i).IsPrime := by\n      have h_max : (q i).IsMaximal := by\n        rw [← Submodule.span_singleton_eq_bot] at hqi_nonzero\n        exact (IsPrincipalIdealRing.isMaximal_of_irreducible (Localization S) hS_pid\n          (Submodule.span_singleton_generator (q i)) (by simpa using hqi_nonzero)).2\n      exact Ideal.isPrime_of_isMaximal h_max\n    have h_comap : ∃ p ∈ t, PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨q i, hqi_prime⟩ = p := by\n      rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one\n        (Localization S) t (by simp [ht]) (by rwa [Set.eq_empty_iff_for