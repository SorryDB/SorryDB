  · use PEmpty, inferInstance, PEmpty.elim, by simp, PEmpty.elim, by simp
    simp [PseudoIsomorphism.of_subsingleton_left, Subsingleton.of_isEmpty]
  · let σ := (Module.support A M ∩ {p | p.1.primeHeight = 1}).toFinset
    have hσ : ∀ p ∈ σ, p.1.primeHeight = 1 := by
      intro p hp
      simp only [Set.mem_inter_iff, Finset.mem_coe, Set.mem_setOf_eq] at hp
      exact hp.2
    have hS : IsDomain (Localization (⨅ p ∈ σ, p.1.primeCompl)) ∧
        IsPrincipalIdealRing (Localization (⨅ p ∈ σ, p.1.primeCompl)) :=
      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ hσ ⟨⟩ (by simp)
    obtain ⟨hS_domain, hS_pid⟩ := hS
    have h_loc_M : Module.Finite (Localization (⨅ p ∈ σ, p.1.primeCompl))
        (LocalizedModule (⨅ p ∈ σ, p.1.primeCompl) M) :=
      LocalizedModule.finite _ _
    have h_loc_torsion : Module.IsTorsion (Localization (⨅ p ∈ σ, p.1.primeCompl))
        (LocalizedModule (⨅ p ∈ σ, p.1.primeCompl) M) :=
      LocalizedModule.isTorsion _ _
    have h_struct : ∃ (ι : Type u) (_ : Fintype ι) (q : ι → Ideal (Localization (⨅ p ∈ σ, p.1.primeCompl))),
        (∀ i, q i ≠ ⊥) ∧
        LocalizedModule (⨅ p ∈ σ, p.1.primeCompl) M ≃ₗ[Localization (⨅ p ∈ σ, p.1.primeCompl)]
          (i : ι) → Localization (⨅ p ∈ σ, p.1.primeCompl) ⧸ q i :=
