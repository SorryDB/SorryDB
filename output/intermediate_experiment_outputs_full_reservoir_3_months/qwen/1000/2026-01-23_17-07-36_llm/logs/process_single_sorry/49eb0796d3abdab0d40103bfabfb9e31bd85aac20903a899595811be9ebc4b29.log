      "\n  haveI := HeightOneLocalizationIsPID A\n  have := Module.IsTorsion.finite_primeHeight_one_support hMT\n  let sigma := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}\n  have hfin : sigma.Finite := Set.Finite.subset this (by rintro p ⟨hp1, hp2⟩; exact ⟨hp1, hp2⟩)\n  obtain ⟨s, rfl, hs⟩ := hfin.to_subtype\n  refine' ⟨s, inferInstance, fun p => p, fun _ => (p : PrimeSpectrum A).2.1, fun p => 1, fun _ => Nat.zero_lt_one, _⟩\n  apply Module.pseudoIsomorphism_of_isPseudoIsomorphism_bijective_map\n  · exact hMT\n  · exact Module.IsTorsion.of_finite (inferInstance : Module.Finite A (∀ i : s, A ⧸ (p i).1 ^ 1))\n  · simp only [Set.mem_univ, forall_true_left, Set.union_eq_right, Set.inter_eq_left, Set.subset_def,\n      Set.mem_setOf_eq, and_imp, forall_and]\n    intro p hp1 hp2\n    have hloc : IsPrincipalIdealRing (Localization p.1.primeCompl) :=\n      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization {p} (by simp [hp1]) (by simp) (by simp)\n    have hpid : IsDomain (Localization p.1.primeCompl) ∧ IsPrincipalIdealRing (Localization p.1.primeCompl) :=\n      ⟨IsLocalization.isDomain_localization (le_nonZeroDivisors_of_primeCompl hp1.ne_zero),\n        hloc⟩\n    have := Module.IsTorsion.isPseudoIsomorphic_pi_aux hMT hp1 hp2 hpid.2\n    simp_all",
      "\n  haveI := hMT\n  have h_support := Module.IsTorsion.finite_primeHeight_one_support hMT\n  let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}\n  have hσ_fin : σ.Finite := Set.toFinite h_support\n  obtain ⟨s, rfl, hs⟩ := hσ_fin.exists_finset_coe\n  refine' ⟨s, inferInstance, fun p ↦ ⟨p, _⟩, fun _ ↦ by simp [hs], _, fun _ ↦ by simp⟩\n  exact (hs _).2",
      "\n  haveI := hMT\n  have h_support_finite : Set.Finite (Module.support A M ∩ {p | p.1.primeHeight = 1}) :=\n    Module.IsTorsion.finite_primeHeight_one_support hMT\n  obtain ⟨t, ht⟩ : ∃ t : Finset (PrimeSpectrum A),\n      ↑t = Module.support A M ∩ {p | p.1.primeHeight = 1} :=\n    Set.Finite.exists_finset_eq h_support_finite\n  let S := ⨅ p ∈ t, p.1.primeCompl\n  have hS : IsDomain (Localization S) ∧ IsPrincipalIdealRing (Localization S) :=\n    HeightOneLocalizationIsPID.isPrincipalIdealRing_localization A t.subset_cast _\n      (by rwa [Set.eq_empty_iff_forall_notMem]; intro p hp; simp_all) t.finite_toSet\n  cases' hS with hS_domain hS_pid\n  have hM_localized : Module.Finite (Localization S) (LocalizedModule S M) :=\n    LocalizedModule.finite S inst✝\n  have hM_torsion_localized : Module.IsTorsion (Localization S) (LocalizedModule S M) :=\n    LocalizedModule.isTorsion S hMT\n  have h_struct : ∃ (ι : Type u) (_ : Fintype ι) (q : ι → Ideal (Localization S))\n      (_ : ∀ i, q i ≠ ⊥) (e : ι → ℕ) (_ : ∀ i, 0 < e i),\n      LocalizedModule S M ≃ₗ[Localization S] (i : ι) → Localization S ⧸ q i ^ e i :=\n    Module.IsTorsion.structureTheorem_PID hS_pid hM_localized hM_torsion_localized\n  rcases h_struct with ⟨ι, hι, q, hq, e, he, h_equiv⟩\n  have h_height_one : ∀ i, (q i).primeHeight = 1 := by\n    intro i\n    have hqi_ne_bot : q i ≠ ⊥ := hq i\n    have hqi_prime : (q i).IsPrime := by\n      have h_max : (q i).IsMaximal := by\n        apply IsPrincipalIdealRing.irreducible_iff_maximal hS_pid\n        exact (IsPrincipalIdealRing.irreducible_of_prime hS_pid (q i).prime (neBot_of_prime hqi_ne_bot)).2\n      exact h_max.isPrime\n    have hqi_height_one : (q i).primeHeight = 1 := by\n      have h_comap : ∃ p ∈ t, PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨q i, hqi_prime⟩ = p := by\n        rw [← ht]\n        have h_in_support : PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨q i, hqi_prime⟩ ∈\n            Module.support A M ∩ {p | p.1.primeHeight = 1} := by\n          rw [Module.mem_support_iff_of_finite] at *\n          have h_nonzero : LocalizedModule S M ≠ 0 := by\n            intro h\n            have h_subsingleton : Subsingleton (LocalizedModule S M) := by\n              rw [h]\n              infer_instance\n            have h_pseudo_null : Module.IsPseudoNull A M := by\n              rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]\n              intro p hp\n              by_cases hpmem : p ∈ t\n              · rw [ht] at hpmem\n                rw [Set.mem_inter_iff] at hpmem\n                have h_height_one : p.1.primeHeight = 1 := hpmem.2\n                have h_localized_subsingleton : Subsingleton (LocalizedModule p.1.primeCompl M) := by\n                  apply subsingleton_of_subsingleton_localization S p.1.primeCompl\n                  intro x hx\n                  have h_in_S : x ∈ S := by\n                    rw [Submonoid.mem_iInf]\n                    intro p' hp'\n                    rw [Ideal.primeCompl, Set.mem_compl_iff]\n                    intro hxp'\n                    have h_p'_in_support : p' ∈ Module.support A M := by\n                      rw [ht] at hp'\n                      exact (Set.mem_inter_iff.mp hp').1\n                    have h_disjoint : Disjoint (Submodule.annihilator A M) p'.1 := by\n                      rw [Module.notMem_support_iff] at h_p'_in_support\n                      exact h_p'_in_support\n                    have h_annihilator : x ∈ Submodule.annihilator A M := by\n                      rw [Submodule.mem_annihilator]\n                      intro m\n                      have h_localized_zero : (x • m : LocalizedModule S M) = 0 := by\n                        rw [hx]\n                        simp\n                      obtain ⟨s, hs, hsm⟩ := LocalizedModule.ext_iff.mp h_localized_zero\n                      use s\n                      simp [hsm]\n                    exact h_disjoint.left h_annihilator hxp'\n                  exact h_in_S\n                have h_localized_subsingleton' : Subsingleton (LocalizedModule S M) := by\n                  apply subsingleton_of_subsingleton_localization p.1.primeCompl S\n                  intro x hx\n                  have h_in_p_compl : x ∈ p.1.primeCompl := by\n                    rw [Ideal.primeCompl, Set.mem_compl_iff]\n                    intro hxp\n                    have h_p_in_support : p ∈ Module.support A M := by\n                      rw [ht] at hpmem\n                      exact (Set.mem_inter_iff.mp hpmem).1\n                    have h_disjoint : Disjoint (Submodule.annihilator A M) p.1 := by\n                      rw [Module.notMem_support_iff] at h_p_in_support\n                      exact h_p_in_support\n                    have h_annihilator : x ∈ Submodule.annihilator A M := by\n                      rw [Submodule.mem_annihilator]\n                      intro m\n                      have h_localized_zero : (x • m : LocalizedModule p.1.primeCompl M) = 0 := by\n                        rw [hx]\n                        simp\n                      obtain ⟨s, hs, hsm⟩ := LocalizedModule.ext_iff.mp h_localized_zero\n                      use s\n                      simp [hsm]\n                    exact h_disjoint.left h_annihilator hxp\n                  exact h_in_p_compl\n                exact h_localized_subsingleton'\n              · rw [Ideal.primeHeight_le_one_iff] at hp\n                rcases hp with hp | hp\n                · have h_p_eq_bot : p.1 = ⊥ := by\n                    rw [Ideal.primeHeight_eq_zero_iff] at hp\n                    exact hp\n                  rw [h_p_eq_bot]\n                  have h_localized_subsingleton : Subsingleton (LocalizedModule (nonZeroDivisors A) M) := by\n                    have h_torsion : Module.IsTorsion (FractionRing A) (LocalizedModule (nonZeroDivisors A) M) := by\n                      apply LocalizedModule.isTorsion\n                      exact hMT\n                    have h_zero : LocalizedModule (nonZeroDivisors A) M = 0 := by\n                      apply Module.IsTorsion.eq_zero_of_isDomain h_torsion\n                      infer_instance\n                    rw [h_zero]\n                    infer_instance\n                  have h_localized_subsingleton' : Subsingleton (LocalizedModule S M) := by\n                    apply subsingleton_of_subsingleton_localization (nonZeroDivisors A) S\n                    intro x hx\n                    have h_in_S : x ∈ S := by\n                      rw [Submonoid.mem_iInf]\n                      intro p' hp'\n                      rw [Ideal.primeCompl, Set.mem_compl_iff]\n                      intro hxp'\n                      have h_p'_in_support : p' ∈ Module.support A M := by\n                        rw [ht] at hp'\n                        exact (Set.mem_inter_iff.mp hp').1\n                      have h_disjoint : Disjoint (Submodule.annihilator A M) p'.1 := by\n                        rw [Module.notMem_support_iff] at h_p'_in_support\n                        exact h_p'_in_support\n                      have h_annihilator : x ∈ Submodule.annihilator A M := by\n                        rw [Submodule.mem_annihilator]\n                        intro m\n                        have h_localized_zero : (x • m : LocalizedModule (nonZeroDivisors A) M) = 0 := by\n                          rw [hx]\n                          simp\n                        obtain ⟨s, hs, hsm⟩ := LocalizedModule.ext_iff.mp h_localized_zero\n                        use s\n                        simp [hsm]\n                      exact h_disjoint.left h_annihilator hxp'\n                    exact h_in_S\n                  exact h_localized_subsingleton'\n            contradiction\n          have h_nonzero' : (q i : Ideal (Localization S)) ≠ ⊥ := by\n            intro h\n            have h_subsingleton : Subsingleton (Localization S ⧸ q i) := by\n              rw [h]\n              simp\n            have h_subsingleton' : Subsingleton (LocalizedModule S M) := by\n              apply Equiv.subsingleton_congr (h_equiv.trans (LinearEquiv.piCongr fun j =>\n                if h : j = i then by\n                  rw [h]\n                  exact LinearEquiv.ofSubsingleton (Localization S ⧸ q i) h_subsingleton\n                else\n                  LinearEquiv.refl _)).toEquiv\n              infer_instance\n            contradiction\n          have h_prime : (q i).IsPrime := by\n            apply IsPrincipalIdealRing.prime_of_irreducible hS_pid\n            exact (IsPrincipalIdealRing.irreducible_of_prime hS_pid (q i).prime (neBot_of_prime h_nonzero')).1\n          exact ⟨PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨q i, h_prime⟩,\n            by\n              rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one]\n              all_goals\n                try\n                  { assumption }\n              all_goals\n                try\n                  { apply t.finite_toSet }\n              all_goals\n                try\n                  { apply t.nonempty_of_ne_empty }\n              all_goals\n                try\n                  { intro p hp; simp_all }⟩\n      rcases h_comap with ⟨p, hpt, hcomap⟩\n      rw [← hcomap] at hqi_prime\n      rw [PrimeSpectrum.ext_iff] at hcomap\n      rw [hcomap]\n      rw [ht] at hpt\n      exact (Set.mem_inter_iff.mp hpt).2\n    exact hqi_height_one\n  refine ⟨ι, hι, fun i => ⟨q i, (h_height_one i).prime⟩, fun i => by simp [h_height_one i],\n    e, he, ?_⟩\n  have h_equiv' : LocalizedModule S M ≃ₗ[Localization S] (i : ι) → Localization S ⧸\n      (Localization.AtPrime (fun i => ⟨q i, (h_height_one i).prime⟩) i).1 ^ e i := by\n    refine h_equiv.trans (LinearEquiv.piCongr fun i => ?_)\n    have hqi_eq : q i = (Localization.AtPrime (fun i => ⟨q i, (h_height_one i).prime⟩) i).1 := by\n      rfl\n    rw [hqi_eq]\n  have h_pseudo_iso : M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (fun i => ⟨q i, (h_height_one i).prime⟩) i.1 ^ e i) := by\n    apply isPseudoIsomorphism_of_isPseudoIsomorphism_localization\n    · exact hMT\n    · exact Module.IsTorsion.pi_isTorsion fun i => by\n        apply Module.IsTorsion.quotient\n        apply Module.IsTorsion.pow\n        apply Module.IsTorsion.cyclic\n        intro a ha\n        have h_prime : (fun i => ⟨q i, (h_height_one i).prime⟩) i.1.IsPrime := by\n          apply (h_height_one i).prime\n        have h_mem : a ∈ (fun i => ⟨q i, (h_height_one i).prime⟩) i.1 := by\n          simpa using ha\n        use a\n        simp [h_mem]\n    · exact h_equiv'\n  exact h_pseudo_iso",
      "\n  have h_sigma_finite : Set.Finite {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M} :=\n    Module.IsTorsion.finite_primeHeight_one_support hMT\n  let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}\n  obtain ⟨ι, hi, he⟩ := h_sigma_finite.exists_finset_coe\n  have hσ : σ = ↑hi := he.symm\n  have h_decomp : Module.IsTorsion A M → ∃ (p : ι → PrimeSpectrum A) (e : ι → ℕ),\n      (∀ i, (p i).1.primeHeight = 1) ∧ (∀ i, 0 < e i) ∧\n      M ∼ₚᵢₛ[A] (Π i, A ⧸ (p i).1 ^ (e i)) := by\n    intro h_tors\n    have h_loc_pid : ∀ s : Set (PrimeSpectrum A),\n        s ⊆ {p | p.1.primeHeight = 1} → s.Nonempty → s.Finite →\n        IsPrincipalIdealRing (Localization (⨅ p ∈ s, p.1.primeCompl)) :=\n      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization\n    have h_struct : Module.IsTorsion A M → ∃ (p : ι → PrimeSpectrum A) (e : ι → ℕ),\n        (∀ i, (p i).1.primeHeight = 1) ∧ (∀ i, 0 < e i) ∧\n        M ∼ₚᵢₛ[A] (Π i, A ⧸ (p i).1 ^ (e i)) := by\n      intro h_t\n      have h_primary : ∃ (p : ι → PrimeSpectrum A) (e : ι → ℕ),\n          (∀ i, (p i).1.IsPrimary) ∧ (∀ i, 0 < e i) ∧\n          M ≃ₗ[A] (Π i, A ⧸ (p i).1) := by\n        apply Module.primary_decomposition\n        exact h_t\n      obtain ⟨p, e, hp, he_pos, h_iso⟩ := h_primary\n      refine ⟨fun i ↦ ⟨p i, ?_⟩, e, ?_, he_pos, ?_⟩\n      · have h_height : (p i).primeHeight = 1 := by\n          have h_mem : ⟨p i, Ideal.isPrime_of_isPrimary hp⟩ ∈ σ := by\n            simp [σ, Set.mem_setOf_eq, Module.mem_support_iff_of_finite]\n            exact h_t (Submodule.Quotient.mk ⟨0, 1⟩)\n          rw [hσ] at h_mem\n          simp_all\n        exact h_height\n      · intro i\n        have h_height : (p i).primeHeight = 1 := by\n          have h_mem : ⟨p i, Ideal.isPrime_of_isPrimary hp⟩ ∈ σ := by\n            simp [σ, Set.mem_setOf_eq, Module.mem_support_iff_of_finite]\n            exact h_t (Submodule.Quotient.mk ⟨0, 1⟩)\n          rw [hσ] at h_mem\n          simp_all\n        exact h_height\n      · have h_pseudo : M ∼ₚᵢₛ[A] (Π i, A ⧸ (p i).1) := by\n          apply PseudoIsomorphism.of_linearEquiv\n          exact h_iso\n        have h_power : ∀ i, ∃ n : ℕ, 0 < n ∧ (p i).1 = (p i).1 ^ n := by\n          intro i\n          use 1\n          simp\n        have h_final : (Π i, A ⧸ (p i).1) ∼ₚᵢₛ[A] (Π i, A ⧸ (p i).1 ^ (e i)) := by\n          apply PseudoIsomorphism.refl\n        exact PseudoIsomorphism.trans h_pseudo h_final\n    exact h_struct h_tors\n  exact h_decomp hMT",
      "\n  have h1 : ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)\n      (e : ι → ℕ) (_ : ∀ i, 0 < e i),\n      LocalizedModule (⨅ p ∈ {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p.1 ∈ Module.support A M}, p.1.primeCompl) M ≃ₗ[Localization _]\n      LocalizedModule (⨅ p ∈ {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p.1 ∈ Module.support A M}, p.1.primeCompl)\n        ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by\n    let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p.1 ∈ Module.support A M}\n    have hσ : σ.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT\n    have hσ' : σ.Nonempty ∨ σ = ∅ := Set.eq_empty_or_nonempty σ\n    rcases hσ' with hσ' | rfl\n    · haveI : Nonempty σ := ⟨hσ'.some⟩\n      have : IsPrincipalIdealRing (Localization (⨅ p ∈ σ, p.1.primeCompl)) :=\n        HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) hσ'.some_mem hσ\n      have : IsDomain (Localization (⨅ p ∈ σ, p.1.primeCompl)) :=\n        HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) hσ'.some_mem hσ |>.1\n      have : Module.Finite (Localization (⨅ p ∈ σ, p.1.primeCompl))\n          (LocalizedModule (⨅ p ∈ σ, p.1.primeCompl) M) :=\n        LocalizedModule.moduleFinite_of_finite _ _\n      have : Module.IsTorsion (Localization (⨅ p ∈ σ, p.1.primeCompl))\n          (LocalizedModule (⨅ p ∈ σ, p.1.primeCompl) M) :=\n        LocalizedModule.isTorsion_of_isTorsion _ _\n      obtain ⟨ι, hι, p, hp, e, he, h⟩ :=\n        Module.IsTorsion.structureTheorem_pid (α := Localization (⨅ p ∈ σ, p.1.primeCompl))\n          (β := LocalizedModule (⨅ p ∈ σ, p.1.primeCompl) M) this this\n      refine ⟨ι, hι, fun i ↦ ⟨(p i).asIdeal, (p i).isPrime⟩, ?_, e, he, ?_⟩\n      · intro i\n        rw [Ideal.primeHeight_eq_one_iff] at hp\n        exact hp i\n      · exact h\n    · refine ⟨Empty, inferInstance, Empty.elim, by simp, Empty.elim, by simp, ?_⟩\n      have : LocalizedModule (⨅ p ∈ (∅ : Set (PrimeSpectrum A)), p.1.primeCompl) M ≃ₗ[Localization _]\n          LocalizedModule (⨅ p ∈ (∅ : Set (PrimeSpectrum A)), p.1.primeCompl) (Empty → A) := by\n        simp\n      exact this\n  obtain ⟨ι, hι, p, hp, e, he, h⟩ := h1\n  refine ⟨ι, hι, p, hp, e, he, ?_⟩\n  apply PseudoIsomorphism.of_bijective_map\n  · exact hMT\n  · exact Module.IsTorsion.finite_primeHeight_one_support (Module.IsTorsion.pi _ fun i ↦ by\n      have : (p i).1 ≠ ⊥ := by\n        intro h\n        rw [h] at hp\n        simp at hp\n      exact Module.IsTorsion.of_support_subset (by simp [hp]) (by simp [this]))\n  · exact h",
      "\n  have h := Module.primary_decomposition hMT\n  obtain ⟨ι, hι, p, hp, e, he, hM⟩ := h\n  refine ⟨ι, hι, p, hp, e, he, ?_⟩\n  rw [hM]\n  exact PseudoIsomorphism.refl _",
      "\n  let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}\n  have hσ : σ.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT\n  obtain ⟨ι, hι, f, hf⟩ := Set.Finite.exists_finset_eq hσ\n  refine ⟨ι, hι, fun i ↦ f i, ?_, fun i ↦ 1, fun i ↦ Nat.zero_lt_one, ?_⟩\n  · intro i\n    rw [← Set.mem_singleton_iff, ← hf]\n    exact (f i).2.1\n  · suffices : M ∼ₚᵢₛ[A] (i : ι) → A ⧸ (f i).1 ^ 1 by exact this\n    apply Module.IsPseudoIsomorphism.symm\n    apply Module.isPseudoIsomorphism_of_isPseudoIsomorphism_localization\n    intro p hp\n    have hloc : IsPrincipalIdealRing (Localization p.1.primeCompl) :=\n      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization {p} (by simp) (by simp) (by simp)\n    have : Module.IsTorsion (Localization p.1.primeCompl) (LocalizedModule p.1.primeCompl M) :=\n      LocalizedModule.isTorsion hMT\n    have : Module.Finite (Localization p.1.primeCompl) (LocalizedModule p.1.primeCompl M) :=\n      LocalizedModule.finite\n    have := Module.IsTorsion.structure_theorem_pid (α := Localization p.1.primeCompl) _ _ this\n    cases' this with ι' hι' h\n    have : LocalizedModule p.1.primeCompl ((i : ι) → A ⧸ (f i).1 ^ 1) ≃ₗ[Localization p.1.primeCompl]\n        (i : ι) → LocalizedModule p.1.primeCompl (A ⧸ (f i).1 ^ 1) := by\n      apply DirectSum.linearEquivFunOnFintype\n    have : ∀ i, LocalizedModule p.1.primeCompl (A ⧸ (f i).1 ^ 1) ≃ₗ[Localization p.1.primeCompl]\n        Localization p.1.primeCompl ⧸ LocalizedModule.submodule_span p.1.primeCompl ((f i).1 ^ 1) := by\n      intro i\n      apply LocalizedModule.quotient_equiv_quotient_span\n    have : LocalizedModule p.1.primeCompl M ≃ₗ[Localization p.1.primeCompl]\n        (i : ι') → Localization p.1.primeCompl ⧸ (Ideal.span {(⟨0, 1⟩ : Localization p.1.primeCompl)}) ^ (h i) := by\n      simpa using h\n    have : (i : ι) → LocalizedModule p.1.primeCompl (A ⧸ (f i).1 ^ 1) ≃ₗ[Localization p.1.primeCompl]\n        (i : ι') → Localization p.1.primeCompl ⧸ 