  have hMT' : Module.IsTorsion (Localization S) (LocalizedModule S M) := LocalizedModule.isTorsion S M hMT
  have hstruct : ∃ (ι : Type u) (_ : Fintype ι) (q : ι → Ideal (Localization S)),
      (∀ i, q i ≠ ⊥) ∧ (LocalizedModule S M ≃ₗ[Localization S] (i : ι) → Localization S ⧸ q i) := by
