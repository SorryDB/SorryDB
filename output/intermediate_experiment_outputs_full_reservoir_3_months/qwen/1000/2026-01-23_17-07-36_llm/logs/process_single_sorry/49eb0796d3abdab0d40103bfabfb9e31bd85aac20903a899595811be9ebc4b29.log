    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  have h1 : Module.IsTorsion A M := hMT
  have h2 : IsNoetherianRing A := inferInstance
  have h3 : HeightOneLocalizationIsPID A := inferInstance
  have h4 : IsDomain A := by
    apply inferInstance
  have h5 : ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 → IsPrincipalIdealRing (Localization p.1.primeCompl) := by
    intro p hp
    exact (h3.isPrincipalIdealRing_localization {p} (by simp [hp]) (by simp) (by simp)).2
  have h6 : Module.support A M ⊆ {p : PrimeSpectrum A | p.1.primeHeight = 1} := by
    intro p hp
    have h7 : p.1 ≠ ⊥ := by
      intro h8
      rw [h8] at hp
      simp at hp
    have h8 : p.1.primeHeight = 1 := by
      apply Ideal.primeHeight_eq_one_of_mem_support_torsion h1 hp
    simp [h8]
  have h7 : Set.Finite (Module.support A M) := by
    apply Module.IsTorsion.finite_support h1
  obtain ⟨s, hs⟩ : ∃ s : Finset (PrimeSpectrum A), ↑s = Module.support A M := by
    apply Set.finite_iff_finset.mp h7
  refine ⟨s, inferInstance, fun i ↦ i, ?_, fun i ↦ 1, fun i ↦ Nat.zero_lt_one, ?_⟩
  · intro i
    rw [← hs]
    exact h6 i (Set.mem_of_mem_of_subset (Finset.mem_coe.mp ‹_›) (by simp))
  · apply Module.pseudoIsomorphic_pi_of_support_finite
    · exact h1
    · exact hs
