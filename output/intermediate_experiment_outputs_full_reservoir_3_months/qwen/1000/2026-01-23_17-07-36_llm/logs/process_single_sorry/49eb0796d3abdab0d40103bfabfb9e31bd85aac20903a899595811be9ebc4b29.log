        q i = (Ideal.comap (algebraMap A (Localization (⨅ p ∈ σ, p.1.primeCompl)))
          ((p.1 : Ideal A) ^ e : Ideal (Localization (⨅ p ∈ σ, p.1.primeCompl)))) := by
      intro i
      have hqi_prime : (q i).IsPrimePow := by
        apply Ideal.isPrimePow_of_isPrimary
        exact Module.IsTorsion.isPrimary_of_isTorsion_of_pid hS_pid h_loc_M h_loc_torsion
          (Submodule.finite_of_fg (by infer_instance) (by infer_instance)) i
