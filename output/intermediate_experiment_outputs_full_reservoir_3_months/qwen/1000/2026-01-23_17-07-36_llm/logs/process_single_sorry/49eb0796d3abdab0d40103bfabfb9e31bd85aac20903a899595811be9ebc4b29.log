      have h_loc_target : LocalizedModule (⨅ p ∈ σ, p.1.primeCompl) ((i : ι) → A ⧸ (p i).1 ^ e i) ≃ₗ[Localization (⨅ p ∈ σ, p.1.primeCompl)]
          (i : ι) → Localization (⨅ p ∈ σ, p.1.primeCompl) ⧸
            Ideal.map (algebraMap A (Localization (⨅ p ∈ σ, p.1.primeCompl))) ((p i).1 ^ e i) := by
        refine LinearEquiv.piCongrLeft R fun i ↦ ?_
