em; simp [Ideal.primeCompl])\n        -- Use the structure theorem over the DVR localization\n        sorry\n      · have h_not_in_support : p ∉ Module.support A M := by\n          simp [ht] at hpmem; tauto\n        rw [← Module.notMem_support_iff] at h_not_in_support\n        simp [h_not_in_support]\n  exact h_pseudo_iso",
      "\n  have hσ : Set.Finite {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M} :=\n    Module.IsTorsion.finite_primeHeight_one_support hMT\n  classical\n  let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}\n  have hσ' : σ.Finite := hσ\n  have hσ'' : σ ⊆ {p : PrimeSpectrum A | p.1.primeHeight = 1} := by\n    rintro p ⟨hp1, hp2⟩\n    exact hp1\n  obtain ⟨f, hf⟩ : ∃ f : M ≃ₗ[A] (⨁ i : σ, A ⧸ (i.1)^(classical.choose (show ∃ n : ℕ, 0 < n, from ⟨1, by decide⟩))), \n    true := by\n    apply Module.equiv_directSum_of_isTorsion hMT\n    · infer_instance\n    · simp\n  use σ, inferInstance, fun p ↦ p, fun _ ↦ rfl, fun p ↦ 1, fun _ ↦ by decide\n  refine Module.pseudoIsomorphism_of_isPseudoIsomorphism ?_\n  rw [Pi.modulePi_eq_directSum]\n  exact Module.IsPseudoIsomorphism.of_linearEquiv f",
      "\n  haveI := HeightOneLocalizationIsPID A\n  have hσ : Set.Finite {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p.1 ∈ Module.support A M} :=\n    Module.IsTorsion.finite_primeHeight_one_support hMT\n  obtain ⟨s, rfl, hs⟩ := Set.finite_iff_finset.mp hσ\n  refine' ⟨s, inferInstance, fun p ↦ p, fun _ ↦ (Set.mem_toFinset.mp ‹_›).2.1, fun p ↦ 1, fun _ ↦ Nat.zero_lt_one, _⟩\n  apply Module.pseudoIsomorphism_of_isPseudoIsomorphism_map_bijective\n  intro p hp\n  have hprime : p.1.primeHeight = 1 := (Set.mem_toFinset.mp hp).2.1\n  have hloc : IsPrincipalIdealRing (Localization p.1.primeCompl) :=\n    (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization {p} (by simp) (by simp) (by simp)).2\n  have hstruct : LocalizedModule p.1.primeCompl M ≃ₗ[Localization p.1.primeCompl]\n      (i : s) → LocalizedModule p.1.primeCompl (A ⧸ (fun p : s ↦ p.1) i ^ 1) := by\n    have : LocalizedModule p.1.primeCompl M ≃ₗ[Localization p.1.primeCompl] 0 := by\n      rw [LocalizedModule.subsingleton_iff]\n      intro x\n      obtain ⟨a, ha, hax⟩ := Module.IsTorsion.exists_annihilator hMT x\n      use a, by\n        simp only [Submonoid.mem_coe, Ideal.primeCompl, Set.mem_compl_iff, not_not]\n        intro h\n        have : a ∈ p.1 := by simpa [h] using ha\n        have : p.1 ∈ Module.support A M := Module.mem_support_of_mem_annihilator hax\n        simp at this\n        contradiction\n      simp [hax]\n    refine this.trans (LinearEquiv.ofSubsingletonRange _ _)\n  exact LinearEquiv.bijective hstruct",
      "\n  haveI := hMT\n  have hfin : Set.Finite (Module.support A M ∩ {p | p.1.primeHeight = 1}) :=\n    Module.IsTorsion.finite_primeHeight_one_support hMT\n  cases' hfin.eq_empty_or_nonempty with hsupp hsupp\n  · use Empty, inferInstance, Empty.elim, by simp, Empty.elim, by simp\n    exact Module.pseudoIsomorphic_of_subsingleton (by simp [hsupp])\n  let s := (Module.support A M ∩ {p | p.1.primeHeight = 1}).toFinset\n  have hs : ↑s = Module.support A M ∩ {p | p.1.primeHeight = 1} := by simp\n  have hS : s.Nonempty := by\n    rw [← Set.nonempty_coe_toFinset]\n    exact hsupp\n  set S := ⨅ p ∈ s, p.1.primeCompl\n  have hPID : IsPrincipalIdealRing (Localization S) :=\n    HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (by simp) hS s.finite\n  have hdom : IsDomain (Localization S) :=\n    HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (by simp) hS s.finite |>.1\n  have hnoeth : IsNoetherianRing (Localization S) :=\n    IsNoetherianRing.localization _\n  have hstruct : ∃ (ι : Type u) (_ : Fintype ι) (n : ι → ℕ),\n      Nonempty (LocalizedModule S M ≃ₗ[Localization S] (i : ι) → Localization S ⧸ (Ideal.span {1} : Ideal (Localization S)) ^ n i) := by\n    apply Module.equiv_directSum_of_isTorsion_of_isPrincipalIdealRing\n    · infer_instance\n    · infer_instance\n    · infer_instance\n    · exact LocalizedModule.isTorsion S hMT\n  rcases hstruct with ⟨ι, hfinι, n, hequiv⟩\n  use ι, hfinι, fun i ↦ Classical.choose (Set.nonempty_of_mem (by\n    have : (Ideal.span {1} : Ideal (Localization S)) = ⊤ := by simp\n    have : (Ideal.span {1} : Ideal (Localization S)) ^ n i = ⊤ := by simp\n    have : (LocalizedModule S M) ≃ₗ[Localization S] (i : ι) → Localization S ⧸ ⊤ := by\n      simpa using hequiv\n    have : (i : ι) → Localization S ⧸ ⊤ ≃ₗ[Localization S] (i : ι) → 0 := by\n      apply Pi.linearEquivFunOnFintype\n      intro j\n      apply Submodule.quotientZeroEquiv\n    have : LocalizedModule S M ≃ₗ[Localization S] 0 := by\n      apply Linear