default\n    have : Module.support A M ∩ {p | p.1.primeHeight = 1} = ∅ := by\n      apply Set.eq_empty_of_forall_not_mem\n      intro p hp\n      have : p ∈ s := by simpa [hs] using hp\n      have : p.1.primeCompl ≤ S := by\n        simp [S]\n        apply iInf_le_of_le\n        apply this\n        simp\n      have : LocalizedModule p.1.primeCompl M ≃ₗ[Localization p.1.primeCompl] LocalizedModule S M := by\n        apply LocalizedModule.algEquiv_of_le\n        apply this\n      have : Subsingleton (LocalizedModule p.1.primeCompl M) := by\n        apply Subsingleton.of_isEmpty\n        apply IsEmpty.of_subsingleton\n        apply Subsingleton.elim\n        apply ‹_›.apply\n        apply ‹_›.symm.apply\n        apply default\n      have : p ∉ Module.support A M := by\n        rw [Module.notMem_support_iff]\n        exact this\n      contradiction\n    contradiction\n  have : M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (Classical.choose (Set.nonempty_of_mem (by\n    have : (Ideal.span {1} : Ideal (Localization S)) = ⊤ := by simp\n    have : (Ideal.span {1} : Ideal (Localization S)) ^ n i = ⊤ := by simp\n    have : (LocalizedModule S M) ≃ₗ[Localization S] (i : ι) → Localization S ⧸ ⊤ := by\n      simpa using hequiv\n    have : (i : ι) → Localization S ⧸ ⊤ ≃ₗ[Localization S] (i : ι) → 0 := by\n      apply Pi.linearEquivFunOnFintype\n      intro j\n      apply Submodule.quotientZeroEquiv\n    have : LocalizedModule S M ≃ₗ[Localization S] 0 := by\n      apply LinearEquiv.trans hequiv\n      apply LinearEquiv.trans ‹_›\n      apply Pi.linearEquivFunOnFintype\n      intro j\n      apply Submodule.quotientZeroEquiv\n    have : Subsingleton (LocalizedModule S M) := by\n      apply Subsingleton.of_isEmpty\n      apply IsEmpty.of_subsingleton\n      apply Subsingleton.elim\n      apply ‹_›.apply\n      apply ‹_›.symm.apply\n      apply default\n    have : Module.support A M ∩ {p | p.1.primeHeight = 1} = ∅ := by\n      apply Set.eq_empty_of_forall_not_mem\n      intro p hp\n      have : p ∈ s := by