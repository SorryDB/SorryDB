theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  have h1 : Module.support A M ⊆ {p : PrimeSpectrum A | p.1.primeHeight = 1} := by
    intro p hp
    rw [Module.mem_support_iff_of_finite] at hp
    contrapose! hp
    rw [Ideal.primeHeight_eq_zero_iff] at hp
    exact Module.notMem_support_of_mem_minimalPrimes hp
  have h2 : (Module.support A M).Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  obtain ⟨s, rfl, hs⟩ := Set.finite_subset_iff.mp h2 h1
  refine ⟨s, inferInstance, id, fun _ ↦ rfl, fun p ↦ 1, fun _ ↦ Nat.zero_lt_one, ?_⟩
  apply Module.pseudoIsomorphic_of_isTorsion_of_support_eq_singleton_pow
  exact hMT
