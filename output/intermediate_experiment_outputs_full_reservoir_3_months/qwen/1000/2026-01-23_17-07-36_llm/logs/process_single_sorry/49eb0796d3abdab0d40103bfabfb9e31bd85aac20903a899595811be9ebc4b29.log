    HeightOneLocalizationIsPID.isPrincipalIdealRing_localization _ (by simp [hp]) (by infer_instance) (by infer_instance)
  have hM_loc : Module.Finite (Localization (⨅ i : σ, (p i).1.primeCompl))
      (LocalizedModule (⨅ i : σ, (p i).1.primeCompl) M) :=
    LocalizedModule.finite _
  have hM_tors : Module.IsTorsion (Localization (⨅ i : σ, (p i).1.primeCompl))
      (LocalizedModule (⨅ i : σ, (p i).1.primeCompl) M) :=
    LocalizedModule.isTorsion _
  have h_struct : ∃ (e : σ → ℕ) (_ : ∀ i, 0 < e i),
      LocalizedModule (⨅ i : σ, (p i).1.primeCompl) M ≃ₗ[Localization (⨅ i : σ, (p i).1.primeCompl)]
