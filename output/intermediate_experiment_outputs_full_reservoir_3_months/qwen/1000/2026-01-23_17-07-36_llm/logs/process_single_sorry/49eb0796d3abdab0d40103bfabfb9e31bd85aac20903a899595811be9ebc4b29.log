      "\n  haveI := HeightOneLocalizationIsPID A\n  have hfin := Module.IsTorsion.finite_primeHeight_one_support hMT\n  let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}\n  have hσ : σ.Finite := hfin\n  have hσ' : σ.Nonempty ∨ σ = ∅ := Set.eq_empty_or_nonempty σ\n  rcases hσ' with hσ' | hσ'\n  · obtain ⟨p₀, hp₀⟩ := hσ'\n    let S := ⨅ p ∈ σ, p.1.primeCompl\n    have hS : IsDomain (Localization S) ∧ IsPrincipalIdealRing (Localization S) :=\n      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) (by aesop) hσ\n    have hM : Module.Finite (Localization S) (LocalizedModule S M) :=\n      LocalizedModule.isModuleFinite_of_isModuleFinite S\n    have hMT' : Module.IsTorsion (Localization S) (LocalizedModule S M) :=\n      LocalizedModule.isTorsion_of_isTorsion S\n    have hstruct : ∃ (ι : Type u) (_ : Fintype ι) (q : ι → Ideal (Localization S)),\n        (∀ i, q i ≠ ⊥) ∧ (LocalizedModule S M ≃ₗ[Localization S] (i : ι) → Localization S ⧸ q i) :=\n      Module.Finite.isTorsion_isPrincipalIdealRing_structure_theorem\n        (R := Localization S) (M := LocalizedModule S M) hS.2 hM hMT'\n    rcases hstruct with ⟨ι, hι, q, hq, hequiv⟩\n    have hprime : ∀ i, ∃! p ∈ σ, (PrimeSpectrum.comap (algebraMap A (Localization S)) p).1 = q i := by\n      intro i\n      have hqi : q i ≠ ⊥ := hq i\n      have hmem : q i ∈ MaximalSpectrum (Localization S) := by\n        apply Ideal.IsMaximal.of_pid_of_nonzero hS.2 hqi\n      have hrange := PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one\n        (Localization S) σ (by simp) (by aesop) hσ\n      rw [hrange] at hmem\n      cases hmem with\n      | inl hmem =>\n        use hmem\n        constructor\n        · simp\n        · intro p hp hcomap\n          have := PrimeSpectrum.ext_iff.mpr hcomap\n          simp_all\n      | inr hmem =>\n        exfalso\n        rw [PrimeSpectrum.ext_iff] at hmem\n        simp_all\n    choose! p hp hcomap using hprime\n    refine ⟨ι, h