theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  haveI := hMT
  let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}
  have hσ : σ.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  have hσ' : σ.Nonempty ∨ σ = ∅ := Set.eq_empty_or_nonempty σ
  rcases hσ' with hσ' | rfl
  · obtain ⟨p₀, hp₀⟩ := hσ'
    refine ⟨σ, hσ.to_subtype, fun p ↦ p, fun p hp ↦ (hp.1), ?_⟩
    set S := ⨅ p ∈ σ, p.1.primeCompl
    have hS : IsDomain (Localization S) ∧ IsPrincipalIdealRing (Localization S) :=
      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) hσ' hσ
    have hM : Module.Finite (Localization S) (LocalizedModule S M) :=
      LocalizedModule.finite S inst✝
    have hMT' : Module.IsTorsion (Localization S) (LocalizedModule S M) :=
      LocalizedModule.isTorsion S hMT
    have hstruct : ∃ (ι : Type u) (_ : Fintype ι) (q : ι → Ideal (Localization S))
        (_ : ∀ i, q i ≠ ⊥) (e : ι → ℕ) (_ : ∀ i, 0 < e i),
        LocalizedModule S M ≃ₗ[Localization S] (i : ι) → Localization S ⧸ q i ^ e i := by
      apply Module.isTorsion_finite_structure_theorem_of_pid
      exact hS.2
      exact hM
      exact hMT'
    obtain ⟨ι, hι, q, hq, e, he, hM'⟩ := hstruct
    refine ⟨e, fun i ↦ he i, ?_⟩
    have hmap : M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ e i) := by
      apply PseudoIsomorphism.of_bijective_map_iff.mpr
      apply LinearMap.isPseudoIsomorphism_iff_bijective_map.mp
      refine ⟨ι, hι, fun i ↦ ?_, fun i ↦ ?_, e, he, ?_⟩
      · have hpi : (p i).1.primeHeight = 1 := (Set.mem_setOf_eq.mp (Set.mem_of_mem_toFinset (Finset.mem_univ i))).1
        exact ⟨(p i).1, hpi⟩
      · have hpi : (p i).1.primeHeight = 1 := (Set.mem_setOf_eq.mp (Set.mem_of_mem_toFinset (Finset.mem_univ i))).1
        exact hpi
      · have hS' : S = ⨅ p ∈ σ, p.1.primeCompl := rfl
        rw [hS']
        have hM'' : LocalizedModule S M ≃ₗ[Localization S] (i : ι) → Localization S ⧸ q i ^ e i := hM'
        have hq' : ∀ i, ∃ p ∈ σ, q i = (Ideal.comap (algebraMap A (Localization S)) (p.1 : Ideal (Localization S))) := by
          intro i
          have hqi : q i ≠ ⊥ := hq i
          have hqi' : q i ∈ Ideal.primeSpectrum (Localization S) := by
            apply Ideal.primeSpectrum.mk
            apply Ideal.isPrime_of_isPrime_compl
            apply Submonoid.isPrime_compl
            apply Submonoid.isPrime_of_prime
            apply PrimeSpectrum.isPrime
          have hqi'' : PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨q i, hqi'⟩ ∈ σ ∪ {⟨⊥, Ideal.bot_prime⟩} := by
            rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one
              (Localization S) σ (by simp) hσ' hσ]
            apply Set.mem_range_self
          cases hqi'' with
          | inl hqi''' =>
            use PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨q i, hqi'⟩, hqi'''
            ext
            simp
          | inr hqi''' =>
            exfalso
            have hbot : q i = ⊥ := by
              rw [← PrimeSpectrum.ext_iff] at hqi'''
              simp at hqi'''
              exact hqi'''
            contradiction
        sorry
    exact hmap
  · refine ⟨PUnit, inferInstance, fun _ ↦ ⟨⊥, Ideal.bot_prime⟩, fun _ ↦ by simp, fun _ ↦ 1, fun _ ↦ by simp, ?_⟩
    apply PseudoIsomorphism.of_subsingleton
    intro p hp
    have hpmem : p ∉ Module.support A M := by
      simp_all
    rw [Module.notMem_support_iff] at hpmem
    exact hpmem
