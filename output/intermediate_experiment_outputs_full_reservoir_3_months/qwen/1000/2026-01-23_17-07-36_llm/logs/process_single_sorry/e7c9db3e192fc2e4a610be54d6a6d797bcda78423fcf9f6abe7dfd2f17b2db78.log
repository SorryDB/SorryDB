lemma remove_one_equinum
    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
  apply Equinum.of_bijection
  use fun x => ⟨f x.1, by
    simp only [Set.mem_diff, Set.mem_singleton_iff] at x
    obtain ⟨hx1, hx2⟩ := x.2
    rw [← h2]
    refine ⟨⟨x.1, hx1⟩, ?_⟩
    simp [hx2, h4]⟩
  use fun y => ⟨Classical.choose (by
    simp only [Set.mem_diff, Set.mem_singleton_iff] at y
    obtain ⟨hy1, hy2⟩ := y.2
    rw [← h2] at hy1
    obtain ⟨x, hx, rfl⟩ := hy1
    refine ⟨⟨x, ?_⟩, ?_⟩
    · simp only [Set.mem_diff, Set.mem_singleton_iff]
      refine ⟨hx, ?_⟩
      intro h
      apply hy2
      rw [← h4, ← h]
      exact h1 hx h3 h
    · simp), by
    simp only [Set.mem_diff, Set.mem_singleton_iff] at y
    obtain ⟨hy1, hy2⟩ := y.2
    rw [← h2] at hy1
    obtain ⟨x, hx, rfl⟩ := hy1
    have h5 : x ≠ a := by
      intro h
      apply hy2
      rw [h, h4]
    exact Classical.choose_spec (by
      refine ⟨⟨x, ?_⟩, ?_⟩
      · simp only [Set.mem_diff, Set.mem_singleton_iff]
        refine ⟨hx, h5⟩
      · simp)⟩
  · intro x
    simp only [Set.mem_diff, Set.mem_singleton_iff] at x
    obtain ⟨hx1, hx2⟩ := x.2
    dsimp
    congr
    apply h1 hx1 h3
    intro h
    apply hx2
    exact h
  · intro y
    simp only [Set.mem_diff, Set.mem_singleton_iff] at y
    obtain ⟨hy1, hy2⟩ := y.2
    dsimp
    rw [← h2] at hy1
    obtain ⟨x, hx, rfl⟩ := hy1
    have h5 : x ≠ a := by
      intro h
      apply hy2
      rw [h, h4]
    dsimp
    congr
    apply Eq.symm
    apply Classical.choose_spec
    refine ⟨⟨x, ?_⟩, ?_⟩
    · simp only [Set.mem_diff, Set.mem_singleton_iff]
      refine ⟨hx, h5⟩
    · simp
