    obtain ⟨x, hx, rfl⟩ := hz
    have hx' : x ∈ A := hx
    by_cases hxa : x = a
    · subst hxa
      exfalso
      simp_all
    · refine' ⟨⟨x, hx', hxa⟩, _⟩
      simp_all
