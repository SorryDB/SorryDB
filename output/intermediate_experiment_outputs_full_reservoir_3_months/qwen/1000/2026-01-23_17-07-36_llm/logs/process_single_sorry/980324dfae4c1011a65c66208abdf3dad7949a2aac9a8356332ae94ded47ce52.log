      apply hP.first_not_in
      exact hIsub hfirst
    · use M_I ∆ E(P)
      constructor
      · exact hP.augment
      · intro x hx
        cases' hx with hx hx
        · exact hIsub hx
        · rw [Set.mem_insert_iff] at hx
          cases' hx with rfl hx
          · exact hP.first_mem
          · exact hIsub hx
