          exact this.symm
        _ = I.encard := by
          have : I = V(G, M_I) := by
            apply le_antisymm
            · exact hI_sub
            · intro x hx
              apply hnotmax
              intro J hJ
              obtain ⟨M_J, hM_J, hJ_sub⟩ := hJ
              have hcard : M_J.encard ≤ M_I.encard := hmax.max M_J hM_J
