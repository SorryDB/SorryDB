  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hnotmax hBmax
    obtain ⟨M_I, hM_I, hIsub⟩ := hI
    have hnotmax' : ¬ G.IsMaxMatching M_I := by
      intro hmax
      apply hnotmax
      intro J hJ
      obtain ⟨M_J, hM_J, hJsub⟩ := hJ
      have : J.encard ≤ M_I.encard := hmax.max M_J hM_J
      calc
        J.encard ≤ M_I.encard := this
        _ ≤ (V(G, M_I)).encard := by
          have : M_I.encard ≤ (V(G, M_I)).encard / 2 := by
            have : ∀ v ∈ V(G, M_I), (M_I ∩ E(G, v)).encard = 1 := by
              intro v hv
              obtain ⟨e, he, hv'⟩ := hv
              exact encard_singleton_of_subsingleton (hM_I.subsingleton_inc v) ⟨he, hv'⟩
            calc
              M_I.encard = (∑ v in V(G, M_I), (M_I ∩ E(G, v)).encard) / 2 := by
                rw [← sum_encard_partition_edges_by_vertices]
                simp [hM_I.subset]
              _ = (∑ v in V(G, M_I), 1) / 2 := by
                apply congr_arg
                apply Finset.sum_congr rfl
                intro v hv
                exact this v hv
              _ = V(G, M_I).encard / 2 := by simp
          omega
        _ = (V(G, M_I)).encard := by
          have : Even (V(G, M_I)).encard := by
            rw [even_iff_two_dvd]
            obtain ⟨n, hn⟩ := exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero (by omega))
            omega
          omega
      omega
    obtain ⟨P, hP⟩ := hM_I.exists_isAugPath_not_max hnotmax' inferInstance
    use P.first
