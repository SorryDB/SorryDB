def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hnotmax hBmax
    obtain ⟨M_I, hM_I, hIsub⟩ := hI
    have hnotmax' : ¬ G.IsMaxMatching M_I := by
      intro hmax
      apply hnotmax
      intro J hJ
      obtain ⟨M_J, hM_J, hJsub⟩ := hJ
      have : J.encard ≤ M_J.encard * 2 := by
        calc
          J.encard ≤ V(G, M_J).encard := encard_mono hJsub
          _ = M_J.encard * 2 := by
            rw [V_encard_eq_of_isMatching hM_J]
      have : M_J.encard ≤ M_I.encard := hmax.max M_J hM_J
      calc
        J.encard ≤ M_J.encard * 2 := this
        _ ≤ M_I.encard * 2 := by gcongr
        _ = V(G, M_I).encard := by
          rw [V_encard_eq_of_isMatching hM_I]
        _ ≥ I.encard := encard_mono hIsub
    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I hnotmax' inferInstance
    use P.first
    constructor
    · intro hfirst
      simp_all [IsAugPath.first_not_in]
    · use M_I ∆ E(P)
      constructor
      · exact hP.augment
      · intro x hx
        cases' hx with hx hx
        · have : x ∈ V(G, M_I) := hIsub hx
          exact hP.augment_vertex_subset hx
        · subst hx
          exact hP.first_not_in.not_mem.mpr (by simp_all)
