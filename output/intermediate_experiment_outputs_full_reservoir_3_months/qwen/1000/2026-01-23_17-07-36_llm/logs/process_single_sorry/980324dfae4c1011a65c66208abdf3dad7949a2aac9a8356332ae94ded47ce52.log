def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hnotmax hBmax
    obtain ⟨M_I, hM_I, hIsub⟩ := hI
    have hnotmax' : ¬ G.IsMaxMatching M_I := by
      intro hmax
      apply hnotmax
      intro J hJ
      obtain ⟨M_J, hM_J, hJsub⟩ := hJ
      have : J.encard ≤ M_I.encard := by
        calc
          J.encard ≤ V(G, M_J).encard := encard_mono hJsub
          _ ≤ 2 * M_J.encard := by
            rw [V_encard_eq_sum_degree]
            exact Finset.sum_le_sum fun e _ ↦ by
              cases' G.edge_fintype_or_infinite e with hfin hinf
              · exact by
                  have : (E(G, e) ∩ M_J).encard ≤ 1 := hM_J.degree_le_one _
                  simp_all [eDegree_eq_encard_inc]
              · simp_all [eDegree_eq_encard_inc]
          _ ≤ 2 * M_I.encard := by gcongr; exact hmax.max M_J hM_J
          _ = V(G, M_I).encard := by
            rw [V_encard_eq_sum_degree]
            exact Finset.sum_congr rfl fun e _ ↦ by
              cases' G.edge_fintype_or_infinite e with hfin hinf
              · exact by
                  have : (E(G, e) ∩ M_I).encard ≤ 1 := hM_I.degree_le_one _
                  simp_all [eDegree_eq_encard_inc]
              · simp_all [eDegree_eq_encard_inc]
      exact le_of_lt (lt_of_le_of_lt (encard_mono hIsub) this)
    obtain ⟨P, hP⟩ := hM_I.exists_isAugPath_not_max hnotmax' inferInstance
    use P.first
    constructor
    · intro hfirst
      apply hP.first_not_in
      exact hIsub hfirst
    · use M_I ∆ E(P)
      constructor
      · exact hP.augment
      · intro x hx
        cases' hx with hx hx
        · exact hIsub hx
        · rw [Set.mem_insert_iff] at hx
          cases' hx with rfl hx
          · exact hP.augment_vertex_subset hP |>.mpr (by simp)
          · exact hIsub hx
