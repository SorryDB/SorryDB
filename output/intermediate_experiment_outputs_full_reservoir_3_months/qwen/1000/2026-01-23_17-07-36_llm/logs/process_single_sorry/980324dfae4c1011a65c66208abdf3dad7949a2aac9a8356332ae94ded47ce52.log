def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hBmax hImax
    obtain ⟨M_I, hM_I, hIsub⟩ := hI
    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax
    have hIB : I.encard < B.encard := by
      contrapose! hImax
      exact maximal_of_encard_ge (fun S hS ↦ hS.2.1.encard) hI hImax
    have hdiff : (B \ I).Nonempty := Set.nonempty_of_encard_pos (by
      calc
        (B \ I).encard = B.encard - I.encard := encard_sdiff_eq_sub hIsub
        _ > 0 := Nat.sub_pos_of_lt hIB)
    obtain ⟨x, hx⟩ := hdiff
    use x, hx
    have hG' : G.IsMatching.restrict₂ hM_I hM_B := G.IsMatching.restrict₂ hM_I hM_B
    have hdeg : hG'.MaxDegreeLE 2 := IsMatching.symmDiff_maxDegree_le_two hM_I hM_B
    have hcomp : ∀ C', C'.IsCompOf hG' → C'.IsPathGraph ∨ C'.IsCycleGraph :=
      fun C' hC' ↦ hC'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hdeg
    have hpath : ∃ P, P.IsPathGraph ∧ P.IsCompOf hG' ∧ x ∈ V(P) ∧ ¬(V(P) ⊆ I) := by
      apply Exists.intro (ComponentOf hG' x)
      exact ⟨ComponentOf_isCompOf _, ComponentOf_isPathGraph_or_isCycleGraph hG' x |>.resolve_right
        (by intro hcycle; simp_all [hcycle]), by simp, by
          intro hVI
          have hBx : x ∈ B := hx.1
          have hIx : x ∉ I := hx.2
          exact hIx (hVI (Component_mem hG' x))⟩
    obtain ⟨P, hPpath, hPcomp, hxP, hPnotI⟩ := hpath
    have hPalt : P.IsAltPath hM_I := by
      refine P.isAltPath_of_isCompOf_symmDiff hM_I hM_B ?_
      exact hPcomp
    have hPaug : P.IsAugPath hM_I ∨ (∃ y ∈ I \ B, P.first = y ∨ P.last = y) := by
      by_contra! h
      have hends : P.first ∈ I ∧ P.last ∈ I := by
        constructor <;> (try apply hPnotI) <;> simp_all [h]
      have hendsB : P.first ∈ B ∧ P.last ∈ B := by
        constructor <;> (try apply hBsub) <;> simp_all [h]
      have heq : P.first = P.last := by
        apply Eq.symm
        apply Classical.em (P.first = P.last) |>.elim id
        intro hne
        have hcyc : P.IsCycleGraph := P.isCycleGraph_of_isPathGraph_and_endpoints_eq hPpath rfl
        have heqcard : (E(P) ∩ M_I).encard = (E(P) ∩ M_B).encard :=
          IsMatching.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM_I hM_B hcyc hPcomp
        simp_all [heqcard]
      simp_all [heq]
    cases' hPaug with hPaug hendsnotB
    · use M_I ∆ E(P)
      exact ⟨hPaug.augment, by
        simp_all [Set.insert_subset_iff, hPaug.augment_vertex_subset]⟩
    · obtain ⟨y, hyI, hyB, hyeq⟩ := hendsnotB
      use M_I ∆ E(P)
      refine ⟨?_, ?_⟩
      · exact P.isAltPath_of_isCompOf_symmDiff hM_I hM_B hPcomp |>.augment_of_endpoint_in_M hM_I hyI hyeq
      · simp_all [Set.insert_subset_iff]
