def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hnotmax hBmax
    obtain ⟨M_I, hM_I, hIsub⟩ := hI
    have hnotmax' : ¬ G.IsMaxMatching M_I := by
      intro hmax
      apply hnotmax
      intro J hJ
      obtain ⟨M_J, hM_J, hJsub⟩ := hJ
      have : J.encard ≤ M_I.encard := hmax.max M_J hM_J
      calc
        J.encard ≤ M_I.encard := this
        _ ≤ (V(G, M_I)).encard := by
          apply encard_le_encard
          rintro x ⟨e, he, hx⟩
          exact ⟨e, he, hx⟩
        _ = (2 * M_I.encard : ℕ∞) := by
          rw [two_mul, add_comm]
          sorry
    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I hnotmax' inferInstance
    use P.first
    constructor
    · intro hfirst
      apply hP.first_not_in
      simpa [hIsub] using hfirst
    · use M_I ∆ E(P)
      constructor
      · exact hP.augment
      · intro x hx
        cases' hx with rfl hx
        · simp_all
        · apply hIsub
          exact hx
