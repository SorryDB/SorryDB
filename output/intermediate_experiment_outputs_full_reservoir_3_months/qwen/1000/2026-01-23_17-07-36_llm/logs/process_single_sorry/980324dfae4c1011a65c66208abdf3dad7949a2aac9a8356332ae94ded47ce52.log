def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hnotmax hBmax
    obtain ⟨M_I, hM_I, hIsub⟩ := hI
    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax
    have hIB : I.encard < B.encard := by
      apply lt_of_le_of_lt
      · exact encard_mono hIsub
      · exact (lt_encard_iff_encard_succ.mpr ⟨_, hnotmax⟩).trans_le (encard_mono hBsub)
    have hdiff : (B \ I).Nonempty := by
      rintro h
      rw [h, diff_empty] at hIB
      exact not_le_of_lt hIB (le_refl _)
    obtain ⟨x, hx⟩ := hdiff
    refine ⟨x, hx, ?_⟩
    cases' le_total I.encard B.encard with hle hle <;> simp_all
