      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      apply lt_of_not_ge\n      intro hge\n      have hmaxI : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by\n        intro S hS hIS\n        obtain ⟨M_S, hM_S, hSsub⟩ := hS\n        have : S.encard ≤ I.encard := by\n          calc\n            S.encard ≤ V(G, M_S).encard := encard_mono hSsub\n            _ ≤ 2 * M_S.encard := by\n              rw [V_encard_le_two_mul_encard]\n            _ ≤ 2 * M_I.encard := by\n              gcongr\n              exact hM_I.encard_le.trans (hM_S.encard_le)\n            _ = V(G, M_I).encard := by\n              rw [V_encard_eq_two_mul_encard hM_I]\n            _ = I.encard := by\n              rw [← hIsub]\n              rfl\n        exact le_antisymm (le_of_lt (lt_of_le_of_ne hIS (Ne.symm (by aesop)))) this\n      contradiction\n    have hdiff : (B \\ I).Nonempty := by\n      intro h\n      have : B ⊆ I := by\n        intro x hx\n        by_contra hx'\n        exact h ⟨x, hx, hx'⟩\n      have : B.encard ≤ I.encard := encard_mono this\n      linarith\n    obtain ⟨x, hx⟩ := hdiff\n    use x, hx\n    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I (by\n      intro hmax\n      have : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by\n        intro S hS hIS\n        obtain ⟨M_S, hM_S, hSsub⟩ := hS\n        have : S.encard ≤ I.encard := by\n          calc\n            S.encard ≤ V(G, M_S).encard := encard_mono hSsub\n            _ ≤ 2 * M_S.encard := by\n              rw [V_encard_le_two_mul_encard]\n            _ ≤ 2 * M_I.encard := by\n              gcongr\n              exact hM_I.encard_le.trans (hM_S.encard_le)\n            _ = V(G, M_I).encard := by\n              rw [V_encard_eq_two_mul_encard hM_I]\n            _ = I.encard := by\n              rw [← hIsub]\n              rfl\n        exact le_antisymm (le_of_lt (lt_of_le_of_ne hIS (Ne.symm (by aesop)))) this\n      contradiction) inferInstance\n    use M_I ∆ E(P)\n    exact ⟨hP.augment, by\n      have : I ⊆ V(G, M_I) := hIsub\n      have : V(G, M_I) ⊆ V(G, M_I ∆ E(P)) := hP.augment_vertex_subset\n      calc\n        insert x I ⊆ V(G, M_I) ∪ {x} := by\n          intro y hy\n          cases' hy with hy hy\n          · left; exact this hy\n          · right; exact hy\n        _ ⊆ V(G, M_I ∆ E(P)) := by\n          intro y hy\n          cases' hy with hy hy\n          · exact this hy\n          · have : x ∈ V(G, P) := by\n              have : P.first = x ∨ P.last = x := by\n                simp_all [IsAugPath.first_not_in, IsAugPath.last_not_in]\n                tauto\n              cases' this with hfirst hlast\n              · rw [← hfirst]; exact P.first_mem\n              · rw [← hlast]; exact P.last_mem\n            have : V(G, P) ⊆ V(G, M_I ∆ E(P)) := by\n              intro z hz\n              obtain ⟨e, he, hze⟩ := hz\n              exact ⟨e, by simpa using he, hze⟩\n            exact this hy⟩",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      apply lt_of_not_ge\n      intro hge\n      have hmaxI : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by\n        intro J hJ hIJ\n        obtain ⟨M_J, hM_J, hJsub⟩ := hJ\n        have : J.encard ≤ I.encard := by\n          calc\n            J.encard ≤ V(G, M_J).encard := encard_mono hJsub\n            _ ≤ 2 * M_J.encard := by\n              rw [V_encard_le_two_mul_encard]\n            _ ≤ 2 * M_I.encard := by\n              gcongr\n              exact hM_I.encard_le.trans (hM_B.encard_le.trans (le_refl _))\n            _ = V(G, M_I).encard := by\n              rw [V_encard_eq_two_mul_encard hM_I]\n            _ ≤ I.encard := encard_mono hIsub\n        linarith\n      contradiction\n    have hdiff : (B \\ I).Nonempty := by\n      intro h\n      have : B ⊆ I := by\n        intro x hx\n        by_contra hxi\n        exact h ⟨x, hx, hxi⟩\n      have : B.encard ≤ I.encard := encard_mono this\n      linarith\n    obtain ⟨x, hxB, hxI⟩ := hdiff\n    use x, ⟨hxB, hxI⟩\n    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I (by\n      intro hmax\n      have : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by\n        intro J hJ hIJ\n        obtain ⟨M_J, hM_J, hJsub⟩ := hJ\n        have : J.encard ≤ I.encard := by\n          calc\n            J.encard ≤ V(G, M_J).encard := encard_mono hJsub\n            _ ≤ 2 * M_J.encard := by\n              rw [V_encard_le_two_mul_encard]\n            _ ≤ 2 * ν(G) := by\n              gcongr\n              exact hM_J.encard_le\n            _ = 2 * M_I.encard := by\n              rw [← IsMaxMatching.encard (by\n                refine ⟨hM_I, fun M' hM' => ?_\n                calc\n                  M'.encard ≤ ν(G) := hM'.encard_le\n                  _ = M_I.encard := by\n                    rw [IsMaxMatching.encard (by\n                      refine ⟨hM_B, fun M' hM' => ?_\n                      calc\n                        M'.encard ≤ ν(G) := hM'.encard_le\n                        _ = M_B.encard := by\n                          rw [IsMaxMatching.encard (by\n                            refine ⟨hM_B, fun M'' hM'' => ?_\n                            exact hM''.encard_le.trans (le_refl _))])])]\n            _ = V(G, M_I).encard := by\n              rw [V_encard_eq_two_mul_encard hM_I]\n            _ ≤ I.encard := encard_mono hIsub\n        linarith\n      contradiction) (by infer_instance)\n    use M_I ∆ E(P)\n    exact ⟨hP.augment, by\n      have : I ⊆ V(G, M_I) := hIsub\n      have : V(G, M_I) ⊆ V(G, M_I ∆ E(P)) := hP.augment_vertex_subset\n      calc\n        insert x I ⊆ V(G, M_I) ∪ {x} := by\n          intro y hy\n          cases' hy with hyI hyx\n          · left\n            exact this hyI\n          · right\n            exact hyx\n        _ ⊆ V(G, M_I ∆ E(P)) := by\n          intro y hy\n          cases' hy with hyM hyx\n          · exact this hyM\n          · have : x ∈ V(G, P) := by\n              have : P.first = x ∨ P.last = x := by\n                by_contra h\n                have : x ∉ V(G, P) := by\n                  intro hxP\n                  obtain ⟨z, e, w, rfl⟩ | ⟨z, e, w, rfl⟩ := WList.mem_V_iff.mp hxP\n                  · have : P.first = z := by\n                      simp [WList.first_cons]\n                    simp_all\n                  · have : P.last = z := by\n                      simp [WList.last_cons]\n                    simp_all\n                have : x ∉ V(G, M_I ∆ E(P)) := by\n                  simp [V_symmDiff, this]\n                have : x ∈ B := hxB\n                have : x ∈ V(G, M_B) := hBsub hxB\n                have : x ∈ V(G, M_I ∆ E(P)) := by\n                  sorry\n                contradiction\n            simp [V_symmDiff, this]⟩",
      "\n              rw [V_encard_eq_two_mul_encard_of_matching hM']\n            _ ≤ 2 * M.encard := by gcongr\n            _ = V(G, M).encard := by\n              rw [V_encard_eq_two_mul_encard_of_matching hM]\n        have : J.encard ≤ I.encard := by\n          calc\n            J.encard ≤ V(G, M').encard := encard_mono hJM'\n            _ ≤ V(G, M).encard := this\n            _ = I.encard := by\n              rw [encard_eq_of_subset_of_encard_le hIM (by\n                calc\n                  I.encard ≤ V(G, M).encard := encard_mono hIM\n                  _ = I.encard := by rfl)]\n        exact le_antisymm (hIJ.trans (by rfl)) this\n      exact hnotmax this\n    obtain ⟨P, hP⟩ := hM.exists_isAugPath_not_max hnotmax' inferInstance\n    use P.first\n    constructor\n    · intro hfirst\n      have : P.first ∈ V(G, M) := hfirst\n      exact hP.first_not_in this\n    · use M ∆ E(P)\n      constructor\n      · exact hP.augment\n      · intro x hx\n        cases' hx with hx hx\n        · rw [Set.mem_insert_iff] at hx\n          cases' hx with rfl hx\n          · exact (hP.augment_vertex_subset hP).trans (Set.mem_univ _)\n          · exact (hIM hx).trans (hP.augment_vertex_subset hP)\n        · simp_all [Set.mem_diff]",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    have hnotmax' : ¬ G.IsMaxMatching M_I := by\n      intro hmax\n      apply hnotmax\n      intro J hJ\n      obtain ⟨M_J, hM_J, hJsub⟩ := hJ\n      have : J.encard ≤ M_I.encard := hmax.max M_J hM_J\n      calc\n        J.encard ≤ M_I.encard := this\n        _ ≤ (V(G, M_I)).encard := by\n          rw [encard_le_encard_iff]\n          intro x hx\n          obtain ⟨e, he, hv⟩ := V_mem.mp hx\n          exact ⟨e, he, hv⟩\n        _ = 2 * M_I.encard := by\n          rw [V_encard_eq_two_mul_of_matching hM_I]\n        _ ≤ 2 * ν(G) := by\n          gcongr\n          exact hM_I.encard_le\n    obtain ⟨P, hP⟩ := hM_I.exists_isAugPath_not_max hnotmax' inferInstance\n    use P.first\n    constructor\n    · intro hfirst\n      apply hP.first_not_in\n      exact hIsub hfirst\n    · use M_I ∆ E(P)\n      constructor\n      · exact hP.augment\n      · intro x hx\n        cases' hx with hx hx\n        · exact hIsub hx\n        · rw [Set.mem_insert_iff] at hx\n          cases' hx with rfl hx\n          · exact hP.first_mem\n          · exact hIsub hx",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hI_sub⟩ := hI\n    obtain ⟨M_B, hM_B, hB_sub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      contrapose! hnotmax\n      apply maximal_of_encard_ge\n      exact hI\n      intro J hJ\n      obtain ⟨M_J, hM_J, hJ_sub⟩ := hJ\n      calc\n        J.encard ≤ V(G, M_J).encard := encard_mono hJ_sub\n        _ ≤ 2 * M_J.encard := by\n          have : V(G, M_J).encard ≤ 2 * M_J.encard := by\n            rw [← sum_encard_fiberwise (fun e ↦ V(G, e)) (by simp [hM_J.subset]), ← Nat.cast_sum]\n            apply Finset.sum_le_sum\n            intro e he\n            have : (V(G, e)).encard ≤ 2 := by\n              cases' e ∈ M_J with heM\n              · have := hM_I.degree_le_one _\n                simp_all\n              · simp_all\n            exact_mod_cast this\n          exact this\n        _ ≤ 2 * ν(G) := by\n          apply mul_le_mul_left'\n          exact hM_J.encard_le\n        _ = V(G, M_B).encard := by\n          rw [← hM_B.encard, ← Nat.cast_two]\n          simp [hM_B.subset]\n        _ ≥ B.encard := encard_mono hB_sub\n    have hdiff : (B \\ I).Nonempty := by\n      intro h\n      have : B ⊆ I := by\n        intro x hx\n        by_contra hxi\n        exact h ⟨x, hx, hxi⟩\n      calc\n        B.encard ≤ I.encard := encard_mono this\n        _ < B.encard := hIB\n    obtain ⟨x, hx⟩ := hdiff\n    use x, hx\n    obtain ⟨P, hP⟩ := hM_I.exists_isAugPath_not_max (by\n      intro hmax\n      have : I.encard ≤ V(G, M_I).encard := encard_mono hI_sub\n      have : V(G, M_I).encard ≤ 2 * M_I.encard := by\n        have : V(G, M_I).encard ≤ 2 * M_I.encard := by\n          rw [← sum_encard_fiberwise (fun e ↦ V(G, e)) (by simp [hM_I.subset]), ← Nat.cast_sum]\n          apply Finset.sum_le_sum\n          intro e he\n          have : (V(G, e)).encard ≤ 2 := by\n            cases' e ∈ M_I with heM\n            · have := hM_I.degree_le_one _\n              simp_all\n            · simp_all\n          exact_mod_cast this\n        exact this\n      have : M_I.encard ≤ ν(G) := hM_I.encard_le\n      calc\n        I.encard ≤ 2 * ν(G) := by\n          calc\n            I.encard ≤ V(G, M_I).encard := encard_mono hI_sub\n            _ ≤ 2 * M_I.encard := by assumption\n            _ ≤ 2 * ν(G) := by gcongr\n        _ = B.encard := by\n          have : B.encard ≤ 2 * ν(G) := by\n            calc\n              B.encard ≤ V(G, M_B).encard := encard_mono hB_sub\n              _ ≤ 2 * M_B.encard := by\n                have : V(G, M_B).encard ≤ 2 * M_B.encard := by\n                  rw [← sum_encard_fiberwise (fun e ↦ V(G, e)) (by simp [hM_B.subset]), ← Nat.cast_sum]\n                  apply Finset.sum_le_sum\n                  intro e he\n                  have : (V(G, e)).encard ≤ 2 := by\n                    cases' e ∈ M_B with heM\n                    · have := hM_B.degree_le_one _\n                      simp_all\n                    · simp_all\n                  exact_mod_cast this\n                exact this\n              _ = 2 * ν(G) := by rw [hM_B.encard]\n          have : 2 * ν(G) ≤ B.encard := by\n            calc\n              2 * ν(G) = V(G, M_B).encard := by rw [hM_B.encard]\n              _ ≤ B.encard := by\n                have : V(G, M_B) ⊆ B := by\n                  intro v hv\n                  by_contra hnb\n                  have : B ⊂ V(G, M_B) := by\n                    refine ⟨hB_sub, ?_⟩\n                    use v, hv, hnb\n                  exact hBmax ⟨M_B, hM_B, this⟩\n                exact encard_mono this\n          linarith\n        _ ≤ I.encard := by\n          have : B ⊆ I := by\n            intro v hv\n            by_contra hni\n            have : I ⊂ insert v I := by\n              refine ⟨hI_sub.trans (Set.insert_subset.mpr ⟨hni, ?_⟩), ?_⟩\n              · intro w hw\n                exact hI_sub hw\n              · use v, hv, hni\n            exact hnotmax ⟨M_I, hM_I, this⟩\n          exact encard_mono this)\n    have hM'_I := hP.augment\n    use M_I ∆ E(P), hM'_I\n    intro y hy\n    cases' hy with hyI hyx\n    · have : y ∈ V(G, M_I) := hI_sub hyI\n      have : y ∈ V(G, M_I ∆ E(P)) := by\n        apply hP.augment_vertex_subset\n        exact this\n      exact this\n    · subst hyx\n      have : x ∈ V(G, M_I ∆ E(P)) := by\n        have : x = P.last := by\n          have : P.first ∉ V(G, M_I) := hP.first_not_in\n          have : P.last ∉ V(G, M_I) := hP.last_not_in\n          have : x ∈ B \\ I := hx\n          have : x ∉ I := Set.mem_diff.mp hx |>.right\n          have : x ∈ V(G, M_B) := hB_sub (Set.mem_diff.mp hx |>.left)\n          sorry\n      exact this",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      contrapose! hnotmax\n      apply maximal_of_encard_ge\n      exact fun J hJ => (hJ.2.trans hIsub).encard_le.trans hIB.le\n    have hdiff : (B \\ I).Nonempty := by\n      rw [Set.nonempty_iff_ne_empty]\n      intro h\n      rw [h] at hIB\n      simp_all\n    obtain ⟨x, hx⟩ := hdiff\n    use x, hx\n    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I (by\n      intro h\n      apply hnotmax\n      refine maximal_of_encard_ge ?_ ?_\n      · exact hI\n      · intro J ⟨M_J, hM_J, hJsub⟩\n        calc\n          J.encard ≤ V(G, M_J).encard := hJsub.encard_le\n          _ = 2 * M_J.encard := by\n            rw [V_encard_eq_two_mul_of_matching hM_J]\n          _ ≤ 2 * ν(G) := by\n            gcongr\n            exact IsMatching.encard_le hM_J\n          _ = V(G, M_I).encard := by\n            rw [← IsMaxMatching.encard (IsMatching.isMaxMatching_of_vertex_subset hM_I (by\n              intro v hv\n              have : v ∈ V(G, M_B) := hBsub hv\n              sorry))]\n            rw [V_encard_eq_two_mul_of_matching hM_I]\n          _ ≥ I.encard := hIsub.encard_le) [inferInstance]\n    use M_I ∆ E(P)\n    exact ⟨IsAugPath.augment hP, by\n      have : I ⊆ V(G, M_I) := hIsub\n      have : V(G, M_I) ⊆ V(G, M_I ∆ E(P)) := IsAugPath.augment_vertex_subset hP\n      calc\n        insert x I ⊆ V(G, M_I) ∪ {x} := by\n          intro y hy\n          cases' hy with hy hy\n          · left; exact this hy\n          · right; exact hy\n        _ ⊆ V(G, M_I ∆ E(P)) := by\n          intro y hy\n          cases' hy with hy hy\n          · exact this hy\n          · have : x ∈ V(G, P) := by\n              have : x ∈ B := hx.1\n              have : x ∈ V(G, M_B) := hBsub this\n              sorry\n            sorry⟩",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    have hnotmax' : ¬ G.IsMaxMatching M_I := by\n      intro hmax\n      apply hnotmax\n      intro J hJ\n      obtain ⟨M_J, hM_J, hJsub⟩ := hJ\n      have : J.encard ≤ M_I.encard := hmax.max M_J hM_J\n      calc\n        J.encard ≤ M_I.encard := this\n        _ ≤ (V(G, M_I)).encard := by\n          have : M_I.encard ≤ (V(G, M_I)).encard / 2 := by\n            have : ∀ v ∈ V(G, M_I), (M_I ∩ E(G, v)).encard = 1 := by\n              intro v hv\n              obtain ⟨e, he, hv'⟩ := hv\n              exact encard_singleton_of_subsingleton (hM_I.subsingleton_inc v) ⟨he, hv'⟩\n            calc\n              M_I.encard = (∑ v in V(G, M_I), (M_I ∩ E(G, v)).encard) / 2 := by\n                rw [← sum_encard_partition_edges_by_vertices]\n                simp [hM_I.subset]\n              _ = (∑ v in V(G, M_I), 1) / 2 := by\n                apply congr_arg\n                apply Finset.sum_congr rfl\n                intro v hv\n                exact this v hv\n              _ = V(G, M_I).encard / 2 := by simp\n          omega\n        _ = (V(G, M_I)).encard := by\n          have : Even (V(G, M_I)).encard := by\n            rw [even_iff_two_dvd]\n            obtain ⟨n, hn⟩ := exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero (by omega))\n            omega\n          omega\n      omega\n    obtain ⟨P, hP⟩ := hM_I.exists_isAugPath_not_max hnotmax' inferInstance\n    use P.first\n    constructor\n    · intro hfirst\n      apply hP.first_not_in\n      exact hIsub hfirst\n    · use M_I ∆ E(P)\n      constructor\n      · exact hP.augment\n      · intro x hx\n        cases' hx with hx hx\n        · exact hIsub hx\n        · rw [hx]\n          exact hP.first_mem",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hI_sub⟩ := hI\n    have hnotmax' : ¬ G.IsMaxMatching M_I := by\n      intro hmax\n      apply hnotmax\n      intro J hJ\n      obtain ⟨M_J, hM_J, hJ_sub⟩ := hJ\n      have : J.encard ≤ M_I.encard := by\n        calc\n          J.encard ≤ V(G, M_J).encard := encard_mono hJ_sub\n          _ ≤ 2 * M_J.encard := by\n            rw [two_mul]\n            exact (encard_image2_le _ _).trans (by simp [hM_J.subset])\n          _ ≤ 2 * M_I.encard := by gcongr; exact hmax.max M_J hM_J\n          _ = V(G, M_I).encard := by\n            rw [two_mul]\n            exact (encard_image2_le _ _).symm.trans (by simp [hM_I.subset])\n      have : I.encard ≤ M_I.encard * 2 := by\n        calc\n          I.encard ≤ V(G, M_I).encard := encard_mono hI_sub\n          _ ≤ 2 * M_I.encard := by\n            rw [two_mul]\n            exact (encard_image2_le _ _).trans (by simp [hM_I.subset])\n      have : J.encard ≤ I.encard := by\n        calc\n          J.encard ≤ 2 * M_I.encard := by linarith\n          _ = I.encard := by linarith\n      exact le_antisymm (by linarith) (by linarith)\n    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I hnotmax' inferInstance\n    use P.first\n    constructor\n    · intro hfirst\n      apply hP.first_not_in\n      exact hI_sub hfirst\n    · use M_I ∆ E(P)\n      constructor\n      · exact hP.augment\n      · intro x hx\n        cases' hx with hx hx\n        · exact hI_sub hx\n        · rw [Set.mem_insert_iff] at hx\n          cases' hx with rfl hx\n          · exact hP.augment_vertex_subset hP |>.mpr (hI_sub hx)\n          · exact hP.augment_vertex_subset hP |>.mpr (hI_sub hx)",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    have hnotmax' : ¬ G.IsMaxMatching M_I := by\n      intro hmax\n      apply hnotmax\n      intro J hJ\n      obtain ⟨M_J, hM_J, hJsub⟩ := hJ\n      have : J.encard ≤ M_I.encard * 2 := by\n        calc\n          J.encard ≤ V(G, M_J).encard := encard_mono hJsub\n          _ = M_J.encard * 2 := by rw [V_encard_eq_of_isMatching hM_J]\n          _ ≤ M_I.encard * 2 := by gcongr; exact hmax.max M_J hM_J\n      have : I.encard ≤ M_I.encard * 2 := by\n        calc\n          I.encard ≤ V(G, M_I).encard := encard_mono hIsub\n          _ = M_I.encard * 2 := by rw [V_encard_eq_of_isMatching hM_I]\n      have : J.encard ≤ I.encard := by\n        apply le_of_not_gt\n        intro hgt\n        have : M_I.encard < M_J.encard := by\n          nlinarith\n        have : ∃ P, G.IsAugPath hM_I P := by\n          apply IsMatching.exists_isAugPath_not_max hM_I\n          intro hmax'\n          apply hnotmax\n          intro K hK\n          obtain ⟨M_K, hM_K, hKsub⟩ := hK\n          have : K.encard ≤ M_K.encard * 2 := by\n            calc\n              K.encard ≤ V(G, M_K).encard := encard_mono hKsub\n              _ = M_K.encard * 2 := by rw [V_encard_eq_of_isMatching hM_K]\n          have : M_K.encard ≤ M_I.encard := by\n            exact hmax'.max M_K hM_K\n          nlinarith\n          assumption\n        obtain ⟨P, hP⟩ := this\n        have hM_I' : G.IsMatching (M_I ∆ E(P)) := hP.augment\n        have hIsub' : I ⊆ V(G, M_I ∆ E(P)) := by\n          calc\n            I ⊆ V(G, M_I) := hIsub\n            _ ⊆ V(G, M_I ∆ E(P)) := hP.augment_vertex_subset\n        have hnew : ∃ M, G.IsMatching M ∧ insert (P.first) I ⊆ V(G, M) := by\n          use M_I ∆ E(P)\n          constructor\n          · exact hM_I'\n          · calc\n              insert (P.first) I ⊆ insert (P.first) (V(G, M_I)) := by gcongr\n              _ ⊆ V(G, M_I ∆ E(P)) := by\n                intro x hx\n                cases' hx with hx hx\n                · have : P.first ∈ V(G, M_I ∆ E(P)) := by\n                    simp [V_union, V_singleton, P.first_mem]\n                  exact this\n                · exact hIsub' hx\n        apply hnotmax\n        use insert (P.first) I\n        exact hnew\n      apply hBmax\n      use I\n      exact hI\n    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax.out\n    have hBmax' : G.IsMaxMatching M_B := by\n      constructor\n      · exact hM_B\n      · intro M' hM'\n        apply le_of_not_gt\n        intro hgt\n        have : ∃ P, G.IsAugPath hM_B P := by\n          apply IsMatching.exists_isAugPath_not_max hM_B\n          intro hmax\n          apply hBmax\n          use B\n          exact ⟨M_B, hM_B, hBsub⟩\n          assumption\n        obtain ⟨P, hP⟩ := this\n        have hM_B' : G.IsMatching (M_B ∆ E(P)) := hP.augment\n        have hBsub' : B ⊆ V(G, M_B ∆ E(P)) := by\n          calc\n            B ⊆ V(G, M_B) := hBsub\n            _ ⊆ V(G, M_B ∆ E(P)) := hP.augment_vertex_subset\n        apply hBmax\n        use B\n        exact ⟨M_B ∆ E(P), hM_B', hBsub'⟩\n    have : M_I.encard < M_B.encard := by\n      have hIcard : I.encard ≤ M_I.encard * 2 := by\n        calc\n          I.encard ≤ V(G, M_I).encard := encard_mono hIsub\n          _ = M_I.encard * 2 := by rw [V_encard_eq_of_isMatching hM_I]\n      have hBcard : B.encard ≤ M_B.encard * 2 := by\n        calc\n          B.encard ≤ V(G, M_B).encard := encard_mono hBsub\n          _ = M_B.encard * 2 := by rw [V_encard_eq_of_isMatching hM_B]\n      have : I.encard < B.encard := by\n        apply lt_of_le_of_lt hIcard\n        nlinarith [hBmax'.encard, hnotmax']\n      nlinarith\n    have : ∃ P, G.IsAugPath hM_I P := by\n      apply IsMatching.exists_isAugPath_not_max hM_I\n      exact hnotmax'\n      infer_instance\n    obtain ⟨P, hP⟩ := this\n    use P.first\n    constructor\n    · intro hfirst\n      have : P.first ∈ V(G, M_I) := hfirst\n      exact hP.first_not_in this\n    · use M_I ∆ E(P)\n      constructor\n      · exact hP.augment\n      · calc\n          insert (P.first) I ⊆ insert (P.first) (V(G, M_I)) := by gcongr\n          _ ⊆ V(G, M_I ∆ E(P)) := by\n            intro x hx\n            cases' hx with hx hx\n            · have : P.first ∈ V(G, M_I ∆ E(P)) := by\n                simp [V_union, V_singleton, P.first_mem]\n              exact this\n            · exact hP.augment_vertex_subset hx",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hI_sub⟩ := hI\n    have hnotmax' : ¬ G.IsMaxMatching M_I := by\n      intro hmax\n      apply hnotmax\n      intro J hJ\n      obtain ⟨M_J, hM_J, hJ_sub⟩ := hJ\n      have hcard : M_J.encard ≤ M_I.encard := hmax.max M_J hM_J\n      calc\n        J.encard ≤ (V(G, M_J)).encard := encard_mono hJ_sub\n        _ ≤ 2 * M_J.encard := by\n          have : (V(G, M_J)).encard ≤ 2 * M_J.encard := by\n            rw [← two_mul]\n            exact encard_sum_le_of_disjoint (fun e _ ↦ (hM_J.subsingleton_inc _).toFinset.encard_le_one)\n          exact this\n        _ ≤ 2 * M_I.encard := by gcongr\n        _ = (V(G, M_I)).encard := by\n          have : (V(G, M_I)).encard = 2 * M_I.encard := by\n            rw [← two_mul]\n            exact encard_sum_eq_of_disjoint (fun e _ ↦ (hM_I.subsingleton_inc _).toFinset.encard_eq_one)\n          exact this.symm\n        _ = I.encard := by\n          have : I = V(G, M_I) := by\n            apply le_antisymm\n            · exact hI_sub\n            · intro x hx\n              apply hnotmax\n              intro J hJ\n              obtain ⟨M_J, hM_J, hJ_sub⟩ := hJ\n              have hcard : M_J.encard ≤ M_I.encard := hmax.max M_J hM_J\n              calc\n                J.encard ≤ (V(G, M_J)).encard := encard_mono hJ_sub\n                _ ≤ 2 * M_J.encard := by\n                  have : (V(G, M_J)).encard ≤ 2 * M_J.encard := by\n                    rw [← two_mul]\n                    exact encard_sum_le_of_disjoint (fun e _ ↦ (hM_J.subsingleton_inc _).toFinset.encard_le_one)\n                  exact this\n                _ ≤ 2 * M_I.encard := by gcongr\n                _ = (V(G, M_I)).encard := by\n                  have : (V(G, M_I)).encard = 2 * M_I.encard := by\n                    rw [← two_mul]\n                    exact encard_sum_eq_of_disjoint (fun e _ ↦ (hM_I.subsingleton_inc _).toFinset.encard_eq_one)\n                  exact this.symm\n          exact this ▸ rfl\n    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I hnotmax' inferInstance\n    use P.last\n    constructor\n    · intro hlast_in_I\n      have : P.last ∈ V(G, M_I) := hI_sub hlast_in_I\n      exact hP.last_not_in this\n    · use M_I ∆ E(P)\n      constructor\n      · exact hP.augment\n      · intro x hx\n        cases' hx with hx hx\n        · have : x ∈ V(G, M_I) := hI_sub hx\n          exact hP.augment_vertex_subset this\n        · subst hx\n          simp [symmDiff, Set.mem_union, Set.mem_diff]\n          exact Or.inr ⟨by simp [hP.nonempty], by simp [hP.last_not_in]⟩",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hI_sub⟩ := hI\n    obtain ⟨M_B, hM_B, hB_sub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      apply lt_of_le_of_lt\n      · exact encard_mono hI_sub\n      · exact lt_of_le_of_ne (encard_mono hB_sub) (fun h => hnotmax (by simp_all [h]))\n    have hdiff : (B \\ I).Nonempty := by\n      intro h\n      rw [Set.eq_empty_iff_forall_not_mem] at h\n      have : B ⊆ I := by\n        intro x hx\n        by_contra hxi\n        exact h x ⟨hx, hxi⟩\n      calc\n        B.encard ≤ I.encard := encard_mono this\n        _ < B.encard := hIB\n    obtain ⟨x, hx⟩ := hdiff\n    refine ⟨x, hx, ?_⟩\n    have hM_I' : G.IsMatching M_I := hM_I\n    have hM_B' : G.IsMatching M_B := hM_B\n    let G' := hM_I'.restrict₂ hM_B'\n    have hmaxdeg : G'.MaxDegreeLE 2 := hM_I'.symmDiff_maxDegree_le_two hM_B'\n    have hcomp : ∀ C, C.IsCompOf G' → C.IsPathGraph ∨ C.IsCycleGraph := by\n      intro C hC\n      exact hC.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmaxdeg\n    have hends : ∀ v ∈ B \\ I, ∃ P, P.IsPathIn G' ∧ P.first = v ∧ (P.last ∈ I \\ B ∨ P.last ∉ V(G, M_I)) := by\n      intro v hv\n      sorry\n    obtain ⟨P, hP_path, hP_first, hP_last⟩ := hends x hx\n    have hP_alt : G.IsAltPath hM_I P := by\n      sorry\n    have hnewM : G.IsMatching (M_I ∆ E(P)) := by\n      sorry\n    use M_I ∆ E(P), hnewM\n    sorry",
      "s⟩",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      apply lt_of_le_of_lt\n      · exact encard_mono hIsub\n      · exact lt_of_not_ge fun hge => hnotmax (fun hS => hBmax (by simpa using hS))\n    have hdiff : (B \\ I).Nonempty := by\n      rw [Set.nonempty_iff_ne_empty]\n      intro h\n      rw [h] at hIB\n      simp_all\n    obtain ⟨x, hx⟩ := hdiff\n    use x, hx\n    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I (by\n      intro hmax\n      have hle : B.encard ≤ I.encard := by\n        obtain ⟨M', hM', hsub⟩ := hmax\n        calc\n          B.encard ≤ V(G, M').encard := encard_mono hBsub\n          _ = 2 * M'.encard := by\n            rw [V_encard_eq_two_mul_encard_of_matching hM']\n          _ ≤ 2 * M_I.encard := by\n            gcongr\n            exact hmax.max M_I hM_I\n          _ = V(G, M_I).encard := by\n            rw [V_encard_eq_two_mul_encard_of_matching hM_I]\n          _ ≥ I.encard := encard_mono hIsub) at hIB\n      exact lt_irrefl _ (lt_of_le_of_lt hle hIB)) inferInstance\n    use M_I ∆ E(P)\n    exact ⟨hP.augment, by\n      have hIsub' : I ⊆ V(G, M_I ∆ E(P)) := by\n        intro y hy\n        have hysub : y ∈ V(G, M_I) := hIsub hy\n        contrapose! hysub\n        simp_all [V_symmDiff, Set.mem_union, Set.mem_diff]\n      have hxsub : x ∈ V(G, M_I ∆ E(P)) := by\n        have hfirst : P.first = x ∨ P.last = x := by\n          cases' hP with _ _ hfirst hlast\n          left; exact hfirst.symm\n        cases' hfirst with hfirst hlast\n        · simp_all [V_symmDiff, Set.mem_union, Set.mem_diff]\n        · simp_all [V_symmDiff, Set.mem_union, Set.mem_diff]\n      simp_all [Set.insert_subset_iff]⟩",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hI_sub⟩ := hI\n    obtain ⟨M_B, hM_B, hB_sub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      apply lt_of_le_of_lt\n      · exact encard_mono hI_sub\n      · exact (lt_encard_iff_encard_succ_le.mp (by simpa using hnotmax))\n    have hdiff : (B \\ I).Nonempty := by\n      contrapose! hIB\n      rw [Set.encard_diff_eq_encard_sub hI_sub]\n      simp_all\n    obtain ⟨x, hx⟩ := hdiff\n    refine ⟨x, hx, ?_⟩\n    have hM_I' : G.IsMatching M_I := hM_I\n    have hM_B' : G.IsMatching M_B := hM_B\n    let G' := hM_I'.restrict₂ hM_B'\n    have hmaxdeg : G'.MaxDegreeLE 2 := hM_I'.symmDiff_maxDegree_le_two hM_B'\n    have hcomp : ∀ C, C.IsCompOf G' → C.IsPathGraph ∨ C.IsCycleGraph := by\n      intro C hC\n      exact hC.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmaxdeg\n    have hends : ∀ v ∈ B \\ I, ∃ P, P.IsPathIn G' ∧ P.first = v ∧ (P.last ∈ I \\ B ∨ P.last ∉ V(G, M_I)) := by\n      sorry\n    obtain ⟨P, hP_path, hP_first, hP_last⟩ := hends x hx\n    use M_I ∆ E(P)\n    constructor\n    · exact hM_I'.augment (by\n        refine { toIsAltPath := ?_, nonempty := ?_, first_not_in := ?_, last_not_in := ?_ }\n        · exact hM_I'.of_cons (by\n            simp_all [isAltPath_iff]\n            )\n        · exact P.nonempty_of_isPath hP_path\n        · simp_all\n        · simp_all)\n    · simp_all [Set.insert_subset]",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hI_sub⟩ := hI\n    obtain ⟨M_B, hM_B, hB_sub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      contrapose! hnotmax\n      apply maximal_of_encard_ge\n      exact fun J hJ ↦ (hJ.2.1.encard_le.trans (by simpa using hJ.2.2)).trans (by simpa using hIB.le)\n    have hdiff : (B \\ I).Nonempty := by\n      intro h\n      rw [Set.encard_diff_eq_sub hI_sub] at hIB\n      omega\n    obtain ⟨x, hx⟩ := hdiff\n    refine ⟨x, hx, ?_⟩\n    have hM_I' : G.IsMatching M_I := hM_I\n    have hM_B' : G.IsMatching M_B := hM_B\n    let G' := hM_I'.restrict₂ hM_B'\n    have hG'_maxdeg : G'.MaxDegreeLE 2 := hM_I'.symmDiff_maxDegree_le_two hM_B'\n    have hcomp : ∀ C, C.IsCompOf G' → C.IsPathGraph ∨ C.IsCycleGraph :=\n      fun C hC ↦ hC.isPathGraph_or_isCycleGraph_of_maxDegreeLE hG'_maxdeg\n    have hends : ∀ v ∈ B \\ I, ∃ P, P.IsPathIn G' ∧ (P.first = v ∨ P.last = v) ∧\n        (P.first ∉ I ∨ P.last ∉ I) := by\n      intro v hv\n      have hvB : v ∈ B := hv.1\n      have hvI : v ∉ I := hv.2\n      have hvM_B : v ∈ V(G, M_B) := hB_sub hvB\n      have hvM_I : v ∉ V(G, M_I) := by\n        intro h\n        exact hvI (hI_sub h)\n      obtain ⟨e, he⟩ := hvM_B\n      have he' : e ∈ M_B := he.1\n      have he'' : v ∈ V(G, e) := he.2\n      have heM_I : e ∉ M_I := by\n        intro h\n        exact hvM_I ⟨h, v, he''⟩\n      have heG' : e ∈ E(G') := by\n        simp [restrict₂, loopRemove, symmDiff]\n        exact Or.inl ⟨he', heM_I⟩\n      have hcompv : ∃ C, C.IsCompOf G' ∧ v ∈ V(C) := by\n        apply exists_comp_of_mem_vertex\n        exact ⟨e, heG', he''⟩\n      obtain ⟨C, hC_comp, hCv⟩ := hcompv\n      cases' hcomp C hC_comp with hC_path hC_cycle\n      · use WList.ofPathGraph C hC_path\n        simp [WList.ofPathGraph_isPathIn, hC_path]\n        have hC_ends : C.first ≠ C.last := by\n          apply hC_path.first_ne_last_of_nontrivial\n          intro h\n          have hC_singleton : C.IsSingleton := by\n            rw [← hC_path.first_eq_last_iff]\n            exact h\n          have hC_edge : E(C).Subsingleton := by\n            apply subsingleton_of_isSingleton hC_singleton\n          have hC_no_edge : E(C) = ∅ := by\n            intro e he\n            have heM_I : e ∈ M_I := by\n              simp [restrict₂, loopRemove, symmDiff] at he\n              cases' he with heM_I heM_B\n              · exact heM_I\n              · contradiction\n            have heM_B : e ∈ M_B := by\n              simp [restrict₂, loopRemove, symmDiff] at he\n              cases' he with heM_I heM_B\n              · contradiction\n              · exact heM_B\n            have hdisj : Disjoint V(G, e) V(G, e) := hM_I.disjoint heM_I heM_B (by aesop)\n            contradiction\n          contradiction\n        have hC_first_or_last : C.first = v ∨ C.last = v := by\n          apply hC_path.mem_vertex_iff_first_or_last hC_ends\n          exact hCv\n        cases' hC_first_or_last with hfirst hlast\n        · left\n          exact hfirst\n        · right\n          exact hlast\n        have hC_first_not_I : C.first ∉ I ∨ C.last ∉ I := by\n          by_contra h\n          push_neg at h\n          have hC_first_M_I : C.first ∈ V(G, M_I) := hI_sub h.1\n          have hC_last_M_I : C.last ∈ V(G, M_I) := hI_sub h.2\n          have hC_first_M_B : C.first ∈ V(G, M_B) := by\n            apply hB_sub\n            apply hBmax.maximal\n            use M_B, hM_B, insert C.first B\n            simp\n          have hC_last_M_B : C.last ∈ V(G, M_B) := by\n            apply hB_sub\n            apply hBmax.maximal\n            use M_B, hM_B, insert C.last B\n            simp\n          contradiction\n        exact hC_first_not_I\n      · contradiction\n    obtain ⟨P, hP_path, hP_end, hP_not_I⟩ := hends x hx\n    use M_I ∆ E(P)\n    constructor\n    · apply hM_I.augment\n      constructor\n      · apply hP_path.isPath\n      · simp [IsAltPath.mem_matching_iff]\n        intro e f he hf\n        simp [restrict₂, loopRemove, symmDiff] at he hf\n        cases' he with heM_I heM_B <;> cases' hf with hfM_I hfM_B <;> simp_all\n    · simp\n      intro y hy\n      cases' hy with hy hy\n      · exact hI_sub hy\n      · exact hy",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hI_sub⟩ := hI\n    obtain ⟨M_B, hM_B, hB_sub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      contrapose! hnotmax\n      apply maximal_of_encard_ge\n      · exact fun S hS ↦ hS\n      · exact hnotmax\n    have hdiff : (B \\ I).Nonempty := by\n      intro h\n      rw [Set.encard_diff_eq_sub hI_sub] at hIB\n      omega\n    obtain ⟨x, hx⟩ := hdiff\n    use x, hx\n    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I (by\n      intro hmax\n      have : B.encard ≤ M_I.encard * 2 := by\n        calc\n          B.encard ≤ V(G, M_I).encard := encard_mono hI_sub\n          _ = M_I.encard * 2 := by\n            rw [V_encard_eq_two_mul_encard_of_matching hM_I]\n      have : M_I.encard * 2 < B.encard := by\n        calc\n          M_I.encard * 2 = I.encard := by\n            rw [← V_encard_eq_two_mul_encard_of_matching hM_I]\n            exact encard_congr hI_sub\n          _ < B.encard := hIB\n      linarith) (by infer_instance)\n    use M_I ∆ E(P)\n    exact ⟨hP.augment, by\n      calc\n        insert x I ⊆ V(G, M_I) ∪ {x} := by\n          simp [Set.insert_subset_iff, hI_sub]\n        _ ⊆ V(G, M_I ∆ E(P)) := by\n          intro y hy\n          cases' hy with hy hy\n          · exact hP.augment_vertex_subset hy\n          · rw [hy]\n            exact hP.first_not_in.symm ▸ hP.augment_vertex_subset (by simp [hP.first_not_in])\n    ⟩",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    have hnotmax' : ¬ G.IsMaxMatching M_I := by\n      intro hmax\n      apply hnotmax\n      intro J hJ\n      obtain ⟨M_J, hM_J, hJsub⟩ := hJ\n      have : J.encard ≤ M_I.encard := by\n        calc\n          J.encard ≤ V(G, M_J).encard := encard_mono hJsub\n          _ ≤ 2 * M_J.encard := by\n            rw [V_encard_eq_sum_degree]\n            exact Finset.sum_le_sum fun e _ ↦ by\n              cases' G.edge_fintype_or_infinite e with hfin hinf\n              · exact by\n                  have : (E(G, e) ∩ M_J).encard ≤ 1 := hM_J.degree_le_one _\n                  simp_all [eDegree_eq_encard_inc]\n              · simp_all [eDegree_eq_encard_inc]\n          _ ≤ 2 * M_I.encard := by gcongr; exact hmax.max M_J hM_J\n          _ = V(G, M_I).encard := by\n            rw [V_encard_eq_sum_degree]\n            exact Finset.sum_congr rfl fun e _ ↦ by\n              cases' G.edge_fintype_or_infinite e with hfin hinf\n              · exact by\n                  have : (E(G, e) ∩ M_I).encard ≤ 1 := hM_I.degree_le_one _\n                  simp_all [eDegree_eq_encard_inc]\n              · simp_all [eDegree_eq_encard_inc]\n      exact le_of_lt (lt_of_le_of_lt (encard_mono hIsub) this)\n    obtain ⟨P, hP⟩ := hM_I.exists_isAugPath_not_max hnotmax' inferInstance\n    use P.first\n    constructor\n    · intro hfirst\n      apply hP.first_not_in\n      exact hIsub hfirst\n    · use M_I ∆ E(P)\n      constructor\n      · exact hP.augment\n      · intro x hx\n        cases' hx with hx hx\n        · exact hIsub hx\n        · rw [Set.mem_insert_iff] at hx\n          cases' hx with rfl hx\n          · exact hP.augment_vertex_subset hP |>.mpr (by simp)\n          · exact hIsub hx",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      apply lt_of_le_of_lt\n      · exact encard_mono hIsub\n      · exact (lt_encard_iff_encard_succ.mpr ⟨_, hBsub, hnotmax⟩).resolve_left (by simpa using hBmax)\n    have hdiff : (B \\ I).Nonempty := by\n      contrapose! hIB\n      simp_all [encard_eq_zero_iff]\n    obtain ⟨x, hx⟩ := hdiff\n    use x, hx\n    obtain ⟨P, hP⟩ := IsMatching.exists_isAugPath_not_max hM_I (by\n      intro hmax\n      have : B.encard ≤ M_I.encard * 2 := by\n        calc\n          B.encard ≤ V(G, M_I).encard := encard_mono hIsub\n          _ = M_I.encard * 2 := by\n            rw [V_encard_eq_two_mul_encard_of_matching hM_I]\n      have : M_I.encard * 2 < B.encard := by\n        calc\n          M_I.encard * 2 = V(G, M_I).encard := by\n            rw [V_encard_eq_two_mul_encard_of_matching hM_I]\n          _ ≥ I.encard := encard_mono hIsub\n          _ < B.encard := hIB\n      linarith) inferInstance\n    use M_I ∆ E(P)\n    exact ⟨hP.augment, by\n      calc\n        insert x I ⊆ V(G, M_I) ∪ {x} := by\n          intro y hy\n          cases' hy with hy hy\n          · exact Or.inl (hIsub hy)\n          · exact Or.inr (by simpa using hy)\n        _ ⊆ V(G, M_I ∆ E(P)) := by\n          intro y hy\n          cases' hy with hy hy\n          · exact hP.augment_vertex_subset hy\n          · simp_all [hP.first_not_in, hP.last_not_in]⟩",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      contrapose! hnotmax\n      apply maximal_of_encard_ge\n      exact fun J hJ ↦ (hJ.2.1.encard_le.trans (hJ.2.2.encard_le.trans (by simp_all [hJ.2.1, hJ.2.2])))\n    have hdiff : (B \\ I).Nonempty := by\n      intro h\n      rw [Set.eq_empty_iff_forall_not_mem] at h\n      have : B ⊆ I := by\n        intro x hx\n        by_contra hx'\n        exact h x ⟨hx, hx'⟩\n      exact not_lt_of_ge (encard_mono this) hIB\n    obtain ⟨x, hx⟩ := hdiff\n    use x, hx\n    obtain ⟨P, hP⟩ := hM_I.exists_isAugPath_not_max (by\n      intro hmax\n      have : B.encard ≤ ν(G) := by\n        obtain ⟨M, hM, _⟩ := hBmax\n        exact hM.encard_le\n      have : ν(G) = M_I.encard := by\n        apply le_antisymm\n        · exact hM_I.encard_le\n        · exact hmax.encard.ge\n      linarith)\n    use M_I ∆ E(P)\n    exact ⟨hP.augment, by\n      have : I ⊆ V(G, M_I) := hIsub\n      have : V(G, M_I) ⊆ V(G, M_I ∆ E(P)) := hP.augment_vertex_subset\n      calc\n        insert x I ⊆ V(G, M_I) ∪ {x} := by simp [Set.insert_subset_iff, this]\n        _ ⊆ V(G, M_I ∆ E(P)) := by\n          intro y hy\n          cases' hy with hy hy\n          · exact this hy\n          · rw [Set.mem_singleton_iff] at hy\n            rw [hy]\n            exact hP.last_not_in.symm ▸ by simpa using hP.toIsPath.last_mem⟩",
      "\n    intro I B hI hnotmax hBmax\n    obtain ⟨M_I, hM_I, hIsub⟩ := hI\n    obtain ⟨M_B, hM_B, hBsub⟩ := hBmax\n    have hIB : I.encard < B.encard := by\n      contrapose! hnotmax\n      apply maximal_of_encard_ge\n      · exact hI\n      · intro J hJ\n        obtain ⟨M_J, hM_J, hJsub⟩ := hJ\n        calc\n          J.encard ≤ (V(G, M_J)).encard := encard_mono hJsub\n          _ ≤ 2 * M_J.encard := by\n            rw [← two_mul, ← encard_sum_add_encard_compl_inter]\n            simp [hM_J.degree_le_one]\n          _ ≤ 2 * ν(G) := by\n            refine mul_le_mul_left' (hM_J.encard_le _) _\n          _ = (V(G, M_B)).encard := by\n            rw [← two_mul, ← hM_B.encard, ← encard_sum_add_encard_compl_inter]\n            simp [hM_B.degree_le_one]\n          _ ≥ B.encard := encard_mono hBsub\n    have hdiff : (B \\ I).Nonempty := by\n      intro h\n      rw [Set.eq_empty_iff_forall_not_mem] at h\n      have : B ⊆ I := by\n        intro x hx\n        by_contra hxi\n        exact h x ⟨hx, hxi⟩\n      calc\n        B.encard ≤ I.encard := encard_mono this\n        _ < B.encard := hIB\n    obtain ⟨x, hx⟩ := hdiff\n    use x, hx\n    obtain ⟨P, hP⟩ := hM_I.exists_isAugPath_not_max (by\n      intro hmax\n      have : I.encard ≤ (V(G, M_I)).encard := encard_mono hIsub\n      have : (V(G, M_I)).encard ≤ 2 * M_I.encard := by\n        rw [← two_mul, ← encard_sum_add_encard_compl_inter]\n        simp [hM_I.degree_le_one]\n      have : 2 * M_I.encard ≤ 2 * ν(G) := by\n        refine mul_le_mul_left' (hM_I.encard_le _) _\n      have : 2 * ν(G) = (V(G, M_B)).encard := by\n        rw [← two_mul, ← hM_B.encard, ← encard_sum_add_encard_compl_inter]\n        simp [hM_B.degree_le_one]\n      have : (V(G, M_B)).encard ≥ B.encard := encard_mono hBsub\n      linarith) (by infer_instance)\n    use M_I ∆ E(P)\n    constructor\n    · exact hP.augment\n    · intro y hy\n      cases' hy with hyI hyx\n      · have : y ∈ V(G, M_I) := hIsub hyI\n        have : y ∈ V(G, M_I ∆ E(P)) := hP.augme