def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hnotmax hBmax
    obtain ⟨M_I, hM_I, hIsub⟩ := hI
    have hnotmax' : ¬ G.IsMaxMatching M_I := by
      intro hmax
      apply hnotmax
      intro J hJ
      obtain ⟨M_J, hM_J, hJsub⟩ := hJ
      have : J.encard ≤ M_I.encard := hmax.max M_J hM_J
      calc
        J.encard ≤ M_I.encard := this
        _ ≤ (V(G, M_I)).encard := by
          rw [encard_le_encard_iff]
          intro x hx
          obtain ⟨e, he, hv⟩ := V_mem.mp hx
          exact ⟨e, he, hv⟩
        _ = 2 * M_I.encard := by
          rw [V_encard_eq_two_mul_of_matching hM_I]
        _ ≤ 2 * ν(G) := by
