    if_true, if_false, ite_mul, sub_mul, add_mul, mul_sub, mul_add, mul_comm, mul_left_comm]
  have h1 : ∀ j, j ≠ i → (Function.update x i (if 0 < biasedLocalField net x i then SpinState.up
    else if biasedLocalField net x i < 0 then SpinState.down else x i)) j = x j := by
    intro j hj; simp [hj]
  have h2 : (Function.update x i (if 0 < biasedLocalField net x i then SpinState.up
    else if biasedLocalField net x i < 0 then SpinState.down else x i)) i =
    (if 0 < biasedLocalField net x i then SpinState.up
    else if biasedLocalField net x i < 0 then SpinState.down else x i) := by
    simp
  rw [h2]
  let x' := Function.update x i (if 0 < biasedLocalField net x i then SpinState.up
    else if biasedLocalField net x i < 0 then SpinState.down else x i)
  let xVec := toRealVector x
  let x'Vec := toRealVector x'
  have h3 : x'Vec = Vector.ofFn (fun j => if j = i then (if 0 < biasedLocalField net x i then 1
    else if biasedLocalField net x i < 0 then -1 else xVec j) else xVec j) := by
    ext j; simp [x', xVec, x'Vec, toRealVector]
  rw [h3]
  simp_all only [Finset.sum_ite, Finset.sum_const, Finset.sum_range_succ, Finset.sum_range_zero,
    Finset.sum_singleton, Finset.sum_union, Finset.sum_diff, Finset.mem_univ, true_and,
