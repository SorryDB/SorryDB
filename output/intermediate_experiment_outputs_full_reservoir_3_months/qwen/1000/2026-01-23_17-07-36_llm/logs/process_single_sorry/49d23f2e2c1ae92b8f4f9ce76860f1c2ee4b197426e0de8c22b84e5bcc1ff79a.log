        basic_type := req.basic_type, occurrence := req.occurrence, pairedRequest? := some paired.id };
    (state.requests.insert req').insert paired'
orderConstraints' : OrderConstraints := state.updateOrderConstraintsAccept req
id : RequestId
h : ∃ a, a ∈ state.removed ∧ a.id = id
