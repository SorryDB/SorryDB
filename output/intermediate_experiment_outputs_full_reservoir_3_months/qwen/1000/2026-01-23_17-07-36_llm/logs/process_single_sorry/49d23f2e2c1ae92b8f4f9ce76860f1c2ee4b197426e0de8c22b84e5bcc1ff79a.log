    occurrence := 0, pairedRequest? := none }
previous : List Request := state.requests.filter fun r => prelimReq.equivalent r
removed : List Request := List.filter (fun r => prelimReq.equivalent r) state.removed
occurrences : List Nat := List.map Request.occurrence previous ++ List.map Request.occurrence removed
req : Request :=
  { id := prelimReq.id, propagated_to := prelimReq.propagated_to, predecessor_at := prelimReq.predecessor_at,
    thread := prelimReq.thread, basic_type := prelimReq.basic_type, occurrence := occurrences.maximum + 1,
    pairedRequest? := prelimReq.pairedRequest? }
pairedRequest? : Option Request :=
  if (reqType.isWrite && (reqType.isTransactional || reqType.isAtomic)) = true then
    let threadReads :=
      state.requests.filter fun r =>
        r.thread == tId && r.isRead && r.address? == req.address? && (r.isAtomic || r.isTransactional);
    let ocLookup := state.orderConstraints.lookup (state.scopes.jointScope tId tId);
    let paired := List.filter (fun r => threadReads.all fun r' => r.id == r'.id || ocLookup r'.id r.id) threadReads;
    paired.head?
  else none
requests' : RequestArray :=
  match pairedRequest? with
  | none => state.requests.insert req
