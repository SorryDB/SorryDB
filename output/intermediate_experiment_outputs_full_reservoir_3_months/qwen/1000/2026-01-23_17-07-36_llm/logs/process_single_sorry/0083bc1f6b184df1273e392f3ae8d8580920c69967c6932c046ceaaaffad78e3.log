/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf (by norm_num : (0 : ℝ) < 1)
  obtain ⟨t, ht, hft⟩ := hl 0
  use ‖f 0‖ + 1
  intro x
  have := hft x
  calc
    ‖f x‖ = ‖f (0 + t + (x - t))‖ := by ring
    _ ≤ ‖f (0 + t)‖ + ‖f (x) - f (0 + t)‖ := by
        simpa using norm_add_le (f (0 + t)) (f x - f (0 + t))
    _ ≤ ‖f 0‖ + 1 := by
        gcongr
        all_goals linarith [ht.1, ht.2]
