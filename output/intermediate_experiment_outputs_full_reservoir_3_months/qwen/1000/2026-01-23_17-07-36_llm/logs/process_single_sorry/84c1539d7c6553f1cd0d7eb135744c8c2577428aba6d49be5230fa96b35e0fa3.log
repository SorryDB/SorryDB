namespace BST1

example {α : Type} (t : Tree α) :
  t.height ≤ t.size ∧ t.size < 2 ^ t.height := by
  apply And.intro
  {
   induction t with
   | null  => simp [Tree.height, Tree.size]
   | node t₁ x t₂ ihl ihr =>
     simp [Tree.height, Tree.size]
     sorry
  }
  {
  induction t with
  | null => simp [Tree.height, Tree.size]
  | node t₁ x t₂ ihl ihr =>
    simp [Tree.height, Tree.size]
    have h₁ : t₁.size < 2 ^ t₁.height := ihl
    have h₂ : t₂.size < 2 ^ t₂.height := ihr
    have h₃ : t₁.size + 1 + t₂.size < 2 ^ t₁.height + 2 ^ t₂.height := by
      linarith
    have h₄ : 2 ^ t₁.height + 2 ^ t₂.height ≤ 2 * 2 ^ max t₁.height t₂.height := by
      cases le_total t₁.height t₂.height <;> simp [*] <;> linarith
    have h₅ : 2 * 2 ^ max t₁.height t₂.height = 2 ^ (1 + max t₁.height t₂.height) := by
      ring
    linarith
  }
