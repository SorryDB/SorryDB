      calc
        t₁.size + 1 + t₂.size
          = (t₁.size + t₂.size) + 1 := by ring
        _ < 2 ^ t₁.height + 2 ^ t₂.height := by linarith
        _ ≤ 2 ^ max t₁.height t₂.height + 2 ^ max t₁.height t₂.height := by
