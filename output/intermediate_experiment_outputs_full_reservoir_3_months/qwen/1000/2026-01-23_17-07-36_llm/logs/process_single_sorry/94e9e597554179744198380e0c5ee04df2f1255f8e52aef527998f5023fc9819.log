lemma matchingMatroid.noColoop (h : ∀ x, G.inessential x) (hx : x ∈ V(G)) :
    ¬ G.matchingMatroid.IsColoop x := by
  intro hc
  have hM := h x
  obtain ⟨M, hMmax, hxM⟩ := hM
  have hMmatch : G.IsMatching M := hMmax.toIsMatching
  have hV : V(G, M) ⊆ V(G) := by simp
  have hrank : G.matchingMatroid.eRk (V(G) \ {x}) = G.matchingMatroid.eRank := by
    rw [Matroid.isColoop_iff_eRk_erase] at hc
    exact hc
  have hcard : M.encard = ν(G) := IsMaxMatching.encard hMmax
  have hmatchable : ∃ M', G.IsMatching M' ∧ V(G) \ {x} ⊆ V(G, M') := by
    rw [matchingMatroid, IndepMatroid.matroid_eRk, matchingIndepMatroid] at hrank
    simp only [Set.encard_diff_singleton, Set.encard_eq_zero, not_le, Nat.cast_le,
      Nat.cast_add, Nat.cast_one, add_comm] at hrank
    exact ⟨M, hMmatch, fun y hy => by simp_all⟩
  obtain ⟨M', hM'match, hsub⟩ := hmatchable
  have hM'card : M'.encard ≤ ν(G) := IsMatching.encard_le hM'match
  have hV'M' : x ∉ V(G, M') := by
    intro hcontra
    have hM'full : V(G) ⊆ V(G, M') := by
      intro y hy
      cases eq_or_ne y x
      · contradiction
      · exact hsub hy
    have hM'max : G.IsMaxMatching M' := IsMatching.isMaxMatching_of_vertex_subset hM'match hM'full
    have hM'eq : M'.encard = ν(G) := IsMaxMatching.encard hM'max
    rw [← hM'eq] at hM'card
    linarith
  exact hxM (hsub hx)
