theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  cases le_or_lt i L.flatten.length
  case inl h_le =>
    have h : i < L.flatten.length + 1 := Nat.lt_succ_of_le h_le
    revert h
    revert i
    induction L with
    | nil => intro i _; simp
    | cons l L ih =>
      intro i h
      simp [flatten_cons, take_append]
      split
      · intro h'
        have : findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums = 1 := by
          simp [partialSums_cons, findIdx_cons]
          rw [findIdx_eq] <;> grind
        simp [this]
        simp [Nat.sub_zero]
      · intro h'
        have : findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums =
            findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums + 1 := by
          simp [partialSums_cons, findIdx_cons, Function.comp_def]
          congr
          funext x
          grind
        simp [this]
        specialize ih (i - l.length)
        have : i - l.length < L.flatten.length + 1 := by
          omega
        rw [ih this]
        simp [take_cons, Nat.sub_sub, Nat.add_sub_cancel]
        omega
  case inr h_gt =>
    have : i ≥ L.flatten.length := Nat.le_of_not_lt h_gt
    have : L.flatten.take i = L.flatten := by
      apply take_all
      exact this
    rw [this]
    have : (L.map length).partialSums.findIdx (· > i) = (L.map length).partialSums.length := by
      apply findIdx_eq_length
      intro x hx
      have : x ≤ L.flatten.length := by
        apply List.mem_partialSums_map_length_le
        exact hx
      omega
    simp [this]
    simp [Nat.sub_self, take_nil, append_nil]
