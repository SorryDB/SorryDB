theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil => simp [partialSums_nil, findIdx_nil]
  | cons l L ih =>
    simp only [flatten_cons, map_cons, partialSums_cons, take_append]
    split_ifs with h
    · have : findIdx (fun x => decide (x > i)) (0 :: (L.map length).partialSums.map (l.length + ·)) = 0 := by
        simp [findIdx_cons]
        exact Nat.not_lt_zero _
      simp [this]
      omega
    · have : findIdx (fun x => decide (x > i)) (0 :: (L.map length).partialSums.map (l.length + ·)) =
        findIdx (fun x => decide (x > i - l.length)) (L.map length).partialSums + 1 := by
        simp [findIdx_cons]
        congr
        funext x
        simp [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]
      simp [this]
      rw [ih]
      simp [take_cons, Nat.sub_add_cancel (le_of_not_lt h)]
