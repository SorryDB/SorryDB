      "by\n  have h_le : refinement B hB hB' hB'' ≤ D := refinement_le B hB hB' hB''\n  refine ⟨h_le, fun h_eq => ?_⟩\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_eq_carrier : (refinement B hB hB' hB'').carrier = D.carrier := by\n    rw [SetLike.ext'_iff] at h_eq\n    exact h_eq\n  simp only [Set.mem_iUnion, Set.mem_iUnion₂] at h_eq_carrier\n  have h_subset : ∀ N hN, B N hN ⊆ D.carrier := by\n    intro N hN\n    intro x hx\n    rw [h_eq_carrier] at *\n    aesop\n  have h_single : B N hN = {N} := by\n    apply Set.eq_singleton_iff_unique_mem.mpr\n    refine ⟨⟨N, hN, rfl⟩, fun x hx => ?_⟩\n    rw [h_eq_carrier] at hx\n    rcases hx with ⟨M', hM', y, hy, rfl⟩\n    have h_sSup : N = sSup (B N hN) := hB N hN\n    have h_indep : sSupIndep (B N hN) := hB' N hN\n    have h_not_bot : ⊥ ∉ B N hN := hB'' N hN\n    have h_mem : x ∈ B N hN := hy\n    have h_le_N : x ≤ N := le_sSup h_mem\n    have h_ge_N : N ≤ x := by\n      rw [← h_sSup]\n      apply sSup_le\n      intro y hy\n      cases' eq_or_ne y x with h_eq h_ne\n      · rw [h_eq]\n        exact le_rfl\n      · have h_disj : Disjoint x y := h_indep.2 x y h_mem hy h_ne\n        have h_inf : x ⊓ y = ⊥ := disjoint_iff.mp h_disj\n        have h_le_inf : y ≤ x ⊓ y := le_inf (le_sSup hy) h_le_N\n        rw [h_inf] at h_le_inf\n        have h_y_bot : y = ⊥ := le_bot_iff.mp h_le_inf\n        contradiction\n    exact le_antisymm h_ge_N h_le_N\n  contradiction",
