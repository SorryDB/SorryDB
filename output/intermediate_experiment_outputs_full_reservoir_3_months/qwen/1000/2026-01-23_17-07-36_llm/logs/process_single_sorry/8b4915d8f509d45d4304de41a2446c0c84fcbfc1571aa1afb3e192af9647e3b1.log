      "by\n  have h_le : refinement B hB hB' hB'' ≤ D := refinement_le B hB hB' hB''\n  refine ⟨h_le, ?_⟩\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_eq_carrier : (refinement B hB hB' hB'').carrier = D.carrier := by\n    rw [h_eq]\n  have h_mem : N ∈ D := hN\n  have h_sub : B N hN ⊆ (refinement B hB hB' hB'').carrier := by\n    intro x hx\n    simp only [Set.mem_iUnion, exists_prop, and_true]\n    exact ⟨N, hN, hx⟩\n  have h_sSup_B : sSup (B N hN) = N := hB N hN\n  have h_sSup_ref : sSup (refinement B hB hB' hB'').carrier = ⊤ := (refinement B hB hB' hB'').sSup_eq_top'\n  have h_sSup_D : sSup D.carrier = ⊤ := D.sSup_eq_top'\n  have h_unique : B N hN = {N} := by\n    apply Set.ext\n    intro x\n    constructor\n    · intro hx\n      have h_x_in_ref : x ∈ (refinement B hB hB' hB'').carrier := h_sub hx\n      rw [← h_eq_carrier] at h_x_in_ref\n      have h_x_in_D : x ∈ D := h_x_in_ref\n      have h_disj : Disjoint x N ∨ x = N := by\n        by_contra h_contra\n        push_neg at h_contra\n        have h_disj' : Disjoint x N := by\n          apply D.sSupIndep'.disjoint_of_ne\n          · exact h_x_in_D\n          · exact h_mem\n          · intro h_eq_x_N\n            exact h_contra ⟨h_eq_x_N⟩\n        have h_le_bot : x ⊓ N = ⊥ := disjoint_iff_inf_le.mp h_disj'\n        have h_x_le_N : x ≤ N := by\n          rw [← h_sSup_B]\n          apply le_sSup hx\n        have h_x_eq_bot : x = ⊥ := by\n          rw [← inf_eq_left.mpr h_x_le_N]\n          exact h_le_bot\n        exact hB'' N hN h_x_eq_bot\n      cases h_disj with\n      | inl h_disj =>\n        have h_x_eq_bot : x = ⊥ := by\n          rw [← inf_eq_left.mpr (le_sSup hx)]\n          exact disjoint_iff_inf_le.mp h_disj\n        exact hB'' N hN h_x_eq_bot\n      | inr h_eq_x_N => exact h_eq_x_N\n    · intro h_eq_x_N\n      rw [h_eq_x_N]\n      have h_N_in_B : N ∈ B N hN := by\n        rw [← h_sSup_B]\n        exact le_sSup_self\n      exact h_N_in_B\n  exact h_ne h_unique",
      "by\n  have h_le : refinement B hB hB' hB'' ≤ D := refinement_le B hB hB' hB''\n  refine ⟨h_le, fun h_eq => ?_⟩\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_eq_carrier : (refinement B hB hB' hB'').carrier = D.carrier := by\n    rw [SetLike.ext'_iff] at h_eq\n    exact h_eq\n  simp only [refinement, SetLike.coe_setOf, Set.mem_iUnion, Set.mem_setOf_eq] at h_eq_carrier\n  have h_mem : N ∈ D.carrier := hN\n  have h_sub : B N hN ⊆ D.carrier := by\n    intro x hx\n    rw [h_eq_carrier]\n    exact ⟨N, h_mem, x, hx⟩\n  have h_sSup_B : sSup (B N hN) = N := hB N hN\n  have h_sSup_D : sSup D.carrier = ⊤ := D.sSup_eq_top'\n  have h_indep : sSupIndep (B N hN) := hB' N hN\n  have h_not_bot : ⊥ ∉ B N hN := hB'' N hN\n  have h_singleton : B N hN = {N} := by\n    apply Set.eq_singleton_iff_unique_mem.mpr\n    refine ⟨⟨N, ?_⟩, fun x hx => ?_⟩\n    · rw [h_sSup_B]\n      exact le_rfl\n    · have h_x_le_N : x ≤ N := le_sSup_of_le h_mem (by simp [h_eq_carrier, h_sub hx])\n      have h_N_le_x : N ≤ x := by\n        rw [h_sSup_B]\n        apply le_sSup hx\n      exact le_antisymm h_N_le_x h_x_le_N\n  contradiction",
      "by\n  have h_le : refinement B hB hB' hB'' ≤ D := refinement_le B hB hB' hB''\n  refine lt_of_le_of_ne h_le ?_\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    rw [← h_eq]\n    simp [refinement, Set.mem_iUnion]\n    intro x hx\n    rcases hx with ⟨⟨M', hM'⟩, hM'_eq⟩\n    subst hM'_eq\n    exact hM'\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_sSup_eq' : sSup (B N hN) = sSup {N} := by\n    rw [← h_eq, refinement] at *\n    simp [Set.iUnion, Set.mem_iUnion]\n    have : B N hN = {N} := by\n      apply Set.ext\n      intro x\n      constructor\n      · intro hx\n        have : x ∈ D := h_sub hx\n        have : x = N := by\n          have : x ≤ N := le_sSup_of_le hN (le_rfl : x ≤ x)\n          have : N ≤ x := by\n            rw [← h_sSup_eq]\n            apply le_sSup hx\n          exact le_antisymm ‹_› ‹_›\n        simp [this]\n      · intro hx\n        simp at hx\n        rw [hx]\n        have : N ∈ B N hN := by\n          rw [← h_sSup_eq]\n          apply le_sSup_iff.mpr\n          intro y hy\n          aesop\n        aesop\n    simp [this]\n  simp at h_sSup_eq'\n  contradiction",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_mem : N ∈ D := hN\n  have h_ref : (refinement B hB hB' hB'').carrier = D.carrier := by\n    rw [Set.ext_iff]\n    intro x\n    simp only [Set.mem_iUnion, exists_prop]\n    constructor\n    · rintro ⟨M, hM, y, hy, rfl⟩\n      have : M = sSup (B M hM) := hB M hM\n      have : x ∈ B M hM := hy\n      have : x ≤ sSup (B M hM) := le_sSup hy\n      rw [← this] at this\n      exact le_antisymm (le_sSup ⟨M, hM⟩) (sSup_le fun m hm => by\n        obtain ⟨M', hM', y', hy', rfl⟩ := hm\n        have : M' = sSup (B M' hM') := hB M' hM'\n        have : y' ≤ sSup (B M' hM') := le_sSup hy'\n        rw [← this] at this\n        exact le_sSup ⟨M', hM'⟩)\n    · intro hxD\n      have : x = sSup (B x hxD) := hB x hxD\n      have : B x hxD ≠ {x} := by\n        intro hBx\n        apply h_ne\n        rw [hBx]\n      have : ∃ y ∈ B x hxD, y ≠ x := by\n        contrapose! this\n        ext y\n        simp_all\n      rcases this with ⟨y, hy, hy_ne⟩\n      exact ⟨x, hxD, y, hy, rfl⟩\n  simp_all",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_eq : B N hN = {N} := by\n    rw [← h]\n    simp [refinement, Set.ext_iff]\n    intro x\n    simp only [Set.mem_iUnion, exists_prop, and_imp, exists_and_right]\n    constructor\n    · rintro ⟨M', hM', rfl⟩\n      exact hM'\n    · intro hM'\n      use N, hN, hM'\n  contradiction",
      "by\n  have h_le : refinement B hB hB' hB'' ≤ D := refinement_le B hB hB' hB''\n  refine lt_of_le_of_ne h_le ?_\n  rintro rfl\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_eq : B N hN = {N} := by\n    rw [← carrier_inj]\n    simp [refinement]\n    ext x\n    simp only [Set.mem_iUnion, exists_prop, and_imp, exists_and_right]\n    constructor\n    · rintro ⟨M, hM, y, hy, rfl⟩\n      have : M = N := by\n        have : M ∈ D := hM\n        have : y ∈ B M hM := hy\n        have : M = sSup (B M hM) := hB M hM\n        have : N = sSup (B N hN) := hB N hN\n        sorry\n      subst this\n      exact hy\n    · intro hx\n      use N, hN, N, hx\n      rfl\n  contradiction",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_eq_carrier : (refinement B hB hB' hB'').carrier = D.carrier := by\n    rw [h_eq]\n  simp only [SetLike.coe_injective, Subtype.ext_iff] at h_eq_carrier\n  have h_subset : B N hN ⊆ D.carrier := by\n    intro x hx\n    rw [← h_eq_carrier]\n    exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hx⟩⟩\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_sSup_eq' : sSup (B N hN) = sSup {N} := by\n    rw [← h_sSup_eq, Set.sSup_singleton]\n  have h_B_eq : B N hN = {N} := by\n    apply sSupIndep.eq_of_sSup_eq_singleton hB' _ h_sSup_eq'\n    exact fun h_bot => hB'' N hN h_bot\n  exact h_ne h_B_eq",
      "by\n  refine' lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq => _\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    intro x hx\n    rw [← hB N hN] at hx\n    exact le_sSup_iff.mp hx |>.imp (fun _ => id)\n  have h_eq_B : B N hN = {N} := by\n    rw [← h_eq]\n    simp [refinement, Set.mem_iUnion, Set.mem_iUnion2]\n    aesop\n  exact h_ne h_eq_B",
      "by\n  have h_le : refinement B hB hB' hB'' ≤ D := refinement_le B hB hB' hB''\n  refine ⟨h_le, ?_⟩\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_sub : B N hN ⊆ D.carrier := by\n    intro x hx\n    rw [← hB N hN] at hx\n    exact le_sSup_iff.mp hx |>.imp (fun _ => id) |>.choose_spec\n  have h_inj : Function.Injective (fun p : refinement B hB hB' hB'' ↦ p.val) := by\n    intro p q hpq\n    apply Subtype.eq\n    exact hpq\n  have h_card : Set.InjOn (fun p : refinement B hB hB' hB'' ↦ p.val) (Set.univ : Set (refinement B hB hB' hB'')) := by\n    intro x y hx hy hxy\n    exact h_inj hxy\n  have h_eq_carrier : (refinement B hB hB' hB'').carrier = D.carrier := by\n    rw [h_eq]\n  have h_contra : B N hN = {N} := by\n    apply Set.ext\n    intro x\n    constructor\n    · intro hx\n      have h_mem : x ∈ (refinement B hB hB' hB'').carrier := by\n        simp [refinement, Set.mem_iUnion]\n        exact ⟨N, hN, hx⟩\n      rw [h_eq_carrier] at h_mem\n      have h_mem_D : x ∈ D.carrier := h_mem\n      have h_disj : ∀ y ∈ D.carrier, y ≠ x → Disjoint x y := by\n        intro y hy h_ne_xy\n        exact (D.sSupIndep' ⟨x, h_mem_D⟩ ⟨y, hy⟩ h_ne_xy).symm\n      have h_x_le_N : x ≤ N := by\n        rw [← hB N hN]\n        apply le_sSup\n        exact hx\n      have h_N_le_x : N ≤ x := by\n        have h_N_in_ref : N ∈ (refinement B hB hB' hB'').carrier := by\n          rw [h_eq_carrier]\n          exact hN\n        rcases h_N_in_ref with ⟨M', hM', hNM'⟩\n        have h_M'_eq_N : M' = N := by\n          have h_M'_in_D : M' ∈ D.carrier := hM'\n          have h_disj_M' : Disjoint M' N := by\n            apply D.sSupIndep'\n            · exact hM'\n            · exact hN\n            · intro h_eq_MN\n              subst h_eq_MN\n              exact h_ne rfl\n          have h_N_le_M' : N ≤ M' := by\n            rw [← hB M' hM']\n            apply le_sSup\n            exact hNM'\n          have h_M'_le_N : M' ≤ N := by\n            apply le_sSup\n            exact hN\n          exact le_antisymm h_N_le_M' h_M'_le_N\n        subst h_M'_eq_N\n        exact hNM'\n      exact le_antisymm h_N_le_x h_x_le_N\n    · intro hx\n      rw [Set.mem_singleton_iff] at hx\n      rw [hx]\n      have h_N_in_B : N ∈ B N hN := by\n        rw [← hB N hN]\n        apply le_sSup_iff.mpr\n        intro y hy\n        exact le_rfl\n      exact h_N_in_B\n  exact h_ne h_contra",
      "by\n  have h_le : refinement B hB hB' hB'' ≤ D := refinement_le B hB hB' hB''\n  refine ⟨h_le, fun h_eq => ?_⟩\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_eq_carrier : (refinement B hB hB' hB'').carrier = D.carrier := by\n    rw [SetLike.ext'_iff] at h_eq\n    exact h_eq\n  simp only [refinement, SetLike.coe_mk] at h_eq_carrier\n  have h_mem : N ∈ D := hN\n  have h_subset : B N hN ⊆ D.carrier := by\n    rw [← h_eq_carrier]\n    intro x hx\n    simp only [Set.mem_iUnion, exists_prop, and_imp, Set.mem_setOf_eq]\n    use N, hN\n    exact hx\n  have h_sSup_eq : sSup (B N hN) = N := hB N hN\n  have h_sSup_eq' : sSup (B N hN) = sSup {N} := by\n    rw [h_sSup_eq, sSup_singleton]\n  have h_eq_singleton : B N hN = {N} := by\n    apply sSupIndep.eq_of_sSup_eq_sSup_singleton\n    · exact hB' N hN\n    · exact h_sSup_eq'\n  contradiction",
      "by\n  have h_le : refinement B hB hB' hB'' ≤ D := refinement_le B hB hB' hB''\n  refine ⟨h_le, ?_⟩\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_ref : refinement B hB hB' hB'' = D := h_eq\n  have h_carrier : (refinement B hB hB' hB'').carrier = D.carrier := by\n    rw [h_ref]\n  simp only [SetLike.coe_injective', Subtype.ext_iff] at h_carrier\n  have h_mem : N ∈ (refinement B hB hB' hB'').carrier := by\n    rw [h_carrier]\n    exact hN\n  simp only [Set.mem_iUnion, exists_prop] at h_mem\n  rcases h_mem with ⟨N', hN', h_mem'⟩\n  have h_eq_N : N' = N := by\n    have h_sSup : N' = sSup (B N' hN') := hB N' hN'\n    have h_sSup' : N = sSup (B N hN) := hB N hN\n    have h_subset : B N' hN' ⊆ D.carrier := by\n      intro x hx\n      simp only [Set.mem_iUnion, exists_prop]\n      use N', hN', hx\n      rw [← h_carrier]\n      rfl\n    have h_disj : sSupIndep (B N' hN') := hB' N' hN'\n    have h_not_bot : ⊥ ∉ B N' hN' := hB'' N' hN'\n    have h_unique : B N' hN' = {N} := by\n      apply Set.eq_singleton_of_subsingleton_of_mem\n      · intro x hx y hy\n        have h_x_le : x ≤ N := by\n          rw [← h_sSup']\n          apply le_sSup_of_le hy\n          exact le_rfl\n        have h_y_le : y ≤ N := by\n          rw [← h_sSup']\n          apply le_sSup_of_le hy\n          exact le_rfl\n        have h_disj_xy : Disjoint x y ∨ x = y := by\n          apply sSupIndep.eq_or_disjoint h_disj hx hy\n          intro h_xy\n          aesop\n        cases h_disj_xy with\n        | inl h_disj_xy =>\n          have h_inf : x ⊓ y = ⊥ := disjoint_iff.mp h_disj_xy\n          have h_x_eq_bot : x = ⊥ := by\n            rw [← h_inf]\n            apply le_inf_iff.mpr\n            constructor\n            · exact le_rfl\n            · exact le_trans h_x_le (le_trans h_y_le (le_sSup_of_le hy le_rfl))\n          exact (h_not_bot hx) h_x_eq_bot.symm\n        | inr h_eq_xy => exact h_eq_xy\n      · use N\n        rw [← h_sSup']\n        apply le_sSup\n        exact h_mem'\n    rw [h_unique] at h_ne\n    simp at h_ne\n  rw [h_eq_N] at h_mem'\n  have h_B_eq : B N hN = {N} := by\n    apply Set.eq_singleton_of_subsingleton_of_mem\n    · intro x hx y hy\n      have h_x_le : x ≤ N := by\n        rw [← hB N hN]\n        apply le_sSup_of_le hx\n        exact le_rfl\n      have h_y_le : y ≤ N := by\n        rw [← hB N hN]\n        apply le_sSup_of_le hy\n        exact le_rfl\n      have h_disj_xy : Disjoint x y ∨ x = y := by\n        apply sSupIndep.eq_or_disjoint (hB' N hN) hx hy\n        intro h_xy\n        aesop\n      cases h_disj_xy with\n      | inl h_disj_xy =>\n        have h_inf : x ⊓ y = ⊥ := disjoint_iff.mp h_disj_xy\n        have h_x_eq_bot : x = ⊥ := by\n          rw [← h_inf]\n          apply le_inf_iff.mpr\n          constructor\n          · exact le_rfl\n          · exact le_trans h_x_le (le_trans h_y_le (le_sSup_of_le hy le_rfl))\n        exact (hB'' N hN hx) h_x_eq_bot.symm\n      | inr h_eq_xy => exact h_eq_xy\n    · exact h_mem'\n  exact h_ne h_B_eq",
