\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.ii :
    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  have h : ∀ t : ℚ, t ≠ 0 → t ≠ 1 → 
    let x := t
    let y := 1 / (1 - t)
    let z := (t - 1) / t
    (x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) ∧ x * y * z = 1 ∧ 
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1 := by
    intro t ht0 ht1
    have h1 : t ≠ 1 := ht1
    have h2 : 1 - t ≠ 0 := by contrapose! h1; linarith
    have h3 : t ≠ 0 := ht0
    have h4 : (t - 1) ≠ 0 := by contrapose! h1; linarith
    have h5 : (1 - t) ≠ 0 := h2
    have h6 : (t - 1) / t ≠ 1 := by
      intro h
      field_simp at h
      linarith
    have h7 : 1 / (1 - t) ≠ 1 := by
      intro h
      field_simp at h
      linarith
    refine' ⟨⟨h1, h7, h6⟩, _, _⟩
    · field_simp [h2, h3, h4]
      ring
    · field_simp [h2, h3, h4]
      ring
  have h_inj : Function.Injective (fun t : ℚ => (t, 1 / (1 - t), (t - 1) / t)) := by
    intro t1 t2 h
    simp only [Prod.mk.inj_iff] at h
    exact h.1
  have h_inf : Set.Infinite (Set.range fun t : { t : ℚ // t ≠ 0 ∧ t ≠ 1 } => 
    (t.val, 1 / (1 - t.val), (t.val - 1) / t.val)) := by
    apply Set.infinite_range_of_injective
    intro x y hxy
    apply Subtype.ext
    apply h_inj
    simpa using hxy
  have h_subset : Set.range (fun t : { t : ℚ // t ≠ 0 ∧ t ≠ 1 } => 
    (t.val, 1 / (1 - t.val), (t.val - 1) / t.val)) ⊆ 
    { (x, y, z) | 
      (x : ℚ) (y : ℚ) (z : ℚ) 
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) 
      (h₁ : x * y * z = 1) 
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
    rintro _ ⟨t, ht⟩
    apply h t ht.1 ht.2
  exact Set.Infinite.mono h_subset h_inf
