    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  have h : ∀ t : ℚ, t ≠ 0 → t ≠ 1 → 
    let x := t
    let y := 1 / t
    let z := 1
    x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1 ∧ x * y * z = 1 ∧ 
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1 := by
    intro t ht0 ht1
    simp_all
    <;> field_simp [ht0, ht1, sub_eq_zero, Ne.symm ht1]
    <;> ring
  apply Set.infinite_of_injective_forall_mem (fun t => (t, 1/t, 1))
  · intro t ht
    exact h t ht (by aesop)
  · intro t₁ t₂ h
    simp_all
