              have : 1 ≤ #A := by
                cases' hA₀ with a ha
                exact Nat.succ_le_iff.mpr (Nat.pos_of_ne_zero fun h => by simp_all)
              have : #A / 2 ≤ #(A ∩ S <• a) := by
                have : 1 ≤ #(A ∩ S <• a) := by
                  apply Finset.card_pos.mpr
                  use a
                  simp [ha, hS₁]
                omega
              exact this
        exact this
      _ ≤ ↑(A ∩ (S ^ 2) <• a).card := by gcongr
```
