-- definition 1.3.13
noncomputable def Preorder (α : Type) := Preorder α

-- definition 1.3.14
noncomputable def Top (α : Type) := Top α

-- definition 1.3.15
noncomputable def PointedSet (α : Type) := { val : α, point : α } -- placeholder, actual definition depends on context

-- theorem 1.3.1
theorem SetProductFunctor : @Functor Set Set (Product Set Set) (Set.prod) :=
  {
    F := fun X => X.1 × X.2
    homF := fun {X Y} f => Prod.mk f.1 f.2
    map_id X := by
      simp [Set.prod]
      funext x
      simp only [Set.mem_prod_iff]
      simp [Set.mem_id]
    map_comp f g := by
      simp [Set.prod]
      funext x
      simp only [Set.mem_prod_iff]
      simp [Function.comp_apply]
      exact Eq.symm (Set.prod_eq_prod f g x)
  }

-- theorem 1.3.2
theorem SetDisjointUnionFunctor : @Functor Set Set (DisjointUnion Set Set) (Set.inl, Set.inr) :=
  {
    F := fun X => if X.1 then inl X.2 else inr X.2
    homF := fun {X Y} f => if f.1 then inl f.2 else inr f.2
    map_id X := by
      simp [Set.disjUnion]
      funext x
      simp only [Set.mem_disjUnion_iff]
      simp [Set.mem_id]
    map_comp f g := by
      simp [Set.disjUnion]
      funext x
      simp only [Set.mem_disjUnion_iff]
      simp [Function.comp_apply]
      exact Eq.symm (Set.disjUnion_eq_disjUnion f g x)
  }

-- theorem 1.3.3
theorem SetFunctionSpaceFunctor : @Functor Set Set (FunctionSpace Set Set) (Set.eval) :=
  {
    F := fun X => { f | ∀ x, f x ∈ X }
    homF := fun {X Y} f => fun x => f x
    map_id X := by
      simp [Set.prod]
      funext x
      simp only [Set.mem_prod_iff]
      simp [Set.mem_id]
    map_comp f g := by
      simp [Set.prod]
      funext x
      simp only [Set.mem_prod_iff]
      simp [Function.comp_apply]
      exact Eq.symm (Set.eval_eq_eval f g x)
  }

