  { F₀ : C → D
    F₁ : ∀ {c d : C}, C.Hom c d → D.Hom (D.objects (F₀ c)) (D.objects (F₀ d))
    -- laws
    F₁_id : ∀ c, F₁ (id c) = id (F₀ c)
    F₁_comp : ∀ {c d e : C}, F₁ (comp c d e) = F₁ d e (F₁ c d)
