import Mathlib

namespace Category

noncomputable structure Hom : Type → Type → Type* :=
  λ (α β : Type) => Type (max (Type.underlyingSort α) (Type.underlyingSort β))

noncomputable structure Category (α : Type) : Type (max (Type.underlyingSort α) 1) :=
  { Hom := Hom α α
    id : Hom α α
    comp : ∀ (X Y Z : α), Hom Y Z → Hom X Y → Hom X Z
    id_comp : ∀ (X : α), comp X X Y id (id X) = id (comp X X Y)
    comp_id : ∀ (X Y : α), comp X Y X (comp X Y X) id = id (comp X Y X)
    assoc : ∀ (X Y Z W : α), comp X Y Z (comp Y Z W) = comp X Y W (comp Y Z X) }

noncomputable structure ContravariantFunctor (α β : Type) [C : Category α] [D : Category β] : Type (max (Type.underlyingSort α) (Type.underlyingSort β)) :=
  { F : α → β
    homF : ∀ (X Y : α) (_ : X = X), ∀ (f : C.Hom X Y), D.Hom (F Y) (F X)
    map_id : ∀ (X : α), homF X X rfl (id X) = id (F X)
    map_comp : ∀ (X Y Z : α), ∀ (f : C.Hom X Y) (g : C.Hom Y Z), homF X Z rfl (f ≫ g) = homF Y Z rfl g ≫ homF X Y rfl f }

-- example 1.3.1
def SetContraFunctor : ContravariantFunctor Type Type where
  F X := Set X
  homF f := Set.preimage f
  map_id X := by
    simp [id]
    funext x
    simp only [Set.preimage_id']
  map_comp f g := by
    simp [comp]
    funext x
    simp only [Function.comp_apply]
    exact Eq.symm (Set.image_id' x)

