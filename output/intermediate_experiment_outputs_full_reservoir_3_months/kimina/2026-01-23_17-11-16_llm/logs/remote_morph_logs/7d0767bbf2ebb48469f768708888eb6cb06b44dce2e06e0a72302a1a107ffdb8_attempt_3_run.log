import Mathlib

-- definition 1.3.1
noncomputable def Product (α β : Type) := α × β

-- definition 1.3.2
noncomputable def DisjointUnion (α β : Type) := α + β

-- definition 1.3.3
noncomputable def FunctionSpace (α β : Type) := α → β

-- definition 1.3.4
noncomputable def PowerSet (α : Type) := Set α

-- definition 1.3.5
noncomputable def Hom (α : Type) := fun (X Y : α) => α →* β

-- definition 1.3.6
noncomputable def Opposite (α : Type) := α

-- definition 1.3.7
noncomputable def SetPreimage (f : α → β) := Set.preimage f

-- definition 1.3.8
noncomputable def SetIntersection (s t : Set α) := s ∩ t

-- definition 1.3.9
noncomputable def SetDifference (s t : Set α) := s \ t

-- definition 1.3.10
noncomputable def Subtype (α : Type) := { val : α, property : Prop } -- placeholder, actual definition depends on context

-- definition 1.3.11
noncomputable def Quotient (α : Type) := α / ∼ -- placeholder, actual definition depends on context

-- definition 1.3.12
noncomputable def Finset (α : Type) := Finset α

-- definition 1.3.13
noncomputable def Preorder (α : Type) := Preorder α

-- definition 1.3.14
noncomputable def Top (α : Type) := Top α

-- definition 1.3.15
noncomputable def PointedSet (α : Type) := { val : α, point : α } -- placeholder, actual definition depends on context

-- theorem 1.3.1
theorem SetProductFunctor : @Functor Set Set (Product Set Set) (Set.prod) :=
  {
    F := fun X => X.1 × X.2
    homF := fun {X Y} f => Prod.mk f.1 f.2
    map_id X := by
      simp [Set.prod]
      funext x
      simp only [Set.mem_prod_iff]
      simp [Set.mem_id]
    map_comp f g := by
      simp [Set.prod]
      funext x
      simp only [Set.mem_prod_iff]
      simp [Function.comp_apply]
      exact Eq.symm (Set.prod_eq_prod f g x)
  }

-- theorem 1.3.2
theorem SetDisjointUnionFunctor : @Functor Set Set (DisjointUnion Set Set) (Set.inl, Set.inr) :=
  {
