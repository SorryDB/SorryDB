      simp only [Set.mem_prod_iff]
      simp [Set.mem_id]
    map_comp f g := by
      simp [Set.prod]
      funext x
      simp only [Set.mem_prod_iff]
      simp [Function.comp_apply]
      exact Eq.symm (Set.difference_eq_difference f g x)
  }

