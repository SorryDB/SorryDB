import Mathlib

open Function

namespace category_theory

-- definition 1.3.1
noncomputable def Category {α : Type*} (C : Type (α → α → Prop)) :=
  Structure.mk C (α → α → Prop) { -- Let the homset be the set of functions from α to α
    id : ∀ x : α, C x x, -- Identity function is a homomorphism
    comp : ∀ x y z : α, C y z → C x y → C x z, -- Composition of homomorphisms
    id_comp : ∀ x y : α, id x ∘ y = id (x ∘ y), -- Identity composition law
    comp_id : ∀ x y : α, x ∘ id y = id (x ∘ y), -- Composition identity law
    associativity : ∀ x y z w : α, comp x y z (comp y z w) = comp x (comp y z) w -- Associativity law
  }

-- definition 1.3.2
noncomputable def Functor {α β : Type*} [C : Category α] [D : Category β] (F : Type (α → β → Prop)) :=
  Structure.mk F (α → β → Prop) { -- Let the map be a function from α to β
    -- map on objects
    F : α → β, -- Define F on objects
    -- map on homs
    homF : ∀ {X Y : α}, C.Hom X Y → D.Hom (F Y) (F X), -- Define F on homs
    -- properties / laws
    map_id : ∀ X : α, homF (id X) = id (F X), -- F preserves identity
    map_comp : ∀ {X Y Z : α}, (X → Y → Z : α → α → α) → (Y → Z : α → α → α) → (X → Y : α → α → α) → homF (f ≫ g) = homF g ≫ homF f -- F preserves composition
  }

-- example 1.3.3
def SetContraFunctor : ContraFunctor Type Type where
  F X := Set X
  homF f := Set.preimage f
  map_id X := by
    simp [Set.preimage_id']
  map_comp f g := by
    simp [Set.image_image]

-- definition 1.3.5
class ContraFunctor (α β : Type*) [C : Category α] [D : Category β] where
  -- data
  -- map on objects
  F : α → β
  -- map on morphisms
  homF {X Y : α} : C.Hom X Y → D.Hom (F Y) (F X)
  -- properties / laws
  -- need to qualify id to avoid clash with id in root namespace.
  map_id (X : α) : homF (id X) = Category.id (F X)
  map_comp {X Y Z : α} (f : C.Hom X Y) (g : C.Hom Y Z) :
    homF (f ≫ g) = homF g ≫ homF f

-- example 1.3.7.i
def PowerSetContraFunctor : ContraFunctor Type Type where
  F X := Set X
  homF f := Set.preimage f
  map_id X := by
    simp [Category.id]
    funext x
    simp only [Set.preimage_id']
  map_comp f g := by
    simp [Category.comp]
    funext x
    simp only [Function.comp_apply]
    rfl

