-- Define the SystemState structure
structure SystemState where
  requests : RequestArray
  removed : List Request
  satisfied : List (RequestId × RequestId)
  orderConstraints : OrderConstraints
  threadTypes : ThreadTypeMap
  removedCoherent : List (ThreadId × Arch)

-- Define the OrderConstraints structure
structure OrderConstraints where
  data : Finset (RequestId × RequestId)
  isTotal : Bool

-- Define the Request structure
structure Request where
  address? : Option Address
  value? : Option Value
  basic_type : BasicRequestType
  id : RequestId
  occurrence : Nat
  isRead : Bool
  isWrite : Bool
  isAtomic : Bool
  isTransactional : Bool
  isSatisfied : Bool
  isMem : Bool
  isFence : Bool
  isPropagated : List ThreadId
  isTentative : Bool
  pairedRequest? : Option (RequestId)
  conditionalValue? : Option (ConditionalValue)
  conditionalSucceeded : Bool
  conditionalFailed : Bool
  conditionalUndecided : Bool
  conditionalTentativeOrSuccessful : Bool

