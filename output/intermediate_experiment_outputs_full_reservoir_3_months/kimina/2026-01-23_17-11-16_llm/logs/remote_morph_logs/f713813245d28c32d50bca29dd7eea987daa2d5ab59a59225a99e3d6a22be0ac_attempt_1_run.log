  requests : RequestArray,
  scopes : List (ThreadId × ThreadId),
  orderConstraints : List (ThreadId × ThreadId × List (RequestId × RequestId)),
  threadTypes : List (ThreadId × OperationType),
  satisfied : List (RequestId × RequestId),
  removed : List (RequestId),
  removedCoherent : List (RequestId × RequestId)
}

noncomputable def Request := {
  id : RequestId,
  thread : ThreadId,
  predecessor_at : List (ThreadId),
  pairedRequest? : Option (RequestId),
  basic_type : BasicRequest,
  id := sorry,
  occurrence : Nat,
  isRead : Bool,
  isWrite : Bool,
  isAtomic : Bool,
  isTransactional : Bool,
  isPropagated : Bool,
  isSatisfied : Bool,
  isTentative : Bool,
  isCond : Bool,
  isRmw : Bool,
  isFence : Bool,
  isCancel : Bool,
  isCondSucc : Bool,
  isCondFail : Bool,
  isCondUndec : Bool,
  isCondTent : Bool
}

-- Basic types of requests: read, write, conditional, etc.
noncomputable def BasicRequest := {
  read : Bool,
  write : Bool,
  conditional : Bool,
  fence : Bool,
  cancel : Bool,
  rw : Bool,
  r : Bool,
  w : Bool,
  c : Bool,
  f : Bool
}

noncomputable def Condition := {
  type : ConditionType,
  value : Nat,
  isTentative : Bool,
  isSatisfied : Bool,
  isFailed : Bool,
  isUndecidable : Bool
}

noncomputable def ConditionType := {
  constant : Nat,
  variable : Nat,
  expression : Nat
}

