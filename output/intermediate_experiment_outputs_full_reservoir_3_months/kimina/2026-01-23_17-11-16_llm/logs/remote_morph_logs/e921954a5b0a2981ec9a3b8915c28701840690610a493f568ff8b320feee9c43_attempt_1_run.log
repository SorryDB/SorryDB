/- A `HasUniformSelect X α` instance means that `X` is a data structure from which elements of type `α` can be selected uniformly at random. This is formalized by providing a probability distribution `↑X` (which is `OptionT (ProbComp α)`) and proofs about its properties. -/
class HasUniformSelect (X : Type) (α : Type) where
  uniformSelect : X → OptionT (ProbComp α)
  -- The probability distribution associated with selecting an element from x
  hasSelect : ∀ (x : X), (↑(x : X) : OptionT (ProbComp α)).isSome := by
    intro x
    simp only [OptionT.isSome_def, uniformSelect]
    use (x : X)

  -- The probability distribution associated with selecting an element from x is a probability measure
  isProbabilityMeasure : ∀ (x : X), (↑(x : X) : OptionT (ProbComp α)).isProbabilityMeasure := by
    intro x
    simp only [OptionT.isProbabilityMeasure_def, uniformSelect]
    use (x : X)

  -- The support of the distribution associated with x is the singleton set containing x
  support : ∀ (x : X), support (↑(x : X) : OptionT (ProbComp α)) = {x} := by
    intro x
    simp only [OptionT.support_def, uniformSelect]
    ext y
    simp only [Set.mem_singleton_iff]
    constructor
    · -- If y is in the support, then y = x
      intro hy
      rcases hy with ⟨y', hy'⟩
      simp only [OptionT.isSome_def, Option.isSome_def, exists_eq_left, true_and] at hy'
      tauto
    · -- If y = x, then y is in the support
      intro hy
      rw [hy]
      use (x : X)
      simp only [OptionT.isSome_def, Option.isSome_def, true_and, exists_eq_left, true_and]

  -- The finite support of the distribution associated with x is the singleton finset containing x
  finSupport : ∀ (x : X), finSupport (↑(x : X) : OptionT (ProbComp α)) = ({x} : Finset X) := by
    intro x
    simp only [OptionT.finSupport_def, uniformSelect]
    ext y
    simp only [Finset.mem_singleton]
    constructor
    · -- If y is in the finite support, then y = x
      intro hy
      rcases hy with ⟨y', hy'⟩
      simp only [OptionT.isSome_def, Option.isSome_def, exists_eq_left, true_and] at hy'
      tauto
    · -- If y = x, then y is in the finite support
      intro hy
      rw [hy]
      use (x : X)
      simp only [OptionT.isSome_def, Option.isSome_def, true_and, exists_eq_left, true_and]

  -- The probability of selecting x from x is 1
  probSelect : ∀ (x : X), Pr[= x | ↑(x : X) : OptionT (ProbComp α)] = 1 := by
    intro x
    simp only [OptionT.prob_eq_def, uniformSelect]
    use (x : X)
    simp only [Option.isSome_def, exists_eq_left, true_and, iff_true]

