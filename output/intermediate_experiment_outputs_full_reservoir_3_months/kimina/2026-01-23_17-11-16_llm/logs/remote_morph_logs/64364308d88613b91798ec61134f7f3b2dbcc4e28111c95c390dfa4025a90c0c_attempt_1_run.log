    AEMeasurable (fun ω => (G ω)ᶜ) P := by
  have h1 : AEMeasurable (fun ω => (G ω)ᶜ) P := by
    have h2 : AEMeasurable (fun ω => (G ω).edgeSet) P := by
      have h3 : IsBinomialRandom G p P := hG
      exact h3.1
    have h7 : AEMeasurable (fun ω => (G ω).edgeSet) P := h2
    have h8 : AEMeasurable (fun ω => (G ω)ᶜ) P := by
      have h9 : AEMeasurable (fun ω => (G ω).edgeSet) P := h7
      have h10 : AEMeasurable (fun ω => (G ω)ᶜ) P := by
        have h11 : (fun ω => (G ω)ᶜ) = fun ω => (V ×ˢ V).diff (G ω).edgeSet := by
          funext ω
          ext e
          simp [SimpleGraph.mem_compl_iff_not_mem, SimpleGraph.mem_edgeSet]
        rw [h11]
        apply AEMeasurable.sdiff
        exact h9
      exact h10
    exact h8
  exact h1
