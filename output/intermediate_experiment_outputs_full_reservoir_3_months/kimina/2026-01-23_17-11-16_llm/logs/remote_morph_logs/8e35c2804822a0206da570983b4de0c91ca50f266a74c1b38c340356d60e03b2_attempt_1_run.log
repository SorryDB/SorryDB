/- Show that the cardinality of a maximum matching equals the matching number. -/
lemma IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  sorry

/- Define the symmetric difference of two matchings as a new graph. -/
def IsMatching.restrict₂ (hM : G.IsMatching M) (hM' : G.IsMatching M') : Graph α β :=
