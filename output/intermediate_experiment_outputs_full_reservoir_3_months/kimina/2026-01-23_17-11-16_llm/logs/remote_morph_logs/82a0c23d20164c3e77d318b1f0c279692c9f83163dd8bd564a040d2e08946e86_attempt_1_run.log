  rw [h_law]
  have h_prod : 𝓛[fun ω ↦ R n ω.1 | fun ω ↦ A n ω.1; 𝔓']
      =ᵐ[(𝔓').map (fun ω ↦ A n ω.1)] 𝓛[fun ω ↦ R n ω.1
