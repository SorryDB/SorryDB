  le_trans I₁ I₂ I₃ h12 h23 := by
    intro N h_mem
    rcases (h12 h_mem) with ⟨C, h_sub, h_eq⟩
    choose f hf hf' using h23
    let A := ⨆ (c : C), (f (h_sub c.prop))
    use A
    constructor
    · apply iSup_le_iff.mpr
