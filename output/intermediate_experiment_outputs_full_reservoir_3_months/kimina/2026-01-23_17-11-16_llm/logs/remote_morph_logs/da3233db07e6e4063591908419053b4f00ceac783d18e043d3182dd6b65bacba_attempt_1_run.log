      rw [вҶҗ hE2leProj]
      apply rexp_mul_smul_proj_lt_mul_sub_le_mul_sub'
      В· exact pinching_commutes (statePow ПҒ n) (вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n))
      В· positivity
      В· positivity
      В· exact Пғ''_posdef ПҒ Оө m Пғ n
    have hE3leq : (1 / вҶ‘n : в„қ) вҖў вҶ‘(E3 Оө2 n) * (вҶ‘(вҶ‘((в„° n) (statePow ПҒ n))).log - вҶ‘(вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)).log) вүӨ c' Оө2 n вҖў вҶ‘(E3 Оө2 n) := by
      rw [вҶҗ hE3comm]
