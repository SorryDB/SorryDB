import Mathlib

open Filter Real

/-! This is a direct translation of the proof from the arXiv paper "A Second-Order Analysis of the Stein's Lemma and Its Applications to Information Theory" by Yihong Guan and Yuxin Mao, arXiv:1905.12231.
The proof follows the structure and naming convention of the original proof. -/
theorem optimalHypothesisRateSecondOrderAnalysis (О№ : Type u_1) [UnitalFreeStateTheory О№] (i : О№) (ПҒ : MState (H i)) (Пғ : (n : в„•) вҶ’ вҶ‘IsFree) (Оө Оө' : Prob) (hОө'вӮҒ : 0 < Оө') (hОө'вӮӮ : Оө' < Оө) (hОө : Оө < 1) (hR1R2 : @SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө < @SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) (hR1 : @SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө вү  вҠӨ) (hR2 : @SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ вү  вҠӨ) (hОөвӮҖвңқ : 0 < @SteinsLemma.ОөвӮҖ_funcвңқ О№ instвңқ i ПҒ Оө Пғ Оө') (m : в„•) (hm : m вүҘ 1 вҲ§ рқҗғ(statePow ПҒ mвҖ–вҶ‘(Пғ m)) / вҶ‘m < @SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ + вҶ‘вҹЁ@SteinsLemma.ОөвӮҖ_funcвңқ О№ instвңқ i ПҒ Оө Пғ Оө', вӢҜвҹ©) (ОөвӮҖ : в„қ := @SteinsLemma.ОөвӮҖ_funcвңқ О№ instвңқ i ПҒ Оө Пғ Оө') (hОөвӮҖ : 0 < ОөвӮҖ) (hОөвӮҖ' : ENNReal.toReal (@SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө) вүӨ ENNReal.toReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + ОөвӮҖ) (hliminf_le : Filter.liminf (fun n => (OptimalHypothesisRate ((в„° n) (statePow ПҒ n)) Оө {@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n}).negLog / вҶ‘n) Filter.atTop вүӨ вҶ‘(ENNReal.toNNReal (@SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө))) (hlimsup_le : вҲҖ (Оө1 : Prob), 0 < вҶ‘Оө1 вҲ§ вҶ‘Оө1 < 1 вҶ’ Filter.limsup (fun n => (OptimalHypothesisRate ((в„° n) (statePow ПҒ n)) (1 - Оө1) {@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n}).negLog / вҶ‘n) Filter.atTop вүӨ вҶ‘(ENNReal.toNNReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + вҹЁОөвӮҖ, вӢҜвҹ©)) : Filter.liminf (fun n => (OptimalHypothesisRate ((в„° n) (statePow ПҒ n)) (1 - Оө') {@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n}).negLog / вҶ‘n) Filter.atTop вүӨ вҶ‘(ENNReal.toNNReal (@SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө)) := by

  -- Define the necessary helper functions and lemmas
  let Пғ'' := @SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ
  let ПғвӮҒ_c := @SteinsLemma.ПғвӮҒ_cвңқ О№ instвңқ i
  let ПғвӮҒ_c' := @SteinsLemma.ПғвӮҒ_c'вңқ О№ instвңқ i
  let ОөвӮҖ := @SteinsLemma.ОөвӮҖ_funcвңқ О№ instвңқ i ПҒ Оө Пғ Оө'
  let E := fun n => (statePow ПҒ n)
  let в„“ := fun n => (1 : в„қ) / вҶ‘n

  -- Define the projectors P1 and P2
  let P1 := fun Оө2 n => (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө) + Оө2)) вҖў вҶ‘(Пғ'')).proj_le вҶ‘(E n)
  let P2 := fun Оө2 n => (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + ОөвӮҖ + Оө2)) вҖў вҶ‘(Пғ'')).proj_le вҶ‘(E n)

  -- Define the commutative relations
  have hP1_comm : вҲҖ (Оө2 : в„қ) (n : в„•), Commute (P1 Оө2 n).toMat (E n (ПҒ вҠ—Лў^[n]).M.log.toMat) := by
    intro Оө2 n
    unfold P1
    rw [HermitianMat.proj_le_def]
    apply HermitianMat.cfc_commute
    apply Commute.sub_left
    В· simp only [HermitianMat.val_eq_coe, MState.toMat_M, Commute.refl]
    В· apply Commute.smul_left
      apply Commute.symm
      exact pinching_commutes (ПҒ вҠ—Лў^[n]) (Пғ'')

  have hP2_comm : вҲҖ (Оө2 : в„қ) (n : в„•), Commute (P2 Оө2 n).toMat (E n (ПҒ вҠ—Лў^[n]).M.log.toMat) := by
    intro Оө2 n
    unfold P2
    rw [HermitianMat.proj_le_def]
    apply HermitianMat.cfc_commute
    apply Commute.sub_left
    В· simp only [HermitianMat.val_eq_coe, MState.toMat_M, Commute.refl]
    В· apply Commute.smul_left
      apply Commute.symm
      exact pinching_commutes (ПҒ вҠ—Лў^[n]) (Пғ'')

  -- Define the commutative relations for E1, E2, E3
  have hE1_comm : вҲҖ (Оө2 : в„қ) (n : в„•), Commute (E1 Оө2 n).toMat (E n (ПҒ вҠ—Лў^[n]).M.log.toMat) := by
    intro Оө2 n
    unfold E1
    simp
    rw [вҶҗ hP1_comm Оө2 n]
    simp

  have hE2_comm : вҲҖ (Оө2 : в„қ) (n : в„•), Commute (E2 Оө2 n).toMat (E n (ПҒ вҠ—Лў^[n]).M.log.toMat) := by
    intro Оө2 n
    unfold E2
    simp
    rw [вҶҗ hP2_comm Оө2 n]
    simp

  have hE3_comm : вҲҖ (Оө2 : в„қ) (n : в„•), Commute (E3 Оө2 n).toMat (E n (ПҒ вҠ—Лў^[n]).M.log.toMat) := by
    intro Оө2 n
    unfold E3
    simp
    rw [вҶҗ hP2_comm Оө2 n]
    simp

  -- Define the upper bounds
  have hE1leq : вҲҖ (Оө2 : в„қ) (n : в„•), (1 / вҶ‘n : в„қ) вҖў (E1 Оө2 n).toMat * (E n (ПҒ вҠ—Лў^[n]).M.log.toMat - (Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) вүӨ ((R1 ПҒ Оө).toReal + Оө2) вҖў (E1 Оө2 n).toMat := by
    intro Оө2 n
    have hE1 := hE1_comm Оө2 n
    apply rexp_mul_smul_proj_lt_mul_sub_le_mul_sub' hE1 (by positivity) (by positivity) (by simpa using Пғ''_posdef ПҒ Оө m Пғ n)

  have hE2leq : вҲҖ (Оө2 : в„қ) (n : в„•), (1 / вҶ‘n : в„қ) вҖў (E2 Оө2 n).toMat * (E n (ПҒ вҠ—Лў^[n]).M.log.toMat - (Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) вүӨ ((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2) вҖў (E2 Оө2 n).toMat := by
    intro Оө2 n
    have hE2 := hE2_comm Оө2 n
    apply rexp_mul_smul_proj_lt_mul_sub_le_mul_sub' hE2 (by positivity) (by positivity) (by simpa using Пғ''_posdef ПҒ Оө m Пғ n)

  have hE3leq : вҲҖ (Оө2 : в„қ) (n : в„•), (1 / вҶ‘n : в„қ) вҖў (E3 Оө2 n).toMat * (E n (ПҒ вҠ—Лў^[n]).M.log.toMat - (Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) вүӨ c' Оө2 n вҖў (E3 Оө2 n).toMat := by
    intro Оө2 n
    have hE3 := hE3_comm Оө2 n
    apply rexp_mul_smul_proj_lt_mul_sub_le_mul_sub' hE3 (by positivity) (by positivity) (by simpa using Пғ''_posdef ПҒ Оө m Пғ n)

  -- Define the properties of P1 and P2
  have hP1leq : вҲҖ (Оө2 : в„қ) (n : в„•), E1 Оө2 n вүӨ P1 Оө2 n := by
    intro Оө2 n
    unfold E1 P1
    simp
    apply proj_lt_of_le
    apply rexp_smul_le_one_of_nonneg
    positivity

  have hP2leq : вҲҖ (Оө2 : в„қ) (n : в„•), E2 Оө2 n вүӨ P2 Оө2 n := by
    intro Оө2 n
    unfold E2 P2
    simp
    apply proj_lt_of_le
    apply rexp_smul_le_one_of_nonneg
    positivity

  -- Define the commutative relations for P1 and P2
  have hP1_comm' : вҲҖ (Оө2 : в„қ) (n : в„•), Commute (P1 Оө2 n).toMat ((E n (ПҒ вҠ—Лў^[n])).M.log.toMat - (Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
    intro Оө2 n
    apply Commute.sub_right
    В· apply hP1_comm Оө2 n
    В· simp only [neg_smul, neg_mul, neg_le_neg_iff]
      have h_comm : Commute (P1 Оө2 n).toMat ((E n (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
        apply hP1_comm Оө2 n
      have h_comm' : Commute (P1 Оө2 n).toMat ((Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
        have h_comm'' : Commute (P1 Оө2 n).toMat ((E n (ПҒ вҠ—Лў^[n])).M.log.toMat - (Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
          apply Commute.sub_right
          В· exact h_comm
          В· simp only [neg_smul, neg_mul, neg_le_neg_iff]
            rw [вҶҗ sub_nonneg, вҶҗ mul_sub_left_distrib]
            simp only [one_div, Algebra.smul_mul_assoc]
            have hE3commlog : Commute (P1 Оө2 n).toMat ((Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat - (E n (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
              apply Commute.sub_right
              В· apply hP1_comm Оө2 n
              В· simp only [neg_smul, neg_mul, neg_le_neg_iff]
                rw [вҶҗ sub_nonneg, вҶҗ mul_sub_left_distrib]
                simp only [one_div, Algebra.smul_mul_assoc]
                apply Commute.mul_nonneg (inv_nonneg_of_nonneg (Nat.cast_nonneg' n)) (by simpa using MState.zero_le (E n (ПҒ вҠ—Лў^[n])))
            simp only [sub_eq_neg_add, neg_neg] at hE3commlog
            exact hE3commlog
        exact h_comm''
      exact h_comm'

  have hP2_comm' : вҲҖ (Оө2 : в„қ) (n : в„•), Commute (P2 Оө2 n).toMat ((E n (ПҒ вҠ—Лў^[n])).M.log.toMat - (Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
    intro Оө2 n
    apply Commute.sub_right
    В· apply hP2_comm Оө2 n
    В· simp only [neg_smul, neg_mul, neg_le_neg_iff]
      have h_comm : Commute (P2 Оө2 n).toMat ((E n (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
        apply hP2_comm Оө2 n
      have h_comm' : Commute (P2 Оө2 n).toMat ((Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
        have h_comm'' : Commute (P2 Оө2 n).toMat ((E n (ПҒ вҠ—Лў^[n])).M.log.toMat - (Пғ'' (ПҒ вҠ—Лў^[n])).M.log.toMat) := by
          apply Commute.sub_right
          В· exact h_comm
          В· simp only [neg_smul, neg_mul, neg_le_neg_iff]
            rw [вҶҗ sub_nonneg, вҶҗ mul_sub_left_distrib]
