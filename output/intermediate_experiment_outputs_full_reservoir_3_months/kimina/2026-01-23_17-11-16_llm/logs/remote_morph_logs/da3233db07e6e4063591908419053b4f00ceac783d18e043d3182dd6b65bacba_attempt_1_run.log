        В· apply Commute.symm
          exact pinching_commutes (statePow ПҒ n) (вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n))
        В· simp
      В· simp
        rw [вҶҗ hE3]
        apply Commute.sub_right
        В· apply Commute.symm
          exact pinching_commutes (statePow ПҒ n) (вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n))
        В· simp
    have hc' : вҲҖ (Оө2 : в„• вҶ’ NNReal), (вҲҖ (n : в„•), Оө2 n < 1) вҶ’ вҲғ C, вҲҖб¶  (n : в„•) in Filter.atTop, c' (вҶ‘(Оө2 n)) n вүӨ вҶ‘C := by
      intro Оө2 hОө2
      apply hc' Оө2 hОө2
    have hПғ'' : вҲҖ (Оө2 : в„қ) (n : в„•), Real.exp (-вҶ‘n * c' Оө2 n) вҖў 1 вүӨ вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n) := by
      intro Оө2 n
      apply hПғ'' Оө2 n
    have hEsum : E1 Оө2 n + E2 Оө2 n + E3 Оө2 n = 1 := by
