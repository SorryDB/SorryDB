    have hE2leProj : E2 Оө2 n вүӨ вҶ‘((в„° n) (statePow ПҒ n)).proj_lt (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + ОөвӮҖ + Оө2)) вҖў вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)) := by
      unfold E2
      simp
      rw [вҶҗ hE2]
      apply proj_lt_of_le
      exact hE2
    have hE3comm : Commute вҶ‘(E3 Оө2 n) вҶ‘(вҶ‘((в„° n) (statePow ПҒ n))).log := by
      unfold E3
      simp
      rw [вҶҗ hE3]
