    ‖f * g‖_[r] ≤ ‖f‖_[p] * ‖g‖_[q] := by
  obtain rfl | p := p
  · sorry
  obtain rfl | q := q
  · sorry
  obtain rfl | r := r
  · sorry
  -- The following two come from `HolderTriple p q r`
  have hp₀ : p ≠ 0 := sorry
  have hq₀ : q ≠ 0 := sorry
  simp only [ENNReal.some_eq_coe] at *
  norm_cast at hr₀
