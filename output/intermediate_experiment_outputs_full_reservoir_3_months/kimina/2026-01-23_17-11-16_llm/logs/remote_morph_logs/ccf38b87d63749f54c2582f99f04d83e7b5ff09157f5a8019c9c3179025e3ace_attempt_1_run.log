  apply T.imp_closed (ПҶ := ПҲ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ПҶ вҲҲ T.theory вҶ” Deduction Ax T.theory ПҶ := by
