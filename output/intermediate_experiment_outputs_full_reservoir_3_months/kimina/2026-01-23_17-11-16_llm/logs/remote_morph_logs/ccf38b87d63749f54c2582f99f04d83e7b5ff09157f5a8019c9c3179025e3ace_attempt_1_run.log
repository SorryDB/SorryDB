structure FTheory (L : Logic в„•) where
  protected theory : FormulaSet в„•
  protected no_bot : вҠҘ вҲү theory
  protected andIR : вҲҖ {ПҶ ПҲ}, ПҶ вҲҲ theory вҶ’ ПҲ вҲҲ theory вҶ’ ПҶ вӢҸ ПҲ вҲҲ theory
  protected imp_closed : вҲҖ {ПҶ ПҲ}, L вҠў ПҶ вҶ’ ПҲ вҶ’ ПҶ вҲҲ theory вҶ’ ПҲ вҲҲ theory
  protected L_subset : L вҠҶ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {ПҶ ПҲ ПҮ : Formula в„•}

@[simp, grind <=]
lemma mem_of_provable [Entainment.HasAxiomVerum L] [Entainment.AFortiori L] (hПҶ : L вҠў ПҶ) : ПҶ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := вҠӨ) $ af hПҶ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entainment.HasAxiomI L] (hвӮҒ : ПҶ вҶ’ ПҲ вҲҲ T.theory) (hвӮӮ : ПҲ вҶ’ ПҮ вҲҲ T.theory) : ПҶ вҶ’ ПҮ вҲҲ T.theory := by
  apply T.imp_closed (axiomI (ПҲ := ПҲ));
  apply T.andIR hвӮҒ hвӮӮ;

@[grind <=]
lemma mem_orIntroL [Entainment.HasAxiomOrInst L] (hПҶ : ПҶ вҲҲ T.theory) : ПҶ вҲЁ ПҲ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := ПҶ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entainment.HasAxiomOrInst L] (hПҲ : ПҲ вҲҲ T.theory) : ПҶ вҲЁ ПҲ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := ПҲ);
  . exact orIntroR;
  . assumption;

