def construction (T : FTheory L) (hT : ПҮ вһқ Оҫ вҲү T.theory) : в„• вҶ’ Set (Formula в„•)
  | 0 => { Оҙ | ПҮ вһқ Оҙ вҲҲ T.theory }
  | i + 1 =>
    match (decode i) with
    | some Оҙ =>
      letI T' := construction T hT i
      if вҲҖ О“ : Finset (Formula _), вҶ‘О“ вҠҶ T' вҶ’ О“.conj вӢҸ Оҙ вһқ Оҫ вҲү T.theory then insert Оҙ T'
