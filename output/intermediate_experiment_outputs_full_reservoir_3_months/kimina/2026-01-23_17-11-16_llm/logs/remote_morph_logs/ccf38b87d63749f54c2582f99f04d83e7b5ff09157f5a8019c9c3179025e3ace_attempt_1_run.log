def construction (T : FTheory L) (hT : ПҮ вҶ’ Оҫ вҲү T.theory) : в„• вҶ’ Set (Formula в„•)
  | 0 => { Оҙ | ПҮ вҶ’ Оҙ вҲҲ T.theory }
  | i + 1 =>
