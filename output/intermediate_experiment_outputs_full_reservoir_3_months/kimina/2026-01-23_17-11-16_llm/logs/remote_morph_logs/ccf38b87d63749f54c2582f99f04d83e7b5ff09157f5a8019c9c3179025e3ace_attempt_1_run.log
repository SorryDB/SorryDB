  have h4 : (вҶ‘О“).conj вӢҸ (ПҶ вӢҸ ПҲ) вҲҲ U := by
    apply U.2.1;
    exact h3;
    exact hПҶПҲ.2;
  have h5 : (вҶ‘О“).conj вӢҸ (ПҶ вӢҸ ПҲ) = (вҶ‘О“).conj вӢҸ ПҶ вӢҸ (вҶ‘О“).conj вӢҸ ПҲ := by
