variable {ПҶ ПҲ ПҮ Оҫ : Formula в„•} {T : FTheory L} {hT : ПҮ вһқ Оҫ вҲү T.theory}

def construction (T : FTheory L) (hT : ПҮ вһқ Оҫ вҲү T.theory) : в„• вҶ’ Set (Formula в„•)
  | 0 => { Оҙ | ПҮ вһқ Оҙ вҲҲ T.theory }
  | i + 1 =>
    match (decode i) with
    | some Оҙ =>
      letI T' := construction T hT i
      if вҲҖ О“ : Finset (Formula _), вҶ‘О“ вҠҶ T' вҶ’ О“.conj вӢҸ Оҙ вһқ Оҫ вҲү T.theory then insert Оҙ T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : ПҮ вһқ Оҫ вҲү T.theory) : Set (Formula в„•) := вӢғ i, construction T hT i

lemma subset_construction_succ : construction T hT i вҠҶ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i вҠҶ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i вүӨ j) : construction T hT i вҠҶ construction T hT j := by
  obtain вҹЁk, rflвҹ© := le_iff_exists_add.mp hij;
  apply subset_construction_add;

lemma mem_omega_of_mem (h : ПҮ вһқ Оҙ вҲҲ T.theory) : Оҙ вҲҲ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion];
  use 0;
  simpa [construction];

lemma of_mem_construction_omega {ПҶ : Formula в„•} (hПҶ : ПҶ вҲҲ construction_omega T hT) :
  (ПҮ вһқ ПҶ вҲҲ T.theory) вҲЁ (вҲҖ О“ : Finset _, вҶ‘О“ вҠҶ construction T hT (encode ПҶ) вҶ’ О“.conj вӢҸ ПҶ вһқ Оҫ вҲү T.theory) := by
  obtain вҹЁi, hiвҹ© := by simpa [construction_omega] using hПҶ;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
    dsimp [construction] at hi;
    sorry;
    /-
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . grind;
      . grind;
    . tauto;
    .dsimp [construction] at hi;
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . sorry;
        . grind;
      . grind;
    . grind;
    split at hi;
    -/

lemma not_of_mem_construction_omega {ПҶ : Formula в„•}
  {О“ : Finset (Formula в„•)} (hО“ : вҶ‘О“ вҠҶ construction T hT (encode ПҶ))
  (hПҶ : О“.conj вӢҸ ПҶ вһқ Оҫ вҲҲ T.theory) :
  ПҶ вҲү (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    sorry;
  | succ i ih =>
    simp [construction];
    split;
    . split_ifs with h;
      . rename_i Оҙ hОҙ;
        by_contra hC;
        have : Оҙ = ПҶ := by grind;
        subst this;
        apply h О“ ((show encode Оҙ = i by sorry) в–ё hО“) hПҶ;
      . assumption
    . assumption;
    .dsimp [construction] at ih;
    split at ih;
    -/

lemma of_not_mem_construction_omega {ПҶ : Formula в„•} (hПҶ : ПҶ вҲү construction_omega T hT) :
  (ПҮ вһқ ПҶ вҲү T.theory) вҲ§ (вҲғ О“ : Finset (Formula _), вҶ‘О“ вҠҶ (construction T hT (encode ПҶ)) вҲ§ О“.conj вӢҸ ПҶ вһқ Оҫ вҲҲ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hПҶ;
  constructor;
  . simpa using hПҶ 0;
  . have this := hПҶ (encode ПҶ + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this;
    . simpa using h;


