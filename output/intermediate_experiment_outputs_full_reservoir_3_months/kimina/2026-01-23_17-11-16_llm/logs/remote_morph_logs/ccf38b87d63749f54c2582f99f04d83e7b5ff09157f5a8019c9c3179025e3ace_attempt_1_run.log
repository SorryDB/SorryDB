import Foundation.Propositional.Hilbert.F.Deduction
import Foundation.Propositional.Kripke2.Basic

namespace LO.Propositional

open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {Оұ : Type*}
variable {S} [Entailment S (Formula Оұ)]
variable {рқ“Ҳ : S}

structure FTheory (L : Logic в„•) where
  protected theory : FormulaSet в„•
  protected no_bot : вҠҘ вҲү theory
  protected andIR : вҲҖ {ПҶ ПҲ}, ПҶ вҲҲ theory вҶ’ ПҲ вҲҲ theory вҶ’ ПҶ вӢҸ ПҲ вҲҲ theory
  protected imp_closed : вҲҖ {ПҶ ПҲ}, L вҠў ПҶ вһқ ПҲ вҶ’ ПҶ вҲҲ theory вҶ’ ПҲ вҲҲ theory
  protected L_subset : L вҠҶ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {ПҶ ПҲ ПҮ : Formula в„•}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hПҶ : L вҠў ПҶ) : ПҶ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := вҠӨ) $ af hПҶ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (hвӮҒ : ПҶ вһқ ПҲ вҲҲ T.theory) (hвӮӮ : ПҲ вһқ ПҮ вҲҲ T.theory) : ПҶ вһқ ПҮ вҲҲ T.theory := by
  apply T.imp_closed (axiomI (ПҲ := ПҲ));
  apply T.andIR hвӮҒ hвӮӮ;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hПҶ : ПҶ вҲҲ T.theory) : ПҶ вӢҺ ПҲ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := ПҶ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hПҲ : ПҲ вҲҲ T.theory) : ПҶ вӢҺ ПҲ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := ПҲ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ПҶ вҲҲ T.theory вҶ” Deduction Ax T.theory ПҶ := by
  constructor;
  . intro hПҶ;
    apply Deduction.ctx hПҶ;
  . intro h; induction h <;> grind

end FTheory


variable {L : Logic в„•}

structure PrimeFTheory (L : Logic в„•) extends FTheory L where
  protected prime : вҲҖ {ПҶ ПҲ}, ПҶ вӢҺ ПҲ вҲҲ theory вҶ’ ПҶ вҲҲ theory вҲЁ ПҲ вҲҲ theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {ПҶ ПҲ ПҮ Оҫ : Formula в„•} {T : FTheory L} {hT : ПҮ вһқ Оҫ вҲү T.theory}

def construction (T : FTheory L) (hT : ПҮ вһқ Оҫ вҲү T.theory) : в„• вҶ’ Set (Formula в„•)
  | 0 => { Оҙ | ПҮ вһқ Оҙ вҲҲ T.theory }
  | i + 1 =>
    match (decode i) with
    | some Оҙ =>
      letI T' := construction T hT i
      if вҲҖ О“ : Finset (Formula _), вҶ‘О“ вҠҶ T' вҶ’ О“.conj вӢҸ Оҙ вһқ Оҫ вҲү T.theory then insert Оҙ T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : ПҮ вһқ Оҫ вҲү T.theory) : Set (Formula в„•) := вӢғ i, construction T hT i

lemma subset_construction_succ : construction T hT i вҠҶ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i вҠҶ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i вүӨ j) : construction T hT i вҠҶ construction T hT j := by
  obtain вҹЁk, rflвҹ© := le_iff_exists_add.mp hij;
  apply subset_construction_add;

lemma mem_omega_of_mem (h : ПҮ вһқ Оҙ вҲҲ T.theory) : Оҙ вҲҲ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion];
  use 0;
  simpa [construction];

lemma of_mem_construction_omega {ПҶ : Formula в„•} (hПҶ : ПҶ вҲҲ construction_omega T hT) :
  (ПҮ вһқ ПҶ вҲҲ T.theory) вҲЁ (вҲҖ О“ : Finset _, вҶ‘О“ вҠҶ construction T hT (encode ПҶ) вҶ’ О“.conj вӢҸ ПҶ вһқ Оҫ вҲү T.theory) := by
  obtain вҹЁi, hiвҹ© := by simpa [construction_omega] using hПҶ;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
    dsimp [construction] at hi;
    sorry;
    /-
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . grind;
      . grind;
    . grind;
    .dsimp [construction] at hi;
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . grind;
      . grind;
    . grind;
    split at hi;
    -/

lemma not_of_mem_construction_omega {ПҶ : Formula в„•}
  {О“ : Finset (Formula в„•)} (hО“ : вҶ‘О“ вҠҶ construction T hT (encode ПҶ))
  (hПҶ : О“.conj вӢҸ ПҶ вһқ Оҫ вҲҲ T.theory) :
  ПҶ вҲү (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    sorry;
  | succ i ih =>
    simp [construction];
    split;
    . split_ifs with h;
      . rename_i Оҙ hОҙ;
        by_contra hC;
        have : Оҙ = ПҶ := by grind;
        subst this;
        apply h О“ ((show encode Оҙ = i by sorry) в–ё hО“) hПҶ;
      . assumption
    . assumption;

lemma of_not_mem_construction_omega {ПҶ : Formula в„•} (hПҶ : ПҶ вҲү construction_omega T hT) :
  (ПҮ вһқ ПҶ вҲү T.theory) вҲ§ (вҲғ О“ : Finset (Formula _), вҶ‘О“ вҠҶ (construction T hT (encode ПҶ)) вҲ§ О“.conj вӢҸ ПҶ вһқ Оҫ вҲҲ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hПҶ;
  constructor;
  . simpa using hПҶ 0;
  . have this := hПҶ (encode ПҶ + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this;
    . simpa using h;


variable [Entailment.F L]

lemma construction_omega_mem_ant : ПҮ вҲҲ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
  apply impId;

lemma construction_omega_not_mem_csq : Оҫ вҲү construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion, not_exists];
  intro i;
  induction i with
  | zero => simpa [construction];
  | succ i ih =>
    contrapose! ih;
    dsimp [construction] at ih;
    split at ih;
    . split_ifs at ih with h;
      . rename_i Оҙ hОҙ;
        have := h вҲ… (by tauto);
        contrapose! this;
        have : Оҫ = Оҙ := by grind;
        subst this;
        apply T.mem_of_provable;
        simp;
      . assumption;
    . assumption;

lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  ПҶ вҲҲ U вҶ’ ПҲ вҲҲ U вҶ’ ПҶ вӢҸ ПҲ вҲҲ U := by
  rintro hПҶ hПҲ;
  by_contra hПҶПҲ;
  replace вҹЁhПҶПҲ, вҹЁО“, hО“вӮҒ, hО“вӮӮвҹ©вҹ© := of_not_mem_construction_omega hПҶПҲ;

  sorry;

lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L вҠў ПҶ вһқ ПҲ вҶ’ ПҶ вҲҲ U вҶ’ ПҲ вҲҲ U := by
  rintro hПҶПҲ hПҶ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ПҲ) + 1;
  simp [construction];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain вҹЁО“, hО“, hО“вӮӮвҹ© := h;
    have hО“вӮҒ : (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) вҲҲ T вҶ’ Оҫ вҲҲ T := by
      intro h1 h2; apply hО“вӮӮ; assumption; assumption
    have h' : (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) вҲҲ T := by
      apply T.imp_closed; assumption; assumption
    exfalso; apply h' h2 h1
```

Looking at the error location, it's in the `construction_omega_impClosed` lemma, specifically in the second case of the `split_ifs` statement.

The error message `tactic 'rewrite' failed, did not find instance of the pattern in the target expression` occurs in the second branch of the `split_ifs`.
The state at that point is:
- `h : (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) вҲү T`
- `h' : (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) вҲҲ T` (derived from `T.imp_closed`)

The tactic `exfalso; apply h' h2 h1` is attempting to apply the hypothesis `h'` to `h2` and `h1` to derive a contradiction. However, `h'` has the form `P вҶ’ Q`, and `h1` and `h2` are hypotheses `P` and `Q` respectively. The `apply` tactic expects `h'` to be applied to `h1` (to get `Q`), and then `Q` would be used with `h2` (which is also `Q`). This is not how `apply` works.

A more direct way to show a contradiction would be to use `h` with `h'`. `h` states that `(О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ)` is not in `T`, while `h'` states it is in `T`. This is a direct contradiction. The tactic `contradiction` can be used here, or `exact h h'`.

The overall proof strategy is to show that `L` implies the implication `(О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ)`.
The proof proceeds by cases based on the structure of the `if` statement in `split_ifs`.
- In the first case, where `вҲҖ (Оҙ : Formula в„•), Оҙ вҲҲ construction T hT (encode ПҲ) вҶ’ ...`, the goal is proven by `tauto`. This is correct.
- In the second case, where `В¬ (вҲҖ (Оҙ : Formula в„•), Оҙ вҲҲ construction T hT (encode ПҲ) вҶ’ ...)`, the proof attempts to derive a contradiction. This is where the error occurs.

The strategy for the second case is to use the fact that `h : (ПҮ вҶ’ Оҫ вҲү T)` (where `T` is `FTheory L`) and `h' : ( (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) ) вҲҲ T`. The hypothesis `h` can be used to show that `( (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) ) вҲү T`, leading to a contradiction. This strategy is sound, but the execution via `apply h' h2 h1` is incorrect.

To fix the error in the second branch of the `split_ifs` statement:
1.  Instead of `exfalso; apply h' h2 h1`, use `exfalso` followed by `have : ( (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) ) вҲҲ T := h'`. This explicitly names the fact that the implication is in `T`.
2.  Then, use `have : ( (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) ) вҲү T := h`. This explicitly names the fact that the implication is not in `T`.
3.  Finally, use `contradiction` to close the goal, as we have both `P вҲҲ T` and `P вҲү T`.

The original code for the second branch is:
```tactics
      . exfalso;
        push_neg at h;
        obtain вҹЁО“, hО“, hО“вӮӮвҹ© := h;
        have hО“вӮҒ : (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) вҲҲ T вҶ’ Оҫ вҲҲ T := by
          intro h1 h2; apply hО“вӮӮ; assumption; assumption
        have h' : (О“.conj вӢҸ ПҶ) вҶ’ (О“.conj вӢҸ ПҲ) вҲҲ T := by
          apply T.imp_closed; assumption; assumption
        exfalso; apply h' h2 h1
```

We will replace the last line with the suggested fix.

