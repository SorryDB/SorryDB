structure PrimeFTheory (L : Logic в„•) extends FTheory L where
  protected prime : вҲҖ {ПҶ ПҲ}, ПҶ вӢҺ ПҲ вҲҲ theory вҶ’ ПҶ вҲҲ theory вҲЁ ПҲ вҲҲ theory

