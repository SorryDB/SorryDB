                        have h14 : (bits2num p w args : ZMod p).val < 2 ^ w := by
                          have h15 : (bits2num p w args : ZMod p).val < 2 ^ w := by
                            have h16 : (bits2num p w args : ZMod p).val < 2 ^ w := by
                              have h17 : (bits2num p w args : ZMod p).val < 2 ^ w := by
                                have h18 : (bits2num p w args : ZMod p).val < 2 ^ w := by
                                  have h19 : (bits2num p w args : ZMod p).val < 2 ^ w := by
                                    have h20 : (bits2num p w args : ZMod p).val < 2 ^ w := by
