    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  unfold IsRefinement
  intro N hN
  use B N hN
  constructor
  · -- Show that B N ⊆ refinement B hB hB' hB''
    simp [Set.mem_iUnion]
  · -- Show that sSup (B N) = N
    have hN_eq_sSup : N = sSup (B N hN) := hB N hN
