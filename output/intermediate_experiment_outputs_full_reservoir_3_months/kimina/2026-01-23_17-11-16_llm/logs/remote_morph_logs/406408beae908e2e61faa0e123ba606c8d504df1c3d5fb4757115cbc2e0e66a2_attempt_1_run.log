      simp only at h_B₁
      have h_mem : A.val ∈ B := by
        by_contra h_A_not_mem
        have h_aux : Disjoint A.val (sSup B) := by
          exact (I.sSupIndep.disjoint_sSup A.prop h_B₂ h_A_not_mem)
        have h_aux' : sSup B ≤ A.val := h_B₁ ▸ h_N_le_A
