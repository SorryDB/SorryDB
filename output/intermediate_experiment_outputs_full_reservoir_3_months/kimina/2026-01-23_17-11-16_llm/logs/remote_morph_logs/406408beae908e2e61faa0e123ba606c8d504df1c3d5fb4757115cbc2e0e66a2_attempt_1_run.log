  ∀ ⦃N⦄, N ∈ D₂ → ∃ B : Set (PersistenceSubmodule M), B ⊆ D₁ ∧ N = sSup B

variable {M : C ⥤ ModuleCat K} in
/-- Suppose `I, J` are direct sum decompositions of `M ` and `J` is a refinement of `I`.
Then for any submodule `N` appearing in `J`, there is a submodule  `A` appearing in `I`
such that `N ≤ A`. -/
lemma RefinementMapSurj' (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : ∀ N : J, ∃ A : I, N.val ≤ A.val := by
  by_contra! h_contra
  rcases h_contra with ⟨N₀, h_not_le⟩
  have h_ge : N₀.val ⊔ sSup I ≤ sSup J := by
    rw [← sSup_pair]
    apply sSup_le_iff.mpr
    intro b h_mem
    rcases h_mem with ⟨h_n⟩
    · exact (le_sSup (h_n ▸ N₀.prop))
    · rename b ∈ {sSup (SetLike.coe I)} => h_i
      have h' : sSup (SetLike.coe I) ≤ sSup J := by
        rw [I.sSup_eq_top, J.sSup_eq_top]
      simp only [Set.mem_singleton_iff] at h_i
      exact (h_i ▸ h')
  let B : Set (PersistenceSubmodule M) := {C | ∃ A : I, C ≤ A.val ∧ C ∈ J}
  have h_sub : B ⊆ J := by
    intro C h_C_mem
    simp [B] at h_C_mem
    exact h_C_mem.right
  have h_aux : sSup B = sSup I := by
    simp_rw [le_antisymm_iff, sSup_le_iff]
    constructor
    · intro b h_mem
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B] at h_mem
      rcases h_mem with ⟨h₁, _⟩
      rcases h₁ with ⟨a, h_a, h_le⟩
      exact (le_sSup_of_le h_a h_le)
    have h_le_subset (A : I) : ∃ C ⊆ B, A ≤ sSup C := by
      choose f hf hf' using h
      refine ⟨f A.prop, ?_, by rw [← (hf' A.prop)]⟩
      intro α h_α
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B]
      refine ⟨⟨A, A.prop, ?_⟩, hf A.prop h_α⟩
      rw [hf' A.prop]
      exact le_sSup h_α
    intro A h_A_mem
    rcases h_le_subset ⟨A, h_A_mem⟩ with ⟨C, h_C⟩
    simp only at h_C
    exact le_trans h_C.right (sSup_le_sSup h_C.left)
  have h_aux' : N₀.val ∉ B := by
    intro h_contra
    simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, SetLike.coe_mem,
      and_true, B] at h_contra
    rcases h_contra with ⟨A, h₁, h₂⟩
    exact (h_not_le (⟨A, h₁⟩) h₂)
  have h_disj : Disjoint N₀.val (sSup B) := by
    exact (sSupIndep.disjoint_sSup J.sSupIndep' N₀.prop h_sub h_aux')
  have h_not_bot : N₀.val ≠ ⊥ := by
    intro h_contra
    exact J.not_bot_mem (h_contra ▸ N₀.prop)
  have h_gt : sSup I < N₀.val ⊔ sSup I := by
    rw [← h_aux]
    -- No clue why I couldn't use this theorem from mathlib directly and had to copy paste it here
    -- instead assuming it has to do with needing to bump
    exact (right_lt_sup_of_left_ne_bot h_disj h_not_bot)
  have contra : (⊤ : PersistenceSubmodule M) < ⊤ := by
    rw [I.sSup_eq_top, J.sSup_eq_top] at *
    apply lt_of_lt_of_le h_gt h_ge
  exact (lt_self_iff_false (⊤ : PersistenceSubmodule M)).mp contra

/-- The refinement relation defines a preorder on direct sum decompositions of `M` via `D₁ ≤ D₂` if
and only if `D₂` is a refinement of `D₁` i.e. this relation is reflexive and transitive. -/
instance : Preorder (DirectSumDecomposition M) where
  le D₁ D₂ := IsRefinement D₂ D₁
  --D₁ ≤ D₂ iff D₂ refines D₁.
  le_refl D := by intro N _; use {N}; aesop
  le_trans I₁ I₂ I₃ h12 h23 := by
    intro N h_mem
    rcases (h12 h_mem) with ⟨C, h_sub, h_eq⟩
    choose f hf hf' using h23
    let A := ⨆ (c : C), (f (h_sub c.prop))
    use A
    constructor
    · apply iSup_le_iff.mpr
      intro c
      exact hf (h_sub c.prop)
    · have h_aux' : sSup A = sSup C := by
        simp_rw [le_antisymm_iff, sSup_le_iff]
        constructor
        · intro a h_a
          have h_aux'' : ∃ (c : C), a ∈ (f (h_sub c.prop)) := by aesop
          rcases h_aux'' with ⟨c_a, h_ca⟩
          have h_le : a ≤ c_a := by
            rw [hf' (N := c_a) (h_sub c_a.2)]
            apply le_sSup h_ca
          apply le_sSup_of_le c_a.prop h_le
        intro c h_mem_c
        let c' : C := ⟨c, h_mem_c⟩
        have h_le_c : c ≤ sSup (f (h_sub c'.prop)) := by rw [← hf' (h_sub c'.prop)]
        apply le_trans h_le_c
        apply sSup_le
        intro a h_mem_a
        have h_a_in_A : a ∈ A := by
          have h_subs : f (h_sub c'.prop) ≤ A := by
            apply le_iSup_of_le c'
            exact le_rfl
          exact h_subs h_mem_a
        exact le_sSup h_a_in_A
      rwa [h_aux']

/-- The refinement relation is antisymmetric. This (combined with the above)
means that it defines a partial order on direct sum decompositions. -/
instance DirectSumDecompLE : PartialOrder (DirectSumDecomposition M) where
  le_antisymm := by
    intro I J h_I_le_J h_J_le_I
    have h_final_left : ∀ N ∈ J, N ∈ I := by
      intro N
      by_contra h_neg
      push_neg at h_neg
      rcases h_neg with ⟨h_N_in_J, h_N_not_in_I⟩
      let N' : J := ⟨N, h_N_in_J⟩
      have h_A : ∃ A : I, N ≤ A.val := by
        exact (RefinementMapSurj' I J h_I_le_J) N'
      rcases h_A with ⟨A, h_N_le_A⟩
      choose f hf hf' using h_J_le_I
      let B := f N'.prop
      have h_B₁ : N = _ := hf' N'.prop
      have h_B₂ := hf N'.prop
      simp only at h_B₁
      have h_mem : A.val ∈ B := by
        by_contra h_A_not_mem
        have h_aux : Disjoint A.val (sSup B) := by
          exact (I.sSupIndep.disjoint_sSup A.prop h_B₂ h_A_not_mem)
        have h_aux' : sSup B ≤ A.val := h_B₁ ▸ h_N_le_A
        have h_last : sSup B = (⊥ : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [← h_B₁] at h_last
        subst h_last
        exact (J.not_bot_mem h_N_in_J)
      have h_A_le_N : A.val ≤ N := by
        rw [h_B₁]
        exact le_sSup h_mem
      have h_A_eq_N : A.val = N := by
        exact (le_antisymm h_A_le_N h_N_le_A)
      have h_contra : N ∈ I := by
        exact h_A_eq_N ▸ A.prop
      aesop
    have h_final_right : ∀ N ∈ I, N ∈ J := by
      sorry
    aesop

section Indecomposable
variable {D : DirectSumDecomposition M}

/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `D` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D` whose underlying set is the
union of all decompositions of the `N`'s appearing in `D`. -/
@[nolint unusedArguments]
def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    sorry
  sSup_eq_top' := by
    sorry
  not_bot_mem' := by simp [Set.mem_iUnion, hB'']

/-- The direct sum decomposition `refinement B hB hB' hB''` is a refinement of `D` -/
lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  -- We need to show that for every N in D, N is in the refinement.
  -- Let N be an element of D.
  intro N hN
  -- We need to show N is in the refinement.
  -- The refinement is the union of sets B M' hM' for all M' in D.
  -- So we need to show that N is in some B M' hM' set.
  -- Since N is in D, we can apply B to N and hN.
  let B_N := B N hN
  -- We need to show N is in B_N.
  -- By hypothesis hB, we know N = sSup (B_N).
  -- Since N is in D, and N is equal to the supremum of B_N.
  -- Also, by hypothesis hB'', we know ⊥ ∉ B_N.
  -- The set B_N is linearly independent (by hB').
  -- The supremum of B_N is N itself (by hB).
  -- Therefore, N must be in the set B_N.
  have hN_in_BN : N ∈ B_N := by
    -- We know that sSup (B_N) = N (from hB).
    -- The supremum of a set is the least upper bound.
    -- So N is an upper bound for B_N.
    -- Also, since B_N is non-empty (because sSup is N and N is non-zero).
    -- We can use the property that sSup S = x implies x ∈ S if S is non-empty.
    -- But we need to ensure B_N is non-empty.
    -- Since N = sSup (B_N), and N is non-zero (because N ∈ D).
    -- So sSup (B_N) is non-zero, which implies B_N is non-empty.
    have hN_nonzero : N ≠ ⊥ := by
      exact D.not_bot_mem hN
    have hB_N_nonempty : Nonempty (B_N) := by
      -- If B_N is empty, then sSup (B_N) = ⊥.
      -- But we know sSup (B_N) = N.
      -- So N = ⊥, which contradicts N ≠ ⊥.
      by_contra h_empty
      have h_sSup_eq_bot : sSup (B_N) = ⊥ := by
        rw [sSup_eq_bot]
        exact h_empty
      have hN_eq_bot : N = ⊥ := by
        rw [hB] at *
        linarith
      contradiction
    -- Now we can use the property that sSup S = x and x ≠ ⊥ implies x ∈ S.
    -- This is because sSup S is the least upper bound.
    -- If x = sSup S and x ≠ ⊥, then x must be in S.
    -- Proof: If x ∉ S, then x is an upper bound not in S.
    -- Then sSup S ≤ x, but x < sSup S if x is not in S.
    -- This would mean sSup S < sSup S, a contradiction.
    have hN_in_sSup : N ∈ sSup (B_N) := by
      -- sSup (B_N) = N, so N ∈ sSup (B_N) is trivial.
      rw [hB]
      exact mem_sSup (B_N) N
    -- But sSup (B_N) = N, so N ∈ sSup (B_N) is trivial.
    -- We need to show N ∈ B_N.
    -- The definition of sSup requires that the set be non-empty.
    -- We have already shown B_N is non-empty.
    -- From the definition of sSup, any element in sSup S must be in S.
    -- Wait, no. sSup S is the least upper bound.
    -- An element x is in sSup S if x is an upper bound of S.
    -- The set sSup S itself is the set of upper bounds.
    -- So to show N ∈ B_N, we need to show N is in the set B_N.
    -- This is not directly given by sSup properties.
    -- Let's use the definition of sSup.
    -- sSup (B_N) = { x | ∀ y ∈ B_N, y ≤ x }.
    -- We know N = sSup (B_N).
    -- So N = { x | ∀ y ∈ B_N, y ≤ x }.
    -- Since N is in the set { x | ∀ y ∈ B_N, y ≤ x }, we have ∀ y ∈ B_N, y ≤ N.
    -- This is just saying N is an upper bound for B_N, which is true by definition of sSup.
    -- To show N ∈ B_N, we need more.
    -- Let's use the property that sSup (B_N) = N and ⊥ ∉ B_N.
    -- If B_N is empty, sSup (B_N) = ⊥. But sSup (B_N) = N and N ≠ ⊥, so B_N is non-empty.
    -- Let x ∈ B_N. Then x ≤ N.
    -- Since sSup (B_N) = N, and B_N is non-empty, N must be in B_N.
    -- Proof: Suppose N ∉ B_N. Then for all x ∈ B_N, x < N.
    -- Then sSup (B_N) < N. But sSup (B_N) = N. Contradiction.
    have hN_in_BN : N ∈ B_N := by
      -- Assume N ∉ B_N for contradiction.
      by_contra hN_not_in_BN
      -- Then for all x ∈ B_N, x < N.
      have h_lt : ∀ x ∈ B_N, x < N := by
        intro x hx
        -- We know that sSup (B_N) = N.
        -- If x ∈ B_N, then x ≤ sSup (B_N) = N.
        have h_le : x ≤ sSup (B_N) := by
          apply le_sSup
          exact hx
        rw [hB] at h_le
        -- So x ≤ N.
        -- If x < N were false, then x = N.
        -- But x ∈ B_N and N ∉ B_N implies x ≠ N.
        -- So x < N.
        -- This part is confusing. Let's try a different approach.
        -- If N ∉ B_N, then for all x ∈ B_N, x < N.
        -- This would mean sSup (B_N) < N.
        -- But sSup (B_N) = N. Contradiction.
        by_contra h_eq
        push_neg at h_eq
        have h_x_eq_N : x = N := by
          linarith
        have h_x_in_BN : x ∈ B_N := hx
        rw [h_x_eq_N] at hN_not_in_BN
        exact hN_not_in_BN h_x_in_BN
      -- Now we know that ∀ x ∈ B_N, x < N.
      -- This implies sSup (B_N) < N.
      have h_sSup_lt_N : sSup (B_N) < N := by
        apply sSup_lt_of_forall_lt
        · exact hB_N_nonempty
        · intro x hx
          exact h_lt x hx
      -- But we know sSup (B_N) = N.
      rw [hB] at h_sSup_lt_N
      -- So N < N, which is a contradiction.
      linarith
    exact hN_in_BN
  -- Now we need to show that N is in the refinement.
  -- The refinement's carrier is the union of all B M' hM' sets.
  -- So we need to show N ∈ ⋃ N', ⋃ hN', B N' hN'.
  -- This is equivalent to ∃ N', ∃ hN', N ∈ B N' hN'.
  -- We have N ∈ B_N, where B_N = B N hN.
  -- So we can take N' = N and hN' = hN.
  -- Then N ∈ B N hN.
  simp [Set.mem_iUnion, Set.mem_iUnion]
  refine ⟨N, hN, N, hN_in_BN⟩
```

