  · -- Show that {N} ∪ ⋃ n ∈ D \ {N}, (B n hn) ⊆ D
    intro B'
    simp only [Set.mem_union, Set.mem_singleton_iff, Set.mem_iUnion]
    intro b hb
    rcases hb with (hb | hb)
    · -- Case where b = N
      exact hN
    · -- Case where b ∈ ⋃ n ∈ D \ {N}, (B n hn)
      rcases hb with ⟨b', hb'⟩
      simp only at hb'
      rcases hb' with ⟨n, hn, hb_n⟩
      have hn' : n ∈ D := hn
      have h_n_mem : n ≠ N := by
        intro h_eq
        simp [h_eq] at hn'
      have h_b_in_B : b = b' := by
        simpa using hb_n
      rw [h_b_in_B]
      exact hn'
  · -- Show that N = sSup ({N} ∪ ⋃ n ∈ D \ {N}, (B n hn))
    have h_sSup_eq : sSup ({N} ∪ ⋃ n ∈ D \ {N}, (B n hn)) = N := by
      have h_sSup_union : sSup ({N} ∪ ⋃ n ∈ D \ {N}, (B n hn)) = sSup {N} := by
