  simp_rw [Set.image_preimage_eq_inter_range, Subtype.range_val, έΗΡ this,
    έΗΡ Set.inter_symmDiff_distrib_left, Set.inter_sdiff_left_comm _ (έΜΔ _, _)] at hAB

protected lemma _root_.IsNIPWith.restrictFiniteSymmDiffComponent
    (hΏζΥΤ : IsNIPWith d (ΏζΥΤ : Set (Set ╬▒))) :
    IsNIPWith d (restrictFiniteSymmDiffComponent ΏζΥΤ : Set (Set έΗΣ((έΜΔ A έΙΙ ΏζΥΤ, A) \ έΜΓ A έΙΙ ΏζΥΤ, A))) := by
