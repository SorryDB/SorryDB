import Mathlib.Algebra.BigOperators.Ring.Finset
import Mathlib.Algebra.Order.BigOperators.Group.Finset
import Mathlib.Data.Set.Card
import Mathlib.Data.Set.Finite.Lattice
import Mathlib.Order.Partition.Finpartition
import MiscYD.Mathlib.Combinatorics.SetFamily.Shatter

/-!
# A small VC dimension family has few edges in the L┬╣ metric

This file proves that set families over a finite type that have small VC dimension have a number
of pairs `(A, B)` with `#(A έΙΗ B) = 1` linear in their size.

## References

* *Sphere Packing Numbers for Subsets of the Boolean n-Cube with Bounded
  Vapnik-Chervonenkis Dimension*, David Haussler
* Write-up by Thomas Bloom: http://www.thomasbloom.org/notes/vc.html
-/

open Finset
open scoped symmDiff

namespace SetFamily
variable {╬▒ : Type*} {ΏζΥΧ ΏζΥΤ : Finset (Set ╬▒)} {A B : Set ╬▒} {d : έΕΧ}

/-- The edges of the subgraph of the hypercube `Set ╬▒` induced by a finite set of vertices
`ΏζΥΧ : Finset (Set ╬▒)`. -/
noncomputable def hypercubeEdgeFinset (ΏζΥΧ : Finset (Set ╬▒)) : Finset (Set ╬▒ ├Ω Set ╬▒) :=
  {AB έΙΙ ΏζΥΧ ├Ω╦λ ΏζΥΧ | (AB.1 έΙΗ AB.2).ncard = 1}

@[simp] lemma prodMk_mem_hypercubeEdgeFinset :
    (A, B) έΙΙ hypercubeEdgeFinset ΏζΥΧ έΗΦ A έΙΙ ΏζΥΧ έΙπ B έΙΙ ΏζΥΧ έΙπ (A έΙΗ B).ncard = 1 := by
  simp [hypercubeEdgeFinset, and_assoc]

open scoped Classical in
@[simp]
private lemma filter_finite_symmDiff_inj (hB : B έΙΙ ΏζΥΧ) :
    {C έΙΙ ΏζΥΧ | (A έΙΗ C).Finite} = {C έΙΙ ΏζΥΧ | (B έΙΗ C).Finite} έΗΦ (A έΙΗ B).Finite where
  mp hAB := by
    have : B έΙΙ {C έΙΙ ΏζΥΧ | (A έΙΗ C).Finite} := hAB έΨ╕ mem_filter.2 έθρhB, by simpέθσ
    exact (mem_filter.1 this).2
  mpr hAB := by ext D; simp [hAB.symmDiff_congr]

open scoped Classical in
/-- Partition a set family into its components of finite symmetric difference. -/
noncomputable def finiteSymmDiffFinpartition (ΏζΥΧ : Finset (Set ╬▒)) : Finpartition ΏζΥΧ where
  parts := ΏζΥΧ.image fun A έΗο {B έΙΙ ΏζΥΧ | (A έΙΗ B).Finite}
  supIndep := by
    simp +contextual only [supIndep_iff_pairwiseDisjoint, Set.PairwiseDisjoint, Set.Pairwise,
      coe_image, Set.mem_image, mem_coe, ne_eq, Function.onFun, id, disjoint_left,
      forall_exists_index, and_imp, forall_apply_eq_imp_iffέΓΓ, mem_filter, not_and, forall_const,
      filter_finite_symmDiff_inj]
    refine fun A hA B hB hAB C hC hAC hBC έΗο hAB ?_
    exact (hAC.union <| symmDiff_comm B C έΨ╕ hBC).subset <| symmDiff_triangle ..
  sup_parts := by
    simp only [sup_image, le_antisymm_iff, Finset.sup_le_iff, le_eq_subset,
      filter_subset, implies_true, true_and, Function.id_comp]
    exact fun A hA έΗο mem_sup.2 έθρA, hA, mem_filter.2 έθρhA, by simpέθσέθσ
  bot_notMem := by
    simp only [bot_eq_empty, mem_image, filter_eq_empty_iff, not_exists, not_and, not_forall,
      Decidable.not_not]
    exact fun A hA έΗο έθρA, hA, by simpέθσ

open scoped Classical in
lemma finite_symmDiff_of_mem_finiteSymmDiffFinpartition
    (hΏζΥΤ : ΏζΥΤ έΙΙ (finiteSymmDiffFinpartition ΏζΥΧ).parts) (hA : A έΙΙ ΏζΥΤ) (hB : B έΙΙ ΏζΥΤ) :
    (A έΙΗ B).Finite := by
  simp only [finiteSymmDiffFinpartition, mem_image] at hΏζΥΤ
  obtain έθρC, hC, rflέθσ := hC
  rw [mem_filter] at hA hB
  exact ((symmDiff_comm A C έΨ╕ hA.2).union hB.2).subset <| symmDiff_triangle ..

open scoped Classical in
lemma finite_iUnion_sdiff_iInter_of_mem_finiteSymmDiffFinpartition
    (hΏζΥΤ : ΏζΥΤ έΙΙ (finiteSymmDiffFinpartition ΏζΥΧ).parts) : ((έΜΔ A έΙΙ ΏζΥΤ, A) \ έΜΓ A έΙΙ ΏζΥΤ, A).Finite := by
  simp_rw [Set.iUnion_diff, Set.diff_iInter]
  exact .biUnion ΏζΥΤ.finite_toSet fun A hA έΗο .biUnion ΏζΥΤ.finite_toSet fun B hB έΗο
    (finite_symmDiff_of_mem_finiteSymmDiffFinpartition hC hA hB).subset le_sup_left

open scoped Classical in
@[simp]
lemma sup_finiteSymmDiffFinpartition_hypercubeEdgeFinset (ΏζΥΧ : Finset (Set ╬▒)) :
    (finiteSymmDiffFinpartition ΏζΥΧ).parts.sup hypercubeEdgeFinset = hypercubeEdgeFinset ΏζΥΧ := by
  ext έθρA, Bέθσ
  simp only [finiteSymmDiffFinpartition, sup_image, mem_sup, Function.comp_apply,
    prodMk_mem_hypercubeEdgeFinset, mem_filter, and_assoc, and_left_comm, exists_and_left,
    and_congr_right_iff, Set.ncard_eq_one]
  refine fun hA hB έΗο έθρ?_, ?_έθσ
  ┬╖ rintro έθρC, hC, hCA, hCB, hABέθσ
    exact hAB
  ┬╖ rintro έθρa, haέθσ
    exact έθρA, by simp [*]έθσ

open scoped Classical Set.Notation in
/-- Restrict a component of finite symmetric difference to a set family over a finite type. -/
noncomputable def restrictFiniteSymmDiffComponent (ΏζΥΤ : Finset (Set ╬▒)) :
    Finset (Set έΗξ((έΜΔ A έΙΙ ΏζΥΤ, A) \ έΜΓ A έΙΙ ΏζΥΤ, A)) :=
  ΏζΥΤ.image fun A έΗο _ έΙσ A έΙΗ έΜΓ B έΙΙ ΏζΥΤ, B

@[simp] lemma card_restrictFiniteSymmDiffComponent (ΏζΥΤ : Finset (Set ╬▒)) :
    #(restrictFiniteSymmDiffComponent ΏζΥΤ) = #ΏζΥΤ := by
  classical
  refine card_image
