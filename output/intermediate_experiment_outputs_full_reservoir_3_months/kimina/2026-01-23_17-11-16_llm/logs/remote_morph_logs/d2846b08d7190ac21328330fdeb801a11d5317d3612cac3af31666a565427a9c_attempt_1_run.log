    (hΏζΥΤ : ΏζΥΤ έΙΙ (finiteSymmDiffFinpartition ΏζΥΧ).parts) : ((έΜΔ A έΙΙ ΏζΥΤ, A) \ έΜΓ A έΙΙ ΏζΥΤ, A).Finite := by
  simp_rw [Set.iUnion_diff, Set.diff_iInter]
  exact .biUnion ΏζΥΤ.finite_toSet fun A hA έΗο .biUnion ΏζΥΤ.finite_toSet fun B hB έΗο
    (finite_symmDiff_of_mem_finiteSymmDiffFinpartition hΏζΥΤ hA hB).subset le_sup_left

open scoped Classical in
@[simp]
lemma sup_finiteSymmDiffFinpartition_hypercubeEdgeFinset (ΏζΥΧ : Finset (Set ╬▒)) :
    (finiteSymmDiffFinpartition ΏζΥΧ).parts.sup hypercubeEdgeFinset = hypercubeEdgeFinset ΏζΥΧ := by
  ext έθρA, Bέθσ
