  parts := ΏζΥΧ.image fun A έΗο {B έΙΙ ΏζΥΧ | (A έΙΗ B).Finite}
  supIndep := by
    simp +contextual only [supIndep_iff_pairwiseDisjoint, Set.PairwiseDisjoint, Set.Pairwise,
      coe_image, Set.mem_image, mem_coe, ne_eq, Function.onFun, id, disjoint_left,
      forall_exists_index, and_imp, forall_apply_eq_imp_iffέΓΓ, mem_filter, not_and, forall_const,
      filter_finite_symmDiff_inj]
    refine fun A hA B hB hAB C hC hAC hBC έΗο hAB ?_
