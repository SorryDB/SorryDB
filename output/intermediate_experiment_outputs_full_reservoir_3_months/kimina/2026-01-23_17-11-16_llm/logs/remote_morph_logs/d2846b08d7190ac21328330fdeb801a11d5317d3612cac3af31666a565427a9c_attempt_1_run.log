noncomputable def hypercubeEdgeFinset (ΏζΥΧ : Finset (Set ╬▒)) : Finset (Set ╬▒ ├Ω Set ╬▒) :=
  {AB έΙΙ ΏζΥΧ ├Ω╦λ ΏζΥΧ | (AB.1 έΙΗ AB.2).ncard = 1}

