        have hN_le : N ≤ sSup (D.carrier) := by
          rw [hN_eq]
          exact le_rfl
        have hN_in_D : N ∈ D := hN
        have hx_in_D : x ∈ D := by
          have hx_le_sSup : x ≤ sSup (D.carrier) := hx_in_sSup
          exact (D.not_bot_mem' (by simpa using hN_in_D)).le_of_le_sSup hx_le_sSup
