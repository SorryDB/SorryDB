· -- Show that all submodules are non-zero
  intro P hP
  simp at hP ⊢
  rcases hP with (h | h)
  · -- P ∈ D \ {N}
    simp [h.2]
    have hP_in_D : P ∈ D := by
      simpa using h.1
    intro hP_zero
    have hP_zero_in_D : P = ⊥ := by
      simpa using hP_zero
    rw [hP_zero_in_D] at hP_in_D
    have hN_in_D : N ∈ D := hN
    exfalso
    have hN_eq : N = sSup (D.carrier) := by
      rw [D.sSup_eq_top']
    have hN_le : N ≤ sSup (D.carrier) := by
      rw [hN_eq]
      exact le_rfl
    have hN_in_D : N ∈ D := hN
    have hN_not_zero : N ≠ ⊥ := by
      have hN_eq : N = x ⊔ y := hN_eq
      rw [hN_eq]
      by_contra h
      have h_zero : x ⊔ y = ⊥ := by
        simpa using h
      have hx_zero : x ≤ x ⊔ y := by
        apply le_sup_iff.mpr
        simp
      have hy_zero : y ≤ x ⊔ y := by
        apply le_sup_iff.mpr
        simp
      have hx_eq_zero : x = ⊥ := by
        linarith [h_zero, hx]
      have hy_eq_zero : y = ⊥ := by
        linarith [h_zero, hy]
      exfalso
      have hxy : Disjoint x y := hxy
      have hxy' : Disjoint ⊥ ⊥ := by
        rw [hx_eq_zero, hy_eq_zero]
      simp at hxy'
    contradiction
