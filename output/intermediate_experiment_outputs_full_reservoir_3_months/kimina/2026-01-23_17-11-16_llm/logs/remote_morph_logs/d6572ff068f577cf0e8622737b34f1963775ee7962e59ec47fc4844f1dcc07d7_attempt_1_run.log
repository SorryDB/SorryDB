        try { 
          tauto 
        }
    have h4 : IsRightInverse g.1 (b.2) := by 
      rw [h2] 
      all_goals 
        try { 
          simp 
        } 
        try { 
          tauto 
        }
    have h5 : ∃ B₁, B₁ ⊆ B ∧ IsIsomorphism (f.1 | B₁) := by 
      apply hf 
      all_goals 
        try { 
          exact h3 
        } 
        try { 
          tauto 
        }
