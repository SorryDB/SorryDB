  have h2 : ‚ąÉ t ‚ąą Set.Ico 0 l, x + t ‚ąą {t | IsLinftyAP őĶ t f} := hl x
  rcases h2 with ‚ü®t, ht_mem, ht_is_ap‚ü©
  have h3 : ‚ąÉ s ‚ąą Set.Ico 0 l, y + s ‚ąą {t | IsLinftyAP őĶ t f} := hl y
  rcases h3 with ‚ü®s, hs_mem, hs_is_ap‚ü©
  have ht0 : 0 ‚Č§ t := ht_mem.1
  have ht1 : t < l := ht_mem.2
  have hs0 : 0 ‚Č§ s := hs_mem.1
  have hs1 : s < l := hs_mem.2
  have h4 : ‚ÄĖf (x + t) - f x‚ÄĖ ‚Č§ őĶ := by
    simpa using ht_is_ap
  have h5 : ‚ÄĖf (y + s) - f y‚ÄĖ ‚Č§ őĶ := by
    simpa using hs_is_ap
  have h6 : ‚ÄĖf (x + t) - f (y + s)‚ÄĖ ‚Č§ 2 * őĶ := by
    have h7 : ‚ÄĖf (x + t) - f (y + s)‚ÄĖ ‚Č§ ‚ÄĖf (x + t) - f x‚ÄĖ + ‚ÄĖf x - f y‚ÄĖ + ‚ÄĖf y - f (y + s)‚ÄĖ := by
      have h8 : f (x + t) - f (y + s) = (f (x + t) - f x) + (f x - f y) + (f y - f (y + s)) := by ring
      rw [h8]
      apply norm_add_le
    have h8 : ‚ÄĖf (x + t) - f x‚ÄĖ ‚Č§ őĶ := h4
    have h9 : ‚ÄĖf y - f (y + s)‚ÄĖ ‚Č§ őĶ := by
      have h10 : ‚ÄĖf (y + s) - f y‚ÄĖ ‚Č§ őĶ := h5
      have h11 : ‚ÄĖf y - f (y + s)‚ÄĖ = ‚ÄĖf (y + s) - f y‚ÄĖ := by
        simp [norm_sub]
