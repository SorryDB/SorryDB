import Mathlib.Analysis.Complex.Basic
import Mathlib.Tactic.Positivity.Basic
import Mathlib.Tactic.FieldSimp
import Mathlib.Tactic.Ring

/-!
# Uniformly almost periodic functions
-/

variable {E F : Set ‚ĄĚ} {C D őĶ őī t l : ‚ĄĚ} {f g : ‚ĄĚ ‚Üí ‚Ąā}

variable (E l) in
/-- A set `E` of reals is **relatively dense with respect to `l`** if every (closed-open) interval
of length `l` contains an element of `E`. -/
def IsRelDenseWith : Prop := ‚ąÄ x, ‚ąÉ y ‚ąą Set.Ico 0 l, x + y ‚ąą E

lemma IsRelDenseWith.subset (hEF : E ‚äÜ F) : IsRelDenseWith E l ‚Üí IsRelDenseWith F l :=
  forall_imp fun _x ‚Ü¶ .imp fun _l ‚Ü¶ .imp_right <| @hEF _

lemma IsRelDenseWith.pos (hE : IsRelDenseWith E l) : 0 < l := by
  obtain ‚ü®y, ‚ü®hy‚āÄ, hyl‚ü©, _‚ü© := hE 0; exact hy‚āÄ.trans_lt hyl

variable (E) in
/-- A set `E` of reals is **relatively dense** if it is relatively dense with respect to some `l`.
-/
def IsRelDense : Prop := ‚ąÉ l, IsRelDenseWith E l

lemma IsRelDense.subset (hEF : E ‚äÜ F) : IsRelDense E ‚Üí IsRelDense F := .imp fun _ ‚Ü¶ .subset hEF

variable (őĶ t f) in
/-- A real number `t` is an **`őĶ`, L‚ąě-almost period** of a function `f : ‚ĄĚ \r ‚ĄĚ` if
`‚ÄĖf - ŌĄ t f‚ÄĖ_‚ąě ‚Č§ őĶ`. -/
def IsLinftyAP : Prop := ‚ąÄ x, ‚ÄĖf (x + t) - f x‚ÄĖ ‚Č§ őĶ

lemma IsLinftyAP.mul_fun (hfbdd : ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C) (hgbdd : ‚ąÄ x, ‚ÄĖg x‚ÄĖ ‚Č§ D)
    (hf : IsLinftyAP őĶ t f) (hg : IsLinftyAP őī t g) : IsLinftyAP (D * őĶ + C * őī) t (f * g) := by
  rintro x
  have := hf x
  have := hg x
  have := hfbdd (x + t)
  have := hgbdd x
  calc
        ‚ÄĖf (x + t) * g (x + t) - f x * g x‚ÄĖ
    _ = ‚ÄĖg x * (f (x + t) - f x) + f (x + t) * (g (x + t) - g x)‚ÄĖ := by ring_nf
    _ ‚Č§ ‚ÄĖg x * (f (x + t) - f x)‚ÄĖ + ‚ÄĖf (x + t) * (g (x + t) - g x)‚ÄĖ := norm_add_le ..
    _ = ‚ÄĖg x‚ÄĖ * ‚ÄĖf (x + t) - f x‚ÄĖ + ‚ÄĖf (x + t)‚ÄĖ * ‚ÄĖg (x + t) - g x‚ÄĖ := by simp
    _ ‚Č§ D * őĶ + C * őī := by gcongr <;> exact (norm_nonneg _).trans ‚ÄĻ_‚Äļ

variable (f) in
/-- A function `f : ‚ĄĚ ‚Üí ‚Ąā` is **uniformly almost periodic** if its set of `őĶ`, L‚ąě-almost period is
relatively dense for all `őĶ > 0`. -/
def IsUnifAlmostPeriodic : Prop := ‚ąÄ ‚¶ÉőĶ‚¶Ą, 0 < őĶ ‚Üí IsRelDense {t | IsLinftyAP őĶ t f}

/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
