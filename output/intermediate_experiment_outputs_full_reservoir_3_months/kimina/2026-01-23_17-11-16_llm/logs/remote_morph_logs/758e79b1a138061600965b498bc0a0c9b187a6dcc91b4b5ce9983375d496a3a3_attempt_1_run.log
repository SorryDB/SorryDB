    have h3 : x ≤ 1 := by
      nlinarith [h10, h20, sq_nonneg (x - 1), sq_nonneg (x + 1)]
    linarith
  have gt_one : x > 1 := by
    have h4 : x > 1 := by
      nlinarith [h10, h20, sq_nonneg (x - 1), sq_nonneg (x + 1)]
    linarith
  linarith [le_one, gt_one]
