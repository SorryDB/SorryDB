import Mathlib

-- Define the Comma category structure
noncomputable def Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Type (max D.univSort C.univSort) :=
  Σ (d : D) (e : E), (C (F d) (G e))

-- Define the Hom structure in the Comma category
noncomputable def Comma_category_Hom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    ∀ (X Y : (d : D) × (e : E) × (h : C (F d) (G e))), Type* :=
  fun X Y => (D × E × (C (F X.1) (G Y.1)) × (C (F X.1) (G Y.1))) / 
    (λ h => F.map_comp (D × E × (C (F X.1) (G Y.1)) × (C (F X.1) (G Y.1))) h)

-- Define the identity function in the Comma category
noncomputable def id_in_comma {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    ∀ X : (d : D) × (e : E) × (h : C (F d) (G e)), (d : D) × (e : E) × (h : C (F d) (G e)) := 
  fun X => X

-- Define the composition function in the Comma category
noncomputable def comp_in_comma {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    ∀ (f g : (d : D) × (e : E) × (h : C (F d) (G e))), 
      f.1.1 ≫ g.1.1 ∧ f.1.2 ≫ g.1.2 := 
  fun f g => ⟨f.1.1 ≫ g.1.1, f.1.2 ≫ g.1.2⟩

-- Define the Comma category as a full category
noncomputable instance : Category (Comma_category D C E F G) :=
  { 
    Hom := fun X Y => (D × E × (C (F X.1) (G Y.1)) × (C (F X.1) (G Y.1))) / 
      (λ h => F.map_comp (D × E × (C (F X.1) (G Y.1)) × (C (F X.1) (G Y.1))) h),
    id := id_in_comma F G,
    comp := comp_in_comma F G,
    id_comp := by 
      intro X
      simp [id_in_comma]
      all_goals try tauto,
    comp_id := by 
      intro X Y
      simp [comp_in_comma]
      all_goals try tauto,
    assoc := by 
      intro X Y Z
      simp [comp_in_comma]
      all_goals try tauto
  }

-- Prove the identity is a functor
noncomputable instance : Functor (Comma_category D C E F G) D :=
  { 
    F := fun X => X.2.1,
    homF := fun {X Y} f => f.2.1,
    map_id X := by 
      simp [id_in_comma]
      all_goals try tauto,
    map_comp f g := by 
      simp [comp_in_comma]
      all_goals try tauto
  }

-- Prove the identity is a contravariant functor
noncomputable instance : ContraFunctor (Comma_category D C E F G) E :=
  { 
    F := fun X => X.2.2,
    homF := fun {X Y} f => f.2.2,
    map_id X := by 
      simp [id_in_comma]
