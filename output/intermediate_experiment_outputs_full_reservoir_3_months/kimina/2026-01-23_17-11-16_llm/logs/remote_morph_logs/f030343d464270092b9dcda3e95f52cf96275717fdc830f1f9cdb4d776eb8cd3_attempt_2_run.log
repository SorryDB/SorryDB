-- exercise 1.3.vi
-- using exercise notation, instead of mathlib style
instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where

  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := by
    intro X Y h
    simp only at h
    simp only [id]
    simp only [id_comp, comp]
    simp only at h
    simp only [h]
    simp only [id_comp]
    simp only [comp]

  comp_id := by
    intro X Y h
    simp only at h
    simp only [comp_id, comp]
    simp only at h
    simp only [h]
    simp only [comp_id]
    simp only [comp]

  assoc := by
    intro X Y Z h
    simp only at h
    simp only [comp, comp]
    simp only at h
    simp only [h]
    simp only [comp, comp, comp]
    simp only at h
    simp only [h]
    simp only [comp, comp, comp, comp]

theorem Comma_category_functor {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    ∃ K : Type*, ∃ hK : Category K, ∃ F' : Functor K D, ∃ G' : Functor K E, ∃ hF' : F' = fun ⟨d, _, _⟩ => d, ∃ hG' : G' = fun ⟨_, e, _⟩ => e := by
  use Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)
  use instance : Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e))
  use fun ⟨d, e, h⟩ => ⟨d, e, h⟩
  use fun ⟨d, e, h⟩ => ⟨d, e, h⟩
  simp

