def Comma_category_id {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Comma_category D C E F G :=
    letI := F; letI := G; {
      F := @fun (⟨d, e, h⟩ : Comma_category D C E F G) => ⟨d, e, h.1, h.2⟩
      homF := @fun ⟨d, e, h⟩ ⟨d', e', h'⟩ =>
        letI := h.1; letI := h.2; letI := h'; {
          F := h.1.1
          homF := h.1.2
          map_id := h.2.1
          map_comp := h.2.2
