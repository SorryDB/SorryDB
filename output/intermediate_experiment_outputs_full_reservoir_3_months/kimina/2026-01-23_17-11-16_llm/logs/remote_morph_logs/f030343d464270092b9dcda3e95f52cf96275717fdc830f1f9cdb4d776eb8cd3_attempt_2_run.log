    (F : Functor D C) (G : Functor E C) : Type (max (max u_1 u_2) u_3) :=
    Σ (d : D) (e : E), (D.Hom (F.F d) (G.F e))

noncomputable instance : Category (Comma_category D C E F G) where
  Hom := fun ⟨d, e, h⟩ ⟨d', e', h'⟩ =>
    { val := (D.Hom d d' × E.Hom e e') // (F.homF (d' : D) (e : E) h.1) ≫ h' = h.1 ≫ (G.homF (d : D) (e' : E) h.2)
