have h1 : ∀ n, ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖ ≤ ‖(RCLike.ofReal ∘ NNReal.toReal ∘ f) x‖ := by
  intro n
  have h2 : ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖ ≤ ‖f x‖ := by
    have h3 := hfs x -- hfs x is Monotone (fun (n : ℕ) => ‖fs n x‖)
    have h4 : ‖f x‖ = ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fun (n : ℕ) => (f x : NNReal))) x‖ := by simp
    -- We know that for large n, ‖fs n x‖ approaches ‖f x‖
    -- We can use the fact that hlim implies that eventually ‖fs n x‖ ≤ ‖f x‖
    have h5 : ∀ᶠ (n : ℕ) in Filter.atTop, ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖ ≤ ‖f x‖ := by
      have h6 : Filter.Tendsto (fun n => ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖) Filter.atTop (nhds ‖f x‖) := by
        apply Filter.Tendsto.norm
        exact hlim x
      have h7 : ∀ᶠ (n : ℕ) in Filter.atTop, ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖ ≤ ‖f x‖ := by
        have h8 : Filter.Tendsto (fun n => ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖) Filter.atTop (nhds ‖f x‖) := h6
        have h9 : ∀ᶠ (n : ℕ) in Filter.atTop, ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖ ≤ ‖f x‖ := by
          simpa using Filter.eventually_le_of_tendsto h8
        exact h9
      exact h7
    -- Since the sequence is eventually bounded by ‖f x‖, it is bounded overall
    have h8 : Bounded (fun (n : ℕ) => ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖) := by
      use ‖f x‖
      simp only [Bounded, Set.mem_setOf_eq]
      intro n
      -- We know that eventually ‖fs n x‖ ≤ ‖f x‖, so overall it's bounded
      have h9 : ∃ N, ∀ n ≥ N, ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖ ≤ ‖f x‖ := by
        simpa using h5
      rcases h9 with ⟨N, hN⟩
      by_cases hN' : n ≥ N
      · exact hN n hN'
      · -- If n < N, we need to show it's still bounded
        -- Since the sequence is monotone, values before N are ≤ values at N
        have h10 : ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖ ≤ ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs N)) x‖ := by
          apply h3.monotone
          exact Nat.le_of_lt hN'
        have h11 : ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs N)) x‖ ≤ ‖f x‖ := by
          have h12 : ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs N)) x‖ ≤ ‖f x‖ := by
            have h13 : ∀ᶠ (n : ℕ) in Filter.atTop, ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖ ≤ ‖f x‖ := h5
            simpa using h13
          exact h12
        linarith
    -- Now use the boundedness to prove the Tendsto goal
    have h12 : Filter.Tendsto (fun (n : ℕ) => ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖) Filter.atTop (nhds ‖(RCLike.ofReal ∘ NNReal.toReal ∘ f) x‖) := by
      have h13 : Filter.Tendsto (fun (n : ℕ) => ‖(RCLike.ofReal ∘ NNReal.toReal ∘ ⇑(fs n)) x‖) Filter.atTop (nhds ‖f x‖) := by
        apply Filter.Tendsto.norm
        exact hlim x
      have h14 : ‖(RCLike.ofReal ∘ NNReal.toReal ∘ f) x‖ = ‖f x‖ := by simp
      rw [h14] at *
      exact h13
    -- The goal is just the norm of the limit, so this is what we need
    simpa using h12
exact h1
