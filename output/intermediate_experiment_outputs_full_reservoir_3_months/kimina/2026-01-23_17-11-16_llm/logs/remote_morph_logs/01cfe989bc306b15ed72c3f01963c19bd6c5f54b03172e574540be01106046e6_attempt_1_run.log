  --have p'_toReal_ne_zero : p'.toReal ≠ 0 := sorry

  have T_add : ∀ (f g : α → ℝ≥0) (x : α'), T (f + g) x = T f x + T g x := by
    intro f g x
    have h := T_subadd f g x (by simpa using hf) (by simpa using hg)
    simpa using h
  have T_smul : ∀ (a : ℝ≥0) (f : α → ℝ≥0) (x : α'), T (a • f) x = a • T f x := by
    intro a f x
