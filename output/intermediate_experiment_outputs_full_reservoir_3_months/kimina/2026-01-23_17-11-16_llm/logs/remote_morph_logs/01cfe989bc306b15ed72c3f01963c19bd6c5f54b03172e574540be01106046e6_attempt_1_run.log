        apply weakly_cont_T SimpleFunc.monotone_nnapprox hf' G
      _ ≤ Filter.limsup (fun n ↦ (c / p) * eLorentzNorm' (SimpleFunc.nnapprox f n) p 1 μ * ν G ^ p'⁻¹.toReal) Filter.atTop := by
        apply Filter.mono_limsup
