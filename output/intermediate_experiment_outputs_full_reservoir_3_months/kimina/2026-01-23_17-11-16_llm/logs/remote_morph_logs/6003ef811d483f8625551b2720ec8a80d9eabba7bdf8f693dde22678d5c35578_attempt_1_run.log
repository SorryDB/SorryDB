    (riemannZeta.zeroes_sum Set.univ (Set.Icc (I.T₀) V) (fun ρ ↦ 1 / ρ.im)) := by
  have h2 : Set.Ioo (0 : ℝ) V = Set.Ioo 0 (I.T₀) ∪ Set.Icc (I.T₀) V := by
    ext x
    simp
    constructor
    · -- Assume x ∈ (0, V)
      intro h
      rcases h with ⟨hx1, hx2⟩
      by_cases h3 : x < I.T₀
      · -- Case x < T₀
        left
        constructor <;> linarith
      · -- Case x ≥ T₀
        right
        constructor <;> linarith
    · -- Assume x ∈ (0, T₀) ∪ [T₀, V)
      rintro (h | h)
      · -- Case x ∈ (0, T₀)
        rcases h with ⟨hx1, hx2⟩
        constructor <;> linarith
      · -- Case x ∈ [T₀, V)
        rcases h with ⟨hx1, hx2⟩
        constructor <;> linarith
  rw [h2]
  rw [←riemannZeta.zeroes_sum_union]
  all_goals
    try { aesop }
    try { norm_num }
```

