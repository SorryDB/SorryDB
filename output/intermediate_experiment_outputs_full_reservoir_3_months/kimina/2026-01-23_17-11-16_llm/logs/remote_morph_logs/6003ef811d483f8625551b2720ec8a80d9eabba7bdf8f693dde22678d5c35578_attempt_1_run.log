open Real

namespace FKS

structure Inputs where
  b₁ : ℝ
  b₂ : ℝ
  b₃ : ℝ
  hRvM : riemannZeta.Riemann_vonMangoldt_bound b₁ b₂ b₃
  ZDB : zero_density_bound
  H₀ : ℝ
  hH₀ : riemannZeta.RH_up_to H₀
  R : ℝ
  hR : riemannZeta.classicalZeroFree R
  S₀ : ℝ
  T₀ : ℝ
  hS₀T₀ : riemannZeta.zeroes_sum Set.univ (Set.Ioo 0 T₀) (fun ρ ↦ 1 / ρ.im) < S₀

namespace bounds

def B₁ : ℝ → ℝ → ℝ := fun U V ↦ I.b₁ * (V - U)

def RvM : ℝ → ℝ := fun U ↦ I.b₁ * log U + I.b₂

def N' : ℝ → ℝ → ℝ := fun σ T ↦ (T - I.H₀) * log T / (2 * π * d) * log (1 + (KLN.CC₁ I.H₀ α d δ k H σ * (log (k * T)) ^ (2 * σ) * (log T) ^ (4 * (1 - σ)) * T ^ (8 / 3 * (1 - σ)) ) / (T - I.H₀) + KLN.CC₂ I.H₀ d η k H μ σ * (log T) ^ 2 / (2 * π * d))

theorem lemma_1 (I : Inputs) {U V : ℝ} (hU : U ≥ 0) (hV : V ≥ 0) : 
  riemannZeta.zeroes_sum Set.univ (Set.Ico U V) (fun ρ ↦ 1 / ρ.im) ≤ I.b₁ * (V - U) := by 
  sorry

theorem corollary_1 (I : Inputs) {V : ℝ} (hV : V ≥ I.T₀) : 
  riemannZeta.zeroes_sum Set.univ (Set.Ioo 0 V) (fun ρ ↦ 1 / ρ.im) < I.S₀ + I.b₁ * (V - I.T₀) := by
  have h3 : I.b₁ * (V - I.T₀) ≤ I.b₁ * (V - I.T₀) := by linarith
  linarith [hS₀T₀, lemma_1 I (show I.T₀ ≥ 0 by linarith) (show V ≥ 0 by linarith)]

noncomputable def default : FKS.Inputs := {
  b₁ := 0.1038
  b₂ := 0.2573
  b₃ := 9.3675
  hRvM := HSW.main_theorem
  ZDB := corollary_2_9
  H₀ := 3e12
  hH₀ := PT_theorem_1
  R := 5.5666305
  hR := MT_theorem_1
  S₀ := 39.5797647802
  T₀ := 30610046000
  hS₀T₀ := table_1_prop (by unfold table_1; aesop)
}

noncomputable def corollary_2_9 : zero_density_bound := {
