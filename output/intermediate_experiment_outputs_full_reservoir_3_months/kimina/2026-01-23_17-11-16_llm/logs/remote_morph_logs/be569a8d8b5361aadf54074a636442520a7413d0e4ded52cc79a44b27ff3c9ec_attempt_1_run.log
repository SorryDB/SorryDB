    (isHermitian_iff_isSymmetric.mp hB) (commute_euclideanLin hAB)

noncomputable def Matrix.sharedEigenvectorUnitary (hA : A.IsHermitian) (hB : B.IsHermitian)
    (hAB : Commute A B) : Matrix.unitaryGroup d 𝕜 :=
