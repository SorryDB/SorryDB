    rw [← inner_self_eq_zero (𝕜 := 𝕜)]
    have h_inner_zero : inner 𝕜 (x μ₁₂ : E) (x.coeAddMonoidHom _) = 0 := by
      simp [hx]
    rw [← h_inner_zero]
    simp only [DirectSum.coeAddMonoidHom_eq_dfinsuppSum, ZeroMemClass.coe_zero, implies_true,
