theorem sharedEigenvectorUnitary_mulVec (j : d) : (sharedEigenvectorUnitary hA hB hAB) *ᵥ
    Pi.single j 1 = WithLp.ofLp (sharedEigenbasis hA hB hAB j) := by
  simp_all only [mulVec_single, MulOpposite.op_one, one_smul]
