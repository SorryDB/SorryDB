  · -- Show that (U.val * A * Uᴴ) is diagonal
    simp [Matrix.isDiag_iff, U]
    funext i
    simp [Matrix.mul_apply, Matrix.dotProduct, U, Matrix.conjTranspose]
    <;> ring_nf <;> field_simp [Matrix.mul_apply, Matrix.dotProduct, U, Matrix.conjTranspose]
    <;> norm_num
  · -- Show that (U.val * B * Uᴴ) is diagonal
