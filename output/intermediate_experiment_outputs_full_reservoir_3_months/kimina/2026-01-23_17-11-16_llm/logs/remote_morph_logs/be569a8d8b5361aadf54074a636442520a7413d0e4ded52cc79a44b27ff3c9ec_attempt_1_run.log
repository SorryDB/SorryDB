  ∀ i j, A i j = conj (A j i)

noncomputable def Matrix.SharedEigenvectorUnitary (hA : A.IsHermitian) (hB : B.IsHermitian) (hAB : Commute A B) : Matrix.unitaryGroup d ℂ :=
  ⟨(EuclideanSpace.basisFun d ℂ).toBasis.toMatrix (Matrix.sharedEigenbasis hA hB hAB).toBasis,
    (EuclideanSpace.basisFun d ℂ).toMatrix_orthonormalBasis_mem_unitary (Matrix.sharedEigenbasis hA hB hAB)⟩

