  . exfalso;
    push_neg at h;
    obtain ⟨Γ, hΓ, h₁⟩ := h;
    have h₂ : (Γ.conj ⋏ φ) ➝ (Γ.conj ⋏ ψ) ∈ T.lindenbaum.Tactics.Tactics T := by
      apply T.lindenbaum.Tactics.Tactics T.mem_of_provable $ by
        apply iff_mem_CorsiDeducible.mp hφ
      apply af
    have : (Γ.conj ⋏ φ) ➝ ξ ∈ T.lindenbaum.Tactics.Tactics T := T.lindenbaum.Tactics.Tactics T.imp_closed axiomI $ T.lindenbaum.Tactics.Tactics T.andIR h₂ h₁;

     sorry;


lemma construction_omega_L_subset :
  letI U := construction_omega T hT
  L ⊆ U := by
  intro φ hφ;
