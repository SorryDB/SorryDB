  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hψ : ψ ∈ T.theory) : φ ⋎ ψ ∈ T.theory := by
  apply T.imp_closed (φ := ψ);
  . exact orIntroR;
  . assumption;

