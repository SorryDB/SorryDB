    have : (Γ.conj) → ξ ∈ T := T.mem_trans h₂ h₁;
    have : (Γ.conj) → ξ ∈ construction_omega T hT := by
      simp only [construction_omega, Set.mem_iUnion, Set.mem_setOf_eq, true_and];
      use (encode φ + 1); simp [construction]; split_ifs with h'; assumption; exfalso; apply h; assumption
    simp only [Set.mem_setOf_eq, true_and] at this; assumption

lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra hC;
