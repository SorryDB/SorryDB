        apply iff_mem_CorsiDeducible.mp hφ
      apply af
    have : (Γ.conj ⋏ (φ : Formula ℕ)) ∈ U := by sorry;
    sorry;




lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
