        apply abs_add_le
      linarith [h4, h5, h6, h7]
    have h4 : |δ| ≤ 1 := by
      cases min_cases 1 (ε / (3 * |x| + 1)) with
      | inl h =>
        rw [h]
        all_goals
          norm_num
      | inr h =>
        rw [h]
        have h5 : ε / (3 * |x| + 1) ≤ 1 := by
