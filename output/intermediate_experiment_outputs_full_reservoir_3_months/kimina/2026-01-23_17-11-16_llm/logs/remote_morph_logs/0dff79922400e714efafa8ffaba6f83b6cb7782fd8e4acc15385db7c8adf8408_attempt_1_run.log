      exact hε
      have h3 : 0 < (3 * |x| + 1 : ℝ) := by
        have h4 : 0 ≤ |x| := abs_nonneg x
        linarith
      linarith
    have h3 : 0 < min 1 (ε / (3 * |x| + 1)) := by
