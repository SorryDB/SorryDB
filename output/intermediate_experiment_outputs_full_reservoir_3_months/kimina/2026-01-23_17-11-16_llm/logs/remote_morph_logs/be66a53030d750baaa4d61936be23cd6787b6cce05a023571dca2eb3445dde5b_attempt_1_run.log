def verifyProof {n : ℕ} (i : Fin (2 ^ n)) (leaf : α) (root : α) (proof : List.Vector α n) :
    OptionT (OracleComp (spec α)) Unit := do
  let putative_root ← getPutativeRoot α i leaf proof
