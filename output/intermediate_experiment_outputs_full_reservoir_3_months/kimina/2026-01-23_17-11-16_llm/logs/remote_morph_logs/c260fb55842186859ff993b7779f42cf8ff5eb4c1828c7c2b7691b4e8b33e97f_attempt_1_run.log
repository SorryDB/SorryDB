    have h5 : IsLeastUpperBound {p x | p ‚ąą SetLike.coe D} (sSup {p x | p ‚ąą SetLike.coe D}) := by
      apply isLeastUpperBound_of_sSup_eq
      all_goals simp
    have h6 : IsLeastUpperBound {p x | p ‚ąą SetLike.coe D} ‚ä§ := by
      rw [h4] at *
      exact h5
    exact h6.le
  exact h3

