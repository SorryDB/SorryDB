lemma not_bot_mem (D : DirectSumDecomposition M) : ‚ä• ‚ąČ D := D.not_bot_mem'

lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ‚®Ü p ‚ąą D, p x = ‚ä§ := by
