class IsSolid (A : LightCondAb) : Prop where
  oneMinusShiftInducesIsomorphism : IsIsomorphism ((fun {X Y : Type u_1} [AddCommGroup X] [AddCommGroup Y] [Module R X] [Module R Y] [Condensed R X] [Condensed R Y] => (pre (oneMinusShift ℤ)).app) A)

