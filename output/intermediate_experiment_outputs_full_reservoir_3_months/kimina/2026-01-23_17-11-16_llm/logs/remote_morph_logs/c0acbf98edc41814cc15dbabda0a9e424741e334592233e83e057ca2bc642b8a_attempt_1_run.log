/-!
Restrict a component of finite symmetric difference to a set family over a finite type.
The resulting set family consists of sets of the form (A ∆ B) ∩ C, where C is the original set.
This operation is designed to be used with set families that have a finite symmetric difference structure.
-/
noncomputable def restrictFiniteSymmDiffComponent (𝓒 : Finset (Set α)) :
    Finset (Set α) :=
  Finset.image (fun A => A ∆ ⋂ B ∈ 𝓒, B) 𝓒

@[simp]
lemma card_restrictFiniteSymmDiffComponent (𝓒 : Finset (Set α)) :
    #(restrictFiniteSymmDiffComponent 𝓒) = #𝓒 := by
  classical
  rw [Finset.card_image_of_injOn]
  intro A hA B hB hAB
  simp [Finset.mem_image] at hAB
  obtain ⟨X, hX, hAB⟩ := hAB
  have h1 : A ∆ ⋂ B ∈ 𝓒, B = B ∆ ⋂ B ∈ 𝓒, B := by
    have h2 : A ∆ ⋂ B ∈ 𝓒, B = X := by
      simp [hX] at *
      tauto
    have h3 : B ∆ ⋂ B ∈ 𝓒, B = Y := by
      simp [hX] at *
      tauto
    rw [h2, h3]
    rw [symmDiff_comm]
  have h4 : A = B := by
    apply Subtype.val_inj.mp
    rw [show Subtype.val A = (A ∆ ⋂ B ∈ 𝓒, B) by rw [hX]; simp]
    rw [show Subtype.val B = (B ∆ ⋂ B ∈ 𝓒, B) by rw [hX]; simp]
    rw [h1]
    all_goals simp
  exact h4
