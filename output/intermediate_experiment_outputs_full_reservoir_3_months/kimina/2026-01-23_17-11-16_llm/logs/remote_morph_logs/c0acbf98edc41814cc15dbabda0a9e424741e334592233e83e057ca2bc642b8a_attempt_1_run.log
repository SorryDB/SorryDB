      apply Set.Subtype.val_injOn (Set.symmDiff_subset (A) (⋂ B ∈ 𝓒, B)) (Set.symmDiff_subset (B) (⋂ B ∈ 𝓒, B)) h2
    have h4 : (A ∆ (⋂ B ∈ 𝓒, B)) = (B ∆ (⋂ B ∈ 𝓒, B)) := by
      rw [show (symmDiff A (⋂ B ∈ 𝓒, B)) = A ∆ (⋂ B ∈ 𝓒, B) by simp [symmDiff]] at h3
      rw [show (symmDiff B (⋂ B ∈ 𝓒, B)) = B ∆ (⋂ B ∈ 𝓒, B) by simp [symmDiff]] at h3
      exact h3
    have h5 : (A ∩ C ∆ ⋂ B ∈ 𝓒, B) = (B ∩ C ∆ ⋂ B ∈ 𝓒, B) := by
      have h6 : (A ∩ C) ∆ (⋂ B ∈ 𝓒, B) = (B ∩ C) ∆ (⋂ B ∈ 𝓒, B) := by
