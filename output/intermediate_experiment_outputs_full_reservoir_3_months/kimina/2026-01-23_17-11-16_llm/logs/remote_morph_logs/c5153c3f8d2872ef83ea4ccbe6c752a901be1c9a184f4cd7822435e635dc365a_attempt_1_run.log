import Mathlib

open Finset

lemma in_list_idx {α} {l : List α} {x : α} (H : x ∈ l) :
    ∃ i : Fin (List.length l), l[i] = x := by
  induction l with
  | nil => contradiction
  | cons hd tl HR =>
    rw [List.mem_cons] at H
    cases H <;> rename_i H
    · subst x; apply Exists.intro ⟨0, by simpa⟩; rfl
    · obtain ⟨i, hi⟩ := HR H; exists ⟨i + 1, by simpa⟩

variable {α β} {n : Nat}

theorem vec_in_if_idx {v : Vector α n} {x : α} (hin : x ∈ v) :
     ∃ i : Fin n, v[i] = x := by
  apply in_list_idx
  simpa using hin

theorem Vector.mapIdx_eq_map {v : Vector α n} (f : α → β) :
    v.mapIdx (λ _ => f) = v.map f := by
  simp [mapIdx, map]

theorem idx_in_vec {v : Vector α n} {x : α} (hidx : ∃ i : Fin n, v[i] = x) :
     x ∈ v := by
  rcases hidx with ⟨i, hi⟩
  simp [hi]

theorem vec_set_concat_perm {v : Vector (List α) n} {idx : Fin n} {l : List α} {elt : α} :
    v.toList.flatten.Perm l →
    (v.set idx (v[idx] ++ [elt])).toList.flatten.Perm (l ++ [elt]) := by
  intro h
  simp [Set.mem_setOf_eq] at h ⊢
  all_goals try { tauto }
  all_goals try { 
    have h1 : (v.set (↑idx) (v[idx] ++ [elt])).toList.flatten = (v.toList ++ [[elt]]).flatten := by 
      simp [Set.mem_setOf_eq, List.flatten_append, List.append_singleton]
      <;> try { tauto }
    rw [h1]
    apply List.Perm.append_right
    exact h
  }
  all_goals try { 
    have h1 : (v.set (↑idx) (v[idx] ++ [elt])).toList.flatten = (v.toList ++ [[elt]]).flatten := by 
      simp [Set.mem_setOf_eq, List.flatten_append, List.append_singleton]
      <;> try { tauto }
    rw [h1]
    apply List.Perm.append_right
    exact h
  }
  all_goals try { 
    tauto
  }
