  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

noncomputable abbrev Distribution := 𝓓^{n}(Ω, ℝ) →L_c[ℝ] F

-- Notation for the space of distributions of order less than `n`. -/
@[expose] scoped[Distributions] notation "𝓓'^{" n "}(" Ω ", " F ")" => Distribution Ω F n

-- We denote `𝓓'(Ω, F)` the space of `F`-valued distributions on `Ω`. Note that using `𝓓'`
-- is a bit abusive since this is no longer a dual space unless `F = 𝕜`. -/
@[expose] scoped[Distributions] notation "𝓓'(" Ω ", " F ")" => Distribution Ω F ⊤

namespace Distributions

noncomputable def mapCLM [IsTopologicalAddGroup F] [ContinuousSMul ℝ F] [IsTopologicalAddGroup F']
    [ContinuousSMul ℝ F'] (A : F →L[ℝ] F') : Distribution Ω F →L[ℝ] Distribution Ω F' :=
  A.postcomp_uniformConvergenceCLM _

@[simp]
lemma mapCLM_apply [IsTopologicalAddGroup F] [ContinuousSMul ℝ F] [IsTopologicalAddGroup F']
    [ContinuousSMul ℝ F'] {A : F →L[ℝ] F'} {T : Distribution Ω F} {f : 𝓓(Ω, ℝ)} :
    mapCLM A T f = A (T f) := rfl

