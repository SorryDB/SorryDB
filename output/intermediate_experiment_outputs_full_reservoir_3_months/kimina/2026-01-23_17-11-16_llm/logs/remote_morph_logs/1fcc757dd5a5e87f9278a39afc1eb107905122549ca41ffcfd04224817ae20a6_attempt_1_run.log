def Indecomposable' (N : PersistenceSubmodule M) : Prop :=
  ∀ a b : PersistenceSubmodule M, a ≤ N → b ≤ N → a ⊓ b = ⊥ → a ⊔ b = N → a = ⊥ ∨ b = ⊥

section LatticeRefinements

