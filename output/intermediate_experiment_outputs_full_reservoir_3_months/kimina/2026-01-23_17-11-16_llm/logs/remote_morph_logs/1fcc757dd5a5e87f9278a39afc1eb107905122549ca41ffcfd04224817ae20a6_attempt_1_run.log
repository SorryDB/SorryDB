  rcases h2 with ⟨E, hE, hbE⟩
  have h3 : D ≤ E ∨ E ≤ D := by
    apply R.2.2.2
    all_goals
      try { tauto }
      try { 
        tauto 
      }
  cases h3 with
  | inl h_le_D_E =>
    have h4 : a ∈ E := by 
      have h5 : a ∈ D := haD
      have h6 : D ≤ E := h_le_D_E
      have h7 : a ∈ E := by 
        apply h6
        exact h5
      exact h7
    have h8 : a = ⊥ := by
      apply (R.2.2.1 E hE)
      all_goals
        try { tauto }
        try { 
          tauto 
        }
        try { 
          exact h4 
        }
        try { 
          exact hbE 
        }
        try { 
          exact h_le 
        }
    exact h8
  | inr h_le_E_D =>
    have h4 : b ∈ D := by 
      have h5 : b ∈ E := hbE
      have h6 : E ≤ D := h_le_E_D
      have h7 : b ∈ D := by 
