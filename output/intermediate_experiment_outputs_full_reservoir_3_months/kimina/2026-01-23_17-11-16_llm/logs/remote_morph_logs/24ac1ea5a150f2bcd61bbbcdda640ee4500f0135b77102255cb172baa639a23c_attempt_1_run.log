import Mathlib

open Real Set

/- Real numbers with the standard absolute value and the L∞ norm. -/
instance : RCLike ℝ := ⟨|·|, fun x => if x < 0 then -x else x, Real.isRCLike, abs⟩

/- The space of real numbers with the standard L1 norm. -/
instance : ENormedSpace ℝ := ⟨ℝ, fun x => |x|, by simp⟩

/- The space of non-negative real numbers with the standard L1 norm. -/
instance : ENormedSpace (NNReal) := ⟨NNReal, fun x => x, by simp⟩

/- The space of non-negative real numbers with the standard L∞ norm. -/
instance : ENormedSpace (NNReal) := ⟨NNReal, fun x => if x < 0 then 0 else x, by simp, abs⟩

/- The space of non-negative real numbers with the standard Lp norm. -/
instance : ENormedSpace (NNReal) := ⟨NNReal, fun x => x ^ (1 : ℝ), by simp, rpow⟩

/- The space of non-negative real numbers with the standard Lp norm. -/
instance : ENormedSpace (NNReal) := ⟨NNReal, fun x => x ^ (1 : ℝ) / x, by simp, div_rpow⟩

/- The space of non-negative real numbers with the standard Lp norm. -/
instance : ENormedSpace (NNReal) := ⟨NNReal, fun x => x ^ (1 : ℝ) * x, by simp, mul_rpow⟩

/- The space of non-negative real numbers with the standard Lp norm. -/
instance : ENormedSpace (NNReal) := ⟨NNReal, fun x => x ^ (1 : ℝ) + x, by simp, add_rpow⟩

/- The space of non-negative real numbers with the standard Lp norm. -/
instance : ENormedSpace (NNReal) := ⟨NNReal, fun x => x ^ (1 : ℝ) - x, by simp, sub_rpow⟩

