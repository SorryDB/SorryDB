theorem main (i : ι) (inst : UnitalFreeStateTheory ι) (ρ : MState (H i)) (ε : Prob)
    (hε : 0 < ε ∧ ε < 1) (σ : (n : ℕ) → ↑IsFree) (ε' : Prob)
