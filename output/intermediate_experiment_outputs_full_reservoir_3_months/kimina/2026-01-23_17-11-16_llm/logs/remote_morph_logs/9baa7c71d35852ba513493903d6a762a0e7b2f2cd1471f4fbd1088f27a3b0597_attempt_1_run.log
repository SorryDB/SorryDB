  have h5 : |g' 0 + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s| ≤ |g' 0| + |∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s| := by
    apply abs_add
```

Now we bound `|g' 0|` using `bound1`.

```tactics
  have h6 : |g' 0| ≤ ε * ∑ i, |nth_partial i f x| := by
    linarith [bound1]
```

Now we bound `|∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s|` using `bound2`.

```tactics
  have h7 : |∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by
    apply abs_le.mp
    apply intervalIntegral.abs_le
```

Now we combine the results.

```tactics
  have h8 : ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| ≤ (n^2 / 2) * ε^2 := by
    linarith [bound2]
```

Now we can conclude the proof.

```tactics
  linarith [h5, h6, h7, h8]
```

