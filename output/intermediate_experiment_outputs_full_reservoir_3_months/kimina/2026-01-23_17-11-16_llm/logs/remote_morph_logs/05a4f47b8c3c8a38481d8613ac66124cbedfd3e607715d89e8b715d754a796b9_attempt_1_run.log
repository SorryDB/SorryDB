namespace ProbabilityTheory

variable {ι Ω E : Type*} [LinearOrder ι] [TopologicalSpace ι]
  [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  {mΩ : MeasurableSpace Ω} {P : Measure Ω}
  {X Y : ι → Ω → E} {𝓕 : Filtration ι mΩ}

/-- A square integrable martingale is a martingale with cadlag paths and uniformly bounded
second moments. -/
structure IsSquareIntegrable (X : ι → Ω → E) (𝓕 : Filtration ι mΩ) (P : Measure Ω) : Prop where
  martingale : Martingale X 𝓕 P
  cadlag : ∀ ω, IsCadlag (X · ω)
  bounded : ⨆ i, eLpNorm (X i) 2 P < ∞

lemma IsSquareIntegrable.integrable_sq (hX : IsSquareIntegrable X 𝓕 P) (i : ι) :
    Integrable (fun ω ↦ ‖X i ω‖ ^ 2) P := by
  constructor
  · have hX_meas := (hX.martingale.adapted i).mono (𝓕.le i)
    fun_prop
  · have hX_bound : eLpNorm (X i) 2 P < ∞ := by
      calc eLpNorm (X i) 2 P
      _ ≤ ⨆ j, eLpNorm (X j) 2 P := le_iSup (fun j ↦ eLpNorm (X j) 2 P) i
      _ < ∞ := hX.bounded
    simpa [HasFiniteIntegral, eLpNorm_lt_top_iff_lintegral_rpow_enorm_lt_top] using hX_bound

lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine' ⟨hX.martingale.add hY.martingale, fun ω => ?_, ?_⟩
  · -- Show that the sum is cadlag
    intro ω
    have hXcad : IsCadlag (X · ω) := hX.cadlag ω
    have hYcad : IsCadlag (Y · ω) := hY.cadlag ω
    have hsum : IsCadlag (fun x => X x ω + Y x ω) := by
      apply IsCadlag.add
      exact hXcad
      exact hYcad
    exact hsum
  · -- Show that the sum is bounded in L^2
    have hXbounded : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded
    have hYbounded : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded
    have hsum_bounded : ⨆ i, eLpNorm (fun i ω ↦ X i ω + Y i ω) 2 P < ∞ := by
      have h1 : ∀ i, eLpNorm (fun i ω ↦ X i ω + Y i ω) 2 P ≤ 2 * (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
        intro i
        have h2 : eLpNorm (fun i ω ↦ X i ω + Y i ω) 2 P = eLpNorm (fun ω ↦ ‖X i ω + Y i ω‖ ^ 2) P := by
          simp [eLpNorm]
        have h3 : eLpNorm (X i) 2 P = eLpNorm (fun ω ↦ ‖X i ω‖ ^ 2) P := by
          simp [eLpNorm]
        have h4 : eLpNorm (Y i) 2 P = eLpNorm (fun ω ↦ ‖Y i ω‖ ^ 2) P := by
          simp [eLpNorm]
        have h5 : ‖X i ω + Y i ω‖ ^ 2 ≤ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) := by
          have h6 : ‖X i ω + Y i ω‖ ^ 2 ≤ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) := by
            have h7 : ‖X i ω + Y i ω‖ ^ 2 = ‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2 + 2 * ‖X i ω‖ * ‖Y i ω‖ := by
              simp [norm_add_sq]
            rw [h7]
            have h9 : 2 * ‖X i ω‖ * ‖Y i ω‖ ≤ ‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2 := by
              linarith [two_mul_le_add_sq ‖X i ω‖ ‖Y i ω‖]
            linarith
          linarith
        have h6 : eLpNorm (fun ω ↦ ‖X i ω + Y i ω‖ ^ 2) P ≤ eLpNorm (fun ω ↦ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2)) P := by
          apply eLpNorm_le_eLpNorm
          intro ω
          apply h5
        have h7 : eLpNorm (fun ω ↦ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2)) P = 2 * eLpNorm (fun ω ↦ ‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) P := by
          simp [eLpNorm_const_mul]
        have h8 : eLpNorm (fun ω ↦ ‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) P = eLpNorm (fun ω ↦ ‖X i ω‖ ^ 2) P + eLpNorm (fun ω ↦ ‖Y i ω‖ ^ 2) P := by
          rw [eLpNorm_add]
        rw [h2, h3, h4]
        rw [h6, h7, h8]
        all_goals simp
        all_goals linarith [show eLpNorm (fun (ω : Ω) ↦ ‖X i ω‖ ^ 2) P ≥ 0 by positivity, show eLpNorm (fun (ω : Ω) ↦ ‖Y i ω‖ ^ 2) P ≥ 0 by positivity]
      have h2 : ⨆ i, eLpNorm (fun i ω ↦ X i ω + Y i ω) 2 P ≤ ⨆ i, 2 * (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
