        have h4 : (‖X i ω‖ + ‖Y i ω‖) ^ 2 ≤ (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) + 2 * (‖X i ω‖ * ‖Y i ω‖) := by
          nlinarith [sq_nonneg (‖X i ω‖ - ‖Y i ω‖)]
        have h5 : (‖X i ω‖ + ‖Y i ω‖) ^ 2 ≤ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) := by
