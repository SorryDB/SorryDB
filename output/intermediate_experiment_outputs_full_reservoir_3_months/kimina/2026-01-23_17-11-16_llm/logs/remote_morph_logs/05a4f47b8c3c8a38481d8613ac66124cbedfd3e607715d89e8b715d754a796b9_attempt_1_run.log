                  have h11 : ‖X i ω + Y i ω‖ ^ 2 ≤ (‖X i ω‖ + ‖Y i ω‖) ^ 2 := by
                    nlinarith [h10]
                  nlinarith [sq_nonneg (‖X i ω‖ - ‖Y i ω‖)]
                nlinarith [sq_nonneg (‖X i ω‖ - ‖Y i ω‖)]
              nlinarith [sq_nonneg (‖X i ω‖ - ‖Y i ω‖)]
            nlinarith [sq_nonneg (‖X i ω‖ - ‖Y i ω‖)]
          nlinarith [sq_nonneg (‖X i ω‖ - ‖Y i ω‖)]
        have h6 : eLpNorm (fun i ω ↦ X i ω + Y i ω) 2 P = ⨆ ω, ‖(X i ω + Y i ω)‖ ^ 2 := by
          simp [eLpNorm_eq]
        have h7 : eLpNorm (X i) 2 P = ⨆ ω, ‖X i ω‖ ^ 2 := by
