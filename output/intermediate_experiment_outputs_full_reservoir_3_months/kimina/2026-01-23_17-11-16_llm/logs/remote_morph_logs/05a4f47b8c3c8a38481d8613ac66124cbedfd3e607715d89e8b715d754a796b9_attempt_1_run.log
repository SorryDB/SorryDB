            have h9 : ⨆ i, eLpNorm (X i) 2 P < ∞ := hXbounded
            have h10 : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hYbounded
            have h11 : ⨆ i, eLpNorm (X i) 2 P + ⨆ i, eLpNorm (Y i) 2 P < ∞ := by
