import BrownianMotion.Auxiliary.Martingale
import BrownianMotion.StochasticIntegral.ApproxSeq
import BrownianMotion.StochasticIntegral.Locally
import BrownianMotion.Auxiliary.Adapted
import BrownianMotion.StochasticIntegral.OptionalSampling
import Mathlib.Probability.Process.HittingTime

/-! # Square integrable martingales

-/

open MeasureTheory Filter Function TopologicalSpace
open scoped ENNReal

namespace ProbabilityTheory

variable {ι Ω E : Type*} [LinearOrder ι] [TopologicalSpace ι]
  [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  {mΩ : MeasurableSpace Ω} {P : Measure Ω}
  {X Y : ι → Ω → E} {𝓕 : Filtration ι mΩ}

/-- A square integrable martingale is a martingale with cadlag paths and uniformly bounded
second moments. -/
structure IsSquareIntegrable (X : ι → Ω → E) (𝓕 : Filtration ι mΩ) (P : Measure Ω) : Prop where
  martingale : Martingale X 𝓕 P
  cadlag : ∀ ω, IsCadlag (X · ω)
  bounded : ⨆ i, eLpNorm (X i) 2 P < ∞

lemma IsSquareIntegrable.integrable_sq (hX : IsSquareIntegrable X 𝓕 P) (i : ι) :
    Integrable (fun ω ↦ ‖X i ω‖ ^ 2) P := by
  constructor
  · have hX_meas := (hX.martingale.adapted i).mono (𝓕.le i)
    fun_prop
  · have hX_bound : eLpNorm (X i) 2 P < ∞ := by
      calc eLpNorm (X i) 2 P
      _ ≤ ⨆ j, eLpNorm (X j) 2 P := le_iSup (fun j ↦ eLpNorm (X j) 2 P) i
      _ < ∞ := hX.bounded
    simpa [HasFiniteIntegral, eLpNorm_lt_top_iff_lintegral_rpow_enorm_lt_top] using hX_bound

lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  have h1 : Martingale (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
    rw [Martingale]
    intro s t hst
    have h1 : (E (X t + Y t) | F s) = (E (X t) | F s) + (E (Y t) | F s) := by
      rw [Expectation.add]
    have h2 : (E (X t) | F s) = X s := hX.martingale (s) (t) hst
    have h3 : (E (Y t) | F s) = Y s := hY.martingale (s) (t) hst
    rw [h1, h2, h3]
    all_goals simp
  have h2 : ∀ ω, IsCadlag (fun i => (X i ω + Y i ω)) := by
    intro ω
    have hXω : IsCadlag (fun i => X i ω) := by
      simpa using hX.cadlag ω
    have hYω : IsCadlag (fun i => Y i ω) := by
      simpa using hY.cadlag ω
    have hsum : IsCadlag (fun i => X i ω + Y i ω) := by
      simpa using IsCadlag.add hXω hYω
    simpa using hsum
  have h3 : ⨆ i, eLpNorm (fun i => X i + Y i) 2 P < ∞ := by
    have hX_bounded : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded
    have hY_bounded : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded
    have h4 : ∀ i, eLpNorm (fun i => X i + Y i) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
      intro i
      have h5 : ‖(X i + Y i)‖ ^ 2 ≤ (‖X i‖ + ‖Y i‖) ^ 2 := by
        have h6 : ‖X i + Y i‖ ≤ ‖X i‖ + ‖Y i‖ := by
          apply norm_add_le
        have h7 : ‖X i + Y i‖ ^ 2 ≤ (‖X i‖ + ‖Y i‖) ^ 2 := by
          apply pow_le_pow_left
          all_goals
            try linarith [h6]
            try positivity
        linarith [h7]
      have h8 : eLpNorm (fun i => X i + Y i) 2 P = eLpNorm (fun ω ↦ ‖X i + Y i ω‖ ^ 2) P := by
        simp [eLpNorm]
      have h9 : eLpNorm (X i) 2 P = eLpNorm (fun ω ↦ ‖X i ω‖ ^ 2) P := by
        simp [eLpNorm]
      have h10 : eLpNorm (Y i) 2 P = eLpNorm (fun ω ↦ ‖Y i ω‖ ^ 2) P := by
        simp [eLpNorm]
      rw [h8, h9, h10]
      have h11 : ‖(X i + Y i)‖ ^ 2 ≤ (‖X i‖ + ‖Y i‖) ^ 2 := h5
      have h12 : eLpNorm (fun ω ↦ ‖X i + Y i ω‖ ^ 2) P ≤ eLpNorm (fun ω ↦ ‖X i ω‖ ^ 2) P + eLpNorm (fun ω ↦ ‖Y i ω‖ ^ 2) P := by
        have h13 : ‖(X i + Y i)‖ ^ 2 ≤ (‖X i‖ + ‖Y i‖) ^ 2 := h5
        have h14 : eLpNorm (fun ω ↦ ‖X i + Y i ω‖ ^ 2) P ≤ eLpNorm (fun ω ↦ (‖X i ω‖ + ‖Y i ω‖) ^ 2) P := by
          apply eLpNorm_le_eLpNorm
          all_goals
            try simp [h13]
            try linarith [h13]
        have h15 : eLpNorm (fun ω ↦ (‖X i ω‖ + ‖Y i ω‖) ^ 2) P ≤ eLpNorm (fun ω ↦ ‖X i ω‖ ^ 2) P + eLpNorm (fun ω ↦ ‖Y i ω‖ ^ 2) P := by
          have h16 : (fun ω ↦ (‖X i ω‖ + ‖Y i ω‖) ^ 2) = (fun ω ↦ ‖X i ω‖ ^ 2) + (fun ω ↦ ‖Y i ω‖ ^ 2) := by
            funext ω
            ring
          rw [h16]
          apply eLpNorm_add_le
        linarith [h14, h15]
      linarith [h12]
    have h5 : ∀ i, eLpNorm (fun i => X i + Y i) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
      intro i
      apply h4 i
    have h6 : ⨆ i, eLpNorm (fun i => X i + Y i) 2 P ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
      apply iSup_le_iSup
      intro i
      apply h5 i
    have h7 : ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) = ⨆ i, eLpNorm (X i) 2 P + ⨆ i, eLpNorm (Y i) 2 P := by
      rw [iSup_add]
    rw [h7] at h6
    linarith [h6, hX_bounded, hY_bounded]
  exact ⟨h1, h2, h3⟩
