import BrownianMotion.Auxiliary.Martingale
import BrownianMotion.StochasticIntegral.ApproxSeq
import BrownianMotion.StochasticIntegral.Locally
import BrownianMotion.Auxiliary.Adapted
import BrownianMotion.StochasticIntegral.OptionalSampling
import Mathlib.Probability.Process.HittingTime

/-! # Square integrable martingales

-/

open MeasureTheory Filter Function TopologicalSpace
open scoped ENNReal

namespace ProbabilityTheory

variable {ι Ω E : Type*} [LinearOrder ι] [TopologicalSpace ι]
  [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  {mΩ : MeasurableSpace Ω} {P : Measure Ω}
  {X Y : ι → Ω → E} {𝓕 : Filtration ι mΩ}

/-- A square integrable martingale is a martingale with cadlag paths and uniformly bounded
second moments. -/
structure IsSquareIntegrable (X : ι → Ω → E) (𝓕 : Filtration ι mΩ) (P : Measure Ω) : Prop where
  martingale : Martingale X 𝓕 P
  cadlag : ∀ ω, IsCadlag (X · ω)
  bounded : ⨆ i, eLpNorm (X i) 2 P < ∞

lemma IsSquareIntegrable.integrable_sq (hX : IsSquareIntegrable X 𝓕 P) (i : ι) :
    Integrable (fun ω ↦ ‖X i ω‖ ^ 2) P := by
  constructor
  · have hX_meas := (hX.martingale.adapted i).mono (𝓕.le i)
    fun_prop
  · have hX_bound : eLpNorm (X i) 2 P < ∞ := by
      calc eLpNorm (X i) 2 P
      _ ≤ ⨆ j, eLpNorm (X j) 2 P := le_iSup (fun j ↦ eLpNorm (X j) 2 P) i
      _ < ∞ := hX.bounded
    simpa [HasFiniteIntegral, eLpNorm_lt_top_iff_lintegral_rpow_enorm_lt_top] using hX_bound

lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · -- Show that the sum process is cadlag
    have h1 : IsCadlag (fun (t : ι) => X t ω) := hX.cadlag ω
    have h2 : IsCadlag (fun (t : ι) => Y t ω) := hY.cadlag ω
    have h3 : IsCadlag (fun (t : ι) => (X t ω) + (Y t ω)) := by
      apply IsCadlag.add
      exact h1
      exact h2
    simpa using h3
  · -- Show that the sum process is bounded in L^2
    have h3 : ∀ i, eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P < ∞ := by
      intro i
      have h4 : eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P < ∞ := by
        have h11 : Integrable (fun (ω : Ω) ↦ ‖X i ω + Y i ω‖ ^ 2) P := by
          have h12 : ∀ ω : Ω, ‖X i ω + Y i ω‖ ^ 2 ≤ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) := by
            intro ω
            have h10 : ‖X i ω + Y i ω‖ ≤ ‖X i ω‖ + ‖Y i ω‖ := by
              apply norm_add_le
            have h11 : ‖X i ω + Y i ω‖ ^ 2 ≤ (‖X i ω‖ + ‖Y i ω‖) ^ 2 := by
              apply pow_le_pow_left
              all_goals
                try { linarith [h10] }
                try { positivity }
            have h12 : (‖X i ω‖ +  ‖Y i ω‖) ^ 2 = ‖X i ω‖ ^ 2 + 2 * (‖X i ω‖ *  ‖Y i ω‖) + ‖Y i ω‖ ^ 2 := by
              ring
            have h13 : ‖X i ω‖ ^ 2 + 2 * (‖X i ω‖ *  ‖Y i ω‖) + ‖Y i ω‖ ^ 2 ≤ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) := by
              nlinarith [sq_nonneg (‖X i ω‖ -  ‖Y i ω‖)]
            linarith [h11, h12, h13]
          have h13 : Integrable (fun (ω : Ω) ↦ ‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) P := by
            apply Integrable.add
            · apply IsSquareIntegrable.integrable_sq hX i
            · apply IsSquareIntegrable.integrable_sq hY i
          have h14 : HasFiniteIntegral (fun (ω : Ω) ↦ ‖X i ω‖ ^ 2 +  ‖Y i ω‖ ^ 2) P := by
            simpa using h13
          have h15 : HasFiniteIntegral (fun (ω : Ω) ↦ 2 * (‖X i ω‖ ^ 2 +  ‖Y i ω‖ ^ 2)) P := by
            apply HasFiniteIntegral.mul_const
            exact h14
          have h16 : HasFiniteIntegral (fun (ω : Ω) ↦ ‖X i ω + Y i ω‖ ^ 2) P := by
            apply HasFiniteIntegral.of_nonneg_of_le (by
              intro ω
              positivity
            ) (by
              intro ω
              specialize h12 ω
              linarith
            )
            exact h15
          simpa using h16
        have h10 : eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P < ∞ := by
          simpa [eLpNorm_lt_top_iff_lintegral_rpow_enorm_lt_top] using h11
        exact h10
      exact h4
    have h4 : ⨆ i, eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P < ∞ := by
      have h5 : ∀ i : ι, eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P < ∞ := h3
      have h6 : ⨆ i : ι, eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P < ∞ := by
        apply iSup_lt_top
        intro i
