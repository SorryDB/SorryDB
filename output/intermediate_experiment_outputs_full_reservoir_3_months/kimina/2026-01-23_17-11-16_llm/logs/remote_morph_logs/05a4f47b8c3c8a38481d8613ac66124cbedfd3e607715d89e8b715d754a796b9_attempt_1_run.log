  have h1 : IsCadlag (fun (x : ι) => X x ω) := by
    apply hX.cadlag
  have h2 : IsCadlag (fun (x : ι) => Y x ω) := by
    apply hY.cadlag
  have h3 : IsCadlag (fun (x : ι) => X x ω + Y x ω) := by
    apply IsCadlag.add
    exact h1
    exact h2
  exact h3
