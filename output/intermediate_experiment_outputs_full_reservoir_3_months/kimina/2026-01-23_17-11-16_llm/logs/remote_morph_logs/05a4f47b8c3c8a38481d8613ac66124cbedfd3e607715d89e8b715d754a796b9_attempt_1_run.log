variable {ι Ω E : Type*} [LinearOrder ι] [TopologicalSpace ι]
  [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  {mΩ : MeasurableSpace Ω} {P : Measure Ω}
  {X Y : ι → Ω → E} {𝓕 : Filtration ι mΩ}

/-- A square integrable martingale is a martingale with cadlag paths and uniformly bounded
second moments. -/
structure IsSquareIntegrable (X : ι → Ω → E) (𝓕 : Filtration ι mΩ) (P : Measure Ω) : Prop where
  martingale : Martingale X 𝓕 P
  cadlag : ∀ ω, IsCadlag (X · ω)
  bounded : ⨆ i, eLpNorm (X i) 2 P < ∞

lemma IsSquareIntegrable.integrable_sq (hX : IsSquareIntegrable X 𝓕 P) (i : ι) :
    Integrable (fun ω ↦ ‖X i ω‖ ^ 2) P := by
  constructor
  · have hX_meas := (hX.martingale.adapted i).mono (𝓕.le i)
    fun_prop
  · have hX_bound : eLpNorm (X i) 2 P < ∞ := by
      calc eLpNorm (X i) 2 P
      _ ≤ ⨆ j, eLpNorm (X j) 2 P := le_iSup (fun j ↦ eLpNorm (X j) 2 P) i
      _ < ∞ := hX.bounded
    simpa [HasFiniteIntegral, eLpNorm_lt_top_iff_lintegral_rpow_enorm_lt_top] using hX_bound

lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · -- Show that the sum process is cadlag
    intro ω
    have hX_cadlag : IsCadlag (X · ω) := hX.cadlag ω
    have hY_cadlag : IsCadlag (Y · ω) := hY.cadlag ω
    have h_sum_cadlag : IsCadlag (fun i => X i ω + Y i ω) := by
      have h1 : IsRightContinuous (fun i => X i ω) := by
        simpa using hX_cadlag.isRightContinuous
      have h2 : IsRightContinuous (fun i => Y i ω) := by
        simpa using hY_cadlag.isRightContinuous
      have h3 : IsRightContinuous (fun i => X i ω + Y i ω) := by
        simpa using IsRightContinuous.add h1 h2
      have h4 : IsLimitPointCompact (fun i => X i ω) := by
        simpa using hX_cadlag.isLimitPointCompact
      have h5 : IsLimitPointCompact (fun i => Y i ω) := by
        simpa using hY_cadlag.isLimitPointCompact
      have h6 : IsLimitPointCompact (fun i => X i ω + Y i ω) := by
        simpa using IsLimitPointCompact.add h4 h5
      exact ⟨h3, h6⟩
    simpa using h_sum_cadlag
  · -- Show that the sum process is bounded
    have hX_bounded : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded
    have hY_bounded : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded
    have h_bounded : ⨆ i, eLpNorm (fun i_1 ω_1 ↦ X i_1 ω_1 + Y i_1 ω_1) i 2 P < ∞ := by
      have h1 : ∀ i, eLpNorm (fun i_1 ω_1 ↦ X i_1 ω_1 + Y i_1 ω_1) i 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
        intro i
        have h2 : ‖X i + Y i‖ ^ 2 ≤ (‖X i‖ + ‖Y i‖) ^ 2 := by
          have h3 : ‖X i + Y i‖ ≤ ‖X i‖ + ‖Y i‖ := by
            apply norm_add_le
          nlinarith [h3, sq_nonneg (‖X i + Y i‖ - (‖X i‖ + ‖Y i‖))]
        have h13 : eLpNorm (fun i_1 ω_1 ↦ X i_1 ω_1 + Y i_1 ω_1) i 2 P = Real.sqrt (‖X i + Y i‖ ^ 2) := by
          simp [eLpNorm, Set.mem_univ]
          <;> try { norm_num }
          <;> try { tauto }
        have h14 : eLpNorm (X i) 2 P = Real.sqrt (‖X i‖ ^ 2) := by
          simp [eLpNorm, Set.mem_univ]
          <;> try { norm_num }
          <;> try { tauto }
        have h15 : Real.sqrt (‖X i + Y i‖ ^ 2) ≤ Real.sqrt ((‖X i‖ + ‖Y i‖) ^ 2) := Real.sqrt_le_sqrt (by linarith [h2])
        have h16 : Real.sqrt ((‖X i‖ +  Y i‖) ^ 2) = ‖X i‖ +  Y i‖ := by
          rw [Real.sqrt_sq (show ‖X i‖ +  Y i‖ ≥ 0 by positivity)]
        have h17 : ‖X i‖ = eLpNorm (X i) 2 P := by
          simp [eLpNorm, Set.mem_univ]
          <;> try { norm_num }
          <;> try { tauto }
        have h18 :  Y i‖ = eLpNorm (Y i) 2 P := by
          simp [eLpNorm, Set.mem_univ]
          <;> try { norm_num }
          <;> try { tauto }
        nlinarith [h13, h14, h15, h16, h17, h18]
      have h2 : ⨆ i, eLpNorm (fun i_1 ω_1 ↦ X i_1 ω_1 + Y i_1 ω_1) i 2 P ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
        apply iSup_le_iSup
        intro i
        exact h1 i
      have h3 : ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) = ⨆ i, eLpNorm (X i) 2 P + ⨆ i, eLpNorm (Y i) 2 P := by
        rw [iSup_add]
      rw [h3] at h2
      have h4 : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX_bounded
      have h5 : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY_bounded
      have h6 : ⨆ i, eLpNorm (X i) 2 P + ⨆ i, eLpNorm (Y i) 2 P < ∞ := by
        linarith
      linarith
    simpa using h_bounded
