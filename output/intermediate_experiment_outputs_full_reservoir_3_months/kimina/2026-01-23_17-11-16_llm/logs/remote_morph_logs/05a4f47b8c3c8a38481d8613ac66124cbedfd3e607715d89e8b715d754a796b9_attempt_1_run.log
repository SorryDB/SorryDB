        have h6 : (‖X i ω‖ + ‖Y i ω‖) ^ 2 ≤ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) := by
          nlinarith [sq_nonneg (‖X i ω‖ - ‖Y i ω‖)]
        have h7 : (‖(X i ω + Y i ω)‖) ^ 2 ≤ 2 * (‖X i ω‖ ^ 2 + ‖Y i ω‖ ^ 2) := by
