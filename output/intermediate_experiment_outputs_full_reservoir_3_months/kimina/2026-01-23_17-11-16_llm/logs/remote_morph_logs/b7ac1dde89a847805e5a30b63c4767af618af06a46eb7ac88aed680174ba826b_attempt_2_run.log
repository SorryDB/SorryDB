example (l1 l2 : List Nat) (elt : Nat) (h : Nat) (h1 : h ≤ l1.length) :
    (l1 ++ l2).insertIdx h elt = (l1.insertIdx h elt) ++ l2
  := by 
  cases l1 with
  | nil => 
    -- l1 is empty, so l1.length = 0
    -- h1 is h ≤ 0, which means h = 0
    simp at h1
    -- h1 is now h = 0
    rw [h1]
    -- need to prove (l2).insertIdx 0 elt = (l2).insertIdx 0 elt ++ l2
    -- which is false
    simp [List.insertIdx]
    <;> try { tauto }
    <;> try { omega }
  | cons x xs => 
    -- l1 is non-empty
    -- we need to prove (x :: xs ++ l2).insertIdx h elt = ((x :: xs).insertIdx h elt) ++ l2
    -- with h1 : h ≤ (x :: xs).length
    simp [List.length_cons]
    -- now we need to prove (x :: xs ++ l2).insertIdx h elt = ((x :: xs).insertIdx h elt) ++ l2
    -- with h1 : h ≤ Nat.succ (List.length xs)
    -- we can proceed by induction
    induction xs with
    | nil => 
      -- l1 is x
      -- need to prove (x :: l2).insertIdx h elt = ((x).insertIdx h elt) ++ l2
      -- with h1 : h ≤ Nat.succ 0 = 1
      cases h with
      | zero => 
        simp [List.insertIdx]
        <;> try { tauto }
        <;> try { omega }
      | succ h => 
        -- h is at least 1
        -- need to prove (x :: l2).insertIdx (h+1) elt = ((x).insertIdx (h+1) elt) ++ l2
        -- but h1 is h ≤ 1, so h+1 > 1
        -- so this case is impossible
        simp at h1
        omega
    | succ xs ih => 
      -- l1 is x :: xs
      -- need to prove (x :: xs ++ l2).insertIdx h elt = ((x :: xs).insertIdx h elt) ++ l2
      -- with h1 : h ≤ Nat.succ (List.length xs) + 1
      -- we can use the induction hypothesis
      simp [List.insertIdx]
      <;> try { tauto }
      <;> try { omega }
