      let newLeaf ← query (spec := spec α) ⟨leaf, proof.get (Fin.last n)⟩
      getPutativeRoot i' newLeaf (proof.drop 1)
    else
      -- `i` is a right child
      let newLeaf ← query (spec := spec α) ⟨proof.get (Fin.last n), leaf⟩
      getPutativeRoot i' newLeaf (proof.drop 1)

