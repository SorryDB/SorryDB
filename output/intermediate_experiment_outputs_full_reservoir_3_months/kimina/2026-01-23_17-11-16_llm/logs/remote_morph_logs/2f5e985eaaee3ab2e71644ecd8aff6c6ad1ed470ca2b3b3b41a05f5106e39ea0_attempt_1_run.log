      have hfx : f x ∈ f '' (f ⁻¹' h) := by
        simpa using hx
      have hfx2 : f x ∈ f '' (f ⁻¹' h) := by
        rw [h_eq] at *
        exact hfx
      rcases hfx2 with ⟨y, hy, hfy⟩
      have hy_eq : y = x := by
        apply h_inj
        all_goals
          try tauto
          try assumption
      rw [hy_eq] at hy
      exact hy
    have h2 : x ∈ (f '' (f ⁻¹' h)) → x ∈ (f '' (f ⁻¹' h)) := by
      intro hx
      have hfx : f x ∈ f '' (f ⁻¹' h) := by
        simpa using hx
      have hfx2 : f x ∈ f '' (f ⁻¹' h) := by
        rw [←h_eq]
        exact hfx
      rcases hfx2 with ⟨y, hy, hfy⟩
      have hy_eq : y = x := by
        apply h_inj
        all_goals
          try tauto
          try assumption
      rw [hy_eq] at hy
      exact hy
    simp [h1, h2]
  · -- Show surjectivity
    intro h
    use {a : U | f a ∈ h}
    ext y
    simp [Set.mem_image, Set.mem_setOf_eq]
    constructor
    · -- Assume y ∈ f '' {a : U | f a ∈ h}, prove y ∈ h
      rintro ⟨x, hx, hfx⟩
      have h1 : f x ∈ h := by
        simpa using hx
      rw [hfx] at h1
      exact h1
    · -- Assume y ∈ h, prove y ∈ f '' {a : U | f a ∈ h}
      intro hy
      use g y
      constructor
      · -- Show g y ∈ {a : U | f a ∈ h}
        have h1 : f (g y) ∈ h := by
          have h2 : f (g y) = y := by
            simpa using congr_fun hf y
          rw [h2]
          exact hy
        simpa using h1
      · -- Show f (g y) = y
        have h2 : f (g y) = y := by
          simpa using congr_fun hf y
        exact h2
