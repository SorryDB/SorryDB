theorem Exercise_8_1_5_2 {U V : Type} {A : Set U} {B : Set V}
    (h : A ∼ B) : 𝒫 A ∼ 𝒫 B := by
  rcases h with ⟨f, g, hf, hg⟩
  use fun S => f '' S
  constructor
  · -- Show injectivity
    intro h_eq
    ext x
    simp [Set.mem_image, Set.mem_setOf_eq] at h_eq ⊢
    have h_inj : ∀ {x y : U}, f x = f y → x = y := by
      intro h_eq'
      have h_eq'' : g (f x) = g (f y) := by
        rw [h_eq']
      have h1 : g (f x) = x := by
        simpa using congr_fun hg x
      have h2 : g (f y) = y := by
        simpa using congr_fun hg y
      rw [h1] at h_eq''
      rw [h2] at h_eq''
      linarith
    have h1 : x ∈ (f '' (f ⁻¹' h)) → x ∈ (f '' (f ⁻¹' h)) := by
