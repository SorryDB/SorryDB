def mkPairs : List a ŌåÆ List (a ├Ś a)
  | []           => []
  | [x]          => [(x, x)]
  | x :: y :: xs =>
    if x Ōēż y then
     (x, y) :: mkPairs xs
    else
     (y, x) :: mkPairs xs


