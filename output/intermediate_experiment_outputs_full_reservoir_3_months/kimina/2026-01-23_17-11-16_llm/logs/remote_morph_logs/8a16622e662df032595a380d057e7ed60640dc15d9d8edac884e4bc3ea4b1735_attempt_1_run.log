/- `qsortŌéü` or `qsort` ? -/
def medians : List a ŌåÆ List a :=
  let middle (xs : List a) := xs[((xs.length + 1) / 2) - 1]!
  List.map (middle Ōłś qsortŌéü) Ōłś group 5


/- `selectŌéĆ` or `select` ? -/
def pivot : List a ŌåÆ a
  | [x] => x
  | xs  =>
    let median xs := selectŌéĆ ((xs.length + 1) / 2) xs
    median (medians xs)


partial def qsort : List a ŌåÆ List a
  | [] => []
  | xs =>
    let p := partition3 (pivot xs) xs
    qsort p.1 ++ p.2.1 ++ qsort p.2.2


