```tactics
def foldr1ŌéĆ (f : a ŌåÆ a ŌåÆ a) (xs : List a) (h : xs ŌēĀ []) : a
  :=
  if hŌéü : xs.length = 1 then
    xs.head (by simp [h])
  else
    let b :: bs := xs
    f b (foldr1ŌéĆ f bs (by
      intro hŌéé; apply hŌéü ; rw [hŌéé]; simp))

def foldr1 (f : a ŌåÆ a ŌåÆ a) : List a ŌåÆ a
  | []    => default
  | [x]   => x
  | x::xs => f x (foldr1 f xs)

def foldl1 (f : a ŌåÆ a ŌåÆ a) : List a ŌåÆ a
  | []    => default
  | x::xs => xs.foldl f x

def minimum : List a ŌåÆ a :=
  foldr1 min

def maximum : List a ŌåÆ a :=
  foldr1 max

def minmaxŌéĆ : List a ŌåÆ (a ├Ś a)
  | []      => default
  | x :: xs =>
    let op x q := (min x q.1, max x q.2)
    xs.foldr op (x,x)

def minmaxŌéü : List a ŌåÆ (a ├Ś a)
  | []      => default
  | x :: xs =>
    let op x q :=
      if      x < q.1 then (x, q.2)
      else if x > q.2 then (q.1, x)
      else (q.1, q.2)
    xs.foldr op (x,x)

def minmaxŌéé : List a ŌåÆ (a ├Ś a)
  | []      => default
  | x :: xs =>
    if      hŌéü : xs.length = 0 then (x, x)
    else if hŌéé : xs.length = 1 then
     have hŌéā : xs ŌēĀ [] := by
      intro h; apply hŌéü
      apply List.length_eq_zero_iff.mpr; assumption
     if x Ōēż xs.head hŌéā then (x, xs.head hŌéā) else (xs.head hŌéā, x)
    else
     let p := halve xs
     have : (halve xs).fst.length < xs.length := by
      simp [length_halve_fst]; omega
     have : (halve xs).snd.length < xs.length := by
      simp [length_halve_snd]; omega
     let q := minmaxŌéé p.1
     let r := minmaxŌéé p.2
     (min q.1 r.1, max q.2 r.2)
termination_by xs => xs.length


def mkPairs : List a ŌåÆ List (a ├Ś a)
  | []           => []
  | [x]          => [(x, x)]
  | x :: y :: xs =>
    if x Ōēż y then
     (x, y) :: mkPairs xs
    else
     (y, x) :: mkPairs xs


def minmax (xs : List a) : (a ├Ś a) :=
  let op p q := (min p.1 q.1, max p.2 q.2)
  (unwrap Ōłś until' single (pairWith op) Ōłś mkPairs) xs
    |>.getD default
```

Now we define the selection and related functions:

```tactics
-- # Section 6.2: selection from one set

/-
#check let xs := [1,2,3];
 xs.get (Fin.mk 2 (by simp [List.length]) : Fin xs.length)
-/

def selectŌéĆ (k : Nat) (xs : List a) : a :=
 (qsortŌéü xs)[k - 1]!

def median (xs : List a) : a :=
  let k := (xs.length + 1) / 2
  selectŌéĆ k xs


def group (n : Nat) (xs : List a) : List (List a) :=
  if      hŌéü : n = 0   then []
  else if hŌéé : xs = [] then []
  else
   let p := xs.splitAt n
   have : xs.length - n < xs.length := by
    induction xs with
    | nil => simp at *
    | cons b bs ih =>
      simp ; omega
   p.1 :: (group n p.2)
 termination_by xs.length
```

