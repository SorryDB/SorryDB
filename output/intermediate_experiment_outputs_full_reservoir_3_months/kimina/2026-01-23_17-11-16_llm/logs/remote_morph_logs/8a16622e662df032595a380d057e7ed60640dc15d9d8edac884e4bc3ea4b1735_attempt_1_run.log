-- # Section 6.2: selection from one set

/-
#check let xs := [1,2,3];
 xs.get (Fin.mk 2 (by simp [List.length]) : Fin xs.length)
-/

def selectŌéĆ (k : Nat) (xs : List a) : a :=
 (qsortŌéü xs)[k - 1]!

def median (xs : List a) : a :=
  let k := (xs.length + 1) / 2
  selectŌéĆ k xs


def group (n : Nat) (xs : List a) : List (List a) :=
  if      hŌéü : n = 0   then []
  else if hŌéé : xs = [] then []
  else
   let p := xs.splitAt n
   have : xs.length - n < xs.length := by
    induction xs with
    | nil => simp at *
    | cons b bs ih =>
      simp ; omega
   p.1 :: (group n p.2)
 termination_by xs.length

