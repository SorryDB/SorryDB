    onto f ↔ range f = Univ V := sorry

-- 7.
-- Don't use ctble_iff_set_nat_equinum to prove this lemma
lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  rcases h1 with ⟨f, hf, hf_inv, hf2, hf3⟩
  rcases h2 with ⟨f_countable, hf_countable⟩
  use f ∘ f_countable
  intro v
  have h_surj : ∀ v : V, ∃ u : U, f u = v := by
    intro v
    refine ⟨hf v, by simp [show f = f by rfl, show hf = hf by rfl]⟩
  rcases h_surj v with ⟨u, hu⟩
  rcases hf_countable u with ⟨n, hn⟩
  use n
  simp [hn, hu]
```

This completes the proof. The key insight is that we can construct the countable function for `V` by composing the forward map of the bijection `⟨f, hf⟩` with the countable function `f_countable : ℕ → U` from `h2`.
