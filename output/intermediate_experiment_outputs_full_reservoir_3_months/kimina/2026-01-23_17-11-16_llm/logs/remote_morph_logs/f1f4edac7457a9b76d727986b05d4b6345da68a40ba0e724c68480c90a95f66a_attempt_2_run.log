-- 3.
lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := sorry

-- 4.
lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := sorry

-- 5.
example {U V : Type} (f : U → V) : range f = Ran (graph f) := sorry

-- 6.
lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := sorry

-- 7.
-- Don't use ctble_iff_set_nat_equinum to prove this lemma
lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by 
  obtain ⟨f, g, hfg, hgf⟩ := h1
  rcases h2 with ⟨h, h_inj⟩
  use h ∘ g
  all_goals
    intro v₁ v₂ h_eq
    have h1 : h (g v₁) = h (g v₂) := by
      simpa using h_eq
    have h2 : g v₁ = g v₂ := by
      apply h_inj
      all_goals
        simpa using h1
    have h_inj_g : Function.Injective g := by
      intro v₁ v₂ h_eq
      have h3 : f (g v₁) = v₁ := by
        have h4 : f ∘ g = id := hfg
        simpa using congr_fun h4 v₁
      have h4 : f (g v₂) = v₂ := by
        have h5 : f ∘ g = id := hfg
        simpa using congr_fun h5 v₂
      have h5 : f (g v₁) = f (g v₂) := by
        rw [h_eq]
      rw [h3] at h5
      rw [h4] at h5
      all_goals
        tauto
    exact h_inj_g h2
