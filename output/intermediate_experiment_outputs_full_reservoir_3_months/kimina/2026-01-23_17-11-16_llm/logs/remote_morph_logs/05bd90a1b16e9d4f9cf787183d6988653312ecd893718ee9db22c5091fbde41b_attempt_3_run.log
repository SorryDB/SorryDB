      ⟨n.1 + 1, by simp only [Nat.add_lt_add_iff_right, Fin.is_lt] ⟩

    def fin_range (sz : Nat) : List (Fin sz) :=
      match sz with
      | 0 => []
      | sz' + 1 => ⟨0, Nat.zero_lt_succ _⟩ :: (fin_range sz').map lift_fin

    def fin_range' (sz : Nat) : List (Fin sz) :=
