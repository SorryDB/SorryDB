      simp only [neg_mul, neg_le_neg_iff]
      apply mul_le_mul_of_nonneg_left ?_ (by positivity)
      simp only [neg_smul, neg_le_neg_iff]
      apply mul_le_mul_of_nonneg_left ?_ (by positivity)
      exact hR1R2
    · apply Matrix.pos_def_of_isUnit
      simp only [neg_smul, neg_le_neg_iff]
      apply Real.exp_pos
      apply mul_nonneg (by positivity) (by positivity)
