    -- so that the 0 eigenvalues becomes irrelevant. This is the version we state and prove,
    -- then.
    have hE1leq ε2 (n : ℕ) (hε2 : 0 < ε2) : (1/n : ℝ) • (E1 ε2 n).toMat * ((ℰ n (ρ⊗^S[n])).M.log.toMat - (σ'' ρ ε m σ n).M.log.toMat) ≤ ((R1 ρ ε).toReal + ε2) • (E1 ε2 n).toMat := by
      refine rexp_mul_smul_proj_lt_mul_sub_le_mul_sub ?_ ?_ ?_ ?_ ?_
      · positivity
      · positivity
      · positivity
      · positivity
      · exact pinching_commutes (ρ⊗^S[n]) (σ'' ρ ε m σ n)
      · exact hσ'' ε2 n
      · simp [add_zero, neg_smul, neg_add, sub_neg_eq_add, mul_neg, neg_mul]
        all_goals try { norm_num }
        all_goals try { ring }
        all_goals try { norm_num }
        all_goals try { ring }
        all_goals try { norm_num }
