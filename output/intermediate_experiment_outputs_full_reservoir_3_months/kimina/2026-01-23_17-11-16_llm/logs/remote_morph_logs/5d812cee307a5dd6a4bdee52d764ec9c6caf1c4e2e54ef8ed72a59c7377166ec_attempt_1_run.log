theorem optimalHypothesisRateConvergence {ι : Sort u_1} [inst : UnitalFreeStateTheory ι] {i : ι} {ρ : MState (H i)} {σ : (n : ℕ) → ↑IsFree} {ε ε' : Prob} {hε'₁ : 0 < ε'} {hε'₂ : ε' < ε} {hε : ε < 1} {hR1R2 : @SteinsLemma.R1✝ ι inst✝ i ρ ε < @SteinsLemma.R2✝ ι inst✝ i ρ σ} {hR1 : @SteinsLemma.R1✝ ι inst✝ i ρ ε ≠ ⊤} {hR2 : @SteinsLemma.R2✝ ι inst✝ i ρ σ ≠ ⊤} {hε₀✝ : 0 < @SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε'} {m : ℕ} {hm : m ≥ 1} (hliminf_le : Filter.liminf (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) ε (@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε))) (hlimsup_le : ∀ (ε1 : Prob), 0 < ↑ε1 ∧ ↑ε1 < 1 → Filter.limsup (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) (1 - ε1) (@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ⟨@SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε', ⋯⟩)) : ∃ C, ∀ᶠ (n : ℕ) in Filter.atTop, (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) ε (@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).negLog / ↑n ≤ C := by
