  let P3 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n =>
    (Real.exp (↑n * (ENNReal.toReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ε₀ + ε2)) •
          ↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).proj_le
      ↑((ℰ n) (statePow ρ n))
    -- Ensure P1 ≤ P2
  have hP1leP2 : ∀ (ε2 : ℝ) (n : ℕ), P1 ε2 n ≤ P2 ε2 n := by
    intro ε2 n
    simp only [P1, P2]
    apply proj_le_proj
    · simp only [neg_smul, neg_le_neg_iff]
