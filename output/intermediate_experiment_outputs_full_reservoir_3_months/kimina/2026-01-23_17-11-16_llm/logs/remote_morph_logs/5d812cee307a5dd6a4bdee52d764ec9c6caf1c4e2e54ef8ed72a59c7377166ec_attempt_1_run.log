  let E1 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => P1 ε2 n
  let E2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => P2 ε2 n - P1 ε2 n
  let E3 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => 1 - P1 ε2 n - P2 ε2 n
