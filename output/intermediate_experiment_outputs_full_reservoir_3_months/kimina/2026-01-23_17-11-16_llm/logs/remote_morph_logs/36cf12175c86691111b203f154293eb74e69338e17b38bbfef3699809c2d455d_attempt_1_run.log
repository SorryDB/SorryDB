import Mathlib

open ProbabilityTheory

lemma indepFun_rewardByCount_of_ne [StandardBorelSpace α] [Nonempty α] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) {a b : α} (hab : a ≠ b) :
    IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) (P.prod (Bandit.streamMeasure ν)) := by
  rw [IndepFun]
  intro s t
  have h1 : ∀ (n : ℕ), Measurable (fun (ω : Ω) ↦ A n ω) := by
    intro n
    apply h.measurable_A n
  have h2 : ∀ (n : ℕ), Measurable (fun (ω : Ω) ↦ R n ω) := by
    intro n
    apply h.measurable_R n
  have h4 : ∀ (s t : ℕ), Disjoint {ω | rewardByCount A R a s ω ≠ 0} {ω | rewardByCount A R b t ω ≠ 0} := by
    intro s t
    by_contra h
    push_neg at h
    rcases h with ⟨ω, h1, h2⟩
    have h1' : ∀ (k : ℕ), k < s → A k ω = a := by
      intro k hk
      have hne : rewardByCount A R a s ω ≠ 0 := h1
      simp [rewardByCount] at hne ⊢
      all_goals
        try { tauto }
        try { aesop }
    have h2' : ∀ (k : ℕ), k < t → A k ω = b := by
      intro k hk
      have hne : rewardByCount A R b t ω ≠ 0 := h2
      simp [rewardByCount] at hne ⊢
      all_goals
        try { tauto }
        try { aesop }
    by_cases hs : s = 0
    · -- If s = 0, then the condition is trivially true
      rw [hs] at h1
      simp [rewardByCount] at h1
    by_cases ht : t = 0
    · -- If t = 0, then the condition is trivially true
      rw [ht] at h2
      simp [rewardByCount] at h2
    · -- s > 0 and t > 0
      have hs' : s > 0 := by omega
      have ht' : t > 0 := by omega
      have h3 : A 0 ω = a := by
        apply h1' 0
        omega
      have h4 : A 0 ω = b := by
        apply h2' 0
        omega
      have h5 : a = b := by
        linarith [h3, h4]
      contradiction
  have h5 : ∀ (s t : ℕ), Measure.map (fun ω s_1 ↦ rewardByCount A R a s_1 ω) (P.prod (Bandit.streamMeasure ν)) {ω | rewardByCount A R a s ω ≠ 0} ⊥ Measure.map (fun ω s_1 ↦ rewardByCount A R b s_1 ω) (P.prod (Bandit.streamMeasure ν)) {ω | rewardByCount A R b t ω ≠ 0} := by
    intro s t
    have hdisj : Disjoint {ω | rewardByCount A R a s ω ≠ 0} {ω | rewardByCount A R b t ω ≠ 0} := h4 s t
    simp [hdisj]
  simpa using h5 s t
