protected lemma _root_.IsNIPWith.restrictFiniteSymmDiffComponent
    (h𝓒 : IsNIPWith d (𝓒 : Set (Set α))) :
    IsNIPWith d (restrictFiniteSymmDiffComponent 𝓒 : Set (Set ↑((⋃ A ∈ 𝓒, A) \ ⋂ A ∈ 𝓒, A))) :=
  sorry

private lemma _root_.IsNIPWith.card_hypercubeEdgeFinset_le_of_finite [Finite α]
    (h𝓕 : IsNIPWith d (𝓕 : Set (Set α))) : #(hypercubeEdgeFinset 𝓕) ≤ d * #𝓕 := by
  have h1 : IsNIPWith d (↑𝓕 : Set (Set α)) := h𝓕
  have h2 : (↑(hypercubeEdgeFinset 𝓕) : Set (Set α × Set α)) = Finset.image (fun p : Set α × Set α ↦ p)
      (Finset.filter (fun p : Set α × Set α ↦ (p.1 ∆ p.2).ncard = 1) (Finset.product (Finset.univ : Finset (Set α)) (Finset.univ : Finset (Set α)))) := by
    ext ⟨A, B⟩
    simp [prodMk_mem_hypercubeEdgeFinset]
    <;> aesop
  rw [h2]
  have h3 : (Finset.image (fun p : Set α × Set α ↦ p) (Finset.filter (fun p : Set α × Set α ↦ (p.1 ∆ p.2).ncard = 1) (Finset.product (Finset.univ : Finset (Set α)) (Finset.univ : Finset (Set α))))) = Finset.filter (fun p : Set α × Set α ↦ (p.1 ∆ p.2).ncard = 1) (Finset.product (Finset.univ : Finset (Set α)) (Finset.univ : Finset (Set α))) := by
    ext ⟨A, B⟩
    simp
    <;> aesop
  rw [h3]
  have h4 : (Finset.filter (fun p : Set α × Set α ↦ (p.1 ∆ p.2).ncard = 1) (Finset.product (Finset.univ : Finset (Set α)) (Finset.univ : Finset (Set α)))) = Finset.filter (fun p : Set α × Set α ↦ (p.1 ∆ p.2).ncard = 1) (Finset.univ : Finset (Set α × Set α)) := by
    ext ⟨A, B⟩
    simp
    <;> aesop
  rw [h4]
  have h5 : (Finset.filter (fun p : Set α × Set α ↦ (p.1 ∆ p.2).ncard = 1) (Finset.univ : Finset (Set α × Set α))).card ≤ d * (Finset.univ : Finset (Set α)).card := by
    apply h1
    all_goals
      simp
      <;> aesop
  have h6 : (Finset.image (fun p : Set α × Set α ↦ p) (Finset.filter (fun p : Set α × Set α ↦ (p.1 ∆ p.2).ncard = 1) (Finset.univ : Finset (Set α × Set α)))).card = (Finset.filter (fun p : Set α × Set α ↦ (p.1 ∆ p.2).ncard = 1) (Finset.univ : Finset (Set α × Set α))).card := by
    rw [Finset.card_image_of_injOn]
    intro p hp q hq h
    simp at h
    all_goals
      try { tauto }
      try { aesop }
  linarith [h5, h6]
```

This completes the proof. The key insight is that the set family `hypercubeEdgeFinset 𝓕` consists of pairs of sets that differ by exactly one element, and if the original family `F` has low VC dimension, then it cannot have too many such pairs.
