    symmDiff_of_ge <| Set.biInter_subset_biUnion ⟨A, hA⟩
  stop
  simp_rw [Set.image_preimage_eq_inter_range, Subtype.range_val, ← this, ← Set.inter_symmDiff_distrib_left, Set.inter_sdiff_left_comm _ (⋃ _, _)] at hAB

@[simp]
lemma card_restrictFiniteSymmDiffComponent' (𝓒 : Finset (Set α)) :
    (restrictFiniteSymmDiffComponent 𝓒).toFinite.toSet.ncard = #𝓒 := by
  rw [card_restrictFiniteSymmDiffComponent]

protected lemma _root_.IsNIPWith.restrictFiniteSymmDiffComponent
    (h𝓒 : IsNIPWith d (𝓒 : Set (Set α))) :
    IsNIPWith d (restrictFiniteSymmDiffComponent 𝓒 : Set (Set ↑((⋃ A ∈ 𝓒, A) \ ⋂ A ∈ 𝓒, A))) :=
