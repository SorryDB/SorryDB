    measure_iUnion_null_iff]
  rintro a
  by_cases ha : a ∈ u
  · simp [*]
  calc
    Ber(u, p) ({s | a ∈ s} ∩ {s | a ∉ u})
    _ = Ber(u, p) {s | a ∈ s} := by simp [ha]
