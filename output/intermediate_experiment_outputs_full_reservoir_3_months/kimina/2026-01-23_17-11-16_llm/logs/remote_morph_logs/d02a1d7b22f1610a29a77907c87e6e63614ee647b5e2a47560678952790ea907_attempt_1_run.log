open Set TopologicalSpace
open scoped Distributions CompactConvergenceCLM

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

variable (n) in
noncomputable def ofFunWithOrder (f : E → F) (μ : Measure E := by volume_tac) :
    𝓓'^{n}(Ω, F) :=
  TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f

variable (n) in
noncomputable def ofFun (f : E → F) (μ : Measure E := by volume_tac) : 𝓓'(Ω, F) :=
  ofFunWithOrder f μ

lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder f μ = ofFunWithOrder f' μ := by
  ext φ
  simp only [ofFunWithOrder]
  -- need to handle the case where f is not locally integrable
```

Now we need to split into cases depending on whether `f` is locally integrable. The definition of `ofFunWithOrder` is `TestFunction.integralAgainstBilinCLM ...` if `f` is locally integrable, and 0 otherwise.

```tactics
by_cases h1 : LocallyIntegrableOn f Ω μ
· -- If f is locally integrable, then f' is also locally integrable
  have h2 : LocallyIntegrableOn f' Ω μ := by
    apply LocallyIntegrableOn.of_ae_congr
    exact h
    exact h1
```

Now we can use the fact that the integrals are equal because `f = f'` a.e.

```tactics
have h3 : ∫ x, φ x • f x ∂μ = ∫ x, φ x • f' x ∂μ := by
  apply intervalIntegral.integral_congr_ae
  · -- Show that the sets where φ x • f x and φ x • f' x differ is measure zero
    intro x hx
    have h4 : f x = f' x := by
      apply h
      simp at *
      all_goals tauto
```

We need to show that `φ x • f x = φ x • f' x` almost everywhere. But this follows directly from `f x = f' x`.

```tactics
simp [h4]
```

Now we can complete the proof for the case where `f` is locally integrable:

```tactics
simp [h1, h2, h3]
```

For the case where `f` is not locally integrable, `ofFunWithOrder f μ = 0`. We need to show that `f'` is also not locally integrable, so `ofFunWithOrder f' μ = 0`.

```tactics
· -- f is not locally integrable
  have h4 : ¬LocallyIntegrableOn f' Ω μ := by
    intro h'
    have h5 : LocallyIntegrableOn f Ω μ := by
      apply (LocallyIntegrableOn.of_ae_congr (ae_of_mem (μ.restrict Ω)) (by simp)).mpr
      exact h'
    contradiction
```

Now we can use the fact that both `ofFunWithOrder f μ` and `ofFunWithOrder f' μ` are 0:

```tactics
simp [h1, h4]
```

This completes the proof. The key insight is that if `f = f'` almost everywhere, then for any test function `φ`, the integrals `∫ x, φ x • f x ∂μ` and `∫ x, φ x • f' x ∂μ` will be the same, because `φ x • f x` and `φ x • f' x` will be equal almost everywhere. This holds provided that both `f` and `f'` are locally integrable. If either is not, then both distributions are 0, so the equality holds trivially.
</think>
