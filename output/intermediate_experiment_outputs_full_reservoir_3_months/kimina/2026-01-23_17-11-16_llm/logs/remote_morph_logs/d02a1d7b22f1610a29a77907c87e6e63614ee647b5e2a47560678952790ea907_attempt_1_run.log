open Set TopologicalSpace
open scoped Distributions CompactConvergenceCLM

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

open scoped Distributions

variable (Ω F n) in
abbrev Distribution := 𝓓^{n}(Ω, ℝ) →L_c[ℝ] F

-- Notation for the space of distributions of order less than `n`. -/
scoped[Distributions] notation "𝓓'^{" n "}(" Ω ", " F ")" => Distribution Ω F n

/-- We denote `𝓓'(Ω, F)` the space of `F`-valued distributions on `Ω`. Note that using `𝓓'`
is a bit abusive since this is no longer a dual space unless `F = 𝕜`. -/
scoped[Distributions] notation "𝓓'(" Ω ", " F ")" => Distribution Ω F ⊤


namespace Distribution

open scoped Distributions

variable (E : Type* ) [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
variable (F : Type* ) [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]

variable (f f' : E → F) (μ : Measure E) (h : f =ᶠ[ae (μ.restrict ↑Ω)] f')

/-!
The proof that if two functions are equal almost everywhere, then their corresponding distributions are equal.
-/
lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᶠ[ae (μ.restrict ↑Ω)] f') :
  ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
  -- The goal is to show that `ofFunWithOrder` is equal for `f` and `f'`.
  -- By definition, `ofFunWithOrder` is the integral of the test function against `f`.
  -- Since `f = f'` a.e., the integral should be the same.
  -- We need to consider the case where `f` or `f'` is not locally integrable.
  -- However, if `f` is not locally integrable, then `f'` is also not locally integrable
  -- since `f = f'` a.e. The same for the case of `f'`.
  -- So, we can assume both `f` and `f'` are locally integrable.
  -- Then, the integral of `φ • f` should equal the integral of `φ • f'`.
  -- This is true because `f - f'` is zero a.e., and thus the integrand difference is zero a.e.
  -- We need to formalize this reasoning in Lean.
  ext φ
  simp only [ofFunWithOrder]
  -- We need to show that `∫ x, φ x • f x ∂μ = ∫ x, φ x • f' x ∂μ`
  -- This follows from `f = f'` a.e. and the fact that integral is unchanged by a.e. equality.
  -- We need to handle the case where the functions are not locally integrable.
  -- If `f` is not locally integrable, then the integral is zero, and so is the integral for `f'`.
  -- Similarly if `f'` is not locally integrable.
  -- So, we need to show that `f` is not locally integrable iff `f'` is not locally integrable.
  -- This follows from `f = f'` a.e.
  -- Let's complete the proof.
  have h1 : f =ᶠ[ae (μ.restrict ↑Ω)] f' := h
  have h2 : LocallyIntegrableOn f Ω μ ↔ LocallyIntegrableOn f' Ω μ := by
    apply Iff.intro
    · -- Assume f is locally integrable, prove f' is locally integrable
      intro hf
      have hf' : LocallyIntegrableOn f' Ω μ := by
        apply LocallyIntegrableOn.ae_congr hf h1
      exact hf'
    · -- Assume f' is locally integrable, prove f is locally integrable
      intro hf'
      have hf : LocallyIntegrableOn f Ω μ := by
        apply LocallyIntegrableOn.ae_congr hf' h1.symm
      exact hf
  -- Now, we can split into cases based on local integrability.
  by_cases h3 : LocallyIntegrableOn f Ω μ
  · -- Both f and f' are locally integrable
    have h4 : LocallyIntegrableOn f' Ω μ := h2.mp h3
    -- The integral of φ • f equals the integral of φ • f'
    have h5 : ∫ x in Ω, φ x • f x ∂μ = ∫ x in Ω, φ x • f' x ∂μ := by
      have h6 : f =ᶠ[ae (μ.restrict Ω)] f' := h1
      have h7 : ∫ x in Ω, φ x • f x ∂μ = ∫ x in Ω, φ x • f' x ∂μ := by
        -- Apply the fact that if `f = f'` a.e., then the integral is the same.
        -- This requires `φ x • f x = φ x • f' x` a.e.
        -- This follows from `f = f'` a.e. and `φ x` is a test function (hence bounded).
        have h8 : ∀ x : E, x ∈ Ω → φ x • f x = φ x • f' x := by
          intro x hx
          have h9 : f x = f' x := by
            apply h6
            all_goals
              simp at *
              all_goals
                tauto
          simp [h9]
        -- Apply the equality in the integral
        apply intervalIntegral.integral_congr_ae
        · -- Show that the functions are equal a.e.
          exact h6
        · -- Show that the functions are equal at each point in Ω
          intro x hx
          have h9 : f x = f' x := by
            apply h6
            all_goals
              simp at *
              all_goals
                tauto
          simp [h9]
      exact h7
    exact h5
  · -- Neither f nor f' is locally integrable
    have h4 : ¬LocallyIntegrableOn f' Ω μ := by
      by_contra h4
      have h5 : LocallyIntegrableOn f Ω μ := h2.mp h4
      contradiction
    -- Both integrals are zero
    simp only [not_locallyIntegrableOn_iff_isEmpty, h3, h4]
    simp
