open Set TopologicalSpace
open scoped Distributions CompactConvergenceCLM

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

variable (E Ω F n) in

noncomputable abbrev Distribution := ContinuousLinearMap.compContinuousLinearMaps 𝓓^{n}(Ω, ℝ) F continuousLinearMap_ofTopologicalSpace

-- TODO: I'm not sure these notations are good
/-- Notation for the space of distributions of order less than `n`. -/
scoped[Distributions] notation "𝓓'^{" n "}(" Ω ", " F ")" => Distribution Ω F n

/-- We denote `𝓓'(Ω, F)` the space of `F`-valued distributions on `Ω`. Note that using `𝓓'`
is a bit abusive since this is no longer a dual space unless `F = 𝕜`. -/
scoped[Distributions] notation "𝓓'(" Ω ", " F ")" => Distribution Ω F ⊤

namespace Distribution

variable (E : Type*) [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
variable (F : Type*) [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]

noncomputable def ofFunWithOrder (μ : Measure E := by volume_tac) (f : E → F) (n : ℕ∞) : Distribution Ω F n :=
  ContinuousLinearMap.compContinuousLinearMaps (TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f) continuousLinearMap_ofTopologicalSpace

lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder μ f n = ofFunWithOrder μ f' n := by
  ext φ
  simp [ofFunWithOrder, TestFunction.integralAgainstBilinCLM]
  -- The goal is now of the form ∫ x, φ x • (f x - f' x) ∂μ = 0
  rw [← sub_eq_zero]
  -- The goal is now of the form ∫ x, φ x • (f x - f' x) ∂μ = 0
  -- This follows from f =ᶠ[ae (μ.restrict ↑Ω)] f', which implies f x - f' x = 0 for μ.restrict ↑Ω -almost all x.
  apply Measure.integral_eq_zero_of_ae_zero
  -- The goal is now f =ᶠ[ae (μ.restrict ↑Ω)] f'
  exact h

lemma ofFunWithOrder_ae_congr' {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder μ f ⊤ = ofFunWithOrder μ f' ⊤ := by
  apply ofFunWithOrder_ae_congr h

end Distribution
