open Set TopologicalSpace
open scoped Distributions CompactConvergenceCLM

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

namespace Distributions

variable (E F Ω n) in
noncomputable def ofFunWithOrder (f : E → F) (μ : Measure E := by volume_tac) :
    𝓓'^{n}(Ω, F) :=
  TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f

variable (E F Ω) in
noncomputable def ofFun (f : E → F) (μ : Measure E := by volume_tac) : 𝓓'(Ω, F) :=
  ofFunWithOrder f μ ⊤

lemma ofFunWithOrder_apply {f : E → F} {μ : Measure E} (hf : LocallyIntegrableOn f Ω μ)
    {φ : 𝓓^{n}(Ω, ℝ)} :
    ofFunWithOrder f μ φ = ∫ x, φ x • f x ∂μ := by
  simp [ofFunWithOrder, TestFunction.integralAgainstBilinCLM_apply hf]

lemma ofFun_apply {f : E → F} {μ : Measure E} (hf : LocallyIntegrableOn f Ω μ)
    {φ : 𝓓(Ω, ℝ)} :
    ofFun f μ φ = ∫ x, φ x • f x ∂μ :=
  ofFunWithOrder_apply hf

lemma ofFunWithOrder_of_not_locallyIntegrable {f : E → F} {μ : Measure E}
    (hf : ¬LocallyIntegrableOn f Ω μ) : ofFunWithOrder f μ = 0 := by
  ext φ
  simp_rw [ofFunWithOrder, TestFunction.integralAgainstBilinCLM,
    TestFunction.integralAgainstBilinLM, hf]
  dsimp
  congr

lemma ofFun_of_not_locallyIntegrable {f : E → F} {μ : Measure E} (hf : ¬LocallyIntegrableOn f Ω μ) :
    ofFun f μ = 0 := by
  ext φ
  simp [ofFun, ofFunWithOrder_of_not_locallyIntegrable hf]

lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᶠ[ae (μ.restrict ↑Ω)] f') :
  ofFunWithOrder f μ = ofFunWithOrder f' μ := by
  have h1 : f =ᶠ[ae (μ.restrict ↑Ω)] f' := h
  have eq1 : ofFunWithOrder f μ = ofFunWithOrder f' μ := by
    have eq2 : ofFunWithOrder f μ = TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f := by
      simp [ofFunWithOrder]
    have eq3 : ofFunWithOrder f' μ = TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f' := by
      simp [ofFunWithOrder]
    rw [eq2, eq3]
    have eq4 : TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f =
        TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f' := by
      apply TestFunction.integral_congr
      · -- Show that the set is the same
        ext x
        simp
      · -- Show that f = f' on the support of μ.restrict ↑Ω
        intro x hx
        have hx2 : x ∈ (μ.restrict ↑Ω).support := by
          simpa using hx
        have hx3 : f x = f' x := by
          have h4 : f =ᶠ[ae (μ.restrict ↑Ω)] f' := h
          have h5 : x ∈ (μ.restrict ↑Ω).support := hx2
          have h6 : f x = f' x := by
            have h7 : f =ᶠ[ae (μ.restrict ↑Ω)] f' := h
            have h8 : x ∈ (μ.restrict ↑Ω).support := hx2
            apply h7
            all_goals tauto
          simpa using h6
        simpa using hx3
    exact eq4
  exact eq1
```

