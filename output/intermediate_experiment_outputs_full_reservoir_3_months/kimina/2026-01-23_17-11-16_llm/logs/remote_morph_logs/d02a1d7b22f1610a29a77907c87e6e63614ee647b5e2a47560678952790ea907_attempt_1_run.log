open Set TopologicalSpace
open scoped Distributions CompactConvergenceCLM

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

variable (n) in
noncomputable def ofFunWithOrder (f : E → F) (μ : Measure E := by volume_tac) :
    𝓓'^{n}(Ω, F) :=
  TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f

variable (n) in
noncomputable def ofFun (f : E → F) (μ : Measure E := by volume_tac) : 𝓓'(Ω, F) :=
  ofFunWithOrder f μ

lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder f μ = ofFunWithOrder f' μ := by
  ext φ
  simp only [ofFunWithOrder]
  by_cases h1 : LocallyIntegrableOn f Ω μ
  · -- If f is locally integrable, then f' is also locally integrable
    have h2 : LocallyIntegrableOn f' Ω μ := by
      apply LocallyIntegrableOn.of_ae_congr
      exact h
      exact h1
    have h3 : ∫ x, φ x • f x ∂μ = ∫ x, φ x • f' x ∂μ := by
      apply intervalIntegral.integral_congr_ae
      · -- Show that the sets where φ x • f x and φ x • f' x differ is measure zero
        intro x hx
        have h4 : f x = f' x := by
          apply h
          simp at *
          all_goals tauto
        simp [h4]
      · -- Show that the sets where φ x • f x and φ x • f' x differ is measure zero
        intro x hx
        have h4 : f x = f' x := by
          apply h
          simp at *
          all_goals tauto
        simp [h4]
    simp [h1, h2, h3]
  · -- f is not locally integrable
    have h4 : ¬LocallyIntegrableOn f' Ω μ := by
      intro h'
      have h5 : LocallyIntegrableOn f Ω μ := by
        apply (LocallyIntegrableOn.of_ae_congr (ae_of_mem (μ.restrict Ω)) (by simp)).mpr
        exact h'
      contradiction
    simp [h1, h4]
```

