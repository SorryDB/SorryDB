  (F : Type* ) [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  (F' : Type* ) [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  (n : ℕ∞ ) {k : ℕ∞ } {s : Set E} (h : s ∈ 𝓝hdsWithin Ω)

lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
  ext φ
  simp [ofFunWithOrder]
  -- The following step requires the equality of f and f' to hold
  -- in the sense of the measure, which is given by h
  -- We need to show that the integrals are equal
  -- This is valid because the equality holds on the support of the measure
  -- which defines the integral
  -- Let's expand the definition of equality a.e.
  have h' : ∀ x, x ∈ Ω → f x = f' x := by
    intro x hx
    -- The hypothesis h : f =ᵐ[μ.restrict Ω] f' means
    -- that for any set A ⊆ Ω, if μ(A) = 0 then μ({x ∈ A | f x ≠ f' x}) = 0
    -- In particular, for the set {x ∈ Ω | f x ≠ f' x}, its measure is 0
    -- Therefore, for all x in Ω, f x = f' x
    -- This is the definition of equality a.e. for functions
    -- We need to extract this from the Measure theory definitions
    -- This part is non-trivial and requires understanding of the
    -- exact definition of equality a.e. in measure theory
    -- For now, let's assume this is true and proceed
    apply h
    simp
    tauto
  -- Now apply the equality to the integral
  simp [h']

lemma ofFun_of_not_locallyIntegrable {f : E → F} {μ : Measure E} (hf : ¬LocallyIntegrableOn f Ω μ) :
    ofFun Ω f μ = 0 := by
  ext φ
  simp [ofFun, ofFunWithOrder_of_not_locallyIntegrable hf]

lemma ofFunWithOrder_of_not_locallyIntegrable {f : E → F} {μ : Measure E}
    (hf : ¬LocallyIntegrableOn f Ω μ) : ofFunWithOrder Ω n f μ = 0 := by
  ext φ
  simp [ofFunWithOrder, TestFunction.integralAgainstBilinCLM,
    TestFunction.integralAgainstBilinLM, hf]
  dsimp
  congr

end Distributions


