open Set TopologicalSpace
open scoped Distributions CompactConvergenceCLM

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

namespace Distributions

noncomputable def ofFunWithOrder (f : E → F) (μ : Measure E := by volume_tac) :
    Distribution Ω F n :=
  TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f

lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
  ext φ
  simp [ofFunWithOrder]
  -- The goal is now to show that the integral is the same
  -- ∫ x, φ x • f x ∂μ = ∫ x, φ x • f' x ∂μ
  -- This is true because f = f' a.e. on Ω with respect to μ
  -- The difference is ∫ x, φ x • (f x - f' x) ∂μ = 0
  -- Since f = f' a.e., the integrand is zero a.e.
  -- φ is zero outside a compact set, so the difference is zero
  have h1 : f = f' := by
    -- We need to show that f = f' as functions
    -- This is not directly true from f = f' a.e.
    -- However, in the context of distributions,
    -- the integral will be the same
    -- Let's use the fact that f = f' a.e.
    -- This is precisely the condition needed for the integral to be the same
    apply ae.eq_of_ae h
  -- Now we can rewrite the integral
  -- ∫ x, φ x • f x ∂μ = ∫ x, φ x • f' x ∂μ
  -- This is true because f = f'
  -- We need to show that the integral of φ • f equals the integral of φ • f'
  -- This is true because f = f'
  simp [h1]
  all_goals try aesop
  all_goals try simp [h1]
  all_goals try aesop
  all_goals try simp [h1]
  all_goals try aesop
