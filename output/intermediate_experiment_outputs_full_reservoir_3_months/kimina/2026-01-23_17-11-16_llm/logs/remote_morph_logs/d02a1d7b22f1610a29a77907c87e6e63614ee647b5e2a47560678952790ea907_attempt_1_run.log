    have h1 : ∫ x in Ω, φ x • f x ∂μ = ∫ x in Ω, φ x • f' x ∂μ := by
      have h' : f =ᶠ[ae (μ.restrict Ω)] f' := h
      have h2 : ∀ x, φ x ≠ 0 → f x = f' x := h''
      apply (ae_equiv_of_eq_of_ae h2 h').integral_congr
