    (hfine : 2 * (b - a) / n < ╬┤) :
  |RiemannSum f a b (n * k) - RiemannSum f a b n| < (b - a) * ╬╡  := by
  change |(b - a) / тЖС(n * k) * тИС i тИИ range (n * k), f (a + (i + 1) * (b - a) / тЖС(n * k)) -
      (b - a) / n * тИС i тИИ range n, f (a + (i + 1) * (b - a) / тЖСn)| <
  (b - a) * ╬╡
  rw [sum_of_prod]
  rw [show (b - a) / тЖС(n * k) * тИС j тИИ Finset.range n, тИС k_1 тИИ Finset.range k, f (a + (тЖС(j + k_1 * n) + 1) * (b - a) / тЖС(n * k)) -
      (b - a) / тЖСn * тИС i тИИ Finset.range n, f (a + (тЖСi + 1) * (b - a) / тЖСn) =
      (b - a) / n * тИС j тИИ Finset.range n,  ((1 / k) * тИС тДУ тИИ Finset.range k, f (a + (тДУ + j * k + 1) * (b - a) / (n * k)) -
