import Mathlib

open Finset Set

/- The sum over `m * n` terms can be expressed as a double sum over `m` and `n`.
-/
lemma sum_of_prod {X : Type*} [CommSemiring X] (f : тДХ тЖТ X) (m n : тДХ) :
  тИС i тИИ range (m * n), f i =
    тИС j тИИ range m, тИС k тИИ range n, f (j + k * m) := by
  induction' m with m hm
  simp
  sorry

/- If a function `f` is uniformly continuous on `[a,b]`, then the Riemann sum at `n * k` differs
from that at `n` by at most `(b - a) * ╬╡`, provided the partition is fine enough.
-/
theorem RiemannSumRefinement (f : тДЭ тЖТ тДЭ) {a b : тДЭ} (hab : a < b) {n k : тДХ}
    (hn : n тЙа 0) (hk : k тЙа 0)
    {╬╡ ╬┤ : тДЭ} (h╬╡ : ╬╡ > 0) (h╬┤ : ╬┤ > 0)
    (hunif : тИА x тИИ Icc a b, тИА y тИИ Icc a b, |y - x| < ╬┤ тЖТ |f y - f x| < ╬╡)
    (hfine : 2 * (b - a) / n < ╬┤) :
  |RiemannSum f a b (n * k) - RiemannSum f a b n| < (b - a) * ╬╡  := by
  have h1 : тИА j тИИ range n, тИА тДУ тИИ range k,
      |a + (тДУ + j * k + 1) * (b - a) / (n * k) -  (a + (j + 1) * (b - a) / n)| < ╬┤ := by
    intro j hj тДУ hтДУ
    have h2 : |a + (тДУ + j * k + 1) * (b - a) / (n * k) -  (a + (j + 1) * (b - a) / n)| =
        |(тДУ + 1 - k) * (b - a) / (n * k)| := by
      field_simp
      ring_nf
      <;> field_simp <;> ring
    rw [h2]
    have h3 : |(тДУ + 1 - k) * (b - a) / (n * k)| тЙд (b - a) / n := by
      have h4 : |(тДУ + 1 - k) * (b - a) / (n * k)| = |(тДУ + 1 - k)| * |(b - a) / (n * k)| := by
        rw [abs_mul]
      rw [h4]
      have h5 : |(тДУ + 1 - k)| тЙд k - 1 := by
        have h6 : тДУ < k := by
          simpa using hтДУ
        have h7 : тДУ + 1 тЙд k := by
          omega
        rw [abs_of_nonpos (by omega)]
        linarith
      have h8 : |(b - a) / (n * k)| = |b - a| / (n * k) := by
        field_simp [abs_div]
      rw [h8]
      have h9 : |(тДУ + 1 - k)| * |(b - a) / (n * k)| тЙд (k - 1) * (b - a) / (n * k) := by
        have h10 : |(тДУ + 1 - k)| тЙд k - 1 := h5
        have h11 : |(b - a) / (n * k)| = |b - a| / (n * k) := h8
        have h12 : |b - a| = b - a := by
          apply abs_of_pos
          linarith
        rw [h11, h12]
        have h13 : (k - 1 : тДЭ) * (b - a) / (n * k) тЙд (b - a) / n := by
          have h14 : (k : тДЭ) > 0 := by
            exact_mod_cast show (k : тДХ) > 0 by omega
          have h15 : (n : тДЭ) > 0 := by
