import Mathlib.Analysis.Calculus.Integration.Basic
import Mathlib.Analysis.Calculus.Integration.Riemann

open Finset Set

lemma sum_of_prod {X : Type*} [CommSemiring X] (f : тДХ тЖТ X) (m n : тДХ) :
  тИС i тИИ range (m * n), f i =
    тИС j тИИ range m, тИС k тИИ range n, f (j + k * m) := by
  induction' m with m hm
  simp
  sorry

/--
The sum over `m * n` terms can be expressed as a double sum over `m` and `n`.
-/
TheoremDoc sum_of_prod as "sum_of_prod" in "тИСaтВЩ"

/--
If a function `f` is uniformly continuous on `[a,b]`, then the Riemann sum at `n * k` differs
from that at `n` by at most `(b - a) * ╬╡`, provided the partition is fine enough.
-/
