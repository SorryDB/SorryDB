```lean
import Mathlib.Data.Real.Basic
import Mathlib.Analysis.SpecialFunctions.Integrals.Basic
import Mathlib.Analysis.SpecialFunctions.Integrals.Riemann.Basic
import Mathlib.Analysis.SpecialFunctions.Integrals.Riemann.Sum

open Real Set
open scoped BigOperators

lemma sum_of_prod {X : Type*} [CommSemiring X] (f : тДХ тЖТ X) (m n : тДХ) :
  тИС i тИИ range (m * n), f i =
    тИС j тИИ range m, тИС k тИИ range n, f (j + k * m) := by
  induction' m with m hm
  ┬╖ simp
  ┬╖ simp [Finset.sum_range_succ, hm]
    <;> ring_nf
    <;> simp [Finset.sum_range_succ, hm]
    <;> ring

theorem RiemannSumRefinement (f : тДЭ тЖТ тДЭ) {a b : тДЭ} (hab : a < b) {n k : тДХ}
    (hn : n тЙа 0) (hk : k тЙа 0)
    {╬╡ ╬┤ : тДЭ} (h╬╡ : ╬╡ > 0) (h╬┤ : ╬┤ > 0)
    (hunif : тИА x тИИ Icc a b, тИА y тИИ Icc a b, |y - x| < ╬┤ тЖТ |f y - f x| < ╬╡)
    (hfine : 2 * (b - a) / n < ╬┤) :
