        have h6 : (тДУ + 1) * (b - a) / (n * k) - (b - a) / n тЙд 2 * (b - a) / n := by
          have h7 : (тДУ + 1) * (b - a) / (n * k) - (b - a) / n =
              ( (тДУ + 1) * (b - a) * n - (b - a) * (n * k) ) / (n * k * n) := by
            field_simp
            ring
          rw [h7]
          have h8 : ( (тДУ + 1) * (b - a) * n - (b - a) * (n * k) ) / (n * k * n) тЙд 2 * (b - a) / n := by
            apply (div_le_iffтВА (by positivity)).mpr
            have h9 : (тДУ + 1) * (b - a) * n - (b - a) * (n * k) тЙд 2 * (b - a) * (n * k) := by
