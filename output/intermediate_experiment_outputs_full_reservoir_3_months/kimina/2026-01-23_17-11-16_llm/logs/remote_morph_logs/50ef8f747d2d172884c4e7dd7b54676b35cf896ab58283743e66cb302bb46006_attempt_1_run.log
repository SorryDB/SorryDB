import Mathlib

open Finset Set

theorem RiemannSumRefinement (f : тДЭ тЖТ тДЭ) {a b : тДЭ} (hab : a < b) {n k : тДХ}
    (hn : n тЙа 0) (hk : k тЙа 0)
    {╬╡ ╬┤ : тДЭ} (h╬╡ : ╬╡ > 0) (h╬┤ : ╬┤ > 0)
    (hunif : тИА x тИИ Icc a b, тИА y тИИ Icc a b, |y - x| < ╬┤ тЖТ |f y - f x| < ╬╡)
    (hfine : 2 * (b - a) / n < ╬┤) :
  |RiemannSum f a b (n * k) - RiemannSum f a b n| < (b - a) * ╬╡  := by
  have h1 : |RiemannSum f a b (n * k) - RiemannSum f a b n| < (b - a) * ╬╡ := by
    rw [RiemannSum, RiemannSum]
    simp [Finset.sum_range_succ, abs_mul]
    <;> norm_num
    <;> try { 
      have h2 : тИА (j : тДХ), j тИИ Finset.range n тЖТ тИА (тДУ : тДХ), тДУ тИИ Finset.range k тЖТ
