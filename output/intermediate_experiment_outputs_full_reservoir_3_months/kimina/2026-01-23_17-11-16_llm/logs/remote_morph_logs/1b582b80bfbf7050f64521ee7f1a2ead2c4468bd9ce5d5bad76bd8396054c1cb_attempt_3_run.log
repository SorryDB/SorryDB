theorem liftContext_rbr_soundness [Inhabited InnerStmtOut]
    {outerLangIn : Set (OuterStmtIn × OuterWitIn)} {outerLangOut : Set (OuterStmtOut × OuterWitOut)}
    {innerLangIn : Set (InnerStmtIn × InnerWitIn)} {innerLangOut : Set (InnerStmtOut × InnerWitOut)}
