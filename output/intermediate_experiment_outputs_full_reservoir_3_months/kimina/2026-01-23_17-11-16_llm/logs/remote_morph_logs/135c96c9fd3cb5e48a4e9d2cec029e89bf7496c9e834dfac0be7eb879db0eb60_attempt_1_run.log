import Game.Levels.L22Pset.L02

open Finset Set

World "L22Pset"
Level 3
Title "Differentiability Exercise"
Introduction "
# Level 3: Differentiability Exercise

Show that `x ↦ x ^ 3` is differentiable.

"

/-- Prove this
-/
Statement : ∃ g : ℝ → ℝ,
  fun x ↦ x ^ 3) g := by
  use fun x ↦ 3 * x ^ 2
  intro x ε hε
  let δ : ℝ := min 1 (ε / (3 * |x| + 1))
  have δ_le1 : δ ≤ 1 := by bound
  have δ_le2 : δ ≤ ε / (3 * |x| + 1) := by bound
  have δpos : 0 < δ := by
    by_cases h1 : ε / (3 * |x| + 1) ≤ 1
    · -- case where ε / (3 * |x| + 1) ≤ 1, so δ = ε / (3 * |x| + 1)
      rw [show min 1 (ε / (3 * |x| + 1)) = ε / (3 * |x| + 1) by
        apply min_eq_right
        linarith [h1]
      ]
      positivity
    · -- case where ε / (3 * |x| + 1) > 1, so δ = 1
      rw [show min 1 (ε / (3 * |x| + 1)) = 1 by
        apply min_eq_left
        linarith [show ε / (3 * |x| + 1) ≥ 1 by linarith]
      ]
      all_goals linarith
  use δ, δpos
  intro h hne hh
  have h1 : |3 * x + h| ≤ 3 * |x| + 1 := by
    have h2 : |3 * x + h| ≤ |3 * x| + |h| := by
      apply abs_add
    have h3 : |3 * x| = 3 * |x| := by
      simp [abs_mul]
    rw [h3] at h2
    have h4 : |h| < 1 := by
      have h5 : |h| < δ := by
        simpa using hh
      have h6 : δ ≤ 1 := by
        simpa using δ_le1
      linarith
    linarith
  have h2 : |((x + h) ^ 3 - x ^ 3) / h - 3 * x ^ 2| < ε := by
    have eq1 : ((x + h) ^ 3 - x ^ 3) / h - 3 * x ^ 2 = (h) * (3 * x + h) := by
      field_simp [hne]
      ring
    rw [eq1]
    have eq2 : |(h) * (3 * x + h)| = |h| * |3 * x + h| := by
      rw [abs_mul]
    rw [eq2]
    have h3 : |h| * |3 * x + h| < ε := by
      have h4 : |h| < δ := by
        simpa using hh
      have h5 : |3 * x + h| ≤ 3 * |x| + 1 := h1
      have h6 : δ ≤ ε / (3 * |x| + 1) := by
        simpa using δ_le2
      have h7 : |h| * |3 * x + h| ≤ δ * (3 * |x| + 1) := by
        have h8 : |h| < δ := h4
        have h9 : |3 * x + h| ≤ 3 * |x| + 1 := h5
        nlinarith [abs_nonneg h, abs_nonneg (3 * x + h), abs_nonneg x]
      have h8 : δ * (3 * |x| + 1) ≤ ε := by
        have h9 : δ ≤ ε / (3 * |x| + 1) := h6
        have h10 : (3 * |x| + 1) > 0 := by
          have h11 : |x| ≥ 0 := abs_nonneg x
          linarith [abs_nonneg x]
        have h11 : δ * (3 * |x| + 1) ≤ (ε / (3 * |x| + 1)) * (3 * |x| + 1) := by
          apply mul_le_mul_of_nonneg_right h9
          all_goals linarith [abs_nonneg x]
        have h12 : (ε / (3 * |x| + 1)) * (3 * |x| + 1) = ε := by
          field_simp [show (3 * |x| + 1) ≠ 0 by linarith [abs_nonneg x]]
        linarith [h11, h12]
      nlinarith [abs_nonneg h, abs_nonneg (3 * x + h), abs_nonneg x]
    linarith
  simpa using h2
