    ¬∑ intro ‚ü®witMid, h‚ü©
      exact ‚ü®_, (kSF.toFun_empty stmtIn witMid).mpr h‚ü©
  toFun_next := fun m hDir stmtIn tr hToFunNext msg => by
    simp only [not_exists]
