structure RoundByRound
    (oSpec : OracleSpec őĻ) (StmtIn WitIn WitOut : Type) {n : ‚Ąē} (pSpec : ProtocolSpec n)
    (WitMid : Fin (n + 1) ‚Üí Type) where
