  toFun_full : ‚ąÄ stmtIn tr witOut,
    Pr[fun stmtOut => (stmtOut, witOut) ‚ąą relOut
    | verifier.run_simulate init impl stmtIn tr] > 0 ‚Üí
    toFun (.last n) stmtIn tr (extractor.extractOut stmtIn tr witOut)

/-!
  A one-shot round-by-round knowledge state function for a verifier, with respect to input
  relation `relIn`, output relation `relOut`, and intermediate witness types `WitMid`.
  This is used to define one-shot round-by-round knowledge soundness.
-/
structure KnowledgeStateFunctionOneShot
    (relIn : Set (StmtIn √ó WitIn)) (relOut : Set (StmtOut √ó WitOut))
    (verifier : Verifier oSpec StmtIn StmtOut pSpec)
    where
  /-- The knowledge state function: takes in round index, input statement, transcript up to that
      round, and intermediate witness of that round, and returns True/False. -/
  toFun : (m : Fin (n + 1)) ‚Üí StmtIn ‚Üí Transcript m pSpec ‚Üí Prop
  /-- The input statement and witness are in the input relation if and only if the state function is
