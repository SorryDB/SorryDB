  (this : ¬¨if n = 0 then
      (stmtIn,
          @Extractor.RoundByRound.extractOut őĻ oSpec StmtIn WitIn WitOut n pSpec (fun x => WitIn)
            (Extractor.RoundByRoundOneShot.toRoundByRound őĻ oSpec StmtIn WitIn WitOut n pSpec oneShotE) stmtIn tr
            witOut) ‚ąą
        relIn
    else
      Verifier.KnowledgeStateFunctionOneShot.toFun őĻ oSpec StmtIn StmtOut n pSpec ŌÉ init impl relIn.language
          relOut.language verifier stF (Fin.last n) stmtIn tr ‚ą®
        (stmtIn, @oneShotE (Fin.last n) stmtIn tr default) ‚ąą relIn)
  : ¬¨(¬¨if n = 0 then
      (stmtIn, @oneShotE (Fin.last n) ...) ‚ąą relIn
    else
      Verifier.KnowledgeStateFunctionOneShot.toFun őĻ oSpec StmtIn StmtOut n pSpec ŌÉ init impl relIn.language
