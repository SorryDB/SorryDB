        | verifier.run_simulate init impl stmtIn tr] > 0 := by
      simp only [Fin.val_last, gt_iff_lt, probEvent_pos_iff]
      exact ‚ü®stmtOut, hStmtOut, hRelOut‚ü©
    have := kSF.toFun_full stmtIn tr witOut hProb
