theorem roundByRound_knowledgeSoundness
    (oSpec : OracleSpec őĻ) (StmtIn WitIn : Type) {n : ‚Ąē} (pSpec : ProtocolSpec n)
    (init : ProbComp ŌÉ) (impl : QueryImpl oSpec (StateT ŌÉ ProbComp))
    (relIn : Set (StmtIn √ó WitIn)) (relOut : Set (StmtOut √ó WitOut))
    (verifier : Verifier oSpec StmtIn StmtOut pSpec)
    (stF : Verifier.KnowledgeStateFunctionOneShot őĻ oSpec StmtIn StmtOut n pSpec ŌÉ init impl relIn.language relOut.language
      verifier)
    (oneShotE : @Extractor.RoundByRoundOneShot őĻ oSpec StmtIn WitIn n pSpec)
    : Verifier.KnowledgeStateFunction őĻ oSpec StmtIn StmtOut n pSpec ŌÉ init impl relIn relOut
      (oneShotE.toRoundByRound) := by
  have h1 : Verifier.KnowledgeStateFunction őĻ oSpec StmtIn StmtOut n pSpec ŌÉ init impl relIn relOut
      (oneShotE.toRoundByRound) := by
    rw [show oneShotE.toRoundByRound = oneShotE.toRoundByRound by rfl]
    apply KnowledgeStateFunctionOneShot.toKnowledgeStateFunction
    exact stF
    exact oneShotE
  exact h1
