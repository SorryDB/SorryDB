theorem verifying_round_by_round_knowledge_s soundness
  {oSpec : OracleSpec őĻ}
  {StmtIn WitIn : Type}
  {n : ‚Ąē}
  {pSpec : ProtocolSpec n}
  {ŌÉ : Type}
