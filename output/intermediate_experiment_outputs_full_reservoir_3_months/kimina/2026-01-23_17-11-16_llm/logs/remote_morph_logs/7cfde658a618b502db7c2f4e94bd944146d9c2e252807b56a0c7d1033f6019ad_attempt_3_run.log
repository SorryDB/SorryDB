    have := stF.toFun_full stmtIn tr
    have hQ : ‚ąÉ x ‚ąą support (Verifier.run_simulate őĻ oSpec StmtIn StmtOut n pSpec ŌÉ init impl verifier stmtIn tr), ‚ąÉ x_1, (x, x_1) ‚ąą relOut := by
