      rw [this] at stF_next
      simp_all
      sorry
    ¬∑ simp_all
      sorry
    -- TODO: Complete this proof
  toFun_full := fun stmtIn tr witOut h => by
    have := stF.toFun_full stmtIn tr
    contrapose! this
    simp_all
    stop
    by_cases hn : n = 0
    ¬∑ subst hn
