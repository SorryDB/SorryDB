    regardless of the message -/
  toFun_next : ‚ąÄ m, pSpec.dir m = .P_to_V ‚Üí
    ‚ąÄ stmt tr msg, ¬¨ toFun m.castSucc stmt tr ‚Üí ¬¨ toFun m.succ stmt (tr.concat msg)
  /-- If the state function is false for a full transcript, the verifier will not output a statement
    in the output language -/
  toFun_full : ‚ąÄ stmt tr, ¬¨ toFun (.last n) stmt tr ‚Üí
    Pr[(¬∑ ‚ąą langOut) | verifier.run_simulate init impl stmt tr] = 0

