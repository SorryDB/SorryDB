import Mathlib

open MeasureTheory ProbabilityTheory
open Real

variable (α : Type) (R : Type) (mα : MeasurableSpace α) (mR : MeasurableSpace R)
  (instα : Nonempty α) (instR : Nonempty R)
  (hα : StandardBorelSpace α) (hR : StandardBorelSpace R)
  (instα_dec : DecidableEq α) (instR_dec : DecidableEq R) (instα_count : Countable α) (instR_count : Countable R)

noncomputable def algFunction [DecidableEq α] [Countable α] (a : α) (r : R) (n : ℕ) : α :=
  if n = 0 then a else a

noncomputable def action [DecidableEq α] (a : α) (r : R) (n : ℕ) : α :=
  if n = 0 then a else a

noncomputable def reward [DecidableEq α] (a : α) (r : R) (n : ℕ) : R :=
  if n = 0 then r else r

noncomputable def algorithm : Algorithm α R :=
  ⟨fun _ ↦ (init := fun _ ↦ (a := 1, r := 0)), fun _ ↦ fun _ ↦ (a := 1, r := 0)⟩

noncomputable def kernel : Kernel α R :=
  fun a r n ↦ Dirac a

noncomputable def arrayMeasure : Measure (ℕ → (α × R)) :=
  Measure.infinitePi fun n ↦ Dirac (a := 1, r := 0)

theorem test : AEMeasurable (fun ω : ℕ → α × R ↦ reward (1 : α) (0 : R) (ω 0)) (arrayMeasure) := by
  simp [reward, arrayMeasure]
  apply AEMeasurable.mono
  · simp
  · apply AEMeasurable.mono
    · simp
    · simp [arrayMeasure]
```

