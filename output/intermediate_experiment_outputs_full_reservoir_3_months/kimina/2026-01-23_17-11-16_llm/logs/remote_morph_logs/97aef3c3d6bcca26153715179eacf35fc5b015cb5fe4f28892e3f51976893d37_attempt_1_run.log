```lean
import Mathlib
import Analysis.SpecialFunctions.Pow.Real

open Real

/- A bandit algorithm is a sequence of functions that determines an action at each step
   based on the history of rewards. The formalization follows the structure provided. -/
variable [DecidableEq α] [Countable α] [StandardBorelSpace α] [Nonempty α] [StandardBorelSpace R] [Nonempty R]
  (alg : Algorithm α R) (ω : probSpace α R)

/- The state of the algorithm at step n is represented by `h : Iic n → α × R`.
   This maps indices from 0 to n to pairs of (action, reward). -/
noncomputable
def state [DecidableEq α] (n : ℕ) → (Iic n → α × R)

/- The initial state is just the first pair (action, reward). -/
noncomputable
def initState [DecidableEq α] (n : ℕ) : (Iic n → α × R) :=
  fun _ ↦ (initAlgFunction alg (ω.1 0), ω.2 0 (initAlgFunction alg (ω.1 0)))

/- The state at step n+1 is built from the state at step n. If i ≤ n, the i-th
   element comes from the previous state. Otherwise, it's a new pair (a, r) where
   a is the action chosen by the algorithm at step n based on the current state,
   and r is the corresponding reward. -/
noncomputable
def stepState [DecidableEq α] (n : ℕ) (h : state n) : state (n + 1) :=
  fun i ↦ if hin : i ≤ n then h ⟨i, by simp [hin]⟩ else
    (algFunction alg n h (ω.1 (n + 1)), ω.2 (pullCount' n h (algFunction alg n h (ω.1 (n + 1)))) (algFunction alg n h (ω.1 (n + 1))))

/- A function that, given a state at step n, returns the action taken at step n. -/
noncomputable
def action [DecidableEq α] (n : ℕ) : α := stepState n initState ⟨n, by simp⟩ |>.1

/- A function that, given a state at step n, returns the reward obtained at step n. -/
noncomputable
def reward [DecidableEq α] (n : ℕ) : R := stepState n initState ⟨n, by simp⟩ |>.2

/- The state at step n is a function `Iic n → α × R`. This can be represented as
   a product of the form (Iic n) × α × R. We prove this equality. -/
lemma state_eq_prod [DecidableEq α] (n : ℕ) :
    state n = (Iic n).prod fun i ↦ α × R := by
  ext i
  simp only [state, Function.comp_apply, Finset.mem_Iic, iff_true]
  simp only [Finset.mem_Iic, true_and]
  simp

/- The initial state is just the pair (initAlgFunction, ω.2 0). -/
lemma initState_eq_prod [DecidableEq α] :
    initState = fun _ ↦ (initAlgFunction alg (ω.1 0), ω.2 0 (initAlgFunction alg (ω.1 0))) := by
  ext
  simp [initState]

/- The step state construction corresponds to the product of Iic (n+1) with α × R. -/
lemma stepState_eq_prod [DecidableEq α] :
    stepState = fun n h ↦ (IicSuccProd n).symm (h, (⟨n, by simp⟩, α × R)) := by
  ext i
  simp only [stepState, Finset.mem_Iic, iff_true, IicSuccProd.mem, Prod.mk.injEq]
  by_cases h : i ≤ n
  · simp [h]
    simp only [Finset.mem_Iic, true_and]
  · simp [h]
    simp only [Finset.mem_Iic, true_and]
    simp only [IicSuccProd.mem, true_and]
    simp [Finset.mem_Iic, h]

/- The action function maps a state at step n+1 to its first component. -/
lemma action_eq_prod [DecidableEq α] :
    action = fun _ ↦ (fun s : state (n + 1) ↦ s ⟨n + 1, by simp⟩ |>.1) := by
  ext
  simp [action]

/- The reward function maps a state at step n+1 to its second component. -/
lemma reward_eq_prod [DecidableEq α] :
    reward = fun _ ↦ (fun s : state (n + 1) ↦ s ⟨n + 1, by simp⟩ |>.2) := by
  ext
  simp [reward]

/- The state at step n+1 is the product of Iic (n+1) and α × R. -/
lemma state_add_one_eq_prod [DecidableEq α] :
    state (n + 1) = (IicSuccProd n).symm (state n, (⟨n, by simp⟩, α × R)) := by
  ext i
  simp only [state, stepState, Finset.mem_Iic, iff_true, IicSuccProd.mem, Prod.mk.injEq]
  by_cases h : i ≤ n
  · simp [h]
    simp only [Finset.mem_Iic, true_and]
  · simp [h]
    simp only [Finset.mem_Iic, true_and]
    simp only [IicSuccProd.mem, true_and]
    simp [Finset.mem_Iic, h]

/- The initial state is just the pair (initAlgFunction, ω.2 0). -/
lemma initState_add_one_eq_prod [DecidableEq α] :
    initState (n + 1) = (IicSuccProd n).symm (initState, (⟨n, by simp⟩, α × R)) := by
  ext i
  simp only [initState, stepState, Finset.mem_Iic, iff_true, IicSuccProd.mem, Prod.mk.injEq]
  by_cases h : i ≤ n
  · simp [h]
