: @OrderConstraints state.scopes :=
  let threadreqs := state.requests.filter λ r => r.thread == req.thread ∨ r.isPredecessorAt req.thread
  let newOc := Id.run do
    let mut oc := state.orderConstraints
    for req' in threadreqs do
