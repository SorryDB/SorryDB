  let requests' :=
    match pairedRequest? with
      | none => state.requests.insert req
      | some paired =>
        let paired' := {paired with pairedRequest? := some req.id}
        let req' := {req with pairedRequest? := some paired.id}
        state.requests.insert req' |>.insert paired'
