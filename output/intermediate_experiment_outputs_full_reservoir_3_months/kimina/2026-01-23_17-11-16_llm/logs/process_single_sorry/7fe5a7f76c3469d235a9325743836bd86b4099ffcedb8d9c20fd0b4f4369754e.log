      "\n  have h1 : x' ∈ (ker f) := by\n    simp at hx ⊢\n    exact hx\n  have h2 : (Ideal.Quotient.mk (ker f)) x' = 0 := by\n    simp [mem_ker] at h1 ⊢\n    all_goals try tauto\n  rw [hx']\n  exact h2",
      "\n  have h2 : x' ∈ (ker f) := by\n    simp [mem_ker] at *\n    all_goals try tauto\n  have h3 : (Ideal.Quotient.mk (ker f)) x' = 0 := by\n    simp [mem_ker] at *\n    all_goals try tauto\n  exact h3",
