      "\n  have h1 : x' ∈ (ker f) := by\n    simpa using hx\n  have h2 : (Ideal.Quotient.mk (ker f)) x' = (Ideal.Quotient.mk (ker f)) 0 := by\n    have h3 : x' ∈ (ker f) := h1\n    have h4 : (x' : R) - (0 : R) ∈ (ker f) := by\n      have h5 : (x' : R) - (0 : R) = x' := by ring\n      rw [h5]\n      exact h3\n    have h5 : (Ideal.Quotient.mk (ker f)) x' = (Ideal.Quotient.mk (ker f)) 0 := by\n      rw [Ideal.Quotient.eq_zero_iff_mem] at *\n      -- We need to show (x' - 0) ∈ I\n      have h6 : x' - (0 : R) ∈ (ker f) := h4\n      simpa using h6\n    exact h5\n  have h3 : x = (Ideal.Quotient.mk (ker f)) 0 := by\n    rw [hx'] at h2\n    linarith\n  have h4 : (Ideal.Quotient.mk (ker f)) 0 = 0 := by\n    simp\n  rw [h4] at h3\n  exact h3",
