    exact h2
  have h5 : x' ∈ (ker f) := by
    rw [mem_ker]
    exact h4
  have h6 : (Ideal.Quotient.mk (ker f)) x' = 0 := by
    exact Ideal.Quotient.eq_zero_iff_mem.mpr h5
  rw [h1] at *
  exact h6
