        rw [h3] at h4
        have h5 : C ∈ Knight ↔ False := h4
        have h6 : ¬(C ∈ Knight) := by 
          tauto
        simp at h6 ⊢
        tauto
      have h7 : A ∈ Knight ↔ Knight.card = 1 := by
        have h8 : B ∈ Knight := h
        have h9 : (B ∈ Knight) ↔ (A ∈ Knight ↔ Knight.card = 1) := stB
        rw [h8] at h9
        tauto
      by_cases h10 : A ∈ Knight
      · -- Assume A is a knight
        have h11 : Knight.card = 1 := by
          tauto
        have h14 : A = B := by
          have h15 : A ∈ Knight := h10
          have h16 : B ∈ Knight := h
          have h17 : ∀ x, x ∈ Knight → x = B := by
            intro x hx
            have hx1 : x ∈ Knight := hx
            have h18 : (x : Inhabitant) ∈ Knight := hx1
            have h19 : (B : Inhabitant) ∈ Knight := h
            have h20 : (x : Inhabitant) = (B : Inhabitant) := by
