example : (fun x : ÔäĽ ÔćŽ x + x) 3 = 3 + 3 := rfl
example : copyNat = ÔäĽ := rfl
example (f : ÔäĽ Ôćĺ ÔäĽ) : (fun x ÔćŽ f x) = f := rfl
example {P : ÔäĽ Ôćĺ Type*} (h_zero : P 0) (h_succ : ÔłÇ n, P n Ôćĺ P (n + 1)) :
    Nat.rec (motive := P) h_zero h_succ 0 = h_zero := rfl
example : (let a := 3; a + a) = 3 + 3 := rfl
example (p : ÔäĽ ├Ś ÔäĽ) : (p.1, p.2) = p := rfl
example {P : Prop} (h1 h2 : P) : h1 = h2 := rfl
