`findExponents_precond (n : Nat) (primes : List Nat) : Prop := n > 0 ∧ primes.length > 0 ∧ primes.all (fun p => Nat.Prime p) ∧ List.Nodup primes`

`findExponents_postcond (n : Nat) (primes : List Nat) (result: List (Nat × Nat)) (h_precond : findExponents_precond (n) (primes)) : Prop := (n = result.foldl (fun acc (p, e) => acc * p ^ e) 1) ∧ result.all (fun (p, _) => p ∈ primes) ∧ primes.all (fun p => result.any (fun pair => pair.1 = p))`

