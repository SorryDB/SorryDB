      "\n      simp [addEquivAddHaarChar]\n    have h3 : addEquivAddHaarChar (ContinuousAddEquiv.mulRight u) = ∫ x : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar x, ContinuousAddEquiv.mulRight u x := by\n      simp [addEquivAddHaarChar]\n    rw [h2, h3]\n    have h4 : (∫ x : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar x, ContinuousAddEquiv.mulLeft u x) = (∫ x : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar x, ContinuousAddEquiv.mulRight u x) := by\n      have h5 : (∫ x : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar x, ContinuousAddEquiv.mulLeft u x) = ∫ y : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar y, (y := ContinuousAddEquiv.mulLeft u (u⁻¹ * y)) := by\n        congr\n        funext y\n        have h6 : ContinuousAddEquiv.mulLeft u (u⁻¹ * y) = y := by\n          simp [ContinuousAddEquiv, mul_assoc]\n        simp [h6]\n      have h7 : (∫ x : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar x, ContinuousAddEquiv.mulRight u x) = ∫ y : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar y, (y := ContinuousAddEquiv.mulRight u (y * u⁻¹)) := by\n        congr\n        funext y\n        have h8 : ContinuousAddEquiv.mulRight u (y * u⁻¹) = y := by\n          simp [ContinuousAddEquiv, mul_assoc]\n        simp [h8]\n      have h9 : ∫ y : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar y, (y := ContinuousAddEquiv.mulLeft u (u⁻¹ * y)) = ∫ y : (FiniteAdeleRing (RingOfIntegers K) K), addEquivAddHaar y, (y := ContinuousAddEquiv.mulRight u (y * u⁻¹)) := by\n        congr\n        funext y\n        simp\n      rw [h5, h7, h9]\n    exact h4\n  exact h1",
