theorem tails_append_singleton (xs : List α) (x : α) :
    (xs ++ [x]).tails = xs.tails.map (fun ys => ys ++ [x]) ++ [[]] := by
  induction xs with
  | nil      => simp
  | cons y ys ih =>
      simp [List.tails, ih]

theorem map_reverse_tails_snoc (x : α) (xs : List α) :
