import Mathlib

open List (map reverse tails) in
open Finset (map reverse) in

def inits₁ {a : Type} : List a → List (List a) :=
 map reverse ∘ reverse ∘ tails ∘ reverse

def inits₂ {a : Type} : List a → List (List a) :=
 List.map SymList.fromSL ∘ List.scanl (fun y => SymList.snocSL y) SymList.nil


/- trying to prove inits₁ = inits₂ -/

theorem inits_eq {a : Type} : ∀ xs : List a, inits₁ xs = inits₂ xs
  | [] => by
    unfold inits₁ inits₂
    simp
  | x :: xs => by
    have ih := inits_eq xs
    simp [inits₁, inits₂, Function.comp] at ih ⊢
    <;> try { aesop }
    <;> try { tauto }
    <;> try { native_decide }
```

