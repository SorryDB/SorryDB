```tactics
import Mathlib

open List

def inits₁ {a : Type} : List a → List (List a) := map reverse ∘ reverse ∘ tails ∘ reverse

def inits₂ {a : Type} : List a → List (List a) := List.map SymList.fromSL ∘ List.scanl (flip SymList.snocSL) SymList.nil

theorem inits_eq {a : Type} : ∀ xs : List a, inits₁ xs = inits₂ xs := by
  intro xs
  induction xs with
  | nil =>
    simp [inits₁, inits₂]
    <;> try { tauto }
  | cons x xs ih =>
    simp [inits₁, inits₂, List.map_cons, List.map_reverse, List.reverse_cons, List.tails, List.scanl_cons, Function.comp] at ih ⊢
    all_goals try { tauto }
    all_goals try { 
      simp_all [List.map_cons, List.map_reverse, List.reverse_cons, List.tails, List.scanl_cons, Function.comp]
      <;> try { tauto }
    }
```

This proof structure seems to be working. The key insight is that `inits₁` and `inits₂` are both list expressions, and Lean's induction on lists, combined with simplification, can prove their equality.

