      have h7 : (r : ℝ) ≠ (∞ : ℝ) := by simp
      have h8 : (p : ℝ)⁻¹ + (q : ℝ)⁻¹ = (r : ℝ)⁻¹ := by
        have h9 := hpqr.1
        simp at h9 ⊢
