```lean
import Mathlib.Analysis.SpecialFunctions.Integrals.Basic
import Mathlib.RingTheory.Real.Irrational
import Mathlib.Analysis.Convolution
import Mathlib.MeasureTheory.Integral.Prod
import Mathlib.MeasureTheory.Function.JacobianOneDim

open BigOperators Function Set Real Topology Filter
open ENNReal MeasureTheory Interval intervalIntegral
set_option linter.unusedVariables false
noncomputable section

/-! # Exercises to practice -/

section

/- There are special cases of the change of variables theorems for affine transformations
(but you can also use the change of variable theorem from the lecture) -/
example (a b : ℝ) :
    ∫ x in a..b, sin (x / 2 + 3) =
    2 * cos (a / 2 + 3) - 2 * cos (b / 2  + 3) := by
  sorry
  done

/- Use the change of variables theorem for this exercise. -/
example (f : ℝ → ℝ) (s : Set ℝ) (hs : MeasurableSet s) :
    ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
  have h1 : ∀ x, exp x > 0 := by
    intro x
    positivity

  have h7 : Set.InjOn exp s := by
    intro x hx y hy hxy
    have hx2 : exp x = exp y := hxy
    have hx3 : x = y := by
      have h8 : exp x = exp y := hxy
      have h9 : x = y := by
        apply exp_injective
        all_goals linarith
      linarith
    linarith

  have h8 : Set.SurjOn exp s (exp '' s) := by
    intro y hy
    have hy2 : y ∈ exp '' s := hy
    rcases hy2 with ⟨x, hx, hxy⟩
    use x
    all_goals
      try tauto
      try linarith

  have h14 : ContinuousOn (exp) s := by
    apply Continuous.continuousOn
    exact continuous_exp

  have h15 : ContinuousOn (Real.log) (exp '' s) := by
    apply Continuous.continuousOn
    intro x hx
    have hx2 : x ∈ exp '' s := hx
    rcases hx2 with ⟨y, hy, hxy⟩
    have hy2 : exp y > 0 := by positivity
    have h16 : Real.log (exp y) = y := by
      rw [Real.log_exp]
      all_goals linarith
    simp [h16]

  have h19 : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
    have h21 : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, (f y) * (1 / (exp y)) * (exp y) := by
      apply intervalIntegral.integral_comp
      · -- Show that exp is a bijection from s to exp '' s
        constructor
        · -- Show that exp is injective on s
          exact h7
        · -- Show that exp is surjective from s to exp '' s
          exact h8
      · -- Show that exp is continuous on s
        exact h14
      · -- Show that log is continuous on exp '' s
        exact h15
      · -- Show that f is measurable
        apply hs
      · -- Show that f is integrable
        apply intervalIntegral.intervalIntegral_congr
        intro x hx
        have hx2 : exp x > 0 := by positivity
        simp
        all_goals
          try positivity
          try linarith
    have h22 : ∫ y in exp '' s, (f y) * (1 / (exp y)) * (exp y) = ∫ y in exp '' s, f y := by
      congr
