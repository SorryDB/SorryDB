          have h12 : ∀ x ∈ s, exp x = y ↔ x = log y := by
            intro x hx
            apply h1 x
          simp_all [Set.mem_image]
          <;> try { aesop }
        · -- Show that f is measurable
          apply hs.measurable
        · -- Show that exp is differentiable
          intro x
          apply Real.differentiable_exp
        · -- Show that the derivative is non-zero on s
          intro x hx
          have h13 : (Real.exp x).deriv = Real.exp x := by
