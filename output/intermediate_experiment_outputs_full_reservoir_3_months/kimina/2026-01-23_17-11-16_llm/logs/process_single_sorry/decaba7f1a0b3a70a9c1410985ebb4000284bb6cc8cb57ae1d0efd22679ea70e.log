def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro a b ha hb
    have ha1 : a ∈ I := by simpa using ha
    have ha2 : a ∈ J := by simpa using ha
    have hb1 : b ∈ I := by simpa using hb
    have hb2 : b ∈ J := by simpa using hb
    have hab1 : a + b ∈ I := by apply I.add_mem ha1 hb1
    have hab2 : a + b ∈ J := by apply J.add_mem ha2 hb2
    simp at hab1 hab2 ⊢
    tauto

