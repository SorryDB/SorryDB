    intro a b ha hb
    have ha1 : a ∈ I := by simpa using ha
    have ha2 : a ∈ J := by simpa using ha
    have hb1 : b ∈ I := by simpa using hb
    have hb2 : b ∈ J := by simpa using hb
    have hab1 : a * b ∈ I := by apply I.mul_mem ha1 hb1
    have hab2 : a * b ∈ J := by apply J.mul_mem ha2 hb2
    simp at hab1 hab2 ⊢
    tauto
