      simpa using ha.1
    have ha2 : a ∈ J := by 
      simpa using ha.2
    have h1 : r * a ∈ I := by 
      apply I.mul_mem
      exact ha1
    have h2 : r * a ∈ J := by 
      apply J.mul_mem
      exact ha2
