import SmullyanKnightsAndKnaves.knightsknaves
import SmullyanKnightsAndKnaves.knightsknaves_3

set_option push_neg.use_distrib true

open settheory_approach

variable [Fintype Inhabitant]
variable [DecidableEq Inhabitant]
--A:All of us are knaves.
--B: Exactly one of us is a knave.
example
{stA : A ∈ Knight ↔ (Knave = ({A,B,C} : Finset Inhabitant)) }
{stAn : A ∈ Knave ↔ ¬ (Knave = {A,B,C}) }
{stB: B ∈ Knight ↔ Knave = {A} ∨ Knave = {B} ∨ Knave = {C}}
{stBn: B ∈ Knave ↔ ¬ (Knave = {A} ∨ Knave = {B} ∨ Knave = {C})}
{all2: 
 ∀ (x : Inhabitant), x = A or x = B or x = C}
  : A ∈ Knave ∧ C ∈ Knight := by
  have AKnave : A ∈ Knave := by
    by_contra AKnight
    have allKnave := stA.mp AKnight
    have h1 : A ∈ Knave := by 
      rw [allKnave]
      simp
    contradiction
  have notallKnave : ¬Knave = {A, B, C} := by
    tauto
  have Cknight : C ∈ Knight := by
    by_contra h
    have Cknave : C ∈ Knave := by 
      simpa using h
    have h1 : Knave = {A, C} := by
      ext x
      simp only [Finset.mem_insert, Finset.mem_singleton]
      constructor
      · -- Assume x ∈ Knave
        intro h
        rcases h with (rfl | rfl)
        · -- x = A
          simp [AKnave]
        · -- x = C
          simp [Cknave]
      · -- Assume x ∈ {A, C}
        intro h
        rcases h with (rfl | rfl)
        · -- x = A
          simp [AKnave]
        · -- x = C
          simp [Cknave]
    have h3 : B ∈ Knave := by
      by_contra h
      have Bknight : B ∈ Knight := by 
        simpa using h
      have h4 : (Knave = {A} ∨ Knave = {B} ∨ Knave = {C}) := by 
        tauto
      rcases h4 with (h4 | h4 | h4)
      · -- Assume Knave = {A}
        rw [h4] at h1
        ext x
        simp at h1 ⊢
        all_goals try { tauto }
      · -- Assume Knave = {B}
        rw [h4] at h1
        ext x
        simp at h1 ⊢
        all_goals try { tauto }
      · -- Assume Knave = {C}
        rw [h4] at h1
        ext x
        simp at h1 ⊢
        all_goals try { tauto }
    have h7 : Knave = {A, B, C} := by
      ext x
      simp only [Finset.mem_insert, Finset.mem_singleton]
      constructor
      · -- Assume x ∈ Knave
        intro h
        rcases h with (rfl | rfl | rfl)
        · -- x = A
          simp [AKnave]
        · -- x = B
          simp [h3]
        · -- x = C
          simp [Cknave]
      · -- Assume x ∈ {A, B, C}
        intro h
        rcases h with (rfl | rfl | rfl)
        · -- x = A
          simp [AKnave]
        · -- x = B
          simp [h3]
        · -- x = C
          simp [Cknave]
    contradiction
  constructor
  · exact AKnave
  · exact Cknight
