        contradiction
    · -- B ∈ Knave
      have hBn' : B ∈ Knave := hBn
      have h3 : ¬(Knave = {A} ∨ Knave = {B} ∨ Knave = {C}) := by 
        tauto
      exfalso
      have hCk : C ∈ Knave := h1
      have h4 : C ∈ ({A} : Finset Inhabitant) ∨ C ∈ ({B} : Finset Inhabitant) ∨ C ∈ ({C} : Finset Inhabitant) := by 
