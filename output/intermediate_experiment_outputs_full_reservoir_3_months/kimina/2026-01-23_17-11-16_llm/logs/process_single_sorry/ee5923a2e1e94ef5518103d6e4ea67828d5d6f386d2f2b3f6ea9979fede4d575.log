```lean
import SmullyanKnightsAndKnaves.knightsknaves
import SmullyanKnightsAndKnaves.knightsknaves_3

set_option push_neg.use_distrib true

open settheory_approach

variable [Fintype Inhabitant]
variable [DecidableEq Inhabitant]
--A:All of us are knaves.
--B: Exactly one of us is a knave.
example
{stA : A ∈ Knight ↔ (allKnave) }
{stAn : A ∈ Knave ↔ ¬ (allKnave) }
{stB: B ∈ Knight ↔ oneKnave }
{stBn: B ∈ Knave ↔ ¬ (oneKnave) }
  : A ∈ Knave ∧ C ∈ Knight := by
  {
  have AKnave : A ∈ Knave := by
    by_contra AKnight
    set_knave_to_knight at AKnight
    have knaves := stA.mp AKnight
    have AKnave := knaves.left
    contradiction

  have notallknaves := stAn.mp AKnave
  constructor
  assumption
  set_knight_or_knave B with BKnight BKnave
  ·
    have oneKn := stB.mp BKnight 
    unfold oneKnave at oneKn
    simp [AKnave,BKnight,knight_notknaveIff] at oneKn
    set_knight_to_knave 
    assumption
  ·
    unfold allKnave at notallknaves
    simp [AKnave,BKnave] at notallknaves
    set_knight_to_knave
    assumption
  }

example
{stA : A ∈ Knight  ↔ (Knave= ({A,B,C} : Finset Inhabitant)) }
{stAn : A ∈ Knave ↔ ¬ (Knave = {A,B,C}) }
{stB : B ∈ Knight ↔ Knave = {A} ∨ Knave = {B} ∨ Knave = {C}}
{stBn : B ∈ Knave ↔ ¬ (Knave = {A} ∨ Knave = {B} ∨ Knave = {C})}
{all2: 
 ∀ (x : Inhabitant), x = A or x = B or x = C}
  : A ∈ Knave ∧ C ∈ Knight := by
  have AKnave : A ∈ Knave := by
    by_contra h
    push_neg at h
    have h1 : A ∈ Knight := by 
      simpa using h
    have h2 : Knave = {A, B, C} := by 
      tauto
    have h3 : A ∈ Knave := by 
      rw [h2]
      simp
    contradiction
  have notallKnave := stAn.mp AKnave
  have CKnight : C ∈ Knight := by
    by_contra h
    push_neg at h
    have h1 : C ∈ Knave := by 
      simpa using h
    have h2 : B ∈ Knight ∨ B ∈ Knave := by 
      by_cases h3 : B ∈ Knight
      · tauto
      · tauto
    rcases h2 with hBk | hBn
    · -- B ∈ Knight
      have hBk' : B ∈ Knight := hBk
      have h3 : (Knave = {A} ∨ Knave = {B} ∨ Knave = {C}) := by 
        tauto
      rcases h3 with h4 | h5 | h6
      · -- Knave = {A}
        exfalso
        have hCk : C ∈ Knave := h1
        have hCk' : C ∈ ({A} : Finset Inhabitant) := by 
          rw [h4] at *
          simp at *
          all_goals try { tauto }
          all_goals try { contradiction }
        simp at hCk' 
        all_goals try { contradiction }
      · -- Knave = {B}
        exfalso
        have hCk : C ∈ Knave := h1
        have hCk' : C ∈ ({B} : Finset Inhabitant) := by 
          rw [h5] at *
          simp at *
          all_goals try { tauto }
          all_goals try { contradiction }
        simp at hCk' 
        all_goals try { contradiction }
      · -- Knave = {C}
        exfalso
        have hA : A ∈ Knave := by 
          have hA : A ∈ ({C} : Finset Inhabitant) := by 
            rw [h6] at *
            simp at *
            all_goals try { tauto }
            all_goals try { contradiction }
          simp at hA 
          all_goals try { contradiction }
        have hA' : A ∈ Knight := by 
