- For k = 2: 2^(2^2) - 3 = 2^4 - 3 = 16 - 3 = 13
- For k = 3: 2^(2^3) - 3 = 2^8 - 3 = 256 - 3 = 253
- For k = 4: 2^(2^4) - 3 = 2^16 - 3 = 65536 - 3 = 65533

Check gcds:
- gcd(1, 13) = 1
- gcd(1, 253) = 1
- gcd(1, 65533) = 1
- gcd(13, 253) = 1
- gcd(13, 65533) = 1
- gcd(253, 65533) = 1

