import Mathlib.Tactic.NormNum
import Mathlib.Tactic.IntervalCases

import ProblemExtraction

problem_file { tags := [.Combinatorics] }

/-!
# Bulgarian Mathematical Olympiad 1998, Problem 1

We will be considering colorings in 2 colors of n (distinct) points
A₁, A₂, ..., Aₙ. Call such a coloring "good" if there exist three points
Aᵢ, Aⱼ, A₂ⱼ₋ᵢ, 1 ≤ i < 2j - i ≤ n, which are colored the same color.

Find the least natural number n (n ≥ 3) such that all colorings
of n points are good.
-/

namespace Bulgaria1998P1

abbrev coloring_is_good {m : ℕ} (color : Set.Icc 1 m → Fin 2) : Prop :=
  ∃ i j : Set.Icc 1 m,
    i < j ∧
    ∃ h3 : 2 * j.val - i ∈ Set.Icc 1 m,
    color i = color j ∧ color i = color ⟨2 * j - i, h3⟩

abbrev all_colorings_are_good (m : ℕ) : Prop :=
  3 ≤ m ∧ ∀ color : Set.Icc 1 m → Fin 2, coloring_is_good color

lemma lemma1 {m n : ℕ} (hmn : m ≤ n) (hm : all_colorings_are_good m) :
    all_colorings_are_good n := by
  constructor
  · exact hm.1.trans hmn
  · intro c
    let c' : Set.Icc 1 m → Fin 2 :=
      fun x ↦ c ⟨x.val, by rw [Set.mem_Icc]; exact ⟨x.prop.1, x.prop.2.trans hmn⟩⟩
    obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := hm.2 c'
    use ⟨i, hi1, hi2.trans hmn⟩
    use ⟨j, hj1, hj2.trans hmn⟩
    simp only [Subtype.mk_lt_mk, Set.mem_Icc, tsub_le_iff_right, exists_and_left]
    simp only [Subtype.mk_lt_mk] at hij1
    refine ⟨hij1, ?_⟩
    simp only [Set.mem_Icc, tsub_le_iff_right] at hij2
    simp only [c'] at hc1
    refine ⟨hc1, ?_⟩
    have hij2' : 1 ≤ 2 * j - i ∧ 2 * j ≤ n + i :=
       ⟨hij2.1, le_add_of_le_add_right hij2.2 hmn⟩
    use hij2'

def coloring_of_eight {n : ℕ} : Set.Icc 1 n → Fin 2
| ⟨1, _⟩ => 0
| ⟨2, _⟩ => 1
| ⟨3, _⟩ => 0
| ⟨4, _⟩ => 1
| ⟨5, _⟩ => 1
| ⟨6, _⟩ => 0
| ⟨7, _⟩ => 1
| ⟨8, _⟩ => 0
| _ => 0 -- unreachable

lemma lemma2 :
    ∃ f : Set.Icc 1 8 → Fin 2, ¬coloring_is_good f := by
  use coloring_of_eight
  intro h
  obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := h
  dsimp [coloring_of_eight] at *
  interval_cases i <;> interval_cases j <;> simp [Set.mem_Icc] at *
  <;> omega

lemma lemma3 : ¬all_colorings_are_good 8 := by
  intro h
  obtain ⟨h1, h2⟩ := h
  have h3 := h2 (lemma2.1)
  contradiction

lemma lemma4 : all_colorings_are_good 5 := by
  constructor
  · norm_num
  · intro color
    have h1 : ∃ i j : Set.Icc 1 5, i < j ∧ ∃ h3 : 2 * j.val - i ∈ Set.Icc 1 5, color i = color j ∧ color i = color ⟨2 * j - i, h3⟩ := by
      have h2 : color 1 = 0 ∨ color 1 = 1 := by omega
      have h3 : color 2 = 0 ∨ color 2 = 1 := by omega
      have h4 : color 3 = 0 ∨ color 3 = 1 := by omega
      have h5 : color 4 = 0 ∨ color 4 = 1 := by omega
      have h6 : color 5 = 0 ∨ color 5 = 1 := by omega
      by_contra h
      push_neg at h
      have h7 : color 1 ≠ color 2 := by
        by_contra h8
        have h8' : color 1 = color 2 := by
          omega
        have h9 := h 1 2 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h8 : color 1 ≠ color 3 := by
        by_contra h9
        have h9' : color 1 = color 3 := by
          omega
        have h10 := h 1 3 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h9 : color 1 ≠ color 4 := by
        by_contra h10
        have h10' : color 1 = color 4 := by
          omega
        have h11 := h 1 3 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h10 : color 1 ≠ color 5 := by
        by_contra h11
        have h11' : color 1 = color 5 := by
          omega
        have h12 := h 1 4 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h11 : color 2 ≠ color 3 := by
        by_contra h12
        have h12' : color 2 = color 3 := by
          omega
        have h13 := h 2 3 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h12 : color 2 ≠ color 4 := by
        by_contra h13
        have h13' : color 2 = color 4 := by
          omega
        have h14 := h 2 4 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h13 : color 2 ≠ color 5 := by
        by_contra h14
        have h14' : color 2 = color 5 := by
          omega
        have h15 := h 2 4 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h14 : color 3 ≠ color 4 := by
        by_contra h15
        have h15' : color 3 = color 4 := by
          omega
        have h16 := h 3 4 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h15 : color 3 ≠ color 5 := by
        by_contra h16
        have h16' : color 3 = color 5 := by
          omega
        have h17 := h 3 4 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      have h16 : color 4 ≠ color 5 := by
        by_contra h17
        have h17' : color 4 = color 5 := by
          omega
        have h18 := h 4 5 (by norm_num) (by norm_num) (by norm_num) (by omega) (by omega) (by omega)
        contradiction
      omega
    exact h1
