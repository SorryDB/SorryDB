    -- Use that f is an isomorphism, so preserves addition
    -- f (x + y) = f x + f y
    -- Then g preserves addition
    -- g (f x + f y) = g (f x) + g (f y)
    -- So overall: g (f (x + y)) = g (f x + f y) = g (f x) + g (f y)
    simp [f.map_add', g.map_add']
