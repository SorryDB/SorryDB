\n                                                                                                                                                                    exact congr_arg (f) (show g (f x) = f x by \n                                                                                                                                                                      exact congr_arg (f) (show g (f x) = f x by \n                                                                                                                                                                        exact congr_arg (f) (show g (f x) = f x by \n                                                                                                                                                                          exact congr_arg (f) (show g (f x) = f x by \n                                                                                                                                                                            exact congr_arg (f) (show g (f x) = f x by \n                                                                                                                                                                              exact congr_arg (f) (show g (f x) = f x by \n                                                                                                                                                                                exact congr_arg (f) (show g (f x) = f x by \n                                                                                                                                                                                  exact congr_arg (f) (show g (f x) = f x by \n                                                                                                                                                                                    exact congr_arg (f) (show g (f x) = f x by \n                                             