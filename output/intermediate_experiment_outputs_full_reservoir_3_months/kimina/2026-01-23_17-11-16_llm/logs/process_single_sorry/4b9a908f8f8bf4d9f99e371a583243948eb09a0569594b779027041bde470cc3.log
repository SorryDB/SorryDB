      "\n  intro S T h\n  -- Since solsInclQuadSols is the identity function, we have S = T directly from h\n  simpa using h",
      "\n  intro S₁ S₂ h\n  simp [solsInclQuadSols] at h\n  have h1 : S₁.val = S₂.val := by\n    have h1 := congr_arg (λ s => s.val) h\n    simp at h1 ⊢\n    exact h1\n  have h2 : S₁.linearSol = S₂.linearSol := by\n    have h2 := congr_arg (λ s => s.linearSol) h\n    simp at h2 ⊢\n    exact h2\n  have h3 : S₁.quadSol = S₂.quadSol := by\n    have h3 := congr_arg (λ s => s.quadSol) h\n    simp at h3 ⊢\n    exact h3\n  exact Sols.ext h1 h2 h3",
      "\n  intro s₁ s₂ h\n  have h1 : (solsInclQuadSols χ) s₁ = (solsInclQuadSols χ) s₂ := h\n  simp [solsInclQuadSols] at h1\n  have h2 : s₁.val = s₂.val := by\n    exact congr_arg Prod.fst h1\n  have h3 : s₁.quadSol = s₂.quadSol := by\n    exact congr_arg Prod.snd h1\n  exact Sols.ext h2",
