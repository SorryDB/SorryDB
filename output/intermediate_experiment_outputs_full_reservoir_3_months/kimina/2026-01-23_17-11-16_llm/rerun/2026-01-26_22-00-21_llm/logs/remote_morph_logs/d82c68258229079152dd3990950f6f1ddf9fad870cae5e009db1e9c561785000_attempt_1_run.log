      have h4 : ∀ k : ℕ, k ≥ 2 → ((↑k : ℂ) ^ (-2 * (↑n : ℂ))) * (Real.log (↑k : ℝ)) > 0 := by
        intro k hk
        have hk1 : (↑k : ℝ) ≥ (2 : ℝ) := by
          exact_mod_cast hk
        have h5 : Real.log (↑k : ℝ) > 0 := by
          apply Real.log_pos
          linarith
        have h6 : (↑k : ℂ) ^ (-2 * (↑n : ℂ)) > 0 := by
          have h7 : (↑k : ℂ) > 0 := by
            exact_mod_cast show (↑k : ℝ) > 0 by linarith
          positivity
        have h8 : ((↑k : ℂ) ^ (-2 * (↑n : ℂ))) * (Real.log (↑k : ℝ)) > 0 := by
          apply mul_pos
          exact_mod_cast h6
          exact_mod_cast h5
        exact_mod_cast h8
      have h7 : ∑' k : ℕ, ((↑k : ℂ) ^ (-2 * (↑n : ℂ))) * (Real.log (↑k : ℝ)) = 
          ∑' k : ℕ, if k ≥ 2 then ((↑k : ℂ) ^ (-2 * (↑n : ℂ))) * (Real.log (↑k : ℝ)) else 0 := by
        congr
        funext k
        simp
      rw [h7]
      have h8 : ∑' k : ℕ, if k ≥ 2 then ((↑k : ℂ) ^ (-2 * (↑n : ℂ))) * (Real.log (↑k : ℝ)) else 0 > 0 := by
        apply HasSum.sum_pos
