    hom := fun u => Int.ofNat (v L u)
    comm g := by
      intro g' u
      simp [Int.ofNat_inj, vL_comm]
      <;> native_decide
  }
  h := {
    hom := (Int.ofNat).toLinearMap
    comm g := by
      intro x
      simp
  }
