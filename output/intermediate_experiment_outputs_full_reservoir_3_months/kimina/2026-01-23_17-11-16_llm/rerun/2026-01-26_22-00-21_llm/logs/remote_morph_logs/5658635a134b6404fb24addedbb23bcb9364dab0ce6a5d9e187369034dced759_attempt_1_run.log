theorem secondInvo_sq : secondInvo k ^ 2 = 1 := by
  change secondInvo k ∘ secondInvo k = id
  funext ⟨⟨x, y, z⟩, h⟩
  rw [comp_apply]
  simp only [secondInvo, secondInvo_fun, sub_sub_cancel, id_eq, Subtype.mk.injEq, Prod.mk.injEq,
