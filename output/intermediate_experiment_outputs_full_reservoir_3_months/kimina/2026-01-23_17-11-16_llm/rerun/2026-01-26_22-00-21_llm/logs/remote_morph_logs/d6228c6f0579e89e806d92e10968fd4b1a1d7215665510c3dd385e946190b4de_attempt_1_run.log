      (fun x : EB × F ↦ e'.coordChangeL 𝕜 e (c x.1) x.2)
      (Prod.fst ⁻¹' range IB) (extChartAt IB x₀.proj x₀.proj, (e' x₀).2) := by
    sorry /-refine ContMDiffWithinAt.clm_apply (𝕜 := 𝕜) ?_ contDiffWithinAt_snd.contMDiffWithinAt
