```tactics
theorem marcinkiewicz_zygmund (iIndepFun_X : iIndepFun X μ)
    (integral_X : ∀ i, ∫ ω, X i ω ∂μ = 0)
    (memLp_X : ∀ i ∈ A, MemLp (X i) (2 * m) μ) :
    ∫ ω, ‖∑ i ∈ A, X i ω‖ ^ (2 * m) ∂μ ≤
      marcinkiewiczZygmundConst (2 * m) * ∫ ω, (∑ i ∈ A, ‖X i ω‖ ^ 2) ^ m ∂μ := by
  let X' : ι → Ω → E := fun i ω ↦ 2 * X i ω
  have iIndepFun_X' : iIndepFun X' μ := by
    intro i
    apply iIndepFun_X.map_const
    funext i
    simp [X']
  have integral_X' : ∀ i, ∫ ω, X' i ω ∂μ = 0 := by
    intro i
    simp [X']
    <;> ring_nf <;> simp [integral_X]
  have memLp_X' : ∀ i ∈ A, MemLp (X' i) (2 * m) μ := by
    intro i hi
    simp [X']
    apply memLp_of_memLp
    exact memLp_X i hi
  have h := marcinkiewicz_zygmund_symmetric iIndepFun_X' (by
    intro i
    apply identDistrib_const_mul
    apply identDistrib_neg_X i
  ) memLp_X'
  simp [marcinkiewiczZygmundConst] at h ⊢
  <;> ring_nf at h ⊢
  <;> try norm_num at h ⊢
  <;> linarith
