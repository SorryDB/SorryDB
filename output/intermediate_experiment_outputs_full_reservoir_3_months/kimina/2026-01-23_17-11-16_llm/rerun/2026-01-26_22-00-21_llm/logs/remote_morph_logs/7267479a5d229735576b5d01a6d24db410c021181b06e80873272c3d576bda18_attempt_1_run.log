          use k + 1
          constructor
          · exact h_k
          · intro j j_lt_k_succ
            rw [@Nat.lt_add_one_iff_lt_or_eq] at j_lt_k_succ
            cases j_lt_k_succ
            · simp at hl
              apply hl
              assumption
            · convert h
```

