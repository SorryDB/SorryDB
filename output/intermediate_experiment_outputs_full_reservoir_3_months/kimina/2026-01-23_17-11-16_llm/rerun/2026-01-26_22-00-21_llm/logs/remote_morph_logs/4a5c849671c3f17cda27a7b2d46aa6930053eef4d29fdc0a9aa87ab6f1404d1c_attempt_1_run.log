    intro h
    induction h using List.induction_on with
    | nil =>
      simp at h ⊢
      all_goals try { tauto }
      all_goals try { 
        have : False := by 
          simp at h ⊢
          all_goals try { tauto }
          all_goals try { 
            have h1 : (Hilbert.F Ax) ⊢ False := by 
              simpa using h
            contradiction
