    | andIR h1 h2 => 
      simp at h1 h2 ⊢
      <;> try { tauto }
      <;> try { 
        exfalso
        <;> try { 
          tauto 
        }
      }
  . intro h; 
    apply Deduction.mp h; 
    apply Deduction.ctx; 
    simp;
