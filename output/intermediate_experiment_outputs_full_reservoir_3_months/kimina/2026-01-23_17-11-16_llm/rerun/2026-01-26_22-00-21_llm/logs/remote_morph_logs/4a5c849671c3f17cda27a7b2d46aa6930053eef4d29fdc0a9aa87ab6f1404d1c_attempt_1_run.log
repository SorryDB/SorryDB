        apply Deduction.andIR
        · apply Deduction.ctx; simp
        · apply deduction_subset (List.toFinset (x :: xs) ⊆ List.toFinset (x :: xs ++ [x]) ? _)
          · simp [List.toFinset_append, List.toFinset_singleton]
          · exact ih
    simp_all [List.toFinset, List.conj₂] at h1 ⊢
    tauto
  . intro h; 
