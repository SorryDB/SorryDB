      have eq2 : ∑ i : Fin (2 * n - 1), (p i : Fin 8) = 4 := by
        have h4 : A + ∑ i : Fin (2 * n - 1), (p i : Fin 8) = A + 4 := eq1
        have h5 : ∑ i : Fin (2 * n - 1), (p i : Fin 8) = 4 := by
