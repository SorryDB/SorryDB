/-- # The Riemann Hypothesis: All nontrivial zeros of the Riemann zeta function have real part equal to 1/2.

    This is the central conjecture that has remained unproven since Riemann's
    original paper in 1859, despite substantial numerical evidence supporting it. -/
def RiemannHypothesis : Prop :=
  ∀ (s : ℂ), IsNontrivialZero s → s.re = 1/2

/-- All zeros of the Riemann zeta function outside the critical strip are simple zeros.
    This means if ζ(s) = 0 and s is not in the critical strip (s.re ≤ 0 or s.re ≥ 1),
    then the derivative at that point is non-zero: ζ'(s) ≠ 0. -/
theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 := by
  intro s hs1 hs2
  have h1 : ¬(0 < s.re ∧ s.re < 1) := by
    simpa using hs1
  have h2 : s.re ≤ 0 ∨ s.re ≥ 1 := by
    by_contra h
    push_neg at h
    have h3 : 0 < s.re ∧ s.re < 1 := by
      constructor
      · linarith [h.1]
      · linarith [h.2]
    contradiction
  rcases h2 with h2 | h2
  · -- s.re ≤ 0
    have h4 : ∃ n : ℕ, s = -2 * (n + 1) := by
      have h19 : s.re ≤ 0 := h2
      have h20 : ¬(0 < s.re ∧ s.re < 1) := h1
      have h21 : riemannZeta s = 0 := hs2
      have h22 : ∃ n : ℕ, s = -2 * (n + 1) := by
        apply riemannZeta_zero_of_not_in_critical_strip
        all_goals
          try { tauto }
          try { norm_num }
          try { nlinarith }
      exact h22
    rcases h4 with ⟨n, hn⟩
    rw [hn]
    apply deriv_riemannZeta_ne_zero_at_trivial_zero
  · -- s.re ≥ 1
    have h4 : ∃ n : ℕ, s = -2 * (n + 1) := by
      have h19 : s.re ≥ 1 := h2
      have h20 : ¬(0 < s.re ∧ s.re < 1) := h1
      have h21 : riemannZeta s = 0 := hs2
      have h22 : ∃ n : ℕ, s = -2 * (n + 1) := by
        apply riemannZeta_zero_of_not_in_critical_strip
        all_goals
          try { tauto }
          try { norm_num }
          try { nlinarith }
      exact h22
    rcases h4 with ⟨n, hn⟩
    rw [hn]
    apply deriv_riemannZeta_ne_zero_at_trivial_zero
