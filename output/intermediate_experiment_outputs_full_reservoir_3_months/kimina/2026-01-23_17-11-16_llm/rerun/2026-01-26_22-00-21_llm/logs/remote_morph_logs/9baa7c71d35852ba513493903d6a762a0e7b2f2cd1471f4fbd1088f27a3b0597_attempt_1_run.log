      have h3 : |∑ i, ∑ j, (y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - s) • x + s • y)| ≤ ∑ i, ∑ j, |(y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - s) • x + s • y)| := by
        apply abs_sum_le
      have h4 : ∑ i, ∑ j, |(y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - s) • x + s • y)| = ∑ i, ∑ j, |y i - x i| * |y j - x j| * |(nth_partial i <| nth_partial j f) ((1 - s) • x + s • y)| := by
