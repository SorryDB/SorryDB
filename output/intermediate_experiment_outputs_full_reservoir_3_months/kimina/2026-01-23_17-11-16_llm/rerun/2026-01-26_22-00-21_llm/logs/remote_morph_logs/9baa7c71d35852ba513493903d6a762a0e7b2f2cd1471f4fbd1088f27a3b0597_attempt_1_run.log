    have h3 : ∑ i, |(y i - x i) * nth_partial i f x| = ∑ i, |y i - x i| * |nth_partial i f x| := by
      congr; funext i; simp [abs_mul]
    rw [h2, h3]
    have h4 : |y i - x i| ≤ ε := by
