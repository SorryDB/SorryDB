  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    sorry
  sSup_eq_top' := by
    sorry
  not_bot_mem' := by simp [Set.mem_iUnion, hB'']

/-- The direct sum decomposition `refinement B hB hB' hB''` is a refinement of `D` -/
lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ @DirectSumDecomposition.refinement C inst✝¹ K inst✝ M D B hB hB' hB'' := by
  apply IsRefinement.mpr
  intro N hN
  refine' ⟨B N (show N ∈ D by assumption), ?_, ?_⟩
  · -- Show that B N (show N ∈ D by assumption) is a subset of the refinement's carrier
    simp [Set.mem_iUnion]
  · -- Show that N = sSup (B N (show N ∈ D by assumption))
    exact hB N (show N ∈ D by assumption)
