    have hk : ÔêÇ x, Ôêâ f' : k x ÔşÂ n, _ := fun x ÔåĞ Set.mem_iUnionÔéé.1 (hs' x).choose_spec
    let f' := fun x ÔåĞ (hk x).choose
    have hf' : ÔêÇ x, s (f' x) Ôêğ x Ôêê Set.range (f' x).1 :=
      fun x ÔåĞ exists_prop.1 (hk x).choose_spec
    let f'' := fun x ÔåĞ f (f' x) (hf' x).1 (hf' x).2.choose
    have hf'' : ÔêÇ l (g : l ÔşÂ n) (hg : s g), f'' Ôêİ g = f g hg := fun l g hg ÔåĞ by
      ext x
      dsimp [f'']
      have h := @hf _ _ 0 (DSmoothMap.const _ (hf' (g x)).2.choose)
        (DSmoothMap.const _ x) _ _ (hf' (g x)).1 hg
        (by ext; exact (hf' (g x)).2.choose_spec)
      exact DFunLike.congr_fun h 0
    refine Ôş¿Ôş¿f'', ?_Ôş®, ?_, ?_Ôş®
    ┬À refine dsmooth_iff_locally_dsmooth.2 fun x : n ÔåĞ
        Ôş¿_, (hs.1 _ _ (hf' x).1).isOpen_range, (hf' x).2, ?_Ôş®
      rw [(DDiffeomorph.ofIsInduction (hs.1 _ _ (hf' x).1).1).isSubduction.dsmooth_iff]
      convert (f (f' x) (hf' x).1).2; exact hf'' (k x) (f' x) (hf' x).1
    ┬À intro l g hg; ext x; exact congr_fun (hf'' l g hg) _
    ┬À intro f''' hf'''; ext (x : n)
      rw [ÔåÉ (hf' x).2.choose_spec]
      exact (DFunLike.congr_fun (f''' (f' x) (hf' x).1) _).trans
        (congr_fun (hf'' _ (f' x) (hf' x).1) _).symmÔş®
  map f := Ôş¿{
    app := fun _ g ÔåĞ f.hom.comp g
    naturality := fun _ _ _ ÔåĞ rfl
  }Ôş®
  map_id := fun _ ÔåĞ rfl
  map_comp := fun _ _ ÔåĞ rfl

/-- `DiffSp.toSmoothSp` is fully faithful. -/
def DiffSp.toSmoothSp.fullyFaithful : DiffSp.toSmoothSp.{u}.FullyFaithful where
  preimage f := ofHom Ôş¿fun x ÔåĞ
      (by exact f.val.app (.op 0) Ôş¿fun _ ÔåĞ x, dsmooth_constÔş® : DSmoothMap (Eucl 0) _) 0, by
    intro n p hp; convert (f.val.app (.op n) Ôş¿p, hp.dsmoothÔş®).dsmooth.isPlot using 1; ext x
    exact DFunLike.congr_fun (F := DSmoothMap _ _) (congrFun (f.val.naturality Ôş¿fun _ ÔåĞ x, dsmooth_constÔş®) Ôş¿p, hp.dsmoothÔş®) 0Ôş®
  map_preimage f := by
    apply Sheaf.Hom.ext; ext n p; refine DSmoothMap.ext fun x ÔåĞ ?_
    exact DFunLike.congr_fun (F := DSmoothMap _ _) (congrFun (f.val.naturality Ôş¿fun _ : Eucl 0 ÔåĞ x, dsmooth_constÔş®) p) 0

instance : DiffSp.toSmoothSp.{u}.Full := DiffSp.toSmoothSp.fullyFaithful.full

instance : DiffSp.toSmoothSp.{u}.Faithful := DiffSp.toSmoothSp.fullyFaithful.faithful

/-- The global sections functor taking a smooth space to its type of points. Note that this
is by no means faithful; `SmoothSp` is not a concrete category. -/
def SmoothSp.╬ô : SmoothSp.{u} ÔÑñ Type u where
  obj X := X.val.obj (.op 0)
  map f := f.val.app (.op 0)
  map_id := fun _ ÔåĞ by rfl
  map_comp := fun _ _ ÔåĞ by rfl

/-- The diffeology on the points of a smooth space given by the concretisation functor. -/
instance SmoothSp.instDiffeologicalSpace╬ô (X : SmoothSp) : DiffeologicalSpace (╬ô.obj X) :=
  .generateFrom {Ôş¿n,pÔş® | Ôêâ (p' : X.val.obj (.op n)),
    p = fun x : Eucl n ÔåĞ X.val.map (Opposite.op Ôş¿fun _ : Eucl 0 ÔåĞ x, dsmooth_constÔş®) p'}

/-- The reflector of `DiffSp` inside of `SmoothSp`, sending a smooth space to its concretisation. -/
def SmoothSp.concr : SmoothSp.{u} ÔÑñ DiffSp.{u} where
  obj X := DiffSp.of (╬ô.obj X)
  map f := DiffSp.ofHom Ôş¿fun p : DSmoothMap _ _ ÔåĞ p 0,
    dsmooth_generateFrom_iff.2 fun _ p Ôş¿p', hpÔş® ÔåĞ by rw [hp]; exact p'.dsmooth.isPlotÔş®
  map_id := fun _ ÔåĞ by rfl
  map_comp := fun _ _ ÔåĞ by rfl

/-- The adjunction between the concretisation functor `SmoothSp ÔÑñ DiffSp` and the
embedding `DiffSp ÔÑñ SmoothSp`. -/
noncomputable def DiffSp.reflectorAdjunction : SmoothSp.concr.{u} Ôèú DiffSp.toSmoothSp.{u} :=
  Adjunction.mkOfUnitCounit {
    unit := {
      app := fun X ÔåĞ Ôş¿{
        app := fun _ p ÔåĞ Ôş¿fun x ÔåĞ X.val.map (Opposite.op Ôş¿fun _ : Eucl 0 ÔåĞ x, dsmooth_constÔş®) p,
          IsPlot.dsmooth (DiffeologicalSpace.isPlot_generateFrom_of_mem Ôş¿p, rflÔş®)Ôş®
        naturality := fun Ôş¿nÔş® Ôş¿mÔş® f ÔåĞ by
          ext p; refine DSmoothMap.ext fun x ÔåĞ ?_
          change X.val.map (Opposite.op Ôş¿fun _ : Eucl 0 ÔåĞ x, dsmooth_constÔş®) (X.val.map f p) =
            X.val.map (Opposite.op Ôş¿fun _ : Eucl 0 ÔåĞ x, dsmooth_constÔş®) p
          exact congrFun (X.val.map_comp f _).symm p
      }Ôş®
      naturality := fun {X Y} f ÔåĞ by
        apply Sheaf.Hom.ext; ext n p; refine DSmoothMap.ext fun x ÔåĞ ?_
        dsimp at p Ôèó
        change Y.val.map (Opposite.op Ôş¿fun _ : Eucl 0 ÔåĞ x, dsmooth_constÔş®) (f.val.app n p) =
          f.val.app (.op 0) (X.val.map _ _)
        exact congrFun (f.val.naturality _).symm p
    }
    counit := {
      app := fun X ÔåĞ DiffSp.ofHom Ôş¿fun p : DSmoothMap _ _ ÔåĞ p 0,
        dsmooth_generateFrom_iff.2 fun _ p Ôş¿p', hpÔş® ÔåĞ by rw [hp]; exact p'.dsmooth.isPlotÔş®
      naturality := fun _ _ _ ÔåĞ rfl
    }
    left_triangle := by
      ext X x; change X.val.obj (.op 0) at x
      change X.val.map _ x = x
      rw [ÔåÉ show DSmoothMap.id (X := Eucl 0) = Ôş¿fun x ÔåĞ 0, dsmooth_constÔş® by
        ext1 x; exact (Unique.eq_default x).trans (Unique.default_eq 0)]
      exact congrFun (X.val.map_id (.op 0) : _ = id) x
    right_triangle := rfl
  }

/-- `SmoothSp.concr` is a left-adjoint. In particular, this means that it preserves colimits. -/
instance : Functor.IsLeftAdjoint SmoothSp.concr :=
  Ôş¿DiffSp.toSmoothSp, Ôş¿DiffSp.reflectorAdjunctionÔş®Ôş®

/-- Diffeological spaces form a reflective subcategory of the category of smooth spaces. -/
noncomputable instance DiffSp.toSmoothSp.reflective : Reflective toSmoothSp where
  L := SmoothSp.concr
  adj := DiffSp.reflectorAdjunction

noncomputable instance DiffSp.toSmoothSp.createsLimits : CreatesLimits toSmoothSp :=
  monadicCreatesLimits _

