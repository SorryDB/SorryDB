    apply Sheaf.Hom.ext; ext n p; refine DSmoothMap.ext fun x ÔåĞ ?_
    exact DFunLike.congr_fun (F := DSmoothMap _ _)
      (congrFun (f.val.naturality Ôş¿fun _ : Eucl 0 ÔåĞ x, dsmooth_constÔş®) p) 0

