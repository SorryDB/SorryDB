import Mathlib
set_option linter.unusedVariables false

noncomputable section

namespace ItaLean



/-!
# Filters
-/



open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro S hS
  rcases hS with ⟨A, hA, hS⟩
  have hA' : A ∈ F := by 
    exact h hA
  use A 
  constructor
  · exact hA'
  · rw [hS]
    all_goals try simp
```
