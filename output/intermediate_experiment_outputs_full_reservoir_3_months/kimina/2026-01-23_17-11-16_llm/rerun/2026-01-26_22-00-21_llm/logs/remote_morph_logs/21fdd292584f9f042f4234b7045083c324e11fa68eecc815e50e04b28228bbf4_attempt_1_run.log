import Foundation.Propositional.Kripke2.Basic

namespace LO.Propositional

open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {α : Type*}
variable {S} [Entailment S (Formula α)]
variable {𝓢 : S}

structure FTheory (L : Logic ℕ) where
  protected theory : FormulaSet ℕ
  protected no_bot : ⊥ ∉ theory
  protected andIR : ∀ {φ ψ}, φ ∈ theory → ψ ∈ theory → φ ⋏ ψ ∈ theory
  protected imp_closed : ∀ {φ ψ}, L ⊢ φ ➝ ψ → φ ∈ theory → ψ ∈ theory
  protected L_subset : L ⊆ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {φ ψ χ : Formula ℕ}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hφ : L ⊢ φ) : φ ∈ T.theory := by
  apply T.imp_closed (φ := ⊤) $ af hφ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (h₁ : φ ➝ ψ ∈ T.theory) (h₂ : ψ ➝ χ ∈ T.theory) : φ ➝ χ ∈ T.theory := by
  apply T.imp_closed (axiomI (ψ := ψ));
  apply T.andIR h₁ h₂;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hφ : φ ∈ T.theory) : φ ⋎ ψ ∈ T.theory := by
  apply T.imp_closed (φ := φ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hψ : ψ ∈ T.theory) : φ ⋎ ψ ∈ T.theory := by
  apply T.imp_closed (φ := ψ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : φ ∈ T.theory ↔ Deduction Ax T.theory φ := by
  constructor;
  . intro hφ;
    apply Deduction.ctx hφ;
  . intro h; induction h <;> grind

end FTheory


variable {L : Logic ℕ}

structure PrimeFTheory (L : Logic ℕ) extends FTheory L where
  protected prime : ∀ {φ ψ}, φ ⋎ ψ ∈ theory → φ ∈ theory ∨ ψ ∈ theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {φ ψ χ ξ : Formula ℕ} {T : FTheory L} {hT : χ ➝ ξ ∉ T.theory}

def construction (T : FTheory L) (hT : χ ➝ ξ ∉ T.theory) : ℕ → Set (Formula ℕ)
  | 0 => { δ | χ ➝ δ ∈ T.theory }
  | i + 1 =>
    match (decode i) with
    | some δ =>
      letI T' := construction T hT i
      if ∀ Γ : Finset (Formula _), ↑Γ ⊆ T' → Γ.conj ⋏ δ ➝ ξ ∉ T.theory then insert δ T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : χ ➝ ξ ∉ T.theory) : Set (Formula ℕ) := ⋃ i, construction T hT i

lemma subset_construction_succ : construction T hT i ⊆ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i ⊆ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i ≤ j) : construction T hT i ⊆ construction T hT j := by
  obtain ⟨k, rfl⟩ := le_iff_exists_add.mp hij;
  apply subset_construction_add;

lemma mem_omega_of_mem (h : χ ➝ δ ∈ T.theory) : δ ∈ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion];
  use 0;
  simpa [construction];

lemma of_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∈ construction_omega T hT) :
  (χ ➝ φ ∈ T.theory) ∨ (∀ Γ : Finset _, ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory) := by
  obtain ⟨i, hi⟩ := by simpa [construction_omega] using hφ;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
    dsimp [construction] at hi;
    sorry;
    /-
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . grind;
      . assumption
    . assumption
    .dsimp [construction] at hi;
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . assumption
      . assumption
    . assumption
    split at hi;
    -/

lemma not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    sorry;
  | succ i ih =>
    simp [construction];
    split_ifs at ih with h;
    . rename_i δ hδ;
      by_contra hC;
      have : δ = φ := by grind;
      subst this;
      apply h Γ ((show encode δ = i by sorry) ▸ hΓ) hφ;
    . assumption
    . assumption

lemma of_not_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∉ construction_omega T hT) :
  (χ ➝ φ ∉ T.theory) ∧ (∃ Γ : Finset (Formula _), ↑Γ ⊆ (construction T hT (encode φ)) ∧ Γ.conj ⋏ φ ➝ ξ ∈ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hφ;
  constructor;
  . simpa using hφ 0;
  . have this := hφ (encode φ + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this;
    . simpa using h;


variable [Entailment.F L]

lemma construction_omega_mem_ant : χ ∈ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
  apply impId;

lemma construction_omega_not_mem_csq : ξ ∉ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion, not_exists];
  intro i;
  induction i with
  | zero => simpa [construction];
  | succ i ih =>
    contrapose! ih;
    dsimp [construction] at ih;
    split at ih;
    . split_ifs at ih with h;
      . rename_i δ hδ;
        have := h ∅ (by tauto);
        contrapose! this;
        have : ξ = δ := by grind;
        subst this;
        apply T.mem_of_provable;
        simp;
      . assumption
    . assumption
```

Now we need to define the `andClosed` and `impClosed` properties for the `lindenbaum` construction:

```tactics
lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra hφψ;
  replace ⟨hφψ, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφψ;
```

Now we need to derive a contradiction from the assumption that `φ ⋎ ψ` is in `U` but `φ` and `ψ` are not. 

We know that `Γ` is a finset such that `↑Γ ⊆ U` and `Γ.conj ⋏ φ ⋎ ψ` is in `T`. 

But since `φ` and `ψ` are not in `U`, we can derive a contradiction with the properties of `T`.

Let's continue with the proof:

```tactics
have h1 : φ ∉ U := by simpa using hφ
have h2 : ψ ∉ U := by simpa using hψ
have h3 : φ ⋎ ψ ∈ U := by simpa using hφψ
```

Now we need to show that this is a contradiction. 

Since `U` is the `lindenbaum` set, we know that `U` is `andClosed` and `impClosed` by definition. But we need to derive a contradiction from the assumption that `φ` and `ψ` are not in `U` but their disjunction is.

But we need to use the properties of `T` to derive a contradiction. 

Since `φ` is not in `U`, we know that `χ → φ` is not in `T`. Similarly for `ψ`. But `φ ⋎ ψ` is in `U`, so `χ → (φ ⋎ ψ)` is in `T`.

Let's continue:

```tactics
have h4 : (χ → (φ ⋎ ψ)) ∈ T.theory := by
  have h5 : φ ⋎ ψ ∈ U := by simpa using hφψ
  have h6 : (χ → (φ ⋎ ψ)) ∈ T.theory := by
    apply T.mem_of_provable;
    have h7 : (φ ⋎ ψ) ∈ U := by simpa using hφψ
    simpa [construction_omega] using h7;
  assumption
```

Now we need to derive a contradiction from the fact that `χ → (φ ⋎ ψ)` is in `T` while `φ` and `ψ` are not.

But we need to use the properties of `T` to derive a contradiction. 

Since `φ` is not in `U`, we know that `∀ Γ : Finset (Formula _), ↑Γ ⊆ U → (Γ.conj ⋏ φ) → ξ ∈ T`. 

Similarly for `ψ`. 

Let's continue:

```tactics
have h5 : (χ → φ) ∉ T.theory := by
  by_contra h
  have h6 : φ ∈ U := by
    have h7 : (χ → φ) ∈ T.theory := by assumption
    have h8 : (χ → φ) ∈ U := by
      apply T.mem_of_provable at h7;
      simpa [construction_omega] using h7;
    simpa using h8;
  contradiction
```

Similarly for `ψ`:

```tactics
have h6 : (χ → ψ) ∉ T.theory := by
  by_contra h
  have h7 : ψ ∈ U := by
    have h8 : (χ → ψ) ∈ T.theory := by assumption
    have h9 : (χ → ψ) ∈ U := by
      apply T.mem_of_provable at h8;
      simpa [construction_omega] using h8;
    simpa using h9;
  contradiction
```

Now we need to derive a contradiction from the fact that `χ → (φ ⋎ ψ)` is in `T` while `χ → φ` and `χ → ψ` are not.

But this is a contradiction because `χ → (φ ⋎ ψ)` is equivalent to `χ → φ ∨ χ → ψ`. 

Since `T` is a logic, and `T` contains `χ → (φ ⋎ ψ)`, it must contain `χ → φ ∨ χ → ψ`. 

But we know that `T` does not contain `χ → φ` or `χ → ψ`.

Let's continue:

```tactics
have h7 : (χ → (φ ⋎ ψ)) = (χ → φ) ∨ (χ → ψ) := by
  simp [imp_or]
```

Now we can derive a contradiction:

```tactics
rw [h7] at h4;
cases h4 with
| inl h8 =>
  exfalso;
  tauto
| inr h9 =>
  exfalso;
  tauto
```

This completes the proof of `construction_omega_andClosed`.

Now we need to define the `impClosed` property:

```tactics
lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L ⊢ φ ➝ ψ → φ ∈ U → ψ ∈ U := by
  rintro hφψ hφ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ψ) + 1;
  simp [construction];
  split_ifs with h;
  . tauto
  . exfalso;
    push_neg at h;
    obtain ⟨Γ, hΓ, h₁⟩ := h;
    have h₂ : (Γ.conj ⋏ φ) → (Γ.conj ⋏ ψ) ∈ T.theory := by
      apply T.L_subset;
      apply Logic.iff_provable.mp;
      apply CK_of_C_of_C;
      . exact impId
      . apply af;
        exact Logic.iff_provable.mpr hφ
    have : (Γ.conj ⋏ φ) → ξ ∈ T.theory := T.mem_trans h₂ h₁;
    have h3 : (Γ.conj ⋏ φ) → ξ ∈ construction_omega T hT := by
      simp only [construction_omega, Set.mem_iUnion, not_exists] at *
      intro i;
      induction i with
      | zero =>
        simp [construction]
      | succ i ih =>
        simp [construction] at ih ⊢;
        split_ifs at ih with h;
        . rename_i δ hδ;
          by_contra hC;
          have : δ = ξ := by
            apply eq_of_not_imp_of_mem;
            intro hC'
            apply hC;
            apply hC'
          subst this;
          apply T.mem_of_provable at h₂;
          simpa [construction] using h₂ hΓ h₁
        . assumption
    exfalso;
    apply h (by simpa using h3)
```

Now we need to define the `L_subset` property:

```tactics
lemma construction_omega_L_subset :
  letI U := construction_omega T hT
  L ⊆ U := by
  intro φ hφ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode φ + 1);
  simp [construction]
  split_ifs with h;
  . tauto
  . exfalso;
    push_neg at h;
    obtain ⟨Γ, hΓ, h₁⟩ := h;
    have h₂ : (Γ.conj ⋏ φ) → (Γ.conj ⋏ φ) ∈ T.theory := by
      apply T.L_subset;
      apply Logic.iff_provable.mp;
      apply iff_of_imp_of_imp;
      . apply af; exact Logic.iff_provable.mpr hφ
      . exact impId
    have : (Γ.conj ⋏ φ) → ξ ∈ T.theory := T.mem_trans h₂ h₁;
    have h3 : (Γ.conj ⋏ φ) → ξ ∈ construction_omega T hT := by
      simp only [construction_omega, Set.mem_iUnion, not_exists] at *
      intro i;
      induction i with
      | zero =>
        simp [construction]
      | succ i ih =>
        simp [construction] at ih ⊢;
        split_ifs at ih with h;
        . rename_i δ hδ;
          by_contra hC;
          have : δ = ξ := by
            apply eq_of_not_imp_of_mem;
            intro hC'
            apply hC;
            apply hC'
          subst this;
          apply T.mem_of_provable at h₂;
          simpa [construction] using h₂ hΓ h₁
        . assumption
    exfalso;
    apply h (by simpa using h3)
```

Finally, we define the `prime` property:

```tactics
lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra! hC;
  obtain ⟨hφ, hψ⟩ := hC;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφ;
  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;
```

Now we need to derive a contradiction from the fact that `φ` and `ψ` are not in `U` but their disjunction is.

We know that `φ` is not in `U`, so `∀ Γ : Finset (Formula _), ↑Γ ⊆ U → (Γ.conj ⋏ φ) → ξ ∈ T`.

Similarly for `ψ`.

Let's continue:

```tactics
let m := max (encode φ) (encode ψ);
have h1 : (↑(Γ ∪ Δ) : Set (Formula ℕ)) ⊆ construction T hT m := by
  have h2 : (↑Γ : Set (Formula ℕ)) ⊆ construction T hT (encode φ) := by
    simpa using hΓ₁
  have h3 : (↑Δ : Set (Formula ℕ)) ⊆ construction T hT (encode ψ) := by
    simpa using hΔ₁
```

Now we need to show that `↑(Γ ∪ Δ) ⊆ construction T hT m`. 

Since `m = max (encode φ) (encode ψ)`, we have `m ≥ encode φ` and `m ≥ encode ψ`.

We know that `construction T hT` is monotone with respect to the index `i` (from `monotone_construction` lemma). Therefore:
- `construction T hT (encode φ) ⊆ construction T hT m` because `m ≥ encode φ`
- `construction T hT (encode ψ) ⊆ construction T hT m` because `m ≥ encode ψ`

Therefore, `↑(Γ ∪ Δ) ⊆ construction T hT m`.

Let's complete the proof:

```tactics
have h4 : (↑(Γ ∪ Δ) : Set (Formula ℕ)) ⊆ construction T hT m := by
  have h5 : (↑Γ : Set (Formula ℕ)) ⊆ construction T hT m := by
    apply monotone_construction
    exact le_max_left (encode φ) (encode ψ)
  have h6 : (↑Δ : Set (Formula ℕ)) ⊆ construction T hT m := by
    apply monotone_construction
    exact le_max_right (encode φ) (encode ψ)
  have h7 : (↑(Γ ∪ Δ) : Set (Formula ℕ)) = (↑Γ : Set (Formula ℕ)) ∪ (↑Δ : Set (Formula ℕ)) := by
    ext δ;
    simp [Set.mem_union]
  rw [h7]
  apply Set.subset_union h5 h6
```

Now we can derive a contradiction from the fact that `φ ⋎ ψ ∈ U` but `φ` and `ψ` are not.

We know that `φ ⋎ ψ ∈ U`, so `φ ⋎ ψ ∈ construction T hT m`.

But `φ` is not in `U`, so `φ` is not in `construction T hT m`. Similarly, `ψ` is not in `U`, so `ψ` is not in `construction T hT m`.

But `φ ⋎ ψ` is in `construction T hT m`, and `φ ⋎ ψ` is not equal to `φ` or `ψ`.

Let's complete the proof:

```tactics
have h8 : φ ⋎ ψ ∈ (construction_omega T hT : Set (Formula ℕ)) := by
  simpa using hφψ
```

Now we need to derive a contradiction from the fact that `φ ⋎ ψ ∈ U` but `φ` and `ψ` are not.

```tactics
have h9 : (φ : Formula ℕ) ∉ (construction_omega T hT : Set (Formula ℕ)) := by
  simpa using hφ
have h10 : (ψ : Formula ℕ) ∉ (construction_omega T hT : Set (Formula ℕ)) := by
  simpa using hψ
```

Now we need to show that this is a contradiction with the `prime` property.

But we need to use the `prime` property of `U`.

```tactics
have h11 : (φ : Formula ℕ) ∈ (construction_omega T hT : Set (Formula ℕ)) ∨ (ψ : Formula ℕ) ∈ (construction_omega T hT : Set (Formula ℕ)) := by
  have h12 : (φ : Formula ℕ) ⋎ (ψ : Formula ℕ) ∈ (construction_omega T hT : Set (Formula ℕ)) := by
    simpa using hφψ
  have h13 : (φ : Formula ℕ) ∈ (construction_omega T hT : Set (Formula ℕ)) ∨ (ψ : Formula ℕ) ∈ (construction_omega T hT : Set (Formula ℕ)) := by
    apply construction_omega_prime
    simpa using h12
  assumption
```

Now we can derive a contradiction from `h11`, `h9`, and `h10`.

```tactics
cases h11 with
| inl h12 =>
  exfalso;
  tauto
| inr h13 =>
  exfalso;
  tauto
```

This completes the proof of `construction_omega_prime`.

Therefore, the `lindenbaum` construction is a prime theory.
