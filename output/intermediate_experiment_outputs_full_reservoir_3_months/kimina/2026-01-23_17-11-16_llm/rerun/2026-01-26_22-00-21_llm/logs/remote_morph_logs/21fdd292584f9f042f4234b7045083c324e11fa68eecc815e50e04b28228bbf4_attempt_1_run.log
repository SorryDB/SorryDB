    have h₂ : (Γ.conj ⋏ φ) ➝ (Γ.conj ⋏ ψ) ∈ T.theory := T.mem_of_provable $ by
      sorry;
    have : (Γ.conj ⋏ φ) ➝ ξ ∈ T.theory := T.mem_trans h₂ h₁;
    have : (Γ.conj ⋏ φ) ∈ construction T hT (encode ψ + 1) := by sorry;
    sorry;

