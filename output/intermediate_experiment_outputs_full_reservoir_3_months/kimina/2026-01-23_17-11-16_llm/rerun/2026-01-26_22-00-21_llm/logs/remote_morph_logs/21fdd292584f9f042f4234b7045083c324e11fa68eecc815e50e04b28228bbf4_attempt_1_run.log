      have h2 : γ ∈ construction T hT m := by
        have h3 : construction T hT (encode ψ) ⊆ construction T hT m := by
          apply monotone_construction;
          apply le_max_right;
        exact h3 h1;
      exact h2;
  have h3 : (φ ⋎ ψ) ∈ construction T hT m := by
    simpa using hφψ;
  have h4 : φ ∈ construction T hT m ∨ ψ ∈ construction T hT m := by
    apply U.prime h3;
  cases h4 with
