        have := h вИЕ (by tauto);
        contrapose! this;
        have : ќЊ = ќі := by grind;
        subst this;
        apply T.mem_of_provable;
        simp;
      . assumption
    . assumption
    . assumption
    . assumption
    . assumption
    . assumption

