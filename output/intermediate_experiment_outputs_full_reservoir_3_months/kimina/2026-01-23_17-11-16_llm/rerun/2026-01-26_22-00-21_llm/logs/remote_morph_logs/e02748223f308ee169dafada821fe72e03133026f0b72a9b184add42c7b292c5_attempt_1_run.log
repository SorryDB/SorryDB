  have h8 := hќУвВВ (Finset.singleton (ѕЖ вЖТ ѕИ)) (by simp; assumption); 
  have h9 := hќУвВБ (Finset.singleton (ѕЖ вИІ ѕИ)) (by simp; assumption); 
  have h10 := hќУвВВ (Finset.singleton (ѕЖ вИІ ѕИ)) (by simp; assumption); 
  have h11 := hќУвВБ (Finset.singleton (ѕЖ вИ® ѕИ)) (by simp; assumption); 
  have h12 := hќУвВВ (Finset.singleton (ѕЖ вИ® ѕИ)) (by simp; assumption); 
