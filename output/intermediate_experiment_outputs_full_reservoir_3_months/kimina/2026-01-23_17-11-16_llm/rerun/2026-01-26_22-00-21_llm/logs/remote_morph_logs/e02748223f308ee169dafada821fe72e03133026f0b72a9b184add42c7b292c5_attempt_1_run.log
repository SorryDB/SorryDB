  simp [construction];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain вЯ®ќУ, hќУ, hќУвВВвЯ© := h;
    have hќУвВБ : (ќУ.conj вЛП ѕЖ) вЖТ (ќУ.conj вЛП ѕИ) вИИ T := T.mem_of_provable $ by
