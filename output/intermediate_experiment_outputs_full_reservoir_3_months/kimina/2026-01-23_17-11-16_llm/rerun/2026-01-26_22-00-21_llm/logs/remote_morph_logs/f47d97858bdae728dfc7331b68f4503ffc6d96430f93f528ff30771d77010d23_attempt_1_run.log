theorem Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ‚ąą D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra hNotMax
  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ‚ü®x, y, hxy, rfl, hx, hy‚ü© := hNotMax
  let B : ‚ąÄ N ‚ąą D, Set (PersistenceSubmodule M) := fun N hN =>
    if N = x ‚äĒ y then {x, y} else
    if N = ‚ä• then ‚ąÖ else
    {N}
  let E := @DirectSumDecomposition.refinement C inst‚úĚ¬Ļ K inst‚úĚ M D B
  have h1 : IsRefinement E D := by
    intro N hN
    rcases hN with ‚ü®N, hN‚ü©
    by_cases hN' : N = x ‚äĒ y
    ¬∑ -- Case where N = x ‚äĒ y
      use {x, y}
      simp [hN']
      constructor
      ¬∑ -- Show {x, y} ‚äÜ E
        intro P hP
        simp at hP
        rcases hP with (hP | hP)
        ¬∑ -- P = x
          have h2 : x ‚ąą D := by
            have h3 : x ‚äĒ y ‚ąą D := hN
            have h4 : x ‚Č§ x ‚äĒ y := by simp [upperBounds]
            have h5 : x ‚ąą D := by
              apply (D.mem_iff_le_sSup (by simp)).mp
              apply le_trans h4
              apply le_sSup (by simp)
            exact h5
          have h3 : x ‚ąą E := by
            simpa using h2
          exact h3
        ¬∑ -- P = y
          have h2 : y ‚ąą D := by
            have h3 : x ‚äĒ y ‚ąą D := hN
            have h4 : y ‚Č§ x ‚äĒ y := by simp [upperBounds]
            have h5 : y ‚ąą D := by
              apply (D.mem_iff_le_sSup (by simp)).mp
              apply le_trans h4
              apply le_sSup (by simp)
            exact h5
          have h3 : y ‚ąą E := by
            simpa using h2
          exact h3
      ¬∑ -- Show N = sSup {x, y}
        rw [hN']
        have h2 : sSup ({x, y} : Set (PersistenceSubmodule M)) = x ‚äĒ y := by
          simp [sSup_pair, disjoint_iff_inter_eq_empty, hxy]
        rw [h2]
        all_goals try simp
    ¬∑ -- Case where N ‚Č† x ‚äĒ y
      by_cases hN'' : N = ‚ä•
      ¬∑ -- Case where N = ‚ä•
        use ‚ąÖ
        simp [hN'']
        all_goals try simp
      ¬∑ -- Case where N ‚Č† ‚ä• and N ‚Č† x ‚äĒ y
        use {N}
        simp [hN', hN'']
        all_goals try simp
  have h2 : E < D := by
    have h3 : IsRefinement E D := h1
    have h4 : E ‚Č† D := by
      by_contra h
      have h5 : x ‚ąą E := by
        have h6 : x ‚ąą D := by
          have h7 : x ‚äĒ y ‚ąą D := hN
          have h8 : x ‚Č§ x ‚äĒ y := by simp [upperBounds]
          have h9 : x ‚ąą D := by
            apply (D.mem_iff_le_sSup (by simp)).mp
            apply le_trans h8
            apply le_sSup (by simp)
          exact h9
        rw [show E = D by tauto] at *
        exact h6
      have h6 : x ‚ąą B x (by exact h6) := by
        simpa using h5
      simp at h6
      all_goals try { tauto }
    have h5 : E ‚Č§ D := by
      apply D.le_of_isRefinement
      exact h1
    exact lt_of_le_of_ne h5 h4
  have h6 : E = D := by
    have h7 : E ‚Č• D := by
      apply hmax.le_of_isRefinement
      exact h1
    have h8 : E ‚Č§ D := by
      apply D.le_of_isRefinement
      exact h1
    have h9 : E = D := by
      apply le_antisymm
      all_goals try { tauto }
    exact h9
  have h7 : E < D := h2
  exact h7.ne h6
