on the imaginary axis.
-/
noncomputable def F := (EтВВ * EтВД.toFun - EтВЖ.toFun) ^ 2

noncomputable def G := HтВВ ^ 3 * (2 * HтВВ ^ 2 + 5 * HтВВ * HтВД + 5 * HтВД ^ 2)

noncomputable def negDEтВВ := - (D EтВВ)

noncomputable def ╬Ф_fun := 1728тБ╗┬╣ * (EтВД.toFun ^ 3 - EтВЖ.toFun ^ 2)

noncomputable def LтВБтВА := (D F) * G - F * (D G)

noncomputable def SerreDer_22_LтВБтВА := serre_D 22 LтВБтВА

noncomputable def FReal (t : тДЭ) : тДЭ := (F.resToImagAxis t).re

noncomputable def GReal (t : тДЭ) : тДЭ := (G.resToImagAxis t).re

noncomputable def FmodGReal (t : тДЭ) : тДЭ := (FReal t) / (GReal t)

theorem F_eq_FReal {t : тДЭ} (ht : 0 < t) : F.resToImagAxis t = FReal t := by sorry

theorem G_eq_GReal {t : тДЭ} (ht : 0 < t) : G.resToImagAxis t = GReal t := by sorry

theorem FmodG_eq_FmodGReal {t : тДЭ} (ht : 0 < t) :
    FmodGReal t = (F.resToImagAxis t) / (G.resToImagAxis t) := by sorry

