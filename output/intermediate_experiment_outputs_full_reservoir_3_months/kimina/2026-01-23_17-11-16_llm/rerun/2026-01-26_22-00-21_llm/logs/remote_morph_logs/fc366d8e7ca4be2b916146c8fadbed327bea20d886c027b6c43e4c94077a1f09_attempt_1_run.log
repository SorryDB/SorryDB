  have h : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) (EтВВ * EтВД.toFun - EтВЖ.toFun) := by
    exact MDifferentiable.sub (MDifferentiable.mul EтВВ_holo' EтВД.holo') EтВЖ.holo'
  rw [F, pow_two]
  exact MDifferentiable.mul h h

theorem G_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) G := by
  sorry

theorem SerreF_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) (serre_D 10 F) := by
  exact serre_D_differentiable F_holo

theorem SerreG_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) (serre_D 10 G) := by
  exact serre_D_differentiable G_holo

theorem FReal_Differentiable {t : тДЭ} (ht : 0 < t) : DifferentiableAt тДЭ FReal t := by
  sorry

theorem GReal_Differentiable {t : тДЭ} (ht : 0 < t) : DifferentiableAt тДЭ GReal t := by
  sorry

