  sorry

theorem F_aux : D F = 5 * 6тБ╗┬╣ * EтВВ ^ 3 * EтВД.toFun ^ 2 - 5 * 2тБ╗┬╣ * EтВВ ^ 2 * EтВД.toFun * EтВЖ.toFun
