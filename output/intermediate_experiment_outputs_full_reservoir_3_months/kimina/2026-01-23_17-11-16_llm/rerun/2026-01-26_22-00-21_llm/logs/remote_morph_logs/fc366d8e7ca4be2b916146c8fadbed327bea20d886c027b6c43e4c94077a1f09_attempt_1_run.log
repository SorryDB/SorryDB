on the imaginary axis.
-/
noncomputable def F := (EтВВ * EтВД.toFun - EтВЖ.toFun) ^ 2

noncomputable def G := HтВВ ^ 3 * (2 * HтВВ ^ 2 + 5 * HтВВ * HтВД + 5 * HтВД ^ 2)

noncomputable def negDEтВВ := - (D EтВВ)

noncomputable def ╬Ф_fun := 1728тБ╗┬╣ * (EтВД.toFun ^ 3 - EтВЖ.toFun ^ 2)

noncomputable def LтВБтВА := (D F) * G - F * (D G)

noncomputable def SerreDer_22_LтВБтВА := serre_D 22 LтВБтВА

noncomputable def FReal (t : тДЭ) : тДЭ := (F.resToImagAxis t).re

noncomputable def GReal (t : тДЭ) : тДЭ := (G.resToImagAxis t).re

noncomputable def FmodGReal (t : тДЭ) : тДЭ := (FReal t) / (GReal t)

theorem F_eq_FReal {t : тДЭ} (ht : 0 < t) : F.resToImagAxis t = FReal t := by sorry

theorem G_eq_GReal {t : тДЭ} (ht : 0 < t) : G.resToImagAxis t = GReal t := by sorry

theorem FmodG_eq_FmodGReal {t : тДЭ} (ht : 0 < t) :
    FmodGReal t = (F.resToImagAxis t) / (G.resToImagAxis t) := by sorry

/- Some basic facts -/
theorem F_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) F := by
  have h : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) (EтВВ * EтВД.toFun - EтВЖ.toFun) := by
    exact MDifferentiable.sub (MDifferentiable.mul EтВВ_holo' EтВД.holo') EтВЖ.holo'
  rw [F, pow_two]
  exact MDifferentiable.mul h h

theorem G_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) G := by
  sorry

theorem SerreF_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) (serre_D 10 F) := by
  exact serre_D_differentiable F_holo

theorem SerreG_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) (serre_D 10 G) := by
  exact serre_D_differentiable G_holo

theorem FReal_Differentiable {t : тДЭ} (ht : 0 < t) : DifferentiableAt тДЭ FReal t := by
  sorry

theorem GReal_Differentiable {t : тДЭ} (ht : 0 < t) : DifferentiableAt тДЭ GReal t := by
  sorry

theorem F_aux : D F = 5 * 6тБ╗┬╣ * EтВВ ^ 3 * EтВД.toFun ^ 2 - 5 * 2тБ╗┬╣ * EтВВ ^ 2 * EтВД.toFun * EтВЖ.toFun
    + 5 * 6тБ╗┬╣ * EтВВ * EтВД.toFun ^ 3 + 5 * 3тБ╗┬╣ * EтВВ * EтВЖ.toFun ^ 2 - 5 * 6тБ╗┬╣ * EтВД.toFun^2 * EтВЖ.toFun
    := by
  rw [F, D_sq, D_sub, D_mul]
  ┬╖ ring_nf
    rw [ramanujan_EтВВ, ramanujan_EтВД, ramanujan_EтВЖ]
    ext z
    simp
    ring_nf

  -- Holomorphicity of the terms
  ┬╖ exact EтВВ_holo'
  ┬╖ exact EтВД.holo'
  ┬╖ exact MDifferentiable.mul EтВВ_holo' EтВД.holo'
  ┬╖ exact EтВЖ.holo'
  ┬╖ exact MDifferentiable.sub (MDifferentiable.mul EтВВ_holo' EтВД.holo') EтВЖ.holo'

/--
Modular linear differential equation satisfied by $F$.
-/
theorem MLDE_F : serre_D 12 (serre_D 10 F) = 5 * 6тБ╗┬╣ * F + 7200 * ╬Ф_fun * negDEтВВ := by
  ext x
  rw [negDEтВВ, ╬Ф_fun, F, F_aux]
  simp [serre_D, EтВВ, EтВД, EтВЖ, D]
  ring_nf
```

