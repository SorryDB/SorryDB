theorem G_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) G := by
  sorry

theorem SerreF_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) (serre_D 10 F) := by
  exact serre_D_differentiable F_holo

theorem SerreG_holo : MDifferentiable ЁЭУШ(тДВ) ЁЭУШ(тДВ) (serre_D 10 G) := by
  exact serre_D_differentiable G_holo

