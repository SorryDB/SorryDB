  rw [eq_comm, min_eq_right_iff]
  exact hτ_le ω

theorem condExp_stoppedValue_ae_eq_stoppedProcess [Approximable 𝓕 μ] {n : ι}
    (h : Martingale X 𝓕 μ) (hRC : ∀ ω, RightContinuous (X · ω))
