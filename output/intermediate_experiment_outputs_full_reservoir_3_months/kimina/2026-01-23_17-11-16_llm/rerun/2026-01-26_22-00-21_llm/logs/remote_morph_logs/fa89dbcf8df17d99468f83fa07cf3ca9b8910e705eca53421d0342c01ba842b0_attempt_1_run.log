      · -- Show that `τ ⊓ σ` is a stopping time
        exact h1
      · -- Show that `τ` is a stopping time
        exact hτ
      · -- Show that `(τ ⊓ σ).measurableSpace ≤ τ.measurableSpace`
        exact h4
      all_goals
      -- Show that `∀ ω : Ω, (τ ⊓ σ) ω ≤ τ ω`
      intro ω
      have h6 : (τ ⊓ σ) ω ≤ τ ω := by
        intro ω
        simp [min_le_iff]
      simpa using h6
    have h6 : P[stoppedValue X τ | τ.measurableSpace] ≤ P[stoppedValue X τ | hσ.measurableSpace] := by
      apply P[condExp_le_condExp_of_mono]
      · -- Show that `hσ.measurableSpace ≤ τ.measurableSpace`
        intro s hs
        have h7 : s ∈ hσ.measurableSpace := by
          simpa using hs
        simp at h7 ⊢
        have h8 : s ∈ τ.measurableSpace := by
          apply hσ.measurableSpace_le _ (hσ.mem_s hs)
        simpa using h8
      all_goals
      -- Show that `hσ ≤ τ`
      intro ω
      have h8 : σ ω ≤ τ ω := by
        apply hσ.le_of_isStoppingTime hτ
      simpa using h8
    linarith
  exact h3
