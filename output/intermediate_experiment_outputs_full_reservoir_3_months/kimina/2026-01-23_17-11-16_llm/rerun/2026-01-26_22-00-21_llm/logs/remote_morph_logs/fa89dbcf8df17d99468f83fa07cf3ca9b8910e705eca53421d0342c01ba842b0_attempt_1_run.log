import Mathlib

open Filter TopologicalSpace Function
open scoped NNReal ENNReal Topology

namespace MeasureTheory

namespace Martingale

variable {ι Ω E : Type*} [LinearOrder ι] [TopologicalSpace ι] [OrderTopology ι]
  [OrderBot ι] [MeasurableSpace ι] [SecondCountableTopology ι] [BorelSpace ι] [MetrizableSpace ι]
  [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  [MeasurableSpace E] [BorelSpace E] [SecondCountableTopology E]
  {mΩ : MeasurableSpace Ω} {𝓕 : Filtration ι mΩ} {μ : Measure Ω} [IsFiniteMeasure μ]
  {X : ι → Ω → E} {τ σ : Ω → WithTop ι} {n : ι}

theorem Submartingale.stoppedValue_min_ae_le_condExp [PartialOrder E] [OrderClosedTopology E]
    [IsOrderedModule ℝ E] [IsOrderedAddMonoid E]
    (hX1 : Submartingale X 𝓕 P) (hX2 : ∀ ω, RightContinuous (X · ω)) {k : ι}
    (hτk : ∀ᵐ ω ∂P, τ ω ≤ k) (hσ : IsStoppingTime 𝓕 σ) (hτ : IsStoppingTime 𝓕 τ) :
    stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
  have h1 : IsStoppingTime 𝓕 (τ ⊓ σ) := by
    exact IsStoppingTime.meet hτ hσ
  have h2 : stoppedValue X (τ ⊓ σ) ≤ P[stoppedValue X τ|hσ.measurableSpace] := by
    have h3 : (τ ⊓ σ) ≤ σ := by
      intro ω
      simp [min_le_iff]
    have h4 : stoppedValue X (τ ⊓ σ) ≤ P[stoppedValue X σ|hσ.measurableSpace] := by
      apply hX1.le_condExp_of_le
      · -- Show that (τ ⊓ σ) is a stopping time
        exact h1
      · -- Show that σ is a stopping time
        exact hσ
      · -- Show that (τ ⊓ σ) ≤ σ
        intro ω
        simp [min_le_iff]
    have h5 : stoppedValue X (τ ⊓ σ) ≤ P[stoppedValue X τ|hτ.measurableSpace] := by
      apply hX1.le_condExp_of_le
      · -- Show that (τ ⊓ σ) is a stopping time
        exact h1
      · -- Show that τ is a stopping time
        exact hτ
      · -- Show that (τ ⊓ σ) ≤ τ
        intro ω
        simp [min_le_iff]
    have h6 : P[stoppedValue X τ|hσ.measurableSpace] ≥ P[stoppedValue X τ|hτ.measurableSpace] := by
      apply conditional_expectation_le_conditional_expectation
      · -- Show that hτ.measurableSpace ≤ hσ.measurableSpace
        intro s hs
        have h7 : s ∈ hτ.measurableSpace := by
          simpa using hs
        have h8 : s ∈ hσ.measurableSpace := by
          apply hσ.measurableSpace_le hτ.measurableSpace
          simpa using h7
        simpa using h8
      · -- Show that stoppedValue X τ is measurable with respect to hτ.measurableSpace
        simp [hτ.measurableSet]
    linarith [h5, h6]
  exact h2
```

