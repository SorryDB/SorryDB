lemma indepFun_rewardByCount_Iic (alg : Algorithm α ℝ) (ν : Kernel α ℝ) [IsMarkovKernel ν] (a : α)
    (n : ℕ) :
    (rewardByCount a (n + 1)) ⟂ᵢ[𝔓] fun ω i => rewardByCount a (↑i) ω := by
  have h1 : (rewardByCount a (n + 1)) ⟂ᵢ[𝔓] fun ω i ↦ rewardByCount a (↑i) ω := by
    have h2 : (rewardByCount a (n + 1)) ⟂ᵢ[PRS] fun ω i ↦ rewardByCount a (↑i) ω := by
      have h3 : ∀ i : Iic n, (rewardByCount a (↑i)) = rewardByCount a (↑i) := by
        intro i
        rfl
      have h4 : (rewardByCount a (n + 1)) = rewardByCount a (n + 1) := by rfl
      have h5 : (rewardByCount a (n + 1)) ⟂ᵢ[PRS] (fun ω i ↦ rewardByCount a (↑i) ω) := by
        apply Markov.indepFun_of_markov (fun i hi ↦ by
          simpa using h3 i) (by
          simpa using h4
          ) (by
            simpa using h3 0
          )
      simpa using h5
    simpa using h2
  simpa using h1

