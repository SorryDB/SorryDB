/- The weak continuity assumption neede for `HasRestrictedWeakType.hasLorentzType_helper`. -/
def WeaklyContinuous [TopologicalSpace őĶ] [ENorm őĶ] [ENorm őĶ'] [SupSet őĶ] [Preorder őĶ] (T : (őĪ ‚Üí őĶ) ‚Üí (őĪ' ‚Üí őĶ')) (p : ‚ĄĚ‚Č•0‚ąě) (őľ : Measure őĪ) (őĹ : Measure őĪ') : Prop :=
  ‚ąÄ {fs : ‚Ąē ‚Üí őĪ ‚Üí őĶ},
  MonotoneOn (fun (n : ‚Ąē) => ‚ÄĖT (fs n)‚ÄĖ‚āĀ) (univ : Set őĪ) ‚Üí
  Filter.Tendsto (fun (n : ‚Ąē) => ‚ÄĖT (fs n)‚ÄĖ‚āĀ) Filter.atTop (nhds ‚ÄĖT f‚ÄĖ‚āĀ) ‚Üí
  ‚ąÄ {f : őĪ ‚Üí őĶ}, Filter.Tendsto (fun (n : ‚Ąē) => f n) Filter.atTop (nhds f) ‚Üí
  eLpNorm (T f) 1 őĹ ‚Č§ Filter.limsup (fun n ‚Ü¶ eLpNorm (T (fs n)) 1 őĹ) Filter.atTop

theorem HasRestrictedWeakType.hasLorentzType [TopologicalSpace őĪ] {ūĚēā : Type*} /- [MeasurableSpace őĶ'] [BorelSpace őĶ'] -/
  --[ENormedAddMonoid őĶ']
