  ‚ąÄ {fs : ‚Ąē ‚Üí SimpleFunc őĪ őĶ} (_ : Monotone fs),
  let f := fun x ‚Ü¶ ‚®Ü n, (fs n) x;
  ‚ąÄ (_ : MemLorentz f p 1 őľ) (G : Set őĪ'),
    eLpNorm (T f) 1 (őĹ.restrict G) ‚Č§ Filter.limsup (fun n ‚Ü¶ eLpNorm (T ‚áĎ(fs n)) 1 (őĹ.restrict G)) Filter.atTop

theorem HasLorentzType.hasLorentzType_helper [TopologicalSpace őĶ'] [ENormedSpace őĶ']
  {p p' : ‚ĄĚ‚Č•0‚ąě} {őľ : Measure őĪ} {őĹ : Measure őĪ'} {c : ‚ĄĚ‚Č•0} (c_pos : 0 < c) {T : (őĪ ‚Üí ‚ĄĚ‚Č•0) ‚Üí őĪ' ‚Üí őĶ'}
  (hT : HasRestrictedWeakType T p p' őľ őĹ c) --(T_zero : eLpNorm (T 0) 1 őĹ = 0)
  (hpp' : p.HolderConjugate p')
  (weakly_cont_T : WeaklyContinuous T p őľ őĹ)
  {G : Set őĪ'} (hG : MeasurableSet G) (hG' : őĹ G < ‚ä§)
  (T_subadditive : ‚ąÄ (f g : őĪ ‚Üí ‚ĄĚ‚Č•0), (MemLorentz f p 1 őľ) ‚Üí (MemLorentz g p 1 őľ) ‚Üí
    eLpNorm (T (f + g)) 1 (őĹ.restrict G) ‚Č§ eLpNorm (T f) 1 (őĹ.restrict G) + eLpNorm (T g) 1 (őĹ.restrict G))
  (T_submult : ‚ąÄ (f : őĪ ‚Üí ‚ĄĚ‚Č•0) (a : ‚ĄĚ‚Č•0), eLpNorm (T (a ‚ÄĘ f)) 1 (őĹ.restrict G) ‚Č§ eLpNorm (a ‚ÄĘ T f) 1 (őĹ.restrict G))
  {f : őĪ ‚Üí ‚ĄĚ‚Č•0} (hf : Measurable f) (hf' : MemLorentz f p 1 őľ) :
      eLpNorm (T f) 1 (őĹ.restrict G) ‚Č§ (c / p) * eLorentzNorm f p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
  by_cases p_ne_top : p = ‚ąě
  ¬∑ sorry --TODO: check whether this works or whether it should be excluded
  by_cases p'_ne_top : p' = ‚ąě
  ¬∑ sorry --TODO: check whether this works or whether it should be excluded
  have hp : 1 ‚Č§ p := hpp'.one_le --use: should follow from hpp'
  have p_ne_zero : p ‚Č† 0 := hpp'.ne_zero --TODO: easy
  rw [eLorentzNorm_eq_eLorentzNorm' p_ne_zero p_ne_top] --TODO: assumptions on p
  revert f
  apply @Measurable.nnreal_induction _ m0
  ¬∑ intro f
    induction f using SimpleFunc.induction''
    ¬∑ rename_i a s hs
      /-
      by_cases a_ne_top : a = ‚ä§
      ¬∑ sorry --TODO: add new lemma what eLorentzNorm does with indicator functions; could also be used for the other part
      -/
      simp only [SimpleFunc.const_zero, SimpleFunc.coe_piecewise, SimpleFunc.coe_const,
        SimpleFunc.coe_zero, Set.piecewise_eq_indicator]
      have : s.indicator (Function.const őĪ a) = a ‚ÄĘ (s.indicator (fun _ ‚Ü¶ 1)) := by
        ext x
        simp only [Pi.smul_apply, smul_eq_mul]
        rw [‚Üź Set.indicator_const_mul]
        congr
        simp
      intro hf'
      calc _
        _ = eLpNorm (T (a ‚ÄĘ (s.indicator (fun _ ‚Ü¶ 1)))) 1 (őĹ.restrict G) := by
          congr 1
          ext x
          congr
        _ ‚Č§ ‚ÄĖa‚ÄĖ‚āĎ * eLpNorm (T ((s.indicator (fun _ ‚Ü¶ 1)))) 1 (őĹ.restrict G) := by
          rw [‚Üź eLpNorm_const_smul']
          --apply eLpNorm_mono_enorm_ae
          apply T_submult
        _ ‚Č§ ‚ÄĖa‚ÄĖ‚āĎ * (c * (őľ s) ^ p‚ĀĽ¬Ļ.toReal * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal) := by
          gcongr
          apply hT.without_finiteness p_ne_zero p_ne_top hpp'.symm.ne_zero p'_ne_top c_pos s G hs hG
        _ = c * (‚ÄĖa‚ÄĖ‚āĎ * őľ s ^ p‚ĀĽ¬Ļ.toReal) * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal := by ring
        _ = (c / p) * eLorentzNorm' (s.indicator (Function.const őĪ a)) p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
          rw [eLorentzNorm'_indicator (by simp) p_ne_zero p_ne_top]
          rw [‚Üź mul_assoc (c / p), ENNReal.div_mul_cancel p_ne_zero p_ne_top]
    ¬∑ rename_i f a s hs hfs hf hg
      /-
      by_cases a_ne_top : a = ‚ä§
      ¬∑ sorry --TODO: add new lemma what eLorentzNorm does with indicator functions; could also be used for the other part
      --have hf' : MemLorentz f p 1 őľ := by sorry --TODO: get this from hfg' and measurability of f and g
      --have hg' : MemLorentz g p 1 őľ := by sorry --TODO: use that g is an indicator function with finite value
      -/
      rw [SimpleFunc.coe_add]
      set g := SimpleFunc.piecewise s hs (SimpleFunc.const őĪ a) (SimpleFunc.const őĪ 0) with g_def
      intro hfg'
      have hf' : MemLorentz f p 1 őľ := by sorry --TODO: get this from hfg' and measurability of f and g
      have hg' : MemLorentz g p 1 őľ := by sorry --TODO: use that g is an indicator function with finite value
      calc _
        _ ‚Č§ eLpNorm (T f) 1 (őĹ.restrict G) + eLpNorm (T g) 1 (őĹ.restrict G) := by
          apply T_subadditive f g hf' hg'
        _ ‚Č§ c / p * eLorentzNorm' f p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal + c / p *  eLorentzNorm' g p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
          gcongr
          ¬∑ exact hf hf' -- hf' is a proof that f is memLorentz, which is needed for hf
          ¬∑ exact hg hg' -- hg' is a proof that g is memLorentz, which is needed for hg
        _ = c / p * eLorentzNorm' (f + g) p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
          rw [‚Üź add_mul, ‚Üź mul_add]
          congr
          rw [eLorentzNorm'_eq_integral_distribution_rpow,
            eLorentzNorm'_eq_integral_distribution_rpow, eLorentzNorm'_eq_integral_distribution_rpow]
          rw [‚Üź mul_add] --‚Üź lintegral_add_left sorry
          congr 1
          rw [SimpleFunc.coe_add, g_def]
          simp only [SimpleFunc.const_zero, SimpleFunc.coe_piecewise,
            SimpleFunc.coe_const, SimpleFunc.coe_zero, Set.piecewise_eq_indicator]
          symm
          calc _
            _ = ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), (if t < a then őľ s else distribution f (t - a) őľ) ^ p.toReal‚ĀĽ¬Ļ := by
              congr with t
              rw [distribution_indicator_add_of_support_subset_nnreal (őľ := őľ) hfs]
              simp only [ENNReal.coe_lt_coe]
            _ = ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), if t < a then őľ s ^ p.toReal‚ĀĽ¬Ļ else distribution f (t - a) őľ ^ p.toReal‚ĀĽ¬Ļ := by
              simp only [ite_pow]
            _ = ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), (Set.Iio a).indicator (fun _ ‚Ü¶ őľ s ^ p.toReal‚ĀĽ¬Ļ) t
                  + (Set.Ici a).indicator (fun t ‚Ü¶ distribution f (t - a) őľ ^ p.toReal‚ĀĽ¬Ļ) t := by
              congr with t
              rw [‚Üź Set.compl_Iio, ‚Üź Pi.add_apply, Set.indicator_add_compl_eq_piecewise]
              unfold Set.piecewise
              simp
            _ = a * őľ s ^ p.toReal‚ĀĽ¬Ļ + ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), distribution f t őľ ^ p.toReal‚ĀĽ¬Ļ := by
              rw [lintegral_add_left (by measurability)]
              congr 1
              ¬∑ rw [lintegral_indicator_const measurableSet_Iio, NNReal.volume_Iio, mul_comm]
              ¬∑ rw [lintegral_indicator measurableSet_Ici, setLIntegral_Ici]
                simp
          rw [add_comm]
          congr
          apply (ENNReal.mul_right_inj p_ne_zero p_ne_top).mp
          rw [‚Üź eLorentzNorm'_eq_integral_distribution_rpow, eLorentzNorm'_indicator (by simp) p_ne_zero p_ne_top]
          simp

  ¬∑ intro f hf hfg hf'
    rw [‚Üź SimpleFunc.iSup_nnapprox hf] at hf'
    --have
    calc _
      _ ‚Č§ Filter.limsup (fun n ‚Ü¶ eLpNorm (T (SimpleFunc.nnapprox f n)) 1 (őĹ.restrict G)) Filter.atTop := by
        nth_rw 1 [‚Üź SimpleFunc.iSup_nnapprox hf]
        apply weakly_cont_T SimpleFunc.monotone_nnapprox hf' G
      _ ‚Č§ Filter.limsup (fun n ‚Ü¶ (c / p) * eLorentzNorm' (SimpleFunc.nnapprox f n) p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal) Filter.atTop := by
        apply Filter.mono_limsup
        intro n
        apply h n _ -- Error: missing argument
        sorry --use : all of these functions are bounded (by a constant / by f and this is MemLorentz)
      _ ‚Č§ (c / p) * eLorentzNorm' f p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
        simp_rw [mul_assoc]
        rw [ENNReal.limsup_const_mul_of_ne_top (ENNReal.div_ne_top (by simp) p_ne_zero)]
        gcongr
        --simp_rw [mul_comm]
        rw [ENNReal.limsup_mul_const_of_ne_top (ENNReal.rpow_ne_top_of_nonneg (by simp) hG'.ne)]
        gcongr
        apply Filter.limsup_le_of_le'
        apply Filter.Eventually.of_forall
        intro x
        exact SimpleFunc.approx_le hf bot_eq_zero'

