      | 0 => (inner ℝ w (EuclideanSpace.basis 0 • S))
      | 1 => (inner ℝ w (EuclideanSpace.basis 1 • S))
      | 2 => (inner ℝ w (EuclideanSpace.basis 2 • S))
      | _ => 0 := by
  simp only [rotproj_inner]
  fun_prop

