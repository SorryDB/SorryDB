    fun i => match i with
      | 0 => (inner ℝ w (EuclideanSpace.basis 0 • p.outer S))
      | 1 => (inner ℝ w (EuclideanSpace.basis 1 • p.outer S))
      | 2 => (inner ℝ w (EuclideanSpace.basis 2 • p.outer S))
      | _ => 0 := by
  simp only [rotproj_outer]
  fun_prop

