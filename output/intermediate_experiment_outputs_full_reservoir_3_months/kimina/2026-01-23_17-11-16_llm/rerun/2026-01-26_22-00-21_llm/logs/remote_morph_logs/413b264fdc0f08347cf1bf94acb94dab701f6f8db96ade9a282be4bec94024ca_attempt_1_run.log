    ContDiff ℝ 2 (fun (x : ℝ³) => rotproj_inner S w x) := by
  refine ContDiff.inner ℝ ?_ (by fun_prop)
  refine ContDiff.comp ?_ (by fun_prop)
  simp only [rotproj_inner]
  refine ContDiff.const_mul ?_
  refine ContDiff.inner ℝ ?_ (by fun_prop)
  simp only [rotprojRM]
  fun_prop

lemma rotation_partials_exist_outer {S : ℝ³} (S_nonzero : ‖S‖ > 0) {w : ℝ²} :
    ContDiff ℝ 2 (fun (x : ℝ³) => rotproj_outer S w x) := by
  refine ContDiff.inner ℝ ?_ (by fun_prop)
  refine ContDiff.comp ?_ (by fun_prop)
  simp only [rotproj_outer]
  refine ContDiff.const_mul ?_
  refine ContDiff.inner ℝ ?_ (by fun_prop)
  simp only [rotproj_outer]
  fun_prop

lemma fderiv_rotprojRM (S : ℝ³) : (fderiv ℝ (fun (x : ℝ³) => rotprojRM (x 1) (x 2) (x 0)) (EuclideanSpace.univ : ℝ³)) =
    fun i => match i with
      | 0 => Matrix.vecHead (Matrix.mulVec (Matrix.vecTail (Matrix.vecHead S)) (EuclideanSpace.basis 0))
      | 1 => Matrix.vecHead (Matrix.mulVec (Matrix.vecTail (Matrix.vecHead S)) (EuclideanSpace.basis 1))
      | 2 => Matrix.vecHead (Matrix.mulVec (Matrix.vecTail (Matrix.vecHead S)) (EuclideanSpace.basis 2))
      | _ => 0 := by
  fun_prop

lemma fderiv_inner (w : ℝ²) : (fderiv ℝ (fun (x : ℝ³) => inner ℝ w x) (EuclideanSpace.univ : ℝ³)) =
    fun i => match i with
      | 0 => (EuclideanSpace.basis 0).coe w
      | 1 => (EuclideanSpace.basis 1).coe w
      | 2 => (EuclideanSpace.basis 2).coe w
      | _ => 0 := by
  fun_prop

theorem fderiv_rotproj_inner (S : ℝ³) (w : ℝ²) : (fderiv ℝ (fun (x : ℝ³) => rotproj_inner S w x) (EuclideanSpace.univ : ℝ³)) =
