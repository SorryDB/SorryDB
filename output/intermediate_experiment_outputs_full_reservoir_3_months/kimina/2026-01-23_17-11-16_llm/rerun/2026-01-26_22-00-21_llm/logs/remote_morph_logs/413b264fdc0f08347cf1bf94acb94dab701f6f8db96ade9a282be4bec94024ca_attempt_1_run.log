noncomputable
def rotprojRM (α θ φ : ℝ) (S : ℝ³) : ℝ³ :=
  Matrix.vecHead (Matrix.mulVec (Matrix.vecTail (Matrix.vecHead (Matrix.mulVec (Matrix.vecTail (Matrix.vecHead S)) α) θ) φ))

noncomputable
def rotproj_inner (S : ℝ³) (w : ℝ²) (p : Pose) : ℝ :=
  ⟪p.inner S, w⟫

