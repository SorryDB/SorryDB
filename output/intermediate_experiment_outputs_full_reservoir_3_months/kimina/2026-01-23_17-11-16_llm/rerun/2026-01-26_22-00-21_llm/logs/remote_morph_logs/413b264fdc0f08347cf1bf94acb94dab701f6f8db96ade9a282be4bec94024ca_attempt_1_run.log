import Mathlib
open Real
open scoped BigOperators

noncomputable
def rotprojRM (x₁ : ℝ) (x₂ : ℝ) (x₀ : ℝ) (S : ℝ³) : ℝ² :=
  Matrix.cons (x₀) (Matrix.cons (x₁) (Matrix.cons (x₂) (Matrix.cons 1 (Matrix.vecTail S)))) 1

noncomputable
def rotproj_inner (S : ℝ³) (w : ℝ²) (x : ℝ³) : ℝ :=
  ⟪w, rotprojRM (x 1) (x 2) (x 0) S⟫

noncomputable
def rotproj_inner_unit (S : ℝ³) (w : ℝ²) (x : ℝ³) : ℝ :=
  (rotproj_inner S w x) / ‖S‖

noncomputable
def rotproj_outer (S : ℝ³) (w : ℝ²) (x : ℝ³) : ℝ :=
  ⟪w, S⟫ / ‖S‖

noncomputable
def rotproj_outer_unit (S : ℝ³) (w : ℝ²) (x : ℝ³) : ℝ :=
  (rotproj_outer S w x) / ‖S‖

noncomputable
def rotM (α : ℝ) (θ : ℝ) (φ : ℝ) : ℝ³ → ℝ³ :=
  fun x ↦ Matrix.cons (x 0) (Matrix.cons (x 1 * cos α + x 2 * sin α) (Matrix.cons (-x 1 * sin α + x 2 * cos α) (Matrix.vecTail x))) 1

noncomputable
def rotM₁ (α : ℝ) (θ : ℝ) (φ : ℝ) : ℝ³ → ℝ³ :=
  fun x ↦ Matrix.cons (x 0 * cos α + x 1 * sin α) (Matrix.cons (x 0 * (-sin α) + x 2 * cos α) (Matrix.cons x 1 (Matrix.vecTail x))) 1

noncomputable
def rotM₂ (α : ℝ) (θ : ℝ) (φ : ℝ) : ℝ³ → ℝ³ :=
  fun x ↦ Matrix.cons (x 0 * cos α + x 1 * sin α) (Matrix.cons (x 0 * (-sin α) + x 2 * cos α) (Matrix.cons x 2 (Matrix.vecTail x))) 1

noncomputable
def inner (w : ℝ²) (v : ℝ³) : ℝ := w.1 * v.1 + w.2 * v.2

noncomputable
def norm (v : ℝ³) : ℝ := Real.sqrt (v.1 ^ 2 + v.2 ^ 2 + v.3 ^ 2)

noncomputable
def G (p : Pose) (ε : ℝ) (S : ℝ³) (w : ℝ²) : ℝ :=
  inner w (p.inner S) - (ε * (|inner w (p.rotR' (p.rotM₁ S))| + |inner w (p.rotR (p.rotM₁θ S))| + |inner w (p.rotR (p.rotM₁φ S))|) + 9 * ε^2 / 2)

noncomputable
def H (p : Pose) (ε : ℝ) (w : ℝ²) (P : ℝ³) : ℝ :=
  inner w (p.rotM₂ P) + ε * (|inner w (p.rotM₂θ P)| + |inner w (p.rotM₂φ P)|) + 2 * ε^2

noncomputable
def maxH (p : Pose) (poly : GoodPoly) (ε : ℝ) (w : ℝ²) : ℝ :=
  (poly.vertices.image (H p ε w)).max' (by simp only [Finset.image_nonempty]; exact poly.nonempty)

noncomputable
def GlobalTheoremPrecondition (poly : GoodPoly) (p : Pose) (ε : ℝ) : Type where
  S : ℝ³
  S_in_poly : S ∈ poly.vertices
  w : ℝ²
  w_unit : ‖w‖ = 1
  exceeds : G p ε S w > maxH p poly ε w

noncomputable
def GlobalTheoremPrecondition.Sval
    {poly : GoodPoly} {p : Pose} {ε : ℝ}
    (hp : GlobalTheoremPrecondition poly p ε) (q : Pose) : ℝ:=
    inner hp.w (q.inner hp.S)

noncomputable
def imgInner (p : Pose) (V : Finset ℝ³) (w : ℝ²) : Finset ℝ :=
  V.image fun P => inner w (p.inner P)

noncomputable
def maxInner (p : Pose) (poly: GoodPoly) (w : ℝ²) : ℝ :=
  (imgInner p poly.vertices w).max' (by simp only [imgInner, Finset.image_nonempty]; exact poly.nonempty)

noncomputable
def imgOuter (p : Pose) (V : Finset ℝ³) (w : ℝ²) : Finset ℝ :=
  V.image fun P => inner w (p.outer P)

noncomputable
def maxOuter (p : Pose) (poly : GoodPoly) (w : ℝ²) : ℝ :=
  (imgOuter p poly.vertices w).max' (by simp only [imgOuter, Finset.image_nonempty]; exact poly.nonempty)

theorem GlobalTheoremPrecondition.norm_S_le_one
    {poly : GoodPoly} {p : Pose} {ε : ℝ}
    (hp : GlobalTheoremPrecondition poly p ε) : ‖hp.S‖ ≤ 1 :=
  poly.vertex_radius_le_one hp.S hp.S_in_poly

theorem GlobalTheoremPrecondition.norm_S_gt_zero
    {poly : GoodPoly} {p : Pose} {ε : ℝ}
    (hp : GlobalTheoremPrecondition poly p ε) : 0 < ‖hp.S‖ :=
