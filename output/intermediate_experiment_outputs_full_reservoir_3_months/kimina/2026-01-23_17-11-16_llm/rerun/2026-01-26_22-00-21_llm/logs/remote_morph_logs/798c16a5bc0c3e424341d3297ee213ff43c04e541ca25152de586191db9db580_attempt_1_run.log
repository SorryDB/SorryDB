      apply Finset.card_insert_of_not_mem
      exact he
    rw [h_card_insert, h_card_insert']
    -- The goal is now S'.card + 1 ≤ E'.card + 1, which follows from S'.card ≤ E'.card + 1 (h_ind).
    all_goals try { linarith [h_ind] }
    all_goals try { aesop }
  · -- The induction hypothesis is that for the loop walk p_1, (S').card ≤ (E').card + 1.
    -- We need to show that for the loop walk, (S ∪ {u}).card ≤ (E' ∪ {e'}).card + 1.
