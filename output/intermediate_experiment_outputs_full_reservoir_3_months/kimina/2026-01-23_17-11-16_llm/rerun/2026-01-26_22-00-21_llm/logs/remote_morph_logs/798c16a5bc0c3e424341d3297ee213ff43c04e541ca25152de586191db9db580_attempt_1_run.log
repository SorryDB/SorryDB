import Mathlib.Data.Finset.Card

/- The `support` of a walk is the list of vertices it visits in order. -/
def support {u v : V} : G.LoopWalk u v → List V
  | nil => [u]
  | cons _ p => u :: p.support
  | loop p => u::p.support

/- The `darts` of a walk is the list of steps it takes, represented as pairs of vertices. -/
@[simp, grind]
def darts {u v : V} : G.LoopWalk u v → List (V × V)
  | nil => []
  | @cons _ _ u v' _ h p => (u, v') :: p.darts
  | loop p => (u, u) :: p.darts

/- The `edgeSet` of a walk is the set of edges it traverses, including loops.-/
def edgeSet {u v : V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (Sym2 V) := (darts p).toFinset

/- The `edges` of a walk is the list of edges it visits in order. -/
@[simp]
def edges {u v : V} (p : G.LoopWalk u v) : List (Sym2 V) := p.darts.map dartEdge

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) : (supportSet p).card ≤ (edgeSet p).card +1 := by
  induction' p with u v w h p ih
  all_goals simp [darts, edges, support] at *
  · -- Base case: p = nil
    simp [Finset.card_singleton]
    all_goals omega
  · -- Inductive step for cons
    -- Need to show: (u :: p.support).toFinset.card ≤ (insert s(u, v) p.edges).card + 1
    -- where v is the start of p.
    have h_support : (@SimpleGraph.LoopWalk.cons V G u v h p).supportSet = insert u p.supportSet := by
      simp [support, supportSet]
      <;> aesop
    have h_edge : (@SimpleGraph.LoopWalk.cons V G u v h p).edgeSet = insert s(u, v) p.edgeSet := by
      simp [edgeSet, darts, edges, supportSet]
      <;> aesop
    rw [h_support, h_edge]
    -- Need to show: (insert u p.supportSet).card ≤ (insert s(u, v) p.edgeSet).card + 1
    -- We know p.supportSet.card ≤ p.edgeSet.card + 1 by ih
    cases Finset.mem_insert_iff.mp (Finset.mem_singleton_iff.mpr rfl) with
    | inl h_mem => 
      simp [Finset.card_insert_of_not_mem h_mem]
      omega
    | inr h_mem =>
      simp [Finset.card_insert_of_not_mem h_mem]
      omega
  · -- Inductive step for loop
    -- Need to show: (insert u p.supportSet).card ≤ (insert s(u, u) p.edges).card + 1
    have h_support : (@SimpleGraph.LoopWalk.loop V G u v p).supportSet = insert u p.supportSet := by
      simp [support, supportSet, loop]
      <;> aesop
    have h_edge : (@SimpleGraph.LoopWalk.loop V G u v p).edgeSet = insert s(u, u) p.edgeSet := by
      simp [edgeSet, darts, edges, supportSet, loop]
