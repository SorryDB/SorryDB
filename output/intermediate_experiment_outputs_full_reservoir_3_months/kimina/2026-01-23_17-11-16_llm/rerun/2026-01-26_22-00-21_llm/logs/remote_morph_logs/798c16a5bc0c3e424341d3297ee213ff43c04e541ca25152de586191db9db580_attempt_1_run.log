  (supportSet p).card ≤ (edgeSet p).card +1 := by
  induction' p with u v p ih
  · -- The support set of the nil walk is {u}, and the edge set is empty.
    simp [SimpleGraph.LoopWalk.supportSet, SimpleGraph.LoopWalk.edgeSet]
    all_goals try { tauto }
  · -- The induction hypothesis is that for the rest of the walk p_1, (S').card ≤ (E').card + 1.
    -- We need to show that for the cons walk, (S ∪ {v}).card ≤ (E' ∪ {e'}).card + 1.
    have h_support : (@SimpleGraph.LoopWalk.supportSet V G v ih inst (@SimpleGraph.LoopWalk.cons V G v p ih h p_1)) =
      insert v (@SimpleGraph.LoopWalk.supportSet V G p ih inst p_1) := by
      simp [SimpleGraph.LoopWalk.supportSet]
      <;> aesop
    have h_edge : (@SimpleGraph.LoopWalk.edgeSet V G v ih inst (@SimpleGraph.LoopWalk.cons V G v p ih h p_1)) =
      insert s(v, p) (@SimpleGraph.LoopWalk.edgeSet V G p ih inst p_1) := by
      simp [SimpleGraph.LoopWalk.edgeSet, SimpleGraph.LoopWalk.edges]
      <;> aesop
      <;> try { aesop }
    have h_ind : Finset.card (@SimpleGraph.LoopWalk.supportSet V G p ih inst p_1) ≤
      Finset.card (@SimpleGraph.LoopWalk.edgeSet V G p ih inst p_1) + 1 := by
      exact ih
    rw [h_support, h_edge]
    -- We need to show: (insert v S').card ≤ (insert e' E').card
    -- where S' is the support set of p_1, E' is the edge set of p_1.
    -- We know that v ∉ S' and e' = s(v,p) is not in E' (unless v is in S', which would mean p_1 is a loop at v).
    -- So we can use Finset.card_insert_of_not_mem.
    have hv : v ∉ @SimpleGraph.LoopWalk.supportSet V G p ih inst p_1 := by
      -- The head vertex v of the cons walk is not in the support set of the rest of the walk.
      -- This is true by definition of the support set of a non-empty walk.
      simp [SimpleGraph.LoopWalk.supportSet, List.mem_cons, List.mem_nil]
      <;> try { aesop }
    have he : s(v, p) ∉ @SimpleGraph.LoopWalk.edgeSet V G p ih inst p_1 := by
      -- The edge s(v,p) is not in the edge set of the rest of the walk.
      simp [SimpleGraph.LoopWalk.edgeSet, List.mem_cons, List.mem_nil]
      <;> try { aesop }
      <;> try { aesop }
      <;> try { aesop }
    have h_card_insert : (insert v (@SimpleGraph.LoopWalk.supportSet V G p ih inst p_1)).card =
