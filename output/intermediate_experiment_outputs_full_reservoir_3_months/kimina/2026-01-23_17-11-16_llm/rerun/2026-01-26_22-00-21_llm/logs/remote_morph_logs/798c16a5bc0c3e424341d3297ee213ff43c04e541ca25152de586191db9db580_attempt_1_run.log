          exact h_support
        contradiction
      rw [h_card_union]
      exact le_trans ih (by simp)
  · -- Inductive step: p = @SimpleGraph.LoopWalk.loop _
    simp [supportSet, edgeSet, darts, edges]
    <;> aesop

lemma count_le_card {u v : V} (p : G.LoopWalk u v) :
  p.length ≤ (edgeSet p).card := by
  have h_sum : ∑ e : edgeSet p, (1 : ℕ) = (edgeSet p).card := by
    simp
  have h_sum' : ∑ e : edgeSet p, (1 : ℕ) = p.length := by
    rw [abs_w_i_eq_k p]
    simp
  rw [h_sum, h_sum']
