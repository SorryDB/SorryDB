      · expose_names
        rw [dart_length_eq_walk_length p_1]
    apply h_length_eq;
  rw [ ← h_sum_edges, Finset.sum_coe_sort ]

/-- The loop_count of a walk is the number of loops along it. -/
def loop_count {u v : V} : G.LoopWalk u v → ℕ
  | nil => 0
  | cons _ q => q.loop_count
  | loop q => q.loop_count.succ

variable {G : SimpleGraph V}

/-- A walk is closed if its start and end vertices are the same. -/
@[simp]
def IsClosed {u v : V} (_ : G.LoopWalk u v) : Prop := u = v

variable {G}

/-- The number of vertices in a closed walk. -/
def vertexCount (p : G.LoopWalk u v) : ℕ :=
  if u = v then (p.supportSet.card) else 0

lemma vertex_count_eq_support_card_for_closed_walks {p : G.LoopWalk u v} (h : IsClosed p) : vertexCount p = p.supportSet.card := by
  simp [IsClosed] at h ⊢
  all_goals try { aesop }
  all_goals try { tauto }

lemma vertex_count_eq_zero_for_nonclosed_walks {p : G.LoopWalk u v} (h : ¬IsClosed p) : vertexCount p = 0 := by
  simp [IsClosed] at h ⊢
  all_goals try { aesop }
  all_goals try { tauto }

