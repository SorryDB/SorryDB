import Mathlib

open SimpleGraph

/- A sequence of edges forming a closed path, represented as a list of vertices
where each consecutive pair is connected by an edge. A loop is represented by a single
vertex. -/
inductive LoopWalk (V : Type u) (G : SimpleGraph V) (u : V) : G.LoopWalk u u → Prop where
  | nil => sorry
  | cons h p => sorry
  | loop p => sorry

