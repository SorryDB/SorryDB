      _ = j := h₀.symm

lemma le_abs_of_dvd {i j : ℤ} (gj: 0 ≠ j) (h: i ∣ j) : |i| ≤ |j| := by
  cases' h with c h₀
  cases' em (c = 0) with hc h
  · by_contra
