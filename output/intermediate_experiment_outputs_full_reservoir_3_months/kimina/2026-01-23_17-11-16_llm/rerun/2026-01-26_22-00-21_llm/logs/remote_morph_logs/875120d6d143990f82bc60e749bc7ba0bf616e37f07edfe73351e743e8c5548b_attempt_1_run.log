  protected prime : тИА {╧Ж ╧И}, ╧Ж тЛО ╧И тИИ theory тЖТ ╧Ж тИИ theory тИи ╧И тИИ theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {╧Ж ╧И ╧З ╬╛ : Formula тДХ} {T : FTheory L} {hT : ╧З тЮЭ ╬╛ тИЙ T.theory}

def construction (T : FTheory L) (hT : ╧З тЮЭ ╬╛ тИЙ T.theory) : тДХ тЖТ Set (Formula тДХ)
  | 0 => { ╬┤ | ╧З тЮЭ ╬┤ тИИ T.theory }
  | i + 1 =>
    match (decode i) with
    | some ╬┤ =>
      letI T' := construction T hT i
      if тИА ╬У : Finset (Formula _), тЖС╬У тКЖ T' тЖТ ╬У.conj тЛП ╬┤ тЮЭ ╬╛ тИЙ T.theory then insert ╬┤ T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : ╧З тЮЭ ╬╛ тИЙ T.theory) : Set (Formula тДХ) := тЛГ i, construction T hT i

lemma subset_construction_succ : construction T hT i тКЖ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i тКЖ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i тЙд j) : construction T hT i тКЖ construction T hT j := by
  obtain тЯиk, rflтЯй := le_iff_exists_add.mp hij;
  apply subset_construction_add;

lemma mem_omega_of_mem (h : ╧З тЮЭ ╬┤ тИИ T.theory) : ╬┤ тИИ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion];
  use 0;
  simpa [construction];

lemma of_mem_construction_omega {╧Ж : Formula тДХ} (h╧Ж : ╧Ж тИИ construction_omega T hT) :
  (╧З тЮЭ ╧Ж тИИ T.theory) тИи (тИА ╬У : Finset _, тЖС╬У тКЖ construction T hT (encode ╧Ж) тЖТ ╬У.conj тЛП ╧Ж тЮЭ ╬╛ тИЙ T.theory) := by
  obtain тЯиi, hiтЯй := by simpa [construction_omega] using h╧Ж;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
    dsimp [construction] at hi;
    sorry;
    /-
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . grind;
      . assumption
    . assumption
    .dsimp [construction] at hi;
    split at hi;
    -/

lemma not_of_mem_construction_omega {╧Ж : Formula тДХ}
  {╬У : Finset (Formula тДХ)} (h╬У : тЖС╬У тКЖ construction T hT (encode ╧Ж))
  (h╧Ж : ╬У.conj тЛП ╧Ж тЮЭ ╬╛ тИИ T.theory) :
  ╧Ж тИЙ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    sorry;
  | succ i ih =>
    simp [construction];
    split_ifs at ih with h;
    . rename_i ╬┤ h╬┤;
      by_contra hC;
      have : ╬┤ = ╧Ж := by grind;
      subst this;
      apply h ╬У ((show encode ╬┤ = i by sorry) тЦ╕ h╬У) h╧Ж;
    . assumption
    . assumption

lemma of_not_mem_construction_omega {╧Ж : Formula тДХ} (h╧Ж : ╧Ж тИЙ construction_omega T hT) :
  (╧З тЮЭ ╧Ж тИЙ T.theory) тИз (тИГ ╬У : Finset (Formula _), тЖС╬У тКЖ (construction T hT (encode ╧Ж)) тИз ╬У.conj тЛП ╧Ж тЮЭ ╬╛ тИИ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at h╧Ж;
  constructor;
  . simpa using h╧Ж 0;
  . have this := h╧Ж (encode ╧Ж + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this;
    . simpa using h;

variable [Entailment.F L]

lemma construction_omega_mem_ant : ╧З тИИ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
  apply impId;

lemma construction_omega_not_mem_csq : ╬╛ тИЙ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion, not_exists];
  intro i;
  induction i with
  | zero => simpa [construction];
  | succ i ih =>
    contrapose! ih;
    dsimp [construction] at ih;
    split at ih;
    . split_ifs at ih with h;
      . rename_i ╬┤ h╬┤;
        have := h тИЕ (by tauto);
        contrapose! this;
        have : ╬╛ = ╬┤ := by grind;
        subst this;
        apply T.mem_of_provable;
        simp;
      . assumption;
    . assumption;

lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  ╧Ж тИИ U тЖТ ╧И тИИ U тЖТ ╧Ж тЛП ╧И тИИ U := by
  rintro h╧Ж h╧И;
  by_contra h╧Ж╧И;
  replace тЯиh╧Ж╧И, тЯи╬У, h╬УтВБ, h╬УтВВтЯйтЯй := of_not_mem_construction_omega h╧Ж╧И;

  sorry;

lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L тКв ╧Ж тЮЭ ╧И тЖТ ╧Ж тИИ U тЖТ ╧И тИИ U := by
  rintro h╧Ж╧И h╧Ж;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ╧И + 1);
  simp [construction];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain тЯи╬У, h╬У, hтВБтЯй := h;
    have hтВВ : (╬У.conj тЛП ╧Ж) тЖТ (╬У.conj тЛП ╧И) тИИ T.theorem := by
      apply T.L_subset;
      apply Logic.iff_provable.mp;
      apply CK_of_C_of_C;
      . exact impId;
      . apply af;
        exact Logic.iff_provable.mpr h╧Ж;
    have : (╬У.conj тЛП ╧Ж) тЖТ ╬╛ тИИ T.theorem := T.mem_trans hтВВ hтВБ;
    have : (╬У.conj тЛП ╧Ж) тЖТ ╬╛ тИИ construction_omega T hT := by sorry;
    assumption;

lemma construction_omega_L_subset :
  letI U := construction_omega T hT
  L тКЖ U := by
  intro ╧Ж h╧Ж;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ╧Ж + 1);
  simp only [construction, encodek];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain тЯи╬У, h╬У, hтВБтЯй := h;
    have hтВВ : (╬У.conj тЛП ╧Ж) тЖТ (╬У.conj тЛП ╧Ж) тИИ T.theorem := by
      apply T.L_subset;
      apply Logic.iff_provable.mp;
      apply CK_of_C_of_C;
      . exact impId;
      . apply af;
        exact Logic.iff_provable.mpr h╧Ж;
    have : (╬У.conj тЛП ╧Ж) тЖТ ╬╛ тИИ T.theorem := T.mem_trans hтВВ hтВБ;
    have : (╬У.conj тЛП ╧Ж) тЖТ ╬╛ тИИ construction_omega T hT := by sorry;
    assumption;

lemma construction_omega_prime : PrimeFTheory L T := by
  constructor;
  -- FTheory structure
  . exact T;
  -- Prime property
  . intro h╧Ж╧И h╧Ж h╧И;
    -- h╧Ж : ╧Ж тИИ T.theorem
    -- h╧И : ╧И тИИ T.theorem
    -- h╧Ж╧И : ╧Ж тИи ╧И тИИ T.theorem
