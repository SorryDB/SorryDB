import Foundation.Propositional.Kripke2.Basic

namespace LO.Propositional

open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {╬▒ : Type*}
variable {S} [Entailment S (Formula ╬▒)]
variable {ЁЭУв : S}

structure FTheory (L : Logic тДХ) where
  protected theory : FormulaSet тДХ
  protected no_bot : тКе тИЙ theory
  protected andIR : тИА {╧Ж ╧И}, ╧Ж тИИ theory тЖТ ╧И тИИ theory тЖТ ╧Ж тЛП ╧И тИИ theory
  protected imp_closed : тИА {╧Ж ╧И}, L тКв ╧Ж тЮЭ ╧И тЖТ ╧Ж тИИ theory тЖТ ╧И тИИ theory
  protected L_subset : L тКЖ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {╧Ж ╧И ╧З : Formula тДХ}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (h╧Ж : L тКв ╧Ж) : ╧Ж тИИ T.theory := by
  apply T.imp_closed (╧Ж := тКд) $ af h╧Ж;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (hтВБ : ╧Ж тЮЭ ╧И тИИ T.theory) (hтВВ : ╧И тЮЭ ╧З тИИ T.theory) : ╧Ж тЮЭ ╧З тИИ T.theory := by
  apply T.imp_closed (axiomI (╧И := ╧И));
  apply T.andIR hтВБ hтВВ;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (h╧Ж : ╧Ж тИИ T.theory) : ╧Ж тЛО ╧И тИИ T.theory := by
  apply T.imp_closed (╧Ж := ╧Ж);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (h╧И : ╧И тИИ T.theory) : ╧Ж тЛО ╧И тИИ T.theory := by
  apply T.imp_closed (╧Ж := ╧И);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ╧Ж тИИ T.theory тЖФ Deduction Ax T.theory ╧Ж := by
  constructor;
  . intro h╧Ж;
    apply Deduction.ctx h╧Ж;
  . intro h; induction h <;> grind

end FTheory


