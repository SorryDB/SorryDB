lemma of_not_mem_construction_omega {╧Ж : Formula тДХ} (h╧Ж : ╧Ж тИЙ construction_omega T hT) :
  (╧З тЮЭ ╧Ж тИЙ T.theory) тИз (тИГ ╬У : Finset (Formula _), тЖС╬У тКЖ (construction T hT (encode ╧Ж)) тИз ╬У.conj тЛП ╧Ж тЮЭ ╬╛ тИИ T.theory) := by
