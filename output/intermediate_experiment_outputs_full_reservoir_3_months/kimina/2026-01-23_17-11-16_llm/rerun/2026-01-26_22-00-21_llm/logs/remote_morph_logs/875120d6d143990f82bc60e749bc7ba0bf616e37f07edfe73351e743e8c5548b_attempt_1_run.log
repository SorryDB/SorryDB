def construction (T : FTheory L) (hT : ╧З тЮЭ ╬╛ тИЙ T.theorem) : тДХ тЖТ Set (Formula тДХ)
  | 0 => { ╬┤ | ╧З тЮЭ ╬┤ тИИ T.theorem }
