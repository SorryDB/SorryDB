  (h_qX_bounds : ŌłĆ i, i < 5 ŌåÆ (q.X[i]!).val Ōēż 2 ^ 52)
  (h_qY_bounds : ŌłĆ i, i < 5 ŌåÆ (q.Y[i]!).val Ōēż 2 ^ 52)
  (h_qZ_bounds : ŌłĆ i, i < 5 ŌåÆ (q.Z[i]!).val Ōēż 2 ^ 52) :
Ōłā c,
double q = ok c Ōł¦
let X := Field51_as_Nat q.X
let Y := Field51_as_Nat q.Y
let Z := Field51_as_Nat q.Z
let X' := Field51_as_Nat c.X
let Y' := Field51_as_Nat c.Y
let Z' := Field51_as_Nat c.Z
let T' := Field51_as_Nat c.T
X' % p = (2 * X * Y) % p Ōł¦
Y' % p = (Y^2 + X^2) % p Ōł¦
(Z' + X^2) % p = Y^2 % p Ōł¦
(T' + Z') % p = (2 * Z^2) % p
