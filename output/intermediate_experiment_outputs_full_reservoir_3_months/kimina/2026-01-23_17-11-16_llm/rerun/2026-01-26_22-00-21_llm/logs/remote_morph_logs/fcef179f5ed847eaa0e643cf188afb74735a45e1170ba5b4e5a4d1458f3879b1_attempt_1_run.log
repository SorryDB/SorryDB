  according to the context-free grammar. -/
structure ContextFreeDerivationStep {α : Sort u_1} {nt : Sort u_2} [DecidableEq α] [DecidableEq nt]
    (G : ContextFreeGrammar α nt) (u : Word (G.V ⊕ G.Z)) :
    lhs : G.V ⊕ G.Z
    rhs : List (G.V ⊕ G.Z)
    sound : (lhs : G.V ⊕ G.Z).isNonterminal ∧
