import Mathlib

/-- The exhaustive condition for a context-free derivation. -/
def exhaustiveCondition (cfd : @ContextFreeDerivation α nt G u v) : Prop :=
  match cfd with
  | .same h_same =>
    True
  | @ContextFreeDerivation.step _ _ _ _ u' _ dstep (derivation : ContextFreeDerivation G u' v) sound =>
    exhaustiveCondition derivation

/-- A context-free derivation step. -/
