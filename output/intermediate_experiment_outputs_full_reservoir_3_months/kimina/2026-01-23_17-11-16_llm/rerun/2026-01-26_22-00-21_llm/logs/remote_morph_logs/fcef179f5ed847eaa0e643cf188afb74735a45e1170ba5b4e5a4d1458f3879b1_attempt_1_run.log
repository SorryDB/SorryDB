import Mathlib

/-- The exhaustive condition of a derivation ensures that the derivation
  does not get stuck on a non-productive rule. This theorem shows that if a
  derivation step is exhaustive, then its children derivations are also
  exhaustive. This is a direct consequence of the fact that the
  exhaustive condition is a necessary condition for a derivation to
  complete. -/
theorem ContextFreeDerivation.exhaustive_imp_child_exhaustive
    {α : Sort u_1} {nt : Sort u_2} {G : ContextFreeGrammar α nt}
    {u v : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }) }
    {u' : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }) }
    {dstep : G.ContextFreeDerivationStep u}
    {derivation : ContextFreeDerivation G u' v}
    {sound : dstep.result = u'}
