  have h_eq_proj : (fun ω => X ω i j) = proj ⟨(min i j, max i j), by
    exact min_le_max⟩ ∧ (fun ω => X ω k l) = proj ⟨(min k l, max k l), by
    exact min_le_max⟩ := by
