-- Define the space of all n×n matrices with entries in ℝ
noncomputable
def MatrixSpace (n : ℕ) := Matrix (Fin n) (Fin n) ℝ

-- Define the space of all n×n matrices with entries in ℝ, viewed as a product space
noncomputable
def WignerSpace (n : ℕ) := Index n → ℝ

-- Define the measure on the space of all n×n matrices, assigning ν to diagonal entries and μ to off-diagonal entries
noncomputable
def wignerMeasure (n : ℕ) : Measure (WignerSpace n) := Measure.pi (fun (p : Index n) => if p.val.1 = p.val.2 then ν else μ)

-- Define the map from the space of all n×n matrices to the space of all n×n matrices with entries in ℝ
noncomputable
def wignerMatrixMap (n : ℕ) : WignerSpace n → MatrixSpace n :=
  fun (ω : WignerSpace n) => Matrix.of (fun i j => if i = j then ω ⟨(i, i), by simp⟩ else if i < j then ω ⟨(i, j), by simp⟩ else ω ⟨(j, i), by simp⟩)

-- Define the map from the space of all n×n matrices to the space of all n×n matrices with entries in ℝ, rescaled by 1/√n
noncomputable
def wignerMatrixMapScaled (n : ℕ) : WignerSpace n → MatrixSpace n :=
  fun (ω : WignerSpace n) => (1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap n ω)

-- The measure on the space of all n×n matrices is the pushforward of the measure on the space of all n×n matrices with entries in ℝ under the map `wignerMatrixMap`
noncomputable
def wignerMatrixMeasure (n : ℕ) : Measure (MatrixSpace n) :=
  Measure.map (wignerMatrixMap n) (wignerMeasure n)

-- Prove that the measure on the space of all n×n matrices is indeed a probability measure
instance (n : ℕ) : IsProbabilityMeasure (wignerMatrixMeasure n) := by
  rw [wignerMatrixMeasure]
  apply MeasureTheory.Measure.map.instIsProbabilityMeasure
  exact isProbabilityMeasure_wignerMeasure n

-- Prove that the map `wignerMatrixMap` is measurable
noncomputable
lemma wignerMatrixMapMeasurable (n : ℕ) : Measurable (wignerMatrixMap n) := by
  apply Matrix.of_measurable

-- Prove that the map `wignerMatrixMap` is measurable
noncomputable
lemma wignerMatrixMapScaledMeasurable (n : ℕ) : Measurable (wignerMatrixMapScaled n) := by
  apply Matrix.of_measurable

-- Prove that the map `wignerMatrixMap` is AEMeasurable
noncomputable
lemma wignerMatrixMapAEMeasurable (n : ℕ) : AEMeasurable (wignerMatrixMap n) := by
  apply Matrix.of_aemeasurable

-- Prove that the map `wignerMatrixMap` is AEMeasurable
noncomputable
lemma wignerMatrixMapScaledAEMeasurable (n : ℕ) : AEMeasurable (wignerMatrixMapScaled n) := by
  apply Matrix.of_aemeasurable

