  meas : Measurable X
  diag_dist : ∀ i : (Fin k), HasLaw (fun ω ↦ X ω i i) ν P
  off_diag_dist : ∀ i j : (Fin k), i > j → HasLaw (fun ω ↦ X ω i j) μ P
  symm : ∀ i j : (Fin k), ∀ ω : Ω, X ω i j = X ω j i
