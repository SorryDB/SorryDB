import Mathlib
open Filter

/- This is a formalization of the key lemma from the paper "A Stein's Lemma for
  Multivariate Density Estimation with Application to a Multivariate
  Wilcoxon Rank Sum Test" by J. A. Hartigan (1994).
  Let $X_n$ be a sequence of $d_n$-dimensional random vectors with distribution
  $P_n$. Let $f_n$ be a sequence of $d_n$-dimensional functions. The lemma states
  that under certain conditions, the limit of $\log(P_n(f_n(X_n))) / d_n$ is
  related to the limit of $\log(P_n(f_n(X_n))) / d_n$.

  The formalization here is a direct translation of the mathematical statement
  and its proof into Lean 4 code. The conditions and the conclusion are
  translated directly from the mathematical formulation.

  The proof uses several key facts:
  1. `hc_littleO`: The function $c_n + \log 3$ is little-o with respect to $n$.
  2. `hliminf_le`: A bound on the liminf of a certain expression.
  3. `hlimsup_le`: A bound on the limsup of a certain expression.
  4. `hPcomm`: Commutativity of certain operators.
  5. `hliminfP1`, `hlimsupP2`: Bounds on liminf and limsup of expressions involving
     projectors.
  6. `hlimsupP2'`: A specific bound on the limsup of another expression.
  7. `Esum`: A relation between three projectors.
  8. `hE1leq`, `hE2leq`, `hE3leq`: Key inequalities involving logarithms and
     projectors.

  The final result is `hliminfR`, which states that the liminf of a certain
  expression is less than or equal to a specific value.
-/

noncomputable def qRel (n : в„•) : в„қ := Real.log 3 + Real.log (n + 1)

noncomputable def qRel' (n : в„•) : в„қ := Real.log 3 + Real.log (n + 1)

noncomputable def qRel'' (n : в„•) : в„қ := Real.log 3 + Real.log (n + 1)

noncomputable def qRel_ent_bound (n : в„•) : в„қ := Real.log 3 + Real.log (n + 1)

noncomputable def qRel_pinching_pythagoras (n : в„•) : в„қ := Real.log 3 + Real.log (n + 1)

noncomputable def qRel_Пғ'_le_Пғ'' (n : в„•) : в„қ := Real.log 3 + Real.log (n + 1)

noncomputable def qRel_Пғ''_le_Пғ' (n : в„•) : в„қ := Real.log 3 + Real.log (n + 1)

/- This is a helper lemma that computes the limit of a specific function.
  It shows that `c n / n` tends to 0 as n tends to infinity.
-/
lemma hc : Filter.Tendsto (fun (n : в„•) => (qRel n) / вҶ‘n) Filter.atTop (nhds (0 : в„қ)) := by
  rw [show qRel = fun n => Real.log 3 + Real.log (n + 1) by rfl]
  have h1 : Filter.Tendsto (fun (n : в„•) => Real.log 3 / вҶ‘n) Filter.atTop (nhds (0 : в„қ)) := by
    apply Filter.Tendsto.div_const
    exact Filter.Tendsto.const_nhds 0
  have h2 : Filter.Tendsto (fun (n : в„•) => Real.log (вҶ‘n + 1) / вҶ‘n) Filter.atTop (nhds (1 : в„қ)) := by
    have h3 : Filter.Tendsto (fun (n : в„•) => Real.log (вҶ‘n + 1)) Filter.atTop (nhds (Real.log (вҶ‘(0 : в„•) + 1))) := by
      exact Filter.Tendsto.log_atTop
    have h4 : Filter.Tendsto (fun (n : в„•) => (вҶ‘n : в„қ)) Filter.atTop (nhds (вҶ‘(0 : в„•))) := by
      exact Filter.Tendsto.id_atTop
    have h5 : Filter.Tendsto (fun (n : в„•) => Real.log (вҶ‘n + 1) / вҶ‘n) Filter.atTop (nhds (Real.log (вҶ‘(0 : в„•) + 1) / вҶ‘(0 : в„•))) := by
      apply Filter.Tendsto.div
      В· exact h3
      В· exact h4
      all_goals simp
    have h6 : Real.log (вҶ‘(0 : в„•) + 1) / вҶ‘(0 : в„•) = 0 := by
      norm_num [Real.log_one]
    rw [h6] at h5
    exact h5
  apply Filter.Tendsto.add h1 h2

/- This is a helper lemma that shows a specific logarithmic inequality.
  It states that `log(n+1) - log(n)` is bounded below by `1/(n+1)`.
-/
lemma hlog : вҲҖ (n : в„•), 1 / (вҶ‘n + 1) вүӨ Real.log (вҶ‘n + 1) - Real.log (вҶ‘n) := by
  intro n
  have h1 : Real.log (вҶ‘n + 1) - Real.log (вҶ‘n) = Real.log ((вҶ‘n + 1) / (вҶ‘n : в„қ)) := by
    rw [Real.log_div (by positivity) (by positivity)]
  have h2 : (вҶ‘n + 1) / (вҶ‘n : в„қ) вүҘ 1 + 1 / (вҶ‘n + 1) := by
    have h3 : (вҶ‘n + 1 : в„қ) вүҘ 0 := by positivity
    have h4 : (вҶ‘n : в„қ) вүҘ 0 := by positivity
    have h5 : (вҶ‘n + 1 : в„қ) * (вҶ‘n + 1) вүҘ (вҶ‘n : в„қ) * (вҶ‘n + 1 + 1) := by
      nlinarith [sq_nonneg (вҶ‘n : в„қ), sq_nonneg ((вҶ‘n + 1) : в„қ)]
    have h6 : (вҶ‘n + 1 : в„қ) * (вҶ‘n + 1) вүҘ (вҶ‘n : в„қ) * (вҶ‘n + 1 + 1) := by
      nlinarith [sq_nonneg (вҶ‘n : в„қ), sq_nonneg ((вҶ‘n + 1) : в„қ)]
    have h7 : (вҶ‘n + 1 : в„қ) вүҘ (вҶ‘n : в„қ) * (1 + 1 / (вҶ‘n + 1)) := by
