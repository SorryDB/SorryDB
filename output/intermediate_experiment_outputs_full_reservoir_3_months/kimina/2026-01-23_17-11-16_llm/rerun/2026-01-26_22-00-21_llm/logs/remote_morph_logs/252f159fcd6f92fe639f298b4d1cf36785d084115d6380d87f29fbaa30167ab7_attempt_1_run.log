import Mathlib
open Filter Real Topology

/- Steins Lemma -/

noncomputable def R1 (i : О№) (ПҒ : MState (H i)) (Оө : Prob) :=
  (1 - Оө) * log (det (ПҒ.toDens : Matrix (Fin i) (Fin i) в„қ)) +
  Оө * log (det (1 / 3 вҖў (Matrix.unit i : Matrix (Fin i) (Fin i) в„қ) + 1 / 3 вҖў (Matrix.unit i : Matrix (Fin i) (Fin i) в„қ) + 1 / 3 вҖў (Matrix.unit i : Matrix (Fin i) (Fin i) в„қ)))

noncomputable def R2 (i : О№) (ПҒ : MState (H i)) (Пғ : (n : в„•) вҶ’ вҶ‘IsFree) :=
  (1 - ОөвӮҖ) * log (det (ПҒ.toDens : Matrix (Fin i) (Fin i) в„қ)) +
  ОөвӮҖ * log (det ((1 / 3) вҖў (Matrix.unit i : Matrix (Fin i) (Fin i) в„қ) + (1 / 3) вҖў (Matrix.unit i : Matrix (Fin i) (Fin i) в„қ) + (1 / 3) вҖў (Matrix.unit i : Matrix (Fin i) (Fin i) в„қ)))

noncomputable def pinching (n : в„•) (Пғ : MState (H (i ^ n))) (i : О№) :=
  (Matrix.unit i : Matrix (Fin (i ^ n)) (Fin (i ^ n)) в„қ) вҖў Пғ.toDens

noncomputable def pinching_map (n : в„•) (i : О№) (Пғ : MState (H (i ^ n))) (ПҒ : MState (H (i ^ n))) :=
  (fun x => pinching n Пғ i x) вҖў ПҒ.toDens

noncomputable def pinching_self (n : в„•) (i : О№) (Пғ : MState (H (i ^ n))) :=
  (fun x => pinching n Пғ i x) вҖў (fun x => x)

noncomputable def pinching_commutes (i : О№) (n : в„•) (ПҒ : MState (H (i ^ n))) (Пғ : MState (H (i ^ n))) :=
