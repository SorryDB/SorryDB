| edge {m n} : (e : Match.edge m n) → ¬ e.isModal → PreStateP bt n → PreStateP bt m
| stopLeaf {m} : m.isLeaf → PreStateP bt m
| stopAtM {m n} : (e : Match.edge m n) → e.isModal → PreStateP bt m

