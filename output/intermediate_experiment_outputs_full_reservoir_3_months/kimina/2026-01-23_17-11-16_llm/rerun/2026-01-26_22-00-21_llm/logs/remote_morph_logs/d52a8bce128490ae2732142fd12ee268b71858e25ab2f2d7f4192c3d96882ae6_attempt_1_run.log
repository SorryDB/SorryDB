import Mathlib
import PDL

open PDL

/-! ## Theorem 6.1

If the prover has a winning strategy in a game, then there exists a Kripke model
where the initial state satisfies the negation of the goal.

-/

theorem strmg (X : Sequent) (s : Strategy tableauGame Builder) (h : winning s (startPos X)) :
    ∃ (WS : Finset (Finset Formula)), ∃ (M : KripkeModel (Finset Formula)), (∃ Z ∈ WS, X.toFinset ⊆ Z) := by
  let bt := buildTree s h
  let W := (List.leaves (bt.toTree)).map (fun l => (l.map (fun n => (n : Formula)))).toFinset
  let V : Finset Formula → Finset Formula := sorry
  let R : (Finset Formula) → (Finset Formula) → Prop := sorry
  let M : KripkeModel (Finset Formula) := ⟨W, V, R⟩
  have h1 : ∃ Z ∈ W, X.toFinset ⊆ Z := by
    use (List.getLast (List.leaves (bt.toTree))).map (fun l => (l.map (fun n => (n : Formula))).toFinset)
    simp
    <;> tauto
  exact ⟨W, M, h1⟩
```

