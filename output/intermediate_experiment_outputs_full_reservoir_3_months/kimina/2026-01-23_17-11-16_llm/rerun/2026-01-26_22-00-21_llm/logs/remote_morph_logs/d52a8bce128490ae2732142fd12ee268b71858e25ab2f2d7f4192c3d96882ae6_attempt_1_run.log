/-- Definition 6.17 to get model graph from strategy tree. -/
@[simp]
def BuildTree.toModel (bt : BuildTree pos) : (Σ W : Finset (Finset Formula), KripkeModel W) :=
  ⟨ ((bt.allPreStates).map (List.toFinset ∘ PreState.forms)).toFinset -- W
