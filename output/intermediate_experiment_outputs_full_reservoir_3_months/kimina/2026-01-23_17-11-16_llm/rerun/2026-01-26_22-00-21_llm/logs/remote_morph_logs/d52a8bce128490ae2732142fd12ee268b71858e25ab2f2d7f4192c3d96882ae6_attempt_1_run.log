    ∀ n, ¬ Nonempty (Match.edge m n) := by
  intro n
  by_contra hyp
  rcases hyp with ⟨m_n⟩
  rcases m_n with ⟨YS, next, mPos, nPos, nPos_in, mvs, h, def_n⟩
  grind

