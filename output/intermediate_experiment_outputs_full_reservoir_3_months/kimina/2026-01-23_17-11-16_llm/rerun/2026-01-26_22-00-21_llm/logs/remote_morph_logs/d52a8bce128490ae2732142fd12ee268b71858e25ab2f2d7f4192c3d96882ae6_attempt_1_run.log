  YS : List GamePos
  next : (newPos : GamePos) → newPos ∈ YS → BuildTree newPos
  mPos : GamePos
  nPos : GamePos
  nPos_in : nPos ∈ YS
  mvs : ∀ newPos ∈ YS, Move mPos newPos
  h : btAt m = ⟨mPos, BuildTree.Step YS mvs next⟩
  def_n : n = m.append (h ▸ @mov mPos YS nPos mvs next nPos_in stop)

