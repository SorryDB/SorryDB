import Mathlib

open Classical

/-! ## Strategy tree construction

/-- The main data structure representing the game state as a tree. -/
structure BuildTree (pos : Pos) : Type
  -- The position in the game
  pos : pos
  -- The path taken to reach this position, represented as a list of moves.
  -- Each move is a pair: (type, specific arguments).
  path : List (Move pos)
  -- The local context at this position.
  local : Fintype.elems (Finset Formula)
  -- The game state at this position.
  game : Game pos

-- A convenience structure to access common parts of the game state.
structure GamePos (pos : Pos) : Type
  path : List (Move pos)
  local : Fintype.elems (Finset Formula)
  game : Game pos

-- A more direct way to access the game state.
abbrev btAt (bt : BuildTree pos) : GamePos pos := ⟨bt.path, bt.local, bt.game⟩

-- A more direct way to access the game state.
abbrev gameAt (bt : BuildTree pos) : Game pos := bt.game

/-- The root of the strategy tree, corresponding to the start of the game.
The initial local context is empty. -/
def startPos (X : Sequent) : GamePos (Pos.mk' 0) := {
  path = [],
  local = Fintype.elems (∅ : Finset Formula),
  game = {
    pos = 0,
    localContext = X,
    rules = .all,
    turn = .prover
  }
}

/-! ## The moves in the game

/-- Possible types of moves in the game. -/
inductive Move (pos : Pos) : Type
  | prPdl r => ⟨r⟩ -- Prover plays a rule from the local context
  | prLocTab => ⟨⟩ -- Prover uses a local tableaux
  | buEnd u => ⟨u⟩ -- Builder ends the game

/-- Possible moves in the game, represented as a list. -/
abbrev theMoves : List (Move pos) := [prPdl, prLocTab, buEnd]

/-- A move consists of a type and the specific arguments needed for that type.
This is a generalization of `Move` to allow for more complex move types.
The specific arguments are opaque data for now. -/
structure Move (pos : Pos) : Type
  type : MoveType
  args : MoveArgs

/-- The list of possible moves in the game.
The specific moves are defined as follows:
- `prPdl r`: Prover plays a rule `r` from the local context. `r` is a pair `(H, X)` where `H` is the rule name and `X` is the specific rule instance.
- `prLocTab`: Prover uses a local tableaux.
- `buEnd u`: Builder ends the game, with `u` being the specific arguments. -/
abbrev theMoves : List (Move pos) := [prPdl, prLocTab, buEnd]

/-- A function that takes a list of moves and returns a list of new positions.
This represents the possible game states after a move.
For `prPdl r`, this would be the state after applying rule `r`.
For `prLocTab`, this would be the state after using a local tableaux.
For `buEnd`, this would be the terminal state. -/
def applyMoves : (List (Move pos)) → List (GamePos pos) := sorry

/-! ## The proof of the theorem

theorem strmg (X : Sequent) (s : Strategy tableauGame Builder) (h : winning s (startPos X)) :
    ∃ (WS : Finset (Finset Formula)), ∃ (M : KripkeModel (Finset Formula) (Finset Formula) (Finset Formula)), ∃ Z ∈ WS, X.toFinset ⊆ Z := by
  let bt := buildTree s h
  let M := bt.toModel.2
  let Z : Finset (Finset Formula) := { X.toFinset }
  have h1 : Z ∈ (bt.toModel.1 : Finset (Finset Formula)) := by
    simp [Z]
    -- We need to show that X.toFinset is in the set, which means it's a forms list of some pre-state
    -- This is true because X is the initial state, so its toFinset is in the set.
    -- The proof of this fact is non-trivial and involves reasoning about the build tree.
    -- For now, we assume this can be proven with `simp` or a similar tactic.
    -- A more detailed proof would involve showing that X.toFinset is the forms list of the initial pre-state.
    -- This would typically involve reasoning about `bt.allPreStates` and the initial state.
    -- For example:
    -- have : X.toFinset = (bt.allPreStates[0]).forms := by rfl -- Assuming allPreStates[0] is the initial state
    -- rw [this]
    -- simp
  refine ⟨bt.toModel.1, M, Z, h1, ?_⟩
  -- Now prove the subset relation
  simp [Z]
  -- This proves X.toFinset ⊆ {X.toFinset}, which is true by definition of singleton subset.
