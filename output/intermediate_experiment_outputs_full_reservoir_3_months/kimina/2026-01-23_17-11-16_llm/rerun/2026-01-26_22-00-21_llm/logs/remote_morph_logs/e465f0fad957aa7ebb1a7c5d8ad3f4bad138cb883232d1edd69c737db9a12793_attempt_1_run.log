  -- Then {x | p x ∧ q x} ∈ 𝓝 x by the property of filters
  -- Similarly {x | p' x ∧ q' x} ∈ 𝓝 x
  -- Then {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x by the property of filters
  -- Let's try to write this in Lean
  -- We need to show {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x
  -- We know {x | p x} ∈ 𝓝 x and {x | q x} ∈ 𝓝 x
  -- So their intersection is in the filter
  have h1 : {x | p x ∧ q x} ∈ 𝓝 x := by
    -- We know {x | p x} ∈ 𝓝 x and {x | q x} ∈ 𝓝 x
    -- The intersection is in the filter
    have h2 : {x | p x} ∩ {x | q x} ∈ 𝓝 x := by
      apply Filter.mem_inter
      exact hT
      exact hS
    -- The set {x | p x ∧ q x} is the same as {x | p x} ∩ {x | q x}
    have h3 : {x | p x ∧ q x} = {x | p x} ∩ {x | q x} := by
      ext y
      simp
    rw [h3]
    exact h2
  -- Similarly for the other disjunct
  have h2 : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    have h3 : {x | p' x} ∩ {x | q' x} ∈ 𝓝 x := by
      apply Filter.mem_inter
      exact hT'
      exact hS'
    have h4 : {x | p' x ∧ q' x} = {x | p' x} ∩ {x | q' x} := by
      ext y
      simp
    rw [h4]
    exact h3
  -- Now we need to show that the union is in the filter
  have h3 : {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    -- We know {x | p x ∧ q x} ∈ 𝓝 x and {x | p' x ∧ q' x} ∈ 𝓝 x
    -- The union is in the filter
    have h4 : {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} ∈ 𝓝 x := by
      apply Filter.mem_union
      exact h1
      exact h2
    -- The set {x | p x ∧ q x ∨ p' x ∧ q' x} is the same as the union
    have h5 : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
      ext y
      simp
      <;> tauto
    rw [h5]
    exact h4
  exact h3

end Filter

