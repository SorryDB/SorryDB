/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := by
    intro s
    if h : π ∈ s then
      1
    else
      0
  empty := by
    simp [measureOf]
  mono {S T} hST := by
    simp [measureOf]
    all_goals aesop
  iUnion_nat := by
    intro s hs
    simp [measureOf]
    all_goals
      try { 
        have h1 : ∀ i, π ∉ s i := by
          intro i
          intro hpi
          have h2 : π ∈ s i := by 
            simpa using hpi
          have h3 : π ∈ s 0 := by 
            apply hs 0 i (by simp)
            all_goals tauto
          have h4 : π ∈ s 0 ∧ π ∈ s i := by 
            constructor <;> assumption
          have h5 : π ∈ s 0 := by 
            tauto
          have h6 : π ∈ s i := by 
            tauto
          -- Contradiction because s i and s 0 are disjoint
          have h7 : Disjoint (s 0) (s i) := by
            apply hs 0 i
            simp
          have h8 : π ∈ s 0 ∩ s i := by 
            exact ⟨h5, h6⟩
          have h9 : π ∈ s 0 ∩ s i := by 
            exact h8
          have h10 : π ∈ s 0 := by 
            tauto
          have h11 : π ∈ s i := by 
            tauto
          -- Use the pairwise disjoint property to get a contradiction
          have h12 : Disjoint (s 0) (s i) := by
            apply hs 0 i
            simp
          -- Contradiction from membership and disjointness
          exact h12 h8
        -- Now we know that π ∉ s i for all i
        -- So the sum is 0
        -- And the measure of the union is 0
        all_goals
          try { 
            simp_all [Finset.sum_eq_zero, h1]
            <;> try { 
              aesop
            }
          }
