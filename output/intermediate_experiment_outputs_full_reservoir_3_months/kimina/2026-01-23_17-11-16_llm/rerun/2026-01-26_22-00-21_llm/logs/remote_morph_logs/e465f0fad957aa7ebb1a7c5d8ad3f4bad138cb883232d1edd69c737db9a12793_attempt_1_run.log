    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : {x | p x ∧ q x} ∈ 𝓝 x := by
    apply Filter.mem_of_inter
    exact hT
    exact hS
  have h2 : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    apply Filter.mem_of_inter
    exact hT'
    exact hS'
  have h3 : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
    ext y
    simp
    <;> tauto
  rw [h3]
  apply Filter.mem_of_union
  exact h1
  exact h2
```

This proof uses basic properties of filters:
- `Filter.mem_of_inter`: If `A ∈ F` and `B ∈ F`, then `A ∩ B ∈ F`
- `Filter.mem_of_union`: If `A ∈ F` and `B ∈ F`, then `A ∪ B ∈ F`
- Set equality `h3` is proven using `ext` and `tauto` (which handles the logical equivalence)

