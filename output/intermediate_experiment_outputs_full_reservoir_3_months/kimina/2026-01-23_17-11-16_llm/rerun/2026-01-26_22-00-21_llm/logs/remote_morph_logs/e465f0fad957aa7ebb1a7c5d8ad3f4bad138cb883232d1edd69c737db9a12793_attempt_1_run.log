      try { 
        -- Case where π is in the union
        -- Then π must be in some s i
        -- Since the sets are pairwise disjoint, π can be in at most one s i
        -- So the sum will have exactly one term equal to 1
        -- And the measure of the union will be 1
        -- So the inequality 1 ≤ 1 holds
        all_goals
          try { 
            simp_all [Finset.sum_eq_zero, Finset.sum_eq_one]
            <;> try { 
