        have h8 : (M x) = ⊤ := by 
          have h9 : (M x) = sSup (SetLike.coe D) := by 
            rw [show sSup (SetLike.coe D) = M by 
              rw [show sSup (SetLike.coe D) = ⊤ by 
                exact h1
              ]
            ]
