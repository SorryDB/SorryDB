  have h1 : sSup (SetLike.coe D) = ⊤ := D.sSup_eq_top'
  have h2 : (sSup (SetLike.coe D)) x = ⊤ := by
    rw [h1]
    all_goals simp
  have h3 : (sSup (SetLike.coe D)) x = ⨆ p ∈ D, p x := by
    simp [sSup]
  rw [h3] at h2
  exact h2
