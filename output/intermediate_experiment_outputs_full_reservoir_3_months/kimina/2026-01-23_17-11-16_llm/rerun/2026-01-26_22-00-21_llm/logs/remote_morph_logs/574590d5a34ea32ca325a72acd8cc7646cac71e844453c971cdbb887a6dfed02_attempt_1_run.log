    . split_ifs at ih with h;
      . rename_i δ hδ;
        have := h ∅ (by tauto);
        contrapose! this;
        have : ⊥ = δ := by grind;
        subst this;
        sorry;
      . assumption;
    . assumption;

lemma construction_rel :
  letI U := construction_omega T hT
  (∀ φ ψ, φ → ψ ∈ T.theory → φ ∈ U → ψ ∈ U) := by
  sorry;
