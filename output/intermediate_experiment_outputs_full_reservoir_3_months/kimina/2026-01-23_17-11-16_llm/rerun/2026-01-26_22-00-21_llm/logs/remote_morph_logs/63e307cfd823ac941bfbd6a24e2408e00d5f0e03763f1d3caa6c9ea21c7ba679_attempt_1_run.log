      <;> try { contradiction }
      <;> try { tauto }
    }
  have S_len_lt : S.length ≤ 2 * m - 5 := by linarith
  have is_min_m : is_minimal m := by
    unfold is_minimal phi is_f_leq
    simp
    constructor
    · exact ⟨m_gt_4, S, ⟨S_allExp, S_len_le⟩⟩
    · intro k k_lt_m four_lt_k σ σ_allExp
      have := m_is_min k k_lt_m four_lt_k σ σ_allExp
      simp_rw [@Nat.le_iff_lt_add_one] at this
      omega
  have noHo_S : noHo S := noHo_of_minimal_expert_sequence S S_len_le S_allExp is_min_m
  -- 2.3 Graph Building -- TODO
