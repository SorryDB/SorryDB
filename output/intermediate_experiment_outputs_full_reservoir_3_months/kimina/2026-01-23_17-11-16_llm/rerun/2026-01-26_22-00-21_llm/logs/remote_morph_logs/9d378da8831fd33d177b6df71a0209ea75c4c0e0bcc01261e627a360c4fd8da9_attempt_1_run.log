/-Wigner matrices are symmetric matrices with diagonal entries distributed according to measure ν and off-diagonal entries distributed according to measure μ.-/
noncomputable
def isWignerMatrix (n : ℕ) (μ ν : Measure ℝ ) (X P : Measure (Matrix (Fin n) (Fin n) ℝ)) : Prop :=
  (Matrix.isSymm X P) ∧ (∀ (i : Fin n), HasLaw (fun ω ↦ X ω i i) ν P) ∧ (∀ (i j : Fin n) (h : i ≠ j), HasLaw (fun ω ↦ X ω i j) μ P)

/-Wigner matrices are symmetric matrices with diagonal entries distributed according to measure ν and off-diagonal entries distributed according to measure μ.-/
noncomputable
def isWignerMatrixMeasure (n : ℕ) (μ ν : Measure ℝ ) : Measure (Matrix (Fin n) (Fin n) ℝ) :=
  Measure.map (fun (ω : (Fin n → ℝ) ) ↦ Matrix.of ω) (Measure.pi (fun i ↦ if i.1 = i.2 then ν else μ))

