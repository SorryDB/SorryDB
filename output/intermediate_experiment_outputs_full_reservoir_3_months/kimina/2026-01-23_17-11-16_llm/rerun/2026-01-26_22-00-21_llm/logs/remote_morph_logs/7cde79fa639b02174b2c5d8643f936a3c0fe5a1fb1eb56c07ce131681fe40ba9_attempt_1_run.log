        exact Logic.iff_provable.mpr hφ
    have h₃ : (Γ.conj ⋏ φ) → ξ ∈ T := T.imp_closed axiomI (T.andIR h₂ h₁)
    have : (Γ.conj ⋏ φ) → ξ ∈ construction_omega T hT := by
      simpa [construction_omega, Set.mem_iUnion]
      use (enc φ + 1)
      simp [construction]
      tauto
    contradiction

lemma construction_omega_L_subset :
  letI U := construction_omega T hT
  L ⊆ U := by
  intro φ hφ
  simp only [construction_omega, Set.mem_iUnion]
  use (enc φ + 1)
  simp [construction]
  split_ifs with h
  · tauto
  · exfalso
    push_neg at h
    obtain ⟨Γ, hΓ, h₁⟩ := h
    have h₂ : (Γ.conj ⋏ φ) → (Γ.conj ⋏ φ) ∈ T := by
