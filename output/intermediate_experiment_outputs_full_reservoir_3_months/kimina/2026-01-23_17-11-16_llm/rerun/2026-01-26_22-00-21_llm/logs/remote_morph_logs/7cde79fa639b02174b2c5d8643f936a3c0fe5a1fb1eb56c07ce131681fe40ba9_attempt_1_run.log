      if ∀ Γ : Finset (Formula _), ↑Γ ⊆ T' → Γ.conj ⋏ δ ➝ ξ ∉ T.theory then insert δ T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : χ ➝ ξ ∉ T.theory) : Set (Formula ℕ) := ⋃ i, construction T hT i
