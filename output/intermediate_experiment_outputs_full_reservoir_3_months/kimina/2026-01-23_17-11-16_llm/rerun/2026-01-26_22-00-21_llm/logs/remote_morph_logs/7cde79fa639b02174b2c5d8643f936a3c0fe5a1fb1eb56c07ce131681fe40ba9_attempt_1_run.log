    split at hi;
    . split_ifs at hi with h;
      . rename_i δ hδ;
        by_contra hC;
        have : δ = φ := by grind;
        subst this;
        apply h Γ ((show encode δ = i by sorry) ▸ hΓ) hφ;
      . assumption
    . assumption;
