    split;
    . split_ifs with h;
      . rename_i δ hδ;
        by_contra hC;
        have : δ = φ := by grind;
        subst this;
        apply h ∅ (by tauto);
        apply hC;
      . assumption
    . assumption;

lemma of_not_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∉ construction_omega T hT) :
  (χ → φ ∉ T.theory) ∧ (∃ (k : Set (Formula ℕ)), ↑k ⊆ (construction T hT (encode φ)) ∧ k.conj ⋏ φ → ξ ∈ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hφ;
  constructor;
  . simpa using hφ 0;
  . have this := hφ (encode φ + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this;
    . simpa using h;


