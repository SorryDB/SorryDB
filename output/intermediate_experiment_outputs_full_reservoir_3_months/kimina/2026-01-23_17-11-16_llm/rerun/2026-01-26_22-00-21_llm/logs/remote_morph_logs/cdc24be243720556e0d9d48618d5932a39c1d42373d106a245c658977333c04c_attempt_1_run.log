import Problems.NavierStokes.Imports

open ComplexConjugate RCLike
/--
This is almost `InnerProductSpace` but we do not require that norm originates from the inner product.

The reason for this class it to be able to have inner product on spaces line `в„қГ—в„қ` and `О№ вҶ’ в„қ`
as they are by default equiped by max norm which is not compatible with inner product. -/
class AdjointSpace (рқ•ң : Type*) (E : Type*) [RCLike рқ•ң] [NormedAddCommGroup E] extends
  NormedSpace рқ•ң E, Inner рқ•ң E where
  /-- Norm induced by inner is topologicaly equivalent to the given norm -/
  inner_top_equiv_norm : вҲғ c d : в„қ,
    c > 0 вҲ§ d > 0 вҲ§
    вҲҖ x : E, (c вҖў вҖ–xвҖ–^2 вүӨ re (inner x x)) вҲ§ (re (inner x x) вүӨ d вҖў вҖ–xвҖ–^2)
  /-- The inner product is *hermitian*, taking the `conj` swaps the arguments. -/
  conj_symm : вҲҖ x y, conj (inner y x) = inner x y
  /-- The inner product is additive in the first coordinate. -/
  add_left : вҲҖ x y z, inner (x + y) z = inner x z + inner y z
  /-- The inner product is conjugate linear in the first coordinate. -/
  smul_left : вҲҖ x y r, inner (r вҖў x) y = conj r * inner x y

attribute [instance low] AdjointSpace.toNormedSpace AdjointSpace.toInner

/-! ### Properties of inner product spaces -/

namespace AdjointSpace

variable {рқ•ң E F : Type*} [RCLike рқ•ң]

variable [NormedAddCommGroup E] [AdjointSpace рқ•ң E]
variable [NormedAddCommGroup F] [AdjointSpace в„қ F]

local notation "вҹӘ" x ", " y "вҹ«" => @inner рқ•ң E _ x y
local notation "вҖ–" x "вҖ–вӮӮВІ" => @inner рқ•ң E _ x x

local notation "IK" => @RCLike.I рқ•ң _

local postfix:90 "вҖ " => starRingEnd _

export InnerProductSpace (norm_sq_eq_inner)

open RCLike ComplexConjugate InnerProductSpace

section BasicProperties

@[simp mid+1]
theorem inner_conj_symm (x y : E) : вҹӘy, xвҹ«вҖ  = вҹӘx, yвҹ« := by rw[conj_symm]

theorem real_inner_comm (x y : F) : вҹӘy, xвҹ«_в„қ = вҹӘx, yвҹ«_в„қ := by
  rw[вҶҗ conj_symm]; simp only [conj_trivial]

theorem inner_eq_zero_symm {x y : E} : вҹӘx, yвҹ« = 0 вҶ” вҹӘy, xвҹ« = 0 := by
  rw [вҶҗ inner_conj_symm]
  exact star_eq_zero

@[simp mid+1]
theorem inner_self_im (x : E) : RCLike.im вҹӘx, xвҹ« = 0 := by
  rw [вҶҗ @ofReal_inj рқ•ң, im_eq_conj_sub]; simp

theorem inner_add_left (x y z : E) : вҹӘx + y, zвҹ« = вҹӘx, zвҹ« + вҹӘy, zвҹ« := by rw[add_left]

theorem inner_add_right (x y z : E) : вҹӘx, y + zвҹ« = вҹӘx, yвҹ« + вҹӘx, zвҹ« := by
  rw [вҶҗ inner_conj_symm, inner_add_left, RingHom.map_add]
  simp only [inner_conj_symm]

theorem inner_re_symm (x y : E) : re вҹӘx, yвҹ« = re вҹӘy, xвҹ« := by rw [вҶҗ inner_conj_symm, conj_re]

theorem inner_im_symm (x y : E) : im вҹӘx, yвҹ« = -im вҹӘy, xвҹ« := by rw [вҶҗ inner_conj_symm, conj_im]

theorem inner_smul_left (x y : E) (r : рқ•ң) : вҹӘr вҖў x, yвҹ« = rвҖ  * вҹӘx, yвҹ« := by rw [smul_left]

theorem real_inner_smul_left (x y : F) (r : в„қ) : вҹӘr вҖў x, yвҹ«_в„қ = r * вҹӘx, yвҹ«_в„қ :=
  inner_smul_left _ _ _

theorem inner_smul_real_left (x y : E) (r : в„қ) : вҹӘ(r : рқ•ң) вҖў x, yвҹ« = r вҖў вҹӘx, yвҹ« := by
  rw [inner_smul_left, conj_ofReal, Algebra.smul_def]

theorem inner_smul_right (x y : E) (r : рқ•ң) : вҹӘx, r вҖў yвҹ« = r * вҹӘx, yвҹ« := by
  rw [вҶҗ inner_conj_symm, inner_smul_left, RingHom.map_mul, conj_conj, inner_conj_symm]

theorem real_inner_smul_right (x y : F) (r : в„қ) : вҹӘx, r вҖў yвҹ«_в„қ = r * вҹӘx, yвҹ«_в„қ :=
  inner_smul_right _ _ _

theorem inner_smul_real_right (x y : E) (r : в„қ) : вҹӘx, (r : рқ•ң) вҖў yвҹ« = r вҖў вҹӘx, yвҹ« := by
  rw [inner_smul_right, Algebra.smul_def]

/-- The inner product as a sesquilinear form.

Note that in the case `рқ•ң = в„қ` this is a bilinear form. -/
@[simps!]
def sesqFormOfInner : E вҶ’вӮ—[рқ•ң] E вҶ’вӮ—вӢҶ[рқ•ң] рқ•ң :=
  LinearMap.mkвӮӮ'вӮӣвӮ— (RingHom.id рқ•ң) (starRingEnd _) (fun x y => вҹӘy, xвҹ«)
    (fun _x _y _z => inner_add_right _ _ _) (fun _r _x _y => inner_smul_right _ _ _)
    (fun _x _y _z => inner_add_left _ _ _) fun _r _x _y => inner_smul_left _ _ _

/-- An inner product with a sum on the left. -/
theorem sum_inner {О№ : Type*} (s : Finset О№) (f : О№ вҶ’ E) (x : E) :
    вҹӘвҲ‘ i вҲҲ s, f i, xвҹ« = вҲ‘ i вҲҲ s, вҹӘf i, xвҹ« :=
  map_sum (sesqFormOfInner (рқ•ң := рқ•ң) (E := E) x) _ _

/-- An inner product with a sum on the right. -/
theorem inner_sum {О№ : Type*} (s : Finset О№) (f : О№ вҶ’ E) (x : E) :
    вҹӘx, вҲ‘ i вҲҲ s, f iвҹ« = вҲ‘ i вҲҲ s, вҹӘx, f iвҹ« :=
  map_sum (LinearMap.flip sesqFormOfInner x) _ _

@[simp mid+1]
theorem inner_zero_left (x : E) : вҹӘ0, xвҹ« = 0 := by
  rw [вҶҗ zero_smul рқ•ң (0 : E), inner_smul_left, RingHom.map_zero, zero_mul]

theorem inner_re_zero_left (x : E) : re вҹӘ0, xвҹ« = 0 := by
  simp only [inner_zero_left, AddMonoidHom.map_zero]

@[simp mid+1]
theorem inner_zero_right (x : E) : вҹӘx, 0вҹ« = 0 := by
  rw [вҶҗ inner_conj_symm, inner_zero_left, RingHom.map_zero]

theorem inner_re_zero_right (x : E) : re вҹӘx, 0вҹ« = 0 := by
  simp only [inner_zero_right, AddMonoidHom.map_zero]

theorem inner_self_nonneg {x : E} : 0 вүӨ re вҹӘx, xвҹ« := by
  have вҹЁc,d,hc,_,hвҹ© := inner_top_equiv_norm (рқ•ң:=рқ•ң) (E:=E)
  have вҹЁh'',_вҹ© := h x
  apply le_trans _ h''
  positivity

theorem real_inner_self_nonneg {x : F} : 0 вүӨ вҹӘx, xвҹ«_в„қ :=
  @inner_self_nonneg в„қ F _ _ _ x

@[simp mid+1]
theorem inner_self_ofReal_re (x : E) : (re вҹӘx, xвҹ« : рқ•ң) = вҹӘx, xвҹ« :=
  ((RCLike.is_real_TFAE (вҹӘx, xвҹ« : рқ•ң)).out 2 3).2 (inner_self_im _)

@[simp mid+1]
theorem inner_self_nonpos {x : E} : re вҹӘx, xвҹ« вүӨ 0 вҶ” x = 0 := by
  constructor
  В· have вҹЁc,d,hc,_,hвҹ© := inner_top_equiv_norm (рқ•ң:=рқ•ң) (E:=E)
    have вҹЁh,_вҹ© := h x
