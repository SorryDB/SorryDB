import Problems.NavierStokes.Imports

open ComplexConjugate RCLike
/--
This is almost `InnerProductSpace` but we do not require that norm originates from the inner product.

The reason for this class it to be able to have inner product on spaces line `в„қГ—в„қ` and `О№ вҶ’ в„қ`
as they are by default equiped by max norm which is not compatible with inner product. -/
class AdjointSpace (рқ•ң : Type*) (E : Type*) [RCLike рқ•ң] [NormedAddCommGroup E] extends
  NormedSpace рқ•ң E, Inner рқ•ң E where
  /-- Norm induced by inner is topologicaly equivalent to the given norm -/
  inner_top_equiv_norm : вҲғ c d : в„қ,
    c > 0 вҲ§ d > 0 вҲ§
    вҲҖ x : E, (c вҖў вҖ–xвҖ–^2 вүӨ re (inner x x)) вҲ§ (re (inner x x) вүӨ d вҖў вҖ–xвҖ–^2)
  /-- The inner product is *hermitian*, taking the `conj` swaps the arguments. -/
  conj_symm : вҲҖ x y, conj (inner y x) = inner x y
  /-- The inner product is additive in the first coordinate. -/
  add_left : вҲҖ x y z, inner (x + y) z = inner x z + inner y z
  /-- The inner product is conjugate linear in the first coordinate. -/
  smul_left : вҲҖ x y r, inner (r вҖў x) y = conj r * inner x y

attribute [instance low] AdjointSpace.toNormedSpace AdjointSpace.toInner

/-! ### Properties of inner product spaces -/

