import Mathlib
open Filter

/- The main theorem establishes that if a linear map T satisfies certain conditions (HasRestrictedWeakType, HolderConjugate, and continuity properties), then T is a Lorentz-type operator.
Specifically, it proves that eLpNorm (T f) 1 (ν.restrict G) ≤ (4 * c / p) * eLorentzNorm f p 1 μ * (ν G) ^ p'⁻¹.toReal.
-/

theorem HasLorentzType {T : (α → 𝕂) → (α' → ε')} {p p' : ℝ≥0∞}
    {μ : Measure α} [IsLocallyFiniteMeasure μ] {ν : Measure α'} {c : ℝ≥0} (c_pos : 0 < c)
    (hT : HasRestrictedWeakType T p p' μ ν c) (hpp' : p.HolderConjugate p')
    (T_meas : ∀ {f : α → 𝕂}, (MemLorentz f p 1 μ) → AEStronglyMeasurable (T f) ν)
    (T_subadd : ∀ (f g : α → 𝕂) (x : α'), (MemLorentz f p 1 μ) → (MemLorentz g p 1 μ) →
      ‖T (f + g) x‖ₑ ≤ ‖T f x + T g x‖ₑ)
    (T_submul : ∀ (a : 𝕂) (f : α → 𝕂) (x : α'), ‖T (a • f) x‖ₑ ≤ ‖a‖ₑ • ‖T f x‖ₑ)
    (weakly_cont_T : ∀ {f : α → 𝕂} {fs : ℕ → α → 𝕂}
                     (f_locInt : LocallyIntegrable f μ)
                     (hF_meas : ∀ (n : ℕ), AEStronglyMeasurable (fs n) μ)
                     (h_norm_monotone : ∀ (a : α), Monotone (fun n ↦ ‖fs n a‖))
                     (h_lim : ∀ (a : α), Filter.Tendsto (fun (n : ℕ) => fs n a) Filter.atTop (nhds (f a)))
                     (G : Set α'),
    eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n ↦ eLpNorm (T (fs n)) 1 (ν.restrict G)) Filter.atTop)

    :

  --(weakly_cont_T : WeaklyContinuous T μ ν) : --TODO: correct assumption with modified T
    --TODO: might have to adjust the constant
    HasLorentzType T p 1 p ∞ μ ν (4 * c / p) := by
  intro f hf
  --have hp : 1 ≤ p := by sorry --use: should follow from hpp'
  have claim : ∀ (G : Set α'), (MeasurableSet G) → (ν G < ∞) → eLpNorm (T f) 1 (ν.restrict G)
    ≤ (4 * c / p) * eLorentzNorm f p 1 μ * (ν G) ^ p'⁻¹.toReal := by
      intro G measurable_G G_finite
      rcases hf with ⟨aemeasurable_f, hf⟩
      revert f --TODO: go on here
      apply AEStronglyMeasurable.induction
      · intro f g stronglyMeasurable_f hfg hf hg
        have : eLorentzNorm f p 1 μ < ⊤ := by
          sorry --use: hg
        have hf := hf this
        sorry --use: hf
      intro g stronglyMeasurable_g hg
      set f₁ := fun x ↦ Real.toNNReal (RCLike.re (g x))
      set f₂ := fun x ↦ Real.toNNReal (- RCLike.re (g x))
      set f₃ := fun x ↦ Real.toNNReal (RCLike.im (g x))
      set f₄ := fun x ↦ Real.toNNReal (- RCLike.im (g x))
      have h1 : g = f₁ + f₂ + f₃ + f₄ := by
        simp [Pi.add_apply, Pi.smul_apply, algebraMap, *]
        <;> ring_nf <;> simp [norm_algebraMap, Real.norm_eq_abs, NNReal.abs_eq]
        <;> ring
      set T'' := T ∘ (fun f : α → ℝ≥0 ↦ algebraMap ℝ 𝕂 ∘ NNReal.toReal ∘ f)
      have hf1 : Measurable f₁ := by simpa using hg1
      have hf2 : Measurable f₂ := by simpa using hg2
      have hf3 : Measurable f₃ := by simpa using hg3
      have hf4 : Measurable f₄ := by simpa using hg4

      have hf'1 : LocallyIntegrable f₁ μ := by simpa using hg'1
      have hf'2 : LocallyIntegrable f₂ μ := by simpa using hg'2
      have hf'3 : LocallyIntegrable f₃ μ := by simpa using hg'3
      have hf'4 : LocallyIntegrable f₄ μ := by simpa using hg'4

      have hf''1 : @MeasureTheory.MemLorentz α NNReal m0 instENormedSpaceNNReal.toENorm f₁ p 1 μ := by simpa using hg''1
      have hf''2 : @MeasureTheory.MemLorentz α NNReal m0 instENormedSpaceNNReal.toENorm f₂ p 1 μ := by simpa using hg''2
      have hf''3 : @MeasureTheory.MemLorentz α NNReal m0 instENormedSpaceNNReal.toENorm f₃ p 1 μ := by simpa using hg''3
      have hf''4 : @MeasureTheory.MemLorentz α NNReal m0 instENormedSpaceNNReal.toENorm f₄ p 1 μ := by simpa using hg''4

      have h2 : eLpNorm (T'' f₁) 1 (ν.restrict G) ≤ (4 * c / p) * @MeasureTheory.eLorentzNorm α NNReal m0 instENormedSpaceNNReal.toENorm f₁ p 1 μ * ν G ^ p'⁻¹.toReal := by
        apply HasLorentzType T'' p 1 p' ∞ μ ν (4 * c / p)
        all_goals
          try { tauto }
          try { simpa using hf1 }
