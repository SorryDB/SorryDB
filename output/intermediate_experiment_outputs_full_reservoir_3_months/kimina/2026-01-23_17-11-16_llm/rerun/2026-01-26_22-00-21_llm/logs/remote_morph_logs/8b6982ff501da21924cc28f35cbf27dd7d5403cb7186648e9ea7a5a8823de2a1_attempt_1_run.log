      apply Measurable.comp
      · exact (Measurable.neg (stronglyMeasurable_g.re)).mpr
      · exact measurable_coe_toNNReal

    have g₂_memLorentz : @MeasureTheory.MemLorentz α NNReal m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace g₂ p 1 μ := by
      sorry

    have h2 : eLpNorm (T' g₂) 1 (ν.restrict G) ≤ (c / p) * eLorentzNorm g₂ p 1 μ * ν G ^ p'⁻¹.toReal := by
      apply helper g₂
      · exact g₂_meas
      · exact g₂_memLorentz
```

For `g₃` and `g₄`, the proofs are analogous.

```tactics
