/- Given a function g : α → K, we define g₁, g₂, g₃, g₄ to be the real and imaginary parts of g.
  Specifically, g₁(x) = Re(g(x)), g₂(x) = -Re(g(x)), g₃(x) = Im(g(x)), g₄(x) = -Im(g(x)).
  This decomposition is useful for applying theorems related to real-valued functions
  to complex-valued functions, by considering them as vector-valued functions
  with components in ℝ.
  The proof of this decomposition relies on the properties of complex numbers,
  specifically that any complex number z can be written as x + iy where x, y ∈ ℝ,
  and that the real and imaginary parts of a complex number are unique.
  The proof uses extensionality (`ext x`) to show that the functions are equal pointwise.
  At each point x, it uses `simp` with the definitions of g₁, ..., g₄ and properties of complex numbers
  (like `Complex.ext_iff`, `mul_add`, `add_mul`, `mul_assoc`) to simplify the expressions and show equality.
  The `<;> ring_nf <;> simp [Complex.ext_iff] <;> ring` part is used to handle the algebraic manipulations
  required to show that the complex number constructed from the real/imaginary parts
  is equal to the original complex number.
  This lemma is crucial for breaking down complex-valued functions into their real components
  when applying theorems that are primarily stated for real-valued functions.
  -/
lemma ComplexDecomposition {K : Type u_1} [RCLike K] [AddCommGroupWithOne K] [InnerProductSpace ℝ K] {g : α → K}
    (g₁ : α → ℝ) (g₂ : α → ℝ) (g₃ : α → ℝ) (g₄ : α → ℝ) :
    g = (1 : K) • (g₁) + (-1 : K) • (g₂) + (RCLike.I : K) • (g₃) + (-RCLike.I : K) • (g₄) := by
  set g₁ := fun x ↦ Real.toNNReal (RCLike.re (g x))
  set g₂ := fun x ↦ Real.toNNReal (- RCLike.re (g x))
  set g₃ := fun x ↦ Real.toNNReal (RCLike.im (g x))
  set g₄ := fun x ↦ Real.toNNReal (- RCLike.im (g x))
  have g_decomposition : g = (1 : K) • (algebraMap ℝ K ∘ NNReal.toReal ∘ g₁)
    + (-1 : K) • (algebraMap ℝ K ∘ NNReal.toReal ∘ g₂)
    + (RCLike.I : K) • (algebraMap ℝ K ∘ NNReal.toReal ∘ g₃)
    + (-RCLike.I : K) • (algebraMap ℝ K ∘ NNReal.toReal ∘ g₄) := by
    ext x
    simp only [g₁, g₂, g₃, g₄]
    simp [Complex.ext_iff, mul_add, add_mul, mul_assoc]
    <;> ring_nf <;> simp [Complex.ext_iff] <;> ring
  exact g_decomposition

