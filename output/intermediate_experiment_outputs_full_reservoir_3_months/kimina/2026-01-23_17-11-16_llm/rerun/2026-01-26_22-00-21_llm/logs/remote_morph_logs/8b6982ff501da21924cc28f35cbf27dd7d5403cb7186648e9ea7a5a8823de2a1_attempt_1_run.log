import Mathlib
open Real

/- An operator T is said to be of Lorentz type if it maps functions from one Lorentz space to another.
Specifically, T is of type (p, q) if for all functions f in L^p, the norm of Tf is in L^q.
This generalizes the concept of operators between Lebesgue spaces.
The specific case where q = p corresponds to operators bounded with respect to the Lorentz norms.
Operators of Lorentz type play a crucial role in harmonic analysis and the study of function spaces. -/
structure HasLorentzType (T : (α → 𝕂) → (α' → ε')) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (ν : Measure α')
    (C : ℝ≥0) : Prop :=
  ∀ (f : α → 𝕂), (eLorentzNorm f p 1 μ < ⊤) → (eLpNorm (T f) q (ν.restrict (Set.univ : Set α')) < ⊤) →
    eLpNorm (T f) q (ν.restrict (Set.univ : Set α')) ≤ C * eLorentzNorm f p 1 μ

/- An operator T is said to be of restricted weak type if it maps functions from one Lorentz space to another, but only on a bounded set.
Specifically, T is of restricted weak type (p, q) with respect to measures μ and ν, and a constant c if for all functions f in L^p, the norm of Tf restricted to any bounded set G is bounded by c times the norm of f.
This is a weaker condition than being of full Lorentz type, but it is often easier to prove and is still sufficient for many applications.
Operators of restricted weak type are important in the study of singular integrals and their boundedness properties.
The theorem states that if an operator T is of restricted weak type (p, p') with respect to measures μ and ν, and satisfies certain additional conditions (like being weakly continuous and mapping strongly measurable functions to strongly measurable functions), then it is also of Lorentz type (p, 1) with a specific constant related to p and the Holder conjugate p'. -/
structure HasRestrictedWeakType (T : (α → 𝕂) → (α' → ε')) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (ν : Measure α')
    (c : ℝ≥0) : Prop :=
  ∀ (f : α → 𝕂) (G : Set α'), (eLorentzNorm f p 1 μ < ⊤) → (eLpNorm (T f) q (ν.restrict G) < ⊤) →
    eLpNorm (T f) q (ν.restrict G) ≤ c * eLorentzNorm f p 1 μ

/- An operator T is said to be weakly continuous if it maps bounded sets to bounded sets in the target space.
Specifically, for any sequence of functions f_n that converges pointwise to a function f, the norms of Tf_n converge to the norm of Tf.
This is a weaker condition than continuity but is still important for the behavior of operators on function spaces.
Weakly continuous operators are key in the study of operator theory and functional analysis. -/
structure WeaklyContinuous (T : (α → 𝕂) → (α' → ε')) (p : ℝ≥0∞) (μ : Measure α) (ν : Measure α') :
  ∀ {f : α → 𝕂} {fs : ℕ → α → 𝕂}, (LocallyIntegrable f μ) →
    (∀ (n : ℕ), AEStronglyMeasurable (fs n) μ) →
      (∀ (a : α), Monotone fun n => ‖fs n a‖) →
        (∀ (a : α), Filter.Tendsto (fun n => fs n a) Filter.atTop (nhds (f a))) →
          ∀ (G : Set α'), eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n => eLpNorm (T (fs n)) 1 (ν.restrict G)) Filter.atTop

/- An operator T is said to be of restricted weak type (p, p') if it is of restricted weak type (p, p') and satisfies certain additional conditions.
Specifically, it requires that T maps functions from L^p to L^{p'} (where p' is the Holder conjugate of p) and that T is weakly continuous.
This is a key result that connects the different types of operator boundedness and is crucial for the theory of singular integrals. -/
structure HasRestrictedWeakType' (T : (α → 𝕂) → (α' → ε')) (p : ℝ≥0∞) (p' : ℝ≥0∞) (μ : Measure α) (ν : Measure α')
    (c : ℝ≥0) : Prop :=
  HasRestrictedWeakType T p p' μ ν c ∧
    p.HolderConjugate p' ∧
    ∀ {f : α → 𝕂}, (eLorentzNorm f p 1 μ < ⊤) → (eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) < ⊤) →
      eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) ≤ c * eLorentzNorm f p 1 μ ∧
    ∀ {f : α → 𝕂}, (eLorentzNorm f p 1 μ < ⊤) → (eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) < ⊤) →
      eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) ≤ c * eLorentzNorm f p 1 μ ∧
    ∀ {f : α → 𝕂}, (eLorentzNorm f p 1 μ < ⊤) → (eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) < ⊤) →
      eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) ≤ c * eLorentzNorm f p 1 μ ∧
    ∀ {f : α → 𝕂}, (eLorentzNorm f p 1 μ < ⊤) → (eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) < ⊤) →
      eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) ≤ c * eLorentzNorm f p 1 μ ∧
    ∀ {f : α → 𝕂}, (eLorentzNorm f p 1 μ < ⊤) → (eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) < ⊤) →
      eLpNorm (T f) p' (ν.restrict (Set.univ : Set α')) ≤ c * eLorentzNorm f p 1 μ ∧
