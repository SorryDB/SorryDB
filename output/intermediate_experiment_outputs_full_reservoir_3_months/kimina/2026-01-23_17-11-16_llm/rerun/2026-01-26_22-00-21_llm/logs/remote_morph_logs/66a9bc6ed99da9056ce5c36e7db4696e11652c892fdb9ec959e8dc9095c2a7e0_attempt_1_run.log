  have h1 : ContMDiffAt IB (fun b : B => (e.coordChangeL 𝕜 e' b : F →L[𝕜] F)) (↑⊤) x₀ := by
    have h2 : x₀ ∈ (e.open_baseSet).inter (e'.open_baseSet) := by
      simpa using hx₀
    have h3 : ContMDiffOn IB (fun b : B => (e.coordChangeL 𝕜 e' b : F →L[𝕜] F)) (↑⊤) (e.open_baseSet).inter (e'.open_baseSet) := by
      apply contMDiffOn_coordChangeL
      all_goals
        try { tauto }
        try { 
          simp_all [e.mem_trivialization_atlas, e'.mem_trivialization_atlas]
          all_goals tauto 
        }
    have h4 : x₀ ∈ (e.open_baseSet).inter (e'.open_baseSet) := h2
    exact h3.contMDiffAt x₀ h4
  have h2 : ↑n ≤ (↑⊤ : Filter.NeighborFilter B) := by
    simp at *
    all_goals
