    exact h1.of_le h2
  have h4 : ContMDiffAt IB (fun x : M => e.coordChangeL 𝕜 e' (f x)) n x₀ := by
    apply h3.comp hf
  have h5 : ContMDiffAt IM (fun x : M => e.coordChangeL 𝕜 e' (f x) (g x)) n x₀ := by
