    all_goals try { 
      have h2 : (n : ℕ∞) ≤ (⊤ : ℕ∞) := by 
        simp 
        all_goals try { 
          try { 
            native_decide 
          } 
          all_goals try { 
            try { 
              trivial 
            } 
          } 
        }
      exact_mod_cast h2 
    }
  exact_mod_cast h1 
