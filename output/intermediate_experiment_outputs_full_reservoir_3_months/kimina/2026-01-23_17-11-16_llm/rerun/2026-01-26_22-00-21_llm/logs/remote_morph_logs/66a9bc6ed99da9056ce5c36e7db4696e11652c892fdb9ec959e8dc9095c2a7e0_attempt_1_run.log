  (contMDiffOn_coordChangeL e e').contMDiffAt <| (e.open_baseSet.inter e'.open_baseSet).mem_nhds hx₀

variable {IB}

theorem contMDiffAt_coord_change_apply (e e' : Trivialization F (π F E)) {x₀ : M} {f : M → B} {g : M → F} (hf : ContMDiffAt IM IB n f x₀) (hg : ContMDiffAt IM (modelWithCornersSelf 𝕜 F) n g x₀) (hx₀ : f x₀ ∈ e.baseSet ∩ e'.baseSet) [MemTrivializationAtlas e] [MemTrivializationAtlas e'] :
    ContMDiffAt IM (modelWithCornersSelf 𝕜 F) n (fun x ↦ e.coordChangeL 𝕜 e' (f x) (g x)) x₀ := by 
