theorem contMDiffAt_coord_change_apply (e e' : Trivialization F (π F E)) {x₀ : M} {f : M → B} {g : M → F} (hf : ContMDiffAt IM IB n f x₀) (hg : ContMDiffAt IM 𝓘(𝕜, F) n g x₀)
    (hx₀ : f x₀ ∈ e.baseSet ∩ e'.baseSet) [MemTrivializationAtlas e] [MemTrivializationAtlas e'] :
