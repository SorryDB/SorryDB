    (hx₀ : f x₀ ∈ e.baseSet ∩ e'.baseSet) [MemTrivializationAtlas e] [MemTrivializationAtlas e'] :
    ContMDiffAt IM 𝓘(𝕜, F) n (fun x ↦ e.coordChangeL 𝕜 e' (f x) (g x)) x₀ := by
  have h1 : n ≤ ⊤ := by 
    simp
  have h2 : ContMDiffAt IB (L[𝕜] F) n (fun x => e.coordChangeL 𝕜 e' (f x) (g x)) x₀ := by
    have h3 : ContMDiffAt IB (L[𝕜] F) ∞ (fun x => e.coordChangeL 𝕜 e' x) x₀ := by
