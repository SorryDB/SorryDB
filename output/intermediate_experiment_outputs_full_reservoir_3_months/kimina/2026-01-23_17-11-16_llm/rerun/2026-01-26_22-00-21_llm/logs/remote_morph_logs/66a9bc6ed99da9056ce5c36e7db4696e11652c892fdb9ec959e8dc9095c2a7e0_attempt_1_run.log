    (h : f.curry =ᶠ[𝓝[s] z.1] g.curry) : f =ᶠ[𝓝[Prod.fst ⁻¹' s] z] g :=
  Filter.Eventually.nhdsWithin_preimage_fst <| by simp_rw [← funext_iff]; exact h

theorem eventually_mem_nhds_within' {α} [TopologicalSpace α] {s t : Set α} {a : α} :
