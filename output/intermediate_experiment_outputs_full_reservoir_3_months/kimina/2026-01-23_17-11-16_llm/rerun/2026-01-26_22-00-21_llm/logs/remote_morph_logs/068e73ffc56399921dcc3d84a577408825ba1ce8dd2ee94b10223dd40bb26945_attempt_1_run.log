```lean
import Mathlib

open DiffeologicalSpace

/-!
# Diffeological Groups

A *diffeological group* is a group `G` equipped with a *diffeology* such that the group operations (multiplication, inverse, and identity) are *smooth* with respect to this diffeology. The framework for diffeological spaces in Mathlib provides the necessary tools to formalize this concept.

We define `DiffeologicalGroup` as a typeclass that extends `DiffeologicalSpace` and `DiffeologicalGroup`. This allows us to leverage the existing infrastructure for diffeological spaces and groups in Mathlib.

```tactics
import Mathlib

open DiffeologicalSpace

/-!
A diffeological group is a group with a diffeology such that all group operations are smooth.
-/
@[to_additive]
class DiffeologicalGroup (G : Type*) extends DiffeologicalSpace G, DiffeologicalGroup G where

/-!
If multiplication is continuous in `α`, then it also is in `αᵐᵒᵖ`. -/
@[to_additive /-- If addition is continuous in `α`, then it also is in `αᵃᵒᵖ`. -/]
instance {G : Type*} [DiffeologicalSpace G] [Group G] [DiffeologicalGroup G] :
    DiffeologicalGroup Gᵐᵒᵖ where
  toDiffeologicalSpace := fun x ↦ x
  toDiffeologicalGroup := fun x y ↦ y * x
  dsmooth_mul := dsmooth_mul.symm
  dsmooth_inv := dsmooth_inv.symm

/-!
The map `(x, y) ↦ (x, x * y)` as a diffeomorphism. This is a shear mapping.
-/
@[to_additive /-- The map `(x, y) ↦ (x, x + y)` as a homeomorphism. This is a shear mapping. -/]
def DDiffeomorph.shearMulRight : G × G ᵈ≃ G × G :=
  { Equiv.prodShear (Equiv.refl _) Equiv.mulLeft with
    dsmooth_toFun := dsmooth_fst.prod_mk dsmooth_mul
    dsmooth_invFun := dsmooth_fst.prod_mk <| dsmooth_fst.inv.mul dsmooth_snd }

/-!
The map `(x, y) ↦ (x, x * y)` as a diffeomorphism. This is a shear mapping.
-/
@[to_additive (attr := simp)]
theorem DDiffeomorph.shearMulRight_coe :
    ⇑(DDiffeomorph.shearMulRight G) = fun z : G × G ↦ (z.1, z.1 * z.2) :=
  rfl

/-!
The map `(x, y) ↦ (x, x * y)` as a diffeomorphism. This is a shear mapping.
-/
@[to_additive (attr := simp)]
theorem DDiffeomorph.shearMulRight_symm_coe :
    ⇑(DDiffeomorph.shearMulRight G).symm = fun z : G × G ↦ (z.1, z.1⁻¹ * z.2) :=
  rfl

variable {G}

/-!
For any group homomorphism to a diffeological group, the induced diffeology makes the
domain a diffeological group too.
-/
@[to_additive /-- For any group homomorphism to a diffeological group, the induced diffeology makes
  the domain a diffeological group too. -/]
protected theorem IsDInducing.diffeologicalGroup {F : Type*} [Group H] [DiffeologicalSpace H]
    [FunLike F H G] [MonoidHomClass F H G] (f : F) (hf : IsDInducing f) : DiffeologicalGroup H :=
  { toDSmoothMul := hf.dsmoothMul _
    toDSmoothInv := hf.dsmoothInv (map_inv f) }

/-!
For any group homomorphism to a diffeological group, the induced diffeology makes the
domain a diffeological group too.
-/
@[to_additive]
theorem diffeologicalGroup_induced {F : Type*} [Group H] [FunLike F H G] [MonoidHomClass F H G]
    (f : F) : @DiffeologicalGroup H (DiffeologicalSpace.induced f ‹_›) _ :=
  letI := DiffeologicalSpace.induced f ‹_›
  { toDSmoothMul := dsmoothMul_induced f
    toDSmoothInv := dsmoothInv_induced f (map_inv f) }

namespace Subgroup

@[to_additive]
instance (S : Subgroup G) : DiffeologicalGroup S :=
  isInduction_subtype_val.diffeologicalGroup S.subtype

end Subgroup

/-!
The quotient group `G/N` has the quotient topology, and hence the quotient diffeology.
-/
end DiffeologicalGroup

/-!
The quotient group `G/N` has the quotient topology, and hence the quotient diffeology.
-/
