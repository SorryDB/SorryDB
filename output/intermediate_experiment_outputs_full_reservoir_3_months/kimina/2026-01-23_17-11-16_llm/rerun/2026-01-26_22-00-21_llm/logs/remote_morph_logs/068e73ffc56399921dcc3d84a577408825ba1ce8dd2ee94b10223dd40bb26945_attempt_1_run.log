import Mathlib
open Topology Filter Real Complex TopologicalSpace Finset
open scoped BigOperators

variable {G : Type*}

/-!
### Diffeological Groups

A diffeological group is a group `G` equipped with a diffeology such that the group operations (multiplication and inversion) are smooth.
-/

/-- A diffeological group is a group `G` equipped with a diffeology such that the group operations (multiplication and inversion) are smooth. -/
@[to_additive]
structure DiffeologicalGroup (G : Type*) [Group G] [DiffeologicalSpace G] :
    DiffeologicalSpace G × DiffeologicalGroup G :=
  { dsmul := fun x y ↦ x * y, dsmul' := fun x y ↦ x * y, -- these are the same
    dsmul'' := fun x y ↦ x * y, -- these are the same
    dsinv := fun x ↦ x⁻¹ } -- these are the same

variable {G : Type*} [DiffeologicalSpace G] [Group G] [DiffeologicalGroup G]

/-- The map `(x, y) ↦ (x, x * y)` as a diffeomorphism. This is a shear mapping. -/
@[to_additive /-- The map `(x, y) ↦ (x, x + y)` as a homeomorphism. This is a shear mapping. -/]
def DDiffeomorph.shearAddRight : G × G ≃ G × G :=
  { Equiv.shearAddRight with
    dsmul := dsmul,
    dsmul' := dsmul,
    dsinv := dsinv,
    dsmul'' := dsmul,
    dsinv' := dsinv }

/-- The map `(x, y) ↦ (x, x * y)` as a diffeomorphism. This is a shear mapping. -/
@[to_additive /-- The map `(x, y) ↦ (x, x + y)` as a homeomorphism. This is a shear mapping. -/]
def DDiffeomorph.shearMulRight : G × G ≃ G × G :=
  { Equiv.shearMulRight with
    dsmul := dsmul,
    dsmul' := dsmul,
    dsinv := dsinv,
    dsmul'' := dsmul,
    dsinv' := dsinv }

variable {H : Type*} [DiffeologicalSpace H] [Group H] [DiffeologicalGroup H]

@[to_additive]
instance {H : Type*} [DiffeologicalSpace H] [Group H] [DiffeologicalGroup H] :
    DiffeologicalGroup (H × G) :=
  { dsmul := fun p q ↦ p.1 * q.1, dsmul' := fun p q ↦ p.1 * q.1,
    dsinv := fun p ↦ (p.1)⁻¹, dsmul'' := fun p q ↦ p.1 * q.1,
    dsinv' := fun p ↦ (p.1)⁻¹ }

@[to_additive]
instance {H : Type*} [DiffeologicalSpace H] [Group H] [DiffeologicalGroup H] :
    DiffeologicalGroup (H ⨬ G) :=
  { dsmul := fun p q ↦ p.1 * q.1, dsmul' := fun p q ↦ p.1 * q.1,
    dsinv := fun p ↦ (p.1)⁻¹, dsmul'' := fun p q ↦ p.1 * q.1,
    dsinv' := fun p ↦ (p.1)⁻¹ }

variable {ι : Type*} {G : ι → Type*} [∀ i, DiffeologicalSpace (G i)]
    [∀ i, Group (G i)] [∀ i, DiffeologicalGroup (G i)] : DiffeologicalGroup (∀ i, G i) :=
  { dsmul := fun i p q ↦ p i * q i, dsmul' := fun i p q ↦ p i * q i,
    dsinv := fun i p ↦ p i⁻¹, dsmul'' := fun i p q ↦ p i * q i,
    dsinv' := fun i p ↦ p i⁻¹ }

open DiffeologicalGroup

variable {G : Type*} [DiffeologicalSpace G] [Group G] [DiffeologicalGroup G]
  {H : Type*} [DiffeologicalSpace H] [Group H] [DiffeologicalGroup H]

/-!
### Subgroups

A subgroup `S` of a diffeological group `G` is a subset `S ⊆ G` that is itself a diffeological group, with the group operations induced from `G`.
-/

namespace Subgroup

@[to_additive]
instance (S : Subgroup G) : DiffeologicalGroup S :=
  isInduction_subtype_val.diffeologicalGroup S.subtype

end Subgroup

/-!
### Quotient Diffeological Groups

A quotient group `G/N` is formed by taking the set of cosets of a normal subgroup `N` in `G`. The group operations on `G/N` are defined as `(gN)(hN) = (gh)N` and `(gN)⁻¹ = (g⁻¹)N`. A quotient group is a diffeological group if the projection map `G → G/N` is a submersion.
-/

variable {G : Type*} [DiffeologicalSpace G] [Group G] [DiffeologicalGroup G]
  (N : Subgroup G)-- (n : N.Normal)

@[to_additive]
theorem QuotientGroup.isSubduction_coe : IsSubduction ((↑) : G → G ⧸ N) :=
  isSubduction_quotient_mk'

@[to_additive]
instance diffeologicalGroup_quotient [N.Normal] : DiffeologicalGroup (G ⧸ N) where
  dsmul := ((isSubduction_coe N).prod_map (isSubduction_coe N)).comp dsmul
  dsinv := (isSubduction_coe N).comp dsinv

end QuotientDiffeologicalGroup

/-!
### Lattice of Group Diffeologies

We define a type class `GroupDiffeology G` which endows a group `G` with a diffeology such that all group operations are smooth.

Group diffeologies on a fixed group `G` are ordered by inclusion. They form a complete lattice, with `⊥` the discrete diffeology and `⊤` the indiscrete diffeology.

Any function `f : G → H` induces `coinduced f : DiffeologicalSpace G → GroupDiffeology H`.
-/

/-- An additive group diffeology on a group `G` is a diffeology that makes `G` into an
additive diffeological group. -/
structure AddGroupDiffeology (G : Type u) [AddGroup G] : Type u extends DiffeologicalSpace G,
  DiffeologicalAddGroup G

/-- A group diffeology on a group `G` is a diffeology that makes `G` into a
diffeological group. -/
@[to_additive]
structure GroupDiffeology (G : Type u) [Group G] : Type u extends DiffeologicalSpace G,
  DiffeologicalGroup G

namespace GroupDiffeology

variable {G : Type*} [Group G]

/-- A version of the global `dsmooth_mul` suitable for dot notation. -/
@[to_additive /-- A version of the global `dsmooth_add` suitable for dot notation. -/]
theorem dsmul' (d : GroupDiffeology G) :
    haveI := d.toDiffeologicalSpace
    DSmooth fun p : G × G ↦ p.1 * p.2 := by
  letI := d.toDiffeologicalSpace
  haveI := d.toDiffeologicalGroup
  exact dsmul

/-- A version of the global `dsmooth_inv` suitable for dot notation. -/
@[to_additive /-- A version of the global `dsmooth_neg` suitable for dot notation. -/]
theorem dsinv' (d : GroupDiffeology G) :
    haveI := d.toDiffeologicalSpace
    DSmooth (Inv.inv : G → G) := by
  letI := d.toDiffeologicalSpace
  haveI := d.toDiffeologicalGroup
  exact dsinv

@[to_additive]
theorem toDiffeologicalSpace_injective :
    Function.Injective (toDiffeologicalSpace : GroupDiffeology G → DiffeologicalSpace G) :=
  fun f g h ↦ by cases f; cases g; congr

@[to_additive (attr := ext)]
theorem ext' {d₁ d₂ : GroupDiffeology G} (h : d₁.1 = d₂.1) : d₁ = d₂ :=
  toDiffeologicalSpace_injective h

@[to_additive]
instance : PartialOrder (GroupDiffeology G) :=
  PartialOrder.lift toDiffeologicalSpace toDiffeologicalSpace_injective

@[to_additive (attr := simp)]
theorem toDiffeologicalSpace_le {d₁ d₂ : GroupDiffeology G} :
    d₁.1 ≤ d₂.1 ↔ d₁ ≤ d₂ :=
  Iff.rfl

@[to_additive]
instance : Top (GroupDiffeology G) :=
  let _t : DiffeologicalSpace G := ⊤
  ⟨{  dsmul := dsmul_top,
      dsinv := dsinv_top }⟩

@[to_additive (attr := simp)]
theorem toDiffeologicalSpace_top : (⊤ : GroupDiffeology G).toDiffeologicalSpace = ⊤ :=
  rfl

@[to_additive]
instance : Bot (GroupDiffeology G) :=
  let _t : DiffeologicalSpace G := ⊥
  ⟨{  dsmul := by 
      -- Since DiffeologicalSpace G is ⊥, all functions are dcontinuous.
      -- We can use the fact that Dite can handle goals that are true in all branches.
      -- The identity function is dcontinuous, and projections are dcontinuous.
      -- The product of two dcontinuous functions is dcontinuous.
      -- Therefore, the multiplication map is dcontinuous.
      exact dite (fun _ => rfl) (fun _ => rfl) 
    , dsinv := by 
      -- Similar reasoning applies for the inversion map.
      exact dite (fun _ => rfl) (fun _ => rfl)
  }
  ⟩
