    (h' : ∀ i, @DiffeologicalGroup G (D i) _) : @DiffeologicalGroup G (⨅ i, D i) _ := by
  rw [←sInf_range]; exact diffeologicalGroup_sInf (Set.forall_mem_range.mpr h')
