```lean
import Mathlib
open DiffeologicalSpace

variable (G)

/-!
A diffeological group structure on a type `G` consists of a diffeology on `G` such that
the group operations (multiplication and inversion) are smooth.
-/
@[to_additive]
structure DiffeologicalGroup (G : Type*) extends DiffeologicalSpace G, DiffeologicalGroup G where
  dsmooth_mul : DSmoothe fun p : G × G ↦ p.1 * p.2
  dsmooth_inv : DSmoothe fun x : G ↦ x⁻¹

/-!
