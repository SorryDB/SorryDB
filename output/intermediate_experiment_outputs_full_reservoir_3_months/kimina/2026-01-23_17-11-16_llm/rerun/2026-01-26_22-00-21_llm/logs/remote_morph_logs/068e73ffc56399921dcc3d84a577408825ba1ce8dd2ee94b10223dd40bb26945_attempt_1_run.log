@[to_additive]
theorem diffeologicalGroup_sInf {G : Type*} [Group G] {D : Set (DiffeologicalSpace G)}
    (h : ∀ d ∈ D, @DiffeologicalGroup G d _) : @DiffeologicalGroup G (sInf D) _ :=
  letI := sInf D
