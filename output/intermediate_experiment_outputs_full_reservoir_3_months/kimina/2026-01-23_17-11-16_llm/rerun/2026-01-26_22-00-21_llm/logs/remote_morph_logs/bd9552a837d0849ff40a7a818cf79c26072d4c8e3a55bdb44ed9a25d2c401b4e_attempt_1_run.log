/- The determinant map is a continuous group homomorphism. -/
lemma LinearMap.det_isContinuousGroupHom : ContinuousGroupHom (LinearEquivGroup ℚ V) (MultiplicativeTopologicalSpace ℚ) := {
  groupHom := LinearMap.det_isGroupHom
  continuous := sorry
}

/- The determinant map is a continuous non-zero group homomorphism. -/
lemma LinearMap.det_isContinuousNonZeroGroupHom : ContinuousNonZeroGroupHom (LinearEquivGroup ℚ V) (MultiplicativeTopologicalSpace ℚ) := {
  nonZeroGroupHom := {
    groupHom := LinearMap.det_isGroupHom
    nonZero := by
      intro φ
      exact LinearMap.det_ne_zero φ
  }
  continuous := sorry
}

/- The determinant map is a continuous group homomorphism. -/
lemma LinearMap.det_isContinuousGroupHomToUnits : ContinuousGroupHom (LinearEquivGroup ℚ V) (UnitsTopologicalSpace ℚ) := {
  groupHom := LinearMap.det_isGroupHomToUnits
  continuous := sorry
}

/- The determinant map is a continuous non-zero group homomorphism. -/
lemma LinearMap.det_isContinuousNonZeroGroupHomToUnits : ContinuousNonZeroGroupHom (LinearEquivGroup ℚ V) (UnitsTopologicalSpace ℚ) := {
  nonZeroGroupHom := {
    groupHom := LinearMap.det_isGroupHomToUnits
    nonZero := by
      intro φ
      exact LinearMap.det_ne_zero φ
  }
  continuous := sorry
}

/- The determinant of a linear map is the determinant of its matrix representation. -/
lemma LinearMap.det_eq_multiset_prod (φ : LinearMap ℚ V V) : LinearMap.det φ = Multiset.prod (φ.matrix.toList) := by
