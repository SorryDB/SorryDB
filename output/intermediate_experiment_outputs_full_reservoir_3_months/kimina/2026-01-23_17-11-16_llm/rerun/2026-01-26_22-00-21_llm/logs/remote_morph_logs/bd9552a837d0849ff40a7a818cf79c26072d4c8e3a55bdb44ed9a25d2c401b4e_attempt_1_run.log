import Mathlib.Analysis.Measure.Haar

open Real

variable {V} in
variable [Module ℚ V] [FiniteDimensional ℚ V]

/- The determinant of a linear automorphism of a finite-dimensional vector space
over a field is an element of the field. -/
noncomputable def LinearEquiv.det (φ : V ≃ₗ[ℚ] V) : ℚ := (LinearMap.det φ)

/- The determinant of a linear map is a multiplicative function. -/
lemma LinearEquiv.det_mul (φ₁ φ₂ : V ≃ₗ[ℚ] V) : LinearEquiv.det (φ₁ * φ₂) = LinearEquiv.det φ₁ * LinearEquiv.det φ₂ := by
  simp

/- The determinant of the identity map is 1. -/
lemma LinearEquiv.det_id : LinearEquiv.det (V ≃ₗ[ℚ] id) = 1 := by
  simp

/- The determinant of the inverse map is the inverse of the determinant. -/
lemma LinearEquiv.det_inv (φ : V ≃ₗ[ℚ] V) : LinearEquiv.det φ⁻¹ = (LinearEquiv.det φ)⁻¹ := by
  simp

/- The determinant is a group homomorphism from the group of linear
automorphisms to the multiplicative group of the field. -/
lemma LinearEquiv.det_isGroupHom : GroupHom (LinearEquivGroup ℚ V) (MultiplicativeGroup ℚ) := {
  hom := LinearEquiv.det
  left_inv := by
    intro φ
    rw [LinearEquiv.det_inv φ]
    simp
  right_inv := by
    intro φ
    rw [LinearEquiv.det_inv φ]
    simp
  map_mul := by
    intro φ₁ φ₂
    rw [LinearEquiv.det_mul φ₁ φ₂]
    simp
}

/- The determinant is non-zero for any map in the group of linear
automorphisms. -/
lemma LinearEquiv.det_ne_zero (φ : V ≃ₗ[ℚ] V) : LinearEquiv.det φ ≠ 0 := by
  simp [LinearEquiv.det]

/- The determinant is a non-zero group homomorphism. -/
lemma LinearEquiv.det_isNonZeroGroupHom : NonZeroGroupHom (LinearEquivGroup ℚ V) (MultiplicativeGroup ℚ) := {
  groupHom := LinearEquiv.det_isGroupHom
  nonZero := by
    intro φ
    exact LinearEquiv.det_ne_zero φ
}

/- The determinant map is a continuous group homomorphism. -/
lemma LinearEquiv.det_isContinuousGroupHom : ContinuousGroupHom (LinearEquivGroup ℚ V) (MultiplicativeTopologicalSpace ℚ) := {
  groupHom := LinearEquiv.det_isGroupHom
  continuous := sorry
}

/- The determinant map is a continuous non-zero group homomorphism. -/
lemma LinearEquiv.det_isContinuousNonZeroGroupHom : ContinuousNonZeroGroupHom (LinearEquivGroup ℚ V) (MultiplicativeTopologicalSpace ℚ) := {
  nonZeroGroupHom := LinearEquiv.det_isNonZeroGroupHom
  continuous := sorry
