def IsClosed {u v : V} (_ : G.LoopWalk u v) : Prop := u = v

section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (p.supportSet).card ≤ (p.edgeSet).card +1 := by
  induction p using Nat.strongRecOn with
