  main input := main n input
  localLength _ := n
  localLength_eq := by sorry
  output _ i := varFromOffset (fields n) i
  output_eq := by sorry
  subcircuitsConsistent := by sorry
  Assumptions input := sorry
  Spec input output := sorry
  soundness := by sorry
  -- The actual proof construction starts here
  have h1 : (∀ (i : Fin n), IsBool (out[i])) ∧ (∃ (aux : F p), IsBool aux ∧ lin = lout) := by
