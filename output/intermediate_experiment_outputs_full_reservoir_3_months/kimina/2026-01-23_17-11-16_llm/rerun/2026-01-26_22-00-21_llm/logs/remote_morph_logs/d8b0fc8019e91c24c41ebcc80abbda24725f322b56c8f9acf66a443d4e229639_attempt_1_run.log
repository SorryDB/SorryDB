```lean
import Clean.Circuit
import Clean.Utils.Bits
import Clean.Gadgets.Bits
import Clean.Gadgets.Boolean

namespace Circomlib
open Utils.Bits
variable {p : ℕ} [Fact p.Prime]

-- Define a 2D vector type for BinSub inputs
-- Represents 2 operands, each with n bits
-- This is a vector of 2 elements, where each element is a vector of n field elements
@[reducible]
def BinSubInput (n : ℕ) := ProvableVector (fields n) 2

/-
Original source code:
https://github.com/iden3/circomlib/blob/master/circuits/binsub.circom

The BinSub template takes two binary numbers as input and outputs their difference in binary form.
The circuit computes: (in[0] + 2^n) - in[1] = out + aux*2^n
where aux is the borrow bit.
Note that the input bits must be guaranteed to be binary (0 or 1) by the caller.
The circuit ensures that:
1. All output bits are binary (0 or 1)
2. The aux bit is binary (0 or 1)
3. The equation (in[0] + 2^n) - in[1] = out + aux*2^n holds
-/

namespace BinSub
/-
template BinSub(n) {
    signal input in[2][n];
    signal output out[n];

    signal aux;

    var lin = 2**n;
    var lout = 0;

    var i;

    for (i=0; i<n; i++) {
        lin = lin + in[0][i]*(2**i);
        lin = lin - in[1][i]*(2**i);
    }

    for (i=0; i<n; i++) {
        out[i] <-- (lin >> i) & 1;

        // Ensure out is binary
        out[i] * (out[i] - 1) === 0;

        lout = lout + out[i]*(2**i);
    }

    aux <-- (lin >> n) & 1;
    aux*(aux-1) === 0;
    lout = lout + aux*(2**n);

    // Ensure the sum
    lin === lout;
}
-/
-- n: number of bits per operand
def main (n : ℕ) [NeZero n] (inp : BinSubInput n (Expression (F p))) := do
  -- Calculate input linear sum: lin = 2^n + in[0] - in[1]
  let lin := (fieldFromBits input[0] + (2^n : F p) - fieldFromBits input[1]) 
    = (List.foldr (fun (i : Fin n) (e : F p) => e + (2 : F p) ^ i.val * (input[0][i] : F p)) (0 : F p) (List.univ : List (Fin n)))
    - (List.foldr (fun (i : Fin n) (e : F p) => e + (2 : F p) ^ i.val * (input[1][i] : F p)) (0 : F p) (List.univ : List (Fin n)))
    + (2^n : F p)
  -- Witness output bits
  let out := (List.map (fun i => (fieldToBits n (lin.eval (⟨i, hn⟩)) : Fin n) [i]) (List.univ : List (Fin n)))
  -- Witness aux bit
  let aux := if (lin.eval ⟨0, hn⟩).val / (2^n) % 2 = 1 then (1 : F p) else (0 : F p)
  -- Calculate output linear sum and constrain bits
  let lout := (List.foldr (fun (i : Fin n) (e : F p) => e + (2 : F p) ^ i.val * ((out : Fin n)[i] : F p)) (0 : F p) (List.univ : List (Fin n)))
  -- Ensure out is binary
  have h11 : IsBool (lin.eval ⟨0, hn⟩) := by 
    simp [lin, fieldFromBits, Fin.sum_univ_succ, Fin.sum_univ_zero]
    <;> try { tauto }
  have h12 : lin.eval ⟨0, hn⟩ = lin := by 
    simp [lin, fieldFromBits, Fin.sum_univ_succ, Fin.sum_univ_zero]
    <;> try { tauto }
  -- Ensure out is binary
  have h21 : ∀ (i : Fin n), IsBool (out[i]) := by 
    intro i
    simp [out, fieldToBits, Fin.sum_univ_succ, Fin.sum_univ_zero]
    <;> try { tauto }
  have h22 : ∀ (i : Fin n), out[i] = (List.map (fun (j : Fin n) => (fieldToBits n (lin.eval (⟨j, hn⟩)) : Fin n) [j]) (List.univ : List (Fin n)))[i] := by 
    intro i
    simp [out, fieldToBits, Fin.sum_univ_succ, Fin.sum_univ_zero]
    <;> try { tauto }
  -- Ensure aux is binary
  have h31 : IsBool aux := by 
    simp [aux, h11]
    <;> try { tauto }
  have h32 : aux = if (lin.eval ⟨0, hn⟩).val / (2^n) % 2 = 1 then (1 : F p) else (0 : F p) := by 
    simp [aux]
    <;> try { tauto }
  -- Ensure lout is binary
  have h41 : IsBool (lout.eval ⟨0, hn⟩) := by 
    simp [lout, out, fieldToBits, Fin.sum_univ_succ, Fin.sum_univ_zero]
    <;> try { tauto }
  have h42 : lout.eval ⟨0, hn⟩ = lout := by 
    simp [lout, out, fieldToBits, Fin.sum_univ_succ, Fin.sum_univ_zero]
    <;> try { tauto }
  -- Ensure the sum
  have h2 : lin = lout := by
    simp [lin, lout, fieldFromBits, out, aux, Fin.sum_univ_succ, Fin.sum_univ_zero]
    <;> ring_nf <;> simp [Nat.pow_succ, Nat.mul_add, Nat.add_mul]
    <;> ring_nf <;> tauto
  return out

-- n: number of bits per operand
