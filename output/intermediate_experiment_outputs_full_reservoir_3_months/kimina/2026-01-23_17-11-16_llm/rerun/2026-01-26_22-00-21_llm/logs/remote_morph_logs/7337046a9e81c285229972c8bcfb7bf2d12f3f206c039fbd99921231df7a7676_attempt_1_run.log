Let's start by analyzing the structure of the proof.

```tactics
import Mathlib.Algebra.DirectSum.Module
import PersistentDecomp.Mathlib.Order.Disjoint
import PersistentDecomp.Prereqs.Indecomposable
import PersistentDecomp.Prereqs.PersistenceSubmodule

/-!

# Direct sum decompositions for persistence modules

In this file, we define the type of direct sum decompositions of a persistence module `M`.
This has a natural order given by refinements.
-/

open CategoryTheory CategoryTheory.Limits DirectSum
open CompleteLattice hiding sSup_le -- TODO: Fix in mathlib

variable {C : Type} [Category.{0, 0} C] {K : Type} [DivisionRing K] {M : C ⥤ ModuleCat K}

variable (M) in
/-- A direct sum decompositon of `M ` is a set of non-zero submodules
that are linearly independent and whose supremum is the whole of `M`. -/
@[ext]
structure DirectSumDecomposition where
  carrier : Set (PersistenceSubmodule M)
  sSupIndep' : sSupIndep carrier
  sSup_eq_top' : sSup carrier = ⊤
  not_bot_mem' : ⊥ ∉ carrier

namespace DirectSumDecomposition

instance : SetLike (DirectSumDecomposition M) (PersistenceSubmodule M) where
  coe := carrier
  coe_injective' D₁ := by cases D₁; congr!

attribute [-instance] SetLike.instPartialOrder

protected lemma sSupIndep (D : DirectSumDecomposition M) : sSupIndep (SetLike.coe D) :=
  D.sSupIndep'

lemma sSup_eq_top (D : DirectSumDecomposition M) : sSup (SetLike.coe D) = ⊤ := D.sSup_eq_top'
lemma not_bot_mem (D : DirectSumDecomposition M) : ⊥ ∉ D := D.not_bot_mem'

lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := sorry

lemma pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := sorry

open scoped Classical in
lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor <;> sorry
  --rw [← iSup_apply, ← sSup_eq_iSup', I.sSup_eq_top]
  --rfl

variable {M : C ⥤ ModuleCat K} in
/-- Let `D₁, D₂` be direct sum decomposition of `M` we say that `D₁` is a refinement of `D₂` if for
every submodule `N` that appears in `D`, there is a subset `B` of submodules that appear
in `D₁` such that `∑ T ∈ B, T = N`. -/
def IsRefinement (D₁ D₂ : DirectSumDecomposition M) : Prop :=
  ∀ ⦃N⦄, N ∈ D₂ → ∃ B : Set (PersistenceSubmodule M), B ⊆ D₁ ∧ N = sSup B

variable {M : C ⥤ ModuleCat K} in
/-- Suppose `I, J` are direct sum decompositions of `M ` and `J` is a refinement of `I`.
Then for any submodule `N` appearing in `J`, there is a submodule  `A` appearing in `I`
such that `N ≤ A`. -/
lemma RefinementMapSurj' (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : ∀ N : J, ∃ A : I, N.val ≤ A.val := by
  by_contra! h_contra
  rcases h_contra with ⟨N₀, h_not_le⟩
  have h_ge : N₀.val ⊔ sSup I ≤ sSup J := by
    rw [← sSup_pair]
    apply sSup_le_iff.mpr
    intro b h_mem
    rcases h_mem with ⟨h_n⟩
    · exact (le_sSup (h_n ▸ N₀.prop))
    · rename b ∈ {sSup (SetLike.coe I)} => h_i
      have h' : sSup (SetLike.coe I) ≤ sSup J := by
        rw [I.sSup_eq_top, J.sSup_eq_top]
      simp only [Set.mem_singleton_iff] at h_i
      exact (h_i ▸ h')
  let B : Set (PersistenceSubmodule M) := {C | ∃ A : I, C ≤ A.val ∧ C ∈ J}
  have h_sub : B ⊆ J := by
    intro C h_C_mem
    simp [B] at h_C_mem
    exact h_C_mem.right
  have h_aux : sSup B = sSup I := by
    simp_rw [le_antisymm_iff, sSup_le_iff]
    constructor
    · intro b h_mem
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B] at h_mem
      rcases h_mem with ⟨h₁, _⟩
      rcases h₁ with ⟨a, h_a, h_le⟩
      exact (le_sSup_of_le h_a h_le)
    have h_le_subset (A : I) : ∃ C ⊆ B, A ≤ sSup C := by
      choose f hf hf' using h
      refine ⟨f A.prop, ?_, by rw [← (hf' A.prop)]⟩
      intro α h_α
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B]
      refine ⟨⟨A, A.prop, ?_⟩, hf A.prop h_α⟩
      rw [hf' A.prop]
      exact le_sSup h_α
    intro A h_A_mem
    rcases h_le_subset ⟨A, h_A_mem⟩ with ⟨C, h_C⟩
    simp only at h_C
    exact le_trans h_C.right (sSup_le_sSup h_C.left)
  have h_aux' : N₀.val ∉ B := by
    intro h_contra
    simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B] at h_contra
    rcases h_contra with ⟨A, h₁, h₂⟩
    exact (h_not_le (⟨A, h₁⟩) h₂)
  have h_disj : Disjoint N₀.val (sSup B) := by
    exact (sSupIndep.disjoint_sSup J.sSupIndep' N₀.prop h_sub h_aux')
  have h_not_bot : N₀.val ≠ ⊥ := by
    intro h_contra
    exact J.not_bot_mem (h_contra ▸ N₀.prop)
  have h_gt : sSup I < N₀.val ⊔ sSup I := by
    rw [← h_aux]
    -- No clue why I couldn't use this theorem from mathlib directly and had to copy paste it here
    -- instead assuming it has to do with needing to bump
    exact (right_lt_sup_of_left_ne_bot h_disj h_not_bot)
  have contra : (⊤ : PersistenceSubmodule M) < ⊤ := by
    rw [I.sSup_eq_top, J.sSup_eq_top] at *
    apply lt_of_lt_of_le h_gt h_ge
  exact (lt_self_iff_false (⊤ : PersistenceSubmodule M)).mp contra

/-- The refinement relation defines a preorder on direct sum decompositions of `M` via `D₁ ≤ D₂` if
and only if `D₂` is a refinement of `D₁` i.e. this relation is reflexive and transitive. -/
instance : Preorder (DirectSumDecomposition M) where
  le D₁ D₂ := IsRefinement D₂ D₁
  --D₁ ≤ D₂ iff D₂ refines D₁.
  le_refl D := by intro N _; use {N}; aesop
  le_trans I₁ I₂ I₃ h12 h23 := by
    intro N h_mem
    rcases (h12 h_mem) with ⟨C, h_sub, h_eq⟩
    choose f hf hf' using h23
    let A := ⨆ (c : C), (f (h_sub c.prop))
    use A
    constructor
    · apply iSup_le_iff.mpr
      intro c
      exact hf (h_sub c.prop)
    · have h_aux' : sSup A = sSup C := by
        simp_rw [le_antisymm_iff, sSup_le_iff]
        constructor
        · intro a h_a
          have h_aux'' : ∃ (c : C), a ∈ (f (h_sub c.prop)) := by aesop
          rcases h_aux'' with ⟨c_a, h_ca⟩
          have h_le : a ≤ c_a := by
            rw [hf' (N := c_a) (h_sub c_a.2)]
            apply le_sSup h_ca
          apply le_sSup_of_le c_a.prop h_le
        intro c h_mem_c
        let c' : C := ⟨c, h_mem_c⟩
        have h_le_c : c ≤ sSup (f (h_sub c'.prop)) := by rw [← hf' (h_sub c'.prop)]
        apply le_trans h_le_c
        apply sSup_le
        intro a h_mem_a
        have h_a_in_A : a ∈ A := by
          have h_subs : f (h_sub c'.prop) ≤ A := by
            apply le_iSup_of_le c'
            exact le_rfl
          exact h_subs h_mem_a
        exact le_sSup h_a_in_A
      rwa [h_aux']

/-- The refinement relation is antisymmetric. This (combined with the above)
means that it defines a partial order on direct sum decompositions. -/
instance DirectSumDecompLE : PartialOrder (DirectSumDecomposition M) where
  le_antisymm := by
    intro I J h_I_le_J h_J_le_I
    have h_final_left : ∀ N ∈ J, N ∈ I := by
      intro N
      by_contra h_neg
      push_neg at h_neg
      rcases h_neg with ⟨h_N_in_J, h_N_not_in_I⟩
      let N' : J := ⟨N, h_N_in_J⟩
      have h_A : ∃ A : I, N ≤ A.val := by
        exact (RefinementMapSurj' I J h_I_le_J) N'
      rcases h_A with ⟨A, h_N_le_A⟩
      choose f hf hf' using h_J_le_I
      let B := f N'.prop
      have h_B₁ : N = _ := hf' N'.prop
      have h_B₂ := hf N'.prop
      simp only at h_B₁
      have h_mem : A.val ∈ B := by
        by_contra h_A_not_mem
        have h_aux : Disjoint A.val (sSup B) := by
          exact (I.sSupIndep.disjoint_sSup A.prop h_B₂ h_A_not_mem)
        have h_aux' : sSup B ≤ A.val := h_B₁ ▸ h_N_le_A
        have h_last : sSup B = (⊥ : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [← h_B₁] at h_last
        subst h_last
        exact (J.not_bot_mem h_N_in_J)
      have h_A_le_N : A.val ≤ N := by
        rw [h_B₁]
        exact le_sSup h_mem
      have h_A_eq_N : A.val = N := by
        exact (le_antisymm h_A_le_N h_N_le_A)
      have h_contra : N ∈ I := by
        exact h_A_eq_N ▸ A.prop
      aesop
    have h_final_right : ∀ N ∈ I, N ∈ J := by
      sorry
    aesop

section Indecomposable
variable {D : DirectSumDecomposition M}

/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `D` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D` whose underlying set is the
union of all decompositions of the `N`'s appearing in `D`. -/
@[nolint unusedArguments]
def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    sorry
  sSup_eq_top' := by
    sorry
  not_bot_mem' := by simp [Set.mem_iUnion, hB'']

/-- The direct sum decomposition `refinement B hB hB' hB''` is a refinement of `D` -/
lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := sorry

/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `D` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := sorry
```

Now we need to prove `refinement_lt_of_exists_ne_singleton`. Let's think about how to construct the proof.

We need to show that `D < refinement B hB hB' hB''`. This means that `D` is less than or equal to the refinement, and the refinement is strictly greater than `D`.

We already have `D ≤ refinement B hB hB' hB''` from `refinement_le`, so we just need to show `D ≠ refinement B hB hB' hB''` and that `D` is strictly less than the refinement.

To show `D ≠ refinement B hB hB' hB''`, we need to find at least one submodule in `refinement B hB hB' hB''` that is not in `D`.

The hypothesis `H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}` tells us that there exists some submodule `N` in `D` such that the decomposition `B N hN` is not just `{N}`. This means `B N hN` contains at least one other submodule besides `N`.

Let's use this to construct our proof.

```tactics
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
```

We need to show `D < refinement B hB hB' hB''`. This is equivalent to `D ≤ refinement B hB hB' hB'' ∧ D ≠ refinement B hB hB' hB''`.

We'll first show `D ≤ refinement B hB hB' hB''` using `refinement_le`.

```tactics
have h1 : D ≤ refinement B hB hB' hB'' := by
  apply refinement_le B hB hB' hB''
```

Now we need to show `D ≠ refinement B hB hB' hB''`. To do this, we'll show that there's at least one submodule in `refinement B hB hB' hB''` that's not in `D`.

From hypothesis `H`, we have `∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}`. Let's use this to find a submodule `A` in `refinement B hB hB' hB''` such that `A ∉ D`.

```tactics
have h2 : D ≠ refinement B hB hB' hB'' := by
  by_contra h_eq
```

If `D = refinement B hB hB' hB''`, then for all `A`, `A ∈ D ↔ A ∈ refinement B hB hB' hB''`.

Let's use the hypothesis `H` to find a contradiction.

From `H`, there exists `N₀ ∈ D` such that `B N₀ hN₀ ≠ {N₀}`. Let's call this `N₀` and its property `hN₀`.

```tactics
rcases H with ⟨N₀, hN₀, h_ne⟩
```

Now, `N₀ ∈ D`. By `h_eq`, this means `N₀ ∈ refinement B hB hB' hB''`.

The definition of `refinement B hB hB' hB''` is `carrier := ⋃ N, ⋃ hN, B N hN`.

So `N₀ ∈ refinement B hB hB' hB''` means `N₀ = sSup (B N₀ hN₀)` (from `hB`) and `N₀ ∈ D` (which we already know from `hN₀`).

But `h_ne` says `B N₀ hN₀ ≠ {N₀}`. This means `B N₀ hN₀` contains at least one other submodule besides `N₀`.

Let's look at the structure of `refinement B hB hB' hB''`. The `carrier` is `⋃ N, ⋃ hN, B N hN`. So any submodule in `B N hN` for some `N ∈ D` and `hN : N ∈ D` is in the refinement.

Since `N₀ ∈ D`, we can look at `B N₀ hN₀`. The hypothesis `h_ne` tells us that `B N₀ hN₀` is not equal to `{N₀}`. So there exists some `A ∈ B N₀ hN₀` such that `A ≠ N₀`.

Let's find such an `A`.

```tactics
have h3 : N₀ ∈ refinement B hB hB' hB'' := by
  rw [h_eq]
  exact ⟨N₀, hN₀⟩
```

Now, `N₀ ∈ refinement B hB hB' hB''`. By definition of `refinement`, this means `N₀ ∈ D` (which we know) and `N₀ = sSup (B N₀ hN₀)` (which we also know from `hB`).

But we need to find a submodule in the refinement that's not in `D`.

Let's take a submodule `A ∈ B N₀ hN₀` where `A ≠ N₀`.

```tactics
have h4 : ∃ A ∈ refinement B hB hB' hB'', A ∉ D := by
```

To prove this, let's use `h_ne : B N₀ hN₀ ≠ {N₀}`. This means there exists some `A ∈ B N₀ hN₀` such that `A ≠ N₀`.

```tactics
have h5 : B N₀ hN₀ ≠ {N₀} := h_ne
```

From `h5`, we can find an `A` in `B N₀ hN₀` that's not equal to `N₀`.

```tactics
have h6 : ∃ A ∈ B N₀ hN₀, A ≠ N₀ := by
  by_contra h
  push_neg at h
  have h7 : ∀ A ∈ B N₀ hN₀, A = N₀ := by
    intro A hA
    specialize h A hA
    tauto
  have h8 : B N₀ hN₀ = {N₀} := by
    ext A
    simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
    exact h7 A (by tauto)
  contradiction
```

Now we have `A ∈ B N₀ hN₀` such that `A ≠ N₀`. Let's use this to construct our desired submodule.

```tactics
rcases h6 with ⟨A, hA_in_B, hA_ne_N₀⟩
```

Now, `A ∈ B N₀ hN₀`. By definition of `refinement`, `A ∈ refinement B hB hB' hB''` because `N₀ ∈ D` (from `hN₀`).

```tactics
have hA_in_ref : A ∈ refinement B hB hB' hB'' := by
  simp [refinement] at *
  have hA_in_iUnion : A ∈ ⋃ N, ⋃ hN, B N hN := by
    simp [Set.mem_iUnion]
    refine' ⟨N₀, hN₀, A, hA_in_B⟩
  tauto
```

So we have `A ∈ refinement B hB hB' hB''`. Now we need to show `A ∉ D`.

If `A ∈ D`, then `A = sSup (B A (show A ∈ D by assumption))` by `hB`.

But `A ∈ B N₀ hN₀`. If `A ∈ D`, then `A` must be equal to `N₀` by the definition of `B N₀ hN₀` (since `B N₀ hN₀` is a direct sum decomposition of `N₀`).

But we know `A ≠ N₀`, so this would be a contradiction.

Let's complete the proof.

```tactics
have hA_not_in_D : A ∉ D := by
  intro hA_in_D
```

If `A ∈ D`, then `A = sSup (B A (show A ∈ D by assumption))` by `hB`.

```tactics
have hA_eq_sSup := hB A (show A ∈ D by tauto)
```

Also, `A ∈ B N₀ hN₀`. Since `B N₀ hN₀` is a direct sum decomposition (from `hB'`), its submodules are linearly independent.

```tactics
have hA_in_B' : A ∈ B N₀ hN₀ := hA_in_B
```

From `hB'`, `sSupIndep (B N₀ hN₀)`.

```tactics
have hIndep : sSupIndep (B N₀ hN₀) := hB' N₀ hN₀
```

If `A ∈ D`, then `A` must be equal to `N₀` because `A ∈ B N₀ hN₀` and `B N₀ hN₀` is a direct sum decomposition of `N₀`.

```tactics
have hA_eq_N₀ : A = N₀ := by
  have hA_in_sSup : A ∈ sSup (B N₀ hN₀) := by
    simpa using hA_in_B'
```

Since `A ∈ D` and `A ∈ sSup (B N₀ hN₀)`, and `sSup (B N₀ hN₀) = N₀` (from `hB`), we have `A ∈ N₀`. But `A` is a submodule of `N₀`, and since `N₀` is simple (as it's a direct sum decomposition of a single module), `A = N₀`.

Wait, actually, `hB` says `N₀ = sSup (B N₀ hN₀)`. So `A ∈ sSup (B N₀ hN₀)` means `A ≤ N₀`. But `A ∈ D` and `N₀ ∈ D`. How does this give `A = N₀`?

Wait, we need more. Since `A ∈ D` and `A ∈ sSup (B N₀ hN₀)`, and `sSup (B N₀ hN₀) = N₀`, we have `A ∈ N₀`. But `A` is a submodule of `N₀`, and since `N₀` is in the direct sum decomposition `D`, which is a union of simple submodules, `A` must be equal to `N₀`.

Wait, this is getting complicated. Let's think more carefully.

`A ∈ D`. `A ∈ sSup (B N₀ hN₀)`. `sSup (B N₀ hN₀) = N₀`. So `A ∈ N₀`. `A` is a submodule of `N₀`. `N₀ ∈ D`.

If `A ∈ D` and `A ∈ N₀`, then `A ≤ N₀`. But since `N₀ ∈ D` and `D` is a direct sum decomposition, which is a union of simple submodules, the only way `A ≤ N₀` and `A ∈ D` is if `A = N₀`.

Wait, this is not necessarily true. `A` could be a submodule of `N₀`, but not equal to `N₀`. For example, `A = 0` submodule.

But `A ∈ D`. If `A ∈ D` and `A ≤ N₀`, then `A` must be equal to `N₀` only if `A` is maximal in `D`. But this is not necessarily the case.

Wait, we need more. Let's look at the structure of `D`. `D` is a direct sum decomposition, so `sSup D = ⊤` and `D` is linearly independent.

If `A ∈ D` and `A ≤ N₀`, then `A` is in `D` and `A` is a submodule of `N₀`. Since `N₀ ∈ D` and `D` is linearly independent, `A` must be equal to `N₀`.

Wait, let's think. If `A ∈ D` and `A ≤ N₀`, and `N₀ ∈ D`. Since `D` is linearly independent, any submodule in `D` must be simple. So `A` must be equal to `N₀`.

Wait, this is getting too complicated. Let's just use the fact that `A ∈ B N₀ hN₀` and `A ≠ N₀` to derive a contradiction if `A ∈ D`.

If `A ∈ D`, then `A = sSup (B A (show A ∈ D by assumption))` by `hB`. But `A ∈ B N₀ hN₀`. If `A ∈ D`, then `A` must be equal to `N₀` because `A ∈ B N₀ hN₀` and `B N₀ hN₀` is a direct sum decomposition of `N₀`. But `A ≠ N₀`, so this is a contradiction.

Let's complete the proof.

```tactics
have hA_in_sSup : A ∈ sSup (B N₀ hN₀) := by
  simpa using hA_in_B'
```

Since `sSup (B N₀ hN₀) = N₀` (from `hB`), we have `A ∈ N₀`.

```tactics
have hA_in_N₀ : A ∈ N₀ := by
  rw [show sSup (B N₀ hN₀) = N₀ by
    rw [hB N₀ hN₀]
  ] at hA_in_sSup
  exact hA_in_sSup
```

If `A ∈ D` and `A ∈ N₀`, then `A` must be equal to `N₀`. Why? Because `N₀ ∈ D` and `D` is linearly independent. If `A ∈ D` and `A ≤ N₀`, then `A` must be equal to `N₀` because `N₀` is the only submodule in `D` that contains `A`.

Wait, this is getting too involved. Let's just use the fact that `A ≠ N₀` and `A ∈ D` would lead to a contradiction with `hB` and `hB'`.

Let's complete the proof.

```tactics
have hA_eq_N₀ : A = N₀ := by
  have hA_in_sSup : A ∈ sSup (B N₀ hN₀) := by
