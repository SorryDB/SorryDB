  sSupIndep' : sSupIndep carrier
  sSup_eq_top' : sSup carrier = ⊤
  not_bot_mem' : ⊥ ∉ carrier

namespace DirectSumDecomposition

instance : SetLike (DirectSumDecomposition M) (PersistenceSubmodule M) where
  coe := carrier
  coe_injective' D₁ := by cases D₁; congr!

attribute [-instance] SetLike.instPartialOrder

protected lemma sSupIndep (D : DirectSumDecomposition M) : sSupIndep (SetLike.coe D) :=
  D.sSupIndep'

lemma sSup_eq_top (D : DirectSumDecomposition M) : sSup (SetLike.coe D) = ⊤ := D.sSup_eq_top'
lemma not_bot_mem (D : DirectSumDecomposition M) : ⊥ ∉ D := D.not_bot_mem'

lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := sorry

lemma pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := sorry

open scoped Classical in
lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor <;> sorry
  --rw [← iSup_apply, ← sSup_eq_iSup', I.sSup_eq_top]
  --rfl

variable {M : C ⥤ ModuleCat K} in
/-- Let `D₁, D₂` be direct sum decomposition of `M` we say that `D₁` is a refinement of `D₂` if for
every submodule `N` that appears in `D`, there is a subset `B` of submodules that appear
in `D₁` such that `∑ T ∈ B, T = N`. -/
def IsRefinement (D₁ D₂ : DirectSumDecomposition M) : Prop :=
  ∀ ⦃N⦄, N ∈ D₂ → ∃ B : Set (PersistenceSubmodule M), B ⊆ D₁ ∧ N = sSup B

variable {M : C ⥤ ModuleCat K} in
/-- Suppose `I, J` are direct sum decompositions of `M ` and `J` is a refinement of `I`.
Then for any submodule `N` appearing in `J`, there is a submodule  `A` appearing in `I`
such that `N ≤ A`. -/
lemma RefinementMapSurj' (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : ∀ N : J, ∃ A : I, N.val ≤ A.val := by
  by_contra! h_contra
  rcases h_contra with ⟨N₀, h_not_le⟩
  have h_ge : N₀.val ⊔ sSup I ≤ sSup J := by
    rw [← sSup_pair]
    apply sSup_le_iff.mpr
    intro b h_mem
    rcases h_mem with ⟨h_n⟩
    · exact (le_sSup (h_n ▸ N₀.prop))
    · rename b ∈ {sSup (SetLike.coe I)} => h_i
      have h' : sSup (SetLike.coe I) ≤ sSup J := by
        rw [I.sSup_eq_top, J.sSup_eq_top]
      simp only [Set.mem_singleton_iff] at h_i
      exact (h_i ▸ h')
  let B : Set (PersistenceSubmodule M) := {C | ∃ A : I, C ≤ A.val ∧ C ∈ J}
  have h_sub : B ⊆ J := by
    intro C h_C_mem
    simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B] at h_C_mem
    rcases h_C_mem with ⟨h₁, _⟩
    exact h₁.right
  have h_aux : sSup B = sSup I := by
    simp_rw [le_antisymm_iff, sSup_le_iff]
    constructor
    · intro b h_mem
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B] at h_mem
      rcases h_mem with ⟨h₁, _⟩
      rcases h₁ with ⟨a, h_a, h_le⟩
      exact (le_sSup_of_le h_a h_le)
    have h_le_subset (A : I) : ∃ C ⊆ B, A ≤ sSup C := by
      choose f hf hf' using h
      refine ⟨f A.prop, ?_, by rw [← (hf' A.prop)]⟩
      intro α h_α
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B]
      refine ⟨⟨A, A.prop, ?_⟩, hf A.prop h_α⟩
      rw [hf' A.prop]
      exact le_sSup h_α
    intro A h_A_mem
    rcases h_le_subset ⟨A, h_A_mem⟩ with ⟨C, h_C⟩
    simp only at h_C
    exact le_trans h_C.right (sSup_le_sSup h_C.left)
  have h_aux' : N₀.val ∉ B := by
    intro h_contra
    simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, SetLike.coe_mem,
      and_true, B] at h_contra
    rcases h_contra with ⟨A, h₁, h₂⟩
    exact (h_not_le (⟨A, h₁⟩) h₂)
  have h_disj : Disjoint N₀.val (sSup B) := by
    exact (sSupIndep.disjoint_sSup J.sSupIndep' N₀.prop h_sub h_aux')
  have h_not_bot : N₀.val ≠ ⊥ := by
    intro h_contra
    exact J.not_bot_mem (h_contra ▸ N₀.prop)
  have h_gt : sSup I < N₀.val ⊔ sSup I := by
    rw [← h_aux]
    -- No clue why I couldn't use this theorem from mathlib directly and had to copy paste it here
    -- instead assuming it has to do with needing to bump
    exact (right_lt_sup_of_left_ne_bot h_disj h_not_bot)
  have contra : (⊤ : PersistenceSubmodule M) < ⊤ := by
    rw [I.sSup_eq_top, J.sSup_eq_top] at *
    apply lt_of_lt_of_le h_gt h_ge
  exact (lt_self_iff_false (⊤ : PersistenceSubmodule M)).mp contra

/-- The refinement relation defines a preorder on direct sum decompositions of `M` via `D₁ ≤ D₂` if
and only if `D₂` is a refinement of `D₁` i.e. this relation is reflexive and transitive. -/
instance : Preorder (DirectSumDecomposition M) where
  le D₁ D₂ := IsRefinement D₂ D₁
  --D₁ ≤ D₂ iff D₂ refines D₁.
  le_refl D := by intro N _; use {N}; aesop
  le_trans I₁ I₂ I₃ h12 h23 := by
    intro N h_mem
    rcases (h12 h_mem) with ⟨C, h_sub, h_eq⟩
    choose f hf hf' using h23
    let A := ⨆ (c : C), (f (h_sub c.prop))
    use A
    constructor
    · apply iSup_le_iff.mpr
      intro c
      exact hf (h_sub c.prop)
    · have h_aux' : sSup A = sSup C := by
        simp_rw [le_antisymm_iff, sSup_le_iff]
        constructor
        · intro a h_a
          have h_aux'' : ∃ (c : C), a ∈ (f (h_sub c.prop)) := by aesop
          rcases h_aux'' with ⟨c_a, h_ca⟩
          have h_le : a ≤ c_a := by
            rw [hf' (N := c_a) (h_sub c_a.2)]
            apply le_sSup h_ca
          apply le_sSup_of_le c_a.prop h_le
        intro c h_mem_c
        let c' : C := ⟨c, h_mem_c⟩
        have h_le_c : c ≤ sSup (f (h_sub c'.prop)) := by rw [← hf' (h_sub c'.prop)]
        apply le_trans h_le_c
        apply sSup_le
        intro a h_mem_a
        have h_a_in_A : a ∈ A := by
          have h_subs : f (h_sub c'.prop) ≤ A := by
            apply le_iSup_of_le c'
            exact le_rfl
          exact h_subs h_mem_a
        exact le_sSup h_a_in_A
      rwa [h_aux']

/-- The refinement relation is antisymmetric. This (combined with the above)
means that it defines a partial order on direct sum decompositions. -/
instance DirectSumDecompLE : PartialOrder (DirectSumDecomposition M) where
  le_antisymm := by
    intro I J h_I_le_J h_J_le_I
    have h_final_left : ∀ N ∈ J, N ∈ I := by
      intro N
      by_contra h_neg
      push_neg at h_neg
      rcases h_neg with ⟨h_N_in_J, h_N_not_in_I⟩
      let N' : J := ⟨N, h_N_in_J⟩
      have h_A : ∃ A : I, N ≤ A.val := by
        exact (RefinementMapSurj' I J h_I_le_J) N'
      rcases h_A with ⟨A, h_N_le_A⟩
      choose f hf hf' using h_J_le_I
      let B := f N'.prop
      have h_B₁ : N = _ := hf' N'.prop
      have h_B₂ := hf N'.prop
      simp only at h_B₁
      have h_mem : A.val ∈ B := by
        by_contra h_A_not_mem
        have h_aux : Disjoint A.val (sSup B) := by
          exact (I.sSupIndep.disjoint_sSup A.prop h_B₂ h_A_not_mem)
        have h_aux' : sSup B ≤ A.val := h_B₁ ▸ h_N_le_A
        have h_last : sSup B = (⊥ : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [← h_B₁] at h_last
        subst h_last
        exact (J.not_bot_mem h_N_in_J)
      have h_A_le_N : A.val ≤ N := by
        rw [h_B₁]
        exact le_sSup h_mem
      have h_A_eq_N : A.val = N := by
        exact (le_antisymm h_A_le_N h_N_le_A)
      have h_contra : N ∈ I := by
        exact h_A_eq_N ▸ A.prop
      aesop
    have h_final_right : ∀ N ∈ I, N ∈ J := by
      sorry
    aesop

section Indecomposable
variable {D : DirectSumDecomposition M}

/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `D` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D` whose underlying set is the
union of all decompositions of the `N`'s appearing in `D`. -/
@[nolint unusedArguments]
def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    sorry
  sSup_eq_top' := by
    sorry
  not_bot_mem' := by simp [Set.mem_iUnion, hB'']

/-- The direct sum decomposition `refinement B hB hB' hB''` is a refinement of `D` -/
lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := sorry

/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `D` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
```

Now we need to prove that `D < refinement B hB hB' hB''`.

To show this, we need to prove two things:
1. `D ≤ refinement B hB hB' hB''` (which is given by `refinement_le`)
2. `D ≠ refinement B hB hB' hB''` (to show strictness)

For the first part, `refinement_le` states that `D ≤ refinement B hB hB' hB''`. This is given.

For the second part, we need to show that `D ≠ refinement B hB hB' hB''`. This follows from the hypothesis `H : ∃ N, ∃ (hN : N ∈ D), B N hN ≠ {N}`.

Let's complete the proof:

```tactics
rcases H with ⟨N₀, ⟨hN₀, hB₀⟩⟩
```

Now we have a submodule `N₀` in `D` such that `B N₀ hN₀ ≠ {N₀}`.

This means that in the new decomposition `refinement B hB hB' hB''`, the set `B N₀ hN₀` is included. Since `B N₀ hN₀ ≠ {N₀}`, there's at least one element in `B N₀ hN₀` that's different from `N₀`.

This implies that `refinement B hB hB' hB''` contains elements not in `D`. Specifically, elements of `B N₀ hN₀` that are not equal to `N₀`.

To complete the proof, we need to show that `D` is strictly less than `refinement B hB hB' hB''`. This means showing that `D` is not equal to `refinement B hB hB' hB''`.

```tactics
have h1 : D ≤ refinement B hB hB' hB'' := by
  apply refinement_le
```

Now we need to show that `D ≠ refinement B hB hB' hB''` to get strict inequality.

```tactics
have h2 : D ≠ refinement B hB hB' hB'' := by
```

To prove this inequality, we'll show that `D` and `refinement B hB hB' hB''` have different elements.

```tactics
intro h_eq
```

Now assuming `D = refinement B hB hB' hB''`, we'll derive a contradiction.

First, let's look at the `carrier` of `refinement B hB hB' hB''`.

The `carrier` of the new decomposition is `⋃ N, ⋃ hN, B N hN`.

The `carrier` of `D` is `D`.

So for any `A` in `D`, `A` must be in `refinement B hB hB' hB''`.

```tactics
have h3 : (N₀ : Set (PersistenceSubmodule M)) ∈ D := by
  exact hN₀
```

Wait, actually `N₀` is a `PersistenceSubmodule M`. Let's adjust:

Wait, `hN₀ : N₀ ∈ D`. So `N₀` is already in `D`.

Now, let's look at `refinement B hB hB' hB''`.

The `carrier` is `⋃ N, ⋃ hN, B N hN`.

So to show that `N₀` is in the new decomposition:

For `N₀`, we have `hN₀ : N₀ ∈ D`.

In the new decomposition, `N₀` is constructed from `B N₀ hN₀`.

From `hB : ∀ N hN, N = sSup (B N hN)`, applied to `N₀` and `hN₀`, we get `N₀ = sSup (B N₀ hN₀)`.

So `N₀` is the supremum of `B N₀ hN₀`. Since `N₀` is in `D`, and `D`'s supremum is `⊤`, this is consistent.

But we also have `hB₀ : B N₀ hN₀ ≠ {N₀}`.

This means that `B N₀ hN₀` contains at least one element different from `N₀`.

Let's pick one such element `A` in `B N₀ hN₀` where `A ≠ N₀`.

```tactics
have h4 : N₀ ∈ (refinement B hB hB' hB'').carrier := by
  simp [refinement, hN₀]
```

Wait, this is not correct. The `carrier` of `refinement B hB hB' hB''` is `⋃ N, ⋃ hN, B N hN`.

So to show that `N₀` is in the new `carrier`:

We need to show `N₀ ∈ ⋃ N, ⋃ hN, B N hN`.

This is true if `N₀ ∈ B N₀ hN₀` for some `N₀` in `D`.

But `N₀` is in `D`, so we can take `N₀` as the index:

```tactics
have h4 : N₀ ∈ (refinement B hB hB' hB'').carrier := by
  have h5 : N₀ ∈ (refinement B hB hB' hB'').carrier := by
    simp [refinement]
    exact ⟨N₀, hN₀, N₀⟩
  exact h5
```

Now we have `N₀ ∈ D` and `N₀ ∈ refinement B hB hB' hB''`.

But we assumed `D = refinement B hB hB' hB''`.

So this is consistent so far.

Now, let's pick an element from `B N₀ hN₀` that's different from `N₀`.

Since `hB₀ : B N₀ hN₀ ≠ {N₀}`, there exists some `A ∈ B N₀ hN₀` such that `A ≠ N₀`.

Let's get such an element:

```tactics
rcases hB₀ with ⟨A, hA⟩
```

Wait, `hB₀ : B N₀ hN₀ ≠ {N₀}`.

To extract an element from `B N₀ hN₀` that's different from `N₀`:

```tactics
have h5 : ∃ A ∈ B N₀ hN₀, A ≠ N₀ := by
  by_contra h
  push_neg at h
  have h6 : ∀ A ∈ B N₀ hN₀, A = N₀ := by
    intro A hA
    have h7 : A = N₀ := by
      have h8 : A ∈ B N₀ hN₀ := hA
      have h9 : A = N₀ := by
        -- Need to show A = N₀ from the assumption that all elements in B N₀ hN₀ are N₀
        tauto
      exact h9
    exact h7
  have h7 : B N₀ hN₀ = {N₀} := by
    ext A
    simp only [Set.mem_setOf_eq]
    -- Show that A is in B N₀ hN₀ iff A = N₀
    constructor
    · -- If A ∈ B N₀ hN₀, then A = N₀
      intro hA
      exact h6 A hA
    · -- If A = N₀, then A ∈ B N₀ hN₀
      intro hA
      rw [hA]
      -- Need to show N₀ ∈ B N₀ hN₀
      -- This follows from the definition of B and hB
      have h8 : N₀ ∈ B N₀ hN₀ := by
        have h9 : N₀ = sSup (B N₀ hN₀) := by
          apply hB N₀ hN₀
        have h10 : N₀ ∈ B N₀ hN₀ := by
          -- Need to show that N₀ is in B N₀ hN₀
          -- This follows from N₀ = sSup (B N₀ hN₀)
          apply le_antisymm_iff.mpr
          constructor
          · -- N₀ ≤ sSup (B N₀ hN₀)
            apply le_sSup
            intro a ha
            -- Need to show that a ∈ B N₀ hN₀ implies a ≤ N₀
            -- But we know N₀ = sSup (B N₀ hN₀), so this is true
            apply le_sSup
            exact ha
          · -- sSup (B N₀ hN₀) ≤ N₀
            -- This is the reverse of N₀ = sSup (B N₀ hN₀)
            -- This is true by definition
            rw [h9]
            exact le_rfl
        exact h10
      exact h8
  contradiction
```

Now we have an element `A ∈ B N₀ hN₀` such that `A ≠ N₀`.

Now, `A ∈ B N₀ hN₀` means `A ∈ (refinement B hB hB' hB'').carrier`.

So `A ∈ D` by the equality `h_eq`.

But `A ∈ D` implies `A ∈ D`.

But we'll show this leads to a contradiction.

```tactics
rcases h5 with ⟨A, hA_in_B, hA_ne_N₀⟩
```

Now we have `A ∈ B N₀ hN₀` and `A ≠ N₀`.

Since `A ∈ B N₀ hN₀`, `A` is in the `carrier` of `refinement B hB hB' hB''`.

So `A ∈ D` by `h_eq`.

```tactics
have hA_in_D : A ∈ D := by
  have hA_in_new_carrier : A ∈ (refinement B hB hB' hB'').carrier := by
    simp [refinement] at *
    -- Need to show A ∈ ⋃ N, ⋃ hN, B N hN
    -- This is true because A ∈ B N₀ hN₀
    use N₀
    use hN₀
    exact hA_in_B
  rw [show (refinement B hB hB' hB'').carrier = D by
    rw [h_eq]
    all_goals simp
  ] at hA_in_new_carrier
  exact hA_in_new_carrier
```

So now we have `A ∈ D`.

But `A ∈ D` implies `A ≠ ⊥` (from `D.not_bot_mem'`).

Also, `A ∈ D` implies `A` is in `D`.

But we also have `A ∈ B N₀ hN₀`.

From `hB' : ∀ N hN, sSupIndep (B N hN)`, applied to `N₀` and `hN₀`, we get `sSupIndep (B N₀ hN₀)`.

The set `B N₀ hN₀` is linearly independent.

But we have `N₀ = sSup (B N₀ hN₀)` from `hB N₀ hN₀`.

And `A ∈ B N₀ hN₀`.

From `sSupIndep (B N₀ hN₀)`, we have that if `C₁, C₂ ∈ B N₀ hN₀` and `C₁ + C₂ = 0`, then `C₁ = 0` and `C₂ = 0`.

But we have `A ∈ B N₀ hN₀` and `A ≠ N₀`.

But `N₀ = sSup (B N₀ hN₀)`, so `N₀` is the sum of the elements in `B N₀ hN₀`.

But `A ∈ B N₀ hN₀`, so `A ≤ N₀`.

But we also have `A ≠ N₀`.

This doesn't immediately give a contradiction.

Wait, we need more information.

Wait, `A ∈ B N₀ hN₀`.

From `hB' N₀ hN₀ : sSupIndep (B N₀ hN₀)`.

The set `B N₀ hN₀` is linearly independent.

So if `A` and `N₀` were in `B N₀ hN₀`, we could derive something.

Wait, `N₀` is not in `B N₀ hN₀`.

Wait, `hB₀ : B N₀ hN₀ ≠ {N₀}`.

So `N₀` is not in `B N₀ hN₀`.

But `N₀ = sSup (B N₀ hN₀)`.

This is a contradiction.

Wait, `N₀ = sSup (B N₀ hN₀)` means that `N₀` is the sum of the elements in `B N₀ hN₀`.

But if `B N₀ hN₀` is linearly independent (from `hB'`), then `N₀` must be the sum of a subset of `B N₀ hN₀`.

But `N₀` is not in `B N₀ hN₀`.

This is a contradiction.

Let's complete this:

```tactics
have hN₀_in_B : N₀ ∈ sSup (B N₀ hN₀) := by
  have h9 : N₀ = sSup (B N₀ hN₀) := by
    apply hB N₀ hN₀
  rw [h9]
  exact le_rfl
```

Wait, this is not correct. `N₀ ∈ sSup (B N₀ hN₀)` is true by definition, because `N₀ = sSup (B N₀ hN₀)`.

```tactics
have hN₀_in_sSup : N₀ ∈ sSup (B N₀ hN₀) := by
  have h9 : N₀ = sSup (B N₀ hN₀) := by
    apply hB N₀ hN₀
  rw [h9]
  exact le_rfl
```

Now, from `sSupIndep (B N₀ hN₀)`, we have that if a sum of elements from `B N₀ hN₀` is `N₀`, then each element must be `0`.

But `N₀` is in `sSup (B N₀ hN₀)`, which means `N₀` is the sum of some elements from `B N₀ hN₀`.

```tactics
have hN₀_sum : N₀ = ⨆ i ∈ (Finset.range (Finset.card (B N₀ hN₀))), (if i = 0 then (A : K) else (0 : K)) := by
  sorry
```

Wait, this is getting complicated. Let's try a simpler approach.

We have `A ∈ B N₀ hN₀`.

From `hB' N₀ hN₀ : sSupIndep (B N₀ hN₀)`.

From `hB N₀ hN₀ : N₀ = sSup (B N₀ hN₀)`.

So `N₀` is the sum of the elements in `B N₀ hN₀`.

But `A ∈ B N₀ hN₀`.

So `A ≤ N₀`.

But we also have `A ≠ N₀`.

This doesn't give a contradiction yet.

Wait, we need to use the linear independence.

If `B N₀ hN₀` is linearly independent, and `N₀` is the sum of some elements from `B N₀ hN₀`, then `N₀` must be the sum of a subset of `B N₀ hN₀`.

But `N₀` is not in `B N₀ hN₀`.

