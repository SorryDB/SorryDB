        -- Let X = sSup (B N₀ hN₀)
        -- We know X ∈ D
        -- From hB X (show X ∈ D by assumption), we have X = sSup (B X hX)
        -- But we need to show X = sSup (B N₁ hN₁)
        -- This is true if B N₁ hN₁ = {X}
        -- But we don't know that
