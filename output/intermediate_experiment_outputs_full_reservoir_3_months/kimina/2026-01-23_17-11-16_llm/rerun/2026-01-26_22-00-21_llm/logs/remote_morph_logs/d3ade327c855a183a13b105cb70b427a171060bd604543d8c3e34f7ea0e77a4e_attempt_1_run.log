import Mathlib

/-- A factorization of a natural number $n$ is a map from prime numbers to natural numbers
  such that the product of $p^{f_p}$ over all primes $p$ is $n$. -/
structure Factorization (n : ℕ) : Type u_1 := { a : Multiset ℕ := ∅
  ha : ∀ m ∈ a, m > 0
  hpos : ∀ m ∈ a, m ≠ 1
  score L : ℕ := ∑ p ∈ (n + 1).primesBelow, a.map (fun m ↦ m.factorization p).sum * L
  total_imbalance : ℤ := ∑ p ∈ (n + 1).primesBelow, (a.map (fun m ↦ m.factorization p)).sum * (p.factorization n) }

