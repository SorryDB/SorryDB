  exact ⟨f', hf'_bal, by rw [waste_eq f' hf'_bal]; linarith [score_eq hf'_bal L]⟩

-- Define the theorem statement with the initial factorization and score bound
theorem Params.initial.score (ε : ℝ) (hε : ε > 0) :
