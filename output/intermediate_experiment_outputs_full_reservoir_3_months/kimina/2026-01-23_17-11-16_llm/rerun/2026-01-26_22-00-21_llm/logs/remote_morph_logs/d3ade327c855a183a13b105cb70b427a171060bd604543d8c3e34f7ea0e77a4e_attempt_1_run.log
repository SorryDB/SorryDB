import Mathlib

open Nat

/-- The waste of a factorization $f$ is the difference between its score and the logarithm of its cardinality times the logarithm of $n$. -/
def Factorization.waste (f : Factorization n) : ℤ := f.score L - ((f.a.card : ℝ) * (Real.log n)).floor

/-- The score of a factorization $f$ with total imbalance 0 is the logarithm of its cardinality times the logarithm of $n$. -/
lemma score_eq (f : Factorization n) (hf : f.total_imbalance = 0) (L : ℕ) :
    f.score L = (f.a.card : ℝ) * (Real.log n) := by
  rw [score_def]
  simp [hf, sum_zero, mul_zero]

/-- The waste of a factorization $f$ is nonpositive. -/
lemma balance_le_zero (f : Factorization n) : f.waste ≤ 0 := by
  have h1 : f.waste = f.score L - ((f.a.card : ℝ) * (Real.log n)).floor := rfl
  have h2 : (f.a.card : ℝ) * (Real.log n) ≤ (n.factorial).log + f.score L := by
    have h3 := card_le_factorial_of_factorization f
    have h4 : (f.a.card : ℝ) * (Real.log n) ≤ (n.factorial).log + f.score L := by
      have h5 : (f.a.card : ℝ) * (Real.log n) ≤ (n.factorial).log := by
        have h6 : (n.factorial).log = ∑ k ∈ Finset.Ico 1 (Nat.log n + 1), (n / k) := by
          rw [Nat.log_factorial]
        have h7 : (f.a.card : ℝ) * (Real.log n) ≤ (n.factorial).log := by
          have h8 : (f.a.card : ℝ) * (Real.log n) ≤ ∑ k ∈ Finset.Ico 1 (Nat.log n + 1), (n / k) := by
            apply sum_le_sum
            intro k hk
            have h9 : k ≤ n := by
              have h10 : k ≤ Nat.log n + 1 := by
                simp at hk ⊢; tauto
              have h11 : k ≤ n := by
                have h12 : Nat.log n + 1 ≤ n := Nat.log_add_one_le_self (by linarith)
                linarith
              linarith
            have h10 : (f.a.card : ℝ) ≤ (n / k : ℝ) := by
              have h11 : k ≤ n := by linarith
              have h12 : k ≤ f.card := by
                have h13 : f.card = (f.a.card : ℕ) := by simp
                have h14 : (f.a.card : ℝ) = (f.card : ℝ) := by simp [h13]
                have h15 : (f.card : ℝ) ≤ (n / k : ℝ) := by
                  have h16 : f.card ≤ n / k := by
                    have h17 : f.card ≤ n / k := by
                      have h18 : k ∣ f.card := by
                        apply Nat.dvd_factorization_of_dvd k f
                        exact Nat.dvd_refl k
                      exact Nat.le_of_dvd (by linarith) h18
                    linarith
                  exact_mod_cast h16
                linarith
              linarith
            simp at h10 ⊢
            nlinarith
          linarith
        linarith
      linarith
    linarith
  have h3 : ((f.a.card : ℝ) * (Real.log n)).floor ≤ (f.score L : ℤ) := by
    have h4 : (f.a.card : ℝ) * (Real.log n) ≤ (f.score L : ℝ) := by linarith
    have h5 : ((f.a.card : ℝ) * (Real.log n)).floor ≤ (f.score L : ℤ) := by
      exact_mod_cast (Int.floor_le h4)
    linarith
  linarith [h1, h3]

/-- One can bring any factorization into balance without increasing the score. -/
theorem Factorization.lowest_score {n : ℕ} (f : Factorization n) (L : ℕ) :
    ∃ f' : Factorization n, f'.total_imbalance = 0 ∧ f'.score L ≤ f.score L := by
  induction h : f.total_imbalance using Nat.strong_induction_on generalizing f with
  | _ k ih =>
    obtain rfl | hk := k.eq_zero_or_pos
    · exact ⟨f, h, le_refl _⟩
    · have step : ∀ g : Factorization n, g.total_imbalance < k →
          ∃ f' : Factorization n, f'.total_imbalance = 0 ∧ f'.score L ≤ g.score L := fun g hg =>
        ih g.total_imbalance (h ▸ hg) g rfl
      by_cases h1 : ∃ p ∈ (n + 1).primesBelow, f.balance p > 0
      · obtain ⟨f₁, hlt, hle⟩ := lower_score_1 f L h1
        obtain ⟨f', hbal, hle'⟩ := step f₁ (h ▸ hlt)
        exact ⟨f', hbal, hle'.trans hle⟩
      · by_cases h2 : ∃ p ∈ (n + 1).primesBelow, p > L ∧ f.balance p < 0
        · obtain ⟨f₁, hlt, hle⟩ := lower_score_2 f L h2
          obtain ⟨f', hbal, hle'⟩ := step f₁ (h ▸ hlt)
          exact ⟨f', hbal, hle'.trans hle⟩
        · have h3 : ∃ p ∈ (n + 1).primesBelow, p ≤ L ∧ f.balance p < 0 := by
            simp only [not_exists, not_and, not_lt] at h1 h2; by_contra hc; push_neg at hc
            exact hk.ne' <| h ▸ sum_eq_zero fun p hp ↦ by
              have := h1 p hp; have := if hpL : p ≤ L then hc p hp hpL
                else h2 p hp (lt_of_not_ge hpL); omega
          obtain ⟨f₁, hlt, hle⟩ := lower_score_3 f L h3
          obtain ⟨f', hbal, hle'⟩ := step f₁ (h ▸ hlt)
          exact ⟨f', hbal, hle'.trans hle⟩

/-- Starting from any factorization $f$, one can find a factorization $f'$ in balance whose
cardinality is at most $\log n!$ plus the score of $f$, divided by $\log n$. -/
theorem Factorization.card_bound {n : ℕ} (f : Factorization n) (L : ℕ) : ∃ f' :
    Factorization n, f'.total_imbalance = 0 ∧ (f'.a.card : ℝ) * (Real.log n)
      ≤ Real.log n.factorial + (f.score L) := by
  obtain ⟨f', hf'_bal, hf'_score⟩ := lowest_score f L
  exact ⟨f', hf'_bal, by
    have hw_eq : (f'.a.card : ℝ) * (Real.log n) - (Real.log n.factorial + f'.score L) = f'.waste := by
      rw [waste_eq f' hf'_bal]
    have hw_le : f'.waste ≤ 0 := by
      have h1 := balance_le_zero f'
      simp [hw_eq] at *
      linarith
    linarith [hw_eq, hw_le, hf'_score]
  ⟩

@[blueprint
  "params-set"
  (statement := /-- Now let $M,L$ be additional parameters with $n > L^2$. -/)]
structure Params where
  n : ℕ
  M : ℕ
  L : ℕ
  hL_pos : L > 0
  hL : n > L * L

@[blueprint
  "initial-factorization-def"
  (statement := /-- We perform an initial factorization by taking the natural numbers between
  $n-n/M$ and $n$ repeated $M$ times, deleting those elements that are not $n/L$-smooth. -/)]
def Params.initial (P : Params) : Factorization P.n := {
  a := (replicate P.M (.Ico (P.n - P.n/P.M) P.n)).join.filter
    (fun m ↦ m ∈ (P.n/P.L).smoothNumbers)
  ha := fun m hm ↦ by
    simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
    obtain ⟨⟨_, ⟨_, rfl⟩, hs⟩, _⟩ := hm
    rw [Multiset.mem_Ico, tsub_le_iff_right] at hs
    grind
  hpos := fun m hm ↦ by
    simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
    obtain ⟨_, hsmooth⟩ := hm
    exact pos_of_ne_zero (mem_smoothNumbers.mp hsmooth).1
}

@[blueprint
  "initial-factorization-card"
  (statement := /-- The number of elements in this initial factorization is at most $n$. -/)]
theorem Params.initial.card (P : Params) : P.initial.a.card ≤ P.n := by
  calc Multiset.card (filter (fun m ↦ m ∈ (P.n / P.L).smoothNumbers)
      (replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)).join)
    _ ≤ Multiset.card (replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)).join :=
        card_le_card (filter_le _ _)
