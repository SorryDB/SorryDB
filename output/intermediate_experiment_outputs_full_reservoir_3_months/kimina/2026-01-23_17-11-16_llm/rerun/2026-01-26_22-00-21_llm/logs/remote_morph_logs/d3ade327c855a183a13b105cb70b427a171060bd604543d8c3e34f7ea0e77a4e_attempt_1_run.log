/-- A factorization of a natural number $n$ is a map from primes $p$ to natural numbers $k$
  such that $\prod p^k = n$. -/
structure Factorization (n : ℕ) where
  a : Multiset ℕ
  ha : ∀ m ∈ a, m.factorization n = 0
  hpos : ∀ m ∈ a, 0 < m
  total_imbalance : ℕ
  score : ℕ → ℕ

/-- Define the set of primes $p$ such that $p$ divides $m$. -/
def divisors (m : ℕ) := {p : ℕ | p.Prime ∧ p ∣ m}

/-- Define the set of primes $p$ such that $p$ divides $m$ and $p \le L$. -/
def primesBelow (m : ℕ) (L : ℕ) := {p : ℕ | p.Prime ∧ p ∣ m ∧ p ≤ L}

/-- Define the set of primes $p$ such that $p$ divides $m$ and $p > L$. -/
def primesAbove (m : ℕ) (L : ℕ) := {p : ℕ | p.Prime ∧ p ∣ m ∧ p > L}

/-- Define the set of primes $p$ such that $p$ is $m$-smooth, meaning $p$ divides $m!$. -/
def smoothNumbers (m : ℕ) := {p : ℕ | p.Prime ∧ p ∣ m.factorial}

/-- Define the set of primes $p$ such that $p$ is $m$-smooth and $p \le L$. -/
def smoothPrimesBelow (m : ℕ) (L : ℕ) := {p : ℕ | p.Prime ∧ p ∣ m.factorial ∧ p ≤ L}

/-- Define the set of primes $p$ such that $p$ is $m$-smooth and $p > L$. -/
def smoothPrimesAbove (m : ℕ) (L : ℕ) := {p : ℕ | p.Prime ∧ p ∣ m.factorial ∧ p > L}

/-- The balance of an element `m` in the factorization `f` for a prime `p` is
  `f.factorization m - f.factorization m`. -/
def balance (f : Factorization ℕ) {m : ℕ} {p : ℕ} (hm : m ∈ f.a) (hp : p ∈ f.primesBelow m) : f.balance p = 0 := sorry

/-- The total balance of an element `m` in the factorization `f` is
  the sum of the balances for all primes `p` below `m` in `f`. -/
