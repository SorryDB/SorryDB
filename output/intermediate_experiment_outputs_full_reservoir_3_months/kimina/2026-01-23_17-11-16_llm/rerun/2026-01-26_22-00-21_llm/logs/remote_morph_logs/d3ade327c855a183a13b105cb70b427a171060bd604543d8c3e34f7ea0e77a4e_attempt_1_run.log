/-- A factorization `f` is in balance if its total imbalance is zero. -/
def balanced (f : Factorization ℕ) : f.balanced := sorry

/-- The cardinality of a factorization `f` is the number of elements in the multiset `f.a`. -/
def card (f : Factorization ℕ) : f.card := sorry

/-- The waste of a factorization `f` at level `L` is the sum of the cardinalities of the
  sets of primes `p > L` that divide each element `m` in `f.a`. -/
def waste (f : Factorization ℕ) (L : ℕ) : f.waste L := sorry

/-- Define the initial factorization based on parameters `P`. -/
def initial (P : Params) : Factorization P.n := {
  a := (replicate P.M (.Ico (P.n - P.n/P.M) P.n)).join.filter
    (fun m ↦ m ∈ (P.n/P.L).smoothNumbers)
  ha := fun m hm ↦ by
