  (T_meas : вҲҖ {f : Оұ вҶ’ рқ•Ӯ}, (MemLorentz f p 1 Ој) вҶ’ AEStronglyMeasurable (T f) ОҪ)
  (T_subadd : вҲҖ (f g : Оұ вҶ’ рқ•Ӯ) (x : Оұ'), (MemLorentz f p 1 Ој) вҶ’ (MemLorentz g p 1 Ој) вҶ’
    вҖ–T (f + g) xвҖ–вӮ‘ вүӨ вҖ–T f x + T g xвҖ–вӮ‘)
  (T_submul : вҲҖ (a : рқ•Ӯ) (f : Оұ вҶ’ рқ•Ӯ) (x : Оұ'), вҖ–T (a вҖў f) xвҖ–вӮ‘ вүӨ вҖ–aвҖ–вӮ‘ вҖў вҖ–T f xвҖ–вӮ‘)
  (weakly_cont_T : вҲҖ {f : Оұ вҶ’ рқ•Ӯ} {fs : в„• вҶ’ Оұ вҶ’ рқ•Ӯ}
                     (f_locInt : LocallyIntegrable f Ој)
                     (hF_meas : вҲҖ (n : в„•), AEStronglyMeasurable (fs n) Ој)
                     (h_norm_monotone : вҲҖ (a : Оұ), Monotone (fun n вҶҰ вҖ–fs n aвҖ–))
                     (h_lim : вҲҖ (a : Оұ), Filter.Tendsto (fun (n : в„•) => fs n a) Filter.atTop (nhds (f a)))
                     (G : Set Оұ'),
    eLpNorm (T f) 1 (ОҪ.restrict G) вүӨ Filter.limsup (fun n вҶҰ eLpNorm (T (fs n)) 1 (ОҪ.restrict G)) Filter.atTop)
    :
    HasLorentzType T p 1 p' Ој ОҪ (4 * c / p) := by
```

Now we need to prove `HasLorentzType T p 1 p' Ој ОҪ (4 * c / p)`. The definition of `HasLorentzType` is:
`вҲҖ (f : Оұ вҶ’ рқ•Ӯ), (hf : MemLorentz f p 1 Ој) вҶ’ eLpNorm (T f) 1 (ОҪ.restrict G) вүӨ (4 * c / p) * eLorentzNorm f p 1 Ој * (ОҪ G) ^ p'вҒ»В№.toReal`

```tactics
  intro f hf
```

Now we have `f : Оұ вҶ’ рқ•Ӯ` and `hf : @MeasureTheory.MemLorentz Оұ рқ•Ӯ m0 SeminormedAddGroup.toContinuousENorm.toENorm PseudoMetricSpace.toUniformSpace.toTopologicalSpace f p 1 Ој < вҠӨ`.
We need to show: `eLpNorm (T f) 1 (ОҪ.restrict G) вүӨ (4 * c / p) * eLorentzNorm f p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal`.

The strategy is to decompose `f` into its real and imaginary parts, `gвӮҒ` and `gвӮӮ`, and then use the properties of `T`.
Let `gвӮҒ = fun x вҶҰ Real.toNNReal (RCLike.re (f x))` and `gвӮӮ = fun x вҶҰ Real.toNNReal (RCLike.im (f x))`.
Then `f = (1 : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮҒ) + (RCLike.I : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮӮ)`.

```tactics
  have hf' : @MeasureTheory.MemLorentz Оұ рқ•Ӯ m0 SeminormedAddGroup.toContinuousENorm.toENorm PseudoMetricSpace.toUniformSpace.toTopologicalSpace f p 1 Ој < вҠӨ := hf
```

Now we define `gвӮҒ` and `gвӮӮ`.

```tactics
  have h1 : eLpNorm (T f) 1 (ОҪ.restrict G) вүӨ (4 * c / p) * eLorentzNorm f p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
```

We need to express `f` in terms of `gвӮҒ` and `gвӮӮ`.

```tactics
    have hf1 : @MeasureTheory.MemLorentz Оұ рқ•Ӯ m0 SeminormedAddGroup.toContinuousENorm.toENorm PseudoMetricSpace.toUniformSpace.toTopologicalSpace f p 1 Ој < вҠӨ := hf
```

Now we define `gвӮҒ` and `gвӮӮ`.

```tactics
    have h1 : @MeasureTheory.MemLorentz Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace (fun x вҶҰ Real.toNNReal (RCLike.re (f x))) p 1 Ој < вҠӨ := by
      apply @MeasureTheory.MemLorentz.of_nonneg hf
      intro x
      simp
    have h2 : @MeasureTheory.MemLorentz Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace (fun x вҶҰ Real.toNNReal (RCLike.im (f x))) p 1 Ој < вҠӨ := by
      apply @MeasureTheory.MemLorentz.of_nonneg hf
      intro x
      simp
```

Now we establish the decomposition of `f`.

```tactics
    have hf_decomp : f = (1 : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ (fun x вҶҰ Real.toNNReal (RCLike.re (f x)))) + (RCLike.I : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ (fun x вҶҰ Real.toNNReal (RCLike.im (f x)))) := by
      funext x
      simp [algebraMap, RCLike.ext_iff]
      <;> ring_nf <;> simp [Real.toNNReal]
      <;> ring
```

Now we define `T'` and its properties.

```tactics
    set T' := T вҲҳ (fun f вҶҰ (@RCLike.ofReal рқ•Ӯ _) вҲҳ NNReal.toReal вҲҳ f)
```

Now we prove that `T'` satisfies the conditions for `HasLorentzType`.

```tactics
    have hT' : @MeasureTheory.HasRestrictedWeakType Оұ m0 Оұ' Оө' m instвңқВІ instвңқВ№.toENorm NNReal instZeroNNReal instOneNNReal T' p p' Ој ОҪ вҶ‘c := by
      simpa using hT
```

Now we prove that `T'` is weakly continuous.

```tactics
    have weaklyCont_T' : @MeasureTheory.WeaklyContinuous Оұ NNReal Оө' m0 Оұ' m NNReal.instTopologicalSpace instENormedSpaceNNReal.toENorm T' p Ој ОҪ := by
      simpa using weakly_cont_T
```

Now we prove the subadditivity and submultiplicativity properties for `T'`.

```tactics
    have T'_subadd : вҲҖ (f g : Оұ вҶ’ NNReal)
        (a : @MeasureTheory.MemLorentz Оұ NNReal m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace f p 1 Ој)
        (a : @MeasureTheory.MemLorentz Оұ NNReal m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace g p 1 Ој),
        eLpNorm (T' (f + g)) 1 (ОҪ.restrict G) вүӨ eLpNorm (T' f) 1 (ОҪ.restrict G) + eLpNorm (T' g) 1 (ОҪ.restrict G) := by
      intro f g hf hg
      unfold T'
      simp only [Function.comp_apply]
      have hf' : @MeasureTheory.MemLorentz Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace f p 1 Ој < вҠӨ := hf
      have hg' : @MeasureTheory.MemLorentz Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace g p 1 Ој < вҠӨ := hg
      apply le_trans _ (eLpNorm_add_le _ _ le_rfl)
      В· apply eLpNorm_mono_enorm
        intro x
        simp only [Pi.add_apply]
        apply le_of_eq_of_le _ (T_subadd _ _ _ hf' hg')
        congr with x
        simp
      В· apply AEStronglyMeasurable.restrict
        apply T_meas hf'
      В· apply AEStronglyMeasurable.restrict
        apply T_meas hg'
```

Now we prove the submultiplicativity property for `T'`.

```tactics
    have T'_submul : вҲҖ (f : Оұ вҶ’ NNReal) (a : NNReal), eLpNorm (T' (a вҖў f)) 1 (ОҪ.restrict G)
        вүӨ eLpNorm (a вҖў T' f) 1 (ОҪ.restrict G) := by
      intro f a
      apply eLpNorm_mono_enorm
      intro x
      unfold T'
      simp only [Function.comp_apply, Pi.smul_apply, norm_smul_eq_smul]
      have : a вҖў вҖ–T (RCLike.ofReal вҲҳ NNReal.toReal вҲҳ f) xвҖ–вӮ‘
          = вҖ–aвҖ–вӮ‘ вҖў вҖ–T (RCLike.ofReal вҲҳ NNReal.toReal вҲҳ f) xвҖ–вӮ‘ := by
        simp [norm_smul_eq_smul]
      rw [this]
      convert T_submul (NNReal.toReal a) _ x
      В· ext x
        simp
      congr
      simp
```

Now we prove the main inequality using the helper lemma.

```tactics
    have helper : вҲҖ {f : Оұ вҶ’ NNReal},
        Measurable f вҶ’
          вҲҖ
            (hf' :
              @MeasureTheory.MemLorentz Оұ NNReal m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace f p 1 Ој),
            eLpNorm (T' f) 1 (ОҪ.restrict G) вүӨ
              вҶ‘c / p * @MeasureTheory.eLorentzNorm Оұ NNReal m0 instENormedSpaceNNReal.toENorm f p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
      intro f hf hf'
      apply HasRestrictedWeakType.hasLorentzType_helper c_pos hT' hpp' weaklyCont_T' measurable_G G_finite
        T'_subadd T'_submul hf hf'
```

Now we apply the helper lemma to `gвӮҒ` and `gвӮӮ`.

```tactics
    have h11 : eLpNorm (T' (fun x вҶҰ Real.toNNReal (RCLike.re (f x)))) 1 (ОҪ.restrict G) вүӨ вҶ‘c / p * @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.re (f x))) p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
      apply helper
      В· -- Show that gвӮҒ is measurable
        apply measurable_coe_nnreal_real
        apply SimpleFunc.measurable
      В· -- Show that gвӮҒ is memLorentz
        exact h1
    have h12 : eLpNorm (T' (fun x вҶҰ Real.toNNReal (RCLike.im (f x)))) 1 (ОҪ.restrict G) вүӨ вҶ‘c / p * @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.im (f x))) p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
      apply helper
      В· -- Show that gвӮӮ is measurable
        apply measurable_coe_nnreal_real
        apply SimpleFunc.measurable
      В· -- Show that gвӮӮ is memLorentz
        exact h2
```

Now we combine the results using the decomposition of `f`.

```tactics
    calc _
      _ = eLpNorm (T (1 вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ (fun x вҶҰ Real.toNNReal (RCLike.re (f x)))) + RCLike.I вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ (fun x вҶҰ Real.toNNReal (RCLike.im (f x))))) ) 1 (ОҪ.restrict G) := by
        rw [hf_decomp]
        all_goals simp
      _ вүӨ eLpNorm (T' (fun x вҶҰ Real.toNNReal (RCLike.re (f x)))) 1 (ОҪ.restrict G) + eLpNorm (T' (fun x вҶҰ Real.toNNReal (RCLike.im (f x)))) 1 (ОҪ.restrict G) := by
        have : T' (fun x вҶҰ Real.toNNReal (RCLike.re (f x))) = T (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ (fun x вҶҰ Real.toNNReal (RCLike.re (f x)))) := by simp [T']
        have : T' (fun x вҶҰ Real.toNNReal (RCLike.im (f x))) = T (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ (fun x вҶҰ Real.toNNReal (RCLike.im (f x)))) := by simp [T']
        rw [this, this]
        apply eLpNorm_add_le
        В· -- Show that T (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮҒ) is AESTronglyMeasurable
          apply T_meas
          exact h1
        В· -- Show that T (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮӮ) is AESTronglyMeasurable
          apply T_meas
          exact h2
      _ = eLpNorm (T' (fun x вҶҰ Real.toNNReal (RCLike.re (f x)))) 1 (ОҪ.restrict G) + eLpNorm (T' (fun x вҶҰ Real.toNNReal (RCLike.im (f x)))) 1 (ОҪ.restrict G) := by
        simp
      _ вүӨ вҶ‘c / p * @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.re (f x))) p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal + вҶ‘c / p * @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.im (f x))) p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
        linarith [h11, h12]
      _ = вҶ‘c / p * (@MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.re (f x))) p 1 Ој + @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.im (f x))) p 1 Ој) * ОҪ G ^ p'вҒ»В№.toReal := by
        ring
      _ = вҶ‘c / p * (@MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.re (f x))) p 1 Ој + @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.im (f x))) p 1 Ој) * ОҪ G ^ p'вҒ»В№.toReal := by
        rfl
```

Now we simplify the expression using the property `eLorentzNorm_add`.

```tactics
    rw [show @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.re (f x))) p 1 Ој + @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm (fun x вҶҰ Real.toNNReal (RCLike.im (f x))) p 1 Ој = @MeasureTheory.eLorentzNorm Оұ (в„қвүҘ0) m0 instENormedSpaceNNReal.toENorm f p 1 Ој by
      simp [eLorentzNorm_add]
    ]
    all_goals norm_num
```

This completes the proof of `h1`.

```tactics
  exact h1
```

This completes the proof of the main theorem.
