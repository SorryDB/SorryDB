      funext x
      simp only [one_smul, Pi.add_apply, Function.comp_apply, algebraMap]
      simp [RCLike.ext_iff, gвӮҒ, gвӮӮ]
      <;> ring_nf <;> simp [Real.coe_toNNReal]
      <;> ring_nf <;> simp [Real.coe_toNNReal]
