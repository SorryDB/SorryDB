import Mathlib

open MeasureTheory

/-!
Lorentz space norms
-/
noncomputable def eLorentzNorm (f : Оұ вҶ’ рқ•Ӯ) (p : в„қвүҘ0вҲһ) (r : в„қвүҘ0вҲһ) (Ој : Measure Оұ) :=
  вҲ« x in Оұ, (вҖ–f xвҖ– ^ r.toReal) ^ (1 / r.toReal) dОј x

/-!
Lorentz space
-/
noncomputable def LorentzSpace (p : в„қвүҘ0вҲһ) (r : в„қвүҘ0вҲһ) (Ој : Measure Оұ) :=
  {f : Оұ вҶ’ рқ•Ӯ | вҖ–fвҖ–_p r Ој < вҲһ}

/-!
Lorentz space norm
-/
