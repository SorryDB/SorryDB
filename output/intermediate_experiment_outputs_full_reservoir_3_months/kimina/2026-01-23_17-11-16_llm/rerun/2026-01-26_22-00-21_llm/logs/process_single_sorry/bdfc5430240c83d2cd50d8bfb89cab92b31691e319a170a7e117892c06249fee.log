    tree := chainTree V
    payoff A := PO (⋂ n, A.1 n)
variable {V}
variable {W : Set (Set X)} (hWV : W ⊆ V) (hW : ∀ A ∈ V, ∃ B ∈ W, B ⊆ A)
lemma extend_mem_iff (x : List W) : x.map (Set.inclusion hWV) ∈ chainTree V ↔ x ∈ chainTree W := by
    simp [chainTree, List.isChain_map]
