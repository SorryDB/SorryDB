      "rfl",
      "try { \n    apply Prod.ext\n    all_goals try { \n      aesop? (add safe Aesop.BuiltinRules.ext) (config := {warnOnNonterminal := false})\n    }\n    all_goals try { tauto }\n  }\n  all_goals try { \n    simp_all [MyProd.ext_iff]\n  }\n  all_goals try { tauto }\n  all_goals try { \n    aesop? (add safe Aesop.BuiltinRules.ext) (config := {warnOnNonterminal := false})\n  }\n  all_goals try { tauto }",
