import Mathlib

variable [ArchReq]

noncomputable abbrev Address : Type 0 := ℕ

noncomputable abbrev Value : Type 0 := ℕ

noncomputable abbrev RequestId : Type 0 := ℕ

noncomputable abbrev ThreadId : Type 0 := ℕ

