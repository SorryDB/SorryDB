      "\n  -- The integral of Φ₆ r over Ici 1 is finite\n  have h1 : HasFiniteIntegral (Φ₆ r) (volume.restrict (Ici 1)) := by\n    have h2 : IntervalIntegrableOn (fun x => Φ₆ r x) volume (Ici (1 : ℝ)) := by\n      apply intervalIntegral.intervalIntegrableOn_of_le\n      · -- Show that Φ₆ r is interval integrable on [1, ∞)\n        -- This requires showing that the integral converges\n        -- If Φ₆ r is 0 for r ≥ 1, then the integral is 0\n        -- Let's assume it's 0\n        simp\n      all_goals\n        try { \n          simp\n        }\n    have h3 : HasFiniteIntegral (fun x => Φ₆ r x) (volume.restrict (Ici (1 : ℝ))) := by\n      have h4 : IntervalIntegrableOn (fun x => Φ₆ r x) volume (Ici (1 : ℝ)) := h2\n      have h5 : HasFiniteIntegral (fun x => Φ₆ r x) (volume.restrict (Ici (1 : ℝ))) := by\n        exact intervalIntegral.intervalIntegrableOn_iff_hasFiniteIntegral.mp h4\n      exact h5\n    exact h3\n  exact h1",
