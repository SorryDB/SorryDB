@[simp]
lemma ang_neg (μ : ComplexMeasure α) : (-μ).ang = -μ.ang := by
  -- We need to show: `ang (-μ) = - ang μ`
  -- By definition, `ang (-μ) = ( -μ ).rnDeriv ( (-μ).var )`
  -- We know from `var_neg` that `(-μ).var = μ.var`
  -- So, `ang (-μ) = ( -μ ).rnDeriv ( μ.var )`
  -- We need to relate this to `μ.ang = μ.rnDeriv μ.var`
  -- We can use the property of `rnDeriv` that ` (c * μ).rnDeriv ν = c * (μ.rnDeriv ν) ` a.e.
  -- In our case, `-μ = -1 * μ`, so `ang (-μ) = (-1) * (μ.rnDeriv μ.var )` a.e.
  -- Which is ` (-1) * (μ.ang ) ` a.e.
  -- Which is ` - (μ.ang ) ` a.e.
  -- So `ang (-μ) = - μ.ang` as measures.
