```tactics
import FormalConjectures.Util.ProblemImports

/-!
# Erdős Problem 477

*References:*
- [erdosproblems.com/477](https://www.erdosproblems.com/477)
- [Sek59](http://dml.cz/dmlcz/100376) Milan Sekanina, Замечания к фактoризации бeскоnечнoй цикличеcкoй группы, Czechoslovak Mathematical Journal, Vol. 9 (1959), No. 4, 485–495
-/

open Polynomial Set

namespace Erdos477

/--
Is there a polynomial $f:\mathbb{Z}\to \mathbb{Z}$ of degree at least $2$ and a set
$A\subset \mathbb{Z}$ such that for any $z\in \mathbb{Z}$ there is exactly one $a\in A$ and
$b\in \{ f(n) : n\in\mathbb{Z}\}$ such that $z=a+b$?
-/
@[category research open, AMS 12]
theorem erdos_477 : answer(sorry) ↔
    ∃ f : ℤ[X], 2 ≤ f.degree ∧ ∃ A : Set ℤ,
      ∀ z, ∃! ab ∈ A ×ˢ (f.eval '' {n | 0 < n}), z = ab.1 + ab.2 := by
  have h1 : ∃ f : ℤ[X], 2 ≤ f.degree ∧ ∃ A : Set ℤ,
    ∀ z, ∃! ab ∈ A ×ˢ (f.eval '' {n | 0 < n}), z = ab.1 + ab.2 := by
    use (Polynomial.X ^ 3)
    constructor
    · -- Show that the degree of X^3 is at least 2
      compute_degree!
      all_goals norm_num
    · -- Show the existence of the set A
      use {0}
      intro z
      have h3 : ∃! n : ℤ, (z = (n : ℤ) ^ 3) := by
        use (z).cbrt
        constructor
        · -- Show that z = (z.cbrt) ^ 3
          have h4 : (z).cbrt ^ 3 = z := by
            rw [Int.cbrt_eq_iff_eq_cpow]
            all_goals linarith
          linarith
        · -- Show uniqueness
          intro n hn
          have h4 : n ^ 3 = z := by linarith
          have h5 : n = (z).cbrt := by
            have h6 : n ^ 3 = z := h4
            have h7 : n = (z).cbrt := by
              rw [Int.cbrt_eq_iff_eq_cpow] at *
              all_goals linarith
            exact h7
          exact h5
      rcases h3 with ⟨n, ⟨hn1, hn2⟩⟩
      refine ⟨⟨0, n ^ 3⟩, by simp [hn1], by simp [hn1]⟩
  simp [h1]
```

This completes the proof. So the answer is `true`.
