-/

open Polynomial Set

namespace Erdos477

/--
Is there a polynomial $f:\mathbb{Z}\to \mathbb{Z}$ of degree at least $2$ and a set
$A\subset \mathbb{Z}$ such that for any $z\in \mathbb{Z}$ there is exactly one $a\in A$ and
$b\in \{ f(n) : n\in\mathbb{Z}\}$ such that $z=a+b$?
-/
@[category research open, AMS 12]
theorem erdos_477 : answer(sorry) ↔
    ∃ f : ℤ[X], 2 ≤ f.degree ∧ ∃ A : Set ℤ,
      ∀ z, ∃! ab ∈ A ×ˢ (f.eval '' {n | 0 < n}), z = ab.1 + ab.2 := by
  have h1 : (2 : ℤ) ≤ (2 : ℤ) := by norm_num
  have h2 : ∃ f : ℤ[X], 2 ≤ f.degree ∧ ∃ A : Set ℤ,
      ∀ z, ∃! ab ∈ A ×ˢ (f.eval '' {n | 0 < n}), z = ab.1 + ab.2 := by
    use (Polynomial.X ^ 2 + 1)
    constructor
    · -- Show that the degree is at least 2
      compute_degree!
      all_goals norm_num
    · -- Show the existence of the set A
      use {z | z % 2 = 0}
      intro z
      use (-z ^ 2 + 3 * z - 2, (z - 1) ^ 2 + 1)
      constructor
      · -- Show that this pair is in the set
        constructor
        · -- Show that -z^2 + 3 * z - 2 is even
          have h3 : (-z ^ 2 + 3 * z - 2) % 2 = 0 := by
            have h4 : z % 2 = 0 ∨ z % 2 = 1 := by omega
            rcases h4 with (h4 | h4)
            · -- If z is even
              simp [h4, pow_two, Int.add_emod, Int.sub_emod, Int.mul_emod]
              <;> omega
            · -- If z is odd
              simp [h4, pow_two, Int.add_emod, Int.sub_emod, Int.mul_emod]
              <;> omega
          have h4 : (-z ^ 2 + 3 * z - 2) % 2 = 0 := h3
          simp [Set.mem_setOf_eq] at *
          omega
        · -- Show that (z - 1)^2 + 1 is in the image of f
          use z - 1
          all_goals
            simp [Set.mem_image, Set.mem_setOf_eq, Polynomial.eval_add, Polynomial.eval_pow, Polynomial.eval_X]
            <;> ring_nf
      · -- Show uniqueness
        intro w hw hz
        rcases hw with ⟨ha, hb⟩
        rcases hb with ⟨n, hn⟩
        have h_eq1 : w.1 = -z ^ 2 + 3 * z - 2 := by
          have h_eq2 : w.1 = z - (n ^ 2 + 1) := by
            have h_eq3 : w.1 + (n ^ 2 + 1) = z := by
              linarith [hz, hn]
            linarith
          have h_eq4 : n ^ 2 = (z - 1) ^ 2 := by
            nlinarith [show w.1 % 2 = 0 by 
              have h3 : w.1 % 2 = 0 := by
                have h4 : w.1 ∈ ({z | z % 2 = 0} : Set ℤ) := by 
                  simpa using ha
                simpa using h4
              omega
            ]
          have h_eq5 : n = z - 1 ∨ n = 1 - z := by
            have h_eq6 : n ^ 2 - (z - 1) ^ 2 = 0 := by
              nlinarith
            have h_eq7 : (n - (z - 1)) * (n + (z - 1)) = 0 := by
              nlinarith
            cases' (mul_eq_zero.1 h_eq7) with h_eq8 h_eq9
            · -- Case where n - (z - 1) = 0
              left
              linarith
            · -- Case where n + (z - 1) = 0
              right
              linarith
          cases' h_eq5 with h_eq6 h_eq7
          · -- If n = z - 1
            rw [h_eq6] at h_eq2
            nlinarith
          · -- If n = 1 - z
            rw [h_eq7] at h_eq2
            nlinarith
        have h_eq2 : w.2 = (z - 1) ^ 2 + 1 := by
          have h_eq3 : w.2 = n ^ 2 + 1 := by
            simpa using hn
          have h_eq4 : n ^ 2 = (z - 1) ^ 2 := by
            nlinarith [show w.1 % 2 = 0 by 
              have h3 : w.1 % 2 = 0 := by
                have h4 : w.1 ∈ ({z | z % 2 = 0} : Set ℤ) := by 
                  simpa using ha
                simpa using h4
              omega
            ]
          rw [h_eq3]
          nlinarith
        simp [h_eq1, h_eq2]
        all_goals tauto
  simp [h2]
  all_goals tauto
