open scoped ENNReal

namespace ProbabilityTheory

variable {őĻ ő© E : Type*} [LinearOrder őĻ] [OrderBot őĻ] [TopologicalSpace őĻ] [OrderTopology őĻ]
  [MeasurableSpace őĻ] [NormedAddCommGroup E] [NormedSpace ‚ĄĚ E] [CompleteSpace E]
  {mő© : MeasurableSpace ő©} {P : Measure ő©} {X : őĻ ‚Üí ő© ‚Üí E} {ūĚďē : Filtration őĻ mő©}

lemma IsLocalMartingale.isLocalSubmartingale_sq_norm
    (hX : IsLocalMartingale X ūĚďē P) (hX_cadlag : ‚ąÄ ŌČ, IsCadlag (X ¬∑ ŌČ)) :
    IsLocalSubmartingale (fun t ŌČ ‚Ü¶ ‚ÄĖX t ŌČ‚ÄĖ ^ 2) ūĚďē P := by

  have h1 : ‚ąÄ ŌČ, IsCadlag (fun t => ‚ÄĖX t ŌČ‚ÄĖ ^ 2) := by
    intro ŌČ
    have h2 : IsCadlag (X ¬∑ ŌČ) := hX_cadlag ŌČ
    have h3 : IsCadlag (fun t => ‚ÄĖX t ŌČ‚ÄĖ ^ 2) := by
      have h4 : IsCadlag (X ¬∑ ŌČ) := hX_cadlag ŌČ
      have h5 : Continuous (fun x : E => ‚ÄĖx‚ÄĖ ^ 2) := by
        apply Continuous.pow
        apply Continuous.norm
      have h6 : IsCadlag (fun t => X t ŌČ) := by
        simpa using h4
      have h7 : IsCadlag (fun t => ‚ÄĖX t ŌČ‚ÄĖ ^ 2) := by
        apply IsCadlag.comp
        exact h6
        exact h5
      exact h7
    exact h3

  have h2 : IsLocalSubmartingale (fun t ŌČ ‚Ü¶ ‚ÄĖX t ŌČ‚ÄĖ ^ 2) ūĚďē P := by
    apply IsLocalSubmartingale.mk
    ¬∑ -- Show that ‚ąÄ ŌČ, IsCadlag (fun t => ‚ÄĖX t ŌČ‚ÄĖ ^ 2)
      intro ŌČ
      have h1' : IsCadlag (fun t => ‚ÄĖX t ŌČ‚ÄĖ ^ 2) := h1 ŌČ
      simpa using h1'
    ¬∑ -- Show that ‚ąÄ s ‚ąą I, ‚ąÄ ŌČ, E[‚ÄĖX s ŌČ‚ÄĖ ^ 2 | F s] ‚Č§ ‚ÄĖX s ŌČ‚ÄĖ ^ 2
      intro s hs ŌČ
      have h8 : ‚ÄĖX s ŌČ‚ÄĖ ^ 2 = ‚ÄĖX s ŌČ‚ÄĖ ^ 2 := by rfl
      have h9 : E[‚ÄĖX s ŌČ‚ÄĖ ^ 2 | F s] ‚Č§ ‚ÄĖX s ŌČ‚ÄĖ ^ 2 := by
        have h10 : ‚ÄĖX s ŌČ‚ÄĖ ^ 2 = ‚ÄĖX s ŌČ‚ÄĖ ^ 2 := by rfl
        have h11 : F s ‚äĘ ‚ÄĖX s ŌČ‚ÄĖ ^ 2 := by
          simp
        have h12 : E[‚ÄĖX s ŌČ‚ÄĖ ^ 2 | F s] = ‚ÄĖX s ŌČ‚ÄĖ ^ 2 := by
          rw [h11]
          simp
        linarith [h12]
      simpa using h9
  exact h2
