  · -- First implication: if k = 1, then ...
    intro hk1
    use double e, Choice.one
    constructor
    · -- Show that double e = ok (double e)
      simp
    constructor
    · -- Show that ct_eq (mul_by_pow_2 e k) (double e) = ok (Choice.one)
      have h1 : k = 1#u32 := by
        exact_mod_cast hk1
      rw [show mul_by_pow_2 e k = double e by
        rw [h1]
