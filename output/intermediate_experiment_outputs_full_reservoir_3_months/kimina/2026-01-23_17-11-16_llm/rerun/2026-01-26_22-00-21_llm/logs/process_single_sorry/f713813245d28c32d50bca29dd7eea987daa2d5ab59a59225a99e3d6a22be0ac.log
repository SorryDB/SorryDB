/- A simple example to show how to work with lists and sets in Lean 4 -/
example (l₁ l₂ : List Nat) (s₁ s₂ : Set Nat) (f : Nat → Nat) :
    (∀ (n : Nat), n ∈ l₁ → n ∈ l₂) →
    (∀ (n : Nat), n ∈ l₂ → n ∈ s₁) →
    (∀ (n : Nat), n ∈ s₁ → n ∈ s₂) →
    (∀ (n : Nat), n ∈ l₁ → f n ∈ s₂) := by
  intro h₁ h₂ h₃
  intro n hn
  have h₄ : n ∈ l₂ := h₁ n hn
  have h₅ : n ∈ s₁ := h₂ n h₄
  have h₆ : n ∈ s₂ := h₃ n h₅
  simp [f] at h₆ ⊢
  exact h₆
