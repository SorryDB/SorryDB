structure SystemState : Type where
  id : ℕ
  requests : RequestArray
  orderConstraints : OrderConstraintSystem
  threadTypes : List (ThreadId × Type)
  removed : List (RequestId × Request)
  satisfied : List (RequestId × RequestId)
  removedCoherent : List (RequestId × CoherentValue)

/- The basic type of a request, which can be a read or a write.
