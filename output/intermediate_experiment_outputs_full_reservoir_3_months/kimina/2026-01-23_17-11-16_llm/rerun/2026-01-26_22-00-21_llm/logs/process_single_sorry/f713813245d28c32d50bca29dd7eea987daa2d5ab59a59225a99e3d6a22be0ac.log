  removed : List (RequestId × Request)
  satisfied : List (RequestId × RequestId)
  removedCoherent : List (RequestId × CoherentValue)

/- The basic type of a request, which can be a read or a write.
-/
noncomputable structure BasicRequest : Type where
  address? : Option (Address)
  isRead : Prop
  isWrite : Prop
  isAtomic : Prop
  isTransactional : Prop
  isSatisfiable : Prop
  isSatisfied : Prop
  value? : Option (CoherentValue)

/- A request, which is either a read or a write.
-/
structure Request : Type where
  basic_type : BasicRequest
  id : ℕ
  occurrence : ℕ
  thread : ThreadId
  predecessor_at : List (ThreadId)
  pairedRequest? : Option (RequestId)
  address? : Option (Address)
  isRead : Prop
  isWrite : Prop
  isAtomic : Prop
  isTransactional : Prop
  isSatisfiable : Prop
  isSatisfied : Prop
  value? : Option (CoherentValue)
  propagating : Prop
  propagated_to : List (ThreadId)
  conditionalValue? : Option (ConditionalValue)
  conditionalSucceeded : Prop
  conditionalFailed : Prop
  conditionalUndecided : Prop
  conditionalTentativeOrSuccessful : Prop

