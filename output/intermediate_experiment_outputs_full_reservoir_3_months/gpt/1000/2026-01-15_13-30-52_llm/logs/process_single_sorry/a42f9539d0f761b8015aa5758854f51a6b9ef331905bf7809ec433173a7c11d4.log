import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  have hn : 2 ≤ n := le_trans (by decide : (2 : ℕ) ≤ 4) h₀
  have hmono : n ^ 2 ≤ n ^ n := by
    simpa [pow_two] using pow_le_pow_of_le_left' hn (show 2 ≤ n from hn)
  have hfact : n ^ n ≤ n ! := by
    simpa using pow_le_factorial n
  exact le_trans hmono hfact
```
