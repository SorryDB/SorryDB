  have hle_rpow :
      (‚ąę‚ĀĽ ŌČ, (‚ÄĖX i ŌČ‚ÄĖ ^ 2 : ‚ĄĚ‚Č•0‚ąě) ‚ąāP) ^ (1 / (2 : ‚ĄĚ)) ‚Č§
