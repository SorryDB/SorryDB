theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil =>
    simp
  | cons l L ih =>
    by_cases hli : i ≤ l.length
    · have hpos : 0 < (l :: L).flatten.length := by
        simp [flatten_cons, List.length_append]
      have hlt : i < (l :: L).flatten.length := by
        simp [flatten_cons, List.length_append, hli]
      have hfind : findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums = 1 := by
        simp [partialSums_cons, findIdx_cons]
        rw [findIdx_eq] <;> grind
      simp [flatten_cons, hfind, hli, Nat.sub_eq_of_eq_add_rev (by simp), Nat.sub_eq_zero_of_le hli]
    · have hlt' : l.length < i := Nat.lt_of_not_ge hli
      have hpos : 0 < (l :: L).flatten.length := by
        simp [flatten_cons, List.length_append]
      have hlt : i < (l :: L).flatten.length := by
        simpa [flatten_cons, List.length_append] using (by
          have : i < l.length + L.flatten.length := by
            simpa [flatten_cons, List.length_append] using (Nat.lt_of_lt_of_le (Nat.lt_add_of_pos_right (by
              cases L <;> simp)) (Nat.le_of_lt (by
                simpa [flatten_cons, List.length_append] using (Nat.lt_of_lt_of_le (Nat.lt_add_of_pos_left (by
                  cases L <;> simp)) (Nat.le_add_right _ _)))))
          exact this)
      have hfind :
          findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums =
            findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums + 1 := by
        simp [partialSums_cons, findIdx_cons, Function.comp_def]
        congr
        funext x
        grind
      have : i - l.length + l.length = i := Nat.sub_add_cancel (Nat.le_of_lt hlt')
      have ht : (l ++ L.flatten).take i = l ++ (L.flatten.take (i - l.length)) := by
        simp [List.take_append, hli, Nat.sub_eq_of_eq_add this.symm]
      have hjtake : (l :: L).take (findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums - 1) =
          l :: (L.take (findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums - 1)) := by
        simp [hfind, Nat.succ_sub_one, List.take_succ_cons]
      have hjget :
          (l :: L)[findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums - 1]? =
            L[findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums - 1]? := by
        simp [hfind, Nat.succ_sub_one]
      have hflatten_take :
          ((l :: L).take (findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums - 1)).flatten =
            l ++ ((L.take (findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums - 1)).flatten) := by
        simp [hjtake, flatten_cons]
      have hlen :
          ((l :: L).take (findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums - 1)).flatten.length =
            l.length + (L.take (findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums - 1)).flatten.length := by
        simp [hflatten_take, List.length_append]
      have hk :
          i - ((l :: L).take (findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums - 1)).flatten.length =
            (i - l.length) - (L.take (findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums - 1)).flatten.length := by
        omega
      have := ih (i := i - l.length)
      simp [flatten_cons, ht, hfind, hflatten_take, hjget, hlen, hk, List.append_assoc, this]
