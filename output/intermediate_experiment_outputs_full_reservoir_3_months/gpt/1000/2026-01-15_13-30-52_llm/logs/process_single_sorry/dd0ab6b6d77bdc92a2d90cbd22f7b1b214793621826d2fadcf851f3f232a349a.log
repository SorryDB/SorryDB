def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    have hw : w₁ = w₁ ∩ w₂ := by
      ext z; constructor
      · intro hz; exact ⟨hz, h hz⟩
      · intro hz; exact hz.1
    have hproj : E.measureOf' w₁ = E.measureOf' w₁ * E.measureOf' w₂ := by
      have : E.measureOf' (w₁ ∩ w₂) = E.measureOf' w₁ * E.measureOf' w₂ :=
        E.m_Inter' (by
          by_cases hw₁ : MeasurableSet w₁
          · exact hw₁
          · exfalso
            have := E.not_measurable' (i := w₁) hw₁
            simpa [this] using (E.isOrthogonalProjection' w₁).2)
          (by
            by_cases hw₂ : MeasurableSet w₂
            · exact hw₂
            · exfalso
              have := E.not_measurable' (i := w₂) hw₂
              simpa [this] using (E.isOrthogonalProjection' w₂).2)
      simpa [hw] using this
    have hP : IsOrthogonalProjection (E.measureOf' w₂) := E.isOrthogonalProjection' w₂
    have hnorm : ‖(E.measureOf' w₂) (E.measureOf' w₁ x)‖ ≤ ‖E.measureOf' w₁ x‖ := by
      have hadj : (E.measureOf' w₂).adjoint = E.measureOf' w₂ := by
        simpa [IsOrthogonalProjection] using (hP.2.symm)
      have hmul : (E.measureOf' w₂) ^ 2 = E.measureOf' w₂ := by
        simpa [IsOrthogonalProjection, pow_two] using congrArg (fun t => t.symm) hP.1
      have hop : ((E.measureOf' w₂).opNorm : ℝ≥0∞) ≤ 1 := by
        simpa [hadj, hmul] using (ContinuousLinearMap.opNorm_le_one_of_idempotent_selfAdjoint
          (E.measureOf' w₂) (by simpa [pow_two] using hmul) (by simpa using hadj))
      have : ‖(E.measureOf' w₂) (E.measureOf' w₁ x)‖ ≤ ‖E.measureOf' w₂‖ * ‖E.measureOf' w₁ x‖ :=
        (E.measureOf' w₂).le_opNorm _ 
      have hle : ‖E.measureOf' w₂‖ ≤ 1 := by
        have := (ContinuousLinearMap.opNorm_le_iff_le (E.measureOf' w₂) 1).1 ?_
        · simpa using this
        · intro y
          have := (ContinuousLinearMap.le_opNorm (E.measureOf' w₂) y)
          exact le_trans this (by
            have : (‖(1 : ℝ)‖ : ℝ) = 1 := by simp
            simpa [one_mul] using mul_le_mul_of_nonneg_right (by
              simpa using (ENNReal.coe_le_coe.1 hop)) (norm_nonneg _))
      exact le_trans ((E.measureOf' w₂).le_opNorm _) (by
        simpa [mul_assoc] using mul_le_mul_of_nonneg_right hle (norm_nonneg _))
    have : ‖E.measureOf' w₁ x‖ = ‖(E.measureOf' w₂) (E.measureOf' w₁ x)‖ := by
      have := congrArg (fun T => T x) hproj
      simpa [ContinuousLinearMap.mul_apply] using this
    simpa [this] using hnorm
