theorem trivialInvo_fixedPoints : (fixedPoints (trivialInvo k)).Nonempty := by
  classical
  by_contra h
  have hodd : Odd (Fintype.card (T k)) := card_T_odd (k := k)
  have hno : IsEmpty (fixedPoints (trivialInvo k)) := by
    simpa [Finset.Nonempty] using h
  have hsq : trivialInvo k ^ 2 = (1 : Function.End (T k)) := by
    change trivialInvo k ∘ trivialInvo k = id
    funext x
    cases x with
    | mk x hx =>
      cases x with
      | mk x hxS =>
        cases x with
        | mk x y z =>
          simp [trivialInvo]
  have heven : Even (Fintype.card (T k)) := by
    simpa using Fintype.card_even_of_isEmpty_fixedPoints (f := trivialInvo k) hsq hno
  exact (hodd.not_even heven)
```
