lemma IsMatching.exists_isAugPath_not_max (hM : G.IsMatching M) (hnotmax : ¬ G.IsMaxMatching M)
    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  obtain ⟨M', hM', hM'cd⟩ := by
    simpa only [isMaxMatching_iff, hM, true_and, not_forall, not_le] using hnotmax
  classical
  by_contra hno
  have hmax : G.IsMaxMatching M :=
    hM.isMaxMatching_of_vertex_subset (by
      intro x hxV
      by_contra hxnot
      have hx0 : (M ∩ E(G, x)).encard = 0 := by
        classical
        exact encard_eq_zero.2 (by
          intro e he
          exact hxnot ⟨e, he.1, he.2⟩)
      have hxM : x ∉ V(G, M) := by
        intro hxM
        rcases hxM with ⟨e, heM, hex⟩
        have : e ∈ (M ∩ E(G, x)) := ⟨heM, hex⟩
        have : (M ∩ E(G, x)).encard ≠ 0 := by
          classical
          exact (encard_ne_zero.2 ⟨e, this⟩)
        exact this hx0
      rcases hxV with ⟨y, hyV, hconn⟩
      have hxV' : x ∈ V(G) := hxV
      have hyM : y ∈ V(G, M) := by
        classical
        have : (M ∩ E(G, y)).encard ≤ 1 := hM.degree_le_one y
        have hy0 : (M ∩ E(G, y)).encard ≠ 0 := by
          intro hy0
          have hyM0 : y ∉ V(G, M) := by
            intro hyM
            rcases hyM with ⟨e, heM, hey⟩
            have : e ∈ (M ∩ E(G, y)) := ⟨heM, hey⟩
            have : (M ∩ E(G, y)).encard ≠ 0 := by
              classical
              exact (encard_ne_zero.2 ⟨e, this⟩)
            exact this hy0
          have : ∃ P, G.IsAugPath hM P := by
            classical
            refine ⟨.nil x, ?_⟩
            simp [isAugPath_iff, hxM, hxV']
          exact False.elim (hno this)
        rcases (encard_ne_zero.1 hy0) with ⟨e, he⟩
        exact ⟨e, he.1, he.2⟩
      have : ∃ P, G.IsAugPath hM P := by
        classical
        refine ⟨.nil x, ?_⟩
        simp [isAugPath_iff, hxM, hxV']
      exact False.elim (hno this))
  exact (not_lt_of_ge (hmax.max M' hM') hM'cd)
```
