lemma forall_indep {S D : Set α} (R : refinement S) :
    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  have hbI : b ≤ sSup (I \ {a}) := by
    refine le_trans hb' ?_
    refine sSup_le_sSup ?_
    intro x hx
    rcases hx with ⟨hxU, hxa⟩
    rcases hxU with ⟨J, hJR, hxJ⟩
    have hJne : J ≠ I := by
      intro hJI
      subst hJI
      exact hxa (hxJ ▸ hI')
    exact Set.mem_diff_of_mem (by exact hxJ) (by
      intro hxa'
      exact hJne (by
        ext y
        constructor
        · intro hy
          exact hy
        · intro hy
          exact hy))
  have h_indep : sSupIndep I := R.carrier_indep I hI
  have : b ≤ ⊥ := by
    have := h_indep a hI' (sSup (I \ {a})) (by
      refine le_trans hb ?_
      exact le_sSup_of_le a (le_rfl)) (by
      refine le_trans hbI ?_
      exact le_sSup_of_le (sSup (I \ {a})) le_rfl)
    simpa [disjoint_iff, Set.disjoint_singleton_right, Set.mem_diff, Set.mem_singleton_iff] using
      this
  exact this
