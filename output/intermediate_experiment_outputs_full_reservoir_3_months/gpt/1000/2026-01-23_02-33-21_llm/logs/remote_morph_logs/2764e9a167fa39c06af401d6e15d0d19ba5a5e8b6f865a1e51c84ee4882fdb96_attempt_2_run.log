            _ = ⟪p x, y⟫_ℂ := by simpa [hp.2]
            _ = 0 := by simpa [hx']
        simpa [inner_eq_zero_symm] using this
      exact (Submodule.hasOrthogonalProjection_iff (K := LinearMap.range p)).2 hker
    ·
