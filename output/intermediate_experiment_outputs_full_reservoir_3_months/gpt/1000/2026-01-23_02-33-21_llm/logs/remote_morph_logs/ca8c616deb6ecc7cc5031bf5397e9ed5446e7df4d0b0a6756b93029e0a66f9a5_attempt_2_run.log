  have h : Nat.gcd (21 * n + 4) (14 * n + 3) ∣ 1 := by
    have h1 : Nat.gcd (21 * n + 4) (14 * n + 3) ∣ (21 * n + 4) := Nat.gcd_dvd_left _ _
    have h2 : Nat.gcd (21 * n + 4) (14 * n + 3) ∣ (14 * n + 3) := Nat.gcd_dvd_right _ _
    have h3 : Nat.gcd (21 * n + 4) (14 * n + 3) ∣ (2 * (21 * n + 4) - 3 * (14 * n + 3)) :=
      dvd_sub (dvd_mul_of_dvd_right h1 _) (dvd_mul_of_dvd_right h2 _)
