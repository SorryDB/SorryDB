import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  classical
  by_cases h : (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b))
  · exact Or.inl h
  · exact Or.inr (by
      classical
      by_contra h'
      exact h (by
        classical
        by_contra h''
        exact h' (by
          classical
          simpa [not_exists, not_and, not_or, not_imp] using h'')))
