import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_algebra_282 (f : ℝ → ℝ) (h₀ : ∀ x : ℝ, ¬ (Irrational x) → f x = abs (Int.floor x))
  (h₁ : ∀ x, Irrational x → f x = (Int.ceil x) ^ 2) :
  f (8 ^ (1 / 3)) + f (-Real.pi) + f (Real.sqrt 50) + f (9 / 2) = 79 := by
  have h8irr : ¬ Irrational (8 ^ ((1 : ℝ) / 3)) := by
    have hpow : (8 : ℝ) ^ ((1 : ℝ) / 3) = 2 := by
      norm_num
    simpa [hpow] using (Rat.not_irrational (2 : ℚ))
  have hpiirr : Irrational (-Real.pi) := by
    simpa using (Irrational.neg (by simpa using Real.irrational_pi))
  have hsqrtirr : ¬ Irrational (Real.sqrt 50) := by
    have hs : Real.sqrt 50 = 5 * Real.sqrt 2 := by
      have : (0 : ℝ) ≤ 2 := by norm_num
      calc
        Real.sqrt 50 = Real.sqrt (25 * 2) := by norm_num
        _ = Real.sqrt 25 * Real.sqrt 2 := by
              simpa [mul_assoc] using (Real.sqrt_mul (show (0 : ℝ) ≤ 25 by norm_num) this)
        _ = 5 * Real.sqrt 2 := by
              simp
    have hr : ¬ Irrational (5 * Real.sqrt 2) := by
      have : Irrational (Real.sqrt 2) := by
        simpa using Real.irrational_sqrt_two
      exact (Irrational.mul_rat (5 : ℚ)).1 ?_
    · -- fill in: ¬Irrational (5*sqrt 2) is false; actually sqrt 50 is irrational.
      -- But we need compute f(sqrt 50) using h₁, so prove Irrational.
      -- switch: derive Irrational sqrt50 instead.
      sorry
  sorry
