  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    simpa using (norm_le_norm_of_nonexpansive (E.isOrthogonalProjection' w₂).1 x (by
      have : E.measureOf' w₁ = E.measureOf' (w₁ ∩ w₂) := by
        have hw : w₁ ∩ w₂ = w₁ := by
          ext z; constructor
          · intro hz; exact hz.1
          · intro hz; exact ⟨hz, h hz⟩
        simp [hw]
      -- use `m_Inter'` with measurability assumptions if needed; otherwise fall back to
      -- `not_measurable'` gives `0` so inequality is trivial
      by_cases hmw₁ : MeasurableSet w₁
      · by_cases hmw₂ : MeasurableSet w₂
        · have := congrArg (fun p => (p : H →L[ℂ] H) x) (E.m_Inter' (w₁ := w₁) (w₂ := w₂) hmw₁ hmw₂)
          -- `E (w₁ ∩ w₂) = E w₁ * E w₂`, and since `w₁ ⊆ w₂`, `w₁ ∩ w₂ = w₁`
          have hw : w₁ ∩ w₂ = w₁ := by
            ext z; constructor
            · intro hz; exact hz.1
            · intro hz; exact ⟨hz, h hz⟩
          -- conclude `E w₁ x = E w₁ (E w₂ x)` and use contractiveness of projection `E w₂`
          -- `IsOrthogonalProjection` gives idempotent and self-adjoint; this implies it's an orthogonal projection hence nonexpansive
          -- so `‖E w₁ x‖ ≤ ‖E w₂ x‖` follows from `E w₁ = E w₁ * E w₂` and `‖E w₁‖ ≤ 1`
          -- we use `‖p (q x)‖ ≤ ‖q x‖` for orthogonal projection `p`
          -- apply with `p = E w₁`, `q = E w₂`
          have hmul : (E.measureOf' w₁) x = (E.measureOf' w₁) ((E.measureOf' w₂) x) := by
            have := congrArg (fun p => (p : H →L[ℂ] H) x) (by
              simpa [hw, mul_assoc] using (E.m_Inter' (w₁ := w₁) (w₂ := w₂) hmw₁ hmw₂))
            simpa [ContinuousLinearMap.mul_apply] using this
          -- now use nonexpansiveness of `E w₁`
          -- for orthogonal projection, `‖p v‖ ≤ ‖v‖`
          have hcontract :
              ‖(E.measureOf' w₁) ((E.measureOf' w₂) x)‖ ≤ ‖(E.measureOf' w₂) x‖ := by
            -- `E.measureOf' w₁` is an orthogonal projection hence `IsStarProjection`; use `ContinuousLinearMap.norm_le_one_of_idempotent_selfAdjoint`
            -- available lemma in Mathlib:
            -- `norm_le_of_isOrthogonalProjection` not sure; use general bound `‖p v‖ ≤ ‖v‖` for `IsIdempotent` and `IsSelfAdjoint`:
            -- we use `LinearIsometry` characterization via `Submodule.orthogonalProjection` by converting to `IsStarProjection`.
            -- fall back: use `ContinuousLinearMap.opNorm_le_bound` with `‖p‖ ≤ 1` lemma for orthogonal projection.
            have hop : ‖E.measureOf' w₁‖ ≤ (1 : ℝ) := by
              -- lemma: `ContinuousLinearMap.opNorm_le_one_of_idempotent_selfAdjoint`
              simpa [IsOrthogonalProjection] using
                (ContinuousLinearMap.opNorm_le_one_of_idempotent_selfAdjoint
                  (p := E.measureOf' w₁) (E.isOrthogonalProjection' w₁).1 (E.isOrthogonalProjection' w₁).2)
            have := (E.measureOf' w₁).le_opNorm ((E.measureOf' w₂) x)
            -- `‖p v‖ ≤ ‖p‖ * ‖v‖ ≤ 1 * ‖v‖`
            have : ‖(E.measureOf' w₁) ((E.measureOf' w₂) x)‖ ≤ ‖(E.measureOf' w₁)‖ * ‖(E.measureOf' w₂) x‖ :=
              (E.measureOf' w₁).le_opNorm _
            have : ‖(E.measureOf' w₁) ((E.measureOf' w₂) x)‖ ≤ ‖(E.measureOf' w₂) x‖ := by
              calc
                ‖(E.measureOf' w₁) ((E.measureOf' w₂) x)‖
                    ≤ ‖(E.measureOf' w₁)‖ * ‖(E.measureOf' w₂) x‖ := this
                _ ≤ (1 : ℝ) * ‖(E.measureOf' w₂) x‖ := by
                      gcongr
                _ = ‖(E.measureOf' w₂) x‖ := by simp
            exact this
