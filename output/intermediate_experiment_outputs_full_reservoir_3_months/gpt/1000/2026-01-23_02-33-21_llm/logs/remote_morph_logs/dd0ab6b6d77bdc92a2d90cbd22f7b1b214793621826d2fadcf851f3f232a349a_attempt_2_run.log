def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    by_cases hw₁ : MeasurableSet w₁
    · by_cases hw₂ : MeasurableSet w₂
      · have hdis : Disjoint w₁ (w₂ \ w₁) := disjoint_sdiff_right
        have hunion : w₁ ∪ (w₂ \ w₁) = w₂ := by
          ext z
          constructor
          · intro hz
            rcases hz with hz | hz
            · exact h hz
            · exact hz.1
          · intro hz
            by_cases hz1 : z ∈ w₁
            · exact Or.inl hz1
            · exact Or.inr ⟨hz, hz1⟩
        have hadd :
            E.measureOf' w₂ =
              E.measureOf' w₁ + E.measureOf' (w₂ \ w₁) := by
          have := (E.m_Union' hw₁ (hw₂.diff hw₁) hdis)
          simpa [hunion, add_comm] using this
        have hmul :
            E.measureOf' w₁ * E.measureOf' w₂ = E.measureOf' w₁ := by
          have := E.m_Inter' hw₁ hw₂
          have hInter : w₁ ∩ w₂ = w₁ := by
            ext z; constructor
            · intro hz; exact hz.1
            · intro hz; exact ⟨hz, h hz⟩
          have : E.measureOf' (w₁ ∩ w₂) = E.measureOf' w₁ * E.measureOf' w₂ := this
          simpa [hInter] using this.symm
        have hmem : E.measureOf' w₁ x = E.measureOf' w₁ (E.measureOf' w₂ x) := by
          have := congrArg (fun T : H →L[ℂ] H => T x) (congrArg (fun T => T) hmul)
          simpa [ContinuousLinearMap.mul_def] using this
        calc
          ‖E.measureOf' w₁ x‖
              = ‖E.measureOf' w₁ (E.measureOf' w₂ x)‖ := by simpa [hmem]
          _ ≤ ‖E.measureOf' w₁‖ * ‖E.measureOf' w₂ x‖ := by
                simpa using (ContinuousLinearMap.le_opNorm (E.measureOf' w₁) (E.measureOf' w₂ x))
          _ ≤ ‖E.measureOf' w₂ x‖ := by
                have hop : IsOrthogonalProjection (E.measureOf' w₁) := E.isOrthogonalProjection' w₁
                have hnorm : ‖E.measureOf' w₁‖ ≤ (1 : ℝ) := by
                  rcases hop with ⟨hsq, hstar⟩
                  have : IsStarProjection (E.measureOf' w₁) := by
                    constructor
