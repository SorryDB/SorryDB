        · -- w₂ not measurable: E w₂ = 0, so RHS is 0 and LHS ≥ 0
          rw [E.not_measurable' (i := w₂) hmw₂] 
          simp
      · -- w₁ not measurable: E w₁ = 0, so inequality holds
        rw [E.not_measurable' (i := w₁) hmw₁]
        simp))
