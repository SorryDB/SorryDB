                    · exact hstar
                  have hle := (ContinuousLinearMap.opNorm_le_of_idempotent_and_selfAdjoint this)
                  simpa using hle
                have : ‖E.measureOf' w₁‖ * ‖E.measureOf' w₂ x‖ ≤ (1 : ℝ) * ‖E.measureOf' w₂ x‖ :=
                  mul_le_mul_of_nonneg_right hnorm (norm_nonneg _)
                simpa using this
      · rw [E.not_measurable' (by simpa using hw₂)]
        simp only [ContinuousLinearMap.zero_apply, norm_zero, norm_nonneg]
    · rw [E.not_measurable' (by simpa using hw₁)]
      simp only [ContinuousLinearMap.zero_apply, norm_zero, norm_nonneg]
