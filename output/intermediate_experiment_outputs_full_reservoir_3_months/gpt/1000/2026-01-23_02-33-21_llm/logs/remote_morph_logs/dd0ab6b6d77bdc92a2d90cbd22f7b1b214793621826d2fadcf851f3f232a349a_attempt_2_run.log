    rcases hp with ⟨hpow, hadj⟩
    -- use `‖p q x‖ ≤ ‖q x‖` for orthogonal projection `q`
    have : ‖(E.measureOf' w₁ * E.measureOf' w₂) x‖ ≤ ‖(E.measureOf' w₂) x‖ := by
      -- `E.measureOf' w₂` is an orthogonal projection hence contractive
