    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    by_cases hw₁ : MeasurableSet w₁
    · by_cases hw₂ : MeasurableSet w₂
      · have hdiff : Disjoint w₁ (w₂ \ w₁) := by
          refine disjoint_left.2 ?_
          intro a ha₁ ha₂
          exact ha₂.2 ha₁
        have hw₂diff : MeasurableSet (w₂ \ w₁) := hw₂.diff hw₁
        have hproj :
            E.measureOf' w₂ = E.measureOf' w₁ + E.measureOf' (w₂ \ w₁) := by
          have : w₂ = w₁ ∪ (w₂ \ w₁) := by
            ext a
            constructor
            · intro ha
              by_cases ha₁ : a ∈ w₁
              · exact Or.inl ha₁
              · exact Or.inr ⟨ha, ha₁⟩
            · intro ha
              cases ha with
              | inl ha₁ => exact h ha₁
              | inr ha₂ => exact ha₂.1
          calc
            E.measureOf' w₂
                = E.measureOf' (w₁ ∪ (w₂ \ w₁)) := by simpa [this]
            _ = E.measureOf' w₁ + E.measureOf' (w₂ \ w₁) := by
                  simpa using E.m_Union' hw₁ hw₂diff hdiff
        have :
            ‖E.measureOf' w₁ x‖ ≤ ‖E.measureOf' w₂ x‖ := by
          have :
              E.measureOf' w₂ x = E.measureOf' w₁ x + E.measureOf' (w₂ \ w₁) x := by
            simpa [hproj, map_add] using congrArg (fun p => p x) hproj
          calc
            ‖E.measureOf' w₁ x‖
                = ‖E.measureOf' w₁ x + 0‖ := by simp
            _ ≤ ‖E.measureOf' w₁ x + E.measureOf' (w₂ \ w₁) x‖ := by
                  simpa using norm_add_le (E.measureOf' w₁ x) (E.measureOf' (w₂ \ w₁) x)
            _ = ‖E.measureOf' w₂ x‖ := by simpa [this]
        exact this
