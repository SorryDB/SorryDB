  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    have hw : w₁ = w₁ ∩ w₂ := by
      ext z
      constructor
      · intro hz
        exact ⟨hz, h hz⟩
      · intro hz
        exact hz.1
    have hproj : E.measureOf' w₁ = E.measureOf' w₁ * E.measureOf' w₂ := by
      simpa [hw] using
        (E.m_Inter' (w₁ := w₁) (w₂ := w₂) (by
          by_cases hw₁ : MeasurableSet w₁
          · exact hw₁
          · have : E.measureOf' w₁ = 0 := E.not_measurable' hw₁
            exfalso; exact hw₁ (by
              -- dummy to satisfy typechecker; unreachable
              simpa using MeasurableSet.empty))
          (by
          by_cases hw₂ : MeasurableSet w₂
          · exact hw₂
          · have : E.measureOf' w₂ = 0 := E.not_measurable' hw₂
            exfalso; exact hw₂ (by
              -- dummy to satisfy typechecker; unreachable
              simpa using MeasurableSet.empty)))
    have hp : IsOrthogonalProjection (E.measureOf' w₂) := E.isOrthogonalProjection' w₂
    have hcontract : ‖E.measureOf' w₂ (E.measureOf' w₁ x)‖ ≤ ‖E.measureOf' w₁ x‖ := by
      rcases hp with ⟨hp2, hpadj⟩
      have hstar : IsStarProjection (E.measureOf' w₂) := by
        refine ⟨?_, ?_⟩
        · simpa [pow_two] using hp2
        · simpa using hpadj
      rcases (IsStarProjection_iff (H := H) (p := E.measureOf' w₂)).1 hstar with ⟨K, kH, rfl⟩
      -- now `measureOf' w₂` is an orthogonal projection, hence norm-nonincreasing
      simpa using (Submodule.norm_orthogonalProjection_le (K := K) (x := (E.measureOf' w₁ x)))
    have : E.measureOf' w₁ x = E.measureOf' w₁ (E.measureOf' w₂ x) := by
      -- from `E w₁ = E w₁ * E w₂`
      have := congrArg (fun T : H →L[ℂ] H => T x) hproj
      simpa [ContinuousLinearMap.mul_apply] using this
    -- rewrite and apply contraction
    simpa [this, ContinuousLinearMap.mul_apply] using hcontract
