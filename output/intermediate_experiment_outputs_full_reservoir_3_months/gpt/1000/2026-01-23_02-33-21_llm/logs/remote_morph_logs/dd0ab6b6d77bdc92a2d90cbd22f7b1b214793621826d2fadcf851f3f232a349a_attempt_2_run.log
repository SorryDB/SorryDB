def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    have h₁ : w₁ = w₁ ∩ w₂ := by
      ext a
      constructor
      · intro ha
        exact ⟨ha, h ha⟩
      · intro ha
        exact ha.1
    have h₂ : IsOrthogonalProjection (E.measureOf' w₂) := E.isOrthogonalProjection' w₂
    have hproj : (E.measureOf' w₂) ^ 2 = E.measureOf' w₂ := by
      simpa [pow_two] using congrArg (fun p => p) h₂.1.symm
    have hinter : E.measureOf' w₁ = E.measureOf' w₁ * E.measureOf' w₂ := by
      by_cases hw₁ : MeasurableSet w₁
      · by_cases hw₂ : MeasurableSet w₂
        ·
          calc
            E.measureOf' w₁ = E.measureOf' (w₁ ∩ w₂) := by simpa [h₁]
            _ = E.measureOf' w₁ * E.measureOf' w₂ := by simpa using E.m_Inter' hw₁ hw₂
        ·
          have : E.measureOf' w₂ = 0 := E.not_measurable' hw₂
          simp [this]
      ·
        have : E.measureOf' w₁ = 0 := E.not_measurable' hw₁
        simp [this]
    have : ‖E.measureOf' w₁ x‖ ≤ ‖E.measureOf' w₂ (E.measureOf' w₁ x)‖ := by
      -- use `hinter` rewritten as `E(w₂)(E(w₁)x)=E(w₁)x` and contractivity of projections
      have hx :
          E.measureOf' w₂ (E.measureOf' w₁ x) = E.measureOf' w₁ x := by
        -- apply both sides of `hinter` to `x`
        have := congrArg (fun T : H →L[ℂ] H => T x) hinter.symm
        simpa [ContinuousLinearMap.mul_apply] using this
      -- `E.measureOf' w₂` is an orthogonal projection, hence has operator norm ≤ 1
      have hn : ‖E.measureOf' w₂ (E.measureOf' w₁ x)‖ ≤ ‖E.measureOf' w₁ x‖ := by
        -- from `p = p^2 ∧ p = p†` we get `IsStarProjection p`
        have hstar : IsStarProjection (E.measureOf' w₂) := by
          refine ⟨?_, ?_⟩
          ·
            -- idempotent
            simpa [pow_two] using h₂.1.symm
          ·
            -- selfadjoint
            simpa using h₂.2
        rcases (IsStarProjection_iff (H := H) (p := E.measureOf' w₂)).1 hstar with ⟨K, kH, rfl⟩
        -- contractivity of `orthogonalProjection`
        simpa using (Submodule.norm_orthogonalProjection_le (K := K) (x := (E.measureOf' w₁ x)))
      simpa [hx] using hn
    -- now `E(w₁)x` is in the range of the projection `E(w₂)` so its norm is ≤ ‖E(w₂)x‖
    have hstar : IsStarProjection (E.measureOf' w₂) := by
      refine ⟨?_, ?_⟩
      · simpa [pow_two] using h₂.1.symm
      · simpa using h₂.2
    rcases (IsStarProjection_iff (H := H) (p := E.measureOf' w₂)).1 hstar with ⟨K, kH, hp⟩
    -- identify `E(w₂)` with `orthogonalProjection` to use Pythagoras
    subst hp
    -- `E(w₁) = E(w₁) * E(w₂)` implies `E(w₁)x` lies in `K`
    have hxK :
        (K.subtypeL.comp (@K.orthogonalProjection _ _ _ _ _ kH)) (E.measureOf' w₁ x) =
          E.measureOf' w₁ x := by
      -- this is exactly the equation `E(w₂)(E(w₁)x)=E(w₁)x`
      have hx :
          (K.subtypeL.comp (@K.orthogonalProjection _ _ _ _ _ kH)) (E.measureOf' w₁ x) =
            E.measureOf' w₁ x := by
        -- same as above
        have := congrArg (fun T : H →L[ℂ] H => T x) (hinter.symm)
        simpa [ContinuousLinearMap.mul_apply] using this
      simpa using hx
    -- now compare norms using `orthogonalProjection` contractive and idempotent on range
    have hnproj :
        ‖E.measureOf' w₁ x‖ ≤ ‖(K.subtypeL.comp (@K.orthogonalProjection _ _ _ _ _ kH)) x‖ := by
      -- use characterization as projection onto `K` and the fact `E(w₁)x` is fixed by it
      have hle :
          ‖(K.subtypeL.comp (@K.orthogonalProjection _ _ _ _ _ kH)) (E.measureOf' w₁ x)‖ ≤
            ‖(K.subtypeL.comp (@K.orthogonalProjection _ _ _ _ _ kH)) x‖ := by
        -- use `‖P u‖ ≤ ‖P x‖` where `u = P u` and `P` is orthogonal projection: apply `Submodule.norm_orthogonalProjection_le` to `x - u`
        have hP : (K.subtypeL.comp (@K.orthogonalProjection _ _ _ _ _ kH)) (E.measureOf' w₁ x) =
            E.measureOf' w₁ x := hxK
        -- use `‖u‖ ≤ ‖P x‖` since `u` is in the range and `P x` is best approximation
        -- `Submodule.norm_subtype_orthogonalProjection_subtype_le` not available; use inequality `‖u‖ ≤ ‖P x‖` from `‖x - u‖ ≥ ‖x - P x‖`
        -- implement via `by classical` and `simp` with `Submodule.norm_orthogonalProjection_sub_le`:
        classical
        -- `‖x - u‖ ≥ ‖x - P x‖` implies by choosing `x = 0` and `u = u - P x`? too hard; instead use `‖P u‖ ≤ ‖u‖` twice:
        -- `‖u‖ = ‖P u‖ ≤ ‖u‖` doesn't help; we use linearity with triangle:
        -- `‖u‖ = ‖P u‖ = ‖P (x - (x - u))‖ ≤ ‖P x‖ + ‖P (x - u)‖ ≤ ‖P x‖ + ‖x - u‖` and then use `‖x - u‖ ≥ 0`
        -- giving `‖u‖ ≤ ‖P x‖ + ‖x - u‖`, not enough.
        -- fallback: use operator norm bound: `‖P(E(w₁)x)‖ ≤ ‖P‖*‖E(w₁)x‖` and `‖P‖ ≤ 1` gives ≤ ‖E(w₁)x‖.
        -- So just use `‖E(w₁)x‖ ≤ ‖P x‖` from the earlier `this` chain.
        simpa [hP] using (le_of_eq (rfl : ‖E.measureOf' w₁ x‖ = ‖E.measureOf' w₁ x‖))
      simpa using hle
    simpa using hnproj
