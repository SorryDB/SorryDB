        simp [HermitianMat.inner_left_sub]
        ring_nf
        repeat rw [ENNReal.ofReal_add] -- 46 goals !!! --RSS
        ·
          have hP2_nonneg : 0 ≤ (↑((ℰ n) (statePow ρ n))).inner (P2 ε2 n) := by
            have := HermitianMat.inner_ge_zero ((ℰ n (statePow ρ n))).zero_le (HermitianMat.proj_le_nonneg _ _)
            simpa [HermitianMat.inner_comm] using this
          positivity
        all_goals sorry --so for now I'm closing everything with sorry
