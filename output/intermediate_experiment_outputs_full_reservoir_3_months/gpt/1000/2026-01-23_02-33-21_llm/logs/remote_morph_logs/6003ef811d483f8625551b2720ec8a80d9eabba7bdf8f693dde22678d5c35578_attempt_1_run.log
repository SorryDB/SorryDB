@[blueprint
  "fks-corollary_2_3"
  (title := "FKS Corollary 2.3")
  (statement := /-- For each pair $T_0,S_0$ in Table 1 we have, for all $V > T_0$, $\sum_{0 < \gamma < V} 1/\gamma < S_0 + B_1(T_0,V)$. -/)]
theorem corollary_2_3 (I : Inputs) {V : ℝ} (hV : V > I.T₀) : riemannZeta.zeroes_sum Set.univ (Set.Ioo 0 V) (fun ρ ↦ 1 / ρ.im) < I.S₀ + I.B₁ I.T₀ V := by
  have hsum0 : riemannZeta.zeroes_sum Set.univ (Set.Ioo 0 I.T₀) (fun ρ ↦ 1 / ρ.im) < I.S₀ := I.hS₀T₀
  have hU : I.T₀ ≥ 1 := by
    have : (I.T₀ : ℝ) > 0 := lt_trans (by linarith) hV
    linarith
  have hVU : V ≥ I.T₀ := le_of_lt hV
  have hsumUV : riemannZeta.zeroes_sum Set.univ (Set.Ico I.T₀ V) (fun ρ ↦ 1 / ρ.im) ≤ I.B₁ I.T₀ V :=
    lemma_2_1 I (U := I.T₀) (V := V) hU hVU
  have hdecomp :
      riemannZeta.zeroes_sum Set.univ (Set.Ioo 0 V) (fun ρ ↦ 1 / ρ.im)
        =
      riemannZeta.zeroes_sum Set.univ (Set.Ioo 0 I.T₀) (fun ρ ↦ 1 / ρ.im)
        +
      riemannZeta.zeroes_sum Set.univ (Set.Ico I.T₀ V) (fun ρ ↦ 1 / ρ.im) := by
    simpa [Set.Ioo, Set.Ico, add_comm, add_left_comm, add_assoc] using
      (riemannZeta.zeroes_sum_Ioo_eq_add_Ioo_Ico (U := (0 : ℝ)) (T := I.T₀) (V := V) (by linarith) hVU)
  have hsum : riemannZeta.zeroes_sum Set.univ (Set.Ioo 0 V) (fun ρ ↦ 1 / ρ.im) <
      I.S₀ + I.B₁ I.T₀ V := by
    have := add_lt_add_of_lt_of_le hsum0 hsumUV
    simpa [hdecomp, add_assoc, add_left_comm, add_comm] using this
  exact hsum
