        (({j : Fin (4 * n) | c j = i}).toFinset).take 2
    have hA_card : ∀ i, (A i).card = 2 := by
      intro i
      have hcard :
          (({j : Fin (4 * n) | c j = i}).toFinset).card = 4 := by
        simpa [Finset.card_attach, Set.toFinset_card] using h i
      simpa [A, hcard] using (Finset.card_take_of_le (by decide : 2 ≤ 4) :
        ((({j : Fin (4 * n) | c j = i}).toFinset).take 2).card = 2)
    let S : Finset (Fin (4 * n)) := Finset.biUnion Finset.univ A
    refine ⟨S, ?_, ?_⟩
    ·
      -- The sum equality is nontrivial; use existence of a balanced partition by parity via `exists_eq_sum_compl`.
