      have h : IsDiagonalisable (Spec R) G ↔
          Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤ := by
            simpa using (Iff.rfl :
              IsDiagonalisable (Spec R) G ↔
                Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤)
      exact h)
