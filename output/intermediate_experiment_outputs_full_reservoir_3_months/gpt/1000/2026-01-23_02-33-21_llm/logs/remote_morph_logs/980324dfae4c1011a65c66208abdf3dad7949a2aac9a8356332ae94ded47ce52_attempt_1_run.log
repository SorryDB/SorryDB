def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    exfalso
    have hIMax : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
      intro J hJ hIJ
      have : J = I := by
        apply le_antisymm
        · exact hIJ
        · by_contra hlt
          exact hImax ⟨J, hJ, hIJ, hlt⟩
      simpa [this]
    exact hImax hIMax
