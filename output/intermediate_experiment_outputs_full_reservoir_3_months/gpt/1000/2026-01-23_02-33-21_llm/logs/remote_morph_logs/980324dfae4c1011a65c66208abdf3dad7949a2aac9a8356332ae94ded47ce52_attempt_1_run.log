          refine ⟨hI', ?_⟩
          intro J hJ hIJ
          have : B ⊆ J := by
            -- since B is maximal, any independent superset of B equals B, hence B ⊆ J
            by_contra hnot
            have : B ⊂ J := ⟨(by
              intro x hxB
              have : x ∈ I := by
                have : B ⊆ I := by
                  intro y hyB
                  exact (hsub hyB)
                exact this hxB
              exact hIJ this), (by
              obtain ⟨x, hxJ, hxB⟩ := not_subset.mp (by
                intro hBJ
                exact hnot hBJ)
              exact ⟨x, hxJ, hxB⟩)⟩
