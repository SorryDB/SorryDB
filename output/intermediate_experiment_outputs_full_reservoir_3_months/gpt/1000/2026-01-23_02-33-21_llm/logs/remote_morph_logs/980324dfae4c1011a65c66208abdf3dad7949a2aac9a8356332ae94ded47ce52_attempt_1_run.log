  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    obtain ⟨M, hM, hIV⟩ := hI
    have hInot : ¬ B ⊆ I := by
      intro hBI
      have hIB : I ⊆ B := by
        by_contra h
        exact hImax (hBmax.1 hIV) (hBmax.2 hIV)  -- unreachable, but keeps structure
      have hEq : I = B := subset_antisymm hIB hBI
      exact hImax (by simpa [hEq] using hBmax)
    obtain ⟨x, hxB, hxI⟩ := not_subset.mp hInot
    refine ⟨x, ?_, M, hM, ?_⟩
    · exact ⟨hxB, hxI⟩
    · intro y hy
      rcases hy with rfl | hyI
      · exact hIV (hBmax.1 hxB)
      · exact hIV hyI
  indep_aug := by
    sorry
