def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    have hI' : I ⊆ V(G) := by
      rcases hI with ⟨M, hM, hsub⟩
      exact hsub.trans (by simpa [V_edges_subset] using V_edges_subset (G := G) (M := M))
    by_contra hno
    have hMaxI : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
      refine ⟨hI, ?_⟩
      intro J hJ hIJ
      by_contra hne
      have : ∃ x, x ∈ J \ I := by
        have hnot : ¬ J ⊆ I := by
          intro hJI
          exact hne (le_antisymm hJI hIJ)
        exact not_subset.mp hnot
      rcases this with ⟨x, hx⟩
      have hxJ : x ∈ J := hx.1
      have hxI : x ∉ I := hx.2
      have hxnot : ¬ (∃ M, G.IsMatching M ∧ insert x I ⊆ V(G, M)) := by
        intro hex
        refine hno ⟨x, ?_, hex⟩
        refine ⟨?_, hxI⟩
        have : x ∈ J := hxJ
        exact this
      have hix : ¬ (∃ M, G.IsMatching M ∧ insert x I ⊆ V(G, M)) := hxnot
      have hIin : (∃ M, G.IsMatching M ∧ I ⊆ V(G, M)) := hI
      have hJIin : (∃ M, G.IsMatching M ∧ J ⊆ V(G, M)) := hJ
      have : False := by
        exact hix (by
          rcases hJIin with ⟨M, hM, hJV⟩
          refine ⟨M, hM, ?_⟩
          intro y hy
          rcases hy with rfl | hyI
          · exact hJV hxJ
          · exact hJV (hIJ hyI))
      exact (this.elim)
    exact hImax hMaxI
