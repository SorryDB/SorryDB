def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    have hBI : B ⊆ V(G) := by
      rcases hBmax.1 with ⟨M, hM, hBM⟩
      exact (hBM.trans <| by
        intro v hv
        exact (Graph.V_subset _ _ hv))
    have hInB : I ⊆ B := by
      by_contra hsub
      have hproper : I ⊂ B := by
        refine ⟨?_, ?_⟩
        · intro x hxI
          by_contra hxB
          exact hsub (by
            intro y hyI
            exact hyI) -- unreachable
        · exact hsub
      exact hImax (hBmax.1) hproper
    by_contra hex
    have hmaxI : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
      refine ⟨hI, ?_⟩
      intro J hJ hIJ
      have hJBI : J ⊆ B := by
        intro x hxJ
        by_contra hxB
        have hxBI : x ∈ B \ I := by
          refine ⟨?_, ?_⟩
          · exact (hBI <| hJ.1.choose.subset (hJ.1.choose_spec.1 hxJ))
          · exact fun hxI => hxB (hInB hxI)
        have : ∃ x ∈ B \ I, ∃ M, G.IsMatching M ∧ insert x I ⊆ V(G, M) := by
          refine ⟨x, hxBI, ?_⟩
          rcases hJ with ⟨M, hM, hJV⟩
          refine ⟨M, hM, ?_⟩
          intro y hy
          rcases Set.mem_insert_iff.1 hy with rfl | hyI
          · exact hJV hxJ
          · exact hJV (hIJ hyI)
        exact hex this
      have hJIb : J ⊆ I := by
        intro x hxJ
        by_contra hxI
        have hxBI : x ∈ B \ I := ⟨hJBI hxJ, hxI⟩
        rcases hJ with ⟨M, hM, hJV⟩
        have : ∃ x ∈ B \ I, ∃ M, G.IsMatching M ∧ insert x I ⊆ V(G, M) := by
          refine ⟨x, hxBI, M, hM, ?_⟩
          intro y hy
          rcases Set.mem_insert_iff.1 hy with rfl | hyI
          · exact hJV hxJ
          · exact hJV (hIJ hyI)
        exact hex this
      exact Set.eq_of_subset_of_subset hIJ hJIb
    exact hImax.ne hImax
