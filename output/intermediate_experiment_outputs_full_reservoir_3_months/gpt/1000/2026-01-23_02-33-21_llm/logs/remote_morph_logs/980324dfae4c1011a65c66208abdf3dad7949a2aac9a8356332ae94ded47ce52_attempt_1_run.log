    intro I B hI hImax hBmax
    classical
    obtain ⟨M, hM, hIsub⟩ := hI
    have hInmax : ¬ Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := hImax
    have hIlt : ¬ (∀ x ∈ B \ I, False) := by
      intro hno
      have hBI : B ⊆ I := by
        intro x hxB
        by_contra hxI
        have : x ∈ B \ I := ⟨hxB, hxI⟩
        exact hno x this
      have hIB : I ⊆ B := by
        intro x hxI'
        have hIind : ∃ M, G.IsMatching M ∧ I ⊆ V(G, M) := ⟨M, hM, hIsub⟩
        have hBind : ∃ M, G.IsMatching M ∧ B ⊆ V(G, M) := by
          have := (hBmax.1)
          exact this
        -- maximality of B gives I ⊆ B since I is independent and B is maximal independent
        -- Use Maximal property directly
        have hBmax' := hBmax.2
        have hBmem : (∃ M, G.IsMatching M ∧ B ⊆ V(G, M)) := hBmax.1
        have hIin : (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := hIind
        have hBI' : B ⊆ I := hBI
        have : I = B := by
          apply le_antisymm
          · exact hBI'
          · intro x hxI
            by_contra hxB
            have hproper : B ⊂ I := ⟨hBI', by
              refine ⟨x, ?_, ?_⟩
              · exact hxI
              · exact hxB⟩
            have hIind' : (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := hIind
            exact (hBmax'.1 hIind' hproper).elim
        simpa [this]
      have hEq : B = I := Set.Subset.antisymm hBI hIB
      have hImax' : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
        refine ⟨⟨M, hM, hIsub⟩, ?_⟩
        intro J hJ hIJ
        have hJ' : B ⊆ J := by
          simpa [hEq] using hIJ
        have hBmax' := hBmax.2
        have hBJ : B ⊂ J := by
          refine ⟨hJ', hIJ.2⟩
        have : J = B := hBmax'.1 hJ hBJ
        simpa [hEq, this]
      exact hInmax hImax'
    obtain ⟨x, hx⟩ := Set.nonempty_iff_ne_empty.mp (by
      by_contra h
      apply hIlt
      intro x hxBI
      exact False.elim (by
        have : (B \ I) = ∅ := Set.eq_empty_iff_forall_not_mem.mp h
        exact (this ▸ hxBI).elim))
    refine ⟨x, ?_, M, hM, ?_⟩
    · exact hx
    · intro y hy
      rcases hy with rfl | hyI
      · exact hIsub (hx.1)
      · exact hIsub hyI
