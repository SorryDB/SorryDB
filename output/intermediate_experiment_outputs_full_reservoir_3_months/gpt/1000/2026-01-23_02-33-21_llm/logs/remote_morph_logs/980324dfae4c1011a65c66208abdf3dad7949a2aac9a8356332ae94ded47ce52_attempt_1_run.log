def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    have hB : ∃ M, G.IsMatching M ∧ B ⊆ V(G, M) := by
      simpa [Maximal] using (hBmax.1)
    obtain ⟨MI, hMI, hIsub⟩ := hI
    obtain ⟨MB, hMB, hBsub⟩ := hB
    by_contra hcontra
    have hBI : B ⊆ I := by
      intro x hxB
      by_contra hxI
      have hxmem : x ∈ B \ I := ⟨hxB, hxI⟩
      rcases hcontra x hxmem with ⟨M, hM, hIns⟩
      exact hxI (hIns (by simp))
