def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    have hBI : ¬ B ⊆ I := by
      intro hsub
      apply hImax
      refine ⟨B, ?_, ?_, ?_⟩
      · exact hBmax.1
      · exact hsub
      · exact hBmax.2
    obtain ⟨x, hxB, hxI⟩ := not_subset.mp hBI
    refine ⟨x, ⟨hxB, hxI⟩, ?_⟩
    rcases hI with ⟨M, hM, hIsub⟩
    refine ⟨M, hM, ?_⟩
    intro y hy
    rcases Set.mem_insert_iff.mp hy with rfl | hyI
    · exact (hBmax.2 hxB)
    · exact hIsub hyI
