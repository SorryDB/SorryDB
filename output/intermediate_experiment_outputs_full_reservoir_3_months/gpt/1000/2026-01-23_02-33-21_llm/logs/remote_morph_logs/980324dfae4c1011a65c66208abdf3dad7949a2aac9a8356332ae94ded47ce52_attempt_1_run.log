def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    by_contra hcontra
    have hBI : B ⊆ I := by
      intro x hxB
      by_contra hxI
      have hx : x ∈ B \ I := ⟨hxB, hxI⟩
      exact hcontra ⟨x, hx, hBmax.prop x hxB⟩
    have hImax' : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
      refine ⟨hI, ?_⟩
      intro J hJ hIJ
      have hJI : J ⊆ I := by
        intro x hxJ
        have hxV : x ∈ V(G) := by
          rcases hJ with ⟨M, hM, hJV⟩
          exact (hM.subset (hJV hxJ)).1
        have hxJIB : x ∈ J \ I ∨ x ∈ I := by
          by_cases hxI : x ∈ I
          · exact Or.inr hxI
          · exact Or.inl ⟨hxJ, hxI⟩
        cases hxJIB with
        | inr hxI => exact hxI
        | inl hxJI =>
          have hxB : x ∈ B := by
            have : x ∈ I := hBI ?_
            · exact False.elim (hxJI.2 this)
            · have : x ∈ I := hIJ hxJ
              exact False.elim (hxJI.2 this)
          exact False.elim (hxJI.2 (hBI hxB))
      exact subset_antisymm hJI hIJ
    exact hImax hImax'
