def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    have hBI : B ⊄ I := by
      intro hsub
      have : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I :=
        ⟨hI, fun J hJ hIJ => by
          have hBJ : B ⊆ J := by
            by_contra hnot
            exact (hBmax.2 J hJ (le_of_not_ge hnot)).not_lt (lt_of_le_of_ne ?_ ?_)
          · exact le_trans hsub hIJ
          · exact ne_of_lt (lt_of_le_of_ne (le_trans hsub hIJ) (by
              intro hEq; exact hnot (by simpa [hEq])))
        ⟩
      exact hImax this
    obtain ⟨x, hxB, hxI⟩ := not_subset.mp hBI
    refine ⟨x, ?_, ?_⟩
    · exact ⟨hxB, hxI⟩
    ·
      by_contra hno
      have hImax' : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I :=
        ⟨hI, fun J hJ hIJ => by
          by_contra hlt
          have hne : J ≠ I := ne_of_gt (lt_of_le_of_ne hIJ (Ne.symm (ne_of_not_ge hlt)))
          have hss : I ⊂ J := lt_of_le_of_ne hIJ hne
          have : ∃ y, y ∈ J \ I := by
            rcases exists_of_ssubset hss with ⟨y, hyJ, hyI⟩
            exact ⟨y, ⟨hyJ, hyI⟩⟩
          rcases this with ⟨y, hy⟩
          have : ∃ M, G.IsMatching M ∧ insert y I ⊆ V(G, M) := by
            have : insert y I ⊆ J := by
              intro z hz
              rcases hz with rfl | hzI
              · exact hy.1
              · exact hIJ hzI
            rcases hJ with ⟨MJ, hMJ, hJsub⟩
            exact ⟨MJ, hMJ, subset_trans this hJsub⟩
          exact hno ⟨y, hy, this⟩⟩
      exact hImax hImax'
