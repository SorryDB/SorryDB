/-- If `C` is sifted, the `colim` functor `(C ⥤ Type) ⥤ Type` preserves finite products.
Taken from mathlib PR #17781.
TODO: generalise the universe levels of `IsSifted.colim_preservesFiniteProducts_of_isSifted` so it
can replace this. -/
instance colimPreservesFiniteProductsOfIsSifted {C : Type u} [Category.{v} C] :
    PreservesFiniteProducts (colim : (C ⥤ _) ⥤ Type max u w) := by
  classical
  let e : (C ⥤ Type max u w) ≌ (C ⥤ Type v) :=
    (Functor.congrRight (Type.uliftEquiv.{max u w, v}).functor).trans
      (Functor.mapEquiv (Type.uliftEquiv.{max u w, v}).inverse).symm
  refine preservesFiniteProducts_of_equiv e (F := (colim : (C ⥤ Type max u w) ⥤ Type max u w))
    (G := (colim : (C ⥤ Type v) ⥤ Type v)) ?_
  simpa using (IsSifted.colim_preservesFiniteProducts_of_isSifted (C := C) (w := v))
```
