namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · sorry
  · constructor
    · intro hp
      -- TODO: figure out how to easily write `use 1` here to follow more closely the book
      aesop
    · refine ⟨0, ?_⟩
      intro hp
      have : False := by
        have h2 : 2 ∣ p := by
          refine ⟨2 * 0, ?_⟩
          simpa [hp, two_mul, add_assoc, add_left_comm, add_comm, mul_assoc, mul_left_comm,
            mul_comm]
        have hp2 : p = 2 := (h.out.eq_of_dvd_of_dvd (Nat.Prime.two_dvd_iff.mp h2)
          (Nat.dvd_refl p)).symm
        have : (4 * 0 + 1 : ℕ) = 1 := by simp
        have : p = 1 := by simpa [hp2] using congrArg id (by simpa [hp] using this)
        exact Nat.ne_of_gt h.out.one_lt this
      exact (this.elim)
