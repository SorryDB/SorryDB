lemma of_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∈ construction_omega T hT) :
  (χ ➝ φ ∈ T.theory) ∨ (∀ Γ : Finset _, ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory) := by
  obtain ⟨i, hi⟩ := by simpa [construction_omega] using hφ;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
    dsimp [construction] at hi;
    by_cases hdec : decode i = some φ
    · have henc : encode φ = i := by
        have := congrArg encode hdec
        simpa using this
      subst henc
      cases hif : (∀ Γ : Finset (Formula ℕ), (↑Γ ⊆ construction T hT (encode φ)) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory) with
      | _ =>
        simp [hdec, hif] at hi
        rcases hi with hmem | rfl
        · exact ih hmem
        · right; simpa using hif
    · have : φ ∈ construction T hT i := by
        simpa [construction, hdec] using hi
      exact ih this
