lemma iIndepFun_rewardByCount [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) :
    iIndepFun (fun (p : α × ℕ) ↦ rewardByCount A R p.1 (p.2 + 1)) 𝔓' := by
  classical
  -- `rewardByCount A R a (n+1)` is independent across `n` for each fixed `a`,
  -- and for different `a` the variables depend on disjoint coordinates of the stream measure.
  -- Hence the whole family indexed by `α × ℕ` is independent.
  refine iIndepFun_of_forall_finite_subtype ?_
  intro s hs
  classical
  -- Reduce to independence of a finite family; use pairwise independence coming from disjoint
  -- stream coordinates together with independence in `Ω` part already handled in `rewardByCount`.
  -- We can pull back along the second projection to use `iIndepFun_rewardByCount'` for each `a`
  -- and then combine across distinct `a` using independence of coordinates of `streamMeasure`.
  simpa [iIndepFun, hs] using (iIndepFun_pi_iff.mp (by
    intro a
    simpa using iIndepFun_rewardByCount' (A := A) (R := R) (P := P) (alg := alg) (ν := ν) h a)).1 s
