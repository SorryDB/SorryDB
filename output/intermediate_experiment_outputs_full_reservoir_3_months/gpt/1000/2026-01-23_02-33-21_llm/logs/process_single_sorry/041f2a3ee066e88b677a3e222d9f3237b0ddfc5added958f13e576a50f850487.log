                            -- thus right element at idx2 is x; erase that and erase head left
                            have := hPerm_ih (idx1 := ⟨idx2.1, by
                              simpa [List.length_cons] using idx2.2⟩) (idx2 := ⟨0, by simp⟩)
                            have h' : l1[⟨idx2.1, by simpa [List.length_cons] using idx2.2⟩] = (hd :: tl)[⟨0, by simp⟩] := by
                              simp
                            have hp := this h'
                            simpa using (List.Perm.symm hp)
            | succ idx1 =>
                cases idx2 using Fin.cases with
                | zero =>
                    have hx : (x :: l1)[⟨idx1, by
                      simpa [List.length_cons] using idx1.2⟩] = x := by
                        simpa using hEq
                    simp at hx
                | succ idx2 =>
                    have := hPerm_ih (idx1 := ⟨idx1.1, by
                      simpa [List.length_cons] using idx1.2⟩)
                                     (idx2 := ⟨idx2.1, by
                      simpa [List.length_cons] using idx2.2⟩)
                    have h' :
                      l1[⟨idx1.1, by simpa [List.length_cons] using idx1.2⟩] =
                      l2[⟨idx2.1, by simpa [List.length_cons] using idx2.2⟩] := by
                        simpa using hEq
                    have hp := this h'
                    simpa using hp
        | swap x y l =>
            intro idx1 idx2 hEq
            -- analyze indices in the two swapped lists
            cases idx1 using Fin.cases with
            | zero =>
                cases idx2 using Fin.cases with
                | zero =>
                    simp at hEq
                | succ idx2 =>
                    cases idx2 using Fin.cases with
                    | zero =>
                        -- idx2 = 1
                        simp at hEq
                        subst hEq
                        simp
                    | succ idx2' =>
                        -- idx2 >= 2, points into l
                        have : (x :: y :: l)[Fin.succ (Fin.succ idx2')] = l[idx2'] := by
                          simp
                        have hxy : y = l[idx2'] := by
                          simpa [this] using hEq
                        -- impossible: y equals some element of l, but still Perm holds after erasing
                        -- both sides erase y at head/that position -> both become x :: l.eraseIdx idx2'
                        simp [List.eraseIdx, hxy]
            | succ idx1 =>
                cases idx1 using Fin.cases with
                | zero =>
                    -- idx1 = 1
                    cases idx2 using Fin.cases with
                    | zero =>
                        simp at hEq
                        subst hEq
                        simp
                    | succ idx2 =>
                        cases idx2 using Fin.cases with
                        | zero =>
                            -- idx2 = 1
                            simp at hEq
                        | succ idx2' =>
                            have : (x :: y :: l)[Fin.succ (Fin.succ idx2')] = l[idx2'] := by
                              simp
                            have hxy : x = l[idx2'] := by
                              simpa [this] using hEq
                            simp [List.eraseIdx, hxy]
                | succ idx1' =>
                    -- idx1 >= 2, points into l
                    cases idx2 using Fin.cases with
                    | zero =>
                        have : (y :: x :: l)[Fin.succ (Fin.succ idx1')] = l[idx1'] := by
                          simp
                        have hxy : l[idx1'] = x := by
                          simpa [this] using hEq
                        simp [List.eraseIdx, hxy]
                    | succ idx2 =>
                        cases idx2 using Fin.cases with
                        | zero =>
                            have : (y :: x :: l)[Fin.succ (Fin.succ idx1')] = l[idx1'] := by
                              simp
                            have hxy : l[idx1'] = y := by
                              simpa [this] using hEq
                            simp [List.eraseIdx, hxy]
                        | succ idx2' =>
                            -- both indices in l, so just erase corresponding entries; swap doesn't matter
                            have : (y :: x :: l)[Fin.succ (Fin.succ idx1')] = l[idx1'] := by
                              simp
                            have : (x :: y :: l)[Fin.succ (Fin.succ idx2')] = l[idx2'] := by
                              simp
                            have hll : l[idx1'] = l[idx2'] := by
                              simpa [this] using hEq
                            subst hll
                            -- both sides erase the same element from l; heads are swapped but persist
                            -- after erasing inside l, both lists are perm by swap
                            simp [List.eraseIdx]
