     theorem perm_eraseIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
      {idx1 : Fin l1.length} {idx2 : Fin l2.length} :
      l1[idx1] = l2[idx2] → (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2)
      := by
        revert idx1 idx2
        induction hPerm with
        | nil => intro ⟨_, _⟩; contradiction
        | cons x l1 l2 ih =>
            intro idx1 idx2 h
            cases idx1 using Fin.cases with
            | zero =>
                cases idx2 using Fin.cases with
                | zero =>
                    simpa [List.eraseIdx, List.eraseIdx_cons] using ih (idx1 := ⟨0, by simpa⟩) (idx2 := ⟨0, by simpa⟩) (by simpa using h)
                | succ idx2 =>
                    -- x is removed on the left, and must be removed somewhere in x::l2 on the right
                    subst h
                    simpa [List.eraseIdx, List.eraseIdx_cons] using (List.Perm.eraseIdx (List.Perm.cons x (List.Perm.refl l2)) (idx := ⟨idx2.1+1, by simpa using idx2.2⟩))
            | succ idx1 =>
                cases idx2 using Fin.cases with
                | zero =>
                    subst h
                    simpa [List.eraseIdx, List.eraseIdx_cons] using (List.Perm.eraseIdx (List.Perm.cons x (List.Perm.refl l1)) (idx := ⟨idx1.1+1, by simpa using idx1.2⟩)).symm
                | succ idx2 =>
                    have := ih (idx1 := ⟨idx1.1, by simpa using idx1.2⟩) (idx2 := ⟨idx2.1, by simpa using idx2.2⟩)
                      (by simpa [List.getElem_cons_succ] using h)
                    simpa [List.eraseIdx, List.eraseIdx_cons] using List.Perm.cons x this
        | swap x y l =>
            intro idx1 idx2 h
            have hl : (y :: x :: l).Perm (x :: y :: l) := List.Perm.swap _ _ _
            exact List.Perm.eraseIdx_of_getElem_eq hl (by simpa using h)
