      h = id Y ≫ h := by simp
      _ = (g ≫ f) ≫ h := by simpa [Category.IsSection] using congrArg (fun t => t ≫ h) hg₂
      _ = g ≫ (f ≫ h) := by simp [assoc]
      _ = g ≫ (f ≫ k) := by simpa [assoc] using congrArg (fun t => g ≫ t) hk
      _ = (g ≫ f) ≫ k := by simp [assoc]
      _ = id Y ≫ k := by simpa [Category.IsSection] using congrArg (fun t => t ≫ k) hg₂
      _ = k := by simp
