      "\n  have hτ := hX.IsLocalizingSequence\n  have hrc : ∀ n, ∀ ω, Function.RightContinuous\n      ((stoppedProcess (fun i ↦ {ω | ⊥ < hX.localSeq n ω}.indicator (X i)) (hX.localSeq n)) · ω) :=\n    fun n ↦ hX.stoppedProcess n\n  have htop : ∀ᵐ ω ∂P, ∀ n, ⊥ < hX.localSeq n ω := by\n    filter_upwards [hτ.tendsto_top] with ω hω\n    intro n\n    have : ∀ᶠ m in atTop, (hX.localSeq m ω) ∈ {t : WithTop ι | ⊥ < t} := by\n      have hopen : IsOpen ({t : WithTop ι | ⊥ < t} : Set (WithTop ι)) := by\n        simpa [Set.setOf_app_iff] using isOpen_Ioi\n      have hmem : ⊤ ∈ ({t : WithTop ι | ⊥ < t} : Set (WithTop ι)) := by simp\n      exact (hopen.mem_nhds hmem).eventually (hω)\n    rcases (this.and_eventually (hτ.mono)).exists with ⟨m, hmpos, hmono⟩\n    have hle : hX.localSeq n ω ≤ hX.localSeq m ω := hmono n (le_trans (le_max_left _ _) le_rfl)\n    exact lt_of_lt_of_le (by simpa using hmpos) hle\n  filter_upwards [htop] with ω hpos\n  have hst : ∀ n, stoppedProcess (fun i ↦ {ω | ⊥ < hX.localSeq n ω}.indicator (X i))\n      (hX.localSeq n) · ω = X · ω := by\n    intro n\n    funext i\n    have : i ≤ (hX.localSeq n ω).untop := by\n      by_cases htop' : hX.localSeq n ω = ⊤\n      · simp [htop']\n      · have : (hX.localSeq n ω).untop = (Option.get _ (WithTop.ne_top_iff_one.1 htop')).1 := rfl\n        simp\n    have hmem : ω ∈ {ω' | ⊥ < hX.localSeq n ω'} := by simpa using hpos n\n    simp [stoppedProcess, hmem]\n  have hrc' : ∀ n, Function.RightContinuous (X · ω) := by\n    intro n\n    have := hrc n ω\n    simpa [hst n] using this\n  exact hrc' 0",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hτTop : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [hτTop] with ω hωτ\n  intro x\n  by_cases hx : x = ⊥\n  · subst hx\n    simpa using (Function.rightContinuous_const : Function.RightContinuous fun _ : ι => X ⊥ ω)\n  · have hxlt : (x : WithTop ι) < ⊤ := WithTop.coe_lt_top x\n    rcases (WithTop.tendsto_atTop_nhds_top_iff.mp hωτ) x with ⟨n, hn⟩\n    have hnx : (x : WithTop ι) < τ n ω := (hn n le_rfl) hxlt\n    have hmem : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := by\n      have : (⊥ : WithTop ι) < τ n ω := lt_trans (WithTop.bot_lt_coe x) hnx\n      simpa [Set.mem_setOf_eq] using this\n    have hRC := hτX n ω\n    have hxstop :\n        (stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) · ω) x = X x ω := by\n      have hxeq : (x : WithTop ι) ≤ min (τ n ω) x := by\n        simp [hnx.le]\n      simp [stoppedProcess, hxeq, Set.indicator_of_mem hmem]\n    have hEqNear :\n        ∀ᶠ y in 𝓝[>] x,\n          (stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) · ω) y = X y ω := by\n      have : ∀ᶠ y in 𝓝[>] x, (y : WithTop ι) < τ n ω :=\n        (tendsto_principal.1 <| Ioi_mem_nhdsWithin_Ioi.2 hnx).mono (by\n          intro y hy; simpa [Set.mem_setOf_eq] using hy)\n      filter_upwards [this] with y hy\n      have hmem' : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := by\n        have : (⊥ : WithTop ι) < τ n ω := lt_trans (WithTop.bot_lt_coe x) hnx\n        simpa [Set.mem_setOf_eq] using this\n      have hyeq : (y : WithTop ι) ≤ min (τ n ω) y := by simp [hy.le]\n      simp [stoppedProcess, hyeq, Set.indicator_of_mem hmem']\n    have hT :\n        Tendsto (fun y ↦ X y ω) (𝓝[>] x) (𝓝 (X x ω)) := by\n      have hT' :=\n        (hRC x).trans <|\n          (tendsto_congr' hEqNear).trans (by simpa [hxstop])\n      exact hT'\n    have hT2 : Tendsto (fun y ↦ X y ω) (𝓝[≥] x) (𝓝 (X x ω)) := by\n      have : 𝓝[≥] x = 𝓝[>] x ⊔ 𝓟 {x} := by\n        ext s; simp [nhdsWithin_union, nhdsWithin_singleton]\n      rw [this]\n      refine tendsto_sup.2 ?_\n      refine ⟨?_, ?_⟩\n      · exact hT\n      · simpa using (tendsto_principal.2 <| by simp)\n    exact Function.rightContinuous_iff_tendsto.2 hT2",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hst⟩\n  have hTop : ∀ᵐ ω ∂P, Tendsto (fun n ↦ τ n ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [hTop] with ω hω\n  have hω' : Function.RightContinuous (X · ω) := by\n    have htop' : ∀ i : ι, ∃ n, (i : WithTop ι) < τ n ω := by\n      intro i\n      simpa [WithTop.tendsto_atTop_nhds_top_iff] using (hω i)\n    intro i\n    have hrc : Function.RightContinuous\n        (fun x ↦ stoppedProcess (fun j ↦ {ω | ⊥ < τ 0 ω}.indicator (X j)) (τ 0) x ω) := by\n      exact (hst 0) ω\n    have hle : (i : WithTop ι) ≤ τ 0 ω := by\n      by_contra hi\n      have : τ 0 ω < i := lt_of_not_ge hi\n      have := htop' i\n      rcases this with ⟨n, hn⟩\n      exact not_lt_of_lt hn (this.trans_le (le_of_lt this))\n    simpa [stoppedProcess, hle, Set.indicator_of_mem] using hrc i\n  exact hω'",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hτTop := hτ.tendsto_top\n  have hmono := hτ.mono\n  have hrc : ∀ n, ∀ᵐ ω ∂P, Function.RightContinuous (fun t ↦ X (min t (τ n ω)) ω) := by\n    intro n\n    have : ∀ ω, Function.RightContinuous (fun t ↦ (stoppedProcess\n        (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n)) t ω) := hτX n\n    have hrc0 : ∀ᵐ ω ∂P, Function.RightContinuous (fun t ↦ (stoppedProcess\n        (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n)) t ω) :=\n      ae_of_all _ this\n    filter_upwards [hrc0] with ω hω\n    simpa [stoppedProcess, Set.indicator] using hω\n  have hrc_all : ∀ᵐ ω ∂P, ∀ n, Function.RightContinuous (fun t ↦ X (min t (τ n ω)) ω) := by\n    exact ae_all_iff.2 (fun n ↦ hrc n)\n  filter_upwards [hτTop, hmono, hrc_all] with ω hTop hmonoω hrcω\n  have hTop' : Tendsto (τ · ω) atTop (𝓝 (⊤ : WithTop ι)) := hTop\n  have hmin : Tendsto (fun n ↦ min (τ n ω) (⊤ : WithTop ι)) atTop (𝓝 ⊤) := by\n    simpa using hTop'.min tendsto_const_nhds\n  have hTopι : Tendsto (fun n ↦ (τ n ω)) atTop (𝓝 (⊤ : WithTop ι)) := hTop'\n  have hforall : ∀ t : ι, ∃ n, (t : WithTop ι) < τ n ω := by\n    intro t\n    have : (∃ᶠ n in atTop, (t : WithTop ι) < τ n ω) := by\n      simpa [WithTop.tendsto_atTop_nhds_top_iff] using hTop' t\n    rcases (eventually_atTop.1 this) with ⟨n, hn⟩\n    exact ⟨n, hn n le_rfl⟩\n  refine fun t ht => ?_\n  rcases hforall t with ⟨n, hn⟩\n  have hEq : (fun x ↦ X (min x (τ n ω)) ω) = fun x ↦ X x ω := by\n    funext x\n    have : (x : WithTop ι) ≤ τ n ω := by\n      exact le_of_lt (lt_of_le_of_lt (le_coe.2 (le_of_lt (ht x))) hn)\n    simp [min_eq_left_iff, this]\n  simpa [hEq] using (hrcω n) t ht",
