      "\n  classical\n  obtain ⟨τ, hτ, hτX⟩ := hX\n  have hτTop : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [hτTop] with ω hω\n  have hω' : ∀ n, Function.RightContinuous\n      (fun x => stoppedProcess (fun i => {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) x ω) :=\n    hτX · ω\n  rw [WithTop.tendsto_atTop_nhds_top_iff] at hω\n  refine Function.rightContinuous_iff.2 ?_\n  intro i\n  obtain ⟨n, hn⟩ := hω i\n  have hle : (↑i : WithTop ι) ≤ τ n ω := le_of_not_lt hn\n  have hEq :\n      (fun x => X x ω) = fun x =>\n        stoppedProcess (fun i => {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) x ω := by\n    funext x\n    by_cases hx : x ≤ i\n    · have hx' : (x : WithTop ι) ≤ τ n ω := (show (x : WithTop ι) ≤ i from hx).trans hle\n      have hmem : ω ∈ {ω | ⊥ < τ n ω} := by\n        have : (⊥ : WithTop ι) < τ n ω := bot_lt_of_lt_of_le (WithTop.coe_bot_lt _).1\n          ((show (⊥ : ι) ≤ x from bot_le).trans (le_trans hx le_rfl)) |> by\n            exact (WithTop.coe_lt_coe.2 (lt_of_lt_of_le (WithTop.coe_bot_lt _).2 bot_le) )\n        simpa using (WithTop.bot_lt_iff_ne_bot.2 (by\n          have : (⊥ : WithTop ι) < (x : WithTop ι) := WithTop.coe_bot_lt x\n          exact (ne_of_gt (this.trans_le hx')).symm))\n      simp [stoppedProcess, hx', hmem]\n    · have hx' : (τ n ω : WithTop ι) ≤ x := le_trans hle (show (i : WithTop ι) ≤ x from\n        le_of_not_ge (by simpa [not_le] using hx))\n      have hnot : ω ∉ {ω | ⊥ < τ n ω} := by\n        by_contra h\n        have : (⊥ : WithTop ι) < τ n ω := by simpa using h\n        exact not_lt_of_ge (bot_le) this\n      simp [stoppedProcess, hx', hnot]\n  simpa [hEq] using (hω' n).rightContinuousAt i",
      "\n  classical\n  by_cases hP0 : P = 0\n  · subst hP0\n    simpa using (Measure.ae_of_all _ fun ω ↦ hX.stoppedProcess 0 ω)\n  · have hmono : ∀ᵐ ω ∂P, Monotone (hX.localSeq · ω) := hX.IsLocalizingSequence.mono\n    have htop : ∀ᵐ ω ∂P, Tendsto (hX.localSeq · ω) atTop (𝓝 ⊤) :=\n      hX.IsLocalizingSequence.tendsto_top\n    filter_upwards [hmono, htop] with ω hmonoω htopω\n    have hω :\n        ∀ n, Function.RightContinuous\n          (stoppedProcess (fun i ↦ {ω | ⊥ < hX.localSeq n ω}.indicator (X i)) (hX.localSeq n) · ω) :=\n      fun n ↦ hX.stoppedProcess n ω\n    intro x\n    rcases (WithTop.lt_top_iff_ne_top).2 (by simp) with hx\n    have hx' : (x : WithTop ι) < ⊤ := by simpa using hx\n    have hxle : (x : WithTop ι) ≤ ⊤ := le_top\n    rcases (WithTop.tendsto_atTop_nhds_top_iff).1 htopω x with ⟨N, hN⟩\n    have hNx : x < hX.localSeq N ω := by\n      have := hN N le_rfl\n      simpa using this\n    have hmem : ω ∈ {ω | ⊥ < hX.localSeq N ω} := by\n      have : (⊥ : WithTop ι) < hX.localSeq N ω :=\n        lt_of_lt_of_le (by simpa using (bot_lt_iff_ne_bot.2 (by\n          intro hbot\n          have : x < (⊥ : WithTop ι) := by simpa [hbot] using hNx\n          exact (not_lt_bot this)))\n          (le_of_lt hNx)\n      simpa [Set.mem_setOf_eq] using this\n    have hst_eq :\n        (stoppedProcess (fun i ↦ {ω | ⊥ < hX.localSeq N ω}.indicator (X i)) (hX.localSeq N) · ω) =\n          (fun t ↦ X t ω) := by\n      funext t\n      by_cases ht : (t : WithTop ι) ≤ hX.localSeq N ω\n      · simp [stoppedProcess, ht, Set.indicator_of_mem, hmem]\n      · have : ¬ ((t : WithTop ι) ≤ hX.localSeq N ω) := ht\n        simp [stoppedProcess, this, Set.indicator_of_mem, hmem]\n    simpa [hst_eq] using (hω N)",
      "\n  rcases hX with ⟨τ, hτ, hp⟩\n  have hτtop : ∀ᵐ ω ∂P, ∀ n : ℕ, (⊥ : WithTop ι) < τ n ω := by\n    filter_upwards [hτ.tendsto_top] with ω hω\n    intro n\n    have : (⊥ : WithTop ι) < τ n ω := by\n      have hω' := (WithTop.tendsto_atTop_nhds_top_iff.mp hω) ⊥\n      rcases hω' with ⟨N, hN⟩\n      have : ⊥ < τ (max n N) ω := hN (max n N) (le_max_right _ _)\n      exact lt_of_lt_of_le this (hτ.mono.le_iff.1 (hτ.mono (ω := ω) (by\n        have := (hτ.mono).self_of_nhds ?_ ; exact this) )?_)\n    exact this\n  have hmono : ∀ᵐ ω ∂P, Monotone (τ · ω) := hτ.mono\n  filter_upwards [hτtop, hmono] with ω hpos hmonoω\n  have hlim : Tendsto (τ · ω) atTop (𝓝 ⊤) := (hτ.tendsto_top).ae_eq_of_ae_eq (ae_of_all _ fun _ => rfl) |>.mp (by\n    have := (hτ.tendsto_top)\n    exact (by\n      have : Tendsto (τ · ω) atTop (𝓝 ⊤) := by\n        have h := (hτ.tendsto_top)\n        exact (by\n          have := (hτ.tendsto_top)\n          exact (by\n            have : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n            exact (this.self_of_nhds ?_))\n      exact h))\n  have hωtop : ∀ i : ι, ∃ n : ℕ, (i : WithTop ι) ≤ τ n ω := by\n    intro i\n    have h := (WithTop.tendsto_atTop_nhds_top_iff.mp hlim) i\n    rcases h with ⟨n, hn⟩\n    refine ⟨n, ?_⟩\n    exact le_of_lt (hn n le_rfl)\n  have hrc_stopped : ∀ n, Function.RightContinuous fun x => (stoppedProcess\n      (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n)) x ω := by\n    intro n\n    have := hp n ω\n    simpa using this\n  have hrc : ∀ i : ι, Function.RightContinuousAt (fun x => X x ω) i := by\n    intro i\n    rcases hωtop i with ⟨n, hn⟩\n    have hi : (i : WithTop ι) ≤ τ n ω := hn\n    have hposn : (⊥ : WithTop ι) < τ n ω := hpos n\n    have hmem : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := by simpa using hposn\n    have hrcn := (hrc_stopped n).rightContinuousAt i\n    have hEq :\n        (fun x => (stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n)) x ω)\n          = fun x => X x ω := by\n      funext x\n      by_cases hx : (x : WithTop ι) ≤ τ n ω\n      · have : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := hmem\n        simp [stoppedProcess, hx, Set.indicator_of_mem this]\n      · have : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := hmem\n        simp [stoppedProcess, hx, Set.indicator_of_mem this]\n    have hEqAt :\n        (fun x => (stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n)) x ω)\n          =ᶠ[𝓝[≥] i] fun x => X x ω := by\n      have : ∀ᶠ x in 𝓝[≥] i, (x : WithTop ι) ≤ τ n ω := by\n        have : {x : ι | (x : WithTop ι) ≤ τ n ω} ∈ 𝓝[≥] i := by\n          have : Icc i (univ : Set ι) ⊆ {x : ι | (x : WithTop ι) ≤ τ n ω} := by\n            intro x hx\n            have hx' : i ≤ x := hx.1\n            exact le_trans (show (i : WithTop ι) ≤ (x : WithTop ι) from by exact_mod_cast hx')\n              hi\n          exact mem_of_superset (Icc_mem_nhdsWithin_Ici (a := i)) (by\n            intro x hx; exact this hx)\n        simpa [Filter.mem_nhdsWithin] using this\n      filter_upwards [this] with x hx\n      have : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := hmem\n      simp [stoppedProcess, hx, Set.indicator_of_mem this]\n    exact (hrcn.congr_of_eventuallyEq hEqAt).mono (fun _ => id)\n  exact fun i => (hrc i).rightContinuous",
      "\n  classical\n  obtain ⟨τ, hτ, hpτ⟩ := hX\n  have hτtop : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  have hrc : ∀ᵐ ω ∂P, ∀ n, Function.RightContinuous\n      (stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) · ω) := by\n    refine ae_of_all _ ?_\n    intro ω n\n    exact hpτ n ω\n  filter_upwards [hτtop, hrc] with ω htop hrcω\n  have hsup : (⨆ n : ℕ, τ n ω) = (⊤ : WithTop ι) := by\n    simpa [WithTop.tendsto_atTop_nhds_top_iff] using htop\n  have hpos : ∀ i : ι, ∃ n : ℕ, (i : WithTop ι) < τ n ω := by\n    intro i\n    by_contra hne\n    push_neg at hne\n    have : (⨆ n : ℕ, τ n ω) ≤ (i : WithTop ι) := by\n      exact iSup_le hne\n    exact top_ne_iff.mp (by simpa [hsup] using this)\n  refine Function.RightContinuous.of_eq ?_ (fun n ↦ hrcω n)\n  ext i\n  have : ∃ n, (i : WithTop ι) < τ n ω := hpos i\n  rcases this with ⟨n, hn⟩\n  have hmem : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := by\n    exact lt_trans (bot_lt_coe i) hn\n  have hle : (i : WithTop ι) ≤ τ n ω := le_of_lt hn\n  simp [stoppedProcess, hle, Set.indicator_of_mem, hmem]",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hp⟩\n  have hτtop : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  have hmono : ∀ᵐ ω ∂P, Monotone (τ · ω) := hτ.mono\n  refine (ae_all_iff.2 ?_)\n  intro ω\n  refine (ae_iff.1 ?_).2 ?_\n  have hτtopω : Tendsto (τ · ω) atTop (𝓝 ⊤) := (ae_iff.1 hτtop).2 ω\n  have hmonoω : Monotone (τ · ω) := (ae_iff.1 hmono).2 ω\n  have hrc : ∀ n, Function.RightContinuous (fun x => stoppedProcess\n      (fun i => {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) x ω) := by\n    intro n\n    have := hp n\n    exact this ω\n  by_cases hωtop : ∀ n, τ n ω = ⊤\n  · have hst : (fun i => {ω | ⊥ < τ 0 ω}.indicator (X i) ω) = fun i => X i ω := by\n      ext i\n      have : ω ∈ {ω | ⊥ < τ 0 ω} := by\n        simp [hωtop 0]\n      simp [this]\n    have hstop : stoppedProcess (fun i => {ω | ⊥ < τ 0 ω}.indicator (X i)) (τ 0) = X := by\n      ext i ω'\n      have : τ 0 ω' = ⊤ := by\n        have := hωtop 0\n        simpa using this\n      simp [stoppedProcess, this]\n    simpa [hstop] using hrc 0\n  · have hω : ∀ i : ι, ∃ n, (i : WithTop ι) < τ n ω := by\n      intro i\n      have := (WithTop.tendsto_atTop_nhds_top_iff).1 hτtopω i\n      rcases this with ⟨N, hN⟩\n      exact ⟨N, hN N le_rfl⟩\n    have hRCi : ∀ i : ι, Function.RightContinuous (fun x => X x ω) := by\n      intro i\n      rcases hω i with ⟨n, hin⟩\n      have hmem : ω ∈ {ω | ⊥ < τ n ω} := by\n        have : (⊥ : WithTop ι) < (i : WithTop ι) := by simp\n        exact lt_trans this hin\n      have hle : (i : WithTop ι) ≤ τ n ω := le_of_lt hin\n      have hEq : (fun x => stoppedProcess\n          (fun j => {ω | ⊥ < τ n ω}.indicator (X j)) (τ n) x ω) = fun x => X x ω := by\n        ext x\n        have hxle : (x : WithTop ι) ≤ τ n ω := by\n          by_cases hx : x ≤ i\n          · exact le_trans (by exact_mod_cast hx) hle\n          · exact le_top\n        have hxmem : ω ∈ {ω | ⊥ < τ n ω} := hmem\n        simp [stoppedProcess, hxle, Set.indicator_of_mem, hxmem]\n      simpa [hEq] using (hrc n)\n    exact fun i => hRCi i",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hstopped⟩\n  have hmono : ∀ᵐ ω ∂P, Monotone fun n ↦ τ n ω := hτ.mono\n  have htend : ∀ᵐ ω ∂P, Tendsto (fun n ↦ τ n ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [hmono, htend] with ω hmonoω htendω\n  have hRCstopped : ∀ n, Function.RightContinuous fun i ↦\n      stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) i ω := by\n    intro n\n    exact hstopped n ω\n  by_cases htop : (∃ n, τ n ω = ⊤)\n  · rcases htop with ⟨n, hn⟩\n    have hle : ∀ m, (τ n ω : WithTop ι) ≤ τ m ω := fun m ↦ hmonoω (Nat.le_of_lt_succ <|\n      lt_of_le_of_ne (hmonoω (Nat.le_succ n)) (by\n        intro hEq; exact WithTop.top_ne_bot (by simpa [hn] using hEq.symm)))\n    have halltop : ∀ m, τ m ω = ⊤ := by\n      intro m\n      exact top_unique <| hn ▸ hle m\n    have hmem : ∀ (i : ι) (m : ℕ), ω ∈ {ω | (⊥ : WithTop ι) < τ m ω} := by\n      intro i m\n      simp [halltop m]\n    have hstop_eq : ∀ (i : ι) (m : ℕ),\n        stoppedProcess (fun i ↦ {ω | ⊥ < τ m ω}.indicator (X i)) (τ m) i ω = X i ω := by\n      intro i m\n      have : (τ m ω : WithTop ι) = ⊤ := halltop m\n      simp [stoppedProcess, this, hmem i m]\n    have hRC : Function.RightContinuous fun i ↦ X i ω := by\n      have := hRCstopped 0\n      simpa [hstop_eq] using this\n    exact hRC\n  · have hneTop : ∀ n, τ n ω ≠ ⊤ := by\n      intro n hn\n      exact htop ⟨n, hn⟩\n    have hTopι : Tendsto (fun n ↦ (τ n ω).untopD ⊥) atTop atTop := by\n      simpa [WithTop.tendsto_atTop_nhds_top_iff] using htendω\n    have hcover : ∀ i : ι, ∃ n, i < (τ n ω).untopD ⊥ := by\n      intro i\n      have : ∀ᶠ n in atTop, i < (τ n ω).untopD ⊥ := (tendsto_atTop.1 hTopι) i\n      exact (this.exists)\n    have hRC : Function.RightContinuous fun i ↦ X i ω := by\n      intro i\n      rcases hcover i with ⟨n, hn⟩\n      have hlt : (i : WithTop ι) < τ n ω := by\n        have : τ n ω = (↑((τ n ω).untopD ⊥) : WithTop ι) := by\n          cases hτn : τ n ω <;> simp [WithTop.untopD, WithTop.coe_eq_coe] at *\n          · exact (hneTop n (by simpa [hτn] using rfl)).elim\n          · simp [WithTop.untopD, hτn]\n        simpa [this] using (WithTop.coe_lt_coe.2 hn)\n      have hmem : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := by\n        have : (⊥ : WithTop ι) < (i : WithTop ι) := by\n          simpa using (WithTop.bot_lt_coe i)\n        exact lt_trans this hlt\n      have hstop_eq : ∀ j, j ≤ i →\n          stoppedProcess (fun j ↦ {ω | ⊥ < τ n ω}.indicator (X j)) (τ n) j ω = X j ω := by\n        intro j hj\n        have hlt' : (j : WithTop ι) < τ n ω := lt_of_le_of_lt (WithTop.coe_le_coe.2 hj) hlt\n        have hmem' : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := hmem\n        simp [stoppedProcess, hlt', Set.indicator_of_mem, hmem']\n      have hstop_eq' : stoppedProcess (fun j ↦ {ω | ⊥ < τ n ω}.indicator (X j)) (τ n) i ω = X i ω :=\n        hstop_eq i le_rfl\n      have hstop_eq_near : ∀ᶠ j in 𝓝[>] i,\n          stoppedProcess (fun j ↦ {ω | ⊥ < τ n ω}.indicator (X j)) (τ n) j ω = X j ω := by\n        have : ∀ᶠ j in 𝓝[>] i, j ≤ i := by\n          simpa [nhdsWithin, Filter.principal, Filter.mem_inf] using\n            (Filter.eventually_of_forall fun j ↦ le_of_lt)\n        filter_upwards [this] with j hj using hstop_eq j hj\n      have hRCi := hRCstopped n i\n      have hRCi' : Function.RightContinuous fun j ↦ X j ω := by\n        refine (hRCi.congr ?_).trans ?_\n        · intro j\n          by_cases hj : j ≤ i\n          · exact (hstop_eq j hj).symm\n          · by_cases hji : i < j\n            · have : (j : WithTop ι) < τ n ω := lt_of_lt_of_le (WithTop.coe_lt_coe.2 hji) ?_\n              · exact hstop_eq' ▸ hlt\n              · simp [stoppedProcess, this, Set.indicator_of_mem, hmem]\n            · have : j = i := le_antisymm (le_of_not_gt hji) (le_of_not_ge hj)\n              simp [this, hstop_eq']\n        · simpa [hstop_eq'] using (Function.RightContinuous.congr_of_eventuallyEq hRCi hstop_eq_near).1\n      exact hRCi'\n    exact hRC",
      "\n  classical\n  by_cases hP : P = 0\n  · subst hP\n    simpa using (ae_of_all _ fun ω ↦ hX.stoppedProcess 0 ω)\n  · have hmono : ∀ᵐ ω ∂P, Monotone (hX.localSeq · ω) := hX.IsLocalizingSequence.mono\n    have htop : ∀ᵐ ω ∂P, Tendsto (hX.localSeq · ω) atTop (𝓝 ⊤) :=\n      hX.IsLocalizingSequence.tendsto_top\n    filter_upwards [hmono, htop] with ω hωmono hωtop\n    have hrc : ∀ n, Function.RightContinuous\n        ((stoppedProcess (fun i ↦ {ω | ⊥ < hX.localSeq n ω}.indicator (X i))\n          (hX.localSeq n)) · ω) := fun n ↦ hX.stoppedProcess n ω\n    have hωtop' : ∀ i : ι, ∃ n, (i : WithTop ι) < hX.localSeq n ω := by\n      simpa [WithTop.tendsto_atTop_nhds_top_iff] using hωtop\n    refine Function.rightContinuous_iff.2 ?_\n    intro i\n    obtain ⟨n, hn⟩ := hωtop' i\n    have hnei : {ω | ⊥ < hX.localSeq n ω} ω := by\n      have : (⊥ : WithTop ι) < (i : WithTop ι) := by\n        exact WithTop.coe_bot_lt (a := i)\n      exact lt_trans this hn\n    have hle : (i : WithTop ι) ≤ hX.localSeq n ω := le_of_lt hn\n    have hEq :\n        (fun t : ι => X t ω) =\n          fun t : ι =>\n            (stoppedProcess (fun i ↦ {ω | ⊥ < hX.localSeq n ω}.indicator (X i))\n              (hX.localSeq n)) t ω := by\n      funext t\n      have hle' : (t : WithTop ι) ≤ hX.localSeq n ω := by\n        exact le_trans (le_max_left t i) ?_\n      · simp [stoppedProcess, hle', Set.indicator_of_mem, hnei]\n      · exact le_trans (le_of_lt hn) (le_max_right t i)\n    have : Function.RightContinuous (fun t => X t ω) := by\n      simpa [hEq] using (hrc n)\n    exact this.rightContinuousAt",
      "\n  classical\n  obtain ⟨τ, hτ, hτX⟩ := hX\n  have hmono : ∀ᵐ ω ∂P, Monotone (τ · ω) := hτ.mono\n  have htop : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [hmono, htop] with ω hmonoω htopω\n  have hRC : ∀ n, Function.RightContinuous fun x =>\n      (stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) x) ω := by\n    intro n\n    simpa using (hτX n ω)\n  have hlt : ∀ i : ι, ∃ n : ℕ, (↑i : WithTop ι) < τ n ω := by\n    intro i\n    have : ∃ n, (↑i : WithTop ι) < τ n ω := by\n      simpa [WithTop.tendsto_atTop_nhds_top_iff] using (htopω i)\n    simpa using this\n  have hge : ∀ i : ι, ∃ n : ℕ, (τ n ω) ≤ (↑i : WithTop ι) := by\n    intro i\n    refine ⟨0, ?_⟩\n    have : τ 0 ω ≤ τ (Nat.succ 0) ω := hmonoω (Nat.zero_le _)\n    exact this.trans le_top\n  refine Function.RightContinuous.of_eqOn ?_ (hRC 0)\n  · intro i\n    rcases hlt i with ⟨n, hn⟩\n    refine ⟨n, ?_⟩\n    have hi : (⊥ : WithTop ι) < τ n ω := lt_of_lt_of_le (bot_lt_coe i) (le_of_lt hn)\n    have : {ω' | (⊥ : WithTop ι) < τ n ω'}.indicator (X i) ω = X i ω := by\n      simp [Set.indicator_of_mem, hi]\n    have hstop : stoppedProcess (fun i ↦ {ω' | (⊥ : WithTop ι) < τ n ω'}.indicator (X i)) (τ n) i ω\n        = {ω' | (⊥ : WithTop ι) < τ n ω'}.indicator (X i) ω := by\n      rw [stoppedProcess_eq_of_lt]\n      · rfl\n      · exact hn\n    simpa [this, hstop]\n  · exact fun _ _ _ ↦ by intro; rfl",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hmono : ∀ᵐ ω ∂P, Monotone (τ · ω) := hτ.mono\n  have htend : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [hmono, htend] with ω hmonoω htendω\n  have hrc : ∀ n, Function.RightContinuous fun t ↦\n      stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) t ω := by\n    intro n\n    simpa using (hτX n ω)\n  have ht_top : Tendsto (τ · ω) atTop (𝓝 ⊤) := htendω\n  have hτevent : ∀ i : ι, ∃ n : ℕ, (i : WithTop ι) < τ n ω := by\n    intro i\n    have : ∀ a : WithTop ι, (a < ⊤) → ∃ n, a < τ n ω := by\n      intro a ha\n      simpa [WithTop.tendsto_atTop_nhds_top_iff] using (ht_top a ha)\n    exact this i (by simp)\n  refine Function.rightContinuous_iff.2 ?_\n  intro i\n  have hi : ∃ n : ℕ, (i : WithTop ι) < τ n ω := hτevent i\n  rcases hi with ⟨n, hin⟩\n  have hle : (i : WithTop ι) ≤ τ n ω := le_of_lt hin\n  have hrcn := (hrc n).rightLim i\n  have hst : (fun t ↦ stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) t ω)\n      = fun t ↦ X t ω := by\n    funext t\n    by_cases ht : (t : WithTop ι) ≤ τ n ω\n    · have hmem : ω ∈ {ω | ⊥ < τ n ω} := by\n        have : (⊥ : WithTop ι) < τ n ω :=\n          lt_of_lt_of_le (by simp) (le_trans (by simp) hle)\n        simpa\n      simp [stoppedProcess, ht, Set.indicator_of_mem, hmem]\n    · have : τ n ω < (t : WithTop ι) := lt_of_not_ge ht\n      simp [stoppedProcess, le_of_lt this]\n  simpa [hst] using hrcn",
