  refine Function.RightContinuous.of_eqOn ?_ (hRC 0)
  · intro i
    rcases hlt i with ⟨n, hn⟩
    refine ⟨n, ?_⟩
    have hi : (⊥ : WithTop ι) < τ n ω := lt_of_lt_of_le (bot_lt_coe i) (le_of_lt hn)
    have : {ω' | (⊥ : WithTop ι) < τ n ω'}.indicator (X i) ω = X i ω := by
