theorem Exercise_8_1_1_b : denum {n : Int | even n} :=
by
  classical
  refine denum_of_equinum _ denum_Int
  refine
    ⟨(fun n : Int => 2 * n),
      (fun n : {n : Int | even n} => n.1 / 2),
      ?_, ?_⟩
  · intro n
    simp
  · intro n
    rcases n with ⟨n, hn⟩
    have h : (n / 2) * 2 = n := by
      simpa [even_iff_exists_int] using (Int.ediv_mul_cancel hn)
    apply Subtype.ext
    simpa [two_mul, mul_assoc, mul_left_comm, mul_comm] using h.symm
