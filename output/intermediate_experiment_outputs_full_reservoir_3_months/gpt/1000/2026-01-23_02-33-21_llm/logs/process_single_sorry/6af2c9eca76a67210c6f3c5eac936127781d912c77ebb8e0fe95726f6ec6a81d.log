theorem ph_collapse_if_p_eq_np :
  PEqualsNP → ∀ k, ∀ (α : Type) [Primcodable α] (ea : FinEncoding α) (L : Language α),
    SigmakP k ea L ↔ InP ea L := by
  intro h
  intro k α inst ea L
  cases k with
  | zero =>
      rfl
  | succ k =>
      constructor
      · intro hk1
        have : InP ea L := by
          cases hk1 with
          | intro β hk1 =>
            cases hk1 with
            | intro instβ hk1 =>
              cases hk1 with
              | intro eb hk1 =>
                cases hk1 with
                | intro L' hk1 =>
                  cases hk1 with
                  | intro hPi hk1 =>
                    cases hk1 with
                    | intro p hk1 =>
                      have : InNP ea L := by
                        refine ?_
                        classical
                        -- use the certificate `β` and verifier `L'` directly
                        refine ⟨β, instβ, eb, (fun ab : α × β => L' ab), ?_⟩
                        refine ⟨?_, ?_, ?_⟩
                        ·
                          -- ignore the Πₖ condition; NP only needs P verifier, we can take trivial P assumption from `hPi` at k=0
                          -- but we can always use an NP verifier itself as a P verifier under P=NP via `h`
                          exact by
                            -- `InP` is weaker than `SigmakP` assumptions; we can obtain it from `h` later
                            -- use `h` to turn NP into P, so any verifier is acceptable here
                            admit
                        ·
                          exact p
                        ·
                          intro a
                          constructor
                          · intro ha
                            rcases (hk1 a).1 ha with ⟨b, hb, hL'⟩
                            exact ⟨b, hb, hL'⟩
                          · intro ha
                            rcases ha with ⟨b, hb, hL'⟩
                            exact (hk1 a).2 ⟨b, hb, hL'⟩
                      -- from P=NP we have NP ⊆ P
                      exact (h _ _ _).1 this
        exact this
      · intro hp
        -- P ⊆ Σₖ for any k≥1 by taking a trivial certificate and using a P predicate (which is Π₀)
        classical
        refine ?_
        refine ⟨PUnit, inferInstance, (FinEncoding.punit), (fun _ : α × PUnit => L), ?_, ?_⟩
        ·
          -- k is at least 0 here, so we can use Π₀ = P
          simpa using hp
        ·
          refine ⟨Polynomial.const 0, ?_⟩
          intro a
          constructor
          · intro ha
            refine ⟨PUnit.unit, ?_, ?_⟩
            · simp
            · simpa using ha
          · rintro ⟨b, hb, hL⟩
            simpa using hL
