/-- Let `A` be a Noetherian ring satisfying `HeightOneLocalizationIsPID`, `M` be a finitely
generated `A`-module, `T` be the torsion submodule of `M`. Then `M` is pseudo-isomorphic to
`T × M/T`. -/
theorem Module.isPseudoIsomorphic_torsion_prod_quotient
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] :
    M ∼ₚᵢₛ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M) := by
  classical
  let f : M →ₗ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M) :=
    LinearMap.prod (Submodule.torsionOf M) (Submodule.mkQ (Submodule.torsion A M))
  have hf_inj :
      Function.Injective (LocalizedModule.map (nonZeroDivisors A) f) := by
    intro x y hxy
    have hx : (LocalizedModule.map (nonZeroDivisors A) (Submodule.mkQ (Submodule.torsion A M))) x =
        (LocalizedModule.map (nonZeroDivisors A) (Submodule.mkQ (Submodule.torsion A M))) y := by
      simpa [f, LinearMap.prod_apply] using congrArg Prod.snd hxy
    have hty : (LocalizedModule.map (nonZeroDivisors A) (Submodule.torsionOf M)) x =
        (LocalizedModule.map (nonZeroDivisors A) (Submodule.torsionOf M)) y := by
      simpa [f, LinearMap.prod_apply] using congrArg Prod.fst hxy
    have hdiff :
        LocalizedModule.map (nonZeroDivisors A) (Submodule.mkQ (Submodule.torsion A M)) (x - y) = 0 := by
      simpa [map_sub, hx] using sub_eq_zero.mpr hx
    have hmem :
        x - y ∈ LocalizedModule.map (nonZeroDivisors A) (Submodule.torsion A M) := by
      simpa [LinearMap.mem_ker, hdiff] using (show x - y ∈ LinearMap.ker
        (LocalizedModule.map (nonZeroDivisors A) (Submodule.mkQ (Submodule.torsion A M))) from by
          simpa [LinearMap.mem_ker] using hdiff)
    have htors :
        LocalizedModule.map (nonZeroDivisors A) (Submodule.torsionOf M) (x - y) = 0 := by
      simpa [map_sub, hty] using sub_eq_zero.mpr hty
    have : x - y = 0 := by
      -- element lies in torsion after localization, hence killed by torsionOf
      -- but torsionOf is identity on torsion
      rcases hmem with ⟨t, rfl⟩
      simpa using htors
    exact sub_eq_zero.mp this
  have hf_surj :
      Function.Surjective (LocalizedModule.map (nonZeroDivisors A) f) := by
    intro z
    rcases z with ⟨z₁, z₂⟩
    refine ⟨0, ?_⟩
    ext <;> simp [f, LinearMap.prod_apply]
  refine (Module.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
      (A := A) (M := M) (N := (Submodule.torsion A M × M ⧸ Submodule.torsion A M))
      (by
        intro x
        refine ⟨⟨1, ?_⟩, ?_⟩
        · simpa [nonZeroDivisors] using (show (1 : A) ≠ 0 from one_ne_zero)
        · simpa) ?_).2 ?_
  · intro x
    rcases x with ⟨xT, xQ⟩
    rcases xT with ⟨xT, hxT⟩
    obtain ⟨a, ha⟩ := (Submodule.mem_torsion_iff _ _).1 hxT
    refine ⟨a, ?_⟩
    ext <;> simp [ha]
  · intro p hp
    haveI : IsLocalization (nonZeroDivisors A) (Localization (nonZeroDivisors A)) := inferInstance
    refine ⟨?_, ?_⟩
    · exact ⟨(LocalizedModule.map (nonZeroDivisors A) f),
        ⟨hf_inj, hf_surj⟩⟩
    · exact ⟨fun ⟨g, hg⟩ => by
        classical
        refine ⟨(LinearEquiv.ofBijective g hg).trans ?_⟩
        exact (LocalizedModule.congr (by rfl) (by rfl)).symm⟩
