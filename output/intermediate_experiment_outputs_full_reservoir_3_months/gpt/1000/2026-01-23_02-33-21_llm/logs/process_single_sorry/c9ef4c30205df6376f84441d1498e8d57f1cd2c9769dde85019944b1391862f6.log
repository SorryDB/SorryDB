      cases y with
      | mk y1 y2 =>
        cases hx
        cases this
        rfl
  · intro z
    refine ⟨⟨⟨z.1, ?_⟩, 0⟩, ?_⟩
    · simpa using (Submodule.subtype_mem (Submodule.torsion A M) z.1)
    · ext <;> simp
