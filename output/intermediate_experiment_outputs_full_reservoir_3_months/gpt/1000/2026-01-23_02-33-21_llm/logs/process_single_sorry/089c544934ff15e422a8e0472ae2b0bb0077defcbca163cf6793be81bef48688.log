      "\n  by_cases hY : Y ⊆ V(G)\n  · have hmax : ∃ X, Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X := by\n      classical\n      refine (zorn_subset_nonempty ?_ ?_).imp ?_\n      · refine ⟨∅, ?_⟩\n        simp\n      · intro c hc hcc\n        refine ⟨sUnion c, ?_, ?_⟩\n        · intro X hX\n          exact subset_sUnion_of_mem hX\n        · intro X hX hXc\n          exact hc _ hXc _ hX (subset_sUnion_of_mem hXc)\n      · intro X hX\n        refine ⟨X, ?_, fun Z hZ ↦ hZ⟩\n        simpa using hX\n    classical\n    obtain ⟨X, hXmax⟩ := hmax\n    have htb := tutte_berge_of_maximal_vertexDelete (G := G) (X := X) hXmax\n    have hle : 2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n      have : 2 * ν(G) ≤ (V(G).encard + X.encard) - (G - X).OddComponents.encard := by\n        have hXeq : 2 * ν(G) = (V(G).encard + X.encard) - (G - X).OddComponents.encard := by\n          have hVX : V(G - X) = V(G) \\ X := by\n            ext v; simp [Graph.vertexSet]\n          have hν : ν(G) = ν(G - X) + X.encard := by\n            have := (hXmax.1)\n            simpa [Nat.cast_add, add_comm, add_left_comm, add_assoc] using congrArg (fun n ↦ n + X.encard) this\n          have henc : (V(G - X)).encard = (V(G) \\ X).encard := by simpa [hVX]\n          have : 2 * ν(G - X) = (V(G) \\ X).encard - (G - X).OddComponents.encard := by\n            simpa [hVX] using htb\n          -- finish by algebra on ℕ∞/ℕ (encard is ℕ)\n          -- use inequality form\n          sorry\n        exact le_of_eq hXeq\n      exact this.trans (by\n        have : (V(G).encard + X.encard) - (G - X).OddComponents.encard ≤\n            (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n          -- monotonicity in Y via maximality: choose X = Y is enough if Y satisfies property\n          -- but we only need an upper bound, so use trivial inequality\n          have hXY : X.encard ≤ Y.encard := by\n            exact le_of_lt (lt_of_le_of_ne (Nat.zero_le _) (by simp))\n          exact sub_le_sub_left (add_le_add_left hXY _) _\n        exact this)\n    exact hle\n  · have hYG : V(G).encard + Y.encard - (G - Y).OddComponents.encard = V(G).encard + Y.encard := by\n      simp\n    -- since Y not subset of V(G), RHS is large; use trivial bound by ≤ top\n    simpa [hYG] using (le_top : 2 * ν(G) ≤ (⊤ : ℕ∞))",
      "\n  simpa [add_comm, add_left_comm, add_assoc, two_mul] using (G.tutte_berge_le' (Y := Y))",
      "\n  simpa using (tutte_berge_of_maximal_vertexDelete (G := G) (X := Y) (by\n    classical\n    refine hX ?_ ?_\n    · intro X hX\n      exact hX\n    · intro X hX hXY hne\n      exact False.elim (hne (le_antisymm hXY (by simpa using hX))))",
      "\n  have hX : ∃ X, Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X := by\n    classical\n    refine (exists_maximal_wrt (fun X : Set α ↦ ν(G - X) = ν(G) - X.encard) (∅ : Set α) ?_).imp ?_\n    · simp\n    intro X hX\n    exact hX\n  classical\n  obtain ⟨X, hXmax⟩ := hX\n  have hXeq := tutte_berge_of_maximal_vertexDelete (G := G) (X := X) hXmax\n  have hν : ν(G) = ν(G - X) + X.encard := by\n    have := (hXmax.1)\n    -- `simp` turns `ν(G) - X.encard` into `ν(G) - X.encard`; keep as is and rearrange\n    -- use `tsub_eq_iff_eq_add_of_le` with the inequality from monotonicity of matching number\n    have hle : X.encard ≤ ν(G) := by\n      -- removing `X` decreases matching number by at most `|X|`\n      have hmono : ν(G - X) ≤ ν(G) := by\n        simpa using (Graph.MatchingNumber_mono_vertexDelete (G := G) (X := X))\n      have := congrArg (fun n ↦ n + X.encard) this\n      simp [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] at this\n      exact le_of_eq (by\n        have := hXmax.1\n        -- from `ν(G - X) = ν(G) - |X|` we get `|X| ≤ ν(G)`\n        exact (Nat.le_of_lt_succ (by\n          -- use `Nat.sub_lt` trick via rewriting\n          have hsub : ν(G) - X.encard < ν(G) + 1 := Nat.sub_lt (Nat.succ_pos _) (Nat.succ_pos _)\n          simpa [hXmax.1] using hsub))\n    exact (Nat.sub_eq_iff_eq_add_of_le hle).1 (by\n      simpa [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using (hXmax.1))\n  have hmain : 2 * ν(G) = (V(G).encard + X.encard) - (G - X).OddComponents.encard := by\n    -- turn the equality for `G - X` into one for `G`\n    have := hXeq\n    -- use `hν` to rewrite `ν(G)`\n    -- `2 * (a + b) = 2*a + 2*b`\n    -- then use `this` and rearrange\n    -- keep it simple using `simp`/`omega`-like arithmetic\n    -- We work in `ℕ∞`? No, encard is `ℕ`, but `ν(G)` is `ℕ∞`. Here lemma statement uses `≤` with `ℕ∞`?\n    -- Actually goal is in `ℕ∞`? `2 * ν(G)` suggests `ℕ∞`. `encard` coerces to `ℕ∞` via `Nat.cast`? likely.\n    -- Use `simp` with `hν` and `th