      "\n  by_cases hY : Y ⊆ V(G)\n  · have hmax : ∃ X, Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X ∧ Y ⊆ X := by\n      obtain ⟨X, hX⟩ := zorn_subset_nonempty {X | Y ⊆ X ∧ ν(G - X) = ν(G) - X.encard} ?_ ?_\n      · rcases hX with ⟨X, ⟨hYX, hXe⟩, hmax⟩\n        refine ⟨X, ?_, hYX⟩\n        refine ⟨hXe, ?_⟩\n        intro X' hX' hXX'\n        exact (hmax X' ⟨hYX.trans hXX', hX'⟩ hXX').antisymm hXX'\n      · refine ⟨Y, ⟨Subset.rfl, ?_⟩⟩\n        have : ν(G - Y) ≤ ν(G) := by\n          classical\n          by_contra hlt\n          have := (not_le.mp hlt)\n          exact (lt_irrefl _ this)\n        have hle : ν(G) - Y.encard ≤ ν(G - Y) := by\n          classical\n          exact tsub_le_iff_right.mp (by simpa [two_mul] using (zero_le (ν(G - Y))))\n        exact le_antisymm (le_of_eq (by\n          classical\n          simp)) (le_of_eq (by\n          classical\n          simp))\n      · intro c hc hchain\n        refine ⟨sUnion c, ?_⟩\n        constructor\n        · intro y hy\n          rcases hc with ⟨X0, hX0c, hYX0, -⟩\n          exact subset_sUnion_of_mem hX0c (hYX0 hy)\n        · classical\n          have hmono : ∀ {A B}, A ∈ c → B ∈ c → A ⊆ B → ν(G - B) = ν(G) - B.encard → ν(G - A) = ν(G) - A.encard := by\n            intro A B hAc hBc hAB hB\n            exact (hc.2 B hBc).2\n          have : ν(G - sUnion c) = ν(G) - (sUnion c).encard := by\n            classical\n            simp\n          exact this\n    rcases hmax with ⟨X, hXmax, hYX⟩\n    have hX := tutte_berge_of_maximal_vertexDelete (G := G) (X := X) hXmax\n    have hleY : (V(G) \\ X).encard ≤ (V(G) \\ Y).encard := by\n      classical\n      exact encard_mono (by\n        intro v hv\n        exact ⟨hv.1, fun hvY ↦ hv.2 (hYX hvY)⟩)\n    have hodd : (G - X).OddComponents.encard ≤ (G - Y).OddComponents.encard := by\n      classical\n      exact le_of_eq (by simp)\n    have : 2 * ν(G - X) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n      classical\n      have := congrArg (fun n => n) hX\n      have h' : (V(G) \\ X).encard - (G - X).OddComponents.encard ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n        exact sub_le_sub hleY hodd\n      simpa [this] using h'\n    have htsub : ν(G) ≤ ν(G - X) + X.encard := by\n      classical\n      have := le_of_eq (by\n        have := hXmax.1\n        simp [this] )\n      exact this\n    have hle : 2 * ν(G) ≤ 2 * (ν(G - X) + X.encard) := by\n      exact mul_le_mul_of_nonneg_left htsub (by decide : (0:ℕ∞) ≤ 2)\n    have : 2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n      classical\n      have hVX : (V(G) \\ Y).encard ≤ V(G).encard := by\n        exact encard_mono (by intro v hv; exact hv.1)\n      have hmain : 2 * ν(G) ≤ (V(G) \\ Y).encard + (2 * Y.encard) - (G - Y).OddComponents.encard := by\n        exact le_trans (le_trans hle (by\n          have := add_le_add_right this (2 * X.encard)\n          simpa [mul_add] using this)) (by\n          have : (V(G) \\ Y).encard + (2 * Y.encard) ≤ V(G).encard + Y.encard := by\n            simpa [two_mul, add_assoc, add_left_comm, add_comm] using add_le_add hVX (by\n              simpa [two_mul] using le_add_of_nonneg_left (zero_le _))\n          exact sub_le_sub_right this _)\n      exact le_trans hmain (by\n        simpa [two_mul, add_assoc, add_left_comm, add_comm] using le_rfl)\n    simpa [vertexSet] using this\n  · have : V(G).encard + Y.encard - (G - Y).OddComponents.encard = ⊤ := by\n      classical\n      by_cases hfin : (V(G).Finite ∧ Y.Finite)\n      · simp\n      · simp\n    simp [this]",
      "\n  by_cases hY : Y ⊆ V(G)\n  ·\n    -- Choose a maximal `X ⊆ Y` with `ν(G - X) = ν(G) - |X|`.\n    obtain ⟨X, hXY, hmax⟩ :\n        ∃ X ⊆ Y, Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X := by\n      refine zorn_subset_nonempty ?_ ?_\n      · refine ⟨∅, by simp⟩\n      · intro c hc hchain\n        refine ⟨sUnion c, ?_, ?_⟩\n        · intro x hx\n          rcases hx with ⟨Z, hZc, hxZ⟩\n          exact hchain.mem_upperBounds_of_chain hc hZc hXY hxZ\n        · -- `sUnion c` satisfies the property since the matching number and encard are well-behaved\n          -- under chains; this is provided by the library lemma used by `zorn_subset_nonempty`.\n          simpa using (hc.directed_sUnion_eq (fun X ↦ ν(G - X) = ν(G) - X.encard) hchain)\n    have hXsubV : X ⊆ V(G) := hXY.trans hY\n    have hXeq : ν(G - X) = ν(G) - X.encard := hmax.prop\n    have hXYenc : X.encard ≤ Y.encard := encard_mono hXY\n    have hodd_mono : (G - Y).OddComponents.encard ≤ (G - X).OddComponents.encard := by\n      -- deleting more vertices can only increase (or keep) the number of odd components\n      simpa using (OddComponents.encard_mono_vertexDelete (G := G) hXY)\n    have htbX :\n        2 * ν(G - X) = (V(G) \\ X).encard - (G - X).OddComponents.encard :=\n      tutte_berge_of_maximal_vertexDelete (G := G) hmax\n    have hνle : 2 * ν(G) ≤ 2 * (ν(G - X) + X.encard) := by\n      have : ν(G) ≤ ν(G - X) + X.encard := by\n        -- removing `X` can destroy at most `|X|` edges of a matching\n        simpa [hXeq, tsub_eq_iff_eq_add_of_le (by\n          simpa [hXeq] using (le_add_of_nonneg_right (by exact bot_le)))] using le_rfl\n      nlinarith\n    have hmain :\n        2 * ν(G) ≤ (V(G).encard + X.encard) - (G - X).OddComponents.encard := by\n      have : 2 * ν(G) ≤ (V(G).encard + X.encard) - (G - X).OddComponents.encard := by\n        -- combine `htbX` with `ν(G) = ν(G - X) + |X|` (from maximality)\n        have hν : ν(G) = ν(G - X) + X.encard := by\n          have : ν(G - X) = ν(G) - X.encard := hXeq\n          exact (eq_add_of_tsub_eq (by\n            have := (by\n              -- `X.encard ≤ ν(G)` since `ν(G - X) ≥ 0`\n              have : (0 : ℕ∞) ≤ ν(G - X) := bot_le\n              simpa [this] using (le_tsub_iff_right.mp (by simpa [this] using le_rfl))).trans bot_le) this).symm\n        -- rewrite via `htbX`\n        have : 2 * ν(G) = 2 * ν(G - X) + 2 * X.encard := by\n          simpa [hν, mul_add, two_mul, add_assoc, add_left_comm, add_comm]\n        -- use `htbX` to replace `2 * ν(G - X)`\n        nlinarith [htbX]\n      exact this\n    -- enlarge `X` to `Y`\n    have hVdiff : (V(G).encard + X.encard) ≤ (V(G).encard + Y.encard) := by\n      exact add_le_add_left hXYenc _\n    have hfinal :\n        (V(G).encard + X.encard) - (G - X).OddComponents.encard ≤\n          (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n      exact tsub_le_tsub hVdiff (le_trans hodd_mono le_rfl)\n    exact le_trans hmain hfinal\n  ·\n    -- If `Y` is not contained in `V(G)`, replace `Y` by `Y ∩ V(G)`.\n    have hY' : (Y ∩ V(G)) ⊆ V(G) := by intro x hx; exact hx.2\n    have hY'' : (Y ∩ V(G)) ⊆ Y := by intro x hx; exact hx.1\n    have henc : (Y ∩ V(G)).encard ≤ Y.encard := encard_mono hY''\n    have hodd :\n        (G - Y).OddComponents.encard = (G - (Y ∩ V(G))).OddComponents.encard := by\n      -- deleting vertices not in `V(G)` has no effect\n      simpa [Graph.vertexDelete_inter_vertexSet] \n    have hle :\n        2 * ν(G) ≤ (V(G).encard + (Y ∩ V(G)).encard) - (G - (Y ∩ V(G))).OddComponents.encard := by\n      have := (tutte_berge_le (G := G) (Y := (Y ∩ V(G))))\n      simpa using this\n    -- finish using `henc` and `hodd`\n    have : (V(G).encard + (Y ∩ V(G)).encard) - (G - (Y ∩ V(G))).OddComponents.encard ≤\n        (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n      simpa [hodd] using tsub_le_tsub (add_le_add_left henc _) (le_of_eq rfl)\n    exact le_trans hle this",
      "\n  simpa [two_mul, add_assoc, add_left_comm, add_comm] using (Graph.tutte_berge_of_maximal_vertexDelete (G := G) (X := Y)\n    (by\n      classical\n      refine (maximal_iff_forall_superset ?_).2 ?_\n      · exact ⟨by simp, ?_⟩\n      · intro Z hYZ hZ\n        have : (ν(G - Z) : ℕ∞) ≤ ν(G - Y) := by\n          exact Graph.MatchingNumber_mono_vertexDelete (G := G) hYZ\n        have hcard : (Z.encard : ℕ∞) ≤ Y.encard := by\n          exact_mod_cast encard_le_encard hYZ\n        have := sub_le_sub (a := ν(G)) (b := Z.encard) (c := ν(G)) (d := Y.encard) ?_\n        · exact (le_antisymm (le_trans (by simpa [hZ] using this) (by simpa using this)) (by simpa [hZ]))\n        · exact hcard))",
      "\n  by_contra h'\n  exact not_lt_of_ge (le_rfl : (2 * ν(G) : ℕ∞) ≤ 2 * ν(G)) (lt_of_lt_of_le (lt_of_not_ge h') le_rfl)",
      "\n  simpa using (tutte_berge_le (G := G) (Y := Y))",
      "\n  by_cases hY : Y ⊆ V(G)\n  · have hmax : ∃ X, Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X := by\n      refine ⟨Y, ?_⟩\n      classical\n      refine (maximal_iff_forall_lt ?_).2 ?_\n      · exact ⟨∅, by simp⟩\n      intro Z hZY hne hZ\n      have : ¬ (ν(G - Z) = ν(G) - Z.encard) := by\n        simpa using hZ\n      exact False.elim (this rfl)\n    obtain ⟨X, hX⟩ := hmax\n    have hEq := tutte_berge_of_maximal_vertexDelete (G := G) (X := X) hX\n    have hle : 2 * ν(G - X) ≤ (V(G) \\ X).encard - (G - X).OddComponents.encard := by\n      simpa [hEq]\n    have hν : ν(G) ≤ ν(G - X) + X.encard := by\n      -- removing vertices can decrease matching number by at most their number\n      have : ν(G) - X.encard ≤ ν(G - X) := by\n        by_contra h'\n        exact (hX.1 (X := X)).elim\n      exact le_trans (by\n        have := le_add_of_nonneg_right (a := ν(G - X)) (b := X.encard) (by simp)\n        simpa [add_comm, add_left_comm, add_assoc] using this) (by\n          simpa [tsub_le_iff_right] using (le_of_not_ge h'))\n    have hVX : (V(G) \\ X).encard ≤ V(G).encard := by\n      exact (encard_le_encard (by intro x hx; exact hx.1))\n    have hXY : (V(G) \\ X).encard + X.encard ≤ V(G).encard + Y.encard := by\n      have hXsub : X ⊆ V(G) := by\n        intro x hx\n        exact (hY (by\n          have : x ∈ Y := by\n            classical\n            by_contra hxY\n            have : Y ⊂ X := by\n              refine ⟨?_, ?_⟩\n              · intro z hzY\n                by_cases hzX : z ∈ X\n                · exact hzX\n                · exfalso\n                  have : ν(G - (X ∪ {z})) = ν(G) - (X ∪ {z}).encard := by\n                    simp\n                  exact (hX.2 (X ∪ {z}) (by intro w hw; exact Or.elim hw (fun hwX ↦ hwX) (fun hwz ↦ by\n                    simpa using hwz)) (by\n                      refine ⟨z, ?_, ?_⟩\n                      · exact Or.inr (by simp)\n                      · intro hz; exact hzX (by simpa using hz)) this)).elim\n            exact (not_lt_of_ge (by exact hZY)) this\n        )) x hx\n      have hXleY : X.encard ≤ Y.encard := by\n        exact encard_le_encard (by\n          intro x hx\n          classical\n          by_contra hxY\n          exact False.elim (by\n            have : Y ⊂ X := by\n              refine ⟨?_, ?_⟩\n              · intro z hzY; exact hZY hzY\n              · refine ⟨x, hx, ?_⟩\n                simpa using hxY\n            exact (not_lt_of_ge (by exact le_of_eq rfl)) this))\n      exact add_le_add (hle_trans hVX) hXleY\n    have hodd : (G - Y).OddComponents.encard ≤ (G - X).OddComponents.encard := by\n      exact encard_le_encard (by\n        intro H hH\n        exact hH)\n    have : 2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n      calc\n        2 * ν(G) ≤ 2 * (ν(G - X) + X.encard) := by\n          gcongr\n          exact hν\n        _ = 2 * ν(G - X) + 2 * X.encard := by\n          simp [mul_add, add_mul, two_mul, add_assoc, add_left_comm, add_comm]\n        _ ≤ ((V(G) \\ X).encard - (G - X).OddComponents.encard) + 2 * X.encard := by\n          gcongr\n          exact hle\n        _ ≤ ((V(G).encard + Y.encard) - (G - Y).OddComponents.encard) := by\n          -- coarse bounding\n          have := sub_le_sub_right (add_le_add hXY (le_of_eq rfl)) (G - X).OddComponents.encard\n          exact le_trans (by\n            have : (V(G) \\ X).encard - (G - X).OddComponents.encard + 2 * X.encard ≤\n                (V(G) \\ X).encard + X.encard - (G - X).OddComponents.encard + X.encard := by\n              simp [two_mul, add_assoc, add_left_comm, add_comm, sub_eq_add_neg]\n            exact this) (by\n            have : (V(G) \\ X).encard + X.encard - (G - X).OddComponents.encard + X.encard ≤\n                V(G).encard + Y.encard - (G - Y).OddComponents.encard := by\n              exact le_trans (by\n                gcongr\n                exact hodd) (by\n                gcongr)\n            simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this)\n      exact this\n    exact this\n  · -- if Y is not a subset of V(G), then Y.encard counts extra elements, making RHS larger\n    have : (V(G).encard + Y.encard) - (G - Y).OddComponents.encard = (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := rfl\n    have h : 2 * ν(G) ≤ (V(G).encard + Y.encard) := by\n      have : ν(G) ≤ V(G).encard := by\n        -- crude bound\n        exact le_trans (by exact le_of_eq (by simp)) (by simp)\n      nlinarith\n    exact le_trans h (by\n      simp [sub_le_self])",
      "\n  have hY : ν(G) ≤ ν(G - Y) + Y.encard := by\n    simpa [Graph.delete_eq_restrict] using (Graph.MatchingNumber_delete_le_add_encard (G := G) (X := Y))\n  have hodd : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    simpa using Graph.tutte_berge_le_delete (G := G) (Y := Y)\n  have hodd' : 2 * ν(G - Y) + 2 * Y.encard ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard + 2 * Y.encard :=\n    add_le_add_right hodd (2 * Y.encard)\n  have hmain : 2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by\n    exact mul_le_mul_of_nonneg_left hY (by exact_mod_cast (Nat.zero_le 2))\n  have hmain' : 2 * ν(G) ≤ 2 * ν(G - Y) + 2 * Y.encard := by\n    simpa [mul_add, add_assoc, add_left_comm, add_comm] using hmain\n  have hV : (V(G) \\ Y).encard + 2 * Y.encard ≤ V(G).encard + Y.encard := by\n    simpa using Graph.encard_diff_add_two_mul_encard_le_encard_add (G := G) (Y := Y)\n  have : 2 * ν(G) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard + 2 * Y.encard := by\n    exact hmain'.trans (by\n      have := (le_tsub_add_of_le_tsub hodd)\n      simpa [add_assoc, add_left_comm, add_comm] using this)\n  have : 2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n    refine this.trans ?_\n    refine tsub_le_tsub_right ?_ _\n    exact hV\n  simpa [add_comm, add_left_comm, add_assoc] using this",
      "\n  by_cases hY : Y ⊆ V(G)\n  ·\n    let P : Set (Set α) := {X | ν(G - X) = ν(G) - X.encard}\n    obtain ⟨X, hXP, hXmax⟩ := zorn_subset_nonempty (s := P) ?_ ?_\n    · have htb := tutte_berge_of_maximal_vertexDelete (G := G) (X := X) hXmax\n      have hsub : X ⊆ Y := by\n        by_contra hnot\n        have : ¬ Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X := by\n          exact hXmax.ne_iff.2 ⟨Y, by\n            refine ?_, ?_, ?_⟩\n        exact this rfl\n      have hXfin : X.Finite := (Set.finite_of_encard_ne_top (by simp))\n      have hYfin : Y.Finite := (Set.finite_of_encard_ne_top (by simp))\n      have hVfin : V(G).Finite := by simpa [Graph.Finite] using (show V(G).Finite from by\n        simpa using (G := G) (inst✝ := inst✝))\n      have hle : (V(G) \\ X).encard - (G - X).OddComponents.encard ≤\n          (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n        have hVX : (V(G) \\ X).encard ≤ V(G).encard := by\n          simpa using (encard_diff_le (s := V(G)) (t := X))\n        have hodd : (G - Y).OddComponents.encard ≤ (G - X).OddComponents.encard := by\n          simpa using (encard_le_encard (by\n            intro H hH\n            exact hH))\n        have : (V(G) \\ X).encard - (G - X).OddComponents.encard ≤\n            V(G).encard - (G - Y).OddComponents.encard := by\n          exact sub_le_sub hVX (le_trans hodd (le_rfl))\n        exact this.trans (by\n          have : V(G).encard - (G - Y).OddComponents.encard ≤\n              (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n            simpa [add_comm, add_left_comm, add_assoc] using\n              (sub_le_sub_left (Nat.cast_le.mpr (Nat.le_add_left _ _)) _)\n          simpa using this)\n      have hν : 2 * ν(G) ≤ (V(G) \\ X).encard - (G - X).OddComponents.encard := by\n        have := congrArg (fun n ↦ n + 2 * X.encard) htb\n        have hXle : 2 * ν(G) = 2 * ν(G - X) + 2 * X.encard := by\n          have hx : ν(G) = ν(G - X) + X.encard := by\n            have := hXP\n            simpa [P] using this.symm\n          nlinarith\n        nlinarith\n      exact le_trans hν hle\n    · refine ⟨∅, ?_⟩\n      simp [P]\n    · intro c hc hchain\n      refine ⟨⋃₀ c, ?_, ?_⟩\n      ·\n        have hsubV : (⋃₀ c) ⊆ V(G) := by\n          intro x hx\n          rcases mem_sUnion.1 hx with ⟨X, hXc, hxX⟩\n          have : X ⊆ V(G) := by\n            have hxP := hc hXc\n            have : ν(G - X) = ν(G) - X.encard := by simpa [P] using hxP\n            exact by\n              intro y hy\n              exact hY (by\n                have : y ∈ V(G) := by\n                  simpa using (hY (by\n                    have : y ∈ Y := by\n                      exact False.elim (by\n                        have : y ∈ Y := by\n                          sorry\n                        exact this)\n                    exact this))\n                exact this)\n          exact this hxX\n        have : ν(G - (⋃₀ c)) = ν(G) - (⋃₀ c).encard := by\n          simpa using (hc (by\n            have : (⋃₀ c) ∈ P := by\n              sorry\n            exact this))\n        exact this\n      · intro X hXc\n        exact subset_sUnion_of_mem hXc\n  ·\n    have : 2 * ν(G) ≤ V(G).encard + Y.encard := by\n      have hν : ν(G) ≤ V(G).encard := by\n        have : (2 : ℕ∞) * ν(G) ≤ (2 : ℕ∞) * V(G).encard := by\n          exact mul_le_mul_left' (by\n            have : ν(G) ≤ V(G).encard := by\n              sorry\n            exact this) _\n        simpa using (le_of_mul_le_mul_left' this)\n      have : (2 : ℕ∞) * ν(G) ≤ (2 : ℕ∞) * (V(G).encard + Y.encard) := by\n        exact mul_le_mul_left' (by\n          simpa [add_comm, add_left_comm, add_assoc] using le_trans hν (le_add_of_nonneg_right (by simp))) _\n      simpa [mul_add, add_assoc, add_left_comm, add_comm] using this\n    exact le_trans this (by\n      have : (V(G).encard + Y.encard) - (G - Y).OddComponents.encard ≤ V(G).encard + Y.encard := by\n        exact sub_le_self _ (by simp)\n      exact this)",
