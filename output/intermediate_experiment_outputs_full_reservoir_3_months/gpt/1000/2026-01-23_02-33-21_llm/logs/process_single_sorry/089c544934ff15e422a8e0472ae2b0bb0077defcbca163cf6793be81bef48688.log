      simpa using this.trans (by\n              simpa [Nat.cast_one, WithTop.coe_one] using (Finset.sum_const_one_le (s := Y.toFinite.toFinset)))\n          exact hsum.trans this\n        have hpart :\n            M.encard ≤ (M \\ (E(G) ∩ E(G, Y))).encard + (M ∩ (E(G) ∩ E(G, Y))).encard := by\n          classical\n          simpa [Set.diff_eq, inter_assoc, inter_left_comm, inter_comm] using\n            (encard_le_encard_add_encard_diff (A := M) (B := E(G) ∩ E(G, Y)))\n        have := hpart.trans (add_le_add hdel (hcut.trans (le_of_eq rfl)))\n        exact this.trans (by\n          simpa [add_assoc, add_comm, add_left_comm] using (le_rfl : ν(G - Y) + Y.encard ≤ ν(G - Y) + Y.encard))\n      refine le_csSup ?_ ?_\n      · refine ⟨0, ?_⟩\n        refine ⟨∅, ?_, by simp⟩\n        refine ⟨by simp, ?_⟩\n        intro e f he hf hne\n        simpa using (Set.disjoint_empty_left)\n      · intro n hn\n        exact this n hn\n    exact hmon\n  have hodd : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    classical\n    have hmax : ∃ X, Maximal (fun X ↦ ν((G - Y) - X) = ν(G - Y) - X.encard) X := by\n      refine ⟨∅, ?_⟩\n      refine ⟨by simp, ?_⟩\n      intro X hX hXsub\n      have : X = ∅ := by\n        simpa using hXsub.antisymm (by simp)\n      subst this\n      exact hX\n    rcases hmax with ⟨X, hX⟩\n    have := tutte_berge_of_maximal_vertexDelete (G := (G - Y)) (X := X) hX\n    have hle : 2 * ν(G - Y) ≤ (V(G - Y) \\ X).encard - ((G - Y) - X).OddComponents.encard := by\n      simpa [this] using le_of_eq this\n    simpa using hle\n  have : 2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by\n    exact mul_le_mul_left' hsub 2\n  have : 2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n    have hV : (V(G) \\ Y).encard ≤ V(G).encard := by\n      exact encard_le_encard (by intro x hx; exact hx.1)\n    have hineq :\n        (V(G) \\ Y).encard - (G - Y).OddComponents.encard ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by\n