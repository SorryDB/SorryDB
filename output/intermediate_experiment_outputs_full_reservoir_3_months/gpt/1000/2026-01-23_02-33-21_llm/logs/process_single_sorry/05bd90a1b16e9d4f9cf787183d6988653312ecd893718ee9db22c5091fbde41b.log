  theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        classical
        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by
          have : l1[idx1] ∈ l1 := by
            simpa [List.mem_iff_get] using (List.get_mem l1 ⟨idx1, hidx1⟩)
          have : l1[idx1] ∈ (l.set idx l1).flatten := by
            unfold List.flatten
            -- use simp characterization of flatten membership via mem_map/mem_flatten
            simp [List.mem_flatten, List.mem_set] at *
          exact this
        obtain ⟨idx', hget⟩ := in_list_idx (α := α) (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem
        refine ⟨idx', ?_, ?_⟩
        · have : (l.set idx (l1.eraseIdx idx1)).flatten = ((l.set idx l1).flatten).eraseIdx idx' := by
            -- both sides erase the unique occurrence at position idx'
            -- use get equality to rewrite and simp with eraseIdx
            revert l l1 idx idx1 hidx hidx1 hget
            intro l l1 idx idx1 hidx hidx1 hget
            -- reduce to a list-level statement: erasing by index after substituting inside flatten
            -- the witness idx' is chosen such that get idx' equals l1[idx1]
            -- then equality holds by ext/get on indices
            apply List.ext_get
            · simp [List.length_eraseIdx]
            · intro i hi1 hi2
              by_cases hEq : (i : Nat) = idx'.1
              · subst hEq
                -- index falls exactly on erased spot
                simp [List.get?_eraseIdx, Fin.eta, hget]
              ·
                -- indices away from erased spot
                simp [List.get?_eraseIdx, hEq]
          exact this
        · simpa [List.get_eq_getElem] using hget
