leSum : ((List.take idx (l.map List.length)).sum + l1.length)\n              ≤ (l.map List.length).set idx l1.length |>.sum := by\n              -- prefix sum <= total sum\n              have : (List.take (idx + 1) ((l.map List.length).set idx l1.length)).sum\n                    ≤ ((l.map List.length).set idx l1.length).sum := by\n                simpa using (list_take_sum_le (l := (l.map List.length).set idx l1.length) (idx := idx + 1))\n              -- compute take (idx+1) sum as take idx sum + set[idx]\n              have hidx' : idx < ((l.map List.length).set idx l1.length).length := by\n                simpa using hidx\n              have : (List.take idx ((l.map List.length).set idx l1.length)).sum + ((l.map List.length).set idx l1.length)[idx]\n                    = (List.take (idx + 1) ((l.map List.length).set idx l1.length)).sum := by\n                simpa using (list_take_sum (l := (l.map List.length).set idx l1.length) (idx := idx) (hidx := hidx'))\n              have hget : ((l.map List.length).set idx l1.length)[idx] = l1.length := by\n                simp [List.get_set]\n              have : (List.take idx ((l.map List.length).set idx l1.length)).sum + l1.length\n                    ≤ ((l.map List.length).set idx l1.length).sum := by\n                simpa [this, hget] using le_trans (le_of_eq this.symm) this\n              simpa using this\n            have : pos < (l.map List.length).set idx l1.length |>.sum := lt_of_lt_of_le (lt_of_lt_of_le hpos' hleSum) (le_of_eq rfl)\n            simpa [hlenB, pos] using this\n          let idx' : Fin lB.length := ⟨pos, hpos⟩\n          refine ⟨idx', ?_, ?_⟩\n          · -- eraseIdx at pos gives flatten with erased element\n            -- use list_set_flatten to relate inserting the removed element\n            have hflat := list_set_flatten (l := l) (l1 := l1.eraseIdx ⟨idx1, hidx1⟩) (elt := l1[idx1])\n              (idx := idx) (hidx := hidx)\n            have hins : (l.set idx (l1.eraseIdx ⟨idx1, hidx1⟩ ++ [l