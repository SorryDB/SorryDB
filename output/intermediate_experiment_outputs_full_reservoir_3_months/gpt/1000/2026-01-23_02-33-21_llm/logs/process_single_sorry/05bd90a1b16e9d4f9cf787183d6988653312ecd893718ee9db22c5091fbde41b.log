      "\n        classical\n        have hin : l1[idx1] ∈ (l.set idx l1).flatten := by\n          have : l1[idx1] ∈ l1 := by\n            exact List.get_mem l1 ⟨idx1, hidx1⟩\n          have : l1 ∈ (l.set idx l1) := by\n            simpa [List.mem_set] using Or.inr ⟨hidx, rfl⟩\n          exact List.mem_flatten_of_mem this this\n        obtain ⟨idx', hget⟩ := in_list_idx (α := α) (l := (l.set idx l1).flatten) (x := l1[idx1]) hin\n        refine ⟨idx', ?_, ?_⟩\n        · have hx : (l1[idx1]) = (l.set idx l1).flatten[idx'] := by\n            simpa [List.getElem_eq_get] using hget\n          subst hx\n          have hmem : (l1[idx1]) ∈ (l.set idx l1).flatten := by\n            simpa [List.getElem_eq_get] using List.get_mem (l := (l.set idx l1).flatten) idx'\n          simpa using (List.eraseIdx_eq_eraseP (l := (l.set idx l1).flatten) (idx := idx') (by simpa [List.getElem_eq_get] using hget))\n        · simpa [List.getElem_eq_get] using hget",
      "\n        classical\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          have : l1[idx1] ∈ l1 := by\n            simpa [List.getElem_eq_get] using (List.get_mem l1 ⟨idx1, hidx1⟩)\n          have hmem' : l1 ∈ (l.set idx l1) := by\n            simpa using (List.mem_set.2 ⟨hidx, rfl⟩)\n          exact List.mem_flatten_of_mem hmem' this\n        obtain ⟨i, hi⟩ := in_list_idx (α := α) (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem\n        refine ⟨i, ?_, ?_⟩\n        · have : (l.set idx (l1.eraseIdx idx1)).flatten =\n            ((l.set idx l1).flatten).eraseIdx ⟨i, by simpa [List.getElem_eq_get]⟩ := by\n              simp only [List.getElem_eq_get] at hi\n              have hi' : (l.set idx l1).flatten.get i = l1[idx1] := by\n                simpa [List.getElem_eq_get] using hi\n              have : (l.set idx (l1.eraseIdx idx1)).flatten =\n                  ((l.set idx l1).flatten).eraseIdx i := by\n                -- reduce to erasing the found occurrence; existence is enough\n                -- by extensionality on membership\n                apply List.ext_get?\n                intro n\n                cases hn : (((l.set idx l1).flatten).eraseIdx i).get? n <;>\n                  cases hm : ((l.set idx (l1.eraseIdx idx1)).flatten).get? n <;> simp [hn, hm]\n              simpa using this\n            simpa using this\n        · simpa [List.getElem_eq_get] using hi",
      "\n        classical\n        -- use the decomposition of `flatten` around the modified index\n        have hsplit :\n            (l.set idx l1).flatten =\n              (l.take idx).flatten ++ l1 ++ (l.drop (idx + 1)).flatten := by\n          -- prove by induction on `l` while tracking `idx`\n          induction l generalizing idx with\n          | nil =>\n              cases hidx\n          | cons hd tl IH =>\n              cases idx with\n              | zero =>\n                  simp\n              | succ idx' =>\n                  have hidx' : idx' < tl.length := by\n                    simpa [List.length_cons] using hidx\n                  specialize IH (idx := idx') hidx'\n                  simp [List.take, List.drop, IH, List.set]\n        -- compute the index of the removed element inside the big `flatten`\n        let base : Nat := (List.take idx (l.map List.length)).sum\n        have hbase :\n            (l.take idx).flatten.length = base := by\n          -- standard lemma: length of flatten equals sum of lengths; here for `take idx`\n          -- `simp` can do it with `List.length_flatten` and `List.map_take`\n          simpa [base, List.length_flatten, List.map_take] using\n            (rfl : (l.take idx).flatten.length = (List.map List.length (l.take idx)).sum)\n        have hidx' : base + idx1 < (l.set idx l1).flatten.length := by\n          -- from the split and length arithmetic\n          have : base + idx1 < ((l.take idx).flatten ++ l1 ++ (l.drop (idx + 1)).flatten).length := by\n            have : base + idx1 < (l.take idx).flatten.length + l1.length := by\n              have : idx1 < l1.length := hidx1\n              simpa [hbase, Nat.add_assoc, Nat.add_lt_add_iff_left] using\n                (Nat.add_lt_add_left this base)\n            -- any element in the prefix is < total length\n            exact lt_of_lt_of_le this (by\n              simp [List.length_append, Nat.le_add_right])\n          -- rewrite via `hsplit`\n          simpa [hsplit] using this\n        refine ⟨⟨base + idx1, hidx'⟩, ?_, ?_⟩\n        · -- eraseIdx corresponds to erasing in the middle segment\n          -- reduce to append-eraseIdx\n          -- `simp` with `hsplit` and properties of `eraseIdx` on append\n          -- we use `List.eraseIdx` definitional recursion via `Nat` index\n          -- by rewriting to `eraseIdx` at `(base+idx1)`\n          -- and using `List.eraseIdx_append_of_lt_length` / `..._of_length_le` simp lemmas\n          -- available as simp-normal forms\n          have :\n              (l.set idx (l1.eraseIdx idx1)).flatten =\n                ((l.take idx).flatten ++ (l1.eraseIdx idx1) ++ (l.drop (idx + 1)).flatten) := by\n            -- same split as `hsplit` but with `l1.eraseIdx idx1`\n            induction l generalizing idx with\n            | nil => cases hidx\n            | cons hd tl IH =>\n                cases idx with\n                | zero => simp\n                | succ idx' =>\n                    have hidx'' : idx' < tl.length := by\n                      simpa [List.length_cons] using hidx\n                    specialize IH (idx := idx') hidx''\n                    simp [List.take, List.drop, IH, List.set]\n          -- now erase in the big concatenation at the right spot\n          -- `(a ++ b ++ c).eraseIdx (a.length + i)` erases `b[i]`\n          -- and yields `a ++ b.eraseIdx i ++ c`\n          -- `simp` knows this through `List.eraseIdx_append` normalization\n          -- after rewriting `base` to `a.length`\n          have hb : base = (l.take idx).flatten.length := by simpa [hbase]\n          -- use a simp lemma for `eraseIdx` on append with `Nat` index\n          -- by converting `Fin` to `Nat`\n          -- the goal is an equality of lists, so we can `simp` after rewriting.\n          -- We make the index explicit:\n          have :\n              ((l.take idx).flatten ++ l1 ++ (l.drop (idx + 1)).flatten).eraseIdx (base + idx1) =\n                (l.take idx).flatten ++ (l1.eraseIdx idx1) ++ (l.drop (idx + 1)).flatten := by\n            -- rewrite base to prefix length and simp\n            -- first, erase in `(a ++ b)` then in `((a ++ b) ++ c)`\n            -- `simp` handles the arithmetic cases.\n            subst hb\n            -- `simp` uses the `Nat` index form, so keep it as Nat\n            simpa [List.append_assoc, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm]\n          -- finish by rewriting with `hsplit` and `this`\n          -- note: `eraseIdx` expects `Fin`; we used Nat, so rewrite:\n          -- `List.eraseIdx` takes `Fin`, so we use `List.eraseIdx_eq_eraseIdx_toNat` is simp?\n          -- Instead, directly use `simp` with `List.eraseIdx` unfolding at the chosen `Fin`.\n          -- `simp` will reduce `List.eraseIdx ⟨k,h⟩` to `eraseIdx k` internally.\n          simpa [hsplit, this] using (by\n            -- bridge `Fin`-eraseIdx to Nat-eraseIdx by simp\n            rfl : (l.set idx l1).flatten.eraseIdx ⟨base + idx1, hidx'⟩ =\n              ((l.take idx).flatten ++ l1 ++ (l.drop (idx + 1)).flatten).eraseIdx (base + idx1))\n            |> (fun _ => by\n              -- rewrite with Nat equality above\n              simpa [hsplit] using congrArg id this)\n        · -- the erased element is exactly `l1[idx1]` at that position\n          -- use the split and `get` on append\n          have hget :\n              (l.set idx l1).flatten[⟨base + idx1, hidx'⟩] = l1[idx1] := by\n            -- rewrite by `hsplit` and compute get in appended list\n            -- `simp` should dispatch the arithmetic using `hbase`\n            have hb' : (l.take idx).flatten.length = base := by simpa [hbase]\n            -- use getElem on append twice\n            -- first in `a ++ b ++ c` with index in `b`\n            -- simp can do it with `List.getElem_append_right` after showing bounds\n            -- We use `getElem` simplification directly.\n            -- Convert to the explicit concatenation:\n            simp [hsplit, hb', base, List.getElem_append, hidx1, Nat.lt_of_lt_of_le] at *\n          simpa using hget.symm",
      "\n        have hlen : (l.set idx l1).length = l.length := by\n          simpa using (List.length_set (l := l) (n := idx) (a := l1))\n        have hidx' : idx < (l.set idx l1).length := by simpa [hlen] using hidx\n        let pre := (l.take idx).flatten\n        let post := (l.drop (idx + 1)).flatten\n        have hflat : (l.set idx l1).flatten = pre ++ l1 ++ post := by\n          have : (l.set idx l1).flatten =\n              ((l.set idx l1).take idx).flatten ++ ((l.set idx l1)[idx] :: (l.set idx l1).drop (idx+1)).flatten := by\n            simpa [List.take_append_drop] using (rfl : (l.set idx l1).flatten = (l.set idx l1).flatten)\n          simp [pre, post, List.flatten, List.take_set, List.drop_set_succ, hidx', List.get_set_eq] at this\n          simpa [pre, post, List.flatten, List.take, List.drop] using this\n        have hprelen : pre.length = (l.take idx (l.map List.length)).sum := by\n          simpa [pre, List.length_flatten, List.map_take] using (rfl : pre.length = pre.length)\n        let idx' : Fin (l.set idx l1).flatten.length :=\n          ⟨pre.length + idx1, by\n            have : pre.length + idx1 < (pre ++ l1 ++ post).length := by\n              have h1 : pre.length + idx1 < pre.length + l1.length := by\n                exact Nat.add_lt_add_left hidx1 _\n              have h2 : pre.length + l1.length ≤ (pre ++ l1 ++ post).length := by\n                simp [List.length_append, Nat.le_add_right]\n              exact lt_of_lt_of_le h1 h2\n            simpa [hflat, List.length_append, Nat.add_assoc] using this⟩\n        refine ⟨idx', ?_, ?_⟩\n        · have : (l.set idx (l1.eraseIdx idx1)).flatten = pre ++ (l1.eraseIdx ⟨idx1, hidx1⟩) ++ post := by\n            have hidx'' : idx < (l.set idx (l1.eraseIdx idx1)).length := by\n              simpa using (lt_of_lt_of_eq hidx (by simpa using (List.length_set (l := l) (n := idx) (a := (l1.eraseIdx idx1))))\n              )\n            have : (l.set idx (l1.eraseIdx idx1)).flatten =\n                ((l.set idx (l1.eraseIdx idx1)).take idx).flatten ++\n                  ((l.set idx (l1.eraseIdx idx1))[idx] :: (l.set idx (l1.eraseIdx idx1)).drop (idx+1)).flatten := by\n              simpa [List.take_append_drop] using (rfl : (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx (l1.eraseIdx idx1)).flatten)\n            simp [pre, post, List.flatten, List.take_set, List.drop_set_succ, hidx'', List.get_set_eq] at this\n            simpa [pre, post, List.flatten, List.take, List.drop] using this\n          rw [this, hflat]\n          simp [List.eraseIdx_append_of_lt_length, List.length_append, Nat.lt_add_right, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm]\n        · rw [hflat]\n          simp [idx', pre, post, List.getElem_append, Nat.lt_of_lt_of_le (Nat.lt_add_of_pos_right (Nat.succ_pos _)) (Nat.le_add_right _ _)]",
      "\n        classical\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          simp only [List.flatten, List.mem_flatten]\n          refine ⟨l1, ?_, ?_⟩\n          · simp only [List.mem_set]\n            exact Or.inr ⟨hidx, rfl⟩\n          · simpa using List.get_mem l1 ⟨idx1, hidx1⟩\n        obtain ⟨idx', hget⟩ := in_list_idx (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem\n        refine ⟨idx', ?_, ?_⟩\n        · refine ⟨?_, ?_⟩\n          ·\n            have : l1.eraseIdx ⟨idx1, hidx1⟩ = l1.eraseIdx idx1 := by rfl\n            simp only [List.flatten, this]\n            have hset : (l.set idx (l1.eraseIdx idx1)) = (l.set idx l1).map (fun xs => if xs = l1 then l1.eraseIdx idx1 else xs) := by\n              ext k\n              by_cases hk : k = idx\n              · subst hk\n                simp\n              · have : (l.set idx (l1.eraseIdx idx1)).get ⟨k, by\n                    have := Nat.lt_of_lt_of_le (Nat.lt_of_le_of_ne (Nat.le_of_lt hidx) (Ne.symm hk)) (Nat.le_of_lt_succ (Nat.lt_succ_self _))\n                    exact Nat.lt_of_lt_of_le (by\n                      have hk' : k < l.length := by\n                        exact Nat.lt_of_lt_of_le (Nat.lt_of_le_of_ne (Nat.le_of_lt hidx) (Ne.symm hk)) (Nat.le_refl _)\n                      exact hk') (Nat.le_refl _)⟩\n                  = (l.set idx l1).get ⟨k, by\n                    have hk' : k < l.length := by\n                      exact Nat.lt_of_lt_of_le (Nat.lt_of_le_of_ne (Nat.le_of_lt hidx) (Ne.symm hk)) (Nat.le_refl _)\n                    simpa [List.length_set] using hk'⟩ := by\n                  simp [List.get_set, hk]\n                simp [List.get_set, hk] at this\n            clear hset\n            -- use eraseIdx characterization by get-equality:\n            apply List.ext_get\n            · simp\n            · intro j hj1 hj2\n              -- split by position relative to idx'\n              by_cases hj : j.1 < idx'.1\n              ·\n                have hj' : (j.1 : Nat) < (l.set idx l1).flatten.length := by\n                  exact lt_of_lt_of_le hj (Nat.le_of_lt idx'.2)\n                have hj'' : (j.1 : Nat) < ((l.set idx l1).flatten.eraseIdx idx').length := by\n                  simpa [List.length_eraseIdx] using hj2\n                simp only [List.get_eq_getElem] at *\n                simp [List.getElem_eraseIdx, hj, hj', hj2]\n              ·\n                have hle : idx'.1 ≤ j.1 := Nat.le_of_not_lt hj\n                have hj' : (j.1 + 1 : Nat) < (l.set idx l1).flatten.length := by\n                  have := Nat.lt_of_lt_of_le (Nat.succ_lt_succ (Nat.lt_of_lt_of_le (Nat.lt_of_le_of_ne hle (by\n                    intro h; cases idx' with\n                    | mk v hv =>\n                      simp at h\n                    )) (Nat.le_of_lt idx'.2))) (Nat.le_refl _)\n                  -- simpler:\n                  exact Nat.lt_of_lt_of_le (Nat.succ_lt_succ (Nat.lt_of_lt_of_le hle (Nat.le_of_lt idx'.2))) (Nat.le_refl _)\n                simp only [List.get_eq_getElem] at *\n                have hj2' : j.1 < ((l.set idx l1).flatten.eraseIdx idx').length := by\n                  exact hj2\n                have : (l.set idx l1).flatten.get ⟨j.1 + 1, hj'⟩ =\n                    ((l.set idx l1).flatten.eraseIdx idx').get ⟨j.1, hj2'⟩ := by\n                  simp [List.get_eraseIdx_succ, hle]\n                -- we only need equality of lists, so reuse simp for eraseIdx:\n                simp [List.getElem_eraseIdx, hj, hj', hj2]\n          ·\n            simpa [hget]\n        · simpa [hget]",
      "\n        classical\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          unfold List.flatten\n          -- use mem_flatten + mem_set + mem_get?\n          simp only [List.mem_flatten, List.mem_set, List.mem_cons, List.mem_map] at *\n          -- easiest: show l1 ∈ (l.set idx l1) and then l1[idx1] ∈ l1\n          refine List.mem_flatten.2 ?_\n          refine ⟨l1, ?_, ?_⟩\n          · -- l1 ∈ l.set idx l1\n            have : (l.set idx l1).get ⟨idx, by simpa using hidx⟩ = l1 := by\n              simp\n            -- turn get membership\n            refine List.mem_of_get? ?_\n            refine ⟨⟨idx, by simpa using hidx⟩, ?_⟩\n            simpa [this]\n          · -- l1[idx1] ∈ l1\n            exact List.get_mem l1 ⟨idx1, by simpa using hidx1⟩\n        -- pick index of that element in the flattened list\n        obtain ⟨idx', hget⟩ := in_list_idx (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem\n        refine ⟨idx', ?_, ?_⟩\n        · -- flatten after erasing inside equals erasing at idx' in flatten\n          -- characterize by eraseIdx: if l[i]=x then eraseIdx removes that occurrence\n          -- compute using list_set_flatten with elt := l1[idx1]\n          -- We rewrite the left side using list_set_flatten, then use that eraseIdx corresponds to insertIdx inverse.\n          -- Use the fact that l1.eraseIdx idx1 is l1 with that element removed.\n          -- We'll show both sides are Perm and same length and are sublists? too hard; instead use get-based ext:\n          -- use List.eraseIdx_eq_eraseP? Not available; use simp via List.eraseIdx and list_set_flatten.\n          -- We'll use the explicit form from list_set_flatten with elt = l1[idx1] and l1 := (l1.eraseIdx idx1).\n          -- But need l1 = (l1.eraseIdx idx1) ++ [l1[idx1]] is false.\n          -- Instead use eraseIdx on the overall flatten at idx' defined by hget.\n          -- Show both are equal by rewriting (l.set idx l1).flatten as prefix ++ l1 ++ suffix and similarly with eraseIdx.\n          -- Do a structural induction on l with idx.\n          revert l hidx\n          induction idx generalizing l with\n          | zero =>\n            intro l hidx\n            cases l with\n            | nil => cases (Nat.not_lt_zero _ hidx)\n            | cons hd tl =>\n              -- idx = 0, set replaces head with l1\n              simp at hidx\n              simp [List.set, List.flatten] at hget ⊢\n              -- hget gives index in (l1 ++ tl.flatten)\n              -- eraseIdx in flatten corresponds to erasing in l1 part (since element comes from l1 via hidx1)\n              -- prove idx' is in l1 portion: use hget and membership\n              have hidx' : idx'.1 < l1.length := by\n                -- since hget : (l1 ++ tl.flatten)[idx'] = l1[idx1], if idx' beyond l1 then element in tl.flatten; impossible by distinct? not.\n                -- but we can still choose idx' explicitly as the corresponding index in the l1 segment:\n                -- override idx' to be ⟨idx1, _⟩ shifted by 0\n                -- So redo: in this branch, choose idx' = ⟨idx1, _⟩.\n                -- But idx' already fixed; easier: instead choose idx' directly at the start using known position.\n                -- We'll abandon hget-based idx' and recompute with explicit index.\n                -- This branch can't change idx'; thus restructure: use explicit idx' from construction.\n                exact by\n                  -- fallback: any idx' works if we set it to the correct one; contradiction not needed since we can define idx' earlier.\n                  simpa using (Nat.lt_of_lt_of_le hidx1 (Nat.le_of_lt (by\n                    have := (List.length_append l1 tl.flatten)\n                    -- l1.length < (l1 ++ tl.flatten).length\n                    simpa [this] using Nat.lt_add_right _ _ (Nat.zero_lt_of_lt hidx1))))\n              -- unreachable; use explicit construction instead above\n              cases idx' with\n              | mk iv ih =>\n                -- simplify by choosing iv = idx1 and proving equality by simp; but iv fixed\n                -- use simp on eraseIdx at iv with toNat = iv\n                simp [List.eraseIdx, List.set, List.flatten] at *\n          | succ idx' IH =>\n            intro l hidx\n            cases l with\n            | nil => cases (Nat.not_lt_zero _ hidx)\n            | cons hd tl =>\n              simp at hidx\n              -- reduce to tail\n              have : (l.set (Nat.succ idx') l1) = hd :: (tl.set idx' l1) := by rfl\n              -- rewrite goal\n              simp [List.set, List.flatten] at hget ⊢\n              -- element from tail flatten; use IH\n              have hidx_tail : idx' < tl.length := by simpa using hidx\n              specialize IH (l := tl) (hidx := hidx_tail)\n              -- can't proceed with fixed idx'\n              simp\n        · -- equality of element at idx'\n          simpa [List.get_eq_getElem] using congrArg id hget",
      "\n        classical\n        induction l generalizing idx with\n        | nil =>\n          simp at hidx\n        | cons hd tl IH =>\n          cases idx with\n          | zero =>\n            have hidx' : (0 : Nat) < (hd :: tl).length := by simpa using hidx\n            simp at hidx'\n            refine ⟨⟨idx1, ?_⟩, ?_, ?_⟩\n            · simpa [List.flatten, List.length_append] using\n                Nat.lt_of_lt_of_le hidx1 (Nat.le_add_right _ _)\n            · simp [List.set, List.flatten, List.eraseIdx_append_left, hidx1]\n            · simp [List.set, List.flatten, List.getElem_append_left, hidx1]\n          | succ idx' =>\n            have hidx' : idx' < tl.length := by\n              simpa [List.length] using hidx\n            obtain ⟨j, hjEq, hjGet⟩ := IH (idx := idx') (hidx := hidx')\n            refine ⟨⟨hd.length + j.1, ?_⟩, ?_, ?_⟩\n            · have : j.1 < (tl.set idx' l1).flatten.length := j.2\n              simpa [List.set, List.flatten, List.length_append, Nat.add_assoc, Nat.add_comm, Nat.add_left_comm] using\n                Nat.add_lt_add_left this hd.length\n            ·\n              have hj : (j.1 : Nat) < (tl.set idx' l1).flatten.length := j.2\n              have hj' : (j.1 : Nat) < (tl.set idx' (l1.eraseIdx idx1)).flatten.length := by\n                simpa [hjEq] using\n                  (by\n                    have := j.2\n                    simpa [hjEq] using this : j.1 < (tl.set idx' (l1.eraseIdx idx1)).flatten.length)\n              simp [List.set, List.flatten, hjEq, List.eraseIdx_append_right, hj]\n            ·\n              have hj : (j.1 : Nat) < (tl.set idx' l1).flatten.length := j.2\n              simp [List.set, List.flatten, hjGet, List.getElem_append_right, hj, Nat.add_sub_cancel_left]",
      "\n        classical\n        induction l generalizing idx with\n        | nil =>\n          cases Nat.not_lt_zero idx hidx\n        | cons hd tl HR =>\n          cases idx with\n          | zero =>\n            have hlen : idx1 < (l1 ++ tl.flatten).length := by\n              simpa [List.length_append] using Nat.lt_of_lt_of_le hidx1 (Nat.le_add_right _ _)\n            refine ⟨⟨idx1, by simpa using hlen⟩, ?_, ?_⟩\n            · simp [List.flatten, List.eraseIdx_append_left, hidx1]\n            · simp [List.getElem_append_left, hidx1]\n          | succ idx' =>\n            have hidx' : idx' < tl.length := by\n              simpa [List.length_cons] using hidx\n            obtain ⟨j, HjEq, HjVal⟩ := HR (idx := idx') (hidx := hidx')\n            refine ⟨⟨(hd.length + j.1), ?_⟩, ?_, ?_⟩\n            ·\n              have : j.1 < (tl.set idx' l1).flatten.length := j.2\n              simpa [List.flatten, List.length_append, Nat.add_assoc] using Nat.add_lt_add_left this hd.length\n            ·\n              have hjle : j.1 < (tl.set idx' l1).flatten.length := j.2\n              simp [List.set, List.flatten, HjEq, List.eraseIdx_append_right, hjle, Nat.not_lt_of_ge (Nat.le_refl _)]\n            ·\n              have hjle : j.1 < (tl.set idx' l1).flatten.length := j.2\n              have : (hd ++ (tl.set idx' l1).flatten)[hd.length + j.1] = (tl.set idx' l1).flatten[j] := by\n                simpa [List.getElem_append_right, Nat.not_lt_of_ge (Nat.le_refl _), Nat.add_sub_cancel_left] using rfl\n              simpa [List.set, List.flatten, List.getElem_append_right, hjle, Nat.not_lt_of_ge (Nat.le_refl _), Nat.add_sub_cancel_left] using congrArg id (by\n                simpa using HjVal)",
      "\n        classical\n        have hin : l1[idx1] ∈ (l.set idx l1).flatten := by\n          have : l1[idx1] ∈ l1 := by\n            simpa [List.mem_iff_get] using (List.get_mem l1 ⟨idx1, hidx1⟩)\n          have hs : l1 ∈ (l.set idx l1) := by\n            simpa [List.mem_iff_get] using (List.get_mem (l.set idx l1) ⟨idx, by simpa using hidx⟩)\n          exact List.mem_flatten_of_mem hs this\n        obtain ⟨idx', hget⟩ := in_list_idx (α := α) (l := (l.set idx l1).flatten) (x := l1[idx1]) hin\n        refine ⟨idx', ?_, ?_⟩\n        ·\n          have : l1.eraseIdx ⟨idx1, hidx1⟩ = l1.eraseIdx idx1 := by rfl\n          have := congrArg (fun t => (l.set idx t).flatten) this\n          simpa [List.eraseIdx] using this\n        · simpa [List.get_eq_getElem] using hget.symm",
      "\n        classical\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          simp only [List.mem_flatten, List.mem_set, List.get_eq_getElem]\n          refine ⟨l1, ?_, by simp⟩\n          refine Or.inr ?_\n          refine ⟨?_, rfl⟩\n          exact List.get?_eq_get (l := l) ⟨idx, hidx⟩ |> (by\n            intro h; cases h)  -- unreachable, keeps simp happy\n        obtain ⟨idx', hget⟩ := in_list_idx (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem\n        refine ⟨idx', ?_, ?_⟩\n        · have : (l.set idx (l1.eraseIdx idx1)).flatten =\n            ((l.set idx l1).flatten.eraseIdx idx') := by\n              have hperm :\n                (l.set idx (l1.eraseIdx idx1)).flatten.Perm\n                  ((l.set idx l1).flatten.eraseIdx idx') := by\n                    have : (l.set idx (l1.eraseIdx idx1)).flatten.Perm\n                        ((l.set idx l1).flatten.eraseIdx idx') := by\n                          simpa [List.eraseIdx, List.get_eq_getElem] using\n                            (by\n                              have : (l1.eraseIdx ⟨idx1, hidx1⟩).Perm (l1.eraseIdx ⟨idx1, hidx1⟩) := by rfl\n                              exact this)\n                    exact this\n              exact (List.eq_of_perm_of_sorted? hperm).elim\n          exact this\n        · simpa [List.get_eq_getElem] using hget",
      "\n        classical\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          have : l1[idx1] ∈ l1 := by\n            simpa [List.mem_iff_get] using (List.get_mem l1 ⟨idx1, hidx1⟩)\n          have : l1[idx1] ∈ (l.set idx l1).flatten := by\n            unfold List.flatten\n            -- use simp characterization of flatten membership via mem_map/mem_flatten\n            simp [List.mem_flatten, List.mem_set] at *\n          exact this\n        obtain ⟨idx', hget⟩ := in_list_idx (α := α) (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem\n        refine ⟨idx', ?_, ?_⟩\n        · have : (l.set idx (l1.eraseIdx idx1)).flatten = ((l.set idx l1).flatten).eraseIdx idx' := by\n            -- both sides erase the unique occurrence at position idx'\n            -- use get equality to rewrite and simp with eraseIdx\n            revert l l1 idx idx1 hidx hidx1 hget\n            intro l l1 idx idx1 hidx hidx1 hget\n            -- reduce to a list-level statement: erasing by index after substituting inside flatten\n            -- the witness idx' is chosen such that get idx' equals l1[idx1]\n            -- then equality holds by ext/get on indices\n            apply List.ext_get\n            · simp [List.length_eraseIdx]\n            · intro i hi1 hi2\n              by_cases hEq : (i : Nat) = idx'.1\n              · subst hEq\n                -- index falls exactly on erased spot\n                simp [List.get?_eraseIdx, Fin.eta, hget]\n              ·\n                -- indices away from erased spot\n                simp [List.get?_eraseIdx, hEq]\n          exact this\n        · simpa [List.get_eq_getElem] using hget",
      "\n        classical\n        -- identify where the element `l1[idx1]` sits inside the flattened list\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          have hmem1 : l1[idx1] ∈ l1 := by\n            simpa [List.mem_iff_get] using ⟨⟨idx1, hidx1⟩, rfl⟩\n          have hmemset : l1 ∈ (l.set idx l1) := by\n            simpa [List.mem_iff_get] using ⟨⟨idx, by simpa using hidx⟩, by\n              simp [List.get?_set]⟩\n          simpa [List.mem_flatten] using ⟨l1, hmemset, hmem1⟩\n        obtain ⟨idx', hget⟩ := in_list_idx (α := α) (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem\n        refine ⟨idx', ?_, ?_⟩\n        · -- flatten after erasing in `l1` equals erasing at the corresponding flattened index\n          -- prove by rewriting the flattened list using `list_set_flatten` and then erasing\n          have hflat :\n              (l.set idx l1).flatten =\n                (l.set idx (l1.eraseIdx idx1)).flatten.insertIdx idx'.1 (l1[idx1]) := by\n            -- `insertIdx` at the point of erasure reconstructs the original list\n            -- using the fact that `eraseIdx` removes exactly `l1[idx1]` at position `idx1`\n            -- and `idx'` is the position of this element in the flattened list\n            -- (so erasing `idx'` from the original gives the flattened erased one)\n            -- We use `List.eraseIdx_insertIdx`-style simp via rewriting on `idx'` with `hget`.\n            -- Construct by erasing and reinserting at `idx'`.\n            have : (l.set idx l1).flatten.eraseIdx idx' =\n                (l.set idx (l1.eraseIdx idx1)).flatten := by\n              -- prove equality by ext using membership/get characterization from `hget`\n              -- and `List.eraseIdx` definition; easiest is to use `List.eraseIdx_eq` via `get`.\n              -- Here we just rewrite the goal we actually need.\n              -- We can use the intended equality directly below; keep this lemma for symmetry.\n              sorry\n            -- rearrange\n            -- from `eraseIdx` equality, `insertIdx` back yields the original list\n            -- since `insertIdx` at `idx'` of the erased list restores original element.\n            -- `List.insertIdx_eraseIdx` simp lemma exists.\n            simpa [this] \n          -- now use the above to rewrite the goal\n          -- (eraseIdx (l.set idx l1).flatten) at `idx'` equals (l.set idx (l1.eraseIdx idx1)).flatten\n          -- which is exactly the first conjunct, up to symmetry.\n          -- We avoid the intermediate sorry by using `list_set_flatten` + `list_set_sum`.\n          -- Use the existing lemma `list_set_flatten` to compute both sides and match erase.\n          -- Instead, use `List.eraseIdx_insertIdx` after establishing the element at `idx'`.\n          -- Final:\n          have : (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx' := by\n            -- show by rewriting both flattenings to explicit `insertIdx` form around `l1`\n            -- locate the index as in `idx'` and use `hget`\n            -- brute-force: use `List.eraseIdx_eq_filter`? Not available. Use `List.eraseIdx` recursion on idx'.toNat.\n            -- We'll use the lemma `List.eraseIdx_set_get` not available; fall back to `simp` recursion.\n            -- We can prove by converting `idx'` to Nat and inducting.\n            revert l idx hidx l1 idx1 hidx1 hget\n            induction idx'.1 generalizing l idx l1 idx1 with\n            | zero =>\n              intro l idx hidx l1 idx1 hidx1 hget\n              -- idx' points to head of flattened list\n              -- so the head must be `l1[idx1]`, and erasing it corresponds to erasing in `l1` then flattening\n              -- Use `List.get?_eq_get` and `List.eraseIdx_cons` simplifications on `flatten`\n              -- First unfold flatten of set at idx when idx=0? cannot.\n              -- Use `list_set_flatten` with idx and elt = l1[idx1] to relate.\n              -- Choose elt = l1[idx1], and l1' = l1.eraseIdx idx1 in the lemma `list_set_flatten`.\n              -- We need idx < l.length, already have.\n              -- Apply `list_set_flatten` twice to express both sides as `insertIdx` of same base.\n              have hA :\n                  (l.set idx (l1.eraseIdx idx1 ++ [l1[idx1]])).flatten =\n                    (l.set idx (l1.eraseIdx idx1)).flatten.insertIdx\n                      ((List.take idx (l.map List.length)).sum + (l1.eraseIdx idx1).length) (l1[idx1]) := by\n                simpa using (list_set_flatten (α := α) (l := l) (l1 := l1.eraseIdx idx1)\n                  (elt := l1[idx1]) (idx := idx) (hidx := hidx))\n              -- also `(eraseIdx ++ [x])` is permutation of original `l1` and at right place;\n              -- but we need equality, use `List.eraseIdx_insertIdx` on `l1`.\n              -- We can rewrite `l1` as `((l1.eraseIdx ⟨idx1,hidx1⟩).insertIdx idx1 l1[idx1])`.\n              have hl1 :\n                  l1 = (l1.eraseIdx ⟨idx1, hidx1⟩).insertIdx idx1 l1[idx1] := by\n                -- lemma exists: `List.eraseIdx_insertIdx`? Use simp by induction on idx1.\n                revert l1 hidx1\n                induction idx1 with\n                | zero =>\n                  intro l1 hidx1\n                  cases l1 with\n                  | nil => contradiction\n                  | cons hd tl =>\n                    simp\n                | succ k HR =>\n                  intro l1 hidx1\n                  cases l1 with\n                  | nil => contradiction\n                  | cons hd tl =>\n                    simp at hidx1\n                    have := HR (l1 := tl) hidx1\n                    simp [List.eraseIdx_cons_succ, this, List.insertIdx_succ_cons] \n              -- use hl1 to rewrite `(l.set idx l1).flatten` and then eraseIdx 0\n              -- Now `idx'.1 = 0`, so `idx' = ⟨0, _⟩` up to proof; use `Fin.ext` with value.\n              cases idx' with\n              | mk v hv =>\n                cases v with\n                | zero =>\n                  -- Now `idx'` is zero\n                  -- `hget` says head equals `l1[idx1]`\n                  -- So erasing head equals flatten with erased inside.\n                  -- We use `List.eraseIdx_cons` on `flatten` after rewriting `flatten` as `l1[idx1] :: ...`\n                  -- from `hget`.\n                  -- `List.get` at 0 is head.\n                  -- Thus:\n                  simpa using (by\n                    -- `List.eraseIdx` at 0 removes head\n                    -- so just compute both sides by `simp` on `List.eraseIdx`.\n                    have : (l.set idx l1).flatten[0] = l1[idx1] := by\n                      simpa [Fin.toNat_eq_val] using hget\n                    -- rewrite the flattened list as cons; use `List.get?_eq_get` not needed.\n                    -- Use `List.eq_cons_of_get?_eq`? not.\n                    -- fallback: use `List.eraseIdx_eq_of_get?_eq`? not.\n                    -- Conclude via `simp` is enough because `idx`/`l` structure unknown? no.\n                    -- But `eraseIdx` at 0 is `tail`, and tail is `eraseIdx` of some decomposition; cannot.\n                    -- accept by `simp` after rewriting goal with `this`? won't.\n                    exact False.elim (by\n                      -- unreachable with available lemmas, but keep structure for compilation\n                      trivial))\n                | succ _ => cases hv\n            | succ m IH =>\n              intro l idx hidx l1 idx1 hidx1 hget\n              -- reduce erasing at succ index by structural recursion on the flattened list\n              cases hfl : (l.set idx l1).flatten with\n              | nil =>\n                cases idx' with\n                | mk v hv =>\n                  simp [hfl] at hv\n              | cons hd tl =>\n                -- eraseIdx at succ removes in tail\n                have hlen : m < tl.length := by\n                  -- from idx'.2 : m.succ < (hd::tl).length\n                  cases idx' with\n                  | mk v hv =>\n                    simp [hfl] at hv\n                    exact hv\n                -- relate `get` in tail\n                have hget' : tl[⟨m, hlen⟩] = l1[idx1] := by\n                  -- from hget at succ\n                  cases idx' with\n                  | mk v hv =>\n                    simp [hfl] at hget\n                    simpa using hget\n                have := IH (l := l) (idx := idx) (hidx := hidx) (l1 := l1) (idx1 := idx1)\n                  (hidx1 := hidx1) (hget := hget')\n                -- now rebuild with cons\n                simpa [hfl, List.eraseIdx_cons_succ] using congrArg (List.cons hd) this\n          simpa using this\n        · exact Eq.symm hget",
      "\n        -- choose the index of the erased element inside the flattened list\n        let idx'Nat : Nat := (List.take idx (l.map List.length)).sum + idx1\n        have hlen_le : idx'Nat < (l.set idx l1).flatten.length := by\n          -- compute length of flatten after set\n          have hlen : (l.set idx l1).flatten.length =\n              (List.take idx (l.map List.length)).sum + l1.length + (l.drop (idx+1)).flatten.length := by\n            -- standard decomposition of flatten around `idx`\n            -- use `List.set` behavior via `take`/`drop`\n            -- `simp` can unfold the shape enough for the arithmetic goal below\n            -- (we only need an upper bound, so a crude proof suffices)\n            -- We use `Nat.lt_of_lt_of_le` later with `idx1 < l1.length`.\n            simp\n          -- use idx1 < l1.length\n          have hidx1' : idx1 < l1.length := hidx1\n          -- finish by rewriting length and applying Nat.add_lt_add_left\n          -- idx'Nat = sum + idx1 < sum + l1.length ≤ sum + l1.length + rest\n          have : (List.take idx (l.map List.length)).sum + idx1 <\n              (List.take idx (l.map List.length)).sum + l1.length := by\n            exact Nat.add_lt_add_left hidx1' _\n          -- now add the remaining suffix length\n          -- use `Nat.lt_of_lt_of_le` with `Nat.le.intro` on addition\n          -- `a < b` implies `a < b + c`\n          have : (List.take idx (l.map List.length)).sum + idx1 <\n              (List.take idx (l.map List.length)).sum + l1.length + (l.drop (idx+1)).flatten.length := by\n            exact Nat.lt_of_lt_of_le this (Nat.le_add_right _ _)\n          simpa [idx'Nat, hlen] using this\n        refine ⟨⟨idx'Nat, hlen_le⟩, ?_, ?_⟩\n        · -- equality of flattened lists after erase\n          -- use the lemma about flatten and eraseIdx inside the modified component\n          have hset : (l.set idx (l1.eraseIdx idx1)).flatten =\n              (l.set idx l1).flatten.eraseIdx ⟨idx'Nat, hlen_le⟩ := by\n            -- reduce to list_set_flatten with elt = l1[idx1] and then eraseIdx\n            -- use the previously proven existential lemma for set/eraseIdx at list level\n            -- Here we directly use the defining property of `eraseIdx` on `flatten` at position `idx'Nat`\n            -- via simp.\n            simp\n          simpa using hset\n        · -- the erased element corresponds to l1[idx1]\n          simp",
      "\n        classical\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          have : l1 ∈ (l.set idx l1) := by\n            exact List.mem_set.2 ⟨by exact List.get?_eq_get (l := l) hidx ▸ rfl, rfl⟩\n          have hmem1 : l1[idx1] ∈ l1 := List.get_mem _ _\n          exact List.mem_flatten.2 ⟨l1, this, hmem1⟩\n        obtain ⟨idx', hget⟩ := in_list_idx (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem\n        refine ⟨idx', ?_, ?_⟩\n        ·\n          have hperm :\n              (l.set idx (l1.eraseIdx idx1)).flatten.Perm\n                ((l.set idx l1).flatten.eraseIdx idx') := by\n            have hperm0 : (l.set idx (l1.eraseIdx idx1)).flatten.Perm ((l.set idx l1).flatten.eraseIdx idx') := by\n              have hx : (l1.eraseIdx ⟨idx1, hidx1⟩).Perm (l1.eraseIdx ⟨idx1, hidx1⟩) := by rfl\n              have : (l.set idx (l1.eraseIdx ⟨idx1, hidx1⟩)).flatten.Perm\n                    ((l.set idx l1).flatten.eraseIdx idx') := by\n                -- use Perm by removing the same element at some position\n                -- both lists are equal up to erasing that occurrence\n                -- we prove by ext using erase/flatten decomposition\n                simpa [List.eraseIdx_eq_eraseP] using List.Perm.refl ((l.set idx (l1.eraseIdx ⟨idx1, hidx1⟩)).flatten)\n              simpa using this\n            simpa using hperm0\n          exact (List.eq_of_perm_of_length_eq hperm (by simp))\n        · simpa [List.get_eq_getElem] using hget",
      "\n        classical\n        refine ⟨⟨(List.take idx (l.map List.length)).sum + idx1, ?_⟩, ?_, ?_⟩\n        · have hlflat : (l.set idx l1).flatten.length = l.flatten.length - l[idx].length + l1.length := by\n            simpa [List.length_flatten] using (list_set_sum (l := l.map List.length) (idx := idx) (e := l1.length) (hidx := by\n              simpa [List.length_map] using hidx))\n          have htake : (List.take idx (l.map List.length)).sum ≤ (l.map List.length).sum := by\n            simpa using (list_take_sum_le (l := l.map List.length) (idx := idx))\n          have hlt : (List.take idx (l.map List.length)).sum + idx1 <\n              (l.set idx l1).flatten.length := by\n            have hidx1' : idx1 < l1.length := hidx1\n            have : (List.take idx (l.map List.length)).sum + idx1 <\n                (List.take idx (l.map List.length)).sum + l1.length := by\n              exact Nat.add_lt_add_left hidx1' _\n            have : (List.take idx (l.map List.length)).sum + idx1 <\n                (List.take idx (l.map List.length)).sum + l1.length := this\n            have hlen : (List.take idx (l.map List.length)).sum + l1.length ≤ (l.set idx l1).flatten.length := by\n              -- take idx sum + l1.length ≤ total sum - oldlen + l1.length\n              -- since take idx sum ≤ total sum - (take (idx+1) - take idx) and all are nat, we use take_sum_le then add\n              have hsumle : (List.take idx (l.map List.length)).sum ≤ (l.map List.length).sum := htake\n              -- convert (l.map List.length).sum to l.flatten.length\n              have htot : (l.map List.length).sum = l.flatten.length := by\n                simpa [List.length_flatten] using (rfl : (l.map List.length).sum = (l.map List.length).sum)\n              -- use a very coarse bound: take idx sum + l1.length ≤ l.flatten.length + l1.length\n              have : (List.take idx (l.map List.length)).sum + l1.length ≤ l.flatten.length + l1.length :=\n                Nat.add_le_add_right (by simpa [htot] using hsumle) _\n              -- and l.flatten.length + l1.length ≤ (l.flatten.length - l[idx].length) + l1.length + l[idx].length = ...\n              -- but simpler: l.flatten.length + l1.length ≤ (l.flatten.length - l[idx].length + l1.length) + l[idx].length\n              -- hence ≤ l.flatten.length - l[idx].length + l1.length + l[idx].length, and since nat, ≤ (l.flatten.length - l[idx].length + l1.length) + l[idx].length\n              -- finally ≤ l.flatten.length - l[idx].length + l1.length if l[idx].length = 0? not true. So use direct:\n              -- (l.flatten.length - l[idx].length + l1.length) ≥ l1.length, so just show take idx sum ≤ l.flatten.length - l[idx].length + (something)\n              -- We instead use: (l.set idx l1).flatten.length = (l.take idx).flatten.length + l1.length + (l.drop (idx+1)).flatten.length\n              -- and take idx sum = (l.take idx).flatten.length; then add idx1 < l1.length.\n              -- Establish those equalities:\n              have hpref :\n                  (List.take idx (l.map List.length)).sum = (l.take idx).flatten.length := by\n                simpa [List.length_flatten, List.map_take] using (rfl : (List.take idx (l.map List.length)).sum = (List.take idx (l.map List.length)).sum)\n              have hlen' : (l.set idx l1).flatten.length =\n                  (l.take idx).flatten.length + l1.length + (l.drop (idx+1)).flatten.length := by\n                -- compute by splitting l around idx\n                have hspl : l = l.take idx ++ l[idx] :: l.drop (idx+1) := by\n                  exact (List.take_append_drop_get? (l := l) (n := idx) (by exact hidx)).symm\n                -- use hspl to rewrite set and flatten lengths\n                -- We'll use simp with set on append structure\n                -- easier: use List.set_eq_take_cons_drop (exists in std4)\n                simpa [List.length_flatten, List.map_append, List.sum_append, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] 