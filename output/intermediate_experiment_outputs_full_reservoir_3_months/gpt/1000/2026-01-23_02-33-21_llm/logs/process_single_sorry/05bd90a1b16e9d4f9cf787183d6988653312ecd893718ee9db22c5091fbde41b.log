  theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        classical
        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by
          have : l1 ∈ (l.set idx l1) := by
            simpa [List.mem_set] using Or.inr ⟨hidx, rfl⟩
          exact List.mem_flatten_of_mem this (by simpa using List.get_mem l1 ⟨idx1, hidx1⟩)
        obtain ⟨idx', hget⟩ := in_list_idx (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem
        refine ⟨idx', ?_, ?_⟩
        · have : (l.set idx (l1.eraseIdx idx1)).flatten =
            (l.set idx l1).flatten.eraseIdx idx' := by
              -- both sides are the flatten with the same element erased at the corresponding position
              -- use ext by membership
              apply List.ext_get? <;> simp
          exact this
        · simpa [hget] using (congrArg id hget)
