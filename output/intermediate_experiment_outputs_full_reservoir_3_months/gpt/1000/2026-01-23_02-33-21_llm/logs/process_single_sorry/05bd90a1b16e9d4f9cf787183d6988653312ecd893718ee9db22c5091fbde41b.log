1⟩).length = l1.length - 1 := by\n                simpa using List.length_eraseIdx (l := l1) (idx := ⟨idx1, hidx1⟩)\n              have herase : l1.eraseIdx ⟨idx1, hidx1⟩ ++ [l1[idx1]] = l1 := by\n                simpa using (List.eraseIdx_append_get (l := l1) (idx := ⟨idx1, hidx1⟩)).symm\n              have hset : l.set idx (l1.eraseIdx ⟨idx1, hidx1⟩ ++ [l1[idx1]]) = l.set idx l1 := by\n                simp [herase]\n              simpa [pos, hset, hl] using h'.symm\n            -- get at inserted index\n            simpa [this, idx', pos] using List.get_insertIdx_self (l := lA) (idx := pos) (a := l1[idx1])\n        rcases hex with ⟨idx', hErase, hGet⟩\n        refine ⟨idx', ?_, ?_⟩\n        · simpa [lA, lB, List.eraseIdx_eq_eraseIdx] using hErase.symm\n        · simpa [lB] using hGet.symm",
      "\n        classical\n        let l' : List (List α) := l.set idx l1\n        have hin : l1[idx1] ∈ l'.flatten := by\n          have : l1 ⊆ l'.flatten := by\n            intro x hx\n            have : l1 ∈ l' := by\n              have : l'[idx] = l1 := by\n                simpa [l', List.get_set, Nat.lt_of_lt_of_le hidx (Nat.le_of_lt_succ (Nat.lt_succ_self _))] using (List.get_set_eq (l := l) (a := l1) hidx)\n              have hinl' : l1 ∈ l' := by\n                have : l1 = l'[idx] := by simpa [this]\n                subst this\n                exact List.get_mem l' ⟨idx, by simpa [l'] using (List.length_set (l := l) (n := idx) (a := l1)) ▸ hidx⟩\n              exact hinl'\n            exact List.mem_flatten_of_mem this hx\n          exact this (l1[idx1]) (by\n            have : idx1 < l1.length := hidx1\n            simpa [List.getElem?_eq_getElem] using List.get_mem l1 ⟨idx1, this⟩)\n        obtain ⟨idx', hget⟩ := in_list_idx (l := l'.flatten) (x := l1[idx1]) hin\n        refine ⟨idx', ?_, ?_⟩\n        · have hmem : l1[idx1] = l'.flatten[idx'] := by\n            simpa [List.getElem_eq_get] using hget\n          have : (l.set idx (l1.eraseIdx idx1)).flatten =\n              (l'.flatten).eraseIdx idx' := by\n            have : (l.set idx (l1.eraseIdx idx1)).flatten =\n                ((l.set idx l1).set idx (l1.eraseIdx idx1)).flatten := by\n                  simpa [l', List.set_set, List.set_eq_set] using rfl\n            simp [l', List.set_set, List.set_eq_set] at this\n            exact this\n          simpa [l'] using this\n        · simpa [l', List.getElem_eq_get] using hget",
      "\n        -- reduce to a statement about erasing a single element from the flattened list\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          have : l1[idx1] ∈ l1 := by\n            exact List.get_mem l1 ⟨idx1, hidx1⟩\n          -- l1 occurs as an element of (l.set idx l1), hence its members occur in the flatten\n          have hl1 : l1 ∈ (l.set idx l1) := by\n            simpa [List.mem_set] using Or.inr ⟨hidx, rfl⟩\n          exact List.mem_flatten_of_mem hl1 this\n        obtain ⟨idx', hget⟩ := in_list_idx (l := (l.set idx l1).flatten) hmem\n        refine ⟨idx', ?_, ?_⟩\n        · -- both sides are the flattened list with the same element removed\n          apply List.eraseIdx_eq_of_get?_eq ?_ \n          · exact hget\n          · simpa [List.get?_eq_get, hget]\n        · simpa [List.get_eq_getElem, hget]",
      "\n        refine ⟨⟨(List.take idx (l.map List.length)).sum + idx1, ?_⟩, ?_, ?_⟩\n        · have hlen : (l.set idx l1).flatten.length\n            = (List.take idx (l.map List.length)).sum + l1.length + (List.drop (idx + 1) l).flatten.length := by\n              have := List.length_flatten_set (l := l) (idx := idx) (a := l1) hidx\n              simpa [List.length_drop, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this\n          rw [hlen]\n          have : (List.take idx (l.map List.length)).sum + idx1 < (List.take idx (l.map List.length)).sum + l1.length := by\n            exact Nat.add_lt_add_left hidx1 _\n          exact lt_of_lt_of_le this (Nat.le.intro (by\n            simp [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm]))\n        ·\n          have hflat :\n            (l.set idx (l1 ++ [l1[idx1]])).flatten\n              = (l.set idx l1).flatten.insertIdx ((List.take idx (l.map List.length)).sum + l1.length) (l1[idx1]) := by\n                simpa using (list_set_flatten (l := l) (l1 := l1) (elt := l1[idx1]) (idx := idx) (hidx := hidx))\n          have herase :\n            (l.set idx (l1.eraseIdx idx1)).flatten\n              = ((l.set idx l1).flatten.eraseIdx ⟨(List.take idx (l.map List.length)).sum + idx1, by\n                  simpa using (show (List.take idx (l.map List.length)).sum + idx1 < (l.set idx l1).flatten.length from\n                    (by\n                      have hlen : (l.set idx l1).flatten.length\n                        = (List.take idx (l.map List.length)).sum + l1.length + (List.drop (idx + 1) l).flatten.length := by\n                          have := List.length_flatten_set (l := l) (idx := idx) (a := l1) hidx\n                          simpa [List.length_drop, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this\n                      rw [hlen]\n                      have : (List.take idx (l.map List.length)).sum + idx1 < (List.take idx (l.map List.length)).sum + l1.length := by\n                        exact Nat.add_lt_add_left hidx1 _\n                      exact lt_of_lt_of_le this (Nat.le.intro (by\n                        simp [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm]))))⟩) := by\n                -- use erase/insert characterization via `list_set_eraseIdx` on the middle list\n                have hset : (l.set idx (l1.eraseIdx idx1)).flatten\n                    = (l.set idx l1).flatten.eraseIdx ⟨(List.take idx (l.map List.length)).sum + idx1, by\n                        simpa using (show (List.take idx (l.map List.length)).sum + idx1 < (l.set idx l1).flatten.length from\n                          (by\n                            have hlen : (l.set idx l1).flatten.length\n                              = (List.take idx (l.map List.length)).sum + l1.length + (List.drop (idx + 1) l).flatten.length := by\n                                have := List.length_flatten_set (l := l) (idx := idx) (a := l1) hidx\n                                simpa [List.length_drop, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this\n                            rw [hlen]\n                            have : (List.take idx (l.map List.length)).sum + idx1 < (List.take idx (l.map List.length)).sum + l1.length := by\n                              exact Nat.add_lt_add_left hidx1 _\n                            exact lt_of_lt_of_le this (Nat.le.intro (by\n                              simp [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm]))))⟩ := by\n                      -- prove by flattening structure and erasing inside the idx-th block\n                      have hprefix :\n                        (l.take idx).flatten.length = (List.take idx (l.map List.length)).sum := by\n                          simpa using (List.length_flatten_take (l := l) (n := idx))\n                      -- rewrite flatten of set as prefix ++ l1 ++ suffix\n                      have hflatset :\n                        (l.set idx l1).flatten = (l.take idx).flatten ++ l1 ++ (List.drop (idx + 1) l).flatten := by\n                          simpa using (List.flatten_set_eq (l := l) (idx := idx) (a := l1) hidx)\n                      have hflatset' :\n                        (l.set idx (l1.eraseIdx idx1)).flatten =\n                          (l.take idx).flatten ++ (l1.eraseIdx idx1) ++ (List.drop (idx + 1) l).flatten := by\n                          simpa using (List.flatten_set_eq (l := l) (idx := idx) (a := (l1.eraseIdx idx1)) hidx)\n                      -- erase inside concatenation\n                      simp [hflatset, hflatset', hprefix, List.eraseIdx_append, Nat.le_of_lt hidx1]\n                simpa using hset\n          exact herase\n        ·\n          -- show the chosen index points to l1[idx1] in the flattened set\n          have hprefix :\n            (l.take idx).flatten.length = (List.take idx (l.map List.length)).sum := by\n              simpa using (List.length_flatten_take (l := l) (n := idx))\n          have hflatset :\n            (l.set idx l1).flatten = (l.take idx).flatten ++ l1 ++ (List.drop (idx + 1) l).flatten := by\n              simpa using (List.flatten_set_eq (l := l) (idx := idx) (a := l1) hidx)\n          -- compute get at prefix+idx1\n          have : (l.set idx l1).flatten[(List.take idx (l.map List.length)).sum + idx1]\n                = l1[idx1] := by\n            rw [hflatset]\n            rw [hprefix]\n            simpa using (List.getElem_append_right' (l₁ := (l.take idx).flatten) (l₂ := l1 ++ (List.drop (idx + 1) l).flatten)\n              (i := idx1) (by\n                simp [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm, hidx1]))\n          simpa [Fin.getElem_def] using this.symm",
      "\n        classical\n        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by\n          -- show membership in flatten, then use `List.mem_flatten`\n          have : l1[idx1] ∈ (l.set idx l1) := by\n            simpa [List.mem_set, hidx] using (Or.inr (by rfl) : (l1[idx1] = l1) ∨ l1[idx1] ∈ l)\n          -- `simp` approach is brittle; do directly\n          have hmeml1 : l1[idx1] ∈ l1 := by\n            exact List.get_mem l1 ⟨idx1, hidx1⟩\n          -- in flatten: choose the occurrence coming from the set position\n          have : l1 ∈ (l.set idx l1) := by\n            simpa [List.mem_set, hidx] using (Or.inl rfl : (l1 = l1) ∨ l1 ∈ l)\n          -- now flatten membership\n          exact (List.mem_flatten).2 ⟨l1, this, hmeml1⟩\n        obtain ⟨idx', hget⟩ := in_list_idx (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem\n        refine ⟨idx', ?_, ?_⟩\n        · -- eraseIdx removes exactly that element at idx'\n          have : (l.set idx (l1.eraseIdx idx1)).flatten =\n              (l.set idx l1).flatten.eraseIdx idx' := by\n            -- prove by rewriting both sides using `list_set_flatten` and commuting erase/insert\n            -- Use `list_set_flatten` to express flatten after appending; here we remove one element instead.\n            -- Reduce to showing erasing in sublist corresponds to erasing in whole flatten at idx'.\n            -- We'll use ext + get? reasoning via `List.eraseIdx` characterization with `List.mem_eraseIdx`.\n            -- Simpler: use `List.eraseIdx_eq_filter`? not available; proceed by permutation-free argument:\n            -- Since idx' witnesses the exact element, `eraseIdx` equality follows from `List.eraseIdx_eq_of_get?_eq`.\n            -- We'll use `List.eraseIdx_eq` via `List.eraseIdx_get?_eq` is not available; instead use recursion on `l`.\n            -- Do direct recursion on `l` and split on `idx`.\n            revert idx hidx\n            induction l with\n            | nil =>\n              intro idx hidx\n              cases hidx\n            | cons hd tl IH =>\n              intro idx hidx\n              cases idx with\n              | zero =>\n                simp at hidx\n                subst hidx\n                -- idx = 0\n                simp [List.set, List.flatten, List.eraseIdx_cons, List.eraseIdx_cons, List.eraseIdx, List.getElem] at hget ⊢\n                -- show: (l1.eraseIdx idx1) ++ tl.flatten = (l1 ++ tl.flatten).eraseIdx idx'\n                -- and idx' points to l1[idx1] inside the prefix l1\n                have hidx' : idx'.1 < (l1 ++ tl.flatten).length := by\n                  simpa using idx'.2\n                -- idx' must be within l1 length because it points to an element of l1\n                have : idx'.1 < l1.length := by\n                  -- from `hget` and membership source; use `List.getElem?_append` reasoning\n                  -- We'll use `List.get?_append` lemma via simp on getElem of append with lt/decide.\n                  -- `simp` can split by `Nat.lt_or_ge idx'.1 l1.length`.\n                  by_contra hn\n                  have hge : l1.length ≤ idx'.1 := Nat.le_of_not_lt hn\n                  -- then element comes from tl.flatten, impossible since it equals l1[idx1] and we picked witness from l1\n                  -- but could coincide; avoid contradiction, instead just build equality by choosing erase at computed position:\n                  exact False.elim (by\n                    -- use `hget` to rewrite, then compare with `List.getElem_append_right` and `List.getElem_append_left`\n                    -- `simp` will resolve contradiction with bounds\n                    have : (l1 ++ tl.flatten)[idx'.1] = (tl.flatten)[idx'.1 - l1.length] := by\n                      simpa [List.getElem_append_right, hge, Nat.sub_add_cancel hge] using rfl\n                    -- this would make l1[idx1] in tl.flatten; but may happen, so can't contradict\n                    exact False.elim (by trivial))\n                -- Now use known lemma about erasing within append at position < l1.length\n                have hlt : idx'.1 < l1.length := this\n                -- rewrite eraseIdx on append at prefix\n                simp [List.eraseIdx, hlt, List.eraseIdx_append_left]  -- may not exist\n              | succ idx' =>\n                simp at hidx\n                -- idx = idx'.succ, set acts on tail\n                have := IH (idx := idx') (hidx := hidx)\n                -- simplify both sides\n                simpa [List.set, List.flatten] using congrArg (fun x => hd ++ x) this\n          -- fallback: since above is too brittle, use `simp` proof via `List.mem_eraseIdx` is also hard\n          -- Replace with a simpler argument using `List.eraseIdx_eq_eraseP` is unavailable\n          -- We'll accept the equality by using `by\n          --  simpa` after rewriting with `hget` and `List.eraseIdx` ext; but without lemmas, keep as `by\n          --  classical exact by\n          --    -- use `List.eraseIdx` characterization by `get` and `map`?`\n          --`\n          exact this\n          exact this\n        · -- the element at idx' is exactly l1[idx1]\n          simpa [hget]",
