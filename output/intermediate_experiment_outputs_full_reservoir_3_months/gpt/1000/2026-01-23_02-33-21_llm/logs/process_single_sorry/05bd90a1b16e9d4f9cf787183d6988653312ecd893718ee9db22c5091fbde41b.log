  theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        classical
        have hmem : l1[idx1] ∈ (l.set idx l1).flatten := by
          simp only [List.mem_flatten, List.mem_set]
          refine ⟨l1, ?_, ?_⟩
          · refine ⟨idx, hidx, rfl⟩
          · exact List.get_mem l1 ⟨idx1, hidx1⟩
        obtain ⟨idx', hget⟩ := in_list_idx (α := α) (l := (l.set idx l1).flatten) (x := l1[idx1]) hmem
        refine ⟨idx', ?_, ?_⟩
        · have := congrArg (List.eraseIdx (l := (l.set idx l1).flatten) idx') ?_
          · simpa [hget]
          ·
            have : (l.set idx l1).flatten = (l.set idx (l1.eraseIdx idx1)).flatten.insertIdx idx' (l1[idx1]) := by
              sorry
            simpa [this]
        · simpa [List.get_eq_getElem] using hget
