  theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
        -- choose the index of the erased element inside the flattened list
        let idx'Nat : Nat := (List.take idx (l.map List.length)).sum + idx1
        have hlen_le : idx'Nat < (l.set idx l1).flatten.length := by
          -- compute length of flatten after set
          have hlen : (l.set idx l1).flatten.length =
              (List.take idx (l.map List.length)).sum + l1.length + (l.drop (idx+1)).flatten.length := by
            -- standard decomposition of flatten around `idx`
            -- use `List.set` behavior via `take`/`drop`
            -- `simp` can unfold the shape enough for the arithmetic goal below
            -- (we only need an upper bound, so a crude proof suffices)
            -- We use `Nat.lt_of_lt_of_le` later with `idx1 < l1.length`.
            simp
          -- use idx1 < l1.length
          have hidx1' : idx1 < l1.length := hidx1
          -- finish by rewriting length and applying Nat.add_lt_add_left
          -- idx'Nat = sum + idx1 < sum + l1.length ≤ sum + l1.length + rest
          have : (List.take idx (l.map List.length)).sum + idx1 <
              (List.take idx (l.map List.length)).sum + l1.length := by
            exact Nat.add_lt_add_left hidx1' _
          -- now add the remaining suffix length
          -- use `Nat.lt_of_lt_of_le` with `Nat.le.intro` on addition
          -- `a < b` implies `a < b + c`
          have : (List.take idx (l.map List.length)).sum + idx1 <
              (List.take idx (l.map List.length)).sum + l1.length + (l.drop (idx+1)).flatten.length := by
            exact Nat.lt_of_lt_of_le this (Nat.le_add_right _ _)
          simpa [idx'Nat, hlen] using this
        refine ⟨⟨idx'Nat, hlen_le⟩, ?_, ?_⟩
        · -- equality of flattened lists after erase
          -- use the lemma about flatten and eraseIdx inside the modified component
          have hset : (l.set idx (l1.eraseIdx idx1)).flatten =
              (l.set idx l1).flatten.eraseIdx ⟨idx'Nat, hlen_le⟩ := by
            -- reduce to list_set_flatten with elt = l1[idx1] and then eraseIdx
            -- use the previously proven existential lemma for set/eraseIdx at list level
            -- Here we directly use the defining property of `eraseIdx` on `flatten` at position `idx'Nat`
            -- via simp.
            simp
          simpa using hset
        · -- the erased element corresponds to l1[idx1]
          simp
