      "\n        have hlen : (l.set idx l1).flatten.length = (l.set idx (l1.eraseIdx idx1)).flatten.length + 1 := by\n          have : (l1.eraseIdx ⟨idx1, hidx1⟩).length = l1.length - 1 := by\n            simpa using List.length_eraseIdx (l := l1) (idx := ⟨idx1, hidx1⟩)\n          have hlset :\n              (l.set idx (l1.eraseIdx ⟨idx1, hidx1⟩)).flatten.length\n              = (l.set idx l1).flatten.length - 1 := by\n            have hflat :\n                (l.set idx (l1.eraseIdx ⟨idx1, hidx1⟩)).flatten.length\n                = (l.map List.length).set idx (l1.length - 1) |>.sum := by\n              simpa [List.length_flatten, this]\n            have hflat' :\n                (l.set idx l1).flatten.length\n                = (l.map List.length).set idx l1.length |>.sum := by\n              simpa [List.length_flatten]\n            rw [hflat, hflat']\n            have hidx' : idx < (l.map List.length).length := by simpa using hidx\n            simpa using (list_set_sum (l := l.map List.length) (idx := idx) (e := l1.length - 1) (hidx := hidx'))\n          have : (l.set idx l1).flatten.length = (l.set idx (l1.eraseIdx ⟨idx1, hidx1⟩)).flatten.length + 1 := by\n            have := congrArg (fun n => n + 1) hlset\n            simpa [Nat.sub_add_cancel (Nat.succ_le_of_lt (Nat.pos_of_lt (by\n              have : (l.set idx l1).flatten.length ≠ 0 := by\n                intro h0\n                have : l1.length = 0 := by\n                  have hlen0 : (l.set idx l1).flatten.length = (l.map List.length).set idx l1.length |>.sum := by\n                    simpa [List.length_flatten]\n                  have : ((l.map List.length).set idx l1.length |>.sum) = 0 := by simpa [hlen0] using h0\n                  have hpos : l1.length ≤ ((l.map List.length).set idx l1.length |>.sum) := by\n                    have := Nat.le_add_left l1.length (((l.map List.length).set idx l1.length |>.sum) - l1.length)\n                    simpa using this\n                  exact Nat.eq_zero_of_le