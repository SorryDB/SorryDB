  have : DecidableEq ι := Classical.decEq _
  -- Turn the `L^p` assumption on the `X i` into various integrability conditions.
  have integrable_prod_norm_X I (hI : I ∈ A ×ˢ A ^^ m) :
    Integrable (fun ω ↦ ∏ k, ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by
    classical
    simp only [mem_piFinset] at hI
    have h1 : ∀ k : Fin m, I k |>.1 ∈ A := fun k ↦ by
      simpa using (hI k).1
    have h2 : ∀ k : Fin m, I k |>.2 ∈ A := fun k ↦ by
      simpa using (hI k).2
    have hLp1 : ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).1 ω‖) (2 : ℝ≥0∞) μ := fun k ↦ by
      (memLp_X (I k).1 (h1 k)).norm
    have hLp2 : ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).2 ω‖) (2 : ℝ≥0∞) μ := fun k ↦ by
      (memLp_X (I k).2 (h2 k)).norm
    have hIntMul : ∀ k : Fin m,
        Integrable (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := fun k ↦ by
      (hLp1 k).integrable_mul (hLp2 k)
    simpa using integrable_finset_prod' (s := Finset.univ) hIntMul
