      "\n    classical\n    rcases mem_piFinset.mp hI with hI\n    -- each factor is integrable by Hölder/Cauchy-Schwarz from `MemLp` at exponent `2*m`\n    have hLp1 : ∀ k, MemLp (fun ω ↦ ‖X (I k).1 ω‖) (2 : ℝ≥0∞) μ := by\n      intro k\n      have hmem : MemLp (X (I k).1) (2 * (m : ℝ≥0∞)) μ := by\n        have : (I k).1 ∈ A := (hI k).1\n        simpa [two_mul] using memLp_X (I k).1 this\n      have hm : (2 : ℝ≥0∞) ≤ 2 * (m : ℝ≥0∞) := by\n        by_cases hm0 : m = 0\n        · subst hm0; simp\n        ·\n          have : (1 : ℝ≥0∞) ≤ (m : ℝ≥0∞) := by\n            simpa [ENNReal.coe_nat, Nat.cast_le] using (Nat.succ_le_iff.mp (Nat.pos_of_ne_zero hm0)).le\n          nlinarith\n      exact (hmem.norm.mono_exponent hm)\n    have hLp2 : ∀ k, MemLp (fun ω ↦ ‖X (I k).2 ω‖) (2 : ℝ≥0∞) μ := by\n      intro k\n      have hmem : MemLp (X (I k).2) (2 * (m : ℝ≥0∞)) μ := by\n        have : (I k).2 ∈ A := (hI k).2\n        simpa [two_mul] using memLp_X (I k).2 this\n      have hm : (2 : ℝ≥0∞) ≤ 2 * (m : ℝ≥0∞) := by\n        by_cases hm0 : m = 0\n        · subst hm0; simp\n        ·\n          have : (1 : ℝ≥0∞) ≤ (m : ℝ≥0∞) := by\n            simpa [ENNReal.coe_nat, Nat.cast_le] using (Nat.succ_le_iff.mp (Nat.pos_of_ne_zero hm0)).le\n          nlinarith\n      exact (hmem.norm.mono_exponent hm)\n    have hint : ∀ k, Integrable (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by\n      intro k\n      have h1 := (hLp1 k).integrable\n      have h2 := (hLp2 k).integrable\n      exact (h1.mul h2)\n    simpa using integrable_finset_prod (s := (Finset.univ : Finset (Fin m)))\n      (f := fun k ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) hint",
      "\n    classical\n    refine (integrable_finset_prod.mpr ?_)\n    intro k hk\n    have hI' : I ∈ A ^^ m := by\n      exact (Finset.mem_product.mp hI).2\n    have hIk : I k ∈ A ×ˢ A := by\n      simpa [Fintype.mem_piFinset] using (show I k ∈ A ×ˢ A from (by\n        have := (show ∀ j : Fin m, I j ∈ A ×ˢ A from by\n          simpa [A, Fintype.mem_piFinset] using hI'\n        exact this k))\n    have h1 : (I k).1 ∈ A := (Finset.mem_product.mp hIk).1\n    have h2 : (I k).2 ∈ A := (Finset.mem_product.mp hIk).2\n    have hLp1 : MemLp (X (I k).1) (2 * m) μ := memLp_X _ h1\n    have hLp2 : MemLp (X (I k).2) (2 * m) μ := memLp_X _ h2\n    have hInt1 : Integrable (fun ω ↦ ‖X (I k).1 ω‖) μ := by\n      have : MemLp (fun ω ↦ ‖X (I k).1 ω‖) (2 * m) μ := hLp1.norm\n      exact this.integrable (by\n        have : (1 : ℝ≥0∞) ≤ (2 * (m : ℝ)) := by\n          by_cases hm : m = 0\n          · subst hm; simp\n          · have : (1 : ℝ) ≤ (2 * (m : ℝ)) := by nlinarith [Nat.cast_pos.mpr (Nat.pos_of_ne_zero hm)]\n            simpa using this\n        simpa using this)\n    have hInt2 : Integrable (fun ω ↦ ‖X (I k).2 ω‖) μ := by\n      have : MemLp (fun ω ↦ ‖X (I k).2 ω‖) (2 * m) μ := hLp2.norm\n      exact this.integrable (by\n        have : (1 : ℝ≥0∞) ≤ (2 * (m : ℝ)) := by\n          by_cases hm : m = 0\n          · subst hm; simp\n          · have : (1 : ℝ) ≤ (2 * (m : ℝ)) := by nlinarith [Nat.cast_pos.mpr (Nat.pos_of_ne_zero hm)]\n            simpa using this\n        simpa using this)\n    simpa [mul_assoc, mul_left_comm, mul_comm] using hInt1.mul hInt2",
      "\n    classical\n    suffices h :\n        MemLp (fun ω ↦ ∏ k : Fin m, ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) 1 μ := by\n      simpa [memLp_one_iff_integrable] using h\n    have hIX :\n        ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) 1 μ := by\n      intro k\n      have hI1 : (I k).1 ∈ A := by\n        have : I k ∈ A ×ˢ A := by\n          simpa [piFinset, Finset.mem_product] using (Finset.mem_piFinset.mp hI k)\n        exact (Finset.mem_product.mp this).1\n      have hI2 : (I k).2 ∈ A := by\n        have : I k ∈ A ×ˢ A := by\n          simpa [piFinset, Finset.mem_product] using (Finset.mem_piFinset.mp hI k)\n        exact (Finset.mem_product.mp this).2\n      have h1 : MemLp (fun ω ↦ ‖X (I k).1 ω‖) (2 * (m : ℝ≥0∞)) μ := by\n        simpa using (memLp_norm (memLp_X (I k).1 hI1))\n      have h2 : MemLp (fun ω ↦ ‖X (I k).2 ω‖) (2 * (m : ℝ≥0∞)) μ := by\n        simpa using (memLp_norm (memLp_X (I k).2 hI2))\n      simpa [mul_assoc, mul_left_comm, mul_comm] using h1.mul h2\n    simpa using (memLp_prod_of_finite hIX)",
      "\n    classical\n    have hIA : ∀ k, (I k).1 ∈ A ∧ (I k).2 ∈ A := by\n      intro k\n      have hk : I k ∈ A ×ˢ A := by\n        simpa [piFinset, Fintype.mem_piFinset] using (by\n          have := (Fintype.mem_piFinset.mp hI) k\n          simpa using this)\n      simpa [Finset.mem_product] using hk\n    have hLp1 : ∀ k, MemLp (fun ω ↦ ‖X (I k).1 ω‖) (2 * m : ℝ≥0∞) μ := by\n      intro k\n      have : MemLp (X (I k).1) (2 * m : ℝ≥0∞) μ := memLp_X (I k).1 (hIA k).1\n      exact this.norm\n    have hLp2 : ∀ k, MemLp (fun ω ↦ ‖X (I k).2 ω‖) (2 * m : ℝ≥0∞) μ := by\n      intro k\n      have : MemLp (X (I k).2) (2 * m : ℝ≥0∞) μ := memLp_X (I k).2 (hIA k).2\n      exact this.norm\n    have hLpm : ∀ k, MemLp (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) (m : ℝ≥0∞) μ := by\n      intro k\n      simpa [two_mul] using (hLp1 k).mul (hLp2 k)\n    have hInt : ∀ k, Integrable (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by\n      intro k\n      exact (hLpm k).integrable\n    simpa [Fintype.integrable_prod_iff] using (MeasureTheory.integrable_prod_of_integrable hInt)",
      "\n    classical\n    have hI' : ∀ k : Fin m, (I k).1 ∈ A ∧ (I k).2 ∈ A := by\n      intro k\n      have : I k ∈ A ×ˢ A := by\n        simpa [A ^^ m, Fintype.mem_piFinset] using (Fintype.mem_piFinset.mp hI k)\n      simpa [Finset.mem_product] using this\n    have hLp1 : ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).1 ω‖) (2 * (m : ℝ)) μ := by\n      intro k\n      simpa [Real.norm_eq_abs, abs_norm] using (memLp_X (I k).1 (hI' k).1).norm\n    have hLp2 : ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).2 ω‖) (2 * (m : ℝ)) μ := by\n      intro k\n      simpa [Real.norm_eq_abs, abs_norm] using (memLp_X (I k).2 (hI' k).2).norm\n    have hLp_mul :\n        ∀ k : Fin m,\n          MemLp (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) (m : ℝ) μ := by\n      intro k\n      simpa [mul_assoc, two_mul, pow_two] using (hLp1 k).mul (hLp2 k)\n    simpa [Fintype.integrable_pi_iff] using\n      (integrable_finset_prod_of_integrable\n        (s := (Finset.univ : Finset (Fin m)))\n        (f := fun k ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖)\n        (fun k _ ↦ (hLp_mul k).integrable))",
      "\n    classical\n    have hA : (A ×ˢ A ^^ m) = piFinset fun _ : Fin m ↦ A ×ˢ A := rfl\n    have hI' : I ∈ piFinset (fun _ : Fin m ↦ A ×ˢ A) := by simpa [hA] using hI\n    have h1 : ∀ k : Fin m, Integrable (fun ω ↦ ‖X (I k).1 ω‖) μ := by\n      intro k\n      have hk : (I k).1 ∈ A := by\n        have : I k ∈ A ×ˢ A := by\n          exact (mem_piFinset.mp hI') k\n        exact (mem_product.mp this).1\n      exact (memLp_X _ hk).integrable_norm\n    have h2 : ∀ k : Fin m, Integrable (fun ω ↦ ‖X (I k).2 ω‖) μ := by\n      intro k\n      have hk : (I k).2 ∈ A := by\n        have : I k ∈ A ×ˢ A := by\n          exact (mem_piFinset.mp hI') k\n        exact (mem_product.mp this).2\n      exact (memLp_X _ hk).integrable_norm\n    have hmul : ∀ k : Fin m, Integrable (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by\n      intro k\n      exact (h1 k).mul (h2 k)\n    simpa using integrable_finset_prod (s := (Finset.univ : Finset (Fin m))) (f := fun k : Fin m ↦ fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) hmul",
      "\n    classical\n    have hI' : ∀ k : Fin m, I k ∈ A ×ˢ A := by\n      intro k\n      have : I ∈ A ^^ m := by\n        simpa [Fintype.piFinset] using hI\n      simpa [Fintype.piFinset] using (Finset.mem_pi.mp this k)\n    have hLp1 : ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).1 ω‖) (2 * (m : ℝ≥0∞)) μ := by\n      intro k\n      have : MemLp (X (I k).1) (2 * (m : ℝ≥0∞)) μ := by\n        have hmem : (I k).1 ∈ A := (Finset.mem_product.mp (hI' k)).1\n        simpa [two_mul, mul_assoc, ENNReal.ofNat_mul] using memLp_X (I k).1 hmem\n      simpa using this.norm\n    have hLp2 : ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).2 ω‖) (2 * (m : ℝ≥0∞)) μ := by\n      intro k\n      have : MemLp (X (I k).2) (2 * (m : ℝ≥0∞)) μ := by\n        have hmem : (I k).2 ∈ A := (Finset.mem_product.mp (hI' k)).2\n        simpa [two_mul, mul_assoc, ENNReal.ofNat_mul] using memLp_X (I k).2 hmem\n      simpa using this.norm\n    have hInt : ∀ k : Fin m, Integrable (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by\n      intro k\n      have h1 : MemLp (fun ω ↦ ‖X (I k).1 ω‖) 2 μ := (hLp1 k).mono_exponent (by simp)\n      have h2 : MemLp (fun ω ↦ ‖X (I k).2 ω‖) 2 μ := (hLp2 k).mono_exponent (by simp)\n      simpa [mul_comm, mul_left_comm, mul_assoc] using (h1.mul h2).integrable\n    simpa using (Finset.integrable_prod (Finset.univ) (fun k : Fin m ↦ hInt k))",
      "\n    classical\n    rcases mem_piFinset.1 hI with hI\n    have hmem1 : ∀ k : Fin m, (I k).1 ∈ A := fun k =>\n      (mem_product.1 (hI k)).1\n    have hmem2 : ∀ k : Fin m, (I k).2 ∈ A := fun k =>\n      (mem_product.1 (hI k)).2\n    have h1 : ∀ k : Fin m, Integrable (fun ω ↦ ‖X (I k).1 ω‖) μ := fun k =>\n      ((memLp_X _ (hmem1 k)).1.integrable_norm)\n    have h2 : ∀ k : Fin m, Integrable (fun ω ↦ ‖X (I k).2 ω‖) μ := fun k =>\n      ((memLp_X _ (hmem2 k)).1.integrable_norm)\n    have hmul : ∀ k : Fin m, Integrable (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := fun k =>\n      (h1 k).mul (h2 k)\n    simpa [Finset.prod_mul_distrib] using\n      (integrable_finset_prod (s := Finset.univ) fun k _ => hmul k)",
      "\n    classical\n    refine integrable_finset_prod_pi (s := Finset.univ) ?_\n    intro k hk\n    have h1 : (I k).1 ∈ A := by\n      have : I ∈ A ×ˢ A ^^ m := hI\n      have hk' : I k ∈ A ×ˢ A := by\n        simpa [piFinset] using (mem_piFinset_iff.mp this k)\n      exact (mem_product.mp hk').1\n    have h2 : (I k).2 ∈ A := by\n      have : I ∈ A ×ˢ A ^^ m := hI\n      have hk' : I k ∈ A ×ˢ A := by\n        simpa [piFinset] using (mem_piFinset_iff.mp this k)\n      exact (mem_product.mp hk').2\n    have hLp1 : MemLp (X (I k).1) (2 * m) μ := memLp_X _ h1\n    have hLp2 : MemLp (X (I k).2) (2 * m) μ := memLp_X _ h2\n    have hInt1 : Integrable (fun ω ↦ ‖X (I k).1 ω‖) μ :=\n      (hLp1.norm.integrable (by\n        have : (1 : ℝ≥0∞) ≤ (2 * (m : ℝ)) := by\n          simpa [two_mul, mul_assoc, mul_left_comm, mul_comm, Nat.cast_ofNat] using\n            (show (1 : ℝ) ≤ (2 * (m : ℝ)) by\n              nlinarith [show (0 : ℝ) ≤ (m : ℝ) by exact_mod_cast (Nat.zero_le m)])\n        simpa using this))\n    have hInt2 : Integrable (fun ω ↦ ‖X (I k).2 ω‖) μ :=\n      (hLp2.norm.integrable (by\n        have : (1 : ℝ≥0∞) ≤ (2 * (m : ℝ)) := by\n          simpa [two_mul, mul_assoc, mul_left_comm, mul_comm, Nat.cast_ofNat] using\n            (show (1 : ℝ) ≤ (2 * (m : ℝ)) by\n              nlinarith [show (0 : ℝ) ≤ (m : ℝ) by exact_mod_cast (Nat.zero_le m)])\n        simpa using this))\n    simpa [mul_comm, mul_left_comm, mul_assoc] using hInt1.mul hInt2",
      "\n    classical\n    by_cases hm : m = 0\n    · subst hm\n      simpa using (integrable_const (1 : ℝ))\n    ·\n      have hm' : (0 : ℝ) < (m : ℝ) := by\n        exact_mod_cast Nat.pos_of_ne_zero hm\n      have hmem1 : ∀ k : Fin m, (I k).1 ∈ A := by\n        intro k\n        have : I k ∈ A ×ˢ A := by\n          simpa [A ^^ m, Fintype.mem_piFinset] using (Fintype.mem_piFinset.mp hI k)\n        exact (Finset.mem_product.mp this).1\n      have hmem2 : ∀ k : Fin m, (I k).2 ∈ A := by\n        intro k\n        have : I k ∈ A ×ˢ A := by\n          simpa [A ^^ m, Fintype.mem_piFinset] using (Fintype.mem_piFinset.mp hI k)\n        exact (Finset.mem_product.mp this).2\n      have hLp1 : ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).1 ω‖) (2 * (m : ℝ)) μ := by\n        intro k\n        simpa using (memLp_norm (memLp_X (I k).1 (hmem1 k)))\n      have hLp2 : ∀ k : Fin m, MemLp (fun ω ↦ ‖X (I k).2 ω‖) (2 * (m : ℝ)) μ := by\n        intro k\n        simpa using (memLp_norm (memLp_X (I k).2 (hmem2 k)))\n      have hLp_mul : ∀ k : Fin m,\n          MemLp (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) (2 * (m : ℝ)) μ := by\n        intro k\n        have : MemLp (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) (m : ℝ) μ := by\n          simpa [mul_assoc, two_mul] using\n            (hLp1 k).mul (hLp2 k) (by\n              simp [hm', mul_pos, (show (0 : ℝ) < (2:ℝ) by norm_num)])\n        exact this.mono_exponent (by\n          have : (m : ℝ) ≤ 2 * (m : ℝ) := by nlinarith\n          exact this)\n      have hLp_prod : MemLp (fun ω ↦ ∏ k : Fin m, (‖X (I k).1 ω‖ * ‖X (I k).2 ω‖))\n          (2 * (m : ℝ)) μ := by\n        simpa using (memLp_finset_prod (s := Finset.univ) (f := fun k : Fin m =>\n          fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) (p := (2 * (m : ℝ))) (by\n            intro k hk\n            simpa using hLp_mul k))\n      exact hLp_prod.integrable",
      "\n    classical\n    have hI' : I ∈ piFinset (fun _ : Fin m ↦ A ×ˢ A) := by simpa [A ^^ m] using hI\n    refine (integrable_finset_prod (s := Finset.univ) (f := fun k : Fin m ↦ fun ω ↦\n      ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖)).2 ?_\n    intro k hk\n    have hIk : I k ∈ A ×ˢ A := by\n      have : I k ∈ (fun _ : Fin m ↦ A ×ˢ A) k := by\n        exact (mem_piFinset.mp hI') k\n      simpa using this\n    have h1 : (I k).1 ∈ A := (Finset.mem_product.mp hIk).1\n    have h2 : (I k).2 ∈ A := (Finset.mem_product.mp hIk).2\n    have hLp1 : MemLp (X (I k).1) (2 * m) μ := memLp_X _ h1\n    have hLp2 : MemLp (X (I k).2) (2 * m) μ := memLp_X _ h2\n    have hInt1 : Integrable (fun ω ↦ ‖X (I k).1 ω‖) μ :=\n      (hLp1.norm.integrable_of_exponent_le (by positivity) (by\n        simpa [two_mul, Nat.cast_mul, Nat.cast_ofNat] using (show (1 : ℝ) ≤ (2 * m : ℝ) from by\n          have : (0 : ℝ) < (2 * m : ℝ) := by\n            by_cases hm : m = 0\n            · subst hm; simp\n            · have : (0 : ℝ) < (m : ℝ) := by exact_mod_cast Nat.pos_of_ne_zero hm\n              nlinarith\n          nlinarith)))\n    have hInt2 : Integrable (fun ω ↦ ‖X (I k).2 ω‖) μ :=\n      (hLp2.norm.integrable_of_exponent_le (by positivity) (by\n        simpa [two_mul, Nat.cast_mul, Nat.cast_ofNat] using (show (1 : ℝ) ≤ (2 * m : ℝ) from by\n          have : (0 : ℝ) < (2 * m : ℝ) := by\n            by_cases hm : m = 0\n            · subst hm; simp\n            · have : (0 : ℝ) < (m : ℝ) := by exact_mod_cast Nat.pos_of_ne_zero hm\n              nlinarith\n          nlinarith)))\n    simpa [mul_assoc, mul_left_comm, mul_comm] using hInt1.mul hInt2",
