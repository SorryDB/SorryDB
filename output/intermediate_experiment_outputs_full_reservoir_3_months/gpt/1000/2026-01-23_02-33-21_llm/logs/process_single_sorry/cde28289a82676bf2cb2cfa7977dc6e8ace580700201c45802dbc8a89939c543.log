lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  classical
  have hM : Martingale (fun i ↦ X i - μ[X i | 𝓕 i]) 𝓕 μ := by
    simpa [sub_eq_add_neg] using hX.martingale_sub_condExp
  have hUI :=
    (Martingale.uniformIntegrable_stoppedValue (X := fun i ↦ X i - μ[X i | 𝓕 i]) (𝓕 := 𝓕)
        (μ := μ) hM τ hτ (n := n) hτ_le)
  have hUI' : UniformIntegrable (fun i ↦ stoppedValue (fun i ↦ X i - μ[X i | 𝓕 i]) (τ i)) 1 μ := hUI
  have hUIcond : UniformIntegrable (fun i ↦ stoppedValue (fun i ↦ μ[X i | 𝓕 i]) (τ i)) 1 μ := by
    have hXn : Integrable (X n) μ := hX.integrable n
    have hUIc : UniformIntegrable (fun i ↦ μ[X n | (hτ i).measurableSpace]) 1 μ := by
      simpa using
        (UniformIntegrable.condExp'
            (X := fun _ : Unit ↦ X n) (μ := μ)
            (uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X n) le_rfl (by simp)
              (fun _ ↦ memLp_one_iff_integrable.2 hXn))
            (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))
    refine hUIc.ae_eq ?_
    intro i
    simpa [Martingale.ae_eq_condExp_of_isStoppingTime] using
      (stoppedValue_ae_eq_condExp_of_le
        (hX := (hX.martingale_condExp (fun i ↦ le_rfl))) (hσ := isStoppingTime_const 𝓕 n)
        (hτ := hτ i) (n := n) (fun ω ↦ hτ_le i ω) (fun _ ↦ le_rfl))
  have hUIX : UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
    have hEq :
        (fun i ↦ stoppedValue X (τ i))
          = fun i ↦ stoppedValue (fun i ↦ X i - μ[X i | 𝓕 i]) (τ i)
              + stoppedValue (fun i ↦ μ[X i | 𝓕 i]) (τ i) := by
      funext i ω
      simp [stoppedValue, sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
    simpa [hEq] using
      (UniformIntegrable.add (E := ℝ) (ι := ℕ) (Ω := Ω) (μ := μ) (p := (1 : ℝ≥0∞)) le_rfl
        hUI' hUIcond)
  simpa using hUIX
