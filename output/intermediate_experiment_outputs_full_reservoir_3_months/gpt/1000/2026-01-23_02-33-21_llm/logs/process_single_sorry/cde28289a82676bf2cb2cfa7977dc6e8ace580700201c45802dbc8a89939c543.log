  have hX_inc : Adapted 𝓕 (fun i ↦ hX.increasingPart i) := hX.adapted_increasingPart
  have hX_inc_mono : Monotone hX.increasingPart := hX.monotone_increasingPart
  have hX_decomp : ∀ i, X i = hX.martingalePart i + hX.increasingPart i := hX.submartingalePart_eq
