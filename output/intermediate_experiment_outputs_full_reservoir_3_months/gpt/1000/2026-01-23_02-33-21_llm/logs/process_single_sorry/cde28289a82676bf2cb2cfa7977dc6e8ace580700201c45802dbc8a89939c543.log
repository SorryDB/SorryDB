lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
by
  classical
  have hM : Martingale (fun i ↦ (X i, fun _ ↦ (0 : ℝ))) 𝓕 μ := by
    simpa [Martingale, hX.adapted, hX.integrable, Prod.fst_condExp, Prod.snd_condExp] using
      (hX.martingale_pair_const (c := (0 : ℝ)))
  have hUI :
      UniformIntegrable (fun i ↦ stoppedValue (fun i ↦ (X i, fun _ ↦ (0 : ℝ))) (τ i)) 1 μ :=
    Martingale.uniformIntegrable_stoppedValue (μ := μ) (𝓕 := 𝓕) (X := fun i ↦ (X i, fun _ ↦ (0 : ℝ)))
      hM τ hτ (n := n) hτ_le
  have hUI' :
      UniformIntegrable (fun i ↦ (fun ω ↦ (stoppedValue X (τ i) ω : ℝ))) 1 μ := by
    simpa [stoppedValue] using (hUI.comp (fun i ↦ i))
  simpa using hUI'
