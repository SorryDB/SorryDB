    let j := (L.map length).partialSums.findIdx (· > i) - 1
    have hj : j < L.length := getElem_flatten_aux₁ L i h
    let k := i - (L.take j).flatten.length
    k < L[j].length := by
  classical
  intro j hj k
  have hlen : i < ((L.take (j + 1)).flatten.length) := by
    have h' : (L.take (j + 1)).flatten.length ≤ L.flatten.length := by
      simpa [List.flatten_eq_join, List.join_take] using
        (List.length_flatten_le_length_flatten (l₁ := L.take (j + 1)) (l₂ := L) (by simp))
    exact lt_of_lt_of_le h h'
  have hj' : j < (L.take (j + 1)).length := by simp
  have hsplit :
      (L.take (j + 1)).flatten.length =
        (L.take j).flatten.length + (L[j]'(by simpa using hj)).length := by
    have : L.take (j + 1) = L.take j ++ [L[j]'(by simpa using hj)] := by
