      "\n    classical\n    have hle : ∀ i : Fin n, |y i - x i| ≤ ε := by\n      intro i\n      have := hdiff i\n      simpa [abs_sub_comm, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using this\n    have habs : |g' 0| ≤ ∑ i, |y i - x i| * |nth_partial i f x| := by\n      have :\n          |∑ i, (y i - x i) * nth_partial i f x| ≤\n            ∑ i, |(y i - x i) * nth_partial i f x| :=\n        by\n          simpa using abs_sum_le_sum_abs (f := fun i : Fin n => (y i - x i) * nth_partial i f x)\n      have hmul :\n          (∑ i, |(y i - x i) * nth_partial i f x|) =\n            ∑ i, |y i - x i| * |nth_partial i f x| := by\n          refine Finset.sum_congr rfl ?_\n          intro i hi\n          simp [abs_mul, mul_assoc, mul_left_comm, mul_comm]\n      have h0 :\n          (∑ i, (y i - x i) * nth_partial i f ((1 - (0 : ℝ)) • x + (0 : ℝ) • y)) =\n            ∑ i, (y i - x i) * nth_partial i f x := by\n          refine Finset.sum_congr rfl ?_\n          intro i hi\n          simp\n      have h0' :\n          (∑ i, (y i - x i) * nth_partial i f ((1 - (0 : ℝ)) • x + (0 : ℝ) • y)) =\n            g' 0 := by\n          simp [g', GlobalTheorem.interpolated_deriv]\n      have hg0 : g' 0 = ∑ i, (y i - x i) * nth_partial i f x := by\n        simpa [h0'] using congrArg id (h0'.symm.trans h0)\n      have : |g' 0| ≤ ∑ i, |(y i - x i) * nth_partial i f x| := by\n        simpa [hg0] using this\n      simpa [hmul] using this\n    have hsum :\n        (∑ i, |y i - x i| * |nth_partial i f x|) ≤ ε * ∑ i, |nth_partial i f x| := by\n      have :\n          (∑ i, |y i - x i| * |nth_partial i f x|) ≤\n            ∑ i, ε * |nth_partial i f x| := by\n          refine Finset.sum_le_sum ?_\n          intro i hi\n          have := mul_le_mul_of_nonneg_right (hle i) (abs_nonneg (nth_partial i f x))\n          simpa [mul_assoc, mul_left_comm, mul_comm] using this\n      have :\n          (∑ i, ε * |nth_partial i f x|) = ε * ∑ i, |nth_partial i f x| := by\n        simp [Finset.mul_sum]\n      exact this.trans_eq this\n    have : |g' 0| ≤ ε * ∑ i, |nth_partial i f x| := habs.trans (hsum)\n    simpa using this",
      "\n    dsimp [g', GlobalTheorem.interpolated_deriv2, GlobalTheorem.interpolated_deriv]\n    simpa using le_trans (by\n      have : |∑ i, (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)| ≤\n          ∑ i, |(y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)| := by\n        simpa using abs_sum_le_sum_abs (f := fun i => (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y))\n      simpa [sub_eq_add_neg, mul_assoc, mul_left_comm, mul_comm] using this) (by\n      have hx : ((1 - (0:ℝ)) • x + (0:ℝ) • y : E n) = x := by\n        simp\n      have hle :\n          (∑ i, |(y i - x i) * nth_partial i f x|) ≤ ε * ∑ i, |nth_partial i f x| := by\n        have hle' : (∑ i, |(y i - x i) * nth_partial i f x|) ≤\n            ∑ i, (ε * |nth_partial i f x|) := by\n          refine Finset.sum_le_sum ?_\n          intro i hi\n          have hiε : |y i - x i| ≤ ε := by\n            simpa [abs_sub_comm] using hdiff i\n          calc\n            |(y i - x i) * nth_partial i f x|\n                = |y i - x i| * |nth_partial i f x| := by\n                    simp [abs_mul]\n            _ ≤ ε * |nth_partial i f x| := by\n                    nlinarith\n        simpa [Finset.mul_sum] using hle'\n      simpa [hx, abs_mul] using hle)",
      "\n    have hx : ∀ i : Fin n, |y i - x i| ≤ ε := by\n      intro i\n      have := hdiff i\n      simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc, abs_sub_comm] using this\n    have hg0 : g' 0 = ∑ i, (y i - x i) * nth_partial i f x := by\n      simp [g', GlobalTheorem.interpolated_deriv, GlobalTheorem.interpolator]\n    rw [hg0]\n    have hle :\n        |∑ i, (y i - x i) * nth_partial i f x| ≤ ∑ i, |(y i - x i) * nth_partial i f x| := by\n      simpa using (abs_sum_le_sum_abs (fun i : Fin n => (y i - x i) * nth_partial i f x))\n    have hle2 :\n        (∑ i, |(y i - x i) * nth_partial i f x|) ≤ ε * ∑ i, |nth_partial i f x| := by\n      calc\n        (∑ i, |(y i - x i) * nth_partial i f x|)\n            = ∑ i, |y i - x i| * |nth_partial i f x| := by\n                refine Finset.sum_congr rfl ?_\n                intro i hi\n                simp [abs_mul]\n        _ ≤ ∑ i, ε * |nth_partial i f x| := by\n              refine Finset.sum_le_sum ?_\n              intro i hi\n              have := mul_le_mul_of_nonneg_right (hx i) (by simpa using (abs_nonneg (nth_partial i f x)))\n              simpa [mul_assoc, mul_left_comm, mul_comm] using this\n        _ = ε * ∑ i, |nth_partial i f x| := by\n              simp [Finset.mul_sum, mul_comm, mul_left_comm, mul_assoc]\n    exact le_trans hle hle2",
      "\n    classical\n    have hxye : ∀ i : Fin n, |y i - x i| ≤ ε := by\n      intro i\n      have := hdiff i\n      simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc, abs_sub_comm] using this\n    have hspec : g' 0 = ∑ i, (y i - x i) * nth_partial i f x := by\n      simp [g', GlobalTheorem.interpolated_deriv, GlobalTheorem.interpolator]\n    rw [hspec]\n    have hle :\n        |∑ i, (y i - x i) * nth_partial i f x| ≤\n          ∑ i, |(y i - x i) * nth_partial i f x| := by\n      simpa using (norm_sum_le (fun i : Fin n => (y i - x i) * nth_partial i f x))\n    have hle' :\n        (∑ i, |(y i - x i) * nth_partial i f x|) ≤\n          ∑ i, ε * |nth_partial i f x| := by\n      refine Finset.sum_le_sum ?_\n      intro i hi\n      have : |(y i - x i) * nth_partial i f x| ≤ ε * |nth_partial i f x| := by\n        simpa [abs_mul, mul_assoc, mul_left_comm, mul_comm] using\n          mul_le_mul_of_nonneg_right (hxye i) (by simpa using abs_nonneg (nth_partial i f x))\n      exact this\n    have hle'' :\n        (∑ i, ε * |nth_partial i f x|) = ε * ∑ i, |nth_partial i f x| := by\n      simp [Finset.mul_sum]\n    exact le_trans (le_trans hle hle') (by simpa [hle''] )",
      "\n    have hx : (∀ i : Fin n, |y i - x i| ≤ ε) := by\n      intro i\n      have := hdiff i\n      simpa [abs_sub_comm, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using this\n    have hsum :\n        |∑ i, (y i - x i) * nth_partial i f x| ≤ ε * ∑ i, |nth_partial i f x| := by\n      calc\n        |∑ i, (y i - x i) * nth_partial i f x|\n            ≤ ∑ i, |(y i - x i) * nth_partial i f x| := by\n              simpa using (abs_sum_le_sum_abs (fun i => (y i - x i) * nth_partial i f x))\n        _ = ∑ i, |y i - x i| * |nth_partial i f x| := by\n              refine Finset.sum_congr rfl ?_\n              intro i hi\n              simp [abs_mul]\n        _ ≤ ∑ i, ε * |nth_partial i f x| := by\n              refine Finset.sum_le_sum ?_\n              intro i hi\n              have hxi := hx i\n              nlinarith\n        _ = ε * ∑ i, |nth_partial i f x| := by\n              simp [mul_sum, Finset.mul_sum]\n    simpa [g', GlobalTheorem.interpolated_deriv, GlobalTheorem.interpolator, one_smul, zero_smul, sub_zero] using hsum",
      "\n    dsimp [g', GlobalTheorem.interpolated_deriv]\n    have hdiff' : (i : Fin n) → |y i - x i| ≤ ε := by\n      intro i\n      have := hdiff i\n      simpa [abs_sub_comm, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using this\n    have hterm : ∀ i : Fin n, |(y i - x i) * nth_partial i f x| ≤ ε * |nth_partial i f x| := by\n      intro i\n      have hi : |y i - x i| ≤ ε := hdiff' i\n      have hi' : 0 ≤ ε := le_of_lt hε\n      calc\n        |(y i - x i) * nth_partial i f x|\n            = |y i - x i| * |nth_partial i f x| := by simp [abs_mul]\n        _ ≤ ε * |nth_partial i f x| := by\n            gcongr\n    have := Finset.abs_sum_le_sum_abs (s := Finset.univ) (f := fun i : Fin n => (y i - x i) * nth_partial i f x)\n    refine le_trans this ?_\n    have : (∑ i : Fin n, |(y i - x i) * nth_partial i f x|) ≤ ∑ i : Fin n, ε * |nth_partial i f x| := by\n      refine Finset.sum_le_sum ?_\n      intro i hi\n      exact hterm i\n    refine le_trans this ?_\n    simp [Finset.mul_sum]",
      "\n    classical\n    have hdiff' : ∀ i : Fin n, |y i - x i| ≤ ε := by\n      intro i\n      have := hdiff i\n      simpa [abs_sub_comm, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using this\n    have hterm (i : Fin n) :\n        |(y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)| ≤ ε * |nth_partial i f x| := by\n      have hx : ((1 - (0:ℝ)) • x + (0:ℝ) • y) = x := by\n        simp\n      simp [g', GlobalTheorem.interpolated_deriv, hx, abs_mul, mul_assoc, mul_left_comm, mul_comm,\n        mul_le_mul_of_nonneg_right, hdiff' i, le_of_lt hε]\n    have hsum :\n        |∑ i, (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)|\n          ≤ ε * ∑ i, |nth_partial i f x| := by\n      calc\n        |∑ i, (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)|\n            ≤ ∑ i, |(y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)| := by\n              simpa using (abs_sum_le_sum_abs\n                (f := fun i : Fin n => (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)))\n        _ ≤ ∑ i, ε * |nth_partial i f x| := by\n              exact Finset.sum_le_sum (fun i _ => hterm i)\n        _ = ε * ∑ i, |nth_partial i f x| := by\n              simp [Finset.mul_sum, mul_assoc, mul_left_comm, mul_comm]\n    simpa [g', GlobalTheorem.interpolated_deriv] using hsum",
      "\n    classical\n    -- expand g' at 0 and simplify the interpolation point to `x`\n    have hx : ((1 - (0 : ℝ)) • x + (0 : ℝ) • y) = x := by simp\n    have hy : (∀ i : Fin n, |y i - x i| ≤ ε) := by\n      intro i\n      have := hdiff i\n      simpa [abs_sub_comm, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using this\n    have : |g' 0| ≤ ∑ i, |y i - x i| * |nth_partial i f x| := by\n      -- triangle inequality for finite sum, then rewrite the evaluation point\n      simpa [g', GlobalTheorem.interpolated_deriv, hx, mul_assoc, mul_left_comm, mul_comm] using\n        (Finset.abs_sum_le_sum_abs (s := Finset.univ)\n          (f := fun i : Fin n => (y i - x i) * nth_partial i f (((1 - (0 : ℝ)) • x + (0 : ℝ) • y))))\n    have : |g' 0| ≤ ε * ∑ i, |nth_partial i f x| := by\n      calc\n        |g' 0|\n            ≤ ∑ i, |y i - x i| * |nth_partial i f x| := this\n        _   ≤ ∑ i, ε * |nth_partial i f x| := by\n              refine Finset.sum_le_sum ?_\n              intro i hi\n              have hi' : |y i - x i| ≤ ε := hy i\n              exact mul_le_mul_of_nonneg_right hi' (abs_nonneg _)\n        _   = ε * ∑ i, |nth_partial i f x| := by\n              simp [Finset.mul_sum]\n    exact this",
      "\n    dsimp [g', GlobalTheorem.interpolated_deriv]\n    have hε' : 0 ≤ ε := le_of_lt hε\n    have hdiff' : (i : Fin n) → |y i - x i| ≤ ε := by\n      intro i\n      simpa [abs_sub_comm, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using hdiff i\n    have hx : ((1 - (0:ℝ)) • x + (0:ℝ) • y) = x := by simp\n    -- apply triangle inequality and bound each term\n    calc\n      |∑ i, (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)|\n          ≤ ∑ i, |(y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)| := by\n              simpa using (abs_sum_le_sum_abs (f := fun i : Fin n =>\n                (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)))\n      _ = ∑ i, |y i - x i| * |nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)| := by\n            refine Finset.sum_congr rfl ?_\n            intro i hi\n            simp [abs_mul]\n      _ ≤ ∑ i, ε * |nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)| := by\n            refine Finset.sum_le_sum ?_\n            intro i hi\n            have := mul_le_mul_of_nonneg_right (hdiff' i) (by positivity : 0 ≤ |nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)|)\n            simpa [mul_assoc] using this\n      _ = ε * ∑ i, |nth_partial i f x| := by\n            simp [Finset.mul_sum, hx, mul_comm, mul_left_comm, mul_assoc]",
      "\n    classical\n    have hx : (1 - (0 : ℝ)) • x + (0 : ℝ) • y = x := by\n      simp\n    have hg'0 :\n        g' 0 = ∑ i, (y i - x i) * nth_partial i f x := by\n      simp [g', GlobalTheorem.interpolated_deriv, hx]\n    have habs : |g' 0| ≤ ∑ i, |(y i - x i) * nth_partial i f x| := by\n      simpa [hg'0] using (abs_sum_le_sum_abs (fun i => (y i - x i) * nth_partial i f x))\n    have habs' : ∑ i, |(y i - x i) * nth_partial i f x|\n        = ∑ i, |y i - x i| * |nth_partial i f x| := by\n      refine Finset.sum_congr rfl ?_\n      intro i hi\n      simpa [mul_assoc] using (abs_mul (y i - x i) (nth_partial i f x))\n    have hle1 : |g' 0| ≤ ∑ i, |y i - x i| * |nth_partial i f x| := by\n      simpa [habs'] using habs\n    have hle2 : (∑ i, |y i - x i| * |nth_partial i f x|)\n        ≤ ε * ∑ i, |nth_partial i f x| := by\n      have hterm : ∀ i : Fin n, |y i - x i| * |nth_partial i f x| ≤ ε * |nth_partial i f x| := by\n        intro i\n        have : |y i - x i| ≤ ε := by\n          have := hdiff i\n          simpa [abs_sub_comm, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using this\n        exact mul_le_mul_of_nonneg_right this (abs_nonneg _)\n      have := Finset.sum_le_sum (fun i hi => hterm i)\n      simpa [Finset.mul_sum] using this\n    exact le_trans hle1 hle2",
      "\n    dsimp [g', GlobalTheorem.interpolated_deriv]\n    have hxye : ∀ i : Fin n, |y i - x i| ≤ ε := by\n      intro i\n      have := hdiff i\n      simpa [abs_sub_comm, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using this\n    have hmul :\n        ∀ i : Fin n, |(y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)|\n          ≤ ε * |nth_partial i f x| := by\n      intro i\n      have h0 : ((1 - (0:ℝ)) • x + (0:ℝ) • y) = x := by\n        simp\n      simp [h0, abs_mul, mul_assoc, mul_left_comm, mul_comm, mul_le_mul_of_nonneg_right,\n        (abs_nonneg _), hxye i]\n    have hsum :\n        |∑ i, (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y)|\n          ≤ ∑ i, ε * |nth_partial i f x| := by\n      simpa using\n        (norm_sum_le (f := fun i : Fin n =>\n          (y i - x i) * nth_partial i f ((1 - (0:ℝ)) • x + (0:ℝ) • y))).trans\n          (by\n            refine Finset.sum_le_sum ?_\n            intro i hi\n            simpa using hmul i)\n    have hfac : (∑ i : Fin n, ε * |nth_partial i f x|) = ε * ∑ i : Fin n, |nth_partial i f x| := by\n      simp [Finset.mul_sum]\n    have h0 : ((1 - (0:ℝ)) • x + (0:ℝ) • y) = x := by\n      simp\n    simpa [h0, hfac] using hsum",
