lemma offDiagonalHasLaw (n : ℕ) {i j : Fin n} (h : i ≠ j) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
  wlog hij : i < j
  · have hji : j < i := lt_of_le_of_ne (le_of_not_gt hij) (Ne.symm h)
    have : HasLaw (fun ω ↦ (wignerMatrixMap n ω) j i) μ (WignerMeasure μ ν n) := by
      exact offDiagonalHasLaw' (μ := μ) (ν := ν) n hji
    have hsymm : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ (wignerMatrixMap n ω) j i) := by
      funext ω
      simpa [wignerMatrixSymmetric (μ := μ) (ν := ν) n i j] using (rfl : wignerMatrixMap n ω i j = wignerMatrixMap n ω i j)
    simpa [hsymm] using this
  · exact offDiagonalHasLaw' (μ := μ) (ν := ν) n hij
