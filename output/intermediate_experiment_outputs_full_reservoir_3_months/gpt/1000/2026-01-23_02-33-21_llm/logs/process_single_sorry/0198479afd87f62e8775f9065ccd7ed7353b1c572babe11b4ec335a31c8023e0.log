     -- idx1 = 0\n            cases idx2 using Fin.cases with\n            | hz =>\n              -- idx2 = 0\n              simp at hEq\n              subst hEq\n              simp\n            | hs idx2 =>\n              cases idx2 using Fin.cases with\n              | hz =>\n                -- idx2 = 1\n                simp at hEq\n                subst hEq\n                simp\n              | hs idx2 =>\n                -- idx2 >= 2, impossible since head values are x/y\n                simp at hEq\n          | hs idx1 =>\n            cases idx1 using Fin.cases with\n            | hz =>\n              -- idx1 = 1\n              cases idx2 using Fin.cases with\n              | hz =>\n                simp at hEq\n                subst hEq\n                simp\n              | hs idx2 =>\n                cases idx2 using Fin.cases with\n                | hz =>\n                  simp at hEq\n                  subst hEq\n                  simp\n                | hs idx2 =>\n                  simp at hEq\n            | hs idx1 =>\n              -- idx1 >= 2, reduce to tail\n              cases idx2 using Fin.cases with\n              | hz =>\n                simp at hEq\n              | hs idx2 =>\n                cases idx2 using Fin.cases with\n                | hz =>\n                  simp at hEq\n                | hs idx2 =>\n                  have hEq' : l[⟨idx1.1, by simpa using idx1.2⟩] = l[⟨idx2.1, by simpa using idx2.2⟩] := by\n                    simpa using hEq\n                  -- tails identical, erasing corresponding elements preserves Perm\n                  simpa using (List.Perm.refl _)\n        | trans hPerm1 hPerm2 IH1 IH2 =>\n          intro idx1 idx2 hEq\n          have hin : l1[idx1] ∈ _ := by\n            -- use permutation to find matching index in middle list\n            have : l1[idx1] ∈ _ := by\n              have : l1[idx1] ∈ l1 := by\n                rw [List.mem_iff_get]\n                exact ⟨idx1, rfl⟩\n              exact list_perm_in hPerm1 _ this\n            exact this\n          obtain ⟨j, hj⟩ := in_list_idx hin\n          have hEq1 : l1[idx1] = _[j] := by simpa [hj]\n          have hEq2 : _[j] = l2[idx2] := by simpa [hEq] using congrArg id hEq\n          have hP1 := IH1 (idx1 := idx1) (idx2 := j) hEq1\n          have hP2 := IH2 (idx1 := j) (idx2 := idx2) (by simpa [hj] using hEq)\n          exact List.Perm.trans hP1 hP2",
      "\n          intro idx1 idx2 hEq\n          cases idx1 using Fin.cases with\n          | zero =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              simp at hEq\n              subst hEq\n              simpa using hPerm\n            | succ idx2 =>\n              simp at hEq\n              have := (List.Perm.erase hPerm hEq)\n              simpa using this\n          | succ idx1 =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              simp at hEq\n              have := (List.Perm.erase (List.Perm.symm hPerm) (Eq.symm hEq))\n              simpa [List.Perm.symm_iff] using (List.Perm.symm this)\n            | succ idx2 =>\n              simp at hEq\n              have := IH (idx1 := idx1) (idx2 := idx2) hEq\n              simpa using this",
      "\n              have hx1 : (x :: l₁)[idx1] = l₁[⟨k, by\n                cases idx1 with\n                | mk v hv =>\n                  simp only [Fin.toNat_eq_val] at h1\n                  have : v = k + 1 := by exact h1\n                  subst this\n                  simpa [List.length_cons] using (Nat.succ_lt_succ_iff.mp hv)\n              ⟩] := by\n                cases idx1 with\n                | mk v hv =>\n                  simp only [Fin.toNat_eq_val] at h1\n                  have : v = k + 1 := by exact h1\n                  subst this\n                  simp [List.getElem_cons_succ]\n              have hx2 : (x :: l₂)[idx2] = l₂[⟨k2, by\n                cases idx2 with\n                | mk v hv =>\n                  simp only [Fin.toNat_eq_val] at h2\n                  have : v = k2 + 1 := by exact h2\n                  subst this\n                  simpa [List.length_cons] using (Nat.succ_lt_succ_iff.mp hv)\n              ⟩] := by\n                cases idx2 with\n                | mk v hv =>\n                  simp only [Fin.toNat_eq_val] at h2\n                  have : v = k2 + 1 := by exact h2\n                  subst this\n                  simp [List.getElem_cons_succ]\n              have hEq' :\n                l₁[⟨k, by\n                  cases idx1 with\n                  | mk v hv =>\n                    simp only [Fin.toNat_eq_val] at h1\n                    have : v = k + 1 := by exact h1\n                    subst this\n                    simpa [List.length_cons] using (Nat.succ_lt_succ_iff.mp hv)\n                ⟩] =\n                l₂[⟨k2, by\n                  cases idx2 with\n                  | mk v hv =>\n                    simp only [Fin.toNat_eq_val] at h2\n                    have : v = k2 + 1 := by exact h2\n                    subst this\n                    simpa [List.length_cons] using (Nat.succ_lt_succ_iff.mp hv)\n                ⟩] := by\n                  simpa [hx1, hx2] using hEq\n              have : (l₁.eraseIdx k).Perm (l₂.eraseIdx k2) :=\n                IH (idx1 := ⟨k, by\n                  cases idx1 with\n                  | mk v hv =>\n                    simp only [Fin.toNat_eq_val] at h1\n                    have : v = k + 1 := by exact h1\n                    subst this\n                    simpa [List.length_cons] using (Nat.succ_lt_succ_iff.mp hv)\n                ⟩) (idx2 := ⟨k2, by\n                  cases idx2 with\n                  | mk v hv =>\n                    simp only [Fin.toNat_eq_val] at h2\n                    have : v = k2 + 1 := by exact h2\n                    subst this\n                    simpa [List.length_cons] using (Nat.succ_lt_succ_iff.mp hv)\n                ⟩) hEq'\n              simpa [List.eraseIdx_cons, h1, h2] using this",
      "\n          intro idx1 idx2 hEq\n          cases idx1 using Fin.cases with\n          | zero =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              simpa using hPerm\n            | succ idx2 =>\n              have hx : x = l2[idx2.succ] := by\n                simpa using hEq\n              have : (l1.eraseIdx idx2).Perm (l2.eraseIdx idx2) := by\n                have := IH (idx1 := ⟨idx2.1, by\n                  simpa [List.length_cons] using idx2.2⟩) (idx2 := idx2) hx\n                simpa [List.eraseIdx, List.eraseIdx_cons_succ] using this\n              simpa [List.eraseIdx, List.eraseIdx_cons_zero, List.eraseIdx_cons_succ] using this\n          | succ idx1 =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              have hx : l1[idx1] = x := by\n                simpa using hEq\n              have : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx1) := by\n                have := IH (idx1 := idx1) (idx2 := ⟨idx1.1, by\n                  simpa [List.length_cons] using idx1.2⟩) hx\n                simpa [List.eraseIdx, List.eraseIdx_cons_succ] using this\n              simpa [List.eraseIdx, List.eraseIdx_cons_zero, List.eraseIdx_cons_succ] using this\n            | succ idx2 =>\n              have : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by\n                have := IH (idx1 := idx1) (idx2 := idx2) (by simpa using hEq)\n                simpa [List.eraseIdx, List.eraseIdx_cons_succ] using this\n              simpa [List.eraseIdx, List.eraseIdx_cons_succ] using this",
      "\n          intro idx1 idx2 hEq\n          cases idx1 using Fin.cases with\n          | zero =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              simp at hEq\n              subst hEq\n              simpa using hPerm\n            | succ idx2' =>\n              cases idx2' with\n              | mk j hj =>\n                have hEq' : l1[⟨j, by simpa using hj⟩] = x := by\n                  simpa [List.getElem_cons_succ] using hEq\n                have hmem : x ∈ l1 := by\n                  exact List.getElem_mem l1 j\n                have hperm' : (x :: l1).Perm (l1.insertIdx j x) := by\n                  simpa using (List.perm_insertIdx _ _ (idx := j) (a := x))\n                have hperm'' : (l1.insertIdx j x).Perm (x :: l2) := by\n                  exact hperm'.trans (List.Perm.cons x hPerm)\n                have : (l1.eraseIdx ⟨j, by simpa using hj⟩).Perm l2 := by\n                  have hcons : (x :: l1.eraseIdx ⟨j, by simpa using hj⟩).Perm (x :: l2) := by\n                    simpa [List.eraseIdx_cons_succ, List.getElem_cons_succ] using\n                      (ih (idx1 := ⟨j, by simpa using hj⟩) (idx2 := ⟨j, by simpa using hj⟩) (by rfl))\n                  exact List.Perm.cons_inv.mp hcons\n                simpa [List.eraseIdx_cons_zero, List.eraseIdx_cons_succ] using this\n          | succ idx1' =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              cases idx1' with\n              | mk i hi =>\n                have hEq' : x = l2[⟨i, by simpa using hi⟩] := by\n                  simpa [List.getElem_cons_succ] using hEq\n                have hmem : x ∈ l2 := by\n                  exact List.getElem_mem l2 i\n                have : l1.Perm (l2.eraseIdx ⟨i, by simpa using hi⟩) := by\n                  have hcons : (x :: l1).Perm (x :: l2.eraseIdx ⟨i, by simpa using hi⟩) := by\n                    simpa [List.eraseIdx_cons_succ, List.getElem_cons_succ] using\n                      (ih (idx1 := ⟨i, by simpa using hi⟩) (idx2 := ⟨i, by simpa using hi⟩) (by rfl))\n                  exact List.Perm.cons_inv.mp hcons\n                simpa [List.eraseIdx_cons_zero, List.eraseIdx_cons_succ] using this\n            | succ idx2' =>\n              cases idx1' with\n              | mk i hi =>\n                cases idx2' with\n                | mk j hj =>\n                  have hEq' : l1[⟨i, by simpa using hi⟩] = l2[⟨j, by simpa using hj⟩] := by\n                    simpa [List.getElem_cons_succ] using hEq\n                  have hpermEr : (l1.eraseIdx ⟨i, by simpa using hi⟩).Perm (l2.eraseIdx ⟨j, by simpa using hj⟩) :=\n                    ih (idx1 := ⟨i, by simpa using hi⟩) (idx2 := ⟨j, by simpa using hj⟩) hEq'\n                  simpa [List.eraseIdx_cons_succ] using List.Perm.cons x hpermEr",
      "\n          intro idx1 idx2 hEq\n          cases idx1 using Fin.cases with\n          | zero =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              simpa using IH (idx1 := (by\n                have : Fin l₁.length := ⟨0, by simpa using Nat.zero_lt_of_lt (by\n                  have : 0 < (x :: l₁).length := by simpa using Nat.succ_pos _\n                  exact this)⟩\n                exact this)) (idx2 := (by\n                have : Fin l₂.length := ⟨0, by simpa using Nat.zero_lt_of_lt (by\n                  have : 0 < (x :: l₂).length := by simpa using Nat.succ_pos _\n                  exact this)⟩\n                exact this)) (by simpa using hEq)\n            | succ idx2' =>\n              simp at hEq\n          | succ idx1' =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              simp at hEq\n            | succ idx2' =>\n              have hEq' : l₁[idx1'] = l₂[idx2'] := by\n                simpa using hEq\n              simpa [List.eraseIdx_cons_succ, Fin.toNat_eq_val] using\n                IH (idx1 := idx1') (idx2 := idx2') hEq'",
      "rfl\n                  | succ v =>\n                    simp at hv\n              have h2' : (idx2 : Nat) = 0 := by\n                cases idx2 with\n                | mk v hv =>\n                  cases v with\n                  | zero => rfl\n                  | succ v =>\n                    have : (x :: l2)[⟨Nat.succ v, hv⟩] ≠ x := by\n                      simp\n                    have : (x :: l2)[idx2] ≠ x := by simpa using this\n                    have : (x :: l2)[idx2] ≠ (x :: l1)[idx1] := by\n                      simpa [hx1] using this\n                    exact (False.elim (this (by simpa [hEq])))\n              subst h2'\n              simpa using hPerm\n            · by_cases h2 : (idx2 : Nat) = 0\n              · subst h2\n                have hx2 : (x :: l2)[idx2] = x := by\n                  cases idx2 with\n                  | mk v hv =>\n                    cases v with\n                    | zero => rfl\n                    | succ v =>\n                      simp at hv\n                have h1' : (idx1 : Nat) = 0 := by\n                  cases idx1 with\n                  | mk v hv =>\n                    cases v with\n                    | zero => rfl\n                    | succ v =>\n                      have : (x :: l1)[⟨Nat.succ v, hv⟩] ≠ x := by\n                        simp\n                      have : (x :: l1)[idx1] ≠ x := by simpa using this\n                      have : (x :: l1)[idx1] ≠ (x :: l2)[idx2] := by\n                        simpa [hx2] using this\n                      exact (False.elim (this (by simpa [hEq])))\n                exact False.elim (h1 h1')\n              ·\n                cases idx1 with\n                | mk i hi =>\n                  cases idx2 with\n                  | mk j hj =>\n                    have hi' : i < l1.length := by\n                      have : i ≠ 0 := by\n                        intro h0; apply h1; simpa [h0]\n                      cases i with\n                      | zero => cases this rfl\n                      | succ i' =>\n                        simpa [Nat.succ_lt_succ_iff] using hi\n                    have hj' : j < l2.length := by\n                      have : j ≠ 0 := by\n                        intro h0; apply h2; simpa [h0]\n                      cases j with\n                      | zero => cases this rfl\n                      | succ j' =>\n                        simpa [Nat.succ_lt_succ_iff] using hj\n                    have hEq' : l1[⟨i-1, by\n                        cases i with\n                        | zero => simp at h1\n                        | succ i' =>\n                          simpa using (Nat.lt_of_succ_lt_succ (by\n                            simpa [Nat.succ_eq_add_one] using hi))\n                      ⟩] = l2[⟨j-1, by\n                        cases j with\n                        | zero => simp at h2\n                        | succ j' =>\n                          simpa using (Nat.lt_of_succ_lt_succ (by\n                            simpa [Nat.succ_eq_add_one] using hj))\n                      ⟩] := by\n                        cases i with\n                        | zero => simp at h1\n                        | succ i' =>\n                          cases j with\n                          | zero => simp at h2\n                          | succ j' =>\n                            simpa using hEq\n                    have := ih (idx1 := ⟨i-1, by\n                      cases i with\n                      | zero => simp at h1\n                      | succ i' =>\n                        simpa using (Nat.lt_of_succ_lt_succ (by\n                          simpa [Nat.succ_eq_add_one] using hi))\n                    ⟩) (idx2 := ⟨j-1, by\n                      cases j with\n                      | zero => simp at h2\n                      | succ j' =>\n                        simpa using (Nat.lt_of_succ_lt_succ (by\n                          simpa [Nat.succ_eq_add_one] using hj))\n                    ⟩) hEq'\n                    simpa [List.eraseIdx, h1, h2] using this",
      "\n          intro idx1 idx2 hEq\n          cases' idx1 with i1 hi1\n          cases' idx2 with i2 hi2\n          cases i1 using Nat.casesOn with\n          | zero =>\n            cases i2 using Nat.casesOn with\n            | zero =>\n              simpa using hPerm\n            | succ j2 =>\n              -- impossible: head equals a later element in (x :: l2) but RHS head is x\n              have : x = l2[j2] := by\n                simpa [List.getElem_cons, Nat.succ_eq_add_one] using hEq\n              -- remove head on left, remove succ on right, then use IH after swapping x forward\n              have : (l1.Perm (l2.eraseIdx j2)) := by\n                -- from (x :: l1) ~ (x :: l2), cancel x then erase matching element\n                have hxmem : l2[j2] ∈ l2 := by\n                  exact List.get_mem _ _\n                have hxmem' : x ∈ l2 := by simpa [this] using hxmem\n                have : x ∈ (x :: l2) := by simp\n                have : x ∈ (x :: l1) := by\n                  exact (hPerm.subset (by simp)) this\n                have : x ∈ l1 := by\n                  simpa [List.mem_cons] using this\n                -- not needed explicitly; rely on permutation lemma after erasing matching on right via IH on swapped perm\n                exact (hPerm.trans (by\n                  -- (x :: l2).eraseIdx (succ j2) = x :: (l2.eraseIdx j2)\n                  -- so it suffices to show l1.Perm (l2.eraseIdx j2)\n                  simpa [List.eraseIdx_cons_succ] using (List.Perm.refl (x :: l2)))).tail\n              -- simplify the goal directly\n              simpa [List.eraseIdx_cons_zero, List.eraseIdx_cons_succ] using (IH (idx1 := ⟨0, by simpa using Nat.zero_lt_succ _⟩) (idx2 := ⟨j2, by simpa using Nat.lt_of_succ_lt_succ hi2⟩) (by simpa [List.getElem_cons] using this))\n          | succ j1 =>\n            cases i2 using Nat.casesOn with\n            | zero =>\n              -- symmetric to previous impossible case\n              have : l1[j1] = x := by\n                simpa [List.getElem_cons, Nat.succ_eq_add_one] using hEq\n              have : x = l1[j1] := this.symm\n              simpa [List.eraseIdx_cons_zero, List.eraseIdx_cons_succ] using (IH (idx1 := ⟨j1, by simpa using Nat.lt_of_succ_lt_succ hi1⟩) (idx2 := ⟨0, by simpa using Nat.zero_lt_succ _⟩) (by simpa [List.getElem_cons] using this))\n            | succ j2 =>\n              -- both indices in the tail: reduce to IH\n              have hEq' : l1[j1] = l2[j2] := by\n                simpa [List.getElem_cons, Nat.succ_eq_add_one] using hEq\n              have := IH (idx1 := ⟨j1, by simpa using Nat.lt_of_succ_lt_succ hi1⟩) (idx2 := ⟨j2, by simpa using Nat.lt_of_succ_lt_succ hi2⟩) hEq'\n              simpa [List.eraseIdx_cons_succ] using this",
      "cases h2\n                  | succ j =>\n                    have hj' : j < l2.length := by simpa using (Nat.lt_of_succ_lt_succ hv)\n                    -- use IH to erase matching x's at head and at k+1, then perm to erase at j+1; simplify\n                    have hx0 : (x :: l1)[⟨0, by simpa [List.length_cons]⟩] = (x :: l2)[⟨k.1 + 1, by simpa [List.length_cons] using Nat.succ_lt_succ k.2⟩] := by\n                      simpa [List.getElem_cons_zero, hk']\n                    have hbase := IH (idx1 := ⟨0, by simpa [List.length_cons]⟩)\n                                      (idx2 := ⟨k.1 + 1, by simpa [List.length_cons] using Nat.succ_lt_succ k.2⟩) hx0\n                    -- left side: eraseIdx 0 gives l1; right side: eraseIdx (k+1) gives (x::l2).eraseIdx (k+1)\n                    have hbase' : l1.Perm ((x :: l2).eraseIdx (k.1 + 1)) := by\n                      simpa [List.eraseIdx_cons_zero] using hbase\n                    -- now show ((x::l2).eraseIdx (k+1)) perm (l2.eraseIdx j)\n                    have : ((x :: l2).eraseIdx (k.1 + 1)).Perm (l2.eraseIdx j) := by\n                      -- eraseIdx (succ j) on (x::l2) is eraseIdx j on l2\n                      have : ((x :: l2).eraseIdx (Nat.succ j)) = (l2.eraseIdx j) := by\n                        simp [List.eraseIdx_cons_succ]\n                      -- use list_Perm_eraseIdx to change erased index among equal elements in permuted lists (refl perm)\n                      -- simplify via this equality by rewriting with idx2 = succ j and choosing same\n                      simpa [this]\n                    exact hbase'.trans this\n              -- finally simplify eraseIdx on (x::l1) at idx1=0 and on (x::l2) at idx2=succ j\n              cases idx1 with\n              | mk v hv =>\n                simp only [Fin.val_mk] at h1\n                subst v\n                cases idx2 with\n                | mk v2 hv2 =>\n                  simp only [Fin.val_mk] at h2\n                  cases v2 with\n                  | zero => cases h2\n                  | succ j =>\n                    simpa [List.eraseIdx_cons_zero, List.eraseIdx_cons_succ] using this\n          | succ i =>\n            cases h2 : idx2.val with\n            | zero =>\n              -- symmetric to previous case\n              have hx : (x :: l2)[idx2] = x := by\n                cases idx2 with\n                | mk v hv =>\n                  simp only [Fin.val_mk] at h2\n                  subst v\n                  simp\n              have : (x :: l1)[idx1] = x := by simpa [hx] using hEq\n              cases idx1 with\n              | mk v hv =>\n                simp only [List.length_cons, Fin.val_mk] at h1\n                cases v with\n                | zero => cases h1\n                | succ j =>\n                  have hj : j < l1.length := by simpa using (Nat.lt_of_succ_lt_succ hv)\n                  -- reduce to previous case by symmetry using Perm.symm\n                  have h' : (l2.eraseIdx 0).Perm ((x :: l1).eraseIdx (Nat.succ j)) := by\n                    have hx0 : (x :: l2)[⟨0, by simpa [List.length_cons]⟩] = (x :: l1)[⟨j + 1, by simpa [List.length_cons] using Nat.succ_lt_succ hj⟩] := by\n                      simpa [List.getElem_cons_zero, this]\n                    have := (perm_eraseIdx (l1 := (x :: l2)) (l2 := (x :: l1)) (hPerm := (List.Perm.cons x hPerm).symm)\n                      (idx1 := ⟨0, by simpa [List.length_cons]⟩)\n                      (idx2 := ⟨j + 1, by simpa [List.length_cons] using Nat.succ_lt_succ hj⟩)) hx0\n                    simpa [List.eraseIdx_cons_zero] using this\n                  have : ((x :: l1).eraseIdx (Nat.succ j)).Perm l2 := by\n                    simpa [List.eraseIdx_cons_succ] using h'.symm\n                  simpa [List.eraseIdx_cons_succ, List.eraseIdx_cons_zero] using this\n            | succ j =>\n              -- both indices in tail, reduce to IH\n              have hi1 : i < l1.length := by\n                cases idx1 with\n                | mk v hv =>\n                  simp only [List.length_cons, Fin.val_mk] at h1\n                  subst v\n                  simpa using (Nat.lt_of_succ_lt_succ hv)\n              have hi2 : j < l2.length := by\n                cases idx2 with\n                | mk v hv =>\n                  simp only [List.length_cons, Fin.val_mk] at h2\n                  subst v\n                  simpa using (Nat.lt_of_succ_lt_succ hv)\n              have hEq' : l1[⟨i, hi1⟩] = l2[⟨j, hi2⟩] := by\n                -- strip heads\n                cases idx1 with\n                | mk v hv =>\n                  cases idx2 with\n                  | mk v2 hv2 =>\n                    simp only [List.length_cons, Fin.val_mk] at h1 h2\n                    subst v; subst v2\n                    simpa [List.getElem_cons_succ] using hEq\n              have hPerm' := IH (idx1 := ⟨i, hi1⟩) (idx2 := ⟨j, hi2⟩) hEq'\n              -- lift back under cons\n              cases idx1 with\n              | mk v hv =>\n                cases idx2 with\n                | mk v2 hv2 =>\n                  simp only [List.length_cons, Fin.val_mk] at h1 h2\n                  subst v; subst v2\n                  simpa [List.eraseIdx_cons_succ] using hPerm'",
      "\n            intro idx1 idx2 hEq\n            cases idx1 using Fin.cases with\n            | zero =>\n                cases idx2 using Fin.cases with\n                | zero =>\n                    simp at hEq\n                    subst hEq\n                    simpa using hPerm\n                | succ idx2' =>\n                    have hx : x ∈ (x :: l₂) := by simp\n                    have hx' : x ∈ (x :: l₂).eraseIdx (Fin.succ idx2') := by\n                      simpa [List.eraseIdx] using List.mem_eraseIdx_of_mem hx (by simp)\n                    have : False := by\n                      simp [List.eraseIdx, List.getElem_cons_succ] at hEq\n                      exact this.elim\n                    contradiction\n            | succ idx1' =>\n                cases idx2 using Fin.cases with\n                | zero =>\n                    have : False := by\n                      simp [List.getElem_cons_succ] at hEq\n                      exact this.elim\n                    contradiction\n                | succ idx2' =>\n                    have hEq' : l₁[idx1'] = l₂[idx2'] := by\n                      simpa [List.getElem_cons_succ] using hEq\n                    simpa [List.eraseIdx] using ih (idx1 := idx1') (idx2 := idx2') hEq'",
