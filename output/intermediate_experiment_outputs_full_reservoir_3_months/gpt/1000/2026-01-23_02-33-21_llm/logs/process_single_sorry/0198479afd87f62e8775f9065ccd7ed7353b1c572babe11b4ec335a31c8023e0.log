ing h2)\n                    contradiction\n            | inr h1 =>\n                cases hx2 with\n                | inl h2 =>\n                    -- idx2 is head, idx1 in tail: symmetric impossible\n                    subst h2\n                    have : (x :: l₁)[idx1] = x := by simpa [List.getElem_cons, Nat.not_lt_zero] using hEq'.symm\n                    -- similarly impossible\n                    contradiction\n                | inr h2 =>\n                    -- both in tails\n                    cases idx1 with\n                    | mk i hi =>\n                      cases idx2 with\n                      | mk j hj =>\n                        have hi' : i - 1 < l₁.length := by\n                          have hi0 : 0 < i := by simpa using h1\n                          have : i < l₁.length + 1 := by simpa [List.length_cons] using hi\n                          have : i ≤ l₁.length := Nat.le_of_lt_succ this\n                          exact Nat.pred_lt_iff.mp ⟨Nat.ne_of_gt hi0, this⟩\n                        have hj' : j - 1 < l₂.length := by\n                          have hj0 : 0 < j := by simpa using h2\n                          have : j < l₂.length + 1 := by simpa [List.length_cons] using hj\n                          have : j ≤ l₂.length := Nat.le_of_lt_succ this\n                          exact Nat.pred_lt_iff.mp ⟨Nat.ne_of_gt hj0, this⟩\n                        have hEqTail : l₁[⟨i-1, hi'⟩] = l₂[⟨j-1, hj'⟩] := by\n                          simpa [List.getElem_cons_succ, Nat.succ_pred_eq_of_pos (by simpa using h1),\n                            Nat.succ_pred_eq_of_pos (by simpa using h2)] using hEq'\n                        have hPermEr : (l₁.eraseIdx (i-1)).Perm (l₂.eraseIdx (j-1)) := ih (idx1 := ⟨i-1, hi'⟩) (idx2 := ⟨j-1, hj'⟩) hEqTail\n                        -- eraseIdx in cons with succ index\n                        simpa [List.eraseIdx_cons_succ, Nat.succ_pred_eq_of_pos (by simpa using h1),\n                          Nat.succ_pred_eq_of_pos (by s