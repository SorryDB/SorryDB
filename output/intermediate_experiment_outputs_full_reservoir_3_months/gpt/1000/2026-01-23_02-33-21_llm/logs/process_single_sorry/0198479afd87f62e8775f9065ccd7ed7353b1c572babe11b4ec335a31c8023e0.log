      "\n                    simp only [List.getElem_cons_zero, List.getElem_cons_succ] at hEq\n                    have : l₁[idx2] = x := by simpa [hEq] using (Eq.symm hEq)\n                    have hperm' : (l₁.eraseIdx idx2).Perm l₂ := by\n                      have := ih (idx1 := idx2) (idx2 := ⟨0, by simpa⟩) this\n                      simpa [List.eraseIdx, List.eraseIdx_cons] using this\n                    exact hperm'.trans (List.Perm.symm (List.Perm.cons _ (List.Perm.refl _)))\n            | succ idx1 =>\n                cases idx2 using Fin.cases with\n                | zero =>\n                    simp only [List.getElem_cons_succ, List.getElem_cons_zero] at hEq\n                    have : l₁[idx1] = x := by simpa using hEq\n                    have hperm' : l₁.Perm (l₂.eraseIdx idx1) := by\n                      have := ih (idx1 := ⟨0, by simpa⟩) (idx2 := idx1) (by simpa [this])\n                      simpa [List.eraseIdx, List.eraseIdx_cons] using this\n                    exact (List.Perm.cons _ (List.Perm.refl _)).trans hperm'\n                | succ idx2 =>\n                    simp only [List.getElem_cons_succ] at hEq\n                    have := ih (idx1 := idx1) (idx2 := idx2) hEq\n                    simpa [List.eraseIdx, List.eraseIdx_cons] using List.Perm.cons x this",
