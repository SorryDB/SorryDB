hj2⟩\n              subst hj2\n              have hEq' : l1[j1] = l2[j2] := by\n                simpa using hEq\n              have hperm' : (l1.eraseIdx j1).Perm (l2.eraseIdx j2) := by\n                exact IH (idx1 := j1) (idx2 := j2) hEq'\n              simpa using hperm'",
      "\n                    -- both are head\n                    subst h1; subst h2\n                    simpa [List.eraseIdx, List.getElem_cons] using hPerm\n                | inr h2 =>\n                    -- idx1 is head, idx2 in tail: impossible\n                    subst h1\n                    have : x = (x :: l₂)[idx2] := by simpa [List.getElem_cons, Nat.not_lt_zero] using hEq'\n                    have : x ∈ l₂ := by\n                      cases idx2 with\n                      | mk j hj =>\n                        have hj' : 0 < j := by simpa using h2\n                        have : (x :: l₂)[⟨j, hj⟩] = l₂[⟨j-1, by\n                          have : j - 1 < l₂.length := by\n                            have : j < l₂.length + 1 := by simpa [List.length_cons] using hj\n                            simpa [Nat.lt_succ_iff] using (Nat.lt_of_lt_of_le (Nat.pred_lt (Nat.ne_of_gt hj')) (Nat.le_of_lt_succ this))\n                          simpa [Nat.succ_pred_eq_of_pos hj', List.getElem_cons_succ]⟩] := by\n                            simp [List.getElem_cons_succ, Nat.succ_pred_eq_of_pos hj']\n                        -- use membership via get\n                        have : l₂[⟨j-1, by\n                          have : j < l₂.length + 1 := by simpa [List.length_cons] using hj\n                          have : j - 1 < l₂.length := by\n                            have hj' : 0 < j := by simpa using h2\n                            exact Nat.pred_lt_iff.mp (by\n                              have : j ≤ l₂.length := Nat.le_of_lt_succ this\n                              exact And.intro (Nat.ne_of_gt hj') this)\n                          simpa using this⟩] = x := by\n                            simpa [this] using this.symm.trans (by simpa using this)\n                        exact List.get_mem _ _\n                    have : x ∈ l₁ := (hPerm.mem_iff).1 this\n                    -- but eraseIdx at head removes x, so x not in RHS\n                    have : x ∈ (x :: l₁).eraseIdx