                     exact ih (idx1 := idx1') (idx2 := idx2') hEq'\n                    simpa using List.Perm.cons x hPermErase",
      "\n            intro idx1 idx2 hEq\n            cases idx1 using Fin.cases with\n            | zero =>\n                cases idx2 using Fin.cases with\n                | zero =>\n                    simpa using IH (idx1 := ⟨0, by simpa⟩) (idx2 := ⟨0, by simpa⟩) (by simpa using hEq)\n                | succ idx2' =>\n                    have hx : x = (x :: l2)[Fin.succ idx2'] := by simpa using hEq\n                    have : False := by\n                      simpa [List.getElem_cons_succ] using hx\n                    contradiction\n            | succ idx1' =>\n                cases idx2 using Fin.cases with\n                | zero =>\n                    have hx : (x :: l1)[Fin.succ idx1'] = x := by simpa using hEq\n                    have : False := by\n                      simpa [List.getElem_cons_succ] using hx\n                    contradiction\n                | succ idx2' =>\n                    have hEq' : l1[idx1'] = l2[idx2'] := by\n                      simpa [List.getElem_cons_succ] using hEq\n                    have := IH (idx1 := idx1') (idx2 := idx2') hEq'\n                    simpa [List.eraseIdx_cons_succ] using this",
      "cases (Nat.lt_asymm hidx2 hidx2)\n                      | succ v =>\n                        simpa using hEq\n                have hxmem : x ∈ l2 := by\n                  have : x ∈ (x :: l1) := by simp\n                  exact list_perm_in (List.Perm.cons x hPerm) x this\n                have : False := by\n                  have : x ∈ l2.eraseIdx idx2 := by\n                    have : x ∈ (x :: l2).eraseIdx idx2 := by\n                      simpa [List.eraseIdx, hidx2.ne'] using (by\n                        have : x ∈ (x :: l2) := by simp\n                        exact this)\n                    simpa [List.eraseIdx, hidx2.ne'] using this\n                  simpa using this\n                contradiction\n            | inr hidx1 =>\n              cases h2 with\n              | inl hidx2 =>\n                subst hidx2\n                have : False := by\n                  have hxmem : x ∈ l1 := by\n                    have : x ∈ (x :: l1).eraseIdx idx1 := by\n                      cases idx1 with\n                      | mk v hv =>\n                        cases v with\n                        | zero => cases (Nat.lt_asymm hidx1 hidx1)\n                        | succ v =>\n                          simpa [List.eraseIdx, Nat.succ_ne_zero] using (by\n                            have : x ∈ x :: l1 := by simp\n                            exact this)\n                    simpa [List.eraseIdx, Nat.succ_ne_zero] using this\n                  simpa using hxmem\n                contradiction\n              | inr hidx2 =>\n                cases idx1 with\n                | mk v1 hv1 =>\n                  cases idx2 with\n                  | mk v2 hv2 =>\n                    cases v1 with\n                    | zero => cases (Nat.lt_asymm hidx1 hidx1)\n                    | succ v1' =>\n                      cases v2 with\n                      | zero => cases (Nat.lt_asymm hidx2 hidx2)\n                      | succ v2' =>\n                        have hEq' : l1[⟨v1', by simpa using Nat.lt_of_succ_lt_succ hv1⟩] =\n                            l2[⟨v2', by simpa using Nat.lt_of_succ_lt_succ hv2⟩] := by\n                              simpa using hEq\n                        simpa using ih (idx1 := ⟨v1', by simpa using Nat.lt_of_succ_lt_succ hv1⟩)\n                          (idx2 := ⟨v2', by simpa using Nat.lt_of_succ_lt_succ hv2⟩) hEq'",
      "\n            cases idx1.1 with\n            | zero =>\n              cases idx1 with\n              | mk v hv =>\n                simp at heq\n                subst v\n                have : (x :: l₂)[idx2] = x := by simpa using heq.symm\n                have : idx2.1 = 0 := by\n                  cases idx2 with\n                  | mk v hv =>\n                    cases v with\n                    | zero => rfl\n                    | succ v =>\n                      simp [List.getElem_cons_succ] at this\n                cases idx2 with\n                | mk v hv =>\n                  subst v\n                  simp\n                  exact hPerm\n            | succ k1 =>\n              cases idx1 with\n              | mk v1 hv1 =>\n                cases idx2 with\n                | mk v2 hv2 =>\n                  have hv1' : k1 < l₁.length := by\n                    simpa [List.length_cons, Nat.succ_lt_succ_iff] using hv1\n                  have hv2' : k2 < l₂.length := by\n                    simpa [List.length_cons, Nat.succ_lt_succ_iff, h2] using hv2\n                  have hv1eq : v1 = Nat.succ k1 := by\n                    simp only [Fin.toNat_eq_val] at *\n                    simpa using rfl\n                  have hv2eq : v2 = Nat.succ k2 := by\n                    simp only [Fin.toNat_eq_val] at *\n                    simpa using rfl\n                  have hget : l₁[⟨k1, hv1'⟩] = l₂[⟨k2, hv2'⟩] := by\n                    have : (x :: l₁)[⟨Nat.succ k1, by simpa [List.length_cons] using Nat.succ_lt_succ hv1'⟩]\n                          = (x :: l₂)[⟨Nat.succ k2, by simpa [List.length_cons] using Nat.succ_lt_succ hv2'⟩] := by\n                      simpa [h2] using heq\n                    simpa using this\n                  have := IH (idx1 := ⟨k1, hv1'⟩) (idx2 := ⟨k2, hv2'⟩) hget\n                  simpa [List.eraseIdx_cons_succ] using this",
      "\n            intro idx1 idx2 hEq\n            have hx : (x :: l1)[idx1] = (x :: l2)[idx2] := by simpa using hEq\n            cases idx1 using Fin.cases with\n            | zero =>\n                simp only [List.getElem_cons_zero] at hx\n                cases idx2 using Fin.cases with\n                | zero =>\n                    simp at hx\n                    simp [List.eraseIdx, IH] \n                | succ j2 =>\n                    have : False := by\n                      simpa [List.getElem_cons_succ] using hx\n                    contradiction\n            | succ j1 =>\n                cases idx2 using Fin.cases with\n                | zero =>\n                    have : False := by\n                      simpa [List.getElem_cons_succ] using hx\n                    contradiction\n                | succ j2 =>\n                    have hEq' : l1[⟨j1, by simpa using j1.2⟩] = l2[⟨j2, by simpa using j2.2⟩] := by\n                      simpa [List.getElem_cons_succ] using hx\n                    have hPerm' :\n                        (l1.eraseIdx ↑(⟨j1, by simpa using j1.2⟩ : Fin l1.length)).Perm\n                        (l2.eraseIdx ↑(⟨j2, by simpa using j2.2⟩ : Fin l2.length)) :=\n                      IH (idx1 := ⟨j1, by simpa using j1.2⟩) (idx2 := ⟨j2, by simpa using j2.2⟩) hEq'\n                    simpa [List.eraseIdx, Fin.toNat_eq_val] using (List.Perm.cons x hPerm')",
      "a) hEq\n                simp at this\n              contradiction\n          | succ i1' =>\n            cases i2 using Nat.casesOn with\n            | zero =>\n              have : False := by\n                have := congrArg (fun a => a) hEq\n                simp at this\n              contradiction\n            | succ i2' =>\n              have hi1' : i1' < l₁.length := by\n                simpa [List.length_cons, Nat.succ_lt_succ_iff] using hi1\n              have hi2' : i2' < l₂.length := by\n                simpa [List.length_cons, Nat.succ_lt_succ_iff] using hi2\n              have hEq' : l₁[⟨i1', hi1'⟩] = l₂[⟨i2', hi2'⟩] := by\n                simpa [List.getElem_cons_succ] using hEq\n              have hPerm' := ih (idx1 := ⟨i1', hi1'⟩) (idx2 := ⟨i2', hi2'⟩) hEq'\n              simpa [List.eraseIdx_cons_succ] using List.Perm.cons x hPerm'",
      "\n          intro idx1 idx2 hEq\n          have hx1 : idx1.toNat = 0 ∨ ∃ i : Fin l1.length, idx1 = Fin.succ i := by\n            cases hidx1: idx1.toNat with\n            | zero =>\n              left; exact hidx1\n            | succ k =>\n              right\n              have hk : k < l1.length := by\n                have : idx1.toNat < (x :: l1).length := idx1.isLt\n                simpa [hidx1, List.length_cons] using Nat.lt_of_succ_lt_succ this\n              refine ⟨⟨k, hk⟩, ?_⟩\n              apply Fin.ext\n              simpa [Fin.toNat_succ, hidx1]\n          have hx2 : idx2.toNat = 0 ∨ ∃ i : Fin l2.length, idx2 = Fin.succ i := by\n            cases hidx2: idx2.toNat with\n            | zero =>\n              left; exact hidx2\n            | succ k =>\n              right\n              have hk : k < l2.length := by\n                have : idx2.toNat < (x :: l2).length := idx2.isLt\n                simpa [hidx2, List.length_cons] using Nat.lt_of_succ_lt_succ this\n              refine ⟨⟨k, hk⟩, ?_⟩\n              apply Fin.ext\n              simpa [Fin.toNat_succ, hidx2]\n          cases hx1 with\n          | inl h1 =>\n            cases hx2 with\n            | inl h2 =>\n              subst h1; subst h2\n              simpa using hPerm\n            | inr h2 =>\n              rcases h2 with ⟨j, rfl⟩\n              have : x = l2[j] := by\n                simpa using hEq\n              have hmem : x ∈ l2 := by\n                exact List.get_mem _ _\n              obtain ⟨j0, hj0⟩ := in_list_idx (α := α) (l := l2) (x := x) hmem\n              have hperm' : (l1.eraseIdx (Fin.mk idx1.toNat (by\n                have : idx1.toNat < (x :: l1).length := idx1.isLt\n                simpa [List.length_cons] using Nat.lt_of_succ_lt_succ this))).Perm (l2.eraseIdx j0) := by\n                apply ih\n                simpa [hj0] using (show x = l2[j0] from by simpa [hj0])\n              have hswap : ((x :: l2).eraseIdx (Fin.succ j)).Perm (x :: (l2.eraseIdx j)) := by\n                simp\n              have hleft : ((x :: l1).eraseIdx (Fin.mk idx1.toNat (by\n                have : idx1.toNat < (x :: l1).length := idx1.isLt\n                simpa [List.length_cons] using Nat.lt_of_succ_lt_succ this))).Perm l1 := by\n                simp\n              have hright : (l2).Perm ((x :: l2).eraseIdx (Fin.succ j)) := by\n                have : (x :: (l2.eraseIdx j)).Perm ((x :: l2).eraseIdx (Fin.succ j)) := by\n                  exact hswap.symm\n                exact (List.Perm.trans (List.Perm.refl _) this)\n              exact (List.Perm.trans hleft (List.Perm.trans hPerm (List.Perm.refl _)))\n          | inr h1 =>\n            rcases h1 with ⟨i, rfl⟩\n            cases hx2 with\n            | inl h2 =>\n              subst h2\n              have : l1[i] = x := by\n                simpa using hEq\n              have hmem : x ∈ l1 := by\n                have : l1[i] ∈ l1 := List.get_mem _ _\n                simpa [this] using this\n              obtain ⟨i0, hi0⟩ := in_list_idx (α := α) (l := l1) (x := x) hmem\n              have : (l1.eraseIdx i).Perm (l2.eraseIdx i0) := by\n                apply ih\n                simpa [hi0] using (show l1[i] = l2[i0] from by simpa [hi0] using (by\n                  have : (x :: l1)[Fin.succ i] = (x :: l2)[Fin.mk 0 (Nat.zero_lt_succ _)] := by\n                    simpa using hEq\n                  simpa using this))\n              simpa using this\n            | inr h2 =>\n              rcases h2 with ⟨j, rfl⟩\n              have : l1[i] = l2[j] := by\n                simpa using hEq\n              have := ih (idx1 := i) (idx2 := j) this\n              simpa using this\n        | swap x y l =>\n          intro idx1 idx2 hEq\n          cases idx1 using Fin.cases with\n          | zero =>\n            cases idx2 using Fin.cases with\n            | zero =>\n              simp at hEq\n              subst hEq\n              simp\n            | succ j =>\n              simp at hEq\n              sub