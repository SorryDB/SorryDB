      "\n                have hx : l₁[idx1] = l₂[idx2] := by\n                  simpa [hidx1, hidx2] using hEq\n                have : (l₁.eraseIdx idx1).Perm (l₂.eraseIdx idx2) := by\n                  exact ih (idx1 := ⟨0, by simpa using (Nat.zero_lt_succ l₁.length)⟩)\n                           (idx2 := ⟨0, by simpa using (Nat.zero_lt_succ l₂.length)⟩) (by simpa using hx)\n                simpa [hidx1, hidx2, List.eraseIdx_cons] using this\n              | inr hpos2 =>\n                have : (x :: l₁)[idx1] = x := by simpa [hidx1]\n                have : (x :: l₂)[idx2] ≠ x := by\n                  cases idx2 with\n                  | mk v hv =>\n                    cases v with\n                    | zero =>\n                      simp at hpos2\n                    | succ v' =>\n                      simp [List.getElem_cons_succ]\n                have := congrArg (fun t => t) hEq\n                have : False := by\n                  apply this\n                  · simpa [hidx1]\n                  · cases idx2 with\n                    | mk v hv =>\n                      cases v with\n                      | zero =>\n                        simp at hpos2\n                      | succ v' =>\n                        simpa [List.getElem_cons_succ]\n                contradiction\n            | inr hpos1 =>\n              cases h2 with\n              | inl hidx2 =>\n                have : (x :: l₂)[idx2] = x := by simpa [hidx2]\n                have : (x :: l₁)[idx1] ≠ x := by\n                  cases idx1 with\n                  | mk v hv =>\n                    cases v with\n                    | zero =>\n                      simp at hpos1\n                    | succ v' =>\n                      simp [List.getElem_cons_succ]\n                have : False := by\n                  apply this\n                  · cases idx1 with\n                    | mk v hv =>\n                      cases v with\n                      | zero =>\n                        simp at hpo