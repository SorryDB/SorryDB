lemma IsSquareIntegrable.submartingale_sq_norm (hX : IsSquareIntegrable X 𝓕 P) :
    Submartingale (fun i ω ↦ ‖X i ω‖ ^ 2) 𝓕 P := by
  classical
  have hM := hX.martingale
  refine (hM.submartingale_norm_sq).congr ?_
  intro i
  have hMeas : AEStronglyMeasurable (X i) P :=
    ((hM.adapted i).mono (𝓕.le i)).aestronglyMeasurable
  exact (hMeas.norm.pow 2)
```
