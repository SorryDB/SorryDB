    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id :=
by
  constructor
  · intro h
    rcases h with ⟨f, hf⟩
    classical
    refine ⟨f, invFun f, ?_, ?_⟩
    · ext y
      exact invFun_comp hf y
    · ext x
