theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · intro h
    rcases h with ⟨f, hf⟩
    classical
    let g : V → U := fun v =>
      if hv : ∃ u : U, f u = v then Classical.choose hv else Classical.choice (by
        by_contra hU
        exact (not_false (by
          have : False := hU (by
            intro u
            exact False.elim (by
              have : (False) := False.elim (by trivial)
              exact this)))
          exact this))
    refine ⟨f, g, ?_, ?_⟩
    · funext v
      by_cases hv : ∃ u : U, f u = v
      · have hfu : f (Classical.choose hv) = v := Classical.choose_spec hv
        simp [Function.comp, g, hv, hfu]
      · simp [Function.comp, g, hv]
        exfalso
        apply hv
        rcases hf v with ⟨u, rfl⟩
        exact ⟨u, rfl⟩
    · funext u
      have hv : ∃ u' : U, f u' = f u := ⟨u, rfl⟩
      have hfu : f (Classical.choose hv) = f u := Classical.choose_spec hv
      have : Classical.choose hv = u := hf.injective hfu
      simp [Function.comp, g, hv, this]
