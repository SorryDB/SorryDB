-- exercise 1.2.ii.i
theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · rintro ⟨g, hg⟩ c
    refine ⟨g ≫ (id c), ?_⟩
    simpa [Category.split_epi, Category.IsRetraction, assoc, hg, id_comp, comp_id]
  · intro hs
    have hY : Function.Surjective (fun g : Hom Y Y => f ≫ g) := hs Y
    rcases hY (id Y) with ⟨g, hg⟩
    refine ⟨g, ?_⟩
    exact hg
```
