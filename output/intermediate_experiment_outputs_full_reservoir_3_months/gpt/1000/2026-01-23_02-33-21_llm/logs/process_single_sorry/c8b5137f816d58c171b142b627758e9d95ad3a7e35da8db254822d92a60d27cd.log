theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  -- use multinomial divisibility: (a! b! (a+b)!) ∣ (2a)! (2b)! via choose
  have hm : m ! * m ! ∣ (2 * m)! := by
    simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using
      (Nat.mul_factorial_dvd_factorial_add_factorial m m)
  have hn : n ! * n ! ∣ (2 * n)! := by
    simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using
      (Nat.mul_factorial_dvd_factorial_add_factorial n n)
  have hmn : m ! * n ! ∣ (m + n)! := by
    simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using
      (Nat.mul_factorial_dvd_factorial_add_factorial m n)
  rcases hm with ⟨am, ham⟩
  rcases hn with ⟨an, han⟩
  rcases hmn with ⟨a, ha⟩
  refine ⟨am * an * a, ?_⟩
  calc
    (2 * m)! * (2 * n)! =
        ((m ! * m !) * am) * ((n ! * n !) * an) := by
          simp [ham, han, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]
    _ = (m ! * n ! * (m + n)!) * (am * an * a) := by
          -- rearrange using ha : (m+n)! = m! * n! * a
          simp [ha, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]
```
