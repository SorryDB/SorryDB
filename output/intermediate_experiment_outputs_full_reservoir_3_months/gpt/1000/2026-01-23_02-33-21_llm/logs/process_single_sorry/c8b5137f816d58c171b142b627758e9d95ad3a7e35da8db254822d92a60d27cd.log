/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have h1 : m ! * m ! ∣ (2 * m)! := by
    simpa [two_mul, Nat.factorial_mul_factorial_dvd_factorial_add] using
      (Nat.factorial_mul_factorial_dvd_factorial_add m m)
  have h2 : n ! * n ! ∣ (2 * n)! := by
    simpa [two_mul, Nat.factorial_mul_factorial_dvd_factorial_add] using
      (Nat.factorial_mul_factorial_dvd_factorial_add n n)
  have h3 : m ! * n ! ∣ (m + n)! := by
    simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using
      (Nat.factorial_mul_factorial_dvd_factorial_add m n)
  rcases h1 with ⟨a, ha⟩
  rcases h2 with ⟨b, hb⟩
  rcases h3 with ⟨c, hc⟩
  refine ⟨a * b * c, ?_⟩
  calc
    (2 * m)! * (2 * n)! =
        (m ! * m !) * (n ! * n !) * (a * b) := by
          simp [ha, hb, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm, Nat.mul_mul_mul_comm]
    _ =
        (m ! * n ! * (m + n)!) * (a * b * c) := by
          simp [hc, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm, Nat.mul_mul_mul_comm]
