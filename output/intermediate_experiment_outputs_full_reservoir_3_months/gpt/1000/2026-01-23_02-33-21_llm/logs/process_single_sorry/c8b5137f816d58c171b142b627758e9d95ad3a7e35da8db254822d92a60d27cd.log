/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  classical
  -- use central binomial coefficients: (2m)! = (m!)^2 * C(2m,m)
  have hm : m ! * m ! ∣ (2 * m)! := by
    simpa [Nat.choose_mul_factorial_mul_factorial] using
      (Nat.mul_dvd_mul_right (m ! * m !) (Nat.dvd_mul_left ((2 * m).choose m) 1))
  have hn : n ! * n ! ∣ (2 * n)! := by
    simpa [Nat.choose_mul_factorial_mul_factorial] using
      (Nat.mul_dvd_mul_right (n ! * n !) (Nat.dvd_mul_left ((2 * n).choose n) 1))
  have hmn : m ! * n ! ∣ (m + n)! := by
    -- (m+n)! = m! * n! * C(m+n,m)
    simpa [Nat.choose_mul_factorial_mul_factorial, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc,
      Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm] using
      (Nat.dvd_mul_left ((m + n).choose m) (m ! * n !))
  -- combine divisibilities
  have h1 : m ! * n ! * (m ! * n !) ∣ (2 * m)! * (2 * n)! := by
    have : (m ! * m !) * (n ! * n !) ∣ (2 * m)! * (2 * n)! :=
      Nat.mul_dvd_mul hm hn
    simpa [Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm] using this
  have h2 : m ! * n ! * (m + n)! ∣ m ! * n ! * (m ! * n !) := by
    exact Nat.mul_dvd_mul_left (m ! * n !) hmn
  exact dvd_trans h2 h1
