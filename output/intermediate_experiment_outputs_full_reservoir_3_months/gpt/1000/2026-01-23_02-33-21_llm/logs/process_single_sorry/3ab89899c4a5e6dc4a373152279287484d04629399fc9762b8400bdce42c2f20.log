  · simp [lengthOfLIS, h, maxInArray]
  ·
    simp [lengthOfLIS, h]
    set n := nums.length
    set dp : Array Nat := Array.mkArray n 1
    set allSubseq :=
        (nums.foldl fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]] |>.map List.reverse
    set increasingSubseqLens :=
        allSubseq.filter (fun l => List.Pairwise (· < ·) l) |>.map (·.length)
    refine ⟨?_, ?_⟩
    ·
      have : (0 : Nat) ∈ increasingSubseqLens := by
        simp [increasingSubseqLens, allSubseq]
      simpa [maxInArray] using this
    ·
      have : increasingSubseqLens.all (· ≤ (0 : Nat)) := by
        simp [increasingSubseqLens, allSubseq]
      simpa [maxInArray] using this
  -- !benchmark @end proof
