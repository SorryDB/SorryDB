      "\n  classical\n  apply le_antisymm\n  ¬∑ refine sSup_le ?_\n    intro a ha\n    rcases ha with ‚ü®D, hD, haD‚ü©\n    have : a ‚Č§ sSup S := by\n      have hne : D.Nonempty := by\n        rcases Set.nonempty_iff_ne_empty.2 (by\n          intro h\n          have : ‚ä• ‚ąą D := by simpa [h] using (by rfl : (‚ä• : őĪ) ‚ąą (‚ąÖ : Set őĪ))\n          exact (R.bot_not_mem D hD) this) with ‚ü®x, hx‚ü©\n        exact ‚ü®x, hx‚ü©\n      have hsupD_le : sSup D ‚Č§ sSup S := by\n        refine sSup_le ?_\n        intro x hx\n        have hxS : x ‚ąą S := by\n          rcases hne with ‚ü®y, hy‚ü©\n          rcases R.carrier_span y (by\n            by_contra hyS\n            have := R.carrier_span y (by\n              exfalso\n              exact hyS)\n            exact False.elim (by\n              have := this; trivial)) with ‚ü®Dy, hDy, -, -‚ü©\n          rcases R.carrier_span x (by\n            by_contra hxS\n            have := R.carrier_span x (by\n              exfalso\n              exact hxS)\n            exact False.elim (by\n              have := this; trivial)) with ‚ü®Dx, hDx, -, -‚ü©\n          exact False.elim (by\n            have := hxS; trivial)\n        exact le_sSup (by simpa using hxS)\n      simpa [haD] using le_trans (le_rfl) hsupD_le\n    exact this\n  ¬∑ refine sSup_le ?_\n    intro a ha\n    rcases R.carrier_span a ha with ‚ü®D, hD, rfl, -‚ü©\n    exact le_trans (le_sSup (by\n      refine Set.mem_iUnion.2 ?_\n      exact ‚ü®D, Set.mem_iUnion.2 ‚ü®hD, by rfl‚ü©‚ü©)) (le_rfl)",
      "\n  apply le_antisymm\n  ¬∑ refine sSup_le ?_\n    intro a ha\n    simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha\n    rcases ha with ‚ü®D, hD, haD‚ü©\n    have hDS : sSup D ‚Č§ sSup S := by\n      refine sSup_le ?_\n      intro x hx\n      have hxS : x ‚ąą S := by\n        rcases (R.carrier_span _ hD).exists with ‚ü®I, hI, huniq, rfl‚ü©\n        have : D = I := (huniq D hD rfl).symm\n        have : x ‚ąą I := by simpa [this] using hx\n        rcases (R.carrier_span _ hD).exists with ‚ü®I', hI', huniq', ha‚ü©\n        have hIeq : I' = I := (huniq' I hI rfl).symm\n        have hxI' : x ‚ąą I' := by simpa [hIeq] using this\n        exact (R.carrier_span _ hD).choose_spec.1\n      exact le_sSup_of_le x (le_sSup_of_le hxS le_rfl)\n    exact le_trans (le_csSup (by classical exact Set.finite_range _) haD) hDS\n  ¬∑ refine sSup_le ?_\n    intro a ha\n    rcases R.carrier_span a ha with ‚ü®D, hD, huniq, rfl‚ü©\n    exact le_csSup_of_le (by classical exact Set.finite_range _) (by\n      refine le_csSup_of_le D (le_csSup_of_le hD ?_)\n      exact le_rfl)",
      "\n  apply le_antisymm\n  ¬∑ refine sSup_le ?_\n    intro a ha\n    simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha\n    rcases ha with ‚ü®D, hD, haD‚ü©\n    have hle : sSup D ‚Č§ sSup S := by\n      refine sSup_le ?_\n      intro x hx\n      have : ‚ąÉ a ‚ąą S, ‚ąÉ! D' ‚ąą R, a = sSup D' := R.carrier_span\n      rcases this x ?_ with ‚ü®a, haS, huniq‚ü©\n      ¬∑ refine le_trans ?_ (le_csSup (by\n          classical\n          exact Set.Nonempty.to_subtype ?_) haS)\n        exact le_csSup_of_le haS (le_rfl)\n      ¬∑ sorry\n    exact le_trans (le_csSup_of_le hD (le_rfl)) hle\n  ¬∑ refine sSup_le ?_\n    intro a haS\n    rcases R.carrier_span a haS with ‚ü®D, hD, huniq‚ü©\n    have : a = sSup D := huniq.1\n    rw [this]\n    refine le_trans (le_csSup_of_le ?_ (le_rfl)) (le_csSup_of_le hD (le_rfl))\n    exact ‚ü®D, hD, by rfl‚ü©",
      "\n  apply le_antisymm\n  ¬∑ refine sSup_le ?_\n    intro a ha\n    simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha\n    obtain ‚ü®D, hD, haD‚ü© := ha\n    obtain ‚ü®b, hbS, hbD‚ü© := haD\n    subst hbD\n    obtain ‚ü®D', hD'R, hb_eq, -‚ü© := R.carrier_span b hbS\n    subst hb_eq\n    have hDle : sSup D' ‚Č§ sSup (decomposition_of_refinement R) := by\n      refine sSup_le_sSup ?_\n      intro x hx\n      refine Set.mem_iUnion.2 ‚ü®D', Set.mem_iUnion.2 ‚ü®hD'R, hx‚ü©‚ü©\n    exact le_trans hDle (le_sSup (s := S) hbS)\n  ¬∑ refine sSup_le ?_\n    intro a haS\n    obtain ‚ü®D, hDR, ha_eq, -‚ü© := R.carrier_span a haS\n    subst ha_eq\n    have hDle : sSup D ‚Č§ sSup (decomposition_of_refinement R) := by\n      refine sSup_le_sSup ?_\n      intro x hx\n      refine Set.mem_iUnion.2 ‚ü®D, Set.mem_iUnion.2 ‚ü®hDR, hx‚ü©‚ü©\n    exact hDle",
      "\n  classical\n  apply le_antisymm\n  ¬∑ refine sSup_le ?_\n    intro a ha\n    rcases ha with ‚ü®D, hD, haD‚ü©\n    have hDS : ‚ąÄ x ‚ąą D, x ‚ąą S := by\n      intro x hx\n      obtain ‚ü®a, haS, huniq‚ü© := R.carrier_span x (by\n        have : x ‚ąą decomposition_of_refinement R := by exact ‚ü®D, hD, hx‚ü©\n        -- extract `x ‚ąą S` from `carrier_span` applied to `x ‚ąą S` is not possible directly,\n        -- so we instead use the existence part from `carrier_span` on `x` once `x ‚ąą S`;\n        -- thus we prove `x ‚ąą S` from `haD` by rewriting via `a = sSup D`.\n        -- We can do this by taking `a` itself to be `a` in `S` that generated `D`.\n        -- Here we use that `D ‚ąą carrier` implies each element of `D` lies in `S` by uniqueness\n        -- with the witness `x` itself.\n        exact False.elim (by\n          -- `carrier_span` only gives info for elements of `S`; no way to derive membership.\n          -- But in our usage `D` arises from some `a ‚ąą S` in `decomposition_of_refinement`,\n          -- hence each `x ‚ąą D` is in `S` by choosing that `a`.\n          -- This contradiction branch is unreachable in later code.\n          exact by\n            have := haD\n            cases this))\n      -- unreachable; provide a term using classical choice\n      exact by\n        -- Since we cannot derive `x ‚ąą S` from the given data alone, use `by_cases`.\n        by_cases hxS : x ‚ąą S\n        ¬∑ exact hxS\n        ¬∑ exfalso\n          exact hxS (by\n            -- but `x` is a summand of some `a ‚ąą S` by `carrier_span` applied to `a`\n            -- since `D ‚ąą carrier` it appears as the unique decomposition for itself\n            -- which forces `x ‚ąą S`\n            -- (use choice from `carrier_span` on `x` is impossible if `x ‚ąČ S`)\n            -- contradiction is achieved by `R.bot_not_mem`? no.\n            exact False.elim (by\n              have : True := trivial\n              exact (False.elim (by\n                have :=