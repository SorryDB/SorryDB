lemma sSup_eq_top' {S : Set őĪ} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  classical
  apply le_antisymm
  ¬∑ refine sSup_le ?_
    intro a ha
    simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
    obtain ‚ü®D, hD, haD‚ü© := ha
    obtain ‚ü®b, hbS, hb‚ü© := hD
    have hb' := (R.carrier_span b hbS).exists
    rcases hb' with ‚ü®D', hD', rfl‚ü©
    have : D = D' := (R.carrier_span b hbS).unique hD hD'
    subst this
    exact le_trans (le_sSup_of_le b (le_sSup hbS)) (le_of_eq hb.symm)
  ¬∑ refine sSup_le ?_
    intro b hbS
    rcases (R.carrier_span b hbS).exists with ‚ü®D, hD, rfl‚ü©
    exact sSup_le_sSup (by
      intro a haD
      refine ‚ü®D, ?_, haD‚ü©
      exact hD)
