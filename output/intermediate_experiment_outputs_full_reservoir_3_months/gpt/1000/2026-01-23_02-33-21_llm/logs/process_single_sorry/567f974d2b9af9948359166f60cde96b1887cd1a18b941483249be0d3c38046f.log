import Mathlib.Combinatorics.Additive.AP.Three.Defs

open Finset Real

theorem int {A : Finset ℕ} {N : ℕ} (hAN : A ⊆ range N) (hA : ThreeAPFree (α := ℕ) A) :
    ∃ c > 0, #A ≤ N / exp (- c * log N ^ (12⁻¹ : ℝ)) := by
  refine ⟨1, by norm_num, ?_⟩
  have hcard : (A.card : ℝ) ≤ N := by
    have hle : A.card ≤ N := card_le_of_subset hAN
    exact_mod_cast hle
  have hdenom : (0 : ℝ) < exp (- (1 : ℝ) * log (N : ℝ) ^ (12⁻¹ : ℝ)) := by
    simpa using exp_pos (- (1 : ℝ) * log (N : ℝ) ^ (12⁻¹ : ℝ))
  have hexp_ge : (1 : ℝ) ≤ exp (- (1 : ℝ) * log (N : ℝ) ^ (12⁻¹ : ℝ)) :=
    le_of_lt hdenom
  calc
    (A.card : ℝ) ≤ N := hcard
    _ = (N : ℝ) / 1 := by simp
    _ ≤ (N : ℝ) / exp (- (1 : ℝ) * log (N : ℝ) ^ (12⁻¹ : ℝ)) :=
      (div_le_div_of_nonneg_left (by exact_mod_cast (Nat.zero_le N)) hexp_ge)
