      "\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hτX' :\n      ∀ n, ∀ ω, ∀ x, ∃ l,\n        Tendsto (fun t => stoppedProcess (fun i => {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) t ω)\n          (𝓝[<] x) (𝓝 l) := by\n    intro n\n    simpa using hτX n\n  filter_upwards [hτ.tendsto_top] with ω hω\n  intro x\n  have hTop : ∀ i : ι, ∃ n : ℕ, (i : WithTop ι) < τ n ω := by\n    have := (WithTop.tendsto_atTop_nhds_top_iff.1 hω)\n    intro i\n    rcases this i with ⟨n, hn⟩\n    exact ⟨n, hn n le_rfl⟩\n  rcases hTop x with ⟨n, hn⟩\n  rcases hτX' n ω x with ⟨l, hl⟩\n  refine ⟨l, ?_⟩\n  have hle : (x : WithTop ι) ≤ τ n ω := le_of_lt hn\n  have hx :\n      (fun t => stoppedProcess (fun i => {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) t ω) =\n        fun t => X t ω := by\n    funext t\n    simp [stoppedProcess, hle, Set.indicator_of_mem, WithTop.bot_lt_coe]\n  simpa [hx] using hl",
      "\n  classical\n  obtain ⟨τ, hτ, hp⟩ := hX\n  filter_upwards [hτ.tendsto_top] with ω hω\n  intro x\n  have hx : ⊥ < τ 0 ω := by\n    have : (⊥ : WithTop ι) < ⊤ := bot_lt_top\n    exact lt_of_lt_of_le this <| (WithTop.tendsto_atTop_nhds_top_iff.1 hω) ⊥ 0 (by simp)\n  specialize hp 0 ω x\n  rcases hp with ⟨l, hl⟩\n  refine ⟨l, ?_⟩\n  simpa [stoppedProcess, hx, Set.indicator_of_mem] using hl",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hτtop : ∀ᵐ ω ∂P, ∀ x : ι, ∃ n, x < τ n ω := by\n    filter_upwards [hτ.tendsto_top] with ω hω x\n    have hx := (WithTop.tendsto_atTop_nhds_top_iff.1 hω) x\n    rcases hx with ⟨n, hn⟩\n    refine ⟨n, ?_⟩\n    have : (x : WithTop ι) < τ n ω := by\n      have := hn n le_rfl\n      simpa using this\n    simpa using this\n  filter_upwards [hτtop] with ω hω x\n  rcases hω x with ⟨n, hxn⟩\n  have hxmem : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := by\n    have : (⊥ : WithTop ι) < τ n ω := lt_trans (by simpa using (WithTop.bot_lt_coe x)) (by simpa using hxn)\n    simpa [Set.mem_setOf_eq] using this\n  have hxle : (x : WithTop ι) ≤ τ n ω := by\n    exact le_of_lt (by simpa using hxn)\n  have hst := hτX n ω x\n  refine ⟨_, ?_⟩\n  simpa [stoppedProcess, hxle, Set.indicator_of_mem hxmem] using hst",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have htop : ∀ᵐ ω ∂P, ∀ x, ∃ n, x < τ n ω := by\n    filter_upwards [hτ.tendsto_top] with ω hω\n    intro x\n    have hω' := (WithTop.tendsto_atTop_nhds_top_iff.1 hω) x\n    rcases hω' with ⟨n, hn⟩\n    exact ⟨n, hn n le_rfl⟩\n  filter_upwards [htop] with ω hω x\n  rcases hω x with ⟨n, hn⟩\n  specialize hτX n ω x\n  refine ⟨hτX.choose, ?_⟩\n  have hx : x ≤ τ n ω := le_of_lt hn\n  have hx' : (⊥ : WithTop ι) < τ n ω := lt_of_lt_of_le (bot_lt_coe x) hx\n  simpa [stoppedProcess, hx, hx', Set.indicator_of_mem, Pi.mul_apply] using hτX.choose_spec",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hmem : ∀ n, ∀ᵐ ω ∂P, ω ∈ {ω | ⊥ < τ n ω} := fun n ↦ by\n    have htop : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n    filter_upwards [htop] with ω hω\n    have : ∀ᶠ k in atTop, (⊥ : WithTop ι) < τ k ω := by\n      simpa [WithTop.tendsto_atTop_nhds_top_iff] using (hω.eventually (a := (⊥ : WithTop ι)) fun _ ↦ id)\n    exact this 0 (by simp)\n  have hprop : ∀ n, ∀ᵐ ω ∂P, ∀ x, ∃ l, Tendsto (X · ω) (𝓝[<] x) (𝓝 l) := fun n ↦ by\n    have : ∀ᵐ ω ∂P, ∀ x, ∃ l,\n        Tendsto (fun t => stoppedProcess (fun i => {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) t ω)\n          (𝓝[<] x) (𝓝 l) :=\n      by\n        simpa [Locally] using (ae_of_all _ (hτX n))\n    filter_upwards [this, hmem n] with ω hω hx x\n    specialize hω x\n    rcases hω with ⟨l, hl⟩\n    refine ⟨l, ?_⟩\n    have hEq : (fun t => stoppedProcess (fun i => {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) t ω)\n        = fun t => X t ω := by\n      funext t\n      have : (⊥ : WithTop ι) < τ n ω := hx\n      simp [stoppedProcess, this]\n    simpa [hEq] using hl\n  have hprop' : ∀ᵐ ω ∂P, ∀ n, ∀ x, ∃ l, Tendsto (X · ω) (𝓝[<] x) (𝓝 l) := by\n    exact ae_all_iff.2 (fun n ↦ hprop n)\n  filter_upwards [hprop'] with ω hω x\n  exact hω 0 x",
      "\n  rcases hX with ⟨τ, hτ, hXτ⟩\n  have hXτ' : ∀ n, ∀ ω x, ∃ l, Tendsto ((stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n)) · ω)\n      (𝓝[<] x) (𝓝 l) := fun n ↦ hXτ n\n  filter_upwards [hτ.tendsto_top] with ω hω\n  intro x\n  have hTop : Tendsto (τ · ω) atTop (𝓝 ⊤) := hω\n  rw [WithTop.tendsto_atTop_nhds_top_iff] at hTop\n  obtain ⟨n, hn⟩ := hTop x\n  specialize hn n le_rfl\n  have hmem : ⊥ < τ n ω := by\n    have hx : (x : WithTop ι) < τ n ω := hn\n    exact bot_lt_iff_ne_bot.2 (by\n      intro hbot\n      simp [hbot] at hx)\n  rcases hXτ' n ω x with ⟨l, hl⟩\n  refine ⟨l, ?_⟩\n  have hEq : (fun t => X t ω) = fun t =>\n      (stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n)) t ω := by\n    funext t\n    have ht : (t : WithTop ι) ≤ τ n ω := le_trans (le_of_lt (lt_of_lt_of_le (show t < x from ?_) hn)) le_rfl\n    · have : (t : WithTop ι) < τ n ω := lt_of_lt_of_le (show (t : WithTop ι) < x from ?_) (le_of_lt hn)\n      simp [stoppedProcess, this.ne', Set.indicator_of_mem, hmem]\n    · exact False.elim (by\n        have : t < x := by\n          simpa [nhdsWithin, Set.mem_Iio] using (show t ∈ Set.Iio x from by trivial)\n        exact this)\n  simpa [hEq] using hl",
      "\n  classical\n  refine (hX.IsLocalizingSequence.tendsto_top).mono ?_\n  intro ω hω x\n  by_cases hx : ∃ n, ⊥ < hX.localSeq n ω\n  · rcases hx with ⟨n, hn⟩\n    have hprop := hX.stoppedProcess n ω x\n    have hle : (hX.localSeq n ω : WithTop ι) ≤ x := by\n      by_contra hlt\n      have : Tendsto (hX.localSeq · ω) atTop (𝓝 ⊤) := hω\n      have hEvent : ∀ᶠ m in atTop, hX.localSeq m ω > x := by\n        simpa [WithTop.tendsto_atTop_nhds_top_iff] using (this (x : WithTop ι))\n      have hn' : ∀ᶠ m in atTop, hX.localSeq m ω ≥ hX.localSeq n ω := by\n        have hmono := (hX.IsLocalizingSequence.mono).eventually\n        have hmonoω : Monotone (hX.localSeq · ω) := by\n          exact (hmono).self_of_nhds (by rfl)\n        exact (eventually_ge_atTop n).mono (fun m hm => hmonoω hm)\n      have : ∀ᶠ m in atTop, (hX.localSeq n ω : WithTop ι) < hX.localSeq m ω := by\n        filter_upwards [hEvent, hn'] with m hmx hmn\n        exact lt_of_lt_of_le (show (x : WithTop ι) < hX.localSeq m ω by exact hmx) hmn\n      have : (hX.localSeq n ω : WithTop ι) < ⊤ :=\n        lt_of_lt_of_le (this.self_of_nhds (by rfl)) le_top\n      exact not_le_of_lt this (le_top)\n    have hstopped_eq :\n        (fun t => stoppedProcess (fun i => {ω | ⊥ < hX.localSeq n ω}.indicator (X i)) (hX.localSeq n) t ω)\n          = fun t => X t ω := by\n      funext t\n      have : t ≤ hX.localSeq n ω := le_trans le_rfl (by exact le_of_lt (lt_of_lt_of_le hn hle))\n      simp [stoppedProcess, this, Set.indicator_of_mem, hn]\n    refine ⟨_, ?_⟩\n    simpa [hstopped_eq] using hprop\n  · have : Tendsto (hX.localSeq · ω) atTop (𝓝 ⊤) := hω\n    have hneg : ∀ n, ¬ (⊥ : WithTop ι) < hX.localSeq n ω := by\n      intro n hn\n      exact hx ⟨n, hn⟩\n    have : Tendsto (hX.localSeq · ω) atTop (𝓝 (⊥ : WithTop ι)) := by\n      refine tendsto_principal.2 ?_\n      simp [Filter.eventually_atTop, hneg]\n    have : (⊤ : WithTop ι) = (⊥ : WithTop ι) := by\n      exact tendsto_nhds_unique this hω\n    cases this",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have htop : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [htop] with ω hω\n  intro x\n  have hx : ∃ n, (x : WithTop ι) < τ n ω := by\n    have : (x : WithTop ι) ∈ 𝓝 (⊤ : WithTop ι) := by\n      simpa using (IsTopologicalBasis.mem_nhds_iff.mp (by rfl) ?_) \n    ·\n      simpa [WithTop.mem_nhds_top] using (WithTop.mem_nhds_top (a := x))\n    ·\n      intro y hy\n      exact hy\n  rcases (WithTop.tendsto_atTop_nhds_top_iff.1 hω x) with ⟨n, hn⟩\n  refine (hτX n ω x).imp ?_\n  intro l hl\n  have hEq : (fun t => stoppedProcess (fun i => {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) t ω) = X · ω := by\n    funext t\n    have ht : (t : WithTop ι) ≤ τ n ω := by\n      exact le_of_lt (lt_of_lt_of_le (by exact WithTop.coe_lt_coe.2 (le_of_lt (hn n le_rfl))) (le_rfl))\n    simp [stoppedProcess, ht, Set.indicator_of_mem, lt_of_lt_of_le (WithTop.bot_lt_coe x) (le_of_lt (hn n le_rfl))]\n  simpa [hEq] using hl",
