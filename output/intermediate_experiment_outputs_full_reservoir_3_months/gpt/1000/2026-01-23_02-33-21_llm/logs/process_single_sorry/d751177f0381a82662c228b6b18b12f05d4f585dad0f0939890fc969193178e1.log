      "\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hmono : ∀ᵐ ω ∂P, Monotone (τ · ω) := hτ.mono\n  have htend : ∀ᵐ ω ∂P, Tendsto (τ · ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [hmono, htend] with ω hmonoω htendω\n  intro x\n  rcases (hτX 0) ω x with ⟨l, hl⟩\n  refine ⟨l, ?_⟩\n  have hxτ : ⊥ < τ 0 ω := by\n    have : (⊥ : WithTop ι) < ⊤ := by simpa using (WithTop.bot_lt_top : (⊥ : WithTop ι) < ⊤)\n    have hne : τ 0 ω ≠ ⊤ := by\n      have h := (WithTop.tendsto_atTop_nhds_top_iff.mp htendω) ⊥\n      obtain ⟨N, hN⟩ := h\n      have hN' := hN N le_rfl\n      simpa [WithTop.bot_lt_iff_ne_bot] using hN'\n    have hbot : (⊥ : WithTop ι) ≤ τ 0 ω := by\n      by_contra hlt\n      have : τ 0 ω = ⊥ := le_antisymm (le_of_not_ge hlt) bot_le\n      exact (WithTop.bot_lt_iff_ne_bot.mp this ▸ (lt_irrefl _)) \n    have : (⊥ : WithTop ι) < τ 0 ω := lt_of_le_of_ne hbot (Ne.symm <| by\n      intro hEq\n      have : τ 0 ω = ⊥ := hEq\n      have h := (WithTop.tendsto_atTop_nhds_top_iff.mp htendω) ⊥\n      obtain ⟨N, hN⟩ := h\n      have hN' := hN 0 (zero_le _)\n      simpa [this] using hN')\n    exact this\n  have hst : stoppedProcess (fun i ↦ {ω | ⊥ < τ 0 ω}.indicator (X i)) (τ 0) x ω = X x ω := by\n    have : ω ∈ {ω | ⊥ < τ 0 ω} := by simpa [Set.mem_setOf_eq] using hxτ\n    simp [stoppedProcess, this]\n  simpa [hst] using hl",
