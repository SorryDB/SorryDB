      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hτtop : ∀ᵐ ω ∂P, ∀ x : ι, ∃ n : ℕ, x < τ n ω := by\n    filter_upwards [hτ.tendsto_top] with ω hω x\n    have hω' := (WithTop.tendsto_atTop_nhds_top_iff.1 hω) x\n    rcases hω' with ⟨n, hn⟩\n    exact ⟨n, hn n le_rfl⟩\n  filter_upwards [hτtop] with ω hω x\n  rcases hω x with ⟨n, hn⟩\n  have hxmem : ω ∈ {ω | (⊥ : WithTop ι) < τ n ω} := by\n    simpa [Set.mem_setOf_eq, WithTop.bot_lt_iff_ne_bot] using (ne_bot_of_gt (lt_of_lt_of_le hn le_top))\n  have hprop := hτX n ω x\n  refine ⟨_, ?_⟩\n  have hle : (x : WithTop ι) ≤ τ n ω := le_of_lt hn\n  simpa [stoppedProcess, hxmem, hle] using hprop",
      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  refine (hτ.tendsto_top).mono ?_\n  intro ω hTop x\n  rcases (WithTop.tendsto_atTop_nhds_top_iff.mp hTop x) with ⟨n, hn⟩\n  have hx : x ≤ τ n ω := hn n le_rfl\n  have h := hτX n ω x\n  refine ⟨h.choose, ?_⟩\n  have hstop :\n      stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) · ω\n        = fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i ω) := by\n    ext i\n    simp [stoppedProcess]\n  have hle :\n      (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i ω)) =\n        fun i ↦ X i ω := by\n    ext i\n    by_cases hi : i < x\n    · have hi' : i < τ n ω := lt_of_lt_of_le hi hx\n      simp [Set.indicator_of_mem, hi', WithTop.bot_lt_coe]\n    · have : i ∈ Set.Iio x := by simpa [Set.mem_Iio] using hi\n      exfalso\n      exact hi this\n  simpa [nhdsWithin, Set.Iio] using (by\n    simpa [hstop] using h.choose_spec)",
