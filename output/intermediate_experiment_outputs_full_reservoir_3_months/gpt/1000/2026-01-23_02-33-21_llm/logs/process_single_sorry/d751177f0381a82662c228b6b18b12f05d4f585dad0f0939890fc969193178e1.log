      "\n  classical\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hτmono : ∀ᵐ ω ∂P, Monotone fun n ↦ τ n ω := hτ.mono\n  have hτtop : ∀ᵐ ω ∂P, Tendsto (fun n ↦ τ n ω) atTop (𝓝 ⊤) := hτ.tendsto_top\n  filter_upwards [hτmono, hτtop] with ω hmono htop\n  intro x\n  have hmem : ∃ n, (x : WithTop ι) < τ n ω := by\n    have := (WithTop.tendsto_atTop_nhds_top_iff.1 htop) x\n    rcases this with ⟨n, hn⟩\n    exact ⟨n, hn n le_rfl⟩\n  rcases hmem with ⟨n, hn⟩\n  have hx : x ≤ τ n ω := le_of_lt hn\n  have hprop :=\n    hτX n ω x\n  refine ⟨hprop.choose, ?_⟩\n  have hle : stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i ω)) (τ n ω) = fun i ↦ X i ω := by\n    ext i\n    by_cases hi : i ≤ τ n ω\n    · simp [stoppedProcess, hi, Set.indicator_of_mem, lt_of_lt_of_le (bot_lt_iff_ne_bot.2 (by\n        simpa using (show (τ n ω) ≠ ⊥ from by\n          intro hbot\n          have : (x : WithTop ι) < (⊥ : WithTop ι) := by simpa [hbot] using hn\n          exact (not_lt_bot this))), lt_of_lt_of_le (bot_lt_iff_ne_bot.2 (by\n        simpa using (show (τ n ω) ≠ ⊥ from by\n          intro hbot\n          have : (x : WithTop ι) < (⊥ : WithTop ι) := by simpa [hbot] using hn\n          exact (not_lt_bot this))) (le_rfl))]\n    · have hi' : τ n ω < i := lt_of_not_ge hi\n      simp [stoppedProcess, hi'.not_le, Set.indicator_of_notMem]\n  have hEq :\n      (fun y => X y ω) = fun y =>\n        stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i ω)) (τ n ω) y := by\n    funext y\n    symm\n    have hy : y ≤ (τ n ω) := by\n      have : y < x := by\n        intro hx'\n        exact False.elim (not_lt_of_le hx' (lt_of_le_of_lt hx hn))\n      exact (le_of_lt (lt_of_lt_of_le this hx)).trans (le_of_lt hn)\n    simp [stoppedProcess, hy, Set.indicator_of_mem, lt_of_lt_of_le (bot_lt_iff_ne_bot.2 (by\n      simpa using (show (τ n ω) ≠ ⊥ from by\n        intro hbot\n        have : (x : WithTop ι) < (⊥ : WithTop ι) := by simpa [hbot] using hn\n        exact (not_lt_bot this))), lt_of_lt_of_le (bot_lt_iff_ne_bot.2 (by\n      simpa using (show (τ n ω) ≠ ⊥ from by\n        intro hbot\n        have : (x : WithTop ι) < (⊥ : WithTop ι) := by simpa [hbot] using hn\n        exact (not_lt_bot this))) (le_rfl))]\n  simpa [Filter.nhdsWithin, Set.Iio] using (hprop.choose_spec.congr' (by\n    have : (fun y => stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i ω)) (τ n ω) y)\n        = fun y => X y ω := by\n          funext y\n          simpa [hle] using (rfl : stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i ω)) (τ n ω) y =\n            stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i ω)) (τ n ω) y)\n    simpa [this]))",
      "\n  rcases hX with ⟨τ, hτ, hτX⟩\n  have hτTop : ∀ᵐ ω ∂P, ∃ n, τ n ω = ⊤ := by\n    filter_upwards [hτ.tendsto_top] with ω hω\n    rcases (WithTop.tendsto_atTop_nhds_top_iff.mp hω) (⊥ : ι) with ⟨n, hn⟩\n    refine ⟨n, ?_⟩\n    have : (⊥ : WithTop ι) < τ n ω := hn n le_rfl\n    simpa using (WithTop.bot_lt_iff_ne_bot.mp this)\n  filter_upwards [hτTop] with ω hω\n  rcases hω with ⟨n, hn⟩\n  have hprop := hτX n ω\n  simpa [hn] using hprop",
