--- If an expression can be converted to an affine expression, then their evaluations are the same.
theorem ofExpression_correct (p : ℕ) (e : Expression p) (ae : AffineExpression p) :
  some ae = AffineExpression.ofExpression? e
  → ae.eval = e.eval := by
  intro h
  funext env
  induction e generalizing ae with
  | const n =>
      simp [AffineExpression.ofExpression?, AffineExpression.eval] at h ⊢
      cases h
      simp [AffineExpression.eval]
  | var x =>
      simp [AffineExpression.ofExpression?, AffineExpression.eval] at h ⊢
      cases h
      simp [AffineExpression.eval, Std.TreeMap.foldl]
  | add e1 e2 ih1 ih2 =>
      simp [AffineExpression.ofExpression?] at h
      rcases h1 : AffineExpression.ofExpression? e1 with _ | ae1 <;>
      rcases h2 : AffineExpression.ofExpression? e2 with _ | ae2 <;>
      simp [h1, h2] at h
      cases h
      have he1 : some ae1 = AffineExpression.ofExpression? e1 := by simpa [h1]
      have he2 : some ae2 = AffineExpression.ofExpression? e2 := by simpa [h2]
      have := congrArg (fun f => f env) (ih1 _ he1)
      have := congrArg (fun f => f env) (ih2 _ he2)
      simp [Expression.eval, AffineExpression.eval, Add.add, instAdd, AffineExpression.eval] at *
  | mul e1 e2 ih1 ih2 =>
      simp [AffineExpression.ofExpression?] at h
      rcases h1 : AffineExpression.ofExpression? e1 with _ | ae1 <;>
      rcases h2 : AffineExpression.ofExpression? e2 with _ | ae2 <;>
      simp [h1, h2] at h
      · cases h
      ·
        cases h
        have he1 : some ae1 = AffineExpression.ofExpression? e1 := by simpa [h1]
        have he2 : some ae2 = AffineExpression.ofExpression? e2 := by simpa [h2]
        have ih1' := congrArg (fun f => f env) (ih1 _ he1)
        have ih2' := congrArg (fun f => f env) (ih2 _ he2)
        have hconst : ae1.toConstant? = some n := by
          cases ae1 <;> cases hconstEq : (AffineExpression.toConstant? { offset := offset, affine := affine }) <;> simp [AffineExpression.toConstant?] at *
        simp [mul?, Expression.eval, AffineExpression.eval, mul_by_number] at *
      ·
        cases h
        have he1 : some ae1 = AffineExpression.ofExpression? e1 := by simpa [h1]
        have he2 : some ae2 = AffineExpression.ofExpression? e2 := by simpa [h2]
        have ih1' := congrArg (fun f => f env) (ih1 _ he1)
        have ih2' := congrArg (fun f => f env) (ih2 _ he2)
        simp [mul?, Expression.eval, AffineExpression.eval, mul_by_number] at *
      · cases h
