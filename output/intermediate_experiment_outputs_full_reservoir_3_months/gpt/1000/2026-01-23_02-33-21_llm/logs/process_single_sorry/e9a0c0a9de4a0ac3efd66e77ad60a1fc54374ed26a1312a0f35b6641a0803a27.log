theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  classical
  rcases h₁ with ⟨k, hk⟩
  refine ⟨k, ?_⟩
  have hk' : (k : ℝ) * (a * b + 1 : ℕ) = (a ^ 2 + b ^ 2 : ℕ) := by
    exact_mod_cast hk.symm
  have hab1 : (a * b + 1 : ℝ) ≠ 0 := by
    have : (0 : ℕ) < a * b + 1 := Nat.succ_pos _
    exact_mod_cast (ne_of_gt this)
  have hk'' : (k : ℝ) = (a ^ 2 + b ^ 2 : ℕ) / (a * b + 1 : ℕ) := by
    have : (k : ℝ) * (a * b + 1 : ℝ) = (a ^ 2 + b ^ 2 : ℝ) := by simpa using hk'
    exact (eq_div_iff hab1).2 (by simpa [mul_comm] using this)
  have : ((k : ℝ) ^ 2) = ((a ^ 2 + b ^ 2 : ℕ) / (a * b + 1 : ℕ)) ^ 2 := by
    simpa [hk'']
  simpa [pow_two] using this
