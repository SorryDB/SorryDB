      "\n    have h1 : tâ‚پ.size < 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact lt_of_lt_of_le ihl (pow_le_pow_right' (Nat.le_max_left _ _) _)\n    have h2 : tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact lt_of_lt_of_le ihr (pow_le_pow_right' (Nat.le_max_right _ _) _)\n    have hsum : tâ‚پ.size + tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height + 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact Nat.add_lt_add h1 h2\n    have hsum' : tâ‚پ.size + tâ‚‚.size < 2 * (2 ^ max tâ‚پ.height tâ‚‚.height) := by\n      simpa [two_mul, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using hsum\n    have hmain : 1 + (tâ‚پ.size + tâ‚‚.size) < 2 * (2 ^ max tâ‚پ.height tâ‚‚.height) := by\n      have : 2 * (2 ^ max tâ‚پ.height tâ‚‚.height) â‰  0 := by\n        exact Nat.mul_ne_zero (by decide) (pow_ne_zero _ (by decide))\n      exact Nat.lt_of_lt_of_le (Nat.succ_lt_succ hsum') (Nat.le_of_lt (Nat.lt_of_le_of_ne (Nat.le_mul_of_pos_left (2 ^ max tâ‚پ.height tâ‚‚.height) (by decide)) this))\n    have hpow : 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) = 2 * (2 ^ max tâ‚پ.height tâ‚‚.height) := by\n      simp [pow_succ, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]\n    have : 1 + tâ‚پ.size + tâ‚‚.size < 2 * (2 ^ max tâ‚پ.height tâ‚‚.height) := by\n      simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using hmain\n    simpa [hpow, Nat.add_assoc] using this",
      "\n    have hpowâ‚پ : 2 ^ tâ‚پ.height â‰¤ 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact pow_le_pow_of_le_left (by decide : (0:Nat) â‰¤ 2) (Nat.le_max_left _ _)\n    have hpowâ‚‚ : 2 ^ tâ‚‚.height â‰¤ 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact pow_le_pow_of_le_left (by decide : (0:Nat) â‰¤ 2) (Nat.le_max_right _ _)\n    have htâ‚پ : tâ‚پ.size < 2 ^ max tâ‚پ.height tâ‚‚.height := lt_of_lt_of_le ihl hpowâ‚پ\n    have htâ‚‚ : tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height := lt_of_lt_of_le ihr hpowâ‚‚\n    have hsum : tâ‚پ.size + tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height + 2 ^ max tâ‚پ.height tâ‚‚.height :=\n      Nat.add_lt_add htâ‚پ htâ‚‚\n    have hsum' : tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      simpa [two_mul, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using hsum\n    have : 1 + tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact Nat.lt_of_lt_of_le (Nat.succ_lt_succ hsum') (Nat.le_succ _)\n    simpa [pow_succ, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc, Nat.add_assoc] using this\n  }\n\nend BST1",
      "\n    have h1 : tâ‚پ.size < 2 ^ max tâ‚پ.height tâ‚‚.height :=\n      lt_of_lt_of_le ihl (pow_le_pow_of_le_left (by simp) (Nat.pow_le_pow_of_le_right (by\n        exact Nat.le_max_left _ _))\n    have h2 : tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height :=\n      lt_of_lt_of_le ihr (pow_le_pow_of_le_left (by simp) (Nat.pow_le_pow_of_le_right (by\n        exact Nat.le_max_right _ _))\n    have hs : tâ‚پ.size + tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height + 2 ^ max tâ‚پ.height tâ‚‚.height :=\n      Nat.add_lt_add h1 h2\n    have : 1 + tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      have hs' : tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n        simpa [two_mul, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using hs\n      exact Nat.add_lt_of_lt_sub? (by\n        simpa [Nat.add_assoc] using Nat.succ_lt_succ hs')\n    simpa [pow_succ, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc, two_mul, Nat.add_assoc,\n      Nat.add_left_comm, Nat.add_comm] using this",
      "\n    have ht1 : tâ‚پ.height â‰¤ max tâ‚پ.height tâ‚‚.height := Nat.le_max_left _ _\n    have ht2 : tâ‚‚.height â‰¤ max tâ‚پ.height tâ‚‚.height := Nat.le_max_right _ _\n    have hpow1 : 2 ^ tâ‚پ.height â‰¤ 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n      exact Nat.pow_le_pow_of_le_left (by decide : 1 â‰¤ (2:Nat)) ht1\n    have hpow2 : 2 ^ tâ‚‚.height â‰¤ 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n      exact Nat.pow_le_pow_of_le_left (by decide : 1 â‰¤ (2:Nat)) ht2\n    have h1 : tâ‚پ.size < 2 ^ (max tâ‚پ.height tâ‚‚.height) :=\n      lt_of_lt_of_le ihl hpow1\n    have h2 : tâ‚‚.size < 2 ^ (max tâ‚پ.height tâ‚‚.height) :=\n      lt_of_lt_of_le ihr hpow2\n    set m := max tâ‚پ.height tâ‚‚.height\n    have hsum : tâ‚پ.size + tâ‚‚.size < 2 ^ m + 2 ^ m := by\n      exact Nat.add_lt_add h1 h2\n    have hsum' : tâ‚پ.size + tâ‚‚.size < 2 ^ (m + 1) := by\n      simpa [Nat.pow_succ, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc, two_mul] using hsum\n    have hfinal : 1 + (tâ‚پ.size + tâ‚‚.size) < 2 ^ (m + 1) + 1 := Nat.succ_lt_succ hsum'\n    simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm, Nat.pow_succ, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc, two_mul, m] using\n      (lt_of_lt_of_le hfinal (Nat.le_succ _))",
      "\n    have h1 : tâ‚پ.size < 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact lt_of_lt_of_le ihl (pow_le_pow_right' (by exact Nat.le_max_left _ _) _)\n    have h2 : tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact lt_of_lt_of_le ihr (pow_le_pow_right' (by exact Nat.le_max_right _ _) _)\n    have hsum : tâ‚پ.size + tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height + 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact Nat.add_lt_add h1 h2\n    have hsum' : tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      simpa [two_mul] using hsum\n    have : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) := by\n      simpa [Nat.pow_succ, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm, Nat.add_assoc] using\n        Nat.add_lt_add_left hsum' 1\n    simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this\n  }\n\nend BST1",
      "\n    nlinarith [ihl, ihr]\n  }\n\nend BST1",
      "\n    calc\n      1 + tâ‚پ.size + tâ‚‚.size\n          < 1 + 2 ^ tâ‚پ.height + 2 ^ tâ‚‚.height := by\n            gcongr <;> linarith\n      _ â‰¤ 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) := by\n            have hâ‚پ : 2 ^ tâ‚پ.height â‰¤ 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n              exact pow_le_pow_of_le_left (by decide) (le_max_left _ _)\n            have hâ‚‚ : 2 ^ tâ‚‚.height â‰¤ 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n              exact pow_le_pow_of_le_left (by decide) (le_max_right _ _)\n            have : 1 + 2 ^ tâ‚پ.height + 2 ^ tâ‚‚.height â‰¤ 2 * 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n              nlinarith\n            simpa [pow_succ, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc, two_mul] using this",
      "\n    have h1 : tâ‚پ.size < 2 ^ max tâ‚پ.height tâ‚‚.height :=\n      lt_of_lt_of_le ihl (pow_le_pow_of_le_left (by decide) (Nat.pow_le_pow_of_le_right (by\n        exact Nat.le_max_left _ _) _))\n    have h2 : tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height :=\n      lt_of_lt_of_le ihr (pow_le_pow_of_le_left (by decide) (Nat.pow_le_pow_of_le_right (by\n        exact Nat.le_max_right _ _) _))\n    have hsum : tâ‚پ.size + tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height + 2 ^ max tâ‚پ.height tâ‚‚.height :=\n      Nat.add_lt_add h1 h2\n    have hsum' : tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      simpa [two_mul, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using hsum\n    have hmain : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) := by\n      have : 1 + tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n        have : 1 + (tâ‚پ.size + tâ‚‚.size) < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n          exact Nat.succ_lt_succ_iff.mp ?_\n        آ· simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this\n      آ·\n        have : 1 + (tâ‚پ.size + tâ‚‚.size) < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n          exact lt_of_lt_of_le (Nat.succ_lt_succ hsum') (Nat.le_of_eq rfl)\n        simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm, Nat.pow_succ, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm] using\n          (lt_of_lt_of_eq (by\n            simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using (Nat.succ_lt_succ hsum')) (by\n            simp [Nat.pow_succ, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]))\n    simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using hmain",
      "\n    have h1 : 2 ^ tâ‚پ.height â‰¤ 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n      exact pow_le_pow_of_le_left (by exact Nat.zero_le 2) (Nat.le_max_left _ _)\n    have h2 : 2 ^ tâ‚‚.height â‰¤ 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n      exact pow_le_pow_of_le_left (by exact Nat.zero_le 2) (Nat.le_max_right _ _)\n    have ihl' : tâ‚پ.size < 2 ^ (max tâ‚پ.height tâ‚‚.height) :=\n      lt_of_lt_of_le ihl h1\n    have ihr' : tâ‚‚.size < 2 ^ (max tâ‚پ.height tâ‚‚.height) :=\n      lt_of_lt_of_le ihr h2\n    have hs : tâ‚پ.size + tâ‚‚.size < 2 ^ (max tâ‚پ.height tâ‚‚.height) + 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n      exact Nat.add_lt_add ihl' ihr'\n    have hs' : tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n      simpa [two_mul, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using hs\n    have hs'' : 1 + (tâ‚پ.size + tâ‚‚.size) < 2 ^ (max tâ‚پ.height tâ‚‚.height) + 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n      exact Nat.succ_lt_succ hs\n    have hs''' : 1 + (tâ‚پ.size + tâ‚‚.size) < 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) := by\n      simpa [pow_succ, Nat.mul_comm, two_mul] using hs''\n    simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using hs'''\n  }\n\nend BST1",
      "\n    have h1 : tâ‚پ.size < 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact lt_of_lt_of_le ihl (pow_le_pow_of_le_left (by decide) (Nat.pow_le_pow_of_le_right ?_ (Nat.le_max_left _ _)))\n    have h2 : tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact lt_of_lt_of_le ihr (pow_le_pow_of_le_left (by decide) (Nat.pow_le_pow_of_le_right ?_ (Nat.le_max_right _ _)))\n    have hs : tâ‚پ.size + tâ‚‚.size < 2 ^ max tâ‚پ.height tâ‚‚.height + 2 ^ max tâ‚پ.height tâ‚‚.height :=\n      Nat.add_lt_add h1 h2\n    have hs' : tâ‚پ.size + tâ‚‚.size < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      simpa [two_mul, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using hs\n    have hpow : 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) = 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      simp [pow_succ, Nat.mul_assoc, Nat.mul_comm, Nat.mul_left_comm]\n    have : 1 + (tâ‚پ.size + tâ‚‚.size) < 2 * 2 ^ max tâ‚پ.height tâ‚‚.height := by\n      exact Nat.lt_of_lt_of_le (Nat.succ_lt_succ hs') (Nat.le_of_eq rfl)\n    simpa [Nat.add_assoc, Nat.add_left_comm, Nat.add_comm, hpow] using this",
