        have hx'' : x ∈ Set.univ.pi fun i => ((↑(F i) : Set (G i)) • A i) := by
          intro i hi
          exact hFS i (hx' i hi)
        rcases (Set.mem_pi.mp hx'') with hxcoords
        refine ⟨fun i => (hxcoords i trivial).choose, ?_, fun i => (hxcoords i trivial).choose_spec⟩
        ·
          refine Fintype.mem_piFinset ?_
          intro i
          exact (hxcoords i trivial).choose_spec.1
