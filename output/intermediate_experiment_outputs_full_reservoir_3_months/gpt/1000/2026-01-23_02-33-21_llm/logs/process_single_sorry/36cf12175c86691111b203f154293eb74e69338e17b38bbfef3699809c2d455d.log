      "\n  classical\n  have hId_a : IdentDistrib (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n a) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h a\n  have hId_b : IdentDistrib (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n b) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h b\n  have h_indep_eval :\n      IndepFun (fun Пү n вҶҰ Пү.2 n a) (fun Пү n вҶҰ Пү.2 n b) рқ”“ := by\n    simpa [Bandit.measure, Bandit.snd_measure] using\n      (indepFun_eval_streamMeasure_of_ne (ОҪ := ОҪ) hab : IndepFun (fun Пү n вҶҰ Пү n a) (fun Пү n вҶҰ Пү n b) (Bandit.streamMeasure ОҪ))\n  have h_indep' :\n      IndepFun (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү)\n        (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) рқ”“' := by\n    exact (h_indep_eval.comp_identDistrib hId_a.symm hId_b.symm)\n  simpa [IndepFun] using (h_indep'.precomp (g := fun s : в„• вҶҰ s - 1) (g' := fun s : в„• вҶҰ s - 1))",
      "\n  classical\n  have h_id_a : IdentDistrib (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n a) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h a\n  have h_id_b : IdentDistrib (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n b) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h b\n  have h_indep_eval : IndepFun (fun Пү n вҶҰ Пү.2 n a) (fun Пү n вҶҰ Пү.2 n b) рқ”“ := by\n    simpa [Bandit.measure, Measure.snd, Measure.snd_prod] using\n      (indepFun_eval_streamMeasure_of_ne (ОҪ := ОҪ) hab).comp_right (Ој := рқ”“) Prod.snd\n        (by fun_prop)\n  have h_indep_shift : IndepFun (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү)\n      (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) рқ”“' := by\n    exact h_indep_eval.comp_identDistrib h_id_a.symm h_id_b.symm\n  refine h_indep_shift.comp (gвӮҒ := fun s вҶҰ s - 1) (gвӮӮ := fun s вҶҰ s - 1) ?_ ?_\n  В· fun_prop\n  В· fun_prop",
      "\n  classical\n  have hA := h.measurable_A\n  have hR := h.measurable_R\n  -- `rewardByCount` depends only on the stream component, and for different actions these\n  -- are independent under `streamMeasure ОҪ`; then lift to the product measure.\n  have h_indep_stream :\n      IndepFun (fun Пү s вҶҰ rewardByCount A R a s ((), Пү))\n        (fun Пү s вҶҰ rewardByCount A R b s ((), Пү)) (Bandit.streamMeasure ОҪ) := by\n    -- reduce to independence of evaluation maps of the stream measure\n    -- using the fact that `rewardByCount` has the same law as the corresponding stream eval\n    -- and that different coordinates/actions are independent in the product construction.\n    -- This lemma is available in the projectвҖҷs `ForMathlib.IndepFun` development.\n    simpa using indepFun_rewardByCount_streamMeasure (ОҪ := ОҪ) hab\n  -- pull back along `Prod.snd : О© Г— stream вҶ’ stream`\n  have h_indep_precomp :\n      IndepFun (fun Пүs s вҶҰ rewardByCount A R a s Пүs) (fun Пүs s вҶҰ rewardByCount A R b s Пүs) рқ”“' := by\n    simpa [рқ”“', Function.comp] using h_indep_stream.precomp (g := Prod.snd)\n  exact h_indep_precomp",
      "\n  have hA := h.measurable_A\n  have hR := h.measurable_R\n  have h_id_a : IdentDistrib (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n a) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h a\n  have h_id_b : IdentDistrib (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n b) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h b\n  have h_indep_stream : IndepFun (fun Пү n вҶҰ Пү.2 n a) (fun Пү n вҶҰ Пү.2 n b) рқ”“ := by\n    have h_indep_snd :\n        IndepFun (fun Пү n вҶҰ Пү n a) (fun Пү n вҶҰ Пү n b) (Bandit.streamMeasure ОҪ) := by\n      simpa [iIndepFun] using (iIndepFun_eval_streamMeasure ОҪ).indepFun hab\n    have h_indep_snd' :\n        IndepFun (fun Пү n вҶҰ (Prod.snd Пү) n a) (fun Пү n вҶҰ (Prod.snd Пү) n b) рқ”“ := by\n      simpa [Bandit.snd_measure alg ОҪ] using\n        (h_indep_snd.comp measurable_snd measurable_snd)\n    simpa using h_indep_snd'\n  have h_indep' :\n      IndepFun (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү) (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү)\n        рқ”“' := by\n    exact h_indep_stream.transfer_identDistrib h_id_a.symm h_id_b.symm\n  simpa [IndepFun] using\n    (h_indep'.comp (by\n      classical\n      refine (measurable_pi_lambda fun n вҶҰ ?_)\n      simpa [rewardByCount] using\n        (measurable_rewardByCount hA hR a (n + 1)).comp measurable_fst)\n      (by\n      classical\n      refine (measurable_pi_lambda fun n вҶҰ ?_)\n      simpa [rewardByCount] using\n        (measurable_rewardByCount hA hR b (n + 1)).comp measurable_fst))",
      "\n  simpa [rewardByCount, hab] using\n    indepFun_fst_snd (Ој := рқ”“')\n      (f := fun Пү : О© Г— (в„• вҶ’ Оұ вҶ’ в„қ) вҶҰ fun s вҶҰ Пү.2 (s - 1) a)\n      (g := fun Пү : О© Г— (в„• вҶ’ Оұ вҶ’ в„қ) вҶҰ fun s вҶҰ Пү.2 (s - 1) b)\n      (by fun_prop) (by fun_prop)",
      "\n  classical\n  -- Identify both sequences with two coordinate projections of the independent stream measure.\n  have h_id_a :\n      IdentDistrib (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n a) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h a\n  have h_id_b :\n      IdentDistrib (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n b) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h b\n  -- Independence for distinct coordinates in the stream measure.\n  have h_indep_stream :\n      IndepFun (fun Пү n вҶҰ Пү.2 n a) (fun Пү n вҶҰ Пү.2 n b) рқ”“ := by\n    -- reduce to independence of coordinates on `Bandit.streamMeasure ОҪ`\n    have h_indep_snd :\n        IndepFun (fun Пү n вҶҰ Пү n a) (fun Пү n вҶҰ Пү n b) (Bandit.streamMeasure ОҪ) := by\n      -- both are measurable w.r.t. disjoint coordinate sets\n      simpa using\n        (indepFun_eval_streamMeasure_of_ne (ОҪ := ОҪ) (a := a) (b := b) hab)\n    -- pull back along `Prod.snd`\n    simpa [Bandit.snd_measure alg ОҪ, Measure.snd, IndepFun] using\n      h_indep_snd.comp_right measurable_snd measurable_snd\n  -- Transfer independence back to `рқ”“'` via `IdentDistrib`.\n  have h_indep' :\n      IndepFun (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү)\n        (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) рқ”“' := by\n    exact (h_id_a.indepFun_iff h_id_b).2 h_indep_stream\n  -- Reindex `s вҶҰ s+1` to get the statement for all `s : в„•`.\n  simpa [Function.comp] using\n    h_indep'.comp_right (g := fun s : в„• вҶҰ s + 1) (h := fun s : в„• вҶҰ s + 1)\n      (by fun_prop) (by fun_prop)",
      "\n  classical\n  have h_id_a : IdentDistrib (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n a) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h a\n  have h_id_b : IdentDistrib (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n b) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h b\n  have h_indep_eval :\n      IndepFun (fun Пү n вҶҰ Пү.2 n a) (fun Пү n вҶҰ Пү.2 n b) рқ”“' := by\n    simpa [рқ”“'] using\n      (indepFun_prod_snd (Ој := P) (ОҪ := Bandit.streamMeasure ОҪ)\n        (iIndepFun_eval_streamMeasure'' ОҪ) hab)\n  have h_indep_succ :\n      IndepFun (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү)\n        (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) рқ”“' := by\n    exact (h_indep_eval.comp_identDistrib h_id_a.symm h_id_b.symm)\n  simpa [rewardByCount, Nat.succ_eq_add_one] using h_indep_succ",
      "\n  have h_id_a : IdentDistrib (fun Пү s вҶҰ rewardByCount A R a (s + 1) Пү) (fun Пү s вҶҰ Пү.2 s a) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h a\n  have h_id_b : IdentDistrib (fun Пү s вҶҰ rewardByCount A R b (s + 1) Пү) (fun Пү s вҶҰ Пү.2 s b) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h b\n  have h_indep_eval : IndepFun (fun Пү s вҶҰ Пү.2 s a) (fun Пү s вҶҰ Пү.2 s b) рқ”“' := by\n    have h_indep_snd : IndepFun (fun Пү : О© Г— (в„• вҶ’ Оұ вҶ’ в„қ) вҶҰ Пү.2) (fun Пү : О© Г— (в„• вҶ’ Оұ вҶ’ в„қ) вҶҰ Пү.2) рқ”“' :=\n      indepFun_snd_snd_prod (Ој := P) (ОҪ := Bandit.streamMeasure ОҪ)\n    have h_indep_eval' : IndepFun (fun Пү : О© Г— (в„• вҶ’ Оұ вҶ’ в„қ) вҶҰ fun n вҶҰ Пү.2 n a)\n        (fun Пү : О© Г— (в„• вҶ’ Оұ вҶ’ в„қ) вҶҰ fun n вҶҰ Пү.2 n b) рқ”“' := by\n      refine h_indep_snd.comp ?_ ?_\n      В· fun_prop\n      В· fun_prop\n    exact h_indep_eval'\n  have h_indep_succ :\n      IndepFun (fun Пү s вҶҰ rewardByCount A R a (s + 1) Пү) (fun Пү s вҶҰ rewardByCount A R b (s + 1) Пү) рқ”“' := by\n    exact (h_id_a.indepFun_iff h_id_b).2 h_indep_eval\n  simpa [rewardByCount] using h_indep_succ",
      "\n  have h_id :\n      IdentDistrib (fun Пү (p : Оұ Г— в„•) вҶҰ rewardByCount A R p.1 (p.2 + 1) Пү)\n        (fun Пү p вҶҰ Пү p.2 p.1) рқ”“' (Bandit.streamMeasure ОҪ) :=\n    identDistrib_rewardByCount_stream_all (A := A) (R := R) (P := P) (alg := alg) (ОҪ := ОҪ) h\n  have h_indep :\n      IndepFun (fun Пү s вҶҰ Пү (s - 1) a) (fun Пү s вҶҰ Пү (s - 1) b) (Bandit.streamMeasure ОҪ) := by\n    simpa [IndepFun, hab] using\n      (iIndepFun_eval_streamMeasure''' (ОҪ := ОҪ) (a := fun i : Оұ Г— в„• вҶҰ i.1)\n        (h := fun i j hij вҶҰ by\n          have : i.1 вү  j.1 := by\n            intro hEq\n            apply hij\n            cases i <;> cases j <;> cases hij\n            simp [hEq] )\n        (i := (a, 0)) (j := (b, 0)) (by simpa [hab]))\n  have h_indep' :\n      IndepFun (fun Пү s вҶҰ Пү (s - 1) a) (fun Пү s вҶҰ Пү (s - 1) b) рқ”“' := by\n    have : IndepFun (fun Пү : О© Г— (в„• вҶ’ Оұ вҶ’ в„қ) вҶҰ Пү.2) (fun Пү : О© Г— (в„• вҶ’ Оұ вҶ’ в„қ) вҶҰ Пү.2) рқ”“' := by\n      simpa using indepFun_snd_snd (Ој := P) (ОҪ := Bandit.streamMeasure ОҪ)\n    simpa [IndepFun, Function.comp] using\n      (h_indep.comp (measurable_snd.comp (by fun_prop)) (measurable_snd.comp (by fun_prop)))\n  have h_congr :\n      (fun Пү s вҶҰ rewardByCount A R a s Пү) =бөҗ[рқ”“'] (fun Пү s вҶҰ Пү.2 (s - 1) a) := by\n    refine ae_of_all _ ?_\n    intro Пү\n    funext s\n    cases s with\n    | zero =>\n      simp [rewardByCount, stepsUntil, Nat.sub_zero]\n    | succ s =>\n      simp [rewardByCount]\n  have h_congr' :\n      (fun Пү s вҶҰ rewardByCount A R b s Пү) =бөҗ[рқ”“'] (fun Пү s вҶҰ Пү.2 (s - 1) b) := by\n    refine ae_of_all _ ?_\n    intro Пү\n    funext s\n    cases s with\n    | zero =>\n      simp [rewardByCount, stepsUntil, Nat.sub_zero]\n    | succ s =>\n      simp [rewardByCount]\n  exact (h_indep'.ae_eq h_congr h_congr')",
      "\n  classical\n  have hвӮҒ :\n      IdentDistrib (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n a) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h a\n  have hвӮӮ :\n      IdentDistrib (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) (fun Пү n вҶҰ Пү.2 n b) рқ”“' рқ”“ :=\n    identDistrib_rewardByCount_stream h b\n  have h_indep_stream :\n      IndepFun (fun Пү n вҶҰ Пү n a) (fun Пү n вҶҰ Пү n b) (Bandit.streamMeasure ОҪ) := by\n    simpa [Bandit.streamMeasure] using indepFun_eval_streamMeasure_of_ne ОҪ hab\n  have h_indep_stream' :\n      IndepFun (fun Пү n вҶҰ Пү.2 n a) (fun Пү n вҶҰ Пү.2 n b) рқ”“ := by\n    simpa [Bandit.snd_measure alg ОҪ, Measure.snd] using\n      h_indep_stream.comp measurable_snd measurable_snd\n  have h_indep_succ :\n      IndepFun (fun Пү n вҶҰ rewardByCount A R a (n + 1) Пү) (fun Пү n вҶҰ rewardByCount A R b (n + 1) Пү) рқ”“' := by\n    exact (hвӮҒ.indepFun_iff hвӮӮ).2 h_indep_stream'\n  have h_indep_pos :\n      IndepFun (fun Пү s : {n : в„• // 0 < n} вҶҰ rewardByCount A R a s.1 Пү)\n        (fun Пү s : {n : в„• // 0 < n} вҶҰ rewardByCount A R b s.1 Пү) рқ”“' := by\n    simpa [rewardByCount] using\n      h_indep_succ.precomp (g := fun s : {n : в„• // 0 < n} вҶҰ s.1 - 1)\n        (fun s вҶҰ by\n          have : 0 < s.1 := s.2\n          have hs : s.1 = (s.1 - 1) + 1 := by\n            simpa [Nat.sub_eq_iff_eq_add_of_le (Nat.succ_le_iff.2 this), Nat.add_comm, Nat.add_left_comm,\n              Nat.add_assoc]\n          simpa [hs])\n  have h_indep_zero :\n      IndepFun (fun Пү _ : {n : в„• // n = 0} вҶҰ rewardByCount A R a 0 Пү)\n        (fun Пү _ : {n : в„• // n = 0} вҶҰ rewardByCount A R b 0 Пү) рқ”“' := by\n    refine (indepFun_const_left _).mono ?_ ?_\n    В· intro Пү s; cases s; simp [rewardByCount]\n    В· intro Пү s; cases s; simp [rewardByCount]\n  have h_indep_all :\n      IndepFun (fun Пү s вҶҰ rewardByCount A R a s Пү) (fun Пү s вҶҰ rewardByCount A R b s Пү) рқ”“' := by\n    refine indepFun_of_forall_finite_subtype (Ој := рқ”“') (X := fun Пү s вҶҰ rewardByCount A R a s Пү)\n      (Y := fun Пү s вҶҰ rewardByCount A R b s Пү) ?_\n    intro t ht\n    classical\n    by_cases h0 : (0 : в„•) вҲҲ t\n    В· have hpos : IndepFun (fun Пү s : {n // n вҲҲ t вҲ§ 0 < n} вҶҰ rewardByCount A R a s.1 Пү)\n        (fun Пү s : {n // n вҲҲ t вҲ§ 0 < n} вҶҰ rewardByCount A R b s.1 Пү) рқ”“' := by\n        simpa using h_indep_pos.precomp (g := fun s : {n // n вҲҲ t вҲ§ 0 < n} вҶҰ вҹЁs.1, s.2.2вҹ©)\n          (fun i j hij вҶҰ by\n            intro hEq; exact hij (Subtype.ext (by simpa using congrArg Subtype.val hEq)))\n      have hzero' :\n          IndepFun (fun Пү _ : {n // n вҲҲ t вҲ§ n = 0} вҶҰ rewardByCount A R a 0 Пү)\n            (fun Пү _ : {n // n вҲҲ t вҲ§ n = 0} вҶҰ rewardByCount A R b 0 Пү) рқ”“' := by\n        refine h_indep_zero.precomp (g := fun s : {n // n вҲҲ t вҲ§ n = 0} вҶҰ вҹЁs.1, s.2.2вҹ©)\n          (fun i j hij вҶҰ by\n            intro hEq; exact hij (Subtype.ext (by simpa using congrArg Subtype.val hEq)))\n      have hmix :\n          IndepFun (fun Пү s : {n // n вҲҲ t} вҶҰ rewardByCount A R a s.1 Пү)\n            (fun Пү s : {n // n вҲҲ t} вҶҰ rewardByCount A R b s.1 Пү) рқ”“' := by\n        classical\n        simpa [Subtype.forall, Set.mem_setOf_eq] using\n          indepFun_subtype_union_of_disjoint\n            (X := fun Пү s : {n // n вҲҲ t вҲ§ 0 < n} вҶҰ rewardByCount A R a s.1 Пү)\n            (Y := fun Пү s : {n // n вҲҲ t вҲ§ 0 < n} вҶҰ rewardByCount A R b s.1 Пү)\n            (X' := fun Пү s : {n // n вҲҲ t вҲ§ n = 0} вҶҰ rewardByCount A R a 0 Пү)\n            (Y' := fun Пү s : {n // n вҲҲ t вҲ§ n = 0} вҶҰ rewardByCount A R b 0 Пү)\n            hpos hzero' (by\n              intro i j hij\n              exact hij (by\n                have : (i.1 : в„•) = j.1 := by\n                  have hi : 0 < i.1 := i.2.2\n                  have hj : j.1 = 0 := j.2.2\n                  exact (Nat.ne_of_gt hi) (by simpa [hj])\n                exact Subtype.ext th