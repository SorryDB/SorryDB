-- exercise 1.2.ii.ii
theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  constructor
  · rintro ⟨g, hg⟩ c h
    refine ⟨h ≫ g, ?_⟩
    simpa [Category.IsSection, Category.assoc, hg] 
  · intro h
    rcases h Y (id Y) with ⟨g, hg⟩
    refine ⟨g, ?_⟩
    simpa [Category.IsSection] using hg
