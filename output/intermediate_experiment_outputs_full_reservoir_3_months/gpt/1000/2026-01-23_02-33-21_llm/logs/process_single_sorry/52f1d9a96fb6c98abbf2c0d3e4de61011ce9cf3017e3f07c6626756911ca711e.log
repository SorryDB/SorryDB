@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  have hx : 0 ≤ x := h₀.1
  have hy : 0 ≤ y := h₀.2.1
  have hz : 0 ≤ z := h₀.2.2
  have hx1 : x ≤ 1 := by
    linarith [hy, hz, h₁]
  have hy1 : y ≤ 1 := by
    linarith [hx, hz, h₁]
  have hz1 : z ≤ 1 := by
    linarith [hx, hy, h₁]
  have hxyz_le_xy : x * y * z ≤ x * y := by
    have : z ≤ 1 := hz1
    nlinarith [hx, hy, hz, this]
  have hxyz_le_yz : x * y * z ≤ y * z := by
    have : x ≤ 1 := hx1
    nlinarith [hx, hy, hz, this]
  have hxyz_le_zx : x * y * z ≤ z * x := by
    have : y ≤ 1 := hy1
    nlinarith [hx, hy, hz, this]
  have hxyz_le_sum : 3 * (x * y * z) ≤ y * z + z * x + x * y := by
    have h1 : x * y * z ≤ y * z := hxyz_le_yz
    have h2 : x * y * z ≤ z * x := hxyz_le_zx
    have h3 : x * y * z ≤ x * y := hxyz_le_xy
    linarith
