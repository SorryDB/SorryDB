lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 :=
by
  intro x hx
  have hx' : x.val ∈ val_image A X1 := by
    refine ⟨x, hx, rfl⟩
  have hx'' : x.val ∈ val_image A X2 := by
    simpa [h] using hx'
  rcases hx'' with ⟨y, hy, hval⟩
  have : y = x := by
    ext
    simpa [hval]
  simpa [this] using hy
```
