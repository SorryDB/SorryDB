  · intro h
    classical
    by_cases hne : (∃ w : List T, w ∈ L)
    · rcases hne with ⟨w, hw⟩
      let k : KurodaGrammar T :=
        { nt := PUnit
          initial := PUnit.unit
          rules := [] }
      refine ⟨k, ?_⟩
      ext x
      have : False := by
        have : x ∈ L := by
          simpa using hw
        exact False.elim (by trivial)
      exact False.elim this
    ·
      let k : KurodaGrammar T :=
        { nt := PUnit
          initial := PUnit.unit
          rules := [] }
      refine ⟨k, ?_⟩
      ext x
      have hxL : x ∈ L → False := by
        intro hx
        exact hne ⟨x, hx⟩
      constructor
      · intro hx
        exact (hxL hx).elim
      · intro hx
        exact False.elim (hxL (by
          have : x ∈ L := by
            exact False.elim hx
          exact this))
  · rintro ⟨k, hk⟩
    simpa [hk] using (Grammar.IsGG_of_eq (k := grammar_of_kurodaGrammar k) (L := L) (by
      simpa [KurodaGrammar.lang_eq] using congrArg id hk))
