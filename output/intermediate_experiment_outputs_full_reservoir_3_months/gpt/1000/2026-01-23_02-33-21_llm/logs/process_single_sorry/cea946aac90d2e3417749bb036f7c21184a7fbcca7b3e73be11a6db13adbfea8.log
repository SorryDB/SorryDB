      "\n  classical\n  by_contra hno\n  have hmax : G.IsMaxMatching M := by\n    refine IsMatching.isMaxMatching_of_vertex_subset hM ?_\n    intro x hxV\n    by_contra hx\n    have hx' : x ∉ V(G, M) := by simpa [V, hx] using hx\n    have hxV' : x ∈ V(G, M') := by\n      by_contra hxM'\n      have : ∃ P, G.IsAugPath hM P := by\n        refine ⟨.cons x (Classical.choice ?_) (.nil (Classical.choice ?_)), ?_⟩\n        · have : ∃ e, G.IsLink e x (Classical.choice ?_) := by\n            classical\n            have hxne : (E(G, x)).Nonempty := by\n              simpa [E, hxV, Set.nonempty_iff_ne_empty] using (by\n                intro hE\n                have : x ∉ V(G) := by\n                  simpa [V, hE] using (by rfl : x ∈ (∅ : Set α) → False)\n                exact this hxV)\n            rcases hxne with ⟨e, he⟩\n            refine ⟨e, ?_⟩\n            simpa [E] using he\n          exact this\n        · have : ∃ y, True := ⟨x, trivial⟩\n          exact this\n        · have : ∃ y, True := ⟨x, trivial⟩\n          exact this\n        ·\n          have hl : G.IsLink (Classical.choice ?_) x (Classical.choice ?_) := by\n            exact Classical.choice (Classical.choice ?_)\n          have huv : x ≠ Classical.choice ?_ := by\n            classical\n            exact by\n              intro h'\n              exact hxV (by simpa [h'] using hxV)\n          exact isAugPath_of_singleEdge (hM := hM) hl hx' (by simpa [V, hxM'] using hxM') huv\n      exact hno this\n    have : x ∈ V(G, M) := by\n      classical\n      have hsub : V(G) ⊆ V(G, M) := by\n        intro y hyV\n        by_contra hy\n        have : ∃ P, G.IsAugPath hM P := by\n          classical\n          refine ⟨.nil y, ?_⟩\n          simpa [isAugPath_iff, isAltPath_iff, hy] using (by\n            refine ⟨?_, ?_, ?_, ?_⟩ <;> simp)\n        exact (hno this).elim\n      exact hsub hxV\n    exact hx this\n  exact hnotmax hmax",
      "\n  classical\n  exact ⟨.nil (Classical.choice (G.exists_vertex_of_neBot (by\n    simpa using (G.edgeFinite_iff_neBot.mp inferInstance)))), by\n    simpa [isAugPath_iff, isAltPath_iff]⟩",
      "\n  classical\n  by_contra hno\n  have hmax : G.IsMaxMatching M := by\n    refine hM.isMaxMatching_of_vertex_subset ?_\n    intro v hv\n    by_contra hvM\n    have : ∃ P, G.IsAugPath hM P := by\n      refine ⟨.nil v, ?_⟩\n      refine ⟨?_, ?_, ?_, ?_⟩\n      · simpa [isAltPath_iff] using hv\n      · simp\n      · simpa [WList.first, V, hvM]\n      · simpa [WList.last, V, hvM]\n    exact hno this\n  exact (not_lt_of_ge (hmax.max M' hM')) hM'cd",
      "\n  classical\n  have hne : (M' \\ M).Nonempty := by\n    by_contra hne\n    have hsub : M' ⊆ M := by\n      intro e he\n      by_contra hmem\n      exact hne ⟨e, ⟨he, hmem⟩⟩\n    have hle : M'.encard ≤ M.encard := encard_le_encard hsub\n    exact (not_lt_of_ge hle) hM'cd\n  obtain ⟨e, heM', heM⟩ := by\n    rcases hne with ⟨e, he⟩\n    exact ⟨e, he.1, he.2⟩\n  obtain ⟨u, v, hl⟩ := by\n    rcases hM'.subset heM' with ⟨u, v, hl⟩\n    exact ⟨u, v, hl⟩\n  by_cases huv : u = v\n  · subst huv\n    refine ⟨.cons u e (.nil u), ?_⟩\n    have hu : u ∉ V(G, M) := by\n      intro huM\n      have : e ∈ M := by\n        rcases huM with ⟨f, hfM, huV⟩\n        have hne' : e ≠ f := by\n          intro h\n          exact heM (h ▸ hfM)\n        have hdis := hM.disjoint (by exact ?_) hfM hne'\n        · exact (hdis.le_bot ⟨hl.inc_left, huV⟩).elim\n        · exact heM' |> (fun h => h)\n      exact heM this\n    have hu' : u ∉ V(G, M) := hu\n    simpa [isAugPath_iff, isAltPath_iff, hl.right_mem, hu, hu', WList.Nonempty] using\n      (isAugPath_of_singleEdge (u := u) (v := u) (e := e) (hM := hM) hl hu hu' (by simp))\n  · by_cases huM : u ∈ V(G, M)\n    · have hvM : v ∉ V(G, M) := by\n        intro hvM\n        rcases huM with ⟨f, hfM, huf⟩\n        rcases hvM with ⟨g, hgM, hvg⟩\n        have hfne : f ≠ g := by\n          intro hfg\n          have : u = v := by\n            have := congrArg (fun s => u ∈ s) (by simpa [hfg] using rfl : V(G, f) = V(G, g))\n            simpa [huf, hvg] using this\n          exact huv this\n        have hdis := hM.disjoint hfM hgM hfne\n        exact (hdis.le_bot ⟨huf, hvg⟩).elim\n      refine ⟨.cons u e (.nil v), ?_⟩\n      refine isAugPath_of_singleEdge (hM := hM) hl ?_ hvM huv\n      intro huM'\n      have : e ∈ M := by\n        rcases huM' with ⟨f, hfM, huf⟩\n        have hne' : e ≠ f := by\n          intro h\n          exact heM (h ▸ hfM)\n        have hdis := hM.disjoint (by exact ?_) hfM hne'\n        · exact (hdis.le_bot ⟨hl.inc_left, huf⟩).elim\n        · exact heM' |> (fun h => h)\n      exact heM this\n    · have hvM : v ∈ V(G, M) := by\n        by_contra hvM\n        refine (isAugPath_of_singleEdge (hM := hM) hl huM hvM huv) |> (fun h => ?_)\n        exact ⟨.cons u e (.nil v), h⟩ |> (fun h => h)\n      rcases hvM with _  -- unreachable, but keeps structure\n      exact False.elim (hvM rfl)\n  ·\n    by_cases hvM : v ∈ V(G, M)\n    · refine ⟨.cons u e (.nil v), ?_⟩\n      refine isAugPath_of_singleEdge (hM := hM) hl ?_ ?_ huv\n      · intro huM\n        rcases huM with ⟨f, hfM, huf⟩\n        have hne' : e ≠ f := by\n          intro h\n          exact heM (h ▸ hfM)\n        have hdis := hM.disjoint heM' hfM hne'\n        exact (hdis.le_bot ⟨hl.inc_left, huf⟩).elim\n      · intro hvM'\n        rcases hvM' with ⟨f, hfM, hvf⟩\n        have hne' : e ≠ f := by\n          intro h\n          exact heM (h ▸ hfM)\n        have hdis := hM.disjoint heM' hfM hne'\n        exact (hdis.le_bot ⟨hl.inc_right, hvf⟩).elim\n    · refine ⟨.cons u e (.nil v), ?_⟩\n      refine isAugPath_of_singleEdge (hM := hM) hl ?_ hvM huv\n      · intro huM\n        rcases huM with ⟨f, hfM, huf⟩\n        have hne' : e ≠ f := by\n          intro h\n          exact heM (h ▸ hfM)\n        have hdis := hM.disjoint heM' hfM hne'\n        exact (hdis.le_bot ⟨hl.inc_left, huf⟩).elim",
      "\n  have : False := by\n    exact lt_irrefl _ hM'cd\n  exact (this.elim)",
      "\n  classical\n  by_contra hno\n  have hmax : G.IsMaxMatching M :=\n    hM.isMaxMatching_of_vertex_subset (by\n      intro x hxV\n      by_contra hx\n      have hx' : x ∉ V(G, M) := hx\n      have : ∃ P, G.IsAugPath hM P := by\n        classical\n        have hxV' : x ∈ V(G, M') := by\n          have : V(G) ⊆ V(G, M') := by\n            intro y hyV\n            by_contra hy\n            have hy' : y ∉ V(G, M') := hy\n            -- build a strictly larger matching by adding a link incident to y if possible,\n            -- contradicting maximality of `M'` relative to `M` encoded by `hM'cd`\n            -- but we only need existence of an augmenting path contradiction, so use `x`\n            exact False.elim (hyV.elim)\n          exact this hxV\n        -- if x is unmatched in M but matched in M', then in the symmetric difference component\n        -- containing x there is an augmenting path for M\n        -- use the standard construction via alternating paths in the symmetric difference\n        -- (available in the imported development)\n        have := (hM.exists_isAugPath_not_max (by\n          intro hmax'\n          exact hM'cd.not_le ((hmax'.max M' hM').trans_eq (by rfl))))\n        exact this\n      exact hno this\n    )\n  exact hnotmax hmax",
      "\n  classical\n  refine ⟨.nil (Classical.choice (G.exists_vertex_of_isMatching_lt_encard hM hM' hM'cd)), ?_⟩\n  simpa [isAugPath_iff, isAltPath_iff] using\n    (G.nil_isAugPath_of_isMatching_lt_encard hM hM' hM'cd)",
      "\n  exfalso\n  exact (lt_irrefl _ hM'cd)",
      "\n  classical\n  by_contra hex\n  have hmax : G.IsMaxMatching M :=\n    hM.isMaxMatching_of_vertex_subset (by\n      intro x hxV\n      by_contra hxM\n      have hxUn : x ∉ V(G, M) := hxM\n      have hxIn : x ∈ V(G, M') := by\n        by_contra hxIn\n        have hxNe : x ≠ x := by\n          have hl : G.IsLink (Classical.choice (by\n            simpa [V, Set.mem_setOf_eq] using hxV)) x x := by\n            simpa using (Classical.choose_spec (by\n              simpa [V, Set.mem_setOf_eq] using hxV))\n          exact (by simpa using (hl.ne_of_loopless (by\n            classical\n            infer_instance)))\n        exact (hxNe rfl).elim\n      rcases hxIn with ⟨e, heM', hxinc⟩\n      have heE : e ∈ E(G) := hM'.subset heM'\n      have hxinc' : x ∈ V(G, e) := hxinc\n      have hxN : x ∈ V(G, M) := by\n        classical\n        by_contra hxN\n        have hP : G.IsAugPath hM (.cons x e (.nil x)) := by\n          have hl : G.IsLink e x x := by\n            simpa [Graph.IsLink, heE] using hxinc'\n          exact isAugPath_of_singleEdge (G := G) (M := M) (hM := hM) hl hxUn hxUn (by\n            intro hxx; exact hxUn (by simpa [hxx] using hxUn))\n        exact hex ⟨_, hP⟩\n      exact (hxUn hxN).elim)\n  exact hnotmax hmax",
      "\n  classical\n  by_contra hno\n  have hmax : G.IsMaxMatching M :=\n    hM.isMaxMatching_of_vertex_subset (hsu := by\n      intro x hxV\n      by_contra hx\n      have hx' : x ∉ V(G, M) := hx\n      have hne : x ∈ V(G, M') := by\n        by_contra hxM'\n        have : G.IsAugPath hM (.nil x) := by\n          refine ⟨?_, ?_, ?_, ?_, ?_, ?_⟩\n          · simpa [isAltPath_iff, isAugPath_iff] using hxV\n          · simpa [isAltPath_iff, isAugPath_iff] using (by simp : (.nil x : WList α β).edge.IsChain _)\n          · simpa [WList.Nonempty] using (by trivial : (WList.nil x : WList α β).Nonempty)\n          · simpa using hx'\n          · simpa using hx'\n        exact hno ⟨.nil x, this⟩\n      rcases (show ∃ e, e ∈ M' ∧ x ∈ V(G, e) from hne) with ⟨e, heM', hex⟩\n      refine ?_\n      have heE : e ∈ E(G) := hM'.subset heM'\n      have huv : ∃ y, y ≠ x ∧ y ∈ V(G, e) := by\n        rcases (G.inc_exists_of_mem_edge heE) with ⟨u, v, huv, hlink⟩\n        have hxuv : x = u ∨ x = v := by\n          have : x ∈ ({u, v} : Set α) := by simpa [Graph.V, hlink] using hex\n          simpa [Set.mem_insert_iff, Set.mem_singleton_iff] using this\n        cases hxuv with\n        | inl hxu =>\n          refine ⟨v, ?_, ?_⟩\n          · exact huv.symm.trans_ne (by simpa [hxu])\n          · have : v ∈ ({u, v} : Set α) := by simp\n            simpa [Graph.V, hlink] using this\n        | inr hxv =>\n          refine ⟨u, ?_, ?_⟩\n          · exact huv.trans_ne (by simpa [hxv])\n          · have : u ∈ ({u, v} : Set α) := by simp\n            simpa [Graph.V, hlink] using this\n      rcases huv with ⟨y, hxy, hey⟩\n      have hy : y ∉ V(G, M) := by\n        intro hyM\n        have : x ∈ V(G, M) := by\n          rcases (show ∃ f, f ∈ M ∧ y ∈ V(G, f) from hyM) with ⟨f, hfM, hfy⟩\n          have hdis := hM.disjoint hfM (by simpa using heM') (by\n            intro hEq; exact hxy (by\n              have : x ∈ V(G, f) := by\n                have : Disjoint V(G, f) V(G, e) := hM.disjoint hfM (by simpa using heM') hEq\n                exact (this.le_bot ⟨hfy, hey⟩).elim\n              exact this))\n          exact False.elim (hdis.le_bot ⟨hfy, hey⟩)\n        exact hx this\n      have hlink : ∃ z, G.IsLink e x z := by\n        rcases (G.inc_exists_of_mem_edge heE) with ⟨u, v, huv, hlink⟩\n        have hxuv : x = u ∨ x = v := by\n          have : x ∈ ({u, v} : Set α) := by simpa [Graph.V, hlink] using hex\n          simpa [Set.mem_insert_iff, Set.mem_singleton_iff] using this\n        cases hxuv with\n        | inl hxu =>\n          refine ⟨v, ?_⟩\n          simpa [hxu] using hlink\n        | inr hxv =>\n          refine ⟨u, ?_⟩\n          simpa [hxv] using hlink.symm\n      rcases hlink with ⟨z, hlxz⟩\n      have hz : z ∉ V(G, M) := by\n        intro hzM\n        have : x ∈ V(G, M) := by\n          rcases (show ∃ f, f ∈ M ∧ z ∈ V(G, f) from hzM) with ⟨f, hfM, hfz⟩\n          have : x ∈ V(G, f) := by\n            have hdis : Disjoint V(G, f) V(G, e) :=\n              hM.disjoint hfM (by simpa using heM') (by\n                intro hEq\n                have : z ∈ V(G, e) := by\n                  have : z ∈ ({x, z} : Set α) := by simp\n                  simpa [Graph.V, hlxz] using this\n                exact (hdis.le_bot ⟨hfz, this⟩).elim)\n            exact False.elim (hdis.le_bot ⟨hfz, by\n              have : x ∈ ({x, z} : Set α) := by simp\n              simpa [Graph.V, hlxz] using this⟩)\n          exact ⟨f, hfM, this⟩\n        exact hx this\n      have : G.IsAugPath hM (.cons x e (.nil z)) :=\n        isAugPath_of_singleEdge hlxz hx' hz (by\n          intro h; exact hM'.disjoint heM' heM' (by simpa [h] ) |>.le_bot ⟨by simpa [Graph.V, hlxz, h] using hex,\n            by simpa [Graph.V, hlxz, h] using hey⟩)\n      exact hno ⟨.cons x e (.nil z), this⟩\n  exact (not_lt_of_le (hmax.max M' hM')) hM'cd",
      "\n  classical\n  by_contra hno\n  have hmax : G.IsMaxMatching M := by\n    refine hM.isMaxMatching_of_vertex_subset ?_\n    intro x hxV\n    by_contra hx\n    have hneV : (V(G, x) \\ V(G, M)).Nonempty := by\n      refine ⟨x, ?_, hx⟩\n      simpa [V, hxV]\n    rcases (hM'.subset (by\n        rcases hxV with ⟨e, heG⟩\n        exact heG)) with heG\n    have : ∃ P, G.IsAugPath hM P := by\n      classical\n      have hx' : x ∈ V(G) := hxV\n      have : False := by\n        exact hno ⟨.nil x, by\n          simpa [isAugPath_iff, isAltPath_iff, hx, hx', WList.Nonempty]⟩\n      exact this.elim\n    exact (hno this).elim\n  exact hnotmax hmax",
      "\n  classical\n  by_contra hno\n  have hmax : G.IsMaxMatching M :=\n    hM.isMaxMatching_of_vertex_subset (by\n      intro x hxV\n      by_contra hxnot\n      have hxV' : x ∈ V(G, M') := by\n        by_contra hxnot'\n        have : ∃ P, G.IsAugPath hM P := by\n          refine ⟨.cons x (Classical.choose hxV) (.nil (G.other (Classical.choose hxV) x)), ?_⟩\n          classical\n          have hxV'': x ∈ V(G) := hxV\n          have hxE : Classical.choose hxV ∈ E(G) := (Classical.choose_spec hxV).1\n          have hl : G.IsLink (Classical.choose hxV) x (G.other (Classical.choose hxV) x) := by\n            simpa [Graph.isLink_iff, hxE] using (Classical.choose_spec hxV).2\n          have hux : x ∉ V(G, M) := hxnot\n          have hvx : G.other (Classical.choose hxV) x ∉ V(G, M) := by\n            intro hv\n            have : x ∈ V(G, M) := by\n              refine ⟨Classical.choose hxV, ?_, ?_⟩\n              · exact (hM.subset (by\n                  have : Classical.choose hxV ∈ E(G) := hxE\n                  simpa using this)) |> by\n                    exact False.elim (by\n                      have : Classical.choose hxV ∈ M := by\n                        classical\n                        exact by\n                          by_contra hne\n                          exact hux (by\n                            refine ⟨Classical.choose hxV, ?_, ?_⟩\n                            · exact ?_\n                            · exact ?_))\n              · exact hl.inc_left\n            exact hxnot this\n          have huv : x ≠ G.other (Classical.choose hxV) x := by\n            intro hEq\n            have : IsLoop G (Classical.choose hxV) := by\n              refine ⟨x, ?_⟩\n              simpa [hEq] using hl\n            exact (G.loopless_iff.mp (by infer_instance) _ (by\n              have : Classical.choose hxV ∈ E(G) := hxE\n              exact this)) this\n          exact isAugPath_of_singleEdge (G := G) (M := M) (hM := hM) hl hux hvx huv\n        exact hno this\n    