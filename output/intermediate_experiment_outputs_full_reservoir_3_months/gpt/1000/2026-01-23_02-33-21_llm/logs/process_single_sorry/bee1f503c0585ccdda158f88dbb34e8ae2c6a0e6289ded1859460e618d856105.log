  -- hence cannot be 4 (even). In `Fin 8`, equality `A + s = A + 4` forces `s = 4`, which is even.
  -- Therefore there are no such paths.
  -- We prove this by showing the subtype is empty, hence its card is 0.
  have hempty :
      IsEmpty {p : Fin (2 * n - 1) → ℤˣ // A + ∑ i, (p i : Fin 8) = E} := by
    refine ⟨?_⟩
    intro p
