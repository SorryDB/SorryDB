        -- so equality to 0 is parity
        -- use `Fin.sum_const` and `Nat.cast_ofNat`
        have hs : (∑ _i : Fin m, (1 : Fin 2)) = (m : Fin 2) := by
          simpa using (Fin.sum_const (α := fun _ : Fin m => Fin 2) (m := m) (a := (1 : Fin 2)))
        -- hence (m : Fin 2) = 0
        have hm0 : (m : Fin 2) = 0 := by simpa [hs] using this
        -- translate to Nat mod 2 = 0
        -- in Fin 2, nat-cast is mod 2
        exact (by
          -- `Fin.ext` on hm0
          have : (m % 2) = 0 := by
            -- compare vals
            simpa using congrArg Fin.val hm0
          exact this))
    exact Nat.even_iff.mpr this
  -- Now show there are no paths of odd length ending at E.
  have hempty :
      IsEmpty {p : Fin (2 * n - 1) → ℤˣ // A + ∑ i, (p i : Fin 8) = E} := by
    refine ⟨?_
    ⟩
    intro x
    have : Even (2 * n - 1) := hparity x.1 x.2
    have hodd : ¬ Even (2 * n - 1) := by
      have hn' : 1 ≤ n := Nat.succ_le_iff.mp hn
      have : Odd (2 * n - 1) := by
        -- 2*n is even, subtract 1 gives odd
        simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc, Nat.two_mul] using (Nat.odd_sub (Nat.even_mul.mpr (Or.inl Nat.even_two)) (by decide))
      exact this.not_even
    exact (hodd this).elim
  -- conclude via card = 0
  classical
  have := ha_def (2 * n - 1)
  simp [this, Fintype.card_eq_zero_iff, hempty]
