      simpa [this, Finset.card_univ, this, Nat.cast_ofNat, this, Nat.cast_add, Nat.cast_mul, this] using
        (by
          -- `∑ _ : Fin m, (1 : ZMod 2) = m` in `ZMod 2`
          simpa using (Finset.sum_const_one : (∑ _i : Fin (2 * n - 1), (1 : ZMod 2)) = (2 * n - 1 : ZMod 2)))
    have hpar' : ((4 : Fin 8) : ZMod 2) = (0 : ZMod 2) := by
      norm_num
    have : (1 : ZMod 2) = (0 : ZMod 2) := by
      simpa [this] using congrArg (fun x : Fin 8 => (x : ZMod 2)) (this.trans rfl)
    exact one_ne_zero (by simpa using this)
