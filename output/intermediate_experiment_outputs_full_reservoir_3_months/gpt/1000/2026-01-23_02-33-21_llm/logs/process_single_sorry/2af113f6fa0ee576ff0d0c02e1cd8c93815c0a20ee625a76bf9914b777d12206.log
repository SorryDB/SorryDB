      "\n  classical\n  rcases not_forall.mp h₁ with ⟨x₀, hx₀⟩\n  have hx₀' : f x₀ ≠ 0 := by exact hx₀\n  intro y\n  have hmain : f (x₀ + y) + f (x₀ - y) = 2 * f x₀ * g y := h₀ x₀ y\n  have hbound : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by\n    have h1 : |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := by\n      simpa [abs_add] using (abs_add (f (x₀ + y)) (f (x₀ - y)))\n    have h2' : |f (x₀ + y)| + |f (x₀ - y)| ≤ 1 + 1 := by\n      exact add_le_add (h₂ (x₀ + y)) (h₂ (x₀ - y))\n    have : |f (x₀ + y) + f (x₀ - y)| ≤ 1 + 1 := le_trans h1 h2'\n    simpa using this\n  have hbound' : |2 * f x₀ * g y| ≤ 2 := by\n    simpa [hmain] using hbound\n  have hx0abs : 0 < |f x₀| := abs_pos.mpr hx₀'\n  have : |g y| ≤ 1 := by\n    have h' : |f x₀| * |g y| ≤ |f x₀| := by\n      have : |f x₀| * |g y| = |f x₀ * g y| := by\n        simp [abs_mul, mul_assoc]\n      have : |f x₀ * g y| ≤ |f x₀| := by\n        have : |2 * (f x₀ * g y)| ≤ 2 := by\n          simpa [mul_assoc, mul_left_comm, mul_comm] using hbound'\n        have : |f x₀ * g y| ≤ 1 := by\n          have := (mul_le_mul_left (show (0:ℝ) < (2:ℝ) by norm_num)).1 this\n          simpa [abs_mul, mul_assoc, mul_left_comm, mul_comm] using this\n        have hx0le : |f x₀| ≤ 1 := h₂ x₀\n        exact le_trans this hx0le\n      simpa [this] using this\n    have : |g y| ≤ 1 := (mul_le_mul_left hx0abs).1 h'\n    exact this\n  exact this",
      "\n  classical\n  have hfpos : ∀ y : ℝ, ∃ x : ℝ, f x ≠ 0 ∧ |g y| ≤ 1 := by\n    intro y\n    by_contra hy\n    have hy' : ∀ x : ℝ, f x ≠ 0 → ¬ |g y| ≤ 1 := by\n      intro x hx\n      have : ∃ x : ℝ, f x ≠ 0 ∧ |g y| ≤ 1 := ⟨x, hx, by\n        have := (by exact le_rfl : |g y| ≤ |g y|)\n        exact (not_and_or.mp (by\n          have : ¬(f x ≠ 0 ∧ |g y| ≤ 1) := by\n            intro h\n            exact hy ⟨x, h.1, h.2⟩\n          exact this)).elim (fun _ => by\n            exact le_of_lt (by\n              have : False := by\n                exact (by\n                  have := hy ⟨x, hx, ?_⟩\n                  · exact this\n                  · exact le_rfl)\n              exact this.elim) ) (fun h => h)⟩\n      -- unreachable\n      exact by\n        intro hle\n        exact hy ⟨x, hx, hle⟩\n    have hg1 : ¬ |g y| ≤ 1 := by\n      have : ∀ x : ℝ, f x ≠ 0 → ¬ |g y| ≤ 1 := by\n        intro x hx\n        intro hle\n        exact hy ⟨x, hx, hle⟩\n      rcases not_forall.mp (by\n        intro h\n        apply hy\n        rcases h₁ with h₁\n        exfalso\n        apply h₁\n        intro x\n        by_contra hx\n        exact h x hx) with ⟨x, hx⟩\n      exact this x hx\n    have hgy : 1 < |g y| := lt_of_not_ge hg1\n    have hineq : ∀ x : ℝ, |f (x + y) + f (x - y)| ≤ 2 := by\n      intro x\n      have h1 := h₂ (x + y)\n      have h2 := h₂ (x - y)\n      have : |f (x + y) + f (x - y)| ≤ |f (x + y)| + |f (x - y)| := by\n        simpa using abs_add (f (x + y)) (f (x - y))\n      have : |f (x + y) + f (x - y)| ≤ 1 + 1 := by\n        have := le_trans this (add_le_add h1 h2)\n        simpa [two_mul, add_assoc, add_left_comm, add_comm] using this\n      simpa using this\n    have hmain : ∀ x : ℝ, |f x| = 0 := by\n      intro x\n      have := h₀ x y\n      have habs : |2 * f x * g y| ≤ 2 := by\n        have : |2 * f x * g y| = |f (x + y) + f (x - y)| := by\n          simpa [this] using congrArg abs this.symm\n        simpa [this] using hineq x\n      have habs' : |2 * f x * g y| = 2 * |f x| * |g y| := by\n        simp [abs_mul, abs_of_pos (show (0:ℝ) ≤ 2 by linarith), mul_assoc, mul_left_comm, mul_comm]\n      have : 2 * |f x| * |g y| ≤ 2 := by simpa [habs'] using habs\n      have : |f x| * |g y| ≤ 1 := by\n        have h2pos : (0:ℝ) < 2 := by linarith\n        have := (mul_le_mul_left h2pos).1 (by simpa [mul_assoc] using this)\n        simpa using this\n      have : |f x| ≤ 1 / |g y| := by\n        have hgy0 : 0 < |g y| := lt_trans (by linarith) hgy\n        have := (mul_le_mul_right (inv_pos.2 hgy0)).2 this\n        simpa [mul_assoc, mul_left_comm, mul_comm, div_eq_mul_inv] using this\n      have hinvlt : 1 / |g y| < 1 := by\n        have hgy1 : 1 < |g y| := hgy\n        have hgy0 : 0 < |g y| := lt_trans (by linarith) hgy1\n        have := one_div_lt_one_of_lt hgy0 hgy1\n        simpa using this\n      have : |f x| < 1 := lt_of_le_of_lt this hinvlt\n      have : |f x| ≤ 0 := by\n        have : |f x| ≤ 1 := h₂ x\n        linarith [this, this]\n      have hxnonneg : 0 ≤ |f x| := abs_nonneg (f x)\n      exact le_antisymm (le_of_eq (by simpa using (abs_eq_zero.mp (le_antisymm (le_of_lt this) this)))) ?_\n    have : ∀ x, f x = 0 := by\n      intro x\n      have : |f x| = 0 := by\n        have := hmain x\n        simpa using this\n      simpa [abs_eq_zero] using this\n    exact h₁ this\n  intro y\n  by_contra hgy\n  have hy : 1 < |g y| := lt_of_not_ge hgy\n  -- choose x with f x ≠ 0\n  rcases not_forall.mp (by\n    intro h\n    apply h₁\n    intro x\n    exact h x) with ⟨x, hx⟩\n  have hineq : |f (x + y) + f (x - y)| ≤ 2 := by\n    have h1 := h₂ (x + y)\n    have h2 := h₂ (x - y)\n    have : |f (x + y) + f (x - y)| ≤ |f (x + y)| + |f (x - y)| := by\n      simpa using abs_add (f (x + y)) (f (x - y))\n    have : |f (x + y) + f (x - y)| ≤ 1 + 1 := by\n      have := le_trans this (add_le_add h1 h2)\n      simpa using this\n    simpa using this\n  have h0xy := h₀ x y\n  have habs : |2 * f x * g y| ≤ 2 := by\n    have : |2 * f x * g y| = |f (x + y) + f (x - y)| := by\n      simpa [h0xy] using congrArg abs h0xy.symm\n    simpa [this] using hineq\n  have habs' : |2 * f x * g y| = 2 * |f x| * |g y| := by\n    simp [abs_mul, abs_of_pos (show (0:ℝ) ≤ 2 by linarith), mul_assoc, mul_left_comm, mul_comm]\n  have : 2 * |f x| * |g y| ≤ 2 := by simpa [habs'] using habs\n  have : |f x| * |g y| ≤ 1 := by\n    have h2pos : (0:ℝ) < 2 := by linarith\n    have := (mul_le_mul_left h2pos).1 (by simpa [mul_assoc] using this)\n    simpa using this\n  have hxpos : 0 < |f x| := by\n    have : f x ≠ 0 := hx\n    exact abs_pos.2 this\n  have : |g y| ≤ 1 := by\n    have := (mul_le_mul_left (inv_pos.2 hxpos)).2 this\n    simpa [mul_assoc, mul_left_comm, mul_comm, div_eq_mul_inv] using this\n  exact hgy this",
      "\n  classical\n  have hne : ∃ x, f x ≠ 0 := by\n    by_contra h\n    apply h₁\n    intro x\n    have : ¬ f x ≠ 0 := by\n      simpa using (not_exists.mp h) x\n    simpa using eq_of_not_ne this\n  rcases hne with ⟨a, hfa⟩\n  have hg0 : g 0 = 1 := by\n    have h := h₀ a 0\n    -- x+0 = x and x-0 = x\n    simp at h\n    -- 2 * f a = 2 * f a * g 0\n    have : (2 * f a) = (2 * f a) * g 0 := by simpa [mul_assoc] using h\n    have h2fa : (2 * f a) ≠ 0 := by nlinarith\n    exact (mul_right_cancel₀ h2fa).1 this\n  intro y\n  by_contra hy\n  have hy' : 1 < |g y| := lt_of_not_ge hy\n  have hdiv : (0 : ℝ) < |f a| / |g y| := by\n    have hgy : 0 < |g y| := lt_trans (by simpa using (show (0:ℝ) < 1 from zero_lt_one)) hy'\n    have hfa' : 0 < |f a| := abs_pos.mpr hfa\n    exact div_pos hfa' hgy\n  have hlt : |f a| / |g y| < |f a| := by\n    have hgy : 1 < |g y| := hy'\n    have hpos : 0 < |f a| := abs_pos.mpr hfa\n    have : (|f a| / |g y|) < (|f a| / (1:ℝ)) := by\n      exact (div_lt_div_left hpos).2 (by simpa using hgy)\n    simpa using this\n  let S : Set ℝ := {x | |f x| < |f a| / |g y|}\n  have hS_nonempty : S.Nonempty := by\n    refine ⟨a, ?_⟩\n    simpa [S, lt_irrefl] using (lt_of_lt_of_le hlt (le_rfl : |f a| ≤ |f a|))\n  have hS_bdd : BddBelow S := by\n    refine ⟨a - y, ?_⟩\n    intro x hx\n    -- trivial bound to use completeness: use (a - y) as lower bound by ≤? not true\n    -- Instead use that ℝ is bddBelow by taking any number: sets are bddBelow if Nonempty? no.\n    -- Use that S ⊆ Set.univ and univ is bddBelow? also false.\n    -- We can avoid Inf by using minimality via real.inf? We'll use sInf since existence needs BddBelow.\n    -- Provide a bddBelow using a crude bound from |f x| < c implies nothing about x.\n    -- So use different approach: iterative contradiction without Inf.\n    -- We'll redo: define m = inf of {|f x|} over all x? also not bdd below.\n    -- Switch to classic \"choose x with maximal |f x|\" using boundedness and functional equation:\n    -- Use limsup: Actually can prove |g y| ≤ 1 using x = a * n and iterate.\n    -- Let's do iteration: set y fixed. Use relation:\n    -- f(x+y)+f(x-y)=2 f x g y => |f(x+y)+f(x-y)| ≤ 2\n    -- so |2 f x g y| ≤ 2 => |f x| * |g y| ≤ 1 for all x with ? no since LHS equals sum not bounded by 2? yes:\n    -- |2 f x g y| = |f(x+y)+f(x-y)| ≤ |f(x+y)|+|f(x-y)| ≤ 2, hence |f x|*|g y| ≤ 1.\n    -- Then choose x with f x ≠ 0, gives |g y| ≤ 1/|f x|, but may be >1.\n    -- Need show some x with |f x| close to 1. Show sup |f x| = 1 using not identically zero and equation with y=0 gives g0=1, then Jensen style show can amplify.\n    -- Use: define M = sup {|f x|}. Since bounded by 1, M exists. Choose sequence with |f x_n|→M.\n    -- Then inequality gives M*|g y| ≤ M, hence |g y| ≤ 1 if M>0. Since f not zero, M>0.\n    -- Implement with Real.sSup on set { |f x| | x } which is bounded and nonempty.\n    sorry\n  exact False.elim (by trivial)",
      "\n  classical\n  have h0' : ∀ x, f x = 0 → f 0 = 0 := by\n    intro x hx\n    have := h₀ x x\n    simp [hx] at this\n    nlinarith\n  have hf0 : f 0 = 0 := by\n    by_contra hf0\n    have : ∀ x, f x = 0 := by\n      intro x\n      have := h₀ 0 x\n      simp [hf0] at this\n      nlinarith\n    exact h₁ this\n  have hsq : ∀ x y, (f (x + y)) ^ 2 + (f (x - y)) ^ 2 = 2 * (f x) ^ 2 * ((g y) ^ 2) := by\n    intro x y\n    have h1 := h₀ (x + y) y\n    have h2 := h₀ (x - y) y\n    -- rewrite to express f(x+2y), f(x-2y), f(x), then eliminate using h₀ x (2y)\n    -- Using standard identity: from h₀ x y and h₀ x (-y) get evenness of g.\n    -- We'll instead use inequality based on (a+b)^2 ≤ 2(a^2+b^2).\n    -- Start from h₀ x y: 2 f x g y = f(x+y)+f(x-y)\n    have : (2 * f x * g y) ^ 2 = (f (x + y) + f (x - y)) ^ 2 := by\n      simpa [h₀ x y]\n    -- expand and bound via Cauchy: (a+b)^2 ≤ 2(a^2+b^2) and also ≥? use same to derive equality with choice.\n    -- But we need exact expression: use (a-b)^2 ≥ 0 to get (a+b)^2 ≤ 2(a^2+b^2)\n    have hb : (f (x + y) + f (x - y)) ^ 2 ≤ 2 * ((f (x + y)) ^ 2 + (f (x - y)) ^ 2) := by\n      have : 0 ≤ (f (x + y) - f (x - y)) ^ 2 := sq_nonneg (f (x + y) - f (x - y))\n      -- (a-b)^2 ≥ 0 ⇒ a^2 + b^2 ≥ 2ab ⇒ (a+b)^2 = a^2 + b^2 + 2ab ≤ 2(a^2+b^2)\n      nlinarith\n    -- We will not use hsq; keep it as lemma not needed\n    -- Provide a harmless exact equality derived from rewriting hb with `this`; use ≤ to get bound later\n    -- Return a statement by nlinarith: since we defined hsq, it is fine to prove by classical nlinarith using `this` and hb?\n    -- Instead, prove equality by `by nlinarith` is not possible; so give actual formula via expanding using `ring`\n    -- Let's prove the equality by direct expansion from (a+b)^2 + (a-b)^2 = 2(a^2+b^2) applied to a=f(x+y), b=f(x-y)\n    have hs : (f (x + y) + f (x - y)) ^ 2 + (f (x + y) - f (x - y)) ^ 2 =\n        2 * ((f (x + y)) ^ 2 + (f (x - y)) ^ 2) := by\n      ring\n    -- Also compute (f(x+y)-f(x-y)) via h₀ x y and h₀ x (-y) to eliminate g; easier: use hs and relation for sum and difference.\n    have hneg := h₀ x (-y)\n    have hgy : g (-y) = g y := by\n      by_cases hfx : f x = 0\n      · -- if f x = 0 then from h₀ x y get f(x+y) = -f(x-y) and same for -y gives g even by separate x with f x ≠ 0 later\n        have := h₀ x y\n        simp [hfx] at this\n        have := h₀ x (-y)\n        simp [hfx] at this\n        -- can't deduce; avoid using evenness\n        -- Provide some value; won't be used\n        simp\n      · have hy1 : f (x + y) + f (x - y) = 2 * f x * g y := by simpa using (h₀ x y)\n        have hy2 : f (x - y) + f (x + y) = 2 * f x * g (-y) := by\n          simpa [add_comm, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hneg\n        -- hy2 has same LHS, so RHS equal\n        have : 2 * f x * g y = 2 * f x * g (-y) := by nlinarith [hy1, hy2]\n        have : g y = g (-y) := by\n          have hx2 : (2 * f x) ≠ 0 := by nlinarith\n          exact (mul_right_cancel₀ hx2).1 (by simpa [mul_assoc] using this)\n        simpa [this]\n    -- Now difference:\n    have hd : f (x + y) - f (x - y) = 2 * f x * (g y - g (-y)) := by\n      have hy1 : f (x + y) + f (x - y) = 2 * f x * g y := by simpa using (h₀ x y)\n      have hy2 : f (x - y) + f (x + y) = 2 * f x * g (-y) := by\n        simpa [add_comm, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hneg\n      -- But hy2 LHS same as hy1, so g(-y)=g(y) when f x ≠ 0; anyway we already have hgy\n      -- hence difference is 0\n      have : g y - g (-y) = 0 := by simpa [hgy] \n      nlinarith [this]\n    -- Then (a-b)^2 = 0, so from hs we get the desired equality\n    have : (f (x + y) - f (x - y)) ^ 2 = 0 := by\n      have : f (x + y) - f (x - y) = 0 := by simpa using hd\n      simpa [this]\n    have : (f (x + y) + f (x - y)) ^ 2 = 2 * ((f (x + y)) ^ 2 + (f (x - y)) ^ 2) := by\n      nlinarith [hs, this]\n    -- now relate to g\n    have : (2 * f x * g y) ^ 2 = 2 * ((f (x + y)) ^ 2 + (f (x - y)) ^ 2) := by\n      simpa [h₀ x y] using this\n    -- Finally, show RHS also equals 2*(f x)^2*(g y)^2 by expanding LHS; keep as equality\n    nlinarith\n  -- Main proof: choose a with f a ≠ 0\n  rcases not_forall.mp h₁ with ⟨a, ha⟩\n  have hfa : f a ≠ 0 := by\n    intro h\n    exact ha h\n  intro x\n  have hineq : |g x| ≤ 1 := by\n    have hsum : f (a + x) + f (a - x) = 2 * f a * g x := by simpa using (h₀ a x)\n    have habs : |f (a + x) + f (a - x)| ≤ 2 := by\n      have h1 : |f (a + x)| ≤ 1 := h₂ (a + x)\n      have h2 : |f (a - x)| ≤ 1 := h₂ (a - x)\n      have := abs_add (f (a + x)) (f (a - x))\n      have : |f (a + x) + f (a - x)| ≤ |f (a + x)| + |f (a - x)| := by simpa using this\n      have : |f (a + x) + f (a - x)| ≤ 1 + 1 := le_trans this (add_le_add h1 h2)\n      simpa using this\n    have : |2 * f a * g x| ≤ 2 := by simpa [hsum] using habs\n    have hfa1 : |f a| ≤ 1 := h₂ a\n    have hfa0 : 0 < |f a| := abs_pos.2 hfa\n    -- divide inequality: |2*f a*g x| = 2*|f a|*|g x|\n    have : 2 * |f a| * |g x| ≤ 2 := by\n      simpa [abs_mul, abs_of_nonneg (show (0:ℝ) ≤ (2:ℝ) by norm_num), mul_assoc, mul_left_comm,\n        mul_comm] using this\n    have : |f a| * |g x| ≤ 1 := by\n      have : (2:ℝ) * (|f a| * |g x|) ≤ 2 := by\n        simpa [mul_assoc, mul_left_comm, mul_comm] using this\n      have : |f a| * |g x| ≤ 1 := by linarith\n      exact this\n    have : |g x| ≤ 1 := by\n      -- since |f a| ≤ 1 and positive, we can bound by using |f a|*|g x| ≤ 1 and |f a| > 0\n      have : |g x| ≤ 1 / |f a| := by\n        have := (le_div_iff₀ hfa0).2 this\n        simpa [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using this\n      have hdiv : 1 / |f a| ≥ 1 := by\n        have : |f a| ≤ 1 := hfa1\n        have hfapos : 0 < |f a| := hfa0\n        have : (1:ℝ) ≤ 1 / |f a| := by\n          have := (one_le_div₀ hfapos).2 this\n          simpa using this\n        exact this\n      exact le_trans this hdiv\n    exact this\n  simpa using hineq",
      "\n  classical\n  have hf0 : f 0 ≠ 0 := by\n    intro h\n    have hneg : ∀ x, f x = 0 := by\n      intro x\n      have hx : f x + f (-x) = 2 * f 0 * g x := by\n        simpa [add_comm, sub_eq_add_neg, add_assoc, add_left_comm] using (h₀ 0 x)\n      have hx' : f x + f (-x) = 0 := by simpa [h] using hx\n      have hx2 : f x + f x = 2 * f x * g 0 := by simpa using (h₀ x 0)\n      have hg0 : g 0 = 1 := by\n        have : f 0 + f 0 = 2 * f 0 * g 0 := by simpa using (h₀ 0 0)\n        have : 0 = 0 := by simpa [h] using this\n        have : f 0 = 0 := by simpa using h\n        have : True := trivial\n        have : g 0 = 1 := by\n          exfalso\n          exact h (by simpa using this)\n        exact this\n      have : f x = 0 := by\n        have := hx2\n        have : 2 * f x = 2 * f x * g 0 := by simpa [two_mul] using this\n        have : f x = f x * g 0 := by\n          have : (2:ℝ) ≠ 0 := by norm_num\n          exact (mul_left_cancel₀ this).1 (by simpa [mul_assoc] using this)\n        simpa [hg0] using (sub_eq_zero.2 this)\n      exact this\n    exact h₁ hneg\n  intro y\n  have hineq : |g y| ≤ 1 := by\n    have hy : |f (0 + y) + f (0 - y)| ≤ 2 := by\n      have : |f (0 + y) + f (0 - y)| ≤ |f (0 + y)| + |f (0 - y)| := by\n        simpa using (abs_add (f (0 + y)) (f (0 - y)))\n      have hfy : |f (0 + y)| ≤ 1 := h₂ (0 + y)\n      have hfmy : |f (0 - y)| ≤ 1 := h₂ (0 - y)\n      have : |f (0 + y)| + |f (0 - y)| ≤ 1 + 1 := add_le_add hfy hfmy\n      have : |f (0 + y) + f (0 - y)| ≤ 1 + 1 := le_trans this this\n      simpa using this\n    have hEq : f (0 + y) + f (0 - y) = 2 * f 0 * g y := by simpa using (h₀ 0 y)\n    have : |2 * f 0 * g y| ≤ 2 := by simpa [hEq] using hy\n    have : |f 0| * |g y| ≤ 1 := by\n      have : |2 * f 0 * g y| = 2 * (|f 0| * |g y|) := by\n        simp [abs_mul, mul_assoc, mul_left_comm, mul_comm]\n      have h2pos : (0:ℝ) < 2 := by norm_num\n      have : 2 * (|f 0| * |g y|) ≤ 2 := by simpa [this] using this\n      have : |f 0| * |g y| ≤ 1 := by\n        have : |f 0| * |g y| ≤ 2 / 2 := (le_div_iff₀' h2pos).2 (by simpa [mul_assoc] using this)\n        simpa using this\n      exact this\n    have hf0abs : 0 < |f 0| := abs_pos.2 hf0\n    have hbound : |g y| ≤ 1 / |f 0| := (le_div_iff₀' hf0abs).2 (by simpa [mul_comm, mul_left_comm, mul_assoc] using this)\n    have hf0le : |f 0| ≤ 1 := h₂ 0\n    have hone : 1 / |f 0| ≤ 1 := by\n      have : 1 ≤ |f 0| := by\n        have : |f 0| ≠ 0 := by exact ne_of_gt hf0abs\n        have : (1:ℝ) / |f 0| ≤ 1 ↔ 1 ≤ |f 0| := by\n          simpa [one_div] using (div_le_iff₀' hf0abs)\n        exact (this).1 (by simpa using (le_of_eq (rfl : (1:ℝ) / |f 0| = (1:ℝ) / |f 0|)))\n      exact (le_of_not_gt (by\n        intro hgt\n        have : |f 0| < 1 := lt_of_le_of_lt hf0le hgt\n        exact (lt_irrefl _ this)))\n    exact le_trans hbound hone\n  exact hineq",
      "\n  classical\n  have hf : ∃ x, f x ≠ 0 := by\n    by_contra h\n    apply h₁\n    intro x\n    by_contra hx\n    exact h ⟨x, hx⟩\n  rcases hf with ⟨x₀, hx₀⟩\n  intro y\n  have hfg : f (x₀ + y) + f (x₀ - y) = 2 * f x₀ * g y := h₀ x₀ y\n  have hle : |2 * f x₀ * g y| ≤ 2 := by\n    have : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by\n      have h1 : |f (x₀ + y)| ≤ 1 := h₂ (x₀ + y)\n      have h2' : |f (x₀ - y)| ≤ 1 := h₂ (x₀ - y)\n      have : |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| :=\n        abs_add _ _\n      have : |f (x₀ + y) + f (x₀ - y)| ≤ 1 + 1 := by\n        exact le_trans this (add_le_add h1 h2')\n      simpa using this\n    simpa [hfg] using this\n  have hx0_le1 : |f x₀| ≤ 1 := h₂ x₀\n  have hx0_pos : 0 < |f x₀| := abs_pos.mpr hx₀\n  have hg_le : |g y| ≤ 1 := by\n    have : |2 * f x₀| * |g y| ≤ 2 := by\n      simpa [abs_mul, mul_assoc, mul_left_comm, mul_comm] using hle\n    have h2pos : 0 < |2 * f x₀| := by\n      simpa [abs_mul] using (mul_pos (by norm_num : (0:ℝ) < |(2:ℝ)|) hx0_pos)\n    have : |g y| ≤ 2 / |2 * f x₀| := by\n      have := (le_div_iff₀' h2pos).2 this\n      simpa [mul_assoc] using this\n    have hdiv : 2 / |2 * f x₀| ≤ 1 := by\n      have hge : (2:ℝ) ≤ |2 * f x₀| := by\n        have : (2:ℝ) ≤ |2| * |f x₀| := by\n          simpa using (mul_le_mul_of_nonneg_left (show (1:ℝ) ≤ |f x₀| by\n            have : |f x₀| = 1 := le_antisymm hx0_le1 (le_of_lt (lt_of_lt_of_le (by\n              have : (0:ℝ) < |f x₀| := hx0_pos\n              exact this) hx0_le1))\n            simpa [this]) (by norm_num : (0:ℝ) ≤ |(2:ℝ)|))\n        simpa [abs_mul] using this\n      have hpos : 0 < |2 * f x₀| := h2pos\n      have : 2 / |2 * f x₀| ≤ 2 / 2 := by\n        exact div_le_div_of_nonneg_left (by norm_num : (0:ℝ) ≤ 2) hge\n      simpa using this\n    exact le_trans this hdiv\n  exact hg_le",
      "\n  classical\n  have h0' : ∀ x y, f (x + y) + f (x - y) = (2 : ℝ) * f x * g y := h₀\n  obtain ⟨x0, hx0⟩ : ∃ x0, f x0 ≠ 0 := by\n    by_contra h\n    apply h₁\n    intro x\n    have : ¬ f x ≠ 0 := by\n      intro hx\n      exact h ⟨x, hx⟩\n    exact not_ne_iff.mp this\n  intro y\n  have hxy := h0' x0 y\n  have hbound : |f (x0 + y) + f (x0 - y)| ≤ 2 := by\n    have hA : |f (x0 + y)| ≤ 1 := h₂ (x0 + y)\n    have hB : |f (x0 - y)| ≤ 1 := h₂ (x0 - y)\n    have : |f (x0 + y) + f (x0 - y)| ≤ |f (x0 + y)| + |f (x0 - y)| := by\n      simpa using (abs_add (f (x0 + y)) (f (x0 - y)))\n    have : |f (x0 + y) + f (x0 - y)| ≤ 1 + 1 := by\n      exact le_trans this (add_le_add hA hB)\n    simpa using this\n  have hbound' : |(2 : ℝ) * f x0 * g y| ≤ 2 := by simpa [hxy] using hbound\n  have hpos : (0 : ℝ) < |(2 : ℝ) * f x0| := by\n    have : (2 : ℝ) ≠ 0 := by norm_num\n    have : (2 : ℝ) * f x0 ≠ 0 := mul_ne_zero this hx0\n    exact abs_pos.mpr this\n  have : |g y| ≤ 1 := by\n    have : |(2 : ℝ) * f x0| * |g y| ≤ 2 := by\n      simpa [abs_mul, mul_assoc, mul_left_comm, mul_comm] using hbound'\n    have : |g y| ≤ 2 / |(2 : ℝ) * f x0| := by\n      have := (le_div_iff₀ hpos).2 this\n      simpa [mul_comm, mul_left_comm, mul_assoc] using this\n    have hx0le : |f x0| ≤ 1 := h₂ x0\n    have hle : 2 / |(2 : ℝ) * f x0| ≤ 1 := by\n      have : |(2 : ℝ) * f x0| = 2 * |f x0| := by\n        simp [abs_mul, abs_of_pos (show (0 : ℝ) < 2 by norm_num), mul_assoc]\n      have hx0pos : 0 < |f x0| := abs_pos.mpr hx0\n      have hdiv : 2 / (2 * |f x0|) = 1 / |f x0| := by\n        field_simp [hx0pos.ne', (show (2 : ℝ) ≠ 0 by norm_num)]\n      have : 2 / |(2 : ℝ) * f x0| = 1 / |f x0| := by simpa [this, hdiv]\n      rw [this]\n      have : 1 ≤ |f x0| := by\n        have := (one_le_abs).2 (Or.inr (le_of_lt hx0pos))\n        exact this\n      have hfx0le1 : |f x0| ≤ 1 := hx0le\n      have hfx0eq : |f x0| = 1 := le_antisymm hfx0le1 (le_of_not_gt (by\n        intro hlt\n        have : (|f x0| : ℝ) < 1 :