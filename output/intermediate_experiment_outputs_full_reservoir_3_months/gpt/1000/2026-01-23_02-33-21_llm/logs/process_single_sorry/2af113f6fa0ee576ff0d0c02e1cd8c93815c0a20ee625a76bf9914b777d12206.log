      "\n  classical\n  by_contra h\n  have h' : ∃ y, 1 < |g y| := by\n    simpa [not_forall] using h\n  rcases h' with ⟨y, hy⟩\n  have hy0 : g y ≠ 0 := by\n    intro hg\n    have : |g y| = 0 := by simpa [hg]\n    linarith [hy, this]\n  have hf0 : f 0 = 0 := by\n    have := h₀ 0 0\n    -- f(0)+f(0)=2*f(0)*g(0)\n    have : 2 * f 0 = 2 * f 0 * g 0 := by\n      simpa [add_zero, sub_zero, two_mul, mul_assoc, mul_left_comm, mul_comm] using this\n    -- rearrange: 2*f0*(1-g0)=0; if f0≠0 then g0=1\n    by_contra hf0ne\n    have hf0ne' : f 0 ≠ 0 := by exact hf0ne\n    have hg0 : g 0 = 1 := by\n      have : (2 * f 0) ≠ 0 := by\n        nlinarith\n      have := congrArg (fun t => t / (2 * f 0)) this\n      simp [this, mul_assoc, div_mul_eq_mul_div, mul_div_cancel_left₀, *] at this\n      simpa using this\n    -- use h₀ with x=0 to show |f y| = |f (-y)| and both bounded by 1, then g(y) bounded; contradiction not needed, just set f0=0\n    -- but here we derive contradiction with hy by bounding g(y) using any nonzero f(x); so set f0=0 to avoid.\n    exact False.elim (hf0ne' (by\n      -- if g0=1 then x=0 gives f(y)+f(-y)=2*f0*g(y)=0 so consistent; doesn't force contradiction\n      -- so just choose: from h₁ we can find x with f x ≠ 0 and proceed; hence f0=0 can be assumed wlog, but we still need a contradiction from hf0ne\n      -- Instead, show if f0≠0 then g is bounded by 1 already, contradict hy.\n      have : ∀ y, |g y| ≤ 1 := by\n        intro y\n        have hxy := h₀ 0 y\n        -- f(y)+f(-y)=2*f0*g(y)\n        have habs : |f y + f (-y)| ≤ 2 := by\n          have hy1 : |f y| ≤ 1 := h₂ y\n          have hy2 : |f (-y)| ≤ 1 := h₂ (-y)\n          have : |f y + f (-y)| ≤ |f y| + |f (-y)| := by\n            simpa using abs_add (f y) (f (-y))\n          have : |f y + f (-y)| ≤ 2 := by\n            have := le_trans this (by nlinarith [hy1, hy2])\n            simpa using this\n          exact this\n        have : |2 * f 0 * g y| ≤ 2 := by\n          simpa [hxy] using habs\n        have hf0pos : 0 < |f 0| := abs_pos.mpr hf0ne'\n        have : |g y| ≤ 1 := by\n          -- |2*f0*g| = 2*|f0|*|g|\n          have hmul : |2 * f 0 * g y| = 2 * |f 0| * |g y| := by\n            simp [abs_mul, mul_assoc, mul_left_comm, mul_comm]\n          have : 2 * |f 0| * |g y| ≤ 2 := by simpa [hmul] using this\n          have : |f 0| * |g y| ≤ 1 := by\n            have h2pos : (0:ℝ) < 2 := by norm_num\n            have := (mul_le_mul_left h2pos).1 (by simpa [mul_assoc] using this)\n            -- 2*(|f0|*|g|) ≤ 2*1\n            simpa [mul_assoc] using this\n          have hf0le1 : |f 0| ≤ 1 := h₂ 0\n          -- since |f0|>0 and |f0|≤1, divide\n          have : |g y| ≤ 1 / |f 0| := by\n            exact (le_div_iff₀ hf0pos).2 (by simpa [mul_comm, mul_left_comm, mul_assoc] using this)\n          have : |g y| ≤ 1 := by\n            have : 1 / |f 0| ≥ 1 := by\n              have : |f 0| ≤ 1 := hf0le1\n              have hf0pos' : 0 < |f 0| := hf0pos\n              have := one_div_le_one_div_of_le hf0pos' this\n              simpa using this\n            exact le_trans this (by linarith)\n          exact this\n        exact this\n      have := this y\n      linarith [hy, this])\n    ))\n  -- choose x with f x ≠ 0\n  have hx : ∃ x, f x ≠ 0 := by\n    by_contra hx\n    apply h₁\n    intro x\n    by_contra hfx\n    exact hx ⟨x, hfx⟩\n  rcases hx with ⟨x, hxne⟩\n  have hxpos : 0 < |f x| := abs_pos.mpr hxne\n  have hxy := h₀ x y\n  have habs : |f (x + y) + f (x - y)| ≤ 2 := by\n    have h1 : |f (x + y)| ≤ 1 := h₂ (x + y)\n    have h2' : |f (x - y)| ≤ 1 := h₂ (x - y)\n    have : |f (x + y) + f (x - y)| ≤ |f (x + y)| + |f (x - y)| := by\n      simpa using abs_add (f (x + y)) (f (x - y))\n    have : |f (x + y) + f (x - y)| ≤ 2 := by\n      have := le_trans this (by nlinarith [h1, h2'])\n      simpa using this\n    exact this\n  have : |2 * f x * g y| ≤ 2 := by\n    simpa [hxy] using habs\n  have hmul : |2 * f x * g y| = 2 * |f x| * |g y| := by\n    simp [abs_mul, mul_assoc