/--
$f$ and $g$ are real-valued functions defined on the real line. For all $x$ and $y, f(x+y)+f(x-y)=2f(x)g(y)$. $f$ is not identically zero and $|f(x)|\le1$ for all $x$. Prove that $|g(x)|\le1$ for all $x$. -/
@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  classical
  have hx : ∃ x0, f x0 ≠ 0 := by
    by_contra h
    apply h₁
    intro x
    by_contra hx
    exact h ⟨x, hx⟩
  rcases hx with ⟨x0, hx0⟩
  intro y
  have hmain : |f x0| * |g y| ≤ |f x0| := by
    have hxy := h₀ x0 y
    have : |2 * f x0 * g y| ≤ 2 := by
      have := congrArg abs hxy
      -- |f(x0+y)+f(x0-y)| = |2*f(x0)*g(y)|
      have hle : |f (x0 + y) + f (x0 - y)| ≤ 2 := by
        have h1 : |f (x0 + y)| ≤ 1 := h₂ (x0 + y)
        have h2' : |f (x0 - y)| ≤ 1 := h₂ (x0 - y)
        have := abs_add (f (x0 + y)) (f (x0 - y))
        have hle' : |f (x0 + y) + f (x0 - y)| ≤ |f (x0 + y)| + |f (x0 - y)| := by
          simpa using this
        have : |f (x0 + y)| + |f (x0 - y)| ≤ 1 + 1 := by
          exact add_le_add h1 h2'
        have : |f (x0 + y)| + |f (x0 - y)| ≤ 2 := by simpa using this
        exact le_trans hle' this
      -- rewrite and simplify
      simpa [this] using (le_of_eq this).trans_le hle
    -- convert |2*f*x*g| ≤ 2 to |f x0|*|g y| ≤ |f x0|
    have hpos : (0 : ℝ) ≤ |f x0| := abs_nonneg _
    have : |f x0| * |g y| ≤ |f x0| := by
      -- start from: |2*f x0 * g y| ≤ 2
      have : |2 * f x0 * g y| ≤ 2 := this
      -- rewrite abs
      have : |2| * |f x0| * |g y| ≤ 2 := by
        simpa [abs_mul, mul_assoc, mul_left_comm, mul_comm] using this
      -- |2|=2
      have : 2 * |f x0| * |g y| ≤ 2 := by simpa using this
      -- divide by 2
      have : |f x0| * |g y| ≤ 1 := by
        have h2pos : (0 : ℝ) < 2 := by norm_num
        have := (mul_le_mul_left (show (0:ℝ) < (1/2) by norm_num)).2 this
        -- (1/2)*(2*|f|*|g|) ≤ (1/2)*2
        simpa [mul_assoc, mul_left_comm, mul_comm] using this
      -- then multiply by |f x0| ≤ 1? Actually |f x0| ≤ 1 gives |f x0|*|g y| ≤ |f x0|
      have hx0le : |f x0| ≤ 1 := h₂ x0
      have : |f x0| * |g y| ≤ |f x0| * 1 := by
        exact mul_le_mul_of_nonneg_left this hpos
      simpa [mul_one] using le_trans this (by
        have := mul_le_mul_of_nonneg_left hx0le hpos
        simpa [mul_one] using this)
    exact this
  have hx0pos : 0 < |f x0| := abs_pos.2 hx0
  have : |g y| ≤ 1 := by
    have := (le_of_mul_le_mul_left hmain hx0pos)
    simpa using this
  exact this
