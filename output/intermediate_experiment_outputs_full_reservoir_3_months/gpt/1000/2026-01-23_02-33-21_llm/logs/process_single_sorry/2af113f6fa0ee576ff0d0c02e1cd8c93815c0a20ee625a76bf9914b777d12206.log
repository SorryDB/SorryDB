          have := (mul_le_mul_of_nonneg_left (hmain n) (show 0 ≤ |g y| by exact abs_nonneg _))
          simpa [mul_assoc, mul_left_comm, mul_comm, div_eq_mul_inv] using this
        simpa [mul_comm] using h1
    exact this
  have hx0le : |f x0| ≤ 1 / |g y| := by
    simpa using this 0
  have hx0gt : 1 / |g y| < 1 := by
    have hgy : 1 < |g y| := hg'
    have hgypos : 0 < |g y| := lt_trans (by norm_num) hgy
    have := one_div_lt_one (show 1 < |g y| by exact hgy)
    simpa using this
  have : |f x0| < 1 := lt_of_le_of_lt hx0le hx0gt
  have : |f x0| ≤ 1 := h₂ x0
  exact lt_irrefl _ (lt_of_lt_of_le this this)
