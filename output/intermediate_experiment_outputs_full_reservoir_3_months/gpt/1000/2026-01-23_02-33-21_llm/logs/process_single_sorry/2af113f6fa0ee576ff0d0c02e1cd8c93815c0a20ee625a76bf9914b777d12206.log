/--
$f$ and $g$ are real-valued functions defined on the real line. For all $x$ and $y, f(x+y)+f(x-y)=2f(x)g(y)$. $f$ is not identically zero and $|f(x)|\le1$ for all $x$. Prove that $|g(x)|\le1$ for all $x$. -/
@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  classical
  rcases not_forall.mp h₁ with ⟨x₀, hx₀⟩
  have hx₀' : f x₀ ≠ 0 := by exact hx₀
  intro y
  have hmain : f (x₀ + y) + f (x₀ - y) = 2 * f x₀ * g y := h₀ x₀ y
  have hbound : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by
    have h1 : |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := by
      simpa [abs_add] using (abs_add (f (x₀ + y)) (f (x₀ - y)))
    have h2' : |f (x₀ + y)| + |f (x₀ - y)| ≤ 1 + 1 := by
      exact add_le_add (h₂ (x₀ + y)) (h₂ (x₀ - y))
    have : |f (x₀ + y) + f (x₀ - y)| ≤ 1 + 1 := le_trans h1 h2'
    simpa using this
  have hbound' : |2 * f x₀ * g y| ≤ 2 := by
    simpa [hmain] using hbound
  have hx0abs : 0 < |f x₀| := abs_pos.mpr hx₀'
  have : |g y| ≤ 1 := by
    have h' : |f x₀| * |g y| ≤ |f x₀| := by
      have : |f x₀| * |g y| = |f x₀ * g y| := by
        simp [abs_mul, mul_assoc]
      have : |f x₀ * g y| ≤ |f x₀| := by
        have : |2 * (f x₀ * g y)| ≤ 2 := by
          simpa [mul_assoc, mul_left_comm, mul_comm] using hbound'
        have : |f x₀ * g y| ≤ 1 := by
          have := (mul_le_mul_left (show (0:ℝ) < (2:ℝ) by norm_num)).1 this
          simpa [abs_mul, mul_assoc, mul_left_comm, mul_comm] using this
        have hx0le : |f x₀| ≤ 1 := h₂ x₀
        exact le_trans this hx0le
      simpa [this] using this
    have : |g y| ≤ 1 := (mul_le_mul_left hx0abs).1 h'
    exact this
  exact this
