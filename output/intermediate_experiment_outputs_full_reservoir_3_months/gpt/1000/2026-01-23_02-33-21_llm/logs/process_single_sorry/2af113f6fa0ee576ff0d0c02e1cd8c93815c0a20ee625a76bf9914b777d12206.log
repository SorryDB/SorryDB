      "\n  classical\n  have hex : ∃ x, f x ≠ 0 := by\n    by_contra h\n    apply h₁\n    intro x\n    by_contra hx\n    exact h ⟨x, hx⟩\n  rcases hex with ⟨x0, hx0⟩\n  have hpos : 0 < |f x0| := abs.pos hx0\n  intro y\n  have hmain : 2 * f x0 * g y = f (x0 + y) + f (x0 - y) := by\n    simpa [h₀ x0 y] using (h₀ x0 y).symm\n  have habs : |2 * f x0 * g y| ≤ 2 := by\n    have hle : |f (x0 + y) + f (x0 - y)| ≤ 2 := by\n      have h1 : |f (x0 + y)| ≤ 1 := h₂ (x0 + y)\n      have h2' : |f (x0 - y)| ≤ 1 := h₂ (x0 - y)\n      have := abs_add (f (x0 + y)) (f (x0 - y))\n      have h := le_trans this (add_le_add h1 h2')\n      simpa using h\n    simpa [hmain, abs_of_nonneg (show (0:ℝ) ≤ (2:ℝ) by norm_num)] using hle\n  have habs' : |2 * f x0| * |g y| ≤ 2 := by\n    simpa [abs_mul, mul_assoc, mul_left_comm, mul_comm] using habs\n  have hdiv : |g y| ≤ 2 / |2 * f x0| := by\n    have hpos' : 0 < |2 * f x0| := by\n      simpa [abs_mul, abs_of_nonneg (show (0:ℝ) ≤ (2:ℝ) by norm_num)] using\n        (mul_pos (show (0:ℝ) < |(2:ℝ)| by simpa using (abs_pos.2 (by norm_num : (2:ℝ) ≠ 0))) hpos)\n    exact (le_div_iff₀ hpos').2 habs'\n  have hfx0 : |f x0| ≤ 1 := h₂ x0\n  have hpos2 : 0 < |f x0| := hpos\n  have hbound : 2 / |2 * f x0| ≤ 1 := by\n    have hpos2' : 0 < |2 * f x0| := by\n      simpa [abs_mul, abs_of_nonneg (show (0:ℝ) ≤ (2:ℝ) by norm_num)] using\n        (mul_pos (show (0:ℝ) < |(2:ℝ)| by simpa using (abs_pos.2 (by norm_num : (2:ℝ) ≠ 0))) hpos2)\n    have : 2 ≤ |2 * f x0| := by\n      have : 1 ≤ |f x0|⁻¹ := by\n        have hx : |f x0| ≤ 1 := hfx0\n        have hx' : 0 < |f x0| := hpos2\n        have : (|f x0|)⁻¹ ≥ 1 := by\n          have := inv_le_inv_of_le hx' hx\n          simpa using this\n        simpa [ge_iff_le] using this\n      have h2abs : |2 * f x0| = 2 * |f x0| := by\n        simpa [abs_mul, abs_of_nonneg (show (0:ℝ) ≤ (2:ℝ) by norm_num), mul_assoc]\n      have : (2:ℝ) ≤ 2 * |f x0| := by\n        nlinarith [hfx0]\n      simpa [h2abs, mul_assoc] using this\n    have :=