  have hf : ∃ x, f x ≠ 0 := by
    by_contra h
    apply h₁
    intro x
    by_contra hx
    exact h ⟨x, hx⟩
  rcases hf with ⟨x0, hx0⟩
  intro y
  have hmain : ∀ n : ℕ, |g y| ≤ 1 / |f (x0 * (2:ℝ) ^ n)| := by
    intro n
    have hrec : f (x0 * (2:ℝ) ^ n + y) + f (x0 * (2:ℝ) ^ n - y) = 2 * f (x0 * (2:ℝ) ^ n) * g y :=
      h₀ (x0 * (2:ℝ) ^ n) y
    have habs : |2 * f (x0 * (2:ℝ) ^ n) * g y| ≤ 2 := by
      calc
        |2 * f (x0 * (2:ℝ) ^ n) * g y|
            = |f (x0 * (2:ℝ) ^ n + y) + f (x0 * (2:ℝ) ^ n - y)| := by
                simpa [hrec, mul_assoc, mul_left_comm, mul_comm]
        _ ≤ |f (x0 * (2:ℝ) ^ n + y)| + |f (x0 * (2:ℝ) ^ n - y)| := by
              simpa [abs_add] using (abs_add (f (x0 * (2:ℝ) ^ n + y)) (f (x0 * (2:ℝ) ^ n - y)))
        _ ≤ 1 + 1 := by
              gcongr <;> exact h₂ _
        _ = 2 := by norm_num
    have hfne : f (x0 * (2:ℝ) ^ n) ≠ 0 := by
      intro hzero
      have hstep : f x0 = 0 := by
        have : ∀ m : ℕ, f (x0 * (2:ℝ) ^ m) = 0 := by
          refine Nat.rec ?_ ?_ n
          · intro
            simpa using hzero
          · intro m hm
            have : f (x0 * (2:ℝ) ^ (m + 1)) = 0 := by
              have h' : f (x0 * (2:ℝ) ^ (m + 1)) + f (x0 * (2:ℝ) ^ (m + 1)) =
                  2 * f (x0 * (2:ℝ) ^ m) * g (x0 * (2:ℝ) ^ m) := by
                simpa [pow_succ, mul_assoc, mul_left_comm, mul_comm, add_comm, add_left_comm, add_assoc]
                  using (h₀ (x0 * (2:ℝ) ^ m) (x0 * (2:ℝ) ^ m))
              have : 2 * f (x0 * (2:ℝ) ^ (m + 1)) = 0 := by
                simpa [two_mul] using (by simpa [hm] at h')
              have : f (x0 * (2:ℝ) ^ (m + 1)) = 0 := by
                have h2 : (2:ℝ) ≠ 0 := by norm_num
                exact (mul_eq_zero.mp this).resolve_left h2
              simpa [pow_succ, mul_assoc] using this
            exact this
        have := this 0
        simpa using this
      exact hx0 hstep
    have : |g y| ≤ 1 / |f (x0 * (2:ℝ) ^ n)| := by
      have hpos : 0 < |f (x0 * (2:ℝ) ^ n)| := abs_pos.mpr hfne
      have : |g y| = |2 * f (x0 * (2:ℝ) ^ n) * g y| / (2 * |f (x0 * (2:ℝ) ^ n)|) := by
        field_simp [hpos.ne', abs_mul, abs_of_pos (show (0:ℝ) < (2:ℝ) by norm_num), mul_assoc, mul_comm, mul_left_comm]
      have hle : |g y| ≤ 2 / (2 * |f (x0 * (2:ℝ) ^ n)|) := by
        have hpos2 : 0 < (2:ℝ) * |f (x0 * (2:ℝ) ^ n)| := by
          nlinarith [hpos]
        have := (div_le_div_of_nonneg_right (show 0 ≤ (2:ℝ) * |f (x0 * (2:ℝ) ^ n)| by nlinarith [hpos]) habs)
        simpa [this, this] using this
      have : |g y| ≤ 1 / |f (x0 * (2:ℝ) ^ n)| := by
        simpa [div_mul_eq_div_div, div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm] using hle
      exact this
    exact this
  by_contra hg
  have hg' : 1 < |g y| := lt_of_not_ge hg
  have : ∀ n : ℕ, |f (x0 * (2:ℝ) ^ n)| ≤ 1 / |g y| := by
    intro n
    have := hmain n
    have hgypos : 0 < |g y| := lt_trans (by norm_num) hg'
    have hfxpos : 0 < |f (x0 * (2:ℝ) ^ n)| := by
      have : f (x0 * (2:ℝ) ^ n) ≠ 0 := by
        intro hzero
        have : |g y| ≤ 1 / |f (x0 * (2:ℝ) ^ n)| := hmain n
