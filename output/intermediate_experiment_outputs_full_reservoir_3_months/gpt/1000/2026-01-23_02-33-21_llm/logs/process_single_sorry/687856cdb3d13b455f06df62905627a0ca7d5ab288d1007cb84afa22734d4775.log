import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  classical
  refine ⟨1, by norm_num, ?_⟩
  intro n hn S hS hpair
  obtain ⟨p₁, hp₁⟩ := S.card_pos.mp (by
    have : 0 < n := lt_trans (by decide : (0 : ℕ) < 1) hn
    simpa [hS] using this)
  let l : AffineSubspace ℝ P := AffineSubspace.span ℝ (S : Set P)
  refine ⟨l, ?_, ?_, ?_⟩
  · have hdir : finrank ℝ l.direction ≤ finrank ℝ V := by
      simpa using (AffineSubspace.finrank_direction_le (l := l))
    have : finrank ℝ l.direction ≤ 2 := by
      simpa [Fact.out (p := (finrank ℝ V = 2))] using hdir
    have hpos : 0 < finrank ℝ l.direction := by
      have : (⊥ : Submodule ℝ V) ≤ l.direction := bot_le
      have hne : (l.direction : Submodule ℝ V) ≠ ⊥ := by
        intro hbot
        have : (S : Set P).Subsingleton := by
          simpa [l, hbot] using (AffineSubspace.subsingleton_of_direction_eq_bot (l := l))
        rcases this (by simpa using hp₁) (by simpa using hp₁) with h
        have := hn.ne' (by simpa [hS] using (S.card_le_one_iff.mpr (by
          intro a ha b hb
          simpa using this ha hb)))
        exact this
      exact Nat.pos_of_ne_zero (by
        intro h0
        apply hne
        exact Submodule.eq_bot_of_finrank_eq_zero h0)
    have : finrank ℝ l.direction = 1 := by
      have : finrank ℝ l.direction = 1 ∨ finrank ℝ l.direction = 2 := by
        have := Nat.lt_succ_iff.mp (lt_of_lt_of_le (Nat.lt_succ_self 1) this)
        exact Or.inl (le_antisymm (Nat.succ_le_iff.mp (Nat.succ_le_of_lt hpos)) (by
          have : finrank ℝ l.direction ≤ 1 := by
            exact Nat.le_of_lt_succ (lt_of_le_of_lt this (Nat.lt_succ_self 1))
          exact this))
      exact this.elim id (fun h2 => by
        exfalso
        have : finrank ℝ l.direction = 1 := by
          have : finrank ℝ l.direction ≤ 1 := Nat.le_of_lt_succ (by simpa [h2])
          exact le_antisymm this (Nat.succ_le_iff.mp (Nat.succ_le_of_lt hpos))
        exact (by simpa [this] using h2))
    exact this
  · refine ⟨p₁, p₁, hp₁, hp₁, ?_⟩
    simpa using (l.sOppSide_rfl (p := p₁))
  · intro p hp
    have : Metric.infDist p (l : Set P) = 0 := by
      have : p ∈ (l : Set P) := by
        have : p ∈ (S : Set P) := by simpa using hp
        exact AffineSubspace.subset_span this
      simpa [Metric.infDist_eq_zero] using this
    simp [this]
