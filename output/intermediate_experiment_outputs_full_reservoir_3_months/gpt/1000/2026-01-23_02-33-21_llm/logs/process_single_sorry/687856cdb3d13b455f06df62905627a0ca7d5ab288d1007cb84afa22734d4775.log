theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  classical
  refine ⟨1, by norm_num, ?_⟩
  intro n hn S hcard hpair
  rcases hn with hn
  have hne : S.Nonempty := by
    classical
    by_contra h
    have : S.card = 0 := Finset.card_eq_zero.2 (Finset.not_nonempty_iff_eq_empty.1 h)
    linarith [hcard, this]
  rcases hne with ⟨p₀, hp₀⟩
  refine ⟨(AffineSubspace.span ℝ (Set.singleton p₀)), ?_, ?_, ?_⟩
  · simpa using (by
      have : finrank ℝ (AffineSubspace.span ℝ (Set.singleton p₀)).direction = 0 := by
        simpa using (AffineSubspace.finrank_direction_span_singleton (R := ℝ) (P := P) p₀)
      exact this)
  · refine ⟨p₀, p₀, hp₀, hp₀, ?_⟩
    simpa using (AffineSubspace.sOppSide_self (l := AffineSubspace.span ℝ (Set.singleton p₀)) p₀)
  · intro p hp
    have : Metric.infDist p (AffineSubspace.span ℝ (Set.singleton p₀) : Set P) = 0 := by
      have : p ∈ (AffineSubspace.span ℝ (Set.singleton p₀) : Set P) := by
        exact AffineSubspace.subset_span (by simpa using hp₀)
      simpa [Metric.infDist_eq_zero] using ⟨this, rfl⟩
    simp [this]
