      "\n  classical\n  by_cases hk : k = 0\n  · subst hk\n    have hT : IsEmpty (T 0) := by\n      refine ⟨?_⟩\n      intro t\n      rcases t with ⟨⟨⟨x, y, z⟩, hS⟩, hz⟩\n      have hxpos : 0 < x := hS.2.1\n      have hxle : x ≤ (0 : ℤ) := by\n        have := S_upper_bound (k := 0) (x := x) (y := y) (z := z) hS\n        simpa using this.1\n      exact (not_lt_of_ge hxle hxpos).elim\n    have hU : IsEmpty (U 0) := by\n      refine ⟨?_⟩\n      intro u\n      rcases u with ⟨⟨⟨x, y, z⟩, hS⟩, hu⟩\n      have hxpos : 0 < x := hS.2.1\n      have hxle : x ≤ (0 : ℤ) := by\n        have := S_upper_bound (k := 0) (x := x) (y := y) (z := z) hS\n        simpa using this.1\n      exact (not_lt_of_ge hxle hxpos).elim\n    simpa [Fintype.card_eq_zero] using congrArg (fun (P : Prop) => (by\n      classical\n      exact (by\n        haveI : IsEmpty (U 0) := hU\n        haveI : IsEmpty (T 0) := hT\n        rfl : Fintype.card (U 0) = Fintype.card (T 0)))) True.intro\n  ·\n    let f : U k → T k := fun u =>\n      by\n        rcases u with ⟨s, hsU⟩\n        rcases s with ⟨⟨x, y, z⟩, hsS⟩\n        have hxpos : 0 < x := hsS.2.1\n        have hxle : x ≤ (k : ℤ) := (S_upper_bound (k := k) (x := x) (y := y) (z := z) hsS).1\n        have hkpos : 0 < (k : ℤ) := by\n          have : (0 : ℤ) < (k : ℤ) := by\n            have : 0 < k := Nat.pos_of_ne_zero hk\n            exact Int.ofNat_pos.mpr this\n          simpa using this\n        have : 0 < z := by\n          have hxk : (x : ℤ) ≤ k := hxle\n          have h1 : (x - y) + z ≤ k - 1 + z := by linarith\n          have h2 : 0 < k - 1 + z := lt_of_lt_of_le hsU h1\n          have : 0 < z := by linarith\n          exact this\n        exact ⟨⟨⟨x, y, z⟩, hsS⟩, this⟩\n    let g : T k → U k := fun t =>\n      by\n        rcases t with ⟨s, hsT⟩\n        rcases s with ⟨⟨x, y, z⟩, hsS⟩\n        have : (x - y) + z > 0 := by\n          have hxpos : 0 < x := hsS.2.1\n          have hypos : 0 < y := hsS.2.2\n          have hzpos : z > 0 := hsT\n          linar