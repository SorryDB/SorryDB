      "\n  classical\n  refine Fintype.card_congr ?_\n  refine\n    { toFun := fun u =>\n        ⟨u.1, by\n          rcases u with ⟨⟨⟨x, y, z⟩, hS⟩, hu⟩\n          dsimp [U] at hu\n          simp [T, hu]⟩\n      invFun := fun t =>\n        ⟨t.1, by\n          rcases t with ⟨⟨⟨x, y, z⟩, hS⟩, ht⟩\n          dsimp [T] at ht\n          simp [U]\n          nlinarith⟩\n      left_inv := by\n        rintro ⟨⟨⟨x, y, z⟩, hS⟩, hu⟩\n        rfl\n      right_inv := by\n        rintro ⟨⟨⟨x, y, z⟩, hS⟩, ht⟩\n        rfl }",
      "\n  classical\n  simp [U, T]",
