      have hn1 : (1 : ℝ) ≤ (P.n : ℝ) := by
        have : 1 ≤ P.n := Nat.succ_le_iff.mp (Nat.pos_iff_ne_zero.mp (Nat.ne_of_gt (Nat.pos_of_gt (lt_of_lt_of_le (Nat.mul_pos P.hL_pos P.hL_pos) P.hL.le))))
        exact_mod_cast this
      exact Real.log_nonneg hn1
    have hbal_le : P.initial.balance p ≤ P.M * (Real.log P.n) := by
      have hfac_nonneg : 0 ≤ (P.n.factorial.factorization p : ℤ) := by exact_mod_cast (Nat.zero_le _)
      have hsum_nonneg : 0 ≤ (P.initial.a.map (·.factorization p)).sum := Nat.zero_le _
      unfold Factorization.balance Factorization.sum
      have : (P.initial.a.map (fun m ↦ m.factorization p)).sum - (P.n.factorial.factorization p : ℤ) ≤
          (P.initial.a.map (fun m ↦ m.factorization p)).sum := by omega
      have hsum_le : (P.initial.a.map (fun m ↦ m.factorization p)).sum ≤ (P.initial.a.card : ℕ) * Nat.log p P.n := by
        classical
        have h_each : ∀ m ∈ P.initial.a, m.factorization p ≤ Nat.log p P.n := by
          intro m hm
          by_cases hm0 : m = 0
          · simp [hm0]
          · have hm_le_n : m ≤ P.n := P.initial.ha m hm
            exact (Nat.factorization_le_log_of_le hm0 hm_le_n)
        have := Multiset.sum_le_card_nsmul _ _ (by
          intro m hm
          exact h_each m hm)
        simpa [nsmul_eq_mul] using this
      have hcard_le : (P.initial.a.card : ℝ) ≤ P.n := by
        exact_mod_cast (Params.initial.card P)
      have hlog_le : (Nat.log p P.n : ℝ) ≤ Real.log (P.n : ℝ) := by
        have hp_pos : 1 < p := hprime.one_lt
        have hn_ge : (1 : ℕ) ≤ P.n := by
