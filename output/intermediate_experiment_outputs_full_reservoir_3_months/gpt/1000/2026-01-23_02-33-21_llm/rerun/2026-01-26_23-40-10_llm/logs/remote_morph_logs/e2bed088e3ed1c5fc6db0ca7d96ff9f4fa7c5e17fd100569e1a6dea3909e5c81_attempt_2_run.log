        have hn1 : (1 : ℝ) ≤ (P.n : ℝ) := by exact_mod_cast hn_ge
        have hp_posR : (1 : ℝ) < (p : ℝ) := by exact_mod_cast hp_pos
        have hn_posR : (0 : ℝ) < (P.n : ℝ) := by exact_mod_cast (Nat.pos_of_ge hn_ge)
        have : (Nat.log p P.n : ℝ) ≤ Real.log (P.n : ℝ) / Real.log (p : ℝ) := by
          simpa [Nat.cast_ofNat] using (Nat.cast_log_le_real_log_div_log (p := p) (n := P.n) hp_pos hn_ge)
        have hlogp_pos : 0 < Real.log (p : ℝ) := Real.log_pos hp_posR
        have := (le_div_iff₀ hlogp_pos).1 this
        have : (Nat.log p P.n : ℝ) * Real.log (p : ℝ) ≤ Real.log (P.n : ℝ) := this
        have hlogp_ge1 : (1 : ℝ) ≤ Real.log (p : ℝ) := le_of_lt (lt_of_lt_of_le (by have := Real.log_pos hp_posR; exact this) (le_of_lt (by nlinarith)))
        exact le_trans (le_of_eq (by ring)) (le_trans (mul_le_mul_of_nonneg_left (le_of_lt hlogp_pos) (by positivity)) this)
      have : (P.initial.a.map (fun m ↦ m.factorization p)).sum ≤ (P.M * (Real.log P.n) : ℝ) := by
        have hsum_leR : ((P.initial.a.map (fun m ↦ m.factorization p)).sum : ℝ) ≤
