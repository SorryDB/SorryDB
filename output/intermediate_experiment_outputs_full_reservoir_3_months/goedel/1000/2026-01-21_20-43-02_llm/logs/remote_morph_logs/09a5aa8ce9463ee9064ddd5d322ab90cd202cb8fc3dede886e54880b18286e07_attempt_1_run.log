-/
import Mathlib
set_option linter.unusedVariables false

noncomputable section

namespace ItaLean

/-!
# Filters
-/


section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  have h₁ : f ⁻¹' s ∈ F := by
    exact Filter.mem_map.mp hs
  have h₂ : f ⁻¹' s ∈ G := h h₁
  exact Filter.mem_map.mpr h₂
``` 

