  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;

  let m := max (encode φ) (encode ψ);
  have h_union_subset : ↑(Γ ∪ Δ) ⊆ construction L χ ξ T hT m := by
    have hΓ : ↑Γ ⊆ construction L χ ξ T hT m := by
