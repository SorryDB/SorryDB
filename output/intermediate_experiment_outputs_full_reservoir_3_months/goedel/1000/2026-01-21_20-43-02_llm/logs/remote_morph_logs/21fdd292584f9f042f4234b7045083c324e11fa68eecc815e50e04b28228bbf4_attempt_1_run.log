        _ ⊆ construction L χ ξ T hT m := h₂
    have hΔ : ↑Δ ⊆ construction L χ ξ T hT m := by
      have h₁ : encode ψ ≤ m := by
        simp [m]
        <;> apply le_max_right
      have h₂ : construction L χ ξ T hT (encode ψ) ⊆ construction L χ ξ T hT m := by
        apply monotone_construction
        <;> simp_all
      calc
        ↑Δ ⊆ construction L χ ξ T hT (encode ψ) := hΔ₁
        _ ⊆ construction L χ ξ T hT m := h₂
    have h₃ : ↑(Γ ∪ Δ) = ↑Γ ∪ ↑Δ := by
      simp [Set.coe_union]
    have h₄ : ↑Γ ∪ ↑Δ ⊆ construction L χ ξ T hT m := by
      apply Set.union_subset
      · exact hΓ
      · exact hΔ
