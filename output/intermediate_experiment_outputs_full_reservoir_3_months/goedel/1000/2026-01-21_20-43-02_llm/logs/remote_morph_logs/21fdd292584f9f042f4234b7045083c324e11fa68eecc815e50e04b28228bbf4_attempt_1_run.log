lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra! hC;
  obtain ⟨hφ, hψ⟩ := hC;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφ;
  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;

  let m := max (encode φ) (encode ψ);
  have h : ↑(Γ ∪ Δ) ⊆ (construction T hT m) := by
    have hΓ : ∀ δ ∈ (Γ : Set _), δ ∈ construction T hT m := by
      intro δ hδ
      have : δ ∈ (Γ : Set _) := hδ
      have h₁ : δ ∈ construction T hT (encode φ) := by
        exact hΓ₁ hδ
      have h₂ : encode φ ≤ m := by
        simp [m]
        <;> exact le_max_left _ _
      have h₃ : construction T hT (encode φ) ⊆ construction T hT m := by
        apply subset_construction_add
        <;> simp_all [Nat.add_comm]
        <;> omega
      exact h₃ h₁
    have hΔ : ∀ δ ∈ (Δ : Set _), δ ∈ construction T hT m := by
      intro δ hδ
      have : δ ∈ (Δ : Set _) := hδ
      have h₁ : δ ∈ construction T hT (encode ψ) := by
        exact hΔ₁ hδ
      have h₂ : encode ψ ≤ m := by
        simp [m]
        <;> exact le_max_right _ _
      have h₃ : construction T hT (encode ψ) ⊆ construction T hT m := by
        apply subset_construction_add
        <;> simp_all [Nat.add_comm]
        <;> omega
      exact h₃ h₁
    have h₄ : ↑(Γ ∪ Δ) ⊆ (construction T hT m) := by
      intro δ hδ
      simp only [Set.mem_union, Finset.mem_coe] at hδ
      cases hδ with
      | inl hδ =>
        exact hΓ δ hδ
      | inr hδ =>
        exact hΔ δ hδ
    exact h₄
  sorry;
