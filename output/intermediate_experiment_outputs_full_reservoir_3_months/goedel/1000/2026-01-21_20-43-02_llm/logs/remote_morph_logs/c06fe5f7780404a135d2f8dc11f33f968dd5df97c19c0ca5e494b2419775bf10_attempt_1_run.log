      <;> try simp_all [h₁]
      <;> try simp_all [K.call]
      <;> try simp_all [h₁]
      <;> try simp_all [K.call]

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ◁ x = K ◁ y) :
        (x = y) := by
      have h₁ := K.call x y
      have h₂ := K.call y x
      have h₃ := K.call x x
      have h₄ := K.call y y
