theorem kestrel_fondness
    (x : Bird)
    (fond_Kx : K is fond of (K ◁ x)) :
    K is fond of x := by
  have h₁ : K ◁ (K ◁ x) = K ◁ x := fond_Kx
  have h₂ : ∀ (y : Bird), (K ◁ x) ◁ y = x := by
    intro y
    have h₃ := K.call x y
    have h₄ := K.call (K ◁ x) y
    simp [response] at h₃ h₄ ⊢
    <;>
    (try simp_all [Kestrel.K.call]) <;>
    (try aesop) <;>
    (try simp_all [Kestrel.K]) <;>
    (try aesop)
  have h₃ := h₂ x
  have h₄ := h₂ (K ◁ x)
  simp [response] at h₃ h₄ ⊢
  <;>
  (try simp_all [Kestrel.K.call]) <;>
  (try aesop) <;>
  (try simp_all [Kestrel.K]) <;>
  (try aesop)
