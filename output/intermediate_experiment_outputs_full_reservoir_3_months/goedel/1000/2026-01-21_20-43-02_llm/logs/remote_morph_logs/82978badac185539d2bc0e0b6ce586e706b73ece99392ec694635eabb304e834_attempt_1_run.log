  <;>
  (try
    norm_num)
  <;>
  (try
    simp_all [List.all_iff_forall])
  <;>
  (try
    aesop)
  <;>
  (try
    simp_all [Nat.beq_eq, Nat.lt_succ_iff])
  <;>
  (try
    aesop)

