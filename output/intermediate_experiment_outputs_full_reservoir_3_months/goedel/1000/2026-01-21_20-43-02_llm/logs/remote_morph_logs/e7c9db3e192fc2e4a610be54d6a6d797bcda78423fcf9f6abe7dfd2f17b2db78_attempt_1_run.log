      exact hx
    have h7 : f x ∈ B := by
      rw [h2] at h6
      exact h6
    have h8 : f x ≠ b := by
      intro h9
      have h10 : f x = f a := by rw [h4] at *; exact h9
      have h11 : x = a := by
        apply h1
        <;> aesop
      contradiction
    exact ⟨h7, h8⟩
  
  have h6 : ∀ (y : V), y ∈ B → y ≠ b → ∃ (x : U), x ∈ A ∧ x ≠ a ∧ f x = y := by
    intro y hy hyb
    have h7 : y ∈ image f A := by
      rw [h2] at *
      exact hy
    obtain ⟨x, hx, hxy⟩ := h7
    have h8 : x ∈ A := hx
