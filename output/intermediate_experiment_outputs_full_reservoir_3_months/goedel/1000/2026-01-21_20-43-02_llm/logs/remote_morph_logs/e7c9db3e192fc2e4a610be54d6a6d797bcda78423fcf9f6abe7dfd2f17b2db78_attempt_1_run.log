  have h7 : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
    -- Step 1: Define the function from A \ {a} to B \ {b}
    let F : {x : U // x ∈ A ∧ x ≠ a} → {y : V // y ∈ B ∧ y ≠ b} := fun ⟨x, hx⟩ =>
