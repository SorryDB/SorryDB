          simpa [Set.mem_image] using h24
        obtain ⟨x, hx, hx'⟩ := h31
        have h32 : x ∈ A := by
          simp only [Set.mem_diff, Set.mem_singleton_iff] at hx
          exact hx.1
        have h33 : x ≠ a := by
          simp only [Set.mem_diff, Set.mem_singleton_iff] at hx
          intro h34
          apply hx.2
          simp [h34]
        have h34 : f x = b := by simp_all
        have h35 : f x = f a := by simp_all
        have h36 : x = a := by
          have h37 := h1
          have h38 : x ∈ A := h32
          have h39 : a ∈ A := h3
          have h40 : f x = f a := by simp_all
          have h41 : x = a := by
            apply h37
            <;> simp_all [Set.mem_singleton_iff]
            <;> aesop
          exact h41
