      intro x hx y hy hxy
      have h14 : x ∈ A := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at hx
        exact hx.1
      have h15 : y ∈ A := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at hy
        exact hy.1
      have h16 : x ∈ A \ {a} := hx
      have h17 : y ∈ A \ {a} := hy
      have h18 : f x = f y := hxy
      have h19 : x ≠ a := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at h16
        intro h20
        apply h16.2
        simp [h20]
      have h20 : y ≠ a := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at h17
        intro h21
        apply h17.2
        simp [h21]
      have h21 : x = y := by
        apply h1
        <;> simp_all [Set.mem_diff, Set.mem_singleton_iff]
        <;> aesop
      exact h21
    -- Use the fact that f is injective on A \ {a} to show that it is a bijection between A \ {a} and image f (A \ {a})
    have h22 : ↑(A \ {a}) ∼ ↑(image f (A \ {a})) := by
      let g : (A \ {a}) → (image f (A \ {a})) := fun x => ⟨f x.val, by
        -- Show that f x.val is in the image of f
