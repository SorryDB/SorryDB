  have h5 : a ∈ A := h3
  have h6 : f a = b := h4
  have h7 : one_one_on f A := h1
  have h8 : image f A = B := h2
  have h9 : a ∈ A := h3
  have h10 : f a ∈ image f A := by
    apply Set.mem_image_of_mem
    exact h9
  have h11 : b ∈ B := by
    rw [h8] at h10
    simpa [h6] using h10
