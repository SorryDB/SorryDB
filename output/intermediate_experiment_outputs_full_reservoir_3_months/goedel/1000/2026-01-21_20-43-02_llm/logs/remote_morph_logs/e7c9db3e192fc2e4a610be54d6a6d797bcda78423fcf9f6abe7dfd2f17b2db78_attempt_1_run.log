          <;> aesop
        · -- Show that g ⟨v, _⟩ = ⟨f v, _⟩
          simp_all [Subtype.ext_iff]
          <;> aesop
      -- Since g is a bijection, we have A \ {a} ∼ image f (A \ {a})
      exact ⟨g, h25, h30⟩
    exact h22
