        have h28 : y.val ∈ A \ {a} := y.prop
        have h29 : x.val = y.val := by
          apply h13
          <;> simp_all [Set.mem_diff, Set.mem_singleton_iff]
          <;> aesop
        simp_all [Subtype.ext_iff]
        <;> aesop
      have h30 : Function.Surjective g := by
