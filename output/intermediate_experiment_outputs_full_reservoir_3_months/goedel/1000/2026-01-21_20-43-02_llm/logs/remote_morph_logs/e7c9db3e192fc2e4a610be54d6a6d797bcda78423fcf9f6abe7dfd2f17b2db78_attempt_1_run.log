      have h37 : y ∈ B \ {b} := by
        simp_all [Set.mem_singleton_iff]
        <;> aesop
      exact h37
    · -- Show that B \ {b} ⊆ image f (A \ {a})
      intro y hy
      have h24 : y ∈ B := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at hy
        exact hy.1
      have h25 : y ∈ image f A := by
        rw [h8] at *
        exact h24
      have h26 : y ≠ b := by
        simp only [Set.mem_diff, Set.mem_singleton_iff] at hy
        exact hy.2
      have h27 : ∃ (x : U), x ∈ A ∧ f x = y := by
        simpa [Set.mem_image] using h25
      obtain ⟨x, hx, hx'⟩ := h27
      by_cases h28 : x = a
