instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where

  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := by
    intro a b
    cases a with
    | mk d e f =>
      cases b with
      | mk d' e' f' =>
        dsimp [id, comp]
        <;> simp_all [F.map_id, G.map_id, id_comp]
        <;> congr 1 <;> ext <;> simp_all [F.map_id, G.map_id, id_comp]
        <;> simp_all [Category.assoc]
        <;> rfl

  comp_id := by
    intro a b
    cases a with
    | mk d e f =>
      cases b with
      | mk d' e' f' =>
        dsimp [id, comp]
        <;> simp_all [F.map_id, G.map_id, comp_id]
        <;> congr 1 <;> ext <;> simp_all [F.map_id, G.map_id, comp_id]
        <;> simp_all [Category.assoc]
        <;> rfl

  assoc := by
    intro a b c d
    cases a with
    | mk d₁ e₁ f₁ =>
      cases b with
      | mk d₂ e₂ f₂ =>
        cases c with
        | mk d₃ e₃ f₃ =>
          cases d with
          | mk d₄ e₄ f₄ =>
            dsimp [comp] at *
            <;> simp_all [Category.assoc]
            <;> congr 1 <;> ext <;> simp_all [Category.assoc]
            <;> simp_all [F.map_comp, G.map_comp]
            <;> simp_all [Category.assoc]
            <;> rfl

