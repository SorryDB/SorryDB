theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  -- We need to find a monotone function f : α → β that coincides with F.F on all x : α.
  -- Since F is a functor, it already provides a function F.F : α → β.
  -- We will show that F.F is monotone and trivially coincides with itself.
  refine' ⟨F.F, ⟨fun a b h => _, fun x => rfl⟩⟩
  -- To show that F.F is monotone, we need to prove that if a ≤ b, then F.F a ≤ F.F b.
  -- We use the fact that F is a functor and the properties of the preorder.
  have h₁ : (PLift.mk h : (α := α) ≤ (β := α)) = (PLift.mk h : (α := α) ≤ (β := α)) := rfl
  -- Since F is a functor, it maps the morphism (a ≤ b) to a morphism (F.F a ≤ F.F b).
  -- In the category of preorders, the hom set is the set of order relations.
  -- Therefore, F.homF (a ≤ b) is an order relation between F.F a and F.F b.
  -- However, since F.homF (a ≤ b) is a morphism in the category of preorders,
  -- it must satisfy F.F a ≤ F.F b.
  -- This is because the only morphisms in the category of preorders are the order relations.
  -- Therefore, F.F a ≤ F.F b.
  have h₂ : (F.homF (PLift.mk h) : (α := β) ≤ (β := β)) = (F.homF (PLift.mk h) : (α := β) ≤ (β := β)) := rfl
  -- Simplify the expression to get F.F a ≤ F.F b.
  simp [Category.Hom] at h₁ h₂ ⊢
  <;>
  (try cases' F.homF (PLift.mk h) with x hx) <;>
  (try simp_all [PLift.mk.injEq]) <;>
  (try exact hx) <;>
  (try aesop)
