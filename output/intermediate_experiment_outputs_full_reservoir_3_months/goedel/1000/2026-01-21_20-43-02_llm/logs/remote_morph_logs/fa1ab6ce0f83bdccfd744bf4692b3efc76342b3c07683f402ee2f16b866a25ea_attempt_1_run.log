def WithOne (W : Type*) : Type* := Option W

variable {W : Type*}
variable [Semigroup W]
variable [One W]

class Magma (H : Type u → Type u → Type u) : Prop :=

class MagmaOne (H : Type u → Type u → Type u) : Prop :=

