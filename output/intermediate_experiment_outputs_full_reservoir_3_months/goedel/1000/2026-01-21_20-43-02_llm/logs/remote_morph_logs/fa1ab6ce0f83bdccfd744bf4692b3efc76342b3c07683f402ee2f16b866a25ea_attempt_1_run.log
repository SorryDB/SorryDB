lemma Preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  use F.F
  refine' ⟨_, _⟩
  · -- Prove that F.F is monotone
    intro x y h
    have h1 : F.F x = F.F x := rfl
    have h2 : F.F y = F.F y := rfl
    have h3 : (PLift.mk h : (α : Type*) ⊢ : Type*) = (PLift.mk h : (α : Type*) ⊢ : Type*) := rfl
    have h4 : (PLift.mk h : (α : Type*) ⊢ : Type*) = (PLift.mk h : (α : Type*) ⊢ : Type*) := rfl
    -- Use the fact that F is a functor to show monotonicity
    have h5 : (F.homF (⟨h, by simp⟩ : α ⊢ α)) : β ⊢ β = (F.homF (⟨h, by simp⟩ : α ⊢ α)) : β ⊢ β := rfl
    -- Simplify the expression using the properties of the preorder category
    have h6 : (F.homF (⟨h, by simp⟩ : α ⊢ α)) : β ⊢ β = (F.homF (⟨h, by simp⟩ : α ⊢ α)) : β ⊢ β := rfl
    -- Use the fact that the homomorphism preserves the order
    have h7 : (F.homF (⟨h, by simp⟩ : α ⊢ α)).down : F.F x ≤ F.F y := by
      -- Extract the underlying proof from the PLift
      have h8 : (F.homF (⟨h, by simp⟩ : α ⊢ α)).down : F.F x ≤ F.F y := by
        simpa [Category.comp] using (F.map_comp (⟨h, by simp⟩ : α ⊢ α) (id (y : α))).down
      exact h8
    -- Convert the proof back to the preorder
    exact h7
  · -- Prove that F.F is the underlying function of F
    intro x
    rfl
```

