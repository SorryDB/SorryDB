instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where

  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    have h₁ : F.homF (f.1 ≫ f'.1) = F.homF f.1 ≫ F.homF f'.1 := by
      rw [F.map_comp]
    have h₂ : G.homF (f.2 ≫ f'.2) = G.homF f.2 ≫ G.homF f'.2 := by
      rw [G.map_comp]
    have h₃ : F.homF f'.1 ≫ f' = f ≫ G.homF f'.2 := by
      exact hf'
    have h₄ : F.homF f.1 ≫ f'.1 = f ≫ G.homF f.2 := by
      exact hf
    calc
      (F.homF (f.1 ≫ f'.1)) ≫ f' = (F.homF f.1 ≫ F.homF f'.1) ≫ f' := by rw [h₁]
      _ = F.homF f.1 ≫ (F.homF f'.1 ≫ f') := by rw [assoc]
      _ = F.homF f.1 ≫ (f ≫ G.homF f'.2) := by rw [h₃]
      _ = (F.homF f.1 ≫ f) ≫ G.homF f'.2 := by rw [← assoc]
      _ = (f ≫ G.homF f.2) ≫ G.homF f'.2 := by rw [h₄]
      _ = f ≫ (G.homF f.2 ≫ G.homF f'.2) := by rw [assoc]
      _ = f ≫ G.homF (f.2 ≫ f'.2) := by rw [h₂]
  ⟩

  id_comp := fun a b => by
    cases a <;> cases b <;> simp_all [id_comp, comp_id]
    <;> try simp_all [F.map_id, F.map_comp]
    <;> try simp_all [G.map_id, G.map_comp]
    <;> try simp_all [Category.assoc]
    <;> try simp_all [id_comp, comp_id]

  comp_id := fun a b => by
    cases a <;> cases b <;> simp_all [id_comp, comp_id]
    <;> try simp_all [F.map_id, F.map_comp]
    <;> try simp_all [G.map_id, G.map_comp]
    <;> try simp_all [Category.assoc]
    <;> try simp_all [id_comp, comp_id]

  assoc := fun a b c d => by
    cases a <;> cases b <;> cases c <;> cases d <;> simp_all [id_comp, comp_id]
    <;> try simp_all [F.map_id, F.map_comp]
    <;> try simp_all [G.map_id, G.map_comp]
    <;> try simp_all [Category.assoc]
    <;> try simp_all [id_comp, comp_id]
    <;> try simp_all [assoc]

def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) D where
  F := fun ⟨X, _, _⟩ => X
  homF := fun ⟨hk, _⟩ => hk.1
  map_id X := by
    simp [id, prod.ext_iff]
    <;> aesop
``` 

