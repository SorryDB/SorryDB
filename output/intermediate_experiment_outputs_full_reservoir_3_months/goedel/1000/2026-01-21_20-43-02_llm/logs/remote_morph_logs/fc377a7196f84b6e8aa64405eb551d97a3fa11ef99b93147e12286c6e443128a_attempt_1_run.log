    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨r, hr⟩ := r
      rw [Valuation.mem_integer_iff] at hr ⊢
      have h₁ : (valuation K).map (algebraMap K L) r ≤ 1 := by
        have h₂ : (valuation L).map (algebraMap K L) r ≤ (valuation K).map (algebraMap K L) r := by
          exact (valuation L).map_algebraMap_le (valuation K)
        have h₃ : (valuation>L>.map (algebraMap K L) r ≤ 1 := by
