instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      -- Prove that the image of r under algebraMap K L is in the integer ring of L
      have h : valuation L (algebraMap K L (r : K)) ≤ 0 := by
        -- Use the fact that the valuation is non-negative for r in 𝒪[K]
        have h₁ : valuation K (r : K) ≥ 0 := by
          -- Since r is in 𝒪[K], its valuation is non-negative
          have h₂ : (r : K) ∈ (valuation K).integer := by exact r.2
          simp [Valuation.mem_integer] at h₂ ⊢
          <;> linarith
        -- Use the compatibility of valuations to transfer the inequality
        have h₃ : (valuation K).rel (valuation L) := (inferInstance : ValuativeExtension K L).compat
        have h₄ : valuation K (r : K) ≤ valuation L (algebraMap K L (r : K)) := by
          -- Apply the compatibility condition
          have h₅ : (valuation K).rel (valuation L) := (inferInstance : ValuativeExtension K L).compat
          exact h₅.le_map (r : K)
        -- Combine the inequalities to get the desired result
        have h₆ : valuation L (algebraMap K L (r : K)) ≥ 0 := by
          linarith
        -- The valuation is non-negative, so it is ≤ 0 if and only if it is 0
        have h₇ : valuation L (algebraMap K L (r : K)) ≤ 0 := by
          by_contra h₈
          -- If the valuation is positive, then it contradicts the non-negativity of the original valuation
          have h₉ : valuation L (algebraMap K L (r : K)) > 0 := by linarith
          have h₁₀ : valuation K (r : K) > 0 := by
            have h₁₁ : (valuation K).rel (valuation L) := (inferInstance : ValuativeExtension K L).compat
            have h₁₂ : valuation K (r : K) < valuation L (algebraMap K L (r : K)) := by
              -- Use the strict monotonicity of the valuation map
              have h₁₃ := h₁₁.lt_iff_lt.mpr (by simpa using h₉)
              linarith
            linarith
          have h₁₄ : (r : K) ∈ (valuation K).integer := by exact r.2
          simp [Valuation.mem_integer] at h₁₄ ⊢
          <;> linarith
        exact h₇
      -- Use the fact that the valuation is non-positive to show that the element is in 𝒪[L]
      have h₁ : valuation L (algebraMap K L (r : K)) ≥ 0 := by
        -- Since the valuation is non-negative for all elements in L
        have h₂ : valuation L (algebraMap K L (r : K)) ≥ 0 := by
          by_contra h₃
          have h₄ : valuation L (algebraMap K L (r : K)) < 0 := by linarith
          have h₅ : valuation L (algebraMap K L (r : K)) ≤ 0 := by linarith
          have h₆ : valuation L (algebraMap K L (r : K)) < 0 := by linarith
          -- This leads to a contradiction because the valuation cannot be negative
          simp_all [Valuation.mem_integer]
          <;>
          (try norm_num) <;>
          (try linarith) <;>
          (try simp_all [Valuation.mem_integer]) <;>
          (try nlinarith)
        exact h₂
      -- Combine the inequalities to show that the valuation is 0
      have h₂ : valuation L (algebraMap K L (r : K)) = 0 := by
        linarith
      -- Since the valuation is 0, the element is in 𝒪[L]
      simp [Valuation.mem_integer, h₂]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try simp_all [Valuation.mem_integer]) <;>
      (try nlinarith)
    ⟩
    map_add' := by
      intro r s
      rfl
    map_one' := by
      rfl
    map_mul' := by
      intro r s
      rfl
    map_zero' := by
      rfl
  }
  commutes' := by
    intros
    <;> simp_all [Algebra.algebraMap_eq_smul_one]
    <;> ring_nf
    <;> simp_all [smul_smul]
    <;> norm_num
