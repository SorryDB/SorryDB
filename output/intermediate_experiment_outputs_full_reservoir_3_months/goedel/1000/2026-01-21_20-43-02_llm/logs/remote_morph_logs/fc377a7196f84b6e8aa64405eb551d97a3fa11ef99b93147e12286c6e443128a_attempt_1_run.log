theorem r_liminf_le_r {U : Type u} [UniformSpace U] [METRIC U]
    {u : ℕ → U} {r : ℕ → ℝ} (hr : ∀ n, 0 ≤ r n)
    (h : ∀ n, dist_uu u ≤ r n) :
    r_liminf r ≥ 0 := by
  have : r_liminf r ≥ 0 := by
    refine' le_of_not_lt _
    intro h₁
    have h₂ := Metric.tendsto_atTop_nhds_iff.mp (Metric.tendsto_of_mem 𝓝 r)
    have h₃ := Metric.tendsto_atTop_nhds_iff.mp (Metric.tendsto_of_mem 𝓝 r)
    have h₄ : ∃ (ε : ℝ), ε > 0 ∧ ∀ᶠ (n : ℕ) in atTop, r n < r_liminf r + ε := by
      have h₅ : (𝓝 r_liminf r).mem_nhds (r_liminf r) := by exact Hausdorff.mem_nhds _
      have h₆ : ∃ (ε : ℝ), ε > 0 ∧ ∀ᶠ (n : ℕ) in atTop, r n ∈ Metric.ball (r_liminf r) ε := by
        have h₇ := Metric.eventually_nhds_iff.mp h₅
        -- Use the fact that the limit inferior is less than r_n for sufficiently large n
        obtain ⟨ε, hε, hε'⟩ := h₇
        exact ⟨ε, hε, hε'⟩
      obtain ⟨ε, hε, hε'⟩ := h₆
      refine' ⟨ε/2, by linarith, _⟩
      filter_upwards [hε'] with n hn using by
        have h₈ : dist (r n) (r_liminf r) < ε := by simpa [Metric.ball] using hn
        have h₉ : r n < r_liminf r + ε := by
          linarith [Real.dist_eq.mp h₈]
        linarith
    obtain ⟨ε, hε, hε'⟩ := h₄
    have h₅ : ∀ᶠ (n : ℕ) in atTop, r n < r_liminf r + ε := hε'
    have h₆ : ∃ (N : ℕ), ∀ (n : ℕ), n ≥ N → r n < r_liminf r + ε := by
      simp only [Filter.eventually_atTop] at h₅
      obtain ⟨N, hN⟩ := h₅
      exact ⟨N, hN⟩
    obtain ⟨N, hN⟩ := h₆
    have h₇ : ∀ (n : ℕ), n ≥ N → dist_uu u ≤ r n := by
      intro n hn
      exact h n
    have h₈ : dist_uu u ≤ r_liminf r + ε := by
      by_contra h₈
      have h₉ : r_liminf r + ε < dist_uu u := by linarith
      have h₁₀ : ∀ᶠ (n : ℕ) in atTop, r n < r_liminf r + ε := h₅
      have h₁₁ : ∀ᶠ (n : ℕ) in atTop, r n < dist_uu u := by
        filter_upwards [h₁₀] with n hn using by linarith
      have h₁₂ : ∃ (N : ℕ), ∀ (n : ℕ), n ≥ N → r n < dist_uu u := by
        simp only [Filter.eventually_atTop] at h₁₁
        obtain ⟨N, hN⟩ := h₁₁
        exact ⟨N, hN⟩
      obtain ⟨M, hM⟩ := h₁₂
      have h₁₃ : ∃ (n : ℕ), n ≥ M ∧ n ≥ N := by
        use max M N
        <;> simp [le_max_left, le_max_right]
      obtain ⟨n, hnM, hnN⟩ := h₁₃
      have h₁₄ : r n < dist_uu u := hM n hnM
      have h₁₅ : dist_uu u ≤ r n := h n
      linarith
    linarith [Metric.tendsto_atTop_nhds_iff.mp (Metric.tendsto_of_mem 𝓝 r)]
  exact this
