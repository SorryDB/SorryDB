    have h₄ : ∀ (i : ℕ), ∃ (j : ℕ), ∀ᵐ (ω : Ω) ∂μ, ‖(fun i => stoppedValue X (τ i) ω) i‖ ≤ ‖(fun i => stoppedValue X (τ i) ω) j‖ := h₂
    have h₅ : ∀ (i : ℕ), AEStronglyMeasurable (fun ω => stoppedValue X (τ i) ω) μ := h₁
    have h₆ : ∃ (Y : ℕ → Ω → ℝ), UniformIntegrable Y 1 μ ∧ ∀ (i : ℕ), ∃ (j : ℕ), ∀ᵐ (ω : Ω) ∂μ, ‖(fun ω => stoppedValue X (τ i) ω) ω‖ ≤ ‖Y j ω‖ := by
