lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓝 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓝]
    (hX : Submartingale X 𝓝 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓝 (τ i))
