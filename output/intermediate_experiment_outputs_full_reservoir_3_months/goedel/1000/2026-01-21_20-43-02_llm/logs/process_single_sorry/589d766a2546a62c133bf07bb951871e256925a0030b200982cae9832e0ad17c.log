theorem OMR_problem_46757 (G : Type*) [Group G] [DecidableRel ((· < ·) : G → G → Prop)] (a b c : G) (hab : a < b) (hca : c < a) : c < b := by
  have h : c < b := by
    -- Use the transitivity of the order relation to combine the inequalities c < a and a < b
    have h₁ : c < a := hca
    have h₂ : a < b := hab
    -- Apply the transitivity property to get c < b
    exact lt_trans h₁ h₂
  -- The result follows directly from the established inequality
  exact h
