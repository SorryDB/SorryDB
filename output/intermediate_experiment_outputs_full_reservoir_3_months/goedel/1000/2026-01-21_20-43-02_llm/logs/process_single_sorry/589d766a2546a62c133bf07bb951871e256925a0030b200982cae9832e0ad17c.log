  ∀ (L2 : Type*) {α : Type*} (afunc : (List (α × L2)) → (α × L2) → List (α × L2)) (l1 : List (α × L2)) (l2 : List (α × L2)) (index₁ : L2) (h : (∀ (a : α × L2) (l1 : List (α × L2)) (l2 : List (α × L2)), List.foldl afunc l1 l2 = List.foldl afunc (afunc l1 a) l2)),
  ((List.foldl afunc [] l2 = []) ↔ (∀ (a : α × L2), a ∈ l2 → a.2 ≠ index₁)) := by
  intro L2 α afunc l1 l2 index₁ h
  have h₁ : (∀ (a : α × L2) (l1 : List (α × L2)) (l2 : List (α × L2)), List.foldl afunc l1 (a :: l2) = List.foldl afunc (afunc l1 a) l2) := by
    intro a l1 l2
    have h₂ := h a l1 l2
    simp [List.foldl] at h₂ ⊢
    <;> aesop
  have h₂ : (∀ (l1 : List (α × L2)) (l2 : List (α × L2)), List.foldl afunc l1 l2 = List.foldl (fun l1 a => List.foldl afunc l1 [a]) l1 l2) := by
    intro l1 l2
    induction l2 with
    | nil => simp [List.foldl]
    | cons a as ih =>
      simp_all [List.foldl, h₁]
      <;>
      (try simp_all) <;>
      (try aesop) <;>
      (try ring_nf at * <;> aesop)
  have h₃ : (List.foldl afunc [] l2 = []) ↔ (∀ (a : α × L2), a ∈ l2 → a.2 ≠ index₁) := by
    have h₄ := h₂ [] l2
    have h₅ := h₂ [] []
    simp at h₄ h₅
