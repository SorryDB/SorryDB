          |y - x| < min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) := h₄
          _ ≤ 1 := h₂
    have h₆ : |y - x| < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
        calc
          |y - x| < min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) := h₄
          _ ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := h₃
    have h₇ : |y ^ 3 - x ^ 3| < ε := by
        have h₈ : y ^ 3 - x ^ 3 = (y - x) * (x ^ 2 + x * y + y ^ 2) := by ring
        rw [h₈]
        have h₉ : |(y - x) * (x ^ 2 + x * y + y ^ 2)| = |y - x| * |x ^ 2 + x * y + y ^ 2| := by
