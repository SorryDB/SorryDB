      "\n  have h₁ : |y - x| < δ := hy\n  have h₂ : δ ≤ 1 := δle1\n  have h₃ : |y - x| < 1 := by linarith\n  have h₄ : -1 < y - x := by linarith [abs_lt.mp h₃]\n  have h₅ : y - x < 1 := by linarith [abs_lt.mp h₃]\n  have h₆ : y < x + 1 := by linarith\n  have h₇ : x - 1 < y := by linarith\n  have h₈ : |x| + 1 - |y| ≥ 0 := by\n    cases' abs_cases x with hx₁ hx₁ <;> cases' abs_cases y with hy₁ hy₁ <;>\n      (try { nlinarith }) <;>\n      (try {\n        cases' le_or_lt 0 (x - y) with h h <;>\n          cases' le_or_lt 0 (y - x) with h' h' <;>\n            nlinarith\n      }) <;>\n      nlinarith\n  have h₉ : |y| ≤ |x| + 1 := by\n    linarith\n  exact h₉",
      "\n  have h1 : |y - x| < 1 := by linarith [δle1, hy]\n  have h2 : |y| ≤ |x| + |y - x| := by\n    calc\n      |y| = |x + (y - x)| := by ring_nf\n      _ ≤ |x| + |y - x| := abs_add x (y - x)\n  -- Now, use that |y - x| < 1 to get |x| + |y - x| < |x| + 1\n  -- and thus |y| ≤ |x| + 1 because |y| ≤ |x| + |y - x|\n  linarith",
      "\n    calc\n      |y| = |y - x + x| := by ring_nf\n      _ ≤ |y - x| + |x| := abs_add (y - x) x\n      _ < δ + |x| := by\n        have h₁ : |y - x| < δ := hy\n        linarith\n      _ ≤ 1 + |x| := by\n        have h₂ : δ ≤ 1 := δle1\n        linarith\n      _ = |x| + 1 := by ring\n  sorry",
      "ℝ)",
      "\n            cases' le_total 0 (x ^ 2 + x * y + y ^ 2) with h h <;>\n              cases' le_total 0 x with hx hx <;>\n                cases' le_total 0 y with hy hy <;>\n                  simp_all [abs_of_nonneg, abs_of_nonpos, add_nonneg, add_nonpos, mul_comm, mul_assoc, mul_left_comm] <;>\n                    nlinarith [sq_nonneg (x + y), sq_nonneg (x - y), sq_nonneg (x + y + 1), sq_nonneg (x + y - 1)]\n        have h₁₁ : |y - x| * |x ^ 2 + x * y + y ^ 2| < ε := by\n            calc\n              |y - x| * |x ^ 2 + x * y + y ^ 2| ≤ |y - x| * (3 * |x| ^ 2 + 3 * |x| + 1) := by\n                gcongr <;> simp_all [abs_of_nonneg, abs_of_nonpos]\n              _ < (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) * (3 * |x| ^ 2 + 3 * |x| + 1) := by\n                gcongr\n                <;>\n                  (try norm_num) <;>\n                  (try simp_all [abs_of_nonneg, abs_of_nonpos]) <;>\n                  (try linarith)\n              _ = ε := by\n                have h₁₂ : 3 * |x| ^ 2 + 3 * |x| + 1 > 0 := by\n                  nlinarith [abs_nonneg x, sq_nonneg (|x| + 1)]\n                field_simp [h₁₂.ne']\n                <;>\n                  ring_nf <;>\n                  linarith\n        linarith\n    exact h₇",
      "\n  calc\n    |y| = |(y - x) + x| := by ring_nf\n    _ ≤ |y - x| + |x| := abs_add (y - x) x\n    _ < 1 + |x| := by\n      have h₁ : |y - x| < 1 := by\n        calc\n          |y - x| < δ := hy\n          _ ≤ 1 := δle1\n      linarith\n    _ = |x| + 1 := by ring\n    _ ≤ |x| + 1 := le_refl _\nhave h₂ : |y - x| < 1 := by\n  calc\n    |y - x| < δ := hy\n    _ ≤ 1 := δle1\nhave h₃ : 0 ≤ |x| := abs_nonneg x\nhave h₄ : 0 ≤ |y| := abs_nonneg y\nhave h₅ : |x ^ 2 + x * y + y ^ 2| ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by\n  have h₅₁ : |x ^ 2 + x * y + y ^ 2| ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by\n    cases' le_total 0 (x ^ 2 + x * y + y ^ 2) with h h <;>\n      cases' le_total 0 x with hx hx <;>\n        cases' le_total 0 y with hy hy <;>\n          simp_all [abs_of_nonneg, abs_of_nonpos, abs_mul, abs_of_nonneg, abs_of_nonpos,\n            mul_comm, mul_assoc, mul_left_comm] <;>\n          (try { nlinarith [sq_nonneg (x + y), sq_nonneg (x - y)] }) <;>\n          (try {\n            nlinarith [sq_nonneg (x + y), sq_nonneg (x - y), hy', h₂, h₃, h₄]\n          }) <;>\n          (try {\n            cases' le_total 0 (x - y) with hxy hxy <;>\n              cases' le_total 0 (x + y) with hxy' hxy' <;>\n                simp_all [abs_of_nonneg, abs_of_nonpos, abs_mul, abs_of_nonneg, abs_of_nonpos,\n                  mul_comm, mul_assoc, mul_left_comm] <;>\n                nlinarith [sq_nonneg (x + y), sq_nonneg (x - y), hy', h₂, h₃, h₄]\n          })\n  exact h₅₁\ncalc\n  |y - x| * |x ^ 2 + x * y + y ^ 2| < δ * (3 * |x| ^ 2 + 3 * |x| + 1) := by\n    gcongr <;> nlinarith [abs_nonneg (x ^ 2 + x * y + y ^ 2)]\n  _ ≤ (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) * (3 * |x| ^ 2 + 3 * |x| + 1) := by\n    gcongr\n    <;>\n    (try { linarith }) <;>\n    (try { nlinarith }) <;>\n    (try { positivity })\n  _ = ε := by\n    have h₅ : 0 < 3 * |x| ^ 2 + 3 * |x| + 1 := by\n      nlinarith [abs_nonneg x, sq_nonneg (|x| + 1)]\n    field_simp [h₅.ne']\n    <;> ring_nf\n    <;> field_simp [h₅.ne']\n    <;> nlinarith",
