theorem funcont_cube : FunCont (fun x : ℝ => x ^ 3) := by
  intro x ε hε
  have h₁ : ε / (3 * |x| ^ 2 + 3 * |x| + 1) > 0 := by positivity
  let δ := min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1))
  have h₂ : δ ≤ 1 := by
    apply min_le_left
  have h₃ : δ ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
    apply min_le_right
  have h₄ : 0 < δ := by
    have h₄₁ : 0 < 1 := by norm_num
    have h₄₂ : 0 < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by positivity
    have h₄₃ : 0 < min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) := by
      apply lt_min
      · norm_num
      · positivity
    simpa [δ] using h₄₃
  use δ, h₄
  intro y hy
  have h₅ : |y - x| < δ := hy
  have h₆ : |y^3 - x^3| < ε := by
    have h₆₁ : |y^3 - x^3| = |(y - x) * (x ^ 2 + x * y + y ^ 2)| := by
      calc
        |y^3 - x^3| = |(y - x) * (x ^ 2 + x * y + y ^ 2)| := by
          ring_nf
          <;> simp [abs_mul, abs_of_nonneg, abs_of_nonpos, sub_nonneg, sub_nonpos]
          <;> ring_nf
          <;> linarith
        _ = |(y - x) * (x ^ 2 + x * y + y ^ 2)| := by rfl
    rw [h₆₁]
    have h₆₂ : |(y - x) * (x ^ 2 + x * y + y ^ 2)| = |y - x| * |x ^ 2 + x * y + y ^ 2| := by
      rw [abs_mul]
    rw [h₆₂]
    have h₆₃ : |y - x| < δ := h₅
    have h₆₄ : |y - x| < 1 := by
      linarith [h₂]
    have h₆₅ : |y - x| < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
      linarith [h₃]
    have h₆₆ : |x ^ 2 + x * y + y ^ 2| ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by
      -- Prove that |x² + xy + y²| ≤ 3|x|² + 3|x| + 1 using the fact that |y - x| < 1
      cases' le_total 0 (x ^ 2 + x * y + y ^ 2) with h₆₆₁ h₆₆₁ <;>
        cases' le_total 0 x with h₆₆₂ h₆₆₂ <;>
          cases' le_total 0 y with h₆₆₃ h₆₆₃ <;>
            simp_all only [abs_of_nonneg, abs_of_nonpos, sub_nonneg, sub_nonpos] <;>
              (try { nlinarith }) <;>
                (try {
                  nlinarith [sq_nonneg (x - y), sq_nonneg (x + y), sq_nonneg (x - 1),
                    sq_nonneg (y - 1), sq_nonneg (x + 1), sq_nonneg (y + 1)]
                }) <;>
                  (try {
                    cases' le_total 0 (x ^ 2 + x * y + y ^ 2) with h₆₆₄ h₆₆₄ <;>
                      simp_all [abs_of_nonneg, abs_of_nonpos] <;>
                        nlinarith [sq_nonneg (x - y), sq_nonneg (x + y), sq_nonneg (x - 1),
                          sq_nonneg (y - 1), sq_nonneg (x + 1), sq_nonneg (y + 1)]
                  })
    calc
      |y - x| * |x ^ 2 + x * y + y ^ 2| < δ * (3 * |x| ^ 2 + 3 * |x| + 1) := by
        gcongr
        <;> nlinarith
      _ ≤ (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) * (3 * |x| ^ 2 + 3 * |x| + 1) := by
