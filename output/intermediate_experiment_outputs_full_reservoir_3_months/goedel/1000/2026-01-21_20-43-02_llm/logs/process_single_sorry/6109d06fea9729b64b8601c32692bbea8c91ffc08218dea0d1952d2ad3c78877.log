class SampleableFintype (α : Type*) [Fintype α] where
  /-- Selects an element uniformly at random from `α`. -/
  selectElem : ProbComp α
  /-- Each element is in the support of the selection. -/
  mem_support_selectElem : ∀ x : α, x ∈ support selectElem
  /-- No failure occurs during selection. -/
  probFailure_selectElem : [⊥ | selectElem] = 0

def uniformSample {α : Type*} [Fintype α] [SampleableFintype α] : ProbComp α :=
  SampleableFintype.selectElem

notation:0 "$“α”" => uniformSample
  <;>
  simp [uniformSample, Fintype.card_fin]
  <;>
  try decide
