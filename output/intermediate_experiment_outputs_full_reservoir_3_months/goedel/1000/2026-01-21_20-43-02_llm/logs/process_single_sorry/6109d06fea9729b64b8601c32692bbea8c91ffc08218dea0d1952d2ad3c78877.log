instance (n : ℕ) : SampleableType (ZMod (n + 1)) where
  selectElem := $[0..n]
  mem_support_selectElem x := by
    simp only [support]
    have h : 0 ≤ n := by
      exact Nat.zero_le n
    have h₁ : x.val < (n + 1 : ℕ) := by
      have h₂ : x.val < (n + 1 : ℕ) := by
        have h₃ : x.val < (n + 1 : ℕ) := by
          -- Prove that the value of x in ZMod (n + 1) is less than (n + 1)
          have h₄ : x.val < (n + 1 : ℕ) := by
            -- Use properties of ZMod to get the value constraint
            simpa [ZMod.val_nat_cast] using ZMod.val_lt _ _
          exact h₄
        exact h₃
      exact h₂
    -- Show that x.val is within the bounds of the uniform sample
    have h₂ : x.val ∈ Finset.Ico 0 (n + 1) := by
      simp [Finset.mem_Ico]
      <;>
      (try omega) <;>
      (try
        {
          simp_all [Nat.lt_succ_iff]
          <;> omega
        })
    -- Since x.val is in the support, x is in the support
    have h₃ : (x.val : ℕ) ∈ (Finset.Ico 0 (n + 1) : Finset ℕ) := h₂
    simp_all [Finset.mem_Ico]
    <;>
    (try omega) <;>
    (try
      {
        simp_all [Nat.lt_succ_iff]
        <;> omega
      })
