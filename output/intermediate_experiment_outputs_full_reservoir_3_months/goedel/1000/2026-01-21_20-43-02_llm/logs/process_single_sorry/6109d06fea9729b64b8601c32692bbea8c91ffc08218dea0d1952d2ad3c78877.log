instance (n : ℕ) : SampleableFintype (Fin (n + 1)) where
  /-- Select a uniform element from `Fin (n + 1)` using a uniform sample on the indices `0` to `n`. -/
  selectElem := $[0..n]
  /-- Each element of `Fin (n + 1)` is in the support of the selection. -/
  mem_support_selectElem x := by
    have : x.val < n + 1 := by
      simp [Fin.is_lt]
    simp only [support]
    have h₁ : x.val ∈ Finset.Ico 0 (n + 1) := by
      simp [Finset.mem_Ico, Nat.lt_succ_iff] at *
      <;>
      (try omega) <;>
      (try
        {
          simp_all [Fin.ext_iff]
          <;> omega
        })
    simp_all [Finset.mem_range]
    <;>
    (try omega) <;>
    (try
      {
        simp_all [Fin.ext_iff]
        <;> omega
      })
  /-- No failure occurs in selection from `Fin (n + 1)`. -/
  probFailure_selectElem := by
    simp [probFailure_seq]
