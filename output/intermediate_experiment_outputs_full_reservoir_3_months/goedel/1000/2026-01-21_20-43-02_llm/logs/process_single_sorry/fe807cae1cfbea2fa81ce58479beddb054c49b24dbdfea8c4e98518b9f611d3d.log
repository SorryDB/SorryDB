                have h₇ : evaluate (combinedModel collection newVal).fst (Sum.inr ⟨R, oldWorld⟩) (⌈α⌉f) := h
                have h₈ : ∀ (w : (Sum Unit (Σ k : β, (collection k).1))), relate (combinedModel collection newVal).fst α (Sum.inr ⟨R, oldWorld⟩) w → evaluate (combinedModel collection newVal).fst w f := by
                  intro w hw
                  exact @relate_eval_implies_eval_of_box (combinedModel collection newVal).fst α f (Sum.inr ⟨R, oldWorld⟩) w hw
