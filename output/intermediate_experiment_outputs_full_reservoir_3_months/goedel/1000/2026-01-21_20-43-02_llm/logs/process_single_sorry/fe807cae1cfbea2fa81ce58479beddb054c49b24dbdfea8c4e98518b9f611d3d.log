theorem combMo_preserves_truth_at_oldWOrld {β : Type}
    (collection : β → Σ W : Type, Nat × KripkeModel W × W) (newVal : Nat → Prop) :
    ∀ (f : Formula) (R : β) (oldWorld : (collection R).fst),
      evaluate (combinedModel collection newVal).fst (Sum.inr ⟨R, oldWorld⟩) f ↔
        evaluate (collection R).snd.snd.fst oldWorld f :=
    by
    intro mF mR moW
    apply @Formula.rec
      (fun φ => ∀ (R : β) (oldWorld : (collection R).fst),  -- Formula IH
        evaluate (combinedModel collection newVal).fst (Sum.inr ⟨R, oldWorld⟩) φ ↔
          evaluate (collection R).snd.snd.fst oldWorld φ)
      -- Program IH 1: relations within models are preserved
      (fun π => (∀ (R : β) (oldWorld₁ oldWorld₂ : (collection R).fst),
          relate (combinedModel collection newVal).fst π
            (Sum.inr ⟨R, oldWorld₁⟩) (Sum.inr ⟨R, oldWorld₂⟩)
        ↔ relate (collection R).snd.snd.fst π oldWorld₁ oldWorld₂)
            -- Program IH 2: if old worlds are from different models they are not related
            ∧ (∀ (R₁ R₂ : β) (oldWorld₁ : (collection R₁).fst) (oldWorld₂ : (collection R₂).fst),
              R₁ ≠ R₂ →
                ¬(relate (combinedModel collection newVal).fst π
                    (Sum.inr ⟨R₁, oldWorld₁⟩) (Sum.inr ⟨R₂, oldWorld₂⟩)))
              -- Program IH 3: no old world can see the new world
              ∧ (∀ (R : β) (oldWorld : (collection R).fst),
                ¬(relate (combinedModel collection newVal).fst π
                    (Sum.inr ⟨R, oldWorld⟩) (Sum.inl Unit.unit))))
      (by simp)       -- case bottom
      (by aesop)      -- case atom_prop
      (by aesop)      -- case neg
      (by aesop)      -- case and
      ( by            -- case box
          intro α f IH_a IH_f R oldWorld
          have h₁ : (∀ (R : β) (oldWorld₁ oldWorld₂ : (collection R).fst),
              relate (combinedModel collection newVal).fst α (Sum.inr ⟨R, oldWorld₁⟩) (Sum.inr ⟨R, oldWorld₂⟩) ↔
                relate (collection R).snd.snd.fst α oldWorld₁ oldWorld₂) ∧ (∀ (R₁ R₂ : β) (oldWorld₁ : (collection R₁).fst) (oldWorld₂ : (collection R₂).fst), R₁ ≠ R₂ → ¬relate (combinedModel collection newVal).fst α (Sum.inr ⟨R₁, oldWorld₁⟩) (Sum.inr ⟨R₂, oldWorld₂⟩)) ∧ ∀ (R : β) (oldWorld : (collection R).fst), ¬relate (combinedModel collection newVal).fst α (Sum.inr ⟨R, oldWorld⟩) (Sum.inl Unit.unit) := IH_a
          have h₂ : ∀ (R : β) (oldWorld : (collection R).fst), evaluate (combinedModel collection newVal).fst (Sum.inr ⟨R, oldWorld⟩) f ↔ evaluate (collection R).snd.snd.fst oldWorld f := IH_f
          have h₃ : evaluate (combinedModel collection newVal).fst (Sum.inr ⟨R, oldWorld⟩) (⌈α⌉f) → evaluate (collection R).snd.snd.fst oldWorld (⌈α⌉f) := by
            intro h
            have h₄ : evaluate (combinedModel collection newVal).fst (Sum.inr ⟨R, oldWorld⟩) (⌈α⌉f) ↔ evaluate ((combinedModel collection newVal).fst ^[α]) (Sum.inr ⟨R, oldWorld⟩) f := by
              simp [evaluate_box]
            have h₅ : evaluate (collection R).snd.snd.fst oldWorld (⌈α⌉f) ↔ evaluate ((collection R).snd.snd.fst ^[α]) oldWorld f := by
              simp [evaluate_box]
            have h₆ : (combinedModel collection newVal).fst ^[α] = (collection R).snd.snd.fst ^[α] := by
              have h₇ : ∀ (R : β) (oldWorld₁ oldWorld₂ : (collection R).fst), relate ((combinedModel collection newVal).fst ^[α]) oldWorld₁ oldWorld₂ ↔ relate ((collection R).snd.snd.fst ^[α]) oldWorld₁ oldWorld₂ := by
                intro R oldWorld₁ oldWorld₂
                have h₈ : relate ((combinedModel collection newVal).fst ^[α]) oldWorld₁ oldWorld₂ = relate ((combinedModel collection newVal).fst ^[α]) oldWorld₁ oldWorld₂ := rfl
                have h₉ : relate ((collection R).snd.snd.fst ^[α]) oldWorld₁ oldWorld₂ = relate ((collection R).snd.snd.fst ^[α]) oldWorld₁ oldWorld₂ := rfl
                simp_all [diffRelate_pow, h₁]
                <;> aesop
              functional_ext oldWorld₁ oldWorld₂
              <;> simp_all [diffRelate_pow, h₁]
              <;> aesop
            rw [h₄] at h
            rw [h₅]
            simpa [h₆] using h
          exact by tauto )
