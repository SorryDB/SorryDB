  -- Use the property of filter composition for tendsto
  have h1 : F.map (t ‚ąė s) ‚Č§ H := by
    -- Use the fact that composition of functions maps filters accordingly
    calc
      F.map (t ‚ąė s) = (F.map s).map t := by
        -- Show that the map of the composition is the map of the first function followed by the second
        simp [Function.comp_def, Filter.map_map]
        <;>
        ext <;>
        simp [Filter.mem_map]
        <;>
        aesop
      _ ‚Č§ G.map t := by
        -- Since s tends to G from F, the map of s is less than or equal to G
        exact Filter.map_mono t hs
      _ ‚Č§ H := by
        -- Since t tends to H from G, the map of t is less than or equal to H
        exact ht
  -- Conclude that t ‚ąė s tends to H from F
  exact h1


