      " by choosing n=0, the smallest possible choice\n      use 0\n      intro z\n      -- We have z.val ‚ąą language.1 and z.val_len ‚Č• 0\n      have h‚āā : z.val ‚ąą language.1 := by exact z.prop.1\n      have h‚āÉ : z.val = z.val := rfl\n      -- Decompose z.val as z.val = őĶ * z.val * őĶ * őĶ * őĶ\n      refine' ‚ü®őĶ, z.val, őĶ, őĶ, őĶ, by simp [h‚āÉ], by\n        -- Prove that (v * x).len ‚Č• 1\n        simp [h‚āÉ, Word.length_mul, Word.length_empty]\n        <;>\n        (try omega) <;>\n        (try\n          {\n            have h‚āĄ : 0 < z.val.length := by\n              have h‚āÖ : z.val.length ‚Č• 0 := by omega\n              by_contra h‚āÜ\n              have h‚āá : z.val.length = 0 := by omega\n              have h‚āą : z.val = őĶ := by\n                apply Word.length_zero_iff_unique\n                <;> simp_all\n              simp_all [h‚āą]\n            omega\n          }\n        )\n        , by\n        -- Prove that (v * w * x).len ‚Č§ 0\n        simp [h‚āÉ, Word.length_mul, Word.length_empty]\n        <;>\n        (try omega) <;>\n        (try\n          {\n            have h‚āĄ : 0 < z.val.length := by\n              have h‚āÖ : z.val.length ‚Č• 0 := by omega\n              by_contra h‚āÜ\n              have h‚āá : z.val.length = 0 := by omega\n              have h‚āą : z.val = őĶ := by\n                apply Word.length_zero_iff_unique\n                <;> simp_all\n              simp_all [h‚āą]\n            omega\n          }\n        )\n        , _‚ü©\n      intro k\n      -- Simplify the word u * v^k * w * x^k * y to őĶ * (z.val)^k * őĶ * őĶ^k * őĶ = (z.val)^k\n      -- But (z.val)^k is in language because z.val is and language is closed under repetitions\n      simp_all [pow_succ, mul_assoc]\n      <;>\n      (try simp_all) <;>\n      (try tauto) <;>\n      (try aesop) <;>\n      (try norm_num)\n      <;>\n      (try\n        {\n          -- Use the fact that language is closed under concatenation (if needed)\n          have h‚āĄ : ‚