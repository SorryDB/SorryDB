(a :: w) := by\n        cases z.val with\n        | mk l =>\n          have h‚āá : l.length ‚Č• 1 := by\n            simp_all [Wrd.length, List.length]\n          have h‚āą : ‚ąÉ (a : őĪ) (w : List őĪ), l = a :: w := by\n            cases l with\n            | nil => contradiction\n            | cons a as => exact ‚ü®a, as, rfl‚ü©\n          obtain ‚ü®a, w, h‚āČ‚ü© := h‚āą\n          refine' ‚ü®a, ‚ü®w‚ü©, _‚ü©\n          simp_all [Wrd.mk.injEq]\n          <;>\n          (try aesop)\n      exact h‚āÜ\n    obtain ‚ü®a, w, h‚āÖ‚ü© := h‚āĄ\n    refine' ‚ü®őĶ, (a ::), w, őĶ, őĶ, _, _, _, _‚ü© <;>\n    (try simp_all [mul_assoc, pow_succ, pow_zero, Wrd.ext_iff, List.cons_append, List.nil_append, List.cons_append,\n      List.nil_append, List.cons_append, List.nil_append]) <;>\n    (try {\n      norm_num\n      <;>\n      simp_all [mul_assoc, pow_succ, pow_zero, Wrd.ext_iff, List.cons_append, List.nil_append]\n      <;>\n      (try omega)\n    }) <;>\n    (try {\n      intro k\n      simp_all [mul_assoc, pow_succ, pow_zero, Wrd.ext_iff, List.cons_append, List.nil_append]\n      <;>\n      (try {\n        have h‚āÜ : z.val ‚ąą language.1 := z.prop.1\n        simp_all [mul_assoc, pow_succ, pow_zero, Wrd.ext_iff, List.cons_append, List.nil_append]\n        <;>\n        (try omega)\n      })\n    }) <;>\n    (try {\n      have h‚āÜ : z.val ‚ąą language.1 := z.prop.1\n      simp_all [mul_assoc, pow_succ, pow_zero, Wrd.ext_iff, List.cons_append, List.nil_append]\n      <;>\n      (try omega)\n    })\n    <;>\n    (try {\n      have h‚āÜ : z.val ‚ąą language.1 := z.prop.1\n      simp_all [mul_assoc, pow_succ, pow_zero, Wrd.ext_iff, List.cons_append, List.nil_append]\n      <;>\n      (try omega)\n    })",
