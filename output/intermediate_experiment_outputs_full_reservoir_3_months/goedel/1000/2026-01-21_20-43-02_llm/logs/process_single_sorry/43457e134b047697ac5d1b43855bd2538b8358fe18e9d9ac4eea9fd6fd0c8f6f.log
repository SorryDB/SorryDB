      "\n      use 0\n      intro z\n      have h‚āĀ : z.val ‚ąą language.1 := z.1.1\n      have h‚āā : z.val.length ‚Č• 0 := by simp [z.2]\n      refine' ‚ü®z.val, őĶ, őĶ, őĶ, őĶ, by simp [h‚āĀ, őĶ], by simp, by simp, _‚ü©\n      -- This part of the proof is trivial because we are using őĶ and all conditions are met.\n      intro k\n      simp [h‚āĀ]\n      <;>\n      aesop\n    case neg =>\n      -- This case is actually impossible because it is handled by the positive case.\n      use 0\n      intro z\n      exfalso\n      have h‚āĀ : z.val ‚ąą language.1 := z.1.1\n      have h‚āā : őĶ ‚ąČ language.1 := neg\n      simp_all [h‚āĀ, h‚āā]\n      <;>\n      aesop",
