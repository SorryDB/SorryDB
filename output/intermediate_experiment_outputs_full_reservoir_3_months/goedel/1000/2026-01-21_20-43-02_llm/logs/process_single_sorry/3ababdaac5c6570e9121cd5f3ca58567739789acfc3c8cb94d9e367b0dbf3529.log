        (MeasureTheory.volume.restrict (Ioc 0 (2 * π)))) := by
    filter_upwards with a
    have z₀ : MeromorphicOn (fun x ↦ f (circleMap 0 r x) - circleMap 0 1 a) (uIcc 0 (2 * π)) := by
      sorry
    have := intervalIntegrable_log_norm_meromorphicOn (a := 0) (b := 2 * π)
        (f := fun x ↦ f (circleMap 0 r x) - circleMap 0 1 a) z₀
    unfold IntervalIntegrable at this
    simp at this
    unfold MeasureTheory.IntegrableOn at this
    exact this.1
  simp_all
  clear this

  have :  (∀ᶠ (x : ℝ) in MeasureTheory.ae MeasureTheory.volume ⊓ 𝓟 (Ioc 0 (2 * π)),
      MeasureTheory.Integrable (fun y ↦ log ‖f (circleMap 0 r x) - circleMap 0 1 y‖)
        (MeasureTheory.volume.restrict (Ioc 0 (2 * π)))) := by
    filter_upwards with a
    have z₀ : MeromorphicOn (fun x ↦ f (circleMap 0 r a) - circleMap 0 1 x) (uIcc 0 (2 * π)) := by
      have h₁ : AnalyticOnNhd (fun x : ℝ => (1 : ℂ) * x) ⊤ := by
        apply analyticOnNhd_of_analyticAt
        intro x
        apply analyticAt_id.const_smul
        <;> simp
      have h₂ : Continuous (fun x : ℝ => (1 : ℂ) * x) := by
        continuity
        <;> simp
      have h₃ : (fun x : ℝ => (1 : ℂ) * x) = (fun x : ℝ => (1 : ℂ) * x) := rfl
      have h₄ : Measurable (fun x : ℝ => (1 : ℂ) * x) := by
        apply Continuous.measurable
        continuity
        <;> simp
      have h₅ : (fun x : ℝ => (1 : ℂ) * x) = (fun x : ℝ => (1 : ℂ) * x) := rfl
      -- Use the fact that the identity function is analytic to deduce that f - circleMap 0 1 x is meromorphic
      have h₆ : MeromorphicOn (fun x : ℝ => f (circleMap 0 r a) - circleMap 0 1 x) (uIcc 0 (2 * π)) := by
        have h₇ : (fun x : ℝ => f (circleMap 0 r a) - circleMap 0 1 x) = (fun x : ℝ => f (circleMap 0 r a) - (1 : ℂ) * (x : ℂ)) := by
          funext x
          simp [circleMap, Complex.ext_iff]
          <;> ring_nf
          <;> simp_all [Complex.ext_iff]
          <;> norm_num
          <;> linarith
        rw [h₇]
        -- The function f (circleMap 0 r a) is constant, and (1 : ℂ) * x is linear, so their difference is meromorphic
        have h₈ : MeromorphicOn (fun x : ℝ => (1 : ℂ) * (x : ℂ)) (uIcc 0 (2 * π)) := by
          apply meromorphicOn_of_analyticOn
          apply analyticOn_iff_hasDerivAt.mpr
          intro x _
          have h₉ : HasDerivAt (fun x : ℝ => (1 : ℂ) * (x : ℂ)) (1 : ℂ) x := by
            -- The derivative of x ↦ (1 : ℂ) * x is 1
            have h₁₀ : HasDerivAt (fun x : ℝ => (x : ℂ)) 1 x := by
              -- The derivative of x ↦ x is 1
              simpa using (hasDerivAt_id x).const_cast
            convert HasDerivAt.const_mul (1 : ℂ) h₁₀ using 1 <;> simp [Complex.ext_iff] <;> ring_nf <;> simp_all [Complex.ext_iff] <;> norm_num <;> linarith
          exact h₉
        -- The function f (circleMap 0 r a) is constant, so it is meromorphic
        have h₉ : MeromorphicOn (fun x : ℝ => (f (circleMap 0 r a) : ℂ)) (uIcc 0 (2 * π)) := by
          apply meromorphicOn_const
        -- The difference of two meromorphic functions is meromorphic
        have h₁₀ : MeromorphicOn (fun x : ℝ => (f (circleMap 0 r a) : ℂ) - (1 : ℂ) * (x : ℂ)) (uIcc 0 (2 * π)) := by
          apply MeromorphicOn.sub h₉ h₈
        exact h₁₀
      exact h₆
