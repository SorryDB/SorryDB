def toBoundedBilin {C : ℝ} (f : (spectrum ℂ a) → ℂ)
  : H →L⋆[ℂ] H →L[ℂ] ℂ where
  toFun x := {  toFun y := (cfc_toComplexMeasure ha x y).integral f
                map_add' := by
                  intro y z
                  simp [cfc_toComplexMeasure, ComplexMeasure.integral_add]
                  <;>
                  simp_all [ComplexMeasure.integral_add, toLinearFunctional_apply, cfc_toLinearFunctional_apply,
                    cfcCLM_apply, cfcHom_apply]
                  <;>
                  ring_nf at *
                  <;>
                  simp_all [Complex.ext_iff, Complex.inner_re, Complex.inner_im]
                  <;>
                  norm_num
                  <;>
                  linarith
                map_smul' := by
                  intro r y
                  simp [cfc_toComplexMeasure, ComplexMeasure.integral_smul]
                  <;>
                  simp_all [ComplexMeasure.integral_smul, toLinearFunctional_apply, cfc_toLinearFunctional_apply,
                    cfcCLM_apply, cfcHom_apply]
                  <;>
                  ring_nf at *
                  <;>
                  simp_all [Complex.ext_iff, Complex.inner_re, Complex.inner_im]
                  <;>
                  norm_num
                  <;>
                  linarith
                cont := by
                  have _ : ContinuousLinearMap _ _ _ := toLinearFunctional x
                  sorry
