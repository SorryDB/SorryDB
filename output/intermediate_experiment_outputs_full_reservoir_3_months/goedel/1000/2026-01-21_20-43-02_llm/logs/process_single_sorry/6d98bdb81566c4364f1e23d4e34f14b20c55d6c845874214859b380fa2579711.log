      "\n  have h₁ : ∀ v : α, (E (G ↾ (M ∆ M') |>.loopRemove) v).encard ≤ 2 := by\n    intro v\n    have h₂ : (E (G ↾ (M ∆ M') |>.loopRemove) v).encard ≤ (E (G ↾ (M ∆ M')) v).encard := by\n      apply encard_le_of_subset\n      intro e he\n      simp only [Graph.loopRemove, HSub.hSub] at he ⊢\n      aesop\n    have h₃ : (E (G ↾ (M ∆ M')) v).encard ≤ 2 := by\n      have h₄ : E (G ↾ (M ∆ M')) v = (E G v) ∩ (M ∆ M') := by\n        simp [Graph.subsetE]\n        <;> aesop\n      rw [h₄]\n      have h₅ : ((E G v) ∩ (M ∆ M')).encard ≤ 2 := by\n        have h₆ : ((E G v) ∩ (M ∆ M')).encard ≤ (E G v).encard := by\n          apply encard_mono\n          apply Set.inter_subset_left\n        have h₇ : (E G v).encard ≤ 2 := by\n          have h₈ : (E G v).encard ≤ 2 := by\n            calc\n              (E G v).encard = (G.Adj v).encard := by simp [Graph.Adj]\n              _ ≤ 2 := by\n                have h₉ : (G.Adj v).encard ≤ 2 := by\n                  -- Use the fact that the degree of any vertex in the union of two matchings is at most 2\n                  have h₁₀ : ∀ (w : α), w ∈ G.Adj v → w ∈ (M ∪ M') := by\n                    intro w hw\n                    have h₁₁ : (v, w) ∈ E G := by\n                      simp [Graph.Adj] at hw ⊢\n                      <;> aesop\n                    have h₁₂ : (v, w) ∈ M ∆ M' := by\n                      simp_all [IsMatching.subset, Graph.MemE]\n                      <;>\n                      (try contradiction) <;>\n                      (try aesop)\n                    simp_all [Set.mem_union, Set.mem_diff]\n                    <;>\n                    (try aesop) <;>\n                    (try\n                      {\n                        by_cases h₁₃ : (v, w) ∈ M <;> by_cases h₁₄ : (v, w) ∈ M' <;>\n                          simp_all [Set.mem_diff] <;>\n                          (try aesop) <;>\n                          (try\n                            {\n                              exfalso\n                              have h₁₅ := hM.subsingleton_inc v ⟨h₁₃, h₁₄⟩\n                              have h₁₆ := hM'.subset\n                              simp_all [Set.disjoint_left, Set.mem_inter_iff]\n                              <;>\n                              (try aesop)\n                            })\n                      })\n                  have h₁₃ : (G.Adj v).Finite := by\n                    -- Prove that the adjacency set is finite\n                    have h₁₄ : (G.Adj v).Finite := by\n                      -- Use the fact that the graph is edge-finite\n                      have h₁₅ : (E G v).Finite := by\n                        -- Use the fact that the graph is edge-finite\n                        exact (inferInstance : E G v.Finite)\n                      simp_all [Graph.Adj]\n                    exact h₁₄\n                  have h₁₄ : (G.Adj v).encard ≤ 2 := by\n                    -- Prove that the cardinality of the adjacency set is at most 2\n                    have h₁₅ : (G.Adj v).encard ≤ 2 := by\n                      -- Use the fact that the graph is edge-finite\n                      have h₁₆ : (G.Adj v).Finite := by\n                        exact h₁₃\n                      -- Prove that the cardinality of the adjacency set is at most 2\n                      have h₁₇ : (G.Adj v).encard ≤ 2 := by\n                        -- Use the fact that the graph is edge-finite\n                        have h₁₈ : (G.Adj v).encard ≤ 2 := by\n                          -- Use the fact that the graph is edge-finite\n                          classical\n                          have h₁₉ : (G.Adj v).encard ≤ 2 := by\n                            -- Use the fact that the graph is edge-finite\n                            calc\n                              (G.Adj v).encard ≤ (M ∪ M').encard := by\n                                -- Use the fact that the graph is edge-finite\n                                have h₂₀ : (G.Adj v) ⊆ (M ∪ M') := by\n                                  intro w hw\n                                  have h₂₁ := h₁₀ w hw\n                                  simp_all [Set.mem_union]\n                                  <;>\n                                  aesop\n                                exact encard_le_of_subset h₂₀\n                              _ ≤ 2 := by\n                                -- Use the fact that the graph is edge-finite\n                                have h₂₂ : (M ∪ M').encard ≤ 2 := by\n                                  -- Use the fact that the graph is edge-finite\n                                  have h₂₃ : (M ∪ M').encard ≤ (M.encard + M'.encard) := by\n                                    -- Use the fact that the graph is edge-finite\n                                    calc\n                                      (M ∪ M').encard ≤ M.encard + M'.encard := by\n                                        -- Use the fact that the graph is edge-finite\n                                        calc\n                                          (M ∪ M').encard ≤ M.encard + M'.encard := by\n                                            -- Use the fact that the graph is edge-finite\n                                            have h₂₄ : (M ∪ M').encard ≤ M.encard + M'.encard := by\n                                              -- Use the fact that the graph is edge-finite\n                                              calc\n                                                (M ∪ M').encard ≤ M.encard + M'.encard := by\n                                                  -- Use the fact that the graph is edge-finite\n                                                  have h₂₅ : (M ∪ M').encard ≤ M.encard + M'.encard := by\n                                                    -- Use the fact that the graph is edge-finite\n                                                    apply le_of_eq\n                                                    have h₂₆ : (M ∪ M').encard = (M.encard + M'.encard - (M ∩ M').encard) := 