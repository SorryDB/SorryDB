      "\n  have h : ∀ v : α, ((G ↾ (M ∆ M')).loopRemove : Graph α β).eDegree v ≤ 2 := by\n    intro v\n    have h₁ : ((G ↾ (M ∆ M')).loopRemove : Graph α β).eDegree v ≤ (G ↾ (M ∆ M')).eDegree v := by\n      -- The number of edges in the loop removed graph is at most the number in the original graph\n      apply le_of_sub_nonneg\n      have : (G ↾ (M ∆ M')).eDegree v ≥ ((G ↾ (M ∆ M')).loopRemove : Graph α β).eDegree v := by\n        apply eDegree_mono\n        intro e he\n        simp only [Graph.loopRemove, Set.mem_diff] at he ⊢\n        -- If e is an edge in the restricted graph and not a loop, it remains in the loop removed graph\n        simp_all [Graph.loop_iff]\n        <;>\n          (try omega) <;>\n          (try\n            {\n              aesop\n            }) <;>\n          (try\n            {\n              aesop\n            })\n      omega\n    have h₂ : (G ↾ (M ∆ M')).eDegree v ≤ 2 := by\n      -- The number of edges incident to v in the symmDiff restricted graph is at most 2\n      have h₃ : (G ↾ (M ∆ M')).eDegree v = ((M ∆ M') ∩ E(G, v)).encard := by\n        simp [eDegree_eq_encard_inc, Set.ext_iff]\n        <;>\n          (try aesop) <;>\n          (try\n            {\n              simp_all [Set.mem_inter_iff, Set.mem_diff]\n              <;>\n                aesop\n            })\n      rw [h₃]\n      have h₄ : ((M ∆ M') ∩ E(G, v)).encard ≤ 2 := by\n        -- At most two edges can be incident to v from M ∆ M'\n        have h₅ : ((M ∆ M') ∩ E(G, v)) ⊆ (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) := by\n          intro x hx\n          simp only [Set.mem_inter_iff, Set.mem_union, Set.mem_symmDiff] at hx ⊢\n          -- If x is in M ∆ M' and E(G, v), then it's in M or M' but not both\n          by_cases hxM : x ∈ M <;> by_cases hxM' : x ∈ M' <;> simp_all [Set.mem_inter_iff]\n          <;>\n            (try { contradiction }) <;>\n            (try { aesop }) <;>\n            (try { simp_all [Set.mem_inter_iff] <;> aesop })\n        have h₆ : ((M ∆ M') ∩ E(G, v)).encard ≤ ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := by\n          apply encard_le_of_subset h₅\n        have h₇ : ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ 2 := by\n          -- Since M and M' are matchings, at most one edge from each can be incident to v\n          have h₈ : (M ∩ E(G, v)).encard ≤ 1 := by\n            -- M is a matching, so at most one edge from M is incident to v\n            have h₉ : (M ∩ E(G, v)).encard ≤ 1 := by\n              -- Use the fact that M is a matching to bound the encard of M ∩ E(G, v)\n              have h₁₀ : (M ∩ E(G, v)).encard ≤ 1 := by\n                -- Since M is a matching, the edges in M ∩ E(G, v) are disjoint\n                have h₁₁ : (M ∩ E(G, v)).Subsingleton := by\n                  -- Prove that M ∩ E(G, v) is a subsingleton\n                  refine' hM.subsingleton_inc v\n                  <;>\n                    (try aesop)\n                -- The encard of a subsingleton set is at most 1\n                rw [encard_le_one_iff_subsingleton]\n                exact h₁₁\n              exact h₁₀\n            exact h₉\n          have h₉ : (M' ∩ E(G, v)).encard ≤ 1 := by\n            -- M' is a matching, so at most one edge from M' is incident to v\n            have h₁₀ : (M' ∩ E(G, v)).encard ≤ 1 := by\n              -- Use the fact that M' is a matching to bound the encard of M' ∩ E(G, v)\n              have h₁₁ : (M' ∩ E(G, v)).Subsingleton := by\n                -- Prove that M' ∩ E(G, v) is a subsingleton\n                refine' hM'.subsingleton_inc v\n                <;>\n                  (try aesop)\n              -- The encard of a subsingleton set is at most 1\n              rw [encard_le_one_iff_subsingleton]\n              exact h₁₁\n            exact h₁₀\n          have h₁₀ : ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ 2 := by\n            -- Use the fact that the union of two sets with encard ≤ 1 has encard ≤ 2\n            calc\n              ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ (M ∩ E(G, v)).en