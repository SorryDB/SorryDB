      "\n  have h1 : (hM.restrict₂ hM').MaxDegreeLE 2 := by\n    have h2 : ∀ (v : α), (hM.restrict₂ hM').eDegree v ≤ 2 := by\n      intro v\n      have h3 : (hM.restrict₂ hM').eDegree v = (E(G, v) ∩ (M ∆ M')).encard := by\n        simp [hM.restrict₂, eDegree_eq_encard, Filter.CoeDecidable]\n        <;>\n        aesop\n      rw [h3]\n      have h4 : (E(G, v) ∩ (M ∆ M')).encard ≤ 2 := by\n        have h5 : (E(G, v) ∩ (M ∆ M')).encard ≤ 2 := by\n          have h6 : (E(G, v) ∩ (M ∆ M')) ⊆ E(G, v) := by\n            intro e he\n            exact he.1\n          have h7 : E(G, v).encard ≤ 2 := by\n            have h8 : (M ∩ E(G, v)).encard ≤ 1 := hM.degree_le_one v\n            have h9 : (M' ∩ E(G, v)).encard ≤ 1 := hM'.degree_le_one v\n            have h10 : E(G, v).encard ≤ 2 := by\n              have h11 : E(G, v).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard + ((E(G, v)) \\ (M ∪ M')).encard := by\n                have h12 : E(G, v) = (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ∪ ((E(G, v)) \\ (M ∪ M')) := by\n                  ext e\n                  simp [Set.mem_union, Set.mem_inter_iff, Set.mem_diff]\n                  <;> tauto\n                rw [h12]\n                calc\n                  ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ∪ ((E(G, v)) \\ (M ∪ M'))).encard ≤ ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard + ((E(G, v)) \\ (M ∪ M')).encard := by\n                    exact encard_union_le _ _ |>.trans (add_comm _ _)\n                  _ ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard + ((E(G, v)) \\ (M ∪ M')).encard := by\n                    have h13 : ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                      exact encard_union_le _ _\n                    omega\n              have h14 : (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard ≤ 2 := by\n                calc\n                  (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard ≤ 1 + 1 := by\n                    have h15 : (M ∩ E(G, v)).encard ≤ 1 := hM.degree_le_one v\n  