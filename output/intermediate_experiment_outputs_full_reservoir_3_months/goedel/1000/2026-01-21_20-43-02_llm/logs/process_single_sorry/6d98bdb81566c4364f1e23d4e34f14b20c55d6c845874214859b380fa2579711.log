lemma IsMatching.symmDiff_maxDegree_le_two (hM : G.IsMatching M) (hM' : G.IsMatching M') :
    (hM.restrict₂ hM').MaxDegreeLE 2 := by
  have h₁ : ∀ (v : α), (E(hM.restrict₂ hM', v)).encard ≤ 2 := by
    intro v
    have h₂ : (E(hM.restrict₂ hM', v)).encard ≤ 2 := by
      have h₃ : (hM.restrict₂ hM') = (G ↾ (M ∆ M')) |>.loopRemove := rfl
      rw [h₃]
      have h₄ : E((G ↾ (M ∆ M')) |>.loopRemove, v) ⊆ E(G ↾ (M ∆ M'), v) := by
        intro e he
        exact (Graph.loopRemove_subset _ _).subset he
      have h₅ : E(G ↾ (M ∆ M'), v) = E(G, v) ∩ (M ∆ M') := by
        ext e
        simp [Graph.instEdgeSetRestrictGraph]
        <;> aesop
      have h₆ : E((G ↾ (M ∆ M')) |>.loopRemove, v) ⊆ E(G, v) ∩ (M ∆ M') := by
        intro e he
        have h₇ : e ∈ E(G ↾ (M ∆ M'), v) := h₄ he
        rw [h₅] at h₇
        exact h₇
      have h₇ : (E((G ↾ (M ∆ M')) |>.loopRemove, v)).encard ≤ (E(G, v) ∩ (M ∆ M')).encard := by
        exact enCard_mono h₆
      have h₈ : (E(G, v) ∩ (M ∆ M')).encard ≤ 2 := by
        have h₉ : (E(G, v) ∩ (M ∆ M')).encard ≤ 2 := by
          -- Use the fact that M and M' are matchings to bound the number of edges incident to v in M ∆ M'
          have h₁₀ : (E(G, v) ∩ M).encard ≤ 1 := by
            have h₁₁ : (E(G, v) ∩ M).encard ≤ 1 := by
              have h₁₂ : (M ∩ E(G, v)).encard ≤ 1 := hM.degree_le_one v
              have h₁₃ : (E(G, v) ∩ M) = (M ∩ E(G, v)) := by
                ext e
                <;> simp [Set.mem_inter_iff]
                <;> tauto
              rw [h₁₃]
              exact h₁₂
            exact h₁₁
          have h₁₁ : (E(G, v) ∩ M').encard ≤ 1 := by
            have h₁₂ : (E(G, v) ∩ M').encard ≤ 1 := by
              have h₁₃ : (M' ∩ E(G, v)).encard ≤ 1 := hM'.degree_le_one v
              have h₁₄ : (E(G, v) ∩ M') = (M' ∩ E(G, v)) := by
                ext e
                <;> simp [Set.mem_inter_iff]
                <;> tauto
              rw [h₁₄]
              exact h₁₃
            exact h₁₂
          have h₁₂ : (E(G, v) ∩ (M ∆ M')).encard ≤ 2 := by
            calc
              (E(G, v) ∩ (M ∆ M')).encard ≤ (E(G, v) ∩ (M ∪ M')).encard := by
                apply enCard_mono
                intro x hx
                simp only [Set.mem_inter_iff, Set.mem_union, Set.mem_diff] at hx ⊢
                tauto
              _ = (E(G, v) ∩ M ∪ E(G, v) ∩ M').encard := by
                rw [inter_distrib_left]
                <;> simp [Set.ext_iff]
              _ ≤ 2 := by
                have h₁₃ : (E(G, v) ∩ M ∪ E(G, v) ∩ M').encard ≤ 2 := by
                  calc
                    (E(G, v) ∩ M ∪ E(G, v) ∩ M').encard ≤ (E(G, v) ∩ M).encard + (E(G, v) ∩ M').encard := by
                      apply enCard_union_le
                    _ ≤ 1 + 1 := by
                      gcongr <;> simp_all
                    _ = 2 := by norm_num
                exact h₁₃
          exact h₁₂
        exact h₉
      calc
        (E((G ↾ (M ∆ M')) |>.loopRemove, v)).encard ≤ (E(G, v) ∩ (M ∆ M')).encard := h₇
        _ ≤ 2 := h₈
    exact h₂
  rw [maxDegreeLE_iff']
  intro v hv
  have := h₁ v
  simp [eDegree_eq_encard_inc] at this ⊢
  <;> assumption
