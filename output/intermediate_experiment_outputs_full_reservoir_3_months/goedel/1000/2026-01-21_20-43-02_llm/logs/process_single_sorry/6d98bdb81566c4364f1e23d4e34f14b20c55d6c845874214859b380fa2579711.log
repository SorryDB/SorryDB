               -- If M' is empty, then M'.encard = 0 < 2\n                      have h₂₁ : M' = ∅ := by\n                        apply Set.eq_empty_of_forall_not_mem\n                        intro x hx\n                        have h₂₂ : ∃ (e : β), e ∈ M' := ⟨x, hx⟩\n                        tauto\n                      have h₂₃ : M'.encard = 0 := by\n                        simp [h₂₁]\n                      have h₂₄ : (M'.encard : ℕ∞) < 2 := by\n                        simp [h₂₃]\n                        <;> norm_num\n                      simp_all [Nat.lt_succ_iff]\n                    obtain ⟨e, he⟩ := h₁₉\n                    have h₂₅ : ∃ (f : β), f ∈ M' ∧ f ≠ e := by\n                      by_contra h₂₆\n                      -- If all elements in M' are equal to e, then M'.encard ≤ 1\n                      have h₂₇ : M' ⊆ {e} := by\n                        intro x hx\n                        by_cases h₂₈ : x = e\n                        · simp_all\n                        · exfalso\n                          have h₂₉ : ∃ (f : β), f ∈ M' ∧ f ≠ e := ⟨x, hx, h₂₈⟩\n                          tauto\n                      have h₃₀ : M'.encard ≤ 1 := by\n                        calc\n                          M'.encard ≤ ({e} : Set β).encard := enCard_le_of_subset h₂₇\n                          _ = 1 := by simp\n                      simp_all [Nat.lt_succ_iff]\n                    obtain ⟨f, hf, hfe⟩ := h₂₅\n                    exact ⟨e, f, he, hf, by intro h; apply hfe; simp_all⟩\n                  exact h₁₇\n                obtain ⟨e, f, he, hf, hne⟩ := h₁₆\n                -- Use the fact that M' is a matching to derive a contradiction\n                have h₂₁ := hM'.disjoint he hf hne\n                simp_all [Set.disjoint_left]\n                <;> aesop\n              exact h₁₁\n            -- Combine the inequalities to get the desired result\n            have h₁₀ : (M.encard + M'.encard : ℕ∞) ≤ 2 := by\n              calc\n                (M.encard + M'.encar