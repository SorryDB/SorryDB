      "\n  have h₁ : ∀ v : α, E((hM.restrict₂ hM'), v).encard ≤ 2 := by\n    intro v\n    have h₂ : E((hM.restrict₂ hM'), v) ⊆ {e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} := by\n      intro e he\n      simp only [hM.restrict₂, E, loopRemove, mem_setOf_eq, Union.mem_iff, Set.mem_diff, Set.mem_singleton_iff] at he ⊢\n      aesop\n    have h₃ : E((hM.restrict₂ hM'), v).encard ≤ ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard := by\n      apply encard_le_of_subset h₂\n    have h₄ : ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard ≤ 2 := by\n      -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n      have h₅ : ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard ≤ 2 := by\n        -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n        have h₆ : ∀ e ∈ ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β), e ∈ M ∆ M' ∧ e ∈ E(G) := by\n          intro e he\n          exact he.1\n        -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n        have h₇ : ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard ≤ 2 := by\n          -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n          have h₈ : M ∩ M' = ∅ := by\n            -- Use the fact that M and M' are matchings to show that their intersection is empty\n            have h₉ : ∀ ⦃e f⦄, e ∈ M → f ∈ M' → e ≠ f → Disjoint V(G, e) V(G, f) := by\n              intro e f he hf hne\n              -- Use the fact that M and M' are matchings to show that their edges are disjoint\n              have h₁₀ : e ∈ M ∨ f ∈ M := by tauto\n              have h₁₁ : e ∈ M' ∨ f ∈ M' := by tauto\n              -- Consider the cases for e and f being in M or M'\n              have h₁₂ : e ∈ M := he\n              have h₁₃ : f ∈ M' := hf\n              -- Use the fact that M and M' are matchings to show that their edges are disjoint\n              cases' h₁₀ with h₁₀ h₁₀ <;> cases' h₁₁ with h₁₁ h₁₁ <;>\n                (try { contradiction }) <;>\n                (try { simp_all [hM.disjoint, hM'.disjoint, Disjoint] }) <;>\n                (try { aesop })\n            -- Use the fact that M and M' are matchings to show that their intersection is empty\n            have h₁₀ : M ∩ M' = ∅ := by\n              apply Set.eq_empty_of_forall_not_mem\n              intro e he\n              have h₁₁ : e ∈ M := by simp_all [Set.mem_inter_iff]\n              have h₁₂ : e ∈ M' := by simp_all [Set.mem_inter_iff]\n              have h₁₃ : Disjoint V(G, e) V(G, e) := by\n                have h₁₄ := h₉ e e h₁₁ h₁₂ (by simp_all)\n                simp_all [hM.disjoint, hM'.disjoint, Disjoint]\n              simp_all [Set.disjoint_iff_ne]\n            exact h₁₀\n          -- Use the fact that M and M' are matchings to show that their intersection is empty\n          have h₉ : ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard ≤ 2 := by\n            -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n            have h₁₀ : ∀ e ∈ ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β), e ∈ M ∆ M' := by\n              intro e he\n              exact he.1.1\n            -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n            have h₁₁ : ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard ≤ 2 := by\n              -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n              have h₁₂ : ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β) ⊆ (M ∪ M') := by\n                intro e he\n                simp only [h₁₀ he, mem_setOf_eq, Set.mem_union] at he ⊢\n                simp_all [Set.mem_union]\n                <;> aesop\n              have h₁₃ : ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard ≤ (M ∪ M' : Set β).encard := by\n                apply encard_le_of_subset h₁₂\n              have h₁₄ : (M ∪ M' : Set β).encard ≤ 2 := by\n                -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n                have h₁₅ : (M ∪ M' : Set β).encard ≤ 2 := by\n                  -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n                  classical\n                  by_cases h₁₆ : M = M'\n                  · simp_all [Set.ext_iff]\n                    <;> aesop\n                  · have h₁₇ : M ∪ M' = M ∪ M' := rfl\n                    simp_all [Set.ext_iff]\n                    <;> aesop\n                exact h₁₅\n              calc\n                ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard ≤ (M ∪ M' : Set β).encard := h₁₃\n                _ ≤ 2 := h₁₄\n            exact h₁₁\n          exact h₉\n        exact h₇\n      exact h₅\n    -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n    calc\n      E((hM.restrict₂ hM'), v).encard ≤ ({e : β | (e ∈ M ∆ M' ∧ e ∈ E(G)) ∧ (∃ w, (G contextual v : Set α) w.1 e)} : Set β).encard := h₃\n      _ ≤ 2 := h₄\n  -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n  rw [maxDegreeLE_iff]\n  intro v\n  rw [eDegree_eq_encard_inc]\n  have h₂ := h₁ v\n  -- Use the fact that the number of edges incident to v in the symmetric difference of M and M' is at most 2\n  norm_num at h₂ ⊢\n  <;> omega",
      "\n   - For any vertex `v`, the set `E(G.restrict₂ M M', v)` is a subset of the set of edges incident to `v` in `M ∆ M'`.\n   - But in `M ∆ M'`, the number of edges incident to `v` is at most `|E_M(v)| + |E_M'(v)| ≤ 2`, because `M` and `M'` are matchings.\n\nBut perhaps Lean has a better way? The `MaxDegreeLE` predicate means that every vertex has degree ≤ 2. \n\nSo perhaps we can use the following approach:\n1. Take any vertex `v` in `G.restrict₂ M M'`.\n2. The edges incident to `v` in `G.restrict₂ M M'` are the edges `e ∈ M ∆ M'` incident to `v` that are not loops.\n3. The number of such edges is ≤ number of edges ∈ M ∆ M' incident to",
      "and `f` are distinct elements of `Set β",
      "\n  have h₁ : ∀ (v : α), (E (hM.restrict₂ hM', v)).encard ≤ 2 := by\n    sorry\n  have h₂ : (hM.restrict₂ hM').MaxDegreeLE 2 := by\n    sorry\n  exact h₂",
      "v) ∩ (M ∆ M')) ⊆ (E(G, v) ∩ (M ∪ M'))`, because `M ∆ M' ⊆ M ∪ M'`.\n\nBut `(E(G, v) ∩ (M ∪ M')) = (E",
      "\n  have h₁ : ∀ (v : α), (E((hM.restrict₂ hM'), v)).Finite := by\n    intro v\n    -- Since G is edge-finite, any subset of E(G) is also finite.\n    haveI := inferInstanceAs (EdgeFinite G)\n    exact Set.Finite.subset (inferInstance) (fun e he ↦ by\n      -- Each edge in (hM.restrict₂ hM').E is in E(G).\n      simp only [Graph.restrict₂, Graph.loopRemove, Set.mem_symmDiff, Set.mem_inter_iff, Set.mem_compl_iff,\n        Set.mem_singleton_iff] at he ⊢\n      simp_all [Graph.mem_E, Set.mem_union]\n      <;> aesop)\n  -- We need to show that every vertex in (hM.restrict₂ hM') has degree at most 2.\n  have h₂ : ∀ (v : α), (E((hM.restrict₂ hM'), v)).encard ≤ 2 := by\n    intro v\n    -- Calculate the number of edges incident to v in (hM.restrict₂ hM').\n    haveI := inferInstanceAs (EdgeFinite G)\n    have h₃ : (E((hM.restrict₂ hM'), v)) ⊆ (E(G, v) ∩ (M ∆ M')) ∩ {e : β | ↑e ∉ Loop} := by\n      intro e he\n      simp only [Graph.restrict₂, Graph.loopRemove, Set.mem_symmDiff, Set.mem_inter_iff,\n        Set.mem_compl_iff, Set.mem_singleton_iff, Graph.mem_E, Set.mem_setOf_eq] at he ⊢\n      simp_all [Set.mem_union]\n      <;>\n      (try aesop) <;>\n      (try\n        {\n          cases' he with he₁ he₂\n          <;> simp_all [Set.mem_diff, Set.mem_union]\n          <;>\n          (try aesop) <;>\n          (try\n            {\n              tauto\n            })\n        }) <;>\n      (try\n        {\n          aesop\n        })\n    -- Since M and M' are matchings, each vertex in G has at most one edge incident to it in M and M'.\n    have h₄ : (E(G, v) ∩ (M ∆ M')).encard ≤ 2 := by\n      have h₅ : (E(G, v) ∩ (M ∆ M')).encard ≤ (E(G, v) ∩ M).encard + (E(G, v) ∩ M').encard := by\n        calc\n          (E(G, v) ∩ (M ∆ M')).encard = (E(G, v) ∩ (M ∪ M') \\ (M ∩ M')).encard := by\n            congr\n            ext e\n            simp [Set.mem_union, Set.mem_diff, Set.mem_inter_iff]\n            <;>\n            by_cases h : e ∈ M <;>\n            by_cases h' : e ∈ M' <;>\n            simp_all [h, h'] <;>\n            tauto\n          _ ≤ ((E(G, v) ∩ (M ∪ M')) \\ (M ∩ M')).encard := by simp [Set.inter_subset_left]\n          _ ≤ (E(G, v) ∩ (M ∪ M')).encard := by\n            apply encard_mono\n            exact Set.diff_subset\n          _ = (E(G, v) ∩ M).encard + (E(G, v) ∩ M').encard := by\n            have h₆ : (E(G, v) ∩ (M ∪ M')).encard = (E(G, v) ∩ M).encard + (E(G, v) ∩ M').encard := by\n              have h₇ : Disjoint (E(G, v) ∩ M) (E(G, v) ∩ M') := by\n                rw [Set.disjoint_left]\n                intro x hx\n                simp only [Set.mem_inter_iff] at hx\n                have h₈ : x ∈ M := hx.2\n                have h₉ : x ∈ M' := by aesop\n                have h₁₀ : x ∈ E(G, v) := hx.1\n                have h₁₁ := hM.disjoint h₈ h₉\n                simp_all [Set.disjoint_left]\n                <;> aesop\n              have h₈ : (E(G, v) ∩ M) ∪ (E(G, v) ∩ M') = E(G, v) ∩ (M ∪ M') := by\n                ext x\n                simp [Set.mem_union, Set.mem_inter_iff]\n                <;> tauto\n              have h₉ : (E(G, v) ∩ M).encard + (E(G, v) ∩ M').encard = (E(G, v) ∩ M ∪ E(G, v) ∩ M').encard := by\n                rw [← Set.encard_union_add_encard_inter]\n                have h₁₀ : Disjoint (E(G, v) ∩ M) (E(G, v) ∩ M') := h₇\n                simp_all [disjoint_iff_inter_eq_empty]\n                <;> aesop\n              rw [h₈] at *\n              linarith\n            rw [h₆]\n          _ ≤ (E(G, v) ∩ M).encard + (E(G, v) ∩ M').encard := by simp\n      have h₆ : (E(G, v) ∩ M).encard ≤ 1 := by\n        have h₇ : (E(G, v) ∩ M).Subsingleton := by\n          apply hM.subsingleton_inc v\n        have h₈ : (E(G, v) ∩ M).encard ≤ 1 := by\n          rw [encard_le_one_iff_subsingleton]\n          exact h₇\n        exact h₈\n      have h₇ : (E(G, v) ∩ M').encard ≤ 1 := by\n        have h₈ : (E(G, v) ∩ M').Subsingleton := by\n          apply hM'.subsingleton_inc v\n        have h₉ : (E(G, v) ∩ M').encard ≤ 1 := by\n          rw [encard_le_one_iff_subsingleton]\n          exact h₈\n        exact h₉\n      calc\n        (E(G, v) ∩ (M ∆ M')).encard ≤ (E(G, v) ∩ M).encard + (E(G, v) ∩ M').encard := h₅\n        _ ≤ 1 + 1 := by\n          gcongr <;> simp_all [Set.encard_le_span]\n        _ = 2 := by norm_num\n    -- Since the number of edges incident to v in M ∆ M' is at most 2, the number of edges incident to v in (hM.restrict₂ hM') is also at most 2.\n    have h₅ : (E((hM.restrict₂ hM'), v)).encard ≤ 2 := by\n      calc\n        (E((hM.restrict₂ hM'), v)).encard ≤ ((E(G, v) ∩ (M ∆ M')) ∩ {e : β | ↑e ∉ Loop}).encard := by\n          apply encard_mono\n          exact h₃\n        _ ≤ (E(G, v) ∩ (M ∆ M')).encard := by\n          apply encard_mono\n          intro e he\n          simp only [Set.mem_inter_iff, Set.mem_setOf_eq] at he ⊢\n          aesop\n        _ ≤ 2 := h₄\n    exact h₅\n  -- Finally, we can conclude that (hM.restrict₂ hM') has maximum degree at most 2.\n  have h₃ : MaxDegreeLE (hM.restrict₂ hM') 2 := by\n    rw [maxDegreeLE_iff']\n    intro v\n    -- For each vertex v, the degree is at most 2.\n    have h₄ : (E((hM.restrict₂ hM'), v)).encard ≤ 2 := h₂ v\n    exact h₄\n  exact h₃",
      "\n  have h₁ : (hM.restrict₂ hM').MaxDegreeLE 2 := by\n    let H : Graph α β := G ↾ (M ∆ M') |>.loopRemove\n    have h₂ : H = hM.restrict₂ hM' := rfl\n    rw [h₂]\n    have h₃ : H.EdgeFinite := inferInstance\n    -- Since H is the graph obtained by removing loops from G restricted to M ∆ M', its maximum degree is bounded by 2.\n    rw [maxDegreeLE_iff]\n    intro v hv\n    have h₄ : E(H, v).encard ≤ 2 := by\n      -- Each vertex v can have at most two edges in H, as M ∆ M' can contribute edges at most twice.\n      have h₅ : E(H, v).encard ≤ 2 := by\n        -- Use the fact that G.IsMatching implies that no vertex has more than one edge in M or M'.\n        have h₆ : E(H, v).subset (E(G ↾ (M ∆ M'), v)) := by\n          -- Each edge in H is an edge in G restricted to M ∆ M'.\n          intro e he\n          simp_all [Graph.E, Set.mem_setOf_eq, H, loopRemove]\n          <;> aesop\n        have h₇ : E(G ↾ (M ∆ M'), v).encard ≤ 2 := by\n          -- Each vertex v can have at most two edges in G restricted to M ∆ M'.\n          have h₈ : E(G ↾ (M ∆ M'), v) = (M ∆ M') ∩ E(G, v) := by\n            -- The edges of G restricted to M ∆ M' are in M ∆ M' and E(G, v).\n            ext e\n            simp [Graph.E, Set.mem_setOf_eq]\n            <;>\n            aesop\n          rw [h₈]\n          -- Since M and M' are matchings, the number of edges incident to v is at most 2.\n          have h₉ : ((M ∆ M') ∩ E(G, v)).encard ≤ 2 := by\n            have h₁₀ : ((M ∆ M') ∩ E(G, v)).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n              have h₁₁ : (M ∆ M') ∩ E(G, v) ⊆ (M ∪ M') ∩ E(G, v) := by\n                intro e he\n                simp only [mem_inter_iff, mem_union] at he ⊢\n                by_cases h : e ∈ M <;> by_cases h' : e ∈ M' <;> simp_all [Set.mem_symmDiff]\n                <;> tauto\n              have h₁₂ : (M ∪ M') ∩ E(G, v) = (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) := by\n                ext e\n                simp [Set.mem_inter_iff, Set.mem_union]\n                <;>\n                tauto\n              have h₁₃ : ((M ∆ M') ∩ E(G, v)).encard ≤ ((M ∪ M') ∩ E(G, v)).encard := by\n                apply encard_mono\n                exact h₁₁\n              have h₁₄ : ((M ∪ M') ∩ E(G, v)).encard = ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := by\n                rw [h₁₂]\n              have h₁₅ : ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                calc\n                  ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ ((M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard) :=\n                    calc\n                      ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := by rfl\n                      _ ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                        calc\n                          ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard :=\n                            calc\n                              ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ ((M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard) :=\n                                by\n                                  -- Use the fact that the union of two sets has cardinality at most the sum of their cardinalities.\n                                  have h₁₆ : ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                                    calc\n                                      ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ ((M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard) :=\n                                        by\n                                          -- Use the fact that the union of two sets has cardinality at most the sum of their cardinalities.\n                                          exact encard_union_le (M ∩ E(G, v)) (M' ∩ E(G, v))\n                                      _ = (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by rfl\n                                  exact h₁₆\n                              _ = (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by rfl\n                          _ = (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by rfl\n                  _ = (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by rfl\n              calc\n                ((M ∆ M') ∩ E(G, v)).encard ≤ ((M ∪ M') ∩ E(G, v)).encard := h₁₃\n                _ = ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := by rw [h₁₄]\n                _ ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := h₁₅\n            have h₁₁ : (M ∩ E(G, v)).encard ≤ 1 := by\n              -- Since M is a matching, each vertex can have at most one edge in M.\n              have h₁₂ : (M ∩ E(G, v)).encard ≤ 1 := by\n                -- The set of edges in M incident to v has cardinality at most 1.\n                have h₁₃ : (M ∩ E(G, v)).encard ≤ 1 := by\n                  -- Use the fact that M is a matching to bound the cardinality.\n                  have h₁₄ : (M ∩ E(G, v)).Subsingleton := by\n                    intro e he f hf\n                    by_contra hne\n                    -- If there are two edges in M incident to v, then they are disjoint, which contradicts the matching property.\n                    have h₁₅ : e ∈ M := by simp_all [Set.mem_inter_iff]\n                    have h₁₆ : f ∈ M := by simp_all [Set.mem_inter_iff]\n                    have h₁₇ : e ≠ f := by tauto\n                    have h₁₈ : Disjoint (V(G, e)) (V(G, f)) := hM.disjoint h₁₅ h₁₆ h₁₇\n                    have h₁₉ : v ∈ V(G, e) := by\n                      simp_all [Graph.V]\n                      <;> aesop\n                    have h₂₀ : v ∈ V(G, f) := by\n                      simp_all [Graph.V]\n                      <;> aesop\n                    have h₂₁ : ¬Disjoint (V(G, e)) (V(G, f)) := by\n                      -- If v is in both sets, then they are not disjoint.\n                      have h₂₂ : v ∈ (V(G, e) ∩ V(G, f)) := by\n                        simp_all [Set.mem_inter_iff]\n                      simp_all [Set.disjoint_iff_inter_eq_empty]\n                      <;> aesop\n                    simp_all [Set.disjoint_iff_inter_eq_empty]\n                    <;> aesop\n                  -- The set is a subsingleton, so its cardinality is at most 1.\n                  have h₁₅ : (M ∩ E(G, v)).encard ≤ 1 := by\n                    rw [encard_le_one_iff_subsingleton]\n                    exact h₁₄\n                  exact h₁₅\n                exact h₁₃\n              exact h₁₂\n            have h₁₂ : (M' ∩ E(G, v)).encard ≤ 1 := by\n              -- Similarly for M'.\n              have h₁₃ : (M' ∩ E(G, v)).encard ≤ 1 := by\n                have h₁₄ : (M' ∩ E(G, v)).Subsingleton := by\n                  intro e he f hf\n                  by_contra hne\n                  have h₁₅ : e ∈ M' := by simp_all [Set.mem_inter_iff]\n                  have h₁₆ : f ∈ M' := by simp_all [Set.mem_inter_iff]\n                  have h₁₇ : e ≠ f := by tauto\n                  have h₁₈ : Disjoint (V(G, e)) (V(G, f)) := hM'.disjoint h₁₅ h₁₆ h₁₇\n                  have h₁₉ : v ∈ V(G, e) := by\n                    simp_all [Graph.V]\n                    <;> aesop\n                  have h₂₀ : v ∈ V(G, f) := by\n                    simp_all [Graph.V]\n                    <;> aesop\n                  have h₂₁ : ¬Disjoint (V(G, e)) (V(G, f)) := by\n                    have h₂₂ : v ∈ (V(G, e) ∩ V(G, f)) := by\n                      simp_all [Set.mem_inter_iff]\n                    simp_all [Set.disjoint_iff_inter_eq_empty]\n                    <;> aesop\n                  simp_all [Set.disjoint_iff_inter_eq_empty]\n                  <;> aesop\n                have h₁₅ : (M' ∩ E(G, v)).encard ≤ 1 := by\n                  rw [encard_le_one_iff_subsingleton]\n                  exact h₁₄\n                exact h₁₅\n              exact h₁₃\n            -- Combine the bounds to get the desired result.\n            calc\n              ((M ∆ M') ∩ E(G, v)).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := h₁₀\n              _ ≤ 1 + 1 := by gcongr <;> simp_all\n              _ = 2 := by norm_num\n          -- Simplify the result.\n          exact h₉\n        -- Use the fact that the edges in H are a subset of the edges in G restricted to M ∆ M'.\n        calc\n          E(H, v).encard ≤ E(G ↾ (M ∆ M'), v).encard := by\n            apply encard_mono\n            intro e he\n            simp_all [H]\n            <;> aesop\n          _ ≤ 2 := h₇\n      exact h₅\n    -- The result follows from the bound on the cardinality of the edges incident to v.\n    exact by\n      simpa [eDegree_eq_encard_inc] using h₄\n  exact h₁",
      "\n   - `eDegree (G ↾ (M ∆ M')) v = card {e : β | e ∈ M ∆ M' ∧ v ∈ V(G, e)}` (because the edges are exactly those in `M",
      "\n  refine' MaxDegreeLE.mono _ (by simp [hM', hM])\n  <;> simp_all [IsMatching.restrict₂]\n  <;> apply maxDegreeLE_of_maxEdgeDegreeLE\n  <;> simp_all [IsMatching.restrict₂]\n  <;> norm_num\n  <;> aesop",
      "\n  have h : ∀ (v : α), E(hM.restrict₂ hM', v).encard ≤ 2 := by\n    intro v\n    have h₁ : E(hM.restrict₂ hM', v) ⊆ E(G, v) := by\n      intro e he\n      simp only [hM.restrict₂, Subtype.ext_iff] at he ⊢\n      simp_all [Graph.subEdge, Graph.loopRemove]\n      <;>\n      (try aesop) <;>\n      (try\n        {\n          norm_num at he ⊢ <;>\n          (try omega)\n        }) <;>\n      (try\n        {\n          aesop\n        })\n    have h₂ : E(hM.restrict₂ hM', v).encard ≤ E(G, v).encard := by\n      exact encard_le_encard h₁\n    have h₃ : E(G, v).encard ≤ 2 := by\n      -- Use the fact that the edges incident to v are either in M or M'\n      have h₄ : E(G, v) = (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) := by\n        apply Set.Subset.antisymm\n        · -- Prove that E(G, v) ⊆ (M ∩ E(G, v)) ∪ (M' ∩ E(G, v))\n          intro e he\n          have h₅ : e ∈ E(G, v) := he\n          by_cases h₆ : e ∈ M\n          · -- Case: e ∈ M\n            have h₇ : e ∈ M ∩ E(G, v) := ⟨h₆, h₅⟩\n            exact Or.inl h₇\n          · -- Case: e ∉ M\n            by_cases h₈ : e ∈ M'\n            · -- Subcase: e ∈ M'\n              have h₉ : e ∈ M' ∩ E(G, v) := ⟨h₈, h₅⟩\n              exact Or.inr h₉\n            · -- Subcase: e ∉ M' (but this cannot happen because e ∈ E(G, v))\n              exfalso\n              -- This case is impossible because e ∈ E(G, v) and M, M' are matchings\n              have h₁₀ := hM.subsingleton_inc v\n              have h₁₁ := hM'.subsingleton_inc v\n              simp_all [Set.Subsingleton]\n              <;>\n              (try\n                {\n                  aesop\n                })\n              <;>\n              (try\n                {\n                  simp_all [Set.ext_iff]\n                  <;>\n                  (try omega)\n                })\n        · -- Prove that (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ⊆ E(G, v)\n          intro e he\n          cases he with\n          | inl he =>\n            have h₅ : e ∈ M ∩ E(G, v) := he\n            exact h₅.2\n          | inr he =>\n            have h₅ : e ∈ M' ∩ E(G, v) := he\n            exact h₅.2\n      have h₅ : E(G, v).encard = ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := by\n        rw [h₄]\n      have h₆ : ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ 2 := by\n        -- Use the fact that the union of two sets with at most 1 element each has at most 2 elements\n        have h₇ : (M ∩ E(G, v)).encard ≤ 1 := by\n          -- Since M is a matching, at most one edge in M is incident to v\n          have h₈ : (M ∩ E(G, v)).encard ≤ 1 := by\n            apply le_of_not_gt\n            intro h₉\n            have h₁₀ : (M ∩ E(G, v)).encard > 1 := h₉\n            have h₁₁ : ∃ (e f : β), e ∈ M ∩ E(G, v) ∧ f ∈ M ∩ E(G, v) ∧ e ≠ f := by\n              -- There exist at least two distinct edges in M ∩ E(G, v)\n              have h₁₂ : (M ∩ E(G, v)).encard ≥ 2 := by\n                have h₁₃ : (M ∩ E(G, v)).encard > 1 := h₁₀\n                have h₁₄ : (M ∩ E(G, v)).encard ≥ 2 := by\n                  have h₁₅ : (M ∩ E(G, v)).encard > 1 := h₁₀\n                  omega\n                exact h₁₄\n              -- Extract two distinct edges\n              have h₁₅ : ∃ (e f : β), e ∈ M ∩ E(G, v) ∧ f ∈ M ∩ E(G, v) ∧ e ≠ f := by\n                -- Use the fact that the cardinality is at least 2 to extract two distinct edges\n                have h₁₆ : (M ∩ E(G, v)).encard ≥ 2 := h₁₂\n                have h₁₇ : ∃ (e : β), e ∈ M ∩ E(G, v) := by\n                  by_contra h₁₈\n                  push_neg at h₁₈\n                  have h₁₉ : M ∩ E(G, v) = ∅ := by\n                    apply Set.eq_empty_of_forall_not_mem\n                    intro e he\n                    have h₂₀ := h₁₈ e\n                    tauto\n                  have h₂₀ : (M ∩ E(G, v)).encard = 0 := by\n                    rw [h₁₉]\n                    simp\n                  omega\n                obtain ⟨e, he⟩ := h₁₇\n                have h₂₁ : ∃ (f : β), f ∈ M ∩ E(G, v) ∧ f ≠ e := by\n                  by_contra h₂₂\n                  push_neg at h₂₂\n                  have h₂₃ : M ∩ E(G, v) ⊆ {e} := by\n                    intro f hf\n                    by_cases h₂₄ : f = e\n                    · simp_all\n                    · have h₂₅ := h₂₂ f\n                      simp_all\n                  have h₂₄ : (M ∩ E(G, v)).encard ≤ 1 := by\n                    calc\n                      (M ∩ E(G, v)).encard ≤ ({e} : Set β).encard := by\n                        apply encard_le_encard h₂₃\n                      _ = 1 := by simp\n                  omega\n                obtain ⟨f, hf₁, hf₂⟩ := h₂₁\n                refine' ⟨e, f, he, hf₁, _⟩\n                intro h₂₅\n                apply hf₂\n                simp_all\n              exact h₁₅\n            obtain ⟨e, f, he₁, he₂, he₃⟩ := h₁₁\n            have h₁₂ : e ∈ M := he₁.1\n            have h₁₃ : f ∈ M := he₂.1\n            have h₁₄ : e ≠ f := he₃\n            have h₁₅ : Disjoint (V(G, e)) (V(G, f)) := hM.disjoint h₁₂ h₁₃ h₁₄\n            have h₁₆ : e ∈ E(G, v) := he₁.2\n            have h₁₇ : f ∈ E(G, v) := he₂.2\n            have h₁₈ : v ∈ V(G, e) := by\n              simp_all [Graph.mem_V, Graph.mem_E]\n              <;> aesop\n            have h₁₉ : v ∈ V(G, f) := by\n              simp_all [Graph.mem_V, Graph.mem_E]\n              <;> aesop\n            have h₂₀ : v ∈ (V(G, e) ∩ V(G, f)) := by\n              exact ⟨h₁₈, h₁₉⟩\n            have h₂₁ : V(G, e) ∩ V(G, f) = ∅ := by\n              rw [disjoint_iff_inter_eq_empty] at h₁₅\n              exact h₁₅\n            rw [h₂₁] at h₂₀\n            simp at h₂₀\n            <;> aesop\n          exact h₈\n        have h₈ : (M' ∩ E(G, v)).encard ≤ 1 := by\n          -- Since M' is a matching, at most one edge in M' is incident to v\n          have h₉ : (M' ∩ E(G, v)).encard ≤ 1 := by\n            apply le_of_not_gt\n            intro h₁₀\n            have h₁₁ : (M' ∩ E(G, v)).encard > 1 := h₁₀\n            have h₁₂ : ∃ (e f : β), e ∈ M' ∩ E(G, v) ∧ f ∈ M' ∩ E(G, v) ∧ e ≠ f := by\n              -- There exist at least two distinct edges in M' ∩ E(G, v)\n              have h₁₃ : (M' ∩ E(G, v)).encard ≥ 2 := by\n                have h₁₄ : (M' ∩ E(G, v)).encard > 1 := h₁₁\n                have h₁₅ : (M' ∩ E(G, v)).encard ≥ 2 := by\n                  have h₁₆ : (M' ∩ E(G, v)).encard > 1 := h₁₁\n                  omega\n                exact h₁₅\n              -- Extract two distinct edges\n              have h₁₄ : ∃ (e f : β), e ∈ M' ∩ E(G, v) ∧ f ∈ M' ∩ E(G, v) ∧ e ≠ f := by\n                -- Use the fact that the cardinality is at least 2 to extract two distinct edges\n                have h₁₅ : (M' ∩ E(G, v)).encard ≥ 2 := h₁₃\n                have h₁₆ : ∃ (e : β), e ∈ M' ∩ E(G, v) := by\n                  by_contra h₁₇\n                  push_neg at h₁₇\n                  have h₁₈ : M' ∩ E(G, v) = ∅ := by\n                    apply Set.eq_empty_of_forall_not_mem\n                    intro e he\n                    have h₁₉ := h₁₇ e\n                    tauto\n                  have h₁₉ : (M' ∩ E(G, v)).encard = 0 := by\n                    rw [h₁₈]\n                    simp\n                  omega\n                obtain ⟨e, he⟩ := h₁₆\n                have h₂₀ : ∃ (f : β), f ∈ M' ∩ E(G, v) ∧ f ≠ e := by\n                  by_contra h₂₁\n                  push_neg at h₂₁\n                  have h₂₂ : M' ∩ E(G, v) ⊆ {e} := by\n                    intro f hf\n                    by_cases h₂₃ : f = e\n                    · simp_all\n                    · have h₂₄ := h₂₁ f\n                      simp_all\n                  have h₂₃ : (M' ∩ E(G, v)).encard ≤ 1 := by\n                    calc\n                      (M' ∩ E(G, v)).encard ≤ ({e} : Set β).encard := by\n                        apply encard_le_encard h₂₂\n                      _ = 1 := by simp\n                  omega\n                obtain ⟨f, hf₁, hf₂⟩ := h₂₀\n                refine' ⟨e, f, he, hf₁, _⟩\n                intro h₂₄\n                apply hf₂\n                simp_all\n              exact h₁₄\n            obtain ⟨e, f, he₁, he₂, he₃⟩ := h₁₂\n            have h₁₃ : e ∈ M' := he₁.1\n            have h₁₄ : f ∈ M' := he₂.1\n            have h₁₅ : e ≠ f := he₃\n            have h₁₆ : Disjoint (V(G, e)) (V(G, f)) := hM'.disjoint h₁₃ h₁₄ h₁₅\n            have h₁₇ : e ∈ E(G, v) := he₁.2\n            have h₁₈ : f ∈ E(G, v) := he₂.2\n            have h₁₉ : v ∈ V(G, e) := by\n              simp_all [Graph.mem_V, Graph.mem_E]\n              <;> aesop\n            have h₂₀ : v ∈ V(G, f) := by\n              simp_all [Graph.mem_V, Graph.mem_E]\n              <;> aesop\n            have h₂₁ : v ∈ (V(G, e) ∩ V(G, f)) := by\n              exact ⟨h₁₉, h₂₀⟩\n            have h₂₂ : V(G, e) ∩ V(G, f",
      "\n  have h₁ : (hM.restrict₂ hM').MaxDegreeLE 2 := by\n    apply maxDegreeLE_of_dpair_le\n    intro v\n    have h₂ : v ∈ (hM.restrict₂ hM').V → (hM.restrict₂ hM').E(v).encard ≤ 2 := by\n      intro hv\n      have h₃ : (hM.restrict₂ hM').E(v) = Set.image (fun e => (⟨v, himp (e.1 : β) _⟩ : β, ⟨v, himp (e.1 : β) _⟩ : β)) (G.E(v) ∩ (M ∆ M')) := by\n        -- Prove that the edges in the restricted graph are the same as in the original graph but filtered by the symmetric difference\n        dsimp [hM.restrict₂, hM'.1.restrict, Graph.EdgeSet, WGraph.loopRemove, Set.compl]\n        <;>\n        (try decide) <;>\n        (try aesop) <;>\n        (try simp_all [Set.image, Set.filter, Set.mem_inter_iff, Set.mem_diff, Set.mem_singleton_iff]) <;>\n        (try\n          {\n            ext ⟨e₁, e₂⟩\n            simp_all [Set.mem_diff, Set.mem_singleton_iff]\n            <;>\n            aesop\n          })\n        <;>\n        (try\n          {\n            ext ⟨e₁, e₂⟩\n            simp_all [Set.mem_diff, Set.mem_singleton_iff]\n            <;>\n            aesop\n          })\n      rw [h₃]\n      have h₄ : (Set.image (fun e => (⟨v, himp (e.1 : β) _⟩ : β, ⟨v, himp (e.1 : β) _⟩ : β)) (G.E(v) ∩ (M ∆ M')) : Set (β × β)).encard ≤ 2 := by\n        -- Prove that the number of edges is at most 2\n        have h₅ : (G.E(v) ∩ (M ∆ M') : Set β).encard ≤ 2 := by\n          -- Use the fact that the number of edges in the original graph is at most 2\n          have h₅₁ : (G.E(v) ∩ (M ∆ M') : Set β) ⊆ (M ∆ M') := by\n            intro x hx\n            simp_all [Set.mem_inter_iff]\n          have h₅₂ : (M ∆ M').encard ≤ 2 := by\n            -- Prove that the symmetric difference of M and M' has at most 2 edges\n            have h₅₃ : M ∆ M' ⊆ (M ∪ M') := by\n              intro x hx\n              simp only [Set.mem_union, Set.mem_symmDiff] at hx ⊢\n              aesop\n            have h₅₄ : (M ∪ M').encard ≤ 2 := by\n              -- Use the fact that M and M' are matchings\n              have h₅₅ : M ⊆ G.E := hM.1\n              have h₅₆ : M' ⊆ G.E := hM'.1\n              have h₅₇ : (M ∪ M') ⊆ G.E := Set.union_subset h₅₅ h₅₆\n              have h₅₈ : (M ∪ M').encard ≤ (G.E).encard := by\n                apply encard_le_of_subset h₅₇\n              have h₅₉ : (G.E).encard ≤ 2 := by\n                -- Since G is a simple graph, the number of edges is at most 2\n                have h₅₁₀ : (G.E).encard ≤ 2 := by\n                  -- Use the fact that G is a simple graph\n                  have h₅₁₁ : (G.E).encard ≤ 2 := by\n                    -- Since G is a simple graph, the number of edges is at most 2\n                    simp_all [Graph.EdgeSet, WGraph.loopRemove]\n                    <;>\n                    (try decide) <;>\n                    (try aesop) <;>\n                    (try simp_all [Set.image, Set.filter, Set.mem_inter_iff, Set.mem_diff, Set.mem_singleton_iff]) <;>\n                    (try\n                      {\n                        ext ⟨e₁, e₂⟩\n                        simp_all [Set.mem_diff, Set.mem_singleton_iff]\n                        <;>\n                        aesop\n                      })\n                  exact h₅₁₁\n                exact h₅₁₀\n              have h₅₁₀ : (M ∪ M').encard ≤ 2 := by\n                linarith\n              exact h₅₁₀\n            have h₅₁₁ : (M ∆ M').encard ≤ (M ∪ M').encard := by\n              apply encard_le_of_subset h₅₃\n            linarith\n          have h₅₅ : (G.E(v) ∩ (M ∆ M') : Set β).encard ≤ (M ∆ M').encard := by\n            apply encard_le_of_subset\n            intro x hx\n            simp_all [Set.mem_inter_iff]\n          linarith\n        -- Prove that the number of edges in the image is at most 2\n        have h₆ : (Set.image (fun e => (⟨v, himp (e.1 : β) _⟩ : β, ⟨v, himp (e.1 : β) _⟩ : β)) (G.E(v) ∩ (M ∆ M')) : Set (β × β)).encard ≤ (G.E(v) ∩ (M ∆ M') : Set β).encard := by\n          apply Set.encard_image_le\n        linarith\n      exact h₄\n    -- Use the fact that the number of edges is at most 2 to prove the maximum degree is at most 2\n    by_cases hv : v ∈ (hM.restrict₂ hM').V\n    · have h₃ : (hM.restrict₂ hM').E(v).encard ≤ 2 := h₂ hv\n      simpa using h₃\n    · have h₃ : (hM.restrict₂ hM').E(v).encard = 0 := by\n        have h₄ : (hM.restrict₂ hM').E(v) = ∅ := by\n          -- If v is not in the vertex set of the restricted graph, then it has no edges\n          have h₅ : v ∉ (hM.restrict₂ hM').V := hv\n          have h₆ : (hM.restrict₂ hM').E(v) = ∅ := by\n            simp_all [hM.restrict₂, hM'.1.restrict, Graph.EdgeSet, WGraph.loopRemove, Set.compl]\n            <;>\n            (try decide) <;>\n            (try aesop) <;>\n            (try simp_all [Set.image, Set.filter, Set.mem_inter_iff, Set.mem_diff, Set.mem_singleton_iff]) <;>\n            (try\n              {\n                ext ⟨e₁, e₂⟩\n                simp_all [Set.mem_diff, Set.mem_singleton_iff]\n                <;>\n                aesop\n              })\n          exact h₆\n        rw [h₄]\n        simp\n      have h₄ : (hM.restrict₂ hM').E(v).encard ≤ 2 := by\n        linarith\n      simpa using h₄\n  exact h₁",
      "\n  rw [show hM.restrict₂ hM' = G ↾ (M ∆ M') |>.loopRemove by rfl]\n  have h₁ : (G ↾ (M ∆ M')).MaxDegreeLE 2 := by\n    have h₂ : ∀ (v : α), (G ↾ (M ∆ M')).eDegree v ≤ 2 := by\n      intro v\n      have h₃ : (G ↾ (M ∆ M')).eDegree v = (M ∆ M').encard (G.invImage v ∩ (M ∆ M')) := by\n        simp [eDegree]\n        <;> rfl\n      rw [h₃]\n      have h₄ : (M ∆ M').encard (G.invImage v ∩ (M ∆ M')) ≤ 2 := by\n        have h₅ : (M ∆ M').encard (G.invImage v ∩ (M ∆ M')) = (M △ M').encard (G.invImage v ∩ (M △ M')) := by rfl\n        rw [h₅]\n        have h₆ : (G.invImage v ∩ (M △ M')).Finite := by\n          apply Set.Finite.subset (M △ M').toFinite\n          intro x hx\n          simp only [Set.mem_inter_iff] at hx\n          exact hx.2\n        have h₇ : (M △ M').encard (G.invImage v ∩ (M △ M')) = (G.invImage v ∩ (M △ M')).encard := by rfl\n        rw [h₇]\n        have h₈ : (G.invImage v ∩ (M △ M')).encard ≤ 2 := by\n          -- Here we use the fact that for any vertex v, the number of edges in the symmetric difference incident to v is at most 2.\n          -- This is because the edges incident to v in M and M' are disjoint and each can contribute at most one edge to the symmetric difference.\n          have h₉ : G.invImage v ∩ (M △ M') ⊆ G.invImage v ∩ (M ∪ M') := by\n            intro x hx\n            simp only [Set.mem_inter_iff] at hx ⊢\n            have h₁₀ : x ∈ G.invImage v := hx.1\n            have h₁₁ : x ∈ M △ M' := hx.2\n            have h₁₂ : x ∈ M ∪ M' := by\n              simp only [Set.mem_union, Set.mem_singleton_iff, dif_eq_left, dif_eq_right] at h₁₁ ⊢\n              aesop\n            exact ⟨h₁₀, h₁₂⟩\n          have h₁₀ : (G.invImage v ∩ (M △ M')).encard ≤ (G.invImage v ∩ (M ∪ M')).encard := by\n            apply encard_le_of_subset h₉\n          have h₁₁ : (G.invImage v ∩ (M ∪ M')).encard ≤ 2 := by\n            have h₁₂ : (G.invImage v ∩ M).encard ≤ 1 := by\n              -- Each vertex can have at most one edge in a matching\n              have h₁₃ : (G.invImage v ∩ M).encard = (M ∩ G.invImage v).encard := by\n                rw [Set.inter_comm]\n                <;> simp [Set.inter_comm]\n              rw [h₁₃]\n              have h₁₄ : (M ∩ G.invImage v).encard ≤ 1 := by\n                -- Since M is a matching, the number of edges incident to v in M is at most 1\n                have h₁₅ : (M ∩ G.invImage v) ⊆ M := by\n                  exact Set.inter_subset_left\n                have h₁₆ : (M ∩ G.invImage v).Subsingleton := by\n                  intro e₁ he₁ e₂ he₂\n                  have h₁₇ : e₁ ∈ M := by\n                    exact h₁₅ he₁\n                  have h₁₈ : e₂ ∈ M := by\n                    exact h₁₅ he₂\n                  have h₁₉ : e₁ ∈ G.invImage v := by\n                    simp only [Set.mem_inter_iff] at he₁\n                    exact he₁.2\n                  have h₂₀ : e₂ ∈ G.invImage v := by\n                    simp only [Set.mem_inter_iff] at he₂\n                    exact he₂.2\n                  have h₂₁ : v ∈ G.invImage e₁ := by\n                    simp_all [Set.mem_invImage, Graph.mem_invImage]\n                    <;>\n                    (try simp_all [Graph.val_invImage]) <;>\n                    (try aesop)\n                  have h₂₂ : v ∈ G.invImage e₂ := by\n                    simp_all [Set.mem_invImage, Graph.mem_invImage]\n                    <;>\n                    (try simp_all [Graph.val_invImage]) <;>\n                    (try aesop)\n                  have h₂₃ : e₁ ≠ e₂ → Disjoint (G.val e₁) (G.val e₂) := by\n                    intro hne\n                    exact hM.disjoint h₁₇ h₁₈ hne\n                  by_contra hne\n                  have h₂₄ : e₁ ≠ e₂ := hne\n                  have h₂₅ : Disjoint (G.val e₁) (G.val e₂) := h₂₃ h₂₄\n                  have h₂₆ : v ∈ G.val e₁ := by\n                    simp_all [Set.mem_invImage, Graph.mem_invImage]\n                    <;>\n                    (try simp_all [Graph.val_invImage]) <;>\n                    (try aesop)\n                  have h₂₇ : v ∈ G.val e₂ := by\n                    simp_all [Set.mem_invImage, Graph.mem_invImage]\n                    <;>\n                    (try simp_all [Graph.val_invImage]) <;>\n                    (try aesop)\n                  have h₂₈ : (G.val e₁ ∩ G.val e₂).Nonempty := by\n                    exact ⟨v, h₂₆, h₂₇⟩\n                  have h₂₉ : Disjoint (G.val e₁) (G.val e₂) := h₂₅\n                  have h₃₀ : (G.val e₁ ∩ G.val e₂).Empty := by\n                    rw [Set.eq_empty_iff_forall_not_mem]\n                    intro x hx\n                    have h₃₁ : x ∈ G.val e₁ := by\n                      exact hx.1\n                    have h₃₂ : x ∈ G.val e₂ := by\n                      exact hx.2\n                    have h₃₃ : Disjoint (G.val e₁) (G.val e₂) := h₂₉\n                    have h₃₄ : x ∉ G.val e₁ ∩ G.val e₂ := by\n                      simp_all [Set.disjoint_left]\n                    contradiction\n                  contradiction\n                have h₂₀ : (M ∩ G.invImage v).encard ≤ 1 := by\n                  rw [encard_le_one_iff_subsingleton]\n                  exact h₁₆\n                exact h₂₀\n              exact h₁₄\n            have h₁₅ : (G.invImage v ∩ M').encard ≤ 1 := by\n              -- Similarly for M'\n              have h₁₆ : (G.invImage v ∩ M').encard = (M' ∩ G.invImage v).encard := by\n                rw [Set.inter_comm]\n                <;> simp [Set.inter_comm]\n              rw [h₁₆]\n              have h₁₇ : (M' ∩ G.invImage v).encard ≤ 1 := by\n                -- Since M' is a matching, the number of edges incident to v in M' is at most 1\n                have h₁₈ : (M' ∩ G.invImage v) ⊆ M' := by\n                  exact Set.inter_subset_left\n                have h₁₉ : (M' ∩ G.invImage v).Subsingleton := by\n                  intro e₁ he₁ e₂ he₂\n                  have h₂₀ : e₁ ∈ M' := by\n                    exact h₁₈ he₁\n                  have h₂₁ : e₂ ∈ M' := by\n                    exact h₁₈ he₂\n                  have h₂₂ : e₁ ∈ G.invImage v := by\n                    simp only [Set.mem_inter_iff] at he₁\n                    exact he₁.2\n                  have h₂₃ : e₂ ∈ G.invImage v := by\n                    simp only [Set.mem_inter_iff] at he₂\n                    exact he₂.2\n                  have h₂₄ : v ∈ G.invImage e₁ := by\n                    simp_all [Set.mem_invImage, Graph.mem_invImage]\n                    <;>\n                    (try simp_all [Graph.val_invImage]) <;>\n                    (try aesop)\n                  have h₂₅ : v ∈ G.invImage e₂ := by\n                    simp_all [Set.mem_invImage, Graph.mem_invImage]\n                    <;>\n                    (try simp_all [Graph.val_invImage]) <;>\n                    (try aesop)\n                  have h₂₆ : e₁ ≠ e₂ → Disjoint (G.val e₁) (G.val e₂) := by\n                    intro hne\n                    exact hM'.disjoint h₂₀ h₂₁ hne\n                  by_contra hne\n                  have h₂₇ : e₁ ≠ e₂ := hne\n                  have h₂₈ : Disjoint (G.val e₁) (G.val e₂) := h₂₆ h₂₇\n                  have h₂₉ : v ∈ G.val e₁ := by\n                    simp_all [Set.mem_invImage, Graph.mem_invImage]\n                    <;>\n                    (try simp_all [Graph.val_invImage]) <;>\n                    (try aesop)\n                  have h₃₀ : v ∈ G.val e₂ := by\n                    simp_all [Set.mem_invImage, Graph.mem_invImage]\n                    <;>\n                    (try simp_all [Graph.val_invImage]) <;>\n                    (try aesop)\n                  have h₃₁ : (G.val e₁ ∩ G.val e₂).Nonempty := by\n                    exact ⟨v, h₂₉, h₃₀⟩\n                  have h₃₂ : Disjoint (G.val e₁) (G.val e₂) := h₂₈\n                  have h₃₃ : (G.val e₁ ∩ G.val e₂).Empty := by\n                    rw [Set.eq_empty_iff_forall_not_mem]\n                    intro x hx\n                    have h₃₄ : x ∈ G.val e₁ := by\n                      exact hx.1\n                    have h₃₅ : x ∈ G.val e₂ := by\n                      exact hx.2\n                    have h₃₆ : Disjoint (G.val e₁) (G.val e₂) := h₃₂\n                    have h₃₇ : x ∉ G.val e₁ ∩ G.val e₂ := by\n                      simp_all [Set.disjoint_left]\n                    contradiction\n                  contradiction\n                have h₃₀ : (M' ∩ G.invImage v).encard ≤ 1 := by\n                  rw [encard_le_one_iff_subsingleton]\n                  exact h₁₉\n                exact h₃₀\n              exact h₁₇\n            have h₁₈ : (G.invImage v ∩ (M ∪ M')).encard ≤ 2 := by\n              have h₁₉ : (G.invImage v ∩ (M ∪ M')) ⊆ (G.invImage v ∩ M) ∪ (G.invImage v ∩ M') := by\n                intro x hx\n                simp only [Set.mem_inter_iff, Set.mem_union] at hx ⊢\n                tauto\n              have h₂₀ : (G.invImage v ∩ (M ∪ M')).encard ≤ ((G.invImage v ∩ M) ∪ (G.invImage v ∩ M')).encard := by\n                apply encard_le_of_subset h₁₉\n              have h₂₁ : ((G.invImage v ∩ M) ∪ (G.invImage v ∩ M')).encard ≤ 2 := by\n                have h₂₂ : (G.invImage v ∩ M).encard ≤ 1 := h₁₂\n                have h₂₃ : (G.invImage v ∩ M').encard ≤ 1 := h₁₅\n                have h₂₄ : ((G.invImage v ∩ M) ∪ (G.invImage v ∩ M')).encard ≤ (G.invImage v ∩ M).encard + (G.invImage v ∩ M').encard := by\n                  calc\n                    ((G.invImage v ∩ M) ∪ (G.invImage v ∩ M')).encard ≤ (G.invImage v ∩ M).encard + (G.invImage v ∩ M').encard := by\n                      -- Use the fact that the union of two sets has cardinality at most the sum of their cardinalities\n                      have h₂₅ : ((G.invImage v ∩ M) ∪ (G.invImage v ∩ M')).encard ≤ (G.invImage v ∩ M).encard + (G.invImage v ∩ M').encard :=",
      "\n  have h₁ : (hM.restrict₂ hM').MaxDegreeLE 2 := by\n    have h₂ : ∀ (v : α), (E (hM.restrict₂ hM', v)).encard ≤ 2 := by\n      intro v\n      have h₃ : (E (hM.restrict₂ hM', v)).encard = (E (G, v) ∩ (M ∆ M')).encard := by\n        simp [hM.restrict₂, Graph.ext_iff, Graph.E, Set.mem_inter_iff]\n        <;>\n          aesop\n      rw [h₃]\n      have h₄ : (E (G, v) ∩ (M ∆ M')).encard ≤ 2 := by\n        have h₅ : (E (G, v) ∩ (M ∆ M')).encard ≤ 2 := by\n          -- Use the fact that the symmetric difference of two matchings can have at most two edges incident to any vertex\n          have h₆ : (E (G, v) ∩ (M ∆ M')).encard ≤ 2 := by\n            -- Prove that the symmetric difference of two matchings cannot have more than two edges incident to any vertex\n            have h₇ : (E (G, v) ∩ (M ∆ M')).encard ≤ (E (G, v) ∩ M).encard + (E (G, v) ∩ M').encard := by\n              calc\n                (E (G, v) ∩ (M ∆ M')).encard ≤ (E (G, v) ∩ (M ∪ M')).encard := by\n                  apply Set.encard_mono\n                  intro x hx\n                  simp only [Set.mem_inter_iff, Set.mem_union, Set.mem_diff, Set.mem_singleton_iff] at hx ⊢\n                  tauto\n                _ ≤ (E (G, v) ∩ M).encard + (E (G, v) ∩ M').encard := by\n                  have h₈ : (E (G, v) ∩ (M ∪ M')).encard ≤ (E (G, v) ∩ M).encard + (E (G, v) ∩ M').encard := by\n                    calc\n                      (E (G, v) ∩ (M ∪ M')).encard = ((E (G, v) ∩ M) ∪ (E (G, v) ∩ M')).encard := by\n                        simp [Set.inter_distrib_left]\n                      _ ≤ (E (G, v) ∩ M).encard + (E (G, v) ∩ M').encard := by\n                        apply Set.encard_union_le\n                  exact h₈\n            have h₉ : (E (G, v) ∩ M).encard ≤ 1 := by\n              -- Since M is a matching, at most one edge in M is incident to v\n              have h₁₀ : (M ∩ E (G, v)).Subsingleton := hM.subsingleton_inc v\n              have h₁₁ : (E (G, v) ∩ M).encard ≤ 1 := by\n                have h₁₂ : (E (G, v) ∩ M).encard = (M ∩ E (G, v)).encard := by\n                  rw [Set.inter_comm]\n                  <;> simp [Set.encard_comm]\n                rw [h₁₂]\n                have h₁₃ : (M ∩ E (G, v)).encard ≤ 1 := by\n                  have h₁₄ : (M ∩ E (G, v)).Subsingleton := hM.subsingleton_inc v\n                  have h₁₅ : (M ∩ E (G, v)).encard ≤ 1 := by\n                    apply Set.encard_le_one_iff.mpr\n                    exact h₁₄\n                  exact h₁₅\n                exact h₁₃\n              exact h₁₁\n            have h₁₀ : (E (G, v) ∩ M').encard ≤ 1 := by\n              -- Since M' is a matching, at most one edge in M' is incident to v\n              have h₁₁ : (M' ∩ E (G, v)).Subsingleton := hM'.subsingleton_inc v\n              have h₁₂ : (E (G, v) ∩ M').encard ≤ 1 := by\n                have h₁₃ : (E (G, v) ∩ M').encard = (M' ∩ E (G, v)).encard := by\n                  rw [Set.inter_comm]\n                  <;> simp [Set.encard_comm]\n                rw [h₁₃]\n                have h₁₄ : (M' ∩ E (G, v)).encard ≤ 1 := by\n                  have h₁₅ : (M' ∩ E (G, v)).Subsingleton := hM'.subsingleton_inc v\n                  have h₁₆ : (M' ∩ E (G, v)).encard ≤ 1 := by\n                    apply Set.encard_le_one_iff.mpr\n                    exact h₁₅\n                  exact h₁₆\n                exact h₁₄\n              exact h₁₂\n            have h₁₁ : (E (G, v) ∩ (M ∆ M')).encard ≤ (E (G, v) ∩ M).encard + (E (G, v) ∩ M').encard := by\n              exact h₇\n            have h₁₂ : (E (G, v) ∩ M).encard + (E (G, v) ∩ M').encard ≤ 1 + 1 := by\n              have h₁₃ : (E (G, v) ∩ M).encard ≤ 1 := h₉\n              have h₁₄ : (E (G, v) ∩ M').encard ≤ 1 := h₁₀\n              have h₁₅ : (E (G, v) ∩ M).encard + (E (G, v) ∩ M').encard ≤ 1 + 1 := by\n                calc\n                  (E (G, v) ∩ M).encard + (E (G, v) ∩ M').encard ≤ 1 + 1 := by\n                    gcongr <;> simp_all [Nat.cast_le]\n                  _ = 1 + 1