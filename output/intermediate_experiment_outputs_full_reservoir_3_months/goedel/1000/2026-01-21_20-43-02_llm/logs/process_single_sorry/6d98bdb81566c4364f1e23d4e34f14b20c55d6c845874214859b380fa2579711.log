      "\n  have h₁ : (hM.restrict₂ hM').MaxDegreeLE 2 := by\n    have h₂ : ∀ (v : α), (hM.restrict₂ hM').eDegree v ≤ 2 := by\n      intro v\n      have h₃ : (hM.restrict₂ hM').eDegree v = (E ((G ↾ M ∆ M') |>.loopRemove), v).encard := by\n        simp [eDegree_eq_encard_inc, E_inc]\n        <;>\n        simp_all [Graph.restrict₂, EdgeSet.edgs, Set.ext_iff]\n        <;>\n        aesop\n      rw [h₃]\n      have h₄ : (E ((G ↾ M ∆ M') |>.loopRemove), v).encard ≤ 2 := by\n        -- Use the fact that the number of edges in the symmetric difference is at most 2\n        have h₅ : (E ((G ↾ M ∆ M') |>.loopRemove), v).encard ≤ (E (G ↾ M ∆ M'), v).encard := by\n          apply le_of_subset\n          intro e\n          simp [EdgeSet.mem_inc]\n          <;>\n          aesop\n        have h₆ : (E (G ↾ M ∆ M'), v).encard ≤ 2 := by\n          -- Use the fact that the number of edges in the symmetric difference is at most 2\n          have h₇ : (E (G ↾ M ∆ M'), v) ⊆ (E (G ↾ M), v) ∪ (E (G ↾ M'), v) := by\n            intro e\n            simp [EdgeSet.mem_inc, EdgeSet.mem_left, EdgeSet.mem_right, Mset.mem_prop]\n            <;>\n            (try aesop) <;>\n            (try {\n              by_cases h : e ∈ M <;> by_cases h' : e ∈ M' <;> simp_all [h, h', Set.mem_symmDiff]\n              <;> aesop\n            })\n            <;>\n            (try {\n              aesop\n            })\n          have h₈ : (E (G ↾ M), v).encard ≤ 1 := by\n            -- Use the fact that the number of edges in a matching incident to a vertex is at most 1\n            have h₉ : (E (G ↾ M), v).encard ≤ 1 := by\n              calc\n                (E (G ↾ M), v).encard = (M ∩ E (G, v)).encard := by\n                  simp [EdgeSet.mem_inc, EdgeSet.mem_left, EdgeSet.mem_right, Mset.mem_prop]\n                  <;>\n                  aesop\n                _ ≤ 1 := by\n                  have h₁₀ : (M ∩ E (G, v)).encard ≤ 1 := by\n                    apply hM.degree_le_one\n                  exact h₁₀\n            exact h₉\n          have h₉ : (E (G ↾ M'), v).encard ≤ 1 := by\n            -- Use the fact that the number of edges in a matching incident to a vertex is at most 1\n            have h₁₀ : (E (G ↾ M'), v).encard ≤ 1 := by\n              calc\n                (E (G ↾ M'), v).encard = (M' ∩ E (G, v)).encard := by\n                  simp [EdgeSet.mem_inc, EdgeSet.mem_left, EdgeSet.mem_right, Mset.mem_prop]\n                  <;>\n                  aesop\n                _ ≤ 1 := by\n                  have h₁₁ : (M' ∩ E (G, v)).encard ≤ 1 := by\n                    apply hM'.degree_le_one\n                  exact h₁₁\n            exact h₁₀\n          have h₁₀ : (E (G ↾ M ∆ M'), v).encard ≤ 2 := by\n            calc\n              (E (G ↾ M ∆ M'), v).encard ≤ ((E (G ↾ M), v) ∪ (E (G ↾ M'), v)).encard := by\n                apply h₇.encard_le\n              _ ≤ (E (G ↾ M), v).encard + (E (G ↾ M'), v).encard := by\n                apply (encard_union_le (E (G ↾ M), v) (E (G ↾ M'), v)).trans\n                <;>\n                simp [add_comm]\n              _ ≤ 1 + 1 := by\n                gcongr <;>\n                simp_all [h₈, h₉]\n                <;>\n                linarith\n              _ = 2 := by norm_num\n          exact h₁₀\n        calc\n          (E (G ↾ M ∆ M'), v).encard ≤ 2 := h₆\n          _ = 2 := by norm_num\n      have h₅ : (E ((G ↾ M ∆ M') |>.loopRemove), v).encard ≤ (E (G ↾ M ∆ M'), v).encard := by\n        apply le_of_subset\n        intro e\n        simp [EdgeSet.mem_inc]\n        <;>\n        aesop\n      linarith\n    -- Use the fact that the degree of each vertex is at most 2 to conclude that the maximum degree is at most 2\n    simpa [MaxDegreeLE] using h₂\n  exact h₁",
      "\n   Let me think more carefully:\n\n   - For any vertex `v`, the edges incident to `v` in `M` are at most 1, say `e`.\n   - Similarly for `M'`, say `f`.\n   - The edges incident to `v` in `M ∆ M'` are either in `M` or `M'`, but not in both.\n   - So it can contain `e` if `e ∉ M'`, and it can contain `f` if `f ∉ M`.\n   - Therefore, there can be at most two such edges, `e` and `f`.\n\n   But",
      "\n  have h : ∀ v : α, (hM.restrict₂ hM').eDegree v ≤ 2 := by\n    intro v\n    have h₁ : (hM.restrict₂ hM').eDegree v ≤ 2 := by\n      have h₂ : (hM.restrict₂ hM').eDegree v = ( ( (G ↾ (M ∆ M')).vAdj v ).encard ) := by\n        simp [eDegree_eq_encard_vAdj, DegreeDegree]\n      have h₃ : ( (G ↾ (M ∆ M')).vAdj v ).encard ≤ 2 := by\n        have h₄ : ( (G ↾ (M ∆ M')).vAdj v ) ⊆ (G.vAdj v) := by\n          intro e he\n          simp [Graph.mem_vAdj, SetLike.mem_coe, Subgraph.mem_coe] at he ⊢\n          <;> aesop\n        have h₅ : (G.vAdj v).encard ≤ 2 := by\n          have h₆ : (G.vAdj v).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n            have h₇ : G.vAdj v ⊆ (E(G, v)) := by\n              intro e he\n              simp [Graph.mem_vAdj, SetLike.mem_coe] at he ⊢\n              <;> aesop\n            have h₈ : E(G, v) = (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) := by\n              ext e\n              simp [Set.union_comm]\n              <;> aesop\n            have h₉ : (G.vAdj v) ⊆ (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) := by\n              intro e he\n              have h₁₀ : e ∈ E(G, v) := by\n                simp [Graph.mem_vAdj, SetLike.mem_coe] at he ⊢\n                <;> aesop\n              rw [h₈] at *\n              aesop\n            have h₁₀ : (G.vAdj v) ⊆ (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) := by\n              intro e he\n              have h₁₁ : e ∈ E(G, v) := by\n                simp [Graph.mem_vAdj, SetLike.mem_coe] at he ⊢\n                <;> aesop\n              rw [h₈] at *\n              aesop\n            have h₁₁ : (G.vAdj v).encard ≤ ( (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) ).encard := by\n              exact encard_mono h₉\n            have h₁₂ : ( (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) ).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n              have h₁₃ : ( (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) ) ⊆ (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) := by\n                simp\n              have h₁₄ : (M ∪ M') ∩ E(G, v) = (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) := by\n                ext e\n                simp [Set.mem_inter_iff, Set.mem_union]\n                <;> tauto\n              have h₁₅ : ( (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) ).encard ≤ ( (M ∪ M') ∩ E(G, v) ).encard + ( (M ∪ M')ᶜ ∩ E(G, v) ).encard := by\n                calc\n                  ( (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) ).encard ≤ ( (M ∪ M') ∩ E(G, v) ).encard + ( (M ∪ M')ᶜ ∩ E(G, v) ).encard := by\n                    apply encard_union_le\n                  _ = ( (M ∪ M') ∩ E(G, v) ).encard + ( (M ∪ M')ᶜ ∩ E(G, v) ).encard := by rfl\n              have h₁₆ : ( (M ∪ M') ∩ E(G, v) ).encard = ( (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ).encard := by\n                rw [h₁₄]\n              have h₁₇ : ( (M ∪ M')ᶜ ∩ E(G, v) ).encard ≤ 0 := by\n                have h₁₈ : (M ∪ M')ᶜ ∩ E(G, v) = ∅ := by\n                  apply Set.eq_empty_of_forall_not_mem\n                  intro e he\n                  have h₁₉ : e ∈ (M ∪ M')ᶜ := by simp_all [Set.mem_inter_iff]\n                  have h₂₀ : e ∈ E(G, v) := by simp_all [Set.mem_inter_iff]\n                  have h₂₁ : e ∉ M ∪ M' := by simp_all [Set.mem_compl_iff]\n                  have h₂₂ : e ∈ E(G) := by\n                    have h₂₃ : e ∈ E(G, v) := by simp_all [Set.mem_inter_iff]\n                    have h₂₄ : E(G, v) ⊆ E(G) := by\n                      intro e he\n                      simp [Graph.mem_vAdj, SetLike.mem_coe] at he ⊢\n                      <;> aesop\n                    exact h₂₄ h₂₃\n                  have h₂₃ : e ∈ M ∪ M' := by\n                    have h₂₄ : hM.subset : M ⊆ E(G) := hM.subset\n                    have h₂₅ : hM'.subset : M' ⊆ E(G) := hM'.subset\n                    have h₂₆ : M ∪ M' ⊆ E(G) := by\n                      apply Set.union_subset\n                      · exact h₂₄\n                      · exact h₂₅\n                    have h₂₇ : e ∈ E(G) := h₂₂\n                    have h₂₈ : e ∈ M ∪ M' := by\n                      have h₂₉ : e ∈ E(G) := h₂₂\n                      have h₃₀ : M ∪ M' ⊆ E(G) := h₂₆\n                      have h₃₁ : e ∈ M ∪ M' := by\n                        by_cases h₃₂ : e ∈ M\n                        · exact Or.inl h₃₂\n                        · by_cases h₃₃ : e ∈ M'\n                          · exact Or.inr h₃₃\n                          · exfalso\n                            have h₃₄ : e ∉ M := h₃₂\n                            have h₃₅ : e ∉ M' := h₃₃\n                            have h₃₆ : e ∈ E(G) := h₂₂\n                            have h₃₇ : e ∉ M ∪ M' := by\n                              simp_all [Set.mem_union]\n                            simp_all [Set.mem_union]\n                      exact h₃₁\n                    exact h₂₈\n                  simp_all [Set.mem_union]\n                rw [h₁₈]\n                simp\n              have h₁₈ : ( (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) ).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                calc\n                  ( (M ∪ M') ∩ E(G, v) ∪ ( (M ∪ M')ᶜ ∩ E(G, v) ) ).encard ≤ ( (M ∪ M') ∩ E(G, v) ).encard + ( (M ∪ M')ᶜ ∩ E(G, v) ).encard := h₁₅\n                  _ = ( (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ).encard + ( (M ∪ M')ᶜ ∩ E(G, v) ).encard := by rw [h₁₆]\n                  _ ≤ ( (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ).encard + 0 := by\n                    have h₁₉ : ( (M ∪ M')ᶜ ∩ E(G, v) ).encard ≤ 0 := h₁₇\n                    have h₂₀ : ( (M ∪ M')ᶜ ∩ E(G, v) ).encard ≥ 0 := by positivity\n                    have h₂₁ : ( (M ∪ M')ᶜ ∩ E(G, v) ).encard = 0 := by\n                      linarith\n                    rw [h₂₁]\n                    <;> simp\n                  _ = ( (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ).encard := by simp\n                  _ ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                    have h₂₂ : ( (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                      calc\n                        ( (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) ).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                          apply encard_union_le\n                        _ = (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by rfl\n                    exact h₂₂\n                  _ = (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by rfl\n              exact h₁₈\n            have h₁₃ : (G.vAdj v).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n              linarith\n            exact h₁₃\n          have h₈ : (M ∩ E(G, v)).encard ≤ 1 := by\n            have h₉ : (M ∩ E(G, v)).encard ≤ 1 := by\n              have h₁₀ : (M ∩ E(G, v)).encard ≤ 1 := hM.degree_le_one v\n              exact h₁₀\n            exact h₉\n          have h₉ : (M' ∩ E(G, v)).encard ≤ 1 := by\n            have h₁₀ : (M' ∩ E(G, v)).encard ≤ 1 := hM'.degree_le_one v\n            exact h₁₀\n          have h₁₀ : (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard ≤ 2 := by\n            linarith\n          have h₁₁ : (G.vAdj v).encard ≤ 2 := by\n            linarith\n          exact h₁₁\n        have h₁₂ : ( (G ↾ (M ∆ M')).vAdj v ).encard ≤ (G.vAdj v).encard := by\n          have h₁₃ : ( (G ↾ (M ∆ M')).vAdj v ) ⊆ (G.vAdj v) := by\n            intro e he\n            simp [Graph.mem_vAdj, SetLike.mem_coe, Subgraph.mem_coe] at he ⊢\n            <;> aesop\n          exact encard_mono h₁₃\n        have h₁₄ : ( (G ↾ (M ∆ M')).vAdj v ).encard ≤ 2 := by\n          linarith\n        exact h₁₄\n      rw [h₂]\n      exact h₃\n    exact h₁\n  rw [MaxDegreeLE]\n  intro v\n  have h₁ := h v\n  simp_all [Nat.cast_le]\n  <;>\n  omega",
      "\n  -- Use the fact that the maximum degree in the symmetric difference of two matchings is at most 2.\n  -- This is because each vertex can be incident to at most one edge in each matching, and thus in their symmetric difference.\n  have h₁ : (hM.restrict₂ hM').MaxDegreeLE 2 := by\n    rw [show (hM.restrict₂ hM') = (G ↾ (M ∆ M')).loopRemove by rfl]\n    -- We use the fact that the maximum degree of G ↾ (M ∆ M') is at most 2 and the loop removal does not increase the degree.\n    have h₂ : (G ↾ (M ∆ M')).MaxDegreeLE 2 := by\n      -- The maximum degree of G ↾ (M ∆ M') is at most 2 because each vertex can be incident to at most two edges in M ∆ M'.\n      have h₃ : ∀ v : α, (E(G ↾ (M ∆ M'), v)).encard ≤ 2 := by\n        intro v\n        -- For each vertex v, the number of edges incident to v in M ∆ M' is at most 2.\n        have h₄ : (E(G ↾ (M ∆ M'), v)).encard ≤ 2 := by\n          calc\n            (E(G ↾ (M ∆ M'), v)).encard = ( (M ∆ M') ∩ E(G, v) ).encard := by\n              simp [E, Set.ext_iff]\n              <;> aesop\n            _ ≤ 2 := by\n              -- Use the fact that (M ∆ M') ∩ E(G, v) contains at most two edges.\n              have h₅ : ( (M ∆ M') ∩ E(G, v) ) ⊆ (M ∆ M') ∩ E(G, v) := by simp\n              have h₆ : ( (M ∆ M') ∩ E(G, v) ).encard ≤ 2 := by\n                -- Since M and M' are matchings, (M ∆ M') ∩ E(G, v) can contain at most two edges.\n                have h₇ : (M ∩ E(G, v)).encard ≤ 1 := by\n                  have h₈ : (M ∩ E(G, v)).Subsingleton := by\n                    apply hM.subsingleton_inc\n                  have h₉ : (M ∩ E(G, v)).encard ≤ 1 := by\n                    rw [encard_le_one_iff_subsingleton]\n                    exact h₈\n                  exact h₉\n                have h₁₀ : (M' ∩ E(G, v)).encard ≤ 1 := by\n                  have h₁₁ : (M' ∩ E(G, v)).Subsingleton := by\n                    apply hM'.subsingleton_inc\n                  have h₁₂ : (M' ∩ E(G, v)).encard ≤ 1 := by\n                    rw [encard_le_one_iff_subsingleton]\n                    exact h₁₁\n                  exact h₁₂\n                have h₁₃ : ((M ∆ M') ∩ E(G, v)).encard ≤ 2 := by\n                  calc\n                    ((M ∆ M') ∩ E(G, v)).encard ≤ ((M ∪ M') ∩ E(G, v)).encard := by\n                      apply Set.encard_mono\n                      intro x hx\n                      simp only [Set.mem_diff, Set.mem_inter_iff] at hx ⊢\n                      tauto\n                    _ ≤ ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := by\n                      apply Set.encard_mono\n                      intro x hx\n                      simp only [Set.mem_union, Set.mem_inter_iff] at hx ⊢\n                      tauto\n                    _ ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                      have h₁₄ : ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by\n                        calc\n                          ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ ((M ∩ E(G, v))).encard + ((M' ∩ E(G, v))).encard := by\n                            apply Set.encard_union_le\n                          _ = (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by rfl\n                      exact h₁₄\n                    _ ≤ 1 + 1 := by\n                      have h₁₅ : (M ∩ E(G, v)).encard ≤ 1 := h₇\n                      have h₁₆ : (M' ∩ E(G, v)).encard ≤ 1 := h₁₀\n                      have h₁₇ : (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard ≤ 1 + 1 := by\n                        calc\n                          (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard ≤ 1 + 1 := by\n                            have h₁₈ : (M ∩ E(G, v)).encard ≤ 1 := h₇\n                            have h₁₉ : (M' ∩ E(G, v)).encard ≤ 1 := h₁₀\n                            omega\n                          _ = 1 + 1 := by rfl\n                      exact h₁₇\n                    _ = 2 := by norm_num\n                exact h₁₃\n              exact h₆\n            _ = 2 := by rfl\n          <;> norm_num\n        exact h₄\n      -- Use the fact that the maximum degree is at most 2 to bound the degree of each vertex.\n      rw [maxDegreeLE_iff']\n      intro v hv\n      have h₅ : (E(G ↾ (M ∆ M'), v)).encard ≤ 2 := h₃ v\n      simp_all [eDegree_eq_encard_inc]\n      <;>\n      (try omega) <;>\n      (try simp_all) <;>\n      (try norm_num) <;>\n      (try linarith)\n    -- Since the loop removal does not increase the degree, the maximum degree of (G ↾ (M ∆ M')).loopRemove is at most 2.\n    have h₃ : ((G ↾ (M ∆ M')).loopRemove).MaxDegreeLE 2 := by\n      have h₄ : ((G ↾ (M ∆ M')).loopRemove).MaxDegreeLE 2 := by\n        -- The maximum degree of (G ↾ (M ∆ M')).loopRemove is at most the maximum degree of G ↾ (M ∆ M').\n        calc\n          ((G ↾ (M ∆ M')).loopRemove).MaxDegreeLE 2 := by\n            -- Use the fact that the maximum degree of G ↾ (M ∆ M') is at most 2.\n            have h₅ : (G ↾ (M ∆ M')).MaxDegreeLE 2 := h₂\n            have h₆ : ((G ↾ (M ∆ M')).loopRemove).MaxDegreeLE 2 := by\n              -- Loop removal does not increase the degree.\n              have h₇ : ((G ↾ (M ∆ M')).loopRemove).MaxDegreeLE (G ↾ (M ∆ M')).maxDegree := by\n                -- Use the fact that loop removal does not increase the degree.\n                apply loopRemove_maxDegreeLE_subgraph\n                <;> simp_all [Subgraph]\n                <;> try norm_num\n              have h₈ : (G ↾ (M ∆ M')).maxDegree ≤ 2 := by\n                -- Use the fact that the maximum degree of G ↾ (M ∆ M') is at most 2.\n                have h₉ : (G ↾ (M ∆ M')).MaxDegreeLE 2 := h₂\n                simp_all [maxDegreeLE_iff]\n                <;>\n                (try omega) <;>\n                (try simp_all) <;>\n                (try norm_num) <;>\n                (try linarith)\n              have h₉ : ((G ↾ (M ∆ M')).loopRemove).maxDegree ≤ 2 := by\n                -- Use the fact that the maximum degree of (G ↾ (M ∆ M')).loopRemove is at most the maximum degree of 