                                     apply Set.inter_subset_left\n                                                                exact h₃₃\n                                                          exact h₃₁\n                                                        -- Use the fact that the sum of the cardinalities is at least the cardinality of the intersection\n                                                        simp_all [add_comm]\n                                                        <;>\n                                                        (try omega) <;>\n                                                        (try\n                                                          {\n                                                            simp_all [add_comm]\n                                                            <;>\n                                                            omega\n                                                          })\n                                                      })\n                                                  exact h₂₅\n                                                _ = M.encard + M'.encard := by rfl\n                                            exact h₂₄\n                                          _ = M.encard + M'.encard := by rfl\n                                      _ = M.encard + M'.encard := by rfl\n                                  -- Use the fact that the graph is edge-finite\n                                  have h₂₄ : M.encard ≤ 1 := by\n                                    -- Use the fact that M is a matching\n                                    have h₂₅ : ∀ v : α, (M ∩ E(G, v)).encard ≤ 1 := by\n                                      intro v\n                                      exact hM.degree_le_one v\n                                    -- Use the fact that the graph is edge-finite\n                                    have h₂₆ : M.encard ≤ 1 := by\n                                      -- Use the fact that M is a matching\n                                      have h₂₇ : M.Finite := by\n                                        -- Use the fact that the graph is edge-finite\n                                        have h₂₈ : M ⊆ E(G) := hM.subset\n                                        have h₂₉ : E(G).Finite := by\n                                          -- Use the fact that the graph is edge-finite\n                                          exact (inferInstance : (E(G) : Set β).Finite)\n                                        exact Set.Finite.subset h₂₉ h₂₈\n                                      -- Use the fact that M is a matching\n                                      classical\n                                      by_contra h₃₀\n                                      -- Use the fact that M is a matching\n                                      have h₃₁ : M.encard > 1 := by\n                                        -- Use the fact that M is a matching\n                                        simp_all [Nat.cast_lt]\n                                        <;>\n                                        (try omega)\n                                      -- Use the fact that M is a matching\n                                      have h₃₂ : ∃ (v : α), (M ∩ E(G, v)).encard ≥ 2 := by\n                                        -- Use the fact that M is a matching\n                                        classical\n                                        have h₃₃ : M.encard > 1 := h₃₁\n                                        have h₃₄ : ∃ (v : α), (M ∩ E(G, v)).encard ≥ 2 := by\n                                          by_contra h₃₅\n                                          -- Use the fact that M is a matching\n                                          have h₃₆ : ∀ (v : α), (M ∩ E(G, v)).encard < 2 := by\n                                            intro v\n                                            by_contra h₃₇\n                                            have h₃₈ 