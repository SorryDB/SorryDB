            simpa [mul_assoc] using h₂
          have h₃ : ‖x‖ * ‖y‖ * C = C * ‖x‖ * ‖y‖ := by ring
          have h₄ : ‖x‖ * ‖y‖ * C ≤ C * ‖x‖ * ‖y‖ := by linarith
          have h₅ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ C * ‖x‖ * ‖y‖ := by linarith
          simpa [h₃] using h₅
      )
