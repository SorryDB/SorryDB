      simp_all [ComplexLinearMap.map_smul]
      <;>
      simp_all [ComplexMeasure.integral_smul]
      <;>
      simp_all [toLinearFunctional_smul]
      <;>
      simp_all [cfc_toComplexMeasure]
      <;>
      simp_all [ComplexMeasure.integral_smul]
      <;>
      simp_all [toLinearFunctional_smul]
      <;>
      simp_all [ComplexMeasure.integral_smul]
