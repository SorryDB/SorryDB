def toBoundedBilin {C : ℝ} (f : (spectrum ℂ a) → ℂ)
  : H →L⋆[ℂ] H →L[ℂ] ℂ where
  toFun x := {  
    toFun y => (cfc_toComplexMeasure ha x y).integral f
    map_add' := by
      intro y z
      simp only [ComplexCMAdd, ComplexMAdd, ContinuousLinearMap.add_apply]
      <;>
      simp_all [ComplexMeasure.integral_add]
      <;>
      simp_all [toLinearFunctional_add, ContinuousLinearMap.add_apply]
      <;>
      simp_all [cfc_toComplexMeasure, ComplexMeasure.integral_add]
      <;>
      simp_all [toLinearFunctional_add]
      <;>
      simp_all [ComplexMeasure.integral_add]
      <;>
      simp_all [toLinearFunctional_add]
      <;>
      simp_all [ComplexMeasure.integral_add]
      <;>
      simp_all [toLinearFunctional_add]
      <;>
      simp_all [ComplexMeasure.integral_add]
      <;>
      simp_all [toLinearFunctional_add]
    map_smul' := by
      intro m y
      have h := congr_arg (fun x => x y) (ComplexLinearMap.ext_iff.2 fun z => by
        simp_all [ComplexLinearMap.map_smul]
        <;>
        simp_all [ComplexMeasure.integral_smul]
        <;>
