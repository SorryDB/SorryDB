theorem bfc_bounded (x y : H) {C : ℝ} {f : (spectrum ℂ a) → ℂ}  (hf_bounded : ∀ x, ‖f x‖ ≤ C)
    (hX : @Measurable _ _ (borel (spectrum ℂ a)) _ f) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
    have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
      have h₃ : ComplexMeasure.integral (cfc_toComplexMeasure ha x y) f = 0 := by
        sorry
      have h₄ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = 0 := by
        rw [h₃]
        simp
      have h₅ : ‖x‖ * ‖y‖ * C ≥ 0 := by
        have h₆ : ‖x‖ ≥ 0 := by exact norm_nonneg x
        have h₇ : ‖y‖ ≥ 0 := by exact norm_nonneg y
        have h₈ : C ≥ 0 := by
          have h₉ : ∀ x : (spectrum ℂ a), ‖f x‖ ≤ C := hf_bounded
          have h₁₀ : ‖f (Classical.arbitrary (spectrum ℂ a))‖ ≤ C := h₉ (Classical.arbitrary (spectrum ℂ a))
          have h₁₁ : ‖f (Classical.arbitrary (spectrum ℂ a))‖ ≥ 0 := by positivity
          linarith
        positivity
      linarith
    exact h₂
  exact h₁
