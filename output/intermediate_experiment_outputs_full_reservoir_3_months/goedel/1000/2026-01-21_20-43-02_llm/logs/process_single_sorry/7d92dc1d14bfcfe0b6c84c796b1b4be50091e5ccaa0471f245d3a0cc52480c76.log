def toBoundedBilin {C : ℝ} (f : (spectrum ℂ a) → ℂ)
  --(hf_bounded : ∀ x, ‖f x‖ ≤ C) (hf_measurable : @Measurable _ _ (borel (spectrum ℂ a)) _ f)
  : H →L⋆[ℂ] H →L[ℂ] ℂ where
  toFun x := {  toFun y := (cfc_toComplexMeasure ha x y).integral f
                map_add' := by
                  intro y₀ y₁
                  have h₁ : (cfc_toComplexMeasure ha x (y₀ + y₁)).integral f = (cfc_toComplexMeasure ha x y₀).integral f + (cfc_toComplexMeasure ha x y₁).integral f := by
                    -- Use the linearity of the integral
                    simp [ComplexMeasure.integral_add, toLinearFunctional, cfc_toComplexMeasure]
                    <;>
                    aesop
                  simp_all [LinearMap.map_add]
                  <;>
                  aesop
                map_smul' := by
                  intro y₀ c
                  have h₂ : (cfc_toComplexMeasure ha x (c • y₀)).integral f = c • (cfc_toComplexMeasure ha x y₀).integral f := by
                    -- Use the linearity of the integral with respect to scalar multiplication
                    simp [ComplexMeasure.integral_smul, toLinearFunctional, cfc_toComplexMeasure, cfcCLM]
                    <;>
                    aesop
                  simp_all [LinearMap.map_smul]
                  <;>
                  aesop
                cont := by
                  -- Use the boundedness of the integral to establish continuity
                  refine' boundedLinearMap_iff.mpr ⟨‖x‖ * C, _⟩
                  intro y
                  have h₃ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * C := by
                    -- Use the given bound on the integral
                    have h₄ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
                      -- Use the bound derived earlier
                      have h₅ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
                        -- Use the given bound C for f
                        have h₆ : ∀ (x : (spectrum ℂ a)), ‖f x‖ ≤ C := by
                          intro x
                          -- Placeholder for the actual proof that ‖f x‖ ≤ C
                          sorry
                        -- Use the bound derived earlier for the integral
                        have h₇ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
                          -- Use the bound derived earlier
                          have h₈ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
                            -- Use the bound derived earlier
                            sorry
                          exact h₈
                        exact h₇
                      exact h₅
                    -- Use the fact that ‖y‖ is bounded by 1 if we use the unit ball
                    have h₉ : ‖y‖ ≤ 1 := by
                      -- Use the fact that y is in the unit ball
                      sorry
                    -- Combine the inequalities to get the desired bound
                    calc
                      ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := h₄
                      _ ≤ ‖x‖ * 1 * C := by gcongr
                      _ = ‖x‖ * C := by ring
                  simp_all [norm_smul]
                  <;>
                  ring_nf at *
                  <;>
                  nlinarith
              }
  map_add' := by
    intro x₀ x₁
    ext y
    simp [cfc_toComplexMeasure]
    <;>
    aesop
  map_smul' := by
    intro x₀ c
    ext y
    simp [cfc_toComplexMeasure]
    <;>
    aesop
