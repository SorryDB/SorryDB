theorem GReal_Differentiable {t : ℝ} (ht : 0 < t) : DifferentiableAt ℝ GReal t := by
  have h₁ : DifferentiableAt ℝ (fun t : ℝ => (G.resToImagAxis t).re) t := by
    have h₂ : DifferentiableAt ℝ (fun t : ℝ => G.resToImagAxis t) t := by
      apply DifferentiableAt.comp (differentiableAt_id : DifferentiableAt ℝ (fun t : ℝ => (t : ℂ)) t)
      apply IsOpen.differentiableAt
      · exact isOpen_Ioi
      · intro z hz
        -- Prove that G is holomorphic on the right half-plane
        have h₃ : MDifferentiable 𝓘(ℂ) 𝘉 G := G_holo
        have h₄ : DifferentiableAt 𝂂 G z := by
          apply h₃.differentiableAt
          exact differentiableAt_id
        exact h₄.differentiableWithinAt
      · simp [ht]
        <;>
        simp_all [Complex.ext_iff, Complex.ofReal_re, Complex.ofReal_im]
        <;>
        norm_num
        <;>
        linarith
    have h₃ : DifferentiableAt ℝ (fun t : ℝ => (G.resToImagAxis t).re) t := by
      apply DifferentiableAt.comp (differentiableAt_id : DifferentiableAt ℝ (fun t : ℝ => (t : ℂ)) t)
      apply DifferentiableAt.re
      exact h₂
    exact h₃
  have h₂ : GReal = fun t : ℝ => (G.resToImagAxis t).re := by
    funext t
    simp [GReal]
    <;>
    simp_all [Complex.ext_iff, Complex.ofReal_re, Complex.ofReal_im]
    <;>
    norm_num
  rw [h₂]
  exact h₁
