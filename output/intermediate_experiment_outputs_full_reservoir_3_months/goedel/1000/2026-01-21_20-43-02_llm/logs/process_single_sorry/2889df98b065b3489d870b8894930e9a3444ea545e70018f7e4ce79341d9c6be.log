      "\n  have h : J * t ≠ 0 := by\n    have h₁ : J * t > 0 := by\n      have h₂ : (J : ℝ) = 3 := by norm_num [J]\n      rw [h₂]\n      norm_num\n      <;> linarith\n    linarith\n  -- Use the fact that the composition of differentiable functions is differentiable.\n  have h₁ : DifferentiableAt ℝ (fun t : ℝ => (G.resToImagAxis t : ℂ).re) t := by\n    -- Prove that the composition of the function G with the real part is differentiable.\n    have h₂ : DifferentiableAt (⊤ : Filter ℝ) (fun t : ℝ => G.resToImagAxis t : ℝ → ℂ) t := by\n      -- Show that the restriction to the imaginary axis is differentiable.\n      have h₃ : AnalyticAt (fun z : ℂ => (G : ℂ → ℂ) z) (t * I) := by\n        -- Use the fact that G is holomorphic to deduce analyticity.\n        have h₄ : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (G : ℂ → ℂ) := G_holo\n        exact h₄.differentiableAt.to_analyticAt\n      -- Use the property of analytic functions to deduce differentiability on the imaginary axis.\n      have h₅ : DifferentiableAt (⊤ : Filter ℝ) (fun t : ℝ => (G : ℂ → ℂ) (t * I)) t := by\n        -- Use the fact that the function is analytic to deduce differentiability.\n        apply (h₃.differentiableAt_of_curve (𝓝 t) (differentiableAt_id.const_mul I))\n        <;> simp_all [Complex.ext_iff, pow_two, pow_three]\n        <;> ring_nf\n        <;> norm_num\n        <;> aesop\n      -- Use the fact that the function is differentiable to deduce the differentiability of the real part.\n      convert h₅ using 1 <;> simp [Complex.ext_iff, pow_two, pow_three, ImaginaryAxis.comp]\n      <;> ext <;> simp_all [Complex.ext_iff, pow_two, pow_three, ImaginaryAxis.comp]\n      <;> ring_nf\n      <;> norm_num\n      <;> simp_all [Complex.ext_iff, pow_two, pow_three, ImaginaryAxis.comp]\n      <;> linarith\n    -- Use the fact that the real part is differentiable to deduce the differentiability of GReal.\n    have h₃ : DifferentiableAt ℝ (fun t : ℝ => (G.resToImagAxis t : ℂ).re) t := by\n      -- Prove that the real part of