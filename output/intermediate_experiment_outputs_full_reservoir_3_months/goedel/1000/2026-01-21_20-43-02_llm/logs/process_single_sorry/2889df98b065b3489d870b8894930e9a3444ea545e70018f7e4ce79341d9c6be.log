theorem G_holo : MDifferentiable 𝓘(ℂ) 𝘯(ℂ) G := by
  have h1 : MDifferentiable 𝘯(ℂ) 𝘯(ℂ) (fun z : ℂ => (H₂ z) ^ 3) := by
