      "\n  have h₁ : DifferentiableAt ℝ GReal t := by\n    have h₂ : HDifferentiableAt 𝕜 G (Complex.I * t : ℂ) := by\n      have h₃ : G = H₂ ^ 3 * (2 * H₂ ^ 2 + 5 * H₂ * H₄ + 5 * H₄ ^ 2) := rfl\n      rw [h₃]\n      -- Prove that each term is holomorphic\n      have h₄ : HDifferentiableAt 𝕜 (H₂ ^ 3) (Complex.I * t : ℂ) := by sorry\n      have h₅ : HDifferentiableAt 𝕜 (2 * H₂ ^ 2 + 5 * H₂ * H₄ + 5 * H₄ ^ 2) (Complex.I * t : ℂ) := by sorry\n      -- Product of holomorphic functions is holomorphic\n      exact HDifferentiableAt.mul h₄ h₅\n    -- Use the fact that G is holomorphic to deduce that GReal is differentiable\n    have h₃ : DifferentiableAt ℝ (fun t : ℝ => (G.resToImagAxis t).re) t := by sorry\n    have h₄ : (fun t : ℝ => (G.resToImagAxis t).re) = GReal := by\n      funext t\n      rfl\n    rw [h₄] at h₃\n    exact h₃\n  exact h₁",
