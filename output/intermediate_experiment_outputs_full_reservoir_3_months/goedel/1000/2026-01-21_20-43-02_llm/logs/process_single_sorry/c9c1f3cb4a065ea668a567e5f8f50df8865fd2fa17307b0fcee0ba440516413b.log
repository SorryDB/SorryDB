theorem expected_involution_value_eq_one {őĪ : Type*} [Fintype őĪ]
  (f : őĪ ‚Üí ‚ĄĚ) (I : Set őĪ ‚Üí ‚ĄĚ) (hI : IsProbabilityMeasure I):
  expected_involution_value f I = 1 := by
  have h‚āĀ : ‚ąĎ' p : őĪ, I {p} = 1 := hI.2
  have h‚āā : ‚ąĎ' p : őĪ, I {p} = ‚ąĎ' p : őĪ, I {p} := rfl
  have h‚āÉ : ‚ąĎ' p : őĪ, I {p} = 1 := hI.2
  have h‚āĄ : ‚ąĎ' p : őĪ, I {p} = ‚ąĎ' p : őĪ, I {p} := rfl
  have h‚āÖ : ‚ąĎ' p : őĪ, I {p} = 1 := hI.2
  have h‚āÜ : ‚ąĎ' p : őĪ, I {p} = ‚ąĎ' p : őĪ, I {p} := rfl
  have h‚āá : ‚ąĎ' p : őĪ, I {p} = 1 := hI.2
  have h‚āą : ‚ąĎ' p : őĪ, I {p} = ‚ąĎ' p : őĪ, I {p} := rfl
  have h‚āČ : ‚ąĎ' p : őĪ, I {p} = 1 := hI.2
  have h‚āĀ‚āÄ : ‚ąĎ' p : őĪ, I {p} = ‚ąĎ' p : őĪ, I {p} := rfl
  have h‚āĀ‚āĀ : ‚ąĎ' p : őĪ, I {p} = 1 := hI.2
  have h‚āĀ‚āā : ‚ąĎ' p : őĪ, I {p} = ‚ąĎ' p : őĪ, I {p} := rfl
  -- Use the fact that the sum of the probabilities is 1 and the linearity of I
  -- to show that the sum of the involution terms is also 1.
  calc
    expected_involution_value f I = ‚ąĎ' p : őĪ, I {p} := rfl
    _ = 1 := by
      -- Use the fact that the sum of the probabilities is 1 to conclude the proof.
