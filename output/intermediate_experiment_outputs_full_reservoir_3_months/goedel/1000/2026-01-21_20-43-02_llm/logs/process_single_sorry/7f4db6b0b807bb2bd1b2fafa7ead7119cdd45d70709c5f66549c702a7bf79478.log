lemma hasCondDistrib_reward' (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν]
    (n : ℕ) :
    HasCondDistrib (reward alg (n + 1)) (fun ω ↦ (hist alg ω n, action alg (n + 1) ω))
      (ν.prodMkLeft _) (arrayMeasure ν) := by
  rw [reward_eq]
  refine ⟨?_, by fun_prop, ?_⟩
  · -- Prove that the map is AEMeasurable
    have h1 : Measurable (fun ω : 1 => ω.2 (pullCount' n (hist alg ω n) (algFunction alg n (hist alg ω n) (ω.1 (n + 1)))) (algFunction alg n (hist alg ω n) (ω.1 (n + 1)))) := by
      -- Use the fact that pullCount'_action_add_one is measurable to conclude the proof
      have h_hist_measurable : Measurable (fun x : 1 => hist alg x n) := by
        apply measurable_hist
      have h_alg_function_measurable : Measurable (fun x : 1 => algFunction alg n (hist alg x n) (x.1 (n + 1))) := by
        -- Use the fact thatHist is measurable to conclude the proof
        apply measurable_action_add_one'
        <;> exact h_hist_measurable
      apply (measurable_uncurry_pullCount' (α := α) n).comp (h_hist_measurable.prodMk h_alg_function_measurable)
    
    -- Since the map is measurable, it is also AEMeasurable
    have h2 : AEMeasurable (fun ω : 1 => ω.2 (pullCount' n (hist alg ω n) (algFunction alg n (hist alg ω n) (ω.1 (n + 1)))) (algFunction alg n (hist alg ω n) (ω.1 (n + 1)))) (arrayMeasure ν) := by
      refine' h1.ae_measurable
      <;>
      (try simp) <;>
      (try norm_num) <;>
      (try
        {
          apply MeasureTheory.isFullMeasure_ae_iff.mpr
          <;>
          simp [MeasureTheory.isFullMeasure]
          <;>
          decide
        })
      <;>
      (try
        {
          apply eq_of_sub_eq_zero
          <;>
          norm_num
          <;>
          simp_all [MeasureTheory.isFullMeasure]
          <;>
          aesop
        })
    
    -- Use the fact that the map is AEMeasurable to prove the goal
    have h3 : AEMeasurable (fun ω : 1 => (ω.2 (pullCount' n (hist alg ω n) (algFunction alg n (hist alg ω n) (ω.1 (n + 1)))) (algFunction alg n (hist alg ω n) (ω.1 (n + 1))))) (arrayMeasure ν) := by
      exact h2
    -- Use the fact that the map is AEMeasurable to prove the goal
    have h4 : AEMeasurable (fun ω : 1 => (ω.2 (pullCount (action alg) (action alg (n + 1) ω) n ω) (action alg (n + 1) ω))) (arrayMeasure ν) := by
      have h5 : AEMeasurable (fun ω : 1 => (ω.2 (pullCount' n (hist alg ω n) (algFunction alg n (hist alg ω n) (ω.1 (n + 1)))) (algFunction alg n (hist alg ω n) (ω.1 (n + 1))))) (arrayMeasure ν) := h3
      have h6 : (fun ω : 1 => (ω.2 (pullCount (action alg) (action alg (n + 1) ω) n ω) (action alg (n + 1) ω))) = (fun ω : 1 => (ω.2 (pullCount' n (hist alg ω n) (algFunction alg n (hist alg ω n) (ω.1 (n + 1)))) (algFunction alg n (hist alg ω n) (ω.1 (n + 1))))) := by
        funext ω
        have h7 : pullCount (action alg) (action alg (n + 1) ω) n ω = pullCount' n (hist alg ω n) (action alg (n + 1) ω) := by
          cases n with
          | zero => simp [pullCount, action_add_one_eq, hist_zero, action_zero]
          | succ n =>
            simp_all [pullCount_eq_pullCount', action_add_one_eq, hist_add_one, Nat.succ_eq_add_one]
            <;> aesop
        have h8 : action alg (n + 1) ω = algFunction alg n (hist alg ω n) (ω.1 (n + 1)) := by
          simp [action_add_one_eq]
          <;> aesop
        rw [h7, h8]
        <;> simp [pullCount']
        <;>
        (try
          {
            simp_all [pullCount_eq_pullCount', action_add_one_eq, hist_add_one, Nat.succ_eq_add_one]
            <;> aesop
          })
      rw [h6]
      exact h5
    exact h4
  
  · -- Prove the condition for the conditional distribution
    sorry
