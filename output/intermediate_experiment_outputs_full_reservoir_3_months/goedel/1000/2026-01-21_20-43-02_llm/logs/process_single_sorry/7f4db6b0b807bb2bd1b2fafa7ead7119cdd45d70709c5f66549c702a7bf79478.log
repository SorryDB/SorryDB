lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  have h_inc : Set.InjOn (fun (i : ℕ) ↦ i) (Set.univ : Set ℕ) := by
    intro i _ j _ h
    simpa using h
  have h_ind : IndepFun (fun (ω : ℕ → ε × (ℕ → α → R)) ↦ ω.1 (n + 1))
      (fun (ω : ℕ → ε × (ℕ → α → R)) ↦ ω.2 n) (arrayMeasure ν) := by
    have h₁ : IndepFun (fun (ω : ℕ → ε × (ℕ → α → R)) ↦ ω.1 (n + 1))
        (fun (ω : ℕ → ε × (ℕ → α → R)) ↦ ω.2 n) (arrayMeasure ν) := by
      have h₂ : IndepFun (fun (ω : ℕ → ε × (ℕ → α → R)) ↦ ω.1 (n + 1))
          (fun (ω : ℕ → ε × (ℕ → α → R)) ↦ ω.2 n) (arrayMeasure ν) := by
        -- Use the fact that the σ-algebra generated by the product measure is independent
        have h₃ : IndepFun (fun (ω : ℕ → ε × (ℕ → α → R)) ↦ ω.1 (n + 1))
            (fun (ω : ℕ → ε × (ℕ → α → R)) ↦ ω.2 n) (arrayMeasure ν) := by
          have h₄ : IndepFun (𝓟 ((n + 1 : ℕ) : ℕ → ε × (ℕ → α → R))) (𝓟 ((n : ℕ) : ℕ → ε × (ℕ → α → R))) :=
            (indepFun_pi_mem _ _ _).trans (indepFun_prod.).symm
          exact h₄.restrictScalars measurable_fst measurable_snd
        exact h₃
      exact h₂
    exact h₁
  -- Now we need to show that the original function is independent
  -- Use the fact that the function is the same as the one in the product measure
  have h_final : IndepFun (fun ω ↦ ω.1 (n + 1)) (fun ω ↦ ω.2 n) (arrayMeasure ν) := by
    simpa using h_ind
  have h_main : IndepFun (fun ω ↦ ω.1 (n + 1)) (fun ω ↦ ω.2 n) (arrayMeasure ν) := h_final
  -- Since `hist` is measurable, we can use the fact that the product measure is independent
  have h_measurable : Measurable (fun ω ↦ ω.2 n) := by
    fun_prop
  have h_ind' : IndepFun (fun ω ↦ ω.1 (n + 1)) (fun ω ↦ ω.2 n) (arrayMeasure ν) := h_main
  have h_ind'' : IndepFun (fun ω ↦ ω.1 (n + 1)) (fun ω ↦ ω.2 n) (arrayMeasure ν) := h_main
  -- Use the fact that the function is the same as the one in the product measure
  have h_ind''' : IndepFun (fun ω ↦ ω.1 (n + 1)) (fun ω ↦ ω.2 n) (arrayMeasure ν) := h_main
  -- Since `hist` is measurable, we can use the fact that the product measure is independent
  simpa [hist] using h_main.comp h₁ h₂
