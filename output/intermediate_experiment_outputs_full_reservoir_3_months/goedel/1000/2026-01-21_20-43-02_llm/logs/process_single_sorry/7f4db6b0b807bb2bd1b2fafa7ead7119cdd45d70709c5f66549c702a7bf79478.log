  -- Use the fact that the future is independent of the past given the present
  have h₁ : IndepFun (fun ω ↦ ω.1 (n + 1)) (fun ω ↦ (ω.1 0, ω.2 0)) (arrayMeasure ν) := by
    have h₁₁ : (fun ω ↦ ω.1 (n + 1)) ∧ᵢ[arrayMeasure ν] (fun ω ↦ (ω.1 0, ω.2 0)) := by
      -- Use the independent sigma-algebra properties
      have h₁₂ : (fun ω ↦ ω.1 (n + 1)) ∈ MeasurableSet.independentOf (sigma (Q n))
        (Pi.σ, (Pi.sUnion : ℕ → SigmaAlgebra (α → R))) (by
          -- Show that the future is independent of the past
          exact (by
            simp [Q, Pi.tBlock, Nat.div_eq_of_lt]
            <;>
              (try simp_all [POSet.pi_sUnion_mono])
            <;>
              (try omega)
          )
        )
      -- Combine the properties to get independence
      exact independentOf_subst_mem _
    exact h₁₁
  -- Use the previous result to get the final independence
  exact (fun ω => (ω.1 (n + 1), (fun ω => hist alg ω n) ⟨ω.1 0, ω.2⟩)) ∈».map h₁
