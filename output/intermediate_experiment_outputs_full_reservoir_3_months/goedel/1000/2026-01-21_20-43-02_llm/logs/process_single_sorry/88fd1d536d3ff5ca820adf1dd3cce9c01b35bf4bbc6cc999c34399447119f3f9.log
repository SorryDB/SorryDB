    calc
      ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y).toContinuousLinearMap f‖ := by
        simp [cfc_toComplexMeasure, ComplexMeasure.integral_eq_apply]
        <;> simp_all [ContinuousLinearMap.comp_def]
        <;> simp_all [ContinuousLinearMap.toLinearMap]
        <;> simp_all [ComplexLinearMap.toLinearMap]
        <;> simp_all [continuousLinearMap_toLinearMap]
        <;> simp_all [ContinuousLinearMap.smulRight]
