        -- Use the fact that the norm of the composition is less than or equal to the product of the norms
        have h₁ : ‖(cfc_toLinearFunctional ha x y).toContinuousLinearMap f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
          -- Use the property of continuous linear maps
          calc
