nuousLinearMap.comp]\n      <;>\n      rfl\n    have h₆ : ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ ≤ 1 := by\n      have h₇ : (C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ)) = (C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ)) := rfl\n      have h₈ : ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ ≤ 1 := by\n        -- Since f is a function in C₀, its norm is bounded by 1\n        apply ContinuousLinearMap.le_opNorm\n        <;> simp [C₀, ContinuousLinearMap.comp]\n        <;>\n        (try simp_all [C₀, ContinuousLinearMap.comp])\n        <;>\n        (try aesop)\n        <;>\n        (try\n          {\n            have h₉ : ContinuousMap.continuousOn f continuousOn_id := by\n              exact (ContinuousMap.continuousOn f continuousOn_id)\n            simp_all [C₀, ContinuousLinearMap.comp]\n            <;> aesop\n          })\n        <;>\n        (try\n          {\n            have h₉ : ContinuousMap.continuousOn f continuousOn_id := by\n              exact (ContinuousMap.continuousOn f continuousOn_id)\n            simp_all [C₀, ContinuousLinearMap.comp]\n            <;> aesop\n          })\n      exact h₈\n    have h₉ : ‖(cfc_toLinearFunctional ha x y) (C₀((spectrum ℂ a), ℂ).straight f)‖ ≤ ‖x‖ * ‖y‖ := h₄\n    calc\n      ‖(cfc_toLinearFunctional ha x y) (C₀((spectrum ℂ a), ℂ).straight f)‖ ≤ ‖x‖ * ‖y‖ := h₉\n      _ ≤ ‖x‖ * ‖y‖ * ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ := by\n        have h₁₀ : ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ ≥ 0 := by positivity\n        have h₁₁ : ‖x‖ * ‖y‖ ≥ 0 := by positivity\n        have h₁₂ : ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ ≤ 1 := h₆\n        have h₁₃ : ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ ≥ 0 := by positivity\n        have h₁₄ : ‖x‖ * ‖y‖ * ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ ≥ ‖x‖ * ‖y‖ * 0 := by\n          gcongr <;> nlinarith\n        nlinarith\n  have h₃ : ‖x‖ * ‖y‖ * ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ = ‖x‖ * ‖y‖ * ‖f‖ := by\n    have h₄ : ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ = ‖f‖ := by\n      simp [C₀, ContinuousLinearMap.comp]\n      <;>\n      simp_all [C₀, ContinuousLinearMap.comp]\n      <;>\n      rfl\n    rw [h₄]\n    <;>\n    ring\n  calc\n    ‖((C₀((spectrum ℂ a), ℂ) →L[ℂ] ℂ).raster _) [(cfc_toLinearFunctional ha x y) (C₀((spectrum ℂ a), ℂ).straight f)]‖ ≤ ‖x‖ * ‖y‖ * ‖(C₀((spectrum ℂ a), ℂ).straight f : C((spectrum ℂ a), ℂ))‖ := h₂\n    _ = ‖x‖ * ‖y‖ * ‖f‖ := by rw [h₃]",
      "\n  have h₁ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by\n    apply cfc_toLinearFunctional_bound\n  \n  have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n    have h₃ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n      -- Use the fact that the integral of a function against the measure is bounded by the norm of the linear functional and the norm of the function.\n      have h₄ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y) f‖ := by\n        -- The integral of f against the measure is equal to the linear functional applied to f.\n        simp [cfc_toComplexMeasure, ComplexRMK.integral_rieszMeasure]\n        <;>\n        (try simp_all [ContinuousLinearMap.comp_apply]) <;>\n        (try ring_nf) <;>\n        (try simp_all [cfc_toLinearFunctional_apply]) <;>\n        (try aesop)\n      rw [h₄]\n      -- Use the fact that the norm of the linear functional applied to f is bounded by the norm of the linear functional times the norm of f.\n      calc\n        ‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n          -- Use the bound on the linear functional.\n          calc\n            ‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n              -- Apply the norm of the linear functional.\n              apply ContinuousLinearMap.le_opNorm\n            _ = ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by rfl\n        _ = ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by rfl\n    -- Combine the bounds to get the final result.\n    calc\n      ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := h₃\n      _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by\n        gcongr\n        <;>\n        (try simp_all)\n        <;>\n        (try linarith)\n      _ = ‖x‖ * ‖y‖ * ‖f‖ := by\n        ring\n        <;>\n        (try simp_all)\n        <;>\n        (try linarith)\n  \n  exact h₂",
      "\n  calc\n    ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖ComplexMeasure.integral (@cfc_toComplexMeasure H inst✝² inst✝¹ inst✝ a ha x y) f‖ := by rfl\n    _ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n      have h₁ : ‖(cfc_toLinearFunctional ha x y : C((spectrum ℂ a), ℂ) →L[ℂ] ℂ)‖ ≤ ‖x‖ * ‖y‖ := by\n        apply cfc_toLinearFunctional_bound x y\n      have h₂ : ‖(cfc_toComplexMeasure ha x y : EMeasure (spectrum ℂ a) ℂ)‖ ≤ ‖x‖ * ‖y‖ := by\n        calc\n          ‖(cfc_toComplexMeasure ha x y : EMeasure (spectrum ℂ a) ℂ)‖ =\n              ‖ComplexRMK.rieszMeasure (compSL C₀((spectrum ℂ a), ℂ) _ _ _ _ (cfc_toLinearFunctional ha x y)\n                (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap)‖ := by rfl\n          _ = ‖(cfc_toLinearFunctional ha x y : C((spectrum ℂ a), ℂ) →L[ℂ] ℂ)‖ := by\n            rw [ComplexRMK.norm_rieszMeasure]\n            <;> simp [C₀Embedding.isContinuous]\n          _ ≤ ‖x‖ * ‖y‖ := h₁\n      have h₃ : ‖(cfc_toComplexMeasure ha x y : EMeasure (spectrum ℂ a) ℂ).integral f‖ ≤ ‖(cfc_toComplexMeasure ha x y : EMeasure (spectrum ℂ a) ℂ)‖ * ‖f‖ := by\n        apply EMeasure.norm_integral_le_mul_norm\n      calc\n        ‖ComplexMeasure.integral (@cfc_toComplexMeasure ha x y) f‖ =\n            ‖(cfc_toComplexMeasure ha x y : EMeasure (spectrum ℂ a) ℂ).integral f‖ := by\n          simp [ComplexMeasure.integral_def]\n        _ ≤ ‖(cfc_toComplexMeasure ha x y : EMeasure (spectrum ℂ a) ℂ)‖ * ‖f‖ := h₃\n        _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by gcongr\n        _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring",
