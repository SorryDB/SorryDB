lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
  calc
    ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖ComplexMeasure.integral (cfc_toComplexMeasure ha x y) f‖ := rfl
    _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
      have h₁ : ‖ComplexMeasure.integral (cfc_toComplexMeasure ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
        -- Use the fact that the integral is a linear functional bounded by the operator norm of cfc_toLinearFunctional ha x y
        have h₂ : ‖ComplexMeasure.integral (cfc_toComplexMeasure ha x y) f‖ = ‖(cfc_toLinearFunctional ha x y) f‖ := by
          rfl
        rw [h₂]
        -- Use the fact that the norm of a linear functional applied to f is bounded by the norm of the linear functional times the norm of f
        have h₃ : ‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
          -- Use the fact that the norm of a linear functional applied to f is bounded by the norm of the linear functional times the norm of f
          calc
            ‖(cfc_toLinearFunctional ha x y) f‖ = ‖(cfc_toLinearFunctional ha x y) f‖ := rfl
            _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := ContinuousLinearMap.le_opNorm
              (cfc_toLinearFunctional ha x y) f
        exact h₃
      exact h₁
    _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by
      -- Use the fact that the operator norm of cfc_toLinearFunctional ha x y is bounded by ‖x‖ * ‖y‖
      have h₂ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
      calc
        ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by
          gcongr
        _ = (‖x‖ * ‖y‖) * ‖f‖ := by rfl
    _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring
