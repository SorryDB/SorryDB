### Complete Lean 4 Proof

```lean
lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
  calc
    ‖(cfc_toComplexMeasure ha x y).integral f‖ =
        ‖(cfc_toComplexMeasure ha x y).integral f‖ := rfl
    _ = ‖ComplexMeasure.integral (cfc_toComplexMeasure ha x y) f‖ := rfl
    _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
      have h₁ : ‖ComplexMeasure.integral (cfc_toComplexMeasure ha x y) f‖ =
          ‖(cfc_toLinearFunctional ha x y).apply f‖ := by
        simp [cfc_toComplexMeasure, ComplexRMK.integral_rieszMeasure, ContinuousLinearMap.comp_apply]
        <;> rfl
      rw [h₁]
      apply ContinuousLinearMap.norm_apply_le
    _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by
      have h₂ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
      calc
        ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by gcongr
        _ = (‖x‖ * ‖y‖) * ‖f‖ := by rfl
    _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring
``` 

