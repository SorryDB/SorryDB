      "\n  have h1 : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖cfc_toLinearFunctional ha x y f‖ := by\n    simp [ComplexMeasure.integral_zero_at_infty, cfc_toComplexMeasure]\n    <;>\n    simp_all [ComplexRMK.rieszMeasure_apply]\n    <;>\n    norm_cast\n    <;>\n    simp [ContinuousLinearMap.coe_comp, ContinuousLinearMap.mul_apply]\n  \n  rw [h1]\n  have h2 : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖y‖ := by\n    have h3 : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by\n      apply cfc_toLinearFunctional_bound\n    calc\n      ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n        apply ContinuousLinearMap.le_opNorm\n      _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by\n        gcongr\n      _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring\n      _ ≤ ‖x‖ * ‖y‖ := by\n        have h4 : ‖f‖ ≤ 1 → ‖x‖ * ‖y‖ * ‖f‖ ≤ ‖x‖ * ‖y‖ := by\n          intro h\n          have h5 : 0 ≤ ‖x‖ * ‖y‖ := by positivity\n          have h6 : ‖x‖ * ‖y‖ * ‖f‖ ≤ ‖x‖ * ‖y‖ * 1 := by\n            gcongr\n          have h7 : ‖x‖ * ‖y‖ * 1 = ‖x‖ * ‖y‖ := by ring\n          linarith\n        by_cases h8 : ‖f‖ ≤ 1\n        · exact h4 h8\n        · have h9 : ‖x‖ * ‖y‖ * ‖f‖ ≥ ‖x‖ * ‖y‖ := by\n            have h10 : ‖f‖ ≥ 1 := by\n              by_contra h11\n              have h12 : ‖f‖ < 1 := by linarith\n              have h13 : ‖f‖ ≤ 1 := by linarith\n              exact h8 h13\n            have h14 : 0 ≤ ‖x‖ * ‖y‖ := by positivity\n            have h15 : ‖x‖ * ‖y‖ * ‖f‖ ≥ ‖x‖ * ‖y‖ * 1 := by\n              gcongr\n            have h16 : ‖x‖ * ‖y‖ * 1 = ‖x‖ * ‖y‖ := by ring\n            linarith\n          nlinarith\n  calc\n    ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖y‖ := by apply h2\n    _ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n      have h3 : 1 ≤ ‖f‖ ∨ ‖f‖ < 1 := by\n        by_cases h : 1 ≤ ‖f‖\n        · exact Or.inl h\n        · exact Or.inr (by linarith [norm_nonneg f])\n      cases h3 with\n      | inl h3 =>\n        have h4 : 1 ≤ ‖f‖ := h3\n        have h5 : 0 ≤ ‖x‖ * ‖y‖ := by positivity\n        have h6 : ‖x‖ * ‖y‖ * 1 ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n          gcongr\n        have h7 : ‖x‖ * ‖y‖ * 1 = ‖x‖ * ‖y‖ := by ring\n        linarith\n      | inr h3 =>\n        have h4 : ‖f‖ < 1 := h3\n        have h5 : 0 ≤ ‖x‖ * ‖y‖ := by positivity\n        by_cases h6 : ‖x‖ * ‖y‖ = 0\n        · have h7 : ‖x‖ * ‖y‖ * ‖f‖ = 0 := by\n            have h8 : ‖x‖ * ‖y‖ = 0 := h6\n            calc\n              ‖x‖ * ‖y‖ * ‖f‖ = 0 * ‖f‖ := by rw [h8]\n              _ = 0 := by simp\n          have h9 : ‖x‖ * ‖y‖ = 0 := h6\n          linarith\n        · have h7 : 0 < ‖x‖ * ‖y‖ := by\n            contrapose! h6\n            positivity\n          have h8 : 0 < ‖x‖ * ‖y‖ := h7\n          have h9 : ‖x‖ * ‖y‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n            have h10 : 1 ≤ ‖f‖ := by\n              exfalso\n              linarith [norm_nonneg f]\n            have h11 : 0 ≤ ‖x‖ * ‖y‖ := by positivity\n            have h12 : ‖x‖ * ‖y‖ * 1 ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n              gcongr\n            have h13 : ‖x‖ * ‖y‖ * 1 = ‖x‖ * ‖y‖ := by ring\n            linarith\n          linarith",
      "\n   But perhaps it is easier to notice that because we are working on a compact space, `C(X) = C₀(X)`, and then the measure is built from `C₀(X)` and integrates `C(X)` as well. \n\n   Then, we use that for `f : C(X)`, `∫ f dE_{a, x, y} = Λ(f)` where `Λ : C(X) → ℂ` is the original linear functional (since `C(X",
      "\n  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖cfc_toLinearFunctional ha x y f‖ := by\n    rw [ComplexMeasure.integral_toLinearFunctional_eq]\n    <;>\n    simp [cfc_toComplexMeasure]\n    <;>\n    try\n      {\n        simp_all [ContinuousMap.isCompact]\n        <;>\n        aesop\n      }\n    <;>\n    try\n      {\n        norm_num\n      }\n    <;>\n    try\n      {\n        rfl\n      }\n  \n  rw [h₁]\n  have h₂ : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n    have h₃ : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by\n      calc\n        ‖cfc_toLinearFunctional ha x y f‖ = ‖cfc_toLinearFunctional ha x y (f : C((spectrum ℂ a), ℂ))‖ := rfl\n        _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by\n          -- Use the property of the operator norm for linear maps.\n          exact norm_le_opNorm (cfc_toLinearFunctional ha x y) (f : C((spectrum ℂ a), ℂ))\n        _ = ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := rfl\n    \n    have h₄ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by\n      -- Use the previously established bound for the norm of cfc_toLinearFunctional.\n      exact cfc_toLinearFunctional_bound ha x y\n    \n    calc\n      ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := h₃\n      _ ≤ (‖x‖ * ‖y‖) * ‖(f : C((spectrum ℂ a), ℂ))‖ := by gcongr\n      _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring\n      _ ≤ ‖x‖ * ‖y‖ * ‖f‖ := le_refl _\n  \n  calc\n    ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := h₂\n    _ = ‖x‖ * ‖y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by simp\n    _ = ‖x‖ * ‖y‖ * ‖f‖ := by simp",
      "\n  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n    have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toComplexMeasure ha x y).integral f‖ := rfl\n    rw [h₂]\n    -- Use the property of the integral of a complex measure to bound the norm\n    have h₃ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n      -- Use the fact that the integral of f with respect to the measure is bounded by the product of the norms\n      have h₄ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖cfc_toLinearFunctional ha x y (show (f : C((spectrum ℂ a), ℂ)) by exact f)‖ := by\n        -- The integral of f with respect to the measure is equal to the linear functional applied to f\n        rw [ComplexMeasure.integral_congr (cfc_toComplexMeasure ha x y)]\n        <;> simp [cfc_toLinearFunctional_apply]\n        <;>\n        (try norm_num) <;>\n        (try simp_all) <;>\n        (try ring_nf) <;>\n        (try norm_num) <;>\n        (try field_simp) <;>\n        (try linarith)\n      rw [h₄]\n      -- Use the fact that the norm of the linear functional applied to f is bounded by the product of the norms\n      have h₅ : ‖cfc_toLinearFunctional ha x y (show (f : C((spectrum ℂ a), ℂ)) by exact f)‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by\n        -- Use the fact that the norm of a continuous linear map applied to a vector is bounded by the product of the norms\n        calc\n          ‖cfc_toLinearFunctional ha x y (show (f : C((spectrum ℂ a), ℂ)) by exact f)‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by\n            -- Use the fact that the norm of a continuous linear map applied to a vector is bounded by the product of the norms\n            apply ContinuousLinearMap.le_opNorm\n          _ = ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by rfl\n      -- Use the fact that the norm of the linear functional applied to f is bounded by the product of the norms\n      have h₆ : ‖(f : C((spectrum ℂ a), ℂ))‖ = ‖f‖ := by simp\n      rw [h₆] at h₅\n      -- Use the fact that the norm of the linear functional applied to f is bounded by the product of the norms\n      exact h₅\n    -- Use the fact that the integral of f with respect to the measure is bounded by the product of the norms\n    exact h₃\n  -- Use the fact that the norm of the linear functional is bounded by the product of the norms of x and y\n  have h₂ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by\n    -- Use the fact that the norm of the linear functional is bounded by the product of the norms of x and y\n    apply cfc_toLinearFunctional_bound\n  -- Combine the two inequalities to get the final result\n  calc\n    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := h₁\n    _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by gcongr <;> simp_all\n    _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring",
      "\n  have h₁ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y\n  have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖cfc_toLinearFunctional ha x y f‖ := by sorry\n  have h₃ : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by sorry\n  have h₄ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by sorry\n  sorry",
      "\n  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toComplexMeasure ha x y).integral f‖ := rfl\n  have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap).toContinuousLinearMap f‖ := by\n    simp [cfc_toComplexMeasure, ComplexRMK.rieszMeasure_integrate]\n    <;>\n    (try simp_all [ContinuousLinearMap.comp_apply])\n    <;>\n    (try rfl)\n    <;>\n    (try simp_all [ContinuousLinearMap.comp_apply])\n    <;>\n    (try rfl)\n  have h₃ : ‖(compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap).toContinuousLinearMap f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n    have h₄ : ‖(compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap).toContinuousLinearMap f‖ ≤ ‖(compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap).toContinuousLinearMap‖ * ‖f‖ := by\n      apply norm_le_opNorm_mul_norm\n    have h₅ : ‖(compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap).toContinuousLinearMap‖ = ‖compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ := by\n      simp [ContinuousLinearMap.norm_eq_opNorm]\n    have h₆ : ‖compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ ≤ ‖cfc_toLinearFunctional ha x y‖ := by\n      have h₇ : ‖compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ := by\n        calc\n          ‖compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖\n            = ‖(cfc_toLinearFunctional ha x y : C((spectrum ℂ a), ℂ) →L[ℂ] ℂ) ∘L (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ := by rfl\n          _ ≤ ‖(cfc_toLinearFunctional ha x y : C((spectrum ℂ a), ℂ) →L[ℂ] ℂ)‖ * ‖(@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ := by\n            apply ContinuousLinearMap.norm_comp_le\n          _ = ‖cfc_toLinearFunctional ha x y‖ * ‖(@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ := by rfl\n      have h₈ : ‖(@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ = 1 := by\n        have h₉ : ‖(@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ = 1 := by\n          simp [ContinuousLinearMap.norm_eq_opNorm]\n          <;>\n          (try simp_all [ContinuousLinearMap.norm_eq_opNorm])\n          <;>\n          (try norm_num)\n          <;>\n          (try simp_all [ContinuousLinearMap.norm_eq_opNorm])\n          <;>\n          (try rfl)\n        exact h₉\n      calc\n        ‖compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ := h₇\n        _ = ‖cfc_toLinearFunctional ha x y‖ * 1 := by rw [h₈]\n        _ = ‖cfc_toLinearFunctional ha x y‖ := by ring\n    calc\n      ‖(compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap).toContinuousLinearMap‖ = ‖compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap‖ := by simp [ContinuousLinearMap.norm_eq_opNorm]\n      _ ≤ ‖cfc_toLinearFunctional ha x y‖ := h₆\n      _ ≤ ‖cfc_toLinearFunctional ha x y‖ := le_refl _\n  have h₄ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y\n  calc\n    ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap).toContinuousLinearMap f‖ := by rw [h₂]\n    _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := h₃\n    _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by\n      gcongr\n      <;>\n      (try simp_all)\n      <;>\n      (try linarith)\n    _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring",
      "\n  have h₀ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n    calc\n      ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y).toContinuousLinearMap f‖ := by\n        simp [cfc_toComplexMeasure, ComplexMeasure.integral_eq_apply]\n        <;> simp_all [ContinuousLinearMap.comp_def]\n        <;> simp_all [ContinuousLinearMap.toLinearMap]\n        <;> simp_all [ComplexLinearMap.toLinearMap]\n        <;> simp_all [continuousLinearMap_toLinearMap]\n        <;> simp_all [ContinuousLinearMap.smulRight]\n      _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n        -- Use the fact that the norm of the composition is less than or equal to the product of the norms\n        have h₁ : ‖(cfc_toLinearFunctional ha x y).toContinuousLinearMap f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n          -- Use the property of continuous linear maps\n          calc\n            ‖(cfc_toLinearFunctional ha x y).toContinuousLinearMap f‖ = ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by\n              simp [ContinuousLinearMap.norm_comp_le]\n              <;> simp_all [ContinuousLinearMap.norm_eq_zero]\n              <;> norm_num\n              <;> simp_all [ContinuousLinearMap.toLinearMap]\n              <;> simp_all [ComplexLinearMap.toLinearMap]\n              <;> simp_all [continuousLinearMap_toLinearMap]\n              <;> simp_all [ContinuousLinearMap.smulRight]\n            _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by simp\n        exact h₁\n  have h₁ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by\n    apply cfc_toLinearFunctional_bound\n  have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n    calc\n      ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := h₀\n      _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by gcongr <;> simp_all\n      _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring\n  exact h₂",
      "\n   - The integral `(cfc_toComplexMeasure ha x y).integral f` is equal to `(cfc_toLinearFunctional ha x y) f` because of the correspondence provided by the Riesz-Markov-Kakutani theorem.\n   - Therefore, `‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y) f‖`.\n\n3. **Use the Bound on `cfc_toLinearFunctional`**:\n   - We have already shown that `‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖`.\n   - By the definition of operator norm, `‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖`.\n   - Combining these gives `‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖`.\n\nHowever, there is a discrepancy in step 2. The `ComplexRMK.rieszMeasure` construction does not directly equate `integral f` to the linear functional `cfc_toLinearFunctional ha x y f`. Specifically:\n- The Riesz-Markov-Kakutani theorem gives a measure `μ` such that `∫ φ dμ = L(φ)` for `φ ∈ C₀(X)`.\n- However, in Lean, `cfc_toComplexMeasure` is defined by extending the linear functional to `C(X)` by composing with the restriction map `C(X) → C₀(X)`. Thus, `(cfc_toComplexMeasure ha x y).integral f` is actually `(cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)`, not `(cfc_toLinearFunctional ha x y) f`.\n\nBut in Lean's definition, `cfc_toComplexMeasure ha x y` is defined as `ComplexRMK.rieszMeasure (compSL ...)` where the composition is `C₀(X) → C(X) → ℂ`. So:\n- `ComplexMeasure.integral (cfc_toComplexMeasure ha x y) f` is actually `(cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)`.\n\nBut `zeroAtInfty.toContinuousMap f : C₀(X)` and `norm (zeroAtInfty.toContinuousMap f) ≤ norm f`, because the operator `zeroAtInfty.toContinuousMap : C(X) → C₀(X)` has norm `≤ 1`.\n\nThus, we have:\n```\n‖(cfc_toComplexMeasure ha x y).integral f‖ \n= ‖(cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)‖\n≤ ‖cfc_toLinearFunctional ha x y‖ * ‖zeroAtInfty.toContinuousMap f‖\n≤ (‖x‖ * ‖y‖) * ‖f‖\n```\n\nBut we need to ensure that `‖zeroAtInfty.toContinuousMap f‖ ≤ ‖f‖`. \n\nAlternatively, perhaps Lean's `cfc_toComplexMeasure` is not using `zeroAtInfty.toContinuousMap` in a way that introduces a norm discrepancy. \n\nBut looking more carefully at the definitions in Lean:\n- `cfc_toComplexMeasure ha x y` is defined using `ComplexRMK.rieszMeasure (compSL C₀(X) C(X) ℂ _ _ (cfc_toLinearFunctional ha x y) ...)`.\n   - The composition is `C₀(X) → C(X) → ℂ`.\n   - `C₀(X)` is embedded into `C(X)` by a map (likely with norm `≤ 1` if it is the restriction map).\n   - So the functional on `C₀(X)` is `(cfc_toLinearFunctional ha x y) ∘ (C₀(X) → C(X))`.\n   - Then `ComplexRMK.rieszMeasure` gives a measure `μ` s.t. `∫ φ dμ = (cfc_toLinearFunctional ha x y)(φ')`, where `φ' : C(X)` is the image of `φ : C₀(X)` under the embedding.\n   - Therefore, for `f : C(X)`, `∫ f dμ = (cfc_toLinearFunctional ha x y)(f')` where `f' : C₀(X)` is `f` restricted to `X`? No, this is not directly possible because `C(X)` and `C₀(X)` are different spaces.\n   - Hmm, perhaps Lean is composing with the embedding `C₀(X) → C(X)` to make `(cfc_toLinearFunctional ha x y)` a functional on `C₀(X)`?\n\nAlternatively, perhaps Lean is using the fact that `C₀(X)` is a quotient of `C(X)` when `X` is compact (which it is, since it is the spectrum of a bounded operator). But perhaps the definition is more subtle.\n\nBut perhaps a better approach is to note that the `ComplexMeasure.integral` of `f : C(X)` against the measure `μ` is actually defined by `μ` acting on the restriction of `f` to a suitable compact space (but perhaps `X` is already compact).\n\nWait no: Lean's `ComplexMeasure.integral` takes `f : C(X)`, and `X` is the spectrum of `a`, which is compact because `a` is a compact operator (but actually `a` is just self adjoint, not necessarily compact).\n\nWait no: the spectrum of a bounded operator on a Banach space is compact, so `spectrum ℂ a` is indeed compact because `a : H →L[ℂ] H` is bounded (since it is a linear map between normed spaces and Lean automatically assumes it is bounded). \n\nThus, `C(spectrum ℂ a)` can be seen as `C₀(spectrum ℂ a)` because `spectrum ℂ a` is compact. \n\nBut Lean's definition uses `zeroAtInfty.toContinuousMap f : C₀(spectrum ℂ a)`, which is `f` because `f` is already zero at infinity (since `spectrum ℂ a` is compact). \n\nBut perhaps the `zeroAtInfty.toContinuousMap : C(X) → C₀(X)` is actually an isometry? If so, then `‖zeroAtInfty.toContinuousMap f‖ = ‖f‖` because for compact `X`, `C₀(X) = C(X)`.\n\nTherefore, perhaps the following is true: \n\n`‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖zeroAtInfty.toContinuousMap f‖ = ‖x‖ * ‖y‖ * ‖f‖`\n\nBut we need to verify that `‖zeroAtInfty.toContinuousMap f‖ = ‖f‖` when `X` is compact. \n\nIndeed, if `X` is compact, then `C₀(X) = C(X)` and the embedding `C(X) → C₀(X)` is an isometry.\n\nBut Lean's `zeroAtInfty.toContinuousMap : C(X) → C₀(X)` is defined when `X` is a locally compact space, but it is not always an isometry. \n\nHowever, in the case where `X` is compact, we have that:\n- The supremum norm on `C₀(X)` is the same as the supremum norm on `C(X)` because functions in `C₀(X)` are automatically bounded and `C(X)` is all continuous functions on `X` (since `X` is compact).\nThus, for compact `X`, `zeroAtInfty.toContinuousMap : C(X) → C₀(X)` is actually an isometry because it preserves the supremum norm.\n\nBut in Lean, `spectrum ℂ a` is compact because it is the spectrum of a bounded operator (as `a` is automatically bounded because it is a continuous linear map). \n\nTherefore:\n`‖zeroAtInfty.toContinuousMap f‖ = ‖f‖`, because `spectrum ℂ a` is compact and the embedding is an isometry.\n\nSo now we have the correct proof steps:\n1. `‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)‖`\n   - Because `ComplexMeasure.integral` is defined using `rieszMeasure`, which maps `f : C(X)` to `(cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)`.\n2. `‖(cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖zeroAtInfty.toContinuousMap f‖`\n   - By the operator norm property.\n3. `‖zeroAtInfty.toContinuousMap f‖ = ‖f‖`\n   - Because the embedding is an isometry when `X` is compact (here, `X = spectrum ℂ a` is compact).\n4. `‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖`\n   - As established earlier (`cfc_toLinearFunctional_bound`).\n5. Combining these gives `‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖`.\n\nNow, to formalize step 1 in Lean:\n- The integral `(cfc_toComplexMeasure ha x y).integral f` is defined by `ComplexMeasure.integral`, which for the measure obtained via `ComplexRMK.rieszMeasure` will be `(cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)` because of how `rieszMeasure` is constructed with the composition `C₀(X) → C(X) → ℂ`.\n\nBut perhaps Lean's API for `ComplexMeasure.integral` directly gives us that `ComplexMeasure.integral (ComplexRMK.rieszMeasure L) f = L (zeroAtInfty.toContinuousMap f)`?\n\nIn Lean, `ComplexMeasure.integral` for `μ = rieszMeasure L` is defined as:\n```\nintegral μ f = L (zeroAtInfty.toContinuousMap f)\n```\n\nThis seems to be the case based on the source code of `MeasureTheory.rieszMeasure` (or `ComplexMeasure.rieszMeasure`). \n\nThus:\n- `ComplexMeasure.integral (cfc_toComplexMeasure ha x y) f = (cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)`.\n\nNow for step 3, in Lean, `spectrum ℂ a` is compact because `a : H →L[ℂ] H` is a bounded operator (as a continuous linear map) and the spectrum of a bounded operator is compact. \n\nMoreover, Lean's `zeroAtInfty.toContinuousMap` is an isometry when `X` is compact:\n- `‖zeroAtInfty.toContinuousMap f‖ = ‖f‖`, because the supremum norm on `C(X)` is the same as that on `C₀(X)` when `X` is compact.\n\nBut let's check if Lean already has this fact. \n\nIt is likely that Lean has a lemma that `IsCompact X → Isometry zeroAtInfty.toContinuousMap`, but perhaps not exactly.\n\nAlternatively, since `spectrum ℂ a` is compact, we can show that for any `f : C(spectrum ℂ a)`, `‖zeroAtInfty.toContinuousMap f‖ = ‖f‖` because `f` is already zero at infinity (as the space is compact).\n\nBut perhaps the following is true in Lean:\n`‖(zeroAtInfty.toContinuousMap f : C₀(X))‖ = ‖f : C(X)‖` when `X` is compact.\n\nIndeed, `‖f : C(X)‖ = sup_{x ∈ X} |f x|`, and `‖zeroAtInfty.toContinuousMap f : C₀(X)‖ = sup_{x ∈ X} |f x|` because the latter is the same as the former as `X` is the whole space.\n\nThus, it should hold that `‖zeroAtInfty.toContinuousMap f‖ = ‖f‖` for compact `X`. \n\n### Formal Proof Steps\n\n1. Show that `‖(zeroAtInfty.toContinuousMap f : C₀(X))‖ = ‖f : C(X)‖` when `X` is compact (`X = spectrum ℂ a` here).\n2. Use the property of the Riesz-Markov-Kakutani measure to write `(cfc_toComplexMeasure ha x y).integral f = (cfc_toLinearFunctional ha x y) (zeroAtInfty.toContinuousMap f)`.\n3. Bound the norm using the operator norm of `cfc_toLinearFunctional ha x y` and `‖zeroAtInfty.toContinuousMap f‖ = ‖f‖`.\n\nBut perhaps step 1 is not even needed, as Lean might already have `‖zeroAtInfty.toContinuousMap f‖ ≤ ‖f‖`, but not necessarily equality.",
      "f",
      "\n  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖cfc_toLinearFunctional ha x y f‖ := by\n    -- The integral is the same as the linear functional applied to f\n    simp [ComplexMeasure.integral, ComplexMeasure.rieszExtend]\n    <;> rfl\n  rw [h₁]\n  -- Use the bound on the linear functional\n  have h₂ : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ := by\n    calc\n      ‖cfc_toLinearFunctional ha x y f‖ = ‖⟪x, ((cfcHom (IsSelfAdjoint.isStarNormal ha)) f y)⟫_ℂ‖ := by\n        simp [cfc_toLinearFunctional_apply]\n      _ ≤ ‖x‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f y)‖ := by\n        -- Use the inequality ‖⟨x, y⟩‖ ≤ ‖x‖ * ‖y‖\n        exact norm_inner_le_norm x (((cfcHom (IsSelfAdjoint.isStarNormal ha)) f) y)\n      _ ≤ ‖x‖ * (‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ * ‖y‖) := by\n        -- Use the fact that ‖T(y)‖ ≤ ‖T‖ * ‖y‖\n        have h₃ : ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f y)‖ ≤ ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ * ‖y‖ := by\n          exact le_opNorm ((cfcHom (IsSelfAdjoint.isStarNormal ha)) f) y\n        calc\n          ‖x‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f y)‖ ≤ ‖x‖ * (‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ * ‖y‖) := by\n            gcongr\n          _ = ‖x‖ * (‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ * ‖y‖) := by rfl\n      _ = ‖x‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ * ‖y‖ := by ring\n      _ = ‖x‖ * ‖y‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ := by ring\n      _ ≤ ‖x‖ * ‖y‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ := by rfl\n      _ = ‖x‖ * ‖y‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ := by rfl\n      _ = ‖x‖ * ‖y‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ := by rfl\n      _ = ‖x‖ * ‖y‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ := by rfl\n  have h₃ : ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ = ‖f‖ := by\n    rw [norm_cfcHom a f]\n  have h₄ : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖f‖ := by\n    calc\n      ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖((cfcHom (IsSelfAdjoint.isStarNormal ha)) f)‖ := h₂\n      _ = ‖x‖ * ‖f‖ := by rw [h₃]\n  calc\n    ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖x‖ * ‖f‖ := h₄\n    _ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n      -- Use the fact that ‖y‖ ≥ 1 leads to a contradiction if we had a tighter bound\n      have h₅ : ‖y‖ ≥ 0 := norm_nonneg y\n      have h₆ : ‖x‖ ≥ 0 := norm_nonneg x\n      have h₇ : ‖f‖ ≥ 0 := norm_nonneg f\n      by_cases h : ‖y‖ = 0\n      · -- If ‖y‖ = 0, then ‖x‖ * ‖f‖ = 0 ≤ 0\n        have h₈ : ‖x‖ * ‖f‖ = 0 := by\n          have h₉ : ‖x‖ * ‖f‖ = ‖x‖ * ‖f‖ := rfl\n          have h₁₀ : ‖y‖ = 0 := h\n          have h₁₁ : ‖x‖ ≥ 0 := norm_nonneg x\n          have h₁₂ : ‖f‖ ≥ 0 := norm_nonneg f\n          -- Use the fact that ‖y‖ = 0 to deduce that ‖x‖ * ‖f‖ = 0\n          simp_all [h₁₀]\n          <;>\n          (try norm_num) <;>\n          (try linarith) <;>\n          (try nlinarith)\n        have h₉ : ‖x‖ * ‖y‖ * ‖f‖ = 0 := by\n          simp_all [h]\n          <;>\n          (try norm_num) <;>\n          (try linarith) <;>\n          (try nlinarith)\n        linarith\n      · -- If ‖y‖ > 0, then ‖x‖ * ‖f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖\n        have h₈ : ‖y‖ > 0 := by\n          by_contra h₈\n          have h₉ : ‖y‖ ≤ 0 := by linarith\n          have h₁₀ : ‖y‖ ≥ 0 := norm_nonneg y\n          have h₁₁ : ‖y‖ = 0 := by linarith\n          contradiction\n        have h₉ : ‖x‖ * ‖f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n          -- Use the fact that ‖y‖ > 0 to deduce that ‖x‖ * ‖f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖\n          have h₁₀ : 0 ≤ ‖x‖ * ‖f‖ := by positivity\n          have h₁₁ : 0 ≤ ‖x‖ * ‖y‖ := by positivity\n          have h₁₂ : 0 ≤ ‖y‖ := by positivity\n          have h₁₃ : 0 ≤ ‖x‖ := by positivity\n          have h₁₄ : 0 ≤ ‖f‖ := by positivity\n          have h₁₅ : 1 ≤ ‖y‖ := by\n            by_contra h₁₅\n            have h₁₆ : ‖y‖ < 1 := by linarith\n            have h₁₇ : ‖y‖ > 0 := h₈\n            linarith\n          calc\n            ‖x‖ * ‖f‖ = ‖x‖ * 1 * ‖f‖ := by ring\n            _ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by\n              gcongr\n              <;> nlinarith\n            _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring\n        linarith",
      "`|∫ f dμ| ≤ ‖f‖ * ‖μ‖` because:\n\nFor a complex measure `μ`, `∫ f dμ` is the same as `∫ f dμ` in the usual sense because `f` is continuous and the measure is regular (which it is because it is constructed via Riesz-Markov). Thus, by standard measure theory, `|∫ f dμ| ≤ ∫ |f| d|μ| ≤ ‖f‖ ∫ 1 d|μ| = ‖f‖ * ‖μ‖`.\n\nIn Lean, we can find that:\n\nFor any `f : C(X, ℂ)`, we have that `Integrable f μ`, and `‖∫ f dμ‖ ≤ ‖f‖ * ‖μ‖`.\n\nBut perhaps `‖f‖` in Lean is the `sup` norm, and `‖μ‖` is the total variation. \n\nBut the lemma `ComplexMeasure.abs_integral_le` in Lean says exactly that:\n\n`‖∫ f dμ‖ ≤ ‖f‖ * ‖μ‖` when `f` is `Integrable`.\n\nHere, `f : C(X, ℂ)` is automatically integrable because it is continuous on a compact space (but `X = σ(a)` is compact, and `f : C(σ(a), ℂ)` is continuous on the compact set `σ(a)`).\n\nThus, perhaps we need:\n\n1. Prove that `f : C(σ(a), ℂ)` is integrable with respect to `μ",
      "\n   **But in Lean, it's:**\n   - `μ = ComplexRmk.rieszMeasure (T ∘ (C₀ → C))`, but because `X` is compact, `C₀(X)` and `C(X)` are equal.\n   - But Lean might not know this unless we use the fact that `C₀` on a compact set is equal to `C`.\n\n   **But actually `C₀(σ(a))` and `C(σ(a))` are the same as spaces:**\n   - The space of complex continuous zero-at-infinity functions on `σ(a)` is the same as the space of continuous functions `C(σ(a))` because `σ(a)` is compact (`zero-at-infty` is vacuous as there is no infinity in a compact space).\n\n   So perhaps we can say that:\n   - The inclusion `C₀(σ(a)) → C(σ(a))` is just the identity.\n   - The composition is `T ∘ id = T`.\n   - Then `μ = ComplexRmk.rieszMeasure T`, and for every `f ∈ C(σ(a))`, `∫ f dμ = T f`.\n\n   But actually no: \n   - Lean defines `ComplexRmk.rieszMeasure",
      "\n   Actually, looking closely at Lean's definition, `cfc_toComplexMeasure` uses `continuityMap`, which seems incorrect. A better approach is to directly use the fact that the `cfc_toLinearFunctional` is a continuous linear functional on `C`, and then use the Riesz-Markov-Kakutani theorem for `C(K)` (but Lean's version only seems to be for `C₀(K)`). \n\n   However, in Lean, `ComplexMeasure.integral` is only defined for functions in `C₀`, so perhaps we need to ask that `f` is in `C₀`. But in the problem statement, `f` is in `C`. \n\n   But let's check the Lean definitions again carefully. It turns out that `ComplexMeasure` (via `MeasureTheory`) is defined on the space of functions that are equal almost everywhere to a compactly supported continuous function. So `f` is not necessarily in this space. \n\n   **Clarification**: `cfc_toComplexMeasure` is constructed incorrectly in Lean, as `ComplexRMK.rieszMeasure` expects a linear functional on `C₀`, but `cfc_toLinearFunctional` is on `C`. \n\n   **But in Lean's mathlib, `RieszMeasure` is defined for a map `F : C_c(X) → 𝕜`, so it does not apply directly to `F : C(K) → 𝕜` unless we can identify `C(K)` with `C_c(K)` (but if `K` is compact, it is `C_c(K)`). \n\n   But in Lean, the type `(spectrum ℂ a)` is not known to be compact (we should have that `a` is bounded, otherwise the spectrum is not compact; but in Lean, `a : H →L[ℂ] H` is automatically bounded). \n\n   Actually, in Lean, for `a : H →L[ℂ] H`, the spectrum is compact (`IsCompact.spectrum`), so perhaps we are good. \n\n   Then perhaps Lean expects `F : C_c(X) → 𝕜`, but `C(K) = C_c(K)` when `K` is compact (`ContinuousMap.ext`).\n\n   Wait no: Lean's `C_c` is for `C₀`, the functions vanishing at infinity. So perhaps Lean's `RieszMeasure` is to be used with `F : C₀ → 𝕜`. \n\n   But `cfc_toLinearFunctional : C((spectrum ℂ a), ℂ) →L[ℂ] ℂ`, and to get a `C₀ → 𝕜`, we could composing with `C₀ ↪ C`. So `C₀ → C → 𝕜`, and Lean will get the Riesz measure of that. \n\n   **But in the Lean code, `cfc_toComplexMeasure` instead uses `F : C → 𝕜`, then is mapped via the continuity map `C₀ → C` to `C₀ → 𝕜`, but this is not the right direction.** \n\n   This suggests that the Lean definition of `cfc_toComplexMeasure` is backward. The right approach would be to have `F : C(K) → 𝕜`, then notice `C₀(K) = C_c(K) = C(K)` when `K` is compact, and then take Riesz measure of `F ∘ inclusion`.\n\n   So perhaps we should redefine `cfc_toComplexMeasure` as the Riesz measure of `cfc_toLinearFunctional ha x y ∘ inclusion`. \n\n   But in the Lean code, it uses `ContinuousMap.liftZeroAtInfty` (the inclusion `C₀ ↪ C`), but we need `C ↪ C₀`? No, we should not have that! \n\n   Alternatively, perhaps the Lean code uses the inclusion `C₀(K) ↪ C(K)` when `K` is compact (as it is), but in the direction `C₀ ↪ C`, and then `cfc_toLinearFunctional` is on `C`, so the composition is `C₀ → C → 𝕜`. \n\n   But in Lean, `RieszMeasure` needs `F : C₀ → 𝕜`, but we have `C₀ → C → 𝕜`. Hmm. \n\n   Maybe not. Let's read the Lean code for `ComplexRMK.rieszMeasure` carefully: it wants `F : C₀(X) → 𝕜`, but the Lean code for `cfc_toComplexMeasure` is applying it to `F : C → 𝕜` composed with `C₀ → C`. \n\n   So perhaps the Lean code is trying to say that we have `G : C₀ → C` (`liftZeroAtInfty` is the inclusion `C₀ ↪ C`) and `F : C → 𝕜`, so we can make `F ∘ G : C₀ → 𝕜`, and then take the Riesz measure. \n\n   But actually `liftZeroAtInfty : C₀ ↪ C` is injective, but it is not surjective unless `X` is compact. \n\n   Now, if we have `F : C → 𝕜` and take `F ∘ G : C₀ → 𝕜`, then for the Riesz measure to work, it requires that `X` is locally compact, and the `F` to come from `C₀`. \n\n   But in our case, `F = cfc_toLinearFunctional ha x y`, which is the map `f ↦ ⟪x, f(a) y⟫_ℂ`, and `G : C₀ ↪ C` is `g ↦ g`. \n\n   So we are getting `F ∘ G = (g ↦ ⟪x, g(a) y⟫_ℂ)`, which is fine because `g` is continuous and compactly supported, hence in `C`. \n\n   The only problem is that `X = spectrum ℂ a`, which is compact because `a` is bounded (as `a : H →L[ℂ] H`). \n\n   So actually, we should have `C₀(X) = C(K)` because `X` is compact. But no: the topological space of `spectrum ℂ a` is not `K` but the subspace of `ℂ`, and if it's compact, then `C(spectrum ℂ a)` is the same as `C₀(spectrum ℂ a)` because any continuous function on a compact space is already in `C₀` (as it automatically vanishes at infinity because there's no infinity!).\n\n   Wait, no: in Lean, if `X` is compact, then `C₀(X)` is the set of continuous functions on `X` that vanish at infinity, but since `X` is already compact, this means the set of functions that vanish at every point. No, that's not the case, because the \"infinity\" is not part of `X`.\n\n   The correct statement is: if `X` is compact, then every continuous function `X → 𝕜` (here `𝕜 = ℂ`) is in `C₀(X)` because for any `ε > 0`, taking `K = X`, `f(K)` is compact, so it is bounded, and for any point at infinity (but there are none), the function automatically vanishes.\n\n   No, that's incorrect definitionally. The definition of `C₀(X)` is the set of continuous functions that vanish at infinity, meaning for every `ε > 0`, there exists a compact set `K` such that `|f(x)| < ε` for all `x ∈ X \\ K`.\n\n   But if `X` is compact, then we can take `K = X`, and there's no `x ∈ X \\ K`, so the condition is vacuously true. Hence all continuous functions on `X` are in `C₀(X)` if `X` is compact.\n\n   So in Lean, if `X` is compact, then `C(X) = C₀(X)` as topological spaces (because the inclusion is continuous and dense, but actually it is a bijection).\n\n   However, in Lean, `RieszMeasure` requires `F : C₀(X) → 𝕜`, so to apply it, we need to think of `F` as defined on `C₀(X)`. \n\n   But we can define `F : C₀(X) → 𝕜` by `f ↦ ⟪x, f(a) y⟫_ℂ` because if `X` is compact, `C₀(X) = C(X)` and `a` is bounded (as it is an operator), `a` can be applied to `f ∈ C(X)`, but `f` is not in `C(X)` unless it is already a function on `ℂ`... \n\n   Hmm. Wait no: `cfcHom ha.isStarNormal f` is defined for `f : C(spectrum ℂ a, ℂ)`, and we can get an operator for that. But if `g : C₀(spectrum ℂ a, ℂ)`, and `spectrum ℂ a` is compact, then we can think of `g` as a continuous function `spectrum ℂ a → ℂ`, so `g ∈ C(spectrum ℂ a, ℂ)`. \n\n   Thus, we can define a new functional `G : C₀(spectrum ℂ a, ℂ) → ℂ` as `g ↦ ⟪x, (cfcHom ha.isStarNormal (g : C(spectrum ℂ a, ℂ))) y⟫_ℂ`. \n\n   So to use Riesz, we should actually use this `G`, not the `F` on `C`. \n\n   **But Lean's code uses `F` on `C`, and then `F ∘ (G : C₀ → C)` to get the functional on `C₀`.** \n\n   If `X` is compact, then `G : C₀(X) → C(X)` is bijective, but Lean does not recognize this yet. \n\n   Therefore, perhaps the Lean code is correct because if `X` is compact, `C₀(X)` is dense in `C(X)` (but actually equal!), but `RieszMeasure` is constructed using the condition that the space is locally compact, and it produces a measure for any continuous functional on `C₀(X)`. \n\n   The problem is that we have a continuous functional on `C(X)`, and to make it on `C₀(X)`, we can restrict it, but if `X` is compact, then every continuous function on `X` is already in `C₀(X)`. \n\n   But perhaps Lean does not use this fact, and we need to use that `C₀` is dense in `C` (for the sup norm), but perhaps that's not directly relevant. \n\n   Anyway, since `X = spectrum ℂ a` is compact (because `a` is bounded, as it is a linear operator on a normed space), and because `C₀(X)` is the set of functions vanishing at infinity, and all continuous functions on a compact space vanish at infinity (vacuously), we have that `C(X) = C₀(X)`.\n\n   So perhaps Lean can use `cfc_toLinearFunctional` as the functional on `C₀(X)` because they are the same as `C(X)` here. \n\n   Thus, perhaps we can proceed assuming that `ComplexMeasure.integral` works in such a way that the integral is equal to the original functional. \n\n   But perhaps we don't even need that. \n\n   Anyway, the actual statement is `‖integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖`, where `f : C(spectrum ℂ a, ℂ)`. \n\n   But perhaps Lean's `ComplexMeasure.integral f` is actually defined for `f : C(spectrum ℂ a, ℂ)` by thinking of `f` as `C₀`, because of the compactness, and then using that the previous norm estimates already give `‖F(f)‖ ≤ ‖x‖ * ‖y‖ * ‖f‖`, because `‖f‖` as a `C₀` function is the same as the `C` norm. \n\n   So perhaps we can just use that:\n   - `ComplexMeasure.integral f` (with `f : C(X)`) is defined (because in Lean, `ComplexMeasure` is defined so that the integral is only for functions a.e. equal to a compact supported function, but perhaps in the case where `X` is compact, and `f` is continuous, it's the same as `F(f)`).\n\n   This seems very shaky. \n\n   **Alternatively**, perhaps we can use the following strategy:\n\n   1. Because `X` is compact, every continuous function on `X` is in `C₀(X)`, so we can interpret `cfc_toLinearFunctional ha x y` also as a functional on `C₀(X)",
      "\n  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖ComplexMeasure.toTotalMeasure (cfc_toComplexMeasure ha x y)‖ * ‖f‖ := by\n    apply integral_norm_le\n  have h₂ : ‖ComplexMeasure.toTotalMeasure (cfc_toComplexMeasure ha x y)‖ = ‖cfc_toLinearFunctional ha x y‖ := by\n    sorry\n  have h₃ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by\n    apply cfc_toLinearFunctional_bound\n  have h₄ : ‖ComplexMeasure.toTotalMeasure (cfc_toComplexMeasure ha x y)‖ ≤ ‖x‖ * ‖y‖ := by\n    calc\n      ‖ComplexMeasure.toTotalMeasure (cfc_toComplexMeasure ha x y)‖ = ‖cfc_toLinearFunctional ha x y‖ := by rw [h₂]\n      _ ≤ ‖x‖ * ‖y‖ := h₃\n  calc\n    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖ComplexMeasure.toTotalMeasure (cfc_toComplexMeasure ha x y)‖ * ‖f‖ := h₁\n    _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by gcongr\n    _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring",
      "\n  have h1 : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toLinearFunctional ha x y) f‖ := by\n    have h1 : (cfc_toComplexMeasure ha x y).integral (f : C₀ _) = (cfc_toLinearFunctional ha x y) f := by\n      -- Use the definition of the complex measure and the linear functional to show they are equal\n      simp [cfc_toComplexMeasure, ComplexMeasure.integral, ← ContinuousLinearMap.ofReal_eq_iff]\n      <;>\n      simp_all [Complex.ext_iff, LinearMap.ofReal_apply]\n      <;>\n      norm_cast\n      <;>\n      simp_all [Complex.ext_iff, LinearMap.ofReal_apply]\n      <;>\n      norm_cast\n      <;>\n      simp_all [Complex.ext_iff, LinearMap.ofReal_apply]\n      <;>\n      norm_cast\n      <;>\n      simp_all [Complex.ext_iff, LinearMap.ofReal_apply]\n      <;>\n      norm_cast\n    -- Use the equality of the integrals to show the norms are equal\n    calc\n      ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toComplexMeasure ha x y).integral (f : C₀ _)‖ := by\n        congr 1 <;>\n        simp_all [Coe.comp]\n      _ = ‖(cfc_toLinearFunctional ha x y) f‖ := by rw [h1]\n  \n  have h2 : ‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by\n    have h2 : ‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by\n      calc\n        ‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by\n          -- Use the fact that the norm of the linear map applied to f is bounded by the product of the norms\n          calc\n            ‖(cfc_toLinearFunctional ha x y) f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by\n              -- Apply the bound for the norm of a linear map\n              exact (continuousLinearMap_norm_le _ _)\n            _ = ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by rfl\n        _ = ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a)