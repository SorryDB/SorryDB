theorem T_cases_zero {L : Type*} [Access L] [DecidableEq L] [Fintype L] (l : L) :
    l ∈ ({0, 1} : Finset L) → False := by
  intro h
  have h₁ : l = 0 ∨ l = 1 := by
    simp only [Finset.mem_insert, Finset.mem_singleton] at h
    tauto
  have h₂ : False := by
    cases h₁ with
    | inl h₁ =>
      have h₃ : l = 0 := h₁
      have h₄ : (l : ℕ) % 2 = 1 := by
        haveI : Fact (Nat.Prime 2) := ⟨by decide⟩
        have h₅ : (l : ℕ) % 2 = 1 := by
          simp_all [Access, Nat.mod_eq_of_lt]
          <;> norm_num
        exact h₅
      have h₅ : (l : ℕ) = 0 := by
        simp_all [h₃]
      omega
    | inr h₁ =>
      have h₃ : l = 1 := h₁
      have h₄ : (l : ℕ) % 2 = 1 := by
        haveI : Fact (Nat.Prime 2) := ⟨by decide⟩
        have h₅ : (l : ℕ) % 2 = 1 := by
          simp_all [Access, Nat.mod_eq_of_lt]
          <;> norm_num
        exact h₅
      have h₅ : (l : ℕ) = 1 := by
        simp_all [h₃]
      omega
  exact h₂
