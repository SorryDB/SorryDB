        simp_all [ZMod.card, Finset.card_eq_one]
        <;>
        (try decide)
        <;>
        (try
          {
            norm_num at *
            <;>
            simp_all [ZMod.nat_cast_self]
          })
      }) <;>
    (try
      {
        rfl
      })
  have h₃ : (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
    use 0
    intro h₄
    have h₅ : p = 1 := by
      omega
    have h₆ : p.Prime := h.1
    have h₇ : p = 1 → False := by
      intro h₈
      have h₉ : p.Prime := h.1
      have h₁₀ : ¬Nat.Prime 1 := by decide
      simp_all [h₈]
    exfalso
    exact h₇ h₅
  exact ⟨h₁, h₂, h₃⟩
