lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  intro num_solutions
  have h₁ : (∃ m, p = 4 * m + 1 → {s : ZMod p | s ^ 2 = -1}.card = 2) := by
    refine' ⟨0, _⟩
    intro h₂
    have h₃ : p = 1 := by
      have h₄ := h₂
      omega
    have h₄ : p.Prime := h.out
    have h₅ : p ≠ 1 := Nat.Prime.ne_one h₄
    contradiction
  have h₂ : (p = 2 → {s : ZMod p | s ^ 2 = -1}.card = 1) := by
    intro h₃
    have h₄ : p = 2 := h₃
    have h₅ : p.Prime := h.out
    subst_vars
    -- We need to show that in ZMod 2, the equation s^2 = -1 has exactly one solution.
    -- Since -1 ≡ 1 mod 2, we are solving s^2 ≡ 1 mod 2.
    -- The elements of ZMod 2 are 0 and 1.
    -- 0^2 = 0 ≢ 1 mod 2, and 1^2 = 1 ≡ 1 mod 2.
    -- Thus, the only solution is s ≡ 1 mod 2.
    norm_num [ZMod.nat_cast_self]
    <;>
    rfl
  have h₃ : (∃ m, p = 4 * m + 1 → {s : ZMod p | s ^ 2 = -1}.card = 0) := by
    refine' ⟨0, _⟩
    intro h₄
    have h₅ : p = 1 := by
      omega
    have h₆ : p.Prime := h.out
    have h₇ : p ≠ 1 := Nat.Prime.ne_one h₆
    contradiction
  exact ⟨h₁, h₂, h₃⟩
