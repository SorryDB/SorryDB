    use 0
    intro h₂
    have h₃ : p = 1 := by
      omega
    have h₄ : p.Prime := h.1
    have h₅ : p = 1 → False := by
      intro h₆
      have h₇ : p.Prime := h.1
      have h₈ : ¬Nat.Prime 1 := by decide
      simp_all [h₆]
    exfalso
    exact h₅ h₃
  have h₂ : (p = 2 → num_solutions = 1) := by
    intro h₃
    have h₄ : p = 2 := h₃
    have h₅ : p.Prime := h.1
    simp_all [num_solutions]
    <;>
    (try decide) <;>
    (try
