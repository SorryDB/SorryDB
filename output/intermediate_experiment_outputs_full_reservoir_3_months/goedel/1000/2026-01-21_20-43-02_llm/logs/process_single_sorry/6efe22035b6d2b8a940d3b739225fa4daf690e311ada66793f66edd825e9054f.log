    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  intro num_solutions
  have h₁ : (∃ m, p = 4 * m + 1 → num_solutions = 2) := by
    refine' ⟨p + 1, _⟩
    intro h₂
    have h₃ : p = 4 * (p + 1) + 1 := by omega
    have h₄ : p ≥ 2 := Nat.Prime.two_le h.1
    omega
  
