      "h₁ : ∃ m, p = 4 * m + 1 → {s : ZMod p | s ^ 2 = -1}.card = 2 := by\n    use 1\n    intro h₂\n    have h₃ : p = 4 * 1 + 1 := h₂\n    have h₄ : p = 5 := by\n      norm_num at h₃ ⊢\n      <;> linarith\n    subst h₄\n    -- For p = 5, we compute the number of solutions to x² ≡ -1 mod 5\n    -- The solutions are 2 and 3 since 2² ≡ 4 ≡ -1 and 3² ≡ 9 ≡ -1 mod 5\n    norm_num [ZMod.nat_cast_self, num_solutions, Finset.card_eq_sum_ones]\n    <;> rfl\n  have h₂ : p = 2 → {s : ZMod p | s ^ 2 = -1}.card = 1 := by\n    intro h₃\n    have h₄ : p = 2 := h₃\n    subst h₄\n    -- For p = 2, we compute the number of solutions to x² ≡ -1 ≡ 1 mod 2\n    -- The only solution is 1 since 0² ≡ 0 ≢ 1 and 1² ≡ 1 mod 2\n    norm_num [ZMod.nat_cast_self, num_solutions, Finset.card_eq_sum_ones]\n    <;> rfl\n  have h₃ : ∃ m, p = 4 * m + 1 → {s : ZMod p | s ^ 2 = -1}.card = 0 := by\n    use 0\n    intro h₄\n    have h₅ : p = 4 * 0 + 1 := h₄\n    have h₆ : p = 1 := by\n      norm_num at h₅ ⊢\n      <;> linarith\n    -- Since p is a prime and p = 1, this case is impossible\n    have h₇ : p.Prime := Fact.out h\n    have h₈ : ¬p.Prime := by\n      subst h₆\n      norm_num [Nat.Prime]\n    exact False.elim (h₈ h₇)\n  exact ⟨h₁, h₂, h₃⟩",
