lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  have h₁ : ∃ m, p = 4 * m + 1 → Finset.card {s : ZMod p | s ^ 2 = -1} = 2 := by
    refine' ⟨0, _⟩
    intro h₂
    have h₃ := h.1
    have h₄ : p = 1 := by
      have h₅ : p = 4 * 0 + 1 := h₂
      omega
    have h₅ : p.Prime := h.1
    rw [h₄] at h₅
    norm_num at h₅
    <;> contradiction
  
  have h₂ : p = 2 → Finset.card {s : ZMod p | s ^ 2 = -1} = 1 := by
    intro h₃
    have h₄ : p = 2 := h₃
    subst_vars
    -- We need to show that the number of solutions to s^2 = -1 in Z/2Z is 1.
    -- In Z/2Z, the elements are 0 and 1.
    -- 0^2 = 0 ≡ -1 ≡ 1 (mod 2)?
    -- Actually, -1 ≡ 1 (mod 2), and 0^2 ≡ 0 ≢ 1 (mod 2).
    -- 1^2 ≡ 1 ≡ -1 (mod 2).
    -- So the only solution is s = 1.
    -- The set is {1}, and its cardinality is 1.
    rfl
  
  have h₃ : ∃ m, p = 4 * m + 1 → Finset.card {s : ZMod p | s ^ 2 = -1} = 0 := by
    refine' ⟨0, _⟩
    intro h₄
    have h₅ := h.1
    have h₆ : p = 1 := by
      have h₇ : p = 4 * 0 + 1 := h₄
      omega
    have h₇ : p.Prime := h.1
    rw [h₆] at h₇
    norm_num at h₇
    <;> contradiction
  
  exact ⟨h₁, h₂, h₃⟩
