```lean
def slice_over' (c : α) := @slice_under (Opposite α) (C.opp) c
theorem slice_over_equiv_slice_over' (c : α) :
  slice_over c = @slice_over' α C c := by
  have h₁ : (C.opp : Category (Opposite α)) = (C.opp : Category (Opposite α)) := rfl
  have h₂ : slice_over c = slice_over' c := by
    -- Use the fact that the opposite category's slice under is the same as the original category's slice over
    simp only [slice_over, slice_over', slice_under, Opposite]
    <;>
    (try congr 1) <;>
    (try ext) <;>
    (try simp_all [Category.opp, Hom, comp, id]) <;>
    (try aesop) <;>
    (try rfl)
  -- The result follows directly from the above equality
  exact h₂
```
