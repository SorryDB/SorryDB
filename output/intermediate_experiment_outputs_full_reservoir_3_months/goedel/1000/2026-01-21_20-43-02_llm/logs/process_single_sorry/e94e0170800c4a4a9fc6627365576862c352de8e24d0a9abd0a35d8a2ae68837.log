  -- Simplify the hypothesis hx to get 0 ≤ x and x ≤ 1.
  norm_num [Real.norm_eq_abs, abs_le] at hx ⊢
  -- Use the fact that 0 ≤ x and x ≤ 1 to show that |x| ≤ 1.
  <;>
  (try cases' le_total 0 x with hx' hx' <;> simp_all [abs_of_nonneg, abs_of_nonpos]) <;>
  nlinarith
  
theorem compact_unit_interval : IsCompact (Set.Icc (0 : ℝ) 1) := by
  have h₁ : IsClosed (Set.Icc (0 : ℝ) 1) := closed_unit_interval
  have h₂ : Bounded (Set.Icc (0 : ℝ) 1) := bounded_unit_interval
  -- Use the general theorem that a closed and bounded set is compact.
  have h₃ : IsCompact (Set.Icc (0 : ℝ) 1) := bounded_and_closed_implies_compact h₁ h₂
  exact h₃
```

