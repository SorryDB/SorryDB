.factorial * (∏ k in Finset.Icc (m + n + 1) (2 * m + 2 * n), k) / (m + n).factorial = (∏ k in Finset.Icc (m + n + 1) (2 * m + 2 * n), k) := by\n              apply Nat.div_eq_of_eq_mul_left (show 0 < (m + n).factorial by apply Nat.factorial_pos)\n              <;>\n              ring_nf\n              <;>\n              simp_all [mul_comm]\n              <;>\n              try { omega }\n            rw [h₂₃]\n          exact h₂₀\n        rw [h₁₈]\n      have h₂₁ : (m + n).factorial * (∏ k in Finset.Icc (m + n + 1) (2 * m + 2 * n), k) = (2 * m + 2 * n).factorial / (m + n).factorial := by\n        have h₂₂ : (2 * m + 2 * n).factorial / (m + n).factorial = (∏ k in Finset.Icc (m + n + 1) (2 * m + 2 * n), k) := by\n          rw [h₁₂]\n        have h₂₃ : (m + n).factorial * (∏ k in Finset.Icc (m + n + 1) (2 * m + 2 * n), k) = (m + n).factorial * ((2 * m + 2 * n).factorial / (m + n).factorial) := by\n          rw [h₂₂]\n        have h₂₄ : (m + n).factorial * ((2 * m + 2 * n).factorial / (m + n).factorial) = (2 * m + 2 * n).factorial := by\n          have h₂₅ : (m + n).factorial ∣ (2 * m + 2 * n).factorial := by\n            apply Nat.dvd_of_mod_eq_zero\n            have h₂₆ : (2 * m + 2 * n).factorial % (m + n).factorial = 0 := by\n              have h₂₇ : (m + n).factorial ∣ (2 * m + 2 * n).factorial := by\n                apply Nat.dvd_factorial\n                <;>\n                (try omega) <;>\n                (try nlinarith)\n              exact Nat.mod_eq_zero_of_dvd h₂₇\n            exact h₂₆\n          have h₂₆ : (m + n).factorial * ((2 * m + 2 * n).factorial / (m + n).factorial) = (2 * m + 2 * n).factorial := by\n            apply Nat.mul_div_cancel'\n            exact h₂₅\n          exact h₂₆\n        linarith\n      linarith\n    have h₅ : (2 * m).factorial * (2 * n).factorial = (m ! * n ! * (m + n)!)",
