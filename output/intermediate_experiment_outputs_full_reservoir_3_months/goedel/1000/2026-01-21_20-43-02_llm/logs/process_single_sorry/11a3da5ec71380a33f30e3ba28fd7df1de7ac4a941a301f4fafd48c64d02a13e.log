theorem Φ₁_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₁ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₁_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  -- Use the fact that Φ₁ r is continuous on [0,1] and hence absolutely continuous to prove integrability.
  have h : HasFiniteIntegral (fun x : ℝ => Φ₁ r x) (volume.restrict (Ioc (0 : ℝ) 1)) := by
    -- Since Φ₁ r is continuous on [0,1], it is bounded and hence integrable.
    have h₁ : ContinuousOn (fun x : ℝ => Φ₁ r x) (Set.Icc 0 1) := by
      apply Φ₁_contDiffOn.continuousOn.mono
      intro x hx
      simp at hx ⊢
      <;>
      (try norm_num at hx ⊢) <;>
      (try linarith) <;>
      (try exact ⟨by linarith, by linarith⟩)
    -- Use the fact that a continuous function on a compact set is bounded to show integrability.
    have h₂ : HasFiniteIntegral (fun x : ℝ => Φ₁ r x) (volume.restrict (Ioc (0 : ℝ) 1)) := by
      -- Apply the theorem that a continuous function on a compact set has a finite integral.
      apply ContinuousOn.hasFiniteIntegral_restrict_Icc
      <;> simp_all [h₁]
      <;>
      (try norm_num) <;>
      (try linarith)
    exact h₂
  exact h
