        -- Now, using the fact that the process is bounded in time, we can deduce that the entire process is uniformly integrable.
        have h6 : UniformIntegrable X 1 P := by
          -- Use the density of bounded stopping times to approximate the general stopping times.
          sorry
        exact h6
      exact h2
    have h2 : UniformIntegrable X 1 P → UniformIntegrable (fun T : {T : Ω → WithTop ι | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} =>
      stoppedValue X T.1) 1 P := by
      intro h
      -- Use the density of bounded stopping times to show that the uniform integrability of the bounded stopping times follows from that of X.
      sorry
    exact ⟨h1, h2⟩
  -- Combine the above results to establish the equivalence.
  have hX9 : ClassD X 𝓕 P ↔ UniformIntegrable (fun T : {T : Ω → WithTop ι | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} =>
    stoppedValue X T.1) 1 P := by
