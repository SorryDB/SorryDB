  have hX8 : UniformIntegrable (fun T : {T : Ω → WithTop ι | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} =>
    stoppedValue X T.1) 1 P ↔ UniformIntegrable X 1 P := by
    -- We use the fact that the bounded stopping times are dense in the set of all stopping times
    -- to establish a bijection between the two uniform integrability conditions.
    have h1 : UniformIntegrable (fun T : {T : Ω → WithTop ι | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} =>
