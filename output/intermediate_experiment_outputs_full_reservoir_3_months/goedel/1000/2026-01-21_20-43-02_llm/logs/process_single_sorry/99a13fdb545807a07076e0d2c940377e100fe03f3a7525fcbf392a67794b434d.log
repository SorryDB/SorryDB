      intro h
      have h2 : UniformIntegrable X 1 P := by
        -- Use the density of bounded stopping times to show that the uniform integrability of X follows from that of the bounded stopping times.
        have h3 : ∀ t : ι, UniformIntegrable (fun (x : Ω) => X t x) 1 P := by
          intro t
          have h4 : UniformIntegrable (fun (x : Ω) => X t x) 1 P := by
