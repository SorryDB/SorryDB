      (e.open_baseSet.mem_nhds <| mem_baseSet_trivializationAt _ _ _)
  have h2 :=
    (hf.continuousAt.comp (FiberBundle.continuous_proj E (TangentSpace I)).continuousAt).preimage_mem_nhds
      (e'.open_baseSet.mem_nhds <| mem_baseSet_trivializationAt _ _ _)
