  theorem vec_set_toList {v : Vector α n} {idx : Fin n} {elt : α} :
    (v.set idx elt).toList = v.toList.set (↑idx) elt := by
    -- Prove by induction on the vector index
    have h : ∀ {n : ℕ} {v : Vector α n} {idx : Fin n} {elt : α},
          (v.set idx elt).toList = v.toList.set (↑idx) elt := by
      intro n v
      induction' n with n ih
      · -- Base case: when n = 0, this case is impossible because Fin 0 is empty
        intro idx elt
        exfalso
        exact Fin.elim0 idx
      · -- Inductive step: assume the statement holds for n, prove for n + 1
        intro idx elt
        fin_cases idx <;> simp_all [Vector.set, Vector.toList, List.set]
        <;>
        (try { contradiction }) <;>
        (try { simp_all [Fin.ext_iff] }) <;>
        (try { aesop }) <;>
        (try { rfl }) <;>
        (try { simp_all [List.set] }) <;>
        (try { simp_all [List.set, Fin.ext_iff] }) <;>
        (try { aesop }) <;>
        (try { rfl })
        <;>
        simp_all [Fin.ext_iff, List.set]
        <;>
        aesop
    -- Apply the lemma to the current vector and index
    exact h v idx elt
