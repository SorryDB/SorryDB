theorem RelIO.liftFinf_in {S} {ident : InternalPort Nat} {n : Nat} {f : Fin n → RelIO S}:
  AssocList.contains ident (RelIO.liftFinf n f) = true
  → ∃ i : Fin n, ident = i := by
    dsimp [liftFinf, fin_range]
    simp only [
      AssocList.contains_eq, List.toList_toAssocList, List.any_map,
      List.any_eq_true, List.mem_mapFinIdx, List.length_replicate,
      Function.comp_apply, beq_iff_eq, forall_exists_index, and_imp
    ]
    intro h
    -- We need to find an i such that ident = i
    -- Given that the list contains ident, we can use the fact that it must be in the list
    have h₁ : ∃ (x : ℕ) (y : Fin n) (h₂ : x < n), ident = y := by
      -- Use the fact that the list contains ident to find x and y
      have h₂ : ∃ (x : ℕ) (y : Fin n) (h₃ : x < n), ident = y := by
        -- Use the fact that the list contains ident to find x and y
        cases h with
        | intro x h =>
          cases h with
          | intro y h =>
            cases h with
            | intro h₁ h₂ =>
              -- We have found an x and y such that ident = y
              refine' ⟨x, y, by omega, by simp_all [Fin.ext_iff]⟩
      -- We have found an x and y such that ident = y
      exact h₂
    -- We have found an x and y such that ident = y
    obtain ⟨x, y, h₂, h₃⟩ := h₁
    -- We need to find an i such that ident = i
    refine' ⟨y, _⟩
    -- Simplify the expression to show that ident = y
    simp_all [Fin.ext_iff]
    <;>
    (try omega) <;>
    (try simp_all [Fin.ext_iff]) <;>
    (try omega)
