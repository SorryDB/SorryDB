def rbrKnowledgeSoundnessOneShot_implies_rbrKnowledgeSoundness
    {relIn : Set (StmtIn × WitIn)} {relOut : Set (StmtOut × WitOut)}
    {verifier : Verifier oSpec StmtIn StmtOut pSpec}
    {rbrKnowledgeError : pSpec.ChallengeIdx → ℝ≥0}
    (hInit : HasEvalSPMF.NeverFail init)
    (h : verifier.rbrKnowledgeSoundnessOneShot init impl relIn relOut rbrKnowledgeError) :
    verifier.rbrKnowledgeSoundness init impl relIn relOut rbrKnowledgeError := by
  unfold rbrKnowledgeSoundness
  unfold rbrKnowledgeSoundnessOneShot at h
  obtain ⟨stF, oneShotE, h⟩ := h
  refine ⟨_, oneShotE.toRoundByRound, stF.toKnowledgeStateFunction init impl oneShotE, ?_⟩
  intro stmtIn witIn prover i
  have := h stmtIn witIn prover i
  simp at h ⊢
  <;>
  (try norm_num at h ⊢) <;>
  (try simp_all [ProbComp.le_of_prob_event_mono, prob_event_and]) <;>
  (try
    {
      refine' le_trans _ h
      -- Use the fact that the probability of the new event is less than or equal to the old event's probability
      <;>
      simp_all [ProbComp.le_of_prob_event_mono, prob_event_and]
      <;>
      (try
        {
          refine' probEvent_mono fun x => _
          <;>
          simp_all [verifier, extractor, toFun, toFun_empty, toFun_next, toFun_full]
          <;>
