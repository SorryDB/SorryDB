lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact Filter.map_mono h

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Use the fact that the composition of functions corresponds to the composition of their images
  have h1 : (F.map s).map t ≤ H := by
    -- Since `s` maps `F` to `G` and `t` maps `G` to `H`, we can compose these two facts.
    calc
      (F.map s).map t = F.map (t ∘ s) := by
        -- The image of the image of `F` under `s` under `t` is the same as the image of `F` under `t ∘ s`.
        rw [← Filter.map_map]
        <;> simp [Function.comp]
      _ ≤ H := by
        -- Since `Tendsto (t ∘ s) F H` is `F.map (t ∘ s) ≤ H`, we can directly use this fact.
        simpa [Tendsto] using ht (by
          -- Here, we need to show that `F.map s ≤ G`, which is `Tendsto s F G`.
          simpa [Tendsto] using hs
        )
  -- Simplify the expression to match the definition of `Tendsto`.
  simpa [Tendsto, Function.comp] using h1

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  apply Tendsto_comp
  · exact hf
  · exact hg

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    have h₁ : Tendsto a atTop (𝓝 (-1)) := ha
    have h₂ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I)) := hφ
    -- Use the fact that the composition of two tendsto functions is tendsto
    have h₃ : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp h₁ h₂
    exact h₃
  exact h

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    have h₂ : {x : α | p x} ∈ 𝓝 x := hT
    have h₃ : {x : α | p' x} ∈ 𝓝 x := hT'
    have h₄ : {x : α | q x} ∈ 𝓝 x := hS
    have h₅ : {x : α | q' x} ∈ 𝓝 x := hS'
    have h₆ : {x : α | p x ∧ q x} ∈ 𝓝 x := by
      -- Prove that the intersection of {x | p x} and {x | q x} is in the neighborhood filter
