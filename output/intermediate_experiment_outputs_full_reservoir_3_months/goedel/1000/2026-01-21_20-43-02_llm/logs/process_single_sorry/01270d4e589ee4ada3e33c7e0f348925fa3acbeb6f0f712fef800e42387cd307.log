section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  -- Since `F ≤ G`, for any set `s` in `G.map f`, we can find a set `t` in `F.map f` such that `t ⊆ s`.
  -- This directly implies that `F.map f ≤ G.map f`.
  exact Filter.map_mono h


/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Using the fact that `(t ∘ s)` is `t` composed with `s`, we can leverage the composition properties of filters.
  -- Specifically, `map (t ∘ s) F = map t (map s F)`.
  -- Since `map s F ≤ G` and `map t G ≤ H`, by transitivity, `map t (map s F) ≤ H`.
  have h : (F.map (t ∘ s)) ≤ H := by
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        -- Prove that `map (t ∘ s) F = map t (map s F)`
        rw [← Filter.map_map]
        <;> simp [Function.comp]
      _ ≤ G.map t := by
        -- Since `F.map s ≤ G`, `map t (F.map s) ≤ map t G`
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Since `map t G ≤ H`
        exact ht
  -- Therefore, `Tendsto (t ∘ s) F H` holds.
  exact h


example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  -- Use the lemma Tendsto_comp to prove that `g ∘ f` tends to `atTop` along `𝓝 0`.
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Apply the composition of limits lemma.
    exact Tendsto_comp hf hg
  -- The result follows directly from the lemma.
  exact h


example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
