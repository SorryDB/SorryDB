    -- Since y is in both intersections, it either satisfies p y and q y or p' y and q' y
    have h₄ : p y ∧ q y ∨ p' y ∧ q' y := by
      -- This step is a bit redundant, but we need to make sure the set is correct
      simp only [Set.mem_inter_iff, Set.mem_setOf_eq] at hy₁ hy₂
      by_cases h₅ : p y ∧ q y
