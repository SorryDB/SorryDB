import Mathlib
set_option linter.unusedVariables false

noncomputable section

namespace ItaLean



/-!
# Filters
-/



section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact Filter.map_mono h


/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  simp only [Tendsto] at hs ht ⊢
  -- Use the fact that the composition of the maps is less than or equal to the composition of the filters
  exact Filter.map_le_iff_le_comap.mp (by
    -- Show that the map of the composition is less than or equal to the composition of the maps
    calc
      (F.map (t ∘ s)) = (F.map s).map t := by simp [Filter.map_map]
      _ ≤ G.map t := by
        -- Use the fact that F.map s ≤ G and the monotonicity of the map operation
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Use the fact that G.map t ≤ H and the monotonicity of the map operation
        exact ht
  )


example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  simpa [Tendsto] using Tendsto_comp hf hg


example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  simpa [Tendsto] using Tendsto_comp ha hφ


/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x | p x ∧ q x} ∈ 𝓝 x := by
    -- Since both {x | p x} and {x | q x} are in 𝓝 x, their intersection is also in 𝓝 x.
    have h₁ : {x | p x} ∈ 𝓝 x := hT
    have h₂ : {x | q x} ∈ 𝓝 x := hS
    have h₃ : {x | p x ∧ q x} ∈ 𝓝 x := by
      -- Use the fact that the intersection of two neighborhoods is a neighborhood.
      have h₄ : {x | p x} ∩ {x | q x} ∈ 𝓝 x := by
        apply Filter.inter_mem
        exact h₁
        exact h₂
      -- The intersection can also be written as {x | p x ∧ q x}.
      have h₅ : {x | p x} ∩ {x | q x} = {x | p x ∧ q x} := by
        ext x
        simp [and_comm]
        <;>
        tauto
      rw [h₅] at h₄
      exact h₄
    exact h₃
  
  have h₂ : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    have h₁ : {x | p' x} ∈ 𝓝 x := hT'
    have h₂ : {x | q' x} ∈ 𝓝 x := hS'
    have h₃ : {x | p' x ∧ q' x} ∈ 𝓝 x := by
      have h₄ : {x | p' x} ∩ {x | q' x} ∈ 𝓝 x := by
        apply Filter.inter_mem
        exact h₁
        exact h₂
      have h₅ : {x | p' x} ∩ {x | q' x} = {x | p' x ∧ q' x} := by
        ext x
        simp [and_comm]
        <;>
        tauto
      rw [h₅] at h₄
      exact h₄
    exact h₃
  
  -- Use the fact that the union of two neighborhoods is a neighborhood.
  have h₃ : {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    have h₄ : {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} ∈ 𝓝 x := by
      apply Filter.union_mem
      exact h₁
      exact h₂
    -- The union can also be written as {x | p x ∧ q x ∨ p' x ∧ q' x}.
    have h₅ : {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} = {x | p x ∧ q x ∨ p' x ∧ q' x} := by
      ext x
      simp [or_comm]
      <;>
