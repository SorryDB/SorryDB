    have h4 : {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} ∈ 𝓝 x := by
      apply Filter.union_mem
      · exact h1
      · exact h2
    -- Now we need to show that {x | p x ∧ q x ∨ p' x ∧ q' x} is equal to {x | p x ∧ q x} ∪ {x | p' x ∧ q' x}.
    have h5 : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
      ext x
      simp [or_iff_not_imp_left]
      <;>
      (try tauto) <;>
      (try aesop) <;>
      (try
        {
          by_cases h : p x ∧ q x <;>
          by_cases h' : p' x ∧ q' x <;>
          simp_all [h, h']
          <;>
          tauto
        })
    rw [h5]
    exact h4
  exact h3
