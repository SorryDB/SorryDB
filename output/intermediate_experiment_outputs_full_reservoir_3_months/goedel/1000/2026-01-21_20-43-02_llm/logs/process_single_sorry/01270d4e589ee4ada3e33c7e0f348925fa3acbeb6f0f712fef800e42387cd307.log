lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  have h₁ : F.map f ≤ G.map f := by
    -- Use the fact that if F ≤ G, then F.map f ≤ G.map f for any function f
    exact Filter.map_mono h
  -- Since hs : s ∈ F.map f and h₁ : F.map f ≤ G.map f, we have s ∈ G.map f
  exact h₁ hs

