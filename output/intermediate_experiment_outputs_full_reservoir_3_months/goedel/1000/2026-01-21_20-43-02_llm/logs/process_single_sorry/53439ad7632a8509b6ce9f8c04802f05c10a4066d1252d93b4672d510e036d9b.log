theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · intro h
    -- Assume f is interval integrable, prove r • f is interval integrable
    -- Use the fact that scalar multiplication by a bounded scalar preserves integrability
    have h₁ : IntervalIntegrable (r • f) μ a b := by
      -- Use the fact that scalar multiplication by a bounded scalar preserves integrability
      have h₂ : IntervalIntegrable f μ a b := h
      -- Apply the property of scalar multiplication preserving interval integrability
      exact h₂.smul r
    exact h₁
  · intro h
    -- Assume r • f is interval integrable, prove f is interval integrable
    -- Use the fact that if r ≠ 0, then scalar multiplication by r⁻¹ preserves integrability
    have h₁ : IntervalIntegrable f μ a b := by
      by_cases hr : r = 0
      · -- Case r = 0: r • f = 0, which is trivially interval integrable
        subst hr
        simp_all [zero_smul]
        <;>
        (try simp_all [IntervalIntegrable]) <;>
        (try exact intervalIntegrable_zero) <;>
        (try assumption) <;>
        (try norm_num) <;>
        (try simp_all [MeasureTheory.Measure]) <;>
        (try simp_all [a, b, μ])
      · -- Case r ≠ 0: Use the fact that scalar multiplication by r⁻¹ preserves interval integrability
        have h₂ : IntervalIntegrable (r • f) μ a b := h
        have h₃ : IntervalIntegrable f μ a b := by
          -- Use the fact that scalar multiplication by r⁻¹ preserves interval integrability
          have h₄ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := h₂.smul r⁻¹
          -- Simplify r⁻¹ • (r • f) to f
          have h₅ : r⁻¹ • (r • f) = f := by
            ext x
            simp [smul_smul, hr]
            <;> field_simp [hr]
            <;> ring
          -- Substitute back to get interval integrability of f
          rw [h₅] at h₄
          exact h₄
        exact h₃
    exact h₁
