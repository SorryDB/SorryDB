lemma tendsto_sin_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
  have h : HasDerivAt (fun x : ℝ => Real.sin (r * x)) r 0 := by
    have h₁ : HasDerivAt (fun x : ℝ => Real.sin (r * x)) (Real.cos (r * 0) * r) 0 := by
      have h₂ : HasDerivAt (fun x : ℝ => r * x) r 0 := by
        simpa using (hasDerivAt_id (0 : ℝ)).const_mul r
      have h₃ : HasDerivAt (fun x : ℝ => Real.sin (r * x)) (Real.cos (r * 0) * r) 0 := by
        apply HasDerivAt.sin (h₂)
      exact h₃
    convert h₁ using 1 <;> simp [Real.cos_zero] <;> ring
    <;> norm_num
    <;> linarith
  
  have h₁ : Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
    have h₂ : (fun x : ℝ => Real.sin (r * x) / x) = fun x => (Real.sin (r * x) - Real.sin (r * 0)) / (x - 0) := by
      funext x
      by_cases hx : x = 0
      · simp_all
      · field_simp [hx, sub_eq_zero]
        <;> ring_nf
        <;> simp_all
        <;> field_simp [hx]
        <;> ring_nf
    rw [h₂]
    have h₃ : Tendsto (fun x : ℝ => (Real.sin (r * x) - Real.sin (r * 0)) / (x - 0)) (𝓝[≠] 0) (𝓝 r) := by
      have h₄ : HasDerivAt (fun x : ℝ => Real.sin (r * x)) r 0 := h
      convert h₄.tendsto_slope_zero using 1 <;>
        (try simp) <;>
        (try norm_num) <;>
        (try ring_nf) <;>
        (try simp_all) <;>
        (try field_simp) <;>
        (try norm_num)
      <;>
      (try
        {
          simp_all [sub_eq_add_neg]
          <;> ring_nf
          <;> field_simp
          <;> norm_num
        })
    exact h₃
  exact h₁
