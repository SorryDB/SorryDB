 can use the known limit of sin(x)/x as x approaches 0\n            have h₇ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := by\n              have h₈ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝 (r * (0 : ℝ))) := by\n                apply Tendsto.const_mul\n                exact tendsto_id\n              have h₉ : r * (0 : ℝ) = 0 := by ring\n              have h₁₀ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝 0) := by\n                simpa [h₉] using h₈\n              have h₁₁ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := by\n                have h₁₂ : (0 : ℝ) ∉ Set.range (fun x : ℝ => r * x) := by\n                  intro h₁₃\n                  rcases h₁₃ with ⟨x, h₁₃⟩\n                  have h₁₄ : r * x = 0 := by simpa using h₁₃\n                  have h₁₅ : r ≠ 0 := by simpa using h₆\n                  have h₁₆ : x = 0 := by\n                    apply mul_left_cancel₀ h₁₅\n                    linarith\n                  simp_all [h₁₆]\n                  <;>\n                  simp_all [h₆]\n                have h₁₃ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := by\n                  apply tendsto_nhdsWithin_of_tendsto_nhds_of_eventually_within h₁₀\n                  filter_upwards [self_mem_nhdsWithin] with x hx\n                  have h₁₄ : x ≠ 0 := by simpa using hx\n                  have h₁₅ : r * x ≠ 0 := by\n                    intro h₁₅\n                    have h₁₆ : r * x = 0 := by simpa using h₁₅\n                    have h₁₇ : r ≠ 0 := by simpa using h₆\n                    have h₁₈ : x = 0 := by\n                      apply mul_left_cancel₀ h₁₇\n                      linarith\n                    simp_all [h₁₈]\n                    <;>\n                    simp_all [h₆]\n                  simp_all\n                exact h₁₃\n              exact h₁₁\n            have h₁₂ : Tendsto (fun x : ℝ => Real.sin (r * x) / (r * x)) (𝓝[≠] 0) (𝓝 1) := by\n              have h₁₃ : Tendsto (fun x : ℝ => Real.sin x / x) (𝓝[≠] 0) (𝓝 1) := h₄\n              have h₁₄ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := h₇\n              have h₁₅ : Tendsto (fun x : ℝ => Real.sin (r * x) / (r * x)) (𝓝[≠] 0) (𝓝 1) := by\n                have h₁₆ : (fun x : ℝ => Real.sin (r * x) / (r * x)) = (fun x : ℝ => Real.sin x / x) ∘ (fun x : ℝ => r * x) := by\n                  funext x\n                  ring_nf\n                rw [h₁₆]\n                have h₁₇ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := h₇\n                have h₁₈ : Tendsto (fun x : ℝ => Real.sin x / x) (𝓝[≠] 0) (𝓝 1) := h₄\n                have h₁₉ : Tendsto (fun x : ℝ => Real.sin x / x) (𝓝[≠] 0) (𝓝 1) := h₄\n                have h₂₀ : Tendsto ((fun x : ℝ => Real.sin x / x) ∘ (fun x : ℝ => r * x)) (𝓝[≠] 0) (𝓝 1) := by\n                  apply h₁₈.comp h₁₇\n                exact h₂₀\n              exact h₁₅\n            exact h₁₂\n        exact h₅\n      have h₆ : Tendsto (fun x : ℝ => r * (Real.sin (r * x) / (r * x))) (𝓝[≠] 0) (𝓝 (r * 1)) := by\n        have h₇ : Tendsto (fun x : ℝ => Real.sin (r * x) / (r * x)) (𝓝[≠] 0) (𝓝 1) := h₃\n        have h₈ : Tendsto (fun x : ℝ => r * (Real.sin (r * x) / (r * x))) (𝓝[≠] 0) (𝓝 (r * 1)) := by\n          convert Tendsto.const_mul r h₇ using 1 <;> simp [mul_one]\n        exact h₈\n      exact h₆\n    have h₃ : Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by\n      have h₄ : (fun x : ℝ => Real.sin (r * x) / x) =ᶠ[𝓝[≠] 0] (fun x : ℝ => r * (Real.sin (r * x) / (r * x))) := h₁\n      have h₅ : Tendsto (fun x : ℝ => r * (Real.sin (r * x) / (r * x))) (𝓝[≠] 0) (𝓝 (r * 1)) := h₂\n      have h₆ : Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by\n        apply Filter.Tendsto.congr' _ h₅\n        filter_upwards [h₄] with x hx\n        rw [hx]\n        <;> simp [mul_one]\n      exact h₆\n    exact h₃\n  exact h₀",
