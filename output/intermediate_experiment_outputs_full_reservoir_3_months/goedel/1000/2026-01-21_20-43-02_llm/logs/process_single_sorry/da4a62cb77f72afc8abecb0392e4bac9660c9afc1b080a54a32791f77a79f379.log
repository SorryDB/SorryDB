      "\n  have h_main : Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by\n    by_cases hr : r = 0\n    · -- Case: r = 0\n      have h₁ : (fun x : ℝ => Real.sin (r * x) / x) = (fun x : ℝ => (0 : ℝ) / x) := by\n        funext x\n        rw [hr]\n        simp [Real.sin_zero]\n      rw [h₁]\n      have h₂ : Tendsto (fun x : ℝ => (0 : ℝ) / x) (𝓝[≠] 0) (𝓝 (0 : ℝ)) := by\n        -- Prove that the limit of 0/x as x → 0 is 0\n        have h₃ : (fun x : ℝ => (0 : ℝ) / x) = fun x : ℝ => 0 := by\n          funext x\n          by_cases hx : x = 0\n          · simp [hx]\n          · field_simp [hx]\n            <;> simp\n        rw [h₃]\n        -- The limit of the constant function 0 is 0\n        exact tendsto_const_nhds\n      -- Since r = 0, the limit is 0\n      simpa [hr] using h₂\n    · -- Case: r ≠ 0\n      have h₁ : Tendsto (fun x : ℝ => Real.sin (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by\n        have h₂ : (fun x : ℝ => Real.sin (r * x) / x) = (fun x : ℝ => r * (Real.sin (r * x) / (r * x))) := by\n          funext x\n          by_cases hx : x = 0\n          · simp [hx]\n          · have h₃ : r * x ≠ 0 := by\n              intro h₄\n              apply hx\n              apply mul_left_cancel₀ (show (r : ℝ) ≠ 0 by exact hr)\n              linarith\n            field_simp [hx, h₃]\n            <;> ring\n            <;> field_simp [hx, h₃]\n            <;> ring\n        rw [h₂]\n        -- Use the fact that sin(y)/y → 1 as y → 0\n        have h₃ : Tendsto (fun x : ℝ => Real.sin (r * x) / (r * x)) (𝓝[≠] 0) (𝓝 1) := by\n          have h₄ : Tendsto (fun x : ℝ => Real.sin x / x) (𝓝[≠] 0) (𝓝 1) := by\n            -- Known limit\n            have h₅ : Tendsto (fun x : ℝ => Real.sin x / x) (𝓝[≠] 0) (𝓝 1) :=\n              tendsto_sin_div_id\n            exact h₅\n          -- Compose with the function x ↦ r * x\n          have h₅ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := by\n            have h₆ : Continuous fun x : ℝ => r * x := by continuity\n            have h