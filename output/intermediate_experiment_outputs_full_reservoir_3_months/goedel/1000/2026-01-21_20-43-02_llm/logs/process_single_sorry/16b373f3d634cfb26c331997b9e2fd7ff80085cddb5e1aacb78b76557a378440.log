                (try norm_num)
                <;>
                (try positivity)
              · have h₁₂ : 1 ≤ ‖X i ω‖ := by
                  by_contra h₁₂
                  have h₁₃ : ‖X i ω‖ < 1 := by linarith
                  have h₁₄ : ‖X i ω‖ ^ 2 < 1 := by
                    have h₁₅ : 0 ≤ ‖X i ω‖ := by positivity
                    have h₁₆ : ‖X i ω‖ < 1 := by linarith
                    have h₁₇ : ‖X i ω‖ ^ 2 < 1 := by
                      nlinarith
                    exact h₁₇
                  have h₁₈ : ‖X i ω‖ ^ (2 * m) < 1 := by
                    have h₁₉ : 0 ≤ ‖X i ω‖ := by positivity
                    have h₂₀ : ‖X i ω‖ < 1 := by linarith
                    have h₂₁ : ‖X i ω‖ ^ (2 * m) < 1 := by
