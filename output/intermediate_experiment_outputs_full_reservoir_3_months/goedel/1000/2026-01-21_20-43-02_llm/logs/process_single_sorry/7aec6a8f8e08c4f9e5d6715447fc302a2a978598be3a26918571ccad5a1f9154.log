theorem biased_constrained_seq_exists {α : Type*} [DecidableEq α]
   (s : Finset α) (t : Finset α) : s ∈ Finset.powerset (s ∪ t) := by
  apply Finset.mem_powerset.mpr
  intro x hx
  simp only [Finset.mem_union, Finset.mem_singleton_add, Finset.mem_singleton_sub] at hx ⊢
  aesop
