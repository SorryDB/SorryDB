lemma IsBernoulliOn.sdiff (hX : IsBernoulliOn X u p P) :
    IsBernoulliOn (fun ω ↦ u \ X ω) u (σ p) P where
  map_eq := sorry
  aemeasurable := by
    have h1 : AEMeasurable X P := hX.3.1
    have h2 : AEMeasurable (fun ω : Ω => u \ X ω) P := by
      refine' AEMeasurable.of_ae_restrict _
      filter_upwards [h1.ae] with ω hω
      -- Show that the function is measurable when restricted to the subset where X is measurable
      have h3 : Measurable (fun ω : Ω => u \ X ω) := by
        -- Prove that the set difference operation preserves measurability
        measurable_of_mem (MeasureTheory.coe_fintype.7 : (⨆ (i : ι), ({i} : Set ι)) ∈
          𝓤 ι)
        <;>
        simp_all [Set.mem_iUnion, Set.mem_singleton_iff]
        <;>
        aesop
