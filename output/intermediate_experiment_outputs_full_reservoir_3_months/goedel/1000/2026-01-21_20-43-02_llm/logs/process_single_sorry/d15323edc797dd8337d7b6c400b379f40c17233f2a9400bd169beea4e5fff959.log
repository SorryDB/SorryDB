lemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :
    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P where
  aemeasurable_fst := by
    have h₁ : AEMeasurable (fun ω : Ω => i ∈ X ω) P := by
      -- Prove that the function (fun ω : Ω => i ∈ X ω) is measurable
      have h₂ : AEMeasurable X P := by
        -- Since X follows the Bernoulli distribution, it is measurable
        have h₃ : HasLaw X (Ber(u, p)) P := hX
        have h₄ : Measurable X := by
          have h₅ : (Ber(u, p) : Measure (Set ι)).toMeasure.isMeasurable := by
            apply IsProbabilityMeasure.isMeasurable
            infer_instance
          -- The law of X is the Bernoulli measure, which is measurable
          exact hasLaw_measurable h₃
        exact h₄.aemeasurable
      -- The membership function is measurable because X is measurable
      exact h₂.comp_aemeasurable (aemeasurable_const_mem (s := ({i} : Set ι)))
    exact h₁
