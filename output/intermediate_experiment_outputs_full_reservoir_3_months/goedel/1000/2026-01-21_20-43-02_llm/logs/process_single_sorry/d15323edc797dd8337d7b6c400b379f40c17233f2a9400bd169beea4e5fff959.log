```lean
lemma IsBernoulliOn.sdiff (hX : IsBernoulliOn X u p P) :
    IsBernoulliOn (fun ω ↦ u \ X ω) u (σ p) P where
  map_eq := by
    have h₁ : HasLaw (fun ω => (u \ X ω : Set ι)) (Ber(u, σ p)) P :=
      by
        -- Prove that (u \ X ω) has the Bernoulli distribution Ber(u, σ p)
        have h₂ : HasLaw X (Ber(u, p)) P := hX
        -- Use the fact that X has the Bernoulli distribution to derive the distribution of u \ X ω
        have h₃ : HasLaw (fun ω => (u \ X ω : Set ι)) (Ber(u, σ p)) P := by
          -- Use the transformation of the Bernoulli distribution under set difference
          convert h₂.map (fun s : Set ι => u \ s) using 1
          <;>
          simp [bernoulliOn_eq_map, MeasurableEquiv.congr_fun]
          <;>
          simp_all [Set.compl_eq_univ_diff]
          <;>
          aesop
        exact h₃
      exact h₁
  aemeasurable := by
    -- Prove that the function (fun ω ↦ u \ X ω) is aemeasurable with respect to P
    have h₁ : AEMeasurable (fun ω => (u \ X ω : Set ι)) P := by
      have h₂ : AEMeasurable X P := hX.aemeasurable
      -- Use the fact that X is aemeasurable to show that u \ X ω is also aemeasurable
      have h₃ : AEMeasurable (fun ω => (u \ X ω : Set ι)) P := by
        -- The set difference operation preserves aemeasurability
        apply AEMeasurable.congr (measurable_fun (u \ X ·)) (h₂.measurableFun) _
        <;>
        simp [Set.ext_iff]
        <;>
        tauto
      exact h₃
    exact h₁
``` 

