theorem AEMeasurable_sdiff {ι : Type} {Ω : Type} [MeasurableSpace ι] [MeasurableSpace Ω]
    {X : Ω → Set ι} {P : Measure Ω} (hX : AEMeasurable X P) :
    AEMeasurable (fun ω => u \ X ω) P := by
  have h1 : AEMeasurable (fun ω => u \ X ω) P := by
    -- Use the fact that the set difference of a measurable set with another measurable set is measurable.
    -- Specifically, `u \ X ω` can be written as `(fun ω => u) ω \ X ω`.
    -- `(fun ω => u)` is a constant function, hence measurable.
    -- `X ω` is given as almost everywhere measurable.
    -- The set difference of two measurable sets is measurable.
    have h₂ : AEMeasurable (fun ω => (u : Set ι)) P := by
      -- The constant function `fun ω => u` is measurable because it is constant.
      exact measurable_const.ae _
    -- The set difference of two measurable functions is measurable.
    have h₃ : AEMeasurable (fun ω => (u : Set ι) \ X ω) P := by
      apply AEMeasurable.sdiff h₂ hX
    -- Simplify the expression `(u : Set ι) \ X ω` to `u \ X ω`.
    simpa using h₃
  exact h1
