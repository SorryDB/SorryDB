def kerLift (f : R →+* S) : R ⧸ ker f →+* S :=
  Ideal.Quotient.lift (ker f) f fun x hx => by
    have h : x ∈ (ker f : Ideal R) := hx
    have h' : f x = 0 := by
      rw [Ideal.ker_mem_iff] at h
      exact h
    rw [h']
    simp [zero_mul]

