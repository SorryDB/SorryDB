example (f : R →+* S) (x y : R) :
    f (1 + x * y) + f 0 = 1 + f x * f y := by
  simp [add_assoc, add_mul, mul_add, mul_assoc, mul_comm, mul_left_comm]
  <;> ring_nf
  <;> simp_all [RingHom.map_one, RingHom.map_mul]
  <;> ring_nf
  <;> simp_all [RingHom.map_add, RingHom.map_mul]
  <;> linarith

def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    simp [RingHom.map_one]
    <;> simp_all [one_mul]
    <;> simp_all [mul_one]
  map_mul' := by
    intro x y
    simp [RingHom.map_mul]
    <;> simp_all [mul_assoc]
  map_zero' := by
    simp [RingHom.map_zero]
    <;> simp_all [zero_mul]
    <;> simp_all [mul_zero]
  map_add' := by
    intro x y
    simp [RingHom.map_add]
    <;> simp_all [add_mul]

def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [Function.comp_apply, g.symm_apply_apply, f.symm_apply_apply]
    <;> simp_all [RingHom.map_add, RingHom.map_mul]
    <;> monoid_hom_ext
    <;> simp_all [RingHom.map_add, RingHom.map_mul]
    <;> simp_all [add_assoc]
  right_inv := by
    intro x
    simp [Function.comp_apply, g.symm_apply_apply, f.symm_apply_apply]
    <;> simp_all [RingHom.map_add, RingHom.map_mul]
    <;> monoid_hom_ext
    <;> simp_all [RingHom.map_add, RingHom.map_mul]
    <;> simp_all [add_assoc]
  map_add' := by
    intro x y
    simp [RingEquiv.map_add]
    <;> simp_all [RingHom.map_add]
    <;> simp_all [add_assoc]
  map_mul' := by
    intro x y
    simp [RingEquiv.map_mul]
    <;> simp_all [RingHom.map_mul]
    <;> simp_all [mul_assoc]

def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro x hx y hy
    exact ⟨I.add_mem hx.1 hy.1, J.add_mem hx.2 hy.2⟩
  zero_mem' := by
    exact ⟨I.zero_mem, J.zero_mem⟩
  smul_mem' := by
    intro r x hx
    exact ⟨I.smul_mem r hx.1, J.smul_mem r hx.2⟩

