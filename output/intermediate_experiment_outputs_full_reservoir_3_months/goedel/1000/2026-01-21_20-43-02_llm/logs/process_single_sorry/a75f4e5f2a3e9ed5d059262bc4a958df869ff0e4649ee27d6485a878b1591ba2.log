    <;>
    simp_all [Equiv.symm_apply_apply]
    <;>
    ring_nf
  map_add' := by
    intro x y
    simp [RingHom.map_add]
    <;>
    simp_all [RingHom.map_add]
    <;>
    ring_nf
  map_mul' := by
    intro x y
    simp [RingHom.map_mul]
    <;>
    simp_all [RingHom.map_mul]
    <;>
    ring_nf

end homomorphisms

