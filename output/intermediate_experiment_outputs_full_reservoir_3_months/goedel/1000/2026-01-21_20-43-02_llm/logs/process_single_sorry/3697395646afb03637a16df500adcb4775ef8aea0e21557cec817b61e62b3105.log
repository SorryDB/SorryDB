example (x y : ‚Ñù) (h : 2 * x + 3 * y = 5) (h' : 4 * x - y = 1) : 10 * x + y = 7 := by linarith
example (a b : ‚Ñù) : a * b ‚â§ ((a + b) / 2) ^ 2 := by nlinarith [sq_nonneg (a - b)]
example (x y : ‚Ñù) (h : 2 * x + 3 * y = 5) (h' : 4 * x - y = 1) : 10 * x + y = 7 := by grobner
