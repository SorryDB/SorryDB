      "by\n  intro h\n  intro k α _\n  intro ea L\n  have h₁ : ∀ (α : Type) [inst : Primcodable α] (ea : FinEncoding α) (L : Language α), SigmakP 0 ea L ↔ InP ea L := by\n    intro α _ ea L\n    constructor <;> intro h₂\n    · -- SigmakP 0 ea L → InP ea L\n      simp [SigmakP] at h₂ ⊢\n      <;> tauto\n    · -- InP ea L → SigmakP 0 ea L\n      simp [SigmakP]\n      <;> tauto\n  have h₂ : ∀ (k : ℕ) (α : Type) [inst : Primcodable α] (ea : FinEncoding α) (L : Language α), SigmakP k ea L ↔ InP ea L := by\n    intro k\n    induction k with\n    | zero =>\n      intro α _ ea L\n      exact h₁ α _ ea L\n    | succ k ih =>\n      intro α _ ea L\n      have h₃ := ih\n      have h₄ : PEqualsNP := h\n      simp_all [SigmakP, Pi0P, Sigma0P, InP, InNP, Complement, Pi1P, Delta1P, Delta2P]\n      <;>\n      (try { contradiction }) <;>\n      (try { aesop }) <;>\n      (try {\n        cases k <;> simp_all [SigmakP, Pi0P, Sigma0P, InP, InNP, Complement, Pi1P, Delta1P, Delta2P]\n        <;> tauto\n      })\n      <;>\n      (try {\n        simp_all [SigmakP, Pi0P, Sigma0P, InP, InNP, Complement, Pi1P, Delta1P, Delta2P]\n        <;> tauto\n      })\n      <;>\n      (try {\n        simp_all [SigmakP, Pi0P, Sigma0P, InP, InNP, Complement, Pi1P, Delta1P, Delta2P]\n        <;> tauto\n      })\n      <;>\n      (try {\n        simp_all [SigmakP, Pi0P, Sigma0P, InP, InNP, Complement, Pi1P, Delta1P, Delta2P]\n        <;> tauto\n      })\n      <;>\n      (try {\n        exfalso\n        cases h₄\n        <;> simp_all (config := {decide := true})\n      })\n      <;>\n      (try {\n        aesop\n      })\n  exact h₂ k α _ ea L",
