      "by\n  intro hP\n  intro k\n  intro α _ ea L\n  have h₁ : SigmakP 0 ea L ↔ InP ea L := by\n    simp [SigmakP, Sigma0P]\n    <;> aesop\n  have h₂ : SigmakP 1 ea L ↔ InP ea L := by\n    have h₃ : SigmakP 1 ea L ↔ InNP ea L := by\n      simp [SigmakP, Sigma1P]\n      <;> aesop\n    have h₄ : InNP ea L ↔ InP ea L := by\n      have h₅ : PEqualsNP := hP\n      have h₆ : ∀ (L : Language α), InNP ea L ↔ InP ea L := by\n        intro L\n        have h₇ : InNP ea L ↔ InP ea L := by\n          simp only [InNP, InP] at *\n          simp_all [PEqualsNP]\n          <;> aesop\n        exact h₇\n      exact h₆ L\n    rw [h₃, h₄]\n    <;> aesop\n  have h₃ : ∀ (k : ℕ), SigmakP k ea L ↔ InP ea L := by\n    intro k\n    induction k with\n    | zero =>\n      simpa using h₁\n    | succ k ih =>\n      have h₄ : SigmakP (k + 1) ea L ↔ InP ea L := by\n        simp_all [SigmakP]\n        <;>\n        (try cases k <;> simp_all [SigmakP, Sigma0P, Sigma1P]) <;>\n        (try\n          {\n            aesop\n          }) <;>\n        (try\n          {\n            simp_all [InP, InNP]\n            <;>\n            (try\n              {\n                simp_all [PEqualsNP]\n                <;>\n                aesop\n              })\n          })\n      simpa using h₄\n  have h₄ : SigmakP k ea L ↔ InP ea L := h₃ k\n  exact h₄",
