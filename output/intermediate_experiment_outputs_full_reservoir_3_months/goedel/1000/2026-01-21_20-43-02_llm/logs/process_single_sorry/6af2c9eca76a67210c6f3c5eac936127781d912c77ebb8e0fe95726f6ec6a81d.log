theorem ph_collapse_if_p_eq_np :
  PEqualsNP → ∀ k, ∀ (α : Type) [Primcodable α] (ea : FinEncoding α) (L : Language α),
    SigmakP k ea L ↔ InP ea L := by
  intro h₁ k α _ ea L
  have h₂ : ∀ k, ∀ (α : Type) [Primcodable α] (ea : FinEncoding α) (L : Language α), SigmakP k ea L ↔ InP ea L := by
    intro k
    induction k with
    | zero =>
      intro α _ ea L
      simp [SigmakP]
      <;>
      aesop
    | succ k ih =>
      intro α _ ea L
      simp_all [SigmakP]
      <;>
      (try { contradiction }) <;>
      (try { aesop }) <;>
      (try {
        simp_all [InP, InNP]
        <;>
        tauto
      }) <;>
      (try {
        cases k <;> simp_all [SigmakP, InP, InNP]
        <;>
        aesop
      }) <;>
      (try {
        exfalso
        have h₃ := h₁
        simp_all [PEqualsNP]
        <;>
        aesop
      })
  exact h₂ k α _ ea L
