theorem least_residue_unique (p : ℕ) (HP : p.Prime) (a : ℕ) :
    ∃! r : ℕ, r < p ∧ a ≡ r [MOD p] := by
  have h₁ : ∃ r : ℕ, r < p ∧ a ≡ r [MOD p] := by
    use a % p
    constructor
    · apply Nat.mod_lt
      exact Nat.Prime.pos HP
    · rw [Nat.ModEq]
      simp [Nat.mod_mod]
  -- Use the previously established existence to get the unique r
  obtain ⟨r, hr₁, hr₂⟩ := h₁
  refine' ⟨r, ⟨hr₁, hr₂⟩, _⟩
  rintro y ⟨hy₁, hy₂⟩
  have h₂ : y ≡ a [MOD p] := by
    calc
      y ≡ a [MOD p] := by
        -- Since y ≡ a [MOD p] is symmetric, we can directly use the given congruence
        exact hy₂.symm
      _ ≡ a [MOD p] := by rfl
  have h₃ : y ≡ r [MOD p] := by
