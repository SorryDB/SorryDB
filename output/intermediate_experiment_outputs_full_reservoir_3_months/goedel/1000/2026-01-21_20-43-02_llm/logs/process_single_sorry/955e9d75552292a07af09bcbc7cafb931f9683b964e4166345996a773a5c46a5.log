example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  -- Use the filter_upwards tactic to combine the neighborhoods into the required set.
  filter_upwards [hT, hS, hT', hS'] with x hx hx' hx'' hx''' xhx'''' hx'' xhx'''''
  -- Simplify the goal by using the assumptions and logical deductions.
  <;> simp_all [or_imp, and_imp]
  <;> tauto

end Filter

