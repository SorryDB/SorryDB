section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  -- Since F ≤ G, we can use the fact that F.map f ≤ G.map f follows directly from the monotonicity of the map function.
  exact h hs

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- To prove that Tendsto (t ∘ s) F H, we need to show that the composition's filter is less than or equal to H.
  -- This follows by writing the composition as t ∘ s and using the order of the filters.
  have h1 : F.map (t ∘ s) ≤ H := by
    -- Use the fact that F.map s ≤ G and G.map t ≤ H to compose them.
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        -- Show that the expression for the composition is the same as applying t to the result of s.
        simp [Filter.map_map, Function.comp]
        <;> ext <;> simp [Set.mem_image]
        <;> aesop
      _ ≤ G.map t := by
        -- Use the monotonicity of the map function.
        exact Filter.map_mono hs
      _ ≤ H := ht
  -- Therefore, Tendsto (t ∘ s) F H holds.
  exact h1

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  -- Use the composition property of Tendsto to conclude that the composition tends to atTop along 𝓝 0.
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Apply the lemma Tendsto_comp to the functions f and g with the given filters.
    have h1 : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
    -- The result follows directly from the previous step.
    exact h1
  -- The conclusion is already obtained in h.
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
