```lean
noncomputable section

namespace ItaLean

section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact h.map f

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h₁ : (F.map s).map t ≤ H := by
    -- Use the fact that the composition of the maps is less than or equal to H
    have h₂ : (F.map s).map t ≤ G.map t := by
      -- Since F.map s ≤ G, we can use the monotonicity of the map operation
      exact hs.map t
    -- Since G.map t ≤ H, we can combine the inequalities
    have h₃ : G.map t ≤ H := ht
    exact le_trans h₂ h₃
  -- Simplify the expression to show that F.map (t ∘ s) ≤ H
  have h₄ : F.map (t ∘ s) = (F.map s).map t := by
    -- Use the property of the map operation for composition of functions
    simp [Function.comp, map_map]
  -- Combine the results to get the final inequality
  rw [h₄]
  exact h₁

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Use the composition of tendsto to combine the two given tendsto statements
    have h₁ : Tendsto (g ∘ f) (𝓝 0) atTop := by
      -- Apply the composition rule for tendsto
      exact Tendsto_comp hf hg
    exact h₁
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
