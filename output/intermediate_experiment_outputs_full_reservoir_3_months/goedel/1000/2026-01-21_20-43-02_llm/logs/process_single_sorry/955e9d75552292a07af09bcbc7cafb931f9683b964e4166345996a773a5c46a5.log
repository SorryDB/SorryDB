variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  refine' fun s hs => _
  -- Since F ≤ G, we can obtain G.map f by mapping G through f.
  have h₁ : F ≤ G := h
  -- Use the property that if F ≤ G, then F.map f ≤ G.map f.
  have h₂ : F.map f ≤ G.map f := by
    exact Filter.map_mono h₁
  -- Use the fact that s ∈ F.map f implies s ∈ G.map f.
  exact h₂ hs

