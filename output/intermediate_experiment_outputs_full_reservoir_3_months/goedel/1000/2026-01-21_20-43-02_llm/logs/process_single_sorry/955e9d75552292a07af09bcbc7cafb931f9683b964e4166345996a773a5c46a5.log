    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    -- Use the fact that the intersection of two open sets is open
    have h2 : {x | p x} ∩ {x | q x} ∈ 𝓝 x := by
