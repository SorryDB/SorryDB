lemma construction_omega_L_subset :
  let I := FTheory.lindenbaum.construction_omega T hT
  I := by
    intro γ hγ
    -- Show that γ is in the construction_omega by using its encoding
    have h₃ : γ ∈ I := by
      have h₄ : γ ∈ construction_omega T hT := by
        simp only [construction_omega, Set.mem_iUnion]
        -- Use the fact that γ is in the logic L and is therefore in the union of all construction steps
        have h₅ : ∃ n : ℕ, γ ∈ construction T hT n := by
          use encode γ + 1
          simp [construction]
          <;>
          (try aesop)
          <;>
          (try simp_all [setLike_subset_iff])
          <;>
          (try tauto)
          <;>
          (try simp_all [setLike_subset_iff])
          <;>
          (try tauto)
        obtain ⟨n, hn⟩ := h₅
        exact ⟨n, hn⟩
      exact h₄
    exact h₃
