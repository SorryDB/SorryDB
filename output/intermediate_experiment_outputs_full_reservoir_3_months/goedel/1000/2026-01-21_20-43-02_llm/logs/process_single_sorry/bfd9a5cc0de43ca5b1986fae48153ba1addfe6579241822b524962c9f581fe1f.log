       ∃ e x_sign,
       opt_e = some e ∧
       field.FieldElement51.is_negative e.X = ok x_sign ∧
       let y := Field51_as_Nat e.Y

       y * (u + 1) % p = (u - 1) % p ∧
       (x_sign.val = 1#u8 ↔ sign.val.testBit 0))) := by
  have h₁ : ∃ (opt_e : Option EdwardsPoint), to_edwards mp sign = ok opt_e := by
    have h₂ : to_edwards mp sign = ok (to_edwards mp sign).getD 0 := by
      apply Result.either.elim
      · intro h
        simp_all [Result.isErr, Result.isOk]
      · intro h
        simp_all [Result.isErr, Result.isOk]
    exact ⟨(to_edwards mp sign).getD 0, by
      apply Result.either.elim
      · intro h
        simp_all [Result.isErr, Result.isOk]
      · intro h
