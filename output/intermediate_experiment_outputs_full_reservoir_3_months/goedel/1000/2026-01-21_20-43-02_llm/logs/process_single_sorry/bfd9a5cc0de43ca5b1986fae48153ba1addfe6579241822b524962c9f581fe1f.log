  obtain ⟨opt_e, hopt⟩ := h₁
  refine' ⟨opt_e, hopt, _⟩
  dsimp
  constructor
  · intro h
    -- Case: (u + 1) % p = 0
    have h₂ : opt_e = none := by
      have h₃ : to_edwards mp sign = ok opt_e := hopt
      -- Simplify the condition (u + 1) % p = 0
      simp [h₃] at *
      <;>
      (try decide) <;>
      (try contradiction) <;>
      (try
        {
          cases mp <;> simp_all [U8x32_as_Nat, p]
          <;>
          norm_num at *
          <;>
