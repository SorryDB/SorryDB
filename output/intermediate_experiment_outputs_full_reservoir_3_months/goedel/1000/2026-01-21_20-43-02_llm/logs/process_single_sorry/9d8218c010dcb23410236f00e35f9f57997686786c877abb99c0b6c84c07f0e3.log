    have h₇ := h₂ 1 2 (by norm_num) (by norm_num)
    have h₈ : (1 : ℕ) + 2 ≤ (n : ℕ) + 1 := by
      have h₉ : (n : ℕ) ≥ 3 := by exact_mod_cast n.property
      linarith
    have h₉ := h₇ h₈
    rcases h₉ with ⟨l, h₁₀, h₁₁⟩
    simp [Fin.ext_iff] at h₁₁
    <;> norm_num at h₁₁ <;>
    (try contradiction) <;>
    (try simp_all [Fin.ext_iff]) <;>
    (try linarith)
    <;>
    (try {
