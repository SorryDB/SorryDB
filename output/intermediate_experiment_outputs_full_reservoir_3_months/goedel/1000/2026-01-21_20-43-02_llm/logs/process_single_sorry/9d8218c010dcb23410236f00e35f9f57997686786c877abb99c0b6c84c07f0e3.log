        have h₅₂ := h₂ 1 1 (by norm_num) (by norm_num)
        have h₅₃ : (1 : ℕ) + 1 ≤ (n : ℕ) + 1 := by
          have h₅₄ : (n : ℕ) ≥ 3 := by exact_mod_cast n.property
          linarith
        have h₅₄ := h₅₂ h₅₃
        rcases h₅₄ with ⟨l, h₅₅, h₅₆⟩
        simp [Fin.ext_iff] at h₅₆
