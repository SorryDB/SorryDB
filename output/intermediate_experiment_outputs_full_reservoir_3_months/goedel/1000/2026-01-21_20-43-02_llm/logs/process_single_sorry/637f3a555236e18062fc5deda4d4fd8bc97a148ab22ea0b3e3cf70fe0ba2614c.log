```lean
theorem GG_iff_kurodaGrammar_exists (L : Language T) :
  L.IsGG ↔ ∃ k : KurodaGrammar T, k.language = L :=
by
  constructor
  · intro h
    have h₁ : ∃ (G : Grammar T), L = G.language := by
      exact h
    obtain ⟨G, hG⟩ := h₁
    have h₂ : ∃ (k : KurodaGrammar T), k.language = L := by
      use {
        nt := Unit
        initial := ()
        rules := []
      }
      simp_all [KurodaGrammar.language]
      <;>
      (try simp_all [Set.ext_iff]) <;>
      (try simp_all [List.mem_map, List.mem_cons, List.mem_singleton]) <;>
      (try aesop) <;>
      (try
        {
          rcases G with ⟨nt, initial, rules⟩
          simp_all [Grammar]
          <;>
          (try aesop)
        }) <;>
      (try
        {
          simp_all [Symbol.terminal, Symbol.nonterminal]
          <;>
          (try aesop)
        }) <;>
      (try
        {
          simp_all [List.map]
          <;>
          (try aesop)
        })
      <;>
      (try
        {
          simp_all [Set.ext_iff]
          <;>
          (try aesop)
        })
      <;>
      (try
        {
          aesop
        })
    exact h₂
  · intro h
    rcases h with ⟨k, hk⟩
    have h₁ : ∃ (G : Grammar T), L = G.language := by
      use grammar_of_kurodaGrammar k
      have h₂ : (grammar_of_kurodaGrammar k).language = k.language := by
        simp [KurodaGrammar.language, KurodaGrammar.Derives, KurodaGrammar.transforms]
        <;>
        (try simp_all [grule_of_kurodaRule]) <;>
        (try simp_all [List.map]) <;>
        (try simp_all [Set.ext_iff]) <;>
        (try simp_all [Symbol.terminal, Symbol.nonterminal]) <;>
        (try aesop)
      rw [h₂]
      rw [hk]
    exact h₁
```
