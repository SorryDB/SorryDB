instance (n : ℕ) : IsProbabilityMeasure (wignerMatrixMeasure n μ ν) := by
  -- The image of a probability measure under a measurable map is a probability measure.
  have h1 : IsProbabilityMeasure (WignerMeasure μ ν n) := by
    infer_instance
  -- The map wignerMatrixMap is measurable.
  have h2 : Measurable (wignerMatrixMap n) := by
    infer_instance
  -- Therefore, the pushforward of the probability measure under this map is a probability measure.
  have h3 : IsProbabilityMeasure (Measure.map (wignerMatrixMap n) (WignerMeasure μ ν n)) := by
    apply IsProbabilityMeasure.map measurableMap
    <;> infer_instance
  -- The wignerMatrixMeasure is defined as the pushforward of the WignerMeasure under wignerMatrixMap.
  simpa [wignerMatrixMeasure] using h3
