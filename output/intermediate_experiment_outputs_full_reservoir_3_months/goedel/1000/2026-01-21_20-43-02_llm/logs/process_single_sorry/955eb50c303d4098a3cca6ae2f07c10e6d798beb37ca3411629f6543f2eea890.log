      "\n  have h₁ : ρ.exp_val (pure ψ) = 1 ↔ ρ = pure ψ := by\n    constructor\n    · intro h\n      have h₂ : ρ.exp_val (pure ψ) = 1 := h\n      have h₃ : ρ.m = (pure ψ).m := by\n        have h₄ : ρ.exp_val (pure ψ) = ψ.conj ⊤ * ρ.m * ψ := by\n          simp [MState.exp_val_apply, MState.toMatrix]\n          <;>\n          simp_all [Matrix.mul_apply, Fin.sum_univ_succ, pow_one]\n          <;>\n          ring_nf\n          <;>\n          simp_all [Ket.conj_mul, Ket.mul_apply, Fin.sum_univ_succ, pow_one]\n          <;>\n          field_simp [Complex.ext_iff, Complex.normSq, Finset.sum_range_succ]\n          <;>\n          ring_nf\n          <;>\n          simp_all [Matrix.mul_apply, Fin.sum_univ_succ, pow_one]\n          <;>\n          linarith\n        have h₅ : ψ.conj ⊤ * ρ.m * ψ = 1 := by\n          simp_all [MState.exp_val_apply, MState.toMatrix]\n          <;>\n          simp_all [Matrix.mul_apply, Fin.sum_univ_succ, pow_one]\n          <;>\n          ring_nf\n          <;>\n          simp_all [Ket.conj_mul, Ket.mul_apply, Fin.sum_univ_succ, pow_one]\n          <;>\n          field_simp [Complex.ext_iff, Complex.normSq, Finset.sum_range_succ]\n          <;>\n          ring_nf\n          <;>\n          simp_all [Matrix.mul_apply, Fin.sum_univ_succ, pow_one]\n          <;>\n          linarith\n        have h₆ : ψ.conj ⊤ * (ρ.m - (pure ψ).m) * ψ = 0 := by\n          calc\n            ψ.conj ⊤ * (ρ.m - (pure ψ).m) * ψ = ψ.conj ⊤ * ρ.m * ψ - ψ.conj ⊤ * (pure ψ).m * ψ := by\n              simp [Matrix.mul_sub, Matrix.sub_mul]\n              <;>\n              ring_nf\n            _ = 1 - 1 := by\n              have h₇ : ψ.conj ⊤ * (pure ψ).m * ψ = 1 := by\n                simp [MState.exp_val_apply, MState.toMatrix]\n                <;>\n                simp_all [Matrix.mul_apply, Fin.sum_univ_succ, pow_one]\n                <;>\n                ring_nf\n                <;>\n                simp_all [Ket.conj_mul, Ket.mul_apply, Fin.sum_univ_succ, pow_one]\n         