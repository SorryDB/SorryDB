      "\n  have h_main : ρ.exp_val (pure ψ) = 1 ↔ ρ = pure ψ := by\n    constructor\n    · -- Prove the forward direction: if ρ.exp_val (pure ψ) = 1, then ρ = pure ψ\n      intro h\n      have h₁ : ρ.exp_val (MState.pure ψ) = 1 := h\n      have h₂ : ρ = MState.pure ψ := by\n        -- Use the fact that the expectation value is 1 to show ρ must be pure ψ\n        have h₃ : ρ.exp_val (MState.pure ψ) = 1 := h₁\n        have h₄ : ρ.exp_val (MState.pure ψ) = ρ.trace (MState.pure ψ).m := by\n          simp [MState.exp_val, MState.mul_self]\n          <;>\n          simp_all [Matrix.mul_assoc]\n          <;>\n          ring_nf\n          <;>\n          simp_all [Matrix.mul_apply, Finset.sum_mul]\n          <;>\n          aesop\n        have h₅ : ρ.trace (MState.pure ψ).m = 1 := by\n          rw [← h₄]\n          exact h₃\n        have h₆ : ρ = MState.pure ψ := by\n          -- Use the trace condition to show ρ = pure ψ\n          have h₇ : ρ.trace (MState.pure ψ).m = 1 := h₅\n          have h₈ : ρ = MState.pure ψ := by\n            -- Use the property of mixed states and pure states to conclude\n            have h₉ : ρ = MState.pure ψ := by\n              -- Use the fact that the trace of ρ * pure ψ is 1 to deduce ρ = pure ψ\n              have h₁₀ : ρ.trace (MState.pure ψ).m = 1 := h₅\n              have h₁₁ : ρ = MState.pure ψ := by\n                -- Use the trace property to deduce ρ = pure ψ\n                have h₁₂ : ρ.trace (MState.pure ψ).m = 1 := h₅\n                -- Use the property of mixed states to conclude ρ = pure ψ\n                have h₁₃ : ρ = MState.pure ψ := by\n                  -- Use the trace condition to deduce ρ = pure ψ\n                  apply MState.ext\n                  intro i j\n                  -- Use the trace condition to deduce the matrix elements\n                  simp [MState.mul_self, Matrix.trace, Finset.sum_ite_eq', Finset.mem_univ, ite_eq_left_iff] at h₁₂ ⊢\n                  <;>\n                  simp_all [Matrix.mul_apply, Finset.sum_mul, Finset.mul_sum, Complex.ext_iff, pow_two]\n                  <;>\n                  norm_num at *\n                  <;>\n                  (try ring_nf at *)\n                  <;>\n                  (try simp_all [Matrix.mul_apply, Finset.sum_mul, Finset.mul_sum, Complex.ext_iff, pow_two])\n                  <;>\n                  (try nlinarith)\n                  <;>\n                  (try\n                    {\n                      cases' d with d\n                      <;> simp_all [Fintype.card_fin]\n                      <;>\n                      (try norm_num)\n                      <;>\n                      (try ring_nf at *)\n                      <;>\n                      (try simp_all [Matrix.mul_apply, Finset.sum_mul, Finset.mul_sum, Complex.ext_iff, pow_two])\n                      <;>\n                      (try nlinarith)\n                    })\n                  <;>\n                  (try\n                    {\n                      aesop\n                    })\n                  <;>\n                  (try\n                    {\n                      norm_num at *\n                      <;>\n                      simp_all [Matrix.mul_apply, Finset.sum_mul, Finset.mul_sum, Complex.ext_iff, pow_two]\n                      <;>\n                      nlinarith\n                    })\n                  <;>\n                  (try\n                    {\n                      ring_nf at *\n                      <;>\n                      simp_all [Matrix.mul_apply, Finset.sum_mul, Finset.mul_sum, Complex.ext_iff, pow_two]\n                      <;>\n                      nlinarith\n                    })\n                  <;>\n                  (try\n                    {\n                      simp_all [Matrix.mul_apply, Finset.sum_mul, Finset.mul_sum, Complex.ext_iff, pow_two]\n                      <;>\n                      nlinarith\n                    })\n                exact h₁₃\n              exact h₁₁\n            exact h₉\n          exact h₈\n        exact h₆\n      exact h₂\n    · -- Prove the reverse direction: if ρ = pure ψ, then ρ.exp_val (pure ψ) = 1\n      intro h\n      have h₁ : ρ = MState.pure ψ := h\n      have h₂ : ρ.exp_val (MState.pure ψ) = 1 := by\n        -- Substitute ρ with pure ψ and compute the expectation value\n        rw [h₁]\n        simp [MState.exp_val, MState.mul_self, Matrix.trace_smul]\n        <;>\n        simp_all [Matrix.mul_assoc]\n        <;>\n        ring_nf\n        <;>\n        simp_all [Matrix.mul_apply, Finset.sum_mul]\n        <;>\n        aesop\n      exact h₂\n  exact h_main",
      "\n  have h₁ : ρ.exp_val (pure ψ) = 1 ↔ ρ = pure ψ := by\n    constructor\n    · -- Prove the forward direction: if ρ.exp_val (pure ψ) = 1, then ρ = pure ψ\n      intro h\n      have h₂ : ρ.exp_val (pure ψ) = 1 := h\n      have h₃ : ρ.exp_val (pure ψ) = (ψ * ψ† * ρ.m * ψ * ψ†).re := by\n        simp [MState.exp_val, Matrix.mul_assoc]\n        <;>\n        simp_all [MState, Complex.ext_iff, pow_two]\n        <;>\n        ring_nf\n        <;>\n        simp_all [Matrix.mul_assoc]\n        <;>\n        field_simp [Complex.ext_iff, pow_two]\n        <;>\n        ring_nf\n        <;>\n        simp_all [Matrix.mul_assoc]\n        <;>\n        nlinarith\n      rw [h₃] at h₂\n      have h₄ : (ψ * ψ† * ρ.m * ψ * ψ†).re = 1 := by\n        exact h₂\n      have h₅ : ψ * ψ† * ρ.m * ψ * ψ† = 1 := by\n        have h₅₁ : (ψ * ψ† * ρ.m * ψ * ψ†).re = 1 := h₄\n        have h₅₂ : (ψ * ψ† * ρ.m * ψ * ψ†).im = 0 := by\n          have h₅₃ : (ψ * ψ† * ρ.m * ψ * ψ†).im = 0 := by\n            simp_all [Matrix.mul_assoc, complex_conj_ofComplex, Matrix.mul_apply, Finset.sum_const, Finset.card_fin]\n            <;>\n            ring_nf at *\n            <;>\n            simp_all [Complex.ext_iff, pow_two, pow_three]\n            <;>\n            nlinarith\n          exact h₅₃\n        have h₅₃ : ψ * ψ† * ρ.m * ψ * ψ† = 1 := by\n          have h₅₄ : (ψ * ψ† * ρ.m * ψ * ψ† : Matrix d d ℂ) = 1 := by\n            apply Complex.ext <;>\n            simp_all [Complex.ext_iff, Matrix.one_apply, Matrix.dotProduct, Finset.sum_congr]\n            <;>\n            ring_nf at *\n            <;>\n            simp_all [Complex.ext_iff, pow_two, pow_three]\n            <;>\n            nlinarith\n          exact_mod_cast h₅₄\n        exact h₅₃\n      have h₆ : ρ = pure ψ := by\n        have h₆₁ : ψ * ψ† * ρ.m * ψ * ψ† = 1 := h₅\n        have h₆₂ : ρ = pure ψ := by\n          -- Use the fact that if ψ * ψ† * ρ.m * ψ * ψ† = 1, then ρ = pure ψ\n          apply le_antisymm\n          · -- Prove ρ ≤ pure ψ\n            -- Use the fact that ψ * ψ† is a projection\n            have h₆₃ : ρ ≤ pure ψ := by\n              -- Use the fact that ψ * ψ† is a projection\n              apply MState.le_of_nat_enc_\n              <;>\n              simp_all [MState, Complex.ext_iff, pow_two]\n              <;>\n              nlinarith\n            exact h₆₃\n          · -- Prove pure ψ ≤ ρ\n            -- Use the fact that ψ * ψ† is a projection\n            have h₆₃ : pure ψ ≤ ρ := by\n              -- Use the fact that ψ * ψ† is a projection\n              apply MState.le_of_nat_enc_\n              <;>\n              simp_all [MState, Complex.ext_iff, pow_two]\n              <;>\n              nlinarith\n            exact h₆₃\n        exact h₆₂\n      exact h₆\n    · -- Prove the reverse direction: if ρ = pure ψ, then ρ.exp_val (pure ψ) = 1\n      intro h\n      have h₂ : ρ = pure ψ := h\n      have h₃ : ρ.exp_val (pure ψ) = 1 := by\n        rw [h₂]\n        simp [MState.exp_val, Matrix.mul_assoc]\n        <;>\n        simp_all [MState, Complex.ext_iff, pow_two]\n        <;>\n        ring_nf\n        <;>\n        simp_all [Matrix.mul_assoc]\n        <;>\n        field_simp [Complex.ext_iff, pow_two]\n        <;>\n        ring_nf\n        <;>\n        simp_all [Matrix.mul_assoc]\n        <;>\n        nlinarith\n      exact h₃\n  exact h₁",
