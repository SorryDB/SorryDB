theorem MState.exp_val_pure_eq_one_iff {d : Type*} [Fintype d] [DecidableEq d] (ρ : MState d) (ψ : Ket d) :
    ρ.exp_val (pure ψ) = 1 ↔ ρ = pure ψ := by
  have h₁ : ρ.exp_val (pure ψ) = 1 ↔ ρ = pure ψ := by
    constructor
    · -- Prove the forward direction: if ρ.exp_val (pure ψ) = 1, then ρ = pure ψ
      intro h
      have h₂ : ρ.exp_val (pure ψ) = 1 := h
      have h₃ : ρ.exp_val (pure ψ) = (ψ * ψ† * ρ.m * ψ * ψ†).re := by
        simp [MState.exp_val, Matrix.mul_assoc]
        <;>
        simp_all [MState, Complex.ext_iff, pow_two]
        <;>
        ring_nf
        <;>
        simp_all [Matrix.mul_assoc]
        <;>
        field_simp [Complex.ext_iff, pow_two]
        <;>
        ring_nf
        <;>
        simp_all [Matrix.mul_assoc]
        <;>
        nlinarith
      rw [h₃] at h₂
      have h₄ : (ψ * ψ† * ρ.m * ψ * ψ†).re = 1 := by
        exact h₂
      have h₅ : ψ * ψ† * ρ.m * ψ * ψ† = 1 := by
        have h₅₁ : (ψ * ψ† * ρ.m * ψ * ψ†).re = 1 := h₄
        have h₅₂ : (ψ * ψ† * ρ.m * ψ * ψ†).im = 0 := by
          have h₅₃ : (ψ * ψ† * ρ.m * ψ * ψ†).im = 0 := by
            simp_all [Matrix.mul_assoc, complex_conj_ofComplex, Matrix.mul_apply, Finset.sum_const, Finset.card_fin]
            <;>
            ring_nf at *
            <;>
            simp_all [Complex.ext_iff, pow_two, pow_three]
            <;>
            nlinarith
          exact h₅₃
        have h₅₃ : ψ * ψ† * ρ.m * ψ * ψ† = 1 := by
          have h₅₄ : (ψ * ψ† * ρ.m * ψ * ψ† : Matrix d d ℂ) = 1 := by
            apply Complex.ext <;>
            simp_all [Complex.ext_iff, Matrix.one_apply, Matrix.dotProduct, Finset.sum_congr]
            <;>
            ring_nf at *
            <;>
            simp_all [Complex.ext_iff, pow_two, pow_three]
            <;>
            nlinarith
          exact_mod_cast h₅₄
        exact h₅₃
      have h₆ : ρ = pure ψ := by
        have h₆₁ : ψ * ψ† * ρ.m * ψ * ψ† = 1 := h₅
        have h₆₂ : ρ = pure ψ := by
          -- Use the fact that if ψ * ψ† * ρ.m * ψ * ψ† = 1, then ρ = pure ψ
          apply le_antisymm
          · -- Prove ρ ≤ pure ψ
            -- Use the fact that ψ * ψ† is a projection
            have h₆₃ : ρ ≤ pure ψ := by
              -- Use the fact that ψ * ψ† is a projection
              apply MState.le_of_nat_enc_
              <;>
              simp_all [MState, Complex.ext_iff, pow_two]
              <;>
              nlinarith
            exact h₆₃
          · -- Prove pure ψ ≤ ρ
            -- Use the fact that ψ * ψ† is a projection
            have h₆₃ : pure ψ ≤ ρ := by
              -- Use the fact that ψ * ψ† is a projection
              apply MState.le_of_nat_enc_
              <;>
              simp_all [MState, Complex.ext_iff, pow_two]
              <;>
              nlinarith
            exact h₆₃
        exact h₆₂
      exact h₆
