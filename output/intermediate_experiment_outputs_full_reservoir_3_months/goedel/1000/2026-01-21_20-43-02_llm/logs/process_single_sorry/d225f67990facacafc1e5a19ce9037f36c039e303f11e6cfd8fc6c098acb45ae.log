```lean
open Classical
open Encodable

variable {φ ψ χ ξ : Formula ℕ} {T : FTheory L} {hT : χ ➝ ξ ∉ T.theory}

def construction (T : FTheory L) (hT : χ ➝ ξ ∉ T.theory) : ℕ → Set (Formula ℕ)
  | 0 => { δ | χ ➝ δ ∈ T.theory }
  | i + 1 =>
    match (decode i) with
    | some δ =>
      letI T' := construction T hT i
      if ∀ Γ : Finset (Formula _), ↑Γ ⊆ T' → Γ.conj ⋏ δ ➝ ξ ∉ T.theory then insert δ T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : χ ➝ ξ ∉ T.theory) : Set (Formula ℕ) := ⋃ i, construction T hT i

lemma subset_construction_succ : construction T hT i ⊆ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i ⊆ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i ≤ j) : construction T hT i ⊆ construction T hT j := by
  obtain ⟨k, rfl⟩ := le_iff_exists_add.mp hij;
  apply subset_construction_add;

lemma mem_omega_of_mem (h : χ ➝ δ ∈ T.theory) : δ ∈ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion];
  use 0;
  simpa [construction] using h;

def mem_construction_omega {φ : Formula ℕ} (hφ : φ ∈ construction_omega T hT) :
  (χ ➝ φ ∈ T.theory) ∨ (∀ Γ : Finset _, ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory) := by
  have h₁ : ∃ i, φ ∈ construction T hT i := by
    simpa [construction_omega] using hφ
  classical
  obtain ⟨i, hi⟩ := h₁
  have h₂ : ∀ i : ℕ, φ ∈ construction T hT i → (χ ➝ φ ∈ T.theory) ∨ (∀ Γ : Finset _, ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory) := by
    intro i
    induction i with
    | zero =>
      intro hφ
      apply Or.inl
      simp [construction] at hφ ⊢
      exact hφ
    | succ i ih =>
      intro hφ
      simp only [construction] at hφ
      have h₃ : (decode i) = none ∨ ∃ δ, (decode i) = some δ := by
        by_cases h : (decode i) = none
        · exact Or.inl h
        · exact Or.inr ⟨Classical.choose (by tauto), by tauto⟩
      rcases h₃ with (h₃ | ⟨δ, h₃⟩)
      · -- Case: decode i = none
        simp [h₃] at hφ ⊢
        exact ih hφ
      · -- Case: decode i = some δ
        dsimp only [h₃, Set.mem_insert_iff, Set.mem_setOf_eq] at hφ
        split_ifs at hφ <;> simp_all [h₃, encode]
        <;>
        (try omega) <;>
        (try {
          left
          <;> simp_all [h₃]
          <;>
          (try omega)
          <;>
          (try {
            tauto
          })
        }) <;>
        (try {
          right
          <;>
          (try omega)
          <;>
          (try {
            tauto
          })
          <;>
          (try {
            intros
            <;> simp_all [h₃]
            <;>
            (try omega)
            <;>
            (try {
              tauto
            })
          })
        }) <;>
        (try {
          exfalso
          <;>
          (try omega)
          <;>
          (try {
            tauto
          })
        })
  exact h₂ i hi
  <;> simp_all [h₂]
  <;> tauto
  <;> tauto

lemma not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction] at hφ ⊢
    <;>
    (try contradiction) <;>
    (try tauto) <;>
    (try {
      simp_all [Set.mem_setOf_eq]
      <;>
      (try contradiction) <;>
      (try tauto)
    }) <;>
    (try {
      exfalso
      simp_all [Set.mem_setOf_eq]
      <;>
      (try contradiction) <;>
      (try tauto)
    })
  | succ i ih =>
    simp [construction] at hφ ⊢
    <;>
    (try contradiction) <;>
    (try tauto) <;>
    (try {
      simp_all [Set.mem_setOf_eq]
      <;>
      (try contradiction) <;>
      (try tauto)
    }) <;>
    (try {
      exfalso
      simp_all [Set.mem_setOf_eq]
      <;>
      (try contradiction) <;>
      (try tauto)
    })

lemma of_not_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∉ construction_omega T hT) :
  (χ ➝ φ ∉ T.theory) ∧ (∃ Γ : Finset (Formula _), ↑Γ ⊆ (construction T hT (encode φ)) ∧ Γ.conj ⋏ φ ➝ ξ ∈ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hφ ⊢
  have h₁ : χ ➝ φ ∉ T.theory := by
    by_contra h
    have h₂ : φ ∈ construction_omega T hT := mem_omega_of_mem h
    exact hφ h₂
  have h₂ : ∃ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT (encode φ) ∧ Γ.conj ⋏ φ ➝ ξ ∈ T.theory := by
    by_cases h : ∃ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT (encode φ) ∧ Γ.conj ⋏ φ ➝ ξ ∈ T.theory
    · exact h
    · exfalso
      have h₃ : ∀ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory := by
        intro Γ hΓ
        by_contra h₄
        have h₅ : ∃ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT (encode φ) ∧ Γ.conj ⋏ φ ➝ ξ ∈ T.theory := ⟨Γ, hΓ, h₄⟩
        tauto
      have h₄ : φ ∈ construction_omega T hT := by
        simp only [construction_omega, Set.mem_iUnion]
        use (encode φ + 1)
        have h₅ : φ ∈ construction T hT (encode φ + 1) := by
          simp only [construction]
          have h₅₁ : (decode (encode φ)) = some φ := by
            rw [decode_encode]
          by_cases h₅₂ : ∀ (Γ : Finset (Formula ℕ)), ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∉ T.theory
          · simp_all [h₅₁]
            <;>
            (try tauto) <;>
            (try {
              aesop
            })
          · simp_all [h₅₁]
            <;>
            (try tauto) <;>
            (try {
              aesop
            })
        tauto
      exact hφ h₄
  exact ⟨h₁, h₂⟩

variable [Entailment.F L]

lemma construction_omega_mem_ant : χ ∈ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
  apply impId;

lemma construction_omega_not_mem_csq : ξ ∉ construction_omega T hT := by
