theorem prime_3 : ∀ (p : ℕ), p ≥ 2 → Prime p → ∃ (a b : ℕ), a ≥ 1 ∧ b ≥ 1 ∧ p = a * b ∧ a + b = p + 1 := by
  intro p hp hprime
  use 1, p - 1
  have h₁ : p - 1 ≥ 1 := by
    have h₂ : p ≥ 2 := hp
    omega
  have h₂ : 1 + (p - 1) = p := by
    have h₃ : p ≥ 2 := hp
    omega
  have h₃ : 1 * (p - 1) = p - 1 := by
    simp [Nat.mul_one]
  have h₄ : 1 ≥ 1 := by norm_num
  have h₅ : p - 1 ≥ 1 := by
    have h₆ : p ≥ 2 := hp
    omega
  have h₆ : p = 1 * (p - 1) + 2 - 1 := by
    have h₇ : p ≥ 2 := hp
    cases p with
    | zero => contradiction
    | succ p' =>
      cases p' with
      | zero => contradiction
      | succ p'' =>
        simp_all [Nat.mul_succ, Nat.add_assoc]
        <;> ring_nf at *
        <;> omega
  constructor
  · -- Prove a ≥ 1
    norm_num
  · constructor
    · -- Prove b ≥ 1
      omega
    · constructor
      · -- Prove p = a * b
        have h₇ : p ≥ 2 := hp
        have h₈ : p = 1 * (p - 1) + 2 - 1 := by
          cases p with
          | zero => contradiction
          | succ p' =>
            cases p' with
            | zero => contradiction
            | succ p'' =>
              simp_all [Nat.mul_succ, Nat.add_assoc]
              <;> ring_nf at *
              <;> omega
        omega
      · -- Prove a + b = p + 1
        have h₇ : p ≥ 2 := hp
        omega
