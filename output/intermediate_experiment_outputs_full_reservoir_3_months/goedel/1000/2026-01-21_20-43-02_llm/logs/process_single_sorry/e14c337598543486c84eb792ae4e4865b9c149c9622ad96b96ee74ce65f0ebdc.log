theorem not_of_mem_construction_omega {L : Logic ℕ} {χ ξ : Formula ℕ} {T : FTheory L} (hT : χ ➝ ξ ∉ T.theory)
  {φ : Formula ℕ} {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ)) (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  intro hφ'
  have h₁ : φ ∈ construction_omega T hT := hφ'
  have h₂ : ∃ i, φ ∈ construction T hT i := by
    simp only [construction_omega, Set.mem_iUnion] at h₁
    exact h₁
  obtain ⟨i, hi⟩ := h₂
  have h₃ : ∀ (Γ : Finset (Formula ℕ)), ↑Γ ⊆ construction T hT (encode φ) → Γ.conj ⋏ φ ➝ ξ ∈ T.theory → False := by
    intro Γ hΓ hφ
    have h₄ : i ≤ encode φ ∨ encode φ ≤ i := by omega
    cases h₄ with
    | inl h₄ =>
      have h₅ : construction T hT i ⊆ construction T hT (encode φ) := monotone_construction h₄
      have h₆ : ↑Γ ⊆ construction T hT (encode φ) := hΓ
      have h₇ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory := hφ
      have h₈ : χ ➝ φ ∈ T.theory := by
        by_contra h
        have h₉ : χ ➝ φ ∉ T.theory := h
        have h₁₀ : φ ∈ construction T hT i := hi
        have h₁₁ : i = 0 := by
          by_contra h₁₁
          have h₁₂ : i > 0 := by omega
          have h₁₃ : φ ∈ construction T hT i := hi
          dsimp [construction] at h₁₃
          <;> simp_all [Nat.succ_eq_add_one, Nat.add_assoc]
          <;> tauto
        simp_all [construction]
        <;> aesop
      simp_all [imp_eq_and_not]
      <;> tauto
    | inr h₄ =>
      have h₅ : construction T hT (encode φ) ⊆ construction T hT i := monotone_construction h₄
      have h₆ : ↑Γ ⊆ construction T hT (encode φ) := hΓ
      have h₇ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory := hφ
      have h₈ : χ ➝ φ ∈ T.theory := by
        by_contra h
        have h₉ : χ ➝ φ ∉ T.theory := h
        have h₁₀ : φ ∈ construction T hT i := hi
        have h₁₁ : i = 0 := by
