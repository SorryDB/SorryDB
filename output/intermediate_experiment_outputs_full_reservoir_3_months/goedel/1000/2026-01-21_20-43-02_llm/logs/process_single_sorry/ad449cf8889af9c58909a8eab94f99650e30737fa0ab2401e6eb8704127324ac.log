  vectors of length `n`. -/
@[reducible]
def spec : OracleSpec (ќ± √Ч ќ±) := (ќ± √Ч ќ±) вЖТвВТ ќ±

@[simp]
lemma domain_def : (spec ќ±).Domain = (ќ± √Ч ќ±) := rfl

@[simp]
lemma range_def (z) : (spec ќ±).Range z = ќ± := rfl

end spec


