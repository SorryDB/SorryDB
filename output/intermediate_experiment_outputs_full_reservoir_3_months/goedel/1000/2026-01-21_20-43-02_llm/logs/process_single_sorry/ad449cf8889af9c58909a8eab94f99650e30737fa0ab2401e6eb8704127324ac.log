def singleHash (left : ќ±) (right : ќ±) : OracleComp (spec ќ±) ќ± := do
  let out вЖР query (spec := spec ќ±) вЯ®left, rightвЯ©
  return out

def buildMerkleTree {s} (leaf_tree : LeafData ќ± s) : OracleComp (spec ќ±) (FullData ќ± s) :=
  match leaf_tree with
  | LeafData.leaf a => do return (FullData.leaf a)
  | LeafData.internal left right => do
    let leftTree вЖР buildMerkleTree left
    let rightTree вЖР buildMerkleTree right
