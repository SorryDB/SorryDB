          ring_nf\n                    <;>\n                    norm_cast\n                    <;>\n                    linarith\n              _ = ∑ j in Finset.range M, (|(b - a) / M| * ‖(fun x => f n x - F x) (a + (j : ℝ) * (b - a) / M)‖) := by rfl\n              _ = (|(b - a) / M| * ∑ j in Finset.range M, ‖(fun x => f n x - F x) (a + (j : ℝ) * (b - a) / M)‖) := by\n                simp [Finset.mul_sum]\n              _ = (|(b - a) / M| * ∑ j in Finset.range M, ‖(fun x => f n x - F x) (a + (j : ℝ) * (b - a) / M)‖) := by rfl\n              _ ≤ (b - a) * (∑ j in Finset.range M, ‖(fun x => f n x - F x) (a + (j : ℝ) * (b - a) / M)‖) := by\n                have h₅ : |(b - a) / M| ≤ b - a := by\n                  have h₅₁ : (b - a : ℝ) ≥ 0 := by linarith\n                  have h₅₂ : (M : ℝ) ≥ 1 := by\n                    by_contra h₅₂\n                    have h₅₃ : (M : ℝ) < 1 := by linarith\n                    have h₅₄ : M = 0 := by\n                      norm_cast at h₅₃ ⊢\n                      <;>\n                      (try omega) <;>\n                      (try linarith)\n                    simp_all [h₅₄]\n                    <;>\n                    norm_num at hε ⊢ <;>\n                    linarith\n                  have h₅₃ : (b - a : ℝ) / M ≤ b - a := by\n                    have h₅₄ : (b - a : ℝ) / M ≤ b - a := by\n                      rw [div_le_iff (by positivity)]\n                      nlinarith\n                    linarith\n                  have h₅₄ : 0 ≤ (b - a : ℝ) / M := by\n                    apply div_nonneg\n                    · linarith\n                    · positivity\n                  have h₅₅ : |(b - a : ℝ) / M| ≤ b - a := by\n                    rw [abs_of_nonneg h₅₄]\n                    linarith\n                  exact h₅₅\n                calc\n                  (|(b - a) / M| * ∑ j in Finset.range M, ‖(fun x => f n x - F x) (a + (j : ℝ) * (b - a) / M)‖) ≤ (b - a) * ∑ j in Finset.range M, ‖(fun x => f n x - F x) (a + (j : ℝ) *