      g (f (x * y)) = g (f x * f y) := by
        -- Use the fact that `f` is a ring homomorphism to preserve multiplication
        rw [f.map_mul]
      _ = g (f x) * g (f y) := by
        -- Use the fact that `g` is a ring homomorphism to preserve multiplication
        rw [g.map_mul]
