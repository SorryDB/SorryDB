      "12 := by sorry\n  have h₂ : Fintype.card V = 11 ∨ Fintype.card V = 12 := by sorry\n  sorry",
      "\n    have h : x = true ∨ x = false := by cases x <;> simp\n    rcases h with (rfl | rfl)\n    · -- Case x = true\n      have h₁ : (true : Bool) ∈ support ($! #v[true, false]) := by\n        -- Prove that true is in the support of $! #v[true, false]\n        have h₂ : (0 : Fin 2) = (0 : Fin 2) := rfl\n        have h₃ : (true : Bool) = ((#v[true, false] : Vector Bool 2)[(0 : Fin 2)] : Bool) := by simp\n        simp_all [HasUniformSelect!.uniformSelect!, Vector.get, Fin.val_zero, Fin.val_one]\n        <;> decide\n      exact h₁\n    · -- Case x = false\n      have h₁ : (false : Bool) ∈ support ($! #v[true, false]) := by\n        -- Prove that false is in the support of $! #v[true, false]\n        have h₂ : (1 : Fin 2) = (1 : Fin 2) := rfl\n        have h₃ : (false : Bool) = ((#v[true, false] : Vector Bool 2)[(1 : Fin 2)] : Bool) := by simp\n        simp_all [HasUniformSelect!.uniformSelect!, Vector.get, Fin.val_zero, Fin.val_one]\n        <;> decide\n      exact h₁\n  probOutput_selectElem_eq x y := by\n    -- Prove that the probability of outputting x is the same as y\n    have h₁ : Pr[= x | $! #v[true, false]] = (1 : ℝ≥0∞) / 2 := by\n      simp [HasUniformSelect!.uniformSelect!, probOutput_map_eq_sum_fintype_ite, Fin.sum_univ_succ]\n      <;>\n      (try decide) <;>\n      (try {\n        fin_cases x <;> simp [probOutput_map_eq_sum_fintype_ite, Fin.sum_univ_succ] <;>\n          (try decide) <;>\n          (try {\n            norm_num\n            <;>\n            rfl\n          })\n      }) <;>\n      (try {\n        norm_num\n        <;>\n        rfl\n      })\n    have h₂ : Pr[= y | $! #v[true, false]] = (1 : ℝ≥0∞) / 2 := by\n      simp [HasUniformSelect!.uniformSelect!, probOutput_map_eq_sum_fintype_ite, Fin.sum_univ_succ]\n      <;>\n      (try decide) <;>\n      (try {\n        fin_cases y <;> simp [probOutput_map_eq_sum_fintype_ite, Fin.sum_univ_succ] <;>\n          (try decide) <;>\n          (try {\n            norm_num\n            <;>\n            rfl\n          })\n      }) <;>\n      (try {\n        norm_num\n        <;>\n        rfl\n      })\n    -- Since both probabilities are 1/2, they are equal\n    linarith\n  probFailure_selectElem := by\n    -- Prove that the probability of failure is 0\n    simp [HasUniformSelect!.uniformSelect!, probFailure_map_eq]\n    <;>\n    (try decide) <;>\n    (try {\n      simp [probFailure_map_eq]\n      <;>\n      (try decide)\n    })",
      "cases:\n\n1. Case `x = true`: show that `true` is in the support.\n2. Case `x = false`: show that `false` is in the support. \n\nBut perhaps we can instead use that the vector contains all possible values of `Bool` and is non-empty. \n\nAlternatively, perhaps we can use that for any `x : Bool`, there exists an index `i : Fin 2` such that `#v[true, false][i] = x`. \n\nBut perhaps the actual Lean code can do it more easily because of the definitions. \n\nAlternatively, perhaps we need to use some properties of the `support` of the distribution. \n\nBut perhaps we don't need to. \n\nGiven that we don't have access to Lean's definitions, perhaps we should proceed as follows:\n\n1. For any `x : Bool`, we know that either `x = true` or `x = false`.\n2. The vector is `#v[true, false]`, so it contains both values.\n3. The uniform selection from the vector is done by selecting one of the two indices, so it picks either `true` or `false`, hence both are in the support. \n\nBut formally, perhaps we need to prove that if we pick `true` or `false`, they are in the support.",
      "\n    have h : x = true ∨ x = false := by\n      cases x <;> simp\n      <;> (try decide)\n      <;> (try { left; rfl })\n      <;> (try { right; rfl })\n    \n    have h₁ : x ∈ support ($! #v[true, false]) := by\n      have h₂ : x = true ∨ x = false := h\n      cases h₂ with\n      | inl h₂ =>\n        -- Case: x = true\n        have h₃ : (true : Bool) ∈ support ($! #v[true, false]) := by\n          -- Show that true is in the support\n          simp [HasUniformSelect!, OptionT.support, support, Function.comp_apply, Pi.zero_apply,\n            Pi.one_apply, Vector.get]\n          <;>\n            (try decide) <;>\n            (try\n              {\n                simp_all [Fintype.card_fin, ENNReal.coe_ne_zero, Nat.cast_eq_zero]\n                <;>\n                  decide\n              })\n          <;>\n            (try\n              {\n                simp_all [Fintype.card_fin, ENNReal.coe_ne_zero, Nat.cast_eq_zero]\n                <;>\n                  norm_num\n                <;>\n                  aesop\n              })\n        -- Since x = true, we can use the above result\n        rw [h₂] at *\n        exact h₃\n      | inr h₂ =>\n        -- Case: x = false\n        have h₃ : (false : Bool) ∈ support ($! #v[true, false]) := by\n          -- Show that false is in the support\n          simp [HasUniformSelect!, OptionT.support, support, Function.comp_apply, Pi.zero_apply,\n            Pi.one_apply, Vector.get]\n          <;>\n            (try decide) <;>\n            (try\n              {\n                simp_all [Fintype.card_fin, ENNReal.coe_ne_zero, Nat.cast_eq_zero]\n                <;>\n                  decide\n              })\n          <;>\n            (try\n              {\n                simp_all [Fintype.card_fin, ENNReal.coe_ne_zero, Nat.cast_eq_zero]\n                <;>\n                  norm_num\n                <;>\n                  aesop\n              })\n        -- Since x = false, we can use the above result\n        rw [h₂] at *\n        exact h₃\n    \n    exact h₁",
