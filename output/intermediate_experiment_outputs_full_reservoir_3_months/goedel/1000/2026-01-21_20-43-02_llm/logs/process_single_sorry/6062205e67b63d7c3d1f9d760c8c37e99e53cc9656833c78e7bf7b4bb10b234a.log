      "\n    have h₁ : x = true ∨ x = false := by\n      cases x\n      · exact Or.inr rfl\n      · exact Or.inl rfl\n    -- We need to show that x is in the support of the uniformSelect! instance for the vector #v[true, false]\n    have h₂ : x ∈ (Vector.toList #v[true, false]).toFinset := by\n      simp_all [Vector.toList_cons, Vector.toList_nil, Finset.mem_insert, Finset.mem_singleton]\n      <;> aesop\n    -- Since x is in the toFinset of the vector, it must be in the support of the uniformSelect! instance\n    simp_all [support, Set.mem_setOf_eq, Vector.toList_cons, Vector.toList_nil, Finset.mem_insert, Finset.mem_singleton]\n    <;>\n    (try decide) <;>\n    (try aesop) <;>\n    (try simp_all [uniformSelectVector_def, uniformSelectList_def, ProbM.nat_cast, Finset.mem_coe, List.mem_toFinset]) <;>\n    (try aesop)\n  probOutput_selectElem_eq x y := by\n    simp [sample, PCpu.hack]\n    <;>\n    (try decide) <;>\n    (try\n      {\n        cases x <;> cases y <;> simp_all [sample, PCpu.hack]\n        <;>\n        (try decide)\n      })\n    <;>\n    (try\n      {\n        aesop\n      })\n  probFailure_selectElem := by\n    simp [sample, PCpu.hack]\n    <;>\n    (try decide) <;>\n    (try\n      {\n        simp_all [sample, PCpu.hack]\n        <;>\n        (try decide)\n      })\n    <;>\n    (try\n      {\n        aesop\n      })",
