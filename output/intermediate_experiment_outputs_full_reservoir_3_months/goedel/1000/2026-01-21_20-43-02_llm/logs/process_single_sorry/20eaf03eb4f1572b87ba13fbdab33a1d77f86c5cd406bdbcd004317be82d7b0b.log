structure emptyPrimeFTheory (L : Logic _) [Entailment.F L] [Entailment.Disjunctive L] : PrimeFTheory L where
  theory := L
  no_bot := by
    intro h;
    have h₁ : L ⊢ False := by simpa [List.mem_singleton] using h;
    have h₂ : False := by {
      have h₃ : L ⊢ True := by exact Empty.elim;
      have h₄ : L ⊢ False := h₁;
      absurd h₃ (by intro h; exact by simp_all [entailment reproves antecedent])
    }
    exact False.elim h₂
