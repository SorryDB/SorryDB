      "\n  have h : ContDiffOn ℝ ∞ (Φ₆' r) ℍ₀ := by\n    -- Use the fact that Φ₆' r is already known to be complex smooth on ℍ₀\n    -- and that complex smoothness implies real smoothness\n    have h₆ : ContDiffOn 𝕜 ∞ (Φ₆' r) ℍ₀ := by\n      exact Φ₆'_contDiffOn_ℂ\n    -- Conversion from complex smoothness to real smoothness\n    simpa using h₆.of_real\n  exact h",
      "",
      "\n  have h₁ : ContDiffOn ℝ ∞ (Φ₆' r) ℍ₀ := by\n    -- Use the fact that Φ₆' r is smooth on the upper half-plane to conclude the proof.\n    have h₂ : ContDiffOn ℝ ∞ (fun z : ℂ => (z : ℂ)) ℍ₀ := by\n      apply contDiffOn_id\n    have h₃ : ContDiffOn ℝ ∞ (fun z : ℂ => exp (r * z)) ℍ₀ := by\n      -- The exponential function is smooth everywhere.\n      apply ContDiffOn.exp\n      apply ContDiffOn.mul\n      · exact contDiffOn_const\n      · exact contDiffOn_id\n    have h₄ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z) ℍ₀ := by\n      -- φ₀'' is smooth on the upper half-plane.\n      have h₅ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z) ℍ₀ := by\n        sorry\n      exact h₅\n    -- Combine the smoothness of the components to get the smoothness of Φ₆' r.\n    have h₅ : ContDiffOn ℝ ∞ (fun z : ℂ => φ₀'' z * exp (r * z)) ℍ₀ := by\n      apply ContDiffOn.mul h₄ h₃\n    -- Use the fact that Φ₆' r is a composition of smooth functions.\n    have h₆ : (fun z : ℂ => φ₀'' z * exp (r * z)) = Φ₆' r := by\n      funext z\n      simp [Φ₆', φ₀'', Complex.ext_iff, Complex.exp_re, Complex.exp_im, mul_comm]\n      <;> ring_nf <;> simp_all [Complex.ext_iff, Complex.exp_re, Complex.exp_im, mul_comm]\n      <;> norm_num <;> linarith\n    rw [h₆] at h₅\n    exact h₅\n  exact h₁",
      "\n  have h : ContDiffOn ℂ ∞ (Φ₆' r) ℍ₀ := Φ₆'_contDiffOn_ℂ\n  have h₂ : ContDiffOn ℝ ∞ (Φ₆' r) ℍ₀ :=\n    h.contDiffOn_real_of_isOpen (isOpen_upperHalfPlaneSet) (differentiableOn_const _)\n  exact h₂",
