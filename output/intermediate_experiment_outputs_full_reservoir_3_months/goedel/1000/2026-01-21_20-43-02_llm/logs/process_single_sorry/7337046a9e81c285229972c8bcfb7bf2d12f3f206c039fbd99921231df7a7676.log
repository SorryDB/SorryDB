      have h_B_eq_singleton : B N hN = {N} := by
        apply Set.Subset.antisymm
        · exact h_subset
        · have h_sup_B : N = sSup (B N hN) := hB N hN
          have h_sup_singleton : sSup ({N} : Set (PersistenceSubmodule M)) = N := by simp
          have h_sub : {N} ⊆ B N hN := by
            by_contra h_sub_neg
            push_neg at h_sub_neg
            obtain ⟨x, hx⟩ := h_sub_neg
            have h_x_not_in_B : x ∉ B N hN := hx
            have h_x_eq_N : x = N := by simp_all [Set.mem_singleton_iff]
            rw [h_x_eq_N] at h_x_not_in_B
            simp_all [Set.mem_singleton_iff]
          have h_sup_sub : sSup ({N} : Set (PersistenceSubmodule M)) ≤ sSup (B N hN) := sSup_le_sSup h_sub
          have h_eq : sSup (B N hN) = N := by
            rw [hB N hN]
