      "by\n  have h₁ : D ≤ refinement B hB hB' hB'' := by\n    intro N hN\n    have h₂ : N ∈ D := hN\n    have h₃ : ∃ B : Set (PersistenceSubmodule M), B ⊆ (refinement B hB hB' hB'').carrier ∧ N = sSup B := by\n      refine' ⟨B N h₂, _, _⟩\n      · -- Prove that B N h₂ is a subset of the carrier of the refinement\n        intro x hx\n        simp only [refinement.carrier, Set.mem_iUnion, Set.mem_iUnion] at hx ⊢\n        refine' ⟨N, h₂, x, hx⟩\n      · -- Prove that N is the supremum of B N h₂\n        exact hB N h₂\n    -- Use the existence of B to construct the required subset\n    obtain ⟨B', hB'_subset, hB'_eq⟩ := h₃\n    exact ⟨B', hB'_subset, by simp_all [SetLike.ext_iff]⟩\n  have h₂ : ¬(refinement B hB hB' hB'' ≤ D) := by\n    intro h_le\n    -- Use the hypothesis H to find a contradiction\n    obtain ⟨N, hN, hB_ne⟩ := H\n    have h₃ : N ∈ D := hN\n    have h₄ : B N h₃ ≠ {N} := hB_ne\n    have h₅ : (sSup (B N h₃)) ∈ (D : Set (PersistenceSubmodule M)) := by\n      have h₆ : N = sSup (B N h₃) := hB N h₃\n      have h₇ : N ∈ D := h₃\n      rw [h₆] at h₇\n      exact h₇\n    have h₆ : sSup (B N h₃) = N := by\n      rw [hB N h₃]\n    have h₇ : ∃ (B : Set (PersistenceSubmodule M)), B ⊆ (D : Set (PersistenceSubmodule M)) ∧ sSup (B N h₃) = sSup B := by\n      refine' ⟨{sSup (B N h₃)}, _, _⟩\n      · -- Prove that {sSup (B N h₃)} is a subset of D\n        intro x hx\n        simp only [Set.mem_singleton_iff] at hx\n        rw [hx]\n        exact h₅\n      · -- Prove that sSup (B N h₃) = sSup {sSup (B N h₃)}\n        simp [sSup_singleton]\n    obtain ⟨B', hB'_subset, hB'_eq⟩ := h₇\n    have h₈ : sSup (B N h₃) = sSup B' := by\n      rw [hB'_eq]\n    have h₉ : B N h₃ ≠ {N} := h₄\n    have h₁₀ : ∃ (x :PersistenceSubmodule M), x ∈ B N h₃ ∧ x ≠ N := by\n      by_contra h\n      push_neg at h\n      have h₁₁ : B N h₃ ⊆ {N} := by\n        intro x hx\n        have h₁₂ : x ∈ B N h₃ := hx\n        have h₁₃ : x = N := by\n          by_cases hx' : x = N\n          · exact hx'\n          · exfalso\n            have h₁₄ := h x hx'\n            aesop\n        simp [h₁₃]\n      have h₁₂ : B N h₃ = {N} := by\n        apply Set.Subset.antisymm\n        · exact h₁₁\n        · intro x hx\n          simp only [Set.mem_singleton_iff] at hx ⊢\n          have h₁₃ : N ∈ B N h₃ := by\n            have h₁₄ : sSup (B N h₃) = N := by\n              rw [hB N h₃]\n            have h₁₅ : N ≤ sSup (B N h₃) := le_sSup (by\n              have h₁₆ : N ∈ D := h₃\n              have h₁₇ : N = sSup (B N h₃) := hB N h₃\n              have h₁₈ : sSup (B N h₃) ∈ B N h₃ := by\n                have h₁₉ : sSupIndep (B N h₃) := hB' N h₃\n                exact h₁₉.mem_of_le_sup (by simp [h₁₇])\n              aesop)\n            have h₁₆ : N ∈ B N h₃ := by\n              have h₁₇ : sSup (B N h₃) ∈ B N h₃ := by\n                have h₁₈ : sSupIndep (B N h₃) := hB' N h₃\n                exact h₁₈.mem_of_le_sup (by simp [hB N h₃])\n              have h₁₉ : N = sSup (B N h₃) := hB N h₃\n              rw [h₁₉] at *\n              exact h₁₇\n            exact h₁₆\n          aesop\n      contradiction\n    obtain ⟨x, hx, hx'⟩ := h₁₀\n    have h₁₁ : x ∈ B N h₃ := hx\n    have h₁₂ : x ≠ N := hx'\n    have h₁₃ : x ∈ (refinement B hB hB' hB'').carrier := by\n      simp only [refinement.carrier, Set.mem_iUnion, Set.mem_iUnion]\n      refine' ⟨N, h₃, x, hx⟩\n    have h₁₄ : x ∈ (D : Set (PersistenceSubmodule M)) := by\n      have h₁₅ : refinement B hB hB' hB'' ≤ D := h_le\n      have h₁₆ : x ∈ (refinement B hB hB' hB'').carrier := h₁₃\n      have h₁₇ : x ∈ (D : Set (PersistenceSubmodule M)) := by\n        have h₁₈ : refine' fun y hy => ?_ := h₁₅\n        have h₁₉ := h₁₈ x h₁₃\n        exact h₁₉\n      exact h₁₇\n    have h₁₅ : x = N := by\n      have h₁₆ : x ∈ (D : Set (PersistenceSubmodule M)) := h₁₄\n      have h₁₇ : N = sSup (B N h₃) := hB N h₃\n      have h₁₈ : x ∈ B N h₃ := hx\n      have h₁₉ : x ≤ sSup (B N h₃) := le_sSup h₁₈\n      have h₂₀ : sSup (B N h₃) = N := by\n        rw [hB N h₃]\n      have h₂₁ : x ≤ N := by\n        rw [h₂₀] at h₁₉\n        exact h₁₉\n      have h₂₂ : N ≤ x := by\n        have h₂₃ : x ∈ D := h₁₄\n        have h₂₄ : sSupIndep (D : Set (PersistenceSubmodule M)) := D.sSupIndep'\n        have h₂₅ : x ∈ (D : Set (PersistenceSubmodule M)) := h₁₄\n        have h₂₆ : N ∈ (D : Set (PersistenceSubmodule M)) := h₃\n        have h₂₇ : sSup (B N h₃) = N := by\n          rw [hB N h₃]\n        have h₂₈ : x ≤ sSup (B N h₃) := le_sSup hx\n        have h₂₉ : x ≤ N := by\n          rw [h₂₇] at h₂₈\n          exact h₂₈\n        have h₃₀ : N ≤ x := by\n          have h₃₁ : sSup (B N h₃) = N := by\n            rw [hB N h₃]\n          have h₃₂ : x ∈ B N h₃ := hx\n          have h₃₃ : x ≤ sSup (B N h₃) := le_sSup h₃₂\n          have h₃₄ : sSup (B N h₃) = N := by\n            rw [hB N h₃]\n          have h₃₅ : x ≤ N := by\n            rw [h₃₄] at h₃₃\n            exact h₃₃\n          have h₃₆ : N ≤ x := by\n            have h₃₇ : sSupIndep (B N h₃) := hB' N h₃\n            have h₃₈ := h₃₇.eq_of_le_sup hx (by\n              have h₃₉ : x ∈ B N h₃ := hx\n              have h₄₀ : x ≤ sSup (B N h₃) := le_sSup h₃₉\n              have h₄₁ : sSup (B N h₃) = N := by\n                rw [hB N h₃]\n              rw [h₄₁] at h₄₀\n              exact h₄₀)\n            simp_all [eq_comm]\n            <;> aesop\n          exact h₃₆\n        exact h₃₀\n      have h₂₃ : x = N := by\n        exact le_antisymm h₂₁ h₂₂\n      exact h₂₃\n    contradiction\n  exact lt_of_le_not_le h₁ h₂",
