      "by\n  have h_lt : D < refinement B hB hB' hB'' := by\n    have h₁ : D ≤ refinement B hB hB' hB'' := refinement_le B hB hB' hB''\n    have h₂ : ¬(refinement B hB hB' hB'' ≤ D) := by\n      by_contra h\n      rcases H with ⟨N, hN, hN'⟩\n      have h₃ : B N hN ≠ {N} := hN'\n      have h₄ : B N hN ⊆ (refinement B hB hB' hB'').carrier := by\n        intro B' hB'\n        simp [refinement]\n        <;> aesop\n      have h₅ : sSup (B N hN) = N := by\n        rw [hB N hN]\n      have h₆ : sSup (B N hN) ≠ (sSup (B N hN) : _) := by\n        simp_all [refinement]\n        <;> aesop\n      simp_all [refinement]\n      <;> aesop\n    exact lt_of_le_of_not_le h₁ h₂\n  exact h_lt",
      "by\n  apply lt_of_le_of_ne (refinement_le B hB hB' hB'')\n  intro h_eq\n  -- If D is equal to refinement B hB hB' hB'', then their carrier sets are the same\n  have h_carrier_eq : D = refinement B hB hB' hB'' := h_eq\n  have h_carrier_eq' : SetLike.coe D = SetLike.coe (refinement B hB hB' hB'') := by\n    simpa [h_carrier_eq] using SetLike.ext'_iff.mpr rfl\n  -- Use the given condition H to find a contradiction\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_N_in_D : N ∈ D := hN\n  have h_B_ne : B N hN ≠ {N} := h_ne\n  -- Use the fact that B N hN ≠ {N} to show that there exists a non-trivial decomposition\n  have h_B_nontrivial : ∃ (p q : PersistenceSubmodule M), p ∈ B N hN ∧ q ∈ B N hN ∧ p ≠ q := by\n    by_contra! h\n    have h₁ : B N hN = {N} := by\n      have h₂ : B N hN ⊆ {N} := by\n        intro x hx\n        by_cases h₃ : x = N\n        · simp_all\n        · -- If x ≠ N and B N hN ≠ {N}, then we get a contradiction\n          have h₄ := h x (by simp_all)\n          simp_all [hB]\n          <;> aesop\n      have h₃ : {N} ⊆ B N hN := by\n        have h₄ : N = sSup (B N hN) := hB N hN\n        have h₅ : N ∈ B N hN := by\n          by_contra h₅\n          have h₆ : sSup (B N hN) = ⊥ := by\n            have h₇ : sSupIndep (B N hN) := hB' N hN\n            have h₈ : Disjoint (sSup (B N hN)) N := by\n              have h₉ := hB'' N hN\n              simp_all [disjoint_left]\n              <;> aesop\n            have h₉ : sSup (B N hN) ≠ ⊥ := by\n              by_contra h₉\n              simp_all [Submodule.bot_eq_empty]\n              <;> aesop\n            have h₁₀ : Disjoint N (sSup (B N hN)) := by\n              exact disjoint_comm.mpr h₈\n            have h₁₁ : N = ⊥ := by\n              simp_all [disjoint_left]\n              <;> aesop\n            simp_all [Submodule.bot_eq_empty]\n            <;> aesop\n          simp_all [hB]\n          <;> aesop\n        simp_all\n      exact Set.Subset.antisymm h₂ h₃\n    contradiction\n  -- Since B N hN is nontrivial, the