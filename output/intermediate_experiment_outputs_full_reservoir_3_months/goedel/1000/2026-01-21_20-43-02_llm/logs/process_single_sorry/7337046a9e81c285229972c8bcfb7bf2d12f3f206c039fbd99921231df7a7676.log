              <;>
              (try aesop) <;>
              (try
                {
                  use hN
                  <;>
                  aesop
                })
            })
        exact h2
      have h2 : refine D = D := by
        simp [SetLike.ext_iff]
        <;>
        aesop
      rw [h2] at h1
      exact h1
    -- Find an element in B N hN that is not in {N}
    have h_exists_x : ∃ x ∈ B N hN, x ≠ N := by
      by_contra h_neg
      -- If no such x exists, then B N hN ⊆ {N}
      push_neg at h_neg
      have h_subset : B N hN ⊆ {N} := by
        intro x hx
        have h_x_eq_N : x = N := by
          by_cases h : x = N
          · exact h
          · exfalso
            have h3 : x ∈ B N hN := hx
            have h4 : x ≠ N := h
            have h5 : ∃ x ∈ B N hN, x ≠ N := ⟨x, hx, h4⟩
            tauto
        rw [h_x_eq_N]
        <;> simp
