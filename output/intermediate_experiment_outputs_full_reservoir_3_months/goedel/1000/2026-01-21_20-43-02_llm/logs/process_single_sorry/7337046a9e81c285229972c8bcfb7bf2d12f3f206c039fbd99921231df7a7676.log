        by_contra h_N_not_mem
        have h_aux : Disjoint N (sSup B) := by
          exact (J.sSupIndep.disjoint_sSup N.prop h_B₂ h_N_not_mem)
        have h_aux' : sSup B ≤ N := by
          calc
            sSup B ≤ A.val := by
              rw [h_B₁]
              <;> simp [le_rfl]
            _ ≤ N := by
              exact h_N_le_A
        have h_last : sSup B = (⊥ : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [h_B₁] at h_last
        have h₂ : A.val = ⊥ := by
          simp_all
        have h₃ : A.val ≠ ⊥ := by
          exact J.not_bot_mem A.prop
        contradiction
      have h_N_le_A_val : N ≤ A.val := le_trans (sSup_le _ h_B₂ h_mem) (le_rfl)
      have h_N_eq_A_val : N = A.val := by
        exact le_antisymm N.le h_N_le_A_val
      have h_contra : A.val ∈ I := by
        exact h_N_eq_A_val ▸ hN
      have h_final : A.val ∈ J := by
        have h₁ : A.val ∈ I := h_contra
        have h₂ : ∀ N ∈ I, N ∈ J := by
          intro N hN
          by_contra h_neg
          push_neg at h_neg
          aesop
        exact h₂ A.val h₁
      aesop
    have h₁ : I = J := by
      ext N
      simp only [Set.mem_setOf_eq]
      constructor <;> intro h <;> simp_all
    exact h₁

lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  intro N hN
  have h₁ : N ∈ D := hN
  refine' ⟨B N h₁, _, _⟩
  · -- Prove B N h₁ ⊆ refinement B hB hB' hB''
    intro X hX
    simp only [Set.mem_iUnion, exists_prop] at hX ⊢
    refine' ⟨N, h₁, _⟩
    simp_all
  · -- Prove N = sSup (B N h₁)
    have h₂ : N = sSup (B N h₁) := hB N h₁
    exact h₂

def ab_lt := by
  have h₁ : ∃ N, ∃ (hN : N ∈ D), B N hN ≠ {N} := H
  rcases h₁ with ⟨N, hN, h⟩
  have h₂ : N ∈ D := hN
  have h₃ : B N h₂ ≠ {N} := h
  have h₄ : D < refinement B hB hB' hB'' := by
    have h₅ : D ≤ refinement B hB hB' hB'' := refinement_le B hB hB' hB''
    have h₆ : ∃ N ∈ D, B N _ ≠ {N} := ⟨N, h₂, h₃⟩
    -- Use the fact that B N h₂ ≠ {N} to show that the refinement is strict
    have h₇ : D ≠ refinement B hB hB' hB'' := by
      intro h_eq
      have h₈ : N ∈ refinement B hB hB' hB'' := by
        rw [h_eq] at h₂
        exact h₂
      simp only [Refinement] at h₈
      -- Since N ∈ refinement B hB hB' hB'', there exists some M ∈ D and hM such that N ∈ B M hM
      have h₉ : N ∈ ⋃ (M : PersistenceSubmodule M) (_ : M ∈ D), B M ‹_› := h₈
      simp only [Set.mem_iUnion, exists_prop] at h₉
      rcases h₉ with ⟨M, hM, hMN⟩
      -- Since N ∈ B M hM, and B M hM ⊆ refinement B hB hB' hB'', we can use this to derive a contradiction
      have h₁₀ : B M hM ⊆ ⋃ (M : PersistenceSubmodule M) (_ : M ∈ D), B M ‹_› := by
        intro X hX
        refine' ⟨M, hM, _⟩
        simp_all
      have h₁₁ : B N h₂ = {N} := by
        by_contra h_ne
        have h₁₂ : B N h₂ ≠ {N} := h_ne
        simp_all
      simp_all [Set.ext_iff]
      <;> aesop
    -- Since D ≤ refinement B hB hB' hB'' and D ≠ refinement B hB hB' hB'', we have D < refinement B hB hB' hB''
    exact lt_of_le_of_ne h₅ (by intro h_eq; apply h₇; simp_all)
  exact h₄
