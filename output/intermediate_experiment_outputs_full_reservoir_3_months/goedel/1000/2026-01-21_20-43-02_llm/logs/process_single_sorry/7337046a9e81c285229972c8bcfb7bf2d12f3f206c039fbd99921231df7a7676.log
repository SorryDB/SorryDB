      "by\n  have h₁ : D ≤ refinement B hB hB' hB'' := refinement_le B hB hB' hB''\n  have h₂ : ¬(refinement B hB hB' hB'' ≤ D) := by\n    intro h₂\n    rcases H with ⟨N, hN, h_not_singleton⟩\n    have h₃ : N = sSup (B N hN) := hB N hN\n    have h₄ : sSupIndep (B N hN) := hB' N hN\n    have h₅ : ⊥ ∉ B N hN := hB'' N hN\n    have h₆ : B N hN ≠ {N} := h_not_singleton\n    -- Use the fact that B N hN is not a singleton to show that the refinement is not less than or equal to D\n    have h₇ : ∃ S ∈ (B N hN), S ≠ N := by\n      by_contra h\n      -- If every S in B N hN is equal to N, then B N hN is a singleton {N}, contradicting h₆\n      have h₈ : ∀ S ∈ B N hN, S = N := by\n        intro S hS\n        by_contra hS'\n        have h₉ : ∃ S ∈ (B N hN), S ≠ N := ⟨S, hS, hS'⟩\n        exact h h₉\n      have h₉ : B N hN ⊆ {N} := by\n        intro S hS\n        have h₁₀ : S = N := h₈ S hS\n        exact Set.mem_singleton_iff.mpr h₁₀\n      have h₁₀ : B N hN ≠ {N} := h₆\n      have h₁₁ : B N hN = {N} := by\n        apply Set.Subset.antisymm h₉\n        intro S hS\n        simp only [Set.mem_singleton_iff] at hS ⊢\n        have h₁₂ : S = N := by aesop\n        aesop\n      contradiction\n    -- Obtain a submodule S in B N hN that is not equal to N\n    rcases h₇ with ⟨S, hS, hS'⟩\n    have h₈ : S ∈ (refinement B hB hB' hB'').carrier := by\n      simp only [Set.mem_iUnion, (refinement B hB hB' hB'').carrier, Set.mem_setOf_eq]\n      refine' ⟨N, _⟩\n      refine' ⟨hN, _⟩\n      simp_all [Set.mem_setOf_eq]\n    have h₉ : S ∉ D.carrier := by\n      intro h₉\n      -- If S were in D, then since S ≤ N (because N = sSup (B N hN)), we would have a contradiction with the linear independence of B N hN\n      have h₁₀ : S ∈ D.carrier := h₉\n      have h₁₁ : S∈ D:=by simp_all [SetLike.mem_coe]\n      have h₁₂ : S ≤ N := by\n        have h₁₃ : S ≤ sSup (B N hN) := le_sSup_of_mem hS\n        have h₁₄ : N = sSup (B N hN) := h₃\n        rw [h₁₄] at *\n        exact h₁₃\n      have h₁₃ : sSupIn