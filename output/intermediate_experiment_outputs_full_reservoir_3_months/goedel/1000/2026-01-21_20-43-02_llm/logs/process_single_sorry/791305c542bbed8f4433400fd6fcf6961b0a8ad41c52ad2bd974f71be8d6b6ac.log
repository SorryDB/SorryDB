```lean
lemma intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro h
    -- Use the fact that the integral of the absolute value of r • f is bounded by the norm of r times the integral of the absolute value of f
    refine' (h.intervalIntegrable_of_dominated (fun x => ‖r‖ * ‖f x‖) (by
      intro x
      simp [norm_smul, IsBoundedSMul.leAssumption]
      <;>
      calc
        ‖r • f x‖ = ‖r‖ * ‖f x‖ := by
          simp [norm_smul]
        _ ≤ ‖r‖ * ‖f x‖ := le_refl _
    ) (by
      -- Use the fact that the integral of ‖r‖ * ‖f x‖ is finite
      have h₂ : IntervalIntegrable (fun x => ‖r‖ * ‖f x‖) μ a b := by
        -- Since ‖r‖ is a constant, the integral is ‖r‖ times the integral of ‖f x‖
        have h₃ : IntervalIntegrable (fun x => ‖f x‖) μ a b := h.norm
        have h₄ : IntervalIntegrable (fun x => ‖r‖ * ‖f x‖) μ a b := by
          -- Use the fact that multiplication by a constant preserves integrability
          apply IntervalIntegrable.mul_left
          exact h₃
        exact h₄
      -- The integral of ‖r‖ * ‖f x‖ is finite
      exact h₂
    ))
    <;>
    simp [norm_smul, IsBoundedSMul.leAssumption]
    <;>
    calc
      ‖r • f x‖ = ‖r‖ * ‖f x‖ := by simp [norm_smul]
      _ ≤ ‖r‖ * ‖f x‖ := le_refl _
  
  have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro h
    -- Use the fact that if r • f is interval integrable, then f is interval integrable
    by_cases hr : r = 0
    · -- If r = 0, then r • f = 0, which is trivially interval integrable
      have h₃ : r • f = fun x => 0 := by
        funext x
        simp [hr]
      have h₄ : IntervalIntegrable (r • f) μ a b := h
      rw [h₃] at h₄
      have h₅ : IntervalIntegrable (fun x => (0 : E)) μ a b := h₄
      have h₆ : IntervalIntegrable f μ a b := by
        -- Since 0 is interval integrable, f must also be interval integrable
        simp_all [intervalIntegrable_zero]
        <;>
        (try simp_all) <;>
        (try aesop) <;>
        (try norm_num) <;>
        (try linarith) <;>
        (try assumption) <;>
        (try contradiction)
        <;>
        (try
          {
            simp_all [intervalIntegrable_zero]
            <;>
            aesop
          })
      exact h₆
    · -- If r ≠ 0, use the fact that the inverse of r exists
      have h₃ : IsBoundedSMul R E := inferInstance
      have h₄ : IntervalIntegrable (r • f) μ a b := h
      have h₅ : IntervalIntegrable f μ a b := by
        -- Use the fact that multiplication by the inverse of r is bounded
        have h₆ : IntervalIntegrable (r • f) μ a b := h₄
        have h₇ : IntervalIntegrable ( (r⁻¹ : R) • (r • f)) μ a b := by
          -- Use the fact that multiplication by r⁻¹ is bounded
          refine' (h₆.intervalIntegrable_of_dominated (fun x => ‖r⁻¹‖ * ‖r • f x‖) (by
            intro x
            simp [norm_smul, IsBoundedSMul.leAssumption]
            <;>
            calc
              ‖(r⁻¹ : R) • (r • f x)‖ = ‖(r⁻¹ : R)‖ * ‖r • f x‖ := by
                simp [norm_smul]
              _ ≤ ‖(r⁻¹ : R)‖ * ‖r • f x‖ := le_refl _
          ) (by
            -- Use the fact that the integral of ‖r⁻¹‖ * ‖r • f x‖ is finite
            have h₈ : IntervalIntegrable (fun x => ‖(r⁻¹ : R)‖ * ‖r • f x‖) μ a b := by
              -- Since ‖r⁻¹‖ is a constant, the integral is ‖r⁻¹‖ times the integral of ‖r • f x‖
              have h₉ : IntervalIntegrable (fun x => ‖r • f x‖) μ a b := h₆.norm
              have h₁₀ : IntervalIntegrable (fun x => ‖(r⁻¹ : R)‖ * ‖r • f x‖) μ a b := by
                -- Use the fact that multiplication by a constant preserves integrability
                apply IntervalIntegrable.mul_left
                exact h₉
              exact h₁₀
            -- The integral of ‖r⁻¹‖ * ‖r • f x‖ is finite
            exact h₈
          ))
          <;>
          simp [norm_smul, IsBoundedSMul.leAssumption]
          <;>
          calc
            ‖(r⁻¹ : R) • (r • f x)‖ = ‖(r⁻¹ : R)‖ * ‖r • f x‖ := by simp [norm_smul]
            _ ≤ ‖(r⁻¹ : R)‖ * ‖r • f x‖ := le_refl _
        -- Simplify (r⁻¹ : R) • (r • f) to f
        have h₈ : (r⁻¹ : R) • (r • f) = f := by
          funext x
          simp [smul_smul, hr]
          <;>
          (try simp_all) <;>
          (try aesop) <;>
          (try norm_num) <;>
          (try linarith) <;>
          (try assumption) <;>
          (try contradiction)
          <;>
          (try
            {
              simp_all [hr]
              <;>
              aesop
            })
        -- Substitute (r⁻¹ : R) • (r • f) with f
        rw [h₈] at h₇
        exact h₇
      exact h₅
  
  exact ⟨h₁, h₂⟩
