theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h_main : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      intro hf
      haveI : IsBoundedSMul R E := inferInstance
      have h : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that scalar multiplication is bounded to deduce integrability.
        refine' (IsBoundedSMul.intervalIntegrable_smul _ _ _
          (by infer_instance : IsBoundedSMul R E) _)
        <;> simp_all [hf]
        <;> try norm_num
        <;> try linarith
      exact h
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      intro hf
      haveI : IsBoundedSMul R E := inferInstance
      have h : IntervalIntegrable f μ a b := by
        -- Use the fact that scalar multiplication is bounded to deduce integrability.
        by_cases hr : r = 0
        · -- If r = 0, then r • f = 0, and f can be deduced from the zero function.
          simp_all [hr, intervalIntegrable_zero]
          <;> try norm_num
          <;> try linarith
        · -- If r ≠ 0, use the boundedness to deduce the result.
          have h₁ : IsBoundedSMul R E := inferInstance
          have h₂ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
            -- Use the boundedness of the inverse scalar multiplication.
            refine' (IsBoundedSMul.intervalIntegrable_smul _ _ _
              (by infer_instance : IsBoundedSMul R E) _)
            <;> simp_all [hf]
            <;> try norm_num
            <;> try linarith
          have h₃ : r⁻¹ • (r • f) = f := by
            -- Simplify the scalar multiplication to get back f.
            ext x
            simp [hr, smul_smul]
            <;> field_simp [hr]
            <;> ring
          rw [h₃] at h₂
          exact h₂
      exact h
  exact h_main
