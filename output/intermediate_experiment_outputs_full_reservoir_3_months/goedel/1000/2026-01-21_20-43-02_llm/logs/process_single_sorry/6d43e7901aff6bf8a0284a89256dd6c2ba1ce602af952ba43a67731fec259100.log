/- Prove the following using the change of variables theorem. -/
lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₀ : ∫ x in 0..π, sin x * f (cos x) = ∫ x in 0..π, sin x * f (cos x) := rfl
  rw [h₀]
  -- Use the substitution u = cos x
  have h₁ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
    have h₂ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in (cos 0 : ℝ)..(cos π : ℝ), f y := by
      -- Apply the change of variables theorem
      have h₃ : ∫ x in 0..π, sin x * f (cos x) = ∫ x in 0..π, sin x * f (cos x) := rfl
      rw [h₃]
      -- Use the substitution u = cos x, du = -sin x dx
      have h₄ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in (cos 0 : ℝ)..(cos π : ℝ), f y := by
        -- Use the fundamental theorem of calculus and the chain rule
        have h₅ : ∫ x in 0..π, sin x * f (cos x) = ∫ x in (0 : ℝ)..π, sin x * f (cos x) := rfl
        rw [h₅]
        -- Use the substitution u = cos x, du = -sin x dx
        have h₆ : (∫ x in (0 : ℝ)..π, sin x * f (cos x)) = ∫ y in (cos 0 : ℝ)..(cos π : ℝ), f y := by
          -- Use the fundamental theorem of calculus and the chain rule
          rw [intervalIntegral.integral_comp_cos (fun x => f x)]
          <;> simp [cos_pi, cos_zero]
          <;> norm_num
          <;> ring_nf
          <;> simp_all [cos_pi, cos_zero]
          <;> norm_num
          <;> linarith
        rw [h₆]
      rw [h₄]
    rw [h₂]
    -- Simplify the bounds of the integral
    have h₅ : (cos 0 : ℝ) = 1 := by norm_num
    have h₆ : (cos π : ℝ) = -1 := by norm_num
    rw [h₅, h₆]
    -- Use the fact that the integral is the same as the integral from -1 to 1
    have h₇ : ∫ y in (1 : ℝ)..(-1 : ℝ), f y = ∫ y in (-1 : ℝ)..(1 : ℝ), f y := by
      -- Use the property of integrals to reverse the bounds
      rw [intervalIntegral.integral_symm]
      <;> simp [neg_neg]
      <;> ring_nf
      <;> simp_all
      <;> linarith
    rw [h₇]
  rw [h₁]
  
  <;>
  simp_all
  <;>
  linarith

