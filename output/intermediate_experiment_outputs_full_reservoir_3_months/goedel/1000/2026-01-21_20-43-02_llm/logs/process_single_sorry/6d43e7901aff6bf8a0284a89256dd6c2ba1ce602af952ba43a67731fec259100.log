      "\n  have h₁ : ∀ m n : ℕ, A m n = myA m n := by\n    intro m n\n    induction' m with m ih generalizing n\n    · -- Case: m = 0\n      intro n\n      induction' n with n ih'\n      · -- Subcase: n = 0\n        norm_num [A, myA]\n      · -- Subcase: n = n' + 1\n        simp_all [A, myA]\n        <;> simp_all [Nat.rec]\n        <;> rfl\n    · -- Case: m = m' + 1\n      intro n\n      induction' n with n ih'\n      · -- Subcase: n = 0\n        simp_all [A, myA]\n        <;> simp_all [Nat.rec]\n        <;> rfl\n      · -- Subcase: n = n' + 1\n        simp_all [A, myA]\n        <;> simp_all [Nat.rec]\n        <;> try simp_all [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm]\n        <;> try norm_num at *\n        <;> try simp_all [Nat.rec]\n        <;> try rfl\n        <;> try {\n          have h₂ := ih n\n          have h₃ := ih'\n          have h₄ := ih (n' + 1)\n          simp_all [Nat.rec]\n          <;> try simp_all [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm]\n          <;> try norm_num at *\n          <;> try simp_all [Nat.rec]\n          <;> try rfl\n        }\n  funext m n\n  exact h₁ m n",
