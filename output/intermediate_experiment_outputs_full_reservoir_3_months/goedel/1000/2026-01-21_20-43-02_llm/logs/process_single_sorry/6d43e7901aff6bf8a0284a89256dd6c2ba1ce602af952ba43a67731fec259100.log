lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₁ : (∫ x in 0..π, sin x * f (cos x)) = ∫ y in -1..1, f y := by
    have h₂ : ∫ x in 0..π, sin x * f (cos x) = -∫ x in 0..π, f (cos x) * (-sin x) := by
      congr
      ext x
      ring
    rw [h₂]
    have h₃ : ∫ x in 0..π, f (cos x) * (-sin x) = ∫ y in (cos (π)..cos (0 : ℝ)), f y := by
      have h₄ : ∫ x in 0..π, f (cos x) * (-sin x) = ∫ x in 0..π, (f ∘ cos) x * (-sin x) := by
        simp [Function.comp_apply]
      rw [h₄]
      -- Use the change of variables theorem
      have h₅ : ∫ x in 0..π, (f ∘ cos) x * (-sin x) = ∫ y in (cos (π)..cos (0 : ℝ)), f y := by
        have h₆ : ∫ x in 0..π, (f ∘ cos) x * (-sin x) = ∫ y in (cos (π)..cos (0 : ℝ)), f y := by
          -- Apply the change of variables theorem for the interval [0, π]
          have h₇ : ∫ x in 0..π, (f ∘ cos) x * (-sin x) = ∫ y in (cos (π)..cos (0 : ℝ)), f y := by
            rw [intervalIntegral.integral_comp_mul_left (fun x => f x) (by norm_num : (-1 : ℝ) ≠ 0)]
            <;> simp [cos_zero, cos_pi, mul_comm]
            <;> ring_nf
            <;> field_simp
            <;> ring_nf
            <;> norm_num
          rw [h₇]
        rw [h₆]
      rw [h₅]
    rw [h₃]
    -- Simplify the bounds of the integral
    have h₄ : cos (π : ℝ) = -1 := by norm_num
    have h₅ : cos (0 : ℝ) = 1 := by norm_num
    rw [h₄, h₅]
    <;> norm_num
    <;>
    (try norm_num) <;>
    (try ring_nf) <;>
    (try simp_all [intervalIntegral.integral_comp_mul_left]) <;>
    (try norm_num) <;>
    (try linarith [Real.pi_pos])
    <;>
    (try
      {
        simp_all [intervalIntegral.integral_comp_mul_left]
        <;> norm_num
        <;> linarith [Real.pi_pos]
      })
    <;>
    (try
      {
        simp_all [intervalIntegral.integral_comp_mul_left]
        <;> norm_num
        <;> linarith [Real.pi_pos]
      })
  rw [h₁]
  <;> simp_all
  <;> norm_num
  <;> linarith [Real.pi_pos]
