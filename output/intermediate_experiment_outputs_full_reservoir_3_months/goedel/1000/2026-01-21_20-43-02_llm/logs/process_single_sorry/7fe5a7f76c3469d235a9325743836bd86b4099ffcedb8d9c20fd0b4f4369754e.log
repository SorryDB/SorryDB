def kerLift (f : R →+* S) : R ⧸ ker f →+* S :=
  Ideal.Quotient.lift (ker f) f fun x hx ↦ by
  have : f x = 0 := by
    have : x ∈ ker f := hx
    rw [mem_ker] at this
    exact this
  simp [this]

theorem kerLift_mk (f : R →+* S) (x : R) : kerLift f (Ideal.Quotient.mk (ker f) x) = f x := by
  simp [kerLift]

theorem kerLift_injective' (f : R →+* S) (x : R ⧸ ker f) (hx : kerLift f x = 0) : x = 0 := by
  rcases Ideal.Quotient.mk_surjective x with ⟨x', hx'⟩
  rw [← hx']
  rw [← hx'] at hx
  have h₁ : f x' = 0 := by
    have h₂ : kerLift f (Ideal.Quotient.mk (ker f) x') = 0 := hx
    have h₃ : kerLift f (Ideal.Quotient.mk (ker f) x') = f x' := by
      apply kerLift_mk
    rw [h₃] at h₂
    exact h₂
  have h₂ : x' ∈ ker f := by
    rw [mem_ker]
    exact h₁
  have h₃ : Ideal.Quotient.mk (ker f) x' = 0 := Ideal.Quotient.eq_zero_of_mem h₂
  simpa using h₃
``` 

