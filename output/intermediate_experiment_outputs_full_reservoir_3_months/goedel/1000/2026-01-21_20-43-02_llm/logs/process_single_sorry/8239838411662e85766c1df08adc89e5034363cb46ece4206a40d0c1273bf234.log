```lean
def kerLift (f : R →+* S) : R ⧸ ker f →+* S :=
  Ideal.Quotient.lift (ker f) f fun x ↦ by
  intro h
  rw [← sub_eq_zero]
  have h₁ : f x = 0 := by
    have h₂ : x ∈ ker f := h
    simpa [mem_ker] using h₂
  have h₃ : f 0 = 0 := by
    exact f.map_zero
  simp [h₁, h₃, sub_self]
