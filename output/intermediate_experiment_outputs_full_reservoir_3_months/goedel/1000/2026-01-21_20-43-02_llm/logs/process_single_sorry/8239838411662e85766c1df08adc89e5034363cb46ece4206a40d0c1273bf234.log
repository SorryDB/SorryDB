def kerLift (f : R →+* S) : R ⧸ ker f →+* S :=
  Ideal.Quotient.lift (ker f) f fun x hx => by
  have h : f x = 0 := by
    -- Since x ∈ ker f, by the definition of the kernel, f(x) = 0.
    have h₁ : x ∈ ker f := hx
    have h₂ : f x = 0 := by
      rw [Ideal.mem_ker] at h₁
      exact h₁
    exact h₂
  -- Simplify the expression using the fact that f(x) = 0.
  simp_all [Ideal.Quotient.mk_eq_mk_iff_sub_mem]
  <;> aesop
