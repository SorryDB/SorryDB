def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    rintro x ⟨hx, hx'⟩ y ⟨hy, hy'⟩
    refine' ⟨I.add_mem hx hy, _⟩
    exact J.add_mem hx' hy'
  
  zero_mem' := by
    refine' ⟨I.zero_mem, J.zero_mem⟩
  
  smul_mem' := by
    intro r x ⟨hx, hx'⟩
    have h₁ : r • x ∈ I := I.smul_mem r hx
    have h₂ : r • x ∈ J := J.smul_mem r hx'
    exact ⟨h₁, h₂⟩
  
