      "\n  have h_main : IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) 𝔓' := by\n    have h1 : IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) 𝔓' := by\n      -- Use the fact that the measures are independent if the underlying processes are independent\n      have h2 : IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) 𝔓' := by\n        -- Use the independence of the reward processes for different actions\n        refine' IndepFun.comp_right _ (h.measurable_A) (h.measurable_R)\n        -- Use the fact that the reward processes for different actions are independent\n        <;> simp_all [indepFun_stepsUntil_of_ne', hab]\n        <;>\n          (try decide) <;>\n          (try {\n            refine' IndepFun.comp_right _ _ _\n            <;> simp_all [indepFun_stepsUntil_of_ne', hab]\n            <;>\n              (try decide) <;>\n              (try {\n                apply IndepFun.prod\n                <;> simp_all [indepFun_stepsUntil_of_ne', hab]\n              })\n          }) <;>\n          (try {\n            apply IndepFun.prod\n            <;> simp_all [indepFun_stepsUntil_of_ne', hab]\n          })\n      exact h2\n    exact h1\n  exact h_main",
