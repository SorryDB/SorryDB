lemma indepFun_rewardByCount_of_ne [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) {a b : α} (hab : a ≠ b) :
    IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) 𝔓' := by
  have h_main : IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) 𝔓' := by
    refine' IndepFun.map_left _ (IsAlgEnvSeq.measurable_rewardByCount _ _ _ _).measurableAe
    refine' IndepFun.prod_of_independent (iIndepFun_independent (iIndepFun_rewardByCount' h a)) (iIndepFun_independent (iIndepFun_rewardByCount' h b)) _
    exact fun i j ↦ by
      by_cases h₀ : i = j
      · -- If i = j, they are independent by the iIndepFun property.
        subst h₀
        exact independent_refl _
      · -- If i ≠ j, they are independent because the sets are disjoint.
        have h₁ : Set.InjOn (fun p : ℕ × ℕ => (p.1, p.2)) Set.univ := by
          intro ⟨i₁, j₁⟩ ⟨i₂, j₂⟩ h₂ h₃
          simp_all [Prod.ext_iff]
          <;> aesop
        have h₂ : (i, b) ≠ (j, a) := by
          intro h₃
          simp_all [Prod.ext_iff]
          <;> aesop
        apply independent_of_disjoint
        have h₃ : Disjoint (measurableSet_Icc : MeasurableSet (Icc i ⊓ Set.univ : Set ℕ)) (measurableSet_Icc : MeasurableSet (Icc j ⊓ Set.univ : Set ℕ)) := by
          simp [Disjoint, Set.Icc, Set.ext_iff] at h₀ ⊢
          <;>
          (try { contradiction }) <;>
          (try { omega }) <;>
          (try { aesop }) <;>
          (try { simp_all [Set.Icc, Set.ext_iff] }) <;>
          (try { omega })
          <;>
          (try { aesop })
        simp_all [Set.ext_iff, independent_iff_ae_eq_singleton]
        <;>
        (try { aesop }) <;>
        (try { simp_all [Set.Icc, Set.ext_iff] }) <;>
        (try { omega }) <;>
        (try { aesop })
  exact h_main
