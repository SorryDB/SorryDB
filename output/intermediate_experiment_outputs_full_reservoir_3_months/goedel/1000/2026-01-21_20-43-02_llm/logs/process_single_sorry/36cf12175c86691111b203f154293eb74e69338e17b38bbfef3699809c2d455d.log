    <;> simp_all [indepFun_iff]\n          exact h14\n        have h15 : IndepFun (fun ω : Ω × (ℕ → α → ℝ) ↦ R (s₁ - 1) ω.1) (fun ω : Ω × (ℕ → α → ℝ) ↦ A s₁ ω.1) 𝔓' := by\n          have h16 : IndepFun (R (s₁ - 1)) (A s₁) P := h10\n          have h17 : IndepFun (fun ω : Ω × (ℕ → α → ℝ) ↦ R (s₁ - 1) ω.1) (fun ω : Ω × (ℕ → α → ℝ) ↦ A s₁ ω.1) 𝔓' := by\n            apply h16.prod _\n            <;> simp_all [indepFun_iff]\n          exact h17\n        exact h15\n      have h18 : IndepFun (fun ω : Ω × (ℕ → α → ℝ) ↦ R (s₂ - 1) ω.1) (fun ω : Ω × (ℕ → α → ℝ) ↦ A s₂ ω.1) 𝔓' := by\n        have h19 : IndepFun (R (s₂ - 1)) (A s₂) P := by\n          have h20 : R (s₂ - 1) ⟂ᵢ[A (s₂ - 1), hA (s₂ - 1); P] A s₂ := by\n            have h21 := h.s Independence property for reward and action\n            simp_all [indepFun_iff]\n          have h22 : R (s₂ - 1) ⟂ᵢ[A (s₂ - 1), hA (s₂ - 1); P] A s₂ := h20\n          have h23 : IndepFun (R (s₂ - 1)) (A s₂) P := by\n            apply h22.of_measurable_left (hX := hA (s₂ - 1))\n            <;> simp_all [indepFun_iff]\n          exact h23\n        have h24 : IndepFun (fun ω : Ω × (ℕ → α → ℝ) ↦ R (s₂ - 1) ω.1) (fun ω : Ω × (ℕ → α → ℝ) ↦ A s₂ ω.1) 𝔓' := by\n          have h25 : IndepFun (R (s₂ - 1)) (A s₂) P := h19\n          have h26 : IndepFun (fun ω : Ω × (ℕ → α → ℝ) ↦ R (s₂ - 1) ω.1) (fun ω : Ω × (ℕ → α → ℝ) ↦ A s₂ ω.1) 𝔓' := by\n            apply h25.prod _\n            <;> simp_all [indepFun_iff]\n          exact h26\n        exact h24\n      have h27 : IndepFun (fun ω ↦ rewardByCount A R a s₁ ω) (fun ω ↦ rewardByCount A R b s₂ ω) 𝔓' := by\n        sorry\n      exact h27\n    have h3 : IndepFun (fun ω s => rewardByCount A R a s ω) (fun ω s => rewardByCount A R b s ω) 𝔓' := by\n      sorry\n    exact h3\n  exact h1",
