theorem kerLift_injective' (f : R →+* S) (x : R ⧸ ker f) (hx : kerLift f x = 0) : x = 0 := by
  rcases Ideal.Quotient.mk_surjective x with ⟨x', hx'⟩
  rw [← hx']
  rw [← hx'] at hx
  have hx'' : kerLift f (Ideal.Quotient.mk (ker f) x') = 0 := hx
  have h₁ : kerLift f (Ideal.Quotient.mk (ker f) x') = f x' := by
    apply kerLift_mk
  rw [h₁] at hx''
  have h₂ : f x' = 0 := hx''
  have h₃ : x' ∈ ker f := by
    rw [mem_ker]
    exact h₂
  have h₄ : Ideal.Quotient.mk (ker f) x' = 0 := by
    rw [Ideal.Quotient.eq_zero_iff_mem]
    exact h₃
  rw [h₄]
  <;> simp [hx']
  <;> aesop

