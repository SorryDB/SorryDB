```lean
def firstIsomorphismTheorem (f : R →+* S) (hf : Function.Surjective f) :
    R ⧸ ker f ≃+* S :=
  { toFun := kerLift f
    invFun x := Ideal.Quotient.mk (ker f) (surjInv hf x)
    right_inv := rightInverse_surjInv hf
    map_mul' := by
      intro x y
      have h1 : kerLift f (x * y) = (kerLift f x) * (kerLift f y) := by
        -- Use the fact that `kerLift` is a ring homomorphism
        have h2 : kerLift f = Ideal.Quotient.lift (ker f) f (by
          intro x hx
          simp_all [Ideal.mem_ker]
          ) := rfl
        rw [h2]
        -- Use the property of the lift map to show that it respects multiplication
        simp_all [Ideal.Quotient.map_mul]
        <;>
        (try simp_all [Ideal.Quotient.eq_zero_iff_mem])
        <;>
        (try simp_all [Ideal.mem_ker])
        <;>
        (try ring_nf)
        <;>
        (try simp_all [mul_assoc])
        <;>
        (try simp_all [mul_comm])
        <;>
        (try simp_all [mul_left_comm])
      exact h1
  }
