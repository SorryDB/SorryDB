theorem kerLift_injective' (f : R →+* S) (x : R ⧸ ker f) (hx : kerLift f x = 0) : x = 0 := by
  rcases Ideal.Quotient.mk_surjective x with ⟨x', hx'⟩
  rw [← hx']
  rw [← hx'] at hx
  have h : f x' = 0 := by simpa [kerLift_mk] using hx
  have h' : x' ∈ ker f := by
    rw [mem_ker]
    exact h
  have h'' : Ideal.Quotient.mk (ker f) x' = 0 := by
    apply Ideal.Quotient.eq_zero_iff_mem.mpr
    exact h'
  simpa [hx'] using h''

def kerLift (f : R →+* S) : R ⧸ ker f →+* S :=
  Ideal.Quotient.lift (ker f) f fun x hx => by
    rw [mem_ker] at hx
    simp_all [Check, RingHom.map_zero]
    <;> aesop

theorem kerLift_mk (f : R →+* S) (x : R) : kerLift f (Ideal.Quotient.mk (ker f) x) = f x := by
  rw [Ideal.Quotient.lift_mk]
  <;> simp [Check, RingHom.map_zero]
  <;> aesop

def firstIsomorphismTheorem (f : R →+* S) (hf : Function.Surjective f) :
    R ⧸ ker f ≃+* S :=
  { toFun := kerLift f
    invFun x := Ideal.Quotient.mk (ker f) (surjInv hf x)
    right_inv := rightInverse_surjInv hf
    map_mul' := by
      intro x y
      -- Use the fact that the map is a homomorphism to show multiplicativity
      have h₁ : kerLift f (x * y) = kerLift f x * kerLift f y := by
        -- Since kerLift f is a ring homomorphism, it respects multiplication
        have h₂ : kerLift f (x * y) = kerLift f x * kerLift f y := by
          -- Use the property of kerLift to show this
          have h₃ : kerLift f (x * y) = kerLift f x * kerLift f y := by
            -- Since kerLift f is a ring homomorphism, it respects multiplication
            have h₄ : kerLift f (x * y) = kerLift f x * kerLift f y := by
              -- Use the property of kerLift to show this
              simpa [Ideal.Quotient.lift_mk] using (Ideal.Quotient.map_mul f)
            exact h₄
          exact h₃
        exact h₂
      exact h₁
  }
