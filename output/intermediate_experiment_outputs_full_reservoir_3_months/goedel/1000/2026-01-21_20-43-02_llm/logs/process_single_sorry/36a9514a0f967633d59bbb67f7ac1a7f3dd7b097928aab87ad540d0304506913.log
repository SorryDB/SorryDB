lemma locally_classD_of_locally_classDL [OrderBot ι] [TopologicalSpace ι] [OrderTopology ι]
  [MeasurableSpace ι]
    (hX : Locally (fun x => @ClassDL ι Ω E _ _ _ _ _ _ _ _ x 𝓕 P) 𝓕 X P) (hファッション : 𝓕.IsRightContinuous) :
    Locally (fun x => @ClassD ι Ω E _ _ _ _ _ _ _ _ x 𝓕 P) 𝓕 X P := by
  -- Step 1: Extract the local base from the hypothesis
  rcases hX with ⟨B, hB, b, hb⟩
  -- Step 2: Use the local base to construct a local base for ClassD
  refine' ⟨B, hB, b, _⟩
  -- Step 3: Show that each element in the local base is in ClassD
  have h : @ClassDL ι Ω E _ _ _ _ _ _ _ _ (X ∘ b) 𝓕 P := hb
  have h₁ : @ClassD ι Ω E _ _ _ _ _ _ _ _ (X ∘ b) 𝓕 P := by
    -- Step 4: Convert ClassDL to ClassD using the right-continuity of the filtration
    exact h.rightContinuous_classD
  simpa using h₁
