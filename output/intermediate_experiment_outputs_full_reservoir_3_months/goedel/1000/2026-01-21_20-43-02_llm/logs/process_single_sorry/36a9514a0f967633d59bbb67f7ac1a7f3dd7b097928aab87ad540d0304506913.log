lemma locally_classD_of_locally_classDL [OrderBot ι] [TopologicalSpace ι] [OrderTopology ι]
  [MeasurableSpace ι]
    (hX : Locally (ClassDL · 𝓕 P) 𝓕 X P) (h𝓕 : 𝓕.IsRightContinuous) :
    Locally (ClassD · 𝓕 P) 𝓕 X P := by
  rw [locally_to_crit_fam_iff] at hX ⊢
  refine' fun i s hs ↦ ?
  have h1 : ∃ (t : ι), i < t := by
    use i + 1
    <;> simp [lt_add_iff]
  obtain ⟨t, ht⟩ := h1
  have h2 := hX t (s ∩ {ω | i < t}) (hs.mono (by intro ω hω; simp_all [Set.mem_inter_iff]))
  have h3 : ClassDL (X ∘ (fun ω ↦ i) : ι → Ω → E) 𝓕 P := by
    exact h2
  have h4 : ClassD (X ∘ (fun ω ↦ i) : ι → Ω → E) 𝓕 P := by
    -- Use the fact that a ClassDL process is also ClassD
    have h5 : ClassD (X ∘ (fun ω ↦ i) : ι → Ω → E) 𝓕 P := by
      -- Prove that the constant process is ClassD
      simpa [ClassD] using h3.of_is_const
    exact h5
  simpa [Function.comp] using h4
