### Solution

```lean
theorem locally_classD_of_locally_classDL [OrderBot ι] [TopologicalSpace ι] [OrderTopology ι]
  [MeasurableSpace ι]
    (hX : Locally (ClassDL · 𝓕 P) 𝓕 X P) (h𝑓 : 𝓕.IsRightContinuous) :
    Locally (ClassD · 𝓕 P) 𝓕 X P := by
  have h' : ∀ t : ι, ClassD X 𝓕 P := by
    intro t
    have h₁ : ClassDL X 𝓕 P := by
      have h₂ := hX.exists (IicIndexOrder 𝓕.increasing) fun s hs => fun t ht => by
        refine' hs.trans ht
      obtain ⟨s, hs, H⟩ := h₂
      have h₃ : ClassDL X 𝓕 P := H
      exact h₃
    have h₂ : ClassD X 𝓕 P := h₁.1
    exact h₂
  refine' ⟨⊤, IocIndexOrder.mono_left (by simp_all [le_refl]), ?_, ?_⟩
  · filter_upwards with ω
    have h₂ := h' (⊥ : ι)
    simp_all [classD_iff]
  · filter_upwards with ω
    have h₂ := h' (⊥ : ι)
    simp_all [classD_iff]
```  
