lemma solsInclQuadSols_injective (χ : ACCSystem) :
    Function.Injective ⇑(ACCSystem.solsInclQuadSols χ) := by
  intro S T h
  have h₁ : S.toQuadSols = T.toQuadSols := by simpa using h
