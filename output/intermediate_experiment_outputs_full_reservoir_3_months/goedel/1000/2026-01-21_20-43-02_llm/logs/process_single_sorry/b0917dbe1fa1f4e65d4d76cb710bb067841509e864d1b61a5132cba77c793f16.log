  have hS₀ : S.Nonempty := ⟨1, hS₁⟩
  have hSA : S ⊆ A⁻¹ * A := filter_subset ..
  have hSsymm : S⁻¹ = S := by
    apply Finset.ext
    intro g
    simp only [Finset.mem_inv, Finset.mem_filter, Finset.mem_univ, true_and]
    constructor
