      have h₁ : (A⁻¹ * A : Finset G).card ≤ K * A.card := by
        -- Since A² has cardinality ≤ K * |A|, then A⁻¹ * A has the same cardinality
        have h₂ : (A ^ 2 : Finset G).card = (A⁻¹ * A : Finset G).card := by
          calc
            (A ^ 2 : Finset G).card = (A * A : Finset G).card := by simp [pow_two]
            _ = (A⁻¹ * A : Finset G).card := by
              -- A * A and A⁻¹ * A have the same cardinality because inversion is a bijection
              apply Finset.card_bij (fun (x : G) _ => x⁻¹)
              <;> simp_all [Finset.mem_product, mul_left_inj, mul_right_inj, inv_inv]
              <;>
                (try aesop) <;>
                (try
