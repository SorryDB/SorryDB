          -- The cardinality of A⁻¹ * A is less than or equal to the cardinality of A².
          calc
            (A⁻¹ * A : Finset G).card ≤ (A⁻¹ * A : Finset G).card := le_refl _
            _ ≤ (A ^ 2 : Finset G).card := by
              -- We need to show that |A⁻¹ * A| ≤ |A²|.
              -- This can be done by considering the map (a⁻¹, a) ↦ a⁻¹ * a.
