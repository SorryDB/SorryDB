      (try simp_all [Finset.card_image_of_injective, Function.Injective]) <;>
      (try omega)
      <;>
      (try norm_num) <;>
      (try linarith)
  have hScard := calc
    (#S : ℝ) ≤ #(A⁻¹ * A) := by
