                    use a⁻¹ <;>
                    simp_all [mul_assoc, mul_left_inj, mul_right_inj, inv_inv]
                  })
              <;>
                aesop
            _ = (A⁻¹ * A : Finset G).card := by rfl
        -- Use the given bound on |A²|
        have h₃ : (A ^ 2 : Finset G).card ≤ K * A.card := by
          exact_mod_cast hA
        have h₄ : (A⁻¹ * A : Finset G).card ≤ K * A.card := by
          linarith
        exact h₄
      -- Since K ≥ 1, K² ≥ K, so K * |A| ≤ K² * |A|
      have h₂ : (K : ℝ) ≥ 1 := by exact_mod_cast hK
      have h₃ : (K : ℝ) ^ 2 ≥ K := by
        nlinarith
      have h₄ : (A⁻¹ * A : Finset G).card ≤ K ^ 2 * A.card := by
