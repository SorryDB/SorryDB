open scoped Classical in
lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor <;> 
  (try simp_all [iSup, iSup_eq_iSupi]) <;>
  (try {
    simp_all [iSup, iSup_eq_iSupi]
    <;>
    exact ⟨fun p => p.1.coe, fun p => p.1.right⟩
  }) <;>
  (try {
    have h₁ : ⨆ p ∈ I, p c = ⊤ := by
      -- Use the given property that the supremum of the decomposition equals the top element
      have h₂ : ⨆ p ∈ I, p c = (⨆ p ∈ I, p) c := by
        simp [iSup_coe_sort]
      rw [h₂]
      have h₃ : (⨆ p ∈ I, p) = ⊤ := by
        -- Since the supremum of the submodules in I is the top element
        have h₄ : sSup (I : Set (PersistenceSubmodule M)) = ⊤ := I.sSup_eq_top'
        have h₅ : (⨆ p ∈ I, p : PersistenceSubmodule M) = sSup (I : Set (PersistenceSubmodule M)) := by
          simp [sSup]
        rw [h₅]
        exact h₄
      rw [h₃]
      <;> simp
    -- Use the fact that the supremum of the decomposition equals the top element
    have h₂ : ⨆ (p : I), (p : PersistenceSubmodule M) c = ⊤ := by
      simpa using h₁
    simpa [iSup] using h₂
  }) <;>
  (try {
