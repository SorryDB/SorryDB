```lean
lemma pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h₁ : sSup (SetLike.coe D) = ⊤ := sSup_eq_top D
  have h₂ : (⨆ p ∈ D, p x : Submodule K (M.obj x)) = ⊤ := by
    calc
      (⨆ p ∈ D, p x : Submodule K (M.obj x)) = ⨆ p : D, (p : PersistenceSubmodule M) x := by
        simp [SetLike.mem_coe] <;>
        rw [show (⨆ p ∈ (D : Set (PersistenceSubmodule M)), p x) = ⨆ p : D, (p : PersistenceSubmodule M) x by
          {
            apply iSup_congr
            intro p
            simp [SetLike.mem_coe]
          }
        ]
      _ = ⨆ p : D, (p : PersistenceSubmodule M) x := rfl
      _ = (⨆ p : D, (p : PersistenceSubmodule M)) x := by
        {
          rw [iSup_submodule]
          <;>
          simp [SetLike.mem_coe]
          <;>
          exact fun p q h => by simpa [SetLike.mem_coe] using h
        }
      _ = (sSup (SetLike.coe D)) x := by
        {
          simp [sSup_eq_iSup]
          <;>
          simp [SetLike.mem_coe]
          <;>
          congr 1 <;>
          ext <;>
          simp [SetLike.mem_coe]
          <;>
          aesop
        }
      _ = ⊤ := by
        {
          rw [h₁]
          <;>
          simp
        }
  exact h₂
