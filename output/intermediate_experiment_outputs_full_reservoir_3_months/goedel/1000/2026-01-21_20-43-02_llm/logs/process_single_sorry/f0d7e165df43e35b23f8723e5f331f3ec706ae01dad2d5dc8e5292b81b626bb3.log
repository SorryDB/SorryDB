lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor <;>
    (try simp_all [DirectSumDecomposition.sSupIndep, DirectSumDecomposition.sSup_eq_top]) <;>
    (try
      {
        have h₁ : sSupIndep (SetLike.coe I) := I.sSupIndep'
        have h₂ : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
        simpa [SetLike.coe_eq] using h₁
      }) <;>
    (try
      {
        have h₃ : ⨆ p ∈ I, p c = ⊤ := by
          have h₄ : (⨆ p ∈ I, p c) = (sSup (SetLike.coe I)) c := by
            simp [SetLike.sSup_coe, iSup_setOf]
            <;>
            (try rfl)
            <;>
            (try simp_all [SetLike.coe_eq])
            <;>
            (try aesop)
          have h₅ : (sSup (SetLike.coe I)) = (⊤ : PersistenceSubmodule M) := by
            rw [I.sSup_eq_top']
            <;>
            (try simp_all [SetLike.coe_eq])
            <;>
            (try aesop)
          rw [h₄, h₅]
          <;>
          (try simp_all [SetLike.coe_eq])
          <;>
          (try aesop)
          <;>
          (try simp [Submodule.top_coe])
          <;>
          (try rfl)
        have h₄ : (⨆ p : I, (p : PersistenceSubmodule M) c) = ⊤ := by
          calc
            (⨆ p : I, (p : PersistenceSubmodule M) c) = (⨆ p ∈ (I : Set (PersistenceSubmodule M)), p c) := by
              simp [SetLike.iSup_coe]
            _ = ⊤ := h₃
        simpa [SetLike.coe_eq] using h₄
      })
