    have h₃ : sSup (SetLike.coe D) = ⊤ := sSup_eq_top D
    have h₄ : sSup (SetLike.coe D) = ⨆ p ∈ D, p := by
      simp [sSup]
    rw [h₄] at h₃
    exact h₃
  rw [h₂]
  <;> simp

lemma pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h₁ : ⨆ p ∈ D, p x = (⨆ p ∈ D, p) x := by
    simp [iSup_coe_sort]
    <;>
    apply iSup_congr
    <;> simp_all [SetLike.coe_mk]
    <;>
    aesop
  rw [h₁]
  have h₂ : (⨆ p ∈ D, p) = ⊤ := by
    have h₃ : sSup (SetLike.coe D) = ⊤ := sSup_eq_top D
    have h₄ : sSup (SetLike.coe D) = ⨆ p ∈ D, p := by
      simp [sSup]
    rw [h₄] at h₃
    exact h₃
  rw [h₂]
  <;> simp

open scoped Classical in
lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor
  · -- Prove iSupIndep
    have h : sSupIndep (Set.range (fun p : I ↦ (p : PersistenceSubmodule M))) := by
      have h₁ : sSupIndep (I : Set (PersistenceSubmodule M)) := I.sSupIndep'
      have h₂ : (I : Set (PersistenceSubmodule M)) = Set.range (fun p : I ↦ (p : PersistenceSubmodule M)) := by
        ext x
        simp [SetLike.mem_coe]
        <;>
        aesop
      rw [h₂] at h₁
      exact h₁
    have h₁ : sSupIndep (Set.range (fun p : I ↦ (p.val : Submodule K (M.obj c)))) := by
      have h₂ : sSupIndep (Set.range (fun p : I ↦ (p : PersistenceSubmodule M))) := h
      have h₃ : sSupIndep (Set.range (fun p : I ↦ (p.val : Submodule K (M.obj c)))) := by
        -- Use the fact that the direct sum decomposition is independent to show that the submodules at each point are independent
        have h₄ : Set.range (fun p : I ↦ (p.val : Submodule K (M.obj c))) = (Set.range (fun p : I ↦ (p : PersistenceSubmodule M))).image (fun p : PersistenceSubmodule M ↦ p c) := by
          ext x
          simp [Set.mem_image]
          <;>
          aesop
        rw [h₄]
        -- Use the fact that the image of an independent set under a morphism is independent
        have h₅ : sSupIndep (Set.range (fun p : I ↦ (p : PersistenceSubmodule M))) := h₂
        have h₆ : sSupIndep ((Set.range (fun p : I ↦ (p : PersistenceSubmodule M))).image (fun p : PersistenceSubmodule M ↦ p c)) := by
          apply sSupIndep.image
          exact h₅
        exact h₆
      exact h₃
    -- Use the fact that the submodules at each point are independent to show that the family of submodules is independent
    have h₂ : sSupIndep (Set.range (fun p : I ↦ (p.val : Submodule K (M.obj c)))) := h₁
    simpa [Set.range] using h₂
  · -- Prove iSup_eq_top
    have h₁ : ⨆ (p : I), (p.val : Submodule K (M.obj c)) = ⊤ := by
      have h₂ : ⨆ p ∈ (I : Set (PersistenceSubmodule M)), p c = ⊤ := pointwise_iSup_eq_top I c
      have h₃ : (⨆ p ∈ (I : Set (PersistenceSubmodule M)), p c) = ⨆ (p : I), (p.val : Submodule K (M.obj c)) := by
        simp [SetLike.coe_mk]
        <;>
        simp_all [iSup_coe_sort]
        <;>
        congr 1
        <;>
        ext
        <;>
        simp_all [SetLike.coe_mk]
        <;>
        aesop
      rw [h₃] at h₂
      exact h₂
    -- Use the fact that the supremum of the submodules at each point is the entire space to show that the family of submodules spans the entire space
    have h₂ : ⨆ (p : I), (p.val : Submodule K (M.obj c)) = ⊤ := h₁
    simpa [Set.range] using h₂
``` 

### Explanation

1. **`pointwise_iSup_eq_top` and `pointwise_sSup_eq_top`**: These lemmas show that the pointwise supremum of the submodules in a direct sum decomposition equals the entire space at each point `c : C`. This is done by leveraging the fact that the supremum of the entire set of submodules is `⊤` (`sSup_eq_top`), and then evaluating this at each point.

2. **`isInternal`**: This lemma is more involved. We need to prove two things:
   - **iSupIndep**: The family of submodules `(p.val : Submodule K (M.obj c))` for `p : I` is independent. This follows from the independence of the original set of submodules and the fact that the image of an independent set under a morphism (here, evaluation at `c`) remains independent.
   - **iSup_eq_top**: The supremum of these submodules is `⊤`. This follows directly from `pointwise_iSup_eq_top` by rewriting the supremum in terms of the pointwise supremum of the original decomposition.

### Detailed Proof

1. **iSupIndep**:
   - The original set `I` is independent (`sSupIndep I.carrier`).
   - The set `I` can be seen as the range of the function `fun p : I ↦ (p : PersistenceSubmodule M)`.
   - The submodules at each point are obtained by taking the image of `I` under the evaluation map `p ↦ p c`.
   - Since the image of an independent set under a morphism is independent, the submodules at each point are independent.

2. **iSup_eq_top**:
   - The pointwise supremum of `I` at `c` is `⊤` (`pointwise_iSup_eq_top`).
   - This pointwise supremum is equal to the supremum of `(p.val : Submodule K (M.obj c))` for `p : I`.
   - Hence, the supremum of the submodules is `⊤`.

This completes the proof that `isInternal` holds for `fun p : I ↦ p.val c`. 

