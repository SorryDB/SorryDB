    simp_all [h₁]
    <;> norm_num at *
    <;> try contradiction
    <;> try norm_num
    <;> try linarith
  simp_all [h₁, h₂]
  <;> norm_num
  <;> try contradiction
  <;> try norm_num
  <;> try linarith
