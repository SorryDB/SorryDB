    ∃ c > 0, ∀ᶠ n in atTop, (2 : ℝ)^(2 : ℝ)^(c * n) ≤ hypergraphRamsey 3 n := by
  have h₁ : answer(sorry) = (False : Prop) := by manifest
  have h₂ : (∃ c > (0 : ℝ), ∀ᶠ (n : ℕ) in atTop, (2 : ℝ) ^ (2 : ℝ) ^ (c * n : ℝ) ≤ (hypergraphRamsey 3 n : ℝ)) = (False : Prop) := by
    by_contra h
    have h₃ : (∃ c > (0 : ℝ), ∀ᶠ (n : ℕ) in atTop, (2 : ℝ) ^ (2 : ℝ) ^ (c * n : ℝ) ≤ (hypergraphRamsey 3 n : ℝ)) := by simpa using h
    -- This part is actually impossible because hypergraphRamsey 3 n grows much faster than 2^(2^(c*n))
