      "\n  <;> simp_all [as_projective_niels]\n  <;> norm_num\n  <;>\n  (try\n    {\n      aesop\n    })\n  <;>\n  (try\n    {\n      rfl\n    })\n  <;>\n  (try\n    {\n      norm_num [Field51_as_Nat, p]\n      <;>\n      ring_nf\n      <;>\n      simp_all [Field51]\n      <;>\n      norm_num\n      <;>\n      aesop\n    })\n  <;>\n  (try\n    {\n      simp_all [Field51_as_Nat, p]\n      <;>\n      norm_num [Field51_as_Nat, p]\n      <;>\n      ring_nf\n      <;>\n      simp_all [Field51]\n      <;>\n      norm_num\n      <;>\n      aesop\n    })",
