  have h₂ : x 0 = ClassicalMechanics.HarmonicOscillator.InitialConditions.x₀ IC := h.2.1
  have h₃ : Time.deriv x 0 = ClassicalMechanics.HarmonicOscillator.InitialConditions.v₀ IC := h.2.2
