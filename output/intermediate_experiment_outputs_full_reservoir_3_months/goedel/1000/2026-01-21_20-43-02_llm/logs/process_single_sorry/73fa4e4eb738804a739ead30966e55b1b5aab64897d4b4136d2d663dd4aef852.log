      have h₆ : HasDerivAt (fun t : ℝ => (cos (S.ω * t) : ℝ)) (-S.ω * sin (S.ω * (t : ℝ))) (t : ℝ) := by
        convert h₂ using 1 <;> simp [mul_assoc]
      have h₇ : HasDerivAt (fun t : ℝ => (cos (S.ω * t) : ℝ) • (IC.x₀ : ℝ →L[ℝ] (Space 1))) ((-S.ω * sin (S.ω * (t : ℝ))) • (IC.x₀ : ℝ →L[ℝ] (Space 1))) (t : ℝ) := by
