lemma identDistrib_rewardByCount_stream_all [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) :
    IdentDistrib (fun ω (p : α × ℕ) ↦ rewardByCount A R p.1 (p.2 + 1) ω)
      (fun ω p ↦ ω p.2 p.1) 𝔓' (Bandit.streamMeasure ν) := by
  refine IdentDistrib.pi (fun p ↦ ?_) ?_ ?_
  · refine identDistrib_rewardByCount_eval h p.1 (p.2 + 1) p.2 (by simp) (ν := ν)
  · exact iIndepFun_rewardByCount h
  · have h1 : iIndepFun (fun (p : α × ℕ) (ω : Ω × (ℕ → α → ℝ)) ↦ (ω.2 p.2) p.1) 𝔓' := by
      have h2 : ∀ (p : α × ℕ), Measurable (fun (ω : Ω × (ℕ → α → ℝ)) ↦ (ω.2 p.2) p.1) := by
        intro p
        apply (Measurable.prod_mk measurable_fst).comp
        apply Measurable.comp (measurable_pi_apply _)
        exact (measurable_snd).ext
      rw [iIndepFun_iff]
      intro S T φs ψs φ ψ hS hT hs ht hφs hps hφ ψps
      have h3 : Measurable (fun ω : Ω × (ℕ → α → ℝ) ↦ ω.2) := by
        apply Measurable.prod_mk
        <;> simp_all [measurable_snd]
      have h4 : Measurable (fun ω : Ω × (ℕ → α → ℝ) ↦ ω.1) := by
        apply Measurable.prod_mk
        <;> simp_all [measurable_fst]
      have h5 : Measurable (fun ω : Ω × (ℕ → α → ℝ) ↦ (ω.2)) := by
        apply Measurable.prod_mk
        <;> simp_all [measurable_snd]
      have h6 : IsFiniteMeasure 𝔓' := by
        apply Product.isFiniteMeasure
        <;> simp_all [P.isFiniteMeasure, StationaryEnv.isFiniteMeasure]
      have h7 : Disjoint (S : Set (Ω × (ℕ → α → ℝ))) T := by
        simp_all [Set.disjoint_left]
        <;> aesop
      simp_all [Set.disjoint_left, Measure.disjoint_iff]
      <;> aesop
    simpa [prod.exists_iff] using h1
