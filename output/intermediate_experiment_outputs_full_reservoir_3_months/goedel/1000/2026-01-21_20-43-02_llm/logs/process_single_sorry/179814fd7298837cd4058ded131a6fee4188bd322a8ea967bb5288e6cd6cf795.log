namespace LeanBandits.Bandit
variable {α : Type} [DecidableEq α] [StandardBorelSpace α] [Nonempty α]
  {R : Type} [DecidableEq R] [StandardBorelSpace R] [Nonempty R]
  (A : ℕ → α) (R : ℕ → R) {P : Measure α} [IsProbabilityMeasure P]
  {ν : Kernel α R} [IsMarkovKernel ν]
  {h : IsAlgSeq A R alg (stationarySeq ν) P}

def streamMeasure : Measure (ℕ → α → R) :=
  Measure.infinitePi fun n ↦ Measure.infinitePi ν

def productStreamMeasure : Measure (α × (ℕ → α → R)) :=
  P.Fubini (streamMeasure)

lemma hasLaw_Z (a : α) (m : ℕ) :
  HasLaw (fun ω : α × (ℕ → α → R) ↦ ω.2 m a) (ν a) productStreamMeasure where
  aemeasurable := by
    apply Measurable.aemeasurable
    apply Measurable.comp (m := MeasurableSpace.toMeasurableSpace (Π _ : ℕ, α → R))
      (h := (measurable_snd.comp (measurable_fst : Measurable (fun p : α × (ℕ → α → R) ↦ p.2))))
      (m := MeasurableSpace.toMeasurableSpace (α → R))
        (m := MeasurableSpace.toMeasurableSpace R)
      (measurable_fintype.eval _).comp (measurable_snd.comp (measurable_fst : Measurable (fun p : α × (ℕ → α → R) ↦ p.2)))
