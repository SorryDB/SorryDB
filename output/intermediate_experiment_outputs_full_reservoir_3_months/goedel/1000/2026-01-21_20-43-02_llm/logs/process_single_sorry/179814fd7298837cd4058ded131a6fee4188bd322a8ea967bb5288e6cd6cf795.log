      <;> try norm_num
      <;> try aesop
      <;> try simp_all [Pi.instDecidableEq]
      <;> try norm_num
      <;> try aesop
  map_eq := by
    calc (productStreamMeasure).map (fun ω : α × (ℕ → α → R) ↦ ω.2 m a)
      = ((P.Fubini (streamMeasure))).map (fun ω : α × (ℕ → α → R) ↦ ω.2 m a) := rfl
      _ = (streamMeasure).map (fun ω : ℕ → α → R ↦ ω m a) := by
        rw [Measure.map_map (by fun_prop) (by fun_prop)]
        simp [Measure.fst, Measure.snd, prod_snd]
        <;> aesop
      _ = (Measure.infinitePi fun n ↦ Measure.infinitePi ν).map (fun ω ↦ ω m) := by
        simp [streamMeasure]
        <;>
        congr 1 <;>
        ext ω <;>
        congr 1 <;>
        ext a <;>
        rfl
      _ = (Measure.infinitePi ν).map (fun ω ↦ ω a) := by
        simp [Measure.map_map (by fun_prop) (by fun_prop), infinitePi_apply]
        <;>
        simp_all [Function.comp]
        <;>
        aesop
      _ = ν a := by
        simp [StreamMeasure.hasLaw]

abbrev banditMeasure : Measure (α × (ℕ → α → R)) := productStreamMeasure

abbrev banditMeasure' : Measure (α × (ℕ → α → R)) :=
  (P.Fubini (streamMeasure))

def transitionKernel (n : ℕ) (x : α × (List R × ℕ → α → R)) : Kernel (α × (List R × ℕ → α → R)) (α × (List R × ℕ → α → R)) :=
  1

def constraint (n : ℕ) (x : α × (List R × ℕ → α → R)) : Set (α × (List R × ℕ → α → R)) :=
  Set.univ

def hasLaw (n : ℕ) (x : α × (List R × ℕ → α → R)) : HasLaw (fun ω : α × (List R × ℕ → α → R) ↦ ω.2 n x.1) (ν x.1) banditMeasure' where
  aemeasurable := by
    apply Measurable.aemeasurable
    apply Measurable.comp (m := MeasurableSpace.toMeasurableSpace (List R × ℕ → α → R))
      (h := (measurable_snd.comp (measurable_fst : Measurable (fun p : α × (List R × ℕ → α → R) ↦ p.2))))
