    [Fintype őĻ] [Nontrivial k] {S : Set P} {y : P} (h : y ‚ąą affineSpan k S) :
    ‚ąÉ w : őĻ ‚Üí k, (‚ąĎ i : őĻ, w i = 1) ‚ąß (y = Finset.affineCombination k Finset.univ (fun i : őĻ => (y : P)) w) := by
  classical
  have h‚āĀ : y ‚ąą affineSpan k (Set.Icc y y) := by
