  have h‚āĄ : ‚ąÉ (w : őĻ ‚Üí k), (‚ąĎ i : őĻ, w i = 1) ‚ąß y = Finset.affineCombination k Finset.univ (fun i : őĻ => (y : P)) w := by
    -- Use the fact that the affine span of a singleton set is the set itself
    -- and the sum of weights can be set to 1.
