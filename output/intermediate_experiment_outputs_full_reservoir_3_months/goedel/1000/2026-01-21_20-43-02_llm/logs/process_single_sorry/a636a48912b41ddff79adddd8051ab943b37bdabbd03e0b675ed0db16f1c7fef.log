theorem Ex_1_24 : ∀ {M : Type*} [Zero M] [One M] [SMul ℕ M],
    (∀ a b : M, (a + b) ^ 2 = a ^ 2 + 2 * a * b + b ^ 2) →
    Subsingleton M := by
  intro M _ _ _ h
  refine ⟨fun a b => _⟩
  have h₁ : a = b := by
    have h₂ : (a + (b - a)) ^ 2 = a ^ 2 + 2 * a * (b - a) + (b - a) ^ 2 := by
      · -- Expand the square of (a + (b - a))
        simpa [add_assoc] using h a (b - a)
      <;>
      (try simp_all [add_assoc, add_left_comm, add_comm]) <;>
      (try ring_nf at * <;> simp_all [sub_eq_add_neg]) <;>
      (try norm_num) <;>
      (try nlinarith)
    have h₃ : (a + (b - a)) ^ 2 = b ^ 2 := by
      · -- Simplify (a + (b - a))^2 to b^2
        simp [add_assoc, add_sub_cancel]
        <;>
        (try simp_all [add_assoc, add_left_comm, add_comm]) <;>
        (try ring_nf at * <;> simp_all [sub_eq_add_neg]) <;>
        (try norm_num) <;>
        (try nlinarith)
    have h₄ : a ^ 2 + 2 * a * (b - a) + (b - a) ^ 2 = b ^ 2 := by
      · -- Equate the two expressions for the square
        linarith
    have h₅ : a = b := by
      · -- Simplify the equation to find a = b
        have h₆ := h a (b - a)
        have h₇ := h₄
        simp [add_assoc, add_sub_cancel] at h₆ h₇ ⊢
        <;>
        (try simp_all [add_assoc, add_left_comm, add_comm]) <;>
        (try ring_nf at * <;> simp_all [sub_eq_add_neg]) <;>
        (try norm_num) <;>
        (try nlinarith) <;>
        (try {
          -- Use the given condition to derive a contradiction unless a = b
          simp_all [add_assoc, add_left_comm, add_comm]
          <;>
          ring_nf at *
          <;>
          simp_all [sub_eq_add_neg]
          <;>
          norm_num at *
          <;>
          nlinarith
        })
    exact h₅
  -- Since a = b, we have shown that M is subsingleton
  exact h₁
