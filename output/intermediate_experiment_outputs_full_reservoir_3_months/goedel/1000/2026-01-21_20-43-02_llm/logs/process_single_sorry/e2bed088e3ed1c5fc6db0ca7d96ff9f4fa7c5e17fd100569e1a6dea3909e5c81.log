      "\n  have h₁ : (P.initial.a.map (·.factorization p)).sum ≤ P.M * Real.log P.n := by\n    have h₂ : ∀ (m : ℕ), m ∈ (P.initial.a : Multiset ℕ) → (m.factorization p : ℕ) ≤ Real.log (P.n : ℝ) := by\n      intro m hm\n      have h₃ : m ∈ (P.initial.a : Multiset ℕ) := hm\n      have h₄ : m ∈ Filter (fun m : ℕ => m ∈ (P.n / P.L).smoothNumbers) (join (replicate P.M (Ico (P.n - P.n / P.M) P.n))) := by\n        simp_all [Params.initial]\n      have h₅ : m ∈ (P.n / P.L).smoothNumbers := by\n        simp_all [Multiset.mem_filter]\n      have h₆ : m ≠ 0 := by\n        have h₇ : m ∈ (P.n / P.L).smoothNumbers := by simp_all [Multiset.mem_filter]\n        have h₈ : m ≠ 0 := (mem_smoothNumbers.mp h₇).1\n        exact h₈\n      have h₇ : (m.factorization p : ℕ) ≤ Real.log (P.n : ℝ) := by\n        -- Use the fact that m is smooth to bound the exponent\n        have h₈ : (m.factorization p : ℕ) ≤ 1 := by\n          have h₉ : p.Prime := p.Prime\n          have h₁₀ : m < (P.n : ℕ) := by\n            have h₁₁ : m ∈ (P.n / P.L).smoothNumbers := by simp_all [Multiset.mem_filter]\n            have h₁₂ : (m : ℕ) < (P.n : ℕ) := (mem_smoothNumbers.mp h₁₁).2\n            exact_mod_cast h₁₂\n          have h₁₁ : (m : ℕ) ≤ (P.n : ℕ) := by linarith\n          have h₁₂ : (m : ℕ) > 0 := by\n            have h₁₃ : m ≠ 0 := by\n              have h₁₄ : m ∈ (P.n / P.L).smoothNumbers := by simp_all [Multiset.mem_filter]\n              exact (mem_smoothNumbers.mp h₁₄).1\n            omega\n          have h₁₃ : (m.factorization p : ℕ) ≤ 1 :=\n            if p.Prime then\n              have h₁₄ : (m.factorization p : ℕ) ≤ 1 := by\n                by_contra h₁₅\n                have h₁₆ : (m.factorization p : ℕ) ≥ 2 := by\n                  omega\n                have h₁₇ : p ^ 2 ∣ m := by\n                  have h₁₈ : p ^ (m.factorization p) ∣ m := by\n                    exact\n                      calc\n                        p ^ (m.factorization p) = p ^ (m.factorization p) := rfl\n              