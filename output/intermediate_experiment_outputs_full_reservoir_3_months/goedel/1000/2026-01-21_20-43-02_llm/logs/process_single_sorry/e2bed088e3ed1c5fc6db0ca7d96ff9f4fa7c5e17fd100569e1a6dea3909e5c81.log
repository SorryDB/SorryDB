      "\n  have h₁ : (P.initial.a.map (·.factorization p)).sum ≤ (P.M * Real.log P.n : ℤ) := by\n    have h₂ : (P.initial.a.map (·.factorization p)).sum ≤ (P.M * Real.log P.n : ℤ) := by\n      have h₃ : (P.initial.a.map (·.factorization p)).sum ≤ 0 := by\n        have h₄ : (P.initial.a.map (·.factorization p)).sum = 0 := by\n          simp only [Params.initial, Multiset.map_map, Multiset.sum_map,\n            Multiset.sum_replicate, Nat.cast_zero, zero_mul]\n          <;> rfl\n        linarith\n      have h₅ : (P.M * Real.log P.n : ℝ) ≥ 0 := by\n        have h₆ : (P.M : ℝ) ≥ 1 := by\n          norm_cast\n          <;> have h₇ := P.hL_pos\n          <;> have h₈ : P.M ≥ 1 := by\n            by_contra h\n            have h₉ : P.M = 0 := by omega\n            simp_all [P]\n          <;> omega\n        have h₇ : (Real.log P.n : ℝ) ≥ 0 := by\n          have h₈ : (P.n : ℝ) ≥ 1 := by\n            norm_cast\n            <;> have h₉ : P.n ≥ 1 := by\n              by_contra h\n              have h₁₀ : P.n = 0 := by omega\n              have h₁₁ := P.hL\n              simp_all [P]\n              <;> nlinarith\n            <;> omega\n          exact Real.log_nonneg (by\n            norm_num at h₈ ⊢ <;>\n            linarith)\n        have h₈ : (P.M : ℝ) * (Real.log P.n : ℝ) ≥ 0 := by positivity\n        exact_mod_cast h₈\n      have h₉ : (0 : ℤ) ≤ (P.M * Real.log P.n : ℤ) := by\n        exact_mod_cast h₅\n      have h₁₀ : (P.initial.a.map (·.factorization p)).sum ≤ (P.M * Real.log P.n : ℤ) := by\n        have h₁₁ : (P.initial.a.map (·.factorization p)).sum ≤ 0 := h₃\n        have h₁₂ : (0 : ℤ) ≤ (P.M * Real.log P.n : ℤ) := h₉\n        linarith\n      exact h₁₀\n    exact h₂\n  \n  simp only [Factorization.balance, Factorization.sum] at *\n  <;> norm_cast at *\n  <;> simp_all [Int.cast_le]\n  <;> linarith",
      "\n  have h₁ : (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log (P.n : ℝ) := by sorry\n  have h₂ : (P.initial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log (P.n : ℝ) := by\n    have h₃ : (P.initial.a.map (·.factorization p)).sum ≤ (P.n.factorial.factorization p : ℕ) := by sorry\n    have h₄ : (P.n.factorial.factorization p : ℕ) ≤ P.n := by sorry\n    have h₅ : (P.M : ℕ) * (P.n : ℕ) ≤ (P.M : ℕ) * (P.n : ℕ) := by sorry\n    norm_cast at h₃ h₄ h₅ ⊢\n    <;>\n    (try norm_num) <;>\n    (try linarith) <;>\n    (try\n      {\n        simp_all [Factorization.balance, Factorization.sum, Real.log_le_sub_one_of_pos,\n          Real.log_lt_iff_lt_exp, Real.log_pow]\n        <;>\n        (try norm_num) <;>\n        (try linarith) <;>\n        (try nlinarith)\n      })\n    <;>\n    (try\n      {\n        simp_all [Factorization.balance, Factorization.sum, Real.log_le_sub_one_of_pos,\n          Real.log_lt_iff_lt_exp, Real.log_pow]\n        <;>\n        (try norm_num) <;>\n        (try linarith) <;>\n        (try nlinarith)\n      })\n  exact_mod_cast h₂",
