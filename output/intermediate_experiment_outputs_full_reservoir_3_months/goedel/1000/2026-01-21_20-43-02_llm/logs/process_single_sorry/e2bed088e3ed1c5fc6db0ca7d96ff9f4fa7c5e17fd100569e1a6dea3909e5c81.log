      "\n  have h₁ : (P.initial.a.map (·.factorization p)).sum ≤ P.M * (P.n) := by\n    calc\n      (P.initial.a.map (·.factorization p)).sum\n        = (P.initial.a.map (·.factorization p)).sum := rfl\n      _ ≤ P.M * (P.n) := by\n        have h₂ : (P.initial.a.map (·.factorization p)).sum ≤ (P.n .factorization p : ℕ) := by\n          -- Use the fact that the sum of valuations in the factorial is the factorial's valuation\n          simp_all [Factorization.sum]\n          <;>\n          (try norm_num) <;>\n          (try aesop) <;>\n          (try omega)\n          <;>\n          (try\n            {\n              have h₃ : (P.n.factorization p : ℕ) = (P.n.factorization p : ℕ) := rfl\n              simp_all [Factorization.sum, h₃]\n              <;>\n              norm_num <;>\n              aesop\n            }\n          )\n        have h₃ : (P.n.factorization p : ℕ) ≤ P.M * (P.n) := by\n          -- The factorial's valuation is at most M * n\n          have h₄ : (P.n.factorization p : ℕ) = (P.n.factorization p : ℕ) := rfl\n          have h₅ : (P.n.factorization p : ℕ) ≤ P.M * (P.n) := by\n            calc\n              (P.n.factorization p : ℕ) ≤ P.n := by\n                -- The valuation of any prime in n! is at most n\n                have h₆ : (P.n.factorization p : ℕ) ≤ P.n := by\n                  have h₇ : (P.n.factorization p : ℕ) = (P.n.factorization p : ℕ) := rfl\n                  calc\n                    (P.n.factorization p : ℕ) ≤ (P.n.factorization p : ℕ) := le_refl _\n                    _ ≤ P.n := by\n                      -- Use the fact that the sum of valuations in the factorial is the factorial's valuation\n                      have h₈ : (P.n.factorization p : ℕ) ≤ P.n := by\n                        -- The valuation of any prime in n! is at most n\n                        have h₉ : (P.n.factorization p : ℕ) ≤ P.n := by\n                          calc\n                            (P.n.factorization p : ℕ) ≤ (P.n.factorization p : ℕ) := le_refl _\n                            _ ≤ P.n := by\n                              -- Use the fact that the sum of valuations in the factorial is the factorial's valuation\n                              exact (Nat.le_of_lt_succ (by\n                                have h₁₀ : (P.n.factorization p : ℕ) < P.n.succ := by\n                                  -- The valuation of any prime in n! is at most n\n                                  have h₁₁ : (P.n.factorization p : ℕ) < P.n.succ := by\n                                    -- The valuation of any prime in n! is at most n\n                                    simp_all [Nat.factorization_eq_zero_iff]\n                                    <;>\n                                    omega\n                                  exact h₁₁\n                                omega\n                              ))\n                        exact h₉\n                      exact h₈\n                exact h₆\n              _ ≤ P.M * (P.n) := by\n                -- M ≥ 1, so M * n ≥ n\n                have h₁₀ : P.M ≥ 1 := by\n                  -- M ≥ 1\n                  norm_num [Params] at P ⊢ <;> nlinarith\n                have h₁₁ : (P.n : ℕ) ≥ 0 := by\n                  -- n ≥ 0\n                  norm_num [Params] at P ⊢ <;> nlinarith\n                nlinarith\n          exact h₅\n        -- Combine the inequalities\n        have h₄ : (P.initial.a.map (·.factorization p)).sum ≤ P.M * (P.n) := by\n          calc\n            (P.initial.a.map (·.factorization p)).sum ≤ (P.n.factorization p : ℕ) := h₂\n            _ ≤ P.M * (P.n) := h₃\n        exact h₄\n  have h₂ : (P.n.factorial.factorization p : ℕ) ≤ P.n := by\n    -- The factorial's valuation is at most n\n    have h₃ : (P.n.factorial.factorization p : ℕ) ≤ P.n := by\n      calc\n        (P.n.factorial.factorization p : ℕ) ≤ (P.n.factorial.factorization p : ℕ) := le_refl _\n        _ ≤ P.n := by\n          -- Use the fact that the sum of valuations in the factorial is the factorial's valuation\n          have h₄ : (P.n.factorial.factorization p : ℕ) ≤ P.n := by\n            -- The valuation of any prime in n! is at most n\n            have h₅ : (P.n.factorial.factorization p : ℕ) ≤ P.n := by\n              calc\n                (P.n.factorial.factorization p : ℕ) ≤ (P.n.factorial.factorization p : ℕ) := le_refl _\n                _ ≤ P.n := by\n                  -- Use the fact that the sum of valuations in the factorial is the factorial's valuation\n                  exact (Nat.le_of_lt_succ (by\n                    have h₆ : (P.n.factorial.factorization p : ℕ) < P.n.succ := by\n                      -- The valuation of any prime in n! is at most n\n                      have h₇ : (P.n.factorial.factorization p : ℕ) < P.n.succ := by\n                        -- The valuation of any prime in n! is at most n\n                        simp_all [Nat.factorization_eq_zero_iff]\n                        <;>\n                        omega\n                      exact h₇\n                    omega\n                  ))\n            exact h₅\n          exact h₄\n    exact h₃\n  have h₃ : (P.M : ℝ) * Real.log (P.n : ℝ) ≥ 0 := by\n    have h₄ : (P.M : ℝ) ≥ 1 := by\n      norm_cast\n      <;>\n      (try\n        {\n          norm_num [Params] at P ⊢ <;>\n          (try omega) <;>\n          (try nlinarith)\n        }) <;>\n      (try\n        {\n          have h₅ := P.hL_pos\n          have h₆ := P.hL\n          norm_num [Params] at P ⊢ <;>\n          (try omega) <;>\n          (try nlinarith)\n        })\n    have h₅ : Real.log (P.n : ℝ) ≥ 0 := by\n      apply Real.log_nonneg\n      norm_cast\n      <;>\n      (try\n        {\n          norm_num [Params] at P ⊢ <;>\n          (try omega) <;>\n          (try nlinarith)\n        }) <;>\n      (try\n        {\n          have h₆ := P.hL_pos\n          have h₇ := P.hL\n          norm_num [Params] at P ⊢ <;>\n          (try omega) <;>\n          (try nlinarith)\n        })\n    have h₆ : (P.M : ℝ) * Real.log (P.n : ℝ) ≥ 0 := by\n      nlinarith\n    exact h₆\n  -- Combine the results to get the final inequality\n  have h₄ : (P.initial.balance p : ℤ) ≤ (P.M : ℤ) * (Real.log (P.n : ℝ)) := by\n    simp_all [Factorization.balance, Factorization.sum, Int.cast_le]\n    <;>\n    (try norm_num) <;>\n    (try linarith) <;>\n    (try\n      {\n        have h₅ : (P.M : ℝ) * Real.log (P.n : ℝ) ≥ 0 := by\n          positivity\n        linarith\n      }\n    ) <;>\n    (try\n      {\n        have h₅ : (P.M : ℝ) ≥ 1 := by\n          norm_cast\n          <;>\n          (try omega) <;>\n          (try nlinarith)\n        have h₆ : Real.log (P.n : ℝ) ≥ 0 := by\n          apply Real.log_nonneg\n          norm_cast\n          <;>\n          (try omega) <;>\n          (try nlinarith)\n        have h₇ : (P.M : ℝ) * Real.log (P.n : ℝ) ≥ 0 := by\n          nlinarith\n        linarith\n      }\n    )\n    <;>\n    (try\n      {\n        norm_num at *\n        <;>\n        (try linarith) <;>\n        (try nlinarith)\n      }\n    )\n  -- Convert the result to the desired form\n  norm_cast at h₄ ⊢\n  <;>\n  (try linarith) <;>\n  (try\n    {\n      simp_all [Int.cast_le]\n      <;>\n      (try norm_num) <;>\n      (try linarith)\n    }\n  ) <;>\n  (try\n    {\n      norm_num at *\n      <;>\n      (try linarith) <;>\n      (try nlinarith)\n    }\n  )",
      "\n  have h₁ : (P.initial.a.map (·.factorization p)).sum = 0 := by sorry\n  simp_all [Factorization.balance]\n  <;>\n  norm_cast\n  <;>\n  ring_nf\n  <;>\n  simp_all [Real.log_one]\n  <;>\n  positivity",
      "\n        apply Real.log_nonneg\n        norm_cast\n        <;>\n        (try omega) <;>\n        (try\n          {\n            have h₂ : P.n ≥ 1 := by\n              by_contra h₂\n              have h₃ : P.n = 0 := by omega\n              simp_all [Params, hL_pos, hL]\n              <;> nlinarith\n            omega\n          })\n      have h₂ : (P.M : ℝ) ≥ 1 := by\n        norm_cast\n        <;>\n        (try omega) <;>\n        (try\n          {\n            have h₃ : P.M ≥ 1 := by\n              by_contra h₃\n              have h₄ : P.M = 0 := by omega\n              simp_all [Params, hL_pos, hL]\n              <;> nlinarith\n            omega\n          })\n      nlinarith [Real.log_le_sub_one_of_pos (by positivity : (0 : ℝ) < P.n)]\n    }) <;>\n  (try\n    {\n      have h₁ : 0 ≤ Real.log (P.n : ℝ) := by\n        apply Real.log_nonneg\n        norm_cast\n        <;>\n        (try omega) <;>\n        (try\n          {\n            have h₂ : P.n ≥ 1 := by\n              by_contra h₂\n              have h₃ : P.n = 0 := by omega\n              simp_all [Params, hL_pos, hL]\n              <;> nlinarith\n            omega\n          })\n      have h₂ : (P.M : ℝ) ≥ 1 := by\n        norm_cast\n        <;>\n        (try omega) <;>\n        (try\n          {\n            have h₃ : P.M ≥ 1 := by\n              by_contra h₃\n              have h₄ : P.M = 0 := by omega\n              simp_all [Params, hL_pos, hL]\n              <;> nlinarith\n            omega\n          })\n      nlinarith [Real.log_le_sub_one_of_pos (by positivity : (0 : ℝ) < P.n)]\n    })",
      "\n        -- Use the fact that the log of the factorial is less than or equal to n times the log of n\n        calc\n          Real.log (n.factorial : ℝ) ≤ (n : ℝ) * Real.log n := h₇\n          _ ≤ (f'.a.card : ℝ) * Real.log n := by\n            -- Use the fact that the number of elements in the factorization is at most n\n            have h₁₀ : 0 ≤ Real.log n := by\n              -- Prove that the log of n is non-negative\n              have h₁₁ : (1 : ℝ) ≤ n := by\n                have h₁₂ : n ≠ 0 := by\n                  by_contra h₁₃\n                  simp_all [Factorization]\n                  <;> omega\n                have h₁₃ : (n : ℝ) ≥ 1 := by\n                  norm_cast\n                  <;> omega\n                linarith",
      "\n  have h₁ : (P.initial.a.map (·.factorization p)).sum ≤ (P.M : ℕ) * (Real.log P.n).toNat := by\n    calc\n      (P.initial.a.map (·.factorization p)).sum\n      _ = (P.initial.a.map (·.factorization p)).sum := rfl\n      _ ≤ (P.M : ℕ) * (Real.log P.n).toNat := by\n        sorry\n        <;>\n        (try norm_num) <;>\n        (try simp_all [Multiset.sum_const, Multiset.card_map, *]) <;>\n        (try norm_cast) <;>\n        (try ring_nf at *) <;>\n        (try linarith)\n        <;>\n        (try omega)\n        <;>\n        (try\n          {\n            have h₂ := P.hL_pos\n            have h₃ := P.hL\n            norm_num at h₂ h₃ ⊢\n            <;>\n            (try linarith)\n            <;>\n            (try omega)\n          })\n        <;>\n        (try\n          {\n            have h₂ := P.hL_pos\n            have h₃ := P.hL\n            norm_num at h₂ h₃ ⊢\n            <;>\n            (try linarith)\n            <;>\n            (try omega)\n          })\n        <;>\n        (try\n          {\n            have h₂ := P.hL_pos\n            have h₃ := P.hL\n            norm_num at h₂ h₃ ⊢\n            <;>\n            (try linarith)\n            <;>\n            (try omega)\n          })\n        <;>\n        (try\n          {\n            have h₂ := P.hL_pos\n            have h₃ := P.hL\n            norm_num at h₂ h₃ ⊢\n            <;>\n            (try linarith)\n            <;>\n            (try omega)\n          })\n  have h₂ : (P.M : ℕ) * (Real.log P.n).toNat ≤ (P.M : ℕ) * (Real.log P.n).toNat := by rfl\n  have h₃ : (P.M : ℝ) * Real.log P.n = (P.M : ℕ) * (Real.log P.n) := by\n    norm_cast\n    <;> simp [mul_comm]\n    <;> ring_nf\n    <;> norm_num\n  have h₄ : (P.M : ℕ) * (Real.log P.n).toNat ≤ (P.M : ℕ) * (Real.log P.n).toNat := by rfl\n  simp_all [Factorization.balance, Factorization.sum]\n  <;>\n  (try norm_cast) <;>\n  (try simp_all [Nat.cast_mul, Nat.cast_ofNat]) <;>\n  (try linarith) <;>\n  (try omega)",
