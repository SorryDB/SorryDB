try omega)\n            have : (n : ℕ) > 0 := by\n              have : P.n > P.L * P.L := P.hL\n              have : (1 : ℕ) < P.L := by\n                nlinarith\n              nlinarith\n            -- M is at least 1 because it is a positive integer.\n            have : P.M ≥ 1 := by\n              by_contra h\n              have : P.M = 0 := by omega\n              simp_all [Nat.div_eq_of_lt]\n              <;>\n              (try omega) <;>\n              (try linarith) <;>\n              (try simp_all [Nat.div_eq_of_lt]) <;>\n              (try norm_num)\n              <;>\n              (try omega)\n            exact this\n          exact_mod_cast this\n        have h₅ : (P.M : ℝ) * (Real.log (P.n : ℝ)) ≥ 0 := by\n          have h₅₁ : (P.M : ℝ) ≥ 1 := h₄\n          have h₅₂ : (Real.log (P.n : ℝ)) ≥ 0 := h₃\n          have h₅₃ : (P.M : ℝ) * (Real.log (P.n : ℝ)) ≥ 1 * (Real.log (P.n : ℝ)) := by\n            nlinarith\n          have h₅₄ : 1 * (Real.log (P.n : ℝ)) = Real.log (P.n : ℝ) := by ring\n          have h₅₅ : (P.M : ℝ) * (Real.log (P.n : ℝ)) ≥ Real.log (P.n : ℝ) := by linarith\n          nlinarith\n        nlinarith [h₃]\n      })\n  exact h₇",
      "\n  have h₁ : P.M ≥ 0 := by sorry\n  have h₂ : Real.log (P.n : ℝ) ≥ 0 := by sorry\n  have h₃ : P.initial.balance p ≤ P.M * Real.log (P.n : ℝ) := by sorry\n  exact h₃",
      "and `L > 0`. The initial factorization removes elements not `n",
      "\n  have h_main : (P.initial.a.map (·.factorization p)).sum = 0 := by\n    have h₁ : (P.initial.a.map (·.factorization p)).sum = 0 := by\n      -- Prove that the sum of the factorizations of p in the initial factors is zero\n      have h₂ : ∀ (m : ℕ), m ∈ P.initial.a → m.factorization p = 0 := by\n        intro m hm\n        -- Each m in the initial factors is in the smooth numbers, so it cannot have any prime factors > L\n        have h₃ : m ∈ (P.n / P.L).smoothNumbers := by\n          simp only [Factorization.mem_a, Params.initial, Multiset.mem_filter, Multiset.mem_join,\n            Multiset.mem_replicate] at hm\n          -- Extract the smoothness condition from the membership in the filtered list\n          obtain ⟨⟨_, ⟨_, rfl⟩, hsmooth⟩, _⟩ := hm\n          exact hsmooth\n        -- Since m is smooth, its prime factors are ≤ L\n        have h₄ : m.factorization p = 0 := by\n          by_cases h₅ : p.Prime\n          · -- If p is prime, then if p ∣ m, p ≤ L\n            by_cases h₆ : p ∣ m\n            · -- If p ∣ m, then p ≤ L because m is smooth\n              have h₇ : p ≤ P.n / P.L := by\n                have h₈ : p ∈ m.factors := by\n                  rw [mem_factors] <;> aesop\n                  <;> simp_all [h₅]\n                  <;> omega\n                have h₉ : p ∣ m := by\n                  simpa [Nat.mem_factors] using h₈\n                have h₁₀ : p ≤ P.n / P.L := by\n                  have h₁₁ : m ∈ (P.n / P.L).smoothNumbers := h₃\n                  have h₁₂ : p ≤ P.n / P.L := by\n                    simp_all [Nat.mem_smoothNumbers]\n                    <;> aesop\n                  exact h₁₂\n                exact h₁₀\n              have h₁₁ : (p : ℕ) > Real.sqrt P.n := by\n                have h₁₂ : (p : ℕ) > Real.sqrt P.n := by\n                  have h₁₃ : (p : ℝ) ≤ Real.sqrt P.n := by\n                    exact hp\n                  have h₁₄ : Real.sqrt P.n < (p : ℝ) := by\n                    -- This is a contradiction because p ≤ sqrt(n) and p > sqrt(n) cannot both be true\n                    have h₁₅ : (p : ℝ) ≤ Real.sqrt P.n := by exact_mod_cast hp\n                    have h₁₆ : Real.sqrt P.n < (p : ℝ) := by\n                      -- This is a contradiction because p ≤ sqrt(n) and p > sqrt(n) cannot both be true\n                      norm_num at h₁₅ ⊢ <;>\n                      (try contradiction) <;>\n                      (try nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : 0 ≤ (P.n : ℝ))])\n                    linarith\n                  linarith\n                linarith\n              -- This leads to a contradiction because p ≤ sqrt(n) and p > sqrt(n) cannot both be true\n              linarith\n            · -- If p does not divide m, then the factorization of p in m is zero\n              have h₇ : m.factorization p = 0 := by\n                simp_all [Nat.factorization_eq_zero_iff]\n                <;> aesop\n              exact h₇\n          · -- If p is not prime, then the factorization of p in m is zero\n            have h₇ : m.factorization p = 0 := by\n              simp_all [Nat.factorization_eq_zero_iff]\n              <;> aesop\n            exact h₇\n        exact h₄\n      -- The sum of the factorizations of p in the initial factors is zero\n      have h₅ : (P.initial.a.map (·.factorization p)).sum = 0 := by\n        calc\n          (P.initial.a.map (·.factorization p)).sum = (P.initial.a.map (·.factorization p)).sum := rfl\n          _ = 0 := by\n            -- Use the fact that each factorization is zero\n            have h₆ : ∀ (m : ℕ), m ∈ P.initial.a → m.factorization p = 0 := h₂\n            have h₇ : (P.initial.a.map (·.factorization p)).sum = 0 := by\n              calc\n                (P.initial.a.map (·.factorization p)).sum = (P.initial.a.map (fun x => 0)).sum := by\n                  apply Multiset.sum_congr rfl\n                  intro x hx\n                  rw [h₆ x hx]\n                _ = 0 := by simp\n            exact h₇\n      exact h₅\n    exact h₁\n  \n  have h_fact : (P.n.factorial).factorization p ≤ P.M * (Real.log P.n) := by\n    norm_cast at hp ⊢\n    <;>\n    (try omega) <;>\n    (try nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : 0 ≤ (P.n : ℝ))]) <;>\n    (try {\n      have h₁ : (p : ℝ) ≤ Real.sqrt P.n := by exact_mod_cast hp\n      have h₂ : (p : ℝ) ^ 2 ≤ (P.n : ℝ) := by\n        nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : 0 ≤ (P.n : ℝ))]\n      norm_num at h₁ h₂ ⊢ <;>\n      (try contradiction) <;>\n      (try nlinarith)\n    })\n    <;>\n    (try {\n      have h₁ : (p : ℝ) > Real.sqrt P.n := by\n        have h₂ : (p : ℝ) ≤ Real.sqrt P.n := by exact_mod_cast hp\n        have h₃ : Real.sqrt P.n < (p : ℝ) := by\n          norm_num at h₂ ⊢ <;>\n          (try contradiction) <;>\n          (try nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : 0 ≤ (P.n : ℝ))])\n        linarith\n      norm_num at h₁ ⊢ <;>\n      (try contradiction) <;>\n      (try nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : 0 ≤ (P.n : ℝ))])\n    })\n  \n  have h_bound : (P.initial.a.map (·.factorization p)).sum ≤ (P.n.factorial).factorization p := by\n    simp_all [Factorization.sum]\n    <;>\n    (try norm_num) <;>\n    (try linarith)\n  \n  have h_final : P.initial.balance p ≤ P.M * (Real.log P.n) := by\n    simp_all [Factorization.balance, Factorization.sum]\n    <;>\n    (try norm_num) <;>\n    (try linarith)\n    <;>\n    (try nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : 0 ≤ (P.n : ℝ))])\n  \n  simpa using h_final",
      "\n  have h₁ : (P\tinitial.a.map (·.factorization p)).sum ≤ P.n := by\n    calc (P.initial.a.map (·.factorization p)).sum ≤ (Multiset.join (Multiset.replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n))).sum := by\n      need : P.initial.a ≤ Multiset.join (Multiset.replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)) := by\n        simp only [Factorization, Multiset.filter_subset]\n        <;>\n        simp [Finset.subset_iff, Multiset.mem_filter, Multiset.mem_join, Multiset.mem_replicate,\n          forall_and]\n        <;>\n        aesop\n      calc_le (P.initial.a.map (·.factorization p)).sum ≤ (Multiset.join (Multiset.replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n))).sum := by\n        calc (P.initial.a.map (·.factorization p)).sum ≤ (Multiset.map (·.factorization p) P.initial.a).sum := by simp\n        _ ≤ (Multiset.map (·.factorization p) (Multiset.join (Multiset.replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)))).sum := by\n          exact Multiset.map_le_map need\n        _ = (Multiset.join (Multiset.replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n))).sum := by\n          simp [Multiset.sum_map_factorization]\n      <;>\n      simp [Multiset.sum_map_factorization]\n      <;>\n      simp_all [Multiset.sum_map]\n      <;>\n      linarith\n    _ = P.M * (P.n - (P.n - P.n / P.M)) := by\n      simp [Multiset.sum_replicate, Multiset.sum_join, Multiset.sum_Ico_eq_sum_range, Finset.sum_range_id]\n      <;>\n      ring_nf\n      <;>\n      simp [Nat.div_mul_cancel (by\n        have h₁ : P.M ∣ P.M := by norm_num\n        norm_num at h₁ ⊢\n        <;>\n        simp_all [Nat.le_of_dvd]\n        <;>\n        omega\n        )]\n      <;>\n      ring_nf\n    _ = P.M * (P.n / P.M) := by\n      have h₂ : P.n / P.M ≥ 0 := by\n        apply Nat.zero_le\n      have h₃ : P.n - (P.n - P.n / P.M) = P.n / P.M := by\n        have h₄ : P.n / P.M ≤ P.n := by\n          apply Nat.div_le_self\n        have h₅ : P.n - (P.n - P.n / P.M) = P.n / P.M := by\n          have h₆ : P.n / P.M ≤ P.n := by\n            apply Nat.div_le_self\n          have h₇ : P.n - (P.n - P.n / P.M) = P.n / P.M := by\n            omega\n          exact h₇\n        exact h₅\n      omega\n    _ ≤ P.n := by\n      have h₂ : P.M * (P.n / P.M) ≤ P.n := by\n        have h₃ : P.M * (P.n / P.M) ≤ P.n := by\n          apply Nat.mul_div_le\n        exact h₃\n      linarith\n  have h₂ : (Pinitial.a.map (·.factorization p)).sum ≤ P.n := h₁\n  -- Use the fact that the sum of the factorizations is bounded by P.n\n  -- to prove the desired inequality. The detailed steps involve logarithms and casts,\n  -- which are handled below.\n  have h₃ : (Pinitial.balance p : ℝ) ≤ (P.M : ℝ) * Real.log (P.n : ℝ) := by\n    have h₄ : (Pinitial.balance p : ℝ) ≤ (Pinitial.a.map (·.factorization p)).sum := by\n      -- Prove that the balance is less than or equal to the sum of the factorizations.\n      simp [Factorization.balance, factorization, h₁]\n      <;>\n      norm_cast\n      <;>\n      simp_all [Finset.sum_const, Finset.card_univ]\n      <;>\n      linarith\n    have h₅ : ((Pinitial.a.map (·.factorization p)).sum : ℝ) ≤ (Pn : ℝ) := by\n      norm_cast at h₂ ⊢\n      <;>\n      simp_all [h₂]\n      <;>\n      linarith\n    have h₆ : (Pn : ℝ) ≤ (P.M : ℝ) * Real.log (P.n : ℝ) := by\n      have h₇ : Real.log ((Pn : ℝ)) ≥ Real.log ((Pn : ℝ)) := by linarith\n      -- Use the fact that the logarithm of Pn is positive.\n      have h₈ : Real.log ((Pn : ℝ)) ≥ 1 → (Pn : ℝ) ≤ (P.M : ℝ) * Real.log (P.n : ℝ) := by\n        intro h₉\n        have : (Pn : ℝ) ≥ 1 := by\n          norm_cast\n          have : Pn ≥ 1 := by\n            have : Pn ≥ 1 := by\n              have : Pn > 0 := by\n                have : Pn > 0 := by\n                  linarith [P.hL]\n                linarith\n              omega\n            omega\n          linarith\n        have h₁₀ : (P.M : ℝ) ≥ 1 := by\n          norm_cast\n          <;>\n          simp_all [Nat.one_le_iff_ne_zero]\n          <;>\n          omega\n        have h₁₁ : Real.log ((Pn : ℝ)) ≥ 1 := by linarith\n        have h₁₂ : (Pn : ℝ) ≤ (P.M : ℝ) * Real.log (P.n : ℝ) := by\n          have h₁₃ : (Pn : ℝ) ≤ (P.M : ℝ) * Real.log (P.n : ℝ) := by\n            have h₁₄ : (Pn : ℝ) ≤ (P.M : ℝ) * Real.log (P.n : ℝ) := by\n              -- Use the fact that the logarithm of Pn is greater than or equal to 1.\n              have h₁₅ : Real.log (P.n : ℝ) ≥ Real.log 1 := by\n                apply Real.log_le_log\n                · positivity\n                · norm_cast\n                  <;>\n                  linarith\n              have h₁₆ : Real.log (1 : ℝ) = 0 := by norm_num\n              have h₁₇ : Real.log (P.n : ℝ) ≥ 1 := by linarith\n              nlinarith [Real.log_pos (by norm_num : (1 : ℝ) < 2)]\n            linarith\n          linarith\n        linarith\n      by_cases h₉ : Real.log ((Pn : ℝ)) ≥ 1\n      · exact h₈ h₉\n      · -- If the logarithm of Pn is not greater than or equal to 1, we need another approach.\n        have h₁₀ : (Pn : ℝ) ≤ 1 := by\n          by_contra h₁₁\n          have h₁₂ : (Pn : ℝ) > 1 := by linarith\n          have h₁₃ : Real.log ((Pn : ℝ)) > 0 := Real.log_pos (by linarith)\n          have h₁₄ : Real.log ((Pn : ℝ)) ≥ 1 := by\n            have h₁₅ : (Pn : ℝ) ≥ 2 := by\n              norm_cast at h₁₂ ⊢\n              have : Pn ≥ 2 := by\n                omega\n              linarith\n            have h₁₆ : Real.log ((Pn : ℝ)) ≥ Real.log 2 := by\n              apply Real.log_le_log\n              · positivity\n              · norm_cast at h₁₅ ⊢\n                <;> linarith\n            have h₁₇ : Real.log 2 ≥ Real.log 1 := by\n              apply Real.log_le_log\n              · positivity\n              · norm_cast\n                <;> norm_num\n            have h₁₈ : Real.log 1 = 0 := by norm_num\n            have h₁₉ : Real.log 2 > 0 := Real.log_pos (by norm_num)\n            have h₂₀ : Real.log ((Pn : ℝ)) ≥ 1 := by\n              have h₂₁ : Real.log 2 ≈ 0.693 := by norm_num [Real.log_two_gt_d