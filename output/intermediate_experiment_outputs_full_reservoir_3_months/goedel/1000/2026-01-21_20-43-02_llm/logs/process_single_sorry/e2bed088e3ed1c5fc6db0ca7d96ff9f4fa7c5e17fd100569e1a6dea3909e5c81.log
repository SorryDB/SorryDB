@[blueprint
  "initial-factorization-small-prime-le"
  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  have h₁ : P.initial.balance p ≤ 0 := by
    simp only [Factorization.balance, Factorization.sum, Params.initial, sub_nonpos]
    have : (map (·.factorization p) (filter (fun m ↦ m ∈ (P.n / P.L).smoothNumbers)
        (replicate P.M (Ico (P.n - P.n / P.M) P.n)).join)).sum = 0 := by
      apply sum_eq_zero
      intro x hx
      simp only [Multiset.mem_map, Multiset.mem_filter] at hx
      obtain ⟨m, ⟨_, hsmooth⟩, rfl⟩ := hx
      rw [factorization_eq_zero_iff]
      have h₂ : m ∈ (P.n / P.L).smoothNumbers := hsmooth
      have h₃ : p > 0 := by
        by_contra h
        simp_all [Nat.Prime]
        <;> linarith
      have h₄ : m ≠ 0 := by
        simp only [mem_smoothNumbers', Set.mem_setOf_eq] at h₂
        have h₅ := h₂.1
        have h₆ := h₂.2
        omega
      have h₅ : p ∣ m → False := by
        intro h₅
        have h₆ : p ≤ m := Nat.le_of_dvd (by
          simp only [mem_smoothNumbers', Set.mem_setOf_eq] at h₂
          have h₇ := h₂.1
          omega) h₅
        have h₇ : p.Prime → p^2 > m := by
          intro h₇
          have h₈ : (p : ℝ) ≤ Real.sqrt P.n := hp
          have h₉ : (p : ℝ)^2 ≤ P.n := by
            have h₁₀ : 0 ≤ (p : ℝ) := by positivity
            nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (by positivity : 0 ≤ (P.n : ℝ))]
          have h₁₀ : (m : ℕ) < P.n := by
            simp only [mem_smoothNumbers', Set.mem_setOf_eq] at h₂
            omega
          have h₁₁ : (p : ℕ)^2 > m := by
            norm_cast at h₉ ⊢
            <;> nlinarith
          exact h₁₁
        simp_all [mem_smoothNumbers', Nat.Prime]
        <;> norm_num at h₈ ⊢ <;>
          (try omega) <;> (try nlinarith) <;> (try contradiction)
      simp_all [Nat.Prime]
      <;> tauto
    simp_all [sum_eq_zero]
    <;> linarith
  have h₂ : (0 : ℝ) ≤ P.M * (Real.log P.n) := by
    have h₃ : (0 : ℝ) ≤ P.M := by positivity
    have h₄ : (0 : ℝ) ≤ Real.log P.n := by
      have h₅ : (1 : ℝ) ≤ P.n := by
        have h₆ : (1 : ℕ) ≤ P.n := by
          have h₇ : P.n > P.L * P.L := P.hL
          have h₈ : P.L > 0 := P.hL_pos
          nlinarith
        exact_mod_cast h₆
      exact Real.log_nonneg (by linarith)
    positivity
  have h₃ : (P.initial.balance p : ℝ) ≤ P.M * (Real.log P.n) := by
    have h₄ : (P.initial.balance p : ℝ) ≤ 0 := by exact_mod_cast h₁
    linarith
  exact_mod_cast h₃
