```lean
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  have h₁ : (P.n : ℝ) > 1 := by
    have h₂ : P.L > 0 := P.hL_pos
    have h₃ : P.n > P.L * P.L := P.hL
    have h₄ : (P.L : ℝ) ≥ 1 := by
      norm_cast
      <;>
      (try omega) <;>
      (try nlinarith)
    have h₅ : (P.n : ℝ) > 1 := by
      have h₆ : (P.n : ℝ) > (P.L : ℝ) * (P.L : ℝ) := by exact_mod_cast P.hL
      have h₇ : (P.L : ℝ) * (P.L : ℝ) ≥ 1 * 1 := by
        nlinarith
      nlinarith
    exact_mod_cast h₅
  
  have h₂ : P.M * (Real.log P.n) ≥ 0 := by
    have h₃ : (P.M : ℝ) ≥ 0 := by exact_mod_cast Nat.zero_le _
    have h₄ : Real.log P.n ≥ 0 := Real.log_nonneg (by
      norm_cast
      <;>
      (try omega) <;>
      (try nlinarith [P.hL_pos, P.hL]))
    nlinarith
  
  have h₃ : P.initial.balance p ≤ 0 := by
    simp only [Factorization.balance, Factorization.sum, Params.initial, sub_nonpos]
    have : (map (fun m ↦ m.factorization p)
      (filter (fun m ↦ m ∈ (P.n / P.L).smoothNumbers)
      (replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)).join)).sum = 0 :=
      sum_eq_zero fun x hx ↦ by
        simp only [Multiset.mem_map, Multiset.mem_filter] at hx
        obtain ⟨m, ⟨_, hsmooth⟩, rfl⟩ := hx
        rw [factorization_eq_zero_iff]
        <;>
        simp_all [Nat.Prime]
        <;>
        norm_num at *
        <;>
        (try omega)
        <;>
        (try aesop)
        <;>
        (try simp_all [Nat.Prime])
        <;>
        (try nlinarith [P.hL_pos, P.hL])
        <;>
        (try
          {
            contrapose! hsmooth
            have h₄ : p ∣ m := by
              -- We need to show that p divides m
              -- Since m is in the smoothNumbers, its prime factors are ≤ P.n / P.L
              -- and p > P.n / P.L, this would mean p does not divide m
              -- Hence, if p divides m, then p ≤ P.n / P.L
              -- But p ≤ P.n / P.L is not possible since p > Real.sqrt P.n and P.n / P.L < Real.sqrt P.n
              -- Therefore, p does not divide m
              -- However, we need to formalize this in Lean, so we use the contrapositive
              omega
