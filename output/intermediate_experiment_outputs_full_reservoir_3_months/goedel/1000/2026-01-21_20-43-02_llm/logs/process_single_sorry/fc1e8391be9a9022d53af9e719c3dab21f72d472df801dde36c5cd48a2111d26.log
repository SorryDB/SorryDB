theorem completes_univ : Completes (.ioat (io) (io', _) (F)) := by
  intro A rfr
  have h₁ : Completes (ioat (io) (io', _) (r' : ℕ → ℕ)) := by
    -- We use the fact that the function output is universal to satisfy the given conditions.
