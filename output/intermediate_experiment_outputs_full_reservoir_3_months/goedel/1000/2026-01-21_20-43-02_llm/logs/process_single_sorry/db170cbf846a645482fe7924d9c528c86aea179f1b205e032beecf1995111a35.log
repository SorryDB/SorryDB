lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    have h₁ : M'.encard ≤ M.encard := by
      have h₂ : ∀ (e : β), e ∈ M' → e ∈ M := by
        intro e he
        have h₃ : e ∈ M' := he
        have h₄ : G.IsMatching M' := hM'
        have h₅ : e ∈ E(G) := hM'.subset h₃
        have h₆ : e ∈ E(G, ↑e) := by
          simp_all [E]
          <;>
          aesop
        have h₇ : ↑e ∈ V(G, e) := by
          simp [G, V]
          <;>
          aesop
        have h₈ : V(G, e) ⊆ V(G) := by
          intro x hx
          simp_all [V]
          <;>
          aesop
        have h₉ : V(G, e) ⊆ V(G, M) := by
          have h₁₀ : V(G, e) ⊆ V(G) := by
            intro x hx
            simp_all [V]
            <;>
            aesop
          have h₁₁ : V(G) ⊆ V(G, M) := hsu
          exact Set.Subset.trans h₁₀ h₁₁
        have h₁₀ : ↑e ∈ V(G, M) := by
          apply h₉
          exact h₇
        have h₁₁ : e ∈ M := by
          simp_all [V]
          <;>
          aesop
        exact h₁₁
      have h₃ : M' ⊆ M := by
        intro e he
        have h₄ : e ∈ M' := he
        have h₅ : e ∈ M := h₂ e h₄
        exact h₅
      exact Set.encard_le_of_subset h₃
    exact h₁
