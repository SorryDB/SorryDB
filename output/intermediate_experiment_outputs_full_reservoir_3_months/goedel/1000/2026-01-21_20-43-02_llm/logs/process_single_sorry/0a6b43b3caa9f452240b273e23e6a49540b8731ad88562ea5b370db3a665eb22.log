    <;>
    simp_all [Equiv.symm_apply_apply]
    <;>
    aesop
  map_one' := by
    simp [RingHom.map_one]
  map_mul' := by
    intro x y
    simp [RingHom.map_mul]
    <;>
    simp_all [Equiv.apply_symm_apply]
    <;>
    aesop
  map_zero' := by
    simp [RingHom.map_zero]
  map_add' := by
