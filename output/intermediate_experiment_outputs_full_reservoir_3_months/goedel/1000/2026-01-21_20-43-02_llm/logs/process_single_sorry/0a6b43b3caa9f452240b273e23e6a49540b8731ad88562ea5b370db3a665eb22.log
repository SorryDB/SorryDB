def RingEquiv.comp (g : S ‚ČÉ+* T) (f : R ‚ČÉ+* S) : R ‚ČÉ+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    -- Left inverse property: f.symm ‚ąė g.symm ‚ąė (g ‚ąė f) = id
    have h1 : Function.LeftInverse (f.symm) f := by
      intro x
      simp [RingEquiv.right_inv]
    have h2 : Function.LeftInverse (g.symm) g := by
      intro x
      simp [RingEquiv.right_inv]
    have h3 : Function.LeftInverse (fun x => f.symm (g.symm (g (f x)))) (fun x => g (f x)) := by
      intro x
      have h4 : g.symm (g (f x)) = f x := by
        apply RingEquiv.left_inv
      have h5 : f.symm (f x) = x := by
        apply RingEquiv.left_inv
      simp_all [Function.comp_apply]
      <;> aesop
    intro x
    have h6 : f.symm (g.symm (g (f x))) = x := by
      have h7 : g.symm (g (f x)) = f x := by
        apply RingEquiv.left_inv
      have h8 : f.symm (f x) = x := by
        apply RingEquiv.left_inv
      simp_all [Function.comp_apply]
      <;> aesop
    simp_all [Function.comp_apply]
    <;> aesop
  right_inv := by
    intro x
    have h1 : g.symm (g x) = x := by
      apply RingEquiv.right_inv
    have h2 : f.symm (g.symm (g x)) = f.symm x := by
      rw [h1]
    simp_all [Function.comp_apply]
    <;> aesop
