theorem list_Perm_insertIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
    {idx1 idx2 : Nat} {hidx1 : idx1 <= l1.length} {hidx2 : idx2 <= l2.length} {elt : α} :
    (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
  have h : (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
    calc
      (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx1 elt) := by
        -- Since l1 and l2 are permutee, inserting the same element at the same index preserves permutation
        apply List.Perm.insert
        <;> simp_all [hPerm]
      _ = (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
        -- Now we need to permute the insertions of the same element at different indices in l2
        have h₁ : l2.insertIdx idx1 elt = l2.insertIdx idx2 elt ∨ ¬(l2.insertIdx idx1 elt = l2.insertIdx idx2 elt) := by by_cases h : l2.insertIdx idx1 elt = l2.insertIdx idx2 elt <;> [exact Or.inl h; exact Or.inr h]
        cases h₁ with
        | inl h₁ =>
          -- If the insertions are equal, we don't need to permute
          simp [h₁]
        | inr h₁ =>
          -- If the insertions are not equal, we need to find a permutation
          have h₂ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
            -- Use the fact that we can rearrange the inserted elements
            apply List.Perm.trans
            · -- First, we can move the inserted element to the desired index using `moves`
              have h₃ : (l2.insertIdx idx1 elt).Perm (l2.insertMove (by
                omega) (by
                  omega) (idx2 - idx1) (List.get (l2.insertIdx idx1 elt) ⟨0, by omega⟩)) := by
                sorry
              sorry
            · sorry
          exact h₂.symm
      _ = (l2.insertIdx idx2 elt).Perm (l2.insertIdx idx2 elt) := by rfl
  exact h
