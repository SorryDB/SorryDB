      "\n    have h : ∀ (l1 l2 : List α), l1.Perm l2 → ∀ {idx1 idx2 : Nat}, idx1 ≤ l1.length → idx2 ≤ l2.length → ∀ (elt : α), (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by\n      intro l1 l2 hPerm\n      refine' List.permRecOn hPerm ?_\n      -- Base case: both lists are empty\n      · intro _ _ _elt\n        simp_all [List.insertIdx]\n      -- Inductive step: insert at the head\n      · intro _ _ _idx1 _hidx1 _idx2 _hidx2 _elt\n        simp_all [List.insertIdx]\n        <;>\n        (try\n          {\n            cases idx1 <;> cases idx2 <;>\n            simp_all [List.insertIdx, Nat.succ_le_iff, Nat.le_succ_iff]\n            <;>\n            try { contradiction }\n            <;>\n            try { aesop }\n          })\n        <;>\n        (try\n          {\n            simp_all [List.Perm]\n            <;>\n            aesop\n          })\n        <;>\n        (try\n          {\n            simp_all [List.Perm.trans]\n            <;>\n            aesop\n          })\n      -- Inductive step: insert in the tail\n      · intro _ a l1' b l2' hPerm1 hPerm2 {idx1} hidx1 {idx2} hidx2 elt\n        cases' le_or_lt b.idx1 with hle hlt\n        <;>\n        cases' le_or_lt a.idx1 with hle' hlt'\n        <;>\n        simp_all [List.Perm, List.insertIdx, Nat.lt_succ_iff]\n        <;>\n        (try\n          {\n            simp_all [List.Perm.trans]\n            <;>\n            aesop\n          })\n        <;>\n        (try\n          {\n            simp_all [List.Perm]\n            <;>\n            aesop\n          })\n        <;>\n        (try\n          {\n            simp_all [List.Perm.trans]\n            <;>\n            aesop\n          })\n        <;>\n        (try\n          {\n            simp_all [List.Perm]\n            <;>\n            aesop\n          })\n      -- Inductive step: insert in both tails\n      · intro _ a l1' b l2' hPerm1 hPerm2 {idx1} hidx1 {idx2} hidx2 elt\n        cases' le_or_lt b.idx1 with hle hlt\n        <;>\n        cases