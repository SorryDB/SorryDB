theorem list_Perm_insertIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
    {idx1 idx2 : Nat} {hidx1 : idx1 ≤ l1.length} {hidx2 : idx2 ≤ l2.length} {elt : α} :
    (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
  have h : ∀ (l1 l2 : List α) (hPerm : l1.Perm l2) (n m : Nat) (hn : n ≤ l1.length) (hm : m ≤ l2.length), (l1.insertIdx n elt).Perm (l2.insertIdx m elt) := by
    intro l1 l2 hPerm n m hn hm
    -- Use the fact that if two lists are permutations of each other, their insertions are also permutations.
    have h₁ : (l1.insertIdx n elt).Perm (l2.insertIdx m elt) :=
      -- Use the property of permutations to insert elements at corresponding positions.
      hPerm.insert n m
    exact h₁
  exact h l1 l2 hPerm idx1 idx2 hidx1 hidx2
