try {\n            apply Perm.trans\n            · apply Perm.trans <;> simp_all [List.perm_cons, List.cons_append] <;>\n                (try { apply Equiv.refl }) <;>\n                (try {\n                  apply Equiv.ofPerm\n                  <;> rfl\n                })\n            · apply Equiv.refl\n          }) <;>\n          (try {\n            apply Equiv.ofPerm\n            <;> rfl\n          }) <;>\n          (try {\n            apply Equiv.refl\n          })\n  -- Apply the general result to our specific case.\n  exact h l1 l2 hPerm idx1 hidx1 idx2 hidx2 elt",
