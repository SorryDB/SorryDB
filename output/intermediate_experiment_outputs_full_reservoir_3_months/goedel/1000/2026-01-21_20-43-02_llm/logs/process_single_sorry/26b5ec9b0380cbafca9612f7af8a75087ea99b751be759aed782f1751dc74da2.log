@[to_additive]
lemma pi {ι : Type*} {G : ι → Type*} [Fintype ι] [∀ i, Group (G i)] {A : ∀ i, Set (G i)} {K : ι → ℝ}
    (hA : ∀ i, IsApproximateSubgroup (K i) (A i)) :
    IsApproximateSubgroup (∏ i, K i) (Set.univ.pi A) where
  one_mem i _ := (hA i).one_mem
  inv_eq_self := by simp [(hA _).inv_eq_self]
  sq_covBySMul := by
    choose F hF hFS using fun i ↦ (hA i).sq_covBySMul
    classical
    refine ⟨Fintype.piFinset F, ?_, ?_⟩
    · calc
        #(Fintype.piFinset F) = ∏ i, (#(F i) : ℝ) := by simp
        _ ≤ ∏ i, K i := by gcongr; exact hF _
    · rintro ⟨a, ha⟩ ⟨b, hb⟩ ⟨i⟩
      have h₁ : a i ∈ A i := ha i
      have h₂ : b i ∈ A i := hb i
      have h₃ : a i * b i ∈ A i ^ 2 := by
        exact Set.mem_pow.mpr ⟨a i, b i, h₁, h₂⟩
      have h₄ : A i ^ 2 ⊆ ↑(F i) • A i := hFS i
      have h₅ : a i * b i ∈ ↑(F i) • A i := h₄ h₃
      rw [smul_set, Set.mem_iUnion] at h₅
      rcases h₅ with ⟨c, hc, x, hx, h₆⟩
      refine' ⟨c, _⟩
      simp_all [Fintype.piFinset.mem_coe, Finset.mem_product]
      <;>
      (try simp_all [Set.mem_univ, forall_true_left]) <;>
      (try aesop) <;>
      (try
        {
          ext i
          simp_all [Set.mem_univ, forall_true_left]
          <;>
          (try aesop)
        })
      <;>
      (try
        {
          simp_all [Set.mem_univ, forall_true_left]
          <;>
          (try aesop)
        })
