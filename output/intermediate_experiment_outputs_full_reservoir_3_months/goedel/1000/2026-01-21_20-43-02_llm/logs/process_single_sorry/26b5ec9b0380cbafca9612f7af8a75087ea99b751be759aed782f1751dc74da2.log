     (hA : ∀ i, IsApproximateSubgroup (K i) (A i)) :
     IsApproximateSubgroup (∏ i, K i) (Set.univ.pi A) where
   one_mem i _ := (hA i).one_mem
   inv_eq_self := by simp [(hA _).inv_eq_self]
   sq_covBySMul := by
     choose F hF hFS using fun i ↦ (hA i).sq_covBySMul
     classical
     refine ⟨Fintype.piFinset F, ?_, ?_⟩
     · calc
         #(Fintype.piFinset F) = ∏ i, (#(F i) : ℝ) := by simp
         _ ≤ ∏ i, K i := by gcongr; exact hF _
     · have h : Set.univ.pi A ^ 2 ⊆ ↑(Fintype.piFinset F) • Set.univ.pi A := by
         intro x hx
         simp only [Set.mem_pi, Set.mem_prod, Set.mem_univ, true_and_iff, Set.mem_iUnion,
           Set.mem_singleton_iff] at hx ⊢
         rw [pow_two] at hx
         -- We need to show that for each i, x.1 i * x.2 i is in F i • A i.
         -- This follows from the fact that A i ^ 2 ⊆ F i • A i for each i.
         have h₁ : ∀ i, ∃ (a : G i), a ∈ A i ∧ x.1 i * x.2 i ∈ (F i : Set (G i)) • A i := by
           intro i
           have h₂ : A i ^ 2 ⊆ (F i : Set (G i)) • A i := hFS i
           have h₃ : (x.1 i, x.2 i) ∈ A i ×ˢ A i := by
             constructor <;> (try simp_all [Set.mem_pi]) <;> (try aesop)
             <;> (try
               {
                 simp_all [Set.mem_pi]
                 <;> aesop
               })
           have h₄ : x.1 i * x.2 i ∈ A i ^ 2 := by
             simp only [pow_two, Set.mem_prod, Set.mem_univ, true_and_iff] at h₃ ⊢
             exact ⟨x.1 i, x.2 i, by aesop⟩
           have h₅ : x.1 i * x.2 i ∈ (F i : Set (G i)) • A i := h₂ h₄
           have h₆ : ∃ (a : G i), a ∈ A i ∧ x.1 i * x.2 i ∈ (F i : Set (G i)) • A i := by
             refine' ⟨x.2 i, _, h₅⟩
             simp_all [Set.mem_pi]
             <;> aesop
           exact h₆
         -- Now we need to construct an element in Fintype.piFinset F • Set.univ.pi A.
         -- We do this by constructing a function that for each i, uses the corresponding element from F i • A i.
         have h₂ : ∃ (g : ι → G) (a : ι → G), (∀ i, g i ∈ (F i : Set (G i))) ∧ (∀ i, a i ∈ A i) ∧ (∀ i, x.1 i * x.2 i = g i * a i) := by
           classical
           choose g hg using h₁
           choose a ha using fun i ↦ (hg i).2
           have h₃ : ∀ i, g i ∈ (F i : Set (G i)) := by
             intro i
             have h₄ := (hg i).1
             simp_all [Set.mem_smul, Set.mem_pi]
             <;> aesop
           refine' ⟨fun i ↦ g i, fun i ↦ a i, h₃, fun i ↦ ha i, _⟩
           intro i
           have h₄ := (hg i).2
           simp_all [Set.mem_smul, Set.mem_pi]
           <;> aesop
         obtain ⟨g, a, hg, ha, h₃⟩ := h₂
         have h₄ : (fun i ↦ g i * a i) ∈ (Fintype.piFinset F : Set (ι → G)) • Set.univ.pi A := by
           simp only [Set.mem_smul, Set.mem_pi, Set.mem_univ, true_and_iff]
           refine' ⟨fun i ↦ g i, _⟩
           constructor
           · -- Show that g is in Fintype.piFinset F
             simp_all [Fintype.piFinset, Set.mem_pi]
             <;> aesop
           · -- Show that a is in Set.univ.pi A
             intro i
             simp_all [Set.mem_pi]
             <;> aesop
         -- Now we need to show that x is in (Fintype.piFinset F : Set (ι → G)) • Set.univ.pi A
         have h₅ : x.1 * x.2 = (fun i ↦ g i * a i) := by
           funext i
           rw [h₃ i]
         rw [h₅]
         exact h₄
       exact h
