theorem HasLUB_of_BddNonempty {S : Set ℝ} (hS : S.Nonempty) {M : ℝ} (hM : IsUB S M) : ∃ L, IsLUB S L := by
  have h₁ : ∃ L, IsLUB S L := by
    classical
    -- Use the least upper bound property of the real numbers to find the supremum
    have h₂ : ∃ L, IsLUB S L := by
      -- Extract an element from the nonempty set S
      obtain ⟨s₀, hs₀⟩ := hS
      -- Use the real numbers' property to find the least upper bound
      use sSup S
      constructor
      · -- Prove that sSup S is an upper bound of S
        intro s hs
        exact le_csSup (by
          -- Prove that S is bounded above
          refine' ⟨M, _⟩
          intro s hs
          exact hM s hs) hs
      · -- Prove that sSup S is the least upper bound
        intro M hM'
        -- Use the property of the supremum
        have h₃ : sSup S ≤ M := by
          apply csSup_le (Set.nonempty_of_mem hs₀)
          intro s hs
          exact hM' s hs
        exact h₃
    exact h₂
  exact h₁
