lemma test (x : ℝ) : Real.sqrt x ^ 2 = x := by
  have h₁ : Real.sqrt x ^ 2 = x := by
    have h₂ : 0 ≤ x ∨ x < 0 := by
      by_cases h : 0 ≤ x
      · exact Or.inl h
      · exact Or.inr (by linarith)
    cases h₂ with
    | inl h₂ =>
      -- Case: x ≥ 0
      have h₃ : Real.sqrt x ≥ 0 := Real.sqrt_nonneg x
      have h₄ : Real.sqrt x ^ 2 = x := by
        rw [Real.sq_sqrt] <;> linarith
      exact h₄
    | inr h₂ =>
      -- Case: x < 0
      have h₃ : Real.sqrt x = 0 := by
        rw [Real.sqrt_eq_zero_of_nonpos] <;> linarith
      have h₄ : Real.sqrt x ^ 2 = 0 := by
        rw [h₃]
        <;> norm_num
      have h₅ : x < 0 := h₂
      have h₆ : (x : ℝ) < 0 := by exact_mod_cast h₅
      have h₇ : Real.sqrt x ^ 2 = x := by
        nlinarith [Real.sqrt_nonneg x]
      exact h₇
  exact h₁
