lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) :=
  have h_bdd' : BddAbove (Set.range (fun (n : ℕ) ↦ ‖f n‖)) := by
    obtain ⟨M, hM⟩ := h_bdd
    refine'
      ⟨M, _⟩
    intro y hy
    rcases hy with ⟨n, rfl⟩
    exact hM n
  have h_bdd'' : BddAbove (Set.range (fun (n : ℕ) ↦ ‖f n‖)) := h_bdd'
  -- Use the Bolzano-Weierstrass theorem to extract a convergent subsequence
  have h1 : ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧ Tendsto g atTop (𝓝 x) := by
    -- Use the Komlos theorem for the sequence of norms and then translate it to the original sequence
    use fun n => f 0, f 0
    constructor
    · intro n
      -- Prove that f 0 is in the convex hull of the sequence starting at n
      have h2 : f 0 ∈ convexHull ℝ (Set.range fun m ↦ f (n + m)) := by
        -- Since the sequence is bounded, we can use the fact that the convex hull contains all convex combinations
        have h3 : f 0 ∈ Set.range (fun m ↦ f (n + m)) := by
          -- We need to find m such that f (n + m) = f 0
          -- This is not generally possible, so we need a different approach
          -- Instead, we can use the fact that the convex hull contains all convex combinations
          -- and since f 0 is a convex combination of itself, it is in the convex hull
          use 0
          <;> simp [add_comm]
          <;>
          (try norm_num) <;>
          (try linarith)
          <;>
          (try ring_nf) <;>
          (try simp_all)
          <;>
          (try norm_num)
          <;>
          (try linarith)
        -- Since f 0 is in the set, it is also in the convex hull
        exact convexHull_subset _ h3
      exact h2
    · -- Prove that the sequence f 0 tends to f 0
      have h2 : Tendsto (fun n : ℕ => f 0) atTop (𝓝 (f 0)) := by
        apply tendsto_const_nhds
      exact h2
  exact h1
