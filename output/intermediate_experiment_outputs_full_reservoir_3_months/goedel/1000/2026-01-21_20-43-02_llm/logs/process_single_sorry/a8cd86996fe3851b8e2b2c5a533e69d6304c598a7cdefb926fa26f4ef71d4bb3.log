lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) :=
  by
  have h₁ : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M := h_bdd
  -- Define g_n as the zero vector in E, which trivially lies in the convex hull of any set containing the origin.
  use fun n => 0, 0
  constructor
  · -- Show that g_n = 0 is in the convex hull of the set {f(n + m) | m ∈ ℕ}
    intro n
    have h₂ : (0 : E) ∈ convexHull ℝ (Set.range fun m ↦ f (n + m)) := by
      -- Use the fact that the convex hull contains the origin if the set contains the origin or if we can form 0 as a convex combination.
      apply convexHull_zero
      -- Show that the set {f(n + m) | m ∈ ℕ} is nonempty.
      have h₃ : ∃ m, (f (n + m) : E) = (f (n + m) : E) := by
        exact ⟨0, rfl⟩
      -- Since the set is nonempty, the origin is in the convex hull.
      <;> simp_all [Set.nonempty_range_iff]
      <;>
      (try norm_num) <;>
      (try aesop) <;>
      (try
        {
          obtain ⟨M, hM⟩ := h_bdd
          have h₄ : ‖f 0‖ ≤ M := hM 0
          norm_num at h₄ ⊢
          <;>
          (try simp_all [h₄]) <;>
          (try linarith)
        })
    exact h₂
  · -- Show that g_n tends to 0 as n tends to infinity.
    have h₃ : Tendsto (fun n : ℕ ↦ (0 : E)) atTop (𝓝 (0 : E)) := by
      apply tendsto_const_nhds
    simpa using h₃
