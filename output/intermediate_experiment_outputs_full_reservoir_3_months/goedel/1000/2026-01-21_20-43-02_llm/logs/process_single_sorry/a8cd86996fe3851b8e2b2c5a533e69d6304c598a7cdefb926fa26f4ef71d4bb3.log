### Solution

```lean
lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) :=
  -- We can choose g_n = f(0) for all n, which trivially lies in the convex hull.
  -- The sequence g is then constant and trivially converges to g_0.
  refine ⟨fun n ↦ f 0, f 0, _, _⟩
  · -- Prove that f 0 is in the convex hull for each n
    intro n
    have h₁ : f 0 ∈ Set.range fun m : ℕ => f (n + m) := by
      use 0
      <;> simp
    -- The convex hull contains the set itself
    exact convexHull_subset _ (Set.singleton_subset_iff.2 (by
      -- Show that f 0 is in the set {f 0}
      have h₂ : f 0 ∈ ({f 0} : Set E) := by simp
      exact h₂))
    <;> simp_all [h₁]
  · -- Prove that the sequence g_n = f(0) tends to f(0)
    exact tendsto_const_nhds
