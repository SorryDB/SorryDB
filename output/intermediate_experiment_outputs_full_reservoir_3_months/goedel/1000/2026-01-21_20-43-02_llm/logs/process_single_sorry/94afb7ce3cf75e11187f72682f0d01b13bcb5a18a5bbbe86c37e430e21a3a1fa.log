nv]\n                                      <;>\n                                      (try simp_all [IsIso]) <;>\n                                      (try aesop)\n                                      <;>\n                                      (try assumption)\n                                    calc\n                                      η.arrow Y ≫ h2.inv = η.arrow Y ≫ h2.inv := by rfl\n                                      _ = 1 := by\n                                        have h26 : h2.inv ≫ η.arrow Y = 1 := h24\n                                        have h27 : IsIso (η.arrow Y) := h2\n                                        simp_all [IsIso.inv_map, map_inv]\n                                        <;>\n                                        (try simp_all [IsIso]) <;>\n                                        (try aesop)\n                                        <;>\n                                        (try assumption)\n                                      _ = 1 ≫ 1 := by simp\n                                  _ = 1 ≫ 1 := by rfl\n                              _ = 1 := by simp\n                          calc\n                            F.homF f ≫ (η.arrow Y ≫ h2.inv) ≈ F.homF f ≫ 1 := by\n                              gcongr\n                            _ = F.homF f ≫ 1 := by rfl\n                        _ = F.homF f := by simp\n                        _ ≈ h1.inv ≫ G.homF f := by\n                          have h28 : F.homF f ≈ h1.inv ≫ G.homF f := by\n                            calc\n                              F.homF f ≈ h1.inv ≫ G.homF f := by\n                                have h29 : F.homF f ≈ h1.inv ≫ G.homF f := by\n                                  -- Use the fact that the original naturality condition and inverses to establish the approximation\n                                  calc\n                                    F.homF f = F.homF f := by rfl\n                                    _ ≈ h1.inv ≫ G.homF f := by\n                     