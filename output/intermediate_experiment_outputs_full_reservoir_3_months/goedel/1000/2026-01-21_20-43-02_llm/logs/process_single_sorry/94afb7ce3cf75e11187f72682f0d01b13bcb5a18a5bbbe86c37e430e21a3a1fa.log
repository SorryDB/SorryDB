    have h5 : IsIso (η.arrow Y) := h2
    have h6 : IsIso (η.arrow X) := h1
    have h7 : IsIso (η.arrow Y) := h2
    -- Use the inverses of the isomorphisms to show the naturality condition for the inverse transformation
