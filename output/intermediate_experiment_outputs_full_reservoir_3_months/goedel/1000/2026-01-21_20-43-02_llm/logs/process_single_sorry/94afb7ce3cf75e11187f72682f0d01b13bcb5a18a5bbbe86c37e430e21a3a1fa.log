      "\n      rw [IsIso.inv_mul]\n      <;> simp_all\n    have h₅ : η.arrow Y ≫ (η.arrow Y).inv = 1 := by\n      rw [IsIso.mul_inv]\n      <;> simp_all\n    have h₆ : (η.arrow X).inv ≫ F.homF f = G.homF f ≫ (η.arrow Y).inv := by\n      calc\n        (η.arrow X).inv ≫ F.homF f = (ηarrow X).inv ≫ (ηarrow X ≫ G.homF f) := by\n          rw [← h₁]\n          <;> simp [comp_assoc]\n        _ = ((ηarrow X).inv ≫ ηarrow X) ≫ G.homF f",
