theorem lean_workbook_25610  (x a b c : ℕ) (h : (x + a) * (x + b) = x ^ 2 + c) :
  a * b = c := by
  have h₁ : (x + a) * (x + b) = x ^ 2 + a * x + b * x + a * b := by
    ring
  rw [h₁] at h
  have h₂ : x ^ 2 + a * x + b * x + a * b = x ^ 2 + c := by
    linarith
  have h₃ : a * x + b * x + a * b = c := by
    omega
  have h₄ : a * b = c := by
    have h₅ : a * x + b * x + a * b = c := by omega
    have h₆ : x = 0 := by
      by_contra h₆
      have h₇ : x ≥ 1 := by
        omega
      have h₈ : a * x + b * x ≥ x := by
        have h₉ : a ≥ 0 := by omega
        have h₁₀ : b ≥ 0 := by omega
        nlinarith
      have h₉ : a * x + b * x + a * b ≥ x := by
        nlinarith
      have h₁₀ : c ≥ x := by
        omega
      nlinarith [sq_nonneg (a - b)]
    subst h₆
    ring_nf at h₃ ⊢
    <;> omega
  exact h₄
