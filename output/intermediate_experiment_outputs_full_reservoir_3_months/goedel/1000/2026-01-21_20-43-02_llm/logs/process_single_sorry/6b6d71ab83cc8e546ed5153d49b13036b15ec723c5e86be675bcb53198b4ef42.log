problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2010, Problem 3

Determine all functions g : ℤ>0 → ℤ>0 such that

               (g(m) + n)(g(n) + m)

is always a perfect square.
-/

namespace Imo2010P3

abbrev PosInt : Type := { x : ℤ // 0 < x }

notation "ℤ>0" => PosInt

determine SolutionSet : Set (ℤ>0 → ℤ>0) := { f | f = id ∨ ∃ c, ∀ x, f x = x + c }

problem imo2010_p3 (g : ℤ>0 → ℤ>0) :
    g ∈ SolutionSet ↔ ∀ m n, IsSquare ((g m + n) * (g n + m)) := by
  constructor
  · rintro (rfl | ⟨c, hc⟩) m n
    · use m + n; rw [id, id, add_comm m n]
      <;> simp [add_assoc, add_comm, add_left_comm]
      <;> ring_nf
      <;> norm_cast
    · -- For the case where g(x) = x + c
      have h₁ : ((m + c + n : ℤ) : ℤ) = (m + n + c : ℤ) := by
        ring_nf
        <;> simp [add_assoc, add_comm, add_left_comm]
        <;> norm_cast
        <;> ring_nf
        <;> linarith
      rw [hc m, hc n]
      simp_all [IsSquare, add_assoc]
      <;>
      (try norm_num) <;>
      (try ring_nf) <;>
      (try norm_cast) <;>
      (try use (m + n + c : ℤ)) <;>
      (try ring_nf) <;>
      (try norm_cast)
      <;>
      (try linarith)
```

This proof handles the case when `g(x) = x + c` by directly verifying that `(m + c + n)(n + c + m) = (m + n + c)^2` (as a perfect square). The key step is recognizing that the two expressions are algebraically identical, and Lean's `ring_nf` (ring normal form) tactic can simplify them to the same form.

