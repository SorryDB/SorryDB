import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h₂ : ∃ (a : ℕ), a ∈ S := by
    have h₃ : 0 < S.card := by
      rw [h₀]
      <;> norm_num
    exact Finset.card_pos.mp h₃
  
  obtain ⟨a, ha⟩ := h₂
  refine' ⟨{a}, ∅, _, _, _, _, _, _⟩
  · -- Prove that {a} is nonempty
    exact Finset.singleton_nonempty a
  · -- Prove that {a} ⊆ S
    exact Finset.singleton_subset_iff.mpr ha
  · -- Prove that ∅ is nonempty
    exfalso
    <;> simp_all [Finset.nonempty_iff_ne_empty]
    <;>
    (try decide) <;>
    (try omega)
  · -- Prove that ∅ ⊆ S
    simp
  · -- Prove that {a} and ∅ are disjoint
    simp [Finset.disjoint_left]
  · -- Prove that the sums are equal
    simp [Finset.sum_singleton]
