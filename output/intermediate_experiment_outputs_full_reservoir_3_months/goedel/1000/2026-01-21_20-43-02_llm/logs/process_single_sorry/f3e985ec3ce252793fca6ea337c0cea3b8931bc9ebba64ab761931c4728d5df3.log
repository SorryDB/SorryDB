```lean
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h₂ : ∃ (S₁ S₂ : Finset ℕ), S₁.Nonempty ∧ S₁ ⊆ S ∧ S₂.Nonempty ∧ S₂ ⊆ S ∧ Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    -- Since S has at least two elements, we can find two disjoint nonempty subsets with the same sum
    have h₃ : S.card = 10 := h₀
    have h₄ : S ⊆ Finset.Ico 10 100 := h₁
    -- Extract two distinct elements from S
    have h₅ : ∃ (a : ℕ), a ∈ S := by
      by_contra h
      push_neg at h
      have h₆ : S = ∅ := by
        apply Finset.eq_empty_of_forall_not_mem
        intro x hx
        have h₇ := h x
        tauto
      have h₇ : S.card = 0 := by
        rw [h₆]
        simp
      linarith
    obtain ⟨a, ha⟩ := h₅
    have h₆ : ∃ (b : ℕ), b ∈ S ∧ b ≠ a := by
      by_contra h
      push_neg at h
      have h₇ : S ⊆ {a} := by
        intro x hx
        by_cases h₈ : x = a
        · simp_all
        · have h₉ := h x
          simp_all
          <;> aesop
      have h₈ : S.card ≤ 1 := by
        calc
          S.card ≤ ({a} : Finset ℕ).card := Finset.card_le_of_subset h₇
          _ = 1 := by simp
      linarith
    obtain ⟨b, hb, hb'⟩ := h₆
    -- Use the two distinct elements to form two disjoint subsets
    have h₇ : ∃ (S₁ S₂ : Finset ℕ), S₁.Nonempty ∧ S₁ ⊆ S ∧ S₂.Nonempty ∧ S₂ ⊆ S ∧ Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
      use {a}, {b}
      constructor
      · -- Prove {a} is nonempty
        simp [ha]
      constructor
      · -- Prove {a} ⊆ S
        simp [ha]
        <;> aesop
      constructor
      · -- Prove {b} is nonempty
        simp [hb]
      constructor
      · -- Prove {b} ⊆ S
        simp [hb]
        <;> aesop
      constructor
      · -- Prove {a} and {b} are disjoint
        simp [ha, hb, hb']
        <;> aesop
      · -- Prove the sums are equal
        simp [ha, hb]
        <;> aesop
    exact h₇
  exact h₂
