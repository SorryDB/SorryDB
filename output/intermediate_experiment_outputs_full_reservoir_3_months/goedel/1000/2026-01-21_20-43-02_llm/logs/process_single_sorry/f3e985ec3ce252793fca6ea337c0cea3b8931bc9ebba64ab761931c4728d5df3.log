```lean
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h₂ : ∃ (S₁ S₂ : Finset ℕ), S₁.Nonempty ∧ S₁ ⊆ S ∧ S₂.Nonempty ∧ S₂ ⊆ S ∧ Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    -- Extract any two distinct elements from S
    have h₃ : ∃ (a b : ℕ), a ∈ S ∧ b ∈ S ∧ a ≠ b := by
      have h₄ : S.card ≥ 2 := by
        norm_num [h₀]
      have h₅ : ∃ (a : ℕ), a ∈ S := Finset.card_pos.1 (by
        rw [h₀]
        norm_num)
      obtain ⟨a, ha⟩ := h₅
      have h₆ : ∃ (b : ℕ), b ∈ S ∧ b ≠ a := by
        by_contra! h
        have h₇ : S ⊆ {a} := by
          intro x hx
          by_cases hx' : x = a
          · simp_all
          · have h₈ := h x hx
            simp_all
        have h₈ : S.card ≤ 1 := by
          calc
            S.card ≤ ({a} : Finset ℕ).card := Finset.card_le_of_subset h₇
            _ = 1 := by simp
        linarith
      obtain ⟨b, hb, hb'⟩ := h₆
      exact ⟨a, b, ha, hb, by intro h; subst h; contradiction⟩
    obtain ⟨a, b, ha, hb, hab⟩ := h₃
    -- Consider the subsets {a} and {b}
    refine' ⟨{a}, {b}, _, _, _, _, _, _⟩
    · -- Prove {a} is nonempty
      simp [ha]
    · -- Prove {a} ⊆ S
      simp [ha]
      <;> aesop
    · -- Prove {b} is nonempty
      simp [hb]
    · -- Prove {b} ⊆ S
      simp [hb]
      <;> aesop
    · -- Prove {a} and {b} are disjoint
      simp [hab]
      <;> aesop
    · -- Prove the sums are equal
      have h₇ : a ∈ S := ha
      have h₈ : b ∈ S := hb
      have h₉ : a ≠ b := hab
      -- Since a and b are in the range [10, 100), they are at least 10 and at most 99.
      -- However, we don't actually need their exact values to prove the sums are equal here because we are using the fact that a and b are distinct and the sums are trivially equal.
      simp [h₉]
      <;>
      (try decide) <;>
      (try omega) <;>
      (try
        {
          have h₁₀ : a ∈ Finset.Ico 10 100 := h₁ h₇
          have h₁₁ : b ∈ Finset.Ico 10 100 := h₁ h₈
          simp only [Finset.mem_Ico] at h₁₀ h₁₁
          omega
        }) <;>
      (try
        {
          have h₁₀ : a ∈ Finset.Ico 10 100 := h₁ h₇
          have h₁₁ : b ∈ Finset.Ico 10 100 := h₁ h₈
          simp only [Finset.mem_Ico] at h₁₀ h₁₁
          simp_all [Finset.sum_singleton]
          <;> omega
        })
  exact h₂
