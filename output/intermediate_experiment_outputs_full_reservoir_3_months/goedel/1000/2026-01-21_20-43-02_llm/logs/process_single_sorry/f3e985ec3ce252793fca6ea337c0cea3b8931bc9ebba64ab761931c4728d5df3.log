theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h₂ : 0 < S.card := by simp [h₀]
  have h₃ : ∃ (a : ℕ), a ∈ S := Finset.card_pos.mp h₂
  obtain ⟨a, ha⟩ := h₃
  refine' ⟨{a}, ∅, by simp, by simp [ha], by simp, by simp, by simp, _⟩
  <;> simp [ha]
