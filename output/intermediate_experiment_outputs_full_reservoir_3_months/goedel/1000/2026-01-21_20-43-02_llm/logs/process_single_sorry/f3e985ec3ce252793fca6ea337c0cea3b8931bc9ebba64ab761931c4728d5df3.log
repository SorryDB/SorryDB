```lean
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h₂ : S.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro h
    rw [h] at h₀
    norm_num at h₀
    <;> simp_all
  
  have h₃ : ∃ (a : ℕ), a ∈ S := by
    obtain ⟨a, ha⟩ := h₂
    exact ⟨a, ha⟩
  
  obtain ⟨a, ha⟩ := h₃
  refine' ⟨{a}, ∅, Finset.singleton_nonempty a, Finset.singleton_subset_iff.mpr ha, by simp, by simp, by simp, _⟩
  <;> simp [ha]
  <;>
  (try decide) <;>
  (try aesop) <;>
  (try norm_num) <;>
  (try ring_nf) <;>
  (try linarith)
``` 

