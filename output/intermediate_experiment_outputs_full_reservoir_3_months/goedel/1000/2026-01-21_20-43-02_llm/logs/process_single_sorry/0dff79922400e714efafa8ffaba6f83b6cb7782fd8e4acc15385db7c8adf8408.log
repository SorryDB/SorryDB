variable {x : E}
variable {u : E →L[𝕜] F}
variable {f : E → F}

theorem hasFDerivAt_iff_isLittleO
    (h : HasFDerivAt f u x) :
    (fun v : E => f (x + v) - f x - u v) =o[v → (0 : E)] (fun v : E => ‖v‖) := by
