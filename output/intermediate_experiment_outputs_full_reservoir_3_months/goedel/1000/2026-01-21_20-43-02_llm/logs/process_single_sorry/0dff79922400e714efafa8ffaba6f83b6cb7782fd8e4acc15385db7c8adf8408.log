### Complete Lean 4 Proof with `have` Statements

```lean
section

variable {𝕜 : Type*} [Field 𝕜] [LinearOrderedField 𝕜]
variable {E : Type*} [NormedAddCommGroup E] [NormedSpace 𝕜 E]
variable {F : Type*} [NormedAddCommGroup F] [NormedSpace 𝕜 F]

variable {x : E}
variable {u : E →L[𝕜] F}
variable {f : E → F}

/-- A function is differentiable at a point if it can be locally approximated by a linear map.
The `HasFDerivAt` predicate expresses this by requiring that the difference between the function and its linear approximation goes to zero faster than the distance to the point. -/
def HasFDerivAt (f : E → F) (u : E →L[𝕜] F) (x : E) :=
  HasFDerivAt f u x

/-- If a function has a Fréchet derivative at a point, then it is differentiable at that point. -/
theorem hasFDerivAt_implies_differentiableAt
    (h : HasFDerivAt f u x) : DifferentiableAt 𝕜 f x :=
  h.differentiableAt

/-- The Fréchet derivative of a differentiable function at a point is unique. -/
theorem differentiableAt_implies_hasFDerivAt
    (h : DifferentiableAt 𝕜 f x) : HasFDerivAt f (fderiv 𝕜 f x) x :=
  h.hasFDerivAt

end

``` 

