theorem exists_deriv_poly (n : ℕ) (a : ℝ) : ∃ g : ℝ → ℝ, deriv (fun x : ℝ => x ^ n) a = g a := by
  refine' ⟨fun x => deriv (fun x : ℝ => x ^ n) x, _⟩
  <;> simp
  <;>
  (try
    {
      -- Use the power rule to find the derivative of x^n
      have h : deriv (fun x : ℝ => x ^ n) a = n * a ^ (n - 1) := by
        -- Apply the power rule for differentiation
        have h₁ : deriv (fun x : ℝ => x ^ n) a = n * a ^ (n - 1) := by
          -- Use the fact that the derivative of x^n is n * x^(n-1)
          simpa using (deriv_pow a n)
