lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := 
  Set.Subset.antisymm (fun x hx => 
    show x ∈ {a} by
      have h3 : x ∈ A \ {a} → False := by
        intro h4
        exact absurd h4 h2
      by_cases h4 : x = a
      · simp_all
      · have h5 : x ∈ A \ {a} := ⟨hx, h4⟩
        exact absurd h5 h3
  ) (fun x hx => 
    have h3 : x = a := by simpa using hx
    rw [h3]
    exact h1
  )
```
