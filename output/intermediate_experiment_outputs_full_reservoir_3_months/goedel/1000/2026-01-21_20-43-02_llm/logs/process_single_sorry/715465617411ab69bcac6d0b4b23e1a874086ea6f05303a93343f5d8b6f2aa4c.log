```lean
lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := by
  have h3 : ∀ (x : U), x ∈ A → x = a := by
    intro x hx
    by_contra h
    -- If x ≠ a, then x ∈ A \ {a}
    have h4 : x ∈ A \ {a} := by
      simp [hx, h]
    -- But A \ {a} is empty
    have h5 : A \ {a} = ∅ := h2
    rw [h5] at h4
    exact Set.not_mem_empty x h4
  
  have h4 : A ⊆ {a} := by
    intro x hx
    have h5 : x = a := h3 x hx
    rw [h5]
    <;> simp
  
  have h5 : {a} ⊆ A := by
    intro x hx
    simp only [Set.mem_singleton_iff] at hx
    rw [hx]
    exact h1
  
  exact Set.Subset.antisymm h4 h5
```

