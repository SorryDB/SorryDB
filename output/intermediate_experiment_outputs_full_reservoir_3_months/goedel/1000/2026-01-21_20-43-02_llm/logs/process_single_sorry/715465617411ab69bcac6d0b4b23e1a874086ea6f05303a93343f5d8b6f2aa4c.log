lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := by
  apply Set.Subset.antisymm
  · intro x hx
    by_contra h
    have h3 : x ≠ a := h
    have h4 : x ∈ A \ {a} := by
      constructor
      · exact hx
      · intro h5
        apply h3
        simp_all [Set.mem_singleton_iff]
    have h5 : x ∈ (∅ : Set U) := by
      have h6 : empty (A \ {a}) := h2
      simpa [h6] using h4
    exact Set.not_mem_empty x h5
  · intro x hx
    have h3 : x = a := by simpa [Set.mem_singleton_iff] using hx
    rw [h3]
    exact h1
