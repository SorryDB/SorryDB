lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := by
  apply Set.Subset.antisymm
  · -- Prove A ⊆ {a}
    intro x hx
    by_cases h : x = a
    · simp [h]
    · -- If x ≠ a, then x ∈ A \ {a}, contradicting h2
      have h3 : x ∈ A \ {a} := ⟨hx, auto⟩
      have h4 : ¬(x ∈ A \ {a}) := by
        intro h5
        exact h2 ⟨x, h5⟩
      exact absurd h3 h4
  · -- Prove {a} ⊆ A
    intro x hx
    simp only [Set.mem_singleton_iff] at hx
    rw [hx]
    exact h1
