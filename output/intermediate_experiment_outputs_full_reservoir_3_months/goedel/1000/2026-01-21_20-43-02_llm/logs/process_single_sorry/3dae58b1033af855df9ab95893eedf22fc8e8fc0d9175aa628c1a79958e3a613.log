theorem practice_theorem (a : Bool) : (a → False) → ¬a := by
  intro h
  intro a'
  -- Assume for contradiction that a is true.
  have h₁ : a = true := by trivial
  -- Substitute a = true into the hypothesis h.
  have h₂ := congr_arg (· a') h₁
  -- Simplify the expression using the fact that a = true.
  simp at h₂
  -- Use the hypothesis h to derive a contradiction.
  <;> tauto
