lemma IsMatching.restrict₂_edgeFinite (hM : G.IsMatching M) (hM' : G.IsMatching M') [G.EdgeFinite] : EdgeFinite (hM.restrict₂ hM') := by
  have h₁ : M ∆ M' ⊆ E(G) := by
    have hM₁ : M ⊆ E(G) := hM.subset
    have hM'₁ : M' ⊆ E(G) := hM'.subset
    have h₂ : M ∆ M' ⊆ E(G) := by
      intro x hx
      simp only [symmDiff.mem_symmDiff] at hx
      -- Either x is in M but not M', or x is in M' but not M
      cases hx with
      | inl hx =>
        -- Case: x ∈ M and x ∉ M'
        exact hM₁ hx.1
      | inr hx =>
        -- Case: x ∈ M' and x ∉ M
        exact hM'₁ hx.1
    exact h₂
  
  have h₂ : EdgeFinite (G ↾ (M ∆ M')) := by
    haveI : EdgeFinite G := inferInstance
    -- Use the fact that the edge set of the subgraph is a subset of the edge set of G
    have h₃ : (G ↾ (M ∆ M')).edges ⊆ G.edges := by
      intro e he
      simp only [Graph.subset_iff, Subgraph.mem_edges] at he ⊢
      aesop
    -- Use the property of edge-finite graphs to conclude
    exact EdgeFinite.of_subset h₃
  
  have h₃ : EdgeFinite ((G ↾ (M ∆ M')) |>.loopRemove) := by
    -- Use the fact that filtering a finite set remains finite
    haveI : EdgeFinite (G ↾ (M ∆ M')) := h₂
