### Complete Lean Code

```lean
def IsMatching.restrict₂ (hM : G.IsMatching M) (hM' : G.IsMatching M') : Graph α β :=
  G ↾ (M ∆ M') |>.loopRemove

instance IsMatching.restrict₂.edgeFinite (hM : G.IsMatching M) (hM' : G.IsMatching M')
    [G.EdgeFinite] : (hM.restrict₂ hM').EdgeFinite := by
  have h₁ : EdgeFinite (G ↾ (M ∆ M')) := by
    apply (G ↾ (M ∆ M')).EdgeFinite.of_subset
    apply G.subgraph_of_subset (fun e => (e ∈ M ∆ M') → true)
    <;> simp_all [Graph.Subgraph.mem_edge]
    <;> aesop
  have h₂ : EdgeFinite (G ↾ (M ∆ M') |>.loopRemove) := by
    refine' (Finite.exists_finset_univ (Finset.univ : Finset (G ↾ (M ∆ M')).Loops)).imp fun s => _
    refine' (Finite.exists_finset_univ (Finset.univ : Finset (G ↾ (M ∆ M')).Loops)).imp fun s' => _
    refine' ⟨(G ↾ (M ∆ M') |>.edgeSet.erase s.sUnion id).union (s' : Finset (β)), _⟩
    <;> simp_all [Graph.loopRemove, Graph.subgraph, Finset.subset_iff]
    <;> aesop
  exact h₂
```
