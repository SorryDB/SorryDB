  /-!
  A bird `E` is called *egocentric* if it is fond of itself.
  -/

  -- the definition of egocentricity
  notation E " is " " egocentric " => E ◁ E = E

  section DefiningTheExcitedGoldenEagle

    /-!
      A鸟 `E` is called an *excited golden eagle* if for any other bird `x`,
      it always responds with its own name. That is, it is hopelessly egocentric.
    -/

    -- `EGE` is the excited golden eagle.
    axiom EGE : Bird
    axiom EGE_property : ∀ x : Bird, EGE ◁ x = EGE

    -- If a bird is hopelessly egocentric, then `EGE` is fond of that bird.
    axiom EGE_like : ∀ x : Bird, x is hopelessly egocentric → EGE is fond of x

    -- If `EGE` is fond of a bird, then that bird is hopelessly egocentric.
    axiom EGE_implies : ∀ x : Bird, EGE is fond of x → x is hopelessly egocentric

  section ExampleUsingAxioms

    open DefiningTheExcitedGoldenEagle

    theorem EGE_test : EGE is hopelessly egocentric := by
      intro x
      calc
        EGE ◁ x = EGE := by apply EGE_property
        _ = EGE := by rfl

    theorem EGE_fond_of_EGE : EGE is fond of EGE := by
      have h : EGE is hopelessly egocentric := EGE_test
      have h' : EGE is fond of EGE := by
        have h'' : EGE is fond of EGE := by
          have h''' : EGE is hopelessly egocentric := h
          apply EGE_like
          exact h'''
        exact h''
      exact h'

    theorem EGE_super_test : ∀ x : Bird, EGE is fond of x → x is hopelessly egocentric := by
      intro x h
      apply EGE_implies
      exact h

  end DefiningTheExcitedGoldenEagle

