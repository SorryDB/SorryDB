    axiom compose : Bird → Bird → Bird
    -- notation for composition
    infixr:100 " ∘ " => compose
    -- the definition of composition
    axiom composition (A B : Bird) : ∀ {x : Bird}, (A ∘ B) ◁ x = A ◁ (B ◁ x)

  end ForestCompositionLaw

