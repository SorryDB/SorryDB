  -- If the composition law holds and a mockingbird is in the forest,
  -- then there is a bird that is egocentric.
  theorem exists_egocentric : ∃ E, E is egocentric := by
    have h : M is egocentric ∨ ¬(M is egocentric) := by by_cases h : M is egocentric <;> [exact Or.inl h; exact Or.inr h]
    cases h with
    | inl h =>
      -- Case: The mockingbird is egocentric.
      exact ⟨M, h⟩
    | inr h =>
      -- Case: The mockingbird is not egocentric.
      have h₁ : M ◁ M ≠ M := by
        intro h₂
        have h₃ : M is egocentric := by simpa [egocentric] using h₂
        contradiction
      -- Use the composition to find an egocentric bird.
      have h₂ : (M ∘ M) ◁ M = M ◁ (M ◁ M) := by
        apply composition
      have h₃ : (M ∘ M) is egocentric := by
        have h₄ : (M ∘ M) ◁ (M ∘ M) = M ◁ (M ◁ (M ∘ M)) := by
          have h₅ : (M ∘ M) ◁ (M ∘ M) = M ◁ (M ◁ (M ∘ M)) := by
            calc
              (M ∘ M) ◁ (M ∘ M) = M ◁ (M ◁ (M ∘ M)) := by
                simp [composition]
              _ = M ◁ (M ◁ (M ∘ M)) := by rfl
          exact h₅
        have h₅ : M ◁ (M ◁ (M ∘ M)) = (M ∘ M) := by
          have h₆ : M ◁ (M ∘ M) = (M ∘ M) ◁ (M ∘ M) := by
            simp [M.call, composition]
            <;> simp_all [M.call, composition]
            <;> try simp_all [M.call, composition]
            <;> try simp_all [M.call, composition]
          have h₇ : M ◁ (M ◁ (M ∘ M)) = (M ∘ M) := by
            simp_all [M.call, composition]
            <;> simp_all [M.call, composition]
            <;> try simp_all [M.call, composition]
            <;> try simp_all [M.call, composition]
          exact h₇
        have h₆ : (M ∘ M) ◁ (M ∘ M) = (M ∘ M) := by
          calc
            (M ∘ M) ◁ (M ∘ M) = M ◁ (M ◁ (M ∘ M)) := by
              simp [composition]
            _ = (M ∘ M) := by
              simp_all [M.call, composition]
              <;> simp_all [M.call, composition]
              <;> try simp_all [M.call, composition]
              <;> try simp_all [M.call, composition]
        simpa [egocentric] using h₆
      exact ⟨M ∘ M, h₃⟩
