      "\n  have h₁ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n    have h₂ : ContinuousOn (Φ₃ r) (Ioc 0 1) := Φ₃_contDiffOn.continuousOn\n    have h₃ : ∀ (x : ℝ), x ∈ Ioc 0 1 → |(Φ₃ r) x| ≤ (2 : ℝ) := by\n      intro x hx\n      have h₄ : 0 < x := by exact hx.1\n      have h₅ : x ≤ 1 := by exact hx.2\n      have h₆ : |(Φ₃ r) x| ≤ (2 : ℝ) := by\n        simp only [Φ₃] at *\n        have h₇ : r ≥ 0 := hr\n        have h₈ : 0 < x := h₄\n        have h₉ : x ≤ 1 := h₅\n        have h₁₀ : 0 ≤ r * x := by positivity\n        have h₁₁ : 0 ≤ r * x ^ 2 := by positivity\n        have h₁₂ : 0 ≤ r * x ^ 3 := by positivity\n        have h₁₃ : 0 ≤ r * x ^ 4 := by positivity\n        cases' le_or_lt 0 (Real.sin (r * x) - r * x) with h₁₄ h₁₄ <;>\n          cases' le_or_lt 0 (r * x ^ 2) with h₁₅ h₁₅ <;>\n            cases' le_or_lt 0 (r * x ^ 3) with h₁₆ h₁₆ <;>\n              cases' le_or_lt 0 (r * x ^ 4) with h₁₇ h₁₇ <;>\n                simp_all [abs_of_nonneg, abs_of_neg, le_of_lt, sub_nonneg, sub_nonpos] <;>\n                  (try { linarith }) <;>\n                  (try { nlinarith [Real.sin_le_one (r * x), Real.cos_le_one (r * x), Real.sin_sq_add_cos_sq (r * x)] }) <;>\n                  (try { nlinarith [Real.sin_le_one (r * x), Real.cos_le_one (r * x), Real.sin_sq_add_cos_sq (r * x),\n                    sq_nonneg (r * x), sq_nonneg (r * x - 1)] })\n      exact h₆\n    have h₄ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n      refine' hasFiniteIntegral_of_dominated_by\n        (fun x hx => by\n          have h₅ : ContinuousOn (Φ₃ r) (Ioc 0 1) := Φ₃_contDiffOn.continuousOn\n          have h₆ : x ∈ Ioc 0 1 := hx\n          exact h₅.aestronglyMeasurable.aeMeasurableAt\n        ) (volume.restrict (Ioc 0 1))\n        (fun x hx => by\n          have h₅ : |(Φ₃ r) x| ≤ (2 : ℝ) := h₃ x hx\n          linarith\n        )\n        (hasFiniteIntegral_const ( volume.restrict (Ioc 0 1) ) (2 : ℝ))\n    exact h₄\n  have h₂ : IntegrableOn (Φ₃ r) (Ioc (0 : ℝ) 1) volume := by\n    exact h₁.integrableOn\n  exact h₂",
      "\n  <;>\n  (try norm_num) <;>\n  (try\n    {\n      -- Use the fact that Φ₃ is continuous on the interval [0,1] to show that it has a finite integral.\n      have h₁ : ContinuousOn (fun x : ℝ => Φ₃ r x) (Set.Icc 0 1) := Φ₃_contDiffOn.continuousOn.mono (by\n        intro x hx\n        simp only [Set.mem_Ioc, Set.mem_Icc] at hx ⊢\n        constructor <;> linarith)\n      -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n      have h₂ : BoundedOn (fun x : ℝ => Φ₃ r x) (Set.Icc 0 1) := by\n        -- Prove that Φ₃ is bounded on [0,1]\n        have h₃ : ContinuousOn (fun x : ℝ => Φ₃ r x) (Set.Icc 0 1) := h₁\n        exact IsCompact.boundedOn (isCompact_Icc) h₃\n      -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n      have h₃ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Ioc 0 1)) := by\n        -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n        have h₄ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Icc 0 1)) := by\n          -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n          refine' ContinuousOn.hasFiniteIntegral_of_isCompact _ (isCompact_Icc)\n          -- Use the fact that Φ₃ is continuous on [0,1] to show that it has a finite integral.\n          exact h₁\n        -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n        have h₅ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Ioc 0 1)) := by\n          -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n          have h₆ : volume.restrict (Ioc 0 1) ≤ volume.restrict (Icc 0 1) := by\n            -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n            apply MeasureTheory.Measure.restrict_le_restrict\n            -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n            <;> simp [Set.Ioc_subset_Icc_self]\n          -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n          exact HasFiniteIntegral.of_le (by\n            -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n            exact h₄) (by\n            -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n            simpa using h₆)\n        -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n        exact h₅\n      -- Use the fact that Φ₃ is bounded on [0,1] to show that it has a finite integral.\n      exact h₃\n    }) <;>\n  (try norm_num) <;>\n  (try linarith)",
