      "\n  have h : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by\n    have h₁ : ContinuousOn (Φ₃ r) (Ioc (0 : ℝ) 1) := Φ₃_contDiffOn.continuousOn\n    have h₂ : BddAbove (Set.range (fun x : Ioc (0 : ℝ) 1 => (Φ₃ r) x)) := by\n      -- Prove that the range of Φ₃ r on Ioc(0,1) is bounded above\n      have h₃ : ∀ (x : ℝ), x ∈ Ioc (0 : ℝ) 1 → (Φ₃ r) x ≤ 1 := by\n        intro x hx\n        have h₄ : 0 < x := by exact hx.1\n        have h₅ : x ≤ 1 := by exact hx.2\n        have h₆ : (Φ₃ r) x = Real.sin (x * r) ^ 2 * (1 - x) := by\n          simp [Φ₃, Real.sin_sq]\n          <;> ring_nf\n          <;> field_simp [Real.sin_sq]\n          <;> ring_nf\n        rw [h₆]\n        have h₇ : Real.sin (x * r) ^ 2 ≤ 1 := by\n          have h₈ : Real.sin (x * r) ^ 2 ≤ 1 := by\n            nlinarith [Real.sin_sq_add_cos_sq (x * r)]\n          exact h₈\n        have h₉ : (1 - x : ℝ) ≥ 0 := by\n          linarith\n        have h₁₀ : Real.sin (x * r) ^ 2 * (1 - x) ≤ 1 * (1 - x) := by\n          nlinarith\n        have h₁₁ : (1 : ℝ) * (1 - x) = 1 - x := by ring\n        have h₁₂ : 1 - x ≤ 1 := by linarith\n        nlinarith\n      -- Use the fact that the function is bounded above by 1 to prove the range is bounded above\n      have h₄ : BddAbove (Set.range (fun x : Ioc (0 : ℝ) 1 => (Φ₃ r) x)) := by\n        use 1\n        intro y hy\n        rcases hy with ⟨⟨x, hx⟩, rfl⟩\n        have h₅ : (Φ₃ r) x ≤ 1 := h₃ x ⟨hx.1, hx.2⟩\n        exact h₅\n      exact h₄\n    -- Prove that the integral is finite using the boundedness and continuity of Φ₃ r\n    have h₃ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by\n      apply ContinuousOn.hasFiniteIntegral\n      <;> simp_all [measurableSet_Ioc]\n      <;>\n      (try norm_num) <;>\n      (try linarith) <;>\n      (try\n        {\n          apply IsCompact.exists_forall_le\n          <;>\n          (try\n            {\n              exact isCompact_Icc\n            }) <;>\n          (try\n            {\n              intro x hx\n              simp_all [Ioc, Icc]\n              <;>\n              (try norm_num) <;>\n              (try linarith)\n            }) <;>\n          (try\n            {\n              use 1\n              <;>\n              simp_all [Ioc, Icc]\n              <;>\n              (try norm_num) <;>\n              (try linarith)\n            })\n        }) <;>\n      (try\n        {\n          apply IsCompact.exists_forall_le\n          <;>\n          (try\n            {\n              exact isCompact_Icc\n            }) <;>\n          (try\n            {\n              intro x hx\n              simp_all [Ioc, Icc]\n              <;>\n              (try norm_num) <;>\n              (try linarith)\n            }) <;>\n          (try\n            {\n              use 1\n              <;>\n              simp_all [Ioc, Icc]\n              <;>\n              (try norm_num) <;>\n              (try linarith)\n            })\n        })\n    exact h₃\n  exact h",
      "\n  have h₁ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Ioc 0 1)) := by\n    -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n    have h₂ : ContinuousOn (Φ₃ r) (Set.Icc 0 1) := by\n      -- Prove that Φ₃ is continuous on [0,1]\n      apply ContinuousOn.mono _ (Set.Icc_subset_Icc_right (by norm_num))\n      exact Φ₃_contDiffOn.continuousOn\n    -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n    have h₃ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Ioc 0 1)) := by\n      -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n      have h₄ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Set.Icc 0 1)) := by\n        -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n        apply ContinuousOn.hasFiniteIntegral\n        <;> simp_all [measurableSet_Icc]\n        <;> try norm_num\n        <;> try linarith\n      -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n      have h₅ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Ioc 0 1)) := by\n        -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n        have h₆ : (volume.restrict (Ioc 0 1)) = (volume.restrict (Set.Icc 0 1)).restrict (Ioc 0 1) := by\n          -- Prove that the restriction of the volume to (0,1] is the same as the restriction of the volume to [0,1] restricted to (0,1]\n          simp [MeasureTheory.MeasureRestrictRestrict]\n          <;> congr 1\n          <;> ext x\n          <;> simp [Set.mem_Ioc, Set.mem_Icc]\n          <;> by_cases h : x = 0 <;> simp_all\n          <;> norm_num at *\n          <;> linarith\n        rw [h₆]\n        -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n        have h₇ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Set.Icc 0 1)) := h₄\n        -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n        exact h₇.restrict (measurableSet_Ioc)\n      exact h₅\n    exact h₃\n  -- Use the fact that Φ₃ is continuous on [0,1] and the interval is compact to show it has a finite integral\n  exact h₁",
      "\n  have h : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n    have h₁ : ContinuousOn (Φ₃ r) (Ioc (0 : ℝ) 1) := Φ₃_contDiffOn.continuousOn\n    have h₂ : BoundedOn (Φ₃ r) (Ioc (0 : ℝ) 1) := by\n      -- Show that the function Φ₃ is bounded on (0,1]\n      have h₃ : ∃ (M : ℝ), ∀ (x : ℝ), x ∈ Ioc (0 : ℝ) 1 → |(Φ₃ r) x| ≤ M := by\n        use (∑ k in Finset.range 4, |(a : ℝ) k 3|) * (r + 1)\n        intro x hx\n        have h₄ : x ∈ Ioc (0 : ℝ) 1 := hx\n        have h₅ : 0 < x := by exact hx.1\n        have h₆ : x ≤ 1 := by exact hx.2\n        have h₇ : |(Φ₃ r) x| ≤ (∑ k in Finset.range 4, |(a : ℝ) k 3|) * (r + 1) := by\n          -- Prove that the absolute value of Φ₃ is bounded by the given expression\n          calc\n            |(Φ₃ r) x| = |∑ k in Finset.range 4, (a : ℝ) k 3 * (r * x) ^ (k : ℕ)| := by\n              simp [Φ₃, pow_one, Finset.sum_range_succ]\n              <;>\n              (try norm_num) <;>\n              (try ring_nf) <;>\n              (try simp_all [abs_of_nonneg, abs_of_nonpos, mul_assoc])\n            _ ≤ ∑ k in Finset.range 4, |(a : ℝ) k 3 * (r * x) ^ (k : ℕ)| := by\n              -- Use the triangle inequality for the absolute value of the sum\n              exact calc\n                |∑ k in Finset.range 4, (a : ℝ) k 3 * (r * x) ^ (k : ℕ)| ≤ ∑ k in Finset.range 4, |(a : ℝ) k 3 * (r * x) ^ (k : ℕ)| := by\n                  exact Finset.abs_sum_le_sum_abs _ _\n                _ = ∑ k in Finset.range 4, |(a : ℝ) k 3 * (r * x) ^ (k : ℕ)| := by rfl\n            _ ≤ ∑ k in Finset.range 4, |(a : ℝ) k 3| * |(r * x) ^ (k : ℕ)| := by\n              -- Use the property |a * b| = |a| * |b|\n              exact Finset.sum_le_sum fun k _ => by\n                calc\n                  |(a : ℝ) k 3 * (r * x) ^ (k : ℕ)| = |(a : ℝ) k 3| * |(r * x) ^ (k : ℕ)| := by\n                    rw [abs_mul]\n                  _ ≤ |(a : ℝ) k 3| * |(r * x) ^ (k : ℕ)| := by rfl\n            _ ≤ ∑ k in Finset.range 4, |(a : ℝ) k 3| * (r + 1) ^ (k : ℕ) := by\n              -- Use the fact that x ≤ 1 and r ≥ 0 to bound (r * x)^k\n              have h₈ : ∀ (k : ℕ), k ∈ Finset.range 4 → |(r * x) ^ (k : ℕ)| ≤ (r + 1) ^ (k : ℕ) := by\n                intro k hk\n                have h₉ : k < 4 := Finset.mem_range.mp hk\n                have h₁₀ : 0 ≤ r := hr\n                have h₁₁ : 0 < x := h₅\n                have h₁₂ : x ≤ 1 := h₆\n                have h₁₃ : 0 ≤ r * x := by positivity\n                have h₁₄ : r * x ≤ r := by\n                  nlinarith\n                have h₁₅ : r * x ≤ r + 1 := by linarith\n                have h₁₆ : 0 ≤ (r * x : ℝ) := by positivity\n                have h₁₇ : 0 ≤ (r + 1 : ℝ) := by positivity\n                calc\n                  |(r * x : ℝ) ^ (k : ℕ)| = (r * x : ℝ) ^ (k : ℕ) := by\n                    rw [abs_of_nonneg (by positivity)]\n                  _ ≤ (r + 1 : ℝ) ^ (k : ℕ) := by\n                    exact pow_le_pow_of_le_left (by positivity) (by linarith) _\n                  _ = (r + 1 : ℝ) ^ (k : ℕ) := by norm_cast\n              calc\n                ∑ k in Finset.range 4, |(a : ℝ) k 3| * |(r * x) ^ (k : ℕ)| ≤ ∑ k in Finset.range 4, |(a : ℝ) k 3| * (r + 1) ^ (k : ℕ) := by\n                  exact Finset.sum_le_sum fun k hk => by\n                    have h₁₈ := h₈ k hk\n                    have h₁₉ : 0 ≤ |(a : ℝ) k 3| := abs_nonneg _\n                    have h₂₀ : 0 ≤ (r + 1 : ℝ) ^ (k : ℕ) := by positivity\n                    nlinarith\n                _ = ∑ k in Finset.range 4, |(a : ℝ) k 3| * (r + 1) ^ (k : ℕ) := by rfl\n            _ ≤ ∑ k in Finset.range 4, |(a : ℝ) k 3| * (r + 1) := by\n              -- Since (r + 1)^k ≤ (r + 1)^1 when k = 0, 1, 2, 3 and r + 1 ≥ 1\n              have h₂₁ : ∀ (k : ℕ), k ∈ Finset.range 4 → (r + 1 : ℝ) ^ (k : ℕ) ≤ (r + 1 : ℝ) := by\n                intro k hk\n                have h₂₂ : k < 4 := Finset.mem_range.mp hk\n                have h₂₃ : k ≤ 3 := by linarith\n                interval_cases k <;> norm_num at h₂₂ ⊢ <;>\n                  (try { nlinarith }) <;>\n                  (try { exact le_of_sub_nonneg (by nlinarith [hr]) }) <;>\n                  (try { nlinarith [sq_nonneg (r + 1 - 1)] })\n              calc\n                ∑ k in Finset.range 4, |(a : ℝ) k 3| * (r + 1) ^ (k : ℕ) ≤ ∑ k in Finset.range 4, |(a : ℝ) k 3| * (r + 1) := by\n                  exact Finset.sum_le_sum fun k hk => by\n                    have h₂₄ := h₂₁ k hk\n                    have h₂₅ : 0 ≤ |(a : ℝ) k 3| := abs_nonneg _\n                    have h₂₆ : 0 ≤ (r + 1 : ℝ) := by positivity\n                    nlinarith\n                _ = ∑ k in Finset.range 4, |(a : ℝ) k 3| * (r + 1) := by rfl\n            _ = (∑ k in Finset.range 4, |(a : ℝ) k 3|) * (r + 1) := by\n              -- Factor out (r + 1) from the sum\n              calc\n                ∑ k in Finset.range 4, |(a : ℝ) k 3| * (r + 1) = ∑ k in Finset.range 4, (|(a : ℝ) k 3| * (r + 1)) := by rfl\n                _ = (∑ k in Finset.range 4, |(a : ℝ) k 3|) * (r + 1) := by\n                  simp [Finset.sum_mul]\n        exact h₇\n      -- Use the boundedness to conclude the proof\n      obtain ⟨M, hM⟩ := h₃\n      refine' ⟨M, _⟩\n      intro x hx\n      have h₄ := hM x hx\n      exact h₄\n    -- Use the fact that the function is continuous and bounded to show it has a finite integral\n    have h₃ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n      apply ContinuousOn.hasFiniteIntegral\n      <;>\n      (try simp_all) <;>\n      (try norm_num) <;>\n      (try assumption) <;>\n      (try\n        {\n          refine' IsCompact.exists_forall_le _ _ ⟨1, by norm_num⟩ <;>\n            (try continuity) <;>\n            (try\n              {\n                refine' ⟨0, by norm_num⟩\n                <;> norm_num\n              }) <;>\n            (try\n              {\n                refine' ⟨1, by norm_num⟩\n                <;> norm_num\n              })\n        }) <;>\n      (try\n        {\n          refine' IsCompact.exists_forall_ge _ _ ⟨0, by norm_num⟩ <;>\n            (try continuity) <;>\n            (try\n              {\n                refine' ⟨0, by norm_num⟩\n                <;> norm_num\n              }) <;>\n            (try\n              {\n                refine' ⟨1, by norm_num⟩\n                <;> norm_num\n              })\n        })\n      <;>\n      (try\n        {\n          simp_all [Ioc, Set.Ioc_subset_Iic_self]\n          <;>\n          (try norm_num) <;>\n          (try linarith)\n        })\n      <;>\n      (try\n        {\n          exact isCompact_Icc\n        })\n    exact h₃\n  -- Use the fact that the function has a finite integral to conclude the proof\n  have h₁ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := h\n  have h₂ : IntegrableOn (Φ₃ r) (Ioc (0 : ℝ) 1) volume := by\n    rw [IntegrableOn]\n    exact h₁\n  exact h₂",
      "\n  have h : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n    have h₁ : ContinuousOn (fun x : ℝ => Φ₃ r x) (Ioc 0 1) := Φ₃_contDiffOn.continuousOn\n    have h₂ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Ioc 0 1)) :=\n      (hasFiniteIntegral_of_ae_stronglyMeasurable (Continuous.aestronglyMeasurable (by\n        apply ContinuousOn.continuous\n        exact Φ₃_contDiffOn.continuousOn\n      )) (by\n        -- Use the fact that Φ₃ r is bounded on [0, 1] to show it has finite integral\n        have h₃ : BddAbove (Set.range (fun x : ℝ => Φ₃ r x)) := by\n          -- Prove that Φ₃ r is bounded above on [0, 1]\n          have h₄ : ContinuousOn (fun x : ℝ => Φ₃ r x) (Icc 0 1) := by\n            apply ContinuousOn.mono Φ₃_contDiffOn.continuousOn\n            intro x hx\n            simp at hx ⊢\n            <;>\n            (try norm_num at hx ⊢) <;>\n            (try linarith) <;>\n            (try exact ⟨by linarith, by linarith⟩)\n          have h₅ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n          have h₆ : BddAbove (Set.range (fun x : ℝ => Φ₃ r x)) := by\n            -- Use the fact that a continuous function on a compact set is bounded\n            have h₇ : BddAbove (Set.image (fun x : ℝ => Φ₃ r x) (Icc 0 1)) := by\n              apply isCompact_Icc.bddAbove_image\n              exact h₄\n            have h₈ : Set.image (fun x : ℝ => Φ₃ r x) (Icc 0 1) ⊆ Set.range (fun x : ℝ => Φ₃ r x) := by\n              intro y hy\n              simp only [Set.mem_image, Set.mem_range] at hy ⊢\n              obtain ⟨x, hx, rfl⟩ := hy\n              exact ⟨x, rfl⟩\n            exact Set.bddAbove.mono h₈ h₇\n          exact h₆\n        have h₉ : BddBelow (Set.range (fun x : ℝ => Φ₃ r x)) := by\n          -- Prove that Φ₃ r is bounded below on [0, 1]\n          have h₁₀ : ContinuousOn (fun x : ℝ => Φ₃ r x) (Icc 0 1) := by\n            apply ContinuousOn.mono Φ₃_contDiffOn.continuousOn\n            intro x hx\n            simp at hx ⊢\n            <;>\n            (try norm_num at hx ⊢) <;>\n            (try linarith) <;>\n            (try exact ⟨by linarith, by linarith⟩)\n          have h₁₁ : IsCompact (Icc (0 : ℝ) 1) := isCompact_Icc\n          have h₁₂ : BddBelow (Set.range (fun x : ℝ => Φ₃ r x)) := by\n            -- Use the fact that a continuous function on a compact set is bounded\n            have h₁₃ : BddBelow (Set.image (fun x : ℝ => Φ₃ r x) (Icc 0 1)) := by\n              apply isCompact_Icc.bddBelow_image\n              exact h₁₀\n            have h₁₄ : Set.image (fun x : ℝ => Φ₃ r x) (Icc 0 1) ⊆ Set.range (fun x : ℝ => Φ₃ r x) := by\n              intro y hy\n              simp only [Set.mem_image, Set.mem_range] at hy ⊢\n              obtain ⟨x, hx, rfl⟩ := hy\n              exact ⟨x, rfl⟩\n            exact Set.bddBelow.mono h₁₄ h₁₃\n          exact h₁₂\n        have h₁₅ : ∃ (a b : ℝ), ∀ (x : ℝ), a ≤ Φ₃ r x ∧ Φ₃ r x ≤ b := by\n          -- Use the boundedness to find a and b\n          obtain ⟨b, hb⟩ := h₃\n          obtain ⟨a, ha⟩ := h₉\n          refine' ⟨a, b, _⟩\n          intro x\n          constructor <;>\n          (try simp_all [Set.mem_range]) <;>\n          (try {\n            have h₁₆ : Φ₃ r x ≤ b := by\n              have h₁₇ : Φ₃ r x ∈ Set.range (fun x : ℝ => Φ₃ r x) := by\n                exact Set.mem_range_self x\n              have h₁₈ : Φ₃ r x ≤ b := by\n                have h₁₉ : Φ₃ r x ∈ Set.range (fun x : ℝ => Φ₃ r x) := by\n                  exact Set.mem_range_self x\n                have h₂₀ : b ≥ Φ₃ r x := by\n                  have h₂₁ : b ≥ Φ₃ r x := by\n                    -- Use the fact that b is an upper bound for the range of Φ₃ r\n                    have h₂₂ : ∀ (y : ℝ), y ∈ Set.range (fun x : ℝ => Φ₃ r x) → y ≤ b := by\n                      intro y hy\n                      exact hb hy\n                    have h₂₃ : Φ₃ r x ∈ Set.range (fun x : ℝ => Φ₃ r x) := by\n                      exact Set.mem_range_self x\n                    exact h₂₂ (Φ₃ r x) h₂₃\n                  linarith\n                linarith\n              linarith\n            linarith\n          }) <;>\n          (try {\n            have h₁₆ : a ≤ Φ₃ r x := by\n              have h₁₇ : Φ₃ r x ∈ Set.range (fun x : ℝ => Φ₃ r x) := by\n                exact Set.mem_range_self x\n              have h₁₈ : a ≤ Φ₃ r x := by\n                have h₁₉ : Φ₃ r x ∈ Set.range (fun x : ℝ => Φ₃ r x) := by\n                  exact Set.mem_range_self x\n                have h₂₀ : a ≤ Φ₃ r x := by\n                  have h₂₁ : a ≤ Φ₃ r x := by\n                    -- Use the fact that a is a lower bound for the range of Φ₃ r\n                    have h₂₂ : ∀ (y : ℝ), y ∈ Set.range (fun x : ℝ => Φ₃ r x) → a ≤ y := by\n                      intro y hy\n                      exact ha hy\n                    have h₂₃ : Φ₃ r x ∈ Set.range (fun x : ℝ => Φ₃ r x) := by\n                      exact Set.mem_range_self x\n                    exact h₂₂ (Φ₃ r x) h₂₃\n                  linarith\n                linarith\n              linarith\n            linarith\n          })\n        -- Use the boundedness to show the function has finite integral\n        obtain ⟨a, b, h₁₆⟩ := h₁₅\n        refine' integrableOn_Ioc_of_bounded (by\n          -- Prove that the interval (0, 1] has finite volume\n          norm_num [volume_Ioc]\n          <;>\n          (try positivity)\n          <;>\n          (try linarith)\n        ) (by\n          -- Prove that Φ₃ r is bounded by a and b on (0, 1]\n          intro x hx\n          have h₁₇ := h₁₆ x\n          constructor <;> linarith\n        )\n        <;>\n        (try norm_num)\n        <;>\n        (try linarith)\n      ))\n    exact h₂\n  -- Use the fact that Φ₃ r has finite integral to conclude integrability\n  exact h.integrableOn",
