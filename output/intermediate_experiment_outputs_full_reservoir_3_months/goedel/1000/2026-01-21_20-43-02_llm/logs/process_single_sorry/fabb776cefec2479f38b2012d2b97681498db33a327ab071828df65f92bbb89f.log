      "\n  -- We use the fact that the function is continuous on the interval to establish integrability.\n  have h₃ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n    -- Use the fact that the function is continuous and the interval is compact to conclude that the integral is finite.\n    have h₃₁ : ContinuousOn (Φ₃ r) (Ioc (0 : ℝ) 1) := Φ₃_contDiffOn.continuousOn\n    have h₃₂ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) :=\n      -- Use the fact that the function is continuous on a compact set to conclude that the integral is finite.\n      ContinuousOn.hasFiniteIntegral (by\n        -- Use the fact that the interval is bounded and the function is continuous to conclude that the integral is finite.\n        have h₃₃ : IsCompact (Icc 0 1) := isCompact_Icc\n        have h₃₄ : (∀ x ∈ Ioc (0 : ℝ) 1, x ∈ Icc 0 1) := by\n          intro x hx\n          simp only [Ioc, Icc, Set.mem_setOf_eq] at hx ⊢\n          constructor <;> linarith\n        exact h₃₃.of_isClosed (by\n          -- Use the fact that the set is closed to conclude that it is compact.\n          have h₃₅ : IsClosed (Icc 0 1) := isClosed_Icc\n          exact h₃₅\n          ) h₃₄\n      ) h₃₁\n    exact h₃₂\n  exact h₃",
