      "\n  refine' hasFiniteIntegral_of_continuousOn_and_boundedOn (by continuity) _\n  <;>\n  ( try norm_num ) <;>\n  ( try\n    {\n      refine' ⟨3, by norm_num, _⟩\n      intro x hx\n      simp only [Ioc, Set.mem_setOf_eq] at hx\n      norm_num at hx ⊢\n      <;>\n      ( try\n        {\n          have h₁ : 0 < x := by linarith\n          have h₂ : x ≤ 1 := by linarith\n          have h₃ : 0 ≤ r := by assumption\n          norm_num [Φ₃] at *\n          <;>\n          ( try { nlinarith [Real.sqrt_nonneg 3, Real.sqrt_nonneg 2, Real.sqrt_nonneg x,\n                            Real.sqrt_nonneg (1 - x), Real.sq_sqrt (show 0 ≤ 3 by norm_num),\n                            Real.sq_sqrt (show 0 ≤ 2 by norm_num), Real.sq_sqrt (show 0 ≤ x by linarith),\n                            Real.sq_sqrt (show 0 ≤ 1 - x by linarith)] }) <;>\n          ( try { field_simp [h₁.ne'] <;>\n                   nlinarith [Real.sqrt_nonneg 3, Real.sqrt_nonneg 2, Real.sqrt_nonneg x,\n                              Real.sqrt_nonneg (1 - x), Real.sq_sqrt (show 0 ≤ 3 by norm_num),\n                              Real.sq_sqrt (show 0 ≤ 2 by norm_num), Real.sq_sqrt (show 0 ≤ x by linarith),\n                              Real.sq_sqrt (show 0 ≤ 1 - x by linarith)] }) <;>\n          ( try { positivity })\n        }) <;>\n      ( try { nlinarith })\n    }) <;>\n  ( try\n    {\n      refine' ⟨3, by norm_num, _⟩\n      intro x hx\n      simp only [Ioc, Set.mem_setOf_eq] at hx\n      norm_num at hx ⊢\n      <;>\n      ( try\n        {\n          have h₁ : 0 < x := by linarith\n          have h₂ : x ≤ 1 := by linarith\n          have h₃ : 0 ≤ r := by assumption\n          norm_num [Φ₃] at *\n          <;>\n          ( try { nlinarith [Real.sqrt_nonneg 3, Real.sqrt_nonneg 2, Real.sqrt_nonneg x,\n                            Real.sqrt_nonneg (1 - x), Real.sq_sqrt (show 0 ≤ 3 by norm_num),\n                            Real.sq_sqrt (show 0 ≤ 2 by norm_num), Real.sq_sqrt (show 0 ≤ x by linarith),\n                            Real.sq_sqrt (show 0 ≤ 1 - x by linarith)] }) <;>\n          ( try { field_simp [h₁.ne'] <;>\n                   nlinarith [Real.sqrt_nonneg 3, Real.sqrt_nonneg 2, Real.sqrt_nonneg x,\n                              Real.sqrt_nonneg (1 - x), Real.sq_sqrt (show 0 ≤ 3 by norm_num),\n                              Real.sq_sqrt (show 0 ≤ 2 by norm_num), Real.sq_sqrt (show 0 ≤ x by linarith),\n                              Real.sq_sqrt (show 0 ≤ 1 - x by linarith)] }) <;>\n          ( try { positivity })\n        }) <;>\n      ( try { nlinarith })\n    })\n  <;>\n  ( try norm_num )\n  <;>\n  ( try linarith )",
      "\n  -- Use the fact that the function is continuous on a compact set to show it is integrable\n  have h₁ : ContinuousOn (Φ₃ r) (Icc 0 1) := by\n    apply ContinuousOn.mono Φ₃_contDiffOn.continuousOn\n    intro x hx\n    simp only [Icc, Ioc, Set.mem_setOf_eq] at hx ⊢\n    <;> (try cases hx <;> simp_all [le_of_lt]) <;>\n    (try { nlinarith }) <;>\n    (try { linarith })\n  -- Use the fact that the function is continuous on a compact set to show it is integrable\n  have h₂ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n    -- Use the fact that the function is continuous on a compact set to show it is integrable\n    refine' (hasFiniteIntegral_of_ae_stronglyMeasurable _ (by\n      -- Use the fact that the function is continuous on a compact set to show it is integrable\n      refine' (ContinuousOn.aestronglyMeasurable _ measurableSet_Ioc).mono _\n      intro x hx\n      simp only [Ioc, Set.mem_setOf_eq] at hx ⊢\n      <;> (try cases hx <;> simp_all [le_of_lt]) <;>\n      (try { nlinarith }) <;>\n      (try { linarith })) _)\n    · -- Use the fact that the function is continuous on a compact set to show it is integrable\n      exact by\n        refine' (h₁.compact_Icc_ae_restrict_mem _)\n        <;>\n        (try simp [hr])\n        <;>\n        (try norm_num)\n        <;>\n        (try continuity)\n        <;>\n        (try assumption)\n        <;>\n        (try linarith)\n    · -- Use the fact that the function is continuous on a compact set to show it is integrable\n      refine' (by\n        -- Use the fact that the function is continuous on a compact set to show it is integrable\n        norm_num\n        <;>\n        (try simp_all [hr])\n        <;>\n        (try norm_num)\n        <;>\n        (try linarith))\n  -- Use the fact that the function is continuous on a compact set to show it is integrable\n  exact h₂",
      "\n  have h₁ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n    have h₂ : ContinuousOn (Φ₃ r) (Ioc (0 : ℝ) 1) := Φ₃_contDiffOn.continuousOn\n    have h₃ : (Ioc (0 : ℝ) 1 : Set ℝ).Compact := compact_Ioc 0 1\n    have h₄ : (0 : ℝ) < 1 := by norm_num\n    -- Use the fact that Φ₃ is continuous on the compact set [0,1] to conclude that it has a finite integral\n    have h₅ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by\n      apply hasFiniteIntegral_of_ae_stronglyMeasurable_of_dominated_loc_of_bounded_open\n      <;>\n      (try\n        {\n          apply ContinuousOn.aestronglyMeasurable\n          <;> simp_all [ContinuousOn]\n        })\n      <;>\n      (try\n        {\n          -- Use a suitable dominating function, e.g., 1, since Φ₃ is bounded on [0,1]\n          refine' ⟨1, _, _, _⟩\n          <;>\n          (try norm_num) <;>\n          (try\n            {\n              simp_all [ContinuousOn]\n              <;>\n              (try\n                {\n                  apply ContinuousOn.mul\n                  <;>\n                  (try\n                    {\n                      apply ContinuousOn.pow\n                      <;>\n                      (try\n                        {\n                          apply ContinuousOn.sub\n                          <;>\n                          (try\n                            {\n                              apply ContinuousOn.div\n                              <;>\n                              simp_all [ContinuousOn]\n                              <;>\n                              (try\n                                {\n                                  norm_num\n                                })\n                            })\n                        })\n                    })\n                })\n            }) <;>\n          (try\n            {\n              simp_all [ContinuousOn]\n              <;>\n              (try norm_num) <;>\n              (try\n                {\n                  apply ContinuousOn.mul\n                  <;>\n                  (try\n                    {\n                      apply ContinuousOn.pow\n                      <;>\n                      (try\n                        {\n                          apply ContinuousOn.sub\n                          <;>\n                          (try\n                            {\n                              apply ContinuousOn.div\n                              <;>\n                              simp_all [ContinuousOn]\n                              <;>\n                              (try\n                                {\n                                  norm_num\n                                })\n                            })\n                        })\n                    })\n                })\n            })\n        })\n      <;>\n      (try\n        {\n          simp_all [ContinuousOn]\n          <;>\n          (try norm_num) <;>\n          (try\n            {\n              apply ContinuousOn.mul\n              <;>\n              (try\n                {\n                  apply ContinuousOn.pow\n                  <;>\n                  (try\n                    {\n                      apply ContinuousOn.sub\n                      <;>\n                      (try\n                        {\n                          apply ContinuousOn.div\n                          <;>\n                          simp_all [ContinuousOn]\n                          <;>\n                          (try\n                            {\n                              norm_num\n                            })\n                        })\n                    })\n                })\n            })\n        })\n      <;>\n      (try\n        {\n          -- Bounding Φ₃ by a constant on [0,1]\n          have h₆ : ∀ x ∈ Ioc (0 : ℝ) 1, |(Φ₃ r) x| ≤ 1 := by\n            intro x hx\n            -- Prove that Φ₃ is bounded by 1 on [0,1]\n            have h₇ : x ∈ Ioc (0 : ℝ) 1 := hx\n            have h₈ : 0 < x := by\n              simp only [Ioc, mem_setOf_eq] at h₇\n              linarith\n            have h₉ : x ≤ 1 := by\n              simp only [Ioc, mem_setOf_eq] at h₇\n              linarith\n            -- Normalize the expression for Φ₃ and bound it\n            norm_num [Φ₃] at *\n            <;>\n            (try\n              {\n                field_simp\n                <;>\n                ring_nf\n                <;>\n                norm_num\n                <;>\n                (try\n                  {\n                    rw [abs_of_nonneg]\n                    <;>\n                    (try\n                      {\n                        positivity\n                      })\n                  })\n                <;>\n                (try\n                  {\n                    nlinarith [sq_nonneg (x - 1)]\n                  })\n              })\n          -- Use the bound to conclude the proof\n          filter_upwards [self_mem_ae_restrict measurableSet_Ioc] with x hx\n          have h₁₀ : x ∈ Ioc (0 : ℝ) 1 := hx\n          have h₁₁ : |(Φ₃ r) x| ≤ 1 := h₆ x h₁₀\n          linarith\n        })\n    exact h₅\n  exact h₁.integrableOn",
