        _ = 1 := by rw [h₃]
        _ < ∞ := by norm_num
    exact h₄
  -- Conclude that Φ₃(r) is integrable on (0,1]
  have h₂ : HasFiniteIntegral (Φ₃ r) (volume.restrict (Ioc 0 1)) := by
