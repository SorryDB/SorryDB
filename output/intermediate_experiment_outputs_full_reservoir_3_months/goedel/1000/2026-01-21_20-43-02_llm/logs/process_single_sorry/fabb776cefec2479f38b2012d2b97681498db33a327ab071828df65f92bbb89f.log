      "\n  <;>\n  (try simp_all)\n  <;>\n  (try norm_num)\n  <;>\n  (try linarith)\n  <;>\n  (try\n    {\n      apply (hasCompactSupport.integrableOn_of_nonneg fun x => by\n        { -- Prove non-negativity of Φ₃ r\n          have h₁ : 0 ≤ r := hr\n          have h₂ : 0 ≤ (Φ₃ r) x := by\n            -- Prove Φ₃ r is non-negative\n            sorry\n          exact h₂\n        }\n      ).compactlyClose\n      <;>\n      simp_all [isCompact_Icc]\n      <;>\n      (try norm_num)\n      <;>\n      (try linarith)\n    })\n  <;>\n  (try\n    {\n      -- Use the fact that the function is continuous and bounded to prove integrability\n      apply integrableOn_of_continuousOn_of_bounded (Φ₃_contDiffOn.continuousOn)\n      <;>\n      (try\n        {\n          -- Prove the function is bounded on [0, 1]\n          use 1\n          <;>\n          intro x hx\n          <;>\n          norm_num at hx ⊢\n          <;>\n          (try linarith)\n          <;>\n          (try\n            {\n              have h₁ : 0 ≤ r := hr\n              have h₂ : (Φ₃ r) x ≤ 1 := by\n                -- Prove Φ₃ r ≤ 1\n                sorry\n              linarith\n            })\n        })\n    })\n  <;>\n  (try\n    {\n      -- Use the fact that the function is continuous and bounded to prove integrability\n      apply integrableOn_of_continuousOn_of_bounded (Φ₃_contDiffOn.continuousOn)\n      <;>\n      (try\n        {\n          -- Prove the function is bounded on [0, 1]\n          use 1\n          <;>\n          intro x hx\n          <;>\n          norm_num at hx ⊢\n          <;>\n          (try linarith)\n          <;>\n          (try\n            {\n              have h₁ : 0 ≤ r := hr\n              have h₂ : (Φ₃ r) x ≤ 1 := by\n                -- Prove Φ₃ r ≤ 1\n                sorry\n              linarith\n            })\n        })\n    })",
      "\n  have h₁ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Ioc 0 1)) := by\n    -- Prove that Φ₃ r is bounded on (0, 1]\n    have h₂ : ∀ x ∈ Ioc (0 : ℝ) 1, |(Φ₃ r x : ℝ)| ≤ 1 := by\n      intro x hx\n      have h₃ : 0 < x := by exact hx.1\n      have h₄ : x ≤ 1 := by exact hx.2\n      have h₅ : |(Φ₃ r x : ℝ)| ≤ 1 := by\n        -- Use the fact that Φ₃ r is bounded by 1 on (0, 1]\n        have h₆ : (Φ₃ r x : ℝ) = Real.sin (r * x) / x := by\n          simp [Φ₃]\n          <;> ring_nf\n          <;> field_simp\n          <;> ring_nf\n        rw [h₆]\n        have h₇ : |Real.sin (r * x) / x| ≤ 1 := by\n          -- Prove that |sin(r * x) / x| ≤ 1 for x ∈ (0, 1]\n          have h₈ : |Real.sin (r * x)| ≤ 1 := Real.abs_sin_le_one (r * x)\n          have h₉ : 0 < x := h₃\n          have h₁₀ : 0 < x := h₃\n          calc\n            |Real.sin (r * x) / x| = |Real.sin (r * x)| / x := by\n              simp [abs_div, abs_of_pos h₉]\n            _ ≤ 1 / x := by gcongr\n            _ ≤ 1 := by\n              have h₁₁ : x ≤ 1 := h₄\n              have h₁₂ : 0 < x := h₃\n              have h₁₃ : 1 / x ≥ 1 := by\n                rw [ge_iff_le]\n                rw [le_div_iff h₁₂]\n                nlinarith\n              have h₁₄ : 1 / x ≤ 1 := by\n                have h₁₅ : x ≥ 1 → 1 / x ≤ 1 := by\n                  intro h₁₅\n                  have h₁₆ : 1 / x ≤ 1 := by\n                    rw [div_le_iff (by positivity)]\n                    nlinarith\n                  exact h₁₆\n                by_cases h₁₅ : x ≥ 1\n                · exact h₁₅ h₁₅\n                · have h₁₆ : x < 1 := by linarith\n                  have h₁₇ : 1 / x > 1 := by\n                    rw [gt_iff_lt]\n                    rw [lt_div_iff (by positivity)]\n                    nlinarith\n                  linarith\n              linarith\n          <;> try norm_num\n          <;> linarith\n        exact h₇\n      exact h₅\n    -- Use the boundedness to show that the integral is fini