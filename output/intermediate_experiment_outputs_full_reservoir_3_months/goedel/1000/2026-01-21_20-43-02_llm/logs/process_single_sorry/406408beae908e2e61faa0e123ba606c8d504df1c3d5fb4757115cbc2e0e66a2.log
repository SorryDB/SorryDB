```lean
theorem refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  intro N hN
  -- For each N in D, we need to find a subset of refinement B hB hB' hB'' whose sSup is N.
  have hB''' : ∃ B : Set (PersistenceSubmodule M), B ⊆ (⋃ N, ⋃ hN, B N hN) ∧ N = sSup B := by
    refine ⟨B N hN, _, _⟩
    · -- Show that B N hN is a subset of the union.
      intro x hx
      exact Set.mem_iUnion.mpr ⟨N, _⟩ (Set.mem_iUnion.mpr ⟨hN, hx⟩)
    · -- Show that the sSup of B N hN is N.
      rw [hB N hN]
  -- Use the above result to find the required subset.
  obtain ⟨B', hB'₁, hB'₂⟩ := hB'''
  refine ⟨B', _, _⟩
  · -- Prove that B' is a subset of the refinement.
    exact hB'₁
  · -- Prove that the sSup of B' is N.
    exact hB'₂
