lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  intro N hN
  use {N}
  constructor
  · intro p hp
    simp_all [SetLike.coe_mem]
    <;> aesop
  · have h₁ : N = sSup ({N} : Set (PersistenceSubmodule M)) := by
      simp [sSup_singleton]
    have h₂ : sSup ({N} : Set (PersistenceSubmodule M)) = sSup (B N hN) := by
      rw [h₁]
      <;> rw [hB N hN]
    rw [h₂] at *
  <;> simp_all [SetLike.coe_mem]
  <;> aesop
