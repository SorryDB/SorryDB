lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  intro N hN
  have h₁ : N = sSup (B N hN) := hB N hN
  use B N hN
  constructor
  · -- Prove that B N hN ⊆ refinement B hB hB' hB''
    simp [Set.subset_def, Set.mem_iUnion]
