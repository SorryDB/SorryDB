theorem exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : {n : Int | even n} = {n : Int | n % 2 = 0} := by
    ext n
    simp [Int.even_iff]
    <;>
    (try omega) <;>
    (try
      {
        cases' Int.emod_two_eq_zero_or_one n with h h <;>
        simp_all [h] <;>
        omega
      })
  rw [h]
  -- Show that the set of integers divisible by 2 is equivalent to the integers
  have h₁ : {n : Int | n % 2 = 0} ≃ (Int : Type) := by
    -- Define the bijection
    use fun n => n / 2
    -- Define the inverse function
    use fun n => 2 * n
    constructor
    · -- Prove that the composition of the functions is the identity
      intro n
      have h₂ : (n / 2 : Int) * 2 = n := by
        have h₃ : n % 2 = 0 := by simpa using n.prop
        have h₄ : (n : Int) = 2 * (n / 2) := by
          have h₅ : (n : Int) % 2 = 0 := by simpa using h₃
          have h₆ : (n : Int) = 2 * (n / 2) := by
            omega
          exact h₆
        linarith
