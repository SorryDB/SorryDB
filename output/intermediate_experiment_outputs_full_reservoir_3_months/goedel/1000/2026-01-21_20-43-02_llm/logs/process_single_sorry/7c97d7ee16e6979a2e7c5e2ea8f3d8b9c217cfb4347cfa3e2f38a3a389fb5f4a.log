    have h₃ : (image g) (image f s) = s := by
      calc
        (image g) (image f s) = {x | ∃ y ∈ image f s, g y = x} := rfl
        _ = {x | ∃ y, (∃ z ∈ s, f z = y) ∧ g y = x} := by
