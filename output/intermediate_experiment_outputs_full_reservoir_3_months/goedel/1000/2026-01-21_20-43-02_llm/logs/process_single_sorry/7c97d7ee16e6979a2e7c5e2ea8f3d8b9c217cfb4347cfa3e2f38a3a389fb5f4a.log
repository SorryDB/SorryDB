lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  have h₁ : ∀ (s : Set U), (image g) (image f s) = s := by
    intro s
    apply Set.ext
    intro x
    have h₂ : x ∈ (image g) (image f s) ↔ x ∈ s := by
      constructor
      · -- Prove the forward direction: if x ∈ (image g) (image f s), then x ∈ s
        intro hx
        obtain ⟨y, hy, rfl⟩ := hx
        obtain ⟨z, hz, rfl⟩ := hy
        have h₃ := congr_fun h z
        simp at h₃
        exact hz
      · -- Prove the backward direction: if x ∈ s, then x ∈ (image g) (image f s)
        intro hx
        have h₃ : f x ∈ Set.univ := Set.mem_univ _
        have h₄ : g (f x) = x := by
          have h₅ := congr_fun h x
          simp at h₅
          <;> simp_all [Function.comp_apply]
          <;> aesop
        refine' ⟨f x, _, _⟩
        · -- Show that f x ∈ image f s
          refine' ⟨x, hx, rfl⟩
        · -- Show that x = g (f x)
          rw [h₄]
    exact h₂
  funext s
  exact h₁ s
