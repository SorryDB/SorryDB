lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  have h₁ : ∀ x : U, g (f x) = x := by
    intro x
    have h₂ := congr_fun h x
    simpa using h₂
  ext s
  apply Set.ext
  intro x
  simp only [Function.comp_apply, image_image]
  constructor
  · -- Prove the forward inclusion: if x ∈ image g (image f s), then x ∈ s
    intro hx
    rcases hx with ⟨y, ⟨z, hz, rfl⟩, rfl⟩
    have h₂ := h₁ z
    aesop
  · -- Prove the reverse inclusion: if x ∈ s, then x ∈ image g (image f s)
    intro hx
    have h₂ : f x ∈ image f s := by
      exact ⟨x, hx, rfl⟩
    have h₃ : g (f x) ∈ {y | ∃ z, z ∈ image f s ∧ g z = y} := by
      exact ⟨f x, h₂, rfl⟩
    have h₄ : g (f x) = x := h₁ x
    rw [h₄] at h₃
    exact h₃
``` 

