theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : Denumerate (fun n : ℤ => 2 * n) (Set.range (fun n : ℕ => (2 * (n : ℤ)))) := by
    refine' ⟨fun n m h => _, _⟩
    · -- Injectivity
      simp [Int.emod_eq_emod_iff_emod_sub_eq_zero] at h ⊢
      <;> ring_nf at h ⊢ <;> norm_cast at h ⊢ <;> omega
    · -- Surjectivity onto the range
      rintro ⟨n, rfl⟩ <;> use n <;> simp [mul_comm]
      <;> ring_nf
      <;> norm_cast
      <;> simp [even_iff_two_dvd]
      <;> use n <;> ring
  -- Show that the set of even integers is in bijection with ℕ
  have h₁ : {n : ℤ | even n} = Set.range (fun n : ℕ => (2 * (n : ℤ))) := by
    apply Set.Subset.antisymm
    · -- {n : ℤ | even n} ⊆ Set.range (fun n : ℕ => (2 * (n : ℤ)))
      intro x hx
      rw [even_iff_two_dvd] at hx
      obtain ⟨k, rfl⟩ := hx
      have h₂ : ∃ n : ℕ, (2 : ℤ) * n = 2 * k := by
        by_cases hk : k ≥ 0
        · -- Case: k ≥ 0
          use k.toNat
          simp [hk, Int.toNat_of_nonneg hk]
          <;> ring_nf
          <;> norm_cast
          <;> omega
        · -- Case: k < 0
          use (-k).toNat
          have h₃ : k < 0 := by linarith
          have h₄ : (-k : ℤ) > 0 := by linarith
          simp [h₃, h₄, Int.toNat_of_nonneg (by linarith : (0 : ℤ) ≤ -k)]
          <;> ring_nf at *
          <;> norm_cast at *
          <;> omega
      obtain ⟨n, hn⟩ := h₂
      refine' ⟨n, _⟩
      simp_all [mul_comm]
      <;> ring_nf at *
      <;> norm_cast at *
      <;> omega
    · -- Set.range (fun n : ℕ => (2 * (n : ℤ))) ⊆ {n : ℤ | even n}
      intro x hx
      rw [even_iff_two_dvd]
      obtain ⟨n, rfl⟩ := hx
      use n
      <;> simp [Int.mul_emod]
      <;> ring_nf
      <;> norm_cast
      <;> simp [Int.emod_emod]
  -- Use the bijection to show denumerability
  have h₂ : Denumerate (fun n : ℕ => (2 * (n : ℤ))) {n : ℤ | even n} := by
    rw [h₁]
    exact ⟨fun x y h => by simp_all [mul_left_inj], fun y => ⟨y / 2, by
      have h₃ : (2 : ℤ) * (y / 2 : ℕ) = y := by
        have h₄ : y % 2 = 0 := by
          simp_all [Int.emod_eq_emod_iff_emod_sub_eq_zero]
          <;> omega
        have h₅ : (y : ℤ) % 2 = 0 := by
          omega
        have h₆ : (y : ℤ) = 2 * (y / 2) := by
          omega
        omega
      simp_all [mul_comm]⟩⟩
  -- Conclude that the set of even integers is denumerable
  exact ⟨(fun n : ℕ => (2 * (n : ℤ))), h₂⟩
