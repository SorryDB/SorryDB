```lean
lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  have h1 : ∀ (s : Set U), (image g) ((image f) s) = s := by
    intro s
    apply Set.Subset.antisymm
    · -- Prove (image g) ((image f) s) ⊆ s
      intro x hx
      -- hx : x ∈ g '' (f '' s)
      -- So there exists y ∈ f '' s such that g y = x
      rcases hx with ⟨y, ⟨z, hz, rfl⟩, rfl⟩
      -- z ∈ s, f z = y, g y = x
      have h2 : g (f z) = z := by
        have h3 : (g ∘ f) z = z := by
          rw [h]
          <;> simp
        exact h3
      -- g (f z) = z and g (f z) = x, so z = x
      <;> simp_all [h2]
      <;> aesop
    · -- Prove s ⊆ (image g) ((image f) s)
      intro x hx
      -- hx : x ∈ s
      -- We need to find y ∈ f '' s such that g y = x
      have h2 : f x ∈ (image f) s := by
        exact ⟨x, hx, rfl⟩
      -- x = g (f x), so g (f x) ∈ g '' (f '' s)
      have h3 : g (f x) = x := by
        have h4 : (g ∘ f) x = x := by
          rw [h]
          <;> simp
        exact h4
      have h4 : x ∈ (image g) ((image f) s) := by
        refine' ⟨f x, h2, _⟩
        rw [h3]
      exact h4
  -- Now, for any set s, (image g) ∘ (image f) s = s
  funext s
  exact h1 s
``` 

