  have h₁ : denumerable {n : Int | even n} := by
    -- Define a bijection between the set of even integers and the set of all integers
    have h₂ : {n : Int | even n} ≃ ℤ := by
      -- Use the fact that the set of even integers is in bijection with the set of all integers
      -- via the map n ↦ n/2
      let f : {n : Int | even n} → ℤ := fun ⟨n, hn⟩ => n / 2
      let g : ℤ → {n : Int | even n} := fun n => ⟨2 * n, by
        -- Show that 2 * n is even
        simp [Int.even_mul, Int.even_iff]
        <;> omega
        ⟩
      -- Prove that f and g are inverses of each other
      refine' ⟨f, g, _, _, _⟩
      · -- Prove that f ∘ g = id
        intro n
        simp [f, g]
        <;> ring_nf
        <;> norm_num
        <;> omega
      · -- Prove that g ∘ f = id
        intro ⟨n, hn⟩
        simp [f, g]
        <;>
        (try cases' hn with k hk) <;>
        (try simp_all [Int.even_iff, Int.mul_ediv_cancel_left]) <;>
        (try ring_nf at *) <;>
        (try omega)
        <;>
        (try {
          have h₃ : n % 2 = 0 := by omega
          have h₄ : n = 2 * (n / 2) := by omega
          omega
        })
      · -- Prove that f is injective
        intro ⟨n₁, hn₁⟩ ⟨n₂, hn₂⟩ h
        simp [f] at h
        -- Since n₁ and n₂ are even, n₁ / 2 = n₂ / 2 implies n₁ = n₂
        have h₃ : n₁ % 2 = 0 := by
          cases' hn₁ with k hk
          omega
        have h₄ : n₂ % 2 = 0 := by
          cases' hn₂ with k hk
          omega
        have h₅ : n₁ = n₂ := by
          have h₆ : n₁ / 2 = n₂ / 2 := by omega
          have h₇ : n₁ % 2 = 0 := h₃
          have h₈ : n₂ % 2 = 0 := h₄
          have h₉ : n₁ = 2 * (n₁ / 2) := by omega
          have h₁₀ : n₂ = 2 * (n₂ / 2) := by omega
          omega
        simp_all
    -- Use the bijection to show that the set of even integers is denumerable
    exact h₂.denumerable
  -- Conclude the proof
  exact h₁
