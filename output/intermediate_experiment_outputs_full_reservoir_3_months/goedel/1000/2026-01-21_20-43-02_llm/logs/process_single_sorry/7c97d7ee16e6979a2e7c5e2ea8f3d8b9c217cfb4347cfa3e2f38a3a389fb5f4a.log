lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  have h₁ : (image g) ∘ (image f) = id := by
    funext s
    apply Set.ext
    intro x
    have h₂ : ∀ (y : U), y ∈ (image g (image f s)) ↔ y ∈ s := by
      intro y
      constructor
      · -- Prove the forward direction: if y ∈ (image g (image f s)), then y ∈ s.
        intro h₃
        rcases h₃ with ⟨z, h₄, h₅⟩
        -- h₄ : z ∈ image f s
        -- h₅ : g z = y
        rcases h₄ with ⟨w, h₆, h₇⟩
        -- h₆ : w ∈ s
        -- h₇ : f w = z
        have h₈ : g z = y := h₅
        have h₉ : g z = g (f w) := by
          rw [h₇]
        have h₁₀ : g (f w) = w := by
          have h₁₁ : g ∘ f = id := h
          calc
            g (f w) = (g ∘ f) w := rfl
            _ = id w := by rw [h₁₁]
            _ = w := rfl
        have h₁₁ : y = w := by
          calc
            y = g z := by rw [h₈]
            _ = g (f w) := by rw [h₉]
            _ = w := by rw [h₁₀]
        rw [h₁₁]
        exact h₆
      · -- Prove the backward direction: if y ∈ s, then y ∈ (image g (image f s)).
        intro h₃
        have h₄ : f y ∈ image f s := by
          -- Since y ∈ s, f y ∈ image f s
          have h₅ : y ∈ s := h₃
          exact ⟨y, h₅, rfl⟩
        have h₅ : g (f y) = y := by
          have h₆ : g ∘ f = id := h
          calc
            g (f y) = (g ∘ f) y := rfl
            _ = id y := by rw [h₆]
            _ = y := rfl
        -- Therefore, y ∈ image g (image f s)
        refine' ⟨f y, h₄, _⟩
        calc
          g (f y) = y := by rw [h₅]
          _ = y := rfl
    -- Use the above equivalence to show that image g (image f s) = s
    have h₂' : image g (image f s) = s := by
      apply Set.ext
      intro x
      exact h₂ x
    simp_all [Function.comp_apply]
    <;> aesop
  exact h₁
