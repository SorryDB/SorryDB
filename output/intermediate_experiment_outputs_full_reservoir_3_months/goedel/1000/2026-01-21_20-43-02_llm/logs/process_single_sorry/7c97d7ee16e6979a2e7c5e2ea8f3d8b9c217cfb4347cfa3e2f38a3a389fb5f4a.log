          · intro h₄
            obtain ⟨y, ⟨z, hz, hfy⟩, hgy⟩ := h₄
            refine' ⟨z, hz, _⟩
            rw [h₂]
            <;> simp_all
            <;> aesop
          · intro h₄
            obtain ⟨z, hz, hgz⟩ := h₄
            refine' ⟨f z, ⟨z, hz, rfl⟩, _⟩
            simp_all
            <;> aesop
        _ = {x | ∃ z ∈ s, (id z : U) = x} := by
          congr 1
          ext x
