lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  funext s
  have h₁ : (image g) (image f s) = s := by
    apply Set.ext
    intro x
    have h₂ : x ∈ (image g) (image f s) ↔ x ∈ s := by
      constructor
      · -- Prove the forward direction: if x ∈ (image g) (image f s), then x ∈ s
        intro hx
        rcases hx with ⟨y, hy, rfl⟩
        have h₃ : y ∈ image f s := hy
        rcases h₃ with ⟨z, hz, rfl⟩
        have h₄ : g (f z) = z := by
          have h₅ : g ∘ f = id := h
          have h₆ : (g ∘ f) z = z := by
            rw [h₅]
            <;> simp
          simpa using h₆
        simp_all
      · -- Prove the reverse direction: if x ∈ s, then x ∈ (image g) (image f s)
        intro hx
        have h₃ : f x ∈ image f s := by
          exact ⟨x, hx, rfl⟩
        have h₄ : g (f x) = x := by
          have h₅ : g ∘ f = id := h
          have h₆ : (g ∘ f) x = x := by
            rw [h₅]
            <;> simp
          simpa using h₆
        exact ⟨f x, h₃, by simp [h₄]⟩
    simp_all
  simp_all
