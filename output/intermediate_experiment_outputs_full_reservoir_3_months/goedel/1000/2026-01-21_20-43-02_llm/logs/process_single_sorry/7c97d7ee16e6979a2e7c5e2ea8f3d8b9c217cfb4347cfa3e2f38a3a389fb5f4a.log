        have h₉ : g (f u) = g v := by rw [h₈]
        have h₁₀ : g v = y := hvy
        have h₁₁ : g (f u) = y := by rw [h₉, h₁₀]
        have h₁₂ : g (f u) = u := by
          have h₁₃ : g ∘ f = id := h
          have h₁₄ : (g ∘ f) u = u := by
            rw [h₁₃]
            <;> simp
          simp [Function.comp_apply] at h₁₄ ⊢
          <;> exact h₁₄
        have h₁₃ : u = y := by
