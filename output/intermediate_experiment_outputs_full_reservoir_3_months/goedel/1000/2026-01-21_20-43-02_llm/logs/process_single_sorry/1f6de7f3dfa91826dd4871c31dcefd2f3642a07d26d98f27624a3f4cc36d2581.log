namespace IMO2025P3

def Bonza (f : ℕ+ → ℕ+) : Prop := ∀ a b : ℕ+, (f a : ℤ) ∣ (b ^ (a : ℕ) : ℤ) - (f b ^ (f a : ℕ) : ℤ)

def answer : ℝ := 1

theorem result : IsLeast {c : ℝ | ∀ f : ℕ+ → ℕ+, Bonza f → ∀ n, f n ≤ c * n}
    answer := by
  refine' ⟨_, _⟩
  · -- Prove that `answer` is in the set
    intro f hf n
    have h₁ : (f n : ℕ) ≤ 1 * (n : ℝ) := by
      have h₂ : (f n : ℕ) ≤ (n : ℕ) := by
        have h₃ : (f n : ℕ) ∣ (n : ℕ) ^ (f n : ℕ) := by
          have h₄ := hf n n
          have h₅ : (f n : ℤ) ∣ (n : ℕ) ^ (f n : ℕ) := by
            have h₆ := hf n n
            norm_cast at h₆ ⊢
            <;> simpa [zpow_ofNat] using h₆
          exact by
            norm_cast at h₅ ⊢
            <;> simpa [zpow_ofNat] using h₅
        have h₇ : (f n : ℕ) ∣ (n : ℕ) ^ (f n : ℕ) := h₃
        have h₈ : (f n : ℕ) ≤ (n : ℕ) ^ (f n : ℕ) := Nat.le_of_dvd (Nat.pos_pow_of_pos _ (by exact_mod_cast n.prop)) h₇
        have h₉ : (f n : ℕ) ≤ (n : ℕ) := by
          by_contra h
          have h₁₀ : (n : ℕ) < (f n : ℕ) := by omega
          have h₁₁ : (n : ℕ) ^ (f n : ℕ) < (f n : ℕ) ^ (f n : ℕ) := by
            exact pow_lt_pow_of_lt_left (by exact_mod_cast (by exact_mod_cast n.prop.lt (by omega))) (by
              have h₁₂ : 0 < (f n : ℕ) := by exact_mod_cast (f n).prop
              omega) (by
              have h₁₃ : 1 < (f n : ℕ) := by
                have h₁₄ : (n : ℕ) < (f n : ℕ) := by omega
                have h₁₅ : 1 ≤ (n : ℕ) := by exact_mod_cast n.prop
                omega
              omega)
          have h₁₂ : (f n : ℕ) ^ (f n : ℕ) ≤ (n : ℕ) ^ (f n : ℕ) := by
            have h₁₃ : (f n : ℕ) ≤ (n : ℕ) := by
              by_contra h₁₄
              have h₁₅ : (n : ℕ) < (f n : ℕ) := by omega
              have h₁₆ : (n : ℕ) ^ (f n : ℕ) < (f n : ℕ) ^ (f n : ℕ) := by
                exact pow_lt_pow_of_lt_left (by exact_mod_cast (by exact_mod_cast n.prop.lt (by omega))) (by
                  have h₁₇ : 0 < (f n : ℕ) := by exact_mod_cast (f n).prop
                  omega) (by
                  have h₁₈ : 1 < (f n : ℕ) := by
                    have h₁₉ : (n : ℕ) < (f n : ℕ) := by omega
                    have h₂₀ : 1 ≤ (n : ℕ) := by exact_mod_cast n.prop
                    omega
                  omega)
              linarith
            exact pow_le_pow_of_le_left (by positivity) h₁₃ _
          linarith
        exact h₉
      -- Convert the inequality to real numbers
      have h₃ : (f n : ℝ) ≤ (n : ℝ) := by
        norm_cast
        <;> exact_mod_cast h₂
      -- Multiply both sides by 1 (which is 1 * 1)
      have h₄ : (f n : ℝ) ≤ 1 * (n : ℝ) := by
        linarith
      exact_mod_cast h₄
    -- Since `answer = 1`, we have `f n ≤ 1 * n`
    have h₂ : (f n : ℝ) ≤ (1 : ℝ) * (n : ℝ) := by
      exact_mod_cast h₁
    -- Simplify the expression
    simpa [answer] using h₂
  · -- Prove that `answer` is the least element
    intro c hc
    have h₁ : (1 : ℝ) ≤ c := by
      -- Consider the identity function `f(n) = n`
      have h₂ : ∀ (n : ℕ+), (n : ℕ+) ≤ c * (n : ℝ) := by
        intro n
        have h₃ : (n : ℕ+) ≤ c * (n : ℝ) := by
          have h₄ : ∀ (f : ℕ+ → ℕ+), Bonza f → ∀ (n : ℕ+), (f n : ℝ) ≤ c * (n : ℝ) := by
            intro f hf n
            exact hc f hf n
          -- Define the identity function
          let f : ℕ+ → ℕ+ := fun n => n
          have h₅ : Bonza f := by
            intro a b
            have h₆ : (f a : ℤ) = (a : ℤ) := by simp [f]
            have h₇ : (f b : ℤ) = (b : ℤ) := by simp [f]
            have h₈ : (a : ℤ) ∣ (b : ℤ) ^ (a : ℕ) - (b : ℤ) ^ (a : ℕ) := by
              use 0
              <;> ring_nf
              <;> simp [h₆, h₇]
            simpa [f, h₆, h₇] using h₈
          have h₉ : (f n : ℝ) ≤ c * (n : ℝ) := h₄ f h₅ n
          simpa [f] using h₉
        exact_mod_cast h₃
      -- Specialize to n = 1
      have h₃ : (1 : ℕ+) ≤ c * (1 : ℝ) := h₂ 1
      norm_num at h₃ ⊢
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try
        {
          simp_all [PNat.one_coe]
          <;>
          norm_num at *
          <;>
          linarith
        })
      <;>
      (try
        {
          norm_num [PNat.one_coe] at h₃ ⊢
          <;>
          linarith
        })
    -- Since `answer = 1`, we have `1 ≤ c`
    simpa [answer] using h₁
