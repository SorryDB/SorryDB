        -- Use the identity function to get a lower bound on c
        have h₃ : ∀ f : ℕ+ → ℕ+, Bonza f → ∀ n, (f n : ℝ) ≤ c * (n : ℝ) := hc
        -- Consider the identity function f(n) = n
        let f : ℕ+ → ℕ+ := fun n => n
        have h₄ : Bonza f := by sorry
