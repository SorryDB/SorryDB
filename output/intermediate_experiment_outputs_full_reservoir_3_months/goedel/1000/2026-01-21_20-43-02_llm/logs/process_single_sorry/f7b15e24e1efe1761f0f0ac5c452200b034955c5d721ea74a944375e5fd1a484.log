      split
      case h_2 =>
        intros
        contradiction
      case h_1 reached_state h_eq_reached =>
        intro ih
        rw [ih] at h_eq
        rw [h_eq_reached]
        simp only [Option.bind_some]
        rw [h_eq]
        simp only [h_hold]

