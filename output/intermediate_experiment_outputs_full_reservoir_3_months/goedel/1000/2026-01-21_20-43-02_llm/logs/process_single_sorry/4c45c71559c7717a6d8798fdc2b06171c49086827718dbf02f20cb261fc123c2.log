theorem le_induction {P : Nat → Prop} {m}
    (h0 : P m) (h1 : ∀ n, m ≤ n → P n → P (n + 1)) :
    ∀ n, m ≤ n → P n := by
  intro n hn
  have h2 : ∀ n ≥ m, P n := by
    intro n hn'
    induction' hn' with n hn' IH
    · -- Base case: n = m
      exact h0
    · -- Inductive step: assume P(n), prove P(n + 1)
      exact h1 n hn' IH
  -- Apply the universal statement to n and hn
  exact h2 n hn
