theorem uncurry_abc (a b c : Type) [Inhabited a] [Inhabited b] [Inhabited c] :
    (a → b → c) ≃ (a × b) → c := by
  haveI := Classical.decEq a
  haveI := Classical.decEq b
  haveI := Classical.decEq c
  apply Equiv.ofEquiv (Equiv.trans (Equiv.trans (Equiv.pcongr (λ (imported) ↦ currying (λ (a b : _) ↦ c))) (Equiv.refl ∀ (a : _) (b : _), c)) (Equiv.refl ((a × b) → c))) (λ (f : (a → b → c)) ↦ (fun (x : a × b) ↦ f x.1 x.2), λ (f : (a × b) → c) ↦ (λ (a b : _) ↦ f (a, b)))
  <;> ext <;> simp_all [currying]
  <;> aesop
