      "\n    have h₃ : (fderiv ℝ (fun x ↦ ⟪pbar.inner x, pc.w⟫) pbar.innerParams) (EuclideanSpace.single 2 1) = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n      have h₄ : HasFDerivAt (fun x ↦ ⟪pbar.inner x, pc.w⟫) (⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫) pbar.innerParams := by\n        -- Prove that the derivative of ⟪pbar.inner x, pc.w⟫ at pbar.innerParams is ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫\n        have h₅ : HasFDerivAt (fun x ↦ pbar.inner x) (pbar.rotR (pbar.rotM₁φ pc.S)) pbar.innerParams := by\n          -- Prove that the derivative of pbar.inner x at pbar.innerParams is pbar.rotR (pbar.rotM₁φ pc.S)\n          have h₆ : HasFDerivAt pbar.inner (pbar.rotR (pbar.rotM₁φ pc.S)) pbar.innerParams := by\n            -- Use the specific form of the derivative of pbar.inner\n            have h₇ : HasFDerivAt (fun x : ℝ³ ↦ pbar.inner x) (pbar.rotR (pbar.rotM₁φ pc.S)) pbar.innerParams := by\n              sorry\n            exact h₇\n          exact h₆\n        -- Use the chain rule and properties of inner product to find the derivative of ⟪pbar.inner x, pc.w⟫\n        have h₈ : HasFDerivAt (fun x ↦ ⟪pbar.inner x, pc.w⟫) (⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫) pbar.innerParams := by\n          have h₉ : HasFDerivAt (fun x : ℝ³ ↦ pbar.inner x) (pbar.rotR (pbar.rotM₁φ pc.S)) pbar.innerParams := h₅\n          have h₁₀ : HasFDerivAt (fun x : ℝ³ ↦ ⟪x, pc.w⟫) (⟪(1 : ℝ³), pc.w⟫) (pbar.inner pbar.innerParams) := by\n            have h₁₁ : HasFDerivAt (fun x : ℝ³ ↦ ⟪x, pc.w⟫) (⟪(1 : ℝ³), pc.w⟫) (pbar.inner pbar.innerParams) := by\n              simpa using ((hasFDerivAt_id : HasFDerivAt (fun x : ℝ³ ↦ x) (1 : ℝ³ →L[ℝ] ℝ³) (pbar.inner pbar.innerParams)).inner (hasFDerivAt_const _ (pc.w)))\n            exact h₁₁\n          -- Use the chain rule to combine the derivatives\n          have h₁₂ : HasFDerivAt (fun x ↦ ⟪pbar.inner x, pc.w⟫) (⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫) pbar.innerParams := by\n            have h₁₃ : HasFDerivAt (fun x : ℝ³ ↦ ⟪pbar.inner x, pc.w⟫) (⟪pbar.rotR (pba