      "\n  have h1 : ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams = ⟨pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟩ := by sorry\n  exact h1",
      "\n  have := pc.norm_S_ne_zero\n  have h₁ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 3 1) =\n    ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n    sorry\n  simp [nth_partial, GlobalTheoremPrecondition.fu] at h₁ ⊢\n  <;>\n  (try\n    {\n      field_simp at h₁ ⊢\n      <;>\n      simp_all [fderiv_const_smul, fderiv_id_mul, mul_comm]\n      <;>\n      (try\n        {\n          norm_num at h₁ ⊢\n          <;>\n          simp_all\n          <;>\n          linarith\n        })\n      <;>\n      (try\n        {\n          linarith\n        })\n    })\n  <;>\n  (try\n    {\n      simp_all [fderiv_const_smul, fderiv_id_mul, mul_comm]\n      <;>\n      (try\n        {\n          norm_num at h₁ ⊢\n          <;>\n          simp_all\n          <;>\n          linarith\n        })\n      <;>\n      (try\n        {\n          linarith\n        })\n    })\n  <;>\n  (try\n    {\n      simp_all [fderiv_const_smul, fderiv_id_mul, mul_comm]\n      <;>\n      (try\n        {\n          norm_num at h₁ ⊢\n          <;>\n          simp_all\n          <;>\n          linarith\n        })\n      <;>\n      (try\n        {\n          linarith\n        })\n    })\n  <;>\n  (try\n    {\n      simp_all [fderiv_const_smul, fderiv_id_mul, mul_comm]\n      <;>\n      (try\n        {\n          norm_num at h₁ ⊢\n          <;>\n          simp_all\n          <;>\n          linarith\n        })\n      <;>\n      (try\n        {\n          linarith\n        })\n    })",
      "",
      "\n  have h_main : ‖pc.S‖ * nth_partial 2 (GlobalTheoremPrecondition.fu pbar ε poly pc) pbar.innerParams = ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n    have h1 : ‖pc.S‖ * nth_partial 2 (fun x => rotproj_inner_unit pc.S pc.w x) pbar.innerParams =\n        ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n      sorry\n    have h2 : pc.fu = (fun x => rotproj_inner_unit pc.S pc.w x) := by rfl\n    rw [show (GlobalTheoremPrecondition.fu pbar ε poly pc) = (fun x => rotproj_inner_unit pc.S pc.w x) by rfl]\n    <;> simpa using h1\n  have h_final : ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n    have h₁ : 0 < ‖pc.S‖ := by\n      exact_mod_cast poly.mem_sphere_pos_iff.mpr (by\n        have h₂ : pc.S ∈ poly.vertices := pc.S_in_poly\n        exact poly.sqrt_le_one.mpr (le_of_eq (by\n          have h₃ : ‖pc.S‖ ≤ 1 := GlobalTheoremPrecondition.norm_S_le_one pc\n          have h₄ : 0 < ‖pc.S‖ := GlobalTheoremPrecondition.norm_S_gt_zero pc\n          linarith [h₃, h₄]\n          )))\n    have h₂ : ‖pc.S‖⁻¹ * ‖pc.S‖ = 1 := by\n      field_simp [h₁.ne']\n      <;> ring_nf\n      <;> norm_num\n    have h₃ : ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n      calc\n        ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ = (‖pc.S‖⁻¹ * ‖pc.S‖) * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n          field_simp [h₁.ne'] <;> ring_nf\n          <;> norm_num\n          <;> linarith [h₁]\n        _ = 1 * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n          rw [h₂]\n        _ = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n          simp [one_mul]\n    exact h₃\n  linarith",
      "\n  have h₀ : ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟪ := by\n    have h₁ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1) = ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n      have h₂ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by\n        exact HasFDerivAt.rotproj_inner pbar pc.S pc.w\n      have h₃ : (HasFDerivAt (rotproj_inner_unit pc.S pc.w) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams).fderiv = (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) := by\n        rfl\n      have h₄ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1) = (rotproj_inner' pbar pc.S pc.w) (EuclideanSpace.single 2 1) := by\n        rw [h₃]\n        <;> simp [h₂.fderiv]\n      rw [h₄]\n      have h₅ : (rotproj_inner' pbar pc.S pc.w) (EuclideanSpace.single 2 1) = ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n        simp [rotproj_inner', Matrix.dotProduct, Fin.sum_univ_succ]\n        <;>\n        (norm_num [Fin.val_zero, Fin.val_one, Fin.val_two] at * <;>\n        simp_all [Fin.val_zero, Fin.val_one, Fin.val_two, Matrix.dotProduct, Fin.sum_univ_succ] <;>\n        ring_nf at * <;>\n        norm_num at * <;>\n        simp_all [inner_smul_left, inner_smul_right])\n        <;>\n        (try norm_num) <;>\n        (try linarith)\n        <;>\n        (try ring_nf at *) <;>\n        (try simp_all [inner_smul_left, inner_smul_right])\n      rw [h₅]\n      <;>\n      (try norm_num) <;>\n      (try linarith)\n      <;>\n      (try ring_nf at *) <;>\n      (try simp_all [inner_smul_left, inner_smul_right])\n    have h₆ : ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟪ := by\n      have h₇ : (nth_partial 2 pc.fu pbar.innerParams : ℝ) = (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1) := by\n        simp [nth_partial, gl