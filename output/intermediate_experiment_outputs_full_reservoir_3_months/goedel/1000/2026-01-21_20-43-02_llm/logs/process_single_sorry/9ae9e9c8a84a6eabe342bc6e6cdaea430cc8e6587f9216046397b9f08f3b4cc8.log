      "\n  have h₀ : ‖pc.S‖ * nth_partial 2 (rotproj_inner_unit pc.S pc.w) pbar.innerParams = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n    have h₁ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1) = (‖pc.S‖⁻¹ : ℝ) * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n      have h₂ := (HasFDerivAt.rotproj_inner pbar pc.S pc.w)\n      have h₃ : (HasFDerivAt (rotproj_inner_unit pc.S pc.w) ( (‖pc.S‖⁻¹ : ℝ) • ( (rotproj_inner' pbar pc.S pc.w)) ) pbar.innerParams) := by\n        -- Use the chain rule to differentiate the composition of functions\n        have h₄ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) ( (‖pc.S‖⁻¹ : ℝ) • (fderiv ℝ (rotproj_inner pc.S pc.w) pbar.innerParams) ) pbar.innerParams := by\n          -- Use the fact that the derivative of the inner function is already known\n          have h₅ : DifferentiableAt ℝ (rotproj_inner pc.S pc.w) pbar.innerParams := by\n            fun_prop\n          have h₆ : HasFDerivAt (fun x : ℝ³ => (rotproj_inner pc.S pc.w x) / ‖pc.S‖) ( (‖pc.S‖⁻¹ : ℝ) • (fderiv ℝ (rotproj_inner pc.S pc.w) pbar.innerParams) ) pbar.innerParams := by\n            -- Apply the chain rule for differentiable functions\n            have h₇ : HasFDerivAt (fun x : ℝ³ => (rotproj_inner pc.S pc.w x) / ‖pc.S‖) ( (‖pc.S‖⁻¹ : ℝ) • (fderiv ℝ (rotproj_inner pc.S pc.w) pbar.innerParams) ) pbar.innerParams := by\n              -- Use the fact that the derivative of the inner function is already known\n              convert HasFDerivAt.div_const (h₅.hasFDerivAt) (‖pc.S‖ : ℝ) using 1\n              <;> field_simp [pc.norm_S_ne_zero]\n              <;> ring\n            exact h₇\n          convert h₆ using 1 <;>\n          simp [rotproj_inner_unit, div_eq_mul_inv]\n          <;>\n          field_simp [pc.norm_S_ne_zero]\n          <;>\n          ring\n        -- Use the fact that the derivative of the inner function is already known\n        have h₇ : ( (‖pc.S‖⁻¹ : ℝ) • (fderiv ℝ (rotproj_inner pc.S pc.w) pbar.innerParams) ) = ( (