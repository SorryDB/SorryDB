      "\n  have h₁ : ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams =\n    ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n    simp only [nth_partial, GlobalTheoremPrecondition.fu]\n    have h₂ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by\n      have h₃ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by\n        -- Prove that the function is differentiable at the point\n        have h₄ : DifferentiableAt ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams := by\n          fun_prop\n        -- Use the fact that the function is differentiable to get the derivative\n        have h₅ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) pbar.innerParams := by\n          apply DifferentiableAt.hasFDerivAt\n          exact h₄\n        -- Simplify the expression using the given derivative\n        convert h₅ using 1\n        <;>\n        (try simp_all [rotproj_inner', HasFDerivAt.rotproj_inner])\n        <;>\n        (try simp_all [fderiv_const, fderiv_id, fderiv_smul, fderiv_comp])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n      exact h₃\n    -- Calculate the derivative\n    have h₃ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1 : ℝ³) = (‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ : ℝ) := by\n      sorry\n    -- Combine the results\n    calc\n      ‖pc.S‖ * ( (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1 : ℝ³) ) = ‖pc.S‖ * (‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ : ℝ) := by rw [h₃]\n      _ = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n        have h₄ : ‖pc.S‖ ≠ 0 := by\n          have h₅ : 0 < ‖pc.S‖ := by\n            have h₅₁ : 0 < ‖pc.S‖ := by\n              -- Prove that the norm of S is positive\n              have h₅₂ : 0 < ‖pc.S‖ := GlobalTheoremPrecondition.norm_S_gt_zero pc\n              exact h₅₂\n            exact h₅₁\n          exact ne_of_gt h₅\n        field_simp [h₄]\n        <;> ring_nf\n        <;> norm_num\n        <;> linarith\n  exact h₁\n```lean```lean\ntheorem partials_helper2 {pbar : Pose} {ε : ℝ} {poly : GoodPoly}\n    (pc : GlobalTheoremPrecondition poly pbar ε) :\n    ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams =\n    ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n  have h₁ : ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams =\n    ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n    simp only [nth_partial, GlobalTheoremPrecondition.fu]\n    have h₂ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by\n      have h₃ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by\n        -- Prove that the function is differentiable at the point\n        have h₄ : DifferentiableAt ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams := by\n          fun_prop\n        -- Use the fact that the function is differentiable to get the derivative\n        have h₅ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) pbar.innerParams := by\n          apply DifferentiableAt.hasFDerivAt\n          exact h₄\n        -- Simplify the expression using the given derivative\n        convert h₅ using 1\n        <;>\n        (try simp_all [rotproj_inner', HasFDerivAt.rotproj_inner])\n        <;>\n        (try simp_all [fderiv_const, fderiv_id, fderiv_smul, fderiv_comp])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n        <;>\n        (try simp_all [LinearMap.comp_apply])\n        <;>\n        (try simp_all [LinearMap.smulRight])\n        <;>\n        (try simp_all [LinearMap.add_apply])\n      exact h₃\n    -- Calculate the derivative\n    have h₃ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1 : ℝ³) = (‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ : ℝ) := by\n      have h₄ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1 : ℝ³) = (‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ : ℝ) := by\n        sorry\n      exact h₄\n    -- Combine the results\n    calc\n      ‖pc.S‖ * ( (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1 : ℝ³) ) = ‖pc.S‖ * (‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ : ℝ) := by rw [h₃]\n      _ = ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n        have h₄ : ‖pc.S‖ ≠ 0 := by\n          have h₅ : 0 < ‖pc.S‖ := by\n            have h₅₁ : 0 < ‖pc.S‖ := by\n              -- Prove that the norm of S is positive\n              have h₅₂ : 0 < ‖pc.S‖ := GlobalTheoremPrecondition.norm_S_gt_zero pc\n              exact h₅₂\n            exact h₅₁\n          exact ne_of_gt h₅\n        field_simp [h₄]\n        <;> ring_nf\n        <;> norm_num\n        <;> linarith\n  exact h₁\n```leantheorem partials_helper2 {pbar : Pose} {ε : ℝ} {poly : GoodPoly}\n    (pc : GlobalTheoremPrecondition poly pbar ε) :\n    ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams =\n    ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n  have h₁ : ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams =\n    ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n    simp only [nth_partial, GlobalTheoremPrecondition.fu]\n    have h₂ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by\n      have h₃ : HasFDerivAt (rotproj_inner_unit pc.S pc.w) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by\n        -- Prove that the function is differentiable at the point\n        have h₄ : DifferentiableAt ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams := by\n          fun_prop\n        -- Use the fact that the function is differentiable to get the derivative\n        have h₅ : HasFDerivAt (rotproj_