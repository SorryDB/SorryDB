Map.hasFDerivAt\n        -- Use the fact that the derivative of the inner function is already known\n        have h₁₀ : (nth_partial 2 (rotproj_inner_unit pc.S pc.w) pbar.innerParams : ℝ) = (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1) := by\n          -- Use the fact that the derivative of the inner function is already known\n          simp [nth_partial, EuclideanSpace.single_apply]\n          <;>\n          simp_all [HasFDerivAt]\n          <;>\n          field_simp [pc.norm_S_ne_zero]\n          <;>\n          ring_nf\n          <;>\n          norm_num\n          <;>\n          simp_all [HasFDerivAt]\n          <;>\n          linarith\n        -- Use the fact that the derivative of the inner function is already known\n        rw [h₁₀] at *\n        -- Use the fact that the derivative of the inner function is already known\n        have h₁₁ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1) = (‖pc.S‖⁻¹ : ℝ) * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n          exact h₃\n        -- Use the fact that the derivative of the inner function is already known\n        rw [h₁₁]\n        <;>\n        simp_all\n        <;>\n        field_simp [pc.norm_S_ne_zero]\n        <;>\n        ring_nf\n        <;>\n        norm_num\n        <;>\n        linarith\n      -- Use the fact that the derivative of the inner function is already known\n      have h₁₀ : (nth_partial 2 (rotproj_inner_unit pc.S pc.w) pbar.innerParams : ℝ) = ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n        exact h₅\n      -- Use the fact that the derivative of the inner function is already known\n      calc\n        ‖pc.S‖ * nth_partial 2 (rotproj_inner_unit pc.S pc.w) pbar",
