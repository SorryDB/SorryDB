    have h₅ : (rotproj_inner' pbar pc.S pc.w) (EuclideanSpace.single 2 1) = ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by
      simp [rotproj_inner']
      -- Extract the relevant gradient component and verify its correspondence with the derivative
