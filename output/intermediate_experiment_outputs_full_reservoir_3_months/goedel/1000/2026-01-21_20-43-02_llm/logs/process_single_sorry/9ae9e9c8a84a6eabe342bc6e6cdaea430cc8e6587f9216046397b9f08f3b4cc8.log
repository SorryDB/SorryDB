      "\n  have := pc.norm_S_ne_zero\n  simp only [nth_partial, GlobalTheoremPrecondition.fu, Fin.isValue] at *\n  -- Use the previously established helper lemma for the first partial derivative\n  have h₁ := partials_helper0a pbar ε poly pc\n  -- Similarly, use the helper lemma for the second partial derivative\n  have h₂ := partials_helper1 pbar ε poly pc\n  -- Handle the third partial derivative similarly\n  have h₃ : (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 2 1 :\n      EuclideanSpace ℝ (Fin 3)) = ‖pc.S‖⁻¹ * ⟪pbar.rotR (pbar.rotM₁φ pc.S), pc.w⟫ := by\n    have := pc.norm_S_ne_zero\n    change (fderiv ℝ (λ x => rotproj_inner_unit pc.S pc.w x) _) _ = _\n    unfold rotproj_inner_unit rotprojRM\n    convert_to (fderiv ℝ (‖pc.S‖⁻¹ • (rotproj_inner pc.S pc.w)) pbar.innerParams) (EuclideanSpace.single 2 1) = _\n    · unfold rotproj_inner rotprojRM\n      conv =>\n        rhs; arg 1; lhs; ext x; simp only [Pi.smul_apply, smul_eq_mul]\n      <;> rw [inv_mul_eq_div]\n    have hf : DifferentiableAt ℝ (rotproj_inner pc.S pc.w) pbar.innerParams := by\n      fun_prop\n    rw [(hf.hasFDerivAt.const_smul ‖pc.S‖⁻¹).fderiv]\n    simp only [Fin.isValue, ContinuousLinearMap.coe_smul', Pi.smul_apply, smul_eq_mul,\n      mul_eq_mul_left_iff]\n    <;> left\n    <;> rw [HasFDerivAt.rotproj_inner pbar pc.S pc.w |>.fderiv]\n    <;> simp [rotproj_inner']\n    <;>\n      simp_all [Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_cons,\n        Matrix.cons_val_two, Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_cons,\n        Matrix.cons_val_two]\n    <;>\n      ring_nf at *\n    <;>\n      norm_num at *\n    <;>\n      simp_all [Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_cons,\n        Matrix.cons_val_two]\n    <;>\n      ring_nf at *\n    <;>\n      norm_num at *\n    <;>\n      linarith\n  \n  <;> simp_all [Fin.isValue]\n  <;> field_simp [pow_one, pow_zero, mul_assoc, mul_comm, mul_left_comm]\n  <;> ring_nf\n  <;> norm_nu