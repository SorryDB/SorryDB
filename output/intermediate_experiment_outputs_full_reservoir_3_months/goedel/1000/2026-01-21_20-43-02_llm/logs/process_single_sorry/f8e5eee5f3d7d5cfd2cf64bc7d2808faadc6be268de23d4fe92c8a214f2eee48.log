/-- `DiffSp.toSmoothSp` is fully faithful. -/
def DiffSp.toSmoothSp.fullyFaithful : DiffSp.toSmoothSp.{u}.FullyFaithful where
  preimage f := ofHom ‚ü®fun x ‚Ü¶
      (by exact f.val.app (.op 0) ‚ü®fun _ ‚Ü¶ x, dsmooth_const‚ü© : DSmoothMap (Eucl 0) _) 0, by
    intro n p hp; convert (f.val.app (.op n) ‚ü®p, hp.dsmooth‚ü©).dsmooth.isPlot using 1; ext x
