theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => comp f g) := by
  have h_imp : split_epi f → ∀ c : α, Function.Surjective (fun g : Hom Y c => comp f g) := by
    intro h_split c
    rcases h_split with ⟨g, hg⟩
    -- We have a right inverse g such that f ≫ g = id X
    -- For any h : Hom X c, we need to find g' : Hom Y c such that f ≫ g' = h
    -- We can set g' = g ≫ h
    refine' fun h => ⟨g ≫ h, _⟩
    -- Verify that f ≫ (g ≫ h) = h
    calc
      f ≫ (g ≫ h) = (f ≫ g) ≫ h := by
        simp [comp_assoc]
      _ = id X ≫ h := by rw [hg]
      _ = h := by simp [comp_id]
  
  have h_conv : (∀ c : α, Function.Surjective (fun g : Hom Y c => comp f g)) → split_epi f := by
    intro h_surj
    -- Use the surjectivity with c = X to get a right inverse
    have h1 : Function.Surjective (fun g : Hom Y X => comp f g) := h_surj X
    -- The identity arrow id X : Hom X X is in the codomain, so there exists g : Hom Y X such that f ≫ g = id X
    have h2 : ∃ (g : Hom Y X), f ≫ g = id X := by
      have h3 : ∃ (g : Hom Y X), (f ≫ g : Hom X X) = id X := by
        have h4 : (id X : Hom X X) ∈ Set.range (fun g : Hom Y X => f ≫ g) := by
          apply h1
          <;> simp
        obtain ⟨g, hg⟩ := h4
        exact ⟨g, by simpa using hg⟩
      obtain ⟨g, hg⟩ := h3
      exact ⟨g, by simpa using hg⟩
    -- This g is the required right inverse, so f is a split epimorphism
    obtain ⟨g, hg⟩ := h2
    exact ⟨g, hg⟩
  
  have h_main : (split_epi f) ↔ (∀ c : α, Function.Surjective (fun g : Hom Y c => comp f g)) := by
    constructor
    · -- Prove the forward direction: if f is a split epimorphism, then for all c, the map is surjective.
      intro h
      exact h_imp h
    · -- Prove the reverse direction: if for all c, the map is surjective, then f is a split epimorphism.
      intro h
      exact h_conv h
  
  exact h_main
