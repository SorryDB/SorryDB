theorem split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if f is a split epi, then for every c, (f ≫ ·) is surjective.
    intro h c
    obtain ⟨g, hg⟩ := h
    have h₁ : Function.Surjective (fun g : Hom Y c => f ≫ g) := by
      intro h₂
      -- Use the existence of a retraction to find a preimage for h₂
      have h₃ : ∃ (h₄ : Hom Y c), f ≫ h₄ = h₂ := by
        -- Use g ≫ h₂ as the preimage
        refine' ⟨g ≫ h₂, _⟩
        calc
          f ≫ (g ≫ h₂) = (f ≫ g) ≫ h₂ := by simp [Hom.ass]
          _ = id X ≫ h₂ := by rw [hg]
          _ = h₂ := by simp [id.ass]
      exact h₃
    exact h₁
  · -- Prove the reverse direction: if for every c, (f ≫ ·) is surjective, then f is a split epi.
    intro h
    have h₁ : ∃ (g : Hom Y X), f ≫ g = id X := by
      -- Use the surjectivity for c = X to find a g such that f ≫ g = id X
      have h₂ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
      have h₃ : ∃ (g : Hom Y X), f ≫ g = id X := by
        have h₄ : id X ∈ Set.range (fun g : Hom Y X => f ≫ g) := by
          have h₅ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
          have h₆ : id X ∈ Set.range (fun g : Hom Y X => f ≫ g) := by
            -- Since (f ≫ ·) is surjective, there exists a g such that f ≫ g = id X
            obtain ⟨g, hg⟩ := h₅ (id X)
            exact ⟨g, by simp_all [hg]⟩
          exact h₆
        obtain ⟨g, hg⟩ := h₄
        refine' ⟨g, _⟩
        simp_all
      exact h₃
    -- Obtain g such that f ≫ g = id X
    obtain ⟨g, hg⟩ := h₁
    -- Show that f is a split epi with g as the splitting map
    exact ⟨g, hg⟩
