theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if f is a split epi, then for every c, the map g ↦ f ≫ g is surjective.
    intro h
    rcases h with ⟨g, hg⟩
    intro c
    intro h_c
    -- Use the retraction property to find a preimage for any h_c : Y → c.
    have h_surj : ∃ (g' : Hom Y c), f ≫ g' = h_c := by
      -- Since f ≫ g = id X, we can use g' = g ≫ h_c.
      use g ≫ h_c
      calc
        f ≫ (g ≫ h_c) = (f ≫ g) ≫ h_c := by rw [comp_assoc]
        _ = id X ≫ h_c := by rw [hg]
        _ = h_c := by simp [id_comp]
    -- Use the existence of g' to show surjectivity.
    obtain ⟨g', hg'⟩ := h_surj
    exact ⟨g', by simp_all [Function.funext_iff]⟩
  · -- Prove the reverse direction: if for every c, the map g ↦ f ≫ g is surjective, then f is a split epi.
    intro h
    -- For c = X, the map g ↦ f ≫ g is surjective, so there exists g : Y → X such that f ≫ g = id X.
    have h_surj : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
    -- Since id X is a morphism X → X, there exists g : Y → X such that f ≫ g = id X.
    have h_exists_g : ∃ (g : Hom Y X), f ≫ g = id X := by
      have h1 : (id X : Hom X X) ∈ Set.range (fun g : Hom Y X => f ≫ g) := by
        apply h_surj
      obtain ⟨g, hg⟩ := h1
      exact ⟨g, by simp_all [Function.funext_iff]⟩
    -- Use this g to show that f is a split epi.
    obtain ⟨g, hg⟩ := h_exists_g
    refine' ⟨g, _⟩
    -- Verify that f ≫ g = id X.
    exact hg
