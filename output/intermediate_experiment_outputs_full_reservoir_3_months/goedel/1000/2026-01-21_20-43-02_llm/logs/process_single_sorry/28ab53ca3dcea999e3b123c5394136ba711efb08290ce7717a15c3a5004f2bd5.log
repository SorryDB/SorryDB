```lean
theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔ ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  have h_imp : split_epi f → (∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g)) := by
    intro h_split
    obtain ⟨g, hg⟩ := h_split
    intro c
    intro h
    -- We need to find a g' : Hom Y c such that f ≫ g' = h
    -- We can choose g' = g ≫ h
    use g ≫ h
    calc
      f ≫ (g ≫ h) = (f ≫ g) ≫ h := by
        rw [comp_assoc]
      _ = (id X) ≫ h := by rw [hg]
      _ = h := by simp [id_comp]
  
  have h_converse : (∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g)) → split_epi f := by
    intro h_surj
    -- Use the surjectivity condition with c = X and h = id X to find g
    have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h_surj X
    -- Since id X : Hom X X, there exists a g : Hom Y X such that f ≫ g = id X
    have h₂ : ∃ (g : Hom Y X), f ≫ g = (id X : Hom X X) := by
      -- Apply the surjectivity condition to id X
      have h₃ : ∃ (g : Hom Y X), (fun g : Hom Y X => f ≫ g) g = (id X : Hom X X) := by
        apply h₁
        <;> simp
      -- Obtain the g such that f ≫ g = id X
      obtain ⟨g, hg⟩ := h₃
      exact ⟨g, by simpa using hg⟩
    -- Obtain the g and the equality f ≫ g = id X
    obtain ⟨g, hg⟩ := h₂
    -- Show that g is a left inverse of f
    exact ⟨g, by simpa [id_comp] using hg⟩
  
  constructor
  · exact h_imp
  · exact h_converse
