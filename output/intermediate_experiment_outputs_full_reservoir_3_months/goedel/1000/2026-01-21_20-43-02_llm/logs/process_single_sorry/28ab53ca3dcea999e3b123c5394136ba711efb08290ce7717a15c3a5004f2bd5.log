```lean
def split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if `split_epi f`, then for all `c`, the map is surjective.
    intro h
    intro c
    obtain ⟨g, hg⟩ := h
    intro z
    -- For any `z : Hom Y c`, we can find `h : Hom X c` such that `f ≫ h = z`.
    use g ≫ z
    -- Show that `f ≫ (g ≫ z) = z`.
    calc
      f ≫ (g ≫ z) = (f ≫ g) ≫ z := by
        rw [comp_assoc]
      _ = id X ≫ z := by rw [hg]
      _ = z := by simp [id_comp]
  · -- Prove the reverse direction: if for all `c`, the map is surjective, then `split_epi f`.
    intro h
    have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
    obtain ⟨g, hg⟩ := h₁ (id X)
    have h₂ : f ≫ g = id X := by
      simpa using hg
    exact ⟨g, h₂⟩
``` 

