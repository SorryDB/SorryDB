```lean
lemma Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if f is a split epi, then for every c, the map is surjective.
    intro h
    obtain ⟨g, hg⟩ := h
    intro c
    intro d
    -- Since f is a split epi, there exists a g such that f ≫ g = id X.
    -- We need to show that for any d : Hom X Z, there exists some h : Hom Y X such that (f ≫ h) = d.
    -- We can use g as the preimage of d under the map.
    refine' ⟨d ≫ g, _⟩
    calc
      f ≫ (d ≫ g) = (f ≫ g) ≫ d := by simp [Functional.comp_apply, Function.comp]
      _ = id X ≫ d := by rw [hg]
      _ = d := by simp [Functional.comp_apply]
  · -- Prove the reverse direction: if for every c, the map is surjective, then f is a split epi.
    intro h
    -- For c = X, the map fun g : Hom Y X => f ≫ g is surjective, so we can find a g such that f ≫ g = id X.
    have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
    obtain ⟨g, hg⟩ := h₁ (id X)
    refine' ⟨g, _⟩
    -- We have f ≫ g = id X, which means g is a right inverse of f.
    simpa [Functional.comp_apply] using hg
