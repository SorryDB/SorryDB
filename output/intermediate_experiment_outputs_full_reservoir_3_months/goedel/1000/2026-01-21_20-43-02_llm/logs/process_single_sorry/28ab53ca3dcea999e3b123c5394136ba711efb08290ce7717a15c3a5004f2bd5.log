def Category.split_epi {X Y : α} (f : Hom X Y) := ∃ (g : Hom Y X), IsRetraction f g
def split_mono {X Y : α} (f : Hom Y X) := ∃ (g : Hom X Y), IsSection f g

theorem split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if f is a split epi, then for every c, the function (fun g => f ≫ g) is surjective.
    intro h
    -- Assume f is a split epi, so there exists g : Hom Y X such that f ≫ g = id X.
    rcases h with ⟨g, hg⟩
    intro c
    -- For any c : α, we need to show that (fun g : Hom Y c => f ≫ g) is surjective.
    have h₁ : Function.Surjective (fun g : Hom Y c => f ≫ g) := by
      -- Given any h : Hom X c, we can find a preimage by considering h ≫ g.
      intro h
      refine' ⟨h ≫ g, _⟩
      calc
        f ≫ (h ≫ g) = h ≫ (f ≫ g) := by
          simp [comp_assoc, ← comp_assoc]
          <;>
          simp_all [comp_assoc]
          <;>
          try simp_all [comp_assoc]
          <;>
          try simp_all [comp_assoc]
        _ = h ≫ (id X) := by rw [hg]
        _ = h := by simp [id_comp]
    exact h₁
  · -- Prove the backward direction: if for every c, the function (fun g => f ≫ g) is surjective, then f is a split epi.
    intro h
    -- For c = X, the function (fun g : Hom Y X => f ≫ g) is surjective.
    have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
    -- The identity morphism id X : Hom X X is in the codomain, so there exists g : Hom Y X such that f ≫ g = id X.
    have h₂ : ∃ (g : Hom Y X), f ≫ g = id X := by
      -- Since (fun g : Hom Y X => f ≫ g) is surjective, there exists g : Hom Y X such that f ≫ g = id X.
      have h₃ : ∃ (g : Hom Y X), (fun g : Hom Y X => f ≫ g) g = id X := by
        apply h₁
        <;> simp [id_comp]
      -- Obtain the required g from the existence statement.
      obtain ⟨g, hg⟩ := h₃
      exact ⟨g, by simpa using hg⟩
    -- Therefore, f is a split epi.
    obtain ⟨g, hg⟩ := h₂
    refine' ⟨g, _⟩
    <;> simp_all [IsRetraction]
