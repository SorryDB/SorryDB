theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if f is a split epi, then for every c, (fun g => f ≫ g) is surjective.
    intro h
    have h₁ : ∃ (g : Hom Y X), IsRetraction f g := h
    rcases h₁ with ⟨g, hg⟩
    intro c
    have h₂ : Function.Surjective (fun g : Hom Y c => f ≫ g) := by
      -- Given any h : X → c, we need to find a g : Y → c such that f ≫ g = h.
      intro h
      -- Use g' = h ∘ g : Y → c.
      have h₃ : ∃ (g' : Hom Y c), f ≫ g' = h := by
        use h ≫ g
        calc
          f ≫ (h ≫ g) = (f ≫ g) ≫ h := by rw [comp_assoc]
          _ = id X ≫ h := by rw [hg]
          _ = h := by simp [comp_id]
      obtain ⟨g', hg'⟩ := h₃
      exact ⟨g', by simp_all [Function.funext_iff]⟩
    exact h₂
  · -- Prove the reverse direction: if for every c, (fun g => f ≫ g) is surjective, then f is a split epi.
    intro h
    have h₁ : ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := h
    -- We need to find a g : Y → X such that f ≫ g = id X.
    have h₂ : ∃ (g : Hom Y X), f ≫ g = id X := by
      -- Use the surjectivity for c = X.
      have h₃ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h₁ X
      -- There exists a g : Y → X such that f ≫ g = id X.
      have h₄ : ∃ (g : Hom Y X), f ≫ g = id X := by
        have h₅ : id X ∈ Set.range (fun g : Hom Y X => f ≫ g) := by
          apply h₃
        rcases h₅ with ⟨g, hg⟩
        exact ⟨g, by simp_all [Function.funext_iff]⟩
      exact h₄
    obtain ⟨g, hg⟩ := h₂
    -- Therefore, f is a split epi.
    refine' ⟨g, _⟩
    exact hg
