lemma Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  simp [split_epi, IsRetraction]
  <;>
  (try tauto) <;>
  (try
    {
      constructor
      · rintro ⟨g, hg⟩ c y
        refine' ⟨g ≫ y, _⟩
        simp [hg, comp_assoc]
      · intro h
        have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
        obtain ⟨g, hg⟩ := h₁ (id X)
        refine' ⟨g, _⟩
        simp [hg]
        <;>
        (try simp_all [comp_assoc, id_comp, comp_id]) <;>
        (try aesop)
    })
```
