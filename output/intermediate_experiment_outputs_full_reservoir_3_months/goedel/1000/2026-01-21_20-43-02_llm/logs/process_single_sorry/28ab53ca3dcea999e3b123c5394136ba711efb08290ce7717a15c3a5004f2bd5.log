    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if f is a split epi, then for every c, the map g ↦ f ≫ g is surjective.
    intro h
    obtain ⟨g, hg⟩ := h
    intro c
    have h₁ : Function.Surjective (fun g : Hom Y c => f ≫ g) := by
      intro h₂
      -- For any h₂ : Hom X c, we need to find g : Hom Y c such that f ≫ g = h₂.
      -- Since f is a split epi, there exists g : Hom Y c such that f ≫ g = h₂.
      have h₃ : f ≫ (h₂ ≫ g) = h₂ := by
        calc
          f ≫ (h₂ ≫ g) = (f ≫ g) ≫ h₂ := by
            simp [Hom.ext]
            <;> simp_all [comp_assoc]
            <;> try simp_all [Hom.ext]
            <;> try simp_all [comp_assoc]
          _ = id X ≫ h₂ := by rw [hg]
          _ = h₂ := by simp [id_comp]
      refine' ⟨h₂ ≫ g, _⟩
      have h₄ : f ≫ (h₂ ≫ g) = h₂ := h₃
      simpa [comp_assoc] using h₄
    exact h₁
  · -- Prove the reverse direction: if for every c, the map g ↦ f ≫ g is surjective, then f is a split epi.
    intro h
    -- Use the surjectivity condition with c = X to find a right inverse.
    have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
    -- Since the map is surjective, there exists g : Hom Y X such that f ≫ g = id X.
    obtain ⟨g, hg⟩ := h₁ (id X)
    -- Show that g is a right inverse of f.
    have h₂ : f ≫ g = id X := by
      simpa [id_comp] using hg
    -- Conclude that f is a split epi.
    exact ⟨g, h₂⟩
