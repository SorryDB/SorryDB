```lean
def Category.split_epi {X Y : α} (f : Hom X Y) := ∃ (g : Hom Y X), f ≫ g = id X

theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective fun g : Hom Y c => f ≫ g := by
  constructor
  · -- (⇒) Assume `split_epi f`, prove surjectivity for all `c`.
    intro h
    rcases h with ⟨g, hg⟩
    intro c
    have h₁ : Function.Surjective (fun g' : Hom Y c => f ≫ g') := by
      intro h₂
      refine' ⟨g ≫ h₂, _⟩
      calc
        f ≫ (g ≫ h₂) = (f ≫ g) ≫ h₂ := by rw [comp_assoc]
        _ = id X ≫ h₂ := by rw [hg]
        _ = h₂ := by simp [id_comp]
    exact h₁
  · -- (⇐) Assume surjectivity for all `c`, prove `split_epi f`.
    intro h
    have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
    have h₂ : ∃ (g : Hom Y X), f ≫ g = id X := by
      have h₃ : ∃ (g : Hom Y X), f ≫ g = id X := by
        -- Since `id X : Hom X X`, we can use the surjectivity to find `g : Hom Y X`.
        have h₄ : ∃ (g : Hom Y X), f ≫ g = id X := by
          have h₅ : (Function.Surjective (fun g : Hom Y X => f ≫ g)) := h X
          have h₆ : (id X : Hom X X) ∈ Set.range (fun g : Hom Y X => f ≫ g) := by
            apply h₅
          obtain ⟨g, hg⟩ := h₆
          exact ⟨g, by simpa using hg⟩
        exact h₄
      exact h₃
    obtain ⟨g, hg⟩ := h₂
    exact ⟨g, hg⟩
```

