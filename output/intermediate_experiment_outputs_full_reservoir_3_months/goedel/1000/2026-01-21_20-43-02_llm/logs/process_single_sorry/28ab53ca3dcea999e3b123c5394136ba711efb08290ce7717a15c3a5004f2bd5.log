theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if `f` is a split epimorphism, then for every `c`, the map `g ↦ f ≫ g` is surjective.
    intro h
    have h₁ : ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
      intro c
      -- For any `c`, we need to show that `g ↦ f ≫ g` is surjective.
      -- Since `f` is a split epimorphism, there exists a right inverse `g'` such that `f ≫ g' = id X`.
      -- We will use this to construct the required `g` for any `h : Hom X c`.
      have h₂ : ∃ (g : Hom Y X), f ≫ g = id X := h
      obtain ⟨g', hg'⟩ := h₂
      -- For any `h : Hom X c`, we can set `g = g' ≫ h`, and then `f ≫ g = f ≫ g' ≫ h = id X ≫ h = h`.
      intro h
      use g' ≫ h
      rw [comp_assoc]
      rw [hg']
      simp
    exact h₁
  · -- Prove the reverse direction: if for every `c`, the map `g ↦ f ≫ g` is surjective, then `f` is a split epimorphism.
    intro h
    -- To show that `f` is a split epimorphism, we need to find a `g : Hom Y X` such that `f ≫ g = id X`.
    -- We can use the surjectivity condition with `c = X` to find such a `g`.
    have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
    -- Since `f ≫ g` is surjective as a function from `Hom Y X` to `Hom X X`, there exists some `g : Hom Y X` such that `f ≫ g = id X`.
    have h₂ : ∃ (g : Hom Y X), f ≫ g = id X := by
      -- We use the fact that `id X : Hom X X` is in the codomain, and the map is surjective.
      have h₃ : (id X : Hom X X) ∈ Set.range (fun g : Hom Y X => f ≫ g) := by
        apply h₁
        <;> simp [id_comp]
      -- Obtain the preimage `g` such that `f ≫ g = id X`.
      obtain ⟨g, hg⟩ := h₃
      exact ⟨g, by simpa using hg⟩
    -- We have found `g`, so `f` is a split epimorphism.
    exact h₂
