theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · intro h
    have h₁ : ∃ (g : Hom Y X), f ≫ g = id X := h
    rcases h₁ with ⟨g, hg⟩
    intro c
    have h₂ : Function.Surjective (fun g : Hom Y c => f ≫ g) := by
      intro w
      have h₃ : ∃ (h : Hom Y c), f ≫ h = w := by
        -- Use the retraction property to find a preimage
        have h₄ : f ≫ (g ≫ w) = w := by
          calc
            f ≫ (g ≫ w) = (f ≫ g) ≫ w := by rw [comp_assoc]
            _ = id X ≫ w := by rw [hg]
            _ = w := by simp
        refine' ⟨g ≫ w, _⟩
        <;> simp [h₄]
      obtain ⟨h, hh⟩ := h₃
      exact ⟨h, by simp [hh]⟩
    exact h₂
  · intro h
    have h₁ : ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := h
    have h₂ : ∃ (g : Hom Y X), f ≫ g = id X := by
      have h₃ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h₁ X
      have h₄ : ∃ (g : Hom Y X), f ≫ g = id X := by
        -- Since the function is surjective, there exists a g such that f ≫ g = id X
        have h₅ : id X ∈ Set.range (fun g : Hom Y X => f ≫ g) := by
          apply h₃
          <;> simp
        obtain ⟨g, hg⟩ := h₅
        exact ⟨g, by simpa using hg⟩
      exact h₄
    -- Use the existence of g to show that f is a split epi
    obtain ⟨g, hg⟩ := h₂
    exact ⟨g, hg⟩
