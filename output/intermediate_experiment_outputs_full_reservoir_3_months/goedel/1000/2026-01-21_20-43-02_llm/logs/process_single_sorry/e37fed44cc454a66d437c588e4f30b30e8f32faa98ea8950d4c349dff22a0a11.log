open Filter
open scoped Topology

namespace Cosmology

inductive SpatialGeometry : Type where
  | Spherical (k : ℝ) (h : k < 0)
  | Flat
  | Saddle (k : ℝ) (h : k > 0)

namespace SpatialGeometry

noncomputable def S (s : SpatialGeometry) : ℝ → ℝ :=
  fun r =>
    match s with
    | SpatialGeometry.Spherical k _ => k * Real.sin (r / k)
    | SpatialGeometry.Flat => r
    | SpatialGeometry.Saddle k _ => k * Real.sinh (r / k)

lemma mul_sinh_as_div (r k : ℝ) :
    k * Real.sinh (r / k) = Real.sinh (r / k) / (1 / k) := by field_simp

@[rigorous]
lemma tendsto_sinh_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
  have h1 : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
    have h2 : (fun x : ℝ => Real.sinh (r * x) / x) =ᶠ[𝓝[≠] 0] (fun x : ℝ => Real.sinh (r * x) / x) := by rfl
    have h3 : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
      have h4 : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
        -- Use the fact that sinh(r*x)/x tends to r as x approaches 0
        have h5 : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
          have h6 : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) r 0 := by
            -- Show that the derivative of sinh(r*x) at 0 is r
            have h7 : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * 0) * r) 0 := by
              have h8 : HasDerivAt (fun x : ℝ => r * x) r 0 := by
                simpa using (hasDerivAt_id (0 : ℝ)).const_mul r
              have h9 : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * 0) * r) 0 := by
                -- Use the chain rule for sinh
                have h10 : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * 0) * r) 0 := by
                  simpa using (Real.hasDerivAt_sinh (r * 0)).comp 0 h8
                exact h10
              exact h9
            have h11 : Real.cosh (r * 0) = 1 := by norm_num [Real.cosh_eq]
            have h12 : Real.cosh (r * 0) * r = r := by
              rw [h11]
              ring
            convert h7 using 1 <;> simp [h12]
          have h13 : HasDerivAt (fun x : ℝ => x) 1 0 := by
            simpa using (hasDerivAt_id (0 : ℝ))
          -- Use the fact that the derivative of sinh(r*x) at 0 is r and the derivative of x at 0 is 1
          have h14 : HasDerivAt (fun x : ℝ => Real.sinh (r * x) / x) r 0 := by
            have h15 : HasDerivAt (fun x : ℝ => Real.sinh (r * x) / x) r 0 := by
              convert HasDerivAt.div h6 h13 (by norm_num) using 1
              <;> field_simp [h6.continuousAt, h13.continuousAt]
              <;> ring
            exact h15
          -- Use the fact that the derivative of sinh(r*x)/x at 0 is r to find the limit
          have h16 : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
            have h17 : ContinuousAt (fun x : ℝ => Real.sinh (r * x) / x) 0 := by
              apply ContinuousAt.div
              · exact (ContinuousAt.sinh (ContinuousAt.mul continuousAt_const continuousAt_id))
              · exact continuousAt_id
              · norm_num
                <;> simp_all [h14.continuousAt]
            have h18 : HasDerivAt (fun x : ℝ => Real.sinh (r * x) / x) r 0 := h14
            have h19 : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
