lemma tendsto_sinh_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
  have h₁ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
    have h₂ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (r * Real.cosh (r * (0 : ℝ))) 0 := by
      have h₃ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (r * Real.cosh (r * (0 : ℝ))) 0 := by
        -- Use the chain rule to find the derivative of sinh(r * x) at x = 0
        have h₄ : HasDerivAt (fun x : ℝ => r * x) r 0 := by
          simpa using (hasDerivAt_id (0 : ℝ)).const_mul r
        have h₅ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * (0 : ℝ)) * r) 0 := by
          -- Apply the chain rule
          have h₆ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * (0 : ℝ)) * r) 0 := by
            -- Use the fact that the derivative of sinh is cosh and the chain rule
            have h₇ : HasDerivAt (fun x : ℝ => r * x) r 0 := by simpa using (hasDerivAt_id (0 : ℝ)).const_mul r
            have h₈ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * (0 : ℝ)) * r) 0 := by
              -- Apply the chain rule
              convert (Real.hasDerivAt_sinh (r * (0 : ℝ))).comp 0 h₇ using 1 <;>
                ring_nf <;> field_simp <;> ring_nf <;> norm_num
            exact h₈
          exact h₆
        -- Simplify the expression
        convert h₅ using 1 <;> ring_nf <;> simp [Real.cosh_zero]
        <;> field_simp <;> ring_nf <;> norm_num
      exact h₃
    -- Use the fact that the limit of sinh(r * x) / x as x approaches 0 is r
    have h₃ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (r * Real.cosh (r * (0 : ℝ))) 0 := h₂
    have h₄ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 (r * Real.cosh (r * (0 : ℝ)))) := by
      -- Use the fact that the derivative at 0 is the limit of the difference quotient
      have h₅ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (r * Real.cosh (r * (0 : ℝ))) 0 := h₃
      have h₆ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 (r * Real.cosh (r * (0 : ℝ)))) := by
        -- Use the fact that the derivative at 0 is the limit of the difference quotient
        convert h₅.tendsto_slope_zero using 1 <;>
          (try simp [mul_comm]) <;>
          (try field_simp) <;>
          (try ring_nf) <;>
          (try simp_all [sub_eq_add_neg]) <;>
          (try norm_num) <;>
          (try linarith)
        <;>
          (try simp_all [sub_eq_add_neg]) <;>
          (try norm_num) <;>
          (try linarith)
      exact h₆
    -- Simplify the expression to show that the limit is r
    have h₅ : r * Real.cosh (r * (0 : ℝ)) = r := by
      have h₆ : Real.cosh (r * (0 : ℝ)) = 1 := by
        -- Since cosh(0) = 1
        norm_num [Real.cosh_zero]
      rw [h₆]
      <;> ring
    rw [h₅] at h₄
    exact h₄
  exact h₁
