lemma tendsto_sinh_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
  have h₁ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by
    -- Use the known limit for sinh(x)/x as x approaches 0
    have h₂ : (fun x : ℝ => Real.sinh (r * x) / x) = (fun x : ℝ => r * (Real.sinh (r * x) / (r * x))) := by
      funext x
      by_cases hx : r = 0
      · rw [hx]
        simp
        <;>
        (try ring_nf) <;>
        (try simp_all) <;>
        (try field_simp) <;>
        (try ring_nf)
      · have h₃ : r ≠ 0 := hx
        field_simp [h₃]
        <;> ring_nf
        <;> field_simp [h₃]
        <;> ring_nf
    rw [h₂]
    have h₃ : Tendsto (fun x : ℝ => r * (Real.sinh (r * x) / (r * x))) (𝓝[≠] 0) (𝓝 r) := by
      by_cases hr : r = 0
      · rw [hr]
        simp
        <;>
        (try simp_all) <;>
        (try field_simp) <;>
        (try ring_nf)
      · have h₄ : r ≠ 0 := hr
        -- Use the known limit for sinh(x)/x as x approaches 0
        have h₅ : Tendsto (fun x : ℝ => Real.sinh (r * x) / (r * x)) (𝓝[≠] 0) (𝓝 1) := by
          have h₆ : Tendsto (fun x : ℝ => Real.sinh x / x) (𝓝[≠] 0) (𝓝 1) := by
            -- Use the known limit for sinh(x)/x as x approaches 0
            have h₇ : Tendsto (fun x : ℝ => Real.sinh x / x) (𝓝[≠] 0) (𝓝 1) := by
              -- Use the known limit for sinh(x)/x as x approaches 0
              have h₈ : (fun x : ℝ => Real.sinh x / x) = (fun x : ℝ => (Real.sinh x - 0) / (x - 0)) := by
                funext x
                ring_nf
                <;>
                (try field_simp) <;>
                (try ring_nf)
              rw [h₈]
              -- Use the known limit for sinh(x)/x as x approaches 0
              have h₉ : Tendsto (fun x : ℝ => (Real.sinh x - 0) / (x - 0)) (𝓝[≠] 0) (𝓝 1) := by
                have h₁₀ : HasDerivAt Real.sinh 1 0 := by
                  -- Derivative of sinh at 0 is 1
                  simpa using (Real.hasDerivAt_sinh 0)
                -- Use the definition of the derivative to find the limit
                have h₁₁ : Tendsto (fun x : ℝ => (Real.sinh x - Real.sinh 0) / (x - 0)) (𝓝[≠] 0) (𝓝 1) := by
                  convert (h₁₀.tendsto_slope_zero) using 1 <;>
                  simp [Real.sinh_zero] <;>
                  field_simp <;>
                  ring_nf
                simpa [Real.sinh_zero] using h₁₁
              exact h₉
            exact h₇
          -- Use the composition of the limit with the function x ↦ r * x
          have h₁₀ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := by
            have h₁₁ : ContinuousAt (fun x : ℝ => r * x) 0 := by
              exact continuousAt_const.mul continuousAt_id
            have h₁₂ : (fun x : ℝ => r * x) 0 = 0 := by simp
            have h₁₃ : Tendsto (fun x : ℝ => r * x) (𝓝 0) (𝓝 0) := h₁₁.tendsto
            have h₁₄ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := by
              apply Tendsto.mono_left _ nhdsWithin_le_nhds
              apply Tendsto.mono_right _ (nhdsWithin_le_nhds)
              convert h₁₃ using 1 <;>
              simp [h₁₂] <;>
              (try simp_all) <;>
              (try field_simp) <;>
              (try ring_nf)
            exact h₁₄
          have h₁₅ : Tendsto (fun x : ℝ => Real.sinh (r * x) / (r * x)) (𝓝[≠] 0) (𝓝 1) := by
            have h₁₆ : (fun x : ℝ => Real.sinh (r * x) / (r * x)) = (fun x : ℝ => Real.sinh x / x) ∘ (fun x : ℝ => r * x) := by
              funext x
              simp [mul_comm]
              <;>
              (try ring_nf)
            rw [h₁₆]
            have h₁₇ : Tendsto (fun x : ℝ => Real.sinh x / x) (𝓝[≠] 0) (𝓝 1) := h₆
            have h₁₈ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := h₁₀
            have h₁₉ : Tendsto ((fun x : ℝ => Real.sinh x / x) ∘ (fun x : ℝ => r * x)) (𝓝[≠] 0) (𝓝 1) := by
              have h₂₀ : Tendsto (fun x : ℝ => r * x) (𝓝[≠] 0) (𝓝[≠] 0) := h₁₀
              have h₂₁ : Tendsto (fun x : ℝ => Real.sinh x / x) (𝓝[≠] 0) (𝓝 1) := h₆
              have h₂₂ : Tendsto ((fun x : ℝ => Real.sinh x / x) ∘ (fun x : ℝ => r * x)) (𝓝[≠] 0) (𝓝 1) :=
                h₂₁.comp h₂₀
              exact h₂₂
            exact h₁₉
          exact h₁₅
        -- Multiply the limit by r
        have h₁₆ : Tendsto (fun x : ℝ => r * (Real.sinh (r * x) / (r * x))) (𝓝[≠] 0) (𝓝 (r * 1)) := by
          have h₁₇ : Tendsto (fun x : ℝ => Real.sinh (r * x) / (r * x)) (𝓝[≠] 0) (𝓝 1) := h₅
          have h₁₈ : Tendsto (fun x : ℝ => r * (Real.sinh (r * x) / (r * x))) (𝓝[≠] 0) (𝓝 (r * 1)) :=
            (continuous_const.mul continuous_id).tendsto (0 : ℝ) |>.comp h₁₇
          exact h₁₈
        have h₁₉ : r * (1 : ℝ) = r := by ring
        rw [h₁₉] at h₁₆
        exact h₁₆
    exact h₃
  exact h₁
