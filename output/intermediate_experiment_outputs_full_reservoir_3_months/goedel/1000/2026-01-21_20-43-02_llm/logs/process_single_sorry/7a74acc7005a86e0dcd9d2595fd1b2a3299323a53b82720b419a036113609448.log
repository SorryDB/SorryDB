  have h_main : IsField R := by
    -- Since R is a finite division ring, it must be a field by Wedderburn's Little Theorem.
    -- We use the fact that in a finite division ring, every non-zero element has a multiplicative inverse.
    -- Additionally, the center of the ring is a field, and we can use properties of finite fields to conclude that R itself is a field.
    apply isField_iff_isDomain_ofDivisionRing.mpr
    refine ⟨_⟩
    -- Show that R is a domain by showing it has no zero divisors.
    -- In a finite division ring, the only elements that multiply to zero are zero itself.
    -- This is because if a ≠ 0 and b ≠ 0, then a * b ≠ 0.
    -- Since R is finite, it is sufficient to check that the multiplicative identity is not zero.
    refine ⟨by
      -- Check that the multiplicative identity is not zero.
      -- In a division ring, 1 ≠ 0.
      exact one_ne_zero⟩
  -- The result follows directly from the main proof.
  exact h_main
