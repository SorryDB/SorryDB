```lean
@[grind .]
theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h : l.count x = (l.filter (fun y => y ≤ pivot)).count x + (l.filter (fun y => pivot < y)).count x := by
    have h₁ : l = (l.filter (fun y => y ≤ pivot)) ++ (l.filter (fun y => pivot < y)) := by
      have h₂ : (l.filter (fun y => y ≤ pivot)) ++ (l.filter (fun y => pivot < y)) = l.filter (fun y => y ≤ pivot ∨ pivot < y) := by
        rw [List.filter_add_filter_neg]
        <;>
        (try simp_all [not_le])
        <;>
        (try tauto)
      have h₃ : l.filter (fun y => y ≤ pivot ∨ pivot < y) = l := by
        apply List.filter_true_of_mem
        intro y hy
        by_cases h₄ : y ≤ pivot
        · exact Or.inl h₄
        · have h₅ : pivot < y := by
            have h₆ : ¬(y ≤ pivot) := h₄
            have h₇ : pivot < y := by
              contrapose! h₆
              exact le_of_not_gt h₆
            exact h₇
          exact Or.inr h₅
      rw [h₂, h₃]
    rw [h₁]
    rw [List.count_append]
  have h₂ : smaller pivot l = l.filter (fun y => y ≤ pivot) := by
    simp [smaller]
  have h₃ : larger pivot l = l.filter (fun y => pivot < y) := by
    simp [larger]
  rw [h₂, h₃] at *
  linarith
