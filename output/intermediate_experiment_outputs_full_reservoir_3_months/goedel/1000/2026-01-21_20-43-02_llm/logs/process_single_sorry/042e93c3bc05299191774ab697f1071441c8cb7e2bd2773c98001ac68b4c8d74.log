           simp_all\n                                  simp_all\n                                simp_all\n                            <;>\n                            (try omega) <;>\n                            (try simp_all [List.length_filter, List.length_append]) <;>\n                            (try omega)\n                          simp_all\n                        <;>\n                        (try omega) <;>\n                        (try simp_all [List.length_filter, List.length_append]) <;>\n                        (try omega)\n                    simp_all\n                  simp_all\n                <;>\n                (try omega) <;>\n                (try simp_all [List.length_filter, List.length_append]) <;>\n                (try omega)\n            simp_all\n          simp_all\n        simp_all\n      have h₁₀ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) = l := by\n        calc\n          l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) = l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot) := by\n            simp [not_le]\n            <;>\n            (try simp_all [List.filter_append, List.filter_filter]) <;>\n            (try ring_nf) <;>\n            (try aesop)\n            <;>\n            (try simp_all [List.filter_append, List.filter_filter])",
      "\n  have h₁ : l = (smaller pivot l) ++ (larger pivot l) := by\n    have h₂ : (smaller pivot l) ++ (larger pivot l) = l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) := rfl\n    rw [h₂]\n    have h₃ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) = l := by\n      have h₄ : ∀ (y : α), y ∈ l → (y ≤ pivot) ∨ (pivot < y) := by\n        intro y hy\n        have h₅ : y ≤ pivot ∨ pivot < y := by\n          by_cases h : y ≤ pivot\n          · exact Or.inl h\n          · exact Or.inr (by\n              have h₆ : ¬y ≤ pivot := h\n              have h₇ : pivot < y := by\n                exact lt_of_not_ge h₆\n              exact h₇)\n        exact h₅\n      have h₅ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) = l := by\n        apply List.ext_get\n        intro i\n        simp [List.get]\n        <;>\n        (try\n          {\n            by_cases h : i < l.length <;>\n            by_cases h' : i < (l.filter (fun y => y ≤ pivot)).length <;>\n            by_cases h'' : i < (l.filter (fun y => pivot < y)).length <;>\n            simp_all [List.get, List.filter_eq, List.length filter, List.mem_filter] <;>\n            (try omega) <;>\n            (try\n              {\n                have h₆ := h₄ (l.get ⟨i, by omega⟩)\n                cases h₆ <;>\n                simp_all [List.get, List.filter_eq, List.length_filter, List.mem_filter] <;>\n                (try omega)\n              })\n          }) <;>\n        (try\n          {\n            have h₆ := h₄ (l.get ⟨i, by omega⟩)\n            cases h₆ <;>\n            simp_all [List.get, List.filter_eq, List.length_filter, List.mem_filter] <;>\n            (try omega)\n          }) <;>\n        (try\n          {\n            omega\n          })\n      exact h₅\n    rw [h₃]\n  rw [h₁]\n  simp [List.count_append]\n  <;>\n  (try\n    {\n      simp_all [smaller, larger]\n      <;>\n      simp_all [List.count_filter]\n    })\n  <;>\n  (try\n    {\n      ring_nf\n    })\n  <;>\n  (try\n    {\n      linarith\n    })",
      "\n  calc\n    l.count x = (l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot)).count x := by\n      have h₁ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot) = l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot) := rfl\n      have h₂ : l = l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot) := by\n        have h₃ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot) = l := by\n          have h₄ : ∀ (l : List α), l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => ¬y ≤ pivot) = l := by\n            intro l\n            induction l with\n            | nil => simp\n            | cons y ys ih =>\n              simp [List.filter_cons, List.le_of_lt_succ]\n              <;>\n              (try { simp_all [List.filter_cons, List.le_of_lt_succ] }) <;>\n              (try { aesop }) <;>\n              (try { split_ifs <;> simp_all [List.filter_cons, List.le_of_lt_succ] }) <;>\n              (try { aesop })\n          exact h₄ l\n        rw [h₃]\n      rw [h₂]\n    _ = (smaller pivot l ++ larger pivot l).count x := by\n      congr 1 <;> ext y <;> simp [smaller, larger] <;>\n      <;>\n      (try { simp_all [List.filter_cons, List.le_of_lt_succ] }) <;>\n      (try { aesop }) <;>\n      (try { split_ifs <;> simp_all [List.filter_cons, List.le_of_lt_succ] }) <;>\n      (try { aesop })\n    _ = (smaller pivot l).count x + (larger pivot l).count x := by\n      rw [List.count_append]\n      <;>\n      (try { simp_all [List.filter_cons, List.le_of_lt_succ] }) <;>\n      (try { aesop }) <;>\n      (try { split_ifs <;> simp_all [List.filter_cons, List.le_of_lt_succ] }) <;>\n      (try { aesop })",
      "\n  have h₁ : l.count x = (smaller pivot l ++ larger pivot l).count x := by\n    have h₂ : ∀ (l : List α), l = smaller pivot l ++ larger pivot l := by\n      intro l\n      have h₃ : ∀ (l : List α), l = smaller pivot l ++ larger pivot l := by\n        intro l\n        induction l with\n        | nil => simp [smaller, larger]\n        | cons y ys ih =>\n          have h₄ : y ∈ smaller pivot l ∨ y ∈ larger pivot l := by\n            by_cases h : y ≤ pivot <;> by_cases h' : pivot < y <;>\n              simp_all [smaller, larger, List.mem_filter, List.mem_cons]\n            <;>\n            (try contradiction) <;>\n            (try {\n              exfalso\n              have h₅ : ¬y ≤ pivot := by tauto\n              have h₆ : ¬pivot < y := by tauto\n              have h₇ : y = pivot := by\n                by_cases h₈ : y ≤ pivot <;> by_cases h₉ : pivot < y <;>\n                  simp_all [not_le, not_lt] <;>\n                  (try omega) <;>\n                  (try contradiction)\n              simp_all [not_le, not_lt]\n            }) <;>\n            (try tauto)\n          simp_all [smaller, larger, List.filter_cons, List.cons_append]\n          <;>\n          (try cases h₄ <;> simp_all (config := {decide := true})) <;>\n          (try omega)\n      exact h₃ l\n    have h₃ := h₂ l\n    rw [h₃]\n  have h₂ : (smaller pivot l ++ larger pivot l).count x = (smaller pivot l).count x + (larger pivot l).count x := by\n    rw [List.count_append]\n  linarith",
