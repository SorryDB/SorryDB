theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h₁ : l.count x = (smaller pivot l ++ larger pivot l).count x := by
    have h₂ : ∀ (a : α), a ∈ l → a ∈ smaller pivot l ∨ a ∈ larger pivot l := by
      intro a ha
      by_cases h : a ≤ pivot <;> by_cases h' : pivot < a <;> simp_all [smaller, larger, List.mem_filter, List.mem_cons, List.mem_singleton]
      <;>
      (try { contradiction }) <;>
      (try { exact Or.inl (by simp_all [h]) }) <;>
      (try { exact Or.inr (by simp_all [h']) })
    have h₃ : smaller pivot l ++ larger pivot l = l.filter (fun y => y ≤ pivot ∨ pivot < y) := by
      simp [smaller, larger, List.filter_or]
      <;> congr 1 <;> ext <;> simp [or_and_right]
      <;> tauto
    have h₄ : l.filter (fun y => y ≤ pivot ∨ pivot < y) = l := by
      apply List.filter_true_of_mem
      intro y hy
      by_cases h : y ≤ pivot <;> by_cases h' : pivot < y <;> simp_all [smaller, larger, List.mem_filter, List.mem_cons, List.mem_singleton]
      <;>
      (try { contradiction }) <;>
      (try { tauto }) <;>
      (try { exact le_of_not_gt (by intro h₁; simp_all [h₁]) }) <;>
      (try { exact lt_of_not_ge (by intro h₁; simp_all [h₁]) })
    have h₅ : smaller pivot l ++ larger pivot l = l := by
      rw [h₃, h₄]
    rw [h₅]
  have h₂ : (smaller pivot l ++ larger pivot l).count x = (smaller pivot l).count x + (larger pivot l).count x := by
    rw [List.count_append]
  linarith
