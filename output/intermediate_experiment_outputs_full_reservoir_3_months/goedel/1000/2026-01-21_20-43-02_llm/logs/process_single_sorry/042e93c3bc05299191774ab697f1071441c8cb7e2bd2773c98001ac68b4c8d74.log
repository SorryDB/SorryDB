@[grind .]
theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have : ∀ l : List α, l.count x = (l.filter (fun y => y ≤ pivot)).count x + (l.filter (fun y => pivot < y)).count x := by
    intro l
    have h₁ : l = (l.filter (fun y => y ≤ pivot)) ++ (l.filter (fun y => pivot < y)) := by
      have h₂ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) = l := by
        apply Eq.symm
        apply Eq.symm
        have h₃ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) = l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) := rfl
        have h₄ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) = l := by
          have h₅ : ∀ (y : α), y ∈ l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) ↔ y ∈ l := by
            intro y
            simp [List.mem_filter, List.mem_append]
            <;>
            (try cases' le_or_lt y pivot with h₆ h₆ <;>
            simp_all [h₆] <;>
            (try omega)) <;>
            (try tauto)
          apply List.ext
          intro y
          simp_all [List.mem_append, List.mem_filter]
          <;>
          (try cases' le_or_lt y pivot with h₆ h₆ <;>
          simp_all [h₆] <;>
          (try omega)) <;>
          (try tauto)
        simp_all
      simp_all [add_comm]
    rw [h₁]
    rw [List.count_append]
    <;>
    simp_all [List.count_filter_le]
  have h₂ := this l
  simp [smaller, larger] at h₂ ⊢
  <;>
  simp_all
  <;>
  linarith
