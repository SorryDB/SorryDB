```lean
theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h_main : l.count x = (l.filter (fun y => y ≤ pivot)).count x + (l.filter (fun y => pivot < y)).count x := by
    have h₁ : l.count x = (l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y)).count x := by
      have h₂ : l.filter (fun y => y ≤ pivot) ++ l.filter (fun y => pivot < y) = l := by
        apply List.ext_get
        intro i hi
        have h₃ : l.get ⟨i, hi⟩ = l.get ⟨i, hi⟩ := rfl
        by_cases h₄ : l.get ⟨i, hi⟩ ≤ pivot <;> by_cases h₅ : pivot < l.get ⟨i, hi⟩ <;> simp_all [List.get, List.filter, List.append_get]
        <;>
        (try omega) <;>
        (try {
          exfalso
          have h₆ := le_total (l.get ⟨i, hi⟩) pivot
          simp_all
          <;>
          omega
        })
      rw [h₂]
    rw [h₁]
    have h₃ : Disjoint (l.filter (fun y => y ≤ pivot)) (l.filter (fun y => pivot < y)) := by
      apply List.disjoint_left.mpr
      intro a ha₁ ha₂
      simp [List.mem_filter] at ha₁ ha₂
      have h₄ : a ≤ pivot := ha₁.2
      have h₅ : pivot < a := ha₂.2
      have h₆ : ¬(a ≤ pivot ∧ pivot < a) := by
        intro h
        have h₇ : a ≤ pivot := h.1
        have h₈ : pivot < a := h.2
        have h₉ : a < a := by
          calc
            a ≤ pivot := h₇
            _ < a := h₈
        exact lt_irrefl a h₉
      exact h₆ ⟨h₄, h₅⟩
    rw [List.count_append]
    <;> simp_all [Disjoint]
    <;>
    (try simp_all) <;>
    (try omega)
  
  have h_final : (l.count x) = (smaller pivot l).count x + (larger pivot l).count x := by
    have h₁ : (smaller pivot l).count x = (l.filter (fun y => y ≤ pivot)).count x := by
      rfl
    have h₂ : (larger pivot l).count x = (l.filter (fun y => pivot < y)).count x := by
      rfl
    have h₃ : l.count x = (l.filter (fun y => y ≤ pivot)).count x + (l.filter (fun y => pivot < y)).count x := h_main
    linarith
  
  apply h_final
``` 

