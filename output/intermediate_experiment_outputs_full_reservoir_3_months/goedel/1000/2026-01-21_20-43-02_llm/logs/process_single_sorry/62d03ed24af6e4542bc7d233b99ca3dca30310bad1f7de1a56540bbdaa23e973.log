example : ¬ Integrable (fun _ ↦ 1 : ℝ → ℝ) := by
  have h : ¬ Integrable (fun _ : ℝ => (1 : ℝ)) := by
    intro h₁
    have h₂ := h₁.nonneg
    have h₃ := h₁.comp_mul_left (2 : ℝ)
    -- The integral of a positive constant over ℝ is infinite, which contradicts integrability.
    have h₄ : ¬ Integrable (fun _ : ℝ => (2 : ℝ)) := by
      intro h₄
      have h₅ : (∫ x : ℝ, (2 : ℝ)) = ∞ := by
        -- The integral of 2 over ℝ is infinite.
        simp [integral_const]
        <;>
        norm_num [Real.volume_Ioi]
        <;>
        simp_all [ENNReal.top_ne_zero]
        <;>
        norm_num
        <;>
        simp_all [ENNReal.top_ne_zero]
        <;>
        norm_num
        <;>
        simp_all [ENNReal.top_ne_zero]
        <;>
        norm_num
      -- Since the integral is infinite, it cannot be finite.
      have h₆ : (∫ x : ℝ, (2 : ℝ)) < ∞ := by
        exact (h₄.integral_lt_∞).trans_le (by simp)
      -- Contradiction arises as the integral cannot be both finite and infinite.
      linarith
    -- Multiplying an integrable function by a constant should remain integrable.
    exact h₄ (h₃)
  exact h
