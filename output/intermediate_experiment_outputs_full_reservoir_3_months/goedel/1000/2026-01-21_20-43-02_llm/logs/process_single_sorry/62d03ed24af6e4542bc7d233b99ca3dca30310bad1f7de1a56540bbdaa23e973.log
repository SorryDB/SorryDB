example : ¬ Integrable (fun _ ↦ 1 : ℝ → ℝ) := by
  intro h
  have h₁ : Integrable (fun _ : ℝ => (1 : ℝ)) := h
  have h₂ : ¬Integrable (fun _ : ℝ => (1 : ℝ)) := by
    -- Use the fact that the integral of 1 over ℝ is infinite to show it is not integrable.
    have h₃ : ¬Integrable (fun _ : ℝ => (1 : ℝ)) := by
      intro h₄
      have h₅ : ∫ x : ℝ, (1 : ℝ) ∂volume = 0 := by
        -- The integral of a constant function over ℝ is not finite.
        have h₆ : ∫ x : ℝ, (1 : ℝ) ∂volume = ∞ := by
          -- The integral of 1 over ℝ is not finite, so we get a contradiction.
          simp [integral_const, Real.volume_Ioi]
          <;>
          simp_all [ENNReal.ofReal_eq_top]
          <;>
          norm_num
          <;>
          contradiction
        -- If the integral were finite, it would be 0, but it is actually infinite.
        simp_all [ENNReal.ofReal_eq_top]
        <;>
        norm_num
        <;>
        contradiction
      -- If the integral were 0, it would contradict the fact that the function is positive.
      have h₇ : ∫ x : ℝ, (1 : ℝ) ∂volume ≠ 0 := by
        simp [integral_const, Real.volume_Ioi]
        <;>
        simp_all [ENNReal.ofReal_eq_top]
        <;>
        norm_num
        <;>
        contradiction
      contradiction
    exact h₃
  contradiction
