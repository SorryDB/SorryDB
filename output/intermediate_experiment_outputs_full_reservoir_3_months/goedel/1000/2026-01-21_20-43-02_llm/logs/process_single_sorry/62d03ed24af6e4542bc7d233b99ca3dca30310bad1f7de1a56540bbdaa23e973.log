            -- Use the fact that the integral cannot be less than infinity.
            have h₁₀ : ¬(∫ x : ℝ, (1 : ℝ)) < ∞ := h₈
            have h₁₁ : (∫ x : ℝ, (1 : ℝ)) ≥ ∞ := by
              -- Use the fact that the integral is not less than infinity.
