def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    have h : g (f 1) = 1 := by
      have h₁ : f 1 = 1 := by simp [RingHom.map_one]
      have h₂ : g (f 1) = g 1 := by rw [h₁]
      have h₃ : g 1 = 1 := by simp [RingHom.map_one]
      calc
        g (f 1) = g 1 := by rw [h₁]
        _ = 1 := by simp [RingHom.map_one]
    exact h
  map_mul' := by
    intro x y
    have h : g (f (x * y)) = g (f x) * g (f y) := by
      have h₁ : f (x * y) = f x * f y := by
        simp [RingHom.map_mul]
      have h₂ : g (f (x * y)) = g (f x * f y) := by rw [h₁]
      have h₃ : g (f x * f y) = g (f x) * g (f y) := by
        simp [RingHom.map_mul]
      calc
        g (f (x * y)) = g (f x * f y) := by rw [h₁]
        _ = g (f x) * g (f y) := by simp [RingHom.map_mul]
    exact h
  map_zero' := by
    have h : g (f 0) = 0 := by
      have h₁ : f 0 = 0 := by simp [RingHom.map_zero]
      have h₂ : g (f 0) = g 0 := by rw [h₁]
      have h₃ : g 0 = 0 := by simp [RingHom.map_zero]
      calc
        g (f 0) = g 0 := by rw [h₁]
        _ = 0 := by simp [RingHom.map_zero]
    exact h
  map_add' := by
    intro x y
    have h : g (f (x + y)) = g (f x) + g (f y) := by
      have h₁ : f (x + y) = f x + f y := by
        simp [RingHom.map_add]
      have h₂ : g (f (x + y)) = g (f x + f y) := by rw [h₁]
      have h₃ : g (f x + f y) = g (f x) + g (f y) := by
        simp [RingHom.map_add]
      calc
        g (f (x + y)) = g (f x + f y) := by rw [h₁]
        _ = g (f x) + g (f y) := by simp [RingHom.map_add]
    exact h
