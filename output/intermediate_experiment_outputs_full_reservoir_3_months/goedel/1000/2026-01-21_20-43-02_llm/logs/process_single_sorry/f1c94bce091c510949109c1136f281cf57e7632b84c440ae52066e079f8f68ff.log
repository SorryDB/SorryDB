def seqFunctor (S : LightProfinite.{0}) : ℕ+ ⥤ LightProfinite where
  obj c := profiniteComponent S c
  map : ∀ {c d : ℕ+} (f : c → d), profiniteComponent S c → profiniteComponent S d := by
    intro c d f
    exact fun x => x
  map_id : ∀ (c : ℕ+), map (id : c → c) = id := by
    intro c
    funext x
    rfl
  map_comp : ∀ {c d e : ℕ+} (f : c → d) (g : d → e), map (funcomp g f) = (map g) ∘ (map f) := by
    intro c d e f g
    funext x
    rfl
```
