```lean
instance : IsProbabilityMeasure (π i, μ i) :=
  ⟨by
    -- If the space is nonempty, then the product of 1's is 1.
    -- If the space is empty, the product is 1 by convention.
    cases Classical.em (∃ i, True) with
    | inl ⟨i, _⟩ =>
      calc
        (π i, μ i) (Set.univ : Set (ι → ℝ)) = ∏ i, μ i (Set.univ : Set ℝ) := by
          simp [MeasureTheory.pi_univ]
        _ = ∏ i, 1 := by
          congr <;> ext i <;> exact MeasureTheory.isProbabilityMeasure_one (μ i)
        _ = 1 := by simp
    | inr h =>
      -- If there are no indices, the product is 1 by convention.
      have : ι → ℝ = Empty → ℝ := by
        have : ι = Empty := by
          apply Empty.eq_of_forall_not_mem
          intro i
          have := h
          push_neg at this
          exact this ⟨i, by trivial⟩
        simp [this]
      simp_all [Function.funext_iff]
  ⟩
