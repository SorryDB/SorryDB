namespace GeometryTransformation
  def rotate : (x y : ℝ) × ℝ → (x' y' : ℝ) × ℝ := fun ⟨⟨x, y⟩, θ⟩ =>
    ⟨x * Real.cos θ - y * Real.sin θ, x * Real.sin θ + y * Real.cos θ⟩

  structure ComplexNumber (re : ℝ) (im : ℝ) :=
    re : ℝ := re
    im : ℝ := im

  def Complex.exp_Iθ (θ : ℝ) : ComplexNumber (Real.cos θ) (Real.sin θ) :=
    ⟨Real.cos θ, Real.sin θ⟩

  def Complex.mul {a b : ComplexNumber} : ComplexNumber (a.re * b.re - a.im * b.im) (a.re * b.im + a.im * b.re) :=
    ⟨a.re * b.re - a.im * b.im, a.re * b.im + a.im * b.re⟩

  def fromComplexToPair (a : ComplexNumber) : (x' y' : ℝ) × ℝ := ⟨a.re, a.im⟩

  theorem rotate_eq_complex_mul (x y θ : ℝ) :
    rotate ⟨⟨x, y⟩, θ⟩ = fromComplexToPair (Complex.mul ⟨x, y⟩ (Complex.exp_Iθ θ)) := by
