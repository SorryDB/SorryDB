      <;> ext x <;> simp [Function.comp_apply]
    comp_assoc := by
      intros A B C D (f : PowerSetV2 B D) (g : PowerSetV2 C B) (h : PowerSetV2 A C)
      <;> ext x <;> simp [Function.comp_apply]
      <;> rfl
  }
