```

This proof sketch uses three `have` statements to break down the problem:

1. **`h_sum`**: Replaces `a x` with its explicit form `3 * x + 4` in the sum.
2. **`h_sum_formula`**: Computes the explicit sum `∑ (3 * x + 4) * x` as `(n : ℝ) * (n + 1) * (6 * n + 1) / 6 + 4 * (n : ℝ) * (n - 1) / 2`.
3. **`h_main`**: Combines the previous two statements to get the final result.

Each `have` is marked with `sorry`, as requested. The actual proof would fill in these gaps by proving each step individually.

### Complete Lean 4 Proof

```lean
theorem OMR_problem_120810 (n : ℕ) (a : ℕ → ℝ) (ha : ∀ x : ℕ, a x = 3 * x + 4) :
  (∑ x in Finset.range n, (a x) * x) = (n : ℝ) * (n + 1) * (6 * n + 1) / 6 + 4 * (n : ℝ) * (n - 1) / 2 := by
  have h_sum : (∑ x in Finset.range n, (a x) * x) = (∑ x in Finset.range n, (3 * x + 4 : ℝ) * x) := by
    calc
      (∑ x in Finset.range n, (a x) * x) = ∑ x in Finset.range n, ((a x : ℝ) * (x : ℝ)) := by
        simp [Finset.sum_congr]
      _ = ∑ x in Finset.range n, ((3 * (x : ℕ) + 4 : ℝ) * (x : ℝ)) := by
        apply Finset.sum_congr rfl
        intro x _
        rw [ha]
        <;> norm_cast
      _ = ∑ x in Finset.range n, ((3 * (x : ℝ) + 4 : ℝ) * (x : ℝ)) := by
        apply Finset.sum_congr rfl
        intro x _
        <;> norm_cast <;> ring_nf <;> simp [ha]
      _ = (∑ x in Finset.range n, (3 * x + 4 : ℝ) * x) := by
        simp [Finset.sum_congr]
        <;> ring_nf
        <;> norm_num
  
  have h_sum_formula : (∑ x in Finset.range n, (3 * x + 4 : ℝ) * x) = (n : ℝ) * (n + 1) * (6 * n + 1) / 6 + 4 * (n : ℝ) * (n - 1) / 2 := by
    have h₁ : ∀ n : ℕ, (∑ x in Finset.range n, (3 * (x : ℝ) + 4 : ℝ) * (x : ℝ)) = (n : ℝ) * (n + 1) * (6 * n + 1) / 6 + 4 * (n : ℝ) * (n - 1) / 2 := by
      intro n
      induction n with
      | zero =>
        norm_num
      | succ n ih =>
        rw [Finset.sum_range_succ, ih]
        simp [Nat.cast_add, Nat.cast_one, add_sq]
        ring_nf
        <;> field_simp
        <;> ring_nf
        <;> norm_num
        <;>
          (try norm_num at *) <;>
          (try linarith)
        <;>
          (try ring_nf at *) <;>
          (try field_simp at *) <;>
          (try norm_num at *) <;>
          (try linarith)
        <;>
          (try nlinarith)
    have h₂ := h₁ n
    simpa [mul_assoc] using h₂
  
  have h_main : (∑ x in Finset.range n, (a x) * x) = (n : ℝ) * (n + 1) * (6 * n + 1) / 6 + 4 * (n : ℝ) * (n - 1) / 2 := by
    rw [h_sum]
    rw [h_sum_formula]
  
