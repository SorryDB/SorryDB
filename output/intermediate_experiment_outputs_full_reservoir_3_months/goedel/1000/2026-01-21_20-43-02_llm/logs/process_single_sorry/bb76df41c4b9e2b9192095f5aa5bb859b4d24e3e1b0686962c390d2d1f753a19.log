  exact {
    hom := fun (A B : PowerSetV1 X) => PowerSetV2 A B
    id := fun (A : PowerSetV1 X) => fun (x : A) => x
    comp := fun (A B C : PowerSetV1 X) (f : PowerSetV2 B C) (g : PowerSetV2 A B) =>
