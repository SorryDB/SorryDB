  have h_sum_formula : (∑ x in Finset.range n, (3 * x + 4 : ℝ) * x) = (n : ℝ) * (n + 1) * (6 * n + 1) / 6 + 4 * (n : ℝ) * (n - 1) / 2 := by sorry
  have h_main : (∑ x in Finset.range n, (a x) * x) = (n : ℝ) * (n + 1) * (6 * n + 1) / 6 + 4 * (n : ℝ) * (n - 1) / 2 := by sorry
