theorem main_theorem : ∀ (n : ℕ) (S : @Dist n) (σ : @OSequence n) (a b : @Agent n),
  S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro n S σ a b h
  have h₁ : ((b, S b) ∈ S⌈σ⌉a ∧ (b, !S b) ∉ S⌈σ⌉a) := by
    have h₂ : S⌈σ⌉ ⊧ (Kv a b) := h
    have h₃ : ((b, S b) ∈ S⌈σ⌉a ∧ (b, !S b) ∉ S⌈σ⌉a) := by
      -- Use the given hypothesis to deduce the required membership and non-membership
      have h₄ : S⌈σ⌉ ⊧ (Kv a b) := h₂
      -- Simplify the hypothesis using the definition of Kv
      simp only [eval, embeddedFormula, Kv] at h₄
      -- Consider the two cases for the boolean value
      by_cases h₅ : S b
      · -- Case: S b is true
        have h₆ : (b, true) ∈ S⌈σ⌉a := by
          -- Since S b is true, we need to show (b, true) ∈ S⌈σ⌉a
          simp_all [resultSet, mem_insert, mem_singleton_iff]
          <;> aesop
        have h₇ : (b, false) ∉ S⌈σ⌉a := by
          -- Since S b is true, (b, false) cannot be in S⌈σ⌉a
          simp_all [resultSet, mem_insert, mem_singleton_iff]
          <;> aesop
        -- Combine the results to get the required conjunction
        constructor <;> simp_all [Bool.not_eq_true]
        <;> aesop
      · -- Case: S b is false
        have h₆ : (b, false) ∈ S⌈σ⌉a := by
          -- Since S b is false, we need to show (b, false) ∈ S⌈σ⌉a
          simp_all [resultSet, mem_insert, mem_singleton_iff]
          <;> aesop
        have h₇ : (b, true) ∉ S⌈σ⌉a := by
          -- Since S b is false, (b, true) cannot be in S⌈σ⌉a
          simp_all [resultSet, mem_insert, mem_singleton_iff]
          <;> aesop
        -- Combine the results to get the required conjunction
        constructor <;> simp_all [Bool.not_eq_true]
        <;> aesop
    exact h₃
  exact h₁
``` 

