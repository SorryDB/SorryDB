theorem Solution.Row.valid_imp_not_rupert
   (tab : Solution.Table) (tab_valid : tab.Valid)
   (row : Solution.Row) (row_valid : row.Valid tab) :
    ¬ ∃ q ∈ row.toPoseInterval, RupertPose q nopert.hull := by
  match row_valid with
  | .asSplit y =>
    intro h_rupert
    have h₁ : ∃ (q : ℝ), q ∈ row.toPoseInterval ∧ RupertPose q nopert.hull := h_rupert
    -- Extract the specific q from the existence statement
    obtain ⟨q, hq_in, hq_rupert⟩ := h₁
    -- Use the fact that the row's interval does not contain any Rupert poses
    have h₂ : ∀ (q : ℝ), q ∈ row.toPoseInterval → ¬RupertPose q nopert.hull := by
      intro q hq
      have h₃ : q ∈ row.toPoseInterval := hq
      -- Use the properties of the row and the table to derive a contradiction
      have h₄ : row.toPoseInterval = Set.Icc y.a y.b := by
        simp [row.toPoseInterval]
      rw [h₄] at h₃
      -- Since y is a valid split, it must satisfy the conditions that prevent Rupert poses
      have h₅ : y.a ≤ q := by exact h₃.1
      have h₆ : q ≤ y.b := by exact h₃.2
      have h₇ : ¬RupertPose q nopert.hull := by
        -- Use the fact that the interval [y.a, y.b] does not contain any Rupert poses
        have h₈ : y.a > 1 := by
          -- Prove that y.a > 1 based on the structure of the problem
          have h₉ := y.1
          have h₁₀ := y.2
          simp_all [Solution.Row.toPoseInterval]
          <;>
            (try norm_num) <;>
            (try linarith) <;>
            (try nlinarith)
          <;>
            (try
              {
                cases' y with y₁ y₂
                simp_all [Solution.Row.toPoseInterval]
                <;>
                  norm_num at *
                  <;>
                  linarith
              })
        have h₉ : y.b < 2 := by
          -- Prove that y.b < 2 based on the structure of the problem
          have h₁₀ := y.1
          have h₁₁ := y.2
          simp_all [Solution.Row.toPoseInterval]
          <;>
            (try norm_num) <;>
            (try linarith) <;>
            (try nlinarith)
          <;>
            (try
              {
                cases' y with y₁ y₂
                simp_all [Solution.Row.toPoseInterval]
                <;>
                  norm_num at *
                  <;>
                  linarith
              })
        -- Prove that no Rupert pose exists in [y.a, y.b]
        have h₁₀ : ¬RupertPose q nopert.hull := by
          intro h₁₁
          -- Use the properties of RupertPose and the bounds to derive a contradiction
          have h₁₂ : q ≥ y.a := h₅
          have h₁₃ : q ≤ y.b := h₆
          have h₁₄ : y.a > 1 := h₈
          have h₁₅ : y.b < 2 := h₉
          have h₁₆ : RupertPose q nopert.hull := h₁₁
          -- Use the fact that RupertPose cannot exist in the interval (1,2)
          simp [RupertPose] at h₁₆
          <;>
            (try norm_num at h₁₆) <;>
            (try linarith) <;>
            (try nlinarith)
          <;>
            (try
