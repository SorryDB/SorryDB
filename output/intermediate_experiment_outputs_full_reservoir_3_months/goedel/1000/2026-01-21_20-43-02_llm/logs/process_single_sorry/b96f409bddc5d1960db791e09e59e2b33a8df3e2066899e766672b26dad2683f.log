      -- Since M' is a matching, its cardinality is finite
      have h₄ : M'.encard < ⊤ := by
        -- Use the fact that the cardinality of M' is a natural number
        have h₅ : M'.encard < ⊤ := by
          by_cases h₆ : M'.Finite
          · -- If M' is finite, its cardinality is a natural number
            have h₇ : M'.encard < ⊤ := by
              simp_all [encard_lt_top]
              <;>
              (try decide) <;>
              (try omega)
            exact h₇
          · -- If M' is infinite, its cardinality is not a natural number
            simp_all [encard_lt_top]
            <;>
            (try decide) <;>
            (try omega)
        exact h₅
      -- Therefore, x is less than or equal to ⊤
      exact le_of_lt h₄
    ) h₂
  have h₂ : ν(G) ≤ M.encard := by
    -- Use the fact that M is a maximum matching
    have h₃ : ∀ (M' : Set β), G.IsMatching M' → M'.encard ≤ M.encard := h.max
    have h₄ : ν(G) = sSup {n : ℕ∞ | ∃ (M' : Set β), G.IsMatching M' ∧ n = M'.encard} := rfl
    rw [h₄]
    -- Use the fact that M.encard is an upper bound for the set
    have h₅ : sSup {n : ℕ∞ | ∃ (M' : Set β), G.IsMatching M' ∧ n = M'.encard} ≤ M.encard := by
      apply csSup_le
      · -- Prove that the set is nonempty
        have h₆ : (∅ : Set β).encard ∈ {n : ℕ∞ | ∃ (M' : Set β), G.IsMatching M' ∧ n = M'.encard} := by
          refine' ⟨∅, _, _⟩
          · -- Prove that ∅ is a matching
            exact ⟨by simp [G.IsMatching], by simp [G.IsMatching]⟩
          · -- Prove that the cardinality of ∅ is 0
            simp
        exact ⟨(∅ : Set β).encard, h₆⟩
      · -- Prove that every element in the set is less than or equal to M.encard
        intro x hx
        rcases hx with ⟨M', hM', rfl⟩
        have h₆ : G.IsMatching M' := hM'.1
        have h₇ : M'.encard ≤ M.encard := h₃ M' h₆
        exact h₇
    exact h₅
  -- Combine the two inequalities to get the desired result
  have h₃ : M.encard = ν(G) := by
    apply le_antisymm
    · -- Prove M.encard ≤ ν(G)
      exact h₁
    · -- Prove ν(G) ≤ M.encard
      exact h₂
  exact h₃
