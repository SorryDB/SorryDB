    have h₃ : M.encard ∈ {n | ∃ M, G.IsMatching M ∧ n = M.encard} := by
      refine' ⟨M, h.toIsMatching, _⟩ <;> simp
    -- The supremum is the least upper bound.
    exact le_csSup (by
      -- The set is non-empty and bounded above by the number of edges in G.
      have h₄ : BddAbove {n | ∃ M, G.IsMatching M ∧ n = M.encard} := by
        use (E(G)).encard
