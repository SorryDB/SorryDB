lemma IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  have h₁ : M.encard ≤ ν(G) := by
    exact IsMatching.encard_le h.1
  have h₂ : M.encard ≥ ν(G) := by
    have h₃ : ν(G) ≤ M.encard := by
      have h₄ : ν(G) = sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} := rfl
      rw [h₄]
      have h₅ : M.encard ∈ {n | ∃ M, G.IsMatching M ∧ n = M.encard} := by
        refine' ⟨M, h.1, _⟩
        <;> simp
      have h₆ : sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} ≤ M.encard := by
        apply csSup_le
        · -- Show that the set is nonempty
          exact ⟨0, by
            -- The empty set is a matching with encard 0
            have h₇ : (∅ : Set β).encard = 0 := by simp
            have h₈ : G.IsMatching (∅ : Set β) := by
              refine' { subset := Set.empty_subset _, disjoint := _ }
              intro _ _ _ h₉ h₁₀ h₁₁
              simp_all
            refine' ⟨∅, h₈, by simp⟩
          ⟩
        · -- Show that all elements in the set are ≤ M.encard
          intro x hx
          rcases hx with ⟨M', hM', rfl⟩
          exact h.max hM'
      -- Combine the inequalities
      linarith
    exact h₃.symm.trans (by simp)
  -- Combine the two inequalities to get equality
  le_antisymm h₁ h₂
