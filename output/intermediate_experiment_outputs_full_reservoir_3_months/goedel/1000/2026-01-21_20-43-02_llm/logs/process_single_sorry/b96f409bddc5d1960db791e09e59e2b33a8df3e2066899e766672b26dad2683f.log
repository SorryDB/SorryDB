lemma IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  have h₁ : M.encard ≤ ν(G) := by
    -- Prove that the cardinality of M is less than or equal to the matching number of G
    apply le_csSup
    · -- Show that the set of cardinalities is bounded above
      refine' ⟨M.encard, _⟩
      -- There exists a matching M with cardinality M.encard
      exact ⟨M, h.toIsMatching, rfl⟩
    · -- Show that M.encard is in the set of cardinalities
      exact ⟨M, h.toIsMatching, rfl⟩
  -- Extract the upper bound from the definition of the matching number
  have h₂ : ν(G) ≤ M.encard := by
    -- Use the fact that M is a maximum matching
    have h₃ : ∀ M', G.IsMatching M' → M'.encard ≤ M.encard := h.max
    -- Apply this to the set of edges in G to get an upper bound
    have h₄ : ν(G) ≤ M.encard := by
      by_cases h₅ : Set.Nonempty {n | ∃ M, G.IsMatching M ∧ n = M.encard}
      · -- If the set is nonempty, use the definition of the supremum
        have h₆ : ν(G) = sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} := rfl
        rw [h₆]
        apply csSup_le
        · -- Show that the set is nonempty
          exact h₅
        · -- Show that every element in the set is less than or equal to M.encard
          intro n hn
          rcases hn with ⟨M', hM', rfl⟩
          have h₇ : M'.encard ≤ M.encard := h₃ M' hM'
          exact h₇
      · -- If the set is empty, the supremum is 0
        have h₆ : {n | ∃ M, G.IsMatching M ∧ n = M.encard} = ∅ := by
          contrapose! h₅
          exact ⟨0, by
            have h₇ : ∃ M, G.IsMatching M ∧ (0 : ℕ∞) = M.encard := by
              use ∅
              constructor
              · -- Prove that the empty set is a matching
                exact ⟨Set.empty_subset _, fun _ _ _ => by simp_all⟩
              · -- Prove that its cardinality is 0
                simp
            simpa using h₇⟩
        rw [h₆]
        simp [sSup_empty]
        <;>
        (try simp_all) <;>
        (try exact le_of_eq (by simp [h.toIsMatching.subset])) <;>
        (try exact le_of_eq (by simp [h.toIsMatching.subset]))
        <;>
        (try exact le_of_eq (by simp [h.toIsMatching.subset]))
    exact h₄
  -- Combine the two inequalities to get the desired result
  exact le_antisymm h₁ h₂
