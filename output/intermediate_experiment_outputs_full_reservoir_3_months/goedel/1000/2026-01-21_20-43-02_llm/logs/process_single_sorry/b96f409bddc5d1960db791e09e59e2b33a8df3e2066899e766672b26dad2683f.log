lemma IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  have h₁ : M.encard ≤ ν(G) := by
    have h₂ : (M : Set β).encard ≤ ν(G) := by
      have h₃ : (M : Set β).encard ∈ {n | ∃ M, G.IsMatching M ∧ n = M.encard} := by
        refine' ⟨M, h.toIsMatching, _⟩
        <;> simp
      -- The supremum of a set containing M.encard is at least M.encard
      have h₄ : (M : Set β).encard ≤ sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} := by
        apply le_csSup
        · -- Show that the set is bounded above
          use M.encard
          intro n hn
          rcases hn with ⟨M', hM', rfl⟩
          have h₅ : M'.encard ≤ M.encard := h.max M' hM'
          exact h₅
        · -- Show that M.encard is in the set
          exact h₃
      -- By definition of MatchingNumber, the supremum is ν(G)
      simpa [ν] using h₄
    exact h₂
  have h₂ : ν(G) ≤ M.encard := by
    -- Since M is a max matching, for any matching M', M'.encard ≤ M.encard
    have h₃ : ν(G) = sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} := rfl
    have h₄ : sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} ≤ M.encard := by
      apply csSup_le
      · -- Show that the set is nonempty
        refine' ⟨M.encard, ⟨M, h.toIsMatching, _⟩⟩
        <;> simp
      · -- For any n in the set, n ≤ M.encard
        intro n hn
        rcases hn with ⟨M', hM', rfl⟩
        have h₅ : M'.encard ≤ M.encard := h.max M' hM'
        exact h₅
    -- Therefore, ν(G) ≤ M.encard
    simpa [ν] using h₄
  -- Combine the two inequalities to get M.encard = ν(G)
  exact le_antisymm h₁ h₂
