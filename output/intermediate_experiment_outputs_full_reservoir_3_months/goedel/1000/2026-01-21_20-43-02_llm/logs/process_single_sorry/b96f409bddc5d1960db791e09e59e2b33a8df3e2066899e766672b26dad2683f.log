lemma IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  have h₁ : M.encard ≤ ν(G) := by
    -- Since M is a matching, its cardinality is less than or equal to the matching number of G.
    have h₂ : M.encard ≤ ν(G) := by
      -- Use the definition of the matching number as the supremum of the cardinalities of matchings in G.
      have h₃ : M.encard ∈ {n : ℕ∞ | ∃ M, G.IsMatching M ∧ n = M.encard} := by
        -- M is a matching in G, so its cardinality is in the set of all cardinalities of matchings in G.
        refine' ⟨M, h.toIsMatching, _⟩
        <;> simp
      -- The cardinality of M is less than or equal to the supremum of the set of cardinalities of matchings in G.
      have h₄ : M.encard ≤ sSup {n : ℕ∞ | ∃ M, G.IsMatching M ∧ n = M.encard} := by
        apply le_csSup
        · -- The set is non-empty because it contains the cardinality of M.
          exact ⟨M.encard, h₃⟩
        · -- The set is bounded above by the maximum cardinality of any matching in G.
          exact h₃
      -- Simplify the right-hand side to the matching number of G.
      simpa [MatchingNumber] using h₄
    exact h₂
  -- Since M is a maximum matching, its cardinality is at least the matching number of G.
  have h₂ : ν(G) ≤ M.encard := by
    -- The matching number of G is the cardinality of the largest matching in G.
    have h₃ : ν(G) ≤ M.encard := by
      -- Use the fact that M is a maximum matching to conclude that its cardinality is at least the matching number of G.
      have h₄ : ∀ M', G.IsMatching M' → M'.encard ≤ M.encard := by
        intro M' hM'
        exact h.max M' hM'
      -- Use the definition of the matching number to get an inequality in the other direction.
      have h₅ : ν(G) ≤ M.encard := by
        -- The matching number of G is the supremum of the cardinalities of matchings in G.
        -- Since M is a maximum matching, this supremum is less than or equal to the cardinality of M.
        have h₆ : ν(G) = sSup {n : ℕ∞ | ∃ M, G.IsMatching M ∧ n = M.encard} := rfl
        have h₇ : sSup {n : ℕ∞ | ∃ M, G.IsMatching M ∧ n = M.encard} ≤ M.encard := by
          -- For any matching M', its cardinality is at most the cardinality of M.
          apply csSup_le
          · -- The set is non-empty because it contains the cardinality of M.
            exact ⟨M.encard, ⟨M, h.toIsMatching, rfl⟩⟩
          · -- The set is bounded above by the cardinality of M.
            intro x hx
            rcases hx with ⟨M', hM', rfl⟩
            exact h₄ M' hM'
        -- Combine the inequalities to get the desired result.
        calc
          ν(G) = sSup {n : ℕ∞ | ∃ M, G.IsMatching M ∧ n = M.encard} := rfl
          _ ≤ M.encard := h₇
      exact h₅
    exact h₃
  -- Combine the two inequalities to get that the cardinality of M is equal to the matching number of G.
  have h₃ : M.encard = ν(G) := by
    apply le_antisymm
    · -- M.encard ≤ ν(G)
      exact h₁
    · -- ν(G) ≤ M.encard
      exact h₂
  -- The result follows directly from the antisymmetry of the inequality.
  exact h₃
