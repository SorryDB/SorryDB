  have h₁ : M.encard ≤ ν(G) := by
    -- Prove that the cardinality of M is less than or equal to the matching number of G.
    have h₂ : M.encard ∈ {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
      refine' ⟨M, h.toIsMatching, _⟩
      <;> simp
    -- Since ν(G) is the supremum of the set of matching cardinalities, M.encard ≤ ν(G).
    have h₃ : M.encard ≤ sSup {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
      apply le_csSup
      · -- Prove that the set is bounded above.
        use ν(G)
        <;> simp [ν]
        <;>
          (try decide) <;>
          (try
            {
              exact ⟨M, h.toIsMatching, by simp⟩
            }) <;>
          (try
            {
              intros n hn
              obtain ⟨M', hM', rfl⟩ := hn
              have h₄ : M'.encard ≤ ν(G) := by
                have h₅ : M'.encard ∈ {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
                  refine' ⟨M', hM', _⟩
                  <;> simp
                have h₆ : M'.encard ≤ sSup {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
                  apply le_csSup
                  · -- Prove that the set is bounded above.
                    use ν(G)
                    <;> simp [ν]
                    <;>
                      (try decide) <;>
                      (try
                        {
                          exact ⟨M, h.toIsMatching, by simp⟩
                        }) <;>
                      (try
                        {
                          intros n hn
                          obtain ⟨M'', hM'', rfl⟩ := hn
                          have h₇ : M''.encard ≤ ν(G) := by
                            have h₈ : M''.encard ∈ {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
                              refine' ⟨M'', hM'', _⟩
                              <;> simp
                            have h₉ : M''.encard ≤ sSup {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
                              apply le_csSup
                              · -- Prove that the set is bounded above.
                                use ν(G)
                                <;> simp [ν]
                                <;>
                                  (try decide) <;>
                                  (try
