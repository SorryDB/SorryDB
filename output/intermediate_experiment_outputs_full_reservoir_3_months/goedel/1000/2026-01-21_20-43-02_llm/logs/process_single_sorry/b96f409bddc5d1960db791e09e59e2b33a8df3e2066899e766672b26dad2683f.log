                                      exact ⟨M, h.toIsMatching, by simp⟩
                                    })
                              · -- Prove that M''.encard is in the set.
                                exact h₈
                            simpa [ν] using h₉
                          simpa [ν] using h₇
                        })
                  · -- Prove that M'.encard is in the set.
                    exact h₅
                simpa [ν] using h₆
              simpa [ν] using h₄
            })
      · -- Prove that M.encard is in the set.
        exact h₂
    simpa [ν] using h₃
  have h₂ : ν(G) ≤ M.encard := by
    -- Since M is a maximum matching, any other matching M' has cardinality less than or equal to M.
    have h₃ : ∀ (M' : Set β), G.IsMatching M' → M'.encard ≤ M.encard := by
      intro M' hM'
      exact h.max M' hM'
    -- By definition of the matching number, ν(G) ≤ M.encard.
    have h₄ : ν(G) = sSup {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := rfl
    have h₅ : sSup {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} ≤ M.encard := by
      apply csSup_le
      · -- Prove that the set is nonempty.
        have h₆ : (∅ : Set β).encard ∈ {n : ℕ∞ | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
