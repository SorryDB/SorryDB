lemma IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  apply le_antisymm
  · -- Prove that the cardinality of M is less than or equal to the matching number of G.
    -- Since M is a matching of G, its cardinality is in the set of cardinalities of matchings of G.
    -- The matching number is the supremum of this set, so M.encard ≤ ν(G).
    have h₁ : M.encard ∈ {n | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
      refine' ⟨M, _⟩
      exact ⟨h.toIsMatching, rfl⟩
    -- Since M.encard is in the set, it is less than or equal to the supremum of the set.
    have h₂ : M.encard ≤ sSup {n | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
      apply le_csSup
      · -- The set is bounded above because the cardinality of any matching is finite.
        use (0 : ℕ∞)
        intro x hx
        rcases hx with ⟨M, hM, rfl⟩
        exact by
          have h₃ : M.encard ≤ M.encard := le_refl _
          simp_all [Nat.cast_le]
          <;>
          (try simp_all [Set.not_nonempty_iff_eq_empty]) <;>
          (try omega) <;>
          (try norm_num) <;>
          (try linarith)
      · -- M.encard is in the set.
        exact h₁
    -- The supremum of the set is the matching number of G.
    simp only [MatchingNumber] at h₂ ⊢
    exact h₂
  · -- Prove that the matching number of G is less than or equal to the cardinality of M.
    -- Since M is a maximum matching, any other matching M' has M'.encard ≤ M.encard.
    -- In particular, the matching number, which is the supremum of the set of cardinalities of matchings,
    -- is less than or equal to M.encard.
    have h₁ : sSup {n | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} ≤ M.encard := by
      apply csSup_le
      · -- The set is nonempty because M is a matching and M.encard is in the set.
        have h₂ : M.encard ∈ {n | ∃ (M : Set β), G.IsMatching M ∧ n = M.encard} := by
          refine' ⟨M, _⟩
          exact ⟨h.toIsMatching, rfl⟩
        exact ⟨M.encard, h₂⟩
      · -- For any element x in the set, x ≤ M.encard.
        intro x hx
        rcases hx with ⟨M', hM', rfl⟩
        have h₂ : M'.encard ≤ M.encard := h.max M' hM'
        exact h₂
    -- The supremum of the set is the matching number of G.
    simp only [MatchingNumber] at h₁ ⊢
    exact h₁
