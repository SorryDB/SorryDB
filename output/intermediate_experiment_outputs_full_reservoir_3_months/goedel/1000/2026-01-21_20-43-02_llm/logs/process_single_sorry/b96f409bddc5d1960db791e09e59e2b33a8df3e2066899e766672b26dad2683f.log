      <;> simp
    have h₃ : ν(G) = sSup {n : ℕ∞ | ∃ (M' : Set β), G.IsMatching M' ∧ n = M'.encard} := rfl
    rw [h₃]
    exact le_csSup (by
      -- Prove that the set is bounded above
      use ⊤
