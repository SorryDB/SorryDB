      "\n    simp [g', interpolated_deriv, interpolator, Finset.sum_mul, Finset.mul_sum]\n    <;>\n    (try norm_num) <;>\n    (try ring_nf) <;>\n    (try simp_all [sub_mul, add_mul, mul_assoc]) <;>\n    (try field_simp) <;>\n    (try norm_num) <;>\n    (try ring_nf) <;>\n    (try simp_all [sub_mul, add_mul, mul_assoc]) <;>\n    (try field_simp) <;>\n    (try norm_num) <;>\n    (try ring_nf) <;>\n    (try simp_all [sub_mul, add_mul, mul_assoc]) <;>\n    (try field_simp)\n  rw [h1]\n  calc\n    |∑ i : Fin n, (y i - x i) * (nth_partial i f x)| ≤ ∑ i : Fin n, |(y i - x i) * (nth_partial i f x)| := by\n      exact abs_sum_le_sum_abs _ _\n    _ = ∑ i : Fin n, |y i - x i| * |nth_partial i f x| := by\n      apply Finset.sum_congr rfl\n      intro i _\n      rw [abs_mul]\n    _ ≤ ∑ i : Fin n, ε * |nth_partial i f x| := by\n      apply Finset.sum_le_sum\n      intro i _\n      have h2 : |y i - x i| ≤ ε := hdiff i\n      have h3 : |y i - x i| * |nth_partial i f x| ≤ ε * |nth_partial i f x| := by\n        have h4 : 0 ≤ |nth_partial i f x| := abs_nonneg _\n        nlinarith\n      exact h3\n    _ = ε * ∑ i : Fin n, |nth_partial i f x| := by\n      simp [Finset.mul_sum]\n      <;>\n      (try norm_num) <;>\n      (try ring_nf) <;>\n      (try simp_all [sub_mul, add_mul, mul_assoc]) <;>\n      (try field_simp) <;>\n      (try norm_num) <;>\n      (try ring_nf) <;>\n      (try simp_all [sub_mul, add_mul, mul_assoc]) <;>\n      (try field_simp) <;>\n      (try norm_num) <;>\n      (try ring_nf) <;>\n      (try simp_all [sub_mul, add_mul, mul_assoc]) <;>\n      (try field_simp)",
      "\n    simp [g', interpolated_deriv]\n    <;>\n    (try simp_all [interpolator, interpolated, Pi.add_apply, Pi.smul_apply, sub_smul]) <;>\n    (try ring_nf) <;>\n    (try field_simp [hε.ne']) <;>\n    (try norm_num) <;>\n    (try linarith) <;>\n    (try simp_all [Finset.sum_add_distrib, Finset.mul_sum])\n    <;>\n    (try aesop)\n  rw [h₁]\n  have h₂ : ∑ i : Fin n, (y i - x i) * nth_partial i f x = ∑ i : Fin n, (y i - x i) * nth_partial i f x := rfl\n  rw [h₂]\n  -- Use the triangle inequality to bound the absolute value of the sum\n  have h₃ : |∑ i : Fin n, (y i - x i) * nth_partial i f x| ≤ ∑ i : Fin n, |(y i - x i) * nth_partial i f x| := by\n    calc\n      |∑ i : Fin n, (y i - x i) * nth_partial i f x| ≤ ∑ i : Fin n, |(y i - x i) * nth_partial i f x| := by\n        exact Finset.abs_sum_le_sum_abs _ _\n      _ = ∑ i : Fin n, |(y i - x i) * nth_partial i f x| := by rfl\n  have h₄ : ∑ i : Fin n, |(y i - x i) * nth_partial i f x| ≤ ∑ i : Fin n, |y i - x i| * |nth_partial i f x| := by\n    apply Finset.sum_le_sum\n    intro i _\n    have h₅ : |(y i - x i) * nth_partial i f x| = |y i - x i| * |nth_partial i f x| := by\n      rw [abs_mul]\n    rw [h₅]\n  have h₅ : ∑ i : Fin n, |y i - x i| * |nth_partial i f x| ≤ ∑ i : Fin n, ε * |nth_partial i f x| := by\n    apply Finset.sum_le_sum\n    intro i _\n    have h₆ : |y i - x i| ≤ ε := by\n      have h₇ : |x i - y i| ≤ ε := hdiff i\n      have h₈ : |y i - x i| = |x i - y i| := by\n        rw [abs_sub_comm]\n      rw [h₈]\n      exact h₇\n    have h₇ : 0 ≤ |nth_partial i f x| := abs_nonneg _\n    nlinarith\n  have h₆ : ∑ i : Fin n, ε * |nth_partial i f x| = ε * ∑ i : Fin n, |nth_partial i f x| := by\n    rw [Finset.mul_sum]\n  calc\n    |∑ i : Fin n, (y i - x i) * nth_partial i f x| ≤ ∑ i : Fin n, |(y i - x i) * nth_partial i f x| := h₃\n    _ ≤ ∑ i : Fin n, |y i - x i| * |nth_partial i f x| := h₄\n    _ ≤ ∑ i : Fin n, ε * |nth_partial i f x| := h₅\n    _ = ε * ∑ i : Fin n, |nth_partial i f x| := by rw [h₆]",
