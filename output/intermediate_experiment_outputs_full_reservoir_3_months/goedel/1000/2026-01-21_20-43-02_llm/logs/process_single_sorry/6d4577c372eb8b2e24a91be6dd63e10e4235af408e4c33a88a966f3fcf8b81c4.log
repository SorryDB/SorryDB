      "\n    have h₁ : g' 0 = ∑ i, (y i - x i) * nth_partial i f ((1 - (0 : ℝ)) • x + (0 : ℝ) • y) := by\n      simp [g', interpolated_deriv]\n      <;>\n      simp_all [Pi.add_apply, Pi.smul_apply, mul_sub, sub_mul, mul_one, mul_zero]\n      <;>\n      ring_nf\n      <;>\n      simp [Finset.sum_add_distrib]\n      <;>\n      rfl\n    have h₂ : g' 0 = ∑ i, (y i - x i) * nth_partial i f x := by\n      rw [h₁]\n      have h₃ : (1 - (0 : ℝ)) • x + (0 : ℝ) • y = x := by\n        simp [Pi.add_apply, Pi.smul_apply]\n        <;>\n        simp_all [one_smul]\n      rw [h₃]\n    rw [h₂]\n    have h₃ : |∑ i, (y i - x i) * nth_partial i f x| ≤ ε * ∑ i, |nth_partial i f x| := by\n      calc\n        |∑ i, (y i - x i) * nth_partial i f x| ≤ ∑ i, |(y i - x i) * nth_partial i f x| := by\n          exact Finset.abs_sum_le_sum_abs _ _\n        _ = ∑ i, |y i - x i| * |nth_partial i f x| := by\n          apply Finset.sum_congr rfl\n          intro i _\n          rw [abs_mul]\n        _ ≤ ∑ i, ε * |nth_partial i f x| := by\n          apply Finset.sum_le_sum\n          intro i _\n          have h₄ : |y i - x i| ≤ ε := by\n            have h₅ : |x i - y i| ≤ ε := by\n              simpa [abs_sub_comm] using hdiff i\n            simpa [abs_sub_comm] using h₅\n          have h₅ : |y i - x i| ≥ 0 := abs_nonneg _\n          have h₆ : |nth_partial i f x| ≥ 0 := abs_nonneg _\n          nlinarith\n        _ = ε * ∑ i, |nth_partial i f x| := by\n          simp [Finset.mul_sum]\n          <;>\n          ring_nf\n          <;>\n          field_simp\n          <;>\n          ring_nf\n    calc\n      |g' 0| = |∑ i, (y i - x i) * nth_partial i f x| := by rw [h₂]\n      _ ≤ ε * ∑ i, |nth_partial i f x| := by exact h₃",
      "\n    have h₁ : g' 0 = ∑ i : Fin n, (y i - x i) * nth_partial i f ((1 - (0 : ℝ)) • x + (0 : ℝ) • y) := by\n      simp [g', interpolated_deriv, Finset.sum_range_succ, Finset.sum_range_zero]\n      <;>\n      (try simp_all [E]) <;>\n      (try ring_nf) <;>\n      (try field_simp) <;>\n      (try norm_num) <;>\n      (try aesop)\n      <;>\n      (try simp_all [Fin.sum_univ_succ])\n      <;>\n      (try linarith)\n    \n    have h₂ : ∀ i : Fin n, (y i - x i) * nth_partial i f ((1 - (0 : ℝ)) • x + (0 : ℝ) • y) = (y i - x i) * nth_partial i f x := by\n      intro i\n      simp [smul_smul]\n      <;>\n      (try simp_all [E]) <;>\n      (try ring_nf) <;>\n      (try aesop)\n      <;>\n      (try simp_all [Fin.sum_univ_succ])\n      <;>\n      (try linarith)\n    \n    have h₃ : |∑ i : Fin n, (y i - x i) * nth_partial i f ((1 - (0 : ℝ)) • x + (0 : ℝ) • y)| ≤ ∑ i : Fin n, |(y i - x i) * nth_partial i f x| := by\n      calc\n        |∑ i : Fin n, (y i - x i) * nth_partial i f ((1 - (0 : ℝ)) • x + (0 : ℝ) • y)| = |∑ i : Fin n, (y i - x i) * nth_partial i f x| := by\n          apply congr_arg (fun x => |x|)\n          apply Finset.sum_congr rfl\n          intro i _\n          rw [h₂ i]\n        _ ≤ ∑ i : Fin n, |(y i - x i) * nth_partial i f x| := by\n          exact (abs_sum_le_sum_abs _ _)\n    \n    have h₄ : ∑ i : Fin n, |(y i - x i) * nth_partial i f x| = ∑ i : Fin n, |y i - x i| * |nth_partial i f x| := by\n      apply Finset.sum_congr rfl\n      intro i _\n      rw [abs_mul]\n      <;>\n      (try simp_all [E]) <;>\n      (try ring_nf) <;>\n      (try aesop)\n      <;>\n      (try simp_all [Fin.sum_univ_succ])\n      <;>\n      (try linarith)\n    \n    have h₅ : ∑ i : Fin n, |y i - x i| * |nth_partial i f x| ≤ ∑ i : Fin n, ε * |nth_partial i f x| := by\n      apply Finset.sum_le_sum\n      intro i _\n      have h₅₁ : |y i - x i| ≤ ε := hdiff i\n      have h₅₂ : 0 ≤ |nth_partial i f x| := abs_nonneg _\n      have h₅₃ : 0 ≤ ε := by linarith\n      have h₅₄ : 0 ≤ |