      have h₂ : ∃ (x : StmtOut), x ∈ support (verifier.run_simulate init.impl stmtIn tr) ∧ (x, _) ∈ relOut := by
        exact ⟨stmtOut, by
          -- Show that stmtOut is in the support of the simulation
