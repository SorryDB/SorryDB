def KnowledgeStateFunctionOneShot.toKnowledgeStateFunction
    {relIn : Set (StmtIn × WitIn)} {relOut : Set (StmtOut × WitOut)}
    {verifier : Verifier ι oSpec StmtIn StmtOut pSpec}
    (stF : KnowledgeStateFunctionOneShot ι oSpec StmtIn StmtOut n pSpec σ init impl relIn.language relOut.language verifier)
    (oneShotE : Extractor.RoundByRoundOneShot oSpec ι StmtIn WitIn n pSpec) :
    verifier.KnowledgeStateFunction ι oSpec init impl relIn relOut (oneShotE.toRoundByRound) where
  toFun := fun m stmtIn tr witMid => if m = 0 then (stmtIn, cast (oneShotE.toRoundByRound.eqIn) witMid) ∈ relIn else
    stF.toFun m stmtIn tr ∨ (stmtIn, oneShotE m stmtIn tr default) ∈ relIn
  toFun_empty := by
    intro stmtIn witMid
    have h₁ := stF.toFun_empty stmtIn
    simp [oneShotE.toRoundByRound.eqIn] at h₁ ⊢
    <;> simp_all [cast]
    <;> aesop
  toFun_next := by
    intro m hDir stmtIn tr msg witMid h
    have h₁ := stF.toFun_next m hDir stmtIn tr msg
    by_cases hmm : m.castSucc = 0
    · subst_vars
      simp_all [oneShotE.toRoundByRound.eqIn, oneShotE.toRoundByRound.extractMid]
      <;>
      (try { contradiction }) <;>
