        <;>
        aesop
      })
      <;>
      (try {
        cases m <;> simp_all [Extractoer.RoundByRoundOneShot.toRoundByRound]
        <;>
        aesop
      })
    · by_cases hm : m = 0
      · have h₂ : m = 0 := hm
        subst_vars
        simp_all [oneShotE.toRoundByRound.eqIn, oneShotE.toRoundByRound.extractMid]
