def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine' ⟨∅, _⟩
    constructor
    · exact ⟨by simp, by intro e; simp_all⟩
    · simp
  
  indep_subset := by
    intro S hS S' hSS'
    obtain ⟨M, hM, hSM⟩ := hS
    refine' ⟨M, hM, _⟩
    exact hSS' hSM
  
  indep_aug := by
    intro I J hI hJ hIsmJ
    obtain ⟨M, hM, hsm⟩ := hJ
    refine' ⟨M, hM, _⟩
    have h₁ : I ⊆ J := hIsmJ
    have h₂ : J ⊆ V(G, M) := hsm
    exact h₁.trans h₂
  
  indep_maximal := by
    intro S hS
