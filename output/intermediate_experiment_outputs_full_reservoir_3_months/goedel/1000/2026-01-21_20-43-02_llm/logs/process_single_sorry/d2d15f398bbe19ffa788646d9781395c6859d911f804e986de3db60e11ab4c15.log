def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine' ⟨∅, ?_, ?_⟩ <;> simp [Set.subset_def]
    <;> try exact fun x hx ↦ absurd hx (Set.not_mem_empty x)
    <;> try exact ⟨⟩
  
  indep_subset := by
    intro S hS T hTS
    obtain ⟨M, hM, hS'⟩ := hS
    refine' ⟨M, hM, ?_⟩
    -- We need to show that T ⊆ V(G, M) given that S ⊆ V(G, M) and T ⊆ S.
    have hT' : T ⊆ S := hTS
    have hS'' : S ⊆ V(G, M) := hS'
    -- Since T ⊆ S and S ⊆ V(G, M), we have T ⊆ V(G, M) by transitivity.
    exact Set.Subset.trans hT' hS''
  
  indep_aug := by
    sorry
  
  indep_maximal := by
    sorry
  
  subset_ground := by
    intro (S : Set α)
    -- We need to show that if there exists a matching M such that S is a subset of V(G, M),
    -- then S is a subset of G.vertexSet.
    intro h
    obtain ⟨M, hM, hS⟩ := h
    -- Since S is a subset of V(G, M), and V(G, M) is a subset of V(G), it follows that S is a subset of V(G).
    have h₁ : V(G, M) ⊆ V(G) := by
      intro v hv
      -- For any v in V(G, M), there exists an edge e in M such that v is in V(G, e).
      obtain ⟨e, he, hv'⟩ := hv
      -- Since e is in E(G) (because M is a subset of E(G)), we have v is in V(G).
      have h₂ : e ∈ E(G) := by
        exact hM.subset (by exact he)
      -- Therefore, v is in V(G).
      exact hv'
    -- Since S is a subset of V(G, M) and V(G, M) is a subset of V(G), by transitivity, S is a subset of V(G).
    exact Set.Subset.trans hS h₁
  
  <;> try simp_all [Graph.isMatching_iff]
  <;> try tauto
