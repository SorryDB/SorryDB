def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine' ⟨∅, ⟨∅, _⟩⟩
    <;> simp_all [Set.empty_subset]
    <;> aesop
  
  indep_subset := by
    intro S₁ hS₁ S₂ hS₂ hS₂₁
    obtain ⟨M, hM, hS₁M⟩ := hS₁
    exact ⟨M, hM, Set.Subset.trans hS₂₁ hS₁M⟩
  
  indep_aug := by
    intro S₁ hS₁ S₂ hS₂ hS₂₁
    have hS₂_card : S₂.encard < S₁.encard := by
      simpa [hS₂₁] using hS₂₁.card_lt
    have hS₂_subset : S₂ ⊆ S₁ := by
      simpa [hS₂₁] using hS₂₁.subset
    obtain ⟨M, hM, hS₁M⟩ := hS₁
    -- We need to show that there exists an element in S₁ \ S₂ that can be added to S₂ while preserving independence.
    -- Since S₁ is independent and S₂ is a subset of S₁ with smaller cardinality, there must be at least one element in S₁ \ S₂.
    have hS₁_card : S₁.encard > S₂.encard := by
      linarith
    have hS₁_not_le_S₂ : ¬S₁ ⊆ S₂ := by
      intro h
      have h' : S₁.encard ≤ S₂.encard := Set.encard_le_of_subset h
      linarith
    -- There exists an element in S₁ that is not in S₂.
    have h_exists_elem : ∃ (x : α), x ∈ S₁ ∧ x ∉ S₂ := by
      by_contra! h
      have h₁ : S₁ ⊆ S₂ := by
        intro x hx
        by_cases hx' : x ∈ S₂
        · exact hx'
        · exfalso
          have h₂ := h x
          tauto
      contradiction
    obtain ⟨x, hx₁, hx₂⟩ := h_exists_elem
    -- We need to show that S₂ ∪ {x} is independent.
    -- Since S₁ is independent, there exists a matching M such that S₁ ⊆ V(G, M).
    -- We can then check if x can be added to S₂ while preserving the subset relation with V(G, M).
    have hS₂cupx : S₂ ∪ {x} ⊆ S₁ := by
      intro y hy
      simp only [Set.mem_union, Set.mem_singleton_iff] at hy
      cases hy with
      | inl h =>
        -- If y ∈ S₂, then y ∈ S₁ because S₂ ⊆ S₁.
        exact hS₂_subset h
      | inr h =>
        -- If y = x, then y ∈ S₁ because x ∈ S₁.
        rw [h]
        exact hx₁
    -- Since S₂ ∪ {x} ⊆ S₁ and S₁ is independent, there exists a matching M such that S₁ ⊆ V(G, M).
    -- Therefore, S₂ ∪ {x} ⊆ V(G, M), and S₂ ∪ {x} is independent.
    refine' ⟨M, hM, _⟩
    -- We need to show that S₂ ∪ {x} ⊆ V(G, M).
    -- Since S₂ ⊆ S₁ and x ∈ S₁, we have S₂ ∪ {x} ⊆ S₁.
    -- And S₁ ⊆ V(G, M) by the independence of S₁.
    have hS₂cupx_subset : S₂ ∪ {x} ⊆ V(G, M) := by
      -- Since S₂ ∪ {x} ⊆ S₁ and S₁ ⊆ V(G, M), we have S₂ ∪ {x} ⊆ V(G, M).
      exact Set.Subset.trans hS₂cupx hS₁M
    exact hS₂cupx_subset
  
  indep_maximal := by
    intro hS
    have h₁ : ∃ (M : Set β), G.IsMatching M ∧ V(G, M) ⊆ V(G) := by
      refine' ⟨∅, ?_, _⟩ <;> simp_all [Set.empty_subset]
      <;> aesop
    -- We use the empty set as a matching, which is always a valid matching and its vertex set is a subset of V(G).
    obtain ⟨M, hM, hM_subset⟩ := h₁
    refine' ⟨V(G, M), ?_, ?_⟩
    · -- Show that V(G, M) is independent
      exact ⟨M, hM, Set.Subset.refl _⟩
    · -- Show that V(G, M) is maximal among independent subsets
      intro S hS_indep
      have h₂ : S ⊆ V(G) := by tauto
      tauto
  
  subset_ground := by
    intro S hS
    -- Given that S is an independent set, there exists a matching M such that S ⊆ V(G, M).
    -- Since V(G, M) ⊆ V(G), it follows that S ⊆ V(G).
    obtain ⟨M, hM, hS_subset⟩ := hS
    have hM_subset : V(G, M) ⊆ V(G) := by
      intro x hx
      -- For any x in V(G, M), x is a vertex in G.
      obtain ⟨e, he⟩ := hx
      have hE : e ∈ E(G) := hM.subset he.1
      have hV : x ∈ V(G) := by
        -- Since e is in E(G), x is either the source or target of e, and hence in V(G).
        simp_all [V, E]
