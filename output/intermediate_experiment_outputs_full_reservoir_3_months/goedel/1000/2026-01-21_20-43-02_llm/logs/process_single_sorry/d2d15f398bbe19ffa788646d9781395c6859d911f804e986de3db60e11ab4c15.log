  indep_empty := by
    refine ⟨∅, ?_⟩
    exact ⟨by
      -- Prove that the empty set is a matching
      refine' ⟨by simp [E, sSub], by simp [E, sSub]⟩
      <;> aesop,
      by simp [subset_def]⟩
  indep_subset := by
    intro S T hS hT
    obtain ⟨M, hM, hS'⟩ := hS
