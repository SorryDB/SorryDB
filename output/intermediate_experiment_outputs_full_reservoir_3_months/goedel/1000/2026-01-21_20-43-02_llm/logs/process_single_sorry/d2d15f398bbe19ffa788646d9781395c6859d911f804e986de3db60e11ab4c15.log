def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine' ⟨∅, _, _⟩ <;> simp [Graph.IsMatching]
    <;> aesop
  indep_subset := by
    intro S I hI hSI
    obtain ⟨M, hM, hSI'⟩ := hI
    refine' ⟨M, hM, _⟩
    exact Set.Subset.trans hSI' hSI
  indep_aug := by
    sorry
  indep_maximal := by
    sorry
  subset_ground := by
    intro S hS
    obtain ⟨M, hM, hS'⟩ := hS
    have h₁ : S ⊆ V(G) := by
      intro v hv
      have h₂ : v ∈ V(G, M) := hS' hv
      have h₃ : v ∈ V(G) := by
        -- Since M is a matching in G, M ⊆ E(G)
        -- Therefore, any vertex in V(G, M) is in V(G)
        have h₄ : ∃ (e : β), EdgeEndpoints G e |>.left = v ∨ EdgeEndpoints G e |>.right = v := by
          -- v is in V(G, M), so it is an endpoint of some edge in M
          have h₅ : v ∈ V(G, M) := h₂
          obtain ⟨e, he⟩ := h₅
          refine' ⟨e, _⟩
          simp_all [V, EdgeEndpoints]
          <;> aesop
        obtain ⟨e, he⟩ := h₄
        have h₅ : e ∈ M := by
          -- e is in M because v is in V(G, M)
          obtain ⟨e, he⟩ := h₂
          aesop
        have h₆ : e ∈ E(G) := hM.subset h₅
        -- Since e is in E(G), its endpoints are in V(G)
        have h₇ : EdgeEndpoints G e |>.left ∈ V(G) := by
          simp [V]
          <;> aesop
        have h₈ : EdgeEndpoints G e |>.right ∈ V(G) := by
          simp [V]
          <;> aesop
        -- Therefore, v is in V(G)
        cases' he with he he
        · rw [← he]
          exact h₇
        · rw [← he]
          exact h₈
      exact h₃
    exact h₁
``` 

