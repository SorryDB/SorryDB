  have h₂ : sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} ≥ M.encard := by
    apply csSup_le
    · -- Show that the set is nonempty
      refine' ⟨0, _⟩
      -- We can use the empty matching as an example, but we need to find at least one element in the set.
      -- Since M is a matching, we can use M itself to show that the set is nonempty.
