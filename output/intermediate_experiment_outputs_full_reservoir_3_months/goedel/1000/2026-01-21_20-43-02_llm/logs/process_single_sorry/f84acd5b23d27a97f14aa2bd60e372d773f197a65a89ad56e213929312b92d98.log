      "`sorry` as is.\n\nBut",
      "\n        <;>\n        (try simp_all [SymList.fromSL, List.init, SymList.reverse, SymList.tailSL, SymList.nil]) <;>\n        (try aesop) <;>\n        (try rfl) <;>\n        (try {\n          split_ifs <;>\n          simp_all [SymList.fromSL, List.init, SymList.reverse, SymList.tailSL, SymList.nil] <;>\n          (try { contradiction }) <;>\n          (try { aesop }) <;>\n          (try { rfl })\n        })\n    | cons a as =>\n      cases bs with\n      | nil =>\n        simp_all [SymList.fromSL, List.init, SymList.reverse, SymList.tailSL, SymList.nil]\n        <;>\n        (try { contradiction }) <;>\n        (try { aesop }) <;>\n        (try { rfl })\n      | cons b bs =>\n        simp_all [SymList.fromSL, List.init, SymList.reverse, SymList.tailSL, SymList.nil]\n        <;>\n        (try { aesop }) <;>\n        (try { rfl }) <;>\n        (try {\n          split_ifs <;>\n          simp_all [SymList.fromSL, List.init, SymList.reverse, SymList.tailSL, SymList.nil] <;>\n          (try { contradiction }) <;>\n          (try { aesop }) <;>\n          (try { rfl })\n        })",
