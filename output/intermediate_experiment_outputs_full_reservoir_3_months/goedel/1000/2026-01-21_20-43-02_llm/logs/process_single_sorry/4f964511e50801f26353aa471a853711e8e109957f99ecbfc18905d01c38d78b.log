theorem solidSphere_centerOfMass {d : ℕ} (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere d.succ m R).centerOfMass = 0 := by
  have h₁ : (solidSphere d.succ m R).mass = m := by
    simpa using solidSphere_mass m R hr

