@[to_additive]
open DSmoothInv

variable {G : Type*} [DiffeologicalSpace G] [Inv G] [DSmoothInv G]

variable {F : Type*} [Group F] [DiffeologicalSpace F] [DiffeologicalGroup F]

@[to_additive]
def zpowElement (n : ℕ) (a : G) : G := zpow (n : Int) a

@[to_additive]
instance : DSmoothInv (G × F) where
  dsmooth_inv := by
    have h1 : DSmooth (fun x : G × F ↦ (x.1⁻¹, x.2⁻¹)) :=
      (dsmooth_inv.prod_mk dsmooth_inv)
    -- Convert the product space smoothness to the inverse in the product group
    have h2 : (fun x : G × F ↦ (x.1⁻¹, x.2⁻¹)) = (fun x : G × F ↦ x⁻¹) := by
      funext x
      simp [Equiv.inv_def, Prod.ext_iff]
      <;> simp_all [Inv.inv]
      <;> try ring_nf
      <;> try simp_all [zpow_neg, zpow_ofNat]
      <;> try aesop
    rw [h2] at h1
    exact h1

@[to_additive]
def dsmooth_zpow (z : ℤ) : DSmooth fun x : G => zpow z x := by
  sorry

@[to_additive]
example [z : ℤ] {x : G} : DSmooth (zpow z) := by
  sorry
  <;>
  exact dsmooth_zpow z

@[to_additive]
theorem application_zpow {F : Type*} [DiffeologicalSpace F] [DSmoothInv F] :
    DSmooth (fun x : G × F ↦ x.1 ^ 2) := by
  have h : DSmooth (fun x : G × F ↦ x.1 ^ 2) := by
    -- The function is smooth because it's a composition of smooth functions
    have h₁ : DSmooth (fun x : G × F ↦ x.1) := dsmooth_fst
    have h₂ : DSmooth (fun x : G ↦ x ^ 2) := by sorry
    have h₃ : DSmooth (fun x : G × F ↦ x.1 ^ 2) := h₂.comp h₁
    exact h₃
  exact h

end DSmoothInv
