class DSmoothInv (G : Type*) [DiffeologicalSpace G] [Inv G] : Prop where
  dsmooth_inv : DSmooth (Inv.inv : G → G)

@[to_additive]
instance {G : Type*} [DiffeologicalSpace G] [Group G] [DiffeologicalGroup G] :
    DSmoothInv G := ⟨dsmooth_inv⟩

@[to_additive]
class DSmoothMul (G : Type*) [DiffeologicalSpace G] [Mul G] : Prop where
  dsmooth_mul : DSmooth (fun p : G × G ↦ p.1 * p.2)

@[to_additive]
instance {G : Type*} [DiffeologicalSpace G] [Mul G] [DiffeologicalMul G] :
    DSmoothMul G := ⟨dsmooth_mul⟩

@[to_additive]
class DSmoothAdd (G : Type*) [DiffeologicalSpace G] [Add G] : Prop where
  dsmooth_add : DSmooth (fun p : G × G ↦ p.1 + p.2)

@[to_additive]
instance {G : Type*} [DiffeologicalSpace G] [Add G] [DiffeologicalAdd G] :
    DSmoothAdd G := ⟨dsmooth_add⟩

@[to_additive]
class DSmoothSub (G : Type*) [DiffeologicalSpace G] [Sub G] : Prop where
  dsmooth_sub : DSmooth (fun p : G × G ↦ p.1 - p.2)

@[to_additive]
class DSmoothDiv (G : Type*) [DiffeologicalSpace G] [Div G] : Prop where
  dsmooth_div' : DSmooth (fun p : G × G ↦ p.1 / p.2)

@[to_additive]
instance {G : Type*} [DiffeologicalSpace G] [Group G] [DiffeologicalGroup G] :
    DSmoothDiv G := ⟨by
  have h : DSmooth (fun p : G × G ↦ p.1 / p.2) := by
    -- Use the fact that division can be expressed as multiplication by the inverse
    have h₁ : DSmooth (fun p : G × G ↦ p.1 * p.2⁻¹) := by
      -- Prove that (x, y) ↦ x * y⁻¹ is smooth
      have h₂ : DSmooth (fun p : G × G ↦ p.1) := dsmooth_fst
      have h₃ : DSmooth (fun p : G × G ↦ p.2) := dsmooth_snd
      have h₄ : DSmooth (fun p : G × G ↦ p.2⁻¹) := h₃.inv
      -- Use the smoothness of multiplication and inversion
      have h₅ : DSmooth (fun p : G × G ↦ p.1 * p.2⁻¹) := h₂.mul h₄
      exact h₅
    -- Relate (x, y) ↦ x * y⁻¹ to (x, y) ↦ x / y
    have h₆ : (fun p : G × G ↦ p.1 / p.2) = (fun p : G × G ↦ p.1 * p.2⁻¹) := by
      ext ⟨x, y⟩
      simp [div_eq_mul_inv]
    rw [h₆]
    exact h₁
  exact h⟩

