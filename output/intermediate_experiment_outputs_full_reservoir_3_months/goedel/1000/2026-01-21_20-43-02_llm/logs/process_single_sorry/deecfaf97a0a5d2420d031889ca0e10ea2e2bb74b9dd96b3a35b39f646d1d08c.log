theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if `f` is interval integrable, then `r • f` is also interval integrable.
      intro h
      -- Use the fact that the scalar multiplication by `r` is bounded and `f` is integrable.
      have h₂ : IntervalIntegrable (r • f) μ a b := by
        -- Use the property of boundedness and scalar multiplication to transferred the integrability.
        have h₃ : IntervalIntegrable f μ a b := h
        have h₄ : BoundedSMul R E := by infer_instance
        -- Use the boundedness of scalar multiplication to show that `r • f` is integrable.
        refine' IntervalIntegrable.smul _ _
        <;> simp_all [h₃]
        <;>
        (try norm_num) <;>
        (try linarith) <;>
        (try assumption) <;>
        (try simp_all [h₃]) <;>
        (try norm_num) <;>
        (try linarith)
      exact h₂
    · -- Prove the reverse direction: if `r • f` is interval integrable, then `f` is interval integrable.
      intro h
      -- Use the fact that scalar multiplication by `r` is bounded and `r • f` is integrable.
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the property of boundedness and scalar multiplication to transfer the integrability.
        have h₃ : IntervalIntegrable (r • f) μ a b := h
        have h₄ : BoundedSMul R E := by infer_instance
        -- Use the boundedness of scalar multiplication to show that `f` is integrable.
        by_cases h₅ : r = 0
        · -- Case: `r = 0`
          simp_all [h₅]
          <;>
          (try norm_num) <;>
          (try linarith) <;>
          (try assumption) <;>
          (try simp_all [h₃]) <;>
          (try norm_num) <;>
          (try linarith)
        · -- Case: `r ≠ 0`
          have h₆ : IsUnit r := by
            -- Since `R` is a normed group and `r ≠ 0`, `r` is a unit.
            sorry
          -- Use the fact that `r` is a unit to show that `f` is integrable.
          refine' (h₃.smul (r⁻¹)).congr (h₆⁻¹.smul_left _)
          intro x
          simp_all [smul_smul]
          <;>
          (try norm_num) <;>
          (try linarith) <;>
          (try assumption) <;>
          (try simp_all [h₃]) <;>
          (try norm_num) <;>
          (try linarith)
      exact h₂
  exact h₁
