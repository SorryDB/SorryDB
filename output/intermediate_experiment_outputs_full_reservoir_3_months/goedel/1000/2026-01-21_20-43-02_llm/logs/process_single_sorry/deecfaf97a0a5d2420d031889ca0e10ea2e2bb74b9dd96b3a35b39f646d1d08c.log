theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · intro h
    -- Use the fact that scalar multiplication by `r` preserves integrability
    exact h.smul_left r
  · intro h
    -- Use the fact that scalar multiplication by `r⁻¹` preserves integrability if `r ≠ 0`
    -- and handle the case `r = 0` separately.
    by_cases hr : r = 0
    · -- If `r = 0`, then `r • f = 0`, which is trivially integrable.
      rw [hr]
      simp
      <;> get_intervalIntegrable_zero h
    · -- If `r ≠ 0`, use the inverse scalar to recover the integrability of `f`.
      have h₁ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := h.smul_left r⁻¹
      have h₂ : r⁻¹ • (r • f) = f := by
        ext x
        rw [smul_smul]
        field_simp [hr]
      rw [h₂] at h₁
      exact h₁
