      "by\n  have h_main : refinement B hB hB' hB'' < D := by\n    haveI := Classical.decEq (C := DirectSumDecomposition M)\n    -- We use the fact that there exists a decomposition B N hN not equal to {N}\n    obtain ⟨N, hN, h⟩ := H\n    -- We need to find a set in D that is not in the refinement\n    -- and thus show that the refinement is strictly smaller\n    have h₁ : ∃ (x : PersistenceSubmodule M), x ∈ D ∧ x ∉ refinement B hB hB' hB''.carrier := by\n      -- Use the decomposition B N hN to find a suitable x\n      have h₂ : B N hN ≠ {N} := h\n      have h₃ : B N hN ≠ ∅ := by\n        by_contra h₄\n        have h₅ : B N hN = ∅ := by simpa using h₄\n        have h₆ : N = sSup (B N hN) := hB N hN\n        rw [h₅] at h₆\n        have h₇ : sSup (∅ : Set (PersistenceSubmodule M)) = ⊥ := by simp\n        rw [h₇] at h₆\n        have h₈ : N = ⊥ := by simpa using h₆\n        have h₉ : N ∈ D := hN\n        have h₁₀ : ⊥ ∉ (D : Set (PersistenceSubmodule M)) := D.not_bot_mem'\n        rw [h₈] at h₉\n        exact h₁₀ h₉\n      -- Since B N hN is not empty and not {N}, we can find an element in it not equal to N\n      -- This element will be in the refinement, but N itself is in D and not in the refinement\n      have h₄ : ∃ x, x ∈ B N hN ∧ x ≠ N := by\n        by_contra h₅\n        push_neg at h₅\n        have h₆ : B N hN ⊆ {N} := by\n          intro x hx\n          have h₇ := h₅ x hx\n          by_cases h₈ : x = N\n          · simp [h₈]\n          · exfalso\n            simp_all\n        have h₇ : B N hN = {N} := by\n          apply Set.Subset.antisymm h₆\n          intro x hx\n          simp only [Set.mem_singleton_iff] at hx ⊢\n          have h₈ : x = N := by\n            have h₉ := h₅ x\n            by_cases h₁₀ : x ∈ B N hN\n            · have h₁₁ := h₉ h₁₀\n              simp_all\n            · simp_all\n          simp [h₈]\n        exact h₂ h₇\n      obtain ⟨x, hx, hx'⟩ := h₄\n      have h₅ : x ∈ refinement B hB hB' hB''.carrier := by\n        -- x is in the refinement by construction\n        simp [refinement, Set.mem_iUnion]\n        <;> aesop\n      have h₆ : N ∉ refinement B hB hB' hB''.carrier := by\n        -- N is not in the refinement because it is not in any B N' hN'\n        simp [refinement, Set.mem_iUnion]\n        <;>\n          (try aesop) <;>\n          (try\n            {\n              by_contra h₇\n              obtain ⟨N', hN', h₈⟩ := h₇\n              have h₉ : x ∈ B N' hN' := h₈\n              have h₁₀ : N = sSup (B N hN) := hB N hN\n              have h₁₁ : N' = sSup (B N' hN') := hB N' hN'\n              have h₁₂ : sSupIndep (B N' hN') := hB' N' hN'\n              have h₁₃ : ⊥ ∉ B N' hN' := hB'' N' hN'\n              simp_all [sSupIndep]\n              <;>\n                (try contradiction) <;>\n                (try aesop)\n            })\n      exact ⟨N, hN, h₆⟩\n    -- Now we have an element in D not in the refinement, so the refinement is strictly smaller\n    have h₂ : refinement B hB hB' hB''.carrier ⊂ D.carrier := by\n      have h₃ : refinement B hB hB' hB''.carrier ⊆ D.carrier := by\n        -- The refinement is a subset of D because it is a refinement\n        have h₄ : ∀ x ∈ refinement B hB hB' hB''.carrier, x ∈ D.carrier := by\n          intro x hx\n          simp [refinement, Set.mem_iUnion] at hx\n          rcases hx with ⟨N, hN, _⟩\n          have h₅ : N ∈ D := hN\n          have h₆ : x ∈ B N hN := by aesop\n          have h₇ : N = sSup (B N hN) := hB N hN\n          have h₈ : sSupIndep (B N hN) := hB' N hN\n          have h₉ : ⊥ ∉ B N hN := hB'' N hN\n          simp_all [sSupIndep]\n          <;> aesop\n        exact h₄\n      have h₄ : ∃ x, x ∈ D.carrier ∧ x ∉ refinement B hB hB' hB''.carrier := by\n        obtain ⟨x, hx, hx'⟩ := h₁\n        exact ⟨x, hx, hx'⟩\n      exact Set.ssubset_iff_subset_ne.mpr ⟨h₃, by\n        obtain ⟨x, hx, hx'⟩ := h₄\n        intro h₅\n        apply hx'\n        aesop⟩\n    -- Since the carrier of the refinement is strictly smaller, the decomposition itself is strictly smaller\n    have h₃ : refinement B hB hB' hB'' < D := by\n      simpa [SetLike.ext_iff] using h₂.lt_iff_subset_ne.mpr ⟨by\n        intro x hx\n        simp_all [SetLike.ext_iff]\n        <;> aesop, by\n        obtain ⟨x, hx, hx'⟩ := h₁\n        intro h₄\n        apply hx'\n        aesop⟩\n    exact h₃\n  exact h_main",
