          simp [refinement, Set.mem_iUnion] at hx
          rcases hx with ⟨N, hN, _⟩
          have h₅ : N ∈ D := hN
          have h₆ : x ∈ B N hN := by aesop
          have h₇ : N = sSup (B N hN) := hB N hN
          have h₈ : sSupIndep (B N hN) := hB' N hN
          have h₉ : ⊥ ∉ B N hN := hB'' N hN
          simp_all [sSupIndep]
          <;> aesop
        exact h₄
      have h₄ : ∃ x, x ∈ D.carrier ∧ x ∉ refinement B hB hB' hB''.carrier := by
        obtain ⟨x, hx, hx'⟩ := h₁
        exact ⟨x, hx, hx'⟩
