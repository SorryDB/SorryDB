 h₂₃ : B ∈ B N hN := hB\n        exact le_sSup h₂₃\n      have h₂₃ : sSup (B N hN) = N := by\n        rw [h₁₉]\n      have h₂₄ : A ≤ N := by\n        calc\n          A ≤ sSup (B N hN) := h₂₁\n          _ = N := by rw [h₁₉]\n      have h₂₅ : B ≤ N := by\n        calc\n          B ≤ sSup (B N hN) := h₂₂\n          _ = N := by rw [h₁₉]\n      have h₂₆ : Disjoint A B := h₁₆\n      have h₂₇ : A ≠ ⊥ := h₁₇\n      have h₂₈ : B ≠ ⊥ := h₁₈\n      -- We have a contradiction because we assumed that B N hN ≠ {N} but it actually must be {N}\n      have h₂₉ : False := by\n        by_contra h₃₀\n        simp_all\n      exact h₂₉\n    exact h₁₄\n  -- Use the fact that refinement B hB hB' hB'' ≤ D and refinement B hB hB' hB'' ≠ D to conclude that refinement B hB hB' hB'' < D\n  have h₃ : refinement B hB hB' hB'' < D := by\n    refine' lt_of_le_of_ne h₁ _\n    intro h_eq\n    apply h₂\n    <;> simp_all\n  exact h₃",
