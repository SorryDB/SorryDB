        obtain ⟨x, hx, hx'⟩ := h₄
        intro h₅
        apply hx'
        aesop⟩
    -- Since the carrier of the refinement is strictly smaller, the decomposition itself is strictly smaller
    have h₃ : refinement B hB hB' hB'' < D := by
      simpa [SetLike.ext_iff] using h₂.lt_iff_subset_ne.mpr ⟨by
        intro x hx
        simp_all [SetLike.ext_iff]
        <;> aesop, by
        obtain ⟨x, hx, hx'⟩ := h₁
        intro h₄
        apply hx'
        aesop⟩
    exact h₃
  exact h_main
