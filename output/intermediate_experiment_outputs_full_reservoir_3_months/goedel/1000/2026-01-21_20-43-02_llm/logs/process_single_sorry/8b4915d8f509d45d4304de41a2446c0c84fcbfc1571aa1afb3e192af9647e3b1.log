lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  have h₁ : refinement B hB hB' hB'' ≤ D := by
    apply refinement_le
  have h₂ : ¬(D ≤ refinement B hB hB' hB'') := by
    rcases H with ⟨N, hN, hB_ne⟩
    have h₃ : B N hN ≠ {N} := hB_ne
    have h₄ : N = sSup (B N hN) := hB N hN
    have h₅ : sSupIndep (B N hN) := hB' N hN
    have h₆ : ⊥ ∉ B N hN := hB'' N hN
    have h₇ : ∃ (X : Set (PersistenceSubmodule M)), X ⊆ (refinement B hB hB' hB'').carrier ∧ N = sSup X := by
      use {N}
      constructor
      · -- Show that {N} is a subset of the carrier of the refinement
        intro x hx
        simp only [Set.mem_singleton_iff] at hx
        rw [hx]
        -- Since N ∈ D, we have N ∈ ⋃ N, ⋃ hN, B N hN
        have h₈ : N ∈ (refinement B hB hB' hB'').carrier := by
          have h₉ : N ∈ D := hN
          have h₁₀ : N ∈ ⋃ (N : PersistenceSubmodule M), ⋃ (hN : N ∈ D), B N hN := by
            -- Since N ∈ D, we can find hN : N ∈ D such that N ∈ B N hN
            have h₁₁ : N ∈ ⋃ (hN : N ∈ D), B N hN := by
              exact Set.mem_iUnion_of_mem hN
            exact Set.mem_iUnion_of_mem N h₁₁
          simpa [refinement.carrier] using h₁₀
        simpa using h₈
      · -- Show that N = sSup {N}
        simp
    -- Use the existence of X to show that D is not a refinement of the refinement
    have h₈ : ∃ (B : Set (PersistenceSubmodule M)), B ⊆ (refinement B hB hB' hB'').carrier ∧ N = sSup B := by
      exact h₇
    -- Since B N hN ≠ {N}, there exists some element in B N hN that is not N
    have h₉ : ∃ (X : Set (PersistenceSubmodule M)), X ⊆ (refinement B hB hB' hB'').carrier ∧ N = sSup X := h₈
    -- Use the fact that B N hN ≠ {N} to derive a contradiction
    by_contra h
    -- If D ≤ refinement B hB hB' hB'', then for every N ∈ D, there exists B ⊆ refinement.carrier such that N = sSup B
    have h₁₀ : D ≤ refinement B hB hB' hB'' := by
      tauto
    have h₁₁ : ∀ ⦃N⦄, N ∈ D → ∃ B : Set (PersistenceSubmodule M), B ⊆ (refinement B hB hB' hB'').carrier ∧ N = sSup B := by
      intro N hN
      exact h₁₀ hN
    -- Use the fact that B N hN ≠ {N} to derive a contradiction
    have h₁₂ : B N hN ≠ {N} := hB_ne
    -- Since B N hN ≠ {N}, there exists some element in B N hN that is not N
    have h₁₃ : ∃ (X : Set (PersistenceSubmodule M)), X ⊆ (refinement B hB hB' hB'').carrier ∧ N = sSup X := h₇
    -- Use the fact that B N hN ≠ {N} to derive a contradiction
    simp_all [Set.ext_iff]
    <;>
    (try contradiction) <;>
    (try aesop) <;>
    (try {
      have h₁₄ := hB' N hN
      have h₁₅ := hB'' N hN
      simp_all [sSupIndep, sSup]
      <;>
      aesop
    })
  -- Combine the two inequalities to show that the refinement is strictly less than D
  exact lt_of_le_of_not_le h₁ h₂
