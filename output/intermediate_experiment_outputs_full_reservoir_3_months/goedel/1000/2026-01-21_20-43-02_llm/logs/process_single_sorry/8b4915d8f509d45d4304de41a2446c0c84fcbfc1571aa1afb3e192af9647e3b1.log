    obtain ⟨N, hN, h⟩ := H
    -- We need to find a set in D that is not in the refinement
    -- and thus show that the refinement is strictly smaller
    have h₁ : ∃ (x : PersistenceSubmodule M), x ∈ D ∧ x ∉ refinement B hB hB' hB''.carrier := by
      -- Use the decomposition B N hN to find a suitable x
      have h₂ : B N hN ≠ {N} := h
      have h₃ : B N hN ≠ ∅ := by
        by_contra h₄
        have h₅ : B N hN = ∅ := by simpa using h₄
        have h₆ : N = sSup (B N hN) := hB N hN
        rw [h₅] at h₆
        have h₇ : sSup (∅ : Set (PersistenceSubmodule M)) = ⊥ := by simp
        rw [h₇] at h₆
        have h₈ : N = ⊥ := by simpa using h₆
        have h₉ : N ∈ D := hN
        have h₁₀ : ⊥ ∉ (D : Set (PersistenceSubmodule M)) := D.not_bot_mem'
        rw [h₈] at h₉
        exact h₁₀ h₉
      -- Since B N hN is not empty and not {N}, we can find an element in it not equal to N
      -- This element will be in the refinement, but N itself is in D and not in the refinement
      have h₄ : ∃ x, x ∈ B N hN ∧ x ≠ N := by
        by_contra h₅
        push_neg at h₅
        have h₆ : B N hN ⊆ {N} := by
          intro x hx
          have h₇ := h₅ x hx
          by_cases h₈ : x = N
          · simp [h₈]
          · exfalso
            simp_all
        have h₇ : B N hN = {N} := by
          apply Set.Subset.antisymm h₆
          intro x hx
          simp only [Set.mem_singleton_iff] at hx ⊢
          have h₈ : x = N := by
            have h₉ := h₅ x
            by_cases h₁₀ : x ∈ B N hN
            · have h₁₁ := h₉ h₁₀
              simp_all
            · simp_all
          simp [h₈]
        exact h₂ h₇
