        simp [refinement, Set.mem_iUnion]
        <;> aesop
      have h₆ : N ∉ refinement B hB hB' hB''.carrier := by
        -- N is not in the refinement because it is not in any B N' hN'
        simp [refinement, Set.mem_iUnion]
        <;>
          (try aesop) <;>
          (try
            {
              by_contra h₇
              obtain ⟨N', hN', h₈⟩ := h₇
              have h₉ : x ∈ B N' hN' := h₈
              have h₁₀ : N = sSup (B N hN) := hB N hN
              have h₁₁ : N' = sSup (B N' hN') := hB N' hN'
              have h₁₂ : sSupIndep (B N' hN') := hB' N' hN'
              have h₁₃ : ⊥ ∉ B N' hN' := hB'' N' hN'
              simp_all [sSupIndep]
              <;>
                (try contradiction) <;>
                (try aesop)
            })
      exact ⟨N, hN, h₆⟩
    -- Now we have an element in D not in the refinement, so the refinement is strictly smaller
    have h₂ : refinement B hB hB' hB''.carrier ⊂ D.carrier := by
      have h₃ : refinement B hB hB' hB''.carrier ⊆ D.carrier := by
        -- The refinement is a subset of D because it is a refinement
        have h₄ : ∀ x ∈ refinement B hB hB' hB''.carrier, x ∈ D.carrier := by
