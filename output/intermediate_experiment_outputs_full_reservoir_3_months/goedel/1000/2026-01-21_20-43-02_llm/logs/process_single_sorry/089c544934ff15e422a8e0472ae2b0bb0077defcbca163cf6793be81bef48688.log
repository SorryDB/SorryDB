      "\n    have h₂ : (G - Y).OddComponents.encard ≤ (G - Y).vertexSet.encard := debugging_lemma\n    have h₃ : 2 * ν(G - Y) ≤ (G - Y).vertexSet.encard - (G - Y).OddComponents.encard := by\n      have h₄ : 2 * ν(G - Y) + (G - Y).OddComponents.encard ≤ (G - Y).vertexSet.encard := by\n        calc\n          2 * ν(G - Y) + (G - Y).OddComponents.encard ≤ (G - Y).vertexSet.encard := by\n            -- Proof that 2 * ν(G - Y) + odd(G - Y) ≤ |V(G - Y)|\n            have h₅ : 2 * ν(G - Y) + (G - Y).OddComponents.encard ≤ (G - Y).vertexSet.encard := by\n              -- Each odd component has at most (|V(C)| - 1)/2 edges in any matching\n              -- and we can use this to bound the total number of edges in a matching.\n              have h₆ : 2 * ν(G - Y) + (G - Y).OddComponents.encard ≤ (G - Y).vertexSet.encard := by\n                -- Use the fact that the number of vertices in odd components is at least the number of odd components\n                -- and the matching number is at most half the number of vertices.\n                have h₇ : ∀ (C : CComponent (G - Y)), C ∈ (G - Y).OddComponents → 2 * ν(C) + 1 ≤ C.vertexSet.encard := by\n                  intro C hC\n                  have h₈ : C.odd := by\n                    simp_all [G.OddComponents]\n                  have h₉ : 2 * ν(C) + 1 ≤ C.vertexSet.encard := by\n                    have h₁₀ : C.odd := by simp_all [G.OddComponents]\n                    have h₁₁ : 2 * ν(C) + 1 ≤ C.vertexSet.encard := by\n                      have h₁₂ : C.odd := by simp_all [G.OddComponents]\n                      -- Use the fact that the number of vertices in an odd component is at least 2 * ν(C) + 1\n                      have h₁₃ : 2 * ν(C) + 1 ≤ C.vertexSet.encard := by\n                        by_contra h\n                        have h₁₄ : C.vertexSet.encard < 2 * ν(C) + 1 := by\n                          omega\n                        have h₁₅ : C.vertexSet.encard < 2 * ν(C) + 1 := by\n                          omega\