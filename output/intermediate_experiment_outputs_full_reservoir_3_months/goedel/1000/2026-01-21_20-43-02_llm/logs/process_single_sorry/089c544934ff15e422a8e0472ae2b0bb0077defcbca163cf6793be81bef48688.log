ing, there are two vertices.\n                                      have h₁₅ : (V(G, M)).encard = M.encard * 2 := by\n                                        calc\n                                          (V(G, M)).encard = (V(G, M)).encard := rfl\n                                          _ = M.encard * 2 := by\n                                            have h₁₆ : ∀ (G : Graph α β) (M : Set (β)), G.IsMatching M → (V(G, M)).encard = M.encard * 2 := by\n                                              intro G M hM\n                                              -- Use the fact that each edge in the matching covers two vertices.\n                                              have h₁₇ : (V(G, M)).encard = M.encard * 2 := by\n                                                classical\n                                                -- Use the fact that each edge in the matching covers two vertices.\n                                                rw [Set.encard_eq_toFinset_card]\n                                                have h₁₈ : (G.verticesOf M).toFinset.card = M.toFinset.card * 2 := by\n                                                  have h₁₉ : (G.verticesOf M).toFinset.card = M.toFinset.card * 2 := by\n                                                    -- Use the fact that each edge in the matching covers two vertices.\n                                                    have h₂₀ : G.IsMatching M := hM\n                                                    have h₂₁ : (G.verticesOf M).toFinset.card = M.toFinset.card * 2 := by\n                                                      -- Use the fact that each edge in the matching covers two vertices.\n                                                      classical\n                                                      induction' (M.toFinset : Finset β) using Finset.induction_on with e Me IH\n                                                      · simp_all [Set.encard_eq_toFinset_card]\n                             