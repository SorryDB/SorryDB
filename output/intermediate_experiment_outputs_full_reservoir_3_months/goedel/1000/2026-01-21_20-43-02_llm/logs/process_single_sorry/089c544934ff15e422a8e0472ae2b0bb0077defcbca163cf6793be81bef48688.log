the number of vertices\n                                                have h₂₄ : ν(C) ≤ C.vertexSet.encard / 2 := by\n                                                  -- Use the fact that the number of edges in a matching is at most half the number of vertices\n                                                  have h₂₅ : ν(C) ≤ C.vertexSet.encard / 2 := by\n                                                    -- Use the fact that the number of edges in a matching is at most half the number of vertices\n                                                    have h₂₆ : 2 * ν(C) ≤ C.vertexSet.encard := by\n                                                      -- Use the fact that the number of edges in a matching is at most half the number of vertices\n                                                      have h₂₇ : 2 * ν(C) ≤ C.vertexSet.encard := by\n                                                        -- Use the fact that the number of edges in a matching is at most half the number of vertices\n                                                        apply (le_div_iff (by decide)).mpr\n                                                        <;>\n                                                        (try omega) <;>\n                                                        (try simp_all [Nat.mul_div_le]) <;>\n                                                        (try nlinarith) <;>\n                                                        (try omega)\n                                                      omega\n                                                    omega\n                                                  omega\n                                                have h₂₈ : 2 * ν(C) ≤ C.vertexSet.encard := by\n                                                  -- Use the fact that the number of edges in a matching is at most half the number of vertices\n                                                  have h₂₉ : ν(C) ≤ C.vertexSet.encard / 2 := h₂₄\n      