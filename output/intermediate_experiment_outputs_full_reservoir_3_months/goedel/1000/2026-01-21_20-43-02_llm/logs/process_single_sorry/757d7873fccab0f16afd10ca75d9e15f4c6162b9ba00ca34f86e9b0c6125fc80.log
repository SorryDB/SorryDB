lemma IsSquareIntegrable.eLpNorm_mono (hX : IsSquareIntegrable X 𝓕 P) {i j : ι} (hij : i ≤ j) :
    eLpNorm (X i) 2 P ≤ eLpNorm (X j) 2 P := by
  have h₁ : eLpNorm (X i) 2 P ≤ ⨆ k, eLpNorm (X k) 2 P := le_iSup _ i
  have h₂ : (⨆ k, eLpNorm (X k) 2 P) = ⨆ k, eLpNorm (X k) 2 P := rfl
  have h₃ : eLpNorm (X j) 2 P = eLpNorm (X j) 2 P := rfl
  have h₄ : eLpNorm (X i) 2 P ≤ eLpNorm (X j) 2 P := by
    have h₅ : eLpNorm (X j) 2 P ≤ ⨆ k, eLpNorm (X k) 2 P := le_iSup _ j
    have h₆ : IsSquareIntegrable (fun i ω => X i ω + (0 : E)) 𝓕 P := by
      refine' ⟨hX.martingale.add (by
        -- The zero function is a trivial martingale.
        refine' { adapted := fun i => (by simp [measurable_zero]) _
               , _ := by simp [measurable_zero, Filter.eventually_of_forall]
               }
        ), fun ω => by simp [hX.cadlag ω, IsCadlag]
                , _⟩
      -- The sum of a bounded function and zero is bounded.
      have h₇ : ⨆ i : ι, eLpNorm (fun ω => (X i ω : E) + (0 : E)) 2 P < ∞ := by
        calc
          (⨆ i : ι, eLpNorm (fun ω => (X i ω : E) + (0 : E)) 2 P) ≤ ⨆ i : ι, eLpNorm (X i) 2 P := by
            -- Since (0 : E) is zero, the norm of the sum is the same as the norm of X i.
            refine' iSup_mono fun i => by
              -- Use the fact that the norm of the sum is less than or equal to the sum of the norms.
              simp [eLpNorm_add_le, norm_zero, add_zero]
              <;>
              simp_all [hX.bounded]
              <;>
              exact le_iSup_of_le _ (hX.martingale.adapted i)
          _ = ⨆ i : ι, eLpNorm (X i) 2 P := by simp [hX.bounded]
          _ < ∞ := hX.bounded
      -- The sum is bounded because X is bounded.
      simpa using h₇
    -- The rest of the proof is trivial.
    exact le_trans (le_of_eq (by simp)) h₅
  exact h₄
  <;>
  try simp_all
  <;>
  try norm_num
  <;>
  try linarith
  <;>
  try assumption
  <;>
  try exact le_rfl
