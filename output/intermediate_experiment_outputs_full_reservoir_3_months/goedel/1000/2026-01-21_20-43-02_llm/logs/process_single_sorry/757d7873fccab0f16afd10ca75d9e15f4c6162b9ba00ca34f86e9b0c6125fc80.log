      "\n  have h1 : HasFiniteIntegral (norm ∘ X i) P := by\n    have h2 : Integrable (fun ω : Ω => ‖X i ω‖ ^ 2) P := hX.integrable_sq i\n    have h3 : HasFiniteIntegral (fun ω : Ω => ‖X i ω‖) P := by\n      -- Use the fact that the square of ‖X i ω‖ is integrable to deduce that ‖X i ω‖ is finite almost everywhere.\n      -- Since ‖X i ω‖ ≥ 0, the integral of ‖X i ω‖ is finite.\n      have h4 : HasFiniteIntegral (fun ω : Ω => ‖X i ω‖ ^ 2) P := by\n        simpa [pow_two] using h2.to_hasFiniteIntegral\n      have h5 : 0 ≤ (fun ω : Ω => ‖X i ω‖ : Ω → ℝ) := by\n        intro ω\n        exact norm_nonneg (X i ω)\n      have h6 : HasFiniteIntegral (fun ω : Ω => ‖X i ω‖) P := by\n        -- Use the fact that the square of ‖X i ω‖ is integrable and ‖X i ω‖ ≥ 0 to deduce that ‖X i ω‖ is integrable.\n        have h7 : (fun ω : Ω => ‖X i ω‖) ≤ (fun ω : Ω => ‖X i ω‖ ^ 2 + 1 : Ω → ℝ) := by\n          intro ω\n          have h8 : 0 ≤ ‖X i ω‖ := norm_nonneg (X i ω)\n          have h9 : 0 ≤ ‖X i ω‖ ^ 2 := by positivity\n          nlinarith [sq_nonneg (‖X i ω‖ - 1)]\n        have h10 : (fun ω : Ω => ‖X i ω‖ ^ 2 + 1 : Ω → ℝ) ≥ 0 := by\n          intro ω\n          have h11 : 0 ≤ ‖X i ω‖ ^ 2 := by positivity\n          linarith\n        have h11 : HasFiniteIntegral (fun ω : Ω => ‖X i ω‖ ^ 2 + 1 : Ω → ℝ) P := by\n          have h12 : HasFiniteIntegral (fun ω : Ω => ‖X i ω‖ ^ 2) P := h4\n          have h13 : HasFiniteIntegral (fun ω : Ω => (1 : ℝ)) P := by\n            simpa using hasFiniteIntegral_const\n          have h14 : HasFiniteIntegral (fun ω : Ω => ‖X i ω‖ ^ 2 + 1 : Ω → ℝ) P := by\n            simpa [add_comm] using HasFiniteIntegral.add h12 h13\n          exact h14\n        have h12 : HasFiniteIntegral (fun ω : Ω => ‖X i ω‖) P := by\n          -- Use the fact that ‖X i ω‖ is bounded by ‖X i ω‖ ^ 2 + 1 and the latter is integrable.\n          refine' HasFiniteIntegral.of_nonneg_of_le (by\n            intro ω\n            exact norm_nonneg (X i ω)) (by\n            intro ω\n   