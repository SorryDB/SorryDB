          <;> by_cases h : x = 0 <;> simp_all [h]
          <;> (try omega) <;> (try {
            fin_cases x <;> simp_all (config := {decide := true})
            <;> omega
          })
        }) <;>
      (try
        {
          simp_all [Finset.sum_range_succ, Finset.sum_range_zero]
          <;> norm_num
          <;> decide
        })
