      "\n  intro h\n  have h₁ : AffineExpression.ofExpression? e = some ae := by\n    rw [← h]\n    <;> simp\n  have h₂ : ae.eval = e.eval := by\n    have h₃ : ∀ (e : Expression p), AffineExpression.ofExpression? e = some ae → ae.eval = e.eval := by\n      intro e h₄\n      induction e using Expression.induction' with\n      | const n =>\n        simp [AffineExpression.ofExpression?] at h₄\n        <;>\n        (try cases p <;> simp_all [ZMod.nat_cast_self, AffineExpression.eval, AffineExpression.add, mul_by_number, AffineExpression.ofExpression?]) <;>\n        (try norm_num) <;>\n        (try ring_nf at * <;> simp_all) <;>\n        (try aesop)\n      | var x =>\n        simp [AffineExpression.ofExpression?] at h₄\n        <;>\n        (try cases p <;> simp_all [ZMod.nat_cast_self, AffineExpression.eval, AffineExpression.add, mul_by_number, AffineExpression.ofExpression?]) <;>\n        (try norm_num) <;>\n        (try ring_nf at * <;> simp_all) <;>\n        (try aesop)\n      | add e₁ e₂ =>\n        simp [AffineExpression.ofExpression?] at h₄ ⊢\n        <;>\n        (try cases p <;> simp_all [ZMod.nat_cast_self, AffineExpression.eval, AffineExpression.add, mul_by_number, AffineExpression.ofExpression?]) <;>\n        (try norm_num) <;>\n        (try ring_nf at * <;> simp_all) <;>\n        (try aesop)\n        <;>\n        (try {\n          simp_all [AffineExpression.eval, AffineExpression.add, mul_by_number, AffineExpression.ofExpression?]\n          <;>\n          (try cases p <;> simp_all [ZMod.nat_cast_self, AffineExpression.eval, AffineExpression.add, mul_by_number, AffineExpression.ofExpression?]) <;>\n          (try norm_num) <;>\n          (try ring_nf at * <;> simp_all) <;>\n          (try aesop)\n        })\n      | mul e₁ e₂ =>\n        simp [AffineExpression.ofExpression?] at h₄ ⊢\n        <;>\n        (try cases p <;> simp_all [ZMod.nat_cast_self, AffineExpression.eval, AffineExpression.add, mul_by_number, AffineExpression.ofExpression?]) <;>\n        (try norm_num) <;>\n        (try ring_nf at * <;> simp_all) <;>\n        (try aesop)\n        <;>\n        (try {\n          simp_all [AffineExpression.eval, AffineExpression.add, mul_by_number, AffineExpression.ofExpression?]\n          <;>\n          (try cases p <;> simp_all [ZMod.nat_cast_self, AffineExpression.eval, AffineExpression.add, mul_by_number, AffineExpression.ofExpression?]) <;>\n          (try norm_num) <;>\n          (try ring_nf at * <;> simp_all) <;>\n          (try aesop)\n        })\n    exact h₃ e h₁\n  exact h₂",
