lemma handshaking : ∑ v, d(v) = 2 * #E := by
  calc  ∑ v, d(v)
    _ = ∑ v, #I(v)             := by simp [G.card_incidenceFinset_eq_degree]
    _ = ∑ v, #{e ∈ E | v ∈ e}  := by simp [G.incidenceFinset_eq_filter]
    _ = ∑ e ∈ E, #{v | v ∈ e}  := Finset.sum_card_bipartiteAbove_eq_sum_card_bipartiteBelow _
    _ = ∑ e ∈ E, 2             := by
      apply Finset.sum_congr rfl
      intro e he
      have h₁ : {v | v ∈ e}.card = 2 := by
        have h₂ : e.card = 2 := by
          have h₃ : e.card = 2 := by
            -- Prove that each edge in the simple graph has exactly two elements
            have h₄ : e.card = 2 := by
              have h₅ : e ∈ G.edgeFinset := he
              have h₆ : e.card = 2 := by
                -- In a simple graph, each edge is a pair of distinct vertices
                have h₇ : e.card = 2 := by
                  simp only [Sym2.mem_coe, SimpleGraph.mem_edgeFinset] at h₅
                  simp_all [Sym2.card]
                exact h₇
              exact h₆
            exact h₄
          exact h₃
        have h₈ : {v | v ∈ e}.card = e.card := by
          simp [Set.ext_iff]
          <;> aesop
        rw [h₈, h₂]
      simp [h₁]
  <;> simp_all [Finset.card_univ]
  <;> ring
  <;> aesop
