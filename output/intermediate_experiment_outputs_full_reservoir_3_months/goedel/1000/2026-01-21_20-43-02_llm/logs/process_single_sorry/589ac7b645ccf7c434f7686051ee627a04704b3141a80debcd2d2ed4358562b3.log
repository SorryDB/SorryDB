lemma handshaking : ∑ v, d(v) = 2 * #E := by
  calc  ∑ v, d(v)
    _ = ∑ v, #I(v)             := by simp [G.card_incidenceFinset_eq_degree]
    _ = ∑ v, #{e ∈ E | v ∈ e}  := by simp [G.incidenceFinset_eq_filter]
    _ = ∑ e ∈ E, #{v | v ∈ e}  := Finset.sum_card_bipartiteAbove_eq_sum_card_bipartiteBelow _
    _ = ∑ e ∈ E, 2             := by
      apply Finset.sum_congr rfl
      intro e he
      have h₁ : {v : α | v ∈ e}.card = 2 := by
        -- Since `e` is an edge in a simple graph, it connects exactly two vertices.
        -- Thus, the set of vertices in `e` has exactly two elements.
        have h₂ : e.1 ≠ e.2 := by
          -- In a simple graph, an edge cannot connect a vertex to itself.
          intro h
          have h₃ := he
          simp [e, Sym2.ext_iff, G.mem_edgeFinset] at h₃
          <;> simp_all [G.loopless]
          <;> aesop
        -- The set `{v : α | v ∈ e}` contains exactly the two endpoints of the edge `e`.
        have h₃ : {v : α | v ∈ e} = {e.1, e.2} := by
          apply Set.ext
          intro v
