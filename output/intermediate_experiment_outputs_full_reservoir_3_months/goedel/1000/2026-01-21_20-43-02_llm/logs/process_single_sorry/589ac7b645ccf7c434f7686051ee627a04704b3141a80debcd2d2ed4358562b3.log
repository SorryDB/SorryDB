lemma handshaking : ∑ v, d(v) = 2 * #E := by
  calc  ∑ v, d(v)
    _ = ∑ v, #I(v)             := by simp [G.card_incidenceFinset_eq_degree]
    _ = ∑ v, #{e ∈ E | v ∈ e}  := by simp [G.incidenceFinset_eq_filter]
    _ = ∑ e ∈ E, #{v | v ∈ e}  := Finset.sum_card_bipartiteAbove_eq_sum_card_bipartiteBelow _
    _ = ∑ e ∈ E, 2             := Finset.sum_congr rfl (λ e he ↦
      have h₁ : ({v | v ∈ e} : Set α) = {e.1, e.2} := by
        ext x
        simp [e, Sym2.mem_lo, Sym2.mem_left_right, Sym2.mem_right_left]
        <;>
        (try cases' le_total x (x : α) with h h <;> simp_all [h]) <;>
        (try tauto) <;>
        (try aesop)
      have h₂ : ({v | v ∈ e} : Set α).card = 2 := by
        rw [h₁]
        have h₃ : e.1 ≠ e.2 := by
          intro h
          simp_all [Sym2.ext_iff]
          <;>
          aesop
        have h₄ : ({e.1, e.2} : Set α).card = 2 := by
          have h₅ : e.1 ≠ e.2 := h₃
          simp [h₅, Set.card_insert_of_not_mem, Set.mem_singleton_iff]
          <;>
          aesop
        exact h₄
      exact h₂)
