```lean
def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine ⟨∅, ⟨by simp, _⟩⟩
    simp
    <;> aesop
  indep_subset := by
    intro S₁ S₂ hS hM
    obtain ⟨M, hM₁, hM₂⟩ := hM
    refine ⟨M, hM₁, _⟩
    have h : S₁ ⊆ V(G, M) := by
      exact Set.Subset.trans hS hM₂
    exact h
  indep_aug := by
    intro X Y hX hY hYX
    have h₁ : X ⊆ Y := by tauto
    have h₂ : ∃ M, G.IsMatching M ∧ Y ⊆ V(G, M) := hY
    have h₃ : ∃ M, G.IsMatching M ∧ X ⊆ V(G, M) := hX
    rcases h₂ with ⟨M, hM₁, hM₂⟩
    have h₄ : X ⊆ V(G, M) := by
      exact Set.Subset.trans h₁ hM₂
    exact ⟨M, hM₁, h₄⟩
  indep_maximal := by
    intro X hX
    classical
    -- Use the maximum cardinality matching for X
    have h₁ : ∃ M, G.IsMatching M ∧ X ⊆ V(G, M) := hX
    -- Use the set of all vertices covered by some matching
    let S := {v : α | ∃ M, G.IsMatching M ∧ v ∈ V(G, M)}
    -- Show that S is the entire vertex set
    have h₂ : ∀ (v : α), v ∈ S ↔ v ∈ V(G) := by
      intro v
      constructor
      · -- Prove the forward direction: if v ∈ S, then v ∈ V(G)
        intro hv
        obtain ⟨M, hM, hm⟩ := hv
        have h₃ : v ∈ V(G, M) := hm
