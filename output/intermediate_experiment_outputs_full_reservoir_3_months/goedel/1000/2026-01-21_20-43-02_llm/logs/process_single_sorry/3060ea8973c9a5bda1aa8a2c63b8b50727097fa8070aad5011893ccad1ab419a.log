def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine ⟨∅, ?_, _⟩ <;> simp
    <;> intro e <;> aesop
  
  indep_subset := by
    intro S' S hSS' hS
    obtain ⟨M, hM, hS'⟩ := hS
    refine' ⟨M, hM, _⟩
    have h Including : S ⊆ S' := hSS'
    have hTrans : S ⊆ V(G, M) := hS'.trans Including
    exact hTrans
    <;> aesop
  
  indep_aug := by
    intro X X' hX' hX'_mem hX'_max
    obtain ⟨M, hM, hX'_in⟩ := hX'
    have hX'_in' : X' ⊆ V(G, M) := hX'_in
    have hX_in : X ⊆ V(G, M) := by
      calc
        X ⊆ X' := by aesop
        _ ⊆ V(G, M) := hX'_in'
    have h₁ : X ⊆ V(G) := Set.Subset.trans hX_in (V_subset _ _)
    have h₂ : X' ⊆ V(G) := by
      calc
        X' ⊆ V(G, M) := hX'_in'
        _ ⊆ V(G) := Set.subset_univ.trans (V_subset _ _)
    -- We need to find a vertex v in V(G) \ X' such that X ∪ {v} is matchable.
    have h₃ : ∃ v ∈ V(G) \ X', ∃ M', G.IsMatching M' ∧ (X ∪ {v}) ⊆ V(G, M') := by
      by_contra! h
      -- If no such v exists, then for every v in V(G) \ X', X ∪ {v} is not matchable.
