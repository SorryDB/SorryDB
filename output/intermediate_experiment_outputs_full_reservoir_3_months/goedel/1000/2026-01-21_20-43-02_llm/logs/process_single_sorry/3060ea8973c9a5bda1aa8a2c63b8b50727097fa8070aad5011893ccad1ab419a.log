def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    refine' ⟨∅, _⟩
    simp [Graph.IsMatching]
    <;>
    (try simp_all [Graph.IsMatching])
    <;>
    (try aesop)
  
  indep_subset := by
    intro S₁ S₂ hS₁₂ hS₂
    obtain ⟨M, hM, hS₂V⟩ := hS₂
    have hS₁V : S₁ ⊆ V(G, M) := by
      have h₁ : S₁ ⊆ S₂ := hS₁₂
      exact h₁.trans hS₂V
    exact ⟨M, hM, hS₁V⟩
  
  indep_aug := by
    intro S₁ S₂ hS₁ hS₂ hs₁s₂
    obtain ⟨M₁, hM₁, hV₁⟩ := hS₁
    obtain ⟨M₂, hM₂, hV₂⟩ := hS₂
    have h₁ : Finite.of_fintype (M₁ ∪ M₂ : Set β) := by
      apply Set.Finite.subset (Set.finite_univ) fun x _ => by simp_all [Set.mem_union]
    have h₂ : ∃ M', G.IsMatching M' ∧ S₁ ∈ S₁ ∪ S₂ ∧ S₂ ∈ S₁ ∪ S₂ := by sorry
    sorry
  
  indep_maximal := by
    sorry
