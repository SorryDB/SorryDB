def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    use ∅
    <;> simp [Graph.IsMatching]
    <;>
      tauto
  indep_subset := by
    intro S hS S' hS'
    obtain ⟨M, hM, hSv⟩ := hS
    refine' ⟨M, hM, _⟩
    exact Set.Subset.trans hS' hSv
  indep_aug := by
    intro S hS v
    obtain ⟨M, hM, hSv⟩ := hS
    have hSv' : S ∪ {v} ⊆ V(G, M) ∪ {v} := by
      intro x hx
      simp only [Set.mem_union, Set.mem_singleton_iff] at hx ⊢
      cases hx with
      | inl hx =>
        exact Or.inl (hSv hx)
      | inr hx =>
        simp_all
    have hM' : ∃ M', G.IsMatching M' ∧ S ∪ {v} ⊆ V(G, M') := by
      by_cases hv : v ∈ V(G, M)
      · -- If v is already in V(G, M), we can keep M
        refine' ⟨M, hM, _⟩
        have h : S ∪ {v} ⊆ V(G, M) := by
          intro x hx
          simp only [Set.mem_union, Set.mem_singleton_iff] at hx ⊢
          cases hx with
          | inl hx =>
            exact hSv hx
          | inr hx =>
            simp_all
        exact h
      · -- If v is not in V(G, M), we need to find an augmenting path and adjust M
        sorry
    obtain ⟨M', hM', hSv''⟩ := hM'
    exact ⟨M', hM', hSv''⟩
  indep_maximal := by
    intro X hX
    have h₁ : ∃ (S : Set α), (∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) ∧ (S ⊆ X) ∧ ∀ (S' : Set α), (∃ M, G.IsMatching M ∧ S' ⊆ V(G, M)) → S ⊆ S' → S = S' := by
      classical
      use X
      have h₂ : ∃ M, G.IsMatching M ∧ X ⊆ V(G, M) := by
        sorry
      refine' ⟨by tauto, by tauto, _⟩
      intro S' hS' hSS'
      have h₃ : S' ⊆ X := by
        sorry
      have h₄ : X ⊆ S' := by
        sorry
      exact Set.Subset.antisymm h₃ h₄
    obtain ⟨S, ⟨M, hM, hSv⟩, hSx, hSmax⟩ := h₁
    refine' ⟨S, ⟨M, hM, hSv⟩, _⟩
    intro S' hS'
    have h₂ := hSmax S' hS'
    have h₃ : S ⊆ S' := by
      sorry
    have h₄ : S' ⊆ S := by
      sorry
    exact Set.Subset.antisymm h₃ h₄
