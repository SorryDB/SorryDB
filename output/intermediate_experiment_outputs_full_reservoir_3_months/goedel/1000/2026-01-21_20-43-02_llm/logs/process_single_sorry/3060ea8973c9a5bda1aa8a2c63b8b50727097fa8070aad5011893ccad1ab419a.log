lemma _root_.Matroid.exists_maximal_subset_property (s : Set E) : ∃ t : Set E, s ⊆ t ∧ t ≤ s ⊔ ⊤ ∧ IsIndependent t := by
  have h : ∃ t : Set E, s ⊆ t ∧ t ≤ s ⊔ ⊤ ∧ IsIndependent t := by
    -- Use the fact that the maximum subset property exists in a matroid
    classical
    -- Use the existence of a maximal independent subset
    -- Consider the collection of all independent subsets containing s
    -- This collection is non-empty because s itself is in it
    -- We can then find a maximal element in this collection
    -- The maximal element will be the desired t
    have h₁ : ∃ t : Set E, s ⊆ t ∧ IsIndependent t ∧ ∀ (u : Set E), s ⊆ u → IsIndependent u → u ⊆ t := by
      -- Use the existence of a maximal independent subset
      classical
      -- Use the collection of all independent subsets containing s
      -- We can then find a maximal element in this collection
      -- This maximal element will be the desired t
      have h₂ : ∃ t : Set E, s ⊆ t ∧ IsIndependent t ∧ ∀ (u : Set E), s ⊆ u → IsIndependent u → u ⊆ t := by
        -- Use the existence of a maximal independent subset
        -- Consider the collection of all independent subsets containing s
        -- This collection is non-empty because s itself is in it
        -- We can then find a maximal element in this collection
        -- The maximal element will be the desired t
        use s ⊔ ⊤
        <;>
          (try simp_all [Set.Subset.rfl]) <;>
          (try aesop) <;>
          (try
            {
              intros
              exact Set.Subset.trans (by aesop) (by aesop)
            })
      -- The maximal element will be the desired t
      exact h₂
    -- The maximal element will be the desired t
    obtain ⟨t, ht₁, ht₂, ht₃⟩ := h₁
    refine' ⟨t, ht₁, _, ht₂⟩ <;>
      (try simp_all) <;>
      (try aesop) <;>
      (try
        {
          intros
          exact Set.Subset.trans (by aesop) (by aesop)
        })
  -- The maximal element will be the desired t
  exact h
