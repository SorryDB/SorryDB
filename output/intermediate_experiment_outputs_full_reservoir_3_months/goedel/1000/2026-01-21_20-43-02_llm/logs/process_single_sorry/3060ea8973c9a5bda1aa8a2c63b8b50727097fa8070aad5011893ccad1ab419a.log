class Adjoin (K : Type*) [AddCommGroup K] (β : Type*) where
  adjoin : (s : Set β) → (A : AddSubgroup K) → AddSubgroup K
  map : {s : Set β} (A : AddSubgroup K) (B : AddSubgroup K) → A ≤ B → s.adjoin A ≤ s.adjoin B
  ⨃ : {s : Set β} {ι : Type*} (A : ι → AddSubgroup K) → (⨆ i, A i).adjoin s = ⨆ i, (A i).adjoin s
  ⨆ : {s : Set β} {ι : Type*} [Preorder ι] (A : ι → AddSubgroup K) → (⨆ i, A i).adjoin s = ⨆ i, (A i).adjoin s

