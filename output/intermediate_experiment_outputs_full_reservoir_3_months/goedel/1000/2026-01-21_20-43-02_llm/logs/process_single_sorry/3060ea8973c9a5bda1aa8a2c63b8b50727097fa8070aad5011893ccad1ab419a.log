instance : Adjoin {γ : Type*} [AddCommGroup γ] (β : Type*) where
  adjoin : (s : Set β) → (A : AddSubgroup γ) → AddSubgroup γ :=
    fun s A => closure (A ↑∪ LinearMap.range ↑(UnitAddSubgroup.to _.1) ↑+ s.mapMap
      (φ : β →+ (Equiv.ofBijective (fun x : β ↦ (1 : α) * x) (by
        constructor
        · intro x y h
          simp_all [one_smul]
          <;> simp_all [Equiv.funext_iff]
          <;> aesop
        · intro y
          use y
          <;> simp [one_smul]
          <;> aesop) ).symm).range))
  map s A := by
    apply closure_le.mpr
    simp [LinearMap.range_le, closure_induction]
    <;> aesop
  ⨃ A := by
    apply closure_add_subgroup_mono
    <;> simp [set_sUnion_subset_iff]
    <;> aesop
  ⨆ A := by
