theorem toSL_injective {a : Type} : Function.Injective (toSL : List a → SymList a) := by
  intro l₁ l₂ h
  have h' : toSL l₁ = toSL l₂ := h
  cases h' with
  | mk h₁ h₂ =>
    have h₃ : toSL l₁ = toSL l₂ := h'
    have h₄ : l₁ = l₂ := by
      have h₅ := congr_arg (fun s => s.lhs) h₃
      simp [toSL] at h₅
      <;> cases l₁ <;> cases l₂ <;> simp_all [List.cons, List.nil]
      <;> simp_all [SymList.mk.injEq]
      <;> try contradiction
      <;> try aesop
    exact h₄

theorem fromSL_eq_nil_iff {a : Type} {l : SymList a} : fromSL l = [] ↔ l = nil := by
  constructor
  · intro h
    have h₁ : fromSL l = [] := h
    have h₂ : l = nil := by
      cases l with
      | mk lhs rhs h₂ =>
        have h₃ : lhs ++ rhs.reverse = [] := by
          simp [fromSL] at h₁ ⊢
          <;> simp_all
        have h₄ : lhs = [] := by
          have h₅ : lhs ++ rhs.reverse = [] := h₃
          have h₆ : lhs = [] := by
            by_contra h₆
            have h₇ : lhs ≠ [] := h₆
            have h₈ : lhs ++ rhs.reverse ≠ [] := by
              have h₉ : lhs ≠ [] := h₇
              have h₁₀ : lhs ++ rhs.reverse ≠ [] := by
                intro h₁₀
                simp [List.append_eq_nil] at h₁₀
                <;> simp_all
              exact h₁₀
            simp_all
          exact h₆
        have h₅ : rhs = [] := by
          have h₆ : lhs ++ rhs.reverse = [] := h₃
          have h₇ : lhs = [] := h₄
          simp [h₇] at h₆
          have h₈ : rhs.reverse = [] := by simp_all
          have h₉ : rhs = [] := by
            have h₁₀ : rhs.reverse = [] := h₈
            have h₁₁ : rhs = [] := by
              simp [List.reverse_eq_nil] at h₁₀ ⊢
              <;> simp_all
            exact h₁₁
          exact h₉
        simp [h₄, h₅]
