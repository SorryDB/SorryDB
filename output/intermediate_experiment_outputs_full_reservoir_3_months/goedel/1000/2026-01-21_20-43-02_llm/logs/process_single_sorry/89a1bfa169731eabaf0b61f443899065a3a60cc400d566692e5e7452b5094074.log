theorem nat_univ_eq_zero_iff {m n : ℕ} : (∀ a : ℕ, m * a + n = 0) ↔ m = 0 ∧ n = 0 := by
  constructor
  · -- Prove the forward direction: (∀ a : ℕ, m * a + n = 0) → m = 0 ∧ n = 0
    intro h
