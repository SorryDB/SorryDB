      have h₆ : m = 0 := by
        have h₇ : n = 0 := h₁
        have h₈ : m + n = 0 := h₅
        have h₉ : m = 0 := by
          simp [h₇] at h₈
          <;> omega
        exact h₉
      exact h₆
    
