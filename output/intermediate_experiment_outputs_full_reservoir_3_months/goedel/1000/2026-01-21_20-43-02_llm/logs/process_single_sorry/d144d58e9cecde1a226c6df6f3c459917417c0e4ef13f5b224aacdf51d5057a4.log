theorem max_count_sub_t_count_inequality (n : ℕ) (p : ℕ → ℕ) : ∑ k in Finset.Icc 1 n, (p k : ℕ) ≥ ∑ k in Finset.Icc 1 n, (p (n + 1 - k) : ℕ) := by
  have h_main : ∑ k in Finset.Icc 1 n, (p k : ℕ) ≥ ∑ k in Finset.Icc 1 n, (p (n + 1 - k) : ℕ) := by
    -- The rewrite step is not generally valid unless we can prove that n + 1 - k is in the same range as k.
    -- However, we can use the fact that the sum is symmetric under the transformation k ↦ n + 1 - k.
    -- This is because the transformation is an involution on the set {1, ..., n}.
    have h₁ : ∑ k in Finset.Icc 1 n, (p (n + 1 - k) : ℕ) = ∑ k in Finset.Icc 1 n, (p k : ℕ) := by
      -- We need to show that the sum remains the same under the transformation.
      -- We can achieve this by reindexing the sum.
      have h₂ : ∑ k in Finset.Icc 1 n, (p (n + 1 - k) : ℕ) = ∑ k in Finset.Icc 1 n, (p k : ℕ) := by
        -- Use the symmetry of the sum to show that the sums are equal.
        apply Finset.sum_bij' (fun (a : ℕ) _ => n + 1 - a) (fun (a : ℕ) _ => n + 1 - a)
        <;> simp_all [Finset.mem_Icc, Nat.le_of_lt_succ, Nat.succ_le_iff]
        <;> (try omega)
        <;> (try
          {
            intros;
            omega
          })
        <;> (try
          {
            intros;
            ring_nf at * <;>
            omega
          })
      -- The sums are equal.
      exact h₂
    -- Since the sums are equal, we can directly conclude the inequality.
    linarith
  
  exact h_main
