theorem IsBinomialRandom.inf (hG : IsBinomialRandom G p P) (hY : IsBinomialRandom H q P) :
    IsBinomialRandom (fun ω ↦ G ω ⊓ H ω) (p * q) P where
  map_eq := by sorry
  aemeasurable := by
    have h₁ : AEMeasurable (fun ω => G ω ⊓ H ω) P := by
      -- Use the fact that the intersection of graphs is measurable if their adjacency matrices are measurable
      -- and the graph structure is built from measurable functions.
      have h₂ : ∀ (e : Sym2 V), AEMeasurable (fun ω => e ∈ (G ω ⊓ H ω).edgeSet) P := by
        intro e
        have h₃ : AEMeasurable (fun ω => e ∈ (G ω).edgeSet) P := by
          -- Since G is binomial, the membership in the edge set is measurable
          exact hG.ae_mem_edgeSet e
        have h₄ : AEMeasurable (fun ω => e ∈ (H ω).edgeSet) P := by
          -- Since H is binomial, the membership in the edge set is measurable
          exact hY.ae_mem_edgeSet e
        have h₅ : AEMeasurable (fun ω => e ∈ (G ω).edgeSet ∧ e ∈ (H ω).edgeSet) P :=
          AEMeasurable.inter h₃ h₄
        have h₆ : e ∈ (G ⊓ H ω)(G ω ⊓ H ω).edgeSet = e ∈ (G ω).edgeSet ∧ e ∈ (H ω).edgeSet := by
          simp [Graph.mem_inf]
          <;> aesop
        -- Use the fact that the intersection of measurable sets is measurable
        simpa [h₆] using h₅
      -- Use the fact that the edge set is measurable to show the graph is measurable
      have h₇ : AEMeasurable (fun ω => G ω ⊓ H ω) P := by
        have h₈ : AEMeasurable (fun ω => EdgeSet (G ω ⊓ H ω)) P := by
          have h₉ : ∀ (e : Sym2 V), AEMeasurable (fun ω => e ∈ EdgeSet (G ω ⊓ H ω)) P := by
            intro e
            exact h₂ e
          -- Use the fact that the union of measurable sets is measurable
          apply Measurable.measurableOn.measurableAE
          apply AEMeasurable.forallApply (by infer_instance) (by infer_instance)
          <;> simp_all [h₂]
          <;> aesop
        -- Use the fact that the edge set is measurable to show the graph is measurable
        simpa [EdgeSet] using h₈
      exact h₇
    exact h₁
