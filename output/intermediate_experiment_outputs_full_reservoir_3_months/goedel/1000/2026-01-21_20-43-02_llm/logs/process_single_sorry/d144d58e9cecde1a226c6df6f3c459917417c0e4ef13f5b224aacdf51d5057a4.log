lemma IsBinomialRandom.inf (hG : IsBinomialRandom G p P) (hY : IsBinomialRandom H q P) :
    IsBinomialRandom (fun ω ↦ G ω ⊓ H ω) (p * q) P where
  map_eq := sorry
  aemeasurable := by
    have hG' : Measurable G := by
      obtain ⟨μ, hμ⟩ := hG
      exact hμ.measurable
    have hH' : Measurable H := by
      obtain ⟨μ, hμ⟩ := hY
      exact hμ.measurable
    have hG'' : Measurable (fun ω : Ω => G ω ⊓ H ω) := by
      refine' measurable_iff_adj.2 fun u v => _
      -- Show that (G ω ⊓ H ω).adj u v is measurable
      have h1 : Measurable fun ω : Ω => (G ω).adj u v := hG'.measurable_adj u v
      have h2 : Measurable fun ω : Ω => (H ω).adj u v := hH'.measurable_adj u v
      have h3 : Measurable fun ω : Ω => (G ω).adj u v ∧ (H ω).adj u v := by
        apply Measurable.and h1 h2
      convert h3 using 1
      ext ω
      simp [SimpleGraph.mem_inf, SimpleGraph.adj_inf]
      <;> aesop
    have h_ae : AEMeasurable (fun ω : Ω => G ω ⊓ H ω) P := by
      exact hG''.aemeasurable
    exact h_ae
```

