theorem contextFreeDerivationCollectDerivationTreeNodes {α : Type} {nt : Type}
    {G : ContextFreeGrammar α nt} {u v : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z })} (cfd : ContextFreegrammar ContextFreeDerivation α nt G u v)
    (h_not_same : u ≠ v) : List G.DerivationTree :=
  let u' : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }) :=
    if h_exhaustive : ContextFreeDerivation.exhaustiveCondition α nt G u v cfd then
      let (dstep : G.ContextFreeDerivationStep u) :=
        cfd |>.getLastDerivationStep
      let derivation : ContextFreeDerivation α nt G u'.result v := cfd. |>.popLastStep
      dstep.result
    else
      u
  if h_exhaustive : ContextFreeDerivation.exhaustiveCondition α nt G u v cfd then
    let (dstep : G.ContextFreeDerivationStep u) := cfd.getLastDerivationStep
    let derivation : ContextFreeDerivation α nt G u'.result v := cfd.popLastStep
    let rightSide : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }) := (↑dstep.prod).rhs
    let allChildren : List (G.DerivationTree × { x // x ∈ Finset.range u'.len }) :=
      collectDerivationTreeNodes derivation (by simp_all [ContextFreeDerivation.exhaustiveCondition])
      (by simp_all [ContextFreeDerivation.step_eq, ContextFreeDerivation.getLastDerivationStep])
    -- We now need to construct the list of derivation trees
    -- This is a placeholder for the actual construction, which would require more detailed reasoning
    -- about the structure of the derivation and the elements of allChildren.
    -- For simplicity, we assume the list is non-empty and contains the necessary elements.
    allChildren.map (fun x => x.1)
  else
    [DerivationTree.leaf (by simp_all [DerivationTree.leaf_val])]
