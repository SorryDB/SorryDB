    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨r, hr⟩ := r
      have h₁ : valuation L (algebraMap K L r) ≤ 0 := by
        have h₂ : valuation L (algebraMap K L r) ≤ 0 := by
          have h₃ : valuation K r ≤ 0 := by
            have h₄ : valuation K r ≤ 0 := by
              -- Use the property that the valuation of an element in the valuation ring is non-positive
              rw [Valuation.mem_integer_iff] at hr
              have h₅ : 0 ≤ valuation K r := by
                -- The valuation is always non-negative
