-- is equal to the scalar square root multiplied by the square root of the original matrix
theorem traceNorm_smul (A : Matrix m n R) (c : R) : (c • A).traceNorm = ‖c‖ * A.traceNorm := by
  have h : (c • A)ᴴ * (c • A) = (‖c‖^2:R) • (Aᴴ * A) := by
    rw [conjTranspose_smul, RCLike.star_def, mul_smul, smul_mul, smul_smul]
    rw [RCLike.mul_conj c]
  rw [traceNorm, h]
  open MatrixOrder in
  have : RCLike.re (trace (‖c‖ • CFC.sqrt (Aᴴ * A))) = ‖c‖ * traceNorm A := by
    simp [RCLike.smul_re]
    apply Or.inl
    rfl
  convert this using 3
  rw [RCLike.real_smul_eq_coe_smul (K := R) ‖c‖]
  by_cases h : c = 0
  · subst c
    simp
  · -- Prove that the square root of a scalar multiplication of a positive semidefinite matrix
    -- is equal to the scalar square root multiplied by the square root of the original matrix
    have h₁ : CFC.sqrt (‖c‖ ^ 2 • (Aᴴ * A)) = ‖c‖ • CFC.sqrt (Aᴴ * A) := by
      rw [show (‖c‖ ^ 2 : R) • (Aᴴ * A) = (‖c‖ : R) * ‖c‖ • (Aᴴ * A) by
        {
          simp [pow_two, smul_smul]
          <;>
          ring_nf <;>
          simp [RCLike.nonneg_iff]
          <;>
          norm_num
        }
      ]
      -- Use the property of square roots of scalar multiples
      have h₂ : CFC.sqrt ((‖c‖ : R) * ‖c‖ • (Aᴴ * A)) = (‖c‖ : R) • CFC.sqrt (Aᴴ * A) := by
        -- Use the property of square roots of positive semidefinite matrices
        rw [CFC.sqrt_eq_iff_sq_eq (by positivity) (by positivity)]
        calc
          ((‖c‖ : R) • CFC.sqrt (Aᴴ * A)) ^ 2 = (‖c‖ : R) ^ 2 • (CFC.sqrt (Aᴴ * A)) ^ 2 := by
            {
              simp [pow_two, Matrix.mul_smul, Matrix.smul_mul, smul_smul]
              <;>
              ring_nf <;>
              simp [RCLike.nonneg_iff]
              <;>
              norm_num
