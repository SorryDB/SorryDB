      have h₁ : valuation L (algebraMap K L r.1) ≤ 1 := by
        have h₂ : valuation K (r.1 : K) ≤ 1 := by
          -- Since r is in the integer ring of K, its valuation is ≤ 1
          have h₃ : (r.1 : K) ∈ (valuation K).integer := r.2
          rw [Valuation.mem_integer_iff] at h₃
          exact h₃
        -- The valuation is compatible with the algebra map
        have h₃ : valuation L (algebraMap K L r.1) ≤ valuation K (r.1 : K) := by
