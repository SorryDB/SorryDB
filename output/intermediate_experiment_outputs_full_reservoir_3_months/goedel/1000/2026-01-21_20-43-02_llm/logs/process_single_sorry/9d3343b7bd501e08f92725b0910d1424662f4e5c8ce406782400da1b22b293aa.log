instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨r, hr⟩ := r
      have h : (algebraMap K L) r ∈ (valuation L).integer := by
        have h₁ : (valuation L) (algebraMap K L r) ≤ 0 := by
          have h₂ : (valuation K) r ≤ 0 := by
            simpa [Valuation.mem_integer] using hr
          have h₃ : (valuation K) r ≤ 0 := by simpa [Valuation.mem_integer] using hr
          -- Use the fact that the valuation on L is compatible with that on K to show the inequality
          have h₄ : (valuation L) (algebraMap K L r) ≤ (valuation L) (1 : L) := by
            apply ValuativeExtension.levaluation L K r
          have h₅ : (valuation L) (1 : L) = 0 := by
            simp [Valuation.map_one]
          have h₆ : (valuation L) (algebraMap K L r) ≤ 0 := by
            calc
              (valuation L) (algebraMap K L r) ≤ (valuation L) (1 : L) := h₄
              _ = 0 := h₅
          exact h₆
        -- Use the fact that the valuation is ≤ 0 to show it is in the integer ring
        simp_all [Valuation.mem_integer]
        <;>
        (try norm_num) <;>
        (try linarith) <;>
        (try simp_all [Valuation.le_zero_iff]) <;>
        (try omega)
      exact h⟩
  }
