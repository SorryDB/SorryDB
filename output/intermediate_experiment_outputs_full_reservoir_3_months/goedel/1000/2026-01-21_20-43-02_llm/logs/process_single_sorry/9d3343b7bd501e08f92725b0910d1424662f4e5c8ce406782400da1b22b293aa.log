theorem algebraMap_integer_mem_integer {K L : Type*} [CommRing K] [ValuativeRel K]
    [CommRing L] [ValuativeRel L] [Algebra K L] [ValuativeExtension K L] (r : ↥(valuation K).integer) :
    (algebraMap K L) (r : K) ∈ (valuation L).integer := by
  -- Extract the property of r being in the integer set of valuation K
  have h : (valuation K) (r : K) ≤ 0 := by exact r.2
  -- Use the fact that the valuation is compatible with the algebra map to show the same for L
  have h' : (valuation L) ((algebraMap K L) (r : K)) ≤ 0 := by
    -- Apply the compatible property of valuations with the algebra map
    have h₁ : (valuation L) ((algebraMap K L) (r : K)) = (valuation K) (r : K) := by
      rw [← ValuativeExtension.valuation_comp]
      <;> simp [Algebra.toFun_eq]
    rw [h₁]
    -- Since (valuation K) (r : K) ≤ 0, we have (valuation L) ((algebraMap K L) (r : K)) ≤ 0
    <;> exact h
  -- Conclude that (algebraMap K L) (r : K) is in the integer set of valuation L
  exact h'
