            have h₆ : v (e y) = v y := by
              -- Use the fact that e is a ring isomorphism and preserves the valuation
              have h₇ : v (e y) = v y := by
                -- Use the property of the valuation and the ring isomorphism e
                simp_all [RingHom.id]
