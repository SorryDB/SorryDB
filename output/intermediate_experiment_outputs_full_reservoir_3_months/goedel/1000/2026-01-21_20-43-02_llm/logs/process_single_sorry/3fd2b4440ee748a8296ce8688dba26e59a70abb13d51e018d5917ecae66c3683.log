      "by\n  intro X1 X2 h\n  have h₁ : val_image A X1 = val_image A X2 := h\n  have h₂ : X1 ⊆ X2 := by\n    intro x hx\n    have h₃ : ∃ (y : (A : Type)) (hy : y ∈ X1), (y : U) = (x : U) := by\n      refine' ⟨⟨x, by simp_all [Set.subset_def]⟩, _, rfl⟩\n      -- We need to show that ⟨x, _⟩ ∈ X1, but we already have x ∈ X1 from hx.\n      simp_all [Set.subset_def]\n    -- Now, we need to show that x ∈ X2.\n    -- We know that val_image A X1 = val_image A X2.\n    -- So, we can use the fact that x.val (which is x itself) is in val_image A X1.\n    have h₄ : (x : U) ∈ val_image A X1 := by\n      obtain ⟨y, hy, hy'⟩ := h₃\n      -- We need to find y ∈ X1 such that y.val = x.\n      -- Here, y = ⟨x, _⟩, and y.val = x.\n      refine' ⟨y, hy, _⟩\n      simp_all [Set.subset_def]\n    -- Since val_image A X1 = val_image A X2, we have x ∈ val_image A X2.\n    have h₅ : (x : U) ∈ val_image A X2 := by\n      rw [h₁] at h₄\n      exact h₄\n    -- Now, we need to show that x ∈ X2.\n    -- This follows directly from the definition of val_image.\n    obtain ⟨y, hy, hy'⟩ := h₅\n    -- We have y ∈ X2 and y.val = x.\n    -- Since y : A, y.val is the underlying element of A.\n    -- So, y.val = x means that x is the underlying element of y.\n    -- But y ∈ X2, and X2 is a subset of A.\n    -- So, x must be in X2.\n    have h₆ : (y : U) = (x : U) := by simp_all [Set.subset_def]\n    have h₇ : x ∈ X2 := by\n      -- Since y ∈ X2 and y.val = x, we need to show that x ∈ X2.\n      -- But y.val = x means that x is the same as y, so x ∈ X2.\n      have h₈ : y ∈ X2 := hy\n      have h₉ : (y : U) = (x : U) := by simp_all [Set.subset_def]\n      have h₁₀ : x ∈ (X2 : Set (A : Type)) := by\n        -- We need to show that x is in X2.\n        -- Since y ∈ X2 and y.val = x, we can use the fact that y is in X2 to show that x is in X2.\n        -- But we need to be careful because X2 is a subset of A.\n        -- However, x is already in A because y is in A and y.val = x.\n        -- So, we can directly use the fact that y ∈ X2 to show that x ∈ X2.\n        -- This is because the coercion from A to U is injective.\n        -- So, if y.val = x, then y = x in A.\n        -- Therefore, x ∈ X2.\n        have h₁₁ : (y : U) = (x : U) := by simp_all [Set.subset_def]\n        have h₁₂ : y ∈ (X2 : Set (A : Type)) := h₈\n        -- Now, we need to show that x ∈ X2.\n        -- Since y ∈ X2 and y.val = x, we can use the fact that y is in X2 to show that x is in X2.\n        -- But we need to be careful because X2 is a subset of A.\n        -- However, x is already in A because y is in A and y.val = x.\n        -- So, we can directly use the fact that y ∈ X2 to show that x ∈ X2.\n        -- This is because the coercion from A to U is injective.\n        -- So, if y.val = x, then y = x in A.\n        -- Therefore, x ∈ X2.\n        simp_all [Set.subset_def]\n        <;>\n        (try simp_all [Subtype.ext_iff])\n        <;>\n        (try aesop)\n        <;>\n        (try\n          {\n            aesop\n          })\n        <;>\n        (try\n          {\n            simp_all [Subtype.ext_iff]\n            <;>\n            aesop\n          })\n      -- Now, we have x ∈ X2.\n      -- So, we can directly use this fact to conclude the proof.\n      simp_all [Set.subset_def]\n      <;>\n      aesop\n    -- Now, we have x ∈ X2.\n    -- So, we can directly use this fact to conclude the proof.\n    exact h₇\n  have h₃ : X2 ⊆ X1 := by\n    intro x hx\n    have h₄ : ∃ (y : (A : Type)) (hy : y ∈ X2), (y : U) = (x : U) := by\n      refine' ⟨⟨x, by simp_all [Set.subset_def]⟩, _, rfl⟩\n      -- We need to show that ⟨x, _⟩ ∈ X2, but we already have x ∈ X2 from hx.\n      simp_all [Set.subset_def]\n    -- Now, we need to show that x ∈ X1.\n    -- We know that val_image A X1 = val_image A X2.\n    -- So, we can use the fact that x.val (which is x itself) is in val_image A X2.\n    have h₅ : (x : U) ∈ val_image A X2 := by\n      obtain ⟨y, hy, hy'⟩ := h₄\n      -- We need to find y ∈ X2 such that y.val = x.\n      -- Here, y = ⟨x, _⟩, and y.val = x.\n      refine' ⟨y, hy, _⟩\n      simp_all [Set.subset_def]\n    -- Since val_image A X1 = val_image A X2, we have x ∈ val_image A X1.\n    have h₆ : (x : U) ∈ val_image A X1 := by\n      rw [h₁] at *\n      exact h₅\n    -- Now, we need to show that x ∈ X1.\n    -- This follows directly from the definition of val_image.\n    obtain ⟨y, hy, hy'⟩ := h₆\n    -- We have y ∈ X1 and y.val = x.\n    -- Since y : A, y.val is the underlying element of A.\n    -- So, y.val = x means that x is the underlying element of y.\n    -- But y ∈ X1, and X1 is a subset of A.\n    -- So, x must be in X1.\n    have h₇ : (y : U) = (x : U) := by simp_all [Set.subset_def]\n    have h₈ : x ∈ X1 := by\n      -- Since y ∈ X1 and y.val = x, we need to show that x ∈ X1.\n      -- But y.val = x means that x is the same as y, so x ∈ X1.\n      have h₉ : y ∈ X1 := hy\n      have h₁₀ : (y : U) = (x : U) := by simp_all [Set.subset_def]\n      have h₁₁ : x ∈ (X1 : Set (A : Type)) := by\n        -- We need to show that x is in X1.\n        -- Since y ∈ X1 and y.val = x, we can use the fact that y is in X1 to show that x is in X1.\n        -- But we need to be careful because X1 is a subset of A.\n        -- However, x is already in A because y is in A and y.val = x.\n        -- So, we can directly use the fact that y ∈ X1 to show that x ∈ X1.\n        -- This is because the coercion from A to U is injective.\n        -- So, if y.val = x, then y = x in A.\n        -- Therefore, x ∈ X1.\n        have h₁₂ : (y : U) = (x : U) := by simp_all [Set.subset_def]\n        have h₁₃ : y ∈ (X1 : Set (A : Type)) := h₉\n        -- Now, we need to show that x ∈ X1.\n        -- Since y ∈ X1 and y.val = x, we can use the fact that y is in X1 to show that x is in X1.\n        -- But we need to be careful because X1 is a subset of A.\n        -- However, x is already in A because y is in A and y.val = x.\n        -- So, we can directly use the fact that y ∈ X1 t