      cases y
      <;> simp_all [Set.mem_setOf_eq]
      <;> aesop
    -- Therefore, x ∈ X
    rw [h₅]
    exact hy₁
  -- Since X ⊆ Y and Y ⊆ X, we have X = Y
  exact Set.Subset.antisymm h₂ h₃
