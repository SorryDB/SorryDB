def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image U A) := by
  dsimp
  intro X1 X2 h
  have h₁ : {y : U | ∃ x ∈ X1, x.val = y} = {y : U | ∃ x ∈ X2, x.val = y} := h
  have h₂ : ∀ y : U, (∃ x ∈ X1, x.val = y) ↔ (∃ x ∈ X2, x.val = y) := by
    intro y
    simp only [Set.mem_setOf_eq] at h₁ ⊢
    exact Iff.intro (fun h₃ => by
      have h₄ : y ∈ {y : U | ∃ x ∈ X1, x.val = y} := h₃
      have h₅ : y ∈ {y : U | ∃ x ∈ X2, x.val = y} := by
        rw [h₁] at h₄
        exact h₄
      exact h₅) (fun h₃ => by
      have h₄ : y ∈ {y : U | ∃ x ∈ X2, x.val = y} := h₃
      have h₅ : y ∈ {y : U | ∃ x ∈ X1, x.val = y} := by
        rw [h₁] at *
        exact h₄
      exact h₅)
  -- We need to show that if the images are equal, then the sets X1 and X2 are equal.
  -- This is done by showing that each set is a subset of the other.
  have h₃ : X1 ⊆ X2 := by
    intro x hx
    have h₄ : (x : U) ∈ {y : U | ∃ x ∈ X1, x.val = y} := by
      refine' ⟨x, hx, _⟩
      <;> simp [A]
    have h₅ : (x : U) ∈ {y : U | ∃ x ∈ X2, x.val = y} := by
      have h₆ := h₂ (x : U)
      have h₇ : (∃ x ∈ X1, x.val = (x : U)) := ⟨x, hx, rfl⟩
      have h₈ : (∃ x ∈ X2, x.val = (x : U)) := by
        simp_all [Set.mem_setOf_eq]
      exact by
        simp_all [Set.mem_setOf_eq]
      <;> aesop
    -- Extract the element from X2 whose value is (x : U)
    rcases h₅ with ⟨x', hx', hx'_eq⟩
    -- Since x' is in X2 and x' = x, we have x ∈ X2
    have h₉ : (x' : U) = (x : U) := by simp_all [A]
    have h₁₀ : x' = x := by
      have h₁₁ : (x' : U) = (x : U) := by simp_all [A]
      have h₁₂ : x' = x := by
        apply Subtype.ext
        <;> simp_all [A]
        <;> aesop
      exact h₁₂
    -- Since x' = x and x' ∈ X2, we have x ∈ X2
    rw [h₁₀] at hx'
    exact hx'
  have h₄ : X2 ⊆ X1 := by
    intro x hx
    have h₅ : (x : U) ∈ {y : U | ∃ x ∈ X2, x.val = y} := by
      refine' ⟨x, hx, _⟩
      <;> simp [A]
    have h₆ : (x : U) ∈ {y : U | ∃ x ∈ X1, x.val = y} := by
      have h₇ := h₂ (x : U)
      have h₈ : (∃ x ∈ X2, x.val = (x : U)) := ⟨x, hx, rfl⟩
      have h₉ : (∃ x ∈ X1, x.val = (x : U)) := by
        simp_all [Set.mem_setOf_eq]
      exact by
        simp_all [Set.mem_setOf_eq]
      <;> aesop
    -- Extract the element from X1 whose value is (x : U)
    rcases h₆ with ⟨x', hx', hx'_eq⟩
    -- Since x' is in X1 and x' = x, we have x ∈ X1
    have h₁₀ : (x' : U) = (x : U) := by simp_all [A]
    have h₁₁ : x' = x := by
      have h₁₂ : (x' : U) = (x : U) := by simp_all [A]
      have h₁₃ : x' = x := by
        apply Subtype.ext
        <;> simp_all [A]
        <;> aesop
      exact h₁₃
    -- Since x' = x and x' ∈ X1, we have x ∈ X1
    rw [h₁₁] at hx'
    exact hx'
  -- Since X1 ⊆ X2 and X2 ⊆ X1, we have X1 = X2
  exact Set.Subset.antisymm h₃ h₄
