lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X Y h
  have h₁ : val_image A X = val_image A Y := h
  have h₂ : X ⊆ Y := by
    intro x hx
    have hx' : x.val ∈ val_image A X := by
      refine' ⟨x, hx, _⟩
      <;> simp
    have hx'' : x.val ∈ val_image A Y := by
      rw [h₁] at hx'
      exact hx'
    -- We need to find y : A such that y ∈ Y and y.val = x.val
    obtain ⟨y, hy₁, hy₂⟩ := hx''
    -- Since x and y are in A and x.val = y.val, we can use the fact that A is a set of U to find the required y
    have h₃ : x.val = y.val := by simpa using hy₂
    -- We need to show that x ∈ Y
    -- Since A is a set of U, we can use the fact that x and y have the same value to conclude x ∈ Y
    have h₄ : x = y := by
      -- Since x and y are in A and x.val = y.val, and A is a subset of U, we can conclude x = y
      -- (This is not necessarily true in general, but since we're working with Set A, it is.)
      cases x
      cases y
      <;> simp_all [Set.mem_setOf_eq]
      <;> aesop
    -- Therefore, x ∈ Y
    rw [h₄]
    exact hy₁
  have h₃ : Y ⊆ X := by
    intro x hx
    have hx' : x.val ∈ val_image A Y := by
      refine' ⟨x, hx, _⟩
      <;> simp
    have hx'' : x.val ∈ val_image A X := by
      rw [h₁] at *
      exact hx'
    -- We need to find y : A such that y ∈ X and y.val = x.val
