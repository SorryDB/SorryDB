lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X1 X2 h
  have h₁ : val_image A X1 = val_image A X2 := h
  have h₂ : X1 ⊆ X2 := subset_of_val_image_eq A h₁
  have h₃ : X2 ⊆ X1 := subset_of_val_image_eq A (by
    rw [val_image, val_image] at h₁ ⊢
    -- Use the fact that the sets are equal to show the reverse inclusion
    rw [Set.ext_iff] at h₁ ⊢
    intro y
    have h₄ := h₁ y
    simp only [Set.mem_setOf_eq] at h₄ ⊢
    tauto)  
  exact Set.Subset.antisymm h₂ h₃
