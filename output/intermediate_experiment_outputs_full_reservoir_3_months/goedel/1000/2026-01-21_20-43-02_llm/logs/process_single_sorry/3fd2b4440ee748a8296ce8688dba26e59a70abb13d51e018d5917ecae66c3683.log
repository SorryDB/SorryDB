      "by\n  intro X1 X2 h\n  have h₁ : val_image A X1 = val_image A X2 := h\n  have h₂ : X1 ⊆ X2 := by\n    intro x hx\n    have h₃ : x.val ∈ val_image A X1 := by\n      exact ⟨x, hx, rfl⟩\n    have h₄ : x.val ∈ val_image A X2 := by\n      rw [h₁] at h₃\n      exact h₃\n    have h₅ : ∃ (y : A), y ∈ X2 ∧ y.val = x.val := h₄\n    obtain ⟨y, hy, hy'⟩ := h₅\n    have h₆ : (y : U) = x.val := by\n      simp_all [Subtype.ext_iff]\n    have h₇ : (x : U) = x.val := by simp\n    have h₈ : (y : U) = (x : U) := by simp_all\n    have h₉ : y = x := by\n      apply Subtype.ext\n      <;> simp_all [Subtype.ext_iff]\n    have h₁₀ : x ∈ X2 := by\n      rw [h₉] at hy\n      exact hy\n    exact h₁₀\n  have h₃ : X2 ⊆ X1 := by\n    intro x hx\n    have h₄ : x.val ∈ val_image A X2 := by\n      exact ⟨x, hx, rfl⟩\n    have h₅ : x.val ∈ val_image A X1 := by\n      rw [h₁] at h₄\n      exact h₄\n    have h₆ : ∃ (y : A), y ∈ X1 ∧ y.val = x.val := h₅\n    obtain ⟨y, hy, hy'⟩ := h₆\n    have h₇ : (y : U) = x.val := by\n      simp_all [Subtype.ext_iff]\n    have h₈ : (x : U) = x.val := by simp\n    have h₉ : (y : U) = (x : U) := by simp_all\n    have h₁₀ : y = x := by\n      apply Subtype.ext\n      <;> simp_all [Subtype.ext_iff]\n    have h₁₁ : x ∈ X1 := by\n      rw [h₁₀] at hy\n      exact hy\n    exact h₁₁\n  exact Set.Subset.antisymm h₂ h₃",
      "by\n  intro X Y h\n  have h₁ : val_image A X = val_image A Y := h\n  have h₂ : X ⊆ Y := by\n    intro x hx\n    have h₃ : x.val ∈ val_image A X := by\n      refine' ⟨x, hx, _⟩\n      <;> simp\n    have h₄ : x.val ∈ val_image A Y := by\n      rw [h₁] at h₃\n      exact h₃\n    have h₅ : ∃ (y : A), y ∈ Y ∧ y.val = x.val := by\n      exact h₄\n    obtain ⟨y, hy, hy'⟩ := h₅\n    have h₆ : y.val = x.val := hy'\n    have h₇ : y ∈ Y := hy\n    have h₈ : x = y := by\n      congr\n      <;> simp_all (config := { contextual := true })\n      <;> aesop\n    rw [h₈] at hx\n    exact hy\n  have h₃ : Y ⊆ X := by\n    intro x hx\n    have h₄ : x.val ∈ val_image A Y := by\n      refine' ⟨x, hx, _⟩\n      <;> simp\n    have h₅ : x.val ∈ val_image A X := by\n      rw [h₁] at h₄\n      exact h₄\n    have h₆ : ∃ (y : A), y ∈ X ∧ y.val = x.val := by\n      exact h₅\n    obtain ⟨y, hy, hy'⟩ := h₆\n    have h₇ : y.val = x.val := hy'\n    have h₈ : y ∈ X := hy\n    have h₉ : x = y := by\n      congr\n      <;> simp_all (config := { contextual := true })\n      <;> aesop\n    rw [h₉] at hx\n    exact hy\n  have h₄ : X = Y := by\n    apply Set.Subset.antisymm h₂ h₃\n  exact h₄",
      "by\n  intro X Y h\n  have h' : val_image A X = val_image A Y := h\n  have h₁ : X ⊆ Y := by\n    intro x hx\n    have : (x : U) ∈ val_image A X := by\n      refine' ⟨x, hx, rfl⟩\n    have : (x : U) ∈ val_image A Y := by\n      rw [h'] at this\n      exact this\n    obtain ⟨y, hy, hy'⟩ := this\n    have : x = y := by\n      have h₂ : (x : U) = (y : U) := by\n        simpa [hy'] using hy'\n      exact Subtype.ext h₂\n    have : y ∈ Y := hy\n    exact by\n      simpa [this] using this\n  have h₂ : Y ⊆ X := by\n    intro y hy\n    have : (y : U) ∈ val_image A Y := by\n      refine' ⟨y, hy, rfl⟩\n    have : (y : U) ∈ val_image A X := by\n      rw [h'] at *\n      exact this\n    obtain ⟨x, hx, hx'⟩ := this\n    have : y = x := by\n      have h₃ : (y : U) = (x : U) := by\n        simpa [hx'] using hx'\n      exact Subtype.ext h₃\n    have : x ∈ X := hx\n    exact by\n      simpa [this] using this\n  exact Set.Subset.antisymm h₁ h₂",
      "\n  intro X Y h\n  apply Set.Subset.antisymm\n  · -- Prove X ⊆ Y\n    intro x hx\n    have h₁ : val_image A X = val_image A Y := h\n    have h₂ : x ∈ val_image A X := hx\n    have h₃ : x ∈ val_image A Y := by\n      rw [h₁] at h₂\n      exact h₂\n    exact h₃\n  · -- Prove Y ⊆ X\n    intro x hx\n    have h₁ : val_image A X = val_image A Y := h\n    have h₂ : x ∈ val_image A Y := hx\n    have h₃ : x ∈ val_image A X := by\n      rw [h₁] at *\n      exact h₂\n    exact h₃",
      "by\n  intro X1 X2 h\n  have h₁ : X1 = X2 := by\n    apply Set.Subset.antisymm\n    · -- Prove X1 ⊆ X2\n      intro x\n      have h₂ : x ∈ X1 := x.prop\n      have h₃ : (val_image A X1 : Set U) = (val_image A X2 : Set U) := h\n      have h₄ : x.val ∈ (val_image A X1 : Set U) := by\n        exact ⟨x, h₂, rfl⟩\n      have h₅ : x.val ∈ (val_image A X2 : Set U) := by\n        rw [h₃] at h₄\n        exact h₄\n      obtain ⟨y, hy₁, hy₂⟩ := h₅\n      have h₆ : x.val = y.val := by\n        simp_all [val_image]\n        <;> aesop\n      have h₇ : y ∈ X2 := hy₁\n      have h₈ : x = y := by\n        cases x\n        cases y\n        simp_all [Subtype.ext_iff]\n        <;> aesop\n      exact h₈ ▸ h₇\n    · -- Prove X2 ⊆ X1\n      intro x\n      have h₂ : x ∈ X2 := x.prop\n      have h₃ : (val_image A X1 : Set U) = (val_image A X2 : Set U) := h\n      have h₄ : x.val ∈ (val_image A X2 : Set U) := by\n        exact ⟨x, h₂, rfl⟩\n      have h₅ : x.val ∈ (val_image A X1 : Set U) := by\n        rw [h₃] at *\n        exact h₄\n      obtain ⟨y, hy₁, hy₂⟩ := h₅\n      have h₆ : x.val = y.val := by\n        simp_all [val_image]\n        <;> aesop\n      have h₇ : y ∈ X1 := hy₁\n      have h₈ : x = y := by\n        cases x\n        cases y\n        simp_all [Subtype.ext_iff]\n        <;> aesop\n      exact h₈ ▸ h₇\n  simpa using h₁",
