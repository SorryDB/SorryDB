```lean
def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X Y h
  have h' : val_image A X = val_image A Y := h
  have h₁ : X ⊆ Y := by
    intro x hx
    have : (x : U) ∈ val_image A X := by
      refine' ⟨x, hx, rfl⟩
    have : (x : U) ∈ val_image A Y := by
      rw [h'] at this
      exact this
    obtain ⟨y, hy, hy'⟩ := this
    have : x = y := by
      have h₂ : (x : U) = (y : U) := by
        simpa [hy'] using hy'
      exact Subtype.ext h₂
    have : y ∈ Y := hy
    exact by
      simpa [this] using this
  have h₂ : Y ⊆ X := by
    intro y hy
    have : (y : U) ∈ val_image A Y := by
      refine' ⟨y, hy, rfl⟩
    have : (y : U) ∈ val_image A X := by
      rw [h'] at *
      exact this
    obtain ⟨x, hx, hx'⟩ := this
    have : y = x := by
      have h₃ : (y : U) = (x : U) := by
        simpa [hx'] using hx'
      exact Subtype.ext h₃
    have : x ∈ X := hx
    exact by
      simpa [this] using this
  exact Set.Subset.antisymm h₁ h₂
```
