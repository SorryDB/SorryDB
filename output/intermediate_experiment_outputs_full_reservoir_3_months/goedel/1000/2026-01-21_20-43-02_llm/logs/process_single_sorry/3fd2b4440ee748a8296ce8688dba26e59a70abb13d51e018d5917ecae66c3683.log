```lean
def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

theorem val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X1 X2 h
  have h₁ : X1 ⊆ X2 := by
    intro x hx
    have h₂ : x.val ∈ val_image A X1 := by
      exact ⟨x, hx, rfl⟩
    have h₃ : x.val ∈ val_image A X2 := by
      rw [h] at h₂
      exact h₂
    obtain ⟨y, hy, hy'⟩ := h₃
    have h₄ : x.val = y.val := by
      have h₅ : y.val = x.val := by
        rw [hy'] at *
        <;> simp_all [Set.mem_setOf_eq]
        <;> aesop
      linarith
    have h₅ : x = y := by
      have h₆ : x.val = y.val := h₄
      have h₇ : x = y := by
        cases x
        cases y
        simp_all
        <;> aesop
      exact h₇
    exact hy ▸ h₅
  have h₂ : X2 ⊆ X1 := by
    intro x hx
    have h₃ : x.val ∈ val_image A X2 := by
      exact ⟨x, hx, rfl⟩
    have h₄ : x.val ∈ val_image A X1 := by
      rw [h] at *
      exact h₃
    obtain ⟨y, hy, hy'⟩ := h₄
    have h₅ : x.val = y.val := by
      have h₆ : y.val = x.val := by
        rw [hy'] at *
        <;> simp_all [Set.mem_setOf_eq]
        <;> aesop
      linarith
    have h₆ : x = y := by
      have h₇ : x.val = y.val := h₅
      have h₈ : x = y := by
        cases x
        cases y
        simp_all
        <;> aesop
      exact h₈
    exact hy ▸ h₆
  exact Set.Subset.antisymm h₁ h₂
