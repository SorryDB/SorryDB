theorem val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X1 X2 h
  have h1 : X1 = X2 := by
    apply Set.Subset.antisymm
    · intro x
      -- Prove that X1 ⊆ X2 using the given equality of val_image sets
      have h2 : val_image A X1 = val_image A X2 := h
      have h3 : x ∈ X1 → x ∈ X2 := by
        intro hx
        -- Use the fact that the val_image sets are equal to deduce subset inclusion
        have h4 : x.val ∈ val_image A X1 := by
          refine' ⟨x, hx, rfl⟩
        have h5 : x.val ∈ val_image A X2 := by
          rw [h2] at h4
          exact h4
        rcases h5 with ⟨y, hy, h6⟩
        -- Since x.val = y.val and the coercion is injective, x = y
        have h7 : (y : U) = x.val := by simpa using h6
        have h8 : (x : U) = x.val := by simp [Subtype.coe_mk]
        have h9 : (y : U) = (x : U) := by simp_all [Subtype.coe_mk]
        -- Deduce that x = y and thus x ∈ X2
        have h10 : y = x := by
          cases x
          cases y
          simp_all [Subtype.ext_iff]
          <;> aesop
        simp_all
      exact h3
    · intro x
      -- Prove that X2 ⊆ X1 using the given equality of val_image sets
      have h2 : val_image A X1 = val_image A X2 := h
      have h3 : x ∈ X2 → x ∈ X1 := by
        intro hx
        -- Use the fact that the val_image sets are equal to deduce subset inclusion
        have h4 : x.val ∈ val_image A X2 := by
          refine' ⟨x, hx, rfl⟩
        have h5 : x.val ∈ val_image A X1 := by
          rw [h2] at *
          exact h4
        rcases h5 with ⟨y, hy, h6⟩
        -- Since x.val = y.val and the coercion is injective, x = y
        have h7 : (y : U) = x.val := by simpa using h6
        have h8 : (x : U) = x.val := by simp [Subtype.coe_mk]
        have h9 : (y : U) = (x : U) := by simp_all [Subtype.coe_mk]
        -- Deduce that x = y and thus x ∈ X1
        have h10 : y = x := by
          cases x
          cases y
          simp_all [Subtype.ext_iff]
          <;> aesop
        simp_all
      exact h3
  
  exact h1
