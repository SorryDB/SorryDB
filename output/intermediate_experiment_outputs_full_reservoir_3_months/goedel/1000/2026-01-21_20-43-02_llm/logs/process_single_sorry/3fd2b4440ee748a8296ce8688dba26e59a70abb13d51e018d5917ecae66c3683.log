def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X Y h
  have h₁ : val_image A X = val_image A Y := h
  have h₂ : X ⊆ Y := by
    intro x hx
    have h₃ : (x : U) ∈ val_image A X := by
      -- Since x is in X, it is in the image of X under the inclusion map
      exact ⟨x, hx, rfl⟩
    have h₄ : (x : U) ∈ val_image A Y := by
      -- The images are equal, so x is also in the image of Y
      rw [h₁] at h₃
      exact h₃
    -- Extract the element from Y whose value is (x : U)
    rcases h₄ with ⟨y, hy, hy'⟩
    -- Since the embedding is injective, x = y
    have h₅ : (x : U) = (y : U) := by simpa [hy'] using hy'
    -- Therefore, x is in Y
    have h₆ : (x : A) = y := by
      apply Subtype.ext
      simpa using h₅
    exact by
      simpa [h₆] using hy
  have h₃ : Y ⊆ X := by
    intro x hx
    have h₄ : (x : U) ∈ val_image A Y := by
      -- Since x is in Y, it is in the image of Y under the inclusion map
      exact ⟨x, hx, rfl⟩
    have h₅ : (x : U) ∈ val_image A X := by
      -- The images are equal, so x is also in the image of X
      rw [h₁] at h₄
      exact h₄
    -- Extract the element from X whose value is (x : U)
    rcases h₅ with ⟨y, hy, hy'⟩
    -- Since the embedding is injective, x = y
    have h₆ : (x : U) = (y : U) := by simpa [hy'] using hy'
    -- Therefore, x is in X
    have h₇ : (x : A) = y := by
      apply Subtype.ext
      simpa using h₆
    exact by
      simpa [h₇] using hy
  -- Since X ⊆ Y and Y ⊆ X, we have X = Y
  exact Set.Subset.antisymm h₂ h₃
