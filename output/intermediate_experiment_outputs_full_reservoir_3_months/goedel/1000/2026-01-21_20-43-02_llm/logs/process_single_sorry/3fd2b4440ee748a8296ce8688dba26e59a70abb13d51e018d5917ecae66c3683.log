theorem Exercise_8_1_5_1 {U V : Type}
    (h : U ∼ V) : Set U ∼ Set V := by
  have h₁ : U ∼ V := h
  have h₂ : Set U ∼ Set V := by
    let F : Set U → Set V := fun A => image h.1 A
    let G : Set V → Set U := fun B => image h.2 B
    have h₃ : bijective h.1 := h.1.prop
    have h₄ : bijective h.2 := h.2.prop
    have h₅ : F ∘ G = id := by
      funext B
      have h₅₁ : (F ∘ G) B = F (G B) := rfl
      rw [h₅₁]
      have h₅₂ : G B = image h.2 B := rfl
      rw [h₅₂]
      have h₅₃ : F (image h.2 B) = image h.1 (image h.2 B) := rfl
      rw [h₅₃]
      have h₅₄ : image h.1 (image h.2 B) = (h.1 ∘ h.2) '' B := by
        simp [image_image]
        <;>
        simp_all [Function.comp]
        <;>
        set_option pp.all true
        <;>
        aesop
      rw [h₅₄]
      have h₅₅ : (h.1 ∘ h.2) '' B = (id : V → V) '' B := by
        have h₅₅₁ : ∀ (x : V), (h.1 ∘ h.2) x = id x := by
          intro x
          have h₅₅₂ : h.1 (h.2 x) = x := by
            have h₅₅₃ : Function.LeftInverse h.1 h.2 := by
              have h₅₅₄ : Function.LeftInverse h.1 h.2 := by
                have h₅₅₅ : Function.LeftInverse h.1 h.2 := h.2.left_inv
                exact h₅₅₅
              exact h₅₅₄
            exact h₅₅₃ x
          simp [Function.comp, id] at h₅₅₂ ⊢
          <;>
          aesop
        ext x
        simp_all [Function.comp]
        <;>
        aesop
      rw [h₅₅]
      have h₅₆ : (id : V → V) '' B = B := by
        simp [image_id]
      rw [h₅₆]
      <;>
      simp_all [Function.comp]
      <;>
      aesop
    have h₆ : G ∘ F = id := by
      funext A
