    apply ContDiffOn.div _ h₂
    · exact contDiffOn_const
    · intro z hz
      have h₄ : z.im > 0 := hz
      have h₅ : (z + 1 : ℂ) ≠ 0 := by
        simp [Complex.ext_iff, pow_two]
        <;> nlinarith
      simp_all [Complex.ext_iff, pow_two]
      <;> norm_num <;>
      (try { contradiction }) <;>
      (try { linarith }) <;>
      (try {
        field_simp [h₅]
        <;> norm_num <;>
        nlinarith
      })
  have h₄ : ContDiffOn ℝ ∞ (fun (z : ℂ) => Complex.exp (-(r : ℂ) * z)) ℍ₀ := by
    apply ContDiffOn.exp
    apply ContDiffOn.mul
    · exact contDiffOn_const
    · exact contDiffOn_id
  have h₅ : ContDiffOn ℝ ∞ (Φ₁' r) ℍ₀ := by
    apply ContDiffOn.mul
    · -- φ₀'' is a composition of holomorphic functions, hence smooth
      have h₅₁ : ContDiffOn ℝ ∞ (fun (z : ℂ) => (φ₀'' z : ℂ)) ℍ₀ := by
        sorry
