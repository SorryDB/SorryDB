        <;> aesop
      exact h₂.contDiffOn
    have h₃ : ContDiffOn ℝ ∞ (fun z : ℂ => (z + 1 : ℂ) : ℂ → ℂ) (Set.univ : Set ℂ) := by
      -- The function z ↦ z + 1 is smooth everywhere.
      apply contDiffOn_id.add
      exact contDiffOn_const
    have h₄ : ContDiffOn ℝ ∞ (fun z : ℂ => (z : ℂ) : ℂ → ℂ) (Set.univ : Set ℂ) := by
