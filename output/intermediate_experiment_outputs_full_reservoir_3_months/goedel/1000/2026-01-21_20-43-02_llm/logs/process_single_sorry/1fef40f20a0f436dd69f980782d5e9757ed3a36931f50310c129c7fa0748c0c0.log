        (try norm_num) <;>
        (try
          {
            nlinarith [sq_nonneg (z.re + 1), sq_nonneg (z.im)]
          }) <;>
        (try
          {
            ring_nf at * <;>
            norm_num at * <;>
            nlinarith [sq_nonneg (z.re + 1), sq_nonneg (z.im)]
          })
    · -- The exponential term is smooth everywhere
      apply ContDiffOn.exp
      apply ContDiffOn.mul
      · -- The constant r is smooth
        exact contDiffOn_const
      · -- The identity function is smooth
        exact contDiffOn_id
  have h₁ : ContDiffOn ℝ ∞ (Φ₁' r : ℂ → ℂ) ℍ₀ := h₀.mono (Set.subset_univ _)
  have h₂ : ContDiffOn ℝ ∞ (Φ₁' r : ℂ → ℝ) ℍ₀ := by
    -- Since the function is already complex-smooth, it is also real-smooth when restricted to the upper half-plane.
    have h₃ : ContDiffOn ℝ ∞ (Φ₁' r : ℂ → ℂ) ℍ₀ := h₁
    -- The real and imaginary parts are smooth because the function is complex-smooth.
    have h₄ : ContDiffOn ℝ ∞ (fun x : ℂ => (Φ₁' r x).re : ℂ → ℝ) ℍ₀ := by
      apply ContDiffOn.comp (h₃.re) (contDiffOn_id : ContDiffOn ℝ ∞ (fun x : ℝ => x : ℝ → ℝ))
      <;> simp [Complex.ext_iff]
      <;> norm_num
    have h₅ : ContDiffOn ℝ ∞ (fun x : ℂ => (Φ₁' r x).im : ℂ → ℝ) ℍ₀ := by
