      <;> simp [Complex.ext_iff]
      <;> norm_num
    -- The function Φ₁' r is real-smooth because it is complex-smooth and the real and imaginary parts are smooth.
    have h₆ : ContDiffOn ℝ ∞ (Φ₁' r : ℂ → ℝ) ℍ₀ := by
