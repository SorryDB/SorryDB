theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · intro hf
      have h₂ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that the scalar multiplication by r preserves the interval integrability of f
        have h₃ : r • f = fun x => r • f x := rfl
        rw [h₃]
        -- Since f is interval integrable, r • f is also interval integrable because scalar multiplication preserves this property
        refine' hf.smul _
        <;>
        (try norm_num) <;>
        (try simp_all [IsBoundedSMul]) <;>
        (try infer_instance) <;>
        (try assumption) <;>
        (try aesop)
        <;>
        (try {
          -- Prove that the scalar multiplication is bounded
          have h₄ : IsBoundedSMul R E := ‹IsBoundedSMul R E›
          simpa using h₄
        })
      exact h₂
    · intro hf
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the fact that the scalar multiplication by r preserves the interval integrability of f
        have h₃ : f = fun x => (r⁻¹) • (r • f x) := by
          funext x
          have h₄ : r • f x = r • f x := rfl
          calc
            f x = (1 : R) • f x := by simp
            _ = (r⁻¹ * r) • f x := by
              have h₅ : (r⁻¹ : R) * r = 1 := by
                simp [mul_inv_cancel_left₀, isUnit_iff_ne_zero]
              rw [h₅]
              <;> simp [smul_smul]
            _ = r⁻¹ • (r • f x) := by
              simp [smul_smul]
              <;>
              (try simp_all [IsBoundedSMul]) <;>
              (try infer_instance) <;>
              (try aesop)
              <;>
              (try {
                -- Prove that the scalar multiplication is bounded
                have h₄ : IsBoundedSMul R E := ‹IsBoundedSMul R E›
                simpa using h₄
              })
        rw [h₃]
        -- Since r • f is interval integrable, (r⁻¹) • (r • f) is also interval integrable because scalar multiplication preserves this property
        refine' hf.smul _
        <;>
        (try norm_num) <;>
        (try simp_all [IsBoundedSMul]) <;>
        (try infer_instance) <;>
        (try assumption) <;>
        (try aesop)
        <;>
        (try {
          -- Prove that the scalar multiplication is bounded
          have h₄ : IsBoundedSMul R E := ‹IsBoundedSMul R E›
          simpa using h₄
        })
      exact h₂
