theorem T_7_2 [Fintype α] (X : Finset α) (A : Finset (Finset α)) :
  IsDistrib A → (X ∈ ⨆ A ↔ ∀ Y ∈ A, X ∩ Y ⊆ X) := by
  intro hDistrib
  have h1 : X ∈ ⨆ A ↔ ∀ Y ∈ A, X ∩ Y ⊆ X := by
    constructor
    · intro h
      intro Y hY
      have h2 : Y ∈ A := hY
      have h3 : X ∈ ⨆ A := h
      have h4 : X ∈ Y := by
        -- Prove that X ∈ Y using the distributive property and the fact that X ∈ ⨆ A
        have h5 : ⨆ A = ⋃ s ∈ A, s := by
          simp [iSup_def, Finset.sup_eq_biSup]
          <;>
          simp_all [Finset.mem_biSup]
          <;>
          aesop
        rw [h5] at h3
        simp only [Finset.mem_iUnion, Finset.mem_biUnion] at h3
        obtain ⟨s, hs, hs'⟩ := h3
        have h6 : s = Y := by
          -- Use the distributive property to show that s must be Y
          have h7 : IsDistrib A := hDistrib
          have h8 : s ∈ A := hs
          have h9 : Y ∈ A := hY
          have h10 : s = Y := by
            -- Use the fact that A is distributive to deduce s = Y
            have h11 : s = Y := by
              by_contra h12
              -- If s ≠ Y, then A would not be distributive, leading to a contradiction
              have h13 : s ≠ Y := h12
              simp_all [IsDistrib]
              <;>
              aesop
            exact h11
          exact h10
        rw [h6] at hs'
        exact hs'
      -- Prove that X ∩ Y ⊆ X
      have h5 : X ∩ Y ⊆ X := by
        intro x hx
        simp only [Finset.mem_inter] at hx ⊢
        tauto
      exact h5
    · intro h
      have h2 : ∀ Y ∈ A, X ∩ Y ⊆ X := h
      have h3 : X ∈ ⨆ A := by
        -- Prove that X ∈ ⨆ A using the given condition and the distributive property
        have h4 : ⨆ A = ⋃ s ∈ A, s := by
          simp [iSup_def, Finset.sup_eq_biSup]
          <;>
          simp_all [Finset.mem_biSup]
          <;>
          aesop
        rw [h4]
        simp only [Finset.mem_iUnion, Finset.mem_biUnion]
        -- Use the fact that for every Y ∈ A, X ∩ Y ⊆ X to find a suitable s ∈ A such that X ∈ s
        by_cases h5 : A = ∅
        · exfalso
          simp_all [Finset.ext_iff]
          <;>
          aesop
        · -- If A is not empty, we can find an element s ∈ A
          have h6 : ∃ Y, Y ∈ A := by
            classical
            exact Finset.nonempty_iff_ne_empty.mpr h5
          obtain ⟨Y, hY⟩ := h6
          have h7 : X ∩ Y ⊆ X := h2 Y hY
          -- Use the fact that A is distributive to find s = Y such that X ∈ Y
          have h8 : X ∈ Y := by
            by_contra h9
            have h10 : X ∩ Y ⊆ X := h2 Y hY
            have h11 : X ∩ Y ⊂ X := by
              apply Finset.ssubset_iff_of_subset h10.mono (fun x hx => by simp_all [Finset.mem_inter])
              -- Prove that there exists an element in X that is not in X ∩ Y
              have h12 : ∃ x, x ∈ X ∧ x ∉ Y := by
                by_contra h13
                push_neg at h13
                have h14 : X ⊆ Y := by
                  intro x hx
                  by_cases h15 : x ∈ Y
                  · exact h15
                  · exfalso
                    have h16 := h13 x
                    simp_all
                have h17 : X ∈ Y := by
                  have h18 : X ⊆ Y := h14
                  have h19 : X ∈ Y := by
                    by_contra h20
                    simp_all [Finset.subset_iff]
                    <;>
                    aesop
                  exact h19
