          (try simp_all [Error.eval, Error.stubbornness, Error.maxOne]) <;>
          (try aesop)
    case Callee =>
      by_cases h : eval S ⟨σ,⁻o⟩ (Kv a b)
      · specialize IH (⁻o) h
        unfold resultSet
        simp only [ra, stubbornness, Subtype.forall, OSequence.length_def]
