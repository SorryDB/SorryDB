    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    have h₁ : x.1 ∈ support (uniformSample α) := SampleableType.mem_support_selectElem x.1
    have h₂ : x.2 ∈ support (uniformSample β) := SampleableType.mem_support_selectElem x.2
    have h₃ : x ∈ support ((·, ·) <$> (uniformSample α) <*> (uniformSample β)) := by
      apply support_bind_mem
      <;> simp_all [support_bind_mem]
      <;> aesop
