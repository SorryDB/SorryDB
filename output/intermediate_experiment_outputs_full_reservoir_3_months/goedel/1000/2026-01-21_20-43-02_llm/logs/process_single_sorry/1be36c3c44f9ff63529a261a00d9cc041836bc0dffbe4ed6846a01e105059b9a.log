instance (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    have h₁ : x.1 ∈ support ($ᵗ α) := SampleableType.mem_support_selectElem x.1
    have h₂ : x.2 ∈ support ($ᵗ β) := SampleableType.mem_support_selectElem x.2
    have h₃ : x ∈ support ((·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
      -- Use the fact that the product of two probability processes with full support has full support
      have h₄ : x.1 ∈ support ($ᵗ α) := h₁
      have h₅ : x.2 ∈ support ($ᵗ β) := h₂
      -- Use the property of product of supports
      simp_all [support_prod]
      <;> aesop
    exact h₃
  
  probOutput_selectElem_eq := by
    intro x y
    have h₁ : Pr[= x | (·, ·) <$> $ᵗ α _ <*> $ᵗ β _] = Pr[= y | (·, ·) <$> $ᵗ α _ <*> $ᵗ β _] := by
      -- Use the fact that the probability of each element is the same in the product distribution
      have h₂ : Pr[= x | (·, ·) <$> $ᵗ α _ <*> $ᵗ β _] = Pr[= x.1 | $ᵗ α _] * Pr[= x.2 | $ᵗ β _] := by
        simp [probOutput_seq]
        <;>
        (try simp_all [probOutput_map])
        <;>
        (try simp_all [prod_probOutput])
      have h₃ : Pr[= y | (·, ·) <$> $ᵗ α _ <*> $ᵗ β _] = Pr[= y.1 | $ᵗ α _] * Pr[= y.2 | $ᵗ β _] := by
        simp [probOutput_seq]
        <;>
        (try simp_all [probOutput_map])
        <;>
        (try simp_all [prod_probOutput])
      have h₄ : Pr[= x.1 | $ᵗ α _] = Pr[= y.1 | $ᵗ α _] := by
        have h₅ : Pr[= x.1 | $ᵗ α _] = Pr[= y.1 | $ᵗ α _] := by
          have h₆ := SampleableType.probOutput_selectElem_eq x.1 y.1
          exact h₆
        exact h₅
      have h₅ : Pr[= x.2 | $ᵗ β _] = Pr[= y.2 | $ᵗ β _] := by
        have h₆ := SampleableType.probOutput_selectElem_eq x.2 y.2
        exact h₆
      calc
        Pr[= x | (·, ·) <$> $ᵗ α _ <*> $ᵗ β _] = Pr[= x.1 | $ᵗ α _] * Pr[= x.2 | $ᵗ β _] := by rw [h₂]
        _ = Pr[= y.1 | $ᵗ α _] * Pr[= x.2 | $ᵗ β _] := by rw [h₄]
        _ = Pr[= y.1 | $ᵗ α _] * Pr[= y.2 | $ᵗ β _] := by rw [h₅]
        _ = Pr[= y | (·, ·) <$> $ᵗ α _ <*> $ᵗ β _] := by
          simp [probOutput_seq]
          <;>
          (try simp_all [probOutput_map])
          <;>
          (try simp_all [prod_probOutput])
    exact h₁
  
  probFailure_selectElem := by
    simp [probFailure_seq, SampleableType.probFailure_selectElem]
