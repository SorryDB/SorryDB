instance (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    have h₁ : x.1 ∈ support (uniformSample α) := SampleableType.mem_support_selectElem x.1
    have h₂ : x.2 ∈ support (uniformSample β) := SampleableType.mem_support_selectElem x.2
    -- Combine h₁ and h₂ to show that (x.1, x.2) is in the support of the product
    have h₃ : x ∈ support ((·, ·) <$> (uniformSample α) <*> (uniformSample β)) := by
      -- Since x.1 is in the support of uniformSample α and x.2 is in the support of uniformSample β,
      -- there exist non-zero probabilities that uniformSample α returns x.1 and uniformSample β returns x.2.
      -- Therefore, the pair (x.1, x.2) has a non-zero probability to be in the product.
      apply support_bind_mem
      <;> simp_all [support_bind_mem]
      <;> aesop
    exact h₃
  probOutput_selectElem_eq := by sorry -- as before
  probFailure_selectElem := by
    -- Use the property that the product of probFailures is the probFailure of the product
    have h₁ : [⊥ | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = 0 := by
      simp [probFailure_seq]
      <;> simp_all [SampleableType.probFailure_selectElem]
      <;> simp_all [mul_zero]
    -- Simplify the expression to use h₁
    simp_all [h₁]
  sorry
