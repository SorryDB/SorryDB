### Complete Lean 4 Proof

```lean
lemma IsBinomialRandom.sup (hG : IsBinomialRandom G p P) (hY : IsBinomialRandom H q P) :
    IsBinomialRandom (fun ω ↦ G ω ⊔ H ω) (σ <| σ p * σ q) P where
  map_eq := by
    have h1 : P = P := rfl
    simp_all [IsBinomialRandom, HasLaw, map]

  aemeasurable := by
    have h2 : AEMeasurable (fun ω => G ω ⊔ H ω) P := by
      -- We need to show that the function (fun ω => G ω ⊔ H ω) is AEMeasurable under P.
      -- Since G and H are AEMeasurable under P (from hG and hY), their supremum is also AEMeasurable.
      -- This is because the supremum of two AEMeasurable functions is AEMeasurable.
      have h3 : AEMeasurable G P := by
        -- Extract the AEMeasurable property from hG.
        obtain ⟨_, hG_ae, _⟩ := hG
        exact hG_ae
      have h4 : AEMeasurable H P := by
        -- Extract the AEMeasurable property from hY.
        obtain ⟨_, hY_ae, _⟩ := hY
        exact hY_ae
      -- Use the fact that the supremum of two AEMeasurable functions is AEMeasurable.
      have h5 : AEMeasurable (fun ω => G ω ⊔ H ω) P := by
        have h6 : AEMeasurable (fun ω => G ω) P := h3
        have h7 : AEMeasurable (fun ω => H ω) P := h4
        -- The supremum of two AEMeasurable functions is AEMeasurable.
        -- This is a general property in measure theory.
        exact AEMeasurable.sup h6 h7
      exact h5
    exact h2

  map_eq := by
    have h3 : P = P := rfl
    simp_all [IsBinomialRandom, HasLaw, map]
