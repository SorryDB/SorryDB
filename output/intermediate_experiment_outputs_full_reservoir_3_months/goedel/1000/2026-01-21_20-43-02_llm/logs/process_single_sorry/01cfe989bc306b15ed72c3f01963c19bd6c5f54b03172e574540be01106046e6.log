        (try simp_all [Complex.ext_iff, Real.toNNReal_of_nonneg, le_of_lt, Real.sqrt_eq_iff_sq_eq])
      --Use the decomposition to apply the HasRestrictedWeakType property
      have h₃ : eLpNorm (T g) 1 (ν.restrict G) ≤ (4 * c / p) * eLorentzNorm g p 1 μ * (ν G) ^ p'⁻¹.toReal := by
        have h₄ : eLpNorm (T g) 1 (ν.restrict G) ≤ 0 := by
