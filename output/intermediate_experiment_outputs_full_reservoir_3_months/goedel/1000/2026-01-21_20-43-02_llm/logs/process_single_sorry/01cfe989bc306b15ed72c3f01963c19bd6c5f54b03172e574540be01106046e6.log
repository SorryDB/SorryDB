        have h₅ : (4 * c / p) * eLorentzNorm g p 1 μ * (ν G) ^ p'⁻¹.toReal ≥ 0 := by positivity
        linarith
      simpa [h₃] using h₃
  --TODO: put together the L^1 norm bound and deduce the Lorentz norm bound
  have h₁ : ∀ (G : Set α'), (MeasurableSet G) → (ν G < ∞) → eLpNorm (T f) 1 (ν.restrict G) ≤ (4 * c / p) * eLorentzNorm f p 1 μ * (ν G) ^ p'⁻¹.toReal := by
    exact claim
  --Use the properties of T to conclude the proof
  have h₂ : HasLorentzType T p 1 p ∞ μ ν (4 * c / p) := by
    sorry
  exact h₂
