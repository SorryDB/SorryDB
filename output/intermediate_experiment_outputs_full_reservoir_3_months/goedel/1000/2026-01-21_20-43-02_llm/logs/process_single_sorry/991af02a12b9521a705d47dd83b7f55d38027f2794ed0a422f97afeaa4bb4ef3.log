      "\n        calc\n          ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ ⨆ i, ((⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P) := by\n            -- Use the fact that the sum of the iSups is an upper bound for each term\n            exact ciSup_mono (fun i ↦ by linarith [h₁ i])\n          _ = (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by\n            -- Simplify the expression\n            simp [iSup_const]\n            <;>\n            (try norm_num) <;>\n            (try linarith)\n      -- Use the fact that the iSup of the sum is less than or equal to the sum of the iSups\n      exact h₇\n    _ = (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by rfl",
      "\n              -- Use the fact that the supremum of the sum is less than or equal to the sum of the supremums\n              calc\n                ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ ⨆ i, (⨆ j, eLpNorm (X j) 2 P) + eLpNorm (Y i) 2 P := by\n                  apply iSup_le\n                  intro i\n                  have h₂ : eLpNorm (X i) 2 P ≤ ⨆ j, eLpNorm (X j) 2 P := le_iSup (i)\n                  have h₃ : eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P ≤ (⨆ j, eLpNorm (X j) 2 P) + eLpNorm (Y i) 2 P := by\n                    exact add_le_add_right (h₂) _\n                  exact h₃\n                _ = (⨆ j, eLpNorm (X j) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by\n                  -- Use the fact that the sum of the supremums is the supremum of the sums\n                  have h₄ : ⨆ i, ((⨆ j, eLpNorm (X j) 2 P) + eLpNorm (Y i) 2 P) = (⨆ j, eLpNorm (X j) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by\n                    rw [iSup_add_const]\n                  rw [h₄]\n                  <;> simp [add_comm]\n                _ = (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by simp [add_comm]\n        -- Use the fact that the supremum of the sum is less than or equal to the sum of the supremums\n        exact h₁",
      "",
      "\n          -- Use the fact that the supremum of the sum is less than or equal to the sum of the suprema\n          have h₁ : ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by\n            -- Apply the property of suprema for sums\n            calc ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ ⨆ i, (⨆ j, eLpNorm (X j) 2 P + eLpNorm (Y i) 2 P) := by\n                -- Since eLpNorm (X i) 2 P ≤ ⨆ j, eLpNorm (X j) 2 P for each i\n                refine' iSup_mono fun i ↦ _\n                have h₂ : eLpNorm (X i) 2 P ≤ ⨆ j, eLpNorm (X j) 2 P := le_iSup (fun j ↦ eLpNorm (X j) 2 P) i\n                -- Therefore, eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P ≤ ⨆ j, eLpNorm (X j) 2 P + eLpNorm (Y i) 2 P\n                linarith [h₂]\n              _ = (⨆ j, eLpNorm (X j) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by\n                -- The supremum over i of (⨆ j, eLpNorm (X j) 2 P + eLpNorm (Y i) 2 P) is (⨆ j, eLpNorm (X j) 2 P) + ⨆ i, eLpNorm (Y i) 2 P\n                simp [iSup_add_right]\n              _ = (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by\n                -- Change the index of the supremum\n                simp [iSup_congr]\n            <;>\n            simp_all\n          -- Use the previous result to conclude the inequality\n          exact h₁\n      _ < ∞ := by\n          -- Since both suprema are finite, their sum is also finite\n          have h₂ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) < ∞ := hX_bound\n          have h₃ : (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := hY_bound\n          -- The sum of two finite values is finite\n          have h₄ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) + (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := by\n            -- Use the fact that the sum of two finite values is finite\n            have h₅ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) < ∞ := hX_bound\n            have h₆ : (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := hY_bound\n            -- Use the property of the sum of two finite values\n            simp [h₅, h₆, ENNReal.add_lt_top]\n          -- The sum of the suprema is finite\n          simpa using h₄",
      "\n        have h : ⨆ i : ι, eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P ≤ (⨆ i : ι, eLpNorm (X i) 2 P) + ⨆ i : ι, eLpNorm (Y i) 2 P := by\n          -- Apply the property of the supremum for sums\n          calc\n            ⨆ i : ι, eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P ≤ ⨆ i : ι, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := le_iSup (fun i : ι => eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P)\n            _ = ⨆ i : ι, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := rfl\n            _ ≤ (⨆ i : ι, eLpNorm (X i) 2 P) + ⨆ i : ι, eLpNorm (Y i) 2 P := by\n              -- Use the subadditivity of the supremum\n              apply iSup_add_le\n              <;>\n                (try simp_all) <;>\n                (try norm_num) <;>\n                (try linarith) <;>\n                (try\n                  {\n                    apply le_of_not_gt\n                    intro h₂\n                    refine' h₂.ne' (by simp_all [hX_bound, hY_bound])\n                  })\n              <;>\n                (try\n                  {\n                    simp_all [hX_bound, hY_bound]\n                    <;>\n                    norm_num at *\n                    <;>\n                    linarith\n                  })\n        -- Use the obtained inequality\n        calc\n          ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) = ⨆ i : ι, eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := rfl\n          _ ≤ (⨆ i : ι, eLpNorm (X i) 2 P) + ⨆ i : ι, eLpNorm (Y i) 2 P := h\n          _ = (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := rfl\n      _ < ∞ := by\n        -- Prove that the sum is finite\n        have h₁ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) < ∞ := by simpa using hX_bound\n        have h₂ : (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := by simpa using hY_bound\n        -- Use the fact that the sum of finite numbers is finite\n        have h₃ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) + (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := by\n          -- Use the fact that the sum of finite numbers is finite\n          simp_all [add_lt_top_iff]\n          <;>\n          norm_num\n          <;>\n          linarith\n        -- Use the fact that the sum of finite numbers is finite\n        simpa using h₃",
