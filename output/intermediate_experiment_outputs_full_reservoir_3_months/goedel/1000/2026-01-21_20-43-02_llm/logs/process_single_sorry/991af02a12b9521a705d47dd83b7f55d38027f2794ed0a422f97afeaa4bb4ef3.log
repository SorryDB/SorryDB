```lean
theorem IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · -- Prove that the sum of cadlag processes is cadlag
    have h1 : IsCadlag (X · ω) := hX.cadlag ω
    have h2 : IsCadlag (Y · ω) := hY.cadlag ω
    apply IsCadlag.add h1 h2
  · -- Prove the boundedness of the sum
    have hX_bound : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded
    have hY_bound : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded
    calc ⨆ i, eLpNorm (fun ω ↦ X i ω + Y i ω) 2 P
        ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
          refine iSup_mono fun i ↦ ?_
          exact eLpNorm_add_le ((hX.martingale.adapted i).mono (𝓕.le i)).aestronglyMeasurable
            ((hY.martingale.adapted i).mono (𝓕.le i)).aestronglyMeasurable (by simp)
      _ ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by
        -- Use the subadditivity of the supremum
        have h₁ : ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by
          -- Apply the inequality of supremums
          calc ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := le_refl _
          _ ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by
            -- Use the fact that the supremum of the sum is less than or equal to the sum of the supremums
            have h₂ : ∀ i, eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by
              intro i
              have h₃ : eLpNorm (X i) 2 P ≤ ⨆ i, eLpNorm (X i) 2 P := le_iSup (fun i ↦ eLpNorm (X i) 2 P) i
              have h₄ : eLpNorm (Y i) 2 P ≤ ⨆ i, eLpNorm (Y i) 2 P := le_iSup (fun i ↦ eLpNorm (Y i) 2 P) i
              linarith
            -- Apply the inequality to each term
            exact iSup_le (fun i ↦ h₂ i)
        -- Use the previous result to conclude the proof
        exact h₁
