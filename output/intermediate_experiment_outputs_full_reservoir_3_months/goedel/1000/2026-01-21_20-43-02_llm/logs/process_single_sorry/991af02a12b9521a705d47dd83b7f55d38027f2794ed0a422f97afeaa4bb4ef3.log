0 ≤ eLpNorm (Y j) 2 P := by\n                  apply ENNReal.coe_nonneg\n                calc\n                  eLpNorm (X j) 2 P + eLpNorm (Y j) 2 P ≤ (⨆ i : ι, eLpNorm (X i) 2 P) + eLpNorm (Y j) 2 P := by\n                    gcongr\n                  _ ≤ (⨆ i : ι, eLpNorm (X i) 2 P) + ⨆ i : ι, eLpNorm (Y i) 2 P := by\n                    gcongr\n                    <;> simp_all [le_iSup]\n              exact h6\n            exact h5\n          exact h1",
      "\n          calc\n            ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := le_refl _\n            _ ≤ (⨆ i, eLpNorm (X i) 2 P) + (⨆ i, eLpNorm (Y i) 2 P) := by\n              -- Use the fact that the supremum of sums is less than or equal to the sum of suprema\n              have h₁ : ∀ (i : ι), eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P ≤ (⨆ (j : ι), eLpNorm (X j) 2 P) + (⨆ (j : ι), eLpNorm (Y j) 2 P) := by\n                intro i\n                have h₂ : eLpNorm (X i) 2 P ≤ ⨆ (j : ι), eLpNorm (X j) 2 P := by\n                  apply le_iSup\n                have h₃ : eLpNorm (Y i) 2 P ≤ ⨆ (j : ι), eLpNorm (Y j) 2 P := by\n                  apply le_iSup\n                linarith\n              -- Use the above inequality to bound the supremum\n              calc\n                ⨆ (i : ι), (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ ⨆ (i : ι), ((⨆ (j : ι), eLpNorm (X j) 2 P) + (⨆ (j : ι), eLpNorm (Y j) 2 P)) := by\n                  apply iSup_mono\n                  intro i\n                  exact h₁ i\n                _ = (⨆ (j : ι), eLpNorm (X j) 2 P) + (⨆ (j : ι), eLpNorm (Y j) 2 P) := by\n                  simp [iSup_const, add_assoc]",
