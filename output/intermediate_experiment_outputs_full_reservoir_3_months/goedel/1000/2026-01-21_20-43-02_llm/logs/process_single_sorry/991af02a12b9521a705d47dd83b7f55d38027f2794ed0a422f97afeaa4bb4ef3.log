theorem IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  have h_sum_martingale : Martingale (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
    refine Martingale.add hX.martingale hY.martingale
  
  have h_sum_cadlag : ∀ ω, IsCadlag (fun i ↦ (X i ω + Y i ω)) := by
    intro ω
    have h₁ : IsCadlag (X · ω) := hX.cadlag ω
    have h₂ : IsCadlag (Y · ω) := hY.cadlag ω
    -- The sum of two cadlag functions is cadlag
    exact IsCadlag.add h₁ h₂
  
  have h_sum_bounded : ⨆ i, eLpNorm (fun ω ↦ X i ω + Y i ω) 2 P < ∞ := by
    have h₁ : ⨆ i, eLpNorm (fun ω ↦ X i ω + Y i ω) 2 P ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by
      calc
        ⨆ i, eLpNorm (fun ω ↦ X i ω + Y i ω) 2 P ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
          refine iSup_mono fun i ↦ _
          -- Use the triangle inequality for eLpNorm
          have h₂ : eLpNorm (fun ω : Ω => X i ω + Y i ω) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
            -- Use the fact that eLpNorm is subadditive for p ≥ 1
            have h₃ : eLpNorm (fun ω : Ω => X i ω + Y i ω) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
              -- Use the subadditivity of eLpNorm for p = 2
              refine eLpNorm_add_le _ _ _
              · -- Show that X i is measurable
                exact (hX.martingale.adapted i).mono (fun _ _ ↦ by simp_all [Filtration.le_def])
                  |>.aestronglyMeasurable
              · -- Show that Y i is measurable
                exact (hY.martingale.adapted i).mono (fun _ _ ↦ by simp_all [Filtration.le_def])
                  |>.aestronglyMeasurable
              · -- Use the normed vector space property
                exact by simp [norm_add_le]
            exact h₃
          exact h₂
        _ ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by
          -- Use the fact that the sum of iSup is the iSup of the sum
          refine le_trans (iSup_add_le _ _) _
          <;>
          simp [add_comm]
          <;>
          simp_all [iSup_add_le]
          <;>
          try norm_num
          <;>
          linarith
    -- Since both iSup eLpNorm X 2 P and iSup eLpNorm Y 2 P are finite, their sum is also finite
    have h₂ : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded
    have h₃ : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded
    have h₄ : (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P < ∞ := by
      -- Use the fact that the sum of two finite numbers is finite
      have h₅ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) < ∞ := by exact_mod_cast h₂
      have h₆ : (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := by exact_mod_cast h₃
      -- Add the two finite numbers to get a finite number
      have h₇ : (⨆ i, eLpNorm (X i) 2 P : ℝ≥0∞) + (⨆ i, eLpNorm (Y i) 2 P : ℝ≥0∞) < ∞ := by
        -- Use the property that the sum of two finite numbers is finite
        exact add_lt_top h₅ h₆
      -- Convert back to the original type
      exact_mod_cast h₇
    -- Combine the inequalities to get the final result
    calc
      ⨆ i, eLpNorm (fun ω ↦ X i ω + Y i ω) 2 P ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := h₁
      _ < ∞ := h₄
  
  exact ⟨h_sum_martingale, h_sum_cadlag, h_sum_bounded⟩
