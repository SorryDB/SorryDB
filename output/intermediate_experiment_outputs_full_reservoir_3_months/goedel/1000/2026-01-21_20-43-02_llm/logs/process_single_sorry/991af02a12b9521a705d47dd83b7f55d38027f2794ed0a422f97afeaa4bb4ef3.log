      "\n      -- Use the iSup_add lemma for ENNReal\n      have h₂ : ∀ i : ι, 0 ≤ (eLpNorm (X i) 2 P : ℝ≥0∞) := by\n        intro i\n        exact zero_le _\n      have h₃ : ∀ i : ι, 0 ≤ (eLpNorm (Y i) 2 P : ℝ≥0∞) := by\n        intro i\n        exact zero_le _\n      -- Apply the iSup_add lemma\n      have h₄ : (⨆ i : ι, (eLpNorm (X i) 2 P : ℝ≥0∞) + (eLpNorm (Y i) 2 P : ℝ≥0∞)) ≤ (⨆ i : ι, (eLpNorm (X i) 2 P : ℝ≥0∞)) + (⨆ i : ι, (eLpNorm (Y i) 2 P : ℝ≥0∞)) := by\n        apply iSup_add\n        <;>\n        (try simp_all [ENNReal.coe_nonneg]) <;>\n        (try simp_all [ENNReal.coe_le_coe]) <;>\n        (try simp_all [ENNReal.coe_add]) <;>\n        (try norm_num) <;>\n        (try linarith)\n      -- Simplify the statement to match the original form\n      simpa [ENNReal.coe_add] using h₄\n    exact h₁",
