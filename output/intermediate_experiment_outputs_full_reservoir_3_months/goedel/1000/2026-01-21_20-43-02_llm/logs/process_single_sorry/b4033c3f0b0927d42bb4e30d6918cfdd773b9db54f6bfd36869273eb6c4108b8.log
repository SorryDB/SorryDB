      "\n  have h_main : False := by\n    have h₁ : False := by\n      by_cases h : (ClassicalMechanics.HarmonicOscillator.InitialConditions.x₀ IC : (PiLp ℝ (ENNReal.ofNat 1))) = 0\n      <;> by_cases h' : (ClassicalMechanics.HarmonicOscillator.InitialConditions.v₀ IC : (PiLp ℝ (ENNReal.ofNat 1))) = 0 <;>\n        simp_all [ClassicalMechanics.HarmonicOscillator.InitialConditions] <;>\n        (try contradiction) <;>\n        (try simp_all [PiLp.ext_iff, Fin.forall_fin_one]) <;>\n        (try norm_num at *) <;>\n        (try linarith) <;>\n        (try {\n          exfalso\n          simp_all [PiLp.ext_iff, Fin.forall_fin_one]\n          <;> norm_num at *\n          <;> linarith\n        })\n      <;>\n      (try {\n        exfalso\n        simp_all [PiLp.ext_iff, Fin.forall_fin_one]\n        <;> norm_num at *\n        <;> linarith\n      })\n    exact h₁\n  \n  have h_final : ∂ₜ (IC.trajectory S) t = 0 ↔ ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n    exfalso\n    exact h_main\n  \n  exact h_final",
