      "\n  have h1 : (S.ω : ℝ) ≠ 0 := by\n    have h2 : (S.ω : ℝ) = S.ω := by simp\n    norm_cast\n    <;> simp_all [ω_neq_zero]\n    <;> aesop\n  \n  have h2 : ∂ₜ (IC.trajectory S) t = 0 ↔ - S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 := by\n    simp [trajectory_velocity]\n    <;>\n    aesop\n  \n  have h3 : (- S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0) ↔ (tan (S.ω * t.val) = (2 : ℝ)) := by\n    have h4 : sin (S.ω * t.val) = 0 → cos (S.ω * t.val) = 0 → False := by\n      intro h5 h6\n      have h7 : sin (S.ω * t.val) ^ 2 + cos (S.ω * t.val) ^ 2 = 1 := by\n        rw [Real.sin_sq_add_cos_sq]\n      rw [h5, h6] at h7\n      norm_num at h7\n      <;> linarith\n    by_cases h5 : sin (S.ω * t.val) = 0\n    · have h6 : cos (S.ω * t.val) ≠ 0 := by\n        intro h7\n        have h8 : sin (S.ω * t.val) = 0 := h5\n        have h9 : cos (S.ω * t.val) = 0 := h7\n        exact h4 h8 h9\n      have h7 : - S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 → (tan (S.ω * t.val) = (2 : ℝ)) := by\n        intro h8\n        have h9 : - S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 := h8\n        simp [h5] at h9\n        <;>\n        (try simp_all [tan_eq_sin_div_cos, mul_zero, zero_mul]) <;>\n        (try field_simp [h6, Real.tan_eq_sin_div_cos] at h9 ⊢) <;>\n        (try norm_num at h9 ⊢) <;>\n        (try simp_all [tan_eq_sin_div_cos, mul_zero, zero_mul]) <;>\n        (try nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]) <;>\n        (try\n          {\n            exfalso\n            simp_all [tan_eq_sin_div_cos, mul_zero, zero_mul]\n            <;>\n            (try field_simp [h6, Real.tan_eq_sin_div_cos] at h9 ⊢) <;>\n            (try norm_num at h9 ⊢) <;>\n            (try simp_all [tan_eq_sin_div_cos, mul_zero, zero_mul]) <;>\n            (try nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)])\n          }) <;>\n        (try\n          {\n            aesop\n          })\n        <;>\n        (try\n     