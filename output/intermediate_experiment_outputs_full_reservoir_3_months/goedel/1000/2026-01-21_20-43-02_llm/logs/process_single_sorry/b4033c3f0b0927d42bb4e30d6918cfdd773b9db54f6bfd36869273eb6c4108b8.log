      "\n  have h : S.ω ≠ 0 := by exact ω_neq_zero S\n  simp only [SeparateLinearMap.toLin_hom]\n  <;>\n  (try { cases hx <;> simp_all }) <;>\n  (try { field_simp [h] at * <;> ring_nf at * <;> simp_all }) <;>\n  (try { norm_num }) <;>\n  (try { aesop }) <;>\n  (try { simp_all [trajectory, trajectory_eq, add_assoc] }) <;>\n  (try { ring_nf at * <;> field_simp [h] at * <;> simp_all }) <;>\n  (try { linarith }) <;>\n  (try { nlinarith }) <;>\n  (try { nlinarith [Real.sqrt_nonneg (‖IC.x₀‖ ^ 2 + (‖IC.v₀‖ / S.ω) ^ 2),\n    Real.sq_sqrt (show 0 ≤ ‖IC.x₀‖ ^ 2 + (‖IC.v₀‖ / S.ω) ^ 2 by positivity)] })\n  <;>\n  (try {\n    simp_all [trajectory, trajectory_eq, add_assoc]\n    <;>\n    ring_nf at *\n    <;>\n    field_simp [h] at *\n    <;>\n    norm_num at *\n    <;>\n    simp_all [Real.norm_eq_abs, abs_mul, abs_of_nonneg, abs_of_nonpos, le_of_lt]\n    <;>\n    linarith\n  })\n  <;>\n  (try {\n    simp_all [norm_eq_abs]\n    <;>\n    ring_nf at *\n    <;>\n    field_simp [h] at *\n    <;>\n    norm_num at *\n    <;>\n    linarith\n  })",
