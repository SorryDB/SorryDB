      "\n  have h₀ : IC.trajectory S = fun t => cos (S.ω * t) • IC.x₀ + (sin (S.ω * t) / S.ω) • IC.v₀ := by\n    funext t\n    rfl\n  have h₁ : ∂ₜ (IC.trajectory S) = fun t => -S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀ := by\n    rfl\n  have h₂ : (S : HarmonicOscillator) = S := rfl\n  rw [h₀] at *\n  rw [h₁] at *\n  simp [h₂, trajectory, Time.deriv, fderiv_fun_add, fderiv_smul_const, fderiv_const,\n    fderiv_id, Pi.one_apply, Pi.add_apply, Pi.smul_apply] at *\n  <;>\n  (try simp_all) <;>\n  (try norm_num) <;>\n  (try ring_nf) <;>\n  (try field_simp) <;>\n  (try simp_all [Real.cos_eq_zero_iff, Real.sin_eq_zero_iff]) <;>\n  (try norm_num) <;>\n  (try nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]) <;>\n  (try\n    {\n      cases hx with\n      | inl hx =>\n        simp_all [hx]\n        <;> norm_num <;>\n        (try\n          {\n            field_simp at *\n            <;> ring_nf at *\n            <;> norm_num at *\n            <;>\n              (try\n                {\n                  simp_all [Real.cos_sq_add_sin_sq]\n                  <;> nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]\n                })\n          })\n      | inr hx =>\n        simp_all [hx]\n        <;> norm_num <;>\n        (try\n          {\n            field_simp at *\n            <;> ring_nf at *\n            <;> norm_num at *\n            <;>\n              (try\n                {\n                  simp_all [Real.cos_sq_add_sin_sq]\n                  <;> nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]\n                })\n          })\n    }) <;>\n  (try\n    {\n      simp_all [Real.cos_sq_add_sin_sq]\n      <;> ring_nf at *\n      <;> field_simp at *\n      <;> norm_num at *\n      <;>\n        (try\n          {\n            nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]\n          })\n    }) <;>\n  (try\n    {\n      cases hx with\n      | inl hx =>\n        simp_all [hx]\n        <;> norm_num <;>\n        (try\n          {\n            field_simp at *\n   