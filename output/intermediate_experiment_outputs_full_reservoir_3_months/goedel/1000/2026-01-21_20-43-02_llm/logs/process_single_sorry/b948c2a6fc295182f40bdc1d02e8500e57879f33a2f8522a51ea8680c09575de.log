lemma identityWalkMap (s : Equiv.Perm (Fin n)) (p : (K n).LoopWalk u v) (hs : s = Equiv.refl (Fin n))
    (he : ∀u: (Fin n), s u = u):
  p.map K (permMap' n s) = p := by
  have h₁ : s = Equiv.refl (Fin n) := hs
  have h₂ : ∀ u : Fin n, s u = u := by simpa [h₁] using he
  have h₃ : p.map K (permMap' n s) = p := by
    apply Eq.symm
    apply Eq.symm
    have h₄ : p.map K (permMap' n s) = p := by
      simp_all [Equiv.refl_apply, permMap', permMap, LoopWalk.map]
      <;>
      (try decide) <;>
      (try simp_all [Equiv.refl_apply]) <;>
      (try aesop) <;>
      (try rfl) <;>
      (try simp_all [Equiv.refl_apply]) <;>
      (try aesop) <;>
      (try rfl)
    exact h₄
  exact h₃

