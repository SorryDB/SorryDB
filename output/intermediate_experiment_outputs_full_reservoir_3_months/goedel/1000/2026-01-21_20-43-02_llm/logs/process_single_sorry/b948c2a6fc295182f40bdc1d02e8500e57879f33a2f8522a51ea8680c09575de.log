def LoopWalkEquiv (p q : ClosedLoopWalk (K n)): Prop :=
  ∃ (s : Equiv.Perm (Fin n)), ∃ (h_eq : s p.1 = q.1),
    h_eq ▸ (permMapWalk n s p.2) = q.2


def LoopWalkSetoid : Setoid (ClosedLoopWalk (K n)) where
  r := LoopWalkEquiv n
  iseqv := by
    constructor
    · intro x
      let s := Equiv.refl (Fin n)
      unfold LoopWalkEquiv
      use s
      have hs : ∀ (y : Fin n), s y = y := by
        intro y
        rfl
      have h₁ : s (x.1 : Fin n) = (x.1 : Fin n) := hs (x.1)
      have h₂ : (x.1 : Fin n) ▸ (permMapWalk n s x.2) = x.2 := by
        simp [h₁, permMapWalk, hs, x.1]
        <;>
        (try decide) <;>
        (try simp_all [K, completeGraph, SimpleGraph.LoopWalk.map, Equiv.refl_apply, Fin.ext_iff]) <;>
        (try aesop) <;>
        (try simp_all [Fin.ext_iff]) <;>
        (try aesop)
      simp_all [h₁, h₂]
      <;>
      aesop
    · intro p q
      unfold LoopWalkEquiv
      aesop
    · intro p q r
      unfold LoopWalkEquiv
      aesop
```
