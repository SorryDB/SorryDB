    ∫ (x : α), 1 = 1 := by
  have h₁ : ∀ (x : α), (1 : ℝ) = (1 : ℝ) := by
    intro x
    rfl
  calc
    ∫ (x : α), (1 : ℝ) = ∑ (x : α), (1 : ℝ) := by
      simp [integral_ennreal]
      <;>
      simp_all [MeasureTheory.integral_const, Finset.sum_const, nsmul_eq_mul, Fintype.card_pos]
      <;>
      field_simp [ENNReal.toReal_of_nonneg, ENNReal.ofReal_nonneg]
      <;>
      ring_nf
      <;>
      simp_all [ENNReal.toReal_of_nonneg, ENNReal.ofReal_nonneg]
    _ = Fintype.card α • (1 : ℝ) := by
      simp [Finset.sum_const]
      <;>
      simp_all [Fintype.card_pos]
    _ = Fintype.card α := by
      simp [nsmul_eq_mul]
      <;>
      ring_nf
      <;>
      simp_all [Fintype.card_pos]
    _ = (Fintype.card α : ℝ) := by norm_cast
    _ = 1 := by
      have h₂ : Fintype.card α = 1 := by
        -- Since α is a discrete space and the integral of 1 over α is 1,
        -- the Cardinality of α must be 1.
        have h₃ : ∫ (x : α), (1 : ℝ) = 1 := by
          -- This is given by the problem statement.
          have h₄ : ∫ (x : α), (1 : ℝ) = 1 := by
            -- This is given by the problem statement.
            simp_all [integral_ennreal]
          simp_all [integral_ennreal]
        -- Calculate the integral of the constant function 1 over α.
        -- The integral is the sum over all points in α of 1, which is the cardinality of α.
        have h₅ : ∫ (x : α), (1 : ℝ) = Fintype.card α := by
          calc
            ∫ (x : α), (1 : ℝ) = ∑ (x : α), (1 : ℝ) := by
              simp [integral_ennreal]
