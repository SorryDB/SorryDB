namespace Circomlib
variable {p : ℕ} [Fact p.Prime] [Fact (p > 2)]

namespace RotR

def main (n r : ℕ) [NeZero n] (inp : Vector (Expression (F p)) n) := do
  let out <== Vector.mapFinRange n fun i => inp.get (i + Fin.ofNat n r)
  return out

def circuit (n r : ℕ) [NeZero n] : FormalCircuit (F p) (fields n) (fields n) where
  main := main n r

  localLength _ := n

  Spec input output := output = input.rotate r

  soundness := by
    intro input output h_spec
    simp_all [Vector.mapFinRange, Vector.mapRange, Fin.castSucc]
    <;>
    (try decide) <;>
    (try ring_nf) <;>
    (try simp_all [Fin.ext_iff, Fin.val_add, Fin.val_ofNat]) <;>
    (try omega) <;>
    (try aesop)
  
  completeness := by
    intro input_var output_var h_spec env
    simp_all [Vector.mapFinRange, Vector.mapRange, Fin.castSucc]
    <;>
    (try decide) <;>
    (try ring_nf) <;>
    (try simp_all [Fin.ext_iff, Fin.val_add, Fin.val_ofNat]) <;>
    (try omega) <;>
    (try aesop)
