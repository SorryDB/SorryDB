      "\n  have h₁ : (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨ (∃ a ∈ Finset.Icc n (2 * n) \\ S, ∃ b ∈ Finset.Icc n (2 * n) \\ S, a ≠ b ∧ IsSquare (a + b)) := by\n    by_cases h₂ : ∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)\n    · exact Or.inl h₂\n    · -- We need to show that if no two distinct elements in S sum to a perfect square, then there exist two distinct elements in (Finset.Icc n (2 * n)) \\ S that sum to a perfect square.\n      have h₃ : (∃ a ∈ Finset.Icc n (2 * n) \\ S, ∃ b ∈ Finset.Icc n (2 * n) \\ S, a ≠ b ∧ IsSquare (a + b)) := by\n        -- We use the fact that there are enough numbers in the interval [n, 2n] to find two distinct elements not in S that sum to a perfect square.\n        have h₄ : ∀ a ∈ S, ∀ b ∈ S, a ≠ b → ¬IsSquare (a + b) := by\n          intro a ha b hb hab\n          by_contra h\n          have h₅ : ∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b) := ⟨a, ha, b, hb, hab, h⟩\n          contradiction\n        -- We now find two distinct elements not in S that sum to a perfect square.\n        -- For simplicity, we can consider specific pairs, such as (n, n + 1), etc.\n        -- However, we need to ensure they are not in S.\n        -- A better approach is to find two distinct squares in the interval [2n, 4n]\n        -- and then find pairs summing to these squares.\n        -- For n ≥ 100, we can find two distinct squares in [2n, 4n].\n        -- For example, (k+1)^2 and (k+2)^2 for k such that (k+1)^2 ≤ 4n and (k+2)^2 ≤ 4n.\n        -- Here, we will use a simpler approach by checking (n and n + 1) are not in S and their sum is not a square.\n        -- Actually, for n ≥ 100, n and n + 1 sum to 2n + 1, which is not a square.\n        -- Alternatively, we can find a square s in [2n, 4n], say s = (k)^2, and check if there are two distinct elements not in S summing to s.\n        -- A more concrete approach is to find two distinct non-squares in [n, 2n] that are not in S, but their sum is a square.\n        -- This is non-trivial, so we