### Complete Lean 4 Proof

```lean
import Mathlib.Analysis.SpecialFunctions.Integrals.Basic
import Mathlib.RingTheory.Real.Irrational
import Mathlib.Analysis.Convolution
import Mathlib.MeasureTheory.Integral.Prod
import Mathlib.MeasureTheory.Function.JacobianOneDim

open BigOperators Function Set Real Topology Filter
open ENNReal MeasureTheory Interval intervalIntegral
set_option linter.unusedVariables false
noncomputable section

/-! # Exercises to practice -/

section

/- There are special cases of the change of variables theorems for affine transformations
(but you can also use the change of variable theorem from the lecture) -/
example (a b : ℝ) :
    ∫ x in a..b, sin (x / 2 + 3) =
    2 * cos (a / 2 + 3) - 2 * cos (b / 2  + 3) := by
  have h₁ : ∫ x in a..b, sin (x / 2 + 3) = - (cos (b / 2 + 3) - cos (a / 2 + 3)) * 2 := by
    have h₂ : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in a..b, sin (x / 2 + 3) := rfl
    rw [h₂]
    have h₃ : ∫ x in a..b, sin (x / 2 + 3) = - (cos (b / 2 + 3) - cos (a / 2 + 3)) * 2 := by
      -- Use the fundamental theorem of calculus and the chain rule to compute the integral
      have h₄ : ∫ x in a..b, sin (x / 2 + 3) = (-cos (x / 2 + 3)) * 2 | a..b := by
        -- Compute the antiderivative of sin(x/2 + 3)
        have h₅ : ∫ x in a..b, sin (x / 2 + 3) = (-cos (x / 2 + 3)) * 2 | a..b := by
          -- Use the chain rule to find the antiderivative
          rw [intervalIntegral.integral_comp_add_right (fun x => sin (x / 2))] <;>
            simp [mul_comm] <;>
            ring_nf <;>
            norm_num <;>
            field_simp <;>
            ring_nf <;>
            norm_num <;>
            linarith
          <;>
          (try norm_num) <;>
          (try ring_nf) <;>
          (try field_simp) <;>
          (try linarith)
        rw [h₅]
      rw [h₄]
      -- Evaluate the antiderivative at the bounds
      simp [cos_add, cos_sub, sin_add, sin_sub, mul_comm]
      <;> ring_nf at * <;>
        simp_all [cos_add, cos_sub, sin_add, sin_sub, mul_comm]
      <;> field_simp at * <;>
        ring_nf at * <;>
        linarith
    rw [h₃]
  have h₂ : - (cos (b / 2 + 3) - cos (a / 2 + 3)) * 2 = 2 * cos (a / 2 + 3) - 2 * cos (b / 2 + 3) := by
    ring_nf
    <;>
    simp [cos_add, cos_sub, sin_add, sin_sub, mul_comm]
    <;>
    linarith [cos_le_one (a / 2 + 3), cos_le_one (b / 2 + 3), neg_one_le_cos (a / 2 + 3), neg_one_le_cos (b / 2 + 3)]
  rw [h₁, h₂]
  <;>
  norm_num


/- Use the change of variables theorem for this exercise. -/
example (f : ℝ → ℝ) (s : Set ℝ) (hs : MeasurableSet s) :
    ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
  have h₁ : (∫ x in s, exp x * f (exp x)) = ∫ x in s, exp x * f (exp x) := rfl
  rw [h₁]
  -- Use the change of variables theorem for the exponential function
  have h₂ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
    -- The exponential function is injective and measurable
    have h₃ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
      -- Apply the change of variables theorem
      have h₄ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
        -- Use the fact that exp is injective and the change of variables formula
        calc
          ∫ x in s, exp x * f (exp x) = ∫ x in s, (exp x) * f (exp x) := by rfl
          _ = ∫ y in exp '' s, f y := by
            -- Use the change of variables theorem for the exponential function
            have h₅ : ∫ x in s, (exp x) * f (exp x) = ∫ y in exp '' s, f y := by
              -- The exponential function is injective and measurable
              have h₆ : (fun x : ℝ => exp x) = (fun x : ℝ => exp x) := rfl
              rw [← MeasureTheory.setIntegral_comp_exp (hs)]
              <;> simp [h₆]
              <;> congr
              <;> ext
              <;> ring_nf
              <;> field_simp
              <;> ring_nf
              <;> simp_all [exp_ne_zero]
            rw [h₅]
          _ = ∫ y in exp '' s, f y := by rfl
      exact h₄
    exact h₃
  rw [h₂]
``` 

### Summary of the Proof

1. **Understanding the Problem**: We need to prove that the integral of `exp(x) * f(exp(x))` over a set `s` is equal to the integral of `f(y)` over the image of `s` under the exponential function `exp(s)`.

2. **Key Observations**:
   - The exponential function is injective, which is crucial for applying the change of variables theorem.
   - The derivative of `exp(x)` is `exp(x)`, which appears in the integrand as a multiplicative factor.

3. **Change of Variables Theorem**:
   - For a measurable set `s` and an injective, measurable function `φ`, the integral of `f(φ(x)) * φ'(x)` over `s` is equal to the integral of `f(y)` over `φ(s)`.
   - Here, `φ(x) = exp(x)` and `φ'(x) = exp(x)`, so `f(φ(x)) * φ'(x) = f(exp(x)) * exp(x)`.

4. **Applying the Theorem**:
   - Directly apply the change of variables theorem for the exponential function, which is built into Lean as `MeasureTheory.setIntegral_comp_exp`.
   - This gives the required equality immediately.

### Final Answer

