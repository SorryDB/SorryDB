  have h₁ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
    -- Use the change of variables theorem with the exponential function
    have h₂ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
      -- Apply the change_of_vars_exp lemma from the library
      rw [← Integral.comp_exp (measurableSet_exp '' hs)]
      -- Simplify the expression using the properties of the exponential function
      <;> simp [Real.log_exp]
      <;> congr 1 <;> ext <;> simp [Real.exp_log]
      <;> aesop
    -- The result follows directly from the change of variables theorem
    exact h₂
  -- The final result is obtained by combining the above steps
  exact h₁
