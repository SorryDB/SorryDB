/-! # Exercises to practice -/

section

/- There are special cases of the change of variables theorems for affine transformations
(but you can also use the change of variable theorem from the lecture) -/
example (a b : ℝ) :
    ∫ x in a..b, sin (x / 2 + 3) =
    2 * cos (a / 2 + 3) - 2 * cos (b / 2  + 3) := by
  have h₀ : ∫ x in a..b, sin (x / 2 + 3) = 2 * cos (a / 2 + 3) - 2 * cos (b / 2 + 3) := by
    have h₁ : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in a..b, sin (x / 2 + 3) := rfl
    rw [h₁]
    -- Use the fundamental theorem of calculus to evaluate the integral
    have h₂ : ∫ x in a..b, sin (x / 2 + 3) = (2 * cos (b / 2 + 3) - 2 * cos (a / 2 + 3)) := by
      -- Compute the antiderivative of sin(x/2 + 3)
      have h₃ : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in a..b, sin (x / 2 + 3) := rfl
      rw [h₃]
      -- Use substitution to find the antiderivative
      have h₄ : (∫ x in a..b, sin (x / 2 + 3)) = (2 * cos (b / 2 + 3) - 2 * cos (a / 2 + 3)) := by
        -- Use the fundamental theorem of calculus
        rw [intervalIntegral.integral_comp_add_right (fun x => sin (x / 2))]
        <;> norm_num <;>
        (try
          {
            simp [cos_add, sin_add, mul_comm]
            <;> ring_nf
            <;> field_simp
            <;> ring_nf
          }) <;>
        (try
          {
            norm_num at *
            <;>
            (try
              {
                linarith
              })
            <;>
            (try
              {
                simp_all [cos_add, sin_add, mul_comm]
                <;> ring_nf
                <;> field_simp
                <;> linarith
              })
          }) <;>
        (try
          {
            simp_all [cos_add, sin_add, mul_comm]
            <;> ring_nf
            <;> field_simp
            <;> linarith
          })
        <;>
        (try
          {
            norm_num
          })
        <;>
        (try
          {
            linarith
          })
      rw [h₄]
    rw [h₂]
    <;> ring_nf
  have h₁ : ∫ x in a..b, sin (x / 2 + 3) = 2 * cos (a / 2 + 3) - 2 * cos (b / 2 + 3) := by
    linarith
  linarith

