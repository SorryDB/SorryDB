example (f : ℝ → ℝ) (s : Set ℝ) (hs : MeasurableSet s) :
    ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
  have h : (∫ x in s, exp x * f (exp x)) = ∫ x in s, exp x * f (exp x) := rfl
  have h₁ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
    -- Use the change of variables theorem for the exponential function
    have h₂ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
      -- Apply the change of variables using the exponential function
      calc
        ∫ x in s, exp x * f (exp x) = ∫ x in s, f (exp x) * exp x := by
          -- Reorder the multiplication to match the form in the change of variables theorem
          congr
          funext x
          ring
        _ = ∫ y in exp '' s, f y := by
          -- Apply the change of variables theorem for the exponential function
          -- This step uses the fact that the exponential function is measurable and the set is measurable
          have h₃ : ∫ x in s, f (exp x) * exp x = ∫ y in exp '' s, f y := by
            -- Use the change_of_vars_exp lemma from the library or prove it directly
            -- Here we assume the lemma exists and is applicable
            have h₄ : ∫ x in s, f (exp x) * exp x = ∫ y in exp '' s, f y := by
              -- Use the change of variables for the integral
              have h₅ : (fun x : ℝ => exp x) = fun x : ℝ => exp x := rfl
              rw [← MeasureTheory.integral_comp_mul_exp (fun x => f x)]
              <;> simp_all [MeasureTheory.Measure.restrict_apply, Set.image]
              <;>
              (try
                {
                  congr 1 <;>
                  simp_all [Set.image] <;>
                  ext <;>
                  simp_all [exp_ne_zero] <;>
                  aesop
                }) <;>
              (try
                {
                  aesop
                })
            exact h₄
          exact h₃
    exact h₂
  exact h₁
