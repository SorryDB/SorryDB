example (a b : ℝ) :
    ∫ x in a..b, sin (x / 2 + 3) =
    2 * cos (a / 2 + 3) - 2 * cos (b / 2  + 3) := by
  have h₀ : ∫ x in a..b, sin (x / 2 + 3) = 2 * (cos (a / 2 + 3) - cos (b / 2 + 3)) := by
    have h₁ : ∫ x in a..b, sin (x / 2 + 3) = 2 * (cos (a / 2 + 3) - cos (b / 2 + 3)) := by
      -- Use the fundamental theorem of calculus to compute the integral
      have h₂ : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in (a : ℝ)..(b : ℝ), sin (x / 2 + 3) := rfl
      rw [h₂]
      -- Use the substitution u = x/2 + 3 to simplify the integral
      have h₃ : ∫ x in (a : ℝ)..(b : ℝ), sin (x / 2 + 3) = 2 * (cos (a / 2 + 3) - cos (b / 2 + 3)) := by
        -- Compute the antiderivative
        have h₄ : (∫ x in (a : ℝ)..(b : ℝ), sin (x / 2 + 3)) = 2 * (cos (a / 2 + 3) - cos (b / 2 + 3)) := by
          -- Use the antiderivative of sin(x/2 + 3)
          rw [intervalIntegral.integral_comp_add_right (fun x => sin (x / 2))]
          <;> simp [cos_add, sin_add, mul_comm]
          <;> ring_nf
          <;> field_simp
          <;> ring_nf
          <;> norm_num
          <;> linarith
        rw [h₄]
      rw [h₃]
    rw [h₁]
  rw [h₀]
  <;> ring_nf
  <;> linarith

