def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    have h : f 1 = 1 := by
      -- Prove that f(1) = 1 using the property of ring homomorphisms
      exact f.map_one
    -- Substitute f(1) = 1 into g(f(1)) to get g(1)
    have h₂ : g (f 1) = g 1 := by rw [h]
    -- Since g is a ring homomorphism, g(1) = 1
    have h₃ : g 1 = 1 := by
      exact g.map_one
    -- Combine the above to get g(f(1)) = 1
    calc
      g (f 1) = g 1 := by rw [h₂]
      _ = 1 := by rw [h₃]
