example : Memℓp GEO 2025 := by
  have h₁ : p ∑' (n : ℕ), ‖(GEO : ℕ → ℝ) n‖ ^ 2025 < ∞ := by
    have h₂ : ∑' (n : ℕ), ‖(GEO : ℕ → ℝ) n‖ ^ 2025 = ∑' (n : ℕ), ((1 / (n : ℝ)) : ℝ) ^ 2025 := by
      simp [GEO, norm_eq_abs, abs_div, abs_of_nonneg, Nat.cast_nonneg, abs_of_nonneg,
        show (0 : ℝ) ≤ 1 by norm_num]
      <;>
      simp_all [div_eq_mul_inv]
      <;>
      congr
      <;>
      ext n
      <;>
      ring_nf
      <;>
      field_simp
      <;>
      ring_nf
      <;>
      simp_all [abs_of_nonneg]
      <;>
      norm_num
      <;>
      linarith
    rw [h₂]
    -- We need to show that the sum of (1 / n)^2025 is finite.
    -- This is true because the p-series ∑ (1 / n^p) converges for p > 1.
    -- Here, p = 2025 > 1, so the sum is finite.
    have h₃ : Summable fun n : ℕ => ((1 / (n : ℝ)) : ℝ) ^ 2025 := by
      -- Use the fact that the series ∑ (1 / n^p) converges for p > 1.
      have h₄ : Summable fun n : ℕ => (1 : ℝ) / (n : ℝ) ^ 2025 := by
        -- Use the integral test or p-series test to show convergence.
        -- For simplicity, we use the fact that p = 2025 > 1.
        norm_num [summable_nat_add_iff]
        <;>
        simpa [div_eq_mul_inv] using
          Summable.comp_injective (summable_nat_add_iff 1).mpr (summable_one_div_pow_of_le 2025 (by norm_num))
            (fun _ _ h => by simpa using h)
      -- Since (1 / n)^2025 = 1 / n^2025, the series converges.
      have h₅ : (fun n : ℕ => ((1 / (n : ℝ)) : ℝ) ^ 2025) = (fun n : ℕ => (1 : ℝ) / (n : ℝ) ^ 2025) := by
        funext n
        cases n with
        | zero => norm_num
        | succ n =>
          field_simp [Nat.cast_add_one_ne_zero]
          <;>
          ring_nf
          <;>
          simp [pow_ne_zero]
          <;>
          norm_num
          <;>
          field_simp [Nat.cast_add_one_ne_zero]
          <;>
          ring_nf
          <;>
          simp [pow_ne_zero]
          <;>
          norm_num
      rw [h₅]
      exact h₄
    -- Since the series is summable, its sum is finite.
    have h₆ : ∑' (n : ℕ), ((1 / (n : ℝ)) : ℝ) ^ 2025 < ∞ := by
      have h₇ : Summable fun n : ℕ => ((1 / (n : ℝ)) : ℝ) ^ 2025 := h₃
      exact (h₇.tsum_lt_top : ∑' (n : ℕ), ((1 / (n : ℝ)) : ℝ) ^ 2025 < ∞)
    -- Since the sum is finite, the p-norm is finite.
    simpa [tsum_eq_zero_add] using h₆
  -- Use the fact that the sum is finite to conclude that the vector is in ℓ^{2025}.
  simpa [p] using h₁
