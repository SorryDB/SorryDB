section Lp

open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := fun s => if (Real.pi : ℝ) ∈ s then 1 else 0
  empty := by
    simp
    <;>
    norm_num
    <;>
    simp_all
    <;>
    norm_num
  
  mono {S T} hST := by
    by_cases h : Real.pi ∈ T
    · -- Case: π ∈ T
      have h₁ : Real.pi ∈ S := by
        -- Since S ⊆ T and π ∈ T, π ∈ S
        have h₂ : Real.pi ∈ T := h
        have h₃ : S ⊆ T := hST
        exact h₃ h₂
      -- Since π ∈ S, μD(S) = 1
      simp_all [μD]
      <;> norm_num
      <;> aesop
    · -- Case: π ∉ T
      have h₁ : Real.pi ∉ S := by
        -- Since S ⊆ T and π ∉ T, π ∉ S
        intro h₂
        have h₃ : S ⊆ T := hST
        have h₄ : Real.pi ∈ T := h₃ h₂
        contradiction
      -- Since π ∉ S and π ∉ T, μD(S) = 0 and μD(T) = 0
      simp_all [μD]
      <;> norm_num
      <;> aesop
  
  iUnion_nat := by
    intro s
    by_cases h : Real.pi ∈ ⋃ (n : ℕ), s n
    · -- Case: π is in the union of sets s n
      have h₁ : ∃ (n : ℕ), Real.pi ∈ s n := by
        -- Since π is in the union, there exists an n such that π is in s n
        simpa using h
      obtain ⟨n, hn⟩ := h₁
      -- We have found an n such that π is in s n
      have h₂ : (1 : ℝ≥0∞) ≤ ∑' (n : ℕ), (if Real.pi ∈ s n then 1 else 0 : ℝ≥0∞) := by
        -- The sum of the measures of s n is at least 1 because π is in s n for some n
        have h₃ : (if Real.pi ∈ s n then 1 else 0 : ℝ≥0∞) = 1 := by
          simp [hn]
        have h₄ : (∑' (n : ℕ), (if Real.pi ∈ s n then 1 else 0 : ℝ≥0∞)) ≥ (if Real.pi ∈ s n then 1 else 0 : ℝ≥0∞) := by
          -- The sum is at least the term for n
          exact le_tsum (by
            -- The series is non-negative
            intro i
            by_cases h₅ : Real.pi ∈ s i <;> simp [h₅] <;> positivity
          ) n (by
            -- The term is non-negative
            by_cases h₅ : Real.pi ∈ s n <;> simp [h₅] <;> positivity
          )
        calc
          (1 : ℝ≥0∞) = (if Real.pi ∈ s n then 1 else 0 : ℝ≥0∞) := by simp [hn]
          _ ≤ ∑' (n : ℕ), (if Real.pi ∈ s n then 1 else 0 : ℝ≥0∞) := h₄
      -- Therefore, the measure of the union is 1 and the sum of the measures is at least 1
      simp_all [μD]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try simp_all [ENNReal.coe_le_coe]) <;>
      (try norm_num) <;>
      (try linarith)
    · -- Case: π is not in the union of sets s n
