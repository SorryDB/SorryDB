lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : Tendsto (t ∘ s) F H := by
    have h2 : (F.map s) ≤ G := hs
    have h3 : (G.map t) ≤ H := ht
    have h4 : (F.map (t ∘ s)) ≤ (G.map t) := by
      -- Show that F.map (t ∘ s) ≤ G.map t using the monotonicity of the map operation
      have h5 : F.map (t ∘ s) = (F.map s).map t := by
        ext U
        simp [Filter.mem_map, Function.comp]
        <;>
        (try
          {
            aesop
          })
        <;>
        (try
          {
            tauto
          })
      rw [h5]
      -- Use the fact that F.map s ≤ G and the monotonicity of the map operation
      have h6 : (F.map s).map t ≤ G.map t := Filter.map_mono h2
      exact h6
    -- Combine the inequalities to get the final result
    have h7 : (F.map (t ∘ s)) ≤ H := le_trans h4 h3
    exact h7
  exact h1
```

