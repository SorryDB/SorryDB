    have h₁ : Tendsto (g ∘ f) (𝓝 0) atTop := by
      -- Use the fact that the composition of tendsto functions is tendsto
      have h₂ : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
      have h₃ : Tendsto g (𝓝 Real.pi) atTop := hg
      -- Use the composition of tendsto lemmas
