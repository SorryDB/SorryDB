theorem no_x_in_3_two_power : ∀ (n : ℕ), (1 : ℕ) ≤ n → ∃ (x : ℕ), x ∈ (2 ^ n) ∧ x % 3 ≠ 0 := by
  intro n hn
  have h : (2 ^ n) % 3 = 1 ∨ (2 ^ n) % 3 = 2 := by
    have h₁ : ∀ (n : ℕ), (2 ^ n) % 3 = 1 ∨ (2 ^ n) % 3 = 2 := by
      intro n
      induction n with
      | zero => simp
      | succ n ih =>
        cases ih with
        | inl h =>
          simp [pow_succ, h, Nat.mul_mod, Nat.pow_mod]
          <;> norm_num <;> omega
        | inr h =>
          simp [pow_succ, h, Nat.mul_mod, Nat.pow_mod]
          <;> norm_num <;> omega
    exact h₁ n
  cases h with
  | inl h =>
    have h₂ : (2 ^ n) % 3 = 1 := h
    use 2 ^ n - 1
    have h₃ : 2 ^ n - 1 < 2 ^ n := by
      have h₄ : 1 < 2 ^ n := by
        have h₅ : 1 < 2 ^ n := by
          apply Nat.one_lt_pow
          <;> omega
        exact h₅
      omega
    have h₄ : 2 ^ n - 1 ∈ (2 ^ n) := by
      simp [Nat.lt_succ_iff]
      <;> omega
    have h₅ : (2 ^ n - 1) % 3 ≠ 0 := by
      have h₆ : (2 ^ n) % 3 = 1 := h₂
      have h₇ : (2 ^ n - 1) % 3 = 0 := by
        omega
      omega
    exact ⟨h₄, h₅⟩
  | inr h =>
    have h₂ : (2 ^ n) % 3 = 2 := h
    use 2 ^ n - 2
    have h₃ : 2 ^ n - 2 < 2 ^ n := by
      have h₄ : 2 < 2 ^ n := by
        have h₅ : 2 < 2 ^ n := by
          have h₆ : n ≥ 1 := hn
          have h₇ : 2 ^ n ≥ 2 ^ 1 := by
            apply Nat.pow_le_pow_of_le_right
            norm_num
            omega
          have h₈ : 2 ^ 1 = 2 := by norm_num
          omega
        exact h₅
      omega
    have h₄ : 2 ^ n - 2 ∈ (2 ^ n) := by
      simp [Nat.lt_succ_iff]
      <;> omega
    have h₅ : (2 ^ n - 2) % 3 ≠ 0 := by
      have h₆ : (2 ^ n) % 3 = 2 := h₂
      have h₇ : (2 ^ n - 2) % 3 = 0 := by
        omega
