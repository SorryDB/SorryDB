/-!

# A electrostatics in a 1d vacuum

In this module we study the electrostatics in 1d with the presence of no charges.

The aim of this module is to show that, in 1-dimension, if an electric field satifies
Gauss's law for the vacuum, then it must be the constant electric field.

-/

namespace Electromagnetism
open Distribution SchwartzMap

namespace OneDimVacuum
open Space StaticElectricField MeasureTheory
noncomputable section

/-- The zero charge distribution in 1d space. -/
def chargeDistribution : ChargeDistribution 1 := 0

/-- An electric field obey's Gauss's law for the vacuum in 1 dimension if and only if
  it is the constant electric field. -/
lemma gaussLaw_iff (q ε : ℝ) (E : StaticElectricField 1) :
    E.GaussLaw ε (chargeDistribution) ↔ ∃ m, E = constD 1 m := by
  have h₁ : E.GaussLaw ε chargeDistribution ↔ ∃ m, E = constD 1 m := by
    have h₂ : E.GaussLaw ε chargeDistribution ↔ ∀ (f : directionalTestFunction 1),
      (∑ d : Fin 1, (coefficient ∘ E) d f) = 0 := by
      simp [GaussLaw, chargeDistribution, zero_apply]
      <;>
      (try ring_nf) <;>
      (try simp_all [coefficient]) <;>
      (try aesop)
      <;>
      (try simp_all [FiniteDimensional.fin_one])
      <;>
      (try ring_nf) <;>
      (try simp_all [coefficient]) <;>
      (try aesop)
    rw [h₂]
    constructor
    · intro h
      use (E.dcoeff 0)
      ext x
      simp [coefficient, dcoeff_fin_one] at h ⊢
      <;>
      (try simp_all [DirectionalTestFunction, Fin.sum_univ_succ, Function.comp_apply]) <;>
      (try ring_nf at h ⊢) <;>
      (try simp_all [directionalTestFunction_1D]) <;>
      (try norm_num) <;>
      (try linarith)
      <;>
      (try {
        have h₃ := h directionalTestFunction_1D
        simp at h₃ ⊢
        <;>
        (try linarith)
        <;>
        (try {
          have h₄ := congr_arg (fun x => x - x) h₃
          simp at h₄ ⊢
          <;>
          (try linarith)
        })
      })
    · intro h
      rcases h with ⟨m, rfl⟩
      intro f
      simp [coefficient, Fin.sum_univ_succ, constD]
      <;>
      (try ring_nf) <;>
      (try simp_all [directionalTestFunction_1D]) <;>
      (try norm_num) <;>
      (try linarith)
  exact h₁
