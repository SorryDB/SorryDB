import PhysLean.Electromagnetism.Electrostatics.Basic
import PhysLean.Mathematics.Distribution.PowMul
/-!

# A electrostatics in a 1d vacuum

In this module we study the electrostatics in 1d with the presence of no charges.

The aim of this module is to show that, in 1-dimension, if an electric field satifies
Gauss's law for the vacuum, then it must be the constant electric field.

-/

namespace Electromagnetism
open Distribution SchwartzMap

namespace OneDimVacuum
open Space StaticElectricField MeasureTheory
noncomputable section

/-- The zero charge distribution in 1d space. -/
def chargeDistribution : ChargeDistribution 1 := 0

/-- An electric field obey's Gauss's law for the vacuum in 1 dimension if and only if
  it is the constant electric field. -/
@[simp]
lemma gaussLaw_iff (q ε : ℝ) (E : StaticElectricField 1) :
    E.GaussLaw ε (chargeDistribution) ↔ ∃ m, E = constD 1 m := by
  constructor
  · -- Prove the forward direction: if E.GaussLaw ε chargeDistribution, then E is constant.
    intro h
    have h₁ : ∃ (m : ℝ), E = constD 1 m := by
      -- Since there are no charges, the electric field must be constant.
      -- We can find the constant by evaluating E at any point.
      use E 0
      have h₂ : ∀ (x : ℝ), E x = E 0 := by
        intro x
        have h₃ := h
        -- Use the fact that the derivative of E is zero to deduce that E is constant.
        have h₄ : E = constD 1 (E 0) := by
          apply Classical.by_contradiction
          intro h₅
          -- If E is not constant, then its derivative is not zero, which contradicts Gauss's law.
          have h₆ := h
          simp_all [GaussLaw, chargeDistribution, Distribution.ext_iff, div_eq_mul_inv]
          <;>
          (try norm_num) <;>
          (try contradiction) <;>
          (try
            {
              have h₇ := h₆ (fun x => 1)
              have h₈ := h₆ (fun x => x)
              norm_num at h₇ h₈ ⊢
              <;>
              (try simp_all [Deriv, mul_comm]) <;>
              (try linarith)
            }) <;>
          (try
            {
              have h₇ := h₆ (fun x => x ^ 2)
              have h₈ := h₆ (fun x => x ^ 3)
              norm_num at h₇ h₈ ⊢
              <;>
              (try simp_all [Deriv, mul_comm]) <;>
              (try linarith)
            }) <;>
          (try
            {
              have h₇ := h₆ (fun x => Real.exp x)
              have h₈ := h₆ (fun x => Real.exp (-x))
              norm_num at h₇ h₈ ⊢
              <;>
              (try simp_all [Deriv, mul_comm]) <;>
              (try linarith)
            })
          <;>
          (try
            {
              norm_num at *
              <;>
              simp_all [Deriv, mul_comm]
              <;>
              linarith
            })
        -- Since E is constant, E x = E 0.
        have h₅ := congr_fun h₄ x
        simp at h₅ ⊢
        <;>
        linarith
      -- Therefore, E is the constant function with value E 0.
      funext x
      apply h₂
    exact h₁
  · -- Prove the reverse direction: if E is constant, then E.GaussLaw ε chargeDistribution.
    intro h
    -- If E is constant, then its derivative is zero, and Gauss's law is satisfied.
    have h₁ : E.GaussLaw ε (chargeDistribution) := by
      obtain ⟨m, rfl⟩ := h
      simp [GaussLaw, chargeDistribution, div_eq_mul_inv, mul_assoc]
      <;>
      (try norm_num) <;>
      (try ring_nf) <;>
      (try field_simp) <;>
      (try simp_all [Deriv, mul_comm]) <;>
      (try norm_num) <;>
      (try linarith)
      <;>
      (try
        {
          intro f
          simp [Deriv, mul_comm]
          <;>
          norm_num
          <;>
          linarith
        })
    exact h₁
