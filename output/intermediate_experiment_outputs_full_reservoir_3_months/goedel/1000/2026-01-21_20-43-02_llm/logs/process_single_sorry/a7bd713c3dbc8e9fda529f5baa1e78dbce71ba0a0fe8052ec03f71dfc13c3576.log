  have z2 : HasFDerivAt (rotproj_inner S w) ((fderivInnerCLM ℝ ((rotprojRM (pbar.innerParams.ofLp 1) (pbar.innerParams.ofLp 2) (pbar.innerParams.ofLp 0)) S, w)).comp ((rotprojRM' S).prod 0)) pbar.innerParams := by sorry
  have z3 : (rotproj_inner' pbar S w) = ((fderivInnerCLM ℝ ((rotprojRM (pbar.innerParams.ofLp 1) (pbar.innerParams.ofLp 2) (pbar.innerParams.ofLp 0)) S, w)).comp ((rotprojRM' S).prod 0)) := by exact step
  have z4 : HasFDerivAt (rotproj_inner S w) (rotproj_inner' pbar S w) pbar.innerParams := by
    rw [z3] at *
    exact z2
  exact z4
