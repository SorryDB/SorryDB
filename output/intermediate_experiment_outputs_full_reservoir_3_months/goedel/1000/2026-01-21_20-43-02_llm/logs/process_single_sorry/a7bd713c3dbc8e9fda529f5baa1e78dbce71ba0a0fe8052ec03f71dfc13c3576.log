  <;> ext i j <;> fin_cases i <;> fin_cases j <;> simp [Matrix.mul_apply, Fin.sum_univ_succ, smul_eq_mul]
  <;> ring_nf <;> simp_all [Matrix.mul_apply, Fin.sum_univ_succ, smul_eq_mul]
