instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Hom (F.F d) (G.F e)) where

  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only [F.map_id, G.map_id]
    simp [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≪ f'.2), by
    have h1 : F.homF (f.1 ≫ f'.1) = F.homF f.1 ≫ F.homF f'.1 := by
      rw [F.map_comp]
    have h2 : G.homF (f.2 ≪ f'.2) = G.homF f' .2 ≪ G.homF f.2 := by
      simp [Preorder]
      <;>
      (try simp_all [CE.Hom, F.map_comp, G.map_comp, comp_assoc])
      <;>
      (try aesop)
    simp_all [h1, h2, comp_assoc]
    <;>
    (try simp_all [CE.Hom, F.map_comp, G.map_comp, comp_assoc])
    <;>
    (try aesop)
  ⟩

  id_comp := by
    intro ⟨d, e, f⟩
    simp [id]
    <;>
    (try simp_all [F.map_id, G.map_id])
    <;>
    (try aesop)
  
  comp_id := by
    intro ⟨d, e, f⟩
    simp [id]
    <;>
    (try simp_all [F.map_id, G.map_id])
    <;>
    (try aesop)
  
  assoc := by
    intro ⟨f1, hf1⟩ ⟨f2, hf2⟩ ⟨f3, hf3⟩
    simp [comp] at *
    <;>
    (try simp_all [F.map_comp, G.map_comp, comp_assoc])
    <;>
    (try aesop)
    <;>
    (try simp_all [CE.Hom, F.map_comp, G.map_comp, comp_assoc])
    <;>
    (try aesop)
