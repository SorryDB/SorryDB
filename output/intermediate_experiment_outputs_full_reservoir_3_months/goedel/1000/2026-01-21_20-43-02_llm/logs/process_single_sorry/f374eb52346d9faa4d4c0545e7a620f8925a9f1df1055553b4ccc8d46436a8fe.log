lemma IsBernoulliOn.ae_subset (hX : IsBernoulliOn X u p P) : ∀ᵐ ω ∂P, X ω ⊆ u :=
  (hX.ae_iff (by
    classical
    -- Prove that the set {ω : Ω | X ω ⊆ u} is measurable
    have h : Measurable {ω : Ω | X ω ⊆ u} := by
      -- Use the fact that the set is the preimage of a measurable set under a measurable function
      have h₁ : Measurable (fun ω : Ω => X ω) := hX.measurable
      have h₂ : Measurable (fun s : Set ι => s ⊆ u) := by
        -- Prove that the function s ↦ s ⊆ u is measurable
        have h₃ : Measurable (fun s : Set ι => s ⊆ u) := by
          -- Use the fact that the set {s : Set ι | s ⊆ u} is closed
          have h₄ : Measurable (fun s : Set ι => s ⊆ u) := by
            -- Use the fact that the set {s : Set ι | s ⊆ u} is closed
            classical
            have h₅ : {s : Set ι | s ⊆ u} = ⋂ (i : ι), (fun s : Set ι => s ⊆ u) ⁻¹' {s : Set ι | i ∈ s → i ∈ u} := by
              ext s
              simp [Set.subset_def]
              <;> aesop
            rw [h₅]
            apply Measurable.biInf
            intro i
            apply Measurable.preimage
            -- Prove that the function (fun s : Set ι => s ⊆ u) is measurable
            classical
            exact by
              simp [measurable_const]
              <;>
              aesop
          exact h₄
        exact h₃
      -- Use the fact that the composition of measurable functions is measurable
      have h₃ : Measurable (fun ω : Ω => X ω ⊆ u) := h₁.comp h₂
      -- Use the fact that the set {ω : Ω | X ω ⊆ u} is measurable
      exact h₃.measurableSet
    -- Use the fact that the set {ω : Ω | X ω ⊆ u} is measurable
    exact h
  )).2 bernoulliOn_ae_subset
