lemma IsBernoulliOn.ae_subset (hX : IsBernoulliOn X u p P) : ∀ᵐ ω ∂P, X ω ⊆ u :=
  (hX.ae_iff (by
    have h₁ : Measurable fun x : Set ι => x ⊆ u := by
      -- We need to show that the set of subsets of u is measurable.
      -- This follows from the fact that the complement of the set of subsets of u is the set of subsets not contained in u,
      -- which is the union over all elements a in ι \ u of the sets containing a.
      -- Since ι is countable, we can form this union countably and use the fact that each set is measurable to deduce the complement is measurable.
      have h₂ : Measurable (fun x : Set ι => ¬x ⊆ u : Set ι → Prop) := by
        classical
        -- The complement of the set of subsets of u is the set of subsets not contained in u.
        -- This can be written as the union over all elements a in ι \ u of the sets containing a.
        -- Since ι is countable, we can form this union countably.
        have h₃ : {x : Set ι | ¬x ⊆ u} = ⋃ (a : ι), {x : Set ι | a ∈ x ∧ a ∉ u} := by
          ext x
          simp [Set.ext_iff]
          <;>
          by_cases hx : x ⊆ u <;>
          simp_all [Set.subset_def] <;>
          (try { contradiction }) <;>
          (try {
            push_neg at *
            aesop
          }) <;>
          (try {
            aesop
          })
        rw [h₃]
        -- Each set {x : Set ι | a ∈ x ∧ a ∉ u} is measurable because it is a product of measurable sets.
        -- The countable union of measurable sets is measurable.
        have h₄ : ∀ (a : ι), Measurable ({x : Set ι | a ∈ x ∧ a ∉ u} : Set (Set ι)) := by
          intro a
          have h₅ : Measurable ({x : Set ι | a ∈ x} : Set (Set ι)) := by
            -- The set {x : Set ι | a ∈ x} is measurable because it is a product of measurable sets.
            have h₆ : Measurable fun x : Set ι => a ∈ x := by
              -- The function x ↦ a ∈ x is measurable because it is a product of measurable functions.
              refine' measurable_fst.prod _
              <;>
              simp [measurable_const]
            exact h₆.measurable_set
          have h₇ : Measurable ({x : Set ι | a ∉ u} : Set (Set ι)) := by
            -- The set {x : Set ι | a ∉ u} is measurable because it is either ∅ or univ.
            simp
            <;>
            (try { contradiction }) <;>
            (try { aesop })
          -- The intersection of two measurable sets is measurable.
          have h₈ : Measurable ({x : Set ι | a ∈ x ∧ a ∉ u} : Set (Set ι)) := by
            refine' Measurable.inter h₅ _
