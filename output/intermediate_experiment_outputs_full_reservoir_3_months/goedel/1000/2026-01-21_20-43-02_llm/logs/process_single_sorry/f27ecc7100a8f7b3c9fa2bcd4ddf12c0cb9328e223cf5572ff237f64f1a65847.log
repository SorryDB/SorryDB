```lean
lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  have h_main : F.map f ≤ G.map f := by
    -- Use the fact that the function f preserves the filter order
    exact Filter.map_mono h
  exact h_main

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h_main : Tendsto (t ∘ s) F H := by
    -- Use the property of tendsto for composition of functions
    have h1 : Tendsto (t ∘ s) F H := by
      -- Apply the composition rule for tendsto
      calc
        Tendsto (t ∘ s) F H = Tendsto (t ∘ s) F H := rfl
        _ = Tendsto t (F.map s) H := by
          -- Use the property of map and tendsto
          simp only [Tendsto, Function.comp]
          <;> simp_all [Filter.map]
          <;> aesop
        _ = Tendsto t (G) H := by
          -- Since s tends to G along F, F.map s ≤ G
          have h2 : F.map s ≤ G := hs
          -- Use the fact that if A ≤ B then t tends to H along A implies t tends to H along B
          simpa [Tendsto] using ht.mono_left h2
    exact h1
  exact h_main

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h_main : Tendsto (g ∘ f) (𝓝 0) atTop := by
    -- Use the Tendsto_comp lemma to compose the two tendsto statements
    have h1 : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
    exact h1
  exact h_main

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h_main : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
    -- Use the Tendsto_comp lemma to compose the two tendsto statements
    have h1 : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp ha hφ
    exact h1
  exact h_main
