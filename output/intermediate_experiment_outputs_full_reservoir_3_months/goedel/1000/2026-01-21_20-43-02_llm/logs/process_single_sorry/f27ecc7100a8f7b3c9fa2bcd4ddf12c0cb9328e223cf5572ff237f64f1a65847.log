    -- Prove that the series ∑ (1/n)^2 converges
    have h₂ : Summable fun n : ℕ => ((1 : ℝ) / n : ℝ) ^ 2 := by
      -- Use the fact that the series ∑ 1/n^2 is summable
      have h₃ : Summable fun n : ℕ => (1 : ℝ) / (n : ℝ) ^ 2 := by
        -- Compare with a convergent p-series (p = 2 > 1)
        have h₄ : Summable fun n : ℕ => (1 : ℝ) / (n : ℝ) ^ 2 := by
          simpa using summable_nat_pow_inv.mpr (by norm_num)
        exact h₄
