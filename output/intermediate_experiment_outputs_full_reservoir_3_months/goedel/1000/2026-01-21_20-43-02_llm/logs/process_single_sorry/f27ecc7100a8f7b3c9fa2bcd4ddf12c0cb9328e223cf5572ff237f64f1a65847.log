section Lp

open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := fun S ↦ if (Real.pi : ℝ) ∈ S then 1 else 0
  empty := by simp
  mono {S T} hST := by
    by_cases h : (Real.pi : ℝ) ∈ T
    · -- Case: π ∈ T
      have h₁ : (Real.pi : ℝ) ∈ S := by
        -- Since S ⊆ T and π ∈ T, π ∈ S
        exact hST h
      simp [h, h₁]
    · -- Case: π ∉ T
      have h₁ : (Real.pi : ℝ) ∉ S := by
        -- If π ∈ S, then π ∈ T, contradicting π ∉ T
        intro h₂
        exact h (hST h₂)
      simp [h, h₁]
  iUnion_nat := by
    intro S
    by_cases h : ∃ n : ℕ, (Real.pi : ℝ) ∈ S n
    · -- Case: There exists n such that π ∈ S n
      obtain ⟨n, hn⟩ := h
