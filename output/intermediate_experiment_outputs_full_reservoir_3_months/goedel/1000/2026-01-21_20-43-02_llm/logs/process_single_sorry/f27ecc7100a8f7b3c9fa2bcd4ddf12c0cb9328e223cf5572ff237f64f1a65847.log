section Lp

open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := fun S => if Real.pi ∈ S then 1 else 0
  empty := by simp [measureOf]
  mono {S T} hST := by
    by_cases h : Real.pi ∈ T
    · simp_all [h]
      <;> aesop
    · simp_all [h]
      <;> aesop
  iUnion_nat := by
    intro S
    by_cases h : Real.pi ∈ ⋃ n : ℕ, S n
    · -- Case: π is in the union of S_n
      have h₁ : ∃ n : ℕ, Real.pi ∈ S n := by
        simp only [Set.mem_iUnion] at h
        exact h
      obtain ⟨n, hn⟩ := h₁
      calc
        (μD).measureOf (⋃ n : ℕ, S n) = 1 := by
          simp_all [h]
        _ ≤ ∑' n : ℕ, (μD).measureOf (S n) := by
          have h₂ : (μD).measureOf (S n) ≥ 1 := by
            simp_all [measureOf]
            <;> aesop
          have h₃ : ∑' n : ℕ, (μD).measureOf (S n) ≥ 1 := by
            calc
              ∑' n : ℕ, (μD).measureOf (S n) ≥ ∑' n : ℕ, if n = n then (μD).measureOf (S n) else 0 := by
                exact tsum_le_tsum (fun n => by
                  split_ifs <;> simp_all [le_refl]) (Summable.of_nonneg_of_le (fun n => by
                    split_ifs <;> simp_all [le_refl, measureOf] <;>
                    (try { positivity }) <;> (try { aesop })) (summable_geometric_of_lt_one (by norm_num) (by norm_num))) (by
                  simp_all [measureOf] <;>
                  (try { positivity }) <;> (try { aesop }))
              _ = (μD).measureOf (S n) := by
                simp [tsum_ite_eq]
                <;> simp_all [measureOf]
                <;> aesop
              _ ≥ 1 := by
                exact h₂
          linarith
    · -- Case: π is not in the union of S_n
      calc
        (μD).measureOf (⋃ n : ℕ, S n) = 0 := by
          simp_all [h]
        _ ≤ ∑' n : ℕ, (μD).measureOf (S n) := by
          have h₂ : ∑' n : ℕ, (μD).measureOf (S n) ≥ 0 := by
            exact tsum_nonneg (fun n => by
              by_cases h₃ : Real.pi ∈ S n <;> simp_all [measureOf] <;>
              (try { positivity }) <;> (try { aesop }))
          linarith

def μL : Measure ℝ := by
  exact volume

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
  have h : μD {x : ℝ | x < 0} = μD (∅ : Set ℝ) := by
    have h₁ : Real.pi ∉ ({x : ℝ | x < 0} : Set ℝ) := by
      have h₂ : Real.pi > 0 := Real.pi_pos
      intro h₃
      linarith
    have h₂ : Real.pi ∉ (∅ : Set ℝ) := by simp
    simp_all [μD.measureOf]
  -- Since the measures of the two sets are equal, they are equal up to almost everywhere equivalence.
  have h₁ : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
    rw [MeasureTheory.ae_iff]
    <;> simp_all [μD.measureOf]
    <;>
    (try { aesop }) <;>
    (try { norm_num }) <;>
    (try { linarith [Real.pi_pos] })
    <;>
    (try {
      by_cases h₃ : Real.pi ∈ ({x : ℝ | x < 0} : Set ℝ)
      <;> simp_all [h₃]
      <;> norm_num at *
      <;> linarith [Real.pi_pos]
    })
  exact h₁

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    -- Use the transitivity of the almost everywhere equality relation.
    exact h1.trans h2
  -- The result follows directly from the transitivity.
  exact h3



