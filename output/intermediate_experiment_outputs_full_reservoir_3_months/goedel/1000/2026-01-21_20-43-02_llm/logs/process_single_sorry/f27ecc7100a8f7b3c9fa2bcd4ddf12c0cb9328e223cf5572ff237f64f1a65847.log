section Lp

open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := fun s => if π ∈ s then 1 else 0
  empty := by simp [μD]
  mono {S T} hST := by
    by_cases h : π ∈ S <;> by_cases h' : π ∈ T <;> simp_all [μD]
    <;> norm_num <;>
    (try { contradiction }) <;>
    (try { aesop }) <;>
    (try { linarith })
  iUnion_nat := by
    by_cases h : π ∈ ⋃ n : ℕ, (Set.univ : Set ℝ) <;> simp_all [μD]
    <;> norm_num <;>
    (try { contradiction }) <;>
    (try { aesop }) <;>
    (try { linarith })

def μL : Measure ℝ := by
  volume_tac [Real.volume]

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
  have h₁ : μD {x : ℝ | x < 0} = 0 := by
    by_cases h : π < 0
    · simp_all [μD, le_of_lt]
      <;> norm_num <;>
      (try { contradiction }) <;>
      (try { aesop }) <;>
      (try { linarith [Real.pi_pos] })
    · simp_all [μD, le_of_lt]
      <;> norm_num <;>
      (try { contradiction }) <;>
      (try { aesop }) <;>
      (try { linarith [Real.pi_pos] })
  have h₂ : μD (∅ : Set ℝ) = 0 := by simp [μD]
  have h₃ : μD {x : ℝ | x < 0} = μD (∅ : Set ℝ) := by rw [h₁, h₂]
  have h₄ : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by
    rw [MeasureTheory.ae_iff_null]
    <;> simp_all [μD]
    <;>
    (try { aesop }) <;>
    (try { linarith [Real.pi_pos] }) <;>
    (try { simp_all [μD] }) <;>
    (try { aesop })
  exact h₄

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    -- Use the transitivity of the equality almost everywhere relation
    have h4 : f =ᵐ[μL] g := h1
    have h5 : g =ᵐ[μL] h := h2
    exact h4.trans h5
  exact h3

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    -- Use the transitivity of the equality almost everywhere relation
    have h4 : f =ᵐ[μL] g := h1
    have h5 : g =ᵐ[μL] h := h2
    exact h4.trans h5
  exact h3

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by
  have h3 : f =ᵐ[μL] h := by
    -- Use the transitivity of the equality almost everywhere relation
    have h4 : f =ᵐ[μL] g := h1
    have h5 : g =ᵐ[μL] h := h2
    exact h4.trans h5
  exact h3

end Lp

