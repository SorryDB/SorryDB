      have h‚ÇÖ‚ÇÅ : p - 1 ‚â• 1 := by
        have h‚ÇÖ‚ÇÇ : p ‚â• 2 := Nat.Prime.two_le hp
        omega
      have h‚ÇÖ‚ÇÇ : p ^ k * p = p ^ k + p ^ k * (p - 1) := by
        have h‚ÇÖ‚ÇÉ : p = 1 + (p - 1) := by
          have h‚ÇÖ‚ÇÑ : p ‚â• 2 := Nat.Prime.two_le hp
          omega
        rw [h‚ÇÖ‚ÇÉ]
        ring_nf
        <;>
          (try omega) <;>
          (try simp_all [Nat.mul_sub_left_distrib, Nat.mul_sub_right_distrib, Nat.add_assoc]) <;>
          (try nlinarith) <;>
          (try ring_nf at *) <;>
          (try nlinarith)
      exact h‚ÇÖ‚ÇÇ
    have h‚ÇÜ : p ^ k + 1 < p ^ k + p ^ k * (p - 1) := by
      have h‚ÇÜ‚ÇÅ : 1 < p ^ k * (p - 1) := by
        have h‚ÇÜ‚ÇÇ : p - 1 ‚â• 1 := by
          have h‚ÇÜ‚ÇÉ : p ‚â• 2 := Nat.Prime.two_le hp
          omega
        have h‚ÇÜ‚ÇÉ : p ^ k ‚â• p := by
          calc
            p ^ k ‚â• p ^ 1 := pow_le_pow_right (by linarith) (by linarith)
            _ = p := by simp
        have h‚ÇÜ‚ÇÑ : p ^ k * (p - 1) ‚â• p * 1 := by
          nlinarith
        have h‚ÇÜ‚ÇÖ : p * 1 = p := by ring
