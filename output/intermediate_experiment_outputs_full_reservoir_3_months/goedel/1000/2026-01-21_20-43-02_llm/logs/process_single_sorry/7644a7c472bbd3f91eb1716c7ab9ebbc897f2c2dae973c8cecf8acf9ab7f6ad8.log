      "\n  have h₁ : ∀ a ∈ S, a ≤ sSup (decomposition_of_refinement R) := by\n    intro a ha\n    have h₂ : ∃! D ∈ R, a = sSup D := R.carrier_span a ha\n    obtain ⟨D, ⟨hD₁, hD₂⟩, hD₃⟩ := h₂\n    have h₃ : a = sSup D := hD₂\n    have h₄ : D ⊆ (decomposition_of_refinement R) := by\n      intro x hx\n      exact ⟨D, hD₁, hx⟩\n    have h₅ : sSup D ≤ sSup (decomposition_of_refinement R) := by\n      apply csSup_le\n      · apply Set.nonempty_of_mem\n        exact Set.mem_iUnion.mpr ⟨D, hD₁, Set.mem_setOf.mpr (by simp_all)⟩\n      · intro y hy\n        obtain ⟨D', hD'₁, hD'₂⟩ := hy\n        have h₆ : D' = D := by\n          by_contra h\n          have h₇ := hD₃ D' ⟨hD'₁, by simp_all [Set.ext_iff]⟩\n          simp_all\n        simp_all\n    have h₆ : a ≤ sSup (decomposition_of_refinement R) := by\n      calc\n        a = sSup D := by rw [h₃]\n        _ ≤ sSup (decomposition_of_refinement R) := h₅\n    exact h₆\n  \n  have h₂ : sSup S ≤ sSup (decomposition_of_refinement R) := by\n    apply le_csSup\n    · apply Set.Nonempty.bddAbove.mpr\n      · refine' ⟨sSup S, _⟩\n        intro x hx\n        have h₃ : x ≤ sSup S := le_csSup (by\n          have h₄ : BddAbove S := by\n            have h₅ : BddAbove S := by\n              -- Since α is a complete lattice, S is bounded above by sSup S\n              exact ⟨sSup S, by\n                intro x hx\n                exact le_csSup (by\n                  -- Show that S is nonempty and bounded above\n                  have h₆ : ∃ x, x ∈ S := by\n                    by_contra h\n                    push_neg at h\n                    have h₇ : S = ∅ := by\n                      ext x\n                      simp_all\n                    simp_all [sSup_empty]\n                    <;>\n                    (try cases α <;> simp_all [BoundedOrder, Top, Bottom, CompleteLattice]) <;>\n                    (try simp_all [Set.univ_eq_empty_iff]) <;>\n                    (try contradiction) <;>\n                    (try\n                      {