   })\n                simp_all [Set.Nonempty]\n                <;>\n                (try simp_all [BddAbove])\n                <;>\n                (try\n                  {\n                    have h₆ := inf_ex\n                    simp_all [Set.univ_eq_empty_iff]\n                    <;>\n                    (try contradiction)\n                  })\n              ) hx\n            ⟩\n          exact h₄\n        simp_all [BddAbove]\n        <;>\n        (try simp_all [Set.Nonempty])\n        <;>\n        (try\n          {\n            have h₆ := inf_ex\n            simp_all [Set.univ_eq_empty_iff]\n            <;>\n            (try contradiction)\n          })\n      ) hx\n      have h₄ : x ≤ sSup (decomposition_of_refinement R) := by\n        have h₅ : x ≤ sSup S := h₃\n        have h₆ : sSup S ≤ sSup (decomposition_of_refinement R) := by\n          -- Use the fact that each element of S is less than or equal to the supremum of the decomposition\n          apply le_csSup\n          · apply Set.Nonempty.bddAbove.mpr\n            · refine' ⟨sSup (decomposition_of_refinement R), _⟩\n              intro y hy\n              have h₇ : y ≤ sSup (decomposition_of_refinement R) := le_csSup (by\n                -- Show that the decomposition is bounded above\n                have h₈ : BddAbove (decomposition_of_refinement R) := by\n                  -- Since α is a complete lattice, the decomposition is bounded above by sSup (decomposition_of_refinement R)\n                  exact ⟨sSup (decomposition_of_refinement R), by\n                    intro z hz\n                    exact le_csSup (by\n                      -- Show that the decomposition is nonempty and bounded above\n                      have h₉ : ∃ z, z ∈ decomposition_of_refinement R := by\n                        by_contra h\n                        push_neg at h\n                        have h₁₀ : decomposition_of_refinement R = ∅ := by\n                          ext z\n                          simp_all\n 