      "\n  calc\n    sSup (decomposition_of_refinement R) = sSup (⋃ D ∈ R, D) := rfl\n    _ = sSup (⋃ D ∈ R, D) := rfl\n    _ = sSup (⋃ D ∈ R, D) := rfl\n    _ = sSup S := by\n      have h1 : sSup (⋃ D ∈ R, D) ≤ sSup S := by\n        -- For each element in the union of D, it is less than or equal to sSup S\n        have h1 : ∀ x ∈ ⋃ D ∈ R, D, x ≤ sSup S := by\n          intro x hx\n          -- x is in some D ∈ R\n          simp only [Set.mem_iUnion, Set.mem_setOf_eq] at hx\n          obtain ⟨D, hD, hD'⟩ := hx\n          -- Since D is a subset of S, x is in S\n          have h2 : D ∈ R := hD\n          have h3 : x ∈ D := hD'\n          -- Use the fact that each element in D is less than or equal to sSup S\n          have h4 : x ≤ sSup S := by\n            -- Since D is a subset of S, x is in S\n            have h5 : sSup D ≤ sSup S := by\n              apply sSup_le_sSup\n              -- Each element in D is less than or equal to some element in S\n              intro y hy\n              have h6 : ∃! (D : Set α), D ∈ R.carrier ∧ y = sSup D := by\n                have h7 : ∀ a ∈ S, ∃! (D : Set α), D ∈ R.carrier ∧ a = sSup D := R.carrier_span\n                -- We need to find a D in R.carrier such that y = sSup D\n                -- But we don't have direct access to S here, so we need to use the given properties\n                -- Since y is in D and D is a subset of S, there exists a D' in R.carrier such that y = sSup D'\n                -- However, this is not directly possible, so we need to find a different approach\n                -- Instead, we can use the fact that sSup D ≤ sSup S because D is a subset of S\n                -- So, we don't need to find D' explicitly, but we can use the fact that sSup D ≤ sSup S\n                -- Therefore, we can skip this part and directly use the fact that sSup D ≤ sSup S\n                -- because D is a subset of S\n                sorry\n              -- We can't directly find D', so we need to use the fact that s