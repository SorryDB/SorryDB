          <;>\n                (try\n                  {\n                    aesop\n                  })\n              })\n            <;>\n            aesop\n        exact h₆\n      -- Use the fact that sSup D' = sSup D to show that a ≤ sSup S\n      -- This is a placeholder for the actual proof\n      have h₅ : a ≤ sSup D := by\n        -- Since a ∈ D and D is a set of elements in α, a ≤ sSup D\n        have h₆ : a ∈ D := ha\n        have h₇ : a ≤ sSup D := by\n          apply le_sSup\n          <;> aesop\n        exact h₇\n      have h₆ : sSup D ≤ sSup S := by\n        -- Since sSup D is the supremum of D and D is part of the refinement of S, sSup D ≤ sSup S\n        -- This is a placeholder for the actual proof\n        have h₇ : ∃ (s : α), s ∈ S ∧ sSup D ≤ s := by\n          -- This is a placeholder; in the actual proof, we would use the fact that sSup D is in S\n          -- because D is in R, and R is constructed based on S\n          sorry\n        obtain ⟨s, hs, h₈⟩ := h₇\n        have h₉ : s ≤ sSup S := by\n          apply le_sSup\n          <;> aesop\n        have h₁₀ : sSup D ≤ sSup S := by\n          calc\n            sSup D ≤ s := h₈\n            _ ≤ sSup S := h₉\n        exact h₁₀\n      have h₇ : a ≤ sSup S := by\n        calc\n          a ≤ sSup D := h₅\n          _ ≤ sSup S := h₆\n      exact h₇\n    · -- Prove that sSup S ≤ sSup {a | ∃ D ∈ (R : Set (Set α)), a ∈ D}\n      apply sSup_le\n      intro a ha\n      have h₄ : a ∈ S := ha\n      have h₅ : ∃! D ∈ (R : Set (Set α)), sSup D = a := by\n        -- Use the fact that R is a refinement of S to find D ∈ R such that sSup D = a\n        -- This is a placeholder for the actual proof, which would use the properties of R\n        have h₆ := R.carrier_span a h₄\n        obtain ⟨D, hD, hD'⟩ := h₆\n        refine' ⟨D, hD, _⟩\n        <;> simp_all [le_antisymm_iff]\n        <;>\n        (try\n          {\n            intro D'' hD'' hD'''\n            have h₇ := hD'' hD'''\n            simp_all [le_antis