lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  have h₁ : sSup (decomposition_of_refinement R) = sSup S := by
    apply le_antisymm
    · -- Prove that sSup (decomposition_of_refinement R) ≤ sSup S
      have h₂ : decomposition_of_refinement R ≤ S := by
        intro x hx
        simp only [decomposition_of_refinement] at hx ⊢
        -- For any x in the union of R, x is in some D of R, and by carrier_span, x is in S
        rcases hx with ⟨D, hD, y, hy⟩
        -- Use the carrier_span property to show that y is in S
        have h₃ := R.carrier_span
        -- Since y is in D, which is in R, we can use the carrier_span property to find a unique D' in carrier with sSup D' = y
        -- But we don't need this here directly
        -- Instead, we use the fact that D is in R, and thus sSup D is in S, but this isn't directly helpful
        -- Actually, we need to think differently: since x is in D, and D is in R, we should be able to find some a in S such that a ≤ x
        -- However, the given answer has a much simpler approach
        -- The key is to realize that the refinement property is designed such that the union of R covers S
        -- So, x is actually in S directly
        simp_all [Set.mem_iUnion, Set.mem_setOf_eq]
        <;> aesop
      calc
        sSup (decomposition_of_refinement R) ≤ sSup S := sSup_le (by
          intro x hx
          -- If x is in the decomposition, then it is in S
          have h₃ : x ∈ S := h₂ hx
          exact h₃)
        _ = sSup S := by rfl
    · -- Prove that sSup S ≤ sSup (decomposition_of_refinement R)
      have h₂ : S ≤ decomposition_of_refinement R := by
        intro x hx
        -- For any x in S, we need to find x in the union of R
        -- By carrier_span, there exists a D in R such that x is in D
        have h₃ := R.carrier_span x hx
        obtain ⟨D, hD, y, hy⟩ := h₃
        -- We can then find x in D, and hence in the union of R
        simp_all [Set.mem_iUnion, Set.mem_setOf_eq]
        <;> aesop
      calc
        sSup S ≤ sSup (decomposition_of_refinement R) := sSup_le (by
          intro x hx
          -- If x is in S, then it is in the decomposition
          have h₃ : x ∈ decomposition_of_refinement R := h₂ hx
          exact h₃)
        _ = sSup (decomposition_of_refinement R) := by rfl
  exact h₁
