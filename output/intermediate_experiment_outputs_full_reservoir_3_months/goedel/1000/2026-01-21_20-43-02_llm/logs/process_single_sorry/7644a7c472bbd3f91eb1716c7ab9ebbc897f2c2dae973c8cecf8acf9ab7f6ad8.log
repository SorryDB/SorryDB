ement R, we have x ≤ sSup (decomposition_of_refinement R)\n    have h₆ : x = sSup D := by rw [hD']\n    have h₇ : sSup D ≤ sSup (decomposition_of_refinement R) := by\n      apply sSup_le' (fun y hy ↦ le_trans (le_sSup hy) (le_sSup (Set.mem_iUnion.mpr ⟨D, hD, hy⟩)))\n    linarith\n  \n  have h₂ : sSup (decomposition_of_refinement R) ≤ sSup S := by\n    -- For any x in decomposition_of_refinement R, there exists a D in R such that x ∈ D and D is a subset of S\n    refine' sSup_le fun x hx ↦ _\n    have h₃ : x ∈ decomposition_of_refinement R := hx\n    have h₄ : x ∈ ⋃ D ∈ (R : Set (Set α)), D := by simpa [decomposition_of_refinement] using h₃\n    obtain ⟨D, hD, hD'⟩ := Set.mem_iUnion.mp h₄\n    have h₅ : D ∈ (R : Set (Set α)) := hD\n    have h₆ : x ∈ D := hD'\n    -- Since D is in R, there exists an a in S such that D is the unique set in R whose supremum is a\n    have h₇ : ∃! (D' : Set α), D' ∈ (R : Set (Set α)) ∧ sSup D' = sSup D := by\n      have h₈ : ∃! (D : Set α), D ∈ (R : Set (Set α)) ∧ sSup D = sSup D := by\n        refine' ⟨D, ⟨h₅, by simp⟩, _⟩\n        rintro D' ⟨hD', hD''⟩\n        simp_all\n      simpa [eq_comm] using h₈\n    obtain ⟨D', ⟨hD'', hD'''⟩, hD''''⟩ := h₇\n    have h₈ : sSup D' = sSup D := by simp_all\n    have h₉ : x ≤ sSup D := by\n      apply le_sSup\n      · -- D is nonempty because x ∈ D\n        exact Set.nonempty_of_mem h₆\n      · -- x ∈ D\n        exact h₆\n    have h₁₀ : sSup D ≤ sSup S := by\n      -- Since D' is in R, there exists an a in S such that D' is the unique set in R whose supremum is a\n      have h₁₁ : ∃ a ∈ S, sSup D = a := by\n        have h₁₂ := R.carrier_span\n        have h₁₃ : ∃! (D : Set α), D ∈ (R : Set (Set α)) ∧ sSup D = sSup D := by\n          refine' ⟨D, ⟨h₅, by simp⟩, _⟩\n          rintro D' ⟨hD', hD''⟩\n          simp_all\n        obtain ⟨D', ⟨hD'', hD'''⟩, hD''''⟩ := h₁₃\n        have h₁₄ : D' ∈ (R : Set (Set α)) := hD''\n        have h₁₅ : sSup D' = sSup D := by simp_all\n        have h₁₆ : ∃ a ∈ S, sSup D