lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  have h₁ : sSup (decomposition_of_refinement R) = sSup (⋃ D ∈ R, D) := rfl
  have h₂ : sSup (⋃ D ∈ R, D) = sSup S := by
    -- We need to show that the supremum of the union of all sets in R is equal to the supremum of S.
    -- First, we show that the union of all sets in R is a subset of S.
    -- This is done by using the property that each element of S is the supremum of some set in R.
    -- Then, we show that S is a subset of the union of all sets in R.
    -- This is done by using the property that the supremum of each set in R is an element of S.
    apply le_antisymm
    · -- Prove that sSup (⋃ D ∈ R, D) ≤ sSup S
      apply sSup_le
      intro x hx
      -- If x is in the union of all sets in R, then it is in some set D in R.
      -- The supremum of D is in S, and x ≤ sSup D, so x ≤ sSup S.
      simp only [Set.mem_iUnion] at hx
      obtain ⟨D, hD, hD'⟩ := hx
      have h₃ : sSup D ≤ sSup S := by
        -- Since D is in R, the supremum of D is in S.
        have h₄ : sSup D ∈ S := by
          -- Using the property of refinement, each element of S is the supremum of some set in R.
          -- Here, we use the fact that the supremum of D is in S.
          have h₅ := R.carrier_span (sSup D) ⟨fun x hx => by
            -- For each x in D, x ≤ sSup D.
            have h₆ : x ≤ sSup D := le_sSup hx
            exact h₆, by
            -- Since D is in R, the supremum of D is in S.
            aesop⟩
          aesop
        -- Since sSup D ∈ S, we have sSup D ≤ sSup S.
        exact le_sSup h₄
      -- Since x ∈ D, x ≤ sSup D, and thus x ≤ sSup S.
      have h₆ : x ≤ sSup D := le_sSup hD'
      exact le_trans h₆ h₃
    · -- Prove that sSup S ≤ sSup (⋃ D ∈ R, D)
      apply sSup_le
      intro x hx
      -- For each x ∈ S, there exists a set D in R such that x = sSup D.
      -- Therefore, x is in the union of all sets in R.
      have h₃ : ∃! (D : Set α), D ∈ (R : Set (Set α)) ∧ x = sSup D := by
        -- Using the property of refinement, each element of S is the supremum of a unique set in R.
        have h₄ := R.carrier_span x hx
        obtain ⟨D, hD, hD'⟩ := h₄
        refine' ⟨D, ⟨hD, _⟩, _⟩ <;> aesop
      obtain ⟨D, ⟨hD, hD'⟩, _⟩ := h₃
      -- Since x = sSup D and D is in R, x is in the union of all sets in R.
      have h₄ : x = sSup D := by simpa using hD'
      have h₅ : D ∈ (R : Set (Set α)) := hD
      have h₆ : sSup D ≤ sSup (⋃ D ∈ R, D) := by
        -- Since D is in R, its supremum is less than or equal to the supremum of the union.
        have h₇ : sSup D ≤ sSup (⋃ D ∈ R, D) := by
          apply sSup_le
          intro x hx
          -- For each x ∈ D, x is in the union of all sets in R.
          have h₈ : x ∈ ⋃ D ∈ R, D := by
            refine' Set.mem_iUnion.mpr ⟨D, _⟩
            aesop
          exact le_trans (by simp_all [Set.mem_iUnion]) (le_sSup h₈)
        exact h₇
      -- Therefore, x ≤ sSup (⋃ D ∈ R, D).
      rw [h₄]
      exact h₆
  rw [h₁, h₂]
``` 

This proof establishes that the supremum of the decomposition of refinement R is equal to the supremum of S by showing that each is less than or equal to the other. The key steps involve using the properties of the refinement to relate the sets in R to the elements of S and then leveraging the definition of supremum to compare them. The proof uses the `sSup_le` lemma to transform the problem into showing subset-like relationships, which are easier to handle given the refinement properties. The proof concludes by using `le_antisymm` to combine the two inequalities into an equality.
