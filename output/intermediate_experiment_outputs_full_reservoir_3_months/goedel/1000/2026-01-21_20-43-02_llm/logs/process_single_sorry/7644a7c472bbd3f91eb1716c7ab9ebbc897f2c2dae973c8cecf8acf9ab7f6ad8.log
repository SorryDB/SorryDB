      "\n  have h₁ : sSup (decomposition_of_refinement R) = sSup S := by\n    calc\n      sSup (decomposition_of_refinement R) = sSup (⋃ D ∈ R, D) := rfl\n      _ = sSup (⋃ D ∈ R, ⋃ a ∈ D, {a}) := by\n        congr 1\n        ext x\n        simp [Set.mem_iUnion]\n        <;>\n        tauto\n      _ = sSup (⋃ D ∈ R, ⋃ a ∈ D, {a}) := rfl\n      _ = sSup (⋃ D ∈ R, ⋃ a ∈ D, {a}) := rfl\n      _ = sSup S := by\n        -- We need to show that the supremum of the union of R equals the supremum of S.\n        -- This involves showing that each element of S is covered by some element of R,\n        -- and that the supremum is preserved.\n        -- Since R is a refinement of S, for every a in S, there exists a unique D in R\n        -- such that a is the supremum of D. This implies that S is contained in the union of R.\n        -- Additionally, since the supremum is a monotone operation, the supremum of S is less than\n        -- or equal to the supremum of the union of R. Conversely, because each element of S is in the\n        -- union of R, the supremum of the union of R is less than or equal to the supremum of S.\n        -- Therefore, the two supremums are equal.\n        have h₂ : (⋃ D ∈ R, ⋃ a ∈ D, {a}) = ⋃ D ∈ R, ⋃ a ∈ D, {a} := rfl\n        have h₃ : (S : Set α) ⊆ ⋃ D ∈ R, ⋃ a ∈ D, {a} := by\n          intro a ha\n          -- For any a in S, there exists a unique D in R such that a is the supremum of D.\n          have h₄ : ∃! D ∈ R, a = sSup D := R.carrier_span a ha\n          obtain ⟨D, hD, h₅⟩ := h₄\n          -- Since D is in R, a is in the union of R.\n          have h₆ : a ∈ ⋃ D ∈ R, D := by\n            exact Set.mem_iUnion.mpr ⟨D, hD, by\n              -- Show that a is in D.\n              have h₇ : a = sSup D := h₅\n              have h₈ : sSup D ∈ D := by\n                have h₉ : BoundedOrder α := inferInstance\n                have h₁₀ : a ∈ (D : Set α) := by\n                  -- Since D is in R, and a is the supremum of D, a is in D.\n                  have h₁₁ : a = sSup D := h₅\n                  have h₁₂ : sSup D ∈ D := by\n                    -- Using the fact that D is non-empty and bounded, the supremum is in D.\n                    have h₁₃ : BoundedOrder α := inferInstance\n                    have h₁₄ : D.Nonempty := by\n                      by_contra h\n                      -- If D is empty, then its supremum is ⊥, which cannot be in D.\n                      have h₁₅ : D = ∅ := by\n                        exact Set.not_nonempty_iff_eq_empty.mp h\n                      simp_all [h₁₅, sSup_empty]\n                      <;>\n                      aesop\n                    -- Since D is non-empty and bounded, its supremum is in D.\n                    have h₁₅ : sSup D ∈ D := by\n                      -- Use the fact that D is a complete lattice to conclude that the supremum is in D.\n                      have h₁₆ : BoundedOrder α := inferInstance\n                      have h₁₇ : D.Nonempty := h₁₄\n                      have h₁₈ : sSup D ∈ D := by\n                        -- Use the fact that D is a complete lattice to conclude that the supremum is in D.\n                        have h₁₉ : sSup D ∈ D := by\n                          -- Use the fact that D is a complete lattice to conclude that the supremum is in D.\n                          classical\n                          -- Use the fact that D is a complete lattice to conclude that the supremum is in D.\n                          by_contra h₂₀\n                          -- If the supremum is not in D, then it is in the complement of D.\n                          have h₂₁ : sSup D ∉ D := h₂₀\n                          -- This leads to a contradiction because D is a lattice.\n                          exfalso\n                          -- Use the fact that D is a lattice to conclude that the supremum is in D.\n                          simp_all [Set.Nonempty, Set.mem_setOf_eq]\n                          <;>\n                          aesop\n                        exact h₁₉\n                      exact h₁₈\n                    exact h₁₅\n                  simp_all [Set.mem_setOf_eq]\n                  <;>\n                  aesop\n                simp_all [Set.mem_setOf_eq]\n                <;>\n                aesop\n              simp_all [Set.mem_setOf_eq]\n              <;>\n              aesop\n            ⟩\n          -- Since a is in the union of R, it is in the union of the union of R.\n          have h₉ : a ∈ ⋃ D ∈ R, ⋃ a ∈ D, {a} := by\n            -- Use the fact that a is in D to show that it is in the union.\n            have h₁₀ : a ∈ ⋃ D ∈ R, D := h₆\n            have h₁₁ : a ∈ ⋃ D ∈ R, ⋃ a ∈ D, {a} := by\n              -- Use the fact that a is in D to show that it is in the union.\n              have h₁₂ : a ∈ ⋃ D ∈ R, D := h₆\n              have h₁₃ : a ∈ ⋃ D ∈ R, ⋃ a ∈ D, {a} := by\n                -- Use the fact that a is in D to show that it is in the union.\n                obtain ⟨D, hD, h₁₄⟩ := Set.mem_iUnion.mp h₁₂\n                have h₁₅ : a ∈ D := h₁₄\n                have h₁₆ : a ∈ ⋃ a ∈ D, {a} := by\n                  -- Use the fact that a is in D to show that it is in the union.\n                  exact Set.mem_iUnion.mpr ⟨a, h₁₅, by simp⟩\n                exact Set.mem_iUnion.mpr ⟨D, hD, h₁₆⟩\n              exact h₁₃\n            exact h₁₁\n          exact h₉\n        -- Use the fact that the supremum is monotone to show that the supremum of S is less than or equal to the supremum of the union of R.\n        have h₄ : sSup (S : Set α) ≤ sSup (⋃ D ∈ R, ⋃ a ∈ D, {a}) := by\n          apply csSup_le\n          · -- Show that the union of R is non-empty.\n            have h₅ : (⋃ D ∈ R, ⋃ a ∈ D, {a} : Set α).Nonempty := by\n              by_contra h₆\n              -- If the union of R is empty, then for every D in R, D is empty.\n              have h₇ : (⋃ D ∈ R, ⋃ a ∈ D, {a} : Set α) = ∅ := by\n                exact Set.not_nonempty_iff_eq_empty.mp h₆\n              have h₈ : ∀ (D : Set α), D ∈ R → (⋃ a ∈ D, {a} : Set α) = ∅ := by\n                intro D hD\n                have h₉ : (⋃ a ∈ D, {a} : Set α) ⊆ (⋃ D ∈ R, ⋃ a ∈ D, {a} : Set α) := by\n                  intro x hx\n                  exact Set.mem_iUnion.mpr ⟨D, hD, hx⟩\n                have h₁₀ : (⋃ a ∈ D, {a} : Set α) ⊆ ∅ := by\n                  rw [h₇] at h₉\n                  exact h₉\n                have h₁₁ : (⋃ a ∈ D, {a} : Set α) = ∅ := by\n                  exact Set.Subset.antisymm h₁₀ (by simp [Set.empty_subset])\n                exact h₁₁\n              -- If every D in R is empty, then for every a in S, there is no D in R such that a is the supremum of D.\n              have h₁₂ : ∀ (a : α), a ∈ S → False := by\n                intro a ha\n                have h₁₃ : ∃! D ∈ R, a = sSup D := R.carrier_span a ha\n                obtain ⟨D, hD, h₁₄⟩ := h₁₃\n                have h₁₅ : (⋃ a ∈ D, {a} : Set α) = ∅ := h₈ D hD\n                have h₁₆ : D = ∅ := by\n                  by_contra h₁₇\n                  have h₁₈ : D.Nonempty := Set.nonempty_iff_ne_empty.mpr h₁₇\n                  obtain ⟨x, hx⟩ := h₁₈\n                  have h₁₉ : ({x} : Set α) ⊆ (⋃ a ∈ D, {a} : Set α) := by\n                    intro y hy\n                    simp only [Set.mem_singleton_iff] at hy ⊢\n                    have h₂₀ : y = x := hy\n                    rw [h₂₀]\n                    exact Set.mem_iUnion.mpr ⟨x, hx, by simp⟩\n                  have h₂₁ : ({x} : Set α) ⊆ ∅ := by\n                    rw [h₁₅] at h₁₉\n                    exact h₁₉\n                  have h₂₂ : ({x} : Set α) = ∅ := by\n                    exact Set.Subset.antisymm h₂₁ (by simp [Set.empty_subset])\n                  have h₂₃ : x ∈ ({x} : Set α) := by simp\n                  have h₂₄ : x ∈ (∅ : Set α) := by\n                    rw [h₂₂] at h₂₃\n                    exact h₂₃\n                  simp at h₂₄\n                simp_all [h₁₆, sSup_empty]\n                <;>\n                aesop\n    