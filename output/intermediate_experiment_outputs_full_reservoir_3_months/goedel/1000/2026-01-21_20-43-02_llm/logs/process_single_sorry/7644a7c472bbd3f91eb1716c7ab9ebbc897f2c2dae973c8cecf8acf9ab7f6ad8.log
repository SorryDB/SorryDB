      "\n  have h₁ : sSup (decomposition_of_refinement R) = sSup S := by\n    rw [show (decomposition_of_refinement R : Set α) = ⋃ D ∈ R, D by rfl]\n    have h₂ : (⋃ D ∈ R, D : Set α) = ⋃ D ∈ R, D := rfl\n    have h₃ : sSup (⋃ D ∈ R, D : Set α) = sSup (⋃ D ∈ R, D : Set α) := rfl\n    have h₄ : sSup S = sSup S := rfl\n    simp only [h₂, h₃, h₄] at *\n    -- To prove that the supremum of the decomposition is the same as the supremum of S,\n    -- we use the properties of the refinement and the fact that every element of S is the supremum of some D in the refinement.\n    have h₅ : ∀ a ∈ S, ∃! D ∈ (R : Set (Set α)), a = sSup D := R.carrier_span\n    have h₆ : ∀ D ∈ (R : Set (Set α)), sSupIndep D := R.carrier_indep\n    have h₇ : ∀ D ∈ (R : Set (Set α)), ⊥ ∉ D := R.bot_not_mem\n    -- We use the fact that the supremum of a union is the supremum of the supremums of each set in the union.\n    have h₈ : sSup (⋃ D ∈ R, D : Set α) = sSup (S : Set α) := by\n      apply le_antisymm\n      · -- Show that sSup (⋃ D ∈ R, D) ≤ sSup S\n        have h₉ : ∀ a ∈ (⋃ D ∈ R, D : Set α), a ≤ sSup S := by\n          intro a ha\n          have h₁₀ : a ∈ ⋃ D ∈ R, D := ha\n          rcases h₁₀ with ⟨D, hD, ha⟩\n          have h₁₁ : a ∈ D := ha\n          have h₁₂ : D ∈ (R : Set (Set α)) := hD\n          have h₁₃ : ∃! D' ∈ (R : Set (Set α)), sSup D = sSup D := by\n            have h₁₄ : ∃! D ∈ (R : Set (Set α)), sSup D = sSup D := by\n              refine' ⟨D, hD, _⟩\n              intro D' hD' h\n              -- We need to show that D is unique.\n              -- This is straightforward since sSup D = sSup D' implies D = D'\n              simp_all [Set.ext_iff]\n              <;> aesop\n            simpa using h₁₄\n          -- Since a ∈ D, we have a ≤ sSup D\n          have h₁₅ : a ≤ sSup D := by\n            apply le_sSup_of_subset\n            · intro x hx\n              simp_all [Set.ext_iff]\n              <;> aesop\n            <;> simp_all [Set.ext_iff]\n            <;> aesop\n          -- Since D ∈ R, we have sSup D ≤ sSup S\n          have h₁₆ : sSup D ≤ sSup S := by\n            have h₁₇ : ∃! D' ∈ (R : Set (Set α)), sSup D = sSup D := by\n              refine' ⟨D, hD, _⟩\n              intro D' hD' h\n              simp_all [Set.ext_iff]\n              <;> aesop\n            have h₁₈ : ∃ (D' : Set α), D' ∈ (R : Set (Set α)) ∧ sSup D = sSup D' := by\n              refine' ⟨D, hD, _⟩\n              <;> simp\n            obtain ⟨D', hD', hD'_sup⟩ := h₁₈\n            have h₁₉ : sSup D ≤ sSup S := by\n              have h₂₀ : ∃! D'' ∈ (R : Set (Set α)), D'' = D' := by\n                refine' ⟨D', hD', _⟩\n                intro D'' hD'' h\n                simp_all [Set.ext_iff]\n                <;> aesop\n              -- Since D' ∈ R, and R is a refinement of S, we have sSup D' ≤ sSup S\n              have h₂₁ : ∃ a ∈ S, D' ⊆ {a} := by\n                -- We need to show that D' is contained in some singleton {a} where a ∈ S\n                -- This is because S is the set of elements that are the supremum of some D in R\n                have h₂₂ := h₅\n                have h₂₃ : ∃! D'' ∈ (R : Set (Set α)), sSup D' = sSup D'' := by\n                  refine' ⟨D', hD', _⟩\n                  intro D'' hD'' h\n                  simp_all [Set.ext_iff]\n                  <;> aesop\n                have h₂₄ : sSup D' = sSup D' := rfl\n                have h₂₅ : ∃ a ∈ S, D' ⊆ {a} := by\n                  -- Use the fact that D' is in R to find a ∈ S such that D' ⊆ {a}\n                  -- This is a placeholder for the actual proof, which would require more detailed steps\n                  sorry\n                exact h₂₅\n              obtain ⟨a, ha, hD'_subset⟩ := h₂₁\n              have h₂₆ : sSup D' ≤ a := by\n                have h₂₇ : D' ⊆ {a} := hD'_subset\n                have h₂₈ : sSup D' ≤ sSup ({a} : Set α) := by\n                  apply sSup_le_sSup\n                  · intro x hx\n                    simp_all [Set.ext_iff]\n             