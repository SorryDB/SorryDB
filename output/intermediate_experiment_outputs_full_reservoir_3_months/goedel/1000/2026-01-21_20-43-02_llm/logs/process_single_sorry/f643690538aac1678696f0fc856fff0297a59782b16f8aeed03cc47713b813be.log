theorem NumberField.AdeleRing.isCentralSimple_addHaarScalarFactor_left_mul_eq_right_mul
  [IsSimpleRing B] [Algebra.IsCentral K B] (u : (B ⊗[K] (𝔸 K))ˣ) :
  addEquivAddHaarChar (ContinuousAddEquiv.mulLeft u) =
  addEquivAddHaarChar (ContinuousAddEquiv.mulRight u) := by
  have h₁ : addEquivAddHaarChar (ContinuousAddEquiv.mulLeft u) = addEquivAddHaarChar (ContinuousAddEquiv.mulRight u) := by
    -- Use the properties of central simple algebras and the Haar measure to show the equality
    have h₂ : ∀ (x : B ⊗[K] (𝔸 K)), ContinuousAddEquiv.mulLeft u x = u • x := rfl
    have h₃ : ∀ (x : B ⊗[K] (𝔸 K)), ContinuousAddEquiv.mulRight u x = x • u := rfl
    -- Use the fact that the algebra is central and simple to show that the actions are the same
    have h₄ : ContinuousAddEquiv.mulLeft u = ContinuousAddEquiv.mulRight u := by
      -- Prove that the left and right multiplications by u are the same
      have h₅ : ContinuousAddEquiv.mulLeft u = ContinuousAddEquiv.mulRight u := by
        -- Use the fact that B is central and simple
        ext x
        simp_all [ContinuousAddEquiv.mulLeft, ContinuousAddEquiv.mulRight]
        <;>
        (try simp_all [Algebra.IsCentral]) <;>
        (try simp_all [IsSimpleRing]) <;>
        (try simp_all [Algebra.IsCentral, IsSimpleRing]) <;>
        (try { aesop }) <;>
        (try { ring_nf }) <;>
        (try { simp_all [Algebra.IsCentral] }) <;>
        (try { simp_all [IsSimpleRing] }) <;>
        (try { simp_all [Algebra.IsCentral, IsSimpleRing] })
      exact h₅
    -- Conclude the proof
    rw [h₄]
  exact h₁
