lemma measureTheory_rpow_comp {f : ℝ → ℝ} (hf : Continuous f) (a : ℝ) :
  Measurable fun x : ℝ => a ^ (f x) := by
  have h : Continuous fun x : ℝ => a ^ (f x) := by
    -- Prove that the function x ↦ a ^ (f x) is continuous.
    -- Since f is continuous and the exponential function with base `a` is continuous,
    -- their composition is continuous.
    have h₁ : Continuous (fun x : ℝ => (a : ℝ) ^ (f x)) := continuous_const.rpow hf
    exact h₁
  -- Use the fact that a continuous function is measurable.
  have h₂ : Measurable fun x : ℝ => a ^ (f x) := h.measurable
  exact h₂
