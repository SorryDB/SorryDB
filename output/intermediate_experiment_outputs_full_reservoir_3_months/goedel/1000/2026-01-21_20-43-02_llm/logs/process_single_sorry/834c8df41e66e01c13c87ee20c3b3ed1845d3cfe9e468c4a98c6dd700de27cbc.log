theorem test_lean (n : ℕ) : (n + 1) * (n + 1) = n * n + 2 * n + 1 := by
  have h₁ : (n + 1) * (n + 1) = n * n + 2 * n + 1 := by
    induction n with
    | zero => norm_num
    | succ n ih =>
      simp [Nat.succ_eq_add_one, add_mul, mul_add, mul_one, mul_assoc, mul_comm, mul_left_comm] at ih ⊢
      <;> ring_nf at *
      <;> omega
  exact h₁
