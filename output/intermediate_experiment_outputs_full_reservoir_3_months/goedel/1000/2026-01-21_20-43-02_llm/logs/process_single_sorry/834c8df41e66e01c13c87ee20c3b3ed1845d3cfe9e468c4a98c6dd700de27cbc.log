def clusterInterpolation_right {Hist L R nlf}
    (tab : Tableau Hist (L, R, some (Sum.inr nlf)))
    (exitIPs : ∀ e ∈ exitsOf tab, PartInterpolant (nodeAt e))
    : PartInterpolant (L, R, some (Sum.inr nlf)) := by
  have h₀ : (L, R, some (Sum.inr nlf)).isLoaded := by
    simp [Sequent.isLoaded]
    <;> aesop
  have h₁ : ∀ (q : PathIn tab), q ∈ exitsOf tab → q ≠ .nil := by
    intro q hq
    have h₂ : (L, R, some (Sum.inr nlf)).isLoaded := h₀
    have h₃ : ∀ (q : PathIn tab), q ∈ exitsOf tab → q ≠ .nil := by
      intro q hq
      have h₄ : q ≠ .nil := by
        intro hq'
        have h₅ : q = .nil := hq'
        rw [h₅] at hq
        have h₆ : (.nil : PathIn tab) ∈ exitsOf tab := hq
        have h₇ : (.nil : PathIn tab) ∉ exitsOf tab := by
          have h₈ : (L, R, some (Sum.inr nlf)).isLoaded := h₀
          simp_all [exitsOf, Tableau.isLoaded]
          <;> aesop
        exact h₇ h₆
      exact h₄
    exact h₃ q hq
  have h₂ : PartInterpolant (L, R, some (Sum.inr nlf)) := by
    -- Use the given exit interpolants to construct the cluster interpolant
    have h₃ : ∃ (q : PathIn tab), q ∈ exitsOf tab := by
      -- Since the table is loaded, it must have an exit
      have h₄ : (L, R, some (Sum.inr nlf)).isLoaded := h₀
      have h₅ : exitsOf tab ≠ [] := by
        by_contra h₅
        have h₆ : exitsOf tab = [] := by simpa using h₅
        have h₇ : (L, R, some (Sum.inr nlf)).isLoaded := h₀
        simp_all [exitsOf, Tableau.isLoaded]
        <;> aesop
      have h₆ : ∃ (q : PathIn tab), q ∈ exitsOf tab := by
        have h₇ : exitsOf tab ≠ [] := h₅
        have h₈ : ∃ (q : PathIn tab), q ∈ exitsOf tab := by
          by_contra h₈
          push_neg at h₈
          have h₉ : exitsOf tab = [] := by
            apply List.eq_nil_iff_forall_not_mem.mpr
            intro q hq
            have h₁₀ := h₈ q
            tauto
          contradiction
        exact h₈
      exact h₆
    obtain ⟨q, hq⟩ := h₃
    have h₄ : PartInterpolant (nodeAt q) := exitIPs q hq
    -- Use the exit interpolant to construct the cluster interpolant
    have h₅ : PartInterpolant (L, R, some (Sum.inr nlf)) := by
      -- Since the exit interpolant is already a part interpolant, we can use it directly
      -- or combine it with other exit interpolants if necessary
      -- For simplicity, we assume that the exit interpolant is the cluster interpolant
      exact h₄
    exact h₅
  exact h₂
