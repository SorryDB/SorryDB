me, erasing at idx3 or idx2 will give the same list.\n      have h₉₄ : (l2.eraseIdx idx3) = (l2.eraseIdx idx2) := by\n        -- Use the fact that the elements are the same to show that the lists are the same.\n        cases l2 with\n        | nil =>\n          simp_all\n        | cons a l2' =>\n          -- Consider the cases where l2 is a singleton or has multiple elements.\n          cases l2' with\n          | nil =>\n            -- If l2 is a singleton, then the indices cannot be different.\n            simp_all [List.eraseIdx, List.length]\n            <;>\n            (try omega) <;>\n            (try simp_all [heq]) <;>\n            (try aesop)\n          | cons b l2'' =>\n            -- If l2 has multiple elements, then we can use the fact that the indices are the same.\n            simp_all [List.eraseIdx, List.get, List.length]\n            <;>\n            (try {\n              induction l2'' with\n              | nil =>\n                simp_all [List.eraseIdx, List.get, List.length]\n                <;>\n                (try omega) <;>\n                (try simp_all [heq]) <;>\n                (try aesop)\n              | cons c l2''' ih =>\n                simp_all [List.eraseIdx, List.get, List.length]\n                <;>\n                (try omega) <;>\n                (try simp_all [heq]) <;>\n                (try aesop)\n            }) <;>\n            (try {\n              simp_all [List.eraseIdx, List.get, List.length]\n              <;>\n              (try omega) <;>\n              (try simp_all [heq]) <;>\n              (try aesop)\n            }) <;>\n            (try {\n              simp_all [List.eraseIdx, List.get, List.length]\n              <;>\n              (try omega) <;>\n              (try simp_all [heq]) <;>\n              (try aesop)\n            })\n      exact h₉₄\n    -- Combine the permutations to get the final result.\n    have h₁₀ : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by\n      calc\n        (l1.eraseIdx idx1) =