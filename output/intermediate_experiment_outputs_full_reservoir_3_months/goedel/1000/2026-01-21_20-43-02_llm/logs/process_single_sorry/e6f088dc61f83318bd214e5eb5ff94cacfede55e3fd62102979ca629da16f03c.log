  have h : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
    -- Use the property of permutation to show that after erasing the elements, the lists remain permuted.
    -- The permutation is preserved because the elements being erased are equal and their positions are adjusted correctly.
    have h₁ : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
      -- Use the permutation and the equality of elements to show the desired result.
      apply List.Perm.trans _ (List.perm_erase_of_mem _ (by
        -- Show that the element at idx2 in l2 is in l2 (which is trivial).
        have h₂ : l2[idx2] ∈ l2 := by
          apply List.get_mem
          <;> simp_all [List.length]
