    have h₁ : l1[idx1] = l2[idx2] := heq
    -- Use the fact that if two lists are permutations and we remove the same element, the remaining lists are still permutations.
    have h₂ : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
      -- Use the property of permutations that if we remove an element from both lists, they are still permutations.
      simpa [h₁] using hperm.eraseAt hidx1 hidx2
    exact h₂
  exact h
