        -- Use the permutation to show that the element is also in l1.
        have h₃ : l2[idx2] ∈ l1 := by
          simpa [hperm] using h₂
        -- Conclude that the element is in l2.
        exact h₂))
      -- Use the permutation and the equality of elements to show the desired result.
      <;>
      (try simp_all [List.Perm])
      <;>
      (try
        {
          apply List.perm_erase_of_mem
          <;>
          (try simp_all [List.get_mem])
          <;>
          (try omega)
        })
      <;>
      (try
        {
          apply List.Perm.refl
        })
      <;>
      (try
        {
          apply List.perm.swap
          <;>
          (try simp_all [List.get_mem])
          <;>
          (try omega)
        })
    -- Conclude the proof.
    exact h₁
  -- Conclude the proof.
  exact h
