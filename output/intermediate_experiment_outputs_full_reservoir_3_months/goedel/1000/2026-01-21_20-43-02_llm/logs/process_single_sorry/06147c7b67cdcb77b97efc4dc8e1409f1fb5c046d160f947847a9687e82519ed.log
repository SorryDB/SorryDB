                  -- Use the fact that the group of roots of unity is cyclic
                  have h₅ : ∃ (g : rootsOfUnity (n + 2) Circle), ∀ (x : rootsOfUnity (n + 2) Circle), x ∈ Submonoid.closure {g} := by
