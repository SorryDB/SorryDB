-- 4.
lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ n m : ℕ, n ≤ m → tri n ≤ tri m := by
    intro n m hnm
    have h3 : ∀ k : ℕ, tri k = k * (k + 1) / 2 := by
      intro k
      rfl
    rw [h3]
    rw [h3]
    have h4 : n * (n + 1) / 2 ≤ m * (m + 1) / 2 := by
      have h5 : n ≤ m := hnm
      have h6 : n * (n + 1) ≤ m * (m + 1) := by
        have h7 : n ≤ m := hnm
        have h8 : n + 1 ≤ m + 1 := by omega
        nlinarith
      have h9 : n * (n + 1) / 2 ≤ m * (m + 1) / 2 := by
        have h10 : n * (n + 1) ≤ m * (m + 1) := h6
        have h11 : n * (n + 1) / 2 ≤ m * (m + 1) / 2 := by
          apply Nat.div_le_div_right
          <;> nlinarith
        exact h11
      exact h9
    exact h4
  exact h2 j k h1

-- 5.
example {U V : Type} (f : U → V) : range f = Ran (graph f) := by
  ext y
  simp [Set.mem_range, Set.mem_Ran]
  <;>
  aesop

-- 6.
lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · intro h
    apply Set.eq_univ_of_forall
    intro v
    have h₁ : ∃ (u : U), f u = v := h v
    rcases h₁ with ⟨u, rfl⟩
    exact ⟨u, rfl⟩
  · intro h
    intro v
    have h₁ : v ∈ (range f : Set V) := by
      rw [h]
      trivial
    rcases h₁ with ⟨u, rfl⟩
    exact ⟨u, rfl⟩

-- 7.
-- Don't use ctble_iff_set_nat_equinum to prove this lemma
lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  have h3 : ctble V := by
    -- Since U and V are equinumerous, and U is countable, V must also be countable.
    have h4 : ctble U := h2
    have h5 : U ∼ V := h1
    exact h4.of_equinum h5.symm
  exact h3

