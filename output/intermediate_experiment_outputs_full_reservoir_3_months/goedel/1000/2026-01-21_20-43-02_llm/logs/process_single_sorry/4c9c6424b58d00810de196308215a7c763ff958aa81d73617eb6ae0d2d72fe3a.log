  · -- Prove the reverse direction: if S is nonempty, then 𝒫 S is possibly empty
    intro h
    have h₁ : S.Nonempty := h
    have h₂ : 𝒫 S ≠ ∅ := by
      by_contra h₃
      -- If 𝒫 S = ∅, then in particular, ∅ ∉ 𝒫 S, which is impossible
