  fin_range n |>.map (λ i => ⟨↑i.toNat, f i⟩) |>.toAssocList

theorem RelIO.mapVal {α β} {n : Nat} {f : Fin n → α} {g : α → β} :
  AssocList.mapVal (λ _ => g) (RelIO.liftFinf n f) = RelIO.liftFinf n (λ i => g (f i)) := by
  dsimp only [RelIO.liftFinf]
  have h₁ : (fin_range n |>.map (λ i => ⟨↑i.toNat, f i⟩)).toAssocList =
    (fin_range n |>.map (λ i => ⟨↑i.toNat, f i⟩)).toAssocList := rfl
  rw [h₁]
  have h₂ : (fin_range n |>.map (λ i => ⟨↑i.toNat, g (f i)⟩)).toAssocList =
    (fin_range n |>.map (λ i => ⟨↑i.toNat, g (f i)⟩)).toAssocList := rfl
  rw [h₂]
  -- Use the fact that mapping the value function over the association list is the same as mapping it over each element
  have h₃ : (fin_range n |>.map (λ i => ⟨↑i.toNat, f i⟩) |>.toAssocList).mapVal (λ _ => g) =
    (fin_range n |>.map (λ i => ⟨↑i.toNat, g (f i)⟩) |>.toAssocList) := by
    -- Use the property of the `mapVal` function on the association list
    congr 1
    <;>
    simp_all [List.map_map]
    <;>
    (try simp_all [List.toAssocList_map])
    <;>
    (try simp_all [List.toAssocList_map])
    <;>
    (try simp_all [List.toAssocList_map])
  rw [h₃]
  <;>
  simp_all [List.map_map]
  <;>
  (try simp_all [List.toAssocList_map])
  <;>
  (try simp_all [List.toAssocList_map])
  <;>
  (try simp_all [List.toAssocList_map])
