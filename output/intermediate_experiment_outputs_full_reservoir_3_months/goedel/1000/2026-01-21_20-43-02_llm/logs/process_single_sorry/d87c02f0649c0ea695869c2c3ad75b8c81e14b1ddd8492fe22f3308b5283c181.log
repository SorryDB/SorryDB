  have h_imp : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro h
    -- Use the fact that scalar multiplication by a bounded operator preserves integrability
    have h₁ : IntervalIntegrable (r • f) μ a b := by
      -- Apply the lemma that if f is integrable, then r • f is integrable when r is a bounded scalar
      exact h.smul r
    exact h₁
  
  have h_conv : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro h
    -- Handle the case when r = 0 separately
    by_cases hr : r = 0
    · -- If r = 0, then r • f = 0, and f can be any function
      have h₁ : (r • f : ℝ → E) = (fun _ => 0 : ℝ → E) := by
        ext x
        simp [hr]
        <;> simp_all [smul_zero]
      -- Since r • f is the zero function, it is trivially interval integrable
      have h₂ : IntervalIntegrable (r • f : ℝ → E) μ a b := h
      -- The zero function is interval integrable, but we need to deduce integrability of f
      -- However, if r = 0, the statement is vacuously true for any f, so we can directly use the given integrability of r • f
      have h₃ : IntervalIntegrable f μ a b := by
        -- Use the fact that the zero function is interval integrable to deduce the integrability of f
        -- This step is a bit tricky, but we can use the fact that the zero function is integrable and the properties of scalar multiplication
        -- to deduce the integrability of f. However, in this case, we can directly use the given integrability of r • f
        -- because r = 0 and r • f is the zero function.
        simpa [h₁] using h₂
      exact h₃
    · -- If r ≠ 0, we can use the boundedness of the scalar multiplication to deduce integrability of f
      have h₁ : IsBoundedSMul R E := inferInstance
      -- Use the fact that the scalar multiplication is bounded to deduce the integrability of f
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the fact that the scalar multiplication is bounded to deduce the integrability of f
        have h₃ : IntervalIntegrable (r • f : ℝ → E) μ a b := h
        -- Use the fact that the scalar multiplication is bounded to deduce the integrability of f
        have h₄ : IntervalIntegrable f μ a b := by
          -- Use the fact that the scalar multiplication is bounded to deduce the integrability of f
          -- by considering the inverse scalar multiplication
          have h₅ : IsBoundedSMul R E := inferInstance
          -- Use the fact that the scalar multiplication is bounded to deduce the integrability of f
          -- by considering the inverse scalar multiplication
          have h₆ : IntervalIntegrable (r⁻¹ • (r • f : ℝ → E)) μ a b := h₃.smul r⁻¹
          -- Simplify the expression r⁻¹ • (r • f) to f
          have h₇ : (r⁻¹ • (r • f : ℝ → E) : ℝ → E) = f := by
            ext x
            -- Simplify the expression r⁻¹ • (r • f x) to f x
            simp [smul_smul, hr]
            <;>
            simp_all [mul_inv_cancel]
            <;>
            simp_all [one_smul]
          -- Use the fact that r⁻¹ • (r • f) = f to deduce the integrability of f
          simpa [h₇] using h₆
        exact h₄
      exact h₂
  
  exact ⟨h_imp, h_conv⟩
