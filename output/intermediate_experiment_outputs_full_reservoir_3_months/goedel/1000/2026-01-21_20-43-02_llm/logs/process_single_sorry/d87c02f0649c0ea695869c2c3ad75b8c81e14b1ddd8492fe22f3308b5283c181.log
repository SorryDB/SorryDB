      -- Use the boundedness of scalar multiplication to show integrability of the scaled function
      have h₄ : ((fun x : ℝ => r • f x) = r • f) := rfl
      have h₅ : IntervalIntegrable f μ a b := hf
      -- Apply the boundedness of scalar multiplication to deduce the integrability of the scaled function
      have h₆ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that scalar multiplication is a bounded operator
        have h₇ : IsBoundedSMul R E := inferInstance
        have h₈ : IntervalIntegrable f μ a b := hf
        -- Use the property of limited scalar multiplication to deduce integrability of the scaled function
        have h₉ : IntervalIntegrable (r • f) μ a b :=
          h₈.bounded_smul _
