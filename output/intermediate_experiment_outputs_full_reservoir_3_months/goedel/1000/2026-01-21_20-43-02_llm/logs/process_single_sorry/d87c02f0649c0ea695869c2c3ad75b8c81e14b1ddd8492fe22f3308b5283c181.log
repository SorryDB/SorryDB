theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      intro h
      -- Use the fact that scalar multiplication by a bounded linear operator preserves integrability.
      have h₂ : IntervalIntegrable (r • f) μ a b := by
        -- Use the boundedness of the scalar multiplication to show that r • f is integrable.
        have h₃ : IsBoundedSMul R E := inferInstance
        -- Use the fact that the product of a bounded function with an integrable function is integrable.
        refine' (IntervalIntegrable.smul _ h)
        <;> simp_all [IsBoundedSMul]
        <;> try aesop
      exact h₂
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      intro h
      -- Use the fact that scalar multiplication by a bounded linear operator preserves integrability.
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the boundedness of the scalar multiplication to show that f is integrable.
        have h₃ : IsBoundedSMul R E := inferInstance
        -- Use the fact that the product of a bounded function with an integrable function is integrable.
        by_cases h₄ : r = 0
        · -- If r = 0, then r • f = 0, and the integrability of 0 implies the integrability of f is trivial.
          simp_all [h₄, smul_zero]
          <;>
          (try
            simp_all [IntervalIntegrable])
          <;>
          (try
            aesop)
        · -- If r ≠ 0, use the fact that r • f is integrable to deduce that f is integrable.
          have h₅ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
            -- Use the boundedness of the scalar multiplication to show that r⁻¹ • (r • f) is integrable.
            refine' (IntervalIntegrable.smul _ h)
            <;> simp_all [IsBoundedSMul]
            <;> try aesop
          -- Simplify r⁻¹ • (r • f) to f.
          have h₆ : (fun x => r⁻¹ • (r • f x)) = f := by
            funext x
            have h₇ : r⁻¹ • (r • f x) = f x := by
              rw [smul_smul]
              field_simp [h₄]
              <;> simp_all [one_smul]
            rw [h₇]
          -- Substitute back to get the integrability of f.
          rw [h₆] at h₅
          exact h₅
      exact h₂
  exact h₁
