```lean
theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : (r : R) = 0 ∨ (r : R) ≠ 0 := by by_cases h : (r : R) = 0 <;> [exact Or.inl h; exact Or.inr h]
  cases h₁ with
  | inl h₁ =>
    simp [h₁, smul_zero, intervalIntegrable_zero]
    <;>
    aesop
  | inr h₁ =>
    constructor
    · intro h₂
      have h₃ : IntervalIntegrable (r • f) μ a b := by
        have h₄ : IntervalIntegrable (fun x => r • f x) μ a b := by
          -- Use the fact that scalar multiplication preserves integrability
          have h₅ : IntervalIntegrable f μ a b := h₂
          have h₆ : Continuous (fun (p : ℝ × E) => r • p.2 : ℝ × E → E) := by
            apply Continuous.smul
            · exact continuous_const
            · exact continuous_snd
          have h₇ : IntervalIntegrable (fun x => r • f x) μ a b := by
            -- Use the fact that scalar multiplication preserves integrability
            have h₈ : IntervalIntegrable (fun x => r • f x) μ a b := by
              apply IntervalIntegrable.smul
              exact h₅
            exact h₈
          exact h₇
        exact h₄
      exact h₃
    · intro h₂
      have h₃ : IntervalIntegrable f μ a b := by
        have h₄ : IntervalIntegrable (fun x => (r⁻¹ : R) • (r • f x)) μ a b := by
          have h₅ : (r : R) ≠ 0 := h₁
          have h₆ : IntervalIntegrable (fun x => r • f x) μ a b := h₂
          have h₇ : Continuous (fun (p : ℝ × E) => (r⁻¹ : R) • p.2 : ℝ × E → E) := by
            apply Continuous.smul
            · exact continuous_const
            · exact continuous_snd
          have h₈ : IntervalIntegrable (fun x => (r⁻¹ : R) • (r • f x)) μ a b := by
            apply IntervalIntegrable.smul
            exact h₆
          exact h₈
        have h₉ : (fun x => (r⁻¹ : R) • (r • f x)) = f := by
          ext x
          have h₁₀ : (r⁻¹ : R) • (r • f x) = f x := by
            calc
              (r⁻¹ : R) • (r • f x) = (r⁻¹ : R) • (r • f x) := rfl
              _ = ((r⁻¹ : R) * r) • f x := by
                rw [smul_smul]
                <;>
                simp [mul_smul]
              _ = (1 : R) • f x := by
                have h₁₁ : (r⁻¹ : R) * r = 1 := by
                  apply mul_inv_cancel
                  exact h₁
                rw [h₁₁]
              _ = f x := by
                simp [one_smul]
          rw [h₁₀]
        have h₁₀ : IntervalIntegrable f μ a b := by
          rw [h₉] at h₄
          exact h₄
        exact h₁₀
      exact h₃
  <;>
  simp_all [intervalIntegrable_zero, smul_zero, zero_smul]
  <;>
  aesop
