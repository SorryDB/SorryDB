theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      intro hf
      have h₂ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that scalar multiplication by a bounded scalar preserves interval integrability.
        have h₃ : IsBoundedSMul R E := inferInstance
        have h₄ : IntervalIntegrable (r • f) μ a b := by
          -- Use the property of scalar multiplication and boundedness to show interval integrability.
          refine' hf.smul r
        exact h₄
      exact h₂
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      intro hf
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the fact that scalar multiplication by a bounded scalar preserves interval integrability.
        have h₃ : IsBoundedSMul R E := inferInstance
        have h₄ : IntervalIntegrable f μ a b := by
          -- Use the property of scalar multiplication and boundedness to show interval integrability.
          by_cases hr : r = 0
          · -- If r = 0, then r • f = 0, and we can directly use the interval integrability of 0.
            subst hr
            simp_all [smul_zero]
            <;>
            (try exact intervalIntegrable_zero) <;>
            (try simp_all [intervalIntegrable_zero]) <;>
            (try exact hf)
          · -- If r ≠ 0, we can use the fact that the inverse of r is bounded to recover f.
            have h₅ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
              -- Use the interval integrability of r • f and the boundedness of r⁻¹ to show the interval integrability of r⁻¹ • (r • f).
              refine' hf.smul r⁻¹
            have h₆ : r⁻¹ • (r • f) = f := by
              -- Show that r⁻¹ • (r • f) = f using the properties of scalar multiplication.
              ext x
              simp [smul_smul, hr]
              <;>
              (try simp_all [smul_zero]) <;>
              (try field_simp [hr]) <;>
              (try ring_nf)
            rw [h₆] at h₅
            exact h₅
        exact h₄
      exact h₂
  exact h₁
