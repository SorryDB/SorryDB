```lean
theorem Integrable_of_UnifConv {f : ℕ → ℝ → ℝ} {F : ℝ → ℝ}
    {a b : ℝ} (hab : a < b)
    {ℓ : ℕ → ℝ}
    (hfint : ∀ n, HasIntegral (f n) a b (ℓ n))
    (hfF : UnifConv f F) :
    ∃ (L : ℝ), SeqLim ℓ L ∧ HasIntegral F a b L := by
  have RSdiff : ∀ ε > 0, ∃ N, ∀ n ≥ N, ∀ M, |RiemannSum (f n) a b M - RiemannSum F a b M| < ε := by
    intro ε hε
    have h₁ : 0 < (b - a : ℝ) := by linarith
    -- Use the uniform convergence of f_n to F to find N such that |f_n(x) - F(x)| < ε / (b - a) for all x and n ≥ N
    have h₂ : ∃ N, ∀ n ≥ N, ∀ x, |f n x - F x| < ε / (b - a) := by
      have h₃ : Tendsto (fun n => f n) atTop (𝓝[Uniformity.uniformPredOn univ] F) := hfF
      have h₄ : ∀ ε > 0, ∃ N, ∀ n ≥ N, ∀ x ∈ univ, dist (f n x) (F x) < ε := Metric.tendsto_atTop.mp (h₃.congr' neighborhoodFilter_mono (le_rfl) _)
      specialize h₄ (ε / (b - a)) (by positivity)
      obtain ⟨N, hN⟩ := h₄
      refine' ⟨N, fun n hn x => _⟩
      have h₅ := hN n hn x (Set.mem_univ x)
      simp [Real.dist_eq] at h₅ ⊢
      <;>
      (try norm_num at h₅ ⊢) <;>
      (try linarith) <;>
      (try assumption) <;>
      (try simp_all [abs_sub_lt_iff]) <;>
      (try norm_num) <;>
      (try linarith)
    obtain ⟨N, hN⟩ := h₂
    use N
    intro n hn M
    -- Use the bound on |f_n(x) - F(x)| to bound the difference of Riemann sums
    have h₃ : |RiemannSum (f n) a b M - RiemannSum F a b M| < ε := by
      have h₄ : |RiemannSum (f n) a b M - RiemannSum F a b M| ≤ (b - a : ℝ) * (ε / (b - a)) := by
        -- Show that the difference of Riemann sums is bounded by (b - a) * (ε / (b - a))
        have h₅ : |RiemannSum (f n) a b M - RiemannSum F a b M| ≤ (b - a : ℝ) * (ε / (b - a)) := by
          calc
            |RiemannSum (f n) a b M - RiemannSum F a b M| ≤ ∑ i : Fin M, |(f n (a + (i : ℝ) * (b - a) / M) - F (a + (i : ℝ) * (b - a) / M))| * ((b - a) / M) := by
              -- Use the triangle inequality and properties of Riemann sums
              calc
                |RiemannSum (f n) a b M - RiemannSum F a b M| = |∑ i : Fin M, (f n (a + (i : ℝ) * (b - a) / M) - F (a + (i : ℝ) * (b - a) / M)) * ((b - a) / M)| := by
                  simp [RiemannSum, Finset.sum_sub_distrib]
                  <;> ring_nf
                  <;> simp_all [Finset.sum_sub_distrib]
                  <;> ring_nf
                _ ≤ ∑ i : Fin M, |(f n (a + (i : ℝ) * (b - a) / M) - F (a + (i : ℝ) * (b - a) / M)) * ((b - a) / M)| := by
                  -- Use the triangle inequality for the sum
                  exact Finset.abs_sum_le_sum_abs _ _
                _ = ∑ i : Fin M, |(f n (a + (i : ℝ) * (b - a) / M) - F (a + (i : ℝ) * (b - a) / M))| * |(b - a) / M| := by
                  -- Use the property of absolute values
                  simp [abs_mul]
                _ = ∑ i : Fin M, |(f n (a + (i : ℝ) * (b - a) / M) - F (a + (i : ℝ) * (b - a) / M))| * ((b - a) / M) := by
                  -- Simplify the absolute value of (b - a) / M
                  have h₆ : 0 ≤ (b - a : ℝ) := by linarith
                  have h₇ : 0 ≤ (b - a : ℝ) / M := by positivity
                  have h₈ : |(b - a : ℝ) / M| = (b - a : ℝ) / M := by
                    rw [abs_of_nonneg]
                    <;> positivity
                  simp_all [h₈]
                  <;>
                  (try norm_num) <;>
                  (try ring_nf) <;>
