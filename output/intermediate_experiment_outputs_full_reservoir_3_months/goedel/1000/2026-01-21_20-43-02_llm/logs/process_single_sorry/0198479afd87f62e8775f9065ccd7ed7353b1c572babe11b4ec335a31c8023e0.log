theorem vec_in_if_idx {v : Vector α n} {x : α} (hin : x ∈ v) :
   ∃ i : Fin n, v[i] = x := by
  have h : ∃ i : Fin n, v[i] = x := by
    classical
    -- Use the fact that x is in the vector to find the index
    have h₁ : x ∈ v := hin
    rw [Vector.mem_iff] at h₁
    obtain ⟨i, hi⟩ := h₁
    refine' ⟨i, _⟩
    <;> simp_all [Vector.get]
  exact h
```

#### 4. `Vector.mapIdx_eq_map` Proof

```lean
theorem Vector.mapIdx_eq_map {v : Vector α n} (f : α → β) :
    v.mapIdx (λ _ => f) = v.map f := by
  apply Vector.ext
  intro i
  simp [Vector.mapIdx]
  <;> rfl
```


