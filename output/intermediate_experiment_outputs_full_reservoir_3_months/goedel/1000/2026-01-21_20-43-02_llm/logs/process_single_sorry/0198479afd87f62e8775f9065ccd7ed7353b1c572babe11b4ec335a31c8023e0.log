        cases i <;> simp_all [Fin.ext_iff, List.Perm.cons_swap, List.eraseIdx_succ]
        <;>
        (try omega)
      })
    | i + 1, j + 1 =>
      simp_all [List.Perm.cons_swap, Fin.ext_iff, Fin.val_succ, List.eraseIdx_succ, Nat.succ_eq_add_one]
      <;>
      (try {
        cases i <;> cases j <;> simp_all [Fin.ext_iff, List.Perm.cons_swap, List.eraseIdx_succ]
        <;>
        (try omega)
      })
      <;>
