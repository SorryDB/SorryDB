theorem RelInt.liftFinf_in' {S} {rule : RelInt S} {n : Nat} {f : Fin n → List (RelInt S)}:
      (∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j) →
      rule ∈ (RelInt.liftFinf n f) := by
        intro ⟨i, j, Hij⟩
        rw [Hij]
        unfold liftFinf
        simp only [RelInt, List.get_eq_getElem, List.mem_flatten, List.mem_map]
        -- We need to show that the element is in the flattened list of the image of f
        -- We can use the fact that the element is in the image of f i and then use the fact that f i is in the list of lists
        -- and finally use the fact that the flattened list of the image of f is the union of the flattened lists of each f i
        -- We need to find an appropriate list in the map and an index in that list to show that the element is in the flattened list
        -- We will use the i we got from the hypothesis and then find the appropriate index
        have h : ∃ (l : List (RelInt S)), l ∈ List.map f (Finset.univ : Finset (Fin n)) ∧ (f i).get j ∈ l := by
          refine' ⟨f i, _⟩
          -- We need to show that f i is in the map and that the element is in f i
          have h₁ : f i ∈ List.map f (Finset.univ : Finset (Fin n)) := by
            -- Since i is in Fin n, it is in the univ set, and f i is in the map of f over univ
            have h₂ : i ∈ (Finset.univ : Finset (Fin n)) := Finset.mem_univ _
            have h₃ : f i ∈ List.map f (Finset.univ : Finset (Fin n)) := by
              apply List.mem_map.mpr
              exact ⟨i, by aesop, rfl⟩
            exact h₃
          -- The element is in f i by the hypothesis
          have h₄ : (f i).get j ∈ f i := by
            apply List.get_mem
          -- Combine these facts to get the required result
          exact ⟨h₁, h₄⟩
        -- Now we can use the fact that if an element is in one of the lists in the map, it is in the flattened list
        obtain ⟨l, h₁, h₂⟩ := h
        simp_all [List.mem_flatten]
        <;> aesop
