      "\n  have h₁ : ∃ r, mul lhs rhs = ok r := by\n    have h₂ : mul lhs rhs = ok (mul_impl lhs rhs) := by\n      simp [mul]\n      <;> rfl\n    refine' ⟨mul_impl lhs rhs, _⟩\n    exact h₂\n  \n  have h₂ : ∀ (r : Array U64 5#usize), mul lhs rhs = ok r → Field51_as_Nat r ≡ (Field51_as_Nat lhs) * (Field51_as_Nat rhs) [MOD p] := by\n    intro r hr\n    have h₃ : mul lhs rhs = ok r := hr\n    have h₄ : r = mul_impl lhs rhs := by\n      have h₅ : mul lhs rhs = ok (mul_impl lhs rhs) := by\n        simp [mul]\n        <;> rfl\n      have h₆ : mul lhs rhs = ok r := h₃\n      have h₇ : ok r = ok (mul_impl lhs rhs) := by\n        rw [h₆] at *\n        <;> simp_all [h₅]\n      simp [Option.ext_iff] at h₇\n      <;> simp_all\n      <;> aesop\n    rw [h₄]\n    sorry\n  \n  have h₃ : ∀ (r : Array U64 5#usize), mul lhs rhs = ok r → (∀ i < 5, r[i]!.val < 2 ^ 52) := by\n    intro r hr\n    have h₄ : mul lhs rhs = ok r := hr\n    have h₅ : r = mul_impl lhs rhs := by\n      have h₆ : mul lhs rhs = ok (mul_impl lhs rhs) := by\n        simp [mul]\n        <;> rfl\n      have h₇ : mul lhs rhs = ok r := h₄\n      have h₈ : ok r = ok (mul_impl lhs rhs) := by\n        rw [h₇] at *\n        <;> simp_all [h₆]\n      simp [Option.ext_iff] at h₈\n      <;> simp_all\n      <;> aesop\n    rw [h₅]\n    sorry\n  \n  obtain ⟨r, hr⟩ := h₁\n  have h₄ : Field51_as_Nat r ≡ (Field51_as_Nat lhs) * (Field51_as_Nat rhs) [MOD p] := h₂ r hr\n  have h₅ : (∀ i < 5, r[i]!.val < 2 ^ 52) := h₃ r hr\n  exact ⟨r, hr, h₄, h₅⟩",
