theorem no_three_consecutive_ones : ∀ n : ℕ, ¬(a n = 1 ∧ a (n + 1) = 1 ∧ a (n + 2) = 1) := by
  intro n hn
  have h₁ : a (n + 1) = 1 := hn.2.1
  have h₂ : a n = 1 := hn.1
  have h₃ : a (n + 2) = 1 := hn.2.2
  have h₄ : a (n + 1) = 1 := by simpa using h₁
  -- Use the definition of `a` to get the constraints for `a (n + 1)`
  have h₅ : a (n + 1) = 1 := h₄
  have h₆ : (a n : ℕ) + (a (n + 2) : ℕ) > 1 := by
    have h₆₁ := hseq (n + 1)
    have h₆₂ : a (n + 1) = 1 := h₅
    simp [h₆₂] at h₆₁
    <;> norm_cast at h₆₁ ⊢ <;>
    (try omega) <;>
    (try simp_all [a]) <;>
    (try omega)
    <;>
    (try
      {
        cases n <;>
        simp_all [a, Nat.gcd_eq_right, Nat.gcd_eq_left] <;>
        omega
      })
  have h₇ : Nat.gcd (a n + 1) (a (n + 2) + 1) = 1 := by
    have h₇₁ := hseq (n + 1)
    have h₇₂ : a (n + 1) = 1 := h₅
    simp [h₇₂] at h₇₁
    <;> norm_cast at h₇₁ ⊢ <;>
    (try omega) <;>
    (try simp_all [a]) <;>
    (try omega)
    <;>
    (try
      {
        cases n <;>
        simp_all [a, Nat.gcd_eq_right, Nat.gcd_eq_left] <;>
        omega
      })
  -- Substitute `a n = 1` and `a (n + 2) = 1` into the constraints
  have h₈ : (a n : ℕ) = 1 := by
    norm_cast
    <;> simp_all
  have h₉ : (a (n + 2) : ℕ) = 1 := by
    norm_cast
    <;> simp_all
  have h₁₀ : Nat.gcd (a n + 1) (a (n + 2) + 1) = 2 := by
    have h₁₀₁ : (a n : ℕ) = 1 := by
      norm_cast
      <;> simp_all
    have h₁₀₂ : (a (n + 2) : ℕ) = 1 := by
      norm_cast
      <;> simp_all
    simp [h₁₀₁, h₁₀₂]
    <;> decide
  -- Derive the contradiction
  omega
