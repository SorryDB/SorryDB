  have h₇ : 2 * j - i ≤ 8 := by
    have h₇₁ : 2 * j - i ≤ 8 := by
      have : 2 * j ≤ i + 8 := by
        omega
      omega
    exact h₇₁
  have h₈ : i < j := hij1
  interval_cases i <;> interval_cases j <;> norm_num [Set.Icc, Fin.ext_iff] at hij1 hij2 hc1 hc2 ⊢ <;>
    (try omega) <;> (try simp_all (config := {decide := true})) <;>
    (try contradiction) <;> (try omega)
  <;> (try contradiction)
  <;> (try omega)
