import Mathlib.Tactic.NormNum
import Mathlib.Tactic.IntervalCases

import ProblemExtraction

problem_file { tags := [.Combinatorics] }

/-!
# Bulgarian Mathematical Olympiad 1998, Problem 1

We will be considering colorings in 2 colors of n (distinct) points
A₁, A₂, ..., Aₙ. Call such a coloring "good" if there exist three points
Aᵢ, Aⱼ, A₂ⱼ₋ᵢ, 1 ≤ i < 2j - i ≤ n, which are colored the same color.

Find the least natural number n (n ≥ 3) such that all colorings
of n points are good.
-/

namespace Bulgaria1998P1

abbrev coloring_is_good {m : ℕ} (color : Set.Icc 1 m → Fin 2) : Prop :=
  ∃ i j : Set.Icc 1 m,
    i < j ∧
    ∃ h3 : 2 * j.val - i ∈ Set.Icc 1 m,
    color i = color j ∧ color i = color ⟨2 * j - i, h3⟩

abbrev all_colorings_are_good (m : ℕ) : Prop :=
  3 ≤ m ∧ ∀ color : Set.Icc 1 m → Fin 2, coloring_is_good color

snip begin

lemma lemma1 {m n : ℕ} (hmn : m ≤ n) (hm : all_colorings_are_good m) :
    all_colorings_are_good n := by
  constructor
  · exact hm.1.trans hmn
  · intro c
    let c' : Set.Icc 1 m → Fin 2 :=
      fun x ↦ c ⟨x.val, by rw [Set.mem_Icc]; exact ⟨x.prop.1, x.prop.2.trans hmn⟩⟩
    obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := hm.2 c'
    use ⟨i, hi1, hi2.trans hmn⟩
    use ⟨j, hj1, hj2.trans hmn⟩
    simp only [Subtype.mk_lt_mk, Set.mem_Icc, tsub_le_iff_right, exists_and_left]
    simp only [Subtype.mk_lt_mk] at hij1
    refine ⟨hij1, ?_⟩
    simp only [Set.mem_Icc, tsub_le_iff_right] at hij2
    simp only [c'] at hc1
    refine ⟨hc1, ?_⟩
    have hij2' : 1 ≤ 2 * j - i ∧ 2 * j ≤ n + i :=
       ⟨hij2.1, le_add_of_le_add_right hij2.2 hmn⟩
    use hij2'

def coloring_of_eight {n : ℕ} : Set.Icc 1 n → Fin 2
| ⟨1, _⟩ => 0
| ⟨2, _⟩ => 1
| ⟨3, _⟩ => 0
| ⟨4, _⟩ => 1
| ⟨5, _⟩ => 1
| ⟨6, _⟩ => 0
| ⟨7, _⟩ => 1
| ⟨8, _⟩ => 0
| _ => 0 -- unreachable

lemma lemma2 :
    ∃ f : Set.Icc 1 8 → Fin 2, ¬coloring_is_good f := by
  use coloring_of_eight
  intro h
  obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := h
  dsimp [coloring_of_eight] at *
  interval_cases i <;> interval_cases j <;> norm_num [Set.Icc, Subtype.val_mk, Fin.ext_iff] at hij1 hij2 hc1 hc2 <;>
    (try contradiction) <;>
    (try {
      simp_all [coloring_of_eight, Set.Icc, Subtype.val_mk, Fin.ext_iff]
      <;> norm_num at *
      <;> try contradiction
      <;> try omega
    }) <;>
    (try {
      simp_all [coloring_of_eight, Set.Icc, Subtype.val_mk, Fin.ext_iff]
      <;> norm_num at *
      <;> try contradiction
      <;> try omega
    }) <;>
    (try {
      simp_all [coloring_of_eight, Set.Icc, Subtype.val_mk, Fin.ext_iff]
      <;> norm_num at *
      <;> try contradiction
      <;> try omega
    })
  <;>
  (try {
    simp_all [coloring_of_eight, Set.Icc, Subtype.val_mk, Fin.ext_iff]
    <;> norm_num at *
    <;> try contradiction
    <;> try omega
  })
```


### Explanation of the Proof

The proof of `lemma2` involves checking all possible values of `i` and `j` (since `i`, `j` are in `Set.Icc 1 8`) to show that no three points `Aᵢ, Aⱼ, A₂ⱼ₋ᵢ` are colored the same under the given coloring. 

1. **Understanding the Coloring**: The coloring is defined as:
   - A₁ = 0, A₂ = 1, A₃ = 0, A₄ = 1, A₅ = 1, A₆ = 0, A₇ = 1, A₈ = 0.

2. **Assumption for Contradiction**: Assume that there exist `i < j` in `{1, ..., 8}` and `2j - i ∈ {1, ..., 8}` such that `color(i) = color(j)` and `color(i) = color(2j - i)`.

3. **Checking All Cases**: 
   - For each pair `(i, j)`, we compute `2j - i` and check if it is within `{1, ..., 8}`.
   - Then, we verify the colors:
     - If `color(i) = color(j)`, we further check if `color(i) = color(2j - i)`.
   - All such cases will lead to contradictions because no such triple exists in the given coloring.

4. **Use of `interval_cases`**: This tactic is used to systematically check all possible values of `i` and `j` from 1 to 8. For each pair, we simplify the conditions using `norm_num` and check for contradictions in the coloring constraints.

5. **Contradictions Found**: Each case where `i < j` and `2j - i ∈ {1, ..., 8}` will have either `color(i) ≠ color(j)` or `color(i) ≠ color(2j - i)`. For example:
   - `(1, 2)`: `2*2 - 1 = 3`, colors are 0, 1, 0 → 0 ≠ 1.
   - `(1, 3)`: `2*3 - 1 = 5`, colors are 0, 0, 1 → 0 ≠ 1.
   - And so on for all pairs.

This exhaustive checking confirms that no triple exists, proving that the coloring is not "good."

