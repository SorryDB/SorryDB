      "\n  have hT : Module.IsTorsion A (Submodule.torsion A M) := by\n    intro x\n    exact Ō¤©1, by simp [Submodule.torsion, mul_one]Ō¤®\n  have h_quotient : Module.IsTorsionZero A (M Ō¦Ė Submodule.torsion A M) := by\n    refine' fun x Ōå” by\n      simp only [Module.IsTorsionZero]\n      have h : (Ōłā (a : A), a ŌēĀ 0 Ōł¦ a ŌĆó x = 0) := by\n        have hŌéü : x.val Ōłł (Submodule.torsion A M) := by\n          have hŌéé : x.val Ōłł M := by\n            exact Submodule.Quotient.mem_mk' x rfl\n          have hŌéā : x.val Ōłł Submodule.torsion A M := by\n            exact Submodule.mem_ofmem x.val (by exact x.prop)\n          exact hŌéā\n        rw [Submodule.mem_torsion] at hŌéü\n        obtain Ō¤©a, haŌ¤® := hŌéü\n        have hŌéé : a ŌēĀ 0 ŌåÆ (Ō¤©a, haŌ¤® : Submodule.Quotient (Submodule.torsion A M)).val ŌēĀ 0 := by\n          intro hŌéā\n          intro hŌéä\n          simp_all [Submodule.Quotient.ext_iff]\n          <;> aesop\n        refine' Ō¤©a, _Ō¤®\n        have hŌéā : a ŌĆó x = 0 := by\n          have hŌéä : a ŌĆó x.val = 0 := by simpa using ha\n          simpa [Submodule.Quotient.eq_zero_iff_mem] using hŌéä\n        by_cases hŌéä : a = 0\n        ┬Ę simp_all\n        ┬Ę exact Ō¤©hŌéä, hŌéāŌ¤®\n      obtain Ō¤©a, haŌéü, haŌééŌ¤® := h\n      exact Ō¤©a, haŌéü, haŌééŌ¤®\n  refine' Ō¤©_, _Ō¤®\n  ┬Ę -- Prove that the kernel of the map is pseudo-null\n    simp_all [isPseudoIsomorphism_iff, isPseudoNull_iff]\n    <;>\n    (try { contradiction }) <;>\n    (try { aesop })\n  ┬Ę -- Prove that the cokernel of the map is pseudo-null\n    simp_all [isPseudoIsomorphism_iff, isPseudoNull_iff]\n    <;>\n    (try { contradiction }) <;>\n    (try { aesop })",
