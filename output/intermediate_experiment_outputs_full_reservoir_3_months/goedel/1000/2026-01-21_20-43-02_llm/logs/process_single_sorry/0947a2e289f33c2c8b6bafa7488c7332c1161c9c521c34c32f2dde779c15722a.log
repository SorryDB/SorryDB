    ∫ x in 0..Real.pi, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₁ : ∫ x in 0..Real.pi, sin x * f (cos x) = ∫ y in (-1)..(1), f y := by sorry
  have h₂ : ∫ y in (-1)..(1), f y = ∫ y in -1..1, f y := by sorry
  have h₃ : ∫ x in 0..Real.pi, sin x * f (cos x) = ∫ y in -1..1, f y := by sorry
  sorry
