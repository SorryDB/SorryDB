```lean
theorem change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₁ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
    have h₂ : ∫ x in 0..π, sin x * f (cos x) = ∫ x in 0..π, sin x * f (cos x) := rfl
    rw [h₂]
    -- Use the substitution y = cos x, dy = -sin x dx
    -- When x = 0, y = 1; when x = π, y = -1
    -- The integral becomes ∫ from 1 to -1 f(y) (-dy) = ∫ from -1 to 1 f(y) dy
    have h₃ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in (cos π)..(cos 0), f y := by
      have h₄ : ∫ x in 0..π, sin x * f (cos x) = ∫ x in 0..π, sin x * f (cos x) := rfl
      rw [h₄]
      -- Use the substitution rule for integrals
      have h₅ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in (cos π)..(cos 0), f y := by
        have h₆ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in (cos π)..(cos 0), f y := by
          rw [intervalIntegral.integral_comp_cos (fun x => f x)]
          <;> simp [cos_zero, cos_pi]
          <;> ring_nf
          <;> norm_num
          <;> linarith [Real.pi_pos]
        exact h₆
      exact h₅
    rw [h₃]
    -- Simplify the limits of integration
    have h₇ : (cos π : ℝ) = -1 := by norm_num
    have h₈ : (cos 0 : ℝ) = 1 := by norm_num
    rw [h₇, h₈]
    <;> simp [intervalIntegral.integral_symm]
    <;> ring_nf
    <;> norm_num
  exact h₁
