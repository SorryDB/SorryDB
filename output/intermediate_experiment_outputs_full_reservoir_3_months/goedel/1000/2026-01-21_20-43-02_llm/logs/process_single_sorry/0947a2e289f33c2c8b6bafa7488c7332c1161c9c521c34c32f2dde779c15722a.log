lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₁ : (∫ x in 0..π, sin x * f (cos x)) = ∫ y in -1..1, f y := by
    have h₂ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in (cos 0)..(cos π), f y := by
      -- Use the substitution rule for integrals
      have h₃ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in (cos 0)..(cos π), f y := by
        rw [intervalIntegral.integral_comp_cos (fun x => f x)]
        <;> simp [sin_zero, sin_pi]
        <;> ring_nf
        <;> norm_num
        <;>
        (try
          {
            -- Verify that the derivative of cos is -sin, and adjust the integral accordingly
            field_simp [Real.differentiableAt_cos]
            <;>
            ring_nf
            <;>
            norm_num
          })
        <;>
        (try
          {
            -- Simplify the integral using the properties of cosine and sine
            simp_all [Real.differentiableAt_cos, Real.differentiableAt_sin]
            <;>
            norm_num
            <;>
            linarith [Real.pi_pos]
          })
      exact h₃
    -- Simplify the bounds of the integral
    have h₄ : (cos 0 : ℝ) = 1 := by norm_num
    have h₅ : (cos π : ℝ) = -1 := by norm_num
    rw [h₂, h₄, h₅]
    <;>
    (try
      {
        -- Reverse the bounds of the integral and adjust the sign
        rw [intervalIntegral.integral_symm]
        <;>
        simp_all [intervalIntegral.integral_symm]
        <;>
        norm_num
        <;>
        linarith [Real.pi_pos]
      })
    <;>
    (try
      {
        -- Confirm the final form of the integral
        simp_all [intervalIntegral.integral_symm]
        <;>
        norm_num
        <;>
        linarith [Real.pi_pos]
      })
  -- Conclude the proof
  exact h₁
