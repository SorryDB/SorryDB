lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₁ : ∫ x in 0..π, sin x * f (cos x) = -∫ x in 0..π, f (cos x) * (-sin x) := by
    congr 1
    ext x
    ring_nf
    <;>
    simp [mul_comm]
    <;>
    ring_nf
    <;>
    simp [mul_comm]
    <;>
    ring_nf
  
  have h₂ : -∫ x in 0..π, f (cos x) * (-sin x) = ∫ y in cos 0..cos π, f y := by
    rw [intervalIntegral.integral_comp_mul_left (fun x => f x)]
    <;>
    simp [cos_zero, cos_pi, mul_neg, mul_one]
    <;>
    ring_nf
    <;>
    norm_num
    <;>
    simp_all [intervalIntegral.integral_comp_mul_left]
    <;>
    ring_nf
    <;>
    norm_num
  
  have h₃ : ∫ y in cos 0..cos π, f y = ∫ y in 1..(-1 : ℝ), f y := by
    simp [cos_zero, cos_pi]
    <;>
    ring_nf
  
  have h₄ : ∫ y in 1..(-1 : ℝ), f y = -∫ y in (-1 : ℝ)..1, f y := by
    rw [← intervalIntegral.integral_symm]
    <;>
    simp [neg_neg]
    <;>
    ring_nf
  
  have h₅ : -∫ y in (-1 : ℝ)..1, f y = ∫ y in -1..1, f y := by
    have h₅₁ : ∫ y in (-1 : ℝ)..1, f y = ∫ y in -1..1, f y := by
      simp
    rw [h₅₁]
    <;>
    ring_nf
  
  calc
    ∫ x in 0..π, sin x * f (cos x) = -∫ x in 0..π, f (cos x) * (-sin x) := by rw [h₁]
    _ = ∫ y in cos 0..cos π, f y := by rw [h₂]
