```lean
theorem ContextFreeDerivation_exhaustive_imp_child_exhaustive
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition) :
  ∀ u' : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }),
  ∀ step : ContextFreeDerivationStep G u,
  ∀ derivation : ContextFreeDerivation G u' v,
  ∀ sound : _,
  cfd = ContextFreeDerivation.step step derivation sound →
  derivation.exhaustiveCondition := by
  have h_main : ∀ (cfd : @ContextFreeDerivation α nt G u v), cfd.exhaustiveCondition → (∀ (u' : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z })) (step : ContextFreeDerivationStep G u) (derivation : ContextFreeDerivation G u' v) (sound : _), cfd = ContextFreeDerivation.step step derivation sound → derivation.exhaustiveCondition) := by
    intro cfd h_exhaustive u' step derivation sound h_eq
    match cfd with
    | .same h_same =>
      intro u' step derivation sound h_eq
      exfalso
      simp_all [ContextFreeDerivation.step]
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound =>
      intro u' step derivation sound h_eq
      rw [exhaustiveCondition] at h_exhaustive ⊢
      simp_all [ContextFreeDerivation.step]
      <;> aesop
  exact h_main cfd h_exhaustive
```

