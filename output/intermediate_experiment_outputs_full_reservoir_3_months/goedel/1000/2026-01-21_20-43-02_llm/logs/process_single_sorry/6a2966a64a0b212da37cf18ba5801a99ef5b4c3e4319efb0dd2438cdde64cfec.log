theorem parts_length (l : List α) : (parts l).length = 2^(l.length - 1) := by
  have h : ∀ (l : List α), l.length ≥ 1 → (parts l).length = 2^(l.length - 1) := by
    intro l hl
    induction' l with a as ih
    · exfalso
      linarith
    · cases as with
      | nil =>
        simp [parts]
      | cons a' as =>
        simp_all [parts, pow_succ, List.length]
        <;>
        (try omega) <;>
        (try ring_nf at * <;> simp_all [Nat.pow_succ, Nat.mul_div_cancel_left]) <;>
        (try
          {
            have h₁ : 0 < as.length + 1 := by omega
            have h₂ : 0 < (as.length + 1) := by omega
            have h₃ : 2 ^ (as.length + 1 - 1) = 2 ^ as.length := by
              have h₄ : as.length + 1 - 1 = as.length := by omega
              rw [h₄]
            simp_all [h₃]
            <;> ring_nf at * <;> omega
          }) <;>
        (try
          {
            have h₁ : 0 < as.length + 1 := by omega
            have h₂ : 0 < (as.length + 1) := by omega
            have h₃ : 2 ^ (as.length + 1 - 1) = 2 ^ as.length := by
              have h₄ : as.length + 1 - 1 = as.length := by omega
              rw [h₄]
            simp_all [h₃]
            <;> ring_nf at * <;> omega
          }) <;>
        (try omega)
        <;>
        (try
          {
            simp_all [pow_succ]
            <;> ring_nf at *
            <;> omega
          })
  by_cases h₁ : l.length ≥ 1
  · exact h l h₁
  · have h₂ : l = [] := by
      by_contra h₃
      have h₄ : l.length ≥ 1 := by
        have h₅ : l ≠ [] := h₃
        have h₆ : l.length ≥ 1 := by
          cases l with
          | nil => contradiction
          | cons _ _ => simp
        exact h₆
      linarith
    simp [h₂, parts]
