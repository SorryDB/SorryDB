theorem theorem_1 (a b : ℕ) : (a = 7 ∧ b = 8) ∨ (a = 9 ∧ b = 7) → a + b = 15 := by
  intro h
  have h₁ : a + b = 15 := by
    cases h with
    | inl h₂ =>
      -- Case: a = 7 and b = 8
      have h₃ : a = 7 := h₂.1
      have h₄ : b = 8 := h₂.2
      rw [h₃, h₄]
      <;> norm_num
    | inr h₂ =>
      -- Case: a = 9 and b = 7
      have h₃ : a = 9 := h₂.1
      have h₄ : b = 7 := h₂.2
      rw [h₃, h₄]
      <;> norm_num
  exact h₁
