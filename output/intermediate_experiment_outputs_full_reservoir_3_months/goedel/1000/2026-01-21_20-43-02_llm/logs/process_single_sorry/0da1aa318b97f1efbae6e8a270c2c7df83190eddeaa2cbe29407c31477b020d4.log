```lean
namespace Ideal
variables {R : Type*} [CommRing R]

def chineseMap  : (R ⧸ ⨅ i, I i) →+* Π i, R ⧸ I i :=
  Quotient.lift (⨅ i, I i) (Pi.ringHom fun i : ι ↦ Quotient.mk (I i))
    (by
      intro x hx i
      simp only [Pi.sub_apply, Pi.zero_apply, smul_eq_mul] at hx ⊢
      -- The key step is to show that if x is in the intersection, then its image in each quotient is zero.
      -- Since x is in every I i, it maps to zero in every R / I i.
      have h : x ∈ I i := by
        -- x is in the intersection, so x is in I i for any i.
        apply Ideal.mem_of_mem_iInf hx
      -- Since x ∈ I i, the image of x in R / I i is zero.
      have h' : Quotient.mk (I i) x = 0 := by
        rw [Quotient.eq_zero_iff_mem]
        exact h
      simp [h'])
