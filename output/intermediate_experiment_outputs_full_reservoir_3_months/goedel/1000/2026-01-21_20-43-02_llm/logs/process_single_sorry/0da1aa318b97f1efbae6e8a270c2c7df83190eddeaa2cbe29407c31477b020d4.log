variable {R} [CommRing R]
variable {ι : Type} (I : ι → Ideal R)

def chineseMap  : (R ⧸ ⨅ i, I i) →+* Π i, R ⧸ I i :=
  Quotient.lift (⨅ i, I i) (Pi.ringHom fun i : ι ↦ Quotient.mk (I i))
    (by
      intro x hx i
      simp [hx, Ideal.subset_iInf, mem_inter_iff, Ideal.mem_ker]
      <;>
      exact inf_mem_left hx
    )

lemma chineseMap_mk (x : R) : chineseMap I (Quotient.mk _ x) = fun i : ι ↦ Quotient.mk (I i) x := rfl
lemma chineseMap_mk' (x : R) (i : ι) : chineseMap I (Quotient.mk _ x) i = Quotient.mk (I i) x := rfl

