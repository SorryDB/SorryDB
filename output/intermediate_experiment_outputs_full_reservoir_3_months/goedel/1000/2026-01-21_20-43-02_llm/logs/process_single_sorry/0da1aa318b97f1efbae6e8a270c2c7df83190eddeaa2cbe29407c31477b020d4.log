lemma chineseMap_injective : Injective (chineseMap I) := by
  refine' fun x y hxy => _
  have h : x = y := by
    classical
    have h₁ : x = y := by
      -- Use the injectivity of the Chinese map to deduce that x = y if their images are equal
      have h₂ : ∀ (i : ι), (x : Π i : ι, R ⧸ I i) i = (y : Π i : ι, R ⧸ I i) i := by
        intro i
        have h₃ := congr_fun hxy i
        simp_all [chineseMap_mk]
        <;>
        (try simp_all [chineseMap_mk']) <;>
        (try simp_all [Function.funext_iff]) <;>
        (try simp_all [Pi.ext_iff])
        <;>
        aesop
      -- Since all components are equal, the elements x and y are equal in the product ring
      have h₃ : x = y := by
        -- Use the fact that the Chinese map is injective to deduce that x = y
        apply Eq.symm
        apply Eq.symm
        simp_all [chineseMap_mk]
        <;>
        (try simp_all [chineseMap_mk']) <;>
        (try simp_all [Function.funext_iff]) <;>
        (try simp_all [Pi.ext_iff])
        <;>
        aesop
      exact h₃
    exact h₁
  exact h
