lemma chineseMap_injective : Injective (chineseMap I) := by
  rw [Function.Injective]
  intro x y h
  have h₁ : Ideal.Quotient.mk _ x = Ideal.Quotient.mk _ y := by
    -- We need to show that x = y given that chineseMap I x = chineseMap I y.
    -- We use the fact that the map is injective if its kernel is zero.
    -- We show that the difference x - y must be zero in the quotient ring.
    -- This follows from the injectivity of the map.
    apply Ideal.Quotient.eq_iff_mem.2
    -- We need to show that x - y is in the intersection of all I i.
    -- This is done by showing that it is in each I i.
    refine' fun i => _
    -- For each i, we use the fact that the projection maps are injective.
    -- Specifically, we use the fact that if the projections of x and y are equal,
    -- then their difference is in I i.
    have h₂ := congr_fun h i
    -- Simplify the expression to show that (x - y) is in I i.
    simp [chineseMap_mk', h] at h₂ ⊢
    <;>
    (try simp_all [Ideal.Quotient.mk_eq_mk_iff_sub_mem]) <;>
    (try simp_all [Ideal.Quotient.eq_zero_iff_mem]) <;>
    (try simp_all [sub_mem_iff_eq_add, add_comm]) <;>
    (try simp_all [Ideal.Quotient.induction_on])
    <;>
    (try aesop)
  -- Since x ≡ y mod ⨅ i, I i, we have x = y.
  rw [h₁]
