lemma chineseMap_injective : Injective (chineseMap I) := by
  rw [Function.Injective]
  intro x y hxy
  have h₁ : Quotient.mk (⨅ i, I i) x = Quotient.mk (⨅ i, I i) y := by
    -- We need to show that if their images are equal, then x and y are equal modulo the intersection.
    -- This is done by showing that x - y is in the intersection.
    have h₂ : x - y ∈ ⨅ i, I i := by
      -- For each i, x - y is in I i because the images of x and y in R / I i are the same.
      refine' Ideal.mem_iInf.2 fun i => _
      have h₃ : (chineseMap I (Quotient.mk (⨅ i, I i) x)) i = (chineseMap I (Quotient.mk (⨅ i, I i) y)) i := by
        rw [hxy]
      have h₄ : (chineseMap I (Quotient.mk (⨅ i, I i) x)) i = Quotient.mk (I i) x := by
        simp [chineseMap_mk]
        <;>
        aesop
      have h₅ : (chineseMap I (Quotient.mk (⨅ i, I i) y)) i = Quotient.mk (I i) y := by
        simp [chineseMap_mk]
        <;>
        aesop
      rw [h₄] at h₃
      rw [h₅] at h₃
      have h₆ : Quotient.mk (I i) x = Quotient.mk (I i) y := by
        exact h₃
      have h₇ : x - y ∈ I i := by
        rw [← Quotient.eq_zero_iff_mem]
        simp_all [Quotient.ext_iff]
        <;>
        ring_nf at *
        <;>
        simp_all
      exact h₇
    -- Since x - y is in the intersection, x and y are equal modulo the intersection.
    have h₃ : Quotient.mk (⨅ i, I i) x = Quotient.mk (⨅ i, I i) y := by
      rw [Quotient.eq_iff_mem]
      simpa [Ideal.mem_iInf] using h₂
    exact h₃
  -- Therefore, x and y are equal modulo the intersection.
  exact h₁
