  refine' fun x y h => _
  have h₁ : (chineseMap I : R ⧸ ⨅ i : ι, I i →+* Π i : ι, R ⧸ I i) x = (chineseMap I : R ⧸ ⨅ i : ι, I i →+* Π i : ι, R ⧸ I i) y := h
  -- To prove that `x = y`, we will show that their representatives in R are related modulo the intersection of the ideals.
  have h₂ : (x : Π i : ι, R ⧸ I i) = (y : Π i : ι, R ⧸ I i) := by
    simpa [chineseMap_mk] using h₁.congr_arg (fun x => x)
  -- For each ideal index `i`, the elements `x` and `y` are in the same equivalence class modulo `I i`.
