lemma chineseMap_injective : Injective (chineseMap I) := by
  rw [Function.Injective]
  intro x y h
  -- Assume chineseMap I x = chineseMap I y
  have h₁ : ∀ (i : ι), (Quotient.mk (I i)) (x.val) = (Quotient.mk (I i)) (y.val) := by
    intro i
    have h₂ := congr_fun h i
    simpa [chineseMap_mk] using h₂
  -- For all i : ι, we get Quotient.mk (I i) x = Quotient.mk (I i) y
  -- This implies x - y ∈ ⨅ i, I i
  have h₂ : x.val - y.val ∈ ⨅ (i : ι), I i := by
    -- We need to show x - y ∈ I i for all i
    have h₃ : ∀ (i : ι), x.val - y.val ∈ I i := by
      intro i
      have h₄ : (Quotient.mk (I i)) (x.val - y.val) = 0 := by
        calc
          (Quotient.mk (I i)) (x.val - y.val) = (Quotient.mk (I i)) (x.val) - (Quotient.mk (I i)) (y.val) := by
            simp [Quotient.mk_eq_zero]
            <;>
            simp_all [sub_eq_add_neg, add_assoc]
          _ = 0 := by
            have h₅ := h₁ i
            simp [h₅, sub_self]
      -- Since (x - y) + I i = 0, x - y ∈ I i
      have h₅ : x.val - y.val ∈ I i := by
        simpa [Quotient.eq_zero_iff_mem] using h₄
      exact h₅
    -- Take the intersection over all i
    exact Ideal.inter_mem _ h₃
  -- Since x - y ∈ ⨅ i, I i, we have x = y in R ⧸ ⨅ i, I i
  have h₃ : x = y := by
    have h₄ : x.val - y.val ∈ x.2 := by
      have h₅ : x.val - y.val ∈ ⨅ (i : ι), I i := h₂
      have h₆ : (⨅ (i : ι), I i) ≤ x.2 := by
        apply Ideal.inf_le_left
      exact h₆ h₅
    have h₅ : x.val ≡ y.val [MOD x.2] := by
      rw [ModEq]
      exact h₄
    -- Since x and y have the same value in the quotient, they are equal
    have h₆ : x = y := by
      apply Quotient.eq
      exact h₅
    exact h₆
  -- Therefore, x = y
  exact h₃
