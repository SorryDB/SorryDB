theorem is_pamphibian (a : ã) : a = 0 ã´ a = 1 ã´ a = 2 ã is_pamphibian a := by
  intro h
  cases h with
  | inl h =>
    -- Case: a = 0
    rw [h]
    simp [is_pamphibian]
    -- For a = 0, no conditions need to be satisfied because there are no primes < 0.
  | inr h =>
    cases h with
    | inl h =>
      -- Case: a = 1
      rw [h]
      simp [is_pamphibian]
      -- For a = 1, the primes < 1 are none, so the condition is vacuously true.
    | inr h =>
      -- Case: a = 2
      rw [h]
      simp [is_pamphibian]
      <;> norm_num
      -- For a = 2, the primes < 2 are none, so the condition is vacuously true.
