namespace LO.Propositional

namespace Axioms

variable {F : Type*} [LogicalConnective F]
variable (φ ψ χ : F)

protected alias PCon₁ := LO.Axioms.Dummett

protected abbrev PCon₂ := (φ ➝ ψ) ➝ ((φ ➝ ψ) ➝ φ)

protected abbrev PCon₃ := (φ ➝ ψ) ➝ ((φ ➝ ψ) ➝ ψ)

protected abbrev PCon₄ := (φ ➝ ψ ⋎ χ) ➝ (φ ➝ ψ) ⋎ (φ ➝ χ)

protected abbrev PCon₅ := (φ ⋏ ψ ⋎ χ) ➝ (φ ➝ χ) ⋎ (φ ➝ ψ)

protected abbrev PCon₆ := ((φ ➝ ψ) ➝ ψ) ⋏ ((ψ ➝ φ) ➝ φ) ➝ (φ ⋎ ψ)

end Axioms


open Kripke2
open Formula.Kripke2

namespace Kripke2

variable {F : Kripke2.Frame} {φ ψ : Formula ℕ}

namespace Frame

protected abbreviation IsPiecewiseConnected (F : Kripke2.Frame) := _root_.IsPiecewiseConnected F_rel

@[grind →] lemma p_connected [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≺ z ∨ y = z ∨ z ≺ y := by
  intro x y z hxy hxz
  have h : y ≺ z ∨ y = z ∨ z ≺ y := by
    apply (inferInstance : IsPiecewiseConnected F).p_connected y z
    <;> (try { trivial }) <;> (try { assumption })
    <;> (try { have := hxy; exact ⟨y, by assumption⟩ }) <;> (try { have := hxz; exact ⟨z, by assumption⟩ })
  exact h

@[grind →] lemma p_connected' [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≠ z → y ≺ z ∨ z ≺ y := by
  intro x y z hxy hxz hne
  have h : y ≺ z ∨ y = z ∨ z ≺ y := p_connected hxy hxz
  cases h with
  | inl h =>
    exact Or.inl h
  | inr h =>
    cases h with
    | inl h =>
      exfalso
      apply hne
      exact h
    | inr h =>
      exact Or.inr h

end Frame

