theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
  have h1 : (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx ((List.take (idx + 1) (l.map List.length)).sum - 1) := by sorry
  have h2 : l1[idx1] = (l.set idx l1).flatten[((List.take (idx + 1) (l.map List.length)).sum - 1)] := by sorry
  refine' ⟨⟨(List.take (idx + 1) (l.map List.length)).sum - 1, _⟩, _⟩ <;>
    (try omega) <;>
    (try simp_all) <;>
    (try
      norm_num [List.length_take, List.length_map, List.map, List.take] at *
      <;>
      omega)
  <;> simp_all [List.length_take, List.length_map, List.map, List.take]
  <;> norm_num at *
  <;> omega
