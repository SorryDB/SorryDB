      "\n    have h₁ : (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.erase (l1[idx1]) := by\n      have h₂ : ∀ (l : List (List α)) (l1 : List α) (idx : ℕ) (hidx : idx < l.length) (el : α),\n          (l.set idx (l1.erase el)).flatten = (l.set idx l1).flatten.erase el := by\n        intro l l1 idx hidx el\n        induction' l with hd tl IH generalizing l1 idx := by\n        cases l with\n        | nil =>\n          simp_all [List.length]\n          <;> contradiction\n        | cons hd tl =>\n          cases' Nat.eq_zero_or_pos (idx + 1) with h h\n          <;> simp_all [List.length, List.get?)\n          <;>\n          (try { omega }) <;>\n          (try {\n            simp_all [List.set]\n            <;>\n            (try { aesop }) <;>\n            (try {\n              simp_all [List.erase, List.erase?, List.map, List.flatten]\n              <;>\n              aesop\n            })\n          }) <;>\n          (try {\n            simp_all [List.set]\n            <;>\n            (try { aesop }) <;>\n            (try {\n              simp_all [List.erase, List.erase?, List.map, List.flatten]\n              <;>\n              aesop\n            })\n          }) <;>\n          (try {\n            simp_all [List.set]\n            <;>\n            (try { aesop }) <;>\n            (try {\n              simp_all [List.erase, List.erase?, List.map, List.flatten]\n              <;>\n              aesop\n            })\n          }) <;>\n          (try {\n            simp_all [List.set]\n            <;>\n            (try { aesop }) <;>\n            (try {\n              simp_all [List.erase, List.erase?, List.map, List.flatten]\n              <;>\n              aesop\n            })\n          })\n        <;>\n        (try {\n          simp_all [List.set]\n          <;>\n          (try { aesop }) <;>\n          (try {\n            simp_all [List.erase, List.erase?, List.map, List.flatten]\n            <;>\n            aesop\n          })\n        })\n    