      have h₃ : k - us.length ≤ vs.length := by
        simp [h₁, h₂] at *
        <;> omega
      vs[k - us.length]!
    else
      select (k - (m + n)) ws (by
        -- We need to prove that k - (m + n) ≤ ws.length.
        -- First, note that m = us.length and n = vs.length.
        -- By the hypothesis h₂, we have k > m + n.
        -- From the fact that partition3 respects the length of the original list,
        -- we have xs.length = m + n + ws.length.
        -- Since k ≤ xs.length and k > m + n, it follows that k - (m + n) ≤ ws.length.
        have h₃ : m = us.length := rfl
        have h₄ : n = vs.length := rfl
