def median (xs : List a) : a :=
  let k := (xs.length + 1) / 2
  select₀ k xs

def group (n : Nat) (xs : List a) : List (List a) :=
  if      h₁ : n = 0   then []
  else if h₂ : xs = [] then []
  else
