```lean
partial def select
  (k : Nat) (xs : List a) (ok : k ≤ xs.length) : a :=
  match partition3 (pivot xs) xs with
  | (us, vs, ws) =>
    let m := us.length
    let n := vs.length
    if         h₁ : k ≤ m then select k us (by
      have h₂ : us.length = m := rfl
      simp_all [h₂]
      <;> omega
    )
    else if    h₂ : k ≤ m + n then vs[k - m]!
    else select (k - m - n) ws (by
      have h₃ : k > m := by
        intro h₄
        apply lt_irrefl (0 : ℕ)
        have h₅ : k ≤ m := by omega
        omega
      have h₄ : k > m + n := by omega
      have h₅ : xs.length = us.length + vs.length + ws.length := by
        have h₆ : (partition3 (pivot xs) xs).1 ++ (partition3 (pivot xs) xs).2.1 ++ (partition3 (pivot xs) xs).2.2 = xs := by
          simp [partition3]
          <;> rfl
        simp [h₆, List.length_append, List.length_append] at *
        <;>
        (try omega) <;>
        (try ring_nf at *) <;>
        (try omega)
      have h₆ : k ≤ xs.length := ok
      have h₇ : k - m - n ≤ ws.length := by
        have h₈ : m = us.length := rfl
        have h₉ : n = vs.length := rfl
        have h₁₀ : m + n = us.length + vs.length := by simp [h₈, h₉]
        have h₁₁ : m + n ≤ us.length + vs.length := by linarith
        have h₁₂ : us.length + vs.length + ws.length = xs.length := by
          have h₁₃ : (partition3 (pivot xs) xs).1 ++ (partition3 (pivot xs) xs).2.1 ++ (partition3 (pivot xs) xs).2.2 = xs := by
            simp [partition3]
            <;> rfl
          simp [h₁₃, List.length_append, List.length_append] at *
          <;>
          (try omega) <;>
          (try ring_nf at *) <;>
          (try omega)
        have h₁₃ : k - m - n ≤ ws.length := by
          omega
        exact h₁₃
      have h₈ : k - m - n ≤ ws.length := h₇
      have h₉ : k - m - n ≤ ws.length := h₈
      omega
    )
