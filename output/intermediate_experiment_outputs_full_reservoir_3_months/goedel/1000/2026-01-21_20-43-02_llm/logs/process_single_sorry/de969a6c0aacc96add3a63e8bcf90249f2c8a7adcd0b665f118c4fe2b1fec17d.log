  (k : Nat) (xs : List a) (ok : k ≤ xs.length) : a :=
  match partition3 (pivot xs) xs with
  | (us, vs, ws) =>
    let m := us.length
    let n := vs.length
    if         h₁ : k ≤ m then select k us (by
      -- We need to prove that k ≤ us.length.
      -- From the given hypothesis h₁ : k ≤ m and the definition m := us.length,
      -- it follows directly that k ≤ us.length.
      have h₂ : m = us.length := rfl
      linarith
