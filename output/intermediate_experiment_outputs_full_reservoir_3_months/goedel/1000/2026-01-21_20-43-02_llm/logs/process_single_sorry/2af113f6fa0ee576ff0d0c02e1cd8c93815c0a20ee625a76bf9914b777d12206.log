      have h₅₅ : |2 * f z * g x| = 2 * |f z| * |g x| := by
        calc
          |2 * f z * g x| = |(2 : ℝ) * f z * g x| := by ring_nf
          _ = (2 : ℝ) * |f z| * |g x| := by
            simp [abs_mul, abs_of_nonneg, show (0 : ℝ) ≤ 2 by norm_num]
            <;>
            ring_nf
            <;>
            simp [abs_mul]
            <;>
            ring_nf
      have h₅₆ : 2 * |f z| * |g x| ≤ |f (z + x)| + |f (z - x)| := by
        linarith
      linarith
    -- Step 3: Use the boundedness of f to derive a contradiction
    have h₆ : |f (z + x)| ≤ 1 := h₂ (z + x)
    have h₇ : |f (z - x)| ≤ 1 := h₂ (z - x)
    have h₈ : |f z| ≤ 1 := h₂ z
    have h₉ : 2 * |f z| * |g x| ≤ 2 := by
      linarith
    have h₁₀ : 2 * |f z| * |g x| > 2 := by
      have h₁₁ : |g x| > 1 := by linarith
      have h₁₂ : |f z| > 0 := by
        have h₁₃ : f z ≠ 0 := hz
        have h₁₄ : |f z| > 0 := abs_pos.mpr h₁₃
        exact h₁₄
      have h₁₃ : 2 * |f z| * |g x| > 2 * |f z| * 1 := by
        have h₁₄ : |g x| > 1 := by linarith
        have h₁₅ : 2 * |f z| > 0 := by positivity
        nlinarith
      have h₁₄ : 2 * |f z| * 1 = 2 * |f z| := by ring
      have h₁₅ : 2 * |f z| ≥ 2 * |f z| := by linarith
      have h₁₆ : 2 * |f z| * 1 = 2 * |f z| := by ring
      have h₁₇ : 2 * |f z| * |g x| > 2 * |f z| := by linarith
      have h₁₈ : 2 * |f z| ≥ 0 := by positivity
      have h₁₉ : 2 * |f z| * |g x| > 2 := by
        nlinarith [abs_nonneg (f z)]
      linarith
    linarith
  exact h₃
