 (f x₀) ^ 2 * (g y) ^ 2 ≤ 4 := by linarith\n    have h₁₄ : (f x₀) ^ 2 > 0 := by\n      have h₁₅ : f x₀ ≠ 0 := hx₀\n      have h₁₆ : (f x₀) ^ 2 > 0 := by positivity\n      exact h₁₆\n    have h₁₅ : (g y) ^ 2 ≤ 1 / (f x₀) ^ 2 := by\n      have h₁₆ : 4 * (f x₀) ^ 2 * (g y) ^ 2 ≤ 4 := h₁₃\n      have h₁₇ : 0 < (f x₀) ^ 2 := h₁₄\n      have h₁₈ : (g y) ^ 2 ≤ 1 / (f x₀) ^ 2 := by\n        calc\n          (g y) ^ 2 = (1 / 4) * (4 * (g y) ^ 2) := by ring\n          _ ≤ (1 / 4) * (4 / (f x₀) ^ 2) := by\n            have h₁₉ : 4 * (f x₀) ^ 2 * (g y) ^ 2 ≤ 4 := h₁₃\n            have h₂₀ : 0 < (f x₀) ^ 2 := h₁₄\n            have h₂₁ : 4 * (g y) ^ 2 ≤ 4 / (f x₀) ^ 2 := by\n              calc\n                4 * (g y) ^ 2 = (4 * (f x₀) ^ 2 * (g y) ^ 2) / (f x₀) ^ 2 := by\n                  field_simp [h₁₄.ne']\n                  <;> ring\n                  <;> field_simp [h₁₄.ne']\n                  <;> ring\n                _ ≤ 4 / (f x₀) ^ 2 := by\n                  apply div_le_div_of_le_of_nonneg _ (by positivity)\n                  nlinarith\n            nlinarith\n          _ = 1 / (f x₀) ^ 2 := by ring\n      exact h₁₈\n    have h₁₆ : (g y) ^ 2 ≤ 1 := by\n      have h₁₇ : |f x₀| ≤ 1 := h₂ x₀\n      have h₁₈ : (f x₀) ^ 2 ≤ 1 := by\n        have h₁₉ : -1 ≤ f x₀ := by linarith [abs_le.mp h₁₇]\n        have h₂₀ : f x₀ ≤ 1 := by linarith [abs_le.mp h₁₇]\n        nlinarith\n      have h₂₁ : 1 / (f x₀) ^ 2 ≥ 1 := by\n        have h₂₂ : 0 < (f x₀) ^ 2 := h₁₄\n        have h₂₃ : (f x₀) ^ 2 ≤ 1 := h₁₈\n        have h₂₄ : 1 / (f x₀) ^ 2 ≥ 1 := by\n          rw [ge_iff_le]\n          rw [le_div_iff (by positivity)]\n          nlinarith\n        exact h₂₄\n      have h₂₂ : (g y) ^ 2 ≤ 1 / (f x₀) ^ 2 := h₁₅\n      have h₂₃ : 1 / (f x₀) ^ 2 ≥ 1 := h₂₁\n      nlinarith\n    have h₁₇ : g y ≥ -1 := by\n      nlinarith [sq_nonneg (g y + 1)]\n    exact h₁₇\n\n  intro x\n  have h₆ : g x ≤ 1 := h₄ x\n  have h₇ : g x ≥ -1 := h₅ x\n  have h₈ : |g x| ≤ 1 := by\n    rw [abs_le]\n    constructor <;