        have h₃₁ : (g y) ^ 2 ≤ 1 := by
          by_contra h₃₂
          have h₃₃ : (g y) ^ 2 > 1 := by linarith
          have h₃₄ : (2 * f x * g y) ^ 2 > 4 * (f x) ^ 2 := by
            nlinarith [sq_pos_of_ne_zero hx, sq_nonneg (g y)]
          have h₃₅ : (f (x + y) + f (x - y)) ^ 2 = (2 * f x * g y) ^ 2 := by
            rw [h₁₄]
          nlinarith [h₂₃]
        nlinarith [sq_nonneg (f x)]
