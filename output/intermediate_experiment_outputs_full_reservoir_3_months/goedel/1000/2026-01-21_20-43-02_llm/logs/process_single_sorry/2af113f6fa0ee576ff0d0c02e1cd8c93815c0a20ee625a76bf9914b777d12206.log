theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  have h₃ : ∃ x, f x ≠ 0 := by
    by_contra h
    push_neg at h
    have h₄ : ∀ x, f x = 0 := by simpa using h
    exact h₁ h₄
  
  have h₄ : ∀ x, |g x| ≤ 1 := by
    intro y
    by_contra! h₅
    have h₆ : g y > 1 ∨ g y < -1 := by
      cases' le_or_lt 0 (g y) with h₇ h₇
      · -- Case: g y ≥ 0
        have h₈ : g y > 1 := by linarith
        exact Or.inl h₈
      · -- Case: g y < 0
        have h₈ : g y < -1 := by linarith
        exact Or.inr h₈
    -- We will derive a contradiction from the assumption |g y| > 1
    cases' h₃ with x₀ hx₀
    have h₇ : |f x₀| ≤ 1 := h₂ x₀
    have h₈ : |f (x₀ + y)| ≤ 1 := h₂ (x₀ + y)
    have h₉ : |f (x₀ - y)| ≤ 1 := h₂ (x₀ - y)
    have h₁₀ : f (x₀ + y) + f (x₀ - y) = 2 * f x₀ * g y := h₀ x₀ y
    have h₁₁ : f (x₀ + y) + f (x₀ - y) = 2 * f x₀ * g y := by rw [h₁₀]
    have h₁₂ : (f (x₀ + y) + f (x₀ - y)) ^ 2 = (2 * f x₀ * g y) ^ 2 := by rw [h₁₁]
    have h₁₃ : (f (x₀ + y) + f (x₀ - y)) ^ 2 ≤ 4 := by
      have h₁₄ : f (x₀ + y) + f (x₀ - y) ≤ 2 := by
        linarith [abs_le.mp h₈, abs_le.mp h₉]
      have h₁₅ : f (x₀ + y) + f (x₀ - y) ≥ -2 := by
        linarith [abs_le.mp h₈, abs_le.mp h₉]
      nlinarith
    have h₁₄ : (2 * f x₀ * g y) ^ 2 > 4 * (f x₀) ^ 2 := by
      have h₁₅ : (g y) ^ 2 > 1 := by
        cases' h₆ with h₆ h₆
        · -- Case: g y > 1
          nlinarith
        · -- Case: g y < -1
          nlinarith
      have h₁₆ : (f x₀) ^ 2 ≥ 0 := by nlinarith
      nlinarith [sq_nonneg (f x₀)]
    have h₁₅ : 4 * (f x₀) ^ 2 ≥ (f (x₀ + y) + f (x₀ - y)) ^ 2 := by
      nlinarith [abs_le.mp h₈, abs_le.mp h₉, sq_nonneg (f (x₀ + y) - f (x₀ - y))]
    nlinarith [h₁₄, h₁₅]
  
  exact h₄
