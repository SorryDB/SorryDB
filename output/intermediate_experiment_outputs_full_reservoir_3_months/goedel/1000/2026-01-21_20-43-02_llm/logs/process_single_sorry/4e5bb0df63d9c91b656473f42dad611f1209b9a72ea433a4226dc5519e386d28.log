theorem not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    <;>
    (try {
      intro h₀ h₁;
      have h₂ := T.imp_closed;
      have h₃ := T.andIR;
      simp_all [Set.mem_insert_iff]
      <;>
      (try {
        aesop
      })
      <;>
      (try {
        norm_num at *
        <;>
        aesop
      })
    })
    <;>
    (try {
      aesop
    })
    <;>
    (try {
      norm_num at *
      <;>
      aesop
    })
  | succ i ih =>
    simp [construction] at *
    <;>
    (try {
      split_ifs at * <;>
      (try {
        simp_all [Set.mem_insert_iff]
        <;>
        (try {
          aesop
        })
        <;>
        (try {
          norm_num at *
          <;>
          aesop
        })
      })
      <;>
      (try {
        aesop
      })
      <;>
      (try {
        norm_num at *
        <;>
        aesop
      })
    })
    <;>
    (try {
      aesop
    })
    <;>
    (try {
      norm_num at *
      <;>
      aesop
    })
