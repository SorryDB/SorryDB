theorem encode_add_one_identity (n : ℕ) : encode (n + 1) = n.succ := rfl

theorem decode_eq_none_iff {n : ℕ} : decode n = none ↔ n = 0 := by
  simp [decode_eq_self]
  <;>
  omega

theorem decode_eq_some_iff {n : ℕ} {δ : Formula ℕ} : decode n = some δ ↔
  δ = (n : ℕ) ∧ n ≠ 0 := by
  simp [decode_eq_self]
  <;>
  constructor <;>
  intro h <;>
  (try { aesop }) <;>
  (try {
    cases n <;>
    simp_all [Nat.succ_eq_add_one, fol.ofFormula] <;>
    (try { aesop }) <;>
    (try { contradiction }) <;>
    (try { omega }) <;>
    (try { ring_nf at * <;> aesop })
  }) <;>
  (try {
    aesop
  }) <;>
  (try {
    omega
  })

