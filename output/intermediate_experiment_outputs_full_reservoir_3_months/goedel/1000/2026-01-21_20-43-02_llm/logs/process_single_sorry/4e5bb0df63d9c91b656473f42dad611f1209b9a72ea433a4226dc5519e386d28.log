    dsimp [construction] at hi;
    cases Classical.em (∀ Γ : Finset (Formula ℕ), ↑Γ ⊆ construction T hT i → Γ.conj ⋏ (Classical.choose (Classical.dec_constructive (decode i))) ➝ ξ ∉ T.theory) with
    | inl h₁ =>
