            })
          exact h₂
        })
        <;>
        (try {
          simp_all [Finset.subset_iff]
          <;>
          aesop
        })
      simp_all [Finset.subset_iff]
      <;>
      (try {
        exfalso
        simp_all [Finset.subset_iff]
        <;>
        aesop
      })
    }) <;>
    (try {
      simp_all [Finset.subset_iff]
      <;>
      (try {
        exfalso
        simp_all [Finset.subset_iff]
        <;>
        aesop
      })
    }) <;>
    (try {
      aesop
    }) <;>
    (try {
      exfalso
      simp_all [Finset.subset_iff]
      <;>
      aesop
    })
