def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same =>
      -- Directly use the list of trees constructed in the derivation
      (ContextFreeDerivation.collectDerivationTree h_same)
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound =>
      -- If it's a step, use the list of trees constructed in the derivation
      ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive sorry)[0]'sorry).fst
