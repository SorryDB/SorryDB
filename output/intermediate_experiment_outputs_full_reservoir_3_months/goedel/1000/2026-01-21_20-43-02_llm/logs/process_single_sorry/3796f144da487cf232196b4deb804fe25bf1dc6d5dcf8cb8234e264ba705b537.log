def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same =>
      have h₁ : u = v := by
        simpa [h_same] using cfd.val
      have h₂ : cfd = ContextFreeDerivation.same u (by simpa [h₁] using h_same) := by
        rfl
      rw [h₂]
      exact DerivationTree.leaf none
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      have h : 0 < List.length (ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive ⋯) := by
        have h₁ : cfd = ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound := h_constructor
        rw [h₁] at *
        <;> simp_all [ContextFreeDerivation.collectDerivationTreeNodes, List.length]
        <;>
        (try simp_all [List.length]) <;>
        (try norm_num) <;>
        (try omega)
        <;>
        (try contradiction) <;>
        (try aesop)
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive ⋯)[0]'h).fst
