      "\n    have h2 : g'' = (fun t : ℝ => ∑ i : Fin n, ∑ j : Fin n, (y i - x i) * (y j - x j) * (nth_partial i (nth_partial j f) (interpolator x y t))) := rfl\n    rw [h2]\n    apply Continuous.sum\n    intro i _\n    apply Continuous.sum\n    intro j _\n    have h3 : Continuous (fun t : ℝ => (y i - x i) * (y j - x j) * (nth_partial i (nth_partial j f) (interpolator x y t))) := by\n      have h4 : Continuous (fun t : ℝ => interpolator x y t) := by\n        have h5 : Differentiable ℝ (interpolator x y) := g₀_diff\n        exact h5.continuous\n      have h6 : Continuous (fun t : ℝ => nth_partial i (nth_partial j f) (interpolator x y t)) := by\n        have h7 : ContDiff ℝ 0 (nth_partial i (nth_partial j f)) := by\n          have h8 : ContDiff ℝ 2 f := fc\n          have h9 : ContDiff ℝ 1 (nth_partial j f) := by\n            exact contDiff_id.nth_partial j |>.comp (h8.nth_partial) _\n          have h10 : ContDiff ℝ 0 (nth_partial i (nth_partial j f)) := by\n            exact contDiff_id.nth_partial i |>.comp (h9.nth_partial) _\n          exact h10\n        have h11 : Continuous (fun t : ℝ => nth_partial i (nth_partial j f) (interpolator x y t)) := by\n          have h12 : Continuous (fun t : ℝ => interpolator x y t) := g₀_diff.continuous\n          exact h7.continuous.continuousAt |>.comp h12\n        exact h11\n      have h13 : Continuous (fun t : ℝ => (y i - x i) * (y j - x j) * (nth_partial i (nth_partial j f) (interpolator x y t))) := by\n        have h14 : Continuous (fun t : ℝ => (y i - x i) * (y j - x j)) := by\n          have h15 : Continuous (fun t : ℝ => (y i - x i)) := continuous_const\n          have h16 : Continuous (fun t : ℝ => (y j - x j)) := continuous_const\n          have h17 : Continuous (fun t : ℝ => (y i - x i) * (y j - x j)) := by\n            apply Continuous.mul\n            · exact h15\n            · exact h16\n          exact h17\n        have h18 : Continuous (fun t : ℝ => (nth_partial i (nth_partial j f) (interpolator x y t))) := h6\n        have h19 : Continuous (fun t : ℝ => (y i - x i) * (y j - x j) * (nth_partial i (nth_partial j f) (interpolator x y t))) := by\n          apply Continuous.mul\n          · exact h14\n          · exact h18\n        exact h19\n      exact h13\n    exact h3\n  sorry",
      "\n    have h : Continuous g'' := by\n      -- Prove that g'' is continuous using the continuity of f and its partial derivatives\n      have h₁ : ContDiff ℝ 2 f := fc\n      have h₂ : Continuous f := by\n        exact h₁.continuous\n      have h₃ : ∀ (i : Fin n), Continuous (nth_partial i f) := by\n        intro i\n        have h₄ : ContDiff ℝ 2 f := fc\n        have h₅ : ContDiff ℝ 1 (nth_partial i f) := by\n          apply ContDiff.nth_partial\n          <;> simp_all [h₄]\n          <;> norm_num\n          <;> linarith\n        exact h₅.continuous\n      have h₄ : ∀ (i j : Fin n), Continuous (nth_partial i (nth_partial j f)) := by\n        intro i j\n        have h₅ : ContDiff ℝ 2 f := fc\n        have h₆ : ContDiff ℝ 0 (nth_partial i (nth_partial j f)) := by\n          have h₇ : ContDiff ℝ 2 f := fc\n          have h₈ : ContDiff ℝ 1 (nth_partial j f) := by\n            apply ContDiff.nth_partial\n            <;> simp_all [h₇]\n            <;> norm_num\n            <;> linarith\n          have h₉ : ContDiff ℝ 0 (nth_partial i (nth_partial j f)) := by\n            apply ContDiff.nth_partial\n            <;> simp_all [h₈]\n            <;> norm_num\n            <;> linarith\n          exact h₉\n        exact h₆.continuous\n      -- Use the continuity of the partial derivatives to prove the continuity of g''\n      have h₅ : Continuous g'' := by\n        -- g'' is a sum of products of continuous functions, hence continuous\n        have h₆ : Continuous fun t : ℝ => ∑ i : Fin n, ∑ j : Fin n, (y i - x i) * (y j - x j) * (nth_partial i (nth_partial j f)) ((1 - t) • x + t • y) := by\n          apply Continuous.tsum\n          intro i\n          apply Continuous.tsum\n          intro j\n          have h₇ : Continuous fun t : ℝ => (y i - x i) * (y j - x j) * (nth_partial i (nth_partial j f)) ((1 - t) • x + t • y) := by\n            have h₈ : Continuous fun t : ℝ => (1 - t : ℝ) := by continuity\n            have h₉ : Continuous fun t : ℝ => (t : ℝ) := by continuity\n            have h₁₀ : Continuous fun t : ℝ => ((1 - t) • x + t • y : E n) := by\n              continuity\n            have h₁₁ : Continuous (nth_partial i (nth_partial j f)) := h₄ i j\n            have h₁₂ : Continuous fun t : ℝ => (nth_partial i (nth_partial j f)) ((1 - t) • x + t • y) := by\n              apply Continuous.comp (h₄ i j) h₁₀\n            have h₁₃ : Continuous fun t : ℝ => (y i - x i : ℝ) := by continuity\n            have h₁₄ : Continuous fun t : ℝ => (y j - x j : ℝ) := by continuity\n            have h₁₅ : Continuous fun t : ℝ => (y i - x i : ℝ) * (y j - x j : ℝ) := by\n              continuity\n            have h₁₆ : Continuous fun t : ℝ => (y i - x i : ℝ) * (y j - x j : ℝ) * (nth_partial i (nth_partial j f)) ((1 - t) • x + t • y) := by\n              continuity\n            exact h₁₆\n          exact h₇\n        simpa [g''] using h₆\n      exact h₅\n    exact h\n  sorry",
