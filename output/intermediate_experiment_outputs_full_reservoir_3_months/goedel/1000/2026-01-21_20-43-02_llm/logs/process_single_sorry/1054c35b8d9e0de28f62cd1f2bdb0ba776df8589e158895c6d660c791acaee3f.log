    (mpb : mixed_partials_bounded f x) :
    |f x - f y| ≤ ε * ∑ i, |nth_partial i f x| + (n^2 / 2) * ε^2 := by
  let g₀ := interpolator x y
  let g := interpolated x y f
  let g' := interpolated_deriv x y f
  let g'' := interpolated_deriv2 x y f
  have f_diff : Differentiable ℝ f := fc.differentiable (by norm_num)
  have g₀_diff : Differentiable ℝ g₀ := Differentiable.interpolator x y
  have g_diff : Differentiable ℝ g := Differentiable.interpolated x y f fc
  have g'_diff : Differentiable ℝ g' := by
    have h₁ : g' = fun t => interpolated_deriv x y f t := rfl
    rw [h₁]
    have h₂ : Differentiable ℝ (fun t : ℝ => interpolated_deriv x y f t) := by
      -- Prove that the first derivative is differentiable
      -- Use the fact that the second partial derivatives are continuous
      -- to show that the first derivative is differentiable
      apply differentiable_of_subset (ball 0 1) (ball 0 1)
      intro x hx
      have h₃ : ContDiff ℝ 2 f := fc
      have h₄ : Differentiable ℝ f := fc.differentiable (by norm_num)
      -- Use the fact that the second partial derivatives are continuous to show differentiability
      -- of the first derivative
      have h₅ : Differentiable ℝ (fun t : ℝ => interpolated_deriv x y f t) := by
        -- Use the fact that the second partial derivatives are continuous to show differentiability
        -- of the first derivative
        sorry
      exact h₅
    exact h₂
  have g'_cont : Continuous g' := by fun_prop
  have g''_cont : Continuous g'' := by
    have h₁ : g'' = fun t => interpolated_deriv2 x y f t := rfl
    rw [h₁]
    -- Prove that the second derivative is continuous
    -- Use the fact that the second partial derivatives are continuous
    -- to show that the second derivative is continuous
    have h₂ : Continuous (fun t : ℝ => interpolated_deriv2 x y f t) := by
      -- The second derivative is a sum of products of continuous functions
      -- because the second partial derivatives are continuous
      have h₃ : ContDiff ℝ 2 f := fc
      have h₄ : Differentiable ℝ f := fc.differentiable (by norm_num)
      -- Use the fact that the second partial derivatives are continuous to show continuity
      -- of the second derivative
      sorry
    exact h₂
  have h₁ : |f x - f y| ≤ ε * ∑ i : Fin n, |nth_partial i f x| + (n ^ 2 / 2 : ℝ) * ε ^ 2 := by sorry
  exact h₁
