import HTPILib.Chap8Part2
namespace HTPI.Exercises

open Classical

/- Section 8.1 -/
-- 1.
--Hint:  Use Exercise_6_1_16a2 from the exercises of Section 6.1
lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by sorry

-- 2.
lemma fnz_fzn : fnz ∘ fzn = id  := by sorry

-- 3.
lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := by sorry

-- 4.
lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by sorry

-- 5.
example {U V : Type} (f : U → V) : range f = Ran (graph f) := by sorry

-- 6.
lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · -- Prove the forward direction: if f is onto, then range f = Univ V
    intro h
    have h₂ : range f = Univ V := by
      apply Set.ext
      intro x
      simp only [Set.mem_univ, iff_true_iff]
      simp [Set.mem_range]
      -- For any x : V, since f is onto, there exists an element u : U such that f u = x
      have h₃ : ∃ (u : U), f u = x := by
        have h₄ : ∀ (y : V), ∃ (u : U), f u = y := by
          intro y
          exact h y
        exact h₄ x
      -- Therefore, x is in the range of f
      aesop
    exact h₂
  · -- Prove the reverse direction: if range f = Univ V, then f is onto
    intro h
    have h₂ : onto f := by
      intro y
      -- Since range f = Univ V, for any y : V, y is in the range of f
      have h₃ : y ∈ range f := by
        have h₄ : y ∈ (Univ V : Set V) := by simp
        have h₅ : (Univ V : Set V) = range f := by
          rw [h]
        rw [h₅] at h₄
        exact h₄
      -- Therefore, there exists an element u : U such that f u = y
      obtain ⟨x, hx⟩ := h₃
      exact ⟨x, by simp_all⟩
    exact h₂
``` 

This proof directly addresses the goal by replacing the `sorry` with a detailed, two-way proof of the equivalence. It uses Lean's `Set.ext` to compare the sets `range f` and `Univ V`, and `aesop` to handle the existential quantifier in the forward direction. The reverse direction uses the fact that if `range f = Univ V`, then every `y : V` is in `range f`, which means `f` is onto. The proof is structured to avoid unnecessary complications and directly mirrors the logical equivalence.  

