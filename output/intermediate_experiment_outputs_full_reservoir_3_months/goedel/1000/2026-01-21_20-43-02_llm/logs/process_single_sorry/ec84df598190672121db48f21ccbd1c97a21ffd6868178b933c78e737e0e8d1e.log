      have h1 : (range f : Set V) = (univ : Set V) := by
        simpa [Set.ext_iff] using hf
      rw [h1]
      trivial
    -- Simplify the membership condition to find the required x
    simp only [Set.mem_range] at hy
    obtain ⟨x, rfl⟩ := hy
    exact ⟨x, rfl⟩
