theorem onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · -- Prove the forward direction: if f is onto, then range f = Univ V
    intro hf
    apply Set.ext
    intro y
    simp only [Set.mem_univ, true_iff_iff, Set.mem_range]
    constructor
    · -- Prove the forward direction: if y is in range f, then y is in Univ V
      intro hy
