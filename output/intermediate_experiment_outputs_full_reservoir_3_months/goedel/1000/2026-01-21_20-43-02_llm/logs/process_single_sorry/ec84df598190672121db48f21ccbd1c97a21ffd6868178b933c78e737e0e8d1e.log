theorem onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · intro h
    apply Set.ext
    intro x
    simp only [range_eq_univ_iff h, Set.mem_univ]
  · intro h
    intro y
    have h₁ : y ∈ range f := by
      have h₂ : range f = (univ : Set V) := by
        simpa [Set.ext_iff] using h
      rw [h₂]
      exact Set.mem_univ y
    rcases h₁ with ⟨x, rfl⟩
    exact ⟨x, rfl⟩
