lemma runWithOracle_buildMerkleTree {s} (leaf_data_tree : LeafData α s) (f) :
    (runWithOracle f (buildMerkleTree leaf_data_tree))
    = buildMerkleTree_with_hash leaf_data_tree fun (left right : α) =>
      (f ⟨left, right⟩) := by
  match s with
  | Skeleton.leaf =>
    cases leaf_data_tree <;> simp_all [buildMerkleTree, buildMerkleTree_with_hash, runWithOracle_pure]
    <;> rfl
  | Skeleton.internal s_left s_right =>
    cases leaf_data_tree <;>
    simp_all [buildMerkleTree, buildMerkleTree_with_hash, runWithOracle_bind, function.comp_apply]
    <;>
    (try simp_all [Function.funext_iff]) <;>
    (try { ext ⟨x, y⟩; rfl }) <;>
    (try { simp_all [Pair.mk.inj_iff] }) <;>
    (try { ring_nf at * <;> aesop }) <;>
    (try {
      simp_all [Pair.mk.inj_iff]
      <;> aesop
    }) <;>
    (try {
      simp_all [Function.funext_iff]
      <;> aesop
    }) <;>
    (try {
      simp_all [Function.funext_iff, Pair.mk.inj_iff]
      <;> aesop
