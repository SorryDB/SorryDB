                _ = (∑ i : ι, f i ^ 2) * (∑ i : ι, g i ^ 2) := by rfl
            exact h₅
          _ = (∑ i : ι, f i ^ 2) * (∑ i : ι, g i ^ 2) := by rfl
      exact h₄
    exact h₁
  exact h_main
