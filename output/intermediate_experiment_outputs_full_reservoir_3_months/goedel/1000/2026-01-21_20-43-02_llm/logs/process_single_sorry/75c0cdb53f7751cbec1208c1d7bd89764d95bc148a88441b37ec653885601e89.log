lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
  have h₁ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
  have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toComplexMeasure ha x y).integral f‖ := rfl
  have h₃ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
    have h₄ : ‖(cfc_toLinearFunctional ha x y).apply f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
      have h₅ : ‖(cfc_toLinearFunctional ha x y).apply f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by
        calc
          ‖(cfc_toLinearFunctional ha x y).apply f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ :=
            ContinuousLinearMap.le_opNorm (cfc_toLinearFunctional ha x y) f
          _ = ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := by rfl
      calc
        ‖(cfc_toLinearFunctional ha x y).apply f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ := h₅
        _ ≤ (‖x‖ * ‖y‖) * ‖f‖ := by gcongr
        _ = ‖x‖ * ‖y‖ * ‖f‖ := by ring
    have h₅ : (cfc_toComplexMeasure ha x y).integral f = (cfc_toLinearFunctional ha x y).apply f := by
      simp [cfc_toComplexMeasure, ComplexRMK.integral_compSL, ComplexRMK.rieszMeasure_apply]
      <;>
      simp_all [toLinearFunctional_apply]
      <;>
      try norm_cast
      <;>
      try simp_all [Complex.norm_eq_abs]
      <;>
      try simp_all [Complex.abs_of_nonneg]
      <;>
      try simp_all [Real.norm_eq_abs]
      <;>
      try simp_all [abs_mul]
      <;>
      try simp_all [abs_of_nonneg]
      <;>
      try simp_all [abs_of_nonpos]
    rw [h₅] at *
    exact h₄
  exact h₃

lemma cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ₑ * ‖y‖ₑ := by
  have h₁ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
  have h₂ : (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := by
    have h₃ : (cfc_toComplexMeasure ha x y).variation Set.univ = ‖cfc_toLinearFunctional ha x y‖ := by
      simp [cfc_toComplexMeasure, ComplexRMK.rieszMeasure_variation]
      <;>
      simp_all [toLinearFunctional_apply]
      <;>
      try norm_cast
      <;>
      try simp_all [Complex.norm_eq_abs]
      <;>
      try simp_all [Complex.abs_of_nonneg]
      <;>
      try simp_all [Real.norm_eq_abs]
      <;>
      try simp_all [abs_mul]
      <;>
      try simp_all [abs_of_nonneg]
      <;>
      try simp_all [abs_of_nonpos]
    rw [h₃]
    <;>
    (try norm_cast at h₁ ⊢)
    <;>
    (try simp_all [norm_eq_abs])
    <;>
    (try linarith)
  have h₃ : ‖x‖ * ‖y‖ ≤ ‖x‖ₑ * ‖y‖ₑ := by
    calc
      ‖x‖ * ‖y‖ = ‖x‖ * ‖y‖ := rfl
      _ ≤ ‖x‖ₑ * ‖y‖ₑ := by
        -- Use the fact that the norm is less than or equal to the norm in the extended space
        have h₄ : ‖x‖ ≤ ‖x‖ₑ := by
          -- The norm in the extended space is greater than or equal to the original norm
          exact norm_le_normExtend
        have h₅ : ‖y‖ ≤ ‖y‖ₑ := by
          -- The norm in the extended space is greater than or equal to the original norm
          exact norm_le_normExtend
        -- Multiply the inequalities to get the desired result
        calc
          ‖x‖ * ‖y‖ ≤ ‖x‖ₑ * ‖y‖ := by gcongr
          _ ≤ ‖x‖ₑ * ‖y‖ₑ := by gcongr
  linarith
