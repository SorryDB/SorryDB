    -- The square function is continuous, and the composition of an IsCadlag function with a continuous function is IsCadlag.
    have h4 : ContinuousAt (fun x : ℝ => x ^ 2) (‖X (⊥ : ι) ω‖) := continuousAt_id.pow 2
    have h5 : IsCadlag (fun t : ι ↦ ‖X t ω‖ ^ 2) := h2.comp h4
    exact h5
  sorry
