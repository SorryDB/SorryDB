noncomputable
def quadraticVariation (hX : IsLocalMartingale X 𝓕 P) (hX_cadlag : ∀ ω, IsCadlag (X · ω)) :
    ι → Ω → ℝ :=
  have hX2_cadlag : ∀ ω, IsCadlag (fun t ↦ ‖X t ω‖ ^ 2) := by
    intro ω
    have h1 : IsCadlag (X · ω) := hX_cadlag ω
    have h2 : Continuous fun x : E => ‖x‖ := by continuity
    have h3 : Continuous fun x : ℝ => x * x := by continuity
    have h4 : Continuous fun x : E => ‖x‖ ^ 2 := by
      continuity
    have h5 : IsCadlag (fun t ↦ ‖X t ω‖) := by
      apply IsCadlag.comp h1
      -- Use the fact that the norm is continuous (in particular, it is continuous at the right)
      exact continuous_norm.continuousOn
    -- Use the fact that the square function is continuous (to preserve cadlag property)
    have h6 : IsCadlag (fun t ↦ ‖X t ω‖ ^ 2) := by
      apply IsCadlag.comp h5
      exact continuous_pow 2 |>.continuousOn
    exact h6
  sorry
