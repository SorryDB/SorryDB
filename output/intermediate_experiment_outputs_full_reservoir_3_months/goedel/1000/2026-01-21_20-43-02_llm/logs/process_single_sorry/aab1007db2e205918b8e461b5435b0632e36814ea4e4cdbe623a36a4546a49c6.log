              aesop
            })
        exact h₂
      -- Use the result to conclude the existence of m.
      exact h₁
    · -- Prove the reverse direction: if E is a constant distribution, then it satisfies Gauss's law.
      rintro ⟨m, rfl⟩
      -- Simplify the expression for Gauss's law when E is a constant distribution.
      simp [GaussLaw, chargeDistribution, distConst]
