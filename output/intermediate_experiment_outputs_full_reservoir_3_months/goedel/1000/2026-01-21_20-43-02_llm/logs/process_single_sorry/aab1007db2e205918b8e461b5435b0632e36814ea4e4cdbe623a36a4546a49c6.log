    E.GaussLaw ε (chargeDistribution) ↔ ∃ m, E = distConst 1 m := by
  have h_main : E.GaussLaw ε (chargeDistribution) ↔ ∃ m, E = distConst 1 m := by
    constructor
    · -- Prove the forward direction: if E satisfies Gauss's law, then E is a constant field.
      intro h
      have h₁ : E = distConst 1 (E 0) := by
        -- Use the fact that the electric field is constant in 1D when there are no charges.
        apply Eq.symm
