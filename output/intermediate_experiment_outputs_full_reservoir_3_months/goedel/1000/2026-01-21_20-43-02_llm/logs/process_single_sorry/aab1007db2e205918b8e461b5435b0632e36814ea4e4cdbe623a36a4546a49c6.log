        use E 0
        have h₃ : ∀ x : Fin 1, E x = E 0 := by
          intro x
          -- Since the divergence is zero, the derivative of E is zero.
          -- Therefore, E is constant.
          fin_cases x <;> simp_all [divergence, Fin.sum_univ_succ]
