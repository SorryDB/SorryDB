      "\n  constructor\n  · -- Prove the forward direction: if E.GaussLaw ε chargeDistribution, then ∃ m, E = distConst 1 m\n    intro h\n    have h₁ : E.GaussLaw ε (0 : ChargeDistribution 1) := by simpa [chargeDistribution] using h\n    have h₂ : ∃ m, E = distConst 1 m := by\n      -- Use the fact that the electric field is constant in 1D when the charge distribution is zero\n      have h₃ : ∃ m, E = distConst 1 m := by\n        -- Extract the constant value from the electric field\n        use E 0\n        ext x\n        -- Show that E is constant\n        have h₄ := h₁\n        simp [GaussLaw, chargeDistribution, zero_mul, mul_zero] at h₄\n        -- Use the fact that the derivative is zero to conclude that E is constant\n        <;>\n        (try simp_all [distConst, Function.funext_iff, Pi.one_apply]) <;>\n        (try ring_nf at * <;> linarith) <;>\n        (try\n          {\n            have h₅ := h₄\n            simp [Distribution.ext_iff, mul_comm] at h₅\n            have h₆ := h₅ (fun x => 1)\n            simp at h₆\n            <;>\n            (try\n              {\n                have h₇ := h₆\n                simp [distConst, Function.funext_iff, Pi.one_apply] at h₇ ⊢\n                <;>\n                (try ring_nf at * <;> linarith)\n              })\n            <;>\n            (try\n              {\n                simp_all [distConst, Function.funext_iff, Pi.one_apply]\n                <;>\n                (try ring_nf at * <;> linarith)\n              })\n          })\n        <;>\n        (try\n          {\n            simp_all [distConst, Function.funext_iff, Pi.one_apply]\n            <;>\n            (try ring_nf at * <;> linarith)\n          })\n      exact h₃\n    exact h₂\n  · -- Prove the reverse direction: if ∃ m, E = distConst 1 m, then E.GaussLaw ε chargeDistribution\n    rintro ⟨m, rfl⟩\n    -- Show that a constant electric field satisfies Gauss's law with no charge\n    have h₁ : (distConst 1 m : StaticElectricField 1).GaussLaw ε