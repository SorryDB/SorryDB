  simp_all [MonoidalLinear, Linear, NatLinear]
  <;>
  try { infer_instance }
  <;>
  try { ext; simp_all; try { ring } }
  <;>
  try { aesop }
  <;>
  try { simp_all [MonoidalLinear, Linear, NatLinear] }
  <;>
  try { infer_instance }
  <;>
  try { ext; simp_all; try { ring } }
  <;>
  try { aesop }
