### Solution

```lean
def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    rintro x y ⟨hx, hy⟩ ⟨h1, h2⟩
    exact ⟨I.add_mem hx h1, J.add_mem hy h2⟩
  zero_mem' := by
    exact ⟨I.zero_mem, J.zero_mem⟩
  smul_mem' := by
    intro r x ⟨hx, hy⟩
    refine' ⟨I.smul_mem r hx, J.smul_mem r hy⟩
