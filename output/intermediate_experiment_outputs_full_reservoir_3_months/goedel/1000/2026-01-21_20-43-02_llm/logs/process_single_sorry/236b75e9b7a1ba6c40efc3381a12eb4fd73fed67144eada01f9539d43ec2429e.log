    simp [RingEquiv.map_add]
    <;>
    simp_all [add_assoc]
    <;>
    try ring_nf
    <;>
    try simp_all [add_assoc]
  map_mul' := by
    intro x y
    simp [RingEquiv.map_mul]
    <;>
    simp_all [mul_assoc]
    <;>
    try ring_nf
    <;>
    try simp_all [mul_assoc]

end homomorphisms

