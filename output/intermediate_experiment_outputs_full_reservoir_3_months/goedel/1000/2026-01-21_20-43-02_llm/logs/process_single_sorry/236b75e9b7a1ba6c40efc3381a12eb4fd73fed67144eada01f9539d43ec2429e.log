  carrier := I ∩ J
  add_mem' := by
    intro x hx y hy
    -- Use the fact that both I and J are ideals, and the intersection preserves the additive closure property.
    exact ⟨I.add_mem hx.1 hy.1, J.add_mem hx.2 hy.2⟩
  zero_mem' := by
