def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro x hx y hy
    have h₁ : x ∈ I := hx.1
    have h₂ : y ∈ I := hy.1
    have h₃ : x + y ∈ I := I.add_mem h₁ h₂
    have h₄ : x ∈ J := hx.2
    have h₅ : y ∈ J := hy.2
    have h₆ : x + y ∈ J := J.add_mem h₄ h₅
    exact ⟨h₃, h₆⟩
  zero_mem' := by
    have h₁ : (0 : R) ∈ I := I.zero_mem
    have h₂ : (0 : R) ∈ J := J.zero_mem
    exact ⟨h₁, h₂⟩
  smul_mem' := by
    intro r x hx
    have h₁ : x ∈ I := hx.1
    have h₂ : x ∈ J := hx.2
    have h₃ : r • x ∈ I := I.smul_mem r h₁
    have h₄ : r • x ∈ J := J.smul_mem r h₂
    exact ⟨h₃, h₄⟩
```

