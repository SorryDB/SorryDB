variable {Œ± Œ≤ Œ≥ : Type*}

lemma mono (f : Œ± ‚Üí Œ≤) {F G : Filter Œ±} (h : F ‚â§ G) : F.map f ‚â§ G.map f := by
  exact Filter.map_mono f h

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : Œ± ‚Üí Œ≤) (F : Filter Œ±) (G : Filter Œ≤) := F.map f ‚â§ G

lemma Tendsto_comp {s : Œ± ‚Üí Œ≤} {t : Œ≤ ‚Üí Œ≥} {F : Filter Œ±} {G : Filter Œ≤} {H : Filter Œ≥}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ‚àò s) F H := by
  have h1 : F.map s ‚â§ G := hs
  have h2 : G.map t ‚â§ H := ht
  have h3 : F.map (t ‚àò s) = (F.map s).map t := by
    rw [‚Üê Filter.map_map]
    <;> simp [Function.comp]
  have h4 : (F.map s).map t ‚â§ H := Filter.map_le_map h2 (F.map s)
  calc
    F.map (t ‚àò s) = (F.map s).map t := by rw [h3]
    _ ‚â§ H := h4

example (f g : ‚Ñù ‚Üí ‚Ñù) (hf : Tendsto f (ùìù 0) (ùìù Real.pi))
    (hg : Tendsto g (ùìù Real.pi) atTop) : Tendsto (g ‚àò f) (ùìù 0) atTop := by
