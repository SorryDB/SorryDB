    have h3 : Tendsto (g ‚àò f) (ùìù 0) atTop := Tendsto_comp h1 h2
    exact h3
  exact h

example (a : ‚Ñï ‚Üí ‚Ñù) (œÜ : ‚Ñù ‚Üí ‚ÑÇ) (ha : Tendsto a atTop (ùìù (-1)))
