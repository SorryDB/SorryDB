example [TopologicalSpace Œ±] {x : Œ±} {p p' q q' : Œ± ‚Üí Prop}
    (hT : {x | p x} ‚àà ùìù x)
    (hT' : {x | p' x} ‚àà ùìù x)
    (hS : {x | q x} ‚àà ùìù x)
    (hS' : {x | q' x} ‚àà ùìù x) :
    {x | p x ‚àß q x ‚à® p' x ‚àß q' x} ‚àà ùìù x := by
  have h‚ÇÅ : {x | p x} ‚à© {x | q x} ‚àà ùìù x := by
    apply Inter_mem hT hS
  have h‚ÇÇ : {x | p' x} ‚à© {x | q' x} ‚àà ùìù x := by
    apply Inter_mem hT' hS'
  have h‚ÇÉ : {x | p x ‚àß q x ‚à® p' x ‚àß q' x} ‚àà ùìù x := by
