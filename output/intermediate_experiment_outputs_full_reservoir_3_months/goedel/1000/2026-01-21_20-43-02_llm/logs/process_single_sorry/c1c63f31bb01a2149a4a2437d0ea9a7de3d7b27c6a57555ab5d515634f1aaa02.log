/-
Copyright (c) 2025 Yaël Dillies. All rights reserved.
Released under Apache 2.0 license as described in the file LICENSE.
Authors: Yaël Dillies
-/
import Mathlib.MeasureTheory.Integral.IntervalAverage
import MiscYD.PhD.VCDim.UnifAP.Defs

/-!
# Fourier analysis of uniformly almost periodic functions
-/

open Filter
open scoped Topology

variable {Λ : ℝ} {f : ℝ → ℂ}

variable (f) in
/-- The **mean** of an uniformly almost periodic function `f` is the limit of its average on
`[0, X]` as `X → +∞`. -/
noncomputable def mean : ℂ := limUnder atTop fun X ↦ ⨍ x in (0)..X, f x

lemma IsUnifAlmostPeriodic.tendsto_mean (hf : IsUnifAlmostPeriodic f) :
    Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) := by
  have h : Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (limUnder atTop fun X ↦ ⨍ x in (0)..X, f x)) := by
    -- The limit of a function as X → ∞ is the same as the limUnder atTop of that function
    have h₁ : (limUnder atTop fun X ↦ ⨍ x in (0)..X, f x) = limUnder atTop fun X ↦ ⨍ x in (0)..X, f x := rfl
    rw [Metric.tendsto_atTop]
    intro ε εpos
    -- Use the definition of limUnder to find the required N
    have h₂ : ∃ (N : ℝ), ∀ (X : ℝ), X ≥ N → dist (⨍ x in (0)..X, f x) (limUnder atTop fun X ↦ ⨍ x in (0)..X, f x) < ε := by
      -- This follows directly from the definition of limUnder
      have h₃ : ∃ (N : ℝ), ∀ (X : ℝ), X ≥ N → dist (⨍ x in (0)..X, f x) (limUnder atTop fun X ↦ ⨍ x in (0)..X, f x) < ε := by
        -- Use the fact that limUnder exists and is finite
        simpa [h₁] using Metric.tendsto_atTop.mp (by
          -- Show that the function tends to its limUnder
          have h₄ : Tendsto (fun X : ℝ ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (limUnder atTop fun X ↦ ⨍ x in (0)..X, f x)) := by
            apply tendsto_limUnder
          exact h₄) ε εpos
      exact h₃
    -- Obtain the N from h₂
    obtain ⟨N, hN⟩ := h₂
    -- Use N as the required bound
    refine' ⟨N, _⟩
    intro X hX
    -- Apply hN to X and hX
    have h₃ : dist (⨍ x in (0)..X, f x) (limUnder atTop fun X ↦ ⨍ x in (0)..X, f x) < ε := hN X hX
    -- Simplify the distance expression
    simpa [dist_eq_norm] using h₃
  -- Use the fact that limUnder exists and is finite to conclude the proof
  convert h using 1
  <;> simp [mean]

variable (Λ f) in
/-- The **Fourier coefficient** at `Λ` of an uniformly almost periodic function `f` is the mean of
`x ↦ f x * exp (-iΛx)`. -/
noncomputable def fourierCoeff : ℂ := mean fun x ↦ f x * .exp (-.I * Λ * x)

/-- The **Fourier exponents** of an uniformly almost periodic function `f` are at most countable. -/
lemma IsUnifAlmostPeriodic.countable_fourierCoeff_ne_zero : {Λ | fourierCoeff Λ f ≠ 0}.Countable := by
  have h : {Λ : ℝ | fourierCoeff Λ f ≠ 0}.Countable := by
    -- Use the fact that the set of Fourier coefficients is countable
    have h₁ : {Λ : ℝ | fourierCoeff Λ f ≠ 0} ⊆ {Λ : ℝ | (fourierCoeff Λ f : ℂ) ≠ 0} := by
      intro Λ hΛ
      simpa [fourierCoeff] using hΛ
    -- Since the set of complex numbers is countable, the subset is also countable
    have h₂ : {Λ : ℝ | (fourierCoeff Λ f : ℂ) ≠ 0}.Countable := by
      -- Use the fact that the set of complex numbers is countable
      have h₃ : {Λ : ℝ | (fourierCoeff Λ f : ℂ) ≠ 0} ⊆ {z : ℂ | z ≠ 0} := by
        intro Λ hΛ
        simp_all [fourierCoeff]
        <;>
        (try norm_num) <;>
        (try simp_all [Complex.ext_iff]) <;>
        (try norm_num) <;>
        (try linarith)
      -- The set of non-zero complex numbers is countable
      have h₄ : {z : ℂ | z ≠ 0}.Countable := by
        -- Use the fact that the set of complex numbers is countable
        have h₅ : {z : ℂ | z ≠ 0} ⊆ {z : ℂ | z ≠ 0} := by
          intro z hz
          exact hz
        -- The set of non-zero complex numbers is countable
        exact Set.countable_subset (by
          -- Use the fact that the set of complex numbers is countable
          exact Set.countable_univ
          ) h₅
      -- The subset of a countable set is countable
      exact Set.countable_subset h₄ h₃
    -- The subset of a countable set is countable
    exact Set.countable_subset h₂ h₁
  -- Convert the set to use real numbers
  exact h
