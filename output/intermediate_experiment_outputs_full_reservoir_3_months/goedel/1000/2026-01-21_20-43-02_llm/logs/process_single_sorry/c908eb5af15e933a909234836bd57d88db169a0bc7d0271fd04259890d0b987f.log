/-! # Exercises to practice -/

section

/- There are special cases of the change of variables theorems for affine transformations
(but you can also use the change of variable theorem from the lecture) -/
example (a b : ℝ) :
    ∫ x in a..b, sin (x / 2 + 3) =
    2 * cos (a / 2 + 3) - 2 * cos (b / 2  + 3) := by
  have h1 : ∫ x in a..b, sin (x / 2 + 3) = 2 * cos (a / 2 + 3) - 2 * cos (b / 2 + 3) := by
    have h2 : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in a..b, sin (x / 2 + 3) := rfl
    rw [h2]
    -- Use the fundamental theorem of calculus to evaluate the integral
    have h3 : ∫ x in a..b, sin (x / 2 + 3) = 2 * cos (a / 2 + 3) - 2 * cos (b / 2 + 3) := by
      have h4 : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in a..b, sin (x / 2 + 3) := rfl
      rw [h4]
      -- Use the substitution u = x/2 + 3
      have h5 : ∫ x in a..b, sin (x / 2 + 3) = 2 * cos (a / 2 + 3) - 2 * cos (b / 2 + 3) := by
        -- Use the fundamental theorem of calculus to evaluate the integral
        rw [intervalIntegral.integral_comp_add_right (fun x => sin (x / 2))]
        <;> simp [sin_add, cos_add]
        <;> ring_nf
        <;> field_simp
        <;> ring_nf
        <;> norm_num
        <;> linarith
      rw [h5]
    rw [h3]
  exact h1

/- Use the change of variables theorem for this exercise. -/
example (f : ℝ → ℝ) (s : Set ℝ) (hs : MeasurableSet s) :
    ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
  have h₁ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
    -- Use the substitution y = exp(x)
    have h₂ : ∫ x in s, exp x * f (exp x) = ∫ y in exp '' s, f y := by
      -- Apply the change of variables theorem
      have h₃ : ∫ x in s, exp x * f (exp x) = ∫ x in s, (fun x => exp x * f (exp x)) x := rfl
      rw [h₃]
      -- Use the fact that exp is measurable and the change of variables theorem
      have h₄ : (∫ x in s, (fun x => exp x * f (exp x)) x) = ∫ y in exp '' s, f y := by
        -- Use the change of variables theorem for the integral
        have h₅ : ∫ x in s, (fun x => exp x * f (exp x)) x = ∫ x in s, (fun x => exp x * f (exp x)) x := rfl
        rw [h₅]
        -- Use the fact that exp is measurable and the change of variables theorem
        have h₆ : ∫ x in s, (fun x => exp x * f (exp x)) x = ∫ y in exp '' s, f y := by
          -- Use the change of variables theorem for the integral
          calc
            ∫ x in s, (fun x => exp x * f (exp x)) x = ∫ x in s, (fun x => exp x * f (exp x)) x := rfl
            _ = ∫ x in s, f (exp x) * exp x := by
              congr
              ext x
              ring
            _ = ∫ y in exp '' s, f y := by
              -- Use the change of variables theorem for the integral
              have h₇ : ∫ x in s, f (exp x) * exp x = ∫ y in exp '' s, f y := by
                -- Use the fact that exp is measurable and the change of variables theorem
                have h₈ : ∫ x in s, f (exp x) * exp x = ∫ x in s, f (exp x) * exp x := rfl
                rw [h₈]
                -- Use the change of variables theorem for the integral
                have h₉ : ∫ x in s, f (exp x) * exp x = ∫ y in exp '' s, f y := by
                  -- Use the fact that exp is measurable and the change of variables theorem
                  have h₁₀ : ∫ x in s, f (exp x) * exp x = ∫ x in s, f (exp x) * exp x := rfl
                  rw [h₁₀]
                  -- Use the change of variables theorem for the integral
                  have h₁₁ : ∫ x in s, f (exp x) * exp x = ∫ y in exp '' s, f y := by
                    -- Use the fact that exp is measurable and the change of variables theorem
                    rw [← MeasureTheory.setIntegral_comp_mul_right (fun x => f x) (by positivity)]
                    <;> simp [hs, Real.exp_ne_zero]
                    <;>
                    (try norm_num) <;>
                    (try simp_all [hs, Real.exp_ne_zero]) <;>
                    (try ring_nf) <;>
                    (try field_simp) <;>
                    (try norm_num) <;>
                    (try linarith)
                  rw [h₁₁]
                rw [h₉]
              rw [h₇]
        rw [h₆]
      rw [h₄]
    rw [h₂]
  rw [h₁]

example (x : ℝ) : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by
  have h₁ : ∫ t in (0 : ℝ)..x, t * Real.exp t = (x - 1) * Real.exp x + 1 := by
    have h₂ : ∫ t in (0 : ℝ)..x, t * Real.exp t = (x - 1) * Real.exp x + 1 := by
      -- Use integration by parts to evaluate the integral
