      "\n                      simp_all [uIcc, Icc]\n                      <;> linarith\n                    exact h₁₄) using 1\n                  <;> field_simp [pow_two]\n                  <;> ring_nf\n                  <;> norm_num\n                exact h₁₃\n              have h₁₄ : deriv (fun x : ℝ => (-(1 : ℝ) / x : ℝ)) x = 1 / x ^ 2 := by\n                apply HasDerivAt.deriv\n                exact h₁₂\n              rw [show (-(1 : ℝ) / x : ℝ) ' = deriv (fun x : ℝ => (-(1 : ℝ) / x : ℝ)) x by\n                simp [deriv]]\n              <;> rw [h₁₄]\n            rw [h₁₀]\n            -- Use the fundamental theorem of calculus\n            have h₁₁ : ∫ x in a..b, (-(1 : ℝ) / x) ' = (-(1 : ℝ) / b + 1 / a) := by\n              -- Use the fundamental theorem of calculus\n              have h₁₂ : ∫ x in a..b, (-(1 : ℝ) / x) ' = (-(1 : ℝ) / b + 1 / a) := by\n                rw [intervalIntegral.integral_deriv_eq_sub']\n                <;>\n                (try\n                  {\n                    norm_num\n                    <;>\n                    (try\n                      {\n                        simp_all [ha.ne', hb.ne']\n                        <;>\n                        (try\n                          {\n                            linarith\n                          })\n                      })\n                  })\n                <;>\n                (try\n                  {\n                    simp_all [ha.ne', hb.ne']\n                    <;>\n                    (try\n                      {\n                        linarith\n                      })\n                  })\n                <;>\n                (try\n                  {\n                    apply ContinuousOn.div\n                    <;>\n                    (try\n                      {\n                        apply ContinuousOn.neg\n                        <;>\n                        apply continuousOn_const\n                      })\n                    <;>\n       