      "\n              have h₇ : 0 ∈ uIcc a b := by\n                simp_all [uIcc, Set.mem_Icc]\n                <;>\n                (try { cases' le_total a b with h₈ h₈ <;>\n                  simp_all [uIcc, Set.mem_Icc] <;>\n                  (try { linarith }) <;>\n                  (try { nlinarith }) }) <;>\n                (try { linarith })\n              contradiction\n            simp_all\n          )\n      exact h₃\n    rw [h₂]\n    -- Compute the integral of 1/x from a to b\n    have h₃ : ∫ x in a..b, (1 / x : ℝ) = log b - log a := by\n      have h₄ : ∫ x in a..b, (1 / x : ℝ) = log b - log a := by\n        -- Use the fundamental theorem of calculus to compute the integral\n        rw [intervalIntegral.integral_congr (fun x hx => by\n          have h₅ : x ≠ 0 := by\n            by_contra h₆\n            have h₇ : x = 0 := by simpa using h₆\n            have h₈ : 0 ∈ uIcc a b := by\n              simp_all [uIcc, Set.mem_Icc]\n              <;>\n              (try { cases' le_total a b with h₉ h₉ <;>\n                simp_all [uIcc, Set.mem_Icc] <;>\n                (try { linarith }) <;>\n                (try { nlinarith }) }) <;>\n              (try { linarith })\n            contradiction\n          field_simp [h₅]\n          <;> ring_nf\n          <;> simp_all [Real.log_div]\n          <;> field_simp [h₅]\n          <;> ring_nf\n          )]\n        <;> simp_all [Real.log_div]\n        <;> norm_num\n        <;> linarith\n      exact h₄\n    -- Compute the integral of 1/x^2 from a to b\n    have h₄ : ∫ x in a..b, (1 / x ^ 2 : ℝ) = 1 / a - 1 / b := by\n      have h₅ : ∫ x in a..b, (1 / x ^ 2 : ℝ) = 1 / a - 1 / b := by\n        -- Use the fundamental theorem of calculus to compute the integral\n        have h₆ : ∫ x in a..b, (1 / x ^ 2 : ℝ) = ∫ x in a..b, (x : ℝ) ^ (-2 : ℝ) := by\n          congr\n          ext x\n          field_simp [Real.rpow_neg, Real.rpow_two]\n          <;> ring_nf\n          <;> simp_all [Real.rpow_neg, Real.rpow_two]\n        