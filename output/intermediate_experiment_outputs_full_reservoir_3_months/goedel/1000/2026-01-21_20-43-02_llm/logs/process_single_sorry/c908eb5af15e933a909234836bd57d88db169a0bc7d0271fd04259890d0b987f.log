theorem interval_inter_empty_or_subset (s : Set α) (I : Set α) :
    s ∩ I = ∅ ∨ s ∩ I = s := by
  classical
  by_cases h : s ∩ I = ∅
  · exact Or.inl h
  · right
    apply Set.Subset.antisymm
    · -- Prove that s ∩ I ⊆ s
      exact Set.inter_subset_left
    · -- Prove that s ⊆ s ∩ I
      intro x hx
      have h₁ : x ∈ s := hx
      have h₂ : x ∈ s ∩ I := by
        -- Since s ∩ I ≠ ∅, and x ∈ s, we need to show x ∈ I
        have h₃ : s ∩ I ≠ ∅ := h
        have h₄ : x ∈ I := by
          by_contra h₄
          -- If x ∉ I, then s ∩ I ⊆ {x}ᶜ, which would imply s ∩ I = ∅
          have h₅ : s ∩ I ⊆ {x}ᶜ := by
            intro y hy
            have h₅₁ : y ∈ s := Set.mem_of_mem_inter_left hy
            have h₅₂ : y ∈ I := Set.mem_of_mem_inter_right hy
            have h₅₃ : y ≠ x := by
              by_contra h₅₄
              have h₅₅ : y = x := h₅₄
              rw [h₅₅] at h₅₂
              exact h₄ h₅₂
            exact h₅₃
          have h₆ : s ∩ I = ∅ := by
            have h₇ : s ∩ I ⊆ {x}ᶜ := h₅
            have h₈ : x ∈ s := h₁
            have h₉ : x ∉ s ∩ I := by
              intro h₉
              have h₁₀ : x ∈ I := Set.mem_of_mem_inter_right h₉
              contradiction
            have h₁₀ : s ∩ I ⊆ {x}ᶜ := h₅
            have h₁₁ : s ∩ I = ∅ := by
              by_contra h₁₁
              have h₁₂ : ∃ y, y ∈ s ∩ I := Set.nonempty_iff_ne_empty.mpr h₁₁
              obtain ⟨y, hy⟩ := h₁₂
              have h₁₃ : y ∈ s ∩ I := hy
              have h₁₄ : y ∈ {x}ᶜ := h₁₀ h₁₃
              have h₁₅ : y ≠ x := by simpa using h₁₄
              have h₁₆ : y ∈ s := Set.mem_of_mem_inter_left h₁₃
              have h₁₇ : y ∈ I := Set.mem_of_mem_inter_right h₁₃
              simp_all
            exact h₁₁
          contradiction
        exact ⟨h₁, h₄⟩
      exact h₂
