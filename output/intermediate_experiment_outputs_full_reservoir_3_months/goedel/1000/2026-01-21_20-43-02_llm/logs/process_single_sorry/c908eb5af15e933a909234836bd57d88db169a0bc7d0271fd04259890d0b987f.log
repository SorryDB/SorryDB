    (try { contradiction }) <;>
    (try { linarith }) <;>
    (try {
      cases' le_total a b with hab hab <;>
      cases' h with h h <;>
      (try { simp_all [hab] <;> linarith }) <;>
      (try { norm_num at h <;> linarith })
    })
    <;>
    (try { aesop })

