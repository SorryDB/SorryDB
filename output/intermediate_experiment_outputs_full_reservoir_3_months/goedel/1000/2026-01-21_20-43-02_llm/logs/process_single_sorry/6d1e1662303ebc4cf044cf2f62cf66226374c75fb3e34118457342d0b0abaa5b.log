    have h₁ : 1 ≤ j := hj1
    have h₂ : j ≤ 8 := hj2
    linarith
  interval_cases i <;> interval_cases j <;> norm_num [coloring_of_eight, Set.mem_Icc, Fin.ext_iff] at hi1 hi2 hj1 hj2 hij1 hij2a hij2b hc1 hc2 <;>
    (try contradiction) <;>
    (try omega) <;>
