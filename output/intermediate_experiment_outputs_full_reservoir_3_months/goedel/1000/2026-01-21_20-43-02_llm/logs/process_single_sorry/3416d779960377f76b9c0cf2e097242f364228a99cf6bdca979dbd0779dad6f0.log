```lean
lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by
  have h : ∀ (n : ℕ), fnz (2 * n + 1) = -↑(n + 1) := by
    intro n
    simp [fnz, Nat.cast_add, Nat.cast_one, Nat.cast_mul, Nat.cast_ofNat]
    <;> ring_nf
    <;> norm_num
    <;> simp_all [Int.ofNat_eq_coe]
    <;> linarith
  exact h k

lemma fnz_fzn : fnz ∘ fzn = id  := by
  funext x
  simp [fnz, fzn]
  <;>
  (try { cases x <;> simp_all [Int.ofNat_eq_coe] <;> ring_nf <;> norm_cast }) <;>
  (try { omega }) <;>
  (try { linarith }) <;>
  (try { simp_all [Int.ofNat_eq_coe] <;> ring_nf <;> norm_cast }) <;>
  (try { omega }) <;>
  (try { linarith })

lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := by
  simp [tri]
  <;> induction k with
  | zero => simp [tri]
  | succ k ih =>
    simp_all [tri, Nat.succ_eq_add_one, add_assoc]
    <;> ring_nf at *
    <;> omega

lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ n : ℕ, tri n = n * (n + 1) / 2 := by
    intro n
    simp [tri]
    <;> ring_nf
    <;> simp [Nat.mul_add, Nat.add_mul, Nat.mul_one, Nat.mul_zero]
    <;> ring_nf
    <;> norm_num
    <;> omega
  
  have h3 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
    have h4 : j ≤ k := h1
    have h5 : j * (j + 1) ≤ k * (k + 1) := by
      have h6 : j ≤ k := h4
      have h7 : j + 1 ≤ k + 1 := by linarith
      have h8 : 0 ≤ j := by linarith
      have h9 : 0 ≤ k := by linarith
      nlinarith
    have h10 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
      have h11 : j * (j + 1) ≤ k * (k + 1) := h5
      have h12 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
        have h13 : 0 ≤ j * (j + 1) := by
          nlinarith
        have h14 : 0 ≤ k * (k + 1) := by
          nlinarith
        have h15 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
          omega
        exact h15
      exact h12
    exact h10
  
  have h4 : tri j = j * (j + 1) / 2 := h2 j
  have h5 : tri k = k * (k + 1) / 2 := h2 k
  have h6 : tri j ≤ tri k := by
    rw [h4, h5]
    exact h3
  exact h6

