lemma f_range_eq_Ran_graph {U V : Type} (f : U → V) : range f = Ran (graph f) := by
  apply Set.ext
  intro y
  simp only [Set.mem_range, Ran.mem, Set.mem_setOf_eq]
  constructor
  · -- Prove the forward direction: if y is in range f, then y is in Ran (graph f)
    intro h
    -- Extract the element x such that f(x) = y
    obtain ⟨x, rfl⟩ := h
    -- Show that (x, f(x)) is in the graph of f and hence y is in Ran (graph f)
    refine' ⟨(x, f x), _⟩
    <;> simp [graph]
  · -- Prove the reverse direction: if y is in Ran (graph f), then y is in range f
    intro h
    -- Extract the element (x, z) in the graph of f such that z = y
    obtain ⟨⟨x, z⟩, h1, rfl⟩ := h
    -- Since (x, z) is in the graph of f, we have z = f(x)
    have h2 : z = f x := by simp [graph] at h1; exact h1
    -- Substitute z = f(x) to get y = f(x), hence y is in range f
    refine' ⟨x, _⟩
    <;> simp [h2]
```

