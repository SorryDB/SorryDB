lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by
  simp [fnz, odd_iff_not_even, parity_simps, Int.ofNat_add, Int.ofNat_mul, Int.ofNat_one]
  <;> induction k with
  | zero => simp
  | succ k ih =>
