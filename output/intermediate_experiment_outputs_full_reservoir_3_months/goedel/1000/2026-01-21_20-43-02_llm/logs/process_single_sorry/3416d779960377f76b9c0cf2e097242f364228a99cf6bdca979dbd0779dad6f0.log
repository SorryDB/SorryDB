lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by
  have h : 2 * k + 1 = 2 * (k + 1) - 1 := by
    have h₁ : 2 * (k + 1) - 1 = 2 * k + 1 := by
      simp [Nat.mul_succ, Nat.add_assoc]
      <;> ring_nf
      <;> omega
    linarith
  rw [h]
  simp [fnz, Int.emod_eq_of_lt]
  <;> induction k <;> simp_all [Nat.mul_succ, pow_succ, Int.mul_emod]
  <;> norm_num <;> ring_nf at * <;> omega

lemma fnz_fzn : fnz ∘ fzn = id := by
  funext x
  simp [fzn, fnz]
  <;> cases x <;> simp_all [Int.emod_eq_of_lt]
  <;> norm_num <;> omega

lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := by
  simp [tri, Nat.succ_eq_add_one, add_assoc]
  <;> ring_nf at *
  <;> omega

lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ n : ℕ, tri n = n * (n + 1) / 2 := by
    intro n
    simp [tri]
    <;> ring_nf
    <;> simp [Nat.mul_succ, Nat.add_assoc]
    <;> induction n with
    | zero => simp
    | succ n ih =>
      simp_all [tri, Nat.succ_eq_add_one, add_assoc]
      <;> ring_nf at *
      <;> omega
  have h3 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
    have h4 : j ≤ k := h1
    have h5 : j * (j + 1) ≤ k * (k + 1) := by
      have h6 : j ≤ k := h1
      have h7 : j + 1 ≤ k + 1 := by linarith
      have h8 : 0 ≤ j := by linarith
      have h9 : 0 ≤ k := by linarith
      nlinarith
    have h10 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
      have h11 : j * (j + 1) ≤ k * (k + 1) := h5
      have h12 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
        have h13 : j * (j + 1) / 2 ≤ (j * (j + 1)) / 2 := by simp [Nat.div_le_self]
        have h14 : (k * (k + 1)) / 2 ≥ (j * (j + 1)) / 2 := by
          have h15 : k * (k + 1) ≥ j * (j + 1) := by nlinarith
          have h16 : (k * (k + 1)) / 2 ≥ (j * (j + 1)) / 2 := by
            omega
          exact h16
        omega
      exact h12
    exact h10
  have h17 : tri j = j * (j + 1) / 2 := by
    rw [h2]
  have h18 : tri k = k * (k + 1) / 2 := by
    rw [h2]
  rw [h17, h18]
  <;> exact h3

