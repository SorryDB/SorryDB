  <;> ring_nf at *
  <;> omega
  
lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ n : ℕ, tri n = n * (n + 1) / 2 := by
    intro n
    simp [tri]
    <;> ring_nf
    <;> omega
  have h3 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
    have h4 : j ≤ k := h1
    have h5 : j * (j + 1) ≤ k * (k + 1) := by
      nlinarith
    have h6 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
      have h7 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
        apply Nat.div_le_div_right
        <;> nlinarith
      exact h7
    exact h6
  have h7 : tri j = j * (j + 1) / 2 := h2 j
  have h8 : tri k = k * (k + 1) / 2 := h2 k
  rw [h7, h8]
  exact h3
  
