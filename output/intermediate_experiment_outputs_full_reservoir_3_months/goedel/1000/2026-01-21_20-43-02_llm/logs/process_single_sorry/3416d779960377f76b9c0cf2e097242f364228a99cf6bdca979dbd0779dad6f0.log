lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := by
  rw [fnz]
  <;> simp [Int.ofNat_add, Int.ofNat_mul, Int.ofNat_one]
  <;> ring_nf
  <;> norm_num
  <;> induction k with
  | zero => simp
  | succ k ih =>
    simp_all [Nat.mul_succ, Nat.add_assoc]
    <;> ring_nf at *
    <;> norm_num at *
    <;> linarith

lemma fnz_fzn : fnz ∘ fzn = id := by
  funext k
  simp [fzn, fnz]
  <;> cases k <;> simp_all [Int.ofNat_add, Int.ofNat_mul, Int.ofNat_one]
  <;> ring_nf at *
  <;> norm_num at *
  <;> omega

lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := by
  simp [tri]
  <;> induction k with
  | zero => simp [tri]
  | succ k ih =>
    simp_all [tri, Nat.succ_eq_add_one, add_assoc]
    <;> ring_nf at *
    <;> omega

lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ n m : ℕ, n ≤ m → tri n ≤ tri m := by
    intro n m h
    induction' h with m h IH
    · simp [tri]
    · simp_all [tri, Nat.succ_eq_add_one, add_assoc]
      <;> nlinarith
  exact h2 j k h1

example {U V : Type} (f : U → V) : range f = Ran (graph f) := by
  ext y
  simp [Set.mem_range, Set.mem_image, graph]
  <;> aesop
