  simp [fnz, fzn]
  <;>
  (try { cases x <;> simp_all [Int.ofNat_succ, Int.ofNat_zero] }) <;>
  (try { ring_nf at * <;> norm_num at * <;> omega }) <;>
  (try { simp_all [Int.emod_eq_of_lt] }) <;>
  (try { linarith })
  <;>
  rfl

-- 3.
