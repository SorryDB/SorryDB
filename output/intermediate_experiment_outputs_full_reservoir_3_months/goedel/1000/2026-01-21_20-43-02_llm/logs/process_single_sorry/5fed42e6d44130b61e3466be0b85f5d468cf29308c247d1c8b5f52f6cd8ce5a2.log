structure BiasedHopfieldNetwork (n : ŌäĢ) extends HopfieldNetwork n where
  bias : Fin n ŌåÆ ŌäØ

def biasedLocalField (net : BiasedHopfieldNetwork n) (x : HopfieldState n) (i : Fin n) : ŌäØ :=
  localField net.toHopfieldNetwork x i + net.bias i

noncomputable def biasedUpdateState (net : BiasedHopfieldNetwork n) (x : HopfieldState n) (i : Fin n) : HopfieldState n :=
  Function.update x i $
    let lf := biasedLocalField net x i
    if 0 < lf then SpinState.up
    else if lf < 0 then SpinState.down
    else x i

def biasedEnergy (net : BiasedHopfieldNetwork n) (x : HopfieldState n) : ŌäØ :=
  let hopfield_net := net.toHopfieldNetwork
  let xVec := toRealVector x;
  let W := weightsMatrix hopfield_net;
  let B := Matrix.toBilin' W;
  -0.5 * B xVec xVec - Finset.sum Finset.univ (fun i => (net.thresholds i + net.bias i) * xVec i)

inductive BiasedUpdateSeq {n : ŌäĢ} (net : BiasedHopfieldNetwork n) : HopfieldState n ŌåÆ Type
  | nil : (x : HopfieldState n) ŌåÆ BiasedUpdateSeq net x
  | cons : (x : HopfieldState n) ŌåÆ (i : Fin n) ŌåÆ BiasedUpdateSeq net (biasedUpdateState net x i) ŌåÆ BiasedUpdateSeq net x

namespace BiasedUpdateSeq
noncomputable def target {n : ŌäĢ} {net : BiasedHopfieldNetwork n} {x : HopfieldState n}
  : BiasedUpdateSeq net x ŌåÆ HopfieldState n
  | nil x => x
  | cons _ _ s => s.target

def biasedIsFixedPoint {n : ŌäĢ} (net : BiasedHopfieldNetwork n) (x : HopfieldState n) : Prop :=
  ŌłĆ i, biasedUpdateState net x i = x

def biasedConvergesTo {n : ŌäĢ} (net : BiasedHopfieldNetwork n) (x p : HopfieldState n) : Prop :=
  Ōłā (seq : BiasedUpdateSeq net x), seq.target = p Ōł¦ biasedIsFixedPoint net p
end BiasedUpdateSeq

