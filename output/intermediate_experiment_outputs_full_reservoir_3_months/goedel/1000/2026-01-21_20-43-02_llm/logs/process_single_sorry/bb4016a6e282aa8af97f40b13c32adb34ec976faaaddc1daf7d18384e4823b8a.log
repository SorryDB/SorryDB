    have h₄ := hP ⟨0, by omega⟩ ⟨2, by omega⟩
    have h₅ := hP ⟨0, by omega⟩ ⟨1, by omega⟩
    simp [Fin.ext_iff, Fin.val_add, Fin.val_zero, Fin.val_one, Fin.val_two] at h₄ h₅
