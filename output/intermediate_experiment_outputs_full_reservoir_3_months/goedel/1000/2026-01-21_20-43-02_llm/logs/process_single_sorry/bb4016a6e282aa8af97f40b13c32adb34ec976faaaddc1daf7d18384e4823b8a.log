theorem imo_1984_p5
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    (P : Fin n → ℝ²)
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have h₁ : False := by
    have h₂ := hP (⟨0, by
      have h₃ : 0 < n := by
        omega
      omega⟩ : Fin n) (⟨0, by
      have h₃ : 0 < n := by
        omega
      omega⟩ : Fin n)
    have h₃ := hP (⟨0, by
      have h₃ : 0 < n := by
        omega
      omega⟩ : Fin n) (⟨1, by
      have h₃ : 1 < n := by
        omega
      omega⟩ : Fin n)
    simp at h₂ h₃
    <;> norm_num at h₂ h₃ <;> try contradiction
    <;> try omega
  
  exfalso
  exact h₁
