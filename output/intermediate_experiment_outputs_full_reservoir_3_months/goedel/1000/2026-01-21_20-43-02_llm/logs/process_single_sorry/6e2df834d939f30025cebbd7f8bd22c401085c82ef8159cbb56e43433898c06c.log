lemma CondIndepFun.prod_right [StandardBorelSpace α] [StandardBorelSpace β] [Nonempty β]
    [StandardBorelSpace γ] [Nonempty γ] [StandardBorelSpace δ] [Nonempty δ] [IsFiniteMeasure μ]
    {X : α → β} {Y : α → γ} {Z : α → δ}
    (hX : Measurable X) (hY : Measurable Y) (hZ : Measurable Z)
    (h : X ⟂ᵢ[Z, hZ; μ] Y) :
    X ⟂ᵢ[Z, hZ; μ] (fun ω ↦ (Y ω, Z ω)) := by
  have h₁ : X ⟂ᵢ[Z, hZ; μ] (fun ω ↦ (Y ω, Z ω)) := by
    have h₂ : X ⟂ᵢ[Z, hZ; μ] (fun ω ↦ (Y ω, Z ω)) := by
      let X' : α → β := X
      let Y' : α → γ := Y
      let Z' : α → δ := Z
      -- Use the fact that the product of the functions Y and Z is the same as the product of the functions Y and Z
      -- and the given condition that X is conditionally independent of Y given Z
      -- to show that X is conditionally independent of the pair (Y, Z) given Z.
      simpa [X', Y', Z'] using h.prod_right (hZ)
    exact h₂
  exact h₁
