      "\n  have h₁ : (fun ω => (Y ω, Z ω)) = fun ω => (Y ω, Z ω) := rfl\n  rw [h₁]\n  have h₂ : X ⟂ᵢ[Z, hZ; μ] (fun ω => (Y ω, Z ω)) := by\n    -- Use the fact that the product of two variables is independent if both are independent\n    have h₃ : X ⟂ᵢ[Z, hZ; μ] (fun ω => (Y ω, Z ω)) := by\n      -- Use the fact that the product of two variables is independent if both are independent\n      refine' h.prod_right _\n      -- Show that the product of Y and Z is measurable\n      <;>\n        (try simp_all [Measurable.prod_mk]) <;>\n        (try assumption) <;>\n        (try apply Measurable.comp) <;>\n        (try apply Measurable.subtype_mk) <;>\n        (try apply Measurable.prod_mk) <;>\n        (try simp_all [hY, hZ]) <;>\n        (try assumption)\n    exact h₃\n  exact h₂",
      "\n  have h₁ : X ⟂ᵢ[Z, hZ; μ] Y := h\n  have h₂ : (fun ω : α ↦ (Y ω, Z ω)) = (fun ω : α ↦ (Y ω, Z ω)) := rfl\n  have h₃ : X ⟂ᵢ[Z, hZ; μ] (fun ω : α ↦ (Y ω, Z ω)) := by\n    rw [condIndepFun_iff.2 (by\n      have h₄ : SFinset (Set (Unit × Unit × Unit)) ∉ SFinset.bind (SFinset.bind (SFinset.bind (SFinset.univ : SFinset (Fin 1)) within (fun i => Set.univ)) within (fun j => Set.univ)) within (fun k => Set.univ) := by\n        simp [Finset.bind_insert, Finset.bind_empty]\n        <;>\n        (try decide) <;>\n        (try contradiction) <;>\n        (try simp_all [Finset.mem_singleton, Finset.mem_not_mem]) <;>\n        (try aesop)\n      simp_all [h₂, Finset.bind_insert, Finset.bind_empty]\n      <;>\n      (try decide) <;>\n      (try contradiction) <;>\n      (try simp_all [Finset.mem_singleton, Finset.mem_not_mem]) <;>\n      (try aesop)\n      )] at h₁ ⊢\n    <;>\n    simp_all [h₂, Finset.bind_insert, Finset.bind_empty]\n    <;>\n    (try decide) <;>\n    (try contradiction) <;>\n    (try simp_all [Finset.mem_singleton, Finset.mem_not_mem]) <;>\n    (try aesop)\n  exact h₃",
      "\n  have h₂ : X ⟂ᵢ[Z, hZ; μ] Y := h\n  have h₃ : IndepFun X (fun ω ↦ (Y ω, Z ω)) (kernelOf μ Z hZ) μ := by\n    -- Use the fact that the product of independent functions is independent\n    have h₄ : IndepFun X Y (kernelOf μ Z hZ) μ := by\n      simpa [ind Cir] using h₂\n    have h₅ : IndepFun X (fun ω ↦ (Y ω, Z ω)) (kernelOf μ Z hZ) μ := by\n      -- Use the product of independent functions\n      apply IndepFun.of_prod_right\n      <;> simpa [ind Cir] using h₄\n    exact h₅\n  -- Convert the independence to the desired form\n  simpa [ind Cir] using h₃",
