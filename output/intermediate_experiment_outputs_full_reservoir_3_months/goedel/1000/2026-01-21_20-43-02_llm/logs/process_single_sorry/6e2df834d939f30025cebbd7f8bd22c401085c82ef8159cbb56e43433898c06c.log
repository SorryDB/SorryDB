    [StandardBorelSpace γ] [Nonempty γ] [StandardBorelSpace δ] [Nonempty δ] [IsFiniteMeasure μ]
    {X : α → β} {Y : α → γ} {Z : α → δ}
    (hX : Measurable X) (hY : Measurable Y) (hZ : Measurable Z)
    (h : X ⟂ᵢ[Z, hZ; μ] Y) :
    X ⟂ᵢ[Z, hZ; μ] (fun ω ↦ (Y ω, Z ω)) := by
  have h₁ : X ⟂ᵢ[Z, hZ; μ] Y := h
  have h₂ : X ⟂ᵢ[Z, hZ; μ] (fun ω : α ↦ (Y ω, Z ω)) := by
    have h₃ : X ⟂ᵢ[Z, hZ; μ] (fun ω : α ↦ (Y ω, Z ω)) := by
      -- Use the property of conditional independence to extend it to the product of Y and a constant Z
      have h₄ : X ⟂ᵢ[Z, hZ; μ] Y := h₁
      have h₅ : X ⟂ᵢ[Z, hZ; μ] (fun _ : α ↦ (Z : α → δ)) := by
        -- Show that X is independent of Z given Z, which is trivially true
        refine' condIndep_self.hsymm.comp_right _
        <;> simp [hZ]
        <;> assumption
      -- Use the fact that if X is independent of Y and X is independent of Z given Z, then X is independent of (Y, Z) given Z
      refine' condIndep.prod_of_right _
      <;> try simp_all [hX, hY, hZ]
      <;> try assumption
      <;> try (try simp_all [hX, hY, hZ])
    exact h₃
  exact h₂
