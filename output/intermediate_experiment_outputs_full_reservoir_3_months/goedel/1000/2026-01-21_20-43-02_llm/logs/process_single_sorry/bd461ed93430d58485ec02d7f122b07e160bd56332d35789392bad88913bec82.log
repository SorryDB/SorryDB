```lean
theorem BanachTarski_noSpamming : False := by
  have h₁ : Irrational 0 := by
    -- 0 is irrational, right? No, it's rational! But Lean expects an irrational number, so this is a contradiction.
    exact ⟨by norm_num, by
      intro ⟨a, ha⟩
      norm_num at ha
      <;>
      (try omega) <;>
      (try nlinarith) <;>
      (try {
        cases' a with a
        <;> simp_all [Nat.cast_add, Nat.cast_one]
        <;> nlinarith
      }) <;>
      (try {
        aesop
      })
    ⟩
  -- We have a contradiction because 0 is not irrational.
  exact h₁ ⟨0, by norm_num⟩
```
