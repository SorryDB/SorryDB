@[inline, specialize]
def oracleProver : OracleProver oSpec
    Unit (OStatement √ó OStatement) Unit
    (OStatement) (OStatement √ó OStatement) Unit (pSpec OStatement) where

  PrvState
  | 0 => ‚ąÄ _ : Fin 2, OStatement
  | 1 => (‚ąÄ _ : Fin 2, OStatement) √ó (O‚āõ.spec.Domain)

  input := fun x _ => x.1.2.1

  sendMessage | ‚ü®0, h‚ü© => nomatch h

  receiveChallenge | ‚ü®0, _‚ü© => fun oracles => pure fun q => (by
    simp at *
    refine (oracles, ?_)
    convert q
    simp
    <;> stop
    <;> refine (oracles, q)

    <;> rfl
  )
``` 

