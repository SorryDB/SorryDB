lemma solsIncl_injective (χ : ACCSystem) :
    Function.Injective χ.solsIncl := by
  rw [Function.Injective]
  intro x y h
  have h₁ : (χ.solsIncl x : χ.Charges) = (χ.solsIncl y : χ.Charges) := by simpa using h
  have h₂ : (x : χ.Charges) = (y : χ.Charges) := by simpa [χ.solsIncl] using h₁
  have h₃ : x = y := by
    have h₄ := χ.solsIncl_injective
    have h₅ : (x : χ.chargesQuotType) = (y : χ.chargesQuotType) :=
      by simpa [χ.solsIncl] using h₂
    have h₆ : x = y := by
      -- Use the injectivity of the inclusion from solutions to charges
      have h₇ : (x : χ.chargesQuotType) = (y : χ.chargesQuotType) := h₅
      -- Since the inclusion is injective, x and y must be equal
      have h₈ : x.toLinSols.val = y.toLinSols.val := by
        simpa [χ.solsIncl, χ.quadSolsIncl, χ.quadSolsInclLinSols, χ.linSolsIncl] using h₇
      have h₉ : x.toLinSols = y.toLinSols := by
        -- Use the injectivity of the inclusion from linSols to charges
        have h₁₀ : Function.Injective (χ.linSolsIncl : χ.LinSols →ₗ[ℚ] χ.Charges) := by
          apply χ.linSolsIncl_injective
        have h₁₁ : (χ.linSolsIncl x.toLinSols : χ.Charges) = (χ.linSolsIncl y.toLinSols : χ.Charges) := by
          simpa [χ.solsIncl, χ.quadSolsIncl, χ.quadSolsInclLinSols, χ.linSolsIncl] using h₇
        exact h₁₀ h₁₁
      -- Since the linSols are equal, the quadSols must also be equal
      have h₁₀ : x.toQuadSols = y.toQuadSols := by
        -- Use the injectivity of the inclusion from quadSols to linSols
        have h₁₁ : Function.Injective (χ.quadSolsInclLinSols : χ.QuadSols →[ℚ] χ.LinSols) := by
          apply χ.quadSolsInclLinSols_injective
        have h₁₂ : (χ.quadSolsInclLinSols x : χ.LinSols) = (χ.quadSolsInclLinSols y : χ.LinSols) := by
          simpa [χ.solsIncl, χ.quadSolsIncl, χ.quadSolsInclLinSols, χ.linSolsIncl] using h₉
        exact h₁₁ h₁₂
      -- Since the quadSols are equal, the sols must also be equal
