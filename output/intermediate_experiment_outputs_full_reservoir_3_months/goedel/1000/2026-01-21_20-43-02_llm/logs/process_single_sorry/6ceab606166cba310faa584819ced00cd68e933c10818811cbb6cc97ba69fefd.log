```lean
```lean
def buildBST : List α → LabelledTree α
  | [] => LabelledTree.leaf (default : α)
  | (x :: xs) => LabelledTree.addLabel (buildBST xs) x


theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  have h₁ : ∀ (l : List α), fastCheckMem label (buildBST l) = true ↔ label ∈ l := by
    intro l
    induction l with
    | nil =>
      simp [buildBST]
      <;>
      simp_all [LabelledTree.mem, fastCheckMem, LabelledTree.addLabel]
      <;>
      aesop
    | cons x xs ih =>
      simp_all [buildBST, LabelledTree.addLabel, fastCheckMem]
      <;>
      (try cases (x = label) <;> simp_all [eq_true_iff, eq_false_iff, le_refl, le_of_lt])
      <;>
      (try
        {
          cases xs with
          | nil =>
            simp_all [LabelledTree.mem, fastCheckMem]
            <;>
            aesop
          | cons y ys =>
            simp_all [LabelledTree.mem, fastCheckMem, buildBST, LabelledTree.addLabel]
            <;>
            (try cases (y = label) <;> simp_all [eq_true_iff, eq_false_iff, le_refl, le_of_lt])
            <;>
            (try aesop)
        })
      <;>
      (try
        {
          simp_all [LabelledTree.mem, fastCheckMem, buildBST, LabelledTree.addLabel]
          <;>
          aesop
        })
      <;>
      (try
        {
          cases le_total label x with
          | inl h =>
            simp_all [h, lt_irrefl, lt_asymm]
            <;>
            aesop
          | inr h =>
            simp_all [h, lt_irrefl, lt_asymm]
            <;>
            aesop
        })
      <;>
      (try
        {
          simp_all [LabelledTree.mem, fastCheckMem, buildBST, LabelledTree.addLabel]
          <;>
          aesop
        })
      <;>
      (try
        {
          aesop
        })
  exact h₁ labels
