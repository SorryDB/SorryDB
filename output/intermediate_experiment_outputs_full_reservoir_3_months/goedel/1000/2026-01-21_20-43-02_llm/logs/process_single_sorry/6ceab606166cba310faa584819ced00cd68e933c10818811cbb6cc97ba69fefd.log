def buildBST : List α → LabelledTree α
  | _ => sorry

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  sorry

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  sorry
```

```lean
def buildBST : List α → LabelledTree α
  | [] => leaf (Classical.arbitrary α)
  | (x :: xs) => LabelledTree.addLabel (buildBST xs) x

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  induction labels with
  | nil =>
    simp [buildBST]
    <;>
    (try decide)
    <;>
    (try simp_all [IsOrdered])
  | cons x xs ih =>
    have h₁ : IsOrdered (buildBST xs) := ih
    have h₂ : IsOrdered (LabelledTree.addLabel (buildBST xs) x) := by
      apply ordered_addLabel
      <;> simp_all
    simp_all [buildBST]

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  have h₁ : fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
    induction labels with
    | nil =>
      simp [buildBST, fastCheckMem]
      <;>
      (try { aesop })
    | cons x xs ih =>
      simp_all [buildBST, LabelledTree.addLabel, fastCheckMem, List.mem_cons]
      <;>
      split_ifs at * <;>
      (try { simp_all [LabelledTree.mem] }) <;>
      (try { aesop }) <;>
      (try {
        cases' le_or_lt label x with h h <;>
        cases' le_or_lt (Classical.arbitrary α) x with h' h' <;>
        simp_all [fastCheckMem, LabelledTree.mem, IsOrdered] <;>
        (try { aesop }) <;>
        (try { linarith }) <;>
        (try { simp_all [add_assoc] })
      }) <;>
      (try {
        simp_all [add_assoc]
        <;>
        (try { aesop })
      }) <;>
      (try {
        simp_all [add_assoc]
        <;>
        (try { linarith })
      })
  exact h₁
