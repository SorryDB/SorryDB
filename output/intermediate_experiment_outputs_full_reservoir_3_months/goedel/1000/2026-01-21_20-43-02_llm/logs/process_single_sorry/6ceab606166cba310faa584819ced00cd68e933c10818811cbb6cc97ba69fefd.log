```lean
def buildBST : List α → LabelledTree α
  | [] => leaf (Classical.arbitrary α)
  | [x] => leaf x
  | x :: y :: xs =>
    let t : LabelledTree α := node (x ⊔ y) (leaf x) (leaf y)
    xs.foldl (fun acc x => addLabel acc x) t
    <;> simp_all [IsOrdered]
    <;>
    (try decide) <;>
    (try
      {
        intros;
        <;>
        (try contradiction) <;>
        (try
          {
            simp_all [LabelledTree.mem, IsOrdered]
            <;>
            (try omega)
          }
        )
      }
    )
    <;>
    (try
      {
        aesop
      }
    )

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  have h₁ : ∀ (l : List α), IsOrdered (buildBST l) := by
    intro l
    induction l with
    | nil =>
      simp [buildBST, IsOrdered]
      <;>
      (try
        {
          intros;
          <;>
          (try contradiction) <;>
          (try
            {
              simp_all [LabelledTree.mem, IsOrdered]
              <;>
              (try omega)
            }
          )
        }
      )
      <;>
      (try
        {
          aesop
        }
      )
    | cons x xs ih =>
      cases xs with
      | nil =>
        simp [buildBST, IsOrdered]
        <;>
        (try
          {
            intros;
            <;>
            (try contradiction) <;>
            (try
              {
                simp_all [LabelledTree.mem, IsOrdered]
                <;>
                (try omega)
              }
            )
          }
        )
        <;>
        (try
          {
            aesop
          }
        )
      | cons y ys =>
        simp_all [buildBST, List.foldl, addLabel, IsOrdered]
        <;>
        (try
          {
            intros;
            <;>
            (try contradiction) <;>
            (try
              {
                simp_all [LabelledTree.mem, IsOrdered]
                <;>
                (try omega)
              }
            )
          }
        )
        <;>
        (try
          {
            aesop
          }
        )
  exact h₁ labels

theorem buildBST_mem_correct (labels : List α)
