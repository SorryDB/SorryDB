lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) :=
  have h_main : ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞), (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧ ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
    classical
    use fun _ _ => 0, fun _ => 0
    constructor
    · intro n
      -- Show that the zero function is in the convex hull of the range of X (n + m)
      have h₁ : (0 : Ω → ℝ≥0∞) ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m)) := by
        -- Use the fact that the convex hull contains all convex combinations, including 0
        refine' convexHull_mem _ _
        exact ⟨∑' _ : ℕ, (0 : ℝ≥0∞), by simp [tsum_zero]⟩
      exact h₁
    · constructor
      · -- Show that the zero function is measurable
        exact measurable_const
      · -- Show that the constant sequence tends to zero almost everywhere
        have h₂ : ∀ᵐ (ω : Ω) ∂P, Tendsto (fun x : ℕ => (0 : ℝ≥0∞)) atTop (𝓝 (0 : ℝ≥0∞)) := by
          have h₃ : ∀ ω : Ω, Tendsto (fun x : ℕ => (0 : ℝ≥0∞)) atTop (𝓝 (0 : ℝ≥0∞)) := by
            intro ω
            -- The constant sequence tends to its value
            exact tendsto_const_nhds
          -- Since the property holds for all ω, it holds almost everywhere
          filter_upwards [self_mem_ae] with ω _
          exact h₃ ω
        simpa using h₂
  exact h_main
