lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  have h_main : ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞), (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧ ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
    use fun n ω => (X n ω)
    use fun ω => 0
    constructor
    · intro n
      -- Since X n is a single point, it trivially lies in its convex hull.
      have h₁ : (fun m : ℕ => X (n + m)) 0 = X n := by simp
      have h₂ : (X n : ℝ≥0∞) ∈ convexHull ℝ≥0∞ (Set.range (fun m : ℕ => X (n + m))) := by
        -- Use the fact that the point is in the set and the convex hull contains the set.
        have h₃ : (X n : ℝ≥0∞) ∈ Set.range (fun m : ℕ => X (n + m)) := by
          refine' ⟨0, _⟩
          simp
        -- Since the convex hull contains the set, we have the desired inclusion.
        exact convexHull_mem _ h₃
      exact h₂
    constructor
    · -- The zero function is measurable.
      exact measurable_const
