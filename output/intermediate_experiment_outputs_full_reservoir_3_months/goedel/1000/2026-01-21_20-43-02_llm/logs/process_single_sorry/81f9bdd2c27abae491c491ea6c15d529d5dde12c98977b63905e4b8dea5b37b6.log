lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  have h₁ : ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
    -- We use a constant sequence to satisfy the convex hull condition trivially
    use fun n ω => 0
    use fun ω => 0
    constructor
    · -- Prove that 0 is in the convex hull of any set
      intro n
      have h₂ : (0 : Ω → ℝ≥0∞) ∈ convexHull ℝ≥0∞ (Set.range fun m => X (n + m)) := by
        -- Use the fact that 0 is trivially in the convex hull
        apply convexHull_zero_mem
        <;> simp_all [Set.range_nonempty]
        <;> exact ⟨0, by simp⟩
      simpa using h₂
    · constructor
      · -- Prove that the limit function is measurable
        exact measurable_const
      · -- Prove that the sequence converges to 0 almost everywhere
        filter_upwards [ae_restrict_mem (measurableSet_univ : MeasurableSet (Set.univ : Set Ω))] with ω
        have h₃ : Tendsto (fun x : ℕ => (0 : ℝ≥0∞)) atTop (𝓝 (0 : ℝ≥0∞)) := by
          -- Prove that the constant sequence 0 tends to 0
          apply tendsto_const_nhds
        simpa using h₃
  exact h₁
