      exact hf.smul_right r
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      intro hf
      exact hf.smul_right (r⁻¹)
  -- Use the previously established equivalence to conclude the proof.
  exact h₁ f
