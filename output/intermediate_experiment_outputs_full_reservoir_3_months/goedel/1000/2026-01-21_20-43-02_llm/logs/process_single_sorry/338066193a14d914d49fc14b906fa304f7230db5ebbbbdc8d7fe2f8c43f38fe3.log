lemma mem_three (c : WickContraction 3) : c.1 ∈ ({∅, {{0, 1}}, {{0, 2}}, {{1, 2}}} :
    Finset (Finset (Finset (Fin 3)))) := by
  revert c
  -- We will use the fact that the number of contractions is finite and can be enumerated.
  -- The following lines will show that c must be one of the 4 possible contractions.
  -- This is achieved by checking the size and elements of the set of contractions.
  <;>
    (try decide) <;>
    (try
      {
        -- Use a decision procedure to verify that c is one of the listed contractions.
        -- This works because the number of possible contractions is small and can be enumerated exhaustively.
        simp only [Finset.mem_insert, Finset.mem_singleton, Finset.mem_coe]
        <;>
          (try decide) <;>
          (try
            {
              -- For each possible contraction, check that it matches one of the listed ones.
              fin_cases c <;>
