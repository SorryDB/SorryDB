    have h₂ : Fintype.card {p : Fin (2*n - 1) → ℤˣ // A + ∑ i, (p i : Fin 8) = E} = 0 := by
      -- Since 2*n - 1 is odd, the sum of steps cannot be 4 mod 8
      have h₃ : ∀ (p : Fin (2*n - 1) → ℤˣ), (A + ∑ i : Fin (2*n - 1), (p i : Fin 8)) ≠ E := by
        intro p
        have h₄ : (A + ∑ i : Fin (2*n - 1), (p i : Fin 8)) ≠ E := by
          rw [hE]
          have h₅ : (A + ∑ i : Fin (2*n - 1), (p i : Fin 8)) ≠ A + 4 := by
            intro h₆
            -- Simplify the equation modulo 8
            have h₇ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) = 4 := by
              have h₈ : (A + ∑ i : Fin (2*n - 1), (p i : Fin 8)) = A + 4 := by
                simpa using h₆
              have h₉ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) = 4 := by
                -- Subtract A from both sides
                have h₁₀ := congr_arg (fun x => x - A) h₈
                simp [add_comm, add_left_comm, add_assoc, Fin.ext_iff, Fin.val_add] at h₁₀ ⊢
