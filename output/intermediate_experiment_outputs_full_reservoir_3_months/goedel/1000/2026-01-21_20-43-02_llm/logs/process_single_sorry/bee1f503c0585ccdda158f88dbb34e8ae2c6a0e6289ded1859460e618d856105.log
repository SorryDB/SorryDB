n                  simp [h₁₃, Fin.ext_iff, Int.cast_neg, Int.cast_one]\n                  <;> norm_num\n                  <;> rfl\n                exact h₁₄\n            -- Sum of an odd number of odd numbers is odd\n            have h₁₃ : (∑ i : Fin (2*n - 1 : ℕ), (p i : Fin 8) : ℕ) % 2 = 1 := by\n              have h₁₄ : ∀ i : Fin (2*n - 1 : ℕ), ((p i : Fin 8) : ℕ) % 2 = 1 := h₁₂\n              have h₁₅ : (∑ i : Fin (2*n - 1 : ℕ), (p i : Fin 8) : ℕ) % 2 = 1 := by\n                have h₁₆ : (∑ i : Fin (2*n - 1 : ℕ), (p i : Fin 8) : ℕ) % 2 = (∑ i : Fin (2*n - 1 : ℕ), ((p i : Fin 8) : ℕ) % 2) % 2 := by\n                  simp [Finset.sum_nat_mod]\n                rw [h₁₆]\n                have h₁₇ : (∑ i : Fin (2*n - 1 : ℕ), ((p i : Fin 8) : ℕ) % 2) % 2 = 1 := by\n                  have h₁₈ : (∑ i : Fin (2*n - 1 : ℕ), ((p i : Fin 8) : ℕ) % 2) = ∑ i : Fin (2*n - 1 : ℕ), 1 := by\n                    apply Finset.sum_congr rfl\n                    intro i _\n                    rw [h₁₄ i]\n                  rw [h₁₈]\n                  have h₁₉ : ∑ i : Fin (2*n - 1 : ℕ), (1 : ℕ) = (2*n - 1 : ℕ) := by\n                    simp [Finset.card_fin]\n                  rw [h₁₉]\n                  have h₂₀ : (2*n - 1 : ℕ) % 2 = 1 := by\n                    have h₂₁ : n ≥ 1 := by omega\n                    have h₂₂ : (2*n - 1 : ℕ) % 2 = 1 := by\n                      have h₂₃ : (2*n : ℕ) % 2 = 0 := by\n                        omega\n                      have h₂₄ : (2*n - 1 : ℕ) % 2 = 1 := by\n                        omega\n                      exact h₂₄\n                    exact h₂₂\n                  omega\n                omega\n              exact h₁₅\n            exact h₁₃\n          -- Contr",
