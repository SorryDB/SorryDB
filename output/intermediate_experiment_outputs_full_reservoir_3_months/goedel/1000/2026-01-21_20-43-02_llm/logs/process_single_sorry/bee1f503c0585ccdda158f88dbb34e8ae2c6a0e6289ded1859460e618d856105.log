              omega
            -- The sum cannot be 4 modulo 8
            have h₂₆ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) % 8 = 4 % 8 → False := h₁₀
            have h₂₇ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) = 4 := h₇
            have h₂₈ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) % 8 = 4 % 8 := by
              rw [h₂₇]
              <;> norm_num
            exact h₂₆ h₂₈
          exact h₅
        exact h₄
      -- The set is empty
      have h₅ : {p : Fin (2*n - 1) → ℤˣ // A + ∑ i, (p i : Fin 8) = E} = ∅ := by
        apply Eq.symm
        apply Eq.symm
        apply Set.eq_empty_of_forall_not_mem
        intro p hp
        have h₆ := h₃ p
        simp_all [Set.mem_setOf_eq]
      -- The cardinality is 0
      rw [h₅]
      simp
    -- Using the definition of a
    have h₃ : a (2*n - 1 : ℕ) = Fintype.card {p : Fin (2*n - 1) → ℤˣ // A + ∑ i, (p i : Fin 8) = E} := by
      rw [ha_def]
    rw [h₃]
    rw [h₂]
