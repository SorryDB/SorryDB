                  intro i
                  have h₁₄ : (p i : Fin 8) = 1 ∨ (p i : Fin 8) = 7 := by
                    have h₁₅ : (p i : ℤˣ) = 1 ∨ (p i : ℤˣ) = -1 := by
                      have h₁₆ : (p i : ℤˣ) = 1 ∨ (p i : ℤˣ) = -1 := by
                        have h₁₇ : (p i : ℤˣ) = 1 ∨ (p i : ℤˣ) = -1 := by
                          -- Since p i is in ℤˣ, it must be ±1
                          fin_cases (p i : ℤˣ) <;> simp_all (config := {decide := true})
                        exact h₁₇
                      exact h₁₆
                    cases h₁₅ with
                    | inl h₁₅ =>
                      have h₁₆ : (p i : Fin 8) = 1 := by
                        simp [h₁₅, Int.cast_one, Fin.ext_iff]
                        <;> norm_num <;>
                        (try omega)
                      exact Or.inl h₁₆
                    | inr h₁₅ =>
                      have h₁₆ : (p i : Fin 8) = 7 := by
                        simp [h₁₅, Int.cast_neg, Fin.ext_iff]
                        <;> norm_num <;>
                        (try omega)
                      exact Or.inr h₁₆
                  exact h₁₄
                have h₁₈ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) % 2 = 1 := by
                  have h₁₉ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) % 2 = (2*n - 1) % 2 := by
                    have h₂₀ : ∀ i : Fin (2*n - 1), (p i : Fin 8) % 2 = 1 := by
                      intro i
                      have h₂₁ : (p i : Fin 8) = 1 ∨ (p i : Fin 8) = 7 := h₁₃ i
                      cases h₂₁ with
