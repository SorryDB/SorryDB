                      _ = (2*n - 1) % 2 := by
                        simp [Finset.sum_const, Finset.card_fin]
                        <;>
                        ring_nf <;>
                        simp [Nat.mul_mod, Nat.add_mod, Nat.mod_mod] <;>
                        omega
                  have h₂₂ : (2*n - 1) % 2 = 1 := by
                    have h₂₃ : n ≥ 1 := by omega
                    have h₂₄ : 2*n - 1 = 2*(n - 1) + 1 := by
                      cases n with
                      | zero => omega
                      | succ n =>
                        simp [Nat.mul_succ, Nat.add_assoc]
                        <;> ring_nf at * <;> omega
                    rw [h₂₄]
                    simp [Nat.add_mod, Nat.mul_mod, Nat.mod_mod]
                  omega
