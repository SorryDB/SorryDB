                <;>
                  simp_all [Fin.val_add, Fin.val_mk]
                <;>
                  omega
              exact h₉
            -- The sum of an odd number of ±1 is odd, so it cannot be 4
            have h₁₀ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) % 8 = 4 % 8 → False := by
              intro h₁₀
              have h₁₁ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) % 8 = 4 % 8 := h₁₀
              have h₁₂ : (∑ i : Fin (2*n - 1), (p i : Fin 8)) % 2 = 1 := by
                -- Each p i is ±1, so the sum modulo 2 is (2*n - 1) mod 2 = 1
