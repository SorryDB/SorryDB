  | .leaf _ => 1
  | .node _ l r => countLeaves l + countLeaves r

def countLeaves' {a : Type*} (t : Tree a) (n : ℕ) : ℕ :=
  match t with
  | .leaf _ => n + 1
  | .node _ l r => countLeaves' l (countLeaves' r n)

theorem countLeaves : ∀ {a : Type*} (t : Tree a),
    countLeaves t = countLeaves' t 0 := by
  intro a t
  have h : countLeaves t = countLeaves' t 0 := by
    induction t with
    | leaf x =>
