theorem countLeaves : ∀ {a : Type*} (t : Tree a),
    countLeaves t = countLeaves' t 0 := by
  intro a t
  have h : countLeaves t = countLeaves' t 0 := by
    induction t with
    | leaf x =>
      -- Base case: a single leaf node
      rfl
    | node a l r ih1 ih2 =>
      -- Inductive step: a node with left and right subtrees
      simp_all [countLeaves', countLeaves, add_assoc]
      <;>
      (try cases l <;> cases r <;> simp_all [countLeaves', countLeaves, add_assoc]) <;>
      (try omega) <;>
