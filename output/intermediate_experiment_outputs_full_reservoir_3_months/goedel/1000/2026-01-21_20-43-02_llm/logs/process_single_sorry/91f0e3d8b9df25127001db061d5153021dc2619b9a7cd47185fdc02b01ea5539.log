theorem FReal_Differentiable {t : ℝ} (ht : 0 < t) : DifferentiableAt ℝ FReal t := by
  have h₁ : DifferentiableAt ℝ (fun t : ℝ => (F.resToImagAxis t).re) t := by
    -- Use the fact that F is holomorphic and the composition of differentiable functions is differentiable
    have h₂ : MDifferentiable ℝ ℝ (fun t : ℝ => (F.resToImagAxis t).re) := by
      -- Use the fact that F is holomorphic and the composition of differentiable functions is differentiable
      have h₃ : MDifferentiable ℝ ℝ (fun t : ℝ => (F.resToImagAxis t).re) := by
        -- Use the fact that F is holomorphic and the composition of differentiable functions is differentiable
        apply Complex.differentiableAt_toReal.comp
        apply hF.holomorphicAt
        <;> simp_all [Complex.ext_iff]
        <;> try norm_num <;> try linarith
      exact h₃
    -- Use the fact that F is holomorphic and the composition of differentiable functions is differentiable
    exact h₂.differentiableAt
  -- Simplify the expression to match the definition of FReal
  simpa [FReal] using h₁
