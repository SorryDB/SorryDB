ree]\n            <;> (try norm_num)\n            <;> (try ring_nf)\n            <;> (try simp_all [Complex.ext_iff, pow_two, pow_three])\n            <;> (try norm_num)\n            <;> (try ring_nf)\n            <;> (try linarith)\n          })\n      -- Use the fact that the restriction to the imaginary axis is differentiable\n      have h₅ : DifferentiableAt ℝ (fun t : ℝ => (F (Complex.I * t)).re) t := by\n        have h₆ : DifferentiableAt ℝ (fun t : ℝ => (Complex.I * t : ℂ)) t := by\n          simpa using (hasDerivAt_id t).const_mul Complex.I |>.differentiableAt\n        have h₇ : DifferentiableAt ℝ (fun z : ℂ => (F z).re) (Complex.I * t) := h₄\n        have h₈ : DifferentiableAt ℝ (fun t : ℝ => (F (Complex.I * t)).re) t := by\n          apply DifferentiableAt.comp t h₇ h₆\n        exact h₈\n      -- Use the fact that the real part of the restriction is differentiable\n      have h₆ : DifferentiableAt ℝ (fun t : ℝ => (F.resToImagAxis t).re) t := by\n        -- Use the fact that the real part of the restriction is differentiable\n        convert h₅ using 1\n        <;> simp [Complex.ext_iff, resToImagAxis]\n        <;> ring_nf\n        <;> simp_all [Complex.ext_iff, pow_two, pow_three]\n        <;> norm_num\n        <;> linarith\n      exact h₆\n    -- Use the fact that the real part of the restriction is differentiable\n    have h₃ : (fun t : ℝ => (F.resToImagAxis t).re) = FReal := by\n      funext t\n      rfl\n    rw [h₃] at h₂\n    exact h₂\n  exact h₁",
