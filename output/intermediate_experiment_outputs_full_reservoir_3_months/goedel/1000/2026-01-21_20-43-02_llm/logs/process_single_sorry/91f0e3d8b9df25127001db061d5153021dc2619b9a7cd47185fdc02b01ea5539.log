      "\n  have h₁ : DifferentiableAt ℝ (fun t : ℝ => (F.resToImagAxis t).re) t := by\n    have h₂ : DifferentiableAt ℝ (fun t : ℝ => F.resToImagAxis t) t := by\n      -- Prove that F.resToImagAxis is differentiable at t\n      apply DifferentiableAt.congr_of_eventuallyEq (differentiableAt_id.const_mul (1 : ℝ) |>.comap (differentiableAt_const _ |>.add (differentiableAt_id)))\n      filter_upwards [isOpen_Ioi.mem_nhds ht] with t' ht'\n      <;> simp [F, E₂, E₄, E₆, Complex.ext_iff, pow_two, pow_three, Complex.ext_iff, Complex.ofReal_add,\n        Complex.ofReal_sub, Complex.ofReal_mul, Complex.ofReal_pow]\n      <;>\n      (try norm_num) <;>\n      (try ring_nf) <;>\n      (try field_simp [ht'.ne']) <;>\n      (try simp_all [Complex.ext_iff, pow_two, pow_three, Complex.ofReal_add, Complex.ofReal_sub,\n        Complex.ofReal_mul, Complex.ofReal_pow]) <;>\n      (try norm_num) <;>\n      (try ring_nf) <;>\n      (try field_simp [ht'.ne']) <;>\n      (try linarith)\n      <;>\n      (try simp_all [Complex.ext_iff, pow_two, pow_three, Complex.ofReal_add, Complex.ofReal_sub,\n        Complex.ofReal_mul, Complex.ofReal_pow]) <;>\n      (try norm_num) <;>\n      (try ring_nf) <;>\n      (try field_simp [ht'.ne']) <;>\n      (try linarith)\n    -- Since F.resToImagAxis is differentiable, its real part is differentiable\n    have h₃ : DifferentiableAt ℝ (fun t : ℝ => (F.resToImagAxis t).re) t := by\n      apply DifferentiableAt.re\n      exact h₂\n    exact h₃\n  -- Since (fun t : ℝ => (F.resToImagAxis t).re) is differentiable, FReal is differentiable\n  have h₄ : FReal = fun t : ℝ => (F.resToImagAxis t).re := by\n    funext t\n    rfl\n  rw [h₄]\n  exact h₁",
      "\n  have h₁ : DifferentiableAt ℝ (fun t : ℝ => (F.resToImagAxis t).re) t := by\n    have h₂ : DifferentiableAt 𝕜 (fun w : 𝕜 => (F w : 𝕜)) (t * Complex.I) := by\n      -- Show that F is differentiable at t * Complex.I\n      have h₃ : DifferentiableAt 𝕜 (fun w : 𝕜 => (F w : 𝕜)) (t * Complex.I) := by\n        apply DifferentiableAt.mono F_holo\n        intro z hz\n        simp only [Metric.ball, Complex.norm_eq_abs, Complex.abs, Real.dist_eq, Complex.ext_iff,\n          Real.sqrt_lt, Real.lt_sqrt, sq, mul_self_nonneg, add_nonneg, mul_self_nonneg] at hz ⊢\n        simp_all [Complex.I_mul_I]\n        <;>\n        (try norm_num) <;>\n        (try linarith) <;>\n        (try constructor <;> nlinarith)\n      exact h₃\n    -- Use the fact that F is differentiable along the imaginary axis to show that FReal is differentiable\n    have h₃ : DifferentiableAt ℝ (fun t : ℝ => (F.resToImagAxis t).re) t := by\n      -- Use the chain rule and the fact that the real part of a differentiable function is differentiable\n      have h₄ : DifferentiableAt 𝕜 (fun w : 𝕜 => (F w : 𝕜)) (t * Complex.I) := h₂\n      have h₅ : DifferentiableAt ℝ (fun t : ℝ => (F.resToImagAxis t).re) t := by\n        -- Use the fact that the real part of a differentiable function is differentiable\n        have h₆ : (fun t : ℝ => (F.resToImagAxis t).re) = (fun t : ℝ => (F (t * Complex.I)).re) := by\n          funext t\n          simp [resToImagAxis]\n          <;>\n          ring_nf\n          <;>\n          simp [Complex.ext_iff, pow_two]\n          <;>\n          norm_num\n          <;>\n          simp_all [Complex.ext_iff, pow_two]\n          <;>\n          norm_num\n          <;>\n          linarith\n        rw [h₆]\n        -- Use the fact that the real part of a differentiable function is differentiable\n        have h₇ : DifferentiableAt ℝ (fun t : ℝ => (F (t * Complex.I)).re) t := by\n          -- Use the chain rule and the fact that F is differentiable at t * Complex.I\n          have h₈ : Diffe