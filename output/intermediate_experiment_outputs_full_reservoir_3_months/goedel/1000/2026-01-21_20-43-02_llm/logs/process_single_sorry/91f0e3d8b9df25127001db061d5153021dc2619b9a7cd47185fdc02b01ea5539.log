theorem FReal_Differentiable {t : ℝ} (ht : 0 < t) : DifferentiableAt ℝ FReal t := by
  have h₁ : DifferentiableAt ℝ FReal t := by
    -- Use the fact that `F` is holomorphic and the restriction to the imaginary axis is smooth
    -- to deduce the differentiability of `FReal`.
    have h₂ : Complex.differentiableAt (fun z : ℂ => F z) t := by
      -- The function `F` is holomorphic, hence complex differentiable everywhere.
      have h₃ : Differentiable ℂ F := by
        exact F_holo.differentiable le_rfl
      -- Since `F` is holomorphic, it is complex differentiable at `t`.
      exact h₃.differentiableAt
    -- The restriction of `F` to the imaginary axis is smooth, hence `FReal` is differentiable at `t`.
    have h₄ : DifferentiableAt ℝ FReal t := by
      -- Use the fact that the real part of a complex differentiable function is real differentiable.
      have h₅ : DifferentiableAt ℝ (fun x : ℝ => (F (x * Complex.I)).re) t := by
        -- The function `x ↦ F(x * I)` is complex differentiable, hence its real part is real differentiable.
        have h₆ : DifferentiableAt ℂ (fun x : ℝ => (x : ℂ) * Complex.I) t := by
          -- The map `x ↦ x * I` is complex differentiable.
          exact differentiableAt_id.const_mul (Complex.I)
        have h₇ : DifferentiableAt ℂ (fun z : ℂ => F z) (t * Complex.I) := by
          -- `F` is complex differentiable at `t * I`.
          have h₈ : Differentiable ℂ F := by
            exact F_holo.differentiable le_rfl
          exact h₈.differentiableAt
        -- Compose the two differentiable functions.
        have h₉ : DifferentiableAt ℂ (fun x : ℝ => F (x * Complex.I)) t := by
          apply DifferentiableAt.comp (h₇) h₆
        -- The real part of a complex differentiable function is real differentiable.
