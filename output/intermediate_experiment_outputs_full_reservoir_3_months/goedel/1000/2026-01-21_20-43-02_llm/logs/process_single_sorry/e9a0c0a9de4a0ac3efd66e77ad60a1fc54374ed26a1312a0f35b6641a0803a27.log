    (try simp_all [Nat.div_eq_of_lt]) <;>
    (try ring_nf at *) <;>
    (try nlinarith) <;>
    (try omega) <;>
    (try
      {
        have h₉ : 0 < (a * b + 1 : ℕ) := by nlinarith [h₀.1, h₀.2]
        have h₁₀ : (a ^ 2 + b ^ 2) = k * (a * b + 1) := by linarith
        have h₁₁ : (a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) = k := by
          rw [h₁₀]
          have h₁₂ : (k * (a * b + 1)) / (a * b + 1 : ℕ) = k := by
            apply Nat.div_eq_of_eq_mul_left (by nlinarith [h₀.1, h₀.2])
            <;> ring_nf
            <;> nlinarith
          rw [h₁₂]
        nlinarith
      })
  obtain ⟨x, hx⟩ := h₃
  have h₄ : (x : ℝ) ^ 2 = (a ^ 2 + b ^ 2 : ℝ) / (a * b + 1 : ℝ) := by
    have h₅ : (x : ℕ) * x = (a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) := by
      simpa using hx
    have h₆ : (a * b + 1 : ℕ) ∣ (a ^ 2 + b ^ 2) := h₁
    have h₇ : (a ^ 2 + b ^ 2 : ℝ) / (a * b + 1 : ℝ) = ((a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) : ℝ) := by
      have h₈ : 0 < (a * b + 1 : ℕ) := by
        nlinarith [h₀.1, h₀.2]
      field_simp [h₈.ne']
      <;>
      norm_cast
      <;>
      simp_all [Nat.cast_add, Nat.cast_mul, Nat.cast_one]
      <;>
      ring_nf at *
      <;>
      norm_cast at *
      <;>
      field_simp [h₈.ne'] at *
      <;>
      norm_cast at *
      <;>
      linarith
    have h₈ : (x : ℝ) ^ 2 = ((x : ℕ) * x : ℝ) := by
      norm_cast
      <;>
      ring_nf
      <;>
      simp [pow_two]
    have h₉ : ((x : ℕ) * x : ℝ) = ((a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) : ℝ) := by
      norm_cast at h₅ ⊢
      <;>
      simp_all [Nat.cast_add, Nat.cast_mul, Nat.cast_one]
      <;>
      ring_nf at *
      <;>
      norm_cast at *
      <;>
      linarith
    calc
      (x : ℝ) ^ 2 = ((x : ℕ) * x : ℝ) := by rw [h₈]
      _ = ((a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) : ℝ) := by rw [h₉]
      _ = (a ^ 2 + b ^ 2 : ℝ) / (a * b + 1 : ℝ) := by rw [h₇]
  exact ⟨x, h₄⟩
