theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  have h₂ : ∃ x : ℕ, x ^ 2 = (a ^ 2 + b ^ 2) / (a * b + 1) := by
    obtain ⟨k, hk⟩ := h₁
    have h₃ : k = (a ^ 2 + b ^ 2) / (a * b + 1) := by
      have h₄ : a * b + 1 > 0 := by nlinarith
      have h₅ : (a * b + 1 : ℕ) * k = a ^ 2 + b ^ 2 := by
        linarith
      have h₆ : k = (a ^ 2 + b ^ 2) / (a * b + 1) := by
        apply Eq.symm
        apply Nat.div_eq_of_eq_mul_left (by nlinarith)
        <;> nlinarith
      exact h₆
    refine' ⟨k, _⟩
    rw [h₃]
    <;>
    (try simp_all) <;>
    (try norm_num) <;>
    (try ring_nf at *) <;>
    (try omega)
  
  obtain ⟨x, hx⟩ := h₂
  refine' ⟨x, _⟩
  norm_cast at hx ⊢
  <;>
  (try simp_all [pow_two]) <;>
  (try field_simp at *) <;>
  (try ring_nf at *) <;>
  (try norm_cast at *) <;>
  (try linarith)
