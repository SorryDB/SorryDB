  have h₂ : (a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) = (a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) := rfl
  have h₃ : ∃ (x : ℕ), x * x = (a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) := by
    -- Use the fact that a * b + 1 divides a ^ 2 + b ^ 2 to find the quotient
    have h₄ : (a * b + 1 : ℕ) ∣ (a ^ 2 + b ^ 2) := h₁
    have h₅ : ∃ (k : ℕ), (a ^ 2 + b ^ 2) = k * (a * b + 1) := by
      obtain ⟨k, hk⟩ := h₄
      exact ⟨k, by linarith⟩
    obtain ⟨k, hk⟩ := h₅
    have h₆ : (a ^ 2 + b ^ 2) / (a * b + 1 : ℕ) = k := by
      rw [hk]
      have h₇ : 0 < (a * b + 1 : ℕ) := by
        nlinarith [h₀.1, h₀.2]
      have h₈ : (k * (a * b + 1)) / (a * b + 1 : ℕ) = k := by
        apply Nat.div_eq_of_eq_mul_left (by nlinarith [h₀.1, h₀.2])
        <;> ring_nf
        <;> nlinarith
      rw [h₈]
    use k
