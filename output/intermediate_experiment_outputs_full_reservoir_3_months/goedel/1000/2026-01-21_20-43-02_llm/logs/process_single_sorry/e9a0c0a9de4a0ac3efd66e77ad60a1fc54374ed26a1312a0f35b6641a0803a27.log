theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  have h₂ : ∃ x : ℕ, x ^ 2 = (a ^ 2 + b ^ 2) / (a * b + 1) := by
    have h₃ : a * b + 1 ∣ a ^ 2 + b ^ 2 := h₁
    have h₄ : (a ^ 2 + b ^ 2) / (a * b + 1) * (a * b + 1) = a ^ 2 + b ^ 2 := by
      have h₅ : (a * b + 1) ∣ (a ^ 2 + b ^ 2) := h₃
      have h₆ : (a ^ 2 + b ^ 2) / (a * b + 1) * (a * b + 1) = a ^ 2 + b ^ 2 := by
        apply Nat.div_mul_cancel h₅
      exact h₆
    have h₇ : ∃ x : ℕ, x ^ 2 = (a ^ 2 + b ^ 2) / (a * b + 1) := by
      use (a ^ 2 + b ^ 2) / (a * b + 1)
      <;> norm_num
      <;>
      (try decide)
      <;>
      (try ring_nf at *)
      <;>
      (try simp_all [Nat.div_eq_of_lt])
      <;>
      (try omega)
      <;>
      (try nlinarith)
    exact h₇
  obtain ⟨x, hx⟩ := h₂
  refine' ⟨x, _⟩
  norm_cast at hx ⊢
  <;>
  field_simp [h₀.1.ne', h₀.2.ne', Nat.cast_add_one_ne_zero] at hx ⊢ <;>
  ring_nf at hx ⊢ <;>
  norm_cast at hx ⊢ <;>
  simp_all [pow_two]
  <;>
  nlinarith
