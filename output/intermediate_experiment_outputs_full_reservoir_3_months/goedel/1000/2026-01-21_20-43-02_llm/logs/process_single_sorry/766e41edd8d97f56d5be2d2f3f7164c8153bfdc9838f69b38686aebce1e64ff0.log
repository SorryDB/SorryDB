### Solution

```lean
def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    simpa using g.map_one.trans (congr_arg f (by simp))
  map_mul' := by
    intro x y
    simp [f.map_mul, g.map_mul]
    <;> ring_nf
    <;> simp_all [RingHom.map_mul]
    <;> ring_nf
  map_zero' := by
    have h₁ : g (f 0) = 0 := by
      have h₂ : f 0 = 0 := by simp [f.map_zero]
      rw [h₂]
      simp [g.map_zero]
    simpa using h₁
```
