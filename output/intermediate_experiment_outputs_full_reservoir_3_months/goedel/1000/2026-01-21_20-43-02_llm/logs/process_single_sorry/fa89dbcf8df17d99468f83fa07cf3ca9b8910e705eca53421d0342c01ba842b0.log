      "\n  have h₁ : stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by\n    -- Use the fact that the stopped value at the minimum is less than or equal to the conditional expectation\n    have h₂ : (fun x => x : WithTop ι → WithTop ι) = id := rfl\n    have h₃ : ∀ (ω : Ω), (τ ⊓ σ) ω ≤ τ ω := by\n      intro ω\n      simp [min_le_left]\n    have h₄ : (fun ω => (τ ⊓ σ) ω) ≤ fun ω => τ ω := by\n      -- Prove that the minimum of τ and σ is less than or equal to τ\n      intro ω\n      exact h₃ ω\n    -- Use the property of conditional expectations and the fact that X is a submartingale to show the inequality\n    have h₅ : stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by\n      -- Use the fact that X is a submartingale and the minimum is less than or equal to τ\n      -- to deduce the inequality for the stopped values and their conditional expectations\n      exact hX1.submartingale_stoppedValue_min_le_condExp hX2 hτ hσ h₃ hτk\n    exact h₅\n  exact h₁",
      "\n  have h1 : ∀ ω, stoppedValue X (τ ⊓ σ) ω ≤ P[stoppedValue X τ|hσ.measurableSpace] ω := by\n    intro ω\n    have h2 : stoppedValue X (τ ⊓ σ) ω ≤ stoppedValue X τ ω := by\n      have h3 : τ ω ⊓ σ ω ≤ τ ω := by\n        exact inf_le_left\n      have h4 : X (τ ω ⊓ σ ω) ω ≤ X (τ ω) ω := by\n        have h5 : RightContinuous (fun x => X x ω) := hX2 ω\n        have h6 : τ ω ⊓ σ ω ≤ τ ω := inf_le_left\n        -- Use the fact that the process is a submartingale to compare the values at different times\n        have h7 : X (τ ω ⊓ σ ω) ω ≤ X (τ ω) ω := by\n          -- Use the right continuity of the sample paths to ensure the inequality holds\n          have h8 : IsClosed (Set.Ici (X (τ ω) ω)) := isClosed_Ici\n          have h9 : (fun x => X x ω) (τ ω ⊓ σ ω) ∈ closure (Set.Ici (X (τ ω) ω)) := by\n            -- Use the right continuity to show that the value at τ ω ⊓ σ ω is in the closure of the interval\n            have h10 : ContinuousAt (fun x : ι => X x ω) (τ ω ⊓ σ ω) := by\n              have h11 : RightContinuous (fun x : ι => X x ω) := hX2 ω\n              exact h11.continuousWithinAt\n            have h12 : Filter.Tendsto (fun x : ι => X x ω) (𝓝[≥] (τ ω ⊓ σ ω)) (𝓝 (X (τ ω ⊓ σ ω) ω)) :=\n              (hX2 ω).tendsto_within_right\n            have h13 : Filter.Tendsto (fun x : ι => X x ω) (𝓝[≥] (τ ω ⊓ σ ω)) (𝓝 (X (τ ω ⊓ σ ω) ω)) := h12\n            have h14 : (X (τ ω) ω) ∈ Set.Ici (X (τ ω) ω) := by\n              exact Set.mem_Ici.mpr le_rfl\n            -- Use the fact that the process is a submartingale and the right continuity to show the inclusion\n            have h15 : (fun x => X x ω) (τ ω ⊓ σ ω) ∈ closure (Set.Ici (X (τ ω) ω)) := by\n              -- Use the right continuity to show that the value at τ ω ⊓ σ ω is in the closure of the interval\n              have h16 : (fun x => X x ω) (τ ω ⊓ σ ω) ∈ closure (Set.Ici (X (τ ω) ω)) := by\n                -- Use the right continuity to show that the value at τ ω ⊓ σ ω is in the closure of the interval\