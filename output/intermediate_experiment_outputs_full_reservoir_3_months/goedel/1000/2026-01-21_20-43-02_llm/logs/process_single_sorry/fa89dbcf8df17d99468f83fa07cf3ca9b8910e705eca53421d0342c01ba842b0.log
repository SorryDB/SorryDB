theorem Submartingale.stoppedValue_min_ae_le_condExp [PartialOrder E] [OrderClosedTopology E]
    [IsOrderedModule ℝ E] [IsOrderedAddMonoid E]
    (hX1 : Submartingale X 𝓕 P) (hX2 : ∀ ω, RightContinuous (X · ω)) {k : ι}
    (hτk : ∀ᵐ ω ∂P, τ ω ≤ k) (hσ : IsStoppingTime 𝓕 σ) (hτ : IsStoppingTime 𝓕 τ) :
    stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
  have h₁ : stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X (τ ⊓ σ) | hσ.measurableSpace] := by
    refine' (le_condExp _ _).aestronglyMeasurable
    exact intermediateValue_stoppedValue hX1 hX2 (hτ ∧ hσ)
  have h₂ : P[stoppedValue X (τ ⊓ σ) | hσ.measurableSpace] ≤ᵐ[P] P[stoppedValue X τ | hσ.measurableSpace] := by
    have h₃ : stoppedValue X (τ ⊓ σ) ≤ᵐ[P] stoppedValue X τ := by
      filter_upwards [hτk] with ω hω
      have h₄ : (τ ⊓ σ) ω ≤ τ ω := min_le_left _ _
      have h₅ : (τ ⊓ σ) ω ≤ k := by
        calc
          (τ ⊓ σ) ω ≤ τ ω := min_le_left _ _
          _ ≤ k := hω
      exact stoppedValue_mono (fun i => X i ω) (by
        -- Prove the partial order for ι
        exact fun i j h => by
          -- Since ι is a linear order, we can use the given order
          exact le_trans (le_of_lt h) (by simp_all [le_refl])) h₄
    exact condExp_mono h₃
  refine' le_trans h₁ h₂
