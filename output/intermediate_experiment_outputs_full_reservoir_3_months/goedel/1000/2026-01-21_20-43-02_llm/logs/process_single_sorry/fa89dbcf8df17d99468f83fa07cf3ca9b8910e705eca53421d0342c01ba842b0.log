    (hτk : ∀ᵐ ω ∂P, τ ω ≤ k) (hσ : IsStoppingTime 𝓕 σ) (hτ : IsStoppingTime 𝓕 τ) :
    stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
  -- Use the fact that the minimum of two stopping times is also a stopping time.
  have hmin : IsStoppingTime 𝓕 (fun x => τ x ⊓ σ x) := hτ.min hσ
  -- Use the property of submartingales for the minimum of two stopping times.
  have hX3 : Submartingale X 𝓕 P := hX1
  -- Use the fact that the conditional expectation of the stopped value at the minimum time is less than or equal to the conditional expectation of the stopped value at the first stopping time.
  have h4 : stoppedValue X (fun ω => τ ω ⊓ σ ω) ≤ᵐ[P] P[stoppedValue X τ|hmin.measurableSpace] := by
    -- This is a direct consequence of the submartingale property.
    have h5 : stoppedValue X (fun ω => τ ω ⊓ σ ω) ≤ᵐ[P] stoppedValue X τ := by
      apply Real.ae_measurable_of_forall_ae_le (measurable_stoppedValue hX3.adapted hmin)
        (measurable_stoppedValue hX3.adapted hτ)
      filter_upwards [hτk] with ω hω
      have h6 : (τ ω ⊓ σ ω : WithTop ι) ≤ τ ω := by
        simp [inf_le_left]
      simp_all [stoppedValue, P]
