 exact h₁₆\n              -- Use the fact that the conditional expectation is greater than or equal to the stopped value\n              linarith\n      exact h₈\n    exact h₅\n  -- Use the fact that the inequality holds almost everywhere to conclude the proof\n  filter_upwards [h₃] with ω h₃\n  <;> simp_all [le_refl]\n  <;> aesop\n```lean\n```lean\n```lean\n```lean\n  <;> aesop\n```lean\n```lean\nlean\n```lean\n```lean\n```lean\n```lean\n```lean\n```lean\n```lean\ntheorem Submartingale.stoppedValue_min_ae_le_condExp [PartialOrder E] [OrderClosedTopology E]\n    [IsOrderedModule ℝ E] [IsOrderedAddMonoid E]\n    (hX1 : Submartingale X 𝓕 P) (hX2 : ∀ ω, RightContinuous (X · ω)) {k : ι}\n    (hτk : ∀ᵐ ω ∂P, τ ω ≤ k) (hσ : IsStoppingTime 𝓕 σ) (hτ : IsStoppingTime 𝓕 τ) :\n    stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by\n  have h₃ : ∀ᵐ ω ∂P, stoppedValue X (τ ⊓ σ) ω ≤ P[stoppedValue X τ|hσ.measurableSpace] ω := by\n    have h₄ : ∀ᵐ ω ∂P, τ ω ≤ k := hτ",
      "\n  have h₁ : stoppingTime σ ⊓ stoppingTime τ ≤ stoppingTime τ := by\n    exact inf_le_right\n  have h₂ : ∀ ω, (τ ⊓ σ) ω ≤ τ ω := by\n    intro ω\n    simp_all [min_le_left]\n  have h₃ : ∀ ω, stoppingTime (τ ⊓ σ) ω ≤ stoppingTime τ ω := by\n    intro ω\n    simp_all [min_le_left]\n  have h₄ : ∀ ω ∈ {ω : Ω | τ ω ≤ k}, (τ ⊓ σ) ω ≤ k := by\n    intro ω hω\n    have h₅ : (τ ⊓ σ) ω ≤ τ ω := by\n      simp_all [min_le_left]\n    have h₆ : τ ω ≤ k := by simpa using hω\n    have h₇ : (τ ⊓ σ) ω ≤ k := le_trans h₅ h₆\n    exact h₇\n  have h₅ : ∀ᵐ ω ∂P, (τ ⊓ σ) ω ≤ k := by\n    filter_upwards [hτk] with ω hω\n    simp_all [h₄]\n  have h₆ : ∀ ω, (τ ⊓ σ) ω ≤ k → (τ ⊓ σ) ω ≤ k := by\n    intro ω hω\n    exact hω\n  have h₇ : ∀ ω, (τ ⊓ σ) ω ≤ k → (τ ⊓ σ) ω ≤ k := by\n    intro ω hω\n    exact hω\n  have h₈ : (P : Measure Ω) [stoppedValue X (τ ⊓ σ)|hσ.measurableSpace] ≤ P [stoppedValue X τ|hσ.measurableSpace] := by\n    -- Use the fact that the stopped value is decreasing\n    have h₈₁ : ∀ ω, (τ ⊓ σ) ω ≤ τ ω := by\n      intro ω\n      simp [min_le_left]\n    -- Use the fact that the stopped value is decreasing\n    have h₈₂ : stoppedValue X (τ ⊓ σ) ≤ stoppedValue X τ := by\n      -- Use the fact that the stopped value is decreasing\n      apply stoppedValue_mono\n      intro ω\n      simp [h₈₁ ω]\n      <;>\n      (try simp_all [le_refl]) <;>\n      (try omega) <;>\n      (try linarith) <;>\n      (try\n        {\n          simp_all [le_of_lt]\n          <;>\n          linarith\n        })\n      <;>\n      (try\n        {\n          simp_all [le_of_lt]\n          <;>\n          linarith\n        })\n    -- Use the fact that the stopped value is decreasing\n    have h₈₃ : (P : Measure Ω) [stoppedValue X (τ ⊓ σ)|hσ.measurableSpace] ≤ P [stoppedValue X τ|hσ.measurableSpace] := by\n      -- Use the fact that the stopped value is decreasing\n      apply condLp.map_mono\n      <;>\n      (try simp_all [h₈₂]) <;>\n      (try norm_num) <;>\n      (try simp_all [le_refl]) <;>\n    