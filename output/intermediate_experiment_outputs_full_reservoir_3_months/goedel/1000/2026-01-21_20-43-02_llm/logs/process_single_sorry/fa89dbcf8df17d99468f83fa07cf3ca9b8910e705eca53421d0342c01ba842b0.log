theorem Submartingale.stoppedValue_min_ae_le_condExp [PartialOrder E] [OrderClosedTopology E]
    [IsOrderedModule ℝ E] [IsOrderedAddMonoid E]
    (hX1 : Submartingale X 𝓕 P) (hX2 : ∀ ω, RightContinuous (X · ω)) {k : ι}
    (hτk : ∀ᵐ ω ∂P, τ ω ≤ k) (hσ : IsStoppingTime 𝓕 σ) (hτ : IsStoppingTime 𝓕 τ) :
    stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
  have h₃ : ∀ᵐ ω ∂P, stoppedValue X (τ ⊓ σ) ω ≤ P[stoppedValue X τ|hσ.measurableSpace] ω := by
    have h₄ : ∀ᵐ ω ∂P, τ ω ≤ k := hτk
    have h₅ : ∀ᵐ ω ∂P, stoppedValue X (τ ⊓ σ) ω ≤ P[stoppedValue X τ|hσ.measurableSpace] ω := by
      filter_upwards [hX1.eventually_stronglyMeasurable, hX2.eventually_stronglyMeasurable] with
        ω h₆ h₇
      -- Use the fact that the submartingale property holds almost everywhere
      have h₈ : stoppedValue X (τ ⊓ σ) ω ≤ P[stoppedValue X τ|hσ.measurableSpace] ω := by
        -- Prove that the stopped value is less than or equal to the conditional expectation
        have h₉ : stoppedValue X (τ ⊓ σ) ω ≤ stoppedValue X τ ω := by
          -- Use the submartingale property to show the inequality
          have h₁₀ : (τ ⊓ σ) ω ≤ τ ω := by
            -- Prove that the minimum is less than or equal to each of the two values
            simp [WithTop_inf_coe, min_le_iff]
            <;> aesop
          -- Use the fact that the process is non-decreasing to show the inequality
          have h₁₁ : stoppedValue X (τ ⊓ σ) ω ≤ stoppedValue X τ ω := by
            apply stoppedValue_monotone
            exact h₁₀
          exact h₁₁
        -- Use the fact that the conditional expectation is greater than or equal to the stopped value
        have h₁₂ : (P[stoppedValue X τ|hσ.measurableSpace] : Ω → E) ω ≥ stoppedValue X τ ω := by
          -- Use the submartingale property to show the inequality
          have h₁₃ : (P[stoppedValue X τ|hσ.measurableSpace] : Ω → E) ω ≥ stoppedValue X τ ω := by
            -- Use the fact that the conditional expectation is greater than or equal to the stopped value
            have h₁₄ : Integrable (fun x => stoppedValue X τ x) P := by
              -- Prove that the stopped value is integrable
              sorry
            -- Use the fact that the conditional expectation is greater than or equal to the stopped value
            have h₁₅ : (P[stoppedValue X τ|hσ.measurableSpace] : Ω → E) ω ≥ stoppedValue X τ ω := by
              -- Use the fact that the conditional expectation is greater than or equal to the stopped value
              sorry
            exact h₁₅
          exact h₁₃
        -- Combine the inequalities to get the final result
        calc
          stoppedValue X (τ ⊓ σ) ω ≤ stoppedValue X τ ω := h₉
          _ ≤ (P[stoppedValue X τ|hσ.measurableSpace] : Ω → E) ω := by
            -- Use the fact that the conditional expectation is greater than or equal to the stopped value
            exact le_of_not_gt fun h₁₆ => by
              -- If the inequality does not hold, then we have a contradiction
              have h₁₇ : (P[stoppedValue X τ|hσ.measurableSpace] : Ω → E) ω < stoppedValue X τ ω := by
                exact h₁₆
              -- Use the fact that the conditional expectation is greater than or equal to the stopped value
              linarith
      exact h₈
    exact h₅
  -- Use the fact that the inequality holds almost everywhere to conclude the proof
  filter_upwards [h₃] with ω h₃
  <;> simp_all [le_refl]
  <;> aesop
