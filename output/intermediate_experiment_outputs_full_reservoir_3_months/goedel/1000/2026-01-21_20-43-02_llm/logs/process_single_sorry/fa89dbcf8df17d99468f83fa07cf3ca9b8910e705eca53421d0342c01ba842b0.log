      (try norm_num) <;>
      (try simp_all [inf_le_left]) <;>
      (try exact le_of_eq (by simp_all [inf_eq_left])) <;>
      (try exact le_of_eq (by simp_all [inf_eq_right]))
    have h6 : stoppedValue X τ ≤ᵐ[P] P[stoppedValue X τ|hmin.measurableSpace] := by
      have h7 : Integrable (fun ω : Ω => stoppedValue X τ ω) P := by
        sorry
      have h8 : almost_surely_strongly_measurable (fun ω : Ω => stoppedValue X τ ω) P := by
        sorry
      -- Use the fact that the conditional expectation is an ordered projection.
      have h9 : (fun ω : Ω => stoppedValue X τ ω) ≤ᵐ[P] P[fun ω => stoppedValue X τ ω|hmin.measurableSpace] := by
        apply lmeasurable_ae_le_condexp
        <;> exact h8.of_mem (measurableSet_univ)
        <;> exact hmin.measurableSpace_le
        <;> exact hmin.measurableSet_of_le
        <;> simp_all [hX3.adapted]
        <;>
        (try norm_num) <;>
        (try simp_all [inf_le_left]) <;>
        (try exact le_of_eq (by simp_all [inf_eq_left])) <;>
        (try exact le_of_eq (by simp_all [inf_eq_right]))
      exact h9
    -- Combine the two inequalities to get the desired result.
    calc
      stoppedValue X (fun ω => τ ω ⊓ σ ω) ≤ᵐ[P] stoppedValue X τ := h5
      _ ≤ᵐ[P] P[stoppedValue X τ|hmin.measurableSpace] := h6
  -- Use the fact that the conditional expectation of the stopped value at the first stopping time is less than or equal to the conditional expectation of the stopped value at the second stopping time.
  have h5 : P[stoppedValue X τ|hmin.measurableSpace] ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
    -- This is because the first stopping time is less than or equal to the second stopping time.
    have h6 : hmin.measurableSpace ≤ hσ.measurableSpace := by
      -- The minimum of two stopping times is less than or equal to each of them.
      apply IsStoppingTime.measurableSpace_mono
      intro ω
      have h7 : (τ ω ⊓ σ ω : WithTop ι) ≤ σ ω := by
        simp [inf_le_right]
      exact h7
    -- Use the property of conditional expectations with respect to increasing σ-algebras.
    have h7 : P[stoppedValue X τ|hmin.measurableSpace] ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
      have h8 : Integrable (fun ω : Ω => stoppedValue X τ ω) P := by
        sorry
      -- Use the fact that the conditional expectation is an ordered projection.
      have h9 : P[fun ω => stoppedValue X τ ω|hmin.measurableSpace] ≤ᵐ[P] P[fun ω => stoppedValue X τ ω|hσ.measurableSpace] := by
        apply condexp_mono
        <;> simp_all [h6]
        <;> try norm_num
        <;> try simp_all [inf_le_left]
        <;> try exact le_of_eq (by simp_all [inf_eq_left])
        <;> try exact le_of_eq (by simp_all [inf_eq_right])
      exact h9
    exact h7
  -- Combine the two inequalities to get the final result.
  have h6 : stoppedValue X (fun ω => τ ω ⊓ σ ω) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
    -- Use the transitivity of the inequality.
