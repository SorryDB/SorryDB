theorem Submartingale.stoppedValue_min_ae_le_condExp [PartialOrder E] [OrderClosedTopology E]
    [IsOrderedModule ℝ E] [IsOrderedAddMonoid E]
    (hX1 : Submartingale X 𝓕 P) (hX2 : ∀ ω, RightContinuous (X · ω)) {k : ι}
    (hτk : ∀ᵐ ω ∂P, τ ω ≤ k) (hσ : IsStoppingTime 𝓕 σ) (hτ : IsStoppingTime 𝓕 τ) :
    stoppedValue X (τ ⊓ σ) ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := by
  have h₁ : ∀ (ω : Ω), stoppedValue X (τ ⊓ σ) ω ≤ stoppedValue X τ ω := by
    intro ω
    have h₂ : (τ ⊓ σ) ω ≤ τ ω := by
      simp [inf_le_left]
    have h₃ : stoppedValue X (τ ⊓ σ) ω ≤ stoppedValue X τ ω := by
      -- Use the fact that the stopped process is monotone
      apply stoppedValue_mono
      exact h₂
    exact h₃
  have h₂ : ∀ᵐ (ω : Ω) ∂P, P[stoppedValue X τ | hσ.measurableSpace] ω = P[stoppedValue X τ | hσ.measurableSpace] ω := by
    exact eventuallyEq_refl _
  have h₃ : ∀ᵐ (ω : Ω) ∂P, stoppedValue X (τ ⊓ σ) ω ≤ P[stoppedValue X τ | hσ.measurableSpace] ω := by
    have h₄ : ∀ᵐ (ω : Ω) ∂P, stoppedValue X (τ ⊓ σ) ω ≤ stoppedValue X τ ω := by
      filter_upwards [ae_univ] with ω
      exact h₁ ω
    have h₅ : ∀ᵐ (ω : Ω) ∂P, stoppedValue X τ ω ≤ P[stoppedValue X τ | hσ.measurableSpace] ω := by
      have h₅₁ : ⦃ω : Ω⦄, stoppedValue X τ ω ≤ P[stoppedValue X τ | hσ.measurableSpace] ω := by
        -- Use the fact that the conditional expectation dominates the original process for submartingales
        apply le_condExp_ae
        exact hX1.contrast
        <;> (try exact hX2)
        <;> (try exact hτ)
        <;> (try exact hσ)
      exact h₅₁
    filter_upwards [h₄, h₅] with ω h₄ω h₅ω
    exact le_trans h₄ω h₅ω
  filter_upwards [h₃] with ω h₃ω
  exact h₃ω
