      stoppedValue X (fun ω => τ ω ⊓ σ ω) ≤ᵐ[P] P[stoppedValue X τ|hmin.measurableSpace] := h4
      _ ≤ᵐ[P] P[stoppedValue X τ|hσ.measurableSpace] := h5
