      "\n  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by\n    -- Use the fact that the integral of f against the complex measure is bounded by the product of the norms of x and y, and the bound C of f\n    have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by\n      -- Use the fact that the integral of f against the complex measure is bounded by the product of the norms of x and y, and the bound C of f\n      have h₃ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) * (C : ℝ) := by\n        -- Use the bound on the integral of a measurable function against a complex measure\n        calc\n          ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) * (C : ℝ) := by\n            -- Use the bound on the integral of a measurable function against a complex measure\n            have h₄ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) * (C : ℝ) := by\n              -- Use the fact that the integral of f against the complex measure is bounded by the product of the variation of the measure and the bound C of f\n              have h₅ : (cfc_toComplexMeasure ha x y).integral f = (cfc_toComplexMeasure ha x y).integral f := rfl\n              rw [h₅]\n              have h₆ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) * (C : ℝ) :=\n                by\n                -- Use the bound on the integral of a measurable function against a complex measure\n                apply ComplexMeasure.abs_integral_le_iff.mpr\n                constructor\n                · positivity\n                · -- Show that the function is bounded by C\n                  intro x _\n                  have h₇ : ‖f x‖ ≤ C := hf_bounded x\n                  have h₈ : 0 ≤ (C : ℝ) := by\n                    -- Show that C is non-negative\n                    have h₉ : ‖f x‖ ≤ C := hf_bounded x\n                    have h₁₀ : 0 ≤ ‖f x‖ := norm_nonneg (f x)\n                    linarith\n                  have h₉ : ‖f x‖ ≤ (C : ℝ) := by exact_mod_cast hf_bounded x\n                  have h₁₀ : 0 ≤ (C : ℝ) := by positivity\n                  simpa [h₈, h₉] using h₉\n              exact h₆\n            exact h₄\n          _ = (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) * (C : ℝ) := by rfl\n      -- Use the bound on the variation of the complex measure\n      have h₄ : (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) ≤ ‖x‖ * ‖y‖ := by\n        -- Use the bound on the variation of the complex measure\n        have h₅ : (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) ≤ ‖x‖ * ‖y‖ := by\n          -- Use the bound on the variation of the complex measure\n          have h₆ : (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) ≤ ‖x‖ * ‖y‖ := by\n            -- Use the bound on the variation of the complex measure\n            have h₇ : (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) ≤ ‖x‖elapsed * ‖y‖elapsed := by\n              -- Use the bound on the variation of the complex measure\n              apply cfc_variation_toComplexMeasure_bounded\n            -- Use the bound on the variation of the complex measure\n            have h₈ : ‖x‖elapsed * ‖y‖elapsed = ‖x‖ * ‖y‖ := by\n              simp [Matrix.cons_val_zero]\n            -- Use the bound on the variation of the complex measure\n            rw [h₈] at h₇\n            exact h₇\n          exact h₆\n        exact h₅\n      -- Combine the bounds to get the final result\n      calc\n        ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) * (C : ℝ) := h₃\n        _ ≤ (‖x‖ * ‖y‖ : ℝ) * (C : ℝ) := by\n          -- Use the bound on the variation of the complex measure\n          gcongr <;> try norm_num <;> linarith\n        _ = ‖x‖ * ‖y‖ * C := by ring\n    exact h₂\n  exact h₁",
      "\n  have h₁ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by\n    have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by\n      -- Use the fact that the integral of f is bounded by the norm of x and y times the bound on f\n      have h₃ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by\n        -- Use the bound on the integral derived from the properties of the measure and the function f\n        calc\n          ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖(cfc_toComplexMeasure ha x y).integral f‖ := rfl\n          _ ≤ ‖x‖ * ‖y‖ * C := by\n            -- Use the bound on the integral derived from the properties of the measure and the function f\n            have h₄ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by\n              -- Use the fact that the measure is bounded by the norm of x and y\n              have h₅ : ‖x‖ * ‖y‖ ≥ 0 := by positivity\n              -- Use the bound on the integral derived from the properties of the measure and the function f\n              have h₆ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by\n                -- Use the fact that the measure is bounded by the norm of x and y\n                have h₇ : ∀ (x : (spectrum ℂ a)), ‖f x‖ ≤ C := hf_bounded\n                -- Use the bound on the integral derived from the properties of the measure and the function f\n                calc\n                  ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ (cfc_toComplexMeasure ha x y).variation Set.univ * C := by\n                    -- Use the fact that the measure is bounded by the norm of x and y\n                    exact ComplexMeasure.integral_bound (cfc_toComplexMeasure ha x y) f hX hf_bounded\n                  _ ≤ ‖x‖ * ‖y‖ * C := by\n                    -- Use the fact that the measure is bounded by the norm of x and y\n                    have h₈ : (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := by\n                     