    have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ (cfc_toComplexMeasure ha x y).variation (Set.univ : Set (spectrum ℂ a)) * (⨆ x : (spectrum ℂ a), ‖f x‖) := by
