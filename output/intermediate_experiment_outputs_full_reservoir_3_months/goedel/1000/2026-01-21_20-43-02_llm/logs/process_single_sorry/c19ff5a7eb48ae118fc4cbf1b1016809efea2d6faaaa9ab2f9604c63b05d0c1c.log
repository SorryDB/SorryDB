theorem SteinsLemma {ι : Type*} [UnitalFreeStateTheory ι] {i : ι} {ρ : MState (H i)}
  {σ : ℕ → IsFreeState ι} {ε ε' : ℝ} (hε'₁ : 0 < ε') (hε'₂ : ε' < ε) (hε : ε < 1)
  (hR1R2 : R1 ρ ε < R2 ρ σ) (hR1 : R1 ρ ε ≠ ⊤) (hR2 : R2 ρ σ ≠ ⊤)
  (hε₀ : 0 < ε₀_func ρ ε σ ε') (m : ℕ) (hm : m ≥ 1 ∧ 𝐃(ρ^m‖σ m) / m < R2 ρ σ + ε₀_func ρ ε σ ε') :
  ∃ m : ℕ, HypothesisTest (ρ^m) (σ m) (m * ε) :=
  by
  use 0
  <;> simp_all [HypothesisTest, Bounded]
  <;> norm_num
  <;>
    (try
      aesop) <;>
    (try
      {
        use 0
        <;> simp_all [Bounded]
        <;> norm_num
        <;>
          (try
            aesop)
      })
```
