lemma def_chainTree (x : List V) : x ∈ chainTree V ↔ x.IsChain (· ≥ ·) := by
    simp [chainTree]
    <;>
    (try decide) <;>
    (try simp_all [List.IsChain]) <;>
    (try aesop)
