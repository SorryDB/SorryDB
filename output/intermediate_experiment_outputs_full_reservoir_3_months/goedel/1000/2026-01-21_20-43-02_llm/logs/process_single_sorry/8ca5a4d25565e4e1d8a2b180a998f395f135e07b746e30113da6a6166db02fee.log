theorem OMR_problem_33419 : ∀ (n : ℕ), (2 : ℕ) ^ n ≥ n + 1 := by
  intro n
  have h_main : (2 : ℕ) ^ n ≥ n + 1 := by
    -- Use the fact that 2^n grows exponentially, while n+1 grows linearly
    have h : ∀ n : ℕ, (2 : ℕ) ^ n ≥ n + 1 := by
      intro n
      -- Base case: when n = 0, 2^0 = 1 ≥ 0 + 1 = 1
      induction n with
      | zero =>
        norm_num
      -- Inductive step: assume the statement holds for n, prove it for n+1
      | succ n ih =>
        -- 2^(n+1) = 2 * 2^n ≥ 2 * (n + 1) = 2n + 2
        -- We need to show that 2n + 2 ≥ (n + 1) + 1 = n + 2
        have h₁ : (2 : ℕ) ^ (n + 1) = 2 * (2 ^ n) := by
          ring_nf
        rw [h₁]
        have h₂ : 2 * (2 ^ n) ≥ 2 * (n + 1) := by
          -- Since 2^n ≥ n + 1 by the inductive hypothesis
          nlinarith
        -- 2 * (n + 1) = 2n + 2 ≥ n + 2
        have h₃ : 2 * (n + 1) ≥ (n + 1) + 1 := by
          cases n with
          | zero => norm_num
          | succ n =>
            simp [mul_add, add_mul, mul_one, mul_comm]
            <;> nlinarith
        -- Combine the inequalities
        omega
    -- Apply the general statement to the specific n
    exact h n
  -- The result follows from the above analysis
  exact h_main
