  refine' ⟨e.is_small_order.unsafe, (e.mul_by_cofactor.unsafe : EdwardsPoint), Identity.curve25519_dalek.edwards.EdwardsPoint.identity, (e.mul_by_cofactor.unsafe).chooseEquiv 1, _⟩
  -- We now need to provide the necessary proofs for each existential variable.
