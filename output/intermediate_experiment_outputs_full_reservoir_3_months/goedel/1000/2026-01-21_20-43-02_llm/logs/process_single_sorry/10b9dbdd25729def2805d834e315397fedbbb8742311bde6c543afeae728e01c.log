theorem list_set_sum {l : List Nat} {idx : Nat} {e : Nat} (hidx : idx < l.length := by simpa) :
    (l.set idx e).sum = l.sum - l[idx] + e := by
  induction' idx generalizing l with
  | zero =>
    cases l with
    | nil =>
      contradiction
    | cons hd tl =>
      simp [List.set, List.get, List.sum_cons]
      <;> ring_nf at * <;>
      (try omega) <;>
      (try simp_all [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm]) <;>
      (try ring_nf at * <;> omega) <;>
      (try omega)
  | succ idx' ih =>
    cases l with
    | nil =>
      contradiction
    | cons hd tl =>
      have h := ih (by
        -- Prove that idx' < tl.length
        simp [List.length_cons] at hidx ⊢
        <;> omega)
      simp [List.set, List.get, List.sum_cons] at h ⊢ <;>
      (try omega) <;>
      (try simp_all [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm]) <;>
      (try ring_nf at * <;> omega) <;>
      (try
        {
          -- Use the induction hypothesis to simplify the goal
          have h₁ := h
          simp [List.sum_cons, List.get] at h₁ ⊢ <;>
          ring_nf at * <;>
          omega
        })
