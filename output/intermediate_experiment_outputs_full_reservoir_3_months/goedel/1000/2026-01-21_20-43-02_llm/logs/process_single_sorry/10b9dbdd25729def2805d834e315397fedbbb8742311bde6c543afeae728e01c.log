  · -- Inductive step: assume the statement holds for idx, prove for idx + 1
    cases l with
    | nil =>
      -- If l is nil, idx + 1 cannot be < 0
      contradiction
    | cons hd tl =>
      -- If l = hd :: tl, then l.set (idx + 1) e = hd :: (tl.set idx e)
      have h₁ : (hd :: tl).length = 1 + tl.length := by simp
      have h₂ : ((hd :: tl).set (idx + 1) e) = hd :: (tl.set idx e) := by
