      have h₄ : ((hd :: tl).set (idx + 1) e).sum = (hd :: (tl.set idx e)).sum := by rw [h₂]
      have h₅ : (hd :: (tl.set idx e)).sum = hd + (tl.set idx e).sum := by simp [List.sum_cons]
