theorem eq_of_mem_fixedPoints : fixedPoints (secondInvo k) = singletonFixedPoint k := by
  simp only [fixedPoints, IsFixedPt, secondInvo, secondInvo_fun,
    singletonFixedPoint, Prod.mk_one_one, Finset.coe_singleton]
  ext t
  constructor
  · intro ht
    simp at ht
    have h₁ : (t.1.1.1 : ℤ) - t.1.1.2.1 + t.1.1.2.2 = t.1.1.1 := by
      simp_all [Prod.ext_iff]
      <;> ring_nf at *
      <;> nlinarith
    have h₂ : (2 : ℤ) * t.1.1.2.1 - t.1.1.2.2 = t.1.1.2.2 := by
      simp_all [Prod.ext_iff]
      <;> ring_nf at *
      <;> nlinarith
    have h₃ : (t.1.1.2.1 : ℤ) > 0 := by
      have := t.2.2.1
      simp [U, S] at this ⊢
      <;> nlinarith
    have h₄ : (t.1.1.2.2 : ℤ) > 0 := by
      have := t.2.1
      simp [U] at this ⊢
      <;> norm_num at this ⊢ <;> linarith
    have h₅ : (t.1.1.1 : ℤ) > 0 := by
      have := t.2.2.1
      simp [S] at this ⊢
      <;> nlinarith
    have h₆ : (4 : ℤ) * t.1.1.1 * t.1.1.2.1 + (t.1.1.2.2 : ℤ) ^ 2 = (4 * k + 1 : ℤ) := by
      have := t.2.2.2.1
      simp [S] at this ⊢
      <;> norm_cast at * <;>
        (try norm_num at * <;>
          try simp_all [U, S] <;>
            try ring_nf at * <;>
              try norm_num at * <;>
                try nlinarith)
      <;> nlinarith
    have h₇ : (t.1.1.1 : ℤ) ≤ k := by
      have := t.2.2.2.2.1
      simp [U] at this ⊢
      <;> norm_num at this ⊢ <;>
        (try norm_cast at * <;>
          try simp_all [U, S] <;>
            try ring_nf at * <;>
              try norm_num at * <;>
                try nlinarith)
      <;> nlinarith
    have h₈ : (t.1.1.2.1 : ℤ) ≤ k := by
      have := t.2.2.2.2.2
      simp [U] at this ⊢
      <;> norm_num at this ⊢ <;>
        (try norm_cast at * <;>
          try simp_all [U, S] <;>
            try ring_nf at * <;>
              try norm_num at * <;>
                try nlinarith)
      <;> nlinarith
    have h₉ : (t.1.1.2.1 : ℤ) = 1 := by
      nlinarith [sq_nonneg (t.1.1.2.2 - 1)]
    have h₁₀ : (t.1.1.2.2 : ℤ) = 1 := by
      nlinarith [sq_nonneg (t.1.1.2.2 - 1)]
    have h₁₁ : (t.1.1.1 : ℤ) = k := by
      nlinarith [sq_nonneg (t.1.1.2.2 - 1)]
    simp_all [Prod.ext_iff]
    <;> norm_cast
    <;> (try omega)
    <;> (try nlinarith)
