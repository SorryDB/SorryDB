      "\n    have h₁ : t.1.1.1 - t.1.1.2.1 + t.1.1.2.2 > 0 := by\n      have h₂ : (t : U k) = ⟨t.1, t.2⟩ := rfl\n      simp_all [U, Set.mem_setOf_eq]\n      <;> linarith\n    have h₂ : 2 * t.1.1.2.1 - t.1.1.2.2 > 0 := by\n      have h₃ : t.1.1.1 > 0 := by\n        have h₄ : t.1 ∈ S k := t.2\n        simp [S] at h₄\n        linarith\n      have h₄ : t.1.1.2.1 > 0 := by\n        have h₅ : t.1 ∈ S k := t.2\n        simp [S] at h₅\n        linarith\n      have h₅ : 4 * (t.1.1.1 : ℤ) * (t.1.1.2.1 : ℤ) + (t.1.1.2.2 : ℤ) ^ 2 = (4 * k + 1 : ℤ) := by\n        have h₆ : t.1 ∈ S k := t.2\n        simp [S] at h₆\n        norm_cast at h₆ ⊢\n        <;> simp_all [Nat.cast_add, Nat.cast_mul, Nat.cast_ofNat]\n        <;> linarith\n      have h₆ : 4 * (t.1.1.1 : ℤ) * (t.1.1.2.1 : ℤ) + (t.1.1.2.2 : ℤ) ^ 2 = (4 * k + 1 : ℤ) := by\n        exact h₅\n      by_contra h₇\n      have h₈ : 2 * (t.1.1.2.1 : ℤ) - (t.1.1.2.2 : ℤ) ≤ 0 := by linarith\n      have h₉ : (t.1.1.2.2 : ℤ) ≥ 2 * (t.1.1.2.1 : ℤ) := by linarith\n      have h₁₀ : (4 : ℤ) * (t.1.1.1 : ℤ) * (t.1.1.2.1 : ℤ) + (t.1.1.2.2 : ℤ) ^ 2 ≥ (4 : ℤ) * (t.1.1.1 : ℤ) * (t.1.1.2.1 : ℤ) + (2 * (t.1.1.2.1 : ℤ)) ^ 2 := by\n        nlinarith\n      have h₁₁ : (4 : ℤ) * (t.1.1.1 : ℤ) * (t.1.1.2.1 : ℤ) + (t.1.1.2.2 : ℤ) ^ 2 ≥ (4 : ℤ) * (t.1.1.1 : ℤ) * (t.1.1.2.1 : ℤ) + 4 * (t.1.1.2.1 : ℤ) ^ 2 := by\n        nlinarith\n      have h₁₂ : (4 : ℤ) * (t.1.1.1 : ℤ) * (t.1.1.2.1 : ℤ) + 4 * (t.1.1.2.1 : ℤ) ^ 2 > (4 * k + 1 : ℤ) := by\n        have h₁₃ : (t.1.1.1 : ℤ) > 0 := by exact_mod_cast t.1.1.1 > 0\n        have h₁₄ : (t.1.1.2.1 : ℤ) > 0 := by exact_mod_cast t.1.1.2.1 > 0\n        have h₁₅ : (t.1.1.1 : ℤ) ≥ 1 := by\n          have h₁₆ : t.1.1.1 > 0 := by exact_mod_cast t.1.1.1 > 0\n          linarith\n        have h₁₆ : (t.1.1.2.1 : ℤ) ≥ 1 := by\n          have h₁₇ : t.1.1.2.1 > 0 := by exact_mod_cast t.1.1.2.1 > 0\n          linarith\n        nlinarith [sq_nonneg ((t.1.1.1 : ℤ) - (t.1.1.2.1 : ℤ))]\n      linarith\n    simp_all [U, S]\n    <;>\n   