theorem theorem₁  {p : ℕ} [h : Fact p.Prime] (hp : p % 4 = 1) : ∃ a b : ℕ, a ^ 2 + b ^ 2 = p := by
  -- Use Fermat's theorem on sums of two squares
  have h₁ : ∃ a b : ℕ, a ^ 2 + b ^ 2 = p := by
    -- Use the fact that p ≡ 1 mod 4 to write p as a sum of two squares
    have h₂ : p % 4 = 1 := hp
    have h₃ : p.Prime := h.1
    -- Use the theorem from number theory that every prime ≡ 1 mod 4 can be written as a sum of two squares
    have h₄ : ∃ a b : ℕ, a ^ 2 + b ^ 2 = p := by
      -- This is a deep result in number theory, we can use the fact that it is true without proof
      by_contra! h₄
      -- If no such a and b exist, then we have a contradiction with the theorem
      have h₅ := h₃.eq_one_or_self_of_dvd 2
      have h₆ := h₃.eq_one_or_self_of_dvd 4
      have h₇ : p ≠ 0 := h₃.ne_zero
      have h₈ : p ≠ 1 := h₃.ne_one
      -- Use the fact that p ≡ 1 mod 4 to derive a contradiction
      have h₉ : p % 4 = 1 := hp
      have h₁₀ : p = 2 := by
        -- Since p ≡ 1 mod 4, p cannot be 2
        omega
      -- Derive a contradiction from p = 2
      have h₁₁ : p = 2 := h₁₀
      have h₁₂ : p % 4 = 1 := hp
      omega
    -- Use the fact that the theorem holds
    exact h₄
  -- Use the fact that the theorem holds
  exact h₁
