theorem soundness : ∀ (c : Circuit p (ZMod p)),
  rw_bisim (Circuit.eval c) (Cs.eval (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs]
    constructor
  | lam k h =>
    simp [Circuit.eval,to_cs]
    constructor
    exact h
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    split
    apply h
    constructor
  | share e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    apply rw_bisim.right
    intro x
    simp [Exp.eval]
    split
    have hmy : x = Exp.eval e := by
      have h₁ : x = Exp.eval e := by
        have h₂ := h₁
        simp_all [Exp.eval]
        <;>
        (try decide) <;>
        (try ring_nf at * <;> simp_all) <;>
        (try norm_num at * <;> simp_all) <;>
        (try omega)
      exact h₁
    rw [←hmy]
    apply h
    constructor
  | is_zero e c h =>
    apply rw_bisim.right
    intro inv
    apply rw_bisim.right
    intro o
    simp [Exp.eval,Circuit.eval,Cs.eval]
    split
    case is_zero.h.h.isTrue he0 =>
      split
      case isTrue hsub =>
        split
        case isTrue hmul =>
          simp [*] at *
          have hmy : o=1 := by
            have h₂ := hmul
            simp_all [Exp.eval]
            <;>
            (try decide) <;>
            (try ring_nf at * <;> simp_all) <;>
            (try norm_num at * <;> simp_all) <;>
            (try omega)
          rw [hmy]
          apply h
        case isFalse hmul => constructor
      case isFalse hsub => constructor
    case is_zero.h.h.isFalse he0 =>
      split
      case isTrue hsub =>
        split
        case isTrue hmul =>
          simp [*] at *
          rw [hmul]
          apply h
        case isFalse hmul => constructor
      case isFalse hsub => constructor
  | assert_range w e c h =>
    simp [Circuit.eval,to_cs]
    apply rw_bisim_uncurry
    intros args
    have h₁ : assert_bits args -> e.eval = bits2num args → (assert_bits_e args (.eq0 (bits2num_e args - e) (to_cs c))).eval = (to_cs c).eval := by
      intro h₂ h₃
      have h₄ : (assert_bit_e args.head (.eq0 (e.eval - (Exp.eval e)) (to_cs c))).eval = (to_cs c).eval := by
        have h₅ : e.eval = (0 : ZMod p) := by
          have h₅₁ : e.eval = (0 : ZMod p) := by
            simp_all [Exp.eval, bits2num, bits2num_e]
            <;>
            (try ring_nf at *) <;>
            (try norm_num at *) <;>
            (try omega)
          exact h₅₁
        simp_all [Exp.eval, bits2num, bits2num_e]
        <;>
        (try ring_nf at *) <;>
        (try norm_num at *) <;>
        (try omega)
      simp_all [assert_bit_e, bits2num, bits2num_e]
      <;>
      (try ring_nf at *) <;>
      (try norm_num at *) <;>
      (try omega)
    have h₂ : ¬assert_bits args ∨ e.eval ≠ bits2num args → (assert_bit_e args.head (.eq0 (e.eval - (Exp.eval e)) (to_cs c))).eval = denotation.n := by
      intro h₂
      cases h₂ with
      | inl h₂ =>
        simp_all [Exp.eval, bits2num, bits2num_e]
        <;>
        (try ring_nf at *) <;>
        (try norm_num at *) <;>
        (try omega)
      | inr h₂ =>
        simp_all [Exp.eval, bits2num, bits2num_e]
        <;>
        (try ring_nf at *) <;>
        (try norm_num at *) <;>
        (try omega)
    simp_all [Exp.eval, bits2num, bits2num_e]
    <;>
    (try ring_nf at *) <;>
    (try norm_num at *) <;>
    (try omega)
