    rw [←hmy]
    apply h
    constructor
  | is_zero e c h =>
    apply rw_bisim.right
    intro inv
    apply rw_bisim.right
    intro o
    simp [Exp.eval,Circuit.eval,Cs.eval]
    split
    <;>
    (try
      {
        cases Classical.em (e.eval = 0) <;>
        cases Classical.em (o = 1) <;>
        simp_all [is_zero, Eq, ZMod.nat_cast_self]
        <;>
        (try contradiction) <;>
        (try aesop) <;>
        (try norm_num) <;>
        (try ring_nf at *) <;>
        (try simp_all [Exp.eval, Cs.eval]) <;>
        (try aesop)
      }) <;>
    (try
      {
        cases Classical.em (inv * e.eval = 1) <;>
        simp_all [is_zero, Eq, ZMod.nat_cast_self]
        <;>
        (try contradiction) <;>
        (try aesop) <;>
        (try norm_num) <;>
        (try ring_nf at *) <;>
        (try simp_all [Exp.eval, Cs.eval]) <;>
