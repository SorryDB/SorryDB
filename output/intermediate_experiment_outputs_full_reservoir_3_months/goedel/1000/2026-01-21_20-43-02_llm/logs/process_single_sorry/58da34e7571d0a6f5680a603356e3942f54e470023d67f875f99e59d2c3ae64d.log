theorem bernoulli_inequality_one_add [StrictOrderedRing R] {x : R} {n : ℕ}
    (h : -1 ≤ x) (a : x ≥ 0) (hn : n ≠ 0) :
    1 + n • x ≤ (1 + x) ^ n := by
  have h₁ : ∀ n : ℕ, n ≥ 1 → 1 + n • x ≤ (1 + x) ^ n := by
    intro n hn
    have h₂ : 1 + (n : ℕ) • x ≤ (1 + x : R) ^ n := by
      have h₃ : ∀ n : ℕ, n ≥ 1 → 1 + (n : ℕ) • x ≤ (1 + x : R) ^ n := by
        intro n hn
        induction' hn with n hn IH
        · -- Base case: n = 1
          norm_num [pow_one, one_smul]
          <;>
          simp_all [add_assoc]
          <;>
          nlinarith
        · -- Inductive step: assume the statement holds for n, prove for n + 1
          simp_all [pow_succ, Nat.cast_add, Nat.cast_one, add_assoc]
          <;>
          (try
            {
              nlinarith [sq_nonneg x, pow_pos (by nlinarith : (0 : R) < 1 + x) n]
            })
          <;>
          (try
            {
              nlinarith [sq_nonneg x, pow_pos (by nlinarith : (0 : R) < 1 + x) n]
            })
          <;>
          (try
            {
              nlinarith [sq_nonneg x, pow_pos (by nlinarith : (0 : R) < 1 + x) n]
            })
          <;>
          (try
            {
              nlinarith [sq_nonneg x, pow_pos (by nlinarith : (0 : R) < 1 + x) n]
            })
      exact h₃ n hn
    exact_mod_cast h₂
  have h₂ : n ≠ 0 → n ≥ 1 := by
    intro hn
    have h₃ : n ≥ 1 := by
      by_contra h₄
      have h₅ : n = 0 := by
        omega
      contradiction
    exact h₃
  have h₃ : n ≥ 1 := by
    by_cases h₄ : n = 0
    · exfalso
      exact hn h₄
    · exact h₂ h₄
  have h₄ : 1 + n • x ≤ (1 + x) ^ n := h₁ n h₃
  exact h₄
