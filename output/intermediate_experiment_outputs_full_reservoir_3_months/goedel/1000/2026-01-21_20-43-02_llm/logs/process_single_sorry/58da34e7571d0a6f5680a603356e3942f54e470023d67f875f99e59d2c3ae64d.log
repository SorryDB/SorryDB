theorem integrable_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
  -- Use the fact that the product of measures is the product of the integrals
  have h : Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
    -- Use the general property that if a function is integrable with respect to one component of the product measure, it is integrable with respect to the product measure
    apply MeasureTheory.integrable_of_hasFiniteIntegral
    exact (MeasureTheory.hasFiniteIntegral_of_hasFiniteIntegral_prod' (fun j => by
      -- For each component, we need to show that the integral is finite
      -- This is true because the measure is a probability measure and thus finite
      -- We can use the fact that the integral of a function over a finite measure space is finite
      -- If the function is not integrable, we can set the integral to 0
      exact by
        by_cases h : j = i
        · -- Case: j = i
          -- Use the fact that f is integrable with respect to μ i
          have h₂ : IsProbabilityMeasure (μ j) := inferInstance
          have h₃ : 0 < μ j.univ := by
            have h₄ : 0 < (μ j).univ := h₂.ne_zero
            exact h₄
          have h₄ : HasFiniteIntegral (fun a : Fin 1 → ℝ => f (a ⟨0, by simp⟩)) (μ j) := by
            -- Use the fact that f is integrable with respect to μ i
            have h₅ : Integrable (fun a : Fin 1 → ℝ => f (a ⟨0, by simp⟩)) (μ j) := by
              -- Use the fact that f is integrable with respect to μ i
              have h₅₁ : (fun a : Fin 1 → ℝ => f (a ⟨0, by simp⟩)) = fun a => f (a ⟨0, by simp⟩) := rfl
              have h₅₂ : (μ j) = μ j := rfl
              -- Use the fact that f is integrable with respect to μ i
              have h₅₃ : Integrable (fun a : ℝ => f a) (μ j) := hf
              -- Use the fact that f is integrable with respect to μ i
              convert hf using 1
              <;> simp [h, Fin.prod_univ_succ]
              <;> funext a <;> simp [a]
              <;> aesop
            exact h₅.hasFiniteIntegral
          simpa [h] using h₄
        · -- Case: j ≠ i
          -- If j ≠ i, then the integral is 1 because the measure is a probability measure and the function is 1
          have h₂ : IsProbabilityMeasure (μ j) := inferInstance
          have h₃ : (μ j).univ = 1 := by
            exact h₂.univ_eq_one
          have h₄ : HasFiniteIntegral (fun _ : ℝ => (1 : ℝ)) (μ j) := by
            -- Use the fact that the measure is a probability measure and the function is 1
            have h₅ : ∫ (x : ℝ) ∂μ j, (1 : ℝ) = 1 := by
              -- Use the fact that the measure is a probability measure and the function is 1
              calc
                ∫ (x : ℝ) ∂μ j, (1 : ℝ) = ∫ (x : ℝ) ∂μ j, 1 := rfl
                _ = (μ j).univ := by
                  simp [MeasureTheory.integral_const]
                  <;> simp [h₃]
                  <;> aesop
                _ = 1 := by rw [h₃]
            -- Use the fact that the integral is finite
            refine' hasFiniteIntegral_of_hasFiniteIntegral_of_ae_eq (by simp [h₃]) _
            filter_upwards [ae_restrict_mem measurableSet_univ] with x hx
            <;> simp_all
          simpa using h₄
      ))
  -- The final result follows from the fact that the product of measures is the product of the integrals
  exact h
