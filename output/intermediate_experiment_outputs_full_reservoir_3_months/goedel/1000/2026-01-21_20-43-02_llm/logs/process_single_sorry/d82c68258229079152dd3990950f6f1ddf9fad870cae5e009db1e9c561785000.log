namespace Millennium

def IsNontrivialZero (s : ℂ) : Prop :=
  riemannZeta s = 0 ∧ ¬∃ (n : ℕ), s = -2 * (n + 1)

def CriticalStrip : Set ℂ :=
  {s : ℂ | 0 < s.re ∧ s.re < 1}

