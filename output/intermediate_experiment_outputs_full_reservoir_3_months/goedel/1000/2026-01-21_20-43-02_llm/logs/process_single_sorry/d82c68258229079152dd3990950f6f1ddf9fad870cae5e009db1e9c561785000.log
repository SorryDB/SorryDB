```lean
namespace Millennium

def IsNontrivialZero (s : ℂ) : Prop :=
  riemannZeta s = 0 ∧ ¬∃ (n : ℕ), s = -2 * (n + 1)

def CriticalStrip : Set ℂ :=
  {s : ℂ | 0 < s.re ∧ s.re < 1}

def CriticalLine : Set ℂ :=
  {s : ℂ | s.re = 1/2}

noncomputable def vonMangoldt (n : ℕ) : ℝ :=
  if h : IsPrimePow n then
    Real.log (n.minFac)
  else
    0

noncomputable def psiFunction (x : ℝ) : ℝ :=
  ∑' n : ℕ, if n ≤ ⌊x⌋ then vonMangoldt n else 0

noncomputable def primeCountingFunction (x : ℝ) : ℕ :=
  if x ≤ 0 then 0 else
    (Finset.filter Nat.Prime (Finset.range (Int.toNat ⌊x⌋ + 1))).card

noncomputable def LiCoefficients (n : ℕ) : ℝ :=
  if n = 0 then 0 else
    Complex.re (∑' m : ℕ, if m ≤ n then
               (-1)^(n-m) * (n.choose m) * (iteratedDeriv m (fun s => (riemannZeta (s+1))⁻¹) 0)
             else 0)

def RiemannHypothesis : Prop :=
  ∀ (s : ℂ), IsNontrivialZero s → s.re = 1/2

theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 :=
sorry

theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 :=
  by
  have h₁ : deriv riemannZeta (-2 * ↑n) ≠ 0 := by
    have h₂ : deriv riemannZeta (-2 * ↑n) ≠ 0 := by
      simpa [Complex.ext_iff, Complex.ofReal_eq_zero] using
        riemannZeta Skip.of_deriv_at_trivial_zero (-2 * (n : ℂ)) (by
          simp_all [Complex.ext_iff, pow_pos, Nat.cast_pos, Complex.ofReal_eq_zero]
          <;> norm_num <;>
          (try omega) <;>
          (try linarith)
        )
    exact h₂
  exact h₁
``` 

