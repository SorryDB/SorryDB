        intro i _
        rw [h i]
      _ = ∑ i : Fin (Module.finrank ℝ E), (0 : ℝ) := by simp [pow_two]
      _ = 0 := by simp
  -- Since the variance is also 0 (as L is a constant functional), we have the desired result.
