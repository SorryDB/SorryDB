lemma variance_dual_stdGaussianMulti (L : StrongDual ℝ E) :
    Var[L; stdGaussianMulti E] = ∑ i, L (stdOrthonormalBasis ℝ E i) ^ 2 := by
  have h1 : Var[L; stdGaussianMulti E] = (∑ i : Fin (Module.finrank ℝ E), L (stdOrthonormalBasis ℝ E i) ^ 2) := by
    rw [show Var[L; stdGaussianMulti E] = (∑ i : Fin (Module.finrank ℝ E), L (stdOrthonormalBasis ℝ E i) ^ 2) by
      have h2 : (stdGaussianMulti E).charFun = fun t ↦ Real.exp (-(∑ i : Fin (Module.finrank ℝ E), (t • (L (stdOrthonormalBasis ℝ E i))) * (t • (L (stdOrthonormalBasis ℝ E i))) / 2)) := by
        have h3 : (stdGaussianMulti E).charFun = fun t : ℝ ↦ Real.exp (-(∑ i : Fin (Module.finrank ℝ E), (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2)) := by
          -- Prove that the characteristic function of the multivariate Gaussian is as stated.
          calc
            (stdGaussianMulti E).charFun = (Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).map (fun x ↦ ∑ i, x i • stdOrthonormalBasis ℝ E i).charFun := rfl
            _ = fun t : ℝ ↦ Real.exp (-(∑ i : Fin (Module.finrank ℝ E), (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2)) := by
              -- Use the fact that the characteristic function of a sum is the product of the characteristic functions
              -- and that the characteristic function of a Gaussian is exp(-t^2 / 2).
              have h4 : ∀ (t : ℝ), ((Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).map (fun x ↦ ∑ i, x i • stdOrthonormalBasis ℝ E i)).charFun t = Real.exp (-(∑ i : Fin (Module.finrank ℝ E), (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2)) := by
                intro t
                have h5 : ((Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).map (fun x ↦ ∑ i, x i • stdOrthonormalBasis ℝ E i)).charFun t = (Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).charFun (fun i : Fin (Module.finrank ℝ E) ↦ t * L (stdOrthonormalBasis ℝ E i)) := by
                  -- Use the property of the characteristic function of a mapped measure
                  simp [Measure.map_charFun, Real.exp_neg, mul_assoc]
                  <;>
                    congr 1 <;>
                    ext x <;>
                    simp [Finset.sum_mul, Finset.mul_sum, Real.exp_neg, mul_assoc] <;>
                    ring_nf <;>
                    simp_all [Finset.sum_mul, Finset.mul_sum, Real.exp_neg, mul_assoc] <;>
                    field_simp <;>
                    ring_nf
                  <;>
                  simp_all [Finset.sum_mul, Finset.mul_sum, Real.exp_neg, mul_assoc]
                have h6 : (Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).charFun (fun i : Fin (Module.finrank ℝ E) ↦ t * L (stdOrthonormalBasis ℝ E i)) = Real.exp (-(∑ i : Fin (Module.finrank ℝ E), (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2)) := by
                  -- Calculate the characteristic function of the product of Gaussian measures
                  calc
                    (Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)).charFun (fun i : Fin (Module.finrank ℝ E) ↦ t * L (stdOrthonormalBasis ℝ E i)) = ∏ i : Fin (Module.finrank ℝ E), (gaussianReal 0 1).charFun (t * L (stdOrthonormalBasis ℝ E i)) := by
                      simp [Measure.pi_charFun]
                    _ = ∏ i : Fin (Module.finrank ℝ E), Real.exp (-( (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2 )) := by
                      -- The characteristic function of a Gaussian(0,1) is exp(-t^2 / 2)
                      apply Finset.prod_congr rfl
                      intro i _
                      rw [show (gaussianReal 0 1).charFun (t * L (stdOrthonormalBasis ℝ E i)) = Real.exp (-( (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2 )) by
                        rw [gaussianReal_charFun]
                        <;> simp [Real.exp_neg]]
                    _ = Real.exp (-(∑ i : Fin (Module.finrank ℝ E), (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2 )) := by
                      -- The product of exp(-a_i) is exp(-sum a_i)
                      calc
                        _ = ∏ i : Fin (Module.finrank ℝ E), Real.exp (-( (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2 )) := by rfl
                        _ = Real.exp (∑ i : Fin (Module.finrank ℝ E), (-( (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2 ))) := by
                          rw [Real.exp_sum]
                          <;> simp [Real.exp_neg]
                        _ = Real.exp (-(∑ i : Fin (Module.finrank ℝ E), (t * L (stdOrthonormalBasis ℝ E i)) ^ 2 / 2 )) := by
                          simp [Finset.sum_neg_distrib]
