          (try simp_all [LinearMap.map_zero]) <;>
          (try norm_num) <;>
          (try linarith)
        })
    exact h₁
  -- Using the fact that L maps each basis vector to 0, we can conclude that the sum of squares is 0.
  have h₂ : ∑ i, L (stdOrthonormalBasis ℝ E i) ^ 2 = 0 := by
    calc
