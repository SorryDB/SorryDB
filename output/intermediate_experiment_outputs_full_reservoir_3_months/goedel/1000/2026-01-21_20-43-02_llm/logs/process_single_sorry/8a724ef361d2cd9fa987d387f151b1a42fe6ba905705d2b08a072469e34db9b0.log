      requests := requests', orderConstraints := orderConstraints'
    }
    have h₁ : ∀ (id : RequestId), id ∈ List.map Request.id state.removed → id ∈ reqIds requests' := by
      intro id h₂
      simp only [List.mem_map] at h₂
