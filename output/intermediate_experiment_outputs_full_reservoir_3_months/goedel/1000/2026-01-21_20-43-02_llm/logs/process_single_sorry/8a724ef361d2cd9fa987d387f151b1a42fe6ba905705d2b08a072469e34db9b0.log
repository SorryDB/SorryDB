theorem SystemState.propagateRemovedCoherent : ∀ (state : SystemState) (reqId : RequestId) (thId : ThreadId), ∀ (id : RequestId), id ∈ List.map Request.id state.removed → id ∈ reqIds (state.updateOrderConstraintsPropagate state.scopes.systemScope reqId thId).requests.insert (req_old.propagate thId)
  := by
  intro state reqId thId id h
  have h₁ : id ∈ List.map Request.id state.removed := h
  have h₂ : id ∈ reqIds (state.updateOrderConstraintsPropagate state.scopes.systemScope reqId thId).requests.insert (req_old.propagate thId) := by
    -- Since the insert operation only adds a new request, and the id is already in the removed list, it must be in the updated requests.
    have h₃ : id ∈ List.map Request.id state.removed := h₁
    have h₄ : id ∈ reqIds (state.updateOrderConstraintsPropagate state.scopes.systemScope reqId thId).requests := by
      -- The id is in the removed list, so it is not affected by the insert operation.
      have h₅ : id ∈ List.map Request.id state.removed := h₃
      have h₆ : id ∈ reqIds (state.updateOrderConstraintsPropagate state.scopes.systemScope reqId thId).requests := by
        -- The id is in the removed list, so it is not affected by the insert operation.
        sorry
      exact h₆
    -- Since the id is in the updated requests, it is also in the insert operation.
    have h₇ : id ∈ reqIds (state.updateOrderConstraintsPropagate state.scopes.systemScope reqId thId).requests.insert (req_old.propagate thId) := by
      sorry
    exact h₇
  exact h₂
