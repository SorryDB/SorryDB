def SystemState.propagate : SystemState → RequestId → ThreadId → SystemState
  | state, reqId, thId => Id.run do
  match state.requests.getReq? reqId with
  | none => state
  | some req_old =>
    let req : Request := Request.propagate req_old thId
    let requests' : RequestArray := state.requests.insert req
    let scope : Scope := state.scopes.jointScope thId req.thread
    let orderConstraints' : OrderConstraints := state.updateOrderConstraintsPropagate scope reqId thId
    let removedCoherent : Bool := sorry
    let mut res := { state with
      requests := requests', orderConstraints := orderConstraints', removedCoherent := sorry}
    exact res
