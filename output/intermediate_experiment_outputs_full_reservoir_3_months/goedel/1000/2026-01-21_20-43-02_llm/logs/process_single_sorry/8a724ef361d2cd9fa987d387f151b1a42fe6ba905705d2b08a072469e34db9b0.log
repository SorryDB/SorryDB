```lean
theorem propagate_removed_in_inserted_requests {state : SystemState} {reqId : RequestId} {thId : ThreadId} {req_old : Request} {req : Request} {requests' : RequestArray} {scope : Scope} {orderConstraints' : OrderConstraints} (inst✝ : Arch) :
