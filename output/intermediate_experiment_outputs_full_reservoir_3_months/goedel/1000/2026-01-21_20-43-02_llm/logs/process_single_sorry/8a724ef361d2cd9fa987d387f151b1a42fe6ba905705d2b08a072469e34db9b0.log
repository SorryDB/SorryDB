  have h₃ : ∀ (r : Request), r ∈ state.removed → r.id ∈ reqIds state.requests := by sorry
  -- The id of r is in reqIds state.requests, so it is in reqIds requests' because inserting req does not affect existing entries
  have h₄ : id ∈ reqIds state.requests := by sorry
  have h₅ : id ∈ reqIds requests' := by sorry
  exact h₅
