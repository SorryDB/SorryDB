    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · -- Prove that the sum of the processes has cadlag paths
    have h₁ : IsCadlag (X · ω) := hX.cadlag ω
    have h₂ : IsCadlag (Y · ω) := hY.cadlag ω
    -- Use the fact that the sum of cadlag functions is cadlag
    have h₃ : IsCadlag (fun x => X x ω + Y x ω) := by
      -- Use the property that the sum of two cadlag functions is cadlag
      apply IsCadlag.add h₁ h₂
    exact h₃
  · -- Prove that the sum of the processes has uniformly bounded second moments
    sorry
``` 

