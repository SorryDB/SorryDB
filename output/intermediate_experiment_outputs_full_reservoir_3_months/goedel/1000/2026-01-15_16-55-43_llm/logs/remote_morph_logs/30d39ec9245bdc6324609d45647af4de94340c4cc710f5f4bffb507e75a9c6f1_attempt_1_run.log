   (tab : Solution.Table) (tab_valid : tab.Valid)
   (row : Solution.Row) (row_valid : row.Valid tab) :
    ¬ ∃ q ∈ row.toPoseInterval, RupertPose q nopert.hull := by
  match row_valid with
