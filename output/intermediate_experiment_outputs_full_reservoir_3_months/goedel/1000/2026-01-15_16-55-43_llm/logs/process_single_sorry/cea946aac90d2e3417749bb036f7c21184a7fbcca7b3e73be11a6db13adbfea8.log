lemma exists_isAugPath_not_max (hM : G.IsMatching M) (hnotmax : ¬ G.IsMaxMatching M)
    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  obtain ⟨M', hM', hM'cd⟩ := by
    simpa only [isMaxMatching_iff, hM, true_and, not_forall, not_le] using hnotmax
  have h₁ : M'.encard > M.encard := by
    have h₂ : M.encard < M'.encard := hM'cd
    exact lt_irrefl _ |>.trans h₂
  -- We use the fact that M and M' are matchings with |M'| > |M| to find an augmenting path for M.
  -- We consider the symmetric difference of the edges of the two matchings.
  have h₂ : ∃ e, e ∈ M' ∧ e ∉ M := by
    by_contra! h
    have h₃ : M' ⊆ M := by
      intro e he
      by_cases h₄ : e ∈ M
      · exact h₄
      · exfalso
        have h₅ := h e
        simp_all
    have h₄ : M'.encard ≤ M.encard := by
      calc
        M'.encard ≤ M.encard := by
          apply Set.encard_le_of_subset h₃
          <;> simp_all
        _ = M.encard := by rfl
    linarith
  obtain ⟨e, he'₁, he'₂⟩ := h₂
  -- Now we have an edge e in M' but not in M. We use this edge to find an augmenting path.
  -- This is a simplified approach and might not find a valid augmenting path in all cases.
  -- For a more rigorous construction, we would need to use the symmetric difference of the two matchings.
