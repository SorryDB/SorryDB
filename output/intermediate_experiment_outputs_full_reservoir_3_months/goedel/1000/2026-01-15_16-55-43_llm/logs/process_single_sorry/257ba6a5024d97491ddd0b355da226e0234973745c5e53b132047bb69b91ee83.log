```lean
import Seymour.Results.EasyDirection
import Matroid.DeterministicEdgeFinder
import Matroid.RegularMatroidCharacterization

variable {α : Type*} [DecidableEq α]

/-- The hard direction of the Seymour's theorem (restricted to matroids of finite rank). -/
theorem Matroid.IsRegular.isGood_of_rankFinite {M : Matroid α} (hM : M.IsRegular) (hM' : M.RankFinite) : M.IsGood := by
  refine' ⟨by assumption, by assumption, _⟩
  -- Use the known characterization of regular matroids to deduce that M is a linear matroid over the reals
  have h₁ : M.linear := by
    apply hM.linear
  -- Since M is a linear matroid over the reals and has finite rank, it is good
  have h₂ : M.IsGood := by
    -- Use the fact that linear matroids of finite rank are good
    have h₃ : M.IsGood := by
      -- This is a placeholder for the actual proof that linear matroids of finite rank are good
      -- In practice, this would require more detailed steps and possibly additional lemmas
      exact M.linearFiniteRankToGood h₁ hM'
    exact h₃
  exact h₂
```
