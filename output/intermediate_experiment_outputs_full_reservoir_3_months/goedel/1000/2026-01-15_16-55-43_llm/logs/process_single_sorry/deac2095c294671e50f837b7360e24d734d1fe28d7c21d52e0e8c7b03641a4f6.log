variable {p:ℕ} [Fact (Nat.Prime p)]
abbrev F (p:ℕ) : Type := ZMod p
def ex p (i: F p) : Option Unit := do
  eq0 i
  let vi := share i
  eq0 (vi + i)
  accept ()
def ex_circuit_fun p : Circuit' (F p) := fun _ =>
  .lam (fun i =>
  .eq0 (.v i) (
  .share (.v i) (fun vi =>
  .eq0 (.v vi + .v i) (
  .nil))))
theorem equiv : ∀ p [Fact (Nat.Prime p)] [Coe (F p) Nat],
  Simulation.s_bisim (ex p) (Circuit.eval' (ex_circuit_fun p)) := by
  unfold ex_circuit_fun
  unfold ex
  simp only [bind]
  simp only [Circuit.eval']
  intro p _ _
  constructor
  intro
  -- Apply the equivalences for the `eq0` and `share` constructs
  apply equiv_eq0
  simp [Exp.eval]
  apply equiv_share
  simp [Exp.eval]
  intro
  apply equiv_eq0
  simp [Exp.eval]
  <;> aesop
