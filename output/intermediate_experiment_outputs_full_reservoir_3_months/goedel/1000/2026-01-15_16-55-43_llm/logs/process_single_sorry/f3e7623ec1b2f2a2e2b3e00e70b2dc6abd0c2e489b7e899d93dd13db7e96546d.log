      have h₅ : max a b = a := by simp [h₂]
      simp_all [h₄, h₅]
      <;> linarith
    linarith
```

However, another approach would be to use the fact that all `x ∈ uIcc a b` are bounded below by either `a` or `b`, and since both are positive, `x > 0`:

```lean
have : 0 ∉ [[a, b]] := by
  intro h
  have h₁ : 0 ∈ [[a, b]] := h
  have h₂ : 0 ≥ min a b := by
    simp only [uIcc, Set.mem_Icc] at h₁
    linarith
  have h₃ : 0 ≤ max a b := by
    simp only [uIcc, Set.mem_Icc] at h₁
    linarith
  have h₄ : min a b > 0 := by
    cases' le_total a b with h₄ h₄
