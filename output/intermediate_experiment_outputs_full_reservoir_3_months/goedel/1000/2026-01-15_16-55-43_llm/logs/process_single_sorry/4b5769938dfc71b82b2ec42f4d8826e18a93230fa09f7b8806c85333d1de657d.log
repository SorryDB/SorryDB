```lean
theorem continuity_of_cubes : Continuous fun x : ℝ => x ^ 3 := by
  have h_main : ∀ (x : ℝ) (ε : ℝ), ε > 0 → (∃ (δ : ℝ), δ > 0 ∧ ∀ (y : ℝ), |y - x| < δ → |y ^ 3 - x ^ 3| < ε) := by
    intro x ε hε
    have h₁ : 0 < ε := hε
    -- Choose δ = min(1, ε / (3 * |x|² + 3 * |x| + 1))
    use min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1))
    constructor
    · -- Prove δ > 0
      have h₂ : 0 < 3 * |x| ^ 2 + 3 * |x| + 1 := by
        nlinarith [abs_nonneg x, sq_nonneg (|x| + 1)]
      have h₃ : 0 < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by positivity
      have h₄ : 0 < min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) := by
        apply lt_min
        · norm_num
        · exact h₃
      exact h₄
    · -- Prove the main inequality |y³ - x³| < ε
      intro y hy
      have h₂ : 0 < 3 * |x| ^ 2 + 3 * |x| + 1 := by
        nlinarith [abs_nonneg x, sq_nonneg (|x| + 1)]
      have h₃ : min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) ≤ 1 := by
        apply min_le_left
      have h₄ : min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
        apply min_le_right
      have h₅ : |y - x| < min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) := hy
      have h₆ : |y - x| < 1 := by
        linarith
      have h₇ : |y - x| < ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
        linarith
      have h₈ : |y| ≤ |x| + 1 := by
        calc
          |y| = |x + (y - x)| := by ring_nf
          _ ≤ |x| + |y - x| := abs_add x (y - x)
          _ ≤ |x| + 1 := by
            have h₈₁ : |y - x| < 1 := h₆
            have h₈₂ : |y - x| ≥ 0 := abs_nonneg (y - x)
            linarith
      have h₉ : |x ^ 2 + x * y + y ^ 2| ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by
        cases' le_total 0 (x ^ 2 + x * y + y ^ 2) with h h <;>
          cases' le_total 0 x with hx hx <;>
            cases' le_total 0 y with hy hy <;>
              simp_all only [abs_of_nonneg, abs_of_nonpos, add_left_neg, add_right_neg, add_assoc] <;>
                nlinarith [sq_nonneg (x + y), sq_nonneg (x - y), abs_nonneg x, abs_nonneg y,
                  abs_mul_abs_self x, abs_mul_abs_self y]
      have h₁₀ : |y ^ 3 - x ^ 3| < ε := by
        calc
          |y ^ 3 - x ^ 3| = |(y - x) * (x ^ 2 + x * y + y ^ 2)| := by
            ring_nf
            <;> simp [abs_mul, abs_of_nonneg, abs_of_nonpos, sub_nonneg, sub_nonpos]
            <;> ring_nf
            <;> linarith
          _ = |y - x| * |x ^ 2 + x * y + y ^ 2| := by
            rw [abs_mul]
          _ ≤ |y - x| * (3 * |x| ^ 2 + 3 * |x| + 1) := by
            gcongr <;>
              (try norm_num) <;>
                (try linarith) <;>
                  (try nlinarith [abs_nonneg x, abs_nonneg y, h₈]) <;>
                    (try linarith)
          _ < (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) * (3 * |x| ^ 2 + 3 * |x| + 1) := by
            gcongr <;>
              (try norm_num) <;>
                (try linarith) <;>
                  (try nlinarith [abs_nonneg x, abs_nonneg y, h₈]) <;>
                    (try linarith)
          _ = ε := by
            have h₁₁ : 3 * |x| ^ 2 + 3 * |x| + 1 > 0 := by positivity
            field_simp [h₁₁.ne']
            <;> ring_nf
            <;> linarith
      exact h₁₀
  -- Use the ε-δ definition to conclude continuity
  have h₂ : Continuous fun x : ℝ => x ^ 3 := by
    refine' Metric.continuous_iff.mpr fun x ε hε => _
    obtain ⟨δ, hδ, hδ'⟩ := h_main x ε hε
    refine' ⟨δ, hδ, _⟩
    intro y hy
    have h₃ : |y - x| < δ := by
      simpa [Real.dist_eq] using hy
    have h₄ : |y ^ 3 - x ^ 3| < ε := hδ' y h₃
    simpa [Real.dist_eq] using h₄
  exact h₂
