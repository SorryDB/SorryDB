      intro x hx
      have hx' : x ∉ S' := by
        simp_all [Set.mem_diff]
        <;> aesop
      have hx'' : x ∈ S := by
        simp_all [Set.mem_diff]
        <;> aesop
      have h₃ : ∃ e : β, e ∈ M ∧ G.IsIncident x e := by
        have h₄ : S' ∪ {x} ⊆ V(G, M) := by
          have h₅ : S' ∪ {x} ⊆ S := by
            have h₆ : S' ⊆ S := by
              simp_all [Set.mem_diff]
              <;> aesop
            have h₇ : {x} ⊆ S := by
              have h₈ : x ∈ S := by
                simp_all [Set.mem_diff]
                <;> aesop
              simpa using h₈
            exact Set.union_subset h₆ h₇
          have h₆ : S ⊆ V(G, M) := hS''
          exact Set.Subset.trans h₅ h₆
        have h₅ : x ∈ V(G, M) := by
          have h₆ : x ∈ S' ∪ {x} := by simp
          exact h₄ h₆
        have h₆ : x ∈ V(G, M) := h₅
        have h₇ : ∃ e : β, e ∈ M ∧ G.IsIncident x e := by
          rw [V(G)] at h₆
          simp only [Set.mem_setOf_eq, Set.mem_iUnion] at h₆
