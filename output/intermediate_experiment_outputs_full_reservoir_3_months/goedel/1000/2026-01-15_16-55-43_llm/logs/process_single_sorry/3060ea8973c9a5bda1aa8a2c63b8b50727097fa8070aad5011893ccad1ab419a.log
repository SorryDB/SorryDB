      -- Prove that S ⊆ V(G, M)
      have h₅ : S ⊆ V(G, M) := by
        have h₆ : S' ⊆ S := by
          simp_all [Set.mem_diff]
          <;> aesop
        have h₇ : S' ⊆ V(G, M) := h₁
        have h₈ : S ⊆ V(G, M) := by
          -- Use the fact that S \ S' can be matched with additional edges
          have h₉ : ∀ x ∈ S \ S', ∃ e : β, e ∈ M ∧ G.IsIncident x e := h₂
          -- Use the fact that S' ⊆ V(G, M) and S \ S' can be matched
          have h₁₀ : S ⊆ V(G, M) := by
            intro x hx
            by_cases hx' : x ∈ S'
