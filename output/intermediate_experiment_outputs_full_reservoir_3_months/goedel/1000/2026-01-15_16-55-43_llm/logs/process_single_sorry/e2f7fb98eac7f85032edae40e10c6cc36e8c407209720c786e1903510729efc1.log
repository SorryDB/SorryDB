  section KestrelTheorems
    open Kestrel

    -- For any bird `x`, the bird `K ◁ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ∀ x, (K ◁ x) is fixated on x := by
      intro x y
      have h := K.call x y
      exact h

    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      intro x
      have h1 := K.call x K
      have h2 := K.call K x
      have h3 := k_x_fixated_on_x K
      have h4 := h3 x
      have h5 := h3 K
      simp_all [Kestrel.K]
      <;>
      (try simp_all [Kestrel.K]) <;>
      (try aesop) <;>
      (try )
      <;>
      (try aesop)
      <;>
      (try simp_all [Kestrel.K]) <;>
      (try aesop)

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ◁ x = K ◁ y) :
        (x = y) := by
      have h1 := K.call x x
      have h2 := K.call y y
      have h3 := K.call x y
      have h4 := K.call y x
      have h5 := k_x_fixated_on_x x
      have h6 := k_x_fixated_on_x y
      simp_all [Kestrel.K]
      <;>
