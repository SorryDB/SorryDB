 Released under Apache 2.0 license as described in the file LICENSE.
 Authors: Filippo Nuccio
-/
import Mathlib
set_option linter.unusedVariables false

noncomputable section

namespace ItaLean

    
    /-
    # Filters
    -/
    
    section Filter
    
    open Filter Topology
    variable {α β γ : Type*}
    
    lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
      -- Use the property that if F ≤ G, then F.map f ≤ G.map f
      exact Filter.map_mono h
    
    /-
    The function `f` tends to `G` along `F`.
    -/
    def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G
    
    lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
        (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
      -- Use the transitivity of the ≤ relation between filters
      have h1 : F.map (t ∘ s) ≤ H := by
        calc
          F.map (t ∘ s) = F.map s |>.map t := by rw [Function.comp_def] <;> simp [map_map]
          _ ≤ G.map t := by
            -- Since F.map s ≤ G, applying map t preserves the order
            have h2 : F.map s ≤ G := hs
            exact Filter.map_mono h2
          _ ≤ H := ht
      -- Conclude that Tendsto (t ∘ s) F H
      exact h1
    
    example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
        (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
      -- Use the composition property of Tendsto
      have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
        -- Apply Tendsto_comp with the given Tendsto properties
        have h1 : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
        have h2 : Tendsto g (𝓝 Real.pi) atTop := hg
        exact Tendsto_comp h1 h2
      -- The result follows from the above steps
      exact h
    
    example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
        (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
      -- Use the composition property of Tendsto
      have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
        -- Apply Tendsto_comp with the given Tendsto properties
        have h1 : Tendsto a atTop (𝓝 (-1)) := ha
        have h2 : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I)) := hφ
        exact Tendsto_comp h1 h2
      -- The result follows from the above steps
      exact h
    
    /-
    `filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
    `h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
    The list is an optional parameter, `[]` being its default value.
    
    `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
    `{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.
    
    `filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
    `{ filter_upwards [h1, ⋯, hn], exact e }`.
    
    Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
    Note that in this case, the `aᵢ` terms can be used in `e`.
    -/
    example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
        (hT : {x | p x} ∈ 𝓝 x)
        (hT' : {x | p' x} ∈ 𝓝 x)
        (hS : {x | q x} ∈ 𝓝 x)
        (hS' : {x | q' x} ∈ 𝓝 x) :
        {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
      -- Use filter_upwards to combine the neighborhoods and prove the result
      have h₁ : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
        -- Use the fact that the intersection of neighborhoods is a neighborhood
        have h₂ : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := by
          -- The intersection of two neighborhoods is a neighborhood
          exact mem_nhds_inter hT hS
        have h₃ : {x : α | p' x} ∩ {x : α | q' x} ∈ 𝓝 x := by
          -- The intersection of two neighborhoods is a neighborhood
          exact mem_nhds_inter hT' hS'
        -- Use filter_upwards to combine the neighborhoods
        filter_upwards [h₂, h₃] with y hy₁ hy₂
        -- Consider the cases where y is in the intersection of p and q or p' and q'
        by_cases h₄ : p y <;> by_cases h₅ : q y <;> by_cases h₆ : p' y <;> by_cases h₇ : q' y <;>
          simp_all [Set.mem_inter_iff]
        <;>
          (try { contradiction }) <;>
          (try { aesop }) <;>
          (try { tauto })
      -- The result follows from the above steps
      exact h₁
    
    end Filter
    
    /-
    ## Lp-spaces
    -/
    
    section Lp
    
    open MeasureTheory ENNReal Set
    
    /-!
    The Dirac (outer) measure at `π ∈ ℝ`.
    -/
    def μD : OuterMeasure ℝ where
      measureOf := fun S => if (Real.pi : ℝ) ∈ S then 1 else 0
      empty := by
        simp [measureOf]
        <;>
        norm_num
      mono {S T} hST := by
        by_cases h : (Real.pi : ℝ) ∈ S
        · -- Case: π ∈ S
          have h₁ : (Real.pi : ℝ) ∈ T := by
            -- Since S ⊆ T, π ∈ S implies π ∈ T
            exact hST h
          simp_all [measureOf]
          <;>
          norm_num
        · -- Case: π ∉ S
          have h₁ : ¬(Real.pi : ℝ) ∈ T := by
            -- Since S ⊆ T, if π ∉ S, then π ∉ T
            intro h₂
            have h₃ : (Real.pi : ℝ) ∈ S := by
              have h₄ : (Real.pi : ℝ) ∈ T := h₂
              have h₅ : (Real.pi : ℝ) ∈ S := by
                by_contra h₅
                -- If π ∉ S, then π ∈ S is false, contradicting h₂
                simp_all [Set.subset_def]
                <;>
                tauto
              exact h₅
            contradiction
          simp_all [measureOf]
          <;>
          norm_num
