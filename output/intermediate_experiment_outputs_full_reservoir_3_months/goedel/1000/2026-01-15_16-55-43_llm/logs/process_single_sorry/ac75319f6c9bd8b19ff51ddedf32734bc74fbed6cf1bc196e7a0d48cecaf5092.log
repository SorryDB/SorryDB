lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, M ∆ E(P)) := by
  have h₁ : V(G, M) ⊆ V(G, M ∆ E(P)) := by
    intro v hv
    have h₂ : v ∈ V(G, M) := hv
    have h₃ : v ∈ V(G) := h₂.1
    have h₄ : ∃ e : β, e ∈ M ∧ v ∈ V(G, e) := h₂.2
    have h₅ : v ∈ V(G, M ∆ E(P)) := by
      -- We need to show that v ∈ V(G, M Δ E(P))
      -- Since v ∈ V(G, M), we can find an edge e ∈ M such that v ∈ V(G, e)
      obtain ⟨e, heM, heV⟩ := h₄
      -- If e ∉ E(P), then e ∈ M Δ E(P), so v ∈ V(G, e) ⊆ V(G, M Δ E(P))
      by_cases h₆ : e ∈ E(P)
      · -- Case: e ∈ E(P)
        -- Since P is an augmenting path, the endpoints of P are not in V(G, M)
        have h₇ : e ∈ E(P) := h₆
        have h₈ : e ∈ M := heM
        have h₉ : e ∈ M ∆ E(P) := by
          simp only [Set.mem_symmDiff, h₇, h₈]
          <;> simp_all
          <;> aesop
        have h₁₀ : v ∈ V(G, e) := heV
        have h₁₁ : V(G, e) ⊆ V(G) := by
          intro x hx
          exact hx.1
        have h₁₂ : v ∈ V(G, M ∆ E(P)) := by
          have h₁₃ : e ∈ M ∆ E(P) := h₉
          have h₁₄ : v ∈ V(G, e) := heV
          have h₁₅ : V(G, e) ⊆ V(G, M ∆ E(P)) := by
            intro x hx
            exact ⟨hx.1, ⟨e, h₁₃, hx.2⟩⟩
          exact h₁₅ h₁₄
        exact h₁₂
      · -- Case: e ∉ E(P)
        -- Since e ∉ E(P), then e ∈ M Δ E(P), so v ∈ V(G, e) ⊆ V(G, M Δ E(P))
        have h₇ : e ∉ E(P) := h₆
        have h₈ : e ∈ M := heM
        have h₉ : e ∈ M ∆ E(P) := by
          simp only [Set.mem_symmDiff, h₇, h₈]
          <;> simp_all
          <;> aesop
        have h₁₀ : v ∈ V(G, e) := heV
        have h₁₁ : V(G, e) ⊆ V(G) := by
          intro x hx
          exact hx.1
        have h₁₂ : v ∈ V(G, M ∆ E(P)) := by
          have h₁₃ : e ∈ M ∆ E(P) := h₉
          have h₁₄ : v ∈ V(G, e) := heV
          have h₁₅ : V(G, e) ⊆ V(G, M ∆ E(P)) := by
            intro x hx
            exact ⟨hx.1, ⟨e, h₁₃, hx.2⟩⟩
          exact h₁₅ h₁₄
        exact h₁₂
    exact h₅
  exact h₁
