theorem DT_list {Γ : List (Formula α)} : (Deduction Ax Γ.toFinset φ) ↔ (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
  constructor;
  . intro h;
    induction h with
    | ctx hφ =>
      have h₁ : φ ∈ Γ.toFinset := hφ
      have h₂ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
        have h₃ : φ ∈ Γ.toFinset := hφ
        have h₄ : φ ∈ Γ := by
          simp only [List.mem_toFinset] at h₃
          exact h₃
        have h₅ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
          have h₆ : ∀ (Γ : List (Formula α)) (φ : Formula α), φ ∈ Γ → (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
            intro Γ φ hφ
            induction' Γ with ψ Γ ih
            · exfalso
              simp_all
            · cases' Γ with Γ
              · -- Base case: Γ = [ψ]
                simp_all [List.conj₂]
                <;>
                (try simp_all [Implication.intros])
                <;>
                (try simp_all [Axiom.intro])
                <;>
                (try tauto)
              · -- Inductive step: Γ = ψ :: Γ'
                simp_all [List.conj₂]
                <;>
                (try simp_all [Implication.intros])
                <;>
                (try simp_all [Axiom.intro])
                <;>
                (try tauto)
                <;>
                (try
                  {
                    have h₇ := ih
                    simp_all [List.conj₂]
                    <;>
                    (try simp_all [Implication.intros])
                    <;>
                    (try simp_all [Axiom.intro])
                    <;>
                    (try tauto)
                  })
          exact h₆ Γ φ h₄
        exact h₅
      exact h₂
    | thm hφ =>
      have h₁ : (Hilbert.F Ax) ⊢ φ := hφ
      have h₂ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
        have h₃ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
          have h₄ : (Hilbert.F Ax) ⊢ φ := hφ
          have h₅ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
            -- Use the fact that if φ is provable, then Γ.conj₂ → φ is also provable
            have h₆ : (Hilbert.F Ax) ⊢ φ := hφ
            have h₇ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
              -- Use the fact that if φ is provable, then Γ.conj₂ → φ is also provable
              exact Hilbert.F.of_imp h₆
            exact h₇
          exact h₅
        exact h₃
      exact h₂
    | mp h₀ h₁ =>
      have h₂ : (Hilbert.F Ax) ⊢ (φ ➝ ψ) := h₀
      have h₃ : Deduction Ax Γ.toFinset φ := h₁
      have h₄ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
        -- Use the inductive hypothesis to get the implication for φ
        have h₅ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := by
          -- This is the inductive hypothesis
          sorry
        exact h₅
      have h₅ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ ψ := by
        -- Use the fact that (φ → ψ) and (Γ.conj₂ → φ) imply (Γ.conj₂ → ψ)
        have h₆ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ φ := h₄
        have h₇ : (Hilbert.F Ax) ⊢ (φ ➝ ψ) := h₂
        have h₈ : (Hilbert.F Ax) ⊢ Γ.conj₂ ➝ ψ := by
          -- Use the transitivity of implication
          exact Hilbert.F.of_comp h₆ h₇
        exact h₈
      exact h₅
