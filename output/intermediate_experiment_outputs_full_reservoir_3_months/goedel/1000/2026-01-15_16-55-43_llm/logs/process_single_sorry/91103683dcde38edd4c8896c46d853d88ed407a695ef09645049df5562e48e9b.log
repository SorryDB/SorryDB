    -- If the composition law holds and a mockingbird is in the forest,
    -- then there is a bird that is egocentric.
    theorem exists_egocentric : ∃ E, E is egocentric := by
      have h : M is egocentric := by
        have h₁ : M ◁ M = M := by
          -- Use the definition of the mockingbird to show that M ◁ M = M
          have h₂ := M.call M
          -- Simplify the equation M ◁ M = M ◁ M to M ◁ M = M
          have h₃ := M.call (M ◁ M)
          -- Use the fact that M is a mockingbird to get M ◁ (M ◁ M) = (M ◁ M) ◁ (M ◁ M)
          -- But since M ◁ M = M, this becomes M ◁ M = M
          simp_all [h₂]
          <;>
            simp_all [h₂]
          <;>
            simp_all [h₂]
          <;>
            simp_all [h₂]
        -- Now we have M ◁ M = M, which means M is egocentric
        simpa [egocentric] using h₁
      -- Since M is egocentric, we can take E = M
      exact ⟨M, h⟩
