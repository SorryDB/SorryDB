    -- If the composition law holds and a mockingbird is in the forest,
    -- then there is a bird that is egocentric.
    theorem exists_egocentric : ∃ E, EnchantedForest.Introduction.response E E = E := by
      have h₁ : M ◁ M = M ◁ M := rfl
      have h₂ : M is egocentric := by
        have h₃ : M ◁ M = M := by
          calc
            M ◁ M = M ◁ M := rfl
            _ = M := by
              have h₄ := M.call M
              have h₅ := M.call (M ◁ M)
              -- Since M is a mockingbird, M ◁ M = (M ◁ M) ◁ (M ◁ M)
              -- Simplifying, we get M ◁ M = M ◁ M, which is trivially true, but we need to show that M ◁ M = M.
              -- However, we can directly use the definition of a mockingbird to get M ◁ M = M.
              simp only [h₄] at *
              <;>
                simp_all [h₄]
              <;>
                rw [h₄]
              <;>
                simp_all [h₄]
        exact h₃
      have h₃ : ∃ E, EnchantedForest.Introduction.response E E = E := by
        refine' ⟨M, _⟩
        have h₄ : M is egocentric := h₂
        have h₅ : M ◁ M = M := by
          have h₆ : M is egocentric := h₂
          simp [egocentric] at h₆ ⊢
          <;>
            simp_all [egocentric]
          <;>
            aesop
        simp [egocentric] at h₄ ⊢
        <;>
          simp_all [egocentric]
        <;>
          aesop
      exact h₃
