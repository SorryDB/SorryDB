              <;> simp
            have h₉ : (μ : Measure E) (Kᶜ) < ε := hK' (μ : Measure E) h₈
            simpa using h₉
          obtain ⟨K, hK, hK'⟩ := h₄
          refine' ⟨K, hK, _⟩
          intro μ hμ
          have h₁₀ : (μ : Measure E) (Kᶜ) < ε := hK' μ hμ
          simpa using h₁₀
        -- Use the Prokhorov's theorem to show that the closure of S is compact.
        have h₄ : IsCompact (closure S) := by
          -- Use the fact that S is a set of probability measures and the closure is compact.
          exact isCompact_closure_of_isTight h₃
        exact h₄
      exact h₂
    exact h₁
  · intro h
    -- Prove that if the closure of S is compact, then the set of measures is tight.
