              have h₆ : IsTight ({x | ∃ μ ∈ S, ↑μ = x} : Set (Measure E)) := h
              have h₇ : ∃ (K : Set E), IsCompact K ∧ ∀ x ∈ {x | ∃ μ ∈ S, ↑μ = x}, x (Kᶜ) < ε := by
                -- Use the tightness of the set of measures to find K.
                exact h₆ ε εpos
              exact h₇
            obtain ⟨K, hK, hK'⟩ := h₅
            refine' ⟨K, hK, _⟩
            intro μ hμ
            have h₈ : (μ : Measure E) ∈ {x | ∃ μ ∈ S, ↑μ = x} := by
