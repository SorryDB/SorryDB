    -- Use the fact that S is tight to show that the set of measures is tight.
    have h₂ : IsTight ({x | ∃ μ ∈ S, ↑μ = x} : Set (Measure E)) := by
      -- Use the fact that S is tight to show that the set of measures is tight.
      have h₃ : IsTight S := h₁
      have h₄ : IsTight ({x | ∃ μ ∈ S, ↑μ = x} : Set (Measure E)) := by
