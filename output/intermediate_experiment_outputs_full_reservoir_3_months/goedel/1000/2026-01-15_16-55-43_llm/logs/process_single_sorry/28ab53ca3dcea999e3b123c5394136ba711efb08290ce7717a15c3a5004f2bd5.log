```lean
theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · -- Prove the forward direction: if `f` is a split epi, then for every `c`, the map `g ↦ f ≫ g` is surjective.
    intro h
    obtain ⟨g, hg⟩ := h
    intro c
    intro z
    -- Since `f ≫ g = id`, we can find a `g' : Hom Y c` such that `f ≫ g' = z`.
    use z ≫ g
    calc
      f ≫ (z ≫ g) = (f ≫ g) ≫ z := by rw [comp_assoc]
      _ = z := by
        -- Use the fact that `f ≫ g = id X`.
        have hX : f ≫ g = id X := by
          apply calc
            f ≫ g = f ≫ g := rfl
            _ = id X := hg
        rw [hX]
        <;> simp [id_comp]
  · -- Prove the backward direction: if for every `c`, the map `g ↦ f ≫ g` is surjective, then `f` is a split epi.
    intro h
    have h₁ : Function.Surjective (fun g : Hom Y X => f ≫ g) := h X
    obtain ⟨g, hg⟩ := h₁ (id X)
    refine' ⟨g, _⟩
    -- We need to show that `f ≫ g = id X`.
    have h₂ : f ≫ g = id X := hg
    exact h₂
```
