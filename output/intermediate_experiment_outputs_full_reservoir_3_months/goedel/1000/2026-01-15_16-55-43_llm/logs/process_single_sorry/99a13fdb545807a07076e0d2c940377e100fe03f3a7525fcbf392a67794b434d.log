```lean
lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  let S := {T : Ω → WithTop ι | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤}
  have h1 : ClassD X 𝓕 P → UniformIntegrable X 1 P := by
    intro h
    have h₂ : UniformIntegrable (fun (τ : S) ↦ stoppedValue X τ) 1 P := h.uniformIntegrable
    have h₃ : UniformIntegrable X 1 P := by
      have h₄ : (fun n : ℕ ↦ (fun ω : Ω ↦ (n : ℕ))) = fun n : ℕ ↦ (fun ω : Ω ↦ n) := by rfl
      -- Use the fact that the set of stopping times {n} is sufficient to imply uniform integrability of X
      have h₅ : { (fun ω : Ω ↦ n : Ω → WithTop ι) | (n : ℕ) } ⊆
          { T : Ω → WithTop ι | IsStoppingTime 𝓕 T ∧ ∀ ω : Ω, T ω ≠ ⊤ } := by
        intro T hT
        rcases hT with ⟨n, rfl⟩
        have h₆ : IsStoppingTime 𝓕 (fun ω : Ω ↦ (n : WithTop ι)) := by
          apply isStoppingTime_const
        have h₇ : ∀ ω : Ω, ( (fun ω : Ω ↦ (n : WithTop ι)) : Ω → WithTop ι ) ω ≠ ⊤ := by
          intro ω
          simp [WithTop.coe_ne_top]
