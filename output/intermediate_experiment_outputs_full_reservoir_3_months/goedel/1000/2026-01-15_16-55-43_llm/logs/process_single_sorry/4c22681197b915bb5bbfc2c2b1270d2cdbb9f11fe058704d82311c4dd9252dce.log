          refine' ⟨c, hc, _⟩
          linarith
        obtain ⟨c, hc, hc'⟩ := h₉
        have h₁₀ : c < 3 / 5 := h₂ c hc
        linarith
      exact h₆
    exact h₃
  exact h₁
