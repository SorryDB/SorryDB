            -- Use the property of supremum
            have h₁₁ : sSup {c | IsAdmissible c} - 1 / 5 < sSup {c | IsAdmissible c} := by
              linarith
            have h₁₂ : ∃ c ∈ {c | IsAdmissible c}, sSup {c | IsAdmissible c} - 1 / 5 < c := by
