```lean
def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) D where
  F := fun ⟨X, _, _⟩ => X
  homF := fun {X Y : Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)} (f : Hom X Y) => f.mk.val.1
  map_id X := by
    -- Prove that the mapping of identity morphisms is correct
    simp [Hom.ext_iff]
    <;>
    simp_all [id_comp, comp_id, Hom.ext_iff]
    <;>
    aesop
  
  map_comp f g := by
    -- Prove that the mapping of composition is correct
    simp [Hom.ext_iff]
    <;>
    simp_all [id_comp, comp_id, Hom.ext_iff]
    <;>
    aesop
``` 

