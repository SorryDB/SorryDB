theorem derivation_result_is_leaf_count :
  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  intro dt
  have h : ∀ (dt : ContextFreeGrammar.DerivationTree G), dt.result.len = dt.collectLeaves'.length := by
    intro dt
    induction dt using ContextFreeGrammar.DerivationTree.strong_induction_on with
    | h dt ih =>
      match dt with
      | ⟨_, ⟨_, []⟩⟩ => simp [List.length]
      | ⟨_, ⟨_, [(d : DerivationStep _ _), st]⟩⟩ =>
        have h₁ : d.prod.rhs.splitContainerProd.statement.d₁ = 0 := by
          simp [DerivationStep.dsplit]
          <;>
          simp_all [List.cons_eq_append, List.cons_eq_append]
          <;>
          aesop
        simp_all [List.length, Word.length_mul_add, List.map]
        <;>
        (try simp_all [splitBin.natSplit]) <;>
        (try omega) <;>
        (try aesop)
        <;>
        (try {
          simp_all [List.map, List.length, Nat.add_assoc]
          <;>
          omega
        })
  exact h dt
```

