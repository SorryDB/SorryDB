theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  refine' ⟨fun x => F.F x, _, _⟩
  · -- Prove that F.F is monotone
    intro x y h
    -- Use the fact that the composition of homomorphisms in the preorder category is the transitivity of the order
    have h₁ : (h : PLift (x ≤ y)) = ⟨h⟩ := rfl
    have h₂ : F.homF ( (⟨h⟩ : PLift (x ≤ y)) ) = ⟨le_refl (F.F x)⟩ := by
      -- Simplify the homomorphism application using the fact that F is a functor
      have h₃ : F.homF (⟨h⟩ : PLift (x ≤ y)) = ⟨le_refl (F.F x)⟩ := by
        -- Use the property of the identity and composition in the preorder category
        have h₄ := F.map_id x
        have h₅ := F.map_id y
        have h₆ := F.map_comp (⟨h⟩ : PLift (x ≤ y)) (⟨le_refl y⟩ : PLift (y ≤ y))
        simp [h₁] at h₆ ⊢
        <;>
        (try cases h₆ <;> simp_all [id]) <;>
        (try simp_all [comp, le_trans]) <;>
        (try aesop)
        <;>
        (try {
          simp_all [id, comp, le_trans]
          <;>
          aesop
        })
        <;>
        (try {
          simp_all [id, comp, le_trans]
          <;>
          aesop
        })
        <;>
        (try {
          simp_all [id, comp, le_trans]
          <;>
          aesop
        })
      exact h₃
    -- Use the simplified form to show that F.F x ≤ F.F y
    have h₃ : (F.F x : β) ≤ (F.F y : β) := by
      have h₄ : (F.homF (⟨h⟩ : PLift (x ≤ y)) : PLift (F.F x ≤ F.F y)) = ⟨le_refl (F.F x)⟩ := by
        simpa using h₂
      have h₅ : (F.homF (⟨h⟩ : PLift (x ≤ y)) : PLift (F.F x ≤ F.F y)) = ⟨le_refl (F.F x)⟩ := by
        simpa using h₂
      -- Use the simplified form to show the inequality
      have h₆ : (F.F x : β) ≤ (F.F y : β) := by
        simp_all [PLift.mk.injEq]
        <;>
        (try {
          simp_all [id, comp, le_trans]
          <;>
          aesop
        })
        <;>
        (try {
          simp_all [id, comp, le_trans]
          <;>
          aesop
        })
        <;>
        (try {
          simp_all [id, comp, le_trans]
          <;>
          aesop
        })
        <;>
        (try {
          simp_all [id, comp, le_trans]
          <;>
          aesop
        })
        <;>
        (try {
          simp_all [id, comp, le_trans]
          <;>
          aesop
        })
      exact h₆
    exact h₃
  · -- Prove that F.F x = F.F x for all x
    intro x
    rfl
