            apply Continuous.div
            · exact continuous_const
            · exact h₃
            · intro x
              have : x ^ 2 ≠ 0 → (x ^ 2 : ℝ) ≠ 0 := by intro h; exact_mod_cast h
              by_cases h₅ : x = 0
              · simp_all
              · have h₆ : x ^ 2 ≠ 0 := by
                  intro h₆
                  have h₇ : x = 0 := by
                    nlinarith
                  contradiction
                simp_all
          exact h₄
        exact h₂
    rw [h₁]
    -- Evaluate the integral of 1/x from a to b
    have h₂ : ∫ x in a..b, (1 / x : ℝ) = Real.log b - Real.log a := by
      have h₃ : ∫ x in a..b, (1 / x : ℝ) = Real.log b - Real.log a := by
        have h₄ : ∫ x in a..b, (1 / x : ℝ) = Real.log b - Real.log a := by
          rw [integral_one_div (by
            -- Prove that 0 ∉ [a, b]
            intro h₅
            norm_num [uIcc, Set.mem_Ioc, Set.mem_Ico] at h₅
            <;>
            (try cases ha.eq_or_lt a <;> cases ha.eq_or_lt b <;> simp_all [ha.le, hb.le]) <;>
            (try { nlinarith }) <;>
            (try { linarith })
            <;>
