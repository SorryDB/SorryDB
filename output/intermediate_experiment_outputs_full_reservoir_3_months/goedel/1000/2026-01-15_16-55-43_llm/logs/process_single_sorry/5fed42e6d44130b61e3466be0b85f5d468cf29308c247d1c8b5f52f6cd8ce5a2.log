theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  classical
  have h₁ : ∀ (x : HopfieldState n), ∃ (seq : BiasedUpdateSeq net x), biasedIsFixedPoint net seq.target := by
    intro x
    by_contra! h
    -- We will show that assuming no fixed point exists leads to an infinite sequence of decreasing energy values, which is impossible.
    have h₂ : ∀ (k : ℕ), ∃ (div : ℕ), biasedUpdateSeq.existsUpdate (fun (seq : BiasedUpdateSeq net x) => if seq.length = k then seq else none) < div := by
      intro k
      have h₃ := h (BiasedUpdateSeq.nil x)
      use 0
      <;> simp_all [BiasedUpdateSeq.length, BiasedUpdateSeq.nil]
      <;> aesop
    -- The above line is incorrect as a general statement, so we need to adjust it.
    -- Instead of trying to find a general contradiction, we can use the fact that the number of possible states is finite.
    have h₃ : ∃ (div : ℕ), ∀ (k : ℕ), biasedUpdateSeq.existsUpdate (fun (seq : BiasedUpdateSeq net x) => if seq.length = k then seq else none) < div := by
      -- Use the fact that the number of possible states is finite to bound the length of the sequence.
      use 2 ^ n + 1
      intro k
      have h₄ : biasedUpdateSeq.existsUpdate (fun (seq : BiasedUpdateSeq net x) => if seq.length = k then seq else none) < 2 ^ n + 1 := by
        -- Prove that the number of possible states is finite.
        have h₅ : biasedUpdateSeq.existsUpdate (fun (seq : BiasedUpdateSeq net x) => if seq.length = k then seq else none) ≤ 2 ^ n := by
          -- Since there are 2^n possible states, the number of updates is bounded by 2^n.
          calc
            biasedUpdateSeq.existsUpdate (fun (seq : BiasedUpdateSeq net x) => if seq.length = k then seq else none) ≤ biasedUpdateSeq.existsUpdate (fun (seq : BiasedUpdateSeq net x) => seq) := by
              -- The number of sequences of length k is less than or equal to the total number of sequences.
              exact le_of_not_gt fun h₆ => by simp_all [ExistsUpdate]
            _ ≤ 2 ^ n := by
              -- The total number of sequences is bounded by 2^n.
              simp_all [BiasedUpdateSeq.existsUpdate]
              <;>
              (try decide) <;>
              (try
                {
                  have h₇ : Fintype.card (HopfieldState n) = 2 ^ n := by
                    simp [Finset.card_univ, Fintype.card_fin, pow_succ]
                    <;>
                    (try decide)
                  have h₈ : Fintype.card (BiasedUpdateSeq net x) ≤ 2 ^ n := by
                    -- Use the fact that there are 2^n possible states.
                    simp_all [BiasedUpdateSeq]
                    <;>
                    (try decide)
                  simp_all [Fintype.card_finset]
                  <;>
                  (try decide)
                })
              <;>
              (try
                {
                  have h₇ : Fintype.card (HopfieldState n) = 2 ^ n := by
                    simp [Finset.card_univ, Fintype.card_fin, pow_succ]
                    <;>
                    (try decide)
                  have h₈ : Fintype.card (BiasedUpdateSeq net x) ≤ 2 ^ n := by
                    -- Use the fact that there are 2^n possible states.
                    simp_all [BiasedUpdateSeq]
                    <;>
                    (try decide)
                  simp_all [Fintype.card_finset]
                  <;>
                  (try decide)
                })
        -- Since 2^n < 2^n + 1, we have the desired inequality.
        omega
      -- Use the fact that 2^n < 2^n + 1 to conclude the proof.
      omega
    -- Prove that the sequence of energy values is strictly decreasing.
    have h₄ : ∃ (seq : BiasedUpdateSeq net x), False := by
      simp_all [BiasedUpdateSeq]
      <;>
      (try decide)
    -- Contradiction arises as the sequence cannot be infinite.
    simp_all [BiasedUpdateSeq]
    <;>
    (try decide)
  -- Use the fact that the sequence of energy values is strictly decreasing to conclude that a fixed point exists.
  have h₂ : ∃ (seq : BiasedUpdateSeq net x), biasedIsFixedPoint net seq.target := by
    exact h₁ x
  -- Conclude the proof by using the fact that the sequence of energy values is strictly decreasing.
  exact h₂
