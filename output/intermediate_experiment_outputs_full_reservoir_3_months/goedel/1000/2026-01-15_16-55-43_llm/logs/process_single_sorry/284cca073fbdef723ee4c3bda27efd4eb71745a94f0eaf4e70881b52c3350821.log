```lean
theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  use {
    toFun := (F.homF (x := (1 : α))),
    map_one' := by
      have h₁ := F.map_id ()
      have h₂ := F.map_id ()
      simp [MonoidHom.map_one, MonoidHom.map_mul] at h₁ h₂ ⊢
      <;> simp_all [F.map_id]
      <;> aesop
    map_mul' := by
      intro x y
      have h₁ := F.map_comp (x := x) (g := y)
      have h₂ := F.map_comp (x := y) (g := x)
      simp [MonoidHom.map_mul] at h₁ h₂ ⊢
      <;> simp_all [F.map_comp, F.map_id]
      <;> aesop
  }
  intro x
  have h₁ := F.map_comp (x := (1 : α)) (g := x)
  have h₂ := F.map_comp (x := x) (g := (1 : α))
  simp [MonoidHom.map_one, MonoidHom.map_mul] at h₁ h₂ ⊢
  <;> simp_all [F.map_comp, F.map_id]
  <;> aesop
``` 

