theorem RelIO.liftFinf_in {S} {ident : InternalPort Nat} {n : Nat} {f : Fin n → RelIO S}:
    AssocList.contains ident (RelIO.liftFinf n f) = true
  → ∃ i : Fin n, ident = i := by
  intro h
  have h₁ : ∃ i : Fin n, ident = i := by
    dsimp [RelIO.liftFinf, fin_range] at h
    simp only [AssocList.contains_eq, List.toList_toAssocList, List.any_map,
      List.any_eq_true, List.mem_mapFinIdx, List.length_replicate,
      Function.comp_apply, beq_iff_eq, forall_exists_index, and_imp] at h
    -- The above line simplifies the hypothesis `h` to a form where we can directly extract the index `i`.
    -- The actual proof is complicated because Lean's `Fin` type and list comprehensions are involved.
    -- However, for the sake of this example, we are assuming that the hypothesis `h` directly gives us the required `i`.
    -- In a real proof, we would need to carefully handle the `Fin` type and list indices.
    -- For the sake of brevity, we are using `aesop` to find the index `i`.
    -- In practice, you may need to provide more detailed steps here.
    <;>
    (try cases n <;> simp_all) <;>
    (try
      {
        aesop
      }) <;>
    (try
      {
        simp_all [Fin.ext_iff]
        <;> aesop
      }) <;>
    (try
      {
        rcases h with ⟨i, hi⟩
        refine' ⟨i, _⟩
        simp_all [Fin.ext_iff]
        <;> aesop
      })
    <;>
    aesop
  exact h₁
