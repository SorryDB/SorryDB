      have h₇ : k - m - 1 < vs.length := by
        have h₈ : k - m ≤ vs.length := by
          omega
        have h₉ : k - m - 1 < vs.length := by
          omega
        exact h₉
      exact h₇
    )
    else select (k - m - n) ws (by
      have h₃ : m = us.length := rfl
      have h₄ : n = vs.length := rfl
      have h₅ : k > m + n := by
        omega
      have h₆ : m + n ≤ xs.length := (partition3 us vs ws).2.2
