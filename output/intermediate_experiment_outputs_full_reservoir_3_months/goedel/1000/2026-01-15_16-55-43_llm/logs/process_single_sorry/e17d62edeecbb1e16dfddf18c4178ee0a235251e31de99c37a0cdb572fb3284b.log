```lean
def μD : OuterMeasure ℝ where
  measureOf := fun s => if (s : Set ℝ) = ∅ then 0 else 1
  empty := by
    simp [μD]
  mono {S T} hST := by
    have h : S ⊆ T := hST
    by_cases hS : S = ∅
    · simp_all [μD]
    · have hT : T ≠ ∅ := by
        intro hT
        have hS' : S = ∅ := by
          rw [hT] at h
          exact Set.Subset.antisymm h (Set.empty_subset S)
        contradiction
      simp_all [μD]
      <;> aesop
  iUnion_nat := by
    intro s
    by_cases h : ∀ n : ℕ, s n = ∅
    · have h₁ : (⋃ n : ℕ, s n) = ∅ := by
        have h₂ : ∀ n : ℕ, s n = ∅ := h
        have h₃ : (⋃ n : ℕ, s n) = ∅ := by
          apply Set.eq_empty_iff_forall_not_mem.mpr
          intro x hx
          have h₄ : ∃ n : ℕ, x ∈ s n := by simpa using hx
          obtain ⟨n, hn⟩ := h₄
          have h₅ : s n = ∅ := h₂ n
          rw [h₅] at hn
          exact Set.not_mem_empty x hn
        exact h₃
      simp_all [μD]
      <;>
      (try decide) <;>
      (try aesop)
    · -- Case 2: Not all sets s n are empty
      have h₁ : ∃ n : ℕ, s n ≠ ∅ := by
        by_contra h₁
        have h₂ : ∀ n : ℕ, s n = ∅ := by
          intro n
          by_contra h₃
          have h₄ : s n ≠ ∅ := h₃
          have h₅ : ∃ n : ℕ, s n ≠ ∅ := ⟨n, h₄⟩
          exact h₁ h₅
        exact h h₂
      -- Since there exists a non-empty set in the union, the measure of the union is 1
      have h₂ : (⋃ n : ℕ, s n) ≠ ∅ := by
        obtain ⟨n, hn⟩ := h₁
        have h₃ : s n ≠ ∅ := hn
        have h₄ : s n ⊆ (⋃ n : ℕ, s n) := by
          apply Set.subset_iUnion
          <;> simp
        have h₅ : s n ≠ ∅ := hn
        have h₆ : (⋃ n : ℕ, s n) ≠ ∅ := by
          by_contra h₆
          have h₇ : (⋃ n : ℕ, s n) = ∅ := by simpa using h₆
          have h₈ : s n ⊆ ∅ := by
            rw [h₇] at h₄
            exact h₄
          have h₉ : s n = ∅ := by
            apply Set.Subset.antisymm h₈
            exact Set.empty_subset (s n)
          contradiction
        exact h₆
      simp_all [μD]
      <;>
      (try decide) <;>
      (try aesop)

