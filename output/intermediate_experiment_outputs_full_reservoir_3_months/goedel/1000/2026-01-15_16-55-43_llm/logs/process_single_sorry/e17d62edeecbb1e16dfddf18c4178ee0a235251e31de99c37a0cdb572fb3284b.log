  have h : μD (∅ : Set ℝ) = 0 := by
    dsimp [μD]
    <;> simp
  exact h

theorem μD_singleton {x : ℝ} : μD {x} = 1 := by
  have h : μD ({x} : Set ℝ) = 1 := by
    dsimp [μD]
    <;> simp [Set.ext_iff]
    <;>
    (try norm_num) <;>
    (try
      {
        intro y
        by_cases hy : y = x <;> simp_all
        <;>
        (try aesop)
      })
  exact h

