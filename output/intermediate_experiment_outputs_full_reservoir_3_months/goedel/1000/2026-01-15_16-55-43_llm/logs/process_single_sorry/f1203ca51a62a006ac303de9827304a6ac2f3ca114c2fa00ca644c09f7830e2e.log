theorem Kesurjacency_of_algebra_maps (A : Algebra S R)
  (φ : S →+* R)
  (h : ∀ (x : A), ∃ (s : S), (algebraMap S A) s = x) :
  Surjective (algebraMap S A) := fun x => by
  -- Given any element x in A, we use the hypothesis to find an s in S such that the algebra map sends s to x.
  obtain ⟨s, hs⟩ := h x
  -- We then use the fact that the algebra map is surjective by definition to conclude that such an s exists.
  exact ⟨s, hs⟩
