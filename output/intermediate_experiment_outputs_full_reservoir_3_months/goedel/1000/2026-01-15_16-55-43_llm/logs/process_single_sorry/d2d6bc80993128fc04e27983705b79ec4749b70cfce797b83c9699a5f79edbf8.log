```lean
variable (V) in
@[simp] lemma binomialRandom_singleton [Finite V] (G : SimpleGraph V) :
    G(V, p) {G} = toNNReal p ^ G.edgeSet.ncard *
      toNNReal (σ p) ^ ((Nat.card V).choose 2 - G.edgeSet.ncard) := by
  classical
  cases nonempty_fintype V
  simp only [binomialRandom, measurableEmbedding_edgeSet.comap_apply, Set.image_singleton,
    edgeSet_subset_setOf_not_isDiag, bernoulliOn_singleton]
  rw [Set.ncard_diff (edgeSet_subset_setOf_not_isDiag _)]
  <;> simp_all [Nat.card_eq_fintype_card, Sym2.card_subtype_not_diag, Fintype.card_eq_nat_card]
  <;>
  (try decide) <;>
  (try simp_all [Set.ncard_insert_of_not_mem, Set.mem_singleton_iff, Sym2.ext_iff, Finset.card_insert_of_not_mem, Finset.mem_singleton]) <;>
  (try ring_nf) <;>
  (try norm_num) <;>
  (try field_simp) <;>
  (try norm_cast) <;>
  (try linarith) <;>
  (try simp_all [Finset.card_insert_of_not_mem, Finset.mem_singleton]) <;>
  (try ring_nf at *) <;>
  (try norm_num at *) <;>
  (try linarith)
