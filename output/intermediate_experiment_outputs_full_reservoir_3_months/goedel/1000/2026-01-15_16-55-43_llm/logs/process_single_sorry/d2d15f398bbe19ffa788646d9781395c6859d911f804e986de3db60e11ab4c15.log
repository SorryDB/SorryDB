def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    exact ⟨∅, by simp [Set.empty_subset]⟩
  indep_subset := by
    intro hS hT
    obtain ⟨M, hM, hS⟩ := hS
    refine' ⟨M, hM, _⟩
    have h₁ : T ⊆ S := hT
    have h₂ : S ⊆ V(G, M) := hS
    exact h₁.trans h₂
  indep_aug := by
    intro I hI J hJ hIJ
    have h₁ : I ⊆ G.vertexSet := by
      obtain ⟨M, hM, hI⟩ := hI
      have h₂ : I ⊆ V(G, M) := hI
      have h₃ : V(G, M) ⊆ G.vertexSet := by
        intro v hv
        simp only [V, Graph.edgeset, Set.mem_setOf_eq] at hv ⊢
        obtain ⟨e, _, rfl⟩ := hv
        simp [Edge.base]
        <;> aesop
      exact h₂.trans h₃
    have h₂ : J ⊆ G.vertexSet := by
      obtain ⟨N, hN, hJ⟩ := hJ
      have h₃ : J ⊆ V(G, N) := hJ
      have h₄ : V(G, N) ⊆ G.vertexSet := by
        intro v hv
        simp only [V, Graph.edgeset, Set.mem_setOf_eq] at hv ⊢
        obtain ⟨e, _, rfl⟩ := hv
        simp [Edge.base]
        <;> aesop
      exact h₃.trans h₄
    obtain ⟨M, hM, hI⟩ := hI
    obtain ⟨N, hN, hJ⟩ := hJ
    have h₃ : (I.card : ℕ) < (J.card : ℕ) := by simpa using hIJ
    have h₄ : J ⊆ G.vertexSet := h₂
