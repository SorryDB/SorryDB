lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : (x : U) ∈ val_image A X1 := by
    refine' ⟨x, hx, _⟩
    <;> simp
  have h₂ : (x : U) ∈ val_image A X2 := by
    rw [h] at h₁
    exact h₁
  rcases h₂ with ⟨y, hy, h₃⟩
  have h₄ : x = y := by
    have h₅ : (x : U) = (y : U) := by
      simpa [Set.mem_setOf_eq] using h₃
    exact Subtype.ext h₅
  rw [h₄]
  exact hy
``` 

