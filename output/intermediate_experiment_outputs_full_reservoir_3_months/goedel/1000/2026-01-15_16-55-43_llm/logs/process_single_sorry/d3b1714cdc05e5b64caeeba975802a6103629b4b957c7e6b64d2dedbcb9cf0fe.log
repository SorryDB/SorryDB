instance (n : ℕ) : SampleableType (ZMod (n + 1)) where
  selectElem := $[0..n]
  mem_support_selectElem := by
    intro x
    simp [support]
    <;>
    (try decide) <;>
    (try aesop) <;>
    (try { use x.val; simp [Fin.forall_fin_succ] <;> aesop }) <;>
    (try { exfalso; omega })
    <;>
    (try { use 0; simp_all [Fin.ext_iff] <;> omega })
  probOutput_selectElem_eq x y := by
    simp only [ZMod.val_nat_cast]
    <;>
    simp_all [probOutput_map_eq_sum_fintype_ite]
    <;>
    (try decide) <;>
    (try ring_nf) <;>
    (try simp_all [Fin.sum_univ_succ]) <;>
    (try norm_num) <;>
    (try aesop)
    <;>
    (try {
      simp_all [Finset.sum_range_succ, Finset.sum_range_zero]
      <;>
      ring_nf
      <;>
      norm_num
      <;>
      aesop
    })
  probFailure_selectElem := by
    simp [probFailure]
    <;>
    (try decide) <;>
    (try aesop)
    <;>
    (try {
      simp_all [Finset.sum_range_succ, Finset.sum_range_zero]
      <;>
      ring_nf
      <;>
      norm_num
      <;>
      aesop
    })
``` 

