<;>
theorem is_bernoulli_distrib {ι : Type u} {Ω : Type v} [MeasurableSpace Ω]
  (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :
    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P := by
  have h1 : HasLaw X Ber(u, p) P := hX
  have h2 : IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P := by
    -- Use the property that for any p-Bernoulli random set X on u, the indicator functions 1_{i ∈ X} and 1_{j ∈ X}
    -- are identically distributed because p is uniform over u.
    have h3 : IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P := by
      -- Prove that the distributions of the indicator functions are the same.
      have h4 : map (fun ω ↦ i ∈ X ω) P = map (fun ω ↦ j ∈ X ω) P := by
        -- Use the fact that the law of X is Ber(u, p), and thus the probabilities of i and j being in X are the same.
        have h5 : map (fun ω ↦ i ∈ X ω) P = Ber(u, p).map (fun s ↦ i ∈ s) := by
          calc
            map (fun ω ↦ i ∈ X ω) P = (map (fun ω ↦ X ω) P).map (fun s ↦ i ∈ s) := by
              rw [← MeasureTheory.map_map]
              <;>
              simp [Function.comp]
            _ = Ber(u, p).map (fun s ↦ i ∈ s) := by
              rw [← h1.map_coe]
              <;>
              simp [Function.comp]
        have h6 : map (fun ω ↦ j ∈ X ω) P = Ber(u, p).map (fun s ↦ j ∈ s) := by
          calc
            map (fun ω ↦ j ∈ X ω) P = (map (fun ω ↦ X ω) P).map (fun s ↦ j ∈ s) := by
              rw [← MeasureTheory.map_map]
              <;>
              simp [Function.comp]
            _ = Ber(u, p).map (fun s ↦ j ∈ s) := by
              rw [← h1.map_coe]
              <;>
              simp [Function.comp]
        have h7 : Ber(u, p).map (fun s ↦ i ∈ s) = Ber(u, p).map (fun s ↦ j ∈ s) := by
          -- Use the symmetry in the definition of Ber(u, p) to show that the two maps are equal.
          have h8 : ∀ a b : ι, a ∈ u → b ∈ u → Ber(u, p).map (fun s ↦ a ∈ s) = Ber(u, p).map (fun s ↦ b ∈ s) := by
            intro a b ha hb
            have h9 : a ∈ u := ha
            have h10 : b ∈ u := hb
            -- Use the fact that the law of X is Ber(u, p), which is symmetric with respect to the elements of u.
            have h11 : Ber(u, p).map (fun s ↦ a ∈ s) = Ber(u, p).map (fun s ↦ b ∈ s) := by
              -- Prove that the two distributions are the same by showing that their values on any measurable set are the same.
              have h12 : ∀ t : Set (Bool), (Ber(u, p).map (fun s ↦ a ∈ s)) t = (Ber(u, p).map (fun s ↦ b ∈ s)) t := by
                intro t
                have h13 : (Ber(u, p).map (fun s ↦ a ∈ s)) t = (Ber(u, p)) ( {s | a ∈ s ∈ t} ) := by
                  simp [MeasureTheory.map_apply, Set.indicator]
                  <;>
                  simp_all [Set.mem_preimage]
                  <;>
                  aesop
                have h14 : (Ber(u, p).map (fun s ↦ b ∈ s)) t = (Ber(u, p)) ( {s | b ∈ s ∈ t} ) := by
                  simp [MeasureTheory.map_apply, Set.indicator]
                  <;>
                  simp_all [Set.mem_preimage]
                  <;>
                  aesop
                have h15 : (Ber(u, p)) ( {s | a ∈ s ∈ t} ) = (Ber(u, p)) ( {s | b ∈ s ∈ t} ) := by
                  -- Use the symmetry in the definition of Ber(u, p) to show that the two sets have the same measure.
                  have h16 : ( {s : Set ι | a ∈ s ∈ t} ) = ( {s : Set ι | b ∈ s ∈ t} ) := by
                    apply Set.ext
                    intro s
                    have h17 : a ∈ u := ha
                    have h18 : b ∈ u := hb
                    have h19 : (a ∈ s) = (b ∈ s ∧ (a ∈ s ↔ b ∈ s)) ∨ ¬(a ∈ s ↔ b ∈ s) := by
                      by_cases h20 : a ∈ s ↔ b ∈ s
                      · exact Or.inl ⟨by tauto, h20⟩
                      · exact Or.inr h20
                    cases h19 with
                    | inl h19 =>
                      simp_all
                      <;>
                      tauto
                    | inr h19 =>
                      -- This case cannot happen because the variables are in u and the distribution is symmetric.
                      exfalso
                      -- Here we use that the variables are in u to show a contradiction.
                      have h20 : a ∈ s ↔ b ∈ s := by
                        -- Prove that a ∈ s iff b ∈ s by using the properties of Ber(u, p).
                        have h21 : ber(u, p) = ber(u, p) := rfl
                        simp_all [ber(u, p), ha, hb, h17, h18]
                        <;>
                        tauto
                      contradiction
                  rw [h16]
                rw [h13, h14, h15]
              -- Use the fact that the two distributions are equal on all measurable sets to conclude that they are equal.
              have h17 : Ber(u, p).map (fun s ↦ a ∈ s) = Ber(u, p).map (fun s ↦ b ∈ s) := by
                apply Measure.ext
                intro t
                apply h12
              exact h17
            exact h11
          have h18 := h8 i j hi hj
          exact h18
        calc
          Ber(u, p).map (fun s ↦ i ∈ s) = Ber(u, p).map (fun s ↦ j ∈ s) := by
            apply h7
          _ = Ber(u, p).map (fun s ↦ j ∈ s) := by rfl
      -- Conclude that the two indicator functions are identically distributed.
      simp_all [IdentDistrib]
      <;>
      aesop
    exact h3
  exact h2
