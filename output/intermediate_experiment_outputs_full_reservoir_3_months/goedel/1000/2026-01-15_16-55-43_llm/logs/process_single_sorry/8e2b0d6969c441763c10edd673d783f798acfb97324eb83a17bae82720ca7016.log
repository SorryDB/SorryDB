instance (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    have h₁ : x.1 ∈ support ($ᵗ α) := SampleableType.mem_support_selectElem x.1
    have h₂ : x.2 ∈ support ($ᵗ β) := SampleableType.mem_support_selectElem x.2
    have h₃ : x.1 ∈ support ($ᵗ α) := h₁
    have h₄ : x.2 ∈ support ($ᵗ β) := h₂
    have h₅ : (x.1, x.2) ∈ support ((·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
      -- Use the fact that the product of two probabilities with non-zero support has non-zero support
      have h₆ : 0 < Pr[= x.1 | $ᵗ α] := by
        have h₇ : x.1 ∈ support ($ᵗ α) := h₁
        have h₈ : 0 < Pr[= x.1 | $ᵗ α] := by
          -- Since x.1 is in the support, its probability is non-zero
          have h₉ : 0 < Pr[= x.1 | $ᵗ α] := by
            simp only [support, Set.mem_setOf_eq] at h₇
            simpa [Pr] using h₇
          exact h₉
        exact h₈
      have h₉ : 0 < Pr[= x.2 | $ᵗ β] := by
        have h₁₀ : x.2 ∈ support ($ᵗ β) := h₂
        have h₁₁ : 0 < Pr[= x.2 | $ᵗ β] := by
          -- Since x.2 is in the support, its probability is non-zero
          have h₁₂ : 0 < Pr[= x.2 | $ᵗ β] := by
            simp only [support, Set.mem_setOf_eq] at h₁₀
            simpa [Pr] using h₁₀
          exact h₁₂
        exact h₁₁
      have h₁₀ : 0 < Pr[= (x.1, x.2) | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] := by
        -- The probability of (x.1, x.2) is the product of the probabilities of x.1 and x.2
        calc
          0 < Pr[= x.1 | $ᵗ α] * Pr[= x.2 | $ᵗ β] := by positivity
          _ = Pr[= (x.1, x.2) | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] := by
            -- Use the property of product probabilities
            simp [Pr, SPMF.bind_apply, SPMF.mul, Function.comp]
            <;>
            simp_all [Fintype.card_pos, Inhabited]
            <;>
            try simp_all [Fintype.card_pos, Inhabited]
            <;>
            try aesop
      -- Since the probability is non-zero, (x.1, x.2) is in the support
      simp only [support, Set.mem_setOf_eq]
      simpa [Pr] using h₁₀
    exact h₅
  probOutput_selectElem_eq x y := by sorry
  probFailure_selectElem := by sorry
