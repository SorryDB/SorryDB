theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  have h₁ : ∀ (k : ℕ), 4 ≤ k → k ^ 2 ≤ k ! := by
    intro k hk
    induction' hk with k hk IH
    · norm_num [Nat.factorial]
    · cases k with
      | zero => contradiction
      | succ k' =>
        cases k' with
        | zero => contradiction
        | succ k'' =>
          cases k'' with
          | zero => contradiction
          | succ k''' =>
            cases k''' with
            | zero => contradiction
            | succ k'''' =>
              simp_all [Nat.factorial, Nat.mul_assoc, Nat.pow_succ, Nat.mul_comm]
              <;>
                nlinarith [Nat.mul_le_mul_left (k'''' + 1) IH]
  exact h₁ n h₀
```
