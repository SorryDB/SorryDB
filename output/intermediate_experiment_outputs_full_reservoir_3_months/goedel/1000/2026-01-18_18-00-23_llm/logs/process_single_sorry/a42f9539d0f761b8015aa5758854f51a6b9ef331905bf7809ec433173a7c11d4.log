### Formal Proof in Lean

```lean
theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  have h₁ : ∀ n : ℕ, 4 ≤ n → n ^ 2 ≤ n ! := by
    intro n hn
    induction' hn with n hn IH
    · -- Base case: n = 4
      norm_num [Nat.factorial]
    · -- Inductive step: assume true for n, prove for n + 1
      have h₂ : n + 1 ≤ n ^ 2 := by
        have h₃ : n ≥ 4 := hn
        have h₄ : n + 1 ≤ n ^ 2 := by
          cases n with
          | zero => contradiction -- n cannot be zero since hn : 4 ≤ n
          | succ n =>
            cases n with
            | zero => contradiction -- n cannot be 1 since hn : 4 ≤ n
            | succ n =>
              cases n with
              | zero => contradiction -- n cannot be 2 since hn : 4 ≤ n
              | succ n =>
                cases n with
                | zero => contradiction -- n cannot be 3 since hn : 4 ≤ n
                | succ n =>
                  simp [Nat.pow_succ, Nat.mul_succ] at *
                  <;> ring_nf at *
                  <;> nlinarith
        exact h₄
      have h₃ : (n + 1) ^ 2 ≤ (n + 1) * n ^ 2 := by
        have h₄ : n + 1 ≤ n ^ 2 := h₂
        have h₅ : (n + 1) ^ 2 = (n + 1) * (n + 1) := by ring
        have h₆ : (n + 1) * (n + 1) ≤ (n + 1) * n ^ 2 := by
          exact Nat.mul_le_mul_left (n + 1) h₄
        linarith
      have h₄ : (n + 1) * n ^ 2 ≤ (n + 1) * n ! := by
        have h₅ : n ^ 2 ≤ n ! := IH
        have h₆ : (n + 1) * n ^ 2 ≤ (n + 1) * n ! := by
          exact Nat.mul_le_mul_left (n + 1) h₅
        exact h₆
      have h₅ : (n + 1) ^ 2 ≤ (n + 1) * n ! := by
        calc
          (n + 1) ^ 2 ≤ (n + 1) * n ^ 2 := h₃
          _ ≤ (n + 1) * n ! := h₄
      have h₆ : (n + 1) * n ! = (n + 1)! := by
        simp [Nat.factorial]
        <;> ring_nf
        <;> simp_all [Nat.factorial]
        <;> linarith
      calc
        (n + 1) ^ 2 ≤ (n + 1) * n ! := h₅
        _ = (n + 1)! := by rw [h₆]
  exact h₁ n h₀
```

