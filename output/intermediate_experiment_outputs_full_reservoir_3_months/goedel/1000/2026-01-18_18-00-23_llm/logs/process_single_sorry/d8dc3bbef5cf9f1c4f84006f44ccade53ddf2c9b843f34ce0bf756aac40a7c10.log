    have h₂ : B ∈ Knight := by
      by_cases h₃ : B ∈ Knight
      · exact h₃
      · exfalso
        -- If B is not a knight, then B is a knave
        have h₄ : B ∈ Knave := by
          simp_all [Knave, not_not]
