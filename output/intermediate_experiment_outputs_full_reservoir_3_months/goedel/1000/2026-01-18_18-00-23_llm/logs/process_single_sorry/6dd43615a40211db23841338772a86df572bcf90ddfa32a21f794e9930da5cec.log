  exact hs'.2
have fc_lt : ¬ f c < 0 := by
  intro h
  have h₁ : ∀ ε > 0, ∃ δ > 0, ∀ x, |x - c| < δ → |f x - f c| < ε := by
    intro ε hε
    have h₂ : Continuous f := hf.1
    exact Metric.continuousAt_iff.mp (h₂.continuousAt) ε hε
  have h₂ : ∃ δ > 0, ∀ x, |x - c| < δ → |f x - f c| < (-f c / 2) := by
    have h₃ : (-f c / 2 : ℝ) > 0 := by linarith
    have h₄ : ∃ δ > 0, ∀ x, |x - c| < δ → |f x - f c| < (-f c / 2) := h₁ (-f c / 2) (by linarith)
    exact h₄
  obtain ⟨δ, hδpos, hδ⟩ := h₂
  have h₃ : c + δ / 2 ≤ b := by
    by_contra h₄
    have h₅ : b < c + δ / 2 := by linarith
    have h₆ : |b - c| < δ := by
