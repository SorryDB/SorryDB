theorem IVT {f : ℝ → ℝ} (hf : Continuous f) {a b : ℝ} (hab : a < b)
    (hfa : f a < 0) (hfb : 0 < f b): ∃ c ∈ Ioo a b, f c = 0 := by
  have h₁ : ∃ c ∈ Set.Ioo a b, f c = 0 := by
    -- Use the intermediate value theorem to find a root in the open interval (a, b)
    have h₂ : ContinuousOn f (Set.Icc a b) := hf.continuousOn
    have h₃ : ∃ c ∈ Set.Ioo a b, f c = 0 := by
      apply intermediate_value_Ioo (by linarith) h₂
      exact ⟨by linarith, by linarith⟩
    exact h₃
  exact h₁
