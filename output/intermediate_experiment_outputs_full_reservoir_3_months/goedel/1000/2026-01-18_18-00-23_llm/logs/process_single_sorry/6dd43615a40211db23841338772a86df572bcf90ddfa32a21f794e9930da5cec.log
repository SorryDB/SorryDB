```lean
theorem IVT {f : ℝ → ℝ} (hf : ContinuousOn f (Set.Icc a b)) (ha : f a < 0) (hb : f b > 0) : ∃ c ∈ Set.Ioo a b, f c = 0 := by
  have h₀ : ∃ c ∈ Set.Ioo a b, f c = 0 := by
    have h₁ : ∃ c ∈ Set.Icc a b, f c = 0 := by
      -- Use the Intermediate Value Theorem to find a point c in [a, b] where f(c) = 0
      have h₂ : ContinuousOn f (Set.Icc a b) := hf
      have h₃ : ∃ c ∈ Set.Icc a b, f c = 0 := by
        apply intermediate_value_Icc (by linarith) h₂
        constructor <;> nlinarith
      exact h₃
    -- Obtain the point c in [a, b] where f(c) = 0
    obtain ⟨c, hc, hc'⟩ := h₁
    -- Check if c is in the open interval (a, b)
    have h₄ : c ∈ Set.Ioo a b := by
      by_cases h₅ : c = a
      · -- If c = a, then f(a) = 0, which contradicts f(a) < 0
        exfalso
        have h₆ : f a < 0 := ha
        have h₇ : f c = 0 := hc'
        have h₈ : f a = 0 := by
          rw [h₅] at h₇
          exact h₇
        linarith
      · by_cases h₅ : c = b
        · -- If c = b, then f(b) = 0, which contradicts f(b) > 0
          exfalso
          have h₆ : f b > 0 := hb
          have h₇ : f c = 0 := hc'
          have h₈ : f b = 0 := by
            rw [h₅] at h₇
            exact h₇
          linarith
        · -- If c ≠ a and c ≠ b, then c is in (a, b)
          have h₆ : a < c := by
            by_contra h₆
            have h₇ : c ≤ a := by linarith
            have h₈ : c ∈ Set.Icc a b := hc
            have h₉ : a ≤ c := h₈.1
            have h₁₀ : c = a := by linarith
            contradiction
          have h₇ : c < b := by
            by_contra h₇
            have h₈ : c ≥ b := by linarith
            have h₉ : c ∈ Set.Icc a b := hc
            have h₁₀ : c ≤ b := h₉.2
            have h₁₁ : c = b := by linarith
            contradiction
          exact ⟨h₆, h₇⟩
    -- Conclude that c is in (a, b) and f(c) = 0
    exact ⟨c, h₄, hc'⟩
  -- Obtain the final result
  exact h₀
```
