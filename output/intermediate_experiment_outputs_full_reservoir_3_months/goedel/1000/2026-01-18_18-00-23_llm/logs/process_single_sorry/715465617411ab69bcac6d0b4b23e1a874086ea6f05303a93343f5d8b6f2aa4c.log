lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := by
  apply Set.Subset.antisymm
  · -- Prove A ⊆ {a}
    intro x hx
    by_contra h
    -- Assume x ∈ A and x ≠ a
    have h3 : x ∈ A \ {a} := by
      constructor
      · exact hx
      · intro h4
        apply h
        simpa using h4
    -- But this contradicts the emptiness of A \ {a}
    exact Set.not_mem_empty _ (h2 h3)
  · -- Prove {a} ⊆ A
    intro x hx
    -- If x ∈ {a}, then x = a
    have h3 : x = a := by simpa using hx
    -- Since a ∈ A, we have x ∈ A
    rw [h3]
    exact h1
