lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := by
  have h3 : A ⊆ {a} := by
    intro x hx
    by_contra h4
    have h5 : x ≠ a := by tauto
    have h6 : x ∈ A \ {a} := by
      exact ⟨hx, by simpa using h5⟩
    have h7 : ¬(x ∈ A \ {a}) := by
      simpa using h2 h6
    exact h7 h6
  have h4 : {a} ⊆ A := by
    intro x hx
    have h5 : x = a := by simpa using hx
    rw [h5]
    exact h1
  exact Set.Subset.antisymm h3 h4
