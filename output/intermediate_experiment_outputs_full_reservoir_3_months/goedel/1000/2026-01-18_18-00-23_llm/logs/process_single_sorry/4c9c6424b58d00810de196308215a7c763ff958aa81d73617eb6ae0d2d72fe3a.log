lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · -- Prove the forward direction: if f is onto, then range f = Univ V
    intro h
    apply Set.eq_univ_of_forall
    intro y
    have h₁ : y ∈ range f := by
      -- Since f is onto, for every y in V, there exists an x in U such that f x = y
      have h₂ : ∃ x, f x = y := h y
      -- Therefore, y is in the range of f
      rcases h₂ with ⟨x, rfl⟩
      exact Set.mem_range_self x
    -- Thus, every y in V is in the range of f, so range f = Univ V
    exact h₁
  · -- Prove the reverse direction: if range f = Univ V, then f is onto
    intro h
    intro y
    -- Since range f = Univ V, y is in the range of f
    have h₁ : y ∈ range f := by
      rw [h]
      trivial
    -- Therefore, there exists an x in U such that f x = y, so f is onto
    rcases h₁ with ⟨x, rfl⟩
    exact ⟨x, rfl⟩
