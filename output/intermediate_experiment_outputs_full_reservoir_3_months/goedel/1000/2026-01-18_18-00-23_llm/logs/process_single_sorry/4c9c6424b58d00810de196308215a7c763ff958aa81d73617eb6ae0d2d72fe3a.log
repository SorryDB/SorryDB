### Solution

```lean
theorem Set_equinum_powerset {U : Type} (A : Set U) :
    Set A ∼ 𝒫 A := by
  classical
  have h₁ : Set A ∼ Set U := by
    apply Equiv.Set.ofEquiv _
    exact Set.inclusion_equiv A
  have h₂ : 𝒫 A ∼ 𝒫 U := by
    apply Set.powersetEquiv (fun _ => by simp [Set.ext_iff])
  have h₃ : Set U ∼ 𝒫 U := by
    apply Set.bijective_coe_coe_ip_bijection
  exact Equiv.trans (Equiv.trans h₁ h₃.symm) h₂
```
