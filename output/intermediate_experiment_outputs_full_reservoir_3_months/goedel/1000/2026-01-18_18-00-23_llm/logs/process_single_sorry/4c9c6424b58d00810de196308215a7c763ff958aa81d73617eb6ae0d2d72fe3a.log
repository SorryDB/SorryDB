theorem Exercise_8_1_1_b : denum {n : Int | even n} := by
  have h : denum {n : Int | even n} := by
    -- We use the fact that the set of even integers is countable by constructing a bijection with the integers.
    have h₁ : {n : Int | even n} ≃ ℤ := by
      -- Define a bijection between the set of even integers and the integers.
      refine' ⟨fun n => n / 2, fun n => 2 * n, _, _⟩
      · -- Prove that the function is injective.
        intro a b h
        have h₂ : a / 2 = b / 2 := h
        have h₃ : a % 2 = 0 := by
          have h₄ : even a := by
            exact Set.mem_setOf.mp (by
              -- Prove that a is in the set of even integers.
              simp_all [Int.even_iff]
              <;>
              (try omega)
            )
          simp_all [Int.even_iff, Int.emod_eq_of_lt]
          <;>
          (try omega)
        have h₄ : b % 2 = 0 := by
          have h₅ : even b := by
            exact Set.mem_setOf.mp (by
              -- Prove that b is in the set of even integers.
              simp_all [Int.even_iff]
              <;>
              (try omega)
            )
          simp_all [Int.even_iff, Int.emod_eq_of_lt]
          <;>
          (try omega)
        -- Use the fact that a and b are even to prove that a = b.
        have h₅ : a = b := by
          have h₆ : a % 2 = 0 := h₃
          have h₇ : b % 2 = 0 := h₄
          have h₈ : a / 2 = b / 2 := h₂
          have h₉ : a = 2 * (a / 2) := by
            have h₁₀ : a % 2 = 0 := h₃
            have h₁₁ : a = 2 * (a / 2) := by
              omega
            exact h₁₁
          have h₁₀ : b = 2 * (b / 2) := by
            have h₁₁ : b % 2 = 0 := h₄
            have h₁₂ : b = 2 * (b / 2) := by
              omega
            exact h₁₂
          omega
        exact h₅
      · -- Prove that the function is surjective.
        intro n
        use 2 * n
        <;>
        (try simp_all [Int.even_iff]) <;>
        (try omega)
    -- Use the bijection to prove that the set of even integers is countable.
    have h₂ : denum {n : Int | even n} := by
      have h₃ : denum ℤ := by
        apply Int.denum
      have h₄ : {n : Int | even n} ≃ ℤ := h₁
      exact h₃.ofEquiv h₄.symm
    exact h₂
  exact h
