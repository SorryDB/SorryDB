lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : x.val ∈ val_image A X1 := by
    refine' ⟨x, hx, _⟩
    <;> simp [Set.mem_setOf_eq]
  have h₂ : x.val ∈ val_image A X2 := by
    rw [h] at h₁
    exact h₁
  rcases h₂ with ⟨y, hy, hy'⟩
  have h₃ : y = x := by
    have h₄ : (y : U) = x.val := by
      simp_all [Set.mem_setOf_eq]
    have h₅ : (y : U) = (x : U) := by
      simp_all [Set.mem_setOf_eq]
    exact Subtype.ext h₅
  have h₄ : x ∈ X2 := by
    simpa [h₃] using hy
  exact h₄
```

