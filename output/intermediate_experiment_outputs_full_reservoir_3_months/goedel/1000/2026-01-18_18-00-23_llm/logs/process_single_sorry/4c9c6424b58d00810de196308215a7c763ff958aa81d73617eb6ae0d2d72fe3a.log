lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := by
  have h2 : ∀ n : ℕ, tri n = n * (n + 1) / 2 := by
    intro n
    induction n with
    | zero => simp [tri]
    | succ n ih =>
      simp_all [tri, Nat.succ_eq_add_one, Nat.mul_succ, Nat.add_assoc]
      <;> ring_nf at *
      <;> omega
  have h3 : tri j = j * (j + 1) / 2 := h2 j
  have h4 : tri k = k * (k + 1) / 2 := h2 k
  rw [h3, h4]
  have h5 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
    have h6 : j ≤ k := h1
    have h7 : j * (j + 1) ≤ k * (k + 1) := by
      have h8 : j ≤ k := h1
      have h9 : j + 1 ≤ k + 1 := by linarith
      have h10 : 0 ≤ j := by linarith
      have h11 : 0 ≤ k := by linarith
      nlinarith
    have h12 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
      have h13 : j * (j + 1) ≤ k * (k + 1) := h7
      have h14 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
        apply Nat.div_le_div_right
        <;> nlinarith
      exact h14
    exact h12
  exact h5
