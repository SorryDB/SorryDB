private lemma inv_convMul_cancel (f : C →ₐc[R] A) : f⁻¹ * f = 1 := by
  have h₁ : f⁻¹ * f = 1 := by
    -- Use the fact that the antipode is an involutive anti-automorphism in the convolution algebra
    have h₂ : f⁻¹ * f = (antipodeBialgHom.comp f) * f := rfl
    rw [h₂]
    -- Use the properties of the antipode in the convolution algebra to show that the product is the identity
    have h₃ : (antipodeBialgHom.comp f : C →ₐ[R] A) * f = 1 := by
      -- Use the fact that the antipode and the identity in the convolution algebra cancel out
      have h₄ : ((antipodeBialgHom.comp f : C →ₐ[R] A) * f : C →ₐ[R] A) = 1 := by
        -- Use the properties of the antipode in the convolution algebra to show that the product is the identity
        apply AlgHom.ext
        intro c
        simp [convMulApplication, antipodeBialgHom, BialgHomClass.map_smul', BialgHomClass.counit_comp]
        <;> simp_all [HopfAlgebra.antipode_mul]
        <;> ring
      exact h₄
    exact h₃
  exact h₁
