def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [Equiv.invFun_eq]
    <;> simp_all [RingHom.map_mul, RingHom.map_add]
    <;> rfl
  
  right_inv := by
    intro x
    simp [Equiv.invFun_eq]
    <;> simp_all [RingHom.map_mul, RingHom.map_add]
    <;> rfl
  
  map_add' := by
    intro x y
    simp [add_assoc]
    <;> simp_all [RingHom.map_mul, RingHom.map_add]
    <;> rfl
  
  map_mul' := by
    intro x y
    simp [add_assoc]
    <;> simp_all [RingHom.map_mul, RingHom.map_add]
    <;> rfl
