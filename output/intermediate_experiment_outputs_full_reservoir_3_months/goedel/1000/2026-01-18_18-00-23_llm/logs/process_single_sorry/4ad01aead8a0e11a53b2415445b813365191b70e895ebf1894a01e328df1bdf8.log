def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    calc
      (g.comp f).invFun ((g.comp f) x) = f.symm (g.symm (g (f x))) := rfl
      _ = f.symm (f x) := by
        have h : g.symm (g (f x)) = f x := by
          apply Equiv.symm_apply_apply
        rw [h]
      _ = x := by
        have h : f.symm (f x) = x := by
          apply Equiv.symm_apply_apply
        rw [h]
  right_inv := by
    intro y
    calc
      (g.comp f) ((g.comp f).invFun y) = g (f (f.symm (g.symm y))) := by
        rfl
      _ = g (g.symm y) := by
        have h : f (f.symm (g.symm y)) = g.symm y := by
          have h₁ : g.symm y ∈ Set.univ := Set.mem_univ _
          have h₂ : f.symm (f (g.symm y)) = g.symm y := by
            apply Equiv.symm_apply_apply
          have h₃ : f (f.symm (g.symm y)) = g.symm y := by
            rw [Equiv.apply_symm_apply]
          exact h₃
        rw [h]
      _ = y := by
        have h : g (g.symm y) = y := by
          apply Equiv.apply_symm_apply
        rw [h]
  map_add' := by
    intro x y
    calc
      (g.comp f) (x + y) = g (f (x + y)) := rfl
      _ = g (f x + f y) := by
        -- Use the fact that f is a ring homomorphism to distribute f over addition
        have h : f (x + y) = f x + f y := f.map_add x y
