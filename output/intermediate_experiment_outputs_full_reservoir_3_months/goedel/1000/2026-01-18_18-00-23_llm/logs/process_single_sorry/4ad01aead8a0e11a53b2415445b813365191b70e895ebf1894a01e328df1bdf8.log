def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [Function.comp_apply]
    <;>
    simp_all [RingEquiv.apply_symm_apply]
    <;>
    simp_all [RingEquiv.apply_symm_apply]
  
  right_inv := by
    intro x
    simp [Function.comp_apply]
    <;>
    simp_all [RingEquiv.symm_apply_apply]
  
  map_add' := by
    intro x y
    simp [Function.comp_apply]
    <;>
    simp_all [RingHom.map_add]
    <;>
