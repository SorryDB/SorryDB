    simp_all [RingEquiv.symm_apply_apply]
    <;>
    simp_all [Function.rightInverse_invFun]
  
  map_add' := by
    intro x y
    simp [add_assoc, add_comm, add_left_comm, f.map_add, g.map_add]
    <;> simp_all [add_assoc, add_comm, add_left_comm]
    <;> ring_nf at *
    <;> simp_all [add_assoc, add_comm, add_left_comm]
    <;> try norm_num
    <;> try linarith
  
  map_mul' := by
    intro x y
    calc
      g (f (x * y)) = g (f x * f y) := by rw [f.map_mul]
      _ = g (f x) * g (f y) := by rw [g.map_mul]
