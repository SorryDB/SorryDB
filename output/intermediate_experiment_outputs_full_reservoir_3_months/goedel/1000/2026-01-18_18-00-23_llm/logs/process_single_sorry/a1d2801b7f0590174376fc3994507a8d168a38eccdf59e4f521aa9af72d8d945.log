            rw [Nat.mod_eq_of_lt h₁₀]
          exact h₁₂
        omega
      have h₁₀ : ZMod.val (y : F p) + 1 ≥ 2 ^ n := by omega
      have h₁₁ : ZMod.val (y : F p) < 2 ^ n := hy'
      omega
    exact h₄
  simp_all [ZMod.val_add, ZMod.val_one]
  <;> omega
