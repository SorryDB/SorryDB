theorem LessEqThan_circuit_soundness (p : ℕ) [Fact (Nat.Prime p)] [Fact (p > 2)] (n : ℕ) (hn : 2 ^ (n + 1) < p) :
  ∀ (i : ℕ) (env : Environment (F p)) (input : Var fieldPair (F p)) (x y : F p),
    Expression.eval env input.1 = x ∧ Expression.eval env input.2 = y →
    (ZMod.val x < 2 ^ n ∧ ZMod.val y < 2 ^ n) →
    ZMod.val (y + 1) < 2 ^ n := by
  intro i env input x y h_input assumptions
  have h_y : ZMod.val y < 2 ^ n := assumptions.2
  have h_val_y_lt : ZMod.val y < 2 ^ n := by simpa using h_y
  have h_val_y_add_one : ZMod.val (y + 1) < 2 ^ n := by
    have h1 : ZMod.val (y + (1 : F p)) = (ZMod.val y + 1) % p := by
      simp [ZMod.val_add, ZMod.val_one]
      <;>
      (try norm_num) <;>
      (try simp_all [ZMod.val_one]) <;>
      (try omega)
    have h2 : (ZMod.val y + 1) % p < p := Nat.mod_lt _ (by
      have h₃ : 0 < p := by
        have h₄ : p > 2 := Fact.out
        linarith
      linarith)
    have h3 : p > 2 ^ n := by
      have h₄ : 2 ^ (n + 1) < p := hn
      have h₅ : 2 ^ n < 2 ^ (n + 1) := by
        apply Nat.pow_lt_pow_of_lt_right
        norm_num
        linarith
      linarith
    have h4 : (ZMod.val y + 1) % p < 2 ^ n := by
      have h₅ : ZMod.val y < 2 ^ n := h_val_y_lt
      have h₆ : ZMod.val y + 1 ≤ 2 ^ n := by
        omega
      have h₇ : (ZMod.val y + 1) % p = ZMod.val y + 1 := by
        have h₈ : ZMod.val y + 1 < p := by
          have h₉ : ZMod.val y < p := by
            have h₁₀ : ZMod.val y < 2 ^ n := h_val_y_lt
            have h₁₁ : 2 ^ n < p := by
              have h₁₂ : 2 ^ (n + 1) < p := hn
              have h₁₃ : 2 ^ n < 2 ^ (n + 1) := by
                apply Nat.pow_lt_pow_of_lt_right
                norm_num
                linarith
              linarith
            linarith
          omega
        have h₁₀ : (ZMod.val y + 1) % p = ZMod.val y + 1 := by
