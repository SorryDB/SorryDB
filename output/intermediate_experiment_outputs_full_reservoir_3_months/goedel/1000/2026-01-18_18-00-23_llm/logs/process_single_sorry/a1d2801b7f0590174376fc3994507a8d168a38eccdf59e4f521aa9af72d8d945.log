  have hx' : ZMod.val (x : F p) < 2 ^ n := hx
  have hy' : ZMod.val (y : F p) < 2 ^ n := hy
  have h₂ : ZMod.val (y + 1 : F p) < 2 ^ n := by
    have h₃ : ZMod.val (y : F p) < 2 ^ n := hy'
    have h₄ : ZMod.val (y + 1 : F p) < 2 ^ n := by
      by_contra h
      -- If ZMod.val (y + 1) ≥ 2^n, then ZMod.val (y + 1) = 2^n - 1 + 1 = 2^n
      have h₅ : ZMod.val (y + 1 : F p) ≥ 2 ^ n := by omega
      have h₆ : ZMod.val (y : F p) + 1 ≥ 2 ^ n := by
        have h₇ : ZMod.val (y + 1 : F p) = (ZMod.val (y : F p) + 1) % p := by
          simp [ZMod.val_add, ZMod.val_one]
          <;> omega
        have h₈ : (ZMod.val (y : F p) + 1) % p ≥ 2 ^ n := by
          omega
        have h₉ : (ZMod.val (y : F p) + 1) % p = ZMod.val (y : F p) + 1 := by
          have h₁₀ : ZMod.val (y : F p) + 1 < p := by
            have h₁₁ : ZMod.val (y : F p) < p := by
              apply ZMod.val_lt
            omega
