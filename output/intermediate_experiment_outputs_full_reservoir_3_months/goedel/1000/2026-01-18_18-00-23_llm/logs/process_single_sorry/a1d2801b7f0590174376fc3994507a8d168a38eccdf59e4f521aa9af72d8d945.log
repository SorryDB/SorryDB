def main (n : ℕ) (hn : 2^(n+1) < p) (input : Expression (F p) × Expression (F p)) := do
  let diff := input.1 + (2^n : F p) - input.2
  let bits ← Num2BitstoCircuit (n + 1) hn diff
  let out := 1 - bits[n]
  return (out, out)

