theorem Module.isPseudoIsomorphic_torsion_prod_quotient
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] :
    M ∼ₚᵢₛ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M) := by
  haveI : PseudoIsomorphic A M (Submodule.torsion A M × M ⧸ Submodule.torsion A M) :=
    isPseudoEquiv.mono_right
      (show (0 : End M) ≈ (0 : End (Submodule.torsion A M × M ⧸ Submodule.torsion A M)) by
        apply M.isPseudoEquiv_iff_nonempty_linearEquiv_localizedModule.mpr
        intro p hp
        have h : Subsingleton (LocalizedModule p.1.primeCompl M) := by
          have h₁ := Submodule.torsion_at_prime p.1
          have h₂ : Module.IsTorsion (Localization p.1.primeCompl) (Submodule.torsion A M) :=
            Submodule.torsion_isTorsionLocalization
          have h₃ : Subsingleton (LocalizedModule p.1.primeCompl (Submodule.torsion A M)) :=
            LocalizedModule.subsingleton_of_isTorsion
              (Submodule.torsion_isTorsionLocalization)
          simp_all [Submodule.torsion_isTorsion]
          <;> aesop
        have h' : Subsingleton (LocalizedModule p.1.primeCompl (Submodule.torsion A M × M ⧸ Submodule.torsion A M)) := by
          simp [Subsingleton.prod]
          <;> aesop
        exact ⟨0, by simp⟩)
  exact PseudoIsomorphic.refl.trans
    (PseudoIsomorphic.ofI (by infer_instance))
