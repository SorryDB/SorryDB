    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] :
    M ∼ₚᵢₛ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M) := by
  -- Use the general form of the theorem to obtain the result.
  have h₁ : M ∼ₚᵢₛ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M) := by
    classical
    -- Use the structure theorem of finitely generated torsion modules to get the desired result.
    have h₂ : M ∼ₚᵢₛ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M) := by
      -- Use the fact that the direct product is isomorphic to the module itself.
