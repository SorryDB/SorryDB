theorem Module.isPseudoIsomorphic_torsion_prod_quotient
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] :
    M ∼ₚᵢₛ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M) := by
  have h : Module.IsTorsion A (Submodule.torsion A M) := by
    unfold Module.IsTorsion
    intro x
    exact ⟨x.prop, by simp⟩
  have h₂ : IsPseudoIsomorphism (fun x : M => ⟨x, x⟩ : M →ₗ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M)) :=
    by
    have h₃ : IsPseudoIsomorphism (fun x : M => ⟨x, x⟩ : M →ₗ[A] (Submodule.torsion A M × M ⧸ Submodule.torsion A M)) := by
      apply isPseudoBoundedHom
      <;> simp_all [Submodule.torsion]
      <;>
      (try
        norm_num)
      <;>
      (try
        aesop)
      <;>
      (try
        simp_all [Submodule.torsion])
      <;>
      (try
        aesop)
    exact h₃
  exact by
    -- Use the fact that the map is a pseudo-isomorphism to conclude the proof
    have h₃ := h₂.isPseudoIsomorphic
    -- Simplify the expression to show the required isomorphism
    simp_all [isPseudoIsomorphic]
    <;>
    (try
      aesop)
    <;>
    (try
      simp_all [Submodule.torsion])
    <;>
    (try
      aesop)
