```lean
theorem uniformSelectList_eq_uniformSelectList_cons {α : Type} [hα : OracleComp.SampleableType α] (n : ℕ) :
  $(List.replicate (n + 1) default) = $! #v[(List.replicate (n + 1) default)] := by
  have h₁ : $(List.replicate (n + 1) default) = $! #v[(List.replicate (n + 1) default)] := by
    cases n with
