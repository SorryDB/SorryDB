@[simp] lemma probEvent_uniformSample [Fintype α] (p : α → Prop) [DecidablePred p] :
    Pr[p | $ᵗ α] = (Finset.univ.filter p).card / Fintype.card α := by
  simp only [probEvent_eq_sum_filter_univ, probOutput_uniformSample, Finset.sum_const,
    nsmul_eq_mul, div_eq_mul_inv]

section instances

instance (α : Type) [Unique α] : SampleableType α where
  selectElem := return default
  mem_support_selectElem x := Unique.eq_default x ▸ (by simp)
  probOutput_selectElem_eq x y := by rw [Unique.eq_default x, Unique.eq_default y]
  probFailure_selectElem := by simp

instance : SampleableType Bool where
  selectElem := $! #v[true, false]
  mem_support_selectElem x := by
    fin_cases x <;> simp [hasUniformSelectList]
    <;> aesop

  probOutput_selectElem_eq x y := by
    fin_cases x <;> fin_cases y <;> simp [hasUniformSelectList]
    <;> aesop
  
  probFailure_selectElem := by
    simp [hasUniformSelectList]
    <;> simp_all [Fin.sum_univ_succ, Fin.val_zero, Fin.val_succ]
    <;> norm_num
    <;> aesop

/-- Select a uniform element from `α × β` by independently selecting from `α` and `β`. -/
instance (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    have h₁ : x.1 ∈ support ($ᵗ α) := SampleableType.mem_support_selectElem x.1
    have h₂ : x.2 ∈ support ($ᵗ β) := SampleableType.mem_support_selectElem x.2
    -- Use the fact that the product of supports is in the support of the product
    simp only [support_map, support_prod, h₁, h₂, Set.mem_prod, Set.mem_univ, true_and] at *
    <;>
    aesop

  probOutput_selectElem_eq := by
    have h₁ : ∀ (x y : α × β), Pr[= x | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = Pr[= y | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] := by
      intro x y
      have h₂ : Pr[= x | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = Pr[= x.1 | $ᵗ α] * Pr[= x.2 | $ᵗ β] := by
        simp [probOutput_map, probOutput_map]
        <;>
        rw [← probOutput_product]
        <;>
        simp [probOutput_map]
        <;>
        aesop
      have h₃ : Pr[= y | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = Pr[= y.1 | $ᵗ α] * Pr[= y.2 | $ᵗ β] := by
        simp [probOutput_map, probOutput_map]
        <;>
        rw [← probOutput_product]
        <;>
        simp [probOutput_map]
        <;>
        aesop
      have h₄ : Pr[= x.1 | $ᵗ α] = Pr[= y.1 | $ᵗ α] := by
        apply SampleableType.probOutput_selectElem_eq
      have h₅ : Pr[= x.2 | $ᵗ β] = Pr[= y.2 | $ᵗ β] := by
        apply SampleableType.probOutput_selectElem_eq
      calc
        Pr[= x | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = Pr[= x.1 | $ᵗ α] * Pr[= x.2 | $ᵗ β] := by rw [h₂]
        _ = Pr[= y.1 | $ᵗ α] * Pr[= y.2 | $ᵗ β] := by rw [h₄, h₅]
        _ = Pr[= y | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] := by rw [h₃]
    intro x y
    exact h₁ x y

  probFailure_selectElem := by
    have h₁ : Pr[⊥ | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = 0 := by
      simp [probFailure_map, probFailure_map]
      <;>
      simp [SampleableType.probFailure_selectElem]
      <;>
      aesop
    exact h₁

/-- Nonempty `Fin` types can be selected from, using implicit casting of `Fin (n - 1 + 1)`. -/
instance (n : ℕ) : SampleableType (Fin (n + 1)) where
  selectElem := $[0..n]
  mem_support_selectElem x := by
    simp [Fin.ext_iff]
    <;>
    (try decide)
    <;>
    (try omega)
    <;>
    (try {
      cases n <;> simp_all [Fin.ext_iff]
      <;>
      omega
    })
    <;>
    (try {
      cases n <;> simp_all [Fin.ext_iff]
      <;>
      omega
    })
    <;>
    (try {
      simp_all [Fin.ext_iff]
      <;>
      omega
    })
  
  probOutput_selectElem_eq x y := by
    have h₁ : Pr[= x | $[0..n]] = (1 : ℝ≥0∞) / (n + 1 : ℝ≥0∞) := by
      simp [HasUniformSelectList, probOutput_map, probOutput_fin, card_fin]
      <;>
      norm_cast
      <;>
      field_simp [Nat.cast_add_one_ne_zero]
      <;>
      ring_nf
      <;>
      simp_all
      <;>
      aesop
    have h₂ : Pr[= y | $[0..n]] = (1 : ℝ≥0∞) / (n + 1 : ℝ≥0∞) := by
      simp [HasUniformSelectList, probOutput_map, probOutput_fin, card_fin]
      <;>
      norm_cast
      <;>
      field_simp [Nat.cast_add_one_ne_zero]
      <;>
      ring_nf
      <;>
      simp_all
      <;>
      aesop
    rw [h₁, h₂]
  
  probFailure_selectElem := by
    simp [HasUniformSelectList]
    <;>
    aesop
