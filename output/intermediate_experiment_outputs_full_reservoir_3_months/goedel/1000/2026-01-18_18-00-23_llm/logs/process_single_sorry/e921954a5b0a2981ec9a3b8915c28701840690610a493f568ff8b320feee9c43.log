theorem probFailure_uniformSelectEquiv (k : ℕ) {α : Type} [Inhabited α]
    {F : Type} [Fintype F] [DecidableEq F]
    (f : F → α) (hf : Function.Bijective f) :
    ([$[0..k]] : OptionT ProbComp F).support = {y : F | y ∈ Finset.univ} := by
  have h₁ : (['[0..k]] : OptionT ProbComp F).support = Set.univ := by
    have h₂ : ∀ (y : F), y ∈ (['[0..k]] : OptionT ProbComp F).support := by
      intro y
      have h₃ : y ∈ (['[0..k]] : OptionT ProbComp F).support := by
        -- Prove that each element y in F is in the support
        refine' (OptionT.mem_support_iff.mpr fun h => _)
        simp_all [OptionT.eq_map, Option.eq, Option.get]
        <;>
        (try contradiction) <;>
        (try
          {
            simp_all [Function.Bijective]
            <;>
            (try
              {
                have h₄ := hf.1
                have h₅ := hf.2
                simp_all [h₄, h₅]
                <;>
                (try contradiction) <;>
                (try
                  {
                    aesop
                  })
              })
            <;>
            (try
              {
                have h₄ := hf.1
                have h₅ := hf.2
                simp_all [h₄, h₅]
                <;>
                (try contradiction) <;>
                (try
                  {
                    aesop
                  })
              })
          }) <;>
        (try
          {
            have h₄ := hf.1
            have h₅ := hf.2
            simp_all [h₄, h₅]
            <;>
            (try contradiction) <;>
            (try
              {
                aesop
              })
          }) <;>
        (try
          {
            simp_all [Function.Bijective]
            <;>
            (try
              {
                have h₄ := hf.1
                have h₅ := hf.2
                simp_all [h₄, h₅]
                <;>
                (try contradiction) <;>
                (try
                  {
                    aesop
                  })
              })
          }) <;>
        (try
          {
            simp_all [Function.Bijective]
            <;>
            (try
              {
                have h₄ := hf.1
                have h₅ := hf.2
                simp_all [h₄, h₅]
                <;>
                (try contradiction) <;>
                (try
                  {
                    aesop
                  })
              })
          })
        <;>
        aesop
      exact h₃
    -- Since every element is in the support, the support is the entire set
    have h₃ : (['[0..k]] : OptionT ProbComp F).support = Set.univ := by
      apply Set.eq_univ_of_forall
      intro y
      exact h₂ y
    exact h₃
  -- The support is the entire set, which is the same as {y : F | y ∈ Finset.univ}
  have h₂ : (['[0..k]] : OptionT ProbComp F).support = {y : F | y ∈ Finset.univ} := by
    rw [h₁]
    ext y
    simp [Finset.mem_univ]
    <;>
    (try aesop)
    <;>
    (try simp_all [Function.Bijective])
    <;>
    (try contradiction)
  -- Use the fact that f is a bijection to conclude the proof
  have h₃ : (['[0..k]] : OptionT ProbComp F).support = {y : F | y ∈ Finset.univ} := by
    exact h₂
  exact h₃
