import Mathlib.Algebra.AffineMonoid.Embedding
import Toric.ToricVariety.Defs

/-!
# Affine monoids give rise to toric varieties
-/

suppress_compilation

open Algebra AlgebraicGeometry Scheme CategoryTheory Limits AddMonoidAlgebra AddLocalization
  AffineAddMonoid
open scoped SpecOfNotation

universe u
variable {𝕜 M : Type u} [Field 𝕜] [AddCancelCommMonoid M] [AddMonoid.FG M] [IsAddTorsionFree M]

namespace AffineToricVarietyFromMonoid

noncomputable instance instToricVariety : ToricVariety 𝕜 (Diag Spec(𝕜) M) where
  torus := Diag Spec(𝕜) (GrothendieckAddGroup M)
  modObjTorus := by
    sorry
  torusEmb := by
    sorry
  isOver_torusEmb := by
    sorry
  isOpenImmersion_torusEmb := by
    obtain ⟨s, hsgen⟩ := AddMonoid.FG.fg_top (N := M)
    let x : AddMonoidAlgebra 𝕜 M := ∏ z ∈ s, single z 1
    let alg : Algebra (AddMonoidAlgebra 𝕜 M) (AddMonoidAlgebra 𝕜 (FreeAbelianGroup <| Fin <| Cardinal.toNat (Fintype.card M))) :=
      (AddMonoidAlgebra.mapDomainAlgHom 𝕜 _ (MonoidHom.coeHom _ _)).toAlgebra
    have _ : IsLocalization.Away x (AddMonoidAlgebra 𝕜 (FreeAbelianGroup <| Fin <| Cardinal.toNat (Fintype.card M))) := by
      sorry
    exact .of_isLocalization x (M := AddMonoidAlgebra 𝕜 (FreeAbelianGroup <| Fin <| Cardinal.toNat (Fintype.card M)))
  isDominant_torusEmb := by
    let img := RingHom.range (AddMonoidAlgebra.mapDomainRingHom 𝕜 (MonoidHom.coeHom _ _))
    have img_domain := Subring.instIsDomainSubtypeMem img
    have := (AlgebraicGeometry.affine_isIntegral_iff (CommRingCat.of (AddMonoidAlgebra 𝕜 M)))
    sorry
  torusMul_comp_torusEmb := by
    simp [← Spec.map_comp, ← CommRingCat.ofHom_comp, pullback.condition]
    <;> simp_all [MonoidalCategoryStruct.comp]
    <;> rfl
``` 

