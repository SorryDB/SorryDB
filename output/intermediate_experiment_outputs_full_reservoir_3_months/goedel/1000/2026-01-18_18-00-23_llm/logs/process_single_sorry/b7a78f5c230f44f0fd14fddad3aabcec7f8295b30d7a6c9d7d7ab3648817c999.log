theorem pow_eq_one {R : Type*} [Semiring R] {x : R} {n : ℕ+} : x ^ n = x := by
  have h : x ^ n = x := by
    have h₁ : x ^ n = x := by
      -- Base case: when n = 1, x^1 = x
      cases n with
      | mk n hn =>
        -- Inductive step: assume the statement holds for some n, prove it for n+1
        induction' n with n ih
        · simp_all [pow_one]
        · simp_all [pow_succ, pow_one, mul_assoc]
          <;> ring_nf at *
          <;> simp_all [pow_succ, pow_one, mul_assoc]
    exact h₁
  exact h
```

