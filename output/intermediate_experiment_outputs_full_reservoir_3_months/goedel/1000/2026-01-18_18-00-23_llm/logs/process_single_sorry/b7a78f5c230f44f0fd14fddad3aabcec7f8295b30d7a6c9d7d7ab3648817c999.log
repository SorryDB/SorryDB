  intro x
  have h₀ : x^2 - 1 > 0 ↔ x < -1 ∨ x > 1 := by
    constructor
    · -- Prove the forward direction: if x² - 1 > 0, then x < -1 or x > 1
      intro h
      have h₁ : x^2 > 1 := by linarith
      have h₂ : x < -1 ∨ x > 1 := by
        by_cases h₃ : x ≥ 0
        · -- Case: x ≥ 0
          have h₄ : x > 1 := by
            nlinarith
          exact Or.inr h₄
        · -- Case: x < 0
          have h₄ : x < -1 := by
            nlinarith
          exact Or.inl h₄
      exact h₂
    · -- Prove the reverse direction: if x < -1 or x > 1, then x² - 1 > 0
      intro h
      cases' h with h h
      · -- Case: x < -1
        have h₁ : x^2 > 1 := by
          nlinarith
        linarith
      · -- Case: x > 1
        have h₁ : x^2 > 1 := by
          nlinarith
        linarith
  exact h₀
