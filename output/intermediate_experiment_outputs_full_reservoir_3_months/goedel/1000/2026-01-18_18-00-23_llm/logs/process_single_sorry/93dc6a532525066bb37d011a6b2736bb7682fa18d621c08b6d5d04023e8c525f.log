```lean
def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    have h₁ : f 1 = 1 := by
      exact f.map_one
    have h₂ : g (f 1) = 1 := by
      rw [h₁]
      exact g.map_one
    simpa using h₂
  
  map_mul' := by
    intro x y
    have h₁ : f (x * y) = f x * f y := by
      apply f.map_mul
    have h₂ : g (f (x * y)) = g (f x * f y) := by
      rw [h₁]
    have h₃ : g (f x * f y) = g (f x) * g (f y) := by
      apply g.map_mul
    calc
      (g ∘ f) (x * y) = g (f (x * y)) := rfl
      _ = g (f x * f y) := by rw [h₁]
      _ = g (f x) * g (f y) := by rw [h₃]
      _ = (g ∘ f) x * (g ∘ f) y := by
        simp [Function.comp_apply]
        <;> ring
        <;> simp_all [RingHom.map_mul]
        <;> ring
  
  map_zero' := by
    have h₁ : f 0 = 0 := by
      exact f.map_zero
    have h₂ : g (f 0) = 0 := by
      rw [h₁]
      exact g.map_zero
    simpa using h₂
  
  map_add' := by
    intro x y
    have h₁ : f (x + y) = f x + f y := by
      apply f.map_add
    have h₂ : g (f (x + y)) = g (f x + f y) := by
      rw [h₁]
    have h₃ : g (f x + f y) = g (f x) + g (f y) := by
      apply g.map_add
    calc
      (g ∘ f) (x + y) = g (f (x + y)) := rfl
      _ = g (f x + f y) := by rw [h₁]
      _ = g (f x) + g (f y) := by rw [h₃]
      _ = (g ∘ f) x + (g ∘ f) y := by
        simp [Function.comp_apply]
        <;> ring
        <;> simp_all [RingHom.map_add]
        <;> ring
```  

