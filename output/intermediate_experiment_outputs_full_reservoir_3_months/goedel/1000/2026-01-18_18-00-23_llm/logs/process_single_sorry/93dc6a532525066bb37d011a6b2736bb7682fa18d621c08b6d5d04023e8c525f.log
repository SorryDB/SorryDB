def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    have h : f 1 = 1 := by
      simpa using f.map_one
    have h' : g 1 = 1 := by
      simpa using g.map_one
    calc
      g (f 1) = g 1 := by rw [h]
      _ = 1 := by rw [h']
  map_mul' := by
    intro x y
    have h₁ : f (x * y) = f x * f y := by
      simpa using f.map_mul x y
    have h₂ : g (f (x * y)) = g (f x * f y) := by rw [h₁]
    have h₃ : g (f x * f y) = g (f x) * g (f y) := by
      have h₄ : g (f x * f y) = g (f x) * g (f y) := by
        simpa using g.map_mul (f x) (f y)
      exact h₄
    calc
      g (f (x * y)) = g (f x * f y) := by rw [h₂]
      _ = g (f x) * g (f y) := by rw [h₃]
  map_zero' := by
    have h : f 0 = 0 := by
      simpa using f.map_zero
    have h' : g 0 = 0 := by
      simpa using g.map_zero
    calc
      g (f 0) = g 0 := by rw [h]
      _ = 0 := by rw [h']
  map_add' := by
    intro x y
    have h₁ : f (x + y) = f x + f y := by
      simpa using f.map_add x y
    have h₂ : g (f (x + y)) = g (f x + f y) := by rw [h₁]
    have h₃ : g (f x + f y) = g (f x) + g (f y) := by
      have h₄ : g (f x + f y) = g (f x) + g (f y) := by
        simpa using g.map_add (f x) (f y)
      exact h₄
    calc
      g (f (x + y)) = g (f x + f y) := by rw [h₂]
      _ = g (f x) + g (f y) := by rw [h₃]
