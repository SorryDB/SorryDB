      "\n    have h₂ : t₁.height ≤ t₁.size := ihl\n    have h₃ : t₁.size ≤ t₁.size + t₂.size := by\n      have h₄ : 0 ≤ t₂.size := by exact Nat.zero_le _\n      omega\n    omega\n  have h₂ : t₂.height ≤ t₁.size + t₂.size := by\n    have h₃ : t₂.height ≤ t₂.size := ihr\n    have h₄ : t₂.size ≤ t₁.size + t₂.size := by\n      have h₅ : 0 ≤ t₁.size := by exact Nat.zero_le _\n      omega\n    omega\n  have h₃ : max t₁.height t₂.height ≤ t₁.size + t₂.size := by\n    apply max_le h₁ h₂\n  omega",
