                    <;> simp [pow_succ]
                    <;> ring
                  have h₁₅ : 2 ^ (t₂.height + 1) = 2 * 2 ^ t₂.height := by
                    ring_nf
                    <;> simp [pow_succ]
                    <;> ring
                  rw [h₁₄]
