example {α : Type} (t : Tree α) :
  t.height ≤ t.size ∧ t.size < 2 ^ t.height := by
  apply And.intro
  {
   induction t with
   | null  => simp [Tree.height, Tree.size]
   | node t₁ x t₂ ihl ihr =>
     simp [Tree.height, Tree.size]
     -- Use the fact that max a b ≤ a + b to complete the proof
     have h : max t₁.height t₂.height ≤ t₁.size + t₂.size := by
       -- Prove that max t₁.height t₂.height ≤ t₁.size + t₂.size
       have h₁ : t₁.height ≤ t₁.size := ihl
       have h₂ : t₂.height ≤ t₂.size := ihr
       have h₃ : max t₁.height t₂.height ≤ max t₁.size t₂.size := by
         -- Since t₁.height ≤ t₁.size and t₂.height ≤ t₂.size, their max also satisfies the inequality
         apply max_le
         · exact h₁
         · exact h₂
       -- Since max t₁.size t₂.size ≤ t₁.size + t₂.size, we can conclude the desired inequality
       have h₄ : max t₁.size t₂.size ≤ t₁.size + t₂.size := by
         cases' le_total t₁.size t₂.size with h₅ h₅ <;>
           simp_all [max_eq_right, max_eq_left] <;>
           (try omega) <;>
           (try nlinarith)
       -- Combine the inequalities to get the final result
       calc
         max t₁.height t₂.height ≤ max t₁.size t₂.size := h₃
         _ ≤ t₁.size + t₂.size := h₄
     -- Use the above result to prove the main inequality
     omega
  }
