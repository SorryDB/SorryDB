lemma hasFiniteMeasure_of_subset {s t : MeasurableSet Ω} (h : s ≤ t) (ht : HasFiniteMeasure t) :
    HasFiniteMeasure s := by
  have h₁ : s ≤ t := h
  have h₂ : HasFiniteMeasure t := ht
