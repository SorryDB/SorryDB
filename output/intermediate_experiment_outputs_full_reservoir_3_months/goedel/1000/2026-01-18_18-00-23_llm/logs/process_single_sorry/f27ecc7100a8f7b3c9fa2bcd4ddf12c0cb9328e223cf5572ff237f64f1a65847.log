    calc
      F.map (t ∘ s) = (F.map s).map t := by rw [h₁]
      _ ≤ G.map t := by
        -- Use the fact that F.map s ≤ G
        gcongr
        <;> simp_all [Tendsto]
      _ ≤ H := by
        -- Use the fact that G.map t ≤ H
        simpa [Tendsto] using ht
  -- Conclude the proof using the definition of Tendsto
  exact h₂

