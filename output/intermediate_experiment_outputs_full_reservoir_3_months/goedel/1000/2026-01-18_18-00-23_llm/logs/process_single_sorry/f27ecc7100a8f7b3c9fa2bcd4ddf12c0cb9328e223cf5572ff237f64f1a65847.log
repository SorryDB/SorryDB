      "simp_all [Nat.div_eq_of_lt]) <;>\n  (try norm_num) <;>\n  (try {\n    convert summable_ite_eq 1 (1 : ℝ) using 1\n    <;> simp [pow_two]\n  }) <;>\n  (try {\n    apply Summable.of_nonneg_of_le (fun n => by positivity) (fun n => by\n      simp [GEO]\n      <;>\n      (try cases n <;> simp [Nat.div_eq_of_lt]) <;>\n      (try norm_num) <;>\n      (try {\n        simp_all [Nat.div_eq_of_lt]\n        <;> norm_num\n        <;> simp_all [Nat.div_eq_of_lt]\n      }) <;>\n      (try {\n        field_simp [Nat.cast_eq_zero]\n        <;> ring_nf\n        <;> norm_num\n        <;> simp_all [Nat.div_eq_of_lt]\n      })\n      <;>\n      (try {\n        norm_cast\n        <;> simp_all [Nat.div_eq_of_lt]\n        <;> norm_num\n      })\n    ) (summable_geometric_two)\n  })",
