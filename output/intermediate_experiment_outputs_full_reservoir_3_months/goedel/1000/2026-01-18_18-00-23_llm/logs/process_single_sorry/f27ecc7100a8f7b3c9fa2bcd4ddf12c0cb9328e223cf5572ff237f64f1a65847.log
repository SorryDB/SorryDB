  exact Filter.map_mono h f

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Use the property of composition of functions and filters
  have h₁ : F.map (t ∘ s) = (F.map s).map t := by
    -- Prove that the map of the composition is the composition of the maps
    simp [Function.comp, Filter.map_map]
    <;> rfl
  -- Use the transitivity of the order of filters
