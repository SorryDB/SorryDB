    by_cases h : Real.pi ∈ (⋃ n : ℕ, ‹_› n)
    · -- Case: π is in the union
      have h₁ : ∃ n : ℕ, Real.pi ∈ ‹_› n := by
        -- Since π is in the union, there exists an n such that π is in the n-th set
        simp only [Set.mem_iUnion] at h
        obtain ⟨n, hn⟩ := h
        exact ⟨n, hn⟩
      obtain ⟨n, hn⟩ := h₁
      have h₂ : (1 : ℝ) ≤ ∑' n : ℕ, (if Real.pi ∈ ‹_› n then 1 else 0 : ℝ) := by
        -- The sum is at least 1 because π is in the n-th set
