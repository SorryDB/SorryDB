          (1 : ℝ) = (if Real.pi ∈ ‹_› n then 1 else 0 : ℝ) := by
            simp [hn]
          _ ≤ ∑' n : ℕ, (if Real.pi ∈ ‹_› n then 1 else 0 : ℝ) := by
            -- The term for n is included in the sum
            have h₃ : (if Real.pi ∈ ‹_› n then 1 else 0 : ℝ) ≤ ∑' n : ℕ, (if Real.pi ∈ ‹_› n then 1 else 0 : ℝ) := by
              apply le_tsum
              · intro i
                exact by positivity
              · simp [hn]
            exact h₃
      simp_all
      <;> norm_num at * <;> simp_all [h]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try aesop)
    · -- Case: π is not in the union
      have h₁ : Real.pi ∉ (⋃ n : ℕ, ‹_› n) := h
