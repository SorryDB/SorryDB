/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := by
    intro s
    by_cases h : (Real.pi : ℝ) ∈ s
    · exact 1
    · exact 0
  empty := by
    norm_num
    <;> simp [Set.not_mem_empty]
  mono {S T} hST := by
    by_cases hS : (Real.pi : ℝ) ∈ S
    · -- Case: π ∈ S
      have hT : (Real.pi : ℝ) ∈ T := by
        -- Since S ⊆ T and π ∈ S, we have π ∈ T
        exact hST hS
      -- Both S and T contain π, so their measures are 1
      simp [hS, hT]
    · -- Case: π ∉ S
      by_cases hT : (Real.pi : ℝ) ∈ T
      · -- Subcase: π ∈ T
        -- S does not contain π, but T does, so measureOf S = 0 ≤ 1 = measureOf T
        simp [hS, hT]
