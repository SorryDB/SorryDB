```lean
noncomputable section

namespace ItaLean

section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact h.map f

def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  calc
    (t ∘ s) = fun x => t (s x) := rfl
    F.map (t ∘ s) = F.map (fun x => t (s x)) := rfl
    F.map (fun x => t (s x)) = (F.map s).map t := by
      simp [map_map]
    _ ≤ G.map t := by
      -- Since Tendsto s F G, we have F.map s ≤ G, and we apply the monotonicity of |>.map t
      exact hs.map t
    _ ≤ H := ht

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := by
    have h1 : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
    have h2 : Tendsto g (𝓝 Real.pi) atTop := hg
    exact Tendsto_comp h1 h2
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
