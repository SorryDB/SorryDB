noncomputable section

namespace ItaLean

section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  -- Since `F ≤ G`, for any set `s ∈ G`, we have `s ∈ F`.
  -- The `map` operation applies `f` to each set in the filter.
  -- Therefore, if `s ∈ G`, then `f ⁻¹' s ∈ F`, which implies `f ⁻¹' s ∈ G`.
  -- This gives us the desired inclusion `F.map f ≤ G.map f`.
  exact h.map f

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  -- Use the fact that the composition of functions corresponds to the composition of their maps.
  have h : (F.map s).map t ≤ H := by
    -- Since `hs : F.map s ≤ G`, and `ht : G.map t ≤ H`, we can compose these inequalities.
    calc
      (F.map s).map t = F.map (t ∘ s) := by
        -- The map of the composition is the composition of the maps.
        simp [Function.comp, map_map]
      _ ≤ G.map t := by
        -- Since `F.map s ≤ G`, we can use the fact that `map t` is monotone.
        exact hs.map t
      _ ≤ H := ht
  -- The result follows by the definition of `Tendsto`.
  simpa [Function.comp] using h

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  -- Use the composition lemma to combine the two tendsto statements.
  exact Tendsto_comp hf hg

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  -- Use the composition lemma to combine the two tendsto statements.
  exact Tendsto_comp ha hφ

/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : {x | p x} ∩ {x | q x} ∈ 𝓝 x := by
    -- The intersection of two neighborhoods is a neighborhood.
    have h1 : {x | p x} ∈ 𝓝 x := hT
    have h2 : {x | q x} ∈ 𝓝 x := hS
    exact h1.inter h2
  have h2 : {x | p' x} ∩ {x | q' x} ∈ 𝓝 x := by
    -- The intersection of two neighborhoods is a neighborhood.
    have h1 : {x | p' x} ∈ 𝓝 x := hT'
    have h2 : {x | q' x} ∈ 𝓝 x := hS'
    exact h1.inter h2
  -- The union of two neighborhoods is a neighborhood.
  have h3 : ({x | p x} ∩ {x | q x}) ∪ ({x | p' x} ∩ {x | q' x}) ∈ 𝓝 x := by
    exact h1.union h2
  -- The set {x | p x ∧ q x ∨ p' x ∧ q' x} is equal to the union of the two intersections.
  have h4 : {x | p x ∧ q x ∨ p' x ∧ q' x} = ({x | p x} ∩ {x | q x}) ∪ ({x | p' x} ∩ {x | q' x}) := by
    ext x
    simp [and_comm]
    <;>
    (try tauto) <;>
    (try
      {
        by_cases h : p x <;> by_cases h' : q x <;> by_cases h'' : p' x <;> by_cases h''' : q' x <;> simp_all [h, h', h'', h''']
        <;> tauto
      })
    <;>
    (try tauto)
  -- Since the union of the two intersections is a neighborhood, the set {x | p x ∧ q x ∨ p' x ∧ q' x} is a neighborhood.
  rw [h4]
  exact h3

end Filter

