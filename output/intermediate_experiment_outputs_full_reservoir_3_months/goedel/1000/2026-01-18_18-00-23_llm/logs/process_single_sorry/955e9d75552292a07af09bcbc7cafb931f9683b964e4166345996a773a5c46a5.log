        (try norm_num) <;>
        (try linarith)
      · -- Subcase: π ∉ T
        -- Both S and T do not contain π, so their measures are 0
        simp [hS, hT]
        <;>
        (try omega) <;>
        (try norm_num) <;>
        (try linarith)

