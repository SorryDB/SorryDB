    calc
      Filter.map t (Filter.map s F) ≤ Filter.map t G := by
        apply Filter.map_mono
        exact h₁
      _ ≤ H := h₂
  calc
    Filter.map (t ∘ s) F ≤ Filter.map t (Filter.map s F) := h₃
    _ ≤ H := h₄

