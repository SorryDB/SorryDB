def μD : OuterMeasure ℝ where
  measureOf := by
    intro s
    if h : Real.pi ∈ s then 1 else 0
  empty := by
    simp [Set.not_mem_empty]
    <;> norm_num
  mono {S T} hST := by
    by_cases h : Real.pi ∈ T
    · -- Case: π ∈ T
      by_cases h' : Real.pi ∈ S
      · -- Subcase: π ∈ S
        simp [h, h']
      · -- Subcase: π ∉ S
        have h₁ : Real.pi ∈ (T : Set ℝ) := h
        have h₂ : Real.pi ∉ (S : Set ℝ) := h'
        simp_all [h₁, h₂]
