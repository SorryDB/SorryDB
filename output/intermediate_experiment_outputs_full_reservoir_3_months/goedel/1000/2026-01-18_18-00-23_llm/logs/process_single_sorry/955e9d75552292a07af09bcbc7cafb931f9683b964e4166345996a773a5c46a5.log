def μD : OuterMeasure ℝ where
  measureOf := by
    intro S
    if h : (∃ x : ℝ, S = {x}) then
      1
    else
      0
  empty := by
    simp [measureOf]
    <;> aesop
  mono {S T} hST := by
    by_cases hS : ∃ x : ℝ, S = {x}
    · by_cases hT : ∃ x : ℝ, T = {x}
      · -- Case: Both S and T are singletons
        simp_all [measureOf]
        <;>
        (try { aesop }) <;>
        (try {
          obtain ⟨x, hx⟩ := hS
          obtain ⟨y, hy⟩ := hT
          have h₁ : S ⊆ T := hST
          have h₂ : S = {x} := hx
          have h₃ : T = {y} := hy
          rw [h₂, h₃] at h₁
          have h₄ : ({x} : Set ℝ) ⊆ ({y} : Set ℝ) := h₁
          have h₅ : x = y := by
            have h₆ : x ∈ ({x} : Set ℝ) := by simp
            have h₇ : x ∈ ({y} : Set ℝ) := h₄ h₆
            simpa using h₇
          simp [h₅]
        }) <;>
        (try { contradiction }) <;>
        (try { simp_all })
      · -- Case: S is a singleton, T is not
        simp_all [measureOf]
        <;> aesop
    · by_cases hT : ∃ x : ℝ, T = {x}
      · -- Case: S is not a singleton, T is a singleton
        simp_all [measureOf]
        <;> aesop
      · -- Case: Neither S nor T are singletons
        simp_all [measureOf]
        <;> aesop
