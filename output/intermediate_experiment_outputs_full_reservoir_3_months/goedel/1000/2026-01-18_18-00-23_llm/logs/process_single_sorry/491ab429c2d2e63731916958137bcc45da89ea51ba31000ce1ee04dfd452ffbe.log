variable {R} [CommRing R]

example (I : Ideal R) (x y : R) (hx : x Ôłł I) : y * x + x * y - 0 Ôłł I := by
  have hÔéü : y * x Ôłł I := Ideal.mul_mem_right I hx y
  have hÔéé : x * y Ôłł I := Ideal.mul_mem_left I hx y
  have hÔéâ : y * x + x * y Ôłł I := Ideal.add_mem I hÔéü hÔéé
  have hÔéä : (0 : R) Ôłł I := Ideal.zero_mem I
  have hÔéů : y * x + x * y - 0 Ôłł I := by
