theorem Φ₅_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₅ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₅_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  have h : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by
    -- Use the fact that Φ₅ is continuous on [0,1] and the interval is bounded
    have h₁ : ContinuousOn (Φ₅ r) (Icc 0 1) := Φ₅_contDiffOn.continuousOn.mono (by
      -- Prove that Ioc 0 1 is a subset of Icc 0 1
      intro x hx
      simp only [Ioc, Icc, Set.mem_setOf_eq] at hx ⊢
      constructor <;> (try norm_num) <;> (try linarith) <;> (try assumption) <;> (try nlinarith))
    -- Apply the theorem that a continuous function on a bounded interval has a finite integral
    have h₂ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Icc 0 1)) :=
      (hasFiniteIntegral_of_continuousOn (h₁) (by
        -- Prove that the volume of Icc 0 1 is finite
        exact isCompact_Icc.measurableSet.finite_volume))
    -- Use the fact that the integral over Ioc 0 1 is a subset of Icc 0 1
    have h₃ : HasFiniteIntegral (Φ₅ r) (volume.restrict (Ioc 0 1)) := by
      have h₄ : volume.restrict (Ioc 0 1) ≤ volume.restrict (Icc 0 1) := by
        -- Prove that the measure of Ioc 0 1 is less than or equal to the measure of Icc 0 1
        apply Measure.restrict_le_restrict
        · -- Prove that Ioc 0 1 is a subset of Icc 0 1
          intro x hx
          simp only [Ioc, Icc, Set.mem_setOf_eq] at hx ⊢
          constructor <;> (try norm_num) <;> (try linarith) <;> (try assumption) <;> (try nlinarith)
        · -- Prove that the volume is non-negative
          exact by positivity
      -- Use the fact that the integral is monotone with respect to the measure
      exact h₂.mono_measure h₄
    -- Conclude the proof
    exact h₃
  -- Use the fact that a function with a finite integral is integrable
  simpa [hasFiniteIntegral_iff_integrable] using h
