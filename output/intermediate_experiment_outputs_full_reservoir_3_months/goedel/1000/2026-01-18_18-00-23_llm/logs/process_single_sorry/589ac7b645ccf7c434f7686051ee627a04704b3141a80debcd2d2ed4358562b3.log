        <;>
        aesop
      -- Use the fact that each edge has 2 vertices to conclude the sum
      simp_all [h₁]
      <;>
      aesop
    )
  <;>
  simp_all [Finset.sum_const, nsmul_eq_mul, mul_comm]
  <;>
  try ring
  <;>
  try norm_num
  <;>
  try linarith
