      have h₁ : {v | v ∈ e}.card = 2 := by
        -- Prove that each edge has exactly 2 vertices
        have h₂ : e.val.card = 2 := by
          simp [Sym2.card]
        -- The set {v | v ∈ e} has the same cardinality as e.val
        simp_all [Set.card_eq_two]
        <;>
        (try decide) <;>
        (try {
          have h₃ := e.val.2
          simp_all [Finset.card_insert_of_not_mem, Finset.mem_singleton]
          <;>
          aesop
