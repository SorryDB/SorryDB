    _ = ∑ e ∈ E, #{v | v ∈ e}  := by
      classical
      calc
        _ = ∑ v : α, #{e ∈ E | v ∈ e} := by rfl
        _ = ∑ v : α, ∑ e ∈ E, if v ∈ e then 1 else 0 := by
          apply Finset.sum_congr rfl
          intro v _
          calc
            #{e ∈ E | v ∈ e} = (Finset.filter (fun e => v ∈ e) E).card := by
              simp [Set.ext_iff]
              <;> aesop
            _ = ∑ e ∈ E, if v ∈ e then 1 else 0 := by
              simp [Finset.sum_ite, Finset.filter_eq']
              <;> simp_all [Finset.mem_filter]
              <;> aesop
        _ = ∑ e ∈ E, ∑ v : α, if v ∈ e then 1 else 0 := by
          rw [Finset.sum_comm]
        _ = ∑ e ∈ E, #{v | v ∈ e} := by
          apply Finset.sum_congr rfl
          intro e _
          calc
            ∑ v : α, if v ∈ e then 1 else 0 = ∑ v : α, if v ∈ ({e} : Set (Sym2 α)) then 1 else 0 := by
              simp [Sym2.mem_coe]
              <;> aesop
            _ = #{v : α | v ∈ ({e} : Set (Sym2 α))} := by
              simp [Set.ext_iff]
              <;> aesop
            _ = #{v | v ∈ e} := by
              simp [Set.ext_iff]
              <;> aesop
    _ = ∑ e ∈ E, 2             := by
      apply Finset.sum_congr rfl
      intro e he
      have : ({v : α | v ∈ (e : Sym2 α)} : Set α).card = 2 := by
        simp [Sym2.mem_coe, Finset.card_insert_of_not_mem, Finset.mem_singleton]
