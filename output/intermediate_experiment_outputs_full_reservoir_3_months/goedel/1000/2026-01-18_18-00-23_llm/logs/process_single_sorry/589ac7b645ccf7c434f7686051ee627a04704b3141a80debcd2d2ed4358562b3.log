lemma handshaking : ∑ v, d(v) = 2 * #E := by
  calc  ∑ v, d(v)
    _ = ∑ v, #I(v)             := by simp [G.card_incidenceFinset_eq_degree]
    _ = ∑ v, #{e ∈ E | v ∈ e}  := by simp [G.incidenceFinset_eq_filter]
    _ = ∑ e ∈ E, #{v | v ∈ e}  := Finset.sum_card_bipartiteAbove_eq_sum_card_bipartiteBelow _
    _ = ∑ e ∈ E, 2             := Finset.sum_congr rfl (λ e he ↦
      have h : {v | v ∈ e}.card = 2 := by
        have h₁ : e.val.1 ≠ e.val.2 := by
          -- Prove that the two elements in the symmetric pair are distinct
          have h₂ : ¬G.Adj e.val.1 e.val.2 → e.val.1 = e.val.2 := by
            simp_all [Sym2, SimpleGraph, irrefl]
            <;> aesop
          simp_all [Sym2, SimpleGraph, irrefl]
          <;> aesop
        -- Since e is a symmetric pair, {v | v ∈ e} has exactly two elements
        have h₂ : {v | v ∈ e}.card = 2 := by
          simp [Set.toFinset_card, Finset.card_insert_of_not_mem, Finset.mem_singleton, h₁]
          <;>
          (try decide) <;>
          (try
            {
              cases e with
              | mk x y hxy =>
                simp_all [Sym2, Finset.card_insert_of_not_mem, Finset.mem_singleton]
                <;> aesop
            }) <;>
          (try
            {
              simp_all [Sym2, Finset.card_insert_of_not_mem, Finset.mem_singleton]
              <;> aesop
            })
        exact h₂
      simp [h])
  <;>
  try simp_all [SimpleGraph, Finset.card_insert_of_not_mem, Finset.mem_singleton]
  <;>
  try aesop
  <;>
  try decide
