lemma handshaking : ∑ v, d(v) = 2 * #E := by
  calc  ∑ v, d(v)
    _ = ∑ v, #I(v)             := by simp [G.card_incidenceFinset_eq_degree]
    _ = ∑ v, #{e ∈ E | v ∈ e}  := by simp [G.incidenceFinset_eq_filter]
    _ = ∑ e ∈ E, #{v | v ∈ e}  := Finset.sum_card_bipartiteAbove_eq_sum_card_bipartiteBelow _
    _ = ∑ e ∈ E, 2             := Finset.sum_congr rfl (λ e he ↦ by
      have h₁ : {v | v ∈ e}.card = 2 := by
        -- Since e is an edge in a simple graph, it must have exactly two distinct endpoints.
        -- This means the set {v | v ∈ e} has exactly two elements.
        have h₂ : ∀ (x : α), x ∈ ({v | v ∈ e} : Set α) ↔ x = e.1 ∨ x = e.2 := by
          intro x
          simp [Finset.mem_coe, Sym2.mem_setOf_eq, Finset.mem_insert, Finset.mem_singleton]
          <;>
          aesop
        have h₃ : {v | v ∈ e} = {e.1, e.2} := by
          ext x
          rw [h₂]
          <;> simp [Finset.mem_insert, Finset.mem_singleton]
          <;>
          aesop
        rw [h₃]
        -- The set {e.1, e.2} has exactly two elements unless e.1 = e.2.
        -- But since e is an edge in a simple graph, e.1 ≠ e.2.
        have h₄ : e.1 ≠ e.2 := by
          have h₅ : e.1 ≠ e.2 := by
            intro h₆
            simp_all [Sym2.ext_iff]
            <;>
            aesop
          exact h₅
        simp [h₄]
        <;>
        aesop
      -- Therefore, the cardinality of {v | v ∈ e} is 2.
      simpa using h₁)
