            -- Use the fact that G is a group of automorphisms of K
            exact (IsGaloisGroup.friendly σ).1
          exact h₃
        exact h₂
      exact h₁
    -- Use the fact that the group G is faithful on K to deduce faithful action on 𝒪[K]
    exact
      (IsGaloisGroup.friendly (1 : G)).2 fun σ hσ => by
