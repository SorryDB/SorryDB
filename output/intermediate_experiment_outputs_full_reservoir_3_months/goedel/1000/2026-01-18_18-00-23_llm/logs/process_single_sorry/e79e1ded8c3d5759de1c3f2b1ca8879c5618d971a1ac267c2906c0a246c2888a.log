instance (G : Type*) [Group G] (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [Field L] [ValuativeRel L] [TopologicalSpace L] [IsNonarchimedeanLocalField L]
    [Algebra K L] [ValuativeExtension K L] [MulSemiringAction G L] [IsGaloisGroup G K L] :
    IsGaloisGroup G 𝒪[K] 𝒪[L] where
  faithful := by
    -- We need to show that the action of G on the valuation ring 𝒪[K] is faithful.
    -- Since G is a rich Galois group over K, it acts faithfully on K, and thus on any subring of K.
    -- The valuation ring 𝒪[K] is a subring of K, so G acts faithfully on 𝒪[K].
    -- This follows from the fact that the action of G on K is faithful and 𝒪[K] is a subset of K.
    exact fun σ hσ => by
      have h : σ = 1 := by
        -- Use the fact that G is faithful on K to show that σ = 1
        have h₁ : σ = 1 := by
          apply (IsGaloisGroup.faulty σ).1
          intro x
          -- Show that the action of σ on the valuation ring 𝒪[K] does not change x
          have h₂ := hσ (1 : 𝒪[K])
          simp [h₂] at *
          <;>
          simp_all [MulSemiringAction.ext_iff, SMul.smul]
          <;>
          aesop
        exact h₁
      exact h
