def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    -- g(f(1_R)) = g(1_S) = 1_T
    simp [RingHom.map_one]
  map_mul' := by
    -- g(f(x * y)) = g(f(x) * f(y)) = g(f(x)) * g(f(y))
    intro x y
    simp [RingHom.map_mul, g.map_mul]
  map_zero' := by
    -- g(f(0_R)) = g(0_S) = 0_T
    simp [RingHom.map_zero]
  map_add' := by
    -- g(f(x + y)) = g(f(x) + f(y)) = g(f(x)) + g(f(y))
    intro x y
    simp [RingHom.map_add, g.map_add]
```

