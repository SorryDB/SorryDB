example (I : Ideal R) (x y : R) (hx : x ∈ I) : y * x + x * y - 0 ∈ I := by
  have h1 : y * x ∈ I := I.mul_mem_right x hx y
  have h2 : x * y ∈ I := I.mul_mem_left x hx y
  have h3 : y * x + x * y ∈ I := I.add_mem h1 h2
  have h4 : y * x + x * y - 0 ∈ I := by
    simpa using h3
  exact h4

example {S} [CommRing S] (f : R →+* S) (x : R) : x ∈ ker f ↔ f x = 0 := by
  rw [mem_ker]

def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro x hx y hy
    -- Prove that the sum of two elements in the intersection is also in the intersection.
    have hx' : x ∈ I := hx.1
    have hy' : y ∈ I := hy.1
    have hx'' : x ∈ J := hx.2
    have hy'' : y ∈ J := hy.2
    -- Since I and J are ideals, they are closed under addition.
    have h1 : x + y ∈ I := I.add_mem hx' hy'
    have h2 : x + y ∈ J := J.add_mem hx'' hy''
    -- Therefore, x + y is in the intersection.
    exact ⟨h1, h2⟩
  zero_mem' := by
    -- Since `I` and `J` are ideals, they contain `0`.
    -- Therefore, `0` is in their intersection.
    exact ⟨I.zero_mem, J.zero_mem⟩
  mul_mem' := by
    intro x hx y
    -- Prove that for any x in the intersection and any y in R, x * y is in the intersection.
    have hx' : x ∈ I := hx.1
    have hx'' : x ∈ J := hx.2
    -- Since I and J are ideals, they are closed under multiplication by any element of R.
    have h1 : x * y ∈ I := I.mul_mem_left x hx' y
    have h2 : x * y ∈ J := J.mul_mem_left x hx'' y
    -- Therefore, x * y is in the intersection.
