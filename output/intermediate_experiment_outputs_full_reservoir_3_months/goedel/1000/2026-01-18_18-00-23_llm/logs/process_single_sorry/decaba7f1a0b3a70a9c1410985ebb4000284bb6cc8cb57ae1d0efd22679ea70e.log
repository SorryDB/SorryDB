def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro x hx y hy
    -- Since I and J are ideals, they are closed under addition
    -- x and y are in both I and J, so their sum is also in both I and J
    have h₁ : x + y ∈ I := I.add_mem hx.1 hy.1
    have h₂ : x + y ∈ J := J.add_mem hx.2 hy.2
    exact ⟨h₁, h₂⟩
  -- To show that 0 is in the intersection, we need to show it's in both I and J
  -- Because I and J are ideals, 0 is in both, so it's also in the intersection
  zero_mem' := by
    have h₃ : (0 : R) ∈ I := I.zero_mem
    have h₄ : (0 : R) ∈ J := J.zero_mem
    exact ⟨h₃, h₄⟩
```
