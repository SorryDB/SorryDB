import GlimpseOfLean.Library.Ring

setup
open PiNotation BigOperators Function Classical
noncomputable section

namespace GlimpseOfLean

example {R : Type*} [CommRing R] (x y z : R) :
    x * (y + z) + y * (z + x) + z * (x + y) = 2 * x * y + 2 * y * z + 2 * x * z := by
  ring

section homomorphisms
variable {R S : Type*} [CommRing R] [CommRing S]

example (f : R →+* S) (x y : R) :
    f (1 + x * y) + f 0 = 1 + f x * f y := by
  simp [map_one, map_mul, map_zero, add_assoc]
  <;> ring_nf
  <;> simp_all [add_assoc]
  <;> linarith

variable {T : Type*} [CommRing T]

def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    simp [RingHom.map_one]
  map_mul' := by
    intro x y
    simp [RingHom.map_mul]
    <;> ring_nf
    <;> simp_all [RingHom.map_mul]
    <;> linarith
  map_zero' := by
    simp [RingHom.map_zero]
  map_add' := by
    intro x y
    simp [RingHom.map_add]
    <;> ring_nf
    <;> simp_all [RingHom.map_add]
    <;> linarith

def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [RingEquiv.apply_symm_apply]
  right_inv := by
    intro x
    simp [RingEquiv.apply_symm_apply]
  map_add' := by
    intro x y
    simp [RingEquiv.map_add]
  map_mul' := by
    intro x y
    simp [RingEquiv.map_mul]

end homomorphisms

