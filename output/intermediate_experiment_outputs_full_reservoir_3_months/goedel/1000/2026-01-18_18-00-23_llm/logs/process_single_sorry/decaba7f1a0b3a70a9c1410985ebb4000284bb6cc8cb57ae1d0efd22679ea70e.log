    <;>
    simp_all [RingEquiv.apply_symm_apply]
  map_add' := by
    intro x y
    simp [RingEquiv.map_add, f.map_add, g.map_add]
  map_mul' := by
    intro x y
    simp [RingEquiv.map_mul, f.map_mul, g.map_mul]
```

