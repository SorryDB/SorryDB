example {R : Type*} [CommRing R] (x y z : R) :
    x * (y + z) + y * (z + x) + z * (x + y) = 2 * x * y + 2 * y * z + 2 * x * z := by
  ring

section homomorphisms
variable {R S : Type*} [CommRing R] [CommRing S]

example (f : R →+* S) (x y : R) :
    f (1 + x * y) + f 0 = 1 + f x * f y := by
  simp [map_one, map_mul, map_zero, map_add]
  <;> ring_nf
  <;> simp_all
  <;> ring_nf
  <;> simp_all

variable {T : Type*} [CommRing T]

def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    simp [map_one]
  map_mul' := by
    intro x y
    simp [map_mul]
    <;>
    simp_all [RingHom.map_mul]
  map_zero' := by
    simp [map_zero]
  map_add' := by
    intro x y
    simp [map_add]
    <;>
    simp_all [RingHom.map_add]

def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    calc
      (g ∘ f).symm ((g ∘ f) x) = (g.symm ∘ g) (f x) := by
        simp [Function.comp_apply, RingEquiv.symm_apply_apply]
      _ = f x := by
        simp [RingEquiv.symm_apply_apply]
      _ = x := by
        have h : f.symm (f x) = x := by
          apply Equiv.symm_apply_apply
        simp_all [Function.comp_apply, RingEquiv.symm_apply_apply]
        <;>
        simp_all [Equiv.symm_apply_apply]
        <;>
        aesop
  right_inv := by
    intro x
    calc
      (g ∘ f) ((g ∘ f).symm x) = (g ∘ f) (f.symm (g.symm x)) := by
        rfl
      _ = g (f (f.symm (g.symm x))) := by
        rfl
      _ = g (g.symm x) := by
        have h : f (f.symm (g.symm x)) = g.symm x := by
          apply Equiv.apply_symm_apply
        rw [h]
      _ = x := by
        apply RingEquiv.apply_symm_apply
  map_add' := by
    intro x y
    simp [RingEquiv.map_add]
    <;>
    simp_all [RingHom.map_add]
  map_mul' := by
    intro x y
    simp [RingEquiv.map_mul]
    <;>
    simp_all [RingHom.map_mul]

end homomorphisms

