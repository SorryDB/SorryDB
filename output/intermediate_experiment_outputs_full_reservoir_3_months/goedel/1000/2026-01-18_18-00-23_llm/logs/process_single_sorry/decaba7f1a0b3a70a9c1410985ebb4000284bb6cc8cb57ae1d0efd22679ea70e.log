setup
open PiNotation BigOperators Function Classical
noncomputable section

namespace GlimpseOfLean

example {R : Type*} [CommRing R] (x y z : R) :
    x * (y + z) + y * (z + x) + z * (x + y) = 2 * x * y + 2 * y * z + 2 * x * z := by
  ring

section homomorphisms
variable {R S : Type*} [CommRing R] [CommRing S]

example (f : R →+* S) (x y : R) :
    f (1 + x * y) + f 0 = 1 + f x * f y := by
  simp [map_add, map_one, map_mul, map_zero, add_mul]
  <;> ring_nf
  <;> simp_all [mul_comm]
  <;> ring_nf
  <;> norm_num
  <;> simp_all [mul_comm]

variable {T : Type*} [CommRing T]

def RingHom.comp (g : S →+* T) (f : R →+* S) : R →+* T where
  toFun x := g (f x)
  map_one' := by
    simp [map_one]
  map_mul' := by
    intro x y
    simp [map_mul]
    <;> simp_all [map_mul]
  map_zero' := by
    simp [map_zero]
  map_add' := by
    intro x y
    simp [map_add]
    <;> simp_all [map_add]

def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    intro x
    simp [RingEquiv.apply_symm_apply]
    <;> simp_all [RingEquiv.apply_symm_apply]
    <;> ring_nf
  right_inv := by
    intro x
    simp [RingEquiv.apply_symm_apply]
    <;> simp_all [RingEquiv.apply_symm_apply]
    <;> ring_nf
  map_add' := by
    intro x y
    simp [RingEquiv.map_add]
    <;> simp_all [RingEquiv.map_add]
    <;> ring_nf
  map_mul' := by
    intro x y
    simp [RingEquiv.map_mul]
    <;> simp_all [RingEquiv.map_mul]
    <;> ring_nf

end homomorphisms

example (I : Ideal R) (x y : R) (hx : x ∈ I) : y * x + x * y - 0 ∈ I := by
  have h1 : y * x ∈ I := I.mul_mem_right y hx
  have h2 : x * y ∈ I := I.mul_mem_left y hx
  have h3 : y * x + x * y ∈ I := I.add_mem h1 h2
  have h4 : y * x + x * y - 0 ∈ I := by
