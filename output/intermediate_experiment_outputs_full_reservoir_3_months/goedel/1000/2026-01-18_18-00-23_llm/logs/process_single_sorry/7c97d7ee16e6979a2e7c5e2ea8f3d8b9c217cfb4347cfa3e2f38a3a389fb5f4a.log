-- 10.
lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  ext s
  have h₁ : (image g) ∘ (image f) s = image g (image f s) := rfl
  rw [h₁]
  have h₂ : image f s = image f s := rfl
  rw [h₂]
  have h₃ : image g (image f s) = s := by
    apply Set.ext
    intro x
    simp only [Set.mem_image, Set.mem_setOf_eq]
    constructor
    · rintro ⟨y, hy, rfl⟩
      have h₄ : ∃ z, z ∈ s ∧ f z = y := by
        have h₅ : y ∈ image f s := hy
        simpa [Set.mem_image] using h₅
      obtain ⟨z, hz, hz'⟩ := h₄
      have h₆ : g (f z) = z := by
        have h₇ : g ∘ f = id := h
        have h₈ : (g ∘ f) z = z := by
          rw [h₇]
          <;> simp
        simp [Function.comp_apply] at h₈ ⊢
        exact h₈
      have h₉ : g y = z := by
        rw [hz'] at *
        exact h₆
      exact ⟨z, hz, by simp [h₉]⟩
    · rintro ⟨y, hy, rfl⟩
      have h₄ : f y ∈ image f s := by
        apply Set.mem_image_of_mem
        exact hy
      refine' ⟨f y, h₄, _⟩
      have h₅ : g (f y) = y := by
        have h₆ : g ∘ f = id := h
        have h₇ : (g ∘ f) y = y := by
          rw [h₆]
          <;> simp
        simp [Function.comp_apply] at h₇ ⊢
        exact h₇
      simp [h₅]
  rw [h₃]
