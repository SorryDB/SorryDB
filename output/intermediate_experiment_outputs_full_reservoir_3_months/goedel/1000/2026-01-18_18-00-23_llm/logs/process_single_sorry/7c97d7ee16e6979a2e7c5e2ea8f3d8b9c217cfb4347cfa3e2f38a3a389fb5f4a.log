lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  ext x
  simp [Function.funext_iff] at h ⊢
  have h₁ : ∀ x : U, g (f x) = x := by
    intro x
    have h₂ := congr_fun h x
    simpa [Function.comp_apply] using h₂
  ext s
  simp only [Function.comp_apply, image_image]
  <;>
  (try simp_all) <;>
  (try ext x <;> simp_all [Set.mem_image, Set.mem_preimage]) <;>
  (try aesop) <;>
  (try
    {
      have h₃ : ∀ x : U, g (f x) = x := h₁
      have h₄ : ∀ (y : V), ∃ (x : U), f x = y := by
        intro y
        have h₅ : ∀ x : U, g (f x) = x := h₁
        have h₆ : g y ∈ ({x : U | ∃ (a : U), f a = y} : Set U) := by
          use g y
          have h₇ := h₅ (g y)
          have h₈ : f (g y) = y := by
            have h₉ := h₇
            simp_all [Function.comp_apply]
