theorem image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  funext s
  have h₁ : (g ∘ f) = id := h
  have h₂ : image g (image f s) = s := by
    calc
      image g (image f s) = image (g ∘ f) s := by
        rw [image_comp]
      _ = image id s := by rw [h₁]
      _ = s := by simp
  rw [h₂]
  <;> simp [Function.funext_iff]
  <;> aesop
