theorem Φ₁_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₁ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₁_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  have h : HasFiniteIntegral (Φ₁ r) (volume.restrict (Ioc (0 : ℝ) 1)) := by
    -- Prove that the integral of Φ₁ r over (0, 1] is finite.
    have h₁ : ContinuousOn (Φ₁ r : ℝ → ℝ) (Set.Icc 0 1) := Φ₁_contDiffOn.continuousOn.mono (Set.Icc_subset_Icc_left (by norm_num))
    have h₂ : ∫ (x : ℝ) in Ioc (0 : ℝ) 1, (Φ₁ r x : ℝ) = ∫ (x : ℝ) in Ioc (0 : ℝ) 1, (Φ₁ r x : ℝ) := rfl
    have h₃ : HasFiniteIntegral (Φ₁ r : ℝ → ℝ) (volume.restrict (Ioc (0 : ℝ) 1)) := by
      -- Use the fact that Φ₁ r is bounded on [0, 1] to show the integral is finite.
      apply hasFiniteIntegral_of_hasFiniteIntegral_of_ae_stronglyMeasurable
      · -- Prove that the function is integrable on [0, 1].
        have h₄ : HasFiniteIntegral (fun x : ℝ => (Φ₁ r x : ℝ)) (volume.restrict (Icc 0 1)) := by
          -- Since Φ₁ r is continuous on [0, 1], it is integrable.
          have h₅ : ContinuousOn (Φ₁ r : ℝ → ℝ) (Set.Icc 0 1) := Φ₁_contDiffOn.continuousOn.mono (Set.Icc_subset_Icc_left (by norm_num))
          have h₆ : HasFiniteIntegral (fun x : ℝ => (Φ₁ r x : ℝ)) (volume.restrict (Icc 0 1)) := by
            apply ContinuousOn.hasFiniteIntegral
            <;> aesop
          exact h₆
        have h₇ : HasFiniteIntegral (fun x : ℝ => (Φ₁ r x : ℝ)) (volume.restrict (Ioc (0 : ℝ) 1)) := by
          have h₈ : HasFiniteIntegral (fun x : ℝ => (Φ₁ r x : ℝ)) (volume.restrict (Icc 0 1)) := h₄
          have h₉ : HasFiniteIntegral (fun x : ℝ => (Φ₁ r x : ℝ)) (volume.restrict (Ioc (0 : ℝ) 1)) := by
            -- Use the fact that the integral over (0, 1] is a subset of [0, 1].
            have h₁₀ : (volume.restrict (Ioc (0 : ℝ) 1)) ≤ volume.restrict (Icc 0 1) := by
