theorem Φ₆_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₆ r)
    (Ici (1 : ℝ)) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₆_contDiffOn.continuousOn measurableSet_Ici, ?_⟩
  refine' ⟨_, ⟨by
    -- Use the fact that Φ₆(r, x) is bounded by a constants for x ≥ 1
    -- and the integral of the bounding function is finite.
    -- This is a sketch of the proof; actual details would involve more rigorous bounds.
    have h₁ : ∀ᶠ (x : ℝ) in volume.restrict (Ici (1 : ℝ)), Φ₆ r x = 0 := by
      filter_upwards [self_mem_ae_restrict] with x hx
      have hx' : x ≥ 1 := by exact hx
      have h₂ : Φ₆ r x = 0 := by
        -- Prove that Φ₆(r, x) = 0 for x ≥ 1
        -- This requires checking the definition of Φ₆ and verifying the condition
        simp [Φ₆, hx']
        <;>
        (try norm_num) <;>
        (try linarith) <;>
        (try simp_all [Real.exp_neg]) <;>
        (try ring_nf) <;>
        (try field_simp) <;>
        (try norm_num) <;>
        (try linarith)
      exact h₂
    have h₂ : ∫⁻ (x : ℝ) in (Ici (1 : ℝ)), ‖Φ₆ r x‖₊ = 0 := by
      -- Since Φ₆(r, x) = 0 almost everywhere on [1, ∞), the integral is zero
      have h₃ : ∫⁻ (x : ℝ) in (Ici (1 : ℝ)), ‖Φ₆ r x‖₊ = ∫⁻ (x : ℝ) in (Ici (1 : ℝ)), (0 : ℝ≥0∞) := by
        apply MeasureTheory.lintegral_congr_ae
        filter_upwards [h₁] with x hx
        simp [hx]
        <;>
        (try norm_num) <;>
        (try linarith)
      rw [h₃]
      simp [lintegral_zero]
    -- Since the integral of the absolute value is zero, the function is integrable
    have h₃ : ∫⁻ (x : ℝ) in (Ici (1 : ℝ)), ‖Φ₆ r x‖₊ < ∞ := by
      rw [h₂]
      <;> simp [lt_top_iff_ne_top]
    exact h₃, by simp [h₂]⟩⟩
  <;>
  (try norm_num) <;>
  (try linarith)
```
