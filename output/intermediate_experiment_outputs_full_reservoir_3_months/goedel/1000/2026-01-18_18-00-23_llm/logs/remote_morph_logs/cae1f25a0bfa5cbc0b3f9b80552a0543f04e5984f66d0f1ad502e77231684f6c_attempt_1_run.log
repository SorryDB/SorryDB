open Algebra Coalgebra Bialgebra HopfAlgebra TensorProduct
open scoped ConvolutionProduct RingTheory.LinearMap

variable {R A C : Type*} [CommSemiring R]

namespace HopfAlgebra
variable [CommSemiring A] [HopfAlgebra R A]

lemma antipode_mul_antidistrib (a b : A) : antipode R (a * b) = antipode R b * antipode R a := by
  let őĪ := antipode R ‚ąė‚āó .mul' R A
  let ő≤ : A ‚äó[R] A ‚Üí‚āó[R] A := .mul' R A ‚ąė‚āó map (antipode R) (antipode R) ‚ąė‚āó TensorProduct.comm R A A
  suffices őĪ = ő≤ from congr($this (a ‚äó‚āú b))
  apply left_inv_eq_right_inv (a := LinearMap.mul' R A) <;> ext a b
  ¬∑ simp [őĪ, ((‚Ąõ R a).tmul (‚Ąõ R b)).convMul_apply, ‚Üź Bialgebra.counit_mul, mul_comm b a,
      ‚Üź sum_antipode_mul_eq_algebraMap_counit ((‚Ąõ R a).mul (‚Ąõ R b))]
  ¬∑ simp [((‚Ąõ R a).tmul (‚Ąõ R b)).convMul_apply, mul_comm, mul_mul_mul_comm, Finset.sum_mul_sum,
      ‚Üź Finset.sum_product', ő≤, ‚Üź sum_mul_antipode_eq_algebraMap_counit (‚Ąõ R a),
      ‚Üź sum_mul_antipode_eq_algebraMap_counit (‚Ąõ R b)]

lemma antipode_mul_distrib (a b : A) : antipode R (a * b) = antipode R a * antipode R b := by
  rw [antipode_mul_antidistrib, mul_comm]

alias antipode_mul := antipode_mul_distrib

variable (R A) in
/-- The antipode of a commutative Hopf algebra as an algebra hom. -/
@[simps!]
def antipodeAlgHom : A ‚Üí‚āź[R] A := .ofLinearMap (antipode R) antipode_one antipode_mul_distrib

@[simp] lemma toLinearMap_antipodeAlgHom : (antipodeAlgHom R A).toLinearMap = antipode R := rfl

end HopfAlgebra

namespace LinearMap

local notation "ő∑" => Algebra.linearMap R A
local notation "őĶ" => counit (R := R) (A := C)
local notation "őľ" => mul' R A
local notation "őī" => comul
local infix:70 " ‚äó‚āė " => TensorProduct.map
-- local notation "őĪ" => TensorProduct.assoc _ _ _

variable [Semiring C] [HopfAlgebra R C]

@[simp] lemma antipode_mul_id : antipode R (A := C) * id = 1 := by
  ext; simp [convMul_def, ‚Üź LinearMap.rTensor_def]

@[simp] lemma id_mul_antipode : id * antipode R (A := C) = 1 := by
  ext; simp [convMul_def, ‚Üź LinearMap.lTensor_def]

end LinearMap

namespace LinearMap
variable [Semiring C] [HopfAlgebra R C]

local notation "őĶ‚āĀ" => counit (R := R) (A := C)
local notation "őĶ‚āā" => counit (R := R) (A := C ‚äó[R] C)
local notation "őľ‚āĀ" => LinearMap.mul' R C
local notation "őľ‚āā" => LinearMap.mul' R (C ‚äó[R] C)
local notation "őī‚āĀ" => comul (R := R) (A := C)
local notation "őī‚āā" => comul (R := R) (A := C ‚äó[R] C)
local notation "ő∑‚āĀ" => Algebra.linearMap R C
local notation "ő∑‚āā" => Algebra.linearMap R (C ‚äó[R] C)
local infix:90 " ‚óĀ " => LinearMap.lTensor
local notation:90 f:90 " ‚Ė∑ " X:90 => LinearMap.rTensor X f
local notation "őĪ" => TensorProduct.assoc R
local notation "ő≤" => TensorProduct.comm R
local notation "ūĚĎļ" => antipode R (A := C)
local notation "ūĚĎ≠" => őī‚āĀ ‚ąė‚āó ūĚĎļ
local notation "ūĚĎģ" => (ūĚĎļ ‚äó‚āė ūĚĎļ) ‚ąė‚āó (ő≤ C C) ‚ąė‚āó őī‚āĀ

lemma comul_right_inv : őī‚āĀ * ūĚĎ≠ = 1 := calc
    őľ‚āā ‚ąė‚āó (őī‚āĀ ‚äó‚āė (őī‚āĀ ‚ąė‚āó ūĚĎļ)) ‚ąė‚āó őī‚āĀ
  _ = őľ‚āā ‚ąė‚āó ((őī‚āĀ ‚ąė‚āó id) ‚äó‚āė (őī‚āĀ ‚ąė‚āó ūĚĎļ)) ‚ąė‚āó őī‚āĀ := rfl
  _ = őľ‚āā ‚ąė‚āó (őī‚āĀ ‚äó‚āė őī‚āĀ) ‚ąė‚āó (id ‚äó‚āė ūĚĎļ) ‚ąė‚āó őī‚āĀ := by
    simp only [_root_.TensorProduct.map_comp, comp_assoc]
  _ = őī‚āĀ ‚ąė‚āó őľ‚āĀ ‚ąė‚āó (id ‚äó‚āė ūĚĎļ) ‚ąė‚āó őī‚āĀ := by
      have : őľ‚āā ‚ąė‚āó (őī‚āĀ ‚äó‚āė őī‚āĀ) = őī‚āĀ ‚ąė‚āó őľ‚āĀ := by ext; simp
      simp [this, ‚Üź comp_assoc]
  _ = őī‚āĀ ‚ąė‚āó (id * ūĚĎļ) := rfl
  _ = őī‚āĀ ‚ąė‚āó ő∑‚āĀ ‚ąė‚āó őĶ‚āĀ := by simp [convOne_def]
  _ = ő∑‚āā ‚ąė‚āó őĶ‚āĀ := by
      have : őī‚āĀ ‚ąė‚āó ő∑‚āĀ = ő∑‚āā := by ext; simp; rfl
      simp [this, ‚Üź comp_assoc]

end LinearMap

namespace AlgHom
variable [CommSemiring A] [Semiring C] [Bialgebra R C] [HopfAlgebra R A]

lemma antipode_id_cancel : HopfAlgebra.antipodeAlgHom R A * AlgHom.id R A = 1 := by
  apply AlgHom.toLinearMap_injective
  rw [toLinearMap_convMul]
  ext
  simp [LinearMap.antipode_mul_id, AlgHom.convOne_apply]

lemma counitAlgHom_comp_antipodeAlgHom :
    (counitAlgHom R A).comp (HopfAlgebra.antipodeAlgHom R A) = counitAlgHom R A :=
  AlgHom.toLinearMap_injective <| by simp

private lemma inv_convMul_cancel (f : C ‚Üí‚āźc[R] A) :
    (.comp (HopfAlgebra.antipodeAlgHom R A) f : C ‚Üí‚āź[R] A) * f = 1 := calc
  _ = (.comp (HopfAlgebra.antipodeAlgHom R A) f : C ‚Üí‚āź[R] A) * (.comp (.id R A) f) := by simp
  _ = .comp (lmul' R) (.comp (Algebra.TensorProduct.map (HopfAlgebra.antipodeAlgHom R A)
       (.id R A)) <| .comp (Algebra.TensorProduct.map f f) (comulAlgHom R C)) := by
    rw [convMul_def, Algebra.TensorProduct.map_comp]
    simp only [comp_assoc]
  _ = (HopfAlgebra.antipodeAlgHom R A * AlgHom.id R A).comp f := by
    simp only [convMul_def, BialgHomClass.map_comp_comulAlgHom]
    simp only [comp_assoc]
  _ = _ := by simp [antipode_id_cancel, convOne_def, comp_assoc]

end AlgHom

namespace BialgHom
variable [CommSemiring A] [CommSemiring C]

section HopfAlgebra
variable [HopfAlgebra R A] [HopfAlgebra R C] [IsCocomm R C]

def antipodeBialgHom : C ‚Üí‚āźc[R] C where
  __ := antipodeAlgHom R (A := C)
