            let clsb := (c >>> (i * 2)) &&& 1
            let cmsb := (c >>> (i * 2 + 1)) &&& 1
            let slsb : F p := input[i * 2]
            let smsb : F p := input[i * 2 + 1]
            if (cmsb == 0 && clsb == 0) then
              -(2^128 - 2^i : F p) * smsb * slsb + (2^128 - 2^i : F p) * smsb + (2^128 - 2^i : F p) * slsb
            else if (cmsb == 0 && clsb == 1) then
              (2^i : F p) * smsb * slsb - (2^i : F p) * slsb + (2^128 - 2^i : F p) * smsb - (2^i : F p) * smsb + (2^i : F p)
            else if (cmsb == 1 && clsb == 0) then
              (2^128 - 2^i : F p) * smsb * slsb - (2^i : F p) * smsb + (2^i : F p)
            else
              -(2^i : F p) * smsb * slsb + (2^i : F p)
          ) (Vector.range 127)
          let sout : F p := parts.sum
          (sout : F p) = if fromBits (Vector.map ZMod.val input) > c then 1 else 0
      )
