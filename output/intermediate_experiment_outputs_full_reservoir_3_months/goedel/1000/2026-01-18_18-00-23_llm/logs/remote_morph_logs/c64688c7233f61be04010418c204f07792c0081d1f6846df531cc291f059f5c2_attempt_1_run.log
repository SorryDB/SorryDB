def bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) → ¬ (Clap.assert_bits p inst✝ w args = true ∧ e = Exp.c (Clap.bits2num p inst✝ w args)) := by
  intro w args e h₁
  intro h₂
  have h₃ : Clap.assert_bits p inst✝ w args = true ∧ e = Exp.c (Clap.bits2num p inst✝ w args) := h₂
  have h₄ : e.eval.val < 2 ^ w := by
    have h₅ : e = Exp.c (Clap.bits2num p inst✝ w args) := h₃.2
    have h₆ : e.eval = (Clap.bits2num p inst✝ w args : ZMod p) := by
      rw [h₅]
      <;> simp [Exp.eval]
    have h₇ : e.eval.val < 2 ^ w := by
      rw [h₆]
      -- Use the fact that the value of e is the same as the bits2num value
      have h₈ : (Clap.bits2num p inst✝ w args : ZMod p).val < 2 ^ w := by
        -- Use the properties of bits2num and the fact that p is prime
        have h₉ : Clap.bits2num p inst✝ w args < 2 ^ w := by
          -- Since each bit is 0 or 1, the number is less than 2^w
          have h₁₀ : ∀ (w : ℕ) (args : Vector (ZMod p) w), Clap.bits2num p inst✝ w args < 2 ^ w := by
            intro w args
            have h₁₁ : ∀ (w : ℕ) (args : Vector (ZMod p) w), Clap.bits2num p inst✝ w args < 2 ^ w := by
              intro w
              induction' w with w ih
              · intro args
                simp [Clap.bits2num]
                <;>
                (try norm_num) <;>
                (try contradiction) <;>
                (try simp_all [Vector.cons_val_zero, Vector.cons_val_succ, pow_succ])
              · intro args
                simp_all [Clap.bits2num, Nat.succ_eq_add_one, pow_add, pow_one, mul_add, mul_one]
                <;>
                (try norm_num) <;>
                (try omega) <;>
                (try {
                  have h₁₂ : (args.head : ℕ) < p := by
                    have h₁₃ : (args.head : ℕ) < p := by
                      simpa [ZMod.val_nat_cast] using ZMod.val_nat_cast_lt (arg := (p : ℕ))
                    exact h₁₃
                  have h₁₄ : (p : ℕ) > 1 := Fact.out (p := Nat.Prime p) |>.one_lt
                  have h₁₅ : (args.head : ℕ) < 2 := by
                    have h₁₆ : (args.head : ℕ) < p := h₁₂
                    have h₁₇ : (p : ℕ) ≥ 2 := Fact.out (p := Nat.Prime p) |>.two_le
                    omega
                  omega
                })
            exact h₁₁ w args
          exact h₁₀ w args
        exact by
          have h₁₁ : (Clap.bits2num p inst✝ w args : ℕ) < 2 ^ w := by
            exact_mod_cast h₉
          have h₁₂ : (Clap.bits2num p inst✝ w args : ZMod p).val < 2 ^ w := by
            have h₁₃ : (Clap.bits2num p inst✝ w args : ZMod p).val = (Clap.bits2num p inst✝ w args : ℕ) % p := by
              simp [ZMod.val_nat_cast]
