theorem reductionAutomaticallyLifts (lens : Context.Lens ...) (R : Reduction ...) [lens.IsSound ...] : lens.IsComplete ... := by
  have h_main : ∀ (outerCtxIn : OuterCtxIn), ∃ (innerCtxOut : InnerCtxOut), (innerCtxOut) ∈ R.prover.run (lens.proj outerCtxIn.1) (lens.proj outerCtxIn.2) := by
    intro outerCtxIn
    -- We use the fact that the prover of R produces some output for the projected input
    have h₁ : ∃ (innerCtxOut : InnerCtxOut), innerCtxOut ∈ R.prover.run (lens.proj outerCtxIn.1) (lens.proj outerCtxIn.2) := by
      -- Since the prover's output is nonempty, we can pick an arbitrary inner context output
      have h₂ : Classical.choice (Nonempty.nonempty (R.prover.run (lens.proj outerCtxIn.1) (lens.proj outerCtxIn.2))) ∈ R.prover.run (lens.proj outerCtxIn.1) (lens.proj outerCtxIn.2) := by
        apply Set.mem_range_self
      -- We can then use this choice to construct the desired inner context output
      refine' ⟨Classical.choice (Nonempty.nonempty (R.prover.run (lens.proj outerCtxIn.1) (lens.proj outerCtxIn.2))), _⟩
      exact h₂
    -- Finally, we use the existence of such an inner context output
    exact h₁
  
  -- Using h_main, we can now prove that the lens is complete
  intro outerCtxIn
  -- We obtain an inner context output from h_main
  obtain ⟨innerCtxOut, h_inner⟩ := h_main outerCtxIn
  -- We then use the fact that the reduction's verifier is sound to lift this inner context output
  -- to an outer context output that is compatible with the lens
  refine' ⟨lens.lift innerCtxOut, _⟩
  -- Finally, we use the properties of the reduction and the lens to show that this outer context output is indeed compatible
  -- with the reduction's prover and verifier
  sorry
