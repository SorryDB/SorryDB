theorem ContMDiffAt.contMDiffAt_tangentMap (x₀ : TangentBundle I M)
    (hf : ContMDiffAt I I' n f x₀.proj) (hmn : m + 1 ≤ n) :
    ContMDiffAt I.tangent I'.tangent m (tangentMap I I' f) x₀ := by
  rw [contMDiffAt_totalSpace]
  refine ⟨(hf.comp x₀ (contMDiffAt_proj (TangentSpace I))).of_le <| by simpa [add_comm] using hmn, ?_⟩
  dsimp only [tangentMap]
  apply ContMDiffAt.congr_of_eventuallyEq _ (tangent_simp x₀) _
  have h1 :=
    (FiberBundle.continuous_proj E (TangentSpace I)).continuousAt.preimage_mem_nhds
      (mem_baseSet_trivializationAt E (TangentSpace I) x₀.proj)
  have h2 :=
    (hd.comp (x₀, x₀)).continuousAt.preimage_mem_nhds _
  filter_upwards [h1, h2] with x hx hx' <;>
    simp_all [TangentBundle.ext_iff, inTangentCoordinates, Trivialization.continuousLinearMapAt_apply,
      tangentMap]
  <;>
    aesop
```
