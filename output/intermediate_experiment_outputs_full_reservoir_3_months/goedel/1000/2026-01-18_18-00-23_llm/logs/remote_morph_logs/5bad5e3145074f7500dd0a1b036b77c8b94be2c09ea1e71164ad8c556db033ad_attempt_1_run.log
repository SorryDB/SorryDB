variable {C : ℝ} {f : (spectrum ℂ a) → ℂ}
  (hf_bounded : ∀ x, ‖f x‖ ≤ C) (hX : @Measurable _ _ (borel (spectrum ℂ a)) _ f)

/-- The linear functional from bounded measurable functions `f` to `∫ f z ∂E_{a, x, y} z` as a bounded
linear functional (bounded by `‖x‖ * ‖y‖`). All the remaining properties should follow from
the definition and `bfc_bounded`. -/
def toBoundedBilin := {
  toFun x := { toFun y := (cfc_toComplexMeasure ha x y).integral f }
  map_add' := by
    intro x₁ x₂
    simp [toLinearFunctional_apply, add_assoc]
    <;>
    simp_all [ComplexMeasure.integral_add, bfc_bounded, show (1 : ℝ) ≥ 0 by norm_num]
    <;>
    try norm_num
    <;>
    try linarith
    <;>
    try assumption
  map_smul' := by
    intro x₁ x₂
    simp [toLinearFunctional_apply, add_assoc]
    <;>
    simp_all [ComplexMeasure.integral_smul, bfc_bounded, show (1 : ℝ) ≥ 0 by norm_num]
    <;>
    try norm_num
    <;>
    try linarith
    <;>
    try assumption
  cont := by
    have h₁ : ContinuousLinearMap (H) (H →L[ℂ] H) := by
      exact continuousLinearMap_id
    have h₂ : ContinuousLinearMap (H →L[ℂ] H) ℂ := toLinearFunctional x y
    exact (h₂.comp h₁).continuous
}
