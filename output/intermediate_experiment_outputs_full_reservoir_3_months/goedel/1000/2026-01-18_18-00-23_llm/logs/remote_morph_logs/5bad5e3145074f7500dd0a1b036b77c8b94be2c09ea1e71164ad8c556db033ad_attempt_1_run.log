toLinearFunctional x y b = ⟪x, (b y)⟫_ℂ := rfl

/- The linear functional `b => ⟪x, b y⟫_ℂ` is bounded by `‖x‖ * ‖y‖`. -/
lemma toLinearFunctional_bounded (x y : H) : ‖toLinearFunctional x y‖ ≤ ‖x‖ * ‖y‖ := by
  rw [ContinuousLinearMap.norm_def]
  apply sSup_le
  intro z hz
  have h₁ : ‖z‖ ≤ 1 := by exact hz
  have h₂ : ‖(toLinearFunctional x y).toFun z‖ ≤ ‖x‖ * ‖y‖ := by
    simp only [toLinearFunctional_apply]
    calc
      ‖⟪x, (z y)⟫_ℂ‖ ≤ ‖x‖ * ‖(z y)‖ := norm_inner_le_norm x (z y)
      _ ≤ ‖x‖ * ‖z‖ * ‖y‖ := by
        have h₃ : ‖(z y)‖ ≤ ‖z‖ * ‖y‖ := by
          calc
            ‖(z y)‖ ≤ ‖z‖ * ‖y‖ := by
              apply ContinuousLinearMap.le_opNorm
            _ = ‖z‖ * ‖y‖ := by rfl
        calc
          ‖x‖ * ‖(z y)‖ ≤ ‖x‖ * (‖z‖ * ‖y‖) := by gcongr
          _ = ‖x‖ * ‖z‖ * ‖y‖ := by ring
      _ ≤ ‖x‖ * 1 * ‖y‖ := by
        gcongr <;> simp_all [ContinuousLinearMap.norm_def]
        <;>
        (try norm_num) <;>
        (try linarith)
      _ = ‖x‖ * ‖y‖ := by ring
  exact h₂
