def toBoundedBilin {C : ℝ} (f : (spectrum ℂ a) → ℂ)
  : H →L⋆[ℂ] H →L[ℂ] ℂ where
  toFun x := {  toFun y := (cfc_toComplexMeasure ha x y).integral f
                map_add' := by
                  intro y₁ y₂
                  simp [cfc_toComplexMeasure, ComplexRMK.rieszMeasure, ContinuousLinearMap.add_apply]
                  <;>
                  simp_all [ComplexMeasure.integral_add, ComplexMeasure.integral_add]
                  <;>
                  try norm_num <;>
                  try ring_nf <;>
                  try simp_all [ComplexMeasure.integral_add]
                  <;>
                  try linarith
                map_smul' := by sorry
                cont := by sorry }
  map_add' := by sorry
