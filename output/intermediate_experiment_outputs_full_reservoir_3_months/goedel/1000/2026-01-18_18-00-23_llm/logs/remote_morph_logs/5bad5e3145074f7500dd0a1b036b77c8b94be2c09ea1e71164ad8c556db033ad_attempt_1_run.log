  have h₁ : ‖cfc_toLinearFunctional ha x y‖ * ‖f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
    sorry
  have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
    linarith
  exact h₂

theorem cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := by
  have h₀ : (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖cfc_toLinearFunctional ha x y‖ := by
