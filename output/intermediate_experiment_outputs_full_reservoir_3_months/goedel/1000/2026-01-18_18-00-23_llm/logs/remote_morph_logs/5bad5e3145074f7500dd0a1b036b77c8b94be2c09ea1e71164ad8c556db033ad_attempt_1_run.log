@[simp]
lemma toBoundedBilin_add {C : ℝ} (f : (spectrum ℂ a) → ℂ)
  {x y : H} (hf_bounded : ∀ x, ‖f x‖ ≤ C)
  (hf_measurable : @Measurable _ _ (borel (spectrum ℂ a)) _ f) :
    (toBoundedBilin f) (x + y) = (toBoundedBilin f) x + (toBoundedBilin f) y := by
  have h1 : (toBoundedBilin f) (x + y) = (toBoundedBilin f) x + (toBoundedBilin f) y := by
    ext z
    simp [toBoundedBilin, ComplexMeasure.integral_add hf_measurable, add_mul]
    <;> simp_all [hf_bounded]
    <;> ring_nf
    <;> norm_num
    <;> linarith
  exact h1
