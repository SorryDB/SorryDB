lemma toLinearFunctional_bounded (x y : H) : ‖toLinearFunctional x y‖ ≤ ‖x‖ * ‖y‖ := by
  rw [ContinuousLinearMap.opNorm_le_bound]
  <;> positivity
  <;> intro a
  <;> simp only [toLinearFunctional_apply]
  <;> calc
      ‖⟪x, (a y)⟫_ℂ‖ ≤ ‖x‖ * ‖a y‖ := norm_inner_le_norm x (a y)
    _ ≤ ‖x‖ * ‖a‖ * ‖y‖ := by
      calc
        ‖x‖ * ‖a y‖ ≤ ‖x‖ * (‖a‖ * ‖y‖) := by
          gcongr <;>
            try norm_num <;>
            try assumption <;>
            try exact le_opNorm a y <;>
            try exact le_opNorm a y
        _ = ‖x‖ * ‖a‖ * ‖y‖ := by ring
    _ = ‖x‖ * ‖a‖ * ‖y‖ := by rfl

lemma cfc_toLinearFunctional_bound (x y : H) : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by
  have h1 : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by
    have h2 : ContinuousLinearMap ℝ (C (spectrum ℂ a) ℂ) ℂ (cfc_toLinearFunctional ha x y) := cfc_toLinearFunctional ha x y
    have h3 : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := by
      have h4 : ContinuousLinearMap ℝ (C (spectrum ℂ a) ℂ) ℂ (cfc_toLinearFunctional ha x y) := cfc_toLinearFunctional ha x y
      calc
        ‖cfc_toLinearFunctional ha x y‖ = ‖toLinearFunctional x y ∘L cfcCLM ha‖ := rfl
        _ ≤ ‖toLinearFunctional x y‖ * ‖cfcCLM ha‖ := norm_comp_le
        _ ≤ (‖x‖ * ‖y‖) * ‖cfcCLM ha‖ := by gcongr
        _ = (‖x‖ * ‖y‖) * 1 := by
          have h5 : ‖cfcCLM ha‖ = 1 := by
            sorry
          rw [h5]
        _ = ‖x‖ * ‖y‖ := by ring
        _ ≤ ‖x‖ * ‖y‖ := le_refl _
    exact h3
  exact h1

theorem cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
