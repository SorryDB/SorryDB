def toBoundedBilin' {C : ℝ} (f : (spectrum ℂ a) → ℂ)
  (hf_bounded : ∀ x, ‖f x‖ ≤ C)
  (hf_measurable : @Measurable _ _ (borel (spectrum ℂ a)) _ f)
  : H →L⋆[ℂ] H →L[ℂ] ℂ where
  toFun x y := (cfc_toComplexMeasure ha x y).integral f,
  map_add' := by
    intro x1 x2
    have h3 : (toBoundedBilin f) (x1 + x2) = (toBoundedBilin f) x1 + (toBoundedBilin f) x2 := by
      apply toBoundedBilin_add
      <;> simp_all
      <;>
      (try simp_all [hf_bounded])
      <;>
      (try simp_all [hf_measurable])
    simp_all [toBoundedBilin]
    <;>
    (try simp_all [hf_bounded])
    <;>
    (try simp_all [hf_measurable])
