    intro z x
    have h4 : (toBoundedBilin f) (z • x) = z • (toBoundedBilin f) x := by
      apply toBoundedBilin_smul
      <;> simp_all
      <;>
      (try simp_all [hf_bounded])
      <;>
      (try simp_all [hf_measurable])
    simp_all [toBoundedBilin]
    <;>
    (try simp_all [hf_bounded])
    <;>
    (try simp_all [hf_measurable])
  cont := by sorry
