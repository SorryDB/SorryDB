```lean
theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  refine ⟨fun hf p hp => ?_, fun hf => _⟩
  · -- Forward direction: M ∼ₚᵢₛ[A] N implies the localized modules are isomorphic for all height one primes
    exact ⟨(PseudoIsomorphism.map_localizedModule hf p.1.primeCompl).toLinearEquiv⟩
  · -- Reverse direction: The localized modules are isomorphic for all height one primes implies M ∼ₚᵢₛ[A] N
    classical
    -- Use the fact that A satisfies HeightOneLocalizationIsPID to show that the localized modules are principal ideal domains
    haveI : ∀ (p : PrimeSpectrum A), p.1.primeHeight = 1 → IsPrincipalIdealRing (Localization p.1.primeCompl) := by
      intro p hp
      have h := (inferInstance : HeightOneLocalizationIsPID A).isPrincipalIdealRing_localization {p} (by simp_all [Set.mem_singleton_iff]) (by simp_all [Set.mem_singleton_iff]) (by simp_all [Set.mem_singleton_iff])
      exact h.2
    -- Construct a pseudo-isomorphism using the given condition
    refine ⟨(IsTorsion.exists_pseudoIsomorphism_of_localizedModule_isomorphism (fun p hp => by
      -- For each height one prime p, the localized modules are isomorphic
      classical
      obtain ⟨e⟩ := hf p hp
      refine e
      ) hMT hNT).1, _⟩
    -- Verify that the constructed map is a pseudo-isomorphism
    <;> simp [PseudoIsomorphism.ext_iff]
    <;>
    (try exact ⟨1, by simp⟩)
    <;>
    (try exact ⟨0, by simp⟩)
