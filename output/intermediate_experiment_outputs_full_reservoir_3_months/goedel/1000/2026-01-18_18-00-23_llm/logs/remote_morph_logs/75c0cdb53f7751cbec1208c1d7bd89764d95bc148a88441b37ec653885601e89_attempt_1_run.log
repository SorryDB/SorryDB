theorem indexed_sum_plus_one : ∑' n : ℕ, one n = ∞ := by
  have h : ∑' n : ℕ, one n = ∑' n : ℕ, (1 : ℝ≥0∞) := by
    congr with n
    simp [one]
    <;>
    simp_all [ENNReal.one_coe]
    <;>
    norm_num
  rw [h]
  -- Now we need to show that the sum of 1 over all natural numbers is infinity.
