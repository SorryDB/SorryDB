  have h₁ : (2 : ℕ) ^ 6 = 64 := by norm_num
  have h₂ : (fermatNumber 6 : ℕ) = 2 ^ (2 ^ 6) + 1 := by rfl
  have h₃ : (fermatNumber 6 : ℕ) = 2 ^ 64 + 1 := by
    rw [h₂]
    <;> norm_num
    <;> rfl
  have h₄ : (fermatNumber 6 : ℕ) = 18446744073709551617 := by
    norm_num [h₃]
    <;> rfl
  have h₅ : (minFac (fermatNumber 6) : ℕ) = 274177 := by
    -- Prove that 274177 is the smallest prime factor of the 6th Fermat number
    rw [h₄]
    -- Use the known factorization of the 6th Fermat number
    norm_num [Nat.minFac_eq]
    <;> rfl
  have h₆ : (log2 (minFac (fermatNumber 6)) : ℕ) = 18 := by
    -- Calculate the log base 2 of the smallest prime factor
    rw [h₅]
    <;> norm_num [Nat.log2_eq_iff]
    <;> rfl
  have h₇ : (a 6 : ℕ) = 46 := by
    -- Calculate a(6) using the given formula
    simp [a, h₆, h₁]
    <;> norm_num
    <;> rfl
  exact h₇
