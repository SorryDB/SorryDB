```lean
theorem Φ₁_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₁ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₁_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  have h₁ : HasFiniteIntegral (fun x : ℝ => Φ₁ r x) (volume.restrict (Ioc 0 1)) := by
    -- Use the fact that Φ₁ is continuous on the interval (0,1] and the interval is compact to show it is bounded
    -- and hence the integral is finite.
    have h₂ : ContinuousOn (fun x : ℝ => Φ₁ r x) (Set.Icc 0 1) := by
      apply ContinuousOn.congr Φ₁_contDiffOn.continuousOn
      intro x hx
      simp only [Set.mem_Icc] at hx
      <;> simp_all [Set.mem_Ioc]
      <;>
      (try norm_num) <;>
      (try linarith) <;>
      (try simp_all [Real.sqrt_eq_iff_sq_eq]) <;>
      (try ring_nf) <;>
      (try norm_num) <;>
