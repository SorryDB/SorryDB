```lean
theorem Φ₁_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₁ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₁_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  have h : HasFiniteIntegral (fun x : ℝ => Φ₁ r x) (volume.restrict (Ioc 0 1)) := by
    -- Use the fact that Φ₁ r is continuous on (0, 1] and the interval is bounded
    have h₁ : ContinuousOn (fun x : ℝ => Φ₁ r x) (Ioc 0 1) := Φ₁_contDiffOn.continuousOn
    -- Use the fact that the interval is bounded and the function is continuous to conclude finite integral
    have h₂ : HasFiniteIntegral (fun x : ℝ => Φ₁ r x) (volume.restrict (Ioc 0 1)) :=
      (hasFiniteIntegral_of_continuous_on (by
        -- Prove that Ioc 0 1 is a measurable set
        apply MeasurableSet.Ioc
        ) h₁
        -- Prove that the set Ioc 0 1 is bounded
        (by
          -- The interval (0, 1] is bounded in ℝ
          apply IsBounded.Ioc
          <;> norm_num
          )
        )
    exact h₂
  exact h
