    have h₃ : BddBelow (Set.Ioc 0 1 : Set ℝ) := by
      refine' ⟨0, _⟩
      intro x hx
      linarith [hx.1]
    have h₄ : BddAbove (Set.Ioc 0 1 : Set ℝ) := by
      refine' ⟨1, _⟩
      intro x hx
      linarith [hx.2]
    have h₅ : HasFiniteIntegral (fun x : ℝ => Φ₁ r x)
      (volume.restrict (Ioc 0 1 : Set ℝ)) := by
      have h₆ : ContinuousOn (fun x : ℝ => Φ₁ r x) (Ioc (0 : ℝ) 1) := Φ₁_contDiffOn.continuousOn
      have h₇ : IntegrableOn (fun x : ℝ => Φ₁ r x) (Ioc (0 : ℝ) 1) volume := by
        -- Use the fact that the function is continuous on a bounded interval
        -- and hence integrable.
        have h₈ : IsCompact (Set.Icc 0 1 : Set ℝ) := isCompact_Icc
        have h₉ : ContinuousOn (fun x : ℝ => Φ₁ r x) (Set.Icc 0 1) := by
          apply ContinuousOn.mono h₆
