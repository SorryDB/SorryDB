### Complete Lean 4 Proof

```lean
theorem lean_workbook_plus_28364 (a b c : ℕ) (h : a^2 = b^2 + c^2) : a < b + c := by
  have h₁ : a < b + c := by
    by_contra h₂
    have h₃ : a ≥ b + c := by omega
    have h₄ : a^2 ≥ (b + c)^2 := by
      have h₅ : a ≥ b + c := h₃
      calc
        a^2 ≥ (b + c)^2 := by
          exact Nat.pow_le_pow_of_le_left h₅ 2
        _ = (b + c)^2 := by rfl
    have h₅ : (b + c)^2 > b^2 + c^2 := by
      have h₆ : 0 < b ∨ 0 < c := by
        by_cases h₇ : 0 < b
        · exact Or.inl h₇
        · have h₈ : b = 0 := by omega
          have h₉ : 0 < c := by
            by_contra h₁₀
            have h₁₁ : c = 0 := by omega
            have h₁₂ : a = 0 := by
              simp [h₈, h₁₁] at h
              <;> nlinarith
            simp [h₈, h₁₁, h₁₂] at h₂ h₃ h₄ ⊢
            <;> omega
          exact Or.inr h₉
      cases h₆ with
      | inl h₆ =>
        have h₇ : 0 < b := h₆
        have h₈ : 0 ≤ c := by omega
        have h₉ : (b + c)^2 = b^2 + c^2 + 2 * b * c := by
          ring_nf
          <;> nlinarith
        have h₁₀ : 2 * b * c > 0 := by
          have h₁₁ : 0 < b := h₆
          have h₁₂ : 0 ≤ c := by omega
          have h₁₃ : 0 < 2 * b := by nlinarith
          have h₁₄ : 0 ≤ c := by omega
          have h₁₅ : 0 < 2 * b * c := by
            by_cases h₁₆ : c = 0
            · exfalso
              simp [h₁₆] at h₉ h
              <;> nlinarith
            · have h₁₇ : 0 < c := by
                omega
              nlinarith
          omega
        nlinarith
      | inr h₆ =>
        have h₇ : 0 < c := h₆
        have h₈ : 0 ≤ b := by omega
        have h₉ : (b + c)^2 = b^2 + c^2 + 2 * b * c := by
          ring_nf
          <;> nlinarith
        have h₁₀ : 2 * b * c > 0 := by
          have h₁₁ : 0 < c := h₆
          have h₁₂ : 0 ≤ b := by omega
          have h₁₃ : 0 < 2 * c := by nlinarith
          have h₁₄ : 0 ≤ b := by omega
          have h₁₅ : 0 < 2 * b * c := by
            by_cases h₁₆ : b = 0
            · exfalso
              simp [h₁₆] at h₉ h
              <;> nlinarith
            · have h₁₇ : 0 < b := by
                omega
              nlinarith
          omega
        nlinarith
    have h₆ : a^2 > b^2 + c^2 := by
      calc
        a^2 ≥ (b + c)^2 := h₄
        _ > b^2 + c^2 := h₅
    linarith
  exact h₁
