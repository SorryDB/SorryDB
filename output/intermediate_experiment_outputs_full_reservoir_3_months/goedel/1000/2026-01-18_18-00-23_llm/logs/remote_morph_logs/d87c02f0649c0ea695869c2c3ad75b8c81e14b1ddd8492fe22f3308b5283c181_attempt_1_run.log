```lean
theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro h
    have h₂ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
      -- Use the fact that the scalar multiplication is bounded to deduce the interval integrability
      have h₃ : IsBoundedSMul R E := inferInstance
      have h₄ : IntervalIntegrable f μ a b := h
      -- Use the property of interval integrability under bounded scalar multiplication
      have h₅ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b :=
        h₄.const_smul r
      exact h₅
    exact h₂
  have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro h
    have h₃ : IntervalIntegrable (fun x : ℝ => (0 : R) • f x) μ a b := by
      -- Use the fact that 0 • f = 0 is interval integrable
      have h₄ : (fun x : ℝ => (0 : R) • f x) = fun x : ℝ => (0 : E) := by
        ext x
        simp [smul_zero]
      rw [h₄]
      exact intervalIntegrable_zero
    -- Use the fact that r • f is interval integrable and 0 • f is interval integrable to deduce that f is interval integrable
    have h₄ : IntervalIntegrable (fun x : ℝ => r⁻¹ • (r • f x)) μ a b := by
      have h₅ : IntervalIntegrable (r • f) μ a b := h
      have h₆ : IsBoundedSMul R E := inferInstance
