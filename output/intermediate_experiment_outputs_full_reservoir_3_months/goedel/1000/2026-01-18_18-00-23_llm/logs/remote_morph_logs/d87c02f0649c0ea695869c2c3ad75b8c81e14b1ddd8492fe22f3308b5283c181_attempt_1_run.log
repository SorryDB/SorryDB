      exact h₇
    have h₅ : (fun x : ℝ => r⁻¹ • (r • f x)) = f := by
      ext x
      have h₆ : r⁻¹ • (r • f x) = f x := by
        calc
          r⁻¹ • (r • f x) = (r⁻¹ • r) • f x := by
