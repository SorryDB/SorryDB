    · -- If `r ≠ 0`, then we can use the inverse of `r` to deduce that `f` is interval integrable from `r • f`.
      have h₁ : IsBoundedLinearMap (SMul.smul r : E → E) := by
        -- Prove that scalar multiplication by `r` is a bounded linear map.
        refine' IsBoundedSMul.isBoundedLinearMap _
      -- Use the fact that `r • f` is interval integrable and `r ≠ 0` to deduce that `f` is interval integrable.
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the inverse of the scalar multiplication to deduce the integrability of `f`.
        have h₃ : IntervalIntegrable (r • f) μ a b := h
        have h₄ : IntervalIntegrable f μ a b := by
          -- Use the fact that scalar multiplication by `r` is invertible when `r ≠ 0`.
          refine' h₃.comp_injective (fun x y hxy => by simpa [hr] using hxy)
          <;>
          (try simp_all [hr]) <;>
          (try aesop) <;>
          (try
            {
