theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro h
    -- Use the fact that scalar multiplication by a bounded operator preserves integrability
    have h₂ : IntervalIntegrable (fun x => r • f x) μ a b := by
      -- Use the boundedness of the scalar multiplication to apply the boundedness condition
      have h₃ : IsBoundedSMul R E := by infer_instance
      -- Use the property of interval integrability under bounded scalar multiplication
      exact h.integrableOn_smul
    exact h₂
  have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro h
    -- Use the fact that scalar multiplication by a bounded operator preserves integrability
    have h₃ : IntervalIntegrable f μ a b := by
      -- Use the boundedness of the scalar multiplication to apply the boundedness condition
      have h₄ : IsBoundedSMul R E := by infer_instance
      -- Use the property of interval integrability under bounded scalar multiplication
      have h₅ : IntervalIntegrable (fun x => r⁻¹ • (r • f x)) μ a b := by
        -- Use the fact that the inverse of the scalar multiplication is bounded
        have h₆ : IntervalIntegrable (fun x => r⁻¹ • (r • f x)) μ a b := by
          -- Use the boundedness of the scalar multiplication to apply the boundedness condition
          have h₇ : IsBoundedSMul R E := by infer_instance
          -- Use the property of interval integrability under bounded scalar multiplication
          exact h.integrableOn_smul
        exact h₆
      -- Use the fact that r⁻¹ • (r • f x) = f x
      have h₆ : (fun x => r⁻¹ • (r • f x)) = f := by
        funext x
        simp [smul_smul, inv_mul_cancel_left]
        <;>
        (try simp_all [smul_smul, inv_mul_cancel_left])
        <;>
        (try simp_all [smul_smul, inv_mul_cancel_left])
      -- Use the fact that the function is equal to f
      have h₇ : IntervalIntegrable f μ a b := by
        simpa [h₆] using h₅
      exact h₇
    exact h₃
  exact ⟨h₁, h₂⟩
