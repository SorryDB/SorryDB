theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro hf
    -- Use the fact that scalar multiplication is bounded to transfer integrability
    refine' hf.of_norm_smul_le (fun x => ?_)
    -- Apply the boundedness of scalar multiplication to get the norm inequality
    simpa using norm_smul_le r (f x)
  
  have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro hf
    -- If r = 0, then r • f = 0 and f is trivially integrable if r • f is integrable
    by_cases hr : r = 0
    · -- Case r = 0
      have h₃ : (r • f : ℝ → E) = fun _ => 0 := by
        funext x
        simp [hr]
      rw [h₃] at hf
      have h₄ : IntervalIntegrable (fun x : ℝ => (0 : E)) μ a b := hf
      -- The zero function is integrable, and f is also integrable in this case
      have h₅ : IntervalIntegrable f μ a b := by
        -- Use the fact that the zero function is integrable to deduce f is integrable
        -- This is a placeholder for a more detailed argument, but in this case, it's trivial
        simpa [hr] using h₄
      exact h₅
    · -- Case r ≠ 0
      -- Use the fact that scalar multiplication is invertible to transfer integrability
      have h₃ : IntervalIntegrable f μ a b := by
        -- Use the boundedness of scalar multiplication to transfer integrability
        have h₄ : IntervalIntegrable (r • f) μ a b := hf
        -- Use the fact that the inverse of scalar multiplication is bounded to transfer integrability
        refine' h₄.of_norm_smul_le (fun x => ?_) |>.of_norm_smul_le (fun x => ?_)
        -- Apply the boundedness of scalar multiplication to get the norm inequality
        <;>
        (try simp_all) <;>
        (try
          {
            calc
              ‖(r⁻¹ : R) • (r • f x)‖ = ‖(r⁻¹ • r) • f x‖ := by
                simp [smul_smul]
                <;>
                simp_all [norm_smul, IsBoundedSMul.bounded_norm_smul]
                <;>
                norm_num
              _ = ‖(1 : R) • f x‖ := by
                have h₅ : (r⁻¹ : R) • r = 1 := by
                  simp_all [inv_smul_cancel_right₀]
                  <;>
                  aesop
                simp_all
              _ = ‖f x‖ := by simp
              _ ≤ ‖f x‖ := le_refl _
          }) <;>
        (try
          {
            calc
              ‖r • f x‖ = ‖r‖ * ‖f x‖ := by
                simp [norm_smul]
              _ ≤ ‖r‖ * ‖f x‖ := le_refl _
          })
      exact h₃
  
  exact ⟨h₁, h₂⟩
