          )
        exact h₅
      exact h₄
    -- Since `(1 : R) • f = f`, we have that `f` is interval integrable
    have h₄ : (fun x : ℝ => (1 : R) • f x) = f := by
      funext x
      simp [one_smul]
      <;>
        (try simp_all)
      <;>
