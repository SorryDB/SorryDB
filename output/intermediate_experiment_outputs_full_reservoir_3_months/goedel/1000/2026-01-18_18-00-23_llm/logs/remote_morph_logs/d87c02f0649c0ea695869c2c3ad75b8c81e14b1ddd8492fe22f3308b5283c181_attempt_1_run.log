            simp [mul_comm]
          _ = 1 • f x := by
            have h₇ : r⁻¹ • r = (1 : R) := by
              simp [inv_smul_cancel]
            rw [h₇]
          _ = f x := by simp [one_smul]
      rw [h₆]
    rw [h₅] at h₄
    exact h₄
