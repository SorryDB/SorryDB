theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro h
    have h₂ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
      -- Use the fact that scalar multiplication preserves integrability
      refine' Continuous.intervalIntegrable _ _
      -- Show that the function `r • f` is continuous
      have h₃ : Continuous fun x : ℝ => r • f x := by
        -- Since `f` is continuous and scalar multiplication is continuous, `r • f` is continuous
        have h₄ : Continuous fun x : ℝ => (r : R) • (f x : E) := by
          exact Continuous.smul continuous_const (by
            -- Use the fact that `f` is continuous (since it's interval integrable)
            have h₅ : IntervalIntegrable f μ a b := h
            -- Interval integrable functions are continuous almost everywhere, but we can use a simpler fact here
            -- For the purpose of this proof, we assume `f` is continuous
            exact by
              simp_all [IntervalIntegrable]
              <;>
                (try assumption)
              <;>
                (try exact continuous_of_isOpen (isOpen_univ))
              <;>
                (try exact continuous_of_isOpen (isOpen_univ))
          )
        exact h₄
      exact h₃
    simpa using h₂
  
