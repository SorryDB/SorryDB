theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  constructor
  · -- Prove the forward direction: if `f` is interval integrable, then `r • f` is interval integrable.
    intro h
    have h₁ : IntervalIntegrable (fun x => r • f x) μ a b := by
      -- Use the fact that scalar multiplication by `r` is a bounded linear map
      -- and `f` is interval integrable to show that `r • f` is interval integrable.
      refine' h.smul_left r
    exact h₁
  · -- Prove the backward direction: if `r • f` is interval integrable, then `f` is interval integrable.
    intro h
    by_cases hr : r = 0
    · -- If `r = 0`, then `r • f = 0`, and `f` is trivially interval integrable because `0` is interval integrable.
      have h₁ : (r • f : ℝ → E) = fun _ => (0 : E) := by
        funext x
        simp [hr]
        <;> simp_all [SMulZeroClass.smul_zero]
      have h₂ : IntervalIntegrable (fun _ : ℝ => (0 : E)) μ a b := by
        -- The zero function is always interval integrable.
        apply intervalIntegrable_const
      have h₃ : IntervalIntegrable f μ a b := by
        -- Since `r • f = 0`, we can deduce that `f` is interval integrable.
        have h₄ : IntervalIntegrable f μ a b := by
          -- Use the fact that `r = 0` to simplify the problem.
          simp_all [h₁]
          <;>
          (try simp_all [hr]) <;>
          (try simp_all [SMulZeroClass.smul_zero]) <;>
          (try aesop)
          <;>
          (try
            {
              exfalso
              simp_all [hr]
              <;>
              aesop
            })
          <;>
          (try
