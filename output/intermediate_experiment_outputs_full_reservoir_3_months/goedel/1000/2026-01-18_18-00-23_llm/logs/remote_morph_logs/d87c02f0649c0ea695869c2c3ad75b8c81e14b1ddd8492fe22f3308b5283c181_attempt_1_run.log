```lean
theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro h
    -- Use the fact that scalar multiplication is continuous and bounded to show the interval integrability of r • f
    refine' h.smul_right r
  have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro h
    -- Use the fact that scalar multiplication is continuous and bounded to show the interval integrability of f
    have h₃ : IsBoundedSMul R E := inferInstance
    -- Use the fact that scalar multiplication is continuous and bounded to show the interval integrability of f
    have h₄ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
      have h₅ : IntervalIntegrable (r • f) μ a b := h
      refine' h₅.smul_right r⁻¹
    -- Simplify r⁻¹ • (r • f) to f
    have h₅ : (fun x => r⁻¹ • (r • f x)) = f := by
      funext x
      -- Use the properties of scalar multiplication to simplify
      simp [smul_smul, smul_eq_mul]
      <;>
      (try simp_all [SMulZeroClass]) <;>
      (try ring_nf) <;>
      (try simp_all [SMulZeroClass]) <;>
      (try field_simp) <;>
      (try simp_all [SMulZeroClass])
    -- Substitute and conclude
    simpa [h₅] using h₄
  exact ⟨h₁, h₂⟩
```
