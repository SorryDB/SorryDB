```lean
theorem quadSolsInclLinSols_injective (χ : ACCSystemQuad) :
    Function.Injective χ.quadSolsInclLinSols := by
  intro S T h
  -- Extract the underlying linear solutions from S and T
  have h₁ : S.toLinSols = T.toLinSols := by
    simpa [QuadSols.ext] using h
  -- Since S and T are quadratic solutions, their linear parts are equal
  have h₂ : S.val = T.val := by
    -- Use the fact that the linear part is injective
    have h₃ : Function.Injective χ.linSolsIncl := χ.ballinlinSolsIncl_injectivity
    -- Use the injectivity of the linear part to conclude equality of values
    have h₄ : (S.toLinSols : χ.LinSols).val = (T.toLinSols : χ.LinSols).val := by
      -- Use the equality of the linear parts
      exact congr_arg (fun x : χ.LinSols => x.val) h₁
    -- Convert back to S and T
    simp [LinSols.val] at h₄ ⊢
    <;> simp_all [QuadSols.val]
  -- Use the equality of values to conclude equality of S and T
  have h₃ : S = T := by
    apply QuadSols.ext
    exact h₂
  -- Conclude the proof
  exact h₃
