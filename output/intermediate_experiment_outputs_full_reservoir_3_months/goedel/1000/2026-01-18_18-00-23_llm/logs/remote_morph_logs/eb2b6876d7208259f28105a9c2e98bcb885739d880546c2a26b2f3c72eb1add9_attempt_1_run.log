theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h_main : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      intro hf
      -- Use the fact that the interval integrability of r • f follows from the boundedness of the scalar multiplication.
      have h₁ : IntervalIntegrable (r • f) μ a b := by
        -- Use the property that scalar multiplication preserves interval integrability.
        have h₂ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
          -- Use the fact that the scalar multiplication is bounded and f is interval integrable.
          apply IntervalIntegrable.smul_left
          exact hf
          <;>
            infer_instance
        simpa [smul_eq_mul] using h₂
      exact h₁
    · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      intro hf
      -- Use the fact that the interval integrability of f follows from the boundedness of the scalar multiplication.
      have h₁ : IntervalIntegrable f μ a b := by
        -- Use the property that scalar multiplication preserves interval integrability.
        have h₂ : IntervalIntegrable (fun x : ℝ => (r⁻¹ : R) • (r • f x)) μ a b := by
          -- Use the fact that the scalar multiplication is bounded and r • f is interval integrable.
          apply IntervalIntegrable.smul_left
          exact hf
          <;>
            infer_instance
        -- Simplify the expression (r⁻¹ : R) • (r • f x) to f x.
        have h₃ : (fun x : ℝ => (r⁻¹ : R) • (r • f x)) = f := by
          funext x
          simp [smul_smul]
          <;>
            (try norm_num) <;>
            (try simp_all [inv_smul, inv_smul, smul_smul]) <;>
            (try field_simp) <;>
            (try norm_num) <;>
            (try simp_all [inv_smul, inv_smul, smul_smul]) <;>
            (try field_simp) <;>
            (try norm_num)
          <;>
            (try simp_all [inv_smul, inv_smul, smul_smul])
          <;>
            (try field_simp)
          <;>
            (try norm_num)
          <;>
            (try simp_all [inv_smul, inv_smul, smul_smul])
          <;>
            (try field_simp)
          <;>
            (try norm_num)
        -- Substitute the simplified expression back into the interval integrability condition.
        rw [h₃] at h₂
        exact h₂
      exact h₁
  
  exact h_main
