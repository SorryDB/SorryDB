  have h₁ : Lb = lim (b : ℕ → ℝ) := by
    -- Prove that Lb is the limit of the sequence b
    have h₂ : HasLimit b Lb := by
      rw [Metric.hasLimit_iff] at *
      -- Use the fact that b is Cauchy to show it converges to Lb
      have h₃ : IsCauchy b := bCauchy
      have h₄ : Filter.Tendsto b Filter.atTop (nhds Lb) := by
        apply Metric.tendsto_nhds_unique (hLb.convergent.tendsto) (Metric.tendsto_nhds (hLb.convergent.tendsto))
        <;> trivial
      simpa [Metric.mem_nhds_iff] using h₄
    -- Since b converges to Lb, its limit is Lb
    have h₃ : lim (b : ℕ → ℝ) = Lb := by
      apply Eq.symm
      apply h₂.unique (hasLimit_id)
      <;> simp_all [Metric.tendsto_nhds]
    linarith
  -- Use the fact that b is antitone to show that Lb ≤ b n for all n
  have h₂ : ∀ (k : ℕ), Lb ≤ b k := by
    intro k
    have h₃ : Lb = lim (b : ℕ → ℝ) := h₁
    have h₄ : Antitone b := bAnti
    have h₅ : ∀ (n : ℕ), b n ≥ b (k + n) := by
      intro n
      have h₆ : b (k + n) ≤ b k := by
        apply h₄
        <;> linarith
      linarith
    -- Use the fact that b is antitone and bounded below to show that the limit is less than or equal to each term
    have h₆ : Filter.Tendsto (fun n : ℕ => b (k + n)) Filter.atTop (nhds (lim (b : ℕ → ℝ))) := by
      have h₇ : Filter.Tendsto (fun n : ℕ => b (k + n)) Filter.atTop (nhds (lim (b : ℕ → ℝ))) := by
        have h₈ : HasLimit (fun n : ℕ => b (k + n)) (lim (b : ℕ → ℝ)) := by
          have h₉ : HasLimit b (lim (b : ℕ → ℝ)) := hasLimit_lim
          have h₁₀ : HasLimit (fun n : ℕ => b (k + n)) (lim (b : ℕ → ℝ)) := h₉.comp (hasLimit_add_atTop_nat k)
          exact h₁₀
        exact h₈.tendsto
      exact h₇
    have h₇ : ∀ (n : ℕ), b (k + n) ≤ b k := by
      intro n
      have h₈ : b (k + n) ≤ b k := by
        apply h₄
        <;> linarith
      exact h₈
    have h₈ : lim (b : ℕ → ℝ) ≤ b k := by
      have h₉ : ∀ (n : ℕ), b (k + n) ≤ b k := h₇
      have h₁₀ : Filter.Tendsto (fun n : ℕ => b (k + n)) Filter.atTop (nhds (lim (b : ℕ → ℝ))) := h₆
      have h₁₁ : lim (b : ℕ → ℝ) ≤ b k := by
        -- Use the fact that the limit of a sequence is less than or equal to an upper bound
        have h₁₂ : ∀ᶠ (n : ℕ) in Filter.atTop, b (k + n) ∈ Set.Iic (b k) := by
          filter_upwards [Filter.eventually_ge_atTop 0] with n hn
          exact Set.mem_Iic.mpr (h₉ n)
        have h₁₃ : Filter.Tendsto (fun n : ℕ => b (k + n)) Filter.atTop (nhds (lim (b : ℕ → ℝ))) := h₆
        have h₁₄ : lim (b : ℕ → ℝ) ∈ closure (Set.Iic (b k)) := by
          apply h₁₃.closure_subset h₁₂
        have h₁₅ : closure (Set.Iic (b k)) = Set.Iic (b k) := by
          apply closure_eq_iff_unique.isClosed_Iic.2
          <;> simp
        have h₁₆ : lim (b : ℕ → ℝ) ∈ Set.Iic (b k) := by
          rw [h₁₅] at h₁₄
          exact h₁₄
        have h₁₇ : lim (b : ℕ → ℝ) ≤ b k := by
          exact h₁₆
        exact h₁₇
      exact h₁₁
    linarith
  exact h₂ n
