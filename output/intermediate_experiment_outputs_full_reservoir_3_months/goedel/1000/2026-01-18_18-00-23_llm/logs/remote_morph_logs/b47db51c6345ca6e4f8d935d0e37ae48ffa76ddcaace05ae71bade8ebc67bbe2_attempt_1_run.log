theorem as_extended_spec (q : ProjectivePoint)
  (h_qX_bounds : ∀ i, i < 5 → (q.X[i]!).val < 2 ^ 54)
  (h_qY_bounds : ∀ i, i < 5 → (q.Y[i]!).val < 2 ^ 54)
  (h_qZ_bounds : ∀ i, i < 5 → (q.Z[i]!).val < 2 ^ 54) :
∃ e,
as_extended q = ok e ∧
let X := Field51_as_Nat q.X
let Y := Field51_as_Nat q.Y
let Z := Field51_as_Nat q.Z
let X' := Field51_as_Nat e.X
let Y' := Field51_as_Nat e.Y
let Z' := Field51_as_Nat e.Z
let T' := Field51_as_Nat e.T
X' % p = (X * Z) % p ∧
Y' % p = (Y * Z) % p ∧
Z' % p = (Z^2) % p ∧
T' % p = (X * Y) % p
:= by
  have h₁ : q.as_extended caseOk
  have h₂ : q.as_extended = ok (q.as_extended caseOk)
  refine' ⟨q.as_extended caseOk, _, _⟩
  · -- Prove that `q.as_extended = ok e`
    exact h₂
  · -- Prove the congruences modulo p
    dsimp at *
    <;> simp_all [Field51_as_Nat, Fin.val_zero, Fin.val_one, Fin.val_two, Fin.val_succ]
    <;> norm_num [p, Curve25519Dalek.Prime.ModEq]
    <;> rfl
```
