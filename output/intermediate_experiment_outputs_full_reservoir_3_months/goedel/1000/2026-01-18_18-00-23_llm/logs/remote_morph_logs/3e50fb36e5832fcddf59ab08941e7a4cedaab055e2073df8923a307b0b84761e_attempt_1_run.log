lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : x.val ∈ val_image A X1 := by
    refine' ⟨x, hx, _⟩
    <;> simp
  have h₂ : x.val ∈ val_image A X2 := by rw [h] at h₁; exact h₁
  obtain ⟨y, hy, hy'⟩ := h₂
  have h₃ : y.val = x.val := by simp_all
  have h₄ : y = x := by
    apply Subtype.ext
    simp_all
  simp_all

