      rcases hx with ⟨y, ⟨z, hz, rfl⟩, hy⟩
      have h₂ := congr_fun h z
      simp at h₂
      have h₃ : g (f z) = z := by simp_all [Function.comp_apply]
      have h₄ : y = f z := by simp_all
      simp_all [Function.comp_apply]
      <;> aesop
    · -- Prove that s ⊆ (image g) (image f s)
      intro x hx
      simp only [Set.mem_image, Function.comp_apply]
      have h₂ : g (f x) = x := by
        have h₃ := congr_fun h x
        simp at h₃ ⊢
        <;> aesop
      refine' ⟨f x, _, g (f x), _⟩ <;> simp_all [Function.comp_apply] <;> aesop
  ext s
  simp only [Function.comp_apply]
  apply h₁
