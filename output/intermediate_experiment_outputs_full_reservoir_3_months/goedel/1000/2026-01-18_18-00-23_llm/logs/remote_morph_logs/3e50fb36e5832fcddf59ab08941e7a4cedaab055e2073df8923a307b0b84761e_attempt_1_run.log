```lean
structure Line where
  exists_eq : ℝ → Prop

def Line.univ : Line :=
  ⟨fun _ => True⟩

def Line.p : ℝ := 0
def Line.q : ℝ := 1

def Line.one : Line :=
  ⟨fun x : ℝ => x = 1⟩

def Line.zero : Line :=
  ⟨fun x : ℝ => x = 0⟩

def Line.nil : Line :=
  ⟨fun _ : ℝ => False⟩

inductive PLine : Type where
| univ : PLine
| vline : ℝ → PLine
| hline : ℝ → PLine
| line : ℝ → ℝ → PLine

def Line.exists_eq (L : Line) (x : ℝ) :=
  L.exists_eq x

def Line.exists_eq (L : PLine) (x : ℝ) : Prop :=
  match L with
  | PLine.univ => True
  | PLine.vline a => x = a
  | PLine.hline b => True
  | PLine.line m b => ∃ (t : ℝ), x = m * t + b

@[reducible]
def Line.exists_eq (L : Line ∨ PLine) (x : ℝ) : Prop :=
  match L with
  | Or.inl L => Line.exists_eq L x
  | Or.inr L => Line.exists_eq L x

class FunctionLike (f : Type → Type → Type) where
  fun_eq {α β : Type} [Inhabited α] [Inhabited β] : f α β = α → β

variable (U V : Type)

def tri (k : ℕ) : ℕ :=
  k * (k + 1) / 2

def fnz (k : ℕ) : ℤ :=
  if k % 2 = 0 then (if k = 0 then 0 else -(k / 2)) else (k + 1) / 2

def fzn (k : ℤ) : ℕ :=
  if 0 ≤ k then 2 * k else -2 * k - 1

def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

def image_comp_id {U V : Type} {f : U → V} {g : V → U} (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  sorry
```

