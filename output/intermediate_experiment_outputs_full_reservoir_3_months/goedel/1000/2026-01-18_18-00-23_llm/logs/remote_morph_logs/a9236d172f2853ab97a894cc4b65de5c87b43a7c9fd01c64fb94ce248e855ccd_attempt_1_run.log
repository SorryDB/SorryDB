          <;>
          (try ring_nf at *) <;>
          (try norm_num at *) <;>
          (try linarith)
      exact h₂
    -- Use the proven equality to conclude the proof
    linarith
  
  have h_main : Tn s t (-F n t + F n (t + 1)) = Tn s t (F (n + 1) t) := by
    rw [h]
    <;>
    simp_all [Tn]
    <;>
    try ring_nf
    <;>
    try norm_num
    <;>
    try linarith
  
  exact h_main
