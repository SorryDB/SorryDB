    Tn s t (-F n t + F n (t + 1)) = Tn s t (F (n + 1) t) := by
  have h : -F n t + F n (t + 1) = F (n + 1) t := by
    have h₁ : F (n + 1) t = -F n t + F n (t + 1) := by
      -- Use the recursive definition of F to prove the equality
      have h₂ : F (n + 1) t = -F n t + F n (t + 1) := by
        -- This is the recursive relation given in the problem statement
        cases n with
        | zero =>
          -- Base case: n = 0
          simp [F]
          <;>
          (try ring_nf) <;>
          (try norm_num) <;>
          (try linarith)
        | succ n =>
