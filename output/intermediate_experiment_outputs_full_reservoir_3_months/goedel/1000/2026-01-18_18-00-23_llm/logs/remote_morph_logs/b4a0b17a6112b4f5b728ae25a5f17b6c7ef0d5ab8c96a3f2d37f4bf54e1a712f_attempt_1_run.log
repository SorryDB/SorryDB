```lean
image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by
  rw [Function.funext_iff]
  intro s
  ext x
  have h₁ : ∀ (y : V), y ∈ image f s → g y ∈ s := by
    intro y hy
    rcases hy with ⟨z, hz, rfl⟩
    have h₂ : g (f z) = z := by
      have h₃ : (g ∘ f) z = z := by rw [h]; simp
      simpa using h₃
    have h₄ : z ∈ s := hz
    have h₅ : g (f z) ∈ s := by simpa [h₂] using h₄
    exact h₅
  have h₂ : ∀ (z : U), z ∈ s → f z ∈ image f s := by
    intro z hz
    exact ⟨z, hz, rfl⟩
  have h₃ : ∀ (z : U), z ∈ s → z ∈ image g (image f s) := by
    intro z hz
    have h₄ : f z ∈ image f s := h₂ z hz
    have h₅ : g (f z) ∈ s := h₁ (f z) h₄
    have h₆ : g (f z) = z := by
      have h₇ : (g ∘ f) z = z := by rw [h]; simp
      simpa using h₇
    have h₇ : z ∈ image g (image f s) := by
      have h₈ : g (f z) ∈ image g (image f s) := by
        apply mem_image_of_mem
        exact h₄
      simpa [h₆] using h₈
    exact h₇
  have h₄ : s ⊆ image g (image f s) := by
    intro x hx
    exact h₃ x hx
  have h₅ : image g (image f s) ⊆ s := by
    intro x hx
    rcases hx with ⟨y, hy, rfl⟩
    have h₆ : y ∈ image f s := hy
    have h₇ : g y ∈ s := h₁ y h₆
    exact h₇
  exact Set.Subset.antisymm h₄ h₅
