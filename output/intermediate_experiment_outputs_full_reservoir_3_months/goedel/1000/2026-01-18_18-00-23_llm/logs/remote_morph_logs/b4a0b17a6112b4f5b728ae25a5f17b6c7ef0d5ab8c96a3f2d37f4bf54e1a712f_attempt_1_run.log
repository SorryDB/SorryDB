theorem Exercise_8_1_5_1 {U V : Type}
    (h : U ∼ V) : Set U ∼ Set V := by
  -- We aim to show that the power sets of U and V are equinumerous if U and V are.
  -- Given h : U ∼ V, there exists a bijection f : U → V.
  -- We can lift this bijection to the power sets by considering the function which maps any subset of U
  -- to its image under f.
  -- Since f is a bijection, this lifted function is also a bijection.
  -- Therefore, Set U ∼ Set V.
  have h1 : Set U ∼ Set V := by
    -- Use the fact that the power sets of U and V are equinumerous if U and V are.
    exact h.pow 2
  -- The result follows directly from h1.
  exact h1
```

