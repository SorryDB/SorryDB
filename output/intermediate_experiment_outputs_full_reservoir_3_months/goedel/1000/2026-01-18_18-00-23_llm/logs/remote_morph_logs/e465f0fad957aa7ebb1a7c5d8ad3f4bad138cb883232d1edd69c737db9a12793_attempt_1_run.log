example [TopologicalSpace ╬▒] {x : ╬▒} {p p' q q' : ╬▒ έΗΤ Prop}
    (hT : {x | p x} έΙΙ ΏζΥζ x)
    (hT' : {x | p' x} έΙΙ ΏζΥζ x)
    (hS : {x | q x} έΙΙ ΏζΥζ x)
    (hS' : {x | q' x} έΙΙ ΏζΥζ x) :
    {x | p x έΙπ q x έΙρ p' x έΙπ q' x} έΙΙ ΏζΥζ x := by
  have h1 : {x : ╬▒ | p x έΙπ q x} έΙΙ ΏζΥζ x := by
    have h1 : {x : ╬▒ | p x} έΙΙ ΏζΥζ x := hT
    have h2 : {x : ╬▒ | q x} έΙΙ ΏζΥζ x := hS
    -- The intersection of two neighborhoods is a neighborhood
    have h3 : {x : ╬▒ | p x} έΙσ {x : ╬▒ | q x} έΙΙ ΏζΥζ x := by
      apply Filter.inter_mem
      <;> assumption
    -- The set {x | p x έΙπ q x} is the same as the intersection {x | p x} έΙσ {x | q x}
    have h4 : {x : ╬▒ | p x έΙπ q x} = {x : ╬▒ | p x} έΙσ {x : ╬▒ | q x} := by
      ext x
      simp [and_comm]
      <;> tauto
    rw [h4] at *
    exact h3
  have h2 : {x : ╬▒ | p' x έΙπ q' x} έΙΙ ΏζΥζ x := by
    have h1 : {x : ╬▒ | p' x} έΙΙ ΏζΥζ x := hT'
    have h2 : {x : ╬▒ | q' x} έΙΙ ΏζΥζ x := hS'
    -- The intersection of two neighborhoods is a neighborhood
    have h3 : {x : ╬▒ | p' x} έΙσ {x : ╬▒ | q' x} έΙΙ ΏζΥζ x := by
      apply Filter.inter_mem
      <;> assumption
    -- The set {x | p' x έΙπ q' x} is the same as the intersection {x | p' x} έΙσ {x | q' x}
    have h4 : {x : ╬▒ | p' x έΙπ q' x} = {x : ╬▒ | p' x} έΙσ {x : ╬▒ | q' x} := by
      ext x
      simp [and_comm]
      <;> tauto
    rw [h4] at *
    exact h3
  -- The union of two neighborhoods is a neighborhood
  have h3 : {x : ╬▒ | p x έΙπ q x έΙρ p' x έΙπ q' x} έΙΙ ΏζΥζ x := by
    have h4 : {x : ╬▒ | p x έΙπ q x} έΙς {x : ╬▒ | p' x έΙπ q' x} έΙΙ ΏζΥζ x := by
      apply Filter.union_mem
      <;> assumption
    -- The set {x | p x έΙπ q x έΙρ p' x έΙπ q' x} is the same as the union {x | p x έΙπ q x} έΙς {x | p' x έΙπ q' x}
    have h5 : {x : ╬▒ | p x έΙπ q x έΙρ p' x έΙπ q' x} = {x : ╬▒ | p x έΙπ q x} έΙς {x : ╬▒ | p' x έΙπ q' x} := by
      ext x
      simp [or_comm]
      <;> tauto
    rw [h5] at *
    exact h4
  exact h3

end Filter

