theorem Completeness_IFFT (F : Type) [Field F] {n : ℕ} [PowCard n] (s : Finset (Fin n)) (D : DepRing F (PowCard n))
    (D' : DepRing F (PowCard n)) [CommSemiring (D (n / 2))] [CommSemiring (D' (n / 2))] (h₁ : s.card = 1) :
    (D.sum s (a : Fin n) => 1 : D n) = 1 := by
