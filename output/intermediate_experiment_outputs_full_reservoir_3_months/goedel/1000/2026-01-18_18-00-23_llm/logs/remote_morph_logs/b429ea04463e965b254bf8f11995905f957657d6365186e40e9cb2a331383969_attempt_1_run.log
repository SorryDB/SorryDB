theorem custom_workbook_plus_40687 (a : ℝ) :
  (∃ x y : ℝ, x * y = a ∧ x + y = a) ↔ a ≥ 4 ∨ a ≤ 0 := by
  constructor
  · -- Prove the forward direction: if ∃x, y such that xy = a and x + y = a, then a ≥ 4 ∨ a ≤ 0
    intro h
    have h₁ : a ≥ 4 ∨ a ≤ 0 := by
      by_contra! h₂
      -- Assume 0 < a < 4 and derive a contradiction
      have h₃ : 0 < a := by linarith
      have h₄ : a < 4 := by linarith
      -- Extract x and y from the hypothesis
      rcases h with ⟨x, y, h₅, h₆⟩
      -- Use the quadratic equation to find a contradiction
      have h₇ : (x - y) ^ 2 ≥ 0 := by nlinarith
      have h₈ : (x + y) ^ 2 - 4 * (x * y) ≥ 0 := by nlinarith
      have h₉ : a ^ 2 - 4 * a < 0 := by nlinarith
      nlinarith [sq_nonneg (x - y)]
    exact h₁
  · -- Prove the reverse direction: if a ≥ 4 ∨ a ≤ 0, then ∃x, y such that xy = a and x + y = a
    intro h
    cases h with
    | inl h =>
      -- Case: a ≥ 4
      -- Choose x = a / 2 + sqrt((a / 2)^2 - a) and y = a / 2 - sqrt((a / 2)^2 - a)
      have h₁ : a ≥ 4 := h
      have h₂ : (a / 2 : ℝ) ^ 2 - a ≥ 0 := by
        nlinarith
      use (a / 2 : ℝ) + Real.sqrt ((a / 2 : ℝ) ^ 2 - a)
      use (a / 2 : ℝ) - Real.sqrt ((a / 2 : ℝ) ^ 2 - a)
      constructor
      · -- Prove xy = a
        nlinarith [Real.sq_sqrt (by nlinarith : (0 : ℝ) ≤ (a / 2 : ℝ) ^ 2 - a)]
      · -- Prove x + y = a
        nlinarith [Real.sq_sqrt (by nlinarith : (0 : ℝ) ≤ (a / 2 : ℝ) ^ 2 - a)]
    | inr h =>
      -- Case: a ≤ 0
      -- Choose x = 0 and y = a
      have h₁ : a ≤ 0 := h
      use 0, a
      constructor
      · -- Prove xy = a
        nlinarith
      · -- Prove x + y = a
        nlinarith
