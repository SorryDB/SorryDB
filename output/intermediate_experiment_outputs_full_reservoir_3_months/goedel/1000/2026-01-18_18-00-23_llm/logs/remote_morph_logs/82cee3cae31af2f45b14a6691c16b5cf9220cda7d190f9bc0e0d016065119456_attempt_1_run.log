def toResolutionOfIdentity : ResolutionOfIdentity (spectrum ℂ a) H where
  measureOf' s := InnerProductSpace.continuousLinearMapOfBilin
    (@toBoundedBilin H inst✝² inst✝¹ inst✝ a ha 1 (Set.indicator s (1 : (spectrum ℂ a) → ℂ)))
  isOrthogonalProjection' := by
    intro s
    have h₁ : IsOrthogonalProjection (InnerProductSpace.continuousLinearMapOfBilin (@toBoundedBilin H inst✝² inst✝¹ inst✝ a ha 1 (Set.indicator s (1 : (spectrum ℂ a) → ℂ)))) := by
      refine' isOrthogonalProjection_iff_apply.mpr ⟨fun x ↦ _, fun x ↦ _⟩
      · -- Prove that the operator is self-adjoint
        simp [InnerProductSpace.continuousLinearMapOfBilin, toBoundedBilin]
        <;>
        aesop
      · -- Prove that the operator is idempotent
        simp [InnerProductSpace.continuousLinearMapOfBilin, toBoundedBilin]
        <;>
        aesop
    exact h₁
