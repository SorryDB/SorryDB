theorem Exercise_8_1_5_2 {U V : Type} {A : Set U} {B : Set V}
    (h : A ∼ B) : 𝒫 A ∼ 𝒫 B := by
  have h₁ : (A : Type) ∼ (B : Type) := by
    exact h
  have h₂ : Set (A : Type) ∼ Set (B : Type) := by
    exact Set_equinum_powerset
  have h₃ : Set (A : Type) ∼ 𝒫 A := by
    -- Prove that the powerset of A is equivalent to the set of subsets of A
    have h₄ : Set (A : Type) ≃ 𝒫 A := by
      -- Construct the equivalence between Set A and 𝒫 A
      let f : Set (A : Type) → 𝒫 A := fun s => ⟨s, by exact Set.Subset.refl _⟩
      let g : 𝒫 A → Set (A : Type) := fun s => s.val
      refine' ⟨f, g, _, _, _⟩ <;> simp_all [Set.ext_iff]
      <;> aesop
    -- Use the equivalence to show the equinumerosity
    exact h₄.equinum
  have h₄ : Set (B : Type) ∼ 𝒫 B := by
    -- Similarly for B
    have h₅ : Set (B : Type) ≃ 𝒫 B := by
      -- Construct the equivalence between Set B and 𝒫 B
      let f : Set (B : Type) → 𝒫 B := fun s => ⟨s, by exact Set.Subset.refl _⟩
      let g : 𝒫 B → Set (B : Type) := fun s => s.val
      refine' ⟨f, g, _, _, _⟩ <;> simp_all [Set.ext_iff]
      <;> aesop
    -- Use the equivalence to show the equinumerosity
    exact h₅.equinum
  -- Combine all the equivalences to get the final result
  have h₅ : 𝒫 A ∼ 𝒫 B := by
    calc
      𝒫 A ∼ Set (A : Type) := h₃.symm
      _ ∼ Set (B : Type) := h₂
      _ ∼ 𝒫 B := h₄
  exact h₅
``` 

