theorem Exercise_8_1_5_2 {U V : Type} {A : Set U} {B : Set V}
    (h : A ∼ B) : 𝒫 A ∼ 𝒫 B := by
  obtain ⟨f, g, _, _⟩ := h
  -- Use the bijection between A and B to construct a bijection between their powersets
  have h₁ : 𝒫 A ∼ 𝒫 B := by
    -- Define the function that maps a subset of A to a subset of B using the bijection f
    have h₂ : Set A ∼ Set B := by
      -- Use the fact that A ∼ B to show that Set A ∼ Set B
      simpa using Set_equinum_powerset A |>.trans (Set_equinum_powerset B).symm.trans (h.equiv.toEquiv)
    -- Convert the equivalence of sets to the equivalence of powersets
    simpa [Set.ext_iff] using h₂
  -- The final result follows from the constructed bijection
  exact h₁
``` 

