theorem Exercise_8_1_5_2 {U V : Type} {A : Set U} {B : Set V}
    (h : A ∼ B) : 𝒫 A ∼ 𝒫 B := by
  have h1 : Set A ∼ Set B := by
    -- Since A and B are equinumerous, their sets are also equinumerous.
    apply Set_equinum
    <;> simpa [SetLike.coe_equiv] using h
  -- The power sets of A and B are isomorphic because their sets are isomorphic.
  apply h1
  <;> simp [SetLike.coe_equiv]
  <;> aesop
```
