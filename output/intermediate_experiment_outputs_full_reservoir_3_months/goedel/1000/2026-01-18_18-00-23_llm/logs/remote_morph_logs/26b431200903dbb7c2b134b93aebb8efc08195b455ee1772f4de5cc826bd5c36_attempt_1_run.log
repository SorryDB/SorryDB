def table_elevation (n : ℕ) : List (ℝ × ℝ × ℝ) :=
  List.range n |>
  (List.map (fun t : ℕ =>
    (t : ℝ),
    elevation (t : ℝ),
    horizontal_distance (elevation (t : ℝ))
  )) |>
  (List.map (fun tuple : ℝ × ℝ × ℝ =>
    (tuple.1, tuple.2, tuple.3)
  ))

variable (h : ℝ)
