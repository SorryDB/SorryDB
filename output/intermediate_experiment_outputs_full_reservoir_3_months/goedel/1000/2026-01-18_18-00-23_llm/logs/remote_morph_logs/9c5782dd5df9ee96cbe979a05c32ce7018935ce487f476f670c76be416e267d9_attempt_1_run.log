def CategoryInContext.Category.Subcategory.mono : Subcategory α where
  obj := fun X => True
  hom := fun f => Mono f
  id_mem X := by
    simp [Category.id_comp, Category.comp_id]
    <;> intros <;> simp_all [Function.funext_iff]
    <;> aesop
  comp_mem hX hY hZ hf hg := by
    intros X Y Z f g hf hg
    have h₁ : Mono (f ≫ g) := by
      apply Category.comp_mono_of_mono_mono
      · exact hf
      · exact hg
    exact h₁

def CategoryInContext.Category.Subcategory.epi : Subcategory α where
  obj := fun X => True
  hom := fun f => Epi f
  id_mem X := by
    simp [Category.id_comp, Category.comp_id]
    <;> intros <;> simp_all [Function.funext_iff]
    <;> aesop
  comp_mem hX hY hZ hf hg := by
