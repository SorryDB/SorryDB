theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : @CategoryInContext.Category.Mono α C X Y f)
    (he : @CategoryInContext.Category.split_epi α C X Y f) : IsIso f := by
  -- Use the fact that f is a split epimorphism to get a retraction g such that f ≫ g = id
  have h₁ : ∃ (g : Hom Y X), f ≫ g = id := by
    obtain ⟨g, hg⟩ := he
    exact ⟨g, hg⟩
  obtain ⟨g, hg⟩ := h₁
  -- Show that g is a two-sided inverse of f
  have h₂ : g ≫ f = id := by
    apply hm
    -- Since f is monic, we have g ≫ f = id' ≫ f, so by monicity, g ≫ f = id'
    calc
      g ≫ f = g ≫ f := rfl
      _ = g ≫ f := rfl
  -- Conclude that f is an isomorphism with inverse g
  refine' ⟨g, _⟩
  ext
  <;> simp_all [hg, h₂]
  <;> rw [← comp_assoc] <;> simp_all [id_comp]
  <;> rfl
  <;> simp_all [comp_id, id_comp]
  <;> rfl
