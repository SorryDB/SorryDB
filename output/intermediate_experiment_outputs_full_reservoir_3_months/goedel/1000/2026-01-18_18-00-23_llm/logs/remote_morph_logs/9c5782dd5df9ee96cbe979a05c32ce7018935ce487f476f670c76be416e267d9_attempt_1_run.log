```lean
theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  rcases he with ⟨g, hg⟩
  have h1 : f ≫ g = id X := hg
  have h2 : g ≫ f = id Y := by
    apply hm
    calc
      g ≫ f ≫ g = id Y ≫ g := by
        calc
          g ≫ f ≫ g = g ≫ (f ≫ g) := by rw [← comp_assoc]
          _ = g ≫ (id X) := by rw [h1]
          _ = g := by simp
          _ = id Y ≫ g := by simp
      _ = g := by simp
      _ = id Y ≫ g := by simp
