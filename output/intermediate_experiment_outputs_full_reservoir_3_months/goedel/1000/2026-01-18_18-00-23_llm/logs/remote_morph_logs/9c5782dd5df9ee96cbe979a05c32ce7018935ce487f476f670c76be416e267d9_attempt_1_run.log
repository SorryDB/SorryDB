theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  have h : IsIso f := by
    obtain ⟨g, hg⟩ := he
    have h1 : IsLeftInverse g f := by
      rw [IsLeftInverse] at *
      exact hg
    have h2 : IsRightInverse g f := by
      apply hm
      rw [IsRightInverse] at *
      simp_all [comp_assoc]
      <;> try aesop
      <;> try simp_all [comp_assoc]
      <;> try aesop
    exact ⟨g, h1, h2⟩
  exact h
