theorem CategoryInContext.Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : @Mono α C X Y f) (he : @split_epi α C X Y f) : IsIso f := by
  obtain ⟨g, hg⟩ := he
  have h₁ : IsLeftInverse g f := by
    have h₂ : f ≫ g = id X := by
      simpa [Function.comp] using hg
    simpa [Function.comp] using h₂
  have h₂ : IsRightInverse g f := by
    have h₃ : Mono f := hm
    have h₄ : IsLeftInverse g f := h₁
    -- Use the fact that f is a monomorphism and g is a right inverse
    have h₅ : g ≫ f = id X := by
      have h₆ : f ≫ g = id X := by simpa [Function.comp] using hg
      have h₇ : g ≫ f = id X := by
        calc
          g ≫ f = g ≫ f := rfl
          _ = id X := by
            -- Use the monomorphism property to cancel f
            have h₈ : f ≫ g = id X := by simpa [Function.comp] using hg
            have h₉ : f ≫ (g ≫ f) = f := by
              calc
                f ≫ (g ≫ f) = (f ≫ g) ≫ f := by rw [Category.assoc]
                _ = (id X) ≫ f := by rw [h₈]
                _ = f := by simp
            have h₁₀ : f ≫ (id X) = f := by simp
            have h₁₁ : g ≫ f = id X := by
              apply h₃
              calc
                f ≫ (g ≫ f) = f := h₉
                _ = f ≫ (id X) := by simp
            exact h₁₁
      exact h₇
    simpa [Function.comp] using h₅
  -- Now we have both left and right inverses, so f is an isomorphism
  refine' ⟨g, _, _⟩
  · exact h₂
  · exact h₁
