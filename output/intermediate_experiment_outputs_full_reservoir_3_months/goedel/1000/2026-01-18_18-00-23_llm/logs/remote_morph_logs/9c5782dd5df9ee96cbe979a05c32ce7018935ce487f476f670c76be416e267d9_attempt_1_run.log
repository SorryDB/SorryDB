theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  obtain ⟨g, hg⟩ := he
  refine' ⟨g, _⟩
  constructor
  · -- Prove that f ≫ g = id X
    exact hg
  · -- Prove that g ≫ f = id Y using the fact that f is mono and g ≫ f = id Y
    have h1 : g ≫ f = id Y := by
      have h2 : f ≫ g = id X := hg
      have h3 : g ≫ f = id Y := by
        -- Use the fact that f is mono to deduce g ≫ f = id Y
        have h4 : Mono f := hm
        have h5 : Epi f := by
          have h6 : ∀ c : α, Function.Injective (fun g : Hom Y c => f ≫ g) := by
            intro c
            exact Category.Epi_surjection f (by
              -- Prove that f is epi using the split epic condition
              obtain ⟨g', hg'⟩ := he
              have h7 : Epi f := by
                intro c h8 h9
                have h10 : f ≫ h8 = f ≫ h9 := by assumption
                have h11 : h8 = h9 := by
                  -- Use the fact that f is mono to deduce h8 = h9
                  have h12 : Mono f := hm
                  have h13 : f ≫ h8 = f ≫ h9 := by assumption
                  exact hm (by assumption)
                exact h11
              exact h7)
            <;> simp_all
          have h8 : Epi f := by
            intro Z h9 h10
            have h11 : f ≫ h9 = f ≫ h10 := by assumption
            have h12 : Function.Injective (fun g : Hom Y Z => f ≫ g) := h6 Z
            have h13 : (fun g : Hom Y Z => f ≫ g) h9 = (fun g : Hom Y Z => f ≫ g) h10 := by simp_all
            have h14 : h9 = h10 := h12 h13
            exact h14
          exact h8
        -- Use the fact that f is epi to deduce g ≫ f = id Y
        have h9 : Epi f := h5
        have h10 : Function.Injective (fun g : Hom Y Y => f ≫ g) := by
          apply Category.Epi_surjection f h9
        have h11 : (fun g : Hom Y Y => f ≫ g) (g ≫ f) = (fun g : Hom Y Y => f ≫ g) (id Y) := by
          calc
            (fun g : Hom Y Y => f ≫ g) (g ≫ f) = f ≫ (g ≫ f) := rfl
            _ = (f ≫ g) ≫ f := by rw [← assoc]
            _ = (id X) ≫ f := by rw [hg]
            _ = f := by simp
            _ = f ≫ id Y := by simp
            _ = (fun g : Hom Y Y => f ≫ g) (id Y) := rfl
        have h12 : g ≫ f = id Y := by
          apply h10
          exact h11
        exact h12
      exact h3
    exact h1
