  have h₁ : (u / v : RingOfIntegers K) + 1 = (u / v : RingOfIntegers K) + 1 := rfl
  have h₂ : (algebraMap (RingOfIntegers K) K) ↑u / ↑↑v + (algebraMap (RingOfIntegers K) K) ↑u / (algebraMap (RingOfIntegers K) K) ↑u = (algebraMap (RingOfIntegers K) K) ↑u / ↑↑v + (algebraMap (RingOfIntegers K) K) ↑u / (algebraMap (RingOfIntegers K) K) ↑u := rfl
  have h₃ : (algebraMap (RingOfIntegers K) K) ↑u / (algebraMap (RingOfIntegers K) K) ↑u = 1 := by
    have h₄ : (algebraMap (RingOfIntegers K) K) ↑u ≠ 0 := by
      intro h₅
      have h₆ : (↑u : K) = 0 := by simpa using h₅
      have h₇ : (u : K) ≠ 0 := by
        intro h₈
        have h₉ : (u : (RingOfIntegers K)ˣ) = 1 := by
          -- Since u is a unit, its inverse exists. If u were 0, then its inverse would not exist, leading to a contradiction.
          have h₁₀ : (u : (RingOfIntegers K)ˣ) = 1 := by
            simp_all [Units.ext_iff]
          simp_all [Units.ext_iff]
        simp_all [Units.ext_iff]
      contradiction
    field_simp [h₄]
    <;> simp_all [Units.ext_iff]
    <;> norm_cast
    <;> simp_all [Units.ext_iff]
  have h₄ : (algebraMap (RingOfIntegers K) K) ↑u / ↑↑v = (u : K) / (v : K) := by
    simp_all [Units.ext_iff]
    <;> norm_cast
    <;> field_simp
    <;> ring_nf
    <;> simp_all [Units.ext_iff]
