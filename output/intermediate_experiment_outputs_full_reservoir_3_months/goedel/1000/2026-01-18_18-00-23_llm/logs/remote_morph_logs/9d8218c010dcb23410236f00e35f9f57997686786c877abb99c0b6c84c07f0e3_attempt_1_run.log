import Mathlib


open scoped Affine Finset
open Module

namespace IMO2025P1

/-- The `x`-axis, as an affine subspace. -/
noncomputable def xAxis : AffineSubspace ‚ĄĚ (EuclideanSpace ‚ĄĚ (Fin 2)) where
  carrier := {p | p 1 = 0}
  smul_vsub_vadd_mem c p‚āĀ p‚āā p‚āÉ hp‚āĀ hp‚āā hp‚āÉ := by simp_all

/-- The `y`-axis, as an affine subspace. -/
noncomputable def yAxis : AffineSubspace ‚ĄĚ (EuclideanSpace ‚ĄĚ (Fin 2)) where
  carrier := {p | p 0 = 0}
  smul_vsub_vadd_mem c p‚āĀ p‚āā p‚āÉ hp‚āĀ hp‚āā hp‚āÉ := by simp_all

/- The line `x+y=0`, as an affine subspace. -/
noncomputable def linexy0 : AffineSubspace ‚ĄĚ (EuclideanSpace ‚ĄĚ (Fin 2)) where
  carrier := {p | p 0 + p 1 = 0}
  smul_vsub_vadd_mem c p‚āĀ p‚āā p‚āÉ hp‚āĀ hp‚āā hp‚āÉ := by
    simp only [Fin.isValue, vsub_eq_sub, vadd_eq_add, Set.mem_setOf_eq, PiLp.add_apply,
      PiLp.smul_apply, PiLp.sub_apply, smul_eq_mul]
    suffices c * (p‚āĀ 0 + p‚āĀ 1 - (p‚āā 0 + p‚āā 1)) + (p‚āÉ 0 + p‚āÉ 1) = 0 by
      rw [‚Üź this]
      ring
    simp_all

/-- The condition on lines in the problem. -/
def Sunny (s : AffineSubspace ‚ĄĚ (EuclideanSpace ‚ĄĚ (Fin 2))) : Prop :=
   ¬¨ s ‚ą• xAxis ‚ąß ¬¨ s ‚ą• yAxis ‚ąß ¬¨ s ‚ą• linexy0

