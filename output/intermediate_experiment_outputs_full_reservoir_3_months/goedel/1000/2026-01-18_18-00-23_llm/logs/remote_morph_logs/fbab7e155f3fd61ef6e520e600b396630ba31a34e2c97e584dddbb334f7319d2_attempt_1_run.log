lemma valuation_ringEquiv {L : Type*} [Field L] [ValuativeRel L] [TopologicalSpace L]
    [IsNonarchimedeanLocalField L] (e : L ≃+* L) (x : L) :
    valuation L (e x) = valuation L x := by
  have h₁ : valuation L (e x) = valuation L x := by
    apply val_eq_val_iff_dense_normed_field.suffices
    · simp [e.map_zero, e.map_one]
      <;>
      simp_all [e.map_mul, e.map_add]
      <;>
      norm_num
    · -- Prove that the map is bijective and preserves the valuation
      have h₂ : Function.Bijective (e : L → L) := e.bijective
      have h₃ : ∀ (x : L), ‖e x‖ = ‖x‖ := by
        intro x
        have h₄ : ‖e x‖ = ‖x‖ := by
          -- Since e is an automorphism of the field, it preserves the norm
          simp_all [IsNonarchimedeanLocalField.norm_eq_val, val_eq_val_iff_dense_normed_field]
          <;>
          norm_num
          <;>
          aesop
        exact h₄
      -- Use the fact that the map preserves the norm to conclude
      exact fun x y h => by
        have h₅ : ‖e x‖ = ‖e y‖ := by
          simp_all [h₃]
        simp_all [h₃]
  exact h₁

instance (G : Type*) [Group G] (L : Type*) [Field L] [TopologicalSpace L] [ValuativeRel L]
    [IsNonarchimedeanLocalField L] [MulSemiringAction G L] : MulSemiringAction G 𝒪[L] where
  smul g r := ⟨g • r.1, by
    obtain ⟨r, hr⟩ := r
    rw [Valuation.mem_integer_iff] at hr
    have h₁ : valuation L (g • r : L) = valuation L r := by
      -- Use the fact that the group action preserves the valuation
      have h₂ : valuation L (g • r : L) = valuation L r := by
        -- Since g is in the group, the valuation is preserved
        have h₃ : (g : L ≃+* L) := by
          -- Convert the group action to an automorphism
          exact (MulSemiringAction.toRingEquiv G L g)
        -- Use the previously proven lemma to get the valuation preservation
        simpa using valuation_ringEquiv h₃ r
      exact h₂
    -- Combine the results to show that g • r is in the valuation ring
