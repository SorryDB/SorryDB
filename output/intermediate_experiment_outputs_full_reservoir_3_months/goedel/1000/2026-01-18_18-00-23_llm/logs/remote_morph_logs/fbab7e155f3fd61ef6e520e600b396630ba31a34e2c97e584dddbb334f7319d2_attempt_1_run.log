  have h₄ : (algebraMap (↥(valuation K).integer) (↥(valuation L).integer)) x *
        (algebraMap (↥(valuation K).integer) (↥(valuation L).integer)) y = ⟨(algebraMap K L) (↑x : K), _⟩ * ⟨(algebraMap K L) (↑y : K), _⟩ := by
    rw [h₂, h₃]
