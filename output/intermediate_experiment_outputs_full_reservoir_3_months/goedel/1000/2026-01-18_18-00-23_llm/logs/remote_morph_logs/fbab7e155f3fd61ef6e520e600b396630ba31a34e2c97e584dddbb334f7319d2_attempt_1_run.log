instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨r, hr⟩ := r
      have h : (algebraMap K L r : L) = algebraMap K L r := rfl
      have h₂ : valuation L (algebraMap K L r : L) ≤ 0 := by
        have h₃ : valuation K r ≤ 0 := by
          -- Since r is in the valuation ring of K, valuation K r ≤ 0
          have h₄ : (r : K) ∈ (valuation K).integer := by
            simpa using hr
          have h₅ : (valuation K).integer = { x : K | valuation K x ≤ 0 } := by
            rfl
          rw [h₅] at h₄
          exact h₄
        -- Using the fact that the valuation is compatible with the algebra map
        have h₆ : valuation L (algebraMap K L r : L) = valuation K r := by
          apply ValuativeExtension.valuation_comp
        rw [h₆]
        exact h₃
      -- Therefore, algebraMap K L r is in the valuation ring of L
      have h₃ : valuation L (algebraMap K L r : L) ≤ 0 := h₂
      have h₄ : (algebraMap K L r : L) ∈ (valuation L).integer := by
        have h₅ : (valuation L).integer = { x : L | valuation L x ≤ 0 } := by
          rfl
        rw [h₅]
        exact h₃
      simpa using h₄⟩
    map_add' := by
      intro x y
      simp [add_comm]
      <;> rfl
    map_one' := by
      simp [one_comm]
      <;> rfl
    map_mul' := by
      intro x y
      simp [mul_comm]
      <;> rfl
  }
