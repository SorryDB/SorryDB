theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  have h : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
    -- Observe that the set {n : ℕ | (n : K) ≠ 0} is exactly the image of the natural map ℕ → K
    have h₁ : {n : ℕ | (n : K) ≠ 0} = {n : ℕ | (n : K) ≠ 0} := rfl
    -- For a finite field K, the only cyclotomic extension is the algebraic closure
    have h₂ : IsCyclotomicExtension {n : ℕ | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
      -- Use the fact that the cyclotomic extension of a finite field is its algebraic closure
      have h₃ : IsAlgebraic K L := by
        -- L is finite-dimensional over K because K is finite
        have h₄ : FiniteDimensional K L := by
          -- Since L is algebraic over K and finite-dimensional, it is finite
          have : Finite L := by
            -- L is a finite field because it is a finite-dimensional vector space over a finite field
            infer_instance
          -- Use the fact that L is finite to show that it is finite-dimensional over K
          exact FiniteDimensional.of_fintype
        -- Use the fact that L is finite-dimensional over K to show that it is algebraic over K
        exact h₄.isAlgebraic
      -- Use the fact that L is algebraic over K to show that the cyclotomic extension condition is equivalent to L being the algebraic closure of K
      have h₅ : IsCyclotomicExtension {n : ℕ | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
        -- Use the fact that the cyclotomic extension of a finite field is its algebraic closure
        haveI : IsPerfectRing K := by
          -- K is a perfect field because it is finite
          exact ⟨fun x => by
            -- Every element of K is a pth power because K is finite
            have h₆ : ∀ x : K, ∃ y : K, y ^ (CharP.char K) = x := by
              intro x
              -- Use the fact that the map y ↦ y^p is bijective
              have h₇ : Function.Surjective (fun y : K => y ^ (CharP.char K)) := by
                -- Use the fact that the map y ↦ y^p is bijective
                have h₈ : Function.Bijective (fun y : K => y ^ (CharP.char K)) := by
                  -- Use the fact that the map y ↦ y^p is bijective
                  apply bijective_pow_char
                  <;> simp_all [CharP.char_pos]
                -- Extract surjectivity from bijectivity
                exact h₈.2
              -- Use surjectivity to find y such that y^p = x
              obtain ⟨y, hy⟩ := h₇ x
              exact ⟨y, hy⟩
            -- Obtain y such that y^p = x
            obtain ⟨y, hy⟩ := h₆ x
            -- Use y to show that x is a pth power
            exact ⟨y, by simp_all [pow_char]⟩,⟩
        -- Use the fact that L is algebraic over K to show that the cyclotomic extension condition is equivalent to L being the algebraic closure of K
        simp_all [IsCyclotomicExtension, IsAlgClosure]
        <;>
          (try
            {
              aesop
            }) <;>
          (try
            {
              simp_all [IsCyclotomicExtension, IsAlgClosure]
              <;>
                aesop
            }) <;>
          (try
            {
              field_simp at *
              <;>
                aesop
            })
      -- The final equivalence
      exact h₅
    -- The final equivalence
    exact h₂
  -- The final equivalence
  exact h
