theorem has_least_upper_bound_of_bdd_nonempty {S : Set ℝ} (hS : S.Nonempty) {M : ℝ} (hM : IsUB S M) : ∃ L, IsLUB S L := by
  have h_main : ∃ L, IsLUB S L := by
    classical
    -- Use the supremum of S as the least upper bound
    have h₁ : BddAbove S := by
      refine' ⟨M, _⟩
      intro x hx
      exact hM x hx
    -- Use the fact that the real numbers have the least upper bound property
    have h₂ : ∃ L, IsLUB S L := by
      use sSup S
      constructor
      · -- Prove that sSup S is an upper bound
        exact csSup_le (Set.nonempty_iff_ne_empty.mpr (by
          intro h
          rw [h] at hS
          exact Set.not_nonempty_empty hS)) (by simpa using h₁)
      · -- Prove that sSup S is the least upper bound
        intro M' hM'
        exact le_csSup (by simpa using h₁) (hM')
    -- The result follows from the existence of sSup S
    exact h₂
  -- The main result follows directly from h_main
  exact h_main
