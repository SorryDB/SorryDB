theorem OMR_problem_39265 : 
  (∀ (a b c d : ℕ), a ≥ b ∧ a < c ∧ a < d ∧ c < d →
    (d - a : ℕ) ≥ 2) ∧
  (∀ (a b c d : ℕ), a < b ∧ a < c ∧ b < d ∧ c < d →
    (d - a : ℕ) ≥ 3) := by
  have h₁ : ∀ (a b c d : ℕ), a ≥ b ∧ a < c ∧ a < d ∧ c < d → (d - a : ℕ) ≥ 2 := by
    intro a b c d h
    have h₂ : a < c := h.2.1
    have h₃ : a < d := h.2.2.1
    have h₄ : c < d := h.2.2.2
    have h₅ : d ≥ c + 1 := by
      omega
    have h₆ : d ≥ a + 2 := by
      omega
    have h₇ : (d - a : ℕ) ≥ 2 := by
      have h₈ : d ≥ a + 2 := h₆
      have h₉ : (d : ℕ) - a ≥ 2 := by
        omega
      exact h₉
    exact h₇
  
  have h₂ : ∀ (a b c d : ℕ), a < b ∧ a < c ∧ b < d ∧ c < d → (d - a : ℕ) ≥ 3 := by
    intro a b c d h
    have h₃ : a < b := h.1
    have h₄ : a < c := h.2.1
    have h₅ : b < d := h.2.2.1
    have h₆ : c < d := h.2.2.2
    have h₇ : d ≥ b + 1 := by
      omega
    have h₈ : d ≥ a + 2 := by
      omega
    have h₉ : d ≥ a + 3 := by
      omega
    have h₁₀ : (d - a : ℕ) ≥ 3 := by
      have h₁₁ : d ≥ a + 3 := h₉
      have h₁₂ : (d : ℕ) - a ≥ 3 := by
        omega
      exact h₁₂
    exact h₁₀
  
  exact ⟨h₁, h₂⟩
