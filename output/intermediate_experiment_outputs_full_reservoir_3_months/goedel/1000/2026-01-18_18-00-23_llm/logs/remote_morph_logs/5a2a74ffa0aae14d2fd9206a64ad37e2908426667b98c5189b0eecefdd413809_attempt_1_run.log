namespace DirectSumDecomposition

protected lemma sSupIndep (D : DirectSumDecomposition M) : sSupIndep (SetLike.coe D) := D.sSupIndep'
lemma sSup_eq_top (D : DirectSumDecomposition M) : sSup (SetLike.coe D) = ⊤ := D.sSup_eq_top'
lemma not_bot_mem (D : DirectSumDecomposition M) : ⊥ ∉ D := D.not_bot_mem'

lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h : ⨆ p ∈ D, p x = ⊤ := by
    have h₁ : ⨆ p ∈ D, p x = (⨆ p ∈ D, p) x := by
      apply congr_arg (fun p => p x)
      -- The pointwise supremum is equal to the supremum of the families evaluated at x
      <;> simp [iSup_set, funext]
      <;> rfl
    rw [h₁]
    have h₂ : (⨆ p ∈ D, p) = ⊤ := by
      -- The supremum of the family is the entire module
      have h₃ : sSup (SetLike.coe D) = ⊤ := sSup_eq_top D
      simpa [sSup_eq_iSup] using h₃
    rw [h₂]
    -- Since the entire module evaluated at x is the entire space, we have the result
    <;> simp [Submodule.top']
  exact h

lemma pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := by
  have h : ⨆ p ∈ D, p x = ⊤ := by
    have h₁ : ⨆ p ∈ D, p x = (⨆ p ∈ D, p) x := by
      apply congr_arg (fun p => p x)
      <;> simp [iSup_set, funext]
      <;> rfl
    rw [h₁]
    have h₂ : (⨆ p ∈ D, p) = ⊤ := by
      have h₃ : sSup (SetLike.coe D) = ⊤ := sSup_eq_top D
      simpa [sSup_eq_iSup] using h₃
    rw [h₂]
    <;> simp [Submodule.top']
  exact h

open scoped Classical in
lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor
  · -- Prove iSupIndep
    have h₁ : iSupIndep fun p : I => (p.val : PersistenceSubmodule M) := by
      -- Use the sSupIndep property from the direct sum decomposition
      have h₂ : sSupIndep (SetLike.coe I) := sSupIndep I
      -- Convert sSupIndep to iSupIndep
      have h₃ : iSupIndep fun p : I => (p.val : PersistenceSubmodule M) := by
        -- Use the fact that the carrier set of I is the image of the canonical map
        -- and that sSupIndep implies iSupIndep
        convert IICS_iSupIndep (fun p : I => (p.val : PersistenceSubmodule M)) (by simp [SetLike.ext_iff]) h₂ using 1
        <;> simp [SetLike.coe]
