  have h₁ : (⨆ p : (p : p ∈ D), p : PersistenceSubmodule M) = ⊤ := by
    have h₂ : sSup (D : Set (PersistenceSubmodule M)) = ⊤ := D.sSup_eq_top'
    have h₃ : (⨆ p : (p : p ∈ D), p : PersistenceSubmodule M) = sSup (D : Set (PersistenceSubmodule M)) := by
