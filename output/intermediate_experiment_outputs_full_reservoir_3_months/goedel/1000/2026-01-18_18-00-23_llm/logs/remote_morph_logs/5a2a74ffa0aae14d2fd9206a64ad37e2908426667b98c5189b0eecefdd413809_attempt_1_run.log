    · have h₁ : sSupIndep (SetLike.coe I) := I.sSupIndep'
      -- Since `I` is a DirectSumDecomposition, it is independent.
      -- We need to show that the family of images of the submodules under the point `c` is independent.
      -- This follows from the fact that the original family of submodules is independent and the map is pointwise linear.
      exact sSupIndep.image (fun p : (I : Set (PersistenceSubmodule M)) => p c)
    · have h₂ : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
      -- Since `I` is a DirectSumDecomposition, the supremum of its submodules is the entire module.
      -- We need to show that the supremum of the images of the submodules under the point `c` is the entire space at that point.
      -- This follows because the map is pointwise surjective.
      have h₃ : (sSup (SetLike.coe I)).c = ⊤ := by
        rw [h₂]
        <;> simp
      -- Converting the supremum of the images to the image of the supremum, we get the desired result.
      simp_all [iSup_coe_sort_eq_coe_iSup]
      <;>
      (try aesop)
      <;>
      (try simp_all [iSup_coe_sort_eq_coe_iSup])
      <;>
      (try aesop)
