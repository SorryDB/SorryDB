open scoped Classical in
lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor
  · -- Prove that the family of submodules is independent
    have h : sSupIndep (SetLike.coe I) := I.sSupIndep'
    have h₁ : iSupIndep fun (p : I) => (p.val : PersistenceSubmodule M) := by
      -- Use the fact that the supremum of the family is independent to deduce the independence of the indexed family
      have h₂ : sSupIndep (SetLike.coe I) := I.sSupIndep'
      have h₃ : iSupIndep fun (p : I) => (p.val : PersistenceSubmodule M) := by
        -- Convert the set-indexed independence to indexed family independence
        have h₄ : sSupIndep (Set.range (fun (p : I) => (p.val : PersistenceSubmodule M))) := by
          -- The supremum of the set is independent
          have h₅ : Set.range (fun (p : I) => (p.val : PersistenceSubmodule M)) = SetLike.coe I := by
            -- The set is exactly the carrier of the direct sum decomposition
            simp [SetLike.ext_iff]
            <;> aesop
          rw [h₅] at *
          exact h₂
        -- Use the fact that the set is the range of the family to deduce independence of the family
        simpa using h₄
      exact h₃
    have h₂ : iSupIndep fun (p : I) => (p.val c : Submodule K (M c)) := by
      -- Use the pointwise independence from the global independence
      have h₃ : iSupIndep fun (p : I) => (p.val : PersistenceSubmodule M) := h₁
      have h₄ : iSupIndep fun (p : I) => (p.val c : Submodule K (M c)) := by
        -- Use the property of pointwise independence
        have h₅ : ∀ (p : I), (p.val : PersistenceSubmodule M) c = (p.val c : Submodule K (M c)) := by
          intro p
          rfl
        -- Apply the property of pointwise independence
        have h₆ : iSupIndep fun (p : I) => (p.val c : Submodule K (M c)) := by
          simpa [h₅] using h₃
        exact h₆
      exact h₄
    -- Convert to the correct form for the internal direct sum
    have h₃ : iSupIndep fun (p : I) => (p.val c : Submodule K (M c)) := h₂
    simpa using h₃
  · -- Prove that the sum of the submodules is the entire space
    have h : sSup (SetLike.coe I) = ⊤ := I.sSup_eq_top'
    have h₁ : (⨆ p : I, (p.val : PersistenceSubmodule M)) = ⊤ := by
      -- Use the fact that the supremum of the family is the top element
      have h₂ : (⨆ p : I, (p.val : PersistenceSubmodule M)) = sSup (Set.range (fun (p : I) => (p.val : PersistenceSubmodule M))) := by
        simp [iSup_range]
      have h₃ : Set.range (fun (p : I) => (p.val : PersistenceSubmodule M)) = SetLike.coe I := by
        simp [SetLike.ext_iff]
        <;> aesop
      rw [h₂, h₃]
      simpa using h
    have h₂ : (⨆ p : I, (p.val : PersistenceSubmodule M) c) = ⊤ := by
      -- Use the pointwise supremum
      have h₃ : (⨆ p : I, (p.val : PersistenceSubmodule M) c) = (⨆ p : I, (p.val : PersistenceSubmodule M)) c := by
        simp [iSup_apply]
      rw [h₃]
      have h₄ : (⨆ p : I, (p.val : PersistenceSubmodule M)) = ⊤ := h₁
      rw [h₄]
      simp [ModuleCat.top_apply]
    simpa [iSup_apply] using h₂
