                        simp [sSup_eq_iSup]
                      _ = ⊤ := by rw [h₆₁]
                  simpa using h₆₂
                have h₇ : iSup (fun p : ↥D => (p.val : PersistenceSubmodule M) x) = ⊤ := by
                  have h₇₁ : (⨆ (p : ↥D), p.val : ∃ i : D, True) = ⊤ := h₆
                  have h₇₂ : iSup (fun p : ↥D => (p.val : PersistenceSubmodule M) x) = ⊤ := by
