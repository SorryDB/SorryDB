    have h₄ : (⨆ p : D, (p :PersistenceSubmodule M)) x = (⊤ : ModuleCat K) x := by
      rw [h₃]
    have h₅ : (⊤ : ModuleCat K) x = ⊤ := by
      simp [ModuleCat.top_apply]
    have h₆ : (⨆ p : D, (p :PersistenceSubmodule M)) x = ⊤ := by
      rw [h₄, h₅]
