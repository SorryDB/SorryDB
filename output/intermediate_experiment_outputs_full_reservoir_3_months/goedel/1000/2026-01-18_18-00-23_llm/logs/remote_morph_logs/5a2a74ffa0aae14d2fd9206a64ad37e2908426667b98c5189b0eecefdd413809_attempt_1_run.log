  have h₃ : (⨆ p : D, (p : PersistenceSubmodule M) x) = ⊤ := by
    have h₄ : (⨆ p : D, (p : PersistenceSubmodule M)) x = ⨆ p : D, (p : PersistenceSubmodule M) x := by
      simp [iSup_apply]
    rw [h₄] at h₂
    exact h₂
  have h₄ : ⨆ p ∈ D, p x = ⨆ p : D, (p : PersistenceSubmodule M) x := by
