          calc
            iSup (fun p : ↥D => p.val x) = (⨆ (p : ↥D), p.val x) := rfl
            _ = iSup (fun p : ↥D => p.val x) := rfl
            _ = ⊤ := by
              have h₄ : iSup (fun p : ↥D => (p.val : PersistenceSubmodule M) x) = ⊤ := by
                have h₅ : sSupIndep (Set.range fun p : ↥D => p.val : Set (PersistenceSubmodule M)) := by
