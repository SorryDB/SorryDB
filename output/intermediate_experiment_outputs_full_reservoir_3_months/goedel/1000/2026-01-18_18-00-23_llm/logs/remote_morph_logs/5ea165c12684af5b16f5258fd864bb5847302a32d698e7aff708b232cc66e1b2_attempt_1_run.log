      -- Use the fact that scalar multiplication preserves integrability in the reverse direction
      by_cases hr : r = 0
      ¬∑ -- If `r = 0`, then `r ‚ÄĘ f = 0`, and we can use the zero function to deduce integrability of `f`
        have h‚āā : (r ‚ÄĘ f) = (fun _ => (0 : E)) := by
