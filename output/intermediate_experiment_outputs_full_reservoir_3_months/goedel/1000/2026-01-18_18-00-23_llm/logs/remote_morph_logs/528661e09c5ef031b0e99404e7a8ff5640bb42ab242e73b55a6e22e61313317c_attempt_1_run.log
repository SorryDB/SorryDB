### Solution

```lean
theorem coerceCFGLang_mem_imp_word_of_type :
  ∀ word : Word α, ∀ G : ContextFreeGrammar α nt,
  word ∈ coerceLang α G.Z G.GeneratedLanguage →
  ∃ word₂ : Word G.Z, word₂ ∈ G.GeneratedLanguage ∧ coerceWord α G.Z word₂ = word := by
  intro word G h
  have h₁ : ∃ (w : Word G.Z), w ∈ G.GeneratedLanguage ∧ coerceWord α G.Z w = word := by
    simpa [coerceLang] using h
  obtain ⟨w, hw₁, hw₂⟩ := h₁
  refine' ⟨w, hw₁, _⟩
  <;> simp_all [coerceWord]
  <;> aesop
