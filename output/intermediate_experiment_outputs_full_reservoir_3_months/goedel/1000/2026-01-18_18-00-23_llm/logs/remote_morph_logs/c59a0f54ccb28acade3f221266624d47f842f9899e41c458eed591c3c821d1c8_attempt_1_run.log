  ∀ grammar : @ContextFreeGrammarCNF α nt,
  ε ∉ grammar.val.GeneratedLanguage := by
  intro grammar
  have h₁ : ε ∉ (grammar.val : ContextFreeGrammar α nt).GeneratedLanguage := by
    intro h
    have h₂ := h
    simp only [ContextFreeGrammar.GeneratedLanguage, Set.mem_setOf_eq] at h₂
    rcases h₂ with ⟨s, hs⟩
    have h₃ := hs
    simp only [ContextFreeDerivation.prod_nil, List.nil_eq_nil] at h₃
    have h₄ : s = [Sum.inl grammar.val.start] := by
      aesop
    rw [h₄] at hs
    -- We now have a derivation from [Sum.inl grammar.val.start] to ε
    -- which is impossible because all rules in CNF produce non-empty strings
    -- unless the start symbol is ε, but that is not allowed in CNF
    have h₅ := grammar.2
    simp [ContextFreeGrammarCNF] at h₅
    <;>
    (try simp_all [ContextFreeDerivation.getRule, List.prod_nil, List.cons_eq_append]) <;>
    (try contradiction) <;>
    (try {
      have h₆ := hs
