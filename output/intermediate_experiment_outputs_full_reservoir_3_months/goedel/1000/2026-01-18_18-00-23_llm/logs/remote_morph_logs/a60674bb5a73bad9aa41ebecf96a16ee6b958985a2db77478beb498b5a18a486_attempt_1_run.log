import Aesop

set_option aesop.check.all true

@[ext]
structure MyProd (α β : Type _) where
  fst : α
  snd : β

variable {α β γ δ ι: Type}

#guard_msgs in
example {p q : MyProd α β} : p = q := by
  have h : p = q := by
    cases p <;> cases q <;>
    simp_all [MyProd.ext_iff]
    <;>
    (try aesop) <;>
    (try simp_all) <;>
    (try aesop)
  exact h

#guard_msgs in
example {p q : MyProd α (MyProd β γ)} : p = q := by
  have h : p = q := by
    cases p <;> cases q <;>
    simp_all [MyProd.ext_iff]
    <;>
    (try aesop) <;>
    (try simp_all) <;>
    (try aesop)
  exact h

#guard_msgs in
example {p q : MyProd (α → β) γ} : p = q := by
  have h : p = q := by
    cases p <;> cases q <;>
    simp_all [MyProd.ext_iff]
    <;>
    (try aesop) <;>
    (try simp_all) <;>
    (try
      {
        funext x
        simp_all
      }) <;>
    (try aesop)
  exact h
