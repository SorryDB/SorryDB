    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  -- We will prove both directions of the equivalence separately.
  constructor
  · -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
    intro hf
    -- Use the fact that the norm of r • f is bounded by the norm of r times the norm of f.
    have h₁ : IntervalIntegrable (fun x => ‖r‖ * ‖f x‖) μ a b := by
      -- Since r is a constant, the function x ↦ ‖r‖ * ‖f x‖ is the product of a constant and an interval integrable function.
      have h₂ : IntervalIntegrable (fun x => ‖r‖ * ‖f x‖) μ a b := by
        -- Use the fact that the constant ‖r‖ is measurable and the function ‖f x‖ is interval integrable.
        have h₃ : IntervalIntegrable (fun x => ‖f x‖) μ a b := hf.norm
        -- Multiply the interval integrable function by the constant ‖r‖.
        exact h₃.const_smul ‖r‖
      exact h₂
    -- Use the boundedness of the scalar multiplication to conclude the proof.
    have h₂ : IntervalIntegrable (r • f) μ a b := by
      -- Use the fact that the norm of r • f is bounded by the norm of r times the norm of f.
      have h₃ : ∀ x, ‖r • f x‖ ≤ ‖r‖ * ‖f x‖ := by
        intro x
        -- Use the property of the norm of the scalar multiplication.
        calc
          ‖r • f x‖ = ‖r‖ * ‖f x‖ := by
            simp [norm_smul]
          _ ≤ ‖r‖ * ‖f x‖ := le_refl _
      -- Use the fact that the norm of r • f is bounded by the norm of r times the norm of f.
      refine' hf.of_norm_bounded _
      -- Use the fact that the function x ↦ ‖r‖ * ‖f x‖ is interval integrable.
      simpa [h₃] using h₁
    exact h₂
  · -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
    intro hf
    -- Use the fact that r is non-zero to cancel it out.
    by_cases hr : r = 0
    · -- If r is zero, then r • f is zero, and f must also be zero.
      simp_all [hr]
      <;>
      (try simp_all [intervalIntegrable_zero]) <;>
      (try simp_all [IsBoundedSMul]) <;>
      (try simp_all [IsBoundedSMul]) <;>
      (try aesop)
    · -- If r is not zero, then we can cancel it out to get f.
      have h₁ : IntervalIntegrable (fun x => ‖r⁻¹‖ * ‖r • f x‖) μ a b := by
        -- Use the fact that the norm of r⁻¹ is positive and the function ‖r • f x‖ is interval integrable.
        have h₂ : IntervalIntegrable (fun x => ‖r • f x‖) μ a b := hf.norm
        -- Multiply the interval integrable function by the constant ‖r⁻¹‖.
        exact h₂.const_smul ‖r⁻¹‖
      -- Use the boundedness of the scalar multiplication to conclude the proof.
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the fact that the norm of f is bounded by the norm of r⁻¹ times the norm of r • f.
        have h₃ : ∀ x, ‖f x‖ ≤ ‖r⁻¹‖ * ‖r • f x‖ := by
          intro x
          -- Use the property of the norm of the scalar multiplication.
          calc
            ‖f x‖ = ‖r⁻¹ • (r • f x)‖ := by
              have h₄ : r⁻¹ • (r • f x) = f x := by
