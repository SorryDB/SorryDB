namespace EnchantedForest

  namespace Introduction
    axiom Bird : Type
    axiom response : Bird → Bird → Bird
    infix:100 " ◁ " => response
  end Introduction

  open Introduction

  namespace IdentityBird
    axiom I : Bird
    axiom I.call : ∀ x : Bird, (I ◁ x) = x
  end IdentityBird

  notation A " is " " fond " " of " B => A ◁ B = B
  notation E " is " " egocentric " => E ◁ E = E

  section DefendingTheIdentityBird
    open IdentityBird

    theorem identity_fond_of_all : ∀ x : Bird, I is fond of x := by
      intro x
      simp [I.call]
      <;> aesop

    theorem identity_egocentric : I is egocentric := by
      have h : I ◁ I = I := by
        calc
          I ◁ I = I := by
            -- Use the property of the identity bird to simplify the expression
            have h₁ : I ◁ I = I := by
              -- Apply the identity bird's property to itself
              have h₂ : ∀ x : Bird, I ◁ x = x := I.call
              specialize h₂ I
              -- Simplify the expression using the property
              exact h₂
            -- The result follows directly from the property
            exact h₁
          _ = I := by rfl
      -- Since I ◁ I = I, we have that I is egocentric
      exact h
  end DefendingTheIdentityBird
