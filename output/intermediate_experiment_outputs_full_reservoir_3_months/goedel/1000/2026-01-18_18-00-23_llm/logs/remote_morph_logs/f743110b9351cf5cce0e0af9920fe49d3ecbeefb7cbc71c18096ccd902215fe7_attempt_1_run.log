inductive NaturalNumber where
  | zero : NaturalNumber
  | succ (n : NaturalNumber) : NaturalNumber

def myAdd : NaturalNumber → NaturalNumber → NaturalNumber
  | zero,   m => m
  | succ n, m => succ (myAdd n m)

def myAdd' : NaturalNumber → NaturalNumber → NaturalNumber
  | n, zero  => n
  | n, succ m => succ (myAdd' n m)

theorem myAdd_eq_add' (n m : NaturalNumber) : myAdd n m = myAdd' n m := by
  have h1 : ∀ (n m : NaturalNumber), myAdd n m = myAdd' n m := by
    intro n
    induction n with
    | zero =>
      intro m
      induction m with
      | zero => rfl
      | succ m ih =>
        simp [myAdd, myAdd', ih]
        <;> simp_all
    | succ n ih =>
      intro m
      induction m with
      | zero =>
        simp [myAdd, myAdd']
        <;> simp_all
        <;> simp [ih]
      | succ m ih' =>
        simp [myAdd, myAdd', ih, ih']
        <;> simp_all
  exact h1 n m

example : myAdd = myAdd' := by
  funext n m
  exact myAdd_eq_add' n m
