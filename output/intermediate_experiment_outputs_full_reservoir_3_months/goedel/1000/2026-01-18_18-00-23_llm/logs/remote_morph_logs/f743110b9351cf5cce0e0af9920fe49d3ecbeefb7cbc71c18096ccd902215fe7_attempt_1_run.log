### Solution

```lean
example : myAdd = myAdd' := by
  have h : ∀ (n m : NaturalNumber), myAdd n m = myAdd' n m := by
    intro n m
    induction n generalizing m with
    | zero =>
      induction m with
      | zero => rfl
      | succ m ih => simp [myAdd, myAdd', ih]
    | succ n ih =>
      induction m with
      | zero => simp [myAdd, myAdd', ih]
      | succ m ih' => simp [myAdd, myAdd', ih, ih']
  funext n m
  apply h
```
