```lean
theorem allols_of_succlinebell_kdisc_affinePlane (q : ℕ)
    (hq : 2 ≤ q) (n : ℕ) (h : ∀ (α : Type u) (_ : Fintype α) (β : Type v),
        [ OCDisk A (n : ℕ) ] :
        FiniteDimensional.finrank α (A ⊗ α _ _ _) = n * Fintype.card β) :
    False := by
  have h₁ := h (Fin 2) inferInstance (Fin 3) (inferInstance : OCDisk A 4)
  simp [FiniteDimensional.finrank_smul, Fintype.card_fin] at h₁
  <;>
  (try contradiction) <;>
  (try norm_num at h₁) <;>
  (try omega)
  <;>
  (try linarith)
```
