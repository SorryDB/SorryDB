  have h1 : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
    -- Use the property of permutations that allows us to remove the same element
    calc
      (l1.eraseIdx idx1).Perm (l2.eraseIdx idx1) := by
        -- Since l1 and l2 are permutations, removing the same index from both preserves permutation
        simpa [Permutation] using List.perm_erase_iff_perm (by omega) |>.mpr ⟨hperm, by omega⟩
