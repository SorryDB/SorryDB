theorem induction_sum_odd (n : ℕ) : (∑ k ∈ Finset.range n, (2 * k + 1)) = n ^ 2 := by
  have h : ∀ n : ℕ, (∑ k in Finset.range n, (2 * k + 1)) = n ^ 2 := by
    intro n
    induction n with
    | zero => simp
    | succ n ih =>
      rw [Finset.sum_range_succ, ih]
      simp [Nat.pow_succ, Nat.mul_succ]
      ring_nf at *
      <;> omega
  apply h
```
