```lean
theorem induction_sum_odd (n : ℕ) : (∑ k ∈ Finset.range n, (2 * k + 1)) = n ^ 2 := by
  have h_base : (∑ k ∈ Finset.range 0, (2 * k + 1)) = 0 ^ 2 := by
    simp [Finset.sum_range_zero]
    <;> norm_num
  
  have h_inductive_step : ∀ m : ℕ, (∑ k ∈ Finset.range m, (2 * k + 1)) = m ^ 2 → (∑ k ∈ Finset.range (m + 1), (2 * k + 1)) = (m + 1) ^ 2 := by
    intro m ih
    have h₁ : (∑ k in Finset.range (m + 1), (2 * k + 1)) = (∑ k in Finset.range m, (2 * k + 1)) + (2 * m + 1) := by
      rw [Finset.sum_range_succ]
      <;> simp [add_assoc]
    rw [h₁]
    have h₂ : (∑ k in Finset.range m, (2 * k + 1)) = m ^ 2 := ih
    rw [h₂]
    have h₃ : m ^ 2 + (2 * m + 1) = (m + 1) ^ 2 := by
      ring_nf
      <;> simp [pow_two]
      <;> ring
      <;> omega
    linarith
  
  have h_main : (∑ k ∈ Finset.range n, (2 * k + 1)) = n ^ 2 := by
    have h : ∀ n : ℕ, (∑ k ∈ Finset.range n, (2 * k + 1)) = n ^ 2 := by
      intro n
      induction n with
      | zero => simp [h_base]
      | succ m ih =>
        apply h_inductive_step
        exact ih
    apply h
  
  apply h_main
``` 

