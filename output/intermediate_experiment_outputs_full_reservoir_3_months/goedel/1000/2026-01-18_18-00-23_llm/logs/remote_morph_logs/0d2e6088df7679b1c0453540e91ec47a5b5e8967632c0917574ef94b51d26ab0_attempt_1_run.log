  have h_inductive_step : ∀ m : ℕ, (∑ k ∈ Finset.range m, (2 * k + 1)) = m ^ 2 → (∑ k ∈ Finset.range (m + 1), (2 * k + 1)) = (m + 1) ^ 2 := by sorry
