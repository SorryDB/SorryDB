theorem Idempotent {╬▒ : Type*} [Semigroup ╬▒] (a : ╬▒) (ha : a * a = a) :
  Рѕђ n : РёЋ, a ^ n = a Рѕе a ^ n = 1 := by
  have h_main : Рѕђ n : РёЋ, a ^ n = a Рѕе a ^ n = 1 := by
    intro n
    have h : a ^ n = a Рѕе a ^ n = 1 := by
      have hРѓЂ : a * a = a := ha
      have hРѓѓ : a ^ 2 = a := by
        calc
          a ^ 2 = a * a := by simp [pow_two]
          _ = a := hРѓЂ
      have hРѓЃ : Рѕђ n : РёЋ, a ^ n = a Рѕе a ^ n = 1 := by
        intro n
        induction n with
        | zero =>
          -- Base case: n = 0
          simp
          <;>
          (try simp_all [pow_zero, one_mul])
          <;>
          (try {
            cases' eq_or_ne a 1 with h h <;> simp_all [h]
            <;>
            (try {
              have hРѓё := hРѓѓ
              simp_all [pow_two, mul_one]
              <;>
              (try contradiction)
            })
          })
          <;>
          (try {
            have hРѓё := hРѓѓ
            simp_all [pow_two, mul_one]
            <;>
            (try contradiction)
          })
        | succ n ih =>
          -- Inductive step: assume the statement holds for n, prove for n+1
          cases' ih with ih ih
          ┬и -- Case: a^n = a
            have hРѓё : a ^ (n + 1) = a * a := by
              calc
                a ^ (n + 1) = a ^ n * a := by simp [pow_succ]
                _ = a * a := by rw [ih]
                _ = a * a := by rfl
            have hРѓЁ : a ^ (n + 1) = a := by
              calc
                a ^ (n + 1) = a * a := hРѓё
                _ = a := by rw [ha]
            exact Or.inl hРѓЁ
          ┬и -- Case: a^n = 1
            have hРѓё : a ^ (n + 1) = 1 * a := by
              calc
                a ^ (n + 1) = a ^ n * a := by simp [pow_succ]
                _ = 1 * a := by rw [ih]
                _ = 1 * a := by rfl
            have hРѓЁ : a ^ (n + 1) = a := by
              calc
                a ^ (n + 1) = 1 * a := hРѓё
                _ = a := by simp [one_mul]
            exact Or.inl hРѓЁ
      exact hРѓЃ n
    exact h
  exact h_main
```
