              (try norm_num)
          rw [h₆]
          <;> linarith
      exact h₅
    -- Use the fact that Φ₁ is bounded above and continuous to show that it has a finite integral
    have h₆ : HasFiniteIntegral (fun x : ℝ => Φ₁ r x) (volume.restrict (Ioc 0 1)) := by
      have h₇ : ContinuousOn (Φ₁ r) (Ioc 0 1) := Φ₁_contDiffOn.continuousOn.mono (Set.Ioc_subset_Ioc_right (by norm_num))
