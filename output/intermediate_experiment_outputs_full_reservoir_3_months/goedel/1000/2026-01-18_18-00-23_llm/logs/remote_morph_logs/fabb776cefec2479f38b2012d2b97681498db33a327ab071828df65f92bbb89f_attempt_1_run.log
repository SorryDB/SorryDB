theorem Φ₃_integrableOn {r : ℝ} (hr : r ≥ 0) : IntegrableOn (Φ₃ r)
    (Ioc (0 : ℝ) 1) volume := by
  refine ⟨ContinuousOn.aestronglyMeasurable Φ₃_contDiffOn.continuousOn measurableSet_Ioc, ?_⟩
  have h₁ : HasFiniteIntegral (fun x : ℝ => Φ₃ r x) (volume.restrict (Ioc 0 1)) := by
    have h₂ : ContinuousOn (fun x : ℝ => Φ₃ r x) (Ioc (0 : ℝ) 1) := Φ₃_contDiffOn.continuousOn
    have h₃ : IsCompact (Set.Icc 0 1) := isCompact_Icc
    have h₄ : ∃ (C : ℝ), ∀ (x : ℝ), x ∈ Ioc (0 : ℝ) 1 → |Φ₃ r x| ≤ C := by
      -- We need to show that Φ₃ r is bounded on the interval (0,1]
      -- This can be done by finding an upper bound for |Φ₃ r x| on this interval
      use 1 + r
      intro x hx
      have h₅ : 0 < x := by exact hx.1
      have h₆ : x ≤ 1 := by exact hx.2
      have h₇ : |Φ₃ r x| ≤ 1 + r := by
        -- Calculate Φ₃ r x and find an upper bound for it
        simp only [Φ₃, abs_sub_lt_iff, abs_of_nonneg, sub_nonneg, Real.sqrt_nonneg]
        have h₈ : 0 ≤ Real.sqrt x := Real.sqrt_nonneg x
        have h₉ : Real.sqrt x ≥ 0 := Real.sqrt_nonneg x
        have h₁₀ : Real.sqrt x ≤ 1 := by
          apply Real.sqrt_le_iff.mpr
          exact ⟨by linarith, by nlinarith⟩
        have h₁₁ : |Real.sqrt x - 1| = 1 - Real.sqrt x := by
          rw [abs_of_nonpos] <;> linarith
        have h₁₂ : (1 - Real.sqrt x : ℝ) ≥ 0 := by linarith
        have h₁₃ : (1 + r : ℝ) ≥ 0 := by linarith
        have h₁₄ : (2 : ℝ) > 0 := by norm_num
        have h₁₅ : |Real.sqrt x - 1| ≤ 1 := by
          linarith
        have h₁₆ : (1 - Real.sqrt x : ℝ) * (1 + r) ≤ 1 + r := by
