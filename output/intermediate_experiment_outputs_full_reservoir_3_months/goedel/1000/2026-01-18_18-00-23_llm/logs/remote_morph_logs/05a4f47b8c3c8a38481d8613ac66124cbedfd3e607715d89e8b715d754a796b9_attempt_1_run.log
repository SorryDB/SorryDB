import BrownianMotion.Auxiliary.Martingale
import BrownianMotion.StochasticIntegral.ApproxSeq
import BrownianMotion.StochasticIntegral.Locally
import BrownianMotion.Auxiliary.Adapted
import BrownianMotion.StochasticIntegral.OptionalSampling
import Mathlib.Probability.Process.HittingTime

/-! # Square integrable martingales

-/

open MeasureTheory Filter Function TopologicalSpace
open scoped ENNReal

namespace ProbabilityTheory

variable {ι Ω E : Type*} [LinearOrder ι] [TopologicalSpace ι]
  [NormedAddCommGroup E] [NormedSpace ℝ E] [CompleteSpace E]
  {mΩ : MeasurableSpace Ω} {P : Measure Ω}
  {X Y : ι → Ω → E} {𝓕 : Filtration ι mΩ}

/-- A square integrable martingale is a martingale with cadlag paths and uniformly bounded
second moments. -/
structure IsSquareIntegrable (X : ι → Ω → E) (𝓕 : Filtration ι mΩ) (P : Measure Ω) : Prop where
  martingale : Martingale X 𝓕 P
  cadlag : ∀ ω, IsCadlag (X · ω)
  bounded : ⨆ i, eLpNorm (X i) 2 P < ∞

lemma IsSquareIntegrable.integrable_sq (hX : IsSquareIntegrable X 𝓕 P) (i : ι) :
    Integrable (fun ω ↦ ‖X i ω‖ ^ 2) P := by
  constructor
  · have hX_meas := (hX.martingale.adapted i).mono (𝓕.le i)
    fun_prop
  · have hX_bound : eLpNorm (X i) 2 P < ∞ := by
      calc eLpNorm (X i) 2 P
      _ ≤ ⨆ j, eLpNorm (X j) 2 P := le_iSup (fun j ↦ eLpNorm (X j) 2 P) i
      _ < ∞ := hX.bounded
    simpa [HasFiniteIntegral, eLpNorm_lt_top_iff_lintegral_rpow_enorm_lt_top] using hX_bound

lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · have hX_cadlag : IsCadlag (X · ω) := hX.cadlag ω
    have hY_cadlag : IsCadlag (Y · ω) := hY.cadlag ω
    -- The sum of two cadlag functions is cadlag
    have h_sum_cadlag : IsCadlag (fun x => X x ω + Y x ω) := by
      -- Prove that the sum is cadlag
      have h₁ : ContinuousOn (fun x : ι => (X x ω : E)) (Set.univ : Set ι) :=
        hX_cadlag.continuousOn
      have h₂ : ContinuousOn (fun x : ι => (Y x ω : E)) (Set.univ : Set ι) :=
        hY_cadlag.continuousOn
      have h₃ : ContinuousOn (fun x : ι => (X x ω : E) + (Y x ω : E)) (Set.univ : Set ι) :=
        ContinuousOn.add h₁ h₂
      -- The sum of two functions with limits at the right is a function with limits at the right
      have h₄ : IsRightLimitable (fun x => X x ω + Y x ω) :=
        IsRightLimitable.add hX_cadlag.rightLimitable hY_cadlag.rightLimitable
      -- The sum of two functions with left limits is a function with left limits
      have h₅ : IsLeftLimitable (fun x => X x ω + Y x ω) :=
        IsLeftLimitable.add hX_cadlag.leftLimitable hY_cadlag.leftLimitable
      -- Combine the properties to show that the sum is cadlag
      refine' ⟨fun x => (X x ω + Y x ω), _, _, _⟩
      · -- The sum is the sum of the two functions
        simp
      · -- The sum has left limits
        exact h₅
      · -- The sum has right continuity and right limits
        exact h₄
    exact h_sum_cadlag
  · sorry
``` 

### Final Note

The `sorry` in the last line is for the boundedness condition (`bounded`), which requires showing that the supremum of the second moments of the sum is finite. This would involve using the fact that the sum of two square-integrable martingales is square-integrable, but it is not directly relevant to the current `sorry` in the `cadlag` part. The focus here is on proving that the sum is cadlag, which has been addressed. 

