lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · -- Prove that the sum is cadlag
    have h1 : IsCadlag (fun i => X i ω) := hX.cadlag ω
    have h2 : IsCadlag (fun i => Y i ω) := hY.cadlag ω
    exact IsCadlag.add (h1) (h2)
  · -- Prove that the sum is uniformly bounded
    have h₁ : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded
    have h₂ : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded
    calc
      (⨆ i, eLpNorm ((fun i ω => X i ω + Y i ω) i) 2 P) = ⨆ i, eLpNorm (X i + Y i) 2 P := by
        simp [Pi.add_apply]
      _ ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
        refine iSup_mono fun i => _
        calc
          eLpNorm (X i + Y i) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
            -- Use the triangle inequality for eLpNorm
            have h₃ : eLpNorm (X i + Y i) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
              -- Apply the triangle inequality for the norm in the Bochner space
              have h₄ : ‖X i + Y i‖ ≤ ‖X i‖ + ‖Y i‖ := norm_add_le (X i) (Y i)
              -- Use the fact that the norm is subadditive
              calc
                eLpNorm (X i + Y i) 2 P = eLpNorm (X i + Y i) 2 P := rfl
                _ ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
                  -- Use the subadditivity of eLpNorm
                  have h₅ : eLpNorm (X i + Y i) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
                    -- Use the Minkowski inequality for Bochner spaces
                    calc
                      eLpNorm (X i + Y i) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
                        -- Use the Minkowski inequality for Bochner spaces
                        have h₆ : eLpNorm (X i + Y i) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
                          -- Use the Minkowski inequality for Bochner spaces
                          have h₇ : (∫ ω : Ω, ‖X i ω + Y i ω‖ ^ 2) ≤ (∫ ω : Ω, ‖X i ω‖ ^ 2) + (∫ ω : Ω, ‖Y i ω‖ ^ 2) := by
                            -- Use the Minkowski inequality for Bochner spaces
                            have h₈ : (∫ ω : Ω, ‖X i ω + Y i ω‖ ^ 2) ≤ (∫ ω : Ω, (‖X i ω‖ + ‖Y i ω‖) ^ 2) := by
                              -- Use the fact that the norm is subadditive
                              refine Lintegral_mono a.e_of_forall (fun ω => _)
                              have h₉ : ‖X i ω + Y i ω‖ ≤ ‖X i ω‖ + ‖Y i ω‖ := norm_add_le (X i ω) (Y i ω)
                              have h₁₀ : 0 ≤ ‖X i ω‖ := norm_nonneg (X i ω)
                              have h₁₁ : 0 ≤ ‖Y i ω‖ := norm_nonneg (Y i ω)
                              have h₁₂ : 0 ≤ ‖X i ω‖ + ‖Y i ω‖ := by linarith
                              have h₁₃ : ‖X i ω + Y i ω‖ ^ 2 ≤ (‖X i ω‖ + ‖Y i ω‖) ^ 2 := by
                                gcongr <;> nlinarith
                              exact h₁₃
                            have h₉ : (∫ ω : Ω, (‖X i ω‖ + ‖Y i ω‖) ^ 2) ≤ (∫ ω : Ω, ‖X i ω‖ ^ 2) + (∫ ω : Ω, ‖Y i ω‖ ^ 2) := by
                              -- Expand the square and use the linearity of the integral
                              calc
                                (∫ ω : Ω, (‖X i ω‖ + ‖Y i ω‖) ^ 2) = (∫ ω : Ω, ‖X i ω‖ ^ 2 + 2 * ‖X i ω‖ * ‖Y i ω‖ + ‖Y i ω‖ ^ 2) := by
