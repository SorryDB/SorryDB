  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · -- Prove that the sum of two cadlag processes is cadlag
    have hX_cadlag : IsCadlag (fun x ↦ X x ω) := hX.cadlag ω
    have hY_cadlag : IsCadlag (fun x ↦ Y x ω) := hY.cadlag ω
    -- Use the fact that the sum of two cadlag functions is cadlag
    have h_sum_cadlag : IsCadlag (fun x ↦ X x ω + Y x ω) := by
