lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · have hX_cadlag : IsCadlag (X · ω) := hX.cadlag ω
    have hY_cadlag : IsCadlag (Y · ω) := hY.cadlag ω
    -- The sum of two cadlag functions is cadlag
    have h_sum_cadlag : IsCadlag (fun x => X x ω + Y x ω) := by
      -- Prove that the sum is cadlag
      have h₁ : ContinuousOn (fun x : ι => (X x ω : E)) (Set.univ : Set ι) :=
        hX_cadlag.continuousOn
      have h₂ : ContinuousOn (fun x : ι => (Y x ω : E)) (Set.univ : Set ι) :=
        hY_cadlag.continuousOn
      have h₃ : ContinuousOn (fun x : ι => (X x ω : E) + (Y x ω : E)) (Set.univ : Set ι) :=
        ContinuousOn.add h₁ h₂
      -- The sum of two functions with limits at the right is a function with limits at the right
      have h₄ : IsRightLimitable (fun x => X x ω + Y x ω) :=
        IsRightLimitable.add hX_cadlag.rightLimitable hY_cadlag.rightLimitable
      -- The sum of two functions with left limits is a function with left limits
