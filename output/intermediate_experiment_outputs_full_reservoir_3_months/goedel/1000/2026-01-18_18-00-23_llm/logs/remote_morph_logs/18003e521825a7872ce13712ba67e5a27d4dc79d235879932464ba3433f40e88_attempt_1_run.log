/--The `dartSet` of a LoopWalk is the set of edges it traverses, including loops.-/
def dartSet {u v : V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (V ├Ś V) :=
  (darts p).toFinset


def connectingDarts {u v : V} : G.LoopWalk u v Ôćĺ List (V ├Ś V)
