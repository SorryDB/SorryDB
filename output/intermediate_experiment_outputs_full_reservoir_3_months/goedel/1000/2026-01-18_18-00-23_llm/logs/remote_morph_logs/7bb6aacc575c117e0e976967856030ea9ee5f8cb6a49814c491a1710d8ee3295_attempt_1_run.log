    have h₂ : l1.Perm l2 := hPerm
    have h₃ : (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx1 elt) :=
      List.Perm.insertIdx _ _ (by
        -- Prove that the perm property satisfies when inserting an element at the same idx1
        have h₄ : l1.Perm l2 := hPerm
        have h₅ : l1.Perm l2 := hPerm
        have h₆ : l1.Perm l2 := hPerm
        -- Use the fact that the lists are perm to prove the inserted lists are also perm
        simpa [List.Perm] using h₅
      )
    exact h₃
  have h₂ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
    -- If idx1 = idx2, the permutation is trivial
    by_cases h : idx1 = idx2
    · subst_vars
      <;> rfl
    · -- If idx1 ≠ idx2, we use the fact that we can permute the indices
      have h₃ : idx1 ≠ idx2 := h
