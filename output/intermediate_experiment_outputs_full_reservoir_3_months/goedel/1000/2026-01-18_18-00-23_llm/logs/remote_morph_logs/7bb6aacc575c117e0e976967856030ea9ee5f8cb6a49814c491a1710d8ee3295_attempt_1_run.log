          <;>
          (try omega)
        })
      <;>
      (try
        {
          cases idx1 <;> cases idx2 <;> simp_all [List.insertAt, List.take, List.drop]
          <;>
          (try omega)
        })
      <;>
      (try
        {
          aesop
        })
    rw [h₄]
  apply List.Perm.trans h₁ h₂
