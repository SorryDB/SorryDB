        -- Use the fact that inserting at different indices can be permuted using the swap property of perm
        have h₅ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
          have h₆ : l2.Perm l2 := by rfl
          have h₇ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) :=
            List.Perm.insertIdx _ _ (by
              -- Prove that the perm property satisfies when inserting an element at different indices
              have h₈ : l2.Perm l2 := by rfl
              have h₉ : l2.Perm l2 := by rfl
              have h₁₀ : l2.Perm l2 := by rfl
              -- Use the fact that the lists are perm to prove the inserted lists are also perm
              simpa [List.Perm] using h₉
            )
          exact h₇
        exact h₅
      exact h₄
  -- Combine the two permutations to get the final result
  have h₃ : (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) :=
    List.Perm.trans h₁ h₂
  exact h₃
