theorem list_Perm_insertIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
    {idx1 idx2 : Nat} {hidx1 : idx1 <= l1.length} {hidx2 : idx2 <= l2.length} {elt : α} :
    (l1.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
