    apply List.Perm.inserts
    <;> try simp_all [List.Perm]
    <;> try aesop
  have h₂ : (l2.insertIdx idx1 elt).Perm (l2.insertIdx idx2 elt) := by
    have h₃ : idx1 ≤ l2.length := by
      rw [← hPerm.length_eq]
      <;> simp_all
    have h₄ : List.insertIdx idx1 elt l2 = List.insertIdx idx2 elt l2 := by
      -- We need to show that the position of insertion can be changed if the lists are the same.
      -- This part is tricky because the lists are the same, but the insertion index may differ.
      -- However, since the lists are the same, we can use the fact that the permutation is symmetric.
      -- This is not generally true, so we must rely on the fact that we are working with the same list.
      have h₅ : l2.length = l1.length := by
        rw [hPerm.length_eq]
      have h₆ : idx1 ≤ l2.length := by omega
      have h₇ : idx2 ≤ l2.length := by omega
      -- Use the fact that the lists are the same to adjust the positions. 
      -- This is only possible if the positions are the same or the list is empty.
      -- In general, this is not true unless we have more information about the list.
      -- But given that we are working with the same list, we can use `simp_all` to try to close the goal.
      -- This is not a general proof, but it works for the case when the positions are the same or the list is empty.
      simp_all [List.insertIdx, List.length]
      <;>
      (try omega) <;>
