theorem lean_workbook_plus_13350 (x : ℝ) (h : x * (1 / 2 + 2 / 3) = 1) : x = 6 / 7 := by
  have h₁ : x = 6 / 7 := by
    have h₂ : x * (7 / 6 : ℝ) = 1 := by
      -- Simplify the left-hand side of the given equation
      norm_num at h ⊢
      <;> linarith
    -- Solve for x by multiplying both sides by 6/7
    have h₃ : x = 6 / 7 := by
      calc
        x = x * (7 / 6 : ℝ) * (6 / 7 : ℝ) := by ring
        _ = 1 * (6 / 7 : ℝ) := by rw [h₂]
        _ = 6 / 7 := by norm_num
    exact h₃
  exact h₁
``` 

