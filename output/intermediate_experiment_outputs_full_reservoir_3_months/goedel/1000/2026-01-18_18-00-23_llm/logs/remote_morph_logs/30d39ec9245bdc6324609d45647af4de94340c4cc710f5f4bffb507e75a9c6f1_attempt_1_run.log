theorem Solution.Row.valid_imp_not_rupert
   (tab : Solution.Table) (tab_valid : tab.Valid)
   (row : Solution.Row) (row_valid : row.Valid tab) :
    ¬ ∃ q ∈ row.toPoseInterval, RupertPose q nopert.hull := by
  match row_valid with
  | .asSplit y => by
    intro h
    -- Extract the hypothesis from the existence statement
    rcases h with ⟨q, hq, h_rupert⟩
    -- Use the fact that the row is a split to derive a contradiction
    have h₁ := y.not_rupert
    -- Simplify the hypothesis to find the contradiction
    simp_all [Solution.Row.toPoseInterval, Set.mem_Icc]
    <;>
    (try norm_num at *) <;>
    (try linarith) <;>
    (try contradiction) <;>
    (try nlinarith)
