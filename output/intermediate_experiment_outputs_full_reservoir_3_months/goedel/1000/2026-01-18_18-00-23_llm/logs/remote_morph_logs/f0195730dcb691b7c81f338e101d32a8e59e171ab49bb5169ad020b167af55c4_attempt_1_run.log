lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨ s, hs ⟩ := heq;
  rw [hs];
  -- We need to show that the cardinality of the edge set of the permuted walk is equal to the cardinality of the edge set of the original walk.
  have h_card_eq : (p.snd.edgeSet).image (fun (e : Finset (Finset (Fin 2))) => e) = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := by
    -- The edge set of the permuted walk is the image of the edge set of the original walk under the permutation.
    have h_edges_eq : ∀ (u v : Fin n) (p : (K n).LoopWalk u v), (SimpleGraph.LoopWalk.permMapWalk n s p).edges = List.map (fun e => e) p.edges := by
      intros u v p
      induction' p with u v w h p ih
      · rfl;
      · -- We perform the induction by cases on the walk: nil, cons, and loop.
        simp_all [SimpleGraph.LoopWalk.permMapWalk, SimpleGraph.LoopWalk.edges, List.map, Sym2.map]
        <;> aesop;
      · -- We perform the induction by cases on the walk: nil, cons, and loop.
        simp_all [SimpleGraph.LoopWalk.permMapWalk, SimpleGraph.LoopWalk.edges, List.map, Sym2.map]
        <;> aesop;
    -- Since the edges of the permuted walk are the same as the edges of the original walk, their edge sets are equal.
    have h_edges_eq' := h_edges_eq p.1 p.1 p.2;
    simp [SimpleGraph.LoopWalk.edgeSet, h_edges_eq'] at *
    <;>
    (try simp_all [Finset.image_insert, Finset.image_singleton, Finset.mem_image])
    <;>
    (try aesop)
    <;>
    (try simp_all [Finset.card_image_of_injective])
    <;>
    (try aesop)
  -- The image of the edge set under the permutation is equal to the edge set of the permuted walk, so their cardinalities are the same.
  rw [ ← h_card_eq]
  <;>
  (try simp_all [Finset.card_image_of_injective])
  <;>
  (try aesop)
```
