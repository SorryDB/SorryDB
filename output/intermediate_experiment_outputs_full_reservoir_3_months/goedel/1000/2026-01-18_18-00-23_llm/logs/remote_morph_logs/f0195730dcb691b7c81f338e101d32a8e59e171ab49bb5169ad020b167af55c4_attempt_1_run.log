theorem walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨ s, hs ⟩ := heq;
  rw [hs];
  -- Since these two sets are equal, their cardinalities are equal.
  have h_card_eq : (p.snd.edgeSet).image s = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := by
    -- By definition of `permMapWalk`, the edge set of the permuted walk is the image of the edge set of the original walk under `s`.
    have h_edge_eq : ∀ (u v : Fin n) (p : (K n).LoopWalk u v), (SimpleGraph.LoopWalk.permMapWalk n s p).edges = List.map (fun e => s e) p.edges := by
      intros u v p
      induction' p with u v w h p ih
      · rfl
      · -- For the cons case, we need to prove that the edges of the permuted start end are the same as the start end of the permutation of the walk.
        simp [SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.map_cons, ih, Function.funext_iff, List.map]
        <;> aesop
      · -- For the loop case, we need to prove that the edges of the permuted start end are the same as the start end of the permutation of the walk.
        simp [SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.map_loop, ih, Function.funext_iff, List.map]
        <;> aesop
    have h_edge_eq' : (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edges = List.map (fun e => s e) p.snd.edges := h_edge_eq _ _ p.snd;
    unfold SimpleGraph.LoopWalk.edgeSet at *
    simp_all [Finset.image_val, Finset.ext_iff]
    <;>
    (try decide) <;>
    (try aesop) <;>
    (try simp_all) <;>
    (try norm_num)
    <;>
    (try
      {
        have h1 : ∀ {a : Sym2 (Fin n)}, s (s⁻¹ a) = a := by
          intro a
          apply Equiv.s_symm_apply
        simp_all [h1]
      })
    <;>
    (try aesop)
    <;>
    (try simp_all [Equiv.bijective, Equiv.surjective])
  -- Since the image of a finite set under an injective function has the same cardinality, the cardinalities of the edge sets are equal.
  have h_card_eq_final : (p.snd.edgeSet).card = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet.card := by
    have h_injective : Function.Injective s := s.injective
    have h_card_eq_new : (p.snd.edgeSet).image s = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := h_card_eq
    have h_card_eq_new' : (p.snd.edgeSet).card = ( (p.snd.edgeSet).image s ).card := by
      apply Finset.card_image_of_injective
      exact h_injective
    have h_card_eq_new'' : ( (p.snd.edgeSet).image s ).card = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet.card := by
      rw [h_card_eq]
    rw [h_card_eq_new', h_card_eq_new''] at *
    <;> aesop
  -- The final step is to apply the previous results to conclude that the cardinalities are equal.
  simp_all [h_card_eq_final]
  <;>
  aesop
