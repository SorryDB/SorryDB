    have h_edges_eq : ∀ (u v : Fin n) (p : (K n).LoopWalk u v), (SimpleGraph.LoopWalk.permMapWalk n s p).edges = List.map (fun e => (s e.1, s e.2)) p.edges := by
      intros u v p
      induction' p with u v w h p ih
      · rfl;
      · -- By definition of `permMap`, the edges of the permuted walk are the image of the edges of the original walk under `s`.
        simp [SimpleGraph.LoopWalk.permMapWalk, SimpleGraph.LoopWalk.edges, ih]
        <;>
        (try simp_all [SimpleGraph.LoopWalk.edges])
        <;>
