      simp [List.toFinset_map]
    rw [h_image]
    rw [show (List.map (fun e => (s e.1, s e.2)) p.snd.edges).toFinset = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edges.toFinset by
      rw [h_edges_eq']
      <;> rfl]
  rw [← h_card_eq]
  simp [Finset.card_image_of_injective, s.injective]
  <;>
  (try simp_all [Edge.setinj, Finset.bijective_iff_has_inverse, s.bijective])
  <;>
  (try aesop)
