  have h₁ : biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
    apply biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField
  rw [h₁]
  have h₂ : (biasedUpdateState net x i i).toReal - (x i).toReal = (if 0 < biasedLocalField net x i then (1 : ℝ) - (x i).toReal else if biasedLocalField net x i < 0 then (-1 : ℝ) - (x i).toReal else 0) := by
    simp [biasedUpdateState, biasedLocalField, Fin.val_mk]
