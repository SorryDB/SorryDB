```lean
theorem linearity_of_directional_derivative (v : E) (T : 𝓓'(Ω, F)) (c : ℝ) :
    lineDerivCLM (c • v) T = c • lineDerivCLM v T := by
  have h_main : ∀ (T : 𝓓'(Ω, F)) (f : 𝓓(Ω, ℝ)), lineDerivCLM (c • v) T f = c • lineDerivCLM v T f := by
    intro T f
    have h₁ : lineDerivCLM (c • v) T f = T (-TestFunction.lineDerivCLM (c • v) f) := by
      simp [lineDerivCLM_apply]
    have h₂ : lineDerivCLM v T f = T (-TestFunction.lineDerivCLM v f) := by
      simp [lineDerivCLM_apply]
    rw [h₁, h₂]
    have h₃ : (-TestFunction.lineDerivCLM (c • v) f : 𝓓(Ω, ℝ)) = c • (-TestFunction.lineDerivCLM v f : 𝓓(Ω, ℝ)) := by
      simp [TestFunction.lineDerivCLM_smul]
      <;>
      (try ring_nf) <;>
      (try simp_all [smul_neg, neg_smul, linearMap_smul, linearMap_neg]) <;>
      (try congr_arg (fun x : 𝓓(Ω, ℝ) => x) (by simp [smul_smul])) <;>
      (try simp [ContinuousLinearMap.comp]) <;>
      (try ext <;> simp [ContinuousLinearMap.smul_apply, ContinuousLinearMap.neg_apply]) <;>
      (try ring_nf) <;>
      (try simp_all [smul_smul]) <;>
      (try field_simp) <;>
      (try linarith)
    rw [h₃]
    simp [ContinuousLinearMap.map_smul]
    <;>
    (try congr_arg (fun x : 𝓓(Ω, ℝ) => x) (by simp [smul_smul])) <;>
    (try simp [ContinuousLinearMap.comp]) <;>
    (try ext <;> simp [ContinuousLinearMap.smul_apply, ContinuousLinearMap.neg_apply]) <;>
    (try ring_nf) <;>
    (try simp_all [smul_smul]) <;>
    (try field_simp) <;>
    (try linarith)
  
  funext T
  ext f
  have h₁ := h_main T f
  simp_all [ContinuousLinearMap.smul_apply]
  <;> congr <;> ext <;> simp_all [ContinuousLinearMap.smul_apply]
  <;> linarith
