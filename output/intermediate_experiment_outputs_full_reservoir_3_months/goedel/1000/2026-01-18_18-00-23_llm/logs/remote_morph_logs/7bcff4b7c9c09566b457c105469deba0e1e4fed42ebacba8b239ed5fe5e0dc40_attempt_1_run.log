theorem lineDerivCLM_smul {T : 𝓓'(Ω, F)} {f : 𝓓(Ω, ℝ)} {x : E} {m : ℝ} :
    lineDerivCLM (m • x) T f = (m : ℝ) • lineDerivCLM x T f := by sorry

theorem lineDerivCLM_smul {T : 𝓓'(Ω, F)} {f : 𝓓(Ω, ℝ)} {x : E} {m : ℝ} :
    lineDerivCLM (m • x) T f = (m : ℝ) • lineDerivCLM x T f := by
  calc
    lineDerivCLM (m • x) T f = T (-lineDerivCLM.mpr (m • x) f) := rfl
    _ = T (- (m • lineDerivCLM.mpr x f)) := by
      -- Use the linearity of the lineDerivCLM.mpr
      simp [lineDerivCLM.mpr_smul]
    _ = (m : ℝ) • T (-lineDerivCLM.mpr x f) := by
      -- Use the continuity of T and the scalar multiplication
      apply congr_arg (fun x => (m : ℝ) • x)
      <;> simp_all [lineDerivCLM.mpr_smul]
    _ = (m : ℝ) • lineDerivCLM x T f := by simp [lineDerivCLM]
