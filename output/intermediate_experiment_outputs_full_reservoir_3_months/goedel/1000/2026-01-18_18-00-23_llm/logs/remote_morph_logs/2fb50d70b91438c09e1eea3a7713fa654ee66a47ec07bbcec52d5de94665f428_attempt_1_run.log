theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h_forward : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro h
    -- Use the fact that if f is interval integrable, then r • f is also interval integrable because of the boundedness of the scalar multiplication
    have h₁ : IntervalIntegrable (r • f) μ a b := by
      -- Use the property that scalar multiplication preserves integrability
      refine' IntervalIntegrable.mul_left _ h
      -- Show that the scalar multiplication is bounded
      <;> simp_all [IsBoundedSMul]
      <;>
      (try norm_num) <;>
      (try aesop) <;>
      (try
        {
          -- Use the boundedness of the scalar multiplication to prove the integrability
          have h₂ : IsBoundedSMul R E := inferInstance
          -- Simplify the expression to show that the scalar multiplication is bounded
          simp_all [IsBoundedSMul]
          <;> norm_num
          <;> aesop
        })
    exact h₁
  
  have h_backward : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro h
    -- If r • f is interval integrable, then f is also interval integrable because of the boundedness of the scalar multiplication
    have h₁ : IntervalIntegrable f μ a b := by
      -- Use the property that scalar multiplication preserves integrability in the reverse direction
      have h₂ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
        -- Show that r⁻¹ • (r • f) is interval integrable because r • f is interval integrable and scalar multiplication preserves integrability
        refine' IntervalIntegrable.mul_left _ h
        <;> simp_all [IsBoundedSMul]
        <;>
        (try norm_num) <;>
        (try aesop) <;>
        (try
          {
            -- Use the boundedness of the scalar multiplication to prove the integrability
            have h₃ : IsBoundedSMul R E := inferInstance
            -- Simplify the expression to show that the scalar multiplication is bounded
            simp_all [IsBoundedSMul]
            <;> norm_num
            <;> aesop
          })
      -- Simplify r⁻¹ • (r • f) to f
      have h₃ : (fun x => r⁻¹ • (r • f x)) = f := by
        funext x
        simp [smul_smul, mul_inv_cancel_left]
        <;>
        (try norm_num) <;>
        (try aesop) <;>
        (try
          {
            -- Use the boundedness of the scalar multiplication to prove the integrability
            have h₄ : IsBoundedSMul R E := inferInstance
            -- Simplify the expression to show that the scalar multiplication is bounded
            simp_all [IsBoundedSMul]
            <;> norm_num
            <;> aesop
          })
      -- Conclude that f is interval integrable
      simpa [h₃] using h₂
    exact h₁
  
  exact ⟨h_forward, h_backward⟩
