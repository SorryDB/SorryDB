theorem p_ne_zero : p ≠ 0 := by
  by_contra h
  have h₁ : p = 0 := by simpa using h
  have h₂ := hpqr
  simp_all [ENNReal.HolderTriple, ENNReal.div_eq_zero_iff]
  <;> aesop
  <;> try norm_num
  <;> try linarith
  <;> try simp_all [ENNReal.toReal_zero]
  <;> try norm_num at *
  <;> try linarith
  <;> try nlinarith
  <;> try nlinarith [hpqr]
```
