```lean
theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h_main : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
      intro hf
      have h₂ : IntervalIntegrable (fun x => r • f x) μ a b := by
        -- Use the fact that scalar multiplication is bounded to preserve integrability
        refine' hf.smul_left r
      simpa using h₂
    
    have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
      intro hf
      have h₃ : IntervalIntegrable (fun x => (1 : R) • f x) μ a b := by
        -- Use the fact that scalar multiplication by 1 is the identity function
        have h₄ : (fun x => (1 : R) • f x) = f := by
          ext x
          simp [one_smul]
        rw [h₄]
        -- Use the fact that f is interval integrable
        have h₅ : IntervalIntegrable f μ a b := by
          -- Use the given interval integrability of r • f to derive that of f
          by_cases h₆ : r = 0
          · -- If r = 0, then r • f = 0, and we need to show f is interval integrable
            exfalso
            simp_all [h₆, smul_eq_zero]
            <;>
            (try simp_all [IntervalIntegrable]) <;>
            (try norm_num) <;>
            (try linarith)
          · -- If r ≠ 0, we can use the fact that scalar multiplication by r is invertible
            have h₇ : IntervalIntegrable (r • f) μ a b := hf
            have h₈ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := h₇.smul_left r⁻¹
            have h₉ : (r⁻¹ • (r • f)) = f := by
              ext x
              simp [smul_smul, h₆]
              <;>
              simp_all [inv_smul_cancel_left]
              <;>
              aesop
            rw [h₉] at h₈
            exact h₈
        exact h₅
      -- Simplify the expression to show f is interval integrable
      have h₄ : (fun x => (1 : R) • f x) = f := by
        ext x
        simp [one_smul]
      rw [h₄] at h₃
      exact h₃
    
    exact ⟨h₁, h₂⟩
  
  exact h_main
