theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h_imp : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro hf
    have h₁ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
      -- Use the fact that scalar multiplication by a normed space element preserves integrability
      have h₂ : IntervalIntegrable f μ a b := hf
      have h₃ : Continuous (fun x : E => r • x) := by
        -- Scalar multiplication is continuous in normed spaces
        apply Continuous.smul
        · exact continuous_const
        · exact continuous_id
      -- Use the composition of continuous functions to show integrability
      have h₄ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := by
        -- Apply the composition rule for interval integrable functions
        apply h₂.comp_smul r
        <;> try simp_all [continuous_const]
        <;> try infer_instance
      exact h₄
    exact h₁
  
  have h_conv : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro h
    have h₁ : IntervalIntegrable (fun x : ℝ => r • f x) μ a b := h
    have h₂ : IntervalIntegrable f μ a b := by
      by_cases hr : r = 0
      · -- Case: r = 0
        simp_all [hr, smul_eq_zero]
      · -- Case: r ≠ 0
        have h₃ : IntervalIntegrable (fun x : ℝ => r⁻¹ • (r • f x)) μ a b := by
          apply h₁.comp_smul r⁻¹
          <;>
          (try simp_all) <;>
          (try
            {
              apply Continuous.smul
              · exact continuous_const
              · exact continuous_id
            }) <;>
          (try infer_instance)
        have h₄ : (fun x : ℝ => r⁻¹ • (r • f x)) = f := by
          funext x
          simp [smul_smul, hr]
          <;> field_simp [hr]
          <;> simp_all [smul_smul]
          <;> ring_nf
          <;> simp_all [hr]
        rw [h₄] at h₃
        exact h₃
    exact h₂
  
  have h_main : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · -- Prove the forward direction: if IntervalIntegrable f μ a b, then IntervalIntegrable (r • f) μ a b
      intro h
      exact h_imp h
    · -- Prove the reverse direction: if IntervalIntegrable (r • f) μ a b, then IntervalIntegrable f μ a b
      intro h
      exact h_conv h
  
  exact h_main
