theorem integral_add {μ : ComplexMeasure α} [SigmaFinite μ] (f g : α → ℂ) :
    ∫ x, f x + g x ∂μ = ∫ x, f x ∂μ + ∫ x, g x ∂μ := by
  calc
    ∫ x, f x + g x ∂μ = ∫ x, f x + g x ∂μ := rfl
    _ = ∫ x, f x ∂μ + ∫ x, g x ∂μ := by
      -- Use the linearity of the integral
