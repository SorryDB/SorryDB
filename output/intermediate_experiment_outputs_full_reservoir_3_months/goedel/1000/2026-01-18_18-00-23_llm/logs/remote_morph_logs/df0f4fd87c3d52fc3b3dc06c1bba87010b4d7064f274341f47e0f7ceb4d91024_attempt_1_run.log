theorem in_list_idx {α} {l : List α} {x : α} (H : x ∈ l) :
    ∃ i : Fin (List.length l), l[i] = x := by
  classical
  have h : ∃ i : ℕ, i < List.length l ∧ l[i] = x := by
    have h₁ : ∃ i : ℕ, i < List.length l ∧ l[i] = x := by
      -- Use the fact that the list contains x to find the index
      have h₂ : x ∈ l := H
      have h₃ : ∃ i : ℕ, i < List.length l ∧ l[i] = x := by
        -- Use the list.get? function to find the index
        have h₄ : ∃ i : ℕ, i < List.length l ∧ l[i] = x := by
          -- Use the list.index_of function to find the index
          use List.index_of x l
          have h₅ : x ∈ l := H
          have h₆ : List.index_of x l < List.length l := by
            apply List.index_of_lt_length
            <;> simp_all
          have h₇ : l[List.index_of x l] = x := by
            apply List.get_index_of
            <;> simp_all
          exact ⟨h₆, h₇⟩
        exact h₄
      exact h₃
    exact h₁
  -- Convert the index to Fin
  obtain ⟨i, hi₁, hi₂⟩ := h
  refine' ⟨⟨i, hi₁⟩, _⟩
  simp [hi₂]
