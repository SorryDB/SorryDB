theorem vec_in_if_idx {v : Vector α n} {x : α} (hin : x ∈ v) :
  ∃ i : Fin n, v[i] = x := by
  have h : ∃ i : Fin n, v.get i = x := by
    simpa [Vector.mem_iff] using hin
  obtain ⟨i, hi⟩ := h
  refine' ⟨i, _⟩
  <;> simp_all [Vector.get]
  <;> aesop

