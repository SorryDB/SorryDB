      -- Use the fact that the number of fixed points of the involution is 1 to deduce that the cardinality of U_k is odd
      have h₆ : Fintype.card (fixedPoints (secondInvo k)) = 1 := card_fixedPoints_eq_one
      have h₇ : (Fintype.card (U k) : ℕ) % 2 = 1 := by
        have h₈ : Fintype.card (fixedPoints (secondInvo k)) % 2 = 1 := by
          rw [h₆]
          <;> norm_num
        -- Since the number of fixed points is 1, the total number of elements in U_k is odd
        have h₉ : (Fintype.card (fixedPoints (secondInvo k)) : ℕ) % 2 = Fintype.card (U k) % 2 := by
          -- Use the involution property to show that the number of non-fixed points is even
          have h₁₀ : Fintype.card (U k) = Fintype.card (fixedPoints (secondInvo k)) + 2 * (Fintype.card (U k) - Fintype.card (fixedPoints (secondInvo k))) / 2 := by
            have h₁₁ : ∀ (x : U k), x ∈ fixedPoints (secondInvo k) ∨ (x ≠ secondInvo k x) := by
              intro x
              by_cases h : x = secondInvo k x
              · exact Or.inl ⟨x, by simp_all [IsFixedPt]⟩
              · exact Or.inr (by intro h₁₂; apply h; simp_all [IsFixedPt])
            have h₁₂ : Fintype.card (U k) = Fintype.card (fixedPoints (secondInvo k)) + Fintype.card {x : U k | x ≠ secondInvo k x} := by
              -- Split the set U_k into fixed points and non-fixed points
              have h₁₃ : Fintype.card (U k) = Fintype.card (fixedPoints (secondInvo k) ∪ {x : U k | x ≠ secondInvo k x}) := by
                apply Fintype.card_congr (Equiv.refl (U k))
              have h₁₄ : fixedPoints (secondInvo k) ∪ {x : U k | x ≠ secondInvo k x} = U k := by
                ext x
                simp [Set.mem_union, Set.mem_setOf_eq, IsFixedPt]
