            have h₉ : Fintype.card (U k) % 2 = 1 := by
              -- Use the fact that the second involution has a unique fixed point to deduce that the cardinality is odd
              have h₁₀ : (Fintype.card (U k) - Fintype.card (fixedPoints (secondInvo k))) % 2 = 0 := by
                -- Use the fact that the second involution has a unique fixed point to deduce that the cardinality is odd
                have h₁₁ : (Fintype.card (U k) - Fintype.card (fixedPoints (secondInvo k))) % 2 = 0 := by
                  -- Use the fact that the second involution has a unique fixed point to deduce that the cardinality is odd
                  have h₁₂ : (Fintype.card (U k) - Fintype.card (fixedPoints (secondInvo k))) % 2 = 0 := by
                    -- Use the fact that the second involution has a unique fixed point to deduce that the cardinality is odd
                    simp [h₈, secondInvo_sq]
                    <;>
                    simp_all [Fintype.card_congr]
                    <;>
                    simp_all [Fintype.card_congr]
                    <;>
                    norm_num
                    <;>
                    contradiction
                  exact h₁₂
                exact h₁₁
              have h₁₁ : Fintype.card (fixedPoints (secondInvo k)) = 1 := card_fixedPoints_eq_one
              omega
