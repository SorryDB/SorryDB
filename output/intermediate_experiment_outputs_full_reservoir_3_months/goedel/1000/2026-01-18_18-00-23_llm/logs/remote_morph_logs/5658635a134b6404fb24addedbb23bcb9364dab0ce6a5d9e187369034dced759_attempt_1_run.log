    have h₅ : Fintype.card (U k) = Fintype.card (T k) := h₁
    have h₆ : Odd (Fintype.card (U k)) := h₄
    have h₇ : Odd (Fintype.card (T k)) := by
      rw [h₅] at h₆
      exact h₆
    exact h₇
  exact h₂
