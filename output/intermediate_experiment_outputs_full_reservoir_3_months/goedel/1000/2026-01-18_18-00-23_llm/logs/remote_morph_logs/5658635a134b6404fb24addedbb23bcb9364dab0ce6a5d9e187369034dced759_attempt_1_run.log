                intro x hx₁ hx₂
                simp [Set.mem_setOf_eq, IsFixedPt] at hx₁ hx₂
                <;> tauto
              have h₁₆ : Fintype.card (fixedPoints (secondInvo k) ∪ {x : U k | x ≠ secondInvo k x}) = Fintype.card (fixedPoints (secondInvo k)) + Fintype.card {x : U k | x ≠ secondInvo k x} := by
                rw [Fintype.card_union_eq] <;> simp_all [Set.disjoint_left]
                <;>
                (try omega) <;>
                (try
                  {
                    aesop
                  })
              rw [h₁₆] at h₁₃
              linarith
            have h₁₃ : Fintype.card {x : U k | x ≠ secondInvo k x} % 2 = 0 := by
              -- The number of non-fixed points is even because they come in pairs
              have h₁₄ : ∀ (x : U k), x ≠ secondInvo k x → secondInvo k x ≠ x := by
                intro x hx
                intro h
                apply hx
                simp_all [Function.funext_iff]
