variable (f) in
/-- A function `f : ℝ → ℂ` is **uniformly almost periodic** if its set of `ε`, L∞-almost period is
relatively dense for all `ε > 0`. -/
def IsUnifAlmostPeriodic : Prop := ∀ ⦃ε⦄, 0 < ε → IsRelDense {t | IsLinftyAP ε t f}

/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := sorry

/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C :=
  by
    have h₁ : ∃ C, ∀ x, ‖f x‖ ≤ C := by
      -- We will use the fact that the set of ε-almost periods is relatively dense to show boundedness.
      have h₂ : ∃ l, IsRelDenseWith {t | IsLinftyAP (1 : ℝ) t f} l := by
        -- For ε = 1, the set of 1-almost periods is relatively dense.
        have h₃ : IsRelDense {t | IsLinftyAP (1 : ℝ) t f} := hf (by norm_num)
        -- Therefore, there exists an l such that the set is relatively dense with respect to l.
        rcases h₃ with ⟨l, h₃⟩
        exact ⟨l, h₃⟩
      -- Obtain l such that the set of 1-almost periods is relatively dense with respect to l.
      rcases h₂ with ⟨l, h₂⟩
      -- Since l > 0, we can use it to find a bound.
      have h₃ : 0 < l := by
        have h₄ : IsRelDenseWith {t | IsLinftyAP (1 : ℝ) t f} l := h₂
        exact IsRelDenseWith.pos h₄
      -- Use the fact that the set is relatively dense to find a bound.
      have h₄ : ∃ C, ∀ x, ‖f x‖ ≤ C := by
        -- We will show that f is bounded on the interval [0, l].
        have h₅ : ∃ (C : ℝ), ∀ x ∈ Set.Icc (0 : ℝ) l, ‖f x‖ ≤ C := by
          -- Since [0, l] is compact, f is bounded on it.
          have h₆ : IsCompact (Set.Icc (0 : ℝ) l) := isCompact_Icc
          -- The image of [0, l] under f is compact and hence bounded.
          have h₇ : ContinuousOn (fun x : ℝ => ‖f x‖ : ℝ → ℝ) (Set.Icc (0 : ℝ) l) := by
            -- The norm of f is continuous.
            apply ContinuousOn.norm
            continuity
          -- The image of [0, l] under the norm of f is bounded.
          have h₈ : ∃ (C : ℝ), ∀ x ∈ Set.Icc (0 : ℝ) l, ‖f x‖ ≤ C := by
            -- Use the extreme value theorem.
            obtain ⟨x₀, hx₀, hx₀'⟩ := h₆.exists_forall_ge (Set.nonempty_Icc.mpr (le_of_lt h₃)) h₇
            refine' ⟨‖f x₀‖, _⟩
            intro x hx
            exact le_of_not_gt (fun h => by
              have h₉ := hx₀' x hx
              linarith [h])
          -- Obtain the bound.
          exact h₈
        -- Obtain the bound on [0, l].
        rcases h₅ with ⟨C, h₅⟩
        -- Extend the bound to all real numbers.
        refine' ⟨C + 1, _⟩
        intro x
        -- Use the fact that the set of 1-almost periods is relatively dense.
        have h₆ : ∃ y ∈ Set.Ico (0 : ℝ) l, x + y ∈ {t | IsLinftyAP (1 : ℝ) t f} := h₂ x
        rcases h₆ with ⟨y, hy₁, hy₂⟩
        have h₇ : y ∈ Set.Ico (0 : ℝ) l := hy₁
        have h₈ : x + y ∈ {t | IsLinftyAP (1 : ℝ) t f} := hy₂
        have h₉ : IsLinftyAP (1 : ℝ) (x + y) f := by simpa using h₈
        have h₁₀ : ∀ x, ‖f (x + (x + y)) - f x‖ ≤ 1 := by
          intro x
          have h₁₁ : ‖f (x + (x + y)) - f x‖ ≤ 1 := by
            have h₁₂ : ‖f (x + (x + y)) - f x‖ = ‖f ((x + y) + x) - f x‖ := by ring_nf
            rw [h₁₂]
            have h₁₃ : ‖f ((x + y) + x) - f x‖ ≤ 1 := by
              have h₁₄ : ‖f ((x + y) + x) - f x‖ ≤ 1 := by
                have h₁₅ : ‖f ((x + y) + x) - f x‖ ≤ 1 := by
                  have h₁₆ : IsLinftyAP (1 : ℝ) (x + y) f := h₉
                  have h₁₇ : ‖f ((x + y) + x) - f x‖ ≤ 1 := h₁₆ x
                  exact h₁₇
                exact h₁₅
              exact h₁₄
            exact h₁₃
          exact h₁₁
        -- Use the bound on [0, l] to bound f(x).
        have h₁₁ : ‖f x‖ ≤ C + 1 := by
          have h₁₂ : ‖f (x + y)‖ ≤ C := by
            have h₁₃ : (x + y) ∈ Set.Icc (0 : ℝ) l := by
              constructor <;>
                (try norm_num at hy₁ ⊢) <;>
                (try norm_num) <;>
                (try linarith [hy₁.1, hy₁.2]) <;>
                (try
                  {
                    have h₁₄ : 0 ≤ y := by linarith [hy₁.1]
                    have h₁₅ : y < l := by linarith [hy₁.2]
                    linarith
                  })
            have h₁₄ : ‖f (x + y)‖ ≤ C := h₅ (x + y) h₁₃
            exact h₁₄
          have h₁₅ : ‖f x - f (x + y)‖ ≤ 1 := by
            have h₁₆ : ‖f (x + (x + y)) - f x‖ ≤ 1 := h₁₀ x
            have h₁₇ : ‖f (x + (x + y)) - f x‖ = ‖f ((x + y) + x) - f x‖ := by ring_nf
            have h₁₈ : ‖f ((x + y) + x) - f x‖ ≤ 1 := by simpa [h₁₇] using h₁₆
            have h₁₉ : ‖f x - f (x + y)‖ ≤ 1 := by
              have h₂₀ : ‖f ((x + y) + x) - f x‖ = ‖f (x + y + x) - f x‖ := by ring_nf
              have h₂₁ : ‖f (x + y + x) - f x‖ ≤ 1 := by simpa [h₂₀] using h₁₈
              have h₂₂ : ‖f (x + y + x) - f x‖ = ‖f (x + (y + x)) - f x‖ := by ring_nf
              have h₂₃ : ‖f (x + (y + x)) - f x‖ ≤ 1 := by simpa [h₂₂] using h₂₁
              have h₂₄ : ‖f (x + (y + x)) - f x‖ = ‖f (y + x + x) - f x‖ := by ring_nf
              have h₂₅ : ‖f (y + x + x) - f x‖ ≤ 1 := by simpa [h₂₄] using h₂₃
              have h₂₆ : ‖f x - f (x + y)‖ ≤ 1 := by
                -- Use the fact that the norm of the difference is bounded by 1.
                have h₂₇ : ‖f (x + y + x) - f x‖ = ‖f (x + y + x) - f x‖ := rfl
                have h₂₈ : ‖f (x + y + x) - f x‖ ≤ 1 := h₂₅
                have h₂₉ : ‖f x - f (x + y)‖ ≤ 1 := by
                  calc
                    ‖f x - f (x + y)‖ = ‖f (x + y) - f x‖ := by
                      rw [← norm_neg]
                      simp [sub_eq_add_neg, add_assoc]
                    _ ≤ ‖f (x + y + x) - f x‖ := by
                      -- Use the triangle inequality to bound the difference.
                      have h₃₀ : ‖f (x + y + x) - f x‖ = ‖(f (x + y + x) - f (x + y)) + (f (x + y) - f x)‖ := by
                        ring_nf
                        <;> simp [sub_eq_add_neg, add_assoc]
                        <;> ring_nf
                      rw [h₃₀]
                      have h₃₁ : ‖(f (x + y + x) - f (x + y)) + (f (x + y) - f x)‖ ≤ ‖f (x + y + x) - f (x + y)‖ + ‖f (x + y) - f x‖ := by
                        apply norm_add_le
                      have h₃₂ : ‖f (x + y + x) - f (x + y)‖ ≤ 1 := by
                        have h₃₃ : ‖f ((x + y) + x) - f (x + y)‖ ≤ 1 := h₉ (x + y)
                        have h₃₄ : ‖f ((x + y) + x) - f (x + y)‖ = ‖f (x + y + x) - f (x + y)‖ := by ring_nf
                        rw [h₃₄] at h₃₃
                        exact h₃₃
                      have h₃₃ : ‖f (x + y) - f x‖ ≥ 0 := by positivity
                      linarith
                    _ ≤ 1 := by linarith
                exact h₂₉
              exact h₂₆
            exact h₁₉
          have h₁₆ : ‖f x‖ ≤ ‖f (x + y)‖ + ‖f x - f (x + y)‖ := by
            calc
              ‖f x‖ = ‖f (x + y) + (f x - f (x + y))‖ := by ring_nf
              _ ≤ ‖f (x + y)‖ + ‖f x - f (x + y)‖ := by apply norm_add_le
          linarith
        exact h₁₁
      -- Obtain the global bound.
      exact h₄
    -- Obtain the final bound.
    exact h₁
