lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
  have h₁ : ‖cfc_toLinearFunctional ha x y‖ ≤ ‖x‖ * ‖y‖ := cfc_toLinearFunctional_bound x y
  have h₂ : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by
    -- Use the property of the Riesz measure to bound the integral by the norm of the functional
    have h₃ : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖cfc_toLinearFunctional ha x y f‖ := by
      simp [ComplexRMK.rieszMeasure_apply, toLinearFunctional_apply]
      <;>
      simp_all [ContinuousLinearMap.integral]
      <;>
      rfl
    rw [h₃]
    -- Use the operator norm bound for the linear functional
    have h₄ : ‖cfc_toLinearFunctional ha x y f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by
      -- Use the bound for the norm of the linear functional and the function
      calc
        ‖cfc_toLinearFunctional ha x y f‖ = ‖cfc_toLinearFunctional ha x y f‖ := rfl
        _ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by
          apply norm_mul_le
    exact h₄
  calc
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := h₂
    _ ≤ (‖x‖ * ‖y‖) * ‖(f : C((spectrum ℂ a), ℂ))‖ := by gcongr
    _ = ‖x‖ * ‖y‖ * ‖(f : C((spectrum ℂ a), ℂ))‖ := by ring

