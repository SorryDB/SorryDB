def toResolutionOfIdentity : ResolutionOfIdentity (spectrum ℂ a) H where
  measureOf' s := InnerProductSpace.continuousLinearMapOfBilin
    (@toBoundedBilin H inst✝² inst✝¹ inst✝ a ha 1 (Set.indicator s (1 : (spectrum ℂ a) → ℂ)))
  isOrthogonalProjection' := by sorry
  empty' := by
    ext
    simp [continuousLinearMapOfBilin, toBoundedBilin, cfc_toComplexMeasure, ComplexMeasure.integral]
    rfl
  not_measurable' := by sorry
  m_Union' := by sorry
  m_Inter' := by
    intro s t hs ht
    have h₁ : (s ∩ t).indicator (1 : (spectrum ℂ a) → ℂ) = (s.indicator (1 : (spectrum ℂ a) → ℂ)) * (t.indicator (1 : (spectrum ℂ a) → ℂ)) := by
      funext x
      by_cases hx : x ∈ s <;> by_cases hx' : x ∈ t <;> simp [hx, hx', Set.indicator]
      <;> aesop
    rw [h₁]
    have h₂ : continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 ((s.indicator (1 : (spectrum ℂ a) → ℂ)) * (t.indicator (1 : (spectrum ℂ a) → ℂ)))) =
      continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 (s.indicator (1 : (spectrum ℂ a) → ℂ))) *
        continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 (t.indicator (1 : (spectrum ℂ a) → ℂ))) := by
      have h₃ : continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 ((s.indicator (1 : (spectrum ℂ a) → ℂ)) * (t.indicator (1 : (spectrum ℂ a) → ℂ)))) =
          (continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 (s.indicator (1 : (spectrum ℂ a) → ℂ))) *
            continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 (t.indicator (1 : (spectrum ℂ a) → ℂ)))) := by
        have h₄ : (continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 (s.indicator (1 : (spectrum ℂ a) → ℂ))) *
            continuousLinearMapOfBilin (@toBoundedBilin H _ _ _ a ha 1 (t.indicator (1 : (spectrum ℂ a) → ℂ)))).toBilin = (@toBoundedBilin H _ _ _ a ha 1 ((s.indicator (1 : (spectrum ℂ a) → ℂ)) * (t.indicator (1 : (spectrum ℂ a) → ℂ)))).toBilin := by
          funext x y
