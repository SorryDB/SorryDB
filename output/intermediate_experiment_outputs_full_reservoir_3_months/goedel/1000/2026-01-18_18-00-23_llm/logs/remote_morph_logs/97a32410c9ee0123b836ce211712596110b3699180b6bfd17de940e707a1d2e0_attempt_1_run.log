    (cfc_toComplexMeasure ha x y).variation Set.univ ‚Č§ ‚ÄĖx‚ÄĖ‚āĎ * ‚ÄĖy‚ÄĖ‚āĎ := by
  calc
    (cfc_toComplexMeasure ha x y).variation Set.univ ‚Č§ ‚ÄĖcfc_toLinearFunctional ha x y‚ÄĖ := by
      -- Apply the Riesz-Markov-Kakutani theorem to bound the variation by the norm of the linear functional.
      have h‚āĀ : (cfc_toComplexMeasure ha x y).variation Set.univ ‚Č§ ‚ÄĖcfc_toLinearFunctional ha x y‚ÄĖ := by
        calc
          (cfc_toComplexMeasure ha x y).variation Set.univ ‚Č§ (cfc_toComplexMeasure ha x y).totalvariation := by
            exact MeasureTheory.sbv_measure_totalvariation_le (cfc_toComplexMeasure ha x y)
          _ = ‚ÄĖcfc_toLinearFunctional ha x y‚ÄĖ := by
            -- Use the Riesz-Markov-Kakutani theorem to equate the total variation with the norm of the linear functional.
            simp [ComplexRMK.rieszMeasure_totalvariation, Complex.norm_eq_abs]
            <;>
            simp_all [ContinuousLinearMap.norm_def, ContinuousLinearMap.smulRight_eq_smul]
            <;>
            norm_cast
            <;>
            simp_all [ComplexRMK.rieszMeasure_def]
      exact h‚āĀ
    _ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ := by
      -- Use the previously established bound on the norm of the linear functional.
      exact cfc_toLinearFunctional_bound x y
    _ ‚Č§ ‚ÄĖx‚ÄĖ‚āĎ * ‚ÄĖy‚ÄĖ‚āĎ := by
      -- Convert the product of norms to the product of extended norms.
      norm_cast
      <;>
      simp [norm_eq_abs]
      <;>
      simp_all [abs_of_nonneg, norm_nonneg, mul_comm]
      <;>
      nlinarith [norm_nonneg x, norm_nonneg y]
