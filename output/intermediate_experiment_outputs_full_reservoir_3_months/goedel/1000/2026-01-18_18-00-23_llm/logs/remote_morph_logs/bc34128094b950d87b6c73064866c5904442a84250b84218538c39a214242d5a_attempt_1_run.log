          have h₁₆ : m < n := h₅
          have h₁₇ : p m := by
            -- Use the fact that p is inductive to show that p m holds
            have h₁₈ : ∀ k ≥ m, p k := by
              intro k hk
              have h₁₉ : m ≤ k := hk
              have h₂₀ : p m := by
                -- Use the fact that p is inductive to show that p m holds
