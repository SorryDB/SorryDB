structure SimpleRing {
  mul_assoc {a b c : α} : (a * b) * c = a * (b * c)
  mul_comm {a b : α} : a * b = b * a
  mul_left_comm {a b c : α} : (a * b) * c = a * (b * c)
  add_assoc {a b c : α} : a + b + c = a + (b + c)
  add_comm {a b : α} : a + b = b + a
  add_left_comm {a b c : α} : a + b + c = a + (b + c)
  add_zero {a : α} : a + 0 = a
  zero_add {a : α} : 0 + a = a
  mul_one {a : α} : a * 1 = a
  one_mul {a : α} : 1 * a = a
  add_neg_cancel {a : α} : a + (-a) = 0
  neg_add_cancel {a : α} : (-a) + a = 0
  neg_neg {a : α} : -(-a) = a
  mul_add {a b c : α} : a * (b + c) = a * b + a * c
  add_mul {a b c : α} : (a + b) * c = a * c + b * c
}
