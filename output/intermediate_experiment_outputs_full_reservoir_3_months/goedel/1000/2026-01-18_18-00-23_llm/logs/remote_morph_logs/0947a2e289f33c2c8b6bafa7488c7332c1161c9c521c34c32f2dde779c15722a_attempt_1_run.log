lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₁ : ∫ x in 0..π, sin x * f (cos x) = ∫ x in 0..π, sin x * f (cos x) := rfl
  rw [h₁]
  -- Use the substitution y = cos(x), dy = -sin(x) dx
  have h₂ : ∫ x in 0..π, sin x * f (cos x) = ∫ y in cos π..cos 0, f y := by
    have h₃ : ∫ x in 0..π, sin x * f (cos x) = ∫ x in 0..π, f (cos x) * sin x := by
      congr
      <;> ext x
      <;> ring
    rw [h₃]
    -- Use the substitution y = cos(x), dy = -sin(x) dx
    have h₄ : ∫ x in 0..π, f (cos x) * sin x = ∫ y in cos π..cos 0, f y := by
      have h₅ : ∫ x in 0..π, f (cos x) * sin x = ∫ y in cos π..cos 0, f y := by
        have h₆ : (fun x => cos x) = (fun x => cos x) := rfl
        -- Use the substitution rule for integrals
        have h₇ : ∫ x in 0..π, f (cos x) * sin x = ∫ y in cos π..cos 0, f y := by
          rw [intervalIntegral.integral_comp_cos (fun x => f x)]
          <;> simp [cos_pi, cos_zero]
          <;> ring_nf
          <;> norm_num
        rw [h₇]
      rw [h₅]
    rw [h₄]
  rw [h₂]
  -- Simplify the bounds of integration
  have h₃ : cos π = -1 := by norm_num [cos_pi]
  have h₄ : cos 0 = 1 := by norm_num [cos_zero]
  rw [h₃, h₄]
  -- The integral from -1 to 1 is the same as the integral from 1 to -1 but with a sign change
  have h₅ : ∫ y in (-1 : ℝ)..(1 : ℝ), f y = ∫ y in (-1 : ℝ)..(1 : ℝ), f y := rfl
  rw [h₅]
  <;> simp [intervalIntegral.integral_symm]
  <;> ring_nf
  <;> norm_num
