example (a b : ℝ) : ∫ x in a..b, 2 * x * exp (x ^ 2) =
    exp (b ^ 2) - exp (a ^ 2) := by
  have h : ∫ x in a..b, 2 * x * exp (x ^ 2) = (exp (b ^ 2) - exp (a ^ 2)) := by
    have h1 : (∫ x in a..b, 2 * x * exp (x ^ 2)) = ∫ x in a..b, (exp (x ^ 2))' := by
      congr
      ext x
      -- Prove that the derivative of exp(x^2) is 2 * x * exp(x^2)
      have h2 : (exp (x ^ 2))' = 2 * x * exp (x ^ 2) := by
        -- Use the chain rule to find the derivative
        have h3 : (exp (x ^ 2))' = exp (x ^ 2) * (2 * x) := by
          -- Apply the chain rule
          simp [Real.differentiableAt_exp, mul_comm]
          <;> field_simp [Real.differentiableAt_exp]
          <;> ring_nf
          <;> norm_num
          <;> ring_nf
          <;> field_simp [Real.differentiableAt_exp]
          <;> linarith
        -- Simplify the expression to match the required form
        calc
          (exp (x ^ 2))' = exp (x ^ 2) * (2 * x) := h3
          _ = 2 * x * exp (x ^ 2) := by ring
      -- Substitute the derivative back into the integral
      rw [h2]
    -- Use the fundamental theorem of calculus to evaluate the integral
    rw [h1]
    -- The integral of the derivative over [a, b] is the difference of the function at the endpoints
    simp [intervalIntegral.integral_deriv_eq_sub']
    <;>
    (try
      {
        -- Prove that exp(x^2) is differentiable on [a, b]
        apply Continuous.intervalIntegrable
        continuity
      })
    <;>
    (try
      {
        -- Prove that exp(x^2) is continuous on [a, b]
        apply Continuous.differentiableAt
        continuity
      })
    <;>
    (try
      {
        -- Simplify the expression using the properties of exp
        simp [Real.exp_ne_zero]
        <;>
        norm_num
      })
  -- The final result follows from the previous steps
  linarith
```
