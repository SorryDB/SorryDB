example (a b : ℝ) : ∫ x in a..b, 2 * x * exp (x ^ 2) =
    exp (b ^ 2) - exp (a ^ 2) := by
  have h₁ : ∫ x in a..b, 2 * x * exp (x ^ 2) = exp (b ^ 2) - exp (a ^ 2) := by
    -- Recognize that 2 * x is the derivative of x^2, so we can use the chain rule.
    have h₂ : ∫ x in a..b, 2 * x * exp (x ^ 2) = ∫ x in a..b, (exp (x ^ 2))' := by
      congr
      funext x
      -- Differentiate exp(x^2) with respect to x to get 2 * x * exp(x^2).
      have h₃ : HasDerivAt (fun x : ℝ => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := by
        have h₄ : HasDerivAt (fun x : ℝ => x ^ 2) (2 * x) x := by
          simpa using (hasDerivAt_pow 2 x)
        have h₅ : HasDerivAt (fun x : ℝ => exp (x ^ 2)) (exp (x ^ 2) * (2 * x)) x := by
          have h₆ : HasDerivAt (fun x : ℝ => x ^ 2) (2 * x) x := h₄
          have h₇ : HasDerivAt (fun x : ℝ => exp (x ^ 2)) (exp (x ^ 2) * (2 * x)) x := by
            -- Use the chain rule to differentiate exp(x^2).
            simpa using (Real.hasDerivAt_exp (x ^ 2)).comp x h₆
          exact h₇
        -- Simplify the expression to match the form 2 * x * exp(x^2).
        convert h₅ using 1
        <;> ring_nf
        <;> field_simp [mul_comm]
        <;> ring_nf
      -- Use the derived result to rewrite the integrand.
      have h₈ : (exp (x ^ 2))' = 2 * x * exp (x ^ 2) := by
        -- Use the fact that the derivative of exp(x^2) is 2 * x * exp(x^2).
        convert HasDerivAt.deriv h₃ using 1 <;> simp [mul_comm]
        <;> ring_nf
        <;> field_simp [mul_comm]
        <;> ring_nf
      -- Substitute back into the integral.
      rw [h₈]
    -- Apply the fundamental theorem of calculus to evaluate the integral.
    rw [h₂]
    <;> simp [exp_ne_zero]
    <;>
    (try norm_num) <;>
    (try ring_nf) <;>
    (try field_simp [exp_ne_zero]) <;>
    (try norm_num) <;>
    (try linarith)
  -- Final result follows directly from the previous steps.
  exact h₁
