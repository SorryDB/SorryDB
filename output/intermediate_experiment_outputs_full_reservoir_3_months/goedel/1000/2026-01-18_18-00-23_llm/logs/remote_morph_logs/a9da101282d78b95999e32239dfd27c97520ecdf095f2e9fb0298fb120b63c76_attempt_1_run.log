              apply HasDerivAt.exp
              exact h₇
            exact h₈
          -- Since the derivative is exp(x^2) * 2x, we can use it directly
          have h₉ : exp (x ^ 2) * (2 * x) = exp (x ^ 2) * (2 * x) := rfl
