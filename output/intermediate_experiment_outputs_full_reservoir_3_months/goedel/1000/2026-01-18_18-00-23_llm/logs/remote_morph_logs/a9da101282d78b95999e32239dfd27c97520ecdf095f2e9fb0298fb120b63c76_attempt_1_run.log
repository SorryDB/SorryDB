      -- Use the fundamental theorem of calculus and the fact that the antiderivative of exp(x^2) * 2x is exp(x^2)
      have h₅ : ∫ x in a..b, exp (x ^ 2) * (2 * x) = (exp (b ^ 2) - exp (a ^ 2)) := by
