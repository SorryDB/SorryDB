def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) D where
  F := fun ⟨X, _, _⟩ => X
  homF := fun ⟨hk, _⟩ => hk.1
  map_id X := by
    dsimp [F]
    <;> rfl
  map_comp f g := by
    dsimp [F]
    <;> simp [CD]
    <;> rfl

def Comma_category_cod {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) E where
  F := fun ⟨_, Y, _⟩ => Y
  homF := fun ⟨hk, _⟩ => hk.2
  map_id X := by
    dsimp [F]
    <;> rfl
  map_comp f g := by
    dsimp [F]
    <;> simp [CE]
    <;> rfl

instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where
  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := by
    intro a b
    obtain ⟨⟨d₁, e₁, f⟩, ⟨d₂, e₂, f'⟩⟩ := a
    obtain ⟨d₃, e₃, f''⟩ := b
    dsimp [id]
    <;> ext
    <;> simp [comp, CD.id_comp, CE.id_comp, F.map_id, G.map_id]
    <;> rfl

  comp_id := by
    intro a b
    obtain ⟨⟨d₁, e₁, f⟩, ⟨d₂, e₂, f'⟩⟩ := a
    obtain ⟨d₃, e₃, f''⟩ := b
    dsimp [id]
    <;> ext
    <;> simp [comp, CD.comp_id, CE.comp_id, F.map_id, G.map_id]
    <;> rfl

  assoc := by
    intro a b c
    obtain ⟨⟨d₁, e₁, f⟩, ⟨d₂, e₂, f'⟩⟩ := a
    obtain ⟨⟨d₃, e₃, f''⟩, ⟨d₄, e₄, f'''⟩⟩ := b
    obtain ⟨d₅, e₅, f''''⟩ := c
    dsimp [comp]
    <;> ext
    <;> simp [CD.assoc, CE.assoc, F.map_comp, G.map_comp]
    <;> rw [← Category.assoc]
    <;> rw [← Category.assoc]
    <;> simp_all [Function.prod_mk.injEq]
    <;> aesop
