instance (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    cases' x with xα xβ
    -- Since the support of the product space is the product of the supports,
    -- and both components have full support, the pair (xα, xβ) is in the support.
    have h₁ : xα ∈ support ($ᵗ α) := by
      apply SampleableType.mem_support_selectElem
    have h₂ : xβ ∈ support ($ᵗ β) := by
      apply SampleableType.mem_support_selectElem
    -- Use the fact that the product of supports is in the support of the product
    have h₃ : (xα, xβ) ∈ support ((·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
      -- This follows from the fact that the product of supports is in the support of the product
      apply InSet.mem_map.mpr ⟨xα, InSet.mem_map.mpr ⟨xβ, mem_univ, by simp⟩, by simp⟩
    exact h₃
  
  probOutput_selectElem_eq := by
    intro x y
    simp [probOutput_seq_map_prod_mk_eq_mul]
    <;> simp [probOutput_uniformSample]
    <;> simp_all [Fintype.card_pos]
    <;> ring_nf
    <;> norm_num
    <;> rfl
  
  probFailure_selectElem := by
    simp [probFailure_seq]
    <;>
    (try simp [SampleableType.probFailure_selectElem])
    <;>
    (try simp [probFailure_bin, probFailure_map, probFailure_uniformSample])
    <;>
    (try simp [SampleableType.probFailure_selectElem])
