theorem partials_helper3 {pbar : Pose} {ε : ℝ} {poly : GoodPoly}
    (pc : GlobalTheoremPrecondition poly pbar ε) (P : ℝ³) :
    ‖P‖ * nth_partial 0 (GlobalTheoremPrecondition.fu_outer P pc) pbar.outerParams =
    ⟪pbar.rotM₂θ P, pc.w⟫ := by
  have := pc.norm_S_ne_zero
  simp [GlobalTheoremPrecondition.fu_outer, nth_partial, rotproj_outer_unit]
  <;>
  simp_all [InnerProductSpace.ext_iff, matrix.cons_val_zero, matrix.cons_val_succ, matrix.head_cons,
    matrix.cons_val_zero, matrix.cons_val_succ, matrix.head_cons, Fin.val_zero, Fin.val_succ]
  <;>
  norm_num
  <;>
  ring_nf
  <;>
  field_simp
  <;>
  norm_cast
  <;>
  simp_all [inner]
  <;>
  norm_num
  <;>
  linarith
```
