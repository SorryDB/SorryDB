    (v.set (↑idx) elt).mapFinIdx f = (v.mapFinIdx f).set (↑idx) (f (↑idx) elt (Fin.is_lt idx)) := by
    classical
    have h₁ : ∀ (v : Vector α n) (f : (i : ℕ) → α → (i < n) → β) (i : Fin n),
