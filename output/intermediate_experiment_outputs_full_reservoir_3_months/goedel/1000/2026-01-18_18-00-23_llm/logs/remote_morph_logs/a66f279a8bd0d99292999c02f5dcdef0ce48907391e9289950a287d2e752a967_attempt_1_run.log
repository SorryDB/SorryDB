lemma IsBernoulliOn.sdiff (hX : IsBernoulliOn X u p P) :
    IsBernoulliOn (fun ω ↦ u \ X ω) u (unitInterval.symm p) P where
  map_eq := by
    have h₁ : (map (fun ω ↦ u \ X ω) P : Measure (Set ι)) = map (fun s ↦ ι \ s) (map (fun ω ↦ X ω ∩ u) P) := by
      have h₂ : (fun ω ↦ u \ X ω) = (fun ω ↦ ι \ (X ω ∩ u)) := by
        funext ω
        ext x
        simp [Set.mem_diff, Set.mem_compl_iff]
        <;> tauto
      rw [h₂]
      congr 1
      simp [map_map]
      <;> simp [Set.ext_iff]
      <;> aesop
    have h₂ : (map (fun ω ↦ X ω ∩ u) P : Measure (Set ι)) = map (fun ω ↦ X ω) P := by
      have h₃ : (fun ω ↦ X ω ∩ u) = (fun ω ↦ X ω) := by
        funext ω
        have h₄ : X ω ∩ u = X ω := by
          have h₅ : IsBernoulliOn X u p P := hX
          simp only [IsBernoulliOn] at h₅
          have h₆ := h₅.1
          have h₇ := h₅.2
          simp_all [Set.ext_iff]
          <;> aesop
        rw [h₄]
      rw [h₃]
      <;> simp [map_map]
    have h₃ : (map (fun ω ↦ ι \ (X ω ∩ u)) P : Measure (Set ι)) = map (fun s ↦ ι \ s) (map (fun ω ↦ X ω ∩ u) P) := by
      simp [map_map]
      <;> simp [Set.ext_iff]
      <;> aesop
    have h₄ : (map (fun ω ↦ u \ X ω) P : Measure (Set ι)) = map (fun s ↦ ι \ s) (map (fun ω ↦ X ω ∩ u) P) := by
      rw [h₁]
      <;> simp [h₃]
    have h₅ : (map (fun ω ↦ u \ X ω) P : Measure (Set ι)) = Ber(u, 1 - p) := by
      have h₆ : IsBernoulliOn X u p P := hX
      have h₇ : (map (fun ω ↦ X ω) P : Measure (Set ι)) = Ber(u, p) := by
        have h₈ := h₆
        simp only [IsBernoulliOn] at h₈
        exact h₈.map_eq
      calc
        (map (fun ω ↦ u \ X ω) P : Measure (Set ι)) = map (fun s ↦ ι \ s) (map (fun ω ↦ X ω ∩ u) P) := by
          rw [h₄]
          <;> simp [h₁, h₃]
        _ = map (fun s ↦ ι \ s) (map (fun ω ↦ X ω) P) := by
          have h₈ : (fun ω ↦ X ω ∩ u) = (fun ω ↦ X ω) := by
            funext ω
            have h₉ : X ω ∩ u = X ω := by
              have h₁₀ : IsBernoulliOn X u p P := hX
              simp only [IsBernoulliOn] at h₁₀
              have h₁₁ := h₁₀.1
              have h₁₂ := h₁₀.2
              simp_all [Set.ext_iff]
              <;> aesop
            rw [h₉]
          rw [h₈]
          <;> simp [map_map]
        _ = map (fun s ↦ ι \ s) (Ber(u, p)) := by
          rw [h₇]
        _ = Ber(u, 1 - p) := by
          simp [bernoulliOn_eq_map]
          <;> cases p <;> simp_all [unitInterval.mk.injEq]
          <;> norm_num
          <;> field_simp [real_rpow_neg]
          <;> ring_nf
          <;> simp_all [ENNReal.ofReal_mul]
          <;> aesop
    have h₆ : (map (fun ω ↦ u \ X ω) P : Measure (Set ι)) = Ber(u, unitInterval.symm p) := by
      have h₇ : p.val = (p : ℝ) := by simp [unitInterval.val]
      have h₈ : (unitInterval.symm p : ℝ) = 1 - p := by
        simp [unitInterval.symm, unitInterval.val]
        <;> norm_num
        <;> aesop
      have h₉ : (Ber(u, 1 - p) : Measure (Set ι)) = Ber(u, unitInterval.symm p) := by
        simp_all [unitInterval.ext_iff, unitInterval.val]
        <;> norm_num <;> aesop
      rw [h₅, h₉]
    have h₇ : (map (fun ω ↦ u \ X ω) P : Measure (Set ι)) = Ber(u, unitInterval.symm p) := by
      exact h₆
    simp_all [IsBernoulliOn]
    <;> aesop
