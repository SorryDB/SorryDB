    have h₂ : HasLaw (fun ω ↦ u \ X ω) (bernoulliOn u (σ p)) P := by
      have h₃ : (fun ω ↦ u \ X ω) = (fun A ↦ u \ A) ∘ X := rfl
      rw [h₃]
      have h₄ : HasLaw ((fun A ↦ u \ A) ∘ X) ((fun A ↦ u \ A) ∘ₘ bernoulliOn u p) P :=
