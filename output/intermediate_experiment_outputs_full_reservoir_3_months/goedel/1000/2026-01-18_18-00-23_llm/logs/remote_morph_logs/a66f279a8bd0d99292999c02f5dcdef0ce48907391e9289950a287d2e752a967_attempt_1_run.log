lemma IsBernoulliOn.sdiff (hX : IsBernoulliOn X u p P) :
    IsBernoulliOn (fun ω ↦ u \ X ω) u (σ p) P where
  map_eq := by
    have h₁ : (σ : UnitInterval → UnitInterval) p = 1 - p := by simp [unitInterval.symm_apply]
    have h₂ : (fun ω ↦ u \ X ω) = (fun ω ↦ u \ X ω) := rfl
    have h₃ : map (fun ω ↦ u \ X ω) P = Ber(u, σ p) := by sorry
    simpa [h₃, h₁] using h₃
  <;> uses h₂
