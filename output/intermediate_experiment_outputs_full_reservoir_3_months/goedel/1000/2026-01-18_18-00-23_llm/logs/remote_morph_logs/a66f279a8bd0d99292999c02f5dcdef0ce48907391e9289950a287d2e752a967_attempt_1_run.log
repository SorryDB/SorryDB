      have h₅ : ((fun A ↦ u \ A) ∘ₘ bernoulliOn u p) = bernoulliOn u (σ p) := by
        -- Since (p + q = 1), the mapping A ↦ u \ A transforms BernoulliOn u p into BernoulliOn u q
