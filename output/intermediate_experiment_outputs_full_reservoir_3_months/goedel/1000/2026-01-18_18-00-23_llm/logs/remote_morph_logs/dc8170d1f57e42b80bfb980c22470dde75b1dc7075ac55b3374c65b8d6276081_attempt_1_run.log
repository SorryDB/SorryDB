structure emptyPrimeFTheory (L : Logic _) [Entailment.F L] [Entailment.Disjunctive L] : PrimeFTheory L where
  theory := L
  no_bot := by
    have := not_provable_bot L
    simp_all [not_in]
    <;> tauto
  andIR := by
    intro ŌÜ Ōą hŌÜ hŌą
    -- Prove that the conjunction of two formulas in the theory is also in the theory.
    have h : ŌÜ ‚čŹ Ōą ‚ąą L := by
      apply AndI
      <;> assumption
    exact h
  imp_closed := by
    intro ŌÜ Ōą hŌÜŌą hŌÜ
    -- Prove that if ŌÜ implies Ōą and ŌÜ is in the theory, then Ōą is in the theory.
    have h : Ōą ‚ąą L := by
      apply CharRule
      <;> assumption
    exact h
  L_subset := by
    intro ŌÜ hŌÜ
    -- Prove that the logic L is a subset of the theory (which is L itself).
    exact hŌÜ
  prime := by
    intro ŌÜ Ōą hŌÜŌą
    -- Prove that if the disjunction of ŌÜ and Ōą is in the theory, then either ŌÜ is in the theory or Ōą is in the theory.
    have h : ŌÜ ‚ąą L ‚ą® Ōą ‚ąą L := by
      have h‚āĀ : ŌÜ ‚čé Ōą ‚ąą L := hŌÜŌą
      have h‚āā : ŌÜ ‚ąą L ‚ą® Ōą ‚ąą L := by
        -- Use the disjunctive property of the logic L.
        have h‚āÉ : ŌÜ ‚čé Ōą ‚ąą L := hŌÜŌą
        have h‚āĄ : ŌÜ ‚ąą L ‚ą® Ōą ‚ąą L := by
          -- Use the disjunctive property of the logic L.
          by_cases h‚āÖ : ŌÜ ‚ąą L
          ¬∑ exact Or.inl h‚āÖ
          ¬∑ have h‚āÜ : ¬¨ŌÜ ‚ąą L := h‚āÖ
            have h‚āá : Ōą ‚ąą L := by
              -- If ŌÜ is not in L, then Ōą must be in L because ŌÜ ‚čé Ōą is in L.
              have h‚āą : ŌÜ ‚čé Ōą ‚ąą L := hŌÜŌą
              have h‚āČ : ŌÜ ‚ąą L ‚ą® Ōą ‚ąą L := by
                -- Use the disjunctive property of the logic L.
                exact (OrD (ŌÜ := ŌÜ) (Ōą := Ōą) h‚āą)
              cases h‚āČ with
              | inl h‚āČ =>
                exfalso
                apply h‚āÜ
                exact h‚āČ
              | inr h‚āČ =>
                exact h‚āČ
            exact Or.inr h‚āá
        exact h‚āĄ
      exact h‚āā
    exact h
