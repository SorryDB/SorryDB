theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  constructor
  · -- Prove the forward direction: if U is countable, then there exists an injective function from U to ℕ.
    intro h
    -- Use the fact that U is countable to get an equivalence with ℕ.
    have h₁ : ∃ (f : U → ℕ), one_to_one f := by
      -- Use the countable set to construct an injective function.
      classical
      -- Use the countable choice to get a bijection between U and ℕ.
      have : ctble U := h
      -- Convert the countable set to an injective function.
      exact by
        simpa [ctble_iff_exists_injective] using this
    -- Obtain the injective function and use it to conclude the proof.
    exact h₁
  · -- Prove the reverse direction: if there exists an injective function from U to ℕ, then U is countable.
    intro h
    -- Use the fact that there exists an injective function to show U is countable.
    have h₁ : ctble U := by
      -- Use the injective function to construct an equivalence with ℕ.
      classical
      -- Extract the injective function from the hypothesis.
      rcases h with ⟨f, hf⟩
      -- Use the injective function to show U is countable.
      exact ⟨f, hf⟩
    -- Conclude that U is countable.
    exact h₁
