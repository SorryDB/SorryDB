theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  have h : ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
    constructor
    · -- Prove the forward direction: if U is countable, then there exists an injective function from U to ℕ
      intro h_ctble
      -- Use the fact that U is countable to get an injective function into ℕ
      have h₁ : ∃ (f : U → ℕ), Function.Injective f := by
        -- Use the countable property to obtain an injective function to ℕ
        obtain ⟨f, hf⟩ := h_ctble
        refine' ⟨fun x => f ⟨x, by simp_all⟩, _⟩
        intro a b h_eq
        simp_all [Subtype.ext_iff]
        <;> aesop
      obtain ⟨f, hf⟩ := h₁
      refine' ⟨f, _⟩
      -- Confirm that the function is injective
      exact hf
    · -- Prove the reverse direction: if there exists an injective function from U to ℕ, then U is countable
      intro h_injective
      -- Use the injective function to show that U is countable
      obtain ⟨f, hf⟩ := h_injective
      have h₁ : ctble U := by
        -- Use the fact that there is an injective function to ℕ to deduce countability
        apply CtblOfInjOn f (Set.univ : Set ℕ)
        · intro x y hxy
          -- Prove that the function is injective on the entire set of ℕ
          apply hf
          exact hxy
        · -- Prove that the set { x : ℕ | x ∈ univ } is countable
          exact Set.countable_univ
      -- Confirm that U is countable
      exact h₁
  exact h
