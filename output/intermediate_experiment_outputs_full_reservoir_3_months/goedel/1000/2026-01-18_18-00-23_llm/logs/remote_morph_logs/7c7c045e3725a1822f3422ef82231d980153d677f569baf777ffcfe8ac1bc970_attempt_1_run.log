```lean
theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  have h₁ : ctble U → ∃ (f : U → Nat), one_to_one f := by
    intro h
    -- Use the fact that a countable type can be injectively mapped to ℕ
    have h₂ : ∃ (f : U → ℕ), Function.Injective f := by
      -- Use the `denumerable` instance to get the injection
      have h₃ : Denumerable U := by
        -- Since U is countable, it is either finite or denumerable
        cases' h with h₄ h₄
        · -- Case: U is finite
          exact inferInstance
        · -- Case: U is denumerable
          exact h₄
      -- Extract the injection from the denumerable instance
      exact ⟨h₃.f, h₃.f.injective⟩
    -- Convert the injective function to the required form
    obtain ⟨f, hf⟩ := h₂
    refine' ⟨f, _⟩
    exact hf
  
  have h₂ : (∃ (f : U → Nat), one_to_one f) → ctble U := by
    intro h
    -- We use the fact that if there exists an injective function from U to ℕ, then U is countable.
    have h₃ : ctble U := by
      -- Since there exists an injective function from U to ℕ, U is countable by definition.
      obtain ⟨f, hf⟩ := h
      have h₄ : Denumerable U := by
        -- Use the injective function to show that U is denumerable.
        have h₅ : Function.Injective f := hf
        -- Use the fact that ℕ is denumerable and f is injective to show that U is denumerable.
        have h₆ : Denumerable ℕ := inferInstance
        -- Use the fact that f is injective to show that U is denumerable.
        exact Denumerable.of_injective f hf
      -- Since U is denumerable, it is countable.
      exact ctble_of_denum h₄
    -- Therefore, U is countable.
    exact h₃
  
  exact ⟨h₁, h₂⟩
