theorem Theorem_8_1_5_3_type {U : Type} :
    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  constructor
  · -- Prove the forward direction: if U is countable, then there exists an injective function from U to ℕ
    intro h
    have h₁ : ∃ (f : U → Nat), one_to_one f := by
      -- Use the fact that U is countable to get an injective function to ℕ
      obtain ⟨f, hf⟩ := h
      exact ⟨f, hf⟩
    exact h₁
  · -- Prove the reverse direction: if there exists an injective function from U to ℕ, then U is countable
    intro h
    obtain ⟨f, hf⟩ := h
    have h₁ : ctble U := by
      -- Use the injective function to show U is countable
      exact ⟨f, hf⟩
    exact h₁
