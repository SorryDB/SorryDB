theorem SteinsLemma {ι : Type*} [UnitalFreeStateTheory ι] (i : ι) (ρ : MState (H i)) (ε : Prob)
  (hε : 0 < ε ∧ ε < 1) (σ : ℕ → (↑IsFree)) :
  ∃ (ε' : Prob), 0 < ε' ∧ ε' < ε ∧
  (
    (R1 ρ ε : ℝ≥0∞) < (R2 ρ σ : ℝ≥0∞) ∧
    1 - ε' ≫ 0 →
      (liminf (fun n : ℕ => 𝐃(ρ⊗^S[n]‖σ n) / n : ℕ → ℝ≥0∞) : ℝ≥0∞)
      - (R1 ρ ε : ℝ≥0∞) ≰ (1 - ε') • ((R2 ρ σ : ℝ≥0∞) - (R1 ρ ε : ℝ≥0∞))
  ) := by
  have h₁ : ∃ (ε' : Prob), 0 < ε' ∧ ε' < ε := by
    -- We can always find a positive ε' less than ε
    have h₂ : 0 < ε := hε.1
    have h₃ : ε < 1 := hε.2
    -- Choose ε' = ε / 2
    use ε / 2
    constructor
    · -- Prove 0 < ε / 2
      exact div_pos h₂ (by norm_num)
    · -- Prove ε / 2 < ε
      have h₄ : ε / 2 < ε := by
        have h₅ : 0 < ε := h₂
        have h₆ : ε / 2 < ε := by
          linarith
        exact h₆
      exact h₄
  obtain ⟨ε', hε'_pos, hε'_lt⟩ := h₁
  refine' ⟨ε', hε'_pos, hε'_lt, _⟩
  intro h
  -- The implication is trivially true because the conclusion is false
  <;> simp_all [h]
  <;> norm_num
  <;> try contradiction
  <;> try linarith
