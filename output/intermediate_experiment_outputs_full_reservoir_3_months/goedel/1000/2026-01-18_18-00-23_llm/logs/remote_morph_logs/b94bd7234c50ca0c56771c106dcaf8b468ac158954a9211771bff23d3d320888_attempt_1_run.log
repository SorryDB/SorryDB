example (x : ℝ) : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by
  have h₁ : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by
    -- Use the fundamental theorem of calculus to compute the integral of t * exp(t)
    have h₂ : ∫ t in 0..x, t * exp t = (x * exp x - exp x) - (0 * exp 0 - exp 0) := by
      -- Use integration by parts to find the antiderivative of t * exp(t)
      have h₃ : ∫ t in 0..x, t * exp t = (x * exp x - exp x) - (0 * exp 0 - exp 0) := by
        -- Compute the integral using the fundamental theorem of calculus
        rw [intervalIntegral.integral_eq_sub_of_hasDerivAt (fun x _ => by
          -- Show that the derivative of (x * exp(x) - exp(x)) is x * exp(x)
          have h₄ : HasDerivAt (fun x : ℝ => x * exp x - exp x) (x * exp x) x := by
            -- Use the product rule and chain rule to find the derivative
            have h₅ : HasDerivAt (fun x : ℝ => x * exp x) (1 * exp x + x * exp x) x := by
              -- Apply the product rule
              simpa using (hasDerivAt_id x).mul (Real.hasDerivAt_exp x)
            have h₆ : HasDerivAt (fun x : ℝ => exp x) (exp x) x := Real.hasDerivAt_exp x
            have h₇ : HasDerivAt (fun x : ℝ => x * exp x - exp x) (1 * exp x + x * exp x - exp x) x := by
              -- Subtract the derivatives
              convert h₅.sub h₆ using 1 <;> ring
            convert h₇ using 1 <;> ring_nf <;> field_simp [Real.exp_ne_zero] <;> ring
          convert h₄ using 1 <;> ring_nf <;> field_simp [Real.exp_ne_zero] <;> ring
        ) (fun x _ => by
          -- Show that the function is continuous on [0, x]
          continuity
        )]
        <;> simp [exp_zero]
        <;> ring_nf
        <;> field_simp [Real.exp_ne_zero]
        <;> ring_nf
      exact h₃
    -- Simplify the expression to get the final result
    have h₄ : (x * exp x - exp x) - (0 * exp 0 - exp 0) = (x - 1) * exp x + 1 := by
      simp [exp_zero]
      <;> ring_nf
      <;> field_simp [Real.exp_ne_zero]
      <;> ring_nf
      <;> linarith [Real.exp_pos x]
    rw [h₂, h₄]
  -- The final result follows from the previous steps
  exact h₁
