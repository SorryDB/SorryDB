example (x : ℝ) : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by
  have h₀ : (∫ t in 0..x, t * exp t) = (x - 1) * exp x + 1 := by
    have h₁ : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by
      -- Use integration by parts to solve the integral
      have h₂ : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by
        -- Use the fundamental theorem of calculus to evaluate the integral
        have h₃ : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by
          -- Use the fundamental theorem of calculus to evaluate the integral
          have h₄ : (∫ t in 0..x, t * exp t) = (x - 1) * exp x + 1 := by
            -- Compute the antiderivative of t * exp(t)
            have h₅ : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by
              -- Use the fundamental theorem of calculus to evaluate the integral
              rw [intervalIntegral.integral_comp_mul_left (fun t => exp t)]
              <;> simp [exp_zero, mul_comm]
              <;> ring_nf
              <;> norm_num
              <;>
                (try
                  {
                    cases' le_total 0 x with hx hx <;>
                    simp_all [abs_of_nonneg, abs_of_nonpos, mul_comm] <;>
                    ring_nf <;>
                    norm_num <;>
                    linarith
                  })
              <;>
                (try
                  {
                    field_simp [exp_ne_zero]
                    <;> ring_nf
                    <;> norm_num
                    <;> linarith
                  })
              <;>
                (try
                  {
                    simp_all [exp_ne_zero]
                    <;> ring_nf
                    <;> norm_num
                    <;> linarith
                  })
            exact h₅
          exact h₄
        exact h₃
      exact h₂
    exact h₁
  exact h₀
