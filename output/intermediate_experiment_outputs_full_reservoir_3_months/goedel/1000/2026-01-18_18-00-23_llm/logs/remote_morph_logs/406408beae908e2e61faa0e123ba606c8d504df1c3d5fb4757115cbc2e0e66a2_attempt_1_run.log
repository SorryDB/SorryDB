lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  intro N hN
  have h1 : N ∈ D := hN
  have h2 : ∃ (hN : N ∈ D), N = sSup (B N hN) := by
    refine' ⟨hN, _⟩
    exact hB N hN
  have h3 : ∃ (B' : Set (PersistenceSubmodule M)), B' ⊆ (⋃ N, ⋃ hN, B N hN) ∧ N = sSup B' := by
    refine' ⟨B N hN, _, _⟩
    · -- Prove that B N hN is a subset of the union of all B N hN
      have h4 : B N hN ⊆ ⋃ ⦃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN := by
        intro x hx
        exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hx⟩⟩
      exact h4
    · -- Prove that N is the supremum of B N hN
      exact hB N hN
  rcases h3 with ⟨B', hB'_sub, hB'_sSup⟩
  refine' ⟨B', _⟩
  <;> simp_all [refinement]
  <;> aesop
