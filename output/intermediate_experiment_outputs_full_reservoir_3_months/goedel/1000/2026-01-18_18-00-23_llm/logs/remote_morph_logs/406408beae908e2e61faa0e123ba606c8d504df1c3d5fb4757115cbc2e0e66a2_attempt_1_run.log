theorem refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  intro N hN
  have h₁ : ∃ B : Set (PersistenceSubmodule M), B ⊆ refinement B hB hB' hB'' ∧ N = sSup B := by
    refine' ⟨B N hN, _, _⟩
    · -- Prove that B ⊆ refinement B hB hB' hB''
      intro X hX
      -- Show that X is in the carrier of refinement B hB hB' hB''
      have h₂ : X ∈ ⋃ N : PersistenceSubmodule M, ⋃ (hN : N ∈ D), B N hN := by
        -- Since X ∈ B N hN, we can find a N and hN such that X ∈ B N hN
        have h₃ : X ∈ B N hN := hX
        have h₄ : (N : Set (PersistenceSubmodule M)) = N := rfl
        refine' ⟨N, hN, h₃⟩
      -- Therefore, X is in the carrier of refinement B hB hB' hB''
      exact h₂
    · -- Prove that N = sSup (B N hN)
      exact hB N hN
  -- Use the above result to complete the proof
  obtain ⟨B', hB'_subset, hB'_eq⟩ := h₁
  refine' ⟨B', hB'_subset, _⟩
  -- Prove that N = sSup B'
  <;> simp_all [hB'_eq]
  <;> aesop
