lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    D ≤ refinement B hB hB' hB'' := by
  intro N hN
  have h₁ : B N hN ⊆ (refinement B hB hB' hB'').carrier := by
    intro S hS
    simp only [refinement_carrier]
    exact ⟨⟨N, hN⟩, by simp [hS]⟩
  refine' ⟨B N hN, h₁, _⟩
  rw [hB N hN]
  <;> simp [sSup_le_iff]
  <;> aesop
