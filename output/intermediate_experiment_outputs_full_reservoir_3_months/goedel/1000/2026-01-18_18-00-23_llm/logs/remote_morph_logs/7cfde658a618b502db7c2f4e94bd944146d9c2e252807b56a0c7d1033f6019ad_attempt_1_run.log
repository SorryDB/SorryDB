  (init : ProbComp σ)
  (impl : QueryImpl oSpec (StateT σ ProbComp))
  (relIn : Set (StmtIn × WitIn))
  (relOut : Set (StmtOut × WitOut))
  (verifier : Verifier oSpec StmtIn StmtOut pSpec)
  (stF :
    Verifier.KnowledgeStateFunctionOneShot ι oSpec StmtIn StmtOut n pSpec σ init impl relIn.language relOut.language
      verifier)
  (oneShotE : @Extractor.RoundByRoundOneShot ι oSpec StmtIn WitIn n pSpec)} :
  KnowledgeOneShot (n := n) (extractor := oneShotE) :=
  { toStateFunction := stF.toStateFunction (oneShotE.toRoundByRound)
    toFun_empty : ∀ stmtIn, stF.toFun 0 stmtIn default → False := by
      intro stmtIn h
      exact stF.toFun_empty stmtIn h
    toFun_next : ∀ m, pSpec.dir m = .P_to_V → ∀ stmt tr msg, stF.toFun m.castSucc stmt tr → stF.toFun m.succ stmt (tr.concat msg) := by
      intro m hDir stmt tr msg h
      exact by simp_all [Fin.ext_iff, Fin.val_castSucc, Fin.val_succ]
    }
