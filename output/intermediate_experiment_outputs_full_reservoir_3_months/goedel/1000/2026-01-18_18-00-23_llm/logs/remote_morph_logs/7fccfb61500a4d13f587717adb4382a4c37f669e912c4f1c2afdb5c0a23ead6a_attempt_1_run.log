/-
This proof is based on the assumption that the mean of an uniformly almost periodic function is defined and that the limit of the average of the function over [0, X] as X → +∞ equals the mean. The `IsUnifAlmostPeriodic.tendsto_mean` lemma is a direct consequence of this definition.
-/
lemma IsUnifAlmostPeriodic.tendsto_mean (hf : IsUnifAlmostPeriodic f) :
    Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) := by
  -- By the definition of `mean`, the function `fun X => ⨍ x in (0)..X, f x` tends to `mean f` as `X → ∞`.
  have h : Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) := by
    -- Use the property of `mean` which directly gives the required convergence.
    have h₁ : (fun X ↦ ⨍ x in (0)..X, f x) = (fun X ↦ ⨍ x in (0)..X, f x) := rfl
    rw [h₁]
    -- Apply the `tendsto` part of the definition of `mean`.
    have h₂ : mean f = mean f := rfl
    have h₃ : Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) := by
      -- This step is abstract and relies on the definition of `mean`.
      have h₄ : mean f = (limUnder atTop fun X ↦ ⨍ x in (0)..X, f x) := rfl
      -- By the properties of limits in the definition of `mean`, we have the convergence.
      have h₅ : Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) := by
        -- Use the fact that the limit exists and is equal to `mean f`.
        simpa [mean] using tendsto_limUnder_atTop (fun X ↦ ⨍ x in (0)..X, f x)
      exact h₅
    exact h₃
  exact h
