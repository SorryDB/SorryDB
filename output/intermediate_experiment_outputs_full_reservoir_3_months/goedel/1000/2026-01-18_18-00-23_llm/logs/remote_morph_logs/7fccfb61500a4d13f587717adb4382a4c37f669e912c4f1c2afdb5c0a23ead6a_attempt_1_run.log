```lean
/-!
# Fourier analysis of uniformly almost periodic functions
-/

open Filter
open scoped Topology

variable {Λ : ℝ} {f : ℝ → ℂ}

variable (f) in
/-- The **mean** of an uniformly almost periodic function `f` is the limit of its average on
`[0, X]` as `X → +∞`. -/
noncomputable def mean : ℂ := limUnder atTop fun X ↦ ⨍ x in (0)..X, f x

lemma IsUnifAlmostPeriodic.tendsto_mean (hf : IsUnifAlmostPeriodic f) :
    Tendsto (fun X ↦ ⨍ x in (0)..X, f x) atTop (𝓝 (mean f)) := by
  have h₁ : HasLimit (fun X : ℝ ↦ ⨍ x in (0)..X, (f : ℝ → ℂ) x) (mean f) atTop := by
    -- Use the property of the mean to get the limit
    have h₂ : mean f = limUnder atTop fun X : ℝ ↦ ⨍ x in (0)..X, (f : ℝ → ℂ) x := rfl
    rw [h₂]
    -- Use the fact that the limit exists by definition of mean
    refine' Metric.tendsto_atTop_of_eventually_const _ _
    -- Show that the function is eventually constant in the filter atTop
    filter_upwards [Filter.eventually_ge_atTop 0] with X hX using by
      simp [hX]
      <;>
      norm_num
      <;>
      aesop
  -- Convert the hasLimit to Tendsto
  convert h₁.tendsto using 1 <;> simp [hf]
  <;>
  aesop
```
