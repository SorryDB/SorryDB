end Modality

theorem triangle_area : ∀ (a b c : ℝ), a ≥ 0 → b ≥ 0 → c ≥ 0 → a + b + c = 0 → a * b + b * c + c * a = 0 := by
  intro a b c ha hb hc hsum
  have h₁ : a = 0 := by
    have h₁ : a + b + c = 0 := hsum
    have h₂ : a ≥ 0 := ha
    have h₃ : b ≥ 0 := hb
    have h₄ : c ≥ 0 := hc
    linarith
  have h₂ : b = 0 := by
    have h₁ : a + b + c = 0 := hsum
    have h₂ : a ≥ 0 := ha
    have h₃ : b ≥ 0 := hb
    have h₄ : c ≥ 0 := hc
    have h₅ : a = 0 := h₁
    linarith
  have h₃ : c = 0 := by
    have h₁ : a + b + c = 0 := hsum
    have h₂ : a ≥ 0 := ha
    have h₃ : b ≥ 0 := hb
    have h₄ : c ≥ 0 := hc
    have h₅ : a = 0 := h₁
    have h₆ : b = 0 := h₂
    linarith
  have h₄ : a * b + b * c + c * a = 0 := by
    have h₅ : a = 0 := h₁
    have h₆ : b = 0 := h₂
    have h₇ : c = 0 := h₃
    rw [h₅, h₆, h₇]
    <;> ring
    <;> norm_num
  exact h₄

