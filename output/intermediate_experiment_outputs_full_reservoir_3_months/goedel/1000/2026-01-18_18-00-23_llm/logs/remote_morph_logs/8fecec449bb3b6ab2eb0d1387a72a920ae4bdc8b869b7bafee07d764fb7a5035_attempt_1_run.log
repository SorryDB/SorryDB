theorem bounded_partials_control_difference {n : ℕ} (f : E n → ℝ)
    (fc : ContDiff ℝ 2 f) (x y : E n)
    (ε : ℝ) (hε : ε > 0) (hdiff : (i : Fin n) → |x i - y i| ≤ ε)
    (mpb : mixed_partials_bounded f x) :
    |f x - f y| ≤ ε * ∑ i, |nth_partial i f x| + (n^2 / 2) * ε^2 := by
  let g₀ := interpolator x y
  let g := interpolated x y f

  let g' := interpolated_deriv x y f
  let g'' := interpolated_deriv2 x y f

  have f_diff : Differentiable ℝ f := fc.differentiable (by norm_num)
  have g₀_diff : Differentiable ℝ g₀ := Differentiable.interpolator x y
  have g_diff : Differentiable ℝ g := Differentiable.interpolated x y f fc
  have g'_diff : Differentiable ℝ g' := by
    have h₁ : Differentiable ℝ g' := by
      -- Prove that g' is differentiable by showing that each partial derivative of f is differentiable
      -- and then using the fact that the interpolator is smooth.
      have h₂ : ∀ (i : Fin n), Differentiable ℝ (fun t : ℝ => nth_partial i f (g₀ t)) := by
        intro i
        have h₃ : Differentiable ℝ (fun t : ℝ => g₀ t) := g₀_diff
        have h₄ : Differentiable ℝ (nth_partial i f) := by
          -- Prove that the partial derivative of f is differentiable
          have h₅ : ContDiff ℝ 1 (nth_partial i f) := by
            -- Use the fact that f is C^2 to deduce that its partial derivatives are C^1
            have h₆ : ContDiff ℝ 2 f := fc
            exact h₆.contDiff_nth_partial (by norm_num)
          exact h₅.differentiable (by norm_num)
        -- Use the chain rule to prove that the composition is differentiable
        exact h₄.comp (by simpa [g₀] using h₃)
      -- Sum of differentiable functions is differentiable
      have h₃ : Differentiable ℝ (fun t : ℝ => ∑ i : Fin n, (y i - x i) * (nth_partial i f (g₀ t))) := by
        apply Differentiable.finset_sum
        intro i _
        have h₄ : Differentiable ℝ (fun t : ℝ => (y i - x i) * (nth_partial i f (g₀ t))) := by
          apply Differentiable.mul
          · -- Prove that (y i - x i) is differentiable
            apply differentiable_const
          · -- Prove that (nth_partial i f (g₀ t)) is differentiable
            exact h₂ i
        exact h₄
      -- Simplify the expression to match g'
      simpa [g', g₀, interpolated_deriv, interpolator] using h₃
    exact h₁
  sorry
