lemma integrable_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
  have h₁ : Integrable f (μ i) := hf
  have h₂ : Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
    -- Use the fact that the integral of f over μ_i is integrable to show that the integral of f(a_i) over the product measure is integrable.
    apply MeasureTheory.integrable_pi_of_isProbabilityMeasure
    <;> simp_all [h₁]
  exact h₂
```
