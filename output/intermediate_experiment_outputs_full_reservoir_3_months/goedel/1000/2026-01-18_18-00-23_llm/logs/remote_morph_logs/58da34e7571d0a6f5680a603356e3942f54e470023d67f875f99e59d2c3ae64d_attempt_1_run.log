lemma integrable_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
  classical
  -- Use the fact that the product measure is the product of the measures for each coordinate
  have h₁ : (Measure.pi μ) = Measure.pi (fun j => μ j) := rfl
  rw [h₁]
  -- Use the integrability of f with respect to μ i to show integrability in the product space
  apply MeasureTheory.integrable_pi_of_mem_space
  <;> simp_all [Pi.mem_space]
  <;> aesop
