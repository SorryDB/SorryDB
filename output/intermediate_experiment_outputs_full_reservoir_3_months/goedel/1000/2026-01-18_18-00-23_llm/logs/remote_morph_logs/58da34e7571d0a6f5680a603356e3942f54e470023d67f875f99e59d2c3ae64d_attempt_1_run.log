lemma integrable_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    Integrable (fun a ↦ f (a i)) (Measure.pi μ) := by
  have h₁ : (Function.comp f (fun a : Fin d → ℝ => a i)) = (fun a : Fin d → ℝ => f (a i)) := by
    funext
  have h₂ : Integrable (Function.comp f (fun a : Fin d → ℝ => a i)) (Measure.pi μ) := by
    -- Use the fact that the transformation is a projection to a coordinate, which is measurable,
    -- and the integral of f with respect to μ_i is finite.
    have h₃ : Integrable f (μ i) := hf
    -- Use the product measure and the fact that the projection is measurable
    -- to deduce the integrability of the composed function.
    have h₄ : (i : Fin d) = i := rfl
    have h₅ : Measurable (fun a : Fin d → ℝ => a i) (Measure.pi μ) := by
      -- Prove that the projection is measurable.
      apply measurable_fst.comp _
      -- The projection is measurable because it is a coordinate map.
      <;> simp_all [Measurable]
      <;>
      (try simp_all) <;>
      (try norm_num) <;>
      (try aesop)
      <;>
      (try
        {
          exact inferInstance
        })
    -- Use the fact that f is integrable and the projection is measurable to deduce the integrability of the composed function.
    have h₆ : Integrable (Function.comp f (fun a : Fin d → ℝ => a i)) (Measure.pi μ) := by
      -- Use the fact that the integral of f with respect to μ_i is finite
      -- and the product measure is the product of the measures μ_i.
      have h₇ : (Measure.pi μ) = (Measure.pi μ) := rfl
      -- Use the fact that f is integrable and the projection is measurable to deduce the integrability of the composed function.
      exact
        (Integrable.comp_injective hf
          (fun a b h => by
            simpa [Function.funext_iff] using congr_fun h i))
    exact h₆
  -- Simplify the expression to match the required form.
  simpa [h₁] using h₂
