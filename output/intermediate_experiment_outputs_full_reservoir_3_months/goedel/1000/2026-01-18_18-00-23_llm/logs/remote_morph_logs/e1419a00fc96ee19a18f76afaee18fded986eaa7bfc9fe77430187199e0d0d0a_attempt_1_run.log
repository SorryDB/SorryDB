example (a b : ℝ) :
    ∫ x in a..b, sin (x / 2 + 3) =
    2 * cos (a / 2 + 3) - 2 * cos (b / 2  + 3) := by
  have h₁ : ∫ x in a..b, sin (x / 2 + 3) = 2 * cos (a / 2 + 3) - 2 * cos (b / 2 + 3) := by
    have h₂ : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in a..b, sin (x / 2 + 3) := rfl
    rw [h₂]
    -- Use the fundamental theorem of calculus to evaluate the integral
    have h₃ : ∫ x in a..b, sin (x / 2 + 3) = (2 * cos (b / 2 + 3) - 2 * cos (a / 2 + 3)) := by
      -- Perform the substitution u = x / 2 + 3
      rw [intervalIntegral.integral_comp_add_right (fun x => sin (x / 2))]
      <;> simp [sin_add, cos_add, add_assoc]
      <;> ring_nf
      <;> norm_num
      <;> field_simp [sin_add, cos_add]
      <;> ring_nf
      <;> norm_num
      <;> linarith [Real.cos_le_one (a / 2 + 3), Real.cos_le_one (b / 2 + 3)]
    -- Simplify the result to match the desired form
    linarith
  exact h₁
