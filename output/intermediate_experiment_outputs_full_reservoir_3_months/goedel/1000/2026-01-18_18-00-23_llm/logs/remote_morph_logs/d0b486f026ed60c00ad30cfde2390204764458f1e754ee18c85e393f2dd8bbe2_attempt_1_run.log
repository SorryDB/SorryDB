theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
    constructor
    · intro h
      -- Prove the forward direction: if f is interval integrable, then r • f is interval integrable.
      have h₂ : IntervalIntegrable (r • f) μ a b := by
        -- Use the fact that bounded smul preserves interval integrability.
        have h₃ : IsBoundedSMul R E := by infer_instance
        have h₄ : BoundedLinearMap R E R (smulRight : R →ₐ[R] E) (fun r => r • 1) := by
          -- Show that the smul operation is bounded.
          refine' ⟨1, _⟩
          intro x y
          simp [norm_smul, IsBoundedSMul.continuous_smul]
          <;>
          (try
            {
              simp_all [NormedAddCommGroup.norm_add_le, IsBoundedSMul.continuous_smul]
              <;>
              norm_num
              <;>
              linarith
            })
          <;>
          (try
            {
              simp_all [NormedAddCommGroup.norm_add_le, IsBoundedSMul.continuous_smul]
              <;>
              norm_num
              <;>
              linarith
            })
        -- Use the boundedness of the smul operation to preserve integrability.
        exact h.integrable.intervalIntegrable_of_bddLinearMap_mul_left _
      exact h₂
    · intro h
      -- Prove the reverse direction: if r • f is interval integrable, then f is interval integrable.
      have h₂ : IntervalIntegrable f μ a b := by
        -- Use the fact that bounded smul preserves interval integrability in reverse.
        have h₃ : IsBoundedSMul R E := by infer_instance
        have h₄ : BoundedLinearMap R E R (smulRight : R →ₐ[R] E) (fun r => r • 1) := by
          -- Show that the smul operation is bounded.
          refine' ⟨1, _⟩
          intro x y
          simp [norm_smul, IsBoundedSMul.continuous_smul]
          <;>
          (try
            {
              simp_all [NormedAddCommGroup.norm_add_le, IsBoundedSMul.continuous_smul]
              <;>
              norm_num
              <;>
              linarith
            })
          <;>
          (try
            {
              simp_all [NormedAddCommGroup.norm_add_le, IsBoundedSMul.continuous_smul]
              <;>
              norm_num
              <;>
              linarith
            })
        -- Use the boundedness of the smul operation to preserve integrability in reverse.
        have h₅ : IntervalIntegrable (r • f) μ a b := h
        have h₆ : IntervalIntegrable f μ a b := by
          -- Use the fact that the smul operation is bounded and linear to deduce the integrability of f.
          have h₇ : IntervalIntegrable (r⁻¹ • (r • f)) μ a b := by
            -- The smul of r⁻¹ and r • f is f.
            have h₈ : r⁻¹ • (r • f) = f := by
              ext x
              simp [smul_smul]
              <;>
              (try simp_all [IsBoundedSMul.continuous_smul])
              <;>
              (try simp_all [SMulZeroClass.zero_smul])
              <;>
              (try simp_all [smul_eq_mul])
              <;>
              (try simp_all [mul_assoc])
              <;>
              (try simp_all [mul_right_inv])
            rw [h₈]
            exact h₅
          -- Since r⁻¹ • (r • f) = f and r⁻¹ • (r • f) is interval integrable, f is interval integrable.
          exact h₇
        exact h₆
      exact h₂
  exact h₁
