theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : BoundedLinearMap.smulRight (r : R) 1 = 1 := by simp
  constructor
  · intro h
    have h₂ : IntervalIntegrable (fun x : ℝ => (1 : ℝ) • f x) μ a b := by simpa using h
    have h₃ : IntervalIntegrable (fun x : ℝ => (r : R) • f x) μ a b := by
      -- Use the boundedness of the scalar multiplication to show integrability
      refine' BoundedLinearMap.intervalIntegrable_comp (smulRightContinuous (r : R)) h
    convert h₃ using 1
    <;> simp [smul_right]
    <;> congr 1 <;> funext x <;> simp [smul_smul]
    <;> ring_nf
    <;> simp_all [isBoundedSMul_def]
    <;> norm_num
  · intro h
    have h₂ : IntervalIntegrable (fun x : ℝ => (r⁻¹ : R) • (r • f x)) μ a b := by
      refine' BoundedLinearMap.intervalIntegrable_comp (smulRightContinuous (r⁻¹ : R)) h
    have h₃ : IntervalIntegrable (fun x : ℝ => (1 : ℝ) • f x) μ a b := by
      -- Simplify the expression to show that f is integrable
      have h₄ : (fun x : ℝ => (r⁻¹ : R) • (r • f x)) = (fun x : ℝ => (1 : ℝ) • f x) := by
        funext x
        calc
          (r⁻¹ : R) • (r • f x) = (r⁻¹ • r : R) • f x := by simp [smul_smul]
          _ = (1 : R) • f x := by
            have h₅ : r⁻¹ • r = (1 : R) := by
              simp [inv_mul_cancel]
            simp [h₅]
          _ = (1 : ℝ) • f x := by
            simp [one_smul]
            <;> norm_cast
            <;> simp_all [isBoundedSMul_def]
            <;> norm_num
      rw [h₄] at h₂
      exact h₂
    convert h₃ using 1
    <;> simp [smul_right]
    <;> congr 1 <;> funext x <;> simp [smul_smul]
    <;> ring_nf
    <;> simp_all [isBoundedSMul_def]
    <;> norm_num
