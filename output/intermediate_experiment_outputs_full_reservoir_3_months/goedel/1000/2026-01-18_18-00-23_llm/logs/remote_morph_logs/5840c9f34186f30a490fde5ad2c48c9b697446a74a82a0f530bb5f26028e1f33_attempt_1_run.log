  have h₁ : (pc.fu_outer P) p.outerParams = ⟪pc.w, p.outer P⟫ / ‖P‖ := by
    simp only [GlobalTheoremPrecondition.fu_outer, rotproj_outer_unit]
    have h₂ : zpow_neg_one (‖P‖ : ℝ) = (‖P‖ : ℝ)⁻¹ := by simp [zpow_neg, zpow_ofNat]
    have h₃ : (‖P‖ : ℝ)⁻¹ = 1 / ‖P‖ := by field_simp
    simp_all [inner, rotation_inner, Matrix.dotProduct, Fin.sum_univ_succ]
    <;>
    (try ring_nf) <;>
    (try field_simp) <;>
    (try norm_num) <;>
    (try ring_nf) <;>
    (try simp_all [inner, rotation_inner, Matrix.dotProduct, Fin.sum_univ_succ]) <;>
    (try field_simp) <;>
    (try norm_num)
    <;>
    (try linarith)
  rw [h₁]
  by_cases h₂ : ‖P‖ = 0
  · have h₃ : P = 0 := by
      have h₄ : ‖P‖ = 0 := h₂
      have h₅ : P = 0 := by
        simpa [Real.norm_eq_abs, abs_eq_zero] using h₄
      exact h₅
    simp_all [pc.w]
    <;>
    (try ring_nf) <;>
    (try field_simp) <;>
    (try norm_num) <;>
