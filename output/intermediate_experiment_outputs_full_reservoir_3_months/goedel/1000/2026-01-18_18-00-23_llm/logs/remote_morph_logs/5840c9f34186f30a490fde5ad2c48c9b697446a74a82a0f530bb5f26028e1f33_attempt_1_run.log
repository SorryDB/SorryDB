```lean
theorem GlobalTheoremPrecondition.fu_outer {pbar : Pose} {ε : ℝ} {poly : GoodPoly} (P : ℝ³)
    (pc : GlobalTheoremPrecondition poly pbar ε) : ℝ² → ℝ :=
  rotproj_outer_unit P pc.w

lemma rotation_inner {P : ℝ³} (w : ℝ²) (θ φ : ℝ) : ⟪w, rotM θ φ P⟫ = w.1 * (P.1 * cos θ * cos φ - P.2 * sin θ * cos φ - P.3 * sin φ) + w.2 * (P.1 * sin θ + P.2 * cos θ) := by
  simp [rotM, Matrix.dotProduct, Fin.sum_univ_succ, Fin.succ_zero_eq_one, Fin.succ_one_eq_two, mul_comm]
  <;> ring_nf
  <;> simp [Real.cos_add, Real.sin_add, mul_assoc]
  <;> ring_nf
  <;> norm_num
  <;> linarith [Real.cos_le_one (θ + φ), Real.cos_le_one θ, Real.cos_le_one φ,
    Real.sin_le_one (θ + φ), Real.sin_le_one θ, Real.sin_le_one φ]

lemma normP {P : ℝ³} : ‖P‖ = Real.sqrt (P.1 * P.1 + P.2 * P.2 + P.3 * P.3) := by
  simp [Real.norm_eq_abs, InnerProductSpace.norm_eq, Real.sqrt_sq_eq_abs]
  <;>
  simp_all [Real.sqrt_sq_eq_abs, abs_mul_abs_self]
  <;>
  ring_nf
  <;>
  simp [Real.sqrt_sq_eq_abs, abs_mul_abs_self]

