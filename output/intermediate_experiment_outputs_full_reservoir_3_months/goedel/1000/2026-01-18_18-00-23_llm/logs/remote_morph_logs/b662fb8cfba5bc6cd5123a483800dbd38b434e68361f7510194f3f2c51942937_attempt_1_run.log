      intro h₈
      -- If S⌈σ⌉ ⊧ K a (b, k), then for any T and τ, the equivalence would hold, contradicting S⌈σ⌉ ⊧ ¬K a (b, k)
      have h₉ : S⌈σ⌉ ⊧ ¬K a (b, k) := h₆
      have h₁₀ : S⌈σ⌉ ⊧ K a (b, k) := h₈
