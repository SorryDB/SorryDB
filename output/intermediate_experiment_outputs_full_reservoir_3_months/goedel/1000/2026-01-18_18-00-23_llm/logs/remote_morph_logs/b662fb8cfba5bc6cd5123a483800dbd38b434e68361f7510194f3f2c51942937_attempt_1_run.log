    intro h_contra
    have h₄ : S⌈σ⌉ ⊧ K a (b, k) := h_contra.1
    have h₅ : S⌈σ⌉ ⊧ ¬K a (b, k) := h_contra.2
    have h₆ : S⌈σ⌉ ⊧ ¬K a (b, k) := h₅
    have h₇ : S⌈σ⌉ ⊧ K a (b, k) := h₄
    -- Since S⌈σ⌉ ⊧ K a (b, k), there exists a T and a sequence τ such that the equivalence holds
