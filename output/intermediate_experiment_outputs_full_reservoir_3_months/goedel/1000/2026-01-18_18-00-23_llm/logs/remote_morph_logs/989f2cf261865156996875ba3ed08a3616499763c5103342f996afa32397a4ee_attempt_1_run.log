    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h; unfold vectorSpaceToInternalTangentSpace at h
  simp at h
  have h₁ : v = w := by
    have h₂ := h
    -- Simplify the goal by using the fact that the maps are linear and injective
    have h₃ : v = w := by
      -- Use the fact that the maps are linear and injective to deduce v = w
