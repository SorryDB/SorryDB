def def_chainTree (x : List V) : x ∈ chainTree V ↔ x.IsChain (· ≥ ·) := by
  simp [chainTree]
  <;>
  simp_all [tree.mem_iff]
  <;>
  aesop

lemma nil_mem_chainTree : [] ∈ chainTree V := by
  simp [chainTree]
  <;>
  simp_all [tree.mem_iff]
  <;>
  aesop

lemma concat_mem_chainTree {x A} :
  x ++ [A] ∈ chainTree V ↔ x ∈ chainTree V ∧ ∀ hx, A ≤ x.getLast hx := by
  simp_rw [def_chainTree, List.isChain_append, List.isChain_singleton]
  <;>
  (try
    {
      obtain rfl | ⟨x, ⟨B, rfl⟩⟩ := x.eq_nil_or_concat' <;>
      simp_all [chainTree, List.isChain_append, List.isChain_singleton]
      <;>
      (try aesop)
    })
  <;>
  (try
    {
      by_cases hx : x = [] <;>
      simp_all [hx, List.getLast_nil, List.getLast_append]
      <;>
      (try aesop)
      <;>
      (try
        {
          have h₁ : x.get ⟨0, by simp_all [hx]⟩ = x.get ⟨0, by simp_all [hx]⟩ := rfl
          simp_all [hx, List.getLast_nil, List.getLast_append]
          <;>
          (try aesop)
        })
      <;>
      (try
        {
          by_contra h₂
          simp_all [hx, List.getLast_nil, List.getLast_append]
          <;>
          (try aesop)
        })
    })
  <;>
  (try
    {
      aesop
    })

def chainTree.concat (x : chainTree V) (A : V) (h : ∀ hx, A ≤ x.val.getLast hx) : chainTree V where
  val := x.val ++ [A]
  property := by
    rw [concat_mem_chainTree]
    <;>
