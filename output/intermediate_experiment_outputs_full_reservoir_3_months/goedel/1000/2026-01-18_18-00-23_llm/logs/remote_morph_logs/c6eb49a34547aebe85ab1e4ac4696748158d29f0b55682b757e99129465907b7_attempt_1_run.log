        <;>
        (try aesop)
      })

def choose_pair (A : V) : W where
  val := (hW A A.coe_prop).choose
  property := (hW A A.coe_prop).choose_spec.1
  
lemma choose_pair_sub A : (choose_pair hW A).val ⊆ A.val := (hW A A.coe_prop).choose_spec.2

