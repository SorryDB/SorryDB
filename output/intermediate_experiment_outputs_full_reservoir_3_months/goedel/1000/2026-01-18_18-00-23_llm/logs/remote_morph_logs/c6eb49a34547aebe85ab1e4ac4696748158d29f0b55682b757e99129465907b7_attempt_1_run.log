theorem same_length_as_faircrush (s : Finset (Nat × Nat)) : s.card ≤ 2^s.card := by
  have h : ∀ (n : ℕ), n ≤ 2^n := by
    intro n
    exact Nat.le_of_lt (Nat.lt_pow_self (by norm_num) n)
  
  have h₁ : s.card ≤ 2 ^ s.card := by
    have h₂ : s.card ≤ 2 ^ s.card := by
      calc
        s.card ≤ 2 ^ s.card := by
          -- Use the fact that for any natural number n, n ≤ 2^n
          have h₃ : s.card ≤ 2 ^ s.card := by
            apply Nat.le_of_lt
            apply Nat.lt_pow_self
            <;> norm_num
          exact h₃
        _ = 2 ^ s.card := by rfl
    exact h₂
  exact h₁
```
