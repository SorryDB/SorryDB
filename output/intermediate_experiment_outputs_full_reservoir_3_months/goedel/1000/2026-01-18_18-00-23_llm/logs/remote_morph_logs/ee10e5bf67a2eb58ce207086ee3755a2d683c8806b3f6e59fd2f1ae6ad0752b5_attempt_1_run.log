```lean
theorem imposes_coprime {n : ℕ} (h : n ≥ 2) (a b : ℕ) :
  ∃ a b : ℕ, n = a * b ∧ Nat.Coprime a b := by
  have h₁ : ∃ a b : ℕ, n = a * b ∧ Nat.Coprime a b := by
    refine' ⟨1, n, _⟩
    have h₂ : n = 1 * n := by
      ring
    have h₃ : Nat.Coprime 1 n := by
      simp [Nat.coprime_one_left]
    exact ⟨h₂, h₃⟩
  
  exact h₁
```
