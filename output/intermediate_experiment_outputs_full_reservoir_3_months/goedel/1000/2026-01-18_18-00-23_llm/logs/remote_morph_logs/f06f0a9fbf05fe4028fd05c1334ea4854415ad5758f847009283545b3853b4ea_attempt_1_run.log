Released under Apache 2.0 license as described in the file LICENSE.
Authors: Shalev Wengrowsky
-/

import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable def solution (n : ℕ) : ENNReal :=
  1 - (8 / 9 : ENNReal) ^ n - (5 / 9 : ENNReal) ^ n + (4 / 9 : ENNReal) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  have h₁ : (unifDistN n).toOuterMeasure (good_seqs : Set (DigitSeq n)) = solution n := by
    classical
    -- Calculate the probability that the product is divisible by 10
    -- Use the inclusion-exclusion principle to find the complement
    -- of sequences not divisible by 2 or 5.
    -- The probability that the product is not divisible by 2 is (8/9)^n.
    -- The probability that the product is not divisible by 5 is (5/9)^n.
    -- The probability that the product is not divisible by 2 and 5 is (4/9)^n.
    -- Therefore, the probability that the product is divisible by 10 is:
    -- 1 - (8/9)^n - (5/9)^n + (4/9)^n.
    simp_all [good_seqs, is_good_seq, to_nat_digit, unifDistN, DigitSeq, Digit]
    <;>
    (try norm_num) <;>
    (try simp_all [Fintype.card_fun, Fintype.card_fin, Fintype.card_fin]) <;>
    (try ring_nf) <;>
    (try norm_num) <;>
    (try field_simp) <;>
    (try norm_cast) <;>
    (try simp_all [ENNReal.ofReal_one, ENNReal.ofReal_zero]) <;>
    (try linarith)
    <;>
    rfl
  simpa using h₁
