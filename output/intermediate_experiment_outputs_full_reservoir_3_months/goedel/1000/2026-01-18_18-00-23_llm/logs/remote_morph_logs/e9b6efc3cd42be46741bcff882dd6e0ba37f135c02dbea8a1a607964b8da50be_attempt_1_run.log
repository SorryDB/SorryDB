theorem exists_quad (n : ℕ) : ∃ a b c d : ℕ, a^2 + b^2 + c^2 + d^2 = n := by
  have h₀ : ∃ (a b c d : ℕ), a^2 + b^2 + c^2 + d^2 = n := by
    classical
    have h₁ : ∀ n : ℕ, ∃ (a b c d : ℕ), a^2 + b^2 + c^2 + d^2 = n := by
      intro n
      have h₂ : ∃ (a b c d : ℕ), a^2 + b^2 + c^2 + d^2 = n := by
        -- Use the fact that every natural number can be expressed as the sum of four squares
        -- This is a known result in number theory
        -- For the purpose of this proof, we can directly provide the decomposition
        have h₃ := Nat.sum_four_squares n
        -- Extract the four squares from the decomposition
        obtain ⟨a, b, c, d, h₄⟩ := h₃
        -- Return the four squares
        exact ⟨a, b, c, d, by linarith⟩
      -- The result follows from the decomposition
      exact h₂
    -- Apply the general result to the specific n
    have h₂ := h₁ n
    exact h₂
  -- The result follows from the existence of the decomposition
  exact h₀
