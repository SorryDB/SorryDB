    (h1 h2 : Hom c d) (h : h1 ≠ h2) :
    NatTrans_Hom_c_?_Hom_?_c c d h1 ≠ NatTrans_Hom_c_?_Hom_?_c c d h2 := by
  intro h_eq
  have h_c : (NatTrans_Hom_c_?_Hom_?_c c d h1).arrow c = (NatTrans_Hom_c_?_Hom_?_c c d h2).arrow c := by
    rw [h_eq]
    <;>
    simp [NatTrans_Hom_c_?_Hom_?_c]
  -- Simplify the expression for the arrow at c for both natural transformations
  have h_c₁ : (NatTrans_Hom_c_?_Hom_?_c c d h1).arrow c = (h1 : Hom c d) := by
    simp [NatTrans_Hom_c_?_Hom_?_c]
  have h_c₂ : (NatTrans_Hom_c_?_Hom_?_c c d h2).arrow c = (h2 : Hom c d) := by
    simp [NatTrans_Hom_c_?_Hom_?_c]
  -- Deduce that h1 = h2 from the equality of arrows at c
  have h_h : h1 = h2 := by
    rw [h_c₁, h_c₂] at h_c
    exact h_c
  -- Contradiction with h : h1 ≠ h2
  exact h h_h
