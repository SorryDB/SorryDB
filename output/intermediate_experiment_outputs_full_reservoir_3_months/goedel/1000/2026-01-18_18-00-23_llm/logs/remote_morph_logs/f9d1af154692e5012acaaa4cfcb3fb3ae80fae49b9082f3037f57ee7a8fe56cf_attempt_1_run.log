instance (priority := 100) IsKrullDomain.isIntegrallyClosed
    (A : Type*) [CommRing A] [IsDomain A] [IsKrullDomain A] : IsIntegrallyClosed A := by
  refine' { algebraMap := algebraMap A (FractionRing A), }
  -- We use the fact that a Krull domain is the intersection of its localizations under every prime ideal of height 1.
  -- However, we need to directly prove that every integral element over A is already in A.
  -- Since we have not yet established a context where we can use the definition of Krull domain to directly verify this,
  -- we will instead appeal to a general fact: that every Krull domain is integrally closed.
  -- This is a known result in commutative algebra.
  sorry
