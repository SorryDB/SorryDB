### Solution

```lean
theorem ext_prod_right {α β γ δ ι : Type} (f g : (α → β) × (γ → δ → ι)) (h : (f.fst : α → β) = (g.fst : α → β)) (h' : (f.snd : γ → δ → ι) = (g.snd : γ → δ → ι)) : f = g := by
  ext <;> simp_all [Prod.ext_iff]
  <;> aesop
  <;> simp_all [Function.funext_iff]
  <;> aesop
