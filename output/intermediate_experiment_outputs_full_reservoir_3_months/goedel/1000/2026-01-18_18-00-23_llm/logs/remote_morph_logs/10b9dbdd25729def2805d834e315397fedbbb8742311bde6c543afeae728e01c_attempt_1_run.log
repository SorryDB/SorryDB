  induction idx generalizing l with
  | zero =>
    cases l with
    | nil => contradiction
    | cons hd tl => simp; apply Nat.add_comm
  | succ idx' HR =>
    cases l with
    | nil =>
      contradiction
    | cons hd tl =>
      simp at hidx ⊢
