    intro h'
    have h₂ : χ ➝ ξ ∈ T.theory := by
      have h₃ : T.imp_closed (axiomI (ψ := ξ)) h'
      have h₄ : ξ ∈ T.theory := by
        have h₅ : L ⊢ ⊥ ➝ ξ := by
          apply af
          apply by_contra
          intros
          simp_all
        have h₆ : ⊥ ∈ T.theory := by
          have h₇ : L ⊢ ⊥ := by
            simp_all [AF]
          have h₈ : ⊥ ∈ T.theory := by
            apply T.mem_of_provable
            exact h₇
          exact h₈
        apply T.imp_closed h₅ h₆
      have h₉ : χ ➝ ξ ∈ T.theory := by
        have h₁₀ : L ⊢ ⊥ ➝ (χ ➝ ξ) := by
          apply af
          <;> simp_all [AF]
        have h₁₁ : ⊥ ∈ T.theory := by
          have h₁₂ : L ⊢ ⊥ := by
            simp_all [AF]
          apply T.mem_of_provable
          exact h₁₂
        apply T.imp_closed h₁₀ h₁₁
      exact h₉
    contradiction
  exact h
