```lean
lemma construction_omega_noBot :
  letI U := construction_omega T hT
  ⊥ ∉ U := by
  simp only [construction_omega, Set.mem_iUnion, not_exists]
  intro i
  induction i with
  | zero =>
    simp [construction]
    <;>
    (try {
      intro h
      simp_all [Finset.subset_iff]
      <;>
      aesop
    })
    <;>
    (try {
      aesop
    })
  | succ i ih =>
    simp [construction] at *
    <;>
    (try {
      split_ifs at *
      <;>
      (try {
        aesop
      })
      <;>
      (try {
        simp_all [Finset.subset_iff]
        <;>
        aesop
      })
      <;>
      (try {
        simp_all [Finset.subset_iff]
        <;>
        (try {
          by_contra! h
          have h₂ := h ⟨⟩ (by simp_all)
          simp_all [conj_empty]
          <;> tauto
        })
        <;>
        aesop
      })
    })
    <;>
    (try {
      aesop
    })
    <;>
    (try {
      simp_all [Finset.subset_iff]
      <;>
      aesop
    })
