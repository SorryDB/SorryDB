theorem RelInt.liftFinf_in' {S} {rule : RelInt S} {n : Nat} {f : Fin n → List (RelInt S)}:
  (∃ (i : Fin n) (j : Fin (f i).length), rule = (f i).get j) →
  rule ∈ (RelInt.liftFinf n f) := by
  intro ⟨i, j, Hij⟩
  rw [Hij]
  unfold liftFinf
  simp only [RelInt, List.get_eq_getElem, List.mem_flatten, List.mem_map]
  exists (f i)
  <;>
  (try simp_all [Fin.forall_fin_succ]) <;>
  (try
    {
      cases n <;>
      simp_all [Fin.ext_iff, Fin.val_zero, Fin.val_succ, Fin.val_zero, Fin.val_succ]
      <;>
      omega
    }) <;>
  (try
    {
      use i
      <;>
      simp_all [Fin.ext_iff, Fin.val_zero, Fin.val_succ]
      <;>
      omega
    })
  <;>
  (try
    {
      use j
      <;>
      simp_all [Fin.ext_iff, Fin.val_zero, Fin.val_succ]
      <;>
      omega
    })
