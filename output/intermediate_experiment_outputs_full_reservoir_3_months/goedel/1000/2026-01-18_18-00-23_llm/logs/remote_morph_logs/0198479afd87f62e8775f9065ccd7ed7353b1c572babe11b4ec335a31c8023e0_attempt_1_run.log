```lean
theorem list_Perm_eraseIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
    {idx1 idx2 : Nat} {hidx1 : idx1 < l1.length} {hidx2 : idx2 < l2.length} {heq : l1[idx1] = l2[idx2]} :
    (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
  -- Convert the given indices to Fin indices
  have h₁ : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
    have h₂ : ∀ {α : Type*} [DecidableEq α] {l1 l2 : List α} {hPerm : l1.Perm l2}
      (i : Fin l1.length) (j : Fin l2.length), l1[i] = l2[j] → (l1.erase i).Perm (l2.erase j) := by
      intro α _ l1 l2 hPerm i j h₃
      induction hPerm with
      | nil => contradiction
      | cons x l1 l2 hPerm ih =>
        cases i <;> cases j <;> simp_all [List.get]
        <;>
        (try omega) <;>
        (try simp_all [List.erase, List.Perm]) <;>
        (try {
          apply Perm.perm_of_eq
          <;> simp_all [List.get]
        }) <;>
        (try {
          apply ih <;>
          (try omega) <;>
          (try simp_all [List.get])
        })
    -- Use the general result with Fin indices
    have h₃ : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
      have h₄ : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
        -- Use the general result with Fin indices
        have h₅ : ∀ {α : Type*} [DecidableEq α] {l1 l2 : List α} {hPerm : l1.Perm l2}
          (i : Fin l1.length) (j : Fin l2.length), l1[i] = l2[j] → (l1.erase i).Perm (l2.erase j) := by
          intro α _ l1 l2 hPerm i j h₃
          induction hPerm with
          | nil => contradiction
          | cons x l1 l2 hPerm ih =>
            cases i <;> cases j <;> simp_all [List.get]
            <;>
            (try omega) <;>
            (try simp_all [List.erase, List.Perm]) <;>
            (try {
              apply Perm.perm_of_eq
              <;> simp_all [List.get]
            }) <;>
            (try {
              apply ih <;>
              (try omega) <;>
              (try simp_all [List.get])
            })
        exact by
          have h₆ : (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2) := by
            -- Use the general result with Fin indices
            classical
            have h₇ : (l1.erase (⟨idx1, by omega⟩ : Fin l1.length)).Perm (l2.erase (⟨idx2, by omega⟩ : Fin l2.length)) := by
              apply h₅
              <;>
              simp_all [List.get]
              <;>
              aesop
            have h₈ : (l1.eraseIdx idx1) = l1.erase (⟨idx1, by omega⟩ : Fin l1.length) := by
              simp [List.eraseIdx_eq_erase]
            have h₉ : (l2.eraseIdx idx2) = l2.erase (⟨idx2, by omega⟩ : Fin l2.length) := by
              simp [List.eraseIdx_eq_erase]
            rw [h₈, h₉] at *
            exact h₇
          exact h₆
      exact h₄
    exact h₃
  exact h₁
