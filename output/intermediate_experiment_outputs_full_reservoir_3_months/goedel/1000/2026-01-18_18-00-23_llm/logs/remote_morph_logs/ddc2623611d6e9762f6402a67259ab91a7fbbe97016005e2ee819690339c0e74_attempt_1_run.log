example : ∀ sl : SymList a,
  List.init sl.fromSL = sl.init.fromSL := by
  intro s
  cases s with
  | mk as bs ok =>
    unfold SymList.fromSL
    unfold List.init
    cases as with
    | nil =>
      simp
      cases bs with
      | nil =>
        simp [SymList.init, SymList.reverse, SymList.tailSL, SymList.nil]
      | cons n ns =>
        simp [SymList.init, SymList.reverse, SymList.tailSL, SymList.nil]
        <;> simp_all [List.tail, List.init, List.cons, List.nil]
        <;> aesop
    | cons n ns =>
      simp_all [SymList.init, SymList.reverse, SymList.tailSL, SymList.nil]
      <;> simp [List.tail, List.init, List.cons, List.nil]
      <;> aesop
