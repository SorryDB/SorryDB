instance (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    obtain ⟨a, b⟩ := x
    have h₁ : a ∈ support ($ᵗ α) := by
      apply SampleableType.mem_support_selectElem
    have h₂ : b ∈ support ($ᵗ β) := by
      apply SampleableType.mem_support_selectElem
    have h₃ : (a, b) ∈ support ((·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
      have h₄ : a ∈ support ($ᵗ α) := h₁
      have h₅ : b ∈ support ($ᵗ β) := h₂
      -- We need to show that (a, b) is in the support of the product distribution.
      -- This follows because the product of two distributions with support {a} and {b} respectively
      -- will have support {(a, b)}.
      -- We use the fact that if a is in the support of α and b is in the support of β, then (a, b) is in the support of the product.
      simp [support_prod, h₄, h₅]
      <;>
      (try aesop) <;>
      (try simp_all [support_prod]) <;>
      (try aesop)
    exact h₃
  probOutput_selectElem_eq := by
    intro x y
    simp [probOutput_seq_map_prod_mk_eq_mul, probOutput_uniformSample]
    <;>
    (try simp_all [SampleableType.probOutput_selectElem_eq]) <;>
    (try aesop)
    <;>
    (try {
      cases x <;> cases y <;> simp_all [SampleableType.probOutput_selectElem_eq]
      <;>
      aesop
    })
  probFailure_selectElem := by
    have h₁ : Pr[⊥ | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = 0 := by
      -- Use the fact that the product of two never-failing computations is never-failing.
      have h₂ : HasEvalSPMF.NeverFail ((·, ·) <$> ($ᵗ α) <*> ($ᵗ β)) := by
        -- Prove that the product of two never-failing computations is never-failing.
        exact HasEvalSPMF NEVERFAIL ($ᵗ α)
        <;>
        exact HasEvalSPMF NEVERFAIL ($ᵗ β)
        <;>
        (try simp_all [HasEvalSPMF.neverFail])
        <;>
        (try aesop)
      -- Since the computation is never-failing, the probability of failure is 0.
      have h₃ : Pr[⊥ | (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)] = 0 := by
        simpa using h₂
      exact h₃
    simpa [SampleableType.selectElem] using h₁

