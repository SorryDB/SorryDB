        have h₇ : (⊥ : Matrix (Fin n) (Fin m) α) ∉ (Nat.recAux (pure (Matrix.of ![])) (fun n ihn => do
            let top ← $ᵗ (Vector α m)
            let bot ← ihn
            pure (Fin.cons top.get bot)) n : ProbComp (Matrix (Fin n) (Fin m) α)).support := h₄
        simp_all [hasSum_zero_iff, Finset.sum_eq_zero]
        <;>
        aesop
      exact h₆
    exact h₃
  
  have h₂ : Pr[⊥ | randomMatrix] = 0 := by
    have h₃ := h_main n
    have h₄ : randomMatrix = Nat.recAux (pure (Matrix.of ![])) (fun n ihn => do
        let top ← $ᵗ (Vector α m)
        let bot ← ihn
        pure (Fin.cons top.get bot)) n := by
      rfl
    rw [h₄]
    exact h_main n
  exact h₂
