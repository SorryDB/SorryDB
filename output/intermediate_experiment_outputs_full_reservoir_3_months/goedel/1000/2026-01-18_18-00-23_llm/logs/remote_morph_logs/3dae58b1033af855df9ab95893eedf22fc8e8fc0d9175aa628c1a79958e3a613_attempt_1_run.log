            <;>
            aesop
          })
    have h₂ : (Nat.recAux (pure (Matrix.of ![])) (fun n ihn => do
        let top ← $ᵗ (Vector α m)
        let bot ← ihn
        pure (Fin.cons top.get bot)) n : ProbComp (Matrix (Fin n) (Fin m) α)).support ⊆ {x | x ≠ ⊥} := by
      intro x hx
      have h₃ := h₁ n
      simp_all [Set.mem_setOf_eq]
      <;>
      aesop
    have h₃ : Pr[⊥ | Nat.recAux (pure (Matrix.of ![])) (fun n ihn => do
        let top ← $ᵗ (Vector α m)
        let bot ← ihn
        pure (Fin.cons top.get bot)) n] = 0 := by
      have h₄ : (⊥ : Matrix (Fin n) (Fin m) α) ∉ (Nat.recAux (pure (Matrix.of ![])) (fun n ihn => do
          let top ← $ᵗ (Vector α m)
          let bot ← ihn
          pure (Fin.cons top.get bot)) n : ProbComp (Matrix (Fin n) (Fin m) α)).support := h₁ n
      have h₅ : (Nat.recAux (pure (Matrix.of ![])) (fun n ihn => do
          let top ← $ᵗ (Vector α m)
          let bot ← ihn
          pure (Fin.cons top.get bot)) n : ProbComp (Matrix (Fin n) (Fin m) α)).support ⊆ {x | x ≠ ⊥} := h₂
      have h₆ : Pr[⊥ | Nat.recAux (pure (Matrix.of ![])) (fun n ihn => do
