      -- This follows from the fact that the square of the norm is convex and the local martingale property
      -- We can use the fact that the square of the norm is a convex function and the definition of submartingale
      -- to show that the square of the norm is a submartingale.
      refine' hX.map _
      -- Check that the function x ↦ ‖x‖² is convex
      refine' { map_mono' := _, map_add_le := _, map_smul_le := _ }
      · -- Monotonicity of the function x ↦ ‖x‖²
        intro x y hxy
        have h₃ : ‖x‖ ≤ ‖y‖ := by
          calc
            ‖x‖ ≤ ‖y‖ := by
              -- Use the fact that the norm is non-decreasing
              exact norm_mono hxy
            _ = ‖y‖ := by rfl
        -- Square both sides to get ‖x‖² ≤ ‖y‖²
        have h₄ : ‖x‖ ^ 2 ≤ ‖y‖ ^ 2 := by
          exact pow_le_pow_of_le_left (norm_nonneg x) h₃ 2
        exact h₄
      · -- Convexity condition for the sum
        intro x y
        have h₃ : ‖x + y‖ ^ 2 ≤ ‖x‖ ^ 2 + ‖y‖ ^ 2 + 2 * ‖x‖ * ‖y‖ := by
          calc
            ‖x + y‖ ^ 2 ≤ (‖x‖ + ‖y‖) ^ 2 := by
              -- Use the triangle inequality for norms
              exact pow_le_pow_of_le_left (by positivity) (norm_add_le x y) 2
            _ = ‖x‖ ^ 2 + ‖y‖ ^ 2 + 2 * ‖x‖ * ‖y‖ := by
              ring_nf
              <;>
              simp [add_assoc, add_comm, add_left_comm]
              <;>
              ring_nf
              <;>
              nlinarith [norm_nonneg x, norm_nonneg y]
        -- Use the convexity of the square function
        have h₄ : ‖x + y‖ ^ 2 ≤ ‖x‖ ^ 2 + ‖y‖ ^ 2 := by
          have h₅ : 0 ≤ ‖x‖ := norm_nonneg x
          have h₆ : 0 ≤ ‖y‖ := norm_nonneg y
          nlinarith [norm_add_le x y, sq_nonneg (‖x‖ - ‖y‖)]
        exact h₄
