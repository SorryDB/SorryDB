                simp [norm_smul, Real.norm_eq_abs]
                <;>
                ring_nf
                <;>
                simp [abs_mul, abs_of_nonneg, h₃]
                <;>
                ring_nf
              _ = a ^ 2 * ‖x‖ ^ 2 := by
                have h₅ : |a| = a := abs_of_nonneg h₃
                rw [h₅]
                <;>
                ring_nf
          have h₅ : a ^ 2 * ‖x‖ ^ 2 ≤ a ^ 2 * ‖x‖ ^ 2 := le_refl _
          calc
            ‖a • x‖ ^ 2 = a ^ 2 * ‖x‖ ^ 2 := by rw [h₄]
