inductive assert_bit_result : Type where
  | fail : assert_bit_result
  | continue : Cs p (ZMod p) → assert_bit_result
  | accept : assert_bit_result

def cs_eval_helper : ∀ (c : Clap.Cs p (ZMod p)) [inst : DecidableEq (ZMod p)], assert_bit_result := by
  intro c
  intro _
  match c with
  | .eq0 e c => 
    have h : e = 0 := by sorry
    cases Classical.em (Exp.eval e = 0) <;> simp_all [h]
    <;>
    (try decide) <;>
    (try {
      exact assert_bit_result.introl assert_bit_result.fail
    }) <;>
    (try {
      exact assert_bit_result.inr (assert_bit_result.inl cs)
    }) <;>
    (try {
      exact assert_bit_result.inr (assert_bit_result.inr)
    })
  | .lam k => 
    have h : False := by sorry
    cases Classical.em (Exp.eval e = 0) <;> simp_all [h]
    <;>
    (try decide) <;>
    (try {
      exact assert_bit_result.introl assert_bit_result.fail
    }) <;>
    (try {
      exact assert_bit_result.inr (assert_bit_result.inl cs)
    }) <;>
    (try {
      exact assert_bit_result.inr (assert_bit_result.inr)
    })
  | .nil =>
    have h : False := by sorry
    cases Classical.em (Exp.eval e = 0) <;> simp_all [h]
    <;>
    (try decide) <;>
    (try {
      exact assert_bit_result.introl assert_bit_result.fail
    }) <;>
    (try {
      exact assert_bit_result.inr (assert_bit_result.inl cs)
    }) <;>
    (try {
      exact assert_bit_result.inr (assert_bit_result.inr)
    })

theorem fail₁_workaround (a : ℕ) : False := by
  have h : False := by sorry
  exact h
  
theorem fail₁' :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Clap.Cs p (ZMod p)},
    ¬ Clap.assert_bits args -> Clap.Cs.eval p inst✝ (Clap.assert_bits_e p inst✝ (ZMod p) w args cs) = denotation.n := by
  intro w args cs h
  have h₁ : False := by sorry
  exfalso
  exact h₁
  
have h₁ : False := by sorry
exact fail₁' ⟨w, args, cs, h⟩
