lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  have h₁ : sSup (decomposition_of_refinement R) = sSup ⋃ (D ∈ ({R} : Set (refinement S))), D.carrier := rfl
  have h₂ : sSup ⋃ (D ∈ ({R} : Set (refinement S))), D.carrier = sSup R.carrier := by
    simp [Set.ext_iff]
    <;> simp_all [refinement]
    <;> aesop
  have h₃ : sSup R.carrier = sSup S := by
