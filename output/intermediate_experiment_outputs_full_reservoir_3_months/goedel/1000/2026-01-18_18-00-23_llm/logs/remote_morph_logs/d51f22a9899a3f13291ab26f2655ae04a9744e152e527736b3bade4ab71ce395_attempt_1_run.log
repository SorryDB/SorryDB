      exact h₅ w args
    have h₅ : e.eval.val < 2 ^ w := by
      have h₆ : e.eval = bits2num args := h₂
      have h₇ : (e.eval : ZMod p) = (bits2num args : ZMod p) := by simpa using h₆
      have h₈ : (e.eval : ZMod p) = (bits2num args : ZMod p) := by simpa using h₆
      have h₉ : (e.eval : ZMod p) = (bits2num args : ZMod p) := by simpa using h₆
      -- Use the fact that the value of the bits2num is less than 2^w and the fact that the evaluation of e is equal to bits2num
