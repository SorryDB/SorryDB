instance : SampleableType Bool where
  selectElem := $! #v[true, false]
  mem_support_selectElem x := by
    simp only [Bool.val, Unit.injEq]
    fin_cases x <;> simp_all (config := {decide := true})
  probOutput_selectElem_eq x y := by
    simp only [Bool.val, Unit.injEq]
    fin_cases x <;> fin_cases y <;> simp_all (config := {decide := true})
