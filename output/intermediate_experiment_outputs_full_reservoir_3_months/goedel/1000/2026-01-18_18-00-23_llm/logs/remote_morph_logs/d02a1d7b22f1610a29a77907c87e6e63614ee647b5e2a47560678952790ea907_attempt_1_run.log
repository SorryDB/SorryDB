lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
  simp only [ofFunWithOrder]
  have h₁ : f =ᵐ[μ.restrict (Ω : Set E)] f' := h
  have h₂ : (TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f : 𝓓^{n}(Ω, ℝ) →L_c[ℝ] F) = (TestFunction.integralAgainstBilinCLM (ContinuousLinearMap.lsmul ℝ ℝ) μ f' : 𝓓^{n}(Ω, ℝ) →L_c[ℝ] F) := by
    refine' ContinuousLinearMap.ext fun φ => _
    have h₃ : (∫ x in Ω, φ x • f x ∂μ) = ∫ x in Ω, φ x • f' x ∂μ := by
      have h₄ : (φ : E → ℝ) hasCompactSupport := (φ : 𝓓^{n}(Ω, ℝ)).hasCompactSupport
      have h₅ : ∫ x in Ω, φ x • f x ∂μ = ∫ x in Ω, φ x • f x ∂μ := rfl
      have h₆ : ∫ x in Ω, φ x • f' x ∂μ = ∫ x in Ω, φ x • f' x ∂μ := rfl
      -- Use the fact that f and f' are equal almost everywhere on Ω to show the integrals are equal
      have h₇ : ∫ x in Ω, φ x • f x ∂μ = ∫ x in Ω, φ x • f' x ∂μ := by
        have h₈ : ∫ x in Ω, φ x • f x ∂μ = ∫ x in Ω, φ x • f x ∂μ := rfl
        have h₉ : ∫ x in Ω, φ x • f' x ∂μ = ∫ x in Ω, φ x • f' x ∂μ := rfl
        -- Use the fact that f and f' are equal almost everywhere on Ω to show the integrals are equal
        have h₁₀ : (φ : E → ℝ) ∘ (fun x : E => (x : E)) =ᵐ[μ.restrict Ω] (φ : E → ℝ) ∘ (fun x : E => (x : E)) := by
          filter_upwards [h₁] with x hx
          <;> simp_all
        have h₁₁ : (fun x : E => φ x • f x : E → F) =ᵐ[μ.restrict Ω] (fun x : E => φ x • f' x : E → F) := by
          filter_upwards [h₁] with x hx
          <;> simp_all [hx, smul_eq_smul]
        -- Use the fact that the integrands are equal almost everywhere to show the integrals are equal
        have h₁₂ : ∫ x in Ω, φ x • f x ∂μ = ∫ x in Ω, φ x • f' x ∂μ := by
          have h₁₃ : (fun x : E => φ x • f x : E → F) =ᵐ[μ.restrict Ω] (fun x : E => φ x • f' x : E → F) := h₁₁
          have h₁₄ : ∫ x in Ω, φ x • f x ∂μ = ∫ x in Ω, φ x • f' x ∂μ := by
            -- Use the fact that the integrands are equal almost everywhere to show the integrals are equal
            refine' set_integral_congr_ae (μ.restrict Ω) _ h₁₃
            <;> measurability
          exact h₁₄
        exact h₁₂
      exact h₇
    simp_all [TestFunction.integralAgainstBilinCLM_apply]
  simp_all [Testing.toSixthSix]
