def toBoundedBilin {C : ℝ} (f : (spectrum ℂ a) → ℂ)
  : H →L⋆[ℂ] H →L[ℂ] ℂ where
  toFun x := {  toFun y := (cfc_toComplexMeasure ha x y).integral f
                map_add' := by
                  intro y z
                  simp [LinearMap.add_apply, ComplexAddCommGroup.add_apply]
                  <;>
                  simp_all [ComplexMeasure.integral_add]
                  <;>
                  ring
                map_smul' := by
                  intro c y
                  simp [LinearMap.smul_apply]
                  <;>
                  simp_all [ComplexMeasure.integral_smul]
                  <;>
                  ring
                cont := by
                  sorry
              }
```
