theorem example (n : ℕ) (h : n % 2 = 0) (h₁ : n % 3 ≠ 0) :
    (n : ℕ) % 6 = 2 ∨ (n : ℕ) % 6 = 4 := by
  have h₂ : n % 6 = 2 ∨ n % 6 = 4 := by
    have h₃ : n % 6 = 0 ∨ n % 6 = 1 ∨ n % 6 = 2 ∨ n % 6 = 3 ∨ n % 6 = 4 ∨ n % 6 = 5 := by
      omega
    have h₄ : n % 2 = 0 := h
    have h₅ : n % 3 ≠ 0 := h₁
    rcases h₃ with (h₃ | h₃ | h₃ | h₃ | h₃ | h₃)
    · -- Case n ≡ 0 mod 6
      exfalso
      have : n % 3 = 0 := by
        omega
      contradiction
    · -- Case n ≡ 1 mod 6
      exfalso
      have : n % 2 = 1 := by
        omega
      contradiction
    · -- Case n ≡ 2 mod 6
      exact Or.inl h₃
    · -- Case n ≡ 3 mod 6
      exfalso
      have : n % 3 = 0 := by
        omega
      contradiction
    · -- Case n ≡ 4 mod 6
      exact Or.inr h₃
    · -- Case n ≡ 5 mod 6
      exfalso
      have : n % 2 = 1 := by
        omega
      contradiction
  -- The conclusion directly follows from h₂
  exact h₂
