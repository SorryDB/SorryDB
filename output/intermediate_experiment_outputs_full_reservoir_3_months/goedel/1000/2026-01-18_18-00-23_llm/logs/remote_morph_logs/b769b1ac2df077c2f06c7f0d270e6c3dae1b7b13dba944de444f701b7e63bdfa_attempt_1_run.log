theorem integral_norm_bound {X : Type*} [Space] {μ : Measure X} {f : X → ℂ}
    (h : Continuous f) : ‖Measure.integral μ f‖ ≤ Measure.integral μ |f| := by
  have h₁ : ‖Measure.integral μ f‖ ≤ Measure.integral μ |f| :=
    calc
      ‖Measure.integral μ f‖ = ‖∫ x, f x ‖ := rfl
      _ ≤ ∫ x, |f x| := abs_of_nonneg (by
          -- Show that the integral of the absolute value is non-negative
          apply Measure.integral_nonneg
          intro x
          exact norm_nonneg (f x)) |>.trans (by
          -- Apply the integral version of the triangle inequality
          exact integral_abs_le_abs_integral (fun x => f x))
