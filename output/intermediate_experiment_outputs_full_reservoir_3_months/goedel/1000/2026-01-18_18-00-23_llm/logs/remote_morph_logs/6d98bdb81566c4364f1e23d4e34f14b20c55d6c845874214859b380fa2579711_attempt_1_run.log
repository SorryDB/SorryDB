lemma IsMatching.symmDiff_maxDegree_le_two (hM : G.IsMatching M) (hM' : G.IsMatching M') :
    (hM.restrict₂ hM').MaxDegreeLE 2 := by
  have h : (hM.restrict₂ hM').MaxDegreeLE 2 := by
    -- We need to show that for every vertex v in the restricted graph, the degree of v is at most 2.
    -- This involves analyzing the edges in M ∆ M' and their incident vertices.
    -- Since M and M' are matchings, any vertex can be incident to at most one edge in M and one edge in M'.
    -- Therefore, in M ∆ M', a vertex can be incident to at most two edges (one from M and one from M').
    -- This gives us the bound of 2 on the maximum degree.
    -- The actual proof would involve more detailed combinatorial reasoning, but we can use the given properties of matchings to derive this.
    sorry
  exact h
