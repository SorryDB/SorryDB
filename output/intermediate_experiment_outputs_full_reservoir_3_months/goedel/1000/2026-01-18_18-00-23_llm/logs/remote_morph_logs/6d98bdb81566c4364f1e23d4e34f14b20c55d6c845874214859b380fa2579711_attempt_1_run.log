          -- Since M and M' are matchings, the number of edges incident to v in each is at most 1
          have h₆ : (E (hM.restrict₂ hM', v)).encard ≤ ((E (G, v) ∩ M) ∪ (E (G, v) ∩ M')).encard := by
            exact Set.encard_le_of_subset h₅
