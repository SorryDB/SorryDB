  have h₁ : ∀ (v : α), (E (hM.restrict₂ hM', v)).encard ≤ 2 := by
    intro v
    have h₂ : (E (hM.restrict₂ hM', v)) ⊆ (E (G, v) |>.filter (fun e => e ∈ M ∆ M')) := by
      intro e he
      simp only [hM.restrict₂, Graph.subgraph, Graph.restrict, EdgeSet.ext_iff, Subgraph.diFF,
        Subgraph.filter) at he ⊢
      aesop
    have h₃ : (E (hM.restrict₂ hM', v)).encard ≤ (E (G, v) |>.filter (fun e => e ∈ M ∆ M')).encard := by
      apply encard_mono h₂
    have h₄ : (E (G, v) |>.filter (fun e => e ∈ M ∆ M')).encard ≤ 2 := by
      have h₅ : (E (G, v) |>.filter (fun e => e ∈ M ∆ M')) ⊆ (E (G, v) |>.filter (fun e => e ∈ M)) ∪ (E (G, v) |>.filter (fun e => e ∈ M')) := by
        intro e he
        simp only [EdgeSet.mem_union, EdgeSet.mem_filter] at he ⊢
        aesop
      have h₆ : (E (G, v) |>.filter (fun e => e ∈ M)).encard ≤ 1 := by
        have h₇ : (E (G, v) |>.filter (fun e => e ∈ M)) ⊆ M ∩ E (G, v) := by
          intro e he
          simp only [EdgeSet.mem_filter, Set.mem_inter_iff] at he ⊢
          aesop
        have h₈ : (E (G, v) |>.filter (fun e => e ∈ M)).encard ≤ (M ∩ E (G, v)).encard := by
          apply encard_mono h₇
        have h₉ : (M ∩ E (G, v)).encard ≤ 1 := by
          have h₁₀ : (M ∩ E (G, v)).encard ≤ 1 := by
            have h₁₁ : (M ∩ E (G, v)).Subsingleton := IsMatching.subsingleton_inc hM v
            rw [encard_le_one_iff_subsingleton.mpr h₁₁]
          exact h₁₀
        linarith
      have h₇ : (E (G, v) |>.filter (fun e => e ∈ M')).encard ≤ 1 := by
        have h₈ : (E (G, v) |>.filter (fun e => e ∈ M')) ⊆ M' ∩ E (G, v) := by
          intro e he
          simp only [EdgeSet.mem_filter, Set.mem_inter_iff] at he ⊢
          aesop
        have h₉ : (E (G, v) |>.filter (fun e => e ∈ M')).encard ≤ (M' ∩ E (G, v)).encard := by
          apply encard_mono h₈
        have h₁₀ : (M' ∩ E (G, v)).encard ≤ 1 := by
          have h₁₁ : (M' ∩ E (G, v)).Subsingleton := IsMatching.subsingleton_inc hM' v
          rw [encard_le_one_iff_subsingleton.mpr h₁₁]
        linarith
      have h₈ : (E (G, v) |>.filter (fun e => e ∈ M)) ∪ (E (G, v) |>.filter (fun e => e ∈ M')).encard ≤ 2 := by
        have h₉ : (E (G, v) |>.filter (fun e => e ∈ M)).encard ≤ 1 := h₆
        have h₁₀ : (E (G, v) |>.filter (fun e => e ∈ M')).encard ≤ 1 := h₇
        calc
          (E (G, v) |>.filter (fun e => e ∈ M)) ∪ (E (G, v) |>.filter (fun e => e ∈ M')).encard ≤
              (E (G, v) |>.filter (fun e => e ∈ M)).encard + (E (G, v) |>.filter (fun e => e ∈ M')).encard := by
            apply encard_union_le
          _ ≤ 1 + 1 := by
            gcongr <;> simp_all
          _ = 2 := by norm_num
      calc
        (E (G, v) |>.filter (fun e => e ∈ M ∆ M')).encard ≤
            (E (G, v) |>.filter (fun e => e ∈ M)) ∪ (E (G, v) |>.filter (fun e => e ∈ M')).encard := by
          apply encard_mono h₅
        _ ≤ 2 := h₈
    calc
      (E (G, v) |>.filter (fun e => e ∈ M ∆ M')).encard ≤ 2 := h₄
      _ = 2 := by norm_num
    <;>
    (try norm_num) <;>
    (try simp_all) <;>
    (try linarith) <;>
    (try aesop)
  have h₂ : (hM.restrict₂ hM').MaxDegreeLE 2 := by
    rw [maxDegreeLE_iff']
    intro v hv
    rw [eDegree_eq_encard_inc]
    have h₃ : (E (hM.restrict₂ hM', v) : Set β).encard ≤ 2 := by
      simpa [he] using h₁ v
    simpa [he] using h₃
  exact h₂
