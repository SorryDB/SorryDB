def IsMatching.restrict₂ (hM : G.IsMatching M) (hM' : G.IsMatching M') : Graph α β :=
  G ↾ (M ∆ M') |>.loopRemove

instance IsMatching.restrict₂.edgeFinite (hM : G.IsMatching M) (hM' : G.IsMatching M')
    [G.EdgeFinite] : (hM.restrict₂ hM').EdgeFinite := by
  infer_instance

lemma IsMatching.symmDiff_maxDegree_le_two (hM : G.IsMatching M) (hM' : G.IsMatching M') :
    (hM.restrict₂ hM').MaxDegreeLE 2 := by
  have h : (hM.restrict₂ hM').MaxDegreeLE 2 := by
    -- Use the fact that the maximum degree of the restricted graph is at most 2
    apply (maxDegreeLE_iff').mpr
    intro v
    -- Calculate the degree of each vertex in the restricted graph
    have h₁ : (hM.restrict₂ hM').eDegree v ≤ 2 := by
      -- Use the fact that the restricted graph has at most two edges per vertex
      calc
        (hM.restrict₂ hM').eDegree v = (G ↾ (M ∆ M') |>.loopRemove).eDegree v := rfl
        _ ≤ (G ↾ (M ∆ M')).eDegree v := by
          apply (eDegree_mono (loopRemove_subgraph) (G ↾ (M ∆ M'))).trans
          <;> simp [eDegree]
          <;>
          (try decide) <;>
          (try simp_all) <;>
          (try aesop)
        _ ≤ 2 := by
          -- Prove that the degree is at most 2
          have h₂ : (G ↾ (M ∆ M')).eDegree v ≤ 2 := by
            -- Use the fact that the degree in the original graph is at most 2
            have h₃ : (G ↾ (M ∆ M')).eDegree v ≤ 2 := by
