lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · -- Prove that the sum process is cadlag
    have h₁ : IsCadlag (X · ω) := hX.cadlag ω
    have h₂ : IsCadlag (Y · ω) := hY.cadlag ω
    exact IsCadlag.add h₁ h₂
  · -- Prove that the sum process has bounded eLpNorm
    have hX_bound : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded
    have hY_bound : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded
    calc
      ⨆ i, eLpNorm (fun ω ↦ X i ω + Y i ω) 2 P
        ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
          refine iSup_mono fun i ↦ ?_
          exact eLpNorm_add_le ((hX.martingale.adapted i).mono (𝓕.le i)).aestronglyMeasurable
            ((hY.martingale.adapted i).mono (𝓕.le i)).aestronglyMeasurable (by simp)
      _ ≤ (⨆ i, eLpNorm (X i) 2 P) + ⨆ i, eLpNorm (Y i) 2 P := by
          have h₁ : ⨆ i : ι, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) ≤ (⨆ i : ι, eLpNorm (X i) 2 P) + ⨆ i : ι, eLpNorm (Y i) 2 P := by
            refine le_trans (iSup_le fun i => _) (add_le_add_right (iSup_le fun i => _) _)
            · refine le_trans (add_le_add_right (le_iSup (fun i => eLpNorm (X i) 2 P) i) _) (add_le_add_left (le_iSup (fun i => eLpNorm (Y i) 2 P) i) _)
            · simp
          exact h₁
      _ < ∞ := by
          -- Prove that the sum of the two bounded quantities is bounded
          have h₁ : (⨆ i, eLpNorm (X i) 2 P : ENNReal) < ∞ := by simpa using hX_bound
          have h₂ : (⨆ i, eLpNorm (Y i) 2 P : ENNReal) < ∞ := by simpa using hY_bound
          -- Use the fact that the sum of two finite numbers is finite
          have h₃ : (⨆ i, eLpNorm (X i) 2 P : ENNReal) + (⨆ i, eLpNorm (Y i) 2 P : ENNReal) < ∞ := by
            -- Use the fact that the sum of two finite numbers is finite
            have h₄ : (⨆ i, eLpNorm (X i) 2 P : ENNReal) < ∞ := h₁
            have h₅ : (⨆ i, eLpNorm (Y i) 2 P : ENNReal) < ∞ := h₂
            -- Use the fact that the sum of two finite numbers is finite
            exact ENNReal.add_lt_top h₄ h₅
          -- Use the fact that the sum of two finite numbers is finite
          simpa using h₃
