theorem add_iSup {α : Type*} [ConditionallyCompleteLattice α] {s : Set α} {f g : α → α} (h : ∀ a ∈ s, f a + g a ≤ f a + g a) : ⨆ a ∈ s, (f a + g a) ≤ (⨆ a ∈ s, f a) + (⨆ a ∈ s, g a) := by
  calc
    ⨆ a ∈ s, (f a + g a) ≤ ⨆ a ∈ s, (f a + g a) := le_refl _
    _ ≤ (⨆ a ∈ s, f a) + (⨆ a ∈ s, g a) := by
      apply ciSup_add_le (by
        intro a ha
        exact le_of_eq (by simp)
        ) (by
          intro a ha
          exact le_of_eq (by simp)
          )
        <;> simp_all [add_assoc]
        <;> try norm_num
        <;> try linarith

