            -- Use the property of the supremum of sums being less than or equal to the sum of supremums
            calc
              ⨆ i : ι, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P)
                ≤ ⨆ i : ι, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := le_refl _
