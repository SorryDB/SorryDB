```lean
structure Group : Type where
  carrier : Type
  mul : carrier → carrier → carrier
  one : carrier
  inv : carrier → carrier
  mul_assoc : ∀ a b c, mul (mul a b) c = mul a (mul b c)
  mul_right_inv : ∀ a, mul a (inv a) = one
  mul_left_inv : ∀ a, mul (inv a) a = one

def isTrivial (G : Group) : Prop :=
  ∀ (a b : G.carrier), a = b

def trivialGroup : Group :=
  ⟨Unit, fun _ _ => Unit.unit, Unit.unit, fun _ => Unit.unit,
    by simp [Unit.ext_iff], by simp [Unit.ext_iff], by simp [Unit.ext_iff]⟩

example : isTrivial trivialGroup := by
  have h : ∀ (a b : trivialGroup.carrier), a = b := by sorry
  sorry
```

