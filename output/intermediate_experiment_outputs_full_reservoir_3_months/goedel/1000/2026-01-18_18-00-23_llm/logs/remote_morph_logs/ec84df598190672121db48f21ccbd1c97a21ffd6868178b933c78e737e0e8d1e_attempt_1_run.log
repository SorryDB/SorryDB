lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  have h₁ : onto f ↔ ∀ (y : V), y ∈ range f := by
    simp [SetLike.mem_coe, onto]
    <;>
    aesop
  
  have h₂ : (∀ (y : V), y ∈ range f) ↔ range f = Univ V := by
    constructor
    · intro h
      apply Set.eq_univ_of_forall
      intro y
      exact h y
    · intro h
      intro y
      have h₃ : y ∈ (Univ V : Set V) := by simp
      rw [h] at h₃
      exact h₃
  
  rw [h₁]
  rw [h₂]
  <;> simp_all
  <;> aesop
```
