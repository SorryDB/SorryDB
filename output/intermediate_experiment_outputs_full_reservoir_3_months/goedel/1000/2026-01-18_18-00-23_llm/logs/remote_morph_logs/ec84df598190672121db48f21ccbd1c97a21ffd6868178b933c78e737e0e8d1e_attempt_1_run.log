theorem onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  apply Iff.intro
  · -- Prove the forward direction: if f is onto, then range f = Univ V
    intro hf
    apply Set.ext
    intro y
    simp only [Set.mem_range, Set.mem_univ, iff_true_iff]
    -- Since f is onto, for every y in V, there exists x in U such that f x = y
    obtain ⟨x, hx⟩ := hf y
    exact ⟨x, by simp_all⟩
  · -- Prove the reverse direction: if range f = Univ V, then f is onto
    intro hf
    intro y
    -- Since range f = Univ V, y is in the range of f
    have h : y ∈ range f := by
      rw [hf]
      trivial
    -- Obtain x such that f x = y
    obtain ⟨x, hx⟩ := h
    exact ⟨x, by simp_all⟩
