    have h'' : y ∈ range f := by
      rw [h] at *
      exact h'
    -- If y is in the range of f, then there exists an x such that f(x) = y.
    rcases h'' with ⟨x, hx⟩
    -- We can directly use x to show that f is onto.
    exact ⟨x, by simp_all⟩
  
  have h_main : onto f ↔ range f = Set.univ := by
    constructor
    · -- Prove the forward direction: if f is onto, then range f = univ
      intro h
      exact h_forward h
    · -- Prove the backward direction: if range f = univ, then f is onto
      intro h
      exact h_backward h
  
  exact h_main
