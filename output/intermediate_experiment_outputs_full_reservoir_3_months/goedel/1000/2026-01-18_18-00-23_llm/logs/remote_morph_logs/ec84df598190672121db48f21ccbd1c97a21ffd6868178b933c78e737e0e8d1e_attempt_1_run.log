lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · -- Prove the forward direction: if f is onto, then range f = Univ V
    intro hf
    have h_subset : range f ⊆ (Univ : Set V) := by
      intro y hy
      trivial
    have h_superset : (Univ : Set V) ⊆ range f := by
      intro y _
      -- Since f is onto, for any y : V, there exists an x : U such that f x = y
      have h : ∃ x : U, f x = y := hf y
      obtain ⟨x, rfl⟩ := h
      exact Set.mem_range_self x
    have h_main : range f = (Univ : Set V) := by
      apply Set.Subset.antisymm h_subset h_superset
    -- Convert the set equality to the desired form
    simpa [Set.ext_iff] using h_main
  · -- Prove the reverse direction: if range f = Univ V, then f is onto
    intro hf
    have h_main : ∀ (y : V), ∃ (x : U), f x = y := by
