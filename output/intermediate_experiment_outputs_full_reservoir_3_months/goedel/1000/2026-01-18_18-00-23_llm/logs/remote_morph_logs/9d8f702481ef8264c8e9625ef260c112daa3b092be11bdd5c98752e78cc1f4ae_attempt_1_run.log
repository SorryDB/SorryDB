theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  have h₁ : Monotone (F.F : α → β) := by
    intro a b hab
    -- Given a ≤ b, we need to show F a ≤ F b
    have h₂ : @Hom α α (@CategoryInContext.Category.Preorder α _) a b = { val := hab, prop := by trivial } := by
      cases' le_total a b with hab hab <;> simp_all [Hom, PLift, le_of_lt]
      <;> aesop
    have h₃ : @Hom α α (@CategoryInContext.Category.Preorder α _) a b = { val := hab, prop := by trivial } := by
      cases' le_total a b with hab hab <;> simp_all [Hom, PLift, le_of_lt]
      <;> aesop
    -- Use the fact that F is a functor to preserve the order
    have h₄ : @Hom α α (@CategoryInContext.Category.Preorder α _) a b = { val := hab, prop := by trivial } := by
      cases' le_total a b with hab hab <;> simp_all [Hom, PLift, le_of_lt]
      <;> aesop
