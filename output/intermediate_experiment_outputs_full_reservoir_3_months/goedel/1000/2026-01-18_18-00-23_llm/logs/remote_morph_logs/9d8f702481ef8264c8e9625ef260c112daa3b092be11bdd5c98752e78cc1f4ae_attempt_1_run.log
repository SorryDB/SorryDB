theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  have h : Monotone (F.F) := by
    intro x y hxy
    have fxy : @PLift (x ≤ y) := ⟨hxy⟩
    have f' : @ PLift (F.F x ≤ F.F y) := F.homF fxy
    exact f'.down
  refine' ⟨F.F, ⟨h, _⟩⟩
  <;> simp
```
