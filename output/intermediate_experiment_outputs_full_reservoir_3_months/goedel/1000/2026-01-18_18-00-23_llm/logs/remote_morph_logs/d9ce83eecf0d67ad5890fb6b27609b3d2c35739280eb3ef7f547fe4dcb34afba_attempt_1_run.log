      have h₃ : HasDerivAt (fun x : ℝ => r * x) r (0 : ℝ) := by
        simpa using (hasDerivAt_id (0 : ℝ)).const_mul r
      have h₄ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * (0 : ℝ)) * r) (0 : ℝ) := by
        have h₅ : HasDerivAt (fun x : ℝ => r * x) r (0 : ℝ) := h₃
        have h₆ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * (0 : ℝ)) * r) (0 : ℝ) := by
          have h₇ : HasDerivAt (fun x : ℝ => r * x) r (0 : ℝ) := h₃
          have h₈ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) (Real.cosh (r * (0 : ℝ)) * r) (0 : ℝ) := by
            convert HasDerivAt.sinh (h₇) using 1 <;> ring_nf <;> simp [Real.cosh_zero]
          exact h₈
        exact h₆
      convert h₄ using 1 <;> ring_nf <;> simp [Real.cosh_zero]
    have h₅ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) r (0 : ℝ) := by
      convert h₂ using 1 <;> simp [Real.cosh_zero]
    have h₆ : HasDerivAt (fun x : ℝ => x) 1 (0 : ℝ) := hasDerivAt_id _
    have h₇ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] (0 : ℝ)) (𝓝 r) := by
      have h₈ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) r (0 : ℝ) := h₅
      have h₉ : HasDerivAt (fun x : ℝ => x) 1 (0 : ℝ) := h₆
      have h₁₀ : IsOpen (Set.univ : Set ℝ) := isOpen_univ
      have h₁₁ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] (0 : ℝ)) (𝓝 r) := by
        have h₁₂ : (fun x : ℝ => Real.sinh (r * x) / x) =ᶠ[𝓝[≠] (0 : ℝ)] fun x : ℝ => Real.sinh (r * x) / x := by rfl
        have h₁₃ : HasDerivAt (fun x : ℝ => Real.sinh (r * x)) r (0 : ℝ) := h₈
        have h₁₄ : HasDerivAt (fun x : ℝ => x) 1 (0 : ℝ) := h₆
        convert h₁₃.div_hasDerivAt h₁₄ (by norm_num) using 1 <;> simp [h₁₂] <;>
          (try simp_all [h₁₂]) <;>
          (try field_simp [h₁₂]) <;>
          (try ring_nf) <;>
          (try norm_num) <;>
          (try simp_all [h₁₂])
        <;>
        (try linarith)
