@[sorryful]
lemma limit_S_saddle(r : ℝ) :
    Tendsto (fun k : ℝ => k * Real.sinh (r / k)) atTop (𝓝 r) := by
  have h : Tendsto (fun (x : ℝ) => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by sorry
  -- Use the fact that sinh(r * x) / x tends to r as x tends to 0
  have h₂ : Tendsto (fun k : ℝ => k * Real.sinh (r / k)) atTop (𝓝 r) := by
    have h₃ : (fun k : ℝ => k * Real.sinh (r / k)) = (fun x : ℝ => Real.sinh (r / x) * x) := by
      funext x
      ring_nf
      <;> field_simp [Real.sinh_neg]
      <;> ring_nf
    rw [h₃]
    -- Substitute x = 1/k and use the limit of sinh(r * x) / x as x tends to 0
    have h₄ : Tendsto (fun k : ℝ => Real.sinh (r / k) * k) atTop (𝓝 r) := by
      have h₅ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by sorry
      have h₆ : Tendsto (fun x : ℝ => (1 / x : ℝ)) atTop (𝓝 0) := by
        have h₇ : Tendsto (fun x : ℝ => (1 / x : ℝ)) atTop (𝓝 0) := by
          simpa using tendsto_inv_atTop_zero
        exact h₇
      have h₇ : Filter.Tendsto (fun k : ℝ => Real.sinh (r / k) * k) atTop (𝓝 r) := by
        have h₈ : (fun k : ℝ => Real.sinh (r / k) * k) = (fun k : ℝ => (Real.sinh (r * (1 / k)) / (1 / k))) := by
          funext k
          by_cases h₈ : k = 0
          · simp_all
          · field_simp [h₈]
            <;> ring_nf
            <;> field_simp [h₈]
            <;> ring_nf
        rw [h₈]
        have h₉ : Tendsto (fun k : ℝ => (1 / k : ℝ)) atTop (𝓝 0) := by
          have h₁₀ : Tendsto (fun k : ℝ => (1 / k : ℝ)) atTop (𝓝 0) := by
            simpa using tendsto_inv_atTop_zero
          exact h₁₀
        have h₁₀ : Tendsto (fun k : ℝ => Real.sinh (r * (1 / k)) / (1 / k)) atTop (𝓝 r) := by
          have h₁₁ : Tendsto (fun k : ℝ => (1 / k : ℝ)) atTop (𝓝[≠] 0) := by
            have h₁₂ : Tendsto (fun k : ℝ => (1 / k : ℝ)) atTop (𝓝 0) := by
              simpa using tendsto_inv_atTop_zero
            have h₁₃ : Tendsto (fun k : ℝ => (1 / k : ℝ)) atTop (𝓝[≠] 0) := by
              have h₁₄ : ∀ᶠ (k : ℝ) in atTop, (1 / k : ℝ) ≠ 0 := by
                filter_upwards [eventually_gt_atTop 1] with k hk
                have h₁₅ : (1 : ℝ) / k > 0 := by positivity
                have h₁₆ : (1 : ℝ) / k ≠ 0 := by linarith
                exact h₁₆
              have h₁₅ : Tendsto (fun k : ℝ => (1 / k : ℝ)) atTop (𝓝 0) := by
                simpa using tendsto_inv_atTop_zero
              have h₁₆ : Tendsto (fun k : ℝ => (1 / k : ℝ)) atTop (𝓝[≠] 0) := by
                apply h₁₅.mono_left _ |>.mono_right _
                · filter_upwards [h₁₄] with k hk
                  simp_all [Set.mem_compl_iff, Set.mem_singleton_iff]
                · intro s hs
                  simp_all [Set.mem_compl_iff, Set.mem_singleton_iff]
                  <;> aesop
              exact h₁₆
            exact h₁₃
          have h₁₂ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by sorry
          have h₁₃ : Tendsto (fun k : ℝ => Real.sinh (r * (1 / k)) / (1 / k)) atTop (𝓝 r) := by
            have h₁₄ : Tendsto (fun k : ℝ => (1 / k : ℝ)) atTop (𝓝[≠] 0) := h₁₁
            have h₁₅ : Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := h₁₂
            have h₁₆ : Tendsto (fun k : ℝ => Real.sinh (r * (1 / k)) / (1 / k)) atTop (𝓝 r) :=
              h₁₅.comp h₁₄
            exact h₁₆
          exact h₁₃
        exact h₁₀
      exact h₇
    simpa using h₄
  exact h₂
