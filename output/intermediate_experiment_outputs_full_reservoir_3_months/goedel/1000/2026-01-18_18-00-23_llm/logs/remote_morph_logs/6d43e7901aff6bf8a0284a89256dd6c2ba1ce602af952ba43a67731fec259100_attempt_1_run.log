### Full Solution

```lean
def myA : ℕ → ℕ → ℕ :=
  fun m n =>
    Nat.recOn m (fun n => n + 1) (fun m ih n => Nat.recOn n (fun m => ih 1) (fun n ih' => ih' ( Nat.recOn m (fun n => n + 1) (fun m ih m => ih ( Nat.recOn m (fun n => n + 1) (fun m ih m => ih (ih m)))) n))) m n

example : A = myA := by
  have h : ∀ m n : ℕ, A m n = myA m n := by
    intro m n
    have h₁ : ∀ m n : ℕ, A m n = myA m n := by
      intro m
      induction m with
      | zero =>
        intro n
        simp [A, myA]
        <;> rfl
      | succ m ih =>
        intro n
        induction n with
        | zero =>
          simp_all [A, myA, Nat.recOn]
          <;>
          (try decide) <;>
          (try ring_nf at * <;> simp_all) <;>
          (try aesop)
        | succ n ih' =>
          simp_all [A, myA, Nat.recOn]
          <;>
          (try decide) <;>
          (try ring_nf at * <;> simp_all) <;>
          (try aesop)
    exact h₁ m n
  funext m
  funext n
  apply h
  <;> rfl
