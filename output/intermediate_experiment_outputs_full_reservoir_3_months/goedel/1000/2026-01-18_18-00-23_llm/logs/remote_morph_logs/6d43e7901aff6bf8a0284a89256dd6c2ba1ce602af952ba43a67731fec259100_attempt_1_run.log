  fun m n =>
    Nat.recOn m (n + 1) (fun m ih =>
      Nat.recOn n (ih 1) (fun n ih' =>
        A m (A (m + 1) n)))
  
example : A = myA := by
  funext m n
  have h : A m n = myA m n := by
    induction m with
    | zero =>
      -- Base case: when m = 0, A 0 n = n + 1 and myA 0 n = n + 1
      simp [A, myA]
    | succ m ih =>
