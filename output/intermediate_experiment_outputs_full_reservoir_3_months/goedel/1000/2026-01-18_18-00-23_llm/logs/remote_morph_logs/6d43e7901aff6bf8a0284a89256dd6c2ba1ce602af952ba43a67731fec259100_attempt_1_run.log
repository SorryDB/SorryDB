def myA : ℕ → ℕ → ℕ :=
  fun m n => Nat.rec (motive := fun m => ℕ → ℕ)
    (fun n => n + 1)
    (fun m ih n => Nat.rec (motive := fun n => ℕ)
      (ih 1)
      (fun n ih' => ih (ih' n + 1)) n) m n

example : A = myA := by
  funext m n
  induction m with
  | zero =>
    -- Base case: m = 0
    simp [A, myA]
  | succ m ih =>
    -- Inductive step for m
    induction n with
    | zero =>
      -- Case: n = 0
      simp_all [A, myA, Nat.succ_eq_add_one]
      <;> try simp_all [Nat.rec]
      <;> try ring_nf at *
      <;> try norm_num at *
      <;> try linarith
    | succ n ih' =>
      -- Case: n = succ n
      simp_all [A, myA, Nat.succ_eq_add_one]
      <;> try simp_all [Nat.rec]
      <;> try ring_nf at *
      <;> try norm_num at *
      <;> try linarith
