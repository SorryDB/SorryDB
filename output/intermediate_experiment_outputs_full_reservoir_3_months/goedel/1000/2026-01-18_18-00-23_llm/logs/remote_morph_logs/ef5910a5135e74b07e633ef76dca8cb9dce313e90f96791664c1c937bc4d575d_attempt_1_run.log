theorem measuremap_eq_compProd (’s : discrete @cool_sorrys : @     there exists universal, straightforward method to construct a @Quotient_med
  instance (M : Set α) [v : MeasurableSpace α] : MeasurableSpace (Set α) :=
    (by infer_instance)

/-- An instance of a `MeasurableSpace` for any `Set.univ : Set α`.

  This instance is a specific case of `inducedInstance`, but is provided
  directly because it is so commonly used.
  -/
  instance (α : Type*) : MeasurableSpace α := Classical.decEq α <| by
    classical
    -- We use the intersection of the power set with definable sets as the base.
    -- This is correct because the power set is the whole set.
    exact
      inherit MeasurableSpace (Set.univ : Set α) (Set.univ : Set α) by simp [Set.subset_univ]
  <;> simp_all [Set.subset_univ]
  <;> aesop
