theorem isClosed_eq {α : Type*} [TopologicalSpace α] {s t : Set α} :
    IsClosed {x | s = t} := by
  have h : {x | s = t} = ∅ ∨ {x | s = t} = univ := by
    by_cases h : s = t
    · exact Or.inr (by simp [h])
    · exact Or.inl (by simp [h])
  cases h with
  | inl h =>
    rw [h]
    exact isClosed_empty
  | inr h =>
    rw [h]
    exact isClosed_univ
```
