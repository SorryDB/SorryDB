theorem bounded_dominated_convergence :
    ∀ E : Type* [MeasureSpace E] [VCompactSpace E]
    {μ : Measure E} {f : ℕ → E → ℝ},
    (∀ n, Measurable (f n)) →
    (∀ n, ∀ x, 0 ≤ f n x) →
    (∀ n, ∫ x, f n x ∂μ ≤ C) →
    ∀ g : E → ℝ, Measurable g → (∀ x, 0 ≤ g x) → (∫ x, g x ∂μ < ∞) →
    (∀ x, ∃ N, ∀ n ≥ N, f n x ≤ g x) →
    ∃ (h : ℕ → ℝ), ∑' n, h n < ∞ ∧ (∀ N, (∑ n in Finset.range N, ∫ x, h n x ∂μ) ≥ ∫ x, (∑ n in Finset.range N, f n x) ∂μ) := by
  intro E _ _ μ f hf_measurable hf_nonneg hf_bounded g hg_measurable hg_nonneg hg_finite hf_dominated
  use fun n => 0
  constructor
  · simp
  · intro N
    have h1 : ∑ n in Finset.range N, (∫ x, (0 : ℝ) ∂μ) ≥ ∫ x, (∑ n in Finset.range N, f n x) ∂μ := by
      have h2 : ∫ x, (∑ n in Finset.range N, f n x) ∂μ ≤ ∑ n in Finset.range N, ∫ x, f n x ∂μ := by
        exact sum_integral_le_sum_integral (fun n _ => (hf_nonneg n)) (hf_measurable)
      have h3 : ∑ n in Finset.range N, ∫ x, f n x ∂μ ≤ ∑ n in Finset.range N, C := by
        exact Finset.sum_le_sum fun n _ => by
          have h4 : ∫ x, f n x ∂μ ≤ C := hf_bounded n
          linarith
      have h4 : ∫ x, (0 : ℝ) ∂μ = 0 := by simp [MeasureTheory.integral_const]
      have h5 : ∑ n in Finset.range N, (∫ x, (0 : ℝ) ∂μ) = 0 := by
        simp [h4]
      have h6 : ∫ x, (∑ n in Finset.range N, f n x) ∂μ ≤ ∑ n in Finset.range N, C := by
        linarith
      have h7 : ∑ n in Finset.range N, C ≥ ∫ x, (∑ n in Finset.range N, f n x) ∂μ := by linarith
      linarith
    have h2 : ∑ n in Finset.range N, (∫ x, (0 : ℝ) ∂μ) ≥ ∫ x, (∑ n in Finset.range N, f n x) ∂μ := h1
    have h3 : (∑ n in Finset.range N, ∫ x, (0 : ℝ) x ∂μ) ≥ ∫ x, (∑ n in Finset.range N, f n x) ∂μ := by
      simpa using h2
    simpa using h3
