def buildBST : List α → LabelledTree α
  | [] => leaf (⊥ : α)
  | [x] => leaf x
  | x :: y :: xs =>
    let aux : List α → LabelledTree α := fun ys =>
      ys.foldr (fun z t => addLabel t z) (leaf x)
    aux (y :: xs)
``` 

