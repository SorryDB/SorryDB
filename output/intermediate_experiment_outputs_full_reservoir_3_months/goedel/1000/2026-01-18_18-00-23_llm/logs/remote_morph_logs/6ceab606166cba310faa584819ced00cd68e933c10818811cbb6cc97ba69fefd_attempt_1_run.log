    intro l
    induction l with
    | nil =>
      simp [IsOrdered]
    | cons x xs ih =>
      have h₁ : IsOrdered (xs.foldl addLabel (leaf x)) := by
        simpa using ih
      have h₂ : IsOrdered (addLabel (xs.foldl addLabel (leaf x)) x) := by
        -- Use the fact that adding an element to an ordered tree preserves the ordered property
        have h₃ : IsOrdered (xs.foldl addLabel (leaf x)) := h₁
        have h₄ : IsOrdered (addLabel (xs.foldl addLabel (leaf x)) x) := ordered_addLabel
          _ x h₃
        exact h₄
      simpa using h₂
  simpa [buildBST] using h

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
