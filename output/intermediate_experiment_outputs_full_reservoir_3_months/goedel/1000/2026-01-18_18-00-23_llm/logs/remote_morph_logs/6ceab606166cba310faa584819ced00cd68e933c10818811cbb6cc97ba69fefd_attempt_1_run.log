    IsOrdered (buildBST labels) := by
  have h₁ : ∀ (t : LabelledTree α), IsOrdered t → ∀ (label : α), IsOrdered (t.addLabel label) := by
    intro t ht label
    exact ordered_addLabel t label ht
  have h₂ : ∀ (l : List α), IsOrdered (buildBST l) := by
    intro l
    induction l with
    | nil =>
      -- Base case: empty list
      simp [buildBST, IsOrdered]
      <;>
      trivial
    | cons x xs ih =>
      -- Inductive step: add one element at a time
      simp_all [buildBST, List.foldr]
      <;>
      (try simp_all [ordered_addLabel, IsOrdered]) <;>
      (try tauto) <;>
      (try aesop)
  exact h₂ labels

