theorem correctness_theorem (n : ℕ) (a : ℕ → ℕ) : 
  (∀ i ≤ n, a i = 0) ↔ 
  ((∑ i in Finset.range (n+1), a i : ℕ) = 0) := by
  have h₁ : (∀ i ≤ n, a i = 0) → (∑ i in Finset.range (n+1), a i : ℕ) = 0 := by
    intro h
    apply Finset.sum_eq_zero
    intro i hi
    have h₂ : i ≤ n := by
      simp [Finset.mem_range] at hi
      omega
    have h₃ : a i = 0 := h i h₂
    simp [h₃]
  
  have h₂ : (∑ i in Finset.range (n+1), a i : ℕ) = 0 → (∀ i ≤ n, a i = 0) := by
    intro h
    intro i hi
    have h₃ : i < n + 1 := by
      omega
    have h₄ : a i = 0 := by
      have h₅ : (∑ k in Finset.range (n + 1), a k) = 0 := h
      have h₆ : a i ≤ ∑ k in Finset.range (n + 1), a k := by
        apply Finset.single_le_sum (fun j _ => by exact Nat.zero_le (a j)) (Finset.mem_range.mpr (by omega))
      have h₇ : a i ≤ 0 := by
        omega
      have h₈ : a i ≥ 0 := by
        exact Nat.zero_le (a i)
      omega
    exact h₄
  
  exact ⟨h₁, h₂⟩
