instance (k A B : Type*) [Field k] [CommRing A] [Ring B]
    [Algebra k A] [Algebra k B]
    [Algebra.IsCentral k B] :
    Algebra.IsCentral A (A ⊗[k] B) := by
  haveI : Algebra.IsCentral A B := by
    -- Since `B` is a central `k`-algebra and `A` is a commutative `k`-algebra, `B` is also a central `A`-algebra.
    -- This is because the multiplication by elements of `A` commutes with the multiplication by elements of `B`.
    -- Specifically, for any `a : A` and `b : B`, `a • b = b • a` in `B`.
    -- Here, `a • b` denotes the scalar multiplication of `a` on `b`, which is the same as the multiplication of `a` and `b` in `B`.
    -- However, since `A` is commutative, `a • b = b • a` is equivalent to `a * b = b * a` in `B`.
    -- Since `B` is central over `k`, `a * b = b * a` for all `a : A` and `b : B`.
    -- Therefore, `B` is central over `A`.
    infer_instance
  infer_instance
