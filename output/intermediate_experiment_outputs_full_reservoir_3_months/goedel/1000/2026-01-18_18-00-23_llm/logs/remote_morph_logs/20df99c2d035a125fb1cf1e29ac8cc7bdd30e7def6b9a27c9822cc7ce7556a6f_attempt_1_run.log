example : ∀ᵐ x : ℝ, Irrational x := by
  have h : (Set.univ : Set ℝ).volume = 0 := by
    have h₁ : (Set.univ : Set ℝ).volume = 0 := by
      -- The volume of the entire set of real numbers in the default measure (counting measure) is 0.
      simp [volume_eq_zero]
    exact h₁
  -- Since the set of irrational numbers is the complement of the set of rational numbers (a countable set),
  -- and the set of rational numbers has measure 0, the set of irrational numbers has full measure.
  have h₂ : ∀ᵐ x : ℝ, Irrational x := by
    -- Use the fact that the set of rational numbers is countable and thus has measure 0.
    have h₃ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (coe : ℚ → ℝ) := by
      -- The set of rational numbers is countable, and the real line is uncountable.
      apply ae_not_mem_of_countable
      exact Set.countable_range _
    -- The condition `x ∉ Set.range (coe : ℚ → ℝ)` is equivalent to `x` being irrational.
    filter_upwards [h₃] with x hx
    intro h₄
    -- If `x` is rational, then it is in the set of rational numbers, which contradicts `hx`.
    have h₅ : ∃ (q : ℚ), (q : ℝ) = x := by
      cases' h₄ with q hq
      exact ⟨q, by simp_all [Rat.cast_inj]⟩
    rcases h₅ with ⟨q, hq⟩
    have h₆ : x ∈ Set.range (coe : ℚ → ℝ) := by
      refine' ⟨q, _⟩
      simp_all
    exact hx h₆
  exact h₂
```
