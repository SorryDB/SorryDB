theorem irrational_tendsto_atTop : ∀ᵐ (x : ℝ), Irrational x :=
  eventually_of_forall fun x => by
    by_contra h
    -- If x is not irrational, then it is rational, so we can write it as a ratio of integers
    have h₁ : ∃ (a : ℤ) (b : ℕ), b ≠ 0 ∧ x = a / b := by
      -- Since x is not irrational, it is rational
      have h₂ : ∃ (q : ℚ), (q : ℝ) = x := by
        exact ⟨x, by simp [h]⟩
      -- Obtain the rational number q and convert it to a ratio of integers
      obtain ⟨q, hq⟩ := h₂
      refine' ⟨q.num, q.den, by simpa [Rat.den_nz] using q.den_nz, _⟩
      -- Verify that x = q.num / q.den
      have h₃ : (q : ℝ) = x := by simpa using hq
      have h₄ : (q : ℝ) = q.num / q.den := by
        norm_cast
        <;> field_simp [Rat.den_nz]
        <;> simp [Rat.num_div_den]
      rw [h₄] at h₃
      norm_cast at h₃ ⊢
      <;> linarith
    -- We have x = a / b for some integers a and positive integer b
    obtain ⟨a, b, hb, hx⟩ := h₁
    -- This leads to a contradiction because x was assumed to be irrational
    exfalso
    exact h ⟨a, b, hb, by simp_all [hx]⟩
