          -- If x were rational, then x would be in the union of all singleton sets of rationals.
          have h₈ : x ∈ (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) := by
            have h₉ : (q : ℝ) = x := by
