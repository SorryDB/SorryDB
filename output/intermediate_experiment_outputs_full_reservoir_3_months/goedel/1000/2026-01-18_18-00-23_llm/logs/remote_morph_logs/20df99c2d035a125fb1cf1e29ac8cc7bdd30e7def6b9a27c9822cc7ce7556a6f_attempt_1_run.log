      -- If x is not in the union of all singleton sets of rationals, then x is irrational.
      have h₅ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
        have h₆ : ∀ᵐ (x : ℝ) ∂volume, x ∉ (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) := h₄
        filter_upwards [h₆] with x hx
        -- Prove that x is irrational.
        have h₇ : Irrational x := by
