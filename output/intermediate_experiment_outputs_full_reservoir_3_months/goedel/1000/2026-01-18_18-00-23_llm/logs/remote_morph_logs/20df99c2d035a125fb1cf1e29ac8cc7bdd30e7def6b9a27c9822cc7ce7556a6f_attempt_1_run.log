section MeasureTheory

variable {X : Type*} [MeasurableSpace X] {μ : Measure X}
variable {Y : Type*} [MeasurableSpace Y] {ν : Measure Y} {f : X → Y}

example : ∀ᵐ x : ℝ, Irrational x := by
  have h : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
    have h₁ : {x : ℝ | Irrational x} = {x : ℝ | ∀ (q : ℚ), (q : ℝ) ≠ x} := by
      ext x
      simp [Irrational]
      <;>
      aesop
    rw [h₁]
    have h₂ : ∀ᵐ (x : ℝ) ∂volume, ∀ (q : ℚ), (q : ℝ) ≠ x := by
      have h₃ : ∀ (q : ℚ), ∀ᵐ (x : ℝ) ∂volume, (q : ℝ) ≠ x := by
        intro q
        have h₄ : ∀ᵐ (x : ℝ) ∂volume, (q : ℝ) ≠ x := by
          have h₅ : ({q : ℝ} : Set ℝ).volume = 0 := by
            -- The Lebesgue measure of a singleton set is zero
            rw [volume_singleton]
          -- The complement of a measure zero set is almost everywhere
          have h₆ : ∀ᵐ (x : ℝ) ∂volume, x ∉ ({q : ℝ} : Set ℝ) := by
            filter_upwards [ae_restrict_compl_null (measurableSet_singleton : MeasurableSet ({q : ℝ} : Set ℝ)) (by simpa using h₅)] with x hx
            exact hx
          filter_upwards [h₆] with x hx
          intro h₇
          apply hx
          simp_all [Set.mem_singleton_iff]
          <;>
          norm_cast at *
          <;>
          aesop
        exact h₄
      -- The intersection of countably many almost everywhere sets is almost everywhere
      have h₇ : ∀ᵐ (x : ℝ) ∂volume, ∀ (q : ℚ), (q : ℝ) ≠ x := by
        have h₈ : ∀ (q : ℚ), ∀ᵐ (x : ℝ) ∂volume, (q : ℝ) ≠ x := h₃
        have h₉ : ∀ᵐ (x : ℝ) ∂volume, ∀ (q : ℚ), (q : ℝ) ≠ x := by
          -- Use the fact that the rationals are countable to take the intersection
          have h₁₀ : Set.Countable (Set.univ : Set ℚ) := Set.countable_univ
          have h₁₁ : ∀ᵐ (x : ℝ) ∂volume, ∀ (q : ℚ), (q : ℝ) ≠ x := by
            -- Use the fact that the rationals are countable to take the intersection
            apply Filter.eventually_all_countable
            intro q
            exact h₈ q
          exact h₁₁
        exact h₉
      exact h₇
    exact h₂
  -- The set of irrational numbers is almost everywhere
  exact h
