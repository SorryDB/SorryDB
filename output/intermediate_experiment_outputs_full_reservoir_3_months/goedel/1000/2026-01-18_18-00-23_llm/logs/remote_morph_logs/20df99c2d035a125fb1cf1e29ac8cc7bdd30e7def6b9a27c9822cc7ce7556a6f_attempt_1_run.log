          have h₄ : {x : ℝ | (q : ℝ) = x} = { (q : ℝ) } := by
            ext x
            simp [Set.mem_setOf_eq]
            <;>
            (try norm_cast) <;>
            (try simp_all [Set.mem_singleton_iff]) <;>
            (try aesop)
          rw [h₄]
          -- The volume of a singleton set is zero.
          simp [volume_singleton]
        exact h₃
      -- Use the fact that the union of all singleton sets of rationals has measure zero.
      have h₃ : (volume : Measure ℝ) (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) = 0 := by
        -- The countable union of sets with measure zero has measure zero.
        have h₄ : (volume : Measure ℝ) (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) = 0 := by
          -- Use the fact that the volume of each singleton set is zero and the countable union of such sets has measure zero.
          have h₅ : (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) = ⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ) := rfl
          rw [h₅]
          -- Apply the countable additivity property of the volume measure.
          have h₆ : (volume : Measure ℝ) (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) ≤ ∑' (q : ℚ), (volume : Measure ℝ) ({x : ℝ | (q : ℝ) = x} : Set ℝ) := by
            -- Use the subadditivity of the measure.
            exact MeasureTheory.measure_le_sum_of_subset (fun q => ({x : ℝ | (q : ℝ) = x} : Set ℝ)) (by simp [Set.subset_def]) (by simp)
          -- Since each term in the sum is zero, the sum is zero.
          have h₇ : ∑' (q : ℚ), (volume : Measure ℝ) ({x : ℝ | (q : ℝ) = x} : Set ℝ) = 0 := by
            have h₈ : ∀ (q : ℚ), (volume : Measure ℝ) ({x : ℝ | (q : ℝ) = x} : Set ℝ) = 0 := by
              intro q
              exact h₂ q
            -- The sum of zeros is zero.
            simp [h₈]
          -- Therefore, the volume of the union is zero.
          have h₈ : (volume : Measure ℝ) (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) ≤ 0 := by
            linarith
          -- The volume is non-negative, so it must be zero.
          have h₉ : 0 ≤ (volume : Measure ℝ) (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) := by
            exact zero_le _
          linarith
        exact h₄
      -- Since the union of all singleton sets of rationals has measure zero, the complement of this set has full measure.
      have h₄ : ∀ᵐ (x : ℝ) ∂volume, x ∉ (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) := by
        -- Use the fact that the measure of the set is zero.
        have h₅ : (volume : Measure ℝ) (⋃ (q : ℚ), ({x : ℝ | (q : ℝ) = x} : Set ℝ)) = 0 := h₃
        -- Use the fact that the complement of a set with measure zero has full measure.
        exact aep_iff_ae_restrict.mpr (by
