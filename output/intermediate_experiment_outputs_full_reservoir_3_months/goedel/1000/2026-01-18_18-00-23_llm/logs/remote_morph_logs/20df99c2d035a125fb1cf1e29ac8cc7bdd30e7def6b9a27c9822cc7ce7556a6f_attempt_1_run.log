      -- Use the fact that the range of the coercion from ℚ to ℝ is countable and has measure zero
      have h₄ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (coe : ℚ → ℝ) := by
        -- Since ℚ is countable, its image under the coercion has measure zero
        have h₅ : Set.range (coe : ℚ → ℝ) ∈ null_sets volume := by
          -- Use the fact that a countable set has measure zero
          have h₆ : Set.Countable (Set.range (coe : ℚ → ℝ)) := by
            -- The range of the coercion is countable because ℚ is countable
            exact Set.countable_range _
          -- Use the fact that a countable set in ℝ has measure zero
          have h₇ : Set.range (coe : ℚ → ℝ) ∈ null_sets volume := by
            exact null_sets_countable h₆
          exact h₇
        -- Since the set of rationals is in the null sets, its complement is almost everywhere
        exact almost_everywhere_of_forall_not_mem h₅
      exact h₄
    exact h₂
  -- Since the set of irrationals is almost everywhere in the restriction to the universe, it is almost everywhere in ℝ
  have h₁ : ∀ᵐ (x : ℝ) ∂volume.restrict (Set.univ : Set ℝ), Irrational x := h
  have h₂ : ∀ᵐ (x : ℝ), Irrational x := by
