example : ∀ᵐ x : ℝ, Irrational x := by
  have h : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
    have h₁ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun (q : ℚ) => (q : ℝ)) := by
      have h₂ : volume (Set.range (fun (q : ℚ) => (q : ℝ)) : Set ℝ) = 0 := by
        apply volume_null_of_isCountable
        exact Set.countable_range _
      filter_upwards [ae_restrict_mem (measurableSet_univ : MeasurableSet (Set.univ : Set ℝ))] with x hx
      by_contra h₃
      have h₄ : x ∈ Set.range (fun (q : ℚ) => (q : ℝ)) := by simpa using h₃
      have h₅ : volume (Set.range (fun (q : ℚ) => (q : ℝ)) : Set ℝ) = 0 := h₂
      have h₆ : x ∈ (Set.range (fun (q : ℚ) => (q : ℝ)) : Set ℝ) := h₄
      have h₇ : volume {x} = 0 := by
        have h₈ : volume {x} = 0 := by
          apply volume_singleton
        exact h₈
      have h₈ : {x} ⊆ (Set.range (fun (q : ℚ) => (q : ℝ)) : Set ℝ) := by
        intro y hy
        simp only [Set.mem_singleton_iff] at hy
        rw [hy]
        exact h₆
      have h₉ : volume {x} ≤ volume (Set.range (fun (q : ℚ) => (q : ℝ)) : Set ℝ) := by
        apply volume_mono
        exact h₈
      have h₁₀ : volume {x} = 0 := h₇
      have h₁₁ : volume (Set.range (fun (q : ℚ) => (q : ℝ)) : Set ℝ) = 0 := h₂
      simp_all
    filter_upwards [h₁] with x hx
    simp_all [Irrational]
    <;>
    (try
      {
        exact fun ⟨q, hq⟩ => hx ⟨q, by simpa using hq⟩
      }) <;>
    (try
      {
        tauto
      })
  -- Since the volume measure is the default measure on ℝ, we can omit it.
  filter_upwards [h] with x hx using hx
