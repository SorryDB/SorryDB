          have h₈ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (fun q : ℚ => (q : ℝ)) := by
            -- Use the fact that the range of rationals has measure zero.
            have h₉ : (volume : Measure ℝ).aep.eq_zero (Set.range (fun q : ℚ => (q : ℝ))) := by
              apply h₂.aep_eq_zero
            filter_upwards [h₉] with x hx
            simp_all [Set.mem_range]
            <;> aesop
          exact h₈
        filter_upwards [h₆] with x hx
        simp_all [Set.mem_diff]
        <;> aesop
      have h₆ : ∀ᵐ (x : ℝ) ∂volume, x ∈ (Set.univ : Set ℝ) \ Set.range (fun q : ℚ => (q : ℝ)) := by
        have h₇ : (volume.restrict (Set.univ : Set ℝ)) = volume := by simp
        rw [h₇] at h₅
        exact h₅
      exact h₆
    -- Therefore, almost every real number is in the set of irrationals.
    filter_upwards [h₃] with x hx
    exact h₁ hx
  -- Since `Irrational ∂volume aep` is true, it means that for almost every `x`, `x` is irrational.
  exact h
