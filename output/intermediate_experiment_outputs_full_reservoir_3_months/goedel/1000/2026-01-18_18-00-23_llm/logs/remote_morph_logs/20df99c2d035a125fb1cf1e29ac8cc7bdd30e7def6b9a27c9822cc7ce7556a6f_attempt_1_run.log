```lean
example : ∀ᵐ x : ℝ, Irrational x := by
  have h : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
    -- The set of rational numbers is countable, hence has measure zero in ℝ.
    have h₁ : (Set.range (coe : ℚ → ℝ)).countable := Set.countable_range _
    have h₂ : (Set.range (coe : ℚ → ℝ)).measurable := by
      -- The set of rationals is measurable because it is a countable union of measurable sets.
      apply MeasurableSet.countableUnion
      intro q
      exact measurableSet_singleton
    -- The complement of the rationals (i.e., the irrationals) has full measure.
    have h₃ : (Set.range (coe : ℚ → ℝ))ᶜ ∈ measurableSet.univ := by
      -- The complement of a measurable set is measurable.
      have h₄ : (Set.range (coe : ℚ → ℝ))ᶜ ∈ (measurableSet.univ : MeasurableSet ℝ) := by
        exact measurableSet_univ
      exact h₄
    -- Since the rationals have measure zero, the irrationals have full measure.
    have h₄ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ)) = 0 := by
      -- A countable set has measure zero.
      have h₅ : (volume : Measure ℝ) (Set.range (coe : ℚ → ℝ)) = 0 := by
        -- Use the fact that the measure of a countable set is zero.
        apply Measure.measure_zero_of_countable
        <;> exact h₁
      exact h₅
    -- Use the fact that the complement of a set of measure zero has full measure.
    have h₅ : ∀ᵐ (x : ℝ) ∂volume, x ∉ Set.range (coe : ℚ → ℝ) := by
      -- A set of measure zero is negligible.
      exact (measurableSet_univ : MeasurableSet ℝ).ae_compl (by
        -- Show that the set is measurable.
        have h₆ : (Set.range (coe : ℚ → ℝ)) ∈ (measurableSet.univ : MeasurableSet ℝ) := by
          exact measurableSet_univ
        exact h₆)
      <;> simp_all [h₄]
      <;> aesop
    -- Convert the condition to the irrationality condition.
    filter_upwards [h₅] with x hx
    -- If x is not rational, then it is irrational.
    have h₆ : Irrational x := by
      intro ⟨q, hq⟩
      -- If x were rational, it would be in the range of the coercion from ℚ to ℝ.
      have h₇ : x ∈ Set.range (coe : ℚ → ℝ) := ⟨q, by simp [hq]⟩
      -- This contradicts the assumption that x is not in the range.
      exact hx h₇
    exact h₆
  -- The statement is about the volume measure on ℝ, which is the same as the default measure.
  simpa using h
