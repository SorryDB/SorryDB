```lean
example : ∀ᵐ x : ℝ, Irrational x := by
  have h : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
    -- Use the fact that the set of irrational numbers is a complement of a countable set in the reals
    have h₁ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
      -- The set of rational numbers has measure zero in the real line
      -- Therefore, the set of irrational numbers has full measure
      have h₂ : (Set.univ : Set ℝ) \ Set.range (coe : ℚ → ℝ) = {x : ℝ | Irrational x} := by
        ext x
        simp [Irrational, Set.mem_range]
        <;>
        simp_all [Rat.cast_inj]
        <;>
        aesop
      -- The set of rational numbers is countable, so its measure is zero
      have h₃ : volume (Set.range (coe : ℚ → ℝ)) = 0 := by
        apply volume_countable
        <;>
        infer_instance
      -- Therefore, the complement has full measure
      have h₄ : ∀ᵐ (x : ℝ) ∂volume, x ∈ ({x : ℝ | Irrational x} : Set ℝ) := by
        have h₅ : ∀ᵐ (x : ℝ) ∂volume, x ∉ (Set.range (coe : ℚ → ℝ) : Set ℝ) := by
          have h₆ : volume (Set.range (coe : ℚ → ℝ)) = 0 := h₃
          have h₇ : ∀ᵐ (x : ℝ) ∂volume, x ∉ (Set.range (coe : ℚ → ℝ) : Set ℝ) := by
            filter_upwards [ae_restrict_compl_null (measurableSet_range (by
              infer_instance : Measurable (coe : ℚ → ℝ))) h₆] with x hx using hx
          exact h₇
        filter_upwards [h₅] with x hx
        simp_all [h₂]
        <;>
        tauto
      -- Convert the statement to the desired form
      have h₅ : ∀ᵐ (x : ℝ) ∂volume, Irrational x := by
        filter_upwards [h₄] with x hx
        simpa using hx
      exact h₅
    exact h₁
  -- The statement follows directly from the fact that the set of irrational numbers has full measure
  exact h
