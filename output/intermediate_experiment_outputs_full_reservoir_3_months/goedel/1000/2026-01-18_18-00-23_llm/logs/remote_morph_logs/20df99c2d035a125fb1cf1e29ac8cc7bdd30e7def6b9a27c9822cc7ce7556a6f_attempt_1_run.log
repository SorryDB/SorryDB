theorem exists_irrational : ∃ x : ℝ, Irrational x := by
  use Real.sqrt 2
  intro h
  rcases h with ⟨q, hq⟩
  have h₁ : (q : ℝ) ^ 2 = 2 := by
    have h₂ : (q : ℝ) = Real.sqrt 2 := by
      linarith [Real.sqrt_nonneg 2, Real.sq_sqrt (show 0 ≤ (2 : ℝ) by norm_num)]
    rw [h₂]
    norm_num [Real.sqrt_eq_iff_sq_eq]
  have h₂ : (q : ℚ) ^ 2 = 2 := by
    norm_cast at h₁ ⊢
    <;>
    (try norm_num at h₁ ⊢) <;>
    (try nlinarith)
  have h₃ : (q : ℚ) ^ 2 ≠ 2 := by
    intro h₄
    have h₅ : (q : ℚ) ^ 2 % 4 = 0 ∨ (q : ℚ) ^ 2 % 4 = 1 := by
      have h₆ : (q : ℚ) % 4 = 0 ∨ (q : ℚ) % 4 = 1 ∨ (q : ℚ) % 4 = 2
