              (try simp_all [Set.mem_singleton_iff]) <;>
              (try aesop)
            -- Therefore, x is in the union of all singleton sets of rationals.
            exact Set.mem_iUnion.mpr ⟨q, h₁₀⟩
          -- Contradiction arises as x cannot be in the union if hx holds.
          simp_all [hx]
          <;>
