namespace ItaLean

section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  exact h.map f

def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : F.map (t ∘ s) ≤ H := by
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        simp [Function.comp, map_map]
      _ ≤ G.map t := by
        -- Use the fact that `hs : Tendsto s F G` implies `F.map s ≤ G`
        apply hs.map
      _ = G.map t := rfl
      _ ≤ H := ht
  exact h1

example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h : Tendsto (g ∘ f) (𝓝 0) atTop := Tendsto_comp hf hg
  exact h

example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  have h : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := Tendsto_comp ha hφ
  exact h

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : {x | p x ∧ q x} ∈ 𝓝 x := by
    have h1 : {x | p x} ∈ 𝓝 x := hT
    have h2 : {x | q x} ∈ 𝓝 x := hS
    have h3 : {x | p x ∧ q x} = {x | p x} ∩ {x | q x} := by
      ext x
      simp [and_imp]
      <;> tauto
    rw [h3]
    exact h1.inf h2
  have h2 : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    have h1 : {x | p' x} ∈ 𝓝 x := hT'
    have h2 : {x | q' x} ∈ 𝓝 x := hS'
    have h3 : {x | p' x ∧ q' x} = {x | p' x} ∩ {x | q' x} := by
      ext x
      simp [and_imp]
      <;> tauto
    rw [h3]
    exact h1.inf h2
  have h3 : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
    ext x
    simp [or_imp]
    <;> tauto
  rw [h3]
  exact h1.sup h2

end Filter

