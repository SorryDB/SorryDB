example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h1 : {x : α | p x ∧ q x} ∈ 𝓝 x := by
    -- Use the fact that the intersection of two neighborhoods is a neighborhood
    have h1 : {x : α | p x} ∩ {x : α | q x} ∈ 𝓝 x := by
      -- The intersection of two neighborhoods is a neighborhood
      have h2 : {x : α | p x} ∈ 𝓝 x := hT
      have h3 : {x : α | q x} ∈ 𝓝 x := hS
      exact Filter.inter_mem h2 h3
    -- The set {x : α | p x ∧ q x} is the same as the intersection
    have h4 : {x : α | p x ∧ q x} = {x : α | p x} ∩ {x : α | q x} := by
      ext x
      simp [and_imp]
      <;> tauto
    rw [h4] at *
    exact h1
  have h2 : {x : α | p' x ∧ q' x} ∈ 𝓝 x := by
    -- Use the fact that the intersection of two neighborhoods is a neighborhood
    have h1 : {x : α | p' x} ∩ {x : α | q' x} ∈ 𝓝 x := by
      -- The intersection of two neighborhoods is a neighborhood
      have h2 : {x : α | p' x} ∈ 𝓝 x := hT'
      have h3 : {x : α | q' x} ∈ 𝓝 x := hS'
      exact Filter.inter_mem h2 h3
    -- The set {x : α | p' x ∧ q' x} is the same as the intersection
    have h4 : {x : α | p' x ∧ q' x} = {x : α | p' x} ∩ {x : α | q' x} := by
      ext x
      simp [and_imp]
      <;> tauto
    rw [h4] at *
    exact h1
  -- Use the fact that the union of two neighborhoods is a neighborhood
  have h3 : {x : α | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
    have h4 : {x : α | p x ∧ q x} ∈ 𝓝 x := h1
    have h5 : {x : α | p' x ∧ q' x} ∈ 𝓝 x := h2
    have h6 : {x : α | p x ∧ q x ∨ p' x ∧ q' x} = {x : α | p x ∧ q x} ∪ {x : α | p' x ∧ q' x} := by
      ext x
      simp [or_imp]
      <;> tauto
    rw [h6]
    -- The union of two neighborhoods is a neighborhood
    exact Filter.union_mem h4 h5
  exact h3

end Filter

