          simp_all [Function.comp] <;>
          aesop
        })
      }) <;>
    (try {
      aesop
    }) <;>
    (try {
      tauto
    }) <;>
    (try {
      simp_all [Function.comp] <;>
      aesop
    })
  have h2 : (F.map s).map t ≤ H := by
    calc
