/-
# Filters
-/



section Filter

open Filter Topology
variable {α β γ : Type*}

lemma mono (f : α → β) {F G : Filter α} (h : F ≤ G) : F.map f ≤ G.map f := by
  intro s hs
  exact h hs

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : α → β) (F : Filter α) (G : Filter β) := F.map f ≤ G

lemma Tendsto_comp {s : α → β} {t : β → γ} {F : Filter α} {G : Filter β} {H : Filter γ}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ∘ s) F H := by
  have h1 : F.map (t ∘ s) ≤ G.map t := by
    calc
      F.map (t ∘ s) = (F.map s).map t := by
        ext s
        simp [Filter.map_map]
        <;> congr 1 <;> ext <;> simp [Function.comp_apply]
      _ ≤ G.map t := by
        apply Filter.map_mono
        exact hs
  calc
    F.map (t ∘ s) ≤ G.map t := h1
    _ ≤ H := ht


example (f g : ℝ → ℝ) (hf : Tendsto f (𝓝 0) (𝓝 Real.pi))
    (hg : Tendsto g (𝓝 Real.pi) atTop) : Tendsto (g ∘ f) (𝓝 0) atTop := by
  have h1 : Tendsto (g ∘ f) (𝓝 0) atTop := by
    calc
      Tendsto (g ∘ f) (𝓝 0) atTop := by
        -- Apply the composition property of tendsto to `f` and `g`
        have h2 : Tendsto f (𝓝 0) (𝓝 Real.pi) := hf
        have h3 : Tendsto g (𝓝 Real.pi) atTop := hg
        -- Use the composition of tendsto to get the desired result
        exact Tendsto_comp h2 h3
      _ = Tendsto (g ∘ f) (𝓝 0) atTop := by rfl
  exact h1


example (a : ℕ → ℝ) (φ : ℝ → ℂ) (ha : Tendsto a atTop (𝓝 (-1)))
    (hφ : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I))) : Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
  calc
    Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by
      -- Use the composition of tendsto to get the desired result
      have h1 : Tendsto a atTop (𝓝 (-1)) := ha
      have h2 : Tendsto φ (𝓝 (-1)) (𝓝 (Complex.I)) := hφ
      -- Use the composition of tendsto to get the desired result
      exact Tendsto_comp h1 h2
    _ = Tendsto (φ ∘ a) atTop (𝓝 (Complex.I)) := by rfl


/-
`filter_upwards [h₁, ⋯, hₙ]` replaces a goal of the form `s ∈ f` and terms
`h₁ : t₁ ∈ f, ⋯, hₙ : tₙ ∈ f` with `∀ x, x ∈ t₁ → ⋯ → x ∈ tₙ → x ∈ s`.
The list is an optional parameter, `[]` being its default value.

`filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ` is a short form for
`{ filter_upwards [h₁, ⋯, hₙ], intro a₁ a₂ ⋯ aₖ }`.

`filter_upwards [h₁, ⋯, hₙ] using e` is a short form for
`{ filter_upwards [h1, ⋯, hn], exact e }`.

Combining both shortcuts is done by writing `filter_upwards [h₁, ⋯, hₙ] with a₁ a₂ ⋯ aₖ using e`.
Note that in this case, the `aᵢ` terms can be used in `e`.
-/

example [TopologicalSpace α] {x : α} {p p' q q' : α → Prop}
    (hT : {x | p x} ∈ 𝓝 x)
    (hT' : {x | p' x} ∈ 𝓝 x)
    (hS : {x | q x} ∈ 𝓝 x)
    (hS' : {x | q' x} ∈ 𝓝 x) :
    {x | p x ∧ q x ∨ p' x ∧ q' x} ∈ 𝓝 x := by
  have h₁ : {x | p x ∧ q x} ∈ 𝓝 x := by
    have h₂ : {x | p x} ∩ {x | q x} ∈ 𝓝 x := by
      -- The intersection of two neighborhoods is a neighborhood.
      have h₃ : {x | p x} ∈ 𝓝 x := hT
      have h₄ : {x | q x} ∈ 𝓝 x := hS
      exact h₃.inter h₄
    -- The set {x | p x ∧ q x} is the same as {x | p x} ∩ {x | q x}.
    have h₅ : {x | p x ∧ q x} = {x | p x} ∩ {x | q x} := by
      ext x
      simp [and_comm]
      <;> tauto
    rw [h₅]
    exact h₂
  have h₂ : {x | p' x ∧ q' x} ∈ 𝓝 x := by
    have h₃ : {x | p' x} ∩ {x | q' x} ∈ 𝓝 x := by
      -- The intersection of two neighborhoods is a neighborhood.
      have h₄ : {x | p' x} ∈ 𝓝 x := hT'
      have h₅ : {x | q' x} ∈ 𝓝 x := hS'
      exact h₄.inter h₅
    -- The set {x | p' x ∧ q' x} is the same as {x | p' x} ∩ {x | q' x}.
    have h₆ : {x | p' x ∧ q' x} = {x | p' x} ∩ {x | q' x} := by
      ext x
      simp [and_comm]
      <;> tauto
    rw [h₆]
    exact h₃
  -- The union of two neighborhoods is a neighborhood.
  have h₃ : {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} ∈ 𝓝 x := by
    have h₄ : {x | p x ∧ q x} ∈ 𝓝 x := h₁
    have h₅ : {x | p' x ∧ q' x} ∈ 𝓝 x := h₂
    exact h₄.union h₅
  -- The set {x | p x ∧ q x ∨ p' x ∧ q' x} is the same as {x | p x ∧ q x} ∪ {x | p' x ∧ q' x}.
  have h₄ : {x | p x ∧ q x ∨ p' x ∧ q' x} = {x | p x ∧ q x} ∪ {x | p' x ∧ q' x} := by
    ext x
    simp [or_comm]
    <;> tauto
  rw [h₄]
  exact h₃


end Filter

