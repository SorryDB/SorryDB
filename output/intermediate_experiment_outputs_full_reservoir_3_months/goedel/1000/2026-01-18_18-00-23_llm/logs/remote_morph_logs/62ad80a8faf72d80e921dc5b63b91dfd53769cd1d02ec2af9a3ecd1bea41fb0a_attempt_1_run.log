      _ ≤ G.map t := by
        -- Since F.map s ≤ G, we can use the fact that the map operation preserves the order
        exact Filter.map_mono hs
      _ ≤ H := by
        -- Since G.map t ≤ H, we can directly use this fact
        exact ht
  calc
    F.map (t ∘ s) = (F.map s).map t := by rw [h1]
    _ ≤ H := h2

