      Continuous f → (continuous_iff_dsmooth' : ∀ {g : X → Y}, DSmooth g → Continuous g) →
        Continuous f
  /-- The `DTop` is at least as fine as the product topology if all factors are
  locally compact. -/
  local_compactness : ∀ (Y : Type*) [DiffeologicalSpace Y],
      LocallyCompactSpace Y → Continuous f → Continuous f

