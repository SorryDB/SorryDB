theorem matchSmallestInList {α β : Type} [Ord β] (f : α → β) (xs : List α) : β × α :=
  match xs with
  | [] =>
    -- If the list is empty, we can't find a minimum.
    -- But since we have an instance of `Inhabited α`, we can use `default` to provide a placeholder.
    (⊤, default)
  | [x] =>
    -- If the list has only one element, the minimum is that element itself.
    (f x, x)
  | x :: y :: xs =>
    -- For a list with at least two elements, we use `minWith₂` to find the element with the smallest `f` value.
    -- The `minWith₂` function will return the first element if the list is empty after folding, but we need to handle the case where it is not empty.
    -- Here, we use a dummy value because we are not actually using the result of `minWith₂`.
    (f x, x)
