section

/- There are special cases of the change of variables theorems for affine transformations
(but you can also use the change of variable theorem from the lecture) -/
example (a b : ℝ) :
    ∫ x in a..b, sin (x / 2 + 3) =
    2 * cos (a / 2 + 3) - 2 * cos (b / 2  + 3) := by
  have h₁ : ∫ x in a..b, sin (x / 2 + 3) = 2 * (cos (a / 2 + 3) - cos (b / 2 + 3)) := by
    have h₂ : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in a..b, sin (x / 2 + 3) := rfl
    rw [h₂]
    -- Use the change of variables theorem to simplify the integral
    have h₃ : ∫ x in a..b, sin (x / 2 + 3) = 2 * (cos (a / 2 + 3) - cos (b / 2 + 3)) := by
      have h₄ : ∫ x in a..b, sin (x / 2 + 3) = ∫ x in a..b, sin (x / 2 + 3) := rfl
      rw [h₄]
      -- Use the fundamental theorem of calculus to evaluate the integral
      have h₅ : ∫ x in a..b, sin (x / 2 + 3) = 2 * (cos (a / 2 + 3) - cos (b / 2 + 3)) := by
        rw [intervalIntegral.integral_comp_add_right (fun x => sin (x / 2))]
        <;> simp [cos_add, sin_add]
        <;> ring_nf
        <;> norm_num
        <;>
          (try
            {
              rw [intervalIntegral.integral_comp_mul_left (fun x => sin x)]
              <;> simp [cos_add, sin_add]
              <;> ring_nf
              <;> norm_num
              <;> field_simp
              <;> ring_nf
              <;> norm_num
            })
        <;>
          (try
            {
              rw [intervalIntegral.integral_comp_add_right (fun x => sin x)]
              <;> simp [cos_add, sin_add]
              <;> ring_nf
              <;> norm_num
            })
        <;>
          (try
            {
              rw [intervalIntegral.integral_comp_mul_left (fun x => sin x)]
              <;> simp [cos_add, sin_add]
              <;> ring_nf
              <;> norm_num
            })
