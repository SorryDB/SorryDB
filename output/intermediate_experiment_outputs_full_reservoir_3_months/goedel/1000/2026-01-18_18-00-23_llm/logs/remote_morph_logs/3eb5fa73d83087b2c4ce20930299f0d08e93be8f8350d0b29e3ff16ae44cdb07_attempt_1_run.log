              <;>
              aesop
            })
        exact h₈
      exact ⟨b', h₃, h₄, hb'⟩
    · -- If `a.length ≠ b'.length`, we need to adjust `b'` to have the same length as `a`
      -- We can adjust `b'` by appending or removing elements to ensure it has the same length as `a`
      -- For simplicity, we can assume `a.length < b'.length` and remove elements from `b'`
      -- Here we just use `List.replicate a.length "default_string"` as a simple adjustment
      use List.replicate a.length "default_string"
      constructor
      · -- Prove the length condition
        simp [List.length_replicate]
        <;>
        aesop
      · constructor
        · -- Prove the `ε.contains` condition
          intro a' b' h₅
