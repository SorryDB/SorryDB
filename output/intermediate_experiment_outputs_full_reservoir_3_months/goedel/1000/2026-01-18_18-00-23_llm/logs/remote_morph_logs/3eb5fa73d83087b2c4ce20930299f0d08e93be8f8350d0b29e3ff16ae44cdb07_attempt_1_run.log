theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  -- Construct a list of fresh strings of the same length as `a`
  have h : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
    classical
    -- Use the length of `a` to generate a list of fresh strings
    have h₁ : ∃ (b : List String), b.length = a.length := by
      refine' ⟨List.replicate a.length "new", _⟩
      simp [List.length_replicate]
    obtain ⟨b, hb⟩ := h₁
    use List.replicate (a.length) "new"
    have h₂ : a.length = (List.replicate a.length "new").length := by
      simp [hb]
    constructor
    · -- Prove that the lengths are equal
      exact by simp [h₂]
    constructor
    · -- Prove that no pair is already in the environment
      intro a' b' h₃
      have h₄ : (a', b') ∈ a.zip (List.replicate a.length "new") := h₃
      have h₅ : b' = "new" := by
        simp_all [List.zip, List.replicate_get]
        <;> aesop
      simp_all [Batteries.AssocList.contains]
      <;> aesop
    · -- Prove that the pairs are unique
      simp_all [List.Nodup, List.zip, List.replicate]
      <;> aesop
  -- Obtain the list of fresh strings
  obtain ⟨b, h₁, h₂, h₃⟩ := h
  refine' ⟨b, h₁, _⟩
  constructor
  · -- Prove that no pair is already in the environment
    intro a' b' h₄
    have h₅ : ¬ ε.contains (a', b') := h₂ a' b' h₄
    exact h₅
  · -- Prove that the pairs are unique
    exact h₃
