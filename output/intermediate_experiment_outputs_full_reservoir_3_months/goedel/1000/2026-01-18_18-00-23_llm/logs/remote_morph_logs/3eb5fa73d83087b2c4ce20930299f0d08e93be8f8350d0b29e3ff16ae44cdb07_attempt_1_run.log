    -- Generate b' by appending a with fresh identifiers to ensure a.zip b' is nodup
    have : ∃ (b : List String), (a.zip b).Nodup := by
      -- We can choose `b` to be a list of fresh strings, ensuring no duplicates in `a.zip b`
      use List.map (fun _ => Ident.fresh) a
