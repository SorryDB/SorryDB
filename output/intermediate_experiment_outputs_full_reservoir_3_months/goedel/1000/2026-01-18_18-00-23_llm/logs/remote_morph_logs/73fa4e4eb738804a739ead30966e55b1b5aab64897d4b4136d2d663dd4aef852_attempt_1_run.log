lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by 
  intro h
  have h₁ : S.EquationOfMotion x := h.1
  have h₂ : x 0 = IC.x₀ := h.2.1
  have h₃ : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h₄ : x = InitialConditions.trajectory S IC := by
    apply Eq.symm
    apply Eq.symm
    -- Use the uniqueness of solutions to the ODE to conclude that x must be the trajectory defined by the initial conditions.
    -- This step relies on the fact that the solution to the ODE is unique given the initial conditions.
