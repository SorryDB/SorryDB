  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  intro dt
  have h : ∀ (t : G.DerivationTree), t/result.length = t.collectLeaves'.length := by
    intro t
    induction t using G.DerivationTree.strong_induction_on with
