def has_unary_digits {a : α} : ∀ (n : ℕ), ∀ (k : ℕ), (n % k) = k - 1 → a ≤ a ^ n := by
  intro n k h
  have h₁ : a ≤ a ^ n := by
    by_cases h₂ : a = ⊥
    · simp_all [h₂, pow_one]
      <;>
      (try decide) <;>
      (try simp_all [lt_irrefl]) <;>
      (try omega)
    · have h₃ : a ≤ a ^ n := by
        calc
          a = a ^ 1 := by simp [pow_one]
          _ ≤ a ^ n := by
            exact pow_le_pow_right (by
              cases' le_total a (⊤ : α) with h₄ h₄ <;> simp_all
              <;>
              (try omega) <;>
              (try simp_all [lt_irrefl]) <;>
              (try decide)
              ) (by
                by_cases h₅ : n = 0
                · simp_all
                  <;>
                  (try omega)
                · have h₆ : 1 ≤ n := by omega
                  omega
              )
      exact h₃
  exact h₁

def is_prime_modulo_k {k : ℕ} (n : ℕ) : Prop := by
  (n % k) = (n / k)

def digits_of_modulo_k (n : ℕ) (k : ℕ) : List ℕ := by
  if n = 0 then [0]
  else if k ≤ 1 then
    if n ≥ 1 then [n] else []
  else
    have h₁ : n % k < k := Nat.mod_lt n (by omega)
    have h₂ : n / k < n := by
      apply Nat.div_lt_self
      · omega
      · omega
    (digits_of_modulo_k (n / k) k) ++ [n % k]

def is_binary (n : ℕ) : Bool := by
  if n = 0 then false
  else if n = 1 then true
  else
    let m := (n : ℕ) % 2
    if m = 0 then false else true

def is_binary2 (n : ℕ) : Bool := by
  if n = 0 then false
  else if n = 1 then true
  else
    let m := (n : ℕ) % 2
    if m = 0 then false else true

example : True := by trivial
``` 

