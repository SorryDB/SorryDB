theorem derivation_result_is_leaf_count :
  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  intro dt
  have h : ∀ (dt : G.DerivationTree), dt.result.len = dt.collectLeaves'.length := by
    intro dt
    -- Induction on the derivation tree
    have h₁ : ∀ (dt : G.DerivationTree), dt.result.len = dt.collectLeaves'.length := by
      intro dt
      -- Use the appropriate induction principle for the derivation tree
      induction dt using ContextFreeGrammar.DerivationTree.strong_induction_on with
      | ht dt ih =>
        -- Handle the case when the node has no children
        cases dt with
        | terminal _ z =>
          -- Base case: the tree is a single terminal node
          simp [ContextFreeGrammar.DerivationTree.terminal, List.length, Word.length]
        | unary _ n =>
          -- Case: the tree is a unary node
          simp_all [ContextFreeGrammar.DerivationTree.unary, List.length]
          <;>
          (try simp_all [List.length, Word.length]) <;>
          (try linarith) <;>
          (try induction n <;> simp_all [List.length, Nat.succ_eq_add_one]) <;>
          (try simp_all [List.length, Nat.succ_eq_add_one]) <;>
          (try linarith)
          <;>
          (try simp_all [List.length, Nat.succ_eq_add_one]) <;>
          (try linarith)
        | binary _ n =>
          -- Case: the tree is a binary node
          simp_all [ContextFreeGrammar.DerivationTree.binary, List.length, List.append]
          <;>
          (try simp_all [List.length, Word.length]) <;>
          (try linarith) <;>
          (try induction n <;> simp_all [List.length, Nat.succ_eq_add_one]) <;>
