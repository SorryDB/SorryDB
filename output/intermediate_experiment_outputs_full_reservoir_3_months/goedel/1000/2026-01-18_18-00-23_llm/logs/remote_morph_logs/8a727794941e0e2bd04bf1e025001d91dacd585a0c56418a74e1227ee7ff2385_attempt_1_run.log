theorem derivation_result_is_leaf_count :
  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  intro dt
  have h₁ : ∀ (dt : ContextFreeGrammar.DerivationTree G), Word.len dt.result = dt.collectLeaves'.length := by
    intro dt
    induction dt with
    | mk production innerTree =>
      cases production with
      | term t =>
        simp [G.DerivationTree.collectLeaves']
        <;>
        simp_all [G.DerivationTree.result]
        <;>
        norm_num
      | apply A rule children =>
        simp [G.DerivationTree.collectLeaves', List.length]
        <;>
        simp_all [G.DerivationTree.result, List.length]
        <;>
        norm_num
        <;>
        rfl
  exact h₁ dt
