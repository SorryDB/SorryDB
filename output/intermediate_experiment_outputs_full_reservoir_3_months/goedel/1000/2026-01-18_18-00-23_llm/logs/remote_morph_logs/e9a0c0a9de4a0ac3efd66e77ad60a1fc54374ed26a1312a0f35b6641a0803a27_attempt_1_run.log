  -- From h₂, (a * b + 1) ∣ (a² + b²), so (a² + b²) / (a * b + 1) is a natural number
  -- Let x be this quotient; then x² = x² in ℝ
  
  have h₅ : ∃ x : ℕ, (x : ℕ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
    refine' ⟨(a ^ 2 + b ^ 2) / (a * b + 1), _⟩
    <;> simp [h₃]
  
