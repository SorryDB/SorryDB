        rw [h₈]
      _ = (k : ℝ) ^ 2 := by rfl
      _ = ((a : ℝ) ^ 2 + (b : ℝ) ^ 2) / ((a : ℝ) * (b : ℝ) + 1) := by
        have h₁₀ : (k : ℝ) = ((a : ℝ) ^ 2 + (b : ℝ) ^ 2) / ((a : ℝ) * (b : ℝ) + 1) := by
          exact h₆
        rw [h₁₀]
        <;> field_simp [h₅.ne']
        <;> ring_nf
        <;>
        (try simp_all [pow_two]) <;>
        (try nlinarith) <;>
