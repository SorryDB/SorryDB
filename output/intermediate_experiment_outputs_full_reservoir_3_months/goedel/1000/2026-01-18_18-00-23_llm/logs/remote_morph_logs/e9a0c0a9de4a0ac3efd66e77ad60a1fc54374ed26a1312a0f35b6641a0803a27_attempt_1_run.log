  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  have h₂ : ∃ (k : ℕ), a ^ 2 + b ^ 2 = (a * b + 1) * k := by
    obtain ⟨k, hk⟩ := h₁
