          h₈.integrableOn_closure_of_subset (φ.support_subset_val)
        exact h₉
      have h₁₀ : ContinuousOn (fun x : E => φ x) (closure φ.support : Set E) := by
        exact φ.continuousOn.mono (closure_subset_iff.mpr (by simp [hφ]))
      have h₁₁ : IntegrableOn (fun x : E => φ x • f x) (closure φ.support) μ := by
        -- Use the fact that the product of a continuous function and an integrable function is integrable
        refine' (IntegrableOn.mul_right (φ.support : Set E) _).mono (by
          -- Show that the closure of the support is a subset of the support union its boundary
