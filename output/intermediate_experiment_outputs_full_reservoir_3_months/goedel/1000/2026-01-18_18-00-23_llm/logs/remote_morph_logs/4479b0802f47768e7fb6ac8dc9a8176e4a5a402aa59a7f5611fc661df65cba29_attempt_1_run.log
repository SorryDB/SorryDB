        have h₄ : Closure (φ.support : Set E) ⊆ Ω := by
          have h₅ : φ.support ⊆ Ω := φ.support_subset_val
          have h₆ : closure (φ.support : Set E) ⊆ closure (Ω : Set E) := closure_mono h₅
          have h₇ : closure (Ω : Set E) = Ω := by
            apply closure_eq_iff_isClosed.mpr
            exact (isOpen_Ω).isClosed_compl.isClosed_compl
          rw [h₇] at h₆
          exact h₆
        have h₈ : LocallyIntegrableOn f Ω μ := hf
