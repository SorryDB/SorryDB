  have h₁ : Fintype.card (U k) = Fintype.card (T k) := by
    -- Define a bijection between T and U
    classical
    have h₂ : T k ≃ U k := by
      -- Construct the equivalence
      let f : T k → U k := fun ⟨⟨x, y, z⟩, h⟩ =>
        ⟨⟨y, x, -z⟩, by
          -- Prove that (y, x, -z) is in U k
