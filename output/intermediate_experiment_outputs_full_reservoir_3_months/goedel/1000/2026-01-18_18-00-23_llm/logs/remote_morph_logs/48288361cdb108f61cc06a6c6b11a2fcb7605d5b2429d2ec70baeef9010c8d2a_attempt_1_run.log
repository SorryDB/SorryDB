  -- We say `ρ` is *automorphic* if there's a quaternion algebra D over F of discriminant 1
  ∃ (D : Type u) (_ : Ring D) (_ : Algebra F D) (_ : IsQuaternionAlgebra F D)
    (r : IsQuaternionAlgebra.NumberField.Rigidification F D)
  -- and an `A`-valued automorphic eigenform,
  -- by which we mean a ℤ_p-linear map from the ℤ_p-Hecke algebra for (D,S) to `A`,
    (π : HeckeAlgebra F D r S ℤ_[p] →ₐ[ℤ_[p]] A),
  -- such that for all good primes `v` of `F`
  ∀ (v : HeightOneSpectrum (𝓞 F)) (_hvp : ↑p ∉ v.1) (hvS : v ∉ S),
    -- `ρ` is unramified at `v`,
    ρ.IsUnramifiedAt v ∧
    -- the det of `ρ(Frobᵥ)` (arithmetic Frobenius) is `N(v)` (i.e. `det(ρ) = cyclo`)
    (ρ.toLocal v (Frob v)).det = v.1.absNorm ∧
    -- and the trace of `ρ(Frobᵥ)` is the eigenvalue of the form at `Tᵥ`
    LinearMap.trace A V (ρ.toLocal v (Frob v)) = π (HeckeAlgebra.T D r ℤ_[p] v hvS)

instance {F E D : Type*}
    [Field F]
    [Field E] [Algebra F E]
    [Ring D] [Algebra F D] [IsQuaternionAlgebra F D] :
    IsQuaternionAlgebra E (E ⊗[F] D) := by
  haveI : Algebra F E := by infer_instance
  haveI : Algebra F D := by infer_instance
  haveI : IsQuaternionAlgebra F D := by infer_instance
  -- We use the fact that the tensor product of a quaternion algebra with a field extension is again a quaternion algebra.
  -- Specifically, we use the property that the basis elements of the quaternion algebra remain linearly independent over the field extension.
  -- We can also directly construct the quaternion algebra over E using the basis elements of D.
  have h : IsQuaternionAlgebra E (E ⊗[F] D) := by
    -- Use the property of quaternion algebras under field extensions
    have h₁ : IsQuaternionAlgebra F D := by infer_instance
    -- Construct the quaternion algebra over E using the basis elements of D
