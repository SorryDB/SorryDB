    (DifferentiableAt 𝕜 f x → d = deriv f x) →
    (d = deriv f x → DifferentiableAt 𝕜 f x) →
    (DifferentiableAt 𝕜 f x ↔ d = deriv f x) := by
  intro h_forward h_backward
  have h_iff : DifferentiableAt 𝕜 f x ↔ d = deriv f x := by
    constructor
    · -- Prove the forward direction: if DifferentiableAt 𝕜 f x, then d = deriv f x
      intro h
      exact h_forward h
    · -- Prove the backward direction: if d = deriv f x, then DifferentiableAt 𝕜 f x
      intro h
      exact h_backward h
  exact h_iff
```

