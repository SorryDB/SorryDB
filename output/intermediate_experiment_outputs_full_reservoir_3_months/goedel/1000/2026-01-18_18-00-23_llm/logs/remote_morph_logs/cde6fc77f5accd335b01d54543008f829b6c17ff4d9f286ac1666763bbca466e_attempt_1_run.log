      singleHash siblingBelowRootHash ancestorBelowRootHash

def getPutativeRoot_with_hash {s} (idx : BinaryTree.SkeletonLeafIndex s) (leafValue : α) (proof : List α) (hashFn : α → α → α) : α :=
  match proof with
  | [] => leafValue
  | siblingBelowRootHash :: restProof =>
