@[grind .]
theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  induction l with
  | nil =>
    simp [smaller, larger, List.count]
  | cons y ys ih =>
    simp_all [smaller, larger, List.count, List.filter_cons_of_pos, List.filter_cons_of_neg,
      List.mem_cons, Nat.add_assoc]
    <;>
    (try {
      cases' le_or_lt x pivot with h h <;>
      cases' le_or_lt y pivot with h' h' <;>
      cases' le_or_lt x y with h'' h'' <;>
      simp_all [h, h', h''] <;>
      (try { nlinarith }) <;>
      (try { aesop })
    }) <;>
    (try {
      nlinarith
    }) <;>
    (try {
      ring_nf at *
      <;> omega
    }) <;>
    (try {
      aesop
    })
