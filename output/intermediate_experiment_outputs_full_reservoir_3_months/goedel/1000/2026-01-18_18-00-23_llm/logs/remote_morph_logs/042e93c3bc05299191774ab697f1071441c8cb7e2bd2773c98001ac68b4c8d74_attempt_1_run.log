      have h₃ : l.count x = (l.filter (fun a => a ≤ pivot) ++ l.filter (fun a => ¬a ≤ pivot)).count x := by
        have h₄ : l.filter (fun a => a ≤ pivot) ++ l.filter (fun a => ¬a ≤ pivot) = l := by
