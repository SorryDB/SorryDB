```lean
@[grind .]
theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h : (l.count x) = ((smaller pivot l) ++ (larger pivot l)).count x := by
    have h₁ : l = (smaller pivot l) ++ (larger pivot l) := by
      have h₂ : l = ((l.filter (fun x => x ≤ pivot)) ++ (l.filter (fun x => pivot < x))) := by
        have h₃ : l = (l.filter (fun x => x ≤ pivot) ++ l.filter (fun x => ¬x ≤ pivot)) := by
          rw [← List.filter_add_filter_not l (fun x => x ≤ pivot)]
        have h₄ : l.filter (fun x => ¬x ≤ pivot) = l.filter (fun x => pivot < x) := by
          congr
          funext a
          simp [not_le]
          <;>
          by_cases h₅ : a ≤ pivot <;> simp_all [h₅]
          <;>
          (try { contrapose! h₅ <;> linarith })
          <;>
          (try { linarith })
        rw [h₃, h₄]
      rw [h₂]
      <;> simp [smaller, larger]
    rw [h₁]
    <;>
    simp [List.count_append]
  have h₂ : ((smaller pivot l) ++ (larger pivot l)).count x = (smaller pivot l).count x + (larger pivot l).count x := by
    simp [List.count_append]
  rw [h]
  rw [h₂]
