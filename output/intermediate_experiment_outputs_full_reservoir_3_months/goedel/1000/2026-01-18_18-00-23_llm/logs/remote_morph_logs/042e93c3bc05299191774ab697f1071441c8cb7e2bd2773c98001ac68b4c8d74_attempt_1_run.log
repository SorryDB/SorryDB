theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h₁ : l.count x = ((smaller pivot l) ++ larger pivot l).count x := by
    have h₂ : l = (smaller pivot l) ++ larger pivot l := by
      apply Eq.symm
      apply Eq.symm
      have h₃ : l = (smaller pivot l) ++ larger pivot l := by
        calc
          l = l.filter (fun x => x ≤ pivot) ++ l.filter (fun x => pivot < x) := by
            -- We use the fact that the list is partitioned into elements ≤ pivot and > pivot.
            have h₄ : l.filter (fun x => x ≤ pivot) ++ l.filter (fun x => pivot < x) = l := by
              apply List.ext_get
              <;> simp_all [smaller, larger, List.get?, List.mem_filter]
              <;>
                (try decide) <;>
                (try {
                  cases' le_or_lt (l.get ⟨i, by omega⟩) pivot with h h <;>
                    simp_all [h]
                  <;>
                    (try omega) <;>
                    (try decide)
                }) <;>
                (try {
                  omega
                })
            rw [h₄]
          _ = (smaller pivot l) ++ larger pivot l := by
            -- Simplify the expressions using the definitions of smaller and larger.
            simp [smaller, larger]
      exact h₃
    rw [h₂]
    <;> simp [List.count_append]
  have h₂ : ((smaller pivot l) ++ larger pivot l).count x = (smaller pivot l).count x + (larger pivot l).count x := by
    simp [List.count_append]
  linarith
