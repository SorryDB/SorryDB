@[grind .]
theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  have h : ∀ (l : List α), l.count x = (l.filter (fun x_1 => x_1 ≤ pivot)).count x + (l.filter (fun x_1 => pivot < x_1)).count x := by
    intro l
    have h₁ : l.count x = (l.filter (fun x_1 => x_1 ≤ pivot)).count x + (l.filter (fun x_1 => pivot < x_1)).count x := by
      have h₂ : l.count x = (l.filter (fun x_1 => x_1 ≤ pivot)).count x + (l.filter (fun x_1 => ¬ x_1 ≤ pivot)).count x := by
        have h₃ : (l.filter (fun x_1 => x_1 ≤ pivot)).count x + (l.filter (fun x_1 => ¬ x_1 ≤ pivot)).count x = l.count x := by
          calc
            (l.filter (fun x_1 => x_1 ≤ pivot)).count x + (l.filter (fun x_1 => ¬ x_1 ≤ pivot)).count x = (l.filter (fun x_1 => x_1 ≤ pivot)).count x + (l.filter (fun x_1 => ¬ x_1 ≤ pivot)).count x := rfl
            _ = l.count x := by
              classical
              rw [← count_add_count_of_filter_neg l x (fun x_1 => x_1 ≤ pivot)]
              <;> simp [not_le]
        linarith
      have h₃ : (l.filter (fun x_1 => ¬ x_1 ≤ pivot)).count x = (l.filter (fun x_1 => pivot < x_1)).count x := by
        congr 1 <;> ext <;> simp (config := { contextual := true }) [not_le] <;>
          (try { cases l <;> simp_all [List.filter_cons, List.count_cons, List.count_eq_zero_of_not_mem] }) <;>
          (try { linarith }) <;>
          (try { omega })
      linarith
    exact h₁
  have h₁ := h l
  simp [smaller, larger] at h₁ ⊢
  <;>
  (try { linarith }) <;>
  (try { simp_all [List.count_cons, List.count_eq_zero_of_not_mem] }) <;>
  (try { ring }) <;>
  (try { omega }) <;>
  (try { linarith }) <;>
  (try { simp_all [List.count_cons, List.count_eq_zero_of_not_mem] })
