variable [FiniteDimensional ℝ E]

-- NOTE: these definitions will change (but not their type).
-- Essentially, using the fact that `E` is finite dimensional, you can put the `v : E`
-- argument wherever you want and keep continuity

-- TODO: where to put the minus ? Doesn't matter mathematically of course
noncomputable def fderivCLM :
    𝓓'(Ω, F) →L[ℝ] 𝓓'(Ω, E →L[ℝ] F) where
  toFun T :=
  { toFun f :=
    { toFun v := lineDerivCLM v T f
      map_add' := by
        intro v w
        simp [lineDerivCLM_apply]
        <;> simp_all [ContinuousLinearMap.map_add]
        <;> abel
      map_smul' := by
        intro v c
        simp [lineDerivCLM_apply]
        <;> simp_all [ContinuousLinearMap.map_smul]
        <;> abel
      cont := by
        have : FiniteDimensional ℝ E := inferInstance
        -- Prove that the linear derivative is continuous for any fixed v : E
        -- by composing with the continuous linear map as a function of v
        have h : ContinuousLinearMap.funLike (lineDerivCLM ?_) = (ContinuousLinearMap.id ℝ (𝓓'(Ω, F) →L[ℝ] 𝓓'(Ω, F)))
          := rfl
        simp_all [ContinuousLinearMap.continuous]
        <;>
        (try
          continuity)
        <;>
        (try
          simp_all [ContinuousLinearMap.continuous])
        <;>
        (try
          aesop)
        <;>
        (try
          exact inferInstance)
        <;>
        (try
          exact by
            simplicity
            <;>
            aesop)
   
