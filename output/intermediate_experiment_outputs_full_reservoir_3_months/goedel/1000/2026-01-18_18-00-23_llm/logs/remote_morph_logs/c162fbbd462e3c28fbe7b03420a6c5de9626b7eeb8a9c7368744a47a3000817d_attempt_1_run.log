      <;> simp [Prod.mk.injEq]
      <;> aesop
    have h‚āā : Pr[=y | (fun x1 x2 => (x1, x2)) <$> ($ŠĶó őĪ) <*> ($ŠĶó ő≤)] = Pr[=y.1 | ($ŠĶó őĪ)] * Pr[=y.2 | ($ŠĶó ő≤)] := by
      rw [probOutput_seq_map_prod_mk_eq_mul]
