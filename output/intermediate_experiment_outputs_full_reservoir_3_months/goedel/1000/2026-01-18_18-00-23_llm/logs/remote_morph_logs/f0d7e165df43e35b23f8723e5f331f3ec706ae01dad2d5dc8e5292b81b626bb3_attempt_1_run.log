cases I with
| mk carrier sSupIndep' sSup_eq_top' not_bot_mem' =>
  have h1 : ⨆ p ∈ carrier, p c = ⊤ := by
    have h2 : ⨆ p ∈ carrier, p c = (⨆ p ∈ carrier, p) c := by
      -- The supremum of the submodules at `c` is the same as the supremum of their images at `c`.
      simp [iSup_subtype]
      <;> congr 1 <;>
      ext p <;>
      simp [Membership.mem_iSup, Pi.le_def]
      <;>
      aesop
    rw [h2]
    -- The supremum of the carrier set is the entire module, so its image at `c` is the entire space.
    have h3 : (⨆ p ∈ carrier, p) = ⊤ := by
      simpa using sSup_eq_top'
    rw [h3]
    simp
  simpa using h1
