    simpa [directSum] using h₁
  })
  <;>
  (try {
    have h₂ : sSupIndep (SetLike.coe I) := I.sSupIndep'
    simpa [sSup_coe, SetLike.coe_sSup, directSum] using 
      (h₂ c)
  })
