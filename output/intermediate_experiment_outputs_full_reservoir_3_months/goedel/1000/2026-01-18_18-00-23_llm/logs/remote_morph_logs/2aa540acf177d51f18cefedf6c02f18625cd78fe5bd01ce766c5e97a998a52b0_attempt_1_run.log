    let W : WeierstrassCurve K := E.val
    have hвВБ : y ^ 2 + W.aвВБ * x * y + W.aвВГ * y = x ^ 3 + W.aвВВ * x ^ 2 + W.aвВД * x + W.aвВЖ := by
      have hвВВ := P.on_curve x y rfl
      simpa using hвВВ
    -- The negative of (x,y) is (x, -y - aвВБ*x - aвВГ)
    MordellWeilGroup.mk_point E x (-y - W.aвВБ * x - W.aвВГ) (by
      have hвВГ : (-y - W.aвВБ * x - W.aвВГ) ^ 2 + W.aвВБ * x * (-y - W.aвВБ * x - W.aвВГ) + W.aвВГ * (-y - W.aвВБ * x - W.aвВГ) = x ^ 3 + W.aвВВ * x ^ 2 + W.aвВД * x + W.aвВЖ := by
        calc
          (-y - W.aвВБ * x - W.aвВГ) ^ 2 + W.aвВБ * x * (-y - W.aвВБ * x - W.aвВГ) + W.aвВГ * (-y - W.aвВБ * x - W.aвВГ) =
