/-- Negation of a point on the elliptic curve -/
def MordellWeilGroup.neg (P : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point with
  | none => P  -- -вИЮ = вИЮ
  | some (x, y) =>
    -- The negative of (x,y) is (x, -y - aвВБ*x - aвВГ)
    MordellWeilGroup.mk_point E x (-y - E.val.aвВБ*x - E.val.aвВГ) (by
      dsimp only
