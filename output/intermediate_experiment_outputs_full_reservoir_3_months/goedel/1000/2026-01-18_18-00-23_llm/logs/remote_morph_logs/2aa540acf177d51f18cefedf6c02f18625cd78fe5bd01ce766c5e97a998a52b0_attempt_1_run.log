      have hвВБ : y^2 + E.val.aвВБ*x*y + E.val.aвВГ*y = x^3 + E.val.aвВВ*x^2 + E.val.aвВД*x + E.val.aвВЖ := by
        -- This is the original point lying on the curve
        have hвВВ := P.on_curve x y (by simp)
        simpa [E.val] using hвВВ
      -- Substitute y' = -y - aвВБ*x - aвВГ into the equation and verify it satisfies the Weierstrass form
      have hвВВ : (-y - E.val.aвВБ*x - E.val.aвВГ)^2 + E.val.aвВБ*x*(-y - E.val.aвВБ*x - E.val.aвВГ) + E.val.aвВГ*(-y - E.val.aвВБ*x - E.val.aвВГ) = x^3 + E.val.aвВВ*x^2 + E.val.aвВД*x + E.val.aвВЖ := by
        calc
          (-y - E.val.aвВБ*x - E.val.aвВГ)^2 + E.val.aвВБ*x*(-y - E.val.aвВБ*x - E.val.aвВГ) + E.val.aвВГ*(-y - E.val.aвВБ*x - E.val.aвВГ)
            = (y + E.val.aвВБ*x + E.val.aвВГ)^2 - E.val.aвВБ*x*(y + E.val.aвВБ*x + E.val.aвВГ) - E.val.aвВГ*(y + E.val.aвВБ*x + E.val.aвВГ) := by
              ring_nf
              <;> simp [add_comm, add_left_comm, add_assoc]
              <;> ring_nf
              <;> simp_all [add_comm, add_left_comm, add_assoc]
              <;> linarith
          _ = (y + E.val.aвВБ*x + E.val.aвВГ)*(y + E.val.aвВБ*x + E.val.aвВГ) - E.val.aвВБ*x*(y + E.val.aвВБ*x + E.val.aвВГ) - E.val.aвВГ*(y + E.val.aвВБ*x + E.val.aвВГ) := by ring
          _ = (y + E.val.aвВБ*x + E.val.aвВГ)*(y + E.val.aвВБ*x + E.val.aвВГ - E.val.aвВБ*x - E.val.aвВГ) := by ring
          _ = (y + E.val.aвВБ*x + E.val.aвВГ)*y := by ring
          _ = y*(y + E.val.aвВБ*x + E.val.aвВГ) := by ring
          _ = y^2 + E.val.aвВБ*x*y + E.val.aвВГ*y := by ring
          _ = x^3 + E.val.aвВВ*x^2 + E.val.aвВД*x + E.val.aвВЖ := by rw [hвВБ]
          _ = x^3 + E.val.aвВВ*x^2 + E.val.aвВД*x + E.val.aвВЖ := by ring
      -- Use the result to complete the proof
      simpa [E.val] using hвВВ
    )
