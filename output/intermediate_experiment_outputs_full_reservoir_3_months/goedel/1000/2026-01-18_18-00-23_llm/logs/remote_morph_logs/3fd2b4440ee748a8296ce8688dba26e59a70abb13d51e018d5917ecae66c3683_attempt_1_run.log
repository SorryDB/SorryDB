theorem Exercise_8_1_5_1 {U V : Type}
    (h : U ∼ V) : Set U ∼ Set V := by
  classical
  rcases h with ⟨f, g, hf, hg⟩
  refine ⟨fun s => {v : V | ∃ u ∈ s, f u = v}, fun t => {u : U | ∃ v ∈ t, g v = u}, _, _⟩
  · -- Prove that the composition of the two functions is the identity on subsets of U
    intro s
    ext u
    simp only [Set.mem_setOf_eq]
    <;>
    (try { aesop }) <;>
    (try {
      constructor <;> intro h <;>
      (try {
        aesop
      }) <;>
      (try {
        simp_all [hf, hg]
        <;> aesop
      })
    }) <;>
    (try {
      simp_all [hf, hg]
      <;> aesop
    })
    <;>
    aesop
  · -- Prove that the composition of the two functions is the identity on subsets of V
    intro t
    ext v
    simp only [Set.mem_setOf_eq]
    <;>
    (try { aesop }) <;>
    (try {
      constructor <;> intro h <;>
      (try {
        aesop
      }) <;>
      (try {
        simp_all [hf, hg]
        <;> aesop
      })
    }) <;>
    (try {
      simp_all [hf, hg]
      <;> aesop
    })
    <;>
    aesop

def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have h₁ : (x.val : U) ∈ val_image A X1 := by
    refine ⟨x, hx, rfl⟩
  have h₂ : (x.val : U) ∈ val_image A X2 := by
    rw [h] at h₁
    exact h₁
  rcases h₂ with ⟨y, hy, hy'⟩
  have h₃ : (y : U) = (x : U) := by
    simpa [Subtype.ext_iff] using hy'
  have h₄ : x = y := by
    apply Subtype.ext
    simpa using h₃
  rw [h₄] at hx
  exact hy

lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image U A) := fun X1 X2 h => by
  have h₁ : X1 ⊆ X2 := subset_of_val_image_eq h
  have h₂ : X2 ⊆ X1 := by
    have h₃ : val_image A X2 = val_image A X1 := by
      rw [h]
    have h₄ : subset_of_val_image_eq h₃
    exact h₄
  exact Set.Subset.antisymm h₁ h₂
