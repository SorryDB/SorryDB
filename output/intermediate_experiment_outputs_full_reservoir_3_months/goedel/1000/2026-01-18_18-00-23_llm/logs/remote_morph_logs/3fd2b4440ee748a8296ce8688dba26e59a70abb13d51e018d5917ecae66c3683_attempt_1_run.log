def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

```lean
lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X1 X2 h
  have h₁ : val_image A X1 = val_image A X2 := h
  have h₂ : X1 ⊆ X2 := by
    intro x hx
    have h₃ : (x : U) ∈ val_image A X1 := by
      refine' ⟨x, hx, _⟩
      <;> simp
    have h₄ : (x : U) ∈ val_image A X2 := by
      rw [h₁] at h₃
      exact h₃
    rcases h₄ with ⟨y, hy, h₅⟩
    have h₆ : (y : U) = (x : U) := by
      simp_all [Set.mem_setOf_eq]
      <;> aesop
    have h₇ : y = x := by
      cases y <;> simp_all [Subtype.ext_iff]
      <;> aesop
    rw [h₇] at hy
    exact hy
  have h₃ : X2 ⊆ X1 := by
    intro x hx
    have h₄ : (x : U) ∈ val_image A X2 := by
      refine' ⟨x, hx, _⟩
      <;> simp
    have h₅ : (x : U) ∈ val_image A X1 := by
      rw [h₁] at h₄
      exact h₄
    rcases h₅ with ⟨y, hy, h₆⟩
    have h₇ : (y : U) = (x : U) := by
      simp_all [Set.mem_setOf_eq]
      <;> aesop
    have h₈ : y = x := by
      cases y <;> simp_all [Subtype.ext_iff]
      <;> aesop
    rw [h₈] at hy
    exact hy
  exact Set.Subset.antisymm h₂ h₃
