```lean
def val_image {U : Type} (A : Set U) (X : Set A) : Set U :=
  {y : U | ∃ x ∈ X, x.val = y}

lemma val_image_one_one {U : Type} (A : Set U) :
    one_to_one (val_image A) := by
  intro X Y h
  have h₁ : ∀ (x : U), x ∈ val_image A X ↔ x ∈ val_image A Y := by
    intro x
    rw [h]
  intro x hx
  have h₂ : x.val ∈ val_image A X := by
    exact ⟨x, hx, rfl⟩
  have h₃ : x.val ∈ val_image A Y := by
    rw [h₁] at h₂
    exact h₂
  rcases h₃ with ⟨y, hy, h₄⟩
  have h₅ : x.val = y.val := by
    simpa using h₄
  have h₆ : x = y := by
    have h₇ : (x : U) = (y : U) := by
      simpa [h₅] using h₅
    exact Subtype.ext h₇
