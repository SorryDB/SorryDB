theorem uniform_sample_prop {n : ℕ} (p : ℕ → Prop) :
    (∀ k < n, p k) ↔ (∀ (s : Finset ℕ), s ⊆ Finset.Iio n → (∀ k ∈ s, p k)) := by
  constructor
  · -- Prove the forward direction: (∀ k < n, p k) → (∀ (s : Finset ℕ), s ⊆ Finset.Iio n → (∀ k ∈ s, p k))
    intro h s hs
    intro x hx
    have h₁ : x < n := by
      have h₂ : x ∈ s := hx
      have h₃ : s ⊆ Finset.Iio n := hs
      have h₄ : x ∈ Finset.Iio n := h₃ h₂
      simp [Finset.mem_Iio] at h₄ ⊢
      exact h₄
    have h₂ : p x := h x h₁
    exact h₂
  · -- Prove the backward direction: (∀ (s : Finset ℕ), s ⊆ Finset.Iio n → (∀ k ∈ s, p k)) → (∀ k < n, p k)
    intro h k hk
    have h₁ : k ∈ Finset.Iio n := by
      simp [Finset.mem_Iio]
      <;> omega
    have h₂ : ∀ (s : Finset ℕ), s ⊆ Finset.Iio n → (∀ k ∈ s, p k) := h
    have h₃ : {k} ⊆ Finset.Iio n := by
      simp_all [Finset.singleton_subset_iff]
      <;> omega
    have h₄ : ∀ k ∈ ({k} : Finset ℕ), p k := h₂ {k} h₃
    have h₅ : p k := h₄ k (Finset.mem_singleton_self k)
    exact h₅
```
