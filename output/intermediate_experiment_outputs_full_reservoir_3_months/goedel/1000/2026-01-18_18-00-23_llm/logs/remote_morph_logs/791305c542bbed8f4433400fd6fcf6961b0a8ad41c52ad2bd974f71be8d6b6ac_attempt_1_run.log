theorem intervalIntegrable_iff_intervalIntegrable_smul
    {E : Type*} [NormedAddCommGroup E]
    {a b : ℝ} {μ : MeasureTheory.Measure ℝ}
    {R : Type*} [NormedAddCommGroup R] [SMulZeroClass R E] [IsBoundedSMul R E]
    {f : ℝ → E} (r : R) :
    IntervalIntegrable f μ a b ↔ IntervalIntegrable (r • f) μ a b := by
  have h₁ : IntervalIntegrable f μ a b → IntervalIntegrable (r • f) μ a b := by
    intro hf
    have h₂ : IntervalIntegrable (fun x ↦ r • f x) μ a b := by
      -- Use the fact that the interval integrability is preserved under scalar multiplication
      have h₃ : IntervalIntegrable (fun x ↦ r • f x) μ a b := by
        -- Apply the interval integrability of f and use the boundedness of the scalar multiplication
        refine' IntervalIntegrable.of_norm _ (isBoundedSMul.comp_norm _)
        -- Use the interval integrability of the norm of f
        exact hf.norm
      exact h₃
    exact h₂
  have h₂ : IntervalIntegrable (r • f) μ a b → IntervalIntegrable f μ a b := by
    intro hf
    have h₃ : IntervalIntegrable (fun x ↦ (r⁻¹ : R) • (r • f x)) μ a b := by
      -- Use the interval integrability of r • f and the boundedness of the scalar multiplication
      refine' IntervalIntegrable.of_norm _ (isBoundedSMul.comp_norm _)
      -- Use the interval integrability of the norm of r • f
      exact hf.norm
    -- Simplify the expression to show that f is interval integrable
    have h₄ : (fun x ↦ (r⁻¹ : R) • (r • f x)) = f := by
      ext x
      simp [smul_smul]
      <;>
      (try simp_all [inv_simp]) <;>
      (try simp_all [smul_smul]) <;>
      (try simp_all [mul_comm]) <;>
      (try simp_all [mul_assoc]) <;>
      (try simp_all [mul_left_comm])
      <;>
      (try simp_all [mul_one]) <;>
      (try simp_all [one_mul])
      <;>
      (try simp_all [mul_zero]) <;>
      (try simp_all [zero_mul])
      <;>
      (try simp_all [add_zero]) <;>
      (try simp_all [zero_add])
      <;>
      (try simp_all [sub_eq_add_neg]) <;>
      (try simp_all [neg_add_rev])
      <;>
      (try simp_all [neg_neg]) <;>
      (try simp_all [neg_zero])
    rw [h₄] at h₃
    exact h₃
  exact ⟨h₁, h₂⟩
