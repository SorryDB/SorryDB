def CompConstant
  (ct : ℕ) (input : Vector (F p) 254) : Expression (F p) := do
  have hp : p > 2^135 := by linarith [‹Fact (p > 2^253)›.elim]
  let parts : Vector (Expression (F p)) 127 := by
    Vector.ofFn fun i =>
      let clsb := (ct >>> (i * 2)) &&& 1
      let cmsb := (ct >>> (i * 2 + 1)) &&& 1
      let slsb := input[i * 2]
      let smsb := input[i * 2 + 1]

      if cmsb == 0 && clsb == 0 then
        (-(2^128 - 2^i : F p) : Expression (F p)) * smsb * slsb +
          (2^128 - 2^i : F p : Expression (F p)) * smsb +
          (2^128 - 2^i : F p : Expression (F p)) * slsb
      else if cmsb == 0 && clsb == 1 then
        (2^i : F p : Expression (F p)) * smsb * slsb -
          (2^i : F p : Expression (F p)) * slsb +
          (2^128 - 2^i : F p : Expression (F p)) * smsb -
          (2^i : F p : Expression (F p)) * smsb +
          (2^i : F p : Expression (F p))
      else if cmsb == 1 && clsb == 0 then
        (2^128 - 2^i : F p : Expression (F p)) * smsb * slsb -
          (2^i : F p : Expression (F p)) * smsb +
          (2^i : F p : Expression (F p))
      else
        (-(2^i : F p) : Expression (F p)) * smsb * slsb +
          (2^i : F p : Expression (F p))
  let sout : Expression (F p) := parts.sum
  let bits : Vector (F p) 135 := by
