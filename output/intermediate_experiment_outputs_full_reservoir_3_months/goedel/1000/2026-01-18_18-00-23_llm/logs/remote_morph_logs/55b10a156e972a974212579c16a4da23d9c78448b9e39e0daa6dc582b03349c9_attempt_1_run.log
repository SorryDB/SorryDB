      subst_vars
      <;> simp_all [h_eq, h_lt]
      <;>
      (try cases' lt_trichotomy i i with h h <;>
        simp_all [lt_irrefl, lt_asymm, le_of_lt]) <;>
      (try simp_all [Fin.ext_iff]) <;>
      (try omega)
    }) <;>
  (try
    {
      aesop
    })
