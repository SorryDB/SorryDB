theorem used_rule_has_smaller_sequents {X : Sequent} {X_rep : X.2.2 ≠ .lrep}
    (rX : RuleApplication X)
    (h : ∀ Y ∈ X.2.1, ¬ rX.summ.isRule (PdlRule))
    : (rX.cSeq.add + X.2.2).2.1 ≺ [X].add ∨ (rX.cSeq.add + X.2.2).2.2 ≺ [X].add
  :=
  match rX with
  | ⟨_, ⟨P, θ⟩⟩ =>
    cases P with
    | localRuleAPPLY lra local_rul marker_def_pos =>
      -- For local rule application, the new sequents are subsets of the original
      -- and thus lexicographically smaller.
      simp_all [RuleApplication, ruleAppends, padj, Sequence.ofAdd]
      <;>
      (try contradiction) <;>
      (try omega) <;>
      (try {
        -- Prove that the new sequents are lexicographically smaller
        simp_all [ctxIgnore]
        <;>
        (try contradiction) <;>
        (try omega)
      }) <;>
      (try {
        -- Handle specific cases for the local rules
        cases local_rul <;>
        simp_all [localRule_left, localRule_right, padj, Sequence.ofAdd] <;>
        (try contradiction) <;>
        (try omega)
