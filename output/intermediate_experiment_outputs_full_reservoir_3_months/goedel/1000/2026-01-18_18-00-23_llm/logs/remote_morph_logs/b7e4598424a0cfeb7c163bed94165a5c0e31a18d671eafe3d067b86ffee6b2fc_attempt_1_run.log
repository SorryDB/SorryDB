    (h : ∀ x : ℝ, f x = x + 1) : 
    ∃ δ > (0 : ℝ), ∀ x : ℝ, |x - x₀| < δ → |f x - f x₀| < ε :=
  by
  have h₁ : ∃ δ > (0 : ℝ), ∀ x : ℝ, |x - x₀| < δ → |f x - f x₀| < ε := by
