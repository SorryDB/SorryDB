lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  have h : (support p).toFinset.card ≤ (p.edges.toFinset.card : ℕ) + 1 := by
    -- Use the fact that the number of vertices is at most the number of edges plus one
    have h₁ : (support p).length = p.length + 1 := by
      induction p with
      | nil =>
        simp [support, length]
      | cons h p ih =>
        simp_all [support, length, List.length_append]
        <;> aesop
      | loop p ih =>
        simp_all [support, length]
        <;> aesop
    have h₂ : (support p).toFinset.card ≤ (support p).length := by
      -- The number of distinct vertices is at most the length of the support list
      have h₃ : (support p).toFinset.card ≤ (support p).length := by
        apply (Finset.card_le_card (Finset.filter_subset _ _)).trans
        <;> simp [List.toFinset]
        <;> simp [List.mem_toFinset]
      exact h₃
    have h₃ : (p.edges.toFinset.card : ℕ) ≥ p.edges.length - (p.edges.length - p.edges.toFinset.card) := by
      -- A trivial inequality to help with the proof
      have h₄ : (p.edges.toFinset.card : ℕ) ≤ p.edges.length := by
        apply (Finset.card_le_card (Finset.filter_subset _ _)).trans
        <;> simp [List.toFinset]
        <;> simp [List.mem_toFinset]
      omega
    have h₄ : (support p).length ≤ (p.edges.toFinset.card : ℕ) + 1 := by
      -- Prove that the length of the support is at most the number of edges plus one
      have h₅ : (support p).length ≤ p.edges.length + 1 := by
        -- The length of the support is at most the length of the edges plus one
        have h₆ : ∀ (l : List (V × V)), (support p).length ≤ l.length + 1 := by
          intro l
          induction p with
          | nil =>
            simp [support]
            <;>
            (try omega)
            <;>
            (try simp_all [List.length])
            <;>
            (try linarith)
          | cons h p ih =>
            simp_all [support, edges, darts, List.length, List.map]
            <;>
            (try omega)
            <;>
            (try simp_all [List.length])
            <;>
            (try linarith)
          | loop p ih =>
            simp_all [support, edges, darts, List.length, List.map]
            <;>
            (try omega)
            <;>
            (try simp_all [List.length])
            <;>
            (try linarith)
        exact h₆ p.edges
      have h₆ : p.edges.length ≤ (p.edges.toFinset.card : ℕ) + (p.edges.length - p.edges.toFinset.card) := by
        -- A trivial inequality to help with the proof
        have h₇ : p.edges.toFinset.card ≤ p.edges.length := by
          apply (Finset.card_le_card (Finset.filter_subset _ _)).trans
          <;> simp [List.toFinset]
          <;> simp [List.mem_toFinset]
        omega
      omega
    -- Combine all the inequalities to get the final result
    omega
  -- Convert the result to the correct form
  simpa [supportSet, edgeSet] using h
