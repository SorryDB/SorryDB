            _ = (darts p).length := by
              -- The length of the map is the same as the length of the list
              simp [List.length_map]
        have h₂₇ : ((darts p).map (fun x => dartEdge x) |>.toFinset : Finset (Sym2 V)).card ≥ (darts p).length := by
          calc
