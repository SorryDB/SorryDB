          (try simp_all [List.toFinset_card, List.length_toFinset]) <;>
          (try norm_num) <;>
          (try aesop)
        -- Simplify the inequality.
        exact h₁₄
      -- Simplify the inequality.
      exact h₁₃
    -- Combine the two inequalities.
    calc
      (supportSet p).card ≤ (support p).toFinset.card := h₁₁
      _ ≤ (support p).length := h₁₂
  have h₂ : (support p).length - 1 ≤ (edgeSet p).card := by
    have h₂₁ : (support p).length ≤ (darts p).length + 1 := by
      -- The length of the support is at most the number of darts plus one
      have h₂₂ : ∀ (p : G.LoopWalk u v), (support p).length ≤ (darts p).length + 1 := by
        intro p
        induction p using LoopWalk.rec
        · -- Base case: nil walk
