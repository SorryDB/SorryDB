lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  have h : (supportSet p).card ≤ (edgeSet p).card + 1 := by
    -- Use the fact that the number of vertices is at most the number of edges plus one
    have h₁ : (supportSet p).card ≤ (p.support.toFinset.card : ℕ) := by simp
    have h₂ : (p.support.toFinset.card : ℕ) ≤ (p.darts.toFinset.card : ℕ) + 1 := by
      -- The number of vertices is at most the number of edges plus one
      have h₃ : p.support.toFinset.card ≤ (p.support.length : ℕ) := by
        simp [List.toFinset_card_le]
      have h₄ : (p.support.length : ℕ) ≤ (p.darts.toFinset.card : ℕ) + 1 := by
        -- The number of vertices is at most the number of edges plus one
        have h₅ : p.support.length ≤ p.darts.length + 1 := by
          -- Prove this by induction on the structure of the LoopWalk
          have h₆ : ∀ (p : G.LoopWalk u v), p.support.length ≤ p.darts.length + 1 := by
            intro p
            induction p using G.LoopWalk.rec
            · -- Base case: nil
              simp [support, darts]
            · -- Inductive step: cons
              simp_all [support, darts, List.length_append, List.length_cons]
              <;> omega
            · -- Inductive step: loop
              simp_all [support, darts, List.length_append, List.length_cons]
              <;> omega
          exact h₆ p
        have h₇ : (p.darts.toFinset.card : ℕ) ≥ p.darts.length - p.darts.length % (p.darts.length) := by
          -- Use the fact that the cardinality of the set is at least the length of the list minus some value
          have h₈ : p.darts.toFinset.card ≤ p.darts.length := by
            -- The cardinality of the set is at most the length of the list
            have h₉ : p.darts.toFinset.card ≤ p.darts.length := by
              apply List.toFinset_card_le
            exact h₉
          have h₉ : p.darts.toFinset.card ≥ 0 := by positivity
          have h₁₀ : p.darts.length ≥ 0 := by positivity
          -- Use the fact that the cardinality of the set is at least the length of the list minus some value
          omega
        -- Combine the inequalities to get the final result
        have h₈ : p.darts.length + 1 ≤ (p.darts.toFinset.card : ℕ) + 1 + (p.darts.length % (p.darts.length)) := by
          omega
        omega
      have h₅ : (p.darts.toFinset.card : ℕ) ≥ 0 := by positivity
      omega
    have h₃ : (p.darts.toFinset.card : ℕ) = (edgeSet p).card := by
      simp [edgeSet]
    -- Combine all the inequalities to get the final result
    have h₄ : (supportSet p).card ≤ (edgeSet p).card + 1 := by
      calc
        (supportSet p).card ≤ (p.support.toFinset.card : ℕ) := h₁
        _ ≤ (p.darts.toFinset.card : ℕ) + 1 := h₂
        _ = (edgeSet p).card + 1 := by
          rw [h₃]
          <;> simp [add_comm]
    exact h₄
  exact h
