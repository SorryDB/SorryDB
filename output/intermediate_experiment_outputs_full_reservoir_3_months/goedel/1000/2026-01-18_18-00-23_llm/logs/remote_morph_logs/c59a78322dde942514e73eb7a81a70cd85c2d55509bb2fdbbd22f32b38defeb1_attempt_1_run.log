theorem vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h₁ : (supportSet p).card ≤ (edgeSet p).card + 1 := by
    -- Use the fact that the number of vertices in a walk is at most the number of edges plus one.
    -- This is because each edge connects two vertices, and we can have at most one more vertex than edges.
    -- We handle the cases for nil, cons, and loop separately.
    have h₂ : ∀ (p : G.LoopWalk u v), (supportSet p).card ≤ (edgeSet p).card + 1 := by
      intro p
      induction p with
      | nil =>
        -- Base case: nil walk.
        simp [supportSet, edgeSet, List.toFinset_card, List.map]
        <;>
        (try decide) <;>
        (try simp_all [Finset.card_singleton]) <;>
        (try norm_num) <;>
        (try omega)
      | cons u v' _ h p ih =>
        -- Inductive step: cons case.
        simp_all [supportSet, edgeSet, List.toFinset_card, List.map, List.append, Nat.succ_eq_add_one]
        <;>
        (try omega) <;>
        (try {
          have h₃ : (p.support.map (fun x => (x, x))).toFinset.card = 0 := by
            simp [List.map, List.toFinset_card]
          simp_all [Finset.card_insert_of_not_mem]
          <;> omega
        }) <;>
        (try {
          simp_all [Finset.card_insert_of_not_mem]
          <;>
          (try omega)
        }) <;>
        (try {
          have h₃ : Finset.card (a.toFinset) ≥ 0 := by
            apply Nat.zero_le
          omega
        })
      | loop p ih =>
        -- Inductive step: loop case.
        simp_all [supportSet, edgeSet, List.toFinset_card, List.map, List.append, Nat.succ_eq_add_one]
        <;>
        (try omega) <;>
        (try {
          have h₃ : (p.support.map (fun x => (x, x))).toFinset.card = 0 := by
            simp [List.map, List.toFinset_card]
          simp_all [Finset.card_insert_of_not_mem]
          <;> omega
        }) <;>
        (try {
          simp_all [Finset.card_insert_of_not_mem]
          <;>
          (try omega)
        }) <;>
        (try {
          have h₃ : Finset.card (a.toFinset) ≥ 0 := by
            apply Nat.zero_le
          omega
        })
    -- Apply the general statement to the specific walk p.
    exact h₂ p
  -- The result follows directly from h₁.
  exact h₁
