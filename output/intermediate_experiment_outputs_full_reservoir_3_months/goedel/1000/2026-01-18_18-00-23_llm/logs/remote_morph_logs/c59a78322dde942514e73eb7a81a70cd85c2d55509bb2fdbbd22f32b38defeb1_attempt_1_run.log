      -- The cardinality of the support set is less than or equal to the cardinality of the support list ToFinset.
      -- Since Finset.card is idempotent, this is straightforward.
      simp [Finset.card_toFinset]
      <;>
      (try decide) <;>
      (try simp_all [List.toFinset_card, List.length_toFinset]) <;>
      (try norm_num) <;>
      (try aesop)
    -- The cardinality of the support set is less than or equal to the cardinality of the support list.
    have h₁₂ : (support p).toFinset.card ≤ (support p).length := by
      -- The cardinality of the support list ToFinset is less than or equal to the length of the support list.
      have h₁₃ : (support p).toFinset.card ≤ (support p).length := by
        -- Use the fact that the support set is a subset of the support list ToFinset.
