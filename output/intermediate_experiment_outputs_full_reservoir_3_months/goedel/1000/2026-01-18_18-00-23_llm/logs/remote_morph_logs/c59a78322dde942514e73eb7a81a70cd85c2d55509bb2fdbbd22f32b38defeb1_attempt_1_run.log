section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  have h : ∀ (l : List V), (l.map id).toFinset.card ≤ l.length := by
    intro l
    calc
      (l.map id).toFinset.card ≤ (l.map id).length := by
        -- The number of distinct elements is at most the number of elements.
        apply (Finset.card_le_of_subset (Finset.subset_univ _)).trans
        simp [List.length_map]
      _ = l.length := by simp [List.length_map]
  -- We need to relate the support and edges of the walk.
  -- The support of the walk is the list of vertices it visits.
  -- The edge set is the set of edges it traverses.
  -- The length of the support set is at most the length of the support list.
  -- The length of the support list is at most the number of edges plus one.
  -- Therefore, the cardinality of the support set is at most the number of edges plus one.
  have h₁ : (support p).toFinset.card ≤ (support p).length := by
    apply h
  have h₂ : (support p).length ≤ (edgeSet p).card + 1 := by
    -- We need to show that the number of vertices visited is at most the number of edges plus one.
    -- This can be done by induction on the structure of the LoopWalk.
    have h₃ : ∀ {u v : V} (w : G.LoopWalk u v), (support w).length ≤ (edgeSet w).card + 1 := by
      intro u v
      induction' w with u _ | u v w h p | u v w p
      · -- Case: nil
        simp [support, edgeSet]
      · -- Case: cons
        simp_all [support, edgeSet, List.length, List.map, dartEdge, Finset.card_insert_of_not_mem,
          Finset.mem_singleton]
        <;>
          (try simp_all [SimpleGraph.mk_adj]) <;>
          (try omega) <;>
          (try {
            have h₄ : (u, v') ∉ p.darts := by
              intro h₄
              simp_all [darts, List.mem_cons, List.mem_singleton]
              <;>
                (try omega) <;>
                (try simp_all [SimpleGraph.mk_adj])
            simp_all [Finset.card_insert_of_not_mem]
            <;> omega
          }) <;>
          (try {
            simp_all [Finset.card_insert_of_not_mem]
            <;> omega
          })
      · -- Case: loop
        simp_all [support, edgeSet, List.length, List.map, dartEdge, Finset.card_insert_of_not_mem,
          Finset.mem_singleton]
        <;>
          (try simp_all [SimpleGraph.mk_adj]) <;>
          (try omega) <;>
          (try {
            have h₄ : (u, u) ∉ p.darts := by
              intro h₄
              simp_all [darts, List.mem_cons, List.mem_singleton]
              <;>
                (try omega) <;>
                (try simp_all [SimpleGraph.mk_adj])
            simp_all [Finset.card_insert_of_not_mem]
            <;> omega
          }) <;>
          (try {
            simp_all [Finset.card_insert_of_not_mem]
            <;> omega
          })
    -- Apply the general statement to the current walk p.
    exact h₃ p
  -- Combine the two inequalities to get the final result.
  calc
    (supportSet p).card = (support p).toFinset.card := rfl
    _ ≤ (support p).length := h₁
    _ ≤ (edgeSet p).card + 1 := h₂
    _ = (edgeSet p).card + 1 := by rfl
