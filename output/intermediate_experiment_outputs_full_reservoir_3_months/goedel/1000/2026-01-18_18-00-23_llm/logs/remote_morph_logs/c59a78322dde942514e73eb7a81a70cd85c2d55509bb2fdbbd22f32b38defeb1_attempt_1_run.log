    have h₃ : (support p).length = p.length + 1 := by
      induction p with
      | nil => simp [List.length]
      | cons h p ih =>
        simp_all [support, length, List.length]
        <;> omega
      | loop p ih =>
        simp_all [support, length, List.length]
        <;> omega
    have h₄ : (edgeSet p).card ≥ p.length := by
      have h₅ : (edgeSet p).card ≥ p.length := by
        have h₆ : p.length ≤ (edgeSet p).card := by
          -- Use the fact that the number of edges is at least the length of the walk
          have h₇ : ∀ (p : G.LoopWalk u v), p.length ≤ (edgeSet p).card := by
            intro p
            induction p with
            | nil => simp [edgeSet, darts, Finset.card]
            | cons h p ih =>
