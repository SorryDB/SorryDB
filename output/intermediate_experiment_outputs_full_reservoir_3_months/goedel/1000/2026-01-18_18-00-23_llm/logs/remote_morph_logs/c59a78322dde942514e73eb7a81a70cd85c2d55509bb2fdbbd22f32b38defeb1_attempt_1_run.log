inductive LoopWalk : V → V → Type u
  | nil {u : V} : LoopWalk u u
  | cons {u v w : V} (h : G.Adj u v) (p : LoopWalk v w) : LoopWalk u w
  | loop {u v : V} (p : LoopWalk u v): LoopWalk u v
  deriving DecidableEq

def LoopWalk.supportSet {u v : V} [DecidableEq V] (p : LoopWalk u v) : Finset V :=
  (LoopWalk.support p).toFinset

def LoopWalk.edgeSet {u v : V} [DecidableEq V] (p : LoopWalk u v) : Finset (Sym2 V) :=
  (LoopWalk.edges p).toFinset

