lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card +1 := by
  have h₁ : (support p).length ≤ (edges p).length + 1 := by
    -- Prove that the number of vertices is at most one more than the number of edges
    have h₂ : ∀ (p : G.LoopWalk u v), (support p).length ≤ (edges p).length + 1 := by
      intro p
      induction p with
      | nil => simp
      | cons h p ih =>
        simp_all [support, edges, darts, dartEdge, List.length_cons, List.map]
        <;>
        (try omega) <;>
        (try
          {
            simp_all [List.length_cons, List.map]
            <;> omega
          })
        <;>
        (try
          {
            cases p with
            | nil => simp_all [List.length_cons, List.map]
            | cons h₂ p₂ =>
              simp_all [support, edges, darts, dartEdge, List.length_cons, List.map]
              <;> omega
          })
        <;>
        (try
          {
            cases p with
            | nil => simp_all [List.length_cons, List.map]
            | loop p₂ =>
              simp_all [support, edges, darts, dartEdge, List.length_cons, List.map]
              <;> omega
          })
      | loop p ih =>
        simp_all [support, edges, darts, dartEdge, List.length_cons, List.map]
        <;>
        (try omega) <;>
        (try
          {
            simp_all [List.length_cons, List.map]
            <;> omega
          })
        <;>
