    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where
  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [F.map_comp, F.map_comp]
    rw [G.map_comp, G.map_comp]
    simp_all [comp_assoc]
    <;> try simp_all [comp_assoc]
  ⟩

  id_comp := by
    intro a b
    simp [Comp]
    <;> aesop

  comp_id := by
    intro a b
    simp [Comp]
    <;> aesop

  assoc := by
    intro a b c d
    simp [Comp]
    <;>
    (try aesop) <;>
    (try simp_all [comp_assoc]) <;>
    (try rw [F.map_comp, F.map_comp, F.map_comp, G.map_comp, G.map_comp, G.map_comp]) <;>
    (try simp_all [comp_assoc]) <;>
    (try aesop)
  
  <;>
