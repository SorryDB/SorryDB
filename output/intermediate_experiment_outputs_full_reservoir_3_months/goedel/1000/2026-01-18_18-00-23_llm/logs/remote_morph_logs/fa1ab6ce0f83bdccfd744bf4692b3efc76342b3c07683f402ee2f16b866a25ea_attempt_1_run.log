theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  have h₀ : ∀ x : α, F.homF (X := ()) (Y := ()) x = F.homF (X := ()) (Y := ()) x := by
    intro x
    rfl
  -- Use the homomorphism property to construct the group homomorphism
  use { toFun := fun x : α => F.homF (X := ()) (Y := ()) x,
        map_one' := by
          -- Prove that the identity element is mapped to the identity element
          have h₁ := F.map_id ()
          simp [Category.Monoid.id] at h₁ ⊢
          <;>
          simp_all [MonoidHom.map_one]
          <;>
          aesop
        map_mul' := by
          -- Prove that the product is preserved
          intro x y
          have h₂ := F.map_comp (x : α) (y : α)
          simp [Category.Monoid.comp] at h₂ ⊢
          <;>
          simp_all [MonoidHom.map_mul]
          <;>
          aesop }
  -- Prove that the constructed homomorphism satisfies the required property
  intro x
  rfl
