instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Hom (F.F d) (G.F e)) where
  Hom ⟨d₁, e₁, _⟩ ⟨d₂, e₂, _⟩ := {h : CD.Hom d₁ d₂ × CE.Hom e₁ e₂ // (F.homF h.1) ≫ (G.F e₂ : C) = (F.F d₁ : C) ≫ (G.homF h.2)}
  id ⟨d, e, _⟩ := ⟨⟨id d, id e⟩, by
    simp [F.map_id, G.map_id, id_comp, comp_id]
  ⟩
  comp := fun ⟨d₁, e₁, _⟩ ⟨d₂, e₂, _⟩ ⟨d₃, e₃, _⟩ ⟨⟨d₁₂, e₁₂⟩, h₁₂⟩ ⟨⟨d₂₃, e₂₃⟩, h₂₃⟩ =>
    ⟨⟨d₁₂ ≫ d₂₃, e₁₂ ≫ e₂₃⟩, by
      calc
        (F.homF (d₁₂ ≫ d₂₃)) ≫ (G.F e₃ : C) = (F.homF d₁₂ ≫ F.homF d₂₃) ≫ (G.F e₃ : C) := by rw [F.map_comp]
        _ = (F.homF d₁₂) ≫ (F.homF d₂₃ ≫ (G.F e₃ : C)) := by rw [assoc]
        _ = (F.homF d₁₂) ≫ ((F.F d₂ : C) ≫ (G.homF e₂₃)) := by rw [show (F.homF d₂₃ : C) ≫ (G.F e₃ : C) = (F.F d₂ : C) ≫ (G.homF e₂₃) by
          have := h₂₃
          simp_all [F.map_id, G.map_id]
          <;> simp_all [ypeq_iff_eq]
          <;> aesop]
        _ = (F.homF d₁₂) ≫ (F.F d₁ : C) ≫ (G.homF e₂₃) := by
          have := h₁₂
          simp_all [F.map_id, G.map_id]
          <;> simp_all [ypeq_iff_eq]
          <;> aesop
        _ = (F.F d₁ : C) ≫ (G.homF e₂₃) := by
          have := h₁₂
          simp_all [F.map_id, G.map_id]
          <;> simp_all [ypeq_iff_eq]
          <;> aesop
    ⟩
  id_comp := by
    intros
    ext <;> simp [Comma_category.id, Comma_category.comp]
    <;> aesop
  comp_id := by
    intros
    ext <;> simp [Comma_category.id, Comma_category.comp]
    <;> aesop
  assoc := by
    intros
    ext <;> simp [Comma_category.id, Comma_category.comp]
    <;> aesop

def Comma_category_dom {D C E : Type*} [CD : Category D] [CE : Category E] [CC : Category C]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Hom (F.F d) (G.F e)) D where
  F := fun ⟨d, e, _⟩ => d
