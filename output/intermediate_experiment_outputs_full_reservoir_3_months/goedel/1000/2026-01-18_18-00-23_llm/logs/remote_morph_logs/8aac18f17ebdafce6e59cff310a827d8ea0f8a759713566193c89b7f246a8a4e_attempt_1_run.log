```lean
example (a b : Nat) : a + b = b + a := by
  have h : ∀ (a b : ℕ), a + b = b + a := by
    intro a b
    induction b with
    | zero => simp [add_assoc]
    | succ b ih =>
      simp_all [add_assoc, add_comm, add_left_comm]
      <;> omega
  have h₂ := h a b
  exact h₂
