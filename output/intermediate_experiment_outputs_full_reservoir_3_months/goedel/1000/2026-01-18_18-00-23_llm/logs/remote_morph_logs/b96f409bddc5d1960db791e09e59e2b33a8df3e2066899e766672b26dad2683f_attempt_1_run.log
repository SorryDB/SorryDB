theorem isMaxMatching_encard {G : Graph α β} {M : Set β} (h : IsMaxMatching G M) : M.encard = MatchingNumber G := by
  have h₁ : M.encard = MatchingNumber G := by
    have h₂ : M.encard ≤ MatchingNumber G := IsMatching.encard_le h.1
    have h₃ : MatchingNumber G ≤ M.encard := by
      have h₄ : M.encard ∈ Set.range fun M : Set β => M.encard := ⟨M, rfl⟩
      have h₅ : MatchingNumber G = sSup {n | ∃ M, IsMatching G M ∧ n = M.encard} := rfl
      have h₆ : ∀ n ∈ {n | ∃ M, IsMatching G M ∧ n = M.encard}, n ≤ M.encard := by
        intro n hn
        rcases hn with ⟨M', hM', rfl⟩
        have h₇ : IsMatching G M' := hM'
        have h₈ : IsMatching G M := h.1
        have h₉ : M'.encard ≤ M.encard := h.max M' h₇
        exact h₉
      -- Use the fact that the maximum of the set is the encard of M
      have h₇ : sSup {n | ∃ M, IsMatching G M ∧ n = M.encard} ≤ M.encard := by
        apply csSup_le
        -- Show that the set is nonempty
        · exact Set.nonempty_of_mem (by
            refine' ⟨M.encard, _⟩
            refine' ⟨M, h.1, rfl⟩)
        -- Show that all elements in the set are ≤ M.encard
        · intro n hn
          exact h₆ n hn
      -- Combine the inequalities to get the desired result
      simp_all [MatchingNumber]
    -- Combine the inequalities to get the desired result
    encard_eq (by
      apply le_antisymm
      · exact h₂
      · exact h₃)
  exact h₁
