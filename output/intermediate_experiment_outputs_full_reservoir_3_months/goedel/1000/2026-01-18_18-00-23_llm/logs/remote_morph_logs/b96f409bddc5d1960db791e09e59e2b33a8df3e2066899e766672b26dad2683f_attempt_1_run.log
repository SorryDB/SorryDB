    -- Combining these results gives M.encard ≥ ν(G)
    simpa [h₄] using h₅
  -- Since we have M.encard ≤ ν(G) and M.encard ≥ ν(G), it follows that M.encard = ν(G)
  exact le_antisymm h₁ h₂
