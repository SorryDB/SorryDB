theorem IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  have h₁ : M.encard ≤ ν(G) := by
    apply IsMatching.encard_le
    exact h.toIsMatching
  have h₂ : M.encard ≥ ν(G) := by
    have h₃ : M.encard ∈ {n : ℕ∞ | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by
      refine' ⟨M, _⟩
      exact ⟨h.toIsMatching, rfl⟩
    -- The matching number ν(G) is the supremum of the set of all matching cardinalities.
    -- Since M is a maximum matching, its cardinality is at least the supremum.
