    have h₅ : M.encard ≥ sSup {n : ℕ∞ | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by
      -- Since M is a maximum matching, for any other matching M', we have M'.encard ≤ M.encard.
      -- This implies that M.encard is an upper bound for the set of matching cardinalities.
      -- Therefore, M.encard is at least the supremum of this set.
      apply le_ciSup
      · -- Show that the set is bounded above
