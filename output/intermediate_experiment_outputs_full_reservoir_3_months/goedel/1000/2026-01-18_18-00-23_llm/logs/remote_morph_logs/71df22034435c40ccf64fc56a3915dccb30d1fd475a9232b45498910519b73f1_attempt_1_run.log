theorem eq_zero_of_I_zero_equinum {n : Nat} (h : I 0 ∼ I n) : n = 0 := by
  have h₁ : Fintype.card (I 0 : Type) = Fintype.card (I n : Type) := by
    apply Fintype.card_congr
    exact h
  have h₂ : Fintype.card (I 0 : Type) = 0 := by
    simp [Fintype.card_eq_zero_iff]
    <;> simp [I_zero]
  have h₃ : Fintype.card (I n : Type) = n := by
    simp [Fintype.card_fin]
    <;> simp_all [I]
  have h₄ : n = 0 := by
    linarith
  exact h₄
