    intro n
    simp [tri]
    <;> ring_nf
    <;> omega
  have h3 : tri j = j * (j + 1) / 2 := by rw [h2]
  have h4 : tri k = k * (k + 1) / 2 := by rw [h2]
  rw [h3, h4]
  have h5 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
    have h6 : j ≤ k := h1
    have h7 : j * (j + 1) ≤ k * (k + 1) := by
      have h8 : j + 1 ≤ k + 1 := by linarith
      have h9 : j ≤ k := h1
      nlinarith
    have h10 : j * (j + 1) / 2 ≤ k * (k + 1) / 2 := by
      apply Nat.div_le_div_right
      <;> nlinarith
    exact h10
  exact h5

example {U V : Type} (f : U → V) : range f = Ran (graph f) := by
  apply Set.Subset.antisymm
  · -- Prove that range f ⊆ Ran (graph f)
    intro y hy
    rcases hy with ⟨x, rfl⟩
    -- For any y in the range of f, there exists an x such that f x = y
    -- We need to show that y is in the range of graph f
    use (x, f x)
    <;> simp [graph, Prod.ext_iff]
    <;> aesop
  · -- Prove that Ran (graph f) ⊆ range f
    intro y hy
    rcases hy with ⟨⟨x, z⟩, h⟩
    -- For any y in the range of graph f, there exists a pair (x, z) such that (x, z) = (x, f x)
    -- We need to show that y is in the range of f
    simp [graph] at h ⊢
    <;>
    (try { aesop }) <;>
    (try {
      use x
      <;> aesop
    })

lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · -- Prove the forward direction: if f is onto, then range f = univ
    intro h
    apply Set.eq_univ_of_forall
    intro y
    have h₁ : ∃ x : U, f x = y := h y
    rcases h₁ with ⟨x, rfl⟩
    exact Set.mem_range_self x
  · -- Prove the reverse direction: if range f = univ, then f is onto
    intro h
    intro y
    have h₁ : y ∈ (Set.univ : Set V) := Set.mem_univ y
    have h₂ : y ∈ range f := by
      rw [h] at *
      exact h₁
    rcases h₂ with ⟨x, rfl⟩
    exact ⟨x, rfl⟩

