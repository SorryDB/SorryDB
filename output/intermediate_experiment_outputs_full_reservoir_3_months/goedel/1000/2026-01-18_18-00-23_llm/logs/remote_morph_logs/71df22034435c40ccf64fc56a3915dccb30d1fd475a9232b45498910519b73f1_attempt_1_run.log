theorem eq_zero_of_I_zero_equinum {n : Nat} (h : I 0 ∼ I n) : n = 0 := by
  have h₁ : n = 0 := by
    cases n with
    | zero => rfl
    | succ n =>
      -- If n is not zero, then I n is non-empty, but I 0 is empty, so they cannot be in bijection.
      exfalso
      have h₂ : Nonempty (I n.succ) := by
        exact ⟨⟨0, by omega⟩⟩
      have h₃ : Empty (I 0) := by
        exact ⟨⟩
      have h₄ : ¬Nonempty (I 0) := by
        intro x
        exact h₃.elim x
      -- Since I 0 is empty and I n.succ is not, they cannot be in bijection.
      have h₅ : ¬(I 0 ∼ I n.succ) := by
        intro h₆
        have h₇ : Nonempty (I 0) := by
          exact Nonempty.ofBij (h₆) h₂
        exact h₄ h₇
      exact h₅ h
  exact h₁
