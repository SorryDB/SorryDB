theorem bound_binomial_coeff {k n : ℕ} :
  Nat.choose n k ≤ n ^ k / (k.factorial : ℚ) ∧
  n ^ k / (k.factorial : ℚ) ≤ n ^ k / 2 ^ (k - 1) := by
  have h₀ : (Nat.choose n k : ℚ) ≤ (n : ℚ) ^ k / (k.factorial : ℚ) := by
    have h₁ : (Nat.choose n k : ℚ) = (n.choose k : ℕ) := by norm_cast
    rw [h₁]
    have h₂ : (n.choose k : ℕ) ≤ n ^ k / k.factorial := by
      have h₃ : n.choose k ≤ n ^ k / k.factorial := by
        have h₄ : n.choose k * k.factorial ≤ n ^ k := by
          calc
            n.choose k * k.factorial = (n.choose k : ℕ) * k.factorial := by simp
            _ ≤ n ^ k := by
              calc
                (n.choose k : ℕ) * k.factorial ≤ n ^ k := by
                  have h₅ : (n.choose k : ℕ) * k.factorial ≤ n ^ k := by
                    have h₆ : (n.choose k : ℕ) * k.factorial ≤ n ^ k := by
                      calc
                        (n.choose k : ℕ) * k.factorial = (n.choose k : ℕ) * Nat.factorial k := by simp [Nat.factorial]
                        _ ≤ n ^ k := by
                          have h₇ : ∀ (n k : ℕ), k ≤ n → (n.choose k : ℕ) * Nat.factorial k ≤ n ^ k := by
                            intro n k hk
                            have h₈ : (n.choose k : ℕ) * Nat.factorial k ≤ n ^ k := by
                              calc
                                (n.choose k : ℕ) * Nat.factorial k = Nat.descFactorial n k := by
                                  rw [Nat.choose_mul_factorial_mul_factorial (by omega)]
                                  <;> simp [Nat.descFactorial, Nat.factorial_succ, mul_assoc]
                                  <;> ring_nf
                                  <;> simp_all [Nat.mul_div_cancel_left]
                                  <;> norm_num
                                  <;> linarith
                                _ ≤ n ^ k := by
                                  have h₉ : Nat.descFactorial n k ≤ n ^ k := by
                                    have h₁₀ : ∀ (n k : ℕ), Nat.descFactorial n k ≤ n ^ k := by
                                      intro n k
                                      calc
                                        Nat.descFactorial n k ≤ n ^ k := by
                                          have h₁₁ : ∀ (m : ℕ), Nat.descFactorial n m ≤ n ^ m := by
                                            intro m
                                            induction' m with m ih
                                            · simp [Nat.descFactorial]
                                            · simp_all [Nat.descFactorial, pow_succ]
                                              <;> nlinarith
                                          exact h₁₁ k
                                        _ = n ^ k := by rfl
                                    exact h₁₀ n k
                                  exact h₉
                            exact h₈
                          have h₁₀ : k ≤ n ∨ k > n := by omega
                          cases h₁₀ with
                          | inl h₁₀ =>
                            exact h₇ n k h₁₀
                          | inr h₁₀ =>
                            have h₁₁ : n.choose k = 0 := by
                              apply Nat.choose_eq_zero_of_lt
                              <;> omega
                            simp [h₁₁]
                            <;> nlinarith
                    exact h₆
                  exact h₅
                _ = n ^ k := by rfl
          <;> simp_all [Nat.choose_eq_factorial_div_factorial]
          <;> norm_num
          <;> linarith
        have h₅ : n.choose k * k.factorial ≤ n ^ k := h₄
        have h₆ : n.choose k ≤ n ^ k / k.factorial := by
          have h₇ : n.choose k * k.factorial ≤ n ^ k := h₅
          have h₈ : n.choose k ≤ n ^ k / k.factorial := by
            apply Nat.le_div_iff_mul_le (by positivity) |>.mpr
            <;> simp_all [mul_comm]
            <;> nlinarith
          exact h₈
        exact h₆
      exact h₃
    have h₃ : (n.choose k : ℕ) ≤ n ^ k / k.factorial := h₂
