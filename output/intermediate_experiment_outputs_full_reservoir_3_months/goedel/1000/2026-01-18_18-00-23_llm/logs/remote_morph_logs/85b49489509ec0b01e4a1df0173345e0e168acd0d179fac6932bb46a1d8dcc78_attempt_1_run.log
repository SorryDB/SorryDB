theorem bound_binomial_coeff {k n : ℕ} :
  Nat.choose n k ≤ n ^ k / (k.factorial : ℚ) ∧
  (n : ℚ) ^ k / (k.factorial : ℚ) ≤ (n : ℚ) ^ k / 2 ^ (k - 1) := by
  have h₁ : (Nat.choose n k : ℚ) ≤ (n : ℚ) ^ k / (k.factorial : ℚ) := by
    have h₂ : (Nat.choose n k : ℚ) = (n : ℚ) ^ k / (k.factorial : ℚ) := by
      norm_cast
      <;>
      simp [Nat.choose_eq_factorial_div_factorial, Nat.factorial_succ, Nat.div_eq_of_lt, Nat.succ_le_iff,
        Nat.lt_succ_iff]
      <;>
      ring_nf
      <;>
      field_simp
      <;>
      norm_cast
      <;>
      simp_all [Nat.mul_div_assoc, Nat.mul_div_cancel_left]
      <;>
      ring_nf at *
      <;>
      norm_num at *
      <;>
      linarith
    rw [h₂]
    <;>
    norm_num
  have h₂ : (n : ℚ) ^ k / (k.factorial : ℚ) ≤ (n : ℚ) ^ k / 2 ^ (k - 1 : ℕ) := by
    have h₃ : (k.factorial : ℚ) ≥ 2 ^ (k - 1 : ℕ) := by
      have h₄ : ∀ (k : ℕ), (k.factorial : ℕ) ≥ 2 ^ (k - 1 : ℕ) := by
        intro k
        have h₅ : k.factorial ≥ 2 ^ (k - 1) := by
          have h₆ : ∀ (k : ℕ), k.factorial ≥ 2 ^ (k - 1) := by
            intro k
            induction' k with k ih
            · norm_num
            · cases k with
              | zero => norm_num
              | succ k =>
                simp_all [Nat.factorial_succ, Nat.pow_succ, Nat.mul_assoc]
                <;>
                nlinarith [pow_pos (by norm_num : (0 : ℕ) < 2) k]
          exact h₆ k
        exact by
          exact_mod_cast h₅
      have h₅ : (k.factorial : ℚ) ≥ 2 ^ (k - 1 : ℕ) := by
        exact by
          exact_mod_cast h₄ k
      exact h₅
    have h₆ : 0 ≤ (n : ℚ) ^ k := by positivity
    have h₇ : 0 < (k.factorial : ℚ) := by positivity
    have h₈ : 0 < (2 : ℚ) ^ (k - 1 : ℕ) := by positivity
    -- Use the fact that if a ≤ b and a, b > 0, then 1/a ≥ 1/b
    have h₉ : 0 < (2 : ℚ) ^ (k - 1 : ℕ) := by positivity
    have h₁₀ : 0 < (k.factorial : ℚ) := by positivity
    -- Use the division inequality to conclude the proof
    have h₁₁ : (n : ℚ) ^ k / (k.factorial : ℚ) ≤ (n : ℚ) ^ k / 2 ^ (k - 1 : ℕ) := by
      apply div_le_div_of_le_left (by positivity) (by positivity)
      <;>
      simpa using h₃
    exact h₁₁
  exact ⟨by exact_mod_cast h₁, h₂⟩
