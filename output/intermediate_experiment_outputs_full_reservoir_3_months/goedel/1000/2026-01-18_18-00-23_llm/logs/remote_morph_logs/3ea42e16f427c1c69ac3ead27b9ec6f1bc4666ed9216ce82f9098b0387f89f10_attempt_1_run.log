### Complete Lean 4 Proof

```lean
theorem le_induction {P : Nat → Prop} {m}
    (h0 : P m) (h1 : ∀ n, m ≤ n → P n → P (n + 1)) :
    ∀ n, m ≤ n → P n := by
  have h2 : ∀ n, m ≤ n → P n := by
    intro n hn
    have h3 : ∀ k : ℕ, P (m + k) := by
      intro k
      induction k with
      | zero => simpa using h0
      | succ k ih =>
        have h4 : m ≤ m + k := by
          omega
        have h5 : P (m + k) := ih
        have h6 : P (m + k + 1) := h1 (m + k) h4 h5
        simpa [add_assoc] using h6
    have h7 : ∃ k : ℕ, n = m + k := by
      use n - m
      have h8 : m ≤ n := hn
      have h9 : n = m + (n - m) := by
        omega
      exact h9
    obtain ⟨k, hk⟩ := h7
    have h8 : P (m + k) := h3 k
    rw [hk] at *
    exact h8
