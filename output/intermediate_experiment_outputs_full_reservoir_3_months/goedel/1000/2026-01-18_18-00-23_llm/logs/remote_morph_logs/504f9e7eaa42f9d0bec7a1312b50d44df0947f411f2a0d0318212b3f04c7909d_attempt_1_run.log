    (F : @CategoryInContext.Functor D C CD CC) (G : @CategoryInContext.Functor E C CE CC) :
    ‚ąÄ (‚ü®f, _‚ü© : Hom (ő£ {d : D // ‚ąÄ (e : E), Hom (F.F d) (G.F e)}) (ő£ {d : D // ‚ąÄ (e : E), Hom (F.F d) (G.F e)})) (‚ü®g, _‚ü© : Hom (ő£ {d : D // ‚ąÄ (e : E), Hom (F.F d) (G.F e)}) (ő£ {d : D // ‚ąÄ (e : E), Hom (F.F d) (G.F e)})),
