/-!
# Category Theory in Context - Section 1.3

We introduce functors, contravariant functors and the category of small categories.
We continue to use the custom definition of a category from Section 1.1.

-/

namespace CategoryInContext

open Category

-- definition 1.3.1
class Functor (őĪ ő≤ : Type*) [C : Category őĪ] [D : Category ő≤] where
  -- data
  -- map on objects
  F : őĪ ‚Üí ő≤
  -- map on morphisms
  homF {X Y : őĪ} : C.Hom X Y ‚Üí D.Hom (F X) (F Y)
  -- properties / laws
  -- need to qualify id to avoid clash with id in root namespace.
  map_id (X : őĪ) : homF (id X) = Category.id (F X)
  map_comp {X Y Z : őĪ} (f : C.Hom X Y) (g : C.Hom Y Z) :
    homF (f ‚Čę g) = homF f ‚Čę homF g

def EndoFunctor (őĪ : Type*) [Category őĪ] := @Functor őĪ őĪ

def IdFunctor {őĪ : Type*} [Category őĪ] : Functor őĪ őĪ where
  F X := X
  homF f := f
  map_id _ := rfl
  map_comp _ _ := rfl

-- examples 1.3.2.i
def PowerSetFunctor : Functor Type Type where
  F X := Set X
  homF f := Set.image f
  map_id X := by
    simp [Category.id]
    funext x
    simp only [Set.image_id']
  map_comp f g := by
    simp [Category.comp]
    funext x
    simp only [Function.comp_apply]
    exact Eq.symm (Set.image_image g f x)

-- todo: add 1.3.2.ii-xi, once we have appropriate categories defined
-- todo: add theorem 1.3.3

-- definition 1.3.5
class ContraFunctor (őĪ ő≤ : Type*) [C : Category őĪ] [D : Category ő≤] where
  -- data
  -- map on objects
  F : őĪ ‚Üí ő≤
  -- map on morphisms
  homF {X Y : őĪ} : C.Hom X Y ‚Üí D.Hom (F Y) (F X)
  -- properties / laws
  -- need to qualify id to avoid clash with id in root namespace.
  map_id (X : őĪ) : homF (id X) = Category.id (F X)
  map_comp {X Y Z : őĪ} (f : C.Hom X Y) (g : C.Hom Y Z) :
    homF (f ‚Čę g) = homF g ‚Čę homF f

-- example 1.3.7.i
def PowerSetContraFunctor : ContraFunctor Type Type where
  F X := Set X
  homF f := Set.preimage f
  map_id X := by
    simp [Category.id]
    funext x
    simp only [Set.preimage_id']
  map_comp f g := by
    simp [Category.comp]
    funext x
    simp only [Function.comp_apply]
    rfl

-- todo: add 1.3.7.ii-vi, once we have appropriate categories defined

-- lemma 1.3.8
theorem Functor.iso_preserve {őĪ ő≤ : Type*} [C : Category őĪ] [D : Category ő≤]
    (F : Functor őĪ ő≤) {X Y : őĪ} (f : C.Hom X Y) (hf : IsIso f) :
    IsIso (F.homF f) := by
  rw [iso_iff_isIso] at hf
  obtain ‚ü®‚ü®f, g, hg, hf‚ü©, rfl‚ü© := hf
  use F.homF g
  simp only
  constructor
  ¬∑ rw [‚Üź F.map_comp]
    rw [hg]
    rw [F.map_id]
  ¬∑ rw [‚Üź F.map_comp]
    rw [hf]
    rw [F.map_id]

-- example 1.3.9
def g_set_left_action (őĪ : Type*) [Group őĪ] (ő≤ : Type*) :
  @Functor Unit (Set ő≤) (Category.Monoid őĪ) _ := by sorry

def g_set_right_action (őĪ : Type*) [Group őĪ] (ő≤ : Type*) :
  @ContraFunctor Unit (Set ő≤) (Category.Monoid őĪ) _ := by sorry

-- todo: corollary 1.3.10, we haven't defined ‚ĀĽ¬Ļ on isomorphisms yet

-- definition 1.3.11 / exercise 1.3.iv
def Hom_c_? {őĪ : Type*} [Category őĪ] (c : őĪ) : Functor őĪ Type where
  F Y := Hom c Y
  homF {Y Z : őĪ} (f : Hom Y Z) (g : Hom c Y) := g ‚Čę f
  map_id Y := by sorry
  map_comp {Y Z W : őĪ} (f : Hom Y Z) (g : Hom Z W) := by sorry

def Hom_?_c {őĪ : Type*} [Category őĪ] (c : őĪ) : ContraFunctor őĪ Type where
  F X := Hom X c
  homF {X Y : őĪ} (f: Hom X Y) (g : Hom Y c) := f ‚Čę g
  map_id X := by sorry
  map_comp {X Y Z : őĪ} (f : Hom X Y) (g : Hom Y Z) := by sorry

-- definition 1.3.12
instance CatProduct {őĪ ő≤ : Type*} [C : Category őĪ] [D : Category ő≤] : Category (őĪ √ó ő≤) where
  Hom X Y := (C.Hom X.1 Y.1) √ó (D.Hom X.2 Y.2)
  id X := (id X.1, id X.2)
  comp f g := (f.1 ‚Čę g.1, f.2 ‚Čę g.2)
  id_comp _ := by repeat rw [id_comp]
  comp_id _ := by repeat rw [comp_id]
  assoc _ _ _ := by repeat rw [assoc]

/--
A functor from the product category (bifunctor) to another category gives
rise to functors from each factor category to the target category when
fixing an object in the other factor.

this is not proved in the book, but it is easy to prove and useful
-/
def prod_functor_functorial_1 {őĪ ő≤ ő≥ : Type*} [C : Category őĪ] [D : Category ő≤]
    [Inhabited ő≤] [E : Category ő≥] (F : Functor (őĪ √ó ő≤) ő≥) : Functor őĪ ő≥ where
  F := fun X => F.F (X, default)
  homF := fun {X Y} f => F.homF (f, id default)
  map_id X := by
    rw [‚Üź F.map_id]
    congr
  map_comp f g := by
    rw [‚Üź F.map_comp]
    congr
    rw [id_comp]

def prod_functor_functorial_2 {őĪ ő≤ ő≥ : Type*} [C : Category őĪ] [D : Category ő≤]
    [Inhabited őĪ] [E : Category ő≥] (F : Functor (őĪ √ó ő≤) ő≥) : Functor ő≤ ő≥ where
  -- todo: find a clever way to prove using prod_functor_functorial_1
  F := fun Y => F.F (default, Y)
  homF := fun {Y Z} f => F.homF (id default, f)
  map_id Y := by
    rw [‚Üź F.map_id]
    congr
  map_comp f g := by
    rw [‚Üź F.map_comp]
    congr
    rw [comp_id]

-- definition 1.3.13
def Hom_bifunctor (őĪ : Type*) [C : Category őĪ] : Functor (Opposite őĪ √ó őĪ) Type where
  -- without the C. qualification Lean picks up C.opp.Hom and hilarity ensues
  F X := C.Hom X.1 X.2
  homF {X Y} f g := f.1 ‚Čę g ‚Čę f.2
  map_id X := by
    funext g
    simp [Category.id]
    rw [id_comp]
    rw [comp_id]
  map_comp f g := by
    funext h
    simp [comp]
    repeat rw [assoc]

-- Category of small (and locally small) categories, which is locally small but not small.
-- A small category is a category whose objects form a set, which in Lean we take
-- to mean a Type in some universe. Large categories are not expressable in Lean
-- as they would lead to inconsistencies.
-- objects are pairs (őĪ, C) where őĪ is a Type and C is a Category structure on őĪ
-- categories need two universes, one for objects and one for morphisms.
def Cat.{u, v} : Type (max (u+1) (v+1)) :=
  ő£ (őĪ : Type u), Category.{u, v} őĪ

def Functor.comp {őĪ ő≤ ő≥ : Type*} [C : Category őĪ] [D : Category ő≤] [E : Category ő≥]
    (F : Functor őĪ ő≤) (G : Functor ő≤ ő≥) : Functor őĪ ő≥ where
  F x := G.F (F.F x)
  homF f := G.homF (F.homF f)
  map_id X := by simp [F.map_id, G.map_id]
  map_comp f g := by simp [F.map_comp, G.map_comp]

universe u v
instance : Category Cat.{u, v} where
  Hom C D := @Functor C.1 D.1 C.2 D.2
  -- adding explicit letI to help typeclass resolution as suggested by Claude.
  id C := letI := C.2; {
    F x := x
    homF f := f
    map_id _ := rfl
    map_comp _ _ := rfl
  }
  comp {C D E} F G := @Functor.comp C.1 D.1 E.1 C.2 D.2 E.2 F G
  id_comp := by dsimp [Functor.comp]; simp
  comp_id := by dsimp [Functor.comp]; simp
  assoc := by dsimp [Functor.comp]; simp

def Category.CatIsomorphism (C D : Cat) := Isomorphism C.1 D.1
def Category.CatIsomorphic (C D : Cat) := Isomorphic C.1 D.1

-- example 1.3.14.i
def Op : Functor Cat Cat where
  F C := ‚ü®Opposite C.1, @Category.opp (Opposite C.1) C.2‚ü©
  homF {C D} F := letI := C.2; letI := D.2; {
    F := F.F
    homF := F.homF
    map_id X := F.map_id X
    map_comp f g := by
      rw [Functor.homF]
      repeat rw [comp]
      simp only
      apply F.map_comp
  }
  map_id C := by sorry
  map_comp {C D E} F G := by sorry

