    (F : @CategoryInContext.Functor D C CD CC) (G : @CategoryInContext.Functor E C CE CC) :
    ‚ąÄ (‚ü®X, _, _‚ü© : { d : D // ‚ąÄ (e : E), Hom (F.F d) (G.F e) }) (x : Hom (‚ü®X, _, _‚ü© : { d : D // ‚ąÄ (e : E), Hom (F.F d) (G.F e)}) (‚ü®X, _, _‚ü© : { d : D // ‚ąÄ (e : E), Hom (F.F d) (G.F e)})),
