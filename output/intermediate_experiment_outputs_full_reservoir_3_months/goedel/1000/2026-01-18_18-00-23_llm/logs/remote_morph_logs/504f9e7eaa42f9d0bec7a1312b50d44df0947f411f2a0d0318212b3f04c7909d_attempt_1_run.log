      simp [id_comp]
      <;>
      aesop
    })
  <;>
    (try {
      aesop
    })
  <;>
    (try {
      simp_all [id_comp]
      <;>
      aesop
    })

  map_comp {Y Z W : őĪ} (f : Hom Y Z) (g : Hom Z W) := by
    funext h
    simp [comp_assoc]
    <;>
    (try simp_all [comp_assoc]) <;>
    (try aesop)
    <;>
    (try {
      simp_all [comp_assoc]
      <;>
      aesop
    })

