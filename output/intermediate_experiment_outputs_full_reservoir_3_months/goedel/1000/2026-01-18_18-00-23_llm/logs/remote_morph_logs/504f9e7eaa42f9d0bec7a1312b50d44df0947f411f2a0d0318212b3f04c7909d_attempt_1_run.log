/-!
# Category Theory in Context - Section 1.3

We introduce functors, contravariant functors and the category of small categories.
We continue to use the custom definition of a category from Section 1.1.

-/

namespace CategoryInContext

open Category

-- definition 1.3.1
class Functor (őĪ ő≤ : Type*) [C : Category őĪ] [D : Category ő≤] where
  -- data
  -- map on objects
  F : őĪ ‚Üí ő≤
  -- map on morphisms
  homF {X Y : őĪ} : C.Hom X Y ‚Üí D.Hom (F X) (F Y)
  -- properties / laws
  -- need to qualify id to avoid clash with id in root namespace.
  map_id (X : őĪ) : homF (id X) = Category.id (F X)
  map_comp {X Y Z : őĪ} (f : C.Hom X Y) (g : C.Hom Y Z) :
    homF (f ‚Čę g) = homF f ‚Čę homF g

def EndoFunctor (őĪ : Type*) [Category őĪ] := @Functor őĪ őĪ

def IdFunctor {őĪ : Type*} [Category őĪ] : Functor őĪ őĪ where
  F X := X
  homF f := f
  map_id _ := rfl
  map_comp _ _ := rfl

-- examples 1.3.2.i
def PowerSetFunctor : Functor Type Type where
  F X := Set X
  homF f := Set.image f
  map_id X := by
    simp [Category.id]
    funext x
    simp only [Set.image_id']
  map_comp f g := by
    simp [Category.comp]
    funext x
    simp only [Function.comp_apply]
    exact Eq.symm (Set.image_image g f x)

-- todo: add 1.3.2.ii-xi, once we have appropriate categories defined
-- todo: add theorem 1.3.3

-- definition 1.3.5
class ContraFunctor (őĪ ő≤ : Type*) [C : Category őĪ] [D : Category ő≤] where
  -- data
  -- map on objects
  F : őĪ ‚Üí ő≤
  -- map on morphisms
  homF {X Y : őĪ} : C.Hom X Y ‚Üí D.Hom (F Y) (F X)
  -- properties / laws
  -- need to qualify id to avoid clash with id in root namespace.
  map_id (X : őĪ) : homF (id X) = Category.id (F X)
  map_comp {X Y Z : őĪ} (f : C.Hom X Y) (g : C.Hom Y Z) :
    homF (f ‚Čę g) = homF g ‚Čę homF f

-- example 1.3.7.i
def PowerSetContraFunctor : ContraFunctor Type Type where
  F X := Set X
  homF f := Set.preimage f
  map_id X := by
    simp [Category.id]
    funext x
    simp only [Set.preimage_id']
  map_comp f g := by
    simp [Category.comp]
    funext x
    simp only [Function.comp_apply]
    rfl

-- todo: add 1.3.7.ii-vi, once we have appropriate categories defined

-- lemma 1.3.8
theorem Functor.iso_preserve {őĪ ő≤ : Type*} [C : Category őĪ] [D : Category ő≤]
    (F : Functor őĪ ő≤) {X Y : őĪ} (f : C.Hom X Y) (hf : IsIso f) :
    IsIso (F.homF f) := by
  rw [iso_iff_isIso] at hf
  obtain ‚ü®‚ü®f, g, hg, hf‚ü©, rfl‚ü© := hf
  use F.homF g
  simp only
  constructor
  ¬∑ rw [‚Üź F.map_comp]
    rw [hg]
    rw [F.map_id]
  ¬∑ rw [‚Üź F.map_comp]
    rw [hf]
    rw [F.map_id]

-- example 1.3.9
