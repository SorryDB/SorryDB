theorem syn_all_cities :
  (∀ i j : ℕ, (i.mk j : ℕ) = 1) ↔ 1 = 0 := by
  have h₁ : (∀ i j : ℕ, (i.mk j : ℕ) = 1) → 1 = 0 := by
