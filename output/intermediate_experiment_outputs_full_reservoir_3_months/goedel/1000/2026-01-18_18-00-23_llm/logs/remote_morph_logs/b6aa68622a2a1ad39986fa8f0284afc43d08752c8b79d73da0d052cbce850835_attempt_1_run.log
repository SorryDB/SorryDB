def fail₂ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {e : Exp (ZMod p) (ZMod p)} {cs : Cs p (ZMod p)},
    e.eval ≠ (bits2num args) -> (Cs.eq0 (bits2num_e args - e) cs).eval = .n := by
  intros w args e cs h
  have h₁ : (bits2num_e args).eval = bits2num args := by
    unfold bits2num_e bits2num
    induction w with
    | zero =>
      simp
    | succ w ih =>
      simp_all [Vector.foldl, Exp.eval, ZMod.nat_cast_self]
      <;>
      (try ring_nf at * <;> simp_all) <;>
      (try norm_num) <;>
      (try omega) <;>
      (try
        {
          simp_all [Vector.foldl, Exp.eval, ZMod.nat_cast_self]
          <;>
          ring_nf at * <;>
          simp_all
        })
  simp [Cs.eval, h₁, sub_eq_zero, h]
  <;>
  (try contradiction) <;>
  (try
    {
      simp_all [denotation]
      <;>
      omega
    })
