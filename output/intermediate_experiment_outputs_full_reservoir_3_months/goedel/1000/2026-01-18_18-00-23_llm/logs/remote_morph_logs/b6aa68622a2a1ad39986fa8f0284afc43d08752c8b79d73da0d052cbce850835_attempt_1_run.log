    have h₃ := h 1 0
    simp [Nat.mk] at h₂ h₃
    <;> norm_num at h₂ h₃ ⊢
    <;> simp_all
  have h₂ : 1 = 0 → (∀ i j : ℕ, (i.mk j : ℕ) = 1) := by
    intro h
    exfalso
    norm_num at h
  exact ⟨h₁, h₂⟩
