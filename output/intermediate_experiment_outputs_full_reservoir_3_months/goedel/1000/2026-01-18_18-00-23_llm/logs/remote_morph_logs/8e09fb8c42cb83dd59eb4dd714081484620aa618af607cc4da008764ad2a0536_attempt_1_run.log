theorem ring_property (R : Type*) [Ring R] : ∀ (a b c : R), (a + b) * c = a * c + b * c := by
  intro a b c
  simp [add_mul]
  <;>
  (try ring_nf) <;>
  (try simp_all [add_mul, mul_add, mul_assoc]) <;>
