theorem test {A : Type u} {U V : A → Type v}
  (hAUBV : ((a : A) → U a) = ((a : A) → V a))
  : U = V := by
  have h : U = V := by
    apply funext
    intro a
    have h₁ : U a = V a := by
      have h₂ : (((a : A) → U a) = ((a : A) → V a)) := hAUBV
      have h₃ : (fun (a : A) => U a) a = (fun (a : A) => V a) a := by
        rw [h₂]
      have h₄ : U a = V a := by
        simpa using h₃
      exact h₄
    exact h₁
  exact h
```
