lemma injective_zHat :
    Function.Injective j₂ := by
  have h : Function.Injective (j₂ : 𝓞^ →ₐ[ℤ] D^) := by
    -- Use the fact that the tensor product with a flat ring (ZHat) is injective.
    have h₁ : Function.Injective (j₂ : 𝓞^ →ₐ[ℤ] D^) := by
      -- Since ZHat is a flat ℤ-module, the tensor product with it preserves injectivity.
      -- Specifically, the map 𝓞^ → D^ is injective because it is constructed from injective maps.
      apply (Function.Injective.comp _ (Algebra.map_injective _ (by infer_instance)))
      -- The composition of injective functions is injective.
      -- The first map is injective because it is a tensor product with an injective map.
      -- The second map is injective because it is an inclusion of a subalgebra.
      intro x y hxy
      simp only [AlgebraHom.coe_coe, Function.funext_iff] at hxy
      simp_all [AlgebraHom.ext_iff]
      <;>
      (try contradiction) <;>
      (try aesop)
      <;>
      (try
        {
          -- Use the fact that ZHat is a flat ℤ-module to deduce injectivity.
          -- Specifically, if the tensor product of two elements with ZHat is zero, then the elements themselves must be zero.
          simp_all [AlgebraHom.ext_iff]
          <;>
          aesop
        })
    exact h₁
  exact h
