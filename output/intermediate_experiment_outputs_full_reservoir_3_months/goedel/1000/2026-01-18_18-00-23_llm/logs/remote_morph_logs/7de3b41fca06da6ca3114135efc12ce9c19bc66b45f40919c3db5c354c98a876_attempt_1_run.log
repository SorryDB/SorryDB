theorem injective_zHat :
    Function.Injective j₂ := by
  have h : Function.Injective j₂ := by
    -- Use the fact that the composition of injective functions is injective
    have h₁ : Function.Injective (fun x : 𝓞^ => (Algebra.TensorProduct.includeRight : 𝓞^ →ₐ[ℤ] ℚ ⊗ 𝓞^) x) := by
      -- The includeRight map is injective because it is a tensor product with a ring
      apply AlgebraMap.injective
      <;> try infer_instance
      <;> try simp_all [AlgebraMap, AlgebraMap]
      <;> try norm_num
      <;> try ring_nf
      <;> try aesop
    have h₂ : Function.Injective (fun x : ℚ ⊗ 𝓞^ => ((Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat).symm : ℚ ⊗ 𝓞^ ≃ₐ[ℤ] D ⊗ ZHat).toAlgHom x) := by
      -- The associativity isomorphism is bijective, hence injective
      apply (Equiv.injective ((Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat).symm))
    -- Compose the injective functions to get the desired injectivity
    have h₃ : Function.Injective (fun x : 𝓞^ => ((Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat).symm : ℚ ⊗ 𝓞^ ≃ₐ[ℤ] D ⊗ ZHat).toAlgHom ((Algebra.TensorProduct.includeRight : 𝓞^ →ₐ[ℤ] ℚ ⊗ 𝓞^) x)) := by
      apply Function.Injective.comp h₂ h₁
    -- Simplify the expression to match the definition of j₂
    simpa [j₂] using h₃
  exact h
