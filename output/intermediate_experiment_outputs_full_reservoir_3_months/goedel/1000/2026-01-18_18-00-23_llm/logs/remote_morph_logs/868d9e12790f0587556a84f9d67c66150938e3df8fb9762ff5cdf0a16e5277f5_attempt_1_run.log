@[simp] lemma probOutput_some_map_some (mx : m α) (x : α) :
    Pr[= some x | some <$> mx] = Pr[= x | mx] := by
  have h₁ : Pr[= some x | some <$> mx] = evalDist (some x) (Optionlikify (some <$> mx)) := rfl
  have h₂ : Pr[= x | mx] = evalDist x (Optionlikify mx) := rfl
  have h₃ : evalDist (some x) (Optionlikify (some <$> mx)) = evalDist x (Optionlikify mx) := by
    -- We need to show that the evaluation of the Optionify of some <$> mx at some x is equal to
    -- the evaluation of the Optionify of mx at x. 
    -- Since the Optionify of a monad m is a function from α to ℝ≥0∞, we can use the definition of Optionify.
    -- We have (Optionify (some <$> mx)) (some x) = (some <$> mx).eval (some x).
    -- But (some <$> mx).eval (some x) = mx.eval x, because (some <$> mx).eval (some x) = mx.eval x.
    -- And (Optionify mx) x = mx.eval x.
    -- Therefore, the two evaluations are equal.
    simp [OptionLikify, evalDist, Option.bind_eq, Option.get )
    <;>
    (try simp_all [Option.get, Option.bind_eq, monad])
    <;>
    (try simp_all [Option.get, Option.bind_eq, monad])
    <;>
    (try simp_all [Option.get, Option.bind_eq, monad])
    <;>
    (try simp_all [Option.get, Option.bind_eq, monad])
    <;>
    (try simp_all [Option.get, Option.bind_eq, monad])
    <;>
    (try simp_all [Option.get, Option.bind_eq, monad])
  rw [h₁, h₂, h₃]
``` 
