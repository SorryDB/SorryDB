instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) := by
  have h : Nonempty (S : TopologicalSpace) := by simpa using inferInstance
  -- Use the injectivity of the codomain
  haveI : Injective S := inferInstance
  -- Use the fact that S is injective to deduce that its image is injective
  exact Injective.of_comp (fun x : LightProfinite => lightToProfinite.map x) inferInstance
