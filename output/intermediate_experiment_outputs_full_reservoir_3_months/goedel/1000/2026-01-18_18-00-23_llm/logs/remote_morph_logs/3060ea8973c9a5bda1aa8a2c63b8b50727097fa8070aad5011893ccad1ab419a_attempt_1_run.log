noncomputable def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    use ∅
    <;> simp_all [Set.subset_def]
    <;> tauto
  indep_subset := by
    intro S hS T hT hTS
    obtain ⟨M, hM, hS'⟩ := hS
    exact ⟨M, hM, hTS.mono_right hS'⟩
  indep_aug := by sorry
  indep_maximal := by sorry
