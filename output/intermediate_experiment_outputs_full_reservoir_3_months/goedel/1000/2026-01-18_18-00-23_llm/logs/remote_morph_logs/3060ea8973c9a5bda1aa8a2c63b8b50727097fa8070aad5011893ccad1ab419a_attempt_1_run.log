def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    simp [IsMatching]
    use ∅
    <;> simp_all [Set.subset_empty]
    <;> aesop
  
  indep_subset := by
    intro S T hT hS
    obtain ⟨M, hM, hM'⟩ := hT
    refine ⟨M, hM, _⟩
    exact hM'.trans hS
  
  indep_aug := by
    intro X S hS hmax
    sorry
  
  indep_maximal := by
    intro S hS
    sorry
  
  _root_.ExistsMaximalSubsetProperty := by
    intro X hX
    classical
    have h₁ : ∃ M, G.IsMatching M ∧ S ⊆ V(G, M) := by
      sorry
    have h₂ : ∀ (X : Set α), X ⊆ G.vertexSet → ∃ (S : Set α), S ⊆ X ∧ ∃ (M : Set β), G.IsMatching M ∧ S ⊆ V(G, M) ∧ ∀ (S' : Set α), ∃ (M' : Set β), G.IsMatching M' ∧ S' ⊆ V(G, M') → ¬(S ⊆ S') := by
      sorry
    sorry
