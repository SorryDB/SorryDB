### Complete Lean 4 Proof

```lean4
instance (α : Type) [Unique α] : SampleableType α where
  selectElem := return default
  mem_support_selectElem x := by
    have h₁ : x = default := by
      have h₂ : x = default := by
        have h₃ : x = default := by
          exact Unique.eq_default x
        exact h₃
      exact h₂
    rw [h₁]
    simp [support_eq]
    <;> aesop
  
  probOutput_selectElem_eq x y := by
    have h₁ : x = default := by
      have h₂ : x = default := by
        have h₃ : x = default := by
          exact Unique.eq_default x
        exact h₃
      exact h₂
    have h₂ : y = default := by
      have h₃ : y = default := by
        have h₄ : y = default := by
          exact Unique.eq_default y
        exact h₄
      exact h₃
    rw [h₁, h₂]
    <;> simp [support_eq, return, ProbComp]
    <;> aesop
  
  probFailure_selectElem := by
    simp [support_eq, return, ProbComp]
    <;> aesop
```
