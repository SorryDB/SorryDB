Looking at this problem, I need to derive a contradiction from the assumption that `Disjunction` can eliminate to `Type` (not just `Prop`).

The classic proof uses the fact that if we could eliminate to `Type`, we could distinguish between different proofs of `True`, which contradicts proof irrelevance.

Let me construct two different proofs of `Disjunction True True` and show they must be equal (by `rfl` since they're both proofs of a `Prop`), but also that they must map to different types, leading to a contradiction.

```lean
open Disjunction
example
    (rec : ∀ (P Q : Prop) (motive : Disjunction P Q → Type)
      (h_left : ∀ hp : P, motive (left hp)) (h_right : ∀ hq : Q, motive (right hq))
      (h : Disjunction P Q), motive h)
    (comp_left : ∀ P Q motive h_left h_right (hp : P),
      rec P Q motive h_left h_right (left hp) = h_left hp)
    (comp_right : ∀ P Q motive h_left h_right (hq : Q),
      rec P Q motive h_right h_right (right hq) = h_right hq) : False := by
  let motive : Disjunction True True → Type := fun _ => Bool
  let h_left : ∀ hp : True, motive (left hp) := fun _ => true
  let h_right : ∀ hq : True, motive (right hq) := fun _ => false
  have e1 : rec True True motive h_left h_right (left True.intro) = true := comp_left True True motive h_left h_right True.intro
  have e2 : rec True True motive h_left h_right (right True.intro) = false := comp_right True True motive h_left h_right True.intro
  have : left True.intro = right True.intro := rfl
  rw [this] at e1
  rw [e2] at e1
  cases e1
```
