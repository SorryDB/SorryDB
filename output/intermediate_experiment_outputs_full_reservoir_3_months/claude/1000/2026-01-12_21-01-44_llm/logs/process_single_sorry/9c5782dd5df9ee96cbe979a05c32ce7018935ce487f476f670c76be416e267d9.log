```lean
theorem Category.iso_of_mono_and_split_epi {X Y : α} (f : Hom X Y)
    (hm : Mono f) (he : split_epi f) : IsIso f := by
  obtain ⟨g, hfg⟩ := he
  have hfe : Epi f := retraction_epi f g hfg
  refine ⟨g, hfg, ?_⟩
  have : f ≫ (g ≫ f) = f ≫ id Y := by simp [← assoc, hfg]
  exact hfe _ _ this
