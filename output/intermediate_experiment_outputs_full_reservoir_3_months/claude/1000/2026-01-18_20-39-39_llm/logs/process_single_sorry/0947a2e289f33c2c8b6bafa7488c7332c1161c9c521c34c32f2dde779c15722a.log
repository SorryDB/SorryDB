lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h : ∫ x in 0..π, sin x * f (cos x) = ∫ x in 0..π, -(- sin x) * f (cos x) := by ring_nf
  rw [h]
  rw [intervalIntegral.integral_comp_mul_deriv (fun x _ => hasDerivAt_cos x)
    (fun x _ => continuous_sin.neg.continuousAt) (fun x => f)]
  simp [cos_zero, cos_pi]
```
