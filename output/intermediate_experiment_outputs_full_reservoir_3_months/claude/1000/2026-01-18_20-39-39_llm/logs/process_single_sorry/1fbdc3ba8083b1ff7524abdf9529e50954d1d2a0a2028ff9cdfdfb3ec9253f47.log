The key insight is that the localizing sequence witnesses that for large enough stopping times, the stopped process is right-continuous. Since the stopping times tend to infinity almost surely, and the stopped process agrees with `X` before the stopping time, we can recover right-continuity of `X` almost everywhere.

```lean
lemma Locally.rightContinuous
    (hX : Locally (fun X ↦ ∀ ω, Function.RightContinuous (X · ω)) 𝓕 X P) :
    ∀ᵐ ω ∂P, Function.RightContinuous (X · ω) := by
  filter_upwards [hX.IsLocalizingSequence.tendsto_top] with ω hω
  rw [WithTop.tendsto_atTop_nhds_top_iff] at hω
  intro t
  obtain ⟨n, hn⟩ := hω t
  specialize hn n le_rfl
  have hRC := hX.stoppedProcess n ω
  have hmem : ⊥ < hX.localSeq n ω := lt_of_le_of_lt bot_le hn
  have hle : t < hX.localSeq n ω := hn
  rw [Function.RightContinuous] at hRC ⊢
  have : stoppedProcess (fun i => {ω | ⊥ < hX.localSeq n ω}.indicator (X i)) (hX.localSeq n) t ω = X t ω := by
    rw [stoppedProcess_eq_of_le (le_of_lt hle), Set.indicator_of_mem hmem]
  rw [← this]
  have hRC' := hRC t
  convert hRC' using 1
  ext s
  by_cases hs : s < hX.localSeq n ω
  · rw [stoppedProcess_eq_of_le (le_of_lt hs), Set.indicator_of_mem hmem]
  · push_neg at hs
    rw [stoppedProcess_eq_of_ge hs, stoppedProcess_eq_of_ge hs, Set.indicator_of_mem hmem]
