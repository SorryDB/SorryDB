lemma IsMatching.symmDiff_maxDegree_le_two (hM : G.IsMatching M) (hM' : G.IsMatching M') :
    (hM.restrict₂ hM').MaxDegreeLE 2 := by
  rw [maxDegreeLE_iff']
  intro v hv
  rw [eDegree_eq_encard_inc]
  have h1 : E(hM.restrict₂ hM', v) ⊆ (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) := by
    intro e he
    simp only [IsMatching.restrict₂, loopRemove_inc, restrict_inc] at he
    obtain ⟨⟨he_symmDiff, he_inc⟩, _⟩ := he
    cases he_symmDiff with
    | inl h => exact Or.inl ⟨h.1, he_inc⟩
    | inr h => exact Or.inr ⟨h.1, he_inc⟩
  calc E(hM.restrict₂ hM', v).encard 
      ≤ ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := encard_le_encard h1
    _ ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := encard_union_le _ _
    _ ≤ 1 + 1 := add_le_add (hM.degree_le_one v) (hM'.degree_le_one v)
    _ = 2 := by norm_num
