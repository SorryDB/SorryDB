- We need to show that getting the value at port `i` returns `f i`

The key insight is that `liftFinf` creates an association list where each `Fin n` index maps to `f` applied to that index.

```lean
    theorem RelIO.liftFinf_get {S} {n : Nat} {i : Fin n} {f : Fin n → RelIO S}:
      (RelIO.liftFinf n f).getIO i = f i := by
        unfold RelIO.liftFinf PortMap.getIO
        simp only [List.toList_toAssocList, List.map_map]
        induction n with
        | zero => exact i.elim0
        | succ n' ih =>
          simp only [fin_range, List.map_cons, List.map_map, Function.comp_apply]
          cases Nat.decEq i.val 0 with
          | isTrue h =>
            have hi : i = ⟨0, Nat.zero_lt_succ n'⟩ := Fin.ext h
            subst hi
            simp only [AssocList.find?_cons_eq, Option.getD_some]
          | isFalse h =>
            have : ∃ j : Fin n', i = lift_fin j := by
              obtain ⟨k, hk⟩ := Nat.exists_eq_succ_of_ne_zero h
              exact ⟨⟨k, Nat.lt_of_succ_lt_succ (hk ▸ i.isLt)⟩, Fin.ext (by simp [lift_fin, hk])⟩
            obtain ⟨j, hj⟩ := this
            subst hj
            simp only [lift_fin, Fin.val_succ, AssocList.find?_cons_of_false, Nat.add_eq_zero_iff,
              and_false, not_false_eq_true]
            have := @ih j (f ∘ lift_fin)
            simp only [PortMap.getIO, List.toList_toAssocList, List.map_map] at this
            convert this using 2
            · ext x
              simp only [Function.comp_apply]
              congr 1
            · simp only [Function.comp_apply]
