lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  apply le_antisymm
  · apply sSup_le
    intro a ha
    simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
    obtain ⟨D, hD, ha⟩ := ha
    obtain ⟨s, hs, rfl, _⟩ := R.carrier_span s (by sorry) -- need s ∈ S
    sorry
  · apply sSup_le
    intro a ha
    obtain ⟨D, hD, rfl, _⟩ := R.carrier_span a ha
    apply sSup_le_sSup
