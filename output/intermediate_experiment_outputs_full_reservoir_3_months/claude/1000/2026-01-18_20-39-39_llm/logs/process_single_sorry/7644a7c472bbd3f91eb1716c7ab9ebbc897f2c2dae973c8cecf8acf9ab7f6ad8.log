lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  apply le_antisymm
  · apply sSup_le
    intro a ha
    simp only [decomposition_of_refinement, Set.mem_iUnion] at ha
    obtain ⟨D, hD, haD⟩ := ha
    obtain ⟨s, hs, rfl, _⟩ := R.carrier_span s hs
    sorry
  · apply sSup_le
    intro a ha
    obtain ⟨D, hD, rfl, _⟩ := R.carrier_span a ha
    apply sSup_le
    intro b hb
    apply le_sSup
    simp only [decomposition_of_refinement, Set.mem_iUnion]
    exact ⟨D, hD, hb⟩
```
