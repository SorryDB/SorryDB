instance (α : Type) (n : ℕ) [SampleableType α] : SampleableType (Vector α n) where
  selectElem := by induction n with
  | zero => exact pure #v[]
  | succ m ih => exact Vector.push <$> ih <*> ($ᵗ α)
  mem_support_selectElem x := by induction n with
  | zero => simp
  | succ m ih =>
    simp only [support_seq, support_map, Set.mem_iUnion, Set.mem_image]
    refine ⟨x.pop, ih x.pop, x.back, SampleableType.mem_support_selectElem x.back, ?_⟩
    exact Vector.push_pop_back x
```
