theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  constructor
  · intro h
    exact ⟨w, h, rfl⟩
  · intro ⟨w', hw', heq⟩
    have : w = w' := by
      unfold coerceWord at heq
      exact List.map_injective_iff.mp (fun _ _ h => Subtype.ext (Subtype.val_injective h)) heq
    rw [this]
    exact hw'
```
