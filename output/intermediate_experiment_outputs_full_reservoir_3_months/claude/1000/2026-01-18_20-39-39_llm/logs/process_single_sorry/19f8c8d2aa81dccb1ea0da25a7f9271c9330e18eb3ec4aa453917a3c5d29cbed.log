      "\n  induction w generalizing cs with\n  | zero => omega\n  | succ w ih =>\n    unfold assert_bits_e\n    simp only [Vector.foldl, Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    cases hi : i with\n    | zero =>\n      simp only [hi, Vector.head_eq_getElem, Nat.zero_eq] at h' h''\n      have hne : args[0] * (1 - args[0]) ≠ 0 := by\n        intro heq\n        have := mul_eq_zero.mp heq\n        rcases this with hl | hr\n        · exact h' hl\n        · exact h'' (sub_eq_zero.mp hr)\n      unfold assert_bit_e\n      simp only [Cs.eval, Exp.eval, ite_eq_right_iff]\n      intro hcontra\n      exact hne hcontra\n    | succ j =>\n      have hj : j < w := Nat.lt_of_succ_lt_succ (hi ▸ h)\n      have hargs : args[i] = (args.extract 1 (w + 1))[j] := by\n        simp only [hi, Vector.getElem_extract]\n        congr; omega\n      rw [hargs] at h' h''\n      exact ih hj h' h''",
      "\n      sorry\n    | Nat.succ j =>\n      apply ih j (Nat.lt_of_succ_lt_succ h)\n      · simp only [Vector.getElem_extract]\n        convert h' using 2\n        omega\n      · simp only [Vector.getElem_extract]\n        convert h'' using 2\n        omega\n      · simp only [Vector.getElem_extract]\n        convert hne using 2\n        omega",
      "\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    cases Nat.lt_or_ge i w with\n    | inl hiw =>\n      apply ih\n      unfold assert_bits\n      simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true,\n        decide_eq_true_eq, not_forall, not_or]\n      use i, (by simp; omega)\n      constructor\n      · simp [Vector.getElem_tail]; convert h' using 1; omega\n      · simp [Vector.getElem_tail]; convert h'' using 1; omega\n    | inr hiw =>\n      have : i = w := Nat.le_antisymm (Nat.lt_succ_iff.mp hi) hiw\n      subst this\n      have hhead : args.head = args[w] := by simp [Vector.head_eq_getElem]\n      unfold assert_bit_e Cs.eval Exp.eval\n      have hne : args.head * (1 - args.head) ≠ 0 := by\n        rw [hhead]\n        intro heq\n        rcases mul_eq_zero.mp heq with h1 | h1\n        · exact h' h1\n        · exact h'' (sub_eq_zero.mp h1)\n      simp [hne]",
      "\n  induction w with\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e at *\n    unfold Vector.foldl at *\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract, Array.size_append,\n      List.size_toArray, List.length_cons, List.length_nil, zero_add, Array.size_extract,\n      Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil] at *\n    by_cases hi : i = 0\n    · subst hi\n      simp only [Vector.getElem_zero] at h' h''\n      have hne : args.head * (1 - args.head) ≠ 0 := by\n        intro heq\n        simp only [mul_eq_zero, sub_eq_zero] at heq\n        rcases heq with heq | heq\n        · exact h' heq\n        · exact h'' heq.symm\n      have : args = Vector.insertIdx args.tail 0 args.head := by\n        simp only [Vector.insertIdx_zero]\n        ext j hj\n        match j with\n        | .zero => simp; rfl\n        | .succ j => simp [add_comm]\n      simp only [Nat.add_one_sub_one, Vector.tail_eq_cast_extract, Vector.insertIdx_zero] at this\n      rw [this]\n      simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n        Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n        Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n        Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n      clear this\n      generalize (Array.foldl assert_bit_e (assert_bit_e cs args.head) (args.extract 1).toArray) = cs'\n      unfold assert_bit_e at cs'\n      simp only [Cs.eval]\n      unfold Exp.eval\n      simp only [hne, ↓reduceIte]\n    · have hi' : i - 1 < w := by omega\n      have hhead : args.head = args[0] := by simp\n      have htail : ∀ j (hj : j < w), args.tail[j] = args[j + 1] := by\n        intros j hj\n        simp [Vector.getElem_tail]\n      have hi'' : i = i - 1 + 1 := by omega\n      rw [hi''] at h' h''\n      rw [←htail (i-1) hi'] at h' h''\n      specialize @ih args.tail (assert_bit_e cs args.head) hi' h' h''\n      have : args = Vector.insertIdx args.tail 0 args.head := by\n        simp only [Vector.insertIdx_zero]\n        ext j hj\n        match j with\n        | .zero => simp; rfl\n        | .succ j => simp [add_comm]\n      simp only [Nat.add_one_sub_one, Vector.tail_eq_cast_extract, Vector.insertIdx_zero] at this\n      rw [this]\n      simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n        Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n        Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n        Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n      convert ih using 2\n      · ext j hj; simp [Vector.getElem_tail]\n      · unfold assert_bit_e; congr",
      "\n      simp only [Vector.insertIdx_zero]\n      ext j hj\n      match j with\n      | .zero => simp; rfl\n      | .succ j => simp [add_comm]\n    simp only [Nat.add_one_sub_one, Vector.tail_eq_cast_extract, Vector.insertIdx_zero] at this\n    rw [this]\n    unfold assert_bits_e Vector.foldl\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract, Array.size_append,\n      List.size_toArray, List.length_cons, List.length_nil, zero_add, Array.size_extract,\n      Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    have extract_eq : args.toArray.extract 1 (w + 1) = (args.extract 1 (w + 1)).toArray := by rfl\n    rw [extract_eq]\n    cases i with\n    | zero =>\n      -- The bad bit is at index 0, i.e., args.head\n      have hhead : args.head * (1 - args.head) ≠ 0 := by\n        simp only [Vector.head_eq_get, Fin.val_zero] at h' h''\n        intro heq\n        rw [mul_comm, sub_mul, one_mul, mul_comm] at heq\n        have : args[0] - args[0] * args[0] = 0 := heq\n        have hsub : args[0] * args[0] = args[0] := by\n          rw [sub_eq_zero] at this\n          exact this.symm\n        have : args[0] * (args[0] - 1) = 0 := by ring_nf; rw [mul_comm]; ring_nf; rw [hsub]; ring\n        rcases mul_eq_zero.mp this with hz | hz\n        · exact h' hz\n        · rw [sub_eq_zero] at hz; exact h'' hz\n      -- We need to show that the fold eventually hits .n\n      -- The assert_bit_e on args.head will fail\n      have min_eq : min (w + 1) (w + 1) - 1 = w := by simp\n      rw [←min_eq]\n      -- After folding over the tail, we apply assert_bit_e on args.head\n      -- The result depends on whether args.head passes the bit check\n      unfold assert_bit_e\n      -- We need to trace through the fold\n      -- The fold applies assert_bit_e to each element\n      -- After all folds, if any bit is bad, the result is .n\n      have : (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray).eval = denotation.n ∨\n             (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray).eval ≠ denotation.n := by\n        tauto\n      rcases this with hfold | hfold\n      · exact hfold\n      · -- If the fold succeeded, then we need the eq0 to fail\n        have tail_bits : assert_bits (args.extract 1 (w+1)) = true ∨ assert_bits (args.extract 1 (w+1)) = false := by tauto\n        rcases tail_bits with htail | htail\n        · -- tail passes, so the fold reduces to the inner cs, and eq0 fails\n          have fold_eq : (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray 0 w).eval =\n                         (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs).eval := by\n            have := @reduce₁ p _ w (args.extract 1) (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) htail\n            unfold assert_bits_e Vector.foldl at this\n            simp at this\n            exact this\n          have arr_eq : (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray) =\n                        (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray 0 w) := by simp\n          rw [arr_eq, fold_eq]\n          simp [Cs.eval, Exp.eval, hhead]\n        · -- tail fails\n          have := @ih (args.extract 1) (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) htail\n          unfold assert_bits_e Vector.foldl at this\n          simp at this\n          have arr_eq : (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray) =\n                        (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray 0 w) := by simp\n          rw [arr_eq, this]\n    | succ i =>\n      -- The bad bit is in the tail\n      have hi' : i < w := Nat.lt_of_succ_lt_succ hi\n      have htail : ¬ assert_bits (args.extract 1 (w+1)) := by\n        unfold assert_bits\n        simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true,\n          decide_eq_true_eq, not_forall, not_or, min_self, add_tsub_cancel_right,\n          Vector.getElem_extract]\n        use i, hi'\n        simp only [Vector.head_eq_get, Fin.val_zero] at h' h''\n        constructor\n        · convert h' using 1\n          simp [Vector.getElem_eq_get]\n        · convert h'' using 1\n          simp [Vector.getElem_eq_get]\n      have := @ih (args.extract 1) (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) htail\n      unfold assert_bits_e Vector.foldl at this\n      simp at this\n      have arr_eq : (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray) =\n                    (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1).toArray 0 w) := by simp\n      rw [arr_eq, this]",
      "\n  induction w generalizing cs with\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e at ih ⊢\n    unfold Vector.foldl at ih ⊢\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil] at ih ⊢\n    cases Nat.lt_or_ge i w with\n    | inl hi =>\n      have : min (w + 1) (w + 1) - 1 = w := by simp\n      rw [←this] at ih\n      have h_idx : args[i] = (args.extract 1 (w + 1))[i]'(by simp; exact hi) := by simp\n      rw [h_idx] at h' h''\n      exact ih h' h''\n    | inr hi =>\n      have : i = w := Nat.le_antisymm (Nat.lt_succ_iff.mp h) hi\n      subst this\n      have hne : args[w] * (1 - args[w]) ≠ 0 := by\n        intro heq\n        have : args[w] = 0 ∨ args[w] = 1 := by\n          by_contra hc\n          push_neg at hc\n          have := mul_eq_zero.mp heq\n          rcases this with hl | hr\n          · exact hc.1 hl\n          · exact hc.2 (sub_eq_zero.mp hr)\n        rcases this with h0 | h1\n        · exact h' h0\n        · exact h'' h1\n      unfold assert_bit_e Cs.eval Exp.eval\n      simp only [sub_zero, ite_eq_right_iff]\n      intro heq\n      exact hne heq",
      "\n  induction w generalizing cs i with\n  | zero => omega\n  | succ w ih =>\n    unfold assert_bits_e Vector.foldl\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    cases Nat.eq_or_lt_of_lt h with\n    | inl heq =>\n      subst heq\n      have hbad : args[w] * (1 - args[w]) ≠ 0 := by\n        intro hcontra\n        rcases mul_eq_zero.mp hcontra with hz | hz\n        · exact h' hz\n        · exact h'' (sub_eq_zero.mp hz)\n      have hhead : args.head = args[w] := by simp [Vector.head]\n      sorry\n    | inr hlt =>\n      apply ih\n      · exact Nat.lt_of_succ_lt_succ hlt\n      · simp [Vector.getElem_extract, add_comm]; exact h'\n      · simp [Vector.getElem_extract, add_comm]; exact h''",
      "\n  induction w with\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e Vector.foldl at ih ⊢\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract, Array.size_append,\n      List.size_toArray, List.length_cons, List.length_nil, zero_add, Array.size_extract,\n      Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    have htail : args.toArray.extract 1 (w + 1) = (args.extract 1 (w + 1)).toArray := rfl\n    rw [assert_bit_e, htail]\n    cases Nat.lt_or_ge i 1 with\n    | inl hi0 =>\n      have hi : i = 0 := Nat.lt_one_iff.mp hi0\n      subst hi\n      have hhead : args[0] = args.head := by\n        simp only [Vector.head]\n        rfl\n      rw [hhead] at h' h''\n      have hbad : args.head * (1 - args.head) ≠ 0 := by\n        intro heq\n        rw [mul_eq_zero, sub_eq_zero] at heq\n        rcases heq with heq | heq\n        · exact h' heq\n        · exact h'' heq.symm\n      have hmin : min (w + 1) (w + 1) - 1 = w := by simp\n      rw [←hmin]\n      clear hmin ih\n      induction w with\n      | zero =>\n        simp [assert_bits_e, Vector.foldl, Cs.eval, Exp.eval, hbad]\n      | succ w ih' =>\n        unfold assert_bits_e Vector.foldl at ih' ⊢\n        simp only [Vector.toArray_extract, Array.size_extract, Vector.size_toArray, min_self,\n          add_tsub_cancel_right, Array.foldl_toArray]\n        have htail' : (args.extract 1).toArray.extract 1 (w + 1) = (args.extract 1 (w + 2)).toArray.extract 1 (w + 1) := by\n          simp\n        rw [assert_bit_e]\n        specialize @ih' (args.extract 0 (w + 2)) (by simp; exact h') (by simp; exact h'')\n          (Cs.eq0 (Exp.v (args.extract 1 (w + 2)).head * (Exp.c 1 - Exp.v (args.extract 1 (w + 2)).head))\n            (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs))\n        simp at ih'\n        have : (args.extract 1 (w + 1 + 1)).toArray.extract 1 (w + 1) =\n               (args.extract 2 (w + 2)).toArray := by simp\n        rw [this]\n        have heq : args.head = (args.extract 0 (w + 2)).head := by simp [Vector.head, Vector.getElem_extract]\n        rw [heq]\n        have heq2 : (args.extract 1 (w + 2)).head = (args.extract 1 (w + 1 + 1)).head := by rfl\n        rw [heq2]\n        have heq3 : (args.extract 2 (w + 2)).toArray = ((args.extract 0 (w + 2)).extract 2 (w + 2)).toArray := by\n          simp\n        rw [heq3]\n        have heq4 : (args.extract 1 (w + 1 + 1)).head = ((args.extract 0 (w + 2)).extract 1 (w + 2)).head := by\n          simp [Vector.head, Vector.getElem_extract]\n        rw [heq4]\n        exact ih'\n    | inr hi0 =>\n      have hmin : min (w + 1) (w + 1) - 1 = w := by simp\n      rw [←hmin]\n      apply ih\n      · exact Nat.sub_lt_left_of_lt_add hi0 h\n      · simp [Vector.getElem_extract]\n        convert h'\n        omega\n      · simp [Vector.getElem_extract]\n        convert h''\n        omega",
      "\n  induction w generalizing cs with\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e at ih ⊢\n    unfold Vector.foldl at ih ⊢\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil] at ih ⊢\n    by_cases hi : i = 0\n    · subst hi\n      simp only [Vector.getElem_zero] at h' h''\n      have hne : args.head * (1 - args.head) ≠ 0 := by\n        intro heq\n        rw [mul_eq_zero, sub_eq_zero] at heq\n        rcases heq with heq | heq\n        · exact h' heq\n        · exact h'' heq.symm\n      have : (Array.foldl assert_bit_e (assert_bit_e cs args.head) (args.toArray.extract 1 (w + 1))).eval = .n := by\n        clear ih\n        generalize hcs' : assert_bit_e cs args.head = cs'\n        have hcs'_eval : cs'.eval = .n := by\n          rw [← hcs', assert_bit_e, Cs.eval]\n          simp only [Exp.eval, mul_one]\n          simp only [ite_eq_right_iff]\n          intro heq\n          exact (hne heq).elim\n        clear hne hcs' h' h''\n        generalize harr : args.toArray.extract 1 (w + 1) = arr\n        induction arr generalizing cs' with\n        | nil => exact hcs'_eval\n        | cons x xs ih' =>\n          simp only [Array.foldl_cons, List.foldl_cons]\n          apply ih'\n          rw [assert_bit_e, Cs.eval]\n          simp only [ite_eq_right_iff]\n          intro _\n          exact hcs'_eval\n      exact this\n    · have hi' : i - 1 < w := by omega\n      have hget : args[i] = (args.extract 1 (w + 1))[i - 1] := by\n        simp only [min_self, add_tsub_cancel_right, Vector.getElem_extract]\n        congr 1\n        omega\n      rw [hget] at h' h''\n      specialize @ih (args.extract 1 (w + 1)) (assert_bit_e cs args.head) hi' h' h''\n      simp only [min_self, add_tsub_cancel_right, Vector.toArray_extract] at ih\n      convert ih using 2\n      simp",
      "\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e at *\n    simp only [Vector.foldl] at *\n    cases Nat.lt_or_ge i w with\n    | inl hi =>\n      have htail : ∃ j, j < w ∧ ¬args.tail[j] = 0 ∧ ¬args.tail[j] = 1 := by\n        refine ⟨i, hi, ?_, ?_⟩\n        · simp only [Vector.getElem_tail]\n          convert h' using 2\n          omega\n        · simp only [Vector.getElem_tail]\n          convert h'' using 2\n          omega\n      rcases htail with ⟨j, hj, hj', hj''⟩\n      exact ih hj hj' hj''\n    | inr hi =>\n      have : i = w := Nat.eq_of_lt_succ_of_not_lt h (Nat.not_lt.mpr hi)\n      subst this\n      have hhead : ¬args.head = 0 ∧ ¬args.head = 1 := by\n        constructor\n        · convert h' using 2\n          simp [Vector.head]\n        · convert h'' using 2\n          simp [Vector.head]\n      clear h h' h'' ih\n      induction w with\n      | zero =>\n        simp [assert_bit_e, Cs.eval, Exp.eval]\n        intro heq\n        have : args.head * (1 - args.head) = 0 := heq\n        rcases mul_eq_zero.mp this with h | h\n        · exact hhead.1 h\n        · exact hhead.2 (sub_eq_zero.mp h)\n      | succ w ih =>\n        simp only [Vector.foldl, Array.foldl_eq_foldlM, Id.run] at *\n        apply ih\n        exact hhead",
      "\n  induction w with\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e at *\n    simp only [Vector.foldl] at *\n    cases Nat.lt_or_ge i w with\n    | inl hi =>\n      have htail : ∃ j, j < w ∧ ¬(args.tail)[j] = 0 ∧ ¬(args.tail)[j] = 1 := by\n        refine ⟨i, hi, ?_, ?_⟩\n        · simp only [Vector.getElem_tail]\n          convert h' using 2\n          omega\n        · simp only [Vector.getElem_tail]\n          convert h'' using 2\n          omega\n      rcases htail with ⟨j, hj, hj', hj''⟩\n      exact ih hj hj' hj''\n    | inr hi =>\n      have hi' : i = w := Nat.le_antisymm (Nat.lt_succ_iff.mp h) hi\n      subst hi'\n      have hhead : args[w] = args.head := by\n        simp only [Vector.head]\n        congr\n      rw [hhead] at h' h''\n      have hne : args.head * (1 - args.head) ≠ 0 := by\n        intro heq\n        rw [mul_eq_zero, sub_eq_zero] at heq\n        rcases heq with heq | heq\n        · exact h' heq\n        · exact h'' heq.symm\n      clear ih h' h''\n      induction w with\n      | zero =>\n        unfold assert_bit_e Cs.eval Exp.eval\n        simp [hne]\n      | succ w ih =>\n        exact ih args.tail hne",
      "\n  induction w with\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e at *\n    simp only [Vector.foldl] at *\n    cases Nat.lt_or_eq_of_lt (Nat.lt_succ_iff_lt_or_eq.mp h) with\n    | inl hi =>\n      have hargs : args = Vector.insertIdx args.tail 0 args.head := by\n        simp only [Vector.insertIdx_zero]\n        ext j hj\n        match j with\n        | .zero => simp; rfl\n        | .succ j => simp [add_comm]\n      simp only [Nat.add_one_sub_one, Vector.tail_eq_cast_extract, Vector.insertIdx_zero] at hargs\n      rw [hargs]\n      simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n        Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n        Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n        Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n      have heq : args.toArray.extract 1 (w + 1) = (args.extract 1 (w + 1)).toArray := rfl\n      rw [heq]\n      have hmin : min (w + 1) (w + 1) - 1 = w := by simp\n      have hi' : i < w := hi\n      have hargs_i : (args.extract 1 (w + 1))[i]'(by simp; exact hi') = args[i] := by\n        simp [Vector.getElem_extract]\n        congr 1\n        omega\n      specialize @ih (args.extract 1 (w + 1)) (assert_bit_e p (ZMod p) cs args.head)\n        i (by simp; exact hi') (by rw [hargs_i]; exact h') (by rw [hargs_i]; exact h'')\n      convert ih using 2\n      simp\n    | inr hi =>\n      have hargs : args = Vector.insertIdx args.tail 0 args.head := by\n        simp only [Vector.insertIdx_zero]\n        ext j hj\n        match j with\n        | .zero => simp; rfl\n        | .succ j => simp [add_comm]\n      simp only [Nat.add_one_sub_one, Vector.tail_eq_cast_extract, Vector.insertIdx_zero] at hargs\n      rw [hargs]\n      simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n        Array.size_append, List.size_toArray, List.length_con