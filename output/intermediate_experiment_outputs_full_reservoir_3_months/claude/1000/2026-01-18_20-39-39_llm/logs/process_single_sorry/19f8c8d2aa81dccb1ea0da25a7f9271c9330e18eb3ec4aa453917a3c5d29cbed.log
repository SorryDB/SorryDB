      "\n  induction w with\n  | zero => omega\n  | succ w ih =>\n    unfold assert_bits_e Vector.foldl at ih ⊢\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    have h_eq : args.toArray.extract 1 (w + 1) = (args.extract 1 (w + 1)).toArray := rfl\n    rw [assert_bit_e, h_eq]\n    cases Nat.eq_or_gt_of_le (Nat.zero_le i) with\n    | inl hi =>\n      subst hi\n      simp only [Cs.eval]\n      have hne : args[0] * (1 - args[0]) ≠ 0 := by\n        intro hcontra\n        simp only [mul_eq_zero, sub_eq_zero] at hcontra\n        rcases hcontra with hc | hc\n        · exact h' hc\n        · exact h'' hc.symm\n      simp only [Exp.eval]\n      simp [hne]\n    | inr hi =>\n      have hmin : min (w + 1) (w + 1) - 1 = w := by simp\n      rw [←hmin] at ih\n      have hi' : i - 1 < w := by omega\n      have hargs : args.extract 1 (w + 1) = args.extract 1 := by simp\n      rw [hargs]\n      have hidx : (args.extract 1)[i - 1] = args[i] := by\n        simp only [min_self, add_tsub_cancel_right, Vector.getElem_extract]\n        congr\n        omega\n      specialize @ih (args.extract 1) (Cs.eq0 (Exp.v args[0] * (Exp.c 1 - Exp.v args[0])) cs) (i - 1) hi'\n      rw [hidx] at ih\n      exact ih h' h''",
      "\n  induction w generalizing i cs with\n  | zero => omega\n  | succ w ih =>\n    unfold assert_bits_e at *\n    simp only [Vector.foldl, Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil] at *\n    by_cases hi : i < w\n    · apply ih hi h' h''\n    · have : i = w := by omega\n      subst this\n      simp only [assert_bit_e, Cs.eval, Exp.eval]\n      have : args[w] * (1 - args[w]) ≠ 0 := by\n        simp only [mul_eq_zero, sub_eq_zero, not_or]\n        exact ⟨h', fun h => h'' h.symm⟩\n      simp [this]",
      "\n  have hbad : args[i] * (1 - args[i]) ≠ 0 := by\n    intro heq\n    rw [mul_eq_zero, sub_eq_zero] at heq\n    rcases heq with heq | heq <;> [exact h' heq; exact h'' heq.symm]\n  induction w generalizing cs with\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e Vector.foldl\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    cases Nat.lt_or_ge i w with\n    | inl hi =>\n      apply ih hi\n      · convert h' using 2; simp; omega\n      · convert h'' using 2; simp; omega\n      · simp only [Vector.getElem_extract] at hbad ⊢\n        convert hbad using 2; omega\n    | inr hi =>\n      have heq : i = w := Nat.le_antisymm (Nat.lt_succ_iff.mp h) hi\n      subst heq\n      have : args[w] = args.head := by simp [Vector.head]; congr\n      rw [this] at hbad\n      clear h' h'' this\n      generalize (Array.foldl assert_bit_e (assert_bit_e cs args.head) \n                  (args.toArray.extract 1 (w + 1)) 0 w) = result\n      cases result with\n      | nil => simp [assert_bit_e, Cs.eval, Exp.eval, hbad]\n      | eq0 e c => simp [assert_bit_e, Cs.eval, Exp.eval, hbad]\n      | lam k => simp [assert_bit_e, Cs.eval, Exp.eval, hbad]",
      "\n  induction w generalizing cs with\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e Vector.foldl at ih ⊢\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    have h_extract : args.toArray.extract 1 (w + 1) = (args.extract 1 (w + 1)).toArray := rfl\n    rw [h_extract]\n    cases i with\n    | zero =>\n      -- The bad element is at index 0, which is args.head\n      have hbad : args.head * (1 - args.head) ≠ 0 := by\n        intro heq\n        have : args.head = args[0] := rfl\n        rw [this] at heq\n        have hmul : args[0] = 0 ∨ args[0] = 1 := by\n          have : args[0] * (1 - args[0]) = 0 := heq\n          by_cases hz : args[0] = 0\n          · left; exact hz\n          · right\n            have : 1 - args[0] = 0 := by\n              cases (mul_eq_zero.mp this) with\n              | inl h => exact (hz h).elim\n              | inr h => exact h\n            linarith\n        cases hmul with\n        | inl h => exact h' h\n        | inr h => exact h'' h\n      -- Now we need to show the fold evaluates to .n\n      -- The innermost application is assert_bit_e on args.head\n      unfold assert_bit_e at hbad ⊢\n      -- We need to show that adding this bad constraint makes everything .n\n      simp only [Cs.eval, Exp.eval]\n      have : min (w + 1) (w + 1) - 1 = w := by simp\n      generalize hcs' : (Array.foldl assert_bit_e (Cs.eq0 (Exp.v args.head * (Exp.c 1 - Exp.v args.head)) cs) (args.extract 1 (w + 1)).toArray 0 w) = cs'\n      unfold Cs.eval Exp.eval\n      simp only [mul_sub, mul_one]\n      simp [hbad]\n    | succ j =>\n      -- The bad element is in the tail (at index j of args.extract 1)\n      have hj : j < w := Nat.lt