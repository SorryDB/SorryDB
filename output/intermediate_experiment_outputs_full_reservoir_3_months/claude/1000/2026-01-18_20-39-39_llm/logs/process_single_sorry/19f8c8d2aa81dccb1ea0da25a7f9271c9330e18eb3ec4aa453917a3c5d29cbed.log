      "\n  induction w generalizing cs with\n  | zero => exact absurd h (Nat.not_lt_zero i)\n  | succ w ih =>\n    unfold assert_bits_e at *\n    unfold Vector.foldl at *\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil] at *\n    cases Nat.lt_or_eq_of_lt (Nat.lt_succ_iff_lt_or_eq.mp h) with\n    | inl hi =>\n      have : args.toArray.extract 1 (w + 1) = (args.extract 1 (w + 1)).toArray := rfl\n      rw [this]\n      apply ih\n      · exact Nat.lt_sub_of_add_lt (by simp [hi])\n      · simp only [min_self, add_tsub_cancel_right, Vector.getElem_extract]\n        convert h' using 2\n        omega\n      · simp only [min_self, add_tsub_cancel_right, Vector.getElem_extract]\n        convert h'' using 2\n        omega\n    | inr hi =>\n      subst hi\n      unfold assert_bit_e Cs.eval Exp.eval\n      simp only [mul_sub, mul_one]\n      have hne : args.head * (1 - args.head) ≠ 0 := by\n        simp only [Vector.head_eq_getElem]\n        intro heq\n        have := mul_eq_zero.mp heq\n        rcases this with hz | hz\n        · exact h' hz\n        · rw [sub_eq_zero] at hz\n          exact h'' hz.symm\n      simp only [ite_eq_right_iff]\n      intro heq\n      exact absurd heq hne",
      "\n  induction w generalizing i cs with\n  | zero => omega\n  | succ w ih =>\n    unfold assert_bits_e Vector.foldl\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    cases hi : i with\n    | zero =>\n      simp only [Vector.getElem_zero_eq_head] at h' h''\n      generalize hcs' : Array.foldl assert_bit_e (assert_bit_e cs args.head) (args.extract 1 (w + 1)).toArray = cs'\n      suffices hsuff : ∀ cs'', (assert_bit_e cs'' args.head).eval = .n by\n        clear hcs'\n        induction w with\n        | zero => simp [assert_bit_e, Cs.eval, Exp.eval, h', h'', sub_eq_zero, mul_eq_zero]\n        | succ w' ih' =>\n          simp only [Vector.toArray_extract, Array.size_extract, Vector.size_toArray, min_self,\n            add_tsub_cancel_right, Array.foldl_eq_foldl_toList, Array.toList_extract] at hcs' ⊢\n          sorry\n      intro cs''\n      simp [assert_bit_e, Cs.eval, Exp.eval, sub_eq_zero, mul_eq_zero, h', h'']\n    | succ j =>\n      have hj : j < w := Nat.lt_of_succ_lt_succ (hi ▸ h)\n      have hj' : args[i] = args.tail[j] := by simp [hi, Vector.getElem_tail]\n      rw [hj'] at h' h''\n      exact ih hj h' h''",
      "\n  | zero => exact (Nat.not_lt_zero i h).elim\n  | succ w ih =>\n    unfold assert_bits_e at ih ⊢\n    unfold Vector.foldl at ih ⊢\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil] at ih ⊢\n    by_cases hi : i = 0\n    · subst hi\n      simp only [Vector.head_toArray, Vector.getElem_zero] at h' h''\n      unfold assert_bit_e Cs.eval Exp.eval\n      simp only [mul_sub, mul_one]\n      have hne : args[0] * (1 - args[0]) ≠ 0 := by\n        intro heq\n        rw [mul_sub, mul_one, sub_eq_zero] at heq\n        rcases eq_or_ne args[0] 0 with hz | hz\n        · exact h' hz\n        · have : args[0] = 1 := by\n            have := mul_inv_cancel₀ hz\n            rw [heq] at this\n            exact this\n          exact h'' this\n      simp [hne]\n    · have hi' : i - 1 < w := by omega\n      have hargs : args[i] = (args.extract 1 (w + 1))[i - 1] := by\n        simp only [Vector.getElem_extract, add_tsub_cancel_right]\n        congr\n        omega\n      rw [hargs] at h' h''\n      specialize @ih (args.extract 1 (w + 1)) (assert_bit_e cs args[0]) hi' h' h''\n      have : (args.extract 1 (w + 1)).toArray = args.toArray.extract 1 (w + 1) := rfl\n      rw [this] at ih\n      exact ih",
      "\n  induction w with\n  | zero => omega\n  | succ w ih =>\n    unfold assert_bits_e Vector.foldl at ih ⊢\n    simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,\n      Array.size_append, List.size_toArray, List.length_cons, List.length_nil, zero_add,\n      Array.size_extract, Vector.size_toArray, min_self, add_tsub_cancel_right,\n      Array.foldl_append', List.foldl_toArray', List.foldl_cons, List.foldl_nil]\n    match i with\n    | 0 =>\n      simp only [Vector.getElem_zero] at h' h''\n      unfold assert_bit_e Cs.eval Exp.eval\n      simp only [sub_zero, mul_one]\n      have hne : args.head * (1 - args.head) ≠ 0 := by\n        intro heq\n        rw [mul_eq_zero] at heq\n        rcases heq with heq | heq\n        · exact h' heq\n        · rw [sub_eq_zero] at heq\n          exact h'' heq.symm\n      simp [hne]\n    | Nat.succ j =>\n      have hj : j < w := Nat.lt_of_succ_lt_succ h\n      have : args.toArray.extract 1 (w + 1) = (args.extract 1 (w + 1)).toArray := rfl\n      rw [this]\n      have h'2 : ¬(args.extract 1 (w + 1))[j] = 0 := by\n        simp only [min_self, add_tsub_cancel_right, Vector.getElem_extract]\n        convert h'\n        omega\n      have h''2 : ¬(args.extract 1 (w + 1))[j] = 1 := by\n        simp only [min_self, add_tsub_cancel_right, Vector.getElem_extract]\n        convert h''\n        omega\n      have hlen : min (w + 1) (w + 1) - 1 = w := by simp\n      rw [←hlen] at ih\n      exact @ih (args.extract 1 (w + 1)) (assert_bit_e (ZMod p) cs args.head) j hj h'2 h''2",
