      "\n  use Bool, Unit\n  use {\n    Hom := fun _ _ => Unit\n    id := fun _ => ()\n    comp := fun _ _ => ()\n    id_comp := fun _ => rfl\n    comp_id := fun _ => rfl\n    assoc := fun _ _ _ => rfl\n  }\n  use {\n    Hom := fun _ _ => Unit\n    id := fun _ => ()\n    comp := fun _ _ => ()\n    id_comp := fun _ => rfl\n    comp_id := fun _ => rfl\n    assoc := fun _ _ _ => rfl\n  }\n  use {\n    F := fun _ => ()\n    homF := fun _ => ()\n    map_id := fun _ => rfl\n    map_comp := fun _ _ => rfl\n  }\n  use true, false, ()\n  constructor\n  · intro ⟨g, hg1, hg2⟩\n    cases hg1\n  · use ()\n    constructor <;> rfl",
