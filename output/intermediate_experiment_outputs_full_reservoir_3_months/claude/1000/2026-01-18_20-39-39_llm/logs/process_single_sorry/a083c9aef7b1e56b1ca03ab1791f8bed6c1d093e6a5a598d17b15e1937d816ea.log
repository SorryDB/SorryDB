Looking at this problem, I need to prove that `fastCheckMem` correctly decides membership for ordered trees.

Let me analyze the structure:
- `fastCheckMem` checks if a label equals the node's value, or recursively searches left (if label < node value) or right (otherwise)
- For ordered trees, left subtree has elements ≤ node value, right subtree has elements ≥ node value

I'll prove this by induction on the tree structure.

```lean
theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, Membership.mem, LabelledTree.mem]
    exact beq_iff_eq label x
  | node v left right ihl ihr =>
    simp only [IsOrdered] at h
    obtain ⟨hl_le, hr_ge, hol, hor, _⟩ := h
    simp only [fastCheckMem, Membership.mem, LabelledTree.mem]
    by_cases heq : v == label
    · simp [heq]
      have : v = label := beq_iff_eq.mp heq
      subst this
      left
      exact h.2.2.2.2
    · simp [heq]
      by_cases hlt : label < v
      · simp [hlt]
        rw [ihl hol]
        constructor
        · intro hmem; left; exact hmem
        · intro hmem
          cases hmem with
          | inl hl => exact hl
          | inr hr =>
            have : v ≤ label := hr_ge label hr
            have : ¬(label < v) := not_lt.mpr this
            contradiction
      · simp [hlt]
        rw [ihr hor]
        constructor
        · intro hmem; right; exact hmem
        · intro hmem
          cases hmem with
          | inl hl =>
            have : label ≤ v := hl_le label hl
            have hne : ¬(v = label) := fun h => heq (beq_iff_eq.mpr h)
            have : label < v := lt_of_le_of_ne this (fun h => hne h.symm)
            contradiction
          | inr hr => exact hr
