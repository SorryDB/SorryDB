Looking at this problem, I need to prove that `fastCheckMem` correctly decides membership for ordered trees.

Let me analyze the structure:
- `fastCheckMem` checks if `label` equals the node's value, or recursively searches left (if `label < v`) or right (otherwise)
- For an ordered tree, left subtree has elements `≤ v` and right subtree has elements `≥ v`

I'll prove this by induction on the tree structure.

```lean
theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, Membership.mem, LabelledTree.mem]
    exact beq_iff_eq label x
  | node v left right ihl ihr =>
    simp only [fastCheckMem, Membership.mem, LabelledTree.mem]
    simp only [IsOrdered] at h
    obtain ⟨hl_le, hr_ge, hlo, hro, hv_mem⟩ := h
    by_cases hveq : v == label
    · simp [hveq]
      rw [beq_iff_eq] at hveq
      subst hveq
      exact Or.intro_left _ (Or.resolve_right hv_mem (fun _ => hv_mem))
    · simp [hveq]
      by_cases hlt : label < v
      · simp [hlt]
        constructor
        · intro hmem
          left
          exact (ihl hlo).mp hmem
        · intro hmem
          cases hmem with
          | inl hl => exact (ihl hlo).mpr hl
          | inr hr =>
            have := hr_ge label hr
            have hne : label ≠ v := by
              intro heq
              rw [beq_iff_eq] at hveq
              exact hveq heq.symm
            omega
      · simp [hlt]
        constructor
        · intro hmem
          right
          exact (ihr hro).mp hmem
        · intro hmem
          cases hmem with
          | inl hl =>
            have := hl_le label hl
            have hne : label ≠ v := by
              intro heq
              rw [beq_iff_eq] at hveq
              exact hveq heq.symm
            omega
          | inr hr => exact (ihr hro).mpr hr
