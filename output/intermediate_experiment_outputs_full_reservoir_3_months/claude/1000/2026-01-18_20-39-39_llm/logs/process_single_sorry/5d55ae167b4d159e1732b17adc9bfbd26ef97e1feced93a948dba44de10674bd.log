The key insight is that we already have `injective_of_light` which shows that a nonempty light profinite space `S` is injective in the category `LightProfinite`. 

For the profinite case, we need to show that `lightToProfinite.obj S` is injective in `Profinite`. The approach should be similar to the proof of `injective_of_light`, but working in the profinite category.

Looking at the structure, we can use `profinite_key_extension_lemma` instead of `light_key_extension_lemma`, and the same inductive argument should work since `lightToProfinite` preserves the relevant structure (limits, the sequential presentation, etc.).

```lean
instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f h := by
    haveI (n : ℕ) : Finite (S.component n) :=
      inferInstanceAs (Finite (FintypeCat.toLightProfinite.obj _))
    haveI : Nonempty (S.component 0) := Nonempty.map (S.proj 0) inferInstance
    haveI (n : ℕ) : Epi (lightToProfinite.map (S.transitionMap n)) := by
      rw [Profinite.epi_iff_surjective]
      exact S.surjective_transitionMap n
    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ lightToProfinite.map (S.proj 0)) f
    have h_step (n : ℕ) (k : Y ⟶ lightToProfinite.obj (S.component n)) 
        (h_down : f ≫ k = g ≫ lightToProfinite.map (S.proj n)) :
        ∃ k' : Y ⟶ lightToProfinite.obj (S.component (n+1)), 
          k' ≫ lightToProfinite.map (S.transitionMap n) = k ∧ 
          f ≫ k' = g ≫ lightToProfinite.map (S.proj (n+1)) := by
      have h_comm : f ≫ k = g ≫ lightToProfinite.map (S.proj (n+1)) ≫ 
          lightToProfinite.map (S.transitionMap n) := by
        rw [h_down, ← lightToProfinite.map_comp]
        exact congrArg _ (congrArg lightToProfinite.map (S.proj_comp_transitionMap n).symm)
      exact profinite_key_extension_lemma _ _ _ _ f (lightToProfinite.map (S.transitionMap n)) 
        (g ≫ lightToProfinite.map (S.proj (n+1))) k h_comm
    let lifts (n : ℕ) := { k : Y ⟶ lightToProfinite.obj (S.component n) // 
        f ≫ k = g ≫ lightToProfinite.map (S.proj n) }
    let next (n : ℕ) : lifts n → lifts (n+1) :=
      fun k ↦ ⟨Classical.choose (h_step n k.val k.property),
        (Classical.choose_spec (h_step n k.val k.property)).2⟩
    let k_seq (n : Nat) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n
    have h_down (n : ℕ) : f ≫ (k_seq n).val = g ≫ lightToProfinite.map (S.proj n) := 
      (k_seq n).property
    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ lightToProfinite.map (S.transitionMap n) = 
        (k_seq n).val := by
      induction n with
      | zero => exact (Classical.choose_spec (h_step 0 k0 h_down0)).1
      | succ n ih =>
        exact (Classical.choose_spec (h_step (n+1) (k_seq (n+1)).val (k_seq (n+1)).property)).1
    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }
    let lim := (Functor.Initial.limitConeComp Functor.initial S.cone lightToProfinite).isLimit
    use lim.lift k_cone
    let g_cone : Cone (S.diagram ⋙ lightToProfinite) :=
      { pt := X, π := NatTrans.ofOpSequence (fun n ↦ g ≫ lightToProfinite.map (S.proj n)) 
        (fun n ↦ by simp [← lightToProfinite.map_comp, S.proj_comp_transitionMap n]) }
    have hg : g = lim.lift g_cone := by
      apply lim.uniq g_cone
      intro n
      rw [NatTrans.ofOpSequence_app]
    rw [hg]
    have hlim : lim.lift (k_cone.extend f) = lim.lift g_cone := by
      congr 1
      ext n
      simp [Cone.extend, show k_cone.π.app n = (k_seq n.unop).1 from rfl, h_down]
    rw [← hlim]
    apply lim.uniq (k_cone.extend f)
    intro n
    simp
