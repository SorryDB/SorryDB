      exact S.surjective_transitionMap n
    let S' := lightToProfinite.obj S
    let comp (n : ℕ) : Profinite := lightToProfinite.obj (S.component n)
    let proj (n : ℕ) : S' ⟶ comp n := lightToProfinite.map (S.proj n)
    let trans (n : ℕ) : comp (n+1) ⟶ comp n := lightToProfinite.map (S.transitionMap n)
    have proj_comp (n : ℕ) : proj (n+1) ≫ trans n = proj n := by
      simp only [proj, trans, ← lightToProfinite.map_comp, S.proj_comp_transitionMap]
    obtain ⟨k0, h_down0⟩ := Profinite.injective_of_finite.factors (g ≫ proj 0) f
    have h_step (n : ℕ) (k : Y ⟶ comp n) (h_down : f ≫ k = g ≫ proj n) :
      ∃ k' : Y ⟶ comp (n+1), k' ≫ trans n = k ∧ f ≫ k' = g ≫ proj (n+1) := by
      have h_comm : f ≫ k = g ≫ proj (n+1) ≫ trans n := by rw [h_down, proj_comp]
      exact Profinite.profinite_key_extension_lemma _ _ _ _ f (trans n) (g ≫ proj (n+1)) k h_comm
    let lifts (n : ℕ) := { k : Y ⟶ comp n // f ≫ k = g ≫ proj n }
    let next (n : ℕ) : lifts n → lifts (n+1) :=
      fun k ↦ ⟨Classical.choose (h_step n k.val k.property),
        (Classical.choose_spec (h_step n k.val k.property)).2⟩
    let k_seq (n : Nat) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n
    have h_down (n : ℕ) : f ≫ (k_seq n).val = g ≫ proj n := (k_seq n).property
    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ trans n = (k_seq n).val := by
      induction n with
      | zero => exact (Classical.choose_spec (h_step 0 k0 h_down0)).1
      | succ n ih =>
        exact (Classical.choose_spec (h_step (n+1) (k_seq (n+1)).val (k_seq (n+1)).property)).1
    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }
    let lim := (Functor.mapCone lightToProfinite S.asLimit).isLimit
    use lim.lift k_cone
    let g_cone : Cone (S.diagram ⋙ lightToProfinite) :=
