lemma range_val_image {U : Type} (A : Set U) :
    range (val_image A) = 𝒫 A := by
  apply Set.ext
  intro B
  apply Iff.intro
  · -- B ∈ range (val_image A) → B ∈ 𝒫 A
    intro h
    obtain ⟨X, hX⟩ := h
    rw [← hX]
    define
    intro y hy
    define at hy
    obtain ⟨x, _, hxval⟩ := hy
    rw [← hxval]
    exact x.property
  · -- B ∈ 𝒫 A → B ∈ range (val_image A)
    intro h
    define at h
    use {x : A | x.val ∈ B}
    apply Set.ext
    intro y
    apply Iff.intro
    · intro hy
      define at hy
      obtain ⟨x, hx, hxval⟩ := hy
      define at hx
      rw [← hxval]
      exact hx
    · intro hy
      define
      have hyA : y ∈ A := h hy
      use ⟨y, hyA⟩
      constructor
      · define
        exact hy
      · rfl
```
