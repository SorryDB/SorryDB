lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  define
  intro x hx
  have hv : x.val ∈ val_image A X1 := by
    define
    use x
    apply And.intro hx
    rfl
  rw [h] at hv
  define at hv
  obtain ⟨y, hy, hxy⟩ := hv
  have : x = y := Subtype.ext hxy.symm
  rw [this]
  exact hy
```
