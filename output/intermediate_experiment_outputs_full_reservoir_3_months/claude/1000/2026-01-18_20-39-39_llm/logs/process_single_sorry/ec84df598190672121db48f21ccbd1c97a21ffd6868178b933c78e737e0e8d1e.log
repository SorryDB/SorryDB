lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  apply Iff.intro
  · intro h
    apply Set.ext
    intro y
    apply Iff.intro
    · intro _
      trivial
    · intro _
      obtain ⟨x, hx⟩ := h y
      exact ⟨x, hx⟩
  · intro h y
    have hy : y ∈ Univ V := trivial
    rw [← h] at hy
    exact hy
