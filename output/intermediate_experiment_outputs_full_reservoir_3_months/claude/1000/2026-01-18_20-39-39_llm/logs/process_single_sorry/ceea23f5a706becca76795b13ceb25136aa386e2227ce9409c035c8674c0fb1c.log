The key insight is that D-smoothness means that for any plot into the source, composition with the function gives a plot into the target. Since we're working with boundaryless manifolds, we can use charts to construct local plots.

```lean
open OpenPartialHomeomorph in
/-- Every D-smooth map from a boundaryless manifold to another manifold is also smooth.
This could probably be proven in quite a lot greater generality. -/
theorem IsOpen.dsmooth_iff_smoothOn {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [FiniteDimensional ℝ E] {H : Type*} [TopologicalSpace H] {I : ModelWithCorners ℝ E H}
    (M : Type*) [TopologicalSpace M] [ChartedSpace H M] [m : IsManifold I ∞ M]
    [hI : I.Boundaryless]
    {E' : Type*} [NormedAddCommGroup E'] [NormedSpace ℝ E'] [FiniteDimensional ℝ E']
    {H' : Type*} [TopologicalSpace H'] {I' : ModelWithCorners ℝ E' H'} (N : Type*)
    [TopologicalSpace N] [ChartedSpace H' N] [m' : IsManifold I' ∞ N]
    {f : M → N} {s : Set M} (hs : IsOpen s) : let _ := m.toDiffeology;
    let _ := m'.toDiffeology; DSmooth (s.restrict f) ↔ ContMDiffOn I I' ∞ f s := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine ⟨fun hf x hxs ↦ ?_,ContMDiffOn.dsmooth_restrict⟩
  rw [contMDiffWithinAt_iff_target]
  refine ⟨(hf.continuous.comp continuous_subtype_val).continuousWithinAt, ?_⟩
  rw [contMDiffWithinAt_iff]
  refine ⟨(hf.continuous.comp continuous_subtype_val).continuousWithinAt, ?_⟩
  have hE := FiniteDimensional.finrank ℝ E
  let e := (chartAt H x).toHomeomorphSourceTarget
  let u := (chartAt H x).source ∩ s
  have hu : IsOpen u := (chartAt H x).open_source.inter hs
  have hxu : x ∈ u := ⟨mem_chart_source H x, hxs⟩
  have : ContMDiff (𝓡 hE) I' ⊤ (f ∘ (chartAt H x).symm ∘ I.symm) := by
    have hp : IsPlot (fun y : Eucl hE ↦ (⟨(chartAt H x).symm (I.symm y),
        (chartAt H x).map_target (hI.isInteriorPoint (I.symm y) ▸ I.symm_map_target (mem_univ y))⟩ : s)) := by
      rw [isPlot_induced_iff, isPlot_iff_contMDiff]
      have h1 : ContMDiff (𝓡 hE) I ⊤ (fun y ↦ (chartAt H x).symm (I.symm y)) := by
        refine contMDiffOn_chart_symm.comp_contMDiff ?_ ?_
        · exact (contMDiff_model_symm (n := ⊤))
        · intro y; exact hI.isInteriorPoint (I.symm y) ▸ I.symm_map_target (mem_univ y)
      exact h1.congr fun y ↦ rfl
