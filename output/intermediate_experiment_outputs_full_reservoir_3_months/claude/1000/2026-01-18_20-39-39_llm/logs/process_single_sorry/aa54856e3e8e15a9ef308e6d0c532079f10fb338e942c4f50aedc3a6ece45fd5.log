theorem Category.iso_mono_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f ∧ Epi f := by
  obtain ⟨g, hfg, hgf⟩ := hf
  constructor
  · intro W h k heq
    calc h = h ≫ id X := by rw [comp_id]
      _ = h ≫ (f ≫ g) := by rw [hfg]
      _ = (h ≫ f) ≫ g := by rw [assoc]
      _ = (k ≫ f) ≫ g := by rw [heq]
      _ = k ≫ (f ≫ g) := by rw [assoc]
      _ = k ≫ id X := by rw [hfg]
      _ = k := by rw [comp_id]
  · intro Z h k heq
    calc h = id Y ≫ h := by rw [id_comp]
      _ = (g ≫ f) ≫ h := by rw [hgf]
      _ = g ≫ (f ≫ h) := by rw [assoc]
      _ = g ≫ (f ≫ k) := by rw [heq]
      _ = (g ≫ f) ≫ k := by rw [assoc]
      _ = id Y ≫ k := by rw [hgf]
      _ = k := by rw [id_comp]
