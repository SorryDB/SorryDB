      "\n  have hdisj := hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.le\n  have hCE : E(C) ⊆ M ∆ M' := by\n    intro e he\n    have := hCG.le.2 he\n    simp only [restrict₂, loopRemove_edgeSet, restrict_edgeSet, mem_inter_iff, mem_diff] at this\n    exact this.1.2\n  have hunion : E(C) ∩ M ∪ E(C) ∩ M' = E(C) := by\n    ext e\n    simp only [mem_union, mem_inter_iff]\n    constructor\n    · intro h; cases h with | inl h => exact h.1 | inr h => exact h.1\n    · intro he\n      have := hCE he\n      simp only [symmDiff_def, mem_union, mem_diff] at this\n      cases this with\n      | inl h => left; exact ⟨he, h.1⟩\n      | inr h => right; exact ⟨he, h.1⟩\n  have heven := hC.even_encard\n  rw [← hunion, encard_union_eq hdisj] at heven\n  have hfin : (E(C) ∩ M).encard + (E(C) ∩ M').encard ≠ ⊤ := by\n    rw [hunion]\n    exact hC.edgeFinite.encard_ne_top\n  exact Even.two_nsmul_eq_of_add_eq hfin heven",
