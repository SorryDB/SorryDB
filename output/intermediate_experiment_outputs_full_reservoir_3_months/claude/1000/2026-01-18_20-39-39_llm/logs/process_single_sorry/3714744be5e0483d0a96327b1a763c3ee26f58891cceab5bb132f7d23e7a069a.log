    simp [length_flatten]
  have ps_j1 : (L.map length).partialSums[j + 1]'(by simp; omega) = (L.take (j + 1)).flatten.length := by
    simp [length_flatten]
  rw [ps_j] at h2
  rw [ps_j1] at h1
