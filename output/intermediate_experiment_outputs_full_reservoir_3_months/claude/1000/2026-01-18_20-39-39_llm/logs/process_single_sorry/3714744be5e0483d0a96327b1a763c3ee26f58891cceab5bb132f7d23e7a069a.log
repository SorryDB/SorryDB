    let j := (L.map length).partialSums.findIdx (· > i) - 1
    have hj : j < L.length := getElem_flatten_aux₁ L i h
    let k := i - (L.take j).flatten.length
    k < L[j].length := by
  simp only
  set j := (L.map length).partialSums.findIdx (· > i) - 1 with hj_def
  have hj : j < L.length := getElem_flatten_aux₁ L i h
  have idx_pos : 0 < (L.map length).partialSums.findIdx (· > i) := by
    by_contra w
    simp at w
  have idx_bound : (L.map length).partialSums.findIdx (· > i) < (L.map length).partialSums.length := by
    apply findIdx_lt_length_of_exists
    exact ⟨L.flatten.length, length_flatten_mem_partialSums_map_length L, by grind⟩
  have j_succ : j + 1 = (L.map length).partialSums.findIdx (· > i) := by omega
  have h1 : (L.map length).partialSums[j + 1]'(by simp; omega) > i := by
    have := findIdx_getElem (L.map length).partialSums (· > i) (by simp; omega)
    simp at this
    rw [← j_succ] at this
    exact this
  have h2 : (L.map length).partialSums[j]'(by simp; omega) ≤ i := by
