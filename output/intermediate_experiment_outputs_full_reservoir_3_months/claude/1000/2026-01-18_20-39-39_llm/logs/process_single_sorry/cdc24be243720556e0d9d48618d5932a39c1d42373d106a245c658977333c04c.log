      "\n      simp only [Inner.inner, map_add, Prod.norm_def]\n      constructor\n      · have hx := (_hx x).1\n        have hy := (_hy y).1\n        have h1 : min cx cy ≤ cx := min_le_left _ _\n        have h2 : min cx cy ≤ cy := min_le_right _ _\n        have hnorm : ‖x‖ ≤ max ‖x‖ ‖y‖ := le_max_left _ _\n        have hnorm' : ‖y‖ ≤ max ‖x‖ ‖y‖ := le_max_right _ _\n        calc min cx cy / 2 • (max ‖x‖ ‖y‖) ^ 2 \n            ≤ min cx cy • ‖x‖ ^ 2 / 2 + min cx cy • ‖y‖ ^ 2 / 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, sq_nonneg (max ‖x‖ ‖y‖)]\n          _ ≤ cx • ‖x‖ ^ 2 / 2 + cy • ‖y‖ ^ 2 / 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖]\n          _ ≤ re ⟪x, x⟫_𝕜 / 2 + re ⟪y, y⟫_𝕜 / 2 := by nlinarith\n          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by nlinarith [inner_self_nonneg (𝕜:=𝕜) (x:=x), inner_self_nonneg (𝕜:=𝕜) (x:=y)]\n      · have hx := (_hx x).2\n        have hy := (_hy y).2\n        have hnorm : ‖x‖ ≤ max ‖x‖ ‖y‖ := le_max_left _ _\n        have hnorm' : ‖y‖ ≤ max ‖x‖ ‖y‖ := le_max_right _ _\n        calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 \n            ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by nlinarith\n          _ ≤ dx • (max ‖x‖ ‖y‖) ^ 2 + dy • (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, sq_nonneg (max ‖x‖ ‖y‖)]\n          _ = (dx + dy) • (max ‖x‖ ‖y‖) ^ 2 := by ring",
      "\n      simp only [Inner.inner, map_add, Prod.norm_def]\n      constructor\n      · have hx' := (hx x).1\n        have hy' := (hy y).1\n        have h1 : (min cx cy / 2) • (max ‖x‖ ‖y‖) ^ 2 ≤ cx • ‖x‖ ^ 2 + cy • ‖y‖ ^ 2 := by\n          simp only [smul_eq_mul]\n          have : ‖x‖^2 ≤ (max ‖x‖ ‖y‖)^2 := by nlinarith [le_max_left ‖x‖ ‖y‖, norm_nonneg x]\n          have : ‖y‖^2 ≤ (max ‖x‖ ‖y‖)^2 := by nlinarith [le_max_right ‖x‖ ‖y‖, norm_nonneg y]\n          nlinarith [min_le_left cx cy, min_le_right cx cy]\n        linarith\n      · have hx' := (hx x).2\n        have hy' := (hy y).2\n        simp only [smul_eq_mul] at *\n        have : ‖x‖^2 ≤ (max ‖x‖ ‖y‖)^2 := by nlinarith [le_max_left ‖x‖ ‖y‖, norm_nonneg x]\n        have : ‖y‖^2 ≤ (max ‖x‖ ‖y‖)^2 := by nlinarith [le_max_right ‖x‖ ‖y‖, norm_nonneg y]\n        nlinarith",
      "\n      simp only [Inner.inner, Prod.norm_def, map_add]\n      constructor\n      · have hx := (_hx x).1\n        have hy := (_hy y).1\n        calc min cx cy / 2 • (max ‖x‖ ‖y‖) ^ 2 \n            ≤ min cx cy • ‖x‖ ^ 2 / 2 + min cx cy • ‖y‖ ^ 2 / 2 := by\n              have h1 : (max ‖x‖ ‖y‖) ^ 2 ≤ ‖x‖ ^ 2 + ‖y‖ ^ 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, le_max_left ‖x‖ ‖y‖, le_max_right ‖x‖ ‖y‖, sq_le_sq' (by linarith [norm_nonneg x]) (le_max_left ‖x‖ ‖y‖), sq_le_sq' (by linarith [norm_nonneg y]) (le_max_right ‖x‖ ‖y‖)]\n              nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖]\n          _ ≤ cx • ‖x‖ ^ 2 / 2 + cy • ‖y‖ ^ 2 / 2 := by nlinarith [min_le_left cx cy, min_le_right cx cy, sq_nonneg ‖x‖, sq_nonneg ‖y‖]\n          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by nlinarith\n      · have hx := (_hx x).2\n        have hy := (_hy y).2\n        calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 \n            ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by nlinarith\n          _ ≤ (dx + dy) • (max ‖x‖ ‖y‖) ^ 2 := by\n              have h1 : ‖x‖ ^ 2 ≤ (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [le_max_left ‖x‖ ‖y‖, sq_nonneg ‖x‖]\n              have h2 : ‖y‖ ^ 2 ≤ (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [le_max_right ‖x‖ ‖y‖, sq_nonneg ‖y‖]\n              nlinarith",
      "\n        le_max_left ‖x‖ ‖y‖, le_max_right ‖x‖ ‖y‖, norm_nonneg x, norm_nonneg y, hcx, hdx, hcy, hdy]",
      "\n      simp only [Inner.inner, Prod.norm_def, map_add]\n      have hx := _hx x\n      constructor <;> nlinarith [hx.1, hx.2, norm_nonneg x, norm_nonneg y, sq_nonneg ‖x‖, sq_nonneg ‖y‖, sq_nonneg (max ‖x‖ ‖y‖), le_max_left ‖x‖ ‖y‖, le_max_right ‖x‖ ‖y‖, sq_le_sq' (by linarith [norm_nonneg x, le_max_left ‖x‖ ‖y‖] : -max ‖x‖ ‖y‖ ≤ ‖x‖) (le_max_left ‖x‖ ‖y‖), sq_le_sq' (by linarith [norm_nonneg y, le_max_right ‖x‖ ‖y‖] : -max ‖x‖ ‖y‖ ≤ ‖y‖) (le_max_right ‖x‖ ‖y‖)]",
      "\n      constructor <;> simp_all [Inner.inner, Prod.norm_def, smul_eq_mul] <;> nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, (_hx x).1, (_hx x).2]",
      "\n      simp only [Inner.inner, map_add, Prod.mk.injEq]\n      constructor <;> nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, (_hx x).1, (_hx x).2, norm_nonneg x, norm_nonneg y, hcx, hdx, hcy, hdy]",
      "\n      simp only [Inner.inner, map_add, Prod.norm_def]\n      constructor <;> sorry",
      "\n      simp only [Inner.inner, map_add, Prod.norm_def]\n      constructor\n      · have hx' := (hx x).1\n        have hy' := (hy y).1\n        have h1 : min cx cy / 2 • (max ‖x‖ ‖y‖) ^ 2 ≤ min cx cy / 2 • ‖x‖ ^ 2 + min cx cy / 2 • ‖y‖ ^ 2 := by\n          simp only [smul_eq_mul]\n          nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, sq_nonneg (‖x‖ - ‖y‖)]\n        calc min cx cy / 2 • (max ‖x‖ ‖y‖) ^ 2 \n            ≤ min cx cy / 2 • ‖x‖ ^ 2 + min cx cy / 2 • ‖y‖ ^ 2 := h1\n          _ ≤ cx • ‖x‖ ^ 2 + cy • ‖y‖ ^ 2 := by simp only [smul_eq_mul]; nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖]\n          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by linarith\n      · have hx' := (hx x).2\n        have hy' := (hy y).2\n        calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 \n            ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by linarith\n          _ ≤ max dx dy • ‖x‖ ^ 2 + max dx dy • ‖y‖ ^ 2 := by simp only [smul_eq_mul]; nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖]\n          _ ≤ max dx dy * 2 • (max ‖x‖ ‖y‖) ^ 2 := by simp only [smul_eq_mul]; nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, sq_nonneg (‖x‖ - ‖y‖)]",
      "\n      simp only [Inner.inner, map_add]\n      have hx := _hx x\n      have hy := _hy y\n      constructor\n      · calc min cx cy / 2 • ‖(x, y)‖ ^ 2 \n            ≤ min cx cy • max (‖x‖^2) (‖y‖^2) := by\n              simp only [Prod.norm_def, smul_eq_mul]\n              have : ‖(x, y)‖ ^ 2 = max ‖x‖ ‖y‖ ^ 2 := rfl\n              nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, norm_nonneg x, norm_nonneg y]\n          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by\n              have h1 : cx • ‖x‖^2 ≤ re ⟪x, x⟫_𝕜 := hx.1\n              have h2 : cy • ‖y‖^2 ≤ re ⟪y, y⟫_𝕜 := hy.1\n              simp only [smul_eq_mul] at *\n              nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, norm_nonneg x, norm_nonneg y]\n      · calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 \n            ≤ dx • ‖x‖^2 + dy • ‖y‖^2 := by linarith [hx.2, hy.2]\n          _ ≤ 2 * (dx + dy) • ‖(x, y)‖ ^ 2 := by\n              simp only [Prod.norm_def, smul_eq_mul]\n              nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, norm_nonneg x, norm_nonneg y, \n                        sq_nonneg (‖x‖ - ‖y‖), le_max_left ‖x‖ ‖y‖, le_max_right ‖x‖ ‖y‖]",
      "\n      simp only [Inner.inner, map_add, Prod.norm_def]\n      constructor\n      · have hx' := (hx x).1\n        have hy' := (hy y).1\n        have h1 : (min cx cy / 2) • (max ‖x‖ ‖y‖) ^ 2 ≤ (min cx cy / 2) • (‖x‖ ^ 2 + ‖y‖ ^ 2) := by\n          apply smul_le_smul_of_nonneg_left\n          · have := sq_max_le_add_sq_sq ‖x‖ ‖y‖ (norm_nonneg x) (norm_nonneg y)\n            linarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, sq_nonneg (‖x‖ - ‖y‖)]\n          · positivity\n        calc (min cx cy / 2) • (max ‖x‖ ‖y‖) ^ 2 \n            ≤ (min cx cy) • (max ‖x‖ ‖y‖) ^ 2 := by apply smul_le_smul_of_nonneg_right; linarith [min_le_left cx cy]; positivity\n          _ ≤ cx • ‖x‖ ^ 2 + cy • ‖y‖ ^ 2 := by\n              simp only [smul_eq_mul]\n              have : (max ‖x‖ ‖y‖) ^ 2 ≤ ‖x‖ ^ 2 + ‖y‖ ^ 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, sq_nonneg (‖x‖ - ‖y‖), sq_max_le_add_sq_sq ‖x‖ ‖y‖ (norm_nonneg x) (norm_nonneg y)]\n              nlinarith [min_le_left cx cy, min_le_right cx cy, sq_nonneg ‖x‖, sq_nonneg ‖y‖]\n          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by linarith\n      · have hx' := (hx x).2\n        have hy' := (hy y).2\n        have h1 : ‖x‖ ^ 2 ≤ (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [le_max_left ‖x‖ ‖y‖]\n        have h2 : ‖y‖ ^ 2 ≤ (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [le_max_right ‖x‖ ‖y‖]\n        calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 \n            ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by linarith\n          _ ≤ dx • (max ‖x‖ ‖y‖) ^ 2 + dy • (max ‖x‖ ‖y‖) ^ 2 := by\n              apply add_le_add\n              · exact smul_le_smul_of_nonneg_left h1 (le_of_lt hdx)\n              · exact smul_le_smul_of_nonneg_left h2 (le_of_lt hdy)\n          _ = (dx + dy) • (max ‖x‖ ‖y‖) ^ 2 := by ring",
      "\n      constructor <;> simp only [Inner.inner, map_add, smul_eq_mul] <;> nlinarith [(_hx x).1, (_hx x).2, sq_nonneg ‖x‖, sq_nonneg ‖y‖, hcx, hdx, hcy, hdy]",
      "\n      simp only [Prod.norm_def, Inner.inner, map_add]\n      constructor\n      · have h1 := (_hx x).1\n        have h2 := (_hy y).1\n        have : max ‖x‖ ‖y‖ ^ 2 ≥ ‖x‖^2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, le_max_left ‖x‖ ‖y‖]\n        have : max ‖x‖ ‖y‖ ^ 2 ≥ ‖y‖^2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, le_max_right ‖x‖ ‖y‖]\n        nlinarith [inner_self_nonneg (𝕜:=𝕜) (x:=x), inner_self_nonneg (𝕜:=𝕜) (x:=y)]\n      · have h1 := (_hx x).2\n        have h2 := (_hy y).2\n        have : ‖x‖^2 ≤ max ‖x‖ ‖y‖ ^ 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, le_max_left ‖x‖ ‖y‖]\n        have : ‖y‖^2 ≤ max ‖x‖ ‖y‖ ^ 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, le_max_right ‖x‖ ‖y‖]\n        nlinarith",
      "\n      simp only [Inner.inner, map_add, Prod.mk.injEq]\n      have hx := _hx x\n      have hy := _hy y\n      constructor\n      · calc (min cx cy / 2) • ‖(x, y)‖ ^ 2 \n            ≤ (min cx cy) • (‖x‖^2 + ‖y‖^2) := by\n              simp only [smul_eq_mul, Prod.norm_def]\n              have h1 : ‖(x, y)‖ = max ‖x‖ ‖y‖ := rfl\n              nlinarith [norm_nonneg x, norm_nonneg y, sq_nonneg ‖x‖, sq_nonneg ‖y‖, \n                         sq_nonneg (‖x‖ - ‖y‖), min_le_left cx cy, min_le_right cx cy]\n          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by\n              have h1 : min cx cy • ‖x‖^2 ≤ re ⟪x, x⟫_𝕜 := by\n                calc min cx cy • ‖x‖^2 ≤ cx • ‖x‖^2 := by nlinarith [sq_nonneg ‖x‖, min_le_left cx cy]\n                  _ ≤ re ⟪x, x⟫_𝕜 := hx.1\n              have h2 : min cx cy • ‖y‖^2 ≤ re ⟪y, y⟫_𝕜 := by\n                calc min cx cy • ‖y‖^2 ≤ cy • ‖y‖^2 := by nlinarith [sq_nonneg ‖y‖, min_le_right cx cy]\n                  _ ≤ re ⟪y, y⟫_𝕜 := hy.1\n              simp only [smul_eq_mul] at h1 h2 ⊢\n              linarith\n      · calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 \n            ≤ dx • ‖x‖^2 + dy • ‖y‖^2 := by linarith [hx.2, hy.2]\n          _ ≤ (2 * (dx + dy)) • ‖(x, y)‖^2 := by\n              simp only [smul_eq_mul, Prod.norm_def]\n              have h1 : ‖(x, y)‖ = max ‖x‖ ‖y‖ := rfl\n              nlinarith [norm_nonneg x, norm_nonneg y, sq_nonneg ‖x‖, sq_nonneg ‖y‖,\n                         le_max_left ‖x‖ ‖y‖, le_max_right ‖x‖ ‖y‖]",
      "\n      constructor <;> simp only [Inner.inner, map_add, Prod.norm_def, smul_eq_mul] <;> nlinarith [(_hx x).1, (_hx x).2, sq_nonneg ‖x‖, sq_nonneg ‖y‖, hcx, hdx, hcy, hdy, norm_nonneg x, norm_nonneg y]",
      "\n      simp only [Inner.inner, map_add, Prod.norm_def]\n      constructor\n      · have hx := (_hx x).1\n        have hy := (_hy y).1\n        have h1 : (min cx cy / 2) • (max ‖x‖ ‖y‖) ^ 2 ≤ (min cx cy / 2) • (‖x‖ ^ 2 + ‖y‖ ^ 2) := by\n          apply smul_le_smul_of_nonneg_left\n          · have : (max ‖x‖ ‖y‖) ^ 2 ≤ ‖x‖ ^ 2 + ‖y‖ ^ 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, le_max_left ‖x‖ ‖y‖, le_max_right ‖x‖ ‖y‖, sq_le_sq' (by linarith [norm_nonneg x]) (le_max_left ‖x‖ ‖y‖), sq_le_sq' (by linarith [norm_nonneg y]) (le_max_right ‖x‖ ‖y‖)]\n            exact this\n          · positivity\n        calc (min cx cy / 2) • (max ‖x‖ ‖y‖) ^ 2 \n            ≤ (min cx cy / 2) • (‖x‖ ^ 2 + ‖y‖ ^ 2) := h1\n          _ = (min cx cy / 2) • ‖x‖ ^ 2 + (min cx cy / 2) • ‖y‖ ^ 2 := by ring\n          _ ≤ cx • ‖x‖ ^ 2 + cy • ‖y‖ ^ 2 := by nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, min_le_left cx cy, min_le_right cx cy]\n          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by linarith\n      · have hx := (_hx x).2\n        have hy := (_hy y).2\n        have h1 : ‖x‖ ^ 2 ≤ (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [le_max_left ‖x‖ ‖y‖]\n        have h2 : ‖y‖ ^ 2 ≤ (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [le_max_right ‖x‖ ‖y‖]\n        calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 \n            ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by linarith\n          _ ≤ dx • (max ‖x‖ ‖y‖) ^ 2 + dy • (max ‖x‖ ‖y‖) ^ 2 := by nlinarith\n          _ = (dx + dy) • (max ‖x‖ ‖y‖) ^ 2 := by ring\n          _ ≤ (2 * (dx + dy)) • (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [sq_nonneg (max ‖x‖ ‖y‖)]\n  conj_symm := by simp[Inner.inner, conj_symm, add_comm]\n  add_left := by simp[Inner.inner, add_left]; ring\n  smul_left := by simp[Inner.inner, smul_left]; ring",
      "\n      simp only [Inner.inner, Prod.norm_def, map_add]\n      constructor\n      · have hx := (_hx x).1\n        have hy := (_hy y).1\n        calc (min cx cy / 2) • (max ‖x‖ ‖y‖) ^ 2 \n            ≤ (min cx cy) • (‖x‖ ^ 2 + ‖y‖ ^ 2) / 2 := by\n              simp only [smul_eq_mul]\n              have h1 : (max ‖x‖ ‖y‖) ^ 2 ≤ ‖x‖ ^ 2 + ‖y‖ ^ 2 := by\n                have := sq_nonneg (‖x‖ - ‖y‖)\n                nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖, sq_abs (‖x‖ - ‖y‖), \n                          sq_max_le_add_sq_self ‖x‖ ‖y‖]\n              nlinarith [min_le_left cx cy, min_le_right cx cy, sq_nonneg (max ‖x‖ ‖y‖)]\n          _ ≤ (cx • ‖x‖ ^ 2 + cy • ‖y‖ ^ 2) / 2 := by\n              simp only [smul_eq_mul]\n              have := min_le_left cx cy\n              have := min_le_right cx cy\n              nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖]\n          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by nlinarith\n      · have hx := (_hx x).2\n        have hy := (_hy y).2\n        calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 \n            ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by nlinarith\n          _ ≤ (dx + dy) • (‖x‖ ^ 2 + ‖y‖ ^ 2) := by simp only [smul_eq_mul]; nlinarith [sq_nonneg ‖x‖, sq_nonneg ‖y‖]\n          _ ≤ 2 * (dx + dy) • (max ‖x‖ ‖y‖) ^ 2 := by\n              simp only [smul_eq_mul]\n              have : ‖x‖ ^ 2 + ‖y‖ ^ 2 ≤ 2 * (max ‖x‖ ‖y‖) ^ 2 := by\n                have h1 : ‖x‖ ^ 2 ≤ (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [le_max_left ‖x‖ ‖y‖, sq_nonneg ‖x‖]\n                have h2 : ‖y‖ ^ 2 ≤ (max ‖x‖ ‖y‖) ^ 2 := by nlinarith [le_max_right ‖x‖ ‖y‖, sq_nonneg ‖y‖]\n                linarith\n              nlinarith",
      "\n      simp only [Inner.inner, map_add, Prod.norm_def]\n      have hx := _hx x\n      constructor <;> nlinarith [hx.1, hx.2, sq_nonneg ‖x‖, sq_nonneg ‖y‖, norm_nonneg x, norm_nonneg y, le_max_left ‖x‖ ‖y‖, le_max_right ‖x‖ ‖y‖]",
