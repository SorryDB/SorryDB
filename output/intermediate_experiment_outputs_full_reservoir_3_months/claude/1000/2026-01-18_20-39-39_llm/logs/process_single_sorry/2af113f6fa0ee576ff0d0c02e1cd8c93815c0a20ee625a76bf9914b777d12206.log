```lean
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  push_neg at h₁
  obtain ⟨x₀, hx₀⟩ := h₁
  intro y
  have key := h₀ x₀ y
  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀
  have hfx₀_le : |f x₀| ≤ 1 := h₂ x₀
  have hfx₀_ne : f x₀ ≠ 0 := hx₀
  have : g y = (f (x₀ + y) + f (x₀ - y)) / (2 * f x₀) := by
    field_simp [hfx₀_ne]
    linarith [key]
  rw [this]
  rw [abs_div, abs_mul, abs_of_pos (by norm_num : (0:ℝ) < 2)]
  have h1 : |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _
  have h2 : |f (x₀ + y)| ≤ 1 := h₂ _
  have h3 : |f (x₀ - y)| ≤ 1 := h₂ _
  have h4 : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by linarith
  have h5 : 2 * |f x₀| > 0 := by positivity
  rw [div_le_one h5]
  calc |f (x₀ + y) + f (x₀ - y)| ≤ 2 := h4
    _ = 2 * 1 := by ring
    _ ≤ 2 * |f x₀| := by nlinarith [hfx₀_pos, hfx₀_le]
