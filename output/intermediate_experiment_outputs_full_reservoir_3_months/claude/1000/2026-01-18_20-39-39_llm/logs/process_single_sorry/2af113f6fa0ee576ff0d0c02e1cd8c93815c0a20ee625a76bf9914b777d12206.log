      "\n  push_neg at h₁\n  obtain ⟨a, ha⟩ := h₁\n  intro y\n  have key := h₀ a y\n  by_contra hgy\n  push_neg at hgy\n  have hfa_pos : 0 < |f a| := abs_pos.mpr ha\n  have h1 : 2 * |f a| * |g y| = |f (a + y) + f (a - y)| := by\n    rw [key, abs_mul, abs_mul, abs_of_pos (by norm_num : (0 : ℝ) < 2)]\n  have h2 : |f (a + y) + f (a - y)| ≤ |f (a + y)| + |f (a - y)| := abs_add _ _\n  have h3 : |f (a + y)| + |f (a - y)| ≤ 2 := by linarith [h₂ (a + y), h₂ (a - y)]\n  have h4 : 2 * |f a| * |g y| ≤ 2 := by linarith [h1.symm ▸ h2.trans h3]\n  have h5 : |f a| * |g y| ≤ 1 := by linarith\n  have h6 : |f a| ≤ 1 := h₂ a\n  have h7 : 1 < |g y| := hgy\n  have h8 : |f a| < |f a| * |g y| := by\n    calc |f a| = |f a| * 1 := by ring\n    _ < |f a| * |g y| := by exact (mul_lt_mul_left hfa_pos).mpr h7\n  have h9 : |f a| < 1 := by\n    calc |f a| < |f a| * |g y| := h8\n    _ ≤ 1 := h5\n  have h10 : 1 < |f a| * |g y| := by\n    have : 1 = 1 * 1 := by ring\n    calc 1 < 1 * |g y| := by linarith\n    _ ≤ |f a| * |g y| := by nlinarith [abs_nonneg (g y)]\n  linarith",
