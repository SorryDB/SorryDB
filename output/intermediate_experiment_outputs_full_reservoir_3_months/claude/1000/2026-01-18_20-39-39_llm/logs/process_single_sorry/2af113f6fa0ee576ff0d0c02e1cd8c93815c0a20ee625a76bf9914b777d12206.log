      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  have hM : ⨆ t, |f t| > 0 := by\n    apply lt_of_lt_of_le (abs_pos.mpr hx₀)\n    exact le_ciSup ⟨1, fun _ ⟨_, hy⟩ => hy ▸ h₂ _⟩ x₀\n  intro y\n  by_contra h\n  push_neg at h\n  have key : ∀ x, |f (x + y)| + |f (x - y)| < 2 * |f x| := by\n    intro x\n    calc |f (x + y)| + |f (x - y)| \n        ≤ |f (x + y) + f (x - y)| + 2 * |f (x + y) - f (x - y)| / 2 := by\n          have := abs_add (f (x + y)) (f (x - y))\n          linarith [abs_nonneg (f (x + y)), abs_nonneg (f (x - y))]\n        _ = |2 * f x * g y| := by rw [h₀]\n        _ = 2 * |f x| * |g y| := by rw [abs_mul, abs_mul, abs_of_pos (by norm_num : (2:ℝ) > 0)]\n        _ > 2 * |f x| * 1 := by nlinarith [abs_nonneg (f x)]\n        _ = 2 * |f x| := by ring\n  have hbdd : BddAbove (Set.range (|f ·|)) := ⟨1, fun _ ⟨x, hx⟩ => hx ▸ h₂ x⟩\n  have hsup : ∀ x, |f x| ≤ ⨆ t, |f t| := fun x => le_ciSup hbdd x\n  have hsup2 : ⨆ t, |f t| ≤ 1 := ciSup_le fun x => h₂ x\n  have contra : ∀ x, |f x| * |g y| ≤ ⨆ t, |f t| := by\n    intro x\n    have := h₀ x y\n    have h1 : |f (x + y) + f (x - y)| ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n    have h2 : |f (x + y)| ≤ ⨆ t, |f t| := hsup _\n    have h3 : |f (x - y)| ≤ ⨆ t, |f t| := hsup _\n    calc |f x| * |g y| = |f x * g y| := (abs_mul _ _).symm\n      _ = |2 * f x * g y| / 2 := by rw [abs_mul]; ring\n      _ = |f (x + y) + f (x - y)| / 2 := by rw [← this]\n      _ ≤ (|f (x + y)| + |f (x - y)|) / 2 := by linarith [abs_add (f (x+y)) (f (x-y))]\n      _ ≤ (⨆ t, |f t| + ⨆ t, |f t|) / 2 := by linarith\n      _ = ⨆ t, |f t| := by ring\n  have final : (⨆ t, |f t|) * |g y| ≤ ⨆ t, |f t| := by\n    have : ∀ ε > 0, (⨆ t, |f t| - ε) * |g y| ≤ ⨆ t, |f t| := by\n      intro ε hε\n      by_cases hgy : |g y| = 0\n      · simp [hgy]; exact le_of_lt hM\n      · obtain ⟨x, hx⟩ := exists_lt_of_lt_ciSup (sub_lt_self _ hε)\n        have := contra x\n        nlinarith [abs_nonneg (f x), abs_nonneg (g y), hsup2, hsup x]\n    nlinarith [this 1 (by norm_num : (1:ℝ) > 0), abs_nonneg (g y), hM]\n  have : |g y| ≤ 1 := by\n    have := final\n    have hpos := hM\n    nlinarith\n  linarith",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  have hfx₀ : |f x₀| > 0 := abs_pos.mpr hx₀\n  intro y\n  have eq1 := h₀ x₀ y\n  have h3 : 2 * f x₀ * g y = f (x₀ + y) + f (x₀ - y) := eq1.symm\n  have h4 : |2 * f x₀ * g y| = |f (x₀ + y) + f (x₀ - y)| := by rw [h3]\n  have h5 : |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _\n  have h6 : |f (x₀ + y)| + |f (x₀ - y)| ≤ 2 := by linarith [h₂ (x₀ + y), h₂ (x₀ - y)]\n  have h7 : |2 * f x₀ * g y| ≤ 2 := by linarith\n  have h8 : |2 * f x₀ * g y| = 2 * |f x₀| * |g y| := by\n    rw [abs_mul, abs_mul, abs_of_pos (by linarith : (2 : ℝ) > 0)]\n  rw [h8] at h7\n  have h9 : |f x₀| * |g y| ≤ 1 := by linarith\n  -- We need to show this implies |g y| ≤ 1\n  -- Use that for any ε > 0, there's x with |f x| > 1 - ε, or sup = 1\n  by_contra hgy\n  push_neg at hgy\n  have : |f x₀| * |g y| > |f x₀| * 1 := by nlinarith [hfx₀]\n  simp at this\n  linarith",
      "\n  have key : ∀ x y, |f x| * |g y| ≤ 1 := fun x y => by\n    have := h₀ x y\n    have h : |f (x + y) + f (x - y)| ≤ 2 := \n      calc |f (x + y) + f (x - y)| ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n        _ ≤ 1 + 1 := by linarith [h₂ (x + y), h₂ (x - y)]\n        _ = 2 := by ring\n    calc |f x| * |g y| = |2 * f x * g y| / 2 := by rw [abs_mul, abs_mul, abs_of_pos]; ring; norm_num\n      _ = |f (x + y) + f (x - y)| / 2 := by rw [this]\n      _ ≤ 2 / 2 := by linarith\n      _ = 1 := by ring\n  intro y\n  by_contra hy\n  push_neg at hy h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  have h1 : |f x₀| * |g y| ≤ 1 := key x₀ y  \n  have h2 : |f x₀| > 0 := abs_pos.mpr hx₀\n  nlinarith [h₂ x₀]",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀\n  intro y\n  have key := h₀ x₀ y\n  have h1 : 2 * f x₀ * g y = f (x₀ + y) + f (x₀ - y) := key.symm\n  have h2 : |2 * f x₀ * g y| = |f (x₀ + y) + f (x₀ - y)| := by rw [h1]\n  have h3 : |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _\n  have h4 : |f (x₀ + y)| + |f (x₀ - y)| ≤ 2 := by linarith [h₂ (x₀ + y), h₂ (x₀ - y)]\n  have h5 : |2 * f x₀ * g y| ≤ 2 := by linarith\n  rw [abs_mul, abs_mul] at h5\n  have h6 : (2 : ℝ) > 0 := by norm_num\n  rw [abs_of_pos h6] at h5\n  have h7 : 2 * |f x₀| * |g y| ≤ 2 := h5\n  have h8 : |f x₀| * |g y| ≤ 1 := by linarith\n  have h9 : |g y| ≤ 1 / |f x₀| := by\n    rw [div_eq_inv_mul, ← le_div_iff' hfx₀_pos]\n    exact h8\n  calc |g y| ≤ 1 / |f x₀| := h9\n    _ ≤ 1 / |f x₀| := le_refl _\n    _ ≤ 1 := by rw [div_le_one hfx₀_pos]; exact h₂ x₀",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  intro y\n  by_contra h\n  push_neg at h\n  have key : ∀ x, |f x| ≤ 1 / |g y| := fun x => by\n    have eq := h₀ x y\n    have bound : |f (x + y) + f (x - y)| ≤ 2 := by\n      calc |f (x + y) + f (x - y)| ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n        _ ≤ 1 + 1 := add_le_add (h₂ _) (h₂ _)\n        _ = 2 := by ring\n    rw [eq] at bound\n    simp only [abs_mul, abs_two] at bound\n    have hg_pos : 0 < |g y| := by linarith\n    have : 2 * |f x| * |g y| ≤ 2 := bound\n    have : |f x| * |g y| ≤ 1 := by linarith\n    exact (div_le_one hg_pos).mpr (by nlinarith)\n  have hbound : |f x₀| ≤ 1 / |g y| := key x₀\n  have hgy : |g y| > 1 := h\n  have : 1 / |g y| < 1 := by\n    rw [div_lt_one (by linarith : 0 < |g y|)]\n    exact hgy\n  have hfx₀ : |f x₀| < 1 := lt_of_le_of_lt hbound this\n  have : ∀ x, |f x| < 1 := fun x => lt_of_le_of_lt (key x) this\n  have hsup : ∀ x, |f x| ≤ 1 / |g y| := key\n  -- Use sup property: there's x with |f x| close to sup\n  have h1 : 1 / |g y| < 1 := this\n  -- From boundedness, get contradiction by iteration\n  have := key x₀\n  have habs : |f x₀| > 0 := abs_pos.mpr hx₀\n  -- g(0) = 1 from x=y=0 if f(0) ≠ 0, or other argument\n  have hz : g 0 = 1 := by\n    have := h₀ x₀ 0\n    simp at this\n    field_simp at this\n    linarith [hx₀]\n  have hgy1 : |g y| ≤ 1 := by\n    nlinarith [h₂ (x₀ + y), h₂ (x₀ - y), h₀ x₀ y, abs_nonneg (f x₀), habs,\n               abs_add (f (x₀ + y)) (f (x₀ - y)), abs_mul (f x₀) (g y), abs_mul 2 (f x₀ * g y)]\n  linarith",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  intro y\n  have key := h₀ x₀ y\n  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀\n  have h1 : 2 * f x₀ * g y = f (x₀ + y) + f (x₀ - y) := key.symm\n  have h2 : |2 * f x₀ * g y| = |f (x₀ + y) + f (x₀ - y)| := by rw [h1]\n  have h3 : |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _\n  have h4 : |f (x₀ + y)| + |f (x₀ - y)| ≤ 1 + 1 := add_le_add (h₂ _) (h₂ _)\n  have h5 : |2 * f x₀ * g y| ≤ 2 := le_trans h2 (le_trans h3 h4)\n  rw [abs_mul, abs_mul, abs_of_pos (by norm_num : (0:ℝ) < 2)] at h5\n  have h6 : 2 * |f x₀| * |g y| ≤ 2 := h5\n  have h7 : |f x₀| * |g y| ≤ 1 := by linarith\n  by_contra habs\n  push_neg at habs\n  have : |f x₀| * |g y| > |f x₀| * 1 := by\n    apply mul_lt_mul_of_pos_left habs hfx₀_pos\n  simp at this\n  have : |f x₀| * |g y| > 1 := lt_of_lt_of_le (lt_of_le_of_lt (h₂ x₀) this) (le_refl _)\n  linarith",
      "\n  by_contra h\n  push_neg at h h₁\n  obtain ⟨y, hy⟩ := h\n  obtain ⟨x₀, hx₀⟩ := h₁\n  have hgy : |g y| > 1 := hy\n  have key : ∀ x, |f x| * |g y| ≤ 1 := fun x => by\n    have := h₀ x y\n    calc |f x| * |g y| = |f x * g y| := (abs_mul _ _).symm\n      _ = |2 * f x * g y| / 2 := by rw [abs_mul, abs_two]; ring\n      _ = |f (x + y) + f (x - y)| / 2 := by rw [this]\n      _ ≤ (|f (x + y)| + |f (x - y)|) / 2 := by gcongr; exact abs_add _ _\n      _ ≤ (1 + 1) / 2 := by gcongr; exact h₂ _; exact h₂ _\n      _ = 1 := by norm_num\n  have : |f x₀| * |g y| ≤ 1 := key x₀\n  have hfx₀ : |f x₀| > 0 := abs_pos.mpr hx₀\n  have bound : |f x₀| ≤ 1 / |g y| := by rwa [mul_comm, ← le_div_iff (by linarith)] at this\n  have lt_one : 1 / |g y| < 1 := by rw [div_lt_one (by linarith)]; exact hy\n  -- Now iterate: |f x| ≤ (1/|g y|)^(2^n) for all n\n  have iter : ∀ n : ℕ, ∀ x, |f x| ≤ (1 / |g y|) ^ (2 ^ n) := by\n    intro n\n    induction n with\n    | zero =>\n      simp only [Nat.pow_zero, pow_one]\n      intro x\n      have := key x\n      rwa [mul_comm, ← le_div_iff (by linarith)] at this\n    | succ n ih =>\n      intro x\n      have eq := h₀ x y\n      have bd : |f (x + y) + f (x - y)| ≤ 2 * (1 / |g y|) ^ (2 ^ n) := by\n        calc |f (x + y) + f (x - y)| ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n          _ ≤ (1 / |g y|) ^ (2 ^ n) + (1 / |g y|) ^ (2 ^ n) := add_le_add (ih _) (ih _)\n          _ = 2 * (1 / |g y|) ^ (2 ^ n) := by ring\n      have eq2 : 2 * |f x| * |g y| = |f (x + y) + f (x - y)| := by\n        rw [← eq, abs_mul, abs_mul, abs_two]\n      have : 2 * |f x| * |g y| ≤ 2 * (1 / |g y|) ^ (2 ^ n) := by rw [eq2]; exact bd\n      have hgy_pos : |g y| > 0 := by linarith\n      have : |f x| ≤ (1 / |g y|) ^ (2 ^ n) / |g y| := by\n        have h1 : |f x| * |g y| ≤ (1 / |g y|) ^ (2 ^ n) := by linarith\n        rwa [← le_div_iff hgy_pos] at h1\n      calc |f x| ≤ (1 / |g y|) ^ (2 ^ n) / |g y| := this\n        _ = (1 / |g y|) ^ (2 ^ n) * (1 / |g y|) := by rw [div_eq_mul_inv, inv_eq_one_div]\n        _ = (1 / |g y|) ^ (2 ^ n + 1) := by rw [← pow_succ]\n        _ = (1 / |g y|) ^ (2 ^ (n + 1)) := by ring_nf; congr 1; omega\n  have tends_zero : Filter.Tendsto (fun n => (1 / |g y|) ^ (2 ^ n)) Filter.atTop (nhds 0) := by\n    have h1 : 0 < 1 / |g y| := by positivity\n    have h2 : 1 / |g y| < 1 := lt_one\n    exact tendsto_pow_atTop_nhds_zero_of_lt_one h1.le h2 |>.comp (Nat.tendsto_pow_atTop_atTop_of_one_lt (by norm_num : 1 < 2))\n  have hfx₀_le : ∀ n, |f x₀| ≤ (1 / |g y|) ^ (2 ^ n) := fun n => iter n x₀\n  have : |f x₀| ≤ 0 := le_of_tendsto_of_tendsto tendsto_const_nhds tends_zero (Filter.eventually_of_forall hfx₀_le)\n  linarith [abs_nonneg (f x₀)]",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  intro y\n  have key := h₀ x₀ y\n  have habs : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by\n    calc |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _\n      _ ≤ 1 + 1 := add_le_add (h₂ _) (h₂ _)\n      _ = 2 := by ring\n  rw [key] at habs\n  simp only [abs_mul, abs_two] at habs\n  have hfx₀ : 0 < |f x₀| := abs_pos.mpr hx₀\n  have h1 : 2 * |f x₀| * |g y| ≤ 2 := habs\n  have h2 : |f x₀| * |g y| ≤ 1 := by linarith\n  by_contra hg\n  push_neg at hg\n  have : |f x₀| * |g y| > |f x₀| * 1 := by\n    apply mul_lt_mul_of_pos_left hg hfx₀\n  simp at this\n  have hfx₀_le : |f x₀| ≤ 1 := h₂ x₀\n  linarith",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  intro y\n  have key : f (x₀ + y) + f (x₀ - y) = 2 * f x₀ * g y := h₀ x₀ y\n  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀\n  have bound : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by\n    calc |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _\n      _ ≤ 1 + 1 := add_le_add (h₂ _) (h₂ _)\n      _ = 2 := by ring\n  rw [key, abs_mul, abs_mul, abs_of_pos (by norm_num : (0:ℝ) < 2)] at bound\n  have h3 : 2 * |f x₀| * |g y| ≤ 2 := bound\n  have h4 : |f x₀| * |g y| ≤ 1 := by linarith\n  by_contra h\n  push_neg at h\n  have : |f x₀| * |g y| > |f x₀| * 1 := by\n    apply mul_lt_mul_of_pos_left h hfx₀_pos\n  simp at this\n  have : |f x₀| * |g y| > 1 := by\n    calc |f x₀| * |g y| > |f x₀| := this\n      _ > 0 := hfx₀_pos\n    have hle : |f x₀| ≤ 1 := h₂ x₀\n    linarith [mul_lt_mul_of_pos_left h hfx₀_pos]\n  linarith",
      "\n  intro y\n  by_contra hgy\n  push_neg at hgy\n  have hM : ∃ x, f x ≠ 0 := by push_neg at h₁; exact h₁\n  obtain ⟨x₀, hx₀⟩ := hM\n  have key : ∀ x, 2 * |f x| * |g y| ≤ 2 := fun x => by\n    have eq := h₀ x y\n    calc 2 * |f x| * |g y| = |2 * f x * g y| := by rw [abs_mul, abs_mul]; ring\n      _ = |f (x + y) + f (x - y)| := by rw [eq]\n      _ ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n      _ ≤ 1 + 1 := add_le_add (h₂ _) (h₂ _)\n      _ = 2 := by ring\n  have bound : ∀ x, |f x| * |g y| ≤ 1 := fun x => by linarith [key x]\n  have habs : |f x₀| > 0 := abs_pos.mpr hx₀\n  have := bound x₀\n  have h3 : |f x₀| * |g y| > |f x₀| * 1 := by\n    apply mul_lt_mul_of_pos_left hgy habs\n  linarith",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀\n  let M := ⨆ x, |f x|\n  have hM_pos : 0 < M := lt_of_lt_of_le hfx₀_pos (le_ciSup ⟨1, fun _ ⟨_, hx⟩ => hx ▸ h₂ _⟩ x₀)\n  have hM_le : M ≤ 1 := ciSup_le fun x => h₂ x\n  intro y\n  by_contra h\n  push_neg at h\n  have h1 : 1 < |g y| := h\n  obtain ⟨x₁, hx₁⟩ : ∃ x₁, M / |g y| < |f x₁| := by\n    by_contra hc\n    push_neg at hc\n    have : M ≤ M / |g y| := ciSup_le fun x => hc x\n    have : M * |g y| ≤ M := by\n      calc M * |g y| = (M / |g y|) * |g y| * |g y| := by field_simp\n        _ ≤ M := by nlinarith [abs_nonneg (g y)]\n    nlinarith [abs_nonneg (g y)]\n  have hgy_ne : g y ≠ 0 := fun h => by simp [h] at h1\n  have eq1 := h₀ x₁ y\n  have : |f (x₁ + y) + f (x₁ - y)| ≤ |f (x₁ + y)| + |f (x₁ - y)| := abs_add _ _\n  have hle1 : |f (x₁ + y)| ≤ M := le_ciSup ⟨1, fun _ ⟨_, hx⟩ => hx ▸ h₂ _⟩ _\n  have hle2 : |f (x₁ - y)| ≤ M := le_ciSup ⟨1, fun _ ⟨_, hx⟩ => hx ▸ h₂ _⟩ _\n  have : |2 * f x₁ * g y| ≤ 2 * M := by rw [← eq1]; linarith\n  rw [abs_mul, abs_mul, abs_of_pos (by norm_num : (0:ℝ) < 2)] at this\n  have : |f x₁| * |g y| ≤ M := by linarith\n  have : M / |g y| * |g y| < |f x₁| * |g y| := by\n    apply mul_lt_mul_of_pos_right hx₁ (abs_pos.mpr hgy_ne)\n  rw [div_mul_cancel₀ M (abs_ne_zero.mpr hgy_ne)] at this\n  linarith",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  by_contra h\n  push_neg at h\n  obtain ⟨y₀, hy₀⟩ := h\n  have key : ∀ x, |f (x + y₀)| + |f (x - y₀)| ≥ 2 * |f x| * |g y₀| := fun x => by\n    have := h₀ x y₀\n    calc |f (x + y₀)| + |f (x - y₀)| ≥ |f (x + y₀) + f (x - y₀)| := abs_add_abs_le_abs_add _ _\n      _ = |2 * f x * g y₀| := by rw [this]\n      _ = 2 * |f x| * |g y₀| := by rw [abs_mul, abs_mul, abs_of_pos (by norm_num : (2:ℝ) > 0)]\n  have hM : ∃ M, M > 0 ∧ ∀ x, |f x| ≤ M ∧ M ≤ 1 := ⟨1, by norm_num, fun x => ⟨h₂ x, le_refl 1⟩⟩\n  have hfx₀ : |f x₀| > 0 := abs_pos.mpr hx₀\n  have bound := key x₀\n  have h1 : |f (x₀ + y₀)| ≤ 1 := h₂ _\n  have h2 : |f (x₀ - y₀)| ≤ 1 := h₂ _\n  have h3 : |f (x₀ + y₀)| + |f (x₀ - y₀)| ≤ 2 := by linarith\n  have h4 : 2 * |f x₀| * |g y₀| ≤ 2 := le_trans bound h3\n  have h5 : |f x₀| * |g y₀| ≤ 1 := by linarith\n  have h6 : |g y₀| ≤ 1 / |f x₀| := by\n    rw [div_eq_iff (ne_of_gt hfx₀)]\n    linarith\n  by_cases hfx₀1 : |f x₀| = 1\n  · simp [hfx₀1] at h6; linarith\n  · have hfx₀lt1 : |f x₀| < 1 := lt_of_le_of_ne (h₂ x₀) hfx₀1\n    -- Need a different approach - use that we can iterate\n    have iter : ∀ n : ℕ, ∃ x, |f x| ≥ |f x₀| * |g y₀|^n := by\n      intro n\n      induction n with\n      | zero => exact ⟨x₀, by simp; exact le_refl _⟩\n      | succ n ih =>\n        obtain ⟨x, hx⟩ := ih\n        have := key x\n        have sum_bound : |f (x + y₀)| + |f (x - y₀)| ≥ 2 * |f x| * |g y₀| := this\n        have : |f (x + y₀)| ≥ |f x| * |g y₀| ∨ |f (x - y₀)| ≥ |f x| * |g y₀| := by\n          by_contra hc\n          push_neg at hc\n          have : |f (x + y₀)| + |f (x - y₀)| < 2 * |f x| * |g y₀| := by linarith\n          linarith\n        cases this with\n        | inl h => exact ⟨x + y₀, by calc |f (x + y₀)| ≥ |f x| * |g y₀| := h\n                                    _ ≥ |f x₀| * |g y₀|^n * |g y₀| := by nlinarith [abs_nonneg (f x₀), abs_nonneg (g y₀)]\n                                    _ = |f x₀| * |g y₀|^(n+1) := by ring⟩\n        |