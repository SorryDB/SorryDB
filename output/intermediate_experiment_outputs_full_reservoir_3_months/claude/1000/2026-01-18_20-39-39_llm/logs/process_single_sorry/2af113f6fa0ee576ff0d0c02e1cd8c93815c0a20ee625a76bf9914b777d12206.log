      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  intro y\n  have key := h₀ x₀ y\n  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀\n  have hfx₀_le : |f x₀| ≤ 1 := h₂ x₀\n  have hfx₀_ne : f x₀ ≠ 0 := hx₀\n  have : g y = (f (x₀ + y) + f (x₀ - y)) / (2 * f x₀) := by\n    field_simp [hfx₀_ne]\n    linarith [key]\n  rw [this]\n  rw [abs_div, abs_mul, abs_of_pos (by norm_num : (0:ℝ) < 2)]\n  have h1 : |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _\n  have h2 : |f (x₀ + y)| ≤ 1 := h₂ _\n  have h3 : |f (x₀ - y)| ≤ 1 := h₂ _\n  have h4 : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by linarith\n  have h5 : 2 * |f x₀| > 0 := by positivity\n  rw [div_le_one h5]\n  calc |f (x₀ + y) + f (x₀ - y)| ≤ 2 := h4\n    _ = 2 * 1 := by ring\n    _ ≤ 2 * |f x₀| := by nlinarith [hfx₀_pos, hfx₀_le]",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  have hM : ∃ M : ℝ, M > 0 ∧ (∀ x, |f x| ≤ M) ∧ ∀ ε > 0, ∃ x, |f x| > M - ε := by\n    use sSup (Set.range (|f ·|))\n    constructor\n    · apply lt_of_lt_of_le (abs_pos.mpr hx₀)\n      apply le_csSup ⟨1, fun y ⟨x, hx⟩ => hx ▸ h₂ x⟩\n      exact ⟨x₀, rfl⟩\n    constructor\n    · intro x\n      apply le_csSup ⟨1, fun y ⟨z, hz⟩ => hz ▸ h₂ z⟩\n      exact ⟨x, rfl⟩\n    · intro ε hε\n      have hsup := Real.lt_sSup_iff ⟨1, fun y ⟨x, hx⟩ => hx ▸ h₂ x⟩\n      rw [hsup] at *\n      obtain ⟨y, ⟨x, rfl⟩, hy⟩ := (sub_lt_self _ hε : sSup (Set.range (|f ·|)) - ε < sSup (Set.range (|f ·|)))\n      exact ⟨x, hy⟩\n  intro y\n  by_contra h\n  push_neg at h\n  obtain ⟨M, hMpos, hMbound, hMsup⟩ := hM\n  have key : ∀ x, |f (x + y)| + |f (x - y)| ≥ 2 * |f x| * |g y| := fun x => by\n    have := h₀ x y\n    calc |f (x + y)| + |f (x - y)| ≥ |f (x + y) + f (x - y)| := abs_add_abs_ge_abs_add _ _\n      _ = |2 * f x * g y| := by rw [this]\n      _ = 2 * |f x| * |g y| := by rw [abs_mul, abs_mul, abs_of_pos (by norm_num : (2:ℝ) > 0)]\n  have contra : ∀ x, |f x| ≤ M / |g y| := fun x => by\n    have hgy : |g y| > 0 := lt_trans zero_lt_one h\n    have := key x\n    have h1 : |f (x + y)| ≤ M := hMbound _\n    have h2 : |f (x - y)| ≤ M := hMbound _\n    nlinarith\n  have hgy1 : |g y| > 1 := h\n  have : M / |g y| < M := by\n    rw [div_lt_iff (lt_trans zero_lt_one h)]\n    nlinarith\n  obtain ⟨x, hx⟩ := hMsup (M - M / |g y|) (by linarith)\n  have := contra x\n  linarith",
      "\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  intro y\n  by_contra h\n  push_neg at h\n  have hg : g y = (f (x₀ + y) + f (x₀ - y)) / (2 * f x₀) := by\n    have := h₀ x₀ y\n    field_simp at this ⊢\n    linarith\n  have hbound : |f (x₀ + y) + f (x₀ - y)| ≤ 2 := by\n    calc |f (x₀ + y) + f (x₀ - y)| ≤ |f (x₀ + y)| + |f (x₀ - y)| := abs_add _ _\n      _ ≤ 1 + 1 := add_le_add (h₂ _) (h₂ _)\n      _ = 2 := by ring\n  have hfx₀ : |f x₀| ≤ 1 := h₂ x₀\n  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀\n  rw [hg, abs_div, abs_mul, abs_two] at h\n  have h' : 2 * |f x₀| < |f (x₀ + y) + f (x₀ - y)| := by\n    have : 2 * |f x₀| < 2 * |f x₀| * |g y| := by\n      have := (div_lt_iff (by positivity : 0 < 2 * |f x₀|)).mp h\n      linarith\n    calc 2 * |f x₀| < 2 * |f x₀| * |g y| := this\n      _ = |f (x₀ + y) + f (x₀ - y)| := by rw [hg, abs_div, abs_mul, abs_two]; field_simp\n  have : 2 * |f x₀| ≤ 2 := by linarith [hfx₀]\n  linarith",
      "\n  by_contra hc\n  push_neg at hc\n  obtain ⟨y, hy⟩ := hc\n  have hgy : |g y| > 1 := hy\n  -- For any x with f(x) ≠ 0, we have 2*f(x)*g(y) = f(x+y) + f(x-y)\n  -- So |2*f(x)*g(y)| ≤ 2, meaning |f(x)| * |g(y)| ≤ 1\n  -- This means |f(x)| ≤ 1/|g(y)| < 1 for all x with f(x) ≠ 0\n  have key : ∀ x, |f x| ≤ 1 / |g y| := by\n    intro x\n    by_cases hfx : f x = 0\n    · simp [hfx, abs_nonneg]\n      exact div_nonneg (by norm_num) (abs_nonneg _)\n    · have h := h₀ x y\n      have bound : |f (x + y) + f (x - y)| ≤ 2 := by\n        calc |f (x + y) + f (x - y)| ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n          _ ≤ 1 + 1 := add_le_add (h₂ _) (h₂ _)\n          _ = 2 := by ring\n      rw [h] at bound\n      simp only [abs_mul, abs_of_pos (by norm_num : (2 : ℝ) > 0)] at bound\n      have hgy_pos : |g y| > 0 := by linarith\n      have : 2 * |f x| * |g y| ≤ 2 := bound\n      have : |f x| * |g y| ≤ 1 := by linarith\n      exact (div_le_one hgy_pos).mpr this\n  -- But sup |f x| must be positive since f is not identically zero\n  push_neg at h₁\n  obtain ⟨x₀, hx₀⟩ := h₁\n  have hfx₀_pos : |f x₀| > 0 := abs_pos.mpr hx₀\n  have hbound := key x₀\n  have hgy_pos : |g y| > 0 := by linarith\n  have : 1 / |g y| < 1 := by\n    rw [div_lt_one hgy_pos]\n    exact hgy\n  have hfx₀_le := h₂ x₀\n  -- We need |f x₀| ≤ 1/|g y| < 1, but also need to derive contradiction\n  -- The issue is that ALL nonzero values of f are bounded by 1/|g y| < 1\n  -- Apply functional equation at x₀, y to get bound, then iterate\n  -- Actually use that f(x+y) + f(x-y) = 2f(x)g(y), so |f(x+y) + f(x-y)| = 2|f(x)||g(y)|\n  -- Taking x = x₀: |f(x₀+y) + f(x₀-y)| = 2|f(x₀)||g(y)| > 2|f(x₀)|\n  -- But |f(x₀+y) + f(x₀-y)| ≤ |f(x₀+y)| + |f(x₀-y)| ≤ 2/|g(y)|\n  -- So 2|f(x₀)||g(y)| ≤ 2/|g(y)|, meaning |f(x₀)| ≤ 1/|g(y)|²\n  -- Iterating, |f(x₀)| → 0, contradiction.\n  -- Simpler: use x where |f(x)| is maximal-ish via supremum argument\n  have iter : ∀ n : ℕ, |f x₀| ≤ (1 / |g y|) ^ n := by\n    intro n\n    induction