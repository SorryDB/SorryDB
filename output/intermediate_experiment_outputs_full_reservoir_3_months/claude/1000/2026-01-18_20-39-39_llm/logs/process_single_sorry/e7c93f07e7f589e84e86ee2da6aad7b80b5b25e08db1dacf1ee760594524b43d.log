  intro x y h
  ext i hi
  unfold U8x32_as_Nat at h
  have key : ∀ (arr : Array U8 32) (j : ℕ) (hj : j < 32),
      (∑ k : Fin 32, ↑arr[k].val * 256 ^ k.val) / 256 ^ j % 256 = arr[j].val := by
