@[grind .]
theorem count_sum_above_below_pivot (pivot : α)
  (l : List α)(x : α) :
    (l.count x) = (smaller pivot l).count x +
      (larger pivot l).count x  := by
  induction l with
  | nil => simp
  | cons y ys ih =>
    simp only [smaller, larger, List.filter_cons]
    by_cases h : y ≤ pivot <;> by_cases hx : x = y <;> simp_all
```
