      "\n  intro v hv\n  obtain ⟨e, he, hev⟩ := hv\n  by_cases heP : e ∈ E(P)\n  · -- e is in both M and P, so e ∉ M ∆ E(P), but v must be incident to another edge in P\n    have hvinP : v ∈ V(P) := h.toIsPath.toIsWalk.vertexSet_subset (hev.mem_vertexSet (hM.subset he))\n    have hvne : v ≠ P.first ∧ v ≠ P.last := ⟨fun hf => h.first_not_in (hf ▸ hv), \n                                              fun hl => h.last_not_in (hl ▸ hv)⟩\n    obtain ⟨f, hfP, hfv, hef⟩ := h.toIsPath.toIsWalk.exists_edge_of_mem_vertexSet_not_endpoint hvinP hvne.1 hvne.2\n    refine ⟨f, ?_, hfv⟩\n    simp only [symmDiff_def, Set.mem_union, Set.mem_diff]\n    by_cases hfM : f ∈ M\n    · exfalso\n      exact (hM.disjoint he hfM hef).notMem_of_mem_left hev hfv\n    · exact Or.inr ⟨hfP, hfM⟩\n  · exact ⟨e, Or.inl ⟨he, heP⟩, hev⟩",
      "\n  sorry",
      "\n  intro v ⟨e, heM, he⟩\n  by_cases heP : e ∈ E(P)\n  · have hv : v ∈ V(P) := h.toIsPath.edgeSet_sub heM heP he\n    have hne_first : v ≠ P.first := fun h' ↦ h.first_not_in ⟨e, heM, h' ▸ he⟩\n    have hne_last : v ≠ P.last := fun h' ↦ h.last_not_in ⟨e, heM, h' ▸ he⟩\n    obtain ⟨f, hfE, hfv, hef⟩ := h.toIsPath.exists_other_edge_of_ne_first_last hv hne_first hne_last heP he\n    have hfnM : f ∉ M := fun hfM ↦ hM.disjoint heM hfM hef.symm |>.notMem_of_mem_left he hfv\n    exact ⟨f, hM.subset (h.toIsPath.edgeSet_sub heM hfE hfv), mem_symmDiff.mpr (Or.inr ⟨hfE, hfnM⟩), hfv⟩\n  · exact ⟨e, hM.subset heM, mem_symmDiff.mpr (Or.inl ⟨heM, heP⟩), he⟩",
      "\n  intro v ⟨e, heM, hve⟩\n  by_cases heP : e ∈ P.edgeSet\n  · sorry\n  · exact ⟨e, mem_symmDiff.mpr (Or.inl ⟨heM, heP⟩), hve⟩",
      "\n  intro v ⟨e, heM, hve⟩\n  by_cases heP : e ∈ P.edgeSet\n  · have hv_in_P : v ∈ V(P) := h.toIsPath.vertexSet_eq ▸ vertexSet_mono (singleton_subset_iff.mpr heP) hve\n    have hne_first : v ≠ P.first := fun hc => h.first_not_in (hc ▸ ⟨e, heM, hve⟩)\n    have hne_last : v ≠ P.last := fun hc => h.last_not_in (hc ▸ ⟨e, heM, hve⟩)\n    obtain ⟨f, hfP, hfv, hef⟩ := h.toIsPath.exists_adj_edge_of_mem hv_in_P hne_first hne_last heP\n    have hfnM : f ∉ M := (h.mem_matching_iff.rel heP hfP hef).mp heM\n    exact ⟨f, Or.inr ⟨hfP, hfnM⟩, hfv⟩\n  · exact ⟨e, Or.inl ⟨heM, heP⟩, hve⟩",
      "\n  intro v hv\n  obtain ⟨e, heM, hve⟩ := hv\n  by_cases heP : e ∈ E(P)\n  · have hv_vertex : v ∈ P.vertex := h.toIsPath.toIsWalk.edgeSet_inc_subset ⟨heP, hve⟩\n    have hne_first : v ≠ P.first := fun h' ↦ h.first_not_in (h' ▸ hv)\n    have hne_last : v ≠ P.last := fun h' ↦ h.last_not_in (h' ▸ hv)\n    obtain ⟨f, hfP, hfv, hef⟩ := h.toIsPath.exists_other_inc_of_mem_vertex hv_vertex hne_first hne_last heP hve\n    have hfnM : f ∉ M := fun hfM ↦ (hM.disjoint heM hfM hef).notMem_of_mem_left hve hfv\n    exact ⟨f, Or.inr ⟨hfP, hfnM⟩, hfv⟩\n  · exact ⟨e, Or.inl ⟨heM, heP⟩, hve⟩"
