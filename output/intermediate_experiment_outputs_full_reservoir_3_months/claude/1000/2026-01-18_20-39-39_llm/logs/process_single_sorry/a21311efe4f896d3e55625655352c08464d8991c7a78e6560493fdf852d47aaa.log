lemma limit_S_sphere(r : ℝ) :
    Tendsto (fun k : ℝ => k * Real.sin (r / k)) atTop (𝓝 r) := by
  have h1 : (fun k : ℝ => k * Real.sin (r / k)) = (fun k : ℝ => Real.sin (r / k) / (1 / k)) := by
    ext k
    exact mul_sin_as_div r k
  rw [h1]
  have h2 : (fun k : ℝ => Real.sin (r / k) / (1 / k)) = (fun k : ℝ => Real.sin (r * (1 / k)) / (1 / k)) := by
    ext k
    ring_nf
  rw [h2]
  have h3 : Tendsto (fun k : ℝ => (1 : ℝ) / k) atTop (𝓝 0) := tendsto_const_div_atTop_nhds_zero_nat ▸ 
    tendsto_one_div_atTop_nhds_zero_nat.congr (fun n => by simp)
  sorry
