            simp only [List.eraseIdx_cons_succ, List.eraseIdx_cons_zero, List.eraseIdx_cons_zero]
            subst heq
            exact List.Perm.refl _
          | 1, 1 =>
            simp only [List.getElem_cons_succ, List.getElem_cons_zero] at heq
            simp only [List.eraseIdx_cons_succ, List.eraseIdx_cons_zero]
            subst heq
