    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  refine ⟨refinement_le B hB hB' hB'', ?_⟩
  intro h_eq
  obtain ⟨N, hN, hBN⟩ := H
  have : B N hN ⊆ refinement B hB hB' hB'' := by
    intro x hx
    simp only [refinement, Set.mem_iUnion]
    exact ⟨N, hN, hx⟩
  have hB_sub_D : B N hN ⊆ D := by
    intro x hx
    exact h_eq ▸ this hx
  have hN_eq : N = sSup (B N hN) := hB N hN
  have : B N hN = {N} := by
    ext x
    constructor
    · intro hx
      have hxD : x ∈ D := hB_sub_D hx
      have hx_le : x ≤ N := by
        rw [hN_eq]
        exact le_sSup hx
      have hN_le : N ≤ x := by
        by_contra h_neg
        push_neg at h_neg
        have h_disj : Disjoint x (sSup (B N hN \ {x})) := 
          (hB' N hN).disjoint_sSup hx (Set.diff_subset) (Set.not_mem_diff_of_mem rfl)
        have h_sup : sSup (B N hN) = x ⊔ sSup (B N hN \ {x}) := by
          rw [← sSup_insert, Set.insert_diff_singleton, Set.insert_eq_of_mem hx]
        rw [hN_eq, h_sup] at h_neg
        have : x < x ⊔ sSup (B N hN \ {x}) := h_neg
        have hne : sSup (B N hN \ {x}) ≠ ⊥ := by
          intro heq
          rw [heq, sup_bot_eq] at this
          exact lt_irrefl x this
        have hle : sSup (B N hN \ {x}) ≤ N := by
          rw [hN_eq]
          exact sSup_le_sSup Set.diff_subset
        sorry
      exact Set.mem_singleton_iff.mpr (le_antisymm hx_le hN_le)
    · intro hx
      rw [Set.mem_singleton_iff] at hx
      subst hx
      have hne : B N hN ≠ ∅ := by
        intro hempty
        rw [hempty, sSup_empty] at hN_eq
        have : N = ⊥ := hN_eq
        exact D.not_bot_mem (this ▸ hN)
      obtain ⟨y, hy⟩ := Set.nonempty_iff_ne_empty.mpr hne
      have : y ≤ N := by rw [hN_eq]; exact le_sSup hy
      sorry
  exact hBN this
