    · exact hBN h.symm
    · obtain ⟨y, hy, hy_ne⟩ := Set.exists_of_ssubset h
      have hyD : y ∈ D := this hy
      have hy_le_N : y ≤ N := by rw [hN_eq]; exact le_sSup hy
      have hxy_disj : Disjoint x y := by
        have : x ≠ y := fun h => hy_ne (Set.mem_singleton_iff.mpr h)
        exact (sSupIndep_pair this).mp (hB' N hN).mono (Set.insert_subset hx (Set.singleton_subset_iff.mpr hy))
      have hx_ne_bot : x ≠ ⊥ := fun h => hB'' N hN (h ▸ hx)
      have hy_ne_bot : y ≠ ⊥ := fun h => hB'' N hN (h ▸ hy)
      have hxN_disj : Disjoint x N ∨ x = N := by
        by_cases hxN : x = N
        · right; exact hxN
        · left
          exact D.sSupIndep.disjoint_sSup hxD (Set.singleton_subset_iff.mpr hN) (Set.not_mem_singleton_iff.mpr hxN)
      rcases hxN_disj with hxN_disj | hxN_eq
      · have : x = ⊥ := Disjoint.eq_bot_of_le hxN_disj hx_le_N
        exact hx_ne_bot this
      · have hyN_disj : Disjoint y N ∨ y = N := by
          by_cases hyN : y = N
          · right; exact hyN
          · left
            exact D.sSupIndep.disjoint_sSup hyD (Set.singleton_subset_iff.mpr hN) (Set.not_mem_singleton_iff.mpr hyN)
        rcases hyN_disj with hyN_disj | hyN_eq
        · have : y = ⊥ := Disjoint.eq_bot_of_le hyN_disj hy_le_N
          exact hy_ne_bot this
        · rw [← hxN_eq, ← hyN_eq] at hxy_disj
          have : x = ⊥ := Disjoint.eq_bot_of_self hxy_disj
          exact hx_ne_bot this
