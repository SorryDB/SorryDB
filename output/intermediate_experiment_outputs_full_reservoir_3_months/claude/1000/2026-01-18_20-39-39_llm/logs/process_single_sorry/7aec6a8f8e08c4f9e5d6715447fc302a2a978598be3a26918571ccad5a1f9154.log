    · simp only [h1.not_lt, ↓reduceIte, h2, Function.update_self] at x' ⊢
      cases x i <;> simp [SpinState.toReal]
      all_goals nlinarith
    · push_neg at h2
      have : lf = 0 := le_antisymm h1 h2
      simp [this]
