  rw [biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField]
  let lf := biasedLocalField net x i
  let newSpin := biasedUpdateState net x i i
  let oldSpin := x i
  have h_update : newSpin = (if 0 < lf then SpinState.up
                            else if lf < 0 then SpinState.down
                            else oldSpin) := by
    simp only [biasedUpdateState, Function.update_same]
  by_cases h_pos : 0 < lf
