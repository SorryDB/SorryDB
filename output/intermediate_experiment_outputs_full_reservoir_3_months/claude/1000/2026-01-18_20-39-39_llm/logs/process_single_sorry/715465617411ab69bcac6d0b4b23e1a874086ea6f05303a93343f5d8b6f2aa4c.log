lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := by
  apply Set.ext
  intro x
  apply Iff.intro
  · intro hx
    by_contra hne
    have : x ∈ A \ {a} := And.intro hx hne
    exact h2 x this
  · intro hx
    rw [hx]
    exact h1
```
