    (F : Functor α β) :
    ∃ f: α → β, (Monotone f ∧ ∀ x: α, F.F x = f x) := by
  use F.F
  constructor
  · intro x y hxy
    have h : (Category.Preorder α).Hom x y := ⟨hxy⟩
    have hF := F.homF h
    exact hF.down
  · intro x
