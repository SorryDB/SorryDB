@[sorryful]
lemma limit_S_saddle(r : ℝ) :
    Tendsto (fun k : ℝ => k * Real.sinh (r / k)) atTop (𝓝 r) := by
  have h : (fun k : ℝ => k * Real.sinh (r / k)) = (fun k : ℝ => Real.sinh (r * k⁻¹) / k⁻¹) := by
    ext k
    simp [div_eq_mul_inv]
    ring_nf
    rfl
  rw [h]
  have h2 : Tendsto (fun k : ℝ => k⁻¹) atTop (𝓝[≠] 0) := by
    rw [tendsto_nhdsWithin_iff]
    constructor
    · exact tendsto_inv_atTop_zero
    · filter_upwards [Filter.eventually_gt_atTop 0] with k hk
      simp [ne_of_gt (inv_pos.mpr hk)]
  exact (tendsto_sinh_rx_over_x r).comp h2
```
