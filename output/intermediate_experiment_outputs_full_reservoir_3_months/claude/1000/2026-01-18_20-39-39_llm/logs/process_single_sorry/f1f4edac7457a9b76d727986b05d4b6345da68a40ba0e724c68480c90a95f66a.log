lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  obtain ⟨f, hf⟩ := h1
  obtain ⟨g, hg⟩ | ⟨n, g, hg⟩ := h2
  · left
    exact ⟨f ∘ g, bij_comp hf hg⟩
  · right
    exact ⟨n, f ∘ g, bij_comp hf hg⟩
```
