  naturality {X Y} f := by
    have hX := h X
    have hY := h Y
    rw [iso_iff_isIso] at hX hY
    obtain ⟨isoX, hXl, hXr⟩ := hX
    obtain ⟨isoY, hYl, hYr⟩ := hY
    have nat := η.naturality f
    -- η.arrow X ≫ G.homF f = F.homF f ≫ η.arrow Y
    -- We need: isoX.inv ≫ F.homF f = G.homF f ≫ isoY.inv
    have key : isoX.inv ≫ F.homF f = G.homF f ≫ isoY.inv := by
      calc isoX.inv ≫ F.homF f 
          = isoX.inv ≫ F.homF f ≫ (η.arrow Y ≫ isoY.inv) := by simp only [hYl, comp_id]
        _ = isoX.inv ≫ (F.homF f ≫ η.arrow Y) ≫ isoY.inv := by rw [assoc]
        _ = isoX.inv ≫ (η.arrow X ≫ G.homF f) ≫ isoY.inv := by rw [← nat]
        _ = (isoX.inv ≫ η.arrow X) ≫ G.homF f ≫ isoY.inv := by rw [assoc, assoc]
        _ = G.homF f ≫ isoY.inv := by simp only [hXr, id_comp]
    simp only
    convert key using 2 <;> {
      congr 1
      apply Classical.choose_spec
    }
```
