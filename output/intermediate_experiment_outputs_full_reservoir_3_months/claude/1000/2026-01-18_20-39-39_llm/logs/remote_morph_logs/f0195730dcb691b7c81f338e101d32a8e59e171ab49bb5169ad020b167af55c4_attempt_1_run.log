lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
    obtain ⟨ s, hs ⟩ := heq
    rw [hs]
    have h_card_eq : (p.snd.edgeSet).image (Sym2.map s) = (SimpleGraph.LoopWalk.permMapWalk n s p.snd).edgeSet := by
      have h_edges_eq : ∀ (u v : Fin n) (p : (K n).LoopWalk u v), (SimpleGraph.LoopWalk.permMapWalk n s p).edges = List.map (Sym2.map s) p.edges := by
        intros u v p
        induction' p with u v w h p ih
        · rfl
        · simp [SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.dartEdge, ih]
        · simp [SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.dartEdge, ih]
      unfold SimpleGraph.LoopWalk.edgeSet
      rw [h_edges_eq]
      simp [List.toFinset_map]
    rw [← h_card_eq, Finset.card_image_of_injective _ (Sym2.map_injective s.injective)]
```
