    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C ≤ hM.restrict₂ hM') :
    Disjoint (E(C) ∩ M) (E(C) ∩ M') := by
  rw [Set.disjoint_iff]
  intro e ⟨⟨heC, heM⟩, _, heM'⟩
  have heCsub : E(C) ⊆ E(hM.restrict₂ hM') := hCG.2
  have he : e ∈ E(hM.restrict₂ hM') := heCsub heC
  simp only [restrict₂, edgeSet_loopRemove, edgeSet_restrict, Set.mem_diff, Set.mem_inter_iff,
