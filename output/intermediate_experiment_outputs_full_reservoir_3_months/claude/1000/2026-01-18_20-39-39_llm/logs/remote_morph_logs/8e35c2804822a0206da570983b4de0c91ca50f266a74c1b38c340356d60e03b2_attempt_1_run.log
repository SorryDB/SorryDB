lemma IsMatching.disjoint_inter_of_isCycleGraph_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C ≤ hM.restrict₂ hM') :
    Disjoint (E(C) ∩ M) (E(C) ∩ M') := by
  rw [Set.disjoint_iff]
  intro e ⟨⟨heC, heM⟩, ⟨_, heM'⟩⟩
  have heCG : e ∈ E(hM.restrict₂ hM') := hCG.2 heC
  simp only [restrict₂, edgeSet_restrict, edgeSet_loopRemove, mem_diff, mem_inter_iff] at heCG
  exact heCG.1.2 (Or.intro_both heM heM')
```
