```lean
lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  have hM' : ∀ n, ‖f n‖² ≤ M ^ 2 := fun n ↦ sq_le_sq' (by linarith [norm_nonneg (f n)]) (hM n)
  obtain ⟨g, hg_mem, hg_cauchy⟩ := komlos_convex (φ := fun x ↦ ‖x‖²) (f := f)
    (fun x ↦ sq_nonneg _) ⟨M ^ 2, fun n ↦ hM' n⟩
  have hg_mem' : ∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m)) := fun n ↦
    convexHull_mono_coeffs (fun _ _ ↦ NNReal.coe_nonneg) (hg_mem n)
  suffices CauchySeq g by
    obtain ⟨x, hx⟩ := this.tendsto_completeSpace
    exact ⟨g, x, hg_mem', hx⟩
  rw [Metric.cauchySeq_iff]
  intro ε εpos
  obtain ⟨N, hN⟩ := hg_cauchy (ε ^ 2 / 2) (by positivity)
  refine ⟨N, fun n hn m hm ↦ ?_⟩
  have key := hN n m hn hm
  have h_parallelogram : ‖g n - g m‖² = 2 * ‖g n‖² + 2 * ‖g m‖² - ‖g n + g m‖² := by
    have := @parallelogram_law_with_norm ℝ E _ _ (g n) (g m)
    linarith [this]
  have h_avg : ‖(2 : ℝ≥0)⁻¹ • (g n + g m)‖² = (1/4) * ‖g n + g m‖² := by
    simp only [norm_smul, NNReal.norm_eq, NNReal.coe_inv, NNReal.coe_ofNat]
    ring
  calc ‖g n - g m‖² = 2 * ‖g n‖² + 2 * ‖g m‖² - ‖g n + g m‖² := h_parallelogram
    _ = 4 * (2⁻¹ * ‖g n‖² + 2⁻¹ * ‖g m‖² - (1/4) * ‖g n + g m‖²) := by ring
    _ = 4 * (2⁻¹ * ‖g n‖² + 2⁻¹ * ‖g m‖² - ‖(2 : ℝ≥0)⁻¹ • (g n + g m)‖²) := by rw [h_avg]
    _ < 4 * (ε ^ 2 / 2) := by nlinarith
    _ < ε ^ 2 := by linarith
  exact sq_lt_sq' (by linarith [norm_nonneg (g n - g m)]) this |>.2
```
