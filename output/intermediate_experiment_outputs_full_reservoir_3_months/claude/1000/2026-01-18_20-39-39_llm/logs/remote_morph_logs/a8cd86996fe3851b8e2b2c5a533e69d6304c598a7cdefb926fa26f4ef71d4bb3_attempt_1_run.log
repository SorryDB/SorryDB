    (fun x ↦ sq_nonneg _) ⟨M ^ 2, fun n ↦ sq_le_sq' (by linarith [norm_nonneg (f n)]) (hM n)⟩
  have hg_mem' : ∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m)) := fun n ↦
    convexHull_mono_scalar (by norm_num : (ℝ≥0 : Type _) → ℝ := (↑·)) (hg_mem n)
  -- The key: parallelogram law gives ‖g n - g m‖² = 2‖g n‖² + 2‖g m‖² - ‖g n + g m‖²
  -- = 4 * (½‖g n‖² + ½‖g m‖² - ‖½(g n + g m)‖²) which → 0
