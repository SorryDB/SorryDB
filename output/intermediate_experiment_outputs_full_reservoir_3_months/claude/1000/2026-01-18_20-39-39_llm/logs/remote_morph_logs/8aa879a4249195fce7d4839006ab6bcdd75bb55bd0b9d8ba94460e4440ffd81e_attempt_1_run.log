theorem algebra_amgm_faxinrrp2msqrt2geq2mxm1div2x :
  ∀ x > 0, 2 - Real.sqrt 2 ≥ 2 - x - 1 / (2 * x) := by
  intro x hx
  have h : x + 1 / (2 * x) ≥ Real.sqrt 2 := by
    have h1 : x + 1 / (2 * x) ≥ 2 * Real.sqrt (x * (1 / (2 * x))) := by
      apply add_div_two_ge_sqrt_mul_self_of_sq_le_sq (le_of_lt hx) (by positivity)
      ring_nf
      nlinarith [sq_nonneg (x - 1 / (2 * x))]
    simp only [mul_one_div, div_self (ne_of_gt (mul_pos (by norm_num : (0:ℝ) < 2) hx))] at h1
    calc x + 1 / (2 * x) ≥ 2 * Real.sqrt (1 / 2) := h1
      _ = 2 * (Real.sqrt 2 / 2) := by rw [Real.sqrt_div_self']
      _ = Real.sqrt 2 := by ring
  linarith
