- `Reversible (unreverse x) (unreverse z) p` means there exists some `w` in `(unreverse z).moves (-p)` such that the appropriate inequality holds with `unreverse x`.
- Since `unreverse z ≈ z` and `unreverse x ≈ x`, if `unreverse z` were reversible in `unreverse x`, then by the equivalences, `z` would be reversible in `x`.

```lean
/-- `unreverse x` has no reversible positions. -/
theorem not_reversible_unreverse (hy : y ∈ x.unreverse.moves p) : ¬ Reversible x.unreverse y p := by
  rw [moves_unreverse, Set.mem_iUnion₂] at hy
  obtain ⟨y, hy, ⟨z, hz, rfl⟩⟩ := hy
  by_cases h : Reversible x y p
  · sorry
  · rw [reverseSet_of_not_reversible h] at hz
    subst hz
    intro h'
    apply h
    cases p with
    | left =>
      rw [reversible_left] at h' ⊢
      obtain ⟨w, hw, hw'⟩ := h'
      rw [moves_unreverse, Set.mem_iUnion₂] at hw
      obtain ⟨w, hw, ⟨v, hv, rfl⟩⟩ := hw
