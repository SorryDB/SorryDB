        · exact .trans (.of_mem_moves hv) (.of_mem_moves h''.choose_mem_moves)
        · exact hv ▸ hw
      · calc x ≈ unreverse x := (unreverse_equiv x).symm
          _ ≤ unreverse v := hw'
          _ ≈ v := unreverse_equiv v
