theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  have hx := h₀.1
  have hy := h₀.2.1
  have hz := h₀.2.2
  have hx1 : x ≤ 1 := by linarith
  have hy1 : y ≤ 1 := by linarith
  have hz1 : z ≤ 1 := by linarith
  constructor
  · have : y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - 2 * x) + x * (y + z) := by ring
    rw [this]
    have hyz : x + y + z = 1 → y + z = 1 - x := by linarith
    rw [hyz h₁]
    have : y * z * (1 - 2 * x) + x * (1 - x) = y * z * (1 - 2 * x) + x * (1 - x) := rfl
    have h2 : 0 ≤ x * (1 - x) := by nlinarith
    by_cases hcase : x ≤ 1/2
    · have h3 : 0 ≤ 1 - 2 * x := by linarith
      have h4 : 0 ≤ y * z := by nlinarith
      nlinarith
    · push_neg at hcase
      have h3 : 1 - 2 * x < 0 := by linarith
      have hyz_bound : y * z ≤ ((y + z) / 2) ^ 2 := by nlinarith
      have hyz_sum : y + z = 1 - x := by linarith
      nlinarith
  · have key : y * z + z * x + x * y - 2 * x * y * z = 
               y * z * (1 - 2 * x) + x * (1 - x) := by ring_nf; linarith
    have am_gm : y * z ≤ ((y + z) / 2) ^ 2 := by nlinarith
    have hsum : y + z = 1 - x := by linarith
    nlinarith
