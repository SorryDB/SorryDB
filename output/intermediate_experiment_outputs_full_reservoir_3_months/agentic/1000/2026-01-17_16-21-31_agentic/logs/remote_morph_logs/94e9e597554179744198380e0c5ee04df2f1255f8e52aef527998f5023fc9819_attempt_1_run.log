```lean
lemma matchingMatroid.noColoop (h : ∀ x, G.inessential x) (hx : x ∈ V(G)) :
    ¬ G.matchingMatroid.IsColoop x := by
  obtain ⟨M, hM, hxM⟩ := h x
  intro hcol
  apply hxM
  have hbase : G.matchingMatroid.Base V(G, M) := by
    rw [Matroid.base_iff_maximal_indep]
    refine ⟨⟨M, hM.toIsMatching, Subset.rfl⟩, ?_⟩
    intro S ⟨M', hM', hSM'⟩ hVMS
    apply le_antisymm hVMS
    intro y hy
    by_contra hny
    have hcard : M.encard < M'.encard := by
      have hsub : V(G, M) ⊂ V(G, M') := ⟨hVMS.trans hSM', fun heq ↦ hny (heq ▸ hy)⟩
      have hfin : V(G, M').Finite := by
        apply Set.Finite.subset (s := E(G))
        · exact G.edgeSet_finite.subset hM'.subset
        · exact fun _ ⟨e, he, hv⟩ ↦ hM'.subset he
      calc M.encard < M'.encard := by
        have h1 : V(G, M).encard < V(G, M').encard := hfin.encard_lt_encard hsub
        simp only [encard_vertexSetEdges, ENat.toNat_mul, Nat.cast_ofNat] at h1
        omega
    exact (hM.max M' hM').not_lt hcard
  exact hcol.mem_of_base hbase
```
