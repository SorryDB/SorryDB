import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let P := S.powerset.filter (fun T => T.Nonempty)
  have hP_card : P.card = 2^10 - 1 := by simp [Finset.card_filter_powerset_nonempty, h₀]
  have hbounds : ∀ x ∈ S, 10 ≤ x ∧ x < 100 := fun x hx => Finset.mem_Ico.mp (h₁ hx)
  have hsum_in : ∀ T ∈ P, ∑ x ∈ T, x ∈ Finset.Icc 10 990 := by
    intro T hT
    simp only [Finset.mem_filter, Finset.mem_powerset] at hT
    obtain ⟨hTsub, t, ht⟩ := hT
    refine Finset.mem_Icc.mpr ⟨?_, ?_⟩
    · exact (hbounds t (hTsub ht)).1.trans (Finset.single_le_sum (fun _ _ => Nat.zero_le _) ht)
    · calc ∑ x ∈ T, x ≤ ∑ _ ∈ T, 99 := Finset.sum_le_sum fun x hx =>
          Nat.lt_succ_iff.mp (hbounds x (hTsub hx)).2
        _ = 99 * T.card := by simp [Finset.sum_const, smul_eq_mul]
        _ ≤ 99 * 10 := Nat.mul_le_mul_left _ ((Finset.card_le_card hTsub).trans (le_of_eq h₀))
        _ = 990 := by norm_num
  have hcard_lt : (Finset.Icc 10 990).card < P.card := by simp [hP_card]; native_decide
  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to hcard_lt hsum_in
  simp only [Finset.mem_filter, Finset.mem_powerset] at hA hB
  have hpos : ∀ x ∈ S, 0 < x := fun x hx => Nat.lt_of_lt_of_le (by norm_num) (hbounds x hx).1
  have hAnB : ¬A ⊆ B := fun h => hne.lt_of_le' (Finset.sum_lt_sum_of_nonempty hA.2
    (fun i hi => hpos i (hB.1 (h hi))) (Finset.exists_of_ssubset (Finset.ssubset_of_subset_of_ne h hne))).ne heq
  have hBnA : ¬B ⊆ A := fun h => hne.lt_of_le (Finset.sum_lt_sum_of_nonempty hB.2
    (fun i hi => hpos i (hA.1 (h hi))) (Finset.exists_of_ssubset (Finset.ssubset_of_subset_of_ne h hne.symm))).ne heq
  refine ⟨A \ B, B \ A, Finset.nonempty_sdiff.mpr hAnB, Finset.sdiff_subset.trans hA.1,
    Finset.nonempty_sdiff.mpr hBnA, Finset.sdiff_subset.trans hB.1, Finset.disjoint_sdiff_sdiff, ?_⟩
  have := Finset.sum_sdiff (Finset.inter_subset_left (s₁ := A) (s₂ := B))
  have := Finset.sum_sdiff (Finset.inter_subset_left (s₁ := B) (s₂ := A))
  simp only [Finset.inter_comm A B] at *
  omega
