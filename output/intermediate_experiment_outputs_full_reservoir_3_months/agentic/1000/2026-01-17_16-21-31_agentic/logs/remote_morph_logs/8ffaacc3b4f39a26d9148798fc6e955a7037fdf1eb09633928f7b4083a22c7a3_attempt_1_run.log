  refine h_indep.comp measurable_id ?_ ?_
  · exact fun ω ↦ hist alg ω n
  · induction n with
    | zero =>
      intro ⟨f, s⟩
      simp only [hist_zero, Fin.val_zero]
      exact ⟨fun _ ↦ (initAlgFunction alg (f 0), s 0 (initAlgFunction alg (f 0))), rfl⟩
