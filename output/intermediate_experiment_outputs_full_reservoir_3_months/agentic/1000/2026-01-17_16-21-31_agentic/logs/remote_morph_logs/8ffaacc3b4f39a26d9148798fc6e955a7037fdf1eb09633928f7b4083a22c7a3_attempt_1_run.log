  have h_indep : IndepFun (fun ω : probSpace α R ↦ ω.1 (n + 1))
      (fun ω ↦ ((fun i : Fin (n + 1) ↦ ω.1 i), ω.2)) (arrayMeasure ν) := by
    rw [arrayMeasure]
    refine IndepFun.prod_mk_right ?_ (by fun_prop)
    have : IndepFun (fun ω : ℕ → I ↦ ω (n + 1)) (fun ω ↦ (fun i : Fin (n + 1) ↦ ω i))
        (Measure.infinitePi fun _ ↦ volume) :=
      indepFun_eval_finset_proj_infinitePi (fun _ ↦ volume) (n + 1) (Finset.univ.map Fin.valEmbedding)
        (by simp)
    exact this.comp (φ := Prod.fst) (ψ := Prod.fst) (by fun_prop) (by fun_prop)
