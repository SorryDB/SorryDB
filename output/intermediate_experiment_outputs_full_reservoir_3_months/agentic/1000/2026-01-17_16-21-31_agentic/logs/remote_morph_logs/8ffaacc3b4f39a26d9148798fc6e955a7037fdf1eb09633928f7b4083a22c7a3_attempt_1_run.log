    h_iIndep.indepFun_restrict (s := Iic n) (i := n + 1) (by simp; omega)
  have h_key : IndepFun (fun ω : probSpace α R ↦ ω.1 (n + 1))
      (fun ω ↦ ((fun i : Iic n ↦ ω.1 i), ω.2)) (arrayMeasure ν) :=
    indepFun_fst_proj_snd_prod h_indep_fst_Iic (Bandit.streamMeasure ν)
