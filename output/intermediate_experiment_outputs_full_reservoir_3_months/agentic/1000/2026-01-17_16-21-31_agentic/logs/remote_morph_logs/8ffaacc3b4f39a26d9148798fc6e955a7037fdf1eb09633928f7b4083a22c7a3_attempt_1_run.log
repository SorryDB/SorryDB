      (Measure.infinitePi (fun _ ↦ (volume : Measure I))) :=
    iIndepFun_infinitePi (P := fun _ ↦ (volume : Measure I)) (X := fun _ ↦ id) fun _ ↦ measurable_id
  have h_indep_fst_Iic : IndepFun (fun ω : ℕ → I ↦ ω (n + 1)) (fun ω ↦ fun i : Iic n ↦ ω i)
