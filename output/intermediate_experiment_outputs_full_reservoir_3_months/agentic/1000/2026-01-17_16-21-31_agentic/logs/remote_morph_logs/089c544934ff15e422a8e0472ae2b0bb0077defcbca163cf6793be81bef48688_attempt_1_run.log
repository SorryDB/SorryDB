```lean
lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  refine le_tsub_of_add_le_left ?_
  have h1 : 2 * ν(G - Y) + (G - Y).OddComponents.encard ≤ (V(G) \ Y).encard := by
    obtain ⟨X, hX⟩ := Finite.exists_maximal (s := {X | ν((G - Y) - X) = ν(G - Y) - X.encard}) ⟨∅, by simp⟩
    have := tutte_berge_of_maximal_vertexDelete hX
    omega
  have h2 : ν(G) ≤ ν(G - Y) + Y.encard := by
    unfold MatchingNumber
    apply sSup_le
    rintro _ ⟨M, hM, rfl⟩
    apply le_sSup_of_le ⟨M ∩ E(G - Y), ⟨⟨fun e he => he.2, fun e f he hf hne => hM.disjoint he.1 hf.1 hne⟩, rfl⟩⟩
    calc M.encard = (M ∩ E(G - Y)).encard + (M \ E(G - Y)).encard := by rw [← encard_union_eq (disjoint_sdiff_right), inter_union_diff]
      _ ≤ (M ∩ E(G - Y)).encard + Y.encard := by
        apply add_le_add_left
        apply encard_le_encard
        intro e he
        have := hM.subset he.1
        simp only [vertexDelete, restrict_edgeSet, mem_diff, mem_setOf_eq] at he ⊢
        push_neg at he
        obtain ⟨v, hv⟩ := he.2 this
        exact hv
  calc 2 * ν(G) + (G - Y).OddComponents.encard 
      ≤ 2 * (ν(G - Y) + Y.encard) + (G - Y).OddComponents.encard := by omega
    _ = 2 * ν(G - Y) + (G - Y).OddComponents.encard + 2 * Y.encard := by ring
    _ ≤ (V(G) \ Y).encard + 2 * Y.encard := by omega
    _ ≤ V(G).encard + Y.encard := by
      have : (V(G) \ Y).encard ≤ V(G).encard := encard_le_encard diff_subset
      omega
```
