lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  obtain ⟨X, hX⟩ : ∃ X, Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X := by
    have : ∃ X, (fun X ↦ ν(G - X) = ν(G) - X.encard) X := ⟨∅, by simp⟩
    exact exists_maximal_wrt id _ (G.vertexSet.finite_of_finite.subset (fun _ _ => trivial)) this
  have hXeq := tutte_berge_of_maximal_vertexDelete hX
  apply le_tsub_of_add_le_left
  calc (G - Y).OddComponents.encard + 2 * ν(G) 
      ≤ V(G - Y).encard + 2 * ν(G) := by
        gcongr
        have : ∀ H ∈ (G - Y).OddComponents, V(H).Nonempty := fun H hH => hH.1.vertex_nonempty
        have hinj : ∀ H ∈ (G - Y).OddComponents, ∃ v ∈ V(G - Y), v ∈ V(H) := 
          fun H hH => ⟨hH.1.vertex_nonempty.some, hH.1.vertex_subset hH.1.vertex_nonempty.some_mem, 
            hH.1.vertex_nonempty.some_mem⟩
        exact encard_le_card (fun H hH => hinj H hH |>.choose) 
          (fun H hH => (hinj H hH).choose_spec.1) 
          (fun H₁ hH₁ H₂ hH₂ heq => hH₁.1.eq_of_vertex_inter_nonempty hH₂.1 
            ⟨_, (hinj H₁ hH₁).choose_spec.2, heq ▸ (hinj H₂ hH₂).choose_spec.2⟩)
    _ ≤ V(G).encard + Y.encard := by
        have hvdel : V(G - Y).encard ≤ V(G).encard := 
          encard_le_encard fun v hv => (vertexDelete_vertexSet ▸ hv).1
        have hν : 2 * ν(G) ≤ V(G).encard := by
          unfold MatchingNumber
          apply iSup_le
          rintro ⟨n, M, hM, rfl⟩
          calc M.encard * 2 ≤ V(G, M).encard := hM.maxDegree_le_one.encard_mul_two_le
            _ ≤ V(G).encard := encard_le_encard fun v hv => hv.1
        calc V(G - Y).encard + 2 * ν(G) 
