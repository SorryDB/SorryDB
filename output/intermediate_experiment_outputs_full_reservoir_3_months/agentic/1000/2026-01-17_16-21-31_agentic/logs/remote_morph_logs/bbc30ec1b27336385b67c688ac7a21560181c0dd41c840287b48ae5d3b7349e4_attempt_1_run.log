      intro i _ j _ hij
      apply Finset.disjoint_of_subset_left (hfsub i)
      apply Finset.disjoint_of_subset_right (hfsub j)
      exact Finset.disjoint_filter.mpr fun x _ hi hj => hij (hi.symm.trans hj)
    have hS₀color : ∀ i, #{j ∈ S₀ | c j = i} = 2 := fun i => by
      have heq : {j ∈ S₀ | c j = i} = f i := by
        ext x
        simp only [Finset.mem_filter, Finset.mem_biUnion, Finset.mem_univ, true_and, S₀]
        constructor
        · rintro ⟨⟨k, hxk⟩, hci⟩
          have hck := (Finset.mem_filter.mp (hfsub k hxk)).2
          have hkeqi : k = i := hck.symm.trans hci
          subst hkeqi; exact hxk
        · intro hx
          exact ⟨⟨i, hx⟩, (Finset.mem_filter.mp (hfsub i hx)).2⟩
      rw [heq, hfcard]
    have hScard : S₀.card = 2 * (n + 1) := by
      rw [Finset.card_biUnion (fun i hi j hj hij => hdisj (Set.mem_univ i) (Set.mem_univ j) hij)]
      simp only [hfcard, Finset.sum_const, Finset.card_univ, Fintype.card_fin, smul_eq_mul, mul_comm]
    have htotal : ∑ i ∈ S₀, ((i : ℕ) + 1) + ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) =
        ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) := Finset.sum_add_sum_compl S₀ _
    have hbalance : ∑ i ∈ S₀, ((i : ℕ) + 1) = ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) := by
      have h1 : ∑ i ∈ S₀, (1 : ℕ) = ∑ i ∈ S₀ᶜ, 1 := by
        simp only [Finset.sum_const, smul_eq_mul, mul_one, hScard, Finset.card_compl,
          Fintype.card_fin]
        omega
      have h2 : ∑ i ∈ S₀, (i : ℕ) = ∑ i ∈ S₀ᶜ, (i : ℕ) := by
        have := Finset.sum_add_sum_compl S₀ (fun i : Fin (4 * (n + 1)) => (i : ℕ))
        have hS₀c_card : S₀ᶜ.card = 2 * (n + 1) := by
          rw [Finset.card_compl, Fintype.card_fin, hScard]; omega
        omega
      simp only [Finset.sum_add_distrib] at htotal ⊢
      omega
