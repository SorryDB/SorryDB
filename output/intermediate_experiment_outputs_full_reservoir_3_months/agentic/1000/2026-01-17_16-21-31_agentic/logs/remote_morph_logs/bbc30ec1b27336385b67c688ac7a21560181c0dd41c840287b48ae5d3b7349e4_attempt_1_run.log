theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  classical
  cases n with
  | zero => exact ⟨∅, rfl, nofun⟩
  | succ n =>
    have : DecidablePred fun S : Finset (Fin (4 * (n + 1))) =>
        ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧ ∀ i, #{j ∈ S | c j = i} = 2 :=
      fun _ => And.decidable
    by_contra hne
    push_neg at hne
    have hsum : ∀ S : Finset (Fin (4 * (n + 1))), (∀ i, #{j ∈ S | c j = i} = 2) →
        ∑ i ∈ S, ((i : ℕ) + 1) + ∑ i ∈ Sᶜ, ((i : ℕ) + 1) = ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) :=
      fun S _ => by rw [← Finset.sum_add_sum_compl S]
    have htot : ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) = 2 * (n + 1) * (4 * n + 5) := by
      rw [Finset.sum_fin_eq_sum_range, ← Finset.sum_add_distrib]
      simp only [Finset.sum_range_id, Finset.card_range]
