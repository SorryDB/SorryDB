Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  classical
  induction n with
  | zero => exact ⟨∅, rfl, nofun⟩
  | succ n _ =>
    have hfour : ∀ i : Fin (n + 1), (Finset.univ.filter fun j => c j = i).card = 4 := fun i => by
      have := h i; simp only [Finset.card_filter] at this ⊢; exact this
    choose f hf hfcard using fun i => Finset.exists_subset_card_eq (s := Finset.univ.filter (c · = i))
      (k := 2) (by omega)
    let S := Finset.univ.biUnion f
    have hS2 : ∀ i, #{j ∈ S | c j = i} = 2 := fun i => by
      have hsub : f i ⊆ S := Finset.subset_biUnion_of_mem (f := f) (Finset.mem_univ i)
      have hfilt : f i ⊆ Finset.univ.filter (c · = i) := hf i
      simp only [Finset.card_filter, Finset.filter_filter]
      conv_lhs => rw [Finset.filter_eq' S (c · = i)]
      rw [Finset.filter_biUnion]
      have hdisj : ∀ j ∈ Finset.univ, ∀ k ∈ Finset.univ, j ≠ k →
          Disjoint (Finset.filter (c · = i) (f j)) (Finset.filter (c · = i) (f k)) := by
        intro j _ k _ hjk
        apply Finset.disjoint_filter_filter
        apply Finset.disjoint_of_subset_left (hf j)
        apply Finset.disjoint_of_subset_right (hf k)
        simp only [Finset.disjoint_filter]
        intro x _ hx _ hy
        exact hjk (hx.symm.trans hy)
      rw [Finset.card_biUnion hdisj]
      have : ∀ j ∈ Finset.univ, (Finset.filter (c · = i) (f j)).card = if j = i then 2 else 0 := by
        intro j _
        split_ifs with hji
        · subst hji
          have : f i ⊆ Finset.univ.filter (c · = i) := hf i
          simp only [Finset.filter_true_of_mem (fun x hx => (Finset.mem_filter.mp (this hx)).2)]
          exact hfcard i
        · apply Finset.card_eq_zero.mpr
          apply Finset.filter_eq_empty_iff.mpr
          intro x hx
          have : c x = j := (Finset.mem_filter.mp (hf j hx)).2
          intro hci
          exact hji (this.symm.trans hci)
      simp only [this, Finset.sum_ite_eq', Finset.mem_univ, ↓reduceIte]
    refine ⟨S, ?_, hS2⟩
    have heven : Even (∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1)) := by
      rw [← Finset.sum_univ_add, Finset.sum_add_distrib]
      simp only [Finset.sum_const, Finset.card_univ, Fintype.card_fin, smul_eq_mul, mul_one]
      rw [Finset.sum_fin_eq_sum_range, Finset.sum_range_id]
      ring_nf
      exact ⟨(n + 1) * (4 * n + 5), by ring⟩
    rw [← Finset.sum_add_sum_compl S, ← two_mul, eq_comm, ← Nat.add_right_cancel_iff (n := 0)]
    simp only [add_zero]
    omega

