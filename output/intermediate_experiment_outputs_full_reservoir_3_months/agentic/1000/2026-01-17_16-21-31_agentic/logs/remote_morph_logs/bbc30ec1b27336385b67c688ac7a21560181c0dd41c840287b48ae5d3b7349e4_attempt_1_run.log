import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  classical
  induction n with
  | zero => exact ⟨∅, rfl, nofun⟩
  | succ n _ =>
    have hge2 : ∀ i : Fin (n + 1), 2 ≤ (Finset.univ.filter fun j => c j = i).card :=
      fun i => by have := h i; omega
    choose f hfsub hfcard using fun i => Finset.exists_subset_card_eq (hge2 i)
    let S₀ := Finset.univ.biUnion f
    have hdisj : (Finset.univ : Set (Fin (n + 1))).PairwiseDisjoint f := by
      intro i _ j _ hij
      apply Finset.disjoint_of_subset_left (hfsub i)
      apply Finset.disjoint_of_subset_right (hfsub j)
      exact Finset.disjoint_filter.mpr fun x _ hi hj => hij (hi.symm.trans hj)
    have hS₀color : ∀ i, #{j ∈ S₀ | c j = i} = 2 := fun i => by
      have : {j ∈ S₀ | c j = i} = f i := by
        ext x
        simp only [Finset.mem_filter, Finset.mem_biUnion, Finset.mem_univ, true_and, S₀]
        constructor
        · rintro ⟨⟨k, hxk⟩, hci⟩
          have hck := (Finset.mem_filter.mp (hfsub k hxk)).2
          rw [hci] at hck
          rw [← hck]; exact hxk
        · intro hx
          exact ⟨⟨i, hx⟩, (Finset.mem_filter.mp (hfsub i hx)).2⟩
      rw [this, hfcard]
    have hScard : S₀.card = 2 * (n + 1) := by
      rw [Finset.card_biUnion hdisj]
      simp only [hfcard, Finset.sum_const, Finset.card_univ, Fintype.card_fin, smul_eq_mul, mul_comm]
    have hcompl : S₀ᶜ.card = 2 * (n + 1) := by
      rw [Finset.card_compl, Fintype.card_fin, hScard]
      omega
    have htotal : ∑ i ∈ S₀, ((i : ℕ) + 1) + ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) =
        ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) := Finset.sum_add_sum_compl S₀ _
    have htotval : ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) = 2 * (n + 1) * (4 * n + 5) := by
      simp only [Fin.sum_univ_eq_sum_range, Finset.sum_add_distrib, Finset.sum_const,
        Finset.card_range, smul_eq_mul, mul_one]
      rw [Finset.sum_range_id]
      ring
    have heven : 2 ∣ ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) := by
      rw [htotval]; exact dvd_mul_right 2 _
    have hbalance : ∑ i ∈ S₀, ((i : ℕ) + 1) = ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) := by
      have key : 2 * ∑ i ∈ S₀, ((i : ℕ) + 1) = ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) ∨
                 2 * ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) = ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) := by
        left
        have h1 : ∑ i ∈ S₀, ((i : ℕ) + 1) + ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) = 2 * (n + 1) * (4 * n + 5) := by
          rw [← htotval]; exact htotal
        have h2 : S₀.card = S₀ᶜ.card := by omega
        omega
      omega
    exact ⟨S₀, hbalance, hS₀color⟩
