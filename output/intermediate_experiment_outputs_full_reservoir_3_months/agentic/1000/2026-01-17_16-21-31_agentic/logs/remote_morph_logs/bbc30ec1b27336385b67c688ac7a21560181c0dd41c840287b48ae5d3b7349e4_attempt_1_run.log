import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  classical
  induction n with
  | zero => exact ⟨∅, rfl, nofun⟩
  | succ n =>
    have hfour : ∀ i : Fin (n + 1), (Finset.univ.filter fun j => c j = i).card = 4 := fun i => h i
    have hge2 : ∀ i : Fin (n + 1), 2 ≤ (Finset.univ.filter fun j => c j = i).card :=
      fun i => by rw [hfour i]; norm_num
    choose f hfsub hfcard using fun i => Finset.exists_subset_card_eq (hge2 i)
    let S₀ := Finset.univ.biUnion f
    have hS₀color : ∀ i, #{j ∈ S₀ | c j = i} = 2 := fun i => by
      simp only [Finset.sep_def, Finset.filter_filter, S₀]
      rw [Finset.filter_biUnion]
      have hdisj : (Finset.univ : Finset (Fin (n + 1))).PairwiseDisjoint
          fun j => Finset.filter (fun x => c x = i) (f j) := by
        intro j _ k _ hjk
        rw [Finset.disjoint_filter]
        intro x hxfj hcxi hxfk
        have := (Finset.mem_filter.mp (hfsub j hxfj)).2
        have := (Finset.mem_filter.mp (hfsub k hxfk)).2
        exact hjk (‹c x = j›.symm.trans ‹c x = k›)
      rw [Finset.card_biUnion hdisj]
      have heq : ∀ j ∈ Finset.univ, (Finset.filter (fun x => c x = i) (f j)).card =
          if j = i then 2 else 0 := by
        intro j _
        split_ifs with hji
        · subst hji
          convert hfcard i using 1
          rw [Finset.filter_true_of_mem]
          intro x hx
          exact (Finset.mem_filter.mp (hfsub i hx)).2
        · rw [Finset.filter_eq_empty_iff.mpr, Finset.card_empty]
          intro x hx
          exact hji.symm ∘ (·.symm.trans (Finset.mem_filter.mp (hfsub j hx)).2)
      simp only [heq, Finset.sum_ite_eq', Finset.mem_univ, ↓reduceIte]
    obtain ⟨S, hSsum, hScol⟩ : ∃ S : Finset (Fin (4 * (n + 1))),
        ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧ ∀ i, #{j ∈ S | c j = i} = 2 := by
      use S₀
      refine ⟨?_, hS₀color⟩
      have hScard : S₀.card = 2 * (n + 1) := by
        simp only [S₀]
        rw [Finset.card_biUnion]
        · simp only [hfcard, Finset.sum_const, Finset.card_univ, Fintype.card_fin, smul_eq_mul]
        · intro i _ j _ hij
          apply Finset.disjoint_of_subset_left (hfsub i)
          apply Finset.disjoint_of_subset_right (hfsub j)
          exact Finset.disjoint_filter.mpr fun x _ hi hj => hij (hi.symm.trans hj)
      have hcompl : S₀ᶜ.card = 2 * (n + 1) := by
        rw [Finset.card_compl, Fintype.card_fin, hScard]
        ring
      have htotal : ∑ i ∈ S₀, ((i : ℕ) + 1) + ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) =
          ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) := Finset.sum_add_sum_compl S₀ _
      have heven : Even (∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1)) := by
        simp only [Fin.sum_univ_eq_sum_range, Finset.sum_add_distrib, Finset.sum_const,
          Finset.card_range, smul_eq_mul, mul_one, Finset.sum_range_id]
        use (n + 1) * (4 * n + 5)
        ring
      omega
    exact ⟨S, hSsum, hScol⟩
