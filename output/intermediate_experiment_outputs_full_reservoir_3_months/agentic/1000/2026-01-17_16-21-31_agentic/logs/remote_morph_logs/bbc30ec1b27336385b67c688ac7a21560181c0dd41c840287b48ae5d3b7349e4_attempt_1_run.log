Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  classical
  induction n with
  | zero => exact ⟨∅, rfl, nofun⟩
  | succ n _ =>
    -- For each color i, the set of pebbles with that color
    let colorClass := fun i => Finset.filter (fun j => c j = i) Finset.univ
    -- Each color class has exactly 4 elements
    have hcc : ∀ i, (colorClass i).card = 4 := fun i => by simpa using h i
    -- The set of all valid selections (exactly 2 from each color)
    let validSels := Finset.filter (fun S : Finset (Fin (4 * (n + 1))) =>
      ∀ i : Fin (n + 1), (S.filter (fun j => c j = i)).card = 2) Finset.univ
    -- The set of balanced valid selections
    let balancedSels := Finset.filter (fun S =>
      ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1)) validSels
    suffices hn : balancedSels.Nonempty by
      obtain ⟨S, hS⟩ := hn
      simp only [Finset.mem_filter, Finset.mem_univ, true_and, balancedSels, validSels] at hS
      exact ⟨S, hS.2, hS.1⟩
    rw [Finset.nonempty_iff_ne_empty]
    intro hemp
    have hvalid : validSels.Nonempty := by
      have : ∀ i : Fin (n + 1), ∃ T : Finset (Fin (4 * (n + 1))), T ⊆ colorClass i ∧ T.card = 2 :=
        fun i => Finset.exists_subset_card_eq (by simp [hcc i])
      choose f hfsub hfcard using this
      use Finset.univ.biUnion f
      simp only [Finset.mem_filter, Finset.mem_univ, true_and, validSels]
      intro i
      have hdisj : Set.PairwiseDisjoint Set.univ f := fun a _ b _ hab => by
        apply Finset.disjoint_of_subset_left (hfsub a)
        apply Finset.disjoint_of_subset_right (hfsub b)
        simp only [colorClass, Finset.disjoint_filter]
        intro x _ hxa hxb
        exact hab (hxa.symm.trans hxb)
      have hmem : ∀ x, x ∈ f i ↔ x ∈ Finset.univ.biUnion f ∧ c x = i := fun x => by
        constructor
        · intro hx
          refine ⟨Finset.mem_biUnion.mpr ⟨i, Finset.mem_univ i, hx⟩, ?_⟩
          exact Finset.mem_filter.mp (hfsub i hx) |>.2
        · rintro ⟨hxU, hci⟩
          obtain ⟨j, _, hxj⟩ := Finset.mem_biUnion.mp hxU
          have : c x = j := Finset.mem_filter.mp (hfsub j hxj) |>.2
          rw [hci] at this; rw [← this]; exact hxj
      conv_lhs => rw [← hfcard i]
      congr 1
      ext x
      rw [Finset.mem_filter, hmem]
    obtain ⟨S₀, hS₀⟩ := hvalid
    simp only [Finset.mem_filter, Finset.mem_univ, true_and, validSels] at hS₀
    have hS₀card : S₀.card = 2 * (n + 1) := by
      have : S₀ = Finset.univ.biUnion (fun i => S₀.filter (fun j => c j = i)) := by
        ext x; simp only [Finset.mem_biUnion, Finset.mem_univ, Finset.mem_filter, true_and]
        constructor
        · intro hx; exact ⟨c x, hx, rfl⟩
        · rintro ⟨_, hx, _⟩; exact hx
      rw [this, Finset.card_biUnion]
      · simp only [hS₀, Finset.sum_const, Finset.card_univ, Fintype.card_fin, smul_eq_mul, mul_comm]
      · intro i _ j _ hij
        simp only [Finset.disjoint_filter]
        intro x _ hci hcj; exact hij (hci.symm.trans hcj)
    have hS₀c_card : S₀ᶜ.card = 2 * (n + 1) := by
      rw [Finset.card_compl, Fintype.card_fin, hS₀card]; omega
    have hS₀c_valid : ∀ i, (S₀ᶜ.filter (fun j => c j = i)).card = 2 := fun i => by
      have h1 : (colorClass i).card = (S₀.filter (c · = i)).card + (S₀ᶜ.filter (c · = i)).card := by
        rw [← Finset.card_union_of_disjoint]
        · congr 1
          ext x
          simp only [Finset.mem_union, Finset.mem_filter, Finset.mem_compl, colorClass,
            Finset.mem_univ, true_and]
          tauto
        · exact Finset.disjoint_of_subset_left Finset.filter_subset Finset.disjoint_compl_right
      simp only [hcc, hS₀] at h1; omega
    have htot : ∑ i ∈ S₀, ((i : ℕ) + 1) + ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) =
        ∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1) := Finset.sum_add_sum_compl S₀ _
    have hne : ∑ i ∈ S₀, ((i : ℕ) + 1) ≠ ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) := by
      intro heq
      have : S₀ ∈ balancedSels := by simp [balancedSels, validSels, hS₀, heq]
      rw [hemp] at this; exact Finset.not_mem_empty _ this
    -- Get contradiction using symmetry
    have hS₀c_mem : S₀ᶜ ∈ validSels := by simp [validSels, hS₀c_valid]
    have hne' : ∑ i ∈ S₀ᶜ, ((i : ℕ) + 1) ≠ ∑ i ∈ S₀ᶜᶜ, ((i : ℕ) + 1) := by
      simp only [Finset.compl_compl]
      exact hne.symm
    have hS₀cc : S₀ᶜᶜ = S₀ := Finset.compl_compl S₀
    -- Both S₀ and S₀ᶜ are valid but neither is balanced - impossible by parity
    have : Even (∑ i : Fin (4 * (n + 1)), ((i : ℕ) + 1)) := by
      use (4 * (n + 1)) * (4 * (n + 1) + 1) / 2
      simp only [Finset.sum_add_distrib, Finset.sum_const, Finset.card_univ, Fintype.card_fin,
        smul_eq_mul, mul_one]
      rw [Fin.sum_univ_eq_sum_range, Finset.sum_range_id]
      omega
    omega
