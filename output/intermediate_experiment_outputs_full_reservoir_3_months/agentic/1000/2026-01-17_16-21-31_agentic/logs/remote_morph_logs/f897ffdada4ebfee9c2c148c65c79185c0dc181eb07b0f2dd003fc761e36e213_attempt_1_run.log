  induction P using WList.rec with
  | nil x => exact (h.nonempty rfl).elim
  | cons x e P ih =>
    have he_not_M : e ∉ M := fun heM ↦ h.first_not_in ⟨e, heM, hpath.toIsWalk.link.inc_left⟩
    match P with
    | .nil y =>
      simp only [WList.edgeSet_cons, WList.edgeSet_nil, union_empty]
      rw [sdiff_singleton_eq_self he_not_M, diff_singleton_eq_self he_not_M,
          encard_insert_of_not_mem (fun ⟨_, hc⟩ ↦ hc rfl)]
    | .cons y f Q =>
