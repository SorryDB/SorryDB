        simp only [WList.cons_edge, List.isChain_cons] at halt
        exact halt.1.resolve_left he_not_M
      simp only [WList.edgeSet_cons]
      rw [sdiff_insert_of_not_mem _ he_not_M, insert_diff_of_mem _ hf_M,
          insert_diff_of_not_mem _ he_not_M, sdiff_insert_of_mem hf_M]
      rw [encard_insert_of_not_mem, encard_insert_of_not_mem]
      · have h' : G.IsAugPath hM (.cons y f Q) := by
          refine ⟨h.toIsAltPath.of_cons, ⟨y, f, Q, rfl⟩, ?_, h.last_not_in⟩
