```lean
instance (priority := 100) IsKrullDomain.isIntegrallyClosed
    (A : Type*) [CommRing A] [IsDomain A] [IsKrullDomain A] : IsIntegrallyClosed A := by
  rw [isIntegrallyClosed_iff (FractionRing A)]
  intro x hx
  rw [← IsKrullDomain.biInf_eq_bot A, Subalgebra.mem_iInf]
  intro p
  rw [Subalgebra.mem_iInf]
  intro hp
  haveI := IsKrullDomain.isDiscreteValuationRing_localization p hp
  haveI : IsIntegrallyClosed (Localization p.1.primeCompl) := inferInstance
  exact Localization.subalgebra.isIntegral_mem hx
```
