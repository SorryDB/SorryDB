import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  suffices h : m ≤ 2 * #A by
    have : (m : ℚ) ≤ 2 * #A := by exact_mod_cast h
    linarith
  have hBinj : Function.Injective B := fun i j hij => by
    have hi := hB i
    have hj := hB j
    rw [hij] at hi
    have heq : (m : ℤ) ^ ((i : ℕ) + 1) = (m : ℤ) ^ ((j : ℕ) + 1) := hi.symm.trans hj
    have hm1 : 1 < m := Nat.one_lt_two.trans_le hm
    have heq' : m ^ ((i : ℕ) + 1) = m ^ ((j : ℕ) + 1) := by
      have := Int.ofNat_inj.mp (by simp only [Int.ofNat_pow]; exact heq)
      exact this
    have := Nat.pow_right_injective hm1 heq'
    ext; omega
  have hnonempty : ∀ k, (B k).Nonempty := fun k => by
    by_contra hemp
    simp only [Finset.not_nonempty_iff_eq_empty] at hemp
    have := hB k
    rw [hemp, Finset.sum_empty] at this
    have hmp : 0 < (m : ℤ) ^ ((k : ℕ) + 1) := by positivity
    omega
  have htotal : m ≤ ∑ k : Fin m, #(B k) := by
    calc m = ∑ _k : Fin m, 1 := by simp
      _ ≤ ∑ k : Fin m, #(B k) := Finset.sum_le_sum fun k _ =>
          Finset.one_le_card.mpr (hnonempty k)
  have hcount : ∑ k : Fin m, #(B k) ≤ ∑ a ∈ A, m := by
    have hsub : ∀ k, B k ⊆ A := hBA
    calc ∑ k : Fin m, #(B k) = ∑ k : Fin m, ∑ _a ∈ B k, 1 := by simp
      _ = ∑ k : Fin m, ∑ a ∈ A, if a ∈ B k then 1 else 0 := by
          congr 1; ext k
          rw [← Finset.sum_filter]
          congr 1
          ext a
          simp only [Finset.mem_filter, and_iff_right_iff_imp]
          exact fun ha => hsub k ha
      _ = ∑ a ∈ A, ∑ k : Fin m, if a ∈ B k then 1 else 0 := Finset.sum_comm
      _ ≤ ∑ a ∈ A, m := Finset.sum_le_sum fun a _ => by
          calc ∑ k : Fin m, if a ∈ B k then 1 else 0
              ≤ ∑ _k : Fin m, 1 := Finset.sum_le_sum fun k _ => by split_ifs <;> omega
            _ = m := by simp
  simp only [Finset.sum_const, Finset.card_univ, Fintype.card_fin, smul_eq_mul] at hcount
  omega
