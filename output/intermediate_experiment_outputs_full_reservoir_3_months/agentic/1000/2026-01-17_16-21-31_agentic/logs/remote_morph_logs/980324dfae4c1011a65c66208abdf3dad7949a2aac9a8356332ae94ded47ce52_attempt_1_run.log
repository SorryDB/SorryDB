  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B ⟨MI, hMI, hIsub⟩ hInotmax ⟨⟨MB, hMB, hBsub⟩, hBmax⟩
    have hBnsubI : ¬(B ⊆ I) := fun hBI ↦ hInotmax ⟨⟨MI, hMI, hIsub⟩,
      fun J hJ hIJ ↦ (hBmax hJ (hBI.trans hIJ)).trans hBI⟩
    by_cases h : ∃ x ∈ B \ I, x ∈ V(G, MI)
    · obtain ⟨x, ⟨hxB, hxnI⟩, hxMI⟩ := h
      exact ⟨x, ⟨hxB, hxnI⟩, MI, hMI, Set.insert_subset hxMI hIsub⟩
    · push_neg at h
      obtain ⟨x, hxB, hxnI⟩ := Set.not_subset.mp hBnsubI
      refine ⟨x, ⟨hxB, hxnI⟩, MB, hMB, Set.insert_subset (hBsub hxB) ?_⟩
