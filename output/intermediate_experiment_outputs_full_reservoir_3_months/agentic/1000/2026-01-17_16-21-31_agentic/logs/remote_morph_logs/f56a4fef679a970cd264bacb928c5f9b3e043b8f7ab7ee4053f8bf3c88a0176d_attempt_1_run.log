lemma sup_stoppedProcess_hittingAfter_Ici_le {E : Type*} [NormedAddCommGroup E] [InfSet ι] [Bot ι]
    {X : ι → Ω → E} (t : ι) (K : ℝ) (ω : Ω) :
    ⨆ s ≤ t, ‖stoppedProcess X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) s ω‖ ≤
    K + Set.indicator {ω | hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω ≤ t}
      (fun ω ↦ ‖stoppedValue X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) ω‖) ω := by
  classical
  set τ := hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥
  by_cases hτω : τ ω ≤ ↑t
  · rw [Set.indicator_of_mem (s := {ω | τ ω ≤ ↑t}) hτω]
    have hbdd : BddAbove (Set.range fun s => ⨆ (_ : s ≤ t), ‖stoppedProcess X τ s ω‖) :=
      ⟨K + ‖stoppedValue X τ ω‖, by simp only [Set.mem_range, forall_exists_index, 
        forall_apply_eq_imp_iff]; intro s; apply ciSup_le'; intro hs; simp [stoppedProcess]; 
        nlinarith [norm_nonneg (X (min ↑s (τ ω)).untopA ω), norm_nonneg (stoppedValue X τ ω)]⟩
    exact Real.iSup_le hbdd (fun s => ciSup_le' fun hs => by simp [stoppedProcess]; 
      nlinarith [norm_nonneg (X (min ↑s (τ ω)).untopA ω), norm_nonneg (stoppedValue X τ ω)])
  · rw [Set.indicator_of_not_mem (s := {ω | τ ω ≤ ↑t}) hτω, add_zero]
    have hbdd : BddAbove (Set.range fun s => ⨆ (_ : s ≤ t), ‖stoppedProcess X τ s ω‖) :=
      ⟨K, by simp only [Set.mem_range, forall_exists_index, forall_apply_eq_imp_iff]; 
        intro s; apply ciSup_le'; intro hs; simp [stoppedProcess]; 
        nlinarith [norm_nonneg (X (min ↑s (τ ω)).untopA ω)]⟩
    exact Real.iSup_le hbdd (fun s => ciSup_le' fun hs => by simp [stoppedProcess]; 
      nlinarith [norm_nonneg (X (min ↑s (τ ω)).untopA ω)])
