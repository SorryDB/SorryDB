lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  rw [hs]
  have h_card_eq : (p.snd.edgeSet).image (Sym2.map s) = (permMapWalk n s p.snd).edgeSet := by
    unfold edgeSet
    ext e
    simp only [Finset.mem_image, List.mem_toFinset]
    constructor
    all_goals intro h
    · obtain ⟨e', he', rfl⟩ := h
      have h_edges_eq : ∀ (u v : Fin n) (w : (K n).LoopWalk u v),
          (permMapWalk n s w).edges = w.edges.map (Sym2.map s) := by
        intros u v w
        induction w with
        | nil => rfl
        | cons h' w' ih => simp [permMapWalk, edges, darts, dartEdge, ih]
        | loop w' ih => simp [permMapWalk, edges, darts, dartEdge, ih]
      rw [h_edges_eq]
      exact List.mem_map_of_mem _ he'
    · have h_edges_eq : ∀ (u v : Fin n) (w : (K n).LoopWalk u v),
          (permMapWalk n s w).edges = w.edges.map (Sym2.map s) := by
        intros u v w
        induction w with
        | nil => rfl
        | cons h' w' ih => simp [permMapWalk, edges, darts, dartEdge, ih]
        | loop w' ih => simp [permMapWalk, edges, darts, dartEdge, ih]
      rw [h_edges_eq] at h
      exact List.mem_map.mp h
  rw [← h_card_eq, Finset.card_image_of_injective _ (Sym2.map_injective s.injective)]
