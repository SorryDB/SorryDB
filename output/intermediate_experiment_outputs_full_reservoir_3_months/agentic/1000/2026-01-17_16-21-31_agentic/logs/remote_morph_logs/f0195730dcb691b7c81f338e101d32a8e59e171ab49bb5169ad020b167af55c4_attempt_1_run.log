lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
    obtain ⟨s, hs⟩ := heq
    rw [hs]
    have h_card_eq : (p.snd.edgeSet).image (Sym2.map s) = (permMapWalk n s p.snd).edgeSet := by
      have h_edges_eq : ∀ (u v : Fin n) (w : (K n).LoopWalk u v), (permMapWalk n s w).edges = w.edges.map (Sym2.map s) := by
        intros u v w
        induction w with
        | nil => rfl
        | cons h' w' ih => simp [permMapWalk, edges, darts, dartEdge, ih]
        | loop w' ih => simp [permMapWalk, edges, darts, dartEdge, ih]
      unfold edgeSet
      aesop
    rw [← h_card_eq, Finset.card_image_of_injective _ (Sym2.map_injective s.injective)]
```
