              | cons b bs => by_cases h : as = [] <;> simp [h, tailSL, fromSL]
          have hhead : List.head? (fromSL s) = some hsl := by
            have ⟨xs, ys, _⟩ := s
            simp only [fromSL, headSL] at h2 ⊢
            split at h2 <;> simp_all
          cases hfs : fromSL s with
