  clear hs lhs rhs ok
  induction s using @WellFounded.induction _ (InvImage.wf lengthSL Nat.lt_wfRel.wf) with
  | _ s ih =>
    conv_rhs => unfold dropWhileSL
    split
    · rename_i hempty
      have ⟨as, bs, _⟩ := s
      simp only [Bool.and_eq_true] at hempty
      simp only [fromSL, List.isEmpty_iff] at hempty ⊢
      simp [hempty.1, hempty.2, nil, dropWhile]
    · split
      · rename_i _ h2
        rw [headSL_none_iff_nilSL] at h2
        simp [h2, nil, fromSL, dropWhile]
      · rename_i _ hsl h2
        split
        · rename_i hp
          have hne : s ≠ nil := by
            intro hc; rw [hc] at h2; simp [headSL, nil] at h2
          have hlt := length_tail_lt_length s hne
          specialize ih (tailSL s) hlt
          have htail : fromSL (tailSL s) = tail (fromSL s) := by
            have ⟨xs, ys, ok'⟩ := s
            cases xs with
            | nil =>
              simp [List.isEmpty_iff] at ok'
              cases ok'.1 rfl with
              | inl h => simp [h, tailSL, nil, fromSL]
              | inr h => have [_] := ys; simp [tailSL, nil, fromSL]
            | cons a as =>
