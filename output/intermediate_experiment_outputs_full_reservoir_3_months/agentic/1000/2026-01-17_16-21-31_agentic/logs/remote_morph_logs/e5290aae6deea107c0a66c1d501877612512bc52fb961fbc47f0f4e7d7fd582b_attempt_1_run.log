The key insight is to use well-founded induction on `lengthSL` and handle the recursive case properly by appealing to the induction hypothesis.

```lean
example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  have ⟨lhs, rhs, ok⟩ := sl
  simp only [Function.comp_apply]
  generalize hs : SymList.mk lhs rhs ok = s
  clear hs lhs rhs ok
  induction s using (measure lengthSL).wf.induction with
  | ind s ih =>
    unfold dropWhileSL
    split
    · rename_i h
      simp only [Bool.and_eq_true, List.isEmpty_iff] at h
      have ⟨as, bs, _⟩ := s
      simp [h.1, h.2, fromSL, nil, dropWhile]
    · split
      · rename_i _ h
        rw [headSL_none_iff_nilSL] at h
        simp [h, nil, fromSL, dropWhile]
      · rename_i _ hsl h
        split
        · rename_i hp
          have hne : s ≠ nil := by
            intro hc; rw [hc, headSL, nil] at h; simp at h
          rw [ih (tailSL s) (length_tail_lt_length s hne)]
          have ⟨xs, ys, ok⟩ := s
          have hhead : (fromSL ⟨xs, ys, ok⟩).head? = some hsl := by
            unfold headSL at h
            split at h <;> simp_all [fromSL]
          cases hfs : fromSL ⟨xs, ys, ok⟩ with
          | nil => simp at hhead
          | cons x xss =>
            simp at hhead
            simp only [dropWhile, hhead, hp, ↓reduceIte]
            congr 1
            cases xs with
            | nil =>
              simp only [List.isEmpty_iff] at ok
              cases ok.1 rfl with
              | inl h2 => simp [h2] at hfs
              | inr h2 => have [_] := ys; simp [tailSL, nil, fromSL]
            | cons a as =>
              cases ys with
              | nil => by_cases h2 : as = [] <;> simp [h2, tailSL, fromSL, splitInTwoSL, hfs]
              | cons b bs => by_cases h2 : as = [] <;> simp [h2, tailSL, fromSL, hfs]
        · rename_i hp
          have ⟨xs, ys, _⟩ := s
          unfold headSL at h
          split at h <;> simp_all [fromSL, dropWhile]
