lemma tutte_berge_of_maximal_vertexDelete (hX : Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X) :
    2 * ν(G - X) = (V(G) \ X).encard - (G - X).OddComponents.encard := by
  have h_iness : ∀ x, (G - X).inessential x := fun x => by
    by_cases hx : x ∈ V(G - X)
    · have hmax := hX.prop
      have hXx : ¬(ν(G - (X ∪ {x})) = ν(G) - (X ∪ {x}).encard) := by
        intro heq
        have : X ⊂ X ∪ {x} := Set.ssubset_insert (by simp [Set.mem_diff] at hx; exact hx.2)
        exact (hX.not_prop_of_ssuperset this) heq
      unfold inessential
      have hGXx : G - (X ∪ {x}) = (G - X) - {x} := by simp [Graph.vertexDelete_vertexDelete]
      simp only [hGXx] at hXx
      have hne : ν((G - X) - {x}) ≥ ν(G - X) := by
        by_contra hlt
        push_neg at hlt
        have : ν((G - X) - {x}) = ν(G - X) - 1 := by omega
        have hXxcard : (X ∪ {x}).encard = X.encard + 1 := by
          rw [Set.encard_union_eq (by simp), Set.encard_singleton]
        rw [hmax, hXxcard] at hXx
        simp at hXx
        exact hXx this
      obtain ⟨M', hM', hM'max⟩ := Classical.choice (inferInstance : Nonempty {M // (G - X).IsMaxMatching M})
      exact ⟨M', hM', by simp [Graph.vertexDelete_vertexSet] at hx; exact hx.2⟩
    · exact inessential_of_not_mem hx
  obtain ⟨M, hM, hcomp⟩ := foo_of_forall_inessential h_iness
  have hvertex : V(G - X, M).encard = (V(G) \ X).encard - (G - X).OddComponents.encard := by
    have : ∀ H, H.IsCompOf (G - X) → ∃! x, x ∈ V(H) ∧ x ∉ V(G - X, M) := hcomp
    sorry
  have htwo : 2 * M.encard = V(G - X, M).encard := by sorry
  have hnu : M.encard = ν(G - X) := by sorry
  omega

