```lean
lemma tutte_berge_of_maximal_vertexDelete (hX : Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X) :
    2 * ν(G - X) = (V(G) \ X).encard - (G - X).OddComponents.encard := by
  have h_iness : ∀ x, (G - X).inessential x := fun x ↦ by
    by_cases hx : x ∈ V(G - X)
    · simp only [Graph.vertexDelete_vertexSet, Set.mem_diff] at hx
      have hXsub : X ⊂ insert x X := Set.ssubset_insert hx.2
      have hne := hX.not_prop_of_ssuperset hXsub
      unfold inessential
      obtain ⟨M, hMmax⟩ := Classical.choice ⟨∅, (⟨Set.empty_subset _, fun e f he ↦ he.elim⟩ : (G - X).IsMatching ∅)⟩
      refine ⟨M, ⟨hMmax.1, fun M' hM' ↦ ?_⟩, fun hxM ↦ ?_⟩
      all_goals exact hMmax.1.encard_le.trans (hM'.encard_le) |> fun _ ↦ hne (by
        simp only [Graph.vertexDelete_vertexDelete, Set.insert_eq]
        rw [Set.union_comm]
        exact hX.prop)
    · exact inessential_of_not_mem hx
  obtain ⟨M, hM, hcomp⟩ := foo_of_forall_inessential h_iness
  have := hM.isMaxMatching_of_vertex_subset fun v hv ↦ by
    by_contra hvM
    obtain ⟨H, hHcomp, hvH, huniq⟩ := by simpa using hcomp
    exact hvM hvH
  simp only [OddComponents]
  rfl
```
