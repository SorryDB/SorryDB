```lean
private lemma _root_.IsNIPWith.card_hypercubeEdgeFinset_le_of_finite [Finite α]
    (h𝓕 : IsNIPWith d (𝓕 : Set (Set α))) : #(hypercubeEdgeFinset 𝓕) ≤ d * #𝓕 := by
  classical
  rw [← sup_finiteSymmDiffFinpartition_hypercubeEdgeFinset, Finset.sup_eq_biUnion]
  calc #((finiteSymmDiffFinpartition 𝓕).parts.biUnion hypercubeEdgeFinset)
      ≤ ∑ 𝓒 ∈ (finiteSymmDiffFinpartition 𝓕).parts, #(hypercubeEdgeFinset 𝓒) :=
        Finset.card_biUnion_le
    _ ≤ ∑ 𝓒 ∈ (finiteSymmDiffFinpartition 𝓕).parts, d * #𝓒 := Finset.sum_le_sum fun 𝓒 h𝓒 => by
        have hfin := finite_iUnion_sdiff_iInter_of_mem_finiteSymmDiffFinpartition h𝓒
        haveI : Fintype ↑((⋃ A ∈ 𝓒, A) \ ⋂ A ∈ 𝓒, A) := hfin.fintype
        have h𝓒_sub : (𝓒 : Set (Set α)) ⊆ 𝓕 :=
          Finset.coe_subset.mpr ((finiteSymmDiffFinpartition 𝓕).le h𝓒)
        have h𝓒' : IsNIPWith d (𝓒 : Set (Set α)) := fun A hA => h𝓕 (hA.mono h𝓒_sub)
        have hres := h𝓒'.restrictFiniteSymmDiffComponent.card_hypercubeEdgeFinset_le_of_finite
        rw [card_restrictFiniteSymmDiffComponent] at hres
        exact le_trans (Finset.card_le_card fun AB hAB => by
          simp only [prodMk_mem_hypercubeEdgeFinset, restrictFiniteSymmDiffComponent,
            mem_image] at hAB ⊢
          obtain ⟨hA, hB, hAB'⟩ := hAB
          exact ⟨⟨_, _, hA, rfl⟩, ⟨_, _, hB, rfl⟩, by
            rw [Set.ncard_eq_one] at hAB' ⊢
            obtain ⟨a, ha⟩ := hAB'
            have hmem : a ∈ (⋃ C ∈ 𝓒, C) \ ⋂ C ∈ 𝓒, C := by
              rw [Set.ext_iff] at ha
              have := ha a
              simp only [Set.mem_symmDiff, Set.mem_singleton_iff] at this
              rw [Set.mem_diff, Set.mem_iUnion₂, Set.mem_iInter₂]; push_neg
