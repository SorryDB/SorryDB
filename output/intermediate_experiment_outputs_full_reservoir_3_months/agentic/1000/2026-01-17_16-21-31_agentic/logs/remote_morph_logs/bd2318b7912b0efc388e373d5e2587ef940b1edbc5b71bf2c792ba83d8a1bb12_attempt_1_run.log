        have hres := h𝓒'.restrictFiniteSymmDiffComponent.card_hypercubeEdgeFinset_le_of_finite
        simp only [card_restrictFiniteSymmDiffComponent] at hres
        calc #(hypercubeEdgeFinset 𝓒)
            ≤ #(hypercubeEdgeFinset (restrictFiniteSymmDiffComponent 𝓒)) := by
              refine Finset.card_le_card fun ⟨A, B⟩ hAB => ?_
              simp only [prodMk_mem_hypercubeEdgeFinset] at hAB ⊢
