    unfold coerceWord at heq
    have key : w' = w := by
      have aux : ∀ (a b : Word {x // x ∈ Z}), List.map Subtype.val a = List.map Subtype.val b → a = b := by
        intro a b hab
        induction a generalizing b with
        | nil =>
