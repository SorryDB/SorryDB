/--Theorem: coerceWord and coerceLang respect the language membership relation.-/
theorem coerceLang_mem {Z : Finset α} {w : Word Z} (l : Language Z) :
  w ∈ l ↔ coerceWord w ∈ coerceLang l := by
  unfold coerceLang coerceWord
  constructor
  · exact fun h => ⟨w, h, rfl⟩
  · intro h
    obtain ⟨w', hw', heq⟩ := h
    suffices w' = w by subst this; exact hw'
    have key : ∀ a b : Word {x // x ∈ Z}, List.map (·.val) a = List.map (·.val) b → a = b := by
      intro a b hab
      induction a generalizing b with
      | nil =>
        cases b with
        | nil => rfl
        | cons _ _ => simp at hab
      | cons x xs ih =>
        cases b with
        | nil => simp at hab
        | cons y ys =>
          simp only [List.map_cons, List.cons.injEq] at hab
          rw [Subtype.val_injective hab.1, ih ys hab.2]
    exact key w' w heq
