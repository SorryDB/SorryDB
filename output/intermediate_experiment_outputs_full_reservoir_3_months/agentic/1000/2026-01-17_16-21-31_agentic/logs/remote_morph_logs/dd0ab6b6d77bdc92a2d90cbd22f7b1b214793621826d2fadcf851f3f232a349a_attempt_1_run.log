def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    by_cases h1 : MeasurableSet w₁
    · by_cases h2 : MeasurableSet w₂
      · have hinter : w₁ ∩ w₂ = w₁ := Set.inter_eq_self_of_subset_left h
        have hmul := E.m_Inter' h1 h2
        rw [hinter] at hmul
        rw [hmul, ContinuousLinearMap.mul_apply]
        set P := E.measureOf' w₁
        set y := (E.measureOf' w₂) x
        have hp := E.isOrthogonalProjection' w₁
        have hselfadj : P = P.adjoint := hp.2
        have hidempot : P = P ^ 2 := hp.1
        by_cases hPy : P y = 0
        · simp only [hPy, norm_zero]; exact norm_nonneg _
        · have key_eq : ⟪P y, P y⟫_ℂ = ⟪P y, y⟫_ℂ := by
            calc ⟪P y, P y⟫_ℂ = ⟪P y, P.adjoint y⟫_ℂ := by rw [← hselfadj]
              _ = ⟪P (P y), y⟫_ℂ := ContinuousLinearMap.adjoint_inner_right P (P y) y
              _ = ⟪(P * P) y, y⟫_ℂ := by rfl
              _ = ⟪P y, y⟫_ℂ := by rw [← sq, ← hidempot]
          have h_sq : ‖P y‖^2 = RCLike.re ⟪P y, P y⟫_ℂ := (inner_self_eq_norm_sq (𝕜 := ℂ) (F := H)).symm
          rw [key_eq] at h_sq
          have h_cs : RCLike.re ⟪P y, y⟫_ℂ ≤ ‖P y‖ * ‖y‖ := by
            calc RCLike.re ⟪P y, y⟫_ℂ ≤ ‖⟪P y, y⟫_ℂ‖ := RCLike.re_le_norm _
              _ ≤ ‖P y‖ * ‖y‖ := norm_inner_le_norm _ _
          nlinarith [sq_nonneg ‖P y‖, norm_nonneg y, norm_nonneg (P y)]
      · rw [E.not_measurable' h2]
        simp only [ContinuousLinearMap.zero_apply, norm_zero]
        exact norm_nonneg _
    · rw [E.not_measurable' h1]
      simp only [ContinuousLinearMap.zero_apply, norm_zero]
      exact norm_nonneg _
