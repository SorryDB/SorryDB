```lean
def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    by_cases h1 : MeasurableSet w₁
    · by_cases h2 : MeasurableSet w₂
      · have hinter : w₁ ∩ w₂ = w₁ := Set.inter_eq_self_of_subset_left h
        have hmul := E.m_Inter' h1 h2
        rw [hinter] at hmul
        rw [hmul, ContinuousLinearMap.mul_apply]
        have hp := E.isOrthogonalProjection' w₁
        set P := E.measureOf' w₁
        set y := (E.measureOf' w₂) x
        have hselfadj : P = P.adjoint := hp.2
        have hidempot : P = P ^ 2 := hp.1
        suffices hs : ‖P y‖ ^ 2 ≤ ‖P y‖ * ‖y‖ by nlinarith [sq_nonneg ‖P y‖, norm_nonneg (P y), norm_nonneg y]
        calc ‖P y‖ ^ 2 = Complex.re ⟪P y, P y⟫_ℂ := by rw [inner_self_eq_norm_sq]; simp [sq]
          _ = Complex.re ⟪y, (P ^ 2) y⟫_ℂ := by rw [← ContinuousLinearMap.adjoint_inner_left, hselfadj]; simp [sq, ContinuousLinearMap.mul_apply]
          _ = Complex.re ⟪y, P y⟫_ℂ := by rw [← hidempot]
          _ ≤ Complex.abs ⟪y, P y⟫_ℂ := Complex.re_le_abs _
          _ = ‖⟪y, P y⟫_ℂ‖ := (Complex.norm_eq_abs _).symm
          _ ≤ ‖y‖ * ‖P y‖ := norm_inner_le_norm y (P y)
          _ = ‖P y‖ * ‖y‖ := mul_comm _ _
      · simp only [E.not_measurable' h2, ContinuousLinearMap.zero_apply, norm_zero]
        exact norm_nonneg _
    · simp only [E.not_measurable' h1, ContinuousLinearMap.zero_apply, norm_zero]
```
