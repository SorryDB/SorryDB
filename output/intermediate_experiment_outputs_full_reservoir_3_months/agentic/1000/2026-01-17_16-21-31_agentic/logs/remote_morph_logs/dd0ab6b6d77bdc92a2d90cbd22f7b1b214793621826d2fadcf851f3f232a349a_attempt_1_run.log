    · by_cases h2 : MeasurableSet w₂
      · have hinter : w₁ ∩ w₂ = w₁ := Set.inter_eq_self_of_subset_left h
        have hmul := E.m_Inter' h1 h2
        rw [hinter] at hmul
        rw [hmul, ContinuousLinearMap.mul_apply]
        have hp := E.isOrthogonalProjection' w₁
        set P := E.measureOf' w₁ with hP
        set y := E.measureOf' w₂ x with hy
        have hselfadj : P = P.adjoint := hp.2
        have hidempot : P = P ^ 2 := hp.1
        have h_norm_sq : ‖P y‖ ^ 2 = re ⟪P y, y⟫_ℂ := by
