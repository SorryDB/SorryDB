def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    by_cases h1 : MeasurableSet w₁
    · by_cases h2 : MeasurableSet w₂
      · have hinter : w₁ ∩ w₂ = w₁ := Set.inter_eq_self_of_subset_left h
        have hmul := E.m_Inter' h1 h2
        rw [hinter] at hmul
        rw [hmul, ContinuousLinearMap.mul_apply]
        have hp := E.isOrthogonalProjection' w₁
        calc ‖(E.measureOf' w₁) ((E.measureOf' w₂) x)‖ 
            ≤ ‖E.measureOf' w₁‖ * ‖(E.measureOf' w₂) x‖ := ContinuousLinearMap.le_opNorm _ _
          _ ≤ 1 * ‖(E.measureOf' w₂) x‖ := by
              apply mul_le_mul_of_nonneg_right _ (norm_nonneg _)
              have : E.measureOf' w₁ = (E.measureOf' w₁).adjoint := hp.2
              have hsq : E.measureOf' w₁ = E.measureOf' w₁ ^ 2 := hp.1
              sorry
          _ = ‖(E.measureOf' w₂) x‖ := one_mul _
      · rw [E.not_measurable' h2, ContinuousLinearMap.zero_apply, norm_zero]
        exact norm_nonneg _
    · rw [E.not_measurable' h1, ContinuousLinearMap.zero_apply, norm_zero]
      exact norm_nonneg _
