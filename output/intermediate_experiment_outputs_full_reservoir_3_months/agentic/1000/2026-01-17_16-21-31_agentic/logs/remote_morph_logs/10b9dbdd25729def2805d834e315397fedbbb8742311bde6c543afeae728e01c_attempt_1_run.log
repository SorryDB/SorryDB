The fix is to prove a general lemma about list elements being bounded by the sum inside a `have`, then use `Nat.add_assoc` and `Nat.add_sub_assoc` for the arithmetic.

```lean
  theorem list_set_sum {l : List Nat} {idx : Nat} {e : Nat} (hidx : idx < l.length := by simpa) :
    (l.set idx e).sum = l.sum - l[idx] + e := by
      induction idx generalizing l with
      | zero =>
        cases l with
        | nil => contradiction
        | cons hd tl => simp; apply Nat.add_comm
      | succ idx' HR =>
        cases l with
        | nil =>
          contradiction
        | cons hd tl =>
          simp at hidx ⊢
          rw [@HR tl hidx]
          have h : tl[idx'] ≤ tl.sum := by
            have h1 : ∀ (l : List Nat) (j : Nat) (hj : j < l.length), l[j] ≤ l.sum := by
              intro l j hj
              induction l generalizing j with
              | nil => contradiction
              | cons a as ih =>
                simp only [List.sum_cons]
                cases j with
                | zero => exact Nat.le_add_right _ _
                | succ j' =>
                  simp only [List.length_cons, Nat.add_lt_add_iff_right] at hj
                  simp only [List.getElem_cons_succ]
                  exact Nat.le_trans (ih j' hj) (Nat.le_add_left _ _)
            exact h1 tl idx' hidx
          rw [← Nat.add_assoc, Nat.add_sub_assoc h]
```
