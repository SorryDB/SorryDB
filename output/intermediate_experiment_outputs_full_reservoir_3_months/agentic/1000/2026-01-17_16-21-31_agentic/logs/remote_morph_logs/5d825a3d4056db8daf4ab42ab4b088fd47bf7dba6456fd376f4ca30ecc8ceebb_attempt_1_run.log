```lean
/-- Let `A` be a Noetherian ring satisfying `HeightOneLocalizationIsPID`. Then two finitely
generated torsion `A`-modules `M`, `N` are pseudo-isomorphic if and only if their localizations
at all height one primes are isomorphic. -/
theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · rintro ⟨f, hf⟩ p hp
    rw [isPseudoIsomorphism_iff, Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton,
        Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton] at hf
    have hker : Subsingleton (LocalizedModule p.1.primeCompl (LinearMap.ker f)) :=
      hf.1 p (le_of_eq hp)
    have hcoker : Subsingleton (LocalizedModule p.1.primeCompl (N ⧸ LinearMap.range f)) :=
      hf.2 p (le_of_eq hp)
    rw [← LinearMap.subsingleton_ker_convert] at hker
    rw [← LinearMap.subsingleton_coker_convert] at hcoker
    exact ⟨LinearEquiv.ofBijective _ ⟨LinearMap.ker_eq_bot.mp (Submodule.subsingleton_iff_eq_bot.mp hker),
      LinearMap.range_eq_top.mp (Submodule.Quotient.subsingleton_iff.mp hcoker)⟩⟩
  · intro h
    obtain ⟨ιM, _, pM, hpM, eM, heM, hM⟩ := hMT.isPseudoIsomorphic_pi
    obtain ⟨ιN, _, pN, hpN, eN, heN, hN⟩ := hNT.isPseudoIsomorphic_pi
    sorry
```
