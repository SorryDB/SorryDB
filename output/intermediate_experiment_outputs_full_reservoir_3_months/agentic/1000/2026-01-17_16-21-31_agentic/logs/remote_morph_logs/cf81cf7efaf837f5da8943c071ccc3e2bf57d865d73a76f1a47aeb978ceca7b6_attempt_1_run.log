n : ℕ
F : TypeVec.{u} (n + 1) → Type u
inst✝ : MvQPF F
α : TypeVec.{u} n
self : StateCofixFinal F α
a b : Coalg F α
R : (a.union b).σ → (a.union b).σ → Prop
h_bisim : Coalg.IsBisim R
h_R : R (Sum.inl a.s) (Sum.inr b.s)
R' : Cofix F α → Cofix F α → Prop :=
  fun x y =>
    ∃ s t,
      R (Sum.inl s) (Sum.inr t) ∧
        x = { σ := a.σ, dest' := a.dest', s := s }.toCofix ∧ y = { σ := b.σ, dest' := b.dest', s := t }.toCofix
s : a.σ
t : b.σ
hR : R (Sum.inl s) (Sum.inr t)
u : (P F).A
f g : (P F).B u ⟹ α ::: (a.σ ⊕ b.σ)
hf : (TypeVec.id ::: Sum.inl) <$$> a.dest' s = abs ⟨u, f⟩
hg : (TypeVec.id ::: Sum.inr) <$$> b.dest' t = abs ⟨u, g⟩
