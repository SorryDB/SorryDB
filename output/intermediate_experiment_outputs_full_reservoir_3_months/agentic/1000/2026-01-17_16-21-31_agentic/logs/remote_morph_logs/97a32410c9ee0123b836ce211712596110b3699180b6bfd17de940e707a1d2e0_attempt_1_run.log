```lean
/-- The complex measure `E_{a, x,y}` has the total variation bounded by `‖x‖ * ‖y‖`.
Rudin "Real and complex analysis" Theorem 6.19 (2), combined with the bound by
`cfc_toLinearFunctional_bound`.-/
lemma cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ₑ * ‖y‖ₑ := by
  simp only [cfc_toComplexMeasure]
  apply le_trans (ComplexRMK.rieszMeasure_variation_le_norm _)
  gcongr
  calc ‖compSL C₀(spectrum ℂ a, ℂ) C(spectrum ℂ a, ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y)
      (ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE).symm.toContinuousLinearMap‖
    ≤ ‖cfc_toLinearFunctional ha x y‖ * ‖(ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE 
        (X := spectrum ℂ a) (𝕜 := ℂ) (A := ℂ)).symm.toContinuousLinearMap‖ := 
      ContinuousLinearMap.opNorm_comp_le _ _
    _ ≤ ‖cfc_toLinearFunctional ha x y‖ * 1 := by
      gcongr
      exact ContinuousLinearEquiv.norm_toContinuousLinearMap_symm_le _
    _ ≤ ‖x‖ * ‖y‖ := by rw [mul_one]; exact cfc_toLinearFunctional_bound ha x y
```
