theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  simp only [two_mul]
  have h1 : (m + m).choose m * m ! * m ! = (m + m)! := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_right m m)
  have h2 : (n + n).choose n * n ! * n ! = (n + n)! := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_right n n)
  have h3 : (m + n).choose m * m ! * n ! = (m + n)! := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_right m n)
  rw [← h1, ← h2, ← h3]
  have hdvd : (m + n).choose m ∣ (m + m).choose m * (n + n).choose n := Nat.choose_add_dvd_choose_mul_choose m n
  obtain ⟨k, hk⟩ := hdvd
  use k
  ring_nf
  ring_nf at hk
  linarith [Nat.mul_comm ((m + n).choose m) k]
