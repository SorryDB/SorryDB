  have hb' : b = (n + n).choose n := (Nat.eq_div_of_eq_mul_right (Nat.mul_pos (Nat.factorial_pos n) (Nat.factorial_pos n)) hb).symm
  have hc' : c = (m + n).choose m := (Nat.eq_div_of_eq_mul_right hpos hc).symm
