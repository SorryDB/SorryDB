open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have h1 : m ! * m ! ∣ (2 * m)! := by simpa using Nat.factorial_mul_factorial_dvd_factorial_add m m
  have h2 : n ! * n ! ∣ (2 * n)! := by simpa using Nat.factorial_mul_factorial_dvd_factorial_add n n
  have h3 : m ! * n ! ∣ (m + n)! := Nat.factorial_mul_factorial_dvd_factorial_add m n
  obtain ⟨a, ha⟩ := h1
  obtain ⟨b, hb⟩ := h2
  obtain ⟨c, hc⟩ := h3
  rw [ha, hb, hc]
  use a * b * c
  ring
