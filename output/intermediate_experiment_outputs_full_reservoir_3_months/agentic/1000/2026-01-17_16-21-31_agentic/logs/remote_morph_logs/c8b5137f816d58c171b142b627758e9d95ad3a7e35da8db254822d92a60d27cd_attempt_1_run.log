import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have h1 : m ! * m ! ∣ (2 * m)! := by simp only [two_mul]; exact Nat.factorial_mul_factorial_dvd_factorial_add m m
  have h2 : n ! * n ! ∣ (2 * n)! := by simp only [two_mul]; exact Nat.factorial_mul_factorial_dvd_factorial_add n n
  have h3 : m ! * n ! ∣ (m + n)! := Nat.factorial_mul_factorial_dvd_factorial_add m n
  obtain ⟨a, ha⟩ := h1
  obtain ⟨b, hb⟩ := h2
  obtain ⟨c, hc⟩ := h3
  have hcpos : 0 < c := by
    by_contra h
    push_neg at h
    interval_cases c <;> simp_all [Nat.factorial_pos]
  have key : c ∣ a * b := by
    have ha' : a = (2 * m).choose m := by
      have := Nat.choose_mul_factorial_mul_factorial (by omega : m ≤ 2 * m)
      simp only [two_mul] at ha this ⊢
      omega
    have hb' : b = (2 * n).choose n := by
      have := Nat.choose_mul_factorial_mul_factorial (by omega : n ≤ 2 * n)
      simp only [two_mul] at hb this ⊢
      omega
    have hc' : c = (m + n).choose m := by
      have := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_right m n)
      omega
    rw [ha', hb', hc']
    have := Nat.choose_mul_choose_dvd_centralBinom_mul_centralBinom m n
    simp only [Nat.centralBinom, two_mul] at this
    exact this
  obtain ⟨k, hk⟩ := key
  use k
  rw [ha, hb, hc, hk]
  ring
