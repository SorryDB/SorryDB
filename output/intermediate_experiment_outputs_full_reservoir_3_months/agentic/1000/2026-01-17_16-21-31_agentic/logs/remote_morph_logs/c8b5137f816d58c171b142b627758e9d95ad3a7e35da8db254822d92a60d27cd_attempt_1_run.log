import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have h1 := Nat.factorial_mul_factorial_dvd_factorial_add m m
  have h2 := Nat.factorial_mul_factorial_dvd_factorial_add n n
  have h3 := Nat.factorial_mul_factorial_dvd_factorial_add m n
  simp only [two_mul]
  obtain ⟨a, ha⟩ := h1
  obtain ⟨b, hb⟩ := h2
  obtain ⟨c, hc⟩ := h3
  rw [ha, hb, hc]
  suffices h : c ∣ a * b by
    obtain ⟨k, hk⟩ := h
    use k
    ring_nf
    ring_nf at hk
    linarith [Nat.factorial_pos m, Nat.factorial_pos n, 
              Nat.mul_pos (Nat.factorial_pos m) (Nat.factorial_pos m),
              Nat.mul_pos (Nat.factorial_pos n) (Nat.factorial_pos n)]
  have ha' : a = (m + m).choose m := by
    have := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_left m m)
    rw [Nat.add_sub_cancel_left] at this
    have hpos : 0 < m ! * m ! := Nat.mul_pos (Nat.factorial_pos m) (Nat.factorial_pos m)
    omega
  have hb' : b = (n + n).choose n := by
    have := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_left n n)
    rw [Nat.add_sub_cancel_left] at this
    have hpos : 0 < n ! * n ! := Nat.mul_pos (Nat.factorial_pos n) (Nat.factorial_pos n)
    omega
  have hc' : c = (m + n).choose m := by
    have := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_right m n)
    rw [Nat.add_sub_cancel_left] at this
    have hpos : 0 < m ! * n ! := Nat.mul_pos (Nat.factorial_pos m) (Nat.factorial_pos n)
    omega
  rw [ha', hb', hc']
  exact Nat.choose_mul_central_binom_dvd m n
