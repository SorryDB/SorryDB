theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  have h1 : m ! * m ! ∣ (2 * m)! := by
    simp only [two_mul]; exact Nat.factorial_mul_factorial_dvd_factorial_add m m
  have h2 : n ! * n ! ∣ (2 * n)! := by
    simp only [two_mul]; exact Nat.factorial_mul_factorial_dvd_factorial_add n n
  have h3 : m ! * n ! ∣ (m + n)! := Nat.factorial_mul_factorial_dvd_factorial_add m n
  obtain ⟨a, ha⟩ := h1
  obtain ⟨b, hb⟩ := h2
  obtain ⟨c, hc⟩ := h3
  have key : c ∣ a * b := by
    simp only [two_mul] at ha hb
    have ha' : a = (m + m).choose m := Nat.eq_div_of_eq_mul_left
      (Nat.mul_pos (Nat.factorial_pos m) (Nat.factorial_pos m))
      (by rw [mul_comm, Nat.add_choose_mul_factorial_mul_factorial]; exact ha.symm)
    have hb' : b = (n + n).choose n := Nat.eq_div_of_eq_mul_left
      (Nat.mul_pos (Nat.factorial_pos n) (Nat.factorial_pos n))
      (by rw [mul_comm, Nat.add_choose_mul_factorial_mul_factorial]; exact hb.symm)
    have hc' : c = (m + n).choose m := Nat.eq_div_of_eq_mul_left
      (Nat.mul_pos (Nat.factorial_pos m) (Nat.factorial_pos n))
      (by rw [mul_comm, Nat.add_choose_mul_factorial_mul_factorial]; exact hc.symm)
    rw [ha', hb', hc']
    exact Nat.choose_mul_add m m n n
  obtain ⟨k, hk⟩ := key
  use k
  calc (2 * m)! * (2 * n)! = (m ! * m ! * a) * (n ! * n ! * b) := by rw [ha, hb]
    _ = m ! * m ! * n ! * n ! * (a * b) := by ring
    _ = m ! * m ! * n ! * n ! * (c * k) := by rw [hk]
    _ = m ! * n ! * (m ! * n ! * c) * k := by ring
    _ = m ! * n ! * (m + n)! * k := by rw [← hc]
