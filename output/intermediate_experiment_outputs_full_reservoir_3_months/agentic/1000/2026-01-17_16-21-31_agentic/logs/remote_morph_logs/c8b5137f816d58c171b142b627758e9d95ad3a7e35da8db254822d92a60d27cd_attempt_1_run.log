import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  rw [show 2 * m = m + m by ring, show 2 * n = n + n by ring]
  have h1 := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_right m m)
  have h2 := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_right n n)
  have h3 := Nat.choose_mul_factorial_mul_factorial (Nat.le_add_right m n)
  simp only [Nat.add_sub_cancel_left] at h1 h2 h3
  rw [← h1, ← h2, ← h3]
  have hdvd : (m + n).choose m ∣ (m + m).choose m * (n + n).choose n :=
    Nat.choose_add_le_choose_mul m n
  obtain ⟨k, hk⟩ := hdvd
  use k
  ring_nf
  ring_nf at hk
  linarith [Nat.factorial_pos m, Nat.factorial_pos n, hk]
