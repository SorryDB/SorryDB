/-- Every D-smooth map from a boundaryless manifold to another manifold is also smooth.
This could probably be proven in quite a lot greater generality. -/
theorem IsOpen.dsmooth_iff_smoothOn {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E]
    [FiniteDimensional ℝ E] {H : Type*} [TopologicalSpace H] {I : ModelWithCorners ℝ E H}
    (M : Type*) [TopologicalSpace M] [ChartedSpace H M] [m : IsManifold I ∞ M]
    [hI : I.Boundaryless]
    {E' : Type*} [NormedAddCommGroup E'] [NormedSpace ℝ E'] [FiniteDimensional ℝ E']
    {H' : Type*} [TopologicalSpace H'] {I' : ModelWithCorners ℝ E' H'} (N : Type*)
    [TopologicalSpace N] [ChartedSpace H' N] [m' : IsManifold I' ∞ N]
    {f : M → N} {s : Set M} (hs : IsOpen s) : let _ := m.toDiffeology;
    let _ := m'.toDiffeology; DSmooth (s.restrict f) ↔ ContMDiffOn I I' ∞ f s := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine ⟨fun hf x hxs ↦ ?_,ContMDiffOn.dsmooth_restrict⟩
  rw [hs.contMDiffWithinAt_iff hxs]
  let n := Module.finrank ℝ E
  let e : EuclideanSpace ℝ (Fin n) ≃L[ℝ] E :=
    (EuclideanSpace.equiv (Fin n) ℝ).symm.toContinuousLinearEquiv
  let c := I (chartAt H x x)
  let ψ : Eucl n → M := fun y ↦ (chartAt H x).symm (I.symm (e y + c))
  have hψ0 : ψ 0 = x := by simp [ψ, c]
  have hψ_cont : Continuous ψ := (chartAt H x).continuousOn_symm.comp_continuous
    (I.continuous_symm.comp (e.continuous.add continuous_const))
    (fun y ↦ hI.range_eq_univ ▸ mem_univ _)
  have hs_preimage : ψ ⁻¹' s ∈ 𝓝 (0 : Eucl n) := by
    apply hψ_cont.continuousAt.preimage_mem_nhds; rw [hψ0]; exact hs.mem_nhds hxs
  obtain ⟨ε, hε, hball⟩ := Metric.mem_nhds_iff.mp hs_preimage
  let φ : Eucl n → s := fun y ↦ if h : y ∈ Metric.ball 0 ε then ⟨ψ y, hball h⟩ else ⟨x, hxs⟩
  have hψ_smooth : ContMDiff (𝓡 n) I ∞ ψ := by
    have h1 : ContMDiff (𝓡 n) (𝓡 n) ∞ (fun y ↦ e y + c) := e.contMDiff.add contMDiff_const
    have h2 : ContMDiff (𝓡 n) I ∞ (I.symm ∘ (fun y ↦ e y + c)) :=
      I.contMDiff_symm.comp h1 (fun _ ↦ hI.range_eq_univ ▸ mem_univ _)
    exact (contMDiff_chart_symm (x := x)).comp h2 (fun y ↦ hI.range_eq_univ ▸ mem_univ _)
  have hφ_plot : IsPlot (Subtype.val ∘ φ) := by
    rw [isPlot_iff_contMDiff]
    refine contMDiffOn_of_locally_contMDiffOn fun y _ ↦ ?_
    by_cases hy : y ∈ Metric.ball 0 ε
    · refine ⟨Metric.ball 0 ε, Metric.isOpen_ball, hy, ?_⟩
      refine hψ_smooth.contMDiffOn.congr fun z hz ↦ ?_
      simp only [Function.comp_apply, φ, dif_pos hz]
    · refine ⟨(Metric.ball 0 ε)ᶜ, Metric.isOpen_ball.isClosed_compl.isOpen, hy, ?_⟩
      refine contMDiff_const.contMDiffOn.congr fun z hz ↦ ?_
      simp only [Function.comp_apply, φ, dif_neg hz]
  have h0_mem : (0 : Eucl n) ∈ Metric.ball (0 : Eucl n) ε := Metric.mem_ball_self hε
  have hfφ := (isPlot_iff_contMDiff I' N).mp (hf n φ (isPlot_induced_iff.mpr hφ_plot))
  have key : (s.restrict f ∘ φ) 0 = f x := by
    show f (φ 0).val = f x
    congr 1
    simp only [φ, dif_pos h0_mem, hψ0]
  exact key ▸ hfφ.contMDiffAt
