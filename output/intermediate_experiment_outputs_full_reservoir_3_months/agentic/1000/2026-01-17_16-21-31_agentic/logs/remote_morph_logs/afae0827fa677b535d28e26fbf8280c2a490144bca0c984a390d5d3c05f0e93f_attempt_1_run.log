lemma integral_eval_pi {i : Fin d} {μ : Fin d → Measure ℝ} [∀ i, IsProbabilityMeasure (μ i)]
    {f : ℝ → ℝ} (hf : Integrable f (μ i)) :
    ∫ (a : Fin d → ℝ), f (a i) ∂Measure.pi μ = ∫ x, f x ∂μ i := by
  have h1 : Measurable (fun a : Fin d → ℝ => a i) := measurable_pi_apply i
  have h2 : (Measure.pi μ).map (fun a => a i) = μ i := by
    ext s hs
    rw [Measure.map_apply h1 hs]
    have hpre : (fun a : Fin d → ℝ => a i) ⁻¹' s =
        Set.pi Set.univ (fun j => if j = i then s else Set.univ) := by
      ext a; simp only [Set.mem_preimage, Set.mem_pi, Set.mem_univ, true_implies]
      constructor
