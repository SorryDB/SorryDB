lemma abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p),
    edgeCount p e = p.length := by
  simp only [edgeSet, edgeCount, edges]
  have h_darts_len : p.darts.length = p.length := by
    induction p with
    | nil => rfl
    | cons _ q ih => simp only [darts, length, List.length_cons]; omega
    | loop q ih => simp only [darts, length, List.length_cons]; omega
  conv_rhs => rw [← h_darts_len, ← List.length_map (f := dartEdge)]
  rw [Finset.sum_attach]
  generalize (List.map dartEdge p.darts) = l
  induction l with
  | nil => simp
  | cons x xs ih =>
    simp only [List.toFinset_cons, List.length_cons]
    by_cases hx : x ∈ xs.toFinset
    · rw [Finset.insert_eq_of_mem hx]
      have : ∑ a ∈ xs.toFinset, List.countP (· = a) (x :: xs) = 
             ∑ a ∈ xs.toFinset, (List.countP (· = a) xs + if x = a then 1 else 0) := by
        apply Finset.sum_congr rfl; intros a _; simp [List.countP_cons]
      rw [this, Finset.sum_add_distrib, ih, Finset.sum_ite_eq', if_pos hx]
    · rw [Finset.sum_insert hx, List.countP_cons_of_pos _ (by rfl)]
      have hcount : List.countP (· = x) xs = 0 := by
        rw [List.countP_eq_zero]; intro a ha heq; exact hx (heq ▸ List.mem_toFinset.mpr ha)
      have : ∑ a ∈ xs.toFinset, List.countP (· = a) (x :: xs) = 
             ∑ a ∈ xs.toFinset, List.countP (· = a) xs := by
        apply Finset.sum_congr rfl; intros a ha
        rw [List.countP_cons_of_neg]; simp only [List.mem_toFinset] at hx ha
        intro heq; exact hx (heq ▸ ha)
      rw [this, ih, hcount]; ring
