lemma abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p),
    edgeCount p e = p.length := by
  unfold edgeSet edgeCount edges
  have h_len : (p.darts.map dartEdge).length = p.length := by
    induction p with
    | nil => rfl
    | cons _ q ih => simp only [darts, List.map_cons, List.length_cons, length, ih]
    | loop q ih => simp only [darts, List.map_cons, List.length_cons, length, ih]
  rw [← h_len]
  set l := p.darts.map dartEdge
  have h_countP_count : ∀ e, l.countP (· = e) = l.count e := fun e => by
    rw [List.countP_eq_length_filter, List.count_eq_length_filter]
    congr 1; ext x; simp only [decide_eq_true_eq, beq_iff_eq]
  simp only [h_countP_count]
  have : ∑ x : { x // x ∈ l.toFinset }, l.count ↑x = ∑ x in l.toFinset, l.count x :=
    Finset.sum_subtype l.toFinset (fun _ => l.toFinset.mem_coe) (fun x => l.count x)
  rw [this]
  rw [← Multiset.coe_toFinset l, Multiset.toFinset_sum_count_eq (↑l), Multiset.length_coe]
