```lean
lemma abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p),
    edgeCount p e = p.length := by
  simp only [edgeSet, edgeCount, edges]
  have h_len : p.darts.length = p.length := by
    induction p with
    | nil => rfl
    | cons _ q ih => simp only [darts, length, List.length_cons]; omega
    | loop q ih => simp only [darts, length, List.length_cons]; omega
  rw [← h_len, ← List.length_map (f := dartEdge)]
  set l := List.map dartEdge p.darts
  have key : ∀ e, List.countP (fun x => decide (x = e)) l = l.count e := fun e => by
    unfold List.count; congr 1; funext x; simp only [beq_iff_eq, decide_eq_decide]
  simp_rw [key, Finset.sum_coe_sort]
  exact List.toFinset_sum_count_eq_length l
```
