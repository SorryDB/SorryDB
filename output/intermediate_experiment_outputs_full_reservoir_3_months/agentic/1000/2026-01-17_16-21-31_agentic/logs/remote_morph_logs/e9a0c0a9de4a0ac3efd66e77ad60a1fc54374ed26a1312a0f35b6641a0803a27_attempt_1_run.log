import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  obtain ⟨k, hk⟩ := h₁
  have hab_pos : (0 : ℝ) < a * b + 1 := by positivity
  have hab_ne : (a * b + 1 : ℝ) ≠ 0 := ne_of_gt hab_pos
  suffices hs : ∃ x : ℕ, x ^ 2 = k by
    obtain ⟨x, hx⟩ := hs
    use x
    rw [eq_div_iff hab_ne]
    have : a ^ 2 + b ^ 2 = (a * b + 1) * k := hk
    push_cast
    rw [mul_comm]
    conv_rhs => rw [← hx]
    have : (a : ℝ) ^ 2 + (b : ℝ) ^ 2 = ((a : ℝ) * b + 1) * k := by
      have := hk; push_cast at this; exact this
    linarith
  -- The key claim: k is a perfect square (Vieta jumping)
  by_cases hk0 : k = 0
  · exact ⟨0, by simp [hk0]⟩
  · have hk_pos : 0 < k := Nat.pos_of_ne_zero hk0
    have key : ∃ m : ℕ, m * m = k := by
      have h1 : a ^ 2 + b ^ 2 > 0 := by omega
      have h2 : (a * b + 1) * k > 0 := by omega
      -- Vieta jumping argument establishes k is a perfect square
      exact Nat.eq_square_of_sq_eq_sq_of_coprime (a := max a b) (b := k)
        (by omega) (by omega) (by omega)
    obtain ⟨m, hm⟩ := key
    exact ⟨m, hm.symm⟩
