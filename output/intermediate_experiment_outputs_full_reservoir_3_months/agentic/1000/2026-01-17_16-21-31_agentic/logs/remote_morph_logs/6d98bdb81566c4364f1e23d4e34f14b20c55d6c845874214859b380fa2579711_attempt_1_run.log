lemma IsMatching.symmDiff_maxDegree_le_two (hM : G.IsMatching M) (hM' : G.IsMatching M') :
    (hM.restrict₂ hM').MaxDegreeLE 2 := by
  haveI : (hM.restrict₂ hM').Loopless := loopRemove.loopless
  rw [maxDegreeLE_iff']
  intro v _
  simp only [restrict₂, eDegree_eq_encard_inc]
  have hsub : E((G ↾ M ∆ M').loopRemove, v) ⊆ (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) := by
    intro e he
    obtain ⟨_, w, hMM', hw⟩ := he
    have heGv : e ∈ E(G, v) := ⟨w, hMM'.2, hw⟩
    rcases hMM'.1 with ⟨heM, _⟩ | ⟨heM', _⟩
    · left; exact ⟨heM, heGv⟩
    · right; exact ⟨heM', heGv⟩
  calc E((G ↾ M ∆ M').loopRemove, v).encard
      ≤ ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := encard_le_encard hsub
    _ ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := encard_union_le _ _
    _ ≤ 1 + 1 := add_le_add (hM.degree_le_one v) (hM'.degree_le_one v)
    _ = 2 := by norm_num
```
