```lean
lemma IsMatching.symmDiff_maxDegree_le_two (hM : G.IsMatching M) (hM' : G.IsMatching M') :
    (hM.restrict₂ hM').MaxDegreeLE 2 := by
  rw [maxDegreeLE_iff']
  intro v _
  rw [eDegree_eq_encard_inc]
  have hsub : E(hM.restrict₂ hM', v) ⊆ (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) := fun e he ↦ by
    have heMM' : e ∈ M ∆ M' := by simp only [restrict₂] at he; exact he.1.1
    have hev : e ∈ E(G, v) := by simp only [restrict₂] at he; exact ⟨v, he.1.2.2⟩
    exact (symmDiff_subset_union heMM').imp (fun h => ⟨h, hev⟩) (fun h => ⟨h, hev⟩)
  calc E(hM.restrict₂ hM', v).encard
      ≤ ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard := encard_le_encard hsub
    _ ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := encard_union_le _ _
    _ ≤ 1 + 1 := add_le_add (hM.degree_le_one v) (hM'.degree_le_one v)
    _ = 2 := by norm_num
```
