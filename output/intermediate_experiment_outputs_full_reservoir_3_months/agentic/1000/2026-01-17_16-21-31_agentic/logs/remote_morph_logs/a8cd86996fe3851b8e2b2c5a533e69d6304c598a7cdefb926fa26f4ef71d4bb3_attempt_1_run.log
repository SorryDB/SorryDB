lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg_mem, hg_δ⟩ := komlos_convex (φ := fun x ↦ ‖x‖^2)
    (fun _ ↦ sq_nonneg _) ⟨M^2, fun n ↦ sq_le_sq' (by linarith [norm_nonneg (f n)]) (hM n)⟩
  have hg_cauchy : CauchySeq g := by
    rw [Metric.cauchySeq_iff]
    intro ε εpos
    obtain ⟨N, hN⟩ := hg_δ (ε^2 / 4) (by positivity)
    refine ⟨N, fun n hn m hm ↦ ?_⟩
    have key := hN n m hn hm
    have para := @norm_add_sq_add_norm_sub_sq_eq_two_mul_norm_sq_add_norm_sq ℝ E _ _ (g n) (g m)
    have h1 : ‖g n - g m‖^2 = 2 * ‖g n‖^2 + 2 * ‖g m‖^2 - ‖g n + g m‖^2 := by linarith
    have h2 : ‖g n + g m‖^2 = 4 * ‖(2 : ℝ)⁻¹ • (g n + g m)‖^2 := by
      rw [norm_smul, Real.norm_eq_abs, abs_of_pos (by norm_num : (0:ℝ) < 2⁻¹)]
      ring
    have h3 : (2 : ℝ≥0)⁻¹ • (g n + g m) = (2 : ℝ)⁻¹ • (g n + g m) := by simp
    rw [h3] at key
    calc ‖g n - g m‖^2 = 2 * ‖g n‖^2 + 2 * ‖g m‖^2 - ‖g n + g m‖^2 := h1
      _ = 2 * ‖g n‖^2 + 2 * ‖g m‖^2 - 4 * ‖(2 : ℝ)⁻¹ • (g n + g m)‖^2 := by rw [h2]
      _ = 4 * (2⁻¹ * ‖g n‖^2 + 2⁻¹ * ‖g m‖^2 - ‖(2 : ℝ)⁻¹ • (g n + g m)‖^2) := by ring
      _ < 4 * (ε^2 / 4) := by nlinarith
      _ = ε^2 := by ring
    all_goals exact sq_lt_sq' (by linarith) (this) |>.trans_le (le_abs_self _) |>.trans_lt εpos
  obtain ⟨x, hx⟩ := hg_cauchy.exists_tendsto_of_isComplete (s := Set.univ)
    isComplete_univ (Filter.eventually_of_forall (fun _ ↦ Set.mem_univ _))
  exact ⟨g, x, fun n ↦ convexHull_mono (fun _ ⟨m, hm⟩ ↦ ⟨m, hm⟩) (convexHull_subset_convexHull_of_subset (by simp) (hg_mem n)), hx⟩
```
