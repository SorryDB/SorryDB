    obtain ⟨N, hN⟩ := hg_δ (ε^2 / 4) (by positivity)
    refine ⟨N, fun n hn ↦ ?_⟩
    have key := hN N n le_rfl hn
    have para := @norm_add_sq_add_norm_sub_sq_eq_two_mul_norm_sq_add_norm_sq ℝ E _ _ (g N) (g n)
    have h1 : ‖g N - g n‖^2 = 2 * ‖g N‖^2 + 2 * ‖g n‖^2 - ‖g N + g n‖^2 := by linarith
    have h2 : ‖g N + g n‖^2 = 4 * ‖(2 : ℝ)⁻¹ • (g N + g n)‖^2 := by
      rw [norm_smul, Real.norm_eq_abs, abs_of_pos (by norm_num : (0:ℝ) < 2⁻¹)]; ring
    have h3 : (2 : ℝ≥0)⁻¹ • (g N + g n) = (2 : ℝ)⁻¹ • (g N + g n) := by simp
    rw [h3] at key
    have hlt : ‖g N - g n‖^2 < ε^2 := by
      calc ‖g N - g n‖^2 = 2 * ‖g N‖^2 + 2 * ‖g n‖^2 - ‖g N + g n‖^2 := h1
        _ = 2 * ‖g N‖^2 + 2 * ‖g n‖^2 - 4 * ‖(2 : ℝ)⁻¹ • (g N + g n)‖^2 := by rw [h2]
        _ = 4 * (2⁻¹ * ‖g N‖^2 + 2⁻¹ * ‖g n‖^2 - ‖(2 : ℝ)⁻¹ • (g N + g n)‖^2) := by ring
        _ < 4 * (ε^2 / 4) := by nlinarith
        _ = ε^2 := by ring
    exact sq_lt_sq' (by linarith [norm_nonneg (g N - g n)]) hlt |>.trans_le (le_abs_self _) |>.trans_lt εpos
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete hg_cauchy
  exact ⟨g, x, hg_mem', hx⟩
