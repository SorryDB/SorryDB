        _ = ε^2 := by ring
    exact sq_lt_sq' (by linarith) hlt |>.trans_le (le_abs_self _) |>.trans_lt εpos
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete hg_cauchy
  exact ⟨g, x, hg_mem', hx⟩
