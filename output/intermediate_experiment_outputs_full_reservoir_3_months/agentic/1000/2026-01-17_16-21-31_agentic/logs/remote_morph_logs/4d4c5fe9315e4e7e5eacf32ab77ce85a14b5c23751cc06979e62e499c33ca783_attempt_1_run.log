```lean
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  rcases Nat.lt_or_ge N 5 with hN | hN
  · use 4
    refine ⟨by omega, 17, by norm_num, by norm_num, ?_⟩
    norm_num
    have h : Real.sqrt 8 < 3 := by
      have h1 : (8 : ℝ) < 9 := by norm_num
      have h2 : Real.sqrt 9 = 3 := by
        have : (3 : ℝ) ^ 2 = 9 := by norm_num
        exact Real.sqrt_eq_iff_sq_eq.mpr ⟨this, by norm_num, by norm_num⟩
      calc Real.sqrt 8 < Real.sqrt 9 := Real.sqrt_lt_sqrt (by norm_num) h1
        _ = 3 := h2
    linarith
  · use N
    refine ⟨le_refl N, ?_⟩
    have hN' : N ≥ 5 := hN
    have key : ∃ p, Nat.Prime p ∧ p ∣ N ^ 2 + 1 ∧ (p : ℝ) > 2 * N + Real.sqrt (2 * N) := by
      have hpos : 0 < N ^ 2 + 1 := by omega
      have hgt1 : 1 < N ^ 2 + 1 := by omega
      obtain ⟨p, hp, hdvd⟩ := Nat.exists_prime_and_dvd (Nat.one_lt_iff_ne_one.mp hgt1)
      use p, hp, hdvd
      have hple : p ≤ N ^ 2 + 1 := Nat.le_of_dvd hpos hdvd
      have hpge : (p : ℝ) ≥ 2 := by exact_mod_cast hp.two_le
      by_contra hcontra
      push_neg at hcontra
      have bound : (N : ℝ) ^ 2 + 1 ≤ (2 * N + Real.sqrt (2 * N)) ^ 2 := by
        calc (N : ℝ) ^ 2 + 1 ≤ p := by exact_mod_cast Nat.le_of_dvd hpos hdvd
          _ ≤ 2 * N + Real.sqrt (2 * N) := hcontra
          _ ≤ (2 * N + Real.sqrt (2 * N)) ^ 2 := by
            have h1 : 2 * (N : ℝ) + Real.sqrt (2 * N) ≥ 1 := by
              have : (N : ℝ) ≥ 5 := by exact_mod_cast hN'
              have hsqrt : Real.sqrt (2 * N) ≥ 0 := Real.sqrt_nonneg _
              linarith
            nlinarith [Real.sqrt_nonneg (2 * (N : ℝ))]
      have expand : (2 * (N : ℝ) + Real.sqrt (2 * N)) ^ 2 = 
                    4 * N ^ 2 + 4 * N * Real.sqrt (2 * N) + 2 * N := by ring
      have hN5 : (N : ℝ) ≥ 5 := by exact_mod_cast hN'
      have hsqrt_bound : Real.sqrt (2 * (N : ℝ)) ≤ N := by
        rw [Real.sqrt_le_left]
        right
        constructor
        · linarith
        · have : 2 * (N : ℝ) ≤ N ^ 2 := by nlinarith
          exact this
      nlinarith [Real.sqrt_nonneg (2 * (N : ℝ)), Real.sq_sqrt (by linarith : 2 * (N : ℝ) ≥ 0)]
    exact key
