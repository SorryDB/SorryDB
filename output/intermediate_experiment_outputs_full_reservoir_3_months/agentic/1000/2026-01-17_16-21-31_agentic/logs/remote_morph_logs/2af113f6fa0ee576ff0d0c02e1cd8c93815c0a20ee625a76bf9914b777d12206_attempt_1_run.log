theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  intro y
  by_contra hy
  push_neg at hy h₁
  obtain ⟨x₀, hx₀⟩ := h₁
  have key : ∀ x, |f x| * |g y| ≤ 1 := fun x => by
    have eq := h₀ x y
    have h3 : |f (x + y) + f (x - y)| ≤ 2 :=
      (abs_add _ _).trans (add_le_add (h₂ _) (h₂ _))
    have h4 : |2 * f x * g y| ≤ 2 := by rw [← eq]; exact h3
    have h5 : 2 * (|f x| * |g y|) ≤ 2 := by
      calc 2 * (|f x| * |g y|) = |2| * |f x| * |g y| := by norm_num
        _ = |2 * f x * g y| := by rw [abs_mul, abs_mul]
        _ ≤ 2 := h4
    linarith
  have hgy_pos : 0 < |g y| := by linarith
  have bound : ∀ x, |f x| ≤ 1 / |g y| := fun x => by
    have := key x
    exact (le_div_iff hgy_pos).mpr (by linarith [mul_comm (|f x|) (|g y)|])
  have strict : 1 / |g y| < 1 := by rw [div_lt_one hgy_pos]; exact hy
  have hfx₀ : |f x₀| ≤ 1 / |g y| := bound x₀
  have hfx₀_lt : |f x₀| < 1 := lt_of_le_of_lt hfx₀ strict
  have h_g0 : g 0 = 1 := by
    have := h₀ x₀ 0
    simp at this
    have hfx₀_ne : f x₀ ≠ 0 := hx₀
    linarith [mul_comm (f x₀) (g 0), mul_one (f x₀), this, hfx₀_ne]
  have h_bound_1 : |f x₀| * |g 0| ≤ 1 := key x₀
  rw [h_g0, abs_one, mul_one] at h_bound_1
  have h_all_small : ∀ x, |f x| < 1 := fun x => lt_of_le_of_lt (bound x) strict
  have h_gy_bound : |g y| ≤ 1 / |f x₀| := by
    have := key x₀
    have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀
    exact (le_div_iff hfx₀_pos).mpr (by ring_nf; exact this)
  have h_inv : 1 / |f x₀| ≥ 1 := by
    rw [ge_iff_le, one_le_div (abs_pos.mpr hx₀)]
    exact h₂ x₀
  have h_gy_ge : |g y| > 1 := hy
  have h_fx₀_le : |f x₀| ≤ 1 / |g y| := bound x₀
  have h_gy_le : |g y| ≤ 1 / |f x₀| := h_gy_bound
  have hfx₀_pos : 0 < |f x₀| := abs_pos.mpr hx₀
  have h1 : |f x₀| * |g y| ≤ 1 := key x₀
  have h2 : |g y| * |f x₀| ≤ 1 := by ring_nf; exact h1
  have h3 : |g y| ≤ 1 / |f x₀| := (le_div_iff hfx₀_pos).mpr h2
  have h4 : |f x₀| ≥ 1 / |g y| := by
    rw [ge_iff_le, le_div_iff hgy_pos]
    ring_nf
    exact h1
  have h5 : |f x₀| ≤ 1 / |g y| := bound x₀
  have h6 : |f x₀| = 1 / |g y| := le_antisymm h5 h4
  have h7 : |g y| = 1 / |f x₀| := by field_simp at h6 ⊢; linarith
