import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
$f$ and $g$ are real-valued functions defined on the real line. For all $x$ and $y, f(x+y)+f(x-y)=2f(x)g(y)$. $f$ is not identically zero and $|f(x)|\le1$ for all $x$. Prove that $|g(x)|\le1$ for all $x$. -/
@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  by_contra hg
  push_neg at hg h₁
  obtain ⟨y, hy⟩ := hg
  apply h₁
  intro x
  have key : ∀ x, |f x| * |g y| ≤ 1 := fun x => by
    have eq := h₀ x y
    have h3 : |f (x + y) + f (x - y)| ≤ 2 :=
      (abs_add _ _).trans (add_le_add (h₂ _) (h₂ _))
    have h4 : |2 * f x * g y| ≤ 2 := by rw [← eq]; exact h3
    have h5 : 2 * (|f x| * |g y|) ≤ 2 := by
      calc 2 * (|f x| * |g y|) = |2| * |f x| * |g y| := by norm_num
        _ = |2 * f x * g y| := by rw [abs_mul, abs_mul]
        _ ≤ 2 := h4
    linarith
  have hgy_pos : |g y| > 0 := by linarith
  have bound : ∀ x, |f x| ≤ 1 / |g y| := fun x => by
    have := key x
    have : |f x| * |g y| ≤ 1 := this
    exact (div_le_one hgy_pos).mpr this |>.trans' (le_div_self' (abs_nonneg _) hgy_pos.le)
  have strict : 1 / |g y| < 1 := by
    rw [div_lt_one hgy_pos]
    exact hy
  have : ∀ x, |f x| < 1 := fun x => (bound x).trans_lt strict
  by_contra hx
  push_neg at hx
  obtain ⟨x₀, hx₀⟩ := hx
  have h_abs_pos : |f x₀| > 0 := abs_pos.mpr hx₀
  have := key x₀
  have hf_bound := bound x₀
  have : |g y| ≤ 1 / |f x₀| := by
    have := key x₀
    exact (le_div_iff h_abs_pos).mpr (by ring_nf; exact this)
  have : 1 / |f x₀| ≥ 1 := by
    rw [ge_iff_le, one_le_div h_abs_pos]
    exact h₂ x₀
  linarith
