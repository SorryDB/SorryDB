  refine ae_of_ae_trim hZ.comap_le ?_
  filter_upwards with a
  rw [Set.preimage_preimage, Set.preimage_preimage]
  have : (fun ω => (Y ω, Z ω)) ⁻¹' t = Y ⁻¹' {y | (y, Z a) ∈ t} ∩ Z ⁻¹' {Z a} ∪
         (fun ω => (Y ω, Z ω)) ⁻¹' t ∩ Z ⁻¹' {Z a}ᶜ := by
    ext x; simp only [Set.mem_inter_iff, Set.mem_preimage, Set.mem_singleton_iff,
      Set.mem_union, Set.mem_compl_iff]
    constructor
    · intro hx; by_cases hZx : Z x = Z a <;> simp [hx, hZx]
    · intro hx; rcases hx with ⟨hy, hz⟩ | ⟨hx, _⟩ <;> [rw [hz]; exact hx]; exact hy
