The key insight is that `ctble_iff_set_nat_equinum` characterizes countable types as those equinumerous to a subset of `Nat`. Since `A` embeds into `U` via `Subtype.val`, and `U` is equinumerous to some `I ⊆ Nat`, we can compose to get an injection from `A` to `Nat`, whose image gives us the desired subset.

```lean
theorem ctble_set_of_ctble_type {U : Type}
    (h : ctble U) (A : Set U) : ctble A := by
  rw [ctble_iff_set_nat_equinum] at h ⊢
  obtain ⟨I, ⟨f, hf_oo, hf_onto⟩⟩ := h
  use {n : Nat | ∃ a : A, (f a.val).val = n}
  use fun a => ⟨(f a.val).val, ⟨a, rfl⟩⟩
  constructor
  · intro a1 a2 heq
    have h1 : (f a1.val).val = (f a2.val).val := congrArg Subtype.val heq
    have h2 : f a1.val = f a2.val := Subtype.ext h1
    have h3 : a1.val = a2.val := hf_oo h2
    exact Subtype.ext h3
  · intro ⟨n, a, ha⟩
    use a
    exact Subtype.ext ha
```
