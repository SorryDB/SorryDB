    _ ≤ ‖x‖ₑ * ‖y‖ₑ * ENNReal.ofReal C := by
        apply ENNReal.mul_le_mul_right' hvar
    _ = ‖x‖ * ‖y‖ * C := by
        simp only [ENNReal.toReal_mul, ENNReal.toReal_ofReal (norm_nonneg x), 
                   ENNReal.toReal_ofReal (norm_nonneg y), ENNReal.toReal_ofReal hC]
