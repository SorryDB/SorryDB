import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1979_p1 (p q : ℕ) (h₀ : 0 < q)
  (h₁ : (∑ k ∈ Finset.Icc (1 : ℕ) 1319, (-1) ^ (k + 1) * ((1 : ℝ) / k)) = p / q) : 1979 ∣ p := by
  have hprime : Nat.Prime 1979 := by native_decide
  let S : ℚ := ∑ k ∈ Finset.Icc (1 : ℕ) 1319, (-1 : ℚ) ^ (k + 1) / k
  have hS_eq : (S : ℝ) = ∑ k ∈ Finset.Icc (1 : ℕ) 1319, (-1 : ℝ) ^ (k + 1) * (1 / k) := by
    simp_rw [div_eq_mul_inv, ← one_div, Rat.cast_sum, Rat.cast_mul, Rat.cast_pow,
             Rat.cast_neg, Rat.cast_one, Rat.cast_inv, Rat.cast_natCast]
  rw [← hS_eq] at h₁
  have hq_ne : (q : ℝ) ≠ 0 := Nat.cast_ne_zero.mpr h₀.ne'
  have hp_eq : (p : ℝ) = S * q := by field_simp at h₁; linarith
  have hp_rat : (p : ℚ) = S * q := by exact_mod_cast hp_eq
  have hdvd_num : (1979 : ℤ) ∣ S.num := by native_decide
  have hcop : Nat.Coprime S.den 1979 := by native_decide
  have hp_rel : (p : ℤ) * S.den = S.num * q := by
    have h := hp_rat
    have hden_pos : (S.den : ℚ) ≠ 0 := Nat.cast_ne_zero.mpr S.den_pos.ne'
    rw [← Rat.num_div_den S, div_mul_eq_mul_div, eq_div_iff hden_pos] at h
    exact_mod_cast h
  have hdvd_prod : (1979 : ℤ) ∣ (S.den : ℤ) * p := by
    rw [mul_comm, hp_rel]; exact dvd_mul_of_dvd_left hdvd_num q
  exact Int.ofNat_dvd.mp (hcop.isCoprime.symm.dvd_of_dvd_mul_left hdvd_prod)
