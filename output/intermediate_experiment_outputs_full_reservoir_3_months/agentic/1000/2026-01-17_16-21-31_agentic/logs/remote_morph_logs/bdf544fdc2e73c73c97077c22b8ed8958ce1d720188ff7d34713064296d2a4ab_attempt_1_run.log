@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  use ⟨1008, by norm_num⟩, ⟨1, by norm_num⟩
  intro m n ⟨hmn, hNm⟩
  simp only [PNat.mk_coe]
  have inj : Function.Injective (fun k : ℕ+ => (k : ℤ) + a k) := by
    intro k l heq
    by_contra hne
    rcases (ne_iff_lt_or_gt.mp hne) with hlt | hgt
    · exact hii l k ⟨k.2, hlt⟩ heq
    · exact hii k l ⟨l.2, hgt⟩ heq.symm
  have hBound : ∀ k : ℕ+, |a k - 1008| ≤ 1007 := fun k => by
    have h1 := (hi k).1
    have h2 := (hi k).2
    rw [abs_le]
    constructor <;> omega
  have hinjOn : Set.InjOn (fun k : ℕ+ => (k : ℤ) + a k) (Finset.Icc (m + 1) n) :=
    fun _ _ _ _ h => inj h
  have himg : (Finset.Icc (m + 1) n).image (fun k : ℕ+ => (k : ℤ) + a k) ⊆
      Finset.Icc ((m : ℤ) + 2) ((n : ℤ) + 2015) := by
    intro x hx
    simp only [Finset.mem_image] at hx
    obtain ⟨k, hk, rfl⟩ := hx
    simp only [Finset.mem_Icc] at hk ⊢
    have hak := hi k
    constructor
    · have : (m : ℤ) + 1 ≤ k := by exact_mod_cast hk.1
      omega
    · have : (k : ℤ) ≤ n := by exact_mod_cast hk.2
      omega
  have hcardImg := Finset.card_le_card himg
  rw [Finset.card_image_of_injOn hinjOn] at hcardImg
  simp only [Int.card_Icc] at hcardImg
  calc |∑ j ∈ Finset.Icc (m + 1) n, (a j - 1008)|
      ≤ ∑ j ∈ Finset.Icc (m + 1) n, |a j - 1008| := Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ _j ∈ Finset.Icc (m + 1) n, (1007 : ℤ) := Finset.sum_le_sum (fun j _ => hBound j)
    _ = (Finset.Icc (m + 1) n).card * 1007 := by simp [Finset.sum_const]
    _ ≤ 1007 * 1007 := by
        have hcard : (Finset.Icc (m + 1) n).card ≤ 1007 := by
          have hpos : 0 ≤ (n : ℤ) + 2015 + 1 - ((m : ℤ) + 2) := by
            have : (m : ℤ) < n := by exact_mod_cast hmn
            omega
          have hIcc_card : (Finset.Icc ((m : ℤ) + 2) ((n : ℤ) + 2015)).card = 
              ((n : ℤ) + 2015 + 1 - ((m : ℤ) + 2)).toNat := Int.card_Icc _ _
          have hle : (Finset.Icc (m + 1) n).card ≤ ((n : ℤ) + 2015 + 1 - ((m : ℤ) + 2)).toNat := by
            calc (Finset.Icc (m + 1) n).card 
                ≤ (Finset.Icc ((m : ℤ) + 2) ((n : ℤ) + 2015)).card := hcardImg
              _ = _ := hIcc_card
          have hsimpl : ((n : ℤ) + 2015 + 1 - ((m : ℤ) + 2)).toNat = (n : ℕ) - (m : ℕ) + 2014 := by
            have hmn' : (m : ℕ) ≤ n := le_of_lt hmn
            have : (n : ℤ) + 2015 + 1 - ((m : ℤ) + 2) = (n : ℤ) - (m : ℤ) + 2014 := by ring
            rw [this]
            have hnn : (n : ℤ) - (m : ℤ) + 2014 ≥ 0 := by omega
            rw [Int.toNat_of_nonneg hnn]
            have : (n : ℤ) - (m : ℤ) = ((n : ℕ) - (m : ℕ) : ℤ) := by omega
            omega
          omega
        nlinarith
    _ = 1007 ^ 2 := by ring
