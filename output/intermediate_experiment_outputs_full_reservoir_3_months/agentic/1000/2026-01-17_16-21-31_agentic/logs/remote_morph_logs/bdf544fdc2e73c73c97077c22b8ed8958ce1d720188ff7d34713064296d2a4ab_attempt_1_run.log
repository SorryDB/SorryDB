  simp only [PNat.mk_coe]
  have inj : Function.Injective (fun k : ℕ+ => (k : ℤ) + a k) := by
    intro k l heq
    by_contra hne
    rcases (ne_iff_lt_or_gt.mp hne) with hlt | hgt
    · exact hii l k ⟨k.2, hlt⟩ heq
    · exact hii k l ⟨l.2, hgt⟩ heq.symm
  have hBound : ∀ k : ℕ+, |a k - 1008| ≤ 1007 := fun k => by
    have h1 := (hi k).1
    have h2 := (hi k).2
    rw [abs_le]
    constructor <;> omega
  have key : |∑ j ∈ Finset.Icc (m + 1) n, (a j - 1008)| ≤
      ∑ j ∈ Finset.Icc (m + 1) n, |a j - 1008| := Finset.abs_sum_le_sum_abs _ _
  calc |∑ j ∈ Finset.Icc (m + 1) n, (a j - 1008)|
      ≤ ∑ j ∈ Finset.Icc (m + 1) n, |a j - 1008| := Finset.abs_sum_le_sum_abs _ _
    _ ≤ ∑ _j ∈ Finset.Icc (m + 1) n, (1007 : ℤ) := Finset.sum_le_sum (fun j _ => hBound j)
    _ = (Finset.Icc (m + 1) n).card * 1007 := by simp [Finset.sum_const]
    _ ≤ 1007 ^ 2 := by
        have hcard : (Finset.Icc (m + 1) n).card ≤ 1007 := by
          by_contra hc
          push_neg at hc
          have hinjOn : Set.InjOn (fun k : ℕ+ => (k : ℤ) + a k) (Finset.Icc (m + 1) n) :=
            fun _ _ _ _ h => inj h
          have hS := Finset.Icc (m + 1) n
          have himg : (Finset.Icc (m + 1) n).image (fun k : ℕ+ => (k : ℤ) + a k) ⊆
              Finset.Icc ((m : ℤ) + 2) ((n : ℤ) + 2015) := by
            intro x hx
            simp only [Finset.mem_image] at hx
            obtain ⟨k, hk, rfl⟩ := hx
            simp only [Finset.mem_Icc, PNat.add_coe, PNat.val_ofNat] at hk ⊢
            have hak := hi k
            constructor
            · have : (m : ℤ) + 1 < k := by exact_mod_cast hk.1
              omega
            · have : (k : ℤ) ≤ n := by exact_mod_cast hk.2
              omega
          have hcardImg := Finset.card_le_card himg
          rw [Finset.card_image_of_injOn hinjOn] at hcardImg
          simp only [Int.card_Icc] at hcardImg
          have : (n : ℤ) + 2015 - ((m : ℤ) + 2) + 1 = (n : ℤ) - m + 2014 := by ring
          rw [this] at hcardImg
          have hcardIcc : (Finset.Icc (m + 1) n).card = n - m := by
            rw [PNat.Icc_eq_finset_Icc]
            simp only [Finset.card_map]
            rw [Finset.card_Icc]
            have hm1n : (m : ℕ) + 1 ≤ n := by exact_mod_cast Nat.add_one_le_iff.mpr hmn
            omega
          rw [hcardIcc] at hc hcardImg
          have hn_m : (n : ℤ) - m = ((n - m : ℕ) : ℤ) := by
            have : (m : ℕ) ≤ n := le_of_lt hmn
            omega
          rw [hn_m] at hcardImg
          omega
        have h1007sq : (1007 : ℤ) ^ 2 = 1007 * 1007 := by ring
        have hcast : ((Finset.Icc (m + 1) n).card : ℤ) ≤ 1007 := by exact_mod_cast hcard
        calc ((Finset.Icc (m + 1) n).card : ℤ) * 1007 ≤ 1007 * 1007 := by nlinarith
          _ = 1007 ^ 2 := by ring
