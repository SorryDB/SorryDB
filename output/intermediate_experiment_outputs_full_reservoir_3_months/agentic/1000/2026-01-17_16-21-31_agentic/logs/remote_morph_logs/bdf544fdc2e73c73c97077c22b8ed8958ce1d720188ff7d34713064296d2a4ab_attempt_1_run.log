    · exact hii l k ⟨k.2, hlt⟩ heq
    · exact hii k l ⟨l.2, hgt⟩ heq.symm
  have hBound : ∀ k : ℕ+, abs (a k - 1008) ≤ 1007 := fun k => by
    have h1 := (hi k).1
    have h2 := (hi k).2
    rw [abs_le]
    constructor <;> omega
  simp only [PNat.mk_coe]
  have key : ∀ S : Finset ℕ+, (∀ k ∈ S, abs (a k - 1008) ≤ 1007) →
      abs (∑ j ∈ S, (a j - 1008)) ≤ (S.card : ℤ) * 1007 := fun S hS => by
