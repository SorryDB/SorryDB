    have hall : Finset.card (Finset.filter (fun j => (after S) j k) Finset.univ) = m + 1 := by
      simp [allKnow] at h
      convert Finset.card_univ (α := Fin (m + 1))
      ext j
      simp [h j]
    omega
```
