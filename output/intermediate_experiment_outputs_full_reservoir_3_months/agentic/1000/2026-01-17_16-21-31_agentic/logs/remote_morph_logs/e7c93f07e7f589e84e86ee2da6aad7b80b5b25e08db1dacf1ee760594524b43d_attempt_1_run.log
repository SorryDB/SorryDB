            rw [← Finset.geom_sum_eq (by norm_num : 2^8 ≠ 1) i]
            apply Finset.sum_le_sum; intro k hk
            simp only [Finset.mem_range] at hk
            rw [pow_mul]; ring_nf
    rw [Nat.add_div_eq_iff (by positivity), if_neg (by omega), Nat.add_mod]
    rw [Nat.mod_eq_of_lt hdiv, Nat.add_zero]
    simp only [Finset.sum_range_succ', Nat.add_zero, pow_zero, one_mul]
    rw [Nat.add_mul_div_left _ _ (by positivity : 0 < 2^(8*i))]
    rw [Nat.add_mod, Nat.mul_mod_right, Nat.add_zero]
    rw [Nat.mod_eq_of_lt (hbnd i i_lt)]
    simp [Array.getElem!_eq_getElem (by omega : i < x.val.length)]
  have := key
  rw [extract a, extract b] at this
  cases ha' : a.val[i]; cases hb' : b.val[i]
  simp_all
