    have hdiv : (∑ k ∈ Finset.range i, 2^(8*k) * (x[k]! : ℕ)) < 2^(8*i) := by
      calc ∑ k ∈ Finset.range i, 2^(8*k) * (x[k]! : ℕ)
          ≤ ∑ k ∈ Finset.range i, 2^(8*k) * (2^8 - 1) := by
            apply Finset.sum_le_sum; intro k hk; apply Nat.mul_le_mul_left; omega
        _ < ∑ k ∈ Finset.range i, 2^(8*(k+1)) := by
            apply Finset.sum_lt_sum_of_nonempty (by simp [i_lt])
            intro k _; nlinarith [Nat.pow_pos (by norm_num : 0 < 2) (8*k)]
