    intro x
    have hx : x.val.length = 32 := x.property
    have hbnd : ∀ k < 32, (x[k]! : ℕ) < 256 := fun k _ => Scalar.hmax
    rw [Finset.sum_range_add (n := i) (m := 32 - i)]
