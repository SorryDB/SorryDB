import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  induction n with
  | zero => simp [Finset.univ_eq_empty]
  | succ n ih =>
    have h1 : ∀ a b : ℝ, 0 ≤ √|a + b| - √|a - b| + (√|-a + b| - √|-a - b|) := fun a b => by
      simp only [neg_sub, abs_sub_comm, neg_add_eq_sub, sub_neg_eq_add, add_comm b a]
