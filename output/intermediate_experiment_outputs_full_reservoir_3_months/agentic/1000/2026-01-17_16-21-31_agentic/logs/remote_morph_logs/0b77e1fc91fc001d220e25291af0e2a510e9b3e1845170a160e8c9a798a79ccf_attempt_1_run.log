import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  have h : ∀ a b : ℝ, √|a - b| + √|-a - b| ≤ √|a + b| + √|-a + b| := fun a b => by
    simp only [neg_sub, abs_sub_comm, neg_add_eq_sub]
    ring_nf
  calc ∑ i, ∑ j, √|x i - x j|
      = (1/2) * (∑ i, ∑ j, √|x i - x j| + ∑ i, ∑ j, √|x j - x i|) := by
        simp only [← Finset.sum_add_distrib, abs_sub_comm]; ring
    _ = (1/2) * (∑ i, ∑ j, (√|x i - x j| + √|x j - x i|)) := by
        congr 1; rw [← Finset.sum_add_distrib]; congr 1; ext i
        rw [← Finset.sum_add_distrib]
    _ = ∑ i, ∑ j, √|x i - x j| := by simp [abs_sub_comm]; ring
    _ ≤ ∑ i, ∑ j, √|x i + x j| := by
        gcongr with i _ j _
