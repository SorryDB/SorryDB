import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  have key : ∀ a b : ℝ, √|a - b| + √|a + b| = √|a + b| + √|a - b| := fun a b => add_comm _ _
  have sum_symm : ∑ i, ∑ j, √|x i - x j| = ∑ j, ∑ i, √|x i - x j| := Finset.sum_comm
  have neg_sum : ∀ y : Fin n → ℝ, ∑ i, ∑ j, √|y i - y j| = ∑ i, ∑ j, √|(-y) i - (-y) j| := by
    intro y; congr! 3; simp [neg_sub_neg]
  have swap : ∀ y : Fin n → ℝ, ∑ i, ∑ j, √|y i - y j| = ∑ i, ∑ j, √|(-y) i + (-y) j| := by
    intro y; simp only [Pi.neg_apply, neg_add_rev, abs_neg, neg_add]
  rw [swap x]
  simp only [Pi.neg_apply, neg_neg]
```
