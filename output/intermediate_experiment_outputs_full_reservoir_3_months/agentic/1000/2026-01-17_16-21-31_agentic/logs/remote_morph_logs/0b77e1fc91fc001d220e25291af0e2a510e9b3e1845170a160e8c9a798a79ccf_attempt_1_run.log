import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  have h1 : ∑ i, ∑ j, √|x i - x j| = ∑ i, ∑ j, √|(-x i) - (-x j)| := by simp [neg_sub_neg]
  have h2 : ∑ i, ∑ j, √|x i + x j| = ∑ i, ∑ j, √|(-x i) + (-x j)| := by simp [neg_add_rev, abs_neg]
  have h3 : ∀ a b : ℝ, √|a - b| + √|(-a) - b| = √|a - b| + √|a + b| := fun a b => by
    simp [abs_neg, neg_sub]
  have h4 : ∀ a b : ℝ, √|a + b| + √|(-a) + b| = √|a + b| + √|a - b| := fun a b => by
    simp [neg_add_eq_sub, abs_sub_comm]
  calc ∑ i, ∑ j, √|x i - x j| 
      = (∑ i, ∑ j, √|x i - x j| + ∑ i, ∑ j, √|(-x i) - x j|) / 2 := by
        simp only [Pi.neg_apply, neg_sub]
        have : ∑ i, ∑ j, √|x i - x j| = ∑ i, ∑ j, √|x i + x j| → 
               ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := le_of_eq
        have swap_neg : ∑ i, ∑ j, √|(-x) i - x j| = ∑ i, ∑ j, √|x i + x j| := by
          simp only [Pi.neg_apply, neg_sub_eq_iff_eq_add, abs_neg]
          congr! 2 with i _ j _
          rw [neg_sub, abs_sub_comm]
        linarith [Finset.sum_nonneg (fun i _ => Finset.sum_nonneg 
          (fun j _ => Real.sqrt_nonneg |x i + x j|))]
    _ ≤ (∑ i, ∑ j, √|x i + x j| + ∑ i, ∑ j, √|(-x i) + x j|) / 2 := by
        simp only [Pi.neg_apply]
        have eq1 : ∑ i, ∑ j, √|(-x) i - x j| = ∑ i, ∑ j, √|x i + x j| := by
          congr! 2 with i _ j _; simp [neg_sub, abs_sub_comm]
        have eq2 : ∑ i, ∑ j, √|-x i + x j| = ∑ i, ∑ j, √|x i - x j| := by
          congr! 2 with i _ j _; simp [abs_sub_comm]
        linarith
    _ = ∑ i, ∑ j, √|x i + x j| := by
        simp only [Pi.neg_apply]
        have eq2 : ∑ i, ∑ j, √|-x i + x j| = ∑ i, ∑ j, √|x i - x j| := by
          congr! 2 with i _ j _; simp [abs_sub_comm]
        have eq3 : ∑ i, ∑ j, √|x i - x j| = ∑ i, ∑ j, √|x j - x i| := by
          congr! 2 with i _ j _; rw [abs_sub_comm]
        linarith
