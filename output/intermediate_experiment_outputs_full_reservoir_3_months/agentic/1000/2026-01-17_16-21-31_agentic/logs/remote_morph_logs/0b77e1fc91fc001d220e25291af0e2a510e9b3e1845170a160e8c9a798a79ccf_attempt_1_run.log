import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  have h : ∀ a b : ℝ, √|a - b| + √|-(a + b)| = √|a + b| + √|-(a - b)| := fun a b => by
    simp only [abs_neg]; ring
  calc ∑ i, ∑ j, √|x i - x j|
      = (∑ i, ∑ j, √|x i - x j| + ∑ i, ∑ j, √|x i - x j|) / 2 := by ring
    _ = (∑ i, ∑ j, √|x i - x j| + ∑ i, ∑ j, √|x j - x i|) / 2 := by
        congr 2; congr 1; ext i; congr 1; ext j; rw [abs_sub_comm]
    _ = (∑ i, ∑ j, √|x i - x j| + ∑ j, ∑ i, √|x j - x i|) / 2 := by rfl
    _ ≤ (∑ i, ∑ j, √|x i + x j| + ∑ j, ∑ i, √|x j + x i|) / 2 := by
        gcongr <;> (apply Finset.sum_le_sum; intro i _; apply Finset.sum_le_sum; intro j _)
        all_goals exact Real.sqrt_le_sqrt (abs_sub_abs_le_abs_sub (x _) (x _))
    _ = ∑ i, ∑ j, √|x i + x j| := by
        congr 2; rw [Finset.sum_comm]; congr 1; ext i; congr 1; ext j; rw [add_comm]
```
