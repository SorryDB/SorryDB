  : xs ≠ [] ∧ ys ≠ [] → foldr1 f (xs ++ ys) = f (foldr1 f xs) (foldr1 f ys) := by
  intro h
  induction xs with
  | nil =>
    simp at h
  | cons b bs ih =>
    simp [foldr1]
    have h₁ := h.right
    match ys with
    | [] => simp_all
    | z :: zs =>
      simp_all
      sorry
