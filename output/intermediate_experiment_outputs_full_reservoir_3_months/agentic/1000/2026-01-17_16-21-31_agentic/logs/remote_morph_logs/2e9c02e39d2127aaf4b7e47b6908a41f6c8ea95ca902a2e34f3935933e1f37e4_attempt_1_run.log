  simp only [List.all_eq_true, List.any_eq_true, Prod.forall, decide_eq_true_eq]
  constructor
  · -- Product equals n: requires induction on countFactors
    sorry
  constructor
  · -- All result primes are from input list
    intro p e h
    induction primes generalizing n with
    | nil => simp [findExponents.countFactors] at h
