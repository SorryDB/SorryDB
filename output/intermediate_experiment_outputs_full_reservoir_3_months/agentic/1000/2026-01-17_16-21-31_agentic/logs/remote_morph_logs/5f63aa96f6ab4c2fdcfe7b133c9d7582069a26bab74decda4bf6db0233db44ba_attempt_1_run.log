  classical
  have hInvo : ∀ s : S k, linearInvo k (linearInvo k s) = s := fun s =>
    congrFun (linearInvo_sq k) s
  have hz_ne : ∀ (s : S k), s.1.2.2 ≠ 0 := by
    intro ⟨⟨x, y, z⟩, h⟩
