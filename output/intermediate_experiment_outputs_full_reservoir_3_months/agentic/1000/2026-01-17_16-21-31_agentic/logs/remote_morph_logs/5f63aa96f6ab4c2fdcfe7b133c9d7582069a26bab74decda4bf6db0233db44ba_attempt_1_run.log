    intro hz
    have := h.1
    simp only [hz, ne_eq, OfNat.ofNat_ne_zero, not_false_eq_true, zero_pow, add_zero] at this
    omega
  have hT_swap : ∀ s : S k, s ∈ T k ↔ linearInvo k s ∉ T k := by
    intro ⟨⟨x, y, z⟩, h⟩
    simp only [T, Set.mem_setOf_eq, linearInvo, Left.neg_pos_iff]
    have := hz_ne ⟨⟨x, y, z⟩, h⟩
    omega
  have hU_swap : ∀ s : S k, s ∈ U k ↔ linearInvo k s ∉ U k := by
    intro ⟨⟨x, y, z⟩, h⟩
    simp only [U, Set.mem_setOf_eq, linearInvo]
    simp only [S, Set.mem_setOf_eq] at h
    have hxyz_ne : x - y + z ≠ 0 := by
      intro hxyz
      have heq : (x + y)^2 = 4 * (k : ℤ) + 1 := by nlinarith
      have hxy_pos : x + y ≥ 2 := by linarith
      have hprime : Nat.Prime (4 * k + 1) := Fact.out
      have habs : (x + y).natAbs ^ 2 = 4 * k + 1 := by
        have := Int.natAbs_sq (x + y); omega
      have hdvd : (x + y).natAbs ∣ 4 * k + 1 := ⟨(x + y).natAbs, habs⟩
      rcases hprime.eq_one_or_self_of_prime_of_dvd _ hdvd with h1 | h2
      · omega
      · have : (4 * k + 1) ^ 2 = 4 * k + 1 := by rw [← h2]; exact habs; nlinarith
    omega
  apply Fintype.card_congr
  refine ⟨fun ⟨s, hs⟩ => ⟨if s.1.2.2 > 0 then s else linearInvo k s, ?_⟩,
          fun ⟨s, hs⟩ => ⟨if s.1.1 - s.1.2.1 + s.1.2.2 > 0 then s else linearInvo k s, ?_⟩,
          ?_, ?_⟩
  · split_ifs with hz <;> [exact hz; exact (hT_swap s).mp (by simp only [T, Set.mem_setOf_eq]; omega)]
  · split_ifs with hxyz <;> [exact hxyz; exact (hU_swap s).mp (by simp only [U, Set.mem_setOf_eq]; omega)]
  · intro ⟨s, hs⟩
    simp only [Set.mem_setOf_eq] at hs ⊢
    split_ifs with hz hxyz hxyz' hz' <;> simp [hInvo, linearInvo, U] at * <;> omega
  · intro ⟨s, hs⟩
    simp only [Set.mem_setOf_eq] at hs ⊢
    split_ifs with hxyz hz hz' hxyz' <;> simp [hInvo, linearInvo, T] at * <;> omega
