  have hxyz_ne : ∀ s : S k, s.1.1 - s.1.2.1 + s.1.2.2 ≠ 0 := by
    intro ⟨⟨x, y, z⟩, h⟩; simp only [S, Set.mem_setOf_eq] at h; intro hxyz
    have heq : (x + y)^2 = 4 * (k : ℤ) + 1 := by nlinarith
    have hprime : Nat.Prime (4 * k + 1) := Fact.out
    have habs : (x + y).natAbs ^ 2 = 4 * k + 1 := by have := Int.natAbs_sq (x + y); omega
