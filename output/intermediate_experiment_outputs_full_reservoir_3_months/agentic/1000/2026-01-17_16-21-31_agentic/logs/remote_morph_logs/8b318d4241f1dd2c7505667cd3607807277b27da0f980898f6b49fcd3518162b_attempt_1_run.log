              _ ‚Č§ P.n * primeCounting P.n := Nat.mul_le_mul_left P.n hpi_ge
              _ ‚Č§ P.n * (P.L^2 * primeCounting P.n) := Nat.mul_le_mul_left P.n (Nat.le_mul_of_pos_left _ (Nat.one_le_pow 2 P.L P.hL_pos))
              _ ‚Č§ P.M * (P.L^2 * primeCounting P.n) := by nlinarith [Nat.div_mul_le_self P.n P.M, mul_div_le P.n P.M]
          sorry
      _ ‚Č§ P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by nlinarith
  calc (‚ÜĎ(Multiset.map (fun x => x.factorization p) P.initial.a).sum - ‚ÜĎ(Nat.factorial P.n).factorization p : ‚ĄĚ)
      ‚Č• -(P.n.factorial.factorization p : ‚ĄĚ) := by exact_mod_cast hbal_ge
    _ ‚Č• -(P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n) := by linarith
    _ = -P.M * Real.log P.n - P.M * P.L^2 * primeCounting P.n := by ring
