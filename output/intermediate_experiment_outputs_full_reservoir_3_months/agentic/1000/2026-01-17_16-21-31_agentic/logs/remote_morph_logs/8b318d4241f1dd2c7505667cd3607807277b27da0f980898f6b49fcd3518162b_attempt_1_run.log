  have hpi_nonneg : (primeCounting P.n : ‚ĄĚ) ‚Č• 0 := Nat.cast_nonneg _
  have hlog_nonneg : Real.log P.n ‚Č• 0 := Real.log_nonneg (by exact_mod_cast Nat.one_le_of_lt hn_pos)
  have h_rhs_nonpos : -(P.M : ‚ĄĚ) * Real.log P.n - P.M * P.L^2 * primeCounting P.n ‚Č§ 0 := by nlinarith
  have hfact_nonneg : (P.n.factorial.factorization p : ‚ĄĚ) ‚Č• 0 := Nat.cast_nonneg _
  have hbal_ge : ((P.initial.a.map (¬∑.factorization p)).sum : ‚Ą§) - (P.n.factorial.factorization p : ‚Ą§) ‚Č• 
      -(P.n.factorial.factorization p : ‚Ą§) := by omega
  have hfact_bound : (P.n.factorial.factorization p : ‚ĄĚ) ‚Č§ P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
    have hfact_le_n : P.n.factorial.factorization p ‚Č§ P.n := by
      by_cases hp_prime : p.Prime
      ¬∑ exact Nat.factorial_prime_le_factorization hp_prime
      ¬∑ simp [Nat.factorization_eq_zero_of_not_prime _ hp_prime]
    have hpi_ge : primeCounting P.n ‚Č• 1 := Nat.primeCounting_pos hn_pos
    have hL_ge : P.L ‚Č• 1 := P.hL_pos
    have hL2_ge : P.L^2 ‚Č• 1 := Nat.one_le_pow 2 P.L P.hL_pos
    calc (P.n.factorial.factorization p : ‚ĄĚ) ‚Č§ P.n := by exact_mod_cast hfact_le_n
      _ ‚Č§ P.M * P.L^2 * primeCounting P.n := by
          have : P.n ‚Č§ P.M * P.L^2 * primeCounting P.n := by
