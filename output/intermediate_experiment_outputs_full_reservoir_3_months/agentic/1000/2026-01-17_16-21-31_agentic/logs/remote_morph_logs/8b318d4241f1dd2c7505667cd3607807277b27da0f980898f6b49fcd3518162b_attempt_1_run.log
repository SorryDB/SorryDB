  "initial-factorization-tiny-prime-ge"
  (statement := /-- A tiny prime $p \leq L$ can be in deficit by at most $M\log n + ML\pi(n)$.-/)
  (proof := /-- In addition to the Legendre calculations, one potentially removes factors of the
  form $plq$ with $l \leq L$ and $q \leq n$ a prime up to $M$ times each, with at most $L$ copies
  of $p$ removed at each factor.-/)]
theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ‚Ąē} (hp : p ‚Č§ P.L) :
    P.initial.balance p ‚Č• - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  have hbal_lower : (P.initial.balance p : ‚ĄĚ) ‚Č• -(P.n.factorial.factorization p : ‚ĄĚ) := by
    simp only [Factorization.balance, Factorization.sum]
    have hsum : (0 : ‚Ą§) ‚Č§ (Multiset.map (fun m => (m.factorization p : ‚Ą§)) P.initial.a).sum :=
      Multiset.sum_nonneg fun x hx => by
        obtain ‚ü®m, _, rfl‚ü© := Multiset.mem_map.mp hx; exact Int.ofNat_nonneg _
    have : (0 : ‚ĄĚ) ‚Č§ ((Multiset.map (fun m => (m.factorization p : ‚Ą§)) P.initial.a).sum : ‚ĄĚ) := by
      exact_mod_cast hsum
    linarith
  have hfact_bound : (P.n.factorial.factorization p : ‚ĄĚ) ‚Č§
      P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
    have hM : (0 : ‚ĄĚ) ‚Č§ P.M := Nat.cast_nonneg _
    have hL : (0 : ‚ĄĚ) ‚Č§ P.L := Nat.cast_nonneg _
    have hŌÄ : (0 : ‚ĄĚ) ‚Č§ primeCounting P.n := Nat.cast_nonneg _
    have hlog : 0 ‚Č§ Real.log P.n := by
      rcases eq_or_lt_of_le (Nat.zero_le P.n) with rfl | hn
      ¬∑ simp
      ¬∑ exact Real.log_nonneg (by exact_mod_cast hn)
    nlinarith [Nat.cast_nonneg (P.n.factorial.factorization p), sq_nonneg P.L,
      mul_nonneg hM hlog, mul_nonneg (mul_nonneg hM (sq_nonneg P.L)) hŌÄ]
  linarith
