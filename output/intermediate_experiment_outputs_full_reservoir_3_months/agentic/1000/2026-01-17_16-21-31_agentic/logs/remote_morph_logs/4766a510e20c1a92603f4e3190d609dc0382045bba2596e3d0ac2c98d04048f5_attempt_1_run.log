lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r := by
  constructor
  · intro hv
    have hne : x ≠ 0 := by
      intro h
      simp only [h, map_zero] at hv
    have hmem : x ∈ (𝒪[K] : Subring K) := by
      rw [ValuativeRel.mem_integerRing]
      exact le_of_eq hv
    have hinv_mem : x⁻¹ ∈ (𝒪[K] : Subring K) := by
      rw [ValuativeRel.mem_integerRing, map_inv₀, hv, inv_one]
    refine ⟨⟨⟨x, hmem⟩, ⟨x⁻¹, hinv_mem⟩, ?_, ?_⟩, rfl⟩
    · ext; exact mul_inv_cancel₀ hne
    · ext; exact inv_mul_cancel₀ hne
  · rintro ⟨r, rfl⟩
    have hr : ((r : 𝒪[K]) : K) ∈ (𝒪[K] : Subring K) := r.val.prop
    have hrinv : ((r⁻¹ : 𝒪[K]ˣ) : K) ∈ (𝒪[K] : Subring K) := r⁻¹.val.prop
    rw [ValuativeRel.mem_integerRing] at hr hrinv
    have hne : ((r : 𝒪[K]) : K) ≠ 0 := Units.val_ne_zero (r.map (𝒪[K]).subtype)
    rw [show ((r⁻¹ : 𝒪[K]ˣ) : K) = ((r : 𝒪[K]) : K)⁻¹ from rfl, map_inv₀] at hrinv
    exact le_antisymm hr (one_le_inv_of_le_one hne hrinv)
```
