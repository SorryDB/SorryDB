```lean
lemma IsMatching.disjoint_inter_of_isCycleGraph_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C ≤ hM.restrict₂ hM') :
    Disjoint (E(C) ∩ M) (E(C) ∩ M') := by
  rw [Set.disjoint_iff]
  intro e he
  obtain ⟨⟨heC, heM⟩, ⟨-, heM'⟩⟩ := he
  have heCsd := hCG.edge_subset heC
  unfold restrict₂ at heCsd
  simp only [edgeSet_loopRemove, edgeSet_restrict, Set.mem_inter_iff] at heCsd
  have hsd : e ∈ M ∆ M' := heCsd.1.2
  rw [Set.mem_symmDiff] at hsd
  cases hsd with
  | inl h => exact h.2 heM'
  | inr h => exact h.2 heM
```
