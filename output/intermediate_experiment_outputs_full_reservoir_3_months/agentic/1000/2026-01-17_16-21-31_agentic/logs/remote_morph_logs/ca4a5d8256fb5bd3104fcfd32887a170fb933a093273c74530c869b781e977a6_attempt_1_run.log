theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  simp only [e, gt_iff_lt]
  have e_pos : (0 : ℝ) < exp 1 := exp_pos 1
  have e_gt_two : (2 : ℝ) < exp 1 := by
    have := Real.add_one_lt_exp (one_ne_zero : (1 : ℝ) ≠ 0)
    linarith
  have key : ∀ k : ℕ, 0 < k → ((k : ℝ) + 1) ^ k < exp 1 * (k : ℝ) ^ k := fun k hk => by
    have hk_cast : (0 : ℝ) < k := Nat.cast_pos.mpr hk
    have h_ne : (1 : ℝ) / k ≠ 0 := by positivity
    have h1 : 1 + 1 / (k : ℝ) < exp (1 / k) := Real.add_one_lt_exp h_ne
    have h2 : (1 + 1 / (k : ℝ)) ^ k < (exp (1 / k)) ^ k :=
      pow_lt_pow_left h1 (by linarith) hk.ne'
    have h3 : (exp (1 / (k : ℝ))) ^ k = exp 1 := by rw [← exp_nat_mul]; congr 1; field_simp
    have h4 : ((k : ℝ) + 1) / k = 1 + 1 / k := by field_simp
    calc ((k : ℝ) + 1) ^ k = (((k : ℝ) + 1) / k * k) ^ k := by field_simp
      _ = (((k : ℝ) + 1) / k) ^ k * k ^ k := by rw [mul_pow, mul_comm]
      _ = (1 + 1 / k) ^ k * k ^ k := by rw [h4]
      _ < (exp (1 / k)) ^ k * k ^ k := by nlinarith [h2, pow_pos hk_cast k]
      _ = exp 1 * k ^ k := by rw [h3]
  induction n using Nat.strong_induction_on with
  | _ n IH =>
    match n with
    | 0 | 1 => omega
    | 2 =>
      calc exp 1 * (2 / exp 1) ^ 2 = 4 / exp 1 := by field_simp; ring
        _ < 4 / 2 := by apply div_lt_div_of_pos_left (by norm_num) (by norm_num) e_gt_two
        _ = 2 := by norm_num
        _ = ↑(2 : ℕ).factorial := by norm_num
    | n + 3 =>
      have hn2 : 1 < n + 2 := by omega
      have IH' := IH (n + 2) (by omega) hn2
      have n2_pos : 0 < n + 2 := by omega
      have n2_cast : (0 : ℝ) < (n + 2 : ℕ) := Nat.cast_pos.mpr n2_pos
      have n3_cast : (0 : ℝ) < (n + 3 : ℕ) := Nat.cast_pos.mpr (by omega)
      have key' := key (n + 2) n2_pos
      calc exp 1 * (↑(n + 3) / exp 1) ^ (n + 3)
          = (↑(n + 3)) ^ (n + 3) / exp 1 ^ (n + 2) := by
            rw [div_pow, pow_succ (exp 1)]; field_simp; ring
        _ = (↑(n + 2) + 1) ^ (n + 2) * (↑(n + 2) + 1) / exp 1 ^ (n + 2) := by
            push_cast; rw [pow_succ']; ring
        _ < exp 1 * (↑(n + 2)) ^ (n + 2) * (↑(n + 2) + 1) / exp 1 ^ (n + 2) := by
            have h : (↑(n + 2) + 1 : ℝ) ^ (n + 2) < exp 1 * (↑(n + 2)) ^ (n + 2) := by
              convert key' using 2; push_cast
            have hpos : (0 : ℝ) < exp 1 ^ (n + 2) := pow_pos e_pos _
            have h' : (↑(n + 2) + 1 : ℝ) ^ (n + 2) * (↑(n + 2) + 1) <
                      exp 1 * ↑(n + 2) ^ (n + 2) * (↑(n + 2) + 1) := by nlinarith
            exact div_lt_div_of_pos_right h' hpos
        _ = (↑(n + 2) + 1) * (exp 1 * (↑(n + 2) / exp 1) ^ (n + 2)) := by
            rw [div_pow]; field_simp; ring
        _ < (↑(n + 2) + 1) * ↑(n + 2).factorial := by nlinarith [IH', n3_cast]
        _ = ↑(n + 3).factorial := by rw [Nat.factorial_succ]; push_cast; ring
