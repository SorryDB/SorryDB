theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  simp only [e, gt_iff_lt]
  have e_pos : (0 : ℝ) < exp 1 := exp_pos 1
  have two_lt_e : (2 : ℝ) < exp 1 := by
    have := add_one_lt_exp_of_pos (zero_lt_one : (0 : ℝ) < 1)
    linarith
  have key_ineq : ∀ k : ℕ, 0 < k → (1 + 1 / (k : ℝ)) ^ k < exp 1 := fun k hk => by
    have hk_pos : (0 : ℝ) < k := Nat.cast_pos.mpr hk
    have h1 : (0 : ℝ) < 1 / k := by positivity
    have h2 := add_one_lt_exp_of_pos h1
    have h3 := pow_lt_pow_left h2 (by linarith : (0 : ℝ) ≤ 1 + 1 / k) hk.ne'
    calc (1 + 1 / (k : ℝ)) ^ k < (exp (1 / k)) ^ k := h3
      _ = exp (k * (1 / k)) := by rw [← exp_nat_mul]; ring_nf
      _ = exp 1 := by field_simp
  have main : ∀ m : ℕ, 1 < m → exp 1 * ((m : ℝ) / exp 1) ^ m < (m.factorial : ℝ) := by
    intro m hm
    induction m with
    | zero => omega
    | succ k ih =>
      cases k with
      | zero => omega
      | succ j =>
        cases j with
        | zero =>
          norm_num [Nat.factorial]
          rw [show exp 1 * (2 / exp 1) ^ 2 = 4 / exp 1 by field_simp; ring]
          rw [div_lt_iff e_pos]; linarith
        | succ i =>
          have hk : 1 < i + 2 := by omega
          have ih' := ih hk
          have k_pos : 0 < i + 2 := by omega
          have k_cast_pos : (0 : ℝ) < (i + 2 : ℕ) := Nat.cast_pos.mpr k_pos
          have k1_cast_pos : (0 : ℝ) < (i + 2 : ℕ) + 1 := by linarith
          have ratio_lt : (((i + 2 : ℕ) + 1) / ((i + 2 : ℕ) : ℝ)) ^ (i + 2) < exp 1 := by
            convert key_ineq (i + 2) k_pos using 2; field_simp
          have h1 : (((i + 2 : ℕ) : ℝ) + 1) ^ (i + 2) < exp 1 * ((i + 2 : ℕ) : ℝ) ^ (i + 2) := by
            have := mul_lt_mul_of_pos_right ratio_lt (pow_pos k_cast_pos (i + 2))
            rwa [div_pow, div_mul_cancel₀] at this
            exact (pow_pos k_cast_pos (i + 2)).ne'
          simp only [Nat.succ_eq_add_one, Nat.reduceAdd, Nat.cast_add, Nat.cast_one]
          calc exp 1 * ((↑(i + 2) + 1) / exp 1) ^ (i + 2 + 1)
              = (↑(i + 2) + 1) ^ (i + 2 + 1) / exp 1 ^ (i + 2) := by
                rw [div_pow, mul_div_assoc, pow_succ (exp 1), mul_comm (exp 1 ^ (i+2))]
                field_simp
            _ = (↑(i + 2) + 1) ^ (i + 2) * (↑(i + 2) + 1) / exp 1 ^ (i + 2) := by rw [pow_succ]
            _ < exp 1 * ↑(i + 2) ^ (i + 2) * (↑(i + 2) + 1) / exp 1 ^ (i + 2) := by
                apply div_lt_div_of_pos_right _ (pow_pos e_pos (i + 2))
                nlinarith [h1, pow_pos k_cast_pos (i + 2)]
            _ = (↑(i + 2) + 1) * (↑(i + 2) / exp 1) ^ (i + 2) := by rw [div_pow]; field_simp; ring
            _ < (↑(i + 2) + 1) * ↑(i + 2)! := by nlinarith [ih', k1_cast_pos]
            _ = ↑(i + 2 + 1)! := by rw [Nat.factorial_succ, Nat.cast_mul]; ring
  exact main n hn
