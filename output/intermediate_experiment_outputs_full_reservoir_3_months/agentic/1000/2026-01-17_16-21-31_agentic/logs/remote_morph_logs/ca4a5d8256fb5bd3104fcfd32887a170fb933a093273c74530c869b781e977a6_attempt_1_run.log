theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  unfold e
  have e_pos : (0 : ℝ) < exp 1 := exp_pos 1
  have two_lt_e : (2 : ℝ) < exp 1 := Real.two_lt_exp_one
  have n_pos : (0 : ℝ) < n := Nat.cast_pos.mpr (Nat.zero_lt_of_lt hn)
  rw [gt_iff_lt, ← sub_pos]
  have h1 : exp 1 * (↑n / exp 1) ^ n = (↑n)^n / (exp 1)^(n-1) := by
    have hn' : n = (n - 1) + 1 := by omega
    field_simp
    rw [mul_comm, ← pow_succ]
    congr 1
    omega
  rw [h1]
  rw [sub_pos, div_lt_iff (pow_pos e_pos (n-1))]
  have key : ∀ m : ℕ, 1 < m → (m : ℝ)^m < (m.factorial : ℝ) * (exp 1)^(m-1) := by
    intro m hm
    induction m using Nat.strong_induction_on with
    | ind m ih =>
      interval_cases m
      · simp only [Nat.factorial_two, Nat.cast_ofNat, pow_one]
        calc (2 : ℝ)^2 = 4 := by norm_num
          _ < 2 * exp 1 := by linarith
      all_goals {
        have hprev : 1 < m - 1 := by omega
        have ih' := ih (m - 1) (by omega) hprev
        have h2 : ((1 : ℝ) + 1 / (m - 1 : ℕ))^(m - 1 : ℕ) ≤ exp 1 := by
          have := Real.add_one_le_exp (1 / (m - 1 : ℕ))
          exact Real.one_add_div_pow_le_exp (m - 1) 1 (by linarith)
        calc (m : ℝ)^m = (m : ℝ) * (m : ℝ)^(m-1) := by rw [← pow_succ]; congr 1; omega
          _ = (m : ℝ) * ((m - 1 : ℕ) + 1 : ℝ)^(m-1) := by norm_cast; congr 2; omega
          _ = (m : ℝ) * ((m - 1 : ℕ) * (1 + 1/(m-1 : ℕ)))^(m-1) := by
              congr 2; field_simp; ring
          _ = (m : ℝ) * (m - 1 : ℕ)^(m-1) * (1 + 1/(m-1 : ℕ))^(m-1) := by
              rw [mul_rpow (by positivity) (by positivity)]; ring
          _ ≤ (m : ℝ) * (m - 1 : ℕ)^(m-1) * exp 1 := by nlinarith [h2, pow_pos (a := (m - 1 : ℕ)) (by positivity : (0:ℝ) < (m-1 : ℕ)) (m-1)]
          _ < (m : ℝ) * ((m - 1).factorial * (exp 1)^(m-2)) * exp 1 := by nlinarith [ih', pow_pos e_pos (m-2)]
          _ = m * (m - 1).factorial * (exp 1)^(m-1) := by rw [← pow_succ]; ring_nf; congr 1; omega
          _ = (m.factorial : ℝ) * (exp 1)^(m-1) := by rw [← Nat.cast_mul]; congr 1; exact (Nat.factorial_mul_pred (by omega)).symm
      }
  exact key n hn
