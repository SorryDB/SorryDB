```lean
theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  unfold e
  have e_pos : (0 : ℝ) < exp 1 := exp_pos 1
  have e_gt_two : (2 : ℝ) < exp 1 := by
    have h := Real.add_one_lt_exp (one_ne_zero : (1 : ℝ) ≠ 0)
    linarith
  have key : ∀ k : ℕ, 0 < k → (1 + 1 / (k : ℝ)) ^ k < exp 1 := fun k hk => by
    have hk_cast : (0 : ℝ) < k := Nat.cast_pos.mpr hk
    have h_ne : (1 : ℝ) / k ≠ 0 := by positivity
    have h1 : 1 + 1 / (k : ℝ) < exp (1 / k) := by
      have := Real.add_one_lt_exp h_ne; linarith
    have hbase : 0 < 1 + 1 / (k : ℝ) := by linarith
    calc (1 + 1 / (k : ℝ)) ^ k < (exp (1 / k)) ^ k := by gcongr
      _ = exp (k * (1 / k)) := by rw [← exp_nat_mul]; ring_nf
      _ = exp 1 := by field_simp
  induction n using Nat.strong_induction_on with
  | _ n IH =>
    match n with
    | 0 | 1 => omega
    | 2 =>
      simp only [gt_iff_lt, Nat.factorial_two, Nat.cast_ofNat]
      calc exp 1 * (2 / exp 1) ^ 2 = 4 / exp 1 := by field_simp; ring
        _ < 4 / 2 := by apply div_lt_div_of_pos_left (by norm_num) (by norm_num) e_gt_two
        _ = 2 := by norm_num
    | n + 3 =>
      have hn2 : 1 < n + 2 := by omega
      have IH' := IH (n + 2) (by omega) hn2
      have n2_pos : 0 < n + 2 := by omega
      have n2_cast : (0 : ℝ) < (n + 2 : ℕ) := Nat.cast_pos.mpr n2_pos
      have n3_cast : (0 : ℝ) < (n + 3 : ℕ) := Nat.cast_pos.mpr (by omega)
      have h_ratio : ((n + 2 : ℕ) + 1 : ℝ) / (n + 2) = 1 + 1 / (n + 2 : ℕ) := by field_simp
      have key' : (((n + 2 : ℕ) : ℝ) + 1) ^ (n + 2) < exp 1 * ((n + 2 : ℕ) : ℝ) ^ (n + 2) := by
        have hk := key (n + 2) n2_pos
        have h := mul_lt_mul_of_pos_right hk (pow_pos n2_cast (n + 2))
        rwa [h_ratio, div_pow, div_mul_cancel₀] at h
        exact (pow_pos n2_cast (n + 2)).ne'
      simp only [gt_iff_lt]
      calc exp 1 * (↑(n + 3) / exp 1) ^ (n + 3)
          = ↑(n + 3) ^ (n + 3) / exp 1 ^ (n + 2) := by
            rw [div_pow]; field_simp; ring
        _ = ↑(n + 3) ^ (n + 2) * ↑(n + 3) / exp 1 ^ (n + 2) := by ring
        _ < exp 1 * ↑(n + 2) ^ (n + 2) * ↑(n + 3) / exp 1 ^ (n + 2) := by
            have h : (↑(n + 3) : ℝ) ^ (n + 2) < exp 1 * ↑(n + 2) ^ (n + 2) := by
              convert key' using 2 <;> simp
            gcongr
        _ = ↑(n + 3) * (exp 1 * (↑(n + 2) / exp 1) ^ (n + 2)) := by
            rw [div_pow]; field_simp; ring
        _ < ↑(n + 3) * ↑(n + 2).factorial := by gcongr
        _ = ↑(n + 3).factorial := by rw [Nat.factorial_succ]; push_cast; ring
```
