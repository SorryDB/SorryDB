lemma image_empty {U : Type} {A : Set U}
    (f : U → Nat) (h : empty A) : image f A = I 0 := by
  ext n
  constructor
  · intro ⟨x, hxA, _⟩
    exact False.elim (h ⟨x, hxA⟩)
  · intro hn
    exact False.elim (Nat.not_lt_zero n hn)
```
