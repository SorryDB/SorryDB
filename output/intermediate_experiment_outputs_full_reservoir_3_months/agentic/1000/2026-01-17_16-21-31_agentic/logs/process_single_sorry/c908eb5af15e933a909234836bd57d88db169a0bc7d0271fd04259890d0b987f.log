    · exact continuousOn_const.div (continuousOn_pow 2) fun x hx => pow_ne_zero 2 (hne x hx)
  have hint : IntervalIntegrable (fun x => 1 / x + 1 / x ^ 2) volume a b := hcont.intervalIntegrable
  have hderiv : ∀ x ∈ [[a, b]], HasDerivAt (fun y => log y - y⁻¹) (1 / x + 1 / x ^ 2) x := by
    intro x hx
