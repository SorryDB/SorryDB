  have hpos : n > 0 := Nat.pos_of_ne_zero hne
  obtain ⟨f, _, honto⟩ := h
  obtain ⟨x, _⟩ := honto ⟨0, hpos⟩
  exact absurd x.2 (Nat.not_lt_zero x.1)
```
