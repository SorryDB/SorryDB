The fix is to use `congrArg` properly and then use `simp_all` or the correct lemma to derive the contradiction from `true = false`.

```lean
example
    (rec : âˆ€ (P Q : Prop) (motive : Disjunction P Q â†’ Type)
      (h_left : âˆ€ hp : P, motive (left hp)) (h_right : âˆ€ hq : Q, motive (right hq))
      (h : Disjunction P Q), motive h)
    (comp_left : âˆ€ P Q motive h_left h_right (hp : P),
      rec P Q motive h_left h_right (left hp) = h_left hp)
    (comp_right : âˆ€ P Q motive h_left h_right (hq : Q),
      rec P Q motive h_left h_right (right hq) = h_right hq) : False := by
  have eq1 := comp_left True True (fun _ => Bool) (fun _ => true) (fun _ => false) True.intro
  have eq2 := comp_right True True (fun _ => Bool) (fun _ => true) (fun _ => false) True.intro
  have key : (left True.intro : Disjunction True True) = right True.intro := Subsingleton.elim _ _
  have h := congrArg (rec True True (fun _ => Bool) (fun _ => true) (fun _ => false)) key
  simp_all
