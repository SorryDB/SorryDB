import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1984_p6
  (a b c d k m : ℕ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d)
  (h₁ : Odd a ∧ Odd b ∧ Odd c ∧ Odd d)
  (h₂ : a < b ∧ b < c ∧ c < d)
  (h₃ : a * d = b * c)
  (h₄ : a + d = 2^k)
  (h₅ : b + c = 2^m) :
  a = 1 := by
  by_contra ha
  have ha_ge : 3 ≤ a := by
    obtain ⟨xa, rfl⟩ := h₁.1
    omega
  have hb_ge : a + 2 ≤ b := by
    obtain ⟨xa, rfl⟩ := h₁.1
    obtain ⟨xb, rfl⟩ := h₁.2.1
    omega
  have hc_ge : b + 2 ≤ c := by
    obtain ⟨xb, rfl⟩ := h₁.2.1
    obtain ⟨xc, rfl⟩ := h₁.2.2.1
    omega
  have gcd_eq : a.gcd d = 1 := by
    have h : a.gcd d ∣ a + d := Nat.gcd_dvd_add_self
    rw [h₄] at h
    obtain ⟨t, ht⟩ := h
    have : Odd (a.gcd d) := Nat.Odd.gcd h₁.1 h₁.2.2.2
    obtain ⟨g, hg⟩ := this
    rw [hg, Nat.mul_comm] at ht
    have : 2 * g + 1 ∣ 2 ^ k := ⟨t, ht⟩
    omega
  have : a ∣ b := by
    have : a ∣ b * c := ⟨d, h₃.symm⟩
    exact Nat.dvd_of_dvd_mul_right_of_gcd_one gcd_eq this
  have : b ≤ a := Nat.le_of_dvd h₀.2.1 this
  omega
```
