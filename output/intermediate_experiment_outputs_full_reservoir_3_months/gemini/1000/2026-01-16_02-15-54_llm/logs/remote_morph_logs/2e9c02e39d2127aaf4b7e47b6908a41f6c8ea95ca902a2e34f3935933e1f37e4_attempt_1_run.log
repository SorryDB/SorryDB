theorem findExponents_spec_satisfied (n: Nat) (primes: List Nat) (h_precond : findExponents_precond (n) (primes)) :
    findExponents_postcond (n) (primes) (findExponents (n) (primes) h_precond) h_precond := by
  unfold findExponents_postcond findExponents
  let rec countFactors_spec (n : Nat) (primes : List Nat) (h_n : n > 0) (h_p : primes.all Nat.Prime) :
    (n = (findExponents.countFactors findExponents.countFactor n primes).foldl (fun acc (p, e) => acc * p ^ e) 1) ∧
    (findExponents.countFactors findExponents.countFactor n primes).all (fun (p, _) => p ∈ primes) ∧
    primes.all (fun p => (findExponents.countFactors findExponents.countFactor n primes).any (fun pair => pair.1 = p)) := by
    match primes with
    | [] =>
      simp [findExponents.countFactors]
      sorry
    | p :: ps =>
      simp [findExponents.countFactors]
      sorry
  exact countFactors_spec n primes h_precond.1 h_precond.2.2.1
