import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := (n.digits 2).foldl (fun acc d => 2 * acc + d) 0
  have hg_eq : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      cases n with
      | zero => contradiction
      | succ n =>
        match n.succ % 2 with
        | 0 =>
          have n_even : n.succ = 2 * (n.succ / 2) := Nat.div_two_mul_two_of_even (Nat.even_iff_mod_two_eq_zero.mpr rfl)
          have n_div_pos : n.succ / 2 > 0 := Nat.div_pos (Nat.succ_pos n) (Nat.succ_pos 1)
          rw [n_even, h₃ _ n_div_pos, ih _ (Nat.div_lt_self (Nat.succ_pos n) (Nat.succ_le_succ (Nat.succ_pos 0))), g]
          simp [Nat.digits_def 2 (2 * (n.succ / 2)), Nat.digits_def 2 (n.succ / 2)]
        | 1 =>
          if n.succ = 1 then rw [h₁, g]; rfl
          else if n.succ = 3 then rw [h₂, g]; rfl
          else
            match n.succ % 4 with
            | 1 =>
              let k := n.succ / 4
              have hk : 0 < k := Nat.div_pos (Nat.lt_trans (by decide) (Nat.pos_of_ne_zero (by intro h; cases h; cases n; contradiction))) (by decide)
              have h_lt : k < 4 * k + 1 := by linarith
              have h_lt2 : 2 * k + 1 < 4 * k + 1 := by linarith
              rw [h₄ k hk, ih _ h_lt, ih _ h_lt2]
              sorry
            | 3 =>
              let k := n.succ / 4
              have hk : 0 < k := Nat.div_pos (Nat.lt_trans (by decide) (Nat.pos_of_ne_zero (by intro h; cases h; cases n; contradiction))) (by decide)
              have h_lt : k < 4 * k + 3 := by linarith
              have h_lt2 : 2 * k + 1 < 4 * k + 3 := by linarith
              rw [h₅ k hk, ih _ h_lt, ih _ h_lt2]
              sorry
            | _ => contradiction
  have h_pal : ∀ n > 0, g n = n ↔ (n.digits 2).reverse = n.digits 2 := by
    intro n hn
    have : g n = (n.digits 2).reverse.foldr (fun d acc => 2 * acc + d) 0 := by
      rw [g, List.foldl_eq_foldr_reverse]
    sorry
  let S := (Finset.Icc 1 1988).filter (fun n => (n.digits 2).reverse = n.digits 2)
  have h_S_card : S.card = 92 := by
    let P (k : ℕ) := (Finset.Icc (2^k) (2^(k+1)-1)).filter (fun n => (n.digits 2).reverse = n.digits 2)
    have hP : ∀ k, (P k).card = 2^(k/2) := sorry
    have h_split : S = (Finset.range 10).biUnion P ∪ (Finset.Icc (2^10) 1988).filter (fun n => (n.digits 2).reverse = n.digits 2) := sorry
    sorry
  rw [← h_S_card]
  apply Finset.card_congr (fun n _ => n)
  · intro n hn; simp at hn ⊢; rw [hg_eq n hn.1, h_pal n hn.1]; exact hn.2
  · intro n m hn hm h; exact h
  · intro n hn; simp at hn ⊢; use n; simp [hn]; rw [hg_eq n hn.1, h_pal n hn.1] at hn; exact ⟨hn.1, hn.2⟩
