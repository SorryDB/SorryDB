import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let is_pal (n : ℕ) : Bool := (Nat.digits 2 n).reverse == Nat.digits 2 n
  have hf : ∀ n > 0, f n = n ↔ is_pal n := by
    intro n hn
    have h_unique : ∀ g : ℕ → ℕ, (g 1 = 1) → (g 3 = 3) → (∀ m > 0, g (2 * m) = g m) →
        (∀ m > 0, g (4 * m + 1) = 2 * g (2 * m + 1) - g m) →
        (∀ m > 0, g (4 * m + 3) = 3 * g (2 * m + 1) - 2 * g m) →
        ∀ x > 0, f x = g x := by
      intro g g1 g3 g2m g4m1 g4m3 x hx
      induction x using Nat.strong_inductionOn with
      | h x ih =>
        if hx1 : x = 1 then rwa [hx1, h₁]
        else if hx3 : x = 3 then rwa [hx3, h₂]
        else if hx2 : x % 2 = 0 then
          have hx0 : x / 2 > 0 := Nat.pos_of_div_pos (Nat.div_le_self x 2) (by
            match x with | 0 => contradiction | 1 => contradiction | n+2 => exact Nat.succ_pos _)
          rw [← Nat.div_add_mod x 2, hx2, Nat.add_zero, mul_comm, h₃ _ hx0, g2m _ hx0, ih _ (Nat.div_lt_self hx (by decide))]
        else
          let m := x / 4
          if hm : m > 0 then
            if hxmod4 : x % 4 = 1 then
              rw [← Nat.div_add_mod x 4, hxmod4, h₄ m hm, g4m1 m hm, ih (2*m+1) (by linarith), ih m (by linarith)]
            else if hxmod4 : x % 4 = 3 then
              rw [← Nat.div_add_mod x 4, hxmod4, h₅ m hm, g4m3 m hm, ih (2*m+1) (by linarith), ih m (by linarith)]
            else
              cases (show x % 4 = 1 ∨ x % 4 = 3 by
                have := Nat.mod_lt x (by decide); have h_odd : x % 2 = 1 := Nat.mod_two_of_not_even hx2
                cases h_x4 : x % 4 <;> linarith [Nat.mod_mod_of_dvd x (show 2 ∣ 4 by decide)]) <;> contradiction
          else
            match x with | 1 | 2 | 3 | 4 | 5 | 7 => (by linarith) | _ => (by linarith)
    let rev (n : ℕ) : ℕ := if n = 0 then 0 else Nat.ofDigits 2 (Nat.digits 2 (n / 2 ^ n.trailingZeros)).reverse
    have h_rev_sol : ∀ n > 0, f n = rev n := by
      apply h_unique rev rfl rfl (fun m hm => by
        simp [rev, hm, Nat.trailingZeros_mul_pow_two m (by decide) 1, Nat.div_pow_mul_two m 1])
      · intro m hm; simp only [rev, hm]; sorry
      · intro m hm; simp only [rev, hm]; sorry
    have h_n_pal : ∀ n > 0, rev n = n ↔ is_pal n := by
      intro n hn; simp only [rev, hn, ite_false];
      have h_odd : n = n / 2 ^ n.trailingZeros ↔ n.trailingZeros = 0 := by
        rw [Nat.div_eq_self]; exact ⟨fun h => by linarith, fun h => by rw [h]; rfl⟩
      sorry
    rw [h_rev_sol n hn, h_n_pal n hn]; rfl
  have h_count : (Finset.filter is_pal (Finset.Icc 1 1988)).card = 92 := by native_decide
  rw [← h_count]; apply Finset.card_congr (fun n _ => n)
  · intros; simp_all
  · intros; simp_all
  · intros; simp_all
