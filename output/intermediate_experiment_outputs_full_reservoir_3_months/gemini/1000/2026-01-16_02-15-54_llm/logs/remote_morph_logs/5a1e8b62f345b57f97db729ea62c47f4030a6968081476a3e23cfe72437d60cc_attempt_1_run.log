import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := if n = 0 then 0 else
    let bits := Nat.digits 2 (n / 2 ^ n.trailingZeros)
    Nat.ofDigits 2 bits.reverse
  have g_even (n : ℕ) : g (2 * n) = g n := by
    by_cases h : n = 0
    · simp [h, g]
    · have h2 : 2 * n > 0 := Nat.mul_pos (by decide) (Nat.pos_of_ne_zero h)
      have h3 : (2 * n).trailingZeros = n.trailingZeros + 1 := by
        rw [Nat.trailingZeros_mul_pow_two n (by decide) 1, Nat.pow_one]
      simp [g, h, h2, h3, Nat.mul_div_right n (by decide)]
  have g_odd (n : ℕ) (hn : n > 0) : g (2 * n + 1) = 2 ^ (Nat.digits 2 n).length + g n := sorry
  have f_eq_g : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strongInductionOn with
    | h n ih =>
      by_cases h_ev : n % 2 = 0
      · obtain ⟨k, rfl⟩ := Nat.even_iff_exists_two_mul.1 (Nat.even_iff.2 h_ev)
        have hk : 0 < k := by
          refine Nat.pos_of_mul_pos_left ?_ (by decide)
          rw [← Nat.two_mul]; exact hn
        rw [h₃ k hk, ih k (Nat.lt_two_mul_self hk), g_even]
      · by_cases h1 : n = 1
        · rw [h1, h₁, rfl]
        · by_cases h3 : n = 3
          · rw [h3, h₂, rfl]
          · obtain ⟨k, rfl⟩ : ∃ k, n = 4 * k + 1 ∨ n = 4 * k + 3 := by
              match h : n % 4 with
              | 0 => exact (h_ev (Nat.even_iff.1 (Nat.dvd_of_mod_eq_zero h))).elim
              | 1 => exact ⟨n / 4, Or.inl (Nat.div_add_mod n 4).symm.trans (by rw [h])⟩
              | 2 => exact (h_ev (Nat.even_iff.1 (Nat.dvd_add (Nat.dvd_of_mod_eq_zero h) (by decide)))).elim
              | 3 => exact ⟨n / 4, Or.inr (Nat.div_add_mod n 4).symm.trans (by rw [h])⟩
              | _ => exact (h_ev (by linarith [Nat.mod_lt n (by decide : 0 < 4)])).elim
            · have hk : k > 0 := by linarith
              have i1 : 2 * k + 1 < 4 * k + 1 := by linarith
              have i2 : k < 4 * k + 1 := by linarith
              rw [h₄ k hk, ih (2 * k + 1) i1, ih k i2]
              sorry
            · have hk : k > 0 := by linarith
              have i1 : 2 * k + 1 < 4 * k + 3 := by linarith
              have i2 : k < 4 * k + 3 := by linarith
              rw [h₅ k hk, ih (2 * k + 1) i1, ih k i2]
              sorry
  have h_rev : ∀ n ∈ Finset.Icc 1 1988, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by
    intro n hn
    have n_pos : n > 0 := (Finset.mem_Icc.1 hn).1
    rw [f_eq_g n n_pos, g]
    split_ifs; · linarith
    have odd_part : ∀ {m}, m > 0 → (m / 2 ^ m.trailingZeros % 2 = 1) := sorry
    have g_val : g n = Nat.ofDigits 2 (Nat.digits 2 (n / 2 ^ n.trailingZeros)).reverse := rfl
    constructor
    · intro h
      have : n.trailingZeros = 0 := sorry
      rw [this, Nat.pow_zero, Nat.div_one] at h
      rw [← h]
      exact Nat.ofDigits_digits 2 (Nat.digits 2 n).reverse
    · intro h
      have : n.trailingZeros = 0 := sorry
      rw [this, Nat.pow_zero, Nat.div_one, ← h, Nat.ofDigits_digits]
  exact (Finset.filter_congr h_rev).trans (by native_decide)
