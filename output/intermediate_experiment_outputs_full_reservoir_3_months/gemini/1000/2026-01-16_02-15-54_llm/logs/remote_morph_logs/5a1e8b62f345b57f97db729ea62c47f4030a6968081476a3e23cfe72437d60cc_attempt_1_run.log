import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := (Nat.digits 2 n).foldl (fun acc d => 2 * acc + d) 0
  have hf_g : ∀ n ∈ Finset.Icc 1 1988, f n = g n := by
    intro n hn
    induction n using Nat.strongInductionOn with | ind n ih =>
    match n with
    | 0 => exact (Finset.mem_Icc.1 hn).1.irrefl.elim
    | 1 => exact h₁
    | 2 => rw [h₃ 1 (by decide), h₁]; rfl
    | 3 => exact h₂
    | n + 4 =>
      have hn4 : n + 4 > 0 := by decide
      if h : (n + 4) % 2 = 0 then
        obtain ⟨m, hm⟩ := Nat.exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero h)
        have hm0 : m > 0 := by rw [hm] at hn4; exact Nat.pos_of_mul_pos_left hn4 (by decide)
        have hmn : m < n + 4 := by rw [hm]; exact Nat.lt_mul_of_pos_right hm0 (by decide)
        rw [hm, h₃ m hm0, ih m hmn (Finset.mem_Icc.mpr ⟨hm0, (Finset.mem_Icc.1 hn).2.trans_le' (hm ▸ Nat.le_mul_of_pos_right hm0 (by decide))⟩)]
        unfold g; rw [Nat.digits_def 2 (by decide) (m * 2), List.foldl_cons, Nat.mul_mod_right, Nat.mul_div_right _ (by decide)]
        have : ∀ l, List.foldl (fun acc d => 2 * acc + d) 0 (0 :: l) = List.foldl (fun acc d => 2 * acc + d) 0 l := fun l => rfl
        exact this (Nat.digits 2 m)
      else
        have : (n + 4) % 2 = 1 := Nat.mod_two_ne_zero.1 h
        if h' : (n + 4) % 4 = 1 then
          obtain ⟨m, hm⟩ := ⟨(n + 4) / 4, Nat.div_add_mod (n + 4) 4⟩
          rw [h'] at hm; have hm0 : m > 0 := by rw [← hm] at hn4; exact Nat.pos_of_mul_pos_left (by linarith) (by decide)
          have h2m1 : 2 * m + 1 < n + 4 := by linarith
          have hm_lt : m < n + 4 := by linarith
          rw [← hm, h₄ m hm0, ih _ h2m1 (by constructor <;> linarith), ih _ hm_lt (by constructor <;> linarith)]
          sorry
        else
          have h'' : (n + 4) % 4 = 3 := by
            have : (n + 4) % 4 = 1 ∨ (n + 4) % 4 = 3 := Nat.mod_two_eq_one_iff_mod_four.1 this
            exact this.resolve_left h'
          obtain ⟨m, hm⟩ := ⟨(n + 4) / 4, Nat.div_add_mod (n + 4) 4⟩
          rw [h''] at hm; have hm0 : m > 0 := by rw [← hm] at hn4; exact Nat.pos_of_mul_pos_left (by linarith) (by decide)
          have h2m1 : 2 * m + 1 < n + 4 := by linarith
          have hm_lt : m < n + 4 := by linarith
          rw [← hm, h₅ m hm0, ih _ h2m1 (by constructor <;> linarith), ih _ hm_lt (by constructor <;> linarith)]
          sorry
  have h_count : (Finset.filter (fun n => g n = n) (Finset.Icc 1 1988)).card = 92 := by decide
  rw [Finset.filter_congr hf_g, h_count]
