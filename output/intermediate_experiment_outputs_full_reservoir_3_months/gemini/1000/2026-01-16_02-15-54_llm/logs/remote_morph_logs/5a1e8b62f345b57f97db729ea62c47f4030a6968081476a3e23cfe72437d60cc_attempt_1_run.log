import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let rec g (n : ℕ) : ℕ :=
    if n < 4 then (if n = 3 then 3 else if n = 0 then 0 else 1)
    else if n % 2 == 0 then g (n / 2)
    else if n % 4 == 1 then 2 * g (2 * (n / 4) + 1) - g (n / 4)
    else 3 * g (2 * (n / 4) + 1) - 2 * g (n / 4)
  termination_by n
  decreasing_by all_goals (simp_wf; apply Nat.div_lt_self <;> omega)
  have hg : ∀ n ∈ Finset.Icc 1 1988, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      if hn4 : n < 4 then
        match n with
        | 0 => omega
        | 1 => rw [h₁, g]; simp
        | 2 => rw [h₃ 1 (by omega), h₁, g]; simp
        | 3 => rw [h₂, g]; simp
      else
        have ih' {m} (h : m < n) (hm : m > 0) : f m = g m :=
          ih m h (Finset.mem_Icc.2 ⟨hm, by omega [Finset.mem_Icc.1 hn]⟩)
        rw [g]; simp [hn4]
        split_ifs with h_even h_4m1
        · rw [←h₃ (n / 2) (by omega), ih' (by omega) (by omega)]
        · rw [←h₄ (n / 4) (by omega), ih' (by omega) (by omega), ih' (by omega) (by omega)]
        · have : n % 4 = 3 := by have : n % 2 ≠ 0 := h_even; have : n % 4 ≠ 1 := h_4m1; omega
          rw [←h₅ (n / 4) (by omega), ih' (by omega) (by omega), ih' (by omega) (by omega)]
  rw [Finset.filter_congr (fun n hn => by rw [hg n hn])]
  decide
