import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := (Nat.bits n).reverse.foldl (fun acc b => 2 * acc + if b then 1 else 0) 0
  have hf_odd : ∀ n, n % 2 = 1 → f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on
    rename_i n ih
    rcases n with (_ | _ | _ | _ | n) <;> try (simp [h₁, h₂, g] at *; done)
    · contradiction
    · rw [h₁]; rfl
    · contradiction
    · rw [h₂]; rfl
    · have : 4 + n > 3 := by omega
      if h_mod : (n + 5) % 4 = 1 then
        obtain ⟨m, hm⟩ := Nat.exists_eq_add_of_le' (by omega : 1 ≤ (n + 5) / 4)
        have hn4 : n + 5 = 4 * (m + 1) + 1 := by omega
        rw [hn4, h₄ (m + 1) (by omega), ih (2 * (m + 1) + 1) (by omega), ih (m + 1) (by omega)]
        · sorry
        · exact Nat.mod_two_of_two_mul_add_one (m + 1)
        · exact Nat.mod_two_of_two_mul_add_one (2 * (m + 1) + 1)
      else if h_mod : (n + 5) % 4 = 3 then
        obtain ⟨m, hm⟩ := Nat.exists_eq_add_of_le' (by omega : 1 ≤ (n + 5) / 4)
        have hn4 : n + 5 = 4 * (m + 1) + 3 := by omega
        rw [hn4, h₅ (m + 1) (by omega), ih (2 * (m + 1) + 1) (by omega), ih (m + 1) (by omega)]
        · sorry
        · exact Nat.mod_two_of_two_mul_add_one (m + 1)
        · exact Nat.mod_two_of_two_mul_add_one (2 * (m + 1) + 1)
      else
        have : (n + 5) % 2 = 1 := by exact hn
        omega
  have hf_even : ∀ n > 0, f n = g (n / 2^(n.trailingZeros)) := by
    intro n hn
    induction n using Nat.strong_induction_on
    rename_i n ih
    if h_even : n % 2 = 0 then
      obtain ⟨m, hm⟩ := Nat.exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero h_even)
      rw [hm, h₃ m (by omega), ih m (by omega)]
      have : (2 * m).trailingZeros = m.trailingZeros + 1 := by
        apply Nat.trailingZeros_mul_pow_two m (by omega) 1
      rw [this, Nat.pow_succ, ←Nat.div_div_eq_div_mul, hm, Nat.mul_div_cancel_left m (by omega)]
    else
      have : n % 2 = 1 := by omega
      rw [hf_odd n this, Nat.trailingZeros_eq_zero_of_odd this, Nat.pow_zero, Nat.div_one]
  have hf_eq_n : ∀ n ∈ Finset.Icc 1 1988, f n = n ↔ (n % 2 = 1 ∧ g n = n) := by
    intro n hn
    constructor
    · intro h
      have : n % 2 = 1 := by
        by_contra h_even
        have : n = 2 * (n / 2) := by omega
        rw [this, h₃ (n / 2) (by omega)] at h
        have hf_odd_val : ∀ m > 0, (f m) % 2 = 1 := sorry
        have : (f (n / 2)) % 2 = 1 := hf_odd_val (n / 2) (by omega)
        rw [h] at this
        omega
      rw [this, hf_odd n this] at h
      exact ⟨this, h⟩
    · intro ⟨h1, h2⟩
      rw [hf_odd n h1, h2]
  let P (n : ℕ) := n % 2 = 1 ∧ g n = n
  have : (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = (Finset.filter P (Finset.Icc 1 1988)).card :=
    Finset.card_congr (fun n _ => n) (by simp; intro n hn; exact hf_eq_n n hn) (by simp) (by simp)
  rw [this]
  exact 92
