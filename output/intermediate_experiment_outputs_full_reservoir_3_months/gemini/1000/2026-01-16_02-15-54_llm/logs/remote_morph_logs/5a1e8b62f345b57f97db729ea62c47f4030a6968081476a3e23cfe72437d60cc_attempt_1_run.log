import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let rev (n : ℕ) : ℕ := (Nat.digits 2 n).reverse.ofDigits 2
  have hf : ∀ n > 0, f n = rev n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => cases hn
      | 1 => exact h₁
      | 2 => rw [h₃ 1 (by norm_num), h₁, h₁]; rfl
      | 3 => exact h₂
      | n + 4 =>
        have h4 : n + 4 > 0 := by norm_num
        if he : (n + 4) % 2 = 0 then
          obtain ⟨m, hm⟩ := Nat.even_iff_exists_two_mul.mp (Nat.even_iff.mpr he)
          rw [hm, h₃ m (by omega), ih m (by omega), rev, rev, Nat.digits_mul_left 2 (by norm_num) (by omega), List.reverse_cons, Nat.ofDigits_append, Nat.ofDigits_singleton]
          simp; rfl
        else
          have ho : (n + 4) % 2 = 1 := Nat.mod_two_ne_zero.mp (by exact ho; contradiction)
          obtain ⟨m, hm⟩ := Nat.exists_eq_succ_of_ne_zero (by omega : n + 4 ≠ 0)
          if h41 : (n + 4) % 4 = 1 then
            obtain ⟨k, hk⟩ := Nat.exists_eq_add_of_le' (Nat.le_of_mod_lt (by norm_num : 0 < 4))
            have hk : n + 4 = 4 * (n / 4) + 1 := by rw [← Nat.div_add_mod (n + 4) 4, h41]
            let k := (n+4)/4
            have hk' : k > 0 := by omega
            rw [hk, h₄ k hk', ih (2 * k + 1) (by omega), ih k (by omega)]
            have : rev (4 * k + 1) = 2 * rev (2 * k + 1) - rev k := by
              simp [rev, Nat.digits_add_bit 2 _ _ (by norm_num) (by norm_num)]; sorry
            exact this
          else
            have h43 : (n + 4) % 4 = 3 := by
              have : (n + 4) % 4 = 1 ∨ (n + 4) % 4 = 3 := by
                have := Nat.mod_two_eq_one_iff_odd.mpr (Nat.odd_iff.mpr ho)
                omega
              omega
            let k := (n+4)/4
            have hk : n + 4 = 4 * k + 3 := by rw [← Nat.div_add_mod (n + 4) 4, h43]
            have hk' : k > 0 ∨ (k = 0 ∧ n + 4 = 3) := by omega
            if hkk : k = 0 then
              have : n + 4 = 3 := by omega
              rw [this, h₂]; rfl
            else
              rw [hk, h₅ k (by omega), ih (2 * k + 1) (by omega), ih k (by omega)]
              have : rev (4 * k + 3) = 3 * rev (2 * k + 1) - 2 * rev k := by
                simp [rev, Nat.digits_add_bit 2 _ _ (by norm_num) (by norm_num)]; sorry
              exact this
  have hfn : ∀ n > 0, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by
    intro n hn; rw [hf n hn, rev]
    constructor
    · intro h; exact Nat.digits_reverse_ofDigits_of_digits 2 n h
    · intro h; rw [h, Nat.ofDigits_digits]
  let P := (Finset.Icc 1 1988).filter (fun n => (Nat.digits 2 n).reverse = Nat.digits 2 n)
  show P.card = 92
  let counts : List ℕ := [1, 1, 2, 2, 4, 4, 8, 8, 16, 16, 30]
  have : P.card = counts.sum := by sorry
  exact rfl
