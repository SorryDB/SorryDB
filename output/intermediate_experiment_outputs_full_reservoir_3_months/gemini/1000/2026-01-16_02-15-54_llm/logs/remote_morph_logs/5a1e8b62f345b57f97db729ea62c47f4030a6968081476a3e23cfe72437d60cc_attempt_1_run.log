    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := if n = 0 then 0 else Nat.bitrev n (Nat.log2 n + 1)
  have hg3 : ∀ n > 0, g (2 * n) = g n := fun n hn => by
    simp [g, hn, Nat.log2_mul_pow2 n 1 hn, Nat.bitrev_mul_pow2 n 1 (Nat.log2 n + 1)]
  have hg_odd : ∀ n > 0, g (2 * n + 1) = 2 ^ (Nat.log2 n + 1) + g n := fun n hn => by
    have hl : Nat.log2 (2 * n + 1) = Nat.log2 n + 1 := Nat.log2_succ_double n hn
    simp [g, hn, hl, Nat.bitrev, Nat.bitrev_aux, Nat.log2_succ_double]
  have hg4 : ∀ n > 0, g (4 * n + 1) = 2 * g (2 * n + 1) - g n := fun n hn => by
    have hl : Nat.log2 (4 * n + 1) = Nat.log2 n + 2 := by rw [← Nat.log2_double (2*n), Nat.log2_succ_double]; exact Nat.succ_pos _; exact Nat.mul_pos (by decide) hn
    simp [g, hn, hl, hg_odd n hn, hg_odd (2 * n) (by positivity), hg3 n hn, pow_succ, mul_add, Nat.log2_mul_pow2 n 1 hn]; omega
  have hg5 : ∀ n > 0, g (4 * n + 3) = 3 * g (2 * n + 1) - 2 * g n := fun n hn => by
    have hl : Nat.log2 (4 * n + 3) = Nat.log2 n + 2 := by rw [← Nat.log2_double (2*n+1), Nat.log2_succ_double]; exact Nat.succ_pos _; exact Nat.succ_pos _
    simp [g, hn, hl, hg_odd n hn, hg_odd (2 * n + 1) (by positivity), pow_succ, mul_add]; omega
  have hfg : ∀ n > 0, f n = g n := fun n => by
    induction n using Nat.strong_induction_on with
    | h n ih =>
      cases n with | zero => exact fun hn => (Nat.lt_irrefl 0 hn).elim | succ n =>
      match n with
      | 0 => exact h₁
      | 1 => exact h₃ 1 (by decide) ▸ h₁
      | 2 => exact h₂
