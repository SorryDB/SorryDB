import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  have hf_bin : ∀ n > 0, f n = Nat.ofDigits 2 (Nat.digits 2 n).reverse := by
    intro n hn
    induction n using Nat.strong_induction_on with | h n ih =>
    match n with
    | 0 => exact (lt_irrefl 0 hn).elim
    | 1 => rw [h₁, Nat.digits_one, List.reverse_singleton, Nat.ofDigits_singleton]
    | 2 => rw [h₃ 1 Nat.one_pos, h₁, Nat.digits_def, Nat.ofDigits_def, List.reverse_cons, List.reverse_singleton] ; rfl
    | 3 => rw [h₂, Nat.digits_def, Nat.ofDigits_def, List.reverse_cons, List.reverse_cons] ; rfl
    | n + 1 =>
      if hn_even : (n + 1) % 2 = 0 then
        obtain ⟨m, hm⟩ := Nat.exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero hn_even)
        have hm_pos : 0 < m := by subst hm ; exact Nat.pos_of_mul_pos_left hn (by linarith)
        have hnm : m < n + 1 := by subst hm ; linarith
        rw [hm, h₃ m hm_pos, ih m hnm hm_pos, Nat.digits_def, if_neg (by linarith), Nat.ofDigits_def]
        simp [hm, Nat.mul_mod_right, Nat.mul_div_right]
      else
        have hn_odd : (n + 1) % 2 = 1 := Nat.mod_two_ne_zero.mp hn_even
        if hn4 : (n + 1) % 4 = 1 then
          obtain ⟨m, hm⟩ := Nat.exists_eq_add_of_le (Nat.le_of_mod_lt (Nat.mod_lt (n + 1) (by linarith)))
          have hm4 : n + 1 = 4 * ((n + 1) / 4) + 1 := by rw [Nat.div_add_mod (n + 1) 4, hn4]
          let m := (n + 1) / 4
          have hm_pos : 0 < m := by subst hm4 ; linarith
          have hnm : m < n + 1 := by subst hm4 ; linarith
          have h2m1 : 2 * m + 1 < n + 1 := by subst hm4 ; linarith
          rw [hm4, h₄ m hm_pos, ih (2 * m + 1) h2m1 (by linarith), ih m hnm hm_pos]
          let d_m := Nat.digits 2 m
          let d_2m1 := Nat.digits 2 (2 * m + 1)
          have hd2m1 : d_2m1 = 1 :: d_m := by rw [Nat.digits_def, if_neg (by linarith)] ; simp [Nat.add_mod, Nat.mul_mod_right]
          let d_4m1 := Nat.digits 2 (4 * m + 1)
          have hd4m1 : d_4m1 = 1 :: 0 :: d_m := by rw [Nat.digits_def, if_neg (by linarith)] ; simp [Nat.add_mod, Nat.mul_mod_right, Nat.add_div, Nat.mul_div_right]
          simp [Nat.ofDigits_def, hd2m1, hd4m1, List.reverse_cons, List.foldl_append]
        else
          have hn4 : (n + 1) % 4 = 3 := by
            have : (n + 1) % 4 = 1 ∨ (n + 1) % 4 = 3 := by
              have hmod := Nat.mod_lt (n + 1) (by linarith)
              have hodd := Nat.mod_two_ne_zero.mp hn_even
              have : (n + 1) % 4 % 2 = 1 := by rw [← Nat.mod_mul_left_mod, hodd]
              interval_cases ( (n+1) % 4 ) <;> simp at this <;> contradiction
            simp [hn4] at this ; exact this
          let m := (n + 1) / 4
          have hm4 : n + 1 = 4 * m + 3 := by rw [Nat.div_add_mod (n + 1) 4, hn4]
          have hm_pos : 0 < m := by subst hm4 ; linarith
          have hnm : m < n + 1 := by subst hm4 ; linarith
          have h2m1 : 2 * m + 1 < n + 1 := by subst hm4 ; linarith
          rw [hm4, h₅ m hm_pos, ih (2 * m + 1) h2m1 (by linarith), ih m hnm hm_pos]
          let d_m := Nat.digits 2 m
          let d_2m1 := Nat.digits 2 (2 * m + 1)
          have hd2m1 : d_2m1 = 1 :: d_m := by rw [Nat.digits_def, if_neg (by linarith)] ; simp [Nat.add_mod, Nat.mul_mod_right]
          let d_4m3 := Nat.digits 2 (4 * m + 3)
          have hd4m3 : d_4m3 = 1 :: 1 :: d_m := by rw [Nat.digits_def, if_neg (by linarith)] ; simp [Nat.add_mod, Nat.mul_mod_right, Nat.add_div, Nat.mul_div_right]
          simp [Nat.ofDigits_def, hd2m1, hd4m3, List.reverse_cons, List.foldl_append]
  have hfn : ∀ n > 0, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by
    intro n hn ; rw [hf_bin n hn] ; constructor
    · intro h ; have : Nat.ofDigits 2 (Nat.digits 2 n).reverse = Nat.ofDigits 2 (Nat.digits 2 n) := by rw [h, Nat.ofDigits_digits]
      exact Nat.digits_reverse_of_digits 2 (Nat.digits 2 n) this (by linarith) (by simp; apply Nat.digits_ne_nil_iff_gt_zero.mpr hn) (by intro x hx ; exact Nat.digits_lt_base (by linarith) hx)
    · intro h ; rw [h, Nat.ofDigits_digits]
  have h_even_not : ∀ n, 0 < n → f n = n → n % 2 = 1 := by
    intro n hn h ; by_contra h_even ; have ⟨m, hm⟩ := Nat.exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero (Nat.not_odd_iff_even.mp h_even))
    have hm_pos : m > 0 := by subst hm ; exact Nat.pos_of_mul_pos_left hn (by linarith)
    have : f n = f m := by rw [hm, h₃ m hm_pos]
    rw [h, hm, this] at hm ; linarith
  exact sorry
