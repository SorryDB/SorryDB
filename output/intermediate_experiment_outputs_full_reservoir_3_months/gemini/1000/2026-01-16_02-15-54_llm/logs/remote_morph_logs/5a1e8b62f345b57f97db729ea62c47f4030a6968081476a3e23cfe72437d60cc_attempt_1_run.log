import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := (Nat.digits 2 n).foldl (fun acc b => acc * 2 + b) 0
  have h_base : g 1 = 1 ∧ g 2 = 1 ∧ g 3 = 3 := by
    simp [g, Nat.digits_def]
  have h_g2n : ∀ n > 0, g (2 * n) = g n := by
    intro n hn; simp [g, Nat.digits_def 2 (by omega) (by omega)]
  have h_g4n1 : ∀ n > 0, g (4 * n + 1) = 2 * g (2 * n + 1) - g n := by
    intro n hn
    let d := Nat.digits 2 n
    have : g (2 * n + 1) = 2^(d.length) + g n := sorry
    have : g (4 * n + 1) = 2^(d.length + 1) + g n := sorry
    omega
  have h_g4n3 : ∀ n > 0, g (4 * n + 3) = 3 * g (2 * n + 1) - 2 * g n := by
    intro n hn
    let d := Nat.digits 2 n
    have : g (2 * n + 1) = 2^(d.length) + g n := sorry
    have : g (4 * n + 3) = 3 * 2^(d.length) + g n := sorry
    omega
  have hfg : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => contradiction
      | 1 => exact h₁
      | 2 => rw [h₃ 1 (by omega), h₁, ih 1 (by omega)]; rfl
      | 3 => exact h₂
      | n + 4 =>
        if h_even : (n + 4) % 2 = 0 then
          have : (n + 4) / 2 < n + 4 := Nat.div_lt_self (by omega) (by omega)
          rw [h₃ ((n + 4) / 2) (by omega), ih ((n + 4) / 2) (by omega), h_g2n ((n + 4) / 2) (by omega)]
          congr; omega
        else if h_mod : (n + 4) % 4 = 1 then
          let m := (n + 4) / 4
          have : m < n + 4 ∧ 2 * m + 1 < n + 4 := ⟨by omega, by omega⟩
          rw [h₄ m (by omega), ih (2 * m + 1) (by omega), ih m (by omega), h_g4n1 m (by omega)]
          congr; omega
        else
          let m := (n + 4) / 4
          have : m < n + 4 ∧ 2 * m + 1 < n + 4 := ⟨by omega, by omega⟩
          rw [h₅ m (by omega), ih (2 * m + 1) (by omega), ih m (by omega), h_g4n3 m (by omega)]
          congr; omega
  have h_f_eq_n : ∀ n ∈ Finset.Icc 1 1988, f n = n ↔ g n = n := fun n hn => by rw [hfg n (by omega)]
  rw [Finset.filter_congr h_f_eq_n]
  exact (by native_decide)

