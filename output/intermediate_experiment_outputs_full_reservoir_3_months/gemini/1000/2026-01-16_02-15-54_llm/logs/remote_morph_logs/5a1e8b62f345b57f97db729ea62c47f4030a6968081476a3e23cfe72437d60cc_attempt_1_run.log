import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := if n = 0 then 0 else Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have hg : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => contradiction
      | 1 => exact h₁
      | 2 => rw [h₃ 1 (by decide), h₁, ih 1 (by decide) (by decide)]; rfl
      | 3 => exact h₂
      | n + 4 =>
        let n' := n + 4
        if h_even : n' % 2 = 0 then
          have : n' / 2 < n' ∧ n' / 2 > 0 := by omega
          rw [h₃ (n' / 2) this.2, ih (n' / 2) this.1 this.2]
          unfold g; split_ifs; omega
          have hm : n' = 2 * (n' / 2) := by omega
          rw [hm, Nat.digits_mul_pow 2 (n' / 2) 1 (by decide), Nat.reverse_append, Nat.ofDigits_append]
          simp; rfl
        else if h_mod4 : n' % 4 = 1 then
          let m := n' / 4
          have : m < n' ∧ m > 0 := by omega
          have : 2 * m + 1 < n' := by omega
          rw [h₄ m this.2, ih (2 * m + 1) this.1 (by omega), ih m this.2 this.2]
          unfold g; split_ifs; omega
          have hm : n' = 4 * m + 1 := by omega
          have hm2 : 2 * m + 1 = 2 * m + 1 := rfl
          let k := (Nat.digits 2 m).length
          have hk : Nat.digits 2 m = Nat.digits 2 m := rfl
          have : Nat.digits 2 (2 * m + 1) = Nat.digits 2 m ++ [1] := by
            rw [Nat.digits_add_mul 2 1 m (by decide) (by decide), Nat.digits_one]
          have : Nat.digits 2 (4 * m + 1) = Nat.digits 2 m ++ [0, 1] := by
            rw [Nat.digits_add_mul 2 1 (2 * m) (by decide) (by decide), Nat.digits_mul_pow 2 m 1 (by decide), Nat.digits_one]; rfl
          rw [this, Nat.reverse_append, Nat.ofDigits_append, Nat.reverse_singleton, Nat.ofDigits_singleton]
          rw [‹Nat.digits 2 (2 * m + 1) = _›, Nat.reverse_append, Nat.ofDigits_append, Nat.reverse_singleton, Nat.ofDigits_singleton]
          simp [Nat.ofDigits]; omega
        else
          have h_mod4 : n' % 4 = 3 := by omega
          let m := n' / 4
          have : m < n' ∧ m > 0 := by omega
          have : 2 * m + 1 < n' := by omega
          rw [h₅ m this.2, ih (2 * m + 1) this.1 (by omega), ih m this.2 this.2]
          unfold g; split_ifs; omega
          have hm : n' = 4 * m + 3 := by omega
          have : Nat.digits 2 (2 * m + 1) = Nat.digits 2 m ++ [1] := by
            rw [Nat.digits_add_mul 2 1 m (by decide) (by decide), Nat.digits_one]
          have : Nat.digits 2 (4 * m + 3) = Nat.digits 2 m ++ [1, 1] := by
            rw [Nat.digits_add_mul 2 3 m (by decide) (by decide)]; rfl
          rw [this, Nat.reverse_append, Nat.ofDigits_append, Nat.reverse_list_set, Nat.ofDigits_append]
          rw [‹Nat.digits 2 (2 * m + 1) = _›, Nat.reverse_append, Nat.ofDigits_append]
          simp [Nat.ofDigits]; omega
  have h_pal : (Finset.Icc 1 1988).filter (fun n => g n = n) |>.card = 92 := by native_decide
  rw [Finset.filter_congr (fun n hn => by rw [hg n (by omega)])]
  exact h_pal

