/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  have hf_odd_reverse (n : ℕ) (hn : n > 0) (h_odd : n % 2 = 1) :
    f n = (Nat.digits 2 n).reverse.foldl (λ a b => 2 * a + b) 0 := sorry
  have hf_even_reverse (n : ℕ) (hn : n > 0) : f n = f (n / 2 ^ n.trailingZeros) := by
    induction n using Nat.strong_induction_on
    case h n ih =>
      by_cases h0 : n = 0; · exfalso; exact hn h0
      by_cases he : n % 2 = 0
      · have : n / 2 < n := Nat.div_lt_self hn (by decide)
        have hnz : n / 2 > 0 := Nat.pos_of_div_pos (Nat.div_le_self n 2) (by
          rw [Nat.div_eq_iff_mul_le (by decide)]
          constructor; exact (Nat.two_le_iff.mpr he).1; exact Nat.le_refl n)
        rw [← h₃ (n / 2) hnz, ih (n / 2) this hnz]
        congr 1; rw [Nat.trailingZeros_two_mul_hom h0 he]; exact (Nat.div_eq_iff_mul_le (by decide)).mpr (by constructor; exact Nat.le_refl n; exact (Nat.div_mul_le_self n 2))
      · rw [Nat.trailingZeros_zero_of_odd (Nat.odd_iff.mpr (Nat.mod_two_ne_zero.mp he)), Nat.pow_zero, Nat.div_one]
  have hf_id (n : ℕ) (hn : 1 ≤ n) : f n = n ↔ n % 2 = 1 ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n := sorry
  let P (n : ℕ) := n % 2 = 1 ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n
  let s := Finset.Icc 1 1988
  have h_count : (s.filter P).card = 92 := by
    let counts := (List.range 11).map (λ k => (Finset.Icc (2^k) (min 1988 (2^(k+1)-1))).filter P |>.card)
    have : counts = [1, 1, 2, 2, 4, 4, 8, 8, 16, 16, 30] := sorry
    sorry
  rw [Finset.filter_congr (λ n hn => hf_id n (Finset.mem_Icc.mp hn).1)]
  exact h_count
