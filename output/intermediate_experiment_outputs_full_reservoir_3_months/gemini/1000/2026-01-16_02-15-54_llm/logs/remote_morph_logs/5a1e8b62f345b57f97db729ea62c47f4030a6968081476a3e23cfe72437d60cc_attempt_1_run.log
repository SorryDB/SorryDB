open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := if n = 0 then 0 else Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have hg_even (n : ℕ) (h : n > 0) : g (2 * n) = g n := by
    simp [g, h]; rw [Nat.digits_def' (by omega : 2 ≥ 2) (by omega : 2 * n > 0), Nat.mul_mod_right, Nat.mul_div_right _ (by omega : 2 > 0)]
    simp [Nat.reverse_cons, Nat.ofDigits_append, Nat.ofDigits_singleton]
  have hg_odd (n : ℕ) : g (2 * n + 1) = 2 ^ (Nat.digits 2 n).length + g n := by
    simp [g]; cases n with
    | zero => simp [Nat.digits, Nat.ofDigits, Nat.reverse]
    | succ n =>
      have : n + 1 > 0 := by omega
      rw [Nat.digits_def' (by omega : 2 ≥ 2) (by omega : 2 * (n + 1) + 1 > 0)]
      simp [Nat.reverse_cons, Nat.ofDigits_append, Nat.ofDigits_singleton, Nat.digits_len]
  have hf : ∀ n > 0, f n = g n := by
    intro n hn; induction n using Nat.strong_induction_on with
    | h n ih =>
      cases n with | zero => contradiction | succ n =>
      match n + 1 with
      | 1 => rw [h₁]; rfl
      | 2 => rw [h₃ 1 (by omega), h₁, hg_even 1 (by omega), hg_odd 0]; rfl
      | 3 => rw [h₂]; rfl
      | n =>
        if he : n % 2 = 0 then
          obtain ⟨m, hm⟩ := Nat.exists_eq_mul_left n (by omega : 2 ∣ n)
          rw [hm, h₃ m (by omega), ih m (by omega) (by omega), hg_even m (by omega)]
        else if ho : n % 4 = 1 then
          let m := n / 4; have hm : n = 4 * m + 1 := by rw [← Nat.div_add_mod n 4, ho]
          have : m > 0 := by omega
          rw [hm, h₄ m this, ih (2 * m + 1) (by omega) (by omega), ih m (by omega) this, hg_odd (2 * m), hg_odd m, hg_even m this, Nat.digits_len, Nat.digits_len]
          simp; omega
        else
          let m := n / 4; have hm : n = 4 * m + 3 := by rw [← Nat.div_add_mod n 4]; have : n % 4 = 3 := by omega; rw [this]
          have : m > 0 := by omega
          rw [hm, h₅ m this, ih (2 * m + 1) (by omega) (by omega), ih m (by omega) this, hg_odd (2 * m), hg_odd m, hg_even m this, Nat.digits_len, Nat.digits_len]
          simp; omega
  have hgn : ∀ n > 0, g n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by
    intro n hn; unfold g; simp [hn]
    constructor
    · intro h; have : n % 2 = 1 := by
        by_contra h2; have : 2 ∣ n := Nat.dvd_of_mod_eq_zero h2
        obtain ⟨m, hm⟩ := this; have : m > 0 := by omega
        rw [hm, hg_even m this] at h; omega
      apply Nat.digits_inj 2; rw [Nat.digits_ofDigits 2 (Nat.digits 2 n).reverse (by
        simp; cases Nat.digits 2 n; simp
        case cons hd tl => simp [Nat.reverse_cons]; rw [Nat.last_cons]; intro h2; have := Nat.digits_mod 2 n; rw [h2] at this; omega)]
      rw [h]; rfl
    · intro h; rw [← Nat.ofDigits_digits 2 n, h]
  exact (Finset.Icc 1 1988).filter_card_eq_92 (by
    intro n hn; rw [hf n (by omega), hgn n (by omega)]
    decide)

