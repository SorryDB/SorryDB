import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := if n = 0 then 0 else Nat.ofDigits 2 (Nat.digits 2 (n / 2 ^ n.countTrailing 0)).reverse
  have hg₁ : g 1 = 1 := rfl
  have hg₂ : g 3 = 3 := rfl
  have hg₃ : ∀ n > 0, g (2 * n) = g n := by
    intro n hn
    simp [g, hn]
    have : (2 * n).countTrailing 0 = n.countTrailing 0 + 1 := by
      rw [Nat.countTrailing_succ (by simp [hn]) (by decide)]
    rw [this, Nat.pow_succ, ← Nat.div_div_eq_div_mul, Nat.mul_div_cancel_left _ (by decide)]
  have hg_odd : ∀ n, g (2 * n + 1) = Nat.ofDigits 2 (Nat.digits 2 (2 * n + 1)).reverse := by
    intro n
    simp [g, Nat.countTrailing_eq_zero]
  have hg₄ : ∀ n > 0, g (4 * n + 1) = 2 * g (2 * n + 1) - g n := by
    intro n hn
    let L := (Nat.digits 2 (2 * n + 1)).length
    have hL : (Nat.digits 2 (4 * n + 1)).length = L + 1 := by
      simp [L, Nat.digits_len _ (by decide) (by omega)]
    have h_rev : Nat.ofDigits 2 (Nat.digits 2 (4 * n + 1)).reverse = 2^(L+1) + Nat.ofDigits 2 (Nat.digits 2 n).reverse := sorry
    have h_rev2 : Nat.ofDigits 2 (Nat.digits 2 (2 * n + 1)).reverse = 2^L + Nat.ofDigits 2 (Nat.digits 2 n).reverse := sorry
    sorry
  have h_fg : f = g := sorry
  have h_pal : ∀ n > 0, g n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by
    intro n hn
    simp [g, hn]
    constructor
    · intro h
      have h_odd : (Nat.ofDigits 2 (Nat.digits 2 (n / 2 ^ n.countTrailing 0)).reverse) % 2 = 1 := sorry
      have : n.countTrailing 0 = 0 := sorry
      rw [this] at h
      simp at h
      rw [← h, Nat.ofDigits_digits]
    · intro h
      have : n.countTrailing 0 = 0 := sorry
      simp [this, h, Nat.ofDigits_digits]
  have : (Finset.filter (fun n => (Nat.digits 2 n).reverse = Nat.digits 2 n) (Finset.Icc 1 1988)).card = 92 := by decide
  rw [← this, h_fg]
  apply Finset.filter_congr
  intro n hn
  exact h_pal n (Finset.mem_Icc.1 hn).1
