import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let rev (n : ℕ) : ℕ := (Nat.bits 2 n).reverse.foldl (fun a b => 2 * a + b) 0
  have h_rev_odd : ∀ n, Odd n → (n.bits 2).reverse.foldl (λ a b => 2 * a + b) 0 = Nat.ofDigits 2 (Nat.bits 2 n).reverse := fun _ _ => rfl
  have hf_rev : ∀ n > 0, Odd n → f n = rev n := by
    intro n hn odd_n
    induction n using Nat.strong_induction_on
    rename_i n ih
    rcases n with _|n; · exact (Nat.not_lt_zero 0 hn).elim
    rcases n with _|n; · exact h₁
    rcases n with _|n; · contradiction
    rcases n with _|n; · exact h₂
    have : n + 4 > 0 := Nat.zero_lt_succ _
    rcases Nat.Even_or_Odd (n + 4) with ⟨k, hk⟩ | ⟨k, hk⟩
    · contradiction
    rcases Nat.Even_or_Odd k with ⟨m, hm⟩ | ⟨m, hm⟩
    · rcases m with _|m; · contradiction
      have hn4 : n + 4 = 4 * m + 1 := by rw [hk, hm]; ring
      have hf_n4 : f (n + 4) = 2 * f (2 * m + 1) - f m := by rw [hn4]; apply h₄; omega
      sorry
    · rcases m with _|m; · have : n + 4 = 3 := by rw [hk, hm]; ring
      have hn4 : n + 4 = 4 * m + 3 := by rw [hk, hm]; ring
      have hf_n4 : f (n + 4) = 3 * f (2 * m + 1) - 2 * f m := by rw [hn4]; apply h₅; omega
      sorry
  have hf_n_odd : ∀ n ∈ Finset.Icc 1 1988, f n = n → Odd n := by
    intro n hn hfn
    rcases Nat.Even_or_Odd n with ⟨k, hk⟩ | h_odd; ·
      rcases k with _|k; · omega
      have hf_k : f (2 * (k + 1)) = f (k + 1) := h₃ (k + 1) (Nat.zero_lt_succ k)
      rw [hk, hf_k] at hfn
      have : f (k + 1) < 2 * (k + 1) := sorry
      omega
    exact h_odd
  have hf_pal : ∀ n ∈ Finset.Icc 1 1988, f n = n ↔ Odd n ∧ (Nat.bits 2 n) = (Nat.bits 2 n).reverse := by
    intro n hn; constructor
    · intro h; have ho := hf_n_odd n hn h
      refine ⟨ho, ?_⟩
      have : f n = rev n := hf_rev n (by omega) ho
      rw [h, rev] at this
      sorry
    · rintro ⟨ho, hp⟩
      have : f n = rev n := hf_rev n (by omega) ho
      rw [this, rev, ← hp]
      sorry
  let S := (Finset.Icc 1 1988).filter (fun n => Odd n ∧ (Nat.bits 2 n) = (Nat.bits 2 n).reverse)
  have : S.card = 92 := by
    let P (L : ℕ) := (Finset.Icc (2^(L-1)) (2^L-1)).filter (fun n => Odd n ∧ (Nat.bits 2 n) = (Nat.bits 2 n).reverse)
    have card_P : ∀ L, (P L).card = 2^((L-1)/2) := sorry
    have S_union : S = (Finset.filter (fun n => Odd n ∧ (Nat.bits 2 n) = (Nat.bits 2 n).reverse) (Finset.Icc 1 1023)) ∪
                 (Finset.filter (fun n => Odd n ∧ (Nat.bits 2 n) = (Nat.bits 2 n).reverse) (Finset.Icc 1024 1988)) := sorry
    have card_small : (Finset.filter (fun n => Odd n ∧ (Nat.bits 2 n) = (Nat.bits 2 n).reverse) (Finset.Icc 1 1023)).card = 62 := by
      have : (Finset.Icc 1 1023) = Finset.disjointUnion (Finset.range 10) (λ i => Finset.Icc (2^i) (2^(i+1)-1)) sorry := sorry
      sorry
    have card_large : (Finset.filter (fun n => Odd n ∧ (Nat.bits 2 n) = (Nat.bits 2 n).reverse) (Finset.Icc 1024 1988)).card = 30 := sorry
    omega
  rw [Finset.filter_congr hf_pal, this]
