        if h_even : (n + 1) % 2 = 0 then
          let m := (n + 1) / 2
          have hm : m > 0 := Nat.div_pos (by omega) (by decide)
          have hm' : m < n + 1 := Nat.div_lt_self hn' (by decide)
          rw [← Nat.mul_div_cancel' h_even, h₃ m hm, ih m hm', hg3 m hm]
        else if h_mod : (n + 1) % 4 = 1 then
          let m := (n + 1) / 4
          have hm : m > 0 := Nat.div_pos (by omega) (by decide)
          have hm' : m < n + 1 := Nat.div_lt_self hn' (by decide)
          have hm2 : 2 * m + 1 < n + 1 := by omega
          rw [← Nat.div_add_mod (n + 1) 4, h_mod, h₄ m hm, ih (2*m+1) hm2, ih m hm', hg4 m hm]
        else
          let m := (n + 1) / 4
          have h_mod' : (n + 1) % 4 = 3 := by
            have : (n + 1) % 2 = 1 := Nat.mod_two_ne_zero.mp h_even
            have : (n + 1) % 4 = 1 ∨ (n + 1) % 4 = 3 := Nat.mod_four_eq_one_or_three this
            omega
          have hm : m > 0 := Nat.div_pos (by omega) (by decide)
          have hm' : m < n + 1 := Nat.div_lt_self hn' (by decide)
          have hm2 : 2 * m + 1 < n + 1 := by omega
          rw [← Nat.div_add_mod (n + 1) 4, h_mod', h₅ m hm, ih (2*m+1) hm2, ih m hm', hg5 m hm]
  have : (Finset.filter (fun n => g n = n) (Finset.Icc 1 1988)).card = 92 := by decide
  exact (Finset.card_congr (fun n _ => n) (by simp (config := {contextual := true}) [hfg]) (by simp) (by simp [Finset.mem_filter, hfg])).symm.trans this
