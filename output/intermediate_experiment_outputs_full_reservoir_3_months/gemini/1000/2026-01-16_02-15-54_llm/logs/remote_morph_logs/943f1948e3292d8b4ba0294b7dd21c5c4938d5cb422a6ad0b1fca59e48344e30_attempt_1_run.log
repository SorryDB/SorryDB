        refine ⟨ (LY,RY,none), Y_in, .nil, ?_, ?_⟩
        · unfold exitsOf
          simp [Sequent.isLoaded]
        · unfold exitsOf at e_in
          simp [Sequent.isLoaded] at e_in
          subst e_in
          unfold PathIn.flip; simp
          unfold PathIn.flip; simp
          -- TODO: Lemma about .loc .nil and cast?
          aesop
