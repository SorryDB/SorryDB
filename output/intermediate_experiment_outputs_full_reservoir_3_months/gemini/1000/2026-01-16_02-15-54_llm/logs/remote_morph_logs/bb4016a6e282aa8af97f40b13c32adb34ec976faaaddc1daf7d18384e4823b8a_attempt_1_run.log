import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  let D (k : ℕ) := ∑ i, dist (P i) (P (i + k))
  have hp0 : 0 < (p : ℝ) := by
    rw [hp]; apply Finset.sum_pos; intro i _; apply dist_pos.2; intro hi
    have := hP i (i + 1) (by simp) (by simp); rw [hi, EuclideanGeometry.oangle_self_right] at this; simp at this
  have hd2 : 2 * (d : ℝ) = ∑ k ∈ Finset.Icc 2 (n - 2), D k := by
    rw [hd]; field_simp; rw [Finset.sum_comm]
    apply Finset.sum_congr rfl; intro i _; let S := Finset.univ \ {i - 1, i, i + 1}
    have : S = (Finset.Icc 2 (n - 2)).map ⟨(λ k => i + k), λ _ _ h => by simp [h]⟩ := by
      ext j; simp; constructor
      · intro ⟨hj1, hj2, hj3⟩; use (j - i).val; simp [hj1, hj2, hj3]
        have : (j - i).val ≥ 2 ∧ (j - i).val ≤ n - 2 := sorry
        exact this
      · intro ⟨k, hk, hj⟩; rw [← hj]; simp [hk.1, hk.2]
    rw [this, Finset.sum_map]; rfl
  have h_Dk_gt_p : ∀ k ∈ Finset.Icc 2 (n - 2), D k > p := by
    intro k hk; have : ∀ i, dist (P i) (P (i + k)) + dist (P (i + 1)) (P (i + k + 1)) > dist (P i) (P (i + 1)) + dist (P (i + k)) (P (i + k + 1)) := by
      intro i; apply EuclideanGeometry.dist_add_dist_gt_dist_add_dist_of_convex_quadrilateral
      exact ⟨P i, P (i + 1), P (i + k), P (i + k + 1), sorry⟩
    have := ∑ i, (dist (P i) (P (i + k)) + dist (P (i + 1)) (P (i + k + 1)))
    rw [Finset.sum_add_distrib, ← Finset.sum_add_distrib] at this
    have hDk : ∑ i, (dist (P i) (P (i + k)) + dist (P (i + 1)) (P (i + k + 1))) = 2 * D k := by
      rw [Finset.sum_add_distrib, ← Finset.sum_range_add_one_shift (λ i => dist (P i) (P (i + k)))]; simp [D]
    have hp2 : ∑ i, (dist (P i) (P (i + 1)) + dist (P (i + k)) (P (i + k + 1))) = 2 * p := by
      rw [Finset.sum_add_distrib, ← hp, ← Finset.sum_range_add_one_shift (λ i => dist (P i) (P (i + 1)))]; simp [hp]
    linarith [Finset.sum_lt_sum (λ i _ => this i) (Finset.univ_nonempty)]
  have h_Dk_lt_p : ∀ k ∈ Finset.Icc 2 (n - 2), D k < min k (n - k) * p := by
    intro k hk; have : ∀ i, dist (P i) (P (i + k)) < ∑ j in Finset.range k, dist (P (i + j)) (P (i + j + 1)) := by
      intro i; apply dist_le_range_sum_dist; sorry
    have h1 : D k < k * p := by
      rw [Finset.sum_mul, ← hp]; apply Finset.sum_lt_sum (λ i _ => this i); simp [Finset.sum_comm]
      intro j _; rw [← Finset.sum_range_add_one_shift (λ i => dist (P (i + j)) (P (i + j + 1)))]; simp
    have : D k = D (n - k) := by simp [D, add_comm]
    rw [this]; refine (lt_min h1 ?_).trans_le (le_refl _); have h2 : D (n - k) < (n - k) * p := sorry; exact h2
  constructor
  · rw [lt_div_iff hp0, hd2]; have : (n - 3 : ℝ) * p = ∑ k ∈ Finset.Icc 2 (n - 2), p := by simp
    rw [this]; apply Finset.sum_lt_sum; intro k hk; exact h_Dk_gt_p k hk; use 2; simp [hn]
  · rw [lt_div_iff hp0, hd2]; let Cn : ℝ := ⌊n / 2 : ℝ⌋ * ⌊(n + 1) / 2 : ℝ⌋ - 2
    have : ∑ k ∈ Finset.Icc 2 (n - 2), (min k (n - k) : ℝ) * p = Cn * p := by
      rw [← Finset.sum_mul, mul_right_inj' hp0.ne.symm]; exact sorry
    apply (Finset.sum_lt_sum (λ k hk => h_Dk_lt_p k hk) (by use 2; simp [hn])).trans_le; rw [this]
