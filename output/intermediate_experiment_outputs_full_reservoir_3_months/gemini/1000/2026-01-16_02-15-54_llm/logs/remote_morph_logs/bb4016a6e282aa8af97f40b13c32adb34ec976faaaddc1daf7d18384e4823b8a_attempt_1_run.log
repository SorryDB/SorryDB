import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp_pos : (p : ℝ) > 0 := by
    rw [hp]
    apply Finset.sum_pos
    · intro i _; apply dist_nonneg
    · use 0, Finset.mem_univ 0; apply dist_pos.mpr; intro h; have := hP 1 2 (by linarith) (by linarith); rw [h] at this; simp at this
  have h_2d : (2 * d : ℝ) = ∑ k in Finset.Icc 2 (n - 2), ∑ i : Fin n, dist (P i) (P (i + k)) := by
    rw [hd]; field_simp; rw [Finset.sum_comm]; apply Finset.sum_congr rfl
    intro i _; rw [Finset.sum_bij (λ j _ => (j - i).val)]
    · intro j hj; simp at hj; simp; constructor
      · have : j.val < i.val + n ∧ i.val < j.val + n := by constructor <;> linarith
        omega
      · have : j.val < i.val + n ∧ i.val < j.val + n := by constructor <;> linarith
        omega
    · intro j hj; simp; rfl
    · intro j1 j2 hj1 hj2 heq; simp at heq; apply Fin_val_inj_iff.mp; exact heq
    · intro k hk; use (i + k); simp at hk ⊢; constructor
      · intro h; rw [h] at hk; simp at hk; linarith
      · constructor
        · intro h; rw [h] at hk; simp at hk; linarith
        · intro h; rw [h] at hk; simp at hk; linarith
  constructor
  · rw [lt_div_iff₀ hp_pos, h_2d]
    have : ∀ k ∈ Finset.Icc 2 (n - 2), ∑ i : Fin n, dist (P i) (P (i + k)) > (p : ℝ) := by
      intro k hk; rw [hp]; have : ∀ i : Fin n, dist (P i) (P (i + k)) + dist (P (i + 1)) (P (i + k + 1)) > dist (P i) (P (i + 1)) + dist (P (i + k)) (P (i + k + 1)) := sorry
      linarith [Finset.sum_add_distrib.symm, Finset.sum_lt_sum (λ i _ => this) (by use 0; simp)]
    calc ∑ k in Finset.Icc 2 (n - 2), ∑ i : Fin n, dist (P i) (P (i + k))
      _ > ∑ k in Finset.Icc 2 (n - 2), (p : ℝ) := Finset.sum_lt_sum (λ k hk => this k hk) (by use 2; simp; linarith)
      _ = (n - 3) * p := by rw [Finset.sum_const, Finset.card_Icc]; simp; linarith
  · rw [div_lt_iff₀ hp_pos, h_2d]
    have h_Lk_up : ∀ k ∈ Finset.Icc 2 (n - 2), ∑ i : Fin n, dist (P i) (P (i + k)) < (min k (n - k) : ℝ) * p := by
      intro k hk; rw [hp]; calc ∑ i, dist (P i) (P (i + k))
        _ < ∑ i, ∑ j in Finset.range k, dist (P (i + j)) (P (i + j + 1)) := sorry
        _ = ∑ j in Finset.range k, ∑ i, dist (P (i + j)) (P (i + j + 1)) := Finset.sum_comm
        _ = k * p := by simp [hp]
      sorry
    have h_sum_min : (∑ k in Finset.Icc 2 (n - 2), (min k (n - k) : ℝ)) = ⌊(n : ℝ) / 2⌋ * ⌊((n + 1) : ℝ) / 2⌋ - 2 := sorry
    calc ∑ k in Finset.Icc 2 (n - 2), ∑ i : Fin n, dist (P i) (P (i + k))
      _ < ∑ k in Finset.Icc 2 (n - 2), (min k (n - k) : ℝ) * p := Finset.sum_lt_sum (λ k hk => h_Lk_up k hk) (by use 2; simp; linarith)
      _ = (∑ k in Finset.Icc 2 (n - 2), (min k (n - k) : ℝ)) * p := Finset.sum_mul.symm
      _ = (⌊(n : ℝ) / 2⌋ * ⌊((n + 1) : ℝ) / 2⌋ - 2) * p := by rw [h_sum_min]

