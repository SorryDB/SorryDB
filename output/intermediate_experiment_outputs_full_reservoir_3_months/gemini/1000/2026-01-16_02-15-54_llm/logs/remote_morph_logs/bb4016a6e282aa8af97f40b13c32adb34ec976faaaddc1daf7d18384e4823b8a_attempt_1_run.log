import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have h_conv : ∀ i j, i + 1 ≠ j ∧ j + 1 ≠ i ∧ i ≠ j →
      dist (P i) (P j) + dist (P (i + 1)) (P (j + 1)) > dist (P i) (P (i + 1)) + dist (P j) (P (j + 1)) := sorry
  have h_tri : ∀ i k : ℕ, 1 < k ∧ k < n → dist (P i) (P (i + k)) < ∑ j in Finset.Ico 0 k, dist (P (i + j)) (P (i + j + 1)) := sorry
  constructor
  · rw [show (2 * d : ℝ) = ∑ i, ∑ k in Finset.Ico 2 (n - 1), dist (P i) (P (i + k)) by sorry]
    have : ∑ i, ∑ k in Finset.Ico 2 (n - 1), (dist (P i) (P (i + k)) + dist (P (i + 1)) (P (i + k + 1))) >
           ∑ i, ∑ k in Finset.Ico 2 (n - 1), (dist (P i) (P (i + 1)) + dist (P (i + k)) (P (i + k + 1))) := sorry
    simp only [hp] at this
    linarith [this]
  · have h_sum : (2 * d + 2 * p : ℝ) = ∑ k in Finset.Ico 1 n, ∑ i, dist (P i) (P (i + k)) := sorry
    have h_bound : ∀ k ∈ Finset.Ico 1 n, ∑ i, dist (P i) (P (i + k)) < (min k (n - k) : ℝ) * p := sorry
    have h_final : (2 * d + 2 * p : ℝ) < (∑ k in Finset.Ico 1 n, (min k (n - k) : ℝ)) * p := by
      rw [h_sum]; exact Finset.sum_lt_sum (λ k hk => h_bound k hk) (by use 2; simp; linarith)
    have : (∑ k in Finset.Ico 1 n, (min k (n - k) : ℝ)) = ⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ := sorry
    rw [this] at h_final
    have hp_pos : (p : ℝ) > 0 := sorry
    exact (lt_div_iff hp_pos).mpr (by linarith)
