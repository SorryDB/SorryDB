/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp0 : (p : ℝ) > 0 := by
    rw [hp]
    have : ∃ i, dist (P i) (P (i + 1)) > 0 := by
      use 0
      rw [dist_pos]
      intro h; have := hP 1 0 (by linarith) (by linarith); rw [h] at this; simp at this
    apply Finset.sum_pos'; intros; apply dist_nonneg; exact this
  have hd_val : 2 * (d : ℝ) = ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) := by
    rw [hd]; linarith
  constructor
  · rw [div_gt_iff hp0, hd_val]
    let side (i : Fin n) := dist (P i) (P (i + 1))
    have h_quad : ∀ i j, j ≠ i - 1 ∧ j ≠ i ∧ j ≠ i + 1 ∧ j ≠ i + 2 →
      dist (P i) (P j) + dist (P (i + 1)) (P (j - 1)) > dist (P i) (P (i + 1)) + dist (P (j - 1)) (P j) := sorry
    have : ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) > (n - 3) * (p : ℝ) := sorry
    exact this
  · rw [lt_div_iff hp0, hd_val]
    let sum_dist (k : ℕ) := ∑ i : Fin n, dist (P i) (P (i + k))
    have h_tri : ∀ k ∈ Finset.Icc 2 (n - 2), sum_dist k < (min k (n - k)) * (p : ℝ) := by
      intro k hk
      have h1 : sum_dist k < k * p := sorry
      have h2 : sum_dist k < (n - k) * p := sorry
      rw [lt_min_iff]; exact ⟨h1, h2⟩
    have : ∑ i, ∑ j ∈ Finset.univ \ {i - 1, i, i + 1}, dist (P i) (P j) < (⌊(n:ℝ)/2⌋ * ⌊((n:ℝ)+1)/2⌋ - 2) * p := sorry
    exact this
