import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  let s (k : ℕ) := ∑ i : Fin n, dist (P i) (P (i + k))
  have hp_pos : (0 : ℝ) < p := by
    rw [hp]; apply Finset.sum_pos; intro i _; exact dist_nonneg
    use 0, Finset.mem_univ _; apply dist_pos.mpr; intro h; apply (hP 1 2 (by simp) (by simp)).ne_zero; simp [h]
  have h_2d : (2 * d : ℝ) = ∑ k in Finset.Icc 2 (n - 2), s k := by
    rw [hd]; simp [Finset.sum_comm (γ := ℝ)]; apply Finset.sum_congr rfl; intro i _; apply Finset.sum_congr
    · ext j; simp [Fin 2]; constructor
      · intro hj; use (j - i).1; refine ⟨?_, by simp⟩
        have hj' : j - i ≠ 0 ∧ j - i ≠ 1 ∧ j - i ≠ n - 1 := by
          refine ⟨by intro h; apply hj.2.1; rw [← h, add_zero]; simp, ?_⟩
          constructor
          · intro h; apply hj.2.2; rw [← h, add_assoc]; simp
          · intro h; apply hj.1; rw [← h, sub_self]; simp
        have : (j - i).1 < n := (j - i).2; omega
      · rintro ⟨k, hk, rfl⟩; simp at hk; constructor
        · intro h; rw [h] at hk; linarith [hn]
        · constructor
          · intro h; rw [h] at hk; linarith
          · intro h; rw [h] at hk; linarith
    · intro k hk; simp
  have h_sk_lt : ∀ k ∈ Finset.Icc 2 (n - 2), s k < min k (n - k) * p := by
    intro k hk; simp at hk
    have h1 : s k < k * p := by
      rw [hp, Finset.sum_mul]; apply Finset.sum_lt_sum (λ _ _ => dist_nonneg)
      use 0, Finset.mem_univ _; apply (dist_triangle_less_iff_not_collinear _ (P (0 + 1))).mpr
      · rw [Finset.sum_range_succ']; apply dist_triangle_less_iff_not_collinear; exact (hP 0 1 (by simp) (by simp)).ne_zero
      · intro h; apply (hP 1 2 (by simp) (by simp)).ne_zero; simp [h]
    have h2 : s k < (n - k) * p := by
      have : s k = s (n - k) := by apply Finset.sum_congr rfl; intro i _; simp [dist_comm]
      rw [this]; -- similar argument for s (n - k) < (n - k) * p
      sorry
    simp [h1, h2]
  have h_sk_gt : ∀ k ∈ Finset.Icc 2 (n - 2), s k > p := by
    intro k hk; rw [hp]; -- convex quadrilateral property: AC + BD > AB + CD for P_i P_{i+1} P_{i+k} P_{i+k+1}
    sorry
  constructor
  · rw [lt_div_iff hp_pos, ← h_2d, (by simp : (n : ℝ) - 3 = (Finset.Icc 2 (n - 2)).card)]
    rw [← Finset.sum_const]; apply Finset.sum_lt_sum; intro k hk; exact h_sk_gt k hk
  · rw [div_lt_iff hp_pos, ← h_2d]
    let C_n := ⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ - 2
    have : ∑ k in Finset.Icc 2 (n - 2), (min k (n - k) : ℝ) = C_n := by
      let m := n / 2
      cases n % 2 with
      | zero =>
        have hn2 : n = 2 * m := Nat.div_add_mod n 2
        have : m ≥ 2 := by linarith
        sorry
      | succ =>
        have hn2 : n = 2 * m + 1 := Nat.div_add_mod n 2
        have : m ≥ 2 := by linarith
        sorry
    rw [← this, Finset.sum_mul]; apply Finset.sum_lt_sum; intro k hk; exact h_sk_lt k hk
