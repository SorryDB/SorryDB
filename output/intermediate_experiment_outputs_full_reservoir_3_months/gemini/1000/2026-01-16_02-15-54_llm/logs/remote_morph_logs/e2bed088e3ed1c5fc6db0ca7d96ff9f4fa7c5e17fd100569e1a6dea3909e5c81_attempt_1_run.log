        Multiset.sum_map_count_dedup, Multiset.Ico, Nat.sub_sub_self (Nat.div_le_self _ _)]
      have : (Multiset.map (padicValNat p) (Multiset.Ico (P.n - P.n / P.M) P.n)).sum =
             ∑ k ∈ Finset.Ico 1 (Nat.log p P.n + 1), (Finset.filter (p ^ k ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card := by
        rw [← Nat.sum_padicValNat_eq_sum_card]
        · simp only [Multiset.Ico, Finset.sum_multiset_sum, Nat.sub_sub_self (Nat.div_le_self _ _)]; rfl
        · exact hp_prime.pos
      rw [this]
