      (Multiset.Ico (P.n - P.n / P.M) P.n))))).sum ≤ ((Multiset.join (Multiset.replicate P.M
      (Multiset.Ico (P.n - P.n / P.M) P.n))).map (fun m ↦ (m.factorization p : ℤ))).sum := by
    refine Multiset.sum_map_le_sum_map_filter _ _ (fun x _ ↦ ?_)
    exact Int.cast_nonneg.mp (by positivity)
  have h_fact : (P.n.factorial.factorization p : ℤ) ≥ 0 := by positivity
