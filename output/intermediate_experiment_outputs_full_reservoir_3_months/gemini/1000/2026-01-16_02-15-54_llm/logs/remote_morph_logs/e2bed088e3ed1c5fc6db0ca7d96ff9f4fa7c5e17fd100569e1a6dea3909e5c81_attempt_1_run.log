      set S := Multiset.join (Multiset.replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n))
      have h1 : P.initial.a ≤ S := by unfold Params.initial; exact Multiset.filter_le _ _
      have h2 : (P.initial.a.map (·.factorization p)).sum ≤ (S.map (·.factorization p)).sum :=
        Multiset.sum_map_le_sum_map _ _ (fun m _ ↦ le_refl _)
      rw [Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, nsmul_eq_mul] at h2
      refine h2.trans (mul_le_mul_of_nonneg_left ?_ (Nat.cast_nonneg _))
      rw [Multiset.Ico, ← Finset.sum_multiset_sum, ← Nat.factorization_factorial]
