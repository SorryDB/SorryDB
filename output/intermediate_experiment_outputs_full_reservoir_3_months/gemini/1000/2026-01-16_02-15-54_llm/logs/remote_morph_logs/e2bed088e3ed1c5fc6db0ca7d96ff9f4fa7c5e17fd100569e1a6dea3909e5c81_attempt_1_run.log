        sorry
      have h_fact_eq : (P.n.factorial.factorization p : ℤ) =
          ∑ k ∈ Finset.Ico 1 (Nat.log p P.n + 1), (P.n / p ^ k : ℤ) := by
        rw [factorization_def (factorial_ne_zero P.n) hp_prime, padicValNat_factorial hp_prime]
        simp only [Int.ofNat_sum, Nat.cast_id]
      have h_diff : (P.initial.balance p : ℝ) ≤ P.M * (Nat.log p P.n : ℝ) := by
        unfold Factorization.balance Factorization.sum; exact_mod_cast (by sorry : (P.initial.balance p : ℤ) ≤ P.M * (Nat.log p P.n : ℤ))
      exact h_diff.trans (by sorry)
    refine h_bal.trans ?_
    have h_log_p : Real.log p ≥ Real.log 2 := Real.log_le_log (by norm_num) (by exact_mod_cast hp_prime.two_le)
    have : Real.log 2 > 0.69 := by norm_num
