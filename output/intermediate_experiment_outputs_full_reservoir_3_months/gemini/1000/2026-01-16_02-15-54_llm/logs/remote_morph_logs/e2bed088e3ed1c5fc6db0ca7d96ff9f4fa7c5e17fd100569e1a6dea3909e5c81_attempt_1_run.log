    have h_bal_le : (Factorization.balance P.n P.initial p : ℤ) ≤
        ∑ k ∈ Finset.Ico 1 (Nat.log p P.n + 1), (P.M * ((P.n / P.M + p ^ k - 1) / p ^ k) - P.n / p ^ k) := by
