/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  refine lt_iff_le_and_ne.mpr ⟨refinement_le B hB hB' hB'', fun h ↦ ?_⟩
  rcases H with ⟨N, hN, h_ne⟩
  apply h_ne
  apply Set.Subset.antisymm
  · intro b hb
    have hbD : b ∈ D := h ▸ (by simp only [refinement, Set.mem_iUnion]; exact ⟨N, hN, hb⟩)
    by_contra hbn
    have h_dis : Disjoint b N := by
      have := D.sSupIndep.disjoint_sSup hbD (Set.singleton_subset_iff.mpr hN) (by rwa [Set.mem_singleton_iff])
      rwa [sSup_singleton] at this
    have h_le : b ≤ N := by rw [hB N hN]; exact le_sSup hb
    have h_bot : b = ⊥ := le_bot_iff.mp (disjoint_iff_inf_le.mp h_dis (le_inf le_rfl h_le))
    exact hB'' N hN (h_bot ▸ hb)
  · intro b hb
    rw [Set.mem_singleton_iff] at hb; subst b
    by_contra hbN
    have h_sub : B N hN ⊆ D := fun x hx ↦ h ▸ (by simp only [refinement, Set.mem_iUnion]; exact ⟨N, hN, hx⟩)
    have h_dis : Disjoint N (sSup (B N hN)) := D.sSupIndep.disjoint_sSup hN h_sub hbN
    have h_eq : N = ⊥ := disjoint_self.mp (hB N hN ▸ h_dis)
    exact D.not_bot_mem (h_eq ▸ hN)
