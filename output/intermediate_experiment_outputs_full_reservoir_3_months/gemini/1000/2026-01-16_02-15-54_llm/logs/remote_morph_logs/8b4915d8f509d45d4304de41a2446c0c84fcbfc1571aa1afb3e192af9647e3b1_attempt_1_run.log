section Indecomposable
variable {D : DirectSumDecomposition M}

/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `S` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D`. -/
@[nolint unusedArguments]
def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    sorry
  sSup_eq_top' := by
    sorry
  not_bot_mem' := by simp [Set.mem_iUnion, hB'']

/-- The direct sum decomposition `refinement B hB hB' hB''` is a refinement of `D`. -/
lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    refinement B hB hB' hB'' ≤ D := sorry

/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  refine ⟨refinement_le B hB hB' hB'', fun h_le ↦ ?_⟩
  rcases H with ⟨N, hN, h_ne⟩
  have h_all_N : ∀ x ∈ B N hN, x = N := fun x hx ↦ by
    have hx_ref : x ∈ refinement B hB hB' hB'' := by simp [refinement]; exact ⟨N, hN, hx⟩
    rcases h_le hx_ref with ⟨S, hS, hxS⟩
    have h_S_sub : S ⊆ {N} := fun y hy ↦ by
      have h_y_le_N : y ≤ N := (le_sSup hy).trans (hxS.symm ▸ (hB N hN).symm ▸ le_sSup hx)
      by_contra h_neq
      have h_disj : Disjoint y N := (sSupIndep_pair h_neq).mp (D.sSupIndep.mono fun z hz ↦ by
        rcases hz with (rfl | rfl); exact hS hy; exact hN)
      exact D.not_bot_mem (le_bot_iff.mp (disjoint_iff_inf_le.mp h_disj (le_inf le_rfl h_y_le_N)) ▸ hS hy)
    have h_S_ne : S ≠ ∅ := fun h_empty ↦ hB'' N hN (by rw [hxS, h_empty, sSup_empty]; exact hx)
    rw [Set.subset_singleton_iff_eq.mp h_S_sub |> (·.resolve_left h_S_ne), sSup_singleton] at hxS
    exact hxS
  exact h_ne <| Set.eq_singleton_iff_nonempty_unique_mem.mpr ⟨(by
    by_contra h_empty
    have h_N_bot : N = ⊥ := by rw [hB N hN, h_empty, sSup_empty]
    exact D.not_bot_mem (h_N_bot ▸ hN)), h_all_N⟩
