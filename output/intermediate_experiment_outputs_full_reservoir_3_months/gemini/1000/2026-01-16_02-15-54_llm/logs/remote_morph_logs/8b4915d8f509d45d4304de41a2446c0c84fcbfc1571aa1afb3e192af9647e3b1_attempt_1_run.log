/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_
  intro h_eq
  rcases H with ⟨N, hN, h_ne⟩
  have h_carrier : (refinement B hB hB' hB'').carrier = D.carrier := congr_arg carrier h_eq
  have h_sub : B N hN ⊆ D.carrier := by
    intro K hK
    have : K ∈ (refinement B hB hB' hB'').carrier :=
      Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hK⟩⟩
    rwa [h_carrier] at this
  have h_subset : B N hN ⊆ {N} := by
    intro K hK
    have hK_D : K ∈ D := h_sub hK
    rw [Set.mem_singleton_iff]
    by_contra h_ne_KN
    have h_disj : Disjoint K (sSup (D.carrier \ {K})) := D.sSupIndep K hK_D
    have h_le_sup : N ≤ sSup (D.carrier \ {K}) := le_sSup (Set.mem_diff_of_mem hN h_ne_KN.symm)
    have h_K_le_N : K ≤ N := (hB N hN).symm ▸ le_sSup hK
    have h_K_bot : K = ⊥ := le_bot_iff.mp (h_disj.le_bot (h_K_le_N.trans h_le_sup))
    exact hB'' N hN (h_K_bot ▸ hK)
  have h_not_empty : (B N hN).Nonempty := by
    by_contra h_emp
    have : N = ⊥ := (hB N hN).trans (Set.not_nonempty_iff_eq_empty.mp h_emp ▸ sSup_empty)
    exact D.not_bot_mem (this ▸ hN)
  exact h_ne ((Set.Nonempty.subset_singleton_iff h_not_empty).mp h_subset)
