/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_
  intro h_eq
  rcases H with ⟨N₀, hN₀, h_ne⟩
  apply h_ne
  have h_le : IsRefinement D (refinement B hB hB' hB'') := h_eq.symm.le
  have h_sub : B N₀ hN₀ ⊆ {N₀} := by
    intro N' hN'
    obtain ⟨S, hS, h_sSup⟩ := h_le ⟨N₀, hN₀, hN'⟩
    have h_S : S ⊆ {N₀} := by
      intro X hX
      have hX_le : X ≤ N₀ := h_sSup ▸ le_trans (le_sSup hX) (hB N₀ hN₀ ▸ le_sSup hN')
      by_contra h_neq
      have h_disj := D.sSupIndep.disjoint_sSup (hS hX) (Set.singleton_subset_iff.mpr hN₀) (by simpa)
      exact D.not_bot_mem (h_disj.eq_bot_of_le hX_le ▸ hS hX)
    rcases Set.subset_singleton_iff_eq.mp h_S with (rfl | rfl)
    · exfalso; rw [sSup_empty] at h_sSup; exact hB'' N₀ hN₀ (h_sSup ▸ hN')
    · exact h_sSup
  apply Set.Subset.antisymm h_sub
  intro X hX; rw [Set.mem_singleton_iff] at hX; subst hX
  have h_none : (B N₀ hN₀).Nonempty := by
    by_contra h_mt
    have : N₀ = ⊥ := by rw [hB N₀ hN₀, Set.not_nonempty_iff_eq_empty.mp h_mt, sSup_empty]
    exact D.not_bot_mem (this ▸ hN₀)
  obtain ⟨N', hN'⟩ := h_none
  have hN'₀ : N' = N₀ := h_sub hN'
  rwa [hN'₀] at hN'
```
