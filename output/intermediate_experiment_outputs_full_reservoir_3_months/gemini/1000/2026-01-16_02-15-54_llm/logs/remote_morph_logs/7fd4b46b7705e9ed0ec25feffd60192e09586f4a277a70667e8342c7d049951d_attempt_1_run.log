theorem mathd_numbertheory_126 (x a : ℕ) (h₀ : 0 < x ∧ 0 < a) (h₁ : Nat.gcd a 40 = x + 3)
  (h₂ : Nat.lcm a 40 = x * (x + 3))
  (h₃ : ∀ b : ℕ, 0 < b → Nat.gcd b 40 = x + 3 ∧ Nat.lcm b 40 = x * (x + 3) → a ≤ b) : a = 8 := by
  have h4 : a * 40 = x * (x + 3) ^ 2 := by
    rw [← Nat.gcd_mul_lcm a 40, h₁, h₂, mul_comm, mul_assoc, pow_two]
  have h5 : x + 3 ∣ 40 := h₁ ▸ a.gcd_dvd_right 40
  have h6 : x + 3 > 3 := Nat.add_lt_add_right h₀.1 3
  have h7 : x + 3 ∈ [4, 5, 8, 10, 20, 40] := by
    have hg : x + 3 ∣ 40 := h5
    have hg3 : x + 3 > 3 := h6
    revert hg hg3; decide
  have h8 : a = x * (x + 3) ^ 2 / 40 := by
    rw [← h4, Nat.mul_div_cancel _ (by linarith)]
  have h9 : ∀ g ∈ [4, 5, 8, 10, 20, 40], g = x + 3 → (Nat.gcd ((g - 3) * g ^ 2 / 40) 40 = g ∧ (g - 3) * g ^ 2 % 40 = 0) → (g = 8 ∨ g = 40) := by decide
  have h10 : x + 3 = 8 ∨ x + 3 = 40 := by
    apply h9 (x + 3) h7 rfl
    constructor
    · rw [← h₁, h8]; rfl
    · rw [← h4, mul_comm]; apply Nat.mul_mod_right
  rcases h10 with hx | hx
  · linarith [hx, h8]
  · exfalso
    have hx' : x = 37 := by linarith [hx]
    have ha : a = 1480 := by rw [h8, hx']; rfl
    have hb : 8 < 1480 := by decide
    have hgcd : Nat.gcd 8 40 = 37 + 3 := by decide
    have hlcm : Nat.lcm 8 40 = 37 * (37 + 3) := by decide
    have hle : a ≤ 8 := h₃ 8 (by decide) ⟨hgcd, hlcm⟩
    linarith
