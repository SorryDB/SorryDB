import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_126 (x a : ℕ) (h₀ : 0 < x ∧ 0 < a) (h₁ : Nat.gcd a 40 = x + 3)
  (h₂ : Nat.lcm a 40 = x * (x + 3))
  (h₃ : ∀ b : ℕ, 0 < b → Nat.gcd b 40 = x + 3 ∧ Nat.lcm b 40 = x * (x + 3) → a ≤ b) : a = 8 := by
  have h₄ : 40 * a = x * (x + 3) ^ 2 := by rw [← Nat.gcd_mul_lcm a 40, h₁, h₂]; ring
  have h₅ : x + 3 ∣ 40 := h₁ ▸ Nat.gcd_dvd_right a 40
  have h₆ : x + 3 ∣ a := h₁ ▸ Nat.gcd_dvd_left a 40
  obtain ⟨m, hm⟩ := h₅
  obtain ⟨k, hk⟩ := h₆
  have h₇ : m * k * (x + 3) = x := by
    rw [hk, hm, mul_assoc, mul_comm m, ← mul_assoc] at h₄
    exact Nat.eq_of_mul_eq_mul_right (Nat.add_pos_right x (by norm_num)) h₄
  have h₈ : m * (m * k + 3) = 40 := by rwa [← h₇, mul_assoc, ← mul_add, hm] at hm
  have h₉ : m ∈ divisors 40 := mem_divisors.mpr ⟨h₈, by norm_num⟩
  revert h₉ h₈ h₇ hk hm; generalize x + 3 = g; intros
  have h_gcd : gcd (k * g) 40 = g := by rwa [← hk] at h₁
  have h_lcm : lcm (k * g) 40 = (m * k * g) * g := by rwa [← hk, ← h₇] at h₂
  replace h_gcd : gcd k m = 1 := by rw [hm, gcd_mul_right] at h_gcd; exact Nat.eq_one_of_mul_eq_self_right (Nat.pos_of_mul_pos_right (hm ▸ (by norm_num : 0 < 40)) (Nat.zero_le g)) h_gcd
  fin_cases h₉
  repeat (rw [h₈] at *; contradiction)
  · rw [h₈] at *; have hk : k = 37 := by linarith; have hg : g = 40 := by linarith; rw [hg, hk] at *; have : a = 1480 := by rw [hk, hg] at hk; linarith; exfalso; exact Nat.lt_irrefl 8 (by rw [← Nat.le_antisymm (h₃ 8 (by norm_num) ⟨by norm_num, by norm_num⟩) (by linarith)] at *; linarith)
  · rw [h₈] at *; have hk : k = 1 := by linarith; have hg : g = 8 := by linarith; rw [hk, hg] at *; linarith
