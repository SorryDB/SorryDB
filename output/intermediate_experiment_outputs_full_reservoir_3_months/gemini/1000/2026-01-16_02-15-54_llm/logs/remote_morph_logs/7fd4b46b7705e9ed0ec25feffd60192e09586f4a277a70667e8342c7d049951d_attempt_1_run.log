import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_126 (x a : ℕ) (h₀ : 0 < x ∧ 0 < a) (h₁ : Nat.gcd a 40 = x + 3)
  (h₂ : Nat.lcm a 40 = x * (x + 3))
  (h₃ : ∀ b : ℕ, 0 < b → Nat.gcd b 40 = x + 3 ∧ Nat.lcm b 40 = x * (x + 3) → a ≤ b) : a = 8 := by
  have h4 : a * 40 = x * (x + 3) ^ 2 := by rw [← Nat.gcd_mul_lcm a 40, h₁, h₂]; ring
  have h5 : x + 3 ∣ 40 := h₁ ▸ Nat.gcd_dvd_right a 40
  have h6 : x + 3 ∈ [4, 5, 8, 10, 20, 40] := by
    have : x + 3 ≤ 40 := Nat.le_of_dvd (by norm_num) h5
    have : 3 < x + 3 := Nat.add_lt_add_right h₀.1 3
    exact decide
  have h7 : (x + 3) ^ 2 ∣ 40 * a := by rw [← h4, mul_comm]; apply dvd_mul_right
  have h8 : (x + 3) ∣ a := h₁ ▸ Nat.gcd_dvd_left a 40
  have h9 : (x + 3) * (40 / (x + 3)) = 40 := Nat.mul_div_cancel' h5
  have h10 : 40 / (x + 3) * a = x * (x + 3) := by
    apply mul_left_cancel₀ (by linarith [h₀.1])
    rw [← mul_assoc, h9, mul_comm, h4]
  have h11 : (40 / (x + 3)) ∣ x := by
    have : (40 / (x + 3)) * (x + 3) = 40 := by rw [mul_comm, h9]
    have : (40 / (x + 3)) ∣ x * (x + 3) := ⟨a, h10.symm⟩
    exact (Nat.dvd_mul_iff_of_rel_prime (by
      have : Nat.gcd (40 / (x + 3)) (x + 3) = Nat.gcd (x + 3) (40 / (x + 3)) := Nat.gcd_comm _ _
      rw [this, ← Nat.gcd_mul_right_left, h9, h₁, Nat.gcd_comm] at h₁
      exact Nat.gcd_one_right _) _).mp this
  revert h11 h10; revert x a; decide
