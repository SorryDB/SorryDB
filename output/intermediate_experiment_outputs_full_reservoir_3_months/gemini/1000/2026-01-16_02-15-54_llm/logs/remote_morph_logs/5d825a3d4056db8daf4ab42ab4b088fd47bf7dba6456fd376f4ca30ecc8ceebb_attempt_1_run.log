      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  obtain ⟨ιM, _, pM, hhpM, eM, _, hpsM⟩ := hMT.isPseudoIsomorphic_pi
  obtain ⟨ιN, _, pN, hhpN, eN, _, hpsN⟩ := hNT.isPseudoIsomorphic_pi
