    herbrandQuotient
    (Rep.ofAlgebraAutOnUnits' G 𝒪[K] 𝒪[L] : Rep ℤ G) = 1 := by
  exact herbrandQuotient_eq_one_of_exists_isFree_submodule_of_finite_index
    (exists_isFree_submodule_of_finite_index_units G K L)

