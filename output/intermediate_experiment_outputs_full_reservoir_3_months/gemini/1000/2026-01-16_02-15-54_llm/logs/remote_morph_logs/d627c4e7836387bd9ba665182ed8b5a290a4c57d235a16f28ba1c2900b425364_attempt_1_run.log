        · have := Error.true_of_knowldege a_knows_after_f
          simp_all [Error.resultSet, ra]
          cases C <;> simp_all [ra]
      · rw [Error.eval_dis] at a_kv_b
        rcases a_kv_b with a_knows_after_t | a_knows_after_f
        · have := Error.true_of_knowldege a_knows_after_t
