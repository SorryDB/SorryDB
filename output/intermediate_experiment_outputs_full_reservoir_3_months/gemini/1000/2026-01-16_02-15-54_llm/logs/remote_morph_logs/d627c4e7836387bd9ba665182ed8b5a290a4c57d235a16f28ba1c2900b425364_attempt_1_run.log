lemma knowledge_implies_correct_belief {n} {S : Error.Dist n} {σ : Error.OSequence n} {a b : Error.Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ Error.resultSet a S σ) := by
  intro a_kv_b
  rcases σ with ⟨σ,o⟩
  induction σ generalizing S a b
  case nil =>
    simp [Error.eval, Error.resultSet_nil] at *
    constructor
    · rcases a_kv_b with h|h <;> (by_cases b = a; · subst b; simp_all; · exfalso; have := h (S.switch b) (by simp [Error.Dist.switch]); simp [Error.Dist.switch] at this)
    · by_cases b = a; · subst b; simp_all; · simp_all
  case cons C σ IH =>
    cases ra : Error.roleOfIn a C
    case Other =>
      rw [Error.not_in_call_then_invariant_resultSet ra, Error.not_in_call_then_invariant_kv ra]
      exact IH (⁻o) a_kv_b
