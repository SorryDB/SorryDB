theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  induction h₀ with
  | refl => norm_num
  | step h ih =>
    calc
      (n + 1) ^ 2 ≤ (n + 1) * n ^ 2 := by nlinarith
      _ ≤ (n + 1) * n.factorial := Nat.mul_le_mul_left (n + 1) ih
      _ = (n + 1).factorial := rfl
