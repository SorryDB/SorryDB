import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 2
    | n + 1 =>
      let M := (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
      M.totient * (a n + 1)
  have a_ge_2 (n : ℕ) : 2 ≤ a n := by
    induction n with
    | zero => exact le_rfl
    | succ n ih =>
      change _ * (a n + 1) ≤ a (n + 1)
      exact (ih.trans (Nat.le_add_right (a n) 1)).trans (Nat.le_mul_of_pos_left (Nat.totient_pos (Finset.prod_pos (fun i _ => Nat.sub_pos_of_lt (by induction i with | zero => norm_num | succ i ih2 => exact (ih2.trans (Nat.le_succ _)).trans_lt (Nat.pow_lt_pow_of_lt (by norm_num) (Nat.lt_mul_of_pos_left (a i + 1) (Nat.totient_pos (Finset.prod_pos (fun _ _ => Nat.sub_pos_of_lt (by norm_num)))))))))))
  have a_mono : StrictMono a := strictMono_nat_of_lt_succ (fun n => by
    dsimp [a]; let M := (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
    have hM : 0 < M := Finset.prod_pos (fun i _ => Nat.sub_pos_of_lt (by norm_num [a_ge_2 i]))
    exact (Nat.lt_succ_self (a n)).trans_le (Nat.le_mul_of_pos_left (Nat.totient_pos hM)))
  use Set.range (fun n => ⟨a n, (Nat.succ_le_of_lt (a_ge_2 n)).trans_le (le_refl _)⟩)
  constructor
  · exact Set.infinite_range_of_injective a_mono.injective
  · rintro _ ⟨n, rfl⟩ _ ⟨m, rfl⟩ hnm
    wlog h : n < m
    · exact (this hnm.symm (Set.mem_range_self m) (Set.mem_range_self n) (h_mono.lt_of_le (not_lt.1 h) hnm.symm)).symm
    dsimp at *; let M := (Finset.range m).prod (fun i => 2 ^ a i - 3)
    have hMn : (2 ^ a n - 3) ∣ M := Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 h)
    have hM_odd : M % 2 = 1 := by
      rw [Finset.prod_mod]; apply Finset.prod_eq_one; intro i hi
      have h_ai := a_ge_2 i
      rw [Nat.sub_mod (by norm_num [h_ai]), Nat.pow_mod, Nat.mod_eq_zero_of_dvd (by norm_num [h_ai])]
      norm_num
    have h_am_mod : 2 ^ a m % M = 1 := by
      have h2M : Nat.Coprime 2 M := Nat.coprime_of_dvd__right (fun _ h2 => h2.symm.not_odd hM_odd)
      have : M.totient ∣ a m := by dsimp [a]; exact dvd_mul_right M.totient (a (m-1) + 1)
      obtain ⟨k, hk⟩ := this
      rw [hk, Nat.pow_mul, Nat.Modeq.pow_totient h2M]
      simp [Nat.Modeq]
    refine Nat.Coprime.coprime_mul_right_right (Nat.coprime_of_dvd_not_div (2 ^ a m - 3) M (fun p hp hM h2am3 => ?_))
    have h2p : 2 ^ a m % p = 1 % p := (h_am_mod.dvd p hM).mod_eq
    have h23p : 2 ^ a m % p = 3 % p := (Nat.mod_eq_of_dvd h2am3).symm
    have : 1 % p = 3 % p := h2p.symm.trans h23p
    have : p ∣ 2 := (Nat.Modeq.dvd (Nat.Modeq.symm this))
    exact (Nat.prime_of_mem_factors hp).two_le.not_lt (Nat.le_of_dvd (by norm_num) this.trans (hM_odd.dvd_not_two p hM))

