problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ+ := fun n ↦
    Nat.recOn n (3 : ℕ+) (fun n fn ↦
      let L := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ ((Nat.recOn i 3 (fun _ fn ↦ ⟨(Finset.range i).prod (fun j ↦ 2 ^ (some fn).val - 3).totient + 2, sorry⟩) : ℕ+).val) - 3)
      ⟨L.totient + 2, sorry⟩)
  let g : ℕ → ℕ+ := fun n ↦
    match n with
    | 0 => 3
    | n + 1 =>
      let L := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (g i).val - 3)
      ⟨L.totient + 2, sorry⟩
  have hg_val : ∀ n, (g (n + 1)).val = (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (g i).val - 3).totient + 2 := fun n ↦ rfl
  have hg_coprime : ∀ n i, i ≤ n → Nat.Coprime (2 ^ (g (n + 1)).val - 3) (2 ^ (g i).val - 3) := by
    intro n i hi
    let L := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (g i).val - 3)
    have hL : Nat.Coprime 2 L := by
      apply Nat.coprime_prod_right
      intro j _
      have : 2 ^ (g j).val - 3 % 2 = 1 := by
        match g j with | ⟨val, hv⟩ =>
        have : val ≥ 3 := by induction j <;> sorry
        sorry
      sorry
    have : 2 ^ (g (n + 1)).val - 3 ≡ 1 [MOD L] := by
      rw [hg_val]
      have : 2 ^ (L.totient + 2) = 4 * 2 ^ L.totient := by rw [pow_add, pow_two]
      rw [this]
      have : 2 ^ L.totient ≡ 1 [MOD L] := Nat.Euler_totient hL
      sorry
    sorry
  refine ⟨Set.range g, Set.infinite_range_of_injective (λ n m h ↦ sorry), λ n hn m hm hne ↦ sorry⟩
