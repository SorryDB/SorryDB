import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let g : ℕ → ℕ × ℕ := fun n ↦ n.rec (3, 5) (fun _ p ↦ (p.2.totient + 1, p.2 * (2 ^ (p.2.totient + 1) - 3)))
  let f n := (g n).1
  let x n := (g n).2
  have hx : ∀ n, x n = (Finset.range (n + 1)).prod (fun i ↦ 2 ^ f i - 3) := by
    intro n; induction n with
    | zero => rfl
    | succ n ih => simp [g, f, x, ih]; rfl
  have hf_gt_2 : ∀ n, f n ≥ 3 := by
    intro n; induction n with
    | zero => exact le_refl 3
    | succ n ih =>
      have hx_pos : x n > 0 := by rw [hx]; apply Finset.prod_pos; intro i _; apply Nat.sub_pos_of_lt; apply Nat.pow_le_pow_of_le_right (by linarith) (ih)
      have hx_ge_5 : x n ≥ 5 := by rw [hx]; exact le_trans (by linarith) (Finset.single_le_prod (fun _ _ ↦ by linarith) (Finset.self_mem_range_succ n))
      simp [f, g]; exact Nat.le_add_left 3 (Nat.totient_ge_two hx_ge_5)
  have hf_mono : StrictMono f := by
    apply strictMono_nat_of_lt_succ; intro n; simp [f, g]
    have hx_ge_5 : x n ≥ 5 := by rw [hx]; exact le_trans (by linarith) (Finset.single_le_prod (fun _ _ ↦ by linarith) (Finset.self_mem_range_succ n))
    have hxf : 2 ^ f n - 3 ∣ x n := by rw [hx]; exact Finset.dvd_prod_of_mem (fun i _ ↦ 2 ^ f i - 3) (Finset.self_mem_range_succ n)
    have hx_odd : x n % 2 = 1 := by rw [hx, Nat.prod_mod]; apply Finset.prod_induction (fun a ↦ a % 2 = 1) (by simp) (fun _ _ h1 h2 ↦ by rw [Nat.mul_mod, h1, h2]; rfl) (fun i _ ↦ by have := hf_gt_2 i; apply Nat.sub_mod_eq_of_lt; apply Nat.one_lt_pow (by linarith) (by linarith); rw [Nat.pow_mod_of_pos _ (by linarith)]; rfl)
    have h_tot_ge : x n.totient ≥ (2 ^ f n - 3).totient := Nat.totient_le_of_dvd hxf (by linarith)
    have h_tot_gt : (2 ^ f n - 3).totient > f n := by
      let m := 2 ^ f n - 3; have hm_ge_5 : m ≥ 5 := by apply Nat.sub_le_sub_right; apply Nat.pow_le_pow_of_le_right (by linarith) (hf_gt_2 n); rfl
      have hm_odd : m % 2 = 1 := by apply Nat.sub_mod_eq_of_lt; apply Nat.one_lt_pow (by linarith) (by linarith); rw [Nat.pow_mod_of_pos _ (by linarith)]; rfl
      have h_ord : Nat.orderOf 2 m > f n := by
        let d := Nat.orderOf 2 m; have h_dvd : m ∣ 2 ^ d - 1 := Nat.orderOf_dvd_of_pow_eq_one (Nat.mod_eq_one_iff_coprime (by linarith) (Nat.coprime_two_right hm_odd).symm).mp rfl
        by_contra hle; have h_le_m : 2 ^ d - 1 < m := by
          have h_le_2n : 2 ^ d - 1 ≤ 2 ^ f n - 1 := by apply Nat.sub_le_sub_right; apply Nat.pow_le_pow_of_le_right (by linarith) (not_lt.mp hle)
          exact lt_of_le_of_lt h_le_2n (Nat.sub_lt_sub_left (by linarith) (by linarith))
        exact (not_le_of_lt h_le_m) (Nat.le_of_dvd (by apply Nat.sub_pos_of_lt; apply Nat.one_lt_pow (by linarith) (by apply Nat.pos_of_gt; apply lt_of_lt_of_le (by linarith) (hf_gt_2 n))) h_dvd)
      exact lt_of_lt_of_le h_ord (Nat.orderOf_le_totient 2 (Nat.coprime_two_right hm_odd).symm)
    exact lt_trans (lt_of_lt_of_le h_tot_gt h_tot_ge) (by linarith)
  use Set.range (fun n ↦ ⟨f n, by have := hf_gt_2 n; linarith⟩)
  constructor
  · apply Set.Infinite.range; exact hf_mono.injective
  · rintro _ ⟨n, rfl⟩ _ ⟨m, rfl⟩ hnm; simp; wlog hlt : m < n
    · exact (this b ⟨n, rfl⟩ a ⟨m, rfl⟩ hnm.symm (not_lt.mp hlt).lt_of_ne (Ne.symm hnm)).symm
    have hx_odd : x (n - 1) % 2 = 1 := by rw [hx, Nat.prod_mod]; apply Finset.prod_induction (fun a ↦ a % 2 = 1) (by simp) (fun _ _ h1 h2 ↦ by rw [Nat.mul_mod, h1, h2]; rfl) (fun i _ ↦ by have := hf_gt_2 i; apply Nat.sub_mod_eq_of_lt; apply Nat.one_lt_pow (by linarith) (by linarith); rw [Nat.pow_mod_of_pos _ (by linarith)]; rfl)
    have hx_pos : x (n - 1) > 0 := by rw [hx]; apply Finset.prod_pos; intro i _; apply Nat.sub_pos_of_lt; apply Nat.pow_le_pow_of_le_right (by linarith) (hf_gt_2 i)
    have h_mod : (2 ^ f n) % x (n - 1) = 2 % x (n - 1) := by
      simp [f, g, Nat.pow_add]; rw [Nat.mul_mod, Nat.pow_totient_mod_eq_one (Nat.coprime_two_right hx_odd).symm, Nat.one_pow, Nat.mul_one]; rfl
    have h_cp : (2 ^ f n - 3).Coprime (x (n - 1)) := by
      apply Nat.Coprime.symm; apply Nat.coprime_of_mod_eq; rw [Nat.sub_mod_eq_of_lt (by linarith), h_mod];
      have hx_ge_5 : x (n - 1) ≥ 5 := by rw [hx]; apply Finset.single_le_prod (fun _ _ ↦ by linarith) (Finset.self_mem_range_succ (n-1))
      rw [Nat.mod_eq_of_lt (by linarith), Nat.coprime_comm]; apply Nat.coprime_one_left
    apply Nat.Coprime.coprime_dvd_right _ h_cp; rw [hx]; exact Finset.dvd_prod_of_mem (fun i _ ↦ 2 ^ f i - 3) (Finset.mem_range.mpr hlt)

end Imo1971P3
