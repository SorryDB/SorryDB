import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 3
    | n + 1 =>
      let M := (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
      M.totient * (a n + 1) + 2
  have a_ge_3 : ∀ n, 3 ≤ a n := by
    intro n
    induction n with
    | zero => simp [a]
    | succ n ih =>
      simp [a]
      apply Nat.le_trans ih
      apply Nat.le_add_left
  have a_mono : ∀ n, a n < a (n + 1) := by
    intro n
    simp [a]
    have hM : 0 < (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3) := by
      apply Finset.prod_pos
      intro i _
      apply Nat.pos_of_gt
      calc 3 < 2 ^ 3 - 3 := by norm_num
           _ ≤ 2 ^ a i - 3 := Nat.sub_le_sub_right (Nat.pow_le_pow_of_le_right (by norm_num) (a_ge_3 i)) 3
    have hT : 0 < (Nat.totient ((Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3))) := Nat.totient_pos.mpr hM
    calc a n < a n + 1 := Nat.lt_succ_self (a n)
         _ ≤ (a n + 1) * _ := Nat.le_mul_of_pos_right (a n + 1) hT
         _ < _ := Nat.lt_add_of_pos_right (by norm_num)
  have a_inj : Function.Injective a := StrictMono.injective a_mono
  let f : ℕ → ℕ+ := fun n => ⟨a n, Nat.pos_of_gt (a_ge_3 n)⟩
  have f_inj : Function.Injective f := fun n m h => a_inj (congr_arg PNat.val h)
  refine ⟨Set.range f, Set.infinite_range_of_injective f_inj, ?_⟩
  intro m_pos hm n_pos hn hmn
  obtain ⟨i, rfl⟩ := hm
  obtain ⟨j, rfl⟩ := hn
  wlog hij : i < j
  · apply Nat.Coprime.symm; apply this n_pos hn m_pos hm hmn.symm (Nat.lt_of_le_of_ne (Nat.le_of_not_lt hij) (fun h => hmn (by rw [h])))
  let M := (Finset.range j).prod (fun k => 2 ^ a k - 3)
  have hM_odd : M % 2 = 1 := by
    apply Finset.prod_induction (fun x => x % 2 = 1) (by simp) (fun x y hx hy => by rw [Nat.mul_mod, hx, hy]; norm_num)
    intro k _
