namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f_pair : ℕ → ℕ+ × ℕ := λ n ↦ n.rec (⟨2, by omega⟩, 1)
    (λ _ p ↦ (⟨(p.1.val + 1) * (p.2 * (2 ^ p.1.val - 3)).totient + 1, by omega⟩, p.2 * (2 ^ p.1.val - 3)))
  let f := λ n ↦ (f_pair n).1
  let L := λ n ↦ (f_pair n).2
  have f_ge_2 : ∀ n, (f n).val ≥ 2 := by
    intro n; induction' n with n ih
    · rfl
    · dsimp [f, f_pair]; omega
  have L_pos : ∀ n, L n > 0 := by
    intro n; induction' n with n ih
    · rfl
    · dsimp [L, f_pair]; refine Nat.mul_pos ih ?_; refine Nat.sub_pos_of_lt ?_; refine (Nat.lt_pow_self (by omega) (f_ge_2 n))
  have L_odd : ∀ n, L n % 2 = 1 := by
    intro n; induction' n with n ih
    · rfl
    · dsimp [L, f_pair]; rw [Nat.mul_mod, ih, Nat.one_mul, Nat.mod_mod];
      have hf := f_ge_2 n;
      match hf : (f n).val with
      | 2 => rfl
      | n' + 3 =>
        rw [pow_succ, pow_succ, pow_succ];
        repeat rw [Nat.mul_mod];
        rfl
  have f_mono : StrictMono f := by
    intro n m hnm; induction' hnm with k _ ih
    · dsimp [f, f_pair]; omega
    · trans f (k + 1); exact ih; dsimp [f, f_pair]; omega
  use Set.range f, Set.infinite_range_of_injective f_mono.injective
  rintro _ ⟨j, rfl⟩ _ ⟨i, rfl⟩ hne
  wlog hij : i < j
  · exact (this hne.symm (Set.mem_range_self i) (Set.mem_range_self j) (h_1.symm)).symm
  have hL : L j = ∏ k in Finset.range j, (2 ^ (f k).val - 3) := by
    induction' j with j ih; · rfl
    · dsimp [L, f_pair]; rw [ih, Finset.prod_range_succ]; rfl
  have h_f_j : (f j).val = ((f (j - 1)).val + 1) * (L j).totient + 1 := by
    cases' j with j; · omega
    · dsimp [f, f_pair]; rfl
  have h_coprime : (2 ^ (f j).val - 3).Coprime (L j) := by
    rw [h_f_j, pow_add, pow_mul, Nat.Coprime];
    have h2L : Nat.Coprime 2 (L j) := by rw [Nat.coprime_comm, Nat.prime_two.coprime_iff_not_dvd]; intro h; rw [← Nat.dvd_iff_mod_eq_zero, L_odd] at h; omega
    rw [Nat.ModEq.pow _ (Nat.pow_totient h2L), Nat.ModEq.pow _ (by rfl), one_pow, Nat.one_mul]
    have : 2 % L j = 2 % L j := rfl
    have h_mod : (2 ^ 1 * (2 ^ (L j).totient) ^ ((f (j - 1)).val + 1)) % L j = 2 % L j := by
      rw [Nat.ModEq.pow _ (Nat.pow_totient h2L)]; dsimp [Nat.ModEq]; rw [Nat.mul_mod, Nat.one_pow, Nat.one_mul]
    rw [Nat.mod_eq_of_lt (by have := L_pos j; have := L_odd j; omega)] at h_mod
    rw [Nat.coprime_comm, Nat.gcd_rec, h_mod];
    have : (2 - 3 : ℤ) ≡ -1 [ZMOD L j] := by omega
    have : (2 : ℕ) - 3 = 0 := by rfl
    have : (L j : ℤ) ≥ 1 := by have := L_pos j; omega
    have h_gcd : Nat.gcd (2 ^ (f j).val - 3) (L j) = Nat.gcd (L j - 1) (L j) := by
      have h_mod_j : (2 ^ (f j).val) % L j = 2 % L j := h_mod
      have : (2 ^ (f j).val - 3 : ℤ) ≡ (2 - 3 : ℤ) [ZMOD L j] := by
        apply Int.ModEq.sub_right; rw [Int.modEq_iff_nat_mod_eq_at_least_zero]; exact h_mod_j; omega; omega
      have : (2 ^ (f j).val - 3 : ℤ) ≡ -1 [ZMOD L j] := by
        apply Int.ModEq.trans this; rw [Int.modEq_iff_nat_mod_eq_at_least_zero]; rfl; omega; omega
      rw [Int.gcd_eq_nat_gcd, ← Int.gcd_rec_left, this, Int.gcd_neg_left, Int.gcd_one_left]
      rfl
    rw [h_gcd, Nat.gcd_comm, Nat.gcd_one_right]
  exact Nat.Coprime.right_forall_pos_of_coprime_prod (by intro k _; have := f_ge_2 k; omega) (by rw [← hL]; exact h_coprime) i (Finset.mem_range.mpr hij)

