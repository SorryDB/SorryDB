import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  have h_next : ∀ s : Finset ℕ+, ∃ n : ℕ+, (∀ m ∈ s, m < n) ∧ ∀ m ∈ s, (2 ^ n.val - 3).Coprime (2 ^ m.val - 3) := by
    intro s
    let M := 2 * s.prod (λ m ↦ 2 ^ m.val - 3) + 1
    have hM : Nat.Coprime 2 M := Nat.coprime_two_left (by simp [M])
    let n := (s.sup (↑)) * M.totient + M.totient + 2
    use ⟨n, by positivity⟩
    have h_gt : ∀ m ∈ s, m < n := by
      intro m hm
      have h1 : m.val ≤ s.sup (↑) := Finset.le_sup hm
      have h2 : s.sup (↑) < n := by
        simp only [n]
        linarith [Nat.totient_pos (by simp [M] : 0 < M)]
      exact h1.trans_lt h2
    refine ⟨h_gt, λ m hm ↦ ?_⟩
    have hM_dvd : (2 ^ m.val - 3) ∣ M := by
      rw [M]; apply Nat.dvd_add_right (Finset.dvd_mul_right _ (Finset.dvd_prod hm))
    apply Nat.Coprime.of_dvd_right hM_dvd
    apply Nat.Coprime.of_remainder_eq_one
    have h_pow : 2 ^ (n - 2) ≡ 1 [MOD M] := by
      have h_n2 : n - 2 = (s.sup (↑) + 1) * M.totient := by simp [n, Nat.add_mul]
      rw [h_n2, Nat.pow_mul]; apply Nat.pow_mod_eq_one
      exact Nat.pow_totient_mod_eq_one hM
    have h_mod : 2 ^ n ≡ 4 [MOD M] := by
      have h_n4 : n = (n - 2) + 2 := by simp [n]
      rw [h_n4, Nat.pow_add]; exact Nat.ModEq.mul h_pow (by simp)
    rw [Nat.mod_eq_of_lt (by linarith [Nat.totient_pos (by simp [M] : 0 < M)]), Nat.mod_eq_of_lt (by linarith)]
    apply Nat.ModEq.add_right_cancel (b := 3) (c := 1)
    · have : 2 ^ n ≥ 3 := by have : n ≥ 3 := by linarith [M.totient_pos (by simp [M] : 0 < M)]; positivity
      rw [Nat.sub_add_cancel this]; exact h_mod.trans (by simp)
  choose next h_next_mono h_next_coprime using h_next
  let f : ℕ → ℕ+ := λ n ↦ Nat.recOn n (next ∅) (λ _ an ↦ next {an})
  let rec seq : ℕ → ℕ+
    | 0 => next ∅
    | n + 1 => next (Finset.image seq (Finset.range (n + 1)))
  use Set.range seq
  constructor
  · apply Set.infinite_range_of_injective
    intro i j h
    by_contra h_ne
    wlog h_lt : i < j
    · exact this j i h.symm (Ne.symm h_ne) (h_ne.lt_or_lt.resolve_left h_lt)
    have := h_next_mono (Finset.image seq (Finset.range j)) (seq j)
    simp [seq] at this
    have h_in : seq i ∈ Finset.image seq (Finset.range j) := by
      rw [Finset.mem_image]; use i; simp [h_lt]
    linarith [this h_in]
  · apply Set.Pairwise.range
    intro i j h_ne
    wlog h_lt : i < j
    · exact (this j i h_ne.symm (h_ne.lt_or_lt.resolve_left h_lt)).symm
    have := h_next_coprime (Finset.image seq (Finset.range j)) (seq i)
    simp [seq] at this
    apply this; rw [Finset.mem_image]; use i; simp [h_lt]

