import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ+ := λ n ↦ Nat.strongRecOn n (λ n' h_rec ↦
    let s := (Finset.range n').attach.image (λ i ↦ h_rec i.1 i.2)
    let M := s.prod (λ m ↦ 2 ^ m.val - 3)
    let k := if M = 0 then 1 else M.totient
    ⟨(s.sup id + 1) * k + 1, by linarith⟩)
  use Set.range f
  constructor
  · apply Set.infinite_range_of_injective
    intro m n hmn
    wlog h : m < n
    · exact hmn.symm ▸ (this n m hmn.symm (by linarith)).symm
    have : f m < f n := by
      induction' n using Nat.strongRecOn with n' _
      simp only [f] at *
      let s := (Finset.range n').attach.image (λ i ↦ f i)
      have hm : f m ∈ s := by
        simp only [Finset.mem_image, Finset.mem_attach, true_and, Subtype.exists, Finset.mem_range]
        exact ⟨m, h, rfl⟩
      apply lt_of_le_of_lt (Finset.le_sup hm) (by simp)
    linarith
  · intro x hx y hy hxy
    obtain ⟨m, rfl⟩ := hx
    obtain ⟨n, rfl⟩ := hy
    wlog h : m < n
    · exact (this y hy x hx hxy.symm (by linarith [show n < m by linarith [Nat.lt_or_gt_of_ne (show m ≠ n by intro h; exact hxy (h ▸ rfl))]])).symm
    simp only [f] at *
    let s := (Finset.range n).attach.image (λ i ↦ f i)
    let M := s.prod (λ m ↦ 2 ^ m.val - 3)
    have hm : f m ∈ s := by
      simp only [Finset.mem_image, Finset.mem_attach, true_and, Subtype.exists, Finset.mem_range]
      exact ⟨m, h, rfl⟩
    have hM_dvd : (2 ^ (f m).val - 3) ∣ M := Finset.dvd_prod_of_mem (λ m ↦ 2 ^ m.val - 3) hm
    have hM_odd : M % 2 = 1 := by
      apply Finset.prod_induction (λ x ↦ x % 2 = 1) (by simp)
      · intro a b ha hb; rw [Nat.mul_mod, ha, hb]; rfl
      · intro k hk; obtain ⟨j, _, rfl⟩ := Finset.mem_image.1 hk; 
        have : (f j).val ≥ 3 := by
          induction' j using Nat.strongRecOn with j' _
          simp only [f]; apply Nat.le_trans (by linarith) (Nat.le_add_left _ _)
        have : 2 ^ (f j).val % 2 = 0 := Nat.pow_mod_even (f j).val (by linarith)
        rw [Nat.sub_mod, this]; rfl; linarith [Nat.one_le_pow (f j).val 2 (by linarith)]
    have h_coprime_M : Nat.Coprime (2 ^ (f n).val - 3) M := by
      have : 2 ^ (f n).val ≡ 2 [MOD M] := by
        let k := if M = 0 then 1 else M.totient
        have : M > 0 := Nat.pos_of_ne_zero (by intro h; rw [h] at hM_odd; linarith)
        have h_pow : 2 ^ k ≡ 1 [MOD M] := by
          simp only [k, this, ite_false]; apply Nat.pow_totient_mod_eq_one
          exact (Nat.coprime_bases_iff (by linarith)).2 (Nat.coprime_one_right 2) |>.mpr hM_odd
        rw [show (f n).val = (Finset.sup s id + 1) * k + 1 by rfl, pow_succ, Nat.pow_mul]
        apply Nat.ModEq.mul_right; apply Nat.ModEq.pow; exact h_pow
      have : (2 ^ (f n).val - 3 : ℤ) ≡ 2 - 3 [ZMOD M] := by
        apply Int.ModEq.sub (Int.ModEq.coe_nat_modEq.2 this)
        exact Int.ModEq.refl 3
      have : (2 ^ (f n).val - 3 : ℤ) ≡ -1 [ZMOD M] := this
      apply Nat.coprime_of_dvd_of_coprime (m := M)
      · rfl
      · rw [Nat.coprime_comm, Nat.Coprime]; exact Int.coe_nat_eq_one.1 (Int.gcd_eq_one_iff_coprime.2 (Int.coprime_minus_left.1 (Int.ModEq.coprime this (Int.coprime_one_left M))))
    exact Nat.Coprime.coprime_dvd_right hM_dvd h_coprime_M

end Imo1971P3

