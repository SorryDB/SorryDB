import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ+
    | 0 => 2
    | n + 1 =>
      let s := (List.range (n + 1)).map f
      let L := (s.map (fun m => 2 ^ m.val - 3)).prod
      ⟨L.eulerPhi * (f n).val + 2, by apply Nat.succ_pos⟩
  have hf_mono : ∀ n, f n < f (n + 1) := by
    intro n
    let s := (List.range (n + 1)).map f
    let L := (s.map (fun m => 2 ^ m.val - 3)).prod
    have hL : L > 0 := by
      apply List.prod_pos
      intro x hx
      obtain ⟨m, _, rfl⟩ := List.mem_map.1 hx
      obtain ⟨i, _, rfl⟩ := List.mem_map.1 hx
      have : f i ≥ 2 := by
        induction i with
        | zero => rfl
        | succ i ih => exact (Nat.le_of_lt (fn_pos i)).trans (Nat.le_add_right _ _)
      exact Nat.sub_pos_of_lt (by gd)
    have hphi : L.eulerPhi > 0 := Nat.eulerPhi_pos hL
    calc f n < f n + 2 := Nat.lt_add_of_pos_right (by decide)
           _ ≤ L.eulerPhi * f n + 2 := Nat.add_le_add_right (Nat.le_mul_of_pos_left _ hphi) 2
  have f_injective : Function.Injective f := (StrictMono.id.hf_mono hf_mono).injective
  exists Set.range f
  constructor
  · exact Set.infinite_range_of_injective f_injective
  · intro x hx y hy hne
    obtain ⟨m, rfl⟩ := hx
    obtain ⟨n, rfl⟩ := hy
    wlog hmn : m < n
    · exact (this y hy x hx hne.symm (hne.lt_or_lt.resolve_left hmn)).symm
    let s_n := (List.range n).map f
    let L_n := (s_n.map (fun m => 2 ^ m.val - 3)).prod
    have hLn : 2 ^ (f n).val - 3 ≡ 1 [MOD L_n] := by
      have : f n = L_n.eulerPhi * (f (n - 1)).val + 2 := by
        cases n with
        | zero => exact (Nat.not_lt_zero m hmn).elim
        | succ n => rfl
      rw [this]
      have hL_pos : L_n > 0 := by
        apply List.prod_pos; intro x hx
        obtain ⟨m', hm', rfl⟩ := List.mem_map.1 hx
        obtain ⟨i, hi, rfl⟩ := List.mem_map.1 hm'
        have : f i ≥ 2 := by
          induction i with | zero => rfl | succ i ih => exact (Nat.le_of_lt (hf_mono i)).trans (Nat.le_add_right _ _)
        exact Nat.sub_pos_of_lt (by gd)
      have hL_odd : L_n % 2 = 1 := by
        apply List.prod_induction (λ x => x % 2 = 1) 1 (· * ·) (by decide)
        intro x hx
        obtain ⟨m', hm', rfl⟩ := List.mem_map.1 hx
        obtain ⟨i, hi, rfl⟩ := List.mem_map.1 hm'
        have : f i ≥ 2 := by
          induction i with | zero => rfl | succ i ih => exact (Nat.le_of_lt (hf_mono i)).trans (Nat.le_add_right _ _)
        rw [Nat.sub_mod (by gd), Nat.pow_mod, ←Nat.one_mod]
        simp
      have : Nat.Coprime 2 L_n := (Nat.coprime_two_right.2 hL_odd)
      calc 2 ^ (L_n.eulerPhi * (f (n - 1)).val + 2) - 3
           ≡ (2 ^ L_n.eulerPhi) ^ (f (n - 1)).val * 2 ^ 2 - 3 [MOD L_n] := by
             apply Nat.ModEq.sub_right; apply Nat.ModEq.pow; rw [pow_add, pow_mul]; rfl
         _ ≡ 1 ^ (f (n - 1)).val * 4 - 3 [MOD L_n] := by
             apply Nat.ModEq.sub_right; apply Nat.ModEq.mul_right; apply Nat.ModEq.pow
             exact Nat.ModEq.pow_eulerPhi_eq_one this
         _ ≡ 4 - 3 [MOD L_n] := by rw [one_pow, one_mul]; rfl
         _ ≡ 1 [MOD L_n] := rfl
    have hx_div : (2 ^ (f m).val - 3) ∣ L_n := by
      apply List.dvd_prod; apply List.mem_map.2; exists (f m); constructor
      · apply List.mem_map.2; exists m; exact ⟨List.mem_range.2 hmn, rfl⟩
      · rfl
    exact Nat.Coprime.symm (Nat.coprime_one_left _).modulo (Nat.ModEq.symm (hLn.mono hx_div))

end Imo1971P3
```
