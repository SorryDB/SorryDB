import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  have h (s : Finset ℕ+) : ∃ m : ℕ+, (∀ n ∈ s, n < m) ∧ ∀ n ∈ s, (2 ^ n.val - 3).Coprime (2 ^ m.val - 3) := by
    let s' := s.filter (·.val ≥ 2)
    let M := s'.prod (fun n ↦ 2 ^ n.val - 3)
    let m_val := if s'.Nonempty then (s.max.map (·.val)).getD 0 + M.totient + 2 else (s.max.map (·.val)).getD 0 + 2
    let m : ℕ+ := ⟨m_val, by omega⟩
    use m
    constructor
    · intro n hn; exact (Finset.le_max hn).trans_lt (by omega)
    · intro n hn
      by_cases h2 : n.val < 2
      · have : 2 ^ n.val - 3 = 0 := by clear m; rcases n with ⟨n, hn⟩; rcases n with _|n <;> [omega; rcases n with _|n <;> omega]
        simp [this]
        have : m.val ≥ 2 := by omega
        rcases m with ⟨m, hm⟩
        rcases m with _|m; omega; rcases m with _|m; omega
        repeat (rw [Nat.pow_succ])
        omega
      · have hM : M > 0 := Finset.prod_pos (fun n hn ↦ by apply Nat.pos_of_neq_zero; apply Nat.ne_of_gt; rw [Finset.mem_filter] at hn; exact Nat.one_lt_pow hn.2 (by omega))
        have hOdd : M % 2 = 1 := by
          apply Finset.prod_induction (· % 2 = 1) <;> intros <;> try simp
          · rfl
          · rw [Nat.mul_mod, h_1, h_2]; rfl
          · rw [Finset.mem_filter] at H; apply Nat.sub_mod_eq_of_le; exact (Nat.one_lt_pow H.2 (by omega)).le; simp [Nat.pow_succ]
        have : 2 ^ m.val ≡ 4 [MOD M] := by
          have : 2 ^ m.val = 2 ^ ((m.val - 2 - M.totient) + M.totient + 2) := by congr; omega
          rw [this, Nat.pow_add, Nat.pow_add]
          apply Nat.ModEq.mul
          · rw [Nat.pow_mul]; have := Nat.ModEq.pow (m.val - 2 - M.totient) (Nat.Euler_theorem hOdd.symm hOdd.symm); simp at this; exact this
          · rfl
        have : (2 ^ m.val - 3) ≡ 1 [MOD M] := by
          apply Nat.ModEq.add_right_neg (s := 3) (t := 3)
          rw [Nat.sub_add_cancel (by apply Nat.one_le_pow; omega)]
          exact this.trans (by rw [Nat.mod_eq_of_lt (by omega)])
        exact Nat.Coprime.symm (Nat.coprime_of_dvd_of_coprime (Finset.dvd_prod (Finset.mem_filter.mpr ⟨hn, by omega⟩)) (Nat.modEq_one_iff_coprime hM).mp this)
  choose g hg using h
  let f : ℕ → ℕ+ := fun n ↦ Nat.recOn n (g ∅) (fun _ an ↦ g (an.toFinset))
  let a : ℕ → ℕ+ := fun n ↦ (Nat.recOn n [f 0] (fun _ l ↦ l ++ [g l.toFinset])).getLast (by simp)
  set s := Set.range a
  use s
  have ha : ∀ n, a n = (Nat.recOn n [f 0] (fun _ l ↦ l ++ [g l.toFinset])).getLast (by simp) := fun n ↦ rfl
  have h_val : ∀ n, a n = g ((List.range n).map a).toFinset := by
    intro n; rcases n with _|n <;> simp [ha]
    · rfl
    · rcases n with _|n <;> simp [ha, List.toFinset_append]
  have h_mono : ∀ n, ∀ i < n, a i < a n := by
    intro n; induction n with | zero => intro i hi; omega | succ n ih =>
      intro i hi; rw [h_val]; rw [Nat.lt_succ_iff_lt_or_eq] at hi; rcases hi with hi | rfl
      · exact (ih i hi).trans ((hg _).1 (by simp; exact ⟨i, hi, rfl⟩))
      · exact (hg _).1 (by simp; exact ⟨n, rfl, rfl⟩)
  constructor
  · apply Set.infinite_range_of_injective; intro i j h; by_contra hne
    wlog hij : i < j; · exact this j i h.symm (Ne.symm hne) (by omega)
    exact (h_mono j i hij).ne h
  · intro n hn m hm hne; rw [Set.mem_range] at hn hm; obtain ⟨i, rfl⟩ := hn; obtain ⟨j, rfl⟩ := hm
    wlog hij : i < j; · exact (this m n hm hn hne.symm (by omega)).symm
    rw [h_val j]; exact (hg _).2 (a i) (by simp; exact ⟨i, hij, rfl⟩)
