/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ+ := fun n ↦ n.recOn 3 (fun _ fn ↦
    let s := (Finset.range (n + 1)).image (fun i ↦ i.recOn 3 (fun _ fn ↦ fn)) -- dummy placeholder
    -- Construction: f(n+1) = phi(3 * prod_{i=0}^n (2^f(i) - 3)) + 1
    -- For simplicity, we define it recursively using a state that carries the product
    (n.recOn (3, 5) (fun _ (an, Pn) ↦
      let a_next := (3 * Pn).phi + 1
      (⟨a_next, Nat.succ_pos _⟩, Pn * (2 ^ a_next - 3)))).1)
  -- For a concise proof, let's build the sequence directly
  let g : ℕ → ℕ+ × ℕ := fun n ↦ n.recOn (3, 5) (fun _ p ↦
    let a_next := (3 * p.2).phi + 1
    (⟨a_next, Nat.succ_pos _⟩, p.2 * (2 ^ a_next - 3)))
  let a (n : ℕ) : ℕ+ := (g n).1
  let P (n : ℕ) : ℕ := (g n).2
  use Set.range a
  constructor
  · apply Set.infinite_range_of_injective
    intro m n hmn
    by_contra h_neq
    wlog hlt : m < n
    · exact this a P n m hmn.symm (h_neq.symm) (Nat.lt_of_le_of_ne (Nat.not_lt.1 hlt) hmn.symm)
    have h_coprime : ∀ i < n, ∀ j < i, (2 ^ (a i : ℕ) - 3).Coprime (2 ^ (a j : ℕ) - 3) := sorry
    have h_val : ∀ i, (a i : ℕ) ≥ 3 := sorry
    -- Detailed proof of pairwise coprimality and injectivity would go here
    sorry
  · rw [Set.pairwise_range_iff]
    intro m n hmn
    wlog hlt : m < n
    · exact (this hmn.symm (Nat.lt_of_le_of_ne (Nat.not_lt.1 hlt) hmn.symm)).symm
    -- Proof: 2^(a n) - 3 = 2^(phi(3*P(n-1))+1) - 3 ≡ 2*1 - 3 = -1 mod P(n-1)
    -- Since (2^(a m) - 3) divides P(n-1), 2^(a n) - 3 ≡ -1 mod (2^(a m) - 3)
    -- So they are coprime.
    sorry

