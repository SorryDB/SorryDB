import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ × ℕ := fun n ↦ n.rec (3, 5) (fun _ p ↦ (p.2.totient + 2, p.2 * (2 ^ (p.2.totient + 2) - 3)))
  let x n := (f n).1
  let g n := (f n).2
  have hg_pos n : 0 < g n := by
    induction n with
    | zero => exact Nat.zero_lt_succ 4
    | succ n ih => dsimp [g, f]; apply Nat.mul_pos ih; linarith [Nat.pow_ge_self_of_ge (show 2 ≤ 2 from rfl) (show 2 ≤ x (n + 1) from (by induction n <;> (dsimp [x, f]; linarith [Nat.totient_pos ih])))]
  have hx_coprime : ∀ n, ∀ m < n, Nat.Coprime (2 ^ x n - 3) (2 ^ x m - 3) := by
    intro n; induction n with
    | zero => intro m hm; exfalso; exact Nat.not_lt_zero m hm
    | succ n ih =>
      intro m hm
      have hx_next : x (n + 1) = (g n).totient + 2 := rfl
      have hg_next : g n = ∏ i in Finset.range (n + 1), (2 ^ x i - 3) := by
        induction n with
        | zero => simp [g, f, x]
        | succ n ih2 => rw [Finset.prod_range_succ, ← ih2]; rfl
      have h_mod : 2 ^ x (n + 1) ≡ 4 [MOD g n] := by
        rw [hx_next, Nat.pow_add]
        apply Nat.ModEq.mul_right
        apply Nat.ModEq.pow_totient
        apply Nat.coprime_ord_of_pos_left (Nat.zero_lt_succ 1)
        have hg_odd : g n % 2 = 1 := by
          rw [hg_next, Nat.prod_mod, Finset.prod_congr rfl (fun i _ ↦ (by
            have : 2 ≤ x i := by induction i <;> (dsimp [x, f]; linarith [Nat.totient_pos (hg_pos _)])
            rw [Nat.sub_mod, Nat.pow_mod, (show 2 % 2 = 0 from rfl)]
            simp; rfl))]
          simp
        exact Nat.coprime_of_lcm_eq_mul (by rw [Nat.gcd_rec]; symm; exact hg_odd)
      have h_coprime_gn : Nat.Coprime (2 ^ x (n + 1) - 3) (g n) := by
        apply Nat.Coprime.modEq (h_mod.sub_right (show 3 ≤ 4 from (by linarith)))
        rw [Nat.sub_mod]; simp [Nat.Coprime]
      cases Nat.lt_succ_iff_lt_or_eq.1 hm with
      | inl h_lt =>
        apply Nat.Coprime.coprime_div_right (ih m h_lt)
        rw [hg_next, Finset.prod_range_succ]
        apply Nat.dvd_mul_right
      | inr h_eq =>
        rw [h_eq, hg_next, Finset.prod_range_succ]
        exact Nat.Coprime.coprime_mul_right_inv h_coprime_gn
  let s : Set ℕ+ := Set.range (λ n ↦ ⟨x n, by induction n <;> (dsimp [x, f]; linarith [Nat.totient_pos (hg_pos _)])⟩)
  use s
  constructor
  · apply Set.infinite_range_of_injective
    intro m n hmn
    rcases Nat.lt_trichotomy m n with h | h | h
    · have := hx_coprime n m h; rw [hmn] at this; simp [Nat.Coprime] at this; linarith [this, (by induction m <;> (dsimp [x, f]; linarith [Nat.totient_pos (hg_pos _)]))]
    · exact h
    · have := hx_coprime m n h; rw [hmn] at this; simp [Nat.Coprime] at this; linarith [this, (by induction n <;> (dsimp [x, f]; linarith [Nat.totient_pos (hg_pos _)]))]
  · rintros ⟨a, ha⟩ ⟨m, rfl⟩ ⟨b, hb⟩ ⟨n, rfl⟩ hne
    rcases Nat.lt_trichotomy m n with h | h | h
    · exact hx_coprime n m h
    · exfalso; apply hne; rw [h]
    · symm; exact hx_coprime m n h

end Imo1971P3
