import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ := fun n ↦ Nat.strongRecOn n (fun n g ↦
    if h : n = 0 then 3 else
    let M := (Finset.range n).prod (fun i ↦ 2 ^ g i (Finset.mem_range.2 h) - 3)
    (g (n - 1) (by omega)) * Nat.totient M + 2)
  have f_pos (n : ℕ) : f n > 0 := by
    induction n using Nat.strong_induction_on with | h n ih =>
    rw [f]; split_ifs; { norm_num }; { omega }
  let nplus (n : ℕ) : ℕ+ := ⟨f n, f_pos n⟩
  use Set.range nplus
  constructor
  · apply Set.range_injective.infinite
    intro i j hij
    wlog h_le : i ≤ j
    · exact (this hij.symm (le_of_not_le h_le)).symm
    by_contra h_neq
    obtain rfl | h_lt := h_le.eq_or_lt; { exact h_neq rfl }
    have h_f_strict : ∀ k, f (k + 1) > f k := by
      intro k
      rw [f]
      set M := (Finset.range (k + 1)).prod (fun i ↦ 2 ^ f i - 3)
      have hM : M > 0 := by
        apply Finset.prod_pos; intro i _
        have : f i ≥ 2 := by
          induction i using Nat.strong_induction_on with | h i ih =>
          rw [f]; split_ifs; { norm_num }; { omega }
        omega
      linarith [Nat.totient_pos hM]
    have : f i < f j := by
      induction h_lt with | refl => exact h_f_strict i | step _ ih => exact ih.trans (h_f_strict _)
    omega
  · intro x hx y hy hxy
    obtain ⟨i, rfl⟩ := hx
    obtain ⟨j, rfl⟩ := hy
    wlog h_lt : i < j
    · rw [Nat.Coprime.symm]; apply this hy hx hxy.symm (Nat.lt_of_le_of_ne (le_of_not_gt h_lt) (by intro h; apply hxy; rw [h]))
    set Mi := (Finset.range j).prod (fun k ↦ 2 ^ f k - 3)
    have h_f_j : f j = f (j - 1) * Nat.totient Mi + 2 := by
      have hj : j ≠ 0 := by omega
      rw [f, Nat.strongRecOn_beta]; simp [hj]
    have h_dvd : (2 ^ f i - 3) ∣ Mi := Finset.dvd_prod_of_mem _ (Finset.mem_range.2 h_lt)
    have h_mod : (2 ^ f j - 3) % Mi = 1 % Mi := by
      have h_gcd : Nat.Coprime 2 Mi := by
        apply Nat.coprime_prod_right; intro k _
        have : f k ≥ 2 := by
          induction k using Nat.strong_induction_on with | h k ih =>
          rw [f]; split_ifs; { norm_num }; { omega }
        have : 2 ^ f k - 3 > 0 := by omega
        rw [Nat.coprime_odd_right]; use 2 ^ (f k - 1) - 2; omega
      rw [h_f_j, Nat.pow_add, Nat.pow_mul, ← Nat.ModEq]
      have : (2 ^ Nat.totient Mi) % Mi = 1 % Mi := by
        cases Nat.eq_zero_or_pos (Nat.totient Mi) with
        | h₁ h_tot => rw [h_tot]; norm_num
        | h₂ h_tot => rw [Nat.pow_totient_mod_eq_one h_gcd]; exact Nat.totient_pos_iff.1 h_tot
      calc
        2 ^ (f (j - 1) * Nat.totient Mi) * 2 ^ 2 - 3 ≡ 1 ^ f (j - 1) * 4 - 3 [MOD Mi] := by rel [this]
        _ ≡ 1 [MOD Mi] := by norm_num
    have h_coprime : Nat.Coprime (2 ^ f j - 3) Mi := by
      rw [Nat.coprime_iff_gcd_eq_one, Nat.gcd_rec, h_mod]
      apply Nat.gcd_one_left
    apply Nat.coprime_of_dvd_right h_dvd h_coprime

end Imo1971P3

