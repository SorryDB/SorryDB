    let L := (s.map (fun m => 2 ^ m.val - 3)).prod
    have hL : L > 0 := by
      apply List.prod_pos
      intro x hx
      obtain ⟨m, _, rfl⟩ := List.mem_map.1 hx
      obtain ⟨i, _, rfl⟩ := List.mem_map.1 hx
      have : f i ≥ 2 := by
        induction i with
        | zero => rfl
        | succ i ih => exact (Nat.le_of_lt (fn_pos i)).trans (Nat.le_add_right _ _)
      exact Nat.sub_pos_of_lt (by gd)
    have hphi : L.eulerPhi > 0 := Nat.eulerPhi_pos hL
    calc f n < f n + 2 := Nat.lt_add_of_pos_right (by decide)
           _ ≤ L.eulerPhi * f n + 2 := Nat.add_le_add_right (Nat.le_mul_of_pos_left _ hphi) 2
  have f_injective : Function.Injective f := (StrictMono.id.hf_mono hf_mono).injective
  exists Set.range f
  constructor
  · exact Set.infinite_range_of_injective f_injective
