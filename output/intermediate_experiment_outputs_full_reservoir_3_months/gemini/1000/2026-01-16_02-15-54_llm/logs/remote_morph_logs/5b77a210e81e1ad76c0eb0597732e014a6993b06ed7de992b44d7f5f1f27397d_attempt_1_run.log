import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ+ := fun n ↦ Nat.recOn n (3 : ℕ+) (fun n an ↦
    let s_n := (Finset.range (n + 1)).image (fun i ↦ (Nat.recOn i (3 : ℕ+) (fun _ _ ↦ (3 : ℕ+)))) -- placeholder
    (3 : ℕ+)) -- placeholder
  let s_next (L : Finset ℕ+) : ℕ+ :=
    let P := L.prod (fun m ↦ 2 ^ m.val - 3)
    let M := L.fold (fun a b ↦ max a b.val) 0
    let k := if P % 2 = 1 then Nat.totient P else 1
    ⟨(M + 1) * k, by
      have : M + 1 ≥ 1 := Nat.le_add_left 1 M
      have : k ≥ 1 := by dsimp [k]; split <;> (try linarith); exact Nat.totient_pos (by
        by_contra h; subst h; simp at *)
      exact Nat.mul_pos (by linarith) (by linarith)⟩
  let g : ℕ → ℕ+ := fun n ↦ Nat.recOn n (3 : ℕ+) (fun n gn ↦
    let s_n := (Finset.range (n + 1)).image (fun i ↦ (Nat.recOn i (3 : ℕ+) (fun _ prev ↦ prev))) -- placeholder
    s_next (Finset.image (fun i ↦ (Nat.recOn i (3 : ℕ+) (fun _ prev ↦ prev))) (Finset.range (n + 1)))) -- incorrect
  have h_exists : ∃ f : ℕ → ℕ+, StrictMono f ∧ ∀ n m, m < n → Nat.Coprime (2 ^ (f n).val - 3) (2 ^ (f m).val - 3) := by
    let f : ℕ → ℕ+ := fun n ↦ Nat.recOn n (3 : ℕ+) (fun n an ↦
      let L := (Finset.range (n + 1)).image (fun i ↦ (Nat.recOn i (3 : ℕ+) (fun _ _ ↦ (3 : ℕ+)))) -- this is not correct
      ⟨3, by simp⟩)
    sorry
  obtain ⟨f, hf_mono, hf_coprime⟩ := h_exists
  use Set.range f
  constructor
  · exact Set.infinite_range_of_injective hf_mono.injective
  · exact Set.pairwise_range_iff.mpr (fun n m h ↦ (Nat.Coprime.symm (hf_coprime (max n m) (min n m) (by
      rw [max_def]; split_ifs with h_1; · exfalso; exact h (by aesop); · exact Nat.lt_max_of_lt_right (by aesop)))))
