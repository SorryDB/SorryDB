import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ
    | 0 => 3
    | n + 1 => ((Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3)).totient * f n + 1
  have f_pos : ∀ n, 0 < f n := by
    intro n; induction n with | zero => simp [f] | succ n ih => dsimp [f]; linarith
  have f_ge_3 : ∀ n, 3 ≤ f n := by
    intro n; induction n with | zero => simp [f] | succ n ih => dsimp [f]; have := f_pos n; linarith
  have f_inc : ∀ n, f n < f (n + 1) := by
    intro n; dsimp [f]
    have hP : 0 < ((Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3)).totient := by
      apply Nat.totient_pos; apply Finset.prod_pos; intro i _; apply Nat.pos_of_gt
      apply Nat.sub_pos_of_lt; apply Nat.one_lt_pow <;> linarith [f_ge_3 i]
    nlinarith [f_pos n]
  use Set.range (fun n => ⟨f n, f_pos n⟩)
  constructor
  · apply Set.range_infinite; exact (StrictMono.injective (fun _ _ => f_inc)).comp PNat.mk_injective
  · rw [Set.pairwise_range]
    intro i j hij
    wlog h : i < j
    · exact (this j i hij.symm (hij.lt_or_lt.resolve_left h)).symm
    let P := (Finset.range j).prod (fun k => 2 ^ f k - 3)
    have hP : P > 1 := by
      have : 5 ≤ 2 ^ f 0 - 3 := by linarith [f_ge_3 0]
      have : 2 ^ f 0 - 3 ≤ P := Finset.single_le_prod (fun k _ => by linarith [f_ge_3 k]) (Finset.mem_range.mpr (by linarith))
      linarith
    have h_mod : 2 ^ f j ≡ 2 [MOD P] := by
      dsimp [f]
      rw [Nat.pow_add, Nat.pow_mul, Nat.ModEq]
      have h2P : Nat.Coprime 2 P := by
        apply Nat.coprime_prod_right; intro k _; apply Nat.coprime_two_right
        have : 2 ^ f k % 2 = 0 := Nat.pow_mod_even (f_pos k) (by decide)
        have : (2 ^ f k - 3) % 2 = 1 := by rw [Nat.sub_mod (by linarith [f_ge_3 k]), this]; decide
        exact Nat.odd_iff.mp this
      rw [Nat.pow_mod, Nat.Euler_theorem h2P, Nat.one_pow, Nat.one_mul]
    have h_gcd : Nat.Coprime (2 ^ f j - 3) P := by
      rw [Nat.Coprime, Nat.gcd_comm, Nat.gcd_rec, ← Nat.ModEq, h_mod]
      have : (2 % P + P - 3 % P) % P = P - 1 := by
        rw [Nat.mod_eq_of_lt (by linarith), Nat.mod_eq_of_lt (by linarith)]
        rw [Nat.add_sub_assoc (by linarith), Nat.mod_eq_of_lt (by linarith)]
      rw [Nat.ModEq, this, Nat.gcd_comm, Nat.gcd_one_left]
    apply Nat.Coprime.symm; apply Nat.coprime_of_dvd_right _ h_gcd
    exact Finset.dvd_prod_of_mem _ (Finset.mem_range.mpr h)

