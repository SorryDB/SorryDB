import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let P : ℕ → ℕ := λ n => Nat.rec 5 (λ _ p => p * (2 ^ (p.totient + 1) - 3)) n
  let a : ℕ → ℕ+ := λ n => ⟨(P n).totient + 1, Nat.succ_pos _⟩
  have hP : ∀ n, P n % 2 = 1 ∧ P n ≥ 5 := by
    intro n; induction n with
    | zero => simp [P]
    | succ n ih =>
      have ha : (a n).val ≥ 4 := by rw [a]; exact Nat.totient_ge_two ih.2
      have h2a : 2 ^ (a n).val - 3 ≥ 5 := by apply Nat.le_sub_of_add_le; omega
      constructor
      · simp [P, ih.1]; apply Nat.Odd.mul ih.1; apply Nat.odd_sub; · omega
        · apply Nat.even_pow.2 ⟨Nat.even_two, (by omega)⟩
      · simp [P]; apply Nat.le_mul_of_pos_right ih.2; omega
  have h_coprime : ∀ n i, i < n → Nat.Coprime (2 ^ (a n).val - 3) (2 ^ (a i).val - 3) := by
    intro n i h; have h1 : 2 ^ (a i).val - 3 ∣ P n := by
      induction n with
      | zero => omega
      | succ n ih =>
        by_cases hi : i = n
        · rw [hi, P]; apply Nat.dvd_mul_right
        · rw [P]; apply Nat.dvd_mul_of_dvd_left (ih (Nat.lt_of_le_of_ne (Nat.lt_succ.1 h) hi))
    apply Nat.Coprime.set_dvd_right h1
    have : 2 ^ (a n).val % P n = 2 % P n := by
      rw [a, Nat.pow_succ, Nat.pow_mod, Nat.pow_totient_mod_eq_one, one_pow, Nat.one_mul]
      · exact Nat.coprime_of_one_eq_gcd (Nat.gcd_eq_one_iff_coprime.2 (Nat.coprime_two_right.2 (hP n).1)).symm
      · exact (hP n).2
    apply Nat.coprime_of_one_eq_gcd; rw [← Nat.gcd_rec, ← Nat.sub_mod_eq_mod_sub]
    · rw [this]; simp [(hP n).2]; rw [Nat.gcd_rec]; simp
    · apply Nat.le_of_lt; apply Nat.pos_pow_of_pos; omega
  use Set.range a; constructor
  · apply Set.infinite_range_of_injective; intro n m h; by_contra hne
    wlog hlt : n < m; · exact this m n h.symm hne.symm (Nat.lt_of_le_of_ne (Nat.not_lt.1 hlt) hne.symm)
    have : Nat.Coprime (2 ^ (a m).val - 3) (2 ^ (a n).val - 3) := h_coprime m n hlt
    rw [h] at this; simp [Nat.Coprime] at this; have : (a m).val ≥ 4 := by rw [a]; apply Nat.totient_ge_two (hP m).2
    omega
  · rintro _ ⟨n, rfl⟩ _ ⟨m, rfl⟩ hnm; wlog hlt : n < m
    · exact (this m n hnm.symm).symm; · exact h_coprime m n hlt

```
