import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ+
    | 0 => ⟨3, by simp⟩
    | n + 1 =>
      let L := 3 * (Finset.range (n + 1)).prod (fun i => 2 ^ (f i).val - 3)
      ⟨(f n).val.succ * L.totient, by
        have hL : 0 < L := by
          apply Nat.mul_pos (by decide)
          apply Finset.prod_pos; intro i _
          apply Nat.sub_pos_of_lt; apply Nat.one_lt_pow (f i).property (by decide); decide
        exact Nat.mul_pos (Nat.succ_pos _) (Nat.totient_pos hL)⟩
  have h_mono : ∀ n, f n < f (n + 1) := fun n => by
    have hL : 2 < 3 * (Finset.range (n + 1)).prod (fun i => 2 ^ (f i).val - 3) := by
      apply Nat.mul_le_mul_right (by decide) (Finset.prod_pos fun i _ => _)
      apply Nat.sub_pos_of_lt; apply Nat.one_lt_pow (f i).property (by decide); decide
    calc (f n).val < (f n).val.succ * 2 := by linarith [(f n).property]
         _ ≤ (f n).val.succ * (3 * (Finset.range (n+1)).prod (fun i => 2 ^ (f i).val - 3)).totient :=
           Nat.mul_le_mul_left _ (Nat.totient_even hL).two_le
  have h_inj : Function.Injective f := strictMono_nat_of_lt_succ h_mono |>.injective
  use Set.range f, Set.infinite_range_of_injective h_inj
  rw [Set.pairwise_range_iff]; intro i j hij
  wlog h : i < j
  · exact (this h_inj hij h_mono j i hij.symm (hij.lt_or_lt.resolve_left h)).symm
  let L := 3 * (Finset.range j).prod (fun k => 2 ^ (f k).val - 3)
  have hL : L % 2 = 1 := by
    apply Nat.mul_mod_pos_pow; rw [Nat.mul_mod]; norm_num
    apply Finset.prod_induction (λ x => x % 2 = 1) (by norm_num) (λ a b ha hb => by rw [Nat.mul_mod, ha, hb]; norm_num)
    intro k _; rw [Nat.sub_mod (Nat.one_lt_pow (f k).property (by decide) |>.le)]; norm_num
    rw [Nat.pow_mod (by decide)]; norm_num
  have h_mod : 2 ^ (f j).val % L = 1 := by
    have h_cop : Nat.Coprime 2 L := Nat.coprime_two_right.mpr hL
    obtain ⟨k, hk⟩ : ∃ k, (f j).val = k * L.totient := ⟨(f (j - 1)).val.succ, by rw [Nat.succ_eq_add_one, Nat.sub_add_cancel (Nat.succ_le_iff.mpr h)]⟩
    rw [hk, Nat.pow_mul, Nat.ModEq.pow_totient h_cop |>.pow k]; norm_num
  have h_gcd : Nat.Coprime (2 ^ (f j).val - 3) L := by
    have : (2 ^ (f j).val - 3) % L = (L - 2) % L := by
      rw [Nat.sub_mod (by apply Nat.one_lt_pow (f j).property (by decide); decide), h_mod]
      if hL1 : L = 1 then simp [hL1] else
      rw [Nat.mod_eq_of_lt (by linarith), Nat.sub_mod (by decide), h_mod]; norm_num
      rw [Nat.mod_eq_of_lt (by linarith)]; rfl
    rw [Nat.coprime_iff_gcd_eq_one, Nat.gcd_comm, Nat.gcd_rec, this, Nat.gcd_comm]
    apply Nat.coprime_two_left.mpr hL
  exact h_gcd.coprime_mul_right |>.coprime_mul_left |>.coprime_product_right i (Finset.mem_range.mpr h)

end Imo1971P3
