import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let a : ℕ → ℕ := Nat.rec 3 (λ _ an ↦ (an - 1) * Nat.totient (2 ^ an - 3) + 1)
  have a_ge_3 : ∀ n, a n ≥ 3 := by
    intro n; induction' n with n ih; · rfl
    · dsimp [a]; have h : 2 ^ a n - 3 > 2 := by linarith [Nat.pow_le_pow_of_le_right (by linarith) ih]
      have : (2 ^ a n - 3).totient ≥ 1 := (Nat.totient_pos (by linarith)).nat_nz
      linarith
  have a_mono : StrictMono a := strictMono_nat_of_lt_succ (λ n ↦ by
    dsimp [a]; have h1 := a_ge_3 n
    have h2 : (2 ^ a n - 3).totient > 1 := Nat.totient_gt_one (by linarith [Nat.pow_le_pow_of_le_right (by linarith) h1])
    linarith)
  use Set.range (λ n ↦ (⟨a n, by linarith [a_ge_3 n]⟩ : ℕ+))
  constructor
  · apply Set.infinite_range_of_injective a_mono.injective
  · rintro _ ⟨m, rfl⟩ _ ⟨n, rfl⟩ hne
    have h_coprime : ∀ i j, i < j → Nat.Coprime (2 ^ a j - 3) (2 ^ a i - 3) := by
      intro i j hij
      have h_div : (2 ^ a i - 3).totient ∣ a j - 1 := by
        induction' j with j ih; · linarith
        · dsimp [a]; by_cases hi : i = j; · rw [hi]; apply Nat.dvd_mul_left
          · exact Nat.dvd_mul_of_dvd_left (ih (lt_of_le_of_ne (Nat.le_of_lt_succ hij) hi)) _
      have h_modeq : 2 ^ (a j - 1) ≡ 1 [MOD (2 ^ a i - 3)] := by
        apply Nat.ModEq.pow_totient; apply Nat.coprime_of_gcd_eq_one
        rw [Nat.gcd_rec]; exact (by decide : Nat.gcd 3 2 = 1)
      have h_modeq2 : 2 ^ a j ≡ 2 [MOD (2 ^ a i - 3)] := by
        have : 2 ^ a j = 2 ^ (a j - 1) * 2 := by rw [← pow_succ, Nat.sub_add_cancel (by linarith [a_ge_3 j])]
        rw [this]; exact Nat.ModEq.mul h_modeq (Nat.ModEq.refl 2)
      set M := 2 ^ a i - 3
      have hM : M > 2 := by linarith [a_ge_3 i, Nat.pow_le_pow_of_le_right (by linarith) (a_ge_3 i)]
      have h_div_M : M ∣ 2 ^ a j - 2 := by
        have : 2 ^ a j % M = 2 := h_modeq2
        apply Nat.dvd_of_mod_eq_zero
        rw [Nat.sub_mod (by linarith [a_ge_3 j]), this, Nat.mod_eq_of_lt hM]; rfl
      have h_div_g : Nat.gcd (2 ^ a j - 3) M ∣ 1 :=
        Nat.dvd_sub (by linarith [a_ge_3 j]) (Nat.dvd_trans (Nat.gcd_dvd_right _ _) h_div_M) (Nat.gcd_dvd_left _ _)
      exact Nat.eq_one_of_dvd_one h_div_g
    rcases hne.lt_or_lt with h | h
    · exact (h_coprime m n h).symm
    · exact h_coprime n m h

