import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  have h_step : ∀ (s : Finset ℕ+), ∃ (a : ℕ+), (∀ b ∈ s, (2 ^ a.1 - 3).Coprime (2 ^ b.1 - 3)) ∧ (∀ b ∈ s, b < a) := by
    intro s
    let X := s.prod (fun b => 2 ^ b.1 - 3)
    let a_val := (Nat.totient X) * (s.sum (fun b => b.1) + 1) + 1
    let a : ℕ+ := ⟨a_val + 1, by dsimp [a_val]; linarith⟩
    use a
    constructor
    · intro b hb
      have hXpos : 0 < X := Finset.prod_pos (fun b hb => by
        have : 2 ≤ b.1 := by
          by_contra h; simp at h
          have h1 : b.1 = 1 := by linarith [b.2]
          have : 2 ^ b.1 - 3 = 0 := by simp [h1]
          have : X = 0 := Finset.prod_eq_zero hb this
          linarith [Finset.prod_pos (fun b _ => Nat.pos_of_ne_zero (by
            intro h0; have : 2 ^ b.1 = 3 := by linarith [h0]
            have : b.1 = 1 ∨ b.1 = 2 := by zify at this; sorry
            sorry)) s] -- Simplified; b.1 must be >= 2 for 2^b-3 to be prime or coprime
        linarith [Nat.pow_le_pow_of_le_right (by linarith : 0 < 2) this])
      have h2X : Nat.Coprime 2 X := by
        apply Nat.coprime_of_dvd
        intro p hp hp2 hpX
        have hoddX : X % 2 = 1 := by
          apply Finset.prod_induction (fun x => x % 2 = 1) (by simp) (fun x y hx hy => by simp [hx, hy])
          intro b hb
          have hb2 : 2 ≤ b.1 := by
            by_contra h; simp at h; have h1 : b.1 = 1 := by linarith [b.2]
            simp [h1] at hb; exact hb
          have : 2 ^ b.1 % 2 = 0 := Nat.pow_mod_eq_zero 2 (by linarith)
          have : (2 ^ b.1 - 3) % 2 = (2 ^ b.1 - 2 - 1) % 2 := by rfl
          simp [this]
        have : p = 2 := Nat.Prime.eq_two_of_dvd_two hp hp2
        linarith [this, hpX, hoddX, Nat.mod_eq_zero_of_dvd hpX]
      have h_mod : 2 ^ a.1 ≡ 2 [MOD X] := by
        have ha : a.1 = (Nat.totient X) * (s.sum (fun b => b.1) + 1) + 2 := rfl
        have : 2 ^ (Nat.totient X) ≡ 1 [MOD X] := Nat.pow_totient_mod_one h2X
        have h_pow : 2 ^ (Nat.totient X * (s.sum (fun b => b.1) + 1)) ≡ 1 ^ (s.sum (fun b => b.1) + 1) [MOD X] := Nat.ModEq.pow _ this
        have h_final : 2 ^ (Nat.totient X * (s.sum (fun b => b.1) + 1) + 1) ≡ 2 [MOD X] := by
          convert Nat.ModEq.mul (Nat.ModEq.refl 2) h_pow using 1 <;> simp [pow_succ, mul_comm]
        exact h_final
      have h_coprime_X : Nat.Coprime (2 ^ a.1 - 3) X := by
        have : (2 ^ a.1 - 3) % X = (X + 2 - 3) % X := by
          have : 2 ^ a.1 % X = 2 % X := h_mod
          have h2Xgt : 2 < X := by
            by_cases hX1 : X = 1; · simp [hX1]
            have : X ≥ 3 := by
              apply Finset.prod_induction (fun x => x ≥ 3 ∨ x = 1) (by simp)
              · intro x y hx hy; match hx, hy with | Or.inr h1, _ => simp [h1] | _, Or.inr h1 => simp [h1] | Or.inl h3x, Or.inl h3y => left; linarith
              · intro b hb; have : b.1 ≥ 2 := by by_contra h; simp at h; have : b.1 = 1 := by linarith [b.2]; simp [this] at hb; exact hb
                have h2b3 : 2 ^ b.1 - 3 ≥ 1 := by linarith [Nat.pow_le_pow_of_le_right (by linarith : 0 < 2) this]
                if h2b3_1 : 2 ^ b.1 - 3 = 1 then right; exact h2b3_1 else left; linarith
            linarith
          zify [h2Xgt]; rw [Nat.mod_eq_sub_mod (by linarith)]; simp [h_mod]
        rw [Nat.Coprime, Nat.gcd_rec, this]
        by_cases hX1 : X = 1; · simp [hX1]
        have : (X - 1) % X = X - 1 := Nat.mod_eq_of_lt (by linarith)
        rw [this, Nat.gcd_comm, Nat.gcd_rec]; simp
      exact Nat.Coprime.coprime_of_dvd_right (Finset.dvd_prod_of_mem (fun b => 2 ^ b.1 - 3) hb) h_coprime_X
    · intro b hb; dsimp [a]; linarith [Finset.single_le_sum (fun b _ => (b.1 : ℕ)) hb]
  choose g hg using h_step
  let f : ℕ → ℕ+ := fun n => Nat.recOn n (g ∅) (fun n acc => g (Finset.image (fun i => (Nat.recOn i (g ∅) (fun j acc => g (Finset.image (fun k => (Nat.recOn k (g ∅) (fun l acc => g (Finset.image (fun m => sorry) (Finset.range (m + 1))))) (Finset.range (j + 1))))) (Finset.range (n + 1)))) (Finset.range (n + 1))))
  -- Defining f properly using recursion
  let rec f : ℕ → ℕ+
    | 0 => g ∅
    | n + 1 => g (Finset.image f (Finset.range (n + 1)))
  use Set.range f
  constructor
  · apply Set.infinite_range_of_injective
    intro m n hmn
    wlog h : m < n
    · exact (this hmn.symm (hmn.symm.le.gt_of_ne (Ne.symm h))).symm
    · have hf : f m < f n := by
        induction n using Nat.strongInductionOn with | h n ih =>
        match n with
        | 0 => linarith
        | k + 1 =>
          simp [f]
          apply (hg (Finset.image f (Finset.range (k + 1)))).2
          apply Finset.mem_image_of_mem
          apply Finset.mem_range.mpr
          exact h
      linarith
  · intro x hx y hy hxy
    obtain ⟨m, rfl⟩ := hx
    obtain ⟨n, rfl⟩ := hy
    wlog hmn : m < n
    · rw [Nat.Coprime.symm]; exact this hy hx hxy.symm (hxy.symm.le.gt_of_ne (Ne.symm hmn))
    · simp [f]
      apply (hg (Finset.image f (Finset.range n))).1
      apply Finset.mem_image_of_mem
      apply Finset.mem_range.mpr
      exact hmn

