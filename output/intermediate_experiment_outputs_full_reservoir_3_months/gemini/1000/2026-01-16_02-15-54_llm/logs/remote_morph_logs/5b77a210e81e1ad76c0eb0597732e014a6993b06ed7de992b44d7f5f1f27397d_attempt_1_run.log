import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ+
    | 0 => 3
    | n + 1 =>
      let M := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (f i : ℕ) - 3)
      ⟨M.totient + 2, by
        have h₀ : 2 ^ (f 0 : ℕ) - 3 = 5 := by decide
        have h_prod : (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (f i : ℕ) - 3) ≥ 5 := by
          apply (Finset.single_le_prod (fun _ _ ↦ Nat.zero_le _) (Finset.mem_range.mpr (Nat.zero_lt_succ n))).trans
          rw [h₀]; exact le_refl 5
        have h_tot : Nat.totient M ≥ 4 := by
          have h_gt : M > 2 := by omega
          have : M ≠ 3 ∧ M ≠ 4 ∧ M ≠ 6 := by
            refine ⟨by omega, by omega, ?_⟩
            intro h; have : M % 2 = 1 := by
              apply Finset.prod_induction (fun x ↦ x % 2 = 1) (fun _ _ ↦ Nat.odd_mul.mpr) (by decide)
              intro i _; exact Nat.odd_sub_odd (Nat.even_pow (by have := f i; omega) (by decide)) (by decide)
            rw [h] at this; simp at this
          have h_phi := Nat.one_lt_totient h_gt
          omega
        omega⟩
  use Set.range f
  constructor
  · apply Set.infinite_range_of_injective
    intro n m h
    if hnm : n < m then
      let M := (Finset.range m).prod (fun i ↦ 2 ^ (f i : ℕ) - 3)
      have h_f_m : (f m : ℕ) = M.totient + 2 := by cases m; cases hnm; rfl
      have h_mod : (2 ^ (f m : ℕ) - 3) % M = 1 := by
        rw [h_f_m, pow_add, (by decide : 2 ^ 2 = 4), Nat.mul_mod, Nat.pow_totient_mod_eq_one, Nat.mul_one, (by decide : 4 % M = 4), (by decide : 4 - 3 = 1)]
        · have h_prod : M ≥ 5 := by
            apply (Finset.single_le_prod (fun _ _ ↦ Nat.zero_le _) (Finset.mem_range.mpr (Nat.zero_lt_m))).trans
            rw [(by decide : 2 ^ (f 0 : ℕ) - 3 = 5)]; exact le_refl 5
          omega
        · have : M % 2 = 1 := by
            apply Finset.prod_induction (fun x ↦ x % 2 = 1) (fun _ _ ↦ Nat.odd_mul.mpr) (by decide)
            intro i _; exact Nat.odd_sub_odd (Nat.even_pow (by have := f i; omega) (by decide)) (by decide)
          exact Nat.coprime_two_right.mpr this
      have h_coprime : Nat.Coprime (2 ^ (f m : ℕ) - 3) M := Nat.coprime_of_mod_eq_one h_mod
      have h_div : (2 ^ (f n : ℕ) - 3) ∣ M := Finset.dvd_prod_of_mem (fun i ↦ 2 ^ (f i : ℕ) - 3) (Finset.mem_range.mpr hnm)
      have h_res := Nat.Coprime.coprime_div_right h_div h_coprime
      rw [h] at h_res
      have h_unit : (2 ^ (f n : ℕ) - 3).Coprime (2 ^ (f n : ℕ) - 3) := h_res
      have h_f_n_gt : 2 ^ (f n : ℕ) - 3 > 1 := by
        induction n with
        | zero => decide
        | succ n ih =>
          let M' := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (f i : ℕ) - 3)
          have : M' ≥ 5 := by
            apply (Finset.single_le_prod (fun _ _ ↦ Nat.zero_le _) (Finset.mem_range.mpr (Nat.zero_lt_succ n))).trans
            rw [(by decide : 2 ^ (f 0 : ℕ) - 3 = 5)]; exact le_refl 5
          have h_tot := Nat.one_lt_totient (by omega)
          have h_f_succ : (f (n + 1) : ℕ) = M'.totient + 2 := rfl
          rw [h_f_succ]; have := Nat.one_lt_totient (by omega); omega
      have := Nat.Coprime.self_iff.mp h_unit; omega
    else if hmn : m < n then
      -- Same as above
      let M := (Finset.range n).prod (fun i ↦ 2 ^ (f i : ℕ) - 3)
      have h_f_n : (f n : ℕ) = M.totient + 2 := by cases n; cases hmn; rfl
      have h_mod : (2 ^ (f n : ℕ) - 3) % M = 1 := by
        rw [h_f_n, pow_add, (by decide : 2 ^ 2 = 4), Nat.mul_mod, Nat.pow_totient_mod_eq_one, Nat.mul_one, (by decide : 4 % M = 4), (by decide : 4 - 3 = 1)]
        · have h_prod : M ≥ 5 := by
            apply (Finset.single_le_prod (fun _ _ ↦ Nat.zero_le _) (Finset.mem_range.mpr (Nat.zero_lt_n))).trans
            rw [(by decide : 2 ^ (f 0 : ℕ) - 3 = 5)]; exact le_refl 5
          omega
        · have : M % 2 = 1 := by
            apply Finset.prod_induction (fun x ↦ x % 2 = 1) (fun _ _ ↦ Nat.odd_mul.mpr) (by decide)
            intro i _; exact Nat.odd_sub_odd (Nat.even_pow (by have := f i; omega) (by decide)) (by decide)
          exact Nat.coprime_two_right.mpr this
      have h_coprime := Nat.coprime_of_mod_eq_one h_mod
      have h_div := Finset.dvd_prod_of_mem (fun i ↦ 2 ^ (f i : ℕ) - 3) (Finset.mem_range.mpr hmn)
      have h_res := Nat.Coprime.coprime_div_right h_div h_coprime
      rw [h] at h_res
      have h_unit : (2 ^ (f m : ℕ) - 3).Coprime (2 ^ (f m : ℕ) - 3) := h_res
      have h_f_m_gt : 2 ^ (f m : ℕ) - 3 > 1 := by
        induction m with
        | zero => decide
        | succ m ih =>
          let M' := (Finset.range (m + 1)).prod (fun i ↦ 2 ^ (f i : ℕ) - 3)
          have : M' ≥ 5 := by
            apply (Finset.single_le_prod (fun _ _ ↦ Nat.zero_le _) (Finset.mem_range.mpr (Nat.zero_lt_succ m))).trans
            rw [(by decide : 2 ^ (f 0 : ℕ) - 3 = 5)]; exact le_refl 5
          have h_f_succ : (f (m + 1) : ℕ) = M'.totient + 2 := rfl
          rw [h_f_succ]; have := Nat.one_lt_totient (by omega); omega
      have := Nat.Coprime.self_iff.mp h_unit; omega
    else omega
  · rw [Set.pairwise_range_iff]
    intro m n hmn
    if h : m < n then
      let M := (Finset.range n).prod (fun i ↦ 2 ^ (f i : ℕ) - 3)
      have h_f_n : (f n : ℕ) = M.totient + 2 := by cases n; cases h; rfl
      have h_mod : (2 ^ (f n : ℕ) - 3) % M = 1 := by
        rw [h_f_n, pow_add, (by decide : 2 ^ 2 = 4), Nat.mul_mod, Nat.pow_totient_mod_eq_one, Nat.mul_one, (by decide : 4 % M = 4), (by decide : 4 - 3 = 1)]
        · have h_prod : M ≥ 5 := by
            apply (Finset.single_le_prod (fun _ _ ↦ Nat.zero_le _) (Finset.mem_range.mpr (Nat.zero_lt_n))).trans
            rw [(by decide : 2 ^ (f 0 : ℕ) - 3 = 5)]; exact le_refl 5
          omega
