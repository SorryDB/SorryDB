import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ × ℕ := fun n ↦ n.rec (3, 1) (fun _ p ↦
    let L' := p.2 * (2 ^ p.1 - 3)
    (L'.totient + 2, L'))
  let e : ℕ → ℕ+ := fun n ↦ ⟨(f n).1, by
    induction n with
    | zero => exact (by decide)
    | succ n ih => dsimp [f]; exact Nat.succ_pos _⟩
  use Set.range e
  constructor
  · apply Set.infinite_range_of_injective
    intro n m hnm
    wlog h : n < m
    · exact (this hnm.symm (h hnm.symm)).elim
    have e_ge_3 : ∀ i, 3 ≤ (e i).val := by
      intro i; induction i with
      | zero => exact (by decide)
      | succ i ih => dsimp [f, e]; exact (Nat.le_add_left 2 _).trans (by simp)
    have L_odd : ∀ i, (f i).2 % 2 = 1 := by
      intro i; induction i with
      | zero => rfl
      | succ i ih =>
        dsimp [f]; rw [Nat.mul_mod, ih]; dsimp;
        have := e_ge_3 i; rw [← Nat.mod_mod (2 ^ (f i).1)];
        have : 2 ^ (f i).1 % 2 = 0 := Nat.pow_mod_eq_zero _ this (by decide)
        rw [this]; rfl
    have h_cop : ∀ i, Nat.Coprime (2 ^ (e (i + 1)).val - 3) (f (i + 1)).2 := by
      intro i; dsimp [e, f]; rw [Nat.Coprime, Nat.gcd_comm, ← Nat.gcd_rec]
      have odd_L : (f (i + 1)).2 % 2 = 1 := L_odd (i + 1)
      have : Nat.Coprime 2 (f (i + 1)).2 := by rw [Nat.Coprime]; simp [odd_L]; exact (by decide)
      have htot := Nat.pow_totient_mod_one this
      have hmod : 2 ^ ((f (i + 1)).2.totient + 2) % (f (i + 1)).2 = 4 % (f (i + 1)).2 := by
        rw [pow_add, Nat.mul_mod, htot]; simp
      rw [hmod, Nat.sub_mod (by
        have := odd_L; have : (f (i + 1)).2 ≥ 1 := by omega
        exact (Nat.mod_lt 4 this).le.trans (by omega))]
      simp; rw [Nat.gcd_comm]; apply Nat.gcd_one_left
    have h_prod : ∀ i j, j ≤ i → (2 ^ (e j).val - 3) ∣ (f (i + 1)).2 := by
      intro i j hj; induction i, hj using Nat.le_induction with
      | base => dsimp [f]; apply Nat.dvd_mul_right
      | succ i hi ih => dsimp [f]; exact ih.trans (Nat.dvd_mul_right _ _)
    have h_inc : StrictMono e := by
      apply strictMono_nat_of_lt_succ; intro i; dsimp [e, f]
      have : (f (i + 1)).2.totient ≥ (2 ^ (e i).val - 3).totient := by
        apply Nat.totient_le_of_dvd; apply h_prod i i (by rfl)
      have : (2 ^ (e i).val - 3).totient > (e i).val := by
        have := e_ge_3 i;
        match h_ei : (e i).val with
        | 3 => decide
        | 4 => decide
        | 5 => decide
        | n+6 =>
          have : 2^(n+6)-3 > (n+6)+2 := by induction n <;> omega
          apply Nat.lt_of_le_of_lt (Nat.le_of_lt (Nat.totient_gt_sqrt (by omega)))
          apply Nat.sqrt_lt_self; omega
      omega
    exact (h_inc.injective hnm).elim
  · intro a ha b hb hab
    obtain ⟨i, hi⟩ := ha; obtain ⟨j, hj⟩ := hb
    rw [← hi, ← hj]; wlog h : i < j
    · rw [Nat.Coprime_comm]; apply this hb ha hab.symm hj hi (by omega)
    dsimp; rw [Nat.Coprime_comm]
    have h_prod : (2 ^ (e i).val - 3) ∣ (f j).2 := by
      induction j, h using Nat.le_induction with
      | base => dsimp [f]; apply Nat.dvd_mul_right
      | succ j hj ih => dsimp [f]; exact ih.trans (Nat.dvd_mul_right _ _)
    apply Nat.Coprime.coprime_div_right h_prod
    dsimp [e, f]; rw [Nat.Coprime, Nat.gcd_comm, ← Nat.gcd_rec]
    have odd_L : (f j).2 % 2 = 1 := by
      induction j with | zero => rfl | succ j ih => dsimp [f]; rw [Nat.mul_mod, ih]; rfl
    have : Nat.Coprime 2 (f j).2 := by rw [Nat.Coprime]; simp [odd_L]; exact (by decide)
    have htot := Nat.pow_totient_mod_one this
    have hmod : 2 ^ ((f j).2.totient + 2) % (f j).2 = 4 % (f j).2 := by
      rw [pow_add, Nat.mul_mod, htot]; simp
    rw [hmod, Nat.sub_mod (by have : (f j).2 ≥ 1 := by omega; exact (Nat.mod_lt 4 this).le.trans (by omega))]
    simp; rw [Nat.gcd_comm]; apply Nat.gcd_one_left

