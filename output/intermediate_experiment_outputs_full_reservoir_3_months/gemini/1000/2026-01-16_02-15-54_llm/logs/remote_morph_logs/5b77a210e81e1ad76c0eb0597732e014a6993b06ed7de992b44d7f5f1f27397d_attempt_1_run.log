import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let a : ℕ → ℕ := fun n ↦ Nat.recOn n 3 (fun n acc ↦
    let L := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (Nat.recOn i 3 (fun _ acc ↦ acc * (Nat.totient ((Finset.range _).prod (fun j ↦ 2 ^ (Nat.recOn j 3 (fun _ acc ↦ sorry)) - 3))) + 1)) - 3)
    acc * Nat.totient L + 1)
  let rec f : ℕ → ℕ
    | 0 => 3
    | n + 1 => f n * (Nat.totient ((Finset.range (n + 1)).prod (fun i ↦ 2 ^ f i - 3))) + 1
  have f_pos n : 0 < f n := by
    induction' n with n ih
    · exact Nat.succ_pos 2
    · dsimp [f]; exact Nat.succ_pos _
  have f_strict_mono : StrictMono f := strictMono_nat_of_lt_succ fun n ↦ by
    dsimp [f]
    let L := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ f i - 3)
    have hL : 1 < L := by
      have : 2 ^ f 0 - 3 ≤ L := Finset.single_le_prod (fun _ _ ↦ by linarith) (Finset.self_mem_range_succ 0)
      exact this.trans_lt' (by dsimp [f]; norm_num)
    have : 1 < Nat.totient L := Nat.one_lt_totient hL
    calc f n < f n * 2 := by linarith [f_pos n]
         _ ≤ f n * Nat.totient L := Nat.mul_le_mul_left (f n) this
         _ < f n * Nat.totient L + 1 := Nat.lt_succ_self _
  have f_pairwise n m (h : n < m) : Nat.Coprime (2 ^ f n - 3) (2 ^ f m - 3) := by
    have h_mod (k : ℕ) (hk : n ≤ k) : 2 ^ f (k + 1) ≡ 2 [MOD (2 ^ f n - 3)] := by
      dsimp [f]
      let L := (Finset.range (k + 1)).prod (fun i ↦ 2 ^ f i - 3)
      have hL : (2 ^ f n - 3) ∣ L := Finset.dvd_prod_of_mem (fun i ↦ 2 ^ f i - 3) (Finset.mem_range.mpr (Nat.lt_succ_of_le hk))
      have h2L : Nat.Coprime 2 L := Nat.coprime_of_dvd_of_coprime hL (by
        have hodd : Nat.Odd (2 ^ f n - 3) := by
          have : 2 ^ 3 ≤ 2 ^ f n := Nat.pow_le_pow_of_le_right (by norm_num) (f_strict_mono.ge_nat n)
          exact Nat.Odd.sub_odd (Nat.even_pow.mpr ⟨Nat.even_two, by linarith⟩) (by norm_num))
        exact (Nat.coprime_two_right.mpr hodd))
      have : 2 ^ (f k * Nat.totient L) ≡ 1 [MOD L] := by
        rw [pow_mul]; exact (Nat.ModEq.pow_totient h2L).pow (f k)
      have : 2 ^ (f k * Nat.totient L + 1) ≡ 2 [MOD L] := (Nat.ModEq.mul_left 2 this).trans (by rw [one_mul]; exact Nat.ModEq.refl 2)
      exact this.of_dvd hL
    induction' m, h using Nat.le_induction with m hm ih
    · have := h_mod n (le_refl n)
      rw [Nat.Coprime, Nat.gcd_rec, ← Nat.ModEq]
      have : (2 ^ f (n + 1) - 3) ≡ 2 - 3 [MOD (2 ^ f n - 3)] := Nat.ModEq.sub_right this 3
      have : (2 ^ f (n + 1) - 3) ≡ (2 ^ f n - 3) - 1 [MOD (2 ^ f n - 3)] := this.trans (by
        have : 3 ≤ 2 ^ f n := (Nat.pow_le_pow_of_le_right (by norm_num) (f_strict_mono.ge_nat n)).trans_le' (by norm_num)
        exact (Nat.mod_eq_of_lt (by linarith)).symm)
      rw [this.gcd_eq]; exact Nat.gcd_self_minus_one _
    · have := h_mod (m - 1) (by linarith)
      rw [Nat.succ_sub (by linarith)] at this
      rw [Nat.Coprime, Nat.gcd_rec, ← Nat.ModEq]
      have : (2 ^ f m - 3) ≡ 2 - 3 [MOD (2 ^ f n - 3)] := (Nat.ModEq.sub_right this 3)
      have : (2 ^ f m - 3) ≡ (2 ^ f n - 3) - 1 [MOD (2 ^ f n - 3)] := this.trans (by
        have : 3 ≤ 2 ^ f n := (Nat.pow_le_pow_of_le_right (by norm_num) (f_strict_mono.ge_nat n)).trans_le' (by norm_num)
        exact (Nat.mod_eq_of_lt (by linarith)).symm)
      rw [this.gcd_eq]; exact Nat.gcd_self_minus_one _
  exists Set.range (fun n ↦ ⟨f n, f_pos n⟩)
  exact ⟨Set.infinite_range_of_injective f_strict_mono.injective,
    Set.pairwise_range_iff.mpr fun n m hnm ↦ (f_pairwise _ _ (hnm.lt_or_lt.resolve_right (by linarith))).symm⟩
```
