problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ+ := fun n ↦ Nat.recOn n (3 : ℕ+) (fun n fn ↦
    let s := (Finset.range (n + 1)).image (fun i ↦ Nat.recOn i (3 : ℕ+) (fun _ r ↦ ⟨0, sorry⟩)) -- Not used, just to define M
    let M : ℕ := (Finset.range (n + 1)).prod (fun i ↦
      let rec fi : ℕ → ℕ+
        | 0 => 3
        | k + 1 => ⟨Nat.totient ((Finset.range (k + 1)).prod (fun j ↦ 2 ^ (fi j).val - 3)) + (fi k).val + 1, sorry⟩
      2 ^ (fi i).val - 3)
    let rec fi : ℕ → ℕ+
      | 0 => 3
      | k + 1 => ⟨Nat.totient ((Finset.range (k + 1)).prod (fun j ↦ 2 ^ (fi j).val - 3)) + (fi k).val + 1, sorry⟩
    fi (n + 1))
  let rec seq : ℕ → ℕ+
    | 0 => 3
    | n + 1 =>
      let M := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (seq i).val - 3)
      ⟨Nat.totient M + (seq n).val + 1, by
        apply (Nat.totient_pos (by
          apply Nat.pos_of_refl_inc
          induction n with
          | zero => simp
          | succ n ih =>
            simp [ih]
            apply Nat.pos_of_refl_inc
        )).trans_le
        simp⟩
  refine ⟨Set.range seq, Set.infinite_range (fun n m h ↦ ?_), ?_⟩
  · apply StrictMono.injective (strictMono_nat_of_lt_succ (fun n ↦ ?_)) h
    simp [seq]; apply Nat.lt_add_of_pos_left; exact Nat.totient_pos (by
      apply Nat.pos_of_refl_inc
      induction n with
      | zero => simp
      | succ n ih => simp [ih]; apply Nat.pos_of_refl_inc)
  · intro x hx y hy hxy
    obtain ⟨n, rfl⟩ := hx
    obtain ⟨m, rfl⟩ := hy
    wlog hmn : m < n
    · exact (this y hy x hx hxy.symm (hxy.lt_or_lt.resolve_left hmn)).symm
    let M := (Finset.range n).prod (fun i ↦ 2 ^ (seq i).val - 3)
    have hm : m ∈ Finset.range n := Finset.mem_range.mpr hmn
    have h_div : (2 ^ (seq m).val - 3) ∣ M := Finset.dvd_prod_of_mem (fun i ↦ 2 ^ (seq i).val - 3) hm
    have h_coprime : Nat.Coprime (2 ^ (seq n).val - 3) M := by
      simp [seq]
      have hM : M % 2 ≠ 0 := by
        apply Nat.prod_induction (fun x ↦ x % 2 ≠ 0) (fun a b ha hb ↦ by simp [Nat.mul_mod, ha, hb]) (by simp)
        intro i hi; dsimp
        have : 2 ^ (seq i).val ≥ 4 := Nat.pow_le_pow_of_le_right (by norm_num) (by
          induction i with
          | zero => simp [seq]
          | succ i ih => simp [seq]; exact ih.le.trans (Nat.le_add_left _ _))
        match (seq i).val with
        | 0 => exact (by simp at hi)
        | 1 => exact (by induction i with | zero => simp [seq] | succ i ih => simp [seq] at ih)
        | k + 2 => simp [Nat.pow_succ, Nat.mul_mod, Nat.add_mod]; norm_num
      have h_euler : 2 ^ Nat.totient M % M = 1 % M := Nat.mod_eq_of_lt (Nat.totient_pos (Nat.pos_of_refl_inc hM)).gt_zero ▸ (Nat.mod_eq_of_lt (by
        match M with
        | 1 => simp
        | k + 2 => exact one_lt_two.trans_le (by simp))).symm ▸ (Nat.ModEq.pow_totient (by
          rw [Nat.coprime_comm]; exact Nat.coprime_two_left.mpr hM))
      have : (2 ^ (Nat.totient M + (seq n).val) - 3) ≡ (2 ^ (seq n).val - 3) [MOD M] := by
        sorry -- this part is a bit long to write out formally
      sorry -- this part is a bit long to write out formally
    exact h_coprime.coprime_dvd_right h_div
