problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let f : ℕ → ℕ+ := fun n => Nat.recOn n (3 : ℕ+) (fun n an =>
    let M : ℕ := (Finset.range (n + 1)).prod (fun i => 2 ^ (Nat.recOn i (3 : ℕ+) (fun _ an =>
      let M' := (Finset.range i).prod (fun j => 2 ^ (Nat.recOn j (3 : ℕ+) (fun _ an => an)).val - 3)
      ⟨an.val * M'.totient + 2, by positivity⟩)).val - 3)
    ⟨an.val * M.totient + 2, by positivity⟩)
  use Set.range f
  constructor
  · apply Set.infinite_range_of_injective
    intro n m h
    by_contra hnm
    wlog hlt : n < m
    · exact this m n h.symm (Ne.symm hnm) (not_lt.mp hlt).lt_of_ne (Ne.symm hnm)
    clear hnm
    induction m with
    | zero => exact (Nat.not_lt_zero n hlt).elim
    | succ m ih =>
      have : f m < f (m + 1) := by
        dsimp [f]
        let M := (Finset.range (m + 1)).prod (fun i => 2 ^ (f i).val - 3)
        have hM : 0 < M := by
          apply Finset.prod_pos; intro i _
          have : 3 ≤ (f i).val := by induction i with | zero => rfl | succ i ih => dsimp [f]; positivity
          omega
        have hT : 0 < M.totient := Nat.totient_pos hM
        have : 3 ≤ (f m).val := by induction m with | zero => rfl | succ i ih => dsimp [f]; positivity
        omega
      if hnm : n = m then subst hnm; exact this.ne h else
        have : n < m := by omega
        exact (ih this).ne (this.trans (by dsimp [f]; let M := (Finset.range (m + 1)).prod (fun i => 2 ^ (f i).val - 3); have hM : 0 < M := by apply Finset.prod_pos; intro i _; have : 3 ≤ (f i).val := by induction i with | zero => rfl | succ i ih => dsimp [f]; positivity; omega; have hT : 0 < M.totient := Nat.totient_pos hM; have : 3 ≤ (f m).val := by induction m with | zero => rfl | succ i ih => dsimp [f]; positivity; omega)).ne h
  · apply Set.pairwise_range_iff.mpr
    intro n m hnm
    wlog hlt : n < m
    · exact (this m n hnm.symm (not_lt.mp hlt).lt_of_ne).symm
    induction m with
    | zero => exact (Nat.not_lt_zero n hlt).elim
    | succ m ih =>
      if hnm2 : n = m then
        subst hnm2; dsimp [f]
        let M := (Finset.range (n + 1)).prod (fun i => 2 ^ (f i).val - 3)
        have h1 : (2 ^ (f n).val - 3) ∣ M := Finset.dvd_prod_of_mem (fun i => 2 ^ (f i).val - 3) (Finset.mem_range_self n)
        have h2 : (2 ^ (f (n + 1)).val - 3) ≡ 1 [MOD M] := by
          dsimp [f]; have hMpos : 0 < M := by apply Finset.prod_pos; intro i _; have : 3 ≤ (f i).val := by induction i with | zero => rfl | succ i ih => dsimp [f]; positivity; omega; omega
          have h2M : Nat.Coprime 2 M := by apply Nat.coprime_left_comm.mp; apply Nat.coprime_prod_right; intro i _; apply (Nat.oddp_two_pow_sub_three (by induction i with | zero => rfl | succ i ih => dsimp [f]; positivity; omega)).coprime_two
          have : 2 ^ ((f n).val * M.totient + 2) = 2 ^ 2 * (2 ^ M.totient) ^ (f n).val := by ring
          rw [this]; apply Nat.ModEq.add_right; apply Nat.ModEq.trans (Nat.ModEq.mul_left 4 (Nat.ModEq.pow _ (Nat.ModEq.pow_totient h2M)))
          norm_num
        exact Nat.Coprime.symm (Nat.Coprime.modEq (Nat.ModEq.symm h2) (Nat.coprime_one_left M)).coprime_dvd_right h1
      else
        have hlt2 : n < m := by omega
        have h_coprime_m := ih hlt2
        dsimp [f]; let M := (Finset.range (m + 1)).prod (fun i => 2 ^ (f i).val - 3)
        have hMpos : 0 < M := by apply Finset.prod_pos; intro i _; have : 3 ≤ (f i).val := by induction i with | zero => rfl | succ i ih => dsimp [f]; positivity; omega; omega
        have h2M : Nat.Coprime 2 M := by apply Nat.coprime_left_comm.mp; apply Nat.coprime_prod_right; intro i _; apply (Nat.oddp_two_pow_sub_three (by induction i with | zero => rfl | succ i ih => dsimp [f]; positivity; omega)).coprime_two
        have h_mod : (2 ^ (f (m + 1)).val - 3) ≡ 1 [MOD M] := by dsimp [f]; have : 2 ^ ((f m).val * M.totient + 2) = 2 ^ 2 * (2 ^ M.totient) ^ (f m).val := by ring; rw [this]; apply Nat.ModEq.add_right; apply Nat.ModEq.trans (Nat.ModEq.mul_left 4 (Nat.ModEq.pow _ (Nat.ModEq.pow_totient h2M))); norm_num
        have h_div : (2 ^ (f n).val - 3) ∣ M := Finset.dvd_prod_of_mem (fun i => 2 ^ (f i).val - 3) (Finset.mem_range.mpr hlt2)
        exact Nat.Coprime.symm (Nat.Coprime.modEq (Nat.ModEq.symm h_mod) (Nat.coprime_one_left M)).coprime_dvd_right h_div

