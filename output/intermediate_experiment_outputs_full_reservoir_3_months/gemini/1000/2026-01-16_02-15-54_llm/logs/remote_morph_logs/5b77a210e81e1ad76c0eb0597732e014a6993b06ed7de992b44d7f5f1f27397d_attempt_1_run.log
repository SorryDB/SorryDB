import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ+
    | 0 => 3
    | n + 1 =>
      let M := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (a i).val - 3)
      ⟨M.totient * (a n).val + 2, Nat.succ_pos _⟩
  have ha : ∀ n, (a n).val ≥ 3 := by
    intro n; induction n with | zero => rfl | succ n ih => dsimp [a]; exact Nat.le_add_left 2 _
  have mono : StrictMono a := strictMono_nat_of_lt_succ fun n ↦ by
    dsimp [a]; refine (Nat.le_mul_of_pos_left (a n).val (Nat.totient_pos (Finset.prod_pos fun i _ ↦ ?_))).trans_lt (Nat.lt_add_of_pos_right (by decide))
