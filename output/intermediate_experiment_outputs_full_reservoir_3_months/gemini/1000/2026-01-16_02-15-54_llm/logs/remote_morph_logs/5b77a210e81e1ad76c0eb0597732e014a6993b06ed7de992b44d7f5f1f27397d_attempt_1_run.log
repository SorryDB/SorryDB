    · exact (this y hy x hx hne.symm (hne.lt_or_lt.resolve_left hmn)).symm
    let s_n := (List.range n).map f
    let L_n := (s_n.map (fun m => 2 ^ m.val - 3)).prod
    have hLn : 2 ^ (f n).val - 3 ≡ 1 [MOD L_n] := by
      have : f n = L_n.eulerPhi * (f (n - 1)).val + 2 := by
        cases n with
        | zero => exact (Nat.not_lt_zero m hmn).elim
        | succ n => rfl
      rw [this]
      have hL_pos : L_n > 0 := by
        apply List.prod_pos; intro x hx
        obtain ⟨m', hm', rfl⟩ := List.mem_map.1 hx
        obtain ⟨i, hi, rfl⟩ := List.mem_map.1 hm'
        have : f i ≥ 2 := by
          induction i with | zero => rfl | succ i ih => exact (Nat.le_of_lt (hf_mono i)).trans (Nat.le_add_right _ _)
        exact Nat.sub_pos_of_lt (by gd)
      have hL_odd : L_n % 2 = 1 := by
        apply List.prod_induction (λ x => x % 2 = 1) 1 (· * ·) (by decide)
        intro x hx
        obtain ⟨m', hm', rfl⟩ := List.mem_map.1 hx
        obtain ⟨i, hi, rfl⟩ := List.mem_map.1 hm'
        have : f i ≥ 2 := by
          induction i with | zero => rfl | succ i ih => exact (Nat.le_of_lt (hf_mono i)).trans (Nat.le_add_right _ _)
        rw [Nat.sub_mod (by gd), Nat.pow_mod, ←Nat.one_mod]
        simp
      have : Nat.Coprime 2 L_n := (Nat.coprime_two_right.2 hL_odd)
      calc 2 ^ (L_n.eulerPhi * (f (n - 1)).val + 2) - 3
           ≡ (2 ^ L_n.eulerPhi) ^ (f (n - 1)).val * 2 ^ 2 - 3 [MOD L_n] := by
             apply Nat.ModEq.sub_right; apply Nat.ModEq.pow; rw [pow_add, pow_mul]; rfl
         _ ≡ 1 ^ (f (n - 1)).val * 4 - 3 [MOD L_n] := by
