import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ
    | 0 => 3
    | n + 1 => (f n + 1) * (Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3).totient + 2
  have hf_ge_3 : ∀ n, f n ≥ 3 := by
    intro n; induction' n with n ih; · exact le_refl 3
    · dsimp [f]; linarith [Nat.totient_pos (show 0 < (Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3) by
        apply Finset.prod_pos; intro i _; apply Nat.pos_of_gt; apply Nat.pow_le_pow_of_le_right (by decide) (ih))]
  have hf_mono : StrictMono f := by
    apply strictMono_nat_of_lt_succ; intro n; dsimp [f]
    have m_pos : 0 < (Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3) := by
      apply Finset.prod_pos; intro i _; apply Nat.pos_of_gt; apply Nat.pow_le_pow_of_le_right (by decide) (hf_ge_3 i)
    linarith [Nat.totient_pos m_pos]
  use Set.range (fun n => ⟨f n, by linarith [hf_ge_3 n]⟩)
  constructor
  · apply Set.infinite_range_of_injective (hf_mono.injective)
  · rintro ⟨i, hi⟩ ⟨j, hj⟩ hij; simp at *
    wlog h : i < j
    · exact (this hj hi hij.symm (hij.lt_or_lt.resolve_left h)).symm
    let m := (Finset.range j).prod (fun k => 2 ^ f k - 3)
    have h2m : Nat.Coprime 2 m := by
      apply Nat.coprime_prod_right; intro k hk; have := hf_ge_3 k
      apply Nat.coprime_of_dvd_of_mod_eq_one (n := 2) (m := 2 ^ f k - 3) (by use 2 ^ (f k - 1) - 2; linarith)
      rw [Nat.mod_eq_of_lt]; linarith; linarith
    have hmj : (2 ^ f j - 3) % m = 1 := by
      dsimp [f]; rw [Nat.add_mod, Nat.mul_mod, Nat.pow_add, Nat.pow_mul, Nat.mul_mod, Nat.pow_mod, Nat.pow_totient_mod_one h2m]
      have : m ≥ 5 := Finset.prod_induction (λ x => x ≥ 5) (by intro a b ha hb; linarith) (by linarith) (by intro i _; linarith [hf_ge_3 i])
      simp; rw [Nat.mod_eq_of_lt]; linarith; linarith
    apply Nat.coprime_of_dvd_of_mod_eq_one (Finset.dvd_prod_of_mem _ (Finset.mem_range.2 h)) hmj

end Imo1971P3
