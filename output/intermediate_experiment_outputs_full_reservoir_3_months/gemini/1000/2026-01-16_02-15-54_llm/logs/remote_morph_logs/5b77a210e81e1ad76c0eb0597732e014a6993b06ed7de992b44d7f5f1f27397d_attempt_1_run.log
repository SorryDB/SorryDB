import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ+
    | 0 => 3
    | n + 1 =>
      let L := (Finset.range (n + 1)).prod (fun i ↦ 2 ^ (f i).val - 3)
      ⟨(f n).val * L.totient + 2, by dsimp; nlinarith [f 0]⟩
  have f_gt_2 : ∀ n, (f n).val ≥ 2 := by
    intro n; induction' n with n ih; · rfl; · dsimp [f]; nlinarith
  have L_odd : ∀ n, (∏ i in Finset.range n, (2 ^ (f i).val - 3)) % 2 = 1 := by
    intro n; induction' n with n ih; · rfl
    rw [Finset.prod_range_succ, Nat.mul_mod, ih]; simp
    have := f_gt_2 n; omega
  have L_pos : ∀ n, (∏ i in Finset.range n, (2 ^ (f i).val - 3)) > 0 := by
    intro n; induction' n with n ih; · rfl
    rw [Finset.prod_range_succ]; apply Nat.mul_pos ih
    have := f_gt_2 n; omega
  have f_mono : StrictMono f := by
    apply strictMono_nat_of_lt_succ; intro n
    dsimp [f]; have := Nat.totient_pos (L_pos (n + 1)); nlinarith
  use Set.range f
  constructor
  · apply Set.infinite_range_of_injective f_mono.injective
  · rw [Set.pairwise_range]
    intro i j hij
    wlog h : i < j
    · exact (this j i hij.symm (not_lt.1 h)).symm
    dsimp; set L := (Finset.range j).prod (fun k ↦ 2 ^ (f k).val - 3)
    have hi : i < j := h
    have h1 : (2 ^ (f i).val - 3) ∣ L := Finset.dvd_prod_of_mem _ (Finset.mem_range.2 hi)
    have h2 : (2 ^ (f j).val - 3) % L = 1 % L := by
      dsimp [f]; set K := (f (j - 1)).val with hK
      have : (f j).val = K * L.totient + 2 := by
        cases j; · contradiction; · simp [f]
      rw [this, Nat.pow_add, Nat.pow_mul, ← Nat.mul_mod, Nat.pow_totient (L_pos j) (Nat.coprime_two_right.2 (L_odd j))]
      simp [Nat.one_pow, Nat.mul_mod]
    apply Nat.Coprime.symm; apply Nat.coprime_of_dvd_mod_eq_one h1
    rw [h2]; cases' L with L; · exact (L_pos j).ne rfl; · rfl
```
