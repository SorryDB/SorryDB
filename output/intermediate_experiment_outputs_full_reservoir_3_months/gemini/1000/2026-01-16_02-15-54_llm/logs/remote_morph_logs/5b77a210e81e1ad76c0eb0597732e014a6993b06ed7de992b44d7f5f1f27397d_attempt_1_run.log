import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ
    | 0 => 3
    | n + 1 => f n * Nat.eulerPhi ((Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3)) + 2
  have f_ge_3 (n : ℕ) : f n ≥ 3 := by
    induction' n with n ih; rfl
    rw [f]; have := Nat.eulerPhi_pos (Finset.prod_pos (fun i _ ↦ Nat.sub_pos_of_lt (by'
      have h := ih; linarith [Nat.pow_le_pow_of_le_right (by linarith) h])))
    linarith
  have f_strictMono : StrictMono f := strictMono_nat_of_lt_succ fun n ↦ by
    rw [f]; have hL := Finset.prod_pos (fun i _ ↦ Nat.sub_pos_of_lt (by'
      have h := f_ge_3 i; linarith [Nat.pow_le_pow_of_le_right (by linarith) h]))
    have := Nat.eulerPhi_pos hL; linarith [f_ge_3 n]
  use Set.range (fun n ↦ (⟨f n, by linarith [f_ge_3 n]⟩ : ℕ+))
  constructor
  · exact Set.infinite_range_iff.mpr f_strictMono.injective
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    wlog hij : i < j
    · exact (this hne.symm (Nat.lt_of_le_and_ne (Nat.le_of_not_lt hij) (fun h ↦ hne (by subst h; rfl)))).symm
    let L := (Finset.range j).prod (fun k ↦ 2 ^ f k - 3)
    have hL_odd : L % 2 = 1 := by
      apply Finset.prod_induction (λ x ↦ x % 2 = 1) (λ x y ha hb ↦ by rw [Nat.mul_mod, ha, hb]; rfl) rfl
      intro k _; rw [Nat.sub_mod, Nat.pow_mod]; rfl; linarith [f_ge_3 k]
    have h2L : Nat.Coprime 2 L := Nat.coprime_two_left.mpr hL_odd
    have h_mod : 2 ^ f j % L = 4 % L := by
      rw [f, pow_add, pow_mul, Nat.mul_mod, Nat.pow_mod, (Nat.ModEq.pow_eulerPhi h2L).mod_eq]
      simp [L]
    have h_mod_1 : (2 ^ f j - 3) % L = 1 % L := by
      rw [Nat.sub_mod, h_mod]; swap; linarith [f_ge_3 j]
      rw [Nat.mod_eq_of_lt (by' have hL_ge : L ≥ 5 := by'
        have : 2 ^ f 0 - 3 ≤ L := Finset.dvd_prod_of_mem (fun k ↦ 2 ^ f k - 3) (Finset.mem_range.mpr hij)
        linarith [f_ge_3 0]
      linarith)]
    exact Nat.coprime_of_dvd_of_coprime (Finset.dvd_prod_of_mem _ (Finset.mem_range.mpr hij))
      (Nat.coprime_of_mod_eq_one h_mod_1)

end Imo1971P3
```
