import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n; simp only [Set.mem_setOf_eq, answer]; constructor
  · rintro ⟨h0, A, B, hAB, h1, h2, h3, f, hf, h5⟩
    let k x := (Finset.univ.filter (x ∈ A ·)).card
    have hB : ∀ x ∈ B, k x = 2 := by
      intro x hx; have h2k : 2 ≤ k x := by
        rcases h3 x hx with ⟨i, j, h, hi, hj⟩
        have : {i, j} ⊆ Finset.univ.filter (x ∈ A ·) := by simp [hi, hj, h]
        simpa [h] using Finset.card_le_card this
      have : ∑ x in B, k x * (k x - 2) = 0 := by
        simp [k, Finset.sum_comm, h1, Finset.card_filter]
        rw [Finset.sum_congr rfl (λ i _ => (Finset.sum_congr rfl (λ j _ => (if h : j = i then (0 : ℕ) else (A i ∩ A j).card))))]
        · simp [h2, Finset.sum_itite, h1]; ring
        · intro i; simp [Finset.sum_comm]
      nlinarith [Finset.sum_eq_zero_iff_of_nonneg (λ y hy => by
        have : 2 ≤ k y := by
          rcases h3 y hy with ⟨i, j, h, hi, hj⟩; have : {i, j} ⊆ Finset.univ.filter (y ∈ A ·) := by simp [hi, hj, h]
          simpa [h] using Finset.card_le_card this
        nlinarith) this hx]
    have : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← Finset.sum_congr rfl (λ i _ => h5 i), Finset.sum_card_filter, Finset.sum_comm]
      simp [k, hB, ← Finset.sum_filter, hAB]
    rw [← Nat.even_iff_two_dvd, ← Nat.even_mul, this]; exact ⟨h0, ⟨_, rfl⟩⟩
  · rintro ⟨h0, m, rfl⟩; let n := 2 * m
    let V := Fin (2 * n + 1); let B' : Finset (Finset V) := Finset.univ.powersetLen 2
    let A' (i : V) : Finset (Finset V) := B'.filter (i ∈ ·)
    let f' (s : Finset V) : ℕ := if ∃ i j : V, s = {i, j} ∧ i.1 < j.1 ∧ (j.1 - i.1 ≤ m ∨ j.1 - i.1 > 2 * n - m) then 0 else 1
    use n, h0, (λ i => (A' i).map ⟨encode, encode_injective⟩), B'.map ⟨encode, encode_injective⟩
    simp only [Finset.mem_map, Function.Embedding.coeFn_mk, forall_exists_index, and_imp, forall_apply_eq_imp_iff₂]
    refine ⟨λ i s hs => hs, λ i => by simp [Finset.card_powersetLen, Nat.choose_two_right, Nat.card_eq_fintype_card],
      λ i j hij => by simp [Finset.card_filter, hij, Finset.card_singleton], λ s hs => ?_,
      ⟨λ x => if h : (decode x).isSome then f' (decode x).get! else 0, λ x hx => ?_, λ i => ?_⟩⟩
    · simp at hs; rcases hs with ⟨s, hs, rfl⟩; rcases Finset.card_eq_two.1 hs with ⟨i, j, hij, rfl⟩; use i, j, hij; simp
    · rcases (Finset.mem_map).1 hx with ⟨s, hs, rfl⟩; simp [encode_injective, hs]; split_ifs <;> simp
    · simp [encode_injective, f', n]; have : ∀ j, j ≠ i ↔ {i, j} ∈ B' := by intro j; simp [Finset.card_eq_two]
      let D := {d : ℕ | 0 < d ∧ d ≤ 2 * m ∧ (d ≤ m ∨ d > 2 * m - m)}
      have hD : D.card = 2 * m := by
        have : D = Finset.range (m + 1) \ {0} ∪ (Finset.range (2 * m + 1) \ Finset.range (m + 1)) := by ext x; simp [D]; constructor <;> rintro (h|h) <;> simp [h] <;> omega
        simp [this, Finset.card_union_eq, Finset.card_range, Finset.range_subset_range]
      have : ∀ j, j ≠ i → (if (i.1 < j.1 ∧ (j.1 - i.1 ≤ m ∨ j.1 - i.1 > 2 * n - m)) ∨ (j.1 < i.1 ∧ (i.1 - j.1 ≤ m ∨ i.1 - j.1 > 2 * n - m)) then (0:ℕ) else 1) = 0 ↔ (if i.1 < j.1 then j.1 - i.1 else 2 * n + 1 - (i.1 - j.1)) ∈ D := sorry
      sorry

