import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n; constructor
  · rintro ⟨h0, A, B, hAB, hA, hI, hB, f, hfB, hfA, rfl⟩
    let S := Finset.univ (α := Fin (2 * n + 1))
    let m x := (S.filter (x ∈ A ·)).card
    have hm : ∀ x ∈ B, m x = 2 := by
      have h1 : (∑ x in B, (m x : ℤ)) = (2 * n + 1) * (2 * n) := by
        simp only [m, Finset.sum_card_filter, hA, Finset.sum_const, Finset.card_univ, smul_eq_mul]
      have h2 : (∑ x in B, (m x : ℤ) * (m x - 1)) = (2 * n + 1) * (2 * n) := by
        simp only [m, ← Finset.sum_card_pair_filter_eq_sum_card_filter_mul_card_filter_sub_card_filter, Finset.sum_comm, hI, Finset.card_erase, Finset.card_univ, Finset.sum_const, smul_eq_mul, Finset.filter_univ, Finset.card_univ]
      have : ∑ x in B, ((m x : ℤ) - 2) * m x = 0 := by
        rw [Finset.sum_congr rfl (λ x _ => (by ring : (m x - 2) * m x = m x * (m x - 1) - m x)), Finset.sum_sub, h2, h1, sub_self]
      intro x hx; apply (Finset.sum_eq_zero_iff_of_nonpos ?_ this) x hx
      intro x hx; rcases hB x hx with ⟨i, j, hne, hi, hj⟩
      have : 2 ≤ m x := Finset.card_le_card_of_subset (λ k hk => by simp at hk; rcases hk with rfl|rfl <;> simp [*]) (by simp [hne])
      nlinarith
    have : (2 * n + 1) * n = 2 * (B.filter (λ x => f x = 0)).card := by
      rw [← Finset.sum_card_filter, ← hfA, Finset.sum_comm]
      simp only [Finset.filter_filter, m]
      exact Finset.sum_congr rfl (λ x hx => by simp [hfB x hx, hm x hx])
    exact ⟨h0, by rw [← Nat.even_iff_exists_two_mul, Nat.even_mul] at this; exact this.resolve_left (by decide)⟩
  · rintro ⟨h0, h2n⟩; rcases h2n with ⟨k, rfl⟩; let n := 2 * k
    let V := Fin (2 * n + 1); let B := (Finset.univ : Finset V).sym2.filter (¬·.IsDiag)
    let A (i : V) := B.filter (i ∈ ·); use h0, (λ i => (A i).image (Quotient.out)), (B.image (Quotient.out))
    have h_card : ∀ i, (A i).card = 2 * n := λ i => by simp [A, Finset.card_sym2_filter_mem_not_diag]
    refine ⟨λ i => Finset.image_subset_image (Finset.filter_subset _ _), λ i => by rw [Finset.card_image_of_injOn, h_card]; intro x hx y hy; apply Quotient.out_inj,
      λ i j h => ?_, λ x hx => ?_, ?_⟩
    · rw [← Finset.image_inter Quotient.out_inj, Finset.card_image_of_injOn Quotient.out_inj]
      simp [A, ← Finset.filter_and, h, Finset.card_sym2_filter_mem_mem_not_diag]
    · rcases Finset.mem_image.1 hx with ⟨y, hy, rfl⟩; rcases Quotient.exists_rep y with ⟨⟨i, j⟩, rfl⟩
      simp at hy; exact ⟨i, j, hy, by simp [hy, A]⟩
    · let f x := if ∃ i j : V, x = (A i ∩ A j).image (Quotient.out) ∧ ((i.1 < j.1 ∧ j.1 - i.1 ≤ k) ∨ (j.1 < i.1 ∧ i.1 - j.1 ≤ k) ∨ (i.1 < j.1 ∧ j.1 - i.1 ≥ n + 1 - k) ∨ (j.1 < i.1 ∧ i.1 - j.1 ≥ n + 1 - k)) then 0 else 1
      use (λ x => if ∃ y ∈ B, Quotient.out y = x ∧ (Quotient.out y).1.val < (Quotient.out y).2.val ∧ (((Quotient.out y).2.val - (Quotient.out y).1.val ≤ k) ∨ ((Quotient.out y).2.val - (Quotient.out y).1.val ≥ n + 1 - k)) then 0 else 1)
      sorry

