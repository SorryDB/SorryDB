import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n; constructor
  · rintro ⟨h0, A, B, hAB, hA, hInter, hB, f, hf, hcount, rfl⟩
    let d x := (Finset.univ.filter (x ∈ A ·)).card
    have h1 : (2 * n + 1) * (2 * n) = ∑ x ∈ B, d x := by
      rw [← Finset.sum_card_fiberwise (h := fun x i => x ∈ A i)]; simp [hA, hAB]
    have h2 : (2 * n + 1) * (2 * n) = ∑ x ∈ B, d x * (d x - 1) := by
      rw [← Finset.sum_comm]; simp_rw [Finset.sum_filter, Finset.sum_ite, Finset.sum_const_zero, add_zero]
      simp_rw [Finset.card_eq_sum_ones, Finset.sum_comm, ←Finset.card_filter]
      simp [hInter, Finset.card_erase, hInter]
    have h_deg : ∀ x ∈ B, d x = 2 := by
      have h3 : ∑ x ∈ B, d x * (d x - 2) = 0 := by
        rw [Finset.sum_sub_distrib, ← h2, ← h1, Nat.mul_sub_left_distrib]; simp
      intro x hx
      have d_ge_2 : ∀ y ∈ B, d y ≥ 2 := fun y hy => by
        rcases hB y hy with ⟨i, j, hij, hi, hj⟩
        exact (Finset.card_le_card (show {i, j} ⊆ _ from fun k hk => by
          simp at hk; rcases hk with (rfl|rfl) <;> simp [hi, hj])).trans_at_top (by simp [hij])
      have : ∀ y ∈ B, d y * (d y - 2) = 0 := Finset.sum_eq_zero_iff_of_nonneg (fun y hy => by
        exact Nat.zero_le _) |>.mp h3
      exact (Nat.mul_eq_zero.mp (this x hx)).resolve_left (by linarith [d_ge_2 x hx])
    have : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← Finset.sum_card_filter, ← hcount, Finset.sum_comm]
      simp_rw [Finset.filter_filter, (f · = 0), d, h_deg]; simp
    exact ⟨h0, (Nat.even_mul.mp ⟨_, this.symm⟩).resolve_right (by decide)⟩
  · rintro ⟨h0, h_even⟩
    obtain ⟨k, rfl⟩ := h_even
    let n := 2 * k
    let V := Fin (2 * n + 1)
    let B_set : Finset (Finset V) := Finset.univ.powersetCard 2
    let e : Finset V ≃ ℕ := Denumerable.eqv _
    refine ⟨h0, (fun i => B_set.filter (i ∈ ·) |>.map e.toEmbedding), B_set.map e.toEmbedding, ?_, ?_, ?_, ?_, ?_⟩
    · intro i; simp
    · intro i; simp [Finset.card_filter, Finset.powersetCard, n]
    · intro i j hij; simp [hij, Finset.filter_filter, Finset.card_filter, Finset.powersetCard]
      rw [← Finset.card_singleton {i, j}]; congr; ext s; simp [hij]; aesop
    · intro x; simp; rintro s hs; exact ⟨s.min' (by aesop), s.max' (by aesop), by aesop, by aesop, by aesop⟩
    · obtain ⟨E, hE⟩ := exists_regular_graph (2 * n + 1) n (by simp) (by linarith)
      let f s := if s ∈ E.edgeFinset then (0:ℕ) else 1
      refine ⟨f ∘ e.symm, ?_, ?_⟩
      · intro x _; by_cases h : (f ∘ e.symm) x = 0 <;> simp [h]
      · intro i; simp [Finset.filter_map, Function.Embedding.coeFn_mk, hE.reg]
