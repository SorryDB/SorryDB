import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  simp only [Set.mem_setOf_eq, Nat.even_iff, ← Nat.mod_two_eq_zero]
  constructor
  · rintro ⟨n, hn, A, B, hAB, hcard, hint, hmem, f, hf, hfi, rfl⟩
    let k x := (Finset.univ.filter (x ∈ A ·)).card
    have h1 : ∑ x in B, k x = (2 * n + 1) * (2 * n) := by
      simp [k, Finset.sum_card_filter_univ_mem, hcard]
    have h2 : ∑ x in B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by
      simp [k, Finset.card_filter, ← Finset.card_filter_univ_mem, ← Finset.sum_card_filter_univ_mem]
      simp [Finset.filter_filter, ← Finset.inter_def, hint, Finset.card_univ, Finset.card_erase, hcard]
    have h3 : ∀ x ∈ B, k x = 2 := by
      intro x hx; have hkx : 2 ≤ k x := by
        obtain ⟨i, j, hij, hi, hj⟩ := hmem x hx
        have : {i, j} ⊆ Finset.univ.filter (λ i => x ∈ A i) := by simp [hi, hj, hij]
        simpa using Finset.card_le_card this
      have : ∑ x in B, k x * (k x - 2) = 0 := by simp [Nat.mul_sub_left_distrib, ← Finset.sum_sub_distrib, h1, h2]
      exact (Finset.sum_eq_zero_iff.1 this x hx |> (λ h => by nlinarith))
    have hsum := (by rw [← Finset.sum_card_filter, ← hfi, Finset.sum_comm]; simp [h3] : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card)
    rw [Nat.even_iff, ← Nat.mod_two_eq_zero, ← hsum]; simp
  · rintro ⟨hn, m, rfl⟩; let n := 2 * m; let V := Fin (2 * n + 1)
    let e (p : V × V) := p.1.val * (2 * n + 1) + p.2.val
    let B := (Finset.univ : Finset (V × V)).filter (λ p => p.1 < p.2) |>.map ⟨e, by aesop⟩
    let A i := (Finset.univ.erase i).map ⟨λ j => if i < j then e (i, j) else e (j, i), by aesop⟩
    let f x := if ∃ i j, i < j ∧ x = e (i, j) ∧ (j.val - i.val ≤ m ∨ j.val - i.val > 2 * m) then 0 else 1
    use n, hn, A, B; repeat' constructor <;> try (simp [A, B]; intro; aesop)
    · intro i j hij; ext x; simp [A]; constructor <;> (intro h; aesop)
    · intro x hx; simp [B] at hx; aesop
    · use f; simp [f]; intro i;
      let S1 := (Finset.univ.filter (λ j : V => i < j ∧ j.val - i.val ≤ m))
      let S2 := (Finset.univ.filter (λ j : V => j < i ∧ i.val - j.val ≤ m))
      have : (A i).filter (f · = 0) = (S1 ∪ S2).map ⟨λ j => if i < j then e (i, j) else e (j, i), by aesop⟩ := by
        ext x; simp [A, S1, S2]; constructor
        · rintro ⟨j, hj, hx, hf0⟩; use j; split_ifs at hf0 <;> aesop
        · rintro ⟨j, hj, hx⟩; use j; aesop
      rw [Finset.card_map, Finset.card_union_of_disjoint (by simp [S1, S2, Finset.disjoint_filter]; intro; omega)]
      simp [S1, S2]; rw [show (Finset.univ.filter (λ j : V => i < j ∧ j.val - i.val ≤ m)).card = if i.val + m < 2*n+1 then m else 2*n-i.val by sorry]
      sorry
