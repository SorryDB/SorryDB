import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  simp only [Set.mem_setOf_eq, answer]
  constructor
  · rintro ⟨n, h0, A, B, hAB, h1, h2, h3, f, hf01, h5, rfl⟩
    let K x := (Finset.univ : Finset (Fin (2 * n + 1))).filter (x ∈ A ·)
    have h_sum_k : ∑ x in B, (K x).card = (2 * n + 1) * (2 * n) := by
      rw [Finset.sum_comm]; simp [h1, Finset.card_univ]
    have h_sum_k2 : ∑ x in B, (K x).card * ((K x).card - 1) = (2 * n + 1) * (2 * n) := by
      simp_rw [Finset.card_mul_diff_one_eq_pair_filter, ← Finset.sum_comm, Finset.filter_mem_univ_eq_card,
        Finset.sum_comm (s := Finset.univ), Finset.filter_filter, ← Finset.card_inter, h2, Finset.filter_ne]; simp
    have h_k_x : ∀ x ∈ B, (K x).card = 2 := by
      intro x hx
      have : 2 ≤ (K x).card := by
        obtain ⟨i, j, hij, hix, hjx⟩ := h3 x hx
        exact Finset.one_lt_card_iff.mpr ⟨i, by simp [K, hix], j, by simp [K, hjx], hij.symm⟩
      have : ∑ x in B, ((K x).card - 2) * (K x).card = 0 := by
        simp_rw [Nat.mul_sub_left_distrib, h_sum_k2, h_sum_k, Nat.mul_comm 2, ← Finset.mul_sum, h_sum_k, Nat.sub_self]
      exact Nat.eq_of_mul_eq_zero (Finset.sum_eq_zero_iff.mp this x hx) |>.resolve_left (by linarith)
    have h_parity : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← h5, Finset.sum_const, Finset.card_univ, ← Finset.sum_card_filter, Finset.sum_comm]
      simp_rw [Finset.filter_filter, h_k_x, Finset.sum_const, Nat.mul_comm]; apply Finset.sum_congr rfl
      intro x hx; simp [hx]
    exact ⟨h0, Nat.even_mul.mp ⟨_, h_parity.symm⟩ |>.resolve_left (by simp)⟩
  · rintro ⟨h0, k, rfl⟩
    let n := 2 * k; use n, h0; let V := Fin (2 * n + 1)
    let e (p : V × V) : ℕ := p.1.1 * (2 * n + 1) + p.2.1
    let B_pairs := (Finset.univ : Finset (V × V)).filter (fun p ↦ p.1 < p.2)
    let A i := (B_pairs.filter (fun p ↦ p.1 = i ∨ p.2 = i)).map ⟨e, fun _ _ h ↦ by simp [e] at h; linarith⟩
    use A, B_pairs.map ⟨e, fun _ _ h ↦ by simp [e] at h; linarith⟩
    have h_card : ∀ i, (A i).card = 2 * n := by intro i; simp [A, B_pairs, Finset.card_filter]; rfl
    have h_int : ∀ i j, i ≠ j → (A i ∩ A j).card = 1 := by
      intro i j hij; simp [A, B_pairs, Finset.card_inter, Finset.filter_filter]; obtain h | h := hij.lt_or_gt
      · use e (i, j); simp [h, hij]; intro p hp; ext; exact hp
      · use e (j, i); simp [h, hij]; intro p hp; ext; exact hp
    have h_at_least : ∀ x ∈ B_pairs.map ⟨e, fun _ _ h ↦ by simp [e] at h; linarith⟩, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j := by
      intro x hx; simp at hx; obtain ⟨p, hp, rfl⟩ := hx; use p.1, p.2; simp [hp, hp.2.ne']
    use (fun _ ↦ (by simp)), h_card, h_int, h_at_least
    let f x := if ∃ p ∈ B_pairs, e p = x ∧ ((p.2.1 - p.1.1 + (2 * n + 1)) % (2 * n + 1) ∈ Set.Icc 1 k ∪ Set.Icc (n + 1) (n + k)) then 0 else 1
    use f; constructor
    · intro x hx; simp [f]
    · intro i; simp [A, f, n, k]; sorry
