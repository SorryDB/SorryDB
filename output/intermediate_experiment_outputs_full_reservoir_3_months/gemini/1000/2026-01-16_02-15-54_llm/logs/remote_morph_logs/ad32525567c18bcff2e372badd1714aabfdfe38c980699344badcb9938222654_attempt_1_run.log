import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  simp only [Set.mem_setOf_eq]
  constructor
  · rintro ⟨n, h_pos, A, B, hAB, h_card, h_inter, h_at_least_two, f, h_f, h_f_n, rfl⟩
    constructor
    · exact h_pos
    · let s := Finset.univ (α := Fin (2 * n + 1))
      have h1 : ∑ x in B, (s.filter (x ∈ A ·)).card = (2 * n + 1) * (2 * n) := by
        rw [Finset.sum_card_filter]; simp [h_card]
      have h2 : ∑ x in B, (s.filter (x ∈ A ·)).card * ((s.filter (x ∈ A ·)).card - 1) = (2 * n + 1) * (2 * n) := by
        rw [← Finset.sum_card_filter_univ_prod]; simp_rw [Finset.filter_filter]
        have : ∀ i j, (s.filter (fun x => x ∈ A i ∧ x ∈ A j)).card = if i = j then 2 * n else 1 := by
          intro i j; split_ifs with h; subst h; simp [h_card]; exact h_inter i j h
        simp_rw [this, Finset.sum_ite, Finset.filter_ne', Finset.card_univ, Fintype.card_fin]; simp; ring
      have h_k2 : ∀ x ∈ B, (s.filter (x ∈ A ·)).card = 2 := by
        intro x hx; let kx := (s.filter (x ∈ A ·)).card
        have : ∑ x in B, kx * (kx - 2) = 0 := by
          simp_rw [Nat.mul_sub_left_distrib, ← h2, ← h1, Finset.sum_sub]; ring
        have hkx := Finset.sum_eq_zero_iff.mp this x hx
        have : kx ≥ 2 := by
          obtain ⟨i, j, hij, hi, hj⟩ := h_at_least_two x hx
          exact Finset.card_le_card (by intro z; simp; rintro (rfl|rfl) <;> assumption) (by simp [hij])
        exact (Nat.eq_zero_of_mul_eq_zero hkx).resolve_left (by linarith)
      have : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
        rw [← h_f_n, Finset.sum_card_filter, Finset.sum_congr rfl (fun x hx ↦ h_k2 x hx.1)]
        simp [Finset.sum_const]
      exact (Nat.even_mul.mp ⟨_, this.symm⟩).resolve_left (by simp)
  · rintro ⟨h_pos, h_even⟩; obtain ⟨k, rfl⟩ := h_even; let n := 2 * k; let V := Fin (2 * n + 1)
    let e := Fintype.equivFin (Sym2 V); let B := (Finset.univ.filter (fun x : Sym2 V ↦ ¬x.IsDiag)).map e.toEmbedding
    let A i := (Finset.univ.filter (fun j ↦ j ≠ i)).map ⟨(fun j ↦ e ⟦(i, j)⟧), (fun _ _ h ↦ e.injective (by simpa using h))⟩
    use n, h_pos, A, B; constructor; · simp [A, B]; rintro i j hij; exact ⟨j, hij, rfl⟩
    constructor; · simp [A, n]
    constructor; · intro i j hij; simp [A]; apply Finset.card_eq_one_of_forall_mem
      · use e ⟦(i, j)⟧; simp [hij, hij.symm]
      · rintro x; simp; rintro j' hj' rfl i' hi' h; cases' Sym2.eq_iff.mp (e.injective h) with hh hh <;> aesop
    constructor; · intro x hx; simp [B] at hx; obtain ⟨s, hs1, rfl⟩ := hx; obtain ⟨i, j, hij, rfl⟩ := Sym2.exists_pair_ne hs1
      refine ⟨i, j, hij, ?_, ?_⟩ <;> simp [A] <;> [refine ⟨j, hij, rfl⟩; refine ⟨i, hij.symm, by rw [Sym2.eq_swap]; rfl⟩]
    · let f (x : ℕ) : ℕ := if (let s := e.symm x; let p := s.out; (p.2.1 + (2 * n + 1) - p.1.1) % (2 * n + 1) ≤ n / 2) then 0 else 0
      use (fun x ↦ if (A (0 : V)).filter (· = x) ≠ ∅ then (if (A (0 : V)).filter (· = x).card = 1 then 0 else 0) else 0); simp
      -- For existence, any set matching the parameters works. $n$ even is both necessary and sufficient.
      -- A full construction would involve a more elaborate definition of f.
      sorry

