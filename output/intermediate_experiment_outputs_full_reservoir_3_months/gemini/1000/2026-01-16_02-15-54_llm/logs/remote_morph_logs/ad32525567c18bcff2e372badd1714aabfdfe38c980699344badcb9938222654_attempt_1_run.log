import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  constructor
  · rintro ⟨n, hn, A, B, hAB, hA, hA2, hB, ⟨f, hf_vals, hf_count⟩, rfl⟩
    let k x := (Finset.univ.filter (λ i => x ∈ A i)).card
    have h_sum1 : ∑ i, (A i).card = ∑ x ∈ B, k x := by simp [k, Finset.card_eq_sum_ones, Finset.sum_comm]
    have h_sum2 : ∑ i, ∑ j, (A i ∩ A j).card = ∑ x ∈ B, (k x)^2 := by
      simp [k, Finset.card_eq_sum_ones, pow_two, Finset.sum_comm]
    have h_k_sum : ∑ x ∈ B, k x = (2 * n + 1) * (2 * n) := by
      rw [← h_sum1, Finset.sum_const, Finset.card_fin]; exact hA _
    have h_k2_sum : ∑ x ∈ B, (k x)^2 = 2 * (2 * n + 1) * (2 * n) := by
      rw [← h_sum2, Finset.sum_univ_diag_add_sum_eq_sum_pair]
      simp [hA, hA2, Finset.sum_const, Finset.card_fin, Nat.mul_comm]
    have h_k2 : ∀ x ∈ B, k x = 2 := by
      intro x hx; have h_k_ge : k x ≥ 2 := by
        obtain ⟨i, j, hne, hi, hj⟩ := hB x hx
        have : {i, j} ⊆ Finset.univ.filter (x ∈ A ·) := by simp [hi, hj, hne]
        simpa using Finset.card_le_card this
      have h_zero : ∑ x ∈ B, (k x - 2) * k x = 0 := by
        rw [Finset.sum_sub_distrib]; simp_rw [mul_sub, pow_two]; rw [h_k2_sum, h_k_sum]; ring
      refine Nat.eq_of_mul_eq_zero hx (Finset.sum_eq_zero_iff_of_nonneg (λ x hx => ?_) h_zero x hx)
      exact Nat.mul_nonneg (Nat.sub_nonneg (h_k_ge x hx)) (Nat.zero_le _)
    have h_f : (2 * n + 1) * n = 2 * (B.filter (λ x => f x = 0)).card := by
      rw [← Finset.sum_const (n := n), ← hf_count, Finset.sum_comm]
      simp_rw [Finset.sum_filter, Finset.card_eq_sum_ones, ← Finset.sum_filter, h_k2, Finset.sum_const]
    exact (Nat.even_mul.mp ⟨_, h_f.symm⟩).resolve_left (by decide)
  · rintro ⟨hn, ⟨k, rfl⟩⟩; let n := 2 * k; let V := Fin (2 * n + 1)
    let B := (Finset.univ : Finset (V × V)).filter (λ p => p.1 < p.2)
    let A (i : V) := B.filter (λ p => p.1 = i ∨ p.2 = i)
    let f (p : V × V) := (p.2.val - p.1.val) % 2
    have hA : ∀ i, (A i).card = 2 * n := by
      intro i; simp [Finset.filter_or]; rw [Finset.card_union_eq];
      · simp [Fin.card_filter_lt, Fin.card_filter_gt]; ring
      · simp; intro x h1 h2; exact (h1.trans h2).ne rfl
    have hA2 : ∀ i j, i ≠ j → (A i ∩ A j).card = 1 := by
      intro i j hne; rcases hne.lt_or_gt with h | h
      · have : A i ∩ A j = {(i, j)} := by ext p; simp [A, h.ne, h.asymm, hne, hne.symm]; aesop
        simp [this]
      · have : A i ∩ A j = {(j, i)} := by ext p; simp [A, h.ne, h.asymm, hne, hne.symm]; aesop
        simp [this]
    refine ⟨n, hn, (λ i => (A i).map ⟨(λ p => p.1.val * (2*n+1) + p.2.val), by simp [V]; rintro ⟨a1, a2⟩ ⟨b1, b2⟩; aesop⟩),
      B.map ⟨(λ p => p.1.val * (2*n+1) + p.2.val), by simp [V]; rintro ⟨a1, a2⟩ ⟨b1, b2⟩; aesop⟩, (by simp), ?_, ?_, ?_, ?_⟩
    · simp [hA]
    · simp [hA2]
    · simp [A]; intro x hx; use x.1, x.2; simp [hx.1, hx.2, hx.1.ne]
    · refine ⟨(λ x => (x % (2*n+1) - (x / (2*n+1))) % 2), ?_⟩; constructor
      · simp; intro x hx; apply Nat.mod_two_is_0_or_1
      · intro i; let f_val (p : V × V) := (p.2.val - p.1.val) % 2
        have : ∀ p ∈ A i, f (p.1.val * (2 * n + 1) + p.2.val) = f_val p := by
          intro p hp; simp [A, f] at hp; simp [hp.1.val, hp.2.val, f_val]
          rw [Nat.div_add_mod, Nat.mod_eq_of_lt]
          · simp; rw [Nat.add_div, Nat.div_eq_of_lt (p := 2*n+1)]; rotate_left
            · exact p.1.2; · exact p.2.2; · exact p.2.2
            simp; rw [Nat.div_eq_of_lt p.1.2]; simp
          · exact p.2.2.trans_le (by simp [V]; ring)
        simp [this]; have : ∀ p ∈ A i, f_val p = 0 ↔ (p.1.val + p.2.val) % 2 = (2 * i.val) % 2 := sorry
        sorry
