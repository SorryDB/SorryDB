import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  simp [answer]; ext n; constructor
  · rintro ⟨h_pos, A, B, hAB, h_card, h_inter, h_at_least_2, f, h_f, h_f_n⟩
    let k x := (Finset.univ.filter (x ∈ A ·)).card
    have h_sum1 : ∑ x ∈ B, k x = (2 * n + 1) * (2 * n) := by rw [← Finset.sum_comm]; simp [h_card]
    have h_sum2 : ∑ x ∈ B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by
      rw [← Finset.sum_comm]; simp_rw [Finset.sum_filter, ← Finset.card_filter]; simp [h_inter, h_card, Finset.filter_ne]
    have h_k2 : ∀ x ∈ B, k x = 2 := fun x hx ↦ by
      have h_ge2 : k x ≥ 2 := by obtain ⟨i, j, hne, hi, hj⟩ := h_at_least_2 x hx; have : {i, j} ⊆ Finset.univ.filter (x ∈ A ·) := by simp [hi, hj]; simpa using Finset.card_le_of_subset this
      have : ∑ x ∈ B, (k x - 2) * k x = 0 := by rw [Finset.sum_mul, Finset.sum_sub_distrib, h_sum2, ← h_sum1]; simp
      exact (Nat.mul_eq_zero.mp (Finset.sum_eq_zero_iff.mp this x hx)).resolve_right (by linarith)
    have : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← h_f_n, Finset.sum_comm]; simp_rw [Finset.filter_filter, h_k2, Finset.sum_const, Nat.smul_eq_mul]; rfl
    exact (Nat.even_mul.mp ⟨_, this⟩).resolve_right (by decide)
  · rintro ⟨h_pos, k, rfl⟩; let n := 2 * k; let V := Fin (2 * n + 1)
    let B_ : Finset (Finset V) := Finset.univ.powersetCard 2; let A_ i := B_.filter (i ∈ ·)
    let f_ (s : Finset V) : ℕ := if h : s.card = 2 then (if (s.max' h).val - (s.min' h).val ∈ ({m + 1 | m : Fin k} : Set ℕ) ∪ {(2 * n + 1) - (m + 1) | m : Fin k} then 0 else 1) else 1
    let encode (s : Finset V) : ℕ := s.val.sum (λ v ↦ 2 ^ v.val); have h_enc : ∀ s₁ s₂ : Finset V, encode s₁ = encode s₂ → s₁ = s₂ := sorry
    let B := B_.map ⟨encode, h_enc⟩; let A i := (A_ i).map ⟨encode, h_enc⟩
    let f x := if hx : x ∈ B then f_ (B_.filter (λ s ↦ encode s = x) |>.choose (by rwa [Finset.mem_map] at hx)) else 1
    use n, h_pos, A, B, (by simp), (by simp [Finset.card_map, Finset.card_filter, Finset.card_powersetCard]), (by intro i j hij; simp [hij, Finset.ext_iff, Finset.card_eq_one]; use encode {i, j}; simp [hij]), (by intro x hx; rwa [Finset.mem_map] at hx; obtain ⟨s, hs, rfl⟩ := hx; obtain ⟨i, j, hne, rfl⟩ := Finset.mem_powersetCard.mp hs; use encode (A_ i).choose sorry, encode (A_ j).choose sorry; sorry), f, (by intro x hx; simp [f, hx]), (by intro i; sorry)
