      have h_sum_k2 : ∑ i, ∑ j in Finset.univ.filter (λ j => i < j), (A i ∩ A j).card = ∑ x in B, (k x).card * ((k x).card - 1) / 2 := by
        simp [k, Finset.card_eq_sum_ones, Finset.sum_filter, Finset.sum_comm, Finset.inter_def]
        apply Finset.sum_congr rfl; intro y hy
        rw [←Finset.card_filter]; congr; ext i; constructor <;> intro h <;> simp at h <;> simp [h]
        rcases h with ⟨hi, j, hj, hij⟩; exact ⟨hi, j, hij, hj⟩
      have s1 : ∑ x in B, (k x).card = 2 * n * (2 * n + 1) := by rw [←h_sum_k]; simp [h_1]
      have s2 : ∑ x in B, (k x).card * ((k x).card - 1) = 2 * n * (2 * n + 1) := by
