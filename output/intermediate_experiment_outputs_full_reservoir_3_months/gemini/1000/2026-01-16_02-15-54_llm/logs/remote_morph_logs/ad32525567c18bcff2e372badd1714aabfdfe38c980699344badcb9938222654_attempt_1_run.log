      by_contra h; have : 0 < ∑ x in B, ((S x).card - 2) * (S x).card := Finset.sum_pos (λ y hy =>
        Nat.zero_le _) ⟨x, hx, Nat.mul_pos (Nat.sub_pos_of_lt (lt_of_le_of_ne h2S (Ne.symm h))) (by linarith)⟩
      linarith [this]
    have h_f : 2 * (B.filter (f · = 0)).card = n * (2 * n + 1) := by
      rw [← Finset.sum_card_filter_eq_sum_filter_card]
      simp_rw [Finset.filter_filter, (λ i x => show f x = 0 ∧ x ∈ A i ↔ x ∈ {y ∈ A i | f y = 0} by simp), hf0]
