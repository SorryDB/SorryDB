@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n; simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]; constructor
  · rintro ⟨h0, A, B, hAB, hA, hI, hB, f, hf, hf0⟩
    have k_eq_2 : ∀ x ∈ B, (Finset.univ.filter (λ i => x ∈ A i)).card = 2 := by
      intro x hx
      have h_ge : ∀ y ∈ B, 2 ≤ (Finset.univ.filter (λ i => y ∈ A i)).card := by
        intro y hy; rcases hB y hy with ⟨i, j, hne, hi, hj⟩
        exact (Finset.card_le_card (by simp [hi, hj, hne]; intro z hz; simp at hz; rcases hz with rfl|rfl <;> simp [*])).trans_eq (Finset.card_doubleton hne).symm
      have h_sum : ∀ i, ∑ y in A i, ((Finset.univ.filter (λ j => y ∈ A j)).card - 1) = 2 * n := by
        intro i
        have : ∑ y in A i, ((Finset.univ.filter (λ j => y ∈ A j)).card - 1) = ∑ j in Finset.univ.erase i, (A i ∩ A j).card := by
          simp_rw [Finset.card_eq_sum_ones, Finset.sum_filter, Finset.sum_comm, Finset.filter_mem_univ]
          rw [Finset.sum_erase_eq_sub (Finset.mem_univ i), Finset.sum_comm]
          simp_rw [← Finset.sum_filter, Finset.card_eq_sum_ones, Finset.filter_filter]
          simp [hA i]
        rw [this, Finset.sum_congr rfl (λ j hj => hI i j (Finset.mem_erase.1 hj).1), Finset.card_erase_of_mem (Finset.mem_univ i), Finset.sum_const, hA i, Nat.mul_one]
      have h_one : ∀ i, ∀ y ∈ A i, (Finset.univ.filter (λ j => y ∈ A j)).card - 1 = 1 := by
        intro i; apply (Finset.sum_eq_card_nsmul _ _ (2*n)).1
        · intro y hy; exact Nat.le_sub_of_add_le (h_ge y (hAB i hy))
        · rw [h_sum i, hA i, Nat.nsmul_one]
      rcases hB x hx with ⟨i, j, hne, hi, hj⟩
      exact Nat.sub_eq_iff_eq_add (Nat.le_trans (by norm_num) (h_ge x hx)) |>.1 (h_one i x hi)
    have h_sum : (2 * n + 1) * n = 2 * (B.filter (λ x => f x = 0)).card := by
      rw [← Finset.sum_const, ← hf0, Finset.sum_comm]
      simp_rw [Finset.sum_filter, Finset.sum_comm, Finset.filter_mem_univ, ← Finset.card_eq_sum_ones, k_eq_2, Finset.sum_const, Nat.nsmul_eq_mul]
      apply Finset.sum_congr rfl; intro i _; apply Finset.sum_congr (by ext x; simp [hAB i]) (λ x hx => rfl)
    exact ⟨h0, Nat.even_mul.1 (this ▸ ⟨(B.filter (λ x => f x = 0)).card, rfl⟩) |>.resolve_left (by norm_num)⟩
  · rintro ⟨h0, h_even⟩; sorry
