import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  simp only [answer]; ext n; constructor
  · rintro ⟨n, hn, A, B, hAB, hA, hI, hB, f, hf, hAf, rfl⟩
    let k x := (Finset.univ.filter (x ∈ A ·)).card
    have h1 : ∑ i, (A i).card = (2 * n + 1) * (2 * n) := by simp [hA]
    have h2 : ∑ i, (A i).card = ∑ x in B, k x := by rw [Finset.sum_comm]; simp [k, Finset.sum_card_filter, hAB]
    have h3 : ∑ x in B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by
      simp [k, Finset.card_filter, ← Finset.sum_comm (s := Finset.univ), ← Finset.filter_filter, hI]
    have h_kx : ∀ x ∈ B, k x = 2 := by
      intro x hx; have kx2 : k x ≥ 2 := by
        rcases hB x hx with ⟨i, j, hne, hi, hj⟩
        exact (Finset.card_le_of_subset (by simp [hi, hj])).trans_refl' (by simp [hne])
      have : ∑ x in B, k x * (k x - 2) = 0 := by rw [Finset.sum_sub_distrib, h3, ← h1, h2]; rfl
      have : k x * (k x - 2) = 0 := (Finset.sum_eq_zero_iff_of_nonneg (λ x hx => by
        have kx2' := (by rcases hB x hx with ⟨i, j, hne, hi, hj⟩;
          exact (Finset.card_le_of_subset (by simp [hi, hj])).trans_refl' (by simp [hne]) : k x ≥ 2)
        nlinarith) hx).mp this; nlinarith
    have h_total : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← hAf, Finset.sum_comm]; simp [Finset.sum_card_filter, hAB, h_kx]
    exact ⟨hn, Nat.even_mul.mp (h_total ▸ even_two_mul _) |>.resolve_left (by simp)⟩
  · rintro ⟨hn, k, rfl⟩
    let n := 2 * k; let V := Fin (2 * n + 1); let e (i j : V) : ℕ := if i < j then i * (2 * n + 1) + j else j * (2 * n + 1) + i
    let A i := (Finset.univ.filter (· ≠ i)).map ⟨(e i ·), λ j1 j2 h => by
      dsimp at h; split_ifs at h <;> (have : _ / (2 * n + 1) = _ := rfl; rw [h] at this; simp at this; (try rw [this] at h); simp at h); assumption⟩
    let B := (Finset.univ.powerset.filter (·.card = 2)).map ⟨λ s => e (s.min' (by simp)) (s.max' (by simp)), sorry⟩
    let f x := if ∃ i j, i < j ∧ x = e i j ∧ ((j.val - i.val + 2 * n + 1) % (2 * n + 1) ∈ Set.Icc 1 k ∪ Set.Icc (n + 1) (n + k)) then 0 else 1
    refine ⟨n, hn, A, B, sorry, sorry, sorry, sorry, f, sorry, sorry⟩
