    let k x := (Finset.univ.filter (x ∈ A ·)).card
    have h_sum_k : (Finset.univ : Finset (Fin (2 * n + 1))).sum (λ i => (A i).card) = ∑ x in B, k x := by
      simp_rw [k, Finset.sum_card_filter, Finset.card_univ, Finset.sum_comm]; congr; ext x; simp [hAB]
