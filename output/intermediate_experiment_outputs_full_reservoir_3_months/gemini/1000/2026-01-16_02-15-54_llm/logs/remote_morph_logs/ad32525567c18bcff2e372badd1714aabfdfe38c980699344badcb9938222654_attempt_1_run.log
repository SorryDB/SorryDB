    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  simp
  constructor
  · rintro ⟨h_pos, A, B, h_0, h_1, h_2, h_3, f, h_f_val, h_f_n⟩
    let k x := (Finset.univ (α := Fin (2 * n + 1))).filter (λ i => x ∈ A i)
    have h_kx : ∀ x ∈ B, (k x).card = 2 := by
      intro x hx; rcases h_3 x hx with ⟨i, j, hij, hi, hj⟩
