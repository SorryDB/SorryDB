import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  refine ⟨fun ⟨h0, A, B, hAB, hA, hInt, hB, f, hf_range, hf_count⟩ => ?_, fun ⟨h0, h_even⟩ => ?_⟩
  · let k x := (Finset.univ.filter (x ∈ A ·)).card
    have h1 : ∑ x ∈ B, k x = (2 * n + 1) * (2 * n) := by
      rw [← Finset.sum_card_fiberwise hAB]; simp [hA]
    have h2 : ∑ x ∈ B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by
      let S := (Finset.univ : Finset (Fin (2 * n + 1) × Fin (2 * n + 1))).filter (fun p => p.1 ≠ p.2)
      have : ∑ p ∈ S, (A p.1 ∩ A p.2).card = (2 * n + 1) * (2 * n) := by
        simp [S, hInt, Finset.card_filter_univ_prod, Finset.filter_ne]
      rw [← this, Finset.sum_card_fiberwise]
      · simp [k, S, Finset.card_filter_univ_prod, Finset.filter_ne]
      · intro x hx p hp; simp at hp; simp [hp.2.1, hp.2.2]
    have h_kx : ∀ x ∈ B, k x = 2 := by
      have : ∑ x ∈ B, (k x - 2) * k x = 0 := by
        zify [h1, h2]; simp [Finset.sum_sub_distrib, left_distrib, mul_comm, h1, h2]
      intro x hx; have h_k2 : k x ≥ 2 := by
        rcases hB x hx with ⟨i, j, hij, hix, hjx⟩
        exact (Finset.card_le_of_subset (by simp [hix, hjx] : {i, j} ⊆ _)).trans_eq' (by simp [hij])
      have := (Finset.sum_eq_zero_iff_of_nonneg (λ x hx => by
        have h_k2 : k x ≥ 2 := by rcases hB x hx with ⟨i, j, hij, hix, hjx⟩; exact (Finset.card_le_of_subset (by simp [hix, hjx] : {i, j} ⊆ _)).trans_eq' (by simp [hij])
        exact mul_nonneg (by omega) (by omega))).mp this x hx
      omega
    have : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← hf_count, Finset.sum_const, ← Finset.sum_card_fiberwise hAB]
      simp [h_kx, Finset.sum_filter]
    exact (Nat.even_mul.mp ⟨_, this.symm⟩).resolve_left (by simp)
  · obtain ⟨k, rfl⟩ := h_even
    let V := Fin (4 * k + 1)
    let B := (Finset.univ : Finset V).sym2.filter (¬·.IsDiag)
    let A i := B.filter (i ∈ ·)
    let f x := if ∃ d : Fin k, x = s(x.out.1, x.out.1 + (d.val + 1)) ∨ x = s(x.out.1, x.out.1 - (d.val + 1)) then 0 else 1
    exact ⟨h0, A, B, by simp, by intro i; simp [A, B, Finset.card_filter_sym2_mem_not_diag], by intro i j hij; simp [A, B, hij], by intro x hx; simp at hx; rcases Quot.exists_rep x with ⟨i, j⟩; use i, j; simp [A, B, hx], f, by intro x _; simp, by intro i; sorry⟩
