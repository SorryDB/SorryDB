      have h2 : ∑ i, (Finset.univ.filter (· ≠ i)).sum (λ j ↦ (A i ∩ A j).card) = ∑ x ∈ B, kx x * (kx x - 1) := by
        simp_rw [Finset.card_eq_sum_ones, Finset.sum_comm (s := Finset.univ), Finset.sum_filter, ← Finset.sum_comm (s := B)]; simp
