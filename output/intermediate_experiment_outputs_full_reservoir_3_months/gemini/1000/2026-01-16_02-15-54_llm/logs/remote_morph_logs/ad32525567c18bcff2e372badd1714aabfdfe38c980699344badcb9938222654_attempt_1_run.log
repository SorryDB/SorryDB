import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  unfold answer; ext n; constructor
  · rintro ⟨n, hn, A, B, hAB, hA, hInt, hB, f, hf_range, hf_count, rfl⟩
    let k x := (Finset.univ.filter (x ∈ A ·)).card
    have h1 : ∑ x in B, k x = (2 * n + 1) * (2 * n) := by
      simp_rw [k, Finset.card_filter, ← Finset.sum_indicator_eq_sum_filter, Finset.sum_comm]; simp [hA]
    have h2 : ∑ x in B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by
      simp_rw [k, ← Finset.card_off_diag, Finset.card_filter, ← Finset.sum_indicator_eq_sum_filter, Finset.sum_comm (s := Finset.univ)]; simp [hInt]
    have hk : ∀ x ∈ B, k x = 2 := by
      intro x hx
      have hkx : 2 ≤ k x := by obtain ⟨i, j, h, hi, hj⟩ := hB x hx; exact Finset.card_le_two.mpr ⟨i, j, h, by simp [hi], by simp [hj]⟩
      have : ∑ x in B, k x * (k x - 2) = 0 := by rw [← h2, ← h1, ← Finset.sum_sub_distrib]; apply Finset.sum_congr rfl; intro; ring
      have := Finset.sum_eq_zero_iff.mp this x hx; nlinarith
    have h_sum : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      simp_rw [← hf_count, Finset.card_filter, ← Finset.sum_indicator_eq_sum_filter, Finset.sum_comm]
      simp_rw [Finset.sum_indicator_eq_sum_filter, ← Finset.card_filter, hk, Finset.sum_const, Nat.smul_eq_mul]
    exact ⟨hn, Nat.even_mul.mp (h_sum ▸ ⟨_, rfl⟩) |>.resolve_left (by decide)⟩
  · rintro ⟨hn, ⟨k, rfl⟩⟩
    sorry

