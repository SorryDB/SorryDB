Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  simp only [Set.mem_setOf_eq, answer]
  ext n; constructor
  · rintro ⟨hn, A, B, hAB, h1, h2, h3, f, hf01, hf0⟩
    let k x := (Finset.univ.filter (λ i => x ∈ A i)).card
    have hsum1 : ∑ x in B, k x = (2 * n + 1) * (2 * n) := by
      rw [← Finset.sum_card_univ, Finset.sum_filter_count]
      simp [h1, Finset.card_univ, Nat.smul_eq_mul]
    have hsum2 : ∑ x in B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by
      rw [← Finset.sum_card_choose_two, Finset.sum_const]
      · simp [h2, hn, Nat.choose_two_right, mul_comm]
      · exact Finset.univ
    have hk2 : ∀ x ∈ B, k x = 2 := by
      intro x hx
      have hkge2 : k x ≥ 2 := by
        rcases h3 x hx with ⟨i, j, hij, hi, hj⟩
        exact (Finset.card_le_of_subset (by simp [hi, hj, Finset.subset_filter])).trans' (by simp [hij])
      have : ∑ x in B, k x * (k x - 2) = 0 := by
        rw [Finset.sum_mul, Finset.sum_sub_distrib, hsum2, ← hsum1]; simp
      nlinarith [Finset.single_le_sum (λ y hy => (by nlinarith [hkge2 y hy] : k y * (k y - 2) ≥ 0)) hx]
    have : 2 * (B.filter (f · = 0)).card = (2 * n + 1) * n := by
      rw [← Finset.sum_filter_count, ← hf0, Finset.sum_const, Finset.card_univ, Nat.smul_eq_mul]
      simp [← Finset.sum_filter, Finset.sum_comm (s := Finset.univ), hk2, hf01]
    exact (Nat.even_mul.mp (Nat.even_iff_exists_two_mul.mpr ⟨_, this.symm⟩)).resolve_left (by simp)
  · rintro ⟨hn, ⟨k, rfl⟩⟩
    let V := 4 * k + 1; let B_e := (Finset.univ : Finset (Fin V)).powerset.filter (·.card = 2)
    let B := B_e.image (λ e => e.sum (λ x => x.1 * (V + 1) + 1))
    let A i := (B_e.filter (i ∈ ·)).image (λ e => e.sum (λ x => x.1 * (V + 1) + 1))
    use 2 * k, hn, A, B; repeat' constructor
    · simp [A, B]
    · intro i; simp [A, B_e, Finset.card_univ, Finset.card_image_of_injOn (λ e1 _ e2 _ h => by
        have h1 : e1.sum (λ x => x.1 * (V + 1) + 1) = e2.sum (λ x => x.1 * (V + 1) + 1) := h
        sorry)]
    · intro i j hij; sorry
    · intro x hx; simp [B, B_e, A] at *; rcases hx with ⟨e, he, rfl⟩
      rcases Finset.card_eq_two.mp (by simp [he] : e.card = 2) with ⟨i, j, hij, rfl⟩
      use i, j, hij; simp [hij, he]
    · use (λ x => if ∃ e ∈ B_e, x = e.sum (λ x => x.1 * (V + 1) + 1) then (if (∃ x y : Fin V, x ∈ e ∧ y ∈ e ∧ x ≠ y ∧ (x.1 - y.1 : ℤ).natAbs % V ∈ Finset.Icc 1 k) then 0 else 1) else 0)
      simp [A, B_e]; intro i; sorry

