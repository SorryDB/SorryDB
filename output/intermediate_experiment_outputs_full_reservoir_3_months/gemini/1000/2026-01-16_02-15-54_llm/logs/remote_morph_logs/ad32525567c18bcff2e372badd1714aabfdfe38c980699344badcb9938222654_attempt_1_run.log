    have hk_sum2 : ∑ x in B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by rw [← h_sum_k2]; simp [hI, Finset.card_erase]
    have h_k_eq_2 : ∀ x ∈ B, k x = 2 := fun x hx =>
