import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  simp only [Set.mem_setOf_eq, answer]
  constructor
  · rintro ⟨h_pos, A, B, h_sub, h_card, h_int, h_atleast, ⟨f, h_f_val, h_f_count⟩⟩
    let I := Finset.univ (α := Fin (2 * n + 1))
    let K x := (I.filter (x ∈ A ·)).card
    have hK1 : ∑ x in B, K x = (2 * n + 1) * (2 * n) := by
      rw [Finset.sum_card_fiberwise h_sub]; simp [h_card]
    have hK2 : ∑ x in B, K x * (K x - 1) = (2 * n + 1) * (2 * n) := by
      simp_rw [K, Finset.card_filter, ← Finset.card_offDiag, Finset.card_eq_sum_ones, Finset.sum_comm (s := B)]
      simp_rw [Finset.sum_comm (s := I.offDiag), ← Finset.mem_inter, ← Finset.card_filter]
      simp [Finset.filter_filter, h_int, h_sub, Finset.card_offDiag]
    have hK_eq_2 : ∀ x ∈ B, K x = 2 := by
      have : ∑ x in B, K x * (K x - 2) = 0 := by
        simp_rw [Nat.mul_sub_left_distrib, Finset.sum_sub_distrib, hK1, hK2]; rfl
      intro x hx
      have hKx : K x ≥ 2 := by
        obtain ⟨i, j, hne, hi, hj⟩ := h_atleast x hx
        exact Finset.card_filter_ge_of_mem (Finset.mem_univ _) hi hj hne
      have h0 := (Finset.sum_eq_zero_iff_of_nonneg (fun _ _ => Nat.zero_le _)).mp this x hx
      omega
    have h_sum : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← Finset.sum_const, ← h_f_count, Finset.sum_card_filter, Finset.sum_comm]
      simp_rw [← Finset.mem_filter, Finset.sum_card_fiberwise h_sub]
      simp [hK_eq_2]
    exact ⟨h_pos, (Nat.even_mul.mp (h_sum ▸ Nat.dvd_mul_right 2 _)).resolve_left (by decide)⟩
  · rintro ⟨h_pos, h_even⟩
    obtain ⟨k, rfl⟩ := h_even; let n := 2 * k; let m := 2 * n + 1
    let B := (Finset.univ : Finset (Fin m)).powersetCard 2
    let A (i : Fin m) := B.filter (i ∈ ·)
    let f (x : Finset (Fin m)) := if ∃ i j, x = {i, j} ∧ ((i - j).val ≤ k ∨ (j - i).val ≤ k) then 0 else 1
    refine ⟨n, h_pos, A, B, (by simp), (by intro i; sorry), (by intro i j hij; sorry), (by intro x hx; sorry), ⟨f, (by simp), (by intro i; sorry)⟩, rfl⟩
