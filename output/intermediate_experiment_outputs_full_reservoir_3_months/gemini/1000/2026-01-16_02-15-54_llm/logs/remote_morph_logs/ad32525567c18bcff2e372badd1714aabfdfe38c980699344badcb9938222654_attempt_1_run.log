  · rintro ⟨n_pos, k, rfl⟩
    let n := 2 * k; let V := Fin (2 * n + 1)
    let e (p : V × V) : ℕ := if p.1 < p.2 then p.1 * (2 * n + 1) + p.2 else p.2 * (2 * n + 1) + p.1
