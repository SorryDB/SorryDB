import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  simp only [Set.mem_setOf_eq, exists_eq_left, Nat.cast_add, Nat.cast_one, Nat.cast_mul, Nat.cast_two]
  constructor
  · rintro ⟨hn, A, B, hAB, hA, hI, hB, f, hf_val, hf_n⟩
    let k x := (Finset.univ.filter (λ i => x ∈ A i)).card
    have h_sum_k : ∑ x in B, k x = (2 * n + 1) * (2 * n) := by
      rw [Finset.sum_card_filter]; simp [hA]
    have h_sum_k2 : ∑ x in B, k x * (k x - 1) = (2 * n + 1) * (2 * n) := by
      simp_rw [k, Finset.card_filter, ← Finset.sum_card_filter]
      rw [Finset.sum_comm]; simp_rw [Finset.filter_filter, ← Finset.inter_def]
      simp [hI, Finset.sum_ite, Finset.filter_ne]
    have h_k2 : ∀ x ∈ B, k x = 2 := by
      have : ∑ x in B, k x * (k x - 2) = 0 := by
        simp_rw [mul_sub, ← h_sum_k, ← h_sum_k2, ← Finset.sum_sub_distrib]
        apply Finset.sum_congr rfl; intro x _; ring
      intro x hx; apply (Nat.eq_zero_of_le_zero _).symm
      have := Finset.sum_eq_zero_iff.1 this x hx
      obtain ⟨i, j, hij, hxi, hxj⟩ := hB x hx
      have : 2 ≤ k x := by
        rw [k, Finset.card_le_two]; use i, j
        simp [hij, hxi, hxj]
      cases' (Nat.le_of_mul_eq_zero this).1 with h_zero h_two
      · contradiction
      · exact h_two
    have : (2 * n + 1) * n = 2 * (B.filter (λ x => f x = 0)).card := by
      rw [← Finset.sum_const, ← hf_n, Finset.sum_card_filter]
      simp_rw [h_k2, Finset.sum_const, Nat.nsmul_eq_mul]
    rw [← Nat.even_iff_exists_bit0, ← Nat.even_mul, this]
    exact ⟨_, rfl⟩
  · rintro ⟨h_pos, k, rfl⟩
    let n := 2 * k
    let B := (Finset.univ : Finset (Fin (2 * n + 1))).powerset.filter (λ s => s.card = 2)
    let B_nat : Finset ℕ := B.map ⟨λ s => (s.min.get! : ℕ) * (2 * n + 1) + (s.max.get! : ℕ), sorry⟩
    let A (i : Fin (2 * n + 1)) : Finset ℕ := B_nat.filter (λ x => ∃ j, j ≠ i ∧ x = if i < j then (i:ℕ)*(2*n+1)+j else (j:ℕ)*(2*n+1)+i)
    use A, B_nat; repeat' constructor <;> try (intro; sorry)
    let f x := if ∃ i j, i < j ∧ (j - i).val ≤ k ∧ x = (i:ℕ)*(2*n+1)+j then (0:ℕ) else 1
    use f; constructor <;> intro <;> sorry
