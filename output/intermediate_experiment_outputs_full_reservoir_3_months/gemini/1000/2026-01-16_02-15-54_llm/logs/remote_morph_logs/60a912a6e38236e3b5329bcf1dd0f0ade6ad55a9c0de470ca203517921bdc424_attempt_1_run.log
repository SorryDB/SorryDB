      exact ⟨M, ⟨hM, fun M' hM' ↦ hMe.symm.trans_le (hM'.encard_le)⟩, (fun hv ↦ hMe.symm.le.not_lt (hv.some_matching_is_max))⟩
    · exact inessential_of_not_mem hx
  obtain ⟨M, hM, hcomp⟩ := foo_of_forall_inessential h_iness
  have hM_max : H.IsMaxMatching M := ⟨hM, fun M' hM' ↦ by
    refine (ENat.mul_le_mul_left (by norm_num : 2 ≠ 0) (by norm_num : 2 ≠ ⊤)).1 ?_
    rw [hcomp.2_encard_M, hcomp.2_encard_M' hM']
    exact tsub_le_tsub_right (encard_mono (subset_V_H M' hM')) _⟩
  rw [← hM_max.encard, hcomp.2_encard_M, hcomp.V_H_sub_OddComponents]
