lemma tutte_berge_of_maximal_vertexDelete (hX : Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X) :
    2 * ν(G - X) = (V(G) \ X).encard - (G - X).OddComponents.encard := by
  let H := G - X
  have hH : ∀ v ∈ H.vertexSet, H.inessential v := fun v hv ↦ by
    have h_ss := hX.2 (ssubset_insert (mem_diff.1 hv).2)
    rw [insert_eq, ← union_singleton, ← vertexDelete_vertexDelete, encard_insert_of_not_mem (mem_diff.1 hv).2, hX.1] at h_ss
    obtain ⟨M, hM⟩ := (H - v).exists_isMaxMatching
    exact ⟨M.of_vertexDelete, ⟨hM.1.of_vertexDelete, fun M' hM' ↦ (not_lt.1 h_ss).trans_eq 
      (MatchingNumber_vertexDelete_le H v |>.antisymm hM'.encard_le).symm⟩, fun h ↦ H.not_mem_V_of_vertexDelete hv h⟩
  obtain ⟨M, hM, hc⟩ := foo_of_forall_inessential hH
  have h_max : H.IsMaxMatching M := ⟨hM, fun M' hM' ↦ H.MatchingNumber_le_of_comp_unmatched hM' hc⟩
  have h_odd : H.OddComponents = {C | C.IsCompOf H} := by
    ext C; exact ⟨(·.toIsCompOf), fun hC ↦ ⟨hC, (hc C hC).finite, (hc C hC).odd⟩⟩
  rw [h_max.encard, h_odd, H.encard_V_eq_2_M_add_comp hM hc, ENat.add_sub_cancel (H.OddComponents_finite_encard hc)]
