open BigOperators Real Nat Topology Rat

theorem imo_1983_p6
  (a b c : ℝ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
  (h₁ : c < a + b)
  (h₂ : b < a + c)
  (h₃ : a < b + c) :
  0 ≤ a^2 * b * (a - b) + b^2 * c * (b - c) + c^2 * a * (c - a) := by
  let x := (b + c - a) / 2
  let y := (a + c - b) / 2
  let z := (a + b - c) / 2
  have h : a^2 * b * (a - b) + b^2 * c * (b - c) + c^2 * a * (c - a) =
      2 * (x * z * (x - y) ^ 2 + y * x * (y - z) ^ 2 + z * y * (z - x) ^ 2) := by
    have h1 : a = y + z := by linarith
    have h2 : b = z + x := by linarith
    have h3 : c = x + y := by linarith
    rw [h1, h2, h3]; ring
  rw [h]
  have hx : 0 < x := by linarith
  have hy : 0 < y := by linarith
  have hz : 0 < z := by linarith
  positivity
