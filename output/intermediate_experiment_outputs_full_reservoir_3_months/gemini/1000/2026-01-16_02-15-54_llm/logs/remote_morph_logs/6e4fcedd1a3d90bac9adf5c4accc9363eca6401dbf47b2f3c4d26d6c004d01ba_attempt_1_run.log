import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1983_p6
  (a b c : ℝ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
  (h₁ : c < a + b)
  (h₂ : b < a + c)
  (h₃ : a < b + c) :
  0 ≤ a^2 * b * (a - b) + b^2 * c * (b - c) + c^2 * a * (c - a) := by
  have h_id : ∀ x y z : ℝ, x^2 * y * (x - y) + y^2 * z * (y - z) + z^2 * x * (z - x) = x * (y - z)^2 * (y + z - x) + y * (x - y) * (x - z) * (x + y - z) := by intros; ring
  rcases max_choice a b with hab | hba
