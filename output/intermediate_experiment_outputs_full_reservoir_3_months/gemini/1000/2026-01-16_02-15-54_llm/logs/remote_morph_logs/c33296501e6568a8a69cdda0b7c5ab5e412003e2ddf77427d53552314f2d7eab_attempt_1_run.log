      have d3 : n / 6 ∈ n.properDivisors := by
        simp [Nat.properDivisors, n]; use 6; simp [h6]
      have h45 : ∀ d ∈ n.properDivisors, d ≤ n / 6 ∨ d = n / 3 ∨ d = n / 2 := by
        intro d hd; simp [Nat.properDivisors] at hd
        let m := n / d; have dm : n = d * m := Nat.mul_div_cancel' hd.1
        have m_ge_2 : 2 ≤ m := Nat.le_of_dvd (by omega) hd.2
        if m2 : m = 2 then right; right; rw [dm, m2]; simp
        else if m3 : m = 3 then right; left; rw [dm, m3]; simp
        else if m4 : m = 4 then exfalso; apply h4; rw [dm, m4]; simp
        else if m5 : m = 5 then exfalso; apply h5; rw [dm, m5]; simp
        else left; apply Nat.div_le_of_le_mul; rw [dm]; nlinarith
      have card_ge_3 : 3 ≤ n.properDivisors.card := by
        have : {n/2, n/3, n/6} ⊆ n.properDivisors := by
          intro x hx; simp at hx; cases hx <;> subst x <;> assumption
