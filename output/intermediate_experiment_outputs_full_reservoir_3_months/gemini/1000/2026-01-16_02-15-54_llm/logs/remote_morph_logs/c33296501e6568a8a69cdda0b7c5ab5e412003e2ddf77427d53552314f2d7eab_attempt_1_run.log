        exact (Finset.card_le_of_subset this).trans_inv (by simp)
      exact ⟨card_ge_3, by
        have : (n.properDivisors.sort (· ≤ ·)).reverse.take 3 = [n/2, n/3, n/6] := by
          sorry
        simp [this, h6]; ring⟩
