lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 < S.length := by
  induction S generalizing k
  case nil =>
    simp [after, initialState, allKnow] at h
    match n with
    | 0 => exact (Fin.elim0 k)
    | 1 =>
      specialize h 0
      simp at h
    | n+2 =>
      specialize h (k + 1)
      simp [initialState] at h
  case cons c S IH =>
    simp at *
    sorry
```
