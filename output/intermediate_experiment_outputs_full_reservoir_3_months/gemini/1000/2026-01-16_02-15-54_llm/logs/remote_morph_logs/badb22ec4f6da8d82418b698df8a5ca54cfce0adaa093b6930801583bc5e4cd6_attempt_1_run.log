instance : AddCommGroup Torus3 := sorry
instance : NormedAddCommGroup Torus3 := sorry
instance : InnerProductSpace ℝ Torus3 := sorry
instance : MeasurableSpace Torus3 := sorry
instance : BorelSpace Torus3 := ⟨rfl⟩
```
