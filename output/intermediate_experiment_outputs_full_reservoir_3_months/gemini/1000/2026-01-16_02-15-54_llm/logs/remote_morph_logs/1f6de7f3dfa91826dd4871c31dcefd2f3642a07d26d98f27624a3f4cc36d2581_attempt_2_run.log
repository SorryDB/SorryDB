import Mathlib


namespace IMO2025P3

/-- The condition on functions in the problem. -/
def Bonza (f : ℕ+ → ℕ+) : Prop := ∀ a b : ℕ+, (f a : ℤ) ∣ (b ^ (a : ℕ) : ℤ) - (f b ^ (f a : ℕ) : ℤ)

/-- The answer to be determined. -/
def answer : ℝ := 4

theorem result : IsLeast {c : ℝ | ∀ f : ℕ+ → ℕ+, Bonza f → ∀ n, f n ≤ c * n}
    answer := by
  constructor
  · intro f hf n
    have f1 : f 1 = 1 := by
      have h1 := hf 1 1
      simp [Bonza] at h1
      have hf1_pos : 0 < f 1 := (f 1).pos
      replace h1 : (f 1 : ℤ) ∣ 1 - (f 1 : ℤ) ^ (f 1 : ℕ) := by exact h1
      have hf1_d : (f 1 : ℤ) ∣ (f 1 : ℤ) ^ (f 1 : ℕ) := dvd_pow_self _ (by exact Nat.not_eq_zero_of_lt (f 1).pos)
      have hf1_1 : (f 1 : ℤ) ∣ 1 := (dvd_add h1 hf1_d).mp (by simp)
      exact PNat.coe_inj.mp (by exact (Int.isUnit_iff.mp (isUnit_of_dvd_one hf1_1)).left)
    by_cases hn : n = 1
    · simp [hn, f1]; linarith
    have h_pow2 : ∀ a : ℕ+, (f a : ℤ) ∣ (1 : ℤ) ^ (a : ℕ) - (f 1 : ℤ) ^ (f a : ℕ) := fun a => hf a 1
    simp [f1] at h_pow2
    have h_even : ∀ a : ℕ+, (f a : ℤ) ∣ (3 : ℤ) ^ (a : ℕ) - (1 : ℤ) ^ (f a : ℕ) := fun a => by
      have h := hf a 3
      simp [f1] at h
      have hf3 : f 3 = 1 := by
        have h3 := hf 3 2
        have h3' := hf 3 1
        simp [f1] at h3 h3'
        have h3d1 : (f 3 : ℤ) ∣ 2^3 - (f 2 : ℤ)^(f 3 : ℕ) := h3
        have h3d2 : (f 3 : ℤ) ∣ 3^3 - (f 3 : ℤ)^(f 3 : ℕ) := hf 3 3
        sorry
      sorry
    sorry
  · intro c hc
    let f : ℕ+ → ℕ+ := fun n => if n = 4 then 16 else if n = 2 then 4 else if Even (n : ℕ) then 2 else 1
    have hf : Bonza f := by sorry
    specialize hc f hf 4
    simp [f] at hc
    linarith
