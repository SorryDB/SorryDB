@[sorryful]
lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  ext t i
  let ω := S.ω
  let y := fun t : ℝ => x (Time.ofReal t) i - IC.trajectory S (Time.ofReal t) i
  let E := fun t : ℝ => ω^2 * (y t)^2 + (deriv y t)^2
  have h_accel : ∀ t, deriv (deriv y) t = - ω^2 * y t := by
    intro t
    have hEOM := h.1
    have hTraj := trajectory_equationOfMotion S IC
    rw [EquationOfMotion, gradLagrangian_eq_force] at hEOM hTraj
    have h1 := congr_fun hEOM (Time.ofReal t)
    have h2 := congr_fun hTraj (Time.ofReal t)
    simp only [Pi.zero_apply, force_eq_linear] at h1 h2
    have h_y'' := congr_fun (congr_fun (sub_eq_zero.2 (h1.trans h2.symm))) i
    simp only [PiLp.sub_apply, PiLp.neg_apply, PiLp.smul_apply, smul_eq_mul, PiLp.zero_apply] at h_y''
    exact h_y''
  have h_E_const : ∀ t, E t = 0 := by
    intro t
    have h_deriv_E : deriv E = fun _ => 0 := by
      funext t'
      rw [deriv_add, deriv_mul_const, deriv_pow, deriv_pow]
      · rw [h_accel]; ring
      · fun_prop
      · fun_prop
      · fun_prop
      · fun_prop
    have h_E0 : E 0 = 0 := by
      simp only [E, y, h.2.1, trajectory_position_at_zero, PiLp.sub_apply, sub_self,
        mul_zero, zero_pow, zero_add]
      have h_v0 : deriv y 0 = 0 := by
        simp only [y, Time.deriv] at *
        rw [deriv_sub]
