/-- The moment of inertia tensor of a solid sphere through its center of mass is
  `2/5 m R^2 * I`. -/
lemma solidSphere_inertiaTensor (m R : ℝ≥0) (hr : R ≠ 0) :
    (solidSphere 3 m R).inertiaTensor = (2/5 * m.1 * R.1^2) • (1 : Matrix _ _ _) := by
  ext i j
  simp only [inertiaTensor, solidSphere, LinearMap.coe_mk, ContMDiffMap.coeFn_mk,
    Matrix.smul_apply, Matrix.one_apply, smul_eq_mul, integral_const_mul]
  have hV : (volume : Measure (Space 3)).real (Metric.closedBall 0 R) ≠ 0 :=
    (measureReal_ne_zero_iff Space.volume_closedBall_neq_top).mpr
      (Space.volume_closedBall_neq_zero (NNReal.coe_ne_zero.mpr hr))
  field_simp [hV]
  by_cases h : i = j
  · subst h
    simp only [if_true, mul_one, Space.integral_ball_norm_sq_sub_coord_sq 3 R i]
    ring
  · simp only [h, if_false, mul_zero, Space.integral_ball_coord_mul_coord 3 R i j h, mul_eq_zero,
      neg_eq_zero, true_or]
```
