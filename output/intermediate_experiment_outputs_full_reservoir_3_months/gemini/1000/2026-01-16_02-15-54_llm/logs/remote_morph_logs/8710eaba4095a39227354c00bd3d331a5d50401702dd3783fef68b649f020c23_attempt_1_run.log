      rw [mul_nonpos_iff]
      simp [Real.log_mul ha.ne' hb.ne', Real.log_pow, ← Real.log_mul hc.ne' hd.ne', Real.log_le_log]
      constructor <;> rintro h <;> (cases h <;> [left; right] <;> constructor <;> linarith)
    replace h₁ := (hlog x₁ x₂ x₃ x₅ hx₁ hx₂ hx₃ hx₅).mp h₁
    replace h₂ := (hlog x₂ x₃ x₄ x₁ hx₂ hx₃ hx₄ hx₁).mp h₂
    replace h₃ := (hlog x₃ x₄ x₅ x₂ hx₃ hx₄ hx₅ hx₂).mp h₃
    replace h₄ := (hlog x₄ x₅ x₁ x₃ hx₄ hx₅ hx₁ hx₃).mp h₄
