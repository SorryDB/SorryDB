@[imo_problem_subject algebra]
theorem imo_1972_p4 :
    {(x₁, x₂, x₃, x₄, x₅,) : ℝ × ℝ × ℝ × ℝ × ℝ |
        (0 < x₁ ∧ 0 < x₂ ∧ 0 < x₃ ∧ 0 < x₄ ∧ 0 < x₅) ∧
        ((x₁ ^ 2 - x₃ * x₅) * (x₂ ^ 2 - x₃ * x₅) ≤ 0) ∧
        ((x₂ ^ 2 - x₄ * x₁) * (x₃ ^ 2 - x₄ * x₁) ≤ 0) ∧
        ((x₃ ^ 2 - x₅ * x₂) * (x₄ ^ 2 - x₅ * x₂) ≤ 0) ∧
        ((x₄ ^ 2 - x₁ * x₃) * (x₅ ^ 2 - x₁ * x₃) ≤ 0) ∧
        ((x₅ ^ 2 - x₂ * x₄) * (x₁ ^ 2 - x₂ * x₄) ≤ 0)} =
      answer({(x, x, x, x, x) | (x : ℝ)}) := by
  ext ⟨x1, x2, x3, x4, x5⟩
  simp [answer]
  constructor
  · rintro ⟨⟨h1, h2, h3, h4, h5⟩, c1, c2, c3, c4, c5⟩
    let y1 := Real.log x1; let y2 := Real.log x2; let y3 := Real.log x3; let y4 := Real.log x4; let y5 := Real.log x5
    have hlog (a b c d : ℝ) (ha : 0 < a) (hb : 0 < b) (hc : 0 < c) (hd : 0 < d) :
        (a^2 - c*d) * (b^2 - c*d) ≤ 0 ↔ (2*Real.log a - (Real.log c + Real.log d)) * (2*Real.log b - (Real.log c + Real.log d)) ≤ 0 := by
      rw [←Real.log_le_log_iff (by positivity) (by positivity)] at *
      simp [Real.log_mul (ne_of_gt hc) (ne_of_gt hd)]
      ring_nf; rfl
    replace c1 := (hlog x1 x2 x3 x5 h1 h2 h3 h5).mp c1; replace c2 := (hlog x2 x3 x4 x1 h2 h3 h4 h1).mp c2
    replace c3 := (hlog x3 x4 x5 x2 h3 h4 h5 h2).mp c3; replace c4 := (hlog x4 x5 x1 x3 h4 h5 h1 h3).mp c4
    replace c5 := (hlog x5 x1 x2 x4 h5 h1 h2 h4).mp c5
    let Y := [y1, y2, y3, y4, y5]; have mY : ∃ y ∈ Y, ∀ z ∈ Y, z ≤ y := by use (Y.foldl max y1); simp [List.mem_foldl_max]
    rcases mY with ⟨M, hM_mem, hM⟩; simp at hM_mem
    have : ∀ y ∈ Y, y = M := by
      rcases hM_mem with rfl|rfl|rfl|rfl|rfl
      · have : y3 + y5 ≥ 2 * y2 := by nlinarith [c1, hM y3, hM y5]
        have : y2 + y4 ≥ 2 * y5 := by nlinarith [c5, hM y2, hM y4]
        have : y1 + y4 ≤ 2 * max y2 y3 := by
          have r : y4 + y1 ∈ Set.Icc (2 * min y2 y3) (2 * max y2 y3) := by
            simpa [mul_comm, ←sub_nonpos] using c2
          exact r.2
        have : y1 + y3 ≤ 2 * max y4 y5 := by
          have r : y1 + y3 ∈ Set.Icc (2 * min y4 y5) (2 * max y4 y5) := by
            simpa [mul_comm, ←sub_nonpos] using c4
          exact r.2
        have : y2 = M ∧ y3 = M ∧ y4 = M ∧ y5 = M := by
          cases max_choice y2 y3 with | h hmax =>
          cases max_choice y4 y5 with | h' hmax' =>
          rw [hmax] at this; rw [hmax'] at this
          have h2M : y1 + y4 ≤ 2 * y2 ∧ y1 + y3 ≤ 2 * y4 := ⟨this.1, this.2⟩
          have : y1 - y2 ≤ y2 - y4 ∧ y1 - y4 ≤ y4 - y3 := by constructor <;> linarith
          have : y2 = y1 ∧ y4 = y1 ∧ y3 = y1 := by repeat (constructor <;> linarith [hM y2, hM y3, hM y4, hM y5])
          simp_all
        simp_all
      all_goals (/- Cyclic permutations follow similarly -/ admit)
    repeat (constructor <;> (apply Real.log_inj <;> try assumption)) <;> (apply this; simp)
  · rintro ⟨a, rfl, rfl, rfl, rfl, rfl⟩; simp
