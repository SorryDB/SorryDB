/-
Copyright (c) 2025 Joseph Myers. All rights reserved.
Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


namespace IMO2025P3

/-- The condition on functions in the problem. -/
def Bonza (f : ℕ+ → ℕ+) : Prop := ∀ a b : ℕ+, (f a : ℤ) ∣ (b ^ (a : ℕ) : ℤ) - (f b ^ (f a : ℕ) : ℤ)

/-- The answer to be determined. -/
def answer : ℝ := 4

theorem result : IsLeast {c : ℝ | ∀ f : ℕ+ → ℕ+, Bonza f → ∀ n, f n ≤ c * n}
    answer := by
  refine ⟨fun c hc ↦ ?_, fun f hf n ↦ ?_⟩
  · let f : ℕ+ → ℕ+ := fun n ↦ if n = 2 then 4 else if 4 ∣ n then 16 else 1
    have hf : Bonza f := by
      intro a b
      rcases a with ⟨a, ha⟩
      by_cases ha2 : a = 2
      · simp [ha2, f]
        by_cases hb : 2 ∣ b
        · simp [hb]; apply Int.dvd_sub (by decide) (dvd_pow_self _ (by decide))
        · have : b ^ 2 % 4 = 1 := by
            have : b % 2 = 1 := Nat.not_even_iff_odd.mp hb
            rcases Nat.exists_eq_succ_of_ne_zero (by linarith) with ⟨k, rfl⟩
            have : (k + 1) % 2 = 1 := ‹(k + 1) % 2 = 1›
            have : k % 2 = 0 := by omega
            rcases this with ⟨m, rfl⟩
            ring_nf; simp [add_assoc]
          simp [f, hb]; rw [Int.dvd_iff_mod_eq_zero]; simp [Int.sub_mod]; assumption
      · by_cases ha4 : 4 ∣ a
        · simp [f, ha4, ha2]
          by_cases hb2 : 2 ∣ b
          · apply Int.dvd_sub (pow_dvd_pow _ (by omega)) (dvd_pow_self _ (by decide))
          · have : (b : ℤ) ^ a % 16 = 1 := by
              have : v_2 a ≥ 2 := by
                rcases ha4 with ⟨k, rfl⟩
                have : v_2 (4 * k) = v_2 4 + v_2 k := by apply multiplicity.multiplicity_mul; repeat decide
                simp [this]
              rw [← Int.emod_eq_zero_iff_dvd, Int.sub_emod, Int.emod_self, Int.sub_zero, Int.emod_eq_zero_iff_dvd]
              apply Nat.modeq_zero_iff_dvd.mp
              have : b % 2 = 1 := Nat.not_even_iff_odd.mp hb2
              calc (b : ℕ) ^ a ≡ 1 [MOD 2 ^ (v_2 a + 2)] := Nat.Modeq.pow_v2_odd rfl (by omega)
                   _ ≡ 1 [MOD 16] := Nat.Modeq.modn_mono (by simp [this]; apply pow_mono; decide) (by simp)
            simp [f, hb2]; rw [Int.dvd_iff_mod_eq_zero, Int.sub_mod]; simp [this]
        · simp [f, ha4, ha2]
    specialize hc f hf 4
    simp [f] at hc; linarith
  · sorry

```
