lemma Set_equinum_powerset {U : Type} (A : Set U) :
    Set ↑A ∼ ↑(𝒫 A) := by
  rw [equinum_iff_inverse_pair]
  let f (X : Set ↑A) : ↑(𝒫 A) := ⟨val_image A X, by rw [← range_val_image A]; exists X⟩
  let g (S : ↑(𝒫 A)) : Set ↑A := {x | x.val ∈ S.val}
  exists f, g; apply conj_intro
  · apply funext; intro S; apply Subtype.ext
