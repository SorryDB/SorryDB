import Mathlib


open scoped EuclideanGeometry
open Affine Module

namespace IMO2021P3

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result {A B C D E F X O₁ O₂ : P}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C])
    (acuteAngled_ABC : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).AcuteAngled)
    (AC_lt_AB : dist A C < dist A B)
    (D_mem_interior_ABC : D ∈ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).interior)
    (angle_DAB_eq_angle_CAD : ∠ D A B = ∠ C A D) (wbtw_A_E_C : Wbtw ℝ A E C)
    (angle_ADE_eq_angle_BCD : ∠ A D E = ∠ B C D) (wbtw_A_F_B : Wbtw ℝ A F B)
    (angle_FDA_eq_angle_DBC : ∠ F D A = ∠ D B C) (X_mem_AC : X ∈ line[ℝ, A, C])
    (CX_eq_BX : dist C X = dist B X)
    (affineIndependent_ADC : AffineIndependent ℝ ![A, D, C])
    (O₁_eq_circumcenter_ADC : O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumcenter)
    (affineIndependent_EXD : AffineIndependent ℝ ![E, X, D])
    (O₂_eq_circumcenter_EXD : O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumcenter) :
    E ≠ F ∧ O₁ ≠ O₂ ∧ (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂] : Set P).Nonempty := by
  have hEF : E ≠ F := by
    intro h
    have hA : E = A := by
      have hE : E ∈ line[ℝ, A, C] := wbtw_A_E_C.mem_affineSpan
      have hF : F ∈ line[ℝ, A, B] := wbtw_A_F_B.mem_affineSpan
      rw [h] at hF
      exact (affineIndependent_ABC.line_inter_line ![0, 2] ![0, 1] (by simp) (by simp) (by simp)).1 ⟨hE, hF⟩
    subst hA
    have hBCD : ∠ B C D = 0 := by rw [← angle_ADE_eq_angle_BCD, angle_self]
    exact (D_mem_interior_ABC.2 2 (by norm_num)).ne (angle_eq_zero_iff_mem_side.1 hBCD).2
  have hO1O2 : O₁ ≠ O₂ := by
    intro h
    have hADCE : Concyclic ({A, D, C, E, X} : Set P) := by
      rw [← h]
      have h1 := (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).dist_circumcenter_eq_circumradius
      have h2 := (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).dist_circumcenter_eq_circumradius
      simp [O₁_eq_circumcenter_ADC, O₂_eq_circumcenter_EXD] at h1 h2
      exact ⟨dist O₁ A, by simp [h1, h2, h]⟩
    have hACEX : Collinear ℝ ({A, C, E, X} : Set P) := by
      refine Collinear.insert_collinear (Collinear.insert_collinear (Collinear.insert_collinear ?_ E X_mem_AC) C ?_) A ?_
      all_goals { simp [line_sample_apply_left, line_sample_apply_right, wbtw_A_E_C.mem_affineSpan] }
    have h_card : ({A, C, E, X} : Set P).Finite ∧ ({A, C, E, X} : Set P).ncard ≤ 2 :=
      hADCE.collinear_subset (by simp) hACEX affineIndependent_ADC.not_collinear
    have hAC : A ≠ C := affineIndependent_ABC.injective.ne (by norm_num)
    have hAX : A ≠ X := by
      intro h
      rw [← h, dist_comm, CX_eq_BX] at AC_lt_AB
      exact AC_lt_AB.not_le dist_triangle_right
    exact (h_card.2.trans (by norm_num)).not_lt (Set.ncard_pos.2 ⟨A, by simp⟩).lt_of_ne (by
      intro h_nc
      have h_subset : {A, C, X} ⊆ ({A, C, E, X} : Set P) := by simp
      have h_nc3 : 3 ≤ ({A, C, E, X} : Set P).ncard := by
        rw [← Set.ncard_with_subset h_subset (by simp)]
        simp [hAC, hAX, (by intro h; rw [h] at CX_eq_BX; simp at CX_eq_BX : C ≠ X)]
      exact h_nc3.not_le h_card.2)
  have hS : (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂]).Nonempty := by
    sorry
  exact ⟨hEF, hO1O2, hS⟩

