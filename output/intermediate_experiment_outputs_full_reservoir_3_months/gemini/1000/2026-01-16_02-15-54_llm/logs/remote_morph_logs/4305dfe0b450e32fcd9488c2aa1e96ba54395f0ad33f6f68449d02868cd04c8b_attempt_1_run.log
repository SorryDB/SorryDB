      have hOA : dist O₁ A = dist O₁ D := by rw [O₁_eq_circumcenter_ADC]; exact (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).dist_circumcenter_eq_dist_circumcenter 0 1
