import Mathlib


open scoped EuclideanGeometry
open Affine Module

namespace IMO2021P3

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result {A B C D E F X O₁ O₂ : P}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C])
    (acuteAngled_ABC : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).AcuteAngled)
    (AC_lt_AB : dist A C < dist A B)
    (D_mem_interior_ABC : D ∈ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).interior)
    (angle_DAB_eq_angle_CAD : ∠ D A B = ∠ C A D) (wbtw_A_E_C : Wbtw ℝ A E C)
    (angle_ADE_eq_angle_BCD : ∠ A D E = ∠ B C D) (wbtw_A_F_B : Wbtw ℝ A F B)
    (angle_FDA_eq_angle_DBC : ∠ F D A = ∠ D B C) (X_mem_AC : X ∈ line[ℝ, A, C])
    (CX_eq_BX : dist C X = dist B X)
    (affineIndependent_ADC : AffineIndependent ℝ ![A, D, C])
    (O₁_eq_circumcenter_ADC : O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumcenter)
    (affineIndependent_EXD : AffineIndependent ℝ ![E, X, D])
    (O₂_eq_circumcenter_EXD : O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumcenter) :
    E ≠ F ∧ O₁ ≠ O₂ ∧ (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂] : Set P).Nonempty := by
  let T_ABC : Triangle ℝ P := ⟨![A, B, C], affineIndependent_ABC⟩
  let T_ADC : Triangle ℝ P := ⟨![A, D, C], affineIndependent_ADC⟩
  let T_EXD : Triangle ℝ P := ⟨![E, X, D], affineIndependent_EXD⟩
  have hE_mem_AC : E ∈ line[ℝ, A, C] := wbtw_A_E_C.mem_affineSpan
  have hF_mem_AB : F ∈ line[ℝ, A, B] := wbtw_A_F_B.mem_affineSpan
  have hEF : E ≠ F := by
    intro h
    have hE : E = F := h
    have hE_in_AB : E ∈ line[ℝ, A, B] := hE ▸ hF_mem_AB
    have hE_in_AC : E ∈ line[ℝ, A, C] := hE_mem_AC
    have hE_is_A : E = A := by
      have hA_in_AB : A ∈ line[ℝ, A, B] := left_mem_affineSpan ℝ A B
      have hA_in_AC : A ∈ line[ℝ, A, C] := left_mem_affineSpan ℝ A C
      exact (affineIndependent_ABC.line_inter_line ![0, 1] ![0, 2] (by decide) (by decide)).mp ⟨hE_in_AB, hE_in_AC⟩
    have hdist : dist A E = 0 := by rw [hE_is_A, dist_self]
    have hD_interior : D ∈ T_ABC.interior := D_mem_interior_ABC
    have h_angle : ∠ A D E = 0 := by rw [hE_is_A, angle_self]
    have h_angle_BCD : ∠ B C D = 0 := angle_ADE_eq_angle_BCD ▸ h_angle
    have hC_mem_BD : D ∈ line[ℝ, B, C] := by sorry
    exact (T_ABC.not_mem_interior_boundary D_mem_interior_ABC).1 (by sorry)
  have hO1O2 : O₁ ≠ O₂ := by
    intro h
    have h_circum : T_ADC.circumcircle = T_EXD.circumcircle := by sorry
    have hA_on_O2 : A ∈ T_EXD.circumcircle := by sorry
    exact affineIndependent_EXD.not_collinear (by sorry)
  have h_concur : (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂]).Nonempty := by
    obtain ⟨S, hS_BC, hS_EF⟩ : ∃ S, S ∈ line[ℝ, B, C] ∩ line[ℝ, E, F] := by sorry
    have hS_O1O2 : S ∈ line[ℝ, O₁, O₂] := by sorry
    exact ⟨S, ⟨hS_BC, hS_EF, hS_O1O2⟩⟩
  exact ⟨hEF, hO1O2, h_concur⟩
