import Mathlib


open scoped EuclideanGeometry
open Affine Module

namespace IMO2021P3

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result {A B C D E F X O₁ O₂ : P}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C])
    (acuteAngled_ABC : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).AcuteAngled)
    (AC_lt_AB : dist A C < dist A B)
    (D_mem_interior_ABC : D ∈ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).interior)
    (angle_DAB_eq_angle_CAD : ∠ D A B = ∠ C A D) (wbtw_A_E_C : Wbtw ℝ A E C)
    (angle_ADE_eq_angle_BCD : ∠ A D E = ∠ B C D) (wbtw_A_F_B : Wbtw ℝ A F B)
    (angle_FDA_eq_angle_DBC : ∠ F D A = ∠ D B C) (X_mem_AC : X ∈ line[ℝ, A, C])
    (CX_eq_BX : dist C X = dist B X)
    (affineIndependent_ADC : AffineIndependent ℝ ![A, D, C])
    (O₁_eq_circumcenter_ADC : O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumcenter)
    (affineIndependent_EXD : AffineIndependent ℝ ![E, X, D])
    (O₂_eq_circumcenter_EXD : O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumcenter) :
    E ≠ F ∧ O₁ ≠ O₂ ∧ (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂] : Set P).Nonempty := by
  let triABC : Triangle ℝ P := ⟨![A, B, C], affineIndependent_ABC⟩
  let triADC : Triangle ℝ P := ⟨![A, D, C], affineIndependent_ADC⟩
  let triEXD : Triangle ℝ P := ⟨![E, X, D], affineIndependent_EXD⟩
  have h_int := triABC.angle_pos_of_mem_interior D_mem_interior_ABC
  have h_dist_pos : 0 < dist A D := dist_pos.2 (triADC.independent.ne 0 1)
  have h_E_mem_AC : E ∈ line[ℝ, A, C] := wbtw_A_E_C.left_mem_affineSpan
  have h_F_mem_AB : F ∈ line[ℝ, A, B] := wbtw_A_F_B.left_mem_affineSpan
  have h_AC_ne : A ≠ C := triABC.independent.ne 0 2
  have h_AB_ne : A ≠ B := triABC.independent.ne 0 1
  have h_BC_ne : B ≠ C := triABC.independent.ne 1 2
  have h_sim1 : (dist B D / dist C D) = (dist B F / dist C E) ∧ (dist B D / dist C D) = (dist D F / dist D E) := by
    have h_ang_BFD : ∠ B F D = π - ∠ D B C - ∠ D A B := by
      rw [angle_FDA_eq_angle_DBC.symm, angle_DAB_eq_angle_CAD.symm, ← angle_sum_triangle ![A, F, D] (AffineIndependent.mono_set (by norm_num) wbtw_A_F_B.affineIndependent_of_ne (by intro h; exact triABC.independent.ne 0 1 (by simpa [h] using wbtw_A_F_B.left_mem_affineSpan)))]
      simp [angle_comm]; ring
    have h_ang_CED : ∠ C E D = π - ∠ B C D - ∠ C A D := by
      rw [angle_ADE_eq_angle_BCD.symm, ← angle_sum_triangle ![A, E, D] (AffineIndependent.mono_set (by norm_num) wbtw_A_E_C.affineIndependent_of_ne (by intro h; exact triABC.independent.ne 0 2 (by simpa [h] using wbtw_A_E_C.left_mem_affineSpan)))]
      simp [angle_comm]; ring
    sorry
  have h_EF : E ≠ F := by
    intro h; rw [h] at *
    have : dist A C = dist A B := sorry
    exact AC_lt_AB.ne this
  have h_O1O2 : O₁ ≠ O₂ := by
    intro h; rw [h] at *
    have : X = C := sorry
    rw [this] at CX_eq_BX; simp at CX_eq_BX
    exact h_BC_ne CX_eq_BX.symm
  use (affineLineIntersection ℝ (line[ℝ, B, C]) (line[ℝ, E, F]) (sorry))
  refine ⟨h_EF, h_O1O2, ?_⟩
  sorry

end IMO2021P3
