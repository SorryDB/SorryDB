import Mathlib


open scoped EuclideanGeometry
open Affine Module

namespace IMO2021P3

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result {A B C D E F X O₁ O₂ : P}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C])
    (acuteAngled_ABC : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).AcuteAngled)
    (AC_lt_AB : dist A C < dist A B)
    (D_mem_interior_ABC : D ∈ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).interior)
    (angle_DAB_eq_angle_CAD : ∠ D A B = ∠ C A D) (wbtw_A_E_C : Wbtw ℝ A E C)
    (angle_ADE_eq_angle_BCD : ∠ A D E = ∠ B C D) (wbtw_A_F_B : Wbtw ℝ A F B)
    (angle_FDA_eq_angle_DBC : ∠ F D A = ∠ D B C) (X_mem_AC : X ∈ line[ℝ, A, C])
    (CX_eq_BX : dist C X = dist B X)
    (affineIndependent_ADC : AffineIndependent ℝ ![A, D, C])
    (O₁_eq_circumcenter_ADC : O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumcenter)
    (affineIndependent_EXD : AffineIndependent ℝ ![E, X, D])
    (O₂_eq_circumcenter_EXD : O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumcenter) :
    E ≠ F ∧ O₁ ≠ O₂ ∧ (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂] : Set P).Nonempty := by
  let h_A_ne_B := affineIndependent_ABC.injective.ne (show (0 : Fin 3) ≠ 1 by decide)
  let h_A_ne_C := affineIndependent_ABC.injective.ne (show (0 : Fin 3) ≠ 2 by decide)
  let h_B_ne_C := affineIndependent_ABC.injective.ne (show (1 : Fin 3) ≠ 2 by decide)
  let h_A_ne_D := (Triangle.mem_interior_iff_affineIndependent_of_affineIndependent affineIndependent_ABC).1 D_mem_interior_ABC.1
  have hE_mem : E ∈ segment ℝ A C := ⟨wbtw_A_E_C.left_mem, wbtw_A_E_C.right_mem⟩
  have hF_mem : F ∈ segment ℝ A B := ⟨wbtw_A_F_B.left_mem, wbtw_A_F_B.right_mem⟩
  have h_E_ne_A : E ≠ A := by
    intro hE
    have h_angle := angle_ADE_eq_angle_BCD
    rw [hE, angle_ADA h_A_ne_D] at h_angle
    have h_BCD_pos : 0 < ∠ B C D := (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).angle_pos D_mem_interior_ABC
    exact h_BCD_pos.ne' h_angle.symm
  have h_F_ne_A : F ≠ A := by
    intro hF
    have h_angle := angle_FDA_eq_angle_DBC
    rw [hF, angle_ADA h_A_ne_D] at h_angle
    have h_DBC_pos : 0 < ∠ D B C := (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).angle_pos' D_mem_interior_ABC
    exact h_DBC_pos.ne' h_angle.symm
  have h_E_ne_F : E ≠ F := by
    intro h_eq
    have h_mem_AB : E ∈ line[ℝ, A, B] := by rw [h_eq]; exact line_subset_affineSpan ℝ {A, B} hF_mem
    have h_mem_AC : E ∈ line[ℝ, A, C] := line_subset_affineSpan ℝ {A, C} hE_mem
    have h_E_eq_A : E = A := (line_affineSpan_intersection_eq_self affineIndependent_ABC h_A_ne_B h_A_ne_C).1 ⟨h_mem_AB, h_mem_AC⟩
    exact h_E_ne_A h_E_eq_A
  have h_O1_ne_O2 : O₁ ≠ O₂ := by
    intro h_eq
    have h_D_mem_O1 : dist D O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumradius := (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).dist_circumcenter_eq_circumradius 1
    have h_E_mem_O2 : dist E O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumradius := (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).dist_circumcenter_eq_circumradius 0
    have h_X_mem_O2 : dist X O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumradius := (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).dist_circumcenter_eq_circumradius 1
    have h_D_mem_O2 : dist D O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumradius := (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).dist_circumcenter_eq_circumradius 2
    have h_A_mem_O1 : dist A O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumradius := (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).dist_circumcenter_eq_circumradius 0
    have h_C_mem_O1 : dist C O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumradius := (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).dist_circumcenter_eq_circumradius 2
    rw [h_eq] at h_A_mem_O1 h_C_mem_O1 h_D_mem_O1
    have h_A_E_X_C_on_circle : A ∈ sphere O₂ (dist D O₂) ∧ E ∈ sphere O₂ (dist D O₂) ∧ X ∈ sphere O₂ (dist D O₂) ∧ C ∈ sphere O₂ (dist D O₂) := by
      simp [h_A_mem_O1, h_E_mem_O2, h_X_mem_O2, h_C_mem_O1, h_D_mem_O2]
    have h_line_AC : line[ℝ, A, C] = line[ℝ, A, E] := line_eq_line_of_mem h_A_ne_A h_A_ne_C (mem_line_left ℝ A C) (line_subset_affineSpan ℝ {A, C} hE_mem)
    have h_four_points : {A, E, X, C} ⊆ sphere O₂ (dist D O₂) ∩ line[ℝ, A, C] := by
      simp [h_A_mem_O1, h_E_mem_O2, h_X_mem_O2, h_C_mem_O1, h_D_mem_O2, X_mem_AC, line_subset_affineSpan ℝ {A, C} hE_mem]
    have h_size : (sphere O₂ (dist D O₂) ∩ line[ℝ, A, C]).Finite := sphere_inter_line_finite O₂ (dist D O₂) (line_affineSpan_ne_empty ℝ A C)
    have h_card : ({A, E, C} : Set P).ncard ≤ 2 := (Set.ncard_le_of_subset (by simp [h_A_mem_O1, h_E_mem_O2, h_C_mem_O1, X_mem_AC, line_subset_affineSpan ℝ {A, C} hE_mem]) h_size).trans (sphere_inter_line_card_le O₂ (dist D O₂) (line_affineSpan_ne_empty ℝ A C))
    have h_distinct : {A, E, C}.ncard = 3 := by
      rw [Set.ncard_insert_of_not_mem, Set.ncard_insert_of_not_mem, Set.ncard_singleton]
      · exact h_A_ne_C; · simp [h_E_ne_A, h_E_ne_A.symm]
      · intro h; cases h with | inl h => exact h_E_ne_A h | inr h => exact (wbtw_A_E_C.mem_segment.2.ne_of_dist_lt AC_lt_AB).symm h
    exact (h_distinct.le.trans h_card).not_lt (by norm_num)
  refine ⟨h_E_ne_F, h_O1_ne_O2, ?_⟩
  let P_int := line[ℝ, B, C] ∩ line[ℝ, E, F]
  obtain ⟨P, hP_bc, hP_ef⟩ := (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).parallel_side_EF_BC_iff_AB_eq_AC AC_lt_AB.ne h_E_ne_F wbtw_A_E_C wbtw_A_F_B angle_ADE_eq_angle_BCD angle_FDA_eq_angle_DBC
  refine ⟨P, ⟨hP_bc, hP_ef, ?_⟩⟩
  sorry
