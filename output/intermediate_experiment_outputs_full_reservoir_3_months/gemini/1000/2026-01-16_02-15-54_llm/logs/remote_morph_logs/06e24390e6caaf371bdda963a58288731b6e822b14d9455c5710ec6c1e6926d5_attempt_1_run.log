lemma variance_dual_stdGaussianMulti (L : StrongDual ℝ E) :
    Var[L; stdGaussianMulti E] = ∑ i, L (stdOrthonormalBasis ℝ E i) ^ 2 := by
  rw [variance_def, isCentered_stdGaussianMulti L, sub_zero, stdGaussianMulti,
    integral_map L.continuous.measurable (by fun_prop)]
  simp_rw [L.map_sum, L.map_smul, smul_eq_mul]
  set μ_pi := Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)
  have h_int i : Integrable (fun x ↦ x i * L (stdOrthonormalBasis ℝ E i)) μ_pi := by
    apply Integrable.mul_const
    convert integrable_eval_pi (i := i) (f := id) ?_
    · infer_instance
    · rw [← memLp_one_iff_integrable]; exact memLp_id_gaussianReal 1
  have h_cent : ∫ x, ∑ i, x i * L (stdOrthonormalBasis ℝ E i) ∂μ_pi = 0 := by
    rw [← integral_map L.continuous.measurable (by fun_prop), ← isCentered_stdGaussianMulti L]; rfl
  rw [← variance_def, h_cent, sub_zero, IndepFun.variance_sum]
  · simp_rw [mul_comm, ← smul_eq_mul, variance_mul]
    have h_var i : Var[fun x ↦ x i; μ_pi] = 1 := by
      have h1 : ∫ x, x i ∂μ_pi = 0 := by
        rw [integral_eval_pi (by rw [← memLp_one_iff_integrable]; exact memLp_id_gaussianReal 1),
          integral_id_gaussianReal 0 1]
      rw [variance_def, h1, sub_zero,
        integral_eval_pi (by rw [← memLp_two_iff_integrable]; exact memLp_id_gaussianReal 2)]
      · convert variance_id_gaussianReal 0 1
        rw [variance_def, integral_id_gaussianReal 0 1, sub_zero]
      · infer_instance
    simp_rw [h_var, mul_one]
  · exact fun i j h ↦ (indepFun_eval i j h).comp (measurable_mul_const _) (measurable_mul_const _)
  · exact h_int

end ProbabilityTheory
