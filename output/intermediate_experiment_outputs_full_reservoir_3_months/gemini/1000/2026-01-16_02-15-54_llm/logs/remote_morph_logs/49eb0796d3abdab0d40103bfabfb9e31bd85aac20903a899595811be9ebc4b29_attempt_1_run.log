```lean
/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let sigma := Module.support A M ∩ {p | p.asIdeal.primeHeight = 1}
  have h_fin : sigma.Finite := hMT.finite_primeHeight_one_support
  rcases sigma.eq_empty_or_nonempty with h_empty | h_ne
  · refine ⟨PEmpty, inferInstance, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim, ⟨0, ?_⟩⟩
    simp [isPseudoIsomorphism_iff, Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
    refine ⟨fun p hp ↦ ?_, fun p hp ↦ ?_⟩
    · rw [LocalizedModule.subsingleton_iff]; intro m
      contrapose! h_empty; exact ⟨p, hp, (Module.mem_support_iff_of_finite A M p).2 (LocalizedModule.not_subsingleton_iff.2 h_empty)⟩
    · simp [LinearMap.range_zero, Submodule.Quotient.subsingleton_iff]
  · set S := ⨅ p ∈ sigma, p.asIdeal.primeCompl
    haveI : IsDomain (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma (fun _ h ↦ h.2) h_ne h_fin).1
    haveI : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma (fun _ h ↦ h.2) h_ne h_fin).2
    have h_torsion : Module.IsTorsion (Localization S) (LocalizedModule S M) := by
      rintro ⟨m, s⟩; obtain ⟨a, ha⟩ := hMT m; use algebraMap A (Localization S) a
      refine ⟨mem_nonZeroDivisors_iff_ne_zero.2 fun h ↦ ha (Ideal.comap_bot_of_injective (algebraMap A (Localization S)) (IsLocalization.injective _ (iInf_le_of_le h_ne.some (iInf_le_of_le h_ne.some_mem (fun _ _ ↦ rfl)))) (Ideal.mem_comap.mpr (h.symm ▸ Ideal.zero_mem _))), ?_⟩
      simp [ha]
    obtain ⟨ι, _, q, hq, e, ⟨h_equiv⟩⟩ := Module.torsion_module_equiv_directSum (Localization S) (LocalizedModule S M) h_torsion
    let ι' := {i // 0 < e i}
    let p' := fun i : ι' ↦ PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨q i, (hq i).isPrime⟩
    have hp' : ∀ i, (p' i).asIdeal.primeHeight = 1 := fun i ↦ by
      rw [← Ideal.primeHeight_comap_localization_of_isLocalization S]; exact Ideal.primeHeight_one_of_maximal_ideal_of_isPrincipalIdealRing (hq i).isPrime (fun h ↦ Ideal.not_maximal_bot _ (h ▸ hq i))
    refine ⟨ι', inferInstance, p', hp', fun i ↦ e i, fun i ↦ i.2, ?_⟩
    let N := (i : ι') → A ⧸ (p' i).asIdeal ^ e i
    have : Nonempty (LocalizedModule S N ≃ₗ[Localization S] LocalizedModule S M) := by
      refine ⟨(h_equiv.trans ?_).symm.trans (LocalizedModule.funDirectSum S ι' _).symm⟩
      refine ((LinearEquiv.directSumCongr fun i ↦ ?_).trans (LinearEquiv.directSum_subtype_fun 0 fun i hi ↦ (by simp at hi; exact hi))).symm
      by_cases hi : 0 < e i
      · exact (LocalizedModule.at_ideal_pow_localization S (p' ⟨i, hi⟩).asIdeal (e ⟨i, hi⟩)).symm
      · exact (LinearEquiv.ofSubsingleton _ _).trans (LinearEquiv.ofSubsingleton _ _)
    obtain ⟨g⟩ := this; obtain ⟨f, hf⟩ := LocalizedModule.IsLocalization.exists_linearMap S M N g.symm
    use f; rw [LinearMap.isPseudoIsomorphism_iff_bijective_map, (by ext p; constructor <;> rintro ⟨h1, h2⟩ <;> [rcases h1 with h | h; _; _] <;> simp_all [sigma, p', Module.support_pi, Module.support_quotient_pow, Ideal.minimalPrimes_eq_subsingleton_self (p' _).2])]
    exact ⟨hf ▸ g.symm.injective, hf ▸ g.symm.surjective⟩
