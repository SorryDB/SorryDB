-- #check Module.equiv_directSum_of_isTorsion

/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let σ := (Module.support A M) ∩ {p : PrimeSpectrum A | p.asIdeal.primeHeight = 1}
  have hσf : σ.Finite := hMT.finite_primeHeight_one_support
  rcases σ.eq_empty_or_nonempty with hσe | hσn
  · use Empty, inferInstance, Empty.elim, Empty.elim, Empty.elim, Empty.elim
    let S : Submonoid A := ⨅ p ∈ σ, p.asIdeal.primeCompl
    have : IsPseudoNull A M := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton A M).mpr fun p hp ↦ by
      rcases hp.lt_or_eq with h | h
      · exact LocalizedModule.subsingleton_iff.mpr fun m ↦ (hMT m).imp fun s hs ↦ ⟨Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes (Ideal.primeHeight_eq_zero_iff.mp (ENat.lt_one_iff_eq_zero.mp h)) (mem_nonZeroDivisors_iff_ne_zero.mpr hs.1) |> Set.disjoint_right.mp (by simp), hs.2⟩
      · exact (Set.not_mem_empty p (hσe ▸ (Set.mem_inter_iff.mpr ⟨Module.mem_support_iff_of_finite.mpr fun hM ↦ by rw [hM] at h; exact ENat.zero_ne_one h.symm, h⟩))).elim
    refine (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT (Module.isTorsion_pi_iff.mpr Empty.elim) 0).mpr ?_
    simp [S, hσe, LocalizedModule.subsingleton_iff.mpr ((LocalizedModule.isPseudoNull_iff _ M).mp this)]
  · let S : Submonoid A := ⨅ p ∈ σ, p.asIdeal.primeCompl
    haveI hD : IsDomain (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) hσn hσf).1
    haveI hP : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) hσn hσf).2
    obtain ⟨n, d, ⟨e_iso⟩⟩ := Module.equiv_directSum_quotient_span (LocalizedModule S M)
    have : ∀ i, d i ≠ 0 := fun i ↦ by intro h; have := e_iso.symm; have := (Module.LocalizedModule_isTorsion_iff S hMT).mpr hMT; specialize this (e_iso.symm (DirectSum.lof _ _ i 1)); rw [h] at this; simp at this
    let ι := Σ i : Fin n, {p : PrimeSpectrum (Localization S) // p.asIdeal.IsMaximal ∧ 0 < (WfCountable.valuation (p.asIdeal) (d i))}
    let p_of (x : ι) : PrimeSpectrum A := PrimeSpectrum.comap (algebraMap A (Localization S)) x.2.1
    let e_of (x : ι) : ℕ := (WfCountable.valuation (x.2.1.asIdeal) (d x.1)).get (by apply WfCountable.isUnit_pow_valuation_not_unit; exact x.2.1.asIdeal.isMaximal.ne_bot; exact this x.1)
    have hp (x : ι) : (p_of x).asIdeal.primeHeight = 1 := by
      have := x.2.1.asIdeal.isMaximal; obtain ⟨q, hq, rfl⟩ := (PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one (Localization S) σ (by simp) hσn hσf).subset (Set.mem_range_self x.2.1.toPrimeSpectrum)
      rcases hq with hq | hq; · exfalso; have := x.2.1.isPrime; rw [hq] at this; exact this.ne_bot rfl; · simpa using (σ.subset_iff.mp (by simp) q hq).1
    use ι, inferInstance, p_of, hp, e_of, fun x ↦ x.2.2
    let N := (x : ι) → A ⧸ (p_of x).asIdeal ^ (e_of x)
    have : LocalizedModule S N ≃ₗ[Localization S] LocalizedModule S M := by
      refine (LinearEquiv.PiCongrLeft (Localization S) fun x ↦ (LocalizedModule.isLocalization_isLocalization_AtPrime_quotient_pow S (p_of x).asIdeal (e_of x) _)).trans ?_
      simp [N, ι, p_of, e_of]; refine e_iso.symm.trans (LinearEquiv.piCongrRight fun i ↦ (IsPrincipalIdealRing.quotient_equiv_pi_factors (d i) (this i)).trans (LinearEquiv.PiCongrLeft _ fun p ↦ ?_))
      congr; ext; simp [p_of, e_of, WfCountable.valuation]
    obtain ⟨f, s, hf⟩ := LocalizedModule.exists_is_localization_hom A S M N this.symm
    exact (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT (Module.isTorsion_pi_iff.mpr fun i ↦ Module.IsTorsion.quotient _ (Module.IsTorsion.pow_ideal_of_isTorsion (by rw [hp i]; exact ENat.zero_ne_one.symm))) f).mpr (by simp [hf]; apply Function.Bijective.comp; · exact this.symm.bijective; · exact (Units.left_multiplication_is_localization (Localization S) s).bijective)
```
