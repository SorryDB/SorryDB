/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  set s := Module.support A M ∩ {p | p.1.primeHeight = 1}
  have hfs := Module.IsTorsion.finite_primeHeight_one_support hMT
  rcases s.eq_empty_or_nonempty with h | h
  · refine ⟨PEmpty, inferInstance, PEmpty.elim, (by intro i; rcases i), (by intro i; rcases i), (by intro i; rcases i), ?_⟩
    refine IsPseudoIsomorphic.zero_left.2 (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton.2 fun p hp ↦ ?_)
    rw [Module.subsingleton_iff_not_mem_support, Module.mem_support_iff_of_finite]
    intro hm; exact h.subset ⟨hm, (ENat.le_one_iff_eq_zero_or_eq_one.1 hp).resolve_left (fun h0 ↦ hMT.annihilator_ne_bot (Ideal.primeHeight_eq_zero_iff.1 h0 ▸ Module.annihilator_bot_of_mem_support hm))⟩
  let S := ⨅ p ∈ s, p.1.primeCompl
  have hS := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (by simp) h hfs
  haveI : IsDomain (Localization S) := hS.1; haveI : IsPrincipalIdealRing (Localization S) := hS.2
  have hM' : Module.IsTorsion (Localization S) (LocalizedModule S M) := by
    rintro x; obtain ⟨m, s'⟩ := LocalizedModule.mk_surjective S x; obtain ⟨a, ha⟩ := hMT m
    refine ⟨algebraMap A _ a, (mem_nonZeroDivisors_iff_ne_zero.2 (IsLocalization.algebraMap_injective S _ (nonZeroDivisors.ne_zero ha))), by simp [LocalizedModule.smul_mk, ha]⟩
  obtain ⟨ι, hι, q, hqp, hqb, e, he, e'⟩ := Module.equiv_directSum_of_isTorsion (LocalizedModule S M) hM'
  let p i := PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨q i, hqp i⟩
  refine ⟨ι, hι, p, fun i ↦ ?_, e, he, ?_⟩
  · have hrange := PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one (Localization S) s (by simp) h hfs
    have hq_max : (q i).IsMaximal := IsMaximal.of_principal_not_bot (hqb i)
    have : ⟨q i, hqp i⟩ ∈ Set.range (PrimeSpectrum.comap (algebraMap A (Localization S))) := by rw [hrange]; exact Or.inl hq_max.ne_bot
    obtain ⟨p', hp'⟩ := this; rw [← hp'] at hrange ⊢; exact (Set.mem_union.1 (hrange ▸ Set.mem_range_self p')).resolve_right (by simp [hq_max.ne_bot]) |>.1
  · obtain ⟨f, s', hf⟩ := IsLocalization.LocalizedModule.exists_linearMap S M ((i : ι) → A ⧸ (p i).1 ^ e i) (e'.trans (DirectSum.linearEquivFunOnFintype _ _ _).symm (LocalizedModule.linearEquiv_pi_quotient_power S p e).symm).toLinearMap
    have hNT : Module.IsTorsion A ((i : ι) → A ⧸ (p i).1 ^ e i) := by
      intro g; obtain ⟨a, ha⟩ := hMT.annihilator_ne_bot.nonempty; use a, ha; ext i; simp;
      have : a ∈ (p i).asIdeal := (Module.mem_support_iff_of_finite A M).1 (by
        have hrange := PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one (Localization S) s (by simp) h hfs
        have hq_max : (q i).IsMaximal := IsMaximal.of_principal_not_bot (hqb i)
        have : ⟨q i, hqp i⟩ ∈ Set.range (PrimeSpectrum.comap (algebraMap A (Localization S))) := by rw [hrange]; exact Or.inl hq_max.ne_bot
        obtain ⟨p', hp'⟩ := this; have : p i = p' := PrimeSpectrum.localization_comap_injective (Localization S) S hp';
        rw [this]; exact (hrange ▸ Set.mem_range_self p' |> Set.mem_union.1 |> Or.resolve_right · (by simp [hq_max.ne_bot])).1) |>.2;
      rw [Ideal.Quotient.eq_zero_iff_mem]; exact Ideal.pow_le_self (he i).ne' this
    use f; rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f]
    rw [hf, LocalizedModule.map_smul]; exact (LocalizedModule.bijective_iff_bijective_smul S _ _ (IsLocalization.algebraMap_unit _ s')).2 (by simp)
