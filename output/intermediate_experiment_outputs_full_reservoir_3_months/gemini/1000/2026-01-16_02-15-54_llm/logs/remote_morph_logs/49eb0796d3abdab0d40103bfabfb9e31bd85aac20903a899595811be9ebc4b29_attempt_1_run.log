```lean
/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let σ := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hσ : σ.Finite := hMT.finite_primeHeight_one_support
  rcases σ.eq_empty_or_nonempty with hσe | hσn
  · refine ⟨PEmpty, inferInstance, fun i => (hσe ▸ i).1, fun i => (hσe ▸ i).1.2, fun _ => 1, fun i => (hσe ▸ i).1.2, ?_⟩
    have : Module.IsPseudoNull A M := by
      rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
      intro p hp
      rcases hp.le.eq_or_lt with hp | hp
      · rw [← Module.notMem_support_iff]; intro hps; exact hσe.subset ⟨hp, hps⟩
      · apply (LocalizedModule.subsingleton_iff A p.1.primeCompl).2
        intro m; obtain ⟨s, hs⟩ := hMT m
        use s, (Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes (Ideal.primeHeight_eq_zero_iff.1 (ENat.lt_one_iff_eq_zero.1 hp))).symm (Submonoid.coe_mem s), hs
    exact ⟨LinearMap.isPseudoIsomorphism_zero_zero this⟩
  set S := ⨅ p ∈ σ, p.1.primeCompl
  have hS : S ≤ nonZeroDivisors A := iInf_le_of_le hσn.some (iInf_le_of_le hσn.some_mem hσn.some.1.primeCompl_le_nonZeroDivisors)
  haveI : IsDomain (Localization S) := IsLocalization.isDomain_localization hS
  haveI : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (fun p hp => hp.2) hσn hσ).2
  obtain ⟨ι, _, p, hp, e, he, iso⟩ := IsPrincipalIdealRing.exists_equiv_directSum_quotient_span_singleton_prime_power (Localization S) (LocalizedModule S M)
  have h_range : ∀ i, (p i).asIdeal ∈ Set.range (PrimeSpectrum.comap (algebraMap A (Localization S))) := by
    intro i; rw [PrimeSpectrum.localization_comap_range (Localization S) S]
    exact Or.inr (hp i)
  let p' : ι → PrimeSpectrum A := fun i => (h_range i).choose
  have hp' : ∀ i, (p' i).asIdeal.primeHeight = 1 := fun i => by
    have h_comap := (h_range i).choose_spec
    rw [← h_comap, PrimeSpectrum.comap_asIdeal] at hp
    have : (p' i).asIdeal.primeHeight = 1 ∨ (p' i).asIdeal.primeHeight = 0 := by
      rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one (Localization S) σ (fun p hp => hp.2) hσn hσ] at h_comap
      rcases h_comap with h | h
      · exact Or.inl (Set.mem_setOf.1 h.2)
      · exact Or.inr (Ideal.primeHeight_eq_zero_iff.2 (PrimeSpectrum.ext_iff.1 h).symm)
    rcases this with h | h
    · exact h
    · exfalso; rw [h, Ideal.comap_bot_of_injective (algebraMap A (Localization S)) (IsLocalization.injective _ hS)] at hp
      rw [hp] at iso; exact (iso.1 i).subsingleton_of_subsingleton
  let N := (i : ι) → A ⧸ (p' i).asIdeal ^ e i
  have hNT : Module.IsTorsion A N := Module.IsTorsion.pi (fun i => Module.IsTorsion.quotient (fun m => ⟨(p' i).asIdeal ^ e i, Ideal.pow_mem_nonZeroDivisors (hp' i ▸ (Ideal.primeHeight_eq_one_iff_minimal_away_bot (p' i).asIdeal).1 (p' i).2) (he i)⟩))
  have hNI : LocalizedModule S N ≃ₗ[Localization S] LocalizedModule S M := (LocalizedModule.equivPi S (fun i => A ⧸ (p' i).asIdeal ^ e i)).symm.trans (iso.symm.trans (LocalizedModule.equivDirectSum S _).symm)
  obtain ⟨f, hf⟩ := LocalizedModule.exists_linearMap_of_localized_linearMap S M N hNI.symm
  refine ⟨ι, inferInstance, p', hp', e, he, ⟨f, ?_⟩⟩
  rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT]
  rwa [← hf, (Localization.atUnits S (Localization S) (Units.map (Submonoid.localizationMap S (Localization S)) (Units.mk0 _ (fun h => by have := IsLocalization.injective (Localization S) hS h; exact hS.ne_zero (Submonoid.coe_mem _) this))))]
