  set s := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hf : s.Finite := hMT.finite_primeHeight_one_support
  rcases s.eq_empty_or_nonempty with h | h
  · use Empty, inferInstance, Empty.elim, Empty.elim, Empty.elim, Empty.elim
    refine ⟨LinearMap.toZero M, (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton.2 fun p hp ↦ ?_), Submodule.subsingleton_bot⟩
    rcases hp.eq_or_lt with h1 | h0
    · have : p ∉ Module.support A M := λ hm ↦ (Set.eq_empty_iff_forall_not_mem.1 h ⟨p, h1, hm⟩); rwa [Module.notMem_support_iff] at this
    · rw [ENat.lt_one_iff_eq_zero, Ideal.primeHeight_eq_zero_iff] at h0; rw [LocalizedModule.subsingleton_iff]; rintro ⟨m, hm⟩; obtain ⟨⟨r, hrnz⟩, hr⟩ := hMT ⟨m, hm⟩; exact ⟨r, (Set.disjoint_right.1 (Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes h0) (by simpa)), (by simpa)⟩
  let S := ⨅ p ∈ s, p.1.primeCompl
  letI : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (λ p hp ↦ hp.2) h hf).2
  have hMT' : Module.IsTorsion (Localization S) (LocalizedModule S M) := by
    rintro ⟨m, r⟩; obtain ⟨⟨a, ha1⟩, ha2⟩ := hMT m; refine ⟨algebraMap A _ a, (by rw [mem_nonZeroDivisors_iff_ne_zero, (IsLocalization.injective (Localization S) _).ne_iff]; exact ha1; exact iInf_le_of_le h.some (iInf_le_of_le h.some_mem h.some.1.primeCompl_le_nonZeroDivisors)), by simp [ha2]⟩
  obtain ⟨ι, _, p', hp', e, he, ⟨g⟩⟩ := Module.IsTorsion.equiv_iDirectSum_maximal_pow hMT'
  let p i := PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨p' i, (hp' i).isPrime⟩
  have hpi i : (p i).1.primeHeight = 1 := by
    have := Set.mem_range_self (f := PrimeSpectrum.comap (algebraMap A (Localization S))) ⟨p' i, (hp' i).isPrime⟩
    rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one (Localization S) s (λ p hp ↦ hp.2) h hf, Set.union_singleton, Set.mem_insert_iff] at this
