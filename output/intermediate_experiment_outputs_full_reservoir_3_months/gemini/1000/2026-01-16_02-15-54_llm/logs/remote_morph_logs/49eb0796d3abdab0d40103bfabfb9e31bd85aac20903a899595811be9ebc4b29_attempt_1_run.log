  let N := (i : ι) → A ⧸ (p i).1 ^ e i
  have hNT : Module.IsTorsion A N := λ x ↦ by
    have := λ i ↦ hMT (1 : A ⧸ (p i).1 ^ e i); choose r hr1 hr2 using this
    use ∏ i, r i, (Submonoid.prod_mem _ fun i _ ↦ hr1 i), (by ext i; simp [hr2 i])
  obtain ⟨f, hf_iso⟩ : ∃ f : M →ₗ[A] N, Function.Bijective (LocalizedModule.map S f) := sorry
  exact ⟨ι, inferInstance, p, hpi, e, he, f, (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f).2 hf_iso⟩

