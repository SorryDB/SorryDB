/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let s := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}
  have hfin : s.Finite := hMT.finite_primeHeight_one_support
  rcases s.eq_empty_or_nonempty with hse | hsn
  · refine ⟨PEmpty, inferInstance, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim, ?_⟩
    apply IsPseudoIsomorphic.of_isPseudoNull hMT
    intro p hp; rcases hp.2.le_iff_eq_or_lt.1 hp.1 with h | h
    · exact hMT.isPseudoNull_zero hp.1 h
    · rw [← hse] at h; exact (h hp.2).elim
  · let S := ⨅ p ∈ s, p.1.primeCompl
    let hPID := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (fun p hp => hp.1) hsn hfin
    letI : IsDomain (Localization S) := hPID.1
    letI : IsPrincipalIdealRing (Localization S) := hPID.2
    obtain ⟨ι, hf, p, hpm, e, he, ⟨equiv⟩⟩ :=
      Module.Finite.equiv_directSum_quotient_p_pow_e (Localization S) (LocalizedModule S M) (hMT.localizedModule S)
    let p' := fun i => (p i).comap (algebraMap A (Localization S))
    refine ⟨ULift.{u} ι, inferInstance, fun i => ⟨p' i.down, inferInstance⟩, ?_, fun i => e i.down, fun i => he i.down, ?_⟩
    · intro i; exact (p i.down).primeHeight_comap_localization S (hpm i.down).isHeightOne
    · apply IsPseudoIsomorphic.of_localized_equiv S hMT _ equiv
      intro i; exact (p' i.down).isTorsion_quotient_pow (he i.down)
