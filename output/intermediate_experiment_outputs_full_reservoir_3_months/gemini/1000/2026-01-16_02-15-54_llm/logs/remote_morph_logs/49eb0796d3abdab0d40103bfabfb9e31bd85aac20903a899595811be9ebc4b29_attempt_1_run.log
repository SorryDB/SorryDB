/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  set s := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}
  have hfs := hMT.finite_primeHeight_one_support
  rcases s.eq_empty_or_nonempty with h | hne
  · use PEmpty, inferInstance, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim
    rw [isPseudoIsomorphism_zero_iff_isPseudoNull]
    intro p hp; rw [LocalizedModule.subsingleton_iff]; contrapose! h; exact ⟨p, hp.1, hp.2, h⟩
  · let S := ⨅ p ∈ s, p.1.primeCompl
    letI := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (fun _ h => h.1) hne hfs).2
    obtain ⟨ι, _, P, hP, hPne, e, he, ⟨eMS⟩⟩ := (LocalizedModule.isTorsion S hMT).exists_is_internal_prime_power_decomposition
    let p i := PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨P i, hP i⟩
    have hp1 i : (p i).1.primeHeight = 1 := by
      rw [← Ideal.height_eq_primeHeight, ← IsLocalization.AtPrime.primeHeight_is_localized_comap S (P i) (hP i)]
      exact IsPrincipalIdealRing.height_one_of_isPrime_ne_bot (hP i) (hPne i)
    use ι, inferInstance, p, hp1, e, he
    let N := (i : ι) → A ⧸ (p i).1 ^ e i
    have hNT : Module.IsTorsion A N := Module.IsTorsion.pi (fun i => Module.IsTorsion.quotient_power_isPrime (p i).2 (he i))
    obtain ⟨f, hf⟩ := IsLocalization.surjective_on_linearMap S M N (eMS.trans (by sorry))
    use f; rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f, hf]; exact (eMS.trans (by sorry)).bijective
