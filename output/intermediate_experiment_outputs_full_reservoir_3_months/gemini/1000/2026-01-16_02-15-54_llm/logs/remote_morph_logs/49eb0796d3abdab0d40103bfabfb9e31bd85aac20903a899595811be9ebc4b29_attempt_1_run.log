/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  set σ := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hσ : σ.Finite := hMT.finite_primeHeight_one_support
  let S := ⨅ p ∈ σ, p.1.primeCompl
  obtain rfl | hσne := σ.eq_empty_or_nonempty
  · use Empty, inferInstance, Empty.elim, Empty.elim, Empty.elim, Empty.elim
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT (Module.isTorsion_zero A)]
    simp [σ]
  haveI : IsDomain (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) hσne hσ).1
  haveI : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) hσne hσ).2
  obtain ⟨ι, _, d, hnz, -, ⟨e_iso⟩⟩ := exists_is_torsion_module_isomorphism (R := Localization S) (M := LocalizedModule S M)
  let factors i := UniqueFactorizationMonoid.normalizedFactors (d i)
  let ι' := Σ i, {q ∈ (factors i).toFinset // True}
  let p iq := PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨Ideal.span {iq.2.1}, (UniqueFactorizationMonoid.irreducible_iff_prime.1 iq.2.1.2).prime⟩
  let e' iq := (factors iq.1).count iq.2.1
  refine ⟨ι', inferInstance, p, ?_, e', ?_, ?_⟩
  · intro iq
    have := (PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one (Localization S) σ (by simp) hσne hσ).symm
    have hmem : p iq ∈ σ ∪ {⟨⊥, Ideal.bot_prime⟩} := by rw [this]; exact Set.mem_range_self _
    rcases hmem with hσ' | hb
    · exact (Set.mem_setOf_eq.1 (σ.mem_coe.1 hσ')).2
    · exfalso; exact iq.2.1.1.ne_zero (Ideal.span_singleton_eq_bot.1 (Ideal.comap_bot_of_injective _ (IsLocalization.injective _ (iInf_le_of_le hσne.some (iInf_le_of_le hσne.some_mem hσne.some.1.primeCompl_le_nonZeroDivisors))) ▸ (congr_arg PrimeSpectrum.asIdeal hb)))
  · exact fun iq => Multiset.count_pos.2 iq.2.1.2
  · let N := (iq : ι') → A ⧸ (p iq).asIdeal ^ e' iq
    have hNT : Module.IsTorsion A N := Module.isTorsion_pi (fun i => (p i).1.primeHeight_eq_one_isTorsion (by
      have := (PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one (Localization S) σ (by simp) hσne hσ).symm
      have hmem : p i ∈ σ ∪ {⟨⊥, Ideal.bot_prime⟩} := by rw [this]; exact Set.mem_range_self _
      rcases hmem with hσ' | hb
      · exact (Set.mem_setOf_eq.1 (σ.mem_coe.1 hσ')).2
      · exfalso; exact i.2.1.1.ne_zero (Ideal.span_singleton_eq_bot.1 (Ideal.comap_bot_of_injective _ (IsLocalization.injective _ (iInf_le_of_le hσne.some (iInf_le_of_le hσne.some_mem hσne.some.1.primeCompl_le_nonZeroDivisors))) ▸ (congr_arg PrimeSpectrum.asIdeal hb)))))
    obtain ⟨f, s, hf⟩ := LocalizedModule.is_exists_linearMap S M N (e_iso.trans (by sorry))
    use f; rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT]
    rw [hf]; exact (IsLocalization.isUnit_singleton_units s).bijective.comp e_iso.bijective

