/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  set s := (Module.support A M ∩ {p : PrimeSpectrum A | p.asIdeal.primeHeight = 1})
  have h_fin : s.Finite := hMT.finite_primeHeight_one_support
  rcases s.eq_empty_or_nonempty with h_empty | h_nonempty
  · refine ⟨ULift PEmpty, inferInstance, ULift.rec PEmpty.elim, ULift.rec PEmpty.elim,
      ULift.rec PEmpty.elim, ULift.rec PEmpty.elim, ⟨0, ?_⟩⟩
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map]
    · intro _; simp; exact ⟨0, Submonoid.mem_top 0⟩
    · rw [h_empty]; simp
  · set S := ⨅ p ∈ s, p.1.primeCompl
    have h_pid := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (by simp) h_nonempty h_fin
    haveI : IsDomain (Localization S) := h_pid.1
    haveI : IsPrincipalIdealRing (Localization S) := h_pid.2
    have hMT_S : Module.IsTorsion (Localization S) (LocalizedModule S M) := hMT.localization S
    obtain ⟨ι, hfι, p', hp', hnz', e, iso_sum⟩ := Module.equiv_directSum_of_isTorsion hMT_S
    let ι' := {i : ι // 0 < e i}
    let n := Fintype.card ι'
    let f_ι' : ULift.{u} (Fin n) ≃ ι' := (Fintype.equivFin ι').symm.trans (Equiv.ulift.symm) |>.symm
    let p_new (i : ULift (Fin n)) : PrimeSpectrum A :=
