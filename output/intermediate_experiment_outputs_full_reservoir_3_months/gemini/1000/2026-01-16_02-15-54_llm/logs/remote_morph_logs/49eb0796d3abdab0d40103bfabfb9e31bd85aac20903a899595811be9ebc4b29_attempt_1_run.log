/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  obtain ⟨hfin, -⟩ := hMT.finite_primeHeight_one_support
  set s := Module.support A M ∩ {p | (p : PrimeSpectrum A).1.primeHeight = 1}
  rcases s.eq_empty_or_nonempty with hse | hsn
  · refine ⟨Empty, inferInstance, (fun i => i.elim), (fun i => i.elim), (fun i => i.elim), (fun i => i.elim), ?_⟩
    let f : M →ₗ[A] ((i : Empty) → A ⧸ (⊥ : Ideal A)) := 0
    have hNT : IsTorsion A ((i : Empty) → A ⧸ (⊥ : Ideal A)) := fun m => ⟨1, one_ne_zero, by simp⟩
    exact ⟨f, (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f).mpr (by simp [hse])⟩
  · set S := ⨅ p ∈ s, p.1.primeCompl
    have hPID := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (fun p hp => hp.2) hsn hfin
    letI : IsDomain (Localization S) := hPID.1
    letI : IsPrincipalIdealRing (Localization S) := hPID.2
    have hS : S ≤ nonZeroDivisors A := iInf_le_of_le hsn.some (iInf_le_of_le hsn.some_mem hsn.some.1.primeCompl_le_nonZeroDivisors)
    letI : IsDomain A := isDomain_of_isLocalization_isDomain S (Localization S)
    let MS := LocalizedModule S M
    have hMST : IsTorsion (Localization S) MS := by
      rintro ⟨m, hm⟩; obtain ⟨a, ha, am⟩ := hMT m; use algebraMap A (Localization S) a
      exact ⟨mem_nonZeroDivisors_iff_ne_zero.mpr (fun h => ha (IsLocalization.injective (Localization S) hS h)), by simp [LocalizedModule.smul_def, am]⟩
    obtain ⟨ι, _, q, hq, hq0, e, he, ⟨eMS⟩⟩ := IsPrincipalIdealRing.exists_equiv_directSum_quotient_pk (Localization S) MS hMST
    let p : ι → PrimeSpectrum A := fun i => ⟨Ideal.comap (algebraMap A (Localization S)) (q i), (hq i).comap _⟩
    have hp1 : ∀ i, (p i).asIdeal.primeHeight = 1 := by
      intro i
      have hqmax : (q i).IsMaximal := (hq i).isMaximal_of_isPrincipalIdealRing (hq0 i)
      have hps : p i ∈ s := by
        rw [Set.mem_inter_iff, ← IsLocalization.prime_comap_loc_iff (S := S) (Localization S)]
        exact ⟨hq i, by simpa using (Localization.localization_comap_range S S).symm.subset (Set.mem_range_self (q i))⟩
      exact hps.2
    set N := (i : ι) → A ⧸ (p i).1 ^ e i
    have hNT : IsTorsion A N := by intro m; obtain ⟨a, ha, am⟩ := hMT (hsn.some_mem.2.some); use a; simp
    let eNS : LocalizedModule S N ≃ₗ[Localization S] ((i : ι) → (Localization S) ⧸ (q i) ^ e i) :=
      (LocalizedModule.pi S _).trans (LinearEquiv.piCongrLeft fun i =>
        (LocalizedModule.quotient S ((p i).1 ^ e i)).trans (Ideal.quotientEquiv (Localization S) _ _
          (by rw [IsLocalization.map_pow (Localization S) S, IsLocalization.map_comap S (Localization S) (q i)]) (LinearEquiv.refl _ _)).quotientEquivAlg (LinearEquiv.refl _ _))
    obtain ⟨f, s_val, fS⟩ := IsLocalization.surjective_hom (M := LocalizedModule S M) (N := LocalizedModule S N) S S (eMS.trans eNS.symm).toLinearMap
    have hfS : Function.Bijective (LocalizedModule.map S f) := by
      have : LocalizedModule.map S f = (algebraMap (Localization S) (Localization S) s_val).smulRight (eMS.trans eNS.symm).toLinearMap := by
        ext m; simp [LocalizedModule.map_def, fS]
      rw [this]; exact (LinearEquiv.smul_right _ (IsLocalization.unit_of_mem_nonZeroDivisors (Localization S) S (S.mem_nonZeroDivisors_iff_ne_zero.mp (nonZeroDivisors_le_nonZeroDivisors_of_le hS (Submonoid.coe_mem s_val)))) (eMS.trans eNS.symm)).bijective
    refine ⟨ι, inferInstance, p, hp1, e, he, f, (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f).mpr ?_⟩
    rwa [← (show _ = S by simp [s, N])]
