/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  set sigma := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hfin : sigma.Finite := hMT.finite_primeHeight_one_support
  rcases sigma.eq_empty_or_nonempty with h_empty | h_sne
  · use Empty, inferInstance, (fun i => i.elim), (fun i => i.elim), (fun i => i.elim), (fun i => i.elim)
    rw [isPseudoIsomorphism_iff_bijective_map]
    simp [h_empty]
    exact hMT.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton.mpr (by simpa [h_empty])
  · let S := ⨅ p ∈ sigma, p.1.primeCompl
    haveI hS_dom : IsDomain (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma (fun p hp => hp.2) h_sne hfin).1
    haveI hS_pir : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma (fun p hp => hp.2) h_sne hfin).2
    let M' := LocalizedModule S M
    obtain ⟨ι, _, d, h_iso⟩ := IsPrincipalIdealRing.equivalent_directSum (Localization S) M'
    have h_tor : ∀ i, d i ≠ 0 := by
      intro i; contrapose! hMT; use (h_iso.symm (DirectSum.lof (Localization S) (fun i => (Localization S) ⧸ Localization S ∙ d i) i 1)).1.1
      sorry
    sorry
