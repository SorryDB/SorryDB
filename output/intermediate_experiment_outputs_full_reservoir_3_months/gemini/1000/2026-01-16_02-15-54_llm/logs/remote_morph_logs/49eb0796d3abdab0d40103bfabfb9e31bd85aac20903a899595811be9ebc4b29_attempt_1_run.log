        obtain ⟨⟨s, hsne⟩, hs⟩ := @hK_is_torsion ⟨m, hm⟩
        use s, ?_, by simpa using hs
        have : Set.Disjoint p.asIdeal (nonZeroDivisors A) := Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes hp₁
