theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  set σ := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hσf : σ.Finite := hMT.finite_primeHeight_one_support
  rcases σ.eq_empty_or_nonempty with h | h
  · refine ⟨PEmpty, inferInstance, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim, ?_⟩
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT (by intro m; rcases m with ⟨_⟩)]
    simp [h]
    exact ⟨Subsingleton.elim _ _, Subsingleton.elim _ _⟩
  let S := ⨅ p ∈ σ, p.1.primeCompl
  letI hpid := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (fun _ h' => h'.2) h hσf
  letI := hpid.1; letI := hpid.2
  have hMT' : Module.IsTorsion (Localization S) (LocalizedModule S M) := by
    rintro ⟨m, s⟩; obtain ⟨r, hr, hrm⟩ := hMT m
    refine ⟨algebraMap A (Localization S) r, ?_, ?_⟩
    · rw [mem_nonZeroDivisors_iff_ne_zero]; exact IsLocalization.to_id_injective S (Localization S) (by simpa using hr)
    · rw [← LocalizedModule.smul_mk, hrm, LocalizedModule.mk_zero]
  obtain ⟨ι, _, P, hP_pr, hP_ne, e, ⟨heq⟩⟩ := Module.equiv_directSum_of_isTorsion (Localization S) (LocalizedModule S M) hMT'
  let ι' := {i // 0 < e i}
  let p' := fun i : ι' => (⟨(P i.1).comap (algebraMap A (Localization S)), Ideal.IsLocalization.comap_is_prime _ S (P i.1)⟩ : PrimeSpectrum A)
  let N := (i : ι') → A ⧸ (p' i).1 ^ e i.1
  have hp' : ∀ i, (p' i).1.primeHeight = 1 := fun i =>
    (Ideal.IsLocalization.primeHeight_is_localization S _ _ (P i.1) (P i.1).2 (Ideal.IsLocalization.is_localization S _) (by rw [Ideal.comap_comap, ← IsLocalization.map_comp, IsLocalization.map_id]; rfl)).symm.trans (Ideal.primeHeight_of_isPrincipalIdealRing_isDomain (P i.1) (hP_pr i.1) (hP_ne i.1))
  have hNT : IsTorsion A N := IsTorsion.pi (fun i => IsTorsion.quotient _ (Ideal.exists_mem_nonZeroDivisors_of_primeHeight_pos (hp' i ▸ zero_lt_one)).some_mem)
  have hMN : Nonempty (LocalizedModule S M ≃ₗ[Localization S] LocalizedModule S N) := by
    refine ⟨heq.trans (DirectSum.linearEquivFunOnFintype _ _ _).symm.trans ?_⟩
    refine (LinearEquiv.ofSubsingleton _ _).trans (LocalizedModule.piEquiv S _).symm.trans (LinearEquiv.piCongrRight fun i => ?_)
    · exact ⨁ i : {i // e i = 0}, (Localization S) ⧸ (P i.1 ^ e i.1)
    · exact (LocalizedModule.quotientEquiv S _ _).symm.trans (LocalizedModule.ofId _ _)
  obtain ⟨f, hf⟩ : ∃ f : M →ₗ[A] N, Function.Bijective (LocalizedModule.map S f) := by
    obtain ⟨f, s, hfs⟩ := LocalizedModule.exists_linearMap_of_finite S M N hMN.some.toLinearMap
    refine ⟨f, ?_⟩
    rw [hfs]
    apply (hMN.some.toLinearMap.toBijective).scale
    rw [Submonoid.mem_iInf] at s
    intro i hi; exact IsLocalization.to_id_injective S (Localization S) (by simpa using (s i hi))
  exact ⟨ι', inferInstance, p', hp', (fun i => e i.1), (fun i => i.2), f, (LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f).mpr hf⟩
