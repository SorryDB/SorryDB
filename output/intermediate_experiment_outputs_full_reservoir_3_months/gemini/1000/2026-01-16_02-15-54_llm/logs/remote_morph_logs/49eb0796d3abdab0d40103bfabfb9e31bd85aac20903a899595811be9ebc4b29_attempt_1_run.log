/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let s := Module.support A M ∩ {p | p.asIdeal.primeHeight = 1}
  have hf : s.Finite := hMT.finite_primeHeight_one_support
  rcases s.eq_empty_or_nonempty with h | h
  · exact ⟨ULift PEmpty, inferInstance, fun i ↦ i.down.elim, fun i ↦ i.down.elim, fun i ↦ i.down.elim, fun i ↦ i.down.elim,
      ⟨0, by simpa [isPseudoIsomorphism_iff, s, h, Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton] using hMT, infer_instance⟩⟩
  let S := ⨅ p ∈ s, p.asIdeal.primeCompl
  letI : IsDomain (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (fun _ h ↦ h.2) h hf).1
  letI : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (fun _ h ↦ h.2) h hf).2
  have hMS : Module.IsTorsion (Localization S) (LocalizedModule S M) := by
    rintro ⟨m, x⟩; obtain ⟨a, ha, hm⟩ := hMT m; use algebraMap A (Localization S) a
    exact ⟨mem_nonZeroDivisors_iff_ne_zero.2 fun h0 ↦ (Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes minimalPrimes.bot_mem (Set.disjoint_right.1 ha)) (by rwa [Ideal.mem_comap, Ideal.mem_bot]), by simp [hm]⟩
  obtain ⟨ι, _, q, hq, e, he, ⟨equiv⟩⟩ := Module.Finite.exists_equiv_directSum_normalized_power (Localization S) (LocalizedModule S M) hMS
  let p i : PrimeSpectrum A := ⟨(Ideal.span {q i}).comap (algebraMap A (Localization S)), Ideal.IsPrime.comap _⟩
  let N := (i : ι) → A ⧸ (p i).asIdeal ^ e i
  have hps (i : ι) : p i ∈ s := ⟨Module.support_subset_of_localization S M (by
    rw [Module.mem_support_iff_of_finite, ← LocalizedModule.subsingleton_iff]; exact Ideal.span_ne_bot.1 (hq i).ne_zero), by
    rw [← Ideal.primeHeight_localization S (p i).1 (Ideal.comap_localization_is_localization S (p i).1)]; exact (hq i).isPrime.primeHeight_of_isPrincipalIdealRing (by simp [(hq i).ne_zero])⟩
  have h_iso : LocalizedModule S M ≃ₗ[Localization S] LocalizedModule S N :=
    equiv.trans (DirectSum.linearEquivFunOnFintype _ _ _).symm |>.trans (LocalizedModule.pi S _).symm |>.trans (LinearEquiv.piCongrLeft _ _ fun i ↦ (LocalizedModule.quotient S _ _).symm.trans (IsLocalization.algEquiv S _ _).toLinearEquiv)
  obtain ⟨f, x, hf_eq⟩ := LocalizedModule.exists_linearMap S h_iso.toLinearMap
  refine ⟨ULift.{u} ι, inferInstance, fun i ↦ p i.down, fun i ↦ (hps i.down).2, fun i ↦ e i.down, fun i ↦ he i.down, f, ?_⟩
  rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT ?_]
  · rw [hf_eq]; exact (h_iso.toLinearMap.isUnit_smul x).bijective
  · refine Module.isTorsion_pi fun i ↦ ?_
    obtain ⟨m, hm⟩ := Module.mem_support_iff_of_finite.1 (hps i).1; obtain ⟨a, ha, ham⟩ := hMT m
    exact ⟨a ^ e i, ha.pow _, by simp [Ideal.Quotient.mk_eq_zero.2 (Ideal.pow_mem_pow ((p i).isPrime.mem_annihilator ham) _)]⟩

