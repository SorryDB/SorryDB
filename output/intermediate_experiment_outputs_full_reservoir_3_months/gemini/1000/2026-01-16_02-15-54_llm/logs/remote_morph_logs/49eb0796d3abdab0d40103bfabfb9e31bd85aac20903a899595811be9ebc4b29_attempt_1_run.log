-- #check Module.equiv_directSum_of_isTorsion

/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}
  have hσ : σ.Finite := hMT.finite_primeHeight_one_support
  rcases σ.eq_empty_or_nonempty with h | h
  · use PEmpty, inferInstance, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim
    have : Module.IsPseudoNull A M := by
      rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
      intro p hp; rcases hp.eq_or_lt with h1 | h0
      · simpa [σ, h1, Module.mem_support_iff_of_finite] using (h.subst (Set.not_mem_empty p))
      · rw [ENat.lt_one_iff_eq_zero, Ideal.primeHeight_eq_zero_iff] at h0
        rw [LocalizedModule.subsingleton_iff]; intro m; obtain ⟨s, hs⟩ := hMT m; use s.1
        exact ⟨Set.disjoint_right.1 (Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes h0) s.2, hs⟩
    exact this.isPseudoIsomorphic_zero.trans (Module.PseudoIsomorphic.pi_empty _).symm
  · set S := ⨅ p ∈ σ, p.1.primeCompl
    haveI := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (fun p h => h.1) h hσ).1
    haveI := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (fun p h => h.1) h hσ).2
    obtain ⟨ι, _, q, hq, hq', e, he, ⟨g⟩⟩ := Module.IsTorsion.equiv_pi_p_pow (Localization S) (LocalizedModule S M) (LocalizedModule.isTorsion S M hMT)
    let p i : PrimeSpectrum A := ⟨Ideal.comap (algebraMap A (Localization S)) (q i), hq i⟩
    use ι, inferInstance, p
    have hp : ∀ i, (p i).1.primeHeight = 1 := fun i ↦ by
      rw [← Ideal.primeHeight_localization S (p i).1, IsLocalization.map_comap S (Localization S) (q i)]
      exact (Ideal.primeHeight_eq_one_iff_is_maximal_of_isPrincipalIdealRing (hq' i)).2 (Ideal.IsPrime.isMaximal (hq i) (hq' i))
    refine ⟨hp, e, he, ?_⟩
    let N := (i : ι) → A ⧸ (p i).1 ^ e i
    have hNT : Module.IsTorsion A N := by
      intro f; refine fun i ↦ ?_; obtain ⟨s, hs⟩ := Ideal.exists_not_mem_zeroDivisors_of_primeHeight_one (hp i)
      use s ^ (e i), Submonoid.pow_mem nonZeroDivisors s hs (e i), by simp [← Submodule.Quotient.mk_smul, Ideal.pow_le_pow_right (he i) (le_refl _)]
    obtain ⟨f, s, hf⟩ := Module.Finite.exists_linearMap_localizedModule_eq' S M N (g.trans (LocalizedModule.pi S _).symm).toLinearMap
    use f; rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT, hf]
    exact (LinearEquiv.bijective _).comp_left_smul (IsLocalization.map_units (Localization S) s)
