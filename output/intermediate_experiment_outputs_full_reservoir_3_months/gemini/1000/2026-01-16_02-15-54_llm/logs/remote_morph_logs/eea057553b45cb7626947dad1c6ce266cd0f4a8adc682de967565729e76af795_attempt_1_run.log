    --Linearly combine S81, S82, S85:
    calc
      𝐃(ℰ n (ρ⊗^S[n])‖σ'' ρ ε m σ n) / (n : ENNReal) ≤
        ENNReal.ofReal (((ℰ n (ρ⊗^S[n])).M.inner (((R1 ρ ε).toReal + ε2) • (E1 ε2 n)))
