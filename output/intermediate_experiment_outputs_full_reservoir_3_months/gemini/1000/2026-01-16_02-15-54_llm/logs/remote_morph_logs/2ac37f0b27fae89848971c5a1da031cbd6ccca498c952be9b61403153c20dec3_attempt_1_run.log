    refine h_q_le.trans (lt_of_lt_of_le ?_ (Nat.div_le_self P.n P.L)).le
    have : (m / p : ℝ) < Real.sqrt P.n := by rw [Real.lt_sqrt (cast_nonneg _)]; apply cast_lt.mpr (div_lt_of_lt_mul (by rwa [mul_comm])); exact (mem_Ico.1 hm).2
    have : Real.sqrt P.n < P.n / P.L := by rw [Real.lt_div_iff (by exact_mod_cast P.hL_pos), ← Real.sqrt_mul_self (by exact_mod_cast Nat.zero_le P.n), Real.sqrt_lt_sqrt_iff (by positivity)]; exact_mod_cast P.hL
