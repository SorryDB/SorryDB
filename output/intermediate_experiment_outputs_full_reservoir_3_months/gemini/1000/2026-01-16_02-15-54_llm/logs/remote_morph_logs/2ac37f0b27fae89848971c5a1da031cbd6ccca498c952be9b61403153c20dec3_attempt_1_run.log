@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases h : p.Prime
  · rw [Factorization.balance, factorial_factorization_eq_div h hp']
    have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * ((Finset.Ico (P.n - P.n / P.M) P.n).filter (p ∣ ·)).card := by
      simp only [Factorization.sum, Params.initial, Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate, smul_eq_mul]
      congr 1; rw [Multiset.filter_congr, Multiset.filter_map, Multiset.sum_eq_card_filter]; · simp
      intro m hm; have hm' := Finset.mem_Ico.mp (Multiset.mem_Ico.mp hm)
      by_cases hp_dvd : p ∣ m
      · have h_sm : m ∈ (P.n / P.L).smoothNumbers := by
          rw [mem_smoothNumbers_iff (by have := hm'.1; omega)]
          intro q q_pr q_dv; by_cases hq : q = p; · rwa [hq]
          · have : q < p := by
              have : (q : ℝ) * p ≤ m := by exact_mod_cast Nat.le_of_dvd (by have := hm'.1; omega) (Nat.mul_dvd_of_prime_of_prime h q_pr hp_dvd q_dv hq)
              nlinarith [hp']
            exact this.le.trans hp
        have h_v : m.factorization p = 1 := by
          rw [hp_dvd.factorization_prime h, h.factorization_exponent_pos_iff, show m / p < p by nlinarith [hp', (show (m : ℝ) < P.n from by exact_mod_cast hm'.2)]]
          · exact pos_of_ne_zero (by omega)
          · rfl
        simp [hp_dvd, h_sm, h_v]
      · simp [hp_dvd, factorization_eq_zero_of_not_dvd hp_dvd]
    rw [h_sum]; have h_card : ((Finset.Ico (P.n - P.n / P.M) P.n).filter (p ∣ ·)).card ≥ P.n / P.M / p := by
      let A := P.n - P.n / P.M; let B := P.n
      have hlen : B - A = P.n / P.M := Nat.sub_sub_self (div_le_self _ _)
      have : (Finset.filter (p ∣ ·) (Finset.Ico A B)).card ≥ (B - A) / p := by
        rw [Finset.card_filter, Nat.card_Ico_filter_dvd_ge B A h.pos]
      rwa [hlen] at this
    have := count_bound_aux P.n P.M p h.pos; omega
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ h]
```
