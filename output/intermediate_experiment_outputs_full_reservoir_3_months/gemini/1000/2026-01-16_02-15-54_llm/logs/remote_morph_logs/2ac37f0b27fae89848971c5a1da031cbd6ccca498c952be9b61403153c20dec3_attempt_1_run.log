@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hprime : p.Prime
  · have h_fac : (P.n.factorial.factorization p : ℤ) = P.n / p := by rw [factorial_factorization_eq_div hprime hp']
    have h_smooth : ∀ m ∈ Ico (P.n - P.n / P.M) P.n, p ∣ m → m ∈ (P.n / P.L).smoothNumbers := by
      intro m hm hpdiv; rw [mem_smoothNumbers]; constructor
      · exact (pos_of_gt (Nat.sub_pos_of_lt (Ico_lt_Ico.mp hm).2)).ne'
      · intro q hq hqdiv; by_cases hqp : q = p
        · subst hqp; exact hp
        · have hq_le : q ≤ m / p := Nat.le_of_dvd (Nat.div_pos (Nat.le_trans (by linarith [hprime.pos]) hpdiv) hprime.pos) (hq.dvd_of_dvd_mul (by rwa [Nat.mul_div_cancel' hpdiv]) (hprime.coprime_iff_not_dvd.2 hqp))
          have : (m : ℝ) / p < √↑P.n := (div_lt_iff₀ (by positivity)).2 (by nlinarith [sqrt_nonneg P.n, mul_self_sqrt (cast_nonneg P.n)])
          have : √↑P.n < ↑(P.n / P.L) := (sqrt_lt (cast_nonneg _) (cast_nonneg _)).2 (by exact_mod_cast by nlinarith [P.hL])
          exact_mod_cast hq_le.trans_lt (by exact_mod_cast this.trans' ‹(m:ℝ)/p < √↑P.n›)
    have h_sum : ((P.initial.a).map (·.factorization p)).sum = (P.M : ℤ) * ((Ico (P.n - P.n / P.M) P.n).filter (p ∣ ·)).card := by
      simp only [initial, Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate, smul_eq_mul, ← cast_mul]
      congr 1; rw [Multiset.filter_map, Multiset.sum_replicate, smul_eq_mul]; congr 1
      rw [Multiset.map_congr rfl]; intro m hm; by_cases hpdiv : p ∣ m
      · rw [if_pos (h_smooth m hm hpdiv), factorization_eq_one_iff]; exact ⟨hprime, hpdiv, by nlinarith [hp']⟩
      · rw [factorization_eq_zero_iff]; exact Or.inr (Or.inl hpdiv)
    rw [Factorization.balance, Factorization.sum, h_sum, h_fac]
    let c := ((Ico (P.n - P.n / P.M) P.n).filter (p ∣ ·)).card
    by_cases hq : (P.n / p : ℤ) ≤ P.M
    · linarith [Nat.cast_nonneg c, Nat.cast_nonneg P.M]
    · have hM : P.M > 0 := by linarith [Nat.cast_nonneg (P.n / p)]
      have hc : c + 1 ≥ P.n / P.M / p + 1 := by
        rw [card_filter, ← Multiset.sum_eq_multiset_sum, Multiset.Ico]
        have := Nat.div_add_mod (P.n - 1) p; have := Nat.div_add_mod (P.n - P.n / P.M - 1) p; omega
      have : (P.M : ℤ) * (c + 1) ≥ P.n / p := by
        have := Nat.div_mul_le_self (P.n / p) P.M; have := Nat.div_div_eq_div_mul P.n P.M p; omega
      linarith
  · simp [Factorization.balance, Factorization.sum, hprime, Nat.factorization_eq_zero_of_not_prime]
