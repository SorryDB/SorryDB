@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hprime : p.Prime
  · have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card := by
      simp only [Params.initial, Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate, smul_eq_mul]
      have h_smooth : ∀ m ∈ .Ico (P.n - P.n / P.M) P.n, p ∣ m → m ∈ (P.n / P.L).smoothNumbers := fun m hm hpm ↦ by
        rw [mem_smoothNumbers']; refine ⟨by linarith [P.hpos m (Params.initial.ha P m (by aesop))], fun q hq hqm ↦ ?_⟩
        by_cases hqp : q = p; · exact hqp ▸ hp
        have : q < Real.sqrt P.n := by
          by_contra! hq_ge; have : (P.n : ℝ) ≤ q * p := by nlinarith [hq_ge, hp']
          have : q * p ≤ m := Nat.mul_le_of_dvd_of_dvd hprime.pos hq.pos hpm hqm hqp
          nlinarith [show (m : ℝ) < P.n from cast_lt.mpr (Multiset.mem_Ico.mp hm).2]
        exact this.le.trans (by rw [Real.le_sqrt (cast_nonneg _) (cast_nonneg _)] at hp'; nlinarith [P.hL])
      have h_val : ∀ m ∈ .Ico (P.n - P.n / P.M) P.n, m.factorization p = if p ∣ m then 1 else 0 := fun m hm ↦ by
        by_cases hpm : p ∣ m
        · rw [if_pos hpm]; have hm_pos : m ≠ 0 := (P.hpos m (Params.initial.ha P m (by aesop))).ne'
          have : p^1 ∣ m := hpm; have : ¬ p^2 ∣ m := fun h ↦ by
            have : (P.n : ℝ) ≤ m := by have : p^2 ≤ m := Nat.le_of_dvd (Nat.pos_of_ne_zero hm_pos) h; nlinarith [hp', (show (m:ℝ) < P.n from cast_lt.mpr (Multiset.mem_Ico.mp hm).2)]
            linarith
          rw [← Nat.factorization_def hm_pos hprime, padicValNat_def hprime (Nat.pos_of_ne_zero hm_pos)]; simp_all
        · rw [if_neg hpm, factorization_eq_zero_iff]; exact .inr (.inl hpm)
      rw [Multiset.filter_congr fun m hm ↦ (h_smooth m (Multiset.mem_Ico.mp hm) (by aesop)), Multiset.filter_true,
        Multiset.map_congr rfl fun m hm ↦ h_val m (Multiset.mem_Ico.mp hm), Multiset.sum_filter, Multiset.sum_ite, Multiset.sum_const, nsmul_eq_mul]
      simp
    simp only [Factorization.balance, Factorization.sum, factorial_factorization_eq_div hprime hp', h_sum]
    have h_card : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≥ P.n / P.M / p := by
      rw [Nat.sub_sub_self (div_le_self P.n P.M)]; set a := P.n - P.n / P.M; set b := P.n
      have : (b - a) / p ≤ (Finset.filter (p ∣ ·) (Finset.Ico a b)).card := by
        rw [Finset.card_filter, ← Finset.sum_ite, Finset.sum_Ico_eq_sum_range]; set n' := b - a
        have : ∀ i, (if p ∣ a + i then 1 else 0) ≥ (if p ∣ i then 1 else 0) - (if p ∣ a then 1 else 0) := by intro; split_ifs <;> omega
        calc ∑ i in Finset.range n', (if p ∣ a + i then 1 else 0 : ℕ)
          _ ≥ (n' / p) := by
            have : (Finset.range n').filter (p ∣ ·) |>.card = n' / p := Finset.card_range_filter_dvd n' hprime.pos
            have h_per : ∀ i, (if p ∣ a + i then 1 else 0) = (if p ∣ a + (i % p) then 1 else 0) := by intro; congr 1; apply Nat.dvd_periodic.periodic
            have h_sum_p : ∑ i in Finset.range p, (if p ∣ a + i then 1 else 0) = 1 := by
              have : ∃! i ∈ Finset.range p, p ∣ a + i := Nat.exists_unique_dvd_add_range a hprime.pos; rcases this with ⟨i, hi, h_unig⟩; rw [Finset.sum_eq_single i] <;> simp_all
            calc ∑ i in Finset.range n', (if p ∣ a + i then 1 else 0)
              _ = (n' / p) * 1 + ∑ i in Finset.range (n' % p), (if p ∣ a + i then 1 else 0) := by rw [Finset.sum_range_mul_add n' p, h_sum_p]; simp
              _ ≥ n' / p := by omega
      rwa [Nat.sub_sub_self (div_le_self P.n P.M)] at this
    have : (P.M : ℤ) * (P.n / P.M / p) ≥ (P.n / p : ℤ) - P.M := by
      rw [Nat.div_div_eq_div_mul]; nlinarith [Nat.mul_div_le P.n (P.M * p), Nat.div_mul_le_self P.n p]
    omega
  · simp_all [Factorization.balance, Factorization.sum, factorization_eq_zero_of_not_prime]
