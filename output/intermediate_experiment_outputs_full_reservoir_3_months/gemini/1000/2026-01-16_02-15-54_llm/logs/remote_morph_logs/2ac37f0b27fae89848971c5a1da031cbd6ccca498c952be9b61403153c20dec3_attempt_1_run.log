      have := Multiset.mem_Ico.mp hm; have hL : (P.L : ℝ) < Real.sqrt P.n := (Real.lt_sqrt (by positivity)).mpr (by exact_mod_cast (by nlinarith [P.hL]))
      have : (p : ℝ) > P.L := hp'.trans_at_left hL.le; nlinarith [P.hL, P.hL_pos, this]
    have h_val : ∀ m ∈ I, m.factorization p = if p ∣ m then 1 else 0 := fun m hm ↦ by
      split_ifs with hpm; · exact hp_prime.factorization_eq_one_iff.mpr ⟨hpm, fun hnot ↦ by
        have := (Multiset.mem_Ico.mp hm).2; have : (m : ℝ) < P.n := by exact_mod_cast this
        have : (m : ℝ) ≥ (p : ℝ) ^ 2 := by exact_mod_cast Nat.le_of_dvd (Nat.pos_of_ne_zero (hm_pos m hm)) hnot
        nlinarith [Real.mul_self_sqrt (cast_nonneg P.n), hp']⟩
      exact Nat.factorization_eq_zero_of_not_dvd hpm
    have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * ((Finset.Ico (P.n - P.n / P.M) P.n).filter (p ∣ ·)).card := by
      simp only [Params.initial, h_val, Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate, smul_eq_mul, Multiset.filter_congr]
      congr 1; intro m hm; split_ifs with hpm; · simp [mem_smoothNumbers, hm_pos m hm]; intro q hq hqm; by_cases hqp : q = p; · rwa [hqp]
      have : q < p := by
        have : q ∣ m / p := (hp_prime.dvd_mul_iff.mp (by rwa [Nat.mul_div_cancel' hpm])).resolve_left hqp
        exact (Nat.le_of_dvd (Nat.pos_of_dvd_of_pos (Nat.div_dvd_of_dvd hpm) (Nat.pos_of_ne_zero (hm_pos m hm))) this).trans_lt (by rwa [Nat.div_lt_iff_lt_mul hp_prime.pos])
      exact this.le.trans hp
      · simp
    have : (P.n / p : ℤ) ≤ P.M * ((Finset.Ico (P.n - P.n / P.M) P.n).filter (p ∣ ·)).card + P.M := by
      rw [Finset.Ico_filter_dvd_card _ _ hp_prime.pos]; omega
    linarith
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hp_prime]
