@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hprime : p.Prime
  · have h_fac : (P.n.factorial.factorization p : ℤ) = P.n / p := factorial_factorization_eq_div hprime hp'
    have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card := by
      unfold Factorization.sum Params.initial; simp only [Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate, nsmul_eq_mul]
      congr 1; rw [Multiset.Ico, ← Finset.sum_eq_multiset_sum]; simp only [filter_filter]
      refine Finset.sum_congr (Finset.ext fun m ↦ by
        simp only [mem_filter, mem_Ico]; constructor; · intro h; exact ⟨h.1.1, h.2⟩;
        · intro h; refine ⟨⟨h.1, ?_⟩, h.2⟩
          rw [mem_smoothNumbers]; refine ⟨(hprime.pos.trans_le (le_of_dvd (by omega) h.2)), fun q hq hqm ↦ ?_⟩
          if hqp : q = p then rwa [hqp] else
          have : (q : ℝ) < Real.sqrt P.n := by
            have : (m / p : ℝ) < Real.sqrt P.n := by rw [Real.lt_sqrt (cast_nonneg _)]; nlinarith [hp', cast_le.mpr h.1.2]
            exact (cast_le.mpr (Nat.le_of_dvd (by omega) (hprime.dvd_of_dvd_mul_left_of_no_common_factor (by grind) hqm))).trans_lt this
          exact this.le.trans (by rw [Real.le_sqrt (cast_nonneg _) (cast_nonneg _)] at *; nlinarith [P.hL])) (fun m h ↦ by
        simp only [mem_filter, mem_Ico] at h; rw [hprime.factorization_def, padicValNat_def hprime (by omega)]
        have : p^2 > m := by nlinarith [hp', Real.mul_self_sqrt (cast_nonneg P.n)]
        rw [hprime.padicValNat_self_index 1]; · simp only [pow_one, h.2, h.1.1, ↓reduceIte, Nat.cast_one]; exact ⟨h.2, by rwa [pow_two]⟩)
    rw [Factorization.balance, h_sum, h_fac]; norm_cast
    have h_card : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card + 1 ≥ (P.n / P.M + p - 1) / p := by
      rw [Finset.card_filter, card_Ico, Nat.sub_sub_self (div_le_self _ _)]
      cases P.M with | zero => simp | succ M => rw [Nat.div_le_div_right]; omega
    linarith [count_bound_aux P.n P.M p hprime.pos]
  · simp_all [Factorization.balance, Factorization.sum]
