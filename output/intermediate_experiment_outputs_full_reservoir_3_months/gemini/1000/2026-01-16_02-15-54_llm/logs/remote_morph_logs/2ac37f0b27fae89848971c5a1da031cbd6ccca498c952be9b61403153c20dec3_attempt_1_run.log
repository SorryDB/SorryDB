@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hprime : p.Prime
  · have h_val_n! : (P.n.factorial.factorization p : ℤ) = P.n / p := factorial_factorization_eq_div hprime hp'
    have h_smooth : ∀ m ∈ (P.n - P.n / P.M).Ico P.n, p ∣ m → m ∈ (P.n / P.L).smoothNumbers := by
      intro m hm hpm; rw [mem_smoothNumbers]
      refine ⟨(pos_of_gt (Nat.lt_of_le_of_lt (Nat.sub_le P.n (P.n / P.M)) (Finset.mem_Ico.1 hm).1)).ne', fun q q_prime hqm ↦ ?_⟩
      by_cases hqp : q = p
      · rw [hqp]; exact hp
      · have : q * p ≤ m := Nat.mul_dvd_le (pos_of_gt (Nat.lt_of_le_of_lt (Nat.sub_le P.n (P.n / P.M)) (Finset.mem_Ico.1 hm).1)) hpm hqm hqp
        have h_m_lt : (m : ℝ) < P.n := by exact_mod_cast (Finset.mem_Ico.1 hm).2
        have h_q_lt : (q : ℝ) < Real.sqrt P.n := by
          have : (p : ℝ) > Real.sqrt P.n := hp'
          nlinarith [Real.mul_self_sqrt (Nat.cast_nonneg P.n)]
        calc (q : ℝ) < Real.sqrt P.n := h_q_lt
             _ < P.n / P.L := by
               rw [Real.lt_div_iff₀ (by exact_mod_cast P.hL_pos), ← Real.sqrt_mul (Nat.cast_nonneg P.n), Real.sqrt_lt (by positivity) (by positivity)]
               exact_mod_cast P.hL
    have h_val_m : ∀ m ∈ (P.n - P.n / P.M).Ico P.n, p ∣ m → m.factorization p = 1 := fun m hm hpm ↦ by
      have : m < p * p := by
        have : (m : ℝ) < P.n := by exact_mod_cast (Finset.mem_Ico.1 hm).2
        nlinarith [Real.mul_self_sqrt (Nat.cast_nonneg P.n)]
      exact Nat.Prime.factorization_eq_one_of_dvd_of_lt hprime hpm (pos_of_gt (Nat.lt_of_le_of_lt (Nat.sub_le P.n (P.n / P.M)) (Finset.mem_Ico.1 hm).1)) this
    set c := (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card
    have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * c := by
      simp only [Factorization.sum, Params.initial, Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join, Multiset.sum_replicate, smul_eq_mul]
      congr 1; rw [Multiset.Ico, ← Finset.sum_eq_multiset_sum, Finset.sum_filter]
      apply Finset.sum_congr rfl; intro m hm
      by_cases hpm : p ∣ m
      · simp [h_smooth m hm hpm, h_val_m m hm hpm]
      · simp [Nat.factorization_eq_zero_iff, hprime, hpm]
    have h_c_lb : (c : ℤ) ≥ (P.n / p : ℤ) - (P.n - P.n / P.M) / p - 1 := by
      rw [Finset.card_filter_dvd_Ico]; omega
    simp [Factorization.balance, h_sum, h_val_n!]
    have h_m_div : (P.n : ℤ) / P.M / p ≥ (P.n / p : ℤ) / P.M - 1 := by
      have hM : (P.M : ℤ) ≥ 0 := by exact_mod_cast Nat.zero_le P.M
      have hpz : (p : ℤ) > 0 := by exact_mod_cast hprime.pos
      rw [Int.ediv_ediv]; exact Int.ediv_le_ediv_le (by omega) (by omega)
    omega
  · simp [Factorization.balance, Factorization.sum, Params.initial, factorization_eq_zero_of_not_prime _ hprime]
