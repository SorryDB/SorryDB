  have h_fac : (P.n.factorial.factorization p : ℤ) = P.n / p := factorial_factorization_eq_div hprime h_sqrt
  rw [Factorization.balance, h_fac]
  have h_m : ∀ m ∈ .Ico (P.n - P.n / P.M) P.n, p ∣ m → m.factorization p = 1 ∧ m ∈ (P.n / P.L).smoothNumbers := fun m hm hpm ↦ by
    have hpm' : p ≤ m := Nat.le_of_dvd (by linarith [hm.1]) hpm
    have hpk : m / p < p := by
      have : (m : ℝ) < p^2 := by rw [Real.lt_sqrt (by positivity)] at h_sqrt; linarith
      rw [Nat.div_lt_iff_lt_mul hprime.pos]; exact_mod_cast this
    refine ⟨by rw [Nat.Prime.factorization_conf hprime hpm (by linarith), Nat.div_self hprime.pos, Nat.Prime.factorization_one hprime], ?_⟩
    rw [mem_smoothNumbers]; refine ⟨(by linarith), fun q qp qm ↦ ?_⟩
    by_cases hqp : q = p; · linarith
    have : q ∣ m / p := Nat.dvd_of_mem_factorization (by
      rw [Nat.factorization_div hpm, Finsupp.coe_tsub, Pi.sub_apply, Nat.Prime.factorization_self hprime] at qm
      simpa [hqp] using qm)
    exact (Nat.le_of_dvd (Nat.div_pos hpm' hprime.pos) this).trans (hpk.le.trans hp)
  have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card := by
    simp [Params.initial, Factorization.sum, h_m, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, nsmul_eq_mul]
    congr; rw [Multiset.map_filter, Finset.filter_val, Multiset.filter_congr (fun x hx ↦ by simp [h_m x (by simpa using hx)])]
    simp [h_m, (· ∣ ·)]
  rw [h_sum, Finset.card_filter_dvd_Ico]
  rcases eq_or_ne P.M 0 with rfl | hM; · simp at P.hL_pos
  have : (P.n / p : ℤ) ≤ (P.M : ℤ) * (P.n / p - (P.n - P.n / P.M) / p) + P.M := by
    have h1 : (P.n / p : ℤ) - ((P.n - P.n / P.M) / p : ℤ) ≥ (P.n / P.M) / p := by
      rw [ge_iff_le, ← Int.cast_id (n := _ / p - _ / p), ← Nat.cast_sub (Nat.div_le_div_right (Nat.sub_le _ _) (by omega))]
      exact_mod_cast Nat.le_sub_of_add_le (Nat.div_le_div_right (Nat.div_add_mod P.n P.M ▸ (Nat.le_add_right _ _)) (by omega))
    calc (P.n / p : ℤ) = (P.M * (P.n / P.M) + P.n % P.M) / p := by rw [Nat.div_add_mod]
      _ ≤ (P.M * (P.n / P.M)) / p + (P.n % P.M) / p + 1 := by exact_mod_cast Nat.div_add_div_le_div_add_one _ _ _
      _ ≤ P.M * ((P.n / P.M) / p) + P.M := by
        have : (P.n % P.M) / p < P.M := by
          have : (P.n % P.M) / p ≤ P.n % P.M := Nat.div_le_self _ _; exact this.trans_lt (Nat.mod_lt _ (Nat.pos_of_ne_zero hM))
        nlinarith [Nat.div_mul_le_div_mul_right (P.n / P.M) P.M p]
      _ ≤ P.M * (P.n / p - (P.n - P.n / P.M) / p) + P.M := by nlinarith
  exact_mod_cast by linarith
