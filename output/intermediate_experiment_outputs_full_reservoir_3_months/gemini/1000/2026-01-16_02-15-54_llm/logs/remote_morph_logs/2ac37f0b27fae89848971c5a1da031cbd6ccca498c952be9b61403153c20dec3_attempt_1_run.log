    rw [mem_smoothNumbers']; refine ⟨by linarith [P.hpos m (by aesop)], fun q q_prime q_dvd ↦ ?_⟩
    by_cases hqp : q = p; · exact hqp ▸ hp
    have : q * p ≤ m := Nat.mul_le_of_dvd_of_dvd q_prime.pos h_prime.pos q_dvd hpm hqp
