    exact (le_of_lt (this.trans_lt (by rw [div_lt_iff₀ (by exact_mod_cast h_prime.pos)]; exact_mod_cast (Real.sqrt_lt (Nat.cast_nonneg P.n) (Nat.cast_nonneg p)).mp hp'))).trans hp
  have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card := by
