import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let f (i : Fin (4 * n)) : Fin (4 * n) := ⟨4 * n - 1 - i.1, by omega⟩
  obtain ⟨g, hg, hgi, hgc⟩ : ∃ g : Fin (4 * n) → Fin (4 * n), (∀ i, g (g i) = i) ∧ (∀ i, g i ≠ i) ∧ (∀ i, c (g i) = c i) := by
    have : ∀ i, ∃ g : {j | c j = i} → {j | c j = i}, (∀ j, g (g j) = j) ∧ (∀ j, g j ≠ j) := by
      intro i
      obtain ⟨a, b, d, e, -, -, -, -, -, -, h4⟩ := card_eq_four.1 (h i)
      refine ⟨λ x => if x = a then b else if x = b then a else if x = d then e else d, ?_, ?_⟩
      · intro x; repeat (split_ifs with hx <;> try subst hx) <;> simp_all
      · intro x; repeat (split_ifs with hx <;> try subst hx) <;> simp_all
    choose g hg1 hg2 using this
