import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let p (i : Fin (4 * n)) : Fin (4 * n) := ⟨4 * n - 1 - i.1, by omega⟩
  have hp : Involution p := ⟨fun i ↦ by simp [p], fun i ↦ by simp [p]⟩
  have : ∃ S : Finset (Fin (4 * n)), (∀ i, (S.filter (fun j ↦ c j = i)).card = 2) ∧ ∀ i, i ∈ S ↔ p i ∈ S := by
    set pairs : Finset (Fin (2 * n)) := Finset.univ
    let edges : Multiset (Sym2 (Fin n)) := (pairs.val.map fun i ↦ ⟦(c ⟨i, by omega⟩, c (p ⟨i, by omega⟩))⟧)
    have hdeg : ∀ i : Fin n, (edges.filter (i ∈ ·)).card = 2 := by
      intro i
      let s := (Finset.univ : Finset (Fin (4 * n))).filter (fun j ↦ c j = i)
      have hs : s.card = 4 := h i
      sorry
    sorry
  obtain ⟨S, h1, h2⟩ := this
  refine ⟨S, ?_, h1⟩
  have hS : S.card = 2 * n := by
    rw [← Finset.sum_card_filter_eq_card, Finset.sum_congr (rfl : Finset.univ = Finset.univ) (fun i _ ↦ h1 i)]; simp
  have hsum : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by
    rw [← mul_left_inj' (show 2 ≠ 0 by norm_num), ← S.sum_bij (fun i _ ↦ p i) (fun i _ ↦ by simp [h2]) (by simp) (by intro a _; simp [hp.2]),
      ← S.sum_add_distrib, mul_assoc, ← S.card_univ, ← S.sum_const]
    apply Finset.sum_congr rfl; intro i _; simp [p]; omega
  rw [hsum, ← Finset.sum_range_id (4 * n + 1), Finset.range_eq_Ico, Finset.sum_Ico_id_add_1,
    Finset.sum_range_id, ← Fin.sum_univ_eq_sum_range, Finset.sum_compl, hsum]
  omega

