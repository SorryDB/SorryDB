import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let f (i : Fin n) := (Finset.univ.filter (λ j => c j = i)).sort (· ≤ ·)
  have hf (i : Fin n) : (f i).length = 4 := by
    simpa [f] using (Finset.card_filter Finset.univ (λ j => c j = i)).trans (h i)
  let M1 : Set (Sym2 (Fin (4 * n))) := Set.range (λ (i : Fin (2 * n)) => s(2 * i, 2 * i + 1))
  let M2 : Set (Sym2 (Fin (4 * n))) := Set.range (λ (i : Fin n) => s((f i).get ⟨0, hf i ▸ by decide⟩, (f i).get ⟨2, hf i ▸ by decide⟩)) ∪
                                        Set.range (λ (i : Fin n) => s((f i).get ⟨1, hf i ▸ by decide⟩, (f i).get ⟨3, hf i ▸ by decide⟩))
  let G : SimpleGraph (Fin (4 * n)) := SimpleGraph.fromRel (λ a b => s(a, b) ∈ M1 ∨ s(a, b) ∈ M2)
  have deg (v : Fin (4 * n)) : G.degree v = 2 := sorry
  let cycles := G.cycleFactors
  sorry
