/-
Copyright (c) 2025 Joseph Myers. All rights reserved.
Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let pairs (k : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨k, by omega⟩, ⟨4 * n - 1 - k, by omega⟩}
  let G : Polygraph (Fin n) := {
    Edge := Fin (2 * n)
    endpoints := fun k => {c ⟨k, by omega⟩, c ⟨4 * n - 1 - k, by omega⟩}
  }
  have h_deg (i : Fin n) : G.degree i = 4 := by
    simp only [Polygraph.degree, Multiset.card_eq_sum_count, G]
    have h_count (i : Fin n) : ∑ e, (G.endpoints e).count i = #{j | c j = i} := by
      rw [Finset.card_eq_sum_ones, ← Finset.sum_filter, ← Finset.sum_range (n := 2 * n)]
      simp [Finset.filter_or, Finset.filter_filter, G, pairs, Finset.card_union]
      let f (k : ℕ) : Fin (4 * n) := ⟨k, by omega⟩
      let g (k : ℕ) : Fin (4 * n) := ⟨4 * n - 1 - k, by omega⟩
      have h1 : Finset.range (2 * n) = (Finset.univ : Finset (Fin (2 * n))).map ⟨(↑), by simp⟩ := by simp
      rw [h1, Finset.sum_map]
      have h2 : (Finset.univ : Finset (Fin (4 * n))) = (Finset.univ : Finset (Fin (2 * n))).map ⟨f, by simp [f]⟩ ∪ (Finset.univ : Finset (Fin (2 * n))).map ⟨g, by simp [g]; omega⟩ := by
        ext x; simp [f, g]; omega
      rw [h2, Finset.sum_union (by simp [f, g, Finset.disjoint_left]; omega)]
      simp [f, g]
    rw [h_count, h]
  obtain ⟨K, hK⟩ := G.exists_even_degree_subgraph (fun _ => 2) (by intro i; rw [h_deg]; omega)
  let S : Finset (Fin (4 * n)) := Finset.univ.filter (fun j => (if j < 2 * n then j.val else 4 * n - 1 - j.val) ∈ K)
  use S
  constructor
  · have h_sum (A : Finset (Fin (4 * n))) : ∑ i ∈ A, ((i : ℕ) + 1) = (A.card : ℕ) * (4 * n + 1) / 2 ↔ ∑ i ∈ A, ((i : ℕ) + 1) = ∑ i ∈ Aᶜ, ((i : ℕ) + 1) := by
      have : ∑ i ∈ A, ((i : ℕ) + 1) + ∑ i ∈ Aᶜ, ((i : ℕ) + 1) = (2 * n) * (4 * n + 1) := by
        rw [← Finset.sum_union (Finset.disjoint_compl A), Finset.union_compl, Finset.sum_range_id (n := 4 * n)]
        omega
      omega
    apply (h_sum S).mp
    have h_pair (k : Fin (2 * n)) : ∑ i ∈ pairs k, ((i : ℕ) + 1) = 4 * n + 1 := by simp [pairs]; omega
    have h_S : S = K.biUnion pairs := by
      ext j; simp [S, pairs]; constructor
      · intro hj; split_ifs at hj with h1
        · use ⟨j, h1⟩; simp [hj]
        · use ⟨4 * n - 1 - j, by omega⟩; simp [hj]; omega
      · rintro ⟨k, hk, hj⟩; simp at hj; rcases hj with rfl | rfl <;> simp [hk] <;> omega
    rw [h_S, Finset.sum_biUnion (by simp [pairs, Finset.disjoint_left]; omega)]
    simp [h_pair, hK.1]
  · intro i
    have : {j ∈ S | c j = i} = K.biUnion (fun k => (pairs k).filter (fun j => c j = i)) := by
      ext j; simp [S, pairs]; split_ifs <;> (constructor <;> rintro ⟨k, hk, hj⟩ <;> use k <;> simp_all) <;> omega
    rw [this, Finset.card_biUnion (by simp [pairs, Finset.disjoint_left]; omega)]
    simp [pairs, G, hK.2 i]
