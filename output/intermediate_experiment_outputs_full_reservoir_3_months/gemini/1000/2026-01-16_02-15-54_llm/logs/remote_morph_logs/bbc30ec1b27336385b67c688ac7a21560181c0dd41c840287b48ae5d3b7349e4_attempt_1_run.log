import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  obtain ⟨G, hG⟩ : ∃ G : SimpleGraph (Fin n × Fin 4), G.IsRegularOf 1 ∧
      ∀ i k, (c (Classical.choose (show ∃ j, c j = i ∧ j ∉ (Finset.univ.filter (λ x => c x = i)).image (λ _ => 0) from sorry))) = i := sorry
  let pairs : Finset (Finset (Fin (4 * n))) := Finset.univ.filter (λ p => p.card = 2 ∧ ∃ j < 2 * n, p = {⟨j, by omega⟩, ⟨4 * n - 1 - j, by omega⟩})
  let edges : Finset (Fin n × Fin n) := sorry
  have : ∃ F : Finset (Finset (Fin (4 * n))), F ⊆ pairs ∧ F.card = n ∧ ∀ i, (F.filter (λ p => ∃ j ∈ p, c j = i)).card = 2 := sorry
  obtain ⟨F, hF1, hF2, hF3⟩ := this
  use F.biUnion id
  constructor
  · have hsum (p : Finset (Fin (4 * n))) (hp : p ∈ pairs) : ∑ j ∈ p, ((j : ℕ) + 1) = 4 * n + 1 := by
      obtain ⟨h2, j, hj, rfl⟩ := Finset.mem_filter.1 hp
      simp [hj] ; omega
    have hS : ∑ i ∈ F.biUnion id, ((i : ℕ) + 1) = n * (4 * n + 1) := by
      rw [Finset.sum_biUnion (by intro a ha b hb hne ; exact Finset.disjoint_left.2 (λ x hx hx' => hne (by
        obtain ⟨ha2, ja, hja, rfl⟩ := Finset.mem_filter.1 ha
        obtain ⟨hb2, jb, hjb, rfl⟩ := Finset.mem_filter.1 hb
        apply Finset.ext ; intro z
        simp at hx hx' ; obtain ⟨rfl | rfl⟩ := hx <;> obtain ⟨rfl | rfl⟩ := hx' <;> try omega
        all_goals exfalso ; apply hne ; apply Finset.ext ; intro w ; simp ; obtain ⟨rfl | rfl⟩ := hx <;> obtain ⟨rfl | rfl⟩ := hx' <;> omega)))]
      rw [Finset.sum_congr rfl (λ p hp => hsum p hp), Finset.sum_const, hF2, nsmul_eq_mul]
    have hTotal : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      simp_rw [← Finset.sum_range (4 * n), Fin.sum_univ_eq_sum_range]
      rw [Finset.sum_range_id_add_one, Nat.mul_comm] ; omega
    rw [hS, ← hTotal, Finset.sum_add_sum_compl] ; omega
  · intro i
    have : {j ∈ F.biUnion id | c j = i} = (F.filter (λ p => ∃ j ∈ p, c j = i)).biUnion (λ p => p.filter (λ j => c j = i)) := by
      ext j ; simp ; constructor <;> intro ⟨p, hp, hj, hc⟩ <;> use p, hp, hj, hc
    rw [this, Finset.card_biUnion]
    · rw [Finset.sum_congr rfl (λ p hp => (by
        obtain ⟨h2, k, hk, rfl⟩ := Finset.mem_filter.1 (hF1 (Finset.mem_filter.1 hp).1)
        simp at hp ; obtain ⟨j, (rfl | rfl), rfl⟩ := hp
        · have : ({⟨k, by omega⟩, ⟨4 * n - 1 - k, by omega⟩} : Finset (Fin (4 * n))).filter (λ x => c x = c ⟨k, by omega⟩) = {⟨k, by omega⟩, ⟨4 * n - 1 - k, by omega⟩}.filter (λ x => c x = i) := by rw [rfl]
          rw [← this] ; have h_card : ({⟨k, by omega⟩, ⟨4 * n - 1 - k, by omega⟩} : Finset (Fin (4 * n))).filter (λ x => c x = c ⟨k, by omega⟩).card = 1 ∨ 2 := sorry
          exact (show (Finset.filter (λ j => c j = i) p).card = 1 from sorry)
      ))]
      exact hF3 i
    · intro a ha b hb hne ; exact Finset.disjoint_left.2 (λ x hx hx' => hne (by
        obtain ⟨ha1, ha2⟩ := Finset.mem_filter.1 ha ; obtain ⟨hb1, hb2⟩ := Finset.mem_filter.1 hb
        obtain ⟨ca, ka, hka, rfl⟩ := Finset.mem_filter.1 (hF1 ha1)
        obtain ⟨cb, kb, hkb, rfl⟩ := Finset.mem_filter.1 (hF1 hb1)
        apply Finset.ext ; intro z ; simp at hx hx' ; obtain ⟨rfl | rfl⟩ := hx.1 <;> obtain ⟨rfl | rfl⟩ := hx'.1 <;> omega))
