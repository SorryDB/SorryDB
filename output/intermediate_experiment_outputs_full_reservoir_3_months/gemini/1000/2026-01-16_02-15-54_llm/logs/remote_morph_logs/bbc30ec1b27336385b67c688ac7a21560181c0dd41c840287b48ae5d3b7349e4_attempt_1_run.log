      a ≠ b ∧ d ≠ e ∧ a.val % 2 = b.val % 2 ∧ d.val % 2 = e.val % 2 := by
    let ci := {j | c j = i}; have hci : ci.card = 4 := h i
    let ci_even := ci.filter (λ j ↦ j.val % 2 = 0); let ci_odd := ci.filter (λ j ↦ j.val % 2 = 1)
