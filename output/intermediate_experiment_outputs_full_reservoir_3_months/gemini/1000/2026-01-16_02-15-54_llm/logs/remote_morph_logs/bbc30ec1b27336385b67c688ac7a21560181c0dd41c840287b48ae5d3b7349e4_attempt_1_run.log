import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let g1 (i : Fin (4 * n)) : Fin (4 * n) := ⟨4 * n - 1 - i.1, by omega⟩
  have h1 i : g1 (g1 i) = i := by ext; simp [g1]; omega
  have h1' i : g1 i ≠ i := by intro h; apply_fun (·.1) at h; simp [g1] at h; omega
  obtain ⟨g2, h2, h2', h2c⟩ : ∃ g : Fin (4 * n) → Fin (4 * n), (∀ i, g (g i) = i ∧ g i ≠ i) ∧ (∀ i, c (g i) = c i) := by
    have : ∀ i, ∃ g : {j | c j = i} → {j | c j = i}, (∀ x, g (g x) = x) ∧ (∀ x, g x ≠ x) := by
      intro i; have : Fintype.card {j | c j = i} = 4 := h i
      obtain ⟨a, b, c, d, h_distinct, h_mem⟩ := (Fintype.card_eq_four : Fintype.card {j | c j = i} = 4).1 this
      use λ x => if x = a then b else if x = b then a else if x = c then d else c
      repeat' constructor <;> (intro x; repeat' split_ifs <;> (simp [*] at *; try solve_by_elim))
    choose g hg1 hg2 using this
    refine ⟨λ i => (g (c i) ⟨i, by simp⟩).1, ?_, ?_, ?_⟩
    · intro i; simp; constructor; · exact Subtype.ext_iff.1 (hg1 _ _)
      · intro h; exact hg2 (c i) ⟨i, by simp⟩ (Subtype.ext h)
    · intro i; simp; exact (g (c i) ⟨i, by simp⟩).2
  let G : SimpleGraph (Fin (4 * n)) := SimpleGraph.fromRel (λ i j => j = g1 i ∨ j = g2 i)
  have : G.IsBipartite := by
    rw [SimpleGraph.isBipartite_iff_no_odd_cycle]
    intro ⟨l, hl⟩; apply even_iff_not_odd.1; rw [← Nat.mod_two_ne_zero, ← Nat.even_iff_not_odd]
    have h_alt k : l.get ⟨(k + 1) % l.length, by simp⟩ = g1 (l.get ⟨k % l.length, by simp⟩) ∨ l.get ⟨(k + 1) % l.length, by simp⟩ = g2 (l.get ⟨k % l.length, by simp⟩) := by
      have := hl.adj (k % l.length); simp [G] at this; exact this.2
    let f k := if l.get ⟨(k + 1) % l.length, by simp⟩ = g1 (l.get ⟨k % l.length, by simp⟩) then (1:ℕ) else 2
    have h_odd : l.length % 2 = 0 := by
      let l_pairs := (List.range l.length).map (λ k => (l.get ⟨k, by simp⟩, l.get ⟨(k + 1) % l.length, by simp⟩))
      -- Cycles in a union of two matchings must be even because they must alternate.
      sorry
    simp [h_odd]
  obtain ⟨S1, S2, hS_part, hS_adj⟩ := this.exists_bipartite_partition
  use S1.toFinset
  have hS1c : S1.toFinsetᶜ = S2.toFinset := by
    ext i; simp; constructor
    · intro h; have := hS_part.2 i; simp [h] at this; exact this
    · intro h; apply hS_part.1.disjoint; simp [h]
  constructor
