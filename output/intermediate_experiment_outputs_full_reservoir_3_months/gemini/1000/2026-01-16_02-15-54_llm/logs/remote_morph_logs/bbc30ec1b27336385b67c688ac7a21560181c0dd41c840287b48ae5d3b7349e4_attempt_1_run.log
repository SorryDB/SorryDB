import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let pairs (j : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨j, by omega⟩, ⟨4 * n - 1 - j, by omega⟩}
  let colors (j : Fin (2 * n)) : Fin n × Fin n := (c ⟨j, by omega⟩, c ⟨4 * n - 1 - j, by omega⟩)
  let G : Multigraph (Fin n) := Multigraph.ofEdgeList (List.map colors (List.finRange (2 * n)))
  have hreg : ∀ v : Fin n, G.degree v = 4 := by
    intro v
    simp [G, Multigraph.degree, Multigraph.ofEdgeList, colors, ← List.count_map, ← List.mem_iff_get]
    have h1 : (List.map colors (List.finRange (2 * n))).countP (λ e => e.1 = v) +
              (List.map colors (List.finRange (2 * n))).countP (λ e => e.2 = v) =
              (List.finRange (4 * n)).countP (λ j => c (⟨j, by omega⟩) = v) := by
      rw [← List.countP_append, List.countP_map, List.countP_map]
      convert List.countP_finRange (λ j => c j = v)
      simp only [List.finRange_append, List.map_id]
      exact h v
    convert h v
  obtain ⟨F, hF⟩ := Multigraph.exists_even_factor hreg 2 (by norm_num)
  let S_idx := {j : Fin (2 * n) | ⟨colors j, by simp⟩ ∈ F}
  let S : Finset (Fin (4 * n)) := S_idx.biUnion pairs
  use S
  constructor
  · have hS_sum : ∑ i ∈ S, ((i : ℕ) + 1) = n * (4 * n + 1) := by
      rw [biUnion_congr (r := (· = ·)) (λ _ _ => rfl)]
      · rw [sum_biUnion (by intro j1 hj1 j2 hj2 hne; simp [pairs, hne])]
        simp only [sum_insert, sum_singleton, mem_singleton]
        have : ∀ j : Fin (2 * n), (j : ℕ) + 1 + (4 * n - 1 - j + 1) = 4 * n + 1 := by intro j; omega
        rw [sum_congr rfl (λ j _ => this j), sum_const, card_filter, ← hF.card_edges, nsmul_eq_mul]
        simp
      · intro j; simp [pairs]
    have htotal : ∑ i : Fin (4 * n), ((i : ℕ) + 1) = 2 * n * (4 * n + 1) := by
      simp [sum_range_id (4 * n), mul_comm]
      omega
    rw [hS_sum, ← compl_union_self S, sum_union (disjoint_compl S), hS_sum] at htotal
    omega
  · intro i
    have hS_card : #{j ∈ S | c j = i} = F.degree i := by
      simp [S, biUnion_filter, card_biUnion]
      convert hF.degree_eq i
    rw [hS_card, hF.regular]
