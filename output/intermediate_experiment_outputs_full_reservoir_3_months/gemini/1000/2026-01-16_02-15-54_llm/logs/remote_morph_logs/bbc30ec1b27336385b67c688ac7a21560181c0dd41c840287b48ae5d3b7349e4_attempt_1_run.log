import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let p (i : Fin (2 * n)) : Finset (Fin (4 * n)) := {⟨2 * i.1, by omega⟩, ⟨2 * i.1 + 1, by omega⟩}
  let v (i : Fin n) : Finset (Fin (2 * n)) := {k | ∃ x ∈ p k, c x = i}
  let E : Finset (Fin (2 * n) × Fin (2 * n)) :=
    Finset.univ.bind fun i =>
      let s := (Finset.univ.filter fun k => ∃ x ∈ p k, c x = i).sort (fun x y => x < y)
      if h' : s.length = 4 then
        {(s.nthLe 0 h', s.nthLe 2 h'), (s.nthLe 1 h', s.nthLe 3 h')}
      else if h' : s.length = 3 then
        let k1 := s.nthLe 0 h'
        let k2 := s.nthLe 1 h'
        let k3 := s.nthLe 2 h'
        if (p k1).filter (fun x => c x = i) |>.card = 2 then {(k1, k1), (k2, k3)}
        else if (p k2).filter (fun x => c x = i) |>.card = 2 then {(k2, k2), (k1, k3)}
        else {(k3, k3), (k1, k2)}
      else if h' : s.length = 2 then
        let k1 := s.nthLe 0 h'
        let k2 := s.nthLe 1 h'
        {(k1, k1), (k2, k2)}
      else ∅
  let G : SimpleGraph (Fin (2 * n)) := SimpleGraph.fromRel fun x y => (x, y) ∈ E ∨ (y, x) ∈ E
  have : ∀ i, G.degree i = 2 := sorry
  obtain ⟨S', hS'⟩ := sorry
  exact sorry

end IMO2020P3
