import Mathlib


open scoped Finset

namespace IMO2020P3

theorem result {n : ℕ} {c : Fin (4 * n) → Fin n} (h : ∀ i, #{j | c j = i} = 4) :
    ∃ S : Finset (Fin (4 * n)), ∑ i ∈ S, ((i : ℕ) + 1) = ∑ i ∈ Sᶜ, ((i : ℕ) + 1) ∧
      ∀ i, #{j ∈ S | c j = i} = 2 := by
  let V := Fin n
  let E := Fin (2 * n)
  let f : E → Sym2 (Fin (4 * n)) := λ i => s{⟨i, by omega⟩, ⟨4 * n - 1 - i, by omega⟩}
  let g : E → Sym2 V := λ i => (f i).map c
  let G : SimpleGraph V := SimpleGraph.fromRel (λ i j => ∃ e, g e = s{i, j})
  let M : Multigraph V := Multigraph.ofEdges (Finset.univ.val.map g)
  have deg : ∀ v : V, M.degree v = 4 := by
    intro v
    simp only [M, Multigraph.degree_ofEdges, Multigraph.count_sum, Multigraph.count_ofEdges,
      Finset.univ_val, List.map_map, Function.comp_apply, Sym2.mem_iff]
    have h_card : (Finset.univ.filter (λ i => v ∈ g i)).card = 2 := by
      let s := {j | c j = v}
      have hs : s.card = 4 := h v
      sorry
    sorry
  sorry
