    exact integral_congr_ae ((VectorMeasure.rnDeriv_rnDeriv ŌÉ ŌÉ.var őĽ).mono (Measure.AbsolutelyContinuous.le_add_left (le_refl _) hŌÉ) |>.symm.mul (ae_of_all _ (őĽ _ => rfl))) |>.trans
      (integral_congr_ae (ae_of_all _ (őĽ _ => by simp [mul_comm, mul_assoc])))
  rw [h őľ (Measure.AbsolutelyContinuous.le_add_right (le_refl _)), h őĹ (Measure.AbsolutelyContinuous.le_add_left (le_refl _)),
    h (őľ + őĹ) (variation_ennrealToMeasure_le_add őľ őĹ)]
  rw [VectorMeasure.rnDeriv_add őľ őĹ őĽ, ‚Üź integral_add]
