variable {G : Type*} [NormedAddCommGroup G] [NormedSpace ‚Ąā G]

/-! ## Polar decomposition of complex measures. -/

/-- The variation measure part in the polar decomposition of a complex measure. -/
noncomputable def var (őľ : ComplexMeasure őĪ) := őľ.variation.ennrealToMeasure

@[simp]
lemma var_neg (őľ : ComplexMeasure őĪ) : (-őľ).var = őľ.var := by
  simp [var, MeasureTheory.VectorMeasure.variation_neg]

/-- The angular part (density function) in the polar decomposition of a complex measure. -/
noncomputable def ang (őľ : ComplexMeasure őĪ) := őľ.rnDeriv őľ.var

@[simp]
lemma ang_neg (őľ : ComplexMeasure őĪ) : (-őľ).ang = -őľ.ang := by
  -- To do: adjust this statement to the `őľ`-a.e. version.
  sorry

/-! ## Definition of the integral. -/

/-- The integral with respect to a complex measure defined using the polar decomposition of the
complex measure and the integral with respect to the total variation.-/
noncomputable def integral (őľ : ComplexMeasure őĪ) (f : őĪ ‚Üí G) :=
  ‚ąę x,  őľ.ang x ‚ÄĘ f x ‚ąā(őľ.var)

notation3 "‚ąę "(...)", "r:60:(scoped f => f)" ‚ąā"őľ:70 => integral őľ r

/-! ## Some lemmas related to the integral. -/

/-- For complex measures `őľ`, `őĹ` and integrable function `f`: `‚ąę f d(őľ + őĹ) = ‚ąę f dőľ + ‚ąę f dőĹ` -/
lemma integral_add (őľ őĹ : ComplexMeasure őĪ) (f : őĪ ‚Üí ‚Ąā) :
    ‚ąę a, f a ‚ąā(őľ + őĹ) = ‚ąę a, f a ‚ąāőľ + ‚ąę a, f a ‚ąāőĹ := by
  dsimp [integral]
  let őĽ := őľ.var + őĹ.var
  have h (ŌÉ : ComplexMeasure őĪ) (hŌÉ : ŌÉ.var ‚Č™ őĽ) :
      ‚ąę a, ŌÉ.ang a * f a ‚ąāŌÉ.var = ‚ąę a, f a * ŌÉ.rnDeriv őĽ a ‚ąāőĽ := by
