module

public import Mathlib
public import SpectralThm.toMathlib.Variation.Defs
public import SpectralThm.toMathlib.Variation.Lemmas


/-!
# Integral with respect to a complex-valued measure

Three options come to mind for defining the integral with respect to a complex-valued measure:

1. Define the integral with respect to a complex measure by decomposing the measure into real and imaginary parts and then using the definition of integral with respect to a signed measure. I.e.,
```
noncomputable def integral (őľ : SignedMeasure őĪ) (f : őĪ ‚Üí G) : G :=
    ‚ąę a, f a ‚ąāőľ.toJordanDecomposition.posPart - ‚ąę a, f a ‚ąāőľ.toJordanDecomposition.negPart
```
In turn, the integral with respect to as signed measure is defined using the Jordan decomposition
into positive and negative parts.

2. Develop directly the integral with respect to any `VectorMeasure` by introducing simple
functions, etc.

3. Use the polar decomposition of a complex measure into total variation measure and angular
function and hence use the definition of a Bochner integral.

It is unclear what the best design choice is so at the moment we opt for using polar decomposition
as the definition.

Whatever the direction taken with these definitions, the different components should be separated
into their own files.

## Main definitions

* `ComplexMeasure.integral`

## Notation

* `‚ąę a, f a ‚ąāőľ` : integral of `f` with respect to a `ComplexMeasure` `őľ`

## To do

* Add many other relevant results.

-/

@[expose] public section

namespace MeasureTheory.ComplexMeasure

open MeasureTheory

variable {őĪ : Type*} [MeasurableSpace őĪ]
variable {G : Type*} [NormedAddCommGroup G] [NormedSpace ‚Ąā G]

/-! ## Polar decomposition of complex measures. -/

/-- The variation measure part in the polar decomposition of a complex measure. -/
noncomputable def var (őľ : ComplexMeasure őĪ) := őľ.variation.ennrealToMeasure

@[simp]
lemma var_neg (őľ : ComplexMeasure őĪ) : (-őľ).var = őľ.var := by
  simp [var, MeasureTheory.VectorMeasure.variation_neg]

/-- The angular part (density function) in the polar decomposition of a complex measure. -/
noncomputable def ang (őľ : ComplexMeasure őĪ) := őľ.rnDeriv őľ.var

@[simp]
lemma ang_neg (őľ : ComplexMeasure őĪ) : (-őľ).ang = -őľ.ang := by
  -- To do: adjust this statement to the `őľ`-a.e. version.
  sorry

/-! ## Definition of the integral. -/

/-- The integral with respect to a complex measure defined using the polar decomposition of the
complex measure and the integral with respect to the total variation.-/
noncomputable def integral (őľ : ComplexMeasure őĪ) (f : őĪ ‚Üí G) :=
  ‚ąę x,  őľ.ang x ‚ÄĘ f x ‚ąā(őľ.var)

notation3 "‚ąę "(...)", "r:60:(scoped f => f)" ‚ąā"őľ:70 => integral őľ r

/-! ## Some lemmas related to the integral. -/

/-- For complex measures `őľ`, `őĹ` and integrable function `f`: `‚ąę f d(őľ + őĹ) = ‚ąę f dőľ + ‚ąę f dőĹ` -/
lemma integral_add (őľ őĹ : ComplexMeasure őĪ) (f : őĪ ‚Üí ‚Ąā) :
    ‚ąę a, f a ‚ąā(őľ + őĹ) = ‚ąę a, f a ‚ąāőľ + ‚ąę a, f a ‚ąāőĹ := by
  dsimp [integral, ang]
  let őĽ := őľ.var + őĹ.var
  have hőľ : őľ.var ‚Č™ őĽ := Measure.IsAbsolutelyContinuous.left _ _
  have hőĹ : őĹ.var ‚Č™ őĽ := Measure.IsAbsolutelyContinuous.right _ _
  have hőľőĹ : (őľ + őĹ).var ‚Č™ őĽ := (VectorMeasure.variation_add_le őľ őĹ).trans_ac (hőľ.add hőĹ)
  have h_eq (őļ : ComplexMeasure őĪ) (hőļ : őļ.var ‚Č™ őĽ) :
      ‚ąę a, őļ.rnDeriv őļ.var a * f a ‚ąāőļ.var = ‚ąę a, őļ.rnDeriv őĽ a * f a ‚ąāőĽ := by
    rw [‚Üź integral_withDensity_eq_integral_smul (őļ.var.measurable_rnDeriv őĽ), őĽ.withDensity_rnDeriv hőļ]
    refine integral_congr_ae ?_
    filter_upwards [őļ.rnDeriv_rnDeriv_measure őļ.var őĽ] with x hx
    rw [hx, mul_assoc, mul_comm (őļ.var.rnDeriv őĽ x)]
  rw [h_eq őľ hőľ, h_eq őĹ hőĹ, h_eq (őľ + őĹ) hőľőĹ]
  simp_rw [VectorMeasure.rnDeriv_add őľ őĹ őĽ, add_mul]
  by_cases hf : Integrable (fun a => őľ.rnDeriv őĽ a * f a) őĽ ‚ąß Integrable (fun a => őĹ.rnDeriv őĽ a * f a) őĽ
  ¬∑ exact integral_add hf.1 hf.2
  ¬∑ simp only [not_and_or] at hf
    have h1 : ¬¨Integrable (fun a => őľ.rnDeriv őĽ a * f a) őĽ ‚Üí ‚ąę a, őľ.rnDeriv őĽ a * f a ‚ąāőĽ = 0 := integral_undef
    have h2 : ¬¨Integrable (fun a => őĹ.rnDeriv őĽ a * f a) őĽ ‚Üí ‚ąę a, őĹ.rnDeriv őĽ a * f a ‚ąāőĽ = 0 := integral_undef
    cases hf with
    | inl hfőľ =>
      rw [h1 hfőľ, zero_add]
      have : ¬¨Integrable (fun a => (őľ + őĹ).rnDeriv őĽ a * f a) őĽ := by
        intro h; rw [VectorMeasure.rnDeriv_add] at h; exact hfőľ (h.sub_left hf.2) -- this logic only works if hf.2 is true
