  have h_ac (ŌČ : ComplexMeasure őĪ) : ŌČ ‚Č™ őĽ := ŌČ.absolutelyContinuous_variation.trans
    (Measure.AbsolutelyContinuous.mk (őĽ s hs => by simp [őĽ, hs]))
  have h_eq (ŌČ : ComplexMeasure őĪ) : (‚ąę x, ŌČ.ang x ‚ÄĘ f x ‚ąāŌČ.var) = ‚ąę x, f x ‚ÄĘ ŌČ.rnDeriv őĽ x ‚ąāőĽ :=
    (VectorMeasure.set_integral_rnDeriv_smul (h_ac ŌČ) f .univ).symm.trans Measure.set_integral_univ.symm
  rw [h_eq (őľ + őĹ), h_eq őľ, h_eq őĹ, VectorMeasure.rnDeriv_add (h_ac őľ) (h_ac őĹ)]
  simp only [Pi.add_apply, smul_add, integral_add]
