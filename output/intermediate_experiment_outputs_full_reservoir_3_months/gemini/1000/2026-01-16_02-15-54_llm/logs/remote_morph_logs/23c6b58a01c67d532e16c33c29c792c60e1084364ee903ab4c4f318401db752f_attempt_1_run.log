import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$, there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = {n | 3 ≤ n ∧ Odd n} := by
  constructor
  · intro n hn
    rcases n with (_|_|_|n) <;> try simp_all
    · use {![0, 0], ![1, 0], ![1/2, Real.sqrt 3 / 2]}
      simp [hb₀]; intro A HA B HB HAB; repeat (rcases HA with ⟨_⟩ | HA); repeat (rcases HB with ⟨_⟩ | HB)
      all_goals (try contradiction; try (use ![1/2, Real.sqrt 3 / 2]; simp [dist]; norm_num; done); try (use ![1, 0]; simp [dist]; norm_num; done); try (use ![0, 0]; simp [dist]; norm_num; done))
    · sorry -- General construction for n >= 4
  · ext n
    constructor
    · rintro ⟨hn, s, h_bal, h_cf, h_card⟩
      rw [hb₀] at h_bal; rw [hb₁] at h_cf; rw [← h_card]
      let pairs := s.offDiag.filter (fun (A, B) => A ≠ B)
      let mapping := fun p : (EuclideanSpace ℝ (Fin 2)) × (EuclideanSpace ℝ (Fin 2)) =>
          Classical.choose (h_bal p.1 (s.mem_of_mem_offDiag p.2.1) p.2 (s.mem_of_mem_offDiag p.2.2) (by sorry))
      have h_mapping_prop : ∀ p ∈ s.offDiag, mapping p ∈ s ∧ dist p.1 (mapping p) = dist p.2 (mapping p) := sorry
      have h_cf_bound : ∀ C ∈ s, (s.offDiag.filter (fun p => mapping p = C)).card ≤ s.card - 1 := sorry
      have : s.card * (s.card - 1) ≤ s.card * (2 * ((s.card - 1) / 2)) := sorry
      rw [Nat.odd_iff_not_even]
      contrapose! this; exact Nat.even_iff_exists_two_mul.mp this |> sorry
    · rintro ⟨hn, h_odd⟩
      sorry -- Regular n-gon construction
