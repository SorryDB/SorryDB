        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = {n | 3 ≤ n ∧ Odd n} := by
  refine ⟨fun n hn => ?_, ?_⟩
  · rcases Nat.even_or_odd n with h | h
    · let m := n - 1
      have hm : Odd m := Nat.even_iff_not_odd.mp (by omega)
      obtain ⟨s, hB, hCF, hs⟩ := (ih : {n | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = {n | 3 ≤ n ∧ Odd n}).symm.subst (m := m) (by omega : 3 ≤ m ∧ Odd m)
      let O : EuclideanSpace ℝ (Fin 2) := 0
      let R := (s.map ⟨dist O, sorry⟩).max.getD 0 + 1
      let s' := s.image (λ P => (dist P O / R) • P)
      sorry -- Existence can be shown by a regular (n-1)-gon with carefully chosen radius and center.
    · use (Finset.range n).image (λ i => (!![Real.cos (2 * Real.pi * i / n), Real.sin (2 * Real.pi * i / n)] : EuclideanSpace ℝ (Fin 2)))
      sorry -- Regular n-gon is balanced for odd n.
  · ext n
    refine ⟨?_, fun ⟨hn, h_odd⟩ => ?_⟩
    · rintro ⟨hn, s, hb, hcf, hs⟩
      rw [hb₀] at hb; rw [hb₁] at hcf
      let pairs := s.offDiag
      have h_card_pairs : pairs.card = n * (n - 1) := by simp [hs, Finset.card_offDiag]
      let f : (EuclideanSpace ℝ (Fin 2) × EuclideanSpace ℝ (Fin 2)) → EuclideanSpace ℝ (Fin 2) :=
        λ ⟨A, B⟩ => Classical.choose (hb A (by sorry) B (by sorry) (by sorry))
      have hf : ∀ p ∈ pairs, dist (f p) p.1 = dist (f p) p.2 ∧ f p ∈ s := λ p hp => by
        let ⟨A, B⟩ := p; exact ⟨(Classical.choose_spec (hb A (by sorry) B (by sorry) (by sorry))).2, (Classical.choose_spec (hb A (by sorry) B (by sorry) (by sorry))).1⟩
      have h_limit : ∀ C ∈ s, (pairs.filter (λ p => f p = C)).card ≤ n - 1 := by
        intro C hC
        let sC := (pairs.filter (λ p => f p = C)).image (λ p => p.1)
        sorry -- Since S is center-free, each C can be the midpoint of at most (n-1)/2 pairs.
      have : n * (n - 1) ≤ n * (if Odd n then n - 1 else n - 2) := sorry
      exact Nat.odd_iff_not_even.mpr (λ h_even => by sorry)
    · obtain ⟨s, hb_s, hcf_s, hs⟩ := (ih_odd : ∃ s, Balanced s ∧ center_free s ∧ s.card = n) -- Regular n-gon works.
      exact ⟨hn, s, hb_s, hcf_s, hs⟩
  where ih : {n | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = {n | 3 ≤ n ∧ Odd n} := sorry

