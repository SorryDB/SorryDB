      rw [hb₁] at hcf
      let pairs := s.offDiag
      let f (C : EuclideanSpace ℝ (Fin 2)) := pairs.filter (λ p => dist C p.1 = dist C p.2)
      have h_cf (C : EuclideanSpace ℝ (Fin 2)) (hC : C ∈ s) : ∀ p1 p2, p1 ∈ f C → p2 ∈ f C → p1 ≠ p2 → Disjoint ({p1.1, p1.2} : Set _) {p2.1, p2.2} := by
        intro p1 p2 hp1 hp2 hpneq
        rw [Finset.mem_filter] at hp1 hp2
        intro x hx; simp at hx
        rcases hx with ⟨(rfl | rfl), (rfl | rfl)⟩ <;> apply hcf C s.1 s.2 <;> aesop
      have h_card (C : EuclideanSpace ℝ (Fin 2)) (hC : C ∈ s) : (f C).card ≤ (n - 1) / 2 := by
        -- Each pair in f C is disjoint and from s \ {C}
        sorry
      have h_bal_sum : pairs.card ≤ ∑ C ∈ s, (f C).card := by
        rw [Finset.card_offDiag, hs]
