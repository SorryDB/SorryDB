import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$, there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = {n | 3 ≤ n ∧ Odd n} := by
  constructor
  · intro n hn
    rcases Nat.even_or_odd n with h | h
    · induction n, hn using Nat.le_induction with
      | base => -- n = 4, rhombus of two equilateral triangles
        let p1 : EuclideanSpace ℝ (Fin 2) := !![0, 1]
        let p2 : EuclideanSpace ℝ (Fin 2) := !![Real.sqrt 3, 0]
        let p3 : EuclideanSpace ℝ (Fin 2) := !![0, -1]
        let p4 : EuclideanSpace ℝ (Fin 2) := !![-Real.sqrt 3, 0]
        exact ⟨{p1, p2, p3, p4}, by sorry⟩
      | step m hm ih => sorry
    · -- n is odd, use regular n-gon
      sorry
  · ext n
    constructor
    · rintro ⟨hn, s, h_bal, h_cf, h_card⟩
      rw [hb₀] at h_bal; rw [hb₁] at h_cf
      let pairs := s.offDiag
      have : pairs.card = n * (n - 1) := by rw [Finset.card_offDiag, h_card]
      let f : s.offDiag → s := λ ⟨(A, B), h⟩ => Classical.choose (h_bal A (h.1) B (h.2.1) (h.2.2))
      have h_f : ∀ p, dist (f p) p.1.1 = dist (f p) p.1.2 := λ p => Classical.choose_spec (h_bal p.1.1 (p.2.1) p.1.2 (p.2.2.1) (p.2.2.2))
      have h_inj : ∀ C ∈ s, ∀ A ∈ s, A ≠ C → ∃! B ∈ s, B ≠ A ∧ B ≠ C ∧ dist C A = dist C B := by
        intro C hCs A hAs hAC
        let s' := s.erase C
        have : ∀ X ∈ s', ∀ Y ∈ s', X ≠ Y → dist C X = dist C Y → False := by
          intro X hX Y hY hXY hdist
          exact h_cf X (Finset.mem_of_mem_erase hX) Y (Finset.mem_of_mem_erase hY) C hCs ⟨hXY, (Finset.ne_of_mem_erase hY).symm, (Finset.ne_of_mem_erase hX).symm⟩ ⟨C, hCs, hdist.symm, hdist.symm⟩
        sorry
      have : n % 2 = 1 := by sorry
      exact ⟨hn, Nat.odd_iff.mpr this⟩
    · rintro ⟨hn, h_odd⟩
      -- Regular n-gon is balanced and centre-free
      sorry
