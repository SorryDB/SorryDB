      Grp.isoMk (Over.isoMk e h1) h2
    let e_hopf := (hopfSpec R).preimageIso ((diagFunctorIso R).hom.app (.op (.of A)) ≪≫ e_grp.symm)
    rw [← (Scheme.ΓSpecIso (Γ(G, ⊤))).symm.trans_apply (IsGroupLikeElem R),
      ← Submodule.map_span, ← Submodule.map_top (f := (Scheme.ΓSpecIso (Γ(G, ⊤))).symm.toLinearMap)]
    apply congr_arg
    rw [Set.image_setOf]
    let e_alg := (Scheme.Γ(G, ⊤).mapIso e_grp.hom.left.iso.symm).trans
      (Scheme.Γ((Diag (Spec R) A).asOver (Spec R), ⊤).mapIso (diagSpecIso R A).symm)
    -- The Hopf algebra of G is isomorphic to R[A], and R[A] is spanned by group-like elements.
