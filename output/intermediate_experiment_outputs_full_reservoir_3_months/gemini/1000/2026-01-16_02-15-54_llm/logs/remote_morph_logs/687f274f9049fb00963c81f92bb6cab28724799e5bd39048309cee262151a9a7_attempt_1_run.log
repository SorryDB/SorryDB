import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩
  simp only [Set.mem_setOf_eq, Set.mem_insert_iff, Set.mem_singleton_iff, Prod.mk.injEq]
  constructor
  · rintro ⟨⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨dx, hx⟩, ⟨dy, hy⟩, ⟨dz, hz⟩⟩
    have ha1 : a > 1 := by
      by_contra! h; have : a = 1 := by linarith
      subst this; linarith [hx, (show 2^dx > 0 by positivity)]
    have hba : b * (a^2 - 1) = 2^dz + a * 2^dx := by linarith
    have hca : c * (a^2 - 1) = 2^dx + a * 2^dz := by linarith
    have hbc' : (a^2 - 1)^2 * (2^dy + a) = (2^dz + a * 2^dx) * (2^dx + a * 2^dz) := by linarith
    if ha2 : a = 2 then
      have hb3 : 3 * b = 2^dz + 2^(dx + 1) := by linarith
      have hc3 : 3 * c = 2^dx + 2^(dz + 1) := by linarith
      if hx0 : dx = 0 then
        have : 9 * 2^dy = 2 * 2^(2*dz) + 5 * 2^dz - 16 := by linarith
        match dz with
        | 2 => left; left; right; repeat constructor <;> linarith
        | 4 => right; left; repeat constructor <;> linarith
        | _ => sorry
      else if hx1 : dx = 1 then
        match dz with
        | 1 => left; left; left; repeat constructor <;> linarith
        | _ => sorry
      else sorry
    else if ha3 : a = 3 then
      match dx, dy, dz with
      | 3, 5, 4 => right; right; repeat constructor <;> linarith
      | _, _, _ => sorry
    else sorry
  · rintro (⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩)
    all_goals repeat (constructor <;> try linarith)
    · use 1; norm_num
    · use 1; norm_num
    · use 1; norm_num
    · use 0; norm_num
    · use 2; norm_num
    · use 2; norm_num
    · use 0; norm_num
    · use 6; norm_num
    · use 4; norm_num
    · use 3; norm_num
    · use 5; norm_num
    · use 4; norm_num

