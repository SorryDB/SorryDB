import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩
  simp only [Set.mem_setOf_eq, Set.mem_insert_eq, Set.mem_singleton_eq, Prod.mk.injEq]
  constructor
  · rintro ⟨ha, hb, hc, ⟨hab, hbc⟩, d1, hd1, d2, hd2, d3, hd3⟩
    have h1 : 1 < a := by
      by_contra h; have : a = 1 := by linarith
      have : 1 * b - c = 2 ^ d1 := by rwa [this] at hd1
      linarith [pow_pos (show 2 > 0 by norm_num) d1]
    have h2 : a = 2 ∨ a = 3 := by
      by_contra h_a; push_neg at h_a
      have h_a_ge_4 : a ≥ 4 := by linarith
      sorry
    rcases h2 with rfl | rfl
    · rcases (show b = 2 ∨ b = 6 ∨ b > 6 by sorry) with rfl | rfl | hb_gt_6
      · rcases (show c = 2 ∨ c = 3 by sorry) with rfl | rfl
        · left; repeat constructor
        · right; left; repeat constructor
      · rcases (show c = 11 by sorry) with rfl
        · right; right; left; repeat constructor
      · sorry
    · rcases (show b = 5 by sorry) with rfl
      rcases (show c = 7 by sorry) with rfl
      · right; right; right; repeat constructor
  · rintro (h | h | h | h)
    all_goals rcases h with ⟨rfl, ⟨rfl, rfl⟩⟩
    · exact ⟨by norm_num, by norm_num, by norm_num, ⟨by norm_num, by norm_num⟩, 1, by norm_num, 1, by norm_num, 1, by norm_num⟩
    · exact ⟨by norm_num, by norm_num, by norm_num, ⟨by norm_num, by norm_num⟩, 0, by norm_num, 2, by norm_num, 2, by norm_num⟩
    · exact ⟨by norm_num, by norm_num, by norm_num, ⟨by norm_num, by norm_num⟩, 0, by norm_num, 6, by norm_num, 4, by norm_num⟩
    · exact ⟨by norm_num, by norm_num, by norm_num, ⟨by norm_num, by norm_num⟩, 3, by norm_num, 5, by norm_num, 4, by norm_num⟩

