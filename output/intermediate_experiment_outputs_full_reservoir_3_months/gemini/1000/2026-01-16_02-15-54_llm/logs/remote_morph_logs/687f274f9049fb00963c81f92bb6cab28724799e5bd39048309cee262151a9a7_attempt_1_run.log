      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩
  constructor
  · rintro ⟨⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨x, hx⟩, ⟨z, hz⟩, ⟨y, hy⟩, hx_eq⟩
    injection hx_eq with ha_eq hb_eq hc_eq; subst_vars
    have ha1 : 1 < a := by
      by_contra h; have : a = 1 := by linarith
      subst this; have : 1 * b - c = 2^x := hx; linarith [show 2^x ≥ 1 from one_le_two_pow x]
    have hbx : (a^2 - 1) * b = a * 2^x + 2^y := by linarith
    have hcx : (a^2 - 1) * c = a * 2^y + 2^x := by linarith
    have hz_val : (a^2 - 1)^2 * 2^z = (a * 2^x + 2^y) * (a * 2^y + 2^x) - a * (a^2 - 1)^2 := by linarith
    if ha2 : a = 2 then
      subst ha2; norm_num at hbx hcx hz_val
      if hx0 : x = 0 then
        subst hx0; norm_num at hbx hcx hz_val
        have : 2^(2 * y + 1) + 5 * 2^y - 16 = 9 * 2^z := by linarith
        if hy2 : y = 2 then subst hy2; right; left; right; left; rfl
        else if hy4 : y = 4 then subst hy4; right; left; right; right; rfl
        else sorry
      else if hx1 : x = 1 then
        subst hx1; norm_num at hbx hcx hz_val
        have : 2^(2 * y + 1) + 10 * 2^y - 10 = 9 * 2^z := by linarith
        if hy1 : y = 1 then subst hy1; left; rfl
        else sorry
      else sorry
    else if ha3 : a = 3 then
      subst ha3; norm_num at hbx hcx hz_val
      if hx3 : x = 3 then
        subst hx3; norm_num at hbx hcx hz_val
        have : 3 * 2^(2 * y) + 80 * 2^y = 64 * 2^z := by linarith
        if hy4 : y = 4 then subst hy4; right; right; rfl
        else sorry
      else sorry
    else sorry
