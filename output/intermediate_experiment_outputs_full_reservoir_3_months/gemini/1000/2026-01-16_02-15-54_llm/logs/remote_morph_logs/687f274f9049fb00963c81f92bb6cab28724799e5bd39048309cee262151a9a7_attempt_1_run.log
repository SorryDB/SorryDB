import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext x
  constructor
  · rintro ⟨a, b, c, h₀, h₁, ⟨dx, hx⟩, ⟨dy, hy⟩, ⟨dz, hz⟩, rfl⟩
    have ha1 : a > 1 := by
      by_contra! h; have ha : a = 1 := by linarith [h₀.1]
      rw [ha] at hx; linarith [Nat.two_pow_pos dx, h₁.2]
    if ha2 : a = 2 then
      subst ha2
      have h3b : (3:ℤ) * b = 2^(dx + 1) + 2^dz := by linarith
      have h3c : (3:ℤ) * c = 2^dx + 2^(dz + 1) := by linarith
      have h9y : (9:ℤ) * (2^dy + 2) = (2^(dx+1) + 2^dz) * (2^dx + 2^(dz+1)) := by linarith
      if hdx0 : dx = 0 then
        subst hdx0
        if hdz2 : dz = 2 then
          have : b = 2 := by linarith
          have : c = 3 := by linarith
          simp [this]
        else if hdz4 : dz = 4 then
          have : b = 6 := by linarith
          have : c = 11 := by linarith
          simp [this]
        else sorry
      else if hdx1 : dx = 1 then
        subst hdx1
        if hdz1 : dz = 1 then
          have : b = 2 := by linarith
          have : c = 2 := by linarith
          simp [this]
        else sorry
      else sorry
    else if ha3 : a = 3 then
      subst ha3
      if hb5 : b = 5 then
        if hc7 : c = 7 then simp [hc7]
        else sorry
      else sorry
    else sorry
  · rintro (h | h | h | h) <;> subst h
    · exact ⟨2, 2, 2, ⟨by decide, by decide, by decide⟩, ⟨by decide, by decide⟩, ⟨1, rfl⟩, ⟨1, rfl⟩, ⟨1, rfl⟩, rfl⟩
    · exact ⟨2, 2, 3, ⟨by decide, by decide, by decide⟩, ⟨by decide, by decide⟩, ⟨0, rfl⟩, ⟨2, rfl⟩, ⟨2, rfl⟩, rfl⟩
    · exact ⟨2, 6, 11, ⟨by decide, by decide, by decide⟩, ⟨by decide, by decide⟩, ⟨0, rfl⟩, ⟨6, rfl⟩, ⟨4, rfl⟩, rfl⟩
    · exact ⟨3, 5, 7, ⟨by decide, by decide, by decide⟩, ⟨by decide, by decide⟩, ⟨3, rfl⟩, ⟨5, rfl⟩, ⟨4, rfl⟩, rfl⟩
