    have h_ax : (a^2 - 1) * c = a * 2^z + 2^x := by linarith
    if ha2 : a = 2 then
      subst ha2; have h3b : 3 * b = 2^(x+1) + 2^z := by linarith
      have h3c : 3 * c = 2 * 2^z + 2^x := by linarith
      if hx0 : x = 0 then
        subst hx0; have h_eq : 2 * 2^(2*z) + 5 * 2^z - 16 = 9 * 2^y := by
          have : 9 * (b * c - 2) = 9 * 2^y := by linarith
          rw [← this]; ring_nf; rw [h3b, h3c]; ring
        match z with
        | 2 => left; rw [show b = 2 by linarith, show c = 3 by linarith]; rfl
        | 4 => right; left; rw [show b = 6 by linarith, show c = 11 by linarith]; rfl
        | _ => sorry
      else if hx1 : x = 1 then
        subst hx1; have h_eq : 2 * 2^(2*z) + 10 * 2^z - 10 = 9 * 2^y := by
          have : 9 * (b * c - 2) = 9 * 2^y := by linarith
          rw [← this]; ring_nf; rw [h3b, h3c]; ring
        match z with
        | 1 => left; rw [show b = 2 by linarith, show c = 2 by linarith]; rfl
        | _ => sorry
      else sorry
    else if ha3 : a = 3 then
      subst ha3; if hx3 : x = 3 then
        subst hx3; have h8b : 8 * b = 24 + 2^z := by linarith
        have h8c : 8 * c = 3 * 2^z + 8 := by linarith
        have h_eq : 3 * 2^(2*z) + 80 * 2^z = 64 * (2^y + 3) := by
