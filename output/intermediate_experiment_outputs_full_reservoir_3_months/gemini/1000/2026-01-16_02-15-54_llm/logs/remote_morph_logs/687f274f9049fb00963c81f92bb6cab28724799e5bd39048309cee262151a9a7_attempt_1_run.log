      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩; constructor
  · rintro ⟨⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨x, hx⟩, ⟨y, hy⟩, ⟨z, hz⟩⟩
    have ha1 : a ≥ 2 := by
