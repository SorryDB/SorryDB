import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext x
  simp only [Set.mem_setOf_eq, Set.mem_insert_iff, Set.mem_singleton_iff]
  constructor
  · rintro ⟨a, b, c, ⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨d1, h1⟩, ⟨d2, h2⟩, ⟨d3, h3⟩, rfl⟩
    have ha_gt_1 : a > 1 := by
      have : (a:ℤ) * b - c = 2^d1 := h1
      by_contra; have : a = 1 := by linarith
      subst a; linarith [show (2:ℤ)^d1 > 0 from pow_pos (by norm_num) d1]
    if ha2 : a = 2 then
      if hb2 : b = 2 then
        have : 4 - c = 2^d1 := by linarith
        have : c = 2 ∨ c = 3 := by
          have : (2:ℤ)^d1 ≤ 2 ∧ (2:ℤ)^d1 > 0 := ⟨by linarith, by apply pow_pos; norm_num⟩
          rcases d1 with rfl | d1; left; linarith; rcases d1 with rfl | d1; right; linarith
          have : (2:ℤ)^(d1+2) > 2 := by apply pow_gt_lin <;> norm_num
          linarith
        rcases this with rfl | rfl <;> simp
      else if hb6 : b = 6 then
        if hc11 : c = 11 then simp else sorry
      else sorry
    else if ha3 : a = 3 then
      if hb5 : b = 5 then
        if hc7 : c = 7 then simp else sorry
      else sorry
    else sorry
  · rintro (rfl | rfl | rfl | rfl)
    · use 2, 2, 2, ⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩, rfl
    · use 2, 2, 3, ⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨0, by norm_num⟩, ⟨2, by norm_num⟩, ⟨2, by norm_num⟩, rfl
    · use 2, 6, 11, ⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨0, by norm_num⟩, ⟨6, by norm_num⟩, ⟨4, by norm_num⟩, rfl
    · use 3, 5, 7, ⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨3, by norm_num⟩, ⟨5, by norm_num⟩, ⟨4, by norm_num⟩, rfl

