      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩
  constructor
  · rintro ⟨⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨dx, hx⟩, ⟨dy, hy⟩, ⟨dz, hz⟩, rfl⟩
    dsimp at *
