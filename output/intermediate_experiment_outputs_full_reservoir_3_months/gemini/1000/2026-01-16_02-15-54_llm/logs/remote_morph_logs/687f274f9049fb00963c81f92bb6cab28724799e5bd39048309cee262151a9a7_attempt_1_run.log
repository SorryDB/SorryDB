      linarith [pow_pos (show 2 > 0 by norm_num) dx]
    rcases (show a = 2 ∨ a = 3 ∨ a ≥ 4 by linarith) with rfl | rfl | ha4
    · rcases (show b = 2 ∨ b = 6 ∨ (b > 2 ∧ b ≠ 6) by linarith) with rfl | rfl | hb
      · rcases (show c = 2 ∨ c = 3 ∨ c > 3 by linarith) with rfl | rfl | hc
        · left; rfl
        · right; left; rfl
        · exfalso; have : 4 - c = (2:ℤ)^dx := hx; linarith [pow_pos (show 2 > 0 by norm_num) dx]
      · rcases (show c = 11 ∨ c ≠ 11 by linarith) with rfl | hc
        · right; right; left; rfl
        · exfalso; sorry
      · exfalso; sorry
    · rcases (show b = 5 ∨ b ≠ 5 by linarith) with rfl | hb
      · rcases (show c = 7 ∨ c ≠ 7 by linarith) with rfl | hc
        · right; right; right; rfl
        · exfalso; sorry
