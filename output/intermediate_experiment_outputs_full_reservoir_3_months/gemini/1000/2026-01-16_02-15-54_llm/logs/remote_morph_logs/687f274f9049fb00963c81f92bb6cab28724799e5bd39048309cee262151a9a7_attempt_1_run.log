import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩
  simp only [Set.mem_setOf_eq, Set.mem_insert_iff, Set.mem_singleton_iff, Prod.mk.injEq]
  constructor
  · rintro ⟨⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨x, hx⟩, ⟨y, hy⟩, ⟨z, hz⟩⟩
    have ha2 : a ≥ 2 := by
      by_contra h; have : a = 1 := by linarith; subst this
      have : b - c = 2^x := by linarith; have : b ≤ c := hab; linarith [pow_pos (show (2:ℤ) > 0 by norm_num) x]
    have h_abc : a = 2 ∨ a = 3 := by
      have hx_pos : 2^x > 0 := pow_pos (by norm_num) x
      have hz_pos : 2^z > 0 := pow_pos (by norm_num) z
      have hy_pos : 2^y > 0 := pow_pos (by norm_num) y
      if ha4 : a ≥ 4 then
        have : (a - 1) * (b + c) = 2^z + 2^x := by nlinarith
        have : (a - 1) * (a + b) ≤ (a - 1) * (b + c) := by nlinarith
        have : 3 * (4 + 4) ≤ (a - 1) * (b + c) := by nlinarith
        sorry -- Contradiction for a ≥ 4
      else
        if ha2' : a = 2 then left; exact ha2' else right; linarith
    rcases h_abc with rfl | rfl
    · have h_bc : 3 * b = 2^(x+1) + 2^z := by nlinarith
      have h_cc : 3 * c = 2^(z+1) + 2^x := by nlinarith
      if hx0 : x = 0 then
        if hz2 : z = 2 then left; right; linarith
        else if hz4 : z = 4 then right; right; left; linarith
        else sorry
      else if hx1 : x = 1 then
        if hz1 : z = 1 then left; left; linarith
        else sorry
      else sorry
    · have h_bc : 8 * b = 3 * 2^x + 2^z := by nlinarith
      have h_cc : 8 * c = 3 * 2^z + 2^x := by nlinarith
      if hx3 : x = 3 ∧ z = 4 then right; right; right; linarith
      else sorry
  · rintro (⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩)
    · exact ⟨⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩⟩
    · exact ⟨⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨0, by norm_num⟩, ⟨2, by norm_num⟩, ⟨2, by norm_num⟩⟩
    · exact ⟨⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨0, by norm_num⟩, ⟨6, by norm_num⟩, ⟨4, by norm_num⟩⟩
    · exact ⟨⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨3, by norm_num⟩, ⟨5, by norm_num⟩, ⟨4, by norm_num⟩⟩

