      _ = ∫ (t : ℝ) in 0..1, g' t := by rw [int_g'_eq_sub]
      _ = ∫ (t : ℝ) in 0..1, g' 0 + ∫ (s : ℝ) in 0..t, g'' s := by
        conv => arg 2; arg 1; intro t; rw [int_g''_eq_sub]; simp
      _ = (∫ (t : ℝ) in 0..1, g' 0) + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s := by
