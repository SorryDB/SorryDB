    (offset : Fin 8) (circuit : Fin 8 → ElaboratedCircuit F Input Output)
    (Assumptions : Input F → Prop) :
    Completeness F (circuit offset) Assumptions := by
  circuit_proof_start
  -- offset is introduced first, then standard parameters
  sorry

