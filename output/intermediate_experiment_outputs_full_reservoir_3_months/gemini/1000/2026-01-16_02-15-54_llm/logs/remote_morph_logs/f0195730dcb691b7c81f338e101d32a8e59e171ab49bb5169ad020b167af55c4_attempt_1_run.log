lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  rw [hs]; simp only [Sigma.snd]
  have h_darts : ∀ {u v} (w : (K n).LoopWalk u v), (permMapWalk n s w).darts = w.darts.map (fun d ↦ (s d.1, s d.2)) := by
    intros; induction ‹(K n).LoopWalk _ _› <;> simp [*]
  simp only [edgeSet, edges, h_darts, List.map_map]
  have : (fun d ↦ dartEdge (s d.1, s d.2)) = Sym2.map s ∘ dartEdge := by ext ⟨u, v⟩; rfl
  rw [this, ← List.map_map, List.toFinset_map]
  exact Finset.card_image_of_injective _ (Sym2.map_injective s.injective)
```
