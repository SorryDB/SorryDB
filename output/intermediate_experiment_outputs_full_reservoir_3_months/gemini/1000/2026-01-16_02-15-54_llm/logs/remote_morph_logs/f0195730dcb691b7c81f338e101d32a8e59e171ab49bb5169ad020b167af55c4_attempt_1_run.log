    | cons h p ih => simp [edgeSet, edges, darts, ih, dartEdge, Sym2.map_mk]
    | loop p ih => simp [edgeSet, edges, darts, ih, dartEdge, Sym2.map_mk]
  rw [h_edgeSet, Finset.card_image_of_injective _ (Sym2.map_injective s.injective)]
