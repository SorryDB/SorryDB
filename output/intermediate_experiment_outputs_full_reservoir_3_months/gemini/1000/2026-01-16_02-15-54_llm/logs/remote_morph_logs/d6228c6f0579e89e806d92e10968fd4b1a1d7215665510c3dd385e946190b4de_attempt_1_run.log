    {x₀ : TotalSpace F E} (hx₀ : x₀.proj ∈ e.baseSet) :
    ContMDiffAt (IB.prod 𝓘(𝕜, F)) (IB.prod 𝓘(𝕜, F)) ∞ e x₀ := by
  rw [@contMDiffAt_prod_iff]
