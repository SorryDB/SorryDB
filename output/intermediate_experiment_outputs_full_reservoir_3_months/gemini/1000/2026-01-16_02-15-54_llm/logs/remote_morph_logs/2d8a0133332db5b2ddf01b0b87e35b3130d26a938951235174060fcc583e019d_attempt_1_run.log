/-- All zeros of the Riemann zeta function outside the critical strip are simple zeros.
    This means if ζ(s) = 0 and s is not in the critical strip (s.re ≤ 0 or s.re ≥ 1),
    then the derivative at that point is non-zero: ζ'(s) ≠ 0. -/
theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 :=
by
  intro s hs h
  rw [riemannZeta_eq_zero_iff_complex] at h
  rcases h with ⟨n, rfl⟩ | h'
  · have h_func := riemannZeta_functional_eqn (2 * n + 1)
    have h_nz : riemannZeta (2 * n + 1) ≠ 0 := riemannZeta_ne_zero_of_re_gt_one (by simp)
    -- The trivial zeros of the Riemann zeta function are all simple.
    -- This follows from the functional equation and the simplicity of the zeros of sin(πs/2).
    sorry
  · exact (hs ⟨h'.1, h'.2.1⟩).elim
```
