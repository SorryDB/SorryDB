theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 := by
  intro s hs hζ
  obtain ⟨n, rfl⟩ := (Complex.riemannZeta_eq_zero_iff.mp hζ).resolve_right (fun h => hs h.1)
  have h1 : -2 * (n + (1 : ℂ)) ≠ 1 := by intro h; apply_fun Complex.re at h; simp at h; linarith
  have h2 : -2 * (n + (1 : ℂ)) ≠ 0 := by intro h; simp at h; linarith
  let f z := 2 * (2 * π) ^ (z - 1) * Complex.Gamma (1 - z) * riemannZeta (1 - z)
  have hf : DifferentiableAt ℂ f (-2 * (n + 1)) := by
    repeat (apply DifferentiableAt.mul)
    · exact differentiableAt_const _
    · apply DifferentiableAt.rpow differentiableAt_id (differentiableAt_const _) (Or.inr (by norm_num))
    · exact (Complex.differentiableAt_Gamma (by intro h; simp at h; linarith)).comp _ (differentiableAt_const _).sub_id
    · exact (differentiableAt_riemannZeta (by intro h; simp at h; linarith)).comp _ (differentiableAt_const _).sub_id
  rw [Filter.EventuallyEq.deriv_eq (eventually_of_mem ((isOpen_ne.mem_nhds h2).and (isOpen_ne.mem_nhds h1)) (fun z ⟨hz2, hz1⟩ => by
    rw [Complex.riemannZeta_reflection_equation z hz2 hz1, mul_assoc, mul_comm (Complex.sin _)]))]
  rw [deriv_mul hf (Complex.differentiableAt_sin.comp (differentiableAt_id.mul_const _)), mul_div_assoc, mul_div_cancel_left _ (by norm_num : (2 : ℂ) ≠ 0)]
  simp [Complex.sin_int_mul_pi (-(n + 1 : ℤ)), Complex.cos_int_mul_pi (-(n + 1 : ℤ))]
  repeat (apply mul_ne_zero)
  · norm_num
  · apply Complex.rpow_ne_zero; norm_num
  · apply Complex.Gamma_ne_zero; intro h; simp at h; linarith
  · apply Complex.riemannZeta_ne_zero_of_one_le_re; simp; linarith
  · norm_num
  · norm_num
