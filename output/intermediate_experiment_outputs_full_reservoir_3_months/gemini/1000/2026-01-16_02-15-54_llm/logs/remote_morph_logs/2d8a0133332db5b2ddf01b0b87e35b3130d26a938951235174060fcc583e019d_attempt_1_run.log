theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 := by
  intro s hcs hz
  have h_triv : ∃ n : ℕ, s = -2 * (n + 1) := by
    rw [Complex.riemannZeta_eq_zero_iff] at hz
    rcases hz with h_triv | ⟨h0, h1, hz⟩
    · exact h_triv
    · exfalso
      rw [CriticalStrip, Set.mem_setOf_eq, not_and_or, not_lt, not_lt] at hcs
      rcases hcs with hle | hge
      · exact Complex.riemannZeta_ne_zero_of_re_eq_zero (le_antisymm hle h0) hz
      · exact Complex.riemannZeta_ne_zero_of_one_le_re hge hz
  rcases h_triv with ⟨n, rfl⟩
  exact (Complex.hasOrderOf_riemannZeta_at_neg_two_mul_nat_add_one n).deriv_ne_zero rfl
```
