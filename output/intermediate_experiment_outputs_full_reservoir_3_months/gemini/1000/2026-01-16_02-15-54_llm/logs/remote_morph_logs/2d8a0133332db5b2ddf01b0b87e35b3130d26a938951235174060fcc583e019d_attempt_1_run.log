theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 := by
  intro s hs hz
  obtain ⟨n, rfl⟩ : ∃ n, s = -2 * (n + 1) := by
    simpa [CriticalStrip, hs, hz] using Complex.riemannZeta_eq_zero_iff (s := s)
  let k : ℂ := n + 1
  have hf : HasDerivAt (fun z => Complex.sin (↑Real.pi * z / 2)) ((-1 : ℂ) ^ (n + 1) * ↑Real.pi / 2) (-2 * k) := by
    convert (HasDerivAt.sin ((hasDerivAt_id _).const_mul ↑Real.pi).div_const).using_parameters
    simp [Complex.cos_nat_mul_pi, mul_comm]
  have hg : DifferentiableAt ℂ (fun z => 2 * (2 * ↑Real.pi) ^ (z - 1) * Complex.Gamma (1 - z) * riemannZeta (1 - z)) (-2 * k) := by
    apply DifferentiableAt.mul
    · apply DifferentiableAt.mul
      · apply DifferentiableAt.const_mul; apply Complex.differentiableAt_cpow_const_base; right; norm_num [Real.pi_pos.ne']
      · apply DifferentiableAt.comp; apply Complex.differentiableAt_Gamma; · intro m; simp [k]; linarith; · apply differentiableAt_const_sub
    · apply DifferentiableAt.comp; apply Complex.differentiableAt_riemannZeta; · simp [k]; linarith; · apply differentiableAt_const_sub
  have h_all := hf.mul hg.hasDerivAt
  rw [show (fun z => Complex.sin (↑Real.pi * z / 2) * (2 * (2 * ↑Real.pi) ^ (z - 1) * Complex.Gamma (1 - z) * riemannZeta (1 - z))) = riemannZeta from funext fun z => by rw [Complex.riemannZeta_eq_functional_equation, mul_comm, mul_assoc]] at h_all
  rw [h_all.deriv]
  repeat (apply mul_ne_zero)
  · apply pow_ne_zero; norm_num; norm_num
  · norm_num [Real.pi_pos.ne']
  · norm_num
  · apply Complex.cpow_ne_zero; norm_num [Real.pi_pos.ne']
  · apply Complex.Gamma_ne_zero; intro m; simp [k]; linarith
  · apply Complex.riemannZeta_ne_zero_of_re_gt_one; simp [k]; linarith
```
