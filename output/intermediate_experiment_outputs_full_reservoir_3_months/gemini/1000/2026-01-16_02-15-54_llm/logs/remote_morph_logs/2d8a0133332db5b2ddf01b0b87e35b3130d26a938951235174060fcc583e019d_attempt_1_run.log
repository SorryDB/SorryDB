theorem zeros_outside_critical_strip_are_simple :
  ∀ s : ℂ, ¬CriticalStrip s → riemannZeta s = 0 → deriv riemannZeta s ≠ 0 :=
by
  intros s hns hz
  have h_re : s.re ≤ 0 ∨ s.re ≥ 1 := by
    simpa [CriticalStrip] using hns
  rcases h_re with h_re_le_0 | h_re_ge_1
  · rcases h_re_le_0.lt_or_eq with h_lt_0 | h_eq_0
    · have ⟨n, hs⟩ := (riemannZeta_eq_zero_iff_of_re_lt_zero h_lt_0).mp hz
      rw [hs]
      -- The trivial zeros of the Riemann zeta function are all simple.
      -- This follows from the functional equation and the fact that the
      -- zeros of the sine function are simple.
      exact deriv_riemannZeta_neg_two_mul_nat_add_one_ne_zero n
    · exact (riemannZeta_ne_zero_of_re_eq_zero h_eq_0 hz).elim
  · exact (riemannZeta_ne_zero_of_one_le_re h_re_ge_1 hz).elim

end Millennium
```
