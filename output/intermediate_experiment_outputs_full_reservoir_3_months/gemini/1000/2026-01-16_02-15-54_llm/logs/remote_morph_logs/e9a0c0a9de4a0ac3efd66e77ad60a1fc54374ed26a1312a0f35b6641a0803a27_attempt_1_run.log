import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  let k := (a ^ 2 + b ^ 2) / (a * b + 1)
  have hk : a ^ 2 + b ^ 2 = k * (a * b + 1) := Nat.eq_mul_of_div_eq_right h₁ rfl
  let S := {x | ∃ y, 0 < x ∧ 0 < y ∧ x ^ 2 + y ^ 2 = k * (x * y + 1)}
  have hSa : a ∈ S := ⟨b, h₀.1, h₀.2, hk⟩
  let x := WellFounded.min Nat.lt_wfRel.wf S hSa
  obtain ⟨y, hx, hy, hxy⟩ := WellFounded.min_mem Nat.lt_wfRel.wf S hSa
  have hmin : ∀ {x' y'}, 0 < x' → 0 < y' → x' ^ 2 + y' ^ 2 = k * (x' * y' + 1) → x ≤ x' :=
    λ hx' hy' hxy' => WellFounded.not_lt_min Nat.lt_wfRel.wf S hSa ⟨_, hx', hy', hxy'⟩
  let y' : ℤ := k * x - y
  have : y' = 0 := by
    by_contra hy'0
    have hxy_le : x ≤ y := (lt_or_ge y x).elim (λ h => (hmin hy hx (by rwa [add_comm, mul_comm])).refl.elim h.not_le) id
    have hy'y : y' * y = x ^ 2 - k := by nlinarith [hxy]
    have hy'x : y' ^ 2 + x ^ 2 = k * (y' * x + 1) := by nlinarith [hxy]
    have : 0 < y' := by
      have : 1 ≤ k := Nat.le_of_dvd (by nlinarith) h₁
      by_contra!; have : x * y' + 1 ≤ 0 := by nlinarith [hx]; nlinarith [hy'x]
    lift y' to ℕ using (by linarith)
    have : y' < x := by nlinarith [hy'y, hxy_le]
    exact (hmin (by linarith) hx (by norm_cast)).not_lt this
  refine ⟨x, ?_⟩; have : x ^ 2 = k := by nlinarith [this, hxy]; rw [this, hk]; norm_cast; field_simp; ring
```
