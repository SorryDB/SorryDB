import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  let k := (a ^ 2 + b ^ 2) / (a * b + 1)
  have hk : a ^ 2 + b ^ 2 = k * (a * b + 1) := Nat.eq_mul_of_div_eq_right h₁ rfl
  have : ∃ x : ℕ, x ^ 2 = k := by
    let sums := { n | ∃ a₀ b₀ : ℕ, 0 < a₀ ∧ 0 < b₀ ∧ a₀ ^ 2 + b₀ ^ 2 = k * (a₀ * b₀ + 1) ∧ a₀ + b₀ = n ∧ b₀ ≤ a₀ }
    have h_sn : sums.Nonempty := by
      use max a b + min a b, max a b, min a b, Nat.max_pos h₀.1 h₀.2, Nat.min_pos h₀.1 h₀.2
      refine ⟨?_, rfl, Nat.min_le_max _ _⟩
      cases le_total a b with | inl h => simp [h, hk, add_comm, mul_comm] | inr h => simp [h, hk]
    obtain ⟨a₀, b₀, ha₀, hb₀, hk₀, rfl, hab₀⟩ := WellFounded.min_mem Nat.lt_wfRel.2 sums h_sn
    let x : ℤ := k * b₀ - a₀
    have hx1 : x ^ 2 - (k * b₀) * x + (b₀ ^ 2 - k) = 0 := by ring_nf; rw [←hk₀]; ring
    have hx2 : (a₀ : ℤ) * x = b₀ ^ 2 - k := by rw [←hk₀]; ring
    if hx0 : x = 0 then use b₀; rw [← Int.coe_nat_inj']; simp [hx0] at hx2; rw [hx2, sq]; ring
    else
      have hx_pos : 0 < x := by
        by_contra h_neg; push_neg at h_neg
        if hx_neg : x < 0 then
          have : (k : ℤ) = x^2 + b₀^2 + (k : ℤ) * b₀ * (-x) := by linarith
          have h1 : 1 ≤ x^2 := Int.one_le_sq_iff.mpr (by linarith)
          have h2 : 1 ≤ b₀^2 := by norm_cast; nlinarith
          have h3 : (k : ℤ) ≤ (k : ℤ) * (b₀ * (-x)) := by have : 1 ≤ b₀ * (-x) := by zify; nlinarith; nlinarith
          linarith
        else linarith
      obtain ⟨xn, hxn⟩ : ∃ n : ℕ, x = n := ⟨x.toNat, by rw [Int.toNat_of_nonneg (le_of_lt hx_pos)]⟩
      have hxn_pos : 0 < xn := by rwa [hxn] at hx_pos; norm_cast
      have h_sum : xn + b₀ < a₀ + b₀ := by
        zify [hxn]; apply (mul_lt_mul_left (by linarith : 0 < (a₀ : ℤ))).mp
        rw [hx2]; have : 0 < k := by
          have : 0 < a₀^2 + b₀^2 := by nlinarith
          rw [hk₀] at this; exact pos_of_mul_pos_right this (by nlinarith)
        calc (b₀ : ℤ) ^ 2 - k < (b₀ : ℤ) ^ 2 := by linarith
             _ ≤ (a₀ : ℤ) ^ 2 := by norm_cast; nlinarith
      have : xn + b₀ ∈ sums := by
        use max xn b₀, min xn b₀, Nat.max_pos hxn_pos hb₀, Nat.min_pos hxn_pos hb₀
        refine ⟨?_, by rw [Nat.max_add_min], Nat.min_le_max _ _⟩
        cases le_total xn b₀ with | inl h => simp [h]; norm_cast; rw [hxn] at hx1; nlinarith | inr h => simp [h]; norm_cast; rw [hxn] at hx1; nlinarith
      linarith [WellFounded.min_le Nat.lt_wfRel.2 sums h_sn this]
  obtain ⟨x, hx⟩ := this
  use x; rw [← hx]; have h_den : (↑a * ↑b + 1 : ℝ) ≠ 0 := by norm_cast; linarith
  rw [div_eq_iff h_den]; norm_cast; exact hk
