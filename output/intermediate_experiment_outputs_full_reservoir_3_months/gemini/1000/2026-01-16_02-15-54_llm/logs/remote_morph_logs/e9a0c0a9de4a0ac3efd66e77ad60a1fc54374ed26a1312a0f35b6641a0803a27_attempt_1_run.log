open BigOperators Real Nat Topology Rat

theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  let k := (a ^ 2 + b ^ 2) / (a * b + 1)
  have hk : a ^ 2 + b ^ 2 = k * (a * b + 1) := (Nat.div_eq_iff_mul_mod_eq_zero.mpr h₁).1
  let S := {m | ∃ n, 0 < m ∧ 0 < n ∧ m ^ 2 + n ^ 2 = k * (m * n + 1)}
  obtain ⟨m, n, hm, hn, hmk, hmin⟩ := WellFounded.min_mem_le isWellFounded_lt.wf S ⟨a, b, h₀.1, h₀.2, hk⟩
