  wlog hxy_le : y ≤ x generalizing x y
  · exact this y x hy hx (by rw [add_comm, hxy, mul_comm]) (by intro n hn; rw [add_comm]; exact hmin n hn) (le_of_not_le hxy_le)
  let x' : ℤ := (k : ℤ) * y - x
