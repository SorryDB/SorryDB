  have hx'2 : x' * x = (y : ℤ) ^ 2 - (k : ℤ) := by zify at hxy; rw [← hxy]; ring
  have h_k_y2 : (k : ℤ) = (y : ℤ) ^ 2 := by
    by_contra hk_not_sq
