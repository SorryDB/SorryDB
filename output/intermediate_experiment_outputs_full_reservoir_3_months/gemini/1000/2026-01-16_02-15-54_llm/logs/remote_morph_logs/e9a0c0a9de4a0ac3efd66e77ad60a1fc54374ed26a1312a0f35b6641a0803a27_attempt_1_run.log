import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  let k := (a ^ 2 + b ^ 2) / (a * b + 1)
  have hk : a ^ 2 + b ^ 2 = k * (a * b + 1) := Nat.mul_div_cancel' h₁
  suffices ∃ x : ℕ, k = x ^ 2 by
    rcases this with ⟨x, rfl⟩; use x
    rw [← Nat.cast_div h₁ (by linarith), k]; simp
  let S := {p : ℕ × ℕ | 0 < p.1 ∧ 0 < p.2 ∧ p.1 ^ 2 + p.2 ^ 2 = k * (p.1 * p.2 + 1)}
  let wf := (Nat.lt_wfRel.invImage (fun p : ℕ × ℕ => p.1 + p.2)).wf
  let p := WellFounded.min wf S ⟨(a, b), h₀, hk⟩
  obtain ⟨A, B⟩ := p
  have hS : (A, B) ∈ S := WellFounded.min_mem wf S ⟨(a, b), h₀, hk⟩
  have hmin : ∀ p ∈ S, A + B ≤ p.1 + p.2 := fun p hp => WellFounded.not_lt_min wf S ⟨(a, b), h₀, hk⟩ hp
  obtain ⟨hA, hB, hAB⟩ := hS
  wlog hBA : B ≤ A generalizing A B
  · rw [add_comm, mul_comm] at hAB; exact this B A hB hA hAB (fun p hp => hmin (p.2, p.1) (by rwa [add_comm, mul_comm])) (le_of_not_le hBA)
  let x₂ : ℤ := k * B - A
  have hx₂₁ : x₂ * A = B ^ 2 - k := by zify at hAB; nlinarith
  have hx₂₂ : x₂ ^ 2 + B ^ 2 = k * (x₂ * B + 1) := by zify at hAB; nlinarith
  if hx₂ : x₂ = 0 then
    use B; zify at hx₂₁; rw [hx₂] at hx₂₁; linarith
  else
    have hx₂_pos : 0 < x₂ := by
      by_contra!; have : x₂ * B + 1 ≤ 0 := by nlinarith
      have : x₂ ^ 2 + B ^ 2 ≤ 0 := by nlinarith
      nlinarith
    have hx₂_lt : x₂ < A := by nlinarith
    have hS' : (x₂.toNat, B) ∈ S := ⟨by zify; linarith, hB, by zify; simpa using hx₂₂⟩
    exact (hmin (x₂.toNat, B) hS' (by zify; linarith)).absurd (by linarith)
