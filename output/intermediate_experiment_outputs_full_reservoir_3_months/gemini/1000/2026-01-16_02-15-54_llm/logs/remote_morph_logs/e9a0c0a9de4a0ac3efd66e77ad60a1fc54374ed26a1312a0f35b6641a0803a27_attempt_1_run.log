theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  let k := (a ^ 2 + b ^ 2) / (a * b + 1)
  have hk : (↑a ^ 2 + ↑b ^ 2 : ℝ) / (↑a * ↑b + 1) = ↑k := by
    rw [← Nat.cast_div h₁ (a * b + 1), Nat.cast_inj]
  suffices ∃ x : ℕ, x ^ 2 = k by obtain ⟨x, hx⟩ := this; use x; rw [hk, ← hx, Nat.cast_pow]
  let S := {n | n > 0 ∧ ∃ m > 0, n ^ 2 + m ^ 2 = k * (n * m + 1)}
  have ha : a ∈ S := ⟨h₀.1, b, h₀.2, by rw [Nat.div_mul_cancel h₁]⟩
  obtain ⟨A, ⟨hA, B, hB, hAB⟩, hmin⟩ := WellFounded.has_min Nat.lt_wfRel.wf S ⟨a, ha⟩
  have hAB' : A ≤ B := by
    by_contra h; exact hmin B ⟨hB, A, hA, by rwa [add_comm, mul_comm]⟩ (not_le.1 h)
  let x : ℤ := k * A - B
  have hk' : (A : ℤ) ^ 2 + (B : ℤ) ^ 2 = k * (A * B + 1) := by push_cast; exact hAB
  if hx0 : x = 0 then
    exact ⟨A, by nlinarith [hx0, hk']⟩
  else if hx_pos : 0 < x then
    let xn := x.toNat; have hxn : 0 < xn := Int.toNat_pos.2 hx_pos
    have hxnS : xn ∈ S := ⟨hxn, A, hA, by push_cast; rw [Int.toNat_of_nonneg (le_of_lt hx_pos)]; nlinarith [hk']⟩
    exact (hmin xn hxnS (by rw [← Int.ofNat_lt, Int.toNat_of_nonneg (le_of_lt hx_pos)]; nlinarith [hk'])).elim
  else
    have : 0 < k := by nlinarith [hk']
    nlinarith [hk']
