  by_cases hsq : ∃ x, k = x ^ 2
  · obtain ⟨x, hx⟩ := hsq; use x; rw [← Nat.cast_pow, hx, Nat.cast_div h₁ (by positivity)]
  exfalso
  let m' : ℤ := k * n - m
  have hm'0 : 0 < m' := by
    by_contra! h'; have : m' ^ 2 + n ^ 2 = k * (m' * n + 1) := by nlinarith [hmk]
    if h0 : m' = 0 then exact hsq ⟨n, by nlinarith [h0, this]⟩
    else have : m' * n + 1 ≤ 0 := by nlinarith [this]; nlinarith
  have hm'm : m' < m := by
    have : m' * m = (n : ℤ) ^ 2 - k := by nlinarith [hmk]
    have : m' * m < (m : ℤ) * m := by nlinarith [hm, hn]
    exact (mul_lt_mul_right (by positivity)).mp this
  refine hm'm.not_le (hmin m'.toNat n (by nlinarith) hn ?_)
  apply (Int.cast_inj (R := ℤ)).mp; norm_cast; rwa [Int.toNat_of_nonneg (by nlinarith)]; nlinarith [hmk]
