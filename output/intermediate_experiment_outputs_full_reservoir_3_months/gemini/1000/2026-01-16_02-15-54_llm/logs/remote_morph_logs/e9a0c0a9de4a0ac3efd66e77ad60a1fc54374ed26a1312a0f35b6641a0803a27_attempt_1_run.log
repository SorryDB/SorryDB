  let S := {p : ℕ × ℕ | 0 < p.1 ∧ 0 < p.2 ∧ p.1 ^ 2 + p.2 ^ 2 = k * (p.1 * p.2 + 1)}
  let wf := WellFounded.measure (fun p : ℕ × ℕ => p.1 + p.2)
  let ⟨A, B⟩ := wf.min S ⟨(a, b), ⟨h₀.1, h₀.2, h_eq⟩⟩
