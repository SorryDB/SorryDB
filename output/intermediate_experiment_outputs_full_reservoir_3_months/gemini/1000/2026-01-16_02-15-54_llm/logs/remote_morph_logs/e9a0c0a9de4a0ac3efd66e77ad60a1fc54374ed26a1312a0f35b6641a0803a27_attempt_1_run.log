import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  wlog hba : b ≤ a generalizing a b h₀ h₁
  · obtain ⟨x, hx⟩ := this b a ⟨h₀.2, h₀.1⟩ (by rwa [add_comm, mul_comm]) (le_of_not_le hba)
    rw [add_comm, mul_comm] at hx; exact ⟨x, hx⟩
  let k := (a ^ 2 + b ^ 2) / (a * b + 1)
  let S := {p : ℕ × ℕ | 0 < p.1 ∧ 0 < p.2 ∧ p.1 ^ 2 + p.2 ^ 2 = k * (p.1 * p.2 + 1)}
  obtain ⟨⟨x, y⟩, ⟨hx, hy, hxy⟩, hmin⟩ :=
    WellFounded.has_min wellFounded_lt (fun p => p.1 + p.2) ⟨(a, b), h₀.1, h₀.2, Nat.div_mul_cancel h₁⟩
  have hle : y ≤ x := by
    by_contra hlt; exact (hmin ⟨y, x⟩ ⟨hy, hx, by rwa [add_comm, mul_comm]⟩ (by rwa [add_comm])).absurd (not_le.1 hlt)
  set x' : ℤ := (k : ℤ) * y - x
  have hx'eq : x' ^ 2 + (y : ℤ) ^ 2 = k * (x' * y + 1) := by nlinarith
  obtain ⟨n, hn⟩ : ∃ n : ℕ, n ^ 2 = k := by
    if hx'0 : x' = 0 then ⟨y, by nlinarith⟩
    else if hx'pos : 0 < x' then
      have : x' < x := by
        have : (k : ℤ) > 0 := by { have : (x : ℤ) ^ 2 + (y : ℤ) ^ 2 = k * (x * y + 1) := by norm_cast; nlinarith }
        have : x' * x = (y : ℤ) ^ 2 - k := by nlinarith
        nlinarith
      exact (hmin ⟨x'.toNat, y⟩ ⟨by linarith, hy, by nlinarith⟩ (by linarith)).absurd
    else
      have : x' * (y : ℤ) + 1 ≤ 0 := by nlinarith
      nlinarith
  exists n; rw [← hn, Nat.cast_pow, ← Nat.cast_div h₁ (by linarith)]
