  have hxyS : (x, y) ∈ S := by rcases WellFounded.min_mem (measure (fun p => p.1 + p.2)).wf S ⟨a, b, h₀.1, h₀.2, hk⟩ with ⟨h1, h2, h3⟩; exact ⟨by linarith, by linarith, by dsimp [x, y]; split_ifs <;> [rwa [add_comm, mul_comm] at *; assumption]⟩
  obtain ⟨hx_pos, hy_pos, hxy_eq⟩ := hxyS
  let x' : ℤ := k * y - x
  have hx' : x' ^ 2 + (y : ℤ) ^ 2 = k * (x' * y + 1) ∧ x' * x = (y : ℤ) ^ 2 - k := by
    have : (x : ℤ) ^ 2 + (y : ℤ) ^ 2 = k * (x * y + 1) := by norm_cast
