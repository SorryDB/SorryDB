    refine Set.Infinite.mono (λ a ha => ⟨ha, ?_⟩) (Set.infinite_range_of_injective (λ n => (n + 1 : ℤ)) (λ _ _ h => Int.ofNat.inj h))
    ring_nf; rw [pow_succ, pow_succ, pow_succ]
