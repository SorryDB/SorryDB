import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := {(5, 3)}

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro rfl
    refine Set.infinite_of_forall_mem_atTop (fun b => ⟨Int.natAbs b + 1, ?_⟩)
    · constructor
      · exact Int.abs_natAbs _ ▸ Int.pos_of_ne_zero (by linarith)
      · use ((b + 1) ^ 2 - (b + 1) + 1)
        simp only [Int.ofNat_succ, Int.ofNat_ofNat, Int.natAbs_of_nonneg (by linarith)]
        ring
  · intro h
    have h_poly : (X : ℚ[X]) ^ n + X ^ 2 - 1 ∣ X ^ m + X - 1 := by
      let P : ℤ[X] := X ^ m + X - 1
      let Q : ℤ[X] := X ^ n + X ^ 2 - 1
      have hQ : Q.Monic := monic_X_pow_add_X_pow_add_C (by simp; omega) (by norm_num) (by norm_num)
      have h_div : ∀ᶠ a : ℤ in Filter.atTop, (Q.eval a) ∣ (P.eval a) := by
        obtain ⟨S, hS_inf, hS_subset⟩ := h
        refine Filter.eventually_atTop.mpr ⟨1, fun a ha => ?_⟩
        by_cases has : a ∈ {a | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1}
        · exact has.2
        · obtain ⟨x, hx_S, hx_gt⟩ := hS_inf.exists_gt a
          have : (Q.eval x) ∣ (P.eval x) := (hS_subset hx_S).2
          sorry -- Standard result: if Q(a) | P(a) for infinitely many a, then Q | P
    have r : ℝ := rootOf (X ^ n + X ^ 2 - 1) 0 1 (by simp) (by simp)
    have : r ^ n + r ^ 2 - 1 = 0 := by exact (rootOf_is_root _ _ _).2
    have : r ^ m + r - 1 = 0 := by
      have : (X ^ n + X ^ 2 - 1 : ℚ[X]).eval r = 0 := by sorry
      have : (X ^ m + X - 1 : ℚ[X]).eval r = 0 := by sorry
      exact this
    have : r ^ n = 1 - r ^ 2 ∧ r ^ m = 1 - r := by constructor <;> linarith
    have : r ^ n = (1 - r) * (1 + r) := by linarith
    have : r ^ n = r ^ m * (1 + r) := by linarith
    have : 1 = r ^ (m - n) + r ^ (m - n + 1) := by sorry
    have : m - n = 2 ∧ n = 3 := by sorry
    simp [this]
```
