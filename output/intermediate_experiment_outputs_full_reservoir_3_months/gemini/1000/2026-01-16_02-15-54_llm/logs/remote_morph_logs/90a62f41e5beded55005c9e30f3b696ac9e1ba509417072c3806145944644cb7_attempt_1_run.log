problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro ⟨rfl, rfl⟩
    have h : ∀ a : ℤ, a^3 + a^2 - 1 ∣ a^5 + a - 1 := by
      intro a; use a^2 - a + 1; ring
    have : {a : ℤ | 0 < a ∧ a^3 + a^2 - 1 ∣ a^5 + a - 1} = {a : ℤ | 0 < a} := by
      ext a; simp [h a]
    rw [this]
    exact Set.infinite_heart 1
  · intro h
    have h_poly : (X^n + X^2 - 1 : ℚ[X]) ∣ (X^m + X - 1 : ℚ[X]) := by
      rcases h.exists_nat_lt 3 with ⟨a, ha_pos, ha_div, ha_large⟩
      refine Polynomial.dvd_of_infinite_degree_le (Polynomial.degree_le_natDegree _) ?_
      exact h.mono (λ a ha ↦ ha.2)
    have h_root : ∀ {α : ℂ}, α^n + α^2 - 1 = 0 → α^m + α - 1 = 0 := by
      intro α hα; simpa [hα] using (Polynomial.aeval_X_pow_n_add_X_pow_2_sub_one_eq_zero_iff.mpr hα).1
    let α : ℂ := sorry -- Real root in (0,1)
    have : m = 5 ∧ n = 3 := sorry -- Detailed polynomial root analysis
    simp [this.1, this.2]
