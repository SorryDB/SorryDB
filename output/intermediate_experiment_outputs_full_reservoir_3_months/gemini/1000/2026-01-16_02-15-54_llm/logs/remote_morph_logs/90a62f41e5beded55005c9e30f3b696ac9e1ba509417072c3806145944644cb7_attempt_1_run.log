import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  rw [solution, Set.mem_singleton_iff, Prod.mk.inj_iff]
  refine ⟨fun ⟨hm, hn⟩ ↦ hm.symm ▸ hn.symm ▸ Set.infinite_of_forall_mem (a := 1) fun a ha ↦ by
    rw [sq, ← pow_two]; refine ⟨ha, ?_⟩
    ring_nf; exact dvd_mul_right _ _, fun h ↦ ?_⟩
  have hpoly : (X ^ n + X ^ 2 - 1 : ℚ[X]) ∣ (X ^ m + X - 1 : ℚ[X]) := by
    exact PolyDvd.of_infinite_int_dvd (h.mono fun a ⟨ha, hdiv⟩ ↦ hdiv)
  have hzero : (X ^ n + X ^ 2 - 1 : ℚ[X]).eval (Set.univ.minᵣ (fun x ↦ if 0 < x ∧ x < 1 then (x^n + x^2 - 1 : ℚ) else 0) sorry) = 0 := sorry
  have : (m, n) = (5, 3) := sorry
  exact this
