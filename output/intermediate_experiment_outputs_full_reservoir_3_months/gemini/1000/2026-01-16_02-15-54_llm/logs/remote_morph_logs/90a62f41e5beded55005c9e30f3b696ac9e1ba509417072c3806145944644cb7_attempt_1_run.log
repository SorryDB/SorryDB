/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro rfl
    have h : ∀ a : ℤ, a ^ 3 + a ^ 2 - 1 ∣ a ^ 5 + a - 1 := by
      intro a
      convert dvd_mul_right (a ^ 3 + a ^ 2 - 1) (a ^ 2 - a + 1)
      ring
    exact Set.Infinite.mono (fun a ha ↦ ⟨ha.1, h a⟩) Set.infinite_pos_ints
  · intro h
    have h_dvd : (Polynomial.X ^ n + Polynomial.X ^ 2 - 1 : ℤ[X]) ∣ Polynomial.X ^ m + Polynomial.X - 1 :=
      Polynomial.dvd_of_infinite_int_dvd (Polynomial.X ^ n + Polynomial.X ^ 2 - 1)
        (Polynomial.X ^ m + Polynomial.X - 1) h
    let α := Complex.rootOfPolynomial (Polynomial.X ^ n + Polynomial.X ^ 2 - 1) 0 1
    have h_α : α ^ n + α ^ 2 - 1 = 0 := by
      have := Complex.isRoot_rootOfPolynomial (Polynomial.X ^ n + Polynomial.X ^ 2 - 1 : ℤ[X]) (by simp; ring_nf; linarith)
      sorry
    have h_α2 : α ^ m + α - 1 = 0 := sorry
    have h_m_n : (5, 3) = (m, n) := sorry
    simp [← h_m_n]

