/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro ⟨h5, h3⟩; rw [h5, h3]
    have h : ∀ a : ℤ, a ^ 3 + a ^ 2 - 1 ∣ a ^ 5 + a - 1 := fun a ↦ by
      have : a^5 + a - 1 = (a^3 + a^2 - 1) * (a^2 - a + 1) := by ring
      exact ⟨a^2 - a + 1, this⟩
    have h_inf : {a : ℤ | 0 < a ∧ a ^ 3 + a ^ 2 - 1 ∣ a ^ 5 + a - 1}.Infinite := by
      have : {a : ℤ | 0 < a} ⊆ {a : ℤ | 0 < a ∧ a ^ 3 + a ^ 2 - 1 ∣ a ^ 5 + a - 1} :=
        fun a ha ↦ ⟨ha, h a⟩
      exact Set.Infinite.mono this (Set.infinite_positive_integers)
    exact h_inf
  · intro h; contrapose! h
    sorry

