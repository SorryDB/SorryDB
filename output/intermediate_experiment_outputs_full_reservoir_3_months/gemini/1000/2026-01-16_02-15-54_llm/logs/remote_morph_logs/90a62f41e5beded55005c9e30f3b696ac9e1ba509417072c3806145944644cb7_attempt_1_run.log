/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro rfl
    have h : ∀ a : ℤ, a ^ 5 + a - 1 = (a ^ 2 - a + 1) * (a ^ 3 + a ^ 2 - 1) := by intro a; ring
    apply Set.Infinite.mono (fun a ha => _) (Set.infinite_positive_integers)
    rw [h, Int.mul_div_cancel_right]
    · apply Int.dvd_mul_left
    · intro h0; exact (by linarith [ha] : a ^ 3 + a ^ 2 - 1 ≠ 0)
  · intro h
    have h_poly : (X ^ n + X ^ 2 - 1 : ℚ[X]) ∣ (X ^ m + X - 1 : ℚ[X]) := by
      refine poly_dvd_of_dvd_at_infinite (L := ℤ) ?_ h
      intro a; simp only [Int.cast_sub, Int.cast_pow, Int.cast_one, Int.cast_add]
    have h_pos : ∃! x : ℝ, 0 < x ∧ x ^ n + x ^ 2 - 1 = 0 := by
      refine ⟨_, ⟨?_, ?_⟩, ?_⟩
      · have f := fun x : ℝ => x ^ n + x ^ 2 - 1
        have : f 0 = -1 ∧ f 1 = 1 := by simp; norm_num; positivity
        exact exists_root_interval_continuous continuous_id.pow.add (continuous_id.pow.add continuous_const) 0 1 (by linarith) (by linarith)
      · rintro x ⟨hx_pos, hx_root⟩ y ⟨hy_pos, hy_root⟩
        have f := fun z : ℝ => z ^ n + z ^ 2 - 1
        have h' : StrictMonoOn f (Set.Ici 0) := by
          intro a ha b hb hab; dsimp [f]; mono
        exact h'.injective (by linarith) (by linarith) (by linarith)
    obtain ⟨α, ⟨hα_pos, hα_root⟩, _⟩ := h_pos
    have hα_root_g : α ^ m + α - 1 = 0 := by
      have := Polynomial.aeval_def (X ^ m + X - 1 : ℚ[X]) α
      rw [← Polynomial.mod_eq_zero_of_dvd h_poly] at this; simp at this; exact this
    have hα_lt_1 : α < 1 := by
      have f := fun x : ℝ => x ^ n + x ^ 2 - 1
      if h : α < 1 then exact h else
        have : α ≥ 1 := by linarith
        have : f α ≥ f 1 := by apply (StrictMonoOn.monotoneOn (fun x hx => by dsimp [f]; mono) (Set.Ici 0)).2 <;> simp [*]
        linarith
    have h_alpha : α ^ n = 1 - α ^ 2 ∧ α ^ m = 1 - α := by constructor <;> linarith
    have h_eq : α ^ n = α ^ m * (1 + α) := by rw [h_alpha.2, ← mul_one_sub_pow_two α, h_alpha.1]
    have h_eq2 : α ^ (n - m : ℤ) = 1 + α := by
      rw [← mul_inv_congr α (by linarith), ← zpow_natCast, ← zpow_natCast, ← zpow_sub₀ (by linarith)] at h_eq; exact h_eq
    have h_m_gt_n : m > n := by
      if hmn : n ≥ m then
        have : α ^ (n - m) ≤ 1 := by apply zpow_le_one_of_nonneg_of_le_one <;> linarith
        linarith
      else linarith
    let k := m - n
    have h_final : α ^ k + α ^ (k + 1) = 1 := by
      rw [← zpow_natCast, ← zpow_natCast, ← h_eq2, zpow_neg, inv_add_one_eq_inv (by linarith), inv_inv] at *; ring_nf; sorry
    have : n = 3 ∧ m = 5 := by sorry
    simp [this]
