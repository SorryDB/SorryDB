namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro rfl
    refine Set.Infinite.mono (fun a ha => ?_) Set.infinite_nat
    have ha' : (a : ℤ) ^ 3 + (a : ℤ) ^ 2 - 1 ∣ (a : ℤ) ^ 5 + (a : ℤ) - 1 := by
      use a ^ 2 - a + 1
      ring
    exact ⟨ha, ha'⟩
  · intro h
    have h_div : (X : ℚ[X]) ^ n + X ^ 2 - 1 ∣ X ^ m + X - 1 := by
      obtain ⟨a, ha_pos, ha_div⟩ := h.exists_nat_gt 2
      apply Polynomial.divisibility_of_infinite_values
      · exact h.mono (fun x hx => hx.2)
    have h_root : ∀ {z : ℂ}, z ^ n + z ^ 2 - 1 = 0 → z ^ m + z - 1 = 0 := fun hz => by
      have : (X : ℂ[X]) ^ n + X ^ 2 - 1 ∣ X ^ m + X - 1 := by
        exact_mod_cast h_div
      simpa [hz] using Polynomial.eval_X_pow (n := m) ▸ Polynomial.eval_X (R := ℂ) ▸
        (Polynomial.eval_pow (X : ℂ[X]) m z).symm ▸ (Polynomial.eval_X (R := ℂ) z).symm ▸
        Polynomial.eval_sub (X ^ m + X) 1 z ▸ Polynomial.eval_add (X ^ m) X z ▸ hz
    have ⟨α, hα_pos, hα_root⟩ : ∃ x ∈ Set.Ioo 0 1, x ^ n + x ^ 2 - 1 = 0 := by
      have f : ℝ → ℝ := fun x => x ^ n + x ^ 2 - 1
      have h0 : f 0 = -1 := by simp [f]
      have h1 : f 1 = 1 := by simp [f]
      obtain ⟨x, hx0, hx1, hxf⟩ := intermediate_value_interval h0.le h1.le
      refine ⟨x, ⟨hx0, hx1⟩, ?_⟩
      · exact_mod_cast hxf
    have hα_m : α ^ m = 1 - α := by simpa using h_root (by exact_mod_cast hα_root)
    have hα_n : α ^ n = 1 - α ^ 2 := by exact_mod_cast hα_root
    have h_kn : α ^ n = α ^ m * (1 + α) := by rw [hα_n, hα_m]; ring
    have h_k : α ^ (m - n) = (1 + α)⁻¹ := by
      have : n < m := by
        by_contra! hnm
        have : α ^ n ≤ α ^ m := pow_le_pow_of_le_one hα_pos.1 hα_pos.2.le hnm
        rw [hα_n, hα_m] at this
        linarith [hα_pos.1, hα_pos.2]
      rw [pow_sub₀ _ (by linarith) this] at h_kn
      · field_simp at h_kn; exact h_kn
    have h_m_n : m - n = 2 ∧ n = 3 := by
      let k := m - n
      have hk : α ^ (k + 1) + α ^ k - 1 = 0 := by
        rw [h_k]; field_simp; ring
      have h_f : ∀ {j : ℕ}, (Set.Ioo (0 : ℝ) 1).InjOn (fun x => x ^ (j + 1) + x ^ j - 1) :=
        fun j x hx => by dsimp; linarith [hx.1]
      have : k = 2 ∧ n = 3 := by
        have root_g : α ^ n + α ^ 2 - 1 = 0 := by exact_mod_cast hα_root
        have root_f : α ^ (k + 1) + α ^ k - 1 = 0 := by exact_mod_cast hk
        if hk2 : k = 2 then
          rw [hk2] at root_f
          have : n = 3 := by
            by_contra! hn3
            if hn : n < 3 then
              have : α ^ 3 + α ^ 2 - 1 < α ^ n + α ^ 2 - 1 := by
                rw [pow_strict_mono_right hα_pos.1 hα_pos.2 hn]; linarith
              linarith
            else
              have : α ^ n + α ^ 2 - 1 < α ^ 3 + α ^ 2 - 1 := by
                rw [pow_strict_mono_right hα_pos.1 hα_pos.2 (lt_of_le_of_ne hn hn3.symm)]; linarith
              linarith
          exact ⟨hk2, this⟩
        else
          exfalso
          have hx : ∀ {j : ℕ}, ∃! x ∈ Set.Ioo (0 : ℝ) 1, x ^ (j + 1) + x ^ j - 1 = 0 := fun j => by
            refine ⟨_, ⟨?_, ?_⟩, ?_⟩
            · exact intermediate_value_Ioo (by simp) (by simp) (by dsimp; linarith)
          obtain ⟨β, hβ_mem, hβ_root⟩ := hx 2
          obtain ⟨γ, hγ_mem, hγ_root⟩ := hx k
          linarith
    simp [h_m_n.1, h_m_n.2]

