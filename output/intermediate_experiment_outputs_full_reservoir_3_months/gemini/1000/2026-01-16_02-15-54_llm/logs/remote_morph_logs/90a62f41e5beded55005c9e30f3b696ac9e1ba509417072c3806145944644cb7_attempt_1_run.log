import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := {(5, 3), (2, 1)}

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro (⟨h5, h3⟩ | ⟨h2, h1⟩)
    · rw [h5, h3]
      have : ∀ a : ℤ, a ^ 3 + a ^ 2 - 1 ∣ a ^ 5 + a - 1 := by
        intro a; ring_nf
        rw [show a ^ 5 + a - 1 = (a ^ 3 + a ^ 2 - 1) * (a ^ 2 - a + 1) by ring]
        apply dvd_mul_right
      exact Set.infinite_val ℤ
        (show Set.Infinite {a : ℤ | 0 < a} by exact Set.infinite_Ioi 0)
        (fun a ha => this a)
    · rw [h2, h1]
      have : ∀ a : ℤ, a ^ 1 + a ^ 2 - 1 ∣ a ^ 2 + a - 1 := by
        intro a; rw [add_comm, add_comm a]
      exact Set.infinite_val ℤ
        (show Set.Infinite {a : ℤ | 0 < a} by exact Set.infinite_Ioi 0)
        (fun a ha => this a)
  · intro h
    have h_div : Polynomial.X ^ n + Polynomial.X ^ 2 - 1 ∣ Polynomial.X ^ m + Polynomial.X - 1 := by
      revert h; exact_mod_cast Polynomial.dvd_of_infinite_int_roots_left_right (Polynomial.X ^ n + Polynomial.X ^ 2 - 1) (Polynomial.X ^ m + Polynomial.X - 1)
    have : ∀ z : ℂ, z ^ n + z ^ 2 - 1 = 0 → z ^ m + z - 1 = 0 := by
      intro z hz
      have h_eval := Polynomial.eval_zmod_poly_id h_div z
      simpa [hz] using h_eval
    let α : ℂ := Polynomial.rootOf (Polynomial.X ^ n + Polynomial.X ^ 2 - 1) 0 1
    have hα : α ^ n = 1 - α ^ 2 := by sorry
    have hαm : α ^ m = 1 - α := by sorry
    sorry

```
