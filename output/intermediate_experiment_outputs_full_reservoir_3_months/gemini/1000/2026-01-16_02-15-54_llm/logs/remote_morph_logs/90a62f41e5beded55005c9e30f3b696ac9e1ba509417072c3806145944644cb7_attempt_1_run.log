import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro ⟨rfl, rfl⟩
    have h : ∀ a : ℤ, a ^ 3 + a ^ 2 - 1 ∣ a ^ 5 + a - 1 := fun a ↦ ⟨a ^ 2 - a + 1, by ring⟩
    exact Set.Infinite.mono (fun a ha ↦ ⟨ha, h a⟩) (Set.infinite_pos_iff_infinite_int.mpr Int.infinite_range_pos)
  · intro h
    have h_poly : (Polynomial.X ^ n + Polynomial.X ^ 2 - 1 : ℤ[Polynomial.X]) ∣ (Polynomial.X ^ m + Polynomial.X - 1) := by
      refine Polynomial.dvd_of_infinite_degree_lt_dvd ?_
      simp only [Set.Infinite, Set.nmem_setOf_iff, not_not] at h
      exact h
    have h_root : ∀ {z : ℂ}, z ^ n + z ^ 2 - 1 = 0 → z ^ m + z - 1 = 0 := by
      intro z hz
      have : Polynomial.IsRoot (Polynomial.X ^ n + Polynomial.X ^ 2 - 1) z := by simp [hz, Polynomial.IsRoot]
      have : Polynomial.IsRoot (Polynomial.X ^ m + Polynomial.X - 1) z := Polynomial.IsRoot.of_dvd this (Polynomial.map (Int.castRingHom ℂ) h_poly)
      simpa [Polynomial.IsRoot] using this
    have h_α : ∃ α : ℝ, 0 < α ∧ α < 1 ∧ α ^ n + α ^ 2 - 1 = 0 := by
      have f : ℝ → ℝ := fun x ↦ x ^ n + x ^ 2 - 1
      have : f 0 < 0 := by simp [f]; linarith
      have : f 1 > 0 := by simp [f]; linarith
      obtain ⟨α, ⟨h0, h1⟩, hα⟩ := exists_intermediate_value_zero continuous_id.pow.add (continuous_id.pow.add continuous_const) this (by linarith)
      exact ⟨α, h0, h1, hα⟩
    obtain ⟨α, hα0, hα1, hαn⟩ := h_α
    have hαm : (α : ℂ) ^ m + (α : ℂ) - 1 = 0 := h_root (by simp [hαn])
    have : α ^ n = 1 - α ^ 2 ∧ α ^ m = 1 - α := by simpa using ⟨hαn, hαm⟩
    have : α ^ n = (1 - α) * (1 + α) := by rw [this.1]; ring
    have : α ^ n = α ^ m * (1 + α) := by rw [this, ← ‹α ^ m = 1 - α›]
    have : 1 = α ^ (m - n) * (1 + α) := by
      have : n < m := by
        by_contra! hnm; have : α ^ n ≥ α ^ m := pow_le_pow_of_le_one hα0.le hα1.le hnm
        linarith [this, α ^ n, α ^ m, (1 - α) * (1 + α), 1 - α, hα0, hα1]
      rw [this, pow_sub₀ _ hα0.ne'] at ‹α ^ n = α ^ m * (1 + α)›; field_simp at ‹α ^ n = α ^ m * (1 + α)›; exact ‹α ^ n = α ^ m * (1 + α)›.symm
    have k_eq : m - n = 2 := by
      let k := m - n; have : α ^ k + α ^ (k + 1) = 1 := by simpa [add_mul] using ‹1 = α ^ (m - n) * (1 + α)›
      have : α ^ n + α ^ 2 = 1 := by linarith
      if hk : k = 1 then
        subst hk; linarith [pow_le_pow_of_le_one hα0.le hα1.le (show 1 ≤ n from by linarith)]
      else if hk2 : k = 2 then
        rwa [hk2] at ‹α ^ k + α ^ (k + 1) = 1›; linarith [‹α ^ n + α ^ 2 = 1›, ‹α ^ 2 + α ^ 3 = 1›]
      else
        have : k ≥ 3 := by omega
        have : α ^ k + α ^ (k + 1) < α ^ 2 + α ^ 3 := by
          apply add_lt_add <;> apply pow_lt_pow_of_lt_left hα1 <;> linarith
        linarith [‹α ^ n + α ^ 2 = 1›, ‹α ^ k + α ^ (k + 1) = 1›]
    simp [k_eq, k_eq.symm] at *; omega

