lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  by_cases hY : Y.Finite
  · refine sSup_le (fun n ⟨M, hM, hn⟩ ↦ ?_)
    subst hn
    let H := G - Y
    let MH := M ∩ E(H)
    let MY := M \ E(H)
    have hMH : H.IsMatching MH := ⟨fun e he ↦ he.2, fun e f he hf ↦ hM.disjoint he.1 hf.1⟩
    have h_diff : (V(H) \ V(H, MH)).encard ≥ H.OddComponents.encard := by
      refine encard_le_encard_of_injOn (fun C ↦ (V(C) \ V(H, MH)).nonempty.some) ?_ ?_
      · rintro C ⟨hC, -⟩; have := hC.odd; sorry
      · rintro C1 C2 ⟨hC1, -⟩ ⟨hC2, -⟩ hne; sorry
    have h_MY : MY.encard ≤ (Y ∩ V(G)).encard := by
      refine encard_le_encard_of_injOn (fun e ↦ (V(G, e.1) ∩ Y).nonempty.some) ?_ ?_
      · rintro e ⟨heM, heH⟩; have := hM.subset heM; sorry
      · rintro e f ⟨heM, heH⟩ ⟨hfM, hfH⟩ hne; sorry
    calc 2 * M.encard = 2 * (MH.encard + MY.encard) := by rw [encard_inter_add_encard_diff M E(H)]
      _ = 2 * MH.encard + 2 * MY.encard := by rw [left_distrib]
      _ ≤ (V(H).encard - H.OddComponents.encard) + 2 * MY.encard := by
        gcongr; rw [← MH.toIsMatching.encard_V, add_comm]; exact le_tsub_of_add_le h_diff
      _ ≤ (V(G).encard - (Y ∩ V(G)).encard - H.OddComponents.encard) + 2 * (Y ∩ V(G)).encard := by
        gcongr; exact h_MY
      _ = V(G).encard + (Y ∩ V(G)).encard - H.OddComponents.encard := by sorry
      _ ≤ V(G).encard + Y.encard - H.OddComponents.encard := by gcongr; exact encard_mono (inter_subset_left _ _)
  · simp [hY, encard_infinite hY]
