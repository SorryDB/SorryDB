lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  rw [tsub_le_iff_right, add_comm]
  refine sSup_le (fun n ⟨M, hM, hn⟩ ↦ ?_)
  rw [hn, ← add_assoc]
  have h_odd : ∀ C ∈ (G - Y).OddComponents, (V(C) \ V(G, M)).Nonempty ∨ ∃ e ∈ M, (V(G, e) ∩ V(C)).Nonempty ∧ (V(G, e) ∩ Y).Nonempty := by
    intro C hC
    have hV := hC.odd
    contrapose! hV
    have h_even : (V(C) ∩ V(G, M)).encard = V(C).encard := by
      rw [inter_eq_self_of_subset_left hV.1, encard_univ]
    have h_sub : ∀ e ∈ M, (V(G, e) ∩ V(C)).Nonempty → V(G, e) ⊆ V(C) := by
      intro e he heC
      obtain ⟨v, hv⟩ := heC
      have hvC : v ∈ V(C) := hv.2
      have h_comp : C.IsCompOf (G - Y) := hC.toIsCompOf
      intro u hu
      by_contra huC
      have huY : u ∈ Y := by
        by_contra huY
        exact huC (h_comp.vertex_mem_of_adj (G.adj_of_mem_edge (hM.subset he) hu hv.1) (by simpa using huY) hvC)
      exact hV.2 e he ⟨v, hv.1, hvC⟩ ⟨u, hu, huY⟩
    rw [← h_even, V(G, M), ⋃_inter, encard_biUnion hM.disjoint (fun e he ↦ (V(G, e) ∩ V(C)).finite_to_set)]
    apply Even.encard_sum
    intro e he
    by_cases heC : (V(G, e) ∩ V(C)).Nonempty
    · rw [inter_eq_self_of_subset_left (h_sub e he heC)]
      exact (G.encard_V_edge_of_not_loop (hM.subset he) (fun hl ↦ by simpa [hl] using hC.odd))
    · rw [not_nonempty_iff_eq_empty.mp heC, encard_empty]; exact even_zero
  sorry
