lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  by_cases hY : Y.Finite
  · have h_fin : (G - Y).OddComponents.encard < ∞ := (Set.Finite.subset G.Finite.vertexSet (fun C hC ↦ hC.toIsCompOf.subset_vertexSet)).encard_lt_top
    rw [ENNReal.le_sub_iff_add h_fin.ne (ENNReal.add_lt_top.mpr ⟨G.Finite.vertexSet.encard_finite, hY.encard_finite⟩).ne]
    refine sSup_le (fun n ⟨M, hM, hn⟩ ↦ ?_)
    rw [hn, two_mul, ← hM.encard_vertexSet, ← encard_diff_add_encard_inter (V(G, M)) Y, add_assoc]
    let MH := M ∩ {e | V(G, e) ⊆ V(G) \ Y}
    have hMH : V(G, MH) ⊆ V(G, M) \ Y := fun v hv ↦ ⟨hv.1, fun hvy ↦ (hM.subset hv.2).left_mem hvy |>.not_mem_deleteVertices (V(G) \ Y) (by simpa)⟩
    have h_odd : (G - Y).OddComponents.encard ≤ (V(G) \ Y).encard - V(G, MH).encard
    · rw [ENNReal.le_sub_iff_add (hM.finite.subset (inter_subset_left _ _)).encard_vertexSet.ne (G.Finite.vertexSet_diff Y).encard_finite.ne]
      refine encard_le_encard_diff_add_encard_inter _ (V(G, MH)) |>.trans (add_le_add_right ?_ _)
      · exact encard_mono (fun C hC ↦ (hC.odd.nonempty_of_encard (V(C).encard_finite.ne)).exists_not_mem_isMatching_of_odd hC.toIsCompOf (hM.inter_restrict _))
    calc (V(G, M) \ Y).encard + (V(G, M) ∩ Y).encard + (G - Y).OddComponents.encard
      = (V(G, M) \ Y).encard + (G - Y).OddComponents.encard + (V(G, M) ∩ Y).encard := by rw [add_assoc, add_comm (V(G, M) ∩ Y).encard, ← add_assoc]
      _ ≤ (V(G) \ Y).encard + (V(G, M) \ Y).encard - V(G, MH).encard + (V(G, M) ∩ Y).encard := add_le_add_right (ENNReal.add_le_of_le_tsub h_odd) _
      _ ≤ (V(G) \ Y).encard + (V(G, M) ∩ Y).encard + (V(G, M) ∩ Y).encard := by sorry
      _ ≤ V(G).encard + Y.encard := by sorry
  · rw [hY.encard_eq_top, add_top, ENNReal.top_sub_any]
    exact le_top
