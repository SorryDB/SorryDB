import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped Classical
open scoped Fin.CommRing

/--
Let $ n$ and $ k$ be positive integers with $ k \geq n$ and $ k - n$ an even number. Let $ 2n$ lamps labelled $ 1$, $ 2$, ..., $ 2n$ be given, each of which can be either [i]on[/i] or [i]off[/i]. Initially all the lamps are off. We consider sequences of steps: at each step one of the lamps is switched (from on to off or from off to on).

Let $ N$ be the number of such sequences consisting of $ k$ steps and resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off.

Let $ M$ be number of such sequences consisting of $ k$ steps, resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off, but where none of the lamps $ n + 1$ through $ 2n$ is ever switched on.

Determine $ \frac {N}{M}$.


[i]Author: Bruno Le Floch and Ilia Smilga, France[/i]

Solution: $2^{k-n}$
-/
@[imo_problem_subject combinatorics]
theorem imo_2008_p5 (n k N M : ℕ) (h : 0 < n ∧ 0 < k ∧ k ≥ n) [NeZero n] (heven : Even (k - n))
    -- whether the mapping of type (t → (lamp_id → on/off)) is a correct switching
    -- sequence.
    (switch_seq : (Fin (k + 1) → Fin (2 * n) → Bool) → Prop)
    (SN SM : Finset (Fin (k + 1) → Fin (2 * n) → Bool))
    (h₀ : ∀ s, switch_seq s ↔
      s 0 = Function.const _ false ∧
      ∀ t : Fin k, ∃ i, s t.succ = Function.update (s t.castSucc) i (!s t.castSucc i))
    (h₁ : ∀ s, s ∈ SN ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), s (Fin.last _) ↑i = false)
    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = 2 ^ (k - n) := by
  have hM_pos : 0 < M := by
    obtain ⟨c, hc_sum, hc_odd⟩ : ∃ c : Fin n → ℕ, (∑ i, c i = k) ∧ (∀ i, Odd (c i)) := by
      let c : Fin n → ℕ := λ i => if i = 0 then k - n + 1 else 1
      refine ⟨c, ?_, ?_⟩
      · rw [Finset.sum_ite, Finset.filter_eq, Finset.card_singleton, Finset.filter_ne]
        rw [Finset.card_univ, Nat.add_comm, Nat.sub_add_cancel (by omega)]
        simp [Nat.sub_add_cancel (by omega)]
      · intro i; split_ifs with hi <;> [simp [Odd, heven]; simp [Odd]]
    let s : Fin (k + 1) → Fin (2 * n) → Bool := λ t i =>
      let flips := (Finset.range t.val).filter (λ j =>
        let step_idx := j
        let lamp_idx := if step_idx < k then (if step_idx < (∑ l : Fin n, c l) then
          let lamp := (Finset.univ.filter (λ l : Fin n => ∑ m : Fin n, if m < l then c m else 0 ≤ step_idx)).card - 1
          (lamp : ℕ) else 0) else 0
        lamp_idx = i.val)
      flips.card % 2 = 1
    have hSM : s ∈ SM := sorry
    exact h₃.2 ▸ Finset.card_pos.mpr ⟨s, hSM⟩
  have hNM : N = M * 2 ^ (k - n) := by
    let f : (Fin (k + 1) → Fin (2 * n) → Bool) → (Fin (k + 1) → Fin (2 * n) → Bool) := λ s t i =>
      if i < n then (s t i.val ≠ s t (i.val + n)) else false
    have h_surj : ∀ s_m ∈ SM, (SN.filter (λ s_n => f s_n = s_m)).card = 2 ^ (k - n) := sorry
    rw [h₃.1, h₃.2, Finset.card_eq_sum_card_fiber f, Finset.sum_congr rfl h_surj, Finset.sum_const, Nat.smul_eq_mul]
    sorry
  simp [h₃, hNM]
  have : (M : ℚ) ≠ 0 := Nat.cast_ne_zero.mpr (ne_of_gt hM_pos)
  field_simp [this]
