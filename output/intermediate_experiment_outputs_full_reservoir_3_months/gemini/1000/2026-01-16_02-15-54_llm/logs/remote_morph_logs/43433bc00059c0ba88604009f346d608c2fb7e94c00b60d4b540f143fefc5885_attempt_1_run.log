open scoped Fin.CommRing

/--
Let $ n$ and $ k$ be positive integers with $ k \geq n$ and $ k - n$ an even number. Let $ 2n$ lamps labelled $ 1$, $ 2$, ..., $ 2n$ be given, each of which can be either [i]on[/i] or [i]off[/i]. Initially all the lamps are off. We consider sequences of steps: at each step one of the lamps is switched (from on to off or from off to on).

Let $ N$ be the number of such sequences consisting of $ k$ steps and resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off.

Let $ M$ be number of such sequences consisting of $ k$ steps, resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off, but where none of the lamps $ n + 1$ through $ 2n$ is ever switched on.

Determine $ \frac {N}{M}$.


[i]Author: Bruno Le Floch and Ilia Smilga, France[/i]

Solution: $2^{k-n}$
-/
@[imo_problem_subject combinatorics]
theorem imo_2008_p5 (n k N M : ℕ) (h : 0 < n ∧ 0 < k ∧ k ≥ n) [NeZero n] (heven : Even (k - n))
    -- whether the mapping of type (t → (lamp_id → on/off)) is a correct switching
    -- sequence.
    (switch_seq : (Fin (k + 1) → Fin (2 * n) → Bool) → Prop)
    (SN SM : Finset (Fin (k + 1) → Fin (2 * n) → Bool))
    (h₀ : ∀ s, switch_seq s ↔
      s 0 = Function.const _ false ∧
      ∀ t : Fin k, ∃ i, s t.succ = Function.update (s t.castSucc) i (!s t.castSucc i))
    (h₁ : ∀ s, s ∈ SN ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), s (Fin.last _) ↑i = false)
    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = 2 ^ (k - n) := by
  let S := { s | switch_seq s }
  let T := Fin k → Fin (2 * n)
  let f (s : Fin (k + 1) → Fin (2 * n) → Bool) (t : Fin k) : Fin (2 * n) := Classical.choose (h₀ s).1.2 t
  let φ (w : T) : Fin (k + 1) → Fin (2 * n) → Bool := fun t i => (Finset.univ.filter (λ j : Fin k => j < t ∧ w j = i)).card % 2 = 1
  have hφ_switch : ∀ w, switch_seq (φ w) := fun w => (h₀ _).2 ⟨by ext; simp [φ], fun t => ⟨w t, by ext i; simp [φ]; by_cases hi : w t = i <;> simp [hi, Fin.succ_lt_succ_iff, Finset.filter_insert] <;> rw [Nat.succ_mod_two, Bool.not_eq_iff]; congr⟩⟩
  have hfφ : ∀ w, f (φ w) = w := fun w => funext (fun t => Classical.choose_spec (h₀ (φ w)).1.2 t |> fun h => by have := funext_iff.1 h (w t); simp [φ] at this; exact Classical.choose_spec (exists_unique_update (φ w t.castSucc) (w t) !(φ w t.castSucc (w t))) (f (φ w) t) h)
  have hφf : ∀ s, switch_seq s → φ (f s) = s := fun s hs => funext (fun t i => by induction t using Fin.induction with | zero => simp [φ, (h₀ s).1.1 hs] | succ t ih => rw [(h₀ s).1.2 hs t |> Classical.choose_spec]; simp [φ, Fin.succ_lt_succ_iff, Finset.filter_insert, ih]; split_ifs with h' <;> simp [h'])
  let T_N := { w : T | (∀ i < n, (Finset.univ.filter (λ j => w j = i)).card % 2 = 1) ∧ (∀ i : Fin n, (Finset.univ.filter (λ j => w j = i.1 + n)).card % 2 = 0) }
  let T_M := { w : T | (∀ i < n, (Finset.univ.filter (λ j => w j = i)).card % 2 = 1) ∧ (∀ i : Fin n, ∀ t, (Finset.univ.filter (λ j => j < t ∧ w j = i.1 + n)).card = 0) }
  have hT_M_def : ∀ w, w ∈ T_M ↔ (∀ i < n, (Finset.univ.filter (λ j => w j = i)).card % 2 = 1) ∧ ∀ j, w j < n := fun w => ⟨fun h => ⟨h.1, fun j => by contrapose! h; let i : Fin n := ⟨w j - n, by omega⟩; refine ⟨i, j.succ, ?_⟩; simp; use j; simp; omega⟩, fun h => ⟨h.1, fun i t => Finset.card_eq_zero.2 (fun j hj => by simp at hj; have := h.2 j; omega)⟩⟩
  let p (w : T) : Fin k → Fin n := fun t => ⟨w t % n, by have := w t; omega⟩
  have hp : ∀ w ∈ T_N, p w ∈ T_M := fun w hw => (hT_M_def (p w)).2 ⟨fun i hi => by simp [p]; rw [←Nat.add_mod_two, ←Finset.card_union_eq, ←Finset.filter_union]; congr; ext j; simp; constructor <;> intro h' <;> (try omega); cases Nat.exists_eq_add_of_le (Fin.is_le (w j)) with | h_ex k' hk' => rw [hk'] at h'; simp at h'; omega; exact hw.1 i hi; exact hw.2 ⟨i, hi⟩; refine Finset.disjoint_filter.2 (fun j _ h1 h2 => ?_); simp at h1 h2; omega, fun j => (p w j).2⟩
  have h_fiber : ∀ w' ∈ T_M, (Finset.univ.filter (λ w => w ∈ T_N ∧ p w = w')).card = 2 ^ (k - n) := fun w' hw' => by
    let idx (i : Fin n) := Finset.univ.filter (λ j => w' j = i)
    have h_split : Finset.univ ≃ (i : Fin n) × idx i := (Fintype.subtypeSigmaEquiv (fun j => ∃ i, w' j = i) (fun j => ⟨w' j, rfl⟩)).symm
    let choice (i : Fin n) := { s : Finset (idx i) // s.card % 2 = 0 }
    have h_ways (i : Fin n) : (Finset.univ : Finset (choice i)).card = 2 ^ ((idx i).card - 1) := by rw [Fintype.card_subtype, ←Finset.sum_range_reflect (idx i).card, ←Nat.sum_range_choose_halfway]; simp [Finset.card_univ]; exact (hT_M_def w').1 i i.2
    have : (Finset.univ.filter (λ w => w ∈ T_N ∧ p w = w')).card = (Finset.univ : Finset (Π i, choice i)).card := by
      refine Finset.card_congr (fun w _ i => ⟨(idx i).filter (λ j => w j.1 = i.1 + n), by have hw_N := (Finset.mem_filter.1 (show w ∈ _ from ‹_›)).2.1; exact hw_N.2 i⟩) (fun w _ => by simp [T_N]; intro i hi; have := (hT_M_def w').1 i hi; have hpw := (Finset.mem_filter.1 (show w ∈ _ from ‹_›)).2.2; simp [p, funext_iff] at hpw; split_ifs with h_case; omega; sorry) (by sorry) (by sorry)
