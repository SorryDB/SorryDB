    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = answer(2 ^ (k - n)) := by
  have hM_pos : M > 0 := by
    sorry
  have hNM : N = M * 2 ^ (k - n) := by
    sorry
  rw [hNM, h₃.1, h₃.2]
  push_cast
  field_simp [Nat.pos_iff_ne_zero.mp hM_pos]
