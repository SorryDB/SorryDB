import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped Classical
open scoped Fin.CommRing

/--
Let $ n$ and $ k$ be positive integers with $ k \geq n$ and $ k - n$ an even number. Let $ 2n$ lamps labelled $ 1$, $ 2$, ..., $ 2n$ be given, each of which can be either [i]on[/i] or [i]off[/i]. Initially all the lamps are off. We consider sequences of steps: at each step one of the lamps is switched (from on to off or from off to on).

Let $ N$ be the number of such sequences consisting of $ k$ steps and resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off.

Let $ M$ be number of such sequences consisting of $ k$ steps, resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off, but where none of the lamps $ n + 1$ through $ 2n$ is ever switched on.

Determine $ \frac {N}{M}$.


[i]Author: Bruno Le Floch and Ilia Smilga, France[/i]

Solution: $2^{k-n}$
-/
@[imo_problem_subject combinatorics]
theorem imo_2008_p5 (n k N M : ℕ) (h : 0 < n ∧ 0 < k ∧ k ≥ n) [NeZero n] (heven : Even (k - n))
    -- whether the mapping of type (t → (lamp_id → on/off)) is a correct switching
    -- sequence.
    (switch_seq : (Fin (k + 1) → Fin (2 * n) → Bool) → Prop)
    (SN SM : Finset (Fin (k + 1) → Fin (2 * n) → Bool))
    (h₀ : ∀ s, switch_seq s ↔
      s 0 = Function.const _ false ∧
      ∀ t : Fin k, ∃ i, s t.succ = Function.update (s t.castSucc) i (!s t.castSucc i))
    (h₁ : ∀ s, s ∈ SN ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), s (Fin.last _) ↑i = false)
    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = 2 ^ (k - n) := by
  let f : (Fin (k + 1) → Fin (2 * n) → Bool) → (Fin (k + 1) → Fin n → Bool) :=
    fun s t i => s t i
  have hM_pos : M > 0 := by
    rw [h₃.2]
    let σ : Fin k → Fin n := fun t => if t.val < k - n then 0 else (t.val - (k - n))
    let s : Fin (k + 1) → Fin (2 * n) → Bool := fun t i =>
      (Finset.univ.filter (fun j : Fin t.val => (if j.val < k - n then (0 : Fin (2 * n)) else (j.val - (k - n) : Fin (2 * n))) = i)).card % 2 = 1
    have hs : s ∈ SM := by
      rw [h₂ s]
      refine ⟨?_, ?_⟩
      · rw [h₀ s]; refine ⟨?_, ?_⟩
        · ext i; simp [s]
        · intro t; let i : Fin (2 * n) := if t.val < k - n then 0 else (t.val - (k - n)); use i; ext j x
          by_cases hj : x = i <;> simp [s, hj, Fin.succ, Function.update]
          · rw [Fin.val_add_one_of_lt (t.is_lt), Finset.filter_range_succ_true]
          · rw [Fin.val_add_one_of_lt (t.is_lt), Finset.filter_range_succ_false hj]
      · intro i hi; simp at hi; refine ⟨?_, ?_⟩
        · simp [s, Fin.last, hi]; have : Even (k - n) := heven
          let count := (Finset.univ.filter (fun j : Fin k => (if j.val < k - n then (0 : Fin (2 * n)) else (j.val - (k - n) : Fin (2 * n))) = ↑i)).card
          have : count = (if i = 0 then (k - n) + 1 else 1) := by
            simp [count]; by_cases hi0 : i = 0 <;> simp [hi0]
            · rw [Finset.card_filter]; trans (Finset.Ico 0 (k - n)).card + (Finset.filter (fun j : Fin k => j.val = k - n) Finset.univ).card
              · congr; ext j; simp; by_cases hj : j.val < k - n <;> simp [hj]
              · simp [h.3]
            · rw [Finset.card_filter]; trans (Finset.filter (fun j : Fin k => j.val = (k - n) + i.val) Finset.univ).card
              · congr; ext j; simp; by_cases hj : j.val < k - n <;> simp [hj]
                intro h; rw [h] at hj; exact (lt_add_of_pos_right _ i.zero_le).not_lt hj
              · simp [h.3, hi.2]
          rw [this]; by_cases hi0 : i = 0 <;> simp [hi0, heven.add_one]
        · intro t; simp [s, hi]; rw [Finset.card_eq_zero]; ext j; simp; intro h_eq; exact hi.left.not_le (by simp [h_eq])
    exact Finset.card_pos.mpr ⟨s, hs⟩
  have hNM : N = M * 2 ^ (k - n) := by
    obtain ⟨rfl, rfl⟩ := h₃; let proj : (Fin (k + 1) → Fin (2 * n) → Bool) → (Fin (k + 1) → Fin n → Bool) := fun s t i => s t i
    rw [Finset.card_eq_sum_card_fiber proj]; rw [Finset.sum_filter_of_subset (fun s (hs : s ∈ SN) => ?_)]
    · rw [Finset.sum_congr rfl (fun s' hs' => ?_)]
      · rw [Finset.sum_const, nsmul_eq_mul, mul_comm]
      · have : (SN.filter (fun s => proj s = s')).card = 2 ^ (k - n) := sorry
        exact this
    · rw [h₂ s']; rw [h₁ s]; aesop
  rw [hNM]; field_simp [Nat.cast_ne_zero.mpr hM_pos.ne']; ring
