      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = 2 ^ (k - n) := by
  let step (s : Fin (k + 1) → Fin (2 * n) → Bool) (t : Fin k) : Fin (2 * n) :=
