@[imo_problem_subject combinatorics]
theorem imo_2008_p5 (n k N M : ℕ) (h : 0 < n ∧ 0 < k ∧ k ≥ n) [NeZero n] (heven : Even (k - n))
    -- whether the mapping of type (t → (lamp_id → on/off)) is a correct switching
    -- sequence.
    (switch_seq : (Fin (k + 1) → Fin (2 * n) → Bool) → Prop)
    (SN SM : Finset (Fin (k + 1) → Fin (2 * n) → Bool))
    (h₀ : ∀ s, switch_seq s ↔
      s 0 = Function.const _ false ∧
      ∀ t : Fin k, ∃ i, s t.succ = Function.update (s t.castSucc) i (!s t.castSucc i))
    (h₁ : ∀ s, s ∈ SN ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), s (Fin.last _) ↑i = false)
    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = 2 ^ (k - n) := by
  have hM_pos : (SM.card : ℚ) ≠ 0 := by
    refine Nat.cast_ne_zero.mpr (Finset.card_ne_zero.mpr ?_)
    let f : Fin k → Fin n := fun i => if i < n then ⟨i, i.2⟩ else ⟨0, h.1⟩
    let s : Fin (k + 1) → Fin (2 * n) → Bool := fun t i =>
      (Finset.filter (fun j : Fin k => (j < t) ∧ (if j < n then j = i else (i = 0))) Finset.univ).card % 2 = 1
    sorry
  have hN_card : (SN.card : ℚ) = SM.card * 2 ^ (k - n) := by
    sorry
  rw [h₃.1, h₃.2, hN_card]
  field_simp [hM_pos]
  ring
