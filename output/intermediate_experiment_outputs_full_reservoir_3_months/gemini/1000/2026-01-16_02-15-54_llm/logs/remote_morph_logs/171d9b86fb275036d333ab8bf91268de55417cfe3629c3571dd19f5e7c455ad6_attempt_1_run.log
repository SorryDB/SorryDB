        simp only [measure_univ]
        exact @measure_univ _ _ _ (Measure.isProbabilityMeasure_map (by fun_prop))
      rw [this]
      infer_instance
    classical
    rw [isGaussian_iff_gaussian_charFunDual]
    apply isGaussian_iff_gaussian_charFunDual.mp
    rw [hX.map_pi_eq_pi]
    exact isGaussian_pi.mpr fun i ↦ (h i).isGaussian_map
