      · linarith [norm_add_sq_add_norm_sub_sq (g n) (g m)]
      · positivity
      · exact hε ⟩)
  exact ⟨g, x, fun n ↦ convexHull_mono (Set.Subset.refl _) (hg n), hx⟩
