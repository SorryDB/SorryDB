  exact ⟨g, x, fun n ↦ convexHull_min (Set.range_subset_iff.2 fun m ↦
    subset_convexHull ℝ _ ⟨m, rfl⟩) (convex_iff_nnreal.1 (convex_convexHull ℝ _)) (hg n), hx⟩
