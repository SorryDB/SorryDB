    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨g, hg, hg_cau⟩ := komlos_convex (fun x ↦ ‖x‖ ^ 2) (fun x ↦ sq_nonneg ‖x‖)
    (let ⟨M, hM⟩ := h_bdd; ⟨M ^ 2, fun n ↦ sq_le_sq.mpr (by linarith [hM n, norm_nonneg (f n)])⟩)
  have h_cau : CauchySeq g := by
    refine metric_cauchySeq_iff.mpr fun ε hε ↦ ?_
    obtain ⟨N, hN⟩ := hg_cau (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    have h_para := parallelogram_law ℝ (g n) (g m)
    have h_norm := norm_smul (2 : ℝ≥0)⁻¹ (g n + g m)
    rw [dist_eq_norm, ← sq_lt_sq, h_para]
    · simp only [NNReal.smul_def, NNReal.coe_inv, NNReal.coe_two, norm_inv, norm_two] at h_norm
      linarith [hN n m hn hm, h_norm]
    · exact norm_nonneg _
    · exact le_of_lt hε
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete h_cau
  exact ⟨g, x, fun n ↦ convexHull_min (Set.subset_convexHull ℝ _)
    (convex_convexHull ℝ _).convex_nnreal (hg n), hx⟩
```
