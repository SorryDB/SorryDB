    linarith [norm_add_sq (g n) (g m), norm_sub_sq (g n) (g m)])
  exact ⟨g, x, fun n ↦ convexHull_min (subset_convexHull ℝ _)
    (fun _ hx _ hy a b hab ↦ convex_convexHull ℝ _ hx hy (a : ℝ).2 b.2 (NNReal.coe_add a b ▸ hab))
    (hg_mem n), hx⟩
