    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨g, hg, h_cau⟩ := komlos_convex (fun x ↦ ‖x‖^2) (by positivity)
    (by obtain ⟨M, hM⟩ := h_bdd; exact ⟨M^2, fun n ↦ by dsimp; nlinarith [hM n]⟩)
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete (Metric.cauchySeq_iff.mpr fun ε hε ↦
    let ⟨N, hN⟩ := h_cau (ε ^ 2 / 4) (by positivity)
