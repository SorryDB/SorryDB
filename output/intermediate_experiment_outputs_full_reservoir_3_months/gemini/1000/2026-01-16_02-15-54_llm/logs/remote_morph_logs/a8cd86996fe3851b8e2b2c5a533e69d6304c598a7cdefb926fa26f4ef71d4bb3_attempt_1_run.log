```lean
lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg_hull, hg_lim⟩ := komlos_convex (f := f) (fun x ↦ ‖x‖^2) (fun _ ↦ sq_nonneg _)
    ⟨M ^ 2, fun n ↦ sq_le_sq.2 (by linarith [hM n, norm_nonneg (f n)])⟩
  have hg_cau : CauchySeq g := Metric.cauchySeq_iff.2 fun ε hε ↦ by
    obtain ⟨N, hN⟩ := hg_lim (ε ^ 2 / 4) (by positivity)
    exact ⟨N, fun n hn m hm ↦ by
      rw [dist_eq_norm, ← sq_lt_sq (norm_nonneg _) (le_of_lt hε), norm_norm,
        ← parallelogram_law_with_norm ℝ]
      have : ‖(2 : ℝ≥0)⁻¹ • (g n + g m)‖^2 = ‖(2 : ℝ)⁻¹ • (g n + g m)‖^2 := by simp
      linarith [hN n m hn hm]⟩
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete hg_cau
  exact ⟨g, x, fun n ↦ convexHull_eq_convexHull_nnreal _ ▸ hg_hull n, hx⟩
```
