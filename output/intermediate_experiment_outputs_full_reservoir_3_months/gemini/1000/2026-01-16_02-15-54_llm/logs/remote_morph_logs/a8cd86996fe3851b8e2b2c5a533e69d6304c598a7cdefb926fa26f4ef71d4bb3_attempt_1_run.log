lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E] [CompleteSpace E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg, h_cau⟩ := komlos_convex (φ := fun x ↦ ‖x‖ ^ 2) (fun x ↦ sq_nonneg _)
    ⟨M ^ 2, fun n ↦ sq_le_sq.mpr (by linarith [hM n, norm_nonneg (f n)])⟩
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_iff.mp (Metric.cauchySeq_iff.mpr fun ε hε ↦ by
    obtain ⟨N, hN⟩ := h_cau (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n hn m hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq, norm_nonneg, abs_of_nonneg (norm_nonneg _)]
    · linarith [norm_add_sq_add_norm_sub_sq (g n) (g m)]
    · linarith [hε])
  exact ⟨g, x, fun n ↦ convexHull_min (Set.subset_convexHull ℝ _)
    ((convex_convexHull ℝ _).restrict_scalars ℝ≥0) (hg n), hx⟩
