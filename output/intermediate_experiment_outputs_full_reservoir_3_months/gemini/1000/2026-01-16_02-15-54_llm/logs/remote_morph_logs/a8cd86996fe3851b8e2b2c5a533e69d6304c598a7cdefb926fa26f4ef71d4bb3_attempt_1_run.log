lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg_mem, hg_cau⟩ := komlos_convex (fun x ↦ sq_nonneg ‖x‖)
    ⟨M ^ 2, fun n ↦ pow_le_pow_left (norm_nonneg _) (hM n) 2⟩
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete (Metric.cauchySeq_iff.mpr fun ε hε ↦ by
    obtain ⟨N, hN⟩ := hg_cau (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n hn m hm ↦ ?_⟩
    specialize hN n m hn hm
    simp only [NNReal.coe_two, NNReal.val_inv, inv_smul_smul₀, two_ne_zero, not_false_iff,
      norm_smul, norm_inv, norm_two] at hN
