  obtain ⟨x, hx⟩ : ∃ x, Tendsto g atTop (𝓝 x) := cauchySeq_atTop_iff.mp
    (cauchySeq_of_le_tendsto_0 (fun n ↦ ‖g n.1 - g n.2‖^2) (fun _ ↦ sq_nonneg _)
