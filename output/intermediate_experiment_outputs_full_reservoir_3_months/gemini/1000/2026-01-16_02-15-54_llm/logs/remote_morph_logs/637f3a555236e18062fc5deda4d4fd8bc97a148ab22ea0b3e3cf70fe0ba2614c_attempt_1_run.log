      constructor
      · exact rink
      use u, v
      dsimp only at hr₀ ⊢
      rw [←hr₀] at hruv
      dsimp only at hruv
      cases' hruv with bef aft
      constructor
      · simp only [List.append_nil] at bef
        exact bef
