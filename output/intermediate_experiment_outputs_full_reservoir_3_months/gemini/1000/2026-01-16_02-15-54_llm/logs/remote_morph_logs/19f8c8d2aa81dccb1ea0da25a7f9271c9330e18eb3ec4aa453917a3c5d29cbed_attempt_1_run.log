lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  unfold assert_bits_e Vector.foldl
  rw [Array.foldl_eq_foldl_toList]
  let l := args.toArray.toList
  have hi : i < l.length := by simpa [l] using h
  rw [←List.take_append_drop i, List.drop_eq_getElem_cons hi]
  simp only [List.foldl_append, List.foldl_cons]
  have h_n : ∀ {l' : List (ZMod p)} {cs'}, Cs.eval p inst✝ cs' = .n → (l'.foldl assert_bit_e cs').eval = .n := by
    intro l'; induction l' with
    | nil => intros; assumption
    | cons x xs ih =>
      intros cs' hcs'; simp only [List.foldl_cons]; apply ih
      simp [assert_bit_e, Cs.eval, hcs']; split <;> rfl
  apply h_n
  simp [assert_bit_e, Cs.eval, Exp.eval]
  split
  · rename_i h_cond
    simp [l, Vector.get_eq_getElem, mul_eq_zero, sub_eq_zero] at h_cond
    cases h_cond <;> contradiction
  · rfl
```
