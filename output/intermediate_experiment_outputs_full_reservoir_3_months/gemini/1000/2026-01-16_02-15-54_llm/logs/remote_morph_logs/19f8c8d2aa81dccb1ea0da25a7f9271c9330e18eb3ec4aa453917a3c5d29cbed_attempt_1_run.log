  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  unfold assert_bits_e Vector.foldl
  have hb_in : args[i] ∈ args.toList := Vector.get_mem _ _
  have hb_nz : args[i] * (1 - args[i]) ≠ 0 := by simp [mul_eq_zero, sub_eq_zero, h', h'']
  have n_foldl : ∀ l rest, rest.eval = .n → (List.foldl assert_bit_e rest l).eval = .n := by
    intro l; induction l with | nil => simp | cons x xs ih => intros; simp [ih, assert_bit_e, Cs.eval, Exp.eval, *]
  simp only [List.foldl_toArray']
  generalize args.toList = l at *
  induction l generalizing cs with
  | nil => cases hb_in
  | cons x xs ih =>
    simp at hb_in; rcases hb_in with rfl | hb_in
    · apply n_foldl; simp [assert_bit_e, Cs.eval, Exp.eval, hb_nz]
    · exact ih _ hb_in
```
