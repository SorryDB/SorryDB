import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let G := {e : Finset ↥S | e.card = 2 ∧ ∃ x > 0, (e.min' (by simp)).1 * (e.max' (by simp)).1 = x^2 + x + k}
  let E (p : Fin #S ≃ S) : Finset (Finset ↥S) := Finset.univ.image (fun i => {p i, p (i + 1)})
  have hE (p : Fin #S ≃ S) (hp : Condition k S p) : E p ⊆ G := by
    intro e he; simp [E] at he; obtain ⟨i, rfl⟩ := he; rw [Set.mem_setOf_eq]; constructor
    · have : p i ≠ p (i + 1) := p.injective.ne (Fin.ne_of_set_succ (by simp [S.card_pos.1 (p.surjective S.any_mem.2).1]))
      simp [Finset.card_pair, this]
    · obtain ⟨x, hx, hxp⟩ := hp i; use x, hx; rw [← hxp]; cases' le_total (p i : ℕ) (p (i + 1) : ℕ) with h h
      all_goals (simp [Finset.min'_pair, Finset.max'_pair, h]; ring)
  have hG : ∀ q ∈ S, {p ∈ S | {p, q} ∈ G}.card ≤ 2 := by
    intro q hq; let roots := {x : ℕ | x < q ∧ (x^2 + x + k) % q = 0}
    have hroots : roots.card ≤ 2 := by
      have : q.Prime := (hS q hq).2; exact (Nat.Prime.card_roots_degree_le_two this 1 1 k (by simp)).trans (by simp)
    have h_to_roots : ∀ p ∈ S, {p, q} ∈ G ∧ p < q → ∃ x ∈ roots, x^2 + x + k = p * q := by
      intro p hpS ⟨hcard, x, hx, hxpq⟩ hpq; use x % q
      have hx_lt : x < q := by nlinarith [hxpq, hk]; simp [roots, hx_lt]; constructor
      · rw [← hxpq]; simp
      · rw [← hxpq]; exact Nat.mod_eq_of_lt (by nlinarith [hxpq, hk])
    let f : {p ∈ S | {p, q} ∈ G ∧ p < q} ↪ roots := ⟨fun p => (h_to_roots p.1 p.2.1 p.2.2).choose, fun p₁ p₂ h => by
      have h1 := (h_to_roots p₁.1 p₁.2.1 p₁.2.2).choose_spec; have h2 := (h_to_roots p₂.1 p₂.2.1 p₂.2.2).choose_spec
      rw [h] at h1; rw [h1, mul_right_inj' (hS q hq).2.ne_zero] at h2; exact Subtype.ext h2⟩
    have h_lt : {p ∈ S | {p, q} ∈ G ∧ p < q}.card ≤ 2 := (Finset.card_le_card_of_embedding f).trans hroots
    have h_deg : ∀ q ∈ S, {p ∈ S | {p, q} ∈ G}.card = {p ∈ S | {p, q} ∈ G ∧ p < q}.card + {p ∈ S | {p, q} ∈ G ∧ q < p}.card := by
      intro q hq; rw [← Finset.card_union_of_disjoint]; apply congr_arg; ext p; simp; aesop
      simp [Finset.disjoint_iff_ne]; intros; linarith
    suffices ∀ p : Fin #S ≃ S, Condition k S p → E p = G by rw [this p₁ hp₁, this p₂ hp₂]; exact Fin.equiv_iff_cycle_eq
    intro p hp; have hcard : (E p).card = #S := by
      rw [E, Finset.card_image_of_injective]; simp; intro i j h; simpa [Finset.subset_iff] using h
    refine' Finset.eq_of_subset_of_card_le (hE p hp) _; rw [hcard]; rw [← Finset.sum_card_filter_lt_eq_card_univ G]
    refine' (Finset.sum_le_sum (fun q _ => h_lt q (by simp))).trans _; simp
