import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let K := 4 * k - 1
  let E := {e : Finset ↥S | e.card = 2 ∧ ∃ a b, a ∈ e ∧ b ∈ e ∧ a ≠ b ∧ ∃ y, y^2 = 4 * (a : ℕ) * (b : ℕ) - K}
  have h_neighbors : ∀ (p : Fin S.card ≃ ↥S), Condition k S p → ∀ i,
      {p i, p (i + 1)} ∈ E := by
    intro p hp i
    have : NeZero S.card := ⟨i.pos.ne'⟩
    rcases hp i with ⟨x, hx, hxy⟩
    simp [E]
    refine ⟨?_, p i, p (i + 1), by simp, by simp, p.injective.ne (Fin.next_ne i), 2 * x + 1, ?_⟩
    · rw [Finset.card_doubleton (p.injective.ne (Fin.next_ne i))]
    · rw [hxy, mul_add, mul_add]
      ring
  have h_deg : ∀ a ∈ S, {e ∈ E | a ∈ e}.card ≤ 2 := by
    intro a ha
    let Sa := {b ∈ S | ∃ y, y^2 = 4 * a * b - K}
    have : {e ∈ E | ↑a ∈ e}.card = (Sa.erase a).card := by
      rw [Finset.card_congr (λ e _ => (e.erase ↑a).min' (by simp [Finset.card_erase_of_mem, (Finset.mem_filter.1 (by assumption)).1]))]
      · intro e he; simp at he; rcases he with ⟨hE, haE⟩
        rcases hE with ⟨h2, a1, b1, ha1, hb1, hne, y, hy⟩
        simp; constructor
        · rcases Finset.card_eq_two.1 h2 with ⟨u, v, huv, rfl⟩
          simp at haE; rcases haE with rfl | rfl
          · simp [huv.symm]; rcases Finset.mem_insert.1 hb1 with rfl | h; contradiction; exact h
          · simp [huv]; rcases Finset.mem_insert.1 ha1 with rfl | h; contradiction; exact h
        · rcases Finset.card_eq_two.1 h2 with ⟨u, v, huv, rfl⟩
          simp at haE; rcases haE with rfl | rfl
          · use y; rw [mul_assoc]; congr 1; rcases Finset.mem_insert.1 hb1 with rfl | h; contradiction; rw [← Finset.mem_singleton.1 h]; rfl
          · use y; rw [mul_assoc]; congr 1; rcases Finset.mem_insert.1 ha1 with rfl | h; contradiction; rw [← Finset.mem_singleton.1 h]; rfl
      · intro e1 e2 h1 h2; simp at h1 h2; rcases h1 with ⟨hE1, haE1⟩; rcases h2 with ⟨hE2, haE2⟩
        intro h; apply Finset.ext; intro x
        rcases Finset.card_eq_two.1 hE1.1 with ⟨u1, v1, huv1, rfl⟩
        rcases Finset.card_eq_two.1 hE2.1 with ⟨u2, v2, huv2, rfl⟩
        simp at haE1 haE2; rcases haE1 with rfl | rfl <;> rcases haE2 with rfl | rfl <;> simp at h <;> simp [h, huv1, huv2]
      · intro b hb; simp at hb; rcases hb with ⟨hbS, hne, y, hy⟩
        use {↑a, b}; simp [E]; refine ⟨⟨by rw [Finset.card_doubleton hne], ↑a, b, by simp, by simp, hne, y, hy⟩, by simp⟩
    let a_max := S.max' (Finset.nonempty_of_ne_empty (by intro h; simp [h] at hp₁))
    sorry
  sorry
