import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let R (p q : ℕ) : Prop := ∃ x : ℕ, 0 < x ∧ p * q = x ^ 2 + x + k
  have hR₁ : ∀ i : Fin #S, R (p₁ i) (p₁ (i + 1)) := hp₁
  have hR₂ : ∀ i : Fin #S, R (p₂ i) (p₂ (i + 1)) := hp₂
  have h_sym : ∀ {p q}, R p q → R q p := fun ⟨x, hx, h⟩ => ⟨x, hx, (mul_comm _ _).trans h⟩
  let G : SimpleGraph S := SimpleGraph.fromRel (λ a b => R a b)
  have h_adj₁ : ∀ i : Fin #S, G.Adj (p₁ i) (p₁ (i + 1)) := by
    intro i; refine' SimpleGraph.fromRel_adj.mpr ⟨hR₁ i, _⟩
    intro he; obtain ⟨x, hx, h⟩ := hR₁ i; rw [he] at h
    have h_odd : Odd ((p₁ i : ℕ) * (p₁ i : ℕ)) := (hS (p₁ i) (p₁ i).2).1.mul (hS (p₁ i) (p₁ i).2).1
    have h_even : Even (x ^ 2 + x + k) := (x.even_mul_succ.add (hk.eq_or_lt.resolve_left (λ hk0 => (hS (p₁ i) (p₁ i).2).1.1 (by rw [←h, hk0, x.even_mul_succ.add_zero]; rfl))).even_sub_one).even_add_one
    sorry
  sorry
```

