import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  have h_unique_edges : ∀ i : Fin #S, {p₁ (i - 1), p₁ (i + 1)} = {p₂ (p₂.symm (p₁ i) - 1), p₂ (p₂.symm (p₁ i) + 1)} := by
    intro i
    let f (a b : ℕ) := ∃ x : ℕ, 0 < x ∧ a * b = x ^ 2 + x + k
    let D := 4 * k - 1
    have hf {a b} (h : f a b) : (2 * x + 1) ^ 2 = 4 * a * b - D := sorry
    have h_max_two (p : ℕ) (hp : p ∈ S) : {q ∈ S | f p q}.card ≤ 2 := sorry
    have h_p1_nb (p : S) : {p₁ (p₁.symm p - 1), p₁ (p₁.symm p + 1)} ⊆ {q ∈ S | f p q} := sorry
    have h_p2_nb (p : S) : {p₂ (p₂.symm p - 1), p₂ (p₂.symm p + 1)} ⊆ {q ∈ S | f p q} := sorry
    exact sorry
  exact sorry

