/-
Copyright (c) 2025 Joseph Myers. All rights reserved.
Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let r (a b : ℕ) : Prop := ∃ x > 0, a * b = x^2 + x + k
  have r_symm : ∀ {a b}, r a b ↔ r b a := fun {a b} => by
    simp [r, mul_comm]
  let G : SimpleGraph S := {
    Adj := fun a b => a ≠ b ∧ r a b,
    symm := fun a b ⟨h1, h2⟩ => ⟨h1.symm, r_symm.mp h2⟩,
    loopless := fun a ⟨h1, _⟩ => h1 rfl
  }
  have h_adj : ∀ {p : Fin #S ≃ S}, Condition k S p → ∀ i, G.Adj (p i) (p (i + 1)) := by
    intro p hp i
    have h_ne : p i ≠ p (i + 1) := by
      intro h; have h_inj := p.injective; apply Fin.ext_iff.mp at h;
      have h_card : 1 < #S := by
        obtain ⟨x, hx1, hx2⟩ := hp i
        have h_p : 3 ≤ (p i : ℕ) := (hS (p i) (p i).2).2.three_le
        have : (p i : ℕ)^2 = x^2 + x + k := by rw [←hx2, h]
        have h_k : k = (p i)^2 - x^2 - x := by rw [this, add_assoc, add_comm]; simp
        exact (NeZero.pos #S).ne'
      exact (Fin.next_ne i) h
    exact ⟨h_ne, hp i⟩
  have h_max_deg : ∀ a ∈ S, G.degree a ≤ 2 := by
    intro a ha
    let N := G.neighborFinset a
    by_contra h_deg
    simp only [not_le] at h_deg
    have : ∃ b c d, b ∈ N ∧ c ∈ N ∧ d ∈ N ∧ b < c ∧ c < d := by
      obtain ⟨b, hb⟩ := N.nonempty_of_card_pos (by linarith)
      obtain ⟨c, hc⟩ := (N.erase b).nonempty_of_card_pos (by linarith)
      obtain ⟨d, hd⟩ := ((N.erase b).erase c).nonempty_of_card_pos (by linarith)
      simp only [Finset.mem_erase, mem_neighborFinset] at hb hc hd
      let L := [b, c, d]; have L_nodup : L.Nodup := by simp [L]; tauto
      obtain ⟨b', c', d', h_perm, h_le⟩ := L.permutation_sort (· ≤ ·)
      use b', c', d'
      simp only [List.mem_set_of_List, List.mem_cons, List.mem_singleton] at h_perm
      repeat (constructor; (repeat (any_goals (first | apply h_perm.subset | rfl))))
      refine ⟨?_, ?_⟩
      all_goals (apply lt_of_le_of_ne; (repeat (any_goals (first | apply h_le | rfl))); intro eq;
        have := L_nodup.sublist (List.is_permutation_iff_eq_at.mp h_perm.symm _);
        contradiction)
    sorry
  sorry
