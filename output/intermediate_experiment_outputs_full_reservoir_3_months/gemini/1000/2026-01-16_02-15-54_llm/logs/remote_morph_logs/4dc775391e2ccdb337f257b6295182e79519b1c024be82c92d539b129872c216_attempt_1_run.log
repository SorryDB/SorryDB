import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let R (u v : ℕ) := ∃ x > 0, u * v = x ^ 2 + x + k
  have hR1 : ∀ i, R (p₁ i) (p₁ (i + 1)) := hp₁
  have hR2 : ∀ i, R (p₂ i) (p₂ (i + 1)) := hp₂
  have h_sym : ∀ {u v}, R u v → R v u := fun ⟨x, hx, h⟩ => ⟨x, hx, by rw [mul_comm, h]⟩
  let G : SimpleGraph S := SimpleGraph.fromRel (λ u v => R u v)
  have h_deg : ∀ p ∈ S, G.degree p ≤ 2 := by
    intro p hp
    let N := {q ∈ S | R p q}
    have : ∀ q ∈ N, ∃ x > 0, p * q = x ^ 2 + x + k := λ q hq => (Finset.mem_filter.1 hq).2
    sorry
  have h_cycle1 : G.IsHamiltonianCycle p₁ := sorry
  have h_cycle2 : G.IsHamiltonianCycle p₂ := sorry
  exact G.isHamiltonianCycle_unique h_deg h_cycle1 h_cycle2

