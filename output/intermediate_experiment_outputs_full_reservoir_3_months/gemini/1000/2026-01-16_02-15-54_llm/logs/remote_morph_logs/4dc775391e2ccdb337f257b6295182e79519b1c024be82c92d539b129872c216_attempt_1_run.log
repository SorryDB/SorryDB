theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let R := {st : S × S | ∃ x > 0, (st.1 : ℕ) * st.2 = x ^ 2 + x + k}
  have hR_sym {a b : S} : (a, b) ∈ R ↔ (b, a) ∈ R := by
    simp [R, mul_comm]
  have h_deg (p : S) : (R.filter (fun st => st.1 = p)).card ≤ 2 := sorry
  have h_p1_adj (i : Fin #S) : (p₁ i, p₁ (i + 1)) ∈ R := hp₁ i
  have h_p2_adj (i : Fin #S) : (p₂ i, p₂ (i + 1)) ∈ R := hp₂ i
  have h_p1_edges (i : Fin #S) :
    {q ∈ S | (p₁ i, q) ∈ R} = {p₁ (i - 1), p₁ (i + 1)} := sorry
  have h_p2_edges (i : Fin #S) :
    {q ∈ S | (p₂ i, q) ∈ R} = {p₂ (i - 1), p₂ (i + 1)} := sorry
  have h_same_cycle (i : Fin #S) :
    {p₂ (i - 1), p₂ (i + 1)} = {p₁ (p₁⁻¹ (p₂ i) - 1), p₁ (p₁⁻¹ (p₂ i) + 1)} := sorry
  sorry
