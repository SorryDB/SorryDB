import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  let m := NegativeType.powMetricSpace (Metric.norm_neg_type ℝ) (by norm_num : 0 < (1 / 2 : ℝ)) (by norm_num : (1 / 2 : ℝ) ≤ 1)
  let h : @NegativeType ℝ m := NegativeType.pow (Metric.norm_neg_type ℝ) _ _
  let y : Fin n ⊕ Fin n → ℝ := Sum.elim x (fun i ↦ -x i)
  let c : Fin n ⊕ Fin n → ℝ := Sum.elim (fun _ ↦ 1) (fun _ ↦ -1)
  have : ∑ i, c i = 0 := by simp [c, Finset.sum_sum_elim]
  have h_rem := @NegativeType.sum_rem ℝ m h _ _ y c this
  simp [c, y, Finset.sum_sum_elim, m, dist, MetricSpace.dist, Real.sqrt_eq_rpow, abs_sub_comm] at h_rem
  linarith
