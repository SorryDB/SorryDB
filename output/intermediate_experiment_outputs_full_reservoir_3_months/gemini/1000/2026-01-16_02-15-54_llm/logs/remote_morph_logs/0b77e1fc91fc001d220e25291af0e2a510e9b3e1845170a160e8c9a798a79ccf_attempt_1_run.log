import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  let f (u : ℝ) := ∑ i, Real.sin (u * x i)
  have h_int (a : ℝ) : √|a| = (Real.sqrt 2 / Real.Gamma (3 / 4)) * ∫ u in Set.Ioi 0, (1 - Real.cos (u * a)) / u ^ (3 / 2) := sorry
  have : ∑ i, ∑ j, (√|x i + x j| - √|x i - x j|) = (Real.sqrt 2 / Real.Gamma (3 / 4)) * ∫ u in Set.Ioi 0, (∑ i, ∑ j, (Real.cos (u * (x i - x j)) - Real.cos (u * (x i + x j)))) / u ^ (3 / 2) := sorry
  rw [le_iff_exists_add]
  use ∑ i, ∑ j, (√|x i + x j| - √|x i - x j|)
  simp_rw [← Finset.sum_sub_distrib, sub_add_cancel, ← Finset.sum_sub_distrib]
  have h_cos (u : ℝ) : ∑ i, ∑ j, (Real.cos (u * (x i - x j)) - Real.cos (u * (x i + x j))) = 2 * (f u) ^ 2 := by
    simp_rw [Real.cos_sub, Real.cos_add, f, Finset.sum_mul, Finset.mul_sum, ← sq]
    simp [sub_add_eq_sub_sub, add_sub_assoc, mul_assoc]
  have : 0 ≤ ∑ i, ∑ j, (√|x i + x j| - √|x i - x j|) := by
    rw [this]
    refine mul_nonneg (div_nonneg (Real.sqrt_nonneg _) (Real.Gamma_pos_of_pos (by norm_num)).le) ?_
    refine integral_nonneg (fun u hu => div_nonneg ?_ (pow_nonneg (le_of_lt hu) _))
    rw [h_cos u]
    exact mul_nonneg (by norm_num) (sq_nonneg _)
  exact this

