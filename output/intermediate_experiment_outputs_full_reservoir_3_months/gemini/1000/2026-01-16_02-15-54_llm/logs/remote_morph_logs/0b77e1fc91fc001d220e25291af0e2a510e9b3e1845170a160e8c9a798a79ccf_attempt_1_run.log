import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  let f (x : ℝ) : ℝ := √|x|
  let y : Fin (2 * n) → ℝ := fun i => if h : i < n then x ⟨i, h⟩ else -x ⟨i - n, (by omega)⟩
  let a : Fin (2 * n) → ℝ := fun i => if i < n then 1 else -1
  have ha : ∑ i, a i = 0 := by
    simp only [Fin.sum_univ_two_mul, a, ↓reduceIte, Fin.sum_congr]
    rw [Finset.sum_add_distrib]
    simp only [Finset.sum_const, Finset.card_univ, Fintype.card_fin, n.nsmul_one, add_neg_cancel]
  have h_cnd : ∀ {n : ℕ} (x : Fin n → ℝ) (a : Fin n → ℝ), ∑ i, a i = 0 → ∑ i, ∑ j, a i * a j * √|x i - x j| ≤ 0 := by
    intro n x a ha
    let K (t : ℝ) (x y : ℝ) : ℝ := exp (-t * |x - y|)
    have hK : ∀ t > 0, 0 ≤ ∑ i, ∑ j, a i * a j * K t (x i) (x j) := by
      intro t ht
      rw [show (fun i j => a i * a j * K t (x i) (x j)) = (fun i j => a i * a j * (1 / π * ∫ u, (t / (t^2 + u^2)) * Real.cos (u * (x i - x j)))) by
        ext i j; congr; rw [Real.exp_neg, ← Real.integral_cos_cauchy ht (x i - x j)]; field_simp]
      simp_rw [Real.cos_sub, ← Real.sum_mul, ← Real.mul_sum]
      let c (u : ℝ) := ∑ i, a i * Real.cos (u * x i)
      let s (u : ℝ) := ∑ i, a i * Real.sin (u * x i)
      have : ∀ u, ∑ i, ∑ j, a i * a j * (Real.cos (u * x i) * Real.cos (u * x j) + Real.sin (u * x i) * Real.sin (u * x j)) = (c u)^2 + (s u)^2 := by
        intro u; simp [c, s, sq]; ring
      sorry -- Final integration and CND property of sqrt
  have h_sum := h_cnd y a ha
  simp only [y, a, Fin.sum_univ_two_mul, ↓reduceIte, n.nsmul_one, mul_one, mul_neg, neg_mul, neg_neg,
    abs_sub_comm, Real.sqrt_abs, sub_self, Real.sqrt_zero, mul_zero, Finset.sum_const_zero,
    add_zero, zero_add, Finset.sum_add_distrib, neg_add_rev] at h_sum
  simp only [show ∀ i j : Fin n, √|x i - -x j| = √|x i + x j| by intros; rw [sub_neg_eq_add]] at h_sum
  linarith
