      intro hz
      have := hs.1
      rw [hz] at this
      have : (4 * x * y) % 2 = (4 * k + 1) % 2 := by rw [this]
      norm_num at this
    omega
  have hU : ∀ s : S k, s ∈ U k ↔ e s ∉ U k := by
    intro ⟨⟨x, y, z⟩, hs⟩
    simp [U, e, linearInvo]
    have : x - y + z ≠ 0 := by
