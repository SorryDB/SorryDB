    𝓝[Prod.fst ⁻¹' s] x ≤ comap Prod.fst (𝓝[s] x.1) := by
  rw [← map_fst_nhdsWithin_eq]
  exact le_comap_map

theorem Filter.Eventually.nhdsWithin_preimage_fst {z : α × β} {s : Set α} {p : α × β → Prop}
    (h : ∀ᶠ x in 𝓝[s] z.1, ∀ y, p (x, y)) : ∀ᶠ z' in 𝓝[Prod.fst ⁻¹' s] z, p z' := by
