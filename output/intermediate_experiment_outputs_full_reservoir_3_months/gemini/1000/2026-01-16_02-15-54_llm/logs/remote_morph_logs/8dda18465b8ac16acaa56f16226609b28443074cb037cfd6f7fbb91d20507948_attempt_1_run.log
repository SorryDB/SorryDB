    ContMDiffAt IB 𝓘(𝕜, F →L[𝕜] F) ∞ (Z.coordChange i j) x₀ :=
  (Z.contMDiffOn_coordChange IB i j).contMDiffAt <|
    ((Z.isOpen_baseSet i).inter (Z.isOpen_baseSet j)).mem_nhds hx₀

