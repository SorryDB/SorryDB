    _ ‚Č§ (#(A ^ 2) : ‚ĄĚ) ^ 2 / #A := (le_div_iff (by positivity)).2 (mod_cast card_inv_mul_le_card_mul_sq hA‚āÄ)
    _ ‚Č§ (K * #A) ^ 2 / #A := by gcongr
