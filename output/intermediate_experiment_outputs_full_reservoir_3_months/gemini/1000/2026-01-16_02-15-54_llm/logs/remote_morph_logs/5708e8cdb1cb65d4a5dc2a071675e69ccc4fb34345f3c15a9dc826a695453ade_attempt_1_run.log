    refine ⟨fun i ↦ if hi : i ∈ Subtype.val '' (t : Set s) then w ⟨i, by aesop⟩ else 0,
      by aesop, ?_⟩
    · simp [Finset.sum_dite]
      have h {M : Type*} [AddCommMonoid M] (g : {x // x ∈ s} → M) :
          ∑ x in {x ∈ s | ∃ h : x ∈ s, ⟨x, h⟩ ∈ t}.attach, g ⟨x.1, (mem_filter.1 x.2).1⟩ = ∑ i in t, g i :=
        sum_bij (λ x _ ↦ ⟨x.1, (mem_filter.1 x.2).1⟩) (by aesop) (by aesop) (by aesop) (by aesop)
      constructor
      · exact h w |>.trans hw₁
      · rw [centerMass, affineCombination_eq_linearCombination R _ _ hw₁]
        simp_rw [ite_smul, zero_smul, sum_dite, h, hw₁, inv_one, one_smul]
