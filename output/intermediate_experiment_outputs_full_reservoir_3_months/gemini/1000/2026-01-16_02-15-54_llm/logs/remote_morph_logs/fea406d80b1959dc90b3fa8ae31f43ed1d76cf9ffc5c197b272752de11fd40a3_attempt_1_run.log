import Mathlib


namespace IMO2021P1

theorem result {n : ‚Ąē} (hn : 100 ‚Č§ n) {S : Finset ‚Ąē} (hS : S ‚äÜ Finset.Icc n (2 * n)) :
    (‚ąÉ a ‚ąą S, ‚ąÉ b ‚ąą S, a ‚Č† b ‚ąß IsSquare (a + b)) ‚ą®
    (‚ąÉ a ‚ąą Finset.Icc n (2 * n) \ S, ‚ąÉ b ‚ąą Finset.Icc n (2 * n) \ S,
      a ‚Č† b ‚ąß IsSquare (a + b)) := by
  let m := Nat.sqrt (2 * n + 3)
  let k := 2 * (m / 2 + 1) + 1
  have hk_odd : k % 2 = 1 := by omega
  let y := (k * k - 2 * k - 3) / 2
  let x := (k * k + 2 * k + 3) / 2
  let z := (k * k + 6 * k + 5) / 2
  have hk_sq : k * k = 2 * y + 2 * k + 3 := by omega
  have h_y_even : Even (k * k - 2 * k - 3) := by
    rw [‚Üź Nat.even_iff, Nat.even_sub (by omega)]; omega
  have h_x_even : Even (k * k + 2 * k + 3) := by
    rw [‚Üź Nat.even_iff]; omega
  have h_z_even : Even (k * k + 6 * k + 5) := by
    rw [‚Üź Nat.even_iff]; omega
  have hy_n : n ‚Č§ y := by
    have : k - 1 ‚Č• m + 1 := by omega
    have : (k - 1) ^ 2 ‚Č• (m + 1) ^ 2 := Nat.pow_le_pow_of_le_left this 2
    have : (k - 1) ^ 2 > 2 * n + 3 := Nat.lt_of_lt_of_le (Nat.lt_sqrt_succ _) this
    omega
  have hz_2n : z ‚Č§ 2 * n := by
    have hm2 : m * m ‚Č§ 2 * n + 3 := Nat.sqrt_le _
    have hmk : k ‚Č§ m + 3 := by omega
    have : 2 * z = (k + 3) ^ 2 - 4 := by omega
    have : 2 * z ‚Č§ (m + 6) ^ 2 - 4 := by omega
    have : 2 * z ‚Č§ m * m + 12 * m + 32 := by omega
    have : 2 * z ‚Č§ 2 * n + 3 + 12 * m + 32 := by omega
    have : 12 * m + 35 ‚Č§ 2 * n := by
      have : 12 * 12 * (2 * n + 3) ‚Č§ (2 * n - 35) * (2 * n - 35) := by omega
      rw [‚Üź Nat.sqrt_le_iff] at this; omega
    omega
  have h_range : {x, y, z} ‚äÜ Finset.Icc n (2 * n) := by
    intro t ht; simp only [Finset.mem_insert, Finset.mem_singleton] at ht
    rcases ht with rfl | rfl | rfl <;> simp [Finset.mem_Icc] <;> omega
  have h_diff : y < x ‚ąß x < z := by omega
  have hsq_xy : IsSquare (x + y) := ‚ü®k, by omega‚ü©
  have hsq_yz : IsSquare (y + z) := ‚ü®k + 1, by omega‚ü©
  have hsq_xz : IsSquare (x + z) := ‚ü®k + 2, by omega‚ü©
  by_cases hx : x ‚ąą S <;> by_cases hy : y ‚ąą S <;> by_cases hz : z ‚ąą S
  ¬∑ left; use x, y, hx, hy; omega
  ¬∑ left; use x, y, hx, hy; omega
  ¬∑ left; use x, z, hx, hz; omega
  ¬∑ left; use x, y, hx, hy; omega
  ¬∑ left; use y, z, hy, hz; omega
  ¬∑ right; use x, z; exact ‚ü®by simp [h_range, hx], by simp [h_range, hz], by omega, hsq_xz‚ü©
  ¬∑ right; use x, y; exact ‚ü®by simp [h_range, hx], by simp [h_range, hy], by omega, hsq_xy‚ü©
  ¬∑ right; use x, y; exact ‚ü®by simp [h_range, hx], by simp [h_range, hy], by omega, hsq_xy‚ü©

