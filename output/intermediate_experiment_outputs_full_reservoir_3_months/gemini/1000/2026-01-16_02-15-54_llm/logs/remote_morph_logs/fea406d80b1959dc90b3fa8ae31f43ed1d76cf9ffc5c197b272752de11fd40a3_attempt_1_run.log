    have h_lt_sqrt := Nat.lt_succ_sqrt n
    have h_m_plus_1 : m + 1 = n.sqrt := by omega
    rwa [h_m_plus_1] at h_lt_sqrt
  have ha : a ‚ąą Finset.Icc n (2 * n) := by
    constructor
    ¬∑ have : m * m - 8 * m ‚Č• 3 := by omega
      omega
    ¬∑ omega
  have hb : b ‚ąą Finset.Icc n (2 * n) := by
    constructor <;> omega
  have hc : c ‚ąą Finset.Icc n (2 * n) := by
    constructor <;> omega
  have hab : IsSquare (a + b) := ‚ü®2 * m - 1, by zify [hm]; ring‚ü©
  have hac : IsSquare (a + c) := ‚ü®2 * m, by zify [hm]; ring‚ü©
  have hbc : IsSquare (b + c) := ‚ü®2 * m + 1, by zify [hm]; ring‚ü©
  by_cases has : a ‚ąą S
  ¬∑ by_cases hbs : b ‚ąą S
    ¬∑ left; refine ‚ü®a, has, b, hbs, by omega, hab‚ü©
    ¬∑ by_cases hcs : c ‚ąą S
      ¬∑ left; refine ‚ü®a, has, c, hcs, by omega, hac‚ü©
      ¬∑ right; refine ‚ü®b, by simp [hb, hbs], c, by simp [hc, hcs], by omega, hbc‚ü©
  ¬∑ by_cases hbs : b ‚ąą S
