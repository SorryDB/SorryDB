  have hsq2 : n + 1 < (m + 2) * (m + 2) := by rw [h_m_plus_1]; exact Nat.lt_sqrt_add_one (n + 1)
  have hmn : m * m + 2 * m ‚Č§ n := by linarith
  have hnm : n ‚Č§ m * m + 4 * m + 2 := by linarith
  let x := 2 * m * m - 4 * m
  let y := 2 * m * m + 1
  let z := 2 * m * m + 4 * m
  have hx : x ‚ąą Finset.Icc n (2 * n) := by simp only [Finset.mem_Icc, x]; constructor <;> linarith
  have hy : y ‚ąą Finset.Icc n (2 * n) := by simp only [Finset.mem_Icc, y]; constructor <;> linarith
  have hz : z ‚ąą Finset.Icc n (2 * n) := by simp only [Finset.mem_Icc, z]; constructor <;> linarith
  have hxy : x < y := by linarith
  have hyz : y < z := by linarith
  have hxz : x < z := by linarith
  have sqxy : IsSquare (x + y) := ‚ü®2 * m - 1, by
    have : (2 * m - 1) * (2 * m - 1) + 4 * m = 4 * m * m + 1 := by
      cases m with | zero => contradiction | succ m => simp [Nat.succ_eq_add_one]; ring
    have : x + y + 4 * m = 4 * m * m + 1 := by simp [x, y]; rw [Nat.sub_add_comm (by linarith)]; ring
    linarith‚ü©
