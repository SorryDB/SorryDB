import Mathlib


namespace IMO2021P1

theorem result {n : ‚Ąē} (hn : 100 ‚Č§ n) {S : Finset ‚Ąē} (hS : S ‚äÜ Finset.Icc n (2 * n)) :
    (‚ąÉ a ‚ąą S, ‚ąÉ b ‚ąą S, a ‚Č† b ‚ąß IsSquare (a + b)) ‚ą®
    (‚ąÉ a ‚ąą Finset.Icc n (2 * n) \ S, ‚ąÉ b ‚ąą Finset.Icc n (2 * n) \ S,
      a ‚Č† b ‚ąß IsSquare (a + b)) := by
  by_contra! h
  let m := (n + 1).sqrt - 2
  have hm : 8 ‚Č§ m := by
    have := Nat.le_sqrt.2 (n := n + 1) (by omega)
    omega
  let a := 2 * m ^ 2 + 4 * m + 3
  let b := 2 * m ^ 2 - 2
  let c := 2 * m ^ 2 + 8 * m + 6
  have hM : ‚ąÄ x, x = a ‚ą® x = b ‚ą® x = c ‚Üí x ‚ąą Finset.Icc n (2 * n) := by
    intro x hx; have h1 := Nat.sqrt_le (n + 1); have h2 := Nat.lt_sqrt.1 (n := n + 1) (by omega)
    rw [Finset.mem_Icc]; rcases hx with (rfl | rfl | rfl) <;> omega
  have hf : ‚ąÄ {x y}, x ‚ąą Finset.Icc n (2 * n) ‚Üí y ‚ąą Finset.Icc n (2 * n) ‚Üí
      x ‚Č† y ‚Üí IsSquare (x + y) ‚Üí (x ‚ąą S ‚ÜĒ y ‚ąČ S) := by
    intro x y hx hy hxy hsq; by_contra! h'; rcases h' with ‚ü®h1, h2‚ü© | ‚ü®h1, h2‚ü©
    ¬∑ exact h.1 x h1 y h2 hxy hsq
    ¬∑ exact h.2 x ‚ü®hx, h1‚ü© y ‚ü®hy, h2‚ü© hxy hsq
  have hsq : IsSquare (a + b) ‚ąß IsSquare (b + c) ‚ąß IsSquare (c + a) :=
    ‚ü®‚ü®2 * m + 1, by ring‚ü©, ‚ü®2 * m + 2, by ring‚ü©, ‚ü®2 * m + 3, by ring‚ü©‚ü©
  have ha := hM a (by simp); have hb := hM b (by simp); have hc := hM c (by simp)
  have : a ‚ąą S ‚ÜĒ a ‚ąČ S := by
    rw [hf ha hb (by omega) hsq.1, hf hb hc (by omega) hsq.2.1, hf hc ha (by omega) hsq.2.2]
  simp at this
