  ¬∑ left; use x, hx, y, hy, hxy.ne, 2 * m + 1; ring
  ¬∑ left; use x, hx, y, hy, hxy.ne, 2 * m + 1; ring
  ¬∑ left; use x, hx, z, hz, hxz.ne, 2 * m + 2; ring
  ¬∑ right; use y; constructor; { simp [hy]; exact ‚ü®by linarith, by linarith‚ü© }
