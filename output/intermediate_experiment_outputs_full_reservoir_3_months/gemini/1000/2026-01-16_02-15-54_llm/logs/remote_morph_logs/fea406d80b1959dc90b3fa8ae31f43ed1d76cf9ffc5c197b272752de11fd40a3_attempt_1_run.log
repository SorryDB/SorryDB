    linarith
  have hz : z ‚Č§ 2 * n := by
    have h := Nat.le_sqrt.1 (Nat.le_add_left 2 j)
    linarith
  have hxI : x ‚ąą Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ‚ü®hx, by linarith‚ü©
  have hyI : y ‚ąą Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ‚ü®by linarith, by linarith‚ü©
  have hzI : z ‚ąą Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ‚ü®by linarith, hz‚ü©
  if hxy : x ‚ąą S ‚ÜĒ y ‚ąą S then
