  have hab : a ‚Č† b ‚ąß IsSquare (a + b) := ‚ü®by linarith, ‚ü®2 * k - 1, by nlinarith [hk_ge_9]‚ü©‚ü©
  have hac : a ‚Č† c ‚ąß IsSquare (a + c) := ‚ü®by linarith, ‚ü®2 * k, by nlinarith [hk_ge_9]‚ü©‚ü©
  have hbc : b ‚Č† c ‚ąß IsSquare (b + c) := ‚ü®by linarith, ‚ü®2 * k + 1, by nlinarith [hk_ge_9]‚ü©‚ü©
  have ha_range : a ‚ąą Finset.Icc n (2 * n) := by simp [Nat.find_spec h_ex]; linarith
