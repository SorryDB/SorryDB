theorem result {n : ‚Ąē} (hn : 100 ‚Č§ n) {S : Finset ‚Ąē} (hS : S ‚äÜ Finset.Icc n (2 * n)) :
    (‚ąÉ a ‚ąą S, ‚ąÉ b ‚ąą S, a ‚Č† b ‚ąß IsSquare (a + b)) ‚ą®
    (‚ąÉ a ‚ąą Finset.Icc n (2 * n) \ S, ‚ąÉ b ‚ąą Finset.Icc n (2 * n) \ S,
      a ‚Č† b ‚ąß IsSquare (a + b)) := by
  let k := Nat.sqrt (n + 1) - 1
  let x := 2 * k ^ 2 + 1
  let y := 2 * k ^ 2 - 4 * k
  let z := 2 * k ^ 2 + 4 * k
  have hk : 9 ‚Č§ k := Nat.le_sub_one_of_le (Nat.le_sqrt.mpr (by linarith))
  have hy : n ‚Č§ y := by
    have : n ‚Č§ (k + 2) ^ 2 - 2 := Nat.le_sub_one_of_lt (Nat.lt_sqrt_succ (n + 1))
    zify [hk] at this ‚äĘ; nlinarith
  have hz : z ‚Č§ 2 * n := by
    have : (k + 1) ^ 2 ‚Č§ n + 1 := Nat.sqrt_le (n + 1)
    zify at this ‚äĘ; nlinarith
  let T : Finset ‚Ąē := {x, y, z}
  have h_yx : y < x := by nlinarith
  have h_xz : x < z := by nlinarith
  have hT : T ‚äÜ Finset.Icc n (2 * n) := by
    intro m hm; simp [T] at hm; rcases hm with rfl | rfl | rfl <;> constructor <;> nlinarith
  have hT3 : T.card = 3 := by simp [T, h_yx.ne, h_xz.ne, (h_yx.trans h_xz).ne]
  have h_sq : ‚ąÄ a ‚ąą T, ‚ąÄ b ‚ąą T, a ‚Č† b ‚Üí IsSquare (a + b) := by
    intro a ha b hb hab; simp [T] at ha hb
    rcases ha with rfl | rfl | rfl <;> rcases hb with rfl | rfl | rfl <;> try contradiction
    any_goals (first | use 2 * k - 1; zify [hk]; ring | use 2 * k; ring | use 2 * k + 1; ring |
      (rw [add_comm]; first | use 2 * k - 1; zify [hk]; ring | use 2 * k; ring | use 2 * k + 1; ring))
  by_cases h : (T.filter (¬∑ ‚ąą S)).card ‚Č• 2
  ¬∑ left; obtain ‚ü®a, b, hab, ha, hb‚ü© := Finset.one_lt_card_iff.mp h
    simp at ha hb; exact ‚ü®a, ha.1, b, hb.1, hab, h_sq a ha.2 b hb.2 hab‚ü©
  ¬∑ right; have hT_sdiff : (T.filter (¬∑ ‚ąČ S)).card ‚Č• 2 := by
      rw [Finset.filter_not, Finset.card_sdiff (Finset.filter_subset _ _), Finset.card_filter] at h ‚äĘ
      linarith [hT3]
    obtain ‚ü®a, b, hab, ha, hb‚ü© := Finset.one_lt_card_iff.mp hT_sdiff
    simp at ha hb; exact ‚ü®a, Finset.mem_sdiff.mpr ‚ü®hT ha.2, ha.1‚ü©, b, Finset.mem_sdiff.mpr ‚ü®hT hb.2, hb.1‚ü©, hab, h_sq a ha.2 b hb.2 hab‚ü©

