  have hxy : IsSquare (x + y) := ‚ü®2 * m - 1, by omega‚ü©
  have hyz : IsSquare (y + z) := ‚ü®2 * m, by omega‚ü©
  have hxz : IsSquare (x + z) := ‚ü®2 * m + 1, by omega‚ü©
  let Sc := Finset.Icc n (2 * n) \ S
  by_cases hx : x ‚ąą S <;> by_cases hy : y ‚ąą S <;> by_cases hz : z ‚ąą S
  ¬∑ left; exact ‚ü®x, hx, y, hy, by omega, hxy‚ü©
  ¬∑ left; exact ‚ü®x, hx, y, hy, by omega, hxy‚ü©
  ¬∑ left; exact ‚ü®x, hx, z, hz, by omega, hxz‚ü©
  ¬∑ right; refine ‚ü®y, ?_, z, ?_, by omega, hyz‚ü© <;> simp [Sc, hI, *]
  ¬∑ left; exact ‚ü®y, hy, z, hz, by omega, hyz‚ü©
