  let x := 2 * m * m + 1
  let y := 2 * m * m - 4 * m
  let z := 2 * m * m + 4 * m
  have hm : 9 ‚Č§ m := Nat.le_sub_one_of_lt (Nat.lt_of_le_of_lt (by norm_num) (Nat.sqrt_le_sqrt hn))
  have hnm : n < (m + 2) * (m + 2) := Nat.lt_sqrt_add_one n
