theorem result {n : ‚Ąē} (hn : 100 ‚Č§ n) {S : Finset ‚Ąē} (hS : S ‚äÜ Finset.Icc n (2 * n)) :
    (‚ąÉ a ‚ąą S, ‚ąÉ b ‚ąą S, a ‚Č† b ‚ąß IsSquare (a + b)) ‚ą®
    (‚ąÉ a ‚ąą Finset.Icc n (2 * n) \ S, ‚ąÉ b ‚ąą Finset.Icc n (2 * n) \ S,
      a ‚Č† b ‚ąß IsSquare (a + b)) := by
  let m := n.sqrt - 1
  have hm : 9 ‚Č§ m := by
    have h100 : 10 * 10 ‚Č§ n := by omega
    have h10 : 10 ‚Č§ n.sqrt := Nat.le_sqrt.mpr h100
    omega
  let a := 2 * m * m - 4 * m
  let b := 2 * m * m + 1
  let c := 2 * m * m + 4 * m
  have h_m_sq : (m + 1) * (m + 1) ‚Č§ n := by
    have h_sqrt := Nat.sqrt_le n
    have h_m_plus_1 : m + 1 = n.sqrt := by omega
    rwa [h_m_plus_1]
