    (‚ąÉ a ‚ąą S, ‚ąÉ b ‚ąą S, a ‚Č† b ‚ąß IsSquare (a + b)) ‚ą®
    (‚ąÉ a ‚ąą Finset.Icc n (2 * n) \ S, ‚ąÉ b ‚ąą Finset.Icc n (2 * n) \ S,
      a ‚Č† b ‚ąß IsSquare (a + b)) := by
  by_contra! h
  obtain ‚ü®hS, hSc‚ü© := h
  let T := Finset.Icc n (2 * n)
  let f : ‚Ąē ‚Üí Prop := (¬∑ ‚ąą S)
  have hf : ‚ąÄ a b, a ‚ąą T ‚Üí b ‚ąą T ‚Üí a ‚Č† b ‚Üí IsSquare (a + b) ‚Üí (f a ‚ÜĒ ¬¨ f b) := by
    intro a b ha hb hab hsq
    by_cases haS : a ‚ąą S
    ¬∑ have hbS : b ‚ąČ S := őĽ hbS => hS a haS b hbS hab hsq
