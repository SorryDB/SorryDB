theorem result {n : ‚Ąē} (hn : 100 ‚Č§ n) {S : Finset ‚Ąē} (hS : S ‚äÜ Finset.Icc n (2 * n)) :
    (‚ąÉ a ‚ąą S, ‚ąÉ b ‚ąą S, a ‚Č† b ‚ąß IsSquare (a + b)) ‚ą®
    (‚ąÉ a ‚ąą Finset.Icc n (2 * n) \ S, ‚ąÉ b ‚ąą Finset.Icc n (2 * n) \ S,
      a ‚Č† b ‚ąß IsSquare (a + b)) := by
  let k := n.succ.sqrt - 1
  have hk : 9 ‚Č§ k := by
    have h101 : 10 * 10 ‚Č§ n + 1 := by omega
    have h10k : 10 ‚Č§ n.succ.sqrt := Nat.le_sqrt.mpr h101
    omega
  let a := 2 * k * k - 4 * k
  let b := 2 * k * k + 1
  let c := 2 * k * k + 4 * k
  have hab : a < b := by omega
  have hbc : b < c := by omega
  have hac : a < c := by omega
  have ha : n ‚Č§ a := by
    have h_lt : n.succ < (k + 2) * (k + 2) := Nat.lt_succ_sqrt n.succ
    omega
  have hc : c ‚Č§ 2 * n := by
    have h_le : (k + 1) * (k + 1) ‚Č§ n.succ := Nat.sqrt_le n.succ
    omega
  have ha_mem : a ‚ąą Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ‚ü®ha, by omega‚ü©
  have hb_mem : b ‚ąą Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ‚ü®by omega, by omega‚ü©
  have hc_mem : c ‚ąą Finset.Icc n (2 * n) := Finset.mem_Icc.mpr ‚ü®by omega, hc‚ü©
  if haS : a ‚ąą S then
    if hbS : b ‚ąą S then left; use a, haS, b, hbS, hab.ne, ‚ü®2 * k - 1, by omega‚ü©
    else if hcS : c ‚ąą S then left; use a, haS, c, hcS, hac.ne, ‚ü®2 * k, by omega‚ü©
    else right; use b, Finset.mem_sdiff.mpr ‚ü®hb_mem, hbS‚ü©, c, Finset.mem_sdiff.mpr ‚ü®hc_mem, hcS‚ü©, hbc.ne, ‚ü®2 * k + 1, by omega‚ü©
  else
    if hbS : b ‚ąČ S then right; use a, Finset.mem_sdiff.mpr ‚ü®ha_mem, haS‚ü©, b, Finset.mem_sdiff.mpr ‚ü®hb_mem, hbS‚ü©, hab.ne, ‚ü®2 * k - 1, by omega‚ü©
    else if hcS : c ‚ąČ S then right; use a, Finset.mem_sdiff.mpr ‚ü®ha_mem, haS‚ü©, c, Finset.mem_sdiff.mpr ‚ü®hc_mem, hcS‚ü©, hac.ne, ‚ü®2 * k, by omega‚ü©
    else left; use b, (by omega), c, (by omega), hbc.ne, ‚ü®2 * k + 1, by omega‚ü©

