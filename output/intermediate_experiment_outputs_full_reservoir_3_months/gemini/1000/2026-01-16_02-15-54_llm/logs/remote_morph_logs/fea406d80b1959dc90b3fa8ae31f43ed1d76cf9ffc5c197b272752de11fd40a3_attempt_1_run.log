theorem result {n : ‚Ąē} (hn : 100 ‚Č§ n) {S : Finset ‚Ąē} (hS : S ‚äÜ Finset.Icc n (2 * n)) :
    (‚ąÉ a ‚ąą S, ‚ąÉ b ‚ąą S, a ‚Č† b ‚ąß IsSquare (a + b)) ‚ą®
    (‚ąÉ a ‚ąą Finset.Icc n (2 * n) \ S, ‚ąÉ b ‚ąą Finset.Icc n (2 * n) \ S,
      a ‚Č† b ‚ąß IsSquare (a + b)) := by
  let k := (n + 1).sqrt - 1
  have hk : 9 ‚Č§ k := by
    have hn1 : 101 ‚Č§ n + 1 := Nat.add_le_add_right hn 1
    have hsq : 10 ‚Č§ (n + 1).sqrt := Nat.le_sqrt.mpr hn1
    exact Nat.le_sub_one_of_le hsq
  let x := 2 * k * k - 4 * k
  let y := 2 * k * k + 1
  let z := 2 * k * k + 4 * k
  have h_k2_sq : n + 1 < (k + 2) * (k + 2) := Nat.lt_sqrt_add_one (n + 1)
  have h_k1_sq : (k + 1) * (k + 1) ‚Č§ n + 1 := Nat.sqrt_le (n + 1)
  have x_in : x ‚ąą Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; constructor
    ¬∑ nlinarith [hk, h_k2_sq]
    ¬∑ nlinarith [hk, h_k1_sq]
  have y_in : y ‚ąą Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; constructor
    ¬∑ nlinarith [hk, h_k2_sq, h_k1_sq]
    ¬∑ nlinarith [hk, h_k1_sq]
  have z_in : z ‚ąą Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; constructor
    ¬∑ nlinarith [hk, h_k1_sq]
    ¬∑ nlinarith [hk, h_k1_sq]
  have hx_val : 2 * k * k ‚Č• 4 * k := by nlinarith [hk]
  have sq_xy : IsSquare (x + y) := ‚ü®2 * k - 1, by rw [x, y]; zify [hx_val]; ring‚ü©
  have sq_xz : IsSquare (x + z) := ‚ü®2 * k, by rw [x, z]; zify [hx_val]; ring‚ü©
  have sq_yz : IsSquare (y + z) := ‚ü®2 * k + 1, by rw [y, z]; zify [hx_val]; ring‚ü©
  by_cases hx : x ‚ąą S <;> by_cases hy : y ‚ąą S <;> by_cases hz : z ‚ąą S
  ¬∑ left; use x, hx, y, hy; exact ‚ü®by linarith, sq_xy‚ü©
  ¬∑ left; use x, hx, y, hy; exact ‚ü®by linarith, sq_xy‚ü©
  ¬∑ left; use x, hx, z, hz; exact ‚ü®by linarith, sq_xz‚ü©
  ¬∑ right; use y, (Finset.mem_sdiff.mpr ‚ü®y_in, hy‚ü©), z, (Finset.mem_sdiff.mpr ‚ü®z_in, hz‚ü©); exact ‚ü®by linarith, sq_yz‚ü©
  ¬∑ left; use y, hy, z, hz; exact ‚ü®by linarith, sq_yz‚ü©
  ¬∑ right; use x, (Finset.mem_sdiff.mpr ‚ü®x_in, hx‚ü©), z, (Finset.mem_sdiff.mpr ‚ü®z_in, hz‚ü©); exact ‚ü®by linarith, sq_xz‚ü©
  ¬∑ right; use x, (Finset.mem_sdiff.mpr ‚ü®x_in, hx‚ü©), y, (Finset.mem_sdiff.mpr ‚ü®y_in, hy‚ü©); exact ‚ü®by linarith, sq_xy‚ü©
  ¬∑ right; use x, (Finset.mem_sdiff.mpr ‚ü®x_in, hx‚ü©), y, (Finset.mem_sdiff.mpr ‚ü®y_in, hy‚ü©); exact ‚ü®by linarith, sq_xy‚ü©

