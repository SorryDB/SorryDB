import Mathlib


namespace IMO2021P1

theorem result {n : ‚Ąē} (hn : 100 ‚Č§ n) {S : Finset ‚Ąē} (hS : S ‚äÜ Finset.Icc n (2 * n)) :
    (‚ąÉ a ‚ąą S, ‚ąÉ b ‚ąą S, a ‚Č† b ‚ąß IsSquare (a + b)) ‚ą®
    (‚ąÉ a ‚ąą Finset.Icc n (2 * n) \ S, ‚ąÉ b ‚ąą Finset.Icc n (2 * n) \ S,
      a ‚Č† b ‚ąß IsSquare (a + b)) := by
  by_contra! h
  obtain ‚ü®h1, h2‚ü© := h
  let T := Finset.Icc n (2 * n)
  let k := (n + 1).sqrt - 1
  have hk : 9 ‚Č§ k := by
    have h100 : 10 * 10 ‚Č§ n + 1 := by omega
    have h10 : 10 ‚Č§ (n + 1).sqrt := Nat.le_sqrt.mpr h100
    omega
  let x := 2 * k * k + 1
  let y := 2 * k * k - 4 * k
  let z := 2 * k * k + 4 * k
  have hzk : k * k + 2 * k ‚Č§ n := by
    have := Nat.sqrt_le.mp (Nat.le_refl (n + 1).sqrt)
    omega
  have hnk : n ‚Č§ k * k + 4 * k + 2 := by
    have := Nat.lt_sqrt.mp (Nat.lt_succ_self (n + 1).sqrt)
    omega
  have hkk : k * k ‚Č• 9 * k := Nat.mul_le_mul_right k hk
  have hyT : y ‚ąą T := Finset.mem_Icc.mpr ‚ü®by omega, by omega‚ü©
  have hxT : x ‚ąą T := Finset.mem_Icc.mpr ‚ü®by omega, by omega‚ü©
  have hzT : z ‚ąą T := Finset.mem_Icc.mpr ‚ü®by omega, by omega‚ü©
  have h_tri : ‚ąÄ a b, a ‚ąą T ‚Üí b ‚ąą T ‚Üí a ‚Č† b ‚Üí IsSquare (a + b) ‚Üí (a ‚ąą S ‚ÜĒ b ‚ąČ S) := by
    intro a b haT hbT hne hsq
    constructor
    ¬∑ intro haS
      by_contra hbS
      exact h1 a haS b hbS hne hsq
    ¬∑ intro hbNS
      by_contra haNS
      exact h2 a (Finset.mem_sdiff.mpr ‚ü®haT, haNS‚ü©) b (Finset.mem_sdiff.mpr ‚ü®hbT, hbNS‚ü©) hne hsq
  have hxy_tri := h_tri x y hxT hyT (by omega) ‚ü®2 * k - 1, by dsimp [x, y]; zify [hk]; ring‚ü©
  have hyz_tri := h_tri y z hyT hzT (by omega) ‚ü®2 * k, by dsimp [y, z]; zify [hk]; ring‚ü©
  have hzx_tri := h_tri z x hzT hxT (by omega) ‚ü®2 * k + 1, by dsimp [z, x]; zify [hk]; ring‚ü©
  have : x ‚ąą S ‚ÜĒ x ‚ąČ S := by rwa [hxy_tri, hyz_tri, hzx_tri]
  simp_all

