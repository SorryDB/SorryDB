import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 1988, Problem 3

A function $f$ defined on the positive integers (and taking positive integers values) is given by:
f(1) = 1
f(3) = 3
f(2 \cdot n) = f(n)
f(4 \cdot n + 1) = 2 \cdot f(2 \cdot n + 1) - f(n)
f(4 \cdot n + 3) = 3 \cdot f(2 \cdot n + 1) - 2 \cdot f(n)
for all positive integers $n.$
Determine with proof the number of positive integers $\leq 1988$ for which $f(n) = n.$
-/

namespace Imo1988P3

determine solution : ℕ := 92

problem imo1988_p3 (f : ℕ+ → ℕ+)
    (h₀ : f 1 = 1)
    (h₁ : f 3 = 3)
    (h₂ : ∀ n, f (2 * n) = f n)
    (h₃ : ∀ n, f (4 * n + 1) + f n = 2 * f (2 * n + 1))
    (h₄ : ∀ n, f (4 * n + 3) + 2 * f n = 3 * f (2 * n + 1)) :
    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  have hf_odd : ∀ n : ℕ+, f (2 * n + 1) = 2 ^ (Nat.log2 (2 * n + 1)) + f n := by sorry
  have hf_rev : ∀ n : ℕ+, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by sorry
  have h_pal_count : ∀ k, Set.ncard {n : ℕ+ | (Nat.digits 2 n).length = k ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n} = 2 ^ ((k - 1) / 2) := by sorry
  have h_sum_pal : Set.ncard {n : ℕ+ | n < 1024 ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n} = 62 := by sorry
  have h_sum_pal_11 : Set.ncard {n : ℕ+ | 1024 ≤ n ∧ n ≤ 1988 ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n} = 30 := by sorry
  rw [solution]
  have h_union : {n | n ≤ 1988 ∧ f n = n} = {n : ℕ+ | n < 1024 ∧ f n = n} ∪ {n : ℕ+ | 1024 ≤ n ∧ n ≤ 1988 ∧ f n = n} := by sorry
  rw [h_union, Set.ncard_union]
  · simp_rw [hf_rev]
    rw [h_sum_pal, h_sum_pal_11]
    norm_num
  · rw [Set.disjoint_left]
    intro n hn1 hn2
    exact (not_le.mpr hn1.1) hn2.1
  · exact Set.ncard_finite _
  · exact Set.ncard_finite _
```
