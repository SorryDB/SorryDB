problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 1988, Problem 3

A function $f$ defined on the positive integers (and taking positive integers values) is given by:
f(1) = 1
f(3) = 3
f(2 \cdot n) = f(n)
f(4 \cdot n + 1) = 2 \cdot f(2 \cdot n + 1) - f(n)
f(4 \cdot n + 3) = 3 \cdot f(2 \cdot n + 1) - 2 \cdot f(n)
for all positive integers $n.$
Determine with proof the number of positive integers $\leq 1988$ for which $f(n) = n.$
-/

namespace Imo1988P3

determine solution : ℕ := 92

problem imo1988_p3 (f : ℕ+ → ℕ+)
    (h₀ : f 1 = 1)
    (h₁ : f 3 = 3)
    (h₂ : ∀ n, f (2 * n) = f n)
    (h₃ : ∀ n, f (4 * n + 1) + f n = 2 * f (2 * n + 1))
    (h₄ : ∀ n, f (4 * n + 3) + 2 * f n = 3 * f (2 * n + 1)) :
    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  unfold solution
  have hf : ∀ n : ℕ+, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := sorry
  have h_card : (Finset.range 1989).filter (λ n => 0 < n ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n) |>.card = 92 := by decide
  rw [Set.ncard_eq_toFinset_card, ← h_card]
  apply congr_arg Finset.card
  ext n
  simp only [Set.mem_toFinset, Set.mem_setOf_eq, Finset.mem_filter, Finset.mem_range, hf]
  constructor
  · rintro ⟨hn, hfn⟩
    exact ⟨by exact_mod_cast Nat.lt_succ_of_le hn, Nat.pos_of_strong_lt hn, hfn⟩
  · rintro ⟨hn, hpos, hfn⟩
    exact ⟨by exact_mod_cast Nat.le_of_lt_succ hn, hfn⟩
