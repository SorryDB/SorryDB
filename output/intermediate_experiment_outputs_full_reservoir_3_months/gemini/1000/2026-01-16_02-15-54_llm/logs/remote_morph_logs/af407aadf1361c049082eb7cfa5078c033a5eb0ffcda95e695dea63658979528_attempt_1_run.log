/-!
# International Mathematical Olympiad 1988, Problem 3

A function $f$ defined on the positive integers (and taking positive integers values) is given by:
f(1) = 1
f(3) = 3
f(2 \cdot n) = f(n)
f(4 \cdot n + 1) = 2 \cdot f(2 \cdot n + 1) - f(n)
f(4 \cdot n + 3) = 3 \cdot f(2 \cdot n + 1) - 2 \cdot f(n)
for all positive integers $n.$
Determine with proof the number of positive integers $\leq 1988$ for which $f(n) = n.$
-/

namespace Imo1988P3

determine solution : ℕ := 92

problem imo1988_p3 (f : ℕ+ → ℕ+)
    (h₀ : f 1 = 1)
    (h₁ : f 3 = 3)
    (h₂ : ∀ n, f (2 * n) = f n)
    (h₃ : ∀ n, f (4 * n + 1) + f n = 2 * f (2 * n + 1))
    (h₄ : ∀ n, f (4 * n + 3) + 2 * f n = 3 * f (2 * n + 1)) :
    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  have f_rev : ∀ n : ℕ+, (f n : ℕ) = Nat.ofDigits 2 (Nat.digits 2 n).reverse := by
    intro n
    induction n using PNat.strong_induction_on with | h n IH =>
    rcases n with ⟨n, hn⟩
    match n with
    | 1 => simp [h₀]; rfl
    | 2 => simp [h₂, h₀]; rfl
    | 3 => simp [h₁, h₀]; rfl
    | n + 1 =>
      if henv : (n + 1) % 2 = 0 then
        have h_even : n + 1 = 2 * ((n + 1) / 2) := (Nat.even_iff_mod_2_eq_zero.mpr henv).two_mul_div.symm
        have h_pos : 0 < (n + 1) / 2 := Nat.div_pos (by linarith) (by linarith)
        let m : ℕ+ := ⟨(n + 1) / 2, h_pos⟩
        have : m < ⟨n + 1, hn⟩ := by simp [m]; apply Nat.div_lt_self <;> linarith
        calc (f ⟨n + 1, hn⟩ : ℕ) = f m := by rw [h_even] at *; exact h₂ m
             _ = Nat.ofDigits 2 (Nat.digits 2 m).reverse := by rw [IH m this]
             _ = Nat.ofDigits 2 (Nat.digits 2 (2 * m)).reverse := by
               simp [Nat.digits_def, Nat.ofDigits_def]
               have : (Nat.digits 2 (m : ℕ)).reverse.concat 0 = 0 :: (Nat.digits 2 (m : ℕ)).reverse := by sorry
               sorry
      else sorry
  have f_eq_n : ∀ n : ℕ+, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by
    intro n
    rw [PNat.ext_iff, f_rev n]
    exact ⟨λ h => Nat.ofDigits_inj (Nat.digits_def 2 n ▸ h.symm), λ h => h ▸ (Nat.ofDigits_digits 2 n).symm⟩
  let S := {n : ℕ+ | n ≤ 1988 ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n}
  change Set.ncard S = 92
  have : S = (Finset.range 1989).filter (λ n => 0 < n ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n) |>.toSet := by
    ext n; simp [S]; constructor <;> intro ⟨h1, h2⟩ <;> refine ⟨by linarith, ?_⟩ <;> assumption
  rw [this, Set.ncard_toSet]
  native_decide
