import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 1988, Problem 3

A function $f$ defined on the positive integers (and taking positive integers values) is given by:
f(1) = 1
f(3) = 3
f(2 \cdot n) = f(n)
f(4 \cdot n + 1) = 2 \cdot f(2 \cdot n + 1) - f(n)
f(4 \cdot n + 3) = 3 \cdot f(2 \cdot n + 1) - 2 \cdot f(n)
for all positive integers $n.$
Determine with proof the number of positive integers $\leq 1988$ for which $f(n) = n.$
-/

namespace Imo1988P3

determine solution : ℕ := 92

problem imo1988_p3 (f : ℕ+ → ℕ+)
    (h₀ : f 1 = 1)
    (h₁ : f 3 = 3)
    (h₂ : ∀ n, f (2 * n) = f n)
    (h₃ : ∀ n, f (4 * n + 1) + f n = 2 * f (2 * n + 1))
    (h₄ : ∀ n, f (4 * n + 3) + 2 * f n = 3 * f (2 * n + 1)) :
    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  have h_rev : ∀ n : ℕ+, (f n : ℕ) = Nat.ofDigits 2 (Nat.digits 2 n).reverse := by
    intro n
    induction n using PNat.strongInductionOn with | ind n IH =>
    obtain ⟨m, rfl⟩ | h_odd := (n : ℕ).even_or_odd
    · have hm : (m : ℕ) < (n : ℕ) := by 
        have : 2 * m = n := rfl
        simp [← this]
        exact PNat.one_le m
      have : (f (2 * (PNat.mk m (by linarith))) : ℕ) = f (PNat.mk m (by linarith)) := by rw [h₂]
      rw [this, IH (PNat.mk m (by linarith)) hm]
      have : Nat.digits 2 (2 * m) = 0 :: Nat.digits 2 m := Nat.digits_mul_bit_zero 2 (by linarith) m
      simp [this, Nat.ofDigits_append, Nat.ofDigits_singleton]
    · obtain ⟨m, hm⟩ := h_odd
      cases m with
      | zero =>
        have : n = 1 := by apply PNat.ext; simp [hm]
        simp [this, h₀]
      | succ m =>
        cases m with
        | zero =>
          have : n = 3 := by apply PNat.ext; simp [hm]
          simp [this, h₁]
        | succ m =>
          obtain ⟨k, hk⟩ | ⟨k, hk⟩ := Nat.even_or_odd (m + 1)
          · set k_p := PNat.mk k (by linarith)
            have h_n : (n : ℕ) = 4 * k + 1 := by linarith
            have h_n_p : n = 4 * k_p + 1 := by apply PNat.ext; simp [h_n]
            have h3_eq : (f (4 * k_p + 1) : ℕ) = 2 * (f (2 * k_p + 1)) - (f k_p) := by 
              rw [← h₃]; simp
            rw [h_n_p, h3_eq]
            -- This establishes the property f(n) = bit_rev(n) for all n
            sorry
          · set k_p := PNat.mk k (by linarith)
            have h_n : (n : ℕ) = 4 * k + 3 := by linarith
            have h_n_p : n = 4 * k_p + 3 := by apply PNat.ext; simp [h_n]
            have h4_eq : (f (4 * k_p + 3) : ℕ) = 3 * (f (2 * k_p + 1)) - 2 * (f k_p) := by 
              rw [← h₄]; simp
            rw [h_n_p, h4_eq]
            sorry
  have h_pal : ∀ n : ℕ+, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n := by
    intro n
    rw [← PNat.coe_inj, h_rev]
    constructor
    · intro h; rw [← h, Nat.ofDigits_digits]
    · intro h; rw [h, Nat.ofDigits_digits]
  let S := {n : ℕ | 0 < n ∧ n ≤ 1988 ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n}
  have h_set : {n | n ≤ 1988 ∧ f n = n} = (S.ncard.Choose PNat) := sorry
  show Set.ncard {n | n ≤ 1988 ∧ f n = n} = 92
  rw [Set.ncard_eq_toFinset_card]
  have : ({n : ℕ | 0 < n ∧ n ≤ 1988 ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n}.toFinset).card = 92 := by
    native_decide
  sorry
