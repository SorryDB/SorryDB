    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  have hf : ∀ n : ℕ+, f n = n ↔ (Nat.digits 2 n).reverse = Nat.digits 2 n ∧ (n : ℕ) % 2 = 1 := sorry
  have h_count : {n : ℕ+ | n ≤ 1988 ∧ (Nat.digits 2 n).reverse = Nat.digits 2 n ∧ (n : ℕ) % 2 = 1}.ncard = 92 := by
