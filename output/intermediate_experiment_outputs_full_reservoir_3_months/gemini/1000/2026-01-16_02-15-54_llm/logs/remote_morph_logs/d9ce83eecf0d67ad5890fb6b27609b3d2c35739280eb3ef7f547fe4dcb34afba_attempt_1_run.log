lemma tendsto_sinh_rx_over_x (r : ℝ) :
    Tendsto (fun x : ℝ => Real.sinh (r * x) / x) (𝓝[≠] 0) (𝓝 r) := by sorry

@[sorryful]
lemma limit_S_saddle(r : ℝ) :
    Tendsto (fun k : ℝ => k * Real.sinh (r / k)) atTop (𝓝 r) := by
  simp_rw [mul_sinh_as_div]
  refine (tendsto_sinh_rx_over_x r).comp (tendsto_nhdsWithin_iff.mpr ?_)
  exact ⟨tendsto_inv_atTop_zero, (eventually_gt_atTop 0).mono fun x hx => inv_ne_zero (ne_of_gt hx)⟩

end SpatialGeometry

end Cosmology
