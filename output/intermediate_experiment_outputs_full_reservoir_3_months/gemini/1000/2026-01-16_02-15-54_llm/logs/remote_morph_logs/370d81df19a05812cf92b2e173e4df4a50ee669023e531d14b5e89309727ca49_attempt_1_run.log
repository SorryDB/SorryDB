import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let v : Fin m → (A → ℚ) := fun k a => if (a : ℤ) ∈ B k then 1 else 0
  have hv : ∀ k, ∑ a in A, v k a * (a : ℚ) = (m : ℚ) ^ ((k : ℕ) + 1) := fun k => by
    simp [v]; rw [← hB k]; norm_cast
    exact sum_subset (hBA k) (fun x _ hx => by simp [hx])
  have h_linear_indep : ∀ (k1 k2 : Fin m), k1 ≠ k2 → v k1 ≠ v k2 := fun k1 k2 hne h_eq => by
    have h1 := hv k1; have h2 := hv k2; rw [h_eq] at h1
    rw [h1] at h2; norm_cast at h2
    exact hne ((pow_right_inj (by linarith [hm]) (by linarith)).mp h2)
  set X := Matrix.of (fun (k : Fin m) (a : A) => v k a)
  have h_rank : (m : ℚ) / 2 ≤ #A := by
    by_contra h_lt
    push_neg at h_lt
    have h_dim : (Matrix.range X.transpose).toSubmodule.rank ≤ #A := by
      convert Submodule.rank_le_card_width (Matrix.range X.transpose).toSubmodule
      simp
    sorry
  exact h_rank
