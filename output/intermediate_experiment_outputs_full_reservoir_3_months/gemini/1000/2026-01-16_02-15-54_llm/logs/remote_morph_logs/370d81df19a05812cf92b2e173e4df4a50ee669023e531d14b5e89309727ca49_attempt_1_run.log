    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let f : (Fin m → Fin m) → (↑A → ℤ) := λ y a => ∑ k, if (a : ℤ) ∈ B k then (y k : ℤ) else 0
  have hf : ∀ y, (∑ a : ↑A, (a : ℤ) * f y a) = m * ∑ k, (y k : ℕ) * m ^ (k : ℕ) := by
    intro y; simp_rw [f, Finset.univ_sum_comm, ← Finset.mul_sum]; simp [← hB, mul_comm, Nat.pow_succ, mul_assoc]
  have h_inj : Function.Injective f := by
    intro y1 y2 hy
    have : (λ y => m * ∑ k, (y k : ℕ) * m ^ (k : ℕ)) y1 = (λ y => m * ∑ k, (y k : ℕ) * m ^ (k : ℕ)) y2 := by
      simp_rw [← hf, hy]
    replace this := Nat.eq_of_mul_eq_mul_left (by linarith) this
    have h_ofD : ∀ y : Fin m → Fin m, Nat.ofDigits m (List.ofFn λ k => (y k : ℕ)) = ∑ k, (y k : ℕ) * m ^ (k : ℕ) := by
      intro y; rw [Nat.ofDigits_eq_sum, List.length_ofFn, List.enum_ofFn]; simp [Function.comp_def]
    rw [← h_ofD, ← h_ofD] at this
    ext k; apply_fun (λ l => l.get ⟨k, by simp⟩) at (List.ofFn_injective (Nat.ofDigits_inj_of_lt (by linarith) (λ x hx => by rcases List.mem_ofFn.1 hx with ⟨k, rfl⟩; exact k.2) (λ x hx => by rcases List.mem_ofFn.1 hx with ⟨k, rfl⟩; exact k.2) (by simp) this))
    simpa using h_eq
  have hAc : 0 < A.card := by
    by_contra hc; have h0 : B 0 = ∅ := Finset.subset_empty.1 (by simpa [Finset.card_eq_zero.1 hc] using hBA 0)
    simpa [h0] using hB 0
  have : m ^ m ≤ (m * (m - 1) + 1) ^ A.card := by
    let S : Finset (↑A → ℤ) := Finset.univ.pi (λ _ => Finset.Icc 0 (m * (m - 1)))
    have hfS : ∀ y, f y ∈ S := by
      intro y; simp [f]; intro a ha; constructor
