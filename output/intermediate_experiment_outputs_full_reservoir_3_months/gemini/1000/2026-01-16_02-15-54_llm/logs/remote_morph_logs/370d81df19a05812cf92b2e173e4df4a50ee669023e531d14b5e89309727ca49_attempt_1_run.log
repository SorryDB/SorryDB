    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let f : Fin m → A → ℚ := λ k a => if (a : ℤ) ∈ B k then 1 else 0
  let M : Matrix (Fin m) A ℚ := Matrix.of f
  let v : Fin m → ℚ := λ k => (m : ℚ) ^ ((k : ℕ) + 1)
  have hM : M.mulVec (λ a => (a : ℚ)) = v := by
    funext k
