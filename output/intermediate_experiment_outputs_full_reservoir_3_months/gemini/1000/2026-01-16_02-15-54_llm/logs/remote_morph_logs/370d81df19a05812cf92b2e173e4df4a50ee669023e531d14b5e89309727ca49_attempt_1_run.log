  have h_injective : Function.Injective f := by
    intro x y h
    simp [f] at h
    have h_eq : ∑ i : Fin m, (if x i then 1 else 0) * m ^ ((i : ℕ) + 1) = ∑ i : Fin m, (if y i then 1 else 0) * m ^ ((i : ℕ) + 1) := by
      convert h using 2 <;> split_ifs <;> simp
