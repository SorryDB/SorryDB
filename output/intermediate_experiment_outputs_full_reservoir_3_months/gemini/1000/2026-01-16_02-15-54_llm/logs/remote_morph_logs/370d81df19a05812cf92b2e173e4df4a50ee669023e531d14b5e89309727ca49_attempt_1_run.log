    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let n := #A
  set v : Fin m → (A → ℤ) := fun k a => if (a : ℤ) ∈ B k then 1 else 0
  have h_sum : ∀ k, ∑ a, a.1 * v k a = m ^ ((k : ℕ) + 1) := by
