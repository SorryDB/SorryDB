  let c : Fin m → A → ℤ := fun k a => if (a : ℤ) ∈ B k then 1 else 0
  have h_sum : ∀ k, ∑ a, c k a * (a : ℤ) = m ^ ((k : ℕ) + 1) := by
    intro k
    simp_rw [c, ← Finset.sum_filter, Finset.filter_mem_eq_inter,
      Finset.inter_eq_right.mpr (hBA k), hB k]
  let r : Fin m → A → ℚ := fun k a => c k a
  have h_lin_indep : LinearIndependent ℚ r := by
    rw [linearIndependent_iff']
    intro s g h_sum_lin i hi
    let P : ℚ[X] := ∑ j ∈ s, g j * X ^ (j : ℕ)
    have h_poly : ∀ a : A, (∑ j ∈ s, g j * (c j a : ℚ)) = 0 := by
      intro a
      have := congr_fun h_sum_lin a
      simp only [r, Pi.zero_apply] at this
      exact this
    have h_zero : P.eval (m : ℚ) = 0 := by
      simp only [P, Polynomial.eval_sum, Polynomial.eval_mul, Polynomial.eval_pow, Polynomial.eval_X]
      have : (∑ j ∈ s, g j * (m : ℚ) ^ (j : ℕ)) * m = ∑ j ∈ s, g j * (m : ℚ) ^ ((j : ℕ) + 1) := by
        simp_rw [mul_sum, ← mul_assoc, ← pow_succ]; norm_cast
      rw [← mul_eq_zero_iff]
      nth_rw 2 [← this]
      simp_rw [← h_sum, ← Finset.sum_comm]
      simp only [mul_sum, ← mul_assoc]
      rw [Finset.sum_eq_zero]
      intro a ha
      rw [← sum_mul, h_poly a, zero_mul]
    have m_gt_one : 1 < (m : ℚ) := by norm_cast
    have coeffs_zero : ∀ j ∈ s, g j = 0 := by
      by_contra h_exists
      push_neg at h_exists
      let k := s.filter (fun j => g j ≠ 0)
      let k_max := k.max' (by
        rcases h_exists with ⟨j, hj, hgj⟩
        exact ⟨j, Finset.mem_filter.mpr ⟨hj, hgj⟩⟩)
      have h_max_mem : k_max ∈ s := (Finset.mem_filter.mp (Finset.max'_mem k _)).1
      have h_max_nz : g k_max ≠ 0 := (Finset.mem_filter.mp (Finset.max'_mem k _)).2
      let Q : ℚ[X] := ∑ j ∈ s, g j * X ^ (j : ℕ)
      have : |g k_max * (m : ℚ) ^ (k_max : ℕ)| = |∑ j ∈ s \ {k_max}, g j * (m : ℚ) ^ (j : ℕ)| := by
        rw [← Finset.sum_add_sum_diff h_max_mem, h_zero] at h_sum_lin
        simp [P] at h_zero
        rw [Finset.sum_eq_add_sum_diff h_max_mem] at h_zero
        rw [← eq_neg_iff_add_eq_zero, abs_neg] at h_zero
        exact h_zero
      sorry -- Final contradiction between power of m and other terms
    exact coeffs_zero i hi
  have h_rank : m ≤ #A := by
    simpa using (h_lin_indep.fintype_card_le_card)
  exact (div_le_iff₀ (show (0 : ℚ) < 2 by norm_num)).mpr (by
    norm_cast
    linarith)

