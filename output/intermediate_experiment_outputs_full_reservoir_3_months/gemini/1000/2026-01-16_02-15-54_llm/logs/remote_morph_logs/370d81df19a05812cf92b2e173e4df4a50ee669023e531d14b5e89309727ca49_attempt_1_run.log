import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  have h_m_pos : 0 < m := by linarith
  have h1 : m ^ m ≤ (m * m) ^ #A := by
    let f : (Fin m → Fin m) → ({x // x ∈ A} → Fin (m * m)) := fun c a =>
      ⟨∑ k, if (a : ℤ) ∈ B k then (c k : ℕ) else 0, by
        calc ∑ k, (if (a : ℤ) ∈ B k then (c k : ℕ) else 0)
          _ ≤ ∑ k : Fin m, (m - 1) := Finset.sum_le_sum (fun k _ => by split_ifs <;> exact Nat.le_pred_of_lt (c k).is_lt)
          _ = m * (m - 1) := by simp
          _ < m * m := by nlinarith [hm]⟩
    have inj : Function.Injective f := by
      intros c1 c2 h
      have h1 : ∀ a : {x // x ∈ A}, (∑ k, if (a : ℤ) ∈ B k then (c1 k : ℕ) else 0) = (∑ k, if (a : ℤ) ∈ B k then (c2 k : ℕ) else 0) := by
        intro a; injection (congr_fun h a)
      have h2 : ∑ k, (c1 k : ℤ) * m ^ ((k : ℕ) + 1) = ∑ k, (c2 k : ℤ) * m ^ ((k : ℕ) + 1) := by
        simp_rw [← hB, Finset.mul_sum, Finset.sum_comm]
        refine Finset.sum_congr rfl (fun i hi => ?_)
        simp_rw [mul_comm (i : ℤ), ← Finset.mul_sum]
        congr; norm_cast; exact h1 ⟨i, hi⟩
      have h3 : m * ∑ k, (c1 k : ℕ) * m ^ (k : ℕ) = m * ∑ k, (c2 k : ℕ) * m ^ (k : ℕ) := by
        norm_cast at h2; simp_rw [pow_succ, ← mul_assoc, ← Finset.mul_sum] at h2; exact h2
      have h4 : (List.ofFn (fun k : Fin m => (c1 k : ℕ))).eval m = (List.ofFn (fun k : Fin m => (c2 k : ℕ))).eval m := by
        rw [List.eval_eq_sum, List.eval_eq_sum]
        simp_rw [List.length_ofFn, List.get_ofFn]
        exact Nat.mul_left_cancel h_m_pos h3
      have h5 : List.ofFn (fun k : Fin m => (c1 k : ℕ)) = List.ofFn (fun k : Fin m => (c2 k : ℕ)) :=
        Nat.eval_digits_inj hm (fun d hd => by rcases List.mem_ofFn.1 hd with ⟨i, rfl⟩; exact (c1 i).is_lt)
          (fun d hd => by rcases List.mem_ofFn.1 hd with ⟨i, rfl⟩; exact (c2 i).is_lt) h4 (by simp)
      ext k; exact (List.vec_ofFn_inj h5) k
    convert Fintype.card_le_of_injective f inj
    simp; rw [pow_mul]
  have h_m_gt_1 : 1 < m := hm
  have h2 : m ≤ 2 * #A := by
    by_contra hlt
    have : (m * m) ^ #A < m ^ m := by
      rw [← pow_mul]
      exact pow_lt_pow_right h_m_gt_1 (not_le.1 hlt)
    exact (this.not_le h1).elim
  norm_cast at h2; linarith

end IMO2021P6
