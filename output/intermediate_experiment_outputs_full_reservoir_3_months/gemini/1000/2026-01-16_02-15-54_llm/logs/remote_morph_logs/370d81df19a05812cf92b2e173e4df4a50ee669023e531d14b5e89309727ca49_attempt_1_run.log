    intro x y hxy
    apply h_injective
    rw [h_fc x, h_fc y]
    simp [hxy]
  let c2 : (Fin m → Bool) → (A → Fin 2) := fun x a => ⟨(c x a % 2).toNat, by
    have : c x a % 2 = 0 ∨ c x a % 2 = 1 := by
      have : 0 ≤ c x a := sum_nonneg (λ _ _ => by split_ifs <;> norm_num)
      have : 0 < 2 := by norm_num
      convert Int.emod_two_eq_zero_or_one (c x a)
    rcases this with h | h <;> rw [h] <;> norm_num⟩
  by_contra h_lt
  simp only [not_le] at h_lt
  have h_card_bool : Fintype.card (Fin m → Bool) = 2 ^ m := by simp
  have h_card_map : Fintype.card (A → Fin 2) = 2 ^ n := by simp
  have : 2 ^ n < 2 ^ (m / 2 : ℚ) := by
    apply pow_lt_pow_right₀ (by norm_num) h_lt
  let c_mod : (Fin m → Bool) → (A → ℤ) := λ x a => c x a % 2
  have : 2 ^ m ≤ (2 : ℚ) ^ (2 * n) := by
