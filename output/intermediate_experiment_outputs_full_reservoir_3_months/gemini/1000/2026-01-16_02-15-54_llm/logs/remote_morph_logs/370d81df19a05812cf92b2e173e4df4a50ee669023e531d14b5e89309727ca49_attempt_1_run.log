import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  by_contra h
  push_neg at h
  have h_m_pos : 0 < m := zero_lt_two.trans_le hm
  have h2 : 2 * A.card < m := by
    rw [← @Nat.cast_lt ℚ]
    calc (2 * A.card : ℚ) = 2 * (A.card : ℚ) := by rw [Nat.cast_mul, Nat.cast_two]
      _ < 2 * (m / 2) := by gcongr
      _ = m := by ring
  let f : (Fin m → Fin m) → (A → Fin (m * m)) := fun u a =>
    ⟨∑ i, (u i : ℕ) * (if (a : ℤ) ∈ B i then 1 else 0), by
      have h3 : ∀ i, (u i : ℕ) * (if (a : ℤ) ∈ B i then 1 else 0) ≤ m - 1 := fun i => by
        split_ifs
        · exact Nat.le_sub_one_of_lt (u i).is_lt
        · exact Nat.zero_le _
      calc ∑ i, (u i : ℕ) * (if (a : ℤ) ∈ B i then 1 else 0) ≤ ∑ i : Fin m, (m - 1) := Finset.sum_le_sum (fun i _ => h3 i)
        _ = m * (m - 1) := by simp
        _ < m * m := Nat.mul_lt_mul_of_pos_right (Nat.sub_one_lt h_m_pos) h_m_pos⟩
  have h_card : Fintype.card (Fin m → Fin m) > Fintype.card (A → Fin (m * m)) := by
    rw [Fintype.card_fun, Fintype.card_fin, Fintype.card_fun, Fintype.card_fin]
    calc (m * m) ^ A.card = m ^ (2 * A.card) := by rw [pow_mul]
      _ ≤ m ^ (m - 1) := Nat.pow_le_pow_of_le_right hm.one_le (Nat.le_sub_one_of_lt h2)
      _ < m ^ m := Nat.pow_lt_pow_of_lt_right (Nat.le_step hm) (Nat.sub_one_lt h_m_pos)
  obtain ⟨u, u', h_ne, h_fu⟩ := Fintype.exists_ne_map_eq_of_card_lt_card f h_card
  have h_sum_base : (List.ofFn fun i : Fin m => (u i : ℕ)).ofDigits m = (List.ofFn fun i : Fin m => (u' i : ℕ)).ofDigits m := by
    apply Nat.mul_left_cancel h_m_pos
    simp_rw [Nat.ofDigits_eq_sum_map_pow, List.ofFn_eq_map, List.mapIdx_eq_enum_map, List.enum_map, List.map_map, Function.comp_apply, List.sum_map_coe, List.finRange_m, List.attach_map_val, List.map_coe_finRange, Nat.sum_mul, ← pow_succ]
    set x := fun i (a : A) => if (a : ℤ) ∈ B i then 1 else 0
    have h_f_eq : ∀ a, ∑ i, (u i : ℕ) * x i a = ∑ i, (u' i : ℕ) * x i a := fun a => by injection h_fu with h_eq; exact congr_fun h_eq a
    calc ∑ i, (u i : ℕ) * m ^ ((i : ℕ) + 1) = ∑ i, (u i : ℕ) * ∑ a ∈ A, (if (a : ℤ) ∈ B i then 1 else 0 : ℤ) * a := by
        simp_rw [← hB]; exact Finset.sum_congr rfl (fun i _ => by rw [Finset.sum_subset (hBA i) (fun a ha hb => by simp [hb])]; simp)
      _ = ∑ i, (u i : ℕ) * ∑ a ∈ A, (x i a : ℤ) * a := rfl
