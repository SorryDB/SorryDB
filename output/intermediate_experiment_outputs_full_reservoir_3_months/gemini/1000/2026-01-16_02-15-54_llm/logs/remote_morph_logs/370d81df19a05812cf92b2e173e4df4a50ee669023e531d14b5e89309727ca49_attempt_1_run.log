    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let f : Finset (Fin m) → ℤ := λ S => ∑ k ∈ S, m ^ ((k : ℕ) + 1)
