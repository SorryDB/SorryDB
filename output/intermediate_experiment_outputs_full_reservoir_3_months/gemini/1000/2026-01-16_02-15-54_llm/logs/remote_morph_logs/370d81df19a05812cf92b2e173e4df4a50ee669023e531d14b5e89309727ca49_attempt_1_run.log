      calc ∑ k ∈ s₁, (m : ℤ) ^ ((k : ℕ) + 1)
        _ = ∑ k ∈ s₁, ∑ a, a.1 * v k a := by simp [h_sum]
        _ = ∑ a, a.1 * ∑ k ∈ s₁, v k a := by rw [sum_comm]
        _ = ∑ a, a.1 * ∑ k ∈ s₂, v k a := by simp_rw [h_eq]
        _ = ∑ k ∈ s₂, ∑ a, a.1 * v k a := by rw [sum_comm]
        _ = ∑ k ∈ s₂, (m : ℤ) ^ ((k : ℕ) + 1) := by simp [h_sum]
    have m_pos : 0 < (m : ℤ) := by exact_mod_cast Nat.zero_lt_of_lt hm
    have m_gt_one : 1 < (m : ℤ) := by exact_mod_cast hm
    clear h_sum h_eq hBA hB A B
    induction' s₁ using Finset.induction_on with k₁ s₁ hk₁ ih generalizing s₂
    · symm
      rw [sum_empty] at h_eq_sum
      exact Finset.sum_eq_zero_iff_of_nonneg (fun k _ => pow_pos m_pos _) h_eq_sum
    · have h_mem : ∃ k₂ ∈ s₂, (k₂ : ℕ) ≤ (k₁ : ℕ) := by
        by_contra h_none
        push_neg at h_none
        have h_lt : ∑ k ∈ s₂, (m : ℤ) ^ ((k : ℕ) + 1) < (m : ℤ) ^ ((k₁ : ℕ) + 1) := by
          apply (sum_lt_sum_native (f := fun k => (m : ℤ) ^ ((k : ℕ) + 1)) s₂ (range (k₁ : ℕ).succ) ?_ ?_).trans_le
          · intro k hk; simp; exact h_none k hk
          · simp; intro x hx; exact pow_pos m_pos _
          · rw [sum_range_pow (x := (m : ℤ)) (n := (k₁ : ℕ) + 1)]
            apply Int.ediv_le_self
            exact Int.sub_nonneg.mpr m_gt_one
        rw [← h_eq_sum, sum_insert hk₁] at h_lt
        have := add_le_self (m ^ (k₁ + 1)) (sum k ∈ s₁, m ^ (k + 1)) (sum_nonneg (fun _ _ => pow_nonneg m_pos.le _))
        exact h_lt.not_le this
      let k_max := (s₁ ∪ s₂).max' (by rw [Finset.nonempty_union]; left; exact ⟨k₁, mem_insert_self _ _⟩)
