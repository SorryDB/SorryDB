    have := Nat.exists_eq_pow_digits_sum (b := m) h_base (if y · then 1 else 0)
    exact Bool.coe_nat_inj (Nat.pow_digits_inj h_base h_val (by intro i; split_ifs <;> exact hm) (by simpa using h_eq) i)
  let c : (Fin m → Bool) → (A → ℤ) := fun x a => ∑ i : Fin m, if x i ∧ (a : ℤ) ∈ B i then 1 else 0
  have h_fc : ∀ x, f x = ∑ a ∈ A, c x a * a := by
    intro x; simp [f, c, hB]
    rw [sum_comm]
    apply sum_congr rfl
    intro i _
    split_ifs with hxi
    · rw [← hB i, ← sum_filter, sum_congr (Finset.ext (by simp [hBA])) (λ _ _ => rfl)]
