    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let A' := A.filter (· ≠ 0)
  let n' := A'.card
  let S := Fintype.piFinset (λ _ : Fin m => Finset.range m)
  let f (c : Fin m → ℕ) : A' → ℕ := λ a => ∑ k, if (a : ℤ) ∈ B k then c k else 0
  have h_inj : ∀ c1 ∈ S, ∀ c2 ∈ S, f c1 = f c2 → c1 = c2 := by
    intros c1 hc1 c2 hc2 hg
    have hX : ∑ k, c1 k * m ^ ((k : ℕ) + 1) = ∑ k, c2 k * m ^ ((k : ℕ) + 1) := by
      calc ∑ k, c1 k * m ^ ((k : ℕ) + 1)
        _ = ∑ k, c1 k * ∑ a ∈ B k, a := by simp [hB]
        _ = ∑ k, ∑ a ∈ A, if a ∈ B k then c1 k * a else 0 := by simp_rw [← Finset.sum_mul, ← Finset.sum_filter, hBA]; simp
        _ = ∑ a ∈ A, a * ∑ k, if a ∈ B k then c1 k else 0 := by simp_rw [Finset.sum_comm]; simp [Int.mul_comm]
        _ = ∑ a ∈ A', a * ∑ k, if a ∈ B k then c1 k else 0 := by rw [Finset.sum_filter_ne_zero]
        _ = ∑ a ∈ A', a * f c1 a := rfl
        _ = ∑ a ∈ A', a * f c2 a := by rw [hg]
        _ = ∑ a ∈ A, a * ∑ k, if a ∈ B k then c2 k else 0 := by rw [Finset.sum_filter_ne_zero]
        _ = ∑ k, c2 k * m ^ ((k : ℕ) + 1) := by simp_rw [Finset.sum_comm]; simp [Int.mul_comm]; simp_rw [← Finset.sum_filter, hBA, Finset.sum_mul, hB]; simp
    simp_rw [pow_succ, ← Finset.mul_sum, Nat.mul_left_inj (Nat.pos_of_gt hm)] at hX
    have h_ofDigits : (List.ofFn c1).ofDigits m = (List.ofFn c2).ofDigits m := by
      simp_rw [Nat.ofDigits_eq_sum_map_pow_mul, List.length_ofFn, List.ofFn_get, Finset.sum_fin_eq_sum_range]
      exact hX
    exact List.ofFn_inj.1 (Nat.ofDigits_inj_of_length (Nat.one_lt_of_le_of_ne hm (by rintro rfl; norm_num at hm)) (by simp) (by simpa using hc1) (by simpa using hc2) h_ofDigits)
  have h_img : ∀ c ∈ S, f c ∈ Fintype.piFinset (λ _ : A' => Finset.range (m * (m - 1) + 1)) := by
    intro c hc
    simp only [Fintype.mem_piFinset, Finset.mem_range]
    intro a
    calc ∑ k, (if (a : ℤ) ∈ B k then c k else 0)
      _ ≤ ∑ k : Fin m, (m - 1) := Finset.sum_le_sum (λ k _ => by split_ifs <;> simpa using hc k)
      _ = m * (m - 1) := by simp
      _ < m * (m - 1) + 1 := Nat.lt_succ_self _
  have h_le := Finset.card_le_card_of_inj_on f h_inj h_img
  simp only [Finset.card_piFinset, Finset.card_range, Finset.card_fin] at h_le
  have hn' : 0 < n' := by
    by_contra hn'z; simp only [nonpos_iff_eq_zero, Finset.card_eq_zero] at hn'z
    rw [hn'z, pow_zero] at h_le
    exact (pow_le_one m m (Nat.pos_of_gt hm)).not_lt (Nat.one_lt_pow m m (Nat.pos_of_gt hm) (Nat.pos_of_gt hm)) h_le
  have hm1 : m * (m - 1) + 1 < m ^ 2 := by
    rw [Nat.mul_sub_left_distrib, Nat.mul_one, Nat.add_comm, ← Nat.add_sub_assoc (Nat.one_le_of_lt (Nat.pos_of_gt hm))]
    exact Nat.sub_lt (Nat.pow_pos (Nat.pos_of_gt hm) 2) (Nat.pos_of_gt (Nat.one_lt_of_le_of_ne hm (by rintro rfl; norm_num at hm)))
  have h_lt : m ^ m < m ^ (2 * n') := by
    calc m ^ m ≤ (m * (m - 1) + 1) ^ n' := h_le
      _ < (m ^ 2) ^ n' := Nat.pow_lt_pow_left hm1 hn'
      _ = m ^ (2 * n') := by rw [Nat.pow_mul]
  have h_mn : m < 2 * n' := Nat.pow_lt_pow_iff_right (Nat.one_lt_of_le_of_ne hm (by rintro rfl; norm_num at hm)) |>.1 h_lt
  rw [le_div_iff₀ (by norm_num : (0 : ℚ) < 2), mul_comm]
  exact Nat.cast_le.2 (h_mn.le.trans (Nat.mul_le_mul_left 2 (Finset.card_filter_le A _)))

end IMO2021P6

