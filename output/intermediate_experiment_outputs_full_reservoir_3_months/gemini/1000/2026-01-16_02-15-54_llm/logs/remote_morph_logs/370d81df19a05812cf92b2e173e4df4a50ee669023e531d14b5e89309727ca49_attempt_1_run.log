    intro S₁ _ S₂ _ hS
    apply Finset.ext; intro k
    have : ∀ S : Finset (Fin m), f S = m * ∑ k ∈ S, m ^ (k : ℕ) := by
      intro S; simp only [f, pow_succ, mul_sum]
    rw [this, this, mul_left_inj' (by linarith)] at hS
    exact (Nat.enat_ext_iff m hm S₁ S₂).mp (by exact_mod_cast hS)
  let c : ℤ → Finset (Fin m) → ℤ := λ i S => if i ∈ B S then 1 else 0
  let g : Finset (Fin m) → ℤ ^ #A := λ S => λ j => if A.toList.get j ∈ B S then 1 else 0
  have h_sum : ∀ S, f S = ∑ i ∈ A, (∑ k ∈ S, if i ∈ B k then (1 : ℤ) else 0) * i := by
    intro S; simp [f]; rw [sum_comm]; apply sum_congr rfl; intro k hk; rw [← hB k, sum_subset (hBA k)]; simp
  let c_vec : Fin m → ℤ ^ #A := λ k => λ j => if A.toList.get j ∈ B k then 1 else 0
  let v : Finset (Fin m) → ℤ ^ #A := λ S => ∑ k ∈ S, c_vec k
  have h_inj : Set.InjOn v Set.univ := by
    intro S₁ _ S₂ _ hV
    have : f S₁ = f S₂ := by
      repeat rw [h_sum]; apply Finset.sum_congr rfl; intro i hi
      let j := (A.toList.indexOf i).toFin (by simp [hi])
      have hj : A.toList.get j = i := by simp [j]
      simp_rw [← hj]; change (v S₁) j = (v S₂) j; rw [hV]
    exact hf (Set.mem_univ _) (Set.mem_univ _) this
  have h_range : ∀ S, ∀ j, 0 ≤ (v S) j ∧ (v S) j ≤ m := by
    intro S j; simp [v, c_vec]; constructor
    · apply sum_nonneg; intros; split_ifs <;> linarith
    · apply le_trans (sum_le_card_nsmul _ _ 1 _); simp; intro k _; split_ifs <;> linarith
  have : 2 ^ m ≤ (m + 1) ^ #A := by
    have h_card_v : (Set.univ : Set (Finset (Fin m))).toFinset.card = 2 ^ m := by simp
    have h_card_range : (Fintype.piFinset (λ _ : Fin #A => Icc (0 : ℤ) m)).card = (m + 1) ^ #A := by simp
    rw [← h_card_v]; apply Finset.card_le_card_of_inj_on v (by simp)
    intro S _; simp; intro j; exact ⟨(h_range S j).1, (h_range S j).2⟩
  by_contra h_lt
  have h_m : (m : ℚ) > 2 * #A := by linarith
  have : (2 : ℚ) ^ m > (m + 1) ^ #A := by
    induction' #A with n _
    · simp at h_lt; linarith
    · have : m ≥ 2 * (n + 1) := by exact_mod_cast (show m ≥ 2 * (n + 1) from by linarith)
