  have hVx : V.mulVec x = s := by
    ext k
    simp [Matrix.mulVec, V, x, h_sum k]
  let r := V.rank
  have hrA : r ≤ #A := Matrix.rank_le_width V
  have hrm : r = m := by
    refine Matrix.rank_eq_m_of_index_free V (fun c hc => ?_)
    have hcs : (Matrix.row (R := ℚ) (n := A) c * V) = 0 := hc
    have : (Matrix.row (R := ℚ) (n := A) c * V).vecMul x = 0 := by simp [hc]
    rw [Matrix.vecMul_vecMul] at this
    have h_zero : ∑ k, c k * s k = 0 := by
      simpa [Matrix.mulVec, hVx] using this
    clear this hc h_sum hVx hrA r x V v
    let P : ℚ[X] := ∑ k, Polynomial.monomial (k.val + 1) (c k)
    have hPm : P.eval (m : ℚ) = 0 := by
      simpa [P, Polynomial.eval_finset_sum, Polynomial.eval_monomial] using h_zero
    by_contra hnz
    have hPnz : P ≠ 0 := by
      contrapose! hnz
      ext k
      simpa [P] using Polynomial.coeff_monomial_pos (k.val + 1) (k.val + 1) (c k)
    let p : ℕ → ℚ := fun k => if k = 0 then 0 else if h : k - 1 < m then c ⟨k - 1, h⟩ else 0
    have : P = ∑ k ∈ Finset.range (m + 1), Polynomial.monomial k (p k) := by
      ext k
      simp [P, p]
      split_ifs with h1 h2 h3
      · subst h1; simp
      · have : ∃ j : Fin m, j.val + 1 = k := ⟨⟨k - 1, h2⟩, by omega⟩
        rcases this with ⟨j, rfl⟩
        simp [j]
      · intro j; omega
    sorry
  linarith [hrA, hrm]
