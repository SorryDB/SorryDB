lemma sup_stoppedProcess_hittingAfter_Ici_le {E : Type*} [NormedAddCommGroup E] [InfSet ι] [Bot ι]
    {X : ι → Ω → E} (t : ι) (K : ℝ) (ω : Ω) :
    ⨆ s ≤ t, ‖stoppedProcess X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) s ω‖ ≤
    K + Set.indicator {ω | hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω ≤ t}
      (fun ω ↦ ‖stoppedValue X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) ω‖) ω := by
  apply iSup₂_le; intro s hs
  let τ := hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥
  rw [stoppedProcess_apply]
  by_cases hτ : τ ω ≤ t
  · rw [Set.indicator_of_mem hτ]
    rcases lt_or_le (min s (τ ω).untopA) (τ ω).untopA with hlt | hle
    · exact (not_le.mp fun m ↦ hlt.not_le (WithTop.untopA_le_iff.mpr (hittingAfter_le ⟨bot_le, m⟩))).le.trans (le_add_of_nonneg_right (norm_nonneg _))
    · rw [le_antisymm (min_le_right _ _) hle]; exact le_add_of_nonneg_left (not_lt.mp fun k ↦ hτ.not_lt (WithTop.bot_lt_iff_ne_bot.mpr fun b ↦ (not_le.mpr k) (le_trans (norm_nonneg _) ((hittingAfter_le_iff ⟨bot_le, b.le.not_lt⟩).mp b.le))))
  · rw [Set.indicator_of_not_mem hτ]
    have h_top : τ ω ≠ ⊤ := fun h_top ↦ hτ (h_top.symm ▸ le_top)
    have : s < (τ ω).untopA := by rwa [WithTop.untopA_eq_untop h_top, ← WithTop.coe_lt_coe, ← not_le]
    exact (not_le.mp fun m ↦ this.not_le (WithTop.untopA_le_iff.mpr (hittingAfter_le ⟨bot_le, m⟩))).le
```
