/-- All the moments of a real semicircle distribution are finite. That is, the identity is in Lp for
all finite `p`. -/
lemma memLp_id_semicircleReal (p : ℝ≥0) : MemLp id p (semicircleReal μ v) := by
  refine memLp_of_mem_interior_integrableExpSet ?_ p
  have c01 : integrableExpSet id (semicircleReal μ v) = Set.univ := by
    ext t; simp [integrableExpSet]
    have c01 : Integrable (fun (x : ℝ) ↦ Real.exp (t * x)) (semicircleReal μ v) := by
      set S := Icc (μ - 2 * √v) (μ + 2 * √v)
      have c011 : ∀ x, x ∈ S → |Real.exp (t * x)| ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by sorry
      by_cases hv : v = 0
      · rw [hv, semicircleReal_zero_var]; apply integrable_dirac; continuity
      · rw [semicircleReal_of_var_ne_zero μ hv]
        apply integrable_of_ae_bound (C := Real.exp (|t| * (|μ| + 2 * √v)))
        · continuity
        · filter_upwards [Measure.ae_le_support (semicirclePDF μ v) volume] with x hx
          apply c011; apply support_semicirclePDF_inc
          exact (ENNReal.ofReal_ne_zero.mp hx).1.ne'
    exact c01
