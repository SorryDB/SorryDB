import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n := 70
  let f (x : ℝ) := ∑ i ∈ Finset.Icc 1 n, (i : ℝ) / (x - i)
  let P : ℝ[X] := Polynomial.C (5/4) * (Finset.Icc 1 n).prod (fun i => Polynomial.X - Polynomial.C (i : ℝ)) -
                 ∑ i ∈ Finset.Icc 1 n, (Polynomial.C (i : ℝ) * (Finset.Icc 1 n).prod (fun j => if i = j then 1 else Polynomial.X - Polynomial.C (j : ℝ)))
  have hP_roots : ∀ x, (∀ i ∈ Finset.Icc 1 n, x ≠ i) → (f x = 5/4 ↔ P.IsRoot x) := by
    intro x hx; rw [f, Polynomial.IsRoot, Polynomial.eval_sub, Polynomial.eval_mul, Polynomial.eval_sum, sub_eq_zero]
    let Q := (Finset.Icc 1 n).prod (fun i => Polynomial.X - Polynomial.C (i : ℝ))
    have hQx : Q.eval x ≠ 0 := by
      simp [Q, hx]
    field_simp [hx]; congr; rw [Finset.sum_congr (Eq.refl (Finset.Icc 1 n))]
    intro i hi; rw [Polynomial.eval_mul, Polynomial.eval_C]; congr; rw [Polynomial.eval_prod]
    exact Finset.prod_congr (Eq.refl _) (fun j hj => by split_ifs with h; subst h; simp; simp [hj])
  have h_roots_exist : ∃ r : ℕ → ℝ, (∀ i < n, l i < r i) ∧ (∀ i < n - 1, r i < l (i + 1)) ∧ (∀ i < n, f (r i) = 5/4) := by
    let l i := (i + 1 : ℝ)
    have : ∀ i ∈ Finset.range n, ∃ x, x ∈ Set.Ioi (l i) ∧ (i < n - 1 → x < l (i + 1)) ∧ f x = 5 / 4 := by
      intro i hi; sorry -- standard IVT on (i+1, i+2) or (n, inf)
    choose r hr using this; refine ⟨r, ?_⟩; simp at hr; exact ⟨fun i hi => (hr i hi).1, fun i hi => (hr i hi).2.1 hi, fun i hi => (hr i hi).2.2⟩
  obtain ⟨r, h1, h2, h3⟩ := h_roots_exist
  use (fun k => k + 1), r, 70
  have h_sum : ∑ k ∈ Finset.range n, (r k - (k + 1 : ℝ)) = 1988 := by
    have h_sum_r : ∑ k ∈ Finset.range n, r k = 9 / 5 * ∑ k ∈ Finset.Icc 1 n, (k : ℝ) := by
      have : P.degree = n := by sorry
      have : P.nextCoeff / P.leadingCoeff = - (9 / 5 * ∑ k ∈ Finset.Icc 1 n, (k : ℝ)) := by sorry
      sorry -- use sum of roots property
    rw [Finset.sum_sub_distrib, h_sum_r, ← Finset.sum_range_reflect, Finset.sum_range_add_one_eq_sum_Icc, ← one_mul (∑ k ∈ Finset.Icc 1 n, (k : ℝ))]
    ring_nf; have : (4/5 : ℝ) * (70 * 71 / 2) = 1988 := by norm_num
    rw [← this, Finset.sum_Icc_nat_cast, Nat.cast_mul, Nat.cast_div (by norm_num) (by norm_num)]; congr
  have h_union : S = ⋃ k ∈ Finset.range n, Set.Ioc (k + 1 : ℝ) (r k) := by
    ext x; rw [h₁]; simp only [Set.mem_setOf_eq, Set.mem_Ioc, Set.mem_Union, Finset.mem_range]
    sorry -- use strict monotonicity of f on each interval
  exact ⟨h1, h2, h_sum, h_union⟩
