import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let f (x : ℝ) := ∑ k in Finset.Icc 1 70, (k : ℝ) / (x - k)
  let p : Polynomial ℝ := Polynomial.C (5 / 4) * ((Finset.Icc 1 70).prod (fun i => Polynomial.X - Polynomial.C (i : ℝ))) -
    (Finset.Icc 1 70).sum (fun i => Polynomial.C (i : ℝ) * ((Finset.Icc 1 70).erase i).prod (fun j => Polynomial.X - Polynomial.C (j : ℝ)))
  have hp : p.degree = 70 := by
    rw [Polynomial.degree_sub_eq_left_of_degree_lt]
    · rw [Polynomial.degree_C_mul (by norm_num), Polynomial.degree_prod]
      · simp [Finset.card_Icc]
      · intro i _; exact Polynomial.X_minus_C_ne_zero i
    · rw [Polynomial.degree_sum_le]
      refine (Finset.sum_le_max _ _).trans_lt ?_
      simp only [Finset.mem_Icc, Polynomial.degree_C_mul (by norm_num), Polynomial.degree_prod,
        Polynomial.X_minus_C_ne_zero, Finset.card_erase_of_mem, Finset.mem_Icc, Nat.cast_lt]
      intro i hi; rw [Finset.card_Icc]; norm_num
  have h_roots_distinct : p.Roots.card = 70 := sorry
