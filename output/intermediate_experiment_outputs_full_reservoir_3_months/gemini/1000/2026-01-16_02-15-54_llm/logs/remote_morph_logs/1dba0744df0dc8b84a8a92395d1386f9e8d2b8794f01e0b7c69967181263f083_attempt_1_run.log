    have h_sum_r : ∑ k in Finset.range n, r k = q.roots.sum id := by
      rw [← Multiset.sum_toFinset q.roots (by sorry), ← Finset.sum_list r_sorted]
      apply Finset.sum_congr rfl; intro k hk; rfl
    rw [h_sum_r, h_sum_roots]
    field_simp [n]; norm_num
  · rw [h₁]; sorry
