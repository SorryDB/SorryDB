    simp; rfl
  have hP_roots_sum : (P.roots.sum : ℝ) = 4473 := by
    have lc : P.leadingCoeff = 5 := by sorry
    have c69 : P.coeff 69 = -9 * ∑ i ∈ Finset.Icc 1 70, (i : ℝ) := by sorry
    have : (P.roots.sum : ℝ) = - P.coeff 69 / P.leadingCoeff := by sorry
    rw [this, lc, c69]; ring_nf; field_simp; ring_nf; rfl
