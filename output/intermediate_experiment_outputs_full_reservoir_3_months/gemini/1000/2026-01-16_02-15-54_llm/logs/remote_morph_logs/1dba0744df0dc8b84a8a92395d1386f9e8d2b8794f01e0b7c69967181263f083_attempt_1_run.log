import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n := 70
  let g (x : ℝ) := ∑ i ∈ Finset.Icc 1 n, (i : ℝ) / (x - i)
  have g_mono : ∀ i ∈ Finset.Icc 1 n, StrictAntiOn g (Set.Ioi (i : ℝ) ∩ {x | ¬∃ j ∈ Finset.Icc 1 n, x = j}) := by
    intro i hi x hx y hy hxy
    apply Finset.sum_lt_sum
    · intro j hj
      apply div_lt_div_of_pos_left (j : ℝ)
      · exact Nat.cast_pos.mpr (Finset.mem_Icc.1 hj).1
      · rw [hx.2, hy.2]; exact sub_lt_sub_right hxy j
      · exact sub_pos.mpr (lt_of_le_of_lt (Finset.mem_Icc.1 hj).1 hx.1)
    · exact ⟨i, hi, (div_lt_div_of_pos_left _ (Nat.cast_pos.mpr (Finset.mem_Icc.1 hi).1) (sub_pos.mpr hx.1) (sub_lt_sub_right hxy i))⟩
  let P : Polynomial ℝ := ∏ i ∈ Finset.Icc 1 n, (Polynomial.X - Polynomial.C (i : ℝ))
  let Q : Polynomial ℝ := Polynomial.C (5 / 4) * P - ∑ i ∈ Finset.Icc 1 n, Polynomial.C (i : ℝ) * (P /ₘ (Polynomial.X - Polynomial.C (i : ℝ)))
  have hQ_deg : Q.degree = n := by
    rw [Polynomial.degree_sub_eq_left_of_degree_lt]
    · rw [Polynomial.degree_mul, Polynomial.degree_C, Polynomial.degree_prod]; simp [n]; norm_num
    · apply (Polynomial.degree_sum_le _ _).trans_lt
      apply Finset.sup_lt_iff.mpr; intro i hi
      rw [Polynomial.degree_mul, Polynomial.degree_C, (Polynomial.degree_prod_erase P hi)]; simp [n]; norm_num
  have hQ_roots_exist : ∃ r : ℕ → ℝ, (∀ i < n, Q.IsRoot (r i)) ∧ (∀ i < n - 1, (i + 1 : ℝ) < r i ∧ r i < (i + 2 : ℝ)) ∧ (n : ℝ) < r (n - 1) := by
    have sign_Q : ∀ i ∈ Finset.Icc 1 n, Q.eval (i : ℝ) = (-1)^(n-i) * (i : ℝ) * (i-1).factorial * (n-i).factorial := by
      intro i hi
      simp [Q, P, Polynomial.eval_sum, Polynomial.eval_sub, Polynomial.eval_mul, Polynomial.eval_prod, Polynomial.eval_C]
      rw [Finset.sum_eq_single i]; simp
      · intro j hj hji; rw [Polynomial.eval_prod_erase P (Finset.mem_Icc.1 hj) hji]; simp
      · exact fun hi' => (hi' hi).elim
    have : ∀ i ∈ Finset.Icc 1 (n-1), ∃ r_i, r_i ∈ Set.Ioo (i : ℝ) (i+1 : ℝ) ∧ Q.IsRoot r_i := by
      intro i hi; apply Polynomial.exists_root_between_levels Q (i : ℝ) (i+1 : ℝ) 0
      · simp [sign_Q i (Finset.mem_Icc.1 hi).1, sign_Q (i+1)]; ring_nf; apply mul_neg_of_pos_of_neg <;> positivity
    choose r hr using this
    have : ∃ r_n, r_n > (n : ℝ) ∧ Q.IsRoot r_n := by
      apply Polynomial.exists_root_of_degree_odd_of_at_infinity Q n
      · simp [sign_Q n]; norm_num; positivity
      · rw [hQ_deg]; simp; norm_num
    choose r_n hr_n using this
    exact ⟨λ i => if h : i < n - 1 then r (i + 1) (by simp [h]) else r_n, by
      intro i hi; split_ifs with h; exact (hr (i+1) _).2; exact hr_n.2,
      by intro i hi; simp [hi]; exact (hr (i+1) _).1, by simp; exact hr_n.1⟩
  obtain ⟨r, hr_root, hr_range, hr_last⟩ := hQ_roots_exist
  exists (λ k => k + 1), r, n
  refine ⟨?_, ?_, ?_, ?_⟩
  · intro k hk; split_ifs with h; exact (hr_range k h).1; exact hr_last
  · intro k hk; exact (hr_range k hk).2
  · have h_sum_r : ∑ k ∈ Finset.range n, r k = 4473 := by
      rw [Polynomial.sum_roots_eq_nextCoeff_div_leadingCoeff]
      · simp [Q, P, n, Polynomial.nextCoeff, Polynomial.leadingCoeff]; norm_num; rfl
      · rw [Polynomial.splits_iff_card_roots]; rw [hQ_deg]; apply le_antisymm (Polynomial.card_roots_le_degree hQ_deg.ge)
        rw [← Finset.card_range n]; apply Finset.card_le_of_subset; intro x hx; simp at hx; simp [hr_root x hx]
    rw [Finset.sum_sub, h_sum_r]; simp [n]; norm_num
  · ext x; rw [h₁, Set.mem_setOf_eq, Set.mem_iUnion]; constructor
    · intro ⟨hx1, hx2⟩; obtain ⟨i, hi, hxi⟩ : ∃ i ∈ Finset.Icc 1 n, i < x := by
        contrapose! hx2; apply lt_of_lt_of_le _ (show 0 < 5/4 by norm_num)
        apply Finset.sum_neg; intro i hi; apply div_neg_of_pos_of_neg (i : ℝ) (Nat.cast_pos.mpr hi.1) (sub_neg.mpr (hx2 i hi))
      let i_max := Finset.max' (Finset.Icc 1 n |>.filter (λ i => (i : ℝ) < x)) (by simp; exists i)
      have hi_max : i_max ∈ Finset.Icc 1 n ∧ (i_max : ℝ) < x := by simp [i_max]
      refine ⟨i_max - 1, by simp [i_max, hi_max.1.1, hi_max.1.2], ?_⟩
      apply Set.mem_Ioc.mpr ⟨hi_max.2, ?_⟩
      have : g x = 5/4 ↔ Q.IsRoot x := by
        simp [Q, P, g]; intro i hi; simp [hx1]
      contrapose! hx2; apply g_mono i_max hi_max.1 ⟨hi_max.2, hx1⟩ ⟨hx2, hx1⟩ hx2 |>.trans_le; rw [this.mpr (hr_root (i_max - 1) (by simp [i_max, hi_max.1.1, hi_max.1.2]))]; exact le_refl _
    · intro ⟨k, hk, hx⟩; simp at hk; rw [Set.mem_Ioc] at hx; have hxi : k + 1 < x ∧ x ≤ r k := hx
      constructor
      · intro ⟨i, hi, hix⟩; rw [hix] at hx; have : Q.IsRoot (r k) := hr_root k hk
        if h : k < n - 1 then
          if hi_k : i = k + 1 then linarith [hx.1, hi_k] else
          if hi_k2 : i < k + 1 then linarith [hx.1] else linarith [hx.2, hr_range k h]
        else
          if hi_k : i = n then linarith [hx.1, hi_k] else linarith [hx.1]
      · rw [← (show g (r k) = 5/4 by simp [g, Q, P, hr_root k hk, hxi.2])]
        exact (g_mono (k + 1) (by simp [hk]) ⟨hxi.1, ?_⟩ ⟨hxi.2, ?_⟩ hxi.2).le
        all_goals { intro ⟨i, hi, hix⟩; rw [hix] at hxi; if h : k < n - 1 then (if hi_k : i = k + 1 then linarith [hxi.1, hi_k] else if hi_k2 : i < k + 1 then linarith [hxi.1] else linarith [hxi.2, hr_range k h]) else (if hi_k : i = n then linarith [hxi.1, hi_k] else linarith [hxi.1]) }
```
