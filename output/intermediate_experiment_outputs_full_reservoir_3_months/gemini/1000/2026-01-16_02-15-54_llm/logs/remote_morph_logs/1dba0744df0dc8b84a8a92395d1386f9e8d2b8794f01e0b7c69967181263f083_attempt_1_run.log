import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let f (x : ℝ) := ∑ k ∈ Finset.Icc 1 70, (k : ℝ) / (x - k)
  let P : Polynomial ℝ := 5 * (Finset.Icc 1 70).prod (fun i => Polynomial.X - Polynomial.C (i : ℝ)) -
    4 * ∑ i ∈ Finset.Icc 1 70, (Polynomial.C (i : ℝ) * (Finset.Icc 1 70).erase i |>.prod (fun j => Polynomial.X - Polynomial.C (j : ℝ)))
  have hP_deg : P.degree = 70 := by
    rw [Polynomial.degree_eq_natDegree (by
      intro h; have := Polynomial.leadingCoeff_zero.mp h; exact (by
        have : P.leadingCoeff = 5 := by
          rw [Polynomial.leadingCoeff_sub]
          · rw [Polynomial.leadingCoeff_mul, Polynomial.leadingCoeff_C, Polynomial.leadingCoeff_prod]
            · simp; rfl
            · intro i _; exact Polynomial.leadingCoeff_X_sub_C (i : ℝ)
          · have deg1 : (5 * (Finset.Icc 1 70).prod (fun i => Polynomial.X - Polynomial.C (i : ℝ))).degree = 70 := by
              rw [Polynomial.degree_mul, Polynomial.degree_C, zero_add, Polynomial.degree_prod]
              simp; rfl
              exact (by simp)
            have deg2 : (4 * ∑ i ∈ Finset.Icc 1 70, (Polynomial.C (i : ℝ) * (Finset.Icc 1 70).erase i |>.prod (fun j => Polynomial.X - Polynomial.C (j : ℝ)))).degree < 70 := by
              apply (Polynomial.degree_mul_le 4 _).trans_lt
              apply (Polynomial.degree_sum_le _ _).trans_lt
              simp only [Polynomial.degree_C, zero_add, Finset.prod_erase, Finset.mem_Icc, Nat.one_le_cast,
                Nat.cast_le, and_imp, Finset.degree_prod, Polynomial.degree_X_sub_C, Finset.sum_const,
                Finset.card_erase, Finset.card_Icc, Nat.card_Icc, Nat.reduceSub, Nat.cast_smul,
                Nat.cast_ofNat, Nat.ofNat_pos, implies_true, Finset.mem_range, Nat.lt_one_iff,
                Finset.not_mem_empty, Nat.cast_zero, zero_lt_one, true_and]
              simp; apply (Finset.degree_sum_le _ _).trans_lt; simp; intro i _;
              rw [Polynomial.degree_mul, Polynomial.degree_C, zero_add, Polynomial.degree_prod]; simp; rfl
            rw [deg1, deg2]; exact WithBot.coe_lt_coe.mpr (by simp)
