import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Show that the set of real numbers $x$ which satisfy the inequality: $${1\over x-1}+{2\over x-2}+{3\over x-3}+\ldots+{70\over x-70}\ge{5\over4}$$ is a union of disjoint intervals, the sum of whose lengths is $1988$. -/
@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n := 70
  let f (x : ℝ) := ∑ k in Finset.Icc 1 n, (k : ℝ) / (x - k)
  let p : ℝ[X] := Polynomial.C (5 / 4) * (Finset.Icc 1 n).prod (λ i => Polynomial.X - Polynomial.C (i : ℝ)) -
                  ∑ i in Finset.Icc 1 n, (Polynomial.C (i : ℝ) * (Finset.Icc 1 n).prod (λ j => if i = j then 1 else Polynomial.X - Polynomial.C (j : ℝ)))
  have hp_deg : p.degree = n := by
    rw [Polynomial.degree_sub_eq_left_of_degree_lt]
    · rw [Polynomial.degree_C_mul (by norm_num), Polynomial.degree_prod]; simp [n]; intro i _; exact Polynomial.degree_X_sub_C (i : ℝ)
    · apply (Polynomial.degree_sum_le _ _).trans_lt; rw [Finset.deg_sup_below]; simp [n]
      intro i _; rw [Polynomial.degree_C_mul (by norm_num), Polynomial.degree_prod]; simp
      intro j hj; split_ifs with h; simp; exact Polynomial.degree_X_sub_C (j : ℝ)
  have hp_roots : ∃ roots : List ℝ, roots.length = n ∧ roots.Chain' (· < ·) ∧ (∀ x, p.IsRoot x ↔ x ∈ roots) ∧ (∀ i, i < n → (i + 1 : ℝ) < roots.get ⟨i, by simp [n, roots.length]⟩) ∧ (∀ i, i < n - 1 → roots.get ⟨i, by simp [n, roots.length]⟩ < (i + 2 : ℝ)) := sorry
  obtain ⟨roots, hlen, hchain, hroots, hlower, hupper⟩ := hp_roots
  let l (k : ℕ) : ℝ := k + 1
  let r (k : ℕ) : ℝ := if h : k < n then roots.get ⟨k, hlen.symm ▸ h⟩ else 0
  use l, r, n
  have hrk : ∀ k < n, r k = roots.get ⟨k, hlen.symm ▸ k⟩ := λ k hk => dif_pos hk
  constructor
  · intro k hk; rw [hrk k hk]; exact hlower k hk
  constructor
  · intro k hk; rw [hrk k (by omega), (by norm_cast : l (k + 1) = (k + 2 : ℝ))]; exact hupper k hk
  constructor
  · have hsum_roots : roots.sum = (9 / 5) * ∑ k in Finset.Icc 1 n, (k : ℝ) := sorry
    have hsum_l : ∑ k in Finset.range n, l k = ∑ k in Finset.Icc 1 n, (k : ℝ) := by
      rw [Finset.sum_range_reflect (λ k => (k + 1 : ℝ)) n]; simp; rw [Finset.sum_range_add]; simp [n]
    rw [Finset.sum_sub_distrib, hsum_l, ← hsum_roots, ← (List.sum_get hlen), ← Finset.sum_range (λ k => r k)]
    · field_simp; ring
    · intro k hk; rw [hrk k hk]
  · rw [h₁]; ext x; simp [n, f]
    have hx_not_k : (¬∃ m ∈ Finset.Icc 1 n, x = ↑m) ↔ ∀ m ∈ Finset.Icc 1 n, x ≠ m := by simp
    rw [hx_not_k]; constructor
    · intro ⟨hx_not, hxf⟩
      have hpg : p.IsRoot x ↔ f x = 5 / 4 := sorry
      have : ∃ k < n, x ∈ Set.Ioc (l k) (r k) := sorry
      simp; exact this
    · intro hx; simp at hx; obtain ⟨k, hk, hx_inc⟩ := hx
      have hx_not : ∀ m ∈ Finset.Icc 1 n, x ≠ m := sorry
      have hxf : 5 / 4 ≤ f x := sorry
      exact ⟨hx_not, hxf⟩
