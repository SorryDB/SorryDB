@[imo_problem_subject algebra]
theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n := 70
  let f (x : ℝ) := ∑ k in Finset.Icc 1 n, (k : ℝ) / (x - k)
  let p : ℝ[X] := ∏ i in Finset.Icc 1 n, (X - C (i : ℝ))
  let q : ℝ[X] := C (5 / 4 : ℝ) * p - ∑ i in Finset.Icc 1 n, C (i : ℝ) * (p.divByMonic (X - C (i : ℝ)))
  have q_deg : q.degree = n := by
    rw [Polynomial.degree_sub_eq_left_of_degree_lt]
    · rw [Polynomial.degree_C_mul (by norm_num), Polynomial.degree_prod]
      · simp only [Polynomial.degree_X_sub_C, Finset.sum_const, Finset.card_Icc, Nat.add_sub_cancel_left, Nat.cast_id, n]
      · intro i _; exact Polynomial.monic_X_sub_C i |>.ne_zero
    · apply (Polynomial.degree_sum_le _ _).trans_lt
      simp only [Finset.degree_C_mul_p_divByMonic_X_sub_C, n]
      rw [Finset.sup_const (Finset.nonempty_Icc.mpr (by norm_num))]
      simp only [Polynomial.degree_prod, Polynomial.degree_X_sub_C, Finset.sum_const, Finset.card_Icc, Nat.add_sub_cancel_left, Nat.cast_id]
      exact WithBot.coe_lt_coe.mpr (Nat.pred_lt (by norm_num))
  have q_roots_distinct : q.roots.card = n := by sorry
  let rs := q.roots.toFinset
  have rs_card : rs.card = n := by sorry
  let r_sorted := rs.sort (· ≤ ·)
