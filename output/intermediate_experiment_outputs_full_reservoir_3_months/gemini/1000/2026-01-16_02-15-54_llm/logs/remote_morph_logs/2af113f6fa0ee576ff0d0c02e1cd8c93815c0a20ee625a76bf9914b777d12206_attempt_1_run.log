import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
$f$ and $g$ are real-valued functions defined on the real line. For all $x$ and $y, f(x+y)+f(x-y)=2f(x)g(y)$. $f$ is not identically zero and $|f(x)|\le1$ for all $x$. Prove that $|g(x)|\le1$ for all $x$. -/
@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  intro y
  let M := ⨆ x, |f x|
  have hb : BddAbove (Set.range fun x => |f x|) := ⟨1, Set.forall_mem_range.mpr h₂⟩
  have hM : 0 < M := by
    rcases not_forall.mp h₁ with ⟨x, hx⟩
    exact (abs_pos.mpr hx).trans_le (le_csiSup hb (Set.mem_range_self x))
  by_cases hg : g y = 0
  · exact hg.symm ▸ abs_zero.symm ▸ zero_le_one
  · have hgp : 0 < |g y| := abs_pos.mpr hg
    have h_le : ∀ x, |f x| ≤ M / |g y| := fun x => (le_div_iff₀ hgp).mpr (by
      rw [← mul_le_mul_left zero_lt_two, ← abs_of_pos zero_lt_two, ← abs_mul, ← abs_mul, ← h₀]
      exact (abs_add _ _).trans (add_le_add (le_csiSup hb (Set.mem_range_self _)) (le_csiSup hb (Set.mem_range_self _))).trans_eq (two_mul M).symm)
    exact (mul_le_iff_le_one_right hM).mp ((le_div_iff₀' hgp).mp (csiSup_le (Set.range_nonempty _) h_le))
