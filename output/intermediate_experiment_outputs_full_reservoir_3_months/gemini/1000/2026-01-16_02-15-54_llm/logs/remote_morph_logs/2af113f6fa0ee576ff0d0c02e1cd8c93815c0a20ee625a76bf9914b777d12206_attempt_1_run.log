    have h_le : ∀ x, |f x| ≤ M / |g y| := by
      intro x
      apply (le_div_iff (zero_lt_one.trans hgy)).mpr
      apply le_of_mul_le_mul_left (a := 2) (by norm_num)
      rw [← abs_of_pos (show (0 : ℝ) < 2 by norm_num), ← abs_mul, ← abs_mul, mul_assoc, ← h₀ x y]
      exact (abs_add (f (x + y)) (f (x - y))).trans ((add_le_add (hM_ub (x + y)) (hM_ub (x - y))).trans_eq (by ring))
    have hM_le : M ≤ M / |g y| := ciSup_le h_le
    have hMg : M * |g y| ≤ M := (le_div_iff (zero_lt_one.trans hgy)).mp hM_le
    exact (hgy.not_le (le_of_mul_le_mul_left (hMg.trans_eq (mul_one M).symm) hM_pos)).elim
