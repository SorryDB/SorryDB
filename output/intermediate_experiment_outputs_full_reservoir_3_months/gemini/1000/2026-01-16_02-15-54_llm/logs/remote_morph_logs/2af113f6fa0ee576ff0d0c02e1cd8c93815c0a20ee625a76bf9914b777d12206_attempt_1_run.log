import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
$f$ and $g$ are real-valued functions defined on the real line. For all $x$ and $y, f(x+y)+f(x-y)=2f(x)g(y)$. $f$ is not identically zero and $|f(x)|\le1$ for all $x$. Prove that $|g(x)|\le1$ for all $x$. -/
@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  intro y
  by_contra! hg
  let S := ⨆ x, |f x|
  have hf_bdd : BddAbove (Set.range (λ x => |f x|)) := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩
  have hS_pos : 0 < S := by
    obtain ⟨x, hx⟩ := exists_not_of_not_forall h₁
    exact (abs_pos.mpr hx).trans_le (le_ciSup hf_bdd x)
  have h_bound : ∀ x, |f x| ≤ S / |g y| := fun x => by
    have h_abs : 2 * |f x| * |g y| = |f (x + y) + f (x - y)| := by
      rw [← abs_mul, ← h₀, abs_mul, abs_mul, abs_of_pos (zero_lt_two' ℝ)]
    have : 2 * |f x| * |g y| ≤ 2 * S :=
      h_abs.trans_le ((abs_add (f (x + y)) (f (x - y))).trans
        (add_le_add (le_ciSup hf_bdd (x + y)) (le_ciSup hf_bdd (x - y))))
    exact (le_div_iff₀ (by linarith)).mpr (by linarith)
  have : S ≤ S / |g y| := ciSup_le h_bound
  linarith [hS_pos, (le_div_iff_of_pos hS_pos).mp this]

