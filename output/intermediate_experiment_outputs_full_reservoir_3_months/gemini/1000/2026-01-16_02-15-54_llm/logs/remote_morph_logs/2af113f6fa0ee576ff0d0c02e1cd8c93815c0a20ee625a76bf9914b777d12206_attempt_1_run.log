import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
$f$ and $g$ are real-valued functions defined on the real line. For all $x$ and $y, f(x+y)+f(x-y)=2f(x)g(y)$. $f$ is not identically zero and $|f(x)|\le1$ for all $x$. Prove that $|g(x)|\le1$ for all $x$. -/
@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  intro x
  by_contra! hg
  let S := Set.range (fun y => |f y|)
  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨y, rfl⟩; exact h₂ y⟩
  set M := sSup S
  have hM_ub y : |f y| ≤ M := le_csSup hS_bdd ⟨y, rfl⟩
  have hM_pos : 0 < M := by
    push_neg at h₁; obtain ⟨y₀, hy₀⟩ := h₁
    exact (abs_pos.mpr hy₀).trans_le (hM_ub y₀)
  have hM_le : M ≤ M / |g x| := by
    apply csSup_le (Set.range_nonempty _)
    rintro _ ⟨y, rfl⟩
    rw [le_div_iff₀ (by linarith), ← abs_two, ← abs_mul, ← abs_mul, ← h₀ y x]
    linarith [abs_add (f (y + x)) (f (y - x)), hM_ub (y + x), hM_ub (y - x)]
  have : M * |g x| ≤ M := (le_div_iff₀ (by linarith)).mp hM_le
  linarith
