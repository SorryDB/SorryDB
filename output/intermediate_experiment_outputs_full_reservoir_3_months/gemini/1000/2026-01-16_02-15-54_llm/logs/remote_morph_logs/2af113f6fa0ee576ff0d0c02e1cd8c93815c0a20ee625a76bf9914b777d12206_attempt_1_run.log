    rw [mul_comm, ← mul_le_mul_iff_left (show (0 : ℝ) < 2 by norm_num), ← abs_mul, mul_assoc, ← h₀]
    exact (abs_add _ _).trans (add_le_add (hM.left ⟨y + x, rfl⟩) (hM.left ⟨y - x, rfl⟩))
  have hMg : M * |g x| ≤ M := by
    by_cases h : g x = 0
    · rw [h, abs_zero, mul_zero]; exact hM_pos.le
    · have hpos : 0 < |g x| := abs_pos.mpr h
      rw [mul_comm, ← le_div_iff₀ hpos]
      exact hM.right (fun _ ⟨y, hy⟩ => hy ▸ (le_div_iff₀ hpos).mpr (hfgx y))
  exact (mul_le_iff_le_one_right hM_pos).mp hMg
