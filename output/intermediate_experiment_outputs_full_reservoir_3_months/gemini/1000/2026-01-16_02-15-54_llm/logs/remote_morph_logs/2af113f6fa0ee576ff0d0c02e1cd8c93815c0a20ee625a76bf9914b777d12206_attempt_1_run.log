@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  intro y
  by_contra! hg
  let M := ⨆ x, |f x|
  have hS_bdd : BddAbove (Set.range fun x => |f x|) := ⟨1, fun _ ⟨x, hx⟩ => hx ▸ h₂ x⟩
  have hM_pos : 0 < M :=
    let ⟨x₀, hx₀⟩ := not_forall.mp h₁
    (abs_pos.mpr hx₀).trans_le (le_ciSup hS_bdd x₀)
  have h_M_bound : M ≤ M / |g y| := ciSup_le (fun x => by
    have h : 2 * |f x| * |g y| ≤ 2 * M := by
      rw [← abs_of_pos (show (0 : ℝ) < 2 by norm_num), ← abs_mul, ← abs_mul, ← h₀]
      exact (abs_add _ _).trans (add_le_add (le_ciSup hS_bdd (x + y)) (le_ciSup hS_bdd (x - y)))
    exact (le_div_iff₀ (lt_trans (by norm_num) hg)).mpr (by linarith))
  exact hg.not_le ((le_div_iff₀ hM_pos).mp h_M_bound)
