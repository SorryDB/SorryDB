import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f (n : ℕ+) : ℤ := (n : ℤ) + a n
  have f_inj : Function.Injective f := by
    intro i j h; by_contra hne
    cases hne.lt_or_lt with
    | inl hlt => exact hii j i ⟨i.2, hlt⟩ h.symm
    | inr hlt => exact hii i j ⟨j.2, hlt⟩ h
  let C_set := {c : ℤ | 1 ≤ c ∧ ∀ i, f i ≠ c}
  have hC_bound : ∀ c ∈ C_set, c ≤ 2015 := by
    intro c ⟨hc1, hc2⟩; by_contra hgt; simp at hgt
    let S := Finset.Icc 1 c
    have : (S.filter (· ∈ Set.range f)).card + (S.filter (· ∈ C_set)).card = c := by
      rw [← Finset.card_union_eq, ← Finset.filter_or]
      · apply Finset.card_congr (fun (x : ℤ) _ => x.toNat); intro; simp; intro x hx _; exact x
      · intro x; simp; intro hx; cases em (∃ i, f i = x) <;> simp [*]
      · apply Finset.disjoint_filter; intro x h; simp; intro i hi; exact hi
    have hf : ∀ i, f i ≤ c ↔ i ≤ c - a i := fun i => by rw [f]; exact ℤ.le_sub_iff_add_le
    have hS1 : (S.filter (· ∈ Set.range f)).card ≤ (c - 1) := by
      have : (S.filter (· ∈ Set.range f)).card = (Finset.univ.filter (fun i => f i ∈ S)).card := by
        rw [Finset.card_congr (fun i _ => f i)] <;> (intros; simp_all)
      have : ∀ i, f i ∈ S → i ≤ c - 1 := fun i hi_s => by
        have := (hi i).1; have := hf i |>.mp (by simp_all); linarith
      have : (Finset.univ.filter (fun i => f i ∈ S)).card ≤ c - 1 := by
        rw [Finset.card_le_card_of_subset (fun i hi_s => by simp_all)]; simp; linarith
      exact this
    have hS2 : (S.filter (· ∈ C_set)).card ≥ 1 := by
      have : c ∈ S.filter (· ∈ C_set) := by simp [hc1, hc2]
      exact Finset.card_pos.mpr ⟨c, this⟩
    linarith
  have hC_fin : C_set.Finite := Set.Finite.subset (Set.finite_Icc 1 2015) (fun c hc => ⟨hc.1, hC_bound c hc⟩)
  let b_nat := hC_fin.toFinset.card
  have hb_pos : 0 < b_nat := by
    have : 1 ∈ C_set := ⟨by simp, fun i => by have := (hi i).1; linarith [f]⟩
    exact Finset.card_pos.mpr ⟨1, by simp [this]⟩
  let b : ℕ+ := ⟨b_nat, hb_pos⟩
  let N : ℕ+ := ⟨(hC_fin.toFinset.max.getD 0).toNat + 1, Nat.succ_pos _⟩
  use b, N; intro m n hmn
  let D (k : ℕ+) : Finset ℤ := ((Finset.Icc 1 k).image f).filter (· > k) |>.image (· - k)
  have h_S (k : ℕ+) (hk : N ≤ k) : ∑ i in Finset.Icc 1 k, (a i - (b : ℤ)) = (∑ d in D k, d) - ∑ c in hC_fin.toFinset, c := sorry
  have h_D (k : ℕ+) (hk : N ≤ k) : (D k).card = b ∧ 1 ∈ D k ∧ ∀ d ∈ D k, 1 ≤ d ∧ d ≤ 2015 := sorry
  rw [Finset.sum_Icc_eq_sub _ (PNat.one_le m) (hmn.1.le), h_S n (hmn.2.trans hmn.1.le), h_S m hmn.2]
  simp only [sub_sub_sub_cancel_right, abs_sub_le_iff]
  obtain ⟨hDn_card, hDn_one, hDn_range⟩ := h_D n (hmn.2.trans hmn.1.le)
  obtain ⟨hDm_card, hDm_one, hDm_range⟩ := h_D m hmn.2
  have h_bound (S : Finset ℤ) (hS_card : S.card = b) (hS_one : 1 ∈ S) (hS_range : ∀ d ∈ S, 1 ≤ d ∧ d ≤ 2015) :
      (1 + (b_nat-1)*b_nat/2 : ℤ) ≤ ∑ d in S, d ∧ (∑ d in S, d) ≤ 1 + (b_nat-1)*(2015-b_nat) + (b_nat-1)*b_nat/2 := sorry
  have hb_bound : b_nat ≤ 2015 := by
    have := h_D N (le_refl N); rw [← hDn_card] at hb_pos; apply Finset.card_le_card_of_subset hDn_range; simp
  nlinarith [h_bound (D n) hDn_card hDn_one hDn_range, h_bound (D m) hDm_card hDm_one hDm_range]
