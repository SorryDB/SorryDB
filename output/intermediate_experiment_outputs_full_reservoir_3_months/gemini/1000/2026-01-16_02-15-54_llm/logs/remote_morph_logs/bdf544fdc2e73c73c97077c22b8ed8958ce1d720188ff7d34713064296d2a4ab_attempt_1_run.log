```lean
import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun k => k + a k
  have f_inj : Function.Injective f := by
    intro k l hkl
    rcases lt_trichotomy k l with h | h | h
    · exact (hii l k ⟨Nat.one_le k, h⟩ hkl.symm).elim
    · exact h
    · exact (hii k l ⟨Nat.one_le l, h⟩ hkl).elim
  let S := {n : ℕ+ | ∀ k, f k ≠ n}
  have S_bound : ∀ s ∈ S, (s : ℤ) ≤ 2015 := by
    intro s hs
    by_contra h_gt
    simp at h_gt
    let s_nat : ℕ := s
    let f_vals := (Finset.range (s_nat - 1)).image (fun i => (f ⟨i + 1, Nat.succ_pos i⟩).toNat)
    have f_vals_subset : f_vals ⊆ Finset.Icc 1 (s_nat + 2014) := by sorry
    sorry
  have S_finite : S.Finite := Set.Finite.subset (Set.finite_le_nat 2015) (fun s hs => hs)
  let b_nat : ℕ := S_finite.toFinset.card
  have b_pos : 0 < b_nat := by
    have : (1 : ℕ+) ∈ S := fun k hk => by
      have : 2 ≤ f k := by linarith [(hi k).1]
      exact (ne_of_lt this).symm (by exact PNat.one_coe ▸ hk)
    exact Finset.card_pos.mpr ⟨1, S_finite.mem_toFinset.mpr this⟩
  let b : ℕ+ := ⟨b_nat, b_pos⟩
  let N : ℕ+ := ⟨2016, by linarith⟩
  use b, N
  intro m n hmn
  let s (k : ℕ+) : ℤ := ∑ i ∈ Finset.Icc 1 k, (a i - b)
  have h_s_val : ∀ k ≥ N, ∃ V ⊆ Finset.Icc 1 2015, V.card = b ∧ s k = (∑ v in V, v) - (∑ s in S_finite.toFinset, s) - b := by sorry
  rcases h_s_val m (by linarith [hmn.2]) with ⟨Vm, hVm1, hVm2, hVm3⟩
  rcases h_s_val n (by linarith [hmn.1, hmn.2]) with ⟨Vn, hVn1, hVn2, hVn3⟩
  rw [Finset.sum_Icc_eq_sub_sum_Icc (by linarith [hmn.1]), hVm3, hVn3]
  simp only [sub_sub_sub_cancel_right]
  let f_sum (V : Finset ℤ) := ∑ v in V, (v - 1008)
  have h_range : ∀ V ⊆ Finset.Icc 1 2015, V.card = b_nat → abs (f_sum V) ≤ (b_nat * (2015 - b_nat)) / 2 := by sorry
  sorry
```
