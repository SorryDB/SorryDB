import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := λ n => (n : ℤ) + a n
  have hf : Function.Injective f := by
    intro k l hkl; rcases lt_trichotomy k l with h | h | h
    · exfalso; exact hii l k ⟨by simp, h⟩ hkl.symm
    · exact h
    · exfalso; exact hii k l ⟨by simp, h⟩ hkl
  let T : Set ℤ := {x | x ≥ 1 ∧ ∀ n, f n ≠ x}
  have hT_bound : ∀ x ∈ T, x ≤ 2015 := by
    intro x hx; by_contra h_gt; push_neg at h_gt
    let S := (Finset.Icc 1 (x.toNat)).image f
    have hS_card : S.card = x.toNat := by
      rw [Finset.card_image_of_injective _ hf, Finset.card_Icc, Nat.add_sub_cancel, PNat.one_val]
    have h_subset : S ⊆ Finset.Icc 2 (x.toNat + 2015) := by
      intro y hy; rcases Finset.mem_image.1 hy with ⟨n, hn, rfl⟩
      simp at hn; exact ⟨by linarith [hi n], by linarith [hi n]⟩
    have : S.card ≤ (x.toNat + 2015) - 2 + 1 := Finset.card_le_of_subset h_subset
    linarith
  have hT_finite : T.Finite := Set.Finite.subset (Set.finite_Icc 1 2015) hT_bound
  let T_fin := hT_finite.toFinset
  let b : ℕ+ := ⟨T_fin.card, by
    have : 1 ∈ T := ⟨by simp, λ n => by linarith [hi n]⟩
    have : 1 ∈ T_fin := by simp [T_fin, this]
    exact Finset.card_pos.2 ⟨1, this⟩⟩
  let N : ℕ+ := ⟨max 2015 (T_fin.max.getD 0).toNat + 1, by linarith⟩
  use b, N
  intro m n hmn
  let x (k : ℕ+) : ℤ := ∑ j in Finset.Icc 1 k, (a j - b)
  suffices ∀ k, N ≤ k → ∃ H, 0 ≤ H ∧ H ≤ 1007 ^ 2 ∧ ∃ C, x k = H + C by
    rcases this m hmn.2 with ⟨Hm, 0 ≤ Hm, Hm_le, C, rfl⟩
    rcases this n (le_trans hmn.2 (by linarith [hmn.1])) with ⟨Hn, 0 ≤ Hn, Hn_le, C', rfl⟩
    have : C = C' := by
      let k_large := max n.val N.val + 2015
      sorry -- C is constant for k >= N
    rw [this, Finset.sum_Icc_eq_sub_sum_Icc_1 (by linarith [hmn.1]) (by simp), sub_add_eq_sub_sub, add_sub_cancel_right]
    exact (abs_sub_le_iff.2 ⟨by linarith, by linarith⟩)
  intro k hk
  let Sk := (Finset.Icc 1 k).image f
  let Uk := (Finset.Icc 1 (k + b)).filter (λ x => x ∉ T)
  have hUk_card : Uk.card = k := by
    simp [Uk, Finset.filter_not, T_fin]; rw [Finset.card_sdiff]
    · simp; rw [Finset.card_Icc, Nat.add_sub_cancel, PNat.one_val]; rfl
    · intro x hx; simp [T_fin] at hx; exact ⟨by linarith, by linarith [hT_bound x hx]⟩
  let Ek := Sk \ Uk
  let Fk := Uk \ Sk
  have hEkFk : Ek.card = Fk.card := by
    have : Sk.card = Uk.card := by rw [hUk_card, Finset.card_image_of_injective _ hf, Finset.card_Icc]; simp
    rw [Finset.card_sdiff (Finset.sdiff_subset Sk Uk), Finset.card_sdiff (Finset.sdiff_subset Uk Sk), this]
  let m_k := Ek.card
  let Hk := (∑ y in Ek, y) - (∑ y in Fk, y)
  let C := (∑ y in Uk, y) - (∑ j in Finset.Icc 1 k, (j + b))
  use Hk + (∑ j in Fk, (k + b)) - (∑ j in Ek, (k + b)) -- should be simplified to use the m_k distinct integers logic
  sorry
