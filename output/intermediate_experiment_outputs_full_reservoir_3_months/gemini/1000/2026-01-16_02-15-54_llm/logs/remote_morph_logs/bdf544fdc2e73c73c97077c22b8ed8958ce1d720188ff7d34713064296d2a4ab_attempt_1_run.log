```lean
import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  have f_inj : ∀ j k, f j = f k → j = k := by
    intro j k h
    rcases j.eq_or_lt_or_gt k with hj | hj | hj
    · exact hj
    · have := hii k j ⟨by simp, hj⟩; exfalso; exact this h.symm
    · have := hii j k ⟨by simp, hj⟩; exfalso; exact this h
  let S : Set ℤ := {x | 1 ≤ x} \ Set.range f
  have f_range : ∀ j, (j : ℤ) + 1 ≤ f j ∧ f j ≤ (j : ℤ) + 2015 := fun j => by
    simp [f]; exact ⟨(hi j).1, (hi j).2⟩
  have S_bound : ∀ x ∈ S, x ≤ 2015 := by
    intro x hx; simp [S] at hx; rcases hx with ⟨h1, h2⟩
    have : ∀ j, (j : ℤ) ≥ x → f j > x := fun j hj => by
      have := (f_range j).1; calc f j ≥ j + 1 ≥ x + 1 > x
    let Imf_x := (Set.range f) ∩ {1, 2, ..., x + 2015}
    by_contra hgt
    let s := Finset.Icc 1 (x : ℕ)
    have : ∀ j ∈ s, f j ≤ x + 2015 := fun j hj => by
      simp at hj; have := (f_range j).2; apply this.trans; simp; exact hj
    have : (Finset.image (fun j : ℕ+ => f j) s.attach).card = x := by
      rw [Finset.card_image_of_injOn]; simp; exact fun _ _ _ _ h => f_inj _ _ h
    sorry
  let b_nat := S.toFinset.card
  have b_pos : 0 < b_nat := sorry
  let b : ℕ+ := ⟨b_nat, b_pos⟩
  let N : ℕ+ := ⟨2016, by norm_num⟩
  use b, N
  intro m n ⟨hmn, hNm⟩
  sorry
```
