```lean
import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  have f_inj : Function.Injective f := fun k l h => by
    rcases hne_iff_lt_or_gt.1 (fun h' => (by rwa [h'] at h : f l = f l)) with h'|h'
    · cases hii l k ⟨k.2, h'⟩ h.symm
    · cases hii k l ⟨l.2, h'⟩ h
  let T_set := {k : ℤ | 1 ≤ k ∧ k ∉ Set.range f}
  have T_bound : ∀ k ∈ T_set, k ≤ 2015 := by
    intro k ⟨hk1, hkR⟩; by_contra hgt
    let I := Finset.Icc 1 (k.toNat - 2015)
    have : ∀ j ∈ I, f ⟨j, by simp [j.2]⟩ < k := by
      intro j hj; simp at hj
      have := hi ⟨j, by simp [j.2]⟩
      calc f ⟨j, by simp [j.2]⟩ ≤ (k.toNat - 2015 : ℤ) + 2015 := add_le_add_right (Int.ofNat_le.2 hj.2) 2015
        _ = k.toNat := by simp
        _ = k := Int.toNat_of_nonneg (by linarith)
    have hfI : (I.image (fun (j : ℕ) => f ⟨j, by simp [j.2]⟩)).card = I.card :=
      Finset.card_image_of_injective _ (fun _ _ _ _ h => Subtype.val_inj.1 (f_inj h))
    let S := (Finset.Icc 1 (k - 1)).filter (fun x => x ∈ Set.range f)
    have : I.image (fun j => f ⟨j, by simp [j.2]⟩) ⊆ S := by
      intro x hx; simp at hx; obtain ⟨j, hj1, hj2⟩ := hx
      simp; refine ⟨⟨by linarith, by linarith⟩, ⟨⟨j, by simp [hj1]⟩, hj2⟩⟩
    have : I.card ≤ S.card := Finset.card_le_of_subset this
    have : S.card ≤ (k-1) := by simp [S, Finset.card_filter_le]
    have : k.toNat - 2015 ≤ k - 1 - (k - 1 - S.card) := by linarith
    have : S.card = (k-1) - (T_set.∩ {x | 1 ≤ x ∧ x ≤ k - 1}).ncard := sorry
    sorry
  let T_fin := (Finset.Icc 1 2015).filter (fun k => ∀ j : ℕ+, (j : ℤ) < k → f j ≠ k)
  let b_val : ℕ := T_fin.card
  have hb : 1 ≤ b_val := by
    have : 1 ∈ T_fin := by simp [f]; intro j; linarith [hi j]
    exact Finset.card_pos.2 ⟨1, this⟩
  let b : ℕ+ := ⟨b_val, hb⟩
  let N_val : ℕ := T_fin.max.getD 1 |>.toNat + 1
  let N : ℕ+ := ⟨N_val, Nat.succ_pos _⟩
  use b, N; intro m n ⟨hmn, hNm⟩
  let V (k : ℕ+) : ℤ := ∑ j ∈ (Finset.Icc 1 k).filter (fun j => f j > k), (f j - k)
  have h_step : ∀ k : ℕ+, V (k + 1) - V k = a (k + 1) - b := sorry
  have h_sum : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = V n - V m := by
    rw [← Finset.sum_range_add_one_Icc (f := fun j => (a j - b)) (m := m) (n := n-1)]
    sorry
  have h_range : ∀ k ≥ N, (b : ℤ) * (b + 1) / 2 ≤ V k ∧ V k ≤ (b : ℤ) * 2015 - (b : ℤ) * (b - 1) / 2 := sorry
  have h_one : ∀ k ≥ N, 1 ∈ (Finset.Icc 1 k).filter (fun j => f j > k).image (fun j => f j - k) := sorry
  have h_bound : ∀ k ≥ N, (b : ℤ) * (b + 1) / 2 ≤ V k ∧ V k ≤ (b : ℤ) * (b + 1) / 2 + (b - 1) * (2015 - b) := sorry
  have : (b - 1 : ℤ) * (2015 - b) ≤ 1007 ^ 2 := by
    let x : ℤ := b - 1
    have hx : 0 ≤ x ∧ x ≤ 2014 := by rcases b with ⟨b, hb⟩; simp at *; linarith [T_bound]
    have := x * (2014 - x)
    have : x * (2014 - x) ≤ 1007 * 1007 := by
      have : x * (2014 - x) = 1007 ^ 2 - (x - 1007) ^ 2 := by ring
      nlinarith
    exact this
  sorry
