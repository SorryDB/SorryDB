import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => j + a j
  have f_inj : Function.Injective f := fun k l h => by
    if hkl : k < l then exact (hii l k ⟨k.2, hkl⟩ h.symm).elim
    else if hlk : l < k then exact (hii k l ⟨l.2, hlk⟩ h).elim
    else exact PNat.ext (le_antisymm (not_lt.1 hlk) (not_lt.1 hkl))
  let X (n : ℕ+) := (Finset.Icc 1 n).filter (fun j => f j > n) |>.image (fun j => f j - n)
  have k_mono : ∀ n, (X n).card ≤ (X (n + 1)).card := sorry
  have k_bdd : ∀ n, (X n).card ≤ 2015 := sorry
  obtain ⟨b_val, N, hN⟩ : ∃ b N, ∀ n ≥ N, (X n).card = b := sorry
  have b_pos : 0 < b_val := sorry
  let b : ℕ+ := ⟨b_val, b_pos⟩
  use b, N
  intro m n hmn
  let R (k : ℕ+) := (X k).sum (fun x => x)
  have h_sum : ∑ j in Finset.Icc (m + 1) n, (a j - b) = R n - R m := sorry
  have h_X_val : ∀ k ≥ N, (X k).card = b ∧ 1 ∈ X k ∧ ∀ x ∈ X k, 1 ≤ x ∧ x ≤ 2015 := sorry
  have h_R_range (k : ℕ+) (hk : k ≥ N) :
    let Rmin := (b : ℤ) * (b + 1) / 2
