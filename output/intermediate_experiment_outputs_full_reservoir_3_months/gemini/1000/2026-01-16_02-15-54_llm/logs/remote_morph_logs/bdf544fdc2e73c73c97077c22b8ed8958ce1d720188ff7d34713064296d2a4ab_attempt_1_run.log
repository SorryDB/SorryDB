import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  set f : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  set R := (Finset.Icc 1 2015).filter fun r => ∀ j, f j ≠ r
  have hR : ∀ r : ℤ, r ≥ 1 ∧ (∀ j, f j ≠ r) ↔ r ∈ R := by
    intro r; constructor
    · intro h; simp [R, h.1]; by_contra h_gt; push_neg at h_gt
      let s := Finset.Icc 1 (r - 1)
      have hf_inj : Set.InjOn f s := fun j hj k hk hjk => by
        by_cases hj_lt_k : j < k
        · exact (hii k j ⟨by linarith [j.2], hj_lt_k⟩ hjk.symm).elim
        · by_cases hk_lt_j : k < j
          · exact (hii j k ⟨by linarith [k.2], hk_lt_j⟩ hjk).elim
          · exact Subtype.ext (linarith : (j : ℕ) = k)
      have hf_img : s.image f ⊆ Finset.Icc 2 (r + 2015) := by
        intro x hx; simp at hx; obtain ⟨j, hj, rfl⟩ := hx; simp; constructor
        · linarith [hi j, j.2]
        · linarith [hj, hi j]
      have hf_not_r : r ∉ s.image f := by intro h_in; simp at h_in; obtain ⟨j, hj, hjf⟩ := h_in; exact h.2 j hjf
      have hf_range : s.image f ⊆ Finset.Icc 2 (r - 1) := by
        intro x hx; simp at hx; obtain ⟨j, hj, rfl⟩ := hx; simp; constructor
        · linarith [hi j, j.2]
        · have : f j ≤ j + 2015 := by linarith [hi j]
          have : f j > j := by linarith [hi j]
          refine ⟨by linarith [hj, h.2 j], hj.2.trans (by linarith)⟩
      have : s.card ≤ (Finset.Icc 2 (r - 1)).card := (Finset.card_image_of_injOn hf_inj).symm.trans_le (Finset.card_le_of_subset hf_range)
      simp at this; linarith
    · intro hr; simp [R] at hr; exact ⟨hr.1, hr.2⟩
  let b : ℕ+ := ⟨R.card, by
    have h1 : 1 ∈ R := by simp [R]; intro j; linarith [hi j, j.2]
    exact Finset.card_pos.mpr ⟨1, h1⟩⟩
  use b, 2015; intro m n hmn
  let S (k : ℕ+) : ℤ := ∑ j in Finset.Icc 1 k, (a j - b)
  have h_Sn : ∀ k ≥ 2015, S k = (∑ j in Finset.Icc 1 k, if f j > k then f j - k else 0) - (∑ r in R, r) := sorry
  rw [Finset.sum_Icc_eq_sum_Icc_sub_sum_Icc hmn.1, show (∑ j in Finset.Icc (m + 1) n, (a j - b)) = S n - S m by simp [S]]
  rw [h_Sn n (by linarith [hmn.1, hmn.2]), h_Sn m hmn.2]
  let V (k : ℕ+) : ℤ := ∑ j in Finset.Icc 1 k, if f j > k then f j - k else 0
  have h_V_card : ∀ k ≥ 2015, (Finset.Icc 1 k).filter (fun j => f j > k).card = b := sorry
  have h_V_range : ∀ k ≥ 2015, ∀ j ∈ (Finset.Icc 1 k).filter (fun j => f j > k), 1 ≤ f j - k ∧ f j - k ≤ 2015 := sorry
  have h_V_inj : ∀ k ≥ 2015, Set.InjOn (fun j => f j - k) ((Finset.Icc 1 k).filter (fun j => f j > k)) := sorry
  have h_V_sum : ∀ k ≥ 2015, ∃ D ⊆ Finset.Icc 1 2015, D.card = b ∧ V k = ∑ d in D, d := sorry
  obtain ⟨Dn, hDn1, hDn2, hDn3⟩ := h_V_sum n (by linarith [hmn.1, hmn.2])
  obtain ⟨Dm, hDm1, hDm2, hDm3⟩ := h_V_sum m hmn.2
  rw [hDn3, hDm3, abs_le]; constructor <;> linarith [show (∑ d in Dn, (d : ℤ)) - (∑ d in Dm, (d : ℤ)) ≤ (b : ℤ) * (2015 - b) by sorry,
    show (∑ d in Dn, (d : ℤ)) - (∑ d in Dm, (d : ℤ)) ≥ -((b : ℤ) * (2015 - b)) by sorry,
    show (b : ℤ) * (2015 - b) ≤ 1007^2 by
      set x := (b : ℤ)
      have : x * (2015 - x) ≤ (2015 / 2 : ℤ) * (2015 - 2015 / 2 : ℤ) := sorry
      linarith]
