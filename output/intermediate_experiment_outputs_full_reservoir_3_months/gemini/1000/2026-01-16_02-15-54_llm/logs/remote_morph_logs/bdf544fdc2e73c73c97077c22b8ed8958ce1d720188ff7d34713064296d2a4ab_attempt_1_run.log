import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  set f : ℕ+ → ℤ := fun j => j + a j
  have hf : Function.Injective f := fun k l h => by
    rcases lt_trichotomy k l with h1 | h2 | h3
    · exact (hii l k ⟨Nat.one_le k, h1⟩ h.symm).elim
    · exact h2
    · exact (hii k l ⟨Nat.one_le l, h3⟩ h).elim
  let U := {n : ℤ | n > 0 ∧ n ∉ Set.range f}
  have hU_mem : ∀ u ∈ U, 1 ≤ u ∧ u ≤ 2015 := fun u ⟨hu, hur⟩ =>
    ⟨hu, by
      by_contra! h; set S := Finset.Icc 1 (u - 2015)
      have : S.image f ⊆ Finset.Icc 2 u := fun x hx => by
        rcases Finset.mem_image.mp hx with ⟨j, hj, rfl⟩
        rcases Finset.mem_Icc.mp hj with ⟨hj1, hj2⟩
        exact ⟨by linarith [(hi j).1], by linarith [(hi j).2]⟩
      have := Finset.card_le_of_subset this
      rw [Finset.card_image_of_injective _ hf, Finset.card_Icc, Finset.card_Icc] at this
      simp at this; linarith⟩
  have hU_fin : U.Finite := Set.Finite.subset (Set.finite_Icc 1 2015) hU_mem
  let b : ℕ+ := ⟨hU_fin.toFinset.card, by
    have : 1 ∈ U := ⟨by linarith, fun ⟨j, hj⟩ => by have := (hi j).1; linarith [hj]⟩
    exact Finset.card_pos.mpr ⟨1, Set.Finite.mem_toFinset.mpr this⟩⟩
  use b, ⟨2015, by linarith⟩
  intro m n ⟨hmn, hmN⟩
  let g (k : ℕ+) : ℤ := (∑ j ∈ Finset.Icc 1 k, a j) - (k : ℤ) * b
  have hgk (k : ℕ+) (hk : 2015 ≤ k) : ∃ A : Finset ℤ, A.card = b ∧ A ⊆ Finset.Icc 1 2015 ∧ 1 ∈ A ∧ g k = (∑ x ∈ A, x) - (∑ u ∈ hU_fin.toFinset, u) := sorry
  rcases hgk m (by linarith [hmN]) with ⟨Am, hm1, hm2, hm3, hm4⟩
  rcases hgk n (by linarith [hmN, hmn]) with ⟨An, hn1, hn2, hn3, hn4⟩
  rw [Finset.sum_Icc_eq_sub, Finset.sum_sub_distrib, g, g, sub_sub_sub_comm]
  rw [hn4, hm4, sub_sub_sub_cancel_right, abs_sub_le_iff]
  · have h_bound (A : Finset ℤ) (hA1 : A.card = b) (hA2 : A ⊆ Finset.Icc 1 2015) (hA3 : 1 ∈ A) :
      (b : ℤ) * (b + 1) / 2 ≤ ∑ x ∈ A, x ∧ ∑ x ∈ A, x ≤ 1 + (b - 1) * 2015 - (b - 1) * (b - 2) / 2 := sorry
    have hmin : (b : ℤ) * (b + 1) / 2 ≤ ∑ x ∈ Am, x := (h_bound Am hm1 hm2 hm3).1
    have hmax : (∑ x ∈ An, x) ≤ 1 + (b - 1) * 2015 - (b - 1) * (b - 2) / 2 := (h_bound An hn1 hn2 hn3).2
    have hmax_diff : (1 + (b - 1) * 2015 - (b - 1) * (b - 2) / 2) - (b : ℤ) * (b + 1) / 2 = (b - 1) * (2015 - b) := by ring
    have h_final : (b : ℤ - 1) * (2015 - b) ≤ 1007 ^ 2 := by
      set x := (b : ℤ) - 1
      have : 0 ≤ x ∧ x ≤ 2014 := by rcases b; dsimp at *; linarith [hU_mem]
      have : x * (2014 - x) ≤ 1007 ^ 2 := by
        nlinarith [sq_nonneg (x - 1007)]
      linarith
    constructor <;> linarith [(h_bound Am hm1 hm2 hm3).2, (h_bound An hn1 hn2 hn3).1]
  · linarith
