import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f (k : ℕ) : ℕ := if h : k = 0 then 0 else (k + (a ⟨k, Nat.pos_of_ne_zero h⟩)).toNat
  have hf : ∀ k : ℕ, k > 0 → f k = k + (a ⟨k, Nat.pos_of_ne_zero (Nat.ne_of_gt k)⟩).toNat := by
    intro k hk; simp [f, hk, (hi ⟨k, hk⟩).1]
  have finj : ∀ k l, k > 0 → l > 0 → f k = f l → k = l := by
    intro k l hk hl hfe
    have : (k : ℤ) + a ⟨k, hk⟩ = (l : ℤ) + a ⟨l, hl⟩ := by
      rw [hf k hk, hf l hl] at hfe; push_cast at hfe; exact hfe
    by_contra h; exact hii (if k < l then ⟨l, hl⟩ else ⟨k, hk⟩) (if k < l then ⟨k, hk⟩ else ⟨l, hl⟩) (by
      split <;> split <;> simp_all [not_lt]
      · exact ⟨hk, h⟩
      · have : l < k := Nat.lt_of_le_of_ne (not_lt.1 ‹¬k < l›) (Ne.symm h)
        exact ⟨hl, this⟩) this
  let S := {x : ℕ | x > 0 ∧ ∃ k > 0, f k = x}
  let T := {x : ℕ | x > 0 ∧ x ∉ S}
  have T_bound : ∀ x, (T ∩ Finset.range (x + 1)).card ≤ 2015 := by
    intro x; let Kx := {k : ℕ | k > 0 ∧ f k ≤ x}
    have : Kx.finite := by apply Set.Finite.subset (Set.finite_Ioc 0 x); intro k hk; exact ⟨hk.1, (Nat.le_trans (Nat.add_le_add_right hk.1 _) hk.2)⟩
    let fKx := Kx.toFinset; have card_k : fKx.card = (Finset.range (x + 1)).filter (· ∈ S) |>.card := by
      rw [Finset.card_congr (fun k _ => f k)]; · intro k hk; simp [fKx] at hk; simp [S, hk.1, hk.2]
      · intro k1 k2 hk1 hk2 hfe; simp [fKx] at hk1 hk2; exact finj k1 k2 hk1.1 hk2.1 hfe
      · intro y hy; simp at hy; rcases hy.2 with ⟨k, hk, fky⟩; use k; simp [fKx, hk, fky, y, hy.1]
    have : (Finset.range (x + 1)).filter (· > 0) |>.card = (Finset.range (x + 1)).filter (· ∈ S) |>.card + (Finset.range (x + 1)).filter (· ∈ T) |>.card := by
      rw [← Finset.card_union_eq]; · apply Finset.card_congr (fun x _ => x) <;> simp [S, T]
      · apply Finset.disjoint_filter.2; intro x hx; simp [T]
    have card_total : ((Finset.range (x + 1)).filter (· > 0)).card = x := by simp
    rw [card_total, card_k] at this
    have kx_bound : x - 2015 ≤ fKx.card ∧ fKx.card ≤ x - 1 := by
      constructor
      · intro; let n := x.filter (· ∈ Kx); sorry -- Simplified bound logic
      · sorry
    sorry -- The core proof continues to show $b = |T|$ and bounded sum.
  sorry
