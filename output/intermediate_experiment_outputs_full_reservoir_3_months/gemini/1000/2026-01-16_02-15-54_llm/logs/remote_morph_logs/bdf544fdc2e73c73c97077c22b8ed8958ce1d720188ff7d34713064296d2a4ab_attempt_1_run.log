@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro l k h; cases' lt_trichotomy l k with h1 h12 h2
    · exact (hii k l ⟨l.2, h1⟩ h.symm).elim
    · exact h12
    · exact (hii l k ⟨k.2, h2⟩ h).elim
  let T := {n : ℤ | 1 ≤ n ∧ n ∉ Set.range f}
  have hT_sub : T ⊆ Set.Icc 1 2015 := fun x ⟨h1, h2⟩ => by
    refine ⟨h1, not_lt.1 fun hgt => h2 ?_⟩
    let k0 : ℕ := (x - 2015).toNat + 1
    have h_k0 : 0 < k0 := Nat.succ_pos _
    let k := PNat.mk k0 h_k0
    have : f k ≤ x := by dsimp [f]; linarith [(hi k).2]
    have : x < f k := by
      let k' : ℕ := (x - (a k)).toNat
      have : 0 < k' := by have := hi k; have := h1; linarith
      let pk' := PNat.mk k' this
      have : f pk' = x := by dsimp [f]; linarith
      exact (h2 ⟨pk', this⟩).elim
    linarith
  have hT_fin : T.Finite := Set.Finite.subset (Set.finite_Icc 1 2015) hT_sub
  let b0 : ℕ := hT_fin.toFinset.card
  have b_pos : 0 < b0 := by
    have h1T : 1 ∈ T := ⟨by norm_num, fun ⟨k, hk⟩ => by have := hi k; dsimp [f] at hk; linarith⟩
    exact Finset.card_pos.2 ⟨1, by simpa using h1T⟩
  let b : ℕ+ := ⟨b0, b_pos⟩
  let N : ℕ+ := ⟨2016 + (if hT_fin.toFinset.Nonempty then hT_fin.toFinset.max' (by simpa) else 0).toNat, by iota_reflexive⟩
  use b, N
  intro m n ⟨hmn, hNm⟩
  let G : ℕ+ → ℤ := fun k => (∑ i ∈ Finset.Icc 1 k, f i) - (∑ i ∈ Finset.Icc 1 k, (i + (b : ℤ)))
  have hG_def : ∀ k ≥ N, ∃ d_k : ℤ, 0 ≤ d_k ∧ d_k ≤ 1007 ∧ ∃ C : ℤ, G k = C + (d_k * 2014 - d_k^2) := sorry
  have h_diff : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = G n - G m := by
    rw [Finset.sum_sub_distrib, ← Finset.sum_Icc_consecutive _ (PNat.one_le m) hmn]
    simp [f, add_comm]; abel
  sorry
