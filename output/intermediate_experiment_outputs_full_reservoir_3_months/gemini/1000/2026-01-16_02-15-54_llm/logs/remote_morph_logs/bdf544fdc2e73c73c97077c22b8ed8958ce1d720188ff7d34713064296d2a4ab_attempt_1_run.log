```lean
import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro j k hjk
    rcases lt_trichotomy j k with hjk' | rfl | hkj'
    · exact (hii k j ⟨by simp, hjk'⟩ hjk.symm).elim
    · rfl
    · exact (hii j k ⟨by simp, hkj'⟩ hjk).elim
  let S := Set.range f
  let B := {x : ℤ | 1 ≤ x ∧ x ∉ S}
  have hB_bound : ∀ x ∈ B, 1 ≤ x ∧ x ≤ 2015 := by
    intro x ⟨h1, hxS⟩
    refine ⟨h1, not_lt.1 fun hx_gt => hxS ?_⟩
    let K := Finset.Icc 1 (x - 2015 - 1).toNat
    have : ∀ k ∈ K, f (PNat.ofNat' (k.toNat + 1)) < x := by
      intro k hk
      simp [f]
      have : (k : ℤ) ≤ x - 2015 - 1 := by simpa using hk
      exact (hi _).2.trans_lt (by linarith)
    have : Finset.card (K.image (fun k => f (PNat.ofNat' (k.toNat + 1)))) = K.card :=
      Finset.card_image_of_injective K (fun k1 k2 heq => by
        have := f_inj heq
        simpa using this)
    sorry
  have hB_finite : B.Finite := Set.Finite.subset (Set.finite_Icc 1 2015) hB_bound
  let b_nat := hB_finite.toFinset.card
  have hb_pos : 1 ≤ b_nat := by
    have : 1 ∈ B := ⟨le_refl 1, fun ⟨j, hj⟩ => by linarith [(hi j).1]⟩
    simpa [b_nat] using hB_finite.toFinset.nonempty_encapsulate this
  let b : ℕ+ := ⟨b_nat, hb_pos⟩
  obtain ⟨N, hN⟩ : ∃ N : ℕ+, ∀ n ≥ N, n + 1 ∈ S := sorry
  use b, N
  intro m n ⟨hmn, hNm⟩
  let V (k : ℕ+) := (Finset.Icc 1 k).filter (fun j => f j > k)
  let W (k : ℕ+) := V k |>.image (fun j => f j - k)
  have hW_size : ∀ k ≥ N, (W k).card = b := sorry
  have hW_one : ∀ k ≥ N, (1 : ℤ) ∈ W k := sorry
  have hW_bound : ∀ k ≥ N, ∀ w ∈ W k, 1 ≤ w ∧ w ≤ 2015 := sorry
  have h_sum : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = (∑ w in W n, w) - (∑ w in W m, w) := sorry
  rw [h_sum]
  let sum_W (k : ℕ+) := ∑ w in W k, w
  have h_min : ∀ k ≥ N, (1 + b * (b + 1) / 2 - b : ℤ) ≤ sum_W k := sorry
  have h_max : ∀ k ≥ N, sum_W k ≤ (1 + (2015 + (2015 - b + 2)) * (b - 1) / 2 : ℤ) := sorry
  have h_diff : ∀ k1 k2, k1 ≥ N → k2 ≥ N → abs (sum_W k1 - sum_W k2) ≤ (b - 1) * (2015 - b) := sorry
  apply (h_diff n m (hNm.trans hmn.le) hNm).trans
  have : (b : ℤ) - 1 ≥ 0 := by linarith [b.2]
  have : 2015 - (b : ℤ) ≥ 0 := by
    have : (b : ℤ) ≤ 2015 := sorry
    linarith
  convert_to (b - 1 : ℤ) * (2015 - b) ≤ 1007 ^ 2
  have : ∀ x : ℤ, (x - 1) * (2015 - x) = 1007 ^ 2 - (x - 1008) ^ 2 := by intro x; linarith
  rw [this]
  have : (b - 1008 : ℤ) ^ 2 ≥ 0 := sq_nonneg _
  linarith
