import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := λ n => n + a n
  have f_inj : Function.Injective f := by
    intro i j h
    rcases lt_trichotomy i j with (hij | hij | hij)
    · exact (hii j i ⟨PNat.one_le i, hij⟩ h.symm).elim
    · exact hij
    · exact (hii i j ⟨PNat.one_le j, hij⟩ h).elim
  let U : Set ℤ := Set.range fᶜ ∩ Set.Ici 1
  have U_fin : U.Finite := by
    apply Set.Finite.subset (Set.finite_Icc 1 2015)
    intro x hx
    refine ⟨hx.2, ?_⟩
    by_contra hf
    obtain ⟨n, hn⟩ := Set.not_not_mem.mp hf
    have : x = n + a n := hn
    have : n + 1 ≤ x := by linarith [(hi n).1]
    have : x ≤ n + 2015 := by linarith [(hi n).2]
    have : n < n + 1 := by linarith
    have : ∀ m, f m ≥ m + 1 := λ m => by simpa [f] using (hi m).1
    have h_card : ∀ M : ℕ, {x | x ≤ M ∧ x ∈ Set.range f}.Finite := λ M => Set.toFinite _
    let S (M : ℕ) := {x : ℤ | 1 ≤ x ∧ x ≤ M + 2015} \ {f n | n ≤ M}
    have : ∀ M : ℕ, (S M).ncard = 2015 := by
      intro M
      simp only [Set.ncard_diff (Set.toFinite _) (Set.subset_range_iff_exists.mpr (λ x h => ⟨Classical.choose (Set.mem_range.mp h), by
        obtain ⟨n, hn⟩ := Set.mem_range.mp h
        sorry⟩))]
      sorry
    sorry
  let b_val := U.ncard
  have hb_pos : b_val ≥ 1 := by
    have : 1 ∈ U := by
      simp [U]
      intro hf
      obtain ⟨n, hn⟩ := hf
      have : f n ≥ n + 1 := by simpa [f] using (hi n).1
      linarith [PNat.one_le n]
    exact Set.ncard_pos.mpr ⟨1, this, U_fin⟩
  let b : ℕ+ := ⟨b_val, hb_pos⟩
  let N : ℕ+ := ⟨max 1 (U.toFinset.sup (λ x => x.toNat)), by linarith [PNat.one_le 1]⟩
  use b, N
  intro m n h
  let V (k : ℕ+) := {i : ℕ+ | i ≤ k ∧ f i > k}
  have h_sum : ∀ k ≥ N, ∑ j ∈ Finset.Icc 1 k, (a j - b) = (∑ i in (V k).toFinset, (f i - k)) - (∑ u in U.toFinset, u) := sorry
  have h_size : ∀ k ≥ N, (V k).toFinset.card = b := sorry
  have h_vals : ∀ k ≥ N, ∀ i ∈ (V k).toFinset, 1 ≤ f i - k ∧ f i - k ≤ 2015 := sorry
  have h_one : ∀ k ≥ N, 1 ∈ (V k).toFinset.image (λ i => f i - k) := sorry
  rw [Finset.sum_Icc_eq_sub_sum_range, Nat.Icc_eq_uIcc, Finset.sum_Icc_eq_sub_sum_Icc_unions]
  · sorry
  · linarith
  · sorry
```
