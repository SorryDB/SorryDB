```lean
import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := λ j => j + a j
  have hf_inj : ∀ k l, f k = f l → k = l := by
    intro k l h
    cases' lt_trichotomy k l with h_lt h_etc
    · exact (hii l k ⟨Nat.one_le k, h_lt⟩ h.symm).elim
    · cases' h_etc with h_eq h_gt
      · exact h_eq
      · exact (hii k l ⟨Nat.one_le l, h_gt⟩ h).elim
  have hf_val : ∀ j, j + 1 ≤ f j ∧ f j ≤ j + 2015 := by
    intro j; constructor
    · exact add_le_add_left (hi j).1 j
    · exact add_le_add_left (hi j).2 j
  let R := {x : ℤ | x ≥ 1 ∧ ∀ j, f j ≠ x}
  have hR_ub : ∀ x ∈ R, x ≤ 2015 := by
    intro x ⟨hx_ge1, hx_nin⟩
    by_contra hx_gt
    push_neg at hx_gt
    let S := Finset.Icc 1 x
    have hS_card : S.card = x := by simp [S, hx_ge1]
    have h_im : ∀ j ∈ S, f j < x + 2015 := by
      intro j hj; exact (hf_val j).2.trans_lt (by simp only [S, Finset.mem_Icc] at hj; linarith)
    have h_card : (Finset.image f (S.filter (λ j => f j ≤ x))).card + (S.filter (λ x => x ∉ Set.range f)).card = x := by sorry
    sorry
  let b_nat := (Finset.filter (λ x : ℤ => 1 ≤ x ∧ ∀ j, f j ≠ x) (Finset.Icc 1 2015)).card
  have hb_pos : b_nat ≥ 1 := by
    have h1 : 1 ∈ Finset.filter (λ x : ℤ => 1 ≤ x ∧ ∀ j, f j ≠ x) (Finset.Icc 1 2015) := by
      simp; intro j; linarith [hf_val j]
    exact Finset.card_pos.mpr ⟨1, h1⟩
  let b : ℕ+ := ⟨b_nat, hb_pos⟩
  let N : ℕ+ := 2015
  use b, N; intro m n hmn
  let S_val (k : ℕ+) : ℤ := ∑ j in Finset.filter (λ j => j ≤ k ∧ f j > k) (Finset.Icc 1 (k + 2015)), (f j - k)
  have h_diff : ∀ k, k ≥ N → ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = S_val n - S_val m := by sorry
  rw [h_diff m hmn.2]
  have hS_bound : ∀ k, k ≥ N → ∃ D : Finset ℤ, D.card = b ∧ (∀ d ∈ D, 1 ≤ d ∧ d ≤ 2015) ∧ (1 ∈ D) ∧ S_val k = ∑ d in D, d := by sorry
  obtain ⟨Dn, hDn_card, hDn_range, hDn_one, hSn⟩ := hS_bound n (hmn.2.trans hmn.1.le)
  obtain ⟨Dm, hDm_card, hDm_range, hDm_one, hSm⟩ := hS_bound m hmn.2
  rw [hSn, hSm]
  have h_max_diff : ∀ (D1 D2 : Finset ℤ), D1.card = b ∧ (∀ d ∈ D1, 1 ≤ d ∧ d ≤ 2015) ∧ (1 ∈ D1) →
    D2.card = b ∧ (∀ d ∈ D2, 1 ≤ d ∧ d ≤ 2015) ∧ (1 ∈ D2) →
    abs (∑ d in D1, d - ∑ d in D2, d) ≤ (b - 1) * (2015 - b) := by sorry
  apply (h_max_diff Dn Dm ⟨hDn_card, hDn_range, hDn_one⟩ ⟨hDm_card, hDm_range, hDm_one⟩).trans
  have hb_range : 1 ≤ b ∧ b ≤ 2015 := by
