import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  have hf : Function.Injective f := by
    intro k l hkl
    by_contra h; push_neg at h
    rcases h.lt_or_lt with hlt | hlt
    · exact hii l k ⟨one_le_k, hlt⟩ hkl.symm
    · exact hii k l ⟨one_le_k, hlt⟩ hkl
  let S := Set.range f
  have h_bound : ∀ j, (j : ℤ) + 1 ≤ f j ∧ f j ≤ (j : ℤ) + 2015 := by
    intro j; constructor
    · exact add_le_add_left (hi j).1 j
    · exact add_le_add_left (hi j).2 j
  let B := {x : ℤ | x ≥ 2 ∧ x ∉ S}
  have B_fin : (B ∩ Set.Iic (n : ℤ)).Finite := Set.Finite.subset (Set.finite_Icc 2 n) (fun _ hx => ⟨hx.1.1, hx.2⟩)
  have skip_bound : ∀ n : ℕ, (Set.Icc 2 (n + 1) \ S).Finite := fun n =>
    Set.Finite.subset (Set.finite_Icc 2 (n + 1)) (fun _ hx => hx.1)
  have dens : ∃ b N, ∀ n ≥ N, ((Set.Iic n \ S) ∩ Set.Ici 1).ncard = b := sorry
  obtain ⟨b, N, hbN⟩ := dens
  use ⟨b, (by sorry)⟩, N
  intro m n hmn
  let sum_a (k : ℕ+) := ∑ j ∈ Finset.Icc 1 k, (a j - b)
  suffices ∀ k ≥ N, ∃ X : Finset ℤ, X.card = b ∧ (∀ x ∈ X, 1 ≤ x ∧ x ≤ 2015) ∧ sum_a k = (∑ x in X, x) - b * (b + 1) / 2 by
    sorry
  sorry
