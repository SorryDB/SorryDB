import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f (j : ℕ+) : ℤ := (j : ℤ) + a j
  have f_inj : ∀ j k, f j = f k → j = k := by
    intro j k h
    by_contra hjk
    cases hjk.lt_or_lt with
    | inl hjlt => exact hii k j ⟨by simp, hjlt⟩ h.symm
    | inr hklt => exact hii j k ⟨by simp, hklt⟩ h
  let Imf := Set.range f
  let S := {n : ℤ | 1 ≤ n} \ Imf
  have S_bdd : ∀ s ∈ S, s ≤ 2015 := by
    intro s ⟨hs1, hs2⟩
    by_contra hgt
    let s0 := s - 2015
    have hs0 : s0 ≥ 1 := by linarith
    let A := Finset.Icc (1 : ℤ) s0
    have hAf : ∀ x ∈ A, f ⟨x.toNat, by simp; linarith⟩ ≤ s := by
      intro x hx
      simp at hx
      have : a ⟨x.toNat, by simp; linarith⟩ ≤ 2015 := (hi _).2
      simp [f]; linarith
    have hA_range : ∀ x ∈ A, f ⟨x.toNat, by simp; linarith⟩ ∈ Finset.Icc (1 : ℤ) s := by
      intro x hx
      simp [hAf x hx]
      have : 1 ≤ a ⟨x.toNat, by simp; linarith⟩ := (hi _).1
      linarith
    let fA := A.attach.image (fun x => f ⟨x.1.toNat, by simp; linarith⟩)
    have fA_card : fA.card = A.card := by
      rw [Finset.card_image_of_injOn]
      intro x _ y _ hxy
      have h := f_inj _ _ hxy
      simp at h; linarith
    have fA_sub : fA ⊆ (Finset.Icc (1 : ℤ) s).erase s := by
      intro x hx
      simp at hx
      rcases hx with ⟨y, hy, rfl⟩
      simp [hA_range y hy]
      exact hs2 _
    have : fA.card ≤ (Finset.Icc (1 : ℤ) s).card - 1 := Finset.card_le_card_of_subset fA_sub
    simp [fA_card] at this; linarith
  let b_nat := (Finset.filter (fun x => x ∈ S) (Finset.Icc 1 2015)).card
  have b_pos : 1 ≤ b_nat := by
    have : 1 ∈ S := ⟨by linarith, fun j => by linarith [(hi j).1]⟩
    simp [b_nat]; exact ⟨by linarith, this⟩
  let b : ℕ+ := ⟨b_nat, b_pos⟩
  let N : ℕ+ := 2015
  refine ⟨b, N, fun m n hmn => ?_⟩
  let Δ (k : ℕ+) : ℤ := (∑ j ∈ Finset.Icc 1 k, f j) - (∑ i ∈ Finset.Icc 1 ((k : ℕ) + b), if i ∈ Imf then i else 0)
  have hΔ : ∀ k, (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) = Δ n - Δ m := by
    intro k
    simp [a, f, b, Finset.sum_sub_distrib, Finset.sum_Icc_eq_sub, ←Finset.add_sum]
    sorry -- Δ k logic here
  sorry
