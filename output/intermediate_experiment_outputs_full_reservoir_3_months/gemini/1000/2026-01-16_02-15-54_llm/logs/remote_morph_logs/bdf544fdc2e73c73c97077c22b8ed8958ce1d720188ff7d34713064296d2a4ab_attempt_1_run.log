import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let x : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  have x_inj : Function.Injective x := by
    intro j k h; by_contra hne; wlog hlt : j < k
    · exact hii k j ⟨by simp, not_lt.1 hlt |>.lt_of_ne hne.symm⟩ h.symm
    · exact hii k j ⟨by simp, hlt⟩ h.symm
  let S := Set.range x
  let B := {n : ℤ | 2 ≤ n ∧ n ∉ S}
  have B_subset : ∀ n ∈ B, n ≤ (2015 : ℤ) + (B ∩ Set.Iic 2016).fincard := sorry
  have B_fin : B.Finite := sorry
  let b_val : ℤ := B.toFinset.card + 1
  have b_pos : 0 < b_val := by simp [b_val]; linarith
  use ⟨b_val.toNat, by simp [b_pos]⟩
  let N_val := B.toFinset.fold 0 max + 1
  use ⟨N_val.toNat, by simp⟩
  intro m n hmn
  let f : ℕ+ → ℤ := fun k => ∑ i ∈ Finset.Icc 1 k, (a i - b_val)
  have h_bound : ∀ k, N_val.toNat ≤ k → ∃ R : Finset ℤ, R.card = (2014 - B.toFinset.card) ∧
      (∀ c ∈ R, 2 ≤ c ∧ c ≤ 2015) ∧ f k = (2015 * 2016 / 2 - 1 - ∑ b in B.toFinset, b) - ∑ c in R, c := sorry
  rcases h_bound m hmn.2 with ⟨Rm, hm_card, hm_sub, hm_val⟩
  rcases h_bound n (hmn.2.trans (PNat.le_of_lt hmn.1)) with ⟨Rn, hn_card, hn_sub, hn_val⟩
  rw [Finset.sum_sub_distrib, ← Finset.sum_Icc_add_sum_Icc_assoc (by simp; linarith) (by simp; exact hmn.1), add_comm, add_sub_cancel_right, hm_val, hn_val, abs_sub_comm, abs_sub_sub_cancel]
  let k := 2014 - B.toFinset.card
  have k_bound : k ≤ 2014 := by simp [k]
  have diff_bound : |∑ c in Rn, c - ∑ c in Rm, c| ≤ (k : ℤ) * (2014 - k) := sorry
  apply (diff_bound.trans _)
  have : (k : ℤ) * (2014 - k) ≤ 1007 ^ 2 := by
    have : ∀ x : ℤ, x * (2014 - x) ≤ 1007^2 := fun x => by
      have : 1007^2 - x * (2014 - x) = (x - 1007)^2 := by ring
      linarith [pow_two_nonneg (x - 1007)]
    exact this k
  exact this
