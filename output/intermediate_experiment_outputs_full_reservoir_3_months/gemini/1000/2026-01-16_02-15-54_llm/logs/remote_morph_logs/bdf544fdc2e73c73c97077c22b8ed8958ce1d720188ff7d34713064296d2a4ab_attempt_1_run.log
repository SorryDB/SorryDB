import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  have f_inj : Function.Injective f := by
    intro k l h; by_contra hkl; wlog hlt : k < l
    · exact (hii l k ⟨one_le_pnat k, (lt_or_gt_of_ne hkl).resolve_left hlt⟩) h.symm
    · exact (hii l k ⟨one_le_pnat k, hlt⟩) h.symm
  let S := {x : ℤ | 1 ≤ x ∧ ∀ j, f j ≠ x}
  have S_bdd : ∀ x ∈ S, x ≤ 2015 := by
    intro x hx; by_contra hx'; push_neg at hx'
    have : ∀ j, f j ≤ x → j < x := fun j h => by
      have : (j : ℤ) + 1 ≤ f j := add_le_add_left (hi j).1 j
      linarith
    have h_card : {j | f j ≤ x}.Finite := (Set.finite_Iic (x - 1)).subset (fun j h => by simpa using this j h)
    let c := (h_card.toFinset).card
    have h_c : c = x - S.encard := sorry
    sorry
  let b_val : ℕ := S.toFinset.card
  have b_pos : 0 < b_val := by
    have : 1 ∈ S := ⟨le_refl 1, fun j => by linarith [(hi j).1]⟩
    have : (1 : ℤ) ∈ S.toFinset := by simpa
    exact Finset.card_pos.mpr ⟨1, this⟩
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let g : ℕ+ → ℤ := fun n => ∑ j ∈ Finset.Icc 1 n, (a j - b)
  have g_bdd : ∃ C, ∀ n, abs (g n) ≤ C := sorry
  obtain ⟨N, hN⟩ : ∃ N, ∀ m n, N ≤ m → N ≤ n → abs (g n - g m) ≤ 1007 ^ 2 := sorry
  exact ⟨b, N, fun m n h => by rw [← Finset.sum_Icc_add_one_sub_sum_Icc (by linarith)]; exact hN m n (by linarith) (by linarith)⟩

