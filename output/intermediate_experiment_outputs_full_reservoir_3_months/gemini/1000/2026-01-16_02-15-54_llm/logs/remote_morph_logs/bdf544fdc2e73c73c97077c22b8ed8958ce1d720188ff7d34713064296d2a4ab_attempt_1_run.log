import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => (j : ℤ) + a j
  have f_inj : ∀ k l, f k = f l → k = l := fun k l h => by
    cases' lt_or_gt_of_ne (fun h_eq => (h_eq : k ≠ l)) with hlt hgt
    · exact (hii l k ⟨Nat.one_le k, hlt⟩ h.symm).elim
    · exact (hii k l ⟨Nat.one_le l, hgt⟩ h).elim
    · exact h_eq
  let S := {x : ℤ | x ≥ 1 ∧ ∀ j, f j ≠ x}
  have S_bound : ∀ x ∈ S, x ≤ 2015 := fun x ⟨x1, hf⟩ => by
    contrapose! hf
    let range_f_up_to_x := (Finset.univ.filter (fun j : PNat => (f j : ℤ) < x)).image f
    have : ∀ j, (j : ℤ) < x - 2015 → (f j : ℤ) < x := fun j hj => by
      have : a j ≤ 2015 := (hi j).2
      linarith
    use ⟨(x - 2015).toNat, by linarith⟩
    simp [f]
  have S_finite : S.Finite := Set.finite_ge_subset (S_bound) (Set.Iic 2015) (by simp)
  let s_finset := S_finite.toFinset
  have s1 : 1 ∈ s_finset := by simp [s_finset, S]; intro j; linarith [hi j]
  let b_val := s_finset.card
  have b_pos : b_val > 0 := Finset.card_pos.mpr ⟨1, s1⟩
  let b : ℕ+ := ⟨b_val, b_pos⟩
  let N : ℕ+ := ⟨(s_finset.max.getD 1).toNat + 1, by linarith⟩
  use b, N
  intro m n ⟨hmn, hNm⟩
  let sum_a (k : ℕ+) := ∑ j ∈ Finset.Icc 1 k, a j
  have h_sum (k : ℕ+) (hk : N ≤ k) :
    sum_a k - (k : ℤ) * b = (∑ j ∈ Finset.univ.filter (fun j => j ≤ k ∧ f j > k + b), (f j - (k + b))) +
    (∑ j ∈ Finset.univ.filter (fun j => j > k ∧ f j ≤ k + b), (k + b - f j)) -
    (∑ s in s_finset, s - ∑ i in Finset.Icc 1 b_val, i) := sorry
  let d (k : ℕ+) := (∑ j ∈ Finset.univ.filter (fun j => j ≤ k ∧ f j > k + b), (f j - (k + b))) +
    (∑ j ∈ Finset.univ.filter (fun j => j > k ∧ f j ≤ k + b), (k + b - f j))
  have d_bound (k : ℕ+) : 0 ≤ d k ∧ d k ≤ 1007 ^ 2 := sorry
  have : ∑ j ∈ Finset.Icc (m + 1) n, (a j - b) = (sum_a n - (n : ℤ) * b) - (sum_a m - (m : ℤ) * b) := by
    rw [Finset.sum_sub_distrib, ← Finset.sum_Icc_add_sum_Icc_assoc (by linarith) (by linarith), add_sub_cancel_left]
    simp [sum_a]; rfl
  rw [this, h_sum n (by linarith), h_sum m hNm]; simp [d]
  have := d_bound n; have := d_bound m; linarith [abs_le.mpr ⟨by linarith, by linarith⟩]
