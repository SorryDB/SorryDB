import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := λ n => n + a n
  have f_inj : Function.Injective f := by
    intro k l hkl
    rcases lt_trichotomy k l with h | h | h
    · exact (hii l k ⟨Nat.one_le k, h⟩ hkl.symm).elim
    · exact h
    · exact (hii k l ⟨Nat.one_le l, h⟩ hkl).elim
  let S : Set ℤ := Set.range f
  let Sc := {x : ℤ | 1 ≤ x} \ S
  have Sc_bound : ∀ x ∈ Sc, x ≤ 2015 := by
    intro x ⟨hx1, hxS⟩
    by_contra hx
    have : ∀ j : ℕ+, f j ≤ x - 1 → j ≤ x - 2 := λ j hf =>
      by simpa using (f j).le_trans (Int.le_sub_one_of_lt (Int.not_le.mp hx))
    let f' : {j : ℕ+ // f j ≤ x - 1} → {y : ℤ // 1 ≤ y ∧ y ≤ x - 1} :=
      λ j => ⟨f j, ⟨(Int.add_le_add (Int.one_le_pow 0 (by norm_num)) (hi j.1).1).trans_eq (by simp), j.2⟩⟩
    have f'_inj : Function.Injective f' := λ _ _ h => Subtype.ext (f_inj (Subtype.ext_iff.mp h))
    have h_card : Fintype.card {j : ℕ+ // f j ≤ x - 1} ≤ (x - 1 : ℤ).toNat := by
      simpa using Fintype.card_le_of_injective _ f'_inj
    have h_not_in : ∀ j : ℕ+, f j ≠ x := λ j hf => hxS ⟨j, hf⟩
    suffices Fintype.card {j : ℕ+ // f j ≤ x} = (x : ℤ).toNat - Sc.nndiff x by sorry
    sorry
  let b_nat := (Finset.filter (λ x => x ∉ (Finset.Icc 1 2015).filter (λ y => ∃ j, f j = y)) (Finset.Icc 1 2015)).card
  have b_pos : 0 < b_nat := by
    have : 1 ∉ S := λ ⟨j, hj⟩ => (hi j).1.not_lt (by simpa [f] using hj)
    simp [b_nat]; exact ⟨1, by simp [this]⟩
  let b : ℕ+ := ⟨b_nat, b_pos⟩
  let N : ℕ+ := 2015
  use b, N
  intro m n ⟨hmn, hmN⟩
  let B (k : ℕ+) := Finset.univ.filter (λ j : ℕ+ => j ≤ k ∧ k < f j)
  let X (k : ℕ+) := ∑ j in B k, (f j - k)
  have hX : ∀ k ≥ N, X (k + 1) - X k = a (k + 1) - b := by sorry
  have hsum : ∑ j in Finset.Icc (m + 1) n, (a j - b) = X n - X m := by
    rw [← Finset.sum_range_add_one_erase (λ k => X (k + 1) - X k) (by sorry)]
    sorry
  have hX_bound : ∀ k ≥ N, (b : ℤ) * (b + 1) / 2 ≤ X k ∧ X k ≤ (b : ℤ) * (b + 1) / 2 + (b - 1) * (2015 - b) := by sorry
  rw [hsum]
  have range_bound : (b - 1 : ℤ) * (2015 - b) ≤ 1007 ^ 2 := by
    let g (x : ℤ) := (x - 1) * (2015 - x)
    have : ∀ x, g x ≤ 1007 ^ 2 := by
      intro x; have := Int.le_of_sub_nonneg (show 0 ≤ 1007^2 - (x-1)*(2015-x) from by nlinarith)
      exact this
    apply this
  have h_abs : |X n - X m| ≤ (b - 1 : ℤ) * (2015 - b) := by
    rcases hX_bound n (hmN.trans hmn.le) with ⟨n1, n2⟩
    rcases hX_bound m hmN with ⟨m1, m2⟩
    exact abs_sub_le_iff.mpr ⟨by linarith, by linarith⟩
  exact h_abs.trans range_bound
