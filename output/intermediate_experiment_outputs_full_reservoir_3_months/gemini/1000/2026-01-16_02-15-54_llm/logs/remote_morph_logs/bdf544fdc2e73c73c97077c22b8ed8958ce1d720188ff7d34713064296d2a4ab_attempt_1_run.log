@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := fun j => j + a j
  have f_inj : Function.Injective f := fun k l e => by
    rcases lt_trichotomy k l with h | rfl | h
    · exact (hii l k ⟨by simp, h⟩ e.symm).elim
    · rfl
    · exact (hii k l ⟨by simp, h⟩ e).elim
  let S := Set.range f
  have hK : {n : ℕ+ | n ∉ S}.Finite := by
    apply Set.Finite.subset (Set.finite_Icc 1 2015)
    intro n hn; simp at *; constructor; exact n.2
    contrapose! hn; rcases hn with ⟨j, rfl⟩; have := hi j; omega
  let b : ℕ+ := ⟨hK.toFinset.card, by
    have h : (1 : ℕ+) ∉ S := fun ⟨j, hj⟩ => by have := hi j; have := j.2; omega
    have : (1 : ℕ+) ∈ hK.toFinset := by simp [h]
    exact Finset.card_pos.mpr ⟨1, this⟩⟩
  use b, 2015; intro m n hmn
  let g (k : ℕ) : ℤ := (Finset.Icc 1 k).filter (fun j => f ⟨j, by omega⟩ > k) |>.sum (fun j => f ⟨j, by omega⟩ - k)
  have hg (k : ℕ) (hk : k ≥ 2015) : g (k + 1) - g k = a ⟨k + 1, by omega⟩ - b := by sorry
  have : ∑ j in Finset.Icc (m + 1) n, (a j - b) = g n - g m := by
    have : ∀ i, m ≤ i ∧ i < n → a i.succ - b = g i.succ - g i := fun i hi => hg i (by omega)
    sorry
  rw [this]; sorry
