  · refine ContinuousOn.add (continuousOn_inv₀.mono h_ne0) ?_
    exact (continuous_pow 2).continuousOn.inv₀ fun x hx h ↦ h_ne0 x hx (pow_eq_zero h)
  · field_simp [ha.ne', hb.ne']; ring
```
