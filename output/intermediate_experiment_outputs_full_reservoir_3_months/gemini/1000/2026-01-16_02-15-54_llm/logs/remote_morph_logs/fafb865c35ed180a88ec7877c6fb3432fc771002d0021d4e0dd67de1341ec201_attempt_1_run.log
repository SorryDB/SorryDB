variable {n : ℕ}


theorem permanent_conjecture (M : Matrix (Fin n) (Fin n) ℝ) :
    M ∈ doublyStochastic ℝ (Fin n) → permanent M ≥ (n.factorial)/(n ^ n) := by
  intro hM
  have hM₀ : 0 ≤ M := (mem_doublyStochastic_iff.mp hM).1
  have hR : ∀ i, ∑ j, M i j = 1 := (mem_doublyStochastic_iff.mp hM).2.1
  have hC : ∀ j, ∑ i, M i j = 1 := (mem_doublyStochastic_iff.mp hM).2.2
  exact permanent_ge_factorial_div_pow n M hM₀ hR hC
