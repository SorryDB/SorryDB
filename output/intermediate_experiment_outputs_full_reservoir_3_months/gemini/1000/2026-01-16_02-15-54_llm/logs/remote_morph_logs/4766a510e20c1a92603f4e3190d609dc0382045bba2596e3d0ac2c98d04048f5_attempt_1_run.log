namespace ValuativeRel

section proofWanted

-- I only need it for IsNonarchimedeanLocalField but it should be true in this generality
lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r :=
  ⟨λ h ↦ (ValuationRing.isUnit_iff_valuation_eq_one (valuation K) ⟨x, mem_ringOfIntegers_iff.mpr h.le⟩).mpr h,
