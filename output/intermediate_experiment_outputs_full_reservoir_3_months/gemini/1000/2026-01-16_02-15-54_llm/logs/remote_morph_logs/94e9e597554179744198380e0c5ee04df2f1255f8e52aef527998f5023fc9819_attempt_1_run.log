lemma matchingMatroid.noColoop (h : ∀ x, G.inessential x) (hx : x ∈ V(G)) :
    ¬ G.matchingMatroid.IsColoop x := by
  rw [Matroid.isColoop_iff_mem_all_bases]
  push_neg
  obtain ⟨M, hM, hxM⟩ := h x
  obtain ⟨B, hB, hMB⟩ := G.matchingMatroid.exists_isBasis_superset ⟨M, hM.toIsMatching, subset_refl _⟩
  refine ⟨B, hB, fun hxB ↦ ?_⟩
  obtain ⟨M', hM', hBM'⟩ := hB.indep
  have h_lt : M.encard < M'.encard := by
    sorry
  exact (hM.max M' hM').not_lt h_lt
```
