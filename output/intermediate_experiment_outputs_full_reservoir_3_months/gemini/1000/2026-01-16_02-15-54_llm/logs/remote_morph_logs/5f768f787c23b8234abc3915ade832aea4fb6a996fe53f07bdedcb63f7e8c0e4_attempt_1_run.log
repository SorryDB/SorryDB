    Field51_as_Nat r ≡ (Field51_as_Nat lhs) * (Field51_as_Nat rhs) [MOD p] ∧
    (∀ i < 5, r[i]!.val < 2 ^ 52) := by
  rw [mul]
  progress
  all_goals { simp [Field51_as_Nat, p, *] }
