/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  have : ∀ (p : Fin n ≃ S) (cond : Condition k S p), ∀ i, ∃ x > 0, (p i : ℕ) * p (i + 1) = x^2 + x + k := fun p cond i => cond i
  let D : ℤ := 4 * k - 1
  let edges : Finset (Finset S) := (S.powersetLen 2).filter (fun e => ∃ u v : S, u ∈ e ∧ v ∈ e ∧ u ≠ v ∧ ∃ x : ℕ, x > 0 ∧ (u : ℕ) * v = x^2 + x + k)
  have h_edge : ∀ (p : Fin n ≃ S) (cond : Condition k S p), ∀ i, {p i, p (i + 1)} ∈ edges := by
    intro p cond i
    have : NeZero n := ⟨i.pos.ne'⟩
    rcases cond i with ⟨x, hx_pos, hx_eq⟩
    simp [edges, hx_pos]
    refine ⟨p i, p (i + 1), by simp, by simp, ?_, x, hx_pos, hx_eq⟩
    intro h; apply_fun (fun (x : S) => (x : ℕ)) at h; rw [h] at hx_eq
    have : (p (i+1) : ℤ)^2 - (p (i+1) : ℤ) - k = x^2 + x := by linarith
    linarith [hS (p (i+1)) (p (i+1)).2]
  have h_degree : ∀ p ∈ S, {e ∈ edges | p ∈ e}.card ≤ 2 := by
    intro p hp
    let f : {e ∈ edges | p ∈ e} → {u ∈ S | u < p ∨ (4*p*u - D).isSquare} := sorry
    sorry
  have h_edges_eq : (Finset.univ : Finset (Fin #S)).image (fun i => {p₁ i, p₁ (i + 1)}) = (Finset.univ : Finset (Fin #S)).image (fun i => {p₂ i, p₂ (i + 1)}) := sorry
  exact (Equiv.congr_arg h_edges_eq).sorry
