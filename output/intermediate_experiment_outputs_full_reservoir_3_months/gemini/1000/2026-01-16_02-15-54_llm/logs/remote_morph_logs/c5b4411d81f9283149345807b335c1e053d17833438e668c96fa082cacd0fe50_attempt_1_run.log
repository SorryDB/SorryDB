    intro i h0; exact ⟨p₂ i, p₂ (i + 1), (p₂ i).2, (p₂ (i + 1)).2, rfl, hp₂ i⟩
  let G := (S, {e | ∃ p q, p ∈ S ∧ q ∈ S ∧ p < q ∧ {p, q} ∈ E})
  have deg_le_two : ∀ p ∈ S, (S.filter (λ q => {p, q} ∈ E ∧ p ≠ q)).card ≤ 2 := by
    intro p hp
