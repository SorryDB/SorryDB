import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  have h_unique_edges : ∀ (p : Fin #S ≃ S), Condition k S p →
    ∀ i, { (p i : ℕ), (p (i + 1) : ℕ) } ∈ (Finset.univ.image (fun i => {(p i : ℕ), (p (i + 1) : ℕ)})) := fun p _ i => Finset.mem_image_of_mem _ (Finset.mem_univ _)
  let edges (p : Fin #S ≃ S) (hp : Condition k S p) := Finset.univ.image (fun i : Fin #S => ({ (p i : ℕ), (p (i + 1) : ℕ) } : Finset ℕ))
  have h_eq_edges : edges p₁ hp₁ = edges p₂ hp₂ := by
    apply Finset.ext; intro e; constructor <;> intro he
    all_goals
      obtain ⟨x, y, hxy, heq⟩ := by
        obtain ⟨i, hi⟩ := Finset.mem_image.1 he
        use (p₁ i : ℕ), (p₁ (i + 1) : ℕ)
        if h : p₁ = p₁ then use rfl, hi else (by contradiction)
      obtain ⟨i, hi⟩ := Finset.mem_image.1 he
    clear h_unique_edges
    let D := 4 * k - 1
    have h_sq (u v : ℕ) (hu : u ∈ S) (hv : v ∈ S) : {u, v} ∈ edges p₁ hp₁ ∨ {u, v} ∈ edges p₂ hp₂ → ∃ y : ℕ, y > 1 ∧ y % 2 = 1 ∧ 4 * u * v - D = y ^ 2 := by
      intro h; obtain ⟨i, hi⟩ := (if h' : {u, v} ∈ edges p₁ hp₁ then Finset.mem_image.1 h' else Finset.mem_image.1 (h.resolve_left h'))
      let p := if h' : {u, v} ∈ edges p₁ hp₁ then p₁ else p₂
      have hp_cond := if h' : {u, v} ∈ edges p₁ hp₁ then hp₁ else hp₂
      obtain ⟨x, hx_pos, hx_eq⟩ := hp_cond i
      use 2 * x + 1; refine ⟨by omega, by omega, ?_⟩
      rw [hx_eq]; ring
    have h_peak (p : ℕ) (hp : p ∈ S) (u v : ℕ) (hu : u ∈ S) (hv : v ∈ S) (hu_lt : u < p) (hv_lt : v < p)
      (hue : ∃ y, y > 1 ∧ 4 * p * u - D = y^2) (hve : ∃ y, y > 1 ∧ 4 * p * v - D = y^2) :
      u ≠ v → p^2 + u^2 + v^2 - 2*(p*u + u*v + v*p) = 1 - 4*k := by
      intro hne; obtain ⟨yu, hyu1, hyu2⟩ := hue; obtain ⟨yv, hyv1, hyv2⟩ := hve
      have hyu_lt : yu < 2 * p := by
        nlinarith [Nat.Prime.pos (hS p hp).2]
      have hyv_lt : yv < 2 * p := by
        nlinarith [Nat.Prime.pos (hS p hp).2]
      have h_mod : yu^2 % p = (D : ℤ).natAbs % p ∧ yv^2 % p = (D : ℤ).natAbs % p := sorry
      have : yu + yv = 2 * p := sorry
      nlinarith
    sorry
  exact sorry
