import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  set m := 4 * k - 1
  have hm : 0 < m := by linarith
  let R : ℕ → ℕ → Prop := λ a b => ∃ x > 0, 4 * a * b - m = x ^ 2
  have hR_sym : Symmetric R := λ a b ⟨x, hx, h⟩ => ⟨x, hx, by rw [← h, mul_right_comm]⟩
  have hpR₁ : ∀ i, R (p₁ i) (p₁ (i + 1)) := by
    intro i
    obtain ⟨x, hx, h⟩ := hp₁ i
    use 2 * x + 1
    refine ⟨by linarith, ?_⟩
    rw [← Nat.mul_assoc, h, pow_two]
    ring
  have hpR₂ : ∀ i, R (p₂ i) (p₂ (i + 1)) := by
    intro i
    obtain ⟨x, hx, h⟩ := hp₂ i
    use 2 * x + 1
    refine ⟨by linarith, ?_⟩
    rw [← Nat.mul_assoc, h, pow_two]
    ring
  have h_unique : ∀ a ∈ S, ∀ b c ∈ S, b < a → c < a → R a b → R a c → b = c := by
    intro a ha b hb c hc hbc Rab Rac
    obtain ⟨x, hx, hx2⟩ := Rab
    obtain ⟨y, hy, hy2⟩ := Rac
    have : x^2 ≡ -m [MOD 4 * a] := by rw [← hx2]; ring_nf; use b; ring
    have : y^2 ≡ -m [MOD 4 * a] := by rw [← hy2]; ring_nf; use c; ring
    have h_cong : x^2 ≡ y^2 [MOD 4 * a] := by trans (-m : ℤ) <;> assumption
    have h_odd : x % 2 = 1 ∧ y % 2 = 1 := by
      constructor <;> apply Nat.Odd.pows_pos (n := 2)
      all_goals (rw [← Nat.odd_iff, ← Nat.mod_two_ne_zero]; intro h; rw [h] at hx2 hy2)
      all_goals (have : m % 4 = 3 := by rw [show m = 4*k-1 from rfl]; cases k <;> nlinarith)
      all_goals (linarith [hx2, hy2, hx, hy])
    have : 2 * a ∣ x - y ∨ 2 * a ∣ x + y := by
      have : 4 * a ∣ (x - y) * (x + y) := by
        obtain ⟨k, hk⟩ := h_cong
        rw [sq_sub_sq] at hk; exact ⟨k, hk⟩
      have h1 : 2 ∣ (x - y) ∧ 2 ∣ (x + y) := ⟨by linarith, by linarith⟩
      have h2 : ¬ (4 ∣ x - y ∧ 4 ∣ x + y) := by
        intro ⟨⟨k1, hk1⟩, ⟨k2, hk2⟩⟩
        have : 2 * x = (x - y) + (x + y) := by ring
        rw [hk1, hk2] at this
        have : x = 2 * (k1 + k2) := by linarith
        exact (Nat.even_iff.mpr this).not_odd h_odd.1
      cases' Int.modeq_iff_dvd.mp (Int.modeq_of_dvd (by linarith) (Int.dvd_mul_right (4*a) ((x+y)))) with d hd
      apply Or.imp id id
      all_goals (intro h; apply Int.dvd_of_mul_dvd_mul_left (a := 2) (by linarith); rw [← Nat.cast_mul])
      all_goals (rw [Int.abs_eq_natAbs] at h; linarith)
      sorry
  sorry

