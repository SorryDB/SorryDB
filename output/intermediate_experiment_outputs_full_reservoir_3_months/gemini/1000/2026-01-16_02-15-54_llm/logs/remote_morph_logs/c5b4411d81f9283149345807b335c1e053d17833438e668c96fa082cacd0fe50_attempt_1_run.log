import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  have h_smaller : ∀ a ∈ S, {b ∈ S | b < a ∧ ∃ x > 0, a * b = x^2 + x + k}.card ≤ 2 := by
    intro a ha
    let D := 4 * k - 1
    let f b := ∃ x > 0, a * b = x^2 + x + k
    have hf : ∀ b, f b ↔ ∃ y, y^2 = 4 * a * b - D ∧ y > 1 ∧ y % 2 = 1 := by
      intro b; constructor
      · rintro ⟨x, hx, hxb⟩
        use 2 * x + 1; refine ⟨?_, by omega, by omega⟩
        rw [hxb]; ring
      · rintro ⟨y, hy, hy1, hyo⟩
        use (y - 1) / 2
        have hy_sq : y^2 = 4*a*b - D := hy
        have : (y - 1) % 2 = 0 := by omega
        constructor; · omega
        rw [Nat.div_pow_of_dvd (by omega : 2 ∣ y - 1), ← Nat.div_eq_of_eq_mul_left (by omega : 0 < 4)]
        ring_nf; rw [hy_sq]; ring
    have h_bound : ∀ b ∈ S, b < a → f b → ∃ y < 2 * a, y^2 ≡ 1 - 4 * k [MOD 4 * a] ∧ 4 * a * b = y^2 + D := by
      intro b _ hba hfb
      rcases (hf b).mp hfb with ⟨y, hy, hy1, hyo⟩
      use y; refine ⟨?_, ?_, by omega⟩
      · have : 4 * a * b < 4 * a * a := by rel [hba]
        omega
      · rw [hy]; ring_nf; refine Nat.ModEq.add_right D ?_
        rw [show 4*a*b = (4*a)*b by ring]; exact Nat.modEq_zero.mpr (dvd_mul_right (4 * a) b)
    let Sol := {y | y < 2 * a ∧ y % 2 = 1 ∧ y^2 ≡ 1 - 4 * k [MOD a]}
    have h_sol_card : Sol.ncard ≤ 2 := by
      have : (Nat.Prime (hS a ha).2) := (hS a ha).2
      apply Nat.card_modEq_sq_mpr (1 - 4 * k) this.prime
    have h_inj : ∀ b1 b2 ∈ S, b1 < a → b2 < a → f b1 → f b2 → (4*a*b1 - D = 4*a*b2 - D → b1 = b2) := by
      intro b1 b2 _ _ _ _ h; simpa using h
    exact Nat.le_trans (Finset.card_le_card_of_inj_on (λ b => (hf b).mp ‹_›).choose (by sorry) (by sorry)) h_sol_card
  sorry
