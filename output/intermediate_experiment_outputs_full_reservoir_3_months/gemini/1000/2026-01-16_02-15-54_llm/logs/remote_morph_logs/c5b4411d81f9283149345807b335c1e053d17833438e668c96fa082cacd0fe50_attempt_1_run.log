import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  set n := S.card
  cases n with
  | zero =>
    left; use 0; intro j; exact Fin.elim0 j
  | succ n =>
    let E : S → S → Prop := fun a b => ∃ x : ℕ, 0 < x ∧ (a : ℕ) * b = x^2 + x + k
    have hE1 : ∀ i : Fin (n + 1), E (p₁ i) (p₁ (i + 1)) := hp₁
    have hE2 : ∀ i : Fin (n + 1), E (p₂ i) (p₂ (i + 1)) := hp₂
    have h_symm : ∀ {a b}, E a b → E b a := fun ⟨x, hx, h⟩ => ⟨x, hx, by rw [Nat.mul_comm, h]⟩
    have h_unique : ∀ s : S, { b | E s b } = { p₁ (p₁.symm s - 1), p₁ (p₁.symm s + 1) } := by
      intro s
      apply Set.Subset.antisymm
      · intro b hb
        rcases hb with ⟨x, hx, hxb⟩
        let r := x % s
        have hr : (r^2 + r + k) % s = 0 := by
          apply Nat.mod_eq_zero_of_dvd
          use (x / s) * (x + 1) + (x % s) * (x / s) + k / s -- Simplified version
          rw [hxb] at *; exact (hS s s.2).2.dvd_iff_mod_eq_zero.mp (Dvd.intro b hxb.symm)
        let r_other := (s - 1 - r) % s
        have : b = p₁ (p₁.symm s - 1) ∨ b = p₁ (p₁.symm s + 1) := sorry
        exact this
      · intro b hb; simp at hb; rcases hb with h | h <;> rw [h]
        · apply h_symm; convert hE1 (p₁.symm s - 1); simp
        · convert hE1 (p₁.symm s); simp
    have h_neighbors : ∀ i : Fin (n + 1), {p₂ (i-1), p₂ (i+1)} = {p₁ (p₁.symm (p₂ i) - 1), p₁ (p₁.symm (p₂ i) + 1)} := by
      intro i; rw [← h_unique (p₂ i)]; apply Set.Subset.antisymm
      · intro b hb; simp at hb; rcases hb with rfl | rfl
        · exact h_symm (hE2 (i-1))
        · exact hE2 i
      · intro b hb; rw [Set.mem_setOf_eq] at hb
        have hdeg : (Finset.univ.filter (E (p₂ i))).card = 2 := sorry
        sorry
    sorry

