    · cases' h_le2.eq_or_lt with h2 h1
      · left; use (if p₂ 0 = p₁ 0 then 0 else 1)
        intro j; fin_cases j
        · split_ifs with h
          · simp [h]
          · have h_ne : p₂ 0 ≠ p₁ 0 := h
            have : p₂ 0 = p₁ 1 := by
              have h_s : S = {p₁ 0, p₁ 1} := by
                rw [← S.image_univ, ← Finset.univ_map_equiv p₁]
                decide
              have h_p2 : p₂ 0 ∈ S := p₂.symm.cond 0
              simp [h_s] at h_p2; cases' h_p2 with hx hx
              · contradiction
              · exact hx
            simp [this]
        · have h_s : S = {p₁ 0, p₁ 1} := by rw [← S.image_univ, ← Finset.univ_map_equiv p₁]; decide
          have h_p2 : p₂ 1 ∈ S := p₂.symm.cond 1
          have h_p20 : p₂ 0 ∈ S := p₂.symm.cond 0
          have h_p2ne : p₂ 1 ≠ p₂ 0 := p₂.injective.ne (by decide)
          split_ifs with h
          · have : p₂ 1 = p₁ 1 := by
              simp [h_s, h] at h_p2 h_p2ne; cases' h_p2 with hx hx <;> [contradiction; exact hx]
            simp [this]
          · have : p₂ 1 = p₁ 0 := by
              simp [h_s] at h_p20 h_p2ne; cases' h_p20 with hx hx <;> simp [hx] at h_p2ne
              · simp [h_s, h_p2ne] at h_p2; cases' h_p2 with hy hy <;> [exact hy; contradiction]
              · contradiction
            simp [this]
      · left; use 0; intro j; fin_cases j
        have h_s : S = {p₁ 0} := by rw [← S.image_univ, ← Finset.univ_map_equiv p₁]; decide
        have h_p2 : p₂ 0 ∈ S := p₂.symm.cond 0
        simp [h_s] at h_p2; simp [h_p2]
  · let adj (p q : ℕ) : Prop := ∃ x : ℕ, 0 < x ∧ p * q = x ^ 2 + x + k
    have h_adj_symm : ∀ p q, adj p q ↔ adj q p := by
      intro p q; constructor <;> intro h <;> obtain ⟨x, hx1, hx2⟩ := h <;> use x <;> rw [Nat.mul_comm] at * <;> exact ⟨hx1, hx2⟩
    let E : Finset (Finset ℕ) := S.powerset.filter (fun e => e.card = 2 ∧ ∀ p ∈ e, p ∈ S ∧ ∃ q ∈ e, q ≠ p ∧ adj p q)
    have hp1_E : ∀ i, {p₁ i, p₁ (i + 1)} ∈ E := by
      intro i; simp [E, adj]; constructor
      · rw [Finset.card_doubleton]; exact p₁.injective.ne (by simp)
      · intro q hq; simp [hq]; constructor
