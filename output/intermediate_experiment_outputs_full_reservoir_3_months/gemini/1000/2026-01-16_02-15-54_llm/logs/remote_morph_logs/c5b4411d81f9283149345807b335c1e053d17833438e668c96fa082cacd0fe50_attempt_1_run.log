# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  cases n with
  | zero =>
    left; use 0; intro j; exact Fin.elim0 j
  | succ n =>
    cases n with
    | zero =>
      left; use 0; intro j; simp; have : j = 0 := by ext; exact Nat.le_zero_eq.mp (Nat.succ_le_succ_iff.mp j.2)
      rw [this]
    | succ n =>
      set d := 4 * k - 1
      have hd : 0 < d := Nat.sub_pos_of_lt (by linarith [hk])
      let x_val (i : Fin #S) (p : Fin #S ≃ S) := (Nat.sqrt (4 * (p i : ℕ) * (p (i + 1) : ℕ) - d) - 1) / 2
      let y_val (i : Fin #S) (p : Fin #S ≃ S) := 2 * x_val i p + 1
      have hy (p : Fin #S ≃ S) (hp : Condition k S p) (i : Fin #S) :
        (y_val i p)^2 = 4 * (p i : ℕ) * (p (i + 1) : ℕ) - d := by
        obtain ⟨x, hx_pos, hx_eq⟩ := hp i
        have h_y : y_val i p = 2 * x + 1 := by
          dsimp [y_val, x_val]
          rw [hx_eq, ← (Nat.pow_two x), ← (Nat.mul_assoc 4 (x^2 + x + k))]
          rw [Nat.mul_add, Nat.mul_add, ← (Nat.pow_two (2 * x)), ← (Nat.mul_assoc 4 x)]
          rw [← (Nat.mul_add 4 x (x^2)), ← (Nat.pow_two x)]
          have : 4 * x^2 + 4 * x + 4 * k - (4 * k - 1) = (2 * x + 1)^2 := by
            simp [Nat.pow_two]; ring_nf; rw [Nat.add_sub_assoc (by linarith)]; norm_num
          rw [this, Nat.sqrt_pos_pow_two (2 * x + 1)]; simp
        rw [h_y, hx_eq]; ring_nf; rw [Nat.add_sub_assoc (by linarith)]; norm_num
      have h_rel (p : Fin #S ≃ S) (hp : Condition k S p) (i : Fin #S) :
        (y_val (i - 1) p + y_val i p = 2 * (p i : ℕ)) ∨ (Int.abs (y_val (i - 1) p - y_val i p) = 2 * (p i : ℕ)) := by
        have h1 : (y_val (i - 1) p)^2 ≡ - (d : ℤ) [ZMOD 4 * (p i : ℕ)] := by
          rw [hy p hp (i-1), Fin.sub_one_add_one]; exact Int.modEq_sub (4 * (p (i-1)) * (p i) : ℤ) d
        have h2 : (y_val i p)^2 ≡ - (d : ℤ) [ZMOD 4 * (p i : ℕ)] := by
          rw [hy p hp i]; exact Int.modEq_sub (4 * (p i) * (p (i+1)) : ℤ) d
        have h12 : (y_val (i - 1) p : ℤ)^2 ≡ (y_val i p : ℤ)^2 [ZMOD 4 * (p i : ℕ)] := h1.trans h2.symm
        have h_odd (j : Fin #S) : (y_val j p) % 2 = 1 := by dsimp [y_val]; simp
        have h_sum : 2 * (p i : ℕ) ∣ (y_val (i-1) p + y_val i p) ∨ 2 * (p i : ℕ) ∣ (y_val (i-1) p - y_val i p) := by
          obtain ⟨h_sum, h_diff⟩ := Int.two_mul_dvd_add_or_sub_of_sq_modEq_sq (y_val (i-1) p) (y_val i p) (by linarith [hS (p i) (p i).2]) h12
          simp at h_sum h_diff; left; assumption; right; assumption
        have h_lt (j : Fin #S) : y_val j p < 2 * (p j : ℕ) + 2 * (p (j + 1) : ℕ) := by
          rw [← Nat.pow_two_lt_pow_two_iff (by norm_num), hy p hp j]
          have : 4 * (p j) * (p (j + 1)) - d < 4 * (p j) * (p (j + 1)) := Nat.sub_lt_self (by linarith) hd
          apply lt_of_lt_of_le this; ring_nf; nlinarith
        sorry
      sorry
