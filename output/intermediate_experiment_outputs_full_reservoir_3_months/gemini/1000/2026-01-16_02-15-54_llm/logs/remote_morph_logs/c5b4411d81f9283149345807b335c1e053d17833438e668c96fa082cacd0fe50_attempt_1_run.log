import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := S.card
  if hn : n < 3 then
    rcases n with rfl | ⟨n1, rfl⟩ | ⟨n2, rfl⟩
    · exact (by simp at hS_pos)
    · left; use 0; intro j; simp
    · have h_range : ∀ j : Fin 2, j = 0 ∨ j = 1 := by intro j; fin_cases j <;> auto
      left; use (if p₂ 0 = p₁ 0 then 0 else 1)
      intro j; rcases h_range j with rfl | rfl <;> rcases h_range (p₂.symm (p₁ 0)) with rfl | rfl
      <;> simp <;> try { rcases h_range (p₂.symm (p₁ 1)) with rfl | rfl } <;> simp_all
  else
    replace hn : 3 ≤ n := Nat.le_of_not_lt hn
    let G : Finset (Finset ℕ) := (S.powerset.filter (fun s => s.card = 2)).filter fun s =>
      ∃ p ∈ s, ∃ q ∈ s, p ≠ q ∧ ∃ x > 0, p * q = x^2 + x + k
    let E (p : Fin n ≃ S) : Finset (Finset ℕ) :=
      Finset.univ.image (fun i : Fin n => {p i, p (i + 1)})
    have hE1 : E p₁ ⊆ G := by
      intro e; simp [E, G]; rintro i rfl
      have : NeZero n := ⟨by linarith⟩
      rcases hp₁ i with ⟨x, hx, hxp⟩
      refine ⟨by simp [Finset.card_doubleton, p₁.injective.ne (Fin.ne_of_vne (by simp; intro h; simp [h] at hn))],
              p₁ i, p₁ i.succ, i, i.succ, by simp [hxp, hx]⟩
    have hE2 : E p₂ ⊆ G := by
      intro e; simp [E, G]; rintro i rfl
      have : NeZero n := ⟨by linarith⟩
      rcases hp₂ i with ⟨x, hx, hxp⟩
      refine ⟨by simp [Finset.card_doubleton, p₂.injective.ne (Fin.ne_of_vne (by simp; intro h; simp [h] at hn))],
              p₂ i, p₂ i.succ, i, i.succ, by simp [hxp, hx]⟩
    have hG_deg : ∀ p ∈ S, (G.filter (fun e => p ∈ e)).card ≤ 2 := sorry
    have hE1_card : (E p₁).card = n := by
      rw [Finset.card_image_of_injective]; simp; intro i j hij;
      rw [Finset.subset_antisymm_iff] at hij; sorry
    have hE2_card : (E p₂).card = n := sorry
    have hE1G : E p₁ = G := by
      refine Finset.eq_of_subset_of_card_le hE1 ?_
      rw [hE1_card]; have := Finset.card_le_of_subset (fun p hp => hG_deg p hp); sorry
    have hE2G : E p₂ = G := by
      refine Finset.eq_of_subset_of_card_le hE2 ?_
      rw [hE2_card]; sorry
    rw [← hE2G] at hE1G; exact sorry

