import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  have n_pos : 0 < #S := by
    cases' Finset.eq_empty_or_nonempty S with hS0 hSn
    · simp [hS0] at p₁
    · simp [Finset.Nonempty.card_pos hSn]
  let n := #S
  haveI : NeZero n := ⟨n_pos.ne'⟩
  let G : ℕ → ℕ → Prop := λ u v => ∃ x : ℕ, 0 < x ∧ u * v = x^2 + x + k
  have g_sym : ∀ u v, G u v ↔ G v u := by
    intro u v; constructor <;> rintro ⟨x, hx, h⟩ <;> use x, hx <;> rwa [Nat.mul_comm]
  have h_p1 : ∀ i : Fin n, G (p₁ i) (p₁ (i + 1)) := hp₁
  have h_p2 : ∀ i : Fin n, G (p₂ i) (p₂ (i + 1)) := hp₂
  have local_max : ∀ p q r, G p q → G p r → q < p → r < p → q ≠ r → G q r := by
    intro p q r Gpq Gpr hqp hrp hqr
    rcases Gpq with ⟨x, hx, hx2⟩
    rcases Gpr with ⟨y, hy, hy2⟩
    have p_prime : Nat.Prime p := (hS p (p₁.symm.equiv.1.mem_range (p₁.symm p))).2
    have : 4 * (p * q) = (2 * x + 1)^2 + 4 * k - 1 := by linear_combination 4 * hx2
    have : 4 * (p * r) = (2 * y + 1)^2 + 4 * k - 1 := by linear_combination 4 * hy2
    have : 4 * p * (q - r) = (2 * x + 1)^2 - (2 * y + 1)^2 := by
      zify [hqp.le, hrp.le]; linear_combination (4 * p * q - (2 * x + 1)^2 - 4 * k + 1) - (4 * p * r - (2 * y + 1)^2 - 4 * k + 1)
    have : 4 * p * (q - r) = (2 * x + 2 * y + 2) * (2 * x - 2 * y) := by linear_combination (2 * x + 1)^2 - (2 * y + 1)^2
    have p_div : p ∣ (x + y + 1) * (x - y) := by
      have : p ∣ 4 * p * (q - r) := Nat.dvd_mul_right p _
      rw [this] at this; simp at this; contradiction -- Simplified for logic
    admit
  admit
