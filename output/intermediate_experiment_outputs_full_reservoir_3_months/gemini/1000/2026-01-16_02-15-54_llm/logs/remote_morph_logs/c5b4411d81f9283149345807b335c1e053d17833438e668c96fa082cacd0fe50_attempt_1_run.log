import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  cases n with
  | zero => left; use 0; intro j; exact j.elim0
  | succ n =>
    cases n with
    | zero => left; use 0; intro j; congr
    | succ n =>
      have : n.succ.succ = #S := rfl
      let rel (a b : ↥S) : Prop := ∃ x > 0, (a : ℕ) * b = x^2 + x + k
      have rel_symm {a b : ↥S} : rel a b → rel b a := λ ⟨x, hx, h⟩ => ⟨x, hx, by rw [mul_comm, h]⟩
      let G_edges (p : Fin #S ≃ S) : Finset (Sym2 ↥S) := univ.map ⟨λ i => s(p i, p (i + 1)), λ i j h => by
        simp at h; sorry⟩
      have hp1_edges : ∀ i, rel (p₁ i) (p₁ (i + 1)) := hp₁
      have hp2_edges : ∀ i, rel (p₂ i) (p₂ (i + 1)) := hp₂
      have h_unique_edges : G_edges p₁ = G_edges p₂ := by
        apply symm;
        let p_rel (q : ↥S) := {a ∈ S | rel q a}
        have h_max_neighbors : ∀ (p_arr : Fin #S ≃ S), Condition k S p_arr →
          ∀ q, {p_arr (p_arr.symm q - 1), p_arr (p_arr.symm q + 1)} ⊆ p_rel q := sorry
        have h_rel_le (q : ↥S) : {a ∈ p_rel q | (a : ℕ) < q}.card ≤ 2 := sorry
        sorry
      exact sorry
