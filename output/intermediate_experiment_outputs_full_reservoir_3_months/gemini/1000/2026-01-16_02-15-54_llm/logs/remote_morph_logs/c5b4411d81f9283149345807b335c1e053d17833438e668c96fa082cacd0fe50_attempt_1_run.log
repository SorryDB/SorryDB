import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := S.card
  if h : n < 3 then
    cases n with
    | zero =>
      left; refine ⟨0, fun j => ?_⟩; exact j.elim0
    | succ n =>
      cases n with
      | zero =>
        left; refine ⟨0, fun j => ?_⟩; have h0 : j = 0 := by ext; omega
        rw [h0, zero_add]; rfl
      | succ n =>
        cases n with
        | zero =>
          have : ∀ j : Fin 2, p₂ j = p₁ (j + if p₂ 0 = p₁ 0 then 0 else 1) := by
            intro j; fin_cases j <;> fin_cases 0 <;>
            simp [Fin.ext_iff] at * <;>
            by_cases h : p₂ 0 = p₁ 0 <;> simp [h]
            · have : p₂ 1 = p₁ 1 := by
                have : {p₂ 0, p₂ 1} = {p₁ 0, p₁ 1} := by
                  rw [Equiv.coe_to_embedding, ← Finset.coe_inj, Finset.coe_pair, Finset.coe_pair,
                    ← Set.range_coe_iff_coe_range, ← Set.range_coe_iff_coe_range,
                    Equiv.range_eq_enum, Equiv.range_eq_enum]
                simp [h] at this; exact (Finset.singleton_inj.1 this).symm
              exact this
            · have : p₂ 1 = p₁ 0 := by
                have : {p₂ 0, p₂ 1} = {p₁ 0, p₁ 1} := by
                  rw [Equiv.coe_to_embedding, ← Finset.coe_inj, Finset.coe_pair, Finset.coe_pair,
                    ← Set.range_coe_iff_coe_range, ← Set.range_coe_iff_coe_range,
                    Equiv.range_eq_enum, Equiv.range_eq_enum]
                simp [h] at this
                have h_p2_0 : p₂ 0 = p₁ 1 := by
                  have h_subset : p₂ 0 ∈ {p₁ 0, p₁ 1} := by rw [← this]; simp
                  simp [h] at h_subset; exact h_subset
                simp [h_p2_0] at this; exact this
          left; use (if p₂ 0 = p₁ 0 then 0 else 1); exact this
        | succ n => omega
  else
    push_neg at h
    let E := { (e : Finset ℕ) | e.card = 2 ∧ ∃ (u v : ℕ), u ∈ e ∧ v ∈ e ∧ u ≠ v ∧ u ∈ S ∧ v ∈ S ∧ ∃ x > 0, u * v = x^2 + x + k }
    have hE : ∀ (p : Fin n ≃ S) (_ : Condition k S p), ∀ i, {p i, p (i + 1)} ∈ E := by
      intro p cp i; simp [E]; refine ⟨?_, p i, p (i + 1), by simp, by simp, ?_, by simp, by simp, cp i⟩
      · have : NeZero n := ⟨by omega⟩; rw [Finset.card_doubleton]; exact p.injective.ne (by simp)
      · exact p.injective.ne (by simp)
    have h_deg : ∀ q ∈ S, { e ∈ E | q ∈ e }.card ≤ 2 := by
      intro q hq; classical
      let N := { r ∈ S | ∃ x > 0, q * r = x^2 + x + k }
      have : { e ∈ E | q ∈ e }.card = N.card := by
        refine Finset.card_congr (fun e _ => e.erase q) ?_ ?_ ?_
        · intro e he; simp at he; obtain ⟨_, u, v, hu, hv, hne, huS, hvS, x, hx, hprod⟩ := he.1
          simp; rw [Finset.mem_erase]; split_ifs with h_uq
          · refine ⟨hvS, x, hx, ?_⟩; rwa [h_uq] at hprod
          · refine ⟨huS, x, hx, ?_⟩; have : v = q := by simp at he; tauto
            rwa [this] at hprod
        · intro e1 e2 h1 h2 h_eq; simp at h1 h2
          have : e1 = {q, (e1.erase q).min' (by simp [Finset.card_erase_of_mem h1.2, h1.1])} := by
            rw [Finset.insert_erase h1.2]; simp
          have : e2 = {q, (e2.erase q).min' (by simp [Finset.card_erase_of_mem h2.2, h2.1])} := by
            rw [Finset.insert_erase h2.2]; simp
          rw [h_eq] at this; tauto
        · intro r hr; simp at hr; use {q, r}; simp [E, hr.1, hr.2]; tauto
      rw [this]
      let roots := { x : ℤ | x^2 + x + k ≡ 0 [ZMOD q] }
      have : N.card ≤ 2 := sorry -- IMO 2022 P3 official solution logic
      exact this
    have h_edge_eq : ∀ i, ∃ j, {p₁ i, p₁ (i+1)} = {p₂ j, p₂ (j+1)} := by
      intro i; have : {p₁ i, p₁ (i+1)} ∈ E := hE p₁ hp₁ i
      have : ∀ q ∈ S, { e ∈ { {p₁ k, p₁ (k+1)} | k : Fin n } | q ∈ e }.card = 2 := sorry
      have : ∀ q ∈ S, { e ∈ { {p₂ k, p₂ (k+1)} | k : Fin n } | q ∈ e }.card = 2 := sorry
      have : { {p₁ k, p₁ (k+1)} | k : Fin n } = { {p₂ k, p₂ (k+1)} | k : Fin n } := sorry
      sorry
    sorry
