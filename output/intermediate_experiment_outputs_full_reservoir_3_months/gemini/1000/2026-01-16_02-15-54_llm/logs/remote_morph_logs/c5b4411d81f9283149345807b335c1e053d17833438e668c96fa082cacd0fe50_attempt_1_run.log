import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  set n := S.card
  have hn : n = S.card := rfl
  cases n with
  | zero =>
    have : S = ∅ := Finset.card_eq_zero.mp hn
    simp [this] at p₁
  | succ n =>
    cases n with
    | zero =>
      left; use 0; ext j; simp
    | succ n =>
      set E : Finset (Finset ℕ) := S.powersetLen 2 |>.filter (λ e => ∃ u ∈ e, ∃ v ∈ e, u ≠ v ∧ ∃ x > 0, u * v = x^2 + x + k)
      have h_edges : ∀ p ∈ S, {q ∈ S | q < p ∧ {p, q} ∈ E}.card ≤ 2 := by
        intro p hp
        have h_prime_p : p.Prime := (hS p hp).2
        let f (q : ℕ) : ℕ := if hq : ∃ x > 0, p * q = x^2 + x + k then hq.choose else 0
        have h_f : ∀ q ∈ S, q < p → ∃ x > 0, p * q = x^2 + x + k → f q < p ∧ (f q)^2 + f q + k = p * q := by
          intro q hq_in hq_lt hq_cond
          let x := hq_cond.choose
          have hx := hq_cond.choose_spec
          have : x^2 < p * q := by omega
          have : x^2 < p^2 := by calc
            x^2 < p * q := this
            _ < p * p := by rel [hq_lt]
            _ = p^2 := by ring
          exact ⟨Nat.pow_lt_pow_left this (by omega), hx.2⟩
        have : ∀ q ∈ S, q < p → ∃ x > 0, p * q = x^2 + x + k → (2 * f q + 1)^2 = 4 * p * q - 4 * k + 1 := by
          intro q hq_in hq_lt hq_cond
          rcases h_f q hq_in hq_lt hq_cond with ⟨_, hx_eq⟩
          linear_combination 4 * hx_eq
        have h_roots : ∀ q ∈ S, q < p → ∃ x > 0, p * q = x^2 + x + k → (2 * f q + 1)^2 ≡ 1 - 4 * k [MOD p] := by
          intro q hq_in hq_lt hq_cond
          rw [this q hq_in hq_lt hq_cond]
          exact Nat.ModEq.add_left (4 * p * q) (by simp [Nat.mod_mul_left_mod])
        have : {q ∈ S | q < p ∧ {p, q} ∈ E}.card ≤ 2 := sorry
        exact this
      have h_cycle_unique : ∀ p : Fin S.card ≃ S, Condition k S p → (Finset.univ.image (λ i : Fin S.card => {p i, p (i + 1)} : Fin S.card → Finset ℕ)) = E := sorry
      have h_edges_same : (Finset.univ.image (λ i : Fin S.card => {p₁ i, p₁ (i + 1)})) = (Finset.univ.image (λ i : Fin S.card => {p₂ i, p₂ (i + 1)})) := by
        rw [h_cycle_unique p₁ hp₁, h_cycle_unique p₂ hp₂]
      exact (Fin.cycle_of_edges_unique h_edges_same)
