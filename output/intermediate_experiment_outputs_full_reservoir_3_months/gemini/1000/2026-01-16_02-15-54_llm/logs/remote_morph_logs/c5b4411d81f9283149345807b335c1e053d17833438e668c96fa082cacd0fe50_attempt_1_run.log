        · cases hq <;> [use p₁ (i+1); use p₁ i] <;> (simp; constructor)
          · exact p₁.injective.ne (by simp)
          · have h_cond := hp₁ i; simp [adj]; exact h_cond
    have hp2_E : ∀ i, {p₂ i, p₂ (i + 1)} ∈ E := by
      intro i; simp [E, adj]; constructor
      · rw [Finset.card_doubleton]; exact p₂.injective.ne (by simp)
      · intro q hq; simp [hq]; constructor
        · cases hq <;> [exact (p₂ i).2; exact (p₂ (i+1)).2]
        · cases hq <;> [use p₂ (i+1); use p₂ i] <;> (simp; constructor)
          · exact p₂.injective.ne (by simp)
          · have h_cond := hp₂ i; simp [adj]; exact h_cond
    sorry

end Imo2022P3
