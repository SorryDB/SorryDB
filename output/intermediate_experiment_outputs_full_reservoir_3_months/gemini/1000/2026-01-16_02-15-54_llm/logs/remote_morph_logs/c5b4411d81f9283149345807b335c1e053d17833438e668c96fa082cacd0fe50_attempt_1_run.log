import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Imo2022P3.Condition k S p₁) (hp₂ : Imo2022P3.Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  induction' S using Finset.strongInductionOn with S ih
  set n := S.card
  rcases n.le_or_lt 2 with hn2 | hn2
  · match n with
    | 0 => left; use 0; intro j; exact Fin.elim0 j
    | 1 => left; use 0; intro j; congr; exact Subsingleton.elim _ _
    | 2 =>
      have h1 : p₂ 0 = p₁ 0 ∨ p₂ 0 = p₁ 1 := by
        have : p₂ 0 ∈ S := p₂.surjective (p₂ 0)
        have : p₁ 0 ∈ S ∧ p₁ 1 ∈ S := ⟨p₁.surjective (p₁ 0), p₁.surjective (p₁ 1)⟩
        simp [Fin.univ_succ, Finset.card_eq_two] at *; tauto
      rcases h1 with h | h
      · left; use 0; intro j; fin_cases j <;> simp [h]
        have h1 : p₂ 1 = p₁ 1 := by
          have : p₂ 1 ≠ p₂ 0 := p₂.injective.ne (by decide)
          have : p₁ 1 ≠ p₁ 0 := p₁.injective.ne (by decide)
          rw [h] at this; rwa [Finset.card_eq_two] at *; tauto
        exact h1
      · right; use 1; intro j; fin_cases j <;> simp [h]
        have h1 : p₂ 1 = p₁ 0 := by
          have : p₂ 1 ≠ p₂ 0 := p₂.injective.ne (by decide)
          have : p₁ 0 ≠ p₁ 1 := p₁.injective.ne (by decide)
          rw [h] at this; rwa [Finset.card_eq_two] at *; tauto
        exact h1
  · obtain ⟨v, hvmax⟩ := S.exists_maximal
    let i₁ := p₁.symm v; let i₂ := p₂.symm v
    let v_prev₁ := p₁ (i₁ - 1); let v_next₁ := p₁ (i₁ + 1)
    let v_prev₂ := p₂ (i₂ - 1); let v_next₂ := p₂ (i₂ + 1)
    let x_prev₁ := (hp₁ (i₁ - 1)).choose; let x_next₁ := (hp₁ i₁).choose
    let x_prev₂ := (hp₂ (i₂ - 1)).choose; let x_next₂ := (hp₂ i₂).choose
    have h1 : v_prev₁ < v ∧ v_next₁ < v ∧ v_prev₂ < v ∧ v_next₂ < v := by
      repeat constructor
      all_goals (apply (hvmax _ (by simp)).lt_of_ne; apply p₁.injective.ne <;> simp; apply p₂.injective.ne <;> simp)
    have h_unique : {v_prev₁, v_next₁} = {v_prev₂, v_next₂} := by
      let f (x : ℕ) := x^2 + x + k
      have hf (a u : ℕ) (x : ℕ) : a * u = f x → x < a := by
        intro h; have : x^2 < a * u := by rw [← h]; nlinarith
        have : u < a := (hvmax u (p₁.surjective u)).lt_of_ne (p₁.injective.ne (by decide))
        nlinarith
      have hb (u w : ℕ) (x y : ℕ) : u * v = f x → w * v = f y → u < v → w < v → u ≠ w → x + y + 1 = v := by
        intros hu hw huv hwv hunw
        have hv_div : v ∣ (x - y) * (x + y + 1) := by
          have : v * (u - w) = (x - y) * (x + y + 1) := by linear_combination hu - hw
          simp [this]
        have hx : x < v := hf v u x hu; have hy : y < v := hf v w y hw
        have hxy : x ≠ y := by intro h; rw [h] at hu; exact hunw (by linear_combination (hu - hw) / v)
        have h_bound : 0 < x + y + 1 ∧ x + y + 1 < 2 * v := by constructor <;> nlinarith
        have : ¬ v ∣ (x - y) := by
          apply Nat.not_dvd_of_pos_of_lt (by apply Nat.pos_of_ne_zero; nlinarith) (by nlinarith)
        rcases (Nat.Prime.dvd_mul (hS v (p₁.surjective v)).2).mp hv_div with h | h
        · contradiction
        · have : x + y + 1 = v := by apply Nat.eq_of_dvd_of_lt_pos h h_bound.2 h_bound.1; exact this
      let s₁ := {v_prev₁, v_next₁}; let s₂ := {v_prev₂, v_next₂}
      have : x_prev₁ + x_next₁ + 1 = v := hb v_prev₁ v_next₁ x_prev₁ x_next₁ (by simpa using (hp₁ (i₁ - 1)).choose_spec.2) (by simpa using (hp₁ i₁).choose_spec.2) h1.1 h1.2.1 (p₁.injective.ne (by decide))
      have : x_prev₂ + x_next₂ + 1 = v := hb v_prev₂ v_next₂ x_prev₂ x_next₂ (by simpa using (hp₂ (i₂ - 1)).choose_spec.2) (by simpa using (hp₂ i₂).choose_spec.2) h1.2.2.1 h1.2.2.2 (p₂.injective.ne (by decide))
      have hx (u x : ℕ) : u * v = x^2 + x + k → u = (x^2 + x + k) / v := by intro h; simp [h]
      suffices {x_prev₁, x_next₁} = {x_prev₂, x_next₂} by
        ext a; constructor <;> intro ha <;> (obtain ⟨x, hx_in, hxa⟩ := by simpa using ha; rw [hx_in] at *; subst a)
        all_goals (obtain ⟨y, hy_in, hya⟩ := by simpa using this; have : v - 1 - x ∈ {x_prev₁, x_next₁} ∨ v - 1 - x ∈ {x_prev₂, x_next₂} := by tauto; rcases this with _ | _ <;> simp [*] at *)
      ext x; have : x ∈ {x_prev₁, x_next₁} ↔ x < v ∧ (v - 1 - x) < v ∧ v ∣ (x^2 + x + k) ∧ (v - 1 - x)^2 + (v - 1 - x) + k ∈ (S.erase v).image (· * v) := sorry
      sorry
    sorry
