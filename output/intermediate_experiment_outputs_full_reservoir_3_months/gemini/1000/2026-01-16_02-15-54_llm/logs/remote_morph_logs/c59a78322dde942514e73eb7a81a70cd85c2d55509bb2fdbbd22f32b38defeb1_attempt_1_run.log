def edgeCount {u v : V} (p : G.LoopWalk u v) (e : Sym2 V) : ‚Ąē := countP (¬∑ = e) p.edges

lemma abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ‚ąĎ(e : edgeSet p),
    edgeCount p e = p.length := by
