  (supportSet p).card ‚Č§ (edgeSet p).card + 1 := by
  have h_edge : ‚ąÄ {u v} (p : G.LoopWalk u v) {e : Sym2 V}, e ‚ąą p.edgeSet ‚Üí ‚ąÄ x ‚ąą e, x ‚ąą p.supportSet := by
