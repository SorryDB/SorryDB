lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ‚Č§ (edgeSet p).card + 1 := by
  have h_start {u v : V} (p' : G.LoopWalk u v) : u ‚ąą p'.supportSet := by
    induction p' <;> simp [supportSet, support, *]
  have h_edge {u v : V} (p' : G.LoopWalk u v) {e} (he : e ‚ąą p'.edgeSet) {x} (hx : x ‚ąą e) : x ‚ąą p'.supportSet := by
    induction p' with
    | nil => cases he
    | loop p'' ih =>
      simp [edgeSet, edges, darts, supportSet, support] at he ‚äĘ
      cases he with
      | head h => subst h; simp [Sym2.mem_iff] at hx; cases hx <;> subst_vars <;> left <;> rfl
