      ¬∑ exact Nat.add_le_add_right ih 1
      ¬∑ intro he;
        have h_sub : ‚ąÄ {e x}, e ‚ąą edgeSet q ‚Üí x ‚ąą e ‚Üí x ‚ąą supportSet q := by
