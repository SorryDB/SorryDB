section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ‚Č§ (edgeSet p).card + 1 := by
  induction p with
  | nil => simp [supportSet, edgeSet, support, edges, darts]
  | loop p ih =>
    have hu : u ‚ąą supportSet p := by cases p <;> simp [supportSet, support]
    simp [supportSet, edgeSet, support, edges, darts, hu]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card_insert _ _) 1)
  | cons h p ih =>
    simp [supportSet, edgeSet, support, edges, darts]
    by_cases hu : u ‚ąą supportSet p
    ¬∑ rw [Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card_insert _ _) 1)
    ¬∑ rw [Finset.card_insert_of_not_mem hu, Finset.card_insert_of_not_mem]
      ¬∑ exact Nat.add_le_add_right ih 1
      ¬∑ intro he
        obtain ‚ü®d, hd, heq‚ü© := mem_map.1 (mem_toFinset.1 he)
        have h_mem : d.1 ‚ąą support p ‚ąß d.2 ‚ąą support p := by
          induction p generalizing d with
          | nil => cases hd
          | loop p' ih' =>
            rcases hd with rfl | hd <;> simp [support]
            ¬∑ exact ‚ü®Or.inl rfl, Or.inl rfl‚ü©
            ¬∑ rcases ih' hd with ‚ü®h1, h2‚ü©; exact ‚ü®Or.inr h1, Or.inr h2‚ü©
          | cons h' p' ih' =>
            rcases hd with rfl | hd <;> simp [support]
            ¬∑ exact ‚ü®Or.inl rfl, Or.inr (by cases p' <;> simp [support])‚ü©
            ¬∑ rcases ih' hd with ‚ü®h1, h2‚ü©; exact ‚ü®Or.inr h1, Or.inr h2‚ü©
        have : u ‚ąą Sym2.mk d := heq.symm ‚Ėł Sym2.mem_mk_left _ _
        rcases Sym2.mem_iff.1 this with h | h
        ¬∑ exact hu (mem_toFinset.2 (h ‚Ėł h_mem.1))
        ¬∑ exact hu (mem_toFinset.2 (h ‚Ėł h_mem.2))

