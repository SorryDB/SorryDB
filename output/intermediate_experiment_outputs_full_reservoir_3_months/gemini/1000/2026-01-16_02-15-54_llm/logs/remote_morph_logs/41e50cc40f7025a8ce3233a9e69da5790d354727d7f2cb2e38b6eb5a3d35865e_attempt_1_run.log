/-- The trajectories to the equation of motion for a given set of initial conditions
  are unique.

  Semiformal implementation:
  - One may needed the added condition of smoothness on `x` here.
  - `EquationOfMotion` needs defining before this can be proved. -/
@[sorryful]
lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  ext t i
  have hx t' : HasDerivAt (fun t' => x (t' : Time) i) (∂ₜ x t' i) t' :=
    (Time.hasDerivAt_toReal t').comp t' ((Time.hasDerivAt_deriv x t').hasDerivAt_f i)
  have hxx t' : HasDerivAt (fun t' => ∂ₜ x (t' : Time) i) (-(S.ω ^ 2) * x (t' : Time) i) t' :=
    (Time.hasDerivAt_toReal t').comp t' ((Time.hasDerivAt_deriv (∂ₜ x) t').hasDerivAt_f i |>.congr_deriv
      (by rw [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear] at h; simpa [ω_sq] using congr_fun (congr_arg (fun x => x i) h.1) t'))
  obtain ⟨a, b, hsol⟩ := exists_cos_sin_combination hx hxx S.ω
  have ha : a = IC.x₀ i := by simpa [h.2.1] using hsol 0
  have hb : b = IC.v₀ i / S.ω := by
    have := (hx 0).unique (by simpa [ha] using ((hasDerivAt_cos 0).const_smul a).add ((hasDerivAt_sin 0).const_smul b) |>.comp 0 (hasDerivAt_mul_const S.ω))
    simpa [S.ω_neq_zero] using this
  simp [trajectory_eq, hsol, ha, hb, S.ω_neq_zero, mul_comm, div_mul_cancel]
```
