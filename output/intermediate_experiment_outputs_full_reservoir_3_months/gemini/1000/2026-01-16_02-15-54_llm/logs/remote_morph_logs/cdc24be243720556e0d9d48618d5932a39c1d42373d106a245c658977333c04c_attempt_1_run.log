          _ = min cx cy * ‖x‖ ^ 2 := by rw [Prod.norm_def, max_eq_left h]
          _ ≤ cx * ‖x‖ ^ 2 := mul_le_mul_of_nonneg_right (min_le_left _ _) (by positivity)
          _ ≤ re ⟪x, x⟫_𝕜 := (hx x).1
          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := le_add_of_nonneg_right inner_self_nonneg
    · calc re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜
        _ ≤ dx * ‖x‖ ^ 2 + dy * ‖y‖ ^ 2 := add_le_add (hx x).2 (hy y).2
