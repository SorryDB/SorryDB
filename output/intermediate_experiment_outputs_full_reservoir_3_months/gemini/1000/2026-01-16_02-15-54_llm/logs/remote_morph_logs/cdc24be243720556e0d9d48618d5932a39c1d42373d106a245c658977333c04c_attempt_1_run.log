instance : AdjointSpace 𝕜 (X×Y) where
  inner := fun (x,y) (x',y') => ⟪x,x'⟫_𝕜 + ⟪y,y'⟫_𝕜
  inner_top_equiv_norm := by
    have ⟨cx,dx,hcx,hdx,_hx⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=X)
    have ⟨cy,dy,hcy,hdy,_hy⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=Y)
    apply Exists.intro (min cx cy)
    apply Exists.intro (dx + dy)
    constructor
    · positivity
    constructor
    · positivity
    · intro (x,y)
      constructor
      · dsimp; rw [re_add]
        calc
          min cx cy * ‖(x, y)‖ ^ 2 = min cx cy * (max ‖x‖ ^ 2 ‖y‖ ^ 2) := by
            rw [prod_norm_def, max_pow₂_eq_pow₂_max (norm_nonneg _) (norm_nonneg _)]
          _ = max (min cx cy * ‖x‖ ^ 2) (min cx cy * ‖y‖ ^ 2) := by rw [mul_max_of_nonneg _ _ (by positivity)]
          _ ≤ max (cx * ‖x‖ ^ 2) (cy * ‖y‖ ^ 2) := by gcongr; apply min_le_left; apply min_le_right
          _ ≤ cx * ‖x‖ ^ 2 + cy * ‖y‖ ^ 2 := by apply max_le_add_of_nonneg <;> positivity
          _ ≤ re ⟪x, x⟫ + re ⟪y, y⟫ := add_le_add (_hx x).1 (_hy y).1
      · dsimp; rw [re_add]
        calc
          re ⟪x, x⟫ + re ⟪y, y⟫ ≤ dx * ‖x‖ ^ 2 + dy * ‖y‖ ^ 2 := add_le_add (_hx x).2 (_hy y).2
          _ ≤ dx * ‖(x, y)‖ ^ 2 + dy * ‖(x, y)‖ ^ 2 := by gcongr; apply ‖x‖.le_max_left; apply ‖y‖.le_max_right
          _ = (dx + dy) * ‖(x, y)‖ ^ 2 := by rw [add_mul]
```
