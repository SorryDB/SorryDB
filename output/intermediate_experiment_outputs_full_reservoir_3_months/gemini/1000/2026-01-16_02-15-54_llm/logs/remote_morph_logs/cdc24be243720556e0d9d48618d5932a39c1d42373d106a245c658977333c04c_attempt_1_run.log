    obtain ⟨cy, dy, hcy, hdy, hy⟩ := AdjointSpace.inner_top_equiv_norm (𝕜 := 𝕜) (E := Y)
    refine ⟨min cx cy, dx + dy, by positivity, by positivity, fun (x, y) => ?_⟩
    simp only [inner, RCLike.add_re]
    constructor
    · cases le_total ‖x‖ ‖y‖ with
      | inl h =>
        calc min cx cy * ‖(x, y)‖ ^ 2
          _ = min cx cy * ‖y‖ ^ 2 := by rw [Prod.norm_def, max_eq_right h]
          _ ≤ cy * ‖y‖ ^ 2 := mul_le_mul_of_nonneg_right (min_le_right _ _) (by positivity)
          _ ≤ re ⟪y, y⟫_𝕜 := (hy y).1
          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := le_add_of_nonneg_left inner_self_nonneg
      | inr h =>
