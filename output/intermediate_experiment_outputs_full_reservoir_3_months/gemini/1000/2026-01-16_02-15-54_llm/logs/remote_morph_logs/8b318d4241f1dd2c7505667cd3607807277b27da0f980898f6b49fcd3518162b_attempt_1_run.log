@[blueprint
  "initial-factorization-tiny-prime-ge"
  (statement := /-- A tiny prime $p \leq L$ can be in deficit by at most $M\log n + ML\pi(n)$.-/)]
theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  unfold Factorization.balance Factorization.sum Params.initial
  simp only [Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_join,
    Multiset.sum_replicate, smul_eq_mul, Int.cast_sub, Int.cast_mul, Int.cast_nat_cast]
  set S := Multiset.Ico (P.n - P.n / P.M) P.n
  set R := S.filter (fun m ↦ m ∉ (P.n / P.L).smoothNumbers)
  have h_split : (P.initial.a.map (·.factorization p)).sum = (P.M : ℝ) * ((S.map (·.factorization p)).sum - (R.map (·.factorization p)).sum) := by
    simp [Params.initial, S, R, Multiset.filter_map, ← Multiset.sum_map_mul_left, ← Multiset.map_sub]
    sorry
  have h_leg : (P.M : ℝ) * (S.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℝ) ≥ -P.M * Real.log P.n := by
    sorry
  have h_rough : (P.M : ℝ) * (R.map (·.factorization p)).sum ≤ P.M * P.L^2 * (primeCounting P.n) := by
    sorry
  rw [h_split]; linarith
