@[blueprint
  "initial-factorization-tiny-prime-ge"
  (statement := /-- A tiny prime $p \leq L$ can be in deficit by at most $M\log n + ML\pi(n)$.-/)
  (proof := /-- In addition to the Legendre calculations, one potentially removes factors of the
  form $plq$ with $l \leq L$ and $q \leq n$ a prime up to $M$ times each, with at most $L$ copies
  of $p$ removed at each factor.-/)]
theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  unfold Factorization.balance Factorization.sum Params.initial
  simp only [Multiset.map_filter, Multiset.map_join, Multiset.map_replicate, Multiset.sum_replicate,
    Multiset.sum_join, Multiset.map_map, smul_eq_mul, Int.ofNat_mul, Int.ofNat_sum, Int.cast_sub,
    Int.cast_mul, Int.cast_sum, Int.cast_neg]
  set I := Multiset.Ico (P.n - P.n / P.M) P.n
  set S := (P.n / P.L).smoothNumbers
  have h_decomp : (∑ m in I.filter (· ∈ S), (m.factorization p : ℝ)) =
      (∑ m in I, (m.factorization p : ℝ)) - (∑ m in I.filter (· ∉ S), (m.factorization p : ℝ)) := by
    rw [← Multiset.filter_add_not (· ∈ S) I, Multiset.map_add, Multiset.sum_add, add_sub_cancel_right]
  rw [h_decomp, mul_sub]
  have h_main : (P.M : ℝ) * (∑ m in I, (m.factorization p : ℝ)) ≥ (P.n.factorial.factorization p : ℝ) - P.M * Real.log P.n := by sorry
  have h_not_smooth : (P.M : ℝ) * (∑ m in I.filter (· ∉ S), (m.factorization p : ℝ)) ≤ P.M * P.L^2 * primeCounting P.n := by sorry
  linarith
```
