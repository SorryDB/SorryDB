instance (priority := 100) IsKrullDomain.isIntegrallyClosed
    (A : Type*) [CommRing A] [IsDomain A] [IsKrullDomain A] : IsIntegrallyClosed A := by
  rw [isIntegrallyClosed_iff]
  intro x hx
  have : x ∈ ⨅ p ∈ {p : PrimeSpectrum A | p.1.primeHeight = 1},
      Localization.subalgebra (FractionRing A) p.1.primeCompl p.1.primeCompl_le_nonZeroDivisors := by
    simp only [Subalgebra.mem_iInf, Set.mem_setOf_eq]
    intro p hp
    haveI := IsKrullDomain.isDiscreteValuationRing_localization p hp
    haveI : IsIntegrallyClosed (Localization p.1.primeCompl) := IsDiscreteValuationRing.toIsIntegrallyClosed
    let L := Localization.subalgebra (FractionRing A) p.1.primeCompl p.1.primeCompl_le_nonZeroDivisors
    haveI : IsIntegrallyClosed L := IsIntegrallyClosed.of_equiv
      (Localization.subalgebra.equiv (FractionRing A) p.1.primeCompl p.1.primeCompl_le_nonZeroDivisors)
    haveI : IsFractionRing L (FractionRing A) := Localization.subalgebra.isFractionRing _ _
    let ⟨r, hr⟩ := (IsIntegrallyClosed.isIntegral_iff (R := L) (K := FractionRing A)).mp (IsIntegral.tower_top (S := L) hx)
    exact hr ▸ r.2
  rw [IsKrullDomain.biInf_eq_bot A] at this
  exact Subalgebra.mem_bot.1 this
