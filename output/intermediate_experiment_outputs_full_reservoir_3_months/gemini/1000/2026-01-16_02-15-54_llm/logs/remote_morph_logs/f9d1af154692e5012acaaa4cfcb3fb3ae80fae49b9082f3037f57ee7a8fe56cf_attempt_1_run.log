instance (priority := 100) IsKrullDomain.isIntegrallyClosed
    (A : Type*) [CommRing A] [IsDomain A] [IsKrullDomain A] : IsIntegrallyClosed A := by
  rw [IsIntegrallyClosed.integralClosure_eq_bot_iff (FractionRing A), ← IsKrullDomain.biInf_eq_bot A]
  refine le_antisymm (le_iInf fun p ↦ le_iInf fun hp ↦ ?_) bot_le
  let hS := p.1.primeCompl_le_nonZeroDivisors
  letI := IsKrullDomain.isDiscreteValuationRing_localization p hp
  haveI : IsIntegrallyClosed (Localization p.1.primeCompl) := DiscreteValuationRing.toIsIntegrallyClosed
  letI : IsIntegrallyClosed (Localization.subalgebra (FractionRing A) p.1.primeCompl hS) :=
    RingEquiv.isIntegrallyClosed (IsLocalization.subalgebra.equiv _ hS).symm
  letI : IsFractionRing (Localization.subalgebra (FractionRing A) p.1.primeCompl hS) (FractionRing A) :=
    IsLocalization.isFractionRing_of_isLocalization _ _ _ hS
  rw [← IsIntegrallyClosed.integralClosure_eq_bot_iff (FractionRing A)]
  apply integralClosure_mono
```
