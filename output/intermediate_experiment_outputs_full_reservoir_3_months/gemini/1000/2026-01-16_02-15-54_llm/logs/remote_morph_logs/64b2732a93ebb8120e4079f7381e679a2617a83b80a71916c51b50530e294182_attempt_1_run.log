/--The diagonal entries of a Wigner Matrix have law ν -/
lemma diagonalHasLaw (n : ℕ) (i : Fin n) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i i) ν (WignerMeasure μ ν n) := by
  rw [HasLaw, wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction]
  simp only [Matrix.of_apply, eq_self_iff_true, dite_true, WignerMeasure]
  rw [Measure.map_eval_pi]
  · simp [wignerMeasureDist]
  · intro j; simp [wignerMeasureDist]; split <;> infer_instance
```
