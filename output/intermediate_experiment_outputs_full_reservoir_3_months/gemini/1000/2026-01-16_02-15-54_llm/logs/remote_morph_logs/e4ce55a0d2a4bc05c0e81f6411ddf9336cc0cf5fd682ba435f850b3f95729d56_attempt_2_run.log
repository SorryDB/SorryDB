    (H_eq_orthocenter : H = Triangle.orthocenter (‚ü®_, affineIndependent_PMN‚ü© : Triangle ‚ĄĚ Pt)) :
    ‚ąÉ affineIndependent_BEF : AffineIndependent ‚ĄĚ ![B, E, F],
