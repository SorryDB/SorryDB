import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1984_p6
  (a b c d k m : ℕ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d)
  (h₁ : Odd a ∧ Odd b ∧ Odd c ∧ Odd d)
  (h₂ : a < b ∧ b < c ∧ c < d)
  (h₃ : a * d = b * c)
  (h₄ : a + d = 2^k)
  (h₅ : b + c = 2^m) :
  a = 1 := by
  have h6 : k > m := by
    have h7 : d - a > c - b := by linarith [h₂.1, h₂.2.2]
    have h8 : (2^k)^2 - 4*a*d > (2^m)^2 - 4*b*c := by
      rw [← h₄, ← h₅, ← h₃]; ring_nf; exact Nat.pow_two_lt_pow_two h7
    rw [h₃] at h8; exact (pow_lt_pow_iff_right one_lt_two).mp (by linarith)
  have h_ba_prod : (b - a) * (b + a) = 2^m * (b - a * 2^(k - m)) := by
    rw [Nat.mul_sub_left_distrib, ← h₃, ← h₄, ← h₅]
    zify [h₀.1, h₀.2.1, h₀.2.2.1, h₀.2.2.2, h₂.1.le, h₆.le]
    ring
  have h_ba_val : b + a = 2^(m - 1) := by
    have h_v2_ba : multiplicity 2 ((b - a) * (b + a)) = m := by
      rw [h_ba_prod, multiplicity_mul, multiplicity_pow_self_of_prime prime_two, multiplicity_odd, PartENat.add_zero]
      · exact prime_two
      · apply Odd.sub_even h₁.2.1
        exact Even.mul_right (even_iff_two_dvd.mpr (dvd_pow_self 2 (Nat.sub_pos_of_lt h6).ne.symm)) _
    have h_gcd : (b - a).gcd (b + a) = 2 := by
      rw [Nat.gcd_rec, Nat.sub_add_cancel h₂.1.le, Nat.gcd_comm, Nat.gcd_rec, Nat.mul_mod_left, Nat.gcd_zero_left]
      exact h₁.1.gcd_two
    have h_v2_b_plus_a : multiplicity 2 (b + a) = m - 1 := by
      have h_v2_sum : multiplicity 2 (b - a) + multiplicity 2 (b + a) = (m : ℕ∞) := by
        rwa [← multiplicity_mul] at h_v2_ba
      have h_v2_min : min (multiplicity 2 (b - a)) (multiplicity 2 (b + a)) = 1 := by
        rw [← multiplicity_gcd_prime_pow prime_two, h_gcd, multiplicity_pow_self_of_prime prime_two]; exacts [rfl, prime_two]
      have h_lt : b - a < 2^(m - 1) := by
        have : 2 * b < b + c := by linarith [h₂.2.1]
        rwa [h₅, ← pow_succ, Nat.succ_le_iff, pow_lt_pow_iff_right one_lt_two] at this
      have : multiplicity 2 (b - a) < (m - 1 : ℕ∞) := by
        rw [← multiplicity_pow_self_of_prime prime_two]; apply multiplicity_lt_multiplicity_of_lt_pow; exacts [prime_two, h_lt]
      cases' (min_choice (multiplicity 2 (b - a)) (multiplicity 2 (b + a))) with hmin hmin
      · rw [hmin, h_v2_min] at h_v2_sum; rw [← h_v2_sum]; exact (WithTop.add_sub_cancel' (by simp)).symm
      · rw [hmin, h_v2_min] at this; linarith [h_v2_sum]
    have h_dvd : 2^(m - 1) ∣ b + a := by rw [← multiplicity_le_iff_pow_dvd]; exact h_v2_b_plus_a.ge
    have h_lt_max : b + a < 2^m := by linarith [h₂.1, h₅, h₂.2.1]
    have h_pos : 0 < b + a := by linarith [h₀.1, h₀.2.1]
    refine Nat.eq_of_dvd_of_lt_of_pos h_dvd ?_ h_pos
    rwa [pow_succ, mul_two] at h_lt_max
  have : a * 2^k = 2^(2 * m - 2) := by
    zify [h₀.1, h₀.2.1, h₆.le]
    have h_b : (b : ℤ) = 2 ^ (m - 1) - a := by zify at h_ba_val; linarith
    have h_ad_bc : (a : ℤ) * (2 ^ k - a) = b * (2 ^ m - b) := by rw [← h₄, ← h₅, ← h₃]; zify; ring
    rw [h_b] at h_ad_bc; ring_nf at h_ad_bc; exact (add_left_inj (a ^ 2 : ℤ)).mp h_ad_bc
  exact h₁.1.eq_one_of_dvd_pow (Dvd.intro (2 ^ k) (by rw [mul_comm, this]))

