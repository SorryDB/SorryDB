    rw [← Nat.count_factors_gcd (by nlinarith [h₂.1]) (by nlinarith), h_gcd]
    exact Nat.count_factors_self (by norm_num)
  have h_cases : (b - a).count_factors 2 = 1 ∧ (b + a).count_factors 2 = m - 1 ∨
                 (b - a).count_factors 2 = m - 1 ∧ (b + a).count_factors 2 = 1 := by
    have : m ≥ 2 := by nlinarith [h₅, h₂, h₀]
    omega
  rcases h_cases with ⟨h_v1, h_v2⟩ | ⟨h_v1, h_v2⟩
  · have h_b_a : ∃ α, Odd α ∧ b - a = 2 * α := by
      exists (b - a) / 2; constructor
      · rw [Nat.odd_iff_not_even, ← Nat.count_factors_eq_zero 2]; norm_num
        rw [Nat.count_factors_div (by nlinarith [h₂.1]), h_v1]; simp
      · rw [Nat.mul_div_cancel' (by rw [← Nat.even_iff_count_factors_ge_one]; linarith)]
    have h_b_p_a : ∃ β, Odd β ∧ b + a = 2^(m-1) * β := by
      exists (b + a) / 2^(m-1); constructor
      · rw [Nat.odd_iff_not_even, ← Nat.count_factors_eq_zero 2]; norm_num
        rw [Nat.count_factors_div (by nlinarith), h_v2]; simp
      · rw [Nat.mul_div_cancel' (by rw [← Nat.count_factors_ge_one]; linarith)]; norm_num
    rcases h_b_a with ⟨α, hα_odd, h_ba⟩
    rcases h_b_p_a with ⟨β, hβ_odd, h_bpa⟩
    have h_sol : (2 ^ (k - m) - 1) * a = (2 - β) * α / β := by
      zify [h₂.1, h₀.1]; rw [h_ba, h_bpa] at h_eq; field_simp at h_eq; linear_combination h_eq / (2 ^ m * β)
    have : β = 1 := by
      by_contra h_not_1; have : β ≥ 3 := by rw [Nat.one_lt_iff_ne_zero_and_ne_one] at h_not_1; exact hβ_odd.three_le h_not_1.2
      have : (2:ℤ) - β < 0 := by linarith
      nlinarith [h₀.1, h_km]
    rw [this] at h_sol; simp at h_sol
    have : a = 2^(m - (k - m) - 2) := sorry
