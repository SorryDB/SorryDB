    have h_mul := congr_arg (Nat.count_factors 2) h_eq
    rw [Nat.count_factors_mul (by nlinarith [h₂.1]) (by nlinarith), Nat.count_factors_mul (by nlinarith) (by nlinarith [h_odd]),
      Nat.count_factors_pow 2 m, Nat.count_factors_2_of_odd h_odd, Nat.add_zero] at h_mul
    exact h_mul
  have h_gcd : (Nat.gcd (b - a) (b + a)) = 2 := by
    have : Nat.gcd (b - a) (b + a) = Nat.gcd (b - a) ((b + a) + (b - a)) := by rw [Nat.gcd_add_right_self]
    rw [this, ← Nat.two_mul]
    have : Nat.gcd (b - a) (2 * b) = 2 * Nat.gcd ((b - a) / 2) b := by
