              rw [вҶҗ mul_assoc]
              pattern (pinching_map (Пғ'' ПҒ Оө m Пғ n))
              change в„° n
            apply (hE1leq Оө2 n hОө2)
          В· apply hE2leqInner
          В· apply hE3leqInner
