    -- $\tilde{\sigma}_n''$; corrected in v4, where $\tilde{\sigma}_n'$ takes
    -- the place of $\sigma_n''$) in this and other steps
    have hE3leq : (1/n : в„қ) вҖў (E3 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' ПҒ Оө m Пғ n).M.log.toMat) вүӨ (c' Оө2 n) вҖў (E3 Оө2 n).toMat := by
      calc
      (1/n : в„қ) вҖў (E3 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' ПҒ Оө m Пғ n).M.log.toMat) вүӨ (1/n : в„қ) вҖў (E3 Оө2 n).toMat * (- (Пғ'' ПҒ Оө m Пғ n).M.log.toMat) := by
        -- first inequality of (S85)
        have hв„°ПҒlognonpos : 0 вүӨ -(в„° n (ПҒвҠ—^S[n])).M.log.toMat := by
          -- log of state is non-positive
          simp only [HermitianMat.log]
          rw [вҶҗ AddSubgroup.coe_neg _, вҶҗ HermitianMat.cfc_neg (в„° n (ПҒвҠ—^S[n])).M]
          change (HermitianMat.toMat 0) вүӨ _
          rw [Subtype.coe_le_coe, HermitianMat.zero_le_cfc (в„° n (ПҒвҠ—^S[n])).M (-Real.log)]
          intro i
          simp
          apply Real.log_nonpos
          В· apply MState.eigenvalue_nonneg _
          В· apply MState.eigenvalue_le_one
        rw [вҶҗ sub_nonneg, вҶҗ mul_sub_left_distrib]
        conv =>
          rhs
          congr; rfl
          rw [вҶҗ sub_add (-(Пғ'' ПҒ Оө m Пғ n).M.log.toMat) ((в„° n (ПҒвҠ—^S[n])).M.log.toMat) ((Пғ'' ПҒ Оө m Пғ n).M.log.toMat)]
          rw [add_comm_sub]
          rw [вҶҗ add_sub_assoc]
          simp [sub_self (Пғ'' ПҒ Оө m Пғ n).M.log.toMat]
        simp only [Algebra.smul_mul_assoc, one_div]
        have hE3в„°nonneg : 0 вүӨ (E3 Оө2 n).toMat * -(в„° n (ПҒвҠ—^S[n])).M.log.toMat := by
          apply Commute.mul_nonneg _ hв„°ПҒlognonpos (Commute.neg_right (hE3commв„° Оө2 n))
          apply HermitianMat.proj_le_nonneg
        apply smul_nonneg (inv_nonneg_of_nonneg (Nat.cast_nonneg' n)) hE3в„°nonneg
      _ вүӨ (1/n : в„қ) вҖў (E3 Оө2 n).toMat * (- (Real.exp (-n * c' Оө2 n) вҖў (1 : HermitianMat (H (i ^ n)) в„Ӯ)).log.toMat) := by
        -- intermediate step in 2nd ineq of S85
        simp only [mul_neg, neg_mul, neg_le_neg_iff]
        have h1logleq : (Real.exp (-(n * c' Оө2 n)) вҖў 1 : HermitianMat (H (i ^ n)) в„Ӯ).log.toMat вүӨ ((Пғ'' ПҒ Оө m Пғ n).M).log.toMat := by
          -- apply hПғ'' Оө2 n to log by monotonicity
          rw [Subtype.coe_le_coe]
          have h_comm : Commute ((Real.exp _ вҖў 1 : HermitianMat _ в„Ӯ).toMat) _ :=
            Commute.smul_left (Commute.one_left (Пғ'' ПҒ Оө m Пғ n).M.toMat) (Real.exp (-(n * c' Оө2 n)))
          exact HermitianMat.log_le_log_of_commute h_comm (by simpa using hПғ'' Оө2 n)
            (Matrix.PosDef.smul Matrix.PosDef.one (Real.exp_pos (-(n * c' Оө2 n))))
        rw [вҶҗ sub_nonneg] at h1logleq
        rw [вҶҗ sub_nonneg, вҶҗ mul_sub_left_distrib]
        simp only [one_div, Algebra.smul_mul_assoc]
        have hE3commlog : Commute (E3 Оө2 n).toMat ((Пғ'' ПҒ Оө m Пғ n).M.log.toMat - (Real.exp (-(n * c' Оө2 n)) вҖў 1 : HermitianMat _ в„Ӯ).log.toMat) := by
          -- projector commutes with logs
          apply Commute.sub_right
          В· -- prove Commute (E3 _) (Пғ'' _).log
            unfold E3 P2
            rw [HermitianMat.proj_le_def]
            apply HermitianMat.cfc_commute
            apply Commute.sub_left
            В· exact pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)
            В· apply Commute.smul_left
              В· rfl
          В· -- prove `Commute (E3 _) (_ 1).log`
            conv_rhs =>
              simp only [
                HermitianMat.log_smul (1 : HermitianMat _ в„Ӯ) (Real.exp _),
                Real.log_exp, neg_smul, HermitianMat.log_one,
                add_zero, NegMemClass.coe_neg,
                HermitianMat.val_eq_coe, selfAdjoint.val_smul,
                selfAdjoint.val_one
                ]
            simp only [Commute.neg_right_iff, Commute.smul_right (Commute.one_right _) _]
        apply smul_nonneg (inv_nonneg_of_nonneg (Nat.cast_nonneg' n))
        apply Commute.mul_nonneg _ h1logleq hE3commlog
        apply HermitianMat.proj_le_nonneg
      _ = (c' Оө2 n) вҖў (E3 Оө2 n).toMat := by
        simp [HermitianMat.log_smul, smul_smul]
        field_simp
    --Linearly combine S81, S82, S85:
    calc
      рқҗғ(в„° n (ПҒвҠ—^S[n])вҖ–Пғ'' ПҒ Оө m Пғ n) / (n : ENNReal) вүӨ
        ENNReal.ofReal (((в„° n (ПҒвҠ—^S[n])).M.inner (((R1 ПҒ Оө).toReal + Оө2) вҖў (E1 Оө2 n)))
        + ((в„° n (ПҒвҠ—^S[n])).M.inner (((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2) вҖў (E2 Оө2 n)))
        + ((в„° n (ПҒвҠ—^S[n])).M.inner ((c' Оө2 n) вҖў (E3 Оө2 n))))
      := by
        -- (S86) to (S88)
        unfold qRelativeEnt SandwichedRelRentropy
        simp only [вҶ“reduceIte]
        have Пғ''_pd := Пғ''_posdef ПҒ Оө m Пғ
        simp only [MState.toMat_M] at Пғ''_pd
        have hker : (Пғ'' ПҒ Оө m Пғ n).M.ker вүӨ (в„° n (ПҒвҠ—^S[n])).M.ker :=
          ker_le_ker_pinching_of_PosDef (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n) (Пғ''_pd n)
        simp only [hker, if_true]
        have hMulOne : (в„° n (ПҒвҠ—^S[n])).M.toMat * (1 : Matrix (H (i ^ n)) (H (i ^ n)) в„Ӯ) = (в„° n (ПҒвҠ—^S[n])).M.toMat := Matrix.mul_one (в„° n (ПҒвҠ—^S[n])).M.toMat
        have hOneMulCommute : Commute (1 : HermitianMat _ в„Ӯ).toMat (в„° n (ПҒвҠ—^S[n])).M.toMat := Commute.one_left (в„° n (ПҒвҠ—^S[n])).M.toMat
        have hOneIsOne : вҲҖ (Оө : в„қ) (n : в„•), (1 : в„қ вҶ’ в„• вҶ’ HermitianMat (H (i ^ n)) в„Ӯ) Оө n = (1 : HermitianMat (H (i ^ n)) в„Ӯ) := by
          intro Оө n; rfl
        /- convert Esum to the HermitianMat equality at point (Оө2, n) -/
        have Esum' : (E1 Оө2 n).toMat + (E2 Оө2 n).toMat + (E3 Оө2 n).toMat = 1 :=
          congrArg HermitianMat.toMat (congrFun (congrFun Esum Оө2) n)
        conv =>
