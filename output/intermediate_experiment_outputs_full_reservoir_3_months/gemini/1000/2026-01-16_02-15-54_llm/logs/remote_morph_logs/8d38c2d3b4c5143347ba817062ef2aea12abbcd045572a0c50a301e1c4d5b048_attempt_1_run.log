              В· simp
        have hE2leqInner : (n : в„қ)вҒ»В№ * ((в„° n (ПҒвҠ—^S[n])).M.toMat * (E2 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' ПҒ Оө m Пғ n).M.log.toMat)).trace.re вүӨ ((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2) * ((в„° n (ПҒвҠ—^S[n])).M).inner (E2 Оө2 n) := by
          open HermMul in
          -- (S82) -- see (S81) for comments
          have hE2leq Оө2 (n : в„•) (hОө2 : 0 < Оө2) : (1/n : в„қ) вҖў (E2 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' ПҒ Оө m Пғ n).M.log.toMat) вүӨ ((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2) вҖў (E2 Оө2 n).toMat := by
