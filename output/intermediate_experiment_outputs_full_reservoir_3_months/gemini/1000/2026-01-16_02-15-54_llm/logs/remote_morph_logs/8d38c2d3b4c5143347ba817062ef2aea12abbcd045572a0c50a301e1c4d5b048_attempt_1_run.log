            rw [вҶҗ HermitianMat.zero_le_iff]
            apply MState.zero_le
          simp at hE2leq
          rw [вҶҗ Complex.re_ofReal_mul (вҶ‘n)вҒ»В№, вҶҗ smul_eq_mul, вҶҗ Matrix.trace_smul]
          rw [вҶҗ RCLike.re_to_complex]
          conv =>
            enter [1, 2]
            rw [mul_assoc]
            enter [1, 2, 2]
            norm_cast
            rw [вҶҗ HermitianMat.symmMul_of_commute hE2comm]
          conv at hE2leq =>
            enter [Оө2, n, hОө2, 1, 2, 2]
            norm_cast
          specialize hE2leq Оө2 n hОө2
          rw [вҶҗ HermitianMat.symmMul_of_commute hE2comm] at hE2leq
          conv_lhs at hE2leq =>
            change (Complex.ofReal (_ : в„қ)) вҖў _
