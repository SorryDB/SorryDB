import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let α1 := ∠ P A B; let β1 := ∠ P B C; let γ1 := ∠ P C A
  let α2 := ∠ P A C; let β2 := ∠ P B A; let γ2 := ∠ P C B
  have hP_mem : P ∈ interior (convexHull ℝ {A, B, C}) := hP
  have hA : P ≠ A := (EuclideanGeometry.mem_interior_convexHull_triangle_iff_exists_pos hABC).1 hP_mem.1
  have hB : P ≠ B := (EuclideanGeometry.mem_interior_convexHull_triangle_iff_exists_pos hABC).1 hP_mem.1
  have hC : P ≠ C := (EuclideanGeometry.mem_interior_convexHull_triangle_iff_exists_pos hABC).1 hP_mem.1
  have h_pos : 0 < α1 ∧ 0 < β1 ∧ 0 < γ1 ∧ 0 < α2 ∧ 0 < β2 ∧ 0 < γ2 := by
    refine ⟨angle_pos_of_mem_interior hABC hP_mem 0 1, angle_pos_of_mem_interior hABC hP_mem 1 2,
            angle_pos_of_mem_interior hABC hP_mem 2 0, angle_pos_of_mem_interior hABC hP_mem 0 2,
            angle_pos_of_mem_interior hABC hP_mem 1 0, angle_pos_of_mem_interior hABC hP_mem 2 1⟩
  have h_sum : α1 + α2 + (β1 + β2) + (γ1 + γ2) = π := by
    rw [angle_add_angle_eq_angle_of_mem_interior hABC hP_mem 0 1 2,
        angle_add_angle_eq_angle_of_mem_interior hABC hP_mem 1 2 0,
        angle_add_angle_eq_angle_of_mem_interior hABC hP_mem 2 0 1,
        angle_sum_pair ![A, B, C] hABC]
  have h_trig : sin α1 * sin β1 * sin γ1 = sin α2 * sin β2 * sin γ2 := by
    have l1 : dist P A * sin α1 = dist P B * sin β2 := (dist_point_line_eq_dist_sin P A B).symm.trans (dist_point_line_eq_dist_sin P B A)
