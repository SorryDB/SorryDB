import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let d_ab := dist P (AffineSubspace.line ℝ ![A, B])
  let d_bc := dist P (AffineSubspace.line ℝ ![B, C])
  let d_ca := dist P (AffineSubspace.line ℝ ![C, A])
  have h_pos : 0 < ∠ P A B ∧ 0 < ∠ P B C ∧ 0 < ∠ P C A ∧ 0 < ∠ P B A ∧ 0 < ∠ P C B ∧ 0 < ∠ P A C := sorry
  have h_α : ∠ P A B < 5 * π / 6 := sorry
  have h_β : ∠ P B C < 5 * π / 6 := sorry
  have h_γ : ∠ P C A < 5 * π / 6 := sorry
  have h1 : d_ab = dist P A * sin (∠ P A B) := sorry
  have h2 : d_bc = dist P B * sin (∠ P B C) := sorry
  have h3 : d_ca = dist P C * sin (∠ P C A) := sorry
  have h1' : d_ab > dist P A / 2 := by
    rw [h1]; unit_interval
    have : sin (∠ P A B) > 1 / 2 := sin_gt_half_of_mem_Ioo ⟨h.1, h_α⟩
    nlinarith
  have h2' : d_bc > dist P B / 2 := by
    rw [h2]; unit_interval
    have : sin (∠ P B C) > 1 / 2 := sin_gt_half_of_mem_Ioo ⟨h.2.1, h_β⟩
    nlinarith
  have h3' : d_ca > dist P C / 2 := by
    rw [h3]; unit_interval
    have : sin (∠ P C A) > 1 / 2 := sin_gt_half_of_mem_Ioo ⟨h.2.2, h_γ⟩
    nlinarith
  have h_em : dist P A + dist P B + dist P C ≥ 2 * (d_bc + d_ca + d_ab) := sorry
  linarith
