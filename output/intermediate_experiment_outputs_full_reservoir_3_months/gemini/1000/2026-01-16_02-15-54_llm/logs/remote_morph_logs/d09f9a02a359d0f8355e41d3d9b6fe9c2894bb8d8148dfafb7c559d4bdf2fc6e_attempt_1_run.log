      rw [← sin_pi_div_six]; apply sin_lt_sin_of_lt_of_le <;> linarith [pi_pos]
    have h_α₁_lt : α₁ < 2 * π / 3 := by linarith
    have h_β₁_lt : β₁ < 2 * π / 3 := by linarith
    have h_γ₁_lt : γ₁ < 2 * π / 3 := by linarith
    have s1 : sin α₁ > 1/2 := h_range α₁ hα₁ (by linarith)
    have s2 : sin β₁ > 1/2 := h_range β₁ hβ₁ (by linarith)
    have s3 : sin γ₁ > 1/2 := h_range γ₁ hγ₁ (by linarith)
