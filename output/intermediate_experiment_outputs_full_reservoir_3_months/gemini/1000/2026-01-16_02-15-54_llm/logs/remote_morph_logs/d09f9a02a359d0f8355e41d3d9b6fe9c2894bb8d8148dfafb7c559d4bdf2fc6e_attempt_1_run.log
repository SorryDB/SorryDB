/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let α₁ := ∠ P A B
  let β₁ := ∠ P B C
  let γ₁ := ∠ P C A
  let α₂ := ∠ P A C
  let β₂ := ∠ P B A
  let γ₂ := ∠ P C B
  let dPAB := Line.dist P (lineId ℝ A B)
  let dPBC := Line.dist P (lineId ℝ B C)
  let dPCA := Line.dist P (lineId ℝ C A)
  have h_P_ne_A : P ≠ A := (interior_convexHull_subset_convexHull ℝ {A, B, C} hP).ne_points_self hABC 0
  have h_P_ne_B : P ≠ B := (interior_convexHull_subset_convexHull ℝ {A, B, C} hP).ne_points_self hABC 1
  have h_P_ne_C : P ≠ C := (interior_convexHull_subset_convexHull ℝ {A, B, C} hP).ne_points_self hABC 2
  have h_dist_pos : 0 < dist P A ∧ 0 < dist P B ∧ 0 < dist P C := by
    simp [dist_pos, h_P_ne_A, h_P_ne_B, h_P_ne_C]
  have h_sin_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have h1 : dPAB = dist P A * sin α₁ := by rw [dist_point_line_eq_dist_sin_angle]
    have h2 : dPAB = dist P B * sin β₂ := by rw [dist_point_line_eq_dist_sin_angle, angle_comm]
    have h3 : dPBC = dist P B * sin β₁ := by rw [dist_point_line_eq_dist_sin_angle]
    have h4 : dPBC = dist P C * sin γ₂ := by rw [dist_point_line_eq_dist_sin_angle, angle_comm]
    have h5 : dPCA = dist P C * sin γ₁ := by rw [dist_point_line_eq_dist_sin_angle]
    have h6 : dPCA = dist P A * sin α₂ := by rw [dist_point_line_eq_dist_sin_angle, angle_comm]
    field_simp [h_dist_pos.1, h_dist_pos.2.1, h_dist_pos.2.2]
    linear_combination h1 * h3 * h5 - h2 * h4 * h6
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := by
    rw [←angle_add_angle_eq_angle_of_interior hABC hP, ←angle_add_angle_eq_angle_of_interior (AffineIndependent.reindex (Equiv.swap 0 1) hABC) (by simpa using hP), ←angle_add_angle_eq_angle_of_interior (AffineIndependent.reindex (Equiv.swap 0 2) hABC) (by simpa using hP)]
    exact angle_sum_triangle hABC
  have h_prod1 : 1 / 8 < sin α₁ * sin β₁ * sin γ₁ := by
    have s1 : 1 / 2 < sin α₁ := sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (angle_le_pi P A B)
    have s2 : 1 / 2 < sin β₁ := sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (angle_le_pi P B C)
    have s3 : 1 / 2 < sin γ₁ := sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (angle_le_pi P C A)
    nlinarith [sin_pos_of_mem_Ioo ⟨by linarith, by linarith [angle_le_pi P A B]⟩]
  have h_prod2 : sin α₂ * sin β₂ * sin γ₂ < 1 / 8 := by
    have h_sum2 : α₂ + β₂ + γ₂ < π / 2 := by linarith
    have h_pos : 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := ⟨angle_pos_of_interior hABC hP, angle_pos_of_interior (AffineIndependent.reindex (Equiv.swap 0 1) hABC) (by simpa using hP), angle_pos_of_interior (AffineIndependent.reindex (Equiv.swap 0 2) hABC) (by simpa using hP)⟩
    have : sin α₂ * sin β₂ * sin γ₂ ≤ (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 := sin_mul_sin_mul_sin_le_sin_cubic h_pos.1 h_pos.2.1 h_pos.2.2 (by linarith)
    refine this.trans_lt ?_
    rw [show (1/8:ℝ) = (1/2:ℝ)^3 by norm_num, pow_lt_pow_left_iff₀ (by norm_num) (by norm_num) (by norm_num)]
    exact sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
  linarith
