    nlinarith
  have h_RHS : sin α₂ * sin β₂ * sin γ₂ < 1 / 8 := by
    have h_prod : sin α₂ * sin β₂ * sin γ₂ ≤ (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 := sorry
