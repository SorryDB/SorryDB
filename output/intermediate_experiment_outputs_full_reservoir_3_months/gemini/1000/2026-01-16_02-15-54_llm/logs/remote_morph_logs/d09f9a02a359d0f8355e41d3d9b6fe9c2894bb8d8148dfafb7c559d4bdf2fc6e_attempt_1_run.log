import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨hPAB, hPBC, hPCA⟩
  let α₁ := ∠ P A B
  let β₁ := ∠ P B C
  let γ₁ := ∠ P C A
  let α₂ := ∠ P A C
  let β₂ := ∠ P B A
  let γ₂ := ∠ P C B
  have hP_A : P ≠ A := by intro r; subst r; exact (interior_subset hP) (subset_convexHull _ _ (by simp))
  have hP_B : P ≠ B := by intro r; subst r; exact (interior_subset hP) (subset_convexHull _ _ (by simp))
  have hP_C : P ≠ C := by intro r; subst r; exact (interior_subset hP) (subset_convexHull _ _ (by simp))
  have hA_B : A ≠ B := hABC.injective.ne (by simp)
  have hB_C : B ≠ C := hABC.injective.ne (by simp)
  have hC_A : C ≠ A := hABC.injective.ne (by simp)
  have h_sin_pos : 0 < Real.sin α₁ ∧ 0 < Real.sin β₁ ∧ 0 < Real.sin γ₁ := by
    have h_int_α₁ : α₁ ∈ Set.Ioo 0 π := angle_pos_of_mem_interior (A := A) (B := P) (C := B)
      (interior_subset_interior_angle_bisector hP (by simp))
    have h_int_β₁ : β₁ ∈ Set.Ioo 0 π := angle_pos_of_mem_interior (A := B) (B := P) (C := C)
      (interior_subset_interior_angle_bisector (P := P) (A := B) (B := C) (C := A) (by
        rw [Set.pair_comm, Set.insert_comm]; exact hP) (by simp))
    have h_int_γ₁ : γ₁ ∈ Set.Ioo 0 π := angle_pos_of_mem_interior (A := C) (B := P) (C := A)
      (interior_subset_interior_angle_bisector (P := P) (A := C) (B := A) (C := B) (by
        rw [Set.pair_comm, Set.insert_comm, Set.pair_comm]; exact hP) (by simp))
    exact ⟨Real.sin_pos_of_mem_Ioo h_int_α₁, Real.sin_pos_of_mem_Ioo h_int_β₁, Real.sin_pos_of_mem_Ioo h_int_γ₁⟩
  have h_prod : Real.sin α₁ * Real.sin β₁ * Real.sin γ₁ = Real.sin α₂ * Real.sin β₂ * Real.sin γ₂ := by
    have h1 : dist P A * Real.sin α₁ = dist P B * Real.sin β₂ := by
      rw [mul_comm, ← dist_sin_angle P A B, mul_comm, ← dist_sin_angle P B A]
    have h2 : dist P B * Real.sin β₁ = dist P C * Real.sin γ₂ := by
      rw [mul_comm, ← dist_sin_angle P B C, mul_comm, ← dist_sin_angle P C B]
    have h3 : dist P C * Real.sin γ₁ = dist P A * Real.sin α₂ := by
      rw [mul_comm, ← dist_sin_angle P C A, mul_comm, ← dist_sin_angle P A C]
    have h_all := congr_arg₂ (· * ·) (congr_arg₂ (· * ·) h1 h2) h3
    field_simp at h_all; linarith
  have h_sum_all : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := by
    have hA := angle_add_angle_of_mem_interior (A := A) (B := B) (C := C) (P := P) (interior_subset_interior_angle_bisector hP (by simp))
    have hB := angle_add_angle_of_mem_interior (A := B) (B := C) (C := A) (P := P) (interior_subset_interior_angle_bisector (P := P) (A := B) (B := C) (C := A) (by rw [Set.pair_comm, Set.insert_comm]; exact hP) (by simp))
    have hC := angle_add_angle_of_mem_interior (A := C) (B := A) (C := B) (P := P) (interior_subset_interior_angle_bisector (P := P) (A := C) (B := A) (C := B) (by rw [Set.pair_comm, Set.insert_comm, Set.pair_comm]; exact hP) (by simp))
    rw [angle_comm P A B] at hA; rw [angle_comm P B C] at hB; rw [angle_comm P C A] at hC
    linarith [angle_sum_triangle A B C hABC]
  have h_α₁_lt : α₁ < 5 * π / 6 := by linarith [h_sum_all, h_sin_pos, hPAB, hPBC, hPCA]
  have h_β₁_lt : β₁ < 5 * π / 6 := by linarith [h_sum_all, h_sin_pos, hPAB, hPBC, hPCA]
  have h_γ₁_lt : γ₁ < 5 * π / 6 := by linarith [h_sum_all, h_sin_pos, hPAB, hPBC, hPCA]
  have h_sin_low : Real.sin α₁ > 1/2 ∧ Real.sin β₁ > 1/2 ∧ Real.sin γ₁ > 1/2 := by
    constructor; exact Real.sin_gt_half_of_Ioo hPAB h_α₁_lt
    constructor; exact Real.sin_gt_half_of_Ioo hPBC h_β₁_lt
    exact Real.sin_gt_half_of_Ioo hPCA h_γ₁_lt
  have h_left : Real.sin α₁ * Real.sin β₁ * Real.sin γ₁ > 1 / 8 := by
    have : 0 < (1/2 : ℝ) := by norm_num
    exact mul_pos (mul_pos h_sin_low.1 h_sin_low.2.1) h_sin_low.2.2
  have h_sum_rhs : α₂ + β₂ + γ₂ < π / 2 := by linarith
  have h_right : Real.sin α₂ * Real.sin β₂ * Real.sin γ₂ < 1 / 8 := by
    have h_pos' : α₂ > 0 ∧ β₂ > 0 ∧ γ₂ > 0 := by
      constructor; exact angle_pos_of_mem_interior (A := A) (B := C) (C := P) (interior_subset_interior_angle_bisector hP (by simp))
      constructor; exact angle_pos_of_mem_interior (A := B) (B := A) (C := P) (interior_subset_interior_angle_bisector (P := P) (A := B) (B := C) (C := A) (by rw [Set.pair_comm, Set.insert_comm]; exact hP) (by simp))
      exact angle_pos_of_mem_interior (A := C) (B := B) (C := P) (interior_subset_interior_angle_bisector (P := P) (A := C) (B := A) (C := B) (by rw [Set.pair_comm, Set.insert_comm, Set.pair_comm]; exact hP) (by simp))
    have h_jensen := Real.geom_mean_le_sin_mean_Icc (x := ![α₂, β₂, γ₂]) (by intro i; fin_cases i <;> simp [h_pos'.1, h_pos'.2.1, h_pos'.2.2]; linarith) (by intro i; fin_cases i <;> simp [h_pos'.1, h_pos'.2.1, h_pos'.2.2]; linarith)
    have h_mean : (α₂ + β₂ + γ₂) / 3 < π / 6 := by linarith
    have h_prod_le := Real.sin_α_sin_β_sin_γ_le_sin_s_div_3 h_pos'.1 h_pos'.2.1 h_pos'.2.2 (by linarith)
    exact h_prod_le.trans_lt (pow_lt_pow_left (Real.sin_lt_sin_of_lt_of_le_pi_div_two (by linarith) h_mean.le (by linarith)) (by norm_num) (by norm_num))
  linarith

```
