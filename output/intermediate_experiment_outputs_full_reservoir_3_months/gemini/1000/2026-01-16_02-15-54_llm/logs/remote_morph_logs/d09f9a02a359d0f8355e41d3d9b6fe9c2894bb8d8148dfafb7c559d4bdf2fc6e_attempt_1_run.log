import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let x₁ := ∠ P A B
  let y₁ := ∠ P B C
  let z₁ := ∠ P C A
  let x₂ := ∠ P A C
  let y₂ := ∠ P B A
  let z₂ := ∠ P C B
  have h_int : P ∈ interior (convexHull ℝ {A, B, C}) := hP
  have h_angle_sum : (x₁ + x₂) + (y₁ + y₂) + (z₁ + z₂) = π := by
    rw [← triangle_angle_sum_eq_pi hABC, ← angle_add_angle_of_point_in_interior_angle A B C P h_int,
        ← angle_add_angle_of_point_in_interior_angle B C A P h_int, ← angle_add_angle_of_point_in_interior_angle C A B P h_int]
    simp [x₁, x₂, y₁, y₂, z₁, z₂]; abel
  have h_pos : 0 < x₁ ∧ 0 < y₁ ∧ 0 < z₁ ∧ 0 < x₂ ∧ 0 < y₂ ∧ 0 < z₂ := by
    repeat constructor; all_goals exact angle_pos_of_point_in_interior_angle _ _ _ _ h_int
  have h_sin_ceva : sin x₁ * sin y₁ * sin z₁ = sin x₂ * sin y₂ * sin z₂ := by
    field_simp [dist_left_sep_sin_angle_p_a_b] -- conceptual placeholder for trigonometric Ceva's theorem
    sorry
  have h_sum1 : x₁ + y₁ + z₁ > π / 2 := by linarith
  have h_sum2 : x₂ + y₂ + z₂ < π / 2 := by linarith
  have h_sin1 : sin x₁ * sin y₁ * sin z₁ > 1 / 8 := by
    have hx₁ : x₁ ∈ Set.Ioo (π / 6) (2 * π / 3) := ⟨hPAB, by linarith [h_angle_sum, h_pos]⟩
    have hy₁ : y₁ ∈ Set.Ioo (π / 6) (2 * π / 3) := ⟨hPBC, by linarith [h_angle_sum, h_pos]⟩
    have hz₁ : z₁ ∈ Set.Ioo (π / 6) (2 * π / 3) := ⟨hPCA, by linarith [h_angle_sum, h_pos]⟩
    have : ∀ x ∈ Set.Ioo (π / 6) (2 * π / 3), sin x > 1 / 2 := fun x hx => by
      if h : x ≤ π / 2 then
        have : sin (π / 6) ≤ sin x := sin_monotone_Icc (by linarith [hx.1]) (by linarith [h]) hx.1.le
        linarith [sin_pi_sixth]
      else
        have : sin (2 * π / 3) ≤ sin x := sin_antitone_Icc (by linarith [h]) (by linarith [hx.2]) hx.2.le
        linarith [sin_two_pi_tri, sin_pi_sixth]
    nlinarith [this x₁ hx₁, this y₁ hy₁, this z₁ hz₁]
  have h_sin2 : sin x₂ * sin y₂ * sin z₂ < 1 / 8 := by
    have h_jensen : sin x₂ * sin y₂ * sin z₂ ≤ (sin ((x₂ + y₂ + z₂) / 3)) ^ 3 := by
      have h_conc : ConcaveOn ℝ (Set.Icc 0 π) sin := concaveOn_sin
      have h_mem : ∀ x ∈ [x₂, y₂, z₂], x ∈ Set.Icc 0 π := by intros x hx; simp at hx; cases hx <;> linarith [h_pos, h_angle_sum]
      -- Jensen's inequality for 3 variables
      sorry
    have : sin ((x₂ + y₂ + z₂) / 3) < 1 / 2 := by
      have : (x₂ + y₂ + z₂) / 3 < π / 6 := by linarith
      rw [← sin_pi_sixth]
      exact sin_lt_sin (by linarith [h_pos]) (by linarith [h_pos, h_angle_sum]) this
    nlinarith
  linarith [h_sin_ceva, h_sin1, h_sin2]
