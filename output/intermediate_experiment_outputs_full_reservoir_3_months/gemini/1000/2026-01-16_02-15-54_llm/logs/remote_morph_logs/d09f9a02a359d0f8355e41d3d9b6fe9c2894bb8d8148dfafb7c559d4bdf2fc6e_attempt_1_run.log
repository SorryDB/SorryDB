import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hA, hB, hC⟩ := h
  let a1 := ∠ P A B; let a2 := ∠ P A C
  let b1 := ∠ P B C; let b2 := ∠ P B A
  let c1 := ∠ P C A; let c2 := ∠ P C B
  have hp : 0 < a1 ∧ 0 < a2 ∧ 0 < b1 ∧ 0 < b2 ∧ 0 < c1 ∧ 0 < c2 := sorry
  have hs : a1 + a2 + b1 + b2 + c1 + c2 = π := sorry
  have hc : sin a1 * sin b1 * sin c1 = sin a2 * sin b2 * sin c2 := sorry
  have h1 : sin a1 * sin b1 * sin c1 > 1/8 := by
    have ha : a1 < 2 * π / 3 := by linarith [hp.2.1, hp.2.2.1, hp.2.2.2.1, hp.2.2.2.2, hs]
    have hb : b1 < 2 * π / 3 := by linarith [hp.1, hp.2.1, hp.2.2.2.1, hp.2.2.2.2, hs]
    have hc' : c1 < 2 * π / 3 := by linarith [hp.1, hp.2.1, hp.2.2.1, hp.2.2.2.2, hs]
    have s1 : sin a1 > 1/2 := sorry
    have s2 : sin b1 > 1/2 := sorry
    have s3 : sin c1 > 1/2 := sorry
    nlinarith
  have h2 : sin a2 * sin b2 * sin c2 < 1/8 := by
    have hsum : a2 + b2 + c2 < π / 2 := by linarith
    exact sorry
  exact h1.not_le (hc.symm.le.trans h2.le)
