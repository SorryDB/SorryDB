import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let α₁ := ∠ P A B
  let β₁ := ∠ P B C
  let γ₁ := ∠ P C A
  let α₂ := ∠ P A C
  let β₂ := ∠ P B A
  let γ₂ := ∠ P C B
  have h_pos : 0 < α₁ ∧ 0 < β₁ ∧ 0 < γ₁ ∧ 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := sorry
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := sorry
  have h_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := sorry
  have h_xyz : α₁ > π / 6 ∧ β₁ > π / 6 ∧ γ₁ > π / 6 := h
  have h_xyz_sum : α₁ + β₁ + γ₁ > π / 2 := by linarith [h_xyz.1, h_xyz.2.1, h_xyz.2.2]
  have h_x'y'z'_sum : α₂ + β₂ + γ₂ < π / 2 := by linarith [h_sum, h_xyz_sum, h_pos.1, h_pos.2.1, h_pos.2.2]
  have h_xyz_limit : α₁ < 2 * π / 3 ∧ β₁ < 2 * π / 3 ∧ γ₁ < 2 * π / 3 := by
    constructor
    · linarith [h_sum, h_pos.2.2.2.1, h_pos.2.2.2.2.1, h_pos.2.2.2.2.2, h_xyz.2.1, h_xyz.2.2]
    · constructor
      · linarith [h_sum, h_pos.2.2.1, h_pos.2.2.2.2.1, h_pos.2.2.2.2.2, h_xyz.1, h_xyz.2.2]
      · linarith [h_sum, h_pos.2.2.1, h_pos.2.2.2.1, h_pos.2.2.2.2.1, h_xyz.1, h_xyz.2.1]
  have h_sin_xyz : sin α₁ * sin β₁ * sin γ₁ > 1 / 8 := by
    have s1 : sin α₁ > 1 / 2 := by
      rw [← sin_pi_div_six]
      apply sin_gt_sin_of_lt_pi_div_two <;> try linarith [h_xyz.1, h_xyz_limit.1]
    have s2 : sin β₁ > 1 / 2 := by
      rw [← sin_pi_div_six]
      apply sin_gt_sin_of_lt_pi_div_two <;> try linarith [h_xyz.2.1, h_xyz_limit.2.1]
    have s3 : sin γ₁ > 1 / 2 := by
      rw [← sin_pi_div_six]
      apply sin_gt_sin_of_lt_pi_div_two <;> try linarith [h_xyz.2.2, h_xyz_limit.2.2]
    linarith [s1, s2, s3]
