import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let x1 := ∠ P A B
  let y1 := ∠ P B C
  let z1 := ∠ P C A
  let x2 := ∠ P A C
  let y2 := ∠ P B A
  let z2 := ∠ P C B
  
  have h_sin_prod : sin x1 * sin y1 * sin z1 = sin x2 * sin y2 * sin z2 := by
    have dPA : dist P A ≠ 0 := (dist_pos.mpr (fun heq => (interior_subset hP) (by simpa [heq] using subset_convexHull ℝ {A, B, C} (Set.mem_insert A {B, C})))).ne'
    have dPB : dist P B ≠ 0 := (dist_pos.mpr (fun heq => (interior_subset hP) (by simpa [heq] using subset_convexHull ℝ {A, B, C} (Set.mem_insert_of_mem _ (Set.mem_insert B {C}))Record))).ne'
    have dPC : dist P C ≠ 0 := (dist_pos.mpr (fun heq => (interior_subset hP) (by simpa [heq] using subset_convexHull ℝ {A, B, C} (Set.mem_insert_of_mem _ (Set.mem_insert_of_mem _ (Set.mem_singleton C)))))).ne'
    -- Using the law of sines in triangles PAB, PBC, and PCA
    have s1 : dist P A * sin x1 = dist P B * sin y2 := sorry
    have s2 : dist P B * sin y1 = dist P C * sin z2 := sorry
    have s3 : dist P C * sin z1 = dist P A * sin x2 := sorry
    calc sin x1 * sin y1 * sin z1
      _ = (dist P A * sin x1) * (dist P B * sin y1) * (dist P C * sin z1) / (dist P A * dist P B * dist P C) := by field_simp; ring
      _ = (dist P B * sin y2) * (dist P C * sin z2) * (dist P A * sin x2) / (dist P A * dist P B * dist P C) := by rw [s1, s2, s3]
      _ = sin x2 * sin y2 * sin z2 := by field_simp; ring

  have hx1 : π / 6 < x1 ∧ x1 < 5 * π / 6 := sorry
  have hy1 : π / 6 < y1 ∧ y1 < 5 * π / 6 := sorry
  have hz1 : π / 6 < z1 ∧ z1 < 5 * π / 6 := sorry
  have h_prod1 : sin x1 * sin y1 * sin z1 > 1 / 8 := by
    have sx : sin x1 > 1 / 2 := by rw [← sin_pi_six]; exact sin_lt_sin_of_lt_of_lt (by linarith [hx1]) (by linarith [hx1]) (by linarith [hx1])
    have sy : sin y1 > 1 / 2 := by rw [← sin_pi_six]; exact sin_lt_sin_of_lt_of_lt (by linarith [hy1]) (by linarith [hy1]) (by linarith [hy1])
    have sz : sin z1 > 1 / 2 := by rw [← sin_pi_six]; exact sin_lt_sin_of_lt_of_lt (by linarith [hz1]) (by linarith [hz1]) (by linarith [hz1])
    nlinarith

  have h_sum : x1 + x2 + y1 + y2 + z1 + z2 = π := sorry
  have h_x2y2z2_pos : x2 > 0 ∧ y2 > 0 ∧ z2 > 0 := sorry
  have h_sum2 : x2 + y2 + z2 < π / 2 := by linarith [h.1, h.2.1, h.2.2, h_sum]
  have h_prod2 : sin x2 * sin y2 * sin z2 < 1 / 8 := by
    have : sin x2 * sin y2 * sin z2 ≤ (sin ((x2 + y2 + z2) / 3)) ^ 3 := sorry
    have : (sin ((x2 + y2 + z2) / 3)) ^ 3 < (sin (π / 6)) ^ 3 := sorry
    linarith [sin_pi_six]

  linarith [h_sin_prod, h_prod1, h_prod2]

end Imo1991P5

