import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨h1, h2, h3⟩ := h
  have hP' : P ∉ ({A, B, C} : Set (EuclideanSpace ℝ (Fin 2))) := fun hm =>
    (interior_subset hP).2 (by simpa [Set.subset_def, affineIndependent_iff_not_collinear] using hm)
  have hPA : dist P A ≠ 0 := by simpa using hP'
  have hPB : dist P B ≠ 0 := by simpa using hP'
  have hPC : dist P C ≠ 0 := by simpa using hP'
  let α₁ := ∠ P A B; let α₂ := ∠ P A C; let β₁ := ∠ P B C; let β₂ := ∠ P B A; let γ₁ := ∠ P C A; let γ₂ := ∠ P C B
  have hsin : sin α₁ * sin β₁ * sin γ₁ = sin β₂ * sin γ₂ * sin α₂ := by
    field_simp [hPA, hPB, hPC, ← dist_mul_sin_angle_eq_dist_mul_sin_angle A B P,
                ← dist_mul_sin_angle_eq_dist_mul_sin_angle B C P,
                ← dist_mul_sin_angle_eq_dist_mul_sin_angle C A P]; ring
  have hsum : (α₁ + α₂) + (β₁ + β₂) + (γ₁ + γ₂) = π := by
    have m := mem_angle_interior_of_mem_interior hP
    rw [← angle_add_angle_eq_angle B A C P (m 0 1 2), ← angle_add_angle_eq_angle C B A P (m 1 2 0),
        ← angle_add_angle_eq_angle A C B P (m 2 0 1), hABC.angle_sum]
    simp [α₁, α₂, β₁, β₂, γ₁, γ₂, angle_comm]
  have hα₁ : α₁ < 5 * π / 6 := by
    linarith [angle_pos_of_mem_interior hP 1 2 0, angle_pos_of_mem_interior hP 2 0 1, hsum]
  have hβ₁ : β₁ < 5 * π / 6 := by
    linarith [angle_pos_of_mem_interior hP 0 1 2, angle_pos_of_mem_interior hP 2 0 1, hsum]
  have hγ₁ : γ₁ < 5 * π / 6 := by
    linarith [angle_pos_of_mem_interior hP 0 1 2, angle_pos_of_mem_interior hP 1 2 0, hsum]
  have hsin_large : 1 / 8 < sin α₁ * sin β₁ * sin γ₁ := by
    have p1 : 1 / 2 < sin α₁ := by simpa using sin_lt_sin_of_lt_of_lt (by linarith) h1 hα₁
    have p2 : 1 / 2 < sin β₁ := by simpa using sin_lt_sin_of_lt_of_lt (by linarith) h2 hβ₁
    have p3 : 1 / 2 < sin γ₁ := by simpa using sin_lt_sin_of_lt_of_lt (by linarith) h3 hγ₁
    linarith [mul_pos p1 (mul_pos p2 p3)]
  have hsum2 : α₂ + β₂ + γ₂ < π / 2 := by linarith
  have hsin_small : sin β₂ * sin γ₂ * sin α₂ < 1 / 8 := by
    have pos2 : 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := ⟨angle_pos_of_mem_interior hP 0 2 1, angle_pos_of_mem_interior hP 1 0 2, angle_pos_of_mem_interior hP 2 1 0⟩
    have : sin α₂ * sin β₂ * sin γ₂ ≤ (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 :=
      sin_mul_sin_mul_sin_le_sin_cube_pos_sum_div_three pos2.1 pos2.2 pos2.3 (by linarith)
    refine this.trans_lt (pow_lt_pow_left (sin_lt_sin_of_lt_of_lt (by linarith) (by linarith) (by linarith)) (by linarith) (by linarith))
  linarith
