import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨hA, hB, hC⟩
  let α1 := ∠ P A B
  let β1 := ∠ P B C
  let γ1 := ∠ P C A
  let α2 := ∠ P A C
  let β2 := ∠ P B A
  let γ2 := ∠ P C B
  have h_pos : 0 < α1 ∧ 0 < β1 ∧ 0 < γ1 ∧ 0 < α2 ∧ 0 < β2 ∧ 0 < γ2 := sorry
  have h_sum : α1 + α2 + β1 + β2 + γ1 + γ2 = π := sorry
  have h_prod : sin α1 * sin β1 * sin γ1 = sin α2 * sin β2 * sin γ2 := sorry
  have h1 : sin α1 * sin β1 * sin γ1 > 1 / 8 := by
    have h_α1 : α1 < 2 * π / 3 := by linarith [h_sum, h_pos]
    have h_β1 : β1 < 2 * π / 3 := by linarith [h_sum, h_pos]
    have h_γ1 : γ1 < 2 * π / 3 := by linarith [h_sum, h_pos]
    have s1 : sin α1 > 1 / 2 := sin_gt_half_of_mem_Ioo (by linarith) (by linarith)
    have s2 : sin β1 > 1 / 2 := sin_gt_half_of_mem_Ioo (by linarith) (by linarith)
    have s3 : sin γ1 > 1 / 2 := sin_gt_half_of_mem_Ioo (by linarith) (by linarith)
    nlinarith
  have h2 : sin α2 * sin β2 * sin γ2 < 1 / 8 := by
    have h_sum2 : α2 + β2 + γ2 < π / 2 := by linarith [h_sum, hA, hB, hC]
    have h_pos2 : 0 < α2 ∧ 0 < β2 ∧ 0 < γ2 := by linarith [h_pos]
    have : sin α2 * sin β2 * sin γ2 ≤ (sin ((α2 + β2 + γ2) / 3)) ^ 3 := sorry
    have : (sin ((α2 + β2 + γ2) / 3)) ^ 3 < (sin (π / 6)) ^ 3 := by
      apply pow_lt_pow_left
      · apply sin_lt_sin_of_lt_of_le <;> linarith
      · apply sin_nonneg; linarith
      · exact zero_lt_three
    exact linarith.lt_of_le_of_lt (by assumption) (by simp; norm_num)
  exact linarith.not_lt h_prod (by linarith)

end Imo1991P5

