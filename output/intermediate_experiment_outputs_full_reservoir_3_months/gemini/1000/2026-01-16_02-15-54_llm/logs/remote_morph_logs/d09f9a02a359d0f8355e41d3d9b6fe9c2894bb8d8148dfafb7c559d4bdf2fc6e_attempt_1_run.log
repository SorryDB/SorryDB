import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨hA, hB, hC⟩
  let α₁ := ∠ P A B; let α₂ := ∠ P A C
  let β₁ := ∠ P B C; let β₂ := ∠ P B A
  let γ₁ := ∠ P C A; let γ₂ := ∠ P C B
  have h_int : P ∉ convexHull ℝ {A, B} ∧ P ∉ convexHull ℝ {B, C} ∧ P ∉ convexHull ℝ {C, A} := by
    have : interior (convexHull ℝ {A, B, C}) ∩ (convexHull ℝ {A, B} ∪ convexHull ℝ {B, C} ∪ convexHull ℝ {C, A}) = ∅ := by
      rw [convexHull_insert_pair]
      simp [interior, frontier]
      sorry
    exact sorry
  have h_pos : 0 < dist P A ∧ 0 < dist P B ∧ 0 < dist P C := ⟨sorry, sorry, sorry⟩
  have h_sine_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have h1 : sin α₁ / dist P B = sin β₂ / dist P A := sorry
    have h2 : sin β₁ / dist P C = sin γ₂ / dist P B := sorry
    have h3 : sin γ₁ / dist P A = sin α₂ / dist P C := sorry
    field_simp [h_pos.1, h_pos.2.1, h_pos.2.2] at h1 h2 h3
    linear_combination h1 * sin β₁ * sin γ₁ + h2 * dist P A * sin β₂ * sin γ₁ + h3 * dist P A * dist P B * sin β₂ * sin γ₂ / dist P C
    sorry
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := sorry
  have h_α₁β₁γ₁ : α₁ + β₁ + γ₁ > π / 2 := by linarith
  have h_α₂β₂γ₂ : α₂ + β₂ + γ₂ < π / 2 := by linarith
  have h_p1 : sin α₁ * sin β₁ * sin γ₁ > 1 / 8 := by
    have : α₁ < π ∧ β₁ < π ∧ γ₁ < π := ⟨sorry, sorry, sorry⟩
    have : α₁ < 2 * π / 3 ∧ β₁ < 2 * π / 3 ∧ γ₁ < 2 * π / 3 := ⟨by linarith, by linarith, by linarith⟩
    have : sin α₁ > 1 / 2 ∧ sin β₁ > 1 / 2 ∧ sin γ₁ > 1 / 2 := sorry
    nlinarith
  have h_p2 : sin α₂ * sin β₂ * sin γ₂ < 1 / 8 := by
    have : 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := ⟨sorry, sorry, sorry⟩
    have : sin α₂ * sin β₂ * sin γ₂ ≤ (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 := sorry
    have : (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 < (sin (π / 6)) ^ 3 := sorry
    sorry
  exact linarith [h_sine_ceva, h_p1, h_p2]
```
