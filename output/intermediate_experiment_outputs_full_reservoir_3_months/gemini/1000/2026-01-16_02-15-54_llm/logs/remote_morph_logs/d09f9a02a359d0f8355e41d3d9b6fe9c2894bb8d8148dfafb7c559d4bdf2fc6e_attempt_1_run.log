import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  have hP_int : P ∈ triangle_interior A B C := by
    rwa [triangle_interior_iff_interior_convexHull_insert_insert]
  have hPA : P ≠ A := hP_int.ne_v0; have hPB : P ≠ B := hP_int.ne_v1; have hPC : P ≠ C := hP_int.ne_v2
  have hAB : A ≠ B := hABC.ne 0 1 (by decide); have hBC : B ≠ C := hABC.ne 1 2 (by decide); have hCA : C ≠ A := hABC.ne 2 0 (by decide)
  have h_prod : sin (∠ P A B) * sin (∠ P B C) * sin (∠ P C A) = sin (∠ P B A) * sin (∠ P C B) * sin (∠ P A C) := by
    calc sin (∠ P A B) * sin (∠ P B C) * sin (∠ P C A)
      _ = (dist P (line ℝ A B) / dist P A) * (dist P (line ℝ B C) / dist P B) * (dist P (line ℝ C A) / dist P C) := by
        rw [dist_p_line_eq_dist_p_a_sin_angle_p_a_b P A B hAB, dist_p_line_eq_dist_p_a_sin_angle_p_a_b P B C hBC, dist_p_line_eq_dist_p_a_sin_angle_p_a_b P C A hCA]
        field_simp; ring
      _ = (dist P (line ℝ A B) / dist P B) * (dist P (line ℝ B C) / dist P C) * (dist P (line ℝ C A) / dist P A) := by field_simp; ring
      _ = sin (∠ P B A) * sin (∠ P C B) * sin (∠ P A C) := by
        rw [dist_p_line_eq_dist_p_a_sin_angle_p_a_b P B A hAB, dist_p_line_eq_dist_p_a_sin_angle_p_a_b P C B hBC, dist_p_line_eq_dist_p_a_sin_angle_p_a_b P A C hCA]
        field_simp; ring
  have h_sum1 : ∠ P A B + ∠ P B C + ∠ P C A > π / 2 := by linarith [h.1, h.2.1, h.2.2]
  have h_sum2 : ∠ P B A + ∠ P C B + ∠ P A C = π - (∠ P A B + ∠ P B C + ∠ P C A) := by
    rw [← angle_sum_triangle A B C, angle_add_angle_eq_angle_of_point_in_interior hP_int.angle_0_interior,
      angle_add_angle_eq_angle_of_point_in_interior hP_int.angle_1_interior, angle_add_angle_eq_angle_of_point_in_interior hP_int.angle_2_interior]
    simp [angle_comm]; ring
  have h_sum3 : ∠ P B A + ∠ P C B + ∠ P A C < π / 2 := by linarith [h_sum1, h_sum2]
  have h_sin1 : sin (∠ P A B) * sin (∠ P B C) * sin (∠ P C A) > 1 / 8 := by
    have h1 : ∠ P A B < 2 * π / 3 := by linarith [h.2.1, h.2.2, h_sum2, angle_nonneg P B A, angle_nonneg P C B, angle_nonneg P A C]
    have h2 : ∠ P B C < 2 * π / 3 := by linarith [h.1, h.2.2, h_sum2, angle_nonneg P B A, angle_nonneg P C B, angle_nonneg P A C]
    have h3 : ∠ P C A < 2 * π / 3 := by linarith [h.1, h.2.1, h_sum2, angle_nonneg P B A, angle_nonneg P C B, angle_nonneg P A C]
    have s1 : sin (∠ P A B) > 1 / 2 := by rw [← sin_pi_six]; exact sin_lt_sin_of_lt_of_le (by linarith) h.1 (by linarith)
    have s2 : sin (∠ P B C) > 1 / 2 := by rw [← sin_pi_six]; exact sin_lt_sin_of_lt_of_le (by linarith) h.2.1 (by linarith)
    have s3 : sin (∠ P C A) > 1 / 2 := by rw [← sin_pi_six]; exact sin_lt_sin_of_lt_of_le (by linarith) h.2.2 (by linarith)
    nlinarith
  have h_sin2 : sin (∠ P B A) * sin (∠ P C B) * sin (∠ P A C) < 1 / 8 := by
    let x := ∠ P B A; let y := ∠ P C B; let z := ∠ P A C
    have h_pos : 0 < x ∧ 0 < y ∧ 0 < z := ⟨angle_pos_of_point_in_interior hP_int.angle_1_interior, angle_pos_of_point_in_interior hP_int.angle_2_interior, angle_pos_of_point_in_interior hP_int.angle_0_interior⟩
    have h_sin_sum : (sin x + sin y + sin z) / 3 ≤ sin ((x + y + z) / 3) := concaveOn_sin_Icc.le_sin_average (by linarith [h_pos.1]) (by linarith [h_sum3]) (by linarith [h_pos.2]) (by linarith [h_sum3]) (by linarith [h_pos.3]) (by linarith [h_sum3])
    have h_am_gm : (sin x * sin y * sin z) ^ ((1:ℝ)/3) ≤ (sin x + sin y + sin z) / 3 := Real.geom_mean_le_arith_mean3_of_nonneg (sin_nonneg_of_angle x) (sin_nonneg_of_angle y) (sin_nonneg_of_angle z)
    have h_val : sin ((x + y + z) / 3) < 1 / 2 := by rw [← sin_pi_six]; exact sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    have h_final : (sin x * sin y * sin z) ^ ((1:ℝ)/3) < 1 / 2 := h_am_gm.trans_lt (h_sin_sum.trans_lt h_val)
    exact (Real.rpow_lt_rpow_iff (by nlinarith) (by linarith) (by linarith)).mp (by rw [Real.rpow_three]; nlinarith)
  linarith
```
