    rw [← angle_angle_plus_angle_of_interior hABC hP_int, ← angle_angle_plus_angle_of_interior hABC hP_int,
      ← angle_angle_plus_angle_of_interior hABC hP_int, angle_sum_triangle A B C hABC]
    all_goals decide
  have h_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have h1 : dist A P * sin α₁ = dist B P * sin β₂ := by
      rw [mul_comm, ← dist_mul_sin_angle_left_right A B P, angle_comm]
    have h2 : dist B P * sin β₁ = dist C P * sin γ₂ := by
