import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  set α₁ := ∠ P A B with hα₁
  set β₁ := ∠ P B C with hβ₁
  set γ₁ := ∠ P C A with hγ₁
  set α₂ := ∠ P A C with hα₂
  set β₂ := ∠ P B A with hβ₂
  set γ₂ := ∠ P C B with hγ₂
  by_contra! h
  have h_pos : 0 < α₁ ∧ 0 < α₂ ∧ 0 < β₁ ∧ 0 < β₂ ∧ 0 < γ₁ ∧ 0 < γ₂ := by
    obtain ⟨w, hw1, hw2, hw3⟩ := (convexHull_three_points_iff hABC).1 (interior_subset_convexHull hP)
    have hp_int := (interior_convexHull_three_points_iff hABC).1 hP
    have h_noncollinear_PAB : ![(P : EuclideanSpace ℝ (Fin 2)), A, B].AffineIndependent := sorry
    have h_noncollinear_PBC : ![(P : EuclideanSpace ℝ (Fin 2)), B, C].AffineIndependent := sorry
    have h_noncollinear_PCA : ![(P : EuclideanSpace ℝ (Fin 2)), C, A].AffineIndependent := sorry
    repeat' constructor <;> apply angle_pos_of_affineIndependent <;> assumption
  have h_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have s1 := dist_sin_angle_eq_dist_sin_angle P A B
    have s2 := dist_sin_angle_eq_dist_sin_angle P B C
    have s3 := dist_sin_angle_eq_dist_sin_angle P C A
    rw [hα₁, hβ₂, hβ₁, hγ₂, hγ₁, hα₂] at s1 s2 s3
    replace s1 : sin α₁ = (dist P B / dist P A) * sin β₂ := by
      rw [mul_comm] at s1; rw [s1, mul_assoc, mul_comm (dist P B), ← mul_assoc]; field_simp; ring
    replace s2 : sin β₁ = (dist P C / dist P B) * sin γ₂ := by
      rw [mul_comm] at s2; rw [s2, mul_assoc, mul_comm (dist P C), ← mul_assoc]; field_simp; ring
    replace s3 : sin γ₁ = (dist P A / dist P C) * sin α₂ := by
      rw [mul_comm] at s3; rw [s3, mul_assoc, mul_comm (dist P A), ← mul_assoc]; field_simp; ring
    rw [s1, s2, s3]
    field_simp [dist_pos.2 (abs_pos.1 (sorry : dist P A ≠ 0)), dist_pos.2 (abs_pos.1 (sorry : dist P B ≠ 0)), dist_pos.2 (abs_pos.1 (sorry : dist P C ≠ 0))]
    ring
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := by
    have h_ang_sum := angle_A_B_C_eq_angle_A_B_P_add_angle_P_B_C
    have h_abc_sum := angle_sum_triangle A B C hABC
    have h_intA : P ∈ (∠ B A C).interior := sorry
    have h_intB : P ∈ (∠ C B A).interior := sorry
    have h_intC : P ∈ (∠ A C B).interior := sorry
    rw [angle_add_angle_eq_angle_of_point_in_angle_interior h_intA,
        angle_add_angle_eq_angle_of_point_in_angle_interior h_intB,
        angle_add_angle_eq_angle_of_point_in_angle_interior h_intC] at h_abc_sum
    rw [← h_abc_sum]
    simp [hα₁, hα₂, hβ₁, hβ₂, hγ₁, hγ₂]
    ring
  have h_α₁β₁γ₁_sum : α₁ + β₁ + γ₁ < π := by linarith [h_pos.2.1, h_pos.2.2.2, h_pos.2.2.2]
  have h_sin_α₁β₁γ₁ : sin α₁ * sin β₁ * sin γ₁ > 1/8 := by
    have h_α₁_range : π/6 < α₁ ∧ α₁ < 2*π/3 := ⟨h.1, by linarith [h.2.1, h.2.2, h_α₁β₁γ₁_sum]⟩
    have h_β₁_range : π/6 < β₁ ∧ β₁ < 2*π/3 := ⟨h.2.1, by linarith [h.1, h.2.2, h_α₁β₁γ₁_sum]⟩
    have h_γ₁_range : π/6 < γ₁ ∧ γ₁ < 2*π/3 := ⟨h.2.2, by linarith [h.1, h.2.1, h_α₁β₁γ₁_sum]⟩
    have sα₁ : sin α₁ > 1/2 := by
      rw [← sin_pi_div_six]; apply sin_lt_sin_of_lt_of_le <;> linarith [h_α₁_range.1, h_α₁_range.2]
    have sβ₁ : sin β₁ > 1/2 := by
      rw [← sin_pi_div_six]; apply sin_lt_sin_of_lt_of_le <;> linarith [h_β₁_range.1, h_β₁_range.2]
    have sγ₁ : sin γ₁ > 1/2 := by
      rw [← sin_pi_div_six]; apply sin_lt_sin_of_lt_of_le <;> linarith [h_γ₁_range.1, h_γ₁_range.2]
    nlinarith
  have h_α₂β₂γ₂_sum : α₂ + β₂ + γ₂ < π/2 := by linarith [h.1, h.2.1, h.2.2]
  have h_sin_α₂β₂γ₂ : sin α₂ * sin β₂ * sin γ₂ < 1/8 := by
    have h_amgm : (sin α₂ * sin β₂ * sin γ₂) ^ (1/3 : ℝ) ≤ (sin α₂ + sin β₂ + sin γ₂) / 3 := by
      apply geom_mean_le_arith_mean3_weighted (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
      repeat' apply sin_nonneg_of_nonneg_of_le_pi; all_goals linarith [h_pos.2.1, h_pos.2.2.1, h_pos.2.2.2, h_α₂β₂γ₂_sum]
    have h_jensen : (sin α₂ + sin β₂ + sin γ₂) / 3 ≤ sin ((α₂ + β₂ + γ₂) / 3) := by
      apply ConcaveOn.le_map_sum Real.concaveOn_sin (by norm_num)
      repeat' (intro; simp; linarith [h_pos.2.1, h_pos.2.2.1, h_pos.2.2.2, h_α₂β₂γ₂_sum])
    have h_max : sin ((α₂ + β₂ + γ₂) / 3) < 1/2 := by
      rw [← sin_pi_div_six]; apply sin_lt_sin_of_lt_of_le <;> linarith [h_α₂β₂γ₂_sum]
    have h_prod_lt : (sin α₂ * sin β₂ * sin γ₂) ^ (1/3 : ℝ) < 1/2 := by linarith
    rwa [← Real.rpow_lt_rpow_iff (by apply mul_nonneg; repeat' apply sin_nonneg_of_nonneg_of_le_pi; all_goals linarith [h_pos.2.1, h_pos.2.2.1, h_pos.2.2.2, h_α₂β₂γ₂_sum]) (by norm_num) (by norm_num : 0 < (3 : ℝ))] at h_prod_lt
    norm_num
  linarith

```
