import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let α₁ := ∠ P A B; let β₁ := ∠ P B C; let γ₁ := ∠ P C A
  let α₂ := ∠ P A C; let β₂ := ∠ P B A; let γ₂ := ∠ P C B
  have h_pos : 0 < α₁ ∧ 0 < β₁ ∧ 0 < γ₁ ∧ 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := by
    have hP' : P ∉ convexHull ℝ {A, B} ∧ P ∉ convexHull ℝ {B, C} ∧ P ∉ convexHull ℝ {C, A} := by
      refine ⟨fun h => ?_, fun h => ?_, fun h => ?_⟩
      all_goals {
        have := interior_convexHull_subset_convexHull _ _ hP
        have := hABC.mem_convexHull_iff.1 (interior_convexHull_subset_convexHull _ _ hP)
        have h_face := (convexHull_subset_convexHull _ (by simp : {A, B} ⊆ {A, B, C})) h
        exact (interior_subset (convexHull ℝ {A, B, C})) hP (h_face)
      }
      all_goals {
        have := hABC.affineSpan_not_mem_interior hP
        exact this (affineSpan_mono ℝ (by simp : {A, B} ⊆ {A, B, C}) (affineSpan_mono ℝ (by simp : {A, B} ⊆ {A, B}) (subset_affineSpan ℝ _ h)))
      }
      -- Simplify: point P is interior, so angles are strictly positive.
      sorry
  have h_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have hPA : dist P A * sin α₁ = dist P B * sin β₂ := by
      rw [mul_comm, ← dist_sin_angle_eq_dist_sin_angle P A B]
    have hPB : dist P B * sin β₁ = dist P C * sin γ₂ := by
      rw [mul_comm, ← dist_sin_angle_eq_dist_sin_angle P B C]
    have hPC : dist P C * sin γ₁ = dist P A * sin α₂ := by
      rw [mul_comm, ← dist_sin_angle_eq_dist_sin_angle P C A]
    replace hPA := (congr_arg (· * (dist P B * sin β₁ * (dist P C * sin γ₁))) hPA)
    simp only [hPB, hPC] at hPA
    have hdist : dist P A ≠ 0 ∧ dist P B ≠ 0 ∧ dist P C ≠ 0 := by
      simp [dist_pos, (interior_subset hP).ne_points hABC]
    field_simp [hdist.1, hdist.2.1, hdist.2.2] at hPA
    linear_combination hPA
  have h_gt : sin α₁ * sin β₁ * sin γ₁ > 1 / 8 := by
    have h_limit : ∀ x ∈ {α₁, β₁, γ₁}, π / 6 < x ∧ x < 5 * π / 6 := by
      intro x hx
      obtain rfl | rfl | rfl := hx
      all_goals {
        refine ⟨h.1, ?_⟩ <|> refine ⟨h.2.1, ?_⟩ <|> refine ⟨h.2.2, ?_⟩
        have h_sum := angle_sum_triangle_of_affineIndependent hABC
        have h_add := angle_add_angle_right A B C P hP
        linarith [angle_pos P A B, angle_pos P A C, angle_pos P B C, angle_pos P B A, angle_pos P C A, angle_pos P C B]
      }
      sorry
    have : ∀ x ∈ {α₁, β₁, γ₁}, sin x > 1 / 2 := fun x hx => by
      have := h_limit x hx
      exact Real.sin_pos_of_mem_Ioo (by linarith [pi_pos]) (by linarith [pi_pos]) (by sorry)
    nlinarith
  have h_sum_all : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := by
    rw [← angle_sum_triangle_of_affineIndependent hABC]
    rw [angle_add_angle_right B A C P hP, angle_add_angle_right C B A P hP, angle_add_angle_right A C B P hP]
    simp [α₁, α₂, β₁, β₂, γ₁, γ₂]; abel
  have h_lt : sin α₂ * sin β₂ * sin γ₂ < 1 / 8 := by
    have h_sum2 : α₂ + β₂ + γ₂ < π / 2 := by linarith [h.1, h.2.1, h.2.2]
    have h_pos2 : 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := sorry
    -- sin x sin y sin z is maximized at x=y=z=pi/6
    sorry
  linarith
