/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let α1 := ∠ P A B; let α2 := ∠ P A C
  let β1 := ∠ P B C; let β2 := ∠ P B A
  let γ1 := ∠ P C A; let γ2 := ∠ P C B
  have hpos : 0 < dist P A ∧ 0 < dist P B ∧ 0 < dist P C := by
    obtain ⟨-, hA, hB, hC⟩ := (convex_hull_interior_subset_convex_hull hP).ne_of_mem_convexHull (by simp)
    simp_all [dist_pos]
  have hceva : sin α1 * sin β1 * sin γ1 = sin α2 * sin β2 * sin γ2 := by
    field_simp [dist_sin_angle_at_p_eq_dist_sin_angle_at_q P A B,
               dist_sin_angle_at_p_eq_dist_sin_angle_at_q P B C,
               dist_sin_angle_at_p_eq_dist_sin_angle_at_q P C A]
    ring
  have hi : P ∈ interior (angle_interior A B C) ∧
            P ∈ interior (angle_interior B C A) ∧
            P ∈ interior (angle_interior C A B) := by
    obtain ⟨w, hw0, hws, hwP⟩ := (mem_interior_convexHull_iff_exists_pos_barycentric hABC).1 hP
    exact ⟨hABC.interior_angle_interior_of_mem_interior_convexHull hP 0 1 2,
           hABC.interior_angle_interior_of_mem_interior_convexHull hP 1 2 0,
           hABC.interior_angle_interior_of_mem_interior_convexHull hP 2 0 1⟩
  have sum_angles : α1 + α2 + β1 + β2 + γ1 + γ2 = π := by
    rw [hi.1.angle_separation, hi.2.1.angle_separation, hi.2.2.angle_separation]
    exact hABC.angle_sum
  have hα1 : α1 ∈ Set.Ioo (π / 6) (2 * π / 3) :=
    ⟨hPAB, by linarith [angle_pos P A B, angle_pos P B C, angle_pos P C A, angle_pos P B A, angle_pos P C B, angle_pos P A C]⟩
  have hβ1 : β1 ∈ Set.Ioo (π / 6) (2 * π / 3) :=
    ⟨hPBC, by linarith [angle_pos P A B, angle_pos P B C, angle_pos P C A, angle_pos P B A, angle_pos P C B, angle_pos P A C]⟩
  have hγ1 : γ1 ∈ Set.Ioo (π / 6) (2 * π / 3) :=
    ⟨hPCA, by linarith [angle_pos P A B, angle_pos P B C, angle_pos P C A, angle_pos P B A, angle_pos P C B, angle_pos P A C]⟩
  have s1 : 1 / 8 < sin α1 * sin β1 * sin γ1 := by
    have lb (x : ℝ) (hx : x ∈ Set.Ioo (π / 6) (2 * π / 3)) : 1 / 2 < sin x :=
      if hx' : x ≤ π / 2 then by
        have := sin_monotone (Set.Icc_subset_Icc (by linarith) (by linarith))
        convert (this (Set.left_mem_Icc.2 (by linarith)) ⟨hx.1.le, hx'⟩ hx.1.le)
        norm_num
      else by
        have := sin_antitone (Set.Icc_subset_Icc (by linarith) (by linarith))
        convert (this ⟨hx', hx.2.le⟩ (Set.right_mem_Icc.2 (by linarith)) hx.2.le)
        simp [sin_two_pi_div_three]
        norm_num; exact (sqrt_three_div_two_gt_one_half).le
    nlinarith [lb α1 hα1, lb β1 hβ1, lb γ1 hγ1]
  have s2 : sin α2 * sin β2 * sin γ2 < 1 / 8 := by
    have hsum : α2 + β2 + γ2 < π / 2 := by linarith
    have hpos' (x : ℝ) (hx : x > 0) : sin x > 0 ∨ ¬ x < π := by
      by_cases h : x < π; left; exact sin_pos_of_mem_Ioo ⟨hx, h⟩; right; exact h
    have h2 : 0 < α2 ∧ 0 < β2 ∧ 0 < γ2 := ⟨angle_pos P A C, angle_pos P B A, angle_pos P C B⟩
    have h3 : α2 < π ∧ β2 < π ∧ γ2 < π := by constructor <;> linarith
    have : (sin α2 * sin β2 * sin γ2) ^ (1/3 : ℝ) ≤ sin ((α2 + β2 + γ2) / 3) :=
      strict_concave_on_sin_Icc.concaveOn.pointwise_weight_to_geom_mean
        (by simp) (by simp [h2, h3]) (by simp) (by simp) (by simp)
    have : (sin α2 * sin β2 * sin γ2) ^ (1/3 : ℝ) < 1/2 := by
      apply this.trans_lt
      have : (α2 + β2 + γ2) / 3 < π / 6 := by linarith
      rw [← sin_pi_div_six]
      exact sin_monotone (Set.Icc_subset_Icc (by linarith) (by linarith)) (by simp) (by linarith) (by linarith)
    exact (Real.rpow_lt_rpow_iff (by positivity) (by positivity) (by norm_num)).1 (by convert this; norm_num)
