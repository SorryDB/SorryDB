import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  let α₁ := ∠ P A B; let α₂ := ∠ P A C
  let β₁ := ∠ P B C; let β₂ := ∠ P B A
  let γ₁ := ∠ P C A; let γ₂ := ∠ P C B
  have hP_not_A : P ≠ A := (interior_subset hP).1 ∘ (fun h => h ▸ mem_convexHull_vertices _ _)
  have hP_not_B : P ≠ B := (interior_subset hP).1 ∘ (fun h => h ▸ mem_convexHull_vertices _ _)
  have hP_not_C : P ≠ C := (interior_subset hP).1 ∘ (fun h => h ▸ mem_convexHull_vertices _ _)
  have s1 := dist_sin_angle_eq_dist_sin_angle B A P
  have s2 := dist_sin_angle_eq_dist_sin_angle C B P
  have s3 := dist_sin_angle_eq_dist_sin_angle A C P
  simp only [angle_comm P A B, angle_comm P B C, angle_comm P C A] at s1 s2 s3
  have h_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    field_simp [dist_pos.mpr hP_not_A, dist_pos.mpr hP_not_B, dist_pos.mpr hP_not_C] at s1 s2 s3
    rw [← s1, ← s2, ← s3]; ring
  have h_angle_sum : α₁ + β₁ + γ₁ + (α₂ + β₂ + γ₂) = π := by
    have h_int := (mem_interior_convexHull_iff_angle_interior hABC).mp hP
    rw [← angle_add_angle_eq_angle_of_point_in_angle_interior h_int.1,
      ← angle_add_angle_eq_angle_of_point_in_angle_interior h_int.2.1,
      ← angle_add_angle_eq_angle_of_point_in_angle_interior h_int.2.2,
      angle_comm B A P, angle_comm C B P, angle_comm A C P]
    linarith [angle_sum_triangle A B C hABC]
  have h_pos : 0 < α₁ ∧ 0 < β₁ ∧ 0 < γ₁ ∧ 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := by
    repeat constructor
    all_goals apply (mem_interior_convexHull_iff_angle_interior hABC).mp hP |>.1 |> (angle_pos_of_mem_angle_interior ·)
    all_goals apply (mem_interior_convexHull_iff_angle_interior hABC).mp hP |>.2.1 |> (angle_pos_of_mem_angle_interior ·)
    all_goals apply (mem_interior_convexHull_iff_angle_interior hABC).mp hP |>.2.2 |> (angle_pos_of_mem_angle_interior ·)
  by_contra! h
  have h_sin_v : sin α₁ * sin β₁ * sin γ₁ > 1 / 8 := by
    have : ∀ x ∈ Set.Ioo (π / 6) (π - 2 * (π / 6)), sin x > 1 / 2 := fun x hx =>
      sin_gt_sin_of_Ioo_left (pi_pos.mul_refl _) hx.1 (by linarith [hx.2])
    have hα₁ : α₁ ∈ Set.Ioo (π / 6) (2 * π / 3) := ⟨h.1, by linarith [h_angle_sum, h.2, h.3, h_pos]⟩
    have hβ₁ : β₁ ∈ Set.Ioo (π / 6) (2 * π / 3) := ⟨h.2, by linarith [h_angle_sum, h.1, h.3, h_pos]⟩
    have hγ₁ : γ₁ ∈ Set.Ioo (π / 6) (2 * π / 3) := ⟨h.3, by linarith [h_angle_sum, h.1, h.2, h_pos]⟩
    replace hα₁ : sin α₁ > 1 / 2 := this α₁ hα₁; replace hβ₁ : sin β₁ > 1 / 2 := this β₁ hβ₁
    replace hγ₁ : sin γ₁ > 1 / 2 := this γ₁ hγ₁
    nlinarith
  have h_sin_w : sin α₂ * sin β₂ * sin γ₂ < 1 / 8 := by
    have h_sum_w : α₂ + β₂ + γ₂ < π / 2 := by linarith [h_angle_sum, h.1, h.2, h.3]
    have h_log_sin : ConcaveOn ℝ (Set.Icc 0 π) (log ∘ sin) := log_sin_concave
    have h_jensen := h_log_sin.le_map_sum (fun _ _ => 1/3) (by norm_num) (by norm_num)
      (fun i => (match i with | 0 => α₂ | 1 => β₂ | 2 => γ₂)) (by intro i; match i with | 0 => simp [h_pos.2.2.1, h_sum_w]; | 1 => simp [h_pos.2.2.2.1, h_sum_w]; | 2 => simp [h_pos.2.2.2.2, h_sum_w])
    simp only [Fin.sum_univ_three, Function.comp_apply, one_div, inv_mul_eq_div] at h_jensen
    have h_sum_div_3 : (α₂ + β₂ + γ₂) / 3 < π / 6 := by linarith
    have h_rhs : log (sin ((α₂ + β₂ + γ₂) / 3)) < log (sin (π / 6)) :=
      log_lt_log (sin_pos_of_mem_Ioo ⟨by linarith [h_pos], by linarith [h_sum_w]⟩)
      (sin_lt_sin_of_lt_of_le (by linarith [h_pos]) h_sum_div_3 (by norm_num; linarith))
    have h_log_prod : (log (sin α₂) + log (sin β₂) + log (sin γ₂)) / 3 < log (1 / 2) := by
      rw [sin_pi_div_six] at h_rhs; linarith
    rw [← log_mul (sin_pos_of_mem_Ioo ⟨h_pos.2.2.1, by linarith⟩).ne' (sin_pos_of_mem_Ioo ⟨h_pos.2.2.2.1, by linarith⟩).ne',
      ← log_mul (mul_pos _ _).ne' (sin_pos_of_mem_Ioo ⟨h_pos.2.2.2.2, by linarith⟩).ne'] at h_log_prod
    all_goals try { apply sin_pos_of_mem_Ioo; constructor; linarith; linarith }
    rw [exp_lt_exp_iff.symm, exp_log, exp_log] at h_log_prod
    all_goals try { apply mul_pos <;> apply sin_pos_of_mem_Ioo <;> constructor <;> linarith }
    linarith [h_log_prod]
  linarith

