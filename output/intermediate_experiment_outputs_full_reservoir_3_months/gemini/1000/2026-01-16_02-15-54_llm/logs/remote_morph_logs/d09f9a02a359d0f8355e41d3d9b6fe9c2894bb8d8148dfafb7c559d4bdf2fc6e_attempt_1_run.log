import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let α₁ := ∠ P A B; let α₂ := ∠ P A C
  let β₁ := ∠ P B C; let β₂ := ∠ P B A
  let γ₁ := ∠ P C A; let γ₂ := ∠ P C B
  have hP_in_A : P ∈ interior (convexHull ℝ {A, B, C}) := hP
  have hABC_tri : ¬ Collinear ℝ {A, B, C} := by
    rwa [affineIndependent_iff_not_collinear] at hABC
  have hP_not_A : P ≠ A := by
    intro hA; subst hA
    have := interior_convexHull_subset_convexHull ℝ {A, B, C} hP
    have : A ∈ convexHull ℝ {A, B, C} := subset_convexHull ℝ {A, B, C} (by simp)
    exact (interior_subset (s := convexHull ℝ {A, B, C})) hP (by simp)
  have hP_not_B : P ≠ B := by intro hB; subst hB; exact (interior_subset (s := convexHull ℝ {A, B, C})) hP (by simp)
  have hP_not_C : P ≠ C := by intro hC; subst hC; exact (interior_subset (s := convexHull ℝ {A, B, C})) hP (by simp)

  have h_sin_prod : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have s1 : dist P A * sin β₂ = dist P B * sin α₁ := by
      rw [mul_comm]; exact dist_sin_angle_eq_dist_sin_angle P B A
    have s2 : dist P B * sin γ₂ = dist P C * sin β₁ := by
      rw [mul_comm]; exact dist_sin_angle_eq_dist_sin_angle P C B
    have s3 : dist P C * sin α₂ = dist P A * sin γ₁ := by
      rw [mul_comm]; exact dist_sin_angle_eq_dist_sin_angle P A C
    have p1 : (dist P A * sin β₂) * (dist P B * sin γ₂) * (dist P C * sin α₂) =
              (dist P B * sin α₁) * (dist P C * sin β₁) * (dist P A * sin γ₁) := by rw [s1, s2, s3]
    have dPA : dist P A ≠ 0 := dist_ne_zero.mpr hP_not_A
    have dPB : dist P B ≠ 0 := dist_ne_zero.mpr hP_not_B
    have dPC : dist P C ≠ 0 := dist_ne_zero.mpr hP_not_C
    simp_all only [α₁, α₂, β₁, β₂, γ₁, γ₂]
    field_simp at p1; linear_combination p1 / (dist P A * dist P B * dist P C)

  have sum_angles : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := by
    have h_int := (convexHull_interior_eq_weighted_points_interior hABC).1 hP
    rcases h_int with ⟨w, hw0, hw1, rfl⟩
    let A' : EuclideanSpace ℝ (Fin 2) := A; let B' : EuclideanSpace ℝ (Fin 2) := B; let C' : EuclideanSpace ℝ (Fin 2) := C
    have h_angle_A : α₁ + α₂ = ∠ B A C := angle_add_angle_eq_angle_of_pos_weight A B C w hw0 hw1 0
    have h_angle_B : β₁ + β₂ = ∠ C B A := angle_add_angle_eq_angle_of_pos_weight B C A w hw0 hw1 1
    have h_angle_C : γ₁ + γ₂ = ∠ A C B := angle_add_angle_eq_angle_of_pos_weight C A B w hw0 hw1 2
    rw [← h_angle_A, ← h_angle_B, ← h_angle_C, angle_sum_triangle A B C]
  
  have h_alpha_range : α₁ < π ∧ β₁ < π ∧ γ₁ < π := by
    constructor; exact (sum_angles ▸ (by nlinarith [angle_nonneg P A C, angle_nonneg P B C, angle_nonneg P B A, angle_nonneg P C A, angle_nonneg P C B] : α₁ ≤ π));
    constructor; exact (sum_angles ▸ (by nlinarith [angle_nonneg P A B, angle_nonneg P A C, angle_nonneg P B A, angle_nonneg P C A, angle_nonneg P C B] : β₁ ≤ π));
    exact (sum_angles ▸ (by nlinarith [angle_nonneg P A B, angle_nonneg P A C, angle_nonneg P B C, angle_nonneg P B A, angle_nonneg P C B] : γ₁ ≤ π))

  have h_sin_α₁ : sin α₁ > 1/2 := sin_gt_half_of_pi_six_lt_angle_lt_five_pi_six h.1 (by nlinarith [h.2.1, h.2.2, sum_angles, angle_nonneg α₂, angle_nonneg β₂, angle_nonneg γ₂])
  have h_sin_β₁ : sin β₁ > 1/2 := sin_gt_half_of_pi_six_lt_angle_lt_five_pi_six h.2.1 (by nlinarith [h.1, h.2.2, sum_angles, angle_nonneg α₂, angle_nonneg β₂, angle_nonneg γ₂])
  have h_sin_γ₁ : sin γ₁ > 1/2 := sin_gt_half_of_pi_six_lt_angle_lt_five_pi_six h.2.2 (by nlinarith [h.1, h.2.1, sum_angles, angle_nonneg α₂, angle_nonneg β₂, angle_nonneg γ₂])
  
  have h_prod_gt : sin α₁ * sin β₁ * sin γ₁ > 1/8 := by nlinarith
  have h_sum_α₂ : α₂ + β₂ + γ₂ < π / 2 := by nlinarith [h.1, h.2.1, h.2.2, sum_angles]
  have h_prod_le : sin α₂ * sin β₂ * sin γ₂ < 1/8 := by
    have h_sin_sum : sin α₂ * sin β₂ * sin γ₂ ≤ (sin ((α₂ + β₂ + γ₂)/3))^3 := by
      apply sin_prod_le_sin_cube_average (by nlinarith [angle_nonneg α₂, angle_nonneg β₂, angle_nonneg γ₂, h_sum_α₂]) (by nlinarith [angle_nonneg α₂, angle_nonneg β₂, angle_nonneg γ₂, h_sum_α₂]) (by nlinarith [angle_nonneg α₂, angle_nonneg β₂, angle_nonneg γ₂, h_sum_α₂])
      nlinarith [h_sum_α₂]
    have h_sin_avg : sin ((α₂ + β₂ + γ₂)/3) < 1/2 := by
      rw [← sin_pi_six]; apply sin_lt_sin (by nlinarith [angle_nonneg α₂, angle_nonneg β₂, angle_nonneg γ₂]) (by nlinarith [h_sum_α₂]); nlinarith [h_sum_α₂]
    nlinarith [pow_three (sin ((α₂ + β₂ + γ₂)/3))]
  
  nlinarith

```
