import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  let α₁ := ∠ P A B
  let β₁ := ∠ P B C
  let γ₁ := ∠ P C A
  let α₂ := ∠ P A C
  let β₂ := ∠ P B A
  let γ₂ := ∠ P C B
  by_contra! h
  have hα₁ : π / 6 < α₁ := h.1
  have hβ₁ : π / 6 < β₁ := h.2
  have hγ₁ : π / 6 < γ₁ := h.3
  have hP_int : P ∈ interior (convexHull ℝ {A, B, C}) := hP
  have h_pos : 0 < α₁ ∧ 0 < β₁ ∧ 0 < γ₁ ∧ 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := by
    refine ⟨angle_pos_of_not_collinear ?_, angle_pos_of_not_collinear ?_, angle_pos_of_not_collinear ?_,
            angle_pos_of_not_collinear ?_, angle_pos_of_not_collinear ?_, angle_pos_of_not_collinear ?_⟩
    all_goals apply EuclideanGeometry.not_collinear_of_mem_interior_convexHull_triangle hABC hP_int; decide
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := by
    rw [← angle_angle_plus_angle_of_interior hABC hP_int, ← angle_angle_plus_angle_of_interior hABC hP_int,
      ← angle_angle_plus_angle_of_interior hABC hP_int, angle_sum_triangle A B C hABC]
    all_goals decide
  have h_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have h1 : dist A P * sin α₁ = dist B P * sin β₂ := by
      rw [mul_comm, ← dist_mul_sin_angle_left_right A B P, angle_comm]
    have h2 : dist B P * sin β₁ = dist C P * sin γ₂ := by
      rw [mul_comm, ← dist_mul_sin_angle_left_right B C P, angle_comm]
    have h3 : dist C P * sin γ₁ = dist A P * sin α₂ := by
      rw [mul_comm, ← dist_mul_sin_angle_left_right C A P, angle_comm]
    have h_prod : (dist A P * sin α₁) * (dist B P * sin β₁) * (dist C P * sin γ₁) =
                  (dist B P * sin β₂) * (dist C P * sin γ₂) * (dist A P * sin α₂) := by rw [h1, h2, h3]
    have h_dist_pos : 0 < dist A P ∧ 0 < dist B P ∧ 0 < dist C P := by
      refine ⟨dist_pos.2 (fun heq => ?_), dist_pos.2 (fun heq => ?_), dist_pos.2 (fun heq => ?_)⟩
      all_goals have := EuclideanGeometry.mem_interior_convexHull_triangle_iff_exists_interior_affine_combination hABC hP_int
      all_goals obtain ⟨w, hw1, hw2, hw3⟩ := this; subst heq
      all_goals apply interior_nonempty.1; use P; exact hP_int
    field_simp [h_dist_pos.1.ne', h_dist_pos.2.1.ne', h_dist_pos.2.2.ne'] at h_prod
    rw [h_prod, mul_assoc, mul_comm (sin α₂), ← mul_assoc, mul_comm (sin β₂)]
  have h_sum1 : α₁ + β₁ + γ₁ > π / 2 := by linarith
  have h_sum2 : α₂ + β₂ + γ₂ < π / 2 := by linarith
  have h_prod1 : sin α₁ * sin β₁ * sin γ₁ > 1 / 8 := by
    have h_range (x : ℝ) (hx_gt : π / 6 < x) (hx_lt : x < π - 2 * (π / 6)) : sin x > 1 / 2 := by
      rw [← sin_pi_div_six]; apply sin_lt_sin_of_lt_of_le <;> linarith [pi_pos]
    have h_α₁_lt : α₁ < 2 * π / 3 := by linarith
    have h_β₁_lt : β₁ < 2 * π / 3 := by linarith
    have h_γ₁_lt : γ₁ < 2 * π / 3 := by linarith
    have s1 : sin α₁ > 1/2 := h_range α₁ hα₁ (by linarith)
    have s2 : sin β₁ > 1/2 := h_range β₁ hβ₁ (by linarith)
    have s3 : sin γ₁ > 1/2 := h_range γ₁ hγ₁ (by linarith)
    nlinarith
  have h_prod2 : sin α₂ * sin β₂ * sin γ₂ < 1 / 8 := by
    have h_sin_prod : sin α₂ * sin β₂ * sin γ₂ ≤ (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 := by
      apply log_sin_self_concave.exp_sum_le_combined (by linarith) (by linarith) (by linarith)
      all_goals linarith [pi_pos]
    have h_sin_lt : sin ((α₂ + β₂ + γ₂) / 3) < 1 / 2 := by
      rw [← sin_pi_div_six]; apply sin_lt_sin_of_lt_of_le <;> linarith [pi_pos]
    apply h_sin_prod.trans_lt; nlinarith
  linarith

end Imo1991P5

