import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let x1 := ∠ P A B
  let y1 := ∠ P B C
  let z1 := ∠ P C A
  let x2 := ∠ P A C
  let y2 := ∠ P B A
  let z2 := ∠ P C B
  have h_sum6 : x1 + x2 + y1 + y2 + z1 + z2 = π := by
    have hP_int_A : P ∈ interior (Angle.Angle A B C).area ∪ interior (Angle.Angle A C B).area ∪ interior (Angle.Angle B A C).area := sorry
    sorry
  have h_ceva : sin x1 * sin y1 * sin z1 = sin x2 * sin y2 * sin z2 := sorry
  have h_sum1 : x1 + y1 + z1 > π / 2 := by linarith
  have h_sum2 : x2 + y2 + z2 < π / 2 := by linarith
  have h_sin1 : sin x1 * sin y1 * sin z1 > 1 / 8 := by
    have hx1 : x1 ∈ Set.Ioo (π / 6) (2 * π / 3) := sorry
    have hy1 : y1 ∈ Set.Ioo (π / 6) (2 * π / 3) := sorry
    have hz1 : z1 ∈ Set.Ioo (π / 6) (2 * π / 3) := sorry
    have : ∀ x ∈ Set.Ioo (π / 6) (2 * π / 3), sin x > 1 / 2 := sorry
    nlinarith [this x1 hx1, this y1 hy1, this z1 hz1]
  have h_sin2 : sin x2 * sin y2 * sin z2 < 1 / 8 := by
    have h_pos : x2 > 0 ∧ y2 > 0 ∧ z2 > 0 := sorry
    have : sin x2 * sin y2 * sin z2 ≤ (sin ((x2 + y2 + z2) / 3)) ^ 3 := sorry
    have : (sin ((x2 + y2 + z2) / 3)) ^ 3 < (sin (π / 6)) ^ 3 := sorry
    sorry
  linarith
