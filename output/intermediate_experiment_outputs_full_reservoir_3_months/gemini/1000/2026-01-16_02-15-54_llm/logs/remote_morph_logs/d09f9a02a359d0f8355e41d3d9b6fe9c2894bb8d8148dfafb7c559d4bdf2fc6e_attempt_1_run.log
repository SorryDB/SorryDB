import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let dAB := dist P (AffineSubspace.line ℝ ![A, B])
  let dBC := dist P (AffineSubspace.line ℝ ![B, C])
  let dCA := dist P (AffineSubspace.line ℝ ![C, A])
  have h_pos : 0 < dist P A ∧ 0 < dist P B ∧ 0 < dist P C := by
    repeat' constructor; all_goals apply dist_pos.2; intro h_eq; subst h_eq
    all_goals apply interior_subset (convexHull_subset_convexHull (Set.subset_insert _ _) (by simp)) hP
  have h_d1 : dAB = dist P A * sin (∠ P A B) ∧ dAB = dist P B * sin (∠ P B A) := by
    constructor; exact dist_line_eq_dist_sin_angle P A B; exact dist_line_eq_dist_sin_angle P B A
  have h_d2 : dBC = dist P B * sin (∠ P B C) ∧ dBC = dist P C * sin (∠ P C B) := by
    constructor; exact dist_line_eq_dist_sin_angle P B C; exact dist_line_eq_dist_sin_angle P C B
  have h_d3 : dCA = dist P C * sin (∠ P C A) ∧ dCA = dist P A * sin (∠ P A C) := by
    constructor; exact dist_line_eq_dist_sin_angle P C A; exact dist_line_eq_dist_sin_angle P A C
  have h_sin_pos : sin (∠ P A B) > 1 / 2 ∧ sin (∠ P B C) > 1 / 2 ∧ sin (∠ P C A) > 1 / 2 := by
    repeat' constructor; all_goals apply sin_gt_half_of_pi_six_lt_angle_lt_five_pi_six
    all_goals try exact h.1; try exact h.2; try exact h.3
    all_goals apply angle_lt_pi_of_affineIndependent_interior_convexHull hABC hP
    all_goals repeat' constructor; all_goals simp
  have h_prod : sin (∠ P A B) * sin (∠ P B C) * sin (∠ P C A) = sin (∠ P B A) * sin (∠ P C B) * sin (∠ P A C) := by
    field_simp [h_pos.1, h_pos.2.1, h_pos.2.2, h_d1.1, h_d1.2, h_d2.1, h_d2.2, h_d3.1, h_d3.2]
    calc dist P A * sin (∠ P A B) * (dist P B * sin (∠ P B C)) * (dist P C * sin (∠ P C A))
      _ = dAB * dBC * dCA := by rw [h_d1.1, h_d2.1, h_d3.1]
      _ = (dist P B * sin (∠ P B A)) * (dist P C * sin (∠ P C B)) * (dist P A * sin (∠ P A C)) := by rw [h_d1.2, h_d2.2, h_d3.2]
  have h_sum : (∠ P A B + ∠ P B C + ∠ P C A) + (∠ P B A + ∠ P C B + ∠ P A C) = π := by
    rw [add_assoc, add_left_comm (∠ P B C + ∠ P C A), ← add_assoc, ← add_assoc]
    rw [angle_add_angle_of_split_line A B C P hABC hP, angle_add_angle_of_split_line B C A P hABC hP, angle_add_angle_of_split_line C A B P hABC hP]
    exact angle_sum_eq_pi A B C hABC
  have h_sum' : ∠ P B A + ∠ P C B + ∠ P A C < π / 2 := by linarith [h.1, h.2, h.3, h_sum]
  have h_prod_lt : sin (∠ P B A) * sin (∠ P C B) * sin (∠ P A C) < 1 / 8 := by
    apply sin_prod_le_sin_cube_sum_div_three
    all_goals try linarith [h_sum', angle_nonneg P B A, angle_nonneg P C B, angle_nonneg P A C]
    all_goals apply angle_pos_of_affineIndependent_interior_convexHull hABC hP
    all_goals repeat' constructor; all_goals simp
  linarith [h_prod, h_sin_pos.1, h_sin_pos.2.1, h_sin_pos.2.2]

end Imo1991P5

