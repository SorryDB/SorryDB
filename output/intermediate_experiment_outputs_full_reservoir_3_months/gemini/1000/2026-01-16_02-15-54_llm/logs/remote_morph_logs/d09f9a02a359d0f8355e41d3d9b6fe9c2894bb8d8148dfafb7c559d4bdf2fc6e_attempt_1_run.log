import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let α₁ := ∠ P A B
  let β₁ := ∠ P B C
  let γ₁ := ∠ P C A
  let α₂ := ∠ P A C
  let β₂ := ∠ P B A
  let γ₂ := ∠ P C B
  let d₁ := dist P A
  let d₂ := dist P B
  let d₃ := dist P C
  have h_int : 0 < α₁ ∧ 0 < β₁ ∧ 0 < γ₁ ∧ 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := sorry
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := sorry
  have h_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := sorry
  have h1 : sin α₁ > 1/2 := by
    have : α₁ + β₁ + γ₁ < π := by linarith [h_sum, h_int.4, h_int.5, h_int.6]
    exact sin_gt_half_of_pi_six_lt_lt_pi_half hPAB (by linarith)
  have h2 : sin β₁ > 1/2 := by
    have : α₁ + β₁ + γ₁ < π := by linarith [h_sum, h_int.4, h_int.5, h_int.6]
    exact sin_gt_half_of_pi_six_lt_lt_pi_half hPBC (by linarith)
  have h3 : sin γ₁ > 1/2 := by
    have : α₁ + β₁ + γ₁ < π := by linarith [h_sum, h_int.4, h_int.5, h_int.6]
    exact sin_gt_half_of_pi_six_lt_lt_pi_half hPCA (by linarith)
  have h_prod1 : sin α₁ * sin β₁ * sin γ₁ > 1/8 := by nlinarith
  have h_sum2 : α₂ + β₂ + γ₂ < π / 2 := by linarith
  have h_prod2 : sin α₂ * sin β₂ * sin γ₂ < 1/8 := by
    have : sin α₂ * sin β₂ * sin γ₂ ≤ (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 := sorry
    have : (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 < (sin (π / 6)) ^ 3 := sorry
    norm_num at this; linarith
  linarith
