    have : sin a₁ / sin b₂ = dist P B / dist P A := sin_rule_triangle_PAB hABC hP
    have : sin b₁ / sin c₂ = dist P C / dist P B := sin_rule_triangle_PBC hABC hP
    have : sin c₁ / sin a₂ = dist P A / dist P C := sin_rule_triangle_PCA hABC hP
    field_simp; linarith
  have h1 : a₁ + b₁ + c₁ > π / 2 := by linarith
  have h2 : a₂ + b₂ + c₂ < π / 2 := by linarith
  have h_abc1 : sin a₁ * sin b₁ * sin c₁ > 1 / 8 := by
    have ha : π / 6 < a₁ ∧ a₁ < 2 * π / 3 := ⟨hPAB, by linarith [h_sum, hPAB, hPBC, hPCA, h_pos]⟩
    have hb : π / 6 < b₁ ∧ b₁ < 2 * π / 3 := ⟨hPBC, by linarith [h_sum, hPAB, hPBC, hPCA, h_pos]⟩
    have hc : π / 6 < c₁ ∧ c₁ < 2 * π / 3 := ⟨hPCA, by linarith [h_sum, hPAB, hPBC, hPCA, h_pos]⟩
    have : sin (π / 6) = 1 / 2 := sin_pi_div_six
