import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let α₁ := ∠ P A B; let α₂ := ∠ P A C
  let β₁ := ∠ P B C; let β₂ := ∠ P B A
  let γ₁ := ∠ P C A; let γ₂ := ∠ P C B
  have h_int : P ∈ interior (convexHull ℝ {A, B, C}) := hP
  have h_pos : 0 < α₁ ∧ 0 < β₁ ∧ 0 < γ₁ ∧ 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := sorry
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := sorry
  have h_sine_rule : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := sorry
  have h_α₁β₁γ₁ : α₁ + β₁ + γ₁ > π / 2 := by linarith
  have h_α₂β₂γ₂ : α₂ + β₂ + γ₂ < π / 2 := by linarith
  have h_LHS : sin α₁ * sin β₁ * sin γ₁ > 1 / 8 := by
    have h1 : sin α₁ > 1 / 2 := by
      have : α₁ ∈ Set.Ioo (π / 6) (π - 2 * (π / 6)) := ⟨hPAB, by linarith [h_sum, h_pos]⟩
      exact Real.sin_pos_of_mem_Ioo (by linarith) (by linarith) |> (Real.sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)).mpr hPAB
    have h2 : sin β₁ > 1 / 2 := by
      have : β₁ ∈ Set.Ioo (π / 6) (π - 2 * (π / 6)) := ⟨hPBC, by linarith [h_sum, h_pos]⟩
      exact Real.sin_pos_of_mem_Ioo (by linarith) (by linarith) |> (Real.sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)).mpr hPBC
    have h3 : sin γ₁ > 1 / 2 := by
