    linarith
  have h_abc2 : sin a₂ * sin b₂ * sin c₂ < 1 / 8 := by
    have : sin a₂ * sin b₂ * sin c₂ ≤ (sin ((a₂ + b₂ + c₂) / 3)) ^ 3 := 
      sin_prod_le_sin_cube_sum_div_three (by linarith) (by linarith) (by linarith) (by linarith)
    have : (sin ((a₂ + b₂ + c₂) / 3)) ^ 3 < (1 / 2) ^ 3 := by
