import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let a1 := ∠ P A B; let a2 := ∠ P A C
  let b1 := ∠ P B C; let b2 := ∠ P B A
  let c1 := ∠ P C A; let c2 := ∠ P C B
  have h_pos : 0 < a1 ∧ 0 < a2 ∧ 0 < b1 ∧ 0 < b2 ∧ 0 < c1 ∧ 0 < c2 := by
    refine ⟨angle_pos_of_mem_interior_convexHull hABC hP 0 1 2,
            angle_pos_of_mem_interior_convexHull hABC hP 0 2 1,
            angle_pos_of_mem_interior_convexHull hABC hP 1 2 0,
            angle_pos_of_mem_interior_convexHull hABC hP 1 0 2,
            angle_pos_of_mem_interior_convexHull hABC hP 2 0 1,
            angle_pos_of_mem_interior_convexHull hABC hP 2 1 0⟩
  have h_sum : a1 + a2 + b1 + b2 + c1 + c2 = π := by
    rw [← angle_add_angle_eq_angle_of_mem_interior_convexHull hABC hP 0 1 2,
        ← angle_add_angle_eq_angle_of_mem_interior_convexHull hABC hP 1 2 0,
        ← angle_add_angle_eq_angle_of_mem_interior_convexHull hABC hP 2 0 1]
    exact angle_A_add_angle_B_add_angle_C_eq_pi hABC
  have h_dist : dist P A > 0 ∧ dist P B > 0 ∧ dist P C > 0 :=
    ⟨dist_pos.2 (left_ne_of_mem_interior_convexHull hABC hP 0),
     dist_pos.2 (left_ne_of_mem_interior_convexHull hABC hP 1),
     dist_pos.2 (left_ne_of_mem_interior_convexHull hABC hP 2)⟩
  have h_sine : sin a1 * sin b1 * sin c1 = sin a2 * sin b2 * sin c2 := by
    have s1 := dist_sin_angle_eq_dist_sin_angle P A B
    have s2 := dist_sin_angle_eq_dist_sin_angle P B C
    have s3 := dist_sin_angle_eq_dist_sin_angle P C A
    field_simplify [h_dist.1, h_dist.2.1, h_dist.2.2] at s1 s2 s3
    rw [mul_comm (dist P B), s1, mul_comm (dist P C), s2, mul_comm (dist P A), s3]
    ring
  have h123 : a1 + b1 + c1 < π := by linarith
  have h_a1b1c1 : sin a1 * sin b1 * sin c1 > 1/8 := by
    have : ∀ x, π / 6 < x → x < 2 * π / 3 → sin x > 1/2 := fun x hx1 hx2 ↦
      sin_pos_of_mem_Ioo ⟨by linarith, by linarith⟩ |>.trans_le (by
        if h : x ≤ π / 2 then
          exact sin_increasing_on_Icc ⟨by linarith, h⟩ ⟨by linarith, by linarith⟩ hx1.le
        else
          exact sin_decreasing_on_Icc ⟨π / 2, by linarith⟩ ⟨h.le, by linarith⟩ hx2.le (by linarith))
    repeat (refine mul_pos_of_pos_of_pos ?_ ?_ <;> try apply sin_pos_of_mem_Ioo <;> linarith)
    apply_rules [mul_lt_mul''] <;> apply this <;> linarith
  have h_a2b2c2 : sin a2 * sin b2 * sin c2 < 1/8 := by
    have hsum2 : a2 + b2 + c2 < π / 2 := by linarith
    have hpos2 : a2 > 0 ∧ b2 > 0 ∧ c2 > 0 := ⟨h_pos.2.1, h_pos.2.2.2.1, h_pos.2.2.2.2.2⟩
    have := log_sin_concave.le_fourth_mean (by linarith) (by linarith) (by linarith) (by linarith) (by linarith) (by linarith)
    simp_rw [← log_sin_concave.le_fourth_mean (by linarith) (by linarith) (by linarith) (by linarith) (by linarith) (by linarith),
             ← log_mul (sin_pos_of_mem_Ioo ⟨hpos2.1, by linarith⟩).ne' (sin_pos_of_mem_Ioo ⟨hpos2.2.1, by linarith⟩).ne',
             ← log_mul (mul_pos _ _).ne' (sin_pos_of_mem_Ioo ⟨hpos2.2.2, by linarith⟩).ne',
             log_le_log_iff (mul_pos (mul_pos _ _) _) (pow_pos _ _)] at this
    · refine this.trans_lt (pow_lt_pow_left₀ (sin_pos_of_mem_Ioo ⟨by linarith, by linarith⟩) ?_ (by linarith))
      exact sin_increasing_on_Icc ⟨(by linarith), (by linarith)⟩ ⟨(by linarith), (by linarith)⟩ (by linarith)
    · repeat (apply sin_pos_of_mem_Ioo; linarith)
  linarith
