import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let α₁ := ∠ P A B
  let β₁ := ∠ P B C
  let γ₁ := ∠ P C A
  let α₂ := ∠ P A C
  let β₂ := ∠ P B A
  let γ₂ := ∠ P C B
  have hP_noncoll_AB : ¬Collinear ℝ {P, A, B} := by
    apply interior_convexHull_not_collinear hABC hP; simp
  have hP_noncoll_BC : ¬Collinear ℝ {P, B, C} := by
    apply interior_convexHull_not_collinear hABC hP; simp
  have hP_noncoll_CA : ¬Collinear ℝ {P, C, A} := by
    apply interior_convexHull_not_collinear hABC hP; simp
  have h_prod : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have h1 : sin α₁ / sin β₂ = dist P B / dist P A := by
      rw [div_eq_div_iff (sin_pos_of_angle_pos (angle_pos_of_not_collinear hP_noncoll_AB)).ne' (sin_pos_of_angle_pos (angle_pos_of_not_collinear hP_noncoll_AB)).ne']
      exact dist_sin_angle P A B
    have h2 : sin β₁ / sin γ₂ = dist P C / dist P B := by
      rw [div_eq_div_iff (sin_pos_of_angle_pos (angle_pos_of_not_collinear hP_noncoll_BC)).ne' (sin_pos_of_angle_pos (angle_pos_of_not_collinear hP_noncoll_BC)).ne']
      exact dist_sin_angle P B C
    have h3 : sin γ₁ / sin α₂ = dist P A / dist P C := by
      rw [div_eq_div_iff (sin_pos_of_angle_pos (angle_pos_of_not_collinear hP_noncoll_CA)).ne' (sin_pos_of_angle_pos (angle_pos_of_not_collinear hP_noncoll_CA)).ne']
      exact dist_sin_angle P C A
    rw [← mul_assoc, mul_comm (sin α₁), mul_assoc, mul_comm (sin β₁), ← mul_assoc, ← mul_assoc]
    field_simp [dist_pos.2 (AffineIndependent.ne_pts hABC 0 1).symm, dist_pos.2 (AffineIndependent.ne_pts hABC 1 2).symm]
    linear_combination h1 * sin β₂ * sin γ₂ * sin α₂ * dist P A + h2 * sin γ₂ * sin α₂ * dist P B + h3 * sin α₂ * dist P C
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := by
    rw [← angle_add_angle_of_set_angle_eq_angle hABC hP 0 1 2, ← angle_add_angle_of_set_angle_eq_angle hABC hP 1 2 0, ← angle_add_angle_of_set_angle_eq_angle hABC hP 2 0 1]
    exact angle_sum_triangle hABC
  have h_sin_xyz : sin α₁ * sin β₁ * sin γ₁ > 1 / 8 := by
    have h_range (a : ℝ) (ha : π / 6 < a) (ha' : a < 5 * π / 6) : sin a > 1 / 2 := by
      rw [← sin_pi_six]; exact sin_gt_sin_of_pi_six_lt a ha ha'
    have α₁_lt : α₁ < 2 * π / 3 := by linarith [angle_pos_of_not_collinear hP_noncoll_AB, angle_pos_of_not_collinear hP_noncoll_BC, angle_pos_of_not_collinear hP_noncoll_CA, h_sum]
    have β₁_lt : β₁ < 2 * π / 3 := by linarith [angle_pos_of_not_collinear hP_noncoll_AB, angle_pos_of_not_collinear hP_noncoll_BC, angle_pos_of_not_collinear hP_noncoll_CA, h_sum]
    have γ₁_lt : γ₁ < 2 * π / 3 := by linarith [angle_pos_of_not_collinear hP_noncoll_AB, angle_pos_of_not_collinear hP_noncoll_BC, angle_pos_of_not_collinear hP_noncoll_CA, h_sum]
    nlinarith [h_range α₁ hPAB (by linarith), h_range β₁ hPBC (by linarith), h_range γ₁ hPCA (by linarith)]
  have h_sin_x'y'z' : sin α₂ * sin β₂ * sin γ₂ < 1 / 8 := by
    have h_sum' : α₂ + β₂ + γ₂ < π / 2 := by linarith [angle_pos_of_not_collinear hP_noncoll_AB, angle_pos_of_not_collinear hP_noncoll_BC, angle_pos_of_not_collinear hP_noncoll_CA, hPAB, hPBC, hPCA, h_sum]
    have h_pos : 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := ⟨angle_pos_of_not_collinear hP_noncoll_CA, angle_pos_of_not_collinear hP_noncoll_AB, angle_pos_of_not_collinear hP_noncoll_BC⟩
    have := (strictConcaveOn_log_sin (Real.Ioo 0 π)).open_gradient_inequality (x := (α₂ + β₂ + γ₂) / 3) (y := α₂)
    have h_max := log_sin_add_log_sin_add_log_sin_le (by linarith) (by linarith) (by linarith) (by linarith)
    have : sin ((α₂ + β₂ + γ₂) / 3) < 1 / 2 := by rw [← sin_pi_six]; apply sin_lt_sin_of_lt_of_le; linarith; linarith; exact pi_six_le_pi_half
    nlinarith [exp_log (mul_pos (sin_pos h_pos.1 (by linarith)) (mul_pos (sin_pos h_pos.2.1 (by linarith)) (sin_pos h_pos.2.2 (by linarith)))), exp_log (sin_pos (by linarith) (by linarith))]
  linarith

