import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  rcases h with ⟨hPAB, hPBC, hPCA⟩
  let α₁ := ∠ P A B
  let β₁ := ∠ P B C
  let γ₁ := ∠ P C A
  let α₂ := ∠ P A C
  let β₂ := ∠ P B A
  let γ₂ := ∠ P C B
  have h_int : α₁ > 0 ∧ β₁ > 0 ∧ γ₁ > 0 ∧ α₂ > 0 ∧ β₂ > 0 ∧ γ₂ > 0 := by
    sorry
  have h_sum : α₁ + α₂ + β₁ + β₂ + γ₁ + γ₂ = π := by
    sorry
  have h_ceva : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    sorry
  have h_sin1 : sin α₁ * sin β₁ * sin γ₁ > 1/8 := by
    have h1 : sin α₁ > 1/2 := by
      have : π / 6 < α₁ ∧ α₁ < 5 * π / 6 := ⟨hPAB, by linarith [h_sum, h_int.2.2, hPAB, h_int.2.1, hPBC, h_int.1, hPCA]⟩
      exact sin_gt_half_of_pi_sixth_lt_lt_five_pi_sixth this.1 this.2
    have h2 : sin β₁ > 1/2 := by
      have : π / 6 < β₁ ∧ β₁ < 5 * π / 6 := ⟨hPBC, by linarith [h_sum, h_int.1, hPAB, h_int.2.1, hPBC, h_int.2.2, hPCA]⟩
      exact sin_gt_half_of_pi_sixth_lt_lt_five_pi_sixth this.1 this.2
    have h3 : sin γ₁ > 1/2 := by
      have : π / 6 < γ₁ ∧ γ₁ < 5 * π / 6 := ⟨hPCA, by linarith [h_sum, h_int.1, hPAB, h_int.2.1, hPBC, h_int.2.2, hPCA]⟩
      exact sin_gt_half_of_pi_sixth_lt_lt_five_pi_sixth this.1 this.2
    nlinarith
  have h_sin2 : sin α₂ * sin β₂ * sin γ₂ < 1/8 := by
    have hsum2 : α₂ + β₂ + γ₂ < π / 2 := by linarith [h_sum, hPAB, hPBC, hPCA]
    have hpos2 : α₂ > 0 ∧ β₂ > 0 ∧ γ₂ > 0 := ⟨h_int.2.1, h_int.2.2.1, h_int.2.2.2⟩
    have : sin α₂ * sin β₂ * sin γ₂ ≤ (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 := by
      sorry
    have : (sin ((α₂ + β₂ + γ₂) / 3)) ^ 3 < (1 / 2) ^ 3 := by
      have : (α₂ + β₂ + γ₂) / 3 < π / 6 := by linarith
      have : sin ((α₂ + β₂ + γ₂) / 3) < 1 / 2 := by
        rw [← sin_pi_sixth]
        apply sin_monotone_half_pi
        · linarith
        · linarith
        · linarith
      exact pow_lt_pow_of_lt_left this (by sorry) (by linarith)
    nlinarith
  linarith [h_ceva, h_sin1, h_sin2]

end Imo1991P5
