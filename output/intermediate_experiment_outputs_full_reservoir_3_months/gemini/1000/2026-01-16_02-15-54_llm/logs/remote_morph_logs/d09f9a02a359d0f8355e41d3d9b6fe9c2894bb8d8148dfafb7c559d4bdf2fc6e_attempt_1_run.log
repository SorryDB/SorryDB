import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let α₁ := ∠ P A B
  let β₁ := ∠ P B C
  let γ₁ := ∠ P C A
  let α₂ := ∠ P A C
  let β₂ := ∠ P B A
  let γ₂ := ∠ P C B
  let A_ang := ∠ B A C
  let B_ang := ∠ C B A
  let C_ang := ∠ A C B
  have h_int : α₁ + α₂ = A_ang ∧ β₁ + β₂ = B_ang ∧ γ₁ + γ₂ = C_ang := by
    have h_tri := hP; rw [convexHull_insert, convexHull_insert, convexHull_singleton] at h_tri
    exact ⟨angle_add_of_interior hABC hP 0 1 2, angle_add_of_interior hABC hP 1 2 0, angle_add_of_interior hABC hP 2 0 1⟩
  have h_pos : 0 < α₁ ∧ 0 < β₁ ∧ 0 < γ₁ ∧ 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := by
    have h_tri := hP; rw [convexHull_insert, convexHull_insert, convexHull_singleton] at h_tri
    exact ⟨angle_pos_of_interior hABC hP 0 1 2, angle_pos_of_interior hABC hP 1 2 0, angle_pos_of_interior hABC hP 2 0 1,
           angle_pos_of_interior hABC hP 0 2 1, angle_pos_of_interior hABC hP 1 0 2, angle_pos_of_interior hABC hP 2 1 0⟩
  have h_sum : α₁ + β₁ + γ₁ + α₂ + β₂ + γ₂ = π := by
    rw [h_int.1, h_int.2.1, h_int.2.2, angle_sum_triangle hABC]
  have h_sin_prod : sin α₁ * sin β₁ * sin γ₁ = sin α₂ * sin β₂ * sin γ₂ := by
    have h1 : dist P A * sin α₁ = dist P B * sin β₂ := dist_sin_angle_pA_eq_dist_sin_angle_pB P A B
    have h2 : dist P B * sin β₁ = dist P C * sin γ₂ := dist_sin_angle_pA_eq_dist_sin_angle_pB P B C
    have h3 : dist P C * sin γ₁ = dist P A * sin α₂ := dist_sin_angle_pA_eq_dist_sin_angle_pB P C A
    have h_P_ne : P ≠ A ∧ P ≠ B ∧ P ≠ C := by
      have h_mem := interior_subset hP; rw [convexHull_insert, convexHull_insert, convexHull_singleton] at h_mem
      exact ⟨ne_of_mem_interior_triangle hABC hP 0, ne_of_mem_interior_triangle hABC hP 1, ne_of_mem_interior_triangle hABC hP 2⟩
    field_simp [h_P_ne.1, h_P_ne.2.1, h_P_ne.2.2] at *
    linear_combination h1 * sin β₁ * sin γ₁ + h2 * sin γ₁ * dist P A + h3 * dist P B * sin β₁
  have h_α₁β₁γ₁ : α₁ + β₁ + γ₁ < π := by linarith [h_sum, h_pos.2.2.1, h_pos.2.2.2.1, h_pos.2.2.2.2]
  have h_sin_α₁β₁γ₁ : sin α₁ * sin β₁ * sin γ₁ > 1/8 := by
    have f (x : ℝ) (hx : π / 6 < x ∧ x < 2 * π / 3) : sin x > 1 / 2 := by
      have : x ∈ Set.Ioo (π / 6) (5 * π / 6) := ⟨hx.1, by linarith [hx.2]⟩
      exact sin_gt_half_of_mem_Ioo this
    have hα₁ : sin α₁ > 1/2 := f α₁ ⟨h.1, by linarith⟩
    have hβ₁ : sin β₁ > 1/2 := f β₁ ⟨h.2.1, by linarith⟩
    have hγ₁ : sin γ₁ > 1/2 := f γ₁ ⟨h.2.2, by linarith⟩
    nlinarith
  have h_sin_α₂β₂γ₂ : sin α₂ * sin β₂ * sin γ₂ < 1/8 := by
    let S := α₂ + β₂ + γ₂
    have hS : S = π - (α₁ + β₁ + γ₁) := by linarith
    have hS_pos : 0 < S := by linarith [h_pos.2.2.1, h_pos.2.2.2.1, h_pos.2.2.2.2]
    have hS_bound : S < π / 2 := by linarith
    have h_log_sin_concave : ConcaveOn ℝ (Set.Ioo 0 π) (λ x => log (sin x)) := by
      apply concaveOn_open_convex_2nd_derivative (convex_Ioo 0 π)
      · exact λ x hx => differentiableAt_log (sin_ne_zero_of_mem_Ioo hx) |>.comp _ (differentiableAt_sin x)
      · intros x hx; simp; field_simp [sin_ne_zero_of_mem_Ioo hx]; nlinarith [sin_pos_of_mem_Ioo hx]
    have h_prod_le : (sin α₂ * sin β₂ * sin γ₂) ≤ (sin (S / 3)) ^ 3 := by
      have hα₂' : α₂ ∈ Set.Ioo 0 π := ⟨h_pos.2.2.1, by linarith⟩
