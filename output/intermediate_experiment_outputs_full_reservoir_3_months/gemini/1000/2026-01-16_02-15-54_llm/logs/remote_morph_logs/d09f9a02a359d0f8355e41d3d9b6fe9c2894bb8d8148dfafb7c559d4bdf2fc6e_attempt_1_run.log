import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real
open Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let x := ∠ P A B; let y := ∠ P B C; let z := ∠ P C A
  let x' := ∠ P B A; let y' := ∠ P C B; let z' := ∠ P A C
  have hAP : P ≠ A := by rintro rfl; exact (interior_subset_convexHull _ hP) (by simp)
  have hBP : P ≠ B := by rintro rfl; exact (interior_subset_convexHull _ hP) (by simp)
  have hCP : P ≠ C := by rintro rfl; exact (interior_subset_convexHull _ hP) (by simp)
  have h_sin_prod : sin x * sin y * sin z = sin x' * sin y' * sin z' := by
    field_simp [dist_sin_angle_eq_dist_sin_angle A B P, dist_sin_angle_eq_dist_sin_angle B C P, dist_sin_angle_eq_dist_sin_angle C A P]
    ring
  have h_sum : x + x' + y + y' + z + z' = π := by
    have h1 := angle_add_angle_eq_angle_of_pos_angle_of_angle_add_angle_lt_pi hABC hP ![0, 1, 2]
    have h2 := angle_add_angle_eq_angle_of_pos_angle_of_angle_add_angle_lt_pi hABC hP ![1, 2, 0]
    have h3 := angle_add_angle_eq_angle_of_pos_angle_of_angle_add_angle_lt_pi hABC hP ![2, 0, 1]
    simp [x, y, z, x', y', z'] at h1 h2 h3
    rw [← angle_A_add_angle_B_add_angle_C_eq_pi hABC, ← h1, ← h2, ← h3]
    ring
  have h_x_range : x ∈ Set.Ioo (π / 6) (2 * π / 3) := by
    have h_pos : 0 < x := angle_pos_of_mem_interior_convexHull hABC hP 0 1
    have h_less : x < π - (y + z) := by linarith [angle_pos_of_mem_interior_convexHull hABC hP 1 2, angle_pos_of_mem_interior_convexHull hABC hP 2 0, h_sum]
    constructor; exact h.1; linarith [h.2, h.3]
  have h_y_range : y ∈ Set.Ioo (π / 6) (2 * π / 3) := by
    have h_pos : 0 < y := angle_pos_of_mem_interior_convexHull hABC hP 1 2
    have h_less : y < π - (x + z) := by linarith [angle_pos_of_mem_interior_convexHull hABC hP 0 1, angle_pos_of_mem_interior_convexHull hABC hP 2 0, h_sum]
    constructor; exact h.2; linarith [h.1, h.3]
  have h_z_range : z ∈ Set.Ioo (π / 6) (2 * π / 3) := by
    have h_pos : 0 < z := angle_pos_of_mem_interior_convexHull hABC hP 2 0
    have h_less : z < π - (x + y) := by linarith [angle_pos_of_mem_interior_convexHull hABC hP 0 1, angle_pos_of_mem_interior_convexHull hABC hP 1 2, h_sum]
    constructor; exact h.3; linarith [h.1, h.2]
  have h_sin_xyz : sin x * sin y * sin z > 1 / 8 := by
    have s1 : sin x > 1 / 2 := by rw [← sin_pi_sixth]; exact sin_lt_sin_of_lt_of_le (by linarith [h_x_range.1, pi_pos]) h_x_range.1 (by linarith [h_x_range.2])
    have s2 : sin y > 1 / 2 := by rw [← sin_pi_sixth]; exact sin_lt_sin_of_lt_of_le (by linarith [h_y_range.1, pi_pos]) h_y_range.1 (by linarith [h_y_range.2])
    have s3 : sin z > 1 / 2 := by rw [← sin_pi_sixth]; exact sin_lt_sin_of_lt_of_le (by linarith [h_z_range.1, pi_pos]) h_z_range.1 (by linarith [h_z_range.2])
    nlinarith
  have h_sum_x'y'z' : x' + y' + z' < π / 2 := by linarith [h.1, h.2, h.3]
  have h_pos_x' : 0 < x' := angle_pos_of_mem_interior_convexHull hABC hP 1 0
  have h_pos_y' : 0 < y' := angle_pos_of_mem_interior_convexHull hABC hP 2 1
  have h_pos_z' : 0 < z' := angle_pos_of_mem_interior_convexHull hABC hP 0 2
  have h_sin_x'y'z' : sin x' * sin y' * sin z' < 1 / 8 := by
    have h_amgm := log_sin_add_log_sin_add_log_sin_le h_pos_x' h_pos_y' h_pos_z' (by linarith) (by linarith) (by linarith)
    simp_rw [← log_mul (sin_pos_of_mem_Ioo ⟨h_pos_x', by linarith⟩).ne' (sin_pos_of_mem_Ioo ⟨h_pos_y', by linarith⟩).ne', ← log_mul (mul_pos _ _).ne' (sin_pos_of_mem_Ioo ⟨h_pos_z', by linarith⟩).ne'] at h_amgm
    have h_sin_avg : sin ((x' + y' + z') / 3) < 1 / 2 := by
      rw [← sin_pi_sixth]; exact sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith [pi_pos])
    have h_final : sin x' * sin y' * sin z' ≤ (sin ((x' + y' + z') / 3))^3 := by
      rw [← exp_log (mul_pos (sin_pos_of_mem_Ioo ⟨h_pos_x', by linarith⟩) (mul_pos (sin_pos_of_mem_Ioo ⟨h_pos_y', by linarith⟩) (sin_pos_of_mem_Ioo ⟨h_pos_z', by linarith⟩)))]
      rw [exp_le_exp, ← mul_le_mul_left (by linarith : (0 : ℝ) < 3), ← log_pow]; exact h_amgm
    exact h_final.trans_lt (pow_lt_pow_left h_sin_avg (by linarith [sin_pos_of_mem_Ioo ⟨h_pos_x', by linarith⟩]) (by linarith))
  linarith

