    linarith [mul_pos p1 (mul_pos p2 p3)]
  have hsum2 : α₂ + β₂ + γ₂ < π / 2 := by linarith
  have hsin_small : sin β₂ * sin γ₂ * sin α₂ < 1 / 8 := by
    have pos2 : 0 < α₂ ∧ 0 < β₂ ∧ 0 < γ₂ := ⟨angle_pos_of_mem_interior hP 0 2 1, angle_pos_of_mem_interior hP 1 0 2, angle_pos_of_mem_interior hP 2 1 0⟩
