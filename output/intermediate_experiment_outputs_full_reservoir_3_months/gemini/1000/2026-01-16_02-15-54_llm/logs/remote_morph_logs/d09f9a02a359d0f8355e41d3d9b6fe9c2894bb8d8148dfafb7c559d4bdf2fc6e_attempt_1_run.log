import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  let x1 := ∠ P A B; let x2 := ∠ P A C; let y1 := ∠ P B C
  let y2 := ∠ P B A; let z1 := ∠ P C A; let z2 := ∠ P C B
  have h_int : P ∈ interior (convexHull ℝ {A, B, C}) := hP
  have hx : x1 + x2 = ∠ B A C := angle_add_angle_of_interior (hABC.affineSpan_set_eq_top_iff.mp rfl |>.symm ▸ hP)
    (orthogonalProjection_mem_interior_angle hABC 0 1 2 h_int)
  have hy : y1 + y2 = ∠ A B C := angle_add_angle_of_interior (hABC.affineSpan_set_eq_top_iff.mp rfl |>.symm ▸ hP)
    (orthogonalProjection_mem_interior_angle hABC 1 2 0 h_int)
  have hz : z1 + z2 = ∠ B C A := angle_add_angle_of_interior (hABC.affineSpan_set_eq_top_iff.mp rfl |>.symm ▸ hP)
    (orthogonalProjection_mem_interior_angle hABC 2 0 1 h_int)
  have h_sum : x1 + x2 + y1 + y2 + z1 + z2 = π := by
    rw [hx, hy, hz, ← angle_sum_eq_pi hABC]; abel
  have sin_prod : sin x1 * sin y1 * sin z1 = sin x2 * sin y2 * sin z2 := by
    field_simp [dist_pos.mpr (show P ≠ A from (interior_subset hP).ne_points 0),
               dist_pos.mpr (show P ≠ B from (interior_subset hP).ne_points 1),
               dist_pos.mpr (show P ≠ C from (interior_subset hP).ne_points 2)]
    repeat rw [mul_comm (dist P _), ← dist_sin_angle]
    rw [dist_comm A B, dist_comm B C, dist_comm C A]
    repeat rw [dist_comm _ P, dist_line_eq_dist_sin_angle]
  have hx1y1z1 : x1 + y1 + z1 > π / 2 := by linarith [h.1, h.2.1, h.2.2]
  have hx2y2z2 : x2 + y2 + z2 < π / 2 := by linarith
  have h_pos : 0 < x1 ∧ 0 < y1 ∧ 0 < z1 ∧ 0 < x2 ∧ 0 < y2 ∧ 0 < z2 := by
    refine ⟨?_, ?_, ?_, ?_, ?_, ?_⟩
    all_goals apply angle_pos_of_mem_interior hABC h_int
  have h_bound : x1 < π ∧ y1 < π ∧ z1 < π ∧ x2 < π ∧ y2 < π ∧ z2 < π := by
    refine ⟨?_, ?_, ?_, ?_, ?_, ?_⟩
    all_goals linarith [h_sum, h_pos.1, h_pos.2.1, h_pos.2.2]
  have h_sin_x1 : sin x1 > 1 / 2 := by
    apply sin_gt_half_of_le_pi_div_six_le_five_pi_div_six
    all_goals linarith [h.1, h_sum, h_pos]
  have h_sin_y1 : sin y1 > 1 / 2 := by
    apply sin_gt_half_of_le_pi_div_six_le_five_pi_div_six
    all_goals linarith [h.2.1, h_sum, h_pos]
  have h_sin_z1 : sin z1 > 1 / 2 := by
    apply sin_gt_half_of_le_pi_div_six_le_five_pi_div_six
    all_goals linarith [h.2.2, h_sum, h_pos]
  have h_prod1 : sin x1 * sin y1 * sin z1 > 1 / 8 := by nlinarith
  have h_prod2 : sin x2 * sin y2 * sin z2 < 1 / 8 := by
    have := log_sin_concave
    have h_jensen := this.sum_le (by linarith) (fun _ _ => h_pos.2.2) (fun _ _ => h_bound.2.2) (fun _ => (1:ℝ)/3) (by norm_num) (by norm_num) ![x2, y2, z2]
    simp at h_jensen; rw [h_sum] at h_jensen
    have : (x2 + y2 + z2) / 3 < π / 6 := by linarith
    have h_log : Real.log (sin x2 * sin y2 * sin z2) < Real.log (1 / 8) := by
      rw [Real.log_mul (sin_pos_of_pos_of_lt_pi h_pos.2.2 h_bound.2.2).ne', Real.log_mul (sin_pos_of_pos_of_lt_pi h_pos.2.2 h_bound.2.1).ne']
      rw [← mul_comm 3]; apply (lt_of_le_of_lt h_jensen ?_)
      rw [Real.log_inv, Real.log_pow, Real.log_nat_cast, ← Real.log_inv, show (2:ℝ)⁻¹ = sin (π/6) by norm_num]
      apply mul_lt_mul_of_pos_left (Real.log_sin_lt_log_sin_of_lt (by linarith) (by linarith) this) (by norm_num)
    exact (Real.log_lt_log_iff (by positivity) (by positivity)).mp h_log
  linarith

