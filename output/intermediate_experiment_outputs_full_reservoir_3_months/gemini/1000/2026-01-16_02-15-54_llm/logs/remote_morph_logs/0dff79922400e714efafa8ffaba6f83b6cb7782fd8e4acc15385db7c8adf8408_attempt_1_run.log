  FunDeriv (fun x ↦ x ^ 3) g := by
use (fun x ↦ 3 * x ^ 2)
intro x ε hε
let δ : ℝ := min 1 (ε / (3 * |x| + 1))
have δ_le1 : δ ≤ 1 := by bound
have δ_le2 : δ ≤ ε / (3 * |x| + 1) := by bound
have δpos : 0 < δ := by bound
```
