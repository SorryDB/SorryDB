    · exact add_pos_of_nonneg_of_pos (Finset.sum_nonneg fun i _ => (hd i).le) zero_lt_one
    · simp only [Inner.inner, smul_eq_mul, RCLike.map_sum]
      rcases isEmpty_or_nonempty ι with hι | hι
      · simp [Pi.norm_def, hι]; positivity
      · let ⟨i, hi⟩ := Finite.exists_max (fun i => ‖x i‖)
        have hi' : ‖x i‖ = ‖x‖ := le_antisymm (Pi.norm_le_norm x i) (iSup_le hi)
