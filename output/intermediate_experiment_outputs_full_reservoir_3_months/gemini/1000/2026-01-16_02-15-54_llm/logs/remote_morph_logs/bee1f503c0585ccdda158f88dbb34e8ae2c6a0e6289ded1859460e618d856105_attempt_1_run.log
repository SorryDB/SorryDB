theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff, isEmpty_subtype_iff]
  intro p hp
  have h_sum : ∑ i, (p i : Fin 8) = 4 := by
    simpa [hE, add_comm, add_left_cancel_iff] using hp
  have h_mod : (∑ i, (p i : ℤ) : ZMod 2) = 0 := by
    have h8 : (∑ i, (p i : ℤ) : ZMod 8) = 4 := by simpa using h_sum
    rw [← ZMod.cast_cast (by norm_num : 2 ∣ 8), h8]
    norm_num
  have h_odd : (∑ i, (p i : ℤ) : ZMod 2) = 1 := by
    simp only [Int.cast_sum]
    have : ∀ i, ((p i : ℤ) : ZMod 2) = 1 := fun i => by
      obtain (rfl | rfl) := Int.units_eq_one_or_neg_one (p i) <;> rfl
    simp [this]
    cases n with
    | zero => contradiction
    | succ n =>
      simp [Nat.succ_eq_add_one, Nat.mul_add, Nat.add_sub_cancel]
      norm_num
  simp [h_odd] at h_mod
```
