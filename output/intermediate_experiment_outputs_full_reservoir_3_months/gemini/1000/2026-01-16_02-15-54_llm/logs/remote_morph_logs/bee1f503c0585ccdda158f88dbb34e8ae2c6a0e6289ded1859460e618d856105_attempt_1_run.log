theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff]
  intro ⟨p, hp⟩
  rw [hE] at hp
  have hsum := add_left_cancel hp
  let f : Fin 8 →+ ZMod 2 :=
    { toFun := fun x => (x.val : ZMod 2),
      map_zero' := rfl,
      map_add' := fun x y => by
        simp [Fin.add_def, ZMod.nat_cast_mod (x.val + y.val) (show 2 ∣ 8 by norm_num)] }
  have hf := map_sum f (fun i => ↑↑(p i)) Finset.univ
  rw [hsum] at hf
  simp [f] at hf
  have h_pi (i : Fin (2 * n - 1)) : ((↑↑(p i) : Fin 8).val : ZMod 2) = 1 := by
    cases Int.units_eq_one_or_neg_one (p i) with
    | inl h => rw [h]; rfl
    | inr h => rw [h]; rfl
  simp [h_pi] at hf
  norm_cast at hf
  omega

