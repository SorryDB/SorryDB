    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff]
  intro ⟨p, hp⟩
  let f : Fin 8 →+ Fin 2 :=
  { toFun := λ x => ⟨x.val % 2, Nat.mod_lt _ (by decide)⟩,
    map_zero' := rfl,
