theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff]
  intro ⟨p, hp⟩
  have h_sum : ∑ i, (p i : Fin 8) = 4 := by
    rw [hE] at hp
    exact add_left_cancel hp
  let f : ZMod 8 →+* ZMod 2 := ZMod.castHom (by norm_num) (ZMod 2)
  have hf : f (∑ i, (p i : Fin 8)) = f 4 := congr_arg f h_sum
  rw [map_sum, Finset.sum_const, Fintype.card_fin] at hf
  have h_p : ∀ i, f (p i : Fin 8) = 1 := by
    intro i
    rcases Int.units_plus_one_minus_one (p i) with h | h <;> { rw [h]; rfl }
  simp [h_p] at hf
  have h_odd : (2 * n - 1 : ZMod 2) = 1 := by
    have : 2 * n - 1 = 2 * (n - 1) + 1 := by omega
    rw [this]; simp
  rw [hf] at h_odd
  contradiction
