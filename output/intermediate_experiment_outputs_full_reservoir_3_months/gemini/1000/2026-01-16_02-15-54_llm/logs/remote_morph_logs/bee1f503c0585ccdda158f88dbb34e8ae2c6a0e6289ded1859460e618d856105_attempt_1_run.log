theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff]
  intro ⟨p, hp⟩
  replace hp : ∑ i, (p i : Fin 8) = 4 := by
    rw [hE] at hp
    simpa [add_comm] using hp
  let f : ZMod 8 →+ ZMod 2 := ZMod.castHom (by norm_num) (ZMod 2)
  have h1 : f (∑ i, (p i : Fin 8)) = f 4 := by rw [hp]
  have h2 : ∀ i, f (p i : Fin 8) = 1 := fun i => by
    cases Units.val_eq_one_or_neg_one (p i) with
    | inl h => rw [h]; rfl
    | inr h => rw [h]; rfl
  simp [map_sum, h2, ZMod.cast_hom_apply] at h1
  have h3 : (2 * n - 1 : ZMod 2) = 1 := by
    cases n; contradiction; simp [Nat.mul_add]
  rw [h3] at h1
  exact one_ne_zero h1
