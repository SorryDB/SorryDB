/-- Any diffeological manifold is also a diffeological manifold with boundary. -/
instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  obtain ⟨u, hu, hxu, ⟨⟩, v, hv, ⟨d⟩⟩ := hm.locally_modelled x
  let y := d ⟨x, hxu⟩
  let _ : TopologicalSpace (Eucl n) := DTop
  obtain ⟨ε, hε, hB⟩ := (dTop_eq (Eucl n) ▸ hv).mem_nhds y.2
  let c : Eucl n := fun i ↦ if i = 0 then ε + 1 - y.1 0 else 0
  let f : Eucl n ᵈ≃ Eucl n := ⟨⟨⟨(· + c), (· - c)⟩, fun _ ↦ by simp, fun _ ↦ by simp⟩,
    dsmooth_id.add dsmooth_const, dsmooth_id.sub dsmooth_const⟩
  let B := Metric.ball y ε
  let d' := (d.restrict (d ⁻¹' B)).trans (f.restrict B)
  have hBv : B ⊆ v := hB
  refine ⟨(↑) '' (d ⁻¹' B), hu.isOpenMap_subtype_val _
    ((dTop_eq u ▸ d.symm.dsmooth.continuous').preimage Metric.isOpen_ball),
    ⟨⟨⟨x, hxu⟩, hB (Metric.mem_ball_self hε)⟩, rfl⟩, (), (↑) ⁻¹' (f '' B),
    (f.dsmooth.continuous'.isOpenMap_of_isDiffeomorph Metric.isOpen_ball).preimage continuous_subtype_val,
    ⟨d'.trans (DDiffeomorph.Set.nested _).symm⟩⟩⟩
