/-- Any diffeological manifold is also a diffeological manifold with boundary. -/
instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u, hu, hxu, (), v, hv, ⟨d⟩⟩ := hm.locally_modelled x
  let y := d ⟨x, hxu⟩
  let ⟨r, r_pos, hr⟩ := Metric.isOpen_iff.1 (dTop_eq (Eucl n) ▸ hv) y.1 y.2
  let a : Eucl n := fun i ↦ if i = 0 then (r - y.1 0 + 1) else 0
  let B := Metric.ball y.1 (r/2)
  let d' := (d.restrict (d ⁻¹' B)).trans (DDiffeomorph.addLeft a)
  let v' : Set {x : Eucl n | 0 ≤ x 0} := Subtype.val ⁻¹' (Metric.ball (y.1 + a) (r/2))
  refine ⟨d ⁻¹' B, (dTop_eq X ▸ hu).preimage d.dsmooth.continuous Metric.isOpen_ball, ⟨x, hxu, by simp⟩,
    (), v', (dTop_eq _ ▸ Metric.isOpen_ball).preimage (continuous_id.add continuous_const), ⟨d'⟩⟩⟩
```
