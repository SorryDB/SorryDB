instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  obtain ⟨u, hu, hxu, ⟨⟩, v, hv, ⟨d⟩⟩ := hm.locally_modelled x
  let y := (d ⟨x, hxu⟩ : Eucl n)
  obtain ⟨ε, hε, hB⟩ := (hv.dTop_isOpen_iff.1 (d ⟨x, hxu⟩).2).1
  let ε' : ℝ := min ε 1
  let e₀ : Eucl n := fun j ↦ if j = 0 then 1 else 0
  let f := DDiffeomorph.add_right (e₀ - y)
  let B : Set (Eucl n) := Metric.ball y ε'
  let u' := d ⁻¹' (v ∩ B)
  let v' : Set {z : Eucl n | 0 ≤ z 0} := Subtype.val ⁻¹' (f '' (v ∩ B))
  have hBv : v ∩ B ⊆ v := Set.inter_subset_left v B
  have hBf : f '' (v ∩ B) ⊆ {z : Eucl n | 0 ≤ z 0} := by
    rintro z ⟨w, ⟨_, hwB⟩, rfl⟩
    simp [f, e₀, y]
    have : dist w y < 1 := (Set.mem_inter_iff.1 hwB).2.trans_le (min_le_right _ _)
    exact (abs_lt.1 ((dist_pi_apply_le w y 0).trans_lt this)).1.le.trans (by simp)
  refine ⟨u', hu.inter (d.dsmooth.continuous.preimage (dTop_eq _ ▸ hv.inter (isOpen_ball _ _))),
    ⟨hxu, hε, (Metric.mem_ball _ _ _).2 (by simp [ε', hε])⟩, (), v', ?_, ⟨?_⟩⟩
  · rw [dTop_eq]; exact (f.isOpenMap_dsmooth (hv.inter (isOpen_ball _ _))).preimage continuous_subtype_val
  · exact (d.restrict (v ∩ B)).trans ((f.restrict (v ∩ B)).trans (DDiffeomorph.Set.image_subtype_val hBf))⟩
```
