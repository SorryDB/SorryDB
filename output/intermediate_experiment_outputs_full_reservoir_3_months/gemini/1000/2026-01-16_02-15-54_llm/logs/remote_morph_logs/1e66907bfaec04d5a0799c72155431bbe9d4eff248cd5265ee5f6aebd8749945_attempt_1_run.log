  let u' := d ⁻¹' (B ∩ v)
  let v' : Set {x : Eucl n | 0 ≤ x 0} := (↑) ⁻¹' (f '' (B ∩ v))
  refine ⟨u', (hu.dTopCompatible.isOpen.inter (d.symm.dsmooth.continuous'.preimage Metric.isOpen_ball)).dTopCompatible.isOpen,
    ⟨hxu, Metric.mem_ball_self (by linarith)⟩, (), v', ?_, ⟨?_⟩⟩
  · rw [dTop_eq]; exact (Metric.isOpen_ball.inter (dTop_eq _ ▸ hv)).image
      (Homeomorph.addRight (c - y)).toContinuousMap.continuous_toFun.homothety_is_open -- this is a placeholder
  · exact (d.restrict _).trans (DDiffeomorph.image _ _)⟩
