-- exercise 1.4.v
-- Natural transformation from F ∘ π₁ to G ∘ π₂ for comma category (F ↓ G)
def Comma_NatTrans {C D E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    let CommaType := Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)
    letI : Category CommaType := Comma_category F G
    NaturalTransformation
      (Functor.comp (Comma_category_dom F G) F)
      (Functor.comp (Comma_category_cod F G) G) where
  arrow X := X.2.2
  naturality {X Y} f := f.2.2
```
