import Mathlib


open scoped Real
open Affine EuclideanGeometry Module

namespace IMO2025P2

variable {V Pt : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace Pt]
variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {M N A B C D P E F H : Pt} {Ω Γ : Sphere Pt} (Ω_center_eq_M : Ω.center = M)
    (Γ_center_eq_N : Γ.center = N) (Ω_radius_lt_Γ_radius : Ω.radius < Γ.radius)
    (A_mem_inter : A ∈ (Ω ∩ Γ : Set Pt)) (B_mem_inter : B ∈ (Ω ∩ Γ : Set Pt)) (A_ne_B : A ≠ B)
    (M_ne_N : M ≠ N) (C_mem_inter : C ∈ (line[ℝ, M, N] ∩ Ω : Set Pt))
    (D_mem_inter : D ∈ (line[ℝ, M, N] ∩ Γ : Set Pt)) (sbtw_C_M_N_D : [C, M, N, D].Sbtw ℝ)
    (affineIndependent_ACD : AffineIndependent ℝ ![A, C, D])
    (P_eq_circumcenter : P = (⟨_, affineIndependent_ACD⟩ : Triangle ℝ Pt).circumcenter)
    (E_mem_inter : E ∈ (line[ℝ, A, P] ∩ Ω : Set Pt)) (E_ne_A : E ≠ A)
    (F_mem_inter : F ∈ (line[ℝ, A, P] ∩ Γ : Set Pt)) (F_ne_A : F ≠ A)
    (affineIndependent_PMN : AffineIndependent ℝ ![P, M, N])
    (H_eq_orthocenter : H = Triangle.orthocenter (⟨_, affineIndependent_PMN⟩ : Triangle ℝ Pt)) :
    ∃ affineIndependent_BEF : AffineIndependent ℝ ![B, E, F],
      (⟨_, affineIndependent_BEF⟩ : Triangle ℝ Pt).circumsphere.IsTangent
        (AffineSubspace.mk' H line[ℝ, A, P].direction) := by
  have h_ne : P ≠ A := (affineIndependent_ACD.injective.ne (by norm_num) (by norm_num)).symm
  let L := line[ℝ, A, P]
  have h_E_L : E ∈ L := E_mem_inter.1
  have h_F_L : F ∈ L := F_mem_inter.1
  have h_A_L : A ∈ L := left_mem_affineSpan ℝ _ _
  have h_P_L : P ∈ L := right_mem_affineSpan ℝ _ _
  have h_B_not_L : B ∉ L := by
    intro h_B_L
    have h_B_A_P : Collinear ℝ ({B, A, P} : Set Pt) := by
      rw [collinear_iff_of_mem h_B_L h_A_L]
      exact affineSpan_mono ℝ (Set.subset_insert _ _)
    have h_A_B_M_N : (A +ᵥ B) = (M +ᵥ N) := sorry
    sorry
  have h_EF : E ≠ F := sorry
  have affineIndependent_BEF : AffineIndependent ℝ ![B, E, F] := by
    rw [affineIndependent_iff_not_collinear]
    intro h_coll
    have h_E_F_L : line[ℝ, E, F] = L := line_eq_of_mem_affineSpan_of_ne h_E_L h_F_L h_EF
    have h_B_L' : B ∈ line[ℝ, E, F] := (collinear_iff_of_mem h_E_L h_F_L).mp h_coll
    rw [h_E_F_L] at h_B_L'
    exact h_B_not_L h_B_L'
  use affineIndependent_BEF
  let s := (⟨_, affineIndependent_BEF⟩ : Triangle ℝ Pt).circumsphere
  let K := AffineSubspace.mk' H L.direction
  have h_rad : 0 < s.radius := circumsphere_radius_pos affineIndependent_BEF
  refine ⟨h_rad, ?_⟩
  rw [dist_comm, dist_eq_iff_dist_sq_eq (dist_nonneg) (le_of_lt h_rad), s.circumsphere_center,
    circumsphere_radius_sq]
  let Q := (⟨_, affineIndependent_BEF⟩ : Triangle ℝ Pt).circumcenter
  have h_dist_Q_K : (dist Q K) ^ 2 = dist Q H ^ 2 - ((InnerProductSpace.Core.inner (Q -ᵥ H) (P -ᵥ A)) ^ 2 / dist P A ^ 2) := sorry
  have h_ge : dist Q B ^ 2 = dist Q H ^ 2 - ((InnerProductSpace.Core.inner (Q -ᵥ H) (P -ᵥ A)) ^ 2 / dist P A ^ 2) := sorry
  rw [h_dist_Q_K, h_ge]
