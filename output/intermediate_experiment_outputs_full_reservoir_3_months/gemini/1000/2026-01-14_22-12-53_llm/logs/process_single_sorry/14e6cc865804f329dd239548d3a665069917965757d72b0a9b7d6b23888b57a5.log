def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    obtain ⟨N, hN, hx⟩ : ∃ N, ∃ hN : N ∈ D, x ∈ B N hN := by simpa only [Set.mem_iUnion] using hx
    have hxN : x ≤ N := by rw [hB N hN]; exact le_sSup hx
    have : a ≤ sSup (B N hN \ {x}) := by
      have h : a ≤ (sSup (B N hN \ {x}) ⊔ sSup (D.carrier \ {N})) ⊓ N := by
        refine le_inf (ha'.trans (sSup_le ?_)) (ha.trans hxN)
        rintro y ⟨hy, hyx⟩
        obtain ⟨N', hN', hyB⟩ : ∃ N', ∃ hN' : N' ∈ D, y ∈ B N' hN' := by simpa only [Set.mem_iUnion] using hy
        if h : N' = N then exact le_sup_of_le_left (le_sSup ⟨by rwa [h] at hyB, hyx⟩)
        else exact le_sup_of_le_right (le_sSup_of_le (show N' ∈ D.carrier \ {N} from ⟨hN', h⟩)
          (by rw [hB N' hN']; exact le_sSup hyB))
      rwa [sup_inf_assoc_of_le (by rw [hB N hN]; exact sSup_le_sSup (Set.diff_subset _ _)),
        (D.sSupIndep N hN).eq_bot, sup_bot_eq] at h
    exact (hB' N hN x hx).le_bot (le_inf ha this)
```
