import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- The sequence $a_1,a_2,\dots$ of integers satisfies the conditions:

(i) $1\le a_j\le2015$ for all $j\ge1$,
(ii) $k+a_k\neq \ell+a_\ell$ for all $1\le k<\ell$.

Prove that there exist two positive integers $b$ and $N$ for which\[\left\vert\sum_{j=m+1}^n(a_j-b)\right\vert\le1007^2\]for all integers $m$ and $n$ such that $n>m\ge N$.

[i]Proposed by Ivan Guo and Ross Atkins, Australia[/i]
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p6 (a : ℕ+ → ℤ) (hi : ∀ j, 1 ≤ a j ∧ a j ≤ 2015)
    (hii : ∀ l k, 1 ≤ k ∧ k < l → ↑k + a k ≠ ↑l + a l) :
    ∃ b N : ℕ+, ∀ (m n) (h : m < n ∧ N ≤ m),
      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let f : ℕ+ → ℤ := λ j => j + a j
  have hf : Function.Injective f := λ j k h => by
    rcases lt_trichotomy j k with r|r|r
    · exact (hii k j ⟨j.2, r⟩ h.symm).elim
    · exact r
    · exact (hii j k ⟨k.2, r⟩ h).elim
  let S := Set.range f
  let K := {n : ℤ | 1 ≤ n} \ S
  have hK_bdd : ∀ x ∈ K, 1 ≤ x ∧ x ≤ 2015 := by
    intro x hx; simp [S, f] at hx; constructor; · exact hx.1
    by_contra! h; let n := Finset.Icc 1 (x - 2015).toNat
    have h_size : n.card = (x - 2015).toNat := by simp
    have h_im : n.image f ⊆ Finset.Icc 1 (x - 1) := by
      intro y hy; simp only [Finset.mem_image, Finset.mem_Icc] at hy
      rcases hy with ⟨j, hj, rfl⟩; simp only [Finset.mem_Icc] at hj
      constructor; · linarith [a j, (hi j).1, (j.2)]
      · have : (j : ℤ) ≤ x - 2015 := by linarith [(hj.2)]
        linarith [(hi j).2]
    have : (n.image f).card ≤ (Finset.Icc 1 (x - 1)).card := Finset.card_le_of_subset h_im
    rw [Finset.card_image_of_injective n hf, h_size] at this
    have : (x - 1).toNat < (x - 2015).toNat := by linarith
    simp at this; linarith
  have hKf : K.Finite := (Set.finite_Icc 1 2015).subset hK_bdd
  let b_val : ℕ := hKf.toFinset.card
  have hb_pos : 0 < b_val := by
    have : 1 ∈ K := by simp [S, f]; intro j; linarith [a j, (hi j).1]
    exact Finset.card_pos.mpr ⟨1, by simp [this]⟩
  let b : ℕ+ := ⟨b_val, hb_pos⟩
  let N : ℕ+ := ⟨(hKf.toFinset.image (λ x => x.toNat)).fold max 1 + 1, by simp⟩
  use b, N; intro m n h; simp only [Finset.sum_sub_distrib, Finset.sum_const, Finset.card_Icc]
  let s (i : ℕ) : ℤ := if hi : i ∈ S then (Classical.choose hi : ℤ) else 0
  let g (k : ℕ) : ℤ := (∑ i in Finset.Icc 1 k, (if i ∈ S then i else 0)) - (∑ i in Finset.Icc 1 (k - b), (i + b))
  -- The core bound is based on the range of missing values and the injective function f(n) = n + a_n.
  -- For large enough n, the partial sum g(n) is bounded between 0 and b(2015-b).
  -- The maximal value of b(2015-b-1) for 1 <= b <= 2015 is at b=1007 or b=1008.
  -- 1007 * (2015 - 1007 - 1) = 1007^2.
  sorry
