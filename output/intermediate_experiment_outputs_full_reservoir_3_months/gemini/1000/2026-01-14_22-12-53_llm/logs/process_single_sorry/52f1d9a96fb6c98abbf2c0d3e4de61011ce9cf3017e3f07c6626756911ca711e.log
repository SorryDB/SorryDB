import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have hx : x ≤ 1 := by linarith
    have hy : y ≤ 1 := by linarith
    have hz : z ≤ 1 := by linarith
    calc y * z + z * x + x * y - 2 * x * y * z
      _ = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z := by ring
      _ ≥ 0 := by nlinarith
  · have h_aux : ∀ a b c : ℝ, 0 ≤ a → 0 ≤ b → 0 ≤ c → a + b + c = 1 → a ≤ 1 / 3 →
      b * c + c * a + a * b - 2 * a * b * c ≤ 7 / 27 := by
      intro a b c h0a h0b h0c hsum h3a
      have hbc : b * c ≤ (1 - a) ^ 2 / 4 := by
        have : 4 * b * c ≤ (b + c) ^ 2 := by nlinarith
        have : b + c = 1 - a := by linarith
        nlinarith
      have : b * c + c * a + a * b - 2 * a * b * c = a * (1 - a) + b * c * (1 - 2 * a) := by
        rw [← hsum]; ring
      rw [this]
      have h3a' : 0 ≤ 1 - 2 * a := by linarith
      have : 7 / 27 - (a * (1 - a) + (1 - a) ^ 2 / 4 * (1 - 2 * a)) = (1 - 3 * a) ^ 2 * (6 * a + 1) / 108 := by ring
      nlinarith
    have h_min : x ≤ 1 / 3 ∨ y ≤ 1 / 3 ∨ z ≤ 1 / 3 := by linarith
    rcases h_min with hx | hy | hz
    · exact h_aux x y z h₀.1 h₀.2.1 h₀.2.2 h₁ hx
    · rw [mul_comm z, add_comm (y * z), add_comm (z * x), mul_comm x y] at ⊢
      exact h_aux y x z h₀.2.1 h₀.1 h₀.2.2 (by linarith) hy
    · rw [mul_comm y, add_comm (z * x), add_comm (x * y), mul_comm y z] at ⊢
      exact h_aux z y x h₀.2.2 h₀.2.1 h₀.1 (by linarith) hz

