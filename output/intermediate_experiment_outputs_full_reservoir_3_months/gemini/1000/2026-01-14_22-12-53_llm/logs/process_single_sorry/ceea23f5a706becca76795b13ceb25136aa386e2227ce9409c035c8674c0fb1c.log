    [TopologicalSpace N] [ChartedSpace H' N] [m' : IsManifold I' ∞ N]
    {f : M → N} {s : Set M} (hs : IsOpen s) : let _ := m.toDiffeology;
    let _ := m'.toDiffeology; DSmooth (s.restrict f) ↔ ContMDiffOn I I' ∞ f s := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine ⟨fun hf x hxs ↦ ?_,ContMDiffOn.dsmooth_restrict⟩
  refine (hs.contMDiffWithinAt_iff hxs).2 ?_
  let n := finrank ℝ E
  let e := (ContinuousLinearEquiv.ofFinrankEq (finrank_euclideanSpace ℝ (Fin n)).symm : EuclideanSpace ℝ (Fin n) ≃L[ℝ] E)
  have : ContMDiffAt (𝓘(ℝ, E)) I' ∞ (f ∘ (chartAt H x).symm ∘ I.symm) (I (chartAt H x x)) := by
    apply (contMDiffAt_iff_contMDiffAt_comp 𝓘(ℝ, E) (𝓡 n) I' (g := e.toContinuousLinearMap)).1
    let p_local := (chartAt H x).symm ∘ I.symm ∘ e
    let z := e.symm (I (chartAt H x x))
    obtain ⟨ρ, hρ_supp, hρ_id⟩ := exists_contDiff_bump_on_units (n := Fin n)
    let p : EuclideanSpace ℝ (Fin n) → M := fun w ↦
      if h : e (z + ρ w • w) + I (chartAt H x x) - e z ∈ I '' (chartAt H x).target ∩ I '' ((chartAt H x).source ∩ s)
