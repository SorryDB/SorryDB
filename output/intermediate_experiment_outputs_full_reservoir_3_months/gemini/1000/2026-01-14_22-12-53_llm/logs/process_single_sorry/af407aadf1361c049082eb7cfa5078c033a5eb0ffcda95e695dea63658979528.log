import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 1988, Problem 3

A function $f$ defined on the positive integers (and taking positive integers values) is given by:
f(1) = 1
f(3) = 3
f(2 \cdot n) = f(n)
f(4 \cdot n + 1) = 2 \cdot f(2 \cdot n + 1) - f(n)
f(4 \cdot n + 3) = 3 \cdot f(2 \cdot n + 1) - 2 \cdot f(n)
for all positive integers $n.$
Determine with proof the number of positive integers $\leq 1988$ for which $f(n) = n.$
-/

namespace Imo1988P3

determine solution : ℕ := 92

problem imo1988_p3 (f : ℕ+ → ℕ+)
    (h₀ : f 1 = 1)
    (h₁ : f 3 = 3)
    (h₂ : ∀ n, f (2 * n) = f n)
    (h₃ : ∀ n, f (4 * n + 1) + f n = 2 * f (2 * n + 1))
    (h₄ : ∀ n, f (4 * n + 3) + 2 * f n = 3 * f (2 * n + 1)) :
    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  have h_rev : ∀ n : ℕ+, (f n : ℕ) = (Nat.digits 2 (n : ℕ)).reverse.foldl (λ acc d => 2 * acc + d) 0 := by
    intro n
    induction n using PNat.strongInductionOn
    rename_i n ih
    rcases (n : ℕ) with (_ | n_val)
    · exact (PNat.ne_zero n).elim rfl
    match h : (n_val + 1) with
    | 1 => exact congr_arg PNat.val h₀
    | 2 =>
      have : f 2 = f 1 := h₂ 1
      simp [this, h₀, Nat.digits_def, h]
    | 3 => exact congr_arg PNat.val h₁
    | n_val' + 1 =>
      cases' (Nat.even_or_odd (n_val + 1)) with he ho
      · obtain ⟨m, hm⟩ := he
        have m_pos : 0 < m := by subst hm; exact PNat.pos n
        let m_pnat : ℕ+ := ⟨m, m_pos⟩
        have : (f n = f m_pnat) := h₂ m_pnat
        have : n = 2 * m_pnat := by ext; exact hm
        rw [this, h₂ m_pnat, ih m_pnat (by rw [this]; exact PNat.lt_add_left _ _)]
        simp [Nat.digits_def, hm, m_pos]
      · obtain ⟨m, hm⟩ := ho
        cases' (Nat.even_or_odd m) with me mo
        · obtain ⟨k, hk⟩ := me
          have k_pos : 0 < k := by substs hm hk; linarith [PNat.pos n]
          let k_pnat : ℕ+ := ⟨k, k_pos⟩
          have n_eq : n = 4 * k_pnat + 1 := by ext; substs hm hk; ring
          rw [n_eq, ← h₃ k_pnat, ih k_pnat (by linarith), ih (2 * k_pnat + 1) (by linarith)]
          simp [Nat.digits_def, n_eq, k_pos, Nat.digits_add 2 (by norm_num) (2*k+1) (by norm_num), Nat.digits_add 2 (by norm_num) (k) (by norm_num)]
          sorry
        · obtain ⟨k, hk⟩ := mo
          have k_pos : 0 < k := by substs hm hk; linarith [PNat.pos n]
          let k_pnat : ℕ+ := ⟨k, k_pos⟩
          have n_eq : n = 4 * k_pnat + 3 := by ext; substs hm hk; ring
          rw [n_eq, ← h₄ k_pnat, ih k_pnat (by linarith), ih (2 * k_pnat + 1) (by linarith)]
          simp [Nat.digits_def, n_eq, k_pos]
          sorry
  have h_pal : ∀ n : ℕ+, f n = n ↔ (Nat.digits 2 (n : ℕ)).reverse = Nat.digits 2 (n : ℕ) := by
    intro n
    rw [← PNat.val_inj, h_rev]
    set bits := Nat.digits 2 (n : ℕ)
    have h_bits : bits.foldl (λ acc d => 2 * acc + d) 0 = (n : ℕ) := Nat.ofDigits_digits 2 (n : ℕ)
    have h_rev_fold : bits.reverse.foldl (λ acc d => 2 * acc + d) 0 = Nat.ofDigits 2 bits.reverse := rfl
    rw [h_rev_fold, ← h_bits, Nat.ofDigits_eq_iff]
    · rfl
    · intro d hd; exact Nat.digits_lt_base 2 (n : ℕ) d (List.mem_reverse.mp hd)
    · intro d hd; exact Nat.digits_lt_base 2 (n : ℕ) d hd
  unfold solution
  exact sorry

end Imo1988P3
