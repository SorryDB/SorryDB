  letI : Fact (0 ≤ (1 / 2 : ℝ)) := ⟨by norm_num⟩
  letI : Fact ((1 / 2 : ℝ) ≤ 2) := ⟨by norm_num⟩
  let c : Sum (Fin n) (Fin n) → ℝ := Sum.elim (fun _ => 1) (fun _ => -1)
  let y : Sum (Fin n) (Fin n) → ℝ := Sum.elim x (-x)
  have hc : ∑ i, c i = 0 := by simp [c, Fintype.sum_sum_type]
  have h := IsGeneralizedNegativeType.summable_condition (p := 1 / 2) y c hc
  simp [Fintype.sum_sum_type, y, c, ← Real.sqrt_eq_rpow, dist_eq_norm, Real.norm_eq_abs, abs_sub_comm, abs_neg] at h
  linarith
