example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  have h_head (s : SymList a) : (fromSL s).head? = headSL s := by
    have ⟨as, bs, o⟩ := s; cases as <;> cases bs <;> simp [fromSL, headSL, *]
    · have := o.1 rfl; cases this <;> simp_all
    · have := o.2 rfl; cases this <;> simp_all
  have h_tail (s : SymList a) : (fromSL s).tail = fromSL (tailSL s) := by
    have ⟨as, bs, o⟩ := s; cases as with
    | nil =>
      cases bs with | nil => simp [tailSL, fromSL, nil]
      | cons b bs => simp [fromSL, tailSL, nil]; have := o.1 rfl; cases this <;> simp_all
    | cons a as =>
      by_cases ha : as = [] <;> simp [tailSL, ha, fromSL, splitInTwoSL]
  induction sl using dropWhileSL.induct with
  | h_1 s h => simp [dropWhileSL, h, fromSL, nil, List.isEmpty_iff.mp h.1, List.isEmpty_iff.mp h.2]
  | h_2 s h1 h2 => simp [headSL_none_iff_nilSL] at h2; simp [h2, nil] at h1
  | h_3 s hsl h1 h2 h3 ih =>
    rw [dropWhileSL]; simp [h1, h2, h3, ih]
    rw [List.head?_eq_some_iff.mp (h_head s ▸ h2), List.dropWhile_cons_of_pos, h_tail s]; exact h3
  | h_4 s hsl h1 h2 h3 =>
    rw [dropWhileSL]; simp [h1, h2, h3]
    rw [List.dropWhile_cons_of_neg]; · exact List.head?_eq_some_iff.mp (h_head s ▸ h2)
    · simp [h3]
