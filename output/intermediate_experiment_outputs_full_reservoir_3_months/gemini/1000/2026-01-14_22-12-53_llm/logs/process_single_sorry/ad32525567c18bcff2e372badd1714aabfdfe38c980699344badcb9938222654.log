@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  simp only [Set.mem_setOf_eq, Set.mem_setOf]
  constructor
  · rintro ⟨n, n_pos, A, B, hAB, hAcard, hAinter, hB, ⟨f, hfB, hfA⟩, rfl⟩
    let k (x : ℕ) : ℕ := (Finset.univ.filter (x ∈ A ·)).card
    have h1 : (Finset.univ : Finset (Fin (2 * n + 1))).sum (λ i ↦ (A i).card) = B.sum k := by
      simp [k, Finset.sum_comm, Finset.sum_filter]
    have h2 : (Finset.univ : Finset (Fin (2 * n + 1))).sum (λ i ↦ (Finset.univ.filter (λ j ↦ i < j)).sum (λ j ↦ (A i ∩ A j).card)) = B.sum (λ x ↦ (k x).choose 2) := by
      simp_rw [Finset.card_eq_sum_ones, Finset.sum_filter, Finset.sum_comm, ← Finset.card_eq_sum_ones, k, Nat.choose_two_right]
      simp_rw [Finset.sum_comm (s := Finset.univ), Finset.filter_filter]
      congr; ext x; simp [k]; ring
    have s1 : B.sum k = 2 * n * (2 * n + 1) := by rw [← h1]; simp [hAcard]
    have s2 : B.sum (λ x ↦ k x * (k x - 1)) = 2 * n * (2 * n + 1) := by
      rw [← 2 * h2]
      simp_rw [hAinter _ _ (ne_of_lt (by simp at ·; assumption)), Finset.sum_const, Finset.card_filter, Finset.card_univ, Fintype.card_fin]
      simp_rw [Finset.sum_range_reflect (λ i ↦ i) (2 * n + 1), Nat.sum_range_id]; ring
    have h_kx : ∀ x ∈ B, k x = 2 := by
      have : B.sum (λ x ↦ (k x - 2) * k x) = 0 := by simp_rw [mul_sub, ← s2, ← s1]; ring
      intro x hx; specialize hB x hx; rcases hB with ⟨i, j, hij, hi, hj⟩
      have : k x ≥ 2 := (Finset.card_le_card (show {i, j} ⊆ _ by simp [hi, hj])).trans_at_least (by simp [hij])
      have : (k x - 2) * k x = 0 := (Finset.sum_eq_zero_iff (λ x hx ↦ by
        have : k x ≥ 2 := by
          rcases hB x hx with ⟨i, j, hij, hi, hj⟩
          exact (Finset.card_le_card (show {i, j} ⊆ _ by simp [hi, hj])).trans_at_least (by simp [hij])
        exact Nat.mul_le_mul_right _ (Nat.sub_le_sub_right this 2))).1 this x hx
      omega
    have : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      rw [← Finset.sum_const (v := n), ← hfA, Finset.sum_comm]
      simp_rw [Finset.filter_filter, Finset.card_eq_sum_ones, Finset.sum_filter, ← Finset.card_eq_sum_ones]
      rw [Finset.sum_congr rfl (λ x hx ↦ (by by_cases hf : f x = 0 <;> simp [hf, h_kx x hx]))]
      simp [Finset.sum_filter]
    exact ⟨n_pos, Nat.even_mul.1 ⟨_, this.symm⟩ |>.1.resolve_right (by omega)⟩
  · rintro ⟨n_pos, n_even⟩
    obtain ⟨k, rfl⟩ := n_even
    let V := Fin (4 * k + 1)
    let E := (Finset.univ : Finset V).sym2.filter (λ x ↦ ¬x.IsDiag)
    let fE : Sym2 V ≃ Fin (E.card) := Fintype.equivFin E
    let B := Finset.univ (α := Fin E.card)
    let A (i : V) := (E.filter (i ∈ ·)).image fE
    let f (x : ℕ) := if h : x < E.card then (if (fE.symm ⟨x, h⟩).exists_rep (λ i j ↦ let d := (i.1 + 4*k+1 - j.1) % (4*k+1); d ≤ k ∨ d ≥ 3*k+1) then 0 else 1) else 1
    refine ⟨2 * k, n_pos, A, B, (by simp), (by intro i; simp [A, E]; sorry), (by intro i j hij; simp [A, E, hij]; sorry), (by intro x hx; simp [B, A, E]; sorry), ⟨f, (by intro x hx; simp [f]), (by intro i; sorry)⟩, rfl⟩

