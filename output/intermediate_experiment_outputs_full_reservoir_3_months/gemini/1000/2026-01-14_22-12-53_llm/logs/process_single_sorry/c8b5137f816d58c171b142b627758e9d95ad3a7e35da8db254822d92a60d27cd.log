import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  apply Nat.dvd_of_forall_padicValNat_le
  · exact Nat.mul_pos (Nat.mul_pos m.factorial_pos n.factorial_pos) (m + n).factorial_pos
  · intro p hp
    simp only [padicValNat.mul p hp.1, padicValNat.factorial p hp.1, ← Finset.sum_add_distrib]
    set N := 2 * m + 2 * n
    have h (k : ℕ) (hk : k ≤ N) : ∑ i in Finset.Ico 1 (k + 1), k / p ^ i = ∑ i in Finset.Ico 1 (N + 1), k / p ^ i := by
      rw [← Finset.sum_Ico_consecutive _ (Nat.le_succ_of_le hk) (Nat.succ_le_succ (Nat.le_refl N))]
      simp only [Finset.sum_eq_zero_iff, Finset.mem_Ico, Nat.div_eq_zero_iff, and_imp]
      intro i hi _
      apply Nat.lt_of_le_of_lt hk
      exact Nat.lt_of_lt_of_le (Nat.lt_pow_self hp.1.1.two_le i) (Nat.pow_le_pow_right hp.1.1.pos hi)
    simp [h m (by omega), h n (by omega), h (m + n) (by omega), h (2 * m) (by omega), h (2 * n) (by omega)]
    apply Finset.sum_le_sum
    intro i _
    set d := p ^ i
    have : (m % d + n % d) / d ≤ (2 * (m % d)) / d + (2 * (n % d)) / d := by
      have : m % d + n % d ≤ 2 * (m % d) + 2 * (n % d) := by omega
      have : (m % d + n % d) / d ≤ (2 * (m % d) + 2 * (n % d)) / d := Nat.div_le_div_right this
      exact Nat.le_trans this (Nat.div_add_div_le_div _ _ _)
    zify [Nat.div_eq_sub_mod m d, Nat.div_eq_sub_mod n d, Nat.div_eq_sub_mod (m + n) d,
      Nat.div_eq_sub_mod (2 * m) d, Nat.div_eq_sub_mod (2 * n) d]
    field_simp [Nat.pos_pow_of_pos _ hp.1.1.pos]
    zify at this; omega

