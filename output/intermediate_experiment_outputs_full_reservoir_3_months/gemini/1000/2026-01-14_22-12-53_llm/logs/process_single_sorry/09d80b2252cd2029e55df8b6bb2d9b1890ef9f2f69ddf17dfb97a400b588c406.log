lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra hφψ;
  replace ⟨hφψ, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφψ;
  let Δ := insert φ (insert ψ Γ)
  have hΔ : ↑Δ ⊆ construction_omega T hT := by
    intro x hx; simp [Δ] at hx;
    rcases hx with (rfl | rfl | hx)
    · exact hφ
    · exact hψ
    · exact monotone_construction (le_refl _) (hΓ₁ hx)
  obtain ⟨δ, hδ, hmax⟩ := Δ.exists_max_image encode (by simp [Δ])
  have hδ_not : δ ∉ construction_omega T hT := by
    apply not_of_mem_construction_omega (Γ := Δ.erase δ)
    · intro x hx
      have hxe : encode x < encode δ := (hmax x (Finset.mem_of_mem_erase hx)).lt_of_ne (fun h => Finset.not_mem_erase x Δ (h ▸ hx))
      obtain ⟨i, hi⟩ := by simpa [construction_omega] using hΔ (Finset.mem_of_mem_erase hx)
      induction i with
      | zero => exact monotone_construction (Nat.zero_le _) hi
      | succ i ih =>
        dsimp [construction] at hi; split at hi <;> try { exact ih hi }
        split_ifs at hi; rcases Set.mem_insert_iff.mp hi with (rfl | h_in)
        · exact monotone_construction hxe (by dsimp [construction, encodek]; split_ifs <;> simp)
        · exact ih h_in
    · apply T.imp_closed _ hΓ₂; apply Logic.iff_provable.mp; simp [Δ]; intro x hx;
      rcases hx with (rfl | rfl | hx) <;> simp
  exact hδ_not (hΔ hδ)
