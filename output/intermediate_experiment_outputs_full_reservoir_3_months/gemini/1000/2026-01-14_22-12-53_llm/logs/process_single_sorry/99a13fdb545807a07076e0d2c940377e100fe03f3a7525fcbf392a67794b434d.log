lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  let h_prog := hX1.adapted.progMeasurable_of_rightContinuous hX2
  let hY := hX1.submartingale_convex_comp (convexOn_norm convex_univ)
    continuous_norm (fun t ↦ (hX1.integrable t).norm)
  have h_ui : UniformIntegrable (fun τ : {T | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} ↦ stoppedValue X τ.1) 1 P ↔
      UniformIntegrable (fun τ ↦ stoppedValue (fun t ω ↦ ‖X t ω‖) τ.1) 1 P := by
    convert uniformIntegrable_iff_norm (fun τ ↦ (stronglyMeasurable_stoppedValue h_prog τ.2.1 τ.2.2).aestronglyMeasurable)
    ext τ ω; simp [stoppedValue]
  rw [uniformIntegrable_iff_norm, ← hY.classD_iff_uniformIntegrable (fun ω t ↦ (hX2 ω t).norm) (fun t ω ↦ norm_nonneg _)]
  exact ⟨fun h ↦ ⟨h_prog.norm, h_ui.mp h.uniformIntegrable⟩, fun h ↦ ⟨h_prog, h_ui.mpr h.uniformIntegrable⟩⟩
