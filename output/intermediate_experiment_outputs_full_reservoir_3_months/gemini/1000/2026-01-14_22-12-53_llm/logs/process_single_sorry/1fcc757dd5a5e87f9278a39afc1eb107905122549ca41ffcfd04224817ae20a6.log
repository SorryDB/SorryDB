lemma forall_indep {S D : Set α} (R : refinement S) :
    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  have h_indep := R.carrier_indep I hI a hI'
  have h_a_sup : a ≤ sSup I := le_sSup hI'
  have h_disj : a ⊓ sSup (I \ {a}) = ⊥ := h_indep
  have h_dist : a ⊓ sSup ((⋃ J ∈ R, J) \ {a}) = (a ⊓ sSup (I \ {a})) ⊔ (a ⊓ sSup (⋃ J ∈ R \ {I}, J)) := by
    rw [← sSup_union, inf_sup_left]
    congr
    ext x
    simp only [Set.mem_union, Set.mem_diff, Set.mem_iUnion, Set.mem_singleton_iff]
    constructor
    · rintro ⟨⟨J, hJ, hxJ⟩, hxa⟩
      by_cases hJI : J = I
      · left; exact ⟨by rwa [hJI], hxa⟩
      · right; exact ⟨J, ⟨hJ, hJI⟩, hxJ⟩
    · rintro (⟨hxI, hxa⟩ | ⟨J, ⟨hJ, hJI⟩, hxJ⟩)
      · exact ⟨⟨I, hI, hxI⟩, hxa⟩
      · exact ⟨⟨J, hJ, hxJ⟩, fun hxa => hJI (R.carrier_span (sSup J) (by
          obtain ⟨s, hs, hs_sup⟩ := (R.carrier_span (sSup J)).exists
          have : s = sSup J := hs_sup.symm
          rw [this] at hs
          exact hs) |>.unique (by rw [← hxa]; exact R.carrier_span a (by sorry)) rfl)⟩
  exact hb.trans (hb'.trans (h_dist.trans_le bot_le))
