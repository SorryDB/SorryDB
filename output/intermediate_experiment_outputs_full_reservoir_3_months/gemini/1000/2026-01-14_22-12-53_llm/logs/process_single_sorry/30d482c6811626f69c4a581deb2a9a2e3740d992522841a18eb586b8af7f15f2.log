lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  -- Each of the n-1 agents j ≠ k must provide their secret to k and receive k's secret.
  -- In a noHo sequence, these actions require distinct calls unless k is a participant.
  -- Each call involving k (v S k such calls) can both inform k and spread k's secret.
  -- All other calls in S can contribute to at most one of these two processes.
  -- Thus, S.length ≥ (n - 1) + (n - 1) - v S k.
  sorry
```
