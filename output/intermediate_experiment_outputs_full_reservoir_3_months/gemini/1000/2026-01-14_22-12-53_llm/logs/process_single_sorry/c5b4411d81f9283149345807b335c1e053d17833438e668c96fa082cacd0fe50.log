import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let E := {e : Finset ℕ | e.card = 2 ∧ e ⊆ S ∧ ∃ x > 0, (e.min' (by aesop) : ℕ) * (e.max' (by aesop) : ℕ) = x^2 + x + k}
  have hE1 : ∀ i : Fin S.card, {p₁ i, p₁ (i + 1)} ∈ E := by
    intro i
    have : NeZero S.card := ⟨i.pos.ne'⟩
    obtain ⟨x, hx, hx2⟩ := hp₁ i
    refine ⟨?_, ?_, ⟨x, hx, ?_⟩⟩
    · rw [Finset.card_doubleton]; intro h; exact (hS (p₁ i) (p₁ i).2).2.ne_one (p₁.injective.p_eq_p_iff_i_eq_i_in_circle hp₁ i h)
    · simp [Finset.insert_subset_iff]; exact ⟨(p₁ i).2, (p₁ (i + 1)).2⟩
    · rw [hx2]; exact (mul_comm _ _).trans (congr_arg _ (by simp [Finset.min'_insert, Finset.max'_insert])) -- Simplified
  have h_deg : ∀ p ∈ S, (E.filter (λ e => p ∈ e)).card ≤ 2 := by
    intro p hp
    let N := E.filter (λ e => p ∈ e)
    by_contra h_count
    simp only [not_le, Finset.card_gt_two_iff] at h_count
    obtain ⟨e1, he1, e2, he2, e3, he3, h12, h13, h23⟩ := h_count
    let q1 := (e1 \ {p}).min' (by aesop)
    let q2 := (e2 \ {p}).min' (by aesop)
    let q3 := (e3 \ {p}).min' (by aesop)
    sorry
  sorry
