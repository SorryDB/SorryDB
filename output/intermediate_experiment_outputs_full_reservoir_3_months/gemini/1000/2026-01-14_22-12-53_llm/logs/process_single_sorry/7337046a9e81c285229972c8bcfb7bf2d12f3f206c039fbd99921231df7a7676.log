/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') (fun h ↦ ?_)
  rcases H with ⟨N, hN, hne⟩
  have h_sub : B N hN ⊆ D := fun b hb ↦ by
    have hb' : b ∈ refinement B hB hB' hB'' := Set.mem_iUnion.2 ⟨N, Set.mem_iUnion.2 ⟨hN, hb⟩⟩
    rwa [← h] at hb'
  have h_B_subset : B N hN ⊆ {N} := by
    intro b hb
    by_contra hbn
    have h_le : b ≤ sSup (D \ {b}) :=
      le_trans (hB N hN ▸ le_sSup hb) (le_sSup (Set.mem_diff_of_mem hN (Ne.symm hbn)))
    exact hB'' N hN (D.sSupIndep b (h_sub hb) |>.eq_bot_of_le h_le ▸ hb)
  rcases Set.subset_singleton_iff_eq.1 h_B_subset with h_empty | h_eq
  · rw [hB N hN, h_empty, sSup_empty] at hN
    exact D.not_bot_mem hN
  · exact hne h_eq
```
