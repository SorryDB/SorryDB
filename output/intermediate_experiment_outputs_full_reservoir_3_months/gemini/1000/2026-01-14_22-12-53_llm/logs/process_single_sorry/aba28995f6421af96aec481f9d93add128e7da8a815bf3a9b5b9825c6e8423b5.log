lemma existsE : ∃ E : Set (D_𝔸), IsCompact E ∧
    ∀ φ : D_𝔸 ≃ₜ+ D_𝔸, addEquivAddHaarChar φ = 1 → ∃ e₁ ∈ E, ∃ e₂ ∈ E,
    e₁ ≠ e₂ ∧ φ e₁ - φ e₂ ∈ Set.range (Algebra.TensorProduct.includeLeft : D →ₐ[K] D_𝔸) := by
  set Γ := (Algebra.TensorProduct.includeLeft : D →ₐ[K] D_𝔸).toAddMonoidHom.range
  obtain ⟨V, hV⟩ := Measure.exists_isAddFundamentalDomain Γ (addHaarMeasure : Measure D_𝔸)
  haveI : CompactSpace (D_𝔸 ⧸ Γ) := by
    let e := D𝔸_iso_top K D
    let e' : D_𝔸 ≃ₜ+ (Fin (Module.finrank K D) → AdeleRing (𝓞 K) K) :=
      { e.toHomeomorph with map_add' := e.toLinearEquiv.map_add' }
    exact Homeomorph.compactSpace_iff (QuotientAddGroup.congr _ _ e' (D_iso K D).toAddEquiv (by ext; simp [incl_Kn_𝔸Kn]))
  obtain ⟨E, hEc, hEm⟩ := Measure.exists_isCompact_measure_gt hV.measure_ne_top
  use E, hEc; intro φ hφ
  have hφE : addHaarMeasure (φ '' E) = addHaarMeasure E := by
    rw [← Measure.map_apply φ.continuous.measurable hEc.measurableSet,
      addEquivAddHaarChar_map_addHaarMeasure, hφ, one_smul]
  have : addHaarMeasure (φ '' E) > addHaarMeasure V := hEm.trans_eq hφE.symm
  obtain ⟨_, ⟨e₁, he₁, rfl⟩, _, ⟨e₂, he₂, rfl⟩, hne, hsub⟩ :=
    hV.exists_ne_sub_mem_range_of_measure_gt this (hEc.image φ.continuous).measurableSet
  exact ⟨e₁, he₁, e₂, he₂, φ.injective.ne hne, hsub⟩
