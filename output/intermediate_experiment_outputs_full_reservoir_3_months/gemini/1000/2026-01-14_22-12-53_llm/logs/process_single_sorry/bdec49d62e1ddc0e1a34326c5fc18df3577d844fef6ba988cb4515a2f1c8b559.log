import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  simp only [answer, Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · rintro ⟨hpos, hU⟩
    have h_le (x : ℝ+) : (x : ℝ) * f x ≤ 1 := by
      obtain ⟨y, hy, -⟩ := hU x
      have := Real.geom_mean_le_arith_mean_two ((x : ℝ) * f y) ((y : ℝ) * f x) (by positivity) (by positivity)
      rw [hy] at this
      exact (sq_le_one_iff_abs_le_one.mp (pow_le_one_of_le_one (by positivity) this 2)).2
    ext x
    have h_eq (x : ℝ+) : (x : ℝ) * f x = 1 := by
      refine le_antisymm (h_le x) (by_contra fun hlt => ?_)
      obtain ⟨y, hy, hU'⟩ := hU x
      have : y = x := hU' x (by linarith [h_le x])
      rw [this, ← two_mul] at hy
      linarith
    exact (eq_one_div_iff (by positivity)).mpr (h_eq x)
  · rintro rfl
    simp only [div_pos, Subtype.coe_pos, zero_lt_one, true_and]
    intro x
    use x
    simp only [Subtype.coe_mk, div_self, mul_one, add_le_iff_le_y, le_refl, true_and]
    intro y hy
    exact (add_div_self_div_self_eq_two (by positivity) (by positivity)).mp
      (le_antisymm hy (two_le_add_div_self_div_self (by positivity) (by positivity)))
