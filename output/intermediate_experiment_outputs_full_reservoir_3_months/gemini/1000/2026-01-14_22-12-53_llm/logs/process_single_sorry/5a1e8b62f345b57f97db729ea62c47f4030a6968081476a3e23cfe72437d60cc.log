import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
A function $f$ is defined on the positive integers by: $f(1)=1, f(3)=3, f(2n)=f(n),f(4n+1)=2f(2n+1)-f(n)$, and $f(4n+3)=3f(2n+1)-2f(n)$ for all positive integers $n$. Determine the number of positive integers $n\le1988$ for which $f(n)=n$.
Solution: 92
-/
@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) : ℕ := ((n.digits 2).foldl (fun acc b => 2 * acc + b) 0)
  have hf : ∀ n > 0, f n = g n := by
    intro n hn
    induction n using Nat.strongInductionOn with
    | h n ih =>
      if n1 : n = 1 then rw [n1, h₁]; rfl
      else if n3 : n = 3 then rw [n3, h₂]; rfl
      else if ne : n % 2 = 0 then
        have : n = 2 * (n / 2) := (Nat.mul_div_cancel' (Nat.dvd_of_mod_eq_zero ne)).symm
        have pos : n / 2 > 0 := Nat.div_pos (Nat.pos_of_not_le (by simp [n1, n3, ne] at *; linarith)) (by norm_num)
        rw [this, h₃ (n / 2) pos, ih (n / 2) (Nat.div_lt_self hn (by norm_num)) pos]; rfl
      else if n41 : n % 4 = 1 then
        let k := n / 4; have kn : k = n / 4 := rfl
        have nk : n = 4 * k + 1 := (Nat.div_add_mod n 4).symm.trans (by rw [n41, Nat.mul_comm])
        have kp : k > 0 := by subst nk; simp at *; linarith
        have klt : k < n := by subst nk; linarith
        have k21lt : 2 * k + 1 < n := by subst nk; linarith
        rw [nk, h₄ k kp, ih (2 * k + 1) k21lt (by linarith), ih k klt kp]; rfl
      else
        have n43 : n % 4 = 3 := by
          have : n % 4 < 4 := Nat.mod_lt _ (by norm_num)
          interval_cases h : n % 4 <;> try contradiction; exact h
        let k := n / 4; have kn : k = n / 4 := rfl
        have nk : n = 4 * k + 3 := (Nat.div_add_mod n 4).symm.trans (by rw [n43, Nat.mul_comm])
        have kp : k > 0 := by subst nk; simp at *; linarith
        have klt : k < n := by subst nk; linarith
        have k21lt : 2 * k + 1 < n := by subst nk; linarith
        rw [nk, h₅ k kp, ih (2 * k + 1) k21lt (by linarith), ih k klt kp]; rfl
  have hg : ∀ n > 0, g n = n ↔ n.digits 2 = (n.digits 2).reverse := by
    intro n hn
    have hval : n = (n.digits 2).foldr (fun b acc => 2 * acc + b) 0 := Nat.ofDigits_digits 2 n
    have hgval : g n = (n.digits 2).foldl (fun acc b => 2 * acc + b) 0 := rfl
    rw [hgval, hval, ← List.foldl_reverse]
    constructor
    · intro h
      have : (n.digits 2).reverse.getLast? = (n.digits 2).getLast? := by
        have : n % 2 ≠ 0 := by
          by_contra h2
          have : (n.digits 2).head? = some 0 := Nat.digits_head_zero hn (by norm_num) h2
          have : g n % 2 = 1 := by
            have : (n.digits 2).getLast? = some 1 := by rw [Nat.digits_last_not_zero 2 hn (by norm_num)]; rfl
            have : (n.digits 2).reverse.head? = some 1 := by rw [List.head?_reverse, this]
            sorry
          sorry
        sorry
      sorry
    · intro h; rw [h]
  have hcard : (Finset.filter (fun n => (n.digits 2) = (n.digits 2).reverse) (Finset.Icc 1 1988)).card = 92 := by decide
  rw [Finset.filter_congr (fun n hn => by rw [hf n (Finset.mem_Icc.1 hn).1, hg n (Finset.mem_Icc.1 hn).1])]
  exact hcard
