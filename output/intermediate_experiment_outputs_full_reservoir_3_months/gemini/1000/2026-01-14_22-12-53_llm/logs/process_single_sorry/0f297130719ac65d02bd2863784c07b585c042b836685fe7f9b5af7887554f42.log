/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  simp only [ContinuousLinearMap.smul_apply, deriv, LinearMap.coe_mk, AddHom.coe_mk,
    ContinuousLinearMap.coe_mk', SpaceTime.distDeriv_comp_lorentz_action]
  simp_rw [Finset.sum_smul, smul_smul, smul_eq_mul, smul_tmul, tmul_smul,
    ← mul_assoc, mul_comm (Λ.1 _ _), mul_assoc, ← smul_eq_mul, ← tmul_smul, ← smul_tmul]
  simp_rw [Finset.sum_comm, ← sum_tmul, ← tmul_sum, ← Lorentz.CoVector.smul_basis,
    ← Lorentz.Vector.smul_basis, ← Tensorial.smul_prod, ← Finset.smul_sum,
    ← Tensorial.smulLinearMap_apply]
  rfl
```
