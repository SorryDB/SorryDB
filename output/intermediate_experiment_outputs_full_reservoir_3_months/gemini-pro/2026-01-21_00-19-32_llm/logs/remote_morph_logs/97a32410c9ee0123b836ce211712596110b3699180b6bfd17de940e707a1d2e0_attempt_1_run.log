    apply ContinuousLinearMap.opNorm_le_bound _ zero_le_one (fun f => ?_)
    simp only [one_mul]
    exact le_of_eq (LinearIsometryEquiv.norm_map (ZeroAtInftyContinuousMap.liftZeroAtInfty (spectrum ℂ a) ℂ).symm f)
  · positivity
