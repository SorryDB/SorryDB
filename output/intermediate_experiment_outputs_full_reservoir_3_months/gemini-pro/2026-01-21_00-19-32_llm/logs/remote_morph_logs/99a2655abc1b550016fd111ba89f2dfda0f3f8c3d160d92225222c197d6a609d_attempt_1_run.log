noncomputable def IntegralLattice.tensorAdelesContinuousEquivRestrictedProduct :
    (IntegralLattice ℤ ℚ V) ⊗[ℤ] AdeleRing (𝓞 ℚ) ℚ ≃L[ℤ]
    ((IntegralLattice ℤ ℚ V) ⊗[ℤ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [(IntegralLattice ℤ ℚ V) ⊗[ℤ] v.adicCompletion ℚ,
        (LinearMap.range (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).toIntSubmodule.subtype))]) := {
  __ := IntegralLattice.tensorAdelesEquivRestrictedProduct V
  /-
  Continuity will follow from the fact that
  (restricted product of V_i)^n = restricted product of (V_i^n)
  is a homeo -- do we have this?
  -/
  continuous_toFun := by
    let b := IntegralLattice.basis ℤ ℚ V
    apply Module.Finite.continuous_of_basis b
    intro i
    dsimp
    apply Continuous.prod_mk
    · exact (IsModuleTopology.continuous_smul (R := ℝ)).comp
        (Continuous.prod_map AdeleRing.continuous_project_infinite continuous_const)
    · apply RestrictedProduct.continuous_iff_continuous_comp.mpr
      intro p
      exact (IsModuleTopology.continuous_smul (R := p.adicCompletion ℚ)).comp
        (Continuous.prod_map (AdeleRing.continuous_project_finite_adic p) continuous_const)
  continuous_invFun := by
    let b := IntegralLattice.basis ℤ ℚ V
    apply Continuous.add
    · apply (Module.Finite.continuous_of_basis b _).mpr (fun i ↦ _)
      exact AdeleRing.continuous_algebraMap_infinite.comp (Module.Finite.continuous_coord b i)
    · apply (RestrictedProduct.continuous_of_continuous_comp _ _).mpr (fun p ↦ _)
      apply (Module.Finite.continuous_of_basis b _).mpr (fun i ↦ _)
      exact (AdeleRing.continuous_algebraMap_finite p).comp (Module.Finite.continuous_coord b i)
}
