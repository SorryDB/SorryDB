              (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                      v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range
    (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
              (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                      v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range :=
    sorry
  rw [MeasureTheory.addEquivAddHaarChar_restrictedProductCongrRight _ hφ]
  let d : ℚˣ := Units.mk0 (LinearMap.det φ.toLinearMap) (LinearMap.det_ne_zero_of_isUnit φ.isUnit)
  have := MeasureTheory.ringHaarChar_adeles_units_rat_eq_one d
  rw [MeasureTheory.ringHaarChar_adeles_rat] at this
  rw [← this]
  congr 1
  · rw [MeasureTheory.addEquivAddHaarChar_continuousLinearEquiv]
