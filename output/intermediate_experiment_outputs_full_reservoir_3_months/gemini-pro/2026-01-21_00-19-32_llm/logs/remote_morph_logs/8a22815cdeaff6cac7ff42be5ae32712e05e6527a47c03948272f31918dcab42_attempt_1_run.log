      ContinuousLinearEquiv.coe_mk, LinearEquiv.baseChange_toLinearMap]
    exact (LinearMap.det_baseChange φ.toLinearMap (InfiniteAdeleRing ℚ)).symm
  · apply finprod_congr
    intro v
