lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  have hX_n : UniformIntegrable (fun i ↦ μ[X n | (hτ i).measurableSpace]) 1 μ :=
    (martingale_condExp X n).uniformIntegrable_stoppedValue τ hτ (fun _ _ ↦ le_rfl)
  have hX_bot : UniformIntegrable (fun i ↦ μ[X ⊥ | (hτ i).measurableSpace]) 1 μ :=
    (martingale_condExp X ⊥).uniformIntegrable_stoppedValue τ hτ (fun _ _ ↦ le_rfl)
  refine uniformIntegrable_of_dominated (hX_n.norm.add hX_bot.norm)
    (fun i ↦ (hX.stronglyMeasurable_stoppedValue (hτ i) (hτ_le i)).aestronglyMeasurable)
    (fun i ↦ ?_)
  filter_upwards [stoppedValue_ae_le_condExp_of_le hX (hτ i) (hτ_le i),
    stoppedValue_ae_ge_condExp_of_le hX (isStoppingTime_const 𝓕 ⊥) (hτ i) (fun _ ↦ bot_le)] with ω hle hge
  rw [norm_eq_abs, abs_le]
  exact ⟨(le_abs_self _).trans (hge.trans (le_add_of_nonneg_left (norm_nonneg _))),
    hle.trans ((le_abs_self _).trans (le_add_of_nonneg_right (norm_nonneg _)))⟩
```
