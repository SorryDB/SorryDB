lemma existsE : ∃ E : Set (D_𝔸), IsCompact E ∧
    ∀ φ : D_𝔸 ≃ₜ+ D_𝔸, addEquivAddHaarChar φ = 1 → ∃ e₁ ∈ E, ∃ e₂ ∈ E,
    e₁ ≠ e₂ ∧ φ e₁ - φ e₂ ∈ Set.range (Algebra.TensorProduct.includeLeft : D →ₐ[K] D_𝔸) := by
  let Γ := Set.range (Algebra.TensorProduct.includeLeft : D →ₐ[K] D_𝔸)
  let Γg := AddSubgroup.fromCommAg Γ _
  have h_comm : (Aux.D𝔸_iso_top K D).toAddMonoidHom.comp (Algebra.TensorProduct.includeLeft : D →+ D_𝔸) =
      (Aux.incl_Kn_𝔸Kn K D).toAddMonoidHom.comp (Aux.D_iso K D).toAddMonoidHom := by
    ext; simp [Aux.incl_Kn_𝔸Kn, Aux.D𝔸_iso_top, ← Algebra.algebraMap_eq_smul_one]
  have h_map : Γg.map (Aux.D𝔸_iso_top K D).toAddEquiv =
      AddSubgroup.fromCommAg (Set.range (Aux.incl_Kn_𝔸Kn K D)) _ := by
    ext x
    simp only [Γg, AddSubgroup.map_fromCommAg, AddEquiv.toAddMonoidHom_eq_coe,
      AddSubgroup.mem_fromCommAg, Set.mem_range, AddEquiv.coe_toAddMonoidHom]
    rw [← Set.range_comp, h_comm, Set.range_comp, (Aux.D_iso K D).surjective.range_eq, Set.image_univ]
  have : CompactSpace (D_𝔸 ⧸ Γg) := by
    refine QuotientAddGroup.compactSpace_of_equiv (Aux.D𝔸_iso_top K D).toAddEquiv h_map
    infer_instance
  have h_finite : volume (D_𝔸 ⧸ Γg) < ⊤ := MeasureTheory.Measure.haar_quotient_finite_of_isCompact _
  obtain ⟨E, hE_comp, hE_meas⟩ : ∃ E, IsCompact E ∧ volume (D_𝔸 ⧸ Γg) < volume E := by
    have h_univ : volume (Set.univ : Set D_𝔸) = ⊤ := MeasureTheory.Measure.haar_univ_of_isCocompact Γg
    have := MeasureTheory.Measure.innerRegular_haar (G := D_𝔸)
    rw [MeasureTheory.InnerRegular.measure_univ_eq_iSup] at this
    simp only [gt_iff_lt, lt_top_iff_ne_top, ne_eq, h_finite.ne, not_false_eq_true,
      lt_iSup_iff, exists_prop, h_univ] at this
    exact this _ h_finite
  refine ⟨E, hE_comp, fun φ hφ ↦ ?_⟩
  have h_vol : volume (φ '' E) = volume E := by
    rw [MeasureTheory.Measure.addEquiv_map_apply φ, addEquivAddHaarChar_eq_iff_map_eq.1 hφ]
  have h_gt : volume (D_𝔸 ⧸ Γg) < volume (φ '' E) := by rwa [h_vol]
  obtain ⟨x, hx, y, hy, hxy, hdiff⟩ := MeasureTheory.AddGroup.blichfeldt (φ '' E)
    (hE_comp.image φ.continuous).measurableSet h_gt
  obtain ⟨e₁, he₁, rfl⟩ := (Set.mem_image _ _ _).1 hx
  obtain ⟨e₂, he₂, rfl⟩ := (Set.mem_image _ _ _).1 hy
  exact ⟨e₁, he₁, e₂, he₂, hxy, hdiff⟩
