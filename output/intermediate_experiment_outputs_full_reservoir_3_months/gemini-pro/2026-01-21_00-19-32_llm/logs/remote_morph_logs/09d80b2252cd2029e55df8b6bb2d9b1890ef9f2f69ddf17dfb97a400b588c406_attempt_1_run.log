lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra hφψ;
  replace ⟨hφψ, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφψ;

  have consistent : ∀ i (S : Finset (Formula ℕ)), ↑S ⊆ construction T hT i → S.conj ➝ ξ ∉ T.theory := by
    intro i; induction i with
    | zero =>
      intro S hS hC;
      apply hT;
      apply T.mem_trans _ hC;
      induction S using Finset.induction_on with
      | empty => simp; apply T.mem_of_provable; apply impId;
      | insert a s ha ih =>
        simp_all [Set.subset_def];
        apply T.imp_closed (ih hS.2);
        apply T.imp_closed (hS.1 a (by simp));
        apply T.mem_of_provable;
        grind;
    | succ i ih =>
      intro S hS hC;
      simp [construction] at hS;
      split at hS;
      . split_ifs at hS with h;
        . rename_i δ;
          rw [Set.subset_insert_iff] at hS;
          by_cases hδ : δ ∈ S;
          . let S' := S.erase δ;
            have : S'.conj ⋏ δ ➝ ξ ∈ T.theory := by
              apply T.imp_closed hC;
              apply T.mem_of_provable;
              rw [←Finset.insert_erase hδ, Finset.conj_insert (Finset.not_mem_erase δ S)];
              grind;
            refine h S' (fun x hx => ?_) this;
            rcases hS x (Finset.mem_erase.mp hx).2 with rfl | h';
            . exfalso; exact (Finset.mem_erase.mp hx).1 rfl;
            . assumption;
          . exact ih S (fun x hx => (hS x hx).resolve_left (mt (· ▸ hx) hδ)) hC;
        . exact ih S hS hC;
      . exact ih S hS hC;

  let m := max (encode (φ ⋏ ψ)) (max (encode φ + 1) (encode ψ + 1));
  let S := insert φ (insert ψ Γ);
  have hS : ↑S ⊆ construction T hT m := by
    intro x hx; simp [S] at hx;
    rcases hx with rfl | rfl | hx;
    . refine monotone_construction (le_trans (le_max_left _ _) (le_max_right _ _)) ?_;
      rcases of_mem_construction_omega hφ with h | h;
      . apply subset_construction_add (j := encode φ + 1) (i := 0); exact h;
      . simp [construction]; split_ifs; exact Set.mem_insert _ _; exact (by contradiction);
    . refine monotone_construction (le_trans (le_max_right _ _) (le_max_right _ _)) ?_;
      rcases of_mem_construction_omega hψ with h | h;
      . apply subset_construction_add (j := encode ψ + 1) (i := 0); exact h;
      . simp [construction]; split_ifs; exact Set.mem_insert _ _; exact (by contradiction);
    . refine monotone_construction (le_max_left _ _) (hΓ₁ hx);

  apply consistent m S hS;
  apply T.imp_closed (φ := Γ.conj ⋏ φ ⋏ ψ);
  . apply T.mem_of_provable;
    simp [S]; grind;
  . assumption;
