theorem padicEquiv_bijOn (v : HeightOneSpectrum (𝓞 ℚ)) :
    Set.BijOn (IsDedekindDomain.HeightOneSpectrum.padicEquiv v) (v.adicCompletionIntegers ℚ)
      (PadicInt.subring v.natGenerator) := by
  rw [Set.BijOn, Set.mapsTo_iff, Set.surjOn_iff]
  simp_rw [PadicInt.mem_subring, ← Padic.isIntegral_iff_norm_le_one,
    ← map_isIntegral_iff (padicEquiv v), ← v.mem_adicCompletionIntegers_iff_isIntegral]
  exact ⟨fun _ ↦ id, (padicEquiv v).injective.injOn _, fun x h ↦
    ⟨(padicEquiv v).symm x, by simpa using h, (padicEquiv v).apply_symm_apply x⟩⟩
```
