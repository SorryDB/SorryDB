```lean
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [TopologicalGroup.discreteTopology_iff_isOpen_singleton 1]
  let V : Set Circle := {z | 0 < z.val.re}
  have : {1} = {f : PontryaginDual M | Set.MapsTo f Set.univ V} := by
    ext f; simp [Set.MapsTo, V]
    refine ⟨fun h x ↦ h ▸ by norm_num, fun h ↦ ?_⟩
    ext x
    by_contra hx
    obtain ⟨n, hn⟩ := Circle.exists_norm_pow_sub_one_ge_sqrt_two hx
    have : (f x ^ n).val.re ≤ 0 := by
      have : 2 ≤ ‖(f x ^ n : ℂ) - 1‖ ^ 2 := (Real.sqrt_le_iff.mp hn).2
      rw [Complex.norm_sq_sub, Complex.norm_sq_one, Complex.norm_sq_eq_abs_sq, Circle.abs_coe] at this
      linarith
    exact not_lt_of_le this (map_pow f x n ▸ h (x ^ n))
  rw [this]
  exact compactOpen.isOpen_setOf_maps_to isCompact_univ (continuous_re.isOpen_preimage _ isOpen_Ioi)
```
