def LoopWalkSetoid : Setoid (ClosedLoopWalk (K n)) where
  r := LoopWalkEquiv n
  iseqv := by
    constructor
    · intro x
      let s := Equiv.refl (Fin n)
      unfold LoopWalkEquiv
      use s
      have hs (y : Fin n):  s y = y := by
        unfold s
        simp
      use hs x.1
      dsimp [s] at *
      simp only [id_eq, Equiv.coe_refl]
      have map_id {u v} (p : (K n).LoopWalk u v) : p.map (K n) (permMap' n (Equiv.refl (Fin n))) = p := by
        induction p <;> simp [SimpleGraph.LoopWalk.map, *]
      apply map_id
    · intro x y h
      unfold LoopWalkEquiv at *
      rcases h with ⟨s, hs, h⟩
      use s.symm, (by rw [←hs]; simp)
      subst_vars
      simp only [permMapWalk] at *
      have map_comp {u v} (p : (K n).LoopWalk u v) (f g : K n →g K n) : (p.map (K n) f).map (K n) g = p.map (K n) (g.comp f) := by
        induction p <;> simp [SimpleGraph.LoopWalk.map, *]
      rw [map_comp, h]
      have map_id' {u v} (p : (K n).LoopWalk u v) : p.map (K n) (permMap' n 1) = p := by
        induction p <;> simp [SimpleGraph.LoopWalk.map, *]
      convert map_id' x.2
      ext
      simp [permMap, permMap']
    · intro x y z h1 h2
      unfold LoopWalkEquiv at *
      rcases h1 with ⟨s1, e1, w1⟩
      rcases h2 with ⟨s2, e2, w2⟩
      use s1.trans s2, (by simp [e1, e2])
      subst_vars
      simp only [permMapWalk] at *
      have map_comp {u v} (p : (K n).LoopWalk u v) (f g : K n →g K n) : (p.map (K n) f).map (K n) g = p.map (K n) (g.comp f) := by
        induction p <;> simp [SimpleGraph.LoopWalk.map, *]
      rw [map_comp, w1, w2]
