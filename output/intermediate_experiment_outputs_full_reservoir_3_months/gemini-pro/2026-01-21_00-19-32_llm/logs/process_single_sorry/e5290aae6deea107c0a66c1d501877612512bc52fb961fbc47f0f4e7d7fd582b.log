example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  induction sl using dropWhileSL.induct p with
  | case1 sl h =>
    simp [dropWhileSL, h, fromSL, nil]
    have e : isEmpty sl := by simp [isEmpty, h]
    rw [sl_empty_l_empty sl e]
    simp
  | case2 sl h h_none =>
    simp [dropWhileSL, h, h_none]
    rw [headSL_none_iff_nilSL] at h_none
    subst h_none
    simp [fromSL, nil]
  | case3 sl h x h_some h_p ih =>
    simp [dropWhileSL, h, h_some, h_p]
    rw [← ih]
    have h_tail : fromSL (tailSL sl) = (fromSL sl).tail := by
      have ⟨lhs, rhs, ok⟩ := sl
      cases lhs with
      | nil =>
        cases rhs with
        | nil => simp [tailSL, fromSL, nil]
        | cons b bs =>
          simp [fromSL, tailSL, nil]
          simp at ok; rw [ok]; simp
      | cons a as =>
        simp [fromSL]
        by_cases h_as : as = []
        . subst h_as
          simp [tailSL, splitInTwoSL, fromSL]
        . simp [tailSL, h_as, fromSL]
    have h_head : (fromSL sl).head? = some x := by
       unfold headSL at h_some; unfold fromSL
       have ⟨lhs, rhs, ok⟩ := sl
       cases lhs <;> simp at h_some ⊢
       case nil => cases rhs <;> simp at h_some ⊢; rw [← h_some]; simp
       case cons => rw [← h_some]; simp
    cases h_eq : fromSL sl with
    | nil => rw [h_eq] at h_head; contradiction
    | cons y ys =>
       rw [h_eq] at h_head; simp at h_head; subst y
       simp [List.dropWhile, h_p]
       rw [← h_tail, h_eq]; rfl
  | case4 sl h x h_some h_p_false =>
    simp [dropWhileSL, h, h_some, h_p_false]
    have h_head : (fromSL sl).head? = some x := by
       unfold headSL at h_some; unfold fromSL
       have ⟨lhs, rhs, ok⟩ := sl
       cases lhs <;> simp at h_some ⊢
       case nil => cases rhs <;> simp at h_some ⊢; rw [← h_some]; simp
       case cons => rw [← h_some]; simp
    cases h_eq : fromSL sl with
    | nil => rw [h_eq] at h_head; contradiction
    | cons y ys =>
       rw [h_eq] at h_head; simp at h_head; subst y
       simp [List.dropWhile, h_p_false]
