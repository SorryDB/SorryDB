-- exercise 1.3.i
-- the answer to what is a group homomorphism, but you need to
-- provide the proof.
theorem group_cat_functor {α β : Type*} [Group α] [Group β]
    (F : @Functor Unit Unit (Category.Monoid α) (Category.Monoid β)) :
    ∃ f: α →* β, ∀ x: α, F.homF (X := ()) (Y := ()) x = f x := by
  use { toFun := F.homF,
        map_one' := by
          have h := F.map_id ()
          simp [Category.id] at h ⊢
          exact h,
        map_mul' := fun x y => by
          have h := F.map_comp x y
          simp [Category.comp] at h ⊢
          exact h }
  intro x
  rfl
