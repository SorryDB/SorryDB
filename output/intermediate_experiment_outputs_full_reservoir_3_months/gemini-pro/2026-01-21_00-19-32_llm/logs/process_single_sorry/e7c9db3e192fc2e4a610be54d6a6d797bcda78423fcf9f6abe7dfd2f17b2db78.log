lemma image_empty {U : Type} {A : Set U}
    (f : U → Nat) (h : empty A) : image f A = I 0 := sorry

-- 2.
lemma remove_one_equinum
    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
  refine ⟨fun ⟨x, hx⟩ => ⟨f x, ?_⟩, ?_, ?_⟩
  · obtain ⟨xA, xna⟩ := hx
    refine ⟨by rw [←h2]; exact ⟨x, xA, rfl⟩, ?_⟩
    intro h; apply xna; apply h1 xA h3; rw [h, h4]
  · intro x1 x2 h
    apply Subtype.eq; apply h1 x1.2.1 x2.2.1 (congr_arg Subtype.val h)
  · rintro ⟨y, yB, ynb⟩
    rw [←h2] at yB; obtain ⟨x, xA, rfl⟩ := yB
    refine ⟨⟨x, ⟨xA, fun h => ynb (by rw [h, h4])⟩⟩, Subtype.eq rfl⟩
