lemma variance_dual_stdGaussianMulti (L : StrongDual ℝ E) :
    Var[L; stdGaussianMulti E] = ∑ i, L (stdOrthonormalBasis ℝ E i) ^ 2 := by
  rw [variance_eq_integral_sq_of_integral_eq_zero (isCentered_stdGaussianMulti L)]
  rw [stdGaussianMulti, integral_map (by fun_prop) (by fun_prop)]
  simp only [map_sum, map_smul, smul_eq_mul]
  rw [sq, Finset.sum_mul_sum, integral_finset_sum (by fun_prop)]
  apply Finset.sum_eq_sum
  intro i _
  rw [Finset.sum_eq_single i]
  · rw [integral_mul_left, integral_mul_left, ← sq]
    have h : ∫ x, x i ^ 2 ∂Measure.pi (fun _ ↦ gaussianReal 0 1) = 1 := by
      rw [integral_eval_pi (by exact (memLp_id_gaussianReal 2).integrable_sq)]
      simp [variance_gaussianReal]
    rw [h, mul_one]
  · intro j _ hij
    rw [integral_mul_left, integral_mul_left]
    have hindep : IndepFun (fun x ↦ x i) (fun x ↦ x j) (Measure.pi (fun _ ↦ gaussianReal 0 1)) :=
      (iIndepFun_pi (fun _ ↦ gaussianReal 0 1)).indepFun hij
    rw [integral_mul_of_indepFun hindep (memLp_id_gaussianReal 1).integrable (memLp_id_gaussianReal 1).integrable]
    have hmean : ∫ x, x i ∂Measure.pi (fun _ ↦ gaussianReal 0 1) = 0 := by
      rw [integral_eval_pi (memLp_id_gaussianReal 1).integrable]; simp
    rw [hmean, zero_mul, mul_zero]
  · exact fun h ↦ (h (Finset.mem_univ i)).elim
