```lean
namespace Solid

def of (A : LightCondAb) [IsSolid A] : Solid := ⟨A⟩

instance category : Category Solid :=
  InducedCategory.category toLightCondAb

instance : IsSolid ((discrete (ModuleCat ℤ)).obj (ModuleCat.of ℤ ℤ)) := sorry

instance : Inhabited Solid := ⟨Solid.of ((discrete (ModuleCat ℤ)).obj (ModuleCat.of ℤ ℤ))⟩

@[simps!]
def solidToCondensed : Solid ⥤ LightCondAb := inducedFunctor _

instance : HasLimitsOfSize.{0, 0} Solid :=
  hasLimits_of_created solidToCondensed <| createsLimitsOfFullyFaithful _ _ fun F =>
    let K := F ⋙ solidToCondensed
    let α := pre (oneMinusShift ℤ)
    let G := ihom (oneMinusShift ℤ).cod
    let H := ihom (oneMinusShift ℤ).dom
    have : ∀ j, IsIso (α.app (K.obj j)) := fun j => (F.obj j).isSolid.1
    have : IsIso (limit.map (whiskerLeft K α)) := inferInstance
    have : α.app (limit K) = (preservesLimitIso G K).inv ≫ limit.map (whiskerLeft K α) ≫ (preservesLimitIso H K).hom := by
      apply (limit.isLimit (H ⋙ K)).hom_ext; intro j
      simp only [Category.assoc, Iso.hom_inv_id_assoc, Functor.mapCone_π_app, preservesLimitIso_hom_π,
        preservesLimitIso_inv_π_assoc, NatTrans.naturality, limit.map_π, whiskerLeft_app]
    ⟨⟨limit K, ⟨by rw [this]; infer_instance⟩⟩, limit.isLimit K⟩

end Solid
```
