    have pec : ∀ x, ¬ Peculiar x := fun x => by rw [ax1, sd x]; simp
    have spec : ∀ x, Special x := fun x => by rw [spec_iff]; simp [pec]
    have c := ax3 Tarr Tarr (iff_of_true hT (spec Tarr))
    rw [sd Tarr, sd (bf Tarr)] at c; simp at c
  · have hF := mt ax6.mpr hT
