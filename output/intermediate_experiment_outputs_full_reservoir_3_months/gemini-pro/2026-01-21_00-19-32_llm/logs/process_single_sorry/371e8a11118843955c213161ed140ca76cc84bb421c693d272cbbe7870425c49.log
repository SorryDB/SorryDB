  induction xs with
  | nil =>
    simp at h
  | cons b bs ih =>
    simp [foldr1]
    have h₁ := h.right
    match ys with
    | [] => simp_all
    | z :: zs =>
      simp_all
      cases bs <;> simp_all [foldr1]
```
