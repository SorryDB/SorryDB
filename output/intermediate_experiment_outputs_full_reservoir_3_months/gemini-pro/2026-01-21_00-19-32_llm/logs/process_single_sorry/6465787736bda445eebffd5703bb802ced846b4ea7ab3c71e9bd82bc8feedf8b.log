/-- For complex measures `μ`, `ν` and integrable function `f`: `∫ f d(μ + ν) = ∫ f dμ + ∫ f dν` -/
lemma integral_add (μ ν : ComplexMeasure α) {f : α → ℂ} (hfμ : Integrable f μ.var) (hfν : Integrable f ν.var) :
    ∫ a, f a ∂(μ + ν) = ∫ a, f a ∂μ + ∫ a, f a ∂ν := by
  dsimp [integral]
  /- **Proof outline**:
  - Every complex measure `μ` has polar decomposition `μ = h · |μ|` where `|μ|` is
    the total variation (positive measure) and `|h| = 1` a.e.
  - By definition `∫ f dμ = ∫ (f · h) d|μ|`
  - We use a common dominating measure to avoid relating different polar decompositions
    Let `λ := |μ| + |ν| + |μ + ν|` (finite positive measure)
  - By RN theorem, ∃ `g₁, g₂ ∈ L¹(λ)` such that:
    - `dμ = g₁ dλ`
    - `dν = g₂ dλ`
    - `d(μ + ν) = (g₁ + g₂) dλ`
  - Use linarity with respect to positive measures:
    ∫ f d(μ + ν) = ∫ f(g₁ + g₂) dλ       -- by definition
                  = ∫ fg₁ dλ + ∫ fg₂ dλ  -- linearity w.r.t. positive measure λ
                  = ∫ f dμ + ∫ f dν      -- returning to the original measures
  -/
  change VectorMeasure.integral (μ + ν) f = VectorMeasure.integral μ f + VectorMeasure.integral ν f
  let ρ := μ.var + ν.var
  have hμ : μ.var ≪ ρ := Measure.absolutelyContinuous_of_le (Measure.le_add_right le_rfl)
  have hν : ν.var ≪ ρ := Measure.absolutelyContinuous_of_le (Measure.le_add_left le_rfl)
  have hadd : (μ + ν).var ≪ ρ := (VectorMeasure.variation_add_le _ _).trans_ac (Measure.absolutelyContinuous_of_le le_rfl)
  rw [VectorMeasure.integral_eq_of_absolutelyContinuous hμ, VectorMeasure.integral_eq_of_absolutelyContinuous hν,
      VectorMeasure.integral_eq_of_absolutelyContinuous hadd]
  rw [← integral_add]
  · apply integral_congr_ae
    filter_upwards [VectorMeasure.rnDeriv_add μ ν ρ] with x hx
    simp only [hx, add_mul]
  · rwa [← VectorMeasure.integrable_iff_integrable_rnDeriv hμ]
  · rwa [← VectorMeasure.integrable_iff_integrable_rnDeriv hν]
```
