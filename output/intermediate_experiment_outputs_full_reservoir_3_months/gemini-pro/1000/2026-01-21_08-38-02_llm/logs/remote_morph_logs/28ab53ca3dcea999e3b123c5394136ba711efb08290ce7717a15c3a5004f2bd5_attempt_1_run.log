-- -- exercise 1.2.i
def Category.slice_over' (c : α) := @slice_under (Opposite α) (C.opp) c
theorem Category.slice_over_equiv_slice_over' (c : α) :
  slice_over c = slice_over' c := by sorry

-- exercise 1.2.ii.i
theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
