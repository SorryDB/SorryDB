-- exercise 1.2.ii.i
theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · rintro ⟨g, hg⟩ c k
    use g ≫ k
    rw [← assoc, hg, id_comp]
  · intro h
    exact h X (id X)
```
