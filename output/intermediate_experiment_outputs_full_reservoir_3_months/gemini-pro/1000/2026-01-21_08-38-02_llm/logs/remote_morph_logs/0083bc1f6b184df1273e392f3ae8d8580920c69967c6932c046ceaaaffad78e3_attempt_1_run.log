/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  have huc := hf.uniformContinuous
  obtain ⟨l, hl⟩ := hf zero_lt_one
  obtain ⟨x₀, -, hx₀⟩ := isCompact_Icc.exists_isMaxOn (Set.nonempty_Icc.mpr hl.pos.le) huc.continuous.continuousOn.norm
  refine ⟨‖f x₀‖ + 1, fun x ↦ ?_⟩
  obtain ⟨y, hy, hxy⟩ := hl (-x)
