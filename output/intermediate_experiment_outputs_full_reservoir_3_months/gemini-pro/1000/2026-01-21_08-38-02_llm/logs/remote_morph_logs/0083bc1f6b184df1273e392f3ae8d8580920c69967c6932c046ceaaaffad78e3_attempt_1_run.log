/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf one_pos
  have hcont := hf.uniformContinuous.continuous.continuousOn
  obtain ⟨C, hC⟩ := isCompact_Icc.exists_forall_norm_le hcont (Set.nonempty_Icc.2 hl.pos.le)
