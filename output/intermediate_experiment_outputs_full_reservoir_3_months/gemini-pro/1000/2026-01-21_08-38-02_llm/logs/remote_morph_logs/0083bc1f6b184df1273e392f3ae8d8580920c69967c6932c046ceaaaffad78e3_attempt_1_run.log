  calc
    ‖f x‖ ≤ ‖f y‖ + ‖f y - f x‖ := norm_le_insert _ _
    _ ≤ ‖f x₀‖ + 1 := add_le_add (hx₀ _ (Set.Ico_subset_Icc_self hy)) (by simpa using hτ x)
