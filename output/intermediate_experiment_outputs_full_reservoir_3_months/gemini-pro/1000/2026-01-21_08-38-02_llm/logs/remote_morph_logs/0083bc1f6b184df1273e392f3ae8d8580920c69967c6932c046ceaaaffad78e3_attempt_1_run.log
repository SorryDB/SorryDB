    ‖f x‖ = ‖f y + (f x - f y)‖ := by simp
    _ ≤ ‖f y‖ + ‖f x - f y‖ := norm_add_le _ _
    _ = ‖f y‖ + ‖f (x + (-x + y)) - f x‖ := by simp; rw [norm_sub_rev]
    _ ≤ ‖f x₀‖ + 1 := add_le_add (hx₀ y (Set.Ico_subset_Icc_self hy)) (hxy x)
