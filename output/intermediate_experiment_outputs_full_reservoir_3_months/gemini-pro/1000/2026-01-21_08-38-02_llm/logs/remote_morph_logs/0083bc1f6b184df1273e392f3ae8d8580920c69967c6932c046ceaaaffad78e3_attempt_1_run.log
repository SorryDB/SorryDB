/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf zero_lt_one
  obtain ⟨C, hC⟩ := isCompact_Icc.exists_bound_of_continuousOn hf.uniformContinuous.continuous.continuousOn (s := Set.Icc 0 l)
  refine ⟨C + 1, fun x ↦ ?_⟩
  obtain ⟨y, hy, hAP⟩ := hl (-x)
  calc
    ‖f x‖ = ‖f y - (f y - f x)‖ := by rw [sub_sub_cancel]
    _ ≤ ‖f y‖ + ‖f y - f x‖ := norm_sub_le _ _
    _ ≤ C + 1 := add_le_add (hC y <| Set.Ico_subset_Icc_self hy) (by simpa [neg_add_cancel_left] using hAP x)
```
