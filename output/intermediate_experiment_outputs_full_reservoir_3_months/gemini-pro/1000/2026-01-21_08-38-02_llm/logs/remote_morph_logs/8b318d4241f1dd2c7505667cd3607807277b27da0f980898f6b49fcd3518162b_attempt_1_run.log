    have h_leg : ((replicate P.M (Ico (P.n - P.n/P.M) P.n)).join.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) ≥ - P.M * Real.log P.n := by
      -- The initial factorization (before filtering) contains M copies of [n - n/M, n).
