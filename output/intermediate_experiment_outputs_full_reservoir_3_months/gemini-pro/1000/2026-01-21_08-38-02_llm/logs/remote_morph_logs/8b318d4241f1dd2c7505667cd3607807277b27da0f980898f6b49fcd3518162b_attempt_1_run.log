      -- The non-smooth numbers removed have a prime factor q > n/L.
      -- Since m ≤ n, m = k*q with k < L.
      -- Since p ≤ L < q, v_p(m) = v_p(k) ≤ L.
      -- The number of such m is bounded by M * L * π(n).
      -- Total valuation removed is ≤ M * L^2 * π(n).
      sorry

    rw [h_decomp, sub_sub]
