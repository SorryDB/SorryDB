      have hp_le_L : p ≤ P.L := hp
      have hq_gt_L : q > P.L := (Nat.div_le_self P.n P.L).trans_lt hq_large
      have hp_ne_q : p ≠ q := ne_of_lt (hp_le_L.trans_lt hq_gt_L)
      rw [factorization_mul (pos_of_gt hk_lt).ne' hq_prime.ne_zero,
          hq_prime.factorization, Finsupp.coe_add, Pi.add_apply,
          if_neg hp_ne_q, add_zero]
      exact (le_of_dvd (pos_of_gt hk_lt) (k.factorization_le p)).trans (le_of_lt hk_lt)

    -- Simpler bound: count * max_val
    have h_val_le : ∀ m ∈ R, m.factorization p < P.L := fun m hm ↦ by
      obtain ⟨k, q, rfl, hq_prime, hq_large, hk_lt⟩ := h_struct m hm
      have hq_gt : q > P.L := (Nat.div_le_self P.n P.L).trans_lt hq_large
      rw [factorization_mul (pos_of_gt hk_lt).ne' hq_prime.ne_zero,
          hq_prime.factorization_self, Finsupp.coe_add, Pi.add_apply,
          if_neg (ne_of_lt (hp.trans_lt hq_gt)).symm, add_zero]
      exact (k.factorization_le p).trans_lt (Nat.lt_of_le_of_lt (le_of_dvd (pos_of_gt hk_lt) (dvd_refl k)) hk_lt)
    
    calc (R.map (·.factorization p)).sum
      _ ≤ R.card * P.L := by
        rw [Multiset.sum_map_mul_right, Multiset.map_const, Multiset.sum_replicate, nsmul_eq_mul]
        apply Multiset.sum_le_card_nsmul
        intro x hx; exact le_of_lt (h_val_le x hx)
      _ ≤ (P.M * P.L * primeCounting P.n) * P.L := by
        apply mul_le_mul_right'
        -- Bound cardinality of R
        -- R ⊆ U. Elements are k*q.
        -- For each k < L, q > n/L, k*q < n.
        -- Total count <= sum_{k < L} M * pi(n) <= L * M * pi(n)
