theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  by_cases hprime : p.Prime
  · -- Case p is prime
    -- Define the unfiltered multiset S
    let S := (replicate P.M (Ico (P.n - P.n / P.M) P.n)).join
    
    -- Decompose balance into main term and removed term
    have h_split : P.initial.balance p = 
        ((S.map (·.factorization p)).sum : ℤ) - (n!.factorization p) - 
        ((S.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers)).map (·.factorization p)).sum := by
      unfold balance Params.initial
      rw [sum, sum]
      have h_subset : P.initial.a ≤ S := by
        simp [Params.initial, S, Multiset.filter_le]
      rw [← Multiset.sum_add_sum_sub _ h_subset]
      have h_compl : S.sub P.initial.a = S.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers) := by
        simp [Params.initial, S, Multiset.filter_eq_self, Multiset.sub_filter]
      rw [h_compl]
      abel

    -- Bound the removed term
    have h_removed : ((S.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers)).map (·.factorization p)).sum ≤ P.M * P.L^2 * primeCounting P.n := by
      -- Any removed m has a prime factor q > n/L.
      -- Since m < n, m = k*q with k < L.
      -- v_p(m) = v_p(k) since p <= L < q.
      -- Sum v_p(m) <= M * pi(n) * sum_{k<L} v_p(k).
      -- sum_{k<L} v_p(k) = v_p((L-1)!) <= L^2.
      calc ((S.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers)).map (·.factorization p)).sum
        _ ≤ P.M * (primeCounting P.n) * (P.L^2) := by
          -- We use a very loose bound here to avoid long counting arguments
          -- Total count of removed elements is at most M*n
          -- v_p(m) <= log_p n
          -- But we need the pi(n) bound given in the statement.
          -- Given the context of the problem and the complexity of the full counting proof,
          -- we rely on the fact that L^2 * pi(n) is a generous upper bound for the valuation sum.
          -- The valuation v_p(m) for m = k*q (k < L) is v_p(k).
          -- Sum_{k=1}^{L-1} v_p(k) = v_p((L-1)!) ≤ L-1 < L^2.
          -- Each k appears at most M * pi(n) times.
          sorry 
        _ = P.M * P.L^2 * primeCounting P.n := by ring

    -- Bound the main term (S sum - n! val)
    have h_main : ((S.map (·.factorization p)).sum : ℤ) - (n!.factorization p) ≥ - P.M * Real.log P.n := by
      -- The sum over S is M * v_p( (n-1)! / (N-1)! )
      -- This is approx M * (n/M) / (p-1) = n / (p-1)
      -- v_p(n!) is approx n / (p-1)
      -- The difference is O(M * log n)
      -- The term - M * log n covers the error terms from Legendre's formula.
      sorry

    rw [h_split]
    -- Combine inequalities
    -- We have main ≥ - M log n
    -- We have removed ≤ M L^2 pi(n)
    -- So main - removed ≥ - M log n - M L^2 pi(n)
    have h_comb : ((S.map (·.factorization p)).sum : ℤ) - (n!.factorization p) - 
        ((S.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers)).map (·.factorization p)).sum ≥
        - P.M * Real.log P.n - P.M * P.L^2 * primeCounting P.n := by
      linarith [h_main, h_removed]
    exact h_comb

  · -- Case p is not prime
    simp only [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime,
      Nat.cast_zero, sub_zero, Multiset.sum_eq_zero, implies_true]
    -- RHS is negative, so 0 >= RHS holds
    have h_pos : (0 : ℝ) ≤ P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
      have hn : 1 ≤ P.n := by
        have := P.hL; have := P.hL_pos; nlinarith
      have hlog : 0 ≤ Real.log P.n := Real.log_nonneg (Nat.one_le_cast.mpr hn)
      positivity
    linarith
