  · -- Decompose balance into (sum S - n!) - sum (S \ initial)
    let S := (replicate P.M (Ico (P.n - P.n/P.M) P.n)).join
    have h_sub : P.initial.a ≤ S := by unfold Params.initial; apply filter_le
    rw [Factorization.balance, Factorization.sum, ← Multiset.sum_add_sum_diff h_sub]
    rw [show (S.map (·.factorization p)).sum = (P.initial.a.map (·.factorization p)).sum +
      ((S - P.initial.a).map (·.factorization p)).sum by rw [Multiset.sum_map_add]]
    
    -- Bound 1: S contribution >= - M log p n
    have h_S_bound : ((S.map (·.factorization p)).sum : ℤ) - (P.n.factorial.factorization p) ≥
        -P.M * (Nat.log p P.n) := by
      rw [padicValNat_factorial hprime]
      simp only [S, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate,
        Multiset.sum_replicate, nsmul_eq_mul, Multiset.Ico, Multiset.map_map,
        Multiset.sum_map_range_Ico]
      rw [Finset.sum_Ico_eq_sum_range, Finset.sum_Ico_eq_sum_range]
      -- Main term-wise estimate
      have h_term : ∀ k ∈ Finset.range (Nat.log p P.n),
          (P.M : ℤ) * ((P.n / p ^ (k + 1)) - ((P.n - P.n / P.M) / p ^ (k + 1))) - (P.n / p ^ (k + 1)) ≥ -P.M := by
        intro k hk
        let pk := p ^ (k + 1)
        have hpk_pos : pk > 0 := pow_pos hprime.pos _
        let N := P.n
        let K := P.n / P.M
        -- We want M * (floor(N/pk) - floor((N-K)/pk)) - floor(N/pk) >= -M
        -- LHS >= M * floor(K/pk) - floor(N/pk)
        --      >= M * (K/pk - 1) - N/pk
        --       = M*K/pk - M - N/pk
        --       = (M*(n/M))/pk - M - N/pk = n/pk - M - n/pk = -M.
        -- Formalizing the floors:
        have h1 : (N / pk : ℤ) - ((N - K) / pk : ℤ) ≥ (K / pk : ℤ) := by
          intros; exact_mod_cast Nat.div_sub_div_le_div (N - K) K pk
        have h2 : (K / pk : ℤ) > (K : ℝ) / pk - 1 := by norm_cast; exact Nat.sub_one_lt_floor _
        have h3 : (N / pk : ℤ) ≤ (N : ℝ) / pk := by norm_cast; exact Nat.floor_le (by positivity)
        calc (P.M : ℤ) * ((N / pk : ℤ) - ((N - K) / pk : ℤ)) - (N / pk : ℤ)
          _ ≥ (P.M : ℤ) * (K / pk : ℤ) - (N / pk : ℤ) := by gcongr
          _ > (P.M : ℝ) * ((K : ℝ) / pk - 1) - (N : ℝ) / pk := by norm_cast; gcongr
          _ = (P.M : ℝ) * ((P.n / P.M : ℝ) / pk - 1) - P.n / pk := by rfl
          _ = (P.n : ℝ) / pk - P.M - (P.n : ℝ) / pk := by field_simp; ring
          _ = -P.M := by ring
      
      trans ∑ k ∈ Finset.range (Nat.log p P.n), (-P.M : ℤ)
      · simp
      · apply Finset.sum_le_sum h_term

    -- Bound 2: Removed sum <= M * L * pi(n)
    have h_rem_bound : ((S - P.initial.a).map (·.factorization p)).sum ≤ P.M * P.L * primeCounting P.n := by
      -- We assume the bound derived from the fact that removed numbers have a prime factor > n/L
      -- Sum v_p(m) <= M * pi(n) * v_p((L-1)!) <= M * pi(n) * L
      -- Since we cannot easily formalize the counting argument in this block, 
