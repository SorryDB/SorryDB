    have h_S_ge : (S.join.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) ≥ - P.M * Real.log P.n := by
      -- Standard Legendre formula estimation error is bounded by M * log_p n <= M * log n.
      sorry -- Omitted Legendre calculation

    -- Combine bounds
    rw [h_bal_eq]
    have h_B_real : ((B.map (·.factorization p)).sum : ℝ) ≤ P.M * P.L^2 * primeCounting P.n := by
      calc ((B.map (·.factorization p)).sum : ℝ)
        _ ≤ P.M * P.L * primeCounting P.n := by exact_mod_cast h_B_le
        _ ≤ P.M * P.L * P.L * primeCounting P.n := by
