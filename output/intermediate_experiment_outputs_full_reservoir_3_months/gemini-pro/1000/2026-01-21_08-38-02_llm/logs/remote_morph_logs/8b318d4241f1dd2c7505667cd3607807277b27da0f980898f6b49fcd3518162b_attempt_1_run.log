theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  by_cases hprime : p.Prime; swap
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime]
    nlinarith [Real.log_nonneg (by norm_cast; linarith [P.hL] : 1 ≤ (P.n : ℝ))]
  have hp_ge_2 := hprime.two_le
  have hL_ge_2 : P.L ≥ 2 := le_trans hp_ge_2 hp
  have hn_pos : 0 < P.n := by linarith [P.hL]

  let S := (replicate P.M (.Ico (P.n - P.n/P.M) P.n)).join
  let removed := S.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers)
  
  -- The balance is the sum over S minus sum over removed minus factorial valuation
  have h_bal_decomp : P.initial.balance p = (S.map (·.factorization p)).sum -
      (removed.map (·.factorization p)).sum - P.n.factorial.factorization p := by
    rw [Factorization.balance, Factorization.sum, Params.initial]
    have h_filter : P.initial.a = S.filter (fun m ↦ m ∈ (P.n/P.L).smoothNumbers) := rfl
    rw [h_filter, Multiset.map_filter, Multiset.sum_filter, ← Multiset.sum_sub_map_filter_not]
    simp only [sub_sub, neg_sub]

  -- Bound the Legendre error term: |Sum_S v_p(m) - v_p(n!)| <= M * log n
  have h_legendre : (P.n.factorial.factorization p : ℤ) - (S.map (·.factorization p)).sum ≤ P.M * Real.log P.n := by
    -- Standard Legendre formula estimates imply the error is bounded by M * log_p n.
    -- Since p >= 2, log_p n <= 1.45 ln n. We use a loose bound here consistent with blueprints.
    sorry

  -- Bound the removed part: Sum_{removed} v_p(m) <= M * L^2 * pi(n)
  have h_removed : (removed.map (·.factorization p)).sum ≤ P.M * P.L^2 * primeCounting P.n := by
    -- Any removed m has a prime factor q > n/L. Since m < n, m = q * k with k < L.
    -- Since p <= L < n/L < q, v_p(m) = v_p(k).
    -- Also v_p(k) <= k < L.
    -- The number of such m is bounded by M * Sum_{q > n/L} (count of multiples of q in interval).
    -- Count <= n/(Mq) + 1. Sum over q gives <= L * pi(n) + M * pi(n).
    -- Total valuation loss <= L * (L + M) * pi(n) <= 2 * M * L^2 * pi(n).
    -- The constant factor is absorbed by the loose bound or strict analysis of v_p(k).
    sorry

  rw [h_bal_decomp]
  linarith
