  -- Step 1: Bound the sum of valuations of removed elements.
  -- Each removed m is of the form k*q where q > n/L and k < L.
  -- v_p(m) = v_p(k) ≤ k < L ≤ L^2.
  -- The number of such elements is at most M * L * π(n).
  -- Thus sum ≤ M * L^2 * π(n).
  have h_rem_le : (Removed.map (·.factorization p)).sum ≤ P.M * P.L^2 * primeCounting P.n := sorry

  -- Step 2: Bound the balance of the unfiltered set S.
  -- This essentially comes from Legendre's formula estimates:
  -- sum_{S} v_p(m) - v_p(n!) ≥ - M log n.
  have h_S_ge : (S.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) ≥
      - P.M * (Real.log P.n) := sorry

  -- Step 3: Combine.
  have h_bal : P.initial.balance p =
      (S.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) -
      (Removed.map (·.factorization p)).sum := by
    rw [Factorization.balance, Factorization.sum, Params.initial]
    simp only [Multiset.map_filter, S, Removed]
    rw [sub_sub, add_comm, ← sub_sub, ← Multiset.sum_map_filter_add_sum_map_filter_not
      S (· ∈ (P.n / P.L).smoothNumbers) (fun m ↦ m.factorization p)]
    simp
  
  rw [h_bal]
  have : ((Removed.map (·.factorization p)).sum : ℝ) ≤ P.M * P.L^2 * primeCounting P.n := by
    exact_mod_cast h_rem_le
  linarith
