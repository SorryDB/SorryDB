```lean
@[blueprint
  "initial-factorization-tiny-prime-ge"
  (statement := /-- A tiny prime $p \leq L$ can be in deficit by at most $M\log n + ML\pi(n)$.-/)
  (proof := /-- In addition to the Legendre calculations, one potentially removes factors of the
  form $plq$ with $l \leq L$ and $q \leq n$ a prime up to $M$ times each, with at most $L$ copies
  of $p$ removed at each factor.-/)]
theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  have hM_pos : 0 < P.M := by
    by_contra h; have := P.hL; simp at h; have := P.hL_pos; linarith
  let I := Finset.Ico (P.n - P.n / P.M) P.n
  let S_full := (Multiset.replicate P.M I.val).join
  have h_decomp : P.initial.balance p =
      ((S_full.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ)) -
      (S_full.filter (fun m ↦ m ∉ (P.n / P.L).smoothNumbers)).map (·.factorization p) |>.sum := by
    simp [Factorization.balance, Factorization.sum, Params.initial, sub_sub]
    rw [← Multiset.sum_add, Multiset.filter_add_filter, Multiset.filter_not, Multiset.add_comm]
    congr; apply (Multiset.map_add _ _ _).symm

  have h_full : (S_full.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) ≥
      - P.M * Real.log P.n := by
    -- The full interval sum approximates the factorial valuation. The error is bounded by logarithmic terms.
    -- v_p(n!) ≈ n/(p-1). Sum_{m ∈ I} v_p(m) ≈ length/(p-1) = (n/M)/(p-1).
    -- Multiplied by M, these match. The difference comes from the boundaries, bounded by M * log_p n.
    sorry

  have h_removed : ((S_full.filter (fun m ↦ m ∉ (P.n / P.L).smoothNumbers)).map (·.factorization p)).sum
      ≤ P.M * P.L^2 * (primeCounting P.n) := by
    rw [Multiset.map_replicate, Multiset.sum_replicate, Multiset.map_filter, Multiset.sum_map]
    apply Nat.mul_le_mul_left
    let bad := I.filter (fun m ↦ m ∉ (P.n / P.L).smoothNumbers)
    calc ∑ m ∈ bad, m.factorization p
      _ ≤ ∑ m ∈ bad, P.L := Finset.sum_le_sum fun m hm ↦ by
          simp only [bad, Finset.mem_filter, mem_smoothNumbers, not_forall, not_le] at hm
          obtain ⟨q, hq, hdvd, hlarge⟩ := hm.2
          have : m / q < P.L := by
            apply Nat.div_lt_of_lt_mul
            calc m < P.n := hm.1.2
              _ < q * P.L := by
                have : P.n / P.L < q := hlarge
                have : P.n < (P.n / P.L + 1) * P.L := Nat.lt_div_mul_add P.hL_pos
                calc P.n < (P.n / P.L + 1) * P.L := this
                  _ ≤ q * P.L := Nat.mul_le_mul_right _ hlarge
          have : p ≠ q := ne_of_lt (lt_of_le_of_lt hp (lt_trans this hlarge))
          rw [← Nat.div_mul_cancel hdvd, Nat.factorization_mul (Nat.div_pos (le_of_lt hm.1.2) (Nat.pos_of_ne_zero (ne_of_gt hlarge).symm)).ne' (ne_of_gt hlarge).ne', Nat.factorization_eq_zero_of_not_prime (fun h => this h.symm), add_zero]
          exact le_trans (Nat.le_of_lt (Nat.log_lt_self (Nat.pos_of_ne_zero (ne_of_gt hp).symm).ne' (by linarith))) (by linarith)
      _ = bad.card * P.L := by simp
      _ ≤ (P.L * primeCounting P.n) * P.L := by
          apply Nat.mul_le_mul_right
          -- Each bad number is of form k*q with k < L.
          -- Card bad <= Sum_{k < L} (Count q s.t. k*q in I).
          -- Count q <= primeCounting n.
          -- Sum_{k < L} primeCounting n = (L-1) * primeCounting n <= L * primeCounting n.
          sorry
      _ = P.L^2 * primeCounting P.n := by ring

  rw [h_decomp]
  linarith
