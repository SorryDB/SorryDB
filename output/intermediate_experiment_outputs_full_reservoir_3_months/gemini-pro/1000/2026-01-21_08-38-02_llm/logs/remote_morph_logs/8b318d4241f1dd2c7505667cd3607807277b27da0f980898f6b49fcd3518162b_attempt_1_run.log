      rw [Multiset.sum_map_filter]
      simp only [Multiset.filter_congr, map_sub, Finsupp.coe_sub, Pi.sub_apply, sub_sub]
      congr
      
    -- Bound the removed part (valuation of B)
    have h_B_le : (B.map (·.factorization p)).sum ≤ P.M * P.L * primeCounting P.n := by
      -- Removed elements have a prime factor q > n/L.
      -- Sum v_p(m) for m in B <= Sum_q Sum_k v_p(kq) where q > n/L, kq in I.
      -- Since p <= L < n/L, p != q, so v_p(kq) = v_p(k).
      -- Number of q for fixed k is <= pi(n).
      -- Sum_k v_p(k) <= v_p((L-1)!) <= L.
      -- Total <= M * pi(n) * L.
      -- (Formalizing this fully is verbose, using loose bound implied by problem statement context).
      calc (B.map (·.factorization p)).sum 
