      _ = P.M * P.L^2 * primeCounting P.n := by ring

  rw [sub_sub]
  have : (P.initial.balance p : ℝ) = ((U.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ)) - (R.map (·.factorization p)).sum := by
    rw [h_bal]; push_cast; ring
  rw [this]
