      -- We use the loose bound logic.
      nlinarith [h_log, Real.log_ge_log_two_of_ge_two (by exact_mod_cast hprime.two_le)]

    rw [sub_eq_add_neg, neg_add_rev, ← sub_eq_add_neg]
    push_cast
    linarith [h_S_bound, h_rem_bound]

  · -- Case not prime
    simp [hprime, Factorization.balance, Factorization.sum, 
      Nat.factorization_eq_zero_of_not_prime _ hprime]
    nlinarith [Real.log_nonneg (by exact_mod_cast one_le_of_lt_succ (lt_of_succ_le P.hL.le)), 
      Nat.cast_nonneg (primeCounting P.n)]
