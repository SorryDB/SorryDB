  (proof := /-- In addition to the Legendre calculations, one potentially removes factors of the
  form $plq$ with $l \leq L$ and $q \leq n$ a prime up to $M$ times each, with at most $L$ copies
  of $p$ removed at each factor.-/)]
theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  by_cases hprime : p.Prime; swap
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime]
    have : 0 ≤ P.M * Real.log P.n + P.M * P.L ^ 2 * primeCounting P.n := by
      have : 0 < P.n := by linarith [P.hL]
      positivity
    linarith
  
  -- Decompose balance into unfiltered and removed parts
  let I := Multiset.Ico (P.n - P.n / P.M) P.n
  let S := Multiset.join (Multiset.replicate P.M I)
  let removed := S.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers)
  have h_bal_eq : P.initial.balance p = 
      ((S.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ)) - 
      (removed.map (·.factorization p)).sum := by
    unfold Params.initial Factorization.balance Factorization.sum
    have h_sub : P.initial.a = S - removed := by
      simp only [S, removed, Params.initial, Multiset.sub_filter_eq_filter, Decidable.not_not]
      rfl
    rw [h_sub, Multiset.map_sub, Multiset.sum_sub (Multiset.filter_le _ _)]
    norm_cast; ring

  -- 1. Bound for unfiltered part: S_balance ≥ - M * log n
  have h_unfiltered : (S.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) ≥ 
      - P.M * (Nat.log p P.n) := by
    rw [Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, 
        nsmul_eq_mul]
    have h_prod : (I.map (·.factorization p)).sum = 
        P.n.factorial.factorization p - (P.n - P.n/P.M).factorial.factorization p := by
      rw [Multiset.Ico, Multiset.sum_map_factorization, Nat.add_sub_cancel']
      exact Nat.sub_le _ _
    rw [h_prod, Nat.cast_sub (Nat.factorial_dvd_factorial (Nat.sub_le _ _) |> Nat.factorization_le_factorization_factorial hprime)]
    
    -- Use Legendre formula sums
    let log_n := Nat.log p P.n
    let f (m : ℕ) := ∑ k ∈ Finset.Ico 1 (log_n + 1), m / p ^ k
    have h_leg (m : ℕ) (hm : m ≤ P.n) : m.factorial.factorization p = f m := by
      rw [Nat.prime_factorization_factorial _ hprime]
      refine Finset.sum_congr (Finset.Ico_subset_Ico rfl (Nat.succ_le_succ (Nat.log_mono_right hm))) fun k _ ↦ ?_
      rw [Nat.div_eq_of_lt]
      exact Nat.lt_pow_of_log_lt (Finset.mem_Ico.mp ‹_›).2
    
