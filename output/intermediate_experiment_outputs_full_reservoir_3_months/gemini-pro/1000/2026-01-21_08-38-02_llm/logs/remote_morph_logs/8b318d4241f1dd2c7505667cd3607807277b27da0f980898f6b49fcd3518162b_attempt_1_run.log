theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  let S := (replicate P.M (Multiset.Ico (P.n - P.n/P.M) P.n)).join
  let S_smooth := S.filter (fun m ↦ m ∈ (P.n/P.L).smoothNumbers)
  let S_removed := S.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers)
  
  have h_decomp : P.initial.balance p = (S.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) - (S_removed.map (·.factorization p)).sum := by
    have h_sum : (S.map (·.factorization p)).sum = (S_smooth.map (·.factorization p)).sum + (S_removed.map (·.factorization p)).sum := by
      rw [← Multiset.sum_add, ← Multiset.map_add]
      congr
      exact (Multiset.filter_add_not _ _).symm
    unfold Factorization.balance P.initial
    rw [h_sum]
    push_cast
    abel

  have h_leg : (S.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) ≥ - P.M * Real.log P.n := by
    -- The sum of valuations in M copies of the interval [n - n/M, n) is M * (v_p(n!) - v_p((n - n/M)!)).
    -- By Legendre's formula, v_p(k!) = k/(p-1) + O(log k).
    -- The leading terms cancel: M * (n/(p-1) - (n-n/M)/(p-1)) - n/(p-1) = 0.
    -- The error term is bounded by M * log n.
    sorry

  have h_rem : (S_removed.map (·.factorization p)).sum ≤ P.M * P.L^2 * (primeCounting P.n) := by
    -- Elements removed are those with a prime factor q > n/L.
    -- Since m < n, m = k * q with k < L.
    -- v_p(m) = v_p(k) + v_p(q). Since p <= L < q, v_p(q) = 0.
    -- Thus v_p(m) = v_p(k) <= k <= L.
    -- The number of such m (with multiplicity M) is roughly bounded by M * L * pi(n).
    -- The sum of valuations is bounded by M * L^2 * pi(n).
    sorry

  rw [h_decomp]
  linarith
