theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  have h_n_pos : 0 < P.n := by
    have := Nat.mul_pos P.hL_pos P.hL_pos
    linarith [P.hL]
  let U := (replicate P.M (.Ico (P.n - P.n/P.M) P.n)).join
  let S := U.filter (fun m ↦ m ∈ (P.n/P.L).smoothNumbers)
  let R := U.filter (fun m ↦ m ∉ (P.n/P.L).smoothNumbers)
  have h_bal : P.initial.balance p = (S.map (·.factorization p)).sum - (P.n.factorial.factorization p) := rfl
  have h_decomp : (S.map (·.factorization p)).sum = (U.map (·.factorization p)).sum - (R.map (·.factorization p)).sum := by
    rw [eq_sub_iff_add_eq]
    have : U = S + R := by
      simp [S, R, U]
      rw [Multiset.filter_add_filter, filter_eq_self.mpr, filter_eq_nil.mpr, add_zero]
      · exact fun _ _ ↦ rfl
      · exact fun _ h ↦ h
      · exact fun _ h ↦ h
    nth_rewrite 1 [this]
    simp [Multiset.sum_add]
  rw [h_decomp] at h_bal
  
  -- Bound 1: Legendre part (sum U - n!)
  have h_legendre : (U.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ) ≥ - P.M * (Real.log P.n) := by
    -- This follows from Legendre's formula estimates similar to balance_small_prime_ge
    -- v_p(n!) ≈ n/(p-1), sum U ≈ M * (n/M)/(p-1) = n/(p-1).
    -- The error is bounded by O(M log n).
    sorry

  -- Bound 2: Removed part (sum R)
  have h_removed : (R.map (·.factorization p)).sum ≤ P.M * P.L^2 * (primeCounting P.n) := by
    have h_struct : ∀ m ∈ R, ∃ k q, m = k * q ∧ q.Prime ∧ q > P.n / P.L ∧ k < P.L := fun m hm ↦ by
      simp only [R, U, Multiset.mem_filter, Multiset.mem_join, Multiset.mem_replicate,
        Multiset.mem_Ico, mem_smoothNumbers, not_forall, not_le, exists_prop] at hm
      obtain ⟨⟨_, ⟨_, rfl⟩, _, hm_lt_n⟩, ⟨q, hq_prime, hq_dvd, hq_large⟩⟩ := hm
      use m / q, q
      refine ⟨Nat.div_mul_cancel hq_dvd, hq_prime, hq_large, ?_⟩
      have hq_pos : 0 < q := hq_prime.pos
      have h_div : P.n / P.L < q := hq_large
      calc m / q < P.n / q := Nat.div_lt_div_of_lt_of_dvd hq_dvd hm_lt_n hq_pos
        _ ≤ P.n / (P.n / P.L + 1) := Nat.div_le_div_left (Nat.div_add_mod P.n P.L ▸ h_div) P.n
        _ < P.L := by
          have hL_pos : 0 < P.L := P.hL_pos
          have h_le : P.L * (P.n / P.L + 1) > P.n := by
            rw [mul_add, mul_one, mul_comm, Nat.div_mul_cancel]
            · exact Nat.lt_add_of_pos_right (Nat.mod_lt _ hL_pos)
            · exact Nat.dvd_sub_mod P.n
          rwa [Nat.div_lt_iff_lt_mul hL_pos]

    -- We group R by the cofactor k
    let K := Finset.Ico 1 P.L
    have h_sum_le : (R.map (·.factorization p)).sum ≤ ∑ k ∈ K, (R.filter (fun m ↦ m / (m.maxPrime) = k)).card * k.factorization p := by
      -- This grouping logic is valid but verbose to formalize with Multisets directly.
      -- Instead, we simply bound term by term.
      apply Multiset.sum_le_sum_map (g := fun m ↦ P.L)
      intro m hm
      obtain ⟨k, q, rfl, hq_prime, hq_large, hk_lt⟩ := h_struct m hm
      have hp_le_L : p ≤ P.L := hp
      have hq_gt_L : q > P.L := (Nat.div_le_self P.n P.L).trans_lt hq_large
      have hp_ne_q : p ≠ q := ne_of_lt (hp_le_L.trans_lt hq_gt_L)
      rw [factorization_mul (pos_of_gt hk_lt).ne' hq_prime.ne_zero,
          hq_prime.factorization, Finsupp.coe_add, Pi.add_apply,
          if_neg hp_ne_q, add_zero]
      exact (le_of_dvd (pos_of_gt hk_lt) (k.factorization_le p)).trans (le_of_lt hk_lt)

    -- Simpler bound: count * max_val
    have h_val_le : ∀ m ∈ R, m.factorization p < P.L := fun m hm ↦ by
      obtain ⟨k, q, rfl, hq_prime, hq_large, hk_lt⟩ := h_struct m hm
      have hq_gt : q > P.L := (Nat.div_le_self P.n P.L).trans_lt hq_large
      rw [factorization_mul (pos_of_gt hk_lt).ne' hq_prime.ne_zero,
          hq_prime.factorization_self, Finsupp.coe_add, Pi.add_apply,
          if_neg (ne_of_lt (hp.trans_lt hq_gt)).symm, add_zero]
      exact (k.factorization_le p).trans_lt (Nat.lt_of_le_of_lt (le_of_dvd (pos_of_gt hk_lt) (dvd_refl k)) hk_lt)
    
    calc (R.map (·.factorization p)).sum
      _ ≤ R.card * P.L := by
        rw [Multiset.sum_map_mul_right, Multiset.map_const, Multiset.sum_replicate, nsmul_eq_mul]
        apply Multiset.sum_le_card_nsmul
        intro x hx; exact le_of_lt (h_val_le x hx)
      _ ≤ (P.M * P.L * primeCounting P.n) * P.L := by
        apply mul_le_mul_right'
        -- Bound cardinality of R
        -- R ⊆ U. Elements are k*q.
        -- For each k < L, q > n/L, k*q < n.
        -- Total count <= sum_{k < L} M * pi(n) <= L * M * pi(n)
        sorry 
      _ = P.M * P.L^2 * primeCounting P.n := by ring

  rw [sub_sub]
  have : (P.initial.balance p : ℝ) = ((U.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ)) - (R.map (·.factorization p)).sum := by
    rw [h_bal]; push_cast; ring
  rw [this]
  linarith [h_legendre, h_removed]
