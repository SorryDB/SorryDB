  · let S := (replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)).join
    let Removed := S.filter (fun m ↦ m ∉ (P.n / P.L).smoothNumbers)
    
    have h_bal_eq : P.initial.balance p = 
        (S.map (·.factorization p)).sum - (Removed.map (·.factorization p)).sum - n.factorial.factorization p := by
      simp only [Factorization.balance, Factorization.sum, Params.initial, sub_sub]
      rw [← Multiset.sum_add, ← Multiset.map_add]
      congr 1
      exact (Multiset.filter_add_not _ S).symm
      
    have h_S_bound : (S.map (·.factorization p)).sum - (n.factorial.factorization p : ℤ) ≥ - P.M * Real.log P.n := by
      sorry -- Legendre estimate for the initial interval sum

    have h_removed_bound : (Removed.map (·.factorization p)).sum ≤ P.M * P.L^2 * primeCounting P.n := by
      sorry -- Counting argument: Removed elements are k*q with q > n/L, k < L.

    rw [h_bal_eq]
    linarith
  · simp only [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime,
      Nat.cast_zero, sub_zero, zero_sub, neg_le_iff_add_nonneg]
    have : 0 < P.n := lt_trans (mul_pos P.hL_pos P.hL_pos) P.hL
    have : 0 ≤ Real.log P.n := Real.log_nonneg (one_le_cast.mpr (by omega))
    positivity
