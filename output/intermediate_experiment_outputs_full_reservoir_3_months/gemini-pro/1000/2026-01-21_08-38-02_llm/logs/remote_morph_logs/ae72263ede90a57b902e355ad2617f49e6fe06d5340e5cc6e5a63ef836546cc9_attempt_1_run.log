/-- The quotient spaces that orbifolds are modelled on are locally compact. -/
instance {n : ℕ} {Γ : {Γ : Subgroup ((Eucl n) ≃ₗ[ℝ] (Eucl n)) | Finite Γ}} :
    LocallyCompactSpace (MulAction.orbitRel.Quotient Γ (Eucl n)) := by
  have : ContinuousConstSMul Γ (Eucl n) := ⟨fun γ ↦ γ.1.toLinearMap.continuous_of_finiteDimensional⟩
  let π := Quotient.mk (MulAction.orbitRel Γ (Eucl n))
  have hπ : IsOpenMap π := MulAction.isOpenMap_quotient_mk (Eucl n)
  have hπ_cont : Continuous π := continuous_quotient_mk
  constructor
  intro y s hs
  obtain ⟨x, rfl⟩ := Quotient.exists_rep y
