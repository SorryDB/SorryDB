/-- The quotient spaces that orbifolds are modelled on are locally compact. -/
instance {n : ℕ} {Γ : {Γ : Subgroup ((Eucl n) ≃ₗ[ℝ] (Eucl n)) | Finite Γ}} :
    LocallyCompactSpace (MulAction.orbitRel.Quotient Γ (Eucl n)) := by
  have : IsOpenMap (Quotient.mk (MulAction.orbitRel (↑Γ) (Eucl n))) := fun u hu ↦ by
    rw [isOpen_quotient_iff]
    have : Quotient.mk (MulAction.orbitRel (↑Γ) (Eucl n)) ⁻¹' (Quotient.mk (MulAction.orbitRel (↑Γ) (Eucl n)) '' u) = ⋃ (g : Γ), (g : (Eucl n) ≃ₗ[ℝ] (Eucl n)) '' u := by
      ext x; simp [Quotient.eq, MulAction.orbitRel_apply]
