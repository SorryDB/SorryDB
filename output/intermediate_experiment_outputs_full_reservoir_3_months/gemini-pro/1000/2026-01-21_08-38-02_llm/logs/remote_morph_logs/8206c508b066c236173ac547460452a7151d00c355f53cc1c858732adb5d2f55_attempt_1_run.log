    theorem RelIO.liftFinf_get {S} {n : Nat} {i : Fin n} {f : Fin n → RelIO S}:
      (RelIO.liftFinf n f).getIO i = f i := by
        induction n with
        | zero => exact i.elim0
        | succ n ih =>
          simp [RelIO.liftFinf, fin_range]
          match i with
          | ⟨0, _⟩ => simp
          | ⟨k+1, hk⟩ =>
            simp
            rw [← ih (i := ⟨k, Nat.lt_of_succ_lt_succ hk⟩) (f := f ∘ lift_fin)]
            simp [RelIO.liftFinf]
            generalize fin_range n = l
            induction l with
            | nil => simp
            | cons hd tl ih_l =>
              simp
              by_cases h : hd.1 = k
              · simp [h]
              · simp [h, mt Nat.succ.inj h, ih_l]
```
