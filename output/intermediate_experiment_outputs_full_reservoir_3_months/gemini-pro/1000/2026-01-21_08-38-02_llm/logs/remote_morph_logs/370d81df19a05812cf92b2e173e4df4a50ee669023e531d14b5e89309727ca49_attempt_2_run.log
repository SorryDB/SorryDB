      · calc _ = m * (m - 1) := by simp
             _ < m * m := Nat.mul_lt_mul_of_pos_left (Nat.pred_lt (by linarith)) (by linarith)
             _ = m ^ 2 := by ring
      · split_ifs; exact Nat.le_pred_of_lt (Fin.is_lt (c k)); exact zero_le _⟩

  have : Fintype.card V < Fintype.card C := by
    simp only [Fintype.card_fun, Fintype.card_fin, Fintype.card_coe]
    rw [pow_mul]
    exact Nat.pow_lt_pow_left h (by linarith)
  
  obtain ⟨c1, c2, hne, heq⟩ := Fintype.exists_ne_map_eq_of_card_lt map this
  let d (k : Fin m) : ℤ := (c1 k : ℤ) - (c2 k : ℤ)
  
  have h_sum : ∑ k, d k * (m : ℤ) ^ (k : ℕ).succ = 0 := by
    have h_val (a : A) : (map c1 a).1 = (map c2 a).1 := by rw [heq]
    have : ∑ a : A, (a : ℤ) * (map c1 a).1 = ∑ a : A, a * (map c2 a).1 := by
      congr; ext a; exact h_val a
    simp only [map, Fin.mk_eq_mk, Nat.cast_sum, Nat.cast_mul, Nat.cast_ite, 
      Nat.cast_one, Nat.cast_zero, Finset.mul_sum] at this
    rw [sum_comm] at this
