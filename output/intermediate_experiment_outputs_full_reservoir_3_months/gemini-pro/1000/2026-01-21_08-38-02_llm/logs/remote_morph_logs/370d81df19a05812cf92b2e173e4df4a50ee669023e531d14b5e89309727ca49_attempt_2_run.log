          apply Finset.sum_le_sum
          intro k _
          rw [abs_mul, abs_pow, abs_num_of_nat]
        _ ≤ ∑ k ∈ Finset.univ.erase K, (m - 1 : ℤ) * (m : ℤ) ^ ((k : ℕ) + 1) := by
          apply Finset.sum_le_sum
          intro k hk
          gcongr
          -- |δ k| ≤ m - 1
          have : δ k = (c k : ℤ) - (d k : ℤ) := rfl
          rw [this]
          have hc : (c k : ℤ) ∈ Set.Icc 0 (m - 1 : ℤ) := by
            constructor; norm_cast; exact zero_le _; norm_cast; exact Nat.le_pred_of_lt (Fin.is_lt _)
          have hd : (d k : ℤ) ∈ Set.Icc 0 (m - 1 : ℤ) := by
             constructor; norm_cast; exact zero_le _; norm_cast; exact Nat.le_pred_of_lt (Fin.is_lt _)
          rw [abs_sub_le_iff]
          constructor <;> linarith
        _ ≤ ∑ j ∈ Finset.range (K : ℕ), (m - 1 : ℤ) * (m : ℤ) ^ (j + 1) := by
          -- The indices in sum are all < K because K is max
          let f : Fin m ↪ ℕ := ⟨fun x => x, fun x y => Fin.val_eq_of_eq⟩
          rw [←Finset.sum_map]
          apply Finset.sum_le_sum_of_subset_of_nonneg
          · intro x hx
            simp at hx
            rw [Finset.mem_map] at hx
            rcases hx with ⟨k, hk_mem, hk_eq⟩
            simp at hk_mem
            rw [Finset.mem_range, ←hk_eq]
            -- k ≠ K and if δ k ≠ 0 then k ≤ K. 
            -- But we sum over all k ≠ K. If δ k = 0, term is 0.
