    nth_rewrite 2 [←one_mul ((m : ℤ) ^ ((K : ℕ) + 1))] at h_bound
    rw [mul_lt_mul_right (pow_pos (by linarith) _)] at h_bound
    have : |δ K| = 0 := by apply Int.eq_zero_of_abs_lt_dvd; exact h_bound; use 1; simp
