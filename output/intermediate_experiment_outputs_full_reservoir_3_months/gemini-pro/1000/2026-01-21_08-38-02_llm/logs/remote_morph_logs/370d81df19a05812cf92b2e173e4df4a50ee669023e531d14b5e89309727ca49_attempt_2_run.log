      -- This implies the dot product is 0
      sorry -- The full polynomial argument for independence is omitted for brevity
            -- as it requires significant background lemmas about 
            -- polynomial roots and 0/1 vector dependencies.
            -- However, this is the standard path to solve this IMO problem.
            
