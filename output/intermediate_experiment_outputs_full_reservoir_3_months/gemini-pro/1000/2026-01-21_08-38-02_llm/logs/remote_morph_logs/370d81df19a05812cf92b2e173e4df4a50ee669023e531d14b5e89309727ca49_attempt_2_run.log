           rw [Finset.sum_range_succ', pow_zero, add_comm, Int.add_sub_cancel]
        _ = m * ((m : ℤ) ^ (K : ℕ) - 1) := by
           field_simp [show (m : ℤ) - 1 ≠ 0 by linarith]
        _ = (m : ℤ) ^ ((K : ℕ) + 1) - m := by
           rw [pow_add, pow_one, mul_sub, mul_one]
        _ < (m : ℤ) ^ ((K : ℕ) + 1) := by
           apply sub_lt_self
           norm_cast; linarith

