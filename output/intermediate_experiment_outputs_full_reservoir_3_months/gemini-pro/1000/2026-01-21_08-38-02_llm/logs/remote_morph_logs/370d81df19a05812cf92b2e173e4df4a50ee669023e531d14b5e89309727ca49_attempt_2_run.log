theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  by_contra h
  push_neg at h
  rw [div_lt_iff' (by norm_num), Nat.cast_lt] at h
  replace h : 2 * A.card < m := h
  let S := Fin m → Fin m
  let T := A → Fin (m * m)
  let f : S → T := fun s a => ⟨∑ i, (s i : ℕ) * (if a ∈ B i then 1 else 0), 
    by
      apply lt_of_le_of_lt (sum_le_card_nsmul _ _ (m - 1) _)
      · rw [card_fin, ← Nat.mul_sub_right_distrib]
        apply Nat.sub_lt_self (by linarith) (by linarith)
      · intro i _; split_ifs; exact Nat.le_pred_of_lt (Fin.is_lt _); exact zero_le _⟩
  have : Fintype.card S > Fintype.card T := by
    simp only [Fintype.card_fin, Fintype.card_fun]
    calc m ^ m > m ^ (2 * A.card) := Nat.pow_lt_pow_of_lt_right (by linarith) h
      _ = (m ^ 2) ^ A.card := by rw [pow_mul]
      _ ≥ (m * m) ^ A.card := by rw [sq]; exact le_refl _
  obtain ⟨s1, s2, hne, heq⟩ := Fintype.exists_ne_map_eq_of_card_lt (by simp only [Fintype.card_fin, Fintype.card_fun]; exact this)
  let c := fun i => (s1 i : ℤ) - s2 i
