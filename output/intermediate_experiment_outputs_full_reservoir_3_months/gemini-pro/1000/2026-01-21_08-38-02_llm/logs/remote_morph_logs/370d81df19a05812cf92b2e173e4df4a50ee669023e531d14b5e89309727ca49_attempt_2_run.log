  have h_delta_zero : ∀ k, δ k = 0 := by
    -- If not, let K be the largest index with δ K ≠ 0
    by_contra h_nonzero
    push_neg at h_nonzero
    let S_supp := (Finset.univ : Finset (Fin m)).filter (fun k => δ k ≠ 0)
    have h_nonempty : S_supp.Nonempty := by
      use (Fin.mk 0 (by linarith)) -- just existence
      rw [Finset.nonempty_iff_ne_empty]
      intro h_empty
      apply hcd_ne
      ext k
      have : k ∉ S_supp := by rw [h_empty]; exact Finset.not_mem_empty k
      simp [S_supp] at this
      simp [δ, sub_eq_zero] at this
      exact this
