import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  by_contra h_contra
  push_neg at h_contra
  -- Assume |A| < m/2, so 2 * |A| < m.
  have h2n_lt_m : 2 * A.card < m := by
    rw [div_lt_iff' (by norm_num)] at h_contra
    norm_cast at h_contra
  -- Define the map from coefficients c ∈ {0, ..., m-1}^m to linear combinations of subset vectors.
  -- We view the vectors in ℤ^A. The image lies in a bounded box.
  let n := A.card
  let Domain := Fin m → Fin m
  let Codomain := A → Fin (m * m)
  let v (k : Fin m) (a : ℤ) : ℤ := if a ∈ B k then 1 else 0
  let F (c : Domain) : Codomain := fun a =>
    ⟨∑ k : Fin m, (c k : ℕ) * v k a, by
      -- Bound the value: sum of m terms, each at most (m-1)*1.
      apply Nat.lt_succ_of_le
      calc
        ∑ k : Fin m, (c k : ℕ) * v k a ≤ ∑ k : Fin m, (m - 1) * 1 := by
          apply Finset.sum_le_sum
          intro k _
          gcongr
          · apply Nat.le_pred_of_lt (Fin.is_lt (c k))
          · split_ifs; exact zero_le_one; exact zero_le_one
        _ = m * (m - 1) := by rw [Finset.sum_const, Finset.card_fin, mul_one]
        _ < m * m := by apply mul_lt_mul_of_pos_left (Nat.pred_lt (by linarith)) (by linarith)
    ⟩

  -- Apply Pigeonhole Principle
  have h_card_dom : Fintype.card Domain = m ^ m := Fintype.card_fun _ _
  have h_card_cod : Fintype.card Codomain = (m * m) ^ n := Fintype.card_fun _ _
  have h_pigeon : Fintype.card Codomain < Fintype.card Domain := by
    rw [h_card_dom, h_card_cod]
    calc
      (m * m) ^ n = m ^ (2 * n) := by rw [←pow_mul, mul_comm, pow_mul]
      _ < m ^ m := by
        apply pow_lt_pow_right (by linarith) h2n_lt_m

  obtain ⟨c, d, hcd_ne, h_eq⟩ := Fintype.exists_ne_map_eq_of_card_lt F h_pigeon

  -- Construct the difference δ = c - d
  let δ (k : Fin m) : ℤ := (c k : ℤ) - (d k : ℤ)
  
  -- The linear combination of sums must vanish
  have h_sum_zero : ∑ k : Fin m, δ k * (m : ℤ) ^ ((k : ℕ) + 1) = 0 := by
    -- Expand S = ∑ δ_k S_k
    trans ∑ k : Fin m, δ k * (∑ a ∈ B k, a)
    · congr; ext k; rw [hB]
    -- Swap sums
    rw [Finset.sum_comm]
    -- Inner sum is ∑_k δ_k * (if a ∈ B k then 1 else 0) * a
    -- This matches F(c)_a - F(d)_a
    have h_inner : ∀ a ∈ A, ∑ k : Fin m, δ k * v k a = 0 := by
      intro a ha
      have h_val := congr_fun h_eq ⟨a, ha⟩
      dsimp [F] at h_val
      rw [Fin.mk_eq_mk] at h_val
      rw [←sub_eq_zero] at h_val ⊢
      convert h_val using 1
      simp only [δ, sub_mul]
      rw [Finset.sum_sub_distrib]
      congr <;> {
        norm_cast
        apply Finset.sum_congr rfl
        intro k _
        rfl
      }
    -- Total sum
    trans ∑ a ∈ A, a * (∑ k : Fin m, δ k * v k a)
    · apply Finset.sum_congr rfl
      intro a ha
      rw [mul_sum]
      apply Finset.sum_congr rfl
      intro k _
      simp [v]
      split_ifs with h_in
      · rw [mul_one]
      · rw [mul_zero, mul_zero]
    · rw [Finset.sum_eq_zero]
      intro a ha
      rw [h_inner a ha, mul_zero]

