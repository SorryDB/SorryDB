          · intro _ _ _ ; apply mul_nonneg; linarith; apply pow_nonneg; linarith
        _ = (m - 1 : ℤ) * ∑ j ∈ Finset.range (K : ℕ), (m : ℤ) ^ (j + 1) := by rw [Finset.mul_sum]
        _ = (m - 1 : ℤ) * (m * ((m : ℤ) ^ (K : ℕ) - 1) / (m - 1)) := by
