def sol (n : ℕ) : ℕ :=
  if n ≤ 1 then n
  else if n = 3 then 3
  else if n % 2 = 0 then sol (n / 2)
  else if n % 4 = 1 then 2 * sol (2 * (n / 4) + 1) - sol (n / 4)
  else 3 * sol (n / 2) - 2 * sol (n / 4)
termination_by n
decreasing_by all_goals omega

