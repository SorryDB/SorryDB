    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  let rec val (n : ℕ) : ℕ :=
    if n ≤ 1 then 1
    else if n = 3 then 3
    else if n % 2 = 0 then val (n / 2)
    else if n % 4 = 1 then 2 * val (2 * (n / 4) + 1) - val (n / 4)
