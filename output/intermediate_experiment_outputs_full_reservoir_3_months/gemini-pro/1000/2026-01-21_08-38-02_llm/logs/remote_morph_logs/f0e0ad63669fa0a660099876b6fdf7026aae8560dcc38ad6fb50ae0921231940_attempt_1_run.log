```lean
theorem erdos_757 {A : Set ℝ} :
    answer(2/3) = sSup {c | IsAdmissible c} := by
  apply le_antisymm
  · apply sSup_le
    intro c hc
    let A₀ : Set ℝ := {0, 1, 2}
    have hA₀ : A₀.Finite := toFinite _
    have h_cond : ∀ B ⊆ A₀, B.ncard = 4 → (B - B).ncard = 11 := by
      intro B hB h4; exfalso
      have := ncard_le_of_subset hB hA₀
      rw [h4] at this; simp [A₀] at this; linarith
    obtain ⟨S, hS, hSid, hIn⟩ := hc hA₀ h_cond
