    intro deck hpos hpair i j
    -- We prove by infinite descent on the sum of the deck that the deck is constant.
    -- Let P(d) be the property.
    let S := ∑ k, deck k
    induction S using Nat.strong_induction_on generalizing deck with
    | h sum ih =>
      -- If all elements are even, we can divide by 2 and apply IH.
      by_cases heven : ∀ k, deck k % 2 = 0
      · have h_div : ∀ k, deck k / 2 < deck k := by
          intro k
          apply Nat.div_lt_self (hpos k) (by norm_num)
        have h_sum_lt : (∑ k, deck k / 2) < sum := by
          apply Finset.sum_lt_sum (fun k _ ↦ h_div k) ⟨i, Finset.mem_univ i, h_div i⟩
