      have h_amgm : (∏ k ∈ S, (deck k : ℝ)) ^ (1 / (#S : ℝ)) ≤ (∑ k ∈ S, (deck k : ℝ)) / (#S : ℝ) :=
        Real.geom_mean_le_arith_mean S (fun k _ ↦ Nat.cast_nonneg _) hS
      rw [← hGM] at h_amgm
      -- Strict AM-GM implies equality only if all elements are equal.
      -- If all elements in S are equal to x, then GM=x, AM=x.
      -- Then (a+b)/2 = x.
