        have h_new_pair : Pairwise fun j k ↦ ∃ S, S.Nonempty ∧ (↑(deck j / 2) + ↑(deck k / 2) : ℝ) / 2 = (∏ i ∈ S, ↑(deck i / 2) : ℝ) ^ (1 / ↑S.card) := by
          intro j k hjk
          obtain ⟨S, hS, h_eq⟩ := hpair hjk
          refine ⟨S, hS, ?_⟩
          push_cast
          rw [← h_eq]
          field_simp
          rw [← mul_rpow, ← Finset.prod_mul_distrib]
          congr 2
          rw [Finset.prod_const]
          norm_cast
          field_simp [heven]
          all_goals { try exact hS.card_ne_zero }
          all_goals { apply Nat.cast_nonneg }
        specialize ih (∑ k, deck k / 2) h_sum_lt (fun k ↦ deck k / 2) h_new_deck h_new_pair i j
        simp only [Nat.div_eq_of_eq_mul_right (ByCases.to_prop (heven i)) (by norm_num),
                   Nat.div_eq_of_eq_mul_right (ByCases.to_prop (heven j)) (by norm_num)] at ih
        exact Nat.mul_right_cancel (by norm_num) ih
      · -- If not all even, show that all must be odd.
        -- Suppose x, y have different parity. Then (x+y)/2 is not integer.
        -- But GM of integers is integer implies (x+y)/2 is integer? No, GM^k is integer.
        -- (x+y)/2 = GM => ((x+y)/2)^k = Prod.
        -- 2-adic valuation: v_2(LHS) = k * (v_2(x+y) - 1).
        -- If x, y diff parity, x+y is odd, v_2(x+y)=0, so v_2(LHS) = -k.
