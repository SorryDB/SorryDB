theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  have n_pos : 0 < (n : ℝ) := Nat.cast_pos.mpr (zero_lt_one.trans hn)
  let f (x : ℝ) := x * log x - x
  have hf : ∀ x ∈ Set.Ici 1, HasDerivAt f (log x) x := fun x hx ↦ by
    have x_pos := lt_of_lt_of_le zero_lt_one hx
    exact (hasDerivAt_id x).mul (hasDerivAt_log x_pos.ne') |>.sub (hasDerivAt_id x) |>.congr (by field_simp) rfl
  have sum_ineq : ∑ k in Finset.range (n - 1), (f (k + 2) - f (k + 1)) < ∑ k in Finset.range (n - 1), log (k + 2) := by
    refine Finset.sum_lt_sum (fun k hk ↦ ?_) ⟨0, Finset.mem_range.mpr (Nat.sub_pos_of_lt hn)⟩
    simp only [Finset.mem_range] at hk
    let x : ℝ := k + 1
    have hx : 1 ≤ x := by simp [x]
    obtain ⟨c, hc, hmean⟩ := exists_hasDerivAt_eq_slope (fun y hy ↦ hf y (hx.trans hy.1)) hx (x+1).le_succ (by norm_num)
    rw [hmean, (by ring : x + 1 - x = 1), mul_one]
    exact log_lt_log (zero_lt_one.trans_le (hx.trans hc.1)) hc.2
  rw [Finset.sum_range_sub (fun k ↦ f (k + 1))] at sum_ineq
  simp only [f, Nat.cast_one, log_one, mul_zero, zero_sub, sub_neg_eq_add] at sum_ineq
  rw [Nat.sub_add_cancel (le_of_lt hn)] at sum_ineq
  have h_log_fact : ∑ k in Finset.range (n - 1), log (k + 2) = log n.factorial := by
    rw [← Nat.sub_add_cancel (le_of_lt hn), Finset.sum_range_succ' (fun k ↦ log (k + 1))]
    simp only [Nat.cast_zero, zero_add, log_one, zero_add, Nat.add_succ_sub_one, add_assoc, one_add_one_eq_two]
    rw [← log_prod _ _ (fun _ _ ↦ (Nat.cast_pos.mpr (Nat.succ_pos _)).ne'), ← Nat.cast_prod, Nat.factorial_eq_prod_range]
  rw [h_log_fact] at sum_ineq
  rw [← log_lt_log_iff (mul_pos (exp_pos _) (pow_pos (div_pos n_pos (exp_pos _)) _)) (Nat.cast_pos.mpr (Nat.factorial_pos n)), log_exp]
  convert sum_ineq using 1
