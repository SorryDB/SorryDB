      log_exp_one]
  have H : ∀ k ≥ 2, (k : ℝ) * log k - k + 1 < log k.factorial := by
    intro k hk
    induction k, hk using Nat.le_induction with
    | base =>
        norm_num
        exact log_lt_sub_one_of_ne (by norm_num) (by norm_num)
    | succ k hk IH =>
