theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  have n_pos : 0 < (n : ℝ) := Nat.cast_pos.mpr (zero_lt_one.trans hn)
  have e_pos : 0 < e := Real.exp_pos 1
  rw [← Real.log_lt_log_iff (by positivity) (by positivity)]
  rw [Real.log_mul e_pos.ne' (pow_ne_zero _ (div_ne_zero n_pos.ne' e_pos.ne')),
      Real.log_pow, Real.log_div n_pos.ne' e_pos.ne', Real.log_exp,
      mul_sub, mul_one, add_sub, ← sub_add]
  let f (k : ℕ) := Real.log k.factorial - (k * Real.log k - k + 1)
  have step : ∀ k, 1 ≤ k → f k < f (k + 1) := by
    intro k hk
    have k_pos : 0 < (k : ℝ) := Nat.cast_pos.mpr (zero_lt_one.trans_le hk)
    dsimp [f]
    rw [Nat.factorial_succ, Nat.cast_mul, Real.log_mul (by positivity) (by positivity), Nat.cast_succ]
    have : (k : ℝ) + 1 = k * (1 + 1 / k) := by field_simp
    rw [this, Real.log_mul (by positivity) (by positivity)]
    ring_nf
    rw [sub_pos, mul_comm, ← lt_div_iff k_pos, one_div]
    refine Real.log_lt_sub_one_of_ne_one (ne_of_gt (lt_add_of_pos_right 1 (one_div_pos.mpr k_pos)))
  have f_pos : 0 < f n := by
    have base : 0 < f 2 := by
      have : f 1 = 0 := by norm_num [f]
      rw [← this]
      exact step 1 le_rfl
    induction n, hn using Nat.le_induction with
    | base => exact base
    | succ k hk ih => exact ih.trans (step k (le_trans (by norm_num) hk))
  exact lt_sub_iff_add_lt.mp f_pos
