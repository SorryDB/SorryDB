theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  have n_pos : 0 < (n : ℝ) := by exact_mod_cast (zero_lt_one.trans hn)
  rw [← log_lt_log_iff (by exact_mod_cast n.factorial_pos) (by positivity)]
  rw [log_mul (by positivity) (by positivity), log_pow, log_div (by positivity) (by positivity),
    e, Real.log_exp, mul_sub, mul_one, add_sub_assoc]
  let f (x : ℝ) := x * log x - x
  have hf : ∀ x > 0, HasDerivAt f (log x) x := fun x hx ↦ by
    convert HasDerivAt.sub_const (HasDerivAt.mul (hasDerivAt_id x) (hasDerivAt_log (ne_of_gt hx))) 1 using 1
    field_simp [ne_of_gt hx]
  have h_mvt : ∀ k : ℕ, 2 ≤ k → f k - f (k - 1) < log k := fun k hk ↦ by
    have k_pos : 0 < (k : ℝ) - 1 := by rw [sub_pos]; exact_mod_cast one_lt_two.trans_le hk
    obtain ⟨c, ⟨hc1, hc2⟩, h_eq⟩ := exists_deriv_eq_slope f (fun y hy ↦ (hf y <|
      (k_pos.trans hy.1).trans_le hy.2).differentiableAt)
      (le_of_lt k_pos) (le_refl _)
    rw [h_eq, sub_sub_cancel, div_one]; exact log_lt_log (hc1.trans hc2) hc2
  have sum_lt : ∑ k in Finset.range (n - 1), (f (k + 2) - f (k + 1)) < ∑ k in Finset.range (n - 1), log (k + 2) :=
    Finset.sum_lt_sum (fun k _ ↦ h_mvt (k + 2) (by simp)) ⟨0, by simp [tsub_pos_iff_lt.2 hn]⟩
  rw [Finset.sum_range_sub (fun i ↦ f (i + 1)), ← Nat.cast_prod, ← Finset.prod_range_add_one_eq_factorial,
      Finset.prod_range_succ', Nat.cast_mul, log_mul (by norm_num) (by exact_mod_cast Nat.factorial_ne_zero _),
      Nat.cast_one, log_one, zero_add] at sum_lt
  convert sum_lt using 1 <;> simp [f, add_comm]
