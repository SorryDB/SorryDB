theorem bound_factorial {n : ℕ} (hn : 1 < n) :
  n.factorial > e * (n / e) ^ n := by
  revert hn
  induction n with
  | zero => intro; contradiction
  | succ n ih =>
    intro hn
    by_cases h : n = 1
    · subst h
      rw [Nat.factorial_two]
      have : 2 < e := Real.two_lt_exp_one
      calc (2 : ℝ)
        _ > 4 / e := (div_lt_iff (by positivity)).mpr (by linarith)
        _ = e * (2 / e) ^ 2 := by field_simp [e]; ring
    · have n_ge_2 : 1 < n := by
        have : n ≠ 0 := by intro; subst n; simp at hn
        omega
      specialize ih n_ge_2
      rw [Nat.factorial_succ, Nat.cast_mul]
      apply lt_trans (mul_lt_mul_of_pos_left ih (by positivity))
      rw [show (n + 1 : ℝ) * (e * (n / e) ^ n) = e * ((n + 1) / e) ^ (n + 1) * (e / (1 + 1 / n) ^ n) by
        field_simp [e]; rw [pow_succ e, pow_succ ((n:ℝ)+1)]; ring]
      rw [mul_comm, mul_lt_mul_left (by positivity), div_lt_iff (by positivity), one_mul]
      refine Real.lt_exp_of_lt_log (by positivity) ?_
      rw [Real.log_pow]
      apply mul_lt_of_lt_div (by positivity)
      exact Real.log_lt_sub_one_of_pos (by positivity) (by field_simp; linarith)
