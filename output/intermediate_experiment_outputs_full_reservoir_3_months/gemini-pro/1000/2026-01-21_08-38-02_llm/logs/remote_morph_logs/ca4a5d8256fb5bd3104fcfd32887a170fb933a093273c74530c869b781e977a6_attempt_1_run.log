theorem bound_factorial {n : ℕ} (hn : 1 < n) :
    n.factorial > e * (n / e) ^ n := by
  have n_pos : 0 < (n : ℝ) := Nat.cast_pos.mpr (zero_lt_one.trans hn)
  rw [e, ← log_lt_log_iff (by positivity) (by positivity), log_mul (by positivity) (by positivity),
      log_pow, log_div (by positivity) (by positivity), log_exp, mul_sub, mul_one,
      add_sub, ← sub_add]
  let f (x : ℝ) := x * log x - x
  have hf : ∀ x ∈ Set.Ioi 0, HasDerivAt f (log x) x := fun x hx ↦ by
    have : HasDerivAt (fun x ↦ x * log x - x) (1 * log x + x * x⁻¹ - 1) x :=
      HasDerivAt.sub (HasDerivAt.mul (hasDerivAt_id _) (hasDerivAt_log (ne_of_gt hx))) (hasDerivAt_id _)
    convert this; rw [one_mul, mul_inv_cancel (ne_of_gt hx).symm, add_sub_cancel_right]
  have term_bound : ∀ i ∈ Finset.range (n - 1), f (i + 2) - f (i + 1) < log (i + 2) := fun i _ ↦ by
    have i_pos : 0 < (i : ℝ) + 1 := add_pos_of_nonneg_of_pos (Nat.cast_nonneg _) zero_lt_one
    obtain ⟨c, hc, h_mvt⟩ := exists_deriv_eq_slope f (i + 1) (i + 2) (lt_add_one _) (fun x hx ↦
      hf x (Set.mem_Ioi.mpr (lt_trans i_pos hx.1)))
    rw [h_mvt, add_sub_add_left_eq_sub, add_sub_cancel_right, div_one]
    exact log_lt_log hc.1.1 hc.2
  have sum_bound : ∑ i in Finset.range (n - 1), (f (i + 2) - f (i + 1)) < ∑ i in Finset.range (n - 1), log (i + 2) :=
    Finset.sum_lt_sum_of_nonempty (Finset.nonempty_range_iff.mpr (Nat.sub_pos_of_lt hn)) term_bound
  rw [Finset.sum_range_sub (fun i ↦ f (i + 1))] at sum_bound
  simp only [Nat.sub_add_cancel (one_le_of_lt hn), Nat.cast_one, f] at sum_bound
  norm_num at sum_bound
  refine lt_of_lt_of_eq sum_bound ?_
  rw [← log_prod _ _ (fun x hx ↦ by positivity)]
  congr; norm_cast
  rw [Nat.factorial_eq_prod_range, ← Nat.sub_add_cancel (one_le_of_lt hn), Finset.prod_range_succ']
  simp
