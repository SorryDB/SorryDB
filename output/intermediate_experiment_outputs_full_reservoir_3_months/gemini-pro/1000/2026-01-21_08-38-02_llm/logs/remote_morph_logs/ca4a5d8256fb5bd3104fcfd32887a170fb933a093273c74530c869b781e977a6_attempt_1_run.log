theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  have n_pos : 0 < (n : ℝ) := Nat.cast_pos.mpr (lt_trans zero_lt_one hn)
  have n_fact_pos : 0 < (n.factorial : ℝ) := Nat.cast_pos.mpr n.factorial_pos
  rw [gt_iff_lt, ← log_lt_log_iff n_fact_pos]
  · rw [log_mul (exp_pos _).ne' (pow_pos (div_pos n_pos (exp_pos _)) _).ne', log_pow,
      log_div n_pos.ne' (exp_pos _).ne', show chapter2.e = exp 1 from rfl, Real.log_exp,
      mul_sub, mul_one]
    let f := fun x : ℝ => x * log x - x
    have hf : ∀ x > 0, HasDerivAt f (log x) x := fun x hx => by
      convert (hasDerivAt_id x).mul (hasDerivAt_log (ne_of_gt hx)) |>.sub (hasDerivAt_id x) using 1
      field_simp [hx.ne']
    have step : ∀ k : ℕ, 2 ≤ k → f k - f (k - 1) < log k := fun k hk => by
      have k_sub_1_pos : 0 < (k : ℝ) - 1 := by rw [sub_pos]; exact Nat.one_lt_cast.mpr (Nat.lt_of_succ_le hk)
      obtain ⟨c, hc, h_mvt⟩ := exists_hasDerivAt_eq_slope f f (k - 1) k (by linarith) (fun x hx => hf x (by linarith [hx.1]))
      rw [h_mvt, sub_sub_cancel, div_one]
      exact log_lt_log (by linarith [hc.1]) hc.2
    have sum_lt : ∑ i in Finset.range (n - 1), (f (i + 2) - f (i + 1)) < ∑ i in Finset.range (n - 1), log (i + 2) :=
      Finset.sum_lt_sum (fun i _ => step (i + 2) (by simp; linarith)) ⟨0, by simp [tsub_pos_of_lt hn]⟩
    rw [Finset.sum_range_sub (fun i => f (i + 1))] at sum_lt
    simp only [add_tsub_cancel_right, Nat.cast_one, one_mul, log_one, zero_sub] at sum_lt
    rw [← log_prod] at sum_lt
    · have prod_eq : ∏ i in Finset.range (n - 1), (i + 2 : ℝ) = n.factorial := by
        rw [← Nat.cast_prod, Nat.cast_inj, Nat.factorial_eq_prod_range]
        rw [← tsub_add_cancel_of_le (Nat.le_of_lt hn), Finset.prod_range_succ']
        simp
      rw [prod_eq] at sum_lt
      linarith
    · intro i _; rw [Nat.cast_pos]; linarith
  · positivity
