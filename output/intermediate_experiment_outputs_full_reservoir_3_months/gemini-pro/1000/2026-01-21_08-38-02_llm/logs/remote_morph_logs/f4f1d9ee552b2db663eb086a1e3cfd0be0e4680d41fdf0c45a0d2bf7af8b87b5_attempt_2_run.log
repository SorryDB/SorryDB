def answer : Set.Ioi 1 → ℕ := fun n ↦ n.1 ^ 2 - n.1 + 1

theorem result (n : Set.Ioi 1) :
    IsLeast {k : ℕ | ∀ A B : Company n k, ∃ i j, A.linked i j ∧ B.linked i j} (answer n) := by
  let m : ℕ := n
  let k₀ := m ^ 2 - m + 1
  refine ⟨fun A B ↦ ?_, fun k hk ↦ ?_⟩
  · by_contra h
    push_neg at h
    let finishes (C : Company n k₀) := Set.range (fun i ↦ (C.cars i).finish)
    have card_roots (C : Company n k₀) : Fintype.card {i // i ∉ finishes C} = m - 1 := by
      rw [Fintype.card_subtype_compl, Fintype.card_fin, Fintype.card_range_of_injective C.injective_finish]
      simp [k₀, tsub_tsub_cancel_of_le (Nat.le_add_left _ _)]
    let rec root {C : Company n k₀} (i : Fin (m ^ 2)) : Fin (m ^ 2) :=
      if h : i ∈ finishes C then
        let ⟨c, hc⟩ := h
        root (C.cars c).start
      else i
      termination_by i.val
      decreasing_by { rw [← hc]; exact (C.cars c).start_lt_finish }
    have root_mem {C : Company n k₀} (i) : root i ∉ finishes C := by
      rw [root]; split_ifs; exact root_mem _; assumption
    have linked_of_root_eq {C : Company n k₀} {i j} (heq : root i = root j) :
        i = j ∨ C.linked i j ∨ C.linked j i := by
      -- Since graph is a forest of functional paths (out-degree 1), root equality implies reachability
      sorry 
    let f i := (⟨root i, root_mem i⟩ : {x // x ∉ finishes A} × {x // x ∉ finishes B})
    have inj : Function.Injective f := by
      intro i j heq
      rcases linked_of_root_eq (congr_arg (·.1.1) heq), linked_of_root_eq (congr_arg (·.2.1) heq) with
        ⟨rfl | hA | hA, rfl | hB | hB⟩
      · rfl
      · exact (h i j ⟨hA, hB⟩).elim
      · exact (h j i ⟨hA, hB⟩).elim -- Symmetry of contradiction not needed due to ordered linked
      · exact (h i j ⟨hA, hB⟩).elim -- Cases with wrong order impossible by start < finish
      · exact (h j i ⟨hA, hB⟩).elim
      · exact (h j i ⟨hA, hB⟩).elim -- A linked j i, B linked j i
      all_goals {
        -- Impossible cases: A linked i j implies i < j, B linked j i implies j < i
        try { have := A.linkage.valid _ _ _ hA; linarith } -- Sketch
        sorry
      }
    have : m ^ 2 ≤ (m - 1) ^ 2 :=
      calc m ^ 2 = Fintype.card (Fin (m ^ 2)) := (Fintype.card_fin _).symm
        _ ≤ Fintype.card _ := Fintype.card_le_of_injective f inj
        _ = (m - 1) ^ 2 := by simp [Fintype.card_prod, card_roots, sq]
    have hm : 1 < m := n.2
    nlinarith
  · let k_bad := m ^ 2 - m
    have : k ≤ k_bad := Nat.le_of_lt_succ hk
    let skip (d i : ℕ) := i + i / d
    let CA : Company n k_bad := {
      cars := fun i ↦ { start := ⟨skip (m - 1) i, sorry⟩, finish := ⟨skip (m - 1) i + 1, sorry⟩, start_lt_finish := sorry }
      injective_start := sorry
      injective_finish := sorry
      monovary_start_finish := sorry
    }
    let CB : Company n k_bad := {
      cars := fun i ↦ { start := ⟨i, sorry⟩, finish := ⟨i + m, sorry⟩, start_lt_finish := sorry }
      injective_start := sorry
      injective_finish := sorry
      monovary_start_finish := sorry
    }
    -- Show no intersection
    use CA, CB
    intro i j ⟨hA, hB⟩
    -- A linked implies same row, B linked implies same col
    -- Hence i = j, contradiction to linked non-empty
    sorry
