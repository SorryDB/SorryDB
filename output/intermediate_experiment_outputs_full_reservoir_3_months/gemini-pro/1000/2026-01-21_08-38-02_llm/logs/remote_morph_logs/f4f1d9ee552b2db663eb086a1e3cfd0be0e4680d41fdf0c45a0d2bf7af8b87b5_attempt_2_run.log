```lean
def answer : (Set.Ioi 1) → ℕ := fun n ↦ (n : ℕ) ^ 2 - n + 1

theorem result (n : Set.Ioi 1) :
    IsLeast {k : ℕ | ∀ A B : Company n k, ∃ i j, A.linked i j ∧ B.linked i j} (answer n) := by
  let N := (n : ℕ) ^ 2
  refine ⟨fun A B ↦ ?_, fun k hk ↦ ?_⟩
  · let roots (C : Company n (answer n)) := {x : Fin N | x ∉ Set.range (fun i ↦ (C.cars i).finish)}
    have hc (C : Company n (answer n)) : Fintype.card (roots C) = n - 1 := by
      rw [Fintype.card_of_subtype, Set.card_range_of_injective C.injective_finish]
      simp [answer, N]; nlinarith [n.property]
    let p (C : Company n (answer n)) (i : Fin N) : Option (Fin N) :=
      (List.finRange (answer n)).findSome? (fun c ↦ if (C.cars c).finish = i then some (C.cars c).start else none)
    have hp (C : Company n (answer n)) (i j) : p C i = some j ↔ ∃ c, (C.cars c).start = j ∧ (C.cars c).finish = i := by
      simp [p, List.findSome?_find_iff]; constructor
      · rintro ⟨c, h, rfl⟩; exact ⟨c, by split_ifs at h; exact h, rfl⟩
      · rintro ⟨c, rfl, rfl⟩; exact ⟨c, ⟨_, rfl⟩, by split_ifs; rfl⟩
    let rec root (C : Company n (answer n)) (i : Fin N) : Fin N :=
      match h : p C i with | some j => root C j | none => i
    termination_by i.val
    decreasing_by obtain ⟨c, rfl, rfl⟩ := (hp C i j).mp h; exact (C.cars c).start_lt_finish
    let f (i : Fin N) := (root A i, root B i)
    obtain ⟨x, y, hne, hxy⟩ : ∃ x y, x ≠ y ∧ f x = f y :=
      Fintype.exists_ne_map_eq_of_card_lt f (by simp [Fintype.card_prod, hc, N]; nlinarith [n.property])
