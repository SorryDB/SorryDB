            let prev := (C.cars h.some).start
            have : prev < curr := by rw [←h.some_spec]; exact (C.cars h.some).start_lt_finish
            have h_prev : getRoot C prev = getRoot C x := by rw [getRoot, dif_pos h] at h_curr; exact h_curr
            path prev h_prev ++ [h.some]
