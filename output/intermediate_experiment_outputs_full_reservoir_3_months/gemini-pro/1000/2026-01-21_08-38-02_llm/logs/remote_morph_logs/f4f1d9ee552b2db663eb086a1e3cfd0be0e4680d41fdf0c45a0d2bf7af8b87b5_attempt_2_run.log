def answer : (Set.Ioi 1) → ℕ := fun n => n ^ 2 - n + 1

theorem result (n : Set.Ioi 1) :
    IsLeast {k : ℕ | ∀ A B : Company n k, ∃ i j, A.linked i j ∧ B.linked i j} (answer n) := by
  have h1 : 1 < (n : ℕ) := n.2
  let N := (n : ℕ) ^ 2
  refine ⟨?_, ?_⟩
  · intro A B
    let R (C : Company n (answer n)) := (Set.univ \ (Set.range fun i => (C.cars i).finish)).toFinset
    have hR (C : Company n (answer n)) : (R C).card = n - 1 := by
      rw [Set.toFinset_diff, Set.toFinset_univ, Set.toFinset_range, Finset.card_sdiff (Finset.map_subset_range _ _)]
      rw [Finset.card_fin, Finset.card_map, (Set.injective_iff_map_eq_iff _).mp C.injective_finish, Finset.card_fin]
      simp only [answer, N]; zify [h1]; ring
    let anc (C : Company n (answer n)) (x : Fin N) : Finset (Fin N) := {y | y = x ∨ C.linked y x}.toFinset
    let root (C : Company n (answer n)) (x : Fin N) : Fin N := (anc C x).min' (by simp [anc])
    have h_root (C : Company n (answer n)) (x : Fin N) : root C x ∈ R C := by
      simp only [R, Set.toFinset_diff, Set.toFinset_univ, Set.toFinset_range, Finset.mem_sdiff, Finset.mem_univ, true_and, Finset.mem_map, Finset.mem_fin, not_exists]
      intro i hi
      have : (C.cars i).start ∈ anc C x := by
        simp only [anc, Set.toFinset_setOf, Finset.mem_filter, Finset.mem_univ, true_and]
