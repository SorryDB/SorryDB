  have hn2 : 2 ≤ (n : ℕ) := n.2
  have h_paths : N - (answer n) = n - 1 := by
    simp [answer, N]
    rw [Nat.sub_sub, Nat.add_comm]
    congr
    omega
  refine ⟨?_, ?_⟩
  · intro A B
    let S (C : Company n (answer n)) := {x | ∀ i, (C.cars i).finish ≠ x}
    have hS (C : Company n (answer n)) : Fintype.card (S C) = n - 1 := by
      rw [Fintype.card_set_eq_filter, ← Finset.card_univ, ← Finset.filter_not]
      rw [← Finset.card_sdiff (s₁ := Finset.univ.filter (fun x ↦ ∃ i, (C.cars i).finish = x))]
      · rw [Finset.card_univ, Fintype.card_fin]
        rw [← Finset.card_map ⟨_, C.injective_finish⟩, Finset.card_univ, Fintype.card_fin]
        simp only [Finset.univ_map_embedding, Finset.filter_map, Finset.mem_univ, true_and]
        simp [answer, N] at h_paths ⊢
        exact h_paths
      · simp
    let root (C : Company n (answer n)) (i : Fin N) : Fin N :=
       if h : ∃ j, (C.cars j).finish = i then root C (C.cars h.choose).start else i
    have root_mem (C : Company n (answer n)) (i : Fin N) : root C i ∈ S C := by
      induction i using Nat.strong_induction_on with i ih
      rw [root]; split_ifs with h
      · exact ih _ ((C.cars h.choose).start_lt_finish.trans_eq h.choose_spec.symm)
      · simp [S, h]
    have linked_of_root (C : Company n (answer n)) (i j : Fin N) (h : root C i = root C j) (hij : i < j) :
        C.linked i j := by
      -- Since components are paths sorted by index, same root and i < j implies i -> j
      sorry
    let f (i : Fin N) := (root A i, root B i)
    have : Fintype.card (S A × S B) < Fintype.card (Fin N) := by
      rw [Fintype.card_prod, hS, hS, Fintype.card_fin, hN]
      nlinarith
    have : ∃ i j, i ≠ j ∧ f i = f j := Fintype.exists_ne_map_eq_of_card_lt f this
    rcases this with ⟨i, j, hne, heq⟩
    rcases lt_trichotomy i j with h | h | h
    · exact ⟨i, j, linked_of_root A i j (congr_arg Prod.fst heq) h,
                  linked_of_root B i j (congr_arg Prod.snd heq) h⟩
    · contradiction
    · exact ⟨j, i, linked_of_root A j i (congr_arg Prod.fst heq).symm h,
                  linked_of_root B j i (congr_arg Prod.snd heq).symm h⟩
  · intro k hk
    rw [mem_setOf_eq] at hk
    let k0 := (n : ℕ) ^ 2 - n
    have hk0 : k ≤ k0 := by
      apply Nat.le_of_lt_succ
      convert hk (by simp [answer, k0]; omega) using 1
      simp [answer, k0]
      omega
    -- Construct counterexample for k0
    let row (i : Fin N) := i.1 / n
    let col (i : Fin N) := i.1 % n
    let A_cars : Fin k0 → Car n := fun i ↦
      let r := i.1 / (n - 1)
      let c := i.1 % (n - 1)
      { start := ⟨r * n + c, by sorry⟩, finish := ⟨r * n + c + 1, by sorry⟩, start_lt_finish := by sorry }
    let B_cars : Fin k0 → Car n := fun i ↦
      let c := i.1 / (n - 1)
      let r := i.1 % (n - 1)
      { start := ⟨r * n + c, by sorry⟩, finish := ⟨(r + 1) * n + c, by sorry⟩, start_lt_finish := by sorry }
    have A : Company n k0 := { cars := A_cars, injective_start := sorry, injective_finish := sorry, monovary_start_finish := sorry }
    have B : Company n k0 := { cars := B_cars, injective_start := sorry, injective_finish := sorry, monovary_start_finish := sorry }
    have : ∀ i j, A.linked i j → row i = row j := sorry
    have : ∀ i j, B.linked i j → col i = col j := sorry
    rcases hk A B with ⟨i, j, hA, hB⟩
    have : row i = row j ∧ col i = col j := ⟨by sorry, by sorry⟩
    -- i = j, but linked implies i < j
    sorry
