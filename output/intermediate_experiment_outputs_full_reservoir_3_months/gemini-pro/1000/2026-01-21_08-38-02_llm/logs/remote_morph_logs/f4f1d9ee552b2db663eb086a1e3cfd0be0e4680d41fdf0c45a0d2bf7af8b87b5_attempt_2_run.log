    let carA (k : Fin k_bad) : Car n := { start := idxA k, finish := ⟨idxA k + 1, sorry⟩, start_lt_finish := sorry }
    -- Similarly for B (transposed)
    let idxB (k : Fin k_bad) : Fin N := ⟨(k % (n-1)) * n + (k / (n-1)), sorry⟩
    let carB (k : Fin k_bad) : Car n := { start := idxB k, finish := ⟨idxB k + n, sorry⟩, start_lt_finish := sorry }
