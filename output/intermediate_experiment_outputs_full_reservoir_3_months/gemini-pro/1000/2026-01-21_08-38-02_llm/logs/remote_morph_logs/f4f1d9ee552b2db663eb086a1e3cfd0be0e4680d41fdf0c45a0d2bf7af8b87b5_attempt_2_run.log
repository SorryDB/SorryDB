        finish := ⟨r * N + c + 1, by sorry⟩,
        start_lt_finish := by simp; apply Nat.lt_succ_self }
    -- Construct A (rows) and B (cols) with k cars (subset of m)
    -- Show intersection is singleton, so no linked pair (u ≠ v).
    use { cars := fun i => carsA ⟨i, by omega⟩, 
          injective_start := sorry, injective_finish := sorry, monovary_start_finish := sorry }
    use { cars := fun i => 
