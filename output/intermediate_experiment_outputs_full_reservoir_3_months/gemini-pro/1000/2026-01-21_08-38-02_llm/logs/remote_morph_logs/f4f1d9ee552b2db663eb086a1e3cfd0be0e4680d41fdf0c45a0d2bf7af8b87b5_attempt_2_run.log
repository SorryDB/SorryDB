    wlog h_lt : x < y generalizing x y
    · exact (this y x hxy.symm heq.symm).symm
    have linked_of_root (C : Company n k_min) (x y : Fin N) (h : getRoot C x = getRoot C y) (hxy : x < y) : C.linked x y := by
      let rec path (curr : Fin N) (h_curr : getRoot C curr = getRoot C x) : List (Fin k_min) :=
        if eq : curr = x then []
