    have h_card (C : Company n k_min) : Fintype.card (roots C) = n - 1 := by
      let Im := Set.range (fun j => (C.cars j).finish)
      rw [Fintype.card_of_finset (Set.toFinset _), Set.toFinset_setOf]
      convert Finset.card_univ_diff (Set.toFinset Im)
      rw [Finset.card_map, Fintype.card_fin]; exact C.injective_finish
      simp [k_min, N]; omega
    let rec getRoot (C : Company n k_min) (i : Fin N) : Fin N :=
      if h : ∃ j, (C.cars j).finish = i then
        have : (C.cars h.some).start < i := by rw [←h.some_spec]; exact (C.cars h.some).start_lt_finish
        getRoot C (C.cars h.some).start
      else i
      termination_by i
    let f (i : Fin N) := (getRoot A i, getRoot B i)
    have : Fintype.card (Set.range f) < Fintype.card (Fin N) := by
      apply lt_of_le_of_lt (Fintype.card_range_le f)
      rw [Fintype.card_fin]
      calc Fintype.card ((roots A) × (roots B))
        _ = (n - 1) * (n - 1) := by rw [Fintype.card_prod, h_card A, h_card B]
        _ < n * n := by nlinarith
