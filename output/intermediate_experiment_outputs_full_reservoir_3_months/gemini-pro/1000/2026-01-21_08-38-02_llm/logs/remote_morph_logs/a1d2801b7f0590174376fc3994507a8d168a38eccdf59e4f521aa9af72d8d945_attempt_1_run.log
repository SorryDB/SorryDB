def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp_all only [circuit_norm, LessThan.circuit, Prod.mk.injEq]
    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith
    rw [ZMod.val_add_of_lt hy, ZMod.val_one] at h_holds
    by_cases hy : y.val + 1 = 2^n
    case neg =>
      specialize h_holds (by omega)
      simp_all [Nat.lt_add_one_iff]
    -- TODO the spec of LessThan is not strong enough to handle this case
    sorry

  completeness := by
    circuit_proof_start
    simp only [circuit_norm, LessThan.circuit, Prod.mk.injEq] at *
    rcases h_assumptions with ⟨hx, hy⟩
    have hx_eval : Expression.eval env input_var.1 = x := by simpa using congrArg Prod.fst h_input
    have hy_eval : Expression.eval env input_var.2 = y := by simpa using congrArg Prod.snd h_input
    simp only [hx_eval, hy_eval]

    have h_pow_n : 2^n < p := by
      have : 2^n < 2^(n+1) := by gcongr; simp
      linarith
    have hy_val : (y + (1 : F p)).val = y.val + 1 := by
      apply ZMod.val_add_of_lt
      apply lt_trans _ hn
      apply lt_of_lt_of_le hy
      apply pow_le_pow_right (by simp) (by simp)

    have h_val : (x + (2^n : F p) - (y + 1)).val = x.val + 2^n - (y.val + 1) := by
      rw [ZMod.val_sub]
      · rw [ZMod.val_add_of_lt]
        · simp [hy_val]; linarith
        · apply lt_trans _ hn; linarith
      · simp [hy_val]; linarith [hx]

    split_ifs with h_le
    · simp only [sub_eq_add_neg, add_assoc]
      have h_bound : (x + (2^n : F p) - (y + 1)).val < 2^n := by
        rw [h_val]; linarith
      simp [Utils.Bits.toBits, Vector.getElem_mapRange, Nat.testBit_eq_false_of_lt h_bound]
      rfl
    · push_neg at h_le
      simp only [sub_eq_add_neg, add_assoc]
      have h_bound_low : 2^n ≤ (x + (2^n : F p) - (y + 1)).val := by
        rw [h_val]; linarith
      have h_bound_high : (x + (2^n : F p) - (y + 1)).val < 2^(n+1) := by
        rw [h_val]
        have : 2^(n+1) = 2^n + 2^n := by ring
        linarith
      simp [Utils.Bits.toBits, Vector.getElem_mapRange]
      rw [Nat.testBit_eq_true_iff_self_div_two_pow_mod_two_eq_one]
      rw [Nat.div_eq_of_lt_le h_bound_low h_bound_high]

end LessEqThan
