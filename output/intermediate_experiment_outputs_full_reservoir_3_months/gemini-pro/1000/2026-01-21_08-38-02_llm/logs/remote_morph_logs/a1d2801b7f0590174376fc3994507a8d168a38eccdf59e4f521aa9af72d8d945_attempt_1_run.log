    let diff_val := x.val + 2^n - (y.val + 1)
    have h_diff_eq : ZMod.val (x + (2^n : F p) - (y + 1)) = diff_val := by
      rw [ZMod.val_sub, ZMod.val_add, ZMod.val_add_of_lt h_y_lt, ZMod.val_one]
      · rw [ZMod.val_ofNat_of_lt (lt_trans (by apply pow_lt_pow_right (by decide); omega) hn)]
        rw [Nat.mod_eq_of_lt (by apply lt_trans _ hn; omega)]
        -- We need to check if x + 2^n >= y + 1. Since y < 2^n, y+1 <= 2^n. x >= 0.
        -- So x + 2^n >= 2^n >= y + 1. No wrapping in sub.
        rw [Nat.mod_eq_of_lt]
        · omega
