      rw [Nat.succ_eq_add_one, add_assoc, ← two_mul, ← pow_succ]
      exact hn

    have h_x_plus_2n : (x + (2^n : F p)).val = x.val + 2^n := by
      rw [ZMod.val_add_of_lt, ZMod.val_nat_cast]
