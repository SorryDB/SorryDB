def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp_all only [circuit_norm, LessThan.circuit, Prod.mk.injEq]
    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith
    rw [ZMod.val_add_of_lt hy, ZMod.val_one] at h_holds
    by_cases hy : y.val + 1 = 2^n
    case neg =>
      specialize h_holds (by omega)
      simp_all [Nat.lt_add_one_iff]
    -- TODO the spec of LessThan is not strong enough to handle this case
    sorry

  completeness := by
    intro i env input h_env (x, y) h_input assumptions
    simp only [circuit_norm, LessThan.circuit, LessThan.main, Num2Bits.circuit] at *
    rcases assumptions with ⟨hx, hy⟩
    rcases h_env with ⟨_, h_bits_eq⟩
    rw [←h_input.1, ←h_input.2] at h_bits_eq
    simp only at h_bits_eq

    have h_p : 2^(n+1) < p := hn
    have h_diff : (x + (2^n : F p) - (y + 1)).val = x.val + 2^n - (y.val + 1) := by
      rw [ZMod.val_sub_of_eq_add, ZMod.val_add_of_lt]
      · simp [ZMod.val_one]
      · simp [ZMod.val_one]; omega
      · rw [ZMod.val_add_of_lt] <;> try omega
        apply lt_trans _ hn; gcongr; repeat linarith
        apply lt_trans _ hn; calc x.val + 2^n < 2^n + 2^n := by omega
                               _ = 2^(n+1) := by ring

    rw [←h_bits_eq, h_diff]
    simp only [Nat.cast_ite, Nat.cast_one, Nat.cast_zero]
    split_ifs with h_le
    · rw [Nat.testBit_eq_false_of_lt]
      · simp
      · omega
    · have h_ge : 2^n ≤ x.val + 2^n - (y.val + 1) := by omega
      have h_lt : x.val + 2^n - (y.val + 1) < 2^(n+1) := by omega
      have : (x.val + 2^n - (y.val + 1)) / 2^n = 1 := by
        apply Nat.eq_of_le_of_lt_succ
        · rwa [Nat.le_div_iff_mul_le]
          exact Nat.pow_pos (by decide) n
        · rw [Nat.div_lt_iff_lt_mul]
          · rwa [pow_succ', two_mul] at h_lt
          · exact Nat.pow_pos (by decide) n
      simp [Nat.testBit, Nat.shiftRight_eq_div_pow, this]

end LessEqThan
