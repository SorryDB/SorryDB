  ⟨fun v ↦ by
    let K_v := v.adicCompletion ℚ
    let O_v := v.adicCompletionIntegers ℚ
    let φ := (Aux.c_v V v).toContinuousLinearEquiv
    let ψ := (LinearMap.lTensor (IntegralLattice ℤ ℚ V) O_v.subtype.toAddMonoidHom.toIntLinearMap)

    -- We want to show IsOpen (range (φ ∘ ψ)).
    -- Since φ is a homeomorphism, this is equivalent to IsOpen (range ψ) in the domain.
    rw [← φ.isOpen_image]
