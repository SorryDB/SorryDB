    simp only [LinearEquiv.toAddMonoidHom_eq_coe, LinearMap.toAddMonoidHom_eq_coe,
      AddMonoidHom.range_comp, AddMonoidHom.range_eq_map]

    -- Now show IsOpen (range ψ).
    -- range ψ is the image of L ⊗ O_v in L ⊗ K_v.
    -- Identify L ⊗ K_v with (K_v)^n using the lattice basis.
    let bL := IntegralLattice.basis ℤ ℚ V
    let iso := (bL.baseChange K_v).equivFunL
    rw [← iso.isOpen_image]

    -- The image of range ψ under iso is exactly Π O_v.
    suffices iso '' ψ.toAddMonoidHom.range = Set.pi Set.univ (fun _ ↦ (O_v : Set K_v)) by
      rw [this]
      apply isOpen_set_pi Set.finite_univ
      intro _ _
      exact NumberField.isOpenAdicCompletionIntegers ℚ v

    -- Proof of equality
    ext f
    simp only [Set.mem_image, AddMonoidHom.mem_range, Set.mem_pi, Set.mem_univ, true_implies]
    let bL_Ov := bL.baseChange O_v
    constructor
    · rintro ⟨_, ⟨y, rfl⟩, rfl⟩
      -- x = ψ y. iso x = ?
      -- y = ∑ c_i (bL i ⊗ 1_Ov).
      -- ψ y = ∑ c_i (bL i ⊗ 1_Kv).
