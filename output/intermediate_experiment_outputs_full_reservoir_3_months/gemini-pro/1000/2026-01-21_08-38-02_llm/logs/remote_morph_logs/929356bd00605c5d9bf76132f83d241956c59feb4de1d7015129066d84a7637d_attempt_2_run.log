instance : Fact (∀ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ), IsOpen
  (((Aux.c_v_alg V v)).toAddMonoidHom.comp
    (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
      (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
        v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range.carrier) :=
  ⟨fun v ↦ by
    let b := IntegralLattice.basis ℤ ℚ V
    let R := v.adicCompletionIntegers ℚ
    let K_v := v.adicCompletion ℚ
    let b_Kv := b.baseChange K_v
    let b_R := b.baseChange R
    -- c_v is a homeomorphism, so we can ignore it
    rw [← (Aux.c_v V v).toHomeomorph.isOpen_image_iff]
    -- The range is determined by coordinates in the integral basis
    let φ := fun i ↦ (b_Kv.coord i).toContinuousLinearMap
    have : LinearMap.range (LinearMap.lTensor (IntegralLattice ℤ ℚ V) R.subtype.toIntLinearMap) =
        { x | ∀ i, φ i x ∈ R } := by
      ext x
      simp only [LinearMap.mem_range, Set.mem_setOf_eq]
      constructor
      · rintro ⟨u, rfl⟩ i
        rw [← b_R.sum_repr u, map_sum]
        simp only [LinearMap.lTensor_tmul, LinearMap.coe_mk, AddHom.coe_mk, Submodule.coeSubtype,
          Submodule.subtype_apply, TensorProduct.tmul_sum, ← Basis.baseChange_apply,
          ContinuousLinearMap.coe_coe, LinearMap.coe_toContinuousLinearMap, Basis.coord_apply,
          Basis.repr_self, Finsupp.single_apply]
        rw [Finset.sum_eq_single i]
        · simp; exact (b_R.repr u i).2
        · intros; simp
        · simp
      · intro h
        refine ⟨∑ i : Module.Basis.ofVectorSpaceIndex ℚ V, (⟨φ i x, h i⟩ : R) • (b_R i), ?_⟩
        apply b_Kv.ext; intro i
        simp only [LinearMap.lTensor_tmul, LinearMap.coe_mk, AddHom.coe_mk, Submodule.coeSubtype,
          Submodule.subtype_apply, TensorProduct.tmul_sum, ← Basis.baseChange_apply, map_sum,
          Basis.coord_apply, Basis.repr_self, Finsupp.single_apply, ContinuousLinearMap.coe_coe,
          LinearMap.coe_toContinuousLinearMap, smul_eq_mul]
        rw [Finset.sum_eq_single i]
        · simp
        · intros; simp
        · simp
    rw [this]
    -- The set of vectors with integral coordinates is open (finite intersection of open half-spaces)
    exact isOpen_iInter_of_finite (fun i ↦ (φ i).continuous.isOpen_preimage _
      (NumberField.isOpenAdicCompletionIntegers ℚ v))⟩
