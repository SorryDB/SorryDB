/-- `unreverse x` has no reversible positions. -/
theorem not_reversible_unreverse (hy : y ∈ x.unreverse.moves p) : ¬ Reversible x.unreverse y p := by
  rw [moves_unreverse, Set.mem_iUnion₂] at hy
  obtain ⟨y, hy, ⟨z, hz, rfl⟩⟩ := hy
  by_cases h : Reversible x y p
  · sorry
  · rw [reverseSet_of_not_reversible h] at hz
    subst hz
    intro h'
    cases p <;> obtain ⟨w, hw, hwx⟩ := h'
    <;> rw [moves_unreverse, Set.mem_iUnion₂] at hw
    <;> obtain ⟨z, hz, ⟨k, hk, rfl⟩⟩ := hw
    <;> by_cases hr : Reversible y z _
    <;> simp [reverseSet_of_not_reversible hr] at hk
    <;> subst hk
    · have := hr.choose_spec
      have := (unreverse_equiv k).trans (hwx.trans (unreverse_equiv x).symm)
      apply h; use z, hz
      rw [le_iff_forall_lf]; constructor
      · intro u hu
        if e : u = hr.choose then rw [e]; exact lf_of_right_le this hk else
        have := hr.choose_le; aesop
      · aesop
    · apply h; use z, hz
      exact (unreverse_equiv z).trans_le (hwx.trans (unreverse_equiv x).symm)
    · have := hr.choose_spec
      have := (unreverse_equiv x).trans (hwx.trans (unreverse_equiv k).symm)
      apply h; use z, hz
      rw [le_iff_forall_lf]; constructor
      · aesop
      · intro u hu
        if e : u = hr.choose then rw [e]; exact lf_of_le_left this hk else
        have := hr.le_choose; aesop
    · apply h; use z, hz
      exact (unreverse_equiv x).trans_le (hwx.trans (unreverse_equiv z).symm)
