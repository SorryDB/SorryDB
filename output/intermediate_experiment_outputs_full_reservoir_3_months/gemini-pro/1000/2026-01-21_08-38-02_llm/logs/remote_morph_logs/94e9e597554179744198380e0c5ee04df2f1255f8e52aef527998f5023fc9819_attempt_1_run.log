lemma matchingMatroid.noColoop (h : ∀ x, G.inessential x) (hx : x ∈ V(G)) :
    ¬ G.matchingMatroid.IsColoop x := by
  obtain ⟨M, hM, hxM⟩ := h x
  rw [Matroid.isColoop_iff_forall_mem_base]
  push_neg
  have hB : G.matchingMatroid.IsBase V(G, M)
  · rw [Matroid.isBase_iff_maximal_indep]
    refine ⟨⟨M, hM.toIsMatching, Subset.rfl⟩, ?_⟩
    rintro I ⟨M', hM', hI⟩ hsub
    have h_le := hM.max M' hM'
    -- Since M is a maximum matching, M' cannot have more edges.
    -- Thus V(M) and V(M') have the same cardinality (assuming finiteness or valid encard).
    -- Since V(M) ⊆ I ⊆ V(M'), V(M) must be equal to I.
    have h_eq : V(G, M).encard = I.encard
    · refine le_antisymm (encard_le_encard hsub) ?_
      calc I.encard ≤ V(G, M').encard := encard_le_encard hI
        _ = 2 * M'.encard := by simp [encard_vertex_eq_two_mul_encard_of_isMatching]
        _ ≤ 2 * M.encard := by gcongr
        _ = V(G, M).encard := by simp [encard_vertex_eq_two_mul_encard_of_isMatching]
    -- We assume the graph or matching allows this deduction
    exact hsub.antisymm (eq_of_subset_of_encard_le hsub h_eq.ge (M.finite_vertex_of_isMatching))
  exact ⟨_, hB, hxM⟩
