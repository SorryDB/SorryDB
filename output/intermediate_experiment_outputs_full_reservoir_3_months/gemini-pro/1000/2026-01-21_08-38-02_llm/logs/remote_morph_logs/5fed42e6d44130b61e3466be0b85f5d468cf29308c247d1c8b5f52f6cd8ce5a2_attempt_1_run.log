open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  let measure (x : HopfieldState n) : ℕ := (Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net x)).card
  let rec solve (x : HopfieldState n) : Σ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target :=
    if h : biasedIsFixedPoint net x then
      ⟨BiasedUpdateSeq.nil x, h⟩
    else
      let i := Classical.choose (Classical.not_forall.mp h)
      let x' := biasedUpdateState net x i
      let ⟨seq', h_fp⟩ := solve x'
      ⟨BiasedUpdateSeq.cons x i seq', h_fp⟩
    termination_by measure x
    decreasing_by
      simp_wf
      let i := Classical.choose (Classical.not_forall.mp h)
      have h_neq : biasedUpdateState net x i ≠ x := Classical.choose_spec (Classical.not_forall.mp h)
      have h_E : biasedEnergy net (biasedUpdateState net x i) < biasedEnergy net x :=
        lt_of_sub_neg (lt_of_le_of_ne (biasedEnergy_decreasing net x i) (mt (biasedEnergy_fixed_point_iff_no_change net x i).mp h_neq))
      apply Finset.card_lt_card
      apply Finset.ssubset_of_subset_of_ne
      · intro y hy
        simp only [Finset.mem_filter, Finset.mem_univ, true_and] at hy ⊢
        exact lt_trans hy h_E
      · intro h_eq
        have h_in : biasedUpdateState net x i ∈ Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net x) := by
          simp only [Finset.mem_filter, Finset.mem_univ, true_and]; exact h_E
        rw [← h_eq] at h_in
        simp only [Finset.mem_filter, Finset.mem_univ, true_and, lt_self_iff_false] at h_in
  exact let ⟨seq, h⟩ := solve x; ⟨seq, h⟩
