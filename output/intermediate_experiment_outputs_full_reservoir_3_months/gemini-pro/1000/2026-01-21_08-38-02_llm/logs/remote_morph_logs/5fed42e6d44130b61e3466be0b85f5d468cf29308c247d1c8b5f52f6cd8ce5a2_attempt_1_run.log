theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  let E := biasedEnergy net
  let m (x : HopfieldState n) := (Finset.univ.filter (fun y => E y < E x)).card
  have h_meas : ∀ x i, biasedUpdateState net x i ≠ x → m (biasedUpdateState net x i) < m x := by
    intro x i h_ne
    let x' := biasedUpdateState net x i
    have h_lt : E x' < E x := by
      have h1 := biasedEnergy_decreasing net x i
      have h2 : biasedEnergyDiff net x i ≠ 0 := by rw [biasedEnergy_fixed_point_iff_no_change]; exact h_ne
      unfold biasedEnergyDiff at h1 h2
      exact lt_of_le_of_ne h1 h2
    apply Finset.card_lt_card
    rw [Finset.ssubset_iff]
    refine ⟨fun y hy => ?_, fun h => ?_⟩
    · rw [Finset.mem_filter] at hy ⊢
      exact ⟨hy.1, lt_trans hy.2 h_lt⟩
    · have hx' : x' ∈ Finset.univ.filter (fun y => E y < E x) := by
        rw [Finset.mem_filter]; exact ⟨Finset.mem_univ _, h_lt⟩
      have hx'_not : x' ∉ Finset.univ.filter (fun y => E y < E x') := by
        rw [Finset.mem_filter]; push_neg; intro; exact lt_irrefl _
      exact hx'_not (h hx')
  
  intro x
  induction x using (InvImage.wf m Nat.lt_wfRel.wf).induction with
  | h x ih =>
    if h_fix : biasedIsFixedPoint net x then
      exact ⟨BiasedUpdateSeq.nil x, h_fix⟩
    else
      rw [biasedIsFixedPoint] at h_fix
      have ⟨i, hi⟩ := Classical.not_forall.mp h_fix
      have h_step := h_meas x i hi
      let ⟨seq, h_seq⟩ := ih (biasedUpdateState net x i) h_step
