section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  let E := biasedEnergy net
  let R := InvImage (· < ·) E
  have h_wf : WellFounded R := Finite.wellFounded_of_trans_of_irrefl R
  intro x
  induction x using h_wf.induction with
  | h x ih =>
    by_cases h_fp : biasedIsFixedPoint net x
    · exact ⟨BiasedUpdateSeq.nil x, h_fp⟩
    · rw [biasedIsFixedPoint] at h_fp
      push_neg at h_fp
      obtain ⟨i, h_neq⟩ := h_fp
      let x' := biasedUpdateState net x i
      have h_lt : E x' < E x := by
        have h_lf : biasedLocalField net x i ≠ 0 := by
          intro h_z
          rw [biasedUpdateState, h_z] at h_neq
          simp only [if_false, lt_self_iff_false] at h_neq
          rw [Function.update_eq_self] at h_neq
          contradiction
        have h_diff := biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero net x i h_neq h_lf
        rw [biasedEnergyDiff] at h_diff
        exact sub_lt_zero.mp h_diff
      obtain ⟨seq, h_res⟩ := ih x' h_lt
      exact ⟨BiasedUpdateSeq.cons x i seq, h_res⟩
```
