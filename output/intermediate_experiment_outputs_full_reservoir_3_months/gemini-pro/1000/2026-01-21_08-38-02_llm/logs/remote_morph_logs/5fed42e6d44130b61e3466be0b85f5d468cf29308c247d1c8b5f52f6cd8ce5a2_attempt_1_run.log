theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let measure (s : HopfieldState n) : ℕ := (Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net s)).card
  have wf : WellFounded (InvImage (· < ·) measure) := InvImage.wf measure Nat.lt_wfRel.wf
  induction x using wf.induction with
  | h x ih =>
    by_cases h_fp : biasedIsFixedPoint net x
    · exact ⟨BiasedUpdateSeq.nil x, h_fp⟩
    · rw [biasedIsFixedPoint, not_forall] at h_fp
      rcases h_fp with ⟨i, h_neq⟩
      let x' := biasedUpdateState net x i
