section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let measure (s : HopfieldState n) : ℕ := (Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net s)).card
  let rec solve (s : HopfieldState n) : ∃ seq : BiasedUpdateSeq net s, biasedIsFixedPoint net seq.target :=
    if h_fp : biasedIsFixedPoint net s then
      ⟨BiasedUpdateSeq.nil s, h_fp⟩
    else
      let ⟨i, h_not_fixed⟩ := Classical.not_forall.mp h_fp
      have h_ne : biasedUpdateState net s i ≠ s := h_not_fixed
      have h_lf : biasedLocalField net s i ≠ 0 := by
        intro h_zero
        have := h_ne
        unfold biasedUpdateState at this
        simp [h_zero] at this
      have h_dec : biasedEnergyDiff net s i < 0 :=
        biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero net s i h_ne h_lf
      have h_measure : measure (biasedUpdateState net s i) < measure s := by
        apply Finset.card_lt_card
        rw [Finset.ssubset_iff_of_subset (Finset.filter_subset_filter (fun y _ hy => lt_trans hy (sub_lt_zero.mp h_dec)))]
        refine ⟨biasedUpdateState net s i, ?_, ?_⟩
        · simp only [Finset.mem_filter, Finset.mem_univ, true_and]
          exact sub_lt_zero.mp h_dec
        · simp only [Finset.mem_filter, Finset.mem_univ, true_and, lt_self_iff_false, not_false_eq_true]
      let ⟨seq', h_target⟩ := solve (biasedUpdateState net s i)
      ⟨BiasedUpdateSeq.cons s i seq', h_target⟩
    termination_by measure s
  exact solve x
