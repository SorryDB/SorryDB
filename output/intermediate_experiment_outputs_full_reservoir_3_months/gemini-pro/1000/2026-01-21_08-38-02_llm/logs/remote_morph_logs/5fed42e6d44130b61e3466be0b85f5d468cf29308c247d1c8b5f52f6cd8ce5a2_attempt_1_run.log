section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  classical
  let E := biasedEnergy net
  let vals := Finset.image E Finset.univ
  let rank (x : HopfieldState n) : ℕ := (vals.filter (· < E x)).card
  have rank_dec : ∀ x i, biasedUpdateState net x i ≠ x → rank (biasedUpdateState net x i) < rank x := by
    intro x i neq
    have lf_ne : biasedLocalField net x i ≠ 0 := by
      intro h
      simp [biasedUpdateState, h] at neq
    have elt : E (biasedUpdateState net x i) < E x :=
      biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero net x i neq lf_ne
    apply Finset.card_lt_card
    rw [Finset.ssubset_iff_subset_ne]
    constructor
    · intro y hy
      rw [Finset.mem_filter] at hy ⊢
      exact ⟨hy.1, lt_trans hy.2 elt⟩
    · intro eq
      have in_vals : E (biasedUpdateState net x i) ∈ vals.filter (· < E x) := by
        rw [Finset.mem_filter]
        exact ⟨Finset.mem_image_of_mem _ (Finset.mem_univ _), elt⟩
      rw [←eq, Finset.mem_filter] at in_vals
      exact lt_irrefl _ in_vals.2
  intro x
  generalize hk : rank x = k
  induction k using Nat.strong_induction_on generalizing x with
  | h k ih =>
    by_cases fp : biasedIsFixedPoint net x
    · exact ⟨BiasedUpdateSeq.nil x, fp⟩
    · unfold biasedIsFixedPoint at fp; push_neg at fp
      rcases fp with ⟨i, hi⟩
      let x' := biasedUpdateState net x i
      have r_lt : rank x' < k := by rw [←hk]; exact rank_dec x i hi
      rcases ih (rank x') r_lt x' rfl with ⟨seq, hseq⟩
      exact ⟨BiasedUpdateSeq.cons x i seq, hseq⟩
