section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  let E := biasedEnergy net
  let measure (x : HopfieldState n) := (Finset.univ.filter (fun y => E y < E x)).card
  intro x
  induction measure x using Nat.strong_induction_on generalizing x with
  | h m ih =>
    by_cases h_fixed : biasedIsFixedPoint net x
    · exact ⟨BiasedUpdateSeq.nil x, h_fixed⟩
    · rw [biasedIsFixedPoint] at h_fixed
      rw [Classical.not_forall] at h_fixed
      rcases h_fixed with ⟨i, h_not_fixed⟩
      let x' := biasedUpdateState net x i
      have h_energy_lt : E x' < E x := by
        refine lt_of_le_of_ne (biasedEnergy_decreasing net x i) ?_
        intro h_eq
        have h_diff_zero : biasedEnergyDiff net x i = 0 := sub_eq_zero.mpr h_eq
        rw [biasedEnergy_fixed_point_iff_no_change] at h_diff_zero
        exact h_not_fixed h_diff_zero
      have h_measure_lt : measure x' < measure x := by
        apply Finset.card_lt_card
        rw [Finset.ssubset_iff_subset_ne]
        constructor
        · intro y hy
          rw [Finset.mem_filter] at hy ⊢
          exact ⟨hy.1, lt_trans hy.2 h_energy_lt⟩
        · intro h_eq
          have h_in : x' ∈ Finset.univ.filter (fun y => E y < E x) := by
            simp only [Finset.mem_filter, Finset.mem_univ, true_and, h_energy_lt]
          rw [h_eq] at h_in
          simp only [Finset.mem_filter, lt_self_iff_false, and_false] at h_in
      rcases ih (measure x') h_measure_lt x' with ⟨seq', h_target⟩
      exact ⟨BiasedUpdateSeq.cons x i seq', h_target⟩
