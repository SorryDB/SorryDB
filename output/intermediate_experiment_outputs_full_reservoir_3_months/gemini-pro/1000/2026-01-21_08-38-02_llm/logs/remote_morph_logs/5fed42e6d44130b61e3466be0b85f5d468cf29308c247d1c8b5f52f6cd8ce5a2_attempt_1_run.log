section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let meas (s : HopfieldState n) : ℕ := (Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net s)).card
  have h_decr : ∀ s i, biasedUpdateState net s i ≠ s → meas (biasedUpdateState net s i) < meas s := by
    intro s i hne
    let s' := biasedUpdateState net s i
    have E_decr : biasedEnergy net s' < biasedEnergy net s := by
      apply biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero
      · exact hne
      · by_contra h0
        have : s' = s := by
          unfold biasedUpdateState; simp [h0]
          funext j; simp [Function.update]; split_ifs <;> rfl
        contradiction
    apply Finset.card_lt_card
    refine ⟨?_, ?_⟩
    · intro y hy; rw [Finset.mem_filter] at *; exact ⟨hy.1, lt_trans hy.2 E_decr⟩
    · intro h_eq
      have : s' ∈ Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net s) := by
        simp [Finset.mem_filter, E_decr]
      rw [←h_eq] at this; simp at this; exact lt_irrefl _ this

  let rec solve (s : HopfieldState n) : Σ seq : BiasedUpdateSeq net s, biasedIsFixedPoint net seq.target :=
    if h : biasedIsFixedPoint net s then
      ⟨BiasedUpdateSeq.nil s, h⟩
    else
      let i := Classical.choose (Classical.not_forall.mp h)
      let hi := Classical.choose_spec (Classical.not_forall.mp h)
      let ⟨seq', h_final⟩ := solve (biasedUpdateState net s i)
      ⟨BiasedUpdateSeq.cons s i seq', h_final⟩
    termination_by meas s
    decreasing_by apply h_decr; exact hi

  exact ⟨(solve x).1, (solve x).2⟩
