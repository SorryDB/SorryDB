      convert (f _ hx.choose_spec.choose_spec).dsmooth using 1
      ext; sorry
    -- Restriction
    · intro m g hg; ext y
      -- Check that g^* s = f g
      -- Follows from definition of s and compatibility hf
      sorry
    -- Uniqueness
    · intro s' hs'; ext x
      -- s' must satisfy pullback property, so it must match s
      sorry
