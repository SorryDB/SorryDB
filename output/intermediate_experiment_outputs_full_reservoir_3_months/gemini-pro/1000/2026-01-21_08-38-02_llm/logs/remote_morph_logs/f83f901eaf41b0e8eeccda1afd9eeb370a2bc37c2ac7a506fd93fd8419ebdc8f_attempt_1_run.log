    rw [CartSp.openCoverTopology, isSheaf_iff_isSheaf_of_type, Presieve.isSheaf_coverage]
    intro n S hS f hf
    -- We define the section pointwise.
    let s : Eucl n.unop → ((Eucl n.unop) [⋀^(Fin k)]→ₗ[ℝ] ℝ) := fun x ↦
      -- Pick a chart g covering x
      let hx := Set.mem_iUnion.1 (hS.2.symm ▸ Set.mem_univ x)
      let g := hx.choose
      let y := hx.choose_spec.choose
      -- The value is (f g ... y) ∘ (dg_y)⁻¹
      -- We assume dg_y is surjective (it is an isomorphism) to get the inverse
