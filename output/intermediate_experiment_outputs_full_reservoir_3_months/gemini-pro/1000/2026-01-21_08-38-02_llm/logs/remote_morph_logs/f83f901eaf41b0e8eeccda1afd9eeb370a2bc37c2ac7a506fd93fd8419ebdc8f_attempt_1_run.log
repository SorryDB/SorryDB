    · rw [dsmooth_iff_locally_dsmooth]; intro x
      -- Smoothness is local, so we check on the chart g covering x
      let hx := Set.mem_iUnion.1 (hS.2.symm ▸ Set.mem_univ x)
      -- g is a subduction (open embedding)
      rw [(DDiffeomorph.ofIsInduction (hS.1 _ hx.choose_spec.choose_spec).1).isSubduction.dsmooth_iff]
