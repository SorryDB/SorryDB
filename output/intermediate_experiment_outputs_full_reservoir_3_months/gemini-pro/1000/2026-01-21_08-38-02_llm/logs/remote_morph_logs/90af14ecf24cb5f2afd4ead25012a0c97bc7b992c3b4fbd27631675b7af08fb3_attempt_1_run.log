def seqFunctor (S : LightProfinite.{0}) : ℕ+ ⥤ LightProfinite where
  obj c := profiniteComponent S c
  map f := limit.map (whiskerLeft S.fintypeDiagram (NatTrans.of fun Si =>
    FintypeCat.toLightProfinite.map (FintypeCat.ofHom (fun a => ⟨a.1, le_trans a.2 (le_of_hom f)⟩))))
  map_id _ := limit.hom_ext fun j => by
    simp only [limit.map_π, whiskerLeft_app, NatTrans.of_app, Category.id_comp, Category.comp_id]
    erw [← Functor.map_id]
    rfl
  map_comp _ _ := limit.hom_ext fun j => by
    simp only [limit.map_π, whiskerLeft_app, NatTrans.of_app, Category.assoc, Category.comp_id]
    erw [← Functor.map_comp]
    rfl
