  by_contra h
  push_neg at h
  let N := 2021
  let S (k : ℕ) : Finset (Fin N) := {x | (p.nth k) x < k}.toFinset
  let ind (k : ℕ) (i : Fin N) : ℤ := if i ∈ S k then 1 else 0
  let b (k : ℕ) : ℤ := ∑ i : Fin N, |ind k i - ind k (i + 1)|

  -- Analyze the change in boundary count at each step
  have step (k : ℕ) (hk : k < N) : b (k + 1) - b k = 2 - 4 * ind k ((p.nth k).symm k - 1) := by
    let pk := p.nth k
    let h_pos := pk.symm k
    let u := (pk.swapped k).1
    let v := (pk.swapped k).2
    -- Neighbors status
    have same_status : ind k (h_pos - 1) = ind k (h_pos + 1) := by
      simp only [ind, S, Set.toFinset_setOf, Set.mem_setOf_eq, Finset.mem_toFinset]
      change pk (h_pos - 1) < k ↔ pk (h_pos + 1) < k
      have : pk (h_pos - 1) = u := rfl
      have : pk (h_pos + 1) = v := rfl
      rw [‹pk (h_pos - 1) = u›, ‹pk (h_pos + 1) = v›]
      have hk := h k
      simp [u, v] at hk ⊢
      tauto

    -- Update of S
    have S_update : S (k + 1) = insert h_pos (S k) := by
      ext x
      simp only [S, Set.toFinset_setOf, Finset.mem_insert, Set.mem_setOf_eq]
      have move : p.nth (k + 1) = pk.trans (Equiv.swap u v) := rfl
      rw [move, Equiv.trans_apply, Equiv.swap_apply_def]
      -- x ∈ S (k+1) ↔ pk.trans swap x < k + 1
      -- pk h_pos = k. swap k = k < k + 1. So h_pos is in.
      -- If x ≠ h_pos, pk x ≠ k.
      -- swap (pk x) < k + 1 ↔ swap (pk x) < k.
      -- If pk x ∈ {u, v}, swap maps to {v, u}. Since u<k ↔ v<k, condition preserved.
      -- If pk x ∉ {u, v}, swap fixes it. Preserved.
      split_ifs with h1 h2 h3 h4
      · subst h1; simp [Nat.lt_succ_self]
      · simp [Nat.lt_succ_iff_lt_or_eq, Ne.symm h2]
        by_cases hu : pk x = u
        · rw [if_pos hu]; rw [←hu];
          have : u < k ↔ v < k := by { have := h k; simp [u,v] at this; tauto }
          rw [this]
        · rw [if_neg hu];
          by_cases hv : pk x = v
          · rw [if_pos hv]; rw [←hv];
            have : u < k ↔ v < k := by { have := h k; simp [u,v] at this; tauto }
            rw [←this]
          · rw [if_neg hv]

    -- Calculate difference
    -- Terms at i = h_pos - 1 and i = h_pos change.
    let term (k' : ℕ) (i : Fin N) := |ind k' i - ind k' (i + 1)|
    let i1 := h_pos - 1
    let i2 := h_pos
    have h_diff : b (k + 1) - b k = (term (k + 1) i1 - term k i1) + (term (k + 1) i2 - term k i2) := by
      simp [b, Finset.sum_sub_distrib]
      apply Finset.sum_subset_zero_on_sdiff (Finset.subset_univ _)
      · intro i _ hi
        simp at hi
        have : i ≠ i1 ∧ i ≠ i2 := by { push_neg at hi; exact hi }
        have not_mem : i ∉ {i1, i2} := by simp [this]
        -- Show ind (k+1) i = ind k i and ind (k+1) (i+1) = ind k (i+1)
        have eq_ind (j : Fin N) (hj : j ≠ h_pos) : ind (k + 1) j = ind k j := by
          simp [ind, S_update]; rw [if_neg hj]
        rw [term, term, eq_ind i (by rintro rfl; exact not_mem (by left; rfl))]
        rw [eq_ind (i+1) (by rintro rfl; exact not_mem (by right; rfl))]
        sub_self
      · simp

    -- Evaluate local changes
    have h_new : ind (k + 1) h_pos = 1 := by simp [ind, S_update]
    have h_old : ind k h_pos = 0 := by simp [ind, S]; exact lt_irrefl k
    have eq1 : ind (k + 1) i1 = ind k i1 := by
      simp [ind, S_update]; rw [if_neg]; intro c; have : i1 + 1 = h_pos := by simp [i1];
      rw [c] at this; simp at this; apply Nat.ne_of_lt (Nat.lt_succ_self 0) this -- 2021 != 0
    have eq2 : ind (k + 1) (i2 + 1) = ind k (i2 + 1) := by
      simp [ind, S_update]; rw [if_neg]; intro c;
      have : i2 + 1 = h_pos := c; simp at this; apply Nat.ne_of_lt (Nat.lt_succ_self 0) this.symm
    
    rw [h_diff]
    dsimp [term]
    rw [eq1, eq2, h_new, h_old]
    have : i1 + 1 = h_pos := by simp [i1]
    rw [this]
    -- |I - 1| + |1 - J| - (|I - 0| + |0 - J|) with I=J
    let I := ind k i1
    have J_eq : ind k (h_pos + 1) = I := same_status.symm
    rw [J_eq]
    -- |I - 1| + |1 - I| - (|I| + |I|)
    -- I is 0 or 1. |I - 1| = 1 - I.
    -- (1 - I) + (1 - I) - 2I = 2 - 4I
    have I_range : I = 0 ∨ I = 1 := by cases I <;> try simp; rename_i n; cases n <;> try simp
    cases I_range with
    | inl h0 => rw [h0]; norm_num
    | inr h1 => rw [h1]; norm_num

  -- Summing up
  have sum_eq : ∑ k in Finset.range N, (b (k + 1) - b k) = 0 := by
    rw [Finset.sum_range_sub]
    have b0 : b 0 = 0 := by simp [b, ind, S]; apply Finset.sum_eq_zero; intro; simp; rfl
    have bN : b N = 0 := by
      simp [b, ind, S]; apply Finset.sum_eq_zero; intro i _
      have : ∀ x, x < N := λ x => x.isLt
      simp [this]
    rw [b0, bN, sub_self]

  rw [Finset.sum_congr rfl step] at sum_eq
  simp only [Finset.sum_sub_distrib, Finset.sum_const, Finset.card_range, nsmul_eq_mul] at sum_eq
  
  -- 2N - 4 Sum = 0 => N = 2 Sum => N even.
  have : (2 : ℤ) * N = 4 * ∑ k in Finset.range N, ind k ((p.nth k).symm k - 1) := by
    linarith
  have even_N : 2 ∣ (N : ℤ) := by
    use 2 * ∑ k in Finset.range N, ind k ((p.nth k).symm k - 1)
    rw [this]; ring
  
  have odd_N : ¬ (2 ∣ (N : ℤ)) := by
    intro h; have : N % 2 = 0 := Int.emod_eq_zero_of_dvd h; norm_num at this
  
  exact odd_N even_N
