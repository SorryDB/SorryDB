          have : v < k := same_side.1 c
          exact huk (le_of_lt (same_side.2 this) |> (ne_of_lt huk).symm ▸ k) -- contradiction
        -- u, v > k. Edges (k,u), (k,v).
        -- e.2 = k implies e.1 < k. No such edges.
        sorry

    -- Edges with y >= k+1
    -- S k = |edges with y=k| + |edges with y>=k+1|
    have Sk_eq : S k = k_edges.card + ((edges q).filter (λ e => k + 1 ≤ e.2)).card := by
      sorry -- disjoint union split
    
    -- S (k+1) = |edges(P (k+1)) with y>=k+1|
    -- Compare edges(q) and edges(P(k+1)) restricted to y>=k+1.
    -- The move swaps u and v.
    -- This affects edges {z, u}, {v, w} -> {z, v}, {u, w}.
    -- We show the count change is even.
    have update_even : ((edges q).filter (λ e => k + 1 ≤ e.2)).card % 2 = S (k + 1) % 2 := by
      sorry -- Standard graph surgery parity argument as derived in scratchpad.
    
    rw [Sk_eq]
    rw [Nat.add_mod, k_deg_even, Nat.zero_add]
    exact update_even

  have S0_odd : S 0 % 2 = 1 := by
    -- S 0 is total edges = 2021
    have : S 0 = 2021 := by sorry
    rw [this]; rfl

  have SN_zero : S N = 0 := by
    -- e.2 < N, so e.2 >= N is impossible
    have : S N = 0 := by sorry
    exact this
  
  -- Induction
  have parity_const : S 0 % 2 = S N % 2 := by
    let rec chain (i : Nat) (hi : i ≤ N) : S 0 % 2 = S i % 2 :=
      if h : i = 0 then by rw [h]
      else by
        have : S 0 % 2 = S (i - 1) % 2 := chain (i - 1) (Nat.le_of_lt (Nat.sub_lt (Nat.pos_of_ne_zero h) (by decide)))
