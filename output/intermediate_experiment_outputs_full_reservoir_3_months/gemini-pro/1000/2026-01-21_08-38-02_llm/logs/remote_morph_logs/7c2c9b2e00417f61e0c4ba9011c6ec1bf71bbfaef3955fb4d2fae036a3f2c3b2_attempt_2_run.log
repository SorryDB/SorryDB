      simp [S, Finset.mem_image, Finset.mem_range]
      constructor
      · rintro ⟨y, hy, rfl⟩; exact hy
      · intro hx; exact ⟨pk x, hx, pk.symm_apply_apply x⟩

    have upd : S (k + 1) = insert h (S k) := by
      ext x; simp [mem_S, Finset.mem_insert]
      let w1 := pk (h - 1); let w2 := pk (h + 1)
      have : p.nth (k+1) = pk.trans (Equiv.swap w1 w2) := rfl
      rw [this, Equiv.trans_apply]
      have nk : w1 ≠ k ∧ w2 ≠ k := by
        have : pk h = k := pk.apply_symm_apply k
        simp [←this]; intro c; simp at c; cases c <;> simp_all
      have sw_lt (w) : Equiv.swap w1 w2 w < k ↔ w < k ∨ w = k := by
        by_cases hw : w = w1 ∨ w = w2
        · cases hw <;> simp_all [Equiv.swap_apply_left, Equiv.swap_apply_right]
          have : (w1 < k ↔ w2 < k) := by
            have := h k; simp [Position.swapped, w1, w2] at this; tauto
          constructor <;> intro <;> simp_all [le_of_lt]
        · simp [Equiv.swap_apply_def, hw]
          have : w ≠ k := by rintro rfl; exact hw (by simp [nk]) 
          simp [this, le_iff_lt_or_eq]
      rw [sw_lt]; simp [pk.apply_symm_apply]

    have chg : b (insert h (S k)) - b (S k) ∈ ({2, -2} : Set ℤ) := by
      have out : h ∉ S k := by simp [mem_S, pk.apply_symm_apply]
      have eq_n : (h - 1 ∈ S k) = (h + 1 ∈ S k) := by
        have := h k; simp [Position.swapped, mem_S] at this; tauto
      let f (s : Finset (Fin n)) (i) := if (i ∈ s) ≠ (i + 1 ∈ s) then (1:ℤ) else 0
      have diff : b (insert h (S k)) - b (S k) = 
          (f (insert h (S k)) (h-1) - f (S k) (h-1)) + (f (insert h (S k)) h - f (S k) h) := by
        simp [b, Finset.sum_sub_distrib.symm]
        rw [Finset.sum_eq_add_sum_diff_singleton (by simp : h-1 ∈ Finset.univ),
            Finset.sum_eq_add_sum_diff_singleton (by simp : h ∈ (Finset.univ \ {h-1})),
            add_assoc]
        simp; apply Finset.sum_eq_zero
        intro i hi
        have : i ≠ h - 1 ∧ i ≠ h := by simpa using hi
        have mi : i ∉ {h} ∧ i + 1 ∉ {h} := by
           simp; constructor; exact this.2; 
           intro c; rw [←c] at this; simp at this; exact this.1
        simp [f, mi.1, mi.2, out]
      simp [f, out, Finset.mem_insert] at diff ⊢
      rw [diff]; rw [eq_n]
      by_cases nb : h + 1 ∈ S k <;> simp [nb]
    
    rw [upd]; cases chg <;> rw [h_1] <;> rfl

  have : b (S n) ≡ 2 * n [ZMOD 4] := by
    induction n with | zero => simp [b, S]; rfl | succ m ih => 
      rw [Nat.cast_succ, mul_add, mul_one]
      exact Int.ModEq.trans (step _) (Int.ModEq.add_right 2 ih)
  
  have bn : b (S n) = 0 := by
    have : S n = Finset.univ := by
      ext; simp [S, Finset.mem_image, Finset.mem_range]
      use p.nth n x; simp [p.nth n x |> Fin.is_lt, (p.nth n).symm_apply_apply]
    simp [this, b]
  
  rw [bn] at this
  have : (0 : ℤ) ≡ 2 [ZMOD 4] := by convert this; decide
  contradiction
