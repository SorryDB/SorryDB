  let is_int (pos : Position) (x : Fin 2021) : Prop :=
    let (a, b) := pos.swapped x
    (a < x ∧ x < b) ∨ (b < x ∧ x < a)
  by_contra h
  push_neg at h
  
  -- Lemma 1: The number of intermediate walnuts in any configuration is odd.
  -- Proof sketch: In a circular arrangement of N (odd) numbers, the number of local maxima
  -- equals the number of local minima. Intermediates are the rest.
  -- N = 2 * Extrema + Intermediates => Intermediates is odd.
  have odd_int_card : ∀ pos, Odd (Finset.univ.filter (is_int pos)).card := fun pos => by
    sorry

  -- Lemma 2: For any fixed walnut x, the number of steps k ≠ x where x is intermediate is even.
  -- Proof sketch: The status of x only changes when a neighbor of x is swapped (i.e., center is neighbor).
  -- A careful analysis of the swap operation shows the parity of intermediate-ness is conserved relative to k.
  have even_off_diag : ∀ x, Even (Finset.univ.filter (fun k => k ≠ x ∧ is_int (p.nth k) x)).card := fun x => by
    sorry

  -- Total count of intermediate configurations over all steps
  let S := ∑ k, (Finset.univ.filter (is_int (p.nth k))).card

  -- S is odd because it's a sum of 2021 (odd) odd numbers.
  have h_S_odd : Odd S := by
    refine Odd.sum ?_ (fun k _ => odd_int_card (p.nth k))
    simp only [Finset.card_fin]; norm_num

  -- Rearrange S to sum over walnuts x
  have h_S_even : Even S := by
    rw [Finset.sum_comm]
    apply Even.sum (fun x _ => ?)
    -- For each x, the term at k=x is 0 by hypothesis h.
    -- Thus we only sum over k ≠ x, which is even by Lemma 2.
    have : (Finset.univ.filter (fun k => is_int (p.nth k) x)).card = 
           (Finset.univ.filter (fun k => k ≠ x ∧ is_int (p.nth k) x)).card := by
      apply Finset.card_congr (fun k _ => k) (fun k hk => ?_) (fun _ _ => rfl) (fun k hk => ?_)
      · simp only [Finset.mem_filter] at hk ⊢
        refine ⟨by rintro rfl; exact h x hk, hk⟩
      · simp only [Finset.mem_filter] at hk ⊢; exact hk.2
    rw [this]
    exact even_off_diag x

  exact (Odd.not_even h_S_odd) h_S_even
