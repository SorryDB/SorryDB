    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra h
  push_neg at h
  let n := 2021
  let P (k : ℕ) := (move^[k] (p, 0)).1
  let val (pos : Position) (k : Fin n) (i : Fin n) : ZMod 4 := if pos i ≤ k then 1 else 0
  let score (pos : Position) (k : Fin n) : ZMod 4 := ∑ i, (val pos k i - val pos k (i + 1))^2

  have step : ∀ k : Fin n, score (P (k + 1)) k = score (P k) (k - 1) + 2 := fun k ↦ by
    let pos := P k; let j := pos.symm k
    have same : val pos (k - 1) (j - 1) = val pos (k - 1) (j + 1) := by
      specialize h k; simp [Position.swapped, Position.nth] at h
      have : pos j = k := pos.apply_symm_apply k
      rw [← this] at h
      have aux : ∀ v, v ≠ k → (v < k ↔ v ≤ k - 1) := fun v hv ↦ by
        rw [← Fin.lt_iff_le_iff_lt_add_one]; simp; exact hv
      simp [val]; split_ifs <;> simp_all
      · rw [aux _ (pos.injective.ne (by simp))] at h
        rw [aux _ (pos.injective.ne (by simp))] at h
        tauto
    
    have term_change : score pos k = score pos (k - 1) + 2 := by
      let v := val pos (k - 1)
      have local_upd : ∀ i, val pos k i = if i = j then 1 else v i := fun i ↦ by
        simp [val]; split_ifs <;> try rfl
        · subst i; simp at ᾰ; contradiction
        · subst i; simp at ᾰ ⊢; exact ᾰ
        · simp at ᾰ; exact (Fin.lt_iff_le_iff_lt_add_one.mp ᾰ)
      have : score pos k - score pos (k - 1) = 
          ((1 - v (j - 1))^2 + (1 - v (j + 1))^2) - ((v (j - 1))^2 + (v (j + 1))^2) := by
        simp [score]
        rw [Finset.sum_sub_distrib]
        apply Finset.sum_eq_sum_of_support_subset
        intro i hi
        simp at hi
        rw [local_upd, local_upd] at hi
        by_contra H
        rcases Fin.eq_of_ne_add_one (fun h => H (by rw [h]; split_ifs; all_goals simp)) with rfl | rfl
        all_goals { simp at hi; contradiction }
      rw [this, same]
      ring_nf
      have : v (j + 1) * 2 = v (j + 1) * 2 * v (j + 1) := by 
        revert same; simp [val]; split_ifs <;> intro <;> decide
      rw [this]; ring_nf
      decide
    
    have swap_inv : score (P (k + 1)) k = score pos k := by
      simp [score, val, P, move, Position.swapped]
      have : (P (k + 1)) = pos.trans (Equiv.swap (pos (j - 1)) (pos (j + 1))) := by
        simp [P, move, Position.swapped]; congr; simp
      rw [this]; simp
      apply Finset.sum_congr rfl
      intro i _
      congr 1 <;> { simp; split_ifs <;> try rfl; all_goals { simp_all [val]; tauto } }

    rw [swap_inv, term_change]

  have total : score (P n) (n - 1) = score (P 0) (n - 1) + 2 * n := by
    induction n using Nat.rec with
    | zero => simp
    | succ m ih => 
      rw [Nat.cast_succ, mul_add, add_assoc, ← ih]
      exact step ⟨m, by apply Nat.lt_succ_self⟩

  have zero_end : score (P n) (n - 1) = 0 := by simp [score, val]; apply Finset.sum_eq_zero; simp
  have zero_start : score (P 0) (n - 1) = 0 := by simp [score, val]; apply Finset.sum_eq_zero; simp
  
  rw [zero_end, zero_start] at total
  have : (2 * 2021 : ZMod 4) ≠ 0 := by decide
  contradiction
