theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra h
  push_neg at h
  let N := 2021
  let edges (q : Position) := Finset.filter (λ e : Fin N × Fin N =>
    e.1 < e.2 ∧ (q.symm e.1 + 1 = q.symm e.2 ∨ q.symm e.2 + 1 = q.symm e.1)) Finset.univ
  let P (k : Nat) : Position := (move^[k] (p, 0)).1
  let S (k : Nat) := ((edges (P k)).filter (λ e => k ≤ e.2)).card
  
  have step_parity : ∀ k : Nat, k < N → S k % 2 = S (k + 1) % 2 := by
    intro k hk
    let q := P k
    let u := (q.swapped k).1
    let v := (q.swapped k).2
    -- From negation of goal, k is not between u and v
    have same_side : (u < k ↔ v < k) := by
      let kf : Fin N := ⟨k, hk⟩
      have hk' : P k = p.nth kf := by rfl
      rw [hk']
      specialize h kf
      simp [Position.swapped] at *
      rcases lt_trichotomy u kf with lu | eu | gu
      · rcases lt_trichotomy v kf with lv | ev | gv
        · simp [lu, lv]
        · rw [ev] at h; simp at h; contradiction -- v != k
        · exfalso; apply h; left; exact ⟨lu, gv⟩
      · rw [eu] at h; simp at h; contradiction -- u != k
      · rcases lt_trichotomy v kf with lv | ev | gv
        · exfalso; apply h; right; exact ⟨lv, gu⟩
        · rw [ev] at h; simp at h; contradiction
        · simp [gu, gv]

    -- Contribution of edges incident to k
    let k_edges := (edges q).filter (λ e => e.2 = k)
    have k_deg_even : k_edges.card % 2 = 0 := by
      -- Neighbors of k are u and v. Edges are {min(u,k), max(u,k)} and {min(v,k), max(v,k)}.
      -- Since u, v same side, either both < k (so max is k) or both > k (so min is k).
      -- If u,v < k, edges are (u,k), (v,k). k_edges has 2 elements.
      -- If u,v > k, edges are (k,u), (k,v). k_edges has 0 elements (since e.1 < e.2 = k implies e.1 < k).
      simp [k_edges, edges]
      by_cases huk : u < k
      · have hvk : v < k := same_side.mp huk
