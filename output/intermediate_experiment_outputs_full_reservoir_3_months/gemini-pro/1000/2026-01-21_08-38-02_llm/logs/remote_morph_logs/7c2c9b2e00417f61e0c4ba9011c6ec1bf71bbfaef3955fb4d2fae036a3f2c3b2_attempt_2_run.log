    apply Even.sum
    intro k _
    rw [Finset.card_eq_sum_ones]
    simp only [Finset.sum_filter]
    convert h_column_even k
    split <;> rfl
    
  exact (Nat.odd_iff_not_even.mp h_total_odd) h_total_even
