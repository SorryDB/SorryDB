theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra h
  push_neg at h
  let seq (n : ℕ) := (move^[n] (p, 0)).1
  let count (q : Position) (k : ℕ) := (Finset.univ.filter (λ i : Fin 2021 => q i ≤ k ∧ ¬ (q (i + 1) ≤ k))).card
  
  have parity : ∀ k < 2021, count (seq (k + 1)) k % 2 = (k + 1) % 2 := by
    intro n hn
    induction n with
    | zero =>
      simp [count]
      have : ∃! i : Fin 2021, (seq 1) i = 0 := by
        use (seq 1).symm 0; simp
      obtain ⟨i, hi, h_unique⟩ := this
      rw [Finset.card_eq_one.mpr ⟨i, by
        simp only [Finset.mem_filter, Finset.mem_univ, true_and]
        constructor
        · rw [hi]; simp; rw [hi] at *; 
          have : (seq 1) (i + 1) ≠ 0 := by
            by_contra hc; apply Fin.succ_ne_self i; apply (seq 1).injective; rw [hi, hc]
          exact Nat.pos_of_ne_zero (Fin.val_ne_of_ne this)
        · intro j hj
          have : (seq 1) j = 0 := le_zero_iff.mp hj.1
          exact h_unique j this
      ⟩]
      rfl
    | succ k ih =>
      have hk_lt : k < 2021 := Nat.lt_of_succ_lt hn
      specialize ih hk_lt
