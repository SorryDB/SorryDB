theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra h
  push_neg at h
  let n := 2021
  let E (k : ℕ) (q : Position) : ℕ := (Finset.univ.filter (fun i : Fin n => q i < k ∧ q (i + 1) < k)).card
  let P (k : ℕ) : Prop := E k (p.nth k) % 2 = 0
  have h_step : ∀ k : Fin n, P k → P (k + 1) := by
    intro k hk
    let q := p.nth k
    let q' := p.nth (k + 1)
    let u := (q.swapped k).1
    let v := (q.swapped k).2
    have h_nbrs : (u < k ∧ v < k) ∨ (u > k ∧ v > k) := by
      specialize h k
      have kne : u ≠ k ∧ v ≠ k := sorry -- Distinct values
      have distinct : u ≠ v := sorry
      -- Logic from h: if not between, then both < or both >
      sorry
    -- Update edges count
    -- Adding k to set:
    let Ek_added := (Finset.univ.filter (fun i : Fin n => q i < k + 1 ∧ q (i + 1) < k + 1)).card
    have h_add : Ek_added % 2 = E k q % 2 := by
      -- Neighbors of k in q are u and v
      -- If u,v < k, Ek_added = E k q + 2. If u,v > k, Ek_added = E k q.
      sorry
    -- Swap effect:
    have h_swap : E (k + 1) q' % 2 = Ek_added % 2 := by
      -- q' is q swapped u, v.
      -- u, v are both < k+1 or both > k+1?
      -- If u,v < k, then u,v < k+1. Both IN.
      -- If u,v > k, then u,v >= k+1. Both OUT.
      -- Swap preserves edge count parity within set
      sorry
    rw [h_swap, h_add]
    exact hk
  have h0 : P 0 := by
    simp [P, E]
    apply Finset.card_eq_zero.mpr
    ext i; simp; intro h; exact Nat.not_lt_zero _ h
  have h_end : P n := by
    -- Induction up to n
    sorry
  have h_contra : E n (p.nth n) = n := by
    simp [E]
    apply Finset.card_univ
  rw [h_contra] at h_end
  -- n is 2021 (odd), so n % 2 != 0
  have h_odd : n % 2 = 1 := rfl
  rw [h_odd] at h_end
  contradiction
