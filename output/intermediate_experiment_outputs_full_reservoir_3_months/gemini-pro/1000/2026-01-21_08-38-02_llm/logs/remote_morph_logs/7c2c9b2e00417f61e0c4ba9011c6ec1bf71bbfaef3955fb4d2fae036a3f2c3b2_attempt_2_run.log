  by_contra h
  push_neg at h
  let n := 2021
  let S (k : ℕ) : Finset (Fin n) := (Finset.range k).image (p.nth k).symm
  let b (s : Finset (Fin n)) : ℤ := ∑ i, if (i ∈ s) ≠ (i + 1 ∈ s) then 1 else 0

  have step : ∀ k : Fin n, b (S (k + 1)) ≡ b (S k) + 2 [ZMOD 4] := by
    intro k
