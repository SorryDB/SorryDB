namespace StateCofixShrunk

/-!
## Basic API

Note this is noncomputable (for now!) because of the Shrink
-/
section

protected def ofLarge : StateCofixFinal F α → StateCofixShrunk F α :=
  CShrink.ofLarge
protected def toLarge : StateCofixShrunk F α → StateCofixFinal F α :=
  CShrink.toLarge
open StateCofixShrunk (ofLarge toLarge)

def corec {β} (f : β → F (α ::: β)) (init : β) : StateCofixShrunk F α :=
  .ofLarge <| .corec f init

def dest (self : StateCofixShrunk F α) : F (α ::: (StateCofixShrunk F α)) :=
  let f self := (TypeVec.id ::: corec self.dest') <$$> self.dest
  have h := by
    show ∀ a b, a ~ b → f a = f b
    -- ^^ Non-trivial to formalize, but clearly true
    rintro a b h_bisim
    unfold Coalg.Bisim at h_bisim
    rcases h_un : a.union b with ⟨un, d'⟩
    simp only [Coalg.dest, f]
    -- At this point, we should rewrite `a.dest' a.s` and `b.dest' b.s` into
    -- some phrasing in terms of `union`.
    unfold corec StateCofixFinal.corec
    rcases h_bisim with ⟨R, h_bisim, h_pair⟩
    let U := a.union b
    let g (s : U.σ) : StateCofixShrunk F α := .ofLarge <| Quot.mk _ <| Coalg.corec U.dest' s
    have hg : ∀ s t, R s t → g s = g t := by
      intro s t hr
      simp only [g]
      congr 1
      apply Quot.sound
      use R, h_bisim, hr
    let embed (c : Coalg F α) (inj : c.σ → U.σ)
        (h_dest : ∀ s, (TypeVec.id ::: inj) <$$> c.dest' s = U.dest' (inj s)) :
        ∀ s, ofLarge (Quot.mk _ (Coalg.corec c.dest' s)) = g (inj s) := by
      intro s
      simp only [g]
      congr 1
      apply Quot.sound
      use fun x y => y = inj x
      constructor
      · intro x y heq
        subst heq
        rw [← h_dest]
        rw [MvQPF.liftR_iff]
        use (TypeVec.id ::: fun k => (k, inj k)) <$$> c.dest' x
        simp [MvFunctor.map_map, TypeVec.comp, TypeVec.id, Function.comp]
        refine ⟨rfl, rfl, fun i j => by cases i <;> simp; rfl⟩
      · rfl
    have ha := embed a Sum.inl (Coalg.union_dest_eq_left a b)
    have hb := embed b Sum.inr (Coalg.union_dest_eq_right a b)
    simp only [ha, hb]
    rw [← MvFunctor.map_map, ← MvFunctor.map_map]
    rw [Coalg.union_dest_eq_left, Coalg.union_dest_eq_right]
    apply MvQPF.map_eq_map_of_liftR
    · apply h_bisim
      exact h_pair
    · intro i x y hxy
      cases i
      · simp at hxy; subst hxy; rfl
      · simp; apply hg; exact hxy
  Quot.lift f h self.toLarge

end
end StateCofixShrunk
