def dest (self : StateCofixShrunk F α) : F (α ::: (StateCofixShrunk F α)) :=
  let f self := (TypeVec.id ::: corec self.dest') <$$> self.dest
  have h : ∀ a b, a ~ b → f a = f b := by
    rintro a b h_bisim
    rcases h_bisim with ⟨R, hR, hinit⟩
    let H : α ::: (a.σ ⊕ b.σ) → α ::: StateCofixShrunk F α :=
      TypeVec.id ::: fun
        | .inl s => .ofLarge <| Quot.mk _ <| Coalg.corec a.dest' s
        | .inr s => .ofLarge <| Quot.mk _ <| Coalg.corec b.dest' s
    have h_lift : LiftR (RelLast α R) 
        ((TypeVec.id ::: Sum.inl) <$$> a.dest' a.s) 
        ((TypeVec.id ::: Sum.inr) <$$> b.dest' b.s) := by
      rw [Coalg.union_dest_eq_left, Coalg.union_dest_eq_right]
      apply hR _ _ hinit
    change (fun x => H ((TypeVec.id ::: Sum.inl) x)) <$$> a.dest' a.s =
           (fun x => H ((TypeVec.id ::: Sum.inr) x)) <$$> b.dest' b.s
    rw [←MvFunctor.map_map, ←MvFunctor.map_map]
    rw [MvQPF.liftR_iff] at h_lift
    rcases h_lift with ⟨z, hL, hR, hRel⟩
    rw [←hL, ←hR, MvFunctor.map_map, MvFunctor.map_map]
    congr 1
    funext i p
    rcases p with ⟨u, v⟩
    specialize hRel i ⟨u, v⟩
    cases hRel with
    | inl => rfl
    | inr s t hst =>
      dsimp [H]
      apply Equiv.injective
      apply Quot.sound
      exact ⟨R, hR, hst⟩
  Quot.lift f h (toLarge self)
