lemma isTotalTimeDerivativeVelocity {n : ℕ}
    (δL : EuclideanSpace ℝ (Fin n) → ℝ)
    (hδL0 : δL 0 = 0)
    (h : IsTotalTimeDerivative (fun _ v _ => δL v)) :
    ∃ g : EuclideanSpace ℝ (Fin n), ∀ v, δL v = ⟪g, v⟫_ℝ := by
  obtain ⟨F, -, hF⟩ := h
  let L := fderiv ℝ F (0, 0)
  have h_time : L (0, 1) = 0 := by rw [← hF 0 0 0, hδL0]
  let φ := L.comp (ContinuousLinearMap.inl ℝ (EuclideanSpace ℝ (Fin n)) ℝ)
  use (toDual ℝ _).symm φ
  intro v
  rw [toDual_symm_apply, hF 0 v 0]
  have : (v, 1) = (v, 0) + (0, (1 : ℝ)) := by simp
  rw [this, map_add, h_time, add_zero]
  rfl
