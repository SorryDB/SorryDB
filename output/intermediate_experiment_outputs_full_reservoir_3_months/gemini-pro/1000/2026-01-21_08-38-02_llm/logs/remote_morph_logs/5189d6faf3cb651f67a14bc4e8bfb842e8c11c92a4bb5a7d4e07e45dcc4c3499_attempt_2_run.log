    -- Aux.c_v_alg is the same as Aux.c_v which is a homeomorphism
    -- so one only has to check that the span of the integral lattice is compact
    -- and I guess one could pick a basis and give it a try
lemma isCompact (v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ)) : IsCompact
  ((((Aux.c_v_alg V v)).toAddMonoidHom.comp
        (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
            (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                    v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range :
                    Set (V ⊗[ℚ] IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v)) := by
  let R := IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ v
  let K := IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v
  let L := IntegralLattice ℤ ℚ V
  have : Module.Finite ℤ L := Module.Finite.of_finitePresentation
  obtain ⟨n, b, hb⟩ := Module.Finite.exists_fin' ℤ L
  let φ : (Fin n → R) → V ⊗[ℚ] K := fun c ↦
    ∑ i, (c i : K) • Aux.c_v_alg V v (b i ⊗ₜ[ℤ] 1)
  have hφ : Continuous φ := by
    apply continuous_finset_sum; intro i _
    apply Continuous.smul
    · exact continuous_induced_dom
    · exact continuous_const
  rw [(_ : _ = Set.range φ)]
  · exact IsCompact.image isCompact_univ hφ
  apply Set.Subset.antisymm
  · rintro _ ⟨x, rfl⟩
    refine TensorProduct.induction_on x (⟨0, by simp [φ]⟩) ?_ ?_
    · intro l r
      have hl : l ∈ Submodule.span ℤ (Set.range b) := by rw [hb]; trivial
      rw [Submodule.mem_span_range_iff_exists_fun] at hl
      obtain ⟨d, rfl⟩ := hl
      use fun j ↦ (d j : R) * r
      simp only [φ, map_sum, AddMonoidHom.coe_comp, AddMonoidHom.coe_coe, Function.comp_apply,
        LinearMap.coe_toAddMonoidHom, LinearMap.lTensor_tmul, Subtype.coe_toIntLinearMap]
      congr; ext j
      rw [LinearMap.map_smul, LinearEquiv.map_smul, ← TensorProduct.tmul_smul,
        smul_eq_mul, mul_one, TensorProduct.sum_tmul]
      congr
    · rintro x y ⟨cx, hx⟩ ⟨cy, hy⟩
      use cx + cy
      simp [φ, hx, hy, Finset.sum_add_distrib, add_smul]
  · rintro _ ⟨c, rfl⟩
    use ∑ i, b i ⊗ₜ[ℤ] c i
    simp only [φ, map_sum, AddMonoidHom.coe_comp, AddMonoidHom.coe_coe, Function.comp_apply,
      LinearMap.coe_toAddMonoidHom, LinearMap.lTensor_tmul, Subtype.coe_toIntLinearMap]
    congr; ext i
    rw [LinearMap.map_smul, LinearEquiv.map_smul, ← TensorProduct.tmul_smul,
      smul_eq_mul, mul_one]
