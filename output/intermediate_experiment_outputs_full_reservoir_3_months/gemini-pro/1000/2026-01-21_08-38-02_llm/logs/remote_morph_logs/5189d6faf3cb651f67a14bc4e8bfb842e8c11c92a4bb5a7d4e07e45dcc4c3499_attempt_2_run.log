lemma isCompact (v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ)) : IsCompact
  ((((Aux.c_v_alg V v)).toAddMonoidHom.comp
        (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
            (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                    v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range :
                    Set (V ⊗[ℚ] IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v)) := by
  let R := v.adicCompletionIntegers ℚ
  have : CompactSpace R := NumberField.instCompactSpaceAdicCompletionIntegers ℚ
  let b := IntegralLattice.basis ℤ ℚ V
  let ι := Module.Basis.ofVectorSpaceIndex ℚ V
  let M := (IntegralLattice ℤ ℚ V) ⊗[ℤ] v.adicCompletion ℚ
  -- Define the continuous map from coefficients to M
  let p : (ι → R) → M := fun c ↦ ∑ i, (c i : v.adicCompletion ℚ) • (b i ⊗ₜ 1)
  have hp : Continuous p := continuous_finset_sum _ (fun i _ ↦
    continuous_smul.comp (continuous_algebraMap _ _ |>.comp (continuous_apply i)) continuous_const)
  -- The range of the original map corresponds to the range of p
  let f := (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
      (v.adicCompletionIntegers ℚ).subtype.toAddMonoidHom.toIntLinearMap)
  have : Set.range f = Set.range p := by
    apply le_antisymm
    · rintro _ ⟨x, rfl⟩
      rw [← (b.baseChange R).sum_repr x]
      refine ⟨(b.baseChange R).repr x, ?_⟩
      simp only [p, map_sum, LinearMap.lTensor_tmul, coe_subtype, Algebra.tensorProduct_baseChange]
      congr; ext; simp only [TensorProduct.tmul_smul, Algebra.smul_def, mul_one]
    · rintro _ ⟨c, rfl⟩
      refine ⟨∑ i, b i ⊗ₜ[ℤ] c i, ?_⟩
      simp only [p, map_sum, LinearMap.lTensor_tmul, coe_subtype,
        TensorProduct.tmul_smul, Algebra.smul_def, mul_one]
  rw [Set.range_comp, this]
  exact (Aux.c_v V v).toContinuousMap.isCompact_image (isCompact_univ.image hp)
