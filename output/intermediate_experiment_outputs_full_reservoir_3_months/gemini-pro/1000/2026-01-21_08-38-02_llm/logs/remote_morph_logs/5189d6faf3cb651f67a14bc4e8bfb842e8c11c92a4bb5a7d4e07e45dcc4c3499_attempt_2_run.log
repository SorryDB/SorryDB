lemma isCompact (v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ)) : IsCompact
  ((((Aux.c_v_alg V v)).toAddMonoidHom.comp
        (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
            (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                    v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range :
                    Set (V ⊗[ℚ] IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v)) := by
  let L := IntegralLattice ℤ ℚ V
  let Kv := v.adicCompletion ℚ
  let Ov := v.adicCompletionIntegers ℚ
  let b := IntegralLattice.basis ℤ ℚ V
  let bK := b.baseChange Kv
  let ψ := Aux.c_v V v
  rw [← ψ.toHomeomorph.isCompact_image]
  let S := (LinearMap.lTensor L Ov.subtype.toIntLinearMap).range
  let C : Set (L ⊗[ℤ] Kv) := bK.equivFun ⁻¹' (Set.pi Set.univ fun _ ↦ (Ov : Set Kv))
  have h_eq : S = C := by
    ext x
    simp only [S, C, Set.mem_range, Set.mem_preimage, Set.mem_pi, Set.mem_univ, true_implies]
    constructor
    · rintro ⟨y, rfl⟩ i
      induction y using TensorProduct.induction_on with
      | zero => simp only [map_zero]; exact Subring.zero_mem _
      | tmul l o =>
        simp only [LinearMap.lTensor_tmul, LinearMap.coe_mk, AddHom.coe_mk,
          Ov.subtype_toIntLinearMap_apply, Basis.baseChange_repr_tmul]
        norm_cast
        exact Subring.zsmul_mem _ (SetLike.coe_mem o) _
      | add x y hx hy =>
        simp only [map_add]; convert Subring.add_mem _ (hx i) (hy i); norm_cast
    · intro h
      use ∑ i, b i ⊗ₜ[ℤ] (⟨bK.repr x i, h i⟩ : Ov)
      rw [map_sum, ← bK.sum_repr x]
      congr; ext i
      simp only [LinearMap.lTensor_tmul, LinearMap.coe_mk, AddHom.coe_mk,
        Ov.subtype_toIntLinearMap_apply]
      rfl
  rw [h_eq]
  apply bK.equivFun.toContinuousLinearEquiv.toHomeomorph.isCompact_preimage.mpr
  apply IsCompact.pi_univ
  intro _
  have : CompactSpace Ov := NumberField.instCompactSpaceAdicCompletionIntegers ℚ v
  exact IsCompact.image IsCompact.univ continuous_subtype_val
