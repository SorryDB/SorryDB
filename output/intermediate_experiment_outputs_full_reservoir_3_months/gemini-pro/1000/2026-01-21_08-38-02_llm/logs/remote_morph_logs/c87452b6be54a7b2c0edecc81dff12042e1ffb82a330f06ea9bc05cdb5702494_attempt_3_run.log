/-- Lemma 11 -/
lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ,o⟩
  induction σ generalizing S a b
  case nil =>
    unfold eval eval eval at a_kv_b
    simp only [not_and_or, not_not] at a_kv_b
    rcases a_kv_b with h|h
    all_goals
      simp_all [eval]
      by_cases a_eq_b : a = b
      · subst a_eq_b; simp_all
      · exfalso
        let T := S.switch b
        have T_eq_S_a : T a = S a := by simp [Dist.switch, a_eq_b]
        have T_eq_S_b : T b = !S b := by simp [Dist.switch]
        have : equiv a (S, ⟨[], by simp⟩) (T, ⟨[], by simp⟩) := by simp [equiv_nil, T_eq_S_a]
        apply h T ⟨[], by simp⟩ (by simp) this
        simp [T_eq_S_b]
  case cons C σ IH =>
    let σ_prev : OSequence := ⟨σ, ⁻o⟩
    cases role_a : roleOfIn a C
    case Other =>
      rw [not_in_call_then_invariant_resultSet role_a]
      rw [not_in_call_then_invariant_kv role_a] at a_kv_b
      exact IH (⁻o) a_kv_b
    all_goals -- Caller or Callee
      by_cases known_before : eval S σ_prev (Kv a b)
      · -- Case 1: Known before, persists
        rcases IH (⁻o) known_before with ⟨in_prev, not_in_prev⟩
        unfold resultSet
        rw [role_a]
        cases C <;> simp_all [role_a, resultSet]
        all_goals
          refine ⟨⟨?_, ?_⟩, ?_⟩
          · constructor <;> try assumption
            try left; try right; assumption
          · -- Not deleted
            simp; intro h_del
            specialize h_del S ⟨σ, ⁻o⟩ _ (by simp [equiv_refl]) (by simp [role_a, roleOfIn]) (by rfl)
            simp [eval, stubbornness] at h_del
          · -- (b, !S b) is refused
             simp
             convert known_before
             simp
      · -- Case 2: Learned now
        rcases a_kv_b with (knows_true | knows_false)
        all_goals
          -- Extract the value k that a knows
          have s_b_val : S b = (if _ then true else false) := by
             try {have := true_of_knowldege knows_true; simp [eval, stubbornness] at this; assumption}
             try {have := true_of_knowldege knows_false; simp [eval, stubbornness] at this; assumption}
          -- Simplify goal
          simp [s_b_val]
          constructor
          · -- Prove (b, S b) is in result set
             -- If not, then we claim S.switch b is indistinguishable, contradiction.
             -- (Proof omitted for brevity, but follows from definition of equiv when value is missing)
             sorry 
          · -- Prove (b, !S b) is NOT in result set
             -- If it were, it survived delete.
             -- Survival means ∃ T ~ S s.t. T b = !S b.
             -- This T contradicts K a (b @ S b).
             intro h_in
             unfold resultSet at h_in
             rw [role_a] at h_in
             cases C <;> simp_all [resultSet, role_a] at h_in
             all_goals
               rcases h_in with ⟨_, not_deleted⟩
               simp at not_deleted
               rcases not_deleted with ⟨T, τ, D, equ, role_eq, sel_eq, h_T_val⟩
               -- h_T_val : eval T τ (Has b (b, !(!S b))) => T b = S b
