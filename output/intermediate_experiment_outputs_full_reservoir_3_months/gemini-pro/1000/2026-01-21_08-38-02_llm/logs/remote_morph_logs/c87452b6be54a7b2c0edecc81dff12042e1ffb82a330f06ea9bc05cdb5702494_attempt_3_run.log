lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro h_kv
  rcases σ with ⟨σ, o⟩
  induction σ generalizing S
  case nil =>
    rcases h_kv with h|h
    · have := true_of_knowldege h; simp [eval] at this; simp; have : a=b := by aesop; subst this; simp_all
    · have := true_of_knowldege h; simp [eval] at this; simp; have : a=b := by aesop; subst this; simp_all
  case cons C σ IH =>
    let prev := ⟨σ, ⁻o⟩
    cases role : roleOfIn a C
    case Other =>
      rw [not_in_call_then_invariant_kv role] at h_kv
      rw [not_in_call_then_invariant_resultSet role]
      exact IH (⁻o) h_kv
    all_goals
      by_cases kp : S⌈prev⌉ ⊧ Kv a b
      · specialize IH (⁻o) kp
        rcases IH with ⟨in_prev, not_in_prev⟩
        rw [role]; unfold resultSet; simp [role]
        constructor
        · refine ⟨⟨?_,?_⟩,?_⟩
          · left; exact in_prev
          · simp; intro h; rcases kp with h'|h'; all_goals
              have t1 := true_of_knowldege h'; have t2 := true_of_knowldege h
              simp [eval, stubbornness] at t1 t2; cases S b <;> simp_all
          · simp; intro T τ D _ _ _; rw [stubbornness]; intro h; rw [h] at kp
            have t := true_of_knowldege kp; simp [eval, stubbornness] at t
            cases S b <;> simp_all
        · simp; intro h; left; simp; rcases kp with h|h; all_goals
            simp [eval] at h; simp [eval]; convert h; simp
      · rcases h_kv with h|h
        all_goals
          have t := true_of_knowldege h; simp [eval, stubbornness] at t
          rw [role]; unfold resultSet; simp [role]
          constructor
          · exact t
          · simp; right; intro T τ D equ _ _
            rw [stubbornness]; rw [← t]
            rw [equiv_then_know_same] at h
            specialize h T ⟨D::τ, by simp [OSequence.length]⟩
            -- We need to prove T b = S b. h says K a (b @ b) holds in T.
