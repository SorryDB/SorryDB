/-- Lemma 11 -/
lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro hKv
  have h_truth : S⌈σ⌉ ⊧ (b, S b) @ b := by
    simp [eval, stubbornness, maxOne]
  have h_knows : S⌈σ⌉ ⊧ K a ((b, S b) @ b) := by
    rcases hKv with h|h
    · simp [eval, Kv] at h; convert h
      rw [stubbornness] at *; simp [maxOne]; exact true_of_knowldege h
    · simp [eval, Kv] at h; exfalso
      have := true_of_knowldege h
      rw [stubbornness] at this; simp [maxOne] at this
      simp [this] at h

  -- (b, !Sb) is deleted because a knows Sb.
  have not_false : (b, ! S b) ∉ S⌈σ⌉a := by
    intro h_in
    rcases σ with ⟨σ, o⟩
    cases σ
    · simp [resultSet] at h_in; simp [h_in.2]
    · -- For a non-empty sequence, if (b, !Sb) is in result, it was not deleted.
      -- Being not deleted implies ¬ K a (b @ Sb). But we have K a (b @ Sb).
      -- We need to unfold resultSet to show this.
      -- This is tedious without a helper lemma, but holds by definition.
      -- We'll use the fact that if a knows phi, then phi must be consistent with observation.
      -- But delete is defined specifically to remove known-false values.
      -- Since K a (b @ Sb) holds, (b, !Sb) is known false.
      sorry

  refine ⟨?_, not_false⟩
  
  -- (b, Sb) must be in result. If not, a wouldn't know it.
  by_contra h_notin
  -- We construct a world T where b has !Sb.
  let T := S.switch b
  have h_diff : S b ≠ T b := by simp [T, Dist.switch]
  
  -- If a doesn't have (b, Sb) (and we know a doesn't have (b, !Sb)),
  -- then a has no value for b.
  -- Thus a cannot distinguish S from T locally.
  have h_equiv : (S, σ) ~_a (T, σ) := by
    -- Proof of indistinguishability when a has no value for b.
    sorry

  -- Since equiv holds, knowledge in S implies knowledge in T.
  have h_knows_T : T⌈σ⌉ ⊧ (b, S b) @ b := by
    rcases h_equiv with ⟨l, eq⟩
    intro U u l' eq'
    apply h_knows U u l'
    exact equiv_trans (equiv_symm.mp eq) eq'
  
  -- But knowledge is truthful.
  have h_truth_T : T⌈σ⌉ ⊧ (b, T b) @ b := by simp [eval, stubbornness, maxOne]
  
  -- So T b = S b.
  have : T b = S b := by
    -- K a (b @ Sb) in T implies T b = Sb
    have k := true_of_knowldege h_knows_T
    rw [stubbornness] at k; exact k; simp [maxOne]
    
  contradiction
