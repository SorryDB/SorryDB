def completeness : ∀ (c:Circuit p (ZMod p)),
  Circuit.eval c = Cs.eval (wrap (to_wg c) (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs,to_wg,wrap]
    constructor
  | lam k h =>
    simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    funext
    apply h
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    split
    exact h
    constructor
  | share e c h =>
    simp [Exp.eval,Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    apply h
  | is_zero e c h =>
    simp [Exp.eval,Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    split
    case is_zero.isTrue he0 =>
      simp
      split <;> apply h
    case is_zero.isFalse he0 =>
      split
      case isTrue he0' =>
        apply h
      case isFalse he0' =>
        simp [*] at *
  | assert_range w e c h =>
    simp [Circuit.eval, to_cs, to_wg]
    let bits := num2bits w (Exp.eval e)
    have h_len : bits.length = w := by induction w generalizing e <;> simp [num2bits, *]
    have h_cons : ∀ {n} {bs : List (ZMod p)} {wg} {k : Vector (ZMod p) n → Cs p (ZMod p)} (hlen : bs.length = n),
        wrap (bs.foldl (fun acc b => .cons b acc) wg) (Cs.curry k) =
        wrap wg (k ⟨bs.reverse.toArray, by simp [bs.reverse_length, hlen]⟩) := by
      intro n bs wg k hlen
      induction n generalizing bs wg
      case zero => cases bs; simp [Cs.curry]; contradiction
      case succ n ih => cases bs; contradiction; simp [Cs.curry, List.foldl]; rw [ih]; congr; simp [Vector.push]; rfl
    rw [h_cons h_len]
    let vbits := Vector.mk bits.reverse.toArray (by simp [h_len])
    have h_dist_eq : ∀ (cs), wrap (to_wg c) (Cs.eq0 (bits2num_e vbits - e) cs) =
                          Cs.eq0 (bits2num_e vbits - e) (wrap (to_wg c) cs) := by intros; rfl
    have h_dist_bits : ∀ (bs : Vector (ZMod p) w) (cs),
       wrap (to_wg c) (assert_bits_e bs cs) = assert_bits_e bs (wrap (to_wg c) cs) := by
       intro bs cs; induction w generalizing bs cs; cases bs using Vector.casesOn; rfl
       rename_i ih; simp [assert_bits_e, Vector.foldl]; rw [ih]; simp [assert_bit_e]; rfl
    simp [h_dist_eq, h_dist_bits, h]
    split
    case isTrue hlt =>
      rw [reduce]
      · rfl
      · constructor
        · sorry -- num2bits produces 0/1 bits
        · sorry -- num2bits reconstructs e when e < 2^w
    case isFalse hlt =>
      rw [fail]
      · rfl
      · intro ⟨_, heq⟩
        apply hlt
        sorry -- reconstruction implies e < 2^w
