    have h_sub : ∀ k wg, Cs.eval (wrap (bits.foldl (fun acc b => .cons b acc) wg) (Cs.curry k)) =
                       Cs.eval (wrap wg (k ⟨bits.reverse.toArray, by simp [hlen]⟩)) := by
      induction bits generalizing w
      case nil => simp [Cs.curry, wrap, Vector.eq_nil]; rfl
      case cons b bs ih =>
        intro k wg; cases w <;> simp [Cs.curry, List.foldl] at *
        rw [ih (fun l => k (l.push b)) (.cons b wg)]
        simp [List.reverse_cons]
    rw [h_sub]
    let vbits := Vector.mk bits.reverse.toArray (by simp [hlen])
    have h_comm : ∀ cs, wrap (to_wg c) (assert_bits_e vbits cs) = assert_bits_e vbits (wrap (to_wg c) cs) := by
