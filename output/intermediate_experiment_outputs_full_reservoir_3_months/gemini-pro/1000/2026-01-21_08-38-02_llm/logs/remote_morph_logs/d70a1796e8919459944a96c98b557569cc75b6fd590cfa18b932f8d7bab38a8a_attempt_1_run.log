      intro w args cs; induction w <;> simp [assert_bits_e, Vector.foldl, assert_bit_e, wrap, *]
    rw [peel bits _ _ len, push]
    simp [wrap]
    split
    · rw [h, reduce]
      · simp
      · apply bits_good; assumption
    · rw [fail]
      · simp [Cs.eval]
