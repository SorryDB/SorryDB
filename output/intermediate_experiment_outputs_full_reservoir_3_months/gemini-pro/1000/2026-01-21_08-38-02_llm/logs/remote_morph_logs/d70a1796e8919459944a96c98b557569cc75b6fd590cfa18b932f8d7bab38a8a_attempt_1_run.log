def completeness : ∀ (c:Circuit p (ZMod p)),
  Circuit.eval c = Cs.eval (wrap (to_wg c) (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs,to_wg,wrap]
    constructor
  | lam k h =>
    simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    funext
    apply h
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    split
    exact h
    constructor
  | share e c h =>
    simp [Exp.eval,Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    apply h
  | is_zero e c h =>
    simp [Exp.eval,Circuit.eval,Cs.eval,to_cs,to_wg,wrap]
    split
    case is_zero.isTrue he0 =>
      simp
      split <;> apply h
    case is_zero.isFalse he0 =>
      split
      case isTrue he0' =>
        apply h
      case isFalse he0' =>
        simp [*] at *
  | assert_range w e c h =>
    simp only [Circuit.eval, to_cs, to_wg]
    let bits := num2bits w (Exp.eval e)
    have hlen : bits.length = w := by
      dsimp [bits]
      induction w generalizing e <;> simp [num2bits, *]

    let k := (fun (v : Vector (ZMod p) w) => assert_bits_e v (.eq0 (bits2num_e v - e) (to_cs c)))

    have reduce_wrap : Cs.eval (wrap (bits.foldl (fun acc b => .cons b acc) (to_wg c)) (Cs.curry k)) =
                       Cs.eval (wrap (to_wg c) (k ⟨Array.mk bits.reverse, by simp [hlen]⟩)) := by
       let rbits := bits.reverse
       have : bits = rbits.reverse := by simp
       rw [this]
       generalize h_rbits : rbits = l
       have h_len_l : l.length = w := by rw [←h_rbits]; simp [hlen]
       clear h_rbits this hlen bits
       rw [List.foldl_reverse]
       induction l generalizing w
       case nil =>
         simp at h_len_l; subst h_len_l
         simp [Cs.curry, wrap, List.foldr]
       case cons x xs ih =>
         simp at h_len_l
         have w_eq : w = xs.length + 1 := by simp [h_len_l, Nat.add_comm]
         subst w_eq
         simp [Cs.curry, wrap, List.foldr]
         rw [ih xs.length (by rfl)]
         rfl

    rw [reduce_wrap]
    simp only [h]

    let args := Vector.mk bits.reverse (by simp [hlen])

    by_cases h_range : e.eval.val < 2^w
    . rw [if_pos h_range]
      have h_good : assert_bits args /\ e.eval = bits2num args := bits_good w args e h_range
      rw [reduce h_good]
    . rw [if_neg h_range]
      have h_bad : ¬ (assert_bits args /\ e.eval = bits2num args) := bits_bad w args e h_range
      rw [fail h_bad]
