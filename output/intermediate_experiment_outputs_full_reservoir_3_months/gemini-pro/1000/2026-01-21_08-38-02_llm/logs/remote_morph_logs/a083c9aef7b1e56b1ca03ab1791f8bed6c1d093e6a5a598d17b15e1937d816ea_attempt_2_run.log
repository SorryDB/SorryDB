```lean
theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem]
    exact beq_iff_eq
  | node v left right ih_l ih_r =>
    rcases h with ⟨h_all_l, h_all_r, h_ord_l, h_ord_r, h_pivot⟩
    simp [fastCheckMem]
    split
    next heq =>
      rw [beq_iff_eq] at heq
      subst heq
      simp [LabelledTree.mem, h_pivot]
    next hne =>
      rw [beq_iff_eq, Bool.not_eq_true] at hne
      split
      next hlt =>
        rw [ih_l h_ord_l, LabelledTree.mem]
        constructor
        · exact Or.inl
        · rintro (hl | hr)
          · exact hl
          · exact absurd (lt_of_lt_of_le hlt (h_all_r _ hr)) (lt_irrefl _)
      next hnlt =>
        rw [ih_r h_ord_r, LabelledTree.mem]
        constructor
        · exact Or.inr
        · rintro (hl | hr)
          · have : v < label := lt_of_le_of_ne (le_of_not_lt hnlt) hne.symm
            exact absurd (lt_of_le_of_lt (h_all_l _ hl) this) (lt_irrefl _)
          · exact hr
```
