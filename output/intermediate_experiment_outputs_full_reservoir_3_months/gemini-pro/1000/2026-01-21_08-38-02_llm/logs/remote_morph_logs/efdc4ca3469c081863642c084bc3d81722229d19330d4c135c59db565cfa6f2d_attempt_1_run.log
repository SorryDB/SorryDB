lemma IsBinomialRandom.identDistrib_mem_edgeSet [Countable V] (hG : IsBinomialRandom G p P)
    (he₁ : ¬e₁.IsDiag) (he₂ : ¬e₂.IsDiag) :
    IdentDistrib (fun ω ↦ e₁ ∈ (G ω).edgeSet) (fun ω ↦ e₂ ∈ (G ω).edgeSet) P P := by
  rw [hG.identDistrib_iff]
  have h (e : Sym2 V) (he : ¬ e.IsDiag) :
      map (fun G ↦ e ∈ G.edgeSet) G(V, p) = Measure.bernoulli p := by
    rw [binomialRandom_eq_map, map_map (by fun_prop) measurable_fromEdgeSet]
