lemma IsSquareIntegrable.add (hX : IsSquareIntegrable X 𝓕 P)
    (hY : IsSquareIntegrable Y 𝓕 P) :
    IsSquareIntegrable (fun i ω ↦ X i ω + Y i ω) 𝓕 P := by
  refine ⟨hX.martingale.add hY.martingale, fun ω ↦ ?_, ?_⟩
  · exact (hX.cadlag ω).add (hY.cadlag ω)
  · refine (iSup_le fun i ↦ ?_).trans_lt (ENNReal.add_lt_top.2 ⟨hX.bounded, hY.bounded⟩)
    calc eLpNorm (X i + Y i) 2 P
      _ ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P :=
        eLpNorm_add_le (hX.martingale.integrable i).aeStronglyMeasurable
          (hY.martingale.integrable i).aeStronglyMeasurable one_le_two
      _ ≤ (⨆ j, eLpNorm (X j) 2 P) + (⨆ j, eLpNorm (Y j) 2 P) :=
