/-- The antipode of a commutative cocommutative Hopf algebra as a coalgebra hom. -/
def antipodeBialgHom : C →ₐc[R] C where
  __ := antipodeAlgHom R (A := C)
  map_smul' := _
  counit_comp := counit_comp_antipode
  map_comp_comul := by
    apply AlgHom.toLinearMap_injective
    apply left_inv_eq_right_inv (a := comul)
    · exact LinearMap.comul_right_inv
    · simp only [toLinearMap_convMul, toLinearMap_comp, toLinearMap_convOne, toLinearMap_id,
        toLinearMap_antipodeAlgHom]
      rw [← LinearMap.comp_convMul_of_isCoalgHom, LinearMap.comp_one]
      ext
      simp [LinearMap.convMul_apply, Algebra.TensorProduct.mul_apply,
