theorem dedup_sem_pre : ∀ (cl: Circuit F F) (cr:Circuit F (Nat × F)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.eval entry.r.2)) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G hG _
  -- We prove a generalization: dedup_ is correct if set contains expressions that evaluate to 0
  let P (cl : Circuit F F) (cr : Circuit F (Nat × F)) :=
    ∀ n set, (∀ e ∈ set, Exp.eval (to_var e) = 0) → cl ≈ dedup_ cr n set
  have h_gen : P cl cr := by
    induction hG
    case nil => intros; simp [dedup_]
    case eq0 e1 e2 _ _ ih =>
      intro n set hset
      simp [dedup_]
      split
      next hmem =>
        rw [Circuit.eq0_of_true (hset _ hmem)]
        apply ih _ _ hset
      next =>
        apply Circuit.eq0_congr rfl
        apply ih
        intro e he
        cases he
        · subst e; apply Circuit.eval_zero_of_eq0
        · apply hset; assumption
    case lam _ _ ih =>
      intro n set hset
      simp [dedup_]
      apply Circuit.lam_congr
      intro x
      apply ih _ _ hset
    case share _ _ ih =>
      intro n set hset
      simp [dedup_]
      apply Circuit.share_congr rfl
      intro x
      apply ih _ _ hset
    case is_zero _ _ ih =>
      intro n set hset
      simp [dedup_]
      apply Circuit.is_zero_congr rfl
      intro x
      apply ih _ _ hset
  apply h_gen 0 []
  simp
