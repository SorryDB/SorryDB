def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    classical
    by_cases h₂ : MeasurableSet w₂
    · by_cases h₁ : MeasurableSet w₁
      · rw [← E.m_Inter' h₁ h₂, inter_eq_self_of_subset_left h, ContinuousLinearMap.coe_mul, Function.comp_apply]
        let P := E.measureOf' w₁
        have hP : IsOrthogonalProjection P := E.isOrthogonalProjection' w₁
        have : ‖P (E.measureOf' w₂ x)‖ ^ 2 ≤ ‖P (E.measureOf' w₂ x)‖ * ‖E.measureOf' w₂ x‖ := by
          rw [pow_two, ← inner_self_eq_norm_sq_to_K, hP.2, ← ContinuousLinearMap.mul_apply, ← hP.1]
          exact norm_inner_le_norm _ _
        by_cases h₀ : ‖P (E.measureOf' w₂ x)‖ = 0
        · rw [h₀]; exact norm_nonneg _
        · exact (mul_le_mul_left (lt_of_le_of_ne (norm_nonneg _) (Ne.symm h₀))).mp this
      · rw [E.not_measurable' h₁]; simp
    · rw [E.not_measurable' h₂]; simp
      by_cases h₁ : MeasurableSet w₁
      · sorry
      · rw [E.not_measurable' h₁]; simp
