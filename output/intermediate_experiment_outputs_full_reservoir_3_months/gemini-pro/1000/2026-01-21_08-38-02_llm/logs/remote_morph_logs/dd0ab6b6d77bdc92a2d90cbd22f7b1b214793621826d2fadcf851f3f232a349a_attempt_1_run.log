def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ⨅ (s : Set α) (_ : w ⊆ s) (_ : MeasurableSet s), ENNReal.ofReal ‖E.measureOf' s x‖
  empty := le_antisymm
    (iInf_le_of_le ∅ (iInf_le_of_le (Set.subset_refl _) (iInf_le_of_le MeasurableSet.empty (by simp [E.empty']))))
    (zero_le _)
  mono {w₁ w₂} h := le_iInf fun s => le_iInf fun hs => le_iInf fun hms =>
    iInf_le_of_le s (iInf_le_of_le (h.trans hs) (iInf_le_of_le hms (le_refl _)))
