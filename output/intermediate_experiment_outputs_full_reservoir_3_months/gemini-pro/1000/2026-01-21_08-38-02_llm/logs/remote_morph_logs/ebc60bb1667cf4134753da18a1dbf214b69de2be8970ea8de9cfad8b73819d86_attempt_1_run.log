    have h36 := proposition_3_6 I (by norm_num) hT_gt_T0 x
    have h38 := proposition_3_8 I x N T (by norm_num) hσ₂ (by sorry) hT_ge_H0
    have h312 := corollary_3_12 I K hσ₂ rfl hT_gt_t0 I.ZDB
    have h_split : riemannZeta.zeroes_sum (Set.Ioo 0 1) (Set.Ioo (-T) T) (fun ρ ↦ ‖x ^ (ρ - 1) / ρ‖) ≤
      riemannZeta.Sigma T x 0 0.9 + riemannZeta.Sigma T x 0.9 σ₂ + riemannZeta.Sigma T x σ₂ 1 := by sorry
    rw [ε]
    calc Eψ x 
      _ ≤ riemannZeta.zeroes_sum (Set.Ioo 0 1) (Set.Ioo (-T) T) (fun ρ ↦ ‖x ^ (ρ - 1) / ρ‖) + ε₁ x T := h34
      _ ≤ (riemannZeta.Sigma T x 0 0.9 + riemannZeta.Sigma T x 0.9 σ₂ + riemannZeta.Sigma T x σ₂ 1) + ε₁ x T := add_le_add_right h_split _
      _ ≤ (ε₂ I x 0.9 T + ε₃ I x 0.9 σ₂ N T + ε₄ I t₀ x σ₂ K T) + ε₁ x T := add_le_add_right (add_le_add (add_le_add h36 h38) h312) _
      _ = ε₁ x T + ε₂ I x 0.9 T + ε₃ I x 0.9 σ₂ N T + ε₄ I t₀ x σ₂ K T := by ring
  have h_mono : ε I x σ₂ c N K ≤ ε I x₀ σ₂ c N K := by sorry
