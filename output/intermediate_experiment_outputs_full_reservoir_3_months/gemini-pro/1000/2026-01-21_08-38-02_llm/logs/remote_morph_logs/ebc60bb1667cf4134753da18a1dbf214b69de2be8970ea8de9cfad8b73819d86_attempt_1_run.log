@[blueprint
"fks-theorem-1-1"
  (title := "FKS Theorem 1.1")
  (statement := /-- For any $x_0$ with $\log x_0 > 1000$, and all $0.9 < \sigma_2 < 1$, $2 \leq c \leq 30$, and $N, K \geq 1$ the formula $\varepsilon(x_0) := \varepsilon(x_0, \sigma_2, c, N, K)$ as defined in (4.1) gives an effectively computable bound
\[
E_\psi(x) \leq \varepsilon(x_0) \quad \text{for all } x \geq x_0.
\]
-/)]
theorem theorem_1_1 (I : Inputs) (x₀ σ₂ c : ℝ) (N K : ℕ) (hlog : log x₀ > 1000) (hσ₂ : σ₂ ∈ Set.Ioo 0.9 1) (hc : c ∈ Set.Icc 2 30) (hN : N ≥ 1) (hK : K ≥ 1) : ∀ x ≥ x₀, Eψ x ≤ ε I x₀ σ₂ c N K := by
  intro x hx
  have hx_pos : 0 < x := exp_pos (log x₀) |>.trans_le hx
  have hlogx : log x ≥ 1000 := (le_log_iff_exp_le hx_pos).mpr <| (exp_lt_iff_lt_log.mpr hlog).le.trans hx
  have hx50 : x > exp 50 := by rw [exp_lt_iff_lt_log hx_pos]; linarith

  -- Define parameters at x
  let t₀ := max (Hσ I.H₀ I.R σ₂) (exp (sqrt (log x) / I.R))
  let T := t₀ ^ c

  -- Verify conditions for Proposition 3.4
  -- T increases with x, but 3 log x increases slower than T ~ exp(sqrt(log x)).
  -- sqrt x / 3 increases much faster than T.
  have hT : T ∈ Set.Ioo (3 * log x) (sqrt x / 3) := by sorry

  -- Bound Eψ x using Proposition 3.4
  have h34 := proposition_3_4 hx50 hT

  -- Bound the sum over zeros using Sigma decompostion
  let S := riemannZeta.Sigma T x
  -- |x^(rho-1)/rho| <= x^(beta-1)/gamma. Sum over |gamma|<T is <= 2 * sum over 0<gamma<T = Sigma.
  have h_sum : riemannZeta.zeroes_sum (Set.Ioo 0 1) (Set.Ioo (-T) T) (fun ρ ↦ ‖x^(ρ - 1) / ρ‖) ≤ S 0 1 := by sorry
  have h_decomp : S 0 1 = S 0 0.9 + S 0.9 σ₂ + S σ₂ 1 := by sorry

  -- Apply bounds to Sigma components
  have h_S1 : S 0 0.9 ≤ ε₂ I x 0.9 T :=
    proposition_3_6 I (by norm_num) hT.1.le x

  have h_S2 : S 0.9 σ₂ ≤ ε₃ I x 0.9 σ₂ N T :=
    proposition_3_8 I x N T (by norm_num) hσ₂.1 (by sorry) hT.1.le

  have h_S3 : S σ₂ 1 ≤ ε₄ I t₀ x σ₂ K T :=
    corollary_3_12 I K hσ₂ rfl hT.1.le I.ZDB

  -- Combine to get Eψ x ≤ ε(x)
  have h_bound_x : Eψ x ≤ ε I x σ₂ c N K := by
    rw [ε]
    have : ε₁ x T + ε₂ I x 0.9 T + ε₃ I x 0.9 σ₂ N T + ε₄ I t₀ x σ₂ K T = ε₁ x T + (ε₂ I x 0.9 T + (ε₃ I x 0.9 σ₂ N T + ε₄ I t₀ x σ₂ K T)) := by ring
    rw [this]
    apply le_trans h34
    apply add_le_add_left
    apply le_trans h_sum
    rw [h_decomp]
    linarith

  -- Monotonicity: ε(x) ≤ ε(x₀)
  -- The epsilon function is constructed to be decreasing in x for x > x0 > e^50.
  have h_mono : ε I x σ₂ c N K ≤ ε I x₀ σ₂ c N K := by sorry

  exact h_bound_x.trans h_mono
