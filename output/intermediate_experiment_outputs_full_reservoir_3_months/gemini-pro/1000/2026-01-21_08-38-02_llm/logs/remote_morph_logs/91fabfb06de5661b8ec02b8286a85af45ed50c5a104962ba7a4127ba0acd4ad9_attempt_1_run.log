      rw [this]; ring_nf
      rw [show 700 = 100 * 7 by rfl, mul_assoc, ← Nat.mul_add, Nat.add_mod_left]
      norm_num
  have mem_S : ∀ n, n ∈ S ↔ n % 50 = 39 := by
    intro n
    rw [h₀, key]
