theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have key : ∀ n, 14 * n % 100 = 46 ↔ n % 50 = 39 := by
    intro n
    constructor
    · intro h
      have h1 : 14 * n ≡ 46 [MOD 100] := h.trans (by norm_num)
      have h2 : 7 * n ≡ 23 [MOD 50] := Nat.ModEq.of_mul_left 2 h1
      have h3 : 43 * (7 * n) ≡ 43 * 23 [MOD 50] := Nat.ModEq.mul_left 43 h2
      rwa [←mul_assoc, show 43 * 7 ≡ 1 [MOD 50] by rfl, one_mul, show 43 * 23 ≡ 39 [MOD 50] by rfl] at h3
    · intro h
      obtain ⟨k, rfl⟩ := Nat.exists_eq_add_of_mod_eq h
      rw [add_mul, Nat.add_mod, show 14 * (50 * k) = 100 * (7 * k) by ring, Nat.mul_mod_right, zero_add]
      norm_num
  have hu : u = 39 := by
    apply h₁.unique
    constructor
    · rw [h₀]; exact ⟨by norm_num, (key 39).mpr (by norm_num)⟩
    · intro n hn; rw [h₀, key] at hn; rw [←hn.2]; exact Nat.mod_le n 50
  have hv : v = 89 := by
    subst hu
    apply h₂.unique
    constructor
    · simp [h₀, key]; norm_num
    · intro n hn
