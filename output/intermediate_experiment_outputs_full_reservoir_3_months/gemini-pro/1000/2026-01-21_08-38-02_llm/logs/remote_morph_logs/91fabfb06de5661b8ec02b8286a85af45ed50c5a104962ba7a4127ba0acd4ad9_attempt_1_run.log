theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have key : ∀ n, 14 * n % 100 = 46 ↔ n % 50 = 39 := by
    intro n
    constructor
    · intro h
      have h_eq : 14 * n = 14 * n / 100 * 100 + 46 := by rw [h, Nat.div_add_mod]
      have h_eq' : 7 * n = (14 * n / 100) * 50 + 23 := by
        apply Nat.eq_of_mul_eq_mul_left (by decide : 0 < 2)
        rw [mul_add, ←mul_assoc, show 2 * 50 = 100 by rfl, ←h_eq]
        ring
      have h_mod : 7 * n % 50 = 23 := by
        rw [h_eq', Nat.add_mod, Nat.mul_mod_right, zero_add, Nat.mod_self]
      have h_inv : 43 * (7 * n) % 50 = 43 * 23 % 50 := by rw [h_mod]
      rw [←mul_assoc, show 43 * 7 = 301 by rfl, show 301 = 6 * 50 + 1 by rfl, add_mul, one_mul] at h_inv
      rw [Nat.add_mod, Nat.mul_mod_left, zero_add, Nat.mod_mod] at h_inv
      rw [show 43 * 23 = 989 by rfl, show 989 = 19 * 50 + 39 by rfl] at h_inv
      rw [Nat.add_mod, Nat.mul_mod_left, zero_add, Nat.mod_self] at h_inv
      exact h_inv
    · intro h
      rw [←Nat.div_add_mod n 50, h]
      generalize n / 50 = k
      rw [show 14 * (50 * k + 39) = 100 * (7 * k + 5) + 46 by ring]
      simp [Nat.add_mod]

  have mem_S : ∀ n, n ∈ S ↔ 0 < n ∧ n % 50 = 39 := fun n ↦ by rw [h₀, key]

  have u_eq : u = 39 := by
    have h_in : 39 ∈ S := by rw [mem_S]; norm_num
    apply le_antisymm (h₁.2 h_in)
    have hu := h₁.1
    rw [mem_S] at hu
    nth_rw 1 [←Nat.div_add_mod u 50]
    rw [hu.2]
    apply Nat.le_add_left

  have v_eq : v = 89 := by
    have h_in : 89 ∈ S \ {u} := by
      rw [u_eq, Set.mem_diff, Set.mem_singleton_iff, mem_S]
      norm_num
    apply le_antisymm (h₂.2 h_in)
    have hv := h₂.1
    rw [Set.mem_diff, Set.mem_singleton_iff, u_eq, mem_S] at hv
    rcases hv with ⟨⟨_, h_mod⟩, h_ne⟩
    nth_rw 1 [←Nat.div_add_mod v 50]
    rw [h_mod]
    have : 0 < v / 50 := by
      by_contra h
      simp [Nat.le_zero.mp (Nat.le_of_not_lt h)] at h_mod
      rw [←Nat.div_add_mod v 50, h_mod, Nat.le_zero.mp (Nat.le_of_not_lt h)] at h_ne
      simp at h_ne
    calc 50 * (v / 50) + 39 ≥ 50 * 1 + 39 := Nat.add_le_add_right (Nat.mul_le_mul_left _ this) _
         _ = 89 := by rfl
  
  rw [u_eq, v_eq]
  norm_num
