      have mod : 7 * n % 50 = 23 := by rw [eq3, Nat.add_mod, Nat.mul_mod_left]; norm_num
      have : 43 * (7 * n) % 50 = 43 * 23 % 50 := by rw [Nat.mul_mod, mod, Nat.mul_mod]; norm_num
      rw [← mul_assoc, show 43 * 7 = 301 by rfl] at this
      rw [show 301 = 50 * 6 + 1 by rfl, Nat.add_mul, one_mul, Nat.add_mod, Nat.mul_mod_left, zero_add, Nat.mod_mod] at this
      exact this
    · intro h
