namespace IMO2022P6

/-- A cell of the board. -/
abbrev Cell (n : ℕ) : Type := Fin n × Fin n

/-- A Nordic square. -/
abbrev NordicSquare (n : ℕ) : Type := Cell n ≃ Finset.Icc 1 (n ^ 2)

/-- Whether two cells are adjacent. -/
def Adjacent {n : ℕ} (x y : Cell n) : Prop :=
  Nat.dist x.1 y.1 + Nat.dist x.2 y.2 = 1

/-- The definition of a valley from the problem. -/
def NordicSquare.Valley {n : ℕ} (ns : NordicSquare n) (c : Cell n) : Prop :=
  ∀ c' : Cell n, Adjacent c c' → (ns c : ℕ) < (ns c' : ℕ)

/-- The definition of an uphill path from the problem. -/
structure NordicSquare.UphillPath {n : ℕ} (ns : NordicSquare n) where
  /-- The cells on the path. -/
  cells : List (Cell n)
  nonempty : cells ≠ []
  first_valley : ns.Valley (cells.head nonempty)
  adjacent : cells.IsChain Adjacent
  increasing : cells.IsChain fun x y ↦ (ns x : ℕ) < (ns y : ℕ)

/-- The answer to be determined. -/
def answer (n : ℕ+) : ℕ := 2 * n ^ 2 - 2 * n + 1

theorem result {n : ℕ+} :
    IsLeast {k : ℕ | ∃ ns : NordicSquare n, #ns.UphillPath = k} (answer n) := by
  have lower_bound : ∀ ns : NordicSquare n, answer n ≤ #ns.UphillPath := by
    intro ns
    -- The number of uphill paths is at least the number of valleys plus the number of edges.
    -- Each edge (u, v) with u < v can be extended to an uphill path ending at v.
    -- The total count is |V| + ∑_{(u,v) ∈ E, u<v} (paths to u).
    -- Since paths to u ≥ 1, sum ≥ |V| + |E| = 1 + 2n(n-1) = 2n² - 2n + 1.
    sorry
  have existence : ∃ ns : NordicSquare n, #ns.UphillPath = answer n := by
    -- For n=3, removing the center and a corner from the grid graph leaves a tree.
    -- This construction generalizes or follows a specific spiral pattern with modifications.
    sorry
  constructor
  · obtain ⟨ns, h⟩ := existence
    use ns, h
  · rintro k ⟨ns, rfl⟩
    apply lower_bound
