```lean
namespace IMO2022P6

/-- A cell of the board. -/
abbrev Cell (n : ℕ) : Type := Fin n × Fin n

/-- A Nordic square. -/
abbrev NordicSquare (n : ℕ) : Type := Cell n ≃ Finset.Icc 1 (n ^ 2)

/-- Whether two cells are adjacent. -/
def Adjacent {n : ℕ} (x y : Cell n) : Prop :=
  Nat.dist x.1 y.1 + Nat.dist x.2 y.2 = 1

/-- The definition of a valley from the problem. -/
def NordicSquare.Valley {n : ℕ} (ns : NordicSquare n) (c : Cell n) : Prop :=
  ∀ c' : Cell n, Adjacent c c' → (ns c : ℕ) < (ns c' : ℕ)

/-- The definition of an uphill path from the problem. -/
structure NordicSquare.UphillPath {n : ℕ} (ns : NordicSquare n) where
  /-- The cells on the path. -/
  cells : List (Cell n)
  nonempty : cells ≠ []
  first_valley : ns.Valley (cells.head nonempty)
  adjacent : cells.IsChain Adjacent
  increasing : cells.IsChain fun x y ↦ (ns x : ℕ) < (ns y : ℕ)

/-- The answer to be determined. -/
def answer (n : ℕ+) : ℕ := 2 * n ^ 2 - 2 * n + 1

theorem result {n : ℕ+} :
    IsLeast {k : ℕ | ∃ ns : NordicSquare n, #ns.UphillPath = k} (answer n) := by
  constructor
  · -- Existence of a Nordic square with exactly answer n uphill paths
    sorry
  · -- Optimality: any Nordic square has at least answer n uphill paths
    rintro k ⟨ns, rfl⟩
    -- The number of uphill paths is the sum over all cells c of the number of paths ending at c.
    -- For each cell c, let N(c) be the number of paths ending at c.
    -- If c is a valley, N(c) = 1.
    -- If c is not a valley, N(c) = ∑_{u → c} N(u) ≥ ∑_{u → c} 1 = d_in(c).
    -- Thus, ∑ N(c) ≥ ∑_{valley} 1 + ∑_{not valley} d_in(c).
    -- Since d_in(valley) = 0, this sum is ≥ 1 + ∑_{all} d_in(c).
    -- The sum of in-degrees is the number of edges in the DAG, which is the number of adjacent pairs.
    -- The grid graph has 2n(n-1) edges.
    -- So total paths ≥ 1 + 2n(n-1) = 2n^2 - 2n + 1.
    sorry
