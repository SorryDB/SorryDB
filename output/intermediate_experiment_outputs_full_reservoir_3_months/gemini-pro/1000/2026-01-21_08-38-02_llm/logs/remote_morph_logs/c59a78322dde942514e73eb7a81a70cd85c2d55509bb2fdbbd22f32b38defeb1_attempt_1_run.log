section LoopWalkCounting

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ‚Č§ (edgeSet p).card +1 := by
  have head_mem {x y} (q : G.LoopWalk x y) : x ‚ąą q.supportSet := by
    cases q <;> simp [supportSet, support]

  have edge_ends_in_support {x y} (q : G.LoopWalk x y) (e : Sym2 V) (he : e ‚ąą q.edgeSet) (z : V) (hz : z ‚ąą e) : z ‚ąą q.supportSet := by
    induction q with
    | nil => simp [edgeSet, edges, darts] at he
    | cons h' q' ih =>
      simp [edgeSet, edges, darts, supportSet, support] at he ‚äĘ
      cases he with
      | inl eq =>
        rw [‚Üź eq] at hz
        rcases Sym2.mem_mk_iff.mp hz with rfl | rfl
        ¬∑ left; rfl
        ¬∑ right; exact head_mem q'
      | inr mem =>
        right; exact ih _ mem _ hz
    | loop q' ih =>
      simp [edgeSet, edges, darts, supportSet, support] at he ‚äĘ
      cases he with
      | inl eq =>
        rw [‚Üź eq] at hz
        rcases Sym2.mem_mk_iff.mp hz with rfl | rfl <;> exact head_mem q'
      | inr mem =>
        exact Finset.mem_insert_of_mem (ih _ mem _ hz)

  induction p with
  | nil =>
    simp [supportSet, support, edgeSet, edges, darts]
  | cons h p ih =>
    simp [supportSet, support, edgeSet, edges, darts]
    by_cases hu : u ‚ąą p.supportSet
    ¬∑ rw [Finset.insert_eq_of_mem hu]
      apply le_trans ih
      apply Nat.add_le_add_right
      apply Finset.card_le_card
      apply Finset.subset_insert
    ¬∑ rw [Finset.card_insert_of_not_mem hu]
