    ¬∑ right; exact IH he hx
  | loop p IH =>
    simp only [edgeSet, edges, darts, map_cons, toFinset_cons, Finset.mem_insert] at he
    simp only [supportSet, support, map_cons, toFinset_cons, Finset.mem_insert]
    rcases he with (rfl | he)
    ¬∑ simp only [Sym2.mem_iff] at hx; subst hx; exact mem_support_start p
    ¬∑ rw [Finset.insert_eq_of_mem (mem_support_start p)]
      exact IH he hx

