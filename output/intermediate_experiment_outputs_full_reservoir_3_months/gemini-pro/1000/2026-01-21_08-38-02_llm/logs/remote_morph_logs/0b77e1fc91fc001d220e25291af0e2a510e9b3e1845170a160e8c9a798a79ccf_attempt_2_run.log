      apply Finset.sum_congr rfl fun i _ => Finset.sum_congr rfl fun j _ => by
        rw [mul_assoc, ← mul_assoc (w j), mul_comm (w j), mul_assoc, cos_sub]
    rw [← hZ]
    exact norm_sq_nonneg Z

  -- 4. Conclusion
  linarith [h_alg, h_le_zero]
