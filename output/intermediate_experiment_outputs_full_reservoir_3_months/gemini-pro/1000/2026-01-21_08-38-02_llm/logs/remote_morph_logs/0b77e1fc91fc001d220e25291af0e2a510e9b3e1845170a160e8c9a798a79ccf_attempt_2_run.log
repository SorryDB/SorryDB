open Real MeasureTheory Set Filter
open scoped BigOperators

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  let f (t : ℝ) := (1 - cos t) / t ^ (3/2)
  have hf : IntegrableOn f (Ioi 0) := by
    refine IntegrableOn.mono_on (g := fun t ↦ if t ≤ 1 then t ^ (1/2) / 2 else 2 * t ^ (-3/2)) ?_ ?_ ?_
    · apply IntegrableOn.union
      · refine (integrableOn_rpow_of_gt (by norm_num)).const_mul.congr_fun (fun t ht ↦ by simp [ht]) measurableSet_Ioc
      · refine (integrableOn_rpow_inv_of_gt (by norm_num)).const_mul.congr_fun (fun t ht ↦ by simp [ht]) measurableSet_Ioi
    · intro t ht; dsimp; split_ifs with h
      · rw [f, le_div_iff (rpow_pos_of_pos (mem_Ioi.mp ht) _), ← rpow_add (mem_Ioi.mp ht)]; norm_num
        exact (one_sub_cos_le_half_sq t).trans (by gcongr; exact h)
      · rw [f, div_le_iff (rpow_pos_of_pos (mem_Ioi.mp ht) _)]; norm_num; exact (sub_le_self _ (cos_le_one t))
    · exact measurableSet_Ioi

  let K := ∫ t in Ioi 0, f t
  have K_pos : 0 < K := by
    apply integral_pos_of_integrable_of_nonneg_of_pos_on_Ioo hf (fun t ht ↦ div_nonneg (sub_nonneg.mpr (cos_le_one t)) (rpow_nonneg (mem_Ioi.mp ht).le _)) (by norm_num)
    exact (continuousOn_id.neg.cos.sub_left_const.div (continuousOn_id.rpow_const (fun t ht ↦ (mem_Ioi.mp ht).ne')) (fun t ht ↦ (rpow_pos_of_pos (mem_Ioi.mp ht) _).ne')).pos_of_mem_Ioo (by norm_num)

