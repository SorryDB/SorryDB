    -- We know countP P + countP (!P & !Q) + countP (!P & Q) = S.length
    -- So suffices: countP Q = countP (!P & Q)
    -- countP Q = countP (Q & P) + countP (Q & !P)
    -- countP (Q & P) = 0 by disjoint.
    
    let P := isInitialCall m S
    let Q := isFinalCall m S
    have h_disj : ∀ x ∈ S, ¬(P x ∧ Q x) := disjoint
    
