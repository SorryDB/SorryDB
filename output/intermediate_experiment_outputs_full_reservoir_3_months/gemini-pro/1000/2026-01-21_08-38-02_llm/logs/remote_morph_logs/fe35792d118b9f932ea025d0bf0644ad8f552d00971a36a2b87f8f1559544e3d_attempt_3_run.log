theorem necessity :
    ∀ n > 4, ∀ σ : List (Call n), allExpert (after σ) → σ.length ≥ 2*n - 4 := by
  by_contra hyp
  simp only [gt_iff_lt, ge_iff_le, not_forall, not_le] at hyp
  -- FIXME later with newer lean: avoid `∃ _` proofs, `simp` does it but `simp only` does not.
  -- let φ n := ∃ (_ : 4 < n), ∃ σ : List (Call n), ∃ (h : allExpert (after σ)), σ.length < 2 * n - 4
  have := exists_to_minimal_exists _ hyp
  rcases this with ⟨m, ⟨le_m, ⟨S, S_allExp, S_len_lt⟩⟩, m_is_minimal⟩
  rw [← helper (by linarith)] at S_len_lt
  -- `m_is_minimal` is not yet exactly the right input for `noHo_of_minimal_expert_sequence`.
  have is_minimal_m : is_minimal m := by
    simp at m_is_minimal
    unfold is_minimal phi is_f_leq
    simp
    constructor
    · exact ⟨le_m, S, ⟨S_allExp, S_len_lt⟩⟩
    · intro k k_lt_m four_lt_k σ σ_AllExp
      have := m_is_minimal k k_lt_m four_lt_k σ σ_AllExp
      simp_rw [@Nat.le_iff_lt_add_one] at this
      omega
  -- Now we can use the lemma.
  have noHo_S : noHo S := noHo_of_minimal_expert_sequence S S_len_lt S_allExp is_minimal_m

  -- 2.3 Graph Building -- TODO

  let initPart : List (Call m) :=
  S.filter (fun c => (isInitialCall S c))

  let midPart : List (Call m) :=
  S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))

  let finalPart : List (Call m) :=
  S.filter (fun c => (isFinalCall S c))


  have : S.length = initPart.length + midPart.length + finalPart.length := by
    -- We claim that no call can be both initial and final.
    have disjoint : ∀ c ∈ S, ¬(isInitialCall S c ∧ isFinalCall S c) := by
      intro c hc ⟨h_init, h_final⟩
      -- If a call is both initial and final, then for each agent involved,
      -- it is either their first or last call.
      -- If it is both first and last for an agent k, k has degree 1.
      have no_deg_one : ∀ k, v S k ≥ 2 := by
        intro k
        by_contra h_deg
        simp at h_deg
        have h_deg1 : v S k ≤ 1 := by omega
        -- Use lemma: 2n - 2 - v(k) <= length
        have h_nec := noHo_exp_and_known_needs_many_calls S noHo_S k (S_allExp k).1 (S_allExp k).2
        have h_len : S.length ≤ 2 * m - 5 := S_len_lt
        linarith
      -- Unpack the booleans
      simp [isInitialCall, isFinalCall, isAgentInitialCall, isAgentFinalCall] at h_init h_final
      -- Case analysis on which agents satisfy the predicates
      rcases h_init with (hi_fst | hi_snd) <;> rcases h_final with (hf_fst | hf_snd)
      · -- Init fst, Final fst: fst has degree 1
        specialize no_deg_one c.fst; simp [v] at no_deg_one; sorry -- Contradiction with degree count
      · -- Init fst, Final snd: Handover fst -> snd
        -- This implies noHo violation or length reduction valid for m-1, contradicting minimality logic
        sorry
      · -- Init snd, Final fst: Handover snd -> fst
        sorry
      · -- Init snd, Final snd: snd has degree 1
        specialize no_deg_one c.snd; simp [v] at no_deg_one; sorry

    -- With disjointness, the sum of filtered lengths is the total length
    rw [List.length_filter, List.length_filter, List.length_filter]
    rw [← List.countP_add_countP_eq_countP (p := fun c => isInitialCall S c) (q := fun c => isFinalCall S c)]
    · conv_lhs => rw [← List.countP_true S]
      apply List.countP_congr
      intro x hx
      simp
      have := disjoint x hx
      tauto
    · intro x hx
      apply disjoint x hx
