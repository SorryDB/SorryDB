theorem necessity :
    ∀ n > 4, ∀ σ : List (Call n), allExpert (after σ) → σ.length ≥ 2*n - 4 := by
  by_contra hyp
  simp only [gt_iff_lt, ge_iff_le, not_forall, not_le] at hyp
  have := exists_to_minimal_exists _ hyp
  rcases this with ⟨m, ⟨le_m, ⟨S, S_allExp, S_len_lt⟩⟩, m_is_minimal⟩
  rw [← helper (by linarith)] at S_len_lt
  have is_minimal_m : is_minimal m := by
    simp at m_is_minimal
    unfold is_minimal phi is_f_leq
    simp
    constructor
    · exact ⟨le_m, S, ⟨S_allExp, S_len_lt⟩⟩
    · intro k k_lt_m four_lt_k σ σ_AllExp
      have := m_is_minimal k k_lt_m four_lt_k σ σ_AllExp
      simp_rw [@Nat.le_iff_lt_add_one] at this
      omega
  have noHo_S : noHo S := noHo_of_minimal_expert_sequence S S_len_lt S_allExp is_minimal_m

  let initPart : List (Call m) := S.filter (fun c => (isInitialCall S c))
  let midPart : List (Call m) := S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))
  let finalPart : List (Call m) := S.filter (fun c => (isFinalCall S c))

  have disjoint : ∀ c ∈ S, ¬(isInitialCall S c ∧ isFinalCall S c) := by
    intro c _ ⟨hI, hF⟩
    -- If a call is both initial and final for the agents involved,
    -- they only meet each other and no one else (in S).
    -- Thus they can only know {c.fst, c.snd}.
    -- Since m > 4, they cannot be experts.
    have : m ≤ 2 := by sorry
    linarith

  have : S.length = initPart.length + midPart.length + finalPart.length := by
    rw [List.length_eq_countP_add_countP (isInitialCall S) S]
    rw [List.length_eq_countP_add_countP (isFinalCall S) (S.filter (fun c => ¬isInitialCall S c))]
    congr 1
    · rfl
    · simp only [List.countP_filter]
      rw [add_comm]
      congr 1
      · apply List.countP_congr
        intro c _
        simp only [Bool.not_eq_true, decide_eq_true_eq]
        rw [and_comm]
        rfl
      · apply List.countP_congr
        intro c hc
        by_cases hF : isFinalCall S c
        · have hI : ¬isInitialCall S c := λ hI => disjoint c hc ⟨hI, hF⟩
          simp [hF, hI]
        · simp [hF]
