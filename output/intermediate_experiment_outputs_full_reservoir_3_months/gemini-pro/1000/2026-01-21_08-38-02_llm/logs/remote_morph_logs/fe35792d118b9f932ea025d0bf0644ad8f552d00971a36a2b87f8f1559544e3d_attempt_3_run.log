      have split := List.countP_add_countP_not (isInitialCall m S) (List.filter (isFinalCall m S) S)
      rw [List.countP_filter] at split
      rw [List.countP_filter] at split
      
      -- split says: countP (F ∧ I) + countP (F ∧ ¬I) = countP F
      -- We know countP (F ∧ I) = 0 from h_inter_empty (and_comm inside countP)
      rw [and_comm] at h_inter_empty
      rw [h_inter_empty, zero_add] at split
      
