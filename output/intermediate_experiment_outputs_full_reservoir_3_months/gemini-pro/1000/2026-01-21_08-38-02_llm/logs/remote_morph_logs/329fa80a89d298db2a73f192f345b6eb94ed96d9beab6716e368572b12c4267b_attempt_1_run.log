lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  -- [Rudin 87, Theorem 6.19]
  -- We prove that ‖μ‖ = 0, which implies μ = 0.
  rw [← ComplexMeasure.norm_eq_zero_iff]
  -- Let g be the conjugate of the polar derivative of μ.
  let g := (μ.polar ·).conj
  -- g is integrable because it is bounded by 1 and |μ| is a finite measure.
  have hg : Integrable g |μ| :=
    (integrable_const 1).mono' μ.polar.aestronglyMeasurable.conj
      (Eventually.of_forall fun x ↦ by simp [g, ComplexMeasure.norm_polar_le_one])
  -- The integral of g with respect to μ gives the total variation norm ‖μ‖.
  have h_norm : μ.integral g = ‖μ‖ := by
    rw [ComplexMeasure.integral_eq_integral_polar]
    simp only [g, RCLike.conj_mul, IsROrC.norm_sq_eq_def']
    rw [integral_congr_ae]
    · simp only [integral_const, Measure.restrict_apply, MeasurableSet.univ, one_mul]
      exact ComplexMeasure.norm_eq_nnnorm.symm
    · filter_upwards [ComplexMeasure.polar_mem_circle μ] with x hx using by simp [hx]
  rw [← h_norm]
  -- We show ∫ g dμ = 0 by approximating g with compactly supported continuous functions.
  apply norm_eq_zero.mp
  refine le_antisymm (le_of_forall_pos_le_add fun ε hε ↦ ?_) (norm_nonneg _)
  -- Use density of C_c(X) in L¹(|μ|).
  obtain ⟨f, hf⟩ := MeasureTheory.Lp.denseRange_continuousCompactSupport (E := ℂ) (p := 1) (μ := |μ|) |>.exists_dist_lt (hg.toLp g) hε
  -- Convert the L¹ distance back to an integral estimate.
  rw [dist_eq_norm, ← Memℒp.toLp_sub, Lp.norm_toLp, snorm_one_eq_lintegral_nnnorm] at hf
  rw [Integral.integral_norm_eq_lintegral_nnnorm (hg.sub (f.continuous.integrable_of_hasCompactSupport f.hasCompactSupport))]
  norm_cast at hf
  -- Use linearity and the hypothesis h to show ‖∫ g‖ is small.
  calc ‖μ.integral g‖
    _ = ‖μ.integral (g - f)‖ := by
      rw [← ComplexMeasure.integral_add hg (f.continuous.integrable_of_hasCompactSupport f.hasCompactSupport).neg]
      simp only [h f, add_zero, map_neg, sub_eq_add_neg]
    _ ≤ ∫ x, ‖(g - f) x‖ ∂|μ| := ComplexMeasure.norm_integral_le_integral_norm _ _
    _ < ε := hf
