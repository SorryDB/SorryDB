    specialize h f
    rw [ComplexMeasure.integral_eq_integral, μ.withDensity_polar,
      integral_withDensity_eq_integral_smul μ.measurable_polar (f.continuous.integrable v)] at h
    exact h
  have key := calc (v Set.univ : ℝ)
    _ = ‖∫ x, star (μ.polar x) * μ.polar x ∂v‖ := by
      rw [← integral_const (1 : ℂ)]
      congr 1
      apply integral_congr_ae
