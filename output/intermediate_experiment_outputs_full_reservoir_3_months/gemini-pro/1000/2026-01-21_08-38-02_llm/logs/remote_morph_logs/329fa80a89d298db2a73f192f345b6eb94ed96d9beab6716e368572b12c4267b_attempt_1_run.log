lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  -- We show that the total variation |μ| is zero, which implies μ = 0.
  -- |μ|(X) = ∫ conj(h) dμ where h is the polar derivative.
  rw [← ComplexMeasure.norm_eq_zero]
  have h_norm : ‖μ‖ = μ.integral (ComplexMeasure.polar μ).conj := by
    rw [ComplexMeasure.integral_eq_integral_polar]
    simp only [RCLike.conj_mul_eq_norm_sq, ComplexMeasure.norm_polar_eq_one, one_mul]
    rw [integral_const]
    simp only [Measure.restrict_univ, MeasurableSet.univ, ENNReal.one_toReal, one_mul]
    exact (ComplexMeasure.norm_def μ).symm
  rw [h_norm]
  -- We use the fact that f ↦ ∫ f dμ is a continuous linear functional on L¹(|μ|)
  -- which vanishes on the dense subspace C₀(X), hence is zero everywhere.
  -- In particular, it is zero at (polar μ).conj.
  let Φ : L1 X ℂ |μ| →L[ℂ] ℂ :=
    (MeasureTheory.L1.integralCLM ℂ |μ|.toMeasure).comp
      (MeasureTheory.Lp.mulLinftyCLM (ComplexMeasure.polar μ) (by
         rw [MeasureTheory.Lp.mem_Linfty_iff_essSup_le]
         exact ⟨1, ae_of_all _ (fun x ↦ (ComplexMeasure.norm_polar_le_one μ x).trans (le_of_eq rfl))⟩))
  have hΦ : ∀ f : C₀(X, ℂ), Φ (ContinuousMap.toL1 f |μ|) = 0 := fun f ↦ by
    simp only [Φ, ContinuousLinearMap.coe_comp, Function.comp_apply,
      MeasureTheory.Lp.mulLinftyCLM_apply, MeasureTheory.L1.integralCLM_apply, ContinuousMap.toL1_coe]
    exact h f
  have h_dense : DenseRange (ContinuousMap.toL1 (· : C₀(X, ℂ) → X → ℂ) |μ|) :=
    MeasureTheory.Lp.denseRange_continuous_zeroAtInfty |μ| 1
  have h_zero : Φ = 0 := ContinuousLinearMap.ext_on h_dense hΦ
  have h_conj : Integrable (ComplexMeasure.polar μ).conj |μ| :=
    ((MeasureTheory.Lp.mem_Linfty_iff_essSup_le.2
      ⟨1, ae_of_all _ (fun x ↦ by simp [ComplexMeasure.norm_polar_le_one])⟩).integrable _)
