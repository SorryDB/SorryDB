lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  rw [← ComplexMeasure.norm_eq_zero_iff, ComplexMeasure.norm_eq_totalVariation_univ]
