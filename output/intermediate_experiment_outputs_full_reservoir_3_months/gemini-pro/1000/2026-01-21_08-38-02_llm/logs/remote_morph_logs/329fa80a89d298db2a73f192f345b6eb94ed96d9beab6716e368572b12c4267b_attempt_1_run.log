lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  -- [Rudin 87, Theorem 6.19]
  -- Suppose `μ` is a regular complex Borel measure on `X`
  -- and that `∫ f dμ = 0` for all `f \in C_0(X)`.
  -- *Theorem 6.12* gives a Borel function `h`, such that `|h| = 1` and `dμ = h d|μ|`.
  -- For any sequence `{f_n}` in `C_0(X)` we then have
  -- `|μ|(X) = \int_X (\bar{h} - f_n) h`, `d|μ| ≤ \int_X |\bar{h} - f_n| \, d|μ|`.
  -- Since `C_c(X)` is dense in `L^1(|μ|)` (*Theorem 3.14*), `\{f_n\}` can be
  -- so chosen that the last expression in the above tends to 0 as `n → \infty`.
  -- Thus `|μ|(X) = 0`, and `μ = 0`.
  -- (Theorem 3.14: compactly supported continuous functions are dense in `L^p`,
  -- depends on 3.13 `MeasureTheory.Lp.simpleFunc.isDenseEmbedding`, this is written only for
  -- `NormalSpace α` and approximation given by bounded functions)
  -- It is easy to see that the difference of two regular complex Borel measures on `X` is regular.
  rw [← ComplexMeasure.norm_eq_zero_iff]
  apply le_antisymm _ (norm_nonneg _)
  by_contra h_pos
  have h_norm : 0 < ‖μ‖ := lt_of_le_of_ne (norm_nonneg _) (Ne.symm h_pos)
  let w := μ.polar
  have hw : Integrable (star w) μ.var := (integrable_polar _).star
  obtain ⟨g, hg⟩ := ContinuousMap.integrable_sub_approx_compact_support hw h_norm
  have h_int : ∫ x, star (w x) ∂μ = ‖μ‖ := by
    rw [ComplexMeasure.integral_eq_integral_withDensity _ hw, ← ComplexMeasure.withDensity_polar]
    simp only [w, RCLike.conj_mul, ComplexMeasure.norm_polar_eq_one, Complex.ofReal_one,
      integral_const, Measure.restrict_univ, Complex.ofReal_inj, ComplexMeasure.norm_eq_vide]
  have := calc
    ‖μ‖ = ‖∫ x, star (w x) ∂μ - μ.integral (ZeroAtInftyContinuousMap.ofCompactlySupported g)‖ := by
      rw [h_int, h]; simp
    _ = ‖∫ x, (star (w x) - g x) ∂μ‖ := by
      rw [integral_sub hw (g.continuous.integrable_of_compact_support g.hasCompactSupport _)]
      rfl
    _ ≤ ∫ x, ‖star (w x) - g x‖ ∂μ.var := ComplexMeasure.norm_integral_le_integral_norm _ _
    _ < ‖μ‖ := hg
  exact lt_irrefl _ this
