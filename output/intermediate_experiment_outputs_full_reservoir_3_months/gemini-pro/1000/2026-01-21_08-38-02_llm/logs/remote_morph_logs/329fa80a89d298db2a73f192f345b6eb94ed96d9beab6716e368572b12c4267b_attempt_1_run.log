The lemma `eq_zero_of_integral_eq_zero` proves the uniqueness of the measure in the Riesz representation theorem. The proof follows Rudin's *Real and Complex Analysis*, Theorem 6.19. We use the fact that the variation measure `μ.variation` is determined by the functional. Specifically, if the integral vanishes for all continuous functions vanishing at infinity, it vanishes for all compactly supported continuous functions. By the density of compactly supported continuous functions in $L^1$, the functional defined by the polar of the measure vanishes on $L^1$, which implies the measure is zero.

```lean
lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  -- [Rudin 87, Theorem 6.19]
  -- Suppose `μ` is a regular complex Borel measure on `X`
  -- and that `∫ f dμ = 0` for all `f \in C_0(X)`.
  -- *Theorem 6.12* gives a Borel function `h`, such that `|h| = 1` and `dμ = h d|μ|`.
  -- For any sequence `{f_n}` in `C_0(X)` we then have
  -- `|μ|(X) = \int_X (\bar{h} - f_n) h`, `d|μ| ≤ \int_X |\bar{h} - f_n| \, d|μ|`.
  -- Since `C_c(X)` is dense in `L^1(|μ|)` (*Theorem 3.14*), `\{f_n\}` can be
  -- so chosen that the last expression in the above tends to 0 as `n → \infty`.
  -- Thus `|μ|(X) = 0`, and `μ = 0`.
  -- (Theorem 3.14: compactly supported continuous functions are dense in `L^p`,
  -- depends on 3.13 `MeasureTheory.Lp.simpleFunc.isDenseEmbedding`, this is written only for
  -- `NormalSpace α` and approximation given by bounded functions)
  -- It is easy to see that the difference of two regular complex Borel measures on `X` is regular.
  rw [← μ.variation_eq_zero]
  let v := μ.variation
  have : IsFiniteMeasure v := inferInstance
  -- The linear functional Φ(g) = ∫ g dμ = ∫ g * polar dv extends to L^1(v)
  let Φ := MeasureTheory.L1.integralCLM ℂ v ∘L MeasureTheory.L1.withDensityCLM ℂ v μ.polar
  -- Φ vanishes on C_c(X) because it vanishes on C_0(X)
  have hΦ : ∀ f : C_c(X, ℂ), Φ (toLp 1 v f) = 0 := fun f ↦ by
    simp only [Φ, ContinuousLinearMap.comp_apply, L1.withDensityCLM_apply, L1.integralCLM_apply]
    rw [← VectorMeasure.integral_eq_integral_withDensity_polar]
    exact h (CompactlySupportedContinuousMap.toZeroAtInfty f)
  -- Since C_c(X) is dense in L^1(v), Φ = 0
  have h_dense := MeasureTheory.L1.denseRange_continuousCompactSupport v
  have h0 : Φ = 0 := ContinuousLinearMap.ext_on_dense h_dense hΦ
  -- Evaluating Φ at the conjugate of the polar function yields the total variation
  let g := toLp 1 v (fun x ↦ RCLike.star (μ.polar x))
  have h_eval : Φ g = v Set.univ := by
    simp only [Φ, ContinuousLinearMap.comp_apply, L1.withDensityCLM_apply, L1.integralCLM_apply]
    rw [integral_congr_ae (μ.norm_polar_eq_one.mono fun x hx ↦ ?_)]
    · simp
    · simp [hx, RCLike.star_mul_self]
  -- Thus |μ|(X) = 0
  apply le_antisymm _ (zero_le _)
  rw [← h_eval, h0]
  simp
