  have hw : ∀ᵐ x ∂ν, ‖w x‖ = 1 := ComplexMeasure.rnDeriv_norm μ
  let g := fun x ↦ conj (w x)
  have hg : Memℒp g 1 ν := by
    simp_rw [memℒp_one_iff_integrable, integrable_iff_norm, norm_eq_abs, Complex.norm_eq_abs, Complex.abs_conj, ← Complex.norm_eq_abs]
    refine (integrable_congr (hw.mono fun x hx ↦ by simp [hx])).mpr (integrable_const 1)
  obtain ⟨f, -, hf⟩ := ContinuousMap.cocompact_dense_Lp hg h_pos
  have h_int : ∫ x, (f : X → ℂ) x * w x ∂ν = 0 := by
    rw [← ComplexMeasure.integral_eq_integral_smul_rnDeriv]
    exact h (ZeroAtInftyContinuousMap.ofCompactlySupported f)
  have h_le : (ν Set.univ : ℝ) ≤ ∫ x, ‖(g - f) x‖ * ‖w x‖ ∂ν := by
    rw [← Complex.norm_of_real, ← ENNReal.toReal_toNNReal (measure_lt_top ν _)]
    have : (ν Set.univ : ℂ) = ∫ x, (g x - f x) * w x ∂ν := by
      rw [integral_sub hg.integrable (f.continuous.integrable_of_hasCompactSupport f.hasCompactSupport _), integral_mul_right, h_int, sub_zero, ← Measure.integral_const_one]
