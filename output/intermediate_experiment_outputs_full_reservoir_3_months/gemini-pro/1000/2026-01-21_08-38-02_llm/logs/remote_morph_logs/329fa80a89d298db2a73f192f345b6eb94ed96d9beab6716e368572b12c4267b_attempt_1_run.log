lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  -- [Rudin 87, Theorem 6.19]
  -- We prove that the measure is zero by showing its variation is zero.
  -- The variation is detected by integrals of continuous functions (density of C_c in L^1).
  ext s hs
  let ν := μ.var
  -- Compactly supported continuous functions are dense in L^1(ν)
  have : DenseRange (ContinuousMap.toLp 1 ν ℂ) :=
    MeasureTheory.Lp.denseRange_continuousCompactSupport
  let χ := Set.indicator s (1 : X → ℂ)
  have hχ : MemLp χ 1 ν := memLp_indicator_const ν hs 1
  -- μ(s) = ∫ 1_s dμ
  rw [← VectorMeasure.integral_indicator hs]
  -- Show |∫ 1_s dμ| < ε for all ε
  refine norm_le_zero_iff.1 (le_of_forall_le_of_dense fun ε hε ↦ ?_)
  rcases this.exists_dist_lt (χ.toLp χ hχ) hε with ⟨g, hg⟩
  rw [dist_eq_norm, Lp.norm_sub_eq_integral_norm] at hg
  -- |∫ χ dμ| = |∫ (χ - g) dμ| ≤ ∫ |χ - g| dν < ε
  calc ‖μ.integral χ‖
    _ = ‖μ.integral (χ - g)‖ := by
      rw [VectorMeasure.integral_sub hχ.integrable (ContinuousMap.integrable _ _)]
      rw [h g, sub_zero]
    _ ≤ ∫ x, ‖(χ - g) x‖ ∂ν := VectorMeasure.norm_integral_le_integral_norm _ _
    _ < ε := hg
