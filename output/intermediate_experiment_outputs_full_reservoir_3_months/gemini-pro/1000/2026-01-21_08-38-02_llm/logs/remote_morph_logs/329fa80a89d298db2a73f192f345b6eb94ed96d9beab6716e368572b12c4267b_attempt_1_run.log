lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  rw [← ComplexMeasure.norm_eq_zero_iff, ENNReal.toReal_eq_zero_iff]
  by_contra h_nz
  -- We use the polar decomposition dμ = h d|μ| with |h|=1.
  -- Then ‖μ‖ = ∫ conj h dμ.
  -- We approximate conj h by a function f ∈ C₀(X).
  let g := fun x ↦ conj (μ.polar x)
  have hg : Integrable g |μ| :=
    MeasureTheory.integrable_of_norm_eq_le (fun x ↦ (RCLike.norm_conj _).trans (ComplexMeasure.norm_polar_le _ _)) (measure_lt_top _ _)
  have h_norm : ‖μ‖ = ∫ x, g x ∂μ := ComplexMeasure.integral_conj_polar μ
  have h_int_zero : ∫ x, g x ∂μ = 0 := by
    apply norm_le_zero_iff.mp
    apply le_of_forall_le_of_dense
    intro ε hε
    -- Density of C_c(X) in L^1(|μ|) implies existence of approximation
