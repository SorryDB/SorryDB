lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral f = 0) :
    μ = 0 := by
  rw [← ComplexMeasure.norm_eq_zero_iff]
  by_contra h_nz
  let h_pol := conj ∘ μ.polar
  have h_int : Integrable h_pol μ.var :=
    (Integrable.bounded (measurable_polar.conj) (measure_lt_top _ _)
      (Eventually.of_forall fun x ↦ by simp [h_pol, abs_polar_le])).1
  have h_norm_eq : μ.integral h_pol = ‖μ‖ := ComplexMeasure.integral_conj_polar μ
  have : ∃ f : C₀(X, ℂ), ∫ x, ‖h_pol x - f x‖ ∂μ.var < ‖μ‖ := by
    have : DenseRange (fun (f : CompactlySupportedContinuousMap X ℂ) ↦ (toLp 1 μ.var ℂ f)) :=
      CompactlySupportedContinuousMap.denseRange_toLp 1 μ.var
    obtain ⟨g, hg⟩ := Metric.mem_closure_range_iff.mp (this (toLp 1 μ.var ℂ h_pol h_int)) ‖μ‖
      (lt_of_le_of_ne (norm_nonneg _) (Ne.symm h_nz))
    use ⟨g, g.is_zero_at_infty⟩
    rw [dist_eq_norm, Lp.norm_def, snorm_one_eq_lintegral_nnnorm] at hg
    rw [ENNReal.toReal_lt_iff_ne_top] at hg
    simp only [toLp_coe_fn, CoeFun.coe] at hg
    rw [← integral_norm_eq_lintegral_nnnorm] at hg
    · exact hg.1
    · exact (h_int.sub (g.continuous.integrable_of_hasCompactSupport g.hasCompactSupport μ.var)).aeStronglyMeasurable
  rcases this with ⟨f, hf⟩
  have h_zero : μ.integral f = 0 := h f
  have : ‖μ‖ ≤ ∫ x, ‖h_pol x - f x‖ ∂μ.var := by
    conv_lhs => rw [← h_norm_eq, ← h_zero, ← ComplexMeasure.integral_sub h_int (f.integrable μ.var)]
    exact ComplexMeasure.norm_integral_le_integral_norm _
  exact not_le_of_lt hf this
