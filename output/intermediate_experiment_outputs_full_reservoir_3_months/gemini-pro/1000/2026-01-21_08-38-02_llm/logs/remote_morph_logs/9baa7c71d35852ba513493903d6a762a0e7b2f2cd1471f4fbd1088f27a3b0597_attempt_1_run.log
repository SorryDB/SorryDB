    let C := (n : ℝ)^2 * ε^2
    have h_bound (s : ℝ) : |g'' s| ≤ C := by
      simp only [g'', interpolated_deriv2]
      have h_sum := abs_sum_le_sum_abs (Finset.univ : Finset (Fin n)) (fun i => ∑ j, (y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - s) • x + s • y))
      refine le_trans h_sum ?_
      apply Finset.sum_le_sum; intro i _
      have h_sum2 := abs_sum_le_sum_abs (Finset.univ : Finset (Fin n)) (fun j => (y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - s) • x + s • y))
      refine le_trans h_sum2 ?_
      apply Finset.sum_le_sum; intro j _
      rw [abs_mul, abs_mul]
      have h1 : |y i - x i| ≤ ε := by rw [abs_sub_comm]; exact hdiff i
      have h2 : |y j - x j| ≤ ε := by rw [abs_sub_comm]; exact hdiff j
      have h3 : |(nth_partial i <| nth_partial j f) ((1 - s) • x + s • y)| ≤ 1 := mpb i j _
      apply le_trans (mul_le_mul h1 (mul_le_mul h2 h3 (abs_nonneg _) (le_of_lt hε)) (abs_nonneg _) (le_of_lt hε))
      rw [mul_one, ← pow_two]; rfl
      
    have h_inner (t : ℝ) (ht : 0 ≤ t) : ∫ s in 0..t, |g'' s| ≤ C * t := by
      rw [← intervalIntegral.integral_const 0 t C]
      apply intervalIntegral.integral_mono_on ht
      · apply Continuous.intervalIntegrable
        exact intervalIntegral.continuous_primitive (Continuous.comp continuous_abs g''_cont) 0
      · exact intervalIntegrable_const
      · intro s _; exact h_bound s

    calc ∫ t in 0..1, ∫ s in 0..t, |g'' s|
      _ ≤ ∫ t in 0..1, C * t := by
