            rw [intervalIntegral.integral_of_le ht.1]
            apply intervalIntegral.integral_mono_of_le_prop ht.1
            · exact g''_cont.norm.intervalIntegrable 0 t
            · exact intervalIntegrable_const
            · intro s _; exact h_bound s
          · exact intervalIntegrable_const
      _ = K / 2 := by
        rw [intervalIntegral.integral_mul_const, intervalIntegral.integral_id]
        simp; ring
      _ = (n^2 / 2) * ε^2 := by simp [K]; ring

  calc |f x - f y|
    _ = |g 1 - g 0| := by simp [g, interpolated, interpolator, neg_sub, abs_sub_comm]
    _ = |g' 0 + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s| := by rw [hobs]
    _ ≤ |g' 0| + |∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s| := abs_add _ _
    _ ≤ |g' 0| + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by
      apply add_le_add_left
      calc |∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s|
        _ ≤ ∫ (t : ℝ) in 0..1, |∫ (s : ℝ) in 0..t, g'' s| := by
          apply intervalIntegral.norm_integral_le_integral_norm (by norm_num)
          apply Continuous.intervalIntegrable
          apply Continuous.integral_interval g''_cont continuous_id
        _ ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by
          apply intervalIntegral.integral_mono_on (by norm_num)
          · apply Continuous.intervalIntegrable
            apply Continuous.norm
            apply Continuous.integral_interval g''_cont continuous_id
          · apply Continuous.intervalIntegrable
            apply Continuous.integral_interval g''_cont.norm continuous_id
          · intro t ht
            rw [Set.uIcc_of_le (by norm_num : (0 : ℝ) ≤ 1)] at ht
            apply intervalIntegral.norm_integral_le_integral_norm ht.1
            exact g''_cont.intervalIntegrable 0 t
    _ ≤ ε * ∑ i, |nth_partial i f x| + (n^2 / 2) * ε^2 := by
