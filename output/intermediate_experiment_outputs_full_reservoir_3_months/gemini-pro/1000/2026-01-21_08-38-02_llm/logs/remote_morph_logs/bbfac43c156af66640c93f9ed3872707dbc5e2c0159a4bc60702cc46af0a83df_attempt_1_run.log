The lemma `Submartingale.uniformIntegrable_stoppedValue` states that the stopped values of a submartingale $X$ at stopping times $\tau_i \le n$ form a uniformly integrable family.

Proof idea:
1.  The positive part $X_{\tau_i}^+$ is a submartingale stopped at $\tau_i \le n$. By the optional sampling theorem, $X_{\tau_i} \le \mathbb{E}[X_n \mid \mathcal{F}_{\tau_i}]$. Thus $0 \le X_{\tau_i}^+ \le \mathbb{E}[|X_n| \mid \mathcal{F}_{\tau_i}]$. The family of conditional expectations is uniformly integrable, hence $\{X_{\tau_i}^+\}_i$ is uniformly integrable.
2.  The negative part $X_{\tau_i}^-$ satisfies $|X_{\tau_i}| = 2 X_{\tau_i}^+ - X_{\tau_i}$. To show uniform integrability of $X_{\tau_i}$, it suffices to show uniform integrability of $X_{\tau_i}^-$ (or equivalently bound the tail integrals of $|X_{\tau_i}|$).
3.  We use the property $\int_A X_{\tau_i} \, d\mu \ge \int_A X_\bot \, d\mu$ for $A \in \mathcal{F}_{\tau_i}$ (from optional sampling with $\bot \le \tau_i$).
4.  For large $M$, let $A = \{X_{\tau_i} < -M\}$. Then $\int_A |X_{\tau_i}| \, d\mu = -\int_A X_{\tau_i} \, d\mu \le -\int_A X_\bot \, d\mu \le \int_A |X_\bot| \, d\mu$.
5.  Since the $L^1$ norms of $X_{\tau_i}$ are bounded (by $2\mathbb{E}[X_{\tau_i}^+] - \mathbb{E}[X_\bot]$), the probability of $A$ vanishes as $M \to \infty$, making $\int_A |X_\bot| \, d\mu$ small.

```lean
lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  have h_pos : UniformIntegrable (fun i ↦ (stoppedValue X (τ i))⁺) 1 μ := by
    refine uniformIntegrable_of_dominated ((hX.memLp n).uniformIntegrable_condExp'.comp
      (fun i ↦ ((), (hτ i).measurableSpace_le)))
      (fun i ↦ (hX.stoppedValue_memLp (hτ i)).aestronglyMeasurable.pos_part) (fun i ↦ ?_)
    filter_upwards [hX.stoppedValue_ae_le_condExp_of_le (hτ i)
      (isStoppingTime_const _ _) (hτ_le i)] with ω hω
    exact (Real.le_norm_self _).trans (abs_le.1 (abs_le_abs_of_nonneg (by simp)
      (hω.trans (le_abs_self _)))).2
  refine uniformIntegrable_of_integral_le_of_nonneg h_pos (fun i ↦ ?_)
  let A := {ω | stoppedValue X (τ i) ω < 0}
  have hA : MeasurableSet A := measurableSet_lt (hX.stoppedValue_measurable (hτ i)) measurable_const
  have h_le : ∫ ω in A, X ⊥ ω ∂μ ≤ ∫ ω in A, stoppedValue X (τ i) ω ∂μ :=
    hX.set_integral_le_of_set_integral_expected_stoppedValue_le (isStoppingTime_const _ _)
      (hτ i) (fun _ ↦ bot_le) hA (by simp [A, stoppedValue])
  calc
    ∫ ω, (stoppedValue X (τ i))⁻ ω ∂μ = ∫ ω in A, -stoppedValue X (τ i) ω ∂μ := by
      rw [← integral_indicator hA]; apply integral_congr_ae; filter_upwards with ω
      by_cases h : ω ∈ A <;> simp [h, A]
    _ = -∫ ω in A, stoppedValue X (τ i) ω ∂μ := integral_neg
    _ ≤ -∫ ω in A, X ⊥ ω ∂μ := neg_le_neg h_le
    _ ≤ ∫ ω in A, |X ⊥ ω| ∂μ :=
      (le_abs_self _).trans (integral_abs_ge_abs_integral (hX.memLp ⊥).integrable.integrableOn)
    _ ≤ ∫ ω, |X ⊥ ω| ∂μ :=
      integral_mono_set (hX.memLp ⊥).integrable.norm.integrableOn (hX.memLp ⊥).integrable.norm.aestronglyMeasurable.ae_ge_0 (Measure.le_add_right le_rfl)
