lemma IsBernoulliOn.inter (hX : IsBernoulliOn X u p P) (hY : IsBernoulliOn Y u q P)
    (hXY : IndepFun X Y P) :
    IsBernoulliOn (fun ω ↦ X ω ∩ Y ω) u (p * q) P where
  aemeasurable := hX.aemeasurable.inter hY.aemeasurable
  map_eq := by
    rw [← hXY.map_prod_eq hX.aemeasurable hY.aemeasurable, hX.map_eq, hY.map_eq,
      bernoulliOn_eq_map, bernoulliOn_eq_map, bernoulliOn_eq_map, Measure.map_map,
      Measure.map_map, Measure.map_prod_map]
    · congr 1
      rw [← Measure.map_pi_map_prod]
      congr with i
      simp only [mem_u, toNNReal_mul, dirac_prod_dirac, map_dirac, Function.comp_apply,
        Bool.forall_bool, Bool.cond_false, Bool.cond_true, Prod.mk_false, Prod.mk_true,
        and_true, and_false, smul_add, smul_smul, add_assoc, ← add_smul, mul_comm (σ p)]
      by_cases hi : i ∈ u
      · simp only [hi, ↓reduceIte, dirac_true, dirac_false]
        congr 1
        rw [← ENNReal.coe_mul, ← ENNReal.coe_mul, ← ENNReal.coe_add]
        congr 1
        rw [unitInterval.coe_symm_eq, unitInterval.coe_symm_eq, unitInterval.coe_symm_eq,
          Subtype.coe_mk]
        ring
      · simp [hi]
    · exact MeasurableEquiv.setOf.measurable
