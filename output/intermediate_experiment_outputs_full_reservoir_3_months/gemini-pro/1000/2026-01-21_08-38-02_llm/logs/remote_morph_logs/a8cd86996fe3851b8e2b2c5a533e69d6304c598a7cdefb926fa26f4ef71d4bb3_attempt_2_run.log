    have eq : ‖g n - g m‖ ^ 2 = 4 * (2⁻¹ * φ (g n) + 2⁻¹ * φ (g m) - φ ((2 : ℝ≥0)⁻¹ • (g n + g m))) := by
      dsimp [φ]
