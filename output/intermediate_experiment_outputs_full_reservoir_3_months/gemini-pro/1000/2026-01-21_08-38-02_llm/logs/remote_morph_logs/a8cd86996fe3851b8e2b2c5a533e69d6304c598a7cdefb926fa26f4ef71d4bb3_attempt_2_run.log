lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E] [CompleteSpace E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (nhds x) := by
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg, hg_phi⟩ := komlos_convex (φ := fun x ↦ ‖x‖^2)
    (fun x ↦ sq_nonneg ‖x‖)
    ⟨M^2, fun n ↦ sq_le_sq.2 (abs_le_abs_of_nonneg (norm_nonneg _) (hM n))⟩
  have h_cauchy : CauchySeq g := by
    rw [Metric.cauchySeq_iff']
    intro ε hε
    obtain ⟨N, hN⟩ := hg_phi (ε^2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq (norm_nonneg _) (le_of_lt hε)]
    calc ‖g n - g m‖^2
      = 2 * ‖g n‖^2 + 2 * ‖g m‖^2 - ‖g n + g m‖^2 := by
        rw [← parallelogram_law_with_norm_sq]; ring
      _ = 4 * (2⁻¹ * ‖g n‖^2 + 2⁻¹ * ‖g m‖^2 - ‖(2 : ℝ≥0)⁻¹ • (g n + g m)‖^2) := by
        simp only [norm_smul, Real.norm_of_nonneg (by norm_num), sq]
        norm_num; ring
      _ < 4 * (ε^2 / 4) := mul_lt_mul_of_pos_left hN (by norm_num)
      _ = ε^2 := by ring
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete h_cauchy
  refine ⟨g, x, fun n ↦ ?_, hx⟩
  refine convexHull_min (subset_convexHull ℝ _) ?_ (hg n)
  intro x y hx hy a b hab
  simp only [NNReal.coe_add, NNReal.coe_one] at hab
  exact convex_convexHull ℝ _ hx hy a b hab
