lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  let φ : E → ℝ := fun x ↦ ‖x‖^2
  have hφ_nonneg : 0 ≤ φ := fun x ↦ sq_nonneg _
  have hφ_bdd : ∃ M', ∀ n, φ (f n) ≤ M' :=
    ⟨M^2, fun n ↦ pow_le_pow_left (norm_nonneg _) (hM n) 2⟩
  obtain ⟨g, hg_hull, hg_cauchy⟩ := komlos_convex hφ_nonneg hφ_bdd
  have h_cauchy : CauchySeq g := by
    refine Metric.cauchySeq_iff.mpr fun ε hε ↦ ?_
    obtain ⟨N, hN⟩ := hg_cauchy (ε^2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    simp only [φ, norm_smul, inv_pow, Real.norm_eq_abs, abs_of_nonneg (by norm_num),
      show (2 : ℝ)^2 = 4 by norm_num] at hN
    rw [parallelogram_law_with_norm_sq] at hN
    rw [dist_eq_norm, ← sq_lt_sq (norm_nonneg _) (le_of_lt hε), div_lt_iff (by norm_num)] at hN
    linarith
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete h_cauchy
  exact ⟨g, x, fun n ↦ convexHull_min (subset_convexHull ℝ _)
    (convex_convexHull ℝ _).restrictScalars (hg_hull n), hx⟩
