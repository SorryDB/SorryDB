lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E] [CompleteSpace E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg_mem, hg_cauchy⟩ := komlos_convex (φ := fun x ↦ ‖x‖^2) (fun _ ↦ sq_nonneg _)
    ⟨M ^ 2, fun n ↦ (norm_sq_eq_inner _).le.trans <| pow_le_pow_left (norm_nonneg _) (hM n) 2⟩
  have h_cauchy : CauchySeq g := by
    rw [Metric.cauchySeq_iff]
    intro ε hε
    rcases hg_cauchy ((ε / 2) ^ 2) (by positivity) with ⟨N, hN⟩
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq (norm_nonneg _) (hε.le.trans_lt (by linarith)),
      ← mul_lt_mul_left (a := (4 : ℝ)⁻¹) (by norm_num), ← mul_pow, mul_div_cancel₀ _ (by norm_num)]
