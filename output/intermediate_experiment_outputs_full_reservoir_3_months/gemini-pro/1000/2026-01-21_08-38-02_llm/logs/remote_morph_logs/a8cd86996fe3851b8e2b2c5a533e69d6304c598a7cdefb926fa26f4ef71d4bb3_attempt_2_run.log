    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  let φ : E → ℝ := fun x ↦ ‖x‖ ^ 2
  have hφ_pos : 0 ≤ φ := fun x ↦ sq_nonneg _
  have hφ_bdd : ∃ M, ∀ n, φ (f n) ≤ M := by
    refine ⟨M ^ 2, fun n ↦ ?_⟩
    have : 0 ≤ M := le_trans (norm_nonneg _) (hM n)
    exact pow_le_pow_left (norm_nonneg _) (hM n) 2
  obtain ⟨g, hg_hull, hg_cauchy⟩ := komlos_convex hφ_pos hφ_bdd
  have hg_cauchy' : CauchySeq g := by
    rw [Metric.cauchySeq_iff]
    intro ε hε
    have hε' : 0 < ε ^ 2 / 4 := div_pos (pow_pos hε 2) zero_lt_four
    obtain ⟨N, hN⟩ := hg_cauchy _ hε'
