def LoopWalkSetoid : Setoid (ClosedLoopWalk (K n)) where
  r := LoopWalkEquiv n
  iseqv := by
    constructor
    · intro x
      classical
      rcases x with ⟨ux, px⟩
      refine ⟨Equiv.refl (Fin n), ?_⟩
      ext
      · simp
      · simp [permMapWalk_refl]
    · intro x y hxy
      classical
      rcases x with ⟨ux, px⟩
      rcases y with ⟨uy, py⟩
      rcases hxy with ⟨s, hy⟩
      refine ⟨s.symm, ?_⟩
      cases hy
      simp [permMapWalk_comp, perm_symm_mul_self, permMapWalk_refl]
    · intro x y z hxy hyz
      rcases hxy with ⟨s, rfl⟩
      rcases hyz with ⟨t, rfl⟩
      refine ⟨t * s, ?_⟩
      simp
