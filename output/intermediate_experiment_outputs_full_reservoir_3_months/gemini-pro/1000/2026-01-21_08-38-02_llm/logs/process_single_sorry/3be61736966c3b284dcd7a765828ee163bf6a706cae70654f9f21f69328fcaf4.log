@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  rw [answer]
  constructor
  · intro h
    have h_sq : ∀ t > 0, f (t ^ 2) = f t ^ 2 := by
      intro t ht
      specialize h t t t t ht ht ht ht rfl
      have : f (t^2) + f (t^2) ≠ 0 := ne_of_gt (add_pos (h₁ _ (pow_pos ht 2)) (h₁ _ (pow_pos ht 2)))
      field_simp [this] at h
      linarith
    
    have h1 : f 1 = 1 := by
      have := h_sq 1 zero_lt_one
      rw [one_pow] at this
      nlinarith [h₁ 1 zero_lt_one]

    have key : ∀ y z, 0 < y → 0 < z → f (y * z) * (y ^ 2 + z ^ 2) = y * z * (f y ^ 2 + f z ^ 2) := by
      intro y z hy hz
      let w := Real.sqrt (y * z)
      have hw : 0 < w := Real.sqrt_pos.mpr (mul_pos hy hz)
      have hw2 : w ^ 2 = y * z := Real.sq_sqrt (le_of_lt (mul_pos hy hz))
      specialize h w w y z hw hw hy hz (by rw [←hw2])
      rw [h_sq y hy, h_sq z hz, ← h_sq w hw, hw2] at h
      field_simp [h₁ (y^2) (pow_pos hy 2), h₁ (z^2) (pow_pos hz 2)] at h
      linarith

    have pt_sol : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize key x 1 hx zero_lt_one
      rw [h1, mul_one, one_pow, one_pow, mul_one] at key
      have : (f x - x) * (x * f x - 1) = 0 := by
        apply eq_zero_of_sub_eq_zero
        rw [← key]
        ring
      rcases eq_zero_or_eq_zero_of_mul_eq_zero this with hx_eq | hx_eq
      · left; linarith
      · right; field_simp [ne_of_gt hx]; linarith

    by_cases H : ∃ a > 0, a ≠ 1 ∧ f a = a
    · left
      rcases H with ⟨a, ha, han, haf⟩
      intro x hx
      rcases pt_sol x hx with hfx | hfx
      · exact hfx
      · by_cases hx1 : x = 1
        · rw [hx1]; exact h1.symm
        · specialize key a x ha hx
          rw [haf, hfx] at key
          rcases pt_sol (a * x) (mul_pos ha hx) with hfax | hfax
          · rw [hfax] at key
            field_simp [ne_of_gt hx] at key
            have : x ^ 4 = 1 := by linarith
            have : x = 1 := (pow_eq_one_iff_of_nonneg (le_of_lt hx) four_ne_zero).mp this
            contradiction
          · rw [hfax] at key
            field_simp [ne_of_gt ha, ne_of_gt hx] at key
            have : a ^ 4 = 1 := by linarith
            have : a = 1 := (pow_eq_one_iff_of_nonneg (le_of_lt ha) four_ne_zero).mp this
            contradiction
    · right
      intro x hx
      push_neg at H
      by_cases hx1 : x = 1
      · rw [hx1, h1]; norm_num
      · have : f x ≠ x := H x hx hx1
        rcases pt_sol x hx with h | h
        · contradiction
        · exact h

  · rintro (h | h) w x y z hw hx hy hz heq
    · simp [h w hw, h x hx, h (y^2) (pow_pos hy 2), h (z^2) (pow_pos hz 2)]
    · simp [h w hw, h x hx, h (y^2) (pow_pos hy 2), h (z^2) (pow_pos hz 2)]
      field_simp
      rw [← mul_pow, ← mul_pow, heq]
      ring
