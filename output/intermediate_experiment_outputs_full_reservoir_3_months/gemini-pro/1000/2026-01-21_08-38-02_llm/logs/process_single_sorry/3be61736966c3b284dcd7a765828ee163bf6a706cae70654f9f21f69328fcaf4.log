      "\n  try unfold answer\n  constructor\n  · intro h\n    have hf1 : f 1 = 1 := by\n      specialize h 1 1 1 1 one_pos one_pos one_pos one_pos rfl\n      simp only [one_pow, one_mul] at h\n      rw [← two_mul, ← two_mul, mul_div_mul_left _ _ (two_ne_zero), sq, mul_div_cancel_right₀] at h\n      exact h; exact ne_of_gt (h₁ 1 one_pos)\n    have hsq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by\n      intro x hx\n      specialize h x x x x hx hx hx hx rfl\n      dsimp only at h\n      rw [← two_mul, ← two_mul, mul_div_mul_left _ _ (two_ne_zero), div_self] at h\n      exact h.symm; exact ne_of_gt (h₁ _ (pow_pos hx 2))\n    have key : ∀ y z, 0 < y → 0 < z → (f y ^ 2 + f z ^ 2) / f (y * z) = (y ^ 2 + z ^ 2) / (y * z) := by\n      intro y z hy hz\n      let w := Real.sqrt (y * z)\n      have hw : 0 < w := Real.sqrt_pos.mpr (mul_pos hy hz)\n      have heq : w * w = y * z := Real.mul_self_sqrt (le_of_lt (mul_pos hy hz))\n      specialize h w w y z hw hw hy hz heq\n      rw [← sq, hsq w hw, heq, ← sq, heq, hsq y hy, hsq z hz] at h\n      field_simp [h₁ (y*z) (mul_pos hy hz)] at h ⊢; linarith\n    have dich : ∀ x > 0, f x = x ∨ f x = 1 / x := by\n      intro x hx\n      specialize key 1 x one_pos hx\n      rw [hf1, one_pow, one_mul, one_mul, one_pow] at key\n      field_simp [h₁ x hx] at key\n      have : (f x - x) * (x * f x - 1) = 0 := by nlinarith\n      cases eq_zero_or_eq_zero_of_mul_eq_zero this with\n      | inl h => left; linarith\n      | inr h => right; field_simp; linarith\n    by_contra hc\n    push_neg at hc\n    rcases hc with ⟨⟨a, ha, hna⟩, ⟨b, hb, hnb⟩⟩\n    have fa : f a = 1 / a := (dich a ha).resolve_left hna\n    have fb : f b = b := (dich b hb).resolve_right hnb\n    specialize key a b ha hb\n    rw [fa, fb] at key\n    rcases dich (a * b) (mul_pos ha hb) with hab | hab\n    · rw [hab] at key; field_simp [ha, hb] at key\n      have : a^4 = 1 := by nlinarith\n      have : a = 1 := by nlinarith [ha]\n      subst this; simp at hna\n    · rw [hab] at key; field_simp