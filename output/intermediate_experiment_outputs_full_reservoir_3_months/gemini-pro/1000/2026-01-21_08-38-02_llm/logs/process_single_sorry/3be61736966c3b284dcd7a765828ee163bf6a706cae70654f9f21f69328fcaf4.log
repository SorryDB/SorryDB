      "\n  try dsimp [answer]\n  constructor\n  · intro h\n    have h_sq : ∀ t > 0, f (t ^ 2) = f t ^ 2 := by\n      intro t ht\n      specialize h t t t t ht ht ht ht rfl\n      field_simp [h₁ _ (pow_pos ht 2)] at h\n      linarith\n    have h1 : f 1 = 1 := by\n      have := h_sq 1 zero_lt_one\n      rw [one_pow] at this\n      nlinarith [h₁ 1 zero_lt_one]\n    have h_vals : ∀ x > 0, f x = x ∨ f x = 1 / x := by\n      intro x hx\n      let t := Real.sqrt x\n      have ht : 0 < t := Real.sqrt_pos.mpr hx\n      have hx_t : x = t ^ 2 := (Real.sq_sqrt (le_of_lt hx)).symm\n      specialize h 1 x t t zero_lt_one hx ht ht (by rw [one_mul, hx_t])\n      rw [h1, one_pow, hx_t, h_sq t ht] at h\n      let u := f t\n      rw [hx_t]\n      have eq : (1 + u^2^2)/(2 * u^2) = (1 + t^2^2)/(2 * t^2) := by\n        rw [←h]\n        field_simp\n        rw [←hx_t, h_sq t ht]\n        ring\n      field_simp [h₁ t ht, ht] at eq\n      have factor : (u^2 - t^2) * (u^2 * t^2 - 1) = 0 := by nlinarith\n      rcases factor with H | H\n      · left; rw [←hx_t]; nlinarith [h₁ t ht, H]\n      · right; rw [←hx_t]; field_simp at H ⊢; nlinarith [h₁ t ht, H]\n    by_contra hc\n    push_neg at hc\n    rcases hc with ⟨⟨a, ha, hfa⟩, ⟨b, hb, hfb⟩⟩\n    have fa_inv : f a = 1 / a := (h_vals a ha).resolve_left hfa\n    have fb_id : f b = b := (h_vals b hb).resolve_right hfb\n    have ha1 : a ≠ 1 := by intro e; rw [e, h1] at fa_inv; norm_num at fa_inv\n    have hb1 : b ≠ 1 := by intro e; rw [e, h1] at fb_id; norm_num at fb_id\n    let y := Real.sqrt (a * b)\n    have hy : 0 < y := Real.sqrt_pos.mpr (mul_pos ha hb)\n    specialize h a b y y ha hb hy hy (Real.mul_self_sqrt (le_of_lt (mul_pos ha hb))).symm\n    rw [fa_inv, fb_id] at h\n    have y_sq : y^2 = a * b := Real.sq_sqrt (le_of_lt (mul_pos ha hb))\n    rw [y_sq] at h\n    rcases h_vals (a * b) (mul_pos ha hb) with hab | hab\n    · rw [hab] at h\n      have : a^4 = 1 := by field_simp [ha, hb, h₁ _ (mul_pos ha hb)] at h; nlinarith\n      nlinarith [ha, h