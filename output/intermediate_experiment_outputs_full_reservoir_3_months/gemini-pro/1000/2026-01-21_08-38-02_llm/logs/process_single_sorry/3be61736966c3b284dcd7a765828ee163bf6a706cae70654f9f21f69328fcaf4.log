      "\n  rw [answer]\n  constructor\n  · intro h\n    have h_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by\n      intro x hx\n      specialize h x x x x hx hx hx hx rfl\n      rw [div_eq_one_iff_eq] at h\n      · have : 2 * f x ^ 2 = 2 * f (x ^ 2) := by linear_combination h\n        linarith\n      · specialize h₁ (x^2) (pow_pos hx 2); linarith\n    have h_pt : ∀ x > 0, f x = x ∨ f x = 1 / x := by\n      intro w hw\n      let y := Real.sqrt w\n      have hy : 0 < y := Real.sqrt_pos.mpr hw\n      have heq : w * 1 = y * y := by rw [mul_one, ← Real.sq_sqrt (le_of_lt hw)]; rfl\n      specialize h w 1 y y hw zero_lt_one hy hy heq\n      rw [one_pow, one_pow, h_sq 1 zero_lt_one, one_pow] at h\n      have f1 : f 1 = 1 := by\n        have := h_sq 1 zero_lt_one\n        nlinarith [h₁ 1 zero_lt_one]\n      rw [f1, one_pow, ← pow_two, Real.sq_sqrt (le_of_lt hw)] at h\n      have : f w * (w^2 + 1) = w * (f w ^ 2 + 1) := by\n        field_simp [h₁ w hw] at h; linear_combination h\n      have : w * (f w - w) * (f w - 1/w) = 0 := by\n        field_simp [hw.ne'] at this ⊢; ring_nf; linear_combination this\n      rw [mul_eq_zero, mul_eq_zero] at this\n      rcases this with rfl | h | h\n      · linarith\n      · left; linarith\n      · right; linarith\n    by_cases H : ∀ x > 0, f x = x\n    · left; exact H\n    · right\n      push_neg at H\n      rcases H with ⟨a, ha, hfa⟩\n      have ha_val : f a = 1 / a := (h_pt a ha).resolve_left hfa\n      intro x hx\n      rcases h_pt x hx with hfx | hfx\n      · let y := Real.sqrt (a * x)\n        have hax : 0 < a * x := mul_pos ha hx\n        have hy : 0 < y := Real.sqrt_pos.mpr hax\n        specialize h a x y y ha hx hy hy (by rw [← Real.sq_sqrt (le_of_lt hax)]; rfl)\n        rw [← pow_two, Real.sq_sqrt (le_of_lt hax)] at h\n        rw [ha_val, hfx] at h\n        rcases h_pt (a * x) hax with hfax | hfax\n        · rw [hfax] at h\n          field_simp [h₁ (a*x) hax, ha.ne', hx.ne', hax.ne'] at h\n          have : a^4 = 1 := by ring_nf at h; linea