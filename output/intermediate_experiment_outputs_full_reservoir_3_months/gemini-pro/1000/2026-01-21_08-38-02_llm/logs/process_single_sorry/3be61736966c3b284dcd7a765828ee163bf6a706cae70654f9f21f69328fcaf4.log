      "\n  dsimp only [answer]\n  constructor\n  · intro h\n    have h_sq : ∀ t > 0, f (t ^ 2) = f t ^ 2 := fun t ht ↦ by\n      specialize h t t t t ht ht ht ht rfl\n      field_simp [h₁ t ht, ht] at h\n      linarith\n    have h_val : ∀ x > 0, f x = x ∨ f x = 1 / x := fun x hx ↦ by\n      have h1 : f 1 = 1 := by\n        have := h_sq 1 zero_lt_one; rw [one_pow] at this\n        exact (sq_eq_self_iff_is_one_or_zero _).mp this.symm |>.resolve_right (h₁ 1 zero_lt_one).ne'\n      let w := Real.sqrt (x * 1)\n      have hw : 0 < w := Real.sqrt_pos.mpr (mul_pos hx zero_lt_one)\n      specialize h w w x 1 hw hw hx zero_lt_one (by rw [← Real.sq_sqrt (mul_pos hx zero_lt_one).le]; simp)\n      rw [← Real.sq_sqrt (mul_pos hx zero_lt_one).le, h_sq x hx, h_sq 1 zero_lt_one, h1, one_pow, one_mul] at h\n      field_simp [h₁ x hx, hx] at h\n      have eq : (f x - x) * (x * f x - 1) = 0 := by nlinarith\n      rcases eq_zero_or_eq_zero_of_mul_eq_zero eq with h | h\n      · left; linarith\n      · right; field_simp [hx] at h ⊢; exact h\n    by_contra h_not\n    push_neg at h_not\n    rcases h_not with ⟨⟨a, ha, hfa⟩, ⟨b, hb, hfb⟩⟩\n    have ha' : f a = 1 / a := (h_val a ha).resolve_left hfa\n    have hb' : f b = b := (h_val b hb).resolve_right hfb\n    let w := Real.sqrt (a * b)\n    have hw : 0 < w := Real.sqrt_pos.mpr (mul_pos ha hb)\n    specialize h w w a b hw hw ha hb (by rw [← Real.sq_sqrt (mul_pos ha hb).le]; simp)\n    rw [← Real.sq_sqrt (mul_pos ha hb).le, h_sq a ha, h_sq b hb, ha', hb'] at h\n    cases h_val (a * b) (mul_pos ha hb) with\n    | inl hfab =>\n        rw [hfab] at h\n        field_simp [ha, hb] at h\n        have : a ^ 4 = 1 := by nlinarith\n        have : a = 1 := (pow_eq_one_iff_of_nonneg ha.le four_ne_zero).mp this\n        subst this; simp at hfa\n    | inr hfab =>\n        rw [hfab] at h\n        field_simp [ha, hb] at h\n        have : b ^ 4 = 1 := by nlinarith\n        have : b = 1 := (pow_eq_one_iff_of_nonneg hb.le four_ne_zero).mp this\n        subst th