theorem longestIncreasingSubsequence_spec_satisfied (nums: List Int) (h_precond : longestIncreasingSubsequence_precond (nums)) :
    longestIncreasingSubsequence_postcond (nums) (longestIncreasingSubsequence (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  unfold longestIncreasingSubsequence longestIncreasingSubsequence_postcond
  let rec helper (lst : List Int) (prev : Option Int) : Nat :=
    match lst with
    | [] => 0
    | h :: t =>
        let canTake : Bool :=
          if prev = none then true
          else if prev.get! < h then true else false
        let withTake : Nat :=
          if canTake then 1 + helper t (some h) else 0
        let withoutTake : Nat := helper t prev
        if withTake > withoutTake then withTake else withoutTake
  
  -- The local helper is definitionally equal to the one in the source function
  have h_eq : longestIncreasingSubsequence nums h_precond = helper nums none := rfl

  -- Define the subsequence generation logic from the spec to reason about it
  let allSubseq (l : List Int) := (l.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]] |>.map List.reverse)
  
  -- Helper lemmas for allSubseq properties
  have step_distrib (L1 L2 : List (List Int)) (x : Int) :
      let step := fun acc x => acc ++ acc.map (fun sub => x :: sub)
      step (L1 ++ L2) x = step L1 x ++ step L2 x := by
    simp [List.map_append, List.append_assoc]

  have fold_distrib (t : List Int) (L1 L2 : List (List Int)) :
      let step := fun acc x => acc ++ acc.map (fun sub => x :: sub)
      t.foldl step (L1 ++ L2) = t.foldl step L1 ++ t.foldl step L2 := by
    induction t generalizing L1 L2 <;> simp [*, step_distrib]

  have map_step_comm (t : List Int) (L : List (List Int)) (k : Int) :
      let step := fun acc x => acc ++ acc.map (fun sub => x :: sub)
      t.foldl step (L.map (· ++ [k])) = (t.foldl step L).map (· ++ [k]) := by
    induction t generalizing L <;> simp [*, step_distrib, List.map_append, List.map_map]

  have allSubseq_cons (h : Int) (t : List Int) : allSubseq (h :: t) = allSubseq t ++ (allSubseq t).map (h :: ·) := by
    simp [allSubseq]
    let step := fun (acc : List (List Int)) (x : Int) => acc ++ acc.map (fun sub => x :: sub)
    have : (h::t).foldl step [[]] = t.foldl step [[]] ++ t.foldl step [[h]] := by
      simp [step]; rw [fold_distrib]; rfl
    rw [this, List.map_append]
    congr 1
    have : [h] = [[]].map (· ++ [h]) := rfl
    rw [this, map_step_comm, List.map_map]
    simp [List.reverse_append]

  -- The specification predicate relative to a lower bound
  let cond (prev : Option Int) (s : List Int) := s.Pairwise (· < ·) ∧ s.all (fun x => prev.map (· < x) |>.getD true)
  
  -- Prove that helper computes the max length of subsequences satisfying cond
  have claim (l : List Int) (prev : Option Int) :
      let lenses := (allSubseq l).filter (cond prev) |>.map List.length
      lenses.contains (helper l prev) ∧ lenses.all (· ≤ helper l prev) := by
    induction l generalizing prev with
    | nil =>
      simp [helper, allSubseq, cond]
    | cons h t ih =>
      rw [h_eq] at ih ⊢; simp [helper]
      -- Use the recursive structure of allSubseq
      rw [allSubseq_cons, List.filter_append, List.map_append]
      
      -- Analyze "Without Take" branch (subsequences from t)
      have h_skip := ih prev
      
      -- Analyze "With Take" branch (h :: s where s from t)
      -- Condition for h :: s: h > prev AND s is valid w.r.t h
      have cond_cons : ∀ s, cond prev (h :: s) ↔ (prev.map (· < h) |>.getD true) ∧ cond (some h) s := by
        intro s
        simp [cond, List.pairwise_cons, List.all_cons]
        constructor
        · intro ⟨⟨h_lt_head, pair⟩, ⟨prev_lt_h, prev_lt_s⟩⟩
          exact ⟨prev_lt_h, pair, ⟨List.rel_of_pairwise_cons h_lt_head, prev_lt_s⟩⟩ 
        · intro ⟨prev_lt_h, pair, h_lt_s, _⟩
          refine ⟨⟨fun x hx => h_lt_s.1 x hx, pair⟩, ⟨prev_lt_h, ?_⟩⟩
          apply List.all_of_forall; intro x hx
          exact match prev with | none => True.intro | some p => Int.lt_trans prev_lt_h (h_lt_s.1 x hx)

      -- Case split on whether we can take h
      by_cases h_lt : (prev.map (· < h) |>.getD true)
      · simp [h_lt, cond_cons]
        have h_take := ih (some h)
        
        -- Logic to combine results
        rw [←List.map_filter, ←List.map_map] at h_take ⊢
        obtain ⟨has_skip, all_skip⟩ := h_skip
        obtain ⟨has_take, all_take⟩ := h_take
        
        simp [List.contains_append, List.all_append]
        constructor
        · -- Check if result is contained in lenses
          by_cases cmp : (1 + helper t (some h) > helper t prev)
          · rw [if_pos cmp]; right
            rw [List.map_map]; simp
            exact has_take
          · rw [if_neg cmp]; left; exact has_skip
        · -- Check if result is >= all other lengths
          rw [if_pos rfl] -- let binding logic
          intro x
          simp
          intro h_or
          rcases h_or with h_s | h_t
          · exact Nat.le_trans (all_skip _ h_s) (Nat.le_max_right _ _)
          · rw [List.map_map] at h_t; simp at h_t
            rcases h_t with ⟨a, ha, rfl⟩
            apply Nat.le_trans (Nat.add_le_add_left (all_take _ ha) 1) (Nat.le_max_left _ _)

      · -- Cannot take h
        simp [h_lt, cond_cons]
        -- take_lens is empty because filter condition is false
        simp at h_skip
        constructor
        · simp; left; exact h_skip.1
        · simp; exact h_skip.2

  rw [h_eq]
  exact claim nums none
  -- !benchmark @end proof
