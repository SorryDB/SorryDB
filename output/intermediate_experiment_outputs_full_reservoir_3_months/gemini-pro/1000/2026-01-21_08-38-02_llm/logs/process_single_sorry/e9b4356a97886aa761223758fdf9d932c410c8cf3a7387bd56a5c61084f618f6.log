  let rec H (l : List Int) (prev : Option Int) : Nat :=
    match l with
    | [] => 0
    | h :: t =>
        let canTake := match prev with | none => true | some p => p < h
        let withTake := if canTake then 1 + H t (some h) else 0
        let withoutTake := H t prev
        max2 withTake withoutTake

