  -- Define the set of valid subsequences: sorted and elements > prev
  let valid (s : List Int) (prev : Option Int) : Prop :=
    s.Pairwise (· < ·) ∧ ∀ x ∈ s, prev.all (· < x)

  -- Define the max length of such a subsequence from a list l
  let max_len (l : List Int) (prev : Option Int) : Nat :=
    (l.sublists.filter (valid · prev)).map List.length |>.max?.getD 0

  -- Prove that the implementation `helper` computes `max_len`
