theorem longestIncreasingSubsequence_spec_satisfied (nums: List Int) (h_precond : longestIncreasingSubsequence_precond (nums)) :
    longestIncreasingSubsequence_postcond (nums) (longestIncreasingSubsequence (nums) h_precond) h_precond := by
  -- Definitions to mirror the postcondition structure
  let S (l : List Int) := (l.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse
  let Good (prev : Option Int) (l : List Int) : Bool := 
    l.Pairwise (· < ·) ∧ match prev, l with | some p, h::_ => p < h | _, _ => true
  
  -- Structural lemma for S
  have S_cons : ∀ x xs, S (x :: xs) = S xs ++ (S xs).map (x :: ·) := by
    intro x xs; simp [S];
    let f := fun (acc : List (List Int)) x => acc ++ acc.map (x :: ·)
    have : ∀ l A B, l.foldl f (A ++ B) = l.foldl f A ++ l.foldl f B := by
      intro l; induction l with | nil => simp | cons y ys ih => intros; simp [f, List.map_append]; rw [←List.append_assoc, ih]; simp [List.append_assoc]
    rw [this]; simp [List.map_append]

  -- The set of lengths of valid subsequences
  let L (l : List Int) (prev : Option Int) := ((S l).filter (Good prev)).map List.length

  -- Properties of foldl max
  have fold_max_assoc : ∀ (l : List Nat) a, l.foldl max a = max a (l.foldl max 0) := by
    intro l; induction l with | nil => simp | cons y ys ih => intro a; simp [ih]; apply Nat.max_assoc
  
  have fold_max_map_succ : ∀ (l : List Nat), l ≠ [] → (l.map (· + 1)).foldl max 0 = 1 + l.foldl max 0 := by
    intro l hl; induction l with | nil => contradiction | cons y ys ih =>
      simp; cases ys with
      | nil => simp
      | cons z zs => rw [ih (by simp), fold_max_assoc (z::zs)]; simp [Nat.add_max_add_left]

  -- Equivalence between helper and computing max length directly
  have helper_eq : ∀ l prev, helper l prev = (L l prev).foldl max 0 := by
    intro l; induction l with
    | nil => simp [helper, L, S, Good]
    | cons h t ih =>
      intro prev; simp [helper, max2]; rw [ih, ih]; simp [L, S_cons]
      rw [List.filter_append, List.map_append, List.foldl_append, fold_max_assoc]
      split_ifs with h_cond
      · rw [List.filter_map, List.map_map]
        have eq_good : ∀ x, Good prev (h :: x) ↔ Good (some h) x := by
          intro x; simp [Good]; cases prev <;> simp_all [h_cond]
        simp [eq_good]
        -- Prove L t (some h) is not empty (contains 0)
        have : 0 ∈ L t (some h) := by
           have : [] ∈ S t := by induction t <;> simp_all [S_cons]; simp [S]
           have : Good (some h) [] := by simp [Good]
           simp [L]; apply List.mem_map_of_mem; rw [List.mem_filter]; exact ⟨by assumption, this⟩
        rw [fold_max_map_succ _ (List.ne_nil_of_mem this)]
        rw [Nat.max_comm]
      · have : filter (Good prev) (map (h :: ·) (S t)) = [] := by
           rw [List.filter_eq_nil]; intro x; simp [Good]; cases prev <;> simp_all [h_cond]
        simp [this]

  -- Final proof using the properties of max
  rw [helper_eq]
  let l_res := L nums none
  have l_has_zero : 0 ∈ l_res := by
    have : [] ∈ S nums := by induction nums <;> simp_all [S_cons]; simp [S]
    simp [L]; apply List.mem_map_of_mem; rw [List.mem_filter]; exact ⟨by assumption, by simp [Good]⟩
  
  refine ⟨?_, ?_⟩
  · -- contains
    have : l_res.foldl max 0 = 0 ∨ l_res.foldl max 0 ∈ l_res := by
      generalize l_res = l; generalize 0 = a
      induction l generalizing a with | nil => left; rfl | cons y ys ih =>
         rcases ih (max a y) with h|h
         · rw [h]; simp [max]; split_ifs; left; rfl; right; left; rfl
         · right; right; exact h
    cases this with | inl h => rw [h]; exact l_has_zero | inr h => exact h
  · -- all <=
