theorem longestIncreasingSubsequence_spec_satisfied (nums: List Int) (h_precond : longestIncreasingSubsequence_precond (nums)) :
    longestIncreasingSubsequence_postcond (nums) (longestIncreasingSubsequence (nums) h_precond) h_precond := by
  -- Define the logical model of the helper function
  let rec LIS (lst : List Int) (prev : Option Int) : Nat :=
    match lst with
    | [] => 0
    | h :: t =>
        let canTake := if prev = none then true else if prev.get! < h then true else false
        let withTake := if canTake then 1 + LIS t (some h) else 0
        let withoutTake := LIS t prev
        if withTake > withoutTake then withTake else withoutTake

  -- Prove the code computes LIS
  have code_eq : longestIncreasingSubsequence nums h_precond = LIS nums none := by
    rw [longestIncreasingSubsequence]
    simp only
    -- The let rec helper is structurally identical to LIS
    -- We prove equality by induction on nums
    let rec helper_eq (l : List Int) (p : Option Int) : 
      (let rec helper (lst : List Int) (prev : Option Int) : Nat :=
        match lst with
        | [] => 0
        | h :: t =>
            let canTake : Bool := if prev = none then true else if prev.get! < h then true else false
            let withTake : Nat := if canTake then 1 + helper t (some h) else 0
            let withoutTake : Nat := helper t prev
            if withTake > withoutTake then withTake else withoutTake
       helper l p) = LIS l p := by
      match l with
      | [] => rfl
      | h :: t =>
        simp [LIS]
        congr 1
        · congr 1; funext; apply helper_eq
        · apply helper_eq
    apply helper_eq

  rw [code_eq]
  
  -- Define validity of a subsequence
  let Valid (prev : Option Int) (s : List Int) : Prop :=
    s.Pairwise (· < ·) ∧ match prev, s with
    | some p, h::_ => p < h
    | _, _ => True

  -- Basic lemmas about Valid
  have valid_cons : ∀ {p h t}, Valid (some h) t → (match p with | none => true | some x => x < h) → Valid p (h :: t) := by
    intro p h t hv cond; simp [Valid] at *
    constructor; 
    · constructor; cases t <;> simp [Valid] at hv <;> try apply hv.2; apply hv.1
    · cases p <;> simp at * <;> exact cond
  
  have valid_sub : ∀ {p s}, Valid p s → s.Pairwise (· < ·) := by
    intro p s h; cases p <;> simp [Valid] at h <;> apply h.1

  -- Correctness of LIS: Reachability and Upper Bound
  have LIS_correct : ∀ l prev, 
    (∃ s <+ l, Valid prev s ∧ s.length = LIS l prev) ∧ 
    (∀ s <+ l, Valid prev s → s.length ≤ LIS l prev) := by
    intro l
    induction l with
    | nil => 
      intro prev; simp [LIS, Valid]; constructor
      · use []; simp
      · intro s hs _; cases s; simp; contradiction
    | cons h t ih =>
      intro prev
      simp [LIS]
      let canTake := if prev = none then true else if prev.get! < h then true else false
      have h_can : canTake = true ↔ match prev with | none => true | some p => p < h := by
        cases prev <;> simp; rfl
      
      have ih1 := ih (some h)
      have ih2 := ih prev
      constructor
      · by_cases hc : canTake
        · simp [hc]
          obtain ⟨s1, hs1_sub, hs1_valid, hs1_len⟩ := ih1.1
          obtain ⟨s2, hs2_sub, hs2_valid, hs2_len⟩ := ih2.1
          by_cases hcmp : 1 + LIS t (some h) > LIS t prev
          · rw [if_pos hcmp]
            use h :: s1
            constructor; apply List.Sublist.cons_cons; exact hs1_sub
            constructor; apply valid_cons hs1_valid; rw [←h_can]; exact hc
            simp [hs1_len]
          · rw [if_neg hcmp]; use s2
            constructor; apply List.Sublist.cons; exact hs2_sub
            constructor; exact hs2_valid
            exact hs2_len
        · simp [hc]
          obtain ⟨s2, hs2_sub, hs2_valid, hs2_len⟩ := ih2.1
          use s2
          constructor; apply List.Sublist.cons; exact hs2_sub
          constructor; exact hs2_valid; exact hs2_len
      · intro s hs hv
        have sub_cases := List.sublist_cons_iff.mp hs
        cases sub_cases with
        | inl h_eq => 
          obtain ⟨rfl, hsub⟩ := h_eq
          have v_xs : Valid (some h) s.tail := by
            simp [Valid] at hv; cases s <;> simp at *; try exact hv.1.1
            case cons => exact hv.1
          have h_take : canTake = true := by
            rw [h_can]; cases prev; simp; simp [Valid] at hv; exact hv.2
            case some p => simp [Valid] at hv; exact hv.2
          simp [h_take]
          have u := ih1.2 s.tail hsub v_xs
          apply le_trans (Nat.add_le_add_left u 1)
          apply Nat.le_max_left
        | inr h_skip =>
          have u := ih2.2 s h_skip hv
          apply le_trans u
          apply Nat.le_max_right

  -- Connection between allSubseq and List.Sublist
  have subseq_spec : ∀ l s, s ∈ (l.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse ↔ s <+ l := by
    intro l s
    suffices s.reverse ∈ l.foldl (fun acc x => acc ++ acc.map (x :: ·)) [[]] ↔ s.reverse <+ l by
      rw [List.mem_map]; constructor
      · rintro ⟨a, ha, rfl⟩; rw [this] at ha; simp [ha]
      · intro h; use s.reverse; rw [this]; simp [h]
    let f := fun (acc : List (List Int)) (x : Int) => acc ++ acc.map (x :: ·)
    have step : ∀ xs x u, u ∈ f xs x ↔ u ∈ xs ∨ ∃ t, t ∈ xs ∧ u = x :: t := by
       intros; simp [f]; constructor
       · intro h; rw [List.mem_append] at h; cases h <;> simp [*] at *
         right; use u.tail; simp [*]
       · rintro (h | ⟨t, ht, rfl⟩) <;> simp [*]
    
    induction l using List.reverseRecOn generalizing s with
    | nil => simp; rfl
    | append_singleton xs x ih =>
      simp [List.foldl_append]; rw [step, ih, ih]
      rw [List.sublist_append_iff]
      constructor
      · rintro (h | ⟨t, ht, rfl⟩); left; exact h; right; use t.reverse; simp [ht]
      · rintro (h | ⟨t, ht, heq⟩); left; exact h; right; use t.reverse; simp [ht, heq]

  -- Final proof using correctness and subseq_spec
  obtain ⟨s, hs_sub, hs_valid, hs_len⟩ := (LIS_correct nums none).1
  rw [longestIncreasingSubsequence_postcond]
  simp only
  constructor
  · apply List.mem_map_of_mem
    rw [List.mem_filter]
    constructor; rw [subseq_spec]; exact hs_sub; exact valid_sub hs_valid
  · rw [List.all_eq_true]
    intro len hlen
    rw [List.mem_map] at hlen
    obtain ⟨sub, hsub, rfl⟩ := hlen
    rw [List.mem_filter] at hsub
    obtain ⟨h_in_all, h_inc⟩ := hsub
    rw [subseq_spec] at h_in_all
    have h_valid : Valid none sub := by simp [Valid, h_inc]
    exact (LIS_correct nums none).2 sub h_in_all h_valid
