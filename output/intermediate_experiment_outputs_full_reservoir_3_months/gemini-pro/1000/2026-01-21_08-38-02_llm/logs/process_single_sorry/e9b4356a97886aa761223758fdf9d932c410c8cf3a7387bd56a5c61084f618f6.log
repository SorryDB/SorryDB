      (∃ s <+ l, s.Pairwise (· < ·) ∧ (∀ x ∈ s, ∀ p, prev = some p → p < x) ∧ s.length = H l prev) ∧
      (∀ s <+ l, s.Pairwise (· < ·) → (∀ x ∈ s, ∀ p, prev = some p → p < x) → s.length ≤ H l prev) := by
