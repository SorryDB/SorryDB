      "\n        if withTake > withoutTake then withTake else withoutTake\n  \n  have h_eq : longestIncreasingSubsequence nums h_precond = helper nums none := by\n    simp [longestIncreasingSubsequence, longestIncreasingSubsequence_precond]\n    rfl\n\n  rw [h_eq]\n  \n  let Valid (p : Option Int) (l : List Int) := l.Pairwise (· < ·) ∧ ∀ x ∈ l, match p with | none => true | some v => v < x\n  \n  have h_alg : ∀ l p, (∃ s <+ l, Valid p s ∧ s.length = helper l p) ∧ (∀ s <+ l, Valid p s → s.length ≤ helper l p) := by\n    intro l\n    induction l generalizing p with\n    | nil => \n      intro p; simp [helper, Valid]; constructor\n      . exists []; simp\n      . intro s h; rw [List.sublist_nil] at h; subst s; simp\n    | cons x xs ih =>\n      intro p; simp [helper]; specialize ih p; rcases ih with ⟨⟨s_skip, hs_skip, hv_skip, hl_skip⟩, hopt_skip⟩\n      by_cases c : (match p with | none => true | some v => v < x)\n      . simp [c]\n        have ih_take := ih (some x)\n        rcases ih_take with ⟨⟨s_take, hs_take, hv_take, hl_take⟩, hopt_take⟩\n        by_cases hmax : (1 + s_take.length > s_skip.length)\n        . simp [hmax]; constructor\n          . exists (x :: s_take); refine ⟨List.Sublist.cons₂ _ hs_take, ?_, ?_⟩\n            . simp [Valid, c] at *; exact ⟨⟨hv_take.1, hv_take.2⟩, hl_take⟩\n            . simp; exact hl_take\n          . intro s hs hv\n            cases hs with\n            | cons _ hs' => apply le_trans (hopt_skip s hs' hv) (le_of_lt hmax)\n            | cons₂ _ hs' => \n              simp at hv; apply Nat.le_trans (Nat.add_le_add_left (hopt_take s hs' ⟨hv.1.1, hv.2⟩) 1) (le_of_eq (Eq.symm hl_take) ▸ le_refl _)\n        . simp [hmax]; constructor\n          . exists s_skip; exact ⟨List.Sublist.cons _ hs_skip, hv_skip, hl_skip⟩\n          . intro s hs hv\n            cases hs with\n            | cons _ hs' => apply hopt_skip s hs' hv\n            | cons₂ _ hs' => \n              simp at hv; have := Nat.add_le_add_left (hopt_take s hs' ⟨hv.1.1, hv.2