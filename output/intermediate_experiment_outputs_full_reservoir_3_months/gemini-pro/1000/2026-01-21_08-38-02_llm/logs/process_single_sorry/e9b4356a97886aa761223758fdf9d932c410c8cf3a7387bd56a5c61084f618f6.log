theorem longestIncreasingSubsequence_spec_satisfied (nums: List Int) (h_precond : longestIncreasingSubsequence_precond (nums)) :
    longestIncreasingSubsequence_postcond (nums) (longestIncreasingSubsequence (nums) h_precond) h_precond := by
  -- Unfold definitions
  dsimp [longestIncreasingSubsequence_postcond, longestIncreasingSubsequence]
  let helper := longestIncreasingSubsequence.helper

  -- 1. Helper returns the length of an existing increasing subsequence
  have h_ex : ∀ l prev, ∃ s, s <+ l ∧ s.Pairwise (· < ·) ∧ (∀ x ∈ s, prev.all (· < x)) ∧ s.length = helper l prev := by
    intro l
    induction l with
    | nil => intro prev; exists []; simp [helper]
    | cons x xs ih =>
      intro prev; simp [helper]
      by_cases h : prev.all (· < x)
      . simp [h]
        rcases ih (some x) with ⟨s1, h1s, h1i, h1b, h1l⟩
        rcases ih prev with ⟨s2, h2s, h2i, h2b, h2l⟩
        by_cases hm : 1 + helper xs (some x) > helper xs prev
        . simp [max, hm, h1l]
          exists x :: s1
          refine ⟨List.sublist_cons_of_sublist x h1s, List.pairwise_cons.mpr ⟨fun y hy => h1b y hy, h1i⟩, by simp [h1b, h], rfl⟩
        . simp [max, hm, h2l]
          exists s2
          refine ⟨List.Sublist.trans h2s (List.Sublist.cons x (List.Sublist.refl _)), h2i, h2b, rfl⟩
      . simp [h]
        rcases ih prev with ⟨s, hs, hi, hb, hl⟩
        exists s; exact ⟨List.Sublist.trans hs (List.Sublist.cons x (List.Sublist.refl _)), hi, hb, hl⟩

  -- 2. Helper result is an upper bound on length of any such subsequence
  have h_ub : ∀ l prev s, s <+ l → s.Pairwise (· < ·) → (∀ x ∈ s, prev.all (· < x)) → s.length ≤ helper l prev := by
    intro l; induction l with
    | nil => intro _ s h _ _; simp at h; subst h; simp [helper]
    | cons x xs ih =>
      intro prev s h hi hb; simp [helper]; cases s with
      | nil => apply Nat.zero_le
      | cons y ys =>
        cases h with
        | cons _ hs => apply le_max_of_le_right; exact ih prev (y::ys) hs hi hb
        | cons2 _ hs => 
          simp at hb; simp [hb.1]; apply le_max_of_le_left; apply Nat.add_le_add_left
          simp at hi; exact ih (some x) ys hs hi.2 hi.1

  -- 3. The generated allSubseq corresponds exactly to sublists
  let allSubseq := (nums.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse
  have h_all : ∀ s, s ∈ allSubseq ↔ s <+ nums := by
    suffices ∀ l, ((l.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse).Perm l.sublists by
      intro s; rw [List.mem_sublists]; exact List.Perm.mem_iff (this nums) s
    intro l; induction l using List.reverseRecOn with
    | nil => simp [List.sublists]
    | append_singleton xs x ih =>
      simp [List.foldl_append]
      rw [List.map_append]; apply List.Perm.append ih
      rw [List.map_map]
      -- Lemma: sublists (xs ++ [x]) ~ sublists xs ++ map (++ [x]) (sublists xs)
      -- The foldl logic generates: map (fun s => reverse (x :: s)) acc = map (fun s => reverse s ++ [x]) acc
      -- acc corresponds to sublists xs (reversed). So map reverse acc is sublists xs.
      -- So this term is map (++ [x]) (sublists xs).
      -- We need sublists (xs ++ [x]) ~ sublists xs ++ map (++ [x]) (sublists xs).
      -- Standard sublists recurrence is on head, but permutation holds for concat too.
      have h_sub_concat : (xs ++ [x]).sublists.Perm (xs.sublists ++ xs.sublists.map (· ++ [x])) := by
        induction xs with
        | nil => simp [List.sublists]
        | cons y ys h_ind =>
          simp [List.sublists, List.map_append]
          refine List.Perm.trans (List.Perm.append_congr_left (List.Perm.map _ h_ind)) ?_
          simp; apply List.Perm.trans (List.Perm.append_comm _ _)
          apply List.Perm.append_congr_left
          apply List.Perm.trans (List.Perm.append_comm _ _)
          rw [List.append_assoc]; apply List.Perm.append_congr_left
          apply List.Perm.of_eq; simp [List.map_map]
      refine List.Perm.trans ?_ (List.Perm.symm h_sub_concat)
      apply List.Perm.append_congr_left
      have h_perm := List.Perm.map (fun l => l ++ [x]) (List.Perm.symm ih)
      simp [List.map_map] at h_perm; convert h_perm

  -- 4. Conclusion
  rcases h_ex nums none with ⟨s, hs, hi, hb, hl⟩
  constructor
  . rw [hl]; apply List.mem_map_of_mem; apply List.mem_filter_of_mem
    . rw [h_all]; exact hs
    . exact hi
  . simp; intro len s' hs' hi' heq; subst heq; apply h_ub nums none s'
    . rw [←h_all]; exact hs'
    . exact hi'
    . simp
