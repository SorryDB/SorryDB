theorem longestIncreasingSubsequence_spec_satisfied (nums: List Int) (h_precond : longestIncreasingSubsequence_precond (nums)) :
    longestIncreasingSubsequence_postcond (nums) (longestIncreasingSubsequence (nums) h_precond) h_precond := by
  let rec helper (lst : List Int) (prev : Option Int) : Nat :=
    match lst with
    | [] => 0
    | h :: t =>
        let canTake := match prev with | none => true | some p => p < h
        let withTake := if canTake then 1 + helper t (some h) else 0
        let withoutTake := helper t prev
        if withTake > withoutTake then withTake else withoutTake
  have h_eq : longestIncreasingSubsequence nums h_precond = helper nums none := rfl
  rw [h_eq]
  
  let valid (l : List Int) (prev : Option Int) (s : List Int) := s <+ l ∧ s.Pairwise (· < ·) ∧ ∀ x ∈ s, prev.all (· < x)
  
  have ub : ∀ l prev s, valid l prev s → s.length ≤ helper l prev := by
    intro l; induction l with
    | nil => intro p s h; cases h.1; exact Nat.zero_le _
    | cons h t ih =>
      intro p s ⟨hsub, hinc, hbound⟩
      rw [List.sublist_cons_iff] at hsub
      simp [helper]; split <;> try simp
      next ct wt nwt =>
        rcases hsub with hs|⟨s', rfl, hs⟩
        · apply Nat.le_trans (ih p s ⟨hs, hinc, hbound⟩); exact Nat.le_max_right _ _
        · have htake : p.all (· < h) := hbound h (Or.inl rfl)
          have : wt = 1 + helper t (some h) := by
             simp [ct] at *; if hct : p.all (· < h) then simp [hct] else contradiction
          rw [this]
          apply Nat.le_trans (Nat.succ_le_succ _) (Nat.le_max_left _ _)
          apply ih (some h) s' ⟨hs, (List.pairwise_cons.1 hinc).2, fun x hx => (List.pairwise_cons.1 hinc).1 x hx⟩

  have ex : ∀ l prev, ∃ s, valid l prev s ∧ s.length = helper l prev := by
    intro l; induction l with
    | nil => intro p; exists []; simp [valid, helper]
    | cons h t ih =>
      intro p; simp [helper]
      let c := p.all (· < h)
      let wt := if c then 1 + helper t (some h) else 0
      let nwt := helper t p
      split
      next _ => 
        have hc : c := by 
           by_contra nc; simp [nc] at wt; simp [wt] at *; 
           cases nwt <;> contradiction
        simp [hc] at wt
        rcases ih (some h) with ⟨s', ⟨S, I, B⟩, L⟩
        refine ⟨h::s', ⟨List.Sublist.cons_cons _ _ S, List.pairwise_cons.2 ⟨fun x mx => B x mx, I⟩, ?_⟩, ?_⟩
        · intro x hx; cases hx; exact hc; exact Int.lt_trans hc (B x (by assumption))
        · simp; rw [L]; assumption
      next _ => 
        rcases ih p with ⟨s, ⟨S, I, B⟩, L⟩
        refine ⟨s, ⟨List.Sublist.cons _ _ S, I, B⟩, L⟩

  unfold longestIncreasingSubsequence_postcond
  let allSubseq := (nums.foldl fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]] |>.map List.reverse
  
  have mem_iff : ∀ s, s ∈ allSubseq ↔ s <+ nums := by
    let f (acc : List (List Int)) (x : Int) := acc ++ acc.map (fun sub => x :: sub)
    have : ∀ l p z, (∀ s, s ∈ z ↔ s.reverse <+ p) → ∀ s, s ∈ l.foldl f z ↔ s.reverse <+ p ++ l := by
      intro l; induction l with
      | nil => intro p z h s; simp; rw [h]; simp
      | cons h t ih => 
         intro p z hz s
         simp; rw [ih (p ++ [h]) (z ++ z.map (fun sub => h :: sub))]; simp
         intro s; rw [List.mem_append, List.mem_map]; constructor
         · rintro (h1|⟨a,h1,rfl⟩)
           · apply List.Sublist.trans (hz s |>.1 h1) (List.Sublist.sublist_append_left _ _)
           · rw [List.reverse_cons]; apply List.Sublist.append_right; exact (hz a |>.1 h1)
         · intro hsub; rw [List.sublist_append_iff] at hsub
           rcases hsub with ⟨l1, l2, h1, h2, rfl⟩
           cases l2 with
           | nil => simp; left; apply (hz l1).2 h1
           | cons x xs => 
             cases xs; simp at h2; subst h2
             right; use l1.reverse; rw [List.reverse_reverse]; exact ⟨(hz l1).2 h1, rfl⟩
             cases ‹_::_›; contradiction
    intro s; rw [this nums [] [[]]]; simp; simp; intro s; rw [List.sublist_nil]; simp
    
  rcases ex nums none with ⟨s, ⟨hsub, hinc, _⟩, hlen⟩
  constructor
  · rw [List.mem_map]; use s; constructor
    · rw [List.mem_filter]; constructor
      · rw [mem_iff]; exact hsub
      · exact hinc
    · exact hlen
  · intro x hx
    rw [List.mem_map] at hx; rcases hx with ⟨l, hl, rfl⟩
    rw [List.mem_filter] at hl
    apply ub nums none l ⟨mem_iff _ |>.1 hl.1, hl.2, fun _ _ => by trivial⟩
