        -- The "with take" part
        let valid_take (s : List Int) := s.Pairwise (· < ·) ∧ ∀ (x : ℤ), x ∈ s → (some h).all (· < x)
        let max_take := (t.sublists.filter valid_take).map List.length |>.max?.getD 0
        
