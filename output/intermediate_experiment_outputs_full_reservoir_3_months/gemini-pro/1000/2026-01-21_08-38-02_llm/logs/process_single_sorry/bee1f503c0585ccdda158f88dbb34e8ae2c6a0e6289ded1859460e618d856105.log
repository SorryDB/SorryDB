    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff]
  rintro ⟨p, hp⟩
  rw [hE, add_assoc, add_left_cancel_iff] at hp
  let f : Fin 8 →+ ZMod 2 :=
  { toFun := fun x => x.val
    map_zero' := rfl
    map_add' := fun x y => by
      simp only [Fin.val_add]
      rw [Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 8), Nat.add_mod]
      rfl }
  apply_fun f at hp
  simp only [map_sum, AddMonoidHom.coe_mk, ZeroHom.coe_mk] at hp
  have h_term : ∀ i, f (p i) = 1 := fun i => by
    rcases Int.units_eq_one_or (p i) with h | h <;> rw [h] <;> rfl
  simp only [h_term, Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_one] at hp
  have h_odd : ((2 * n - 1 : ℕ) : ZMod 2) = 1 := by
    rw [Nat.cast_sub (by linarith), Nat.cast_mul, Nat.cast_two, zero_mul, zero_sub]
    rfl
  rw [h_odd] at hp
  exact one_ne_zero hp
