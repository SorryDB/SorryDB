      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_left_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 := {\n    toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      rw [Fin.val_add]\n      generalize x.val + y.val = s\n      rw [← Nat.mod_add_div s 8, Nat.cast_add, Nat.cast_mul,\n          show (8 : ZMod 2) = 0 from rfl, zero_mul, add_zero] }\n  apply_fun f at hp\n  simp only [map_sum, AddMonoidHom.coe_mk, ZeroHom.coe_mk] at hp\n  rw [show f 4 = 0 from rfl] at hp\n  have : ∀ i, f (p i) = 1 := fun i => by\n    rcases Int.units_eq_one_or (p i) with h | h <;> rw [h] <;> rfl\n  simp [this, Finset.sum_const, nsmul_eq_mul] at hp\n  rw [Nat.cast_sub hn, Nat.cast_one] at hp\n  norm_num at hp",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_left_cancel_iff] at hp\n  let f : Fin 8 →+ Fin 2 := {\n    toFun := fun x => x.val,\n    map_zero' := rfl,\n    map_add' := fun x y => by\n      simp [Fin.val_add]\n      rw [Nat.mod_mod_of_dvd _ (by norm_num)]\n      rfl }\n  apply_fun f at hp\n  rw [map_sum] at hp\n  have h_odd : ∀ i, f (p i) = 1 := by\n    intro i\n    rcases Int.units_eq_one_or (p i) with rfl | rfl <;> rfl\n  simp [h_odd, Finset.card_univ] at hp\n  have h_le : 1 ≤ 2 * n := Nat.mul_le_mul_left 2 hn\n  rw [Nat.cast_sub h_le] at hp\n  simp at hp\n  contradiction",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  dsimp only at hp\n  rw [hE, add_right_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 := ZMod.castHom (show 2 ∣ 8 by norm_num) (Fin 8)\n  have := congr_arg f hp\n  rw [map_sum, map_natCast] at this\n  simp only [ZMod.castHom_apply] at this\n  have h_term : ∀ x, ((p x : Fin 8) : ZMod 2) = 1 := by\n    intro x\n    cases Int.units_eq_one_or (p x) with\n    | inl h => rw [h]; simp; rfl\n    | inr h => rw [h]; simp; rfl\n  simp [h_term] at this\n  rw [Nat.cast_sub (Nat.succ_le_of_lt (Nat.mul_pos (by norm_num) hn))] at this\n  simp at this\n  contradiction",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_left_cancel_iff] at hp\n  apply_fun ZMod.castHom (show 2 ∣ 8 by norm_num) (ZMod 2) at hp\n  rw [map_sum, map_natCast] at hp\n  have : ∀ i, ZMod.castHom (show 2 ∣ 8 by norm_num) (ZMod 2) (p i) = 1 := by\n    intro i\n    rcases Int.units_eq_one_or_neg_one (p i) with h | h <;> simp [h] <;> norm_num\n  rw [Finset.sum_congr rfl (fun i _ => this i)] at hp\n  simp only [Finset.sum_const, Finset.card_fin, nsmul_eq_mul] at hp\n  rw [Nat.cast_sub hn] at hp\n  norm_num at hp\n  exact hp",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_right_cancel_iff] at hp\n  let f : Fin 8 →+ Fin 2 :=\n    { toFun := fun x => ⟨x.val % 2, Nat.mod_lt _ (by norm_num)⟩\n      map_zero' := rfl\n      map_add' := fun x y => Fin.ext (by\n        simp [Fin.add_def, Nat.add_mod]\n        exact Nat.mod_mod_of_dvd _ (by norm_num)) }\n  apply_fun f at hp\n  simp only [map_sum] at hp\n  have h_one (u : ℤˣ) : f u = 1 := by\n    rcases Int.units_eq_one_or u with rfl | rfl <;> rfl\n  simp only [h_one, Finset.sum_const, Finset.card_univ, Fintype.card_fin, nsmul_eq_mul, mul_one] at hp\n  have h_odd : ((2 * n - 1 : ℕ) : Fin 2) = 1 := by\n    apply Fin.ext\n    cases n with\n    | zero => contradiction\n    | succ n =>\n      simp [Nat.succ_mul, Nat.add_sub_assoc]\n      rw [Nat.add_mod]\n      norm_num\n  rw [h_odd] at hp\n  have h_four : f 4 = 0 := rfl\n  rw [h_four] at hp\n  contradiction",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  simp only [hE, add_right_cancel_iff] at hp\n  let f := ZMod.castHom (show 2 ∣ 8 by norm_num) (ZMod 2)\n  apply_fun f at hp\n  rw [map_sum, map_natCast] at hp\n  have : ∀ i, f (p i) = 1 := fun i ↦ by\n    cases Int.units_eq_one_or (p i) with\n    | inl h => simp [h]\n    | inr h => simp [h]\n  simp only [this, Finset.sum_const, Finset.card_univ, Fintype.card_fin, nsmul_eq_mul, mul_one] at hp\n  rw [Nat.cast_sub (Nat.mul_pos (by norm_num) hn)] at hp\n  simp at hp\n  contradiction",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  simp only [hE, add_right_cancel_iff] at hp\n  let π : Fin 8 →+ ZMod 2 :=\n  { toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      simp only [Fin.val_add]\n      rw [Nat.mod_eq_sub_mul_div, Nat.cast_sub (Nat.mul_div_le _ _)]\n      simp }\n  apply_fun π at hp\n  simp only [map_sum, AddMonoidHom.coe_mk, ZeroHom.coe_mk] at hp\n  have h4 : π 4 = 0 := rfl\n  rw [h4] at hp\n  have h_odd (i) : π (p i) = 1 := by\n    rcases Int.units_eq_one_or (p i) with h | h <;> rw [h] <;> rfl\n  simp only [h_odd, Finset.sum_const, Finset.card_fin, nsmul_eq_mul] at hp\n  have h_card : ((2 * n - 1 : ℕ) : ZMod 2) = 1 := by\n    rw [Nat.cast_sub (Nat.succ_le_of_lt (Nat.mul_pos (by norm_num) hn))]\n    simp [Nat.cast_mul, Nat.cast_two]\n  rw [h_card, one_mul] at hp\n  exact one_ne_zero hp",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_right_cancel_iff] at hp\n  apply congr_arg (fun x : Fin 8 => x.val % 2) at hp\n  rw [Fin.val_sum, Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 8), Nat.sum_mod] at hp\n  have h_odd : ∀ i, (p i : Fin 8).val % 2 = 1 := by\n    intro i\n    rcases Int.units_eq_one_or_neg_one (p i) with h | h <;> simp [h] <;> rfl\n  simp [h_odd, Fintype.card_fin] at hp\n  omega",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_left_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 := {\n    toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      rw [Fin.val_add, Nat.add_mod, Nat.mod_mod_of_dvd _ (by norm_num)]\n      rfl }\n  apply_fun f at hp\n  simp only [map_sum, AddMonoidHom.coe_mk, ZeroHom.coe_mk] at hp\n  have h_val : ∀ i, f (p i) = 1 := fun i => by\n    cases Int.units_eq_one_or (p i) with\n    | inl h => rw [h]; rfl\n    | inr h => rw [h]; rfl\n  simp [h_val, Finset.card_fin] at hp\n  have h_odd : ((2 * n - 1 : ℕ) : ZMod 2) = 1 := by\n    rw [Nat.cast_sub (by linarith), Nat.cast_mul, Nat.cast_two, zero_mul, zero_sub]\n    exact neg_one_eq_one_of_char_two rfl\n  rw [h_odd] at hp\n  exact one_ne_zero hp",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  dsimp at hp\n  rw [hE, add_left_cancel_iff] at hp\n  let g : Fin 8 →+ ZMod 2 := {\n    toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      simp only [Fin.val_add, ZMod.nat_cast_mod_of_dvd (by norm_num : 2 ∣ 8), Nat.cast_add] }\n  apply_fun g at hp\n  simp only [map_sum] at hp\n  have h_step : ∀ i, g (p i) = 1 := fun i => by\n    rcases Int.units_eq_one_or (p i) with h | h <;> simp [h, g]\n  simp only [h_step, Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_one] at hp\n  rw [show g 4 = 0 from rfl, ZMod.nat_cast_eq_zero_iff_dvd] at hp\n  have h_odd : Odd (2 * n - 1) := ⟨n - 1, by\n    rw [Nat.mul_sub_left_distrib, mul_one, Nat.sub_add_cancel (Nat.le_mul_of_pos_right 2 hn)]⟩\n  exact (Nat.even_iff_not_odd.mp hp) h_odd",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  simp only [hE, add_right_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 :=\n  { toFun := fun x ↦ x.val\n    map_zero' := rfl\n    map_add' := fun x y ↦ by rw [Fin.val_add]; exact Nat.mod_mod_of_dvd _ (by norm_num) }\n  apply_fun f at hp\n  simp only [map_sum, Finset.sum_const, Finset.card_fin, nsmul_eq_mul] at hp\n  have h_unit : ∀ x : ℤˣ, f x = 1 := by\n    rintro x; rcases Int.units_eq_one_or x with rfl | rfl <;> rfl\n  simp only [h_unit, Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_one] at hp\n  rw [Nat.cast_sub (by omega)] at hp\n  simp at hp",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  simp only [hE, add_left_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 :=\n    { toFun := fun x => x.val\n      map_zero' := rfl\n      map_add' := fun x y => by\n        apply ZMod.val_injective\n        simp [Fin.val_add, ZMod.val_nat_cast, Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 8)] }\n  apply_fun f at hp\n  simp only [map_sum, AddMonoidHom.coe_mk, ZeroHom.coe_mk] at hp\n  have h_one : ∀ i, f (p i) = 1 := fun i => by\n    cases Int.units_eq_one_or (p i) with | inl h => rw [h]; rfl | inr h => rw [h]; rfl\n  simp only [h_one, Finset.sum_const, Finset.card_fin, nsmul_eq_mul, Nat.cast_mul, Nat.cast_one,\n    mul_one] at hp\n  cases n with\n  | zero => contradiction\n  | succ n =>\n    rw [Nat.mul_succ, Nat.add_sub_assoc (by norm_num)] at hp\n    simp at hp",
      "\n  rw [ha_def, Fintype.card_eq_zero]\n  rintro ⟨p, hp⟩\n  rw [hE, add_right_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 := {\n    toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      simp only [Fin.add_def, ZMod.nat_cast_mod, Nat.cast_add]\n      rw [Nat.mod_mod_of_dvd _ (by norm_num)] }\n  apply_fun f at hp\n  simp only [map_sum, map_natCast] at hp\n  have h_one : ∀ i, f (p i) = 1 := by\n    intro i\n    cases Int.units_eq_one_or (p i) with\n    | inl h => simp [h, f]\n    | inr h => simp [h, f]; rfl\n  simp [h_one] at hp\n  rw [Nat.cast_sub (Nat.succ_le_of_lt (Nat.mul_pos (by norm_num) hn))] at hp\n  simp at hp",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_right_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 := {\n    toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      simp [ZMod.nat_cast_val, Fin.val_add]\n      rw [Nat.add_mod_of_dvd] <;> decide\n  }\n  apply_fun f at hp\n  rw [map_sum] at hp\n  have h_one : ∀ i, f (p i) = 1 := fun i => by\n    cases Int.units_eq_one_or_neg_one (p i) with\n    | inl h => rw [h]; rfl\n    | inr h => rw [h]; rfl\n  simp [h_one] at hp\n  have h4 : f 4 = 0 := rfl\n  rw [h4, Finset.sum_const, Finset.card_univ, Fintype.card_fin, nsmul_eq_mul, mul_one] at hp\n  rw [ZMod.nat_cast_zmod_eq_zero_iff_dvd] at hp\n  have : ¬ 2 ∣ 2 * n - 1 := by\n    rw [Nat.dvd_iff_mod_eq_zero, Nat.sub_mod_of_lt (by linarith)]\n    simp [Nat.mul_mod]\n  exact this hp",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_left_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 := {\n    toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      simp [Fin.add_def]\n      norm_cast\n      rw [Nat.add_mod, Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 8)]\n  }\n  apply_fun f at hp\n  rw [map_sum, show f 4 = 0 by rfl] at hp\n  have h_one : ∀ i, f (p i) = 1 := fun i => by\n    rcases Int.units_eq_one_or (p i) with h | h <;> rw [h] <;> rfl\n  simp only [h_one, Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_one] at hp\n  have h_le : 1 ≤ 2 * n := Nat.succ_le_of_lt (Nat.mul_pos (by norm_num) hn)\n  rw [Nat.cast_sub h_le, Nat.cast_mul, Nat.cast_two, zero_mul, zero_sub] at hp\n  rw [show (-1 : ZMod 2) = 1 by rfl] at hp\n  norm_num at hp",
      "\n  rw [ha_def, Fintype.card_eq_zero]\n  rintro ⟨p, hp⟩\n  rw [hE, add_right_cancel_iff] at hp\n  apply_fun ZMod.cast (h := show 2 ∣ 8 by norm_num) at hp\n  simp only [map_sum, ZMod.cast_intCast] at hp\n  have : ∀ i, (p i : ZMod 2) = 1 := fun i ↦ by\n    cases Int.units_eq_one_or_neg_one (p i) <;> simp_all\n  simp [this] at hp\n  rw [Nat.cast_sub] at hp\n  · revert hp; norm_num\n  · exact Nat.succ_le_of_lt (Nat.mul_pos (by norm_num) hn)",
      "\n  rw [ha_def, Fintype.card_eq_zero]\n  rintro ⟨p, hp⟩\n  let π : Fin 8 →+ ZMod 2 := {\n    toFun := fun x ↦ x.val,\n    map_zero' := rfl,\n    map_add' := fun x y ↦ by\n      simp [Fin.val_add]\n      rw [Nat.add_mod, Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 8)] }\n  apply_fun π at hp\n  rw [map_add, map_sum] at hp\n  have h1 : ∀ i, π (p i) = 1 := fun i ↦ by\n    rcases Int.units_eq_one_or_neg_one (p i) with rfl | rfl <;> rfl\n  simp [h1, Finset.card_fin] at hp\n  have h2 : ((2 * n - 1 : ℕ) : ZMod 2) = 1 := by\n    cases n with\n    | zero => contradiction\n    | succ n => simp [Nat.mul_succ, Nat.add_sub_assoc]\n  rw [h2, hE, map_add] at hp\n  revert hp\n  norm_num",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  simp only [hE, add_right_cancel_iff] at hp\n  let ϕ : Fin 8 →+ ZMod 2 :=\n    { toFun := fun x => x.val\n      map_zero' := rfl\n      map_add' := fun x y => by\n        simp only [Fin.val_add]\n        exact Nat.mod_mod_of_dvd _ (by norm_num) }\n  apply_fun ϕ at hp\n  rw [map_sum, show ϕ 4 = 0 from rfl] at hp\n  have h_one : ∀ i, ϕ (p i) = 1 := fun i => by\n    rcases Int.units_eq_one_or (p i) with h | h <;> { rw [h]; rfl }\n  simp only [h_one, Finset.sum_const, Finset.card_fin, nsmul_eq_mul, mul_one] at hp\n  rw [Nat.cast_sub, Nat.cast_mul] at hp\n  · norm_num at hp\n  · exact Nat.succ_le_of_lt (Nat.mul_pos (by norm_num) hn)",
      "\n  rw [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_right_cancel_iff] at hp\n  let f : Fin 8 →+ ZMod 2 := {\n    toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      simp [Fin.val_add, ZMod.nat_cast_mod_of_dvd (by norm_num : 2 ∣ 8)]\n  }\n  apply_fun f at hp\n  simp only [map_sum, AddMonoidHom.coe_mk, AddMonoidHom.toFun_eq_coe] at hp\n  have : ∀ i, f (p i) = 1 := by\n    intro i\n    rcases Int.units_eq_one_or (p i) with h | h <;> rw [h] <;> rfl\n  simp only [this, Finset.sum_const, Finset.card_univ, Fintype.card_fin, nsmul_eq_mul, mul_one] at hp\n  rw [Nat.cast_sub (Nat.succ_le_of_lt (Nat.mul_pos (by norm_num) hn))] at hp\n  simp at hp; contradiction",
      "\n  simp only [ha_def, Fintype.card_eq_zero_iff]\n  rintro ⟨p, hp⟩\n  rw [hE, add_left_cancel_iff] at hp\n  let ϕ : Fin 8 →+ ZMod 2 :=\n  { toFun := fun x => x.val\n    map_zero' := rfl\n    map_add' := fun x y => by\n      simp only [Fin.val_add]\n      rw [Nat.mod_mod_of_dvd] <;> norm_num }\n  apply_fun ϕ at hp\n  rw [map_sum] at hp\n  simp only [show ϕ 4 = 0 by rfl] at hp\n  have h_one : ∀ i, ϕ (p i) = 1 := fun i => by\n    cases Int.units_eq_one_or (p i) with\n    | inl h => rw [h]; rfl\n    | inr h => rw [h]; rfl\n  simp only [h_one, Finset.sum_const, Finset.card_univ, Fintype.card_fin, nsmul_eq_mul, mul_one] at hp\n  have h_odd : ((2 * n - 1 : ℕ) : ZMod 2) = 1 := by\n    rw [Nat.cast_sub (Nat.succ_le_of_lt (Nat.mul_pos (by norm_num) hn))]\n    simp\n  rw [h_odd] at hp\n  contradiction",
