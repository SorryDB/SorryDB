theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  let S := Set.range (fun x ↦ |f x|)
  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩
  have hS_ne : S.Nonempty := ⟨|f 0|, 0, rfl⟩
  let M := sSup S
  have hM_ge : ∀ x, |f x| ≤ M := fun x ↦ le_csSup hS_bdd (Set.mem_range_self x)
  have hM_pos : 0 < M := by
    refine lt_of_not_le fun h_le ↦ h₁ fun x ↦ ?_
    exact abs_eq_zero.mp (le_antisymm (le_trans (hM_ge x) h_le) (abs_nonneg _))
  intro y
  by_contra hg
  push_neg at hg
  have : M * |g y| ≤ M := by
    rw [mul_comm]
    refine csSup_le hS_ne ?_
    rintro _ ⟨x, rfl⟩
    calc |g y| * |f x| = |2 * f x * g y| / 2 := by
          rw [abs_mul, abs_mul, abs_of_nonneg (by norm_num : (0 : ℝ) ≤ 2)]; ring
      _ = |f (x + y) + f (x - y)| / 2 := by rw [h₀]
      _ ≤ (|f (x + y)| + |f (x - y)|) / 2 := by gcongr; exact abs_add _ _
      _ ≤ (M + M) / 2 := by gcongr; exact hM_ge _; exact hM_ge _
      _ = M := by ring
  exact hg.not_le ((mul_le_iff_le_one_right hM_pos).mp this)
