      "\n  let S := Set.range (abs ∘ f)\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have hS_non : S.Nonempty := ⟨|f 0|, 0, rfl⟩\n  let M := sSup S\n  have hM_pos : 0 < M := by\n    contrapose! h₁; ext x\n    exact abs_eq_zero.mp (le_antisymm (le_csSup hS_bdd ⟨x, rfl⟩ |>.trans h₁) (abs_nonneg _))\n  intro y\n  by_contra! hg\n  have h_le (x) : |f x| ≤ M / |g y| := by\n    rw [le_div_iff₀ (by linarith)]\n    calc |f x| * |g y|\n      _ = |2 * f x * g y| / 2 := by rw [abs_mul, abs_mul]; norm_num; ring\n      _ = |f (x + y) + f (x - y)| / 2 := by rw [h₀]\n      _ ≤ (|f (x + y)| + |f (x - y)|) / 2 := by gcongr; exact abs_add _ _\n      _ ≤ (M + M) / 2 := by gcongr; all_goals exact le_csSup hS_bdd ⟨_, rfl⟩\n      _ = M := by ring\n  have : M ≤ M / |g y| := csSup_le hS_non (by rintro _ ⟨x, rfl⟩; exact h_le x)\n  rw [le_div_iff₀ (by linarith)] at this\n  exact hg.not_le ((mul_le_mul_left hM_pos).mp (by rwa [mul_comm]))",
      "\n  intro y\n  by_contra h\n  push_neg at h\n  let S := Set.range (fun x ↦ |f x|)\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have hS_non : S.Nonempty := ⟨|f 0|, Set.mem_range_self 0⟩\n  let M := sSup S\n  have hM_pos : 0 < M := by\n    contrapose! h₁\n    intro x\n    exact abs_eq_zero.mp (le_antisymm (le_trans (le_csSup hS_bdd (Set.mem_range_self x)) h₁) (abs_nonneg _))\n  have h_ineq : ∀ x, |f x| * |g y| ≤ M := by\n    intro x\n    have h_sum : |2 * f x * g y| ≤ |f (x + y)| + |f (x - y)| := by\n      rw [← h₀]; exact abs_add _ _\n    rw [abs_mul, abs_mul] at h_sum\n    norm_num at h_sum\n    have h_le_M : ∀ z, |f z| ≤ M := fun z ↦ le_csSup hS_bdd (Set.mem_range_self z)\n    linarith [h_sum, h_le_M (x + y), h_le_M (x - y)]\n  have h_bound : M * |g y| ≤ M := by\n    apply csSup_le hS_non\n    rintro _ ⟨x, rfl⟩\n    rwa [le_div_iff' (lt_trans zero_lt_one h), mul_comm]\n  have : |g y| ≤ 1 := (mul_le_iff_le_one_right hM_pos).mp h_bound\n  linarith",
      "\n  intro y\n  let S := Set.range (abs ∘ f)\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have hS_ne : S.Nonempty := Set.range_nonempty _\n  let k := sSup S\n  have hk_pos : 0 < k := by\n    contrapose! h₁; intro x\n    exact abs_eq_zero.mp (le_antisymm (le_trans (le_csSup hS_bdd ⟨x, rfl⟩) h₁) (abs_nonneg _))\n  have h_bound : ∀ x, |f x| * |g y| ≤ k := by\n    intro x\n    have : |2 * f x * g y| ≤ k + k := by\n      rw [← h₀]\n      exact le_trans (abs_add _ _) (add_le_add (le_csSup hS_bdd ⟨_, rfl⟩) (le_csSup hS_bdd ⟨_, rfl⟩))\n    rw [abs_mul, abs_mul, abs_of_nonneg (by norm_num : (0:ℝ) ≤ 2)] at this\n    linarith\n  by_contra hc\n  push_neg at hc\n  have hk_div : k / |g y| < k := div_lt_self hk_pos hc\n  obtain ⟨_, ⟨x, rfl⟩, hx⟩ := exists_lt_of_lt_csSup hS_ne hk_div\n  rw [lt_div_iff (lt_trans zero_lt_one hc)] at hx\n  linarith [h_bound x]",
      "\n  by_contra h\n  push_neg at h\n  rcases h with ⟨y, hy⟩\n  let S := Set.range (abs ∘ f)\n  have bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have nonemp : S.Nonempty := Set.range_nonempty _\n  let M := sSup S\n  have M_pos : 0 < M := by\n    push_neg at h₁\n    rcases h₁ with ⟨x, hx⟩\n    exact lt_of_lt_of_le (abs_pos.mpr hx) (le_sSup bdd ⟨x, rfl⟩)\n  have key : ∀ x, |f x| * |g y| ≤ M := by\n    intro x\n    have : 2 * (|f x| * |g y|) ≤ 2 * M := by\n      rw [← mul_assoc, mul_comm 2, mul_assoc, ← abs_two, ← abs_mul, ← abs_mul, ← h₀]\n      apply le_trans (abs_add _ _)\n      have l1 := le_sSup bdd ⟨x + y, rfl⟩\n      have l2 := le_sSup bdd ⟨x - y, rfl⟩\n      linarith\n    linarith\n  have : M * |g y| ≤ M := by\n    rw [mul_comm]\n    apply sSup_le nonemp\n    rintro _ ⟨x, rfl⟩\n    exact key x\n  suffices |g y| ≤ 1 by linarith\n  refine (mul_le_mul_left M_pos).mp ?_\n  simpa using this",
      "\n  intro y\n  by_contra h\n  push_neg at h\n  let S := Set.range fun x ↦ |f x|\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  let M := sSup S\n  have hM_le : ∀ x, |f x| ≤ M := fun x ↦ le_csSup hS_bdd (Set.mem_range_self x)\n  have h_le : M ≤ M / |g y| := csSup_le ⟨|f 0|, Set.mem_range_self 0⟩ (fun _ ⟨x, rfl⟩ ↦ by\n    rw [le_div_iff (lt_trans zero_lt_one h)]\n    have : 2 * (|f x| * |g y|) ≤ 2 * M := calc\n      2 * (|f x| * |g y|) = |2 * f x * g y| := by rw [abs_mul, abs_mul, abs_two, mul_assoc]\n      _ = |f (x + y) + f (x - y)| := by rw [h₀]\n      _ ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n      _ ≤ M + M := add_le_add (hM_le _) (hM_le _)\n      _ = 2 * M := by ring\n    rwa [mul_le_mul_left (by norm_num : (0 : ℝ) < 2)] at this)\n  have hM_pos : 0 < M := by\n    push_neg at h₁; obtain ⟨x, hx⟩ := h₁\n    exact lt_of_lt_of_le (abs_pos.mpr hx) (hM_le x)\n  rw [le_div_iff (lt_trans zero_lt_one h), ← mul_one M] at h_le\n  exact not_le_of_lt h ((mul_le_mul_left hM_pos).mp h_le)",
      "\n  intro y\n  by_cases hgy : g y = 0\n  · rw [hgy, abs_zero]; exact zero_le_one\n  · let S := Set.range (abs ∘ f)\n    have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n    have hS_ne : S.Nonempty := ⟨|f 0|, Set.mem_range_self 0⟩\n    let M := sSup S\n    have hM_le : ∀ x, |f x| ≤ M := fun x ↦ le_csSup hS_bdd (Set.mem_range_self x)\n    have hM_pos : 0 < M := by\n      push_neg at h₁; rcases h₁ with ⟨x, hx⟩\n      exact lt_of_lt_of_le (abs_pos.mpr hx) (hM_le x)\n    have : M ≤ M / |g y| := by\n      apply csSup_le hS_ne\n      rintro _ ⟨x, rfl⟩\n      rw [le_div_iff₀' (abs_pos.mpr hgy)]\n      have : 2 * |f x| * |g y| ≤ 2 * M :=\n        calc 2 * |f x| * |g y|\n          _ = |2 * f x * g y| := by rw [abs_mul, abs_mul, abs_of_pos (by norm_num : (0 : ℝ) < 2)]; ring\n          _ = |f (x + y) + f (x - y)| := by rw [← h₀]\n          _ ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n          _ ≤ M + M := add_le_add (hM_le _) (hM_le _)\n          _ = 2 * M := by ring\n      linarith\n    rwa [le_div_iff₀' (abs_pos.mpr hgy), mul_comm, mul_le_iff_le_one_left hM_pos] at this",
      "\n  let S := Set.range (abs ∘ f)\n  have bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have nonemp : S.Nonempty := Set.range_nonempty _\n  let M := sSup S\n  have M_pos : 0 < M := by\n    obtain ⟨x, hfx⟩ := not_forall.mp h₁\n    exact lt_of_lt_of_le (abs_pos.mpr hfx) (le_csSup bdd (Set.mem_range_self x))\n  intro x\n  by_contra hg\n  push_neg at hg\n  have : M ≤ M / |g x| := csSup_le nonemp (by\n    rintro _ ⟨z, rfl⟩\n    rw [le_div_iff (lt_trans zero_lt_one hg)]\n    calc |f z| * |g x|\n      _ = |2 * f z * g x| / 2 := by rw [abs_mul, abs_mul, abs_of_nonneg (by norm_num)]; ring\n      _ = |f (z + x) + f (z - x)| / 2 := by rw [h₀]\n      _ ≤ (|f (z + x)| + |f (z - x)|) / 2 := by\n        apply div_le_div_of_le (by norm_num)\n        exact abs_add _ _\n      _ ≤ (M + M) / 2 := by\n        apply div_le_div_of_le (by norm_num)\n        apply add_le_add <;> apply le_csSup bdd (Set.mem_range_self _)\n      _ = M := by ring)\n  rw [le_div_iff (lt_trans zero_lt_one hg)] at this\n  conv_rhs at this => rw [← mul_one M]\n  have : |g x| ≤ 1 := (mul_le_mul_left M_pos).mp this\n  linarith",
      "\n  let S := Set.range (fun x => |f x|)\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have hS_ne : S.Nonempty := Set.range_nonempty _\n  let M := sSup S\n  have hM_pos : 0 < M := by\n    push_neg at h₁\n    rcases h₁ with ⟨x, hx⟩\n    exact lt_of_lt_of_le (abs_pos.mpr hx) (le_csSup hS_bdd (Set.mem_range_self x))\n  intro y\n  by_cases hg : g y = 0\n  · rw [hg, abs_zero]; exact zero_le_one\n  · have h_le : ∀ x, |f x| ≤ M / |g y| := by\n      intro x\n      have : 2 * |f x| * |g y| ≤ 2 * M := by\n        calc\n          2 * |f x| * |g y| = |2 * f x * g y| := by rw [abs_mul, abs_mul, abs_of_nonneg (by norm_num)]; ring\n          _ = |f (x + y) + f (x - y)| := by rw [h₀]\n          _ ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n          _ ≤ M + M := add_le_add (le_csSup hS_bdd (Set.mem_range_self _)) (le_csSup hS_bdd (Set.mem_range_self _))\n          _ = 2 * M := by ring\n      rwa [mul_assoc, mul_le_mul_left (by norm_num : (0 : ℝ) < 2), le_div_iff (abs_pos.mpr hg)] at this\n    have : M ≤ M / |g y| := csSup_le hS_ne (by rintro _ ⟨x, rfl⟩; exact h_le x)\n    rwa [le_div_iff (abs_pos.mpr hg), mul_comm, mul_le_iff_le_one_right hM_pos] at this",
      "\n  let S := Set.range fun x ↦ |f x|\n  have hS_ne : S.Nonempty := ⟨|f 0|, 0, rfl⟩\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  let M := sSup S\n  have hM : ∀ x, |f x| ≤ M := fun x ↦ le_csSup hS_bdd ⟨x, rfl⟩\n  have hM_pos : 0 < M := by\n    contrapose! h₁; intro x\n    exact abs_eq_zero.mp (le_antisymm (le_trans (hM x) h₁) (abs_nonneg _))\n  intro y\n  have h_ineq : ∀ x, |f x| * |g y| ≤ M := by\n    intro x\n    have : 2 * (|f x| * |g y|) ≤ 2 * M := calc\n      2 * (|f x| * |g y|) = |2 * f x * g y| := by rw [abs_mul, abs_mul, abs_two, mul_assoc]\n      _ = |f (x + y) + f (x - y)| := by rw [h₀]\n      _ ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n      _ ≤ M + M := add_le_add (hM _) (hM _)\n      _ = 2 * M := by ring\n    linarith\n  have : M * |g y| ≤ M := by\n    by_cases hg : |g y| = 0\n    · rw [hg, mul_zero]; exact le_of_lt hM_pos\n    · have g_pos : 0 < |g y| := lt_of_le_of_ne (abs_nonneg _) (Ne.symm hg)\n      rw [mul_comm, ← le_div_iff' g_pos]\n      apply csSup_le hS_ne\n      rintro _ ⟨x, rfl⟩\n      rwa [le_div_iff' g_pos, mul_comm]\n  exact (mul_le_mul_left hM_pos).mp (by simpa using this)",
      "\n  intro y\n  by_contra hg\n  push_neg at hg\n  let S := Set.range (abs ∘ f)\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have hS_ne : S.Nonempty := Set.range_nonempty _\n  let M := sSup S\n  have hM_le : ∀ x, |f x| ≤ M := fun x ↦ le_csSup hS_bdd (Set.mem_range_self x)\n  have hM_pos : 0 < M := by\n    obtain ⟨x, hx⟩ := not_forall.mp h₁\n    exact lt_of_lt_of_le (abs_pos.mpr hx) (hM_le x)\n  have h_ineq : ∀ x, |f x| ≤ M / |g y| := by\n    intro x\n    rw [le_div_iff₀' (lt_trans zero_lt_one hg)]\n    calc |g y| * |f x| = |f x * g y| := by rw [mul_comm, abs_mul]\n      _ = |(f (x + y) + f (x - y)) / 2| := by rw [← h₀]; field_simp\n      _ ≤ (|f (x + y)| + |f (x - y)|) / 2 := by rw [abs_div, abs_two]; gcongr; exact abs_add _ _\n      _ ≤ (M + M) / 2 := by gcongr <;> apply hM_le\n      _ = M := by ring\n  have : M ≤ M / |g y| := csSup_le hS_ne (by rintro _ ⟨x, rfl⟩; exact h_ineq x)\n  rw [le_div_iff₀' (lt_trans zero_lt_one hg), mul_comm] at this\n  exact (lt_self_iff_false M).mp (lt_of_le_of_lt this (mul_lt_mul_of_pos_right hg hM_pos))",
      "\n  intro y\n  by_contra hg\n  push_neg at hg\n  let S := Set.range (fun x => |f x|)\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have hS_ne : S.Nonempty := Set.range_nonempty _\n  let M := sSup S\n  have hM_pos : 0 < M := by\n    push_neg at h₁\n    rcases h₁ with ⟨x, hx⟩\n    exact lt_of_lt_of_le (abs_pos.mpr hx) (le_sSup hS_bdd (Set.mem_range_self x))\n  have h_bound : ∀ x, |f x| * |g y| ≤ M := by\n    intro x\n    have : 2 * |f x| * |g y| ≤ 2 * M := calc\n      2 * |f x| * |g y| = |2 * f x * g y| := by rw [abs_mul, abs_mul, abs_of_nonneg (by norm_num)]; ring\n      _ = |f (x + y) + f (x - y)| := by rw [h₀]\n      _ ≤ |f (x + y)| + |f (x - y)| := abs_add _ _\n      _ ≤ M + M := add_le_add (le_sSup hS_bdd (Set.mem_range_self _)) (le_sSup hS_bdd (Set.mem_range_self _))\n      _ = 2 * M := by ring\n    linarith\n  have : M ≤ M / |g y| := by\n    apply sSup_le hS_ne\n    rintro _ ⟨x, rfl⟩\n    rw [le_div_iff' (lt_trans (by norm_num) hg)]\n    exact h_bound x\n  rw [le_div_iff' (lt_trans (by norm_num) hg)] at this\n  have : M < M * |g y| := lt_mul_of_one_lt_right hM_pos hg\n  linarith",
      "\n  let S := Set.range fun x => |f x|\n  have h_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  let k := sSup S\n  have hk : ∀ x, |f x| ≤ k := fun x => le_csSup h_bdd ⟨x, rfl⟩\n  have hk_pos : 0 < k := by\n    obtain ⟨x, hx⟩ := not_forall.mp h₁\n    exact lt_of_lt_of_le (abs_pos.mpr hx) (hk x)\n  intro y\n  by_cases hgy : g y = 0\n  · simp [hgy]\n  · rw [← mul_le_mul_left hk_pos, mul_one, ← le_div_iff' (abs_pos.mpr hgy)]\n    apply csSup_le (Set.range_nonempty _)\n    rintro _ ⟨x, rfl⟩\n    rw [le_div_iff' (abs_pos.mpr hgy)]\n    have h : |2 * f x * g y| ≤ |f (x + y)| + |f (x - y)| := by\n      rw [← h₀]\n      exact abs_add _ _\n    rw [abs_mul, abs_mul, abs_of_nonneg (by norm_num : (0 : ℝ) ≤ 2), mul_assoc] at h\n    norm_num at h\n    linarith [hk (x + y), hk (x - y)]",
      "\n  let S := Set.range (fun x => |f x|)\n  have hS_bdd : BddAbove S := ⟨1, by rintro _ ⟨x, rfl⟩; exact h₂ x⟩\n  have hS_ne : S.Nonempty := Set.range_nonempty _\n  let M := sSup S\n  have hM_pos : 0 < M := by\n    push_neg at h₁; obtain ⟨x, hx⟩ := h₁\n    exact lt_of_lt_of_le (abs_pos.mpr hx) (le_csSup hS_bdd (Set.mem_range_self x))\n  intro y\n  by_contra hg; push_neg at hg\n  have h_le : ∀ x, |f x| ≤ M / |g y| := by\n    intro x\n    specialize h₀ x y\n    have h : |2 * f x * g y| ≤ |f (x + y)| + |f (x - y)| := by\n      rw [← h₀]; exact abs_add _ _\n    rw [abs_mul, abs_mul] at h\n    norm_num at h\n    rw [mul_assoc] at h\n    have h_bound : |f (x + y)| + |f (x - y)| ≤ 2 * M :=\n      add_le_add (le_csSup hS_bdd (Set.mem_range_self _)) (le_csSup hS_bdd (Set.mem_range_self _))\n    have := le_trans h h_bound\n    rwa [mul_le_mul_left (by norm_num : (0 : ℝ) < 2), le_div_iff' (lt_trans (by norm_num) hg)] at this\n  have : M ≤ M / |g y| := csSup_le hS_ne (by rintro _ ⟨x, rfl⟩; exact h_le x)\n  rw [div_le_iff (lt_trans (by norm_num) hg), ← mul_one M, mul_le_mul_left hM_pos] at this\n  linarith",
