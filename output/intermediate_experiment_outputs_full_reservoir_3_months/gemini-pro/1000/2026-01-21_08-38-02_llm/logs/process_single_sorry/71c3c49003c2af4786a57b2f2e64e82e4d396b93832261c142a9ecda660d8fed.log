theorem imo_2008_p2.parts.i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  rcases h₀ with ⟨hx, hy, hz⟩
  let a := x / (x - 1)
  let b := y / (y - 1)
  let c := z / (z - 1)
  change a ^ 2 + b ^ 2 + c ^ 2 ≥ 1
  have h : (a - 1) * (b - 1) * (c - 1) = a * b * c := by
    simp [a, b, c]
    field_simp [hx, hy, hz]
    rw [h₁]
  have key : a ^ 2 + b ^ 2 + c ^ 2 - 1 = (a + b + c - 1) ^ 2 := by nlinarith
  rw [← sub_nonneg, key]
  exact sq_nonneg _
