import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp_pos : (p : ℝ) > 0 := by
    rw [hp]; apply Finset.sum_pos;
    intro i _; apply dist_pos.mpr;
    intro h; have := hP (i+1) (i+2) (by simp) (by simp); rw [←h] at this; simp at this
    exact Finset.univ_nonempty
  
  let S (k : ℕ) := ∑ i : Fin n, dist (P i) (P (i + k))
  
  have h_d_sum : 2 * (d : ℝ) = ∑ k in Finset.Icc 2 (n - 2), S k := by
    rw [hd, mul_one_div, mul_div_cancel₀ _ (by norm_num)];
    simp only [Finset.sum_sigma']; rw [Finset.sum_bij' (λ (i,j) _ ↦ (j - i : Fin n)) (λ k _ ↦ (k : ℕ)) _ _ _ _ _]
    · rw [Finset.sum_congr rfl]; intro k hk;
      simp only [Finset.mem_Icc, Nat.le_sub_iff_add_le (Nat.lt_of_succ_le (by simp [hn]))] at hk
      rw [Finset.sum_bij (λ i _ ↦ (i, i+k)) _ _ _ _];
      · intro i _; simp; rw [dist_comm]
      · intro i _; simp; constructor <;> {intro h; apply (Fin.neq_iff_not_eq _ _).mp _ h; intro; simp_all}
        · rw [eq_comm, Fin.eq_iff_veq] at *; simpa using hk.1
        · rw [eq_comm, Fin.eq_iff_veq] at *; omega
      · intro a ha; simp at ha; obtain ⟨i, j⟩ := a; simp; use i; simp at *
        rw [Fin.eq_iff_veq] at *; omega
      · simp
    · intro ⟨i, j⟩ h; simp at h ⊢;
      let k := (j - i : Fin n);
      have : (k : ℕ) ∈ Finset.Icc 2 (n - 2) := by
        rw [Finset.mem_Icc]; constructor
        · by_contra hc; simp at hc; 
