theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  refine ⟨fun h p hp ↦ ?_, fun h ↦ ?_⟩
  · induction h with
    | of f hf =>
      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT] at hf
      let s := (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
      let S := ⨅ p ∈ s, p.1.primeCompl
      by_cases hps : p ∈ s
      · have : S ≤ p.1.primeCompl := iInf_le_of_le p (iInf_le_of_le hps le_rfl)
        refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) ?_⟩
        -- We use the fact that f is bijective after localizing at S, and p.primeCompl >= S.
        -- Localizing at p is localizing at S then at p.
        let g := LocalizedModule.map S f
        let h : LocalizedModule S M →ₗ[Localization S] LocalizedModule S N := g
        let k := LocalizedModule.map p.1.primeCompl f
        -- k is compatible with h via further localization
        -- Since g is bijective (hf), k is bijective.
