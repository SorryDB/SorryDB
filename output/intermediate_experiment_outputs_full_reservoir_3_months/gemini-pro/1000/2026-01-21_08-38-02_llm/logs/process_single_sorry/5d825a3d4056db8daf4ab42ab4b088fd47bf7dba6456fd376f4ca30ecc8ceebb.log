  · induction h with
    | of_linearEquiv e => exact ⟨LocalizedModule.linearEquiv p.1.primeCompl e⟩
    | trans _ _ _ _ h1 h2 => exact ⟨(h1 hp).some.trans (h2 hp).some⟩
    | symm _ _ h => exact ⟨(h hp).some.symm⟩
    | of_pseudoIsomorphism f hf =>
      refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) ?_⟩
      refine (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton.1 ?_ p ?_).bijective_map _
