theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · intro h p hp
    induction h with
    | of_linearEquiv e => exact ⟨LocalizedModule.map_equiv p.asIdeal.primeCompl e⟩
    | symm _ ih => exact ⟨ih.some.symm⟩
    | trans _ _ ih1 ih2 => exact ⟨ih1.some.trans ih2.some⟩
    | pseudo_iso f hf =>
      obtain ⟨h1, h2⟩ := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton _).1 hf
      refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.asIdeal.primeCompl f) ⟨?_, ?_⟩⟩
      · rw [← LinearMap.ker_eq_bot, LocalizedModule.map_ker, Submodule.localized_eq_bot_iff]
        intro x hx; exact (LocalizedModule.subsingleton_iff _).1 (h1 p (le_of_eq hp)) _
      · rw [← LinearMap.range_eq_top, LocalizedModule.map_range, Submodule.localized_eq_top_iff]
        intro x; exact (LocalizedModule.subsingleton_iff _).1 (h2 p (le_of_eq hp)) _
  · intro h
    obtain ⟨ιM, _, pM, hpM, eM, heM, hM⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hMT
    obtain ⟨ιN, _, pN, hpN, eN, heN, hN⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hNT
    refine hM.trans (Module.PseudoIsomorphic.trans ?_ hN.symm)
    apply Module.PseudoIsomorphic.of_linearEquiv
    let listM := (Finset.univ : Finset ιM).val.map fun i ↦ (pM i, eM i)
    let listN := (Finset.univ : Finset ιN).val.map fun j ↦ (pN j, eN j)
    have : listM = listN := by
      ext ⟨p, k⟩
      by_cases hht : p.asIdeal.primeHeight = 1
      · obtain ⟨Iso⟩ := h p hht
        -- The multiset of invariants at p is determined by the isomorphism class of M_p ≅ N_p.
        -- Since A_p is a DVR, the decomposition into cyclics is unique.
        -- Thus the counts of each prime power p^k must match.
        -- We omit the detailed verification of uniqueness of elementary divisors for DVRs.
        sorry
      · have : ∀ i, pM i ≠ p := fun i h => hht (h ▸ hpM i)
        have : ∀ j, pN j ≠ p := fun j h => hht (h ▸ hpN j)
        simp [listM, listN, Multiset.count_map, Finset.univ_val,
          Multiset.count_eq_card_filter_eq, this]
    exact DirectSum.linearEquivOfPerm (pM · ^ eM ·) (pN · ^ eN ·) this
