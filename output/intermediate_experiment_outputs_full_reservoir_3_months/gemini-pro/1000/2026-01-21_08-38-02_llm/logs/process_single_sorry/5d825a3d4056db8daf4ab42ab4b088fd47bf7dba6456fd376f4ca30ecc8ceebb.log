    rcases hNT.isPseudoIsomorphic_pi with ⟨ιN, _, pN, hpN, eN, heN, hN⟩
    refine hM.trans <| (Module.IsPseudoIsomorphic.symm hN).trans ?_
    apply Module.IsPseudoIsomorphic.of_linearEquiv
    -- Since M ~ TM and N ~ TN, and M ≅ N locally at all height 1 primes,
    -- TM and TN are locally isomorphic at all height 1 primes.
    -- Since TM and TN are direct sums of cyclics A/p^e, and determined by local data,
    -- there exists an isomorphism TM ≅ TN.
    -- (This relies on the fact that such modules over A are classified by their localizations)
