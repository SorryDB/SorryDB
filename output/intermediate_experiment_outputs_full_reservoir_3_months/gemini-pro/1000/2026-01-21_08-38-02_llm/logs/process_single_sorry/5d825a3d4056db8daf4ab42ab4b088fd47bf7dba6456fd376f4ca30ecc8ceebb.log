            (LocalizedModule.map_iso _ hN.some).symm
        sorry -- The count of (p, k) is determined by the isomorphism class of the localization over A_p
      · simp only [type, Multiset.count_map, Prod.mk.injEq, Finset.mem_val, Finset.mem_univ, true_and]
        rw [Multiset.count_eq_zero.2, Multiset.count_eq_zero.2]
        all_goals
        · intro ⟨_, _, h⟩
          exact hp (h.1 ▸ h.2.1 ▸ h.2.2.1 ▸ h.2.2.2)
    obtain ⟨σ, hσ⟩ := List.perm_iff_fn_equiv_perm.1 (Multiset.coe_eq_coe.1 this)
    refine DirectSum.linearEquivFunOnFintype _ _ _ _ σ.symm ?_
    intro i
    have := (List.ofFn_get_eq_map (fun i ↦ (pM i, eM i)) i).symm.trans <|
      (List.Perm.get_eq_get_of_perm (Multiset.coe_eq_coe.1 this) hσ i).trans <|
      List.ofFn_get_eq_map (fun i ↦ (pN i, eN i)) (σ i)
    simp only [Prod.mk.injEq] at this
    rw [this.1, this.2]
