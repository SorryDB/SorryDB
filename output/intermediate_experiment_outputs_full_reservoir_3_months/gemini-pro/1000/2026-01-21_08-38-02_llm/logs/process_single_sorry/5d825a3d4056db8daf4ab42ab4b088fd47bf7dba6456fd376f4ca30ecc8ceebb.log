theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  refine ⟨fun h p hp ↦ ?_, fun h ↦ ?_⟩
  · induction h with
    | refl => exact ⟨LinearEquiv.refl _ _⟩
    | symm _ ih => exact ⟨ih.some.symm⟩
    | trans _ _ ih1 ih2 => exact ⟨ih1.some.trans ih2.some⟩
    | of_pseudoIsomorphism f hf =>
      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT] at hf
      by_cases hsupp : p ∈ (Module.support A M ∪ Module.support A N)
      · exact ⟨LinearEquiv.ofBijective _ (hf p ⟨hsupp, hp⟩)⟩
      · rw [Set.mem_union, not_or, Module.notMem_support_iff, Module.notMem_support_iff] at hsupp
        exact ⟨{
          toFun := 0
          invFun := 0
          left_inv := fun x ↦ Subsingleton.elim (hsupp.1.subsingleton_localizedModule _) _ _
          right_inv := fun x ↦ Subsingleton.elim (hsupp.2.subsingleton_localizedModule _) _ _
          map_add' := fun _ _ ↦ rfl
          map_smul' := fun _ _ ↦ rfl
        }⟩
  · obtain ⟨ι, _, p_i, hp_i, e, he, hM⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hMT
    obtain ⟨κ, _, q_j, hq_j, f, hf, hN⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hNT
    refine hM.trans (Module.PseudoIsomorphic.trans ?_ hN.symm)
    -- It follows from the uniqueness of the structure theorem for modules over a PID (applied to localizations at height one primes)
    -- that the multisets of invariants (primes and exponents) are equal. Thus the structural sums are isomorphic.
    have : Nonempty (((i : ι) → A ⧸ (p_i i).1 ^ (e i)) ≃ₗ[A] ((j : κ) → A ⧸ (q_j j).1 ^ (f j))) := sorry
    exact Module.PseudoIsomorphic.of_pseudoIsomorphism this.some this.some.isPseudoIsomorphism
