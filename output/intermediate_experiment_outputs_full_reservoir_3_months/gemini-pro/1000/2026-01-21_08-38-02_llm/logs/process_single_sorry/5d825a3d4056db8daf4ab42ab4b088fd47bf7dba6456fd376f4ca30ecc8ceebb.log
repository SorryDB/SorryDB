theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  set s := (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  set S := ⨅ p ∈ s, p.1.primeCompl
  have hs_fin : s.Finite := (Module.IsTorsion.finite_support hMT).union (Module.IsTorsion.finite_support hNT) |>.inter_of_left _
  
  -- We establish M ~ N ↔ S⁻¹M ≃ S⁻¹N
  have h_pseudo_iff_S : M ∼ₚᵢₛ[A] N ↔ Nonempty (LocalizedModule S M ≃ₗ[Localization S] LocalizedModule S N) := by
    constructor
    · intro h
      obtain ⟨ιM, _, pM, _, eM, _, hM⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hMT
      obtain ⟨ιN, _, pN, _, eN, _, hN⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hNT
      -- Since M ~ N, and ~ is transitive, M ~ N implies they have same elementary divisors
      -- hence isomorphic over S⁻¹A (which is PID or subsingleton)
      -- This step implicitly uses the uniqueness of structure theorem or similar property
      -- For now, we assume the standard consequence that pseudo-iso implies iso after localization at height 1 support.
      -- A full proof would construct the isomorphism from the elementary decompositions.
      obtain ⟨f, hf⟩ : ∃ f : M →ₗ[A] N, f.IsPseudoIsomorphism := sorry -- Simplification for brevity
      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f] at hf
      let e := LinearEquiv.ofBijective (LocalizedModule.map S f) hf
      exact ⟨e⟩
    · rintro ⟨e⟩
      -- If S⁻¹M ≃ S⁻¹N, we can lift to pseudo-iso
      obtain ⟨f, s_val, heq⟩ : ∃ f : M →ₗ[A] N, ∃ a ∈ S, LocalizedModule.map S f = a • e.toLinearMap := sorry
      have hf_bij : Function.Bijective (LocalizedModule.map S f) := sorry
      rw [← LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f] at hf_bij
      -- Usually M ~ N is defined as existence of such map, or generated by it.
      sorry

  rw [h_pseudo_iff_S]
  
  -- Now show S⁻¹M ≃ S⁻¹N ↔ ∀ p ∈ s, M_p ≃ N_p
  have h_S_PID : IsPrincipalIdealRing (Localization S) := by
    cases s.eq_empty_or_nonempty
    · have : Subsingleton (Localization S) := by
        rw [‹s = ∅›, Set.empty_subset.iInf_eq]
        exact IsLocalization.subsingleton (M := ⊤) (Submonoid.mem_top _)
      infer_instance
    · exact (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s Set.inter_subset_right ‹_› hs_fin).2

  constructor
  · rintro ⟨e⟩ p hp
    by_cases hps : p ∈ s
    · -- M_p is localization of M_S at pS
      -- Isomorphism localizes to isomorphism
      exact ⟨LocalizedModule.iso_of_iso S p.1.primeCompl e (by
        intro x hx
        simp only [S, Submonoid.mem_iInf] at hx
        exact hx p hps)⟩
    · -- p ∉ s means p ∉ Support(M) and p ∉ Support(N) (since ht(p)=1)
      -- So M_p = 0 and N_p = 0
      refine ⟨LinearEquiv.ofZero _ _⟩
      · rw [LocalizedModule.isZero_iff_disjoint_submonoid (h := ‹_›)]
        exact Set.disjoint_of_subset_left (Module.support_subset_annihilator_compl A M)
          (by simp only [Set.disjoint_compl_right, Set.le_eq_subset]; contrapose! hps; exact ⟨Or.inl hps, hp⟩)
      · rw [LocalizedModule.isZero_iff_disjoint_submonoid (h := ‹_›)]
        exact Set.disjoint_of_subset_left (Module.support_subset_annihilator_compl A N)
          (by simp only [Set.disjoint_compl_right, Set.le_eq_subset]; contrapose! hps; exact ⟨Or.inr hps, hp⟩)
          
  · intro h
    -- Local isomorphisms imply global isomorphism over PID for torsion modules
    -- S⁻¹M and S⁻¹N are torsion modules over Localization S
    -- Their localizations at maximal ideals (which correspond to p ∈ s) are M_p, N_p
    -- Since M_p ≃ N_p, S⁻¹M ≃ S⁻¹N
    sorry
