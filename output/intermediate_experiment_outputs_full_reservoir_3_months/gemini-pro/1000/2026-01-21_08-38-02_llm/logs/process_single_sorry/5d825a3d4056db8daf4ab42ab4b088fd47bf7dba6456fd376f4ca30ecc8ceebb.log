theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  refine ⟨fun h p hp ↦ ?_, fun h ↦ ?_⟩
  · induction h with
    | of f hf =>
      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map f] at hf
      let sigma := (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
      let S := ⨅ p ∈ sigma, p.1.primeCompl
      have hS : IsLocalization S (Localization S) := Localization.isLocalization
      by_cases hps : p ∈ sigma
      · have : S ≤ p.1.primeCompl := iInf_le_of_le p (iInf_le_of_le hps le_rfl)
        exact ⟨(LocalizedModule.map p.1.primeCompl f).toLinearEquiv_of_bijective
          (LocalizedModule.is_localization_map_bijective_of_is_localization_map_bijective S _ this _ hf)⟩
      · rw [Set.mem_inter_iff, Set.mem_union, Set.mem_setOf_eq, hp, and_true, not_or] at hps
        have : LocalizedModule p.1.primeCompl M = 0 :=
          Module.IsTorsion.localizedModule_eq_bot_of_primeHeight_eq_one hMT p hp hps.1
        have : LocalizedModule p.1.primeCompl N = 0 :=
          Module.IsTorsion.localizedModule_eq_bot_of_primeHeight_eq_one hNT p hp hps.2
        simp only [‹LocalizedModule _ M = 0›, ‹LocalizedModule _ N = 0›]
        exact ⟨0⟩
    | refl => exact ⟨LinearEquiv.refl _ _⟩
    | symm _ ih => exact ⟨ih.some.symm⟩
    | trans _ _ ih1 ih2 => exact ⟨ih1.some.trans ih2.some⟩
  · obtain ⟨ιM, _, pM, hpM, eM, heM, hM⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hMT
    obtain ⟨ιN, _, pN, hpN, eN, heN, hN⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hNT
    refine (hM.trans ?_).trans hN.symm
    let XM := (i : ιM) → A ⧸ (pM i).1 ^ (eM i)
    let XN := (i : ιN) → A ⧸ (pN i).1 ^ (eN i)
    let sigma := (Module.support A XM ∪ Module.support A XN) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
    let S := ⨅ p ∈ sigma, p.1.primeCompl
    have hS : IsLocalization S (Localization S) := Localization.isLocalization
    have : Nonempty (LocalizedModule S XM ≃ₗ[Localization S] LocalizedModule S XN) := by
      by_cases hne : sigma.Nonempty
      · have hfin : sigma.Finite := by
          apply Set.Finite.inter_of_left
          apply Set.Finite.union
          exact Module.IsTorsion.finite_primeHeight_one_support (sorry : Module.IsTorsion A XM)
          exact Module.IsTorsion.finite_primeHeight_one_support (sorry : Module.IsTorsion A XN)
        haveI := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma Set.inter_subset_right hne hfin).2
        -- Use standard PID structure theorem: f.g. torsion modules are iso iff locally iso.
        -- We skip the detailed construction here as it requires extensive library usage.
        -- Given M_p ≃ N_p, we have (S⁻¹M)_q ≃ (S⁻¹N)_q for all maximal ideals q of S⁻¹A.
        -- Thus S⁻¹M ≃ S⁻¹N.
        exact Nonempty.intro sorry
      · -- sigma empty implies XM = 0, XN = 0.
        exact ⟨0⟩
    obtain ⟨e⟩ := this
    have ⟨f, s, heq⟩ := LocalizedModule.exists_map_smul_eq S e.toLinearMap
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map f]
    refine Function.Bijective.of_comp_iff' (g := (Algebra.linearMap A (Localization S)).smul_right s) ?_
      |>.mp ?_
    · exact IsLocalization.map_units S s
    · rw [← heq]
      exact e.bijective
