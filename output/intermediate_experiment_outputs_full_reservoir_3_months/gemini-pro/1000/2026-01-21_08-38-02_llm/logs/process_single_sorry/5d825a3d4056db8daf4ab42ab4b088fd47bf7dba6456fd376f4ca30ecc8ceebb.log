      "\n  constructor\n  · rintro h p hp\n    refine ⟨?_⟩\n    induction h with\n    | of f hf =>\n      refine (LocalizedModule.map p.1.primeCompl f).ofBijective ?_\n      rw [← LinearMap.isPseudoIsomorphism_iff_bijective_map f]\n      · exact hf\n      · exact hp\n      · intro q hq\n        simp only [Set.mem_inter_iff, Set.mem_union, Set.mem_setOf_eq] at hq\n        rwa [hq.2, ← Ideal.primeHeight_eq_one_iff]\n    | refl => exact LinearEquiv.refl _ _\n    | symm _ _ _ h => exact h.some.symm\n    | trans _ _ _ _ _ h1 h2 => exact h1.some.trans h2.some\n  · intro h\n    obtain ⟨ιM, _, pM, hpM, eM, heM, hM⟩ := hMT.isPseudoIsomorphic_pi\n    obtain ⟨ιN, _, pN, hpN, eN, heN, hN⟩ := hNT.isPseudoIsomorphic_pi\n    refine hM.trans (PseudoIsomorphic.trans ?_ hN.symm)\n    let X := (i : ιM) → A ⧸ (pM i).1 ^ (eM i)\n    let Y := (i : ιN) → A ⧸ (pN i).1 ^ (eN i)\n    have hXY : ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →\n        Nonempty ((LocalizedModule p.1.primeCompl X) ≃ₗ[Localization p.1.primeCompl]\n          (LocalizedModule p.1.primeCompl Y)) := fun p hp ↦ by\n      refine (PseudoIsomorphic.localizedModule p.1.primeCompl hM).symm.trans ?_\n      refine (h p hp).trans ?_\n      exact PseudoIsomorphic.localizedModule p.1.primeCompl hN\n    -- Since X and Y are sums of cyclic modules over height 1 primes, and their localizations\n    -- match, they must be isomorphic. We construct the isomorphism by matching summands.\n    let type (ι : Type u) (p : ι → PrimeSpectrum A) (e : ι → ℕ) (P : PrimeSpectrum A) (k : ℕ) :=\n      { i : ι // p i = P ∧ e i = k }\n    have card_eq : ∀ P : PrimeSpectrum A, P.1.primeHeight = 1 → ∀ k,\n        Fintype.card (type ιM pM eM P k) = Fintype.card (type ιN pN eN P k) := by\n      intro P hP k\n      -- The number of summands A/P^k is determined by the module structure over A_P (a DVR).\n      -- Specifically, it is related to dim(P^{k-1} M_P / P^k M_P).\n      -- Since M_P ≅ N_P, these dimensions and thus the counts are equal.\n      sorry\n    let φ (P : PrimeSpectrum A) (k : ℕ) : type ιM pM eM P k ≃ type ιN pN eN P k := by\n      by_cases hP : P.1.primeHeight = 1\n      · exact Fintype.equivOfCardEq (card_eq P hP k)\n      · have : IsEmpty (type ιM pM eM P k) := ⟨fun ⟨i, hi, _⟩ ↦ hP (hi ▸ hpM i)⟩\n        have : IsEmpty (type ιN pN eN P k) := ⟨fun ⟨i, hi, _⟩ ↦ hP (hi ▸ hpN i)⟩\n        exact Equiv.equivOfIsEmpty _ _\n    let Φ : ιM ≃ ιN := Equiv.trans (Equiv.sigmaEquivSubtype _).symm <|\n      Equiv.trans (Equiv.sigmaCongrRight fun P ↦ Equiv.trans (Equiv.sigmaEquivSubtype _).symm <|\n        Equiv.trans (Equiv.sigmaCongrRight fun k ↦ φ P k) (Equiv.sigmaEquivSubtype _))\n        (Equiv.sigmaEquivSubtype _)\n    have hΦ : ∀ i, pN (Φ i) = pM i ∧ eN (Φ i) = eM i := by\n      intro i\n      simp only [Φ, Equiv.trans_apply, Equiv.sigmaEquivSubtype_symm_apply,\n        Equiv.sigmaCongrRight_apply, Equiv.sigmaEquivSubtype_apply]\n      -- Verify the construction preserves P and k\n      sorry\n    refine PseudoIsomorphic.of_linearEquiv <| LinearEquiv.trans\n      (DirectSum.linearEquivFunOnFintype _ _ _).symm <| LinearEquiv.trans ?_\n      (DirectSum.linearEquivFunOnFintype _ _ _)\n    refine DirectSum.linearEquivOfBijective Φ ?_ ?_\n    · intro i\n      obtain ⟨h1, h2⟩ := hΦ i\n      rw [h1, h2]\n      exact LinearEquiv.refl _ _\n    · intro i\n      obtain ⟨h1, h2⟩ := hΦ i\n      rw [h1, h2]",
      "\n  refine ⟨fun h p hp ↦ ?_, fun h ↦ ?_⟩\n  · induction h with\n    | of f hf =>\n      rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton] at hf\n      exact ⟨LocalizedModule.map_iso _ f (hf.1 p hp) (hf.2 p hp)⟩\n    | refl => exact ⟨LinearEquiv.refl _ _⟩\n    | symm _ ih => exact ⟨ih.some.symm⟩\n    | trans _ _ ih1 ih2 => exact ⟨ih1.some.trans ih2.some⟩\n  · let σ := (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}\n    let S := ⨅ p ∈ σ, p.1.primeCompl\n    -- The localized ring is a PID, so M and N become isomorphic iff they are locally isomorphic.\n    -- We use the PID structure theorem (skipped here) to deduce S⁻¹M ≅ S⁻¹N from local data.\n    have ⟨ψ⟩ : Nonempty (LocalizedModule S M ≃ₗ[Localization S] LocalizedModule S N) := sorry\n    obtain ⟨f, ⟨s, hs⟩, hf⟩ := Submodule.exists_linearMap_eq_smul_of_isLocalization S (Localization S) ψ.toLinearMap\n    refine PseudoIsomorphic.of_isPseudoIsomorphism f ?_\n    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT]\n    rw [hf]\n    exact Function.Bijective.comp\n      (Module.smul_bijective_of_isUnit (IsLocalization.map_units (Localization S) ⟨s, hs⟩) _).bijective\n      ψ.bijective",
      "\n  refine ⟨fun h p hp ↦ ?_, fun h ↦ ?_⟩\n  · induction h with\n    | refl => exact ⟨LinearEquiv.refl _ _⟩\n    | symm _ ih => exact ⟨ih.some.symm⟩\n    | trans _ _ ih1 ih2 => exact ⟨ih1.some.trans ih2.some⟩\n    | relation f hf =>\n      let f_p := LocalizedModule.map p.1.primeCompl f\n      have h1 := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton _).1 hf.pseudoNull_ker p (by simp [hp])\n      have h2 := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton _).1 hf.pseudoNull_cokernel p (by simp [hp])\n      rw [← ker_eq_bot, ← Submodule.subsingleton_iff_eq_bot, LinearMap.subsingleton_ker_convert] at h1\n      rw [← range_eq_top, ← Submodule.Quotient.subsingleton_iff, LinearMap.subsingleton_coker_convert] at h2\n      exact ⟨LinearEquiv.ofBijective f_p ⟨h1, h2⟩⟩\n  · obtain ⟨ιM, _, pM, _, eM, _, ⟨hM⟩⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hMT\n    obtain ⟨ιN, _, pN, _, eN, _, ⟨hN⟩⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hNT\n    refine hM.trans (PseudoIsomorphic.trans ?_ hN.symm)\n    -- It suffices to show EM ≅ EN. EM and EN are direct sums of A/p^k.\n    -- Such modules are isomorphic iff they are isomorphic locally at every height 1 prime.\n    -- We construct the isomorphism EM ≅ EN by assembling local isomorphisms.\n    let EM := (i : ιM) → A ⧸ pM i ^ eM i\n    let EN := (j : ιN) → A ⧸ pN j ^ eN j\n    have h_local : ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 → Nonempty ((LocalizedModule p.1.primeCompl EM) ≃ₗ[Localization p.1.primeCompl] (LocalizedModule p.1.primeCompl EN)) := fun p hp ↦ by\n      refine Nonempty.intro ((hM.symm_induction_on (fun f ↦ ?_) (fun f ↦ ?_)).trans ((h p hp).some.trans (hN.induction_on (fun f ↦ ?_) (fun f ↦ ?_))))\n      all_goals\n        intro f\n        let f_p := LocalizedModule.map p.1.primeCompl f\n        have h1 := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton _).1 (by assumption) p (by simp [hp])\n        have h2 := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton _).1 (by assumption) p (by simp [hp])\n        rw [← ker_eq_bot, ← Submodule.subsingleton_iff_eq_bot, LinearMap.subsingleton_ker_convert] at h1\n        rw [← range_eq_top, ← Submodule.Quotient.subsingleton_iff, LinearMap.subsingleton_coker_convert] at h2\n        exact LinearEquiv.ofBijective f_p ⟨h1, h2⟩\n    -- Since EM and EN are direct sums of cyclic modules of the form A/p^k (where ht(p)=1),\n    -- and for such modules, the natural map to the direct sum of their localizations at height 1 primes is an isomorphism,\n    -- and the localizations match component-wise, EM ≅ EN.\n    -- We skip the lengthy construction of the global isomorphism from local data and assume it exists given the matching local structures.\n    exact Classical.choice (Nonempty.intro {\n      toFun := fun m => Classical.choice (nonempty_equiv_of_local_equiv _ _ (fun p hp => (h_local p hp).some)) m\n      map_add' := sorry\n      map_smul' := sorry\n    })",
      "\n  set sigma := (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}\n  set S := ⨅ p ∈ sigma, p.1.primeCompl\n  have hfin : sigma.Finite :=\n    (Module.IsTorsion.finite_primeHeight_one_support hMT).union\n      (Module.IsTorsion.finite_primeHeight_one_support hNT) |>.inter_of_left _\n  rcases sigma.eq_empty_or_nonempty with rfl | hn\n  · simp only [Set.empty_inter, Set.union_empty, Set.inter_empty, Set.mem_empty_iff_false, Set.setOf_false, iInf_neg, iInf_top]\n    constructor\n    · intro _ p hp\n      have : p ∉ Module.support A M := fun h ↦ hp.ne_zero (Ideal.primeHeight_eq_zero_iff.1\n        ((Module.IsTorsion.finite_primeHeight_one_support hMT).mem_toFinset.1 h).2)\n      have : p ∉ Module.support A N := fun h ↦ hp.ne_zero (Ideal.primeHeight_eq_zero_iff.1\n        ((Module.IsTorsion.finite_primeHeight_one_support hNT).mem_toFinset.1 h).2)\n      rw [Module.notMem_support_iff] at this ‹_›\n      exact ⟨{ toFun := 0, map_add' := by simp, map_smul' := by simp, invFun := 0, left_inv := by simp, right_inv := by simp }⟩\n    · intro _\n      use { toFun := 0, map_add' := by simp, map_smul' := by simp }\n      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT]\n      simp only [LocalizedModule.map_zero, Function.Bijective, Function.Injective, Function.Surjective, forall_const, true_and]\n      rw [LocalizedModule.subsingleton_iff, LocalizedModule.subsingleton_iff]\n      constructor <;> intro x <;> use 1 <;> simp\n  · obtain ⟨_, _⟩ := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma (Set.inter_subset_right) hn hfin\n    constructor\n    · rintro ⟨f, hf⟩ p hp\n      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT f] at hf\n      let e := LinearEquiv.ofBijective _ hf\n      by_cases hps : p ∈ sigma\n      · exact ⟨e.localizationLocalization (S := S) (R := A) _ _ (by\n          rw [Ideal.primeCompl, Ideal.primeCompl, le_compl_iff_disjoint_right, disjoint_iff, Submonoid.eq_bot_iff_forall]\n