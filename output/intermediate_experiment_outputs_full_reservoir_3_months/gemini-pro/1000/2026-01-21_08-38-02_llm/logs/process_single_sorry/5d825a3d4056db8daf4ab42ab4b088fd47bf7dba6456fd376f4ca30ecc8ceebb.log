    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  refine ⟨fun h p hp ↦ ?_, fun h ↦ ?_⟩
  · induction h using Module.PseudoIsomorphic.induction_on with
    | iso f => exact ⟨LocalizedModule.map_equiv p.1.primeCompl f⟩
    | pseudo_iso f hf =>
      rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton] at hf
      exact ⟨LocalizedModule.linearEquiv_of_subsingleton_ker_coker _ f (hf.1 _ hp.le) (hf.2 _ hp.le)⟩
    | symm _ _ _ h => exact ⟨(h p hp).some.symm⟩
    | trans _ _ _ _ _ h1 h2 => exact ⟨(h1 p hp).some.trans (h2 p hp).some⟩
  · obtain ⟨ι, _, p, hp, e, he, hM⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hMT
    obtain ⟨κ, _, q, hq, f, hf, hN⟩ := Module.IsTorsion.isPseudoIsomorphic_pi hNT
    refine hM.trans (Module.PseudoIsomorphic.trans ?_ hN.symm)
    apply Module.PseudoIsomorphic.of_linearEquiv
