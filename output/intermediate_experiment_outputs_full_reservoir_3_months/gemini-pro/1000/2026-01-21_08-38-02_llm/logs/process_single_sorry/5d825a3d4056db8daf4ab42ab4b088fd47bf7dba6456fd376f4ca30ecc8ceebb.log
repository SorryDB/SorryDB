      "\n  let sigma := (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}\n  let S := ⨅ p ∈ sigma, p.1.primeCompl\n  have hS_PID : sigma.Nonempty → IsPrincipalIdealRing (Localization S) := fun hn ↦\n    (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization sigma (Set.inter_subset_right _ _) hn\n    ((Module.IsTorsion.finite_primeHeight_one_support hMT).union\n      (Module.IsTorsion.finite_primeHeight_one_support hNT))).2\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, g, hf, hg⟩\n    have : p ∉ Module.support A (LinearMap.ker f) ∧ p ∉ Module.support A (N ⧸ LinearMap.range f) := by\n      constructor <;>\n      · intro h\n        have := (Module.mem_support_iff_of_finite (M := LinearMap.ker f)).1 h\n        apply_fun Ideal.primeHeight at this\n        rw [hp] at this\n        exact (hf.1 _ this).ne rfl\n    have hf_iso : IsLinearMapEquiv (LocalizedModule.map p.1.primeCompl f) := by\n      rw [LocalizedModule.isLinearMapEquiv_iff_isUnit_det]\n      -- This path is complex. Simpler: pseudo-iso becomes iso at height 1.\n      apply LocalizedModule.isLinearMapEquiv_of_ker_coker_eq_bot\n      · rw [LocalizedModule.map_ker, Submodule.eq_bot_iff]\n        intro x hx\n        by_contra hnx\n        apply this.1\n        rw [Module.mem_support_iff_of_finite]\n        exact (LocalizedModule.mk_eq_zero _ _).1 hx\n      · rw [LocalizedModule.map_cokernel, Submodule.eq_bot_iff]\n        intro x hx\n        by_contra hnx\n        apply this.2\n        rw [Module.mem_support_iff_of_finite]\n        exact (LocalizedModule.mk_eq_zero _ _).1 hx\n    exact ⟨(LocalizedModule.map p.1.primeCompl f).toLinearEquiv_of_isLinearMapEquiv hf_iso⟩\n  · intro h\n    rcases Set.eq_empty_or_nonempty sigma with hsigma | hsigma\n    · have hM : M ∼ₚᵢₛ[A] PUnit := by\n        rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]\n        intro p hp\n        rw [LocalizedModule.subsingleton_iff_support_not_mem]\n        contrapose! hsigma