  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r :=
by
  constructor
  · intro h
    have hx : x ∈ 𝒪[K] := (mem_ringOfIntegers x).mpr (le_of_eq h)
    have hxi : x⁻¹ ∈ 𝒪[K] := (mem_ringOfIntegers x⁻¹).mpr (by rw [map_inv, h, inv_one])
    exact ⟨Units.mkOfMulEqOne ⟨x, hx⟩ ⟨x⁻¹, hxi⟩ (Subtype.ext (mul_inv_cancel (by
