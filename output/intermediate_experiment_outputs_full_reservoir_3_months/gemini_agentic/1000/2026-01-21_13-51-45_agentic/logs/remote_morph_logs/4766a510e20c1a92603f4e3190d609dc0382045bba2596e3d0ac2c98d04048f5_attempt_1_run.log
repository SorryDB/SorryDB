    have h1 := (mem_ringOfIntegers (r : K)).mp r.1.2
    have h2 := (mem_ringOfIntegers (r⁻¹ : K)).mp r.inv.2
    rw [map_inv] at h2
    exact le_antisymm h1 (inv_le_one_iff.mp h2)
