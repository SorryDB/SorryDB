import ClassFieldTheory.Cohomology.Functors.Restriction
import ClassFieldTheory.IsNonarchimedeanLocalField.Basic
import Mathlib.FieldTheory.Galois.IsGaloisGroup
/-

# 1 → 𝒪[K]ˣ → Kˣ → ℤ → 0

We construct the short exact sequence `0 → Additive (𝒪[K]ˣ) → Additive (Kˣ) → ℤ → 0` in
the following sense: we define the maps `ker_v K` and `v K`, prove the first is
injective, the second is surjective, and the pair is `Function.Exact`.

-/

namespace ValuativeRel

section proofWanted

-- I only need it for IsNonarchimedeanLocalField but it should be true in this generality
lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r :=
  ⟨fun h ↦ ⟨Units.mkOfMulEqOne ⟨x, h.le⟩ ⟨x⁻¹, by
      rw [(valuation K).map_inv, h, inv_one]⟩
      (Subtype.ext (mul_inv_cancel ((valuation K).ne_zero_iff.mp (h.symm ▸ one_ne_zero)))), rfl⟩,
   fun ⟨r, hr⟩ ↦ by
    rw [hr]
    have h1 : (valuation K) (r.val : K) ≤ 1 := r.val.2
    have h2 : (valuation K) (r.inv : K) ≤ 1 := r.inv.2
    have h3 : (valuation K) (r.val : K) * (valuation K) (r.inv : K) = 1 := by
      rw [← (valuation K).map_mul, ← Subtype.coe_mul, r.val_inv, Subtype.coe_one, (valuation K).map_one]
    have hnz : (valuation K) (r.val : K) ≠ 0 := fun h ↦ by simp [h] at h3
    have h4 : (r.inv : K) = (r.val : K)⁻¹ := by
      apply inv_unique
      rw [← Subtype.coe_mul, r.val_inv, Subtype.coe_one]
    rw [h4, (valuation K).map_inv] at h2
    exact le_antisymm h1 ((inv_le_one_iff₀.mp h2).resolve_left hnz)⟩

