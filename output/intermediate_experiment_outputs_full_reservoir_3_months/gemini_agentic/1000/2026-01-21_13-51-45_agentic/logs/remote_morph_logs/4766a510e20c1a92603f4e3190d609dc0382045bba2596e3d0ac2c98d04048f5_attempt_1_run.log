namespace ValuativeRel

section proofWanted

-- I only need it for IsNonarchimedeanLocalField but it should be true in this generality
lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r :=
  ⟨fun h ↦ by
    have hx : x ≠ 0 := (Valuation.ne_zero_iff (valuation K)).mp (h.symm ▸ one_ne_zero)
    exact ⟨Units.mkOfMulEqOne ⟨x, h.le⟩ ⟨x⁻¹, by
      show (valuation K) x⁻¹ ≤ 1
      rw [Valuation.map_inv, h, inv_one]⟩
      (Subtype.ext (mul_inv_cancel hx)), rfl⟩,
   fun ⟨r, hr⟩ ↦ by
    rw [hr]
    have h1 : (valuation K) (r.val : K) ≤ 1 := r.val.2
    have h2 : (valuation K) (r.inv : K) ≤ 1 := r.inv.2
    have h3 : (valuation K) (r.val : K) * (valuation K) (r.inv : K) = 1 := by
      rw [← Valuation.map_mul, ← Subring.coe_mul, r.val_inv, Subring.coe_one, Valuation.map_one]
    have h4 : 1 ≤ (valuation K) (r.val : K) := by
      rw [← h3]
      exact mul_le_mul_left' h2 _
    exact le_antisymm h1 h4⟩
