    /- `interAlong i` is the `n-1` intersection points which we label using `Fin (n-1)`, and
    by using `lineMap` they are determined by a point in `Set.Ioo 0 1`. -/
    (interAlong : Fin n → Fin (n - 1 : ℕ) ↪o Set.Ioo (0 : ℝ) 1)
    /- `interBtw i ⟨j, hij⟩` is the index of the intersection with `j` along segment `i`. -/
    (interBtw : (i : Fin n) → {j // i ≠ j} ≃ Fin (n - 1 : ℕ))
    /- The segments intersect iff `interAlong` and `interBtw` say they do. -/
    (lineMap_eq_iff : ∀ i j (hij : i ≠ j),
      ∀ ri rj : Set.Ioo 0 (1 : ℝ),
        lineMap (points i).1 (points i).2 ri.1 =
        lineMap (points j).1 (points j).2 rj.1 ↔
          ri = interAlong i (interBtw i ⟨j, hij⟩) ∧
          rj = interAlong j (interBtw j ⟨i, hij.symm⟩))
    -- The following function, `clap`, takes a `Bool` determining a direction, and a number `t`.
    -- It returns the intersection point (by its label) that a Frog should be at after the
    -- `t`:th clap. `false` means backwards movement from the end point, and `true` forward movement
    -- from the starting point.
    (clap : Bool → Fin (n - 1 : ℕ) → Fin (n - 1 : ℕ))
    (clap_def : ∀ b, clap b = if b then Fin.rev else id)
    (hn_odd : Odd n) :
    -- Geoff must assign each frog to a segment and a starting point
    ∃ F : Fin n → Fin n × Bool,
      -- For any two frogs `f ≠ g`
      ∀ f g (hfg : f ≠ g),
        -- The frogs do not start at the same point,
        (F f).1 ≠ (F g).1 ∧
        -- and at each point in time (`t=0` being after the first clap)
        ∀ t : Fin (n - 1 : ℕ),
        -- they don't meet.
        lineMap (points (F f).1).1 (points (F f).1).2 (interAlong (F f).1 (clap (F f).2 t)).1 ≠
        lineMap (points (F g).1).1 (points (F g).1).2 (interAlong (F g).1 (clap (F g).2 t)).1 := by
  have h_n_cast : (n : ZMod 2) = 1 := by
    rcases hn_odd with ⟨k, hk⟩
    rw [hk, Nat.cast_add, Nat.cast_mul, show (2 : ZMod 2) = 0 from rfl, zero_mul, zero_add, Nat.cast_one]
  have h_n2 : ((n - 2 : ℕ) : ZMod 2) = 1 := by
    rw [Nat.cast_sub hn, h_n_cast, show (2 : ZMod 2) = 0 from rfl, sub_zero]
  obtain ⟨b, hb⟩ : ∃ b : Fin n → ZMod 2, ∀ i j (h : i ≠ j),
      (interBtw i ⟨j, h⟩ : ZMod 2) + (interBtw j ⟨i, h.symm⟩ : ZMod 2) + 1 = b i + b j := by
    -- The sum of w_ij = x_ij + x_ji + 1 over any cycle is 0 mod 2. This is a property of line arrangements.
    sorry
  let F := fun f ↦ (f, b f == 1)
  use F
  intro f g hfg
  constructor; · exact hfg
  intro t h_eq
  rw [lineMap_eq_iff f g hfg] at h_eq
  obtain ⟨hf, hg⟩ := h_eq
  have h_clap (bv : Bool) (t : Fin (n - 1)) : (↑(clap bv t) : ZMod 2) = (if bv then 1 else 0 : ZMod 2) + ↑t := by
    rw [clap_def]; cases bv
    · simp
    · simp only [if_true, Fin.val_rev]
      have h_t : t.val ≤ n - 2 := Nat.le_pred_of_lt t.is_lt
      rw [Nat.cast_sub h_t, h_n2]
      have : ∀ x : ZMod 2, 1 - x = 1 + x := by revert t; decide
      rw [this, add_comm]
  have hf_val : (↑(clap (b f == 1) t) : ZMod 2) = (↑(interBtw f ⟨g, hfg⟩) : ZMod 2) := by
    rw [(interAlong f).injective hf]
  have hg_val : (↑(clap (b g == 1) t) : ZMod 2) = (↑(interBtw g ⟨f, hfg.symm⟩) : ZMod 2) := by
    rw [(interAlong g).injective hg]
  have h_bool (v : ZMod 2) : (if v == 1 then (1 : ZMod 2) else 0) = v := by
    revert v; decide
  have h_sum := hb f g hfg
  rw [← hf_val, ← hg_val, h_clap, h_clap, h_bool, h_bool] at h_sum
  simp only [add_assoc] at h_sum
  have : ∀ x y z : ZMod 2, x + y + (z + y) = x + z := by revert f g t b; decide
  rw [this] at h_sum
  simp [add_assoc] at h_sum
  contradiction

