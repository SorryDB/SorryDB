            . exact hs (Δ.erase δ) (λ x hx => by have := hΔ (Finset.mem_of_mem_erase hx); dsimp [construction] at this; rw [h_dec] at this; simp [hs] at this; tauto) (T.imp_closed (Logic.iff_provable.mp (by simp)) h_imp)
            . apply ih Δ (λ x hx => by have := hΔ hx; dsimp [construction] at this; rw [h_dec] at this; simp [hs] at this; tauto) h_imp
          . exact ih Δ hΔ h_imp
    exact h_safe (Nat.max i (encode ψ)) (insert φ Γ) (by
      intro x hx; simp at hx; rcases hx with (rfl | hx)
      . exact monotone_construction (Nat.le_max_left i (encode ψ)) hi
