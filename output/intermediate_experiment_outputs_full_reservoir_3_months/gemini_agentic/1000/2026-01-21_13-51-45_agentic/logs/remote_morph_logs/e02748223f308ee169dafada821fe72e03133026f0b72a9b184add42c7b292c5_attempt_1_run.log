    push_neg at h;
    obtain ⟨Γ, hΓ, hΓ₂⟩ := h;
    have hΓ₁ : (Γ.conj ⋏ φ) ➝ (Γ.conj ⋏ ψ) ∈ T.theory := T.mem_of_provable $ by
      sorry;
    have this : (Γ.conj ⋏ φ) ➝ ξ ∈ T.theory := T.imp_closed axiomI $ T.andIR hΓ₁ hΓ₂;

    obtain ⟨i, hi⟩ := hφ
    have h_safe : ∀ n Δ, ↑Δ ⊆ construction T hT n → Δ.conj ➝ ξ ∉ T.theory := by
      intro n; induction n with
      | zero =>
        intro Δ hΔ h_imp; apply hT;
        have hχΔ : χ ➝ Δ.conj ∈ T.theory := by
          induction Δ using Finset.induction with
          | empty => apply T.mem_of_provable; apply Logic.iff_provable.mp; simp
          | insert a s ih =>
            apply T.imp_closed (Logic.iff_provable.mp (by simp));
            apply T.andIR (hΔ (Finset.mem_insert_self a s)) (ih (λ x hx => hΔ (Finset.mem_insert_of_mem hx)))
        exact T.imp_closed (axiomI (ψ := Δ.conj)) (T.andIR hχΔ h_imp)
      | succ n ih =>
        intro Δ hΔ h_imp; dsimp [construction] at hΔ;
        match h_dec : decode n with
        | none => rw [h_dec] at hΔ; exact ih Δ hΔ h_imp
        | some δ =>
