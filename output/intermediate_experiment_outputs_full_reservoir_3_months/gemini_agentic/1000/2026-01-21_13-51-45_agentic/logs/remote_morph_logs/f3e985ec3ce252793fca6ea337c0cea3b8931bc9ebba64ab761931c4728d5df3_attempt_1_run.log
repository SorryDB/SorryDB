open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f := fun (A : Finset ℕ) => ∑ x ∈ A, x
  have h_card_powerset : S.powerset.card = 1024 := by rw [Finset.card_powerset, h₀]; rfl
  have h_img_sub : S.powerset.image f ⊆ Finset.range 991 := by
    intro y hy
    obtain ⟨A, hA, rfl⟩ := Finset.mem_image.1 hy
    apply Finset.mem_range.2
    have hAS : A ⊆ S := Finset.mem_powerset.1 hA
    calc f A = ∑ x ∈ A, x := rfl
      _ ≤ ∑ x ∈ S, x := Finset.sum_le_sum_of_subset hAS
      _ ≤ ∑ _ ∈ S, 99 := Finset.sum_le_sum (λ x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
      _ = 10 * 99 := by rw [Finset.sum_const, h₀, Nat.nsmul_eq_mul]
      _ = 990 := rfl
      _ < 991 := by norm_num
  have h_not_inj : ¬ (S.powerset : Set (Finset ℕ)).InjOn f := by
    intro h_inj
    have h_card_img : (S.powerset.image f).card = 1024 := by
      rw [Finset.card_image_of_injOn h_inj, h_card_powerset]
    have h_card_le : (S.powerset.image f).card ≤ 991 := by
      have h := Finset.card_le_card h_img_sub
      rwa [Finset.card_range] at h
    rw [h_card_img] at h_card_le
    norm_num at h_card_le
  obtain ⟨A, hA, B, hB, hf, hne⟩ := Set.not_injOn_iff.1 h_not_inj
  let S₁ := A \ B
  let S₂ := B \ A
  have hS₁S : S₁ ⊆ S := (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA)
  have hS₂S : S₂ ⊆ S := (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB)
  have h_sum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    dsimp [f] at hf
    have h1 : ∑ x ∈ A, x = ∑ x ∈ S₁, x + ∑ x ∈ A ∩ B, x := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter A B), Finset.sdiff_union_inter]
    have h2 : ∑ x ∈ B, x = ∑ x ∈ S₂, x + ∑ x ∈ B ∩ A, x := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter B A), Finset.sdiff_union_inter]
    rw [h1, h2, Finset.inter_comm] at hf
    exact Nat.add_right_cancel hf
  have h_S_sum_zero : ∀ {A' : Finset ℕ}, A' ⊆ S → ∑ x ∈ A', x = 0 → A' = ∅ := by
    intro A' hA'S hsum
    rw [Finset.sum_eq_zero_iff] at hsum
    · apply Finset.eq_empty_of_forall_not_mem
      intro x hx
      have : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hA'S hx))).1
      have : x = 0 := hsum x hx
      linarith
    · intro x _; exact Nat.zero_le x
  have hS₁ne : S₁.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₁_empty
    have hS₂_empty : S₂ = ∅ := h_S_sum_zero hS₂S (by rwa [← h_sum_eq, hS₁_empty, Finset.sum_empty])
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁_empty) (Finset.sdiff_eq_empty_iff_subset.1 hS₂_empty))
  have hS₂ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₂_empty
    have hS₁_empty : S₁ = ∅ := h_S_sum_zero hS₁S (by rwa [h_sum_eq, hS₂_empty, Finset.sum_empty])
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁_empty) (Finset.sdiff_eq_empty_iff_subset.1 hS₂_empty))
  use S₁, S₂
  exact ⟨hS₁ne, hS₁S, hS₂ne, hS₂S, Finset.disjoint_sdiff_sdiff, h_sum_eq⟩

