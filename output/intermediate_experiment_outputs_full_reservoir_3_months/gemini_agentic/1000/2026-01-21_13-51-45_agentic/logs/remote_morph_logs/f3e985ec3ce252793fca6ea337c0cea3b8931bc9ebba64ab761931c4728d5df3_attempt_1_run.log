import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f := fun (A : Finset ℕ) => ∑ x in A, x
  have h_range : ∀ A ∈ S.powerset, f A ∈ Finset.range 991 := by
    intro A hA
    rw [Finset.mem_powerset] at hA
    apply Nat.lt_succ_iff.mpr
    calc ∑ x in A, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset hA
      _ ≤ ∑ x in S, 99 := Finset.sum_le_sum (fun x hx => (Finset.mem_Ico.1 (h₁ hx)).2.le_one_less)
      _ = 10 * 99 := by rw [Finset.sum_const, h₀, Nat.nsmul_eq_mul]
      _ = 990 := rfl
  have h_exists : ∃ A ∈ S.powerset, ∃ B ∈ S.powerset, A ≠ B ∧ f A = f B := by
    by_contra! h_inj
    have : (Finset.powerset S).card ≤ (Finset.range 991).card :=
      Finset.card_le_card_of_inj_on f h_range h_inj
    rw [Finset.card_powerset, h₀, Finset.card_range] at this
    norm_num at this
  rcases h_exists with ⟨A, hA, B, hB, h_ne, h_eq⟩
  rw [Finset.mem_powerset] at hA hB
  let S₁ := A \ B
  let S₂ := B \ A
  have h_empty_iff : ∀ {S'}, S' ⊆ S → (S' = ∅ ↔ ∑ x in S', x = 0) := by
    intro S' hS'
    constructor
    · rintro rfl; exact Finset.sum_empty
    · intro h; rw [Finset.sum_eq_zero_iff] at h
      · exact Finset.eq_empty_of_forall_not_mem h
      · intro x hx; exact (by norm_num : 0 < 10).trans_le (Finset.mem_Ico.1 (h₁ (hS' hx))).1
  have h_sum : ∑ x in S₁, x = ∑ x in S₂, x := by
    rw [← Nat.add_right_cancel_iff (n := ∑ x in A ∩ B, x)]
    rw [Finset.sum_sdiff_add_sum_inter A B, Finset.inter_comm, Finset.sum_sdiff_add_sum_inter B A, h_eq]
  have h_S₁_ne : S₁.Nonempty := by
    by_contra h
    have hS₁ : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.mp h
    have hS₂ : S₂ = ∅ := (h_empty_iff (Finset.sdiff_subset B A).trans hB).mpr (h_sum ▸ (h_empty_iff (Finset.sdiff_subset A B).trans hA).mp hS₁)
    exact h_ne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁) (Finset.sdiff_eq_empty_iff_subset.1 hS₂))
  have h_S₂_ne : S₂.Nonempty := by
    by_contra h
    have hS₂ : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.mp h
    have hS₁ : S₁ = ∅ := (h_empty_iff (Finset.sdiff_subset A B).trans hA).mpr (h_sum.trans ((h_empty_iff (Finset.sdiff_subset B A).trans hB).mp hS₂))
    exact h_ne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁) (Finset.sdiff_eq_empty_iff_subset.1 hS₂))
  use S₁, S₂
  exact ⟨h_S₁_ne, (Finset.sdiff_subset A B).trans hA, h_S₂_ne, (Finset.sdiff_subset B A).trans hB, Finset.disjoint_sdiff_sdiff, h_sum⟩

