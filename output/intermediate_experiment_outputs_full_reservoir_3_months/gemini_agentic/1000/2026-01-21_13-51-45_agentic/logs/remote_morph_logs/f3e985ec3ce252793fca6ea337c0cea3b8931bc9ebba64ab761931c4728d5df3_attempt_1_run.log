open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f := fun (A : Finset ℕ) => ∑ x ∈ A, x
  have h_img : ∀ A ∈ S.powerset, f A ∈ Finset.range 991 := by
    intro A hA
    have hAS : A ⊆ S := Finset.mem_powerset.1 hA
    apply Finset.mem_range.2
    have h_sum_S : ∑ x ∈ S, x ≤ 990 := by
      calc ∑ x ∈ S, x ≤ ∑ _ ∈ S, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
        _ = 10 * 99 := by rw [Finset.sum_const, h₀, Nat.nsmul_eq_mul]
        _ = 990 := rfl
    calc ∑ x ∈ A, x ≤ ∑ x ∈ S, x := Finset.sum_le_sum_of_subset hAS
      _ ≤ 990 := h_sum_S
      _ < 991 := by norm_num
  have h_card : (Finset.range 991).card < S.powerset.card := by
    rw [Finset.card_range, Finset.card_powerset, h₀]
    norm_num
  obtain ⟨A, hA, B, hB, hne, hf⟩ := Finset.exists_ne_map_eq_of_card_lt_card f h_img h_card
  let S₁ := A \ B
  let S₂ := B \ A
  have hS₁S : S₁ ⊆ S := fun x hx => (Finset.mem_powerset.1 hA) (Finset.mem_of_mem_sdiff hx)
  have hS₂S : S₂ ⊆ S := fun x hx => (Finset.mem_powerset.1 hB) (Finset.mem_of_mem_sdiff hx)
  have h_sum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    dsimp [f] at hf
    rw [← Finset.sum_union (Finset.disjoint_sdiff_inter A B), Finset.sdiff_union_inter] at hf
    rw [← Finset.sum_union (Finset.disjoint_sdiff_inter B A), Finset.sdiff_union_inter, Finset.inter_comm] at hf
    exact Nat.add_right_cancel hf
  have h_S_sum_zero : ∀ {A' : Finset ℕ}, A' ⊆ S → ∑ x ∈ A', x = 0 → A' = ∅ := by
    intro A' hA'S hsum
    apply Finset.eq_empty_of_forall_not_mem
    intro x hx
    have : x ∈ S := hA'S hx
    have : x ≥ 10 := (Finset.mem_Ico.1 (h₁ this)).1
    have : x ≤ ∑ y ∈ A', y := Finset.single_le_sum (fun _ _ => Nat.zero_le _) hx
    rw [hsum] at this
    linarith
  have hS₁ne : S₁.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₁e
    have hS₂e : S₂ = ∅ := h_S_sum_zero hS₂S (by rwa [← h_sum_eq, hS₁e, Finset.sum_empty])
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁e) (Finset.sdiff_eq_empty_iff_subset.1 hS₂e))
  have hS₂ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₂e
    have hS₁e : S₁ = ∅ := h_S_sum_zero hS₁S (by rwa [h_sum_eq, hS₂e, Finset.sum_empty])
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁e) (Finset.sdiff_eq_empty_iff_subset.1 hS₂e))
  use S₁, S₂
  exact ⟨hS₁ne, hS₁S, hS₂ne, hS₂S, Finset.disjoint_sdiff_sdiff, h_sum_eq⟩

