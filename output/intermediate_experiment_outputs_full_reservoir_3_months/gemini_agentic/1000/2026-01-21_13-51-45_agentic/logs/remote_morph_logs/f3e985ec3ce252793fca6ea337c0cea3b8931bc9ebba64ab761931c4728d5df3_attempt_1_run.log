        _ = A.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
        _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (h₀ ▸ Finset.card_le_card hAS)
        _ = 990 := rfl
        _ < 991 := by norm_num
    have h_card_le : (S.powerset.image f).card ≤ 991 := by
      have h_le := Finset.card_le_card h_img_sub
      rwa [Finset.card_range] at h_le
    rw [h_card_img] at h_card_le
    norm_num at h_card_le
  obtain ⟨A, hA_mem, B, hB_mem, hne, hf⟩ := h_not_inj
  let S₁ := A \ B
  let S₂ := B \ A
  have hAS : A ⊆ S := Finset.mem_powerset.1 hA_mem
  have hBS : B ⊆ S := Finset.mem_powerset.1 hB_mem
  have hS₁S : S₁ ⊆ S := fun x hx => hAS (Finset.mem_sdiff.1 hx).1
  have hS₂S : S₂ ⊆ S := fun x hx => hBS (Finset.mem_sdiff.1 hx).1
  have h_sum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    dsimp [f] at hf
