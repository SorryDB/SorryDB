import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f := fun (A : Finset ℕ) => ∑ x ∈ A, x
  have h_not_inj : ¬ ∀ A ∈ S.powerset, ∀ B ∈ S.powerset, f A = f B → A = B := by
    intro h_inj
    have h_card_le : (S.powerset.image f).card ≤ 991 := by
      apply Finset.card_le_card
      intro s hs
      obtain ⟨A, hA, rfl⟩ := Finset.mem_image.1 hs
      apply Finset.mem_range.2
      have hAS : A ⊆ S := Finset.mem_powerset.1 hA
      calc ∑ x ∈ A, x ≤ ∑ x ∈ S, x := Finset.sum_le_sum_of_subset hAS
        _ ≤ ∑ _ ∈ S, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
        _ = 10 * 99 := by rw [Finset.sum_const, h₀, Nat.nsmul_eq_mul]
        _ < 991 := by norm_num
    have h_card_powerset : S.powerset.card = 1024 := by rw [Finset.card_powerset, h₀]; rfl
    have h_card_img_eq : (S.powerset.image f).card = 1024 := by
      rw [Finset.card_image_of_injOn h_inj, h_card_powerset]
    rw [h_card_img_eq] at h_card_le
    norm_num at h_card_le
  push_neg at h_not_inj
  obtain ⟨A, hA, B, hB, h_sum_eq, hne⟩ := h_not_inj
  let S₁ := A \ B
  let S₂ := B \ A
  have hA_sub : A ⊆ S := Finset.mem_powerset.1 hA
  have hB_sub : B ⊆ S := Finset.mem_powerset.1 hB
  have hS₁S : S₁ ⊆ S := fun x hx => hA_sub (Finset.mem_sdiff.1 hx).1
  have hS₂S : S₂ ⊆ S := fun x hx => hB_sub (Finset.mem_sdiff.1 hx).1
  have h1 : ∑ x ∈ A, x = (∑ x ∈ S₁, x) + ∑ x ∈ A ∩ B, x := by
    rw [← Finset.sdiff_union_inter A B, Finset.sum_union (Finset.disjoint_sdiff_inter A B)]
  have h2 : ∑ x ∈ B, x = (∑ x ∈ S₂, x) + ∑ x ∈ B ∩ A, x := by
    rw [← Finset.sdiff_union_inter B A, Finset.sum_union (Finset.disjoint_sdiff_inter B A)]
  rw [h1, h2, Finset.inter_comm] at h_sum_eq
  have h_sum_S₁S₂ : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := Nat.add_right_cancel h_sum_eq
  have h_S_sum_zero : ∀ {A' : Finset ℕ}, A' ⊆ S → ∑ x ∈ A', x = 0 → A' = ∅ := by
    intro A' hA'S hsum
    rw [Finset.sum_eq_zero_iff] at hsum
    · apply Finset.eq_empty_of_forall_not_mem
      intro x hx
      have : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hA'S hx))).1
      have : x = 0 := hsum x hx
      linarith
    · intro x _; exact Nat.zero_le x
  have hS₁_ne : S₁.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₁_empty
    have hS₂_empty : S₂ = ∅ := by
      have h_sum_S₂ : ∑ x ∈ S₂, x = 0 := by rw [← h_sum_S₁S₂, hS₁_empty, Finset.sum_empty]
      exact h_S_sum_zero hS₂S h_sum_S₂
    have hAB : A ⊆ B := Finset.sdiff_eq_empty_iff_subset.1 hS₁_empty
    have hBA : B ⊆ A := Finset.sdiff_eq_empty_iff_subset.1 hS₂_empty
    exact hne (Finset.Subset.antisymm hAB hBA)
  have hS₂_ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₂_empty
    have hS₁_empty : S₁ = ∅ := by
      have h_sum_S₁ : ∑ x ∈ S₁, x = 0 := by rw [h_sum_S₁S₂, hS₂_empty, Finset.sum_empty]
      exact h_S_sum_zero hS₁S h_sum_S₁
    have hAB : A ⊆ B := Finset.sdiff_eq_empty_iff_subset.1 hS₁_empty
    have hBA : B ⊆ A := Finset.sdiff_eq_empty_iff_subset.1 hS₂_empty
    exact hne (Finset.Subset.antisymm hAB hBA)
  use S₁, S₂
  exact ⟨hS₁_ne, hS₁S, hS₂_ne, hS₂S, Finset.disjoint_left.mpr (fun x hx hx' => (Finset.mem_sdiff.1 hx).2 (Finset.mem_sdiff.1 hx').1), h_sum_S₁S₂⟩

