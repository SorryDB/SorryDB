open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f := fun (A : Finset ℕ) => ∑ x ∈ A, x
  have h_not_inj : ∃ A ∈ S.powerset, ∃ B ∈ S.powerset, A ≠ B ∧ f A = f B := by
    by_contra! h_inj
    have h_card_powerset : S.powerset.card = 1024 := by rw [Finset.card_powerset, h₀]; rfl
    have h_card_img : (S.powerset.image f).card = 1024 := by
      rw [Finset.card_image_of_injOn h_inj, h_card_powerset]
    have h_img_sub : S.powerset.image f ⊆ Finset.range 991 := by
      intro y hy
      obtain ⟨A, hA_mem, rfl⟩ := Finset.mem_image.1 hy
      apply Finset.mem_range.2
      have hAS : A ⊆ S := Finset.mem_powerset.1 hA_mem
      have h_sum_S : ∑ x ∈ S, x ≤ 990 := by
        calc ∑ x ∈ S, x ≤ ∑ _ ∈ S, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
          _ = 10 * 99 := by rw [Finset.sum_const, h₀, Nat.nsmul_eq_mul]
          _ = 990 := rfl
      calc ∑ x ∈ A, x ≤ ∑ x ∈ S, x := Finset.sum_le_sum_of_subset hAS (fun x _ => Nat.zero_le x)
        _ ≤ 990 := h_sum_S
        _ < 991 := by norm_num
    have h_card_le : (S.powerset.image f).card ≤ 991 := by
      have h := Finset.card_le_card h_img_sub
      rwa [Finset.card_range] at h
    linarith
  obtain ⟨A, hA_mem, B, hB_mem, hne, hf⟩ := h_not_inj
  let S₁ := A \ B
  let S₂ := B \ A
  have hS₁S : S₁ ⊆ S := fun x hx => (Finset.mem_powerset.1 hA_mem) (Finset.mem_sdiff.1 hx).1
  have hS₂S : S₂ ⊆ S := fun x hx => (Finset.mem_powerset.1 hB_mem) (Finset.mem_sdiff.1 hx).1
  have h_sum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    dsimp [f, S₁, S₂] at hf ⊢
    rw [← Finset.sum_sdiff_add_sum_inter A B, ← Finset.sum_sdiff_add_sum_inter B A, Finset.inter_comm] at hf
    exact Nat.add_right_cancel hf
  have h_sum_zero : ∀ {A' : Finset ℕ}, A' ⊆ S → ∑ x ∈ A', x = 0 → A' = ∅ := by
    intro A' hA'S hsum
    by_contra hne_empty
    obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.2 hne_empty
    have : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hA'S hx))).1
    have : x ≤ ∑ y ∈ A', y := Finset.single_le_sum (fun y _ => Nat.zero_le y) hx
    linarith
  have hS₁ne : S₁.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₁e
    have hS₂e : S₂ = ∅ := h_sum_zero hS₂S (by rwa [← h_sum_eq, hS₁e, Finset.sum_empty])
    have hAB : A ⊆ B := Finset.sdiff_eq_empty_iff_subset.1 hS₁e
    have hBA : B ⊆ A := Finset.sdiff_eq_empty_iff_subset.1 hS₂e
    exact hne (Finset.Subset.antisymm hAB hBA)
  have hS₂ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₂e
    have hS₁e : S₁ = ∅ := h_sum_zero hS₁S (by rwa [h_sum_eq, hS₂e, Finset.sum_empty])
    have hAB : A ⊆ B := Finset.sdiff_eq_empty_iff_subset.1 hS₁e
    have hBA : B ⊆ A := Finset.sdiff_eq_empty_iff_subset.1 hS₂e
    exact hne (Finset.Subset.antisymm hAB hBA)
  use S₁, S₂
  exact ⟨hS₁ne, hS₁S, hS₂ne, hS₂S, Finset.disjoint_sdiff_sdiff A B, h_sum_eq⟩

