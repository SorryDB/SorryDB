import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f := fun (A : Finset ℕ) => ∑ x ∈ A, x
  have h_not_inj : ∃ A ∈ S.powerset, ∃ B ∈ S.powerset, A ≠ B ∧ f A = f B := by
    apply Finset.exists_ne_map_eq_of_card_lt_card (t := Finset.range 991)
    · intro A hA
      apply Finset.mem_range.mpr
      have hAS : A ⊆ S := Finset.mem_powerset.1 hA
      calc f A ≤ ∑ x ∈ S, x := Finset.sum_le_sum_of_subset hAS
        _ ≤ ∑ _ ∈ S, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
        _ = 10 * 99 := by rw [Finset.sum_const, h₀, Nat.nsmul_eq_mul]
        _ < 991 := by norm_num
    · rw [Finset.card_powerset, h₀, Finset.card_range]
      norm_num
  obtain ⟨A, hA, B, hB, hne, hf⟩ := h_not_inj
  let S₁ := A \ B
  let S₂ := B \ A
  have h_sum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    have h1 : ∑ x ∈ A, x = ∑ x ∈ S₁, x + ∑ x ∈ A ∩ B, x := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter A B), Finset.sdiff_union_inter]
    have h2 : ∑ x ∈ B, x = ∑ x ∈ S₂, x + ∑ x ∈ B ∩ A, x := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter B A), Finset.sdiff_union_inter]
    rw [Finset.inter_comm] at h2
    linarith [hf, h1, h2]
  have h_S_sum_zero : ∀ {A' : Finset ℕ}, A' ⊆ S → ∑ x ∈ A', x = 0 → A' = ∅ := by
    intro A' hA'S hsum
    rw [Finset.sum_eq_zero_iff] at hsum
    · apply Finset.eq_empty_of_forall_not_mem
      intro x hx
      have hxS : x ∈ S := hA'S hx
      have : 10 ≤ x := (Finset.mem_Ico.1 (h₁ hxS)).1
      have : x = 0 := hsum x hx
      linarith
    · intro x _; exact Nat.zero_le x
  have hS₁_ne : S₁.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₁_empty
    have hS₂_empty : S₂ = ∅ := h_S_sum_zero ((Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB)) (by linarith [h_sum_eq, hS₁_empty, Finset.sum_empty])
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁_empty) (Finset.sdiff_eq_empty_iff_subset.1 hS₂_empty))
  have hS₂_ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS₂_empty
    have hS₁_empty : S₁ = ∅ := h_S_sum_zero ((Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA)) (by linarith [h_sum_eq, hS₂_empty, Finset.sum_empty])
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁_empty) (Finset.sdiff_eq_empty_iff_subset.1 hS₂_empty))
  use S₁, S₂
  refine ⟨hS₁_ne, (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA),
          hS₂_ne, (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB),
          Finset.disjoint_left.mpr (fun x hx hx' => (Finset.mem_sdiff.1 hx).2 (Finset.mem_sdiff.1 hx').1),
          h_sum_eq⟩
