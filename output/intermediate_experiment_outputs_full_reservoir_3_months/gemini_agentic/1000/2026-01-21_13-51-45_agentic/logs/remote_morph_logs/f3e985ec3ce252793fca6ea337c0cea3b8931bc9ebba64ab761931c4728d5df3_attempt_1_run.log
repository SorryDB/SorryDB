  have h_range : ∀ A ∈ S.powerset, f A ∈ Finset.range 991 := by
    intro A hA
    rw [Finset.mem_powerset] at hA
    apply Finset.mem_range.mpr
    calc ∑ x ∈ A, x ≤ ∑ x ∈ S, x := Finset.sum_le_sum_of_subset hA
      _ ≤ ∑ x ∈ S, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
      _ = S.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
      _ = 990 := by rw [h₀]; rfl
      _ < 991 := by norm_num
  rcases Finset.exists_ne_map_eq_of_card_lt_card f h_range (by
    rw [Finset.card_powerset, h₀, Finset.card_range]
    norm_num) with ⟨A, hA, B, hB, h_ne, h_eq⟩
  have hA_sub : A ⊆ S := Finset.mem_powerset.1 hA
  have hB_sub : B ⊆ S := Finset.mem_powerset.1 hB
  let S₁ := A \ B
  let S₂ := B \ A
  have h_sum : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    have h1 : ∑ x ∈ A, x = ∑ x ∈ S₁, x + ∑ x ∈ A ∩ B, x := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter A B), Finset.sdiff_union_inter]
    have h2 : ∑ x ∈ B, x = ∑ x ∈ S₂, x + ∑ x ∈ B ∩ A, x := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter B A), Finset.sdiff_union_inter]
    rw [Finset.inter_comm] at h2
    linarith [h1, h2, h_eq]
  have h_empty : ∀ {A'}, A' ⊆ S → ∑ x ∈ A', x = 0 → A' = ∅ := by
    intro A' hA' h_sum0
    rw [Finset.sum_eq_zero_iff] at h_sum0
    apply Finset.eq_empty_of_forall_not_mem
    intro x hx
    have h_x_ge_10 : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hA' hx))).1
    have h_x_eq_0 : x = 0 := h_sum0 x hx
    linarith
  have h_S₁_ne : S₁.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro h_empty_S₁
    have h_subset_AB : A ⊆ B := Finset.sdiff_eq_empty_iff_subset.1 h_empty_S₁
    have h_sum_BA : ∑ x ∈ B \ A, x = 0 := by
      have h_sum_inter := Finset.sum_sdiff_add_sum_inter (f := fun x => x) h_subset_AB
      rw [Finset.inter_eq_right.2 h_subset_AB, h_eq] at h_sum_inter
      linarith [h_sum_inter]
    have h_empty_BA : B \ A = ∅ := h_empty ((Finset.sdiff_subset B A).trans hB_sub) h_sum_BA
    exact h_ne (Finset.Subset.antisymm h_subset_AB (Finset.sdiff_eq_empty_iff_subset.1 h_empty_BA))
  have h_S₂_ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro h_empty_S₂
    have h_subset_BA : B ⊆ A := Finset.sdiff_eq_empty_iff_subset.1 h_empty_S₂
    have h_sum_AB : ∑ x ∈ A \ B, x = 0 := by
      have h_sum_inter := Finset.sum_sdiff_add_sum_inter (f := fun x => x) h_subset_BA
      rw [Finset.inter_eq_right.2 h_subset_BA, h_eq] at h_sum_inter
      linarith [h_sum_inter]
    have h_empty_AB : A \ B = ∅ := h_empty ((Finset.sdiff_subset A B).trans hA_sub) h_sum_AB
    exact h_ne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 h_empty_AB) h_subset_BA)
  use S₁, S₂
  exact ⟨h_S₁_ne, (fun x hx => hA_sub (Finset.mem_of_mem_sdiff hx)),
         h_S₂_ne, (fun x hx => hB_sub (Finset.mem_of_mem_sdiff hx)),
         Finset.disjoint_left.mpr (fun x hx hx' => (Finset.mem_sdiff.1 hx).2 (Finset.mem_sdiff.1 hx').1),
         h_sum⟩

