    specialize h g hg
    simp [Set.mem_image, Player.payoff, Player.cond, interGame] at h ⊢
    obtain ⟨g', hg', hg''⟩ := h
    refine ⟨⟨f, (restrict hWV hW S).pre.subtree_subset_tree hf⟩, ?_, rfl⟩
    cases p <;> simp [Player.cond, interGame] at hg' ⊢ <;> rwa [← hI, ← hg'']
