lemma restrict_winning (h : S.pre.IsWinning (G := interGame V PO)) :
    (restrict hWV hW S).pre.IsWinning (G := interGame W PO) := by
    intro f hf
    have hf_body : f ∈ (interGame W PO).tree.body := Tree.body_mono (Strategy.pre_subtree_subset _) hf
    let g_val : Stream' V := fun n => if p.IsPosition (f|n) then (S (extend hWV (f|n)) (by synth_isPosition)).val else (f n).val
    have hg_chain : ∀ n, g_val (n + 1) ≤ g_val n := by
      intro n
      by_cases hp : p.IsPosition (f|n)
      · simp [g_val, hp]
        have hp' : ¬ p.IsPosition (f|(n+1)) := by sorry -- Turn alternates
        simp [hp']
        have := (S (extend hWV (f|n)) (by synth_isPosition)).prop
        rw [concat_mem_chainTree] at this
        exact (choose_pair_sub hW _).trans (this.2 (by simpa))
      · simp [g_val, hp]
        have hp' : p.IsPosition (f|(n+1)) := by sorry -- Turn alternates
        simp [hp']
        exact (S (extend hWV (f|(n+1))) (by synth_isPosition)).prop.2 (by simpa)
    let g : (interGame V PO).tree.body := ⟨g_val, by
      intro n; induction n with
      | zero => exact nil_mem_chainTree
      | succ n ih =>
        have : g_val | n ∈ chainTree V := ih
        rw [def_chainTree, List.isChain_snoc]
        exact ⟨this, by intro _; apply hg_chain⟩⟩
    have hg_S : g.1 ∈ S.pre.subtree.body := by
      intro n; induction n with
      | zero => exact S.pre.subtree.nil_mem
      | succ n ih =>
        by_cases hp : p.IsPosition (g.1|n)
        · sorry -- g follows S
        · sorry -- Opponent moves are valid
    have hI : (⋂ n, (g.1 n : Set X)) = (⋂ n, (f n : Set X)) := by
      apply Set.Subset.antisymm
      · apply Set.subset_iInter; intro n
        have : g.1 (n+1) ⊆ f n := by sorry -- Interlacing property
        exact this.trans (Set.iInter_subset _ (n+1))
      · apply Set.subset_iInter; intro n
        exact (choose_pair_sub hW _).trans (Set.iInter_subset _ n)
    have hwin := h g.1 hg_S
    use hf_body
    simp [interGame] at hwin ⊢
    rwa [hI] at hwin
