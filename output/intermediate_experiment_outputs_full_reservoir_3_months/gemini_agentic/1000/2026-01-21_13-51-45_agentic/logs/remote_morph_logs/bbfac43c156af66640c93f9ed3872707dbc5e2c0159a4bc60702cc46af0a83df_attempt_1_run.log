lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  let Y := fun i ω ↦ μ[X n | (hτ i).measurableSpace] ω
  have hY : UniformIntegrable Y 1 μ :=
    ((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X n) le_rfl (by simp)
      (memLp_one_iff_integrable.2 (hX.integrable n))).condExp'
      (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))
  have hX_le_Y : ∀ i, stoppedValue X (τ i) ≤ᵐ[μ] Y i :=
    fun i ↦ stoppedValue_ae_le_condExp_of_le hX (isStoppingTime_const 𝓕 n) (hτ i) (hτ_le i) (fun _ ↦ le_rfl)
  have hX_pos_UI : UniformIntegrable (fun i ω ↦ (stoppedValue X (τ i) ω)⁺) 1 μ := by
    refine uniformIntegrable_of_dominated (p := 1) (Y := fun i ω ↦ (Y i ω)⁺) ?_ ?_ ?_
    · exact hY.norm.comp (fun i ↦ i) -- Simplified from UI of Y⁺
    · exact fun i ↦ ((hX.stronglyMeasurable_stoppedValue (hτ i)).aestronglyMeasurable).pos
    · exact fun i ↦ ⟨i, Filter.Eventually.mono (hX_le_Y i) (fun ω h ↦ by
        simp only [norm_eq_abs, Real.norm_coe_fill]
        exact (Real.abs_of_nonneg (Real.pos_nonneg _)).trans_le (Real.pos_le_pos h))⟩
  -- The negative part follows a similar logic using the submartingale property and the integrable bound at 0.
  -- For the sake of this proof, we use the known result that bounded submartingales are UI.
  obtain ⟨M, A, hM, hA, hA0, hMA⟩ := hX.doob_decomposition
  have hM_UI := hM.uniformIntegrable_stoppedValue τ hτ hτ_le
  have hA_UI : UniformIntegrable (fun i ↦ stoppedValue A (τ i)) 1 μ :=
    uniformIntegrable_of_dominated_singleton (p := 1) le_rfl (by simp) (hA.integrable n)
      (fun i ↦ (hA.stronglyMeasurable_stoppedValue (hτ i)).aestronglyMeasurable)
      (fun i ↦ by filter_upwards [hA.stoppedValue_le hτ_le i] with ω hω; exact hω.trans (Real.le_norm_self _))
  exact (hM_UI.add le_rfl hA_UI).ae_eq (fun i ↦ (hMA i).symm)
```
