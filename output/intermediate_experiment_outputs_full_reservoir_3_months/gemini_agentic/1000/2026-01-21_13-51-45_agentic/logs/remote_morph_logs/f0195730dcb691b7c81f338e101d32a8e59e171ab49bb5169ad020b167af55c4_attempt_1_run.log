    | nil => rfl
    | cons h p ih =>
      simp [permMapWalk_cons, edges, darts, ih, Sym2.map_mk, dartEdge, List.map_map]
    | loop p ih =>
      simp [permMapWalk_loop, edges, darts, ih, Sym2.map_mk, dartEdge, List.map_map]
  have h_image : (permMapWalk n s p.2).edgeSet = (p.2.edgeSet).image (Sym2.map s) := by
    ext x
    simp [edgeSet, h_edges, Finset.mem_image, List.mem_toFinset]
  rw [h_image, Finset.card_image_of_injective]
  · intro x y hxy
    apply_fun Sym2.map s.symm at hxy
    simp [← Sym2.map_map, s.symm_comp_self, Sym2.map_id] at hxy
    exact hxy
