lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  subst hs
  have h_edges : ∀ {u v : Fin n} (w : (K n).LoopWalk u v),
      (permMapWalk n s w).edges = w.edges.map (Sym2.map s) := by
    intros u v w
    induction w with
    | nil => rfl
    | cons h p ih =>
      simp [LoopWalk.edges, LoopWalk.darts, ih, LoopWalk.dartEdge, Sym2.map_mk]
    | loop p ih =>
      simp [LoopWalk.edges, LoopWalk.darts, ih, LoopWalk.dartEdge, Sym2.map_mk]
  have h_image : (permMapWalk n s p.2).edgeSet = p.2.edgeSet.image (Sym2.map s) := by
    ext x
    simp [edgeSet, h_edges, Finset.mem_image, List.mem_toFinset]
  rw [h_image]
  apply Finset.card_image_of_injective
  intro x y hxy
  have h_inv : ∀ (z : Sym2 (Fin n)), Sym2.map s.symm (Sym2.map s z) = z := by
    intro z; rw [← Sym2.map_comp, Equiv.symm_comp_self s, Sym2.map_id]; rfl
  rw [← h_inv x, ← h_inv y, hxy]
