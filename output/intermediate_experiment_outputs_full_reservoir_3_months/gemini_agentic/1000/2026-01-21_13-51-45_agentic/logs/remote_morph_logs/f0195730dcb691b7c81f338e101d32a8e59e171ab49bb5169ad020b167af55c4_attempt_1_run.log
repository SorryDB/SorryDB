lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, hs⟩ := heq
  subst hs
  have h_edges : ∀ {u v : Fin n} (w : (K n).LoopWalk u v),
      (permMapWalk n s w).edges = w.edges.map (Sym2.map s) := by
    intro u v w
    induction w with
    | nil => rfl
    | cons h p ih =>
      simp [permMapWalk_cons, edges, darts, dartEdge, ih, Sym2.map_mk, permMap]
    | loop p ih =>
      simp [permMapWalk_loop, edges, darts, dartEdge, ih, Sym2.map_mk]
  have h_image : edgeSet (permMapWalk n s p.2) = (edgeSet p.2).image (Sym2.map s) := by
    ext x
    simp [edgeSet, h_edges, List.mem_toFinset, Finset.mem_image]
  simp only [Sigma.snd_mk, h_image]
  rw [Finset.card_image_of_injective]
  exact Sym2.map_injective s.injective

