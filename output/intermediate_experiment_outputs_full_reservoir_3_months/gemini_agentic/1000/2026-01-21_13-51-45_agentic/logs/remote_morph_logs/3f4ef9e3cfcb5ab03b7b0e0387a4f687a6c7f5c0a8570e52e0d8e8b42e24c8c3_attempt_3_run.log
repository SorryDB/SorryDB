theorem trivialInvo_fixedPoints : (fixedPoints (trivialInvo k)).Nonempty := by
  classical
  let f := trivialInvo k
  have hf : ∀ x, f (f x) = x := by
    intro ⟨⟨⟨x, y, z⟩, ⟨h, hx, hy⟩⟩, hz⟩; rfl
  let f' := Equiv.Perm.ofInvolutive f hf
  have h_card : f'.fixedPoints.card % 2 = Fintype.card (T k) % 2 :=
    Equiv.Perm.card_fixedPoints_mod_two f' (by ext; exact hf _)
  have h_odd_card : f'.fixedPoints.card % 2 = 1 := by
    rw [h_card, Nat.odd_iff.mp (card_T_odd k)]
  have h_pos : 0 < f'.fixedPoints.card := by
    rw [Nat.pos_iff_ne_zero]
    intro h; rw [h] at h_odd_card; norm_num at h_odd_card
  obtain ⟨x, hx⟩ := Finset.card_pos.mp h_pos
  exact ⟨x, (Finset.mem_filter.mp hx).2⟩
```
