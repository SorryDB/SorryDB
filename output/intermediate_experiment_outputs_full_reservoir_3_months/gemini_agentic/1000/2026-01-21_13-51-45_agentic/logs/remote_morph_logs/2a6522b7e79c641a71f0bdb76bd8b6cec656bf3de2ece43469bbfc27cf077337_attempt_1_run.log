        have h_all : ∀ j : Fin 1, k = j := h
        specialize h_all 0
        simp at h_all
        -- Case n=1, k=0: isExpert holds but 0 < 0 is false.
        sorry
      · rename_i n
        -- Case n >= 2: k cannot know all secrets with 0 calls.
        have h0 : (0 : Fin (n + 2)) ≠ (1 : Fin (n + 2)) := by simp
        have hk0 := h 0
        have hk1 := h 1
        -- initialState n k j is k = j, so hk0 is k=0 and hk1 is k=1, contradiction.
        simp [initialState] at hk0 hk1
        rw [hk0] at hk1
        contradiction
  case cons c S' ih =>
    -- To make k an expert in n-1 calls or more.
    -- The goal n - 1 < S.length is equivalent to n ≤ S.length.
    -- One person becoming an expert actually requires only n-1 calls.
    -- The strictly-greater-than might come from the definition of isExpert in Gossip.Sufficient.
    sorry
