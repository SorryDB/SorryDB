  · intro i
    fin_cases i
    all_goals {
      simp [-List.get_eq_getElem, List.get]
      intro h
      decide
    }
  · intro c hc i hi
    fin_cases i
    all_goals {
      simp [-List.get_eq_getElem, List.get] at hi ⊢
      decide
    }
