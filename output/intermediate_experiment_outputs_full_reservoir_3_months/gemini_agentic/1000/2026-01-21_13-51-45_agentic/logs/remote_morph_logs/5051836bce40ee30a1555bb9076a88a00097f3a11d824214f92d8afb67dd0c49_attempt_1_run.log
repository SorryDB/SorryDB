/--The upper diagonal entries of a Wigner Matrix have law μ -/
lemma offDiagonalHasLaw' (n : ℕ) {i j : Fin n} (h : i < j) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
  constructor
  · exact (offDiagonalEntryMeasurable n i j).aemeasurable
  · ext s hs
    rw [Measure.map_apply (offDiagonalEntryMeasurable n i j) hs]
    simp [WignerMeasure, wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction, h]
    set p : Index n := ⟨(i, j), le_of_lt h⟩
    have : (fun ω : Index n → ℝ ↦ ω p) ⁻¹' s = Set.pi Set.univ (fun q ↦ if q = p then s else Set.univ) := by
      ext ω; simp [Set.mem_univ_pi]
    rw [this, Measure.pi_univ_pi]
    haveI h_prob : ∀ q, IsProbabilityMeasure (wignerMeasureDist μ ν n q) := by
      intro q; dsimp [wignerMeasureDist]; split_ifs <;> assumption
    have : ∀ q, (wignerMeasureDist μ ν n q) (if q = p then s else Set.univ) = if q = p then (wignerMeasureDist μ ν n q) s else 1 := by
      intro q; split_ifs with hq
      · rfl
      · exact (h_prob q).measure_univ
    simp_rw [this]
    rw [Finset.prod_ite_eq Finset.univ p (fun q ↦ (wignerMeasureDist μ ν n q) s)]
    simp [wignerMeasureDist, h.ne]

```
