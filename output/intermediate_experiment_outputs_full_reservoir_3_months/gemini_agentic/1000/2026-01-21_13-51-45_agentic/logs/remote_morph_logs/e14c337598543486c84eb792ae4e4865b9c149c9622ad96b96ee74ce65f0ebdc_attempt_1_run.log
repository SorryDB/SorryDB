          . exact ih Γ hΓ hC
        . exact ih Γ hΓ hC
    exact h (encode φ) (insert φ Γ) (by intro x hx; simp at hx; rcases hx with rfl; exact monotone_construction (Nat.zero_le _) (by simpa [construction]); exact hΓ hx) (T.imp_closed (by apply T.L_subset; apply Logic.iff_provable.mpr; simp) hφ)
