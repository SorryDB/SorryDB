    simp [construction]
    intro hχφ
    have h : ∀ i Γ, ↑Γ ⊆ construction T hT i → Γ.conj ➝ ξ ∉ T.theory := by
      intro i; induction i with
      | zero =>
        intro Γ hΓ hC; apply hT;
        have hχΓ : χ ➝ Γ.conj ∈ T.theory := by
          induction Γ using Finset.induction with
          | empty => apply T.mem_of_provable; apply Entailment.AFortiori.af (φ := χ); apply Entailment.HasAxiomVerum.verum
          | insert γ Γ' ih =>
            apply T.imp_closed (φ := (χ ➝ γ) ⋏ (χ ➝ Γ'.conj)) (by apply T.L_subset; apply Logic.iff_provable.mpr; simp)
            apply T.andIR (hΓ (by simp)) (ih (by intro x hx; apply hΓ; simp [hx]))
        apply T.mem_trans hχΓ hC
      | succ i ih =>
        intro Γ hΓ hC; dsimp [construction] at hΓ
        split at hΓ;
        . rename_i δ hδ; split_ifs at hΓ with hcond
          . by_cases hmem : δ ∈ Γ
