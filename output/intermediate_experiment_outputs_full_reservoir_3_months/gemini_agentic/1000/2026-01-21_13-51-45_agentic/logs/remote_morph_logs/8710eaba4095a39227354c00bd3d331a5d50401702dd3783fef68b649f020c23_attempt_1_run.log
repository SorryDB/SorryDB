-- solution: all x_i are equal.
/-- Find all positive real solutions to:

$(x_1^2-x_3x_5)(x_2^2-x_3x_5)\le0$

$(x_2^2-x_4x_1)(x_3^2-x_4x_1)\le0$

$(x_3^2-x_5x_2)(x_4^2-x_5x_2)\le0$

