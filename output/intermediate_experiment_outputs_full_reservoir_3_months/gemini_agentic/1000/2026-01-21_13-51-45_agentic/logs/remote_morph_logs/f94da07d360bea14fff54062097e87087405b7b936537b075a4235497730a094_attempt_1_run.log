  have : DecidableEq ι := Classical.decEq _
  -- Turn the `L^p` assumption on the `X i` into various integrability conditions.
  have integrable_prod_norm_X I (hI : I ∈ A ×ˢ A ^^ m) :
    Integrable (fun ω ↦ ∏ k, ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by
    sorry
  have integrable_prod_inner_X I (hI : I ∈ A ×ˢ A ^^ m) :
    Integrable (fun ω ↦ ∏ k, inner ℝ (X (I k).1 ω) (X (I k).2 ω)) μ := by
    apply Integrable.mono (integrable_prod_norm_X I hI)
    · refine aeStronglyMeasurable_prod fun k _ ↦ ?_
      let hki := mem_piFinset.1 hI k
      exact (memLp_X _ (mem_product.1 hki).1).aeStronglyMeasurable.inner
        (memLp_X _ (mem_product.1 hki).2).aeStronglyMeasurable
    · filter_upwards with ω
      simp_rw [norm_prod, Real.norm_eq_abs]
      exact prod_le_prod (fun k _ ↦ norm_nonneg _) fun k _ ↦ abs_inner_le_norm _ _
