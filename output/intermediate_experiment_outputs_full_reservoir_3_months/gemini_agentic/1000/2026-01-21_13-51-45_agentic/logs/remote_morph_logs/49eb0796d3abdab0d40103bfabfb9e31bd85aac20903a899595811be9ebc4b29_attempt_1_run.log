/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let σ := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hσ_fin : σ.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  rcases σ.eq_empty_or_nonempty with h_empty | h_nonempty
  · use PEmpty, inferInstance, (fun _ ↦ default), (fun _ ↦ by nofun), (fun _ ↦ 1), (fun _ ↦ zero_lt_one)
    have h_ps : IsPseudoNull A M := by
      rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
      intro p hp
      rw [Decidable.le_iff_eq_or_lt, ENat.lt_one_iff_eq_zero] at hp
      rcases hp with hp | hp
      · rw [LocalizedModule.subsingleton_iff]
        rintro ⟨m, hm⟩
        obtain ⟨s, hs1, hs2⟩ := hMT ⟨m, hm⟩
        use s, ?_, hs2
        have := Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes (by rwa [Ideal.primeHeight_eq_zero_iff] at hp)
        rw [Set.disjoint_right] at this; apply this; simpa
      · rw [← Module.notMem_support_iff]; intro h_supp; exact h_empty (Set.mem_inter h_supp hp)
    use 0
    rw [isPseudoIsomorphism_iff]
    constructor <;> rwa [LinearMap.ker_zero, LinearMap.range_zero, Submodule.Quotient.subsingleton_iff, Submodule.top_equiv.subsingleton_congr]
  · set S := ⨅ p ∈ σ, p.1.primeCompl
    let L := Localization S
    haveI hdom : IsDomain L := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) h_nonempty hσ_fin).1
    haveI hpid : IsPrincipalIdealRing L := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) h_nonempty hσ_fin).2
    let ML := LocalizedModule S M
    haveI : Module.Finite L ML := LocalizedModule.is_finite S
    have hMLT : Module.IsTorsion L ML := LocalizedModule.is_torsion S hMT
    obtain ⟨ι, _, p, hp1, e, he, h_iso⟩ := IsPrincipalIdealRing.IsTorsion.exists_directSum_quotient_ideal_equivalent_of_localization S M hMT
    let N := (i : ι) → A ⧸ (p i).1 ^ (e i)
    have hNT : Module.IsTorsion A N := Module.isTorsion_pi (fun i ↦ Ideal.Quotient.isTorsion_quotient_ideal_of_primeHeight_one (p i) (hp1 i) (he i))
    obtain ⟨f, hf⟩ := LocalizedModule.lift_isomorphism_of_isLocalization S M N h_iso
    use ι, inferInstance, p, hp1, e, he, f
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT]
    convert hf
    ext p1
    simp only [Set.mem_inter_iff, σ]
    constructor
    · rintro (hp | hp)
      · exact ⟨hp.1, hp.2⟩
      · have : p1 ∈ Module.support A N := hp.1
        simp only [N, Module.support_pi, Set.mem_iUnion, Module.support_quotient_ideal_prime_power] at this
        obtain ⟨i, hi⟩ := this
        rw [hi]
        exact ⟨(p i).2, hp1 i⟩
    · exact fun h ↦ Or.inl ⟨h.1, h.2⟩

