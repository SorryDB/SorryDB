      (LocalizedModule.piEquiv S (fun i => A ⧸ (p' i).1 ^ (e' i))).trans (LinearEquiv.piCongrLeft fun i =>
        IsLocalization.quotientEquiv S ((p' i).1 ^ e' i) ((q (f_equiv i)) ^ e' i)
