    let f_equiv : ι ≃ ι0 := ULift.equiv.trans (Fintype.equivFin ι0).symm
    let p' : ι → PrimeSpectrum A := fun i => ⟨(q (f_equiv i)).comap (algebraMap A L), (hqp (f_equiv i)).comap _⟩
    let e' : ι → ℕ := fun i => e (f_equiv i)
    have hp1 : ∀ i, (p' i).1.primeHeight = 1 := by
      intro i
      have hq_mem : (p' i) ∈ Set.range (PrimeSpectrum.comap (algebraMap A L)) := ⟨⟨q (f_equiv i), hqp (f_equiv i)⟩, rfl⟩
      rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one L σ (Set.subset_refl _) hσn hσ] at hq_mem
      rcases hq_mem with h | h
      · exact h.2
      · exfalso; apply hqn (f_equiv i); rw [PrimeSpectrum.ext_iff] at h
