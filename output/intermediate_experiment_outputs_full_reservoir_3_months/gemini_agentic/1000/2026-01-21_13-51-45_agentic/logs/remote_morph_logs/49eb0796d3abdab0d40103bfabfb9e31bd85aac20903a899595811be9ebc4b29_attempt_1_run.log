/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let σ := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hσ : σ.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  rcases σ.eq_empty_or_nonempty with hσe | hσn
  · use PEmpty, inferInstance, (fun _ => default), (fun _ => by nofun), (fun _ => 1), (fun _ => zero_lt_one)
    have hM : IsPseudoNull A M := by
      rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
      intro p hp
      rcases (Decidable.le_iff_eq_or_lt.1 hp) with hp0 | hp1
      · rw [LocalizedModule.subsingleton_iff]; rintro ⟨m, hm⟩
        obtain ⟨s, -, hs⟩ := hMT ⟨m, hm⟩; use s, ?_, hs
        have := Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes (by rwa [Ideal.primeHeight_eq_zero_iff] at hp0)
        exact (Set.disjoint_right.1 this) (by simpa)
      · rw [← Module.notMem_support_iff]; intro hsm; exact hσe ⟨hsm, ENat.lt_one_iff_eq_zero.1 hp1 ▸ hp1⟩
    use 0; rw [isPseudoIsomorphism_iff]
    simp [hM, isPseudoNull_zero]
  · set S := ⨅ p ∈ σ, p.1.primeCompl
    let L := Localization S
    have hP := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (Set.subset_refl _) hσn hσ
    letI : IsDomain L := hP.1; letI : IsPrincipalIdealRing L := hP.2
    let ML := LocalizedModule S M
    have hMLT : Module.IsTorsion L ML := LocalizedModule.is_torsion S hMT
    obtain ⟨ι, hι, q, hqp, hqn, e, he, ⟨g⟩⟩ := Module.equiv_directSum_of_isTorsion (R := L) ML
    let p : ι → PrimeSpectrum A := fun i => ⟨(q i).comap (algebraMap A L), (hqp i).comap _⟩
    have hp1 : ∀ i, (p i).1.primeHeight = 1 := by
      intro i; rw [← (q i).primeHeight_localization S, Ideal.height_eq_primeHeight]
      exact (hqn i).height_eq_one_of_maximal
    use ι, hι, p, hp1, e, he
    let N := (i : ι) → A ⧸ (p i).1 ^ (e i)
    have hNT : Module.IsTorsion A N := Module.isTorsion_pi (fun i =>
      Ideal.Quotient.isTorsion_quotient_ideal_of_primeHeight_one (p i) (hp1 i) (he i))
    let NL := LocalizedModule S N
    let hNL : NL ≃ₗ[L] ((i : ι) → L ⧸ (q i) ^ (e i)) :=
      LocalizedModule.piEquiv S (fun i => A ⧸ (p i).1 ^ (e i)) |>.trans
      (LinearEquiv.piCongrLeft fun i => IsLocalization.quotientEquiv S ((p i).1 ^ (e i)) (q i ^ (e i))
        (by rw [Ideal.map_pow, IsLocalization.map_comap S (q i)]; rfl))
    let g' : ML ≃ₗ[L] NL := g.trans (DirectSum.linearEquivFunOnFintype L _ _).trans hNL.symm
    obtain ⟨f, s, hf⟩ := LocalizedModule.exists_linearMap_localized_eq_smul S M N g'
    use f; rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT, hf]
    exact g'.bijective.comp (LinearEquiv.smul_right (IsLocalization.map_units L s)).bijective
