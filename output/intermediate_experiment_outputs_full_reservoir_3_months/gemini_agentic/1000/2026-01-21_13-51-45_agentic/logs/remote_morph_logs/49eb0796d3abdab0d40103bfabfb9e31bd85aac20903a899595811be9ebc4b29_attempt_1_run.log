      · rw [← Module.notMem_support_iff]; intro hsm
        exact hσe ⟨hsm, ENat.lt_one_iff_eq_zero.1 hp1 ▸ hp1⟩
    refine ⟨0, ?_⟩
    rw [LinearMap.isPseudoIsomorphism_iff, and_iff_left hM]
    rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
    intro p hp; rw [LocalizedModule.subsingleton_pi]; intro; use 1; simp
  · set S := ⨅ p ∈ σ, p.1.primeCompl
    let L := Localization S
    have hP := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (Set.subset_refl _) hσn hσ
    letI : IsDomain L := hP.1; letI : IsPrincipalIdealRing L := hP.2
