/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let σ := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}
  have hσ : σ.Finite := hMT.finite_primeHeight_one_support
  rcases σ.eq_empty_or_nonempty with hσe | hσn
  · use ULift.{u} (Fin 0), inferInstance, (fun _ => default), (fun _ => by nofun), (fun _ => 1), (fun _ => zero_lt_one)
    have hM : IsPseudoNull A M := by
      rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
      intro p hp
      rcases (Decidable.le_iff_eq_or_lt.1 hp) with hp0 | hp1
      · rw [LocalizedModule.subsingleton_iff]; rintro ⟨m, hm⟩
        obtain ⟨s, hs1, hs2⟩ := hMT ⟨m, hm⟩
        use s, (Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes (Ideal.primeHeight_eq_zero_iff.1 hp0)).disjoint_right hs1, hs2
      · rw [← Module.notMem_support_iff]; intro hsm
        exact hσe ⟨ENat.lt_one_iff_eq_zero.1 hp1 ▸ hp1, hsm⟩
    refine ⟨0, ?_⟩
    rw [LinearMap.isPseudoIsomorphism_iff, and_iff_left hM]
    rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
    intro p hp; rw [LocalizedModule.subsingleton_pi]; intro i; exact i.elim
  · set S := ⨅ p ∈ σ, p.1.primeCompl
    let L := Localization S
    have hP := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (fun p hp => hp.1) hσn hσ
    letI : IsDomain L := hP.1; letI : IsPrincipalIdealRing L := hP.2
    let ML := LocalizedModule S M
    haveI : Module.Finite L ML := LocalizedModule.is_finite S
    have hMLT : Module.IsTorsion L ML := LocalizedModule.is_torsion S hMT
    obtain ⟨ι0, hι0, q, hqp, hqn, e, he, ⟨g⟩⟩ := Module.equiv_directSum_of_isTorsion hMLT
    let n := Fintype.card ι0
    let ι := ULift.{u} (Fin n)
    let f_equiv : ι ≃ ι0 := ULift.equiv.trans (Fintype.equivFin ι0).symm
    let p' : ι → PrimeSpectrum A := fun i => ⟨(q (f_equiv i)).comap (algebraMap A L), (hqp (f_equiv i)).comap _⟩
    let e' : ι → ℕ := fun i => e (f_equiv i)
    have hp1 : ∀ i, (p' i).1.primeHeight = 1 := by
      intro i
      have hq_mem : (p' i) ∈ Set.range (PrimeSpectrum.comap (algebraMap A L)) := ⟨⟨q (f_equiv i), hqp _⟩, rfl⟩
      rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one L σ (fun p hp => hp.1) hσn hσ] at hq_mem
      rcases hq_mem with h | h
      · exact h.2
      · exfalso; apply hqn (f_equiv i); rw [PrimeSpectrum.ext_iff] at h
        let inj := IsLocalization.injective L (iInf_le_of_le hσn.some (iInf_le_of_le hσn.some_mem hσn.some.1.primeCompl_le_nonZeroDivisors))
        apply Ideal.comap_injective (algebraMap A L) inj; rw [h, Ideal.comap_bot_of_injective]
    let N := (i : ι) → A ⧸ (p' i).1 ^ (e' i)
    have hNT : Module.IsTorsion A N := by
      intro x; obtain ⟨s, hs_nz, hs_ann⟩ := hMT.exists_nonZeroDivisor_mem_annihilator
      use s ^ (Finset.univ.sup e' id), Submonoid.pow_mem _ hs_nz _
      ext i; simp [Pi.smul_apply, Submodule.Quotient.mk_eq_zero]
      apply Ideal.pow_mem_pow; apply hs_ann
      apply Module.annihilator_le_of_mem_support
      have hq_mem : (p' i) ∈ Set.range (PrimeSpectrum.comap (algebraMap A L)) := ⟨⟨q (f_equiv i), hqp _⟩, rfl⟩
      rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one L σ (fun p hp => hp.1) hσn hσ] at hq_mem
      exact (hq_mem.resolve_right (fun h => hqn _ (by
        let inj := IsLocalization.injective L (iInf_le_of_le hσn.some (iInf_le_of_le hσn.some_mem hσn.some.1.primeCompl_le_nonZeroDivisors)))
        apply Ideal.comap_injective (algebraMap A L) inj; rw [h, Ideal.comap_bot_of_injective])))).2
    letI : Module.Finite A N := Module.Finite.pi
    let hNL : LocalizedModule S N ≃ₗ[L] ((i : ι) → L ⧸ (q (f_equiv i)) ^ (e' i)) :=
      (LocalizedModule.piEquiv S (fun i => A ⧸ (p' i).1 ^ (e' i))).trans (LinearEquiv.piCongrRight fun i =>
        IsLocalization.quotientEquiv S ((p' i).1 ^ e' i) ((q (f_equiv i)) ^ e' i)
          (by rw [Ideal.map_pow, IsLocalization.map_comap L (q (f_equiv i))]))
    let g' : ML ≃ₗ[L] LocalizedModule S N := g.trans ((DirectSum.linearEquivFunOnFintype L ι0 _).trans ((LinearEquiv.piCongrLeft L (fun i0 => L ⧸ q i0 ^ e i0) f_equiv.symm).trans hNL.symm))
    obtain ⟨f_map, s, hf_map⟩ := LocalizedModule.exists_linearMap_localized_eq_smul S M N g'
    use ι, inferInstance, p', hp1, e', (fun i => he (f_equiv i)), f_map
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT, hf_map]
    have hσ_supp : (Module.support A M ∪ Module.support A N) ∩ {p | p.1.primeHeight = 1} = σ := by
      ext p; simp only [Set.mem_inter_iff, Set.mem_setOf_eq, Set.mem_union, σ]
      refine ⟨fun ⟨h1, h2⟩ => ⟨h2, ?_⟩, fun ⟨h1, h2⟩ => ⟨Or.inl h2, h1⟩⟩
      rcases h1 with h | h; · exact h
      have : p ∈ Set.range p' := by
        simp only [Module.support_pi, Set.mem_iUnion] at h; obtain ⟨i, hi⟩ := h
        simpa [Module.support_quotient_pow _ (fun i => (he (f_equiv i)).ne')] using hi
      obtain ⟨i, rfl⟩ := this
      have hq_mem : p' i ∈ Set.range (PrimeSpectrum.comap (algebraMap A L)) := ⟨⟨q (f_equiv i), hqp _⟩, rfl⟩
      rw [PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one L σ (fun p hp => hp.1) hσn hσ] at hq_mem
      exact (hq_mem.resolve_right (fun h => hqn _ (by
        let inj := IsLocalization.injective L (iInf_le_of_le hσn.some (iInf_le_of_le hσn.some_mem hσn.some.1.primeCompl_le_nonZeroDivisors)))
        apply Ideal.comap_injective (algebraMap A L) inj; rw [h, Ideal.comap_bot_of_injective])))).2
    rw [hσ_supp]
    exact g'.bijective.comp (LinearEquiv.smul_right (IsLocalization.map_units L s)).bijective
