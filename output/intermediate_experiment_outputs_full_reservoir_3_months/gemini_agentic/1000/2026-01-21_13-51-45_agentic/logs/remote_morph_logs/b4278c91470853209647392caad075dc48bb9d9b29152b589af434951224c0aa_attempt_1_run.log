lemma bfc_bounded (x y : H) {C : ℝ} {f : (spectrum ℂ a) → ℂ}  (hf_bounded : ∀ x, ‖f x‖ ≤ C)
    (hX : @Measurable _ _ (borel (spectrum ℂ a)) _ f) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
  by_cases hC : 0 ≤ C
  · set μ := cfc_toComplexMeasure ha x y
    haveI : IsFiniteMeasure μ.var := ⟨by
      have h_var := cfc_variation_toComplexMeasure_bounded ha x y
      exact (ENNReal.mul_lt_top ENNReal.ofReal_lt_top ENNReal.ofReal_lt_top).trans_le' h_var⟩
    rw [ComplexMeasure.integral]
    refine (norm_integral_le_integral_norm _).trans ?_
    refine (integral_mono ?_ (integrable_const C) (ae_of_all _ fun z => ?_)).trans ?_
    · refine (integrable_const C).mono ?_ (ae_of_all _ fun z => ?_)
      · exact (μ.measurable_ang.mul hX).aestronglyMeasurable
      · rw [norm_mul, μ.norm_ang]; exact (one_mul _).symm.le.trans (hf_bounded z)
    · rw [norm_mul, μ.norm_ang, one_mul]; exact hf_bounded z
    · rw [integral_const, mul_comm]
      refine mul_le_mul_of_nonneg_left ?_ hC
      apply ENNReal.toReal_le_of_le_ofReal (mul_nonneg (norm_nonneg x) (norm_nonneg y))
      exact cfc_variation_toComplexMeasure_bounded ha x y
  · haveI : Subsingleton H := not_nontrivial_iff_subsingleton.1 (fun h =>
      let ⟨z, hz⟩ := spectrum.nonempty a
      hC ((norm_nonneg (f ⟨z, hz⟩)).trans (hf_bounded ⟨z, hz⟩)))
    have : x = 0 := Subsingleton.elim _ _
    subst this
    simp [cfc_toComplexMeasure, cfc_toLinearFunctional, toLinearFunctional, map_zero, ComplexMeasure.integral, integral_zero_measure]
