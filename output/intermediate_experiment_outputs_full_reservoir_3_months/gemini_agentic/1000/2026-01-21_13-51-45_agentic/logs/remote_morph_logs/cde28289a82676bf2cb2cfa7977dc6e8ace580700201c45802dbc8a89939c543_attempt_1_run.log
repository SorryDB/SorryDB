      (memLp_one_iff_integrable.2 <| hX.integrable n)).condExp'
      (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i)))
  have hZ : UniformIntegrable Z 1 μ := by
    exact (((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X ⊥) le_rfl (by simp)
      (memLp_one_iff_integrable.2 <| hX.integrable ⊥)).condExp'
