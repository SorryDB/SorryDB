  filter_upwards [hX.stoppedValue_ae_le_condExp_of_le (isStoppingTime_const 𝓕 n) (hτ i) (hτ_le i) (fun _ ↦ le_rfl),
    hX.ae_le_stoppedValue_condExp_of_le (hτ i) (isStoppingTime_const 𝓕 ⊥) (fun _ ↦ bot_le) (hτ_le i)] with ω h₁ h₂
