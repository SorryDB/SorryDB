lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  letI : Module ℝ≥0 E := Module.compHom E NNReal.toRealHom
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg_hull, hg_cau⟩ := komlos_convex (fun x ↦ ‖x‖ ^ 2) (fun x ↦ sq_nonneg ‖x‖)
    ⟨M ^ 2, fun n ↦ sq_le_sq.2 (by linarith [hM n, norm_nonneg (f n)])⟩
  have hg_cau' : CauchySeq g := Metric.cauchySeq_iff.2 fun ε εpos ↦ by
    obtain ⟨N, hN⟩ := hg_cau (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq, abs_norm, abs_of_pos εpos]
    have h_id : (2 : ℝ)⁻¹ * ‖g n‖ ^ 2 + (2 : ℝ)⁻¹ * ‖g m‖ ^ 2 - ‖((2 : ℝ≥0)⁻¹ • (g n + g m) : E)‖ ^ 2 =
        4⁻¹ * ‖g n - g m‖ ^ 2 := by
      rw [norm_sub_sq_add_norm_add_sq]
      simp only [NNReal.val_inv, NNReal.coe_two, norm_smul, real_norm_eq_abs, abs_inv, abs_two,
        inv_pow, sq_two]
      field_simp; ring
    rwa [h_id] at hN; linarith
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete hg_cau'
  exact ⟨g, x, fun n ↦ convexHull_min (subset_convexHull ℝ _)
    ((convex_convexHull ℝ _).restrict_scalars ℝ≥0) (hg_hull n), hx⟩
```
