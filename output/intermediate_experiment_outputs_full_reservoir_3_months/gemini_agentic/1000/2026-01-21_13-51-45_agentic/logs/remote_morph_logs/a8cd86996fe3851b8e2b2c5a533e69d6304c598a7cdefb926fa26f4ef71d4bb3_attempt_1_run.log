lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E] [CompleteSpace E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (nhds x) := by
  letI : Module ℝ≥0 E := Module.compHom E NNReal.toRealHom
  letI : IsScalarTower ℝ≥0 ℝ E := ⟨fun r s x ↦ by simp [smul_assoc]⟩
  let φ : E → ℝ := fun x ↦ ‖x‖ ^ 2
  have hφ_nonneg : 0 ≤ φ := fun x ↦ sq_nonneg ‖x‖
  let ⟨M, hM⟩ := h_bdd
  have hφ_bdd : ∃ M', ∀ n, φ (f n) ≤ M' := by
    use (max 0 M) ^ 2
    intro n
    simp only [φ]
    exact sq_le_sq.mpr (by
      rw [abs_norm, abs_of_nonneg (norm_nonneg _)]
      exact (hM n).trans (le_max_right 0 M))
  let ⟨g, hg_hull, hg_cau_φ⟩ := komlos_convex hφ_nonneg hφ_bdd
  have h_cau : CauchySeq g := by
    refine Metric.cauchySeq_iff.mpr fun ε εpos ↦ ?_
    let ⟨N, hN⟩ := hg_cau_φ (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n hn m hm ↦ ?_⟩
    rw [dist_eq_norm, ← sq_lt_sq, abs_norm, abs_of_pos εpos]
    have h_id : 2⁻¹ * φ (g n) + 2⁻¹ * φ (g m) - φ ((2 : ℝ≥0)⁻¹ • (g n + g m)) = ‖g n - g m‖ ^ 2 / 4 := by
      simp only [φ, norm_smul, NNReal.coe_inv, NNReal.coe_two]
      field_simp
      rw [norm_add_sq_add_norm_sub_sq]
      ring
    linarith [hN n m hn hm]
  let ⟨x, hx⟩ := cauchySeq_tendsto_of_complete h_cau
  exact ⟨g, x, fun n ↦ convexHull_min (Set.range_subset_convexHull ℝ _)
    (Convex.restrict_scalars (convex_convexHull ℝ _)) (hg_hull n), hx⟩
```
