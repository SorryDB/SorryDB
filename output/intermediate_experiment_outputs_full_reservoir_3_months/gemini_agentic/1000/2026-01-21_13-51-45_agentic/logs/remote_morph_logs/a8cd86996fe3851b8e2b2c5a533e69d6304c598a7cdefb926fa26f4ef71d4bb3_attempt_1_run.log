lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  letI : Module ℝ≥0 E := Module.compHom E NNReal.toRealHom
  rcases h_bdd with ⟨M, hM⟩
  have hM' : ∀ n, ‖f n‖ ^ 2 ≤ M ^ 2 := fun n ↦ by
    have : 0 ≤ M := (norm_nonneg (f 0)).trans (hM 0)
    exact pow_le_pow_left (norm_nonneg _) (hM n) 2
  obtain ⟨g, hg_hull, hg_cau⟩ := komlos_convex (fun x ↦ sq_nonneg ‖x‖) ⟨M ^ 2, hM'⟩
  have hg_cau' : CauchySeq g := by
    refine Metric.cauchySeq_iff.2 fun ε εpos ↦ ?_
    obtain ⟨N, hN⟩ := hg_cau (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq, abs_of_nonneg (norm_nonneg _), abs_of_pos εpos]
    have h_id : (2 : ℝ)⁻¹ * ‖g n‖ ^ 2 + (2 : ℝ)⁻¹ * ‖g m‖ ^ 2 - ‖(2 : ℝ≥0)⁻¹ • (g n + g m)‖ ^ 2 =
        (4 : ℝ)⁻¹ * ‖g n - g m‖ ^ 2 := by
      simp only [norm_smul, NNReal.coe_inv, NNReal.coe_two, real_norm_eq_abs, abs_inv, abs_two, inv_pow, sq_two]
      rw [norm_add_sq_add_norm_sub_sq]
      ring
    linarith
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_of_complete hg_cau'
  exact ⟨g, x, fun n ↦ convexHull_min (Set.range_subset_iff.2 fun m ↦ subset_convexHull ℝ _ ⟨m, rfl⟩)
    ((convex_convexHull ℝ _).restrict_scalars ℝ≥0) (hg_hull n), hx⟩
