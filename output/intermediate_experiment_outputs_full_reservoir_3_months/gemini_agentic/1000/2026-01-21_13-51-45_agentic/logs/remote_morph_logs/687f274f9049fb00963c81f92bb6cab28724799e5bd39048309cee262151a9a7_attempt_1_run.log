    have : (a, b, c) = (2, 2, 2) ∨ (a, b, c) = (2, 2, 3) ∨ (a, b, c) = (2, 6, 11) ∨ (a, b, c) = (3, 5, 7) := by
      sorry
    rcases this with h | h | h | h <;> simp [h]
