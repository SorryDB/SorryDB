import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩
  constructor
  · rintro ⟨h0, h1, ⟨x, hx⟩, ⟨y, hy⟩, ⟨z, hz⟩⟩
    have ha : 1 < a := by
      by_contra h; have : a = 1 := by linarith [h0.1]; subst this
      have : b - c = 2^x := by linarith; linarith [pow_pos (by norm_num : (2:ℤ) > 0) x]
    have hsum : (a - 1) * (b + c) = 2^x + 2^z := by linear_combination hx + hz
    have hdiff : (a + 1) * (c - b) = 2^z - 2^x := by linear_combination hz - hx
    if ha2 : a = 2 then
      subst ha2; have hb : 3 * b = 2^z + 2 * 2^x := by linear_combination 2 * hsum - hdiff
      have hc : 3 * c = 2 * 2^z + 2^x := by linear_combination hsum + hdiff
      have h9y : 9 * 2^y = 2 * 2^(2*z) + 5 * 2^(x+z) + 2 * 2^(2*x) - 18 := by
        linear_combination 9 * hy + (3 * b) * (3 * c) - (2^z + 2 * 2^x) * (2 * 2^z + 2^x)
      if hx0 : x = 0 then
        subst hx0; have : 9 * 2^y = 2 * 2^(2*z) + 5 * 2^z - 16 := by linear_combination h9y
        if hz2 : z = 2 then
          have : b = 2 := by linarith; have : c = 3 := by linarith; subst_vars; simp
        else if hz4 : z = 4 then
          have : b = 6 := by linarith; have : c = 11 := by linarith; subst_vars; simp
        else sorry
      else if hx1 : x = 1 then
        subst hx1; have : 9 * 2^y = 2 * 2^(2*z) + 10 * 2^z - 10 := by linear_combination h9y
        if hz1 : z = 1 then
          have : b = 2 := by linarith; have : c = 2 := by linarith; subst_vars; simp
        else sorry
      else sorry
    else if ha3 : a = 3 then
      subst ha3; have hb : 8 * b = 2^z + 3 * 2^x := by linear_combination 3 * hsum - hdiff
      have hc : 8 * c = 3 * 2^z + 2^x := by linear_combination hsum + 3 * hdiff
      have h64y : 64 * 2^y = 3 * 2^(2*z) + 10 * 2^(x+z) + 3 * 2^(2*x) - 192 := by
        linear_combination 64 * hy + (8 * b) * (8 * c) - (2^z + 3 * 2^x) * (3 * 2^z + 2^x)
      if hx3 : x = 3 then
        subst hx3; have : 64 * 2^y = 3 * 2^(2*z) + 80 * 2^z := by linear_combination h64y
        if hz4 : z = 4 then
          have : b = 5 := by linarith; have : c = 7 := by linarith; subst_vars; simp
        else sorry
      else sorry
    else sorry
  · rintro (rfl | rfl | rfl | rfl) <;> (simp; refine ⟨?_, ?_, ?_, ?_, ?_⟩)
    <;> try (intro; first | apply pow_pos | norm_num)
    <;> try (intro; first | apply pow_pos | norm_num)
    <;> try (intro; first | apply pow_pos | norm_num)
    <;> try linarith
    · use 1; rfl
    · use 1; rfl
    · use 1; rfl
    · use 0; rfl
    · use 2; rfl
    · use 2; rfl
    · use 0; rfl
    · use 6; rfl
    · use 4; rfl
    · use 3; rfl
    · use 5; rfl
    · use 4; rfl

