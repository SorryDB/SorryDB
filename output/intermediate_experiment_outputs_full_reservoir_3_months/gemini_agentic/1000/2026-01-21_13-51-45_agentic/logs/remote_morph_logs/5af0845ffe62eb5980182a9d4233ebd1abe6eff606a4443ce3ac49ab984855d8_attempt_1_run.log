/--The off-diagonal entries of a Wigner Matrix have law μ -/
lemma offDiagonalHasLaw (n : ℕ) {i j : Fin n} (h : i ≠ j) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
  letI : ∀ p, IsProbabilityMeasure (wignerMeasureDist μ ν n p) := fun p ↦ by
    rw [wignerMeasureDist]; split_ifs <;> assumption
  letI : DecidableEq (Index n) := Classical.typeDecidableEq _
  refine ⟨(offDiagonalEntryMeasurable n i j).aemeasurable, ?_⟩
  rcases h.lt_or_lt with hlt | hlt
  · have h_eq : (fun ω ↦ wignerMatrixMap n ω i j) = (fun ω ↦ ω ⟨(i, j), hlt.le⟩) := by
      ext ω; simp [wignerMatrixMap, wignerMatrixMap', h, hlt]
    rw [h_eq, WignerMeasure, Measure.pi_map_eval (wignerMeasureDist μ ν n) ⟨(i, j), hlt.le⟩, wignerMeasureDist, if_neg h]
  · have h_eq : (fun ω ↦ wignerMatrixMap n ω i j) = (fun ω ↦ ω ⟨(j, i), hlt.le⟩) := by
      ext ω; simp [wignerMatrixMap, wignerMatrixMap', h, lt_asymm hlt]
    rw [h_eq, WignerMeasure, Measure.pi_map_eval (wignerMeasureDist μ ν n) ⟨(j, i), hlt.le⟩, wignerMeasureDist, if_neg h.symm]
