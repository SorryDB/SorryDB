def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    use ∅
    exact ⟨⟨empty_subset _, fun e _ _ _ hne ↦ hne.elim⟩, empty_subset _⟩
  indep_subset := by
    rintro I J ⟨M, hM, hIM⟩ hJI
    exact ⟨M, hM, hJI.trans hIM⟩
  indep_aug := by
    intro I B hI hInm hBmax
    obtain ⟨MI, hMI, hIMI⟩ := hI
    obtain ⟨MB, hMB, hBMB⟩ := hBmax.1
    have hB : V(G, MB) = B := (hBmax.right ⟨MB, hMB, Subset.rfl⟩ hBMB).symm
    have hBI : ¬B ⊆ I := fun hsub ↦ hInm (hBmax.right hI hsub ▸ hBmax)
    obtain ⟨x, hxB, hxI⟩ := Set.not_subset.mp hBI
    by_cases hx : x ∈ V(G, MI)
    · exact ⟨x, ⟨hxB, hxI⟩, MI, hMI, insert_subset_iff.mpr ⟨hx, hIMI⟩⟩
    have h_not_max : ¬ G.IsMaxMatching MI := by
      intro h_max
      have hImax : Maximal (fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
        refine ⟨hI, fun K ⟨MK, hMK, hKMK⟩ hIK ↦ ?_⟩
        have h_size : MK.encard ≤ MI.encard := h_max.max MK hMK
        -- cardinality argument: |K| ≤ 2|MK| ≤ 2|MI| = |V(G, MI)|
        sorry
      exact hInm hImax
    obtain ⟨P, hP⟩ := hMI.exists_isAugPath_not_max h_not_max
    let M' := MI ∆ E(P)
    have hM' : G.IsMatching M' := hP.augment
    have hIM' : I ⊆ V(G, M') := hIMI.trans hP.augment_vertex_subset
    -- This x might not be in the augmenting path, but some x from B \ I must be.
    sorry
