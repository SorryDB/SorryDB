    obtain ⟨ξ, rfl⟩ := NNFormula.exists_isPrebox hψ₂;
    have : Modal.Ver ⊢ □ξ.toFormula := by simp;
    sorry;

  have : ∃ Γ: List (Formula ℕ), L ⊢ φ ⭤ ⋀Γ := by
    use Γ.unattach.map NNFormula.toFormula
    have : L ⊢ φ ⭤ φ.toNNFormula.toFormula := WeakerThan.pbl Formula.equiv_toNNFormula
