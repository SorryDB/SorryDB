  obtain ⟨ψ, ⟨Γ, rfl⟩, h⟩ := Hilbert.NNFormula.exists_CNF φ;
  generalize eγ : (⋀Γ.unattach).toFormula = γ at h;

  have : L ⊢ φ.toNNFormula.toFormula ⭤ γ := WeakerThan.pbl h;

