/-- Analogous to `Matrix.IsHermitian.mulVec_eigenvectorBasis` for the shared basis. -/
theorem mulVec_sharedEigenbasis (j : d) :
    A *ᵥ (sharedEigenbasis hA hB hAB j) =
    (sharedEigenvalueA hA hB hAB) j • WithLp.ofLp (sharedEigenbasis hA hB hAB j) := by
  let v := sharedEigenbasis hA hB hAB j
  let hA' := isHermitian_iff_isSymmetric.mp hA
  let hB' := isHermitian_iff_isSymmetric.mp hB
  let internal := hA'.directSum_isInternal_of_commute' hB' (commute_euclideanLin hAB)
  let ortho := hA'.orthogonalFamily_eigenspace_inf_eigenspace' hB'
  let e := Fintype.equivOfCardEq (by simp : Fintype.card (Σ i, _) = Fintype.card d)
  obtain ⟨μ, hμ⟩ := internal.subordinateOrthonormalBasis_subordinate ortho (e.symm j)
  have hAv : A *ᵥ v = (μ.1 : 𝕜) • v := (Submodule.mem_inf.mp hμ).1
  have hμ_real : (μ.1 : 𝕜) = RCLike.ofReal (RCLike.re (μ.1 : 𝕜)) := by
    rw [RCLike.ofReal_re, ← RCLike.conj_eq_iff_re]
    exact hA'.conj_eigenvalue_eq_self μ.1 μ.1.2
  rw [sharedEigenvalueA, hAv, dotProduct_smul, ← hμ_real]
  simp [hAv, dotProduct_self_sharedEigenbasis]
```
