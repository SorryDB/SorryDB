/-- Analogous to `Matrix.IsHermitian.mulVec_eigenvectorBasis` for the shared basis. -/
theorem mulVec_sharedEigenbasis (j : d) :
    A *ᵥ (sharedEigenbasis hA hB hAB j) =
    (sharedEigenvalueA hA hB hAB) j • WithLp.ofLp (sharedEigenbasis hA hB hAB j) := by
  let v := sharedEigenbasis hA hB hAB j
  let hA' := isHermitian_iff_isSymmetric.mp hA
  let hB' := isHermitian_iff_isSymmetric.mp hB
  let hAB' := commute_euclideanLin hAB
  let internal := hA'.directSum_isInternal_of_commute' hB' hAB'
  let ortho := hA'.orthogonalFamily_eigenspace_inf_eigenspace' hB'
  let b := internal.subordinateOrthonormalBasis rfl ortho
  have hv_range : v ∈ Set.range b := by
    simp only [v, Matrix.sharedEigenbasis, LinearMap.sharedEigenbasis, OrthonormalBasis.reindex_apply, Set.mem_range, exists_apply_eq_apply]
  obtain ⟨k, rfl⟩ := hv_range
  let μ₁₂ := internal.subordinateOrthonormalBasisIndex rfl ortho k
  have h_mem := internal.subordinateOrthonormalBasis_subordinate rfl ortho k
  have h_Av : A *ᵥ (b k) = (μ₁₂.1 : 𝕜) • (b k) := by
    rw [← Matrix.toEuclideanLin_apply]
