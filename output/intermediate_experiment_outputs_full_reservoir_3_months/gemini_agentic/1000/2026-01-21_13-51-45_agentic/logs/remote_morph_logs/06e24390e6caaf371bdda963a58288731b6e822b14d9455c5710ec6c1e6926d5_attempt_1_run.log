  let X := fun i (x : Fin (Module.finrank ℝ E) → ℝ) ↦ x i * L (e i)
  have h_sum : ⇑L ∘ f = ∑ i, X i := by
    ext1 x; simp only [f, X, map_sum, map_smul, smul_eq_mul, Finset.sum_apply, Function.comp_apply]
  rw [h_sum]
  have h_indep : iIndepFun (fun _ ↦ measurableSpace) X μ_pi :=
