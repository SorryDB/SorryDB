    Var[L; stdGaussianMulti E] = ∑ i, L (stdOrthonormalBasis ℝ E i) ^ 2 := by
  let e := stdOrthonormalBasis ℝ E
  let f := fun (x : Fin (Module.finrank ℝ E) → ℝ) ↦ ∑ i, x i • e i
  let μ_pi := Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)
  have hf : Measurable f := by fun_prop
  have hL : Measurable L := L.continuous.measurable
  rw [stdGaussianMulti, variance_map hL.aemeasurable hf.aemeasurable]
  let X := fun i (x : Fin (Module.finrank ℝ E) → ℝ) ↦ x i * L (e i)
  have h_sum : (fun x ↦ L (f x)) = ∑ i, X i := by
    ext1 x; simp only [f, X, L.map_sum, L.map_smul, smul_eq_mul, Pi.sum_apply]
  rw [h_sum]
  have h_indep : iIndepFun (fun _ ↦ measurableSpace) X μ_pi :=
    iIndepFun.comp (iIndepFun_pi_apply _) (fun i ↦ (continuous_mul_right (L (e i))).measurable)
  have h_int i : Integrable (X i) μ_pi :=
    Integrable.mul_const (integrable_eval_pi (memLp_one_iff_integrable.mp (memLp_id_gaussianReal 1))) _
  have h_int2 i : Integrable (X i ^ 2) μ_pi := by
    simp_rw [mul_pow]
    exact Integrable.mul_const (integrable_eval_pi (memLp_two_iff_integrable.mp (memLp_id_gaussianReal 2))) _
  rw [iIndepFun.variance_sum h_indep h_int h_int2]
  have h_mean i : ∫ x, X i x ∂μ_pi = 0 := by
    rw [integral_mul_const, integral_eval_pi (memLp_one_iff_integrable.mp (memLp_id_gaussianReal 1)), integral_id_gaussianReal, mul_zero]
  simp_rw [variance_eq_integral_sq (h_int _) (h_mean _), mul_pow, integral_mul_const,
