      clear h_v
      revert v args
      induction w with
      | zero =>
        intro v args hv
        have : args = #v[] := by simp
        simp [this, hv, Exp.eval]
      | succ w ih =>
        intro v args hv
        have h_args : args = Vector.insertIdx args.tail 0 args.head := by
          simp only [Vector.insertIdx_zero]
          ext i hi; match i with | .zero => simp | .succ i => simp [add_comm]
        simp only [Nat.add_one_sub_one, Vector.tail_eq_cast_extract, Vector.insertIdx_zero] at h_args
        rw [h_args]
        simp only [Vector.toArray_cast, Vector.toArray_append, Vector.toArray_extract,
          Array.size_append, List.size_toArray, List.length_cons, List.length_nil,
          zero_add, Array.size_extract, Vector.size_toArray, min_self,
          add_tsub_cancel_right, Array.foldl_append', List.foldl_toArray',
          List.foldl_cons, List.foldl_nil]
        apply ih
        simp [Exp.eval, hv]
    simp [Exp.eval] at h_cond
    rw [h_eval, sub_eq_zero] at h_cond
    exact h h_cond.symm
  · rfl
