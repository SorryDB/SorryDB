import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- [b](a)[/b] Prove that
\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  sorry

/-- [b](a)[/b] Prove that
\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.ii :
    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  let f : ℕ → ℚ × ℚ × ℚ := fun n =>
    let m : ℚ := n + 2
    ((1 - m^2) / 4, -2 * (m + 1) / (m - 1)^2, 2 * (m - 1) / (m + 1)^2)
  have hf : ∀ n, let p := f n; (p.1 ≠ 1 ∧ p.2.1 ≠ 1 ∧ p.2.2 ≠ 1) ∧ p.1 * p.2.1 * p.2.2 = 1 ∧ p.1^2 / (p.1 - 1)^2 + p.2.1^2 / (p.2.1 - 1)^2 + p.2.2^2 / (p.2.2 - 1)^2 = 1 := by
    intro n
    let m : ℚ := n + 2
    have hm1 : m - 1 ≠ 0 := by simp [m]; linarith
    have hm1' : m + 1 ≠ 0 := by simp [m]; linarith
    have hm3 : m^2 + 3 > 0 := by simp [m]; linarith [sq_nonneg (n : ℚ)]
    have hf1 : (f n).1 = (1 - m^2) / 4 := rfl
    have hf2 : (f n).2.1 = -2 * (m + 1) / (m - 1)^2 := rfl
    have hf3 : (f n).2.2 = 2 * (m - 1) / (m + 1)^2 := rfl
    have hx1 : (f n).1 - 1 = -(m^2 + 3) / 4 := by rw [hf1]; field_simplify; ring
    have hy1 : (f n).2.1 - 1 = -(m^2 + 3) / (m - 1)^2 := by rw [hf2]; field_simplify [hm1]; ring
    have hz1 : (f n).2.2 - 1 = -(m^2 + 3) / (m + 1)^2 := by rw [hf3]; field_simplify [hm1']; ring
    repeat' constructor
    · rw [← sub_ne_zero, hx1]; field_simplify; linarith [hm3]
    · rw [← sub_ne_zero, hy1]; field_simplify [hm1]; linarith [hm3]
    · rw [← sub_ne_zero, hz1]; field_simplify [hm1']; linarith [hm3]
    · rw [hf1, hf2, hf3]; field_simplify [hm1, hm1']; ring
    · rw [hx1, hy1, hz1, hf1, hf2, hf3]; field_simplify [hm1, hm1', hm3.ne']; ring
  apply Set.Infinite.mono (s := Set.range f)
  · rintro _ ⟨n, rfl⟩
    exact ⟨(f n).1, (f n).2.1, (f n).2.2, hf n, rfl⟩
  · apply Set.infinite_range_of_injective
    intro n k hnk
    injection hnk with h1 _
    have : ((n : ℚ) + 2)^2 = ((k : ℚ) + 2)^2 := by linarith [h1]
    have : (n : ℚ) + 2 = (k : ℚ) + 2 := (pow_left_inj (by linarith) (by linarith) (by norm_num)).mp this
    have : (n : ℚ) = (k : ℚ) := by linarith
    exact Nat.cast_inj.mp this
