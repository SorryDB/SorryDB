      have hb : b = (k + 1) / (k ^ 2 + k + 1) := by rw [hy]; field_simplify [hk.ne', h2]; ring
      have hc : c = -k / (k ^ 2 + k + 1) := by rw [hz]; field_simplify [h1, h2]; ring
      have hsum : a + b + c = 1 := by rw [ha, hb, hc]; field_simplify [h2]; ring
      have habc : a * b + b * c + c * a = 0 := by rw [ha, hb, hc]; field_simplify [h2]; ring
      rw [div_pow, div_pow, div_pow]
      calc a ^ 2 + b ^ 2 + c ^ 2 = (a + b + c) ^ 2 - 2 * (a * b + b * c + c * a) := by ring
        _ = 1 ^ 2 - 2 * 0 := by rw [hsum, habc]
        _ = 1 := by ring
  apply Set.Infinite.mono (s := Set.range f)
  · rintro p ⟨n, rfl⟩
    exact ⟨(f n).1, (f n).2.1, (f n).2.2, (hf n).1, (hf n).2.1, (hf n).2.2, rfl⟩
  · apply Set.infinite_range_of_injective
