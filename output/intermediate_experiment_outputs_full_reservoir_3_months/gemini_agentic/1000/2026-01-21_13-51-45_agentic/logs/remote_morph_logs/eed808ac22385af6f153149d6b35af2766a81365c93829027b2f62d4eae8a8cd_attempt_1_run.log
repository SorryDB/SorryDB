import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- [b](a)[/b] Prove that
\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  sorry

/-- [b](a)[/b] Prove that
\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.ii :
    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  let f : ℕ → ℚ × ℚ × ℚ := fun n =>
    let k : ℚ := (n : ℚ) + 2
    (-k * (k + 1), -(k + 1) / k ^ 2, k / (k + 1) ^ 2)
  apply Set.Infinite.mono (s := Set.range f)
  · rintro _ ⟨n, rfl⟩
    simp only [Set.mem_setOf_eq]
    let k : ℚ := (n : ℚ) + 2
    have hk0 : k ≠ 0 := by dsimp [k]; norm_cast; linarith
    have hk1 : k + 1 ≠ 0 := by dsimp [k]; norm_cast; linarith
    have hsq : k ^ 2 + k + 1 ≠ 0 := by
      have hk_pos : k > 0 := by dsimp [k]; norm_cast; linarith
      nlinarith
    let x := -k * (k + 1)
    let y := -(k + 1) / k ^ 2
    let z := k / (k + 1) ^ 2
    have hx1 : x - 1 = -(k ^ 2 + k + 1) := by dsimp [x]; ring
    have hy1 : y - 1 = -(k ^ 2 + k + 1) / k ^ 2 := by dsimp [y]; field_simp [hk0]; ring
    have hz1 : z - 1 = -(k ^ 2 + k + 1) / (k + 1) ^ 2 := by dsimp [z]; field_simp [hk1]; ring
    have hxne : x ≠ 1 := by rw [← sub_ne_zero, hx1]; exact neg_ne_zero.mpr hsq
    have hyne : y ≠ 1 := by rw [← sub_ne_zero, hy1]; exact div_ne_zero (neg_ne_zero.mpr hsq) (pow_ne_zero 2 hk0)
    have hzne : z ≠ 1 := by rw [← sub_ne_zero, hz1]; exact div_ne_zero (neg_ne_zero.mpr hsq) (pow_ne_zero 2 hk1)
    refine ⟨x, y, z, ⟨hxne, hyne, hzne⟩, ?_, ?_, rfl⟩
    · dsimp [x, y, z]; field_simp [hk0, hk1]; ring
    · rw [hx1, hy1, hz1]; dsimp [x, y, z]; field_simp [hsq, hk0, hk1]; ring
  · apply Set.infinite_range_of_injective
    intro n1 n2 h
    simp only [f, Prod.mk.injEq] at h
    let k1 : ℚ := (n1 : ℚ) + 2
    let k2 : ℚ := (n2 : ℚ) + 2
    have hk12 : k1 = k2 := by
      have h1 : k1 * (k1 + 1) = k2 * (k2 + 1) := by
        have hx := h.1
        simp only [neg_mul, neg_inj] at hx
        exact hx
      have hk1_ge : k1 ≥ 2 := by dsimp [k1]; norm_cast; linarith
      have hk2_ge : k2 ≥ 2 := by dsimp [k2]; norm_cast; linarith
      nlinarith
    have h_eq_q : (n1 : ℚ) = (n2 : ℚ) := by linarith
    exact Nat.cast_inj.mp h_eq_q

