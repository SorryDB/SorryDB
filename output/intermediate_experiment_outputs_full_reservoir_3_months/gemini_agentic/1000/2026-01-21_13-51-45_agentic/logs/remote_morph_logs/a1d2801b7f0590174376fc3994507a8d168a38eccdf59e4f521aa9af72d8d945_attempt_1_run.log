    intro i env input h_env (x, y) h_input assumptions
    simp only [circuit_norm, LessThan.main, Num2Bits.circuit] at *
    have hy_v : (y + 1).val = y.val + 1 := by
      rw [ZMod.val_add_of_lt]; simp [ZMod.val_one]; linarith [assumptions.2, hn]
    have h_diff_val : (x + (2^n : F p) - (y + 1)).val < 2^(n + 1) := by
