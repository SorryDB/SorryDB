for each `y ∈ I \ {x}`. -/
theorem small_condVar_of_isNIPWith (isNIPWith_𝓕 : IsNIPWith d (𝓕 : Set (Set X)))
    (hA : ∀ᵐ ω ∂μ, A ω ∈ 𝓕) : Var[fun ω ↦ (A ω).indicator 1 x ; μ | .generateFrom { {ω | y ∈ A ω} | y ∈ I \ {x} }] ≤ fun ω ↦ if (A ω) ∆ {x} ∈ 𝓕 then 1 / 4 else 0 :=
  isNIPWith_𝓕.condVar_indicator_le_indicator_symmDiff hA
