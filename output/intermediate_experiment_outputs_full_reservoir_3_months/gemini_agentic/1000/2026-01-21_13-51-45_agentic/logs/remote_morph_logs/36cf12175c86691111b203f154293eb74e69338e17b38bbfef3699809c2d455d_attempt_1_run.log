  have h_eq (c : α) : (fun ω s ↦ rewardByCount A R c s ω) = (fun ω ↦ φ (fun n ↦ rewardByCount A R c (n + 1) ω)) :=
    by ext ω s; cases s <;> simp [rewardByCount, φ]
  rw [h_eq a, h_eq b]
  exact h_indep.comp hφ hφ
