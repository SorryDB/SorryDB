lemma indepFun_rewardByCount_of_ne [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) {a b : α} (hab : a ≠ b) :
    IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) 𝔓' := by
  let X (p : α × ℕ) (ω : Ω × (ℕ → α → ℝ)) : ℝ := rewardByCount A R p.1 (p.2 + 1) ω
  have h_i : iIndepFun X 𝔓' := iIndepFun_rewardByCount h
  let Sa : Set (α × ℕ) := {p | p.1 = a}
  let Sb : Set (α × ℕ) := {p | p.1 = b}
  have h_dis : Disjoint Sa Sb := by
    intro p hp; simp [Sa, Sb] at hp; exact hab (hp.1.symm.trans hp.2)
  let ga (f : Sa → ℝ) (s : ℕ) : ℝ := if hs : s = 0 then 0 else f ⟨(a, s - 1), by simp [Sa, hs]⟩
  let gb (f : Sb → ℝ) (s : ℕ) : ℝ := if hs : s = 0 then 0 else f ⟨(b, s - 1), by simp [Sb, hs]⟩
  have hga : Measurable ga := measurable_pi_iff.mpr (fun s ↦ by dsimp [ga]; split_ifs; exacts [measurable_const, measurable_pi_apply _])
  have hgb : Measurable gb := measurable_pi_iff.mpr (fun s ↦ by dsimp [gb]; split_ifs; exacts [measurable_const, measurable_pi_apply _])
  have heqa : (fun ω s ↦ rewardByCount A R a s ω) = (fun ω ↦ ga (fun (p : Sa) ↦ X p ω)) := by
    ext ω s; dsimp [ga, X]; cases s <;> rfl
  have heqb : (fun ω s ↦ rewardByCount A R b s ω) = (fun ω ↦ gb (fun (p : Sb) ↦ X p ω)) := by
    ext ω s; dsimp [gb, X]; cases s <;> rfl
  rw [heqa, heqb]
  exact (iIndepFun.indepFun_pi h_i h_dis).comp hga hgb
