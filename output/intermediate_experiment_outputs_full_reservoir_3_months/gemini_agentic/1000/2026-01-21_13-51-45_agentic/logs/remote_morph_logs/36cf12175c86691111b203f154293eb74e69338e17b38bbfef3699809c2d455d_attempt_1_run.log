  let φ (f : ℕ → ℝ) (s : ℕ) : ℝ := if s = 0 then 0 else f (s - 1)
  have hφ : Measurable φ := measurable_pi_iff.mpr (fun s ↦ by cases s <;> simp [φ]; fun_prop)
