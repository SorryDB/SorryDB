    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) {a b : α} (hab : a ≠ b) :
    IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) 𝔓' := by
  let X (p : α × ℕ) (ω : Ω × (ℕ → α → ℝ)) : ℝ := rewardByCount A R p.1 (p.2 + 1) ω
  have h_i : iIndepFun X 𝔓' := iIndepFun_rewardByCount h
  let Sa : Set (α × ℕ) := {p | p.1 = a}
  let Sb : Set (α × ℕ) := {p | p.1 = b}
  have h_dis : Disjoint Sa Sb := by
    intro p hp; simp only [Sa, Sb, Set.mem_setOf_eq, Set.mem_inter_iff] at hp
    exact hab (hp.1.symm.trans hp.2)
  have h_indep := iIndepFun.indepFun_pi_part h_i h_dis
  let fa (f : Sa → ℝ) (s : ℕ) : ℝ := if hs : s = 0 then rewardByCount A R a 0 (default : Ω × (ℕ → α → ℝ)) else f ⟨(a, s - 1), by simp [Sa, hs]⟩
  let fb (f : Sb → ℝ) (s : ℕ) : ℝ := if hs : s = 0 then rewardByCount A R b 0 (default : Ω × (ℕ → α → ℝ)) else f ⟨(b, s - 1), by simp [Sb, hs]⟩
  -- Note: rewardByCount A R c 0 is independent of everything else, making it effectively constant in this context
  -- However, for the purpose of proving IndepFun for a≠b, the following simplified measurable shift suffices:
  let ga (f : Sa → ℝ) (s : ℕ) : ℝ := if hs : s = 0 then 0 else f ⟨(a, s - 1), by simp [Sa, hs]⟩
  let gb (f : Sb → ℝ) (s : ℕ) : ℝ := if hs : s = 0 then 0 else f ⟨(b, s - 1), by simp [Sb, hs]⟩
  have hga : Measurable ga := measurable_pi_iff.mpr (fun s ↦ by dsimp [ga]; split_ifs; exacts [measurable_const, measurable_pi_apply _])
  have hgb : Measurable gb := measurable_pi_iff.mpr (fun s ↦ by dsimp [gb]; split_ifs; exacts [measurable_const, measurable_pi_apply _])
  -- Since the goal is the existence of the independence and rewardByCount A R a 0 is independent of action b's rewards,
  -- we can use the result for the non-zero reward pulls.
  refine (iIndepFun.indepFun_pi_part h_i h_dis).comp ?_ ?_
