theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  -- two parts:
  -- (1) log x ≤ π x + 1
  -- (2) This implies that it is not bounded
  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
        by_cases hn : n = 0
        · rw [hn] at hxge hxlt ⊢
          simp at hxlt ⊢
          exact Real.log_nonpos hxge hxlt.le
        · have hx_pos : 0 < x := (Nat.cast_pos.mpr (Nat.pos_of_ne_zero hn)).trans_le hxge
          refine (Real.log_le_log hx_pos hxlt.le).trans ?_
          have h2 : Real.log (n + 1) = ∑ k ∈ Ico 1 (n + 1), (Real.log (k + 1) - Real.log k) := by
            rw [sum_Ico_succ_sub (by linarith)]
            simp [Real.log_one]
          rw [h2, Ico_succ_right (Nat.succ_le_iff.mpr (Nat.pos_of_ne_zero hn))]
          refine sum_le_sum fun k hk ↦ ?_
          have hk_pos : 0 < (k : ℝ) := by
            have : 1 ≤ k := (mem_Icc.mp hk).1
            norm_cast
          have h_log := Real.log_le_sub_one_of_pos (div_pos (by linarith) hk_pos)
          rwa [Real.log_div (by linarith) hk_pos.ne', add_div, div_self hk_pos.ne', one_div] at h_log
      _ ≤ primeCountingReal x + 1 := by sorry
