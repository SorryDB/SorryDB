import Mathlib.Tactic

import ProblemExtraction

problem_file {
  tags := [.NumberTheory]
}

/-!
# International Mathematical Olympiad 2022, Problem 3

Let k be a positive integer and let S be a finite set of odd prime
integers. Prove that there is at most one way (up to rotation and reflection)
to place the elements of S around a circle such that the product of any
two neighbors is of the form x² + x + k for some positive integer x.

-/

namespace Imo2022P3


open scoped Finset

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := S.card
  if h1 : n = 1 then
    left; haveI : NeZero #S := ⟨by omega⟩
    use 0; intro j
    apply Subtype.ext
    exact Finset.card_le_one_iff.1 (by omega) (p₂ j).2 (p₁ (j + 0)).2
  else if h2 : n = 2 then
    left; haveI : NeZero #S := ⟨by omega⟩
    let i := p₁.symm (p₂ 0)
    use i; intro j
    have hi : p₁ i = p₂ 0 := p₁.symm_apply_eq.1 rfl
    have hS_mem : ∀ x : S, x = p₁ 0 ∨ x = p₁ 1 := by
      intro x; let k := p₁.symm x; have : k.val < 2 := by rw [← h2]; exact k.2
      rw [h2] at k; fin_cases k <;> simp [k]
    have hj : j = 0 ∨ j = 1 := by rw [h2] at j; fin_cases j; exacts [or_inl rfl, or_inr rfl]
    have hi2 : i = 0 ∨ i = 1 := by rw [h2] at i; fin_cases i; exacts [or_inl rfl, or_inr rfl]
    rcases hj with rfl | rfl <;> rcases hi2 with rfl | rfl <;> simp [hi, h2]
    · rcases hS_mem (p₂ 1) with h | h
      · exfalso; have : (1 : Fin #S) = 0 := p₂.injective (h.trans hi.symm); rw [h2] at this; contradiction
      · exact h
    · rcases hS_mem (p₂ 1) with h | h
      · exact h
      · exfalso; have : (1 : Fin #S) = 0 := p₂.injective (h.trans hi.symm); rw [h2] at this; contradiction
  else
    sorry

