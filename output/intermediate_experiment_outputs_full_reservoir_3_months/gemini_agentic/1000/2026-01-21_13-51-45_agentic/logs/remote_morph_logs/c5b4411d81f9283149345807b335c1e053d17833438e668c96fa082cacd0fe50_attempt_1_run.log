    have : #S = 2 := hn2
    revert i j; rw [this]; intro i j
    have h_univ : Finset.univ.map p₂ = Finset.univ.map p₁ := by simp
    have h_2 : (Finset.univ : Finset (Fin 2)) = {0, 1} := by ext x; fin_cases x <;> simp
    rw [this, h_2] at h_univ; simp at h_univ
    fin_cases i <;> fin_cases j <;> simp_all
  else
    sorry

