    haveI : NeZero n := ⟨by omega⟩
    let i := p₁.symm (p₂ 0)
    use i; intro j
    revert p₁ p₂ i j; rw [h_card2]; intro p₁ p₂ i j
    fin_cases j <;> fin_cases i <;> simp
