section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  by_cases h : biasedIsFixedPoint net x
  · exact ⟨nil x, h⟩
  · obtain ⟨i, hi⟩ := Classical.not_forall.mp h
    have h_lt : biasedEnergy net (biasedUpdateState net x i) < biasedEnergy net x := by
      have h_le := biasedEnergy_decreasing net x i
      have h_ne : biasedEnergyDiff net x i ≠ 0 := fun h_eq => hi ((biasedEnergy_fixed_point_iff_no_change net x i).mp h_eq)
      have h_lt_diff : biasedEnergyDiff net x i < 0 := h_le.lt_of_ne h_ne
      rwa [biasedEnergyDiff, sub_lt_zero] at h_lt_diff
    obtain ⟨seq, h_fp⟩ := biased_asynchronous_update_convergence (biasedUpdateState net x i)
    exact ⟨cons x i seq, h_fp⟩
termination_by x => (Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net x)).card
decreasing_by
  simp_wf
  classical
  apply Finset.card_lt_card
  apply Finset.ssubset_of_subset_of_exists
  · intro y; simp; intro hy; exact hy.trans h_lt
  · use biasedUpdateState net x i; simp [h_lt]
```
