  · exact ⟨BiasedUpdateSeq.nil x, h⟩
  · have : ∃ i, biasedUpdateState net x i ≠ x := Classical.not_forall.mp h
    let ⟨i, hi⟩ := this
    have h_lt : biasedEnergy net (biasedUpdateState net x i) < biasedEnergy net x := by
      have h_diff_neg : biasedEnergyDiff net x i < 0 :=
