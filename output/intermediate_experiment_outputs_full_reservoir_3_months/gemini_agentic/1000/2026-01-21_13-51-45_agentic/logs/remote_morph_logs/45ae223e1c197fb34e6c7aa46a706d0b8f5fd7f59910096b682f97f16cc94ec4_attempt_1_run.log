all finite `p`. -/
lemma memLp_id_semicircleReal (p : ℝ≥0) : MemLp id p (semicircleReal μ v) := by
  refine memLp_of_mem_interior_integrableExpSet ?_ p
  have c0 : integrableExpSet id (semicircleReal μ v) = Set.univ := by
    ext t; simp [integrableExpSet]
    have c01 : Integrable (fun (x : ℝ) ↦ Real.exp (t * x)) (semicircleReal μ v) := by
      set S := Icc (μ - 2 * √v) (μ + 2 * √v)
      have c011 : ∀ x, x ∈ S → |Real.exp (t * x)| ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by sorry
      refine Integrable.of_bound (C := Real.exp (|t| * (|μ| + 2 * √v)))
        (Real.continuous_exp.comp (continuous_id.const_mul t)).aestronglyMeasurable
        (ae_of_all _ (fun _ => by rw [Real.abs_exp]; positivity)) ?_
      have hS : (semicircleReal μ v) Sᶜ = 0 := by
        by_cases h : v = 0
        · simp [h, semicircleReal_zero_var, S]
        · rw [semicircleReal_apply _ h, setLIntegral_eq_zero_iff (measurable_semicirclePDF μ v)]
          exact ae_of_all _ (fun x hx ↦ ENNReal.ofReal_eq_zero.mpr
            (Function.nmem_support.mp (mt (support_semicirclePDF_inc μ v) hx)))
      exact ae_iff.mpr hS |>.mono fun x hx ↦ c011 x hx
    refine Integrable.of_bound (C := Real.exp (|t| * (|μ| + 2 * √v)))
      (Real.continuous_exp.comp (continuous_abs.const_mul t)).aestronglyMeasurable
      (ae_of_all _ (fun _ => by rw [Real.abs_exp]; positivity)) ?_
    filter_upwards [ae_iff.mpr (by
      set S := Icc (μ - 2 * √v) (μ + 2 * √v)
      by_cases h : v = 0
      · simp [h, semicircleReal_zero_var, S]
      · rw [semicircleReal_apply _ h, setLIntegral_eq_zero_iff (measurable_semicirclePDF μ v)]
        exact ae_of_all _ (fun x hx ↦ ENNReal.ofReal_eq_zero.mpr
          (Function.nmem_support.mp (mt (support_semicirclePDF_inc μ v) hx))))] with x hx
    rw [Real.abs_exp, Real.exp_le_exp]
    calc t * |x| ≤ |t| * |x| := mul_le_mul_of_nonneg_right (le_abs_self t) (abs_nonneg x)
