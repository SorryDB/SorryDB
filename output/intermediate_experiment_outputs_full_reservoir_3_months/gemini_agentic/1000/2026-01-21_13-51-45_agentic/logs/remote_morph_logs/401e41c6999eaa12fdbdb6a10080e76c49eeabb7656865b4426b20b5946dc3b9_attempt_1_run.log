lemma h_k_n_lt_n_of_class_formula {q n : ℕ} {S' : Set (ConjClasses Rˣ)} (A : S')
    (h_card : Fintype.card R = q ^ n) (H : ∃ x y : R, x ≠ y) (h_n : n ≠ 0)
    (h_n_k_A_dvd : n_k A ∣ n) (this : ∀ (A : ↑S'), Fintype.card ↑(↑A).carrier * (q ^ n_k A - 1) = q ^ n - 1) :
    n_k A < n := by
  have hq_gt_1 : 1 < q := Nat.one_lt_of_one_lt_pow n (h_card.symm ▸ Fintype.one_lt_card_iff.mpr H)
  have h_nk_pow_gt_1 : 1 < q ^ n_k A :=
    Nat.one_lt_pow (Nat.pos_of_dvd_of_pos (h_n_k_A_dvd A) (Nat.pos_of_ne_zero h_n)) hq_gt_1
  have h_lt : q ^ n_k A - 1 < q ^ n - 1 := by
    rw [← this A]
    exact Nat.lt_mul_of_one_lt_left (Nat.sub_pos_of_lt h_nk_pow_gt_1) A.2
  exact (Nat.pow_lt_pow_iff_right hq_gt_1).mp (Nat.lt_of_sub_lt_sub h_lt)

theorem wedderburn (h: Fintype R): IsField R := by
  -- Z is a finite field ...
  let Z := center R

  -- .. and we can view R as a vector space of dimension n over R
  obtain ⟨n, h_card⟩ := VectorSpace.card_fintype Z R

