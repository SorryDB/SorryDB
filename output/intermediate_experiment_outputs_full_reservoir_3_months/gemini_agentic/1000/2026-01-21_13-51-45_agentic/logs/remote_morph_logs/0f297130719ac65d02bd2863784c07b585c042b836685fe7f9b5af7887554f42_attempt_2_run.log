/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  rw [ContinuousLinearMap.smul_apply]
  simp only [deriv, LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk']
  calc
    ∑ μ, ∑ ν, (SpaceTime.distDeriv μ (Λ • A) ε ν) • Lorentz.CoVector.basis μ ⊗ₜ[ℝ]
        Lorentz.Vector.basis ν
      = ∑ μ, ∑ ν, ((Λ • (∑ ρ, Λ⁻¹.1 ρ μ • SpaceTime.distDeriv ρ A (Λ⁻¹ • ε))) ν) •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
      simp_rw [SpaceTime.distDeriv_comp_lorentz_action]
    _ = ∑ μ, ∑ ν, (∑ κ, Λ.1 ν κ * (∑ ρ, Λ⁻¹.1 ρ μ * SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ)) •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
      simp_rw [Lorentz.Vector.smul_eq_sum, Lorentz.Vector.apply_sum, Pi.smul_apply,
        smul_eq_mul, Finset.sum_smul, Finset.mul_sum]
      rfl
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ) •
        (Λ⁻¹.1 ρ μ • Lorentz.CoVector.basis μ) ⊗ₜ[ℝ] (Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      refine Finset.sum_congr rfl (fun μ _ => ?_)
      refine Finset.sum_congr rfl (fun ν _ => ?_)
      rw [Finset.sum_smul]
      refine Finset.sum_congr rfl (fun κ _ => ?_)
      rw [Finset.sum_smul]
      refine Finset.sum_congr rfl (fun ρ _ => ?_)
      rw [smul_tmul, tmul_smul, tmul_smul, smul_smul, smul_smul]
      congr 1; simp only [smul_eq_mul]; ring
    _ = ∑ κ, ∑ ρ, (SpaceTime.distDeriv ρ A (Λ⁻¹ • ε) κ) • (Λ • Lorentz.CoVector.basis ρ) ⊗ₜ[ℝ]
        (Λ • Lorentz.Vector.basis κ) := by
      conv_lhs => enter [2, μ]; rw [Finset.sum_comm]
      conv_lhs => rw [Finset.sum_comm]
      conv_lhs => enter [2, κ, 2, μ]; rw [Finset.sum_comm]
      conv_lhs => enter [2, κ]; rw [Finset.sum_comm]
      simp_rw [sum_tmul, tmul_sum, Finset.smul_sum, Lorentz.CoVector.smul_basis,
        Lorentz.Vector.smul_basis]
    _ = Λ • (deriv A (Λ⁻¹ • ε)) := by
      simp_rw [Tensorial.smul_prod, deriv]
      simp only [LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk',
        Finset.smul_sum, Finset.sum_comm]
      rfl

end DistElectromagneticPotential
