      simp [xk, y1, hyz]
    · have y2 : y = 4 * k + 1 := by
        have := Int.natAbs_eq_iff.1 hy
        rcases this with this | this <;> linarith [hS.2.2]
      have : 4 * x + y = 1 := by nlinarith [h_prod, y2, k_pos k]
      linarith [hS.2.1, k_pos k]
  · intro ht
    simp [ht, IsFixedPt, secondInvo, secondInvo_fun, Subtype.ext_iff]
