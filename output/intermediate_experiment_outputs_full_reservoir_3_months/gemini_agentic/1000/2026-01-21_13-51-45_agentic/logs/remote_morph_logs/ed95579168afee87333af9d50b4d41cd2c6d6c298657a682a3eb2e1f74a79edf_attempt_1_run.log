theorem eq_of_mem_fixedPoints : fixedPoints (secondInvo k) = singletonFixedPoint k := by
  ext t
  constructor
  · intro ht
    rcases t with ⟨⟨⟨x, y, z⟩, hS⟩, hU⟩
    simp only [IsFixedPt, secondInvo, secondInvo_fun, Subtype.mk.injEq] at ht
    have hyz : y = z := by linarith [ht]
    have h_prod : y * (4 * x + y) = 4 * k + 1 := by rw [← hS.1, hyz]; ring
    have h_dvd : y.natAbs ∣ 4 * k + 1 := by
      rw [← Int.natAbs_ofNat (4 * k + 1), ← h_prod, Int.natAbs_mul]
      apply dvd_mul_right
    rcases hk.out.eq_one_or_self_of_dvd _ h_dvd with hy | hy
    · have y1 : y = 1 := by
        have : 0 < y := hS.2.2
        rw [Int.natAbs_eq_iff] at hy
        rcases hy with hy | hy <;> linarith
      have xk : x = k := by linarith [h_prod, y1]
      simp only [singletonFixedPoint, Finset.mem_singleton]
      refine Subtype.ext (Subtype.ext ?_)
      simp [xk, y1, hyz]
    · have y2 : y = 4 * k + 1 := by
        have : 0 < y := hS.2.2
        rw [Int.natAbs_eq_iff] at hy
        rcases hy with hy | hy <;> linarith
      have : 4 * x + y = 1 := by
        rw [y2] at h_prod
        nlinarith
      linarith [hS.2.1, k_pos k]
  · intro ht
    simp only [singletonFixedPoint, Finset.mem_singleton] at ht
    rw [ht]
    simp [IsFixedPt, secondInvo, secondInvo_fun]
