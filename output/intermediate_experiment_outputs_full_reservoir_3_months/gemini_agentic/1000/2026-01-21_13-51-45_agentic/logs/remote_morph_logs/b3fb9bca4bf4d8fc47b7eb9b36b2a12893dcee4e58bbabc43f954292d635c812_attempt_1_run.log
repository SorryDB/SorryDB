    have h_nzr : Real.sqrt 3 - Complex.I ≠ 0 := by
      intro h; have := (Complex.ext_iff.1 h).1; simp at this;
      have := Real.sqrt_eq_zero.1 this; norm_num at this
    field_simp [h_nzr]; ring_nf; simp [h_sq, Complex.I_sq]; ring
  have h_z_prod : ∀ n, 1 ≤ n → z (n + 2) = z n * z (n + 1) := by
    intro n hn
    simp [z, h₂ n hn]; field_simp [h_ia n, h_ia (n + 1), h_ia (n + 2)]; ring
  have h_z_fib : ∀ n, z (n + 2) = z 1 ^ fib n * z 2 ^ fib (n + 1) := by
    intro n; induction n using Nat.fib.induction_two_step with
    | h0 => simp [fib_zero, fib_one]
    | h1 => simp [fib_one, fib_two, h_z_prod 1 (by norm_num)]
    | h2 n ih1 ih2 => rw [fib_add_two, pow_add, fib_add_two, pow_add, h_z_prod (n + 2) (by norm_num), ih1, ih2]; ring
  have h_z2009 : z 2009 = 1 := by
    rw [h_z_fib 2007, hz1]
    have h1 : fib 2007 % 4 = 2 := by native_decide
    have h2 : fib 2008 % 6 = 3 := by native_decide
    have h_z1_p4 : z 1 ^ 4 = 1 := by rw [hz1]; ring_nf; simp [Complex.I_sq]
    have h_z2_p6 : z 2 ^ 6 = 1 := by rw [show z 2 ^ 6 = (z 2 ^ 3) ^ 2 by ring, hz2_pow3]; ring
    rw [← mod_add_div (fib 2007) 4, pow_add, pow_mul, h_z1_p4, h1, ← mod_add_div (fib 2008) 6, pow_add, pow_mul, h_z2_p6, h2]
    simp [hz2_pow3]; ring_nf; simp [Complex.I_sq]
  have h_a2009 : a 2009 = 0 := by
    simp [z] at h_z2009; field_simp [h_ia 2009] at h_z2009
    have : 2 * (a 2009 : ℂ) * Complex.I = 0 := by linear_combination h_z2009
    norm_cast at this; simpa using this
  simp [h_a2009]

