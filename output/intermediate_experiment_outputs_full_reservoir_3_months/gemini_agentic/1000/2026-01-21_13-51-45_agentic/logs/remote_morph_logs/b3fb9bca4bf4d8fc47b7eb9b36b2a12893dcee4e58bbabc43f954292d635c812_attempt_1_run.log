    rw [this]; field_simp [h_ia 1]
  have hz2 : z 2 = (Real.sqrt 3 + Complex.I) / (Real.sqrt 3 - Complex.I) := by
    simp [z, h₁]; have h_nz : (Real.sqrt 3 : ℂ) ≠ 0 := by norm_cast; norm_num
    field_simp [h_nz, h_ia 2]; ring
  have hz2_pow3 : z 2 ^ 3 = -1 := by
    rw [hz2]
