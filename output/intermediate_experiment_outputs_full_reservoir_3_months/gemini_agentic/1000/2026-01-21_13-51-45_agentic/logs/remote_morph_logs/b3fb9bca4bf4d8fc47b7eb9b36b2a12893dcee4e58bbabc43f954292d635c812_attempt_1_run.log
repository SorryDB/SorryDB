theorem amc12a_2009_p25 (a : ℕ → ℝ) (h₀ : a 1 = 1) (h₁ : a 2 = 1 / Real.sqrt 3)
  (h₂ : ∀ n, 1 ≤ n → a (n + 2) = (a n + a (n + 1)) / (1 - a n * a (n + 1))) : abs (a 2009) = 0 := by
  let z : ℕ → ℂ := fun n => (1 + a n * Complex.I) / (1 - a n * Complex.I)
  have h_ia : ∀ n, 1 - (a n : ℂ) * Complex.I ≠ 0 := by
    intro n h
    have : (1 - (a n : ℂ) * Complex.I).re = 0 := by rw [h]; simp
    simp at this
