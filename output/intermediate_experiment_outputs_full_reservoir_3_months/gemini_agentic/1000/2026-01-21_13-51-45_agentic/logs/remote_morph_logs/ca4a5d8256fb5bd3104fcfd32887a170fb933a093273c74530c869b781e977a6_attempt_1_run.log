theorem bound_factorial {n : ℕ} (hn : 1 < n):
  ↑n.factorial > e * (↑n / e) ^ n := by
  induction' n, hn using Nat.le_induction with n hn ih
  · -- Base case: n = 2
    have h_e : 2 < e := by { rw [e]; exact exp_gt_one_add_x 1 one_ne_zero }
    have h_e_pos : 0 < e := by { rw [e]; exact exp_pos 1 }
    rw [Nat.factorial_two, Nat.cast_two, div_pow, pow_two, mul_div, div_lt_iff h_e_pos]
    exact (mul_lt_mul_left zero_lt_two).mpr h_e
  · -- Inductive step
    rw [Nat.factorial_succ, Nat.cast_mul, Nat.cast_add, Nat.cast_one]
    have h_e_pos : 0 < e := by rw [e]; exact exp_pos 1
    have h1 : (1 + 1 / (n : ℝ)) ^ n ≤ e := by
      rw [e]; exact add_one_pow_le_exp 1 n
    have h2 : (n : ℝ) ^ n / e ^ n ≥ (n + 1 : ℝ) ^ n / e ^ (n + 1) := by
      rw [ge_iff_le, div_le_div_iff (pow_pos h_e_pos n) (pow_pos h_e_pos (n + 1))]
      rw [pow_succ e, ← mul_assoc, mul_comm (e ^ n), mul_assoc]
      apply mul_le_mul_of_nonneg_right _ (pow_pos h_e_pos n).le
      rw [← div_le_iff' (pow_pos (by positivity) n), ← div_pow, add_div, div_self (by positivity)]
      exact h1
    calc (n + 1 : ℝ) * ↑n.factorial
      _ > (n + 1 : ℝ) * (e * ((n : ℝ) / e) ^ n) := by
        apply mul_lt_mul_of_pos_left ih
        positivity
      _ = (n + 1 : ℝ) * e * ((n : ℝ) ^ n / e ^ n) := by rw [div_pow]; ring
      _ ≥ (n + 1 : ℝ) * e * ((n + 1 : ℝ) ^ n / e ^ (n + 1)) := by
        apply mul_le_mul_of_nonneg_left h2
        positivity
      _ = e * (n + 1 : ℝ) ^ (n + 1) / e ^ (n + 1) := by
        rw [pow_succ' (n + 1 : ℝ) n]
        field_simp [h_e_pos.ne']
        ring
      _ = e * ((n + 1 : ℝ) / e) ^ (n + 1) := by rw [div_pow]
