theorem bound_factorial {n : ℕ} (hn : 1 < n):
  ↑n.factorial > chapter2.e * (↑n / chapter2.e) ^ n := by
  induction n with
  | zero => linarith
  | succ n ih =>
    if h : n = 1 then
      have he_pos : 0 < e := exp_pos 1
      have he : 2 < e := by
        unfold e; exact add_one_lt_exp (by norm_num : (1 : ℝ) ≠ 0)
      rw [h]
      simp only [Nat.factorial_two, Nat.cast_ofNat, pow_two]
      unfold e at *
      field_simp [he_pos.ne']
      linarith [he]
    else if h_large : 1 < n then
      have n_pos : 0 < (n : ℝ) := Nat.cast_pos.mpr (zero_lt_one.trans h_large)
      have n1_pos : 0 < (n + 1 : ℝ) := Nat.cast_pos.mpr (Nat.succ_pos n)
      have he_pos : 0 < e := exp_pos 1
      simp only [Nat.factorial_succ, Nat.cast_mul, Nat.cast_add, Nat.cast_one]
      refine lt_of_le_of_lt ?_ (mul_lt_mul_of_pos_left (ih h_large) n1_pos)
      unfold e
      rw [div_pow, div_pow, pow_succ (n + 1 : ℝ) n]
      field_simp [he_pos.ne', n_pos.ne', n1_pos.ne']
      rw [mul_comm _ (exp 1), ← mul_assoc]
      apply mul_le_mul_of_nonneg_right n1_pos.le
      rw [← div_le_iff (pow_pos n_pos n), ← div_pow, add_div, div_self n_pos.ne']
      exact (add_one_pow_le_exp (1 / (n : ℝ)) n).trans_le (by rw [one_div_mul_cancel n_pos.ne']; rfl)
    else
      exfalso; linarith
