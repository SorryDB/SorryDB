  n.factorial > e * (n / e) ^ n := by
  induction hn using Nat.le_induction with
  | refl =>
    have he_pos : 0 < e := exp_pos 1
    have h2e : 2 < e := add_one_lt_exp (by norm_num)
    simp only [Nat.factorial_two, Nat.cast_ofNat, pow_two]
    field_simp [he_pos.ne']
    exact (mul_lt_mul_of_pos_left h2e (by norm_num))
  | step m hm ih =>
    have hm_pos : 0 < (m : ℝ) := by positivity
    have hm1_pos : 0 < (m + 1 : ℝ) := by positivity
    have he_pos : 0 < e := exp_pos 1
    simp only [Nat.factorial_succ, Nat.cast_mul, Nat.cast_add, Nat.cast_one]
    refine (mul_lt_mul_of_pos_left ih hm1_pos).trans_le ?_
    field_simp [he_pos.ne', hm_pos.ne', hm1_pos.ne']
    rw [div_le_div_right (by positivity)]
    rw [show (m + 1) * e * m ^ m * e = ((m + 1) * e) * (m ^ m * e) by ring]
    rw [show e * (m + 1) ^ (m + 1) = ((m + 1) * e) * (m + 1) ^ m by ring]
    apply mul_le_mul_of_nonneg_left (by positivity)
    rw [← div_le_iff (pow_pos hm_pos m), ← div_pow, add_div, div_self hm_pos.ne']
    exact (add_one_pow_le_exp (1 / m) m).trans (by rw [mul_one_div_cancel hm_pos.ne']; rfl)
