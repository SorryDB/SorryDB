theorem dedup_sem_pre : ∀ (cl: Circuit F F) (cr:Circuit F (Nat × F)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.eval entry.r.2)) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G hwf hG
  unfold dedup
  have h : ∀ {cl : Circuit F F} {cr : Circuit F (ℕ × F)} {G : List (Entry F (ℕ × F))},
    wf G cl cr → ∀ (n : ℕ) (set : List (Exp F ℕ)), cl ≈ dedup_ cr n set := by
    intros cl' cr' G' hwf'
    induction hwf'
    case nil => intros; simp [dedup_]; rfl
    case eq0 el er cl' cr' hwf_e hwf_c ih =>
      intros n set
      simp [dedup_]
      split_ifs with h_mem
      · apply Equiv.eq0_redundant
        apply ih
      · apply Equiv.eq0_congr hwf_e
        apply ih
