      intros n set
      simp [dedup_]
      apply Equiv.lam_congr
      intro x
      apply ih x (n, x) (n + 1) set
    case share el er kl kr G' hwf_e hwf_k ih =>
      intros n set
      simp [dedup_]
      apply Equiv.share_congr hwf_e
      intro x
      apply ih x (n, x) (n + 1) set
    case is_zero el er kl kr G' hwf_e hwf_k ih =>
      intros n set
      simp [dedup_]
      apply Equiv.is_zero_congr hwf_e
      intro x
      apply ih x (n, x) (n + 1) set
  apply h hwf 0 []
