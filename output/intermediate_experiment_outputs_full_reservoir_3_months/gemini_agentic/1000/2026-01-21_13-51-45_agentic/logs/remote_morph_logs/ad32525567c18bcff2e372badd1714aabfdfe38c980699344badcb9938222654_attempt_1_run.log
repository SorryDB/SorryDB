import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext x
  simp only [Set.mem_setOf_eq, exists_prop, answer]
  constructor
  · rintro ⟨n, hn_pos, A, B, hAB, hA_card, h_inter, h_at_least_2, f, hf_val, hf_count, rfl⟩
    let m y := (Finset.univ.filter (fun i : Fin (2 * n + 1) => y ∈ A i)).card
    have h_sum1 : ∑ y ∈ B, m y = (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, Finset.sum_comm]
      have h1 : ∀ i, (B.filter (fun y => y ∈ A i)).card = 2 * n := by
        intro i; rw [Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (hAB i), hA_card]
      simp [h1, Finset.sum_const, Finset.card_univ, Finset.card_fin, Nat.nsmul_eq_mul]
    have h_sum2 : ∑ y ∈ B, m y * (m y - 1) = (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, Finset.card_eq_sum_ones, Finset.sum_mul, one_mul, Finset.sum_comm (s := B)]
      simp_rw [Finset.sum_comm (s := Finset.univ), Finset.sum_ite, Finset.filter_filter, ← Finset.mem_inter, Finset.filter_mem_eq_inter]
      have h2 : ∀ i, ∑ j ∈ Finset.univ.erase i, (B.filter (fun x => x ∈ A i ∧ x ∈ A j)).card = 2 * n := by
        intro i
        have : ∀ j ∈ Finset.univ.erase i, (B.filter (fun x => x ∈ A i ∧ x ∈ A j)).card = 1 := by
          intro j hj; rw [Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (Finset.inter_subset_left.trans (hAB i)), h_inter i j (Finset.mem_erase.1 hj).1]
        simp [this, Finset.card_univ, Finset.card_fin]
      simp_rw [Finset.sum_erase_eq_sub (Finset.mem_univ _), Finset.filter_filter, ← Finset.mem_inter, Finset.inter_self, Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (hAB _), hA_card]
      simp [h2, Finset.sum_const, Finset.card_univ, Finset.card_fin, Nat.nsmul_eq_mul]
    have hm2 : ∀ y ∈ B, m y = 2 := by
      intro y hy
      have h_m_ge_2 : 2 ≤ m y := by
        rcases h_at_least_2 y hy with ⟨i, j, hij, hi, hj⟩
        have : {i, j} ⊆ Finset.univ.filter (fun k => y ∈ A k) := by
          simp [hij, hi, hj]
        exact (Finset.card_le_card this).trans_le' (by simp [hij])
      have h_sum : ∑ y' ∈ B, m y' * (m y' - 2) = 0 := by
        rw [← Finset.sum_sub_distrib]
        · simp_rw [Nat.mul_sub_left_distrib, Nat.mul_two, h_sum2, h_sum1, Nat.sub_self]
        · intro y' hy'; rcases h_at_least_2 y' hy' with ⟨i, j, hij, hi, hj⟩
          have : {i, j} ⊆ Finset.univ.filter (fun k => y' ∈ A k) := by simp [hij, hi, hj]
          exact Nat.mul_le_mul_left _ ((Finset.card_le_card this).trans_le' (by simp [hij]))
      have := Finset.sum_eq_zero_iff.1 h_sum y hy
      cases Nat.mul_eq_zero.1 this with | h => linarith | h => exact Nat.eq_of_sub_eq_zero h
    have h_sum_f : (2 * n + 1) * n = 2 * (B.filter (fun x => f x = 0)).card := by
      have h1 : ∑ i, ((A i).filter (f · = 0)).card = (2 * n + 1) * n := by
        simp [hf_count, Finset.card_univ, Finset.card_fin, Nat.nsmul_eq_mul]
      have h2 : ∑ i, ((A i).filter (f · = 0)).card = ∑ x ∈ B, if f x = 0 then m x else 0 := by
        simp_rw [Finset.card_filter, Finset.sum_comm, Finset.sum_ite, Finset.filter_filter, Finset.card_eq_sum_ones]
        simp_rw [m, Finset.card_filter, Finset.sum_comm]
        simp [Finset.filter_mem_eq_inter, hAB]
      rw [h1] at h2; rw [h2, Finset.sum_congr rfl (fun x hx => by split_ifs; rw [hm2 x hx]; rfl)]
      simp [Finset.sum_ite, Nat.nsmul_eq_mul]
    have h_even : Even ((2 * n + 1) * n) := ⟨(B.filter (f · = 0)).card, by rw [h_sum_f, mul_comm]⟩
    exact ⟨hn_pos, (Nat.even_mul.1 h_even).resolve_left (by simp [Nat.even_add_one]) |> Nat.even_iff_two_dvd.1⟩
  · rintro ⟨hn_pos, h_dvd⟩
    obtain ⟨k, rfl⟩ := h_dvd; let n := 2 * k; let V := Fin (2 * n + 1)
    let B_set := (Finset.univ : Finset (Finset V)).filter (fun s => s.card = 2)
    have B_inj : Function.Injective (fun s : Finset V => s.sum (fun v => 2 ^ (v : ℕ))) := sorry
    let B := B_set.map ⟨_, B_inj⟩; let A i := (B_set.filter (fun s => i ∈ s)).map ⟨_, B_inj⟩
    use n, hn_pos, A, B, (by intro i; simp [A, B]), (by intro i; sorry), (by intro i j hij; sorry), (by intro x hx; sorry)
    obtain ⟨f, hf⟩ : ∃ f : ℕ → ℕ, (∀ x ∈ B, f x = 0 ∨ f x = 1) ∧ ∀ i, ((A i).filter (f · = 0)).card = n := sorry
    exact ⟨f, hf⟩
