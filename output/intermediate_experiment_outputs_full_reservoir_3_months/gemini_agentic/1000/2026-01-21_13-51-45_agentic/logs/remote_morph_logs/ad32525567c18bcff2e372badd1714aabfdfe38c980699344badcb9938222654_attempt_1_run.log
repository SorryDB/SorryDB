\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  simp only [Set.mem_setOf_eq, exists_prop]
  constructor
  · rintro ⟨n1, hn_pos, A, B, hAB, hA_card, h_inter, h_at_least_2, ⟨f, hf_val, hf_count⟩, rfl⟩
    let m (y : ℕ) : Finset (Fin (2 * n + 1)) := (Finset.univ : Finset (Fin (2 * n + 1))).filter (fun i => y ∈ A i)
    have h2m : ∀ y ∈ B, 2 ≤ (m y).card := by
      intro y hy; rcases h_at_least_2 y hy with ⟨i, j, hij, hi, hj⟩
      have : {i, j} ⊆ m y := by
        intro z hz; simp [m]
        rcases Finset.mem_insert.1 hz with rfl | hz
        · exact hi
        · simp at hz; rwa [hz]
      have h_card_ij : {i, j}.card = 2 := by simp [hij]
      rw [← h_card_ij]
      exact Finset.card_le_of_subset this
    have hm2 : ∀ y ∈ B, (m y).card = 2 := by
      have h_sum1 : ∑ y ∈ B, (m y).card = (2 * n + 1) * (2 * n) := by
        simp_rw [m, Finset.card_filter, Finset.sum_comm]
        have : ∀ i, (B.filter (fun y => y ∈ A i)).card = 2 * n := fun i => by
          rw [Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (hAB i), hA_card]
        simp [this, Finset.card_univ, Finset.card_fin]
      have h_sum2 : ∑ y ∈ B, (m y).card * ((m y).card - 1) = (2 * n + 1) * (2 * n) := by
        simp_rw [m, Finset.card_filter, ← Finset.sum_filter, Finset.sum_comm (s := B), Finset.sum_comm (s := Finset.univ)]
        have : ∀ i j, (B.filter (fun x => x ∈ A i ∧ x ∈ A j)).card = if i = j then 2 * n else 1 := by
          intro i j; by_cases hij : i = j <;> simp [hij, hA_card, h_inter, hAB, Finset.filter_mem_eq_inter, Finset.inter_subset_left]
          rw [h_inter i j hij, Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (Finset.inter_subset_left.trans (hAB i))]
        simp_rw [← Finset.filter_inter, this]
        simp [Finset.sum_ite, Finset.filter_ne, Finset.card_univ, Finset.card_fin, Finset.filter_eq, mul_comm]
      have h_zero : ∑ y ∈ B, (m y).card * ((m y).card - 2) = 0 := by
        rw [← h_sum1, ← h_sum2, ← Finset.sum_sub_distrib]
        apply Finset.sum_congr rfl
        intro y _
        rcases (m y).card with _|_|k <;> simp [Nat.mul_sub_left_distrib]
      intro y hy
      have := (Finset.sum_eq_zero_iff.1 h_zero) y hy
      rcases (m y).card with _|_|k
      · linarith [h2m y hy]
      · linarith [h2m y hy]
      · rfl
    have h_B0 : (2 * n + 1) * n = 2 * (B.filter (fun x => f x = 0)).card := by
      have h_sum : ∑ i, ((A i).filter (fun x => f x = 0)).card = (2 * n + 1) * n := by
        simp [hf_count, Finset.card_univ, Finset.card_fin]
      rw [← h_sum, Finset.sum_comm]
      simp_rw [m, Finset.card_filter, Finset.sum_filter, ← Finset.sum_card_filter]
      have : ∑ x ∈ B, (if f x = 0 then (m x).card else 0) = ∑ x ∈ B, (if f x = 0 then 2 else 0) :=
        Finset.sum_congr rfl (fun x hx => by rw [hm2 x hx])
      rw [this, Finset.sum_ite, Finset.sum_const, Nat.smul_eq_mul, Finset.sum_const_zero, add_zero]
    have : Even ((2 * n + 1) * n) := ⟨(B.filter (fun x => f x = 0)).card, by rw [two_mul, ← h_B0]⟩
    exact ⟨hn_pos, (Nat.even_mul.1 this).resolve_left (by simp)⟩
  · rintro ⟨hn_pos, k, rfl⟩
    let n := 2 * k
    let v := 2 * n + 1
    let V := Fin v
    let B_sets := (Finset.univ : Finset (Finset V)).filter (fun s => s.card = 2)
    let e (s : Finset V) : ℕ := s.sum (fun i => (v + 1) ^ (i.val + 1))
    have h_inj : ∀ s t ∈ B_sets, e s = e t → s = t := sorry
    let B := B_sets.map ⟨e, h_inj⟩
    let A (i : V) := (B_sets.filter (i ∈ ·)).map ⟨e, h_inj⟩
    use n, hn_pos, A, B
    refine ⟨by intro i; simp [A, B], by intro i; simp [A, B_sets]; rcases n with _|_ <;> simp, 
            by intro i j hij; simp [A, B_sets, hij]; sorry, by intro x hx; simp at hx; sorry, ?_⟩
    let f_val (s : Finset V) : ℕ := if ∃ i j, s = {i, j} ∧ ((i.val + v - j.val) % v ≤ k ∨ (j.val + v - i.val) % v ≤ k) then 0 else 1
    let f x := if h : ∃ s ∈ B_sets, e s = x then f_val h.choose else 1
    use f; constructor <;> sorry
