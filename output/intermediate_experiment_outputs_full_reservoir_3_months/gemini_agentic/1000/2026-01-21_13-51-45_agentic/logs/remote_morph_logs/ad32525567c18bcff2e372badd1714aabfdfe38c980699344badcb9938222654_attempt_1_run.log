import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext x
  simp only [Set.mem_setOf_eq, exists_prop, answer]
  constructor
  · rintro ⟨n, hn_pos, A, B, hAB, hA_card, h_inter, h_at_least_2, ⟨f, hf_val, hf_count⟩, rfl⟩
    let m (y : ℕ) : Finset (Fin (2 * n + 1)) := Finset.univ.filter (fun i => y ∈ A i)
    have h2m : ∀ y ∈ B, 2 ≤ (m y).card := by
      intro y hy; rcases h_at_least_2 y hy with ⟨i, j, hij, hi, hj⟩
      have : {i, j} ⊆ m y := by
        intro k hk; simp only [Finset.mem_filter, Finset.mem_univ, true_and]
        rcases Finset.mem_insert.1 hk with rfl|hk <;> [exact hi; simpa using hk]
      have h_card2 : ({i, j} : Finset (Fin (2 * n + 1))).card = 2 := Finset.card_doubleton hij
      exact h_card2.symm.trans_le (Finset.card_le_card this)
    have h_sum1 : ∑ y ∈ B, (m y).card = (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, Finset.sum_comm]
      simp [hA_card, hAB, Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr]
    have h_sum2 : ∑ y ∈ B, (m y).card * ((m y).card - 1) = (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, Finset.card_eq_sum_ones, Finset.sum_mul, one_mul]
      simp_rw [Finset.sum_comm (s := B), Finset.sum_ite, Finset.filter_filter, ← Finset.mem_inter]
      simp_rw [Finset.sum_const, Nat.smul_eq_mul, mul_one]
      have h1 : ∀ i j, i ≠ j → (B.filter (fun x => x ∈ A i ∩ A j)).card = 1 := by
        intro i j hij; rw [Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (Finset.inter_subset_left.trans (hAB i)), h_inter i j hij]
      have h2 : ∀ i, ∑ j ∈ Finset.univ.erase i, (B.filter (fun x => x ∈ A i ∩ A j)).card = 2 * n := by
        intro i; rw [Finset.sum_congr rfl (fun j hj => h1 i j (Finset.mem_erase.1 hj).1)]; simp
      simp_rw [Finset.sum_comm (s := Finset.univ), Finset.sum_erase_eq_sub (Finset.mem_univ _)]
      simp [h2]
    have hm2 : ∀ y ∈ B, (m y).card = 2 := by
      have h0 : ∑ y ∈ B, (m y).card * ((m y).card - 2) = 0 := by
        simp_rw [Nat.mul_sub_left_distrib, Nat.mul_two]
        rw [Finset.sum_sub_distrib (fun y hy => Nat.mul_le_mul_left _ (h2m y hy)), h_sum2, ← h_sum1, Nat.sub_self]
      intro y hy; have := Finset.sum_eq_zero_iff.1 h0 y hy
      rcases Nat.mul_eq_zero.1 this with h|h
      · linarith [h2m y hy]
      · exact Nat.eq_add_of_sub_eq_zero h
    have h_B0 : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      have h_sum : ∑ i, ((A i).filter (f · = 0)).card = (2 * n + 1) * n := by simp [hf_count]
      rw [← h_sum, Finset.sum_comm]
      simp_rw [m, Finset.card_filter, Finset.sum_filter, ← Finset.sum_card_filter]
      have : ∑ x ∈ B, (if f x = 0 then (m x).card else 0) = ∑ x ∈ B, (if f x = 0 then 2 else 0) :=
        Finset.sum_congr rfl (fun x hx => by rw [hm2 x hx])
      rw [this, Finset.sum_ite, Finset.sum_const, Nat.smul_eq_mul, Finset.sum_const_zero, add_zero]
    have h_even : Even ((2 * n + 1) * n) := ⟨(B.filter (f · = 0)).card, by rw [h_B0, two_mul]⟩
    have h_n_even : Even n := (Nat.even_mul.mp h_even).resolve_left (by simp [Nat.even_add_one])
    exact ⟨hn_pos, Nat.even_iff_two_dvd.mpr h_n_even⟩
  · rintro ⟨hn_pos, k, rfl⟩
    let n := 2 * k
    let V := Fin (2 * n + 1)
    let B_set := (Finset.univ : Finset (Finset V)).filter (fun s => s.card = 2)
    let enc (s : Finset V) : ℕ := s.sum (fun v => (2 : ℕ) ^ (v : ℕ))
    have h_enc : Function.Injective enc := sorry
    let A i : Finset ℕ := (B_set.filter (i ∈ ·)).map ⟨enc, h_enc⟩
    let B : Finset ℕ := B_set.map ⟨enc, h_enc⟩
    use n, hn_pos, A, B
    refine ⟨by intro i; simp [A, B], by intro i; simp [A, B_set, n]; sorry, 
      by intro i j hij; simp [A, B_set, hij]; sorry, by intro x hx; simp at hx; sorry, ?_⟩
    let f (x : ℕ) : ℕ := if ∃ s ∈ B_set, enc s = x ∧ ∃ i j, s = {i, j} ∧ 
      ((i.val + (2*n+1) - j.val) % (2*n+1) ≤ k ∨ (j.val + (2*n+1) - i.val) % (2*n+1) ≤ k) then 0 else 1
    use f; constructor
    · intro x _; by_cases hf0 : f x = 0 <;> simp [hf0]
    · intro i; sorry

