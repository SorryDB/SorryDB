import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext x
  simp only [Set.mem_setOf_eq, exists_prop]
  constructor
  · rintro ⟨n, hn_pos, A, B, hAB, hA_card, h_inter, h_at_least_2, f_exists, rfl⟩
    rcases f_exists with ⟨f, hf_val, hf_count⟩
    let m (y : ℕ) := (Finset.univ : Finset (Fin (2 * n + 1))).filter (y ∈ A ·)
    have h_sum1 : ∑ y ∈ B, (m y).card = (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, Finset.sum_comm]
      have : ∀ i, (B.filter (· ∈ A i)).card = 2 * n := by
        intro i; rw [Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (hAB i), hA_card]
      simp_rw [this, Finset.sum_const, Finset.card_univ, Finset.card_fin]
    have h_sum_sq : ∑ y ∈ B, (m y).card ^ 2 = 2 * (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, pow_two, Finset.sum_comm, ← Finset.sum_card_filter, Finset.sum_comm, Finset.filter_filter, ← Finset.mem_inter]
      have h_sum_A : ∀ i j, (B.filter (fun x => x ∈ A i ∩ A j)).card = if i = j then 2 * n else 1 := by
        intro i j; by_cases h : i = j <;> simp [h, hA_card, h_inter, hAB, Finset.filter_mem_eq_inter, Finset.inter_subset_left]
        rw [h_inter i j h, Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (Finset.inter_subset_left.trans (hAB i))]
      simp_rw [h_sum_A, Finset.sum_ite, Finset.filter_eq, Finset.mem_univ, if_true, Finset.card_singleton, Finset.filter_ne, Finset.card_erase, Finset.mem_univ, if_true, Finset.card_univ, Finset.card_fin]
      simp [mul_comm, mul_assoc, mul_left_comm]; ring
    have h2m : ∀ y ∈ B, 2 ≤ (m y).card := by
      intro y hy; rcases h_at_least_2 y hy with ⟨i, j, hij, hi, hj⟩
      have : {i, j} ⊆ m y := by intro z hz; simp [m]; rcases Finset.mem_insert.1 hz with rfl | hz <;> [simp [*]; simp at hz; simp [*]]
      exact (Finset.card_le_card this).trans_at_least (by simp [hij])
    have hm2 : ∀ y ∈ B, (m y).card = 2 := by
      have : ∑ y ∈ B, (m y).card * ((m y).card - 2) = 0 := by
        simp_rw [Nat.mul_sub_left_distrib, ← pow_two, Finset.sum_sub_distrib, h_sum_sq, h_sum1]; ring
      intro y hy
      have := Finset.sum_eq_zero_iff.1 this y hy
      exact (Nat.mul_eq_zero.1 this).resolve_left (h2m y hy).ne'
    have h_B0 : (2 * n + 1) * n = 2 * (B.filter (f · = 0)).card := by
      have h7 : (2 * n + 1) * n = ∑ i, ((A i).filter (fun y => f y = 0)).card := by
        simp [hf_count, Finset.card_univ, Finset.card_fin]
      rw [h7, Finset.sum_card_filter, Finset.sum_comm]
      simp_rw [m, Finset.card_filter, Finset.sum_filter, ← Finset.sum_card_filter]
      have : ∑ x ∈ B, (if f x = 0 then (m x).card else 0) = ∑ x ∈ B, (if f x = 0 then 2 else 0) :=
        Finset.sum_congr rfl (fun x hx => by rw [hm2 x hx])
      rw [this, Finset.sum_ite, Finset.sum_const, Nat.smul_eq_mul, Finset.sum_const_zero, add_zero]
    have : Even ((2 * n + 1) * n) := ⟨_, h_B0⟩
    rcases Nat.even_mul.1 this with h | h
    · simp [Nat.even_add_one] at h
    · exact ⟨hn_pos, h⟩
  · rintro ⟨hn_pos, ⟨k, rfl⟩⟩
    let n := 2 * k; let v := 2 * n + 1; let V := Fin v
    let B_sets := (Finset.univ : Finset (Finset V)).filter (fun s => s.card = 2)
    let e (s : Finset V) : ℕ := s.sum (fun i => (v + 1) ^ i.val)
    let B := B_sets.map ⟨e, sorry⟩
    let A (i : V) := (B_sets.filter (i ∈ ·)).map ⟨e, sorry⟩
    use n, hn_pos, A, B
    refine ⟨by intro i; simp [A, B, B_sets], by intro i; sorry, by intro i j hij; sorry, by intro x hx; sorry, ?_⟩
    let S : Finset ℕ := (Finset.range k).map ⟨(· + 1), by intro x y h; linarith⟩
    let f_val (s : Finset V) : ℕ := if ∃ i j, s = {i, j} ∧ (i.val + v - j.val) % v ∈ S ∪ S.map ⟨(v - ·), sorry⟩ then 0 else 1
    let f x := if h : ∃ s ∈ B_sets, e s = x then f_val h.choose else 1
    use f; constructor <;> sorry
