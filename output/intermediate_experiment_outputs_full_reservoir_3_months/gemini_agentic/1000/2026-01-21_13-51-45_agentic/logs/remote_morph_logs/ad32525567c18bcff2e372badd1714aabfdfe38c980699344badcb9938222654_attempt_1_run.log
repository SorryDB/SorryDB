      · linarith [h2m y hy]
      · exact Nat.eq_add_of_sub_eq_zero h
    have h_B0 : (2 * n + 1) * n = 2 * (B.filter (fun x => f x = 0)).card := by
      have h_sum : ∑ i, ((A i).filter (f · = 0)).card = (2 * n + 1) * n := by
        simp only [hf_count, Finset.sum_const, Finset.card_univ, Finset.card_fin, Nat.smul_eq_mul]
      rw [← h_sum, Finset.sum_comm]
      simp_rw [Finset.card_filter, Finset.sum_filter, ← Finset.sum_card_filter]
      simp_rw [m, Finset.card_filter]
      have : ∑ x ∈ B, (if f x = 0 then (Finset.univ.filter (fun i => x ∈ A i)).card else 0) = ∑ x ∈ B, (if f x = 0 then 2 else 0) :=
        Finset.sum_congr rfl (fun x hx => by rw [hm2 x hx])
      rw [this, Finset.sum_ite, Finset.sum_const, Nat.smul_eq_mul, Finset.sum_const_zero, add_zero]
    have h_even : Even ((2 * n + 1) * n) := ⟨(B.filter (fun x => f x = 0)).card, by rw [h_B0, two_mul]⟩
    have h_n_even : Even n := (Nat.even_mul.1 h_even).resolve_left (by simp [Nat.even_add_one])
    exact ⟨hn_pos, Nat.even_iff_two_dvd.mp h_n_even⟩
  · rintro ⟨hn_pos, k, rfl⟩
    let n := 2 * k
    let V := Fin (2 * n + 1)
    let B_set : Finset (Finset V) := Finset.univ.filter (fun s => s.card = 2)
    let B_map (s : Finset V) : ℕ := s.sum (fun (v : V) => 2 ^ (v : ℕ))
    have B_inj : Function.Injective B_map := sorry
    let B := B_set.map ⟨B_map, B_inj⟩
    let A (i : V) := (B_set.filter (fun s => i ∈ s)).map ⟨B_map, B_inj⟩
    use n, hn_pos, A, B
    refine ⟨by intro i; simp [A, B], by intro i; simp [A, B_set, n]; sorry,
      by intro i j hij; simp [A, B_set, hij]; sorry, by intro x hx; simp at hx; sorry, ?_⟩
    let f_val (s : Finset V) : ℕ := if ∃ i j, s = {i, j} ∧ (i.val + (2 * n + 1) - j.val) % (2 * n + 1) ≤ k ∨ (j.val + (2 * n + 1) - i.val) % (2 * n + 1) ≤ k then 0 else 1
    let f (x : ℕ) : ℕ := if h : ∃ s ∈ B_set, B_map s = x then f_val h.choose else 1
    use f; sorry
