        _ = ∑ x ∈ B, if f x = 0 then m x else 0 := sorry
        _ = ∑ x ∈ B, if f x = 0 then 2 else 0 := by apply Finset.sum_congr rfl; intro x hx; split_ifs; rw [hm2 x hx]; rfl
