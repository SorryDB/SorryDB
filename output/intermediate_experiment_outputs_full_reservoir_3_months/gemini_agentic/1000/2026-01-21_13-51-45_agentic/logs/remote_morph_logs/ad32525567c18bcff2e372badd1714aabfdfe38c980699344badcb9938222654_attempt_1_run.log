import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext x
  simp only [Set.mem_setOf_eq, exists_prop, answer]
  constructor
  · rintro ⟨n, hn_pos, A, B, hAB, hA_card, h_inter, h_at_least_2, ⟨f, hf_val, hf_count⟩, rfl⟩
    let m y := (Finset.univ.filter (fun i => y ∈ A i)).card
    have h2m : ∀ y ∈ B, 2 ≤ m y := by
      intro y hy; rcases h_at_least_2 y hy with ⟨i, j, hij, hi, hj⟩
      have h_sub : {i, j} ⊆ Finset.univ.filter (fun k => y ∈ A k) := by
        simp only [Finset.subset_iff, Finset.mem_insert, Finset.mem_singleton, Finset.mem_filter, Finset.mem_univ, true_and]
        intro k hk; rcases hk with rfl|rfl <;> assumption
      have h_card : ({i, j} : Finset (Fin (2 * n + 1))).card = 2 := by
        rw [Finset.card_insert_of_not_mem, Finset.card_singleton]
        · exact hij
        · simp [hij]
      exact h_card.symm.trans_le (Finset.card_le_card h_sub)
    have h_sum1 : ∑ y ∈ B, m y = (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, Finset.sum_comm]
      simp [hA_card, hAB, Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr, Nat.nsmul_eq_mul]
    have h_sum2 : ∑ y ∈ B, m y * (m y - 1) = (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, Finset.card_eq_sum_ones, Finset.sum_mul, one_mul]
      simp_rw [Finset.sum_comm (s := B), Finset.sum_comm (s := Finset.univ)]
      simp_rw [Finset.sum_ite, Finset.filter_filter, ← Finset.mem_inter, Finset.filter_mem_eq_inter]
      have : ∀ i, ∑ j ∈ Finset.univ.erase i, (Finset.univ.filter (fun x => x ∈ A i ∩ A j)).card = 2 * n := by
        intro i
        simp_rw [Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (Finset.inter_subset_left.trans (hAB i))]
