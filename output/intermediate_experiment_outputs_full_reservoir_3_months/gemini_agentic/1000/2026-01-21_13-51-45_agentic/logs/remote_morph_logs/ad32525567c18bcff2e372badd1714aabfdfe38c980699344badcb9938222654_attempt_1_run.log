import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext x
  simp only [Set.mem_setOf_eq, exists_prop]
  constructor
  · rintro ⟨n, hn_pos, A, B, hAB, hA_card, h_inter, h_at_least_2, ⟨f, hf_val, hf_count⟩, rfl⟩
    let m (y : ℕ) : Finset (Fin (2 * n + 1)) := Finset.univ.filter (fun i => y ∈ A i)
    have h2m : ∀ y ∈ B, 2 ≤ (m y).card := by
      intro y hy
      rcases h_at_least_2 y hy with ⟨i, j, hij, hi, hj⟩
      have h_sub : {i, j} ⊆ m y := by
        intro k hk
        simp only [Finset.mem_insert, Finset.mem_singleton] at hk
        simp only [Finset.mem_filter, Finset.mem_univ, true_and]
        rcases hk with rfl | rfl <;> assumption
      have h_card : ({i, j} : Finset (Fin (2 * n + 1))).card = 2 := by
        rw [Finset.card_insert_of_not_mem, Finset.card_singleton]; simp; exact hij
      exact h_card.symm.trans_le (Finset.card_le_card h_sub)
    have h_sum1 : ∑ y ∈ B, (m y).card = (2 * n + 1) * (2 * n) := by
      simp_rw [m, Finset.card_filter, Finset.sum_comm]
      have h1 : ∀ i, (B.filter (fun y => y ∈ A i)).card = 2 * n := by
        intro i; rw [Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (hAB i), hA_card]
      simp only [h1, Finset.sum_const, Finset.card_univ, Finset.card_fin, Nat.smul_eq_mul]
    have h_sum2 : ∑ y ∈ B, (m y).card * ((m y).card - 1) = (2 * n + 1) * (2 * n) := by
      let S := Finset.univ (α := Fin (2 * n + 1))
      have : ∀ y ∈ B, (m y).card * ((m y).card - 1) = ∑ i ∈ S, ∑ j ∈ S.erase i, if y ∈ A i ∧ y ∈ A j then 1 else 0 := by
        intro y _; rw [m, Finset.card_filter, Finset.card_eq_sum_ones, Finset.sum_mul]
        simp_rw [Finset.sum_const, Nat.smul_eq_mul, mul_one, Finset.card_erase_of_mem (Finset.mem_univ _), Finset.card_univ, Finset.card_fin]
        rfl
      simp_rw [this, Finset.sum_comm (s := B), Finset.sum_comm (s := S)]
      have h1 : ∀ i, ∀ j ∈ S.erase i, ∑ y ∈ B, (if y ∈ A i ∧ y ∈ A j then 1 else 0) = 1 := by
        intro i j hj
        have hij : i ≠ j := Finset.mem_erase.1 hj |>.1
        rw [Finset.sum_ite, Finset.filter_filter, ← Finset.mem_inter, Finset.filter_mem_eq_inter, Finset.inter_eq_left.mpr (Finset.inter_subset_left.trans (hAB i)), h_inter i j hij]
        simp
      simp_rw [h1, Finset.sum_const, Finset.card_erase_of_mem (Finset.mem_univ _), Finset.card_univ, Finset.card_fin, Nat.smul_eq_mul, mul_one]
    have hm2 : ∀ y ∈ B, (m y).card = 2 := by
      have h_sum_m_sq : ∑ y ∈ B, (m y).card * (m y).card = 2 * (2 * n + 1) * (2 * n) := by
        rw [← h_sum1, ← h_sum2]
        simp_rw [Nat.mul_sub_left_distrib, mul_one]
        rw [Finset.sum_sub_distrib]
        · rw [Nat.add_sub_cancel]
        · intro y hy; exact Nat.le_mul_self _
      have h0 : ∑ y ∈ B, (m y).card * ((m y).card - 2) = 0 := by
        simp_rw [Nat.mul_sub_left_distrib, Nat.mul_two]
        rw [Finset.sum_sub_distrib]
        · rw [h_sum_m_sq, ← h_sum1, Nat.mul_two, Nat.sub_self]
        · intro y hy; rw [mul_comm]; exact Nat.mul_le_mul_left 2 (h2m y hy)
