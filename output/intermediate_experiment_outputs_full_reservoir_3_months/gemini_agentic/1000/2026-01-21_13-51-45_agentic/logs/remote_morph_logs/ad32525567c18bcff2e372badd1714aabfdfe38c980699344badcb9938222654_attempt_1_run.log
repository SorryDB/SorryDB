    obtain ⟨f, hf⟩ : ∃ f : ℕ → ℕ, (∀ x ∈ B, f x = 0 ∨ f x = 1) ∧ ∀ i, ((A i).filter (f · = 0)).card = n := sorry
    exact ⟨f, hf, rfl⟩
