  · rintro ⟨hx_pos, k, rfl⟩
    let n := 2 * k
    let V := Fin (2 * n + 1)
    let B_set := (Finset.univ : Finset (Finset V)).filter (fun s => s.card = 2)
    let enc (s : Finset V) : ℕ := s.sum (fun v => 2^v.val)
    have h_enc : ∀ s t, s ∈ B_set → t ∈ B_set → enc s = enc t → s = t := sorry
