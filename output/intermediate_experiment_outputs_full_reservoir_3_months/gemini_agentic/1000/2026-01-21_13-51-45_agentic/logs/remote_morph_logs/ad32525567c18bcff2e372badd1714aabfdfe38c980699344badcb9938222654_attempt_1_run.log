      by intro i j hij; simp [A, B_set, hij]; sorry, by intro x hx; simp at hx; sorry, ?_⟩
    let dist (i j : V) := min ((i.val + (2*n+1) - j.val) % (2*n+1)) ((j.val + (2*n+1) - i.val) % (2*n+1))
    let f_val (s : Finset V) : ℕ := if ∃ i j, s = {i, j} ∧ dist i j ≤ k then 0 else 1
    use (fun x => if h : ∃ s ∈ B_set, enc s = x then f_val h.choose else 1)
    sorry
