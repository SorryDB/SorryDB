import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  unfold answer
  ext n
  constructor
  · rintro ⟨n, hn, A, B, hAB, h1, h2, h3, f, hf, h5, rfl⟩
    let m x := (Finset.univ : Finset (Fin (2 * n + 1))).filter (x ∈ A ·)
    have hm : ∀ x ∈ B, (m x).card = 2 := by
      intro x hx
      have h2m : 2 ≤ (m x).card := by
        rcases h3 x hx with ⟨i, j, hij, hi, hj⟩
        have : {i, j} ⊆ m x := by simp [m, hi, hj]; intro y hy; rcases Finset.mem_insert.1 hy with rfl | h; exact hi; rcases Finset.mem_singleton.1 h with rfl; exact hj
        exact (Finset.card_le_of_subset this).trans_at_least (by simp [hij])
      have h_sum1 : ∑ x in B, ((m x).card : ℤ) = (2 * n + 1) * (2 * n) := by
        simp_rw [m, Finset.card_filter, Finset.sum_comm, ← h1, Finset.sum_const, Finset.card_univ, Finset.length_fin]; norm_cast
      have h_sum2 : ∑ x in B, ((m x).card * ((m x).card - 1) : ℤ) = (2 * n + 1) * (2 * n) := by
        simp_rw [m, Finset.card_filter, ← Finset.card_univ, ← Finset.sum_const, ← h2, Finset.sum_comm]
        simp_rw [Finset.filter_filter, ← Finset.and_assoc, @and_comm (x ∈ A _), Finset.and_assoc, Finset.sum_filter, ← Finset.card_filter, Finset.card_univ, Finset.sum_comm, Finset.sum_itE, h2, Finset.sum_const, Finset.card_univ, Finset.length_fin, Nat.mul_one]; simp
      have : ∑ x in B, ((m x).card : ℤ) * ((m x).card - 2) = 0 := by
        simp_rw [mul_sub_left_distrib, mul_two, ← h_sum2, ← h_sum1, Nat.mul_sub_left_distrib, Nat.mul_one]; simp
      have := (Finset.sum_eq_zero_iff_of_nonneg (fun x hx => by
        have := h2m x hx; apply Int.mul_nonneg; norm_cast; linarith; simp; norm_cast; linarith)).1 this x hx
      obtain rfl | rfl := Int.mul_eq_zero.1 this <;> norm_cast at * <;> linarith
    have h6 : (2 * n + 1) * n = 2 * (B.filter (fun x => f x = 0)).card := by
      rw [← h5, Finset.sum_comm, ← Finset.sum_card_filter]
      simp_rw [Finset.filter_filter, (fun i => Finset.filter_congr (fun x hx => by simp [hAB i hx])), ← Finset.sum_filter, Finset.sum_comm, ← Finset.card_filter, hm, Finset.sum_const, Nat.smul_eq_mul]
    exact ⟨hn, (Nat.even_mul.mp (h6 ▸ ⟨_, rfl⟩)).resolve_left (by decide)⟩
  · rintro ⟨hn, ⟨k, rfl⟩⟩
    let n := 2 * k; let v := 2 * n + 1; let V := Fin v; let E := (Finset.univ : Finset V).powersetLen 2
    let g := (Fintype.equivFin E).toEmbedding
    use n, hn, (fun i => (E.filter (i ∈ ·)).map g), E.map g
    refine ⟨by simp, by simp [Finset.card_powersetLen_filter_mem, v, n], by intro i j hij; simp [hij], ?_, ?_⟩
    · intro x; simp; rintro s hs rfl; rcases Finset.card_powersetLen.mp hs with ⟨hs2, -⟩; have : 1 < s.card := hs2; obtain ⟨i, hi, j, hj, hij⟩ := Finset.exists_two_face this; refine ⟨i, j, hij, ?_, ?_⟩ <;> (simp; exact ⟨s, hs, rfl, by assumption⟩)
    · let f x := if ∃ i j : V, g {i, j} = x ∧ (i.val + v - j.val) % v ∈ Set.Icc 1 k ∪ Set.Icc (n + 1) (n + k) then 0 else 1
      use f; refine ⟨by intro x _; by_cases h : f x = 0 <;> simp [h], by intro i; sorry⟩
