lemma biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField :
    biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
  rw [biasedEnergyDiff, biasedEnergy, biasedEnergy, biasedLocalField]
  let hnet := net.toHopfieldNetwork
  let x' := biasedUpdateState net x i
  let v := toRealVector x
  let v' := toRealVector x'
  let Δxi := (x' i).toReal - (x i).toReal
  have hv : v' = Function.update v i (x' i).toReal := by
    ext j; simp [v', x', toRealVector, biasedUpdateState]; split_ifs with hj; · subst hj; simp; · simp [hj]
  have h_sum : Finset.sum Finset.univ (fun j => (net.thresholds j + net.bias j) * v' j) - 
               Finset.sum Finset.univ (fun j => (net.thresholds j + net.bias j) * v j) =
               (net.thresholds i + net.bias i) * Δxi := by
    rw [hv, ← Finset.sum_subtract_distrib, Finset.sum_eq_single i]
    · simp [Δxi]
    · intro j _ hj; simp [hj]
    · intro hi; exact (hi (Finset.mem_univ i)).elim
  have h_bilin : -0.5 * (Matrix.toBilin' (weightsMatrix hnet) v' v' - Matrix.toBilin' (weightsMatrix hnet) v v) = 
                 -Δxi * (weightsMatrix hnet).mulVec v i := by
    rw [hv, Matrix.toBilin'_update_diag_zero hnet.weightsMatrix_symmetric hnet.weightsMatrix_diagonal_zero]
    simp [Δxi]
  rw [h_bilin, ← sub_eq_add_neg, h_sum, localField]
  ring
```
