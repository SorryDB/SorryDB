lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (symmDiff M P.edgeSet).encard = M.encard + 1 := by
  classical
  let L := P.edge
  have h_nodup : L.Nodup := h.isTrail.edge_nodup
  have h_L_set : P.edgeSet = {e | e ∈ L} := by ext e; simp [WList.edgeSet, L]
  have h_L_card : ∀ (l : List β), l.Nodup → ∀ (p : β → Prop) [DecidablePred p], ({e | e ∈ l ∧ p e} : Set β).encard = (l.filter p).length := by
    intro l hl p _
    induction l with
    | nil => simp
    | cons e l' IH =>
      simp only [List.filter_cons, List.length_cons, List.mem_cons, Set.mem_setOf_eq]
      have h_set_eq : {x | (x = e ∨ x ∈ l') ∧ p x} = (if p e then {e} else ∅) ∪ {x | x ∈ l' ∧ p x} := by
        ext x; split_ifs with he <;> simp [he]
      rw [h_set_eq, encard_union, IH hl.of_cons]
      · split_ifs with he <;> simp [he]
      · split_ifs with he <;> simp [hl]
        exact Set.disjoint_singleton_left.mpr (fun h' ↦ hl.not_mem (List.mem_cons_of_mem _ h'.1))
  have h_alt : (P.edgeSet \ M).encard = (M ∩ P.edgeSet).encard + 1 := by
    rw [h_L_set, Set.diff_eq, Set.inter_comm, ← Set.compl_setOf, h_L_card L h_nodup (· ∉ M), h_L_card L h_nodup (· ∈ M)]
    norm_cast
    have h_non : L ≠ [] := by
      cases P with | nil u => cases h.nonempty | cons u e P' => simp [L, WList.edge]
    have h_head : L.head h_non ∉ M := by
      match P with
      | .nil u => cases h.nonempty
      | .cons u e P' =>
        simp only [WList.edge, List.head_cons]
        intro heM
        apply h.first_not_in
        obtain ⟨v, hl, -⟩ := (cons_isPath_iff.1 h.toIsPath).1
        exact ⟨e, heM, hl.inc_left⟩
    have h_last : L.getLast h_non ∉ M := by
      obtain ⟨P', e, v, hPv⟩ := h.nonempty.exists_concat
      have h_L_last : L.getLast L h_non = e := by
        simp [L, ← hPv, WList.concat_edge, List.getLast_append]
      rw [h_L_last]
      intro heM
      apply h.last_not_in
      have hP := h.toIsPath
      rw [← hPv, concat_isPath_iff] at hP
      obtain ⟨u, hl, -⟩ := hP.1
      exact ⟨e, heM, hl.inc_right⟩
    have h_chain := h.mem_matching_iff
    clear h_nodup h_L_set h_L_card h hM G
    induction L using List.recOn with
    | nil => contradiction
    | cons e L' IH =>
      intro h_non h_head h_last h_chain hl_nodup
      cases L' with
      | nil => simp [h_head]
      | cons f L'' =>
        have h_e_not : e ∉ M := h_head
        have h_f_in : f ∈ M := by
          have := List.isChain_cons.1 h_chain |>.1
          rwa [h_e_not, false_iff] at this
        cases L'' with
        | nil =>
          have : (e :: f :: []).getLast (by simp) = f := rfl
          rw [this] at h_last; contradiction
        | cons g L''' =>
          have h_g_not : g ∉ M := by
            have h_chain_f := List.isChain_cons.1 h_chain |>.2
            have h_chain_g := List.isChain_cons.1 h_chain_f |>.1
            rwa [h_f_in, true_iff] at h_chain_g
          have h_last_g : (g :: L''').getLast (by simp) ∉ M := by
            rwa [List.getLast_cons, List.getLast_cons] at h_last
          have h_chain_g_L := (List.isChain_cons.1 (List.isChain_cons.1 h_chain).2).2
          specialize IH (by simp) h_g_not h_last_g h_chain_g_L hl_nodup.of_cons.of_cons
          simp [h_e_not, h_f_in, IH, Nat.add_comm, Nat.add_assoc]
  have h_disj : Disjoint (M \ P.edgeSet) (P.edgeSet \ M) := Set.disjoint_sdiff_sdiff
  rw [symmDiff_def, encard_union h_disj, h_alt]
  rw [← encard_diff_add_encard_inter M P.edgeSet, add_assoc, add_comm (M ∩ P.edgeSet).encard, ← add_assoc]
