    have h_non : L ≠ [] := h.nonempty_edge
    have h_nodup : L.Nodup := h.isTrail.edge_nodup
    have h_chain := h.mem_matching_iff
    have h_head : L.head h_non ∉ M := fun hm ↦ h.first_not_in ⟨L.head h_non, hm, h.first_mem_V_edge h_non⟩
    have h_last : L.last h_non ∉ M := fun hm ↦ h.last_not_in ⟨L.last h_non, hm, h.last_mem_V_edge h_non⟩
