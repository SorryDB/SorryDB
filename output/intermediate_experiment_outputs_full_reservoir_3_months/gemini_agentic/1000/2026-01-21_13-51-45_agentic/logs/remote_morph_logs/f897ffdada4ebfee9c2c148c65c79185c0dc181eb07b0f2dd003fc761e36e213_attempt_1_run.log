  have h_inter : (M \ P.edgeSet ∪ P.edgeSet \ M) ∩ (P.edgeSet \ M) = P.edgeSet \ M := by ext x; simp; tauto
  have h_diff : (M \ P.edgeSet ∪ P.edgeSet \ M) \ (P.edgeSet \ M) = M \ P.edgeSet := by ext x; simp; tauto
  rw [h_inter, h_diff, ← encard_diff_add_encard_inter M P.edgeSet]
  let L := P.edge
  have h_non : L ≠ [] := by cases P with | nil u => cases h.nonempty | cons u e P' => simp [L]
  have h_alt : (P.edgeSet \ M).encard = (M ∩ P.edgeSet).encard + 1 := by
    have h_len : ∀ (p : β → Prop) [DecidablePred p], ({e | e ∈ L ∧ p e} : Set β).encard = (L.filter p).length := by
      intro p _; rw [← Finset.encard_coe, List.toFinset_card (h_nodup.filter p), List.length_filter]
      congr; ext x; simp [L, WList.edgeSet]
    rw [h_len (fun x ↦ x ∉ M), h_len (fun x ↦ x ∈ M)]
    norm_cast
    have h_chain := h.mem_matching_iff
    have h_head : L.head h_non ∉ M := by
      intro hm; cases P with | nil u => cases h.nonempty | cons u e P' =>
      simp [WList.first, WList.edge] at *; obtain ⟨v, hl, -⟩ := (isWWalk_cons_iff.1 h.isTrail.isWWalk)
      exact h.first_not_in ⟨e, hm, hl.left_mem⟩
    have h_last : L.last h_non ∉ M := by
      intro hm; obtain ⟨P', e, x, rfl⟩ := h.nonempty.exists_concat
      simp [WList.last, WList.edge, WList.concat_edge] at *; obtain ⟨u, hl, -⟩ := (isWWalk_concat_iff.1 h.isTrail.isWWalk).2
      exact h.last_not_in ⟨e, hm, hl.right_mem⟩
    induction L using List.strongInductionOn with | h L IH =>
      obtain rfl | ⟨e, L', rfl⟩ := L.eq_nil_or_cons; · contradiction
      obtain rfl | ⟨f, L'', rfl⟩ := L'.eq_nil_or_cons
      · simp [h_head, h_last]
      · have h_e : e ∉ M := h_head
        have h_f : f ∈ M := (List.isChain_cons.1 h_chain).1 f (by simp) |>.1 h_e
        obtain rfl | ⟨g, L''', rfl⟩ := L''.eq_nil_or_cons
        · have : [e, f].last (by simp) = f := rfl; rw [this] at h_last; contradiction
        · have h_fL'' : (f :: g :: L''').IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := (List.isChain_cons.1 h_chain).2
          have h_g : g ∉ M := (List.isChain_cons.1 h_fL'').1 g (by simp) |>.1 h_f
          have h_g_non : g :: L''' ≠ [] := by simp
          have h_g_last : (g :: L''').last h_g_non ∉ M := by rw [List.last_cons _ h_g_non] at h_last; exact h_last
          simp [h_e, h_f, h_g, IH (g :: L''') (by simp) (List.isChain_cons.1 h_fL'').2 h_g_non h_g h_g_last]
