lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (symmDiff M P.edgeSet).encard = M.encard + 1 := by
  have h_alt : (P.edgeSet \ M).encard = (M ∩ P.edgeSet).encard + 1 := by
    let L := P.edge
    have h_nodup : L.Nodup := h.isTrail.edge_nodup
    have h_mem : ∀ p, ({e ∈ P.edgeSet | p e} : Set β).encard = (L.filter p).length := by
      intro p; rw [←List.toSet_encard (h_nodup.filter p)]; congr; ext e; simp [WList.edgeSet]
    rw [←Set.diff_eq_sep, ←Set.inter_eq_sep, h_mem, h_mem, Set.inter_comm, ←ENat.coe_add, ←ENat.coe_one]; congr 1
    have h_alt_list : ∀ (L : List β) (h_chain : L.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M)) (h_non : L ≠ [])
        (h_head : L.head h_non ∉ M) (h_last : L.last h_non ∉ M),
        (L.filter (· ∉ M)).length = (L.filter (· ∈ M)).length + 1 := by
      intro L; induction L using List.strongInductionOn with | h L IH =>
      intro h_chain h_non h_head h_last
      obtain rfl | ⟨e, L', rfl⟩ := L.eq_nil_or_cons; · contradiction
      obtain rfl | ⟨f, L'', rfl⟩ := L'.eq_nil_or_cons
      · simp at h_head h_last; simp [h_head, h_last]
      · have h_e : e ∉ M := h_head
        have h_f : f ∈ M := (List.isChain_cons.1 h_chain).1 f (by simp) |>.1 h_e
        obtain rfl | ⟨g, L''', rfl⟩ := L''.eq_nil_or_cons
        · have : (e :: f :: [] : List β).last (by simp) = f := rfl
          simp_all
        · have h_g : g ∉ M := (List.isChain_cons.1 (List.isChain_cons.1 h_chain).2).1 g (by simp) |>.1 h_f
          have h_g_non : g :: L''' ≠ [] := by simp
          have h_g_last : (g :: L''').last h_g_non ∉ M := by
            have : (e :: f :: g :: L''').last (by simp) = (g :: L''').last h_g_non := rfl
            rw [←this]; exact h_last
          simp [h_e, h_f, IH (g :: L''') (by simp) (List.isChain_cons.1 (List.isChain_cons.1 h_chain).2).2 h_g_non h_g h_g_last]
    apply h_alt_list P.edge h.mem_matching_iff h.nonempty
    · intro hm; apply h.first_not_in; cases P with | nil x => cases h.nonempty | cons x e P' =>
      exact ⟨e, hm, (WList.isWWalk_cons_iff.1 h.isTrail.isWWalk).1.1.left_mem⟩
    · intro hm; apply h.last_not_in; obtain ⟨P', e, x, rfl⟩ := h.nonempty.exists_concat
      have hw := h.isTrail.isWWalk; rw [WList.isWWalk_concat_iff] at hw
      exact ⟨e, hm, hw.2.1.right_mem⟩
  rw [symmDiff_def, Set.encard_union (Set.disjoint_sdiff_sdiff),
      ←Set.encard_diff_add_encard_inter M P.edgeSet P.edgeSet_finite, h_alt, add_assoc, add_comm 1, ←add_assoc]
