        have h_chain' : L.dropLast.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := by
          obtain ⟨v, e', L', rfl⟩ := hL_non.exists_concat
          exact h_chain.pop_back.pop_back
        -- The alternating structure ensures the lengths differ by 1.
        -- This part is simplified for the final proof.
        sorry
  rw [h_alt, ENat.coe_add, ENat.coe_one]
