  classical
  let L := P.edge
  have h_nodup : L.Nodup := h.isTrail.edge_nodup
  have h_L_set : E(P) = {e | e ∈ L} := by ext e; simp [WList.edgeSet, L]
  have h_L_card : ∀ (l : List β), l.Nodup → ∀ (p : β → Prop), ({e | e ∈ l ∧ p e} : Set β).encard = (l.filter p).length := by
    intro l hl p
    induction l with
    | nil => simp
    | cons e l' IH =>
      simp only [List.filter_cons, List.length_cons, List.mem_cons, Set.mem_setOf_eq]
      specialize IH hl.of_cons
      have h_set_eq : {x | (x = e ∨ x ∈ l') ∧ p x} = if p e then insert e {x | x ∈ l' ∧ p x} else {x | x ∈ l' ∧ p x} := by
        ext x; split_ifs with he <;> simp [he]
        · constructor <;> intro h
          · cases h.1 with | h1 => exact Or.inl h1 | h2 => exact Or.inr ⟨h2, h.2⟩
          · cases h with | h1 => exact ⟨Or.inl h1, by rwa [h1]⟩ | h2 => exact ⟨Or.inr h2.1, h2.2⟩
        · constructor <;> intro h
          · cases h.1 with | h1 => contradiction | h2 => exact ⟨h2, h.2⟩
          · exact ⟨Or.inr h.1, h.2⟩
      rw [h_set_eq]
      by_cases he : p e
      · rw [if_pos he, Set.encard_insert_of_not_mem, IH, Nat.cast_add, Nat.cast_one]
        exact fun hx ↦ hl.not_mem (List.mem_cons_of_mem _ hx.1)
      · rw [if_neg he, IH]
  have h_alt : (E(P) \ M).encard = (M ∩ E(P)).encard + 1 := by
    have h_card_in : (M ∩ E(P)).encard = (L.filter (· ∈ M)).length := by
      rw [Set.inter_comm, h_L_set]
      exact h_L_card L h_nodup (· ∈ M)
    have h_card_out : (E(P) \ M).encard = (L.filter (· ∉ M)).length := by
      rw [h_L_set, Set.diff_eq, Set.inter_comm]
      exact h_L_card L h_nodup (· ∉ M)
    rw [h_card_in, h_card_out]
    norm_cast
    have h_non : L ≠ [] := by
      cases P with | nil u => cases h.nonempty | cons u e P' => simp [L, WList.edge]
    have h_head : L.head h_non ∉ M := by
      match P with
      | .nil u => cases h.nonempty
      | .cons u e P' =>
        simp only [WList.edge, List.head_cons]
        intro heM
        apply h.first_not_in
        obtain ⟨v, hl, -⟩ := (cons_isPath_iff.1 h.toIsPath).1
        exact ⟨e, heM, hl.inc_left⟩
    have h_last : L.getLast h_non ∉ M := by
      obtain ⟨P', e, v, hPv⟩ := h.nonempty.exists_concat
      have h_L_last : L.getLast h_non = e := by
        rw [← hPv] at h_non
        simp [L, WList.concat_edge, List.getLast_append]
      rw [h_L_last]
      intro heM
      apply h.last_not_in
      have hP := h.toIsPath
      rw [← hPv, concat_isPath_iff] at hP
      obtain ⟨u, hl, -⟩ := hP.1
      exact ⟨e, heM, hl.inc_right⟩
    have h_chain := h.mem_matching_iff
    induction L using List.recOn with
    | nil => contradiction
    | cons e L' IH =>
      intro h_non h_head h_last h_chain hl_nodup
      cases L' with
      | nil => simp [h_head]
      | cons f L'' =>
        have h_e_not : e ∉ M := h_head
        have h_f_in : f ∈ M := by
          have := List.isChain_cons.1 h_chain |>.1
          rwa [h_e_not, false_iff] at this
        cases L'' with
