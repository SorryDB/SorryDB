          have h_g_not : (g :: L''').head h_L''_non ∉ M := by
            have := (List.isChain_cons.1 (List.isChain_cons.1 h_chain).2).2.1
            rwa [h_f_in, true_iff] at this
          have h_last_L'' : (g :: L''').getLast h_L''_non ∉ M := by
            rwa [List.getLast_cons, List.getLast_cons] at h_last
          have h_chain_L'' : (g :: L''').IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) :=
            (List.isChain_cons.1 (List.isChain_cons.1 h_chain).2).2
          specialize IH h_L''_non h_g_not h_last_L'' h_chain_L'' hl_nodup.of_cons.of_cons
          simp [h_e_not, h_f_in, IH, Nat.add_comm, Nat.add_assoc]
  have h_disj : Disjoint (M \ E(P)) (E(P) \ M) := Set.disjoint_sdiff_sdiff
  rw [symmDiff_def, Set.encard_union h_disj, h_alt]
  have h_M_eq : M.encard = (M \ E(P)).encard + (M ∩ E(P)).encard := by
    rw [← Set.encard_union Set.disjoint_diff_inter, Set.diff_union_inter]
  rw [h_M_eq, add_assoc, add_comm (M ∩ E(P)).encard, ← add_assoc]
