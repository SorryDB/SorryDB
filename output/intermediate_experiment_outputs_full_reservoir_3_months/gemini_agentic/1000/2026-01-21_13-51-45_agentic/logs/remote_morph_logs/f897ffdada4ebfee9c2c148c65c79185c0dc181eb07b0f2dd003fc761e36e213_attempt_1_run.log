    have h_non := h.nonempty_edge
    have h_chain := h.mem_matching_iff
    have h_head : L.head h_non ∉ M := fun hm ↦
      h.first_not_in (mem_V_of_mem_edge _ hm (h.first_mem_V_edge h_non))
    have h_last : L.last h_non ∉ M := fun hm ↦
      h.last_not_in (mem_V_of_mem_edge _ hm (h.last_mem_V_edge h_non))
    induction L using List.reverseRecOn with
    | nil => cases h_non rfl
    | last e L IH =>
      obtain rfl | hL_non := L.eq_nil_or_nonempty
      · simp [h_head]
      · have h_e : e ∉ M := h_last
