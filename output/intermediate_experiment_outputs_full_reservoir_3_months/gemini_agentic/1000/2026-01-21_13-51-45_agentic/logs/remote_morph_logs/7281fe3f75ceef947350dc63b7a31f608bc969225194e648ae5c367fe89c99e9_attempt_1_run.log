lemma matchingMatroid.seriesPair_of_adj (h_ines : ∀ x, G.inessential x) (h_adj : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  let M := G.matchingMatroid
  have h_ne : x ≠ y := h_adj.ne
  obtain ⟨Mx, hMx, hx⟩ := h_ines x
  obtain ⟨My, hMy, hy⟩ := h_ines y
  have hB : ∀ B, M.Basis B → (B ∩ {x, y}).Nonempty := by
    intro B hB
    obtain ⟨m, hm, rfl⟩ := hB.exists_isMatchable
    obtain ⟨e, he⟩ := h_adj
    by_contra! h_disj
    have hB_eq : B = V(G, m) := hB.indep.subset.antisymm (hB.maximal ⟨m, hm, rfl.subset⟩ hB.indep.subset)
    have he_m : e ∉ m := fun he_m ↦ h_disj.1 (hB_eq.symm ▸ V_mem_V_matching he_m .left)
    have hm' : G.IsMatching (insert e m) := by
      refine ⟨insert_subset he.subset hm.subset, fun f hf g hg hne ↦ ?_⟩
      obtain rfl | hf := hf <;> obtain rfl | hg := hg
      · exact (hne rfl).elim
      · rw [he.symm, disjoint_comm]
        exact hm.disjoint_inter_V hg (not_or.mp (h_disj.symm.subset (hB_eq.symm ▸ V_mem_V_matching hg .left))).1
      · rw [he.symm]
        exact hm.disjoint_inter_V hf (not_or.mp (h_disj.symm.subset (hB_eq.symm ▸ V_mem_V_matching hf .left))).1
      · exact hm.disjoint hf hg hne
    exact (encard_lt_encard_insert he_m).not_le (hm.max_encard_le_of_isMaxMatching (G.isMaxMatching_V_basis hB) hm')
  rw [Matroid.Series, Matroid.Parallel, M.dual_isNonloop_iff, M.dual_isNonloop_iff]
  refine ⟨?_, ?_, ?_⟩
  · rw [Matroid.dual_closure_eq_dual_closure_iff_isCocircuit h_ne, Matroid.isCocircuit_iff_forall_basis]
    · exact ⟨h_B, fun s hs ↦ by obtain rfl | rfl := hs
        <;> [exists V(G, Mx), G.isMaxMatching_V_basis hMx, hx; exists V(G, My), G.isMaxMatching_V_basis hMy, hy]⟩
    · exact (M.eRk_mono (subset_diff_singleton (subset_univ _) hx)).antisymm' (G.isMaxMatching_V_basis hMx).eRk_eq_eRank.symm
    · exact (M.eRk_mono (subset_diff_singleton (subset_univ _) hy)).antisymm' (G.isMaxMatching_V_basis hMy).eRk_eq_eRank.symm
  · exact (M.eRk_mono (subset_diff_singleton (subset_univ _) hx)).antisymm' (G.isMaxMatching_V_basis hMx).eRk_eq_eRank.symm
  · exact (M.eRk_mono (subset_diff_singleton (subset_univ _) hy)).antisymm' (G.isMaxMatching_V_basis hMy).eRk_eq_eRank.symm
