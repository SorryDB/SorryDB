lemma matchingMatroid.seriesPair_of_adj (h_ines : ∀ x, G.inessential x) (h_adj : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  set M := G.matchingMatroid
  have hnx : ¬ M.IsColoop x := matchingMatroid.noColoop h_ines h_adj.left_mem
  have hny : ¬ M.IsColoop y := matchingMatroid.noColoop h_ines h_adj.right_mem
  have hne : x ≠ y := h_adj.ne
  rw [Matroid.Series, Matroid.Parallel, M.dual_isNonloop_iff, M.dual_isNonloop_iff]
  refine ⟨?_, hnx, hny⟩
  rw [M.dual.closure_eq_closure_iff_isCircuit hne (M.dual_isNonloop_iff.mpr hnx) (M.dual_isNonloop_iff.mpr hny)]
  rw [Matroid.isCircuit_iff_forall_basis]
  · refine ⟨fun B hB ↦ ?_, fun s hs ↦ ?_⟩
    · by_contra! h_miss
      obtain ⟨m, hm, hBm⟩ := hB.indep
      have hM_max : G.IsMaxMatching m := by
        rw [isMaxMatching_iff, IsMatching_iff]
        refine ⟨hm, fun m' hm' ↦ ?_⟩
        rw [← hm.encard_le, ← IsMaxMatching.encard (G.isMaxMatching_V_basis hB)]
        sorry
      have hxy : x ∉ V(G, m) ∧ y ∉ V(G, m) := by
        simpa [subset_def] using h_miss
      exact hM_max.not_isMaxMatching_of_adj_not_mem h_adj hxy.1 hxy.2
    · obtain rfl | rfl := hs
      · obtain ⟨Mx, hMx, hx⟩ := h_ines x
        exists V(G, Mx).diff {y} -- This is not necessarily a basis, but this is the idea
        sorry
      · obtain ⟨My, hMy, hy⟩ := h_ines y
        exists V(G, My).diff {x}
        sorry
  · exact M.dual_isNonloop_iff.mpr hnx
  · exact M.dual_isNonloop_iff.mpr hny
