        exact (hm.max _ h_aug.augment).not_lt h_aug.augment_encard
      obtain ⟨B, hB, hBm⟩ := (⟨m.toIsMatching, hm.toIsMatching, subset_rfl⟩ : M.Indep (V(G, m))).exists_basis_subset
