lemma matchingMatroid.seriesPair_of_adj (hi : ∀ x, G.inessential x) (ha : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  let M := G.matchingMatroid
  rename_i hi' ha'
  obtain ⟨e, he⟩ := ha'
  have hne : x ≠ y := he.ne
  have h_inter : ∀ B, M.Basis B → (B ∩ {x, y}).Nonempty := by
    intro B hB
    by_contra! h_miss
    obtain ⟨m, hm, hBm⟩ := hB.indep
    have hx : x ∉ V(G, m) := fun hx ↦ h_miss.1 (hBm hx)
    have hy : y ∉ V(G, m) := fun hy ↦ h_miss.2 (hBm hy)
    let P := WList.cons x e (.nil y)
    have hP : G.IsAugPath hm P := isAugPath_of_singleEdge he hx hy hne
    have h_indep : M.Indep (B ∪ {x, y}) := by
      refine ⟨m ∆ E(P), hP.augment, ?_⟩
      intro z hz
      obtain hzB | rfl | rfl := hz
      · exact hP.augment_vertex_subset (hBm hzB)
      · exact ⟨e, by simp [P], he.left_mem⟩
      · exact ⟨e, by simp [P], he.right_mem⟩
    have := hB.eq_of_subset h_indep (Set.subset_union_left _ _)
    exact h_miss.1 (this.symm ▸ Set.mem_union_right B (Set.mem_insert x {y}))
  apply Matroid.IsCocircuit.series (y := y) _ hne
  rw [Matroid.isCocircuit_iff_forall_basis (by simp [M, he.left_mem, he.right_mem])]
  refine ⟨h_inter, fun s hs ↦ ?_⟩
  obtain rfl | rfl := hs
  · obtain ⟨B, hB, hBy⟩ : ∃ B, M.Basis B ∧ y ∉ B := by
      rw [← Matroid.exists_basis_not_mem_iff_not_coloop]
      exact matchingMatroid.noColoop hi' he.right_mem
    refine ⟨B, hB, ?_⟩
    have hx_in : x ∈ B := by
      obtain ⟨z, hz⟩ := h_inter B hB
      obtain rfl | rfl := hz <;> [assumption, contradiction]
    ext z; constructor <;> simp (config := {contextual := true}) [hx_in, hBy]
  · obtain ⟨B, hB, hBx⟩ : ∃ B, M.Basis B ∧ x ∉ B := by
      rw [← Matroid.exists_basis_not_mem_iff_not_coloop]
      exact matchingMatroid.noColoop hi' he.left_mem
    refine ⟨B, hB, ?_⟩
    have hy_in : y ∈ B := by
      obtain ⟨z, hz⟩ := h_inter B hB
      obtain rfl | rfl := hz <;> [contradiction, assumption]
    ext z; constructor <;> simp (config := {contextual := true}) [hy_in, hBx]
