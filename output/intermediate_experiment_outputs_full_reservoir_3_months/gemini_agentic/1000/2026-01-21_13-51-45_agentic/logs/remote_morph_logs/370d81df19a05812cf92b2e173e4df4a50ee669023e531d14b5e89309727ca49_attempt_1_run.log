import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let n := A.card
  let s (a : A) : ℕ := (Finset.univ.filter (fun k => (a : ℤ) ∈ B k)).card
  let c (I : Finset (Fin m)) (a : A) : ℕ := (I.filter (fun k => (a : ℤ) ∈ B k)).card
  have h_m_pos : 0 < m := by linarith
  have h_B_nonempty (k : Fin m) : (B k).Nonempty := by
    by_contra h_emp
    have h_sum := hB k
    rw [Finset.not_nonempty_iff_eq_empty] at h_emp
    rw [h_emp, Finset.sum_empty] at h_sum
    have : 0 < (m : ℤ) ^ ((k : ℕ) + 1) := pow_pos (by norm_cast; linarith) _
    linarith
  have h_n_pos : 0 < n := by
    have h0 := h_B_nonempty ⟨0, h_m_pos⟩
