    have hf : ∀ I, f I ∈ Fintype.piFinset (fun a : A => Icc 0 (s a)) := by
      intro I a; simp [c, s, card_le_card, filter_subset_filter, filter_subset]
    have h_dom : (univ : Finset (Finset (Fin m))).card = 2 ^ m := by simp
    have h_codom : (Fintype.piFinset (fun a : A => Icc 0 (s a))).card = ∏ a : A, (s a + 1) := by
