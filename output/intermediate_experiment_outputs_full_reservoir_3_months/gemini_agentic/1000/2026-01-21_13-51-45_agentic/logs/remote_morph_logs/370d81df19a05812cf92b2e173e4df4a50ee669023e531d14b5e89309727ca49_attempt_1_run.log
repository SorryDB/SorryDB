import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  let n := #A
  let x (k : Fin m) (a : A) : ℤ := if (a : ℤ) ∈ B k then 1 else 0
  have h_sum (k : Fin m) : ∑ a : A, x k a * (a : ℤ) = m ^ (k + 1 : ℕ) := by
    simp only [x, ite_mul, one_mul, zero_mul, ← hB k]
    exact sum_subtype A (λ a => (a : ℤ) ∈ B k) (λ a => (a : ℤ))
  let s (I : Finset (Fin m)) (a : A) : ℤ := ∑ k in I, x k a
  have h_subset_sum (I : Finset (Fin m)) : ∑ a : A, s I a * (a : ℤ) = ∑ k in I, m ^ (k + 1 : ℕ) := by
    simp only [s, sum_mul, sum_comm]
    apply sum_congr rfl
    intro k hk
    exact h_sum k
  have h_distinct : Function.Injective (λ I : Finset (Fin m) => ∑ k in I, m ^ (k + 1 : ℕ)) := by
    intro I J h
    refine Nat.posPow_finset_sum_field_injective (by linarith) (λ k => k + 1) (by simp) ?_
    norm_cast
  have h_map_inj : Function.Injective (λ I : Finset (Fin m) => (λ a : A => s I a)) := by
    intro I J h
    apply h_distinct
    simp_rw [← h_subset_sum]
    congr
    ext a
    exact congr_fun h a
  have h_range (I : Finset (Fin m)) (a : A) : s I a ∈ Icc 0 (m : ℤ) := by
    simp only [s, mem_Icc]
    constructor
    · apply sum_nonneg; intro k _; split_ifs <;> linarith
    · refine (sum_le_sum (λ k _ => (by split_ifs <;> linarith : x k a ≤ 1))).trans ?_
      simp only [sum_const, nsmul_eq_mul, mul_one, card_finset_fin]
      exact (I.card_le_univ).trans (by simp)
  have : (2 : ℚ) ^ (m : ℕ) ≤ (m + 1 : ℚ) ^ n := by
    have h_card_dom : #(univ : Finset (Finset (Fin m))) = 2 ^ m := by simp
    have h_card_codom : #(Fintype.piFinset (λ _ : A => Icc (0 : ℤ) m)) = (m + 1) ^ n := by
      simp only [card_piFinset, card_Icc, sub_zero, n_succ_sub_n, Nat.card_eq_fintype_card, card_fin]
      rw [← Nat.cast_add_one, Nat.cast_inj]
      rfl
    have h_inj : (univ : Finset (Finset (Fin m))).card ≤ (Fintype.piFinset (λ _ : A => Icc (0 : ℤ) m)).card := by
      apply card_le_card_of_inj_on (λ I a => s I a)
      · intro I _; simp only [mem_piFinset, h_range, forall_const]
      · intro I _ J _ h; exact h_map_inj h
    norm_cast at h_inj h_card_dom h_card_codom
    rw [h_card_dom, h_card_codom] at h_inj
    exact Nat.cast_le.mpr h_inj
  by_contra h_lt
  simp only [not_le] at h_lt
  have : (m + 1 : ℚ) ^ n < 2 ^ m := by
    apply (pow_lt_pow_left (by linarith) (by linarith) h_lt).trans_le
    rw [← pow_mul, ← pow_mul]
    have : (m + 1 : ℚ) ≤ 4 ^ (1 / 2 : ℚ) := by
      if hm3 : m ≤ 3 then
        cases m <;> try linarith
        case succ m' => cases m' <;> try linarith
        case succ m'' => cases m'' <;> try linarith
      else
        sorry -- Requires more complex analysis for m > 3
    sorry
  linarith

