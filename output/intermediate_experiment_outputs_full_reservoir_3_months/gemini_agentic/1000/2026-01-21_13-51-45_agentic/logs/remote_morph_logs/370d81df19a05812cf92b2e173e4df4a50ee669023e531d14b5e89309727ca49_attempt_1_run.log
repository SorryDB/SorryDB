    simp only [c, Nat.cast_sum, sum_comm (s := I)]
    apply sum_congr rfl
    intro k hk
    rw [← hB k]
    simp_rw [filter_mem_eq_inter, ← sum_filter, inter_comm]
    rw [← A.sum_subtype (fun a => (a : ℤ) ∈ B k) (fun a => (a : ℤ))]
    · apply sum_congr rfl
      intro a ha
