theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro h
    have h_alg : Algebraic K L := IsCyclotomicExtension.isAlgebraic {n | (n : K) ≠ 0} K L
    refine ⟨h_alg, IsAlgClosed.of_exists_root h_alg (fun f hf ↦ ?_)⟩
    let E := f.splittingField
    haveI : Finite E := Polynomial.IsSplittingField.finite K E
    let n := Nat.card E - 1
    have hn_pos : 0 < n := Nat.sub_pos_of_lt Finite.one_lt_card
    have hn : (n : K) ≠ 0 := by
      haveI : Fintype E := Fintype.ofFinite E
      have : (Nat.card E : K) = 0 := (algebraMap K E).injective (by rw [map_natCast, FiniteField.cast_card_eq_zero E])
      rw [Nat.cast_sub (Nat.one_le_of_lt Finite.one_lt_card), this, Nat.cast_one, zero_sub, neg_ne_zero]
      exact one_ne_zero
    obtain ⟨ζ, hζ⟩ := h.exists_prim_root (show n ∈ {n | (n : K) ≠ 0} from hn)
    have h_splits : (Polynomial.X * (Polynomial.X ^ n - 1) : K[X]).Splits (algebraMap K L) :=
      (Polynomial.splits_X _).mul (hζ.splits_X_pow_sub_one hn_pos)
    have h_dvd : f ∣ Polynomial.X * (Polynomial.X ^ n - 1) := by
      letI : Fintype E := Fintype.ofFinite E
      apply (hf.dvd_iff_has_root (algebraMap K E)).mpr
      obtain ⟨x, hx⟩ := Polynomial.IsSplittingField.exists_root E f hf.ne_zero hf.degree_ne_zero
      use x, hx
      rw [Polynomial.IsRoot, Polynomial.eval_mul, Polynomial.eval_X, Polynomial.eval_sub, Polynomial.eval_pow, Polynomial.eval_X, Polynomial.eval_one, ← pow_succ, Nat.sub_add_cancel (Nat.one_le_of_lt Finite.one_lt_card), FiniteField.pow_card_eq_self E x, sub_self, mul_zero]
    have hf_splits_L : f.Splits (algebraMap K L) := Polynomial.splits_of_dvd (algebraMap K L) h_splits h_dvd
    exact Polynomial.exists_root_of_splits hf_splits_L hf.not_isUnit (Polynomial.map_ne_zero hf.ne_zero)
  · intro h
    have h_alg : Algebraic K L := h.alg
    haveI : IsAlgClosed L := h.closed
    refine ⟨fun {n} hn ↦ IsAlgClosed.exists_isPrimitiveRoot n.pos ((algebraMap K L).injective.ne hn), fun x ↦ ?_⟩
    by_cases hx : x = 0
    · rw [hx]; exact Subalgebra.zero_mem _
    · let Kx := Algebra.adjoin K {x}
      haveI : Finite Kx := Finite.of_finite_dimensional K Kx
      let n := Nat.card Kx - 1
      have hn_pos : 0 < n := Nat.sub_pos_of_lt Finite.one_lt_card
      have hn_mem : (n : K) ≠ 0 := by
        haveI : Fintype Kx := Fintype.ofFinite Kx
        have : (Nat.card Kx : K) = 0 := (algebraMap K Kx).injective (by rw [map_natCast, FiniteField.cast_card_eq_zero Kx])
        rw [Nat.cast_sub (Nat.one_le_of_lt Finite.one_lt_card), this, Nat.cast_one, zero_sub, neg_ne_zero]
        exact one_ne_zero
      obtain ⟨ζ, hζ⟩ := IsAlgClosed.exists_isPrimitiveRoot hn_pos ((algebraMap K L).injective.ne hn_mem)
      have hxn : x ^ n = 1 := by
        let x_val : Kx := ⟨x, Algebra.subset_adjoin (Set.mem_singleton x)⟩
        have : x_val ^ (Nat.card Kx - 1) = 1 := by
          haveI : Fintype Kx := Fintype.ofFinite Kx
          let x' : Kxˣ := Units.mk0 x_val (by intro h; injection h; contradiction)
          have : x' ^ (Fintype.card Kx - 1) = 1 := by rw [← Fintype.card_units, pow_card_eq_one]
          exact_mod_cast (congr_arg Units.val this)
        exact_mod_cast this
      obtain ⟨i, hi⟩ := hζ.eq_pow_of_pow_eq_one (by exact_mod_cast hxn)
      rw [hi]; exact Subalgebra.pow_mem _ (Algebra.subset_adjoin ⟨n, hn_mem, hζ⟩) i
