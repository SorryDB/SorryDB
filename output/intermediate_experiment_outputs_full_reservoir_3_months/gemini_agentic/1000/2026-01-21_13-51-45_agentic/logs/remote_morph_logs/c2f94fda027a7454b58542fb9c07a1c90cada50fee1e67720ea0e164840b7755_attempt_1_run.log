import Mathlib.NumberTheory.Cyclotomic.Basic
import Mathlib.FieldTheory.FiniteField.Basic

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro h
    haveI h_alg : Algebraic K L := h.isAlgebraic
    refine ⟨IsAlgClosed.of_algebraic_root h_alg (fun f hf ↦ ?_), h_alg⟩
    let E := f.SplittingField
    letI : Fintype E := splittingField.fintype f
    let n := Fintype.card E - 1
    have hEn : 1 < Fintype.card E := Fintype.one_lt_card_iff_nontrivial.mpr inferInstance
    have hn : (n : K) ≠ 0 := by
      letI : CharP E (ringChar K) := charP_of_injective_algebraMap (algebraMap K E).injective (ringChar K)
      rw [← RingHom.char_nonzero_iff (algebraMap K E), ringChar.spec E n]
      intro h_n_zero
      have : (Fintype.card E : E) = 0 := FiniteField.cast_card_eq_zero E
      have h_n_cast : (n : E) = -1 := by
        rw [Nat.cast_sub (Nat.one_le_of_lt hEn), Nat.cast_one, this, zero_sub]
      intro hnk
      have : (n : E) = 0 := by rw [← (algebraMap K E).map_natCast n, hnk, RingHom.map_zero]
      rw [this] at h_n_cast; exact one_ne_zero (neg_eq_zero.mp h_n_cast.symm)
    obtain ⟨ζ, hζ⟩ := h.exists_root (show n ∈ {n | (n : K) ≠ 0} from hn)
    have h_splits : (X ^ n - 1 : K[X]).Splits (algebraMap K L) := hζ.splits_X_pow_sub_one
    have h_splits_X : (X * (X ^ n - 1) : K[X]).Splits (algebraMap K L) :=
      Polynomial.Splits.mul (splits_X (algebraMap K L)) h_splits
    have h_roots : f ∣ X * (X ^ n - 1) := by
      letI : Algebra E L := h.isAlgebraic.toAlgebra
      letI : IsScalarTower K E L := IsScalarTower.of_algebraMap_eq (fun _ ↦ rfl)
      have : ∀ x : E, x ^ (Fintype.card E) = x := FiniteField.pow_card_eq_self
      have : ∀ x : E, (X * (X ^ n - 1) : E[X]).eval x = 0 := fun x ↦ by
        rw [eval_mul, eval_X, eval_sub, eval_pow, eval_X, eval_one, mul_sub, mul_one, ← pow_succ,
          Nat.sub_add_cancel (Nat.one_le_of_lt hEn), this, sub_self]
      have h_f_roots : ∀ x ∈ (f.map (algebraMap K E)).roots, x ∈ (X * (X ^ n - 1) : E[X]).roots :=
        fun x hx ↦ mem_roots_iff (by positivity).mpr |>.mpr (this x)
      have h_f_splits : (f.map (algebraMap K E)).Splits (RingHom.id E) := splittingField.splits f
      exact (Polynomial.splits_iff_roots_eq_range_rootSet _).mp h_f_splits ▸ (dvd_iff_roots_subset_of_splits h_f_splits (by positivity)).mpr h_f_roots |> (map_dvd_iff (algebraMap K E) (algebraMap K E).injective).mp
    obtain ⟨x, hx⟩ := exists_root_of_splits h_splits_X hf.not_isUnit h_roots
    exact ⟨x, hx⟩
  · intro h
    haveI := h.isAlgClosed
    haveI := h.algebraic
    refine ⟨fun {n} hn ↦ IsAlgClosed.exists_isPrimitiveRoot n.pos (by rwa [← RingHom.char_nonzero_iff (algebraMap K L)]),
      fun x ↦ ?_⟩
    by_cases hx : x = 0
    · rw [hx]; exact Subalgebra.zero_mem _
    · let Kx := adjoin K {x}
      haveI : Finite Kx := Finite.of_finite_dimensional K Kx
      obtain ⟨n, -, hn2, hxn⟩ := FiniteField.is_root_of_unity_iff.mp (show (⟨x, subset_adjoin (Set.mem_singleton x)⟩ : Kx) ≠ 0 by
        intro h; injection h; contradiction)
      obtain ⟨ζ, hζ⟩ := IsAlgClosed.exists_isPrimitiveRoot (L := L) n.pos (by rwa [← RingHom.char_nonzero_iff (algebraMap K L)])
      obtain ⟨i, hi⟩ := hζ.eq_pow_of_pow_eq_one (by exact_mod_cast hxn)
      rw [hi]; exact Subalgebra.pow_mem _ (subset_adjoin ⟨n, hn2, hζ⟩) _
