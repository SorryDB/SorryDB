module

public import Mathlib.NumberTheory.Cyclotomic.Basic

@[expose] public section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro h
    haveI := h.isAlgebraic
    refine ⟨IsAlgClosed.of_algebraic_root h.isAlgebraic (fun f hf ↦
      let n : ℕ+ := ⟨Finite.card f.SplittingField - 1, Nat.sub_pos_of_lt (Finite.one_lt_card_iff_nontrivial.mpr inferInstance)⟩
      let ⟨r, hr⟩ := h.exists_root (n := n) (by simpa [n, FiniteField.cast_card_eq_zero K f.SplittingField] using neg_ne_zero.mpr (one_ne_zero (R := K)))
      let e := FiniteField.algEquivOfCardEq (K := K) (A := f.SplittingField) (B := adjoin K {r}) (by rw [FiniteField.card_adjoin_isPrimitiveRoot hr, hr.card_root_of_unity, Nat.card_eq_fintype_card]; rfl)
      let ⟨root, hroot⟩ := exists_root_of_splits (splittingField.splits f) hf.not_isUnit
      ⟨e root, by rw [← hroot, AlgEquiv.map_polynomial_root]; rfl⟩), h.isAlgebraic⟩
  · intro h
    refine ⟨fun {n} hn ↦ @IsAlgClosed.exists_isPrimitiveRoot _ _ _ h.isAlgClosed n n.pos (by rwa [← RingHom.char_nonzero_iff (algebraMap K L)]),
      fun x ↦ if hx : x = 0 then hx.symm ▸ Subalgebra.zero_mem _ else
        letI : Finite (adjoin K {x}) := FiniteField.finite_adjoin_of_finite K (h.algebraic x)
        let ⟨n, _, hxn⟩ := FiniteField.is_root_of_unity (⟨x, subset_adjoin (Set.mem_singleton x)⟩ : adjoin K {x}) (by intro h; injection h; contradiction)
        let ⟨r, hr⟩ := @IsAlgClosed.exists_isPrimitiveRoot _ _ _ h.isAlgClosed n n.pos (by rwa [← RingHom.char_nonzero_iff (algebraMap K L)])
        let ⟨i, _, hxi⟩ := hr.eq_pow_of_pow_eq_one (by exact_mod_cast hxn)
        adjoin_mono (Set.singleton_subset_iff.mpr ⟨n, hr⟩) (hxi.symm ▸ Subalgebra.pow_mem _ (subset_adjoin (Set.mem_singleton r)) _)⟩

