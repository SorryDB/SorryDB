public import Mathlib.NumberTheory.Cyclotomic.Basic

@[expose] public section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro h
    have h_alg : Algebraic K L := h.isAlgebraic
    refine ⟨IsAlgClosed.of_algebraic_root h_alg (fun f hf ↦ ?_), h_alg⟩
    let E := f.SplittingField
    haveI : Finite E := Polynomial.IsSplittingField.finite K E
    let n := Nat.card E - 1
    have hn_pos : 0 < n := Nat.sub_pos_of_lt Finite.one_lt_card
    have hn : (n : K) ≠ 0 := by
      have : (Nat.card E : K) = 0 := CharP.cast_card_eq_zero K E
      rw [← Nat.cast_one, ← Nat.cast_sub (Nat.one_le_of_lt Finite.one_lt_card), this, zero_sub, neg_ne_zero]
      exact one_ne_zero
    obtain ⟨ζ, hζ⟩ := h.exists_prim_root (show n ∈ {n | (n : K) ≠ 0} from hn)
    have h_splits : (X ^ n - 1 : K[X]).Splits (algebraMap K L) := hζ.splits_X_pow_sub_one hn_pos
    have h_splits' : (X * (X ^ n - 1) : K[X]).Splits (algebraMap K L) := (Polynomial.splits_X _).mul h_splits
    have : f ∣ X * (X ^ n - 1) := by
      refine (Polynomial.map_dvd_iff (algebraMap K E) (algebraMap K E).injective).mp ?_
      have hf_splits : (f.map (algebraMap K E)).Splits (RingHom.id E) := Polynomial.IsSplittingField.splits E f
      have h_ne_zero : (X * (X ^ n - 1) : E[X]) ≠ 0 := by
        refine Polynomial.mul_ne_zero Polynomial.X_ne_zero (Polynomial.X_pow_sub_one_ne_zero hn_pos)
      refine (Polynomial.dvd_iff_roots_subset_of_splits hf_splits h_ne_zero).mpr (fun x hx ↦ ?_)
      rw [Polynomial.mem_roots_iff h_ne_zero, Polynomial.eval_mul, Polynomial.eval_X, Polynomial.eval_sub, Polynomial.eval_pow, Polynomial.eval_X, Polynomial.eval_one,
        mul_sub, mul_one, ← pow_succ, Nat.sub_add_cancel (Nat.one_le_of_lt Finite.one_lt_card),
        CharP.pow_card_eq_self K E x, sub_self]
    obtain ⟨x, hx⟩ := Polynomial.exists_root_of_splits h_splits' hf.not_isUnit this
    exact ⟨x, hx⟩
  · intro h
    haveI := h.isAlgClosed
    haveI := h.algebraic
    refine ⟨fun {n} hn ↦ IsAlgClosed.exists_isPrimitiveRoot n.pos (by rwa [← RingHom.char_nonzero_iff (algebraMap K L)]),
      fun x ↦ ?_⟩
    by_cases hx : x = 0
    · rw [hx]; exact Subalgebra.zero_mem _
    · let Kx := Algebra.adjoin K {x}
      haveI : Finite Kx := Finite.of_finite_dimensional K Kx
      let n := Nat.card Kx - 1
      have hn_mem : (n : K) ≠ 0 := by
        have : (Nat.card Kx : K) = 0 := CharP.cast_card_eq_zero K Kx
        rw [← Nat.cast_one, ← Nat.cast_sub (Nat.one_le_of_lt Finite.one_lt_card), this, zero_sub, neg_ne_zero]
        exact one_ne_zero
      obtain ⟨ζ, hζ⟩ := IsAlgClosed.exists_isPrimitiveRoot (L := L) (Nat.sub_pos_of_lt Finite.one_lt_card) (by rwa [← RingHom.char_nonzero_iff (algebraMap K L)])
      have hxn : x ^ n = 1 := by
        let x' : Kxˣ := Units.mk0 ⟨x, Algebra.subset_adjoin (Set.mem_singleton x)⟩ (by intro h; injection h; contradiction)
        have : x' ^ n = 1 := by
          letI : Fintype Kx := Fintype.ofFinite Kx
          rw [← Fintype.card_units, pow_card_eq_one]; rfl
        exact_mod_cast (congr_arg (Units.val) this)
      obtain ⟨i, hi⟩ := hζ.eq_pow_of_pow_eq_one (by exact_mod_cast hxn)
      rw [hi]; exact Subalgebra.pow_mem _ (Algebra.subset_adjoin ⟨n, hn_mem, hζ⟩) _

