/-- Let `A` be a Noetherian ring satisfying `HeightOneLocalizationIsPID`. Then two finitely
generated torsion `A`-modules `M`, `N` are pseudo-isomorphic if and only if their localizations
at all height one primes are isomorphic. -/
theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  obtain ⟨ιM, _, pM, hM1, eM, _, hMps⟩ := hMT.isPseudoIsomorphic_pi
  obtain ⟨ιN, _, pN, hN1, eN, _, hNps⟩ := hNT.isPseudoIsomorphic_pi
  constructor
  · intro h p hp
    have hM_loc := hMps.localizedModule_equiv p hp
    have hN_loc := hNps.localizedModule_equiv p hp
    have hMN_loc := h.localizedModule_equiv p hp
    exact ⟨hM_loc.symm.trans (hMN_loc.trans hN_loc)⟩
  · intro h
    refine hMps.trans (HasPseudoIsomorphism.trans ?_ hNps.symm)
    have : ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 → Nonempty (LocalizedModule p.1.primeCompl ((i : ιM) → A ⧸ (pM i).1 ^ eM i) ≃ₗ[Localization p.1.primeCompl] LocalizedModule p.1.primeCompl ((i : ιN) → A ⧸ (pN i).1 ^ eN i)) := by
      intro p hp
      exact ⟨(hMps.localizedModule_equiv p hp).symm.trans ((h p hp).some.trans (hNps.localizedModule_equiv p hp))⟩
    exact HasPseudoIsomorphism.of_equiv (linearEquiv_of_localizedModule_equiv_at_height_one pM hM1 eM pN hN1 eN this)
