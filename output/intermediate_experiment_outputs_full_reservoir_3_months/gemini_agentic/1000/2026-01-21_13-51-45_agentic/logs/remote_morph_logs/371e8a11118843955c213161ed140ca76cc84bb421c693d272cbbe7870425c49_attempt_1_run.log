import Fad.Chapter6
import Fad.Chapter7

namespace Chapter7

/- # Exercicio 7.1 -/

def minimumBy {őĪ : Type} (cmp : őĪ ‚Üí őĪ ‚Üí Ordering) : List őĪ ‚Üí Option őĪ
  | []      => none
  | x :: xs =>
    some (xs.foldr (őĽ y r => cond (cmp y r = Ordering.lt) y r) x)

def minWith‚āĀ {őĪ ő≤ : Type} [Ord ő≤] (f : őĪ ‚Üí ő≤) (xs : List őĪ) : Option őĪ :=
  let helper (x y : őĪ) : Ordering := compare (f x) (f y)
  minimumBy helper xs

def minWith‚āā {őĪ ő≤ : Type} [Ord ő≤] (f : őĪ ‚Üí ő≤) (xs : List őĪ) : Option őĪ :=
  let tuple (x : őĪ) : ő≤ √ó őĪ := (f x, x)
  let cmp (x y : ő≤ √ó őĪ) := compare x.1 y.1
  minimumBy cmp (xs.map tuple) >>= (őĽ pair => some pair.2)

instance : Ord Float where
  compare x y :=
    if x < y then Ordering.lt
    else if x == y then Ordering.eq
    else Ordering.gt


/- # Exercicio 7.2 -/

def minsWith {őĪ ő≤ : Type} [Ord ő≤] (f : őĪ ‚Üí ő≤) (xs : List őĪ) : List őĪ :=
  let step (x : őĪ) (ys : List őĪ) : List őĪ :=
    match ys with
    | [] => [x]
    | y :: ys =>
      match compare (f x) (f y) with
      | Ordering.lt => [x]
      | Ordering.eq => x :: y :: ys
      | Ordering.gt => y :: ys
  xs.foldr step []

def minsWith' {őĪ ő≤ : Type} [Ord ő≤] (f : őĪ ‚Üí ő≤) (xs : List őĪ) : List őĪ :=
  let step (x : ő≤ √ó őĪ) (ys : List (ő≤ √ó őĪ)) :=
    match ys with
    | [] => [x]
    | y :: ys =>
      match compare (x.fst) (y.fst) with
      | Ordering.lt => [x]
      | Ordering.eq => x :: y :: ys
      | Ordering.gt => y :: ys
  xs.map tuple |>.foldr step [] |>.map (¬∑.snd)
    where tuple x := (f x, x)


