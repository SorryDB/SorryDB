Statement IVT {f : ℝ → ℝ} (hf : FunCont f) {a b : ℝ} (hab : a < b)
    (hfa : f a < 0) (hfb : 0 < f b): ∃ c ∈ Ioo a b, f c = 0 := by
let S := { x ∈ Icc a b | f x < 0 }
have a_in_S : a ∈ S := by
  split_ands
  · bound
