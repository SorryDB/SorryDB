  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_mem : ∀ {x y : V} (w : G.LoopWalk x y), x ∈ w.support ∧ y ∈ w.support := by
    intro x y w
    induction w with
    | nil => simp [support]
    | cons h q ih => simp [support, ih.2]
    | loop q ih => simp [support, ih.2]
  have h_edges : ∀ {x y : V} (w : G.LoopWalk x y) {e}, e ∈ w.edgeSet → ∃ a b, e = s(a, b) ∧ a ∈ w.support ∧ b ∈ w.support := by
    intro x y w e he
    induction w with
    | nil => simp [edgeSet, edges, darts] at he
    | cons h q ih' =>
