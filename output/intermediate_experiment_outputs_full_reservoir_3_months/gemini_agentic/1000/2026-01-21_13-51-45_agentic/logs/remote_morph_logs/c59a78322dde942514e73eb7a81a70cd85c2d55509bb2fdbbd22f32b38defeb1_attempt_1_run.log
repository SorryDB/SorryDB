lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_mem : ∀ {x y : V} (w : G.LoopWalk x y), x ∈ w.supportSet ∧ y ∈ w.supportSet := by
    intro x y w
    induction w with
    | nil => simp [supportSet, support]
    | cons h q ih => simp [supportSet, support, ih]
    | loop q ih => simp [supportSet, support, ih]
  have h_edges : ∀ {x y : V} (w : G.LoopWalk x y) {e}, e ∈ w.edgeSet →
      ∃ a b, e = s(a, b) ∧ a ∈ w.supportSet ∧ b ∈ w.supportSet := by
    intro x y w e
    induction w with
    | nil => simp [edgeSet, edges, darts]
