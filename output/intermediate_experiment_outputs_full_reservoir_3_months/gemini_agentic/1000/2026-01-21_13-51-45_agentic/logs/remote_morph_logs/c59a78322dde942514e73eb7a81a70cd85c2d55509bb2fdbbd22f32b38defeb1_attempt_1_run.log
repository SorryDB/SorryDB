lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {x y : V} (w : G.LoopWalk x y), x ∈ w.supportSet := by
    intro x y w
    induction w with
    | nil => simp [supportSet, support]
    | cons _ _ _ => simp [supportSet, support]
    | loop _ _ => simp [supportSet, support]
  have h_edges : ∀ {x y : V} (w : G.LoopWalk x y) {e : Sym2 V}, e ∈ w.edgeSet → ∀ z ∈ e, z ∈ w.supportSet := by
