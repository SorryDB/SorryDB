lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | cons h q ih =>
    simp only [supportSet, support, edgeSet, edges, darts, List.toFinset_cons]
    by_cases hu : u ∈ q.supportSet
    · rw [Finset.insert_eq_of_mem hu]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
    · rw [Finset.card_insert_of_not_mem hu, Finset.card_insert_of_not_mem]
      · exact Nat.add_le_add_right ih 1
      · intro h_mem
        simp only [edgeSet, List.mem_toFinset, List.mem_map, dartEdge] at h_mem
        rcases h_mem with ⟨⟨x, y⟩, h_dart, he⟩
        have h_sub : x ∈ q.supportSet ∧ y ∈ q.supportSet := by
          clear ih hu; induction q with
          | nil => cases h_dart
          | cons _ _ ih' | loop _ ih' =>
            cases h_dart with
            | head => simp [supportSet, support]
            | tail h_dart => specialize ih' h_dart; simp [supportSet, support, ih']
        rcases Sym2.eq_iff.1 he with ⟨rfl, rfl⟩ | ⟨rfl, rfl⟩ <;> [exact hu h_sub.1; exact hu h_sub.2]
  | loop q ih =>
    simp only [supportSet, support, edgeSet, edges, darts, List.toFinset_cons]
    have hu : u ∈ q.supportSet := by induction q <;> simp [supportSet, support]
    rw [Finset.insert_eq_of_mem hu]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card (Finset.subset_insert _ _)) 1)
