lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  have h_start : ∀ {x y} (p : G.LoopWalk x y), x ∈ p.support := by
    intros; cases ‹G.LoopWalk _ _› <;> simp [support]
  induction p with
  | nil => simp [supportSet, support, edgeSet, edges, darts]
  | @cons u v w h q ih =>
    by_cases hu : u ∈ q.support.toFinset
    · have h_supp : (support (cons h q)).toFinset = q.support.toFinset := by
        simp [support, Finset.insert_eq_of_mem hu]
      have h_edge_sub : q.edgeSet ⊆ (edgeSet (cons h q)) := by
        simp [edgeSet, edges, darts]; apply Finset.subset_insert
      rw [supportSet, h_supp]
      exact ih.trans (Nat.add_le_add_right (Finset.card_le_card h_edge_sub) 1)
    · have h_supp : (support (cons h q)).toFinset.card = q.support.toFinset.card + 1 := by
        simp [support, Finset.card_insert_of_not_mem hu]
      have h_edge : s(u, v) ∉ q.edgeSet := by
        intro h_mem
        rw [edgeSet, edges, List.mem_toFinset, List.mem_map] at h_mem
        rcases h_mem with ⟨d, hd, he⟩
        have h_dart : d.1 ∈ q.support ∧ d.2 ∈ q.support := by
          clear ih hu; induction q with
          | nil => cases hd
          | cons _ q' ih' =>
            rcases hd with (rfl | hd')
            · exact ⟨by simp [support], h_start _⟩
            · specialize ih' hd'
              exact ⟨Or.inr ih'.1, Or.inr ih'.2⟩
          | loop q' ih' =>
            rcases hd with (rfl | hd')
            · exact ⟨by simp [support], by simp [support]⟩
            · specialize ih' hd'
              exact ⟨Or.inr ih'.1, Or.inr ih'.2⟩
        rw [dartEdge, Sym2.eq_iff] at he
        rcases he with ⟨rfl, rfl⟩ | ⟨rfl, rfl⟩ <;> [exact hu (List.mem_toFinset.2 h_dart.1); exact hu (List.mem_toFinset.2 h_dart.2)]
      have h_edge_card : (edgeSet (cons h q)).card = q.edgeSet.card + 1 := by
        simp [edgeSet, edges, darts, dartEdge, h_edge, Finset.card_insert_of_not_mem]
      rw [supportSet, h_supp, h_edge_card]
      exact Nat.add_le_add_right ih 1
  | @loop u v q ih =>
    have hu : u ∈ q.support.toFinset := h_start _
    have h_supp : (support (loop q)).toFinset = q.support.toFinset := by
      simp [support, Finset.insert_eq_of_mem hu]
    have h_edge_sub : q.edgeSet ⊆ (edgeSet (loop q)) := by
      simp [edgeSet, edges, darts]; apply Finset.subset_insert
    rw [supportSet, h_supp]
    exact ih.trans (Nat.add_le_add_right (Finset.card_le_card h_edge_sub) 1)
