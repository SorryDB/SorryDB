    | loop q ih =>
      intro h_e
      simp [edgeSet, edges, darts, dartEdge, supportSet, support] at h_e ⊢
      rcases h_e with (rfl | h_e)
      · exact ⟨_, _, rfl, by simp, Or.inr (h_mem q).1⟩
      · rcases ih h_e with ⟨a, b, rfl, ha, hb⟩
