    (hfF : UnifConv f F) :
    ∃ (L : ℝ), SeqLim ℓ L ∧ HasIntegral F a b L
 := by
have RSdiff : ∀ ε > 0, ∃ N, ∀ n ≥ N, ∀ M, |RiemannSum (f n) a b M - RiemannSum F a b M| < ε := by
  intro ε hε
  choose N hN using hfF (ε / (b - a)) (by bound)
  use N
  intro n hn M
  specialize hN n hn
  sorry
have Lconv : SeqConv ℓ := by
  apply SeqConv_of_IsCauchy
  intro ε hε
