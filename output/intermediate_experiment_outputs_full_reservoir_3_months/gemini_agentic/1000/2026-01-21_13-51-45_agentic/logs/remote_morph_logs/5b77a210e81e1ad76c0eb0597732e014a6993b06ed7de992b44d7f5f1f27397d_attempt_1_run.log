import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let fM : ℕ → ℕ × ℕ := fun n ↦ Nat.rec (3, 5) (fun _ p ↦
    let fn := p.1
    let Mn := p.2
    let next_f := (fn + 1) * Nat.totient Mn + 2
    let next_M := Mn * (2 ^ next_f - 3)
    (next_f, next_M)) n
  let f n := (fM n).1
  let M n := (fM n).2
  have hf0 : f 0 = 3 := rfl
  have hM0 : M 0 = 5 := rfl
  have hfs : ∀ n, f (n + 1) = (f n + 1) * Nat.totient (M n) + 2 := fun _ ↦ rfl
  have hMs : ∀ n, M (n + 1) = M n * (2 ^ f (n + 1) - 3) := fun _ ↦ rfl

  have h_fM_prop : ∀ n, 3 ≤ f n ∧ 5 ≤ M n ∧ Odd (M n) := by
    intro n; induction n with
    | zero => rw [hf0, hM0]; exact ⟨by decide, by decide, by decide⟩
    | succ n ih =>
      have hM_pos : 0 < M n := by linarith [ih.2.1]
      have htot : 1 ≤ Nat.totient (M n) := Nat.totient_pos.mpr hM_pos
      have hf_succ : 3 ≤ f (n + 1) := by
        rw [hfs]
        have h_mul_ge4 : 4 ≤ (f n + 1) * Nat.totient (M n) :=
          Nat.mul_le_mul (by linarith [ih.1]) htot
        linarith
      have hM_term_ge5 : 5 ≤ 2 ^ f (n + 1) - 3 := by
        have h2f_ge8 : 8 ≤ 2 ^ f (n + 1) := Nat.pow_le_pow_right (show 0 < 2 by decide) hf_succ
        exact Nat.le_sub_of_add_le h2f_ge8
      have hM_succ : 5 ≤ M (n + 1) := by
        rw [hMs]
        have : 5 * 5 ≤ M n * (2 ^ f (n + 1) - 3) := Nat.mul_le_mul ih.2.1 hM_term_ge5
        linarith
      have hM_odd : Odd (M (n + 1)) := by
        rw [hMs]; apply Odd.mul ih.2.2
        have h_even : Even (2 ^ f (n + 1)) := Nat.even_pow.mpr ⟨by decide, by linarith [hf_succ]⟩
        have h_ge3 : 3 ≤ 2 ^ f (n + 1) := by
          have : 2 ^ 3 ≤ 2 ^ f (n + 1) := Nat.pow_le_pow_right (by decide) hf_succ
          linarith
        exact (Nat.odd_sub h_ge3).mpr (by simp [h_even])
      exact ⟨hf_succ, hM_succ, hM_odd⟩

  have hf_ge3 n : 3 ≤ f n := (h_fM_prop n).1
  have M_odd n : Odd (M n) := (h_fM_prop n).2.2

  have f_strictMono : StrictMono f := strictMono_nat_of_lt_succ (fun n ↦ by
    rw [hfs]
    have htot : 1 ≤ Nat.totient (M n) := Nat.totient_pos.mpr (by linarith [(h_fM_prop n).2.1])
    calc f n < f n + 1 := Nat.lt_succ_self (f n)
         _ ≤ (f n + 1) * Nat.totient (M n) := Nat.le_mul_of_pos_right (f n + 1) htot
         _ < (f n + 1) * Nat.totient (M n) + 2 := by linarith)

  have M_prod : ∀ n, M n = ∏ i ∈ Finset.range (n + 1), (2 ^ f i - 3) := by
    intro n; induction n with
    | zero => rw [hM0, hf0]; simp only [Finset.range_one, Finset.prod_singleton]
    | succ n ih => rw [hMs, ih, Finset.prod_range_succ]; rfl

  have h_gcd_ij : ∀ {i j}, i < j → Nat.Coprime (2 ^ f j - 3) (2 ^ f i - 3) := by
    intro i j hij
    let Mj1 := M (j - 1)
    have hj : j = (j - 1) + 1 := (Nat.succ_pred_eq_of_pos (Nat.zero_lt_of_lt hij)).symm
    have h4Mod : 2 ^ f j ≡ 4 [MOD Mj1] := by
      rw [hj, hfs, Nat.pow_add, Nat.pow_mul]
      have h_cop : Nat.Coprime 2 Mj1 := (Nat.coprime_two_right.mpr (M_odd (j - 1))).symm
      have h_euler : 2 ^ (Nat.totient Mj1) ≡ 1 [MOD Mj1] := Nat.ModEq.pow_totient h_cop
      have h_pow : (2 ^ (Nat.totient Mj1)) ^ (f (j - 1) + 1) ≡ 1 ^ (f (j - 1) + 1) [MOD Mj1] := Nat.ModEq.pow _ h_euler
      simp only [one_pow] at h_pow
      exact Nat.ModEq.mul h_pow (Nat.ModEq.refl 4)
    have h1Mod : 2 ^ f j - 3 ≡ 1 [MOD Mj1] := by
      have h_ge3 : 3 ≤ 2 ^ f j := by
        have : 2 ^ 3 ≤ 2 ^ f j := Nat.pow_le_pow_right (by decide) (hf_ge3 j)
        linarith
      apply Nat.ModEq.of_add_right_cancel (c := 3)
      rw [Nat.sub_add_cancel h_ge3]
      exact h4Mod
    have h_gcd : Nat.Coprime (2 ^ f j - 3) Mj1 := by
      rw [Nat.Coprime, Nat.ModEq.gcd_eq h1Mod, Nat.gcd_one_left]
    have hi_dvd : (2 ^ f i - 3) ∣ M (j - 1) := by
      rw [M_prod (j - 1), hj]
      exact Finset.dvd_prod_of_mem (fun k ↦ 2 ^ f k - 3) (Finset.mem_range.mpr hij)
    exact h_gcd.coprime_dvd_right hi_dvd

  let g : ℕ → ℕ+ := fun n ↦ ⟨f n, by linarith [hf_ge3 n]⟩
  use Set.range g
  constructor
  · exact Set.infinite_range_of_injective (fun i j h ↦ f_strictMono.injective (congr_arg (·.val) h))
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    have h_ne : i ≠ j := fun h_eq ↦ hne (by rw [h_eq])
    rcases (Nat.lt_or_gt_of_ne h_ne) with hij | hji
    · exact h_gcd_ij hij
    · exact (h_gcd_ij hji).symm

