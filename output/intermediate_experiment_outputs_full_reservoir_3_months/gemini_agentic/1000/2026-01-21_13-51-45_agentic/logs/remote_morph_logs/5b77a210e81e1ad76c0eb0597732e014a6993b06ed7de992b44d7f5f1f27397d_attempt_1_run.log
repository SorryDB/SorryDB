import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let fM : ℕ → ℕ × ℕ := fun n ↦ Nat.rec (3, 5) (fun _ p ↦
    let fn := p.1
    let Mn := p.2
    let next_f := (fn + 1) * Mn.totient + 2
    let next_M := Mn * (2 ^ next_f - 3)
    (next_f, next_M)) n
  let f n := (fM n).1
  let M n := (fM n).2
  have hf0 : f 0 = 3 := rfl
  have hM0 : M 0 = 5 := rfl
  have hfs : ∀ n, f (n + 1) = (f n + 1) * (M n).totient + 2 := fun _ ↦ rfl
  have hMs : ∀ n, M (n + 1) = M n * (2 ^ f (n + 1) - 3) := fun _ ↦ rfl

  have h_fM_prop : ∀ n, 3 ≤ f n ∧ 5 ≤ M n ∧ Odd (M n) := by
    intro n; induction n with
    | zero => rw [hf0, hM0]; exact ⟨by decide, by decide, by decide⟩
    | succ n ih =>
      have hM_pos : 0 < M n := by linarith
      have htot : 0 < (M n).totient := Nat.totient_pos.mpr hM_pos
      have hf_succ : 3 ≤ f (n + 1) := by
        rw [hfs]
        have : f n * 1 ≤ f n * (M n).totient := Nat.mul_le_mul_left (f n) htot
        linarith
      have h_ge3_pow : 8 ≤ 2 ^ f (n + 1) := Nat.pow_le_pow_right (by decide) hf_succ
      have hM_term_ge5 : 5 ≤ 2 ^ f (n + 1) - 3 := Nat.le_sub_of_add_le (by linarith)
      have hM_succ : 5 ≤ M (n + 1) := by
        rw [hMs]
        have : 5 * 5 ≤ M n * (2 ^ f (n + 1) - 3) := Nat.mul_le_mul ih.2.1 hM_term_ge5
        linarith
      have hM_odd : Odd (M (n + 1)) := by
        rw [hMs]; apply Odd.mul ih.2.2
        have h_even_pow : Even (2 ^ f (n + 1)) := Nat.even_pow.mpr ⟨by decide, by linarith⟩
        rw [Nat.odd_sub (by linarith)]; simp [h_even_pow, Nat.not_odd_iff_even]
      exact ⟨hf_succ, hM_succ, hM_odd⟩

  have hf_ge3 n : 3 ≤ f n := (h_fM_prop n).1
  have hM_pos n : 0 < M n := by linarith [(h_fM_prop n).2.1]
  have M_odd n : Odd (M n) := (h_fM_prop n).2.2

  have f_strictMono : StrictMono f := strictMono_nat_of_lt_succ (fun n ↦ by
    rw [hfs]
    have htot : 0 < (M n).totient := Nat.totient_pos.mpr (hM_pos n)
    have : f n < (f n + 1) * 1 + 2 := by linarith
    exact this.trans_le (Nat.add_le_add_right (Nat.mul_le_mul_left (f n + 1) htot) 2))

  have M_prod : ∀ n, M n = ∏ i ∈ Finset.range (n + 1), (2 ^ f i - 3) := by
    intro n; induction n with
    | zero => rw [hM0, hf0, Finset.prod_range_one]; rfl
    | succ n ih => rw [hMs, ih, Finset.prod_range_succ, Nat.mul_comm]

  have h_gcd_ij : ∀ {i j}, i < j → Nat.Coprime (2 ^ f j - 3) (2 ^ f i - 3) := by
    intro i j hij
    let Mj1 := M (j - 1)
    have hj_pos : j > 0 := Nat.pos_of_gt hij
    have hj : j = (j - 1) + 1 := (Nat.succ_pred_eq_of_pos hj_pos).symm
    have h4Mod : 2 ^ f j ≡ 4 [MOD Mj1] := by
      rw [hj, hfs, Nat.pow_add, Nat.pow_mul]
      have h_cop : Nat.Coprime 2 Mj1 := Nat.coprime_two_right.mpr (M_odd (j - 1))
      have h_euler : 2 ^ Mj1.totient ≡ 1 [MOD Mj1] := Nat.ModEq.pow_totient h_cop
      have h_pow : (2 ^ Mj1.totient) ^ (f (j - 1) + 1) ≡ 1 ^ (f (j - 1) + 1) [MOD Mj1] := Nat.ModEq.pow (f (j - 1) + 1) h_euler
      exact Nat.ModEq.mul (Nat.ModEq.refl 4) h_pow
    have h1Mod : 2 ^ f j - 3 ≡ 1 [MOD Mj1] := by
      have h_ge3 : 3 ≤ 2 ^ f j := by
        have : 2 ^ 3 ≤ 2 ^ f j := Nat.pow_le_pow_right (by decide) (hf_ge3 j)
        linarith
      apply Nat.ModEq.add_right_cancel (c := 3)
      rw [Nat.sub_add_cancel h_ge3]
      exact h4Mod
    have h_gcd : (2 ^ f j - 3).Coprime Mj1 := (Nat.ModEq.gcd_eq h1Mod).trans (Nat.gcd_one_left Mj1)
    have hi_dvd : (2 ^ f i - 3) ∣ Mj1 := by
      rw [M_prod, hj]; exact Finset.dvd_prod_of_mem (fun k ↦ 2 ^ f k - 3) (Finset.mem_range.mpr hij)
    exact h_gcd.dvd_right hi_dvd

  let g : ℕ → ℕ+ := fun n ↦ ⟨f n, by linarith [hf_ge3 n]⟩
  use Set.range g
  constructor
  · exact Set.infinite_range_of_injective (fun i j h ↦ f_strictMono.injective (congr_arg (·.val) h))
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    have h_ne : i ≠ j := fun h_eq ↦ hne (by rw [h_eq])
    rcases (Nat.lt_or_gt.mpr h_ne) with hij | hji
    · exact h_gcd_ij hij
    · exact (h_gcd_ij hji).symm
```
