import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let fM : ℕ → ℕ × ℕ := fun n ↦ Nat.rec (3, 5) (fun _ p ↦
    let fn := p.1
    let Mn := p.2
    let next_f := fn * Mn.totient + 2
    let next_M := Mn * (2 ^ next_f - 3)
    (next_f, next_M)) n
  let f n := (fM n).1
  let M n := (fM n).2
  have hf0 : f 0 = 3 := rfl
  have hM0 : M 0 = 5 := rfl
  have hfs : ∀ n, f (n + 1) = f n * (M n).totient + 2 := fun n ↦ rfl
  have hMs : ∀ n, M (n + 1) = M n * (2 ^ f (n + 1) - 3) := fun n ↦ rfl

  have h_fM_prop : ∀ n, 3 ≤ f n ∧ 0 < M n ∧ Odd (M n) := by
    intro n; induction n with
    | zero => rw [hf0, hM0]; exact ⟨by decide, by decide, by decide⟩
    | succ n ih =>
      have htot : 0 < (M n).totient := (Nat.totient_pos (n := M n)).mpr ih.2.1
      have hf_ge3_succ : 3 ≤ f (n + 1) := by
        rw [hfs]
        have : 3 * 1 ≤ f n * (M n).totient := Nat.mul_le_mul ih.1 (Nat.succ_le_of_lt htot)
        linarith
      have hM_pos_succ : 0 < M (n + 1) := by
        rw [hMs]; apply Nat.mul_pos ih.2.1
        have : 2 ^ f (n + 1) ≥ 2 ^ 3 := Nat.pow_le_pow_right (by decide) hf_ge3_succ
        linarith
      have hM_odd_succ : Odd (M (n + 1)) := by
        rw [hMs]; apply Odd.mul ih.2.2
        have h2f_even : Even (2 ^ f (n + 1)) := Nat.even_pow.mpr ⟨by decide, by linarith⟩
        exact Nat.Even.sub_odd h2f_even (by decide) (by linarith)
      exact ⟨hf_ge3_succ, hM_pos_succ, hM_odd_succ⟩

  have hf_ge3 n : 3 ≤ f n := (h_fM_prop n).1
  have hM_pos n : 0 < M n := (h_fM_prop n).2.1
  have M_odd n : Odd (M n) := (h_fM_prop n).2.2

  have f_strictMono : StrictMono f := strictMono_nat_of_lt_succ (fun n ↦ by
    rw [hfs]; have htot := (Nat.totient_pos (n := M n)).mpr (hM_pos n)
    have : f n ≤ f n * (M n).totient := Nat.le_mul_of_pos_right (f n) htot
    linarith)

  have M_prod : ∀ n, M n = ∏ i ∈ Finset.range (n + 1), (2 ^ f i - 3) := by
    intro n; induction n with
    | zero => rw [hM0, hf0, Finset.prod_range_one]; rfl
    | succ n ih => rw [hMs, ih, Finset.prod_range_succ]; rfl

  have h_gcd_ij : ∀ {i j}, i < j → Nat.Coprime (2 ^ f j - 3) (2 ^ f i - 3) := by
    intro i j hij
    let Mj1 := M (j - 1)
    have hj : j = (j - 1) + 1 := (Nat.succ_pred_eq_of_pos (Nat.zero_lt_of_lt hij)).symm
    have h4Mod : 2 ^ f j ≡ 4 [MOD Mj1] := by
      rw [hj, hfs, Nat.pow_add, Nat.pow_mul]
      have h_cop : Nat.Coprime 2 Mj1 := (Nat.coprime_two_right.mpr (M_odd (j - 1))).symm
      have h_euler := Nat.ModEq.pow_totient 2 h_cop
      have h_pow := Nat.ModEq.pow (f (j - 1)) h_euler
      exact Nat.ModEq.mul h_pow (Nat.ModEq.refl 4)
    have h1Mod : 2 ^ f j - 3 ≡ 1 [MOD Mj1] := by
      have h_ge3 : 3 ≤ 2 ^ f j := by
        have : 8 ≤ 2 ^ f j := Nat.pow_le_pow_right (by decide) (hf_ge3 j)
        linarith
      apply Nat.ModEq.add_right_cancel (c := 3)
      rw [Nat.sub_add_cancel h_ge3, (by decide : 1 + 3 = 4)]
      exact h4Mod
    have h_gcd : (2 ^ f j - 3).Coprime Mj1 := (Nat.ModEq.gcd_eq h1Mod).trans (Nat.gcd_one_left Mj1)
    have hi_dvd : (2 ^ f i - 3) ∣ Mj1 := by
      rw [M_prod]; exact Finset.dvd_prod_of_mem (fun k ↦ 2 ^ f k - 3) (Finset.mem_range.mpr hij)
    exact h_gcd.coprime_dvd_right hi_dvd

  let g : ℕ → ℕ+ := fun n ↦ ⟨f n, by linarith [hf_ge3 n]⟩
  use Set.range g
  constructor
  · exact Set.infinite_range_of_injective (fun i j h ↦ f_strictMono.injective (congr_arg (·.val) h))
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    have h_ne : i ≠ j := fun h_eq ↦ hne (congr_arg g h_eq)
    rcases h_ne.lt_or_lt with hij | hji
    · exact h_gcd_ij hij
    · exact (h_gcd_ij hji).symm
