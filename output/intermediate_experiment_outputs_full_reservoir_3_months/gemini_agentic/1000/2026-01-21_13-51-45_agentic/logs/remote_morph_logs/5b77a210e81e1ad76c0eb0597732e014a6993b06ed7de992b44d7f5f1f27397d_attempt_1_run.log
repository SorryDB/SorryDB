import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ
  | 0 => 2
  | n + 1 =>
    let M := (Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3)
    (f n + 1) * Nat.totient M + 2
  termination_by k => k
  use Set.range (fun k => ⟨f k, by induction k with | zero => exact (by deciding) | succ k ih => dsimp [f]; omega⟩)
  refine ⟨Set.infinite_range (strictMono_nat_of_lt_succ (fun n => ?_)).injective, ?_⟩
  · dsimp [f]
    have hM : 0 < (Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3) := Finset.prod_pos (fun i _ => by
      have : f i ≥ 2 := by induction i with | zero => exact (by deciding) | succ i ih => dsimp [f]; omega
      omega)
    exact (by have := Nat.totient_pos hM; omega)
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    wlog hij : i < j
    · exact (this _ ⟨j, rfl⟩ _ ⟨i, rfl⟩ hne.symm (hne.lt_or_lt.resolve_left hij)).symm
    let M := (Finset.range j).prod (fun k => 2 ^ f k - 3)
    have hM : (2 ^ f i - 3) ∣ M := Finset.dvd_prod_of_mem _ (Finset.mem_range.mpr hij)
    have h2M : Nat.Coprime 2 M := (Nat.coprime_two_right).mpr (Finset.prod_induction _ _ (fun _ _ => by simp [Nat.mul_mod]) (by simp) (fun k hk => by
      have : f k ≥ 2 := by induction k with | zero => exact (by deciding) | succ k ih => dsimp [f]; omega
      match f k with | 0|1 => omega | n+2 => simp [Nat.pow_succ, Nat.even_add_one, Nat.even_mul]))
    have h4 : 2 ^ f j ≡ 4 [MOD M] := by
      have hj : f j = (f (j - 1) + 1) * Nat.totient M + 2 := by cases j <;> [omega, rfl]
      rw [hj, Nat.pow_add, Nat.pow_mul]
      exact Nat.ModEq.mul (Nat.ModEq.pow _ (Nat.Euler_totient h2M)) rfl
    have h1 : 2 ^ f j - 3 ≡ 1 [MOD M] := by
      have : 2 ^ f j ≥ 3 := by cases j <;> [omega, (dsimp [f]; omega)]
      exact Nat.ModEq.add_right_cancel' 3 (by rw [Nat.sub_add_cancel this]; exact h4.trans (by simp))
    exact Nat.Coprime.coprime_dvd_right hM (Nat.Coprime.mod_eq_right h1 (by simp))

end Imo1971P3
