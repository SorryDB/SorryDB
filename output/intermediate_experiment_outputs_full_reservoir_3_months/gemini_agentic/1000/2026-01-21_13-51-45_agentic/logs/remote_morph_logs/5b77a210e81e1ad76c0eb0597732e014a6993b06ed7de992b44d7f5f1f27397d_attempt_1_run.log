-/

import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec f : ℕ → ℕ
    | 0 => 3
    | n + 1 => (f n + 1) * Nat.totient ((Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3)) + 2

  have hf_ge3 : ∀ n, 3 ≤ f n := by
    intro n
    induction n using Nat.strong_induction_on with
    | h n ih =>
      cases n with
      | zero => dsimp [f]; linarith
      | succ n =>
        rw [f]
        have hM : 0 < (Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3) := by
          apply Finset.prod_pos
          intro i hi
          have : 3 ≤ f i := ih i (Finset.mem_range.1 hi)
          have : 2 ^ f i ≥ 8 := Nat.pow_le_pow_of_le_right (by linarith) this
          linarith
        have : 1 ≤ Nat.totient ((Finset.range (n + 1)).prod fun i => 2 ^ f i - 3) :=
          Nat.totient_pos hM
        have : 3 ≤ f n := ih n (Nat.lt_succ_self n)
        linarith

  have f_strictMono : StrictMono f := by
    apply strictMono_nat_of_lt_succ
    intro n
    rw [f]
    have hM : 0 < (Finset.range (n + 1)).prod (fun i => 2 ^ f i - 3) := by
      apply Finset.prod_pos
      intro i hi
      have : 3 ≤ f i := hf_ge3 i
      have : 2 ^ f i ≥ 8 := Nat.pow_le_pow_of_le_right (by linarith) this
      linarith
    have : 1 ≤ Nat.totient ((Finset.range (n + 1)).prod fun i => 2 ^ f i - 3) :=
      Nat.totient_pos hM
    have : 3 ≤ f n := hf_ge3 n
    linarith

  let g : ℕ → ℕ+ := fun n => ⟨f n, by have := hf_ge3 n; linarith⟩
  have g_injective : Function.Injective g := by
    intro i j h
    have : f i = f j := by injection h
    exact f_strictMono.injective this

  use Set.range g
  constructor
  · exact Set.infinite_range_of_injective g_injective
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    wlog hij : i < j
    · exact (this hne.symm (hne.lt_or_lt.resolve_left hij)).symm
    let M := (Finset.range j).prod (fun k => 2 ^ f k - 3)
    have hM_gt1 : 1 < M := by
      have h0 : 0 < j := by linarith
      have h_factor : 2 ^ f 0 - 3 ∣ M := Finset.dvd_prod_of_mem _ (Finset.mem_range.2 h0)
      have : 2 ^ f 0 - 3 = 5 := by dsimp [f]; linarith
      have : 5 ∣ M := this ▸ h_factor
      have hM_pos : 0 < M := by
        apply Finset.prod_pos; intro k hk; have := hf_ge3 k
        have : 2 ^ f k ≥ 8 := Nat.pow_le_pow_of_le_right (by linarith) this; linarith
      exact Nat.le_of_dvd hM_pos this
    have h2M : Nat.Coprime 2 M := by
      apply Nat.coprime_two_right.mpr
      apply Finset.prod_induction (fun x => x % 2 = 1) (fun a b ha hb => by rw [Nat.mul_mod, ha, hb]; rfl) (by rfl)
      intro k _
      have : 3 ≤ f k := hf_ge3 k
      have h3 : 3 ≤ 2 ^ f k := by have : 8 ≤ 2 ^ f k := Nat.pow_le_pow_of_le_right (by linarith) this; linarith
      rw [Nat.sub_mod h3, Nat.pow_mod_eq_zero (by linarith) (by linarith)]
      rfl
    have h4Mod : 2 ^ f j ≡ 4 [MOD M] := by
      let k := j - 1
      have hj : j = k + 1 := (Nat.succ_pred_eq_of_pos (by linarith)).symm
      rw [hj, f]
      have h_euler : 2 ^ Nat.totient M ≡ 1 [MOD M] := Nat.Euler_totient h2M
      calc
        2 ^ ((f k + 1) * Nat.totient M + 2)
          = (2 ^ Nat.totient M) ^ (f k + 1) * 2 ^ 2 := by rw [pow_add, pow_mul]
        _ ≡ 1 ^ (f k + 1) * 4 [MOD M] := Nat.ModEq.mul (Nat.ModEq.pow _ h_euler) rfl
        _ ≡ 4 [MOD M] := by simp
    have h1Mod : 2 ^ f j - 3 ≡ 1 [MOD M] := by
      have h_le1 : 3 ≤ 2 ^ f j := by have := hf_ge3 j; linarith [Nat.pow_le_pow_of_le_right (by linarith : 1 < 2) this]
      have h_le2 : 3 ≤ 4 := by linarith
      exact Nat.ModEq.add_right_cancel' h_le1 h_le2 (by rw [Nat.sub_add_cancel h_le1, Nat.sub_add_cancel h_le2]; exact h4Mod)
    have h_gcd : Nat.Coprime (2 ^ f j - 3) M := by
      rw [Nat.Coprime, Nat.gcd_comm, Nat.gcd_rec]
      have h_mod : (2 ^ f j - 3) % M = 1 := by
        rw [Nat.ModEq] at h1Mod
        have : 1 < M := hM_gt1
        rw [h1Mod, Nat.mod_eq_of_lt (by linarith)]
      rw [h_mod, Nat.gcd_one_left]
    exact Nat.Coprime.coprime_dvd_right (Finset.dvd_prod_of_mem _ (Finset.mem_range.2 hij)) h_gcd

end Imo1971P3

