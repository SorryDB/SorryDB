import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let fM : ℕ → ℕ × ℕ := fun n ↦ n.rec (3, 5) (λ _ p ↦
    let fn := p.1
    let Mn := p.2
    let next_f := (fn + 1) * Mn.totient + 2
    let next_M := Mn * (2 ^ next_f - 3)
    (next_f, next_M))
  let f n := (fM n).1
  let M n := (fM n).2
  have hf0 : f 0 = 3 := rfl
  have hM0 : M 0 = 5 := rfl
  have hfs : ∀ n, f (n + 1) = (f n + 1) * (M n).totient + 2 := fun n ↦ rfl
  have hMs : ∀ n, M (n + 1) = M n * (2 ^ f (n + 1) - 3) := fun n ↦ rfl

  have h_fM_prop : ∀ n, 3 ≤ f n ∧ 0 < M n := by
    intro n; induction n with
    | zero => rw [hf0, hM0]; decide
    | succ n ih =>
      have hf_ge3_succ : 3 ≤ f (n + 1) := by
        rw [hfs]; have htot := Nat.totient_pos.mpr ih.2; linarith
      constructor
      · exact hf_ge3_succ
      · rw [hMs]; apply Nat.mul_pos ih.2; linarith [Nat.pow_le_pow_right (by decide) hf_ge3_succ]

  have hf_ge3 n : 3 ≤ f n := (h_fM_prop n).1
  have hM_pos n : 0 < M n := (h_fM_prop n).2

  have f_strictMono : StrictMono f := strictMono_nat_of_lt_succ (fun n ↦ by
    rw [hfs]; have htot := Nat.totient_pos.mpr (hM_pos n); linarith)

  have M_odd : ∀ n, Odd (M n) := by
    intro n; induction n with
    | zero => rw [hM0]; decide
    | succ n ih =>
      rw [hMs]; apply Odd.mul ih
      have h_even : Even (2 ^ f (n + 1)) := Nat.even_pow.mpr ⟨by decide, by linarith [hf_ge3 (n + 1)]⟩
      have h_ge3 : 3 ≤ 2 ^ f (n + 1) := by linarith [Nat.pow_le_pow_right (by decide) (hf_ge3 (n + 1))]
      rw [Nat.odd_sub h_ge3]; simp [h_even]

  have M_prod : ∀ n, M n = ∏ i ∈ Finset.range (n + 1), (2 ^ f i - 3) := by
    intro n; induction n with
    | zero => rw [hM0, hf0, Finset.prod_range_one]; rfl
    | succ n ih => rw [hMs, ih, Finset.prod_range_succ]; rfl

  have h_gcd_ij : ∀ {i j}, i < j → Nat.Coprime (2 ^ f j - 3) (2 ^ f i - 3) := by
    intro i j hij
    let Mj1 := M (j - 1)
    have hj : j = (j - 1) + 1 := (Nat.succ_pred_eq_of_pos (Nat.zero_lt_of_lt hij)).symm
    have h4Mod : 2 ^ f j ≡ 4 [MOD Mj1] := by
      rw [hj, hfs, Nat.pow_add, Nat.pow_mul]
      have h_cop : Nat.Coprime 2 Mj1 := (Nat.coprime_two_right.mpr (M_odd (j - 1))).symm
      exact Nat.ModEq.mul (Nat.ModEq.pow (Nat.ModEq.pow_totient 2 h_cop) (f (j - 1) + 1)) (Nat.ModEq.refl 4)
    have h1Mod : 2 ^ f j - 3 ≡ 1 [MOD Mj1] := by
      apply Nat.ModEq.add_right_cancel (n := 3)
      have hfj : 3 ≤ 2 ^ f j := by linarith [Nat.pow_le_pow_right (by decide) (hf_ge3 j)]
      rw [Nat.sub_add_cancel hfj]; exact h4Mod
    have h_gcd : (2 ^ f j - 3).Coprime Mj1 := (Nat.ModEq.coprime h1Mod).mpr (Nat.coprime_one_left Mj1)
    have hi_dvd : (2 ^ f i - 3) ∣ Mj1 := by
      rw [M_prod]; exact Finset.dvd_prod_of_mem (fun k ↦ 2 ^ f k - 3) (Finset.mem_range.mpr hij)
    exact h_gcd.coprime_dvd_right hi_dvd

  let g : ℕ → ℕ+ := fun n ↦ ⟨f n, by linarith [hf_ge3 n]⟩
  use Set.range g
  constructor
  · exact Set.infinite_range_of_injective (fun i j h ↦ f_strictMono.injective (PNat.coe_inj.mp h))
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    rcases (Nat.lt_or_gt.mpr (fun h_eq ↦ hne (Subtype.ext (congr_arg _ h_eq)))) with hij | hji
    · exact h_gcd_ij hij
    · exact (h_gcd_ij hji).symm

