    haveI : IsMonHom e'.hom := h_mon
    rw [← AlgEquiv.span_isGroupLikeElem_eq_top (Scheme.ΓIso e'.symm).toAlgEquiv,
      AlgEquiv.span_isGroupLikeElem_eq_top (Scheme.ΓIso (diagSpecIso R A)).toAlgEquiv]
    exact AddMonoidAlgebra.span_isGroupLikeElem_eq_top R A
  · intro h
    let A := Additive {a : Γ(G, ⊤) // IsGroupLikeElem R a}
    haveI : AddCommGroup A := IsGroupLikeElem.addCommGroup R
    exact ⟨A, inferInstance, (IsAffine.isoSpec G).trans
      ((Spec.mapIso (HopfAlgebra.isoMonoidAlgebra h).toCommRingCatIso).trans (diagSpecIso R A).symm),
      inferInstance, inferInstance⟩
