    rcases hx with (rfl | rfl | hx);
    . exact monotone_construction (Nat.le_trans (Nat.le_max_left iφ iψ) (Nat.le_max_right (encode (φ ⋏ ψ)) (max iφ iψ))) hiφ;
    . exact monotone_construction (Nat.le_trans (Nat.le_max_right iφ iψ) (Nat.le_max_right (encode (φ ⋏ ψ)) (max iφ iψ))) hiψ;
    . exact monotone_construction (Nat.le_max_left (encode (φ ⋏ ψ)) (max iφ iψ)) (hΓ₁ hx);
