lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra hφψ;
  obtain ⟨iφ, hiφ⟩ := Set.mem_iUnion.mp hφ
  obtain ⟨iψ, hiψ⟩ := Set.mem_iUnion.mp hψ
  obtain ⟨_, Γ, hΓ₁, hΓ₂⟩ := of_not_mem_construction_omega hφψ
  let Δ : Finset (Formula ℕ) := insert φ (insert ψ Γ)
  let i := iφ + iψ + encode (φ ⋏ ψ)
  have hΔ : ↑Δ ⊆ construction T hT i := by
    intro x hx; simp [Δ] at hx;
    rcases hx with (rfl | rfl | hx)
    . apply monotone_construction (Nat.le_add_right _ _) hiφ
    . apply monotone_construction (Nat.le_trans (Nat.le_add_right _ _) (Nat.le_add_right _ _)) hiψ
    . apply monotone_construction (Nat.le_add_left _ _) (hΓ₁ hx)
  have h_aux : ∀ i Δ, ↑Δ ⊆ construction T hT i → Δ.conj ➝ ξ ∈ T.theory → False := by
    intro i; induction i with
    | zero =>
      intro Δ hΔ h;
      have hχΔ : χ ➝ Δ.conj ∈ T.theory := by
        induction Δ using Finset.induction with
        | empty => apply T.mem_of_provable; apply Entailment.AFortiori.af; exact Entailment.HasAxiomVerum.verum
        | insert δ Δ _ ih =>
          apply T.imp_closed (φ := (χ ➝ δ) ⋏ (χ ➝ Δ.conj)) (by sorry)
          apply T.andIR (by simpa [construction] using hΔ (by simp)) (ih (by intro x hx; apply hΔ; simp [hx]))
      exact hT (T.mem_trans hχΔ h)
    | succ i ih =>
      intro Δ hΔ h;
      dsimp [construction] at hΔ; split at hΔ;
      . split_ifs at hΔ with h_cond;
        . rename_i δ hδ;
          by_cases h_in : δ ∈ Δ;
          . let Δ' := Δ.erase δ;
            have : Δ'.conj ⋏ δ ➝ ξ ∈ T.theory := T.imp_closed (by sorry) h;
            exact h_cond Δ' (by intro x hx; have := hΔ (by simp [hx]); rcases this with (rfl | hx_sub); . exact (Finset.mem_erase.mp hx).1 rfl; . exact hx_sub) this
          . apply ih Δ (by intro x hx; have := hΔ (by simp [hx]); rcases this with (rfl | hx_sub); . contradiction; . exact hx_sub) h
      . exact ih Δ hΔ h
  apply h_aux i Δ hΔ;
  apply T.imp_closed (by sorry) hΓ₂;
