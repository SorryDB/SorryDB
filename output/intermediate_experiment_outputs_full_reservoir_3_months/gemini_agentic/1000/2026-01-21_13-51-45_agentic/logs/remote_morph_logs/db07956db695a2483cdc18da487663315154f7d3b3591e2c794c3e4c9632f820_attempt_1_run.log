Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  simp only [Set.mem_setOf_eq, answer]
  refine ⟨fun h ↦ h.1, fun h ↦ ⟨h, fun deck h_pos h_mean ↦ ?_⟩⟩
  by_contra! h_deck
  let v (p : ℕ) (n : ℕ) := if n = 0 then 0 else n.valuation p
  have h_int : ∀ j k, ∃ S, S.Nonempty ∧ ((deck j + deck k : ℚ) / 2) ^ S.card = ∏ i ∈ S, (deck i : ℚ) := by
    intro j k
    obtain ⟨S, hS, h_eq⟩ := h_mean j k
    use S, hS
    replace h_eq := (Real.rpow_nat_inv_eq_iff (by positivity) (by positivity) (pos_iff_ne_zero.mpr hS.card_ne_zero)).mp h_eq
    assumption_mod_cast
  have h_same_v2 : ∀ i j, (deck i).valuation 2 = (deck j).valuation 2 := by
    sorry
  have h_all_equal : ∀ i j, deck i = deck j := by
    sorry
  exact h_deck i j (h_all_equal i j)

