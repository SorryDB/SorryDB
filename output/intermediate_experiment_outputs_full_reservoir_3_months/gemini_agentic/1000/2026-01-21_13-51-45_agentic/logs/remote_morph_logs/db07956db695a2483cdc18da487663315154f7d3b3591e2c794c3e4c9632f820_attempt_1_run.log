import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  simp only [Set.mem_setOf_eq, answer]
  refine ⟨fun h ↦ h.1, fun h ↦ ⟨h, fun deck h_pos h_mean ↦ ?_⟩⟩
  have h_val : ∀ p : ℕ, p.Prime → ∀ i j, padicValNat p (deck i) = padicValNat p (deck j) := by
    intro p hp
    let v i := padicValNat p (deck i)
    let m := (Finset.univ.image v).min' (Finset.Nonempty.image Finset.univ_nonempty v)
    have h_all_m : ∀ i, v i = m := by
      intro i
      by_contra h_vi
      have h_gt : v i > m := (Finset.min'_le _ _ (Finset.mem_image.mpr ⟨i, Finset.mem_univ i, rfl⟩)).lt_of_ne (Ne.symm h_vi)
      obtain ⟨j, hj_m⟩ : ∃ j, v j = m := by
        obtain ⟨v_val, hv_val⟩ := Finset.min'_mem (Finset.univ.image v) (Finset.Nonempty.image Finset.univ_nonempty v)
        obtain ⟨j, -, rfl⟩ := Finset.mem_image.mp hv_val
        exact ⟨j, rfl⟩
      obtain ⟨S, hS, h_eq⟩ := h_mean i j
      have h_rational : ((deck i + deck j : ℚ) / 2) ^ #S = ∏ k ∈ S, (deck k : ℚ) := by
        replace h_eq := (Real.rpow_nat_inv_eq_iff (by positivity) (by positivity) (pos_iff_ne_zero.mpr hS.card_ne_zero)).mp h_eq
        assumption_mod_cast
      have h_v_eq : (v (deck i + deck j) - padicValNat p 2) * #S = ∑ k ∈ S, v k := by
        have h_v_prod : padicValNat p (∏ k ∈ S, deck k) = ∑ k ∈ S, v k := by
          rw [padicValNat_prod hp (fun k _ ↦ h_pos k).ne_of_gt]
        have h_v_pow : padicValNat p ((deck i + deck j : ℚ) / 2 ^ 1).num - padicValNat p ((deck i + deck j : ℚ) / 2 ^ 1).den = 0 := sorry
        sorry
      sorry
    intro i j; rw [h_all_m i, h_all_m j]
  intro i j
  refine Nat.prod_pow_padicValNat_eq_self (h_pos i).ne_of_gt (h_pos j).ne_of_gt (fun p hp ↦ ?_)
  exact h_val p hp i j

