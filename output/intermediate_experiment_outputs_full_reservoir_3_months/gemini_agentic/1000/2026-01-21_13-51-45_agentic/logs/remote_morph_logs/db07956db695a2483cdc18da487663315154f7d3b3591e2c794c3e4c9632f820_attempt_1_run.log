import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  simp only [Set.mem_setOf_eq, answer]
  constructor
  · intro h; exact h.1
  · intro h
    refine ⟨h, fun deck h_pos h_mean ↦ ?_⟩
    haveI : Nonempty (Fin n) := ⟨⟨0, Nat.zero_lt_of_lt h⟩⟩
    have h_v2 : ∀ i j, padicValNat 2 (deck i) = padicValNat 2 (deck j) := by
      intro i j
      let v k := padicValNat 2 (deck k)
      have h_nonempty : (Finset.univ.image v).Nonempty := Finset.Nonempty.image Finset.univ_nonempty v
      let m := (Finset.univ.image v).min' h_nonempty
      have h_all_m k : v k = m := by
        by_contra h_vk
        have h_m_lt : m < v k := (Finset.min'_le (Finset.univ.image v) (v k) (Finset.mem_image_of_mem v (Finset.mem_univ k))).lt_of_ne (Ne.symm h_vk)
        obtain ⟨l, -, hl⟩ := Finset.mem_image.mp (Finset.min'_mem (Finset.univ.image v) h_nonempty)
        have h_kl : k ≠ l := by rintro rfl; exact h_vk hl
        obtain ⟨S, hS, h_eq⟩ := h_mean k l h_kl
        have h_q : ((deck k + deck l : ℚ) / 2) ^ #S = ∏ m' ∈ S, (deck m' : ℚ) := by
          rw [← Real.rpow_nat_cast] at h_eq
          replace h_eq := (Real.rpow_nat_inv_eq_iff (by positivity) (by positivity) (by positivity)).mp h_eq
          assumption_mod_cast
        have h_v_eq : (#S : ℤ) * (padicValNat 2 (deck k + deck l) - 1) = ∑ m' ∈ S, (v m' : ℤ) := by
          have h1 : padicValNat 2 (((deck k + deck l : ℚ) / 2) ^ #S) = padicValNat 2 (∏ m' ∈ S, (deck m' : ℚ)) := by rw [h_q]
          simpa [padicValNat_pow, padicValNat_div, padicValNat_prod, h_pos, Nat.prime_two] using h1
        have h_vkl : padicValNat 2 (deck k + deck l) = m := by
          rw [padicValNat_add_eq_min, hl]; exact min_eq_right h_m_lt
        have h_sum : ∑ m' ∈ S, (v m' : ℤ) ≥ #S * m := by
          rw [← nsmul_eq_mul]; exact_mod_cast Finset.sum_le_card_nsmul S m (fun m' _ ↦ Finset.min'_le _ _ (Finset.mem_image_of_mem v (Finset.mem_univ m')))
        linarith
      rw [h_all_m i, h_all_m j]
    let a i := deck i / 2 ^ padicValNat 2 (deck 0)
    have h_a_odd i : Odd (a i) := by
      have : deck i = 2 ^ padicValNat 2 (deck i) * a i := (Nat.ord_proj_odd (deck i) (by positivity) (by norm_num)).symm
      rw [h_v2 i 0] at this; rw [this] at h_pos
      exact (Nat.odd_iff_not_even.mpr (Nat.not_even_right_is_pure_odd (h_pos i) (by norm_num)))
    have h_a_mean i j (hij : i ≠ j) : ∃ S, S.Nonempty ∧ (a i + a j : ℝ) / 2 = (∏ k ∈ S, (a k : ℝ)) ^ (1 / (#S : ℝ)) := by
      obtain ⟨S, hS, h_eq⟩ := h_mean i j hij
      refine ⟨S, hS, ?_⟩
      let m := padicValNat 2 (deck 0)
      have : deck k = 2^m * a k := by rw [h_v2 k 0]; exact (Nat.ord_proj_odd (deck k) (h_pos k) (by norm_num)).symm
      simp_rw [this] at h_eq
      rw [← Finset.prod_mul_distrib, Finset.prod_const, ← Real.mul_rpow (by positivity) (by positivity)] at h_eq
      rw [← Real.rpow_nat_cast, Real.rpow_nat_inv_pow_nat (by positivity) (by positivity)] at h_eq
      field_simp at h_eq; linarith
    intro i j
    by_contra hij
    let diffs := { (deck i).dist (deck j) | (i) (j) }
    have : ∀ k l, k ≠ l → (a k + a l) % 4 = 2 := by
      intro k l hkl
      obtain ⟨S, hS, h_eq⟩ := h_a_mean k l hkl
      have h_int : ((a k + a l : ℚ) / 2) ^ #S = ∏ m' ∈ S, (a m' : ℚ) := by
        rw [← Real.rpow_nat_cast] at h_eq
        replace h_eq := (Real.rpow_nat_inv_eq_iff (by positivity) (by positivity) (by positivity)).mp h_eq
        assumption_mod_cast
      have : padicValNat 2 (a k + a l) = 1 := by
        have h_v : (#S : ℤ) * (padicValNat 2 (a k + a l) - 1) = ∑ m' ∈ S, (padicValNat 2 (a m') : ℤ) := by
          simpa [padicValNat_pow, padicValNat_div, padicValNat_prod, h_pos, Nat.prime_two, a] using h_int
        have : ∀ m', padicValNat 2 (a m') = 0 := fun m' ↦ Nat.padicValNat_eq_zero_of_not_dvd (h_a_odd m').not_even
        simp [this] at h_v; linarith
      rw [← Nat.mod_eq_zero_iff_dvd, Nat.pow_one] at this
      exact Nat.ModEq.eq_of_lt (by norm_num) (by norm_num) (by simpa [Nat.padicValNat_eq_one_iff_mod_four (by norm_num)] using this)
    have : ∀ k l, a k ≡ a l [MOD 4] := by
      intros k l
      if hkl : k = l then rw [hkl] else
      haveI : Nonempty (Fin n) := ⟨k⟩
      obtain ⟨m, -, hkm⟩ := h.1.exists_gt 0
      let m' : Fin n := ⟨1, h.1⟩
      if h_km' : k = m' then
        let m'' : Fin n := ⟨0, h.1⟩
        have : a k + a m'' ≡ 2 [MOD 4] := this k m'' (by rintro rfl; cases m''; cases k; linarith)
        have : a l + a m'' ≡ 2 [MOD 4] := if h_lm : l = m'' then by rw [h_lm]; exact (h_a_odd l).mod_four_apply.symm ▸ (h_a_odd m'').mod_four_apply.symm ▸ by norm_num else this l m'' h_lm
        linarith
      else
        have : a k + a m' ≡ 2 [MOD 4] := this k m' h_km'
        have : a l + a m' ≡ 2 [MOD 4] := if h_lm : l = m' then by rw [h_lm]; exact (h_a_odd l).mod_four_apply.symm ▸ (h_a_odd m').mod_four_apply.symm ▸ by norm_num else this l m' h_lm
        linarith
    have : ∀ k l, a k = a l := by
      by_contra h_not_all; push_neg at h_not_all
      let diff_vals := { (a k).dist (a l) | (k) (l) }
      let d := diff_vals.max' (by use (a 0).dist (a 1); simp)
      sorry
    have : deck i = deck j := by
      have : a i = a j := this i j
      let m := padicValNat 2 (deck 0)
      rw [← Nat.ord_proj_odd (deck i) (h_pos i) (by norm_num), ← Nat.ord_proj_odd (deck j) (h_pos j) (by norm_num)]
      rw [h_v2 i 0, h_v2 j 0, this]
    exact this

