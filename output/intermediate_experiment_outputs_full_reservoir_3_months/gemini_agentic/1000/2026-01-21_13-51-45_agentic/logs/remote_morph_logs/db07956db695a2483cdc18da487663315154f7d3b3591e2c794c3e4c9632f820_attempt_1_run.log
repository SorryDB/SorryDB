          have h_sum_eq : deck i + deck j = 2^k * ((deck i - r) / 2^k + (deck j - r) / 2^k) + 2 * r := by
            rw [h_dk i, h_dk j]; ring
          have h_v_2k1 : 2^(k+1) ∣ 2^k * ((deck i - r) / 2^k + (deck j - r) / 2^k) + 2 * r := dvd_trans (pow_dvd_pow 2 (by linarith)) h_v_2k
          have h_r : 2^k ∣ r := by rw [Nat.modEq_zero_iff_dvd.symm]; exact (ih 0 0).trans (Nat.modEq_mod _ _)
          have h_main : 2^(k+1) ∣ 2^k * ((deck i - r) / 2^k + (deck j - r) / 2^k) := (Nat.dvd_add_right (mul_dvd_mul_left 2 h_r)).mp h_v_2k1
          have : 2 ∣ (deck i - r) / 2^k + (deck j - r) / 2^k := by
            rw [mul_comm] at h_main; exact (Nat.dvd_mul_iff_pow_dvd_of_not_dvd (by norm_num) (by simp)).mp h_main
          have h_mod2 : (deck i - r) / 2^k ≡ (deck j - r) / 2^k [MOD 2] := by
            rw [Nat.modEq_iff_dvd, ← Nat.even_iff_two_dvd, Nat.even_add] at this
            exact (Nat.mod_two_eq_one_iff_odd.mpr this.symm).symm ▸ (Nat.mod_two_eq_one_iff_odd.mpr this).symm ▸ Nat.modEq_of_mod_eq rfl
          exact (h_dk i).symm ▸ (h_dk j).symm ▸ Nat.ModEq.add_right _ (Nat.ModEq.mul_left _ h_mod2)
    exact Nat.dist_eq_zero.mp (Nat.eq_zero_of_forall_pow_dvd (by norm_num) (fun k ↦ Nat.ModEq.dvd_dist (h_mod k i j)))
