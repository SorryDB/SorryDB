  refine ⟨fun h ↦ h.1, fun h ↦ ⟨h, fun deck h_pos h_mean ↦ ?_⟩⟩
  have h_v2 : ∀ i j, padicValNat 2 (deck i) = padicValNat 2 (deck j) := by
    intro i j
    let v i := padicValNat 2 (deck i)
    let m := (Finset.univ.image v).min' (Finset.univ_nonempty.image v)
    have h_all_m : ∀ i, v i = m := by
      intro i
      by_contra h_vi
      have h_gt : m < v i := lt_of_le_of_ne (Finset.min'_le _ _ (Finset.mem_image_of_mem v (Finset.mem_univ i))) (Ne.symm h_vi)
      obtain ⟨k, -, hk⟩ := Finset.mem_image.mp (Finset.min'_mem _ (Finset.univ_nonempty.image v))
      obtain ⟨S, hS, h_eq⟩ := h_mean i k (fun h_eq ↦ h_vi (h_eq ▸ hk))
      have h_q : ((deck i + deck k : ℚ) / 2) ^ #S = ∏ m ∈ S, (deck m : ℚ) := by
        rw [← Real.rpow_nat_cast] at h_eq
        replace h_eq := (Real.rpow_nat_inv_eq_iff (by positivity) (by positivity) (by positivity)).mp h_eq
        assumption_mod_cast
      have h_v_eq : (#S : ℤ) * (padicValNat 2 (deck i + deck k) - 1) = ∑ m ∈ S, (v m : ℤ) := by
        have : padicValNat 2 (((deck i + deck k : ℚ) / 2) ^ #S) = padicValNat 2 (∏ m ∈ S, (deck m : ℚ)) := by rw [h_q]
        simpa [padicValNat_pow, padicValNat_div, padicValNat_prod, h_pos] using this
      have h_vik : padicValNat 2 (deck i + deck k) = m := by
        rw [padicValNat_add_eq_min, hk]; exact min_eq_right h_gt
      linarith [Finset.sum_le_card_nsmul S m (λ m _ => (Finset.min'_le (Finset.univ.image v) _ (Finset.mem_image_of_mem v (Finset.mem_univ m))))]
    rw [h_all_m i, h_all_m j]
  have h_all_mod : ∀ k, ∀ i j, deck i ≡ deck j [MOD 2^k] := by
    intro k
    induction' k with k ih
    · intro i j; exact Nat.modEq_one
    · intro i j
      obtain ⟨r, hr⟩ := exists_exists_eq_and (λ r => ∀ i, deck i ≡ r [MOD 2^k]) |>.mpr ⟨ih i, λ j => ih j⟩
      let z i := (deck i - r) / 2^k
      have h_deck_z i : deck i = r + 2^k * z i := Nat.eq_add_of_sub_eq (Nat.modEq_iff_dvd.mp (hr i))
      obtain ⟨S, hS, h_eq⟩ := h_mean i j (by sorry)
      sorry
  intro i j
  exact Nat.eq_of_forall_modEq h_all_mod i j

