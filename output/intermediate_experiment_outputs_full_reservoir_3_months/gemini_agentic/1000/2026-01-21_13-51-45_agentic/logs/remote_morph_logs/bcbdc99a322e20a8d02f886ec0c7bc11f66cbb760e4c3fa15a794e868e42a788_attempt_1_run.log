        have h_mem_xs : (List.range xs.length).foldr (fun i acc => if (m.shiftRight 1).shiftRight i .land 1 == 1 then xs.get! i :: acc else acc) [] ∈ (List.range (2 ^ xs.length)).map (fun mask => (List.range xs.length).foldr (fun i acc => if (mask.shiftRight i).land 1 == 1 then xs.get! i :: acc else acc) []) :=
