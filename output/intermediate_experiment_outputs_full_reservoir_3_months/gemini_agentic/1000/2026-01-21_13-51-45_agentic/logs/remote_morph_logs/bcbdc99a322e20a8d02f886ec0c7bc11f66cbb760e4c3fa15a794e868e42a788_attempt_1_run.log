    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  unfold maxStrength maxStrength_postcond
  simp only [maxStrength_precond] at h_precond
  let ps1 := (List.range (2 ^ nums.length)).map fun (mask : ℕ) =>
    (List.range nums.length).foldr (fun i acc =>
      if (mask.shiftRight i).land 1 == 1 then nums[i]! :: acc else acc) []
  let prs1 := (ps1.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  let prs2 := (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  have h_non : prs1 ≠ [] := by
    cases nums with
    | nil => contradiction
    | cons x xs =>
      simp [List.ne_nil_iff]
      use x
      simp [prs1, ps1]
      use 1
      simp [List.range_succ, List.foldr, List.get!]
  obtain ⟨res, h_res⟩ := List.max?_eq_some_iff.2 ⟨h_non, rfl⟩
  simp [h_res]
  have h_mem_ps1_sub : ∀ {s}, s ∈ ps1 → s <+ nums := by
    intro s hs
    obtain ⟨mask, ⟨_, rfl⟩⟩ := hs
    let n := nums.length
    have : ∀ i, ((List.range i).foldr (fun j acc => if (mask.shiftRight j).land 1 == 1 then nums[j]! :: acc else acc) []) <+ nums.take i := by
      intro i; induction i with
      | zero => simp [List.range]; constructor
      | succ i ih =>
        simp [List.range_succ, List.foldr]
        split
        · exact ih.trans (List.take_sublist_take i (Nat.le_succ i))
        · rw [List.take_succ, List.get!_take_index i (Nat.lt_succ_self i)]
          exact ih.cons _
    exact (this n).trans (by simp)
  have h_mem_equiv : ∀ {x}, x ∈ prs1 ↔ x ∈ prs2 := by
    intro x
    simp [prs1, prs2, ps1, List.mem_sublists]
    constructor
    · rintro ⟨s, ⟨hs1, hne⟩, rfl⟩
      exact ⟨s, ⟨h_mem_ps1_sub hs1, hne⟩, rfl⟩
    · rintro ⟨s, ⟨hsub, hne⟩, rfl⟩
      induction nums generalizing s with
      | nil => cases hsub; contradiction
      | cons y ys ih =>
        simp [List.sublists] at hsub
        rcases hsub with hsub | ⟨s', hsub, rfl⟩
        · obtain ⟨s_new, ⟨⟨mask, ⟨hm1, hm2⟩⟩, hne'⟩, h_prod⟩ := ih hsub hne
          use s_new; constructor <;> [skip, exact h_prod]
          simp [ps1] at *; use 2 * mask; constructor
          · rw [Nat.pow_succ]; linarith
          · simp [List.range_succ, List.foldr, hm2, Nat.shiftRight_zero, Nat.land_zero]
            have : (List.range ys.length).foldr (fun i acc => if ((2 * mask).shiftRight (i + 1)).land 1 == 1 then (y :: ys)[i + 1]! :: acc else acc) [] = (List.range ys.length).foldr (fun i acc => if (mask.shiftRight i).land 1 == 1 then ys[i]! :: acc else acc) [] := by
              congr; ext i acc; simp [Nat.shiftRight_succ_inside, Nat.mul_div_right]; rfl
            exact this
        · cases s' with
          | nil =>
            use [y]; constructor <;> [skip, rfl]
            simp [ps1]; use 1; simp [List.range_succ, List.foldr, List.get!]
          | cons z zs =>
            obtain ⟨s_new, ⟨⟨mask, ⟨hm1, hm2⟩⟩, hne'⟩, h_prod⟩ := ih hsub (by simp)
            use (y :: s_new); constructor <;> [skip, simp [h_prod]]
            simp [ps1] at *; use 2 * mask + 1; constructor
            · rw [Nat.pow_succ]; linarith
            · simp [List.range_succ, List.foldr, hm2, Nat.shiftRight_zero, Nat.land_one_add_two_mul]
              have : (List.range ys.length).foldr (fun i acc => if ((2 * mask + 1).shiftRight (i + 1)).land 1 == 1 then (y :: ys)[i + 1]! :: acc else acc) [] = (List.range ys.length).foldr (fun i acc => if (mask.shiftRight i).land 1 == 1 then ys[i]! :: acc else acc) [] := by
                congr; ext i acc; simp [Nat.shiftRight_succ_inside, Nat.add_div_right]; rfl
              exact this
  constructor
  · exact h_mem_equiv.1 (List.mem_of_max?_some h_res)
