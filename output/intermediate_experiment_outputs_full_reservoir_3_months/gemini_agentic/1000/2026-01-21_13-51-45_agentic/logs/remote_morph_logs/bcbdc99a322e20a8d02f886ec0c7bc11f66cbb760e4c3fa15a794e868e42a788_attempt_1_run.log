  simp only [maxStrength_precond] at h_precond
  let ps1 := (List.range (2 ^ nums.length)).map fun (mask : ℕ) =>
    (List.range nums.length).foldr (fun i acc =>
      if (mask.shiftRight i).land 1 == 1 then nums[i]! :: acc else acc) []
  let prs1 := (ps1.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  let prs2 := (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  have h_mem_ps1 : ∀ {s}, s ∈ ps1 ↔ s <+ nums := by
    intro s
    induction nums generalizing s with
    | nil =>
      simp [ps1, Nat.pow_zero, List.range, List.Sublist.refl]
      constructor
      · rintro ⟨mask, h, rfl⟩; simp at h; subst mask; simp; constructor
      · intro h; cases h; use 0; simp
    | cons y ys ih =>
      simp [ps1, Nat.pow_succ, Nat.mul_two, List.range_succ, List.foldr_map, List.foldr]
      constructor
      · rintro ⟨mask, hmask, rfl⟩
        simp [Nat.shiftRight_zero, Nat.land_one]
        have h_mask_div : mask / 2 < 2 ^ ys.length := Nat.div_lt_of_lt_mul hmask
        have h_step : ∀ i, (mask.shiftRight (i + 1)).land 1 = ((mask / 2).shiftRight i).land 1 := by
          intro i; simp [Nat.shiftRight_eq_div_pow, Nat.pow_succ, Nat.div_div_eq_div_mul]
        split_ifs with hbit
        · apply List.Sublist.cons₂; rw [ih]; use mask / 2; use h_mask_div
          congr; ext i acc; simp [h_step, List.get!_cons_succ]
        · apply List.Sublist.cons; rw [ih]; use mask / 2; use h_mask_div
          congr; ext i acc; simp [h_step, List.get!_cons_succ]
      · intro h
        cases h with
        | cons s' hsub =>
          obtain ⟨mask', hmask', rfl⟩ := ih.2 hsub
          use 2 * mask'
          constructor
          · linarith
          · simp [Nat.shiftRight_zero, Nat.land_one, List.get!_cons_succ]
            congr; ext i acc; simp [Nat.shiftRight_eq_div_pow, Nat.pow_succ, Nat.div_div_eq_div_mul, List.get!_cons_succ]
        | cons₂ y s' hsub =>
          obtain ⟨mask', hmask', rfl⟩ := ih.2 hsub
          use 2 * mask' + 1
          constructor
          · linarith
          · simp [Nat.shiftRight_zero, Nat.land_one, List.get!_cons_succ]
            congr; ext i acc; simp [Nat.shiftRight_eq_div_pow, Nat.pow_succ, Nat.div_div_eq_div_mul, List.get!_cons_succ]
  have h_prs_eq : ∀ {x}, x ∈ prs1 ↔ x ∈ prs2 := by
    intro x; simp [prs1, prs2, ps1, h_mem_ps1, List.mem_sublists]
  have h_non : prs1 ≠ [] := by
    cases nums with
    | nil => contradiction
    | cons x xs =>
      simp [List.ne_nil_iff]; use x; rw [h_prs_eq]
      simp [prs2, List.mem_sublists]; use [x]; simp [List.Sublist.refl]
  obtain ⟨res, h_res⟩ := List.max?_eq_some_iff.2 ⟨h_non, rfl⟩
  simp [h_res, List.contains_iff_mem, List.all_iff_forall]
  constructor
  · exact h_prs_eq.1 (List.mem_of_max?_some h_res)
  · intro x hx; exact List.le_max?_of_mem (h_prs_eq.2 hx) h_res
