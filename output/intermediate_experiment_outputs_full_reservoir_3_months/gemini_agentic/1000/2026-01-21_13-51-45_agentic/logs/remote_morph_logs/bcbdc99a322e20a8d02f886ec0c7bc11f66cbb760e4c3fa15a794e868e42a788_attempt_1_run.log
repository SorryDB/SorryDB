theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  unfold maxStrength_postcond maxStrength
  simp only [maxStrength_precond] at h_precond
  let ps1 := (List.range (2 ^ nums.length)).map fun mask =>
    (List.range nums.length).foldr (fun i acc =>
      if (mask.shiftRight i).land 1 == 1 then nums[i]! :: acc else acc) []
  let prs1 := (ps1.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  let prs2 := (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  have h_eq : prs1.toFinset = prs2.toFinset := by
    ext x
    simp only [List.mem_toFinset, List.mem_map, List.mem_filter, List.mem_range, List.mem_sublists]
    constructor
    · rintro ⟨mask, ⟨_, h_mask_nonempty⟩, h_x⟩
      let s := (List.range nums.length).foldr (fun i acc => if (mask.shiftRight i).land 1 == 1 then nums[i]! :: acc else acc) []
      use s
      constructor
      · sorry
      · exact h_x
    · rintro ⟨s, ⟨h_s_sub, h_s_nonempty⟩, h_x⟩
      sorry
  have h_non : prs1 ≠ [] := by
    simp [List.ne_nil_iff]
    cases nums with
    | nil => contradiction
    | cons x xs =>
      let mask := (1 : ℕ)
      use (List.range (x :: xs).length).foldr (fun i acc => if (mask.shiftRight i).land 1 == 1 then (x :: xs)[i]! :: acc else acc).foldl (· * ·) 1
      simp [List.mem_map, List.mem_filter]
      sorry
  obtain ⟨m, hm⟩ := List.max?_eq_some_iff.2 ⟨h_non, rfl⟩
  simp [hm]
  constructor
  · have : m ∈ prs1 := List.mem_of_max?_some hm
    rwa [← List.mem_toFinset, h_eq, List.mem_toFinset] at this
  · intro x hx
    have : x ∈ prs1 := by rwa [← List.mem_toFinset, h_eq, List.mem_toFinset] at hx
    exact List.le_max?_of_mem this hm
