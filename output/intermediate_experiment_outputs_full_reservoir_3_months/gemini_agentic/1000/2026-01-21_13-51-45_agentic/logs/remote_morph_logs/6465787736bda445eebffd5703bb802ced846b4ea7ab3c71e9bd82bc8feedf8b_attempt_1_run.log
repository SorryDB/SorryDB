/-! ## Some lemmas related to the integral. -/

/-- For complex measures `μ`, `ν` and integrable function `f`: `∫ f d(μ + ν) = ∫ f dμ + ∫ f dν` -/
lemma integral_add (μ ν : ComplexMeasure α) (f : α → ℂ) :
    ∫ a, f a ∂(μ + ν) = ∫ a, f a ∂μ + ∫ a, f a ∂ν := by
  dsimp [integral]
  let λ := μ.var + ν.var
  have hμ : μ ≪ᵥ λ := μ.absolutelyContinuous_variation.trans (Measure.absolutelyContinuous_of_le (Measure.le_add_right _))
  have hν : ν ≪ᵥ λ := ν.absolutelyContinuous_variation.trans (Measure.absolutelyContinuous_of_le (Measure.le_add_left _))
  have hμν : μ + ν ≪ᵥ λ := hμ.add hν
  rw [integral_eq_integral_rnDeriv μ f λ hμ, integral_eq_integral_rnDeriv ν f λ hν,
    integral_eq_integral_rnDeriv (μ + ν) f λ hμν]
  rw [MeasureTheory.VectorMeasure.rnDeriv_add hμ hν]
  simp_rw [mul_add]
  by_cases hfμ : Integrable (fun a => f a * μ.rnDeriv λ a) λ
  · by_cases hfν : Integrable (fun a => f a * ν.rnDeriv λ a) λ
    · exact integral_add hfμ hfν
    · have hfμν : ¬ Integrable (fun a => f a * (μ.rnDeriv λ a + ν.rnDeriv λ a)) λ := by
        intro h; refine hfν (Integrable.congr (h.sub hfμ) (by ext; ring))
      rw [integral_undef hfν, integral_undef hfμν, add_zero]
  · by_cases hfν : Integrable (fun a => f a * ν.rnDeriv λ a) λ
    · have hfμν : ¬ Integrable (fun a => f a * (μ.rnDeriv λ a + ν.rnDeriv λ a)) λ := by
        intro h; refine hfμ (Integrable.congr (h.sub hfν) (by ext; ring))
      rw [integral_undef hfμ, integral_undef hfμν, zero_add]
    · have hfμν : ¬ Integrable (fun a => f a * (μ.rnDeriv λ a + ν.rnDeriv λ a)) λ ∨ Integrable (fun a => f a * (μ.rnDeriv λ a + ν.rnDeriv λ a)) λ := by
        exact em _
      cases hfμν with
      | h_not => rw [integral_undef hfμ, integral_undef hfν, integral_undef h_not, add_zero]
      | h_is => -- This case is impossible for complex measures since variation is finite
        rw [integral_undef hfμ, integral_undef hfν, zero_add, integral_undef]
        intro h; refine hfμ (Integrable.congr (h_is.sub (Integrable.congr h (by ext; ring))) (by ext; ring))
