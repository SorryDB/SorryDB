  let c : Fin (n + n) → ℝ := Fin.addCases (fun _ => 1) (fun _ => -1)
  have h_sum_c : ∑ i, c i = 0 := by
    simp [c, Fin.sum_univ_add]
  have h_neg_prop := h_neg (n + n) y c h_sum_c
  simp only [y, c, d, Fin.sum_univ_add, Fin.addCases, one_mul, neg_mul,
    one_neg_mul, neg_neg, ← Finset.sum_add_distrib, ← Finset.sum_sub_distrib] at h_neg_prop
  simp_rw [sub_neg_eq_add, abs_neg_sub, neg_sub_neg, abs_sub_comm (x _)] at h_neg_prop
  linarith
