    have h_val := h_neg (n + n) y c h_sum_c
    simp only [Real.dist_eq, Real.norm_eq_abs, Real.sqrt_eq_rpow] at h_val
    exact h_val
  simp_rw [Fin.sum_univ_add, Fin.addCases_left, Fin.addCases_right, y, c] at h_neg_prop
  simp only [one_mul, neg_mul, mul_one, mul_neg, neg_neg,
    Finset.sum_add_distrib, Finset.sum_neg_distrib,
    abs_sub_comm, sub_neg_eq_add, abs_neg, add_comm] at h_neg_prop
  simp only [Real.sqrt_eq_rpow]
  linarith

