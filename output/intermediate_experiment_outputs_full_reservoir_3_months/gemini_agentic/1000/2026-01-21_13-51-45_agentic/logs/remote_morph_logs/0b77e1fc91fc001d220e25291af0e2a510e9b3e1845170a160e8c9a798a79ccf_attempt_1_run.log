theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  let y : Fin (n + n) → ℝ := Fin.addCases x (fun i => -x i)
  let c : Fin (n + n) → ℝ := Fin.addCases (fun _ => (1 : ℝ)) (fun _ => -1)
