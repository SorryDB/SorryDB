instance DirectSumDecompLE : PartialOrder (DirectSumDecomposition M) where
  le_antisymm := by
    intro I J h_J_le_I h_I_le_J
    have h_final_left : ∀ N ∈ J, N ∈ I := by
      intro N
      by_contra h_neg
      push_neg at h_neg
      rcases h_neg with ⟨h_N_in_J, h_N_not_in_I⟩
      let N' : J := ⟨N, h_N_in_J⟩
      have h_A : ∃ A : I, N ≤ A.val := by
        exact (RefinementMapSurj' I J h_I_le_J) N'
      rcases h_A with ⟨A, h_N_le_A⟩
      choose f hf hf' using h_J_le_I
      let h_B₁ := hf' N'.prop
      let h_B₂ := hf N'.prop
      simp only at h_B₁
      have h_mem : A.val ∈ f N'.prop := by
        by_contra h_A_not_mem
        have h_aux : Disjoint A.val (sSup (f N'.prop)) := by
          exact (I.sSupIndep.disjoint_sSup A.prop h_B₂ h_A_not_mem)
        have h_aux' : sSup (f N'.prop) ≤ A.val := h_B₁ ▸ h_N_le_A
        have h_last : sSup (f N'.prop) = (⊥ : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [← h_B₁] at h_last
        subst h_last
        exact (J.not_bot_mem h_N_in_J)
      have h_A_le_N : A.val ≤ N := by
        simpa [← h_B₁] using le_sSup h_mem
      have h_A_eq_N : A.val = N := by
        exact (le_antisymm h_A_le_N h_N_le_A)
      have h_contra : N ∈ I := by
        exact h_A_eq_N ▸ A.prop
      aesop
    have h_final_right : ∀ N ∈ I, N ∈ J := by
      intro N
      by_contra h_neg
      push_neg at h_neg
      rcases h_neg with ⟨h_N_in_I, h_N_not_in_J⟩
      let N' : I := ⟨N, h_N_in_I⟩
      have h_B : ∃ B : J, N ≤ B.val := by
        exact (RefinementMapSurj' J I h_J_le_I) N'
      rcases h_B with ⟨B, h_N_le_B⟩
      choose f hf hf' using h_I_le_J
      let h_B₁ := hf' N'.prop
      let h_B₂ := hf N'.prop
      simp only at h_B₁
      have h_mem : B.val ∈ f N'.prop := by
        by_contra h_B_not_mem
        have h_aux : Disjoint B.val (sSup (f N'.prop)) := by
          exact (J.sSupIndep.disjoint_sSup B.prop h_B₂ h_B_not_mem)
        have h_aux' : sSup (f N'.prop) ≤ B.val := h_B₁ ▸ h_N_le_B
        have h_last : sSup (f N'.prop) = (⊥ : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [← h_B₁] at h_last
        subst h_last
        exact (I.not_bot_mem h_N_in_I)
      have h_B_le_N : B.val ≤ N := by
        simpa [← h_B₁] using le_sSup h_mem
      have h_B_eq_N : B.val = N := by
        exact (le_antisymm h_B_le_N h_N_le_B)
      have h_contra : N ∈ J := by
        exact h_B_eq_N ▸ B.prop
      aesop
    ext N
    exact ⟨h_final_right N, h_final_left N⟩
