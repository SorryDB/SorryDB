@[sorryful]
lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have h_nonneg : 0 ≤ ‖IC.x₀‖ ^ 2 + (‖IC.v₀‖ / S.ω) ^ 2 :=
    add_nonneg (sq_nonneg _) (div_nonneg (sq_nonneg _) (sq_nonneg _))
  constructor
  · intro h
    have h1 := congr_fun (trajectory_energy S IC) t
    simp [energy, kineticEnergy, potentialEnergy, h] at h1
    rw [← sq_eq_sq (norm_nonneg _) (sqrt_nonneg _), sq_sqrt h_nonneg]
    field_simp [S.k_pos.ne', ω_sq, ω_neq_zero] at h1 ⊢
    rw [← h1]
    ring
  · intro h
    have h1 := congr_fun (trajectory_energy S IC) t
    simp [energy, kineticEnergy, potentialEnergy] at h1
    rw [← sq_eq_sq (norm_nonneg _) (sqrt_nonneg _), sq_sqrt h_nonneg] at h
    rw [h, ω_sq] at h1
    field_simp [S.m_pos.ne', S.k_pos.ne', ω_neq_zero] at h1
    simp [S.m_pos.ne', sq_eq_zero_iff, norm_eq_zero] at h1
    exact h1
