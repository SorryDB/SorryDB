@[sorryful]
lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖IC.trajectory S t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have hE := congr_fun (trajectory_energy S IC) t
  simp [energy, kineticEnergy, potentialEnergy, real_inner_self_eq_norm_sq] at hE
  have h_nonneg : 0 ≤ ‖IC.x₀‖ ^ 2 + (‖IC.v₀‖ / S.ω) ^ 2 := add_nonneg (sq_nonneg _) (sq_nonneg _)
  have h_k : S.k = S.m * S.ω ^ 2 := by rw [ω_sq]; field_simp [S.m_pos.ne', S.ω_neq_zero]
  constructor
  · intro h_vel
    rw [h_vel] at hE
    rw [Real.sqrt_eq_iff_sq_eq (norm_nonneg _) h_nonneg]
    field_simp [S.m_pos.ne', S.k_pos.ne', S.ω_neq_zero] at hE ⊢
    try rw [h_k] at hE
    field_simp [S.m_pos.ne', S.ω_neq_zero] at hE ⊢
    nlinarith
  · intro h_pos
    rw [h_pos, Real.sq_sqrt h_nonneg] at hE
    field_simp [S.m_pos.ne', S.k_pos.ne', S.ω_neq_zero] at hE
    try rw [h_k] at hE
    field_simp [S.m_pos.ne', S.ω_neq_zero] at hE
    have h_v_sq : ‖∂ₜ (IC.trajectory S) t‖ ^ 2 = 0 := by nlinarith [S.m_pos]
    exact norm_eq_zero.mp (sq_eq_zero_iff.mp h_v_sq)
