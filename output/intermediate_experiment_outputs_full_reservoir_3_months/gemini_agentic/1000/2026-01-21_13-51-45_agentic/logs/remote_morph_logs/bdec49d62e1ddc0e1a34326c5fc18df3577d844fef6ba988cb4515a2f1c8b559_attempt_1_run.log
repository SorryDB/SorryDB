import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / (x : ℝ)}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f; constructor
  · rintro ⟨hf0, hf1⟩
    ext x; simp [answer] at *
    let h (z : ℝ+) := (z : ℝ) * f z
    have h_pos z : 0 < h z := mul_pos z.2 (hf0 z)
    have h_le_1 z : h z ≤ 1 := by
      rcases hf1 z with ⟨y, hy, -⟩
      have := (two_mul_sqrt_le_add ((z : ℝ) * f y) ((y : ℝ) * f z) (by positivity) (by positivity)).trans hy
      rw [← Real.sqrt_mul] at this; convert Real.sqrt_le_one_iff.mp (by linarith) using 2; ring
    have h_eq_1 z : h z = 1 := by
      by_contra! h_lt_1
      rcases hf1 z with ⟨y_sol, hy_unique⟩
      have : y_sol = z := hy_unique.unique hy_unique.choose_spec (by dsimp [h]; linarith [h_le_1 z])
      let y : ℝ+ := ⟨z / Real.sqrt (h z), by positivity⟩
      have hy : (z : ℝ) * f y + (y : ℝ) * f z < 2 := by
        calc (z : ℝ) * f y + (y : ℝ) * f z
          _ = (z / y) * h y + (y / z) * h z := by field_simp [z.2.ne', y.2.ne']; ring
          _ ≤ (z / y) * 1 + (y / z) * h z := by nlinarith [h_le_1 y, z.2, y.2]
          _ = 2 * Real.sqrt (h z) := by field_simp [z.2.ne', (Real.sqrt_pos.mpr (h_pos z)).ne']; ring
          _ < 2 := by linarith [Real.sqrt_lt_one_iff.mpr ⟨(h_pos z).le, h_lt_1⟩]
      have : y = z := by rw [this] at hy_unique; exact hy_unique.unique hy.le
      simp [y] at this; linarith [Real.sqrt_eq_one_iff_eq_one.mp this]
    have : f x = 1 / x := by
      have := h_eq_1 x; dsimp [h] at this; field_simp [x.2.ne'] at this; exact this
    exact this
  · rintro rfl; simp [answer]; intro x
    refine ⟨x, by simp [x.2.ne'], fun y hy => ?_⟩
    have : (x : ℝ) / y + (y : ℝ) / x ≤ 2 := by
      convert hy; field_simp [x.2.ne', y.2.ne']
    have : (x : ℝ) / y + (y : ℝ) / x ≥ 2 := by
      field_simp [x.2.ne', y.2.ne']; rw [ge_iff_le, div_le_iff (mul_pos x.2 y.2)]; nlinarith
    exact Subtype.ext (by nlinarith)

