        exact (Real.sqrt_le_one_iff (by positivity)).mp (h_amgm.trans hy_le)
      by_contra! hgz
      have hgy : g y < 1 := (mul_lt_iff_lt_one_right hgz).mp h_gzgy
      have y_sol : (y : ℝ) * f y + (y : ℝ) * f y ≤ 2 := by dsimp [g] at *; nlinarith
