import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => (x : ℝ)⁻¹}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  constructor
  · rintro ⟨hf_pos, hf_unique⟩
    rw [answer, Set.mem_singleton_iff]
    ext x
    let g : ℝ+ → ℝ := fun z => (z : ℝ) * f z
    have hg_pos z : 0 < g z := mul_pos z.2 (hf_pos z)
    have hg_le_1 z : g z ≤ 1 := by
      rcases hf_unique z with ⟨y, hy_le, hy_uni⟩
      have h_gzgy : g z * g y ≤ 1 := by
        have h_amgm : 2 * Real.sqrt (g z * g y) ≤ (z : ℝ) * f y + (y : ℝ) * f z := by
          rw [show (z : ℝ) * f y = (z : ℝ) / (y : ℝ) * g y by field_simp [y.2.ne'],
              show (y : ℝ) * f z = (y : ℝ) / (z : ℝ) * g z by field_simp [z.2.ne']]
          have h := two_mul_sqrt_le_add ((z : ℝ) / (y : ℝ) * g y) ((y : ℝ) / (z : ℝ) * g z) (by positivity) (by positivity)
          rw [show ((z : ℝ) / (y : ℝ) * g y) * ((y : ℝ) / (z : ℝ) * g z) = g z * g y by field_simp [z.2.ne', y.2.ne']; ring] at h
          exact h
        rw [← Real.sqrt_le_one_iff (by positivity)]
        nlinarith
      by_contra! hgz
      have hgy : g y < 1 := by nlinarith [hg_pos y]
      have y_sol : (y : ℝ) * f y + (y : ℝ) * f y ≤ 2 := by dsimp [g]; nlinarith
      have : y = z := (hf_unique y).unique y_sol (by rw [add_comm]; exact hy_le)
      linarith
    have hg_eq_1 : g x = 1 := by
      by_contra! hg_ne_1
      have hg_lt_1 : g x < 1 := hg_ne_1.lt_of_le (hg_le_1 x)
      let y2 : ℝ+ := ⟨x / Real.sqrt (g x), by positivity⟩
      have y2_sol : (x : ℝ) * f y2 + (y2 : ℝ) * f x ≤ 2 := by
        rw [show (x : ℝ) * f y2 = (x : ℝ) / (y2 : ℝ) * g y2 by field_simp [y2.2.ne'],
            show (y2 : ℝ) * f x = (y2 : ℝ) / (x : ℝ) * g x by field_simp [x.2.ne']]
        calc (x : ℝ) / (y2 : ℝ) * g y2 + (y2 : ℝ) / (x : ℝ) * g x
          _ ≤ (x : ℝ) / (y2 : ℝ) * 1 + (y2 : ℝ) / (x : ℝ) * g x := by gcongr; exact hg_le_1 y2
          _ = 2 * Real.sqrt (g x) := by dsimp [y2, g]; field_simp [x.2.ne', (Real.sqrt_pos.mpr (hg_pos x)).ne']; ring
          _ ≤ 2 := (Real.sqrt_le_one_iff (hg_pos x).le).mpr (hg_le_1 x)
      have x_sol : (x : ℝ) * f x + (x : ℝ) * f x ≤ 2 := by dsimp [g]; nlinarith
      have y2_eq : y2 = x := (hf_unique x).unique y2_sol x_sol
      have : Real.sqrt (g x) = 1 := by
        have : (y2 : ℝ) = x := Subtype.ext_iff.mp y2_eq
        dsimp [y2] at this; field_simp [x.2.ne', (Real.sqrt_pos.mpr (hg_pos x)).ne'] at this; exact this
      nlinarith [Real.sqrt_eq_one_iff_eq_one (hg_pos x).le]
    dsimp [g] at hg_eq_1; field_simp [x.2.ne'] at hg_eq_1; exact hg_eq_1
  · rw [answer, Set.mem_singleton_iff]; rintro rfl
    constructor
    · intro x; positivity
    · intro x; use x; constructor
      · field_simp [x.2.ne']; ring
      · intro y hy; field_simp [x.2.ne', y.2.ne'] at hy
        have : (x : ℝ)^2 + (y : ℝ)^2 ≤ 2 * x * y := by nlinarith
        have : ((x : ℝ) - y)^2 ≤ 0 := by nlinarith
        exact Subtype.ext (by nlinarith [sq_nonneg ((x : ℝ) - y)])

