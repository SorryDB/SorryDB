      have y2_eq_y_sol : y2 = y_sol := hy_sol_uni y2 y2_sol.le
      have x_eq_y_sol : x = y_sol := hy_sol_uni x x_sol_for_x
      have : y2 = x := by rw [y2_eq_y_sol, x_eq_y_sol]
      have h_sqrt : Real.sqrt (g x) = 1 := by
        let this' := Subtype.ext_iff.mp this
        field_simp [x.2.ne', (by positivity : Real.sqrt (g x) ≠ 0)] at this'
        exact this'
