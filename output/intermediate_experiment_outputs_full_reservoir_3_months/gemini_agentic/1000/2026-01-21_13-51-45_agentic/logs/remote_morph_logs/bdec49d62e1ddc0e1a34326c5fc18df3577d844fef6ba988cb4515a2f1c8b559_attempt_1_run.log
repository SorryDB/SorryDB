        rw [← Real.sqrt_eq_one_iff_eq_one (hg_pos x).le]
        exact h_sqrt
      exact hg_lt_1 this
    dsimp [g] at hg_eq_1; field_simp [x.2.ne'] at hg_eq_1; exact hg_eq_1
