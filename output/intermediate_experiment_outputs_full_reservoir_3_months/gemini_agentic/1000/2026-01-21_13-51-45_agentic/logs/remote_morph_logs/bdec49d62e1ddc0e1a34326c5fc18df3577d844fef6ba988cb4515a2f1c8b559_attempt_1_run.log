        have h_amgm := this.trans hy_le
        rw [mul_le_iff_le_one_right (by norm_num), Real.sqrt_le_one_iff (by positivity)] at h_amgm
        exact h_amgm
      by_contra hgz_gt_1
      have hgy_lt_1 : g y < 1 := by
        have : 0 < g z := hg_pos z
        nlinarith
      have y_sol_for_y : (y : ℝ) * f y + (y : ℝ) * f y ≤ 2 := by
        dsimp [g] at *; nlinarith
      rcases hf_unique y with ⟨y_sol, hy_sol_le, hy_sol_uni⟩
      have y_eq_y_sol : y = y_sol := hy_sol_uni y y_sol_for_y
      have z_eq_y_sol : z = y_sol := hy_sol_uni z (by rw [add_comm]; exact hy_le)
      have : z = y := by rw [z_eq_y_sol, y_eq_y_sol]
      rw [this] at hgz_gt_1
      linarith
    have hg_eq_1 : g x = 1 := by
      by_contra hg_lt_1
      have hg_x_lt_1 : g x < 1 := (hg_le_1 x).lt_of_ne hg_lt_1
      have x_sol_for_x : (x : ℝ) * f x + (x : ℝ) * f x ≤ 2 := by
        dsimp [g] at *; nlinarith
      let y2 : ℝ+ := ⟨x / Real.sqrt (g x), by positivity⟩
      have y2_sol : (x : ℝ) * f y2 + (y2 : ℝ) * f x < 2 := by
        rw [show (x : ℝ) * f y2 = (x / y2) * g y2 by field_simp [y2.2.ne'],
            show (y2 : ℝ) * f x = (y2 / x) * g x by field_simp [x.2.ne']]
        calc (x / y2 : ℝ) * g y2 + (y2 / x : ℝ) * g x
          _ ≤ (x / y2 : ℝ) * 1 + (y2 / x : ℝ) * g x := by nlinarith [hg_le_1 y2, x.2, y2.2]
          _ = 2 * Real.sqrt (g x) := by
