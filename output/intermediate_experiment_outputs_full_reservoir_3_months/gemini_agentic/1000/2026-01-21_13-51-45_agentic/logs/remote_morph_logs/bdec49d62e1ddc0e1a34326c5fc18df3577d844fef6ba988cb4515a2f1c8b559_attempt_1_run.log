import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / (x : ℝ)}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  constructor
  · rintro ⟨hf_pos, hf_unique⟩
    suffices f = fun x => 1 / (x : ℝ) by
      rw [answer, Set.mem_singleton_iff]
      exact this
    ext x
    let g (z : ℝ+) : ℝ := (z : ℝ) * f z
    have hg_pos : ∀ z, 0 < g z := fun z => mul_pos z.2 (hf_pos z)
    have hg_le_1 : ∀ z, g z ≤ 1 := by
      intro z
      rcases hf_unique z with ⟨y, hy_le, hy_uni⟩
      have h_amgm : 2 * Real.sqrt (g z * g y) ≤ (z : ℝ) * f y + (y : ℝ) * f z := by
        rw [show (z : ℝ) * f y = (z / y) * g y by field_simp [y.2.ne'],
            show (y : ℝ) * f z = (y / z) * g z by field_simp [z.2.ne']]
        convert two_mul_sqrt_le_add ((z / y) * g y) ((y / z) * g z) (by positivity) (by positivity) using 2
        field_simp [z.2.ne', y.2.ne']; ring
      have h_gzgy : g z * g y ≤ 1 := by
        rw [← Real.sqrt_le_one_iff (by positivity)]
        nlinarith
      by_contra hgz
      have hgy : g y < 1 := by nlinarith [hg_pos y]
      have : y = z := by
        have y_sol : (y : ℝ) * f y + (y : ℝ) * f y ≤ 2 := by dsimp [g] at *; nlinarith
        have z_sol : (y : ℝ) * f z + (z : ℝ) * f y ≤ 2 := by rw [add_comm]; exact hy_le
        exact (hf_unique y).unique y_sol z_sol
      rw [this] at hgz
      linarith
    have hg_eq_1 : g x = 1 := by
      by_contra hg_ne_1
      have hg_lt_1 : g x < 1 := (hg_le_1 x).lt_of_ne hg_ne_1
      rcases hf_unique x with ⟨y_sol, hy_sol_le, hy_sol_uni⟩
      have x_sol_for_x : (x : ℝ) * f x + (x : ℝ) * f x ≤ 2 := by dsimp [g] at *; nlinarith
      have : y_sol = x := hy_sol_uni x x_sol_for_x
      let y2 : ℝ+ := ⟨x / Real.sqrt (g x), by positivity⟩
      have y2_sol : (x : ℝ) * f y2 + (y2 : ℝ) * f x ≤ 2 := by
        rw [show (x : ℝ) * f y2 = (x / y2) * g y2 by field_simp [y2.2.ne'],
            show (y2 : ℝ) * f x = (y2 / x) * g x by field_simp [x.2.ne']]
        calc (x / y2) * g y2 + (y2 / x) * g x
          _ ≤ (x / y2) * 1 + (y2 / x) * g x := by nlinarith [hg_le_1 y2, x.2, y2.2]
          _ = 2 * Real.sqrt (g x) := by dsimp [y2, g]; field_simp [x.2.ne', (by positivity : Real.sqrt (g x) ≠ 0)]; ring
          _ ≤ 2 := by rw [Real.sqrt_le_one_iff (hg_pos x).le]; linarith
      have : y2 = x := hy_sol_uni y2 y2_sol
      have : g x = 1 := by
        have : (y2 : ℝ) = x := Subtype.ext_iff.mp this
        dsimp [y2] at this
        field_simp [x.2.ne', (by positivity : Real.sqrt (g x) ≠ 0)] at this
        nlinarith [Real.sqrt_eq_one_iff_eq_one (hg_pos x).le]
      contradiction
    dsimp [g] at hg_eq_1; field_simp [x.2.ne'] at hg_eq_1; exact hg_eq_1
  · rw [answer, Set.mem_singleton_iff]; rintro rfl
    constructor
    · intro x; positivity
    · intro x; use x; constructor
      · field_simp; linarith [x.2]
      · intro y hy; field_simp [x.2.ne', y.2.ne'] at hy
        have : (x : ℝ)^2 + (y : ℝ)^2 ≤ 2 * x * y := by nlinarith
        have : ((x : ℝ) - y)^2 ≤ 0 := by nlinarith
        exact Subtype.ext (by nlinarith [sq_nonneg ((x : ℝ) - y)])

