      by_contra! hg_ne_1
      have hg_lt_1 : g z < 1 := hg_ne_1.lt_of_le (hg_le_1 z)
      let y2 : ℝ+ := ⟨(z : ℝ) / Real.sqrt (g z), by positivity⟩
      have y2_sol : (z : ℝ) * f y2 + (y2 : ℝ) * f z ≤ 2 := by
        calc (z : ℝ) * f y2 + (y2 : ℝ) * f z
          _ = (z : ℝ) / (y2 : ℝ) * g y2 + (y2 : ℝ) / (z : ℝ) * g z := by dsimp [g]; field_simp [y2.2.ne', z.2.ne']
          _ ≤ (z : ℝ) / (y2 : ℝ) * 1 + (y2 : ℝ) / (z : ℝ) * g z := by nlinarith [hg_le_1 y2, z.2, y2.2]
