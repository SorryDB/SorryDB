          _ ≤ 2 := (Real.sqrt_le_one_iff (hg_pos z).le).mpr (hg_le_1 z)
      have z_sol : (z : ℝ) * f z + (z : ℝ) * f z ≤ 2 := by dsimp [g]; nlinarith [hg_le_1 z]
      have : y2 = z := (hf_unique z).unique y2_sol z_sol
      have : Real.sqrt (g z) = 1 := by
        have : (y2 : ℝ) = (z : ℝ) := Subtype.ext_iff.mp this
        dsimp [y2] at this; field_simp [z.2.ne', (Real.sqrt_pos.mpr (hg_pos z)).ne'] at this; exact this
