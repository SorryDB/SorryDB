          have h2 : (⟪y, p y⟫_ℂ).re ≤ ‖y‖ * ‖p y‖ :=
            (Complex.re_le_abs _).trans (norm_inner_le_norm _ _)
          rw [← h1] at h2
          exact le_of_mul_self_le_mul_right (norm_nonneg _) h2
        exact h_norm (E.measureOf' w₂ x)
