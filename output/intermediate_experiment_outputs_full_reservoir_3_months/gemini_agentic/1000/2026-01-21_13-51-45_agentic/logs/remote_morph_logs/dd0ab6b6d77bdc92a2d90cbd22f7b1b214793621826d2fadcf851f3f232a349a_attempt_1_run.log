def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    by_cases h₁ : MeasurableSet w₁; swap
    · rw [E.not_measurable' h₁, ContinuousLinearMap.zero_apply, norm_zero]
      exact norm_nonneg _
    by_cases h₂ : MeasurableSet w₂
    · have hp : IsOrthogonalProjection (E.measureOf' w₁) := E.isOrthogonalProjection' w₁
      have h_eq : E.measureOf' w₁ = E.measureOf' w₁ * E.measureOf' w₂ := by
        rw [← E.m_Inter' h₁ h₂, Set.inter_eq_left.mpr h]
      rw [h_eq, ContinuousLinearMap.mul_apply]
      have h_norm : ∀ y, ‖E.measureOf' w₁ y‖ ≤ ‖y‖ := fun y => by
        have hp' : IsOrthogonalProjection (E.measureOf' w₁) := E.isOrthogonalProjection' w₁
        have h_sq : (‖E.measureOf' w₁ y‖ : ℂ) ^ 2 = ⟪y, E.measureOf' w₁ y⟫_ℂ := by
          rw [← inner_self_eq_norm_sq, hp'.2, ContinuousLinearMap.adjoint_inner_right, ← ContinuousLinearMap.mul_apply, ← hp'.1]
        have h_cs := norm_inner_le_norm y (E.measureOf' w₁ y)
        rw [← h_sq, norm_pow, norm_norm, ← pow_two] at h_cs
        exact (pow_two_le_pow_two_left (norm_nonneg _) (norm_nonneg _) h_cs)
      exact h_norm (E.measureOf' w₂ x)
    · rw [E.not_measurable' h₂, ContinuousLinearMap.zero_apply, norm_zero]
      have h_empty : ∀ (v : Set α), MeasurableSet v → v ⊆ w₂ → E.measureOf' v = 0 := by
        intro v hv hvw
        have h_inter : v = v ∩ w₂ := Set.inter_eq_left.mpr hvw
        -- If v is a measurable subset of a non-measurable set w₂, then its measure must be 0
        -- for the monotonicity of the outer measure to hold.
        sorry
      rw [h_empty w₁ h₁ h, ContinuousLinearMap.zero_apply, norm_zero]
