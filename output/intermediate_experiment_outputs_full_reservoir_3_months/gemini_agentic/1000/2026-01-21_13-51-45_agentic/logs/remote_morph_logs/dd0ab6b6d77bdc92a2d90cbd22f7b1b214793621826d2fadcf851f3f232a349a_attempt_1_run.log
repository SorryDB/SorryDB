def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    by_cases h₂ : MeasurableSet w₂
    · by_cases h₁ : MeasurableSet w₁
      · have h_inter : E.measureOf' w₁ = E.measureOf' w₁ * E.measureOf' w₂ := by
          rw [← E.m_Inter' h₁ h₂, inter_eq_left.mpr h]
        rw [h_inter, ContinuousLinearMap.mul_apply]
        let p := E.measureOf' w₁
        have hp : IsOrthogonalProjection p := E.isOrthogonalProjection' w₁
        have h_norm : ∀ y, ‖p y‖ ≤ ‖y‖ := fun y => by
          have h_sq : ‖p y‖^2 = ⟪y, p y⟫_ℂ := by
            rw [inner_self_eq_norm_sq_Complex, hp.2, ← ContinuousLinearMap.mul_apply, ← hp.1]
          rw [← inner_self_eq_norm_sq_Complex] at h_sq
          by_cases h_zero : ‖p y‖ = 0
          · rw [h_zero]; exact norm_nonneg _
          · exact (mul_le_mul_right (pos_iff_ne_zero.mpr h_zero)).mp (h_sq.symm ▸ (inner_le_norm y (p y)))
        exact h_norm (E.measureOf' w₂ x)
      · rw [E.not_measurable' h₁, ContinuousLinearMap.zero_apply, norm_zero]
        exact norm_nonneg _
    · rw [E.not_measurable' h₂, ContinuousLinearMap.zero_apply, norm_zero]
      by_cases h₁ : MeasurableSet w₁
      · sorry
      · rw [E.not_measurable' h₁, ContinuousLinearMap.zero_apply, norm_zero]
