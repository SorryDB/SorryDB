    IsBernoulliOn (fun ω ↦ u \ X ω) u (σ p) P where
  aemeasurable := by
    let k : (ι → Prop) → (ι → Prop) := fun g i ↦ i ∈ u ∧ ¬ g i
    have hk : Measurable k := measurable_pi_lambda _ fun i ↦ measurable_from_top (α := Prop) rfl
    let f : Set ι → Set ι := MeasurableEquiv.setOf.symm ∘ k ∘ MeasurableEquiv.setOf
    have hf : Measurable f := MeasurableEquiv.setOf.symm.measurable.comp <|
      hk.comp MeasurableEquiv.setOf.measurable
    exact hf.comp_aemeasurable hX.aemeasurable
  map_eq := by
    let k : (ι → Prop) → (ι → Prop) := fun g i ↦ i ∈ u ∧ ¬ g i
    have hki i : Measurable (fun (g_i : Prop) ↦ (i ∈ u ∧ ¬ g_i)) :=
      measurable_from_top (α := Prop) rfl
    have hk : Measurable k := measurable_pi_lambda _ fun i ↦ (hki i).comp (measurable_pi_apply i)
    let f : Set ι → Set ι := MeasurableEquiv.setOf.symm ∘ k ∘ MeasurableEquiv.setOf
    have hf : Measurable f := MeasurableEquiv.setOf.symm.measurable.comp <|
      hk.comp MeasurableEquiv.setOf.measurable
    rw [show (fun ω ↦ u \ X ω) = f ∘ X by ext ω; simp [f, k], hX.aemeasurable.map_eq_map hf, hX.map_eq,
      bernoulliOn_eq_map, bernoulliOn_eq_map, Measure.map_map MeasurableEquiv.setOf.symm.measurable hk,
      show f ∘ (MeasurableEquiv.setOf.symm : (ι → Prop) → Set ι) = MeasurableEquiv.setOf.symm ∘ k by ext; simp [f, k],
      ← Measure.map_map MeasurableEquiv.setOf.symm.measurable hk, Measure.map_infinitePi hki]
    · congr 1; ext i
      rw [Measure.map_add, Measure.map_smul, Measure.map_smul, Measure.map_dirac (hki i), Measure.map_dirac (hki i)]
      simp [σ]; split_ifs <;> simp [*]
