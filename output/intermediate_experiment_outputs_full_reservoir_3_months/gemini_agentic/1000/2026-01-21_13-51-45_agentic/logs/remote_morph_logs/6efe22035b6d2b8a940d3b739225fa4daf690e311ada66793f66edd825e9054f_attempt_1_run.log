namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨p / 4, fun hp => ?_⟩
    have hp1 : p % 4 = 1 := by rw [hp]; norm_num
    haveI : Fact p.Prime := h
    have ⟨s, hs⟩ : ∃ s : ZMod p, s ^ 2 = -1 :=
      ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [hp1]; norm_num)
    have h_ne : s ≠ -s := by
      intro h_eq
      have h20 : (2 : ZMod p) * s = 0 := by rw [two_mul, add_eq_zero_iff_eq_neg, h_eq]
      have h2z : (2 : ZMod p) = 0 := by
        refine (mul_eq_zero.mp h20).resolve_right ?_
        intro hs0
        rw [hs0, pow_two, zero_mul] at hs
        have : (1 : ZMod p) = 0 := neg_eq_zero.mp hs.symm
        exact h.out.not_dvd_one ((ZMod.natCast_eq_zero p 1).mp this)
      have hp2 : p ∣ 2 := (ZMod.natCast_eq_zero p 2).mp h2z
      have : p = 2 := h.out.eq_two_of_dvd hp2
      rw [this] at hp1; norm_num at hp1
    dsimp [num_solutions]
    rw [Finset.card_eq_two]
    refine ⟨s, -s, h_ne, ?_⟩
    ext x
    simp
    rw [← hs, sq_eq_sq_iff_eq_or_eq_neg]
```
