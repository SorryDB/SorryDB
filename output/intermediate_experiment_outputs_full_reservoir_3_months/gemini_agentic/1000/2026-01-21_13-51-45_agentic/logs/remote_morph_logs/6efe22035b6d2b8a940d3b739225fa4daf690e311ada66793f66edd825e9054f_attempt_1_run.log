```lean
namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨p / 4, fun hp => ?_⟩
    have hp1 : p % 4 = 1 := by rw [hp]; norm_num
    have h_sq : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [hp1]; norm_num)
    obtain ⟨s, hs⟩ := h_sq
    dsimp [num_solutions]
    rw [Finset.card_eq_two]
    refine ⟨s, -s, ?_, ?_⟩
    · intro h_eq
      have h2s : (2 : ZMod p) * s = 0 := by rw [two_mul, add_eq_zero_iff_eq_neg, h_eq]
      have h2z : (2 : ZMod p) = 0 := (mul_eq_zero.mp h2s).resolve_right (by
        intro h_s0
        rw [h_s0, mul_zero] at hs
        have : (1 : ZMod p) = 0 := neg_eq_zero.mp hs.symm
        exact h.out.not_dvd_one ((ZMod.zero_iff_dvd p 1).mp this))
      have hp2 : p ∣ 2 := (ZMod.zero_iff_dvd p 2).mp h2z
      have : p = 2 := h.out.eq_two_of_dvd hp2
      rw [this] at hp1; norm_num at hp1
    · intro x
      simp
      rw [← hs, ← pow_two, sq_eq_sq_iff_eq_or_eq_neg]
```
