namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨p / 4, fun hp => ?_⟩
    have hp1 : p % 4 = 1 := by rw [hp]; norm_num
    obtain ⟨a, ha⟩ := (ZMod.exists_sq_eq_neg_one_iff (p := p)).mpr (by rw [hp1]; norm_num)
    rw [Finset.card_eq_two]
    refine ⟨a, -a, ?_, ?_⟩
    · intro h_eq
      have h2a : (2 : ZMod p) * a = 0 := by rw [two_mul, add_eq_zero_iff_eq_neg, h_eq]
      have h2z : (2 : ZMod p) = 0 ∨ a = 0 := mul_eq_zero.mp h2a
      cases h2z with
      | inl h2 =>
        have hp2 : p ∣ 2 := (ZMod.zero_iff_dvd p 2).mp h2
        have : p = 2 := Nat.Prime.eq_two_of_dvd h.out hp2
        rw [this] at hp1; norm_num at hp1
      | inr ha0 =>
        rw [ha0, mul_zero] at ha
        have : (1 : ZMod p) = 0 := neg_eq_zero.mp ha.symm
        exact h.out.not_dvd_one ((ZMod.zero_iff_dvd p 1).mp this)
    · ext x
      simp [ha, ← pow_two, sq_eq_sq_iff_eq_or_eq_neg]
