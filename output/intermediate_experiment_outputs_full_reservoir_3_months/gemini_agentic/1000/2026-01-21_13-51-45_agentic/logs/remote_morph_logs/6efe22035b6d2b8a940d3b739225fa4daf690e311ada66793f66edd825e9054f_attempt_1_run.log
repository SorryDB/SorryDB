namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨p / 4, fun hp => ?_⟩
    have hp1 : p % 4 = 1 := by rw [hp]; norm_num
    haveI : Fact p.Prime := h
    have : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [hp1]; norm_num)
    obtain ⟨s, hs⟩ := this
    rw [Finset.card_eq_two]
    use s, -s
    constructor
    · intro h_eq
      have h2s : (2 : ZMod p) * s = 0 := by rw [two_mul, ← add_eq_zero_iff_eq_neg, h_eq]
      have h2 : (2 : ZMod p) ≠ 0 := by
        intro h2z
        have : p = 2 := h.out.eq_two_of_dvd (ZMod.natCast_eq_zero.mp h2z)
        rw [this] at hp1; norm_num at hp1
      have hs0 : s ≠ 0 := by
        intro h0
        rw [h0, zero_pow (by norm_num)] at hs
        have : (1 : ZMod p) = 0 := neg_eq_zero.mp hs.symm
        exact h.out.not_dvd_one (ZMod.natCast_eq_zero.mp this)
      exact h2 (mul_eq_zero.mp h2s |>.resolve_right hs0)
    · ext x
      simp [sq_eq_sq, ← hs, pow_two]
