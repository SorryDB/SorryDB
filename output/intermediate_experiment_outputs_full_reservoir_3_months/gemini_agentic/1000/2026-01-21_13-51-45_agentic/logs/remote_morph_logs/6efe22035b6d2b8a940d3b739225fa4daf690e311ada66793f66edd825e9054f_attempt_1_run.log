namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨p / 4, fun hp => ?_⟩
    have hp1 : p % 4 = 1 := by rw [hp, Nat.add_mod, Nat.mul_mod_right]; rfl
    have : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [hp1]; norm_num)
    obtain ⟨s, hs⟩ := this
    have hsn : s ≠ -s := by
      intro h_eq
      have h2 : (2 : ZMod p) ≠ 0 := by
        intro h0
        have : p = 2 := h.out.eq_two_of_dvd ((ZMod.natCast_zmod_eq_zero_iff_dvd 2 p).mp h0)
        rw [this] at hp1
        norm_num at hp1
      have hs0 : s ≠ 0 := by
        intro h0
        rw [h0, mul_zero] at hs
        exact h.out.not_dvd_one ((ZMod.natCast_zmod_eq_zero_iff_dvd 1 p).mp (neg_eq_zero.mp hs.symm))
      exact absurd (eq_neg_self_iff_two_mul_eq_zero.mp h_eq) (mul_ne_zero h2 hs0)
    rw [Finset.card_eq_two]
    use s, -s
    refine ⟨hsn, fun x => ?_⟩
    simp [sq_eq_sq, ← hs, ← pow_two]
```
