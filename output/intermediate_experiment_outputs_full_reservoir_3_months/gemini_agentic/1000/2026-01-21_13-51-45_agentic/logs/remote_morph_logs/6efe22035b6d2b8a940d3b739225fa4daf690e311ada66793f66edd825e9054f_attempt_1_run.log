import Mathlib.Tactic
import FormalBook.Widgets.Windmill

/-!
# Representing numbers as sums of two squares

## TODO
  - Lemma 1
    - statement
    - proof
  - Lemma 2
    - statement
    - proof
  Proposition
    - statement
    - first proof
    - second proof
      - 1.
      - 2.
      - 3.
    - third proof
  Theorem
    - statement
    - proof
      - (1)
      - (2)
      - (3)
      - (4)
      - (5)
-/


namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨p / 4, fun hp => ?_⟩
    have hp1 : p % 4 = 1 := by rw [hp]; norm_num
    have : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [hp1]; norm_num)
    obtain ⟨s, hs⟩ := this
    rw [Finset.card_eq_two]
    use s, -s
    constructor
    · intro hss
      have h2 : (2 : ZMod p) ≠ 0 := by
        intro h2z
        have hp2 : p = 2 := Nat.Prime.eq_two_of_dvd h.out (ZMod.natCast_eq_zero.mp h2z)
        rw [hp2] at hp1; norm_num at hp1
      have hs0 : s ≠ 0 := by
        intro h0
        rw [h0, mul_zero] at hs
        have : (1 : ZMod p) = 0 := neg_eq_zero.mp hs
        exact Nat.Prime.not_dvd_one h.out (ZMod.natCast_eq_zero.mp this)
      have : (2 : ZMod p) * s = 0 := by rwa [two_mul, add_eq_zero_iff_eq_neg]
      exact h2 (mul_eq_zero.mp this |>.resolve_right hs0)
    · ext x
      simp only [Set.mem_setOf_eq, Finset.mem_insert, Finset.mem_singleton]
      rw [← hs, sq, sq, sq_eq_sq]
