```lean
namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine' ⟨p / 4, fun hp => _⟩
    have hp1 : p % 4 = 1 := by rw [hp, Nat.add_comm, Nat.add_mul_mod_self_left]; rfl
    rw [ZMod.card_sqr_eq_neg_one p, hp1]
    split_ifs with h1 h2
    · norm_num at h1
    · rw [h2] at hp1; norm_num at hp1
    · rfl
```
