/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 := by
  let s : ℂ := -2 * ↑n
  let F : ℂ → ℂ := fun z => (2 : ℂ) * (2 * ↑Real.pi : ℂ) ^ (z - 1) * Complex.Gamma (1 - z) * riemannZeta (1 - z)
  let G : ℂ → ℂ := fun z => Complex.sin (↑Real.pi * z / 2)
  have h_eq : riemannZeta =ᶠ[nhds s] fun z => F z * G z := by
    have h_nhds : {z : ℂ | 1 < Complex.re (1 - z)} ∈ nhds s := by
      apply IsOpen.mem_nhds
      · apply IsOpen.preimage
        · exact Complex.continuous_re.comp (continuous_const.sub continuous_id)
        · exact isOpen_Ioi
      · simp [s]; linarith [hn]
    filter_upwards [h_nhds] with z hz
    have h1 : ∀ m : ℕ, (1 - z) ≠ -m := by
      intro m hm; have : Complex.re (1 - z) = Complex.re (-↑m : ℂ) := congr_arg Complex.re hm
      simp at this; linarith [hn]
    have h2 : (1 - z) ≠ 1 := by
      intro hm; have : Complex.re (1 - z) = Complex.re (1 : ℂ) := congr_arg Complex.re hm
      simp at this; linarith [hn]
    rw [show riemannZeta z = riemannZeta (1 - (1 - z)) by simp]
    rw [riemannZeta_one_sub h1 h2]
    dsimp [F, G]
    rw [show (↑Real.pi * (1 - z)) / 2 = ↑Real.pi / 2 - ↑Real.pi * z / 2 by ring]
    rw [Complex.cos_pi_div_two_sub, mul_rotate, mul_assoc]
  have hFs : DifferentiableAt ℂ F s := by
    apply DifferentiableAt.mul
    · apply DifferentiableAt.mul
      · apply DifferentiableAt.mul
        · exact differentiableAt_const _
        · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.sub (differentiableAt_const 1))
          left; simp; exact Real.pi_pos
      · apply (Complex.differentiableAt_Gamma (s := 1 - s) (by intro m; simp [s]; linarith [hn])).comp s ((differentiableAt_const 1).sub differentiableAt_id)
    · apply (differentiableAt_riemannZeta (s := 1 - s) (by simp [s]; linarith [hn])).comp s ((differentiableAt_const 1).sub differentiableAt_id)
  have hGs : DifferentiableAt ℂ G s := by
    apply DifferentiableAt.comp s Complex.differentiable_sin.differentiableAt
    exact (differentiableAt_id.const_mul _).div_const _
  have hGs_zero : G s = 0 := by
    dsimp [G, s]; rw [show ↑Real.pi * (-2 * ↑n) / 2 = -(↑n * ↑Real.pi) by ring]
    simp [Complex.sin_neg, Complex.sin_nat_mul_pi]
  have hGs_deriv : deriv G s = Complex.cos (↑Real.pi * s / 2) * (↑Real.pi / 2) := by
    apply HasDerivAt.deriv
    have h : HasDerivAt (fun z => ↑Real.pi * z / 2) (↑Real.pi / 2) s := by
      have : (fun z : ℂ => ↑Real.pi * z / 2) = (fun z => z * (↑Real.pi / 2)) := by ext1; ring
      rw [this]
      exact (hasDerivAt_id s).mul_const _
    exact (Complex.hasDerivAt_sin _).comp s h
  rw [Filter.EventuallyEq.deriv_eq h_eq]
  rw [deriv_mul hFs hGs]
  rw [hGs_zero, hGs_deriv]
  simp only [mul_zero, add_zero]
  apply mul_ne_zero
  · dsimp [F]
    apply mul_ne_zero
    · apply mul_ne_zero
      · apply mul_ne_zero
        · exact two_ne_zero
        · apply Complex.cpow_ne_zero; simp; exact Real.pi_pos.ne'
      · apply Complex.Gamma_ne_zero; intro m; simp [s]; linarith [hn]
    · apply riemannZeta_ne_zero_of_one_lt_re
      simp [s]; norm_cast; linarith [hn]
  · apply mul_ne_zero
    · rw [show ↑Real.pi * s / 2 = -(↑n * ↑Real.pi) by simp [s]; ring]
      rw [Complex.cos_neg, Complex.cos_nat_mul_pi]
      apply pow_ne_zero; norm_num
    · apply div_ne_zero (Complex.ofReal_ne_zero.mpr Real.pi_pos.ne') two_ne_zero
