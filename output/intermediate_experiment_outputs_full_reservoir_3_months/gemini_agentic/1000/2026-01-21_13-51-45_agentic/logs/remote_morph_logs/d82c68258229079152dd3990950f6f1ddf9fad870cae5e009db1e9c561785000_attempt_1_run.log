/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 := by
  let s : ℂ := -2 * (n : ℂ)
  let F : ℂ → ℂ := fun z => (2 : ℂ) ^ z * (Real.pi : ℂ) ^ (z - 1) * (Complex.Gamma (1 - z) * riemannZeta (1 - z))
  let G : ℂ → ℂ := fun z => Complex.sin (Real.pi * z / 2)
  have h_eq : riemannZeta =ᶠ[nhds s] fun z => F z * G z := by
    have h_nhds : {z : ℂ | z.re < 0} ∈ nhds s := by
      apply IsOpen.mem_nhds (Complex.continuous_re.isOpen_preimage _ isOpen_Iio)
      simp [s]; linarith
    filter_upwards [h_nhds] with z hz
    have h_not_int : ∀ m : ℕ, 1 - z ≠ -m := by
      intro m hm; apply_fun Complex.re at hm; simp at hm; linarith
    have h_not_one : 1 - z ≠ 1 := by
      intro hm; apply_fun Complex.re at hm; simp at hm; linarith
    rw [show riemannZeta z = riemannZeta (1 - (1 - z)) by simp, riemannZeta_one_sub h_not_int h_not_one]
    dsimp [F, G]
    rw [show (↑Real.pi * (1 - z)) / 2 = ↑Real.pi / 2 - ↑Real.pi * z / 2 by ring, Complex.cos_pi_div_two_sub]
    ring
  have hFs : DifferentiableAt ℂ F s := by
    apply DifferentiableAt.mul
    · apply DifferentiableAt.mul
      · apply DifferentiableAt.cpow (differentiableAt_const (2 : ℂ)) differentiableAt_id (Or.inl (by norm_num))
      · apply DifferentiableAt.cpow (differentiableAt_const (Real.pi : ℂ)) (differentiableAt_id.sub (differentiableAt_const 1)) (Or.inl (by simp; exact Real.pi_pos))
    · apply DifferentiableAt.mul
      · apply Complex.differentiableAt_Gamma.comp s ((differentiableAt_const 1).sub differentiableAt_id)
        intro m; simp [s]; linarith
      · apply (differentiableAt_riemannZeta (by simp [s]; linarith)).comp s ((differentiableAt_const 1).sub differentiableAt_id)
  have hGs : DifferentiableAt ℂ G s := by
    apply Complex.differentiable_sin.differentiableAt.comp s
    exact (differentiableAt_id.mul_const _).div_const _
  have hGs_zero : G s = 0 := by
    dsimp [G, s]; rw [show (Real.pi : ℂ) * (-2 * ↑n) / 2 = ↑(- (n : ℤ)) * ↑Real.pi by push_cast; ring]; simp [Complex.sin_int_mul_pi]
  have hGs_deriv : deriv G s = Complex.cos (↑Real.pi * s / 2) * (↑Real.pi / 2) := by
    apply HasDerivAt.deriv; exact Complex.hasDerivAt_sin _ |>.comp s ((hasDerivAt_id s).mul_const _ |>.div_const _)
  rw [Filter.EventuallyEq.deriv_eq h_eq, deriv_mul hFs hGs, hGs_zero, hGs_deriv]; simp only [mul_zero, add_zero]
  apply mul_ne_zero
  · dsimp [F]; iterate 3 apply mul_ne_zero
    · apply Complex.cpow_ne_zero; norm_num
    · apply Complex.cpow_ne_zero; simp; exact Real.pi_pos.ne'
    · apply Complex.Gamma_ne_zero
    · apply riemannZeta_ne_zero_of_one_lt_re; simp [s]; linarith
  · apply mul_ne_zero
    · have : (Real.pi : ℂ) * s / 2 = ↑(-(n : ℤ)) * ↑Real.pi := by push_cast; dsimp [s]; ring
      rw [this, Complex.cos_int_mul_pi]; apply zpow_ne_zero; norm_num
    · apply div_ne_zero (Complex.ofReal_ne_zero.mpr Real.pi_pos.ne') (by norm_num)

end Millennium
