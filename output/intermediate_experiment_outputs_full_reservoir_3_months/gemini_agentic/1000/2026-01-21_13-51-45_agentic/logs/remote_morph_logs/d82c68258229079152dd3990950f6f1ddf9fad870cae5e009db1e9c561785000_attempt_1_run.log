      apply ContinuousAt.preimage_mem_nhds (by continuity)
      simp [s]; linarith
    filter_upwards [h_nhds, isOpen_ne.mem_nhds h_s] with z hz_re hz_ne1
    have hz_gam : ∀ m : ℕ, 1 - z ≠ -m := by
      intro m hm; apply_fun Complex.re at hm; simp at hm; linarith
    rw [show riemannZeta z = riemannZeta (1 - (1 - z)) by simp, riemannZeta_one_sub hz_gam]
    simp; rw [show (Real.pi : ℂ) * (1 - z) / 2 = Real.pi / 2 - Real.pi * z / 2 by ring, Complex.cos_pi_div_two_sub]; ring
