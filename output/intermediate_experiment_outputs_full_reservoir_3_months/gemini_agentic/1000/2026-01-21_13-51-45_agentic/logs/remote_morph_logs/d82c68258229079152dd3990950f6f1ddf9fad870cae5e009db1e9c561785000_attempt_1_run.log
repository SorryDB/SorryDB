theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 := by
  let s : ℂ := -2 * n
  have h_ne_one : s ≠ 1 := by
    intro h; apply_fun Complex.re at h; simp [s] at h; norm_cast at h; linarith
  let f (z : ℂ) : ℂ := 2 * (2 * Real.pi) ^ (z - 1) * Complex.Gamma (1 - z) * riemannZeta (1 - z)
  let g (z : ℂ) : ℂ := Complex.sin (Real.pi * z / 2)
  have hfs : DifferentiableAt ℂ f s := by
    apply DifferentiableAt.mul
    · apply DifferentiableAt.mul
      · apply DifferentiableAt.const_mul
        apply DifferentiableAt.cpow
        · exact differentiableAt_const _
        · exact (differentiableAt_id.sub (differentiableAt_const 1))
        · left; simp; exact Real.pi_pos
      · apply Complex.differentiableAt_Gamma
        intro m; simp [s]; intro h; apply_fun Complex.re at h; simp at h; linarith
    · apply DifferentiableAt.comp
      · apply Complex.differentiableAt_riemannZeta.mpr
        simp [s]; linarith
      · exact (differentiableAt_const 1).sub differentiableAt_id
  have hgs : HasDerivAt g (Complex.cos (Real.pi * s / 2) * (Real.pi / 2)) s := by
    have h1 : HasDerivAt (fun z => (Real.pi : ℂ) * z / 2) (Real.pi / 2) s := by
      have h2 := HasDerivAt.mul_const (HasDerivAt.id s) (Real.pi : ℂ)
      simpa using HasDerivAt.div_const h2 2
    exact (Complex.hasDerivAt_sin (Real.pi * s / 2)).comp s h1
  have h_eq : riemannZeta =ᶠ[nhds s] fun z => f z * g z := by
    filter_upwards [isOpen_ne.mem_nhds h_ne_one] with z hz
    rw [Complex.riemannZeta_eq_two_mul_pow_pi_mul_sin_mul_gamma_mul_riemannZeta z]
    ring
  rw [h_eq.deriv_eq, deriv_mul hfs hgs.differentiableAt, hgs.deriv]
  have g_s : g s = 0 := by
    simp [g, s]
    rw [show (Real.pi * (-2 * ↑n) / 2 : ℂ) = ↑(-n : ℤ) * Real.pi by ring]
    simp [Complex.sin_int_mul_pi]
  rw [g_s]
  simp
  apply mul_ne_zero
  · apply mul_ne_zero
    · apply mul_ne_zero
      · apply mul_ne_zero
        · exact two_ne_zero
        · apply Complex.cpow_ne_zero; simp; exact Real.pi_pos.ne'
      · apply Complex.Gamma_ne_zero
        intro m; simp [s]; intro h; apply_fun Complex.re at h; simp at h; linarith
    · apply Complex.riemannZeta_ne_zero_of_one_lt_re
      simp [s]; norm_cast; linarith
  · apply mul_ne_zero
    · rw [show (Real.pi * s / 2 : ℂ) = ↑(-n : ℤ) * Real.pi by ring]
      rw [Complex.cos_int_mul_pi]; simp
    · apply div_ne_zero
      · norm_cast; exact Real.pi_pos.ne'
      · exact two_ne_zero

end Millennium
