/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 := by
  let s : ℂ := -2 * (n : ℂ)
  let F : ℂ → ℂ := fun z => (2 : ℂ) ^ z * (Real.pi : ℂ) ^ (z - 1) * Complex.Gamma (1 - z) * riemannZeta (1 - z)
  let G : ℂ → ℂ := fun z => Complex.sin (Real.pi * z / 2)
  have h_eq : riemannZeta =ᶠ[nhds s] fun z => F z * G z := by
    have h_nhds : {z : ℂ | 1 < (1 - z).re} ∈ nhds s := by
      apply ContinuousAt.preimage_mem_nhds (f := fun z => (1 - z).re)
      · exact continuousAt_const.sub Complex.continuous_re.continuousAt
      · simp [s]; linarith
    filter_upwards [h_nhds] with z hz
    have hz_gam : ∀ m : ℕ, 1 - z ≠ -m := by
      intro m hm; have := congr_arg Complex.re hm; simp at this; linarith
    rw [show riemannZeta z = riemannZeta (1 - (1 - z)) by simp, riemannZeta_one_sub hz_gam]
    simp only [mul_assoc]
    rw [show (↑Real.pi * (1 - z)) / 2 = ↑Real.pi / 2 - ↑Real.pi * z / 2 by ring, Complex.cos_pi_div_two_sub]
    simp [F, G]; ring
  have hFs : DifferentiableAt ℂ F s := by
    apply DifferentiableAt.mul
    · apply DifferentiableAt.mul
      · apply DifferentiableAt.mul
        · apply DifferentiableAt.cpow (differentiableAt_const _) differentiableAt_id (Or.inl (by simp; exact two_ne_zero))
        · apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.sub (differentiableAt_const 1)) (Or.inl (by simp; exact Real.pi_pos.ne'))
      · apply Complex.differentiableAt_Gamma.comp s (differentiableAt_const 1 |>.sub differentiableAt_id)
        intro m; simp [s]; linarith
    · apply (differentiableAt_riemannZeta (by simp [s]; linarith)).comp s (differentiableAt_const 1 |>.sub differentiableAt_id)
  have hGs : DifferentiableAt ℂ G s := Complex.differentiable_sin.differentiableAt.comp s (differentiableAt_id.mul_const _ |>.div_const _)
  have hGs_zero : G s = 0 := by
    simp [G, s]; rw [show ↑Real.pi * (-2 * ↑n) / 2 = ↑(-n : ℤ) * ↑Real.pi by ring]
    rw [Complex.sin_int_mul_pi]; simp
  have hGs_deriv : deriv G s = Complex.cos (Real.pi * s / 2) * (Real.pi / 2) := by
    apply HasDerivAt.deriv
    convert (Complex.hasDerivAt_sin (Real.pi * s / 2)).comp s (HasDerivAt.mul_const (HasDerivAt.id s) (Real.pi / 2)) using 1; ring
  rw [Filter.EventuallyEq.deriv_eq h_eq, deriv_mul hFs hGs, hGs_zero, hGs_deriv]
  simp only [mul_zero, add_zero]
  repeat (apply mul_ne_zero)
  · apply Complex.cpow_ne_zero; simp; exact two_ne_zero
  · apply Complex.cpow_ne_zero; simp; exact Real.pi_pos.ne'
  · exact Complex.Gamma_ne_zero _
  · apply riemannZeta_ne_zero_of_one_lt_re; simp [s]; linarith
  · rw [show (Real.pi : ℂ) * s / 2 = ↑(-n : ℤ) * Real.pi by ring, Complex.cos_int_mul_pi]
    apply zpow_ne_zero; simp
  · apply div_ne_zero (by norm_cast; exact Real.pi_pos.ne') two_ne_zero

end Millennium
