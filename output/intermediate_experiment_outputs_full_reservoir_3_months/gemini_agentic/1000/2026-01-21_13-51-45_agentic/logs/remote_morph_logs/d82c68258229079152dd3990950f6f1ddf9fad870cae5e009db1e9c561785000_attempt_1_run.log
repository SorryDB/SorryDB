/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 := by
  let s : ℂ := -2 * (n : ℂ)
  let F : ℂ → ℂ := fun z => (2 : ℂ) * (2 * ↑Real.pi : ℂ) ^ (z - 1) * (Complex.Gamma (1 - z) * riemannZeta (1 - z))
  let G : ℂ → ℂ := fun z => Complex.sin (↑Real.pi * z / 2)
  have h_eq : riemannZeta =ᶠ[nhds s] fun z => F z * G z := by
    have h_nhds : {z : ℂ | 1 < (1 - z).re} ∈ nhds s := by
      refine ContinuousAt.preimage_mem_nhds ?_ (Ioi_mem_nhds (by simp [s]; linarith))
      exact (continuousAt_const.sub Complex.continuous_re.continuousAt)
    filter_upwards [h_nhds] with z hz
    have hz_gam : ∀ m : ℕ, 1 - z ≠ -m := by
      intro m hm; apply_fun Complex.re at hm; simp at hm; linarith
    have hz_one : 1 - z ≠ 1 := by
      intro hm; apply_fun Complex.re at hm; simp at hm; linarith
    rw [show riemannZeta z = riemannZeta (1 - (1 - z)) by simp]
    rw [riemannZeta_one_sub hz_gam hz_one]
    simp only [F, G, mul_assoc]
    rw [show (↑Real.pi * (1 - z)) / 2 = ↑Real.pi / 2 - ↑Real.pi * z / 2 by ring]
    rw [Complex.cos_pi_div_two_sub, mul_comm (Complex.sin _)]
    ring
  have hFs : DifferentiableAt ℂ F s := by
    apply DifferentiableAt.mul
    · apply DifferentiableAt.mul (differentiableAt_const _)
      apply DifferentiableAt.cpow (differentiableAt_const _) (differentiableAt_id.sub (differentiableAt_const 1))
      left; simp; exact Real.pi_pos.ne'
    · apply DifferentiableAt.mul
      · apply DifferentiableAt.comp s
        · apply Complex.differentiableAt_Gamma; intro m; simp [s]; linarith
        · exact (differentiableAt_const 1).sub differentiableAt_id
      · apply DifferentiableAt.comp s
        · apply differentiableAt_riemannZeta; simp [s]; linarith
        · exact (differentiableAt_const 1).sub differentiableAt_id
  have hGs : DifferentiableAt ℂ G s := by
    apply Complex.differentiable_sin.differentiableAt.comp s
    exact (differentiableAt_id.mul_const _).div_const _
  have hGs_zero : G s = 0 := by
    simp [G, s]; rw [show ↑Real.pi * (-2 * ↑n) / 2 = ↑(-n : ℤ) * ↑Real.pi by ring]
    simp
