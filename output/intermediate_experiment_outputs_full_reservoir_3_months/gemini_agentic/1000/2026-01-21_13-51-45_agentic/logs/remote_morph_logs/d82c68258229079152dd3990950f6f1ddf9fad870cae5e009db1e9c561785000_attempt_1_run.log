    apply HasDerivAt.deriv
    convert (Complex.hasDerivAt_sin (↑Real.pi * s / 2)).comp s (HasDerivAt.mul_const (HasDerivAt.id s) (↑Real.pi / 2)) using 1
    ring
  rw [Filter.EventuallyEq.deriv_eq h_eq, deriv_mul hFs hGs, hGs_zero, hGs_deriv]
  simp only [mul_zero, add_zero]
  repeat (apply mul_ne_zero)
  · exact two_ne_zero
  · apply Complex.cpow_ne_zero; simp; exact Real.pi_pos.ne'
  · exact Complex.Gamma_ne_zero _
  · apply riemannZeta_ne_zero_of_one_lt_re; simp [s]; linarith
  · exact div_ne_zero (Complex.ofReal_ne_zero.mpr Real.pi_pos.ne') two_ne_zero
  · rw [show (↑Real.pi * s) / 2 = ↑(-n : ℤ) * ↑Real.pi by simp [s]; ring]
    simp; apply zpow_ne_zero; simp

end Millennium
