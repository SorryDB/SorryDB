    exact Complex.hasDerivAt_sin (↑Real.pi * s / 2) |>.comp s h1
  rw [Filter.EventuallyEq.deriv_eq h_eq]
  rw [deriv_mul hFs hGs]
  rw [hGs_zero, hGs_deriv]
  simp only [mul_zero, add_zero]
