      simp at h_re; linarith
    have h2 : 1 - z ≠ 1 := by
      intro hm
      have h_re : (1 - z).re = (1 : ℂ).re := congr_arg Complex.re hm
      simp at h_re; linarith
    rw [show riemannZeta z = riemannZeta (1 - (1 - z)) by simp]
    rw [riemannZeta_one_sub h1 h2]
    dsimp [F, G]
