    have hz_gam : ∀ m : ℕ, 1 - z ≠ -↑m := by
      intro m hm; apply_fun Complex.re at hm; simp at hm; linarith [hz]
    rw [show riemannZeta z = riemannZeta (1 - (1 - z)) by simp]
    rw [riemannZeta_one_sub hz_gam]
    simp only [mul_assoc]
    rw [show (↑Real.pi * (1 - z)) / 2 = ↑Real.pi / 2 - ↑Real.pi * z / 2 by ring]
