      rw [this]; exact (hasDerivAt_id s).mul_const _
    exact (Complex.hasDerivAt_sin _).comp s h
  rw [Filter.EventuallyEq.deriv_eq h_eq, deriv_mul hFs hGs, hGs_zero, hGs_deriv]
