theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  induction t generalizing label with
  | leaf x =>
    simp [addLabel, IsOrdered]
    split <;> (simp [IsOrdered, mem, *]; try split <;> simp [IsOrdered, mem, *])
    · exact le_of_lt ‹label < x›
    · exact le_of_not_lt ‹¬label < x›
  | node v l r ihl ihr =>
    simp [addLabel, IsOrdered] at *
    have mem_add (t : LabelledTree α) (x y : α) : y ∈ addLabel t x ↔ y = x ∨ y ∈ t := by
      induction t with
      | leaf v => simp [addLabel, mem]; split <;> (simp [*]; split <;> simp [mem, *])
      | node v l r ihl ihr => simp [addLabel, mem]; split <;> simp [ihl, ihr, mem, *] <;> tauto
    split
    · rename_i h_le
      simp [h, ihl h.2.2.1]
      constructor
      · intro x hx; rw [mem_add] at hx; cases hx with | inl h1 => subst h1; exact h_le | inr h1 => exact h.1 x h1
      · rw [mem_add]; tauto
    · rename_i h_nle
      simp [h, ihr h.2.2.2.1]
      constructor
      · intro x hx; rw [mem_add] at hx; cases hx with | inl h1 => subst h1; exact le_of_not_le h_nle | inr h1 => exact h.2.1 x h1
      · rw [mem_add]; tauto

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x => simp [fastCheckMem, mem]; exact Iff.symm (BEq.beq_iff_eq x label)
  | node v l r ihl ihr =>
    simp [fastCheckMem, mem, h]
    split
    · subst label; simp; exact h.2.2.2.2
    · split
      · rw [ihl h.2.2.1]
      · rw [ihr h.2.2.2.1]
        constructor
        · intro h1; right; exact h1
        · intro h1; cases h1
          · exfalso; have : label ≤ v := h.1 label ‹label ∈ l›
            have : v ≤ label := le_of_not_lt ‹¬label < v›
            have : v = label := le_antisymm ‹v ≤ label› ‹label ≤ v›
            have : (v == label) = true := BEq.beq_iff_eq v label |>.mpr this
            contradiction
          · assumption

def buildBST : List α → LabelledTree α
  | [] => leaf (Inhabited.default α)
  | x :: xs => xs.foldl addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    simp [buildBST]
    have ordered_foldl (xs : List α) (t : LabelledTree α) (h : IsOrdered t) :
      IsOrdered (xs.foldl addLabel t) := by
      induction xs generalizing t with
      | nil => exact h
      | cons y ys ih => simp; apply ih; exact ordered_addLabel _ _ h
    apply ordered_foldl; simp [IsOrdered]

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil =>
    simp [buildBST, fastCheckMem, LabelledTree.mem]
    sorry
  | cons x xs =>
    rw [fastCheckMem_correct _ _ (buildBST_ordered _), buildBST]
    have mem_add (t : LabelledTree α) (x y : α) : y ∈ addLabel t x ↔ y = x ∨ y ∈ t := by
      induction t with
      | leaf v => simp [addLabel, mem]; split <;> (simp [*]; split <;> simp [mem, *])
      | node v l r ihl ihr => simp [addLabel, mem]; split <;> simp [ihl, ihr, mem, *] <;> tauto
    have mem_foldl (xs : List α) (t : LabelledTree α) :
      label ∈ xs.foldl addLabel t ↔ label ∈ t ∨ label ∈ xs := by
      induction xs generalizing t with
      | nil => simp
      | cons y ys ih => simp [ih, mem_add]; tauto
    rw [mem_foldl]
    simp [LabelledTree.mem]
    tauto
