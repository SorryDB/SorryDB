          have : label = v := le_antisymm this (le_of_not_lt h_lt)
          simp [this, beq_iff_eq] at h_eq
        | inr hr => exact hr

def buildBST : List α → LabelledTree α
  | [] => leaf (Inhabited.default α)
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    simp [buildBST]
    generalize h_init : leaf x = t
    have h_t : IsOrdered t := by subst h_init; simp [IsOrdered]
    induction xs generalizing t with
    | nil => exact h_t
    | cons y ys ih =>
      simp
      apply ih
      exact ordered_addLabel _ _ h_t

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil =>
    simp [buildBST, fastCheckMem]
    sorry
  | cons x xs =>
    rw [fastCheckMem_correct _ _ (buildBST_ordered (x :: xs))]
    have mem_add {t' : LabelledTree α} {a b : α} : b ∈ t'.addLabel a ↔ b = a ∨ b ∈ t' := by
      induction t' generalizing a with
      | leaf x' => simp [LabelledTree.addLabel]; split_ifs <;> simp [*] <;> tauto
      | node v' l' r' ihl' ihr' => simp [LabelledTree.addLabel]; split_ifs <;> simp [ihl', ihr', *] <;> tauto
    have mem_foldl (l : List α) (t' : LabelledTree α) :
      label ∈ l.foldl LabelledTree.addLabel t' ↔ label ∈ t' ∨ label ∈ l := by
      induction l generalizing t' with
      | nil => simp
      | cons y ys ih => simp [ih, mem_add]; tauto
    simp [buildBST, mem_foldl]
    tauto
