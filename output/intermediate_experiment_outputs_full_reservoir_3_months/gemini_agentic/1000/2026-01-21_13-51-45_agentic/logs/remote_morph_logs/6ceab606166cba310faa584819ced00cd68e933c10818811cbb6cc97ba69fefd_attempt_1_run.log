        | inr h2 => exact h2

def buildBST : List α → LabelledTree α
  | [] => leaf (Inhabited.default α)
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    unfold buildBST
    have h_foldl (l : List α) (t' : LabelledTree α) (h' : IsOrdered t') :
      IsOrdered (l.foldl LabelledTree.addLabel t') := by
      induction l generalizing t' with
      | nil => exact h'
      | cons z zs ih => simp; apply ih; exact ordered_addLabel _ _ h'
    apply h_foldl; simp [IsOrdered]

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil =>
    simp [buildBST, fastCheckMem, LabelledTree.mem, Membership.mem, beq_iff_eq]
    sorry
  | cons x xs =>
    rw [fastCheckMem_correct _ _ (buildBST_ordered (x :: xs))]
    unfold buildBST
    have mem_add {t' : LabelledTree α} {a b : α} : b ∈ t'.addLabel a ↔ b = a ∨ b ∈ t' := by
      induction t' generalizing a with
      | leaf x' =>
        unfold LabelledTree.addLabel
        split_ifs <;> simp [LabelledTree.mem, Membership.mem, *] <;> tauto
      | node v' l' r' ihl' ihr' =>
        unfold LabelledTree.addLabel
        split_ifs <;> simp [ihl', ihr', LabelledTree.mem, Membership.mem, *] <;> tauto
    have mem_foldl (l : List α) (t' : LabelledTree α) :
      label ∈ l.foldl LabelledTree.addLabel t' ↔ label ∈ t' ∨ label ∈ l := by
      induction l generalizing t' with
      | nil => simp
      | cons y ys ih => simp [ih, mem_add]; tauto
    rw [mem_foldl]
    simp [Membership.mem, LabelledTree.mem]
    tauto
