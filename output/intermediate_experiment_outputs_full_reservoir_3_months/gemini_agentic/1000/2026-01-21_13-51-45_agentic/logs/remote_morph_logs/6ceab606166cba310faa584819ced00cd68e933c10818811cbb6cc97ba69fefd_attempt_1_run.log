theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  induction t generalizing label with
  | leaf x =>
    simp [addLabel, IsOrdered, LabelledTree.mem]
    split_ifs <;> simp [IsOrdered, LabelledTree.mem, *]
    · exact le_of_lt ‹label < x›
    · exact le_of_not_lt ‹¬label < x›
  | node v l r ihl ihr =>
    simp [addLabel, IsOrdered] at h ⊢
    have mem_add (t : LabelledTree α) (a b : α) : b ∈ t.addLabel a ↔ b = a ∨ b ∈ t := by
      induction t generalizing a with
      | leaf x => simp [addLabel, LabelledTree.mem]; split_ifs <;> simp [LabelledTree.mem, *] <;> tauto
      | node v l r ihl ihr => simp [addLabel, LabelledTree.mem]; split_ifs <;> simp [ihl, ihr, LabelledTree.mem, *] <;> tauto
    split_ifs with h_le
    · simp [h, ihl h.2.2.1]
