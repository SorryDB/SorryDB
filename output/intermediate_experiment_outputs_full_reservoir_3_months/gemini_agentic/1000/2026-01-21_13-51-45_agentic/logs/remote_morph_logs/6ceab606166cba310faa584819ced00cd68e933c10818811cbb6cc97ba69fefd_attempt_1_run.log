      · rw [mem_add]; tauto

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, LabelledTree.mem]
    exact (BEq.beq_iff_eq x label).trans eq_comm
  | node v l r ihl ihr =>
    simp [fastCheckMem, LabelledTree.mem, h]
    split_ifs with h_beq
    · have : v = label := (BEq.beq_iff_eq v label).mp h_beq
      subst label; simp; exact h.2.2.2.2
    · have h_nbq : v ≠ label := (BEq.beq_iff_eq v label).not.mp h_beq
      split_ifs with h_lt
      · rw [ihl h.2.2.1]
      · rw [ihr h.2.2.2.1]
