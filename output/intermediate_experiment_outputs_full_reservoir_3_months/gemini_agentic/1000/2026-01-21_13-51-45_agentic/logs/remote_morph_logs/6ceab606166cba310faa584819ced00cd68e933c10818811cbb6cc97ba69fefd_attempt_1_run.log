      · rw [ihr h.2.2.2.1]
        constructor
        · intro hr; right; exact hr
        · intro h_mem; cases h_mem with
          | inl hl => have : label ≤ v := h.1 _ hl; have : label = v ∨ label < v := le_iff_lt_or_eq.mp this; tauto
          | inr hr => exact hr

def buildBST : List α → LabelledTree α
  | [] => Inhabited.default (LabelledTree α)
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered, Inhabited.default]
