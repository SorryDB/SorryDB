        · intro h1; cases h1
          · exfalso; exact h_nbq (le_antisymm (h.1 label ‹label ∈ l›) (le_of_not_lt h_lt)).symm
          · assumption

def buildBST : List α → LabelledTree α
  | [] => leaf (Inhabited.default α)
  | x :: xs => xs.foldl addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    simp [buildBST]
    have ordered_foldl (xs : List α) (t : LabelledTree α) (h : IsOrdered t) :
      IsOrdered (xs.foldl addLabel t) := by
      induction xs generalizing t with
      | nil => exact h
      | cons y ys ih => simp; apply ih; exact ordered_addLabel _ _ h
    apply ordered_foldl; simp [IsOrdered]

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil =>
    simp [buildBST, fastCheckMem, LabelledTree.mem]
