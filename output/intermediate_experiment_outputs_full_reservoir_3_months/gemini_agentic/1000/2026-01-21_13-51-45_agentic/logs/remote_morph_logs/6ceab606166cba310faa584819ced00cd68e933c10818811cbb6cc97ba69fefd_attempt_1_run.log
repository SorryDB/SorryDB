      induction t' generalizing a with
      | leaf x' => unfold LabelledTree.addLabel; simp [LabelledTree.mem]; split_ifs <;> simp [LabelledTree.mem, *]
      | node v' l' r' ihl' ihr' => unfold LabelledTree.addLabel; simp [LabelledTree.mem]; split_ifs <;> simp [ihl', ihr', LabelledTree.mem, *] <;> tauto
    split_ifs with h_le
    · simp [h, ihl h.2.2.1]
      constructor
      · intro y hy; rw [mem_add] at hy; cases hy with | inl h1 => subst h1; exact h_le | inr h1 => exact h.1 y h1
