  | node v' l' r' ihl' ihr' => simp [LabelledTree.addLabel, LabelledTree.mem]; split_ifs <;> simp [ihl', ihr', LabelledTree.mem, *] <;> tauto

theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  induction t generalizing label with
  | leaf x =>
    simp [LabelledTree.addLabel, IsOrdered, LabelledTree.mem]
    split_ifs <;> simp [IsOrdered, LabelledTree.mem, *]
    · exact le_of_lt ‹label < x›
    · exact le_of_not_lt ‹¬label < x›
  | node v l r ihl ihr =>
    simp [IsOrdered] at h
    simp [LabelledTree.addLabel, IsOrdered]
