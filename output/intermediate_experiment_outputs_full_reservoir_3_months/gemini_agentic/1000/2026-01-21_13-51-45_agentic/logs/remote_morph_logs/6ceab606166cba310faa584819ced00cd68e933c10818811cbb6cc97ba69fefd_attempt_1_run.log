theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, beq_iff_eq]
  | node v l r ihl ihr =>
    simp [IsOrdered] at h
    simp [fastCheckMem]
    split_ifs with h_eq h_lt
    · simp [beq_iff_eq.1 h_eq, h.2.2.2.2]
    · rw [ihl h.2.2.1]
      constructor
      · intro hl; left; exact hl
      · intro h_mem; cases h_mem with
        | inl hl => exact hl
        | inr hr =>
          have : v ≤ label := h.2.1 _ hr
          have : ¬ (label < v) := not_lt_of_ge this
          contradiction
    · rw [ihr h.2.2.2.1]
      constructor
      · intro hr; right; exact hr
