def buildBST : List α → LabelledTree α
  | [] => leaf (Inhabited.default α)
  | x :: xs => xs.foldl addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    induction xs generalizing x with
    | nil => simp [buildBST, IsOrdered]
    | cons y ys ih =>
      simp [buildBST] at *
      exact ordered_addLabel _ _ (ih x)

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil =>
    simp [buildBST, fastCheckMem]
    intro h
    have : IsOrdered (buildBST []) := buildBST_ordered []
    rw [fastCheckMem_correct label (buildBST []) this] at h
    simp [LabelledTree.mem, buildBST] at h
    sorry
  | cons x xs =>
    rw [fastCheckMem_correct _ _ (buildBST_ordered _)]
    induction xs generalizing x with
    | nil =>
      simp [buildBST, LabelledTree.mem]
    | cons y ys ih =>
      simp [buildBST] at *
      rw [ordered_addLabel_mem]
      · simp [ih]
      · exact buildBST_ordered (x :: ys)
where
  ordered_addLabel_mem {t : LabelledTree α} {v : α} (h : IsOrdered t) :
      x ∈ addLabel t v ↔ x = v ∨ x ∈ t := by
    induction t with
    | leaf x' =>
      simp [addLabel]
      split <;> simp [*]
      split <;> simp [LabelledTree.mem, *]
    | node v' l r ihl ihr =>
      simp [addLabel, LabelledTree.mem]
      split <;> simp [LabelledTree.mem, *]
      · rw [ihl (by simp [IsOrdered] at h; exact h.2.2.1)]
        simp [LabelledTree.mem, or_assoc, @or_comm (x=v)]
      · rw [ihr (by simp [IsOrdered] at h; exact h.2.2.2.1)]
        simp [LabelledTree.mem, or_assoc]
```
