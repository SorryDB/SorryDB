/--Edge counting function.-/
def edgeCount {u v : V} (p : G.LoopWalk u v) (e : Sym2 V) : ℕ := countP (· = e) p.edges

lemma abs_w_i_eq_k {u v : V} (p : G.LoopWalk u v) : ∑(e : edgeSet p),
    edgeCount p e = p.length := by
  have hl_darts : p.darts.length = p.length := by
    induction p with
    | nil => rfl
    | cons h q ih => simp [darts, length, ih]
    | loop q ih => simp [darts, length, ih]
  have hl : p.edges.length = p.length := by
    simp [edges, List.length_map, hl_darts]
  rw [← hl, edgeSet, Finset.sum_coe_sort]
  have h_count : ∀ e, edgeCount p e = p.edges.count e := by
    intro e
    simp [edgeCount, List.count_eq_countP, eq_comm]
  simp_rw [h_count]
  exact List.sum_toFinset_count_eq_length p.edges
```
