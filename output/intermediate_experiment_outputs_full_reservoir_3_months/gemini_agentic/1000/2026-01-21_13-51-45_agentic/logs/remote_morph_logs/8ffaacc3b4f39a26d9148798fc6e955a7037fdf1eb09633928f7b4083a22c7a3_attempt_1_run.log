    | zero =>
      ext i
      simp [hist_zero, hη 0 le_rfl]
    | succ m ih =>
      ext i
      rw [hist_add_one, hist_add_one]
      have h_ih : hist alg (η, ξ) m = hist alg (η', ξ) m := ih (fun j hj ↦ hη j (hj.trans (Nat.le_succ m)))
