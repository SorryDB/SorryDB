lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let f : probSpace α R → (Iic n → I) × (ℕ → α → R) := fun ω ↦ (fun i ↦ ω.1 i.1, ω.2)
  have h_indep : IndepFun (fun ω ↦ ω.1 (n + 1)) f (arrayMeasure ν) := by
    refine indepFun_iff_measure_inter_preimage_eq_prod.mpr fun s t hs ht ↦ ?_
    rw [arrayMeasure, Measure.prod_apply (hs.inter ht), Measure.prod_apply hs, Measure.prod_apply ht]
    have h_fst := (iIndepFun_infinitePi (fun _ : ℕ ↦ (volume : Measure I))).indepFun_prod_combined
      (fun i ↦ i = n + 1) (fun i ↦ i ≤ n) (by omega)
    have : (fun ω : (ℕ → I) × (ℕ → α → R) ↦ ω.1 (n + 1)) = (fun ω₁ ↦ ω₁ (n + 1)) ∘ Prod.fst := rfl
    rw [this, Measure.map_preimage_prod measurable_fst hs, this, Measure.map_preimage_prod measurable_fst hs]
    have : f = (fun (p : (Iic n → I) × (ℕ → α → R)) ↦ p) ∘ f := rfl
    rw [this, Measure.map_preimage_prod (measurable_pi_iff.mpr fun i ↦ by fun_prop |>.prodMk measurable_snd) ht]
    simp only [Measure.prod_prod, ← indepFun_iff_measure_inter_preimage_eq_prod]
    rw [indepFun_iff_measure_inter_preimage_eq_prod.mp h_fst]
    simp [Measure.prod_apply ht]
  have h_map : hist alg · n = (fun p : (Iic n → I) × (ℕ → α → R) ↦
      hist alg (fun i ↦ if hi : i ≤ n then p.1 ⟨i, hi⟩ else 0, p.2) n) ∘ f := by
    ext ω
    simp only [Function.comp_apply, f]
    congr
    ext i
    simp only [hist_eq alg ω n, dite_eq_ite]
    split_ifs with hi
    · simp only [hi, ↓reduceIte]; congr; ext; simp
    · simp at hi
  rw [h_map]
  exact h_indep.comp measurable_id (by fun_prop)
```
