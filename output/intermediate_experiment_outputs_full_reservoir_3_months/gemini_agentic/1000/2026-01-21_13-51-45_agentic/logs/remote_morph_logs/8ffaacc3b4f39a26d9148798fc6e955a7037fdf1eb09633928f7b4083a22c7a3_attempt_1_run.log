  have h_both : ∀ η, (Bandit.streamMeasure ν) {ξ | (η, ξ) ∈ f ⁻¹' s ∩ g ⁻¹' t} = if f1 η ∈ s then H η else 0 := fun η ↦ by
    dsimp [f, g, f1, H]; by_cases h : η (n + 1) ∈ s <;> simp [h]
