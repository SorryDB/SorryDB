      by_cases hin : (i : ℕ) ≤ m
      · simp [hin]
      · have : (i : ℕ) = m + 1 := by
          have hi_le : (i : ℕ) ≤ m + 1 := i.2
          omega
        simp [hin, this, hη (m + 1) le_rfl]
  set f := fun ω : probSpace α R ↦ ω.1 (n + 1)
  set g := fun ω : probSpace α R ↦ hist alg ω n
  have hf : Measurable f := (measurable_pi_apply (n + 1)).comp measurable_fst
  have hg : Measurable g := measurable_hist alg n
  refine (ProbabilityTheory.indepFun_iff_measure_inter_preimage_eq_mul hf hg).mpr (fun s t hs ht ↦ ?_)
  rw [arrayMeasure, Measure.prod_apply (hf hs), Measure.prod_apply (hg ht),
    Measure.prod_apply ((hf hs).inter (hg ht))]
  set f1 := fun η : ℕ → I ↦ η (n + 1)
  set H := fun η ↦ (Bandit.streamMeasure ν) {ξ | hist alg (η, ξ) n ∈ t}
  have h_f1s : ∀ η, (Bandit.streamMeasure ν) {ξ | (η, ξ) ∈ f ⁻¹' s} = if f1 η ∈ s then 1 else 0 := fun η ↦ by
    dsimp [f, f1]; by_cases h : η (n + 1) ∈ s <;> simp [h]
  have h_hht : ∀ η, (Bandit.streamMeasure ν) {ξ | (η, ξ) ∈ g ⁻¹' t} = H η := fun _ ↦ rfl
  have h_both : ∀ η, (Bandit.streamMeasure ν) {ξ | (η, ξ) ∈ f ⁻¹' s ∩ g ⁻¹' t} = if f1 η ∈ s then H η else 0 := fun η ↦ by
    dsimp [f, g, f1, H]; by_cases h : η (n + 1) ∈ s <;> simp [h]
  simp_rw [h_f1s, h_hht, h_both]
  have hH : Measurable H := (hg ht).measurable_measure_prod_mk_left
  have h_indep : IndepFun f1 H (Measure.infinitePi fun _ ↦ volume) := by
    set G := fun η : ℕ → I ↦ fun i : Iic n ↦ η i.1
    have h_H_eq : H = (fun ηsub ↦ (Bandit.streamMeasure ν) {ξ | hist alg (fun i ↦ if h : i ≤ n then ηsub ⟨i, h⟩ else 0, ξ) n ∈ t}) ∘ G := by
      ext η; dsimp [H, G]; congr 1; ext ξ; apply h_depend; intro i hi; simp [hi]
    rw [h_H_eq]
    apply IndepFun.comp _ (iIndepFun_infinitePi _).indepFun_set measurable_id
    · exact disjoint_singleton_left.mpr (Nat.not_succ_le_self n)
    · exact measurable_pi_apply (n + 1)
    · exact measurable_pi_iff.mpr fun i ↦ measurable_pi_apply i.1
  have : (fun η ↦ if f1 η ∈ s then H η else 0) = (fun η ↦ s.indicator (fun _ ↦ (1 : ENNReal)) (f1 η) * H η) := by
    ext η; by_cases h : f1 η ∈ s <;> simp [h, Set.indicator_apply]
  rw [this, h_indep.lintegral_mul (measurable_indicator measurable_const hs |>.comp (measurable_pi_apply (n + 1))) hH]
  simp_rw [lintegral_indicator hs, one_mul]
  rfl
