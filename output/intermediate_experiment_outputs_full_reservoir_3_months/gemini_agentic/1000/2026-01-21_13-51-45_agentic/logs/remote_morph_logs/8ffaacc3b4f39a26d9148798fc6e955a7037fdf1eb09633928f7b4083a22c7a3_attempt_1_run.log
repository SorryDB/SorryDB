    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let f : probSpace α R → (Iic n → I) × (ℕ → α → R) := fun ω ↦ (fun i ↦ ω.1 i.1, ω.2)
  have hf : Measurable f := (measurable_pi_iff.mpr fun i ↦ (measurable_pi_apply i.1).comp measurable_fst).prodMk measurable_snd
  have h_depend : ∀ η η' ξ, (∀ i ≤ n, η i = η' i) → hist alg (η, ξ) n = hist alg (η', ξ) n := by
    intro η η' ξ h; induction n with
    | zero => simp [hist_zero]; congr; exact h 0 (le_refl 0)
    | succ n ih =>
      rw [hist_add_one, hist_add_one]
      congr 2
      · exact ih fun i hi ↦ h i (hi.trans n.le_succ)
      · congr 1
        · exact ih fun i hi ↦ h i (hi.trans n.le_succ)
        · exact h (n + 1) le_rfl
  let φ : (Iic n → I) × (ℕ → α → R) → (Iic n → α × R) :=
    fun p ↦ hist alg (fun i ↦ if hi : i ≤ n then p.1 ⟨i, hi⟩ else 0, p.2) n
  have : (fun ω ↦ hist alg ω n) = φ ∘ f := by
    ext ω; exact h_depend ω.1 (fun i ↦ if hi : i ≤ n then ω.1 i else 0) ω.2 (fun i hi ↦ by simp [hi])
  rw [this]
  refine IndepFun.comp ?_ (measurable_hist alg n |>.comp
    ((measurable_pi_iff.mpr fun i ↦ split_ifs with h <;>
      [exact (measurable_pi_apply ⟨i, h⟩).comp measurable_fst; exact measurable_const]).prodMk measurable_snd)) hf
  rw [arrayMeasure, indepFun_iff_map_prod_eq_map]
  have h := indepFun_proj_infinitePi (Disjoint.singleton_left.mpr (Nat.not_succ_le_self n)) (μ := fun _ ↦ volume)
  rw [indepFun_iff_map_prod_eq_map] at h
  simp [h, f, Measure.map_prod_map, measurable_fst, measurable_snd, Measure.prod_assoc, Measure.map_map, Function.comp_def]

end ArrayModel
