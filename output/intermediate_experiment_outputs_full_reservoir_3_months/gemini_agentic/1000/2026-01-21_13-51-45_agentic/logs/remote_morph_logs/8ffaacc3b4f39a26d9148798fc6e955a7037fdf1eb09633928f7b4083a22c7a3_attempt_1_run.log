    have : H = (fun ηsub ↦ (Bandit.streamMeasure ν) {ξ | hist alg (fun i ↦ if h : i ≤ n then ηsub ⟨i, h⟩ else 0, ξ) n ∈ t}) ∘ G := by
      ext η; dsimp [H, G]; congr 1; ext ξ; apply h_depend; intro i hi; simp [hi]
