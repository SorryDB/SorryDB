  set H := fun η ↦ (Bandit.streamMeasure ν) {ξ | hist alg (η, ξ) n ∈ t}
  have hf1 : Measurable f1 := measurable_pi_apply (n + 1)
  have hH : Measurable H := (hg ht).measurable_measure_prod_mk_left
  have h_f1s : ∀ η, (Bandit.streamMeasure ν) {ξ | (η, ξ) ∈ f ⁻¹' s} = if f1 η ∈ s then 1 else 0 := fun η ↦ by
