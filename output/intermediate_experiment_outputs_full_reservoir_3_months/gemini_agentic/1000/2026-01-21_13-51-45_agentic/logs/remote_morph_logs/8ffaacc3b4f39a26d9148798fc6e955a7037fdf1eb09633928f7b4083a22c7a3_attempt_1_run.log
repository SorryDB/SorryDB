lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let f : probSpace α R → (Iic n → I) × (ℕ → α → R) := fun ω ↦ (fun i ↦ ω.1 i.1, ω.2)
  have h_hist : hist alg · n = (fun p : (Iic n → I) × (ℕ → α → R) ↦
      hist alg (fun i ↦ if hi : i ≤ n then p.1 ⟨i, hi⟩ else 0, p.2) n) ∘ f := by
    ext ω
    simp only [Function.comp_apply, f, hist_eq alg ω n]
    congr; ext i; have hi : i.1 ≤ n := i.2; simp [hi]
  rw [h_hist]
  refine IndepFun.comp ?_ (by fun_prop) (by fun_prop)
  rw [arrayMeasure, indepFun_iff_map_prod_eq_map]
  have h1 := indepFun_proj_infinitePi (Disjoint.singleton_left.mpr (by simp [Iic])) (μ := fun _ ↦ volume)
  have h2 := indepFun_fst_prod h1 (μ' := Bandit.streamMeasure ν)
  have h3 := (indepFun_fst_snd ν).comp (by fun_prop) measurable_id
  rw [← Measure.prod_assoc, ← indepFun_iff_map_prod_eq_map.mp h2, ← indepFun_iff_map_prod_eq_map.mp h3]
  simp only [Measure.map_map, Function.comp_def, arrayMeasure, Measure.fst_prod, Measure.snd_prod]
  rw [Measure.map_map (by fun_prop) (by fun_prop)]
  rfl
