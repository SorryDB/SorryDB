        mem_biUnion.2 ⟨f, hf, mem_inter.2 ⟨hx, mem_smul_finset.2 ⟨s, hs, hxf⟩⟩⟩)
    obtain ⟨a, haF, ha⟩ : ∃ a ∈ F, (#A : ℝ) / #F ≤ #(A ∩ MulOpposite.op a • S) := by
      by_contra! h
      have h_sum : (∑ f ∈ F, (#(A ∩ MulOpposite.op f • S) : ℝ)) < #A := by
        calc (∑ f ∈ F, (#(A ∩ MulOpposite.op f • S) : ℝ))
          _ < ∑ f ∈ F, (#A : ℝ) / #F := sum_lt_sum (fun f hf ↦ h f hf) hF₀
          _ = #A := by rw [sum_const, nsmul_eq_mul, mul_div_cancel₀ _ (mod_cast hF₀.card_pos.ne')]
      exact (mod_cast hAF.trans card_biUnion_le).not_lt h_sum
    refine ⟨a, hFA haF, ?_⟩
    calc
      (#A : ℝ) / (2 * K) ≤ #A / #F :=
        div_le_div_of_nonneg_left (mod_cast hA₀.card_pos).le (mod_cast hF₀.card_pos) hFcard
      _ ≤ #(A ∩ MulOpposite.op a • S) := ha
      _ ≤ #(A ∩ MulOpposite.op a • S ^ 2) :=
        mod_cast card_le_card (inter_subset_inter_right (smul_subset_smul_left (subset_mul_right S hS₁)))
