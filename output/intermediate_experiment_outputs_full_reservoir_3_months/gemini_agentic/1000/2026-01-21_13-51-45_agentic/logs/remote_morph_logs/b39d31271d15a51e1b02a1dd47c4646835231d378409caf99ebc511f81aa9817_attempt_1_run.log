  have hK : 1 ≤ K := one_le_of_le_mul_right₀ (by positivity) <|
    calc (#A : ℝ) ≤ #(A ^ 2) := mod_cast card_le_card_pow two_ne_zero
      _ ≤ K * #A := hA
