          | [] => cases h_zip
          | bt_h :: bt_t =>
            simp at h_zip; cases h_zip with
            | head h_eq => cases h_eq; apply List.mem_cons_self
            | tail h_zip => apply List.mem_cons_of_mem; exact ih_inner h_zip
      have hL : ∀ s ∈ L, s.length < bh.length := by
        intro s hs; simp [bh]; induction L with
        | nil => cases hs
        | cons head tail ihL =>
