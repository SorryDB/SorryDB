  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  induction a with
  | nil => exact ⟨[], rfl, λ _ _ h => by cases h, List.nodup_nil⟩
  | cons h t ih =>
    let ⟨bt, hlen, hcon, hnodup⟩ := ih
    let L := ε.toList.map (fun p => p.1.2) ++ bt
    let bh := String.mk (List.replicate (L.foldr (λ s n => s.length + n + 1) 0 + 1) 'A')
    exists bh :: bt; simp [hlen, hnodup]; constructor
    · intro a' b' h_zip; simp at h_zip; cases h_zip with
      | head h_eq =>
        cases h_eq; intro hc; have : bh ∈ L := by
          rw [Batteries.AssocList.contains_eq_true_iff_exists_find?] at hc
          let ⟨v, hv⟩ := hc; simp [L]; left; apply List.mem_map.mpr
          exists ((a', bh), v); simp [Batteries.AssocList.find?_eq_some_iff_mem.1 hv]
        have hL : ∀ s ∈ L, s.length < bh.length := by
          intro s hs; simp [bh]; induction L with
          | nil => cases hs
          | cons head tail ihL =>
            simp at hs; cases hs with
            | head h_eq => rw [h_eq]; apply Nat.lt_succ_of_le; apply Nat.le_add_right
            | tail hs => apply Nat.lt_trans (ihL hs); apply Nat.lt_succ_of_le; apply Nat.le_add_left
        exact Nat.lt_irrefl _ (hL _ this)
      | tail h_zip => exact hcon a' b' h_zip
    · intro h_zip; have : bh ∈ L := by
        simp [L]; right; clear hcon hnodup hlen; induction t generalizing bt with
        | nil => cases h_zip
        | cons t_h t_t ih_inner =>
