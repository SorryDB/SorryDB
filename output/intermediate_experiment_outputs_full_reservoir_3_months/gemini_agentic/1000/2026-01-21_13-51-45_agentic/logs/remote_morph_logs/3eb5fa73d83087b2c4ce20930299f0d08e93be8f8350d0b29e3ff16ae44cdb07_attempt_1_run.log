namespace FinEnv

@[simp]
def toEnv {Ident Typ} [DecidableEq Typ] (ε : FinEnv Ident Typ) : Env Ident Typ := ε.find?

theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  induction a with
  | nil => exact ⟨[], by simp⟩
  | cons h t ih =>
    let ⟨bt, hlen, hcon, hnodup⟩ := ih
    let L := ε.toList.map (fun p => p.1.2) ++ bt
    let bh := String.mk (List.replicate (L.foldr (λ s n => s.length + n + 1) 0) 'A')
    exists bh :: bt; simp [hlen, hcon, hnodup]
    have hL : ∀ s ∈ L, s.length < bh.length := by
      intro s hs; induction L with | nil => cases hs | cons head tail ihL =>
      simp [bh] at *; cases hs with
      | head => apply Nat.lt_of_le_of_lt (Nat.le_add_right _ _) (Nat.lt_succ_self _)
      | tail hs => apply Nat.lt_trans (ihL hs); apply Nat.lt_of_le_of_lt (Nat.le_add_left _ _) (Nat.lt_succ_self _)
    constructor
    · intro hc; apply Nat.lt_irrefl bh.length; apply hL bh; simp [L]; left
      rw [Batteries.AssocList.contains_eq_true_iff_exists_find?] at hc
      match hc with | ⟨v, hv⟩ =>
      apply List.mem_map.mpr; exists ((h, bh), v); simp [Batteries.AssocList.find?_eq_some_iff_mem.1 hv]
    · intro hin; apply Nat.lt_irrefl bh.length; apply hL bh; simp [L]; right
      induction t generalizing bt with
      | nil => cases hin
      | cons t_h t_t ih_inner =>
        cases bt with
        | nil => cases hlen
        | cons bt_h bt_t =>
          cases hin with
          | head h_eq => injection h_eq with _ h_eq; rw [h_eq]; apply List.mem_cons_self
          | tail hin => apply List.mem_cons_of_mem; apply ih_inner (by injection hlen; assumption); assumption

end FinEnv
