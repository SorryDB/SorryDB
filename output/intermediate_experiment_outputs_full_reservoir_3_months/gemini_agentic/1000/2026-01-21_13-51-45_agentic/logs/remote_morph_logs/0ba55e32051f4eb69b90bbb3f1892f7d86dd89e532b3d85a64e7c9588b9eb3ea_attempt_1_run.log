/-- The **strong Sperner lemma**

A Sperner triangulation contains an odd number of panchromatic simplices. -/
theorem strong_sperner {S : SimplicialComplex ℝ (Fin (m + 1) → ℝ)} {c : E → Fin (m + 1)}
    (hSspace : S.space = stdSimplex ℝ (Fin (m + 1))) (hSfin : S.faces.Finite)
    (hc : IsSpernerColoring S c) :
    Odd {s ∈ S.faces | IsPanchromatic c s}.ncard := by
  induction m with
  | zero =>
    have : ∀ s : Finset (Fin 1 → ℝ), s = {![1]} ∧ s.Nonempty ↔ s = {![1]} := by simp +contextual
    simp [IsPanchromatic, strong_sperner_zero_aux hSspace, this]
  | succ m ih => by
    classical
    let colors : Finset (Fin (m + 2)) := Finset.univ.erase (Fin.last (m + 1))
    let X := hSfin.toFinset.filter (fun s ↦ s.card = m + 2)
    let Y := hSfin.toFinset.filter (fun s ↦ s.card = m + 1 ∧ colors ⊆ s.image c)
    let B := Y.filter (fun τ ↦ ∀ x ∈ τ, x (Fin.last (m + 1)) = 0)
    have hX : ∀ s ∈ X, (Y.filter (fun τ ↦ τ ⊆ s)).card % 2 = if IsPanchromatic c s then 1 else 0 := by sorry
    have hY : ∀ τ ∈ Y, (X.filter (fun s ↦ τ ⊆ s)).card % 2 = if τ ∈ B then 1 else 0 := by sorry
    have h_double : (X.sum (fun s ↦ (Y.filter (fun τ ↦ τ ⊆ s)).card)) % 2 = (Y.sum (fun τ ↦ (X.filter (fun s ↦ τ ⊆ s)).card)) % 2 := by
      rw [Finset.sum_card_filter_rel (fun s τ ↦ τ ⊆ s) X Y]
    have h_panch : {s | s ∈ S.faces ∧ IsPanchromatic c s}.ncard = (X.filter (fun s ↦ IsPanchromatic c s)).card := by sorry
    have hB : Odd B.card := by sorry
    rw [h_panch, Nat.odd_iff, ← Finset.sum_mod, ← h_double, Finset.sum_mod]
    simp_rw [hX, hY]
    simp only [apply_ite (fun x ↦ x % 2), Nat.one_mod_two, Nat.zero_mod_two, Finset.sum_boole, ← Nat.odd_iff, hB]
