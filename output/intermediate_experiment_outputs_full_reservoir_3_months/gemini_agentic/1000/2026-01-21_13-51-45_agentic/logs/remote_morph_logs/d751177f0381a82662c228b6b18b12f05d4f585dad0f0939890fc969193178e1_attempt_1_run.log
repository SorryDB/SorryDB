    (hX : Locally (fun X ↦ ∀ ω, ∀ x, ∃ l, Tendsto (X · ω) (𝓝[<] x) (𝓝 l)) 𝓕 X P) :
    ∀ᵐ ω ∂P, ∀ x, ∃ l, Tendsto (X · ω) (𝓝[<] x) (𝓝 l) := by
  filter_upwards [hX.IsLocalizingSequence.tendsto_top] with ω hω x
  obtain ⟨n, hn⟩ := (WithTop.tendsto_atTop_nhds_top_iff.1 hω x).exists
  obtain ⟨l, hl⟩ := hX.stoppedProcess n ω x
  refine ⟨l, hl.congr' ?_⟩
  filter_upwards [self_mem_nhdsWithin (s := Set.Iio x)] with i hi
  have hbot : ⊥ < hX.localSeq n ω := (WithTop.coe_le_coe.2 bot_le).trans_lt hn
  rw [stoppedProcess, min_eq_left (WithTop.coe_le_coe.2 hi.le |>.trans hn.le),
    Set.indicator_of_mem hbot]
```
