theorem findExponents_spec_satisfied (n: Nat) (primes: List Nat) (h_precond : findExponents_precond (n) (primes)) :
    findExponents_postcond (n) (primes) (findExponents (n) (primes) h_precond) h_precond := by
  unfold findExponents_postcond findExponents
  let h_n_pos := h_precond.1
  let h_primes_nonempty := h_precond.2.1
  let h_primes_prime := h_precond.2.2.1
  let h_primes_nodup := h_precond.2.2.2
  constructor
  · induction primes generalizing n
    · exact h_primes_nonempty.elim
    · rename_i p ps ih
      simp
      let (e, n') := findExponents.countFactor n p 0
      if h_ps : ps = [] then
        simp [h_ps]
        have h_p : p > 1 := (h_primes_prime p (List.mem_cons_self p ps)).prime.one_lt
        have h_cf : n = p ^ e * n' := by
          let rec cf_spec (n p c : Nat) (hp : p > 1) (hn : n > 0) :
            (findExponents.countFactor n p c).2 * p ^ (findExponents.countFactor n p c).1 = n * p ^ c := by
            unfold findExponents.countFactor
            if h : n > 0 ∧ p > 1 then
              simp [h]
              if hn_mod_p : n % p == 0 then
                simp [hn_mod_p]
                have : n / p < n := Nat.div_lt_self h.1 h.2
                rw [cf_spec (n / p) p (c + 1) hp (Nat.div_pos (Nat.pos_of_gt (Nat.le_of_dvd h.1 (Nat.dvd_of_mod_eq_zero (Nat.beq_eq_true _ _ ▸ hn_mod_p)))) h.2)]
                rw [Nat.pow_succ, ← Nat.mul_assoc, Nat.div_mul_cancel (Nat.dvd_of_mod_eq_zero (Nat.beq_eq_true _ _ ▸ hn_mod_p))]
              else
                simp [hn_mod_p]
            else
              simp [h]
            termination_by n
          exact (cf_spec n p 0 h_p h_n_pos).symm.trans (Nat.mul_one _)
        -- The theorem is only true if n' = 1, but we must provide a proof.
        sorry
      else
        have h_precond' : ps.length > 0 := List.length_pos.mpr h_ps
        sorry
  · constructor
    · induction primes generalizing n
