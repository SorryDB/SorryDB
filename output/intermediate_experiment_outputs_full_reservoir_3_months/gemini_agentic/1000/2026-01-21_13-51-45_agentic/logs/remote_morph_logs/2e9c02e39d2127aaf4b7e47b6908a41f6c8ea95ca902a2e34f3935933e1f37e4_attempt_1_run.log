theorem findExponents_spec_satisfied (n: Nat) (primes: List Nat) (h_precond : findExponents_precond (n) (primes)) :
    findExponents_postcond (n) (primes) (findExponents (n) (primes) h_precond) h_precond := by
  -- !benchmark @start proof
  unfold findExponents_postcond findExponents
  let f := fun acc (pair : Nat × Nat) => acc * pair.1 ^ pair.2
  have h_foldl_mul : ∀ l init, l.foldl f init = init * l.foldl f 1 := by
    intro l init; induction l generalizing init with | nil => simp | cons x xs ih => simp [f, ih (init * x.1 ^ x.2), ih (x.1 ^ x.2), Nat.mul_assoc]
  have h_countFactor : ∀ n p c, n > 0 → p > 1 → let res := findExponents.countFactor n p c; n * p^c = res.2 * p^res.1 ∧ res.2 > 0 := by
    intro n p c hn hp; induction n, p, c using findExponents.countFactor.induct with
    | case1 => contradiction
    | case2 n p c h_cond ih =>
      rw [findExponents.countFactor]; simp [h_cond]
      if h_mod : n % p == 0 then
        simp [h_mod]; have h_mod_eq := beq_iff_eq.mp h_mod
        have h_div_pos : n / p > 0 := Nat.div_pos (Nat.le_of_dvd h_cond.1 (Nat.dvd_of_mod_eq_zero h_mod_eq)) (Nat.pos_of_gt h_cond.2)
        specialize ih h_mod h_div_pos h_cond.2
        match h_res_cf : findExponents.countFactor (n / p) p (c + 1) with | (c', n') =>
          simp [h_res_cf] at ih ⊢; constructor
          · rw [Nat.mul_assoc, ← Nat.pow_succ, Nat.div_mul_cancel (Nat.dvd_of_mod_eq_zero h_mod_eq), ih.1]
          · exact ih.2
      else simp [h_mod]; constructor; rfl; exact h_cond.1
  have h_primes_gt_1 : ∀ p ∈ primes, p > 1 := by
    intro p hp; have h_p_prime := (List.all_eq_true.1 h_precond.2.2.1) p hp; exact Nat.Prime.one_lt (decide_eq_true_iff.1 h_p_prime)
  have h_main : ∀ ps n, n > 0 → (∀ p ∈ ps, p > 1) →
      let res := findExponents.countFactors n ps
      (n = res.foldl f 1) ∧ (res.all (fun pair => pair.1 ∈ ps) = true) ∧ (ps.all (fun p' => res.any (fun pair => pair.1 = p')) = true) := by
    intro ps; induction ps with
    | nil => intro n hn hpg; simp [findExponents.countFactors]
    | cons p ps ih =>
      intro n hn hpg; simp [findExponents.countFactors]
      match h_cf : findExponents.countFactor n p 0 with
      | (e, n') =>
        have hcf := h_countFactor n p 0 hn (hpg p (List.mem_cons_self p ps))
        rw [h_cf] at hcf; simp at hcf
        let ⟨h1, h2, h3⟩ := ih n' hcf.2 (λ p' hp' => hpg p' (List.mem_cons_of_mem p hp'))
        refine ⟨?_, ?_, ?_⟩
        · rw [List.foldl_cons, h_foldl_mul, h1, hcf.1, Nat.pow_zero, Nat.mul_one, Nat.mul_comm]
        · rw [List.all_eq_true]; intro ⟨p', e'⟩ h_in; simp at h_in; rcases h_in with h_head | h_tail
          · simp at h_head; simp [h_head]
          · right; exact List.all_eq_true.1 h2 _ h_tail
        · rw [List.all_eq_true]; intro p' hp'; simp at hp'; rcases hp' with rfl | h_tail
          · simp [List.any_eq_true]; use (p, e)
          · simp [List.any_eq_true]; rcases List.any_eq_true.1 (List.all_eq_true.1 h3 p' h_tail) with ⟨pair, h_in, h_eq⟩
            use pair; simp [h_in, h_eq]
