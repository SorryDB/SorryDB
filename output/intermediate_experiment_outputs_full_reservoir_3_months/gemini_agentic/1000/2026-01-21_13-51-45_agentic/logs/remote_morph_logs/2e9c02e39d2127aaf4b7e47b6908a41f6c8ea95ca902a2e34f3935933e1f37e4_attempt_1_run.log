    findExponents_postcond (n) (primes) (findExponents (n) (primes) h_precond) h_precond := by
  unfold findExponents_postcond findExponents
  let f := fun acc (pair : Nat × Nat) => acc * pair.1 ^ pair.2
  have h_foldl_mul : ∀ l init, l.foldl f init = init * l.foldl f 1 := by
    intro l init; induction l generalizing init with
    | nil => simp
    | cons x xs ih => simp [f, ih (init * x.1 ^ x.2), ih (x.1 ^ x.2), Nat.mul_assoc]
  have h_countFactor : ∀ n p c, n > 0 → p > 1 →
      let res := findExponents.countFactor n p c
      n * p^c = res.2 * p^res.1 ∧ res.2 > 0 := by
    intro n p c hn hp; induction n, p, c using findExponents.countFactor.induct with
    | case1 => contradiction
    | case2 n p c h_cond ih =>
      rw [findExponents.countFactor]; simp [h_cond]
      if h_mod : n % p == 0 then
        simp [h_mod]
        have h_mod_eq := beq_iff_eq.mp h_mod
        have h_div_pos : n / p > 0 := Nat.div_pos (Nat.le_of_dvd h_cond.1 (Nat.dvd_of_mod_eq_zero h_mod_eq)) (Nat.pos_of_gt h_cond.2)
        specialize ih h_mod h_div_pos h_cond.2
        let (c', n') := findExponents.countFactor (n / p) p (c + 1)
        have : (c', n') = findExponents.countFactor (n / p) p (c + 1) := rfl
        rw [← this, ih]; constructor
        · rw [Nat.mul_assoc, ← Nat.pow_succ, Nat.div_mul_cancel (Nat.dvd_of_mod_eq_zero h_mod_eq)]
        · exact ih.2
      else
        simp [h_mod]; constructor; rfl; exact h_cond.1
  have h_main : ∀ primes n, n > 0 → (∀ p ∈ primes, p > 1) →
      let res := findExponents.countFactors n primes
      (n = res.foldl f 1) ∧ (res.all (fun (p, _) => p ∈ primes)) ∧ (primes.all (fun p => res.any (fun pair => pair.1 = p))) := by
    intro primes; induction primes with
    | nil => simp [findExponents.countFactors]
    | cons p ps ih =>
      intro n hn hp_all
      simp [findExponents.countFactors]
      let (e, n') := findExponents.countFactor n p 0
      have hp : p > 1 := hp_all p (List.mem_cons_self _ _)
      have hcf := h_countFactor n p 0 hn hp
