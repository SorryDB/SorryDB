import Mathlib.Analysis.Convex.Basic
import Mathlib.Data.Real.Basic

/-!
# VCₙ dimension of convex sets in ℝⁿ⁺¹, ℝⁿ⁺²

In the literature it is known that every convex set in ℝ² has VC dimension at most 3,
and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := sorry

/-- There exists a set of infinite VC dimension in ℝ³. -/
lemma exists_convex_r3_vc_eq_infty :
    ∃ (C : Set (Fin 3 → ℝ)) (hC : Convex ℝ C) (x : ℕ → Fin 3 → ℝ) (y : Set ℕ → Fin 3 → ℝ),
      ∀ i s, x i + y s ∈ C ↔ i ∈ s := sorry

/-! ### What's new -/

/-- There exists a set of infinite VCₙ dimension in ℝⁿ⁺². -/
lemma exists_convex_rn_add_two_vc_n_eq_infty (n : ℕ) :
    ∃ (C : Set (Fin (n + 2) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 2) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 2) → ℝ),
        ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s := by
  obtain ⟨C, hC, x, y, h⟩ := exists_convex_r3_vc_eq_infty
  obtain ⟨f, hf⟩ : ∃ f : (Fin n → ℕ) → ℕ, Function.Injective f := by
    cases n
    · exact ⟨fun _ => 0, fun _ _ _ => Subsingleton.elim _ _⟩
    · obtain ⟨e⟩ := (nonempty_equiv_of_countable (Fin _ → ℕ))
      exact ⟨e, e.injective⟩
  let φ : (Fin (n + 2) → ℝ) →ₗ[ℝ] (Fin 3 → ℝ) :=
    { toFun := fun z => ![z 0, if hn : 1 < n + 2 then z ⟨1, hn⟩ else 0, if hn : 2 < n + 2 then z ⟨2, hn⟩ else 0]
      map_add' := by intros; ext i; fin_cases i <;> simp
      map_smul' := by intros; ext i; fin_cases i <;> simp }
  refine ⟨φ ⁻¹' C, hC.preimage φ,
    fun k m j => if hj : j.1 < 3 then (if k.1 = 0 then x (f (fun _ => m)) ⟨j.1, hj⟩ else 0) else 0,
    fun s j => if hj : j.1 < 3 then y (f '' s) ⟨j.1, hj⟩ else 0, ?_⟩
  intro i s
  simp only [φ, LinearMap.coe_mk, Set.mem_preimage]
  let x_sum : Fin 3 → ℝ := fun j => ∑ k, if k.1 = 0 then x (f (fun _ => i k)) j else 0
  have hx : ∀ j, x_sum j = if n = 0 then 0 else x (f (fun _ => i 0)) j := by
    intro j; simp [x_sum]; cases n
    · simp
    · rw [Finset.sum_eq_single 0]; simp; intros; simp_all
  cases n
  · simp [hx, h]
    have : f (fun x => i x) = 0 := by ext j; exact j.elim0
    rw [this]; simp [h]
  · simp [hx, h, hf.mem_set_image]
    constructor
    · rintro ⟨j, hj, hji⟩
      rwa [hf hji] at hj
    · intro hi; refine ⟨i, hi, rfl⟩
