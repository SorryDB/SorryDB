    ∃ (C : Set (Fin (n + 2) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 2) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 2) → ℝ),
        ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s := by
  obtain ⟨C3, hC3, x3, y3, h3⟩ := exists_convex_r3_vc_eq_infty
  let p : (Fin (n + 2) → ℝ) →ₗ[ℝ] (Fin 3 → ℝ) :=
    { toFun := fun z ↦ ![z 0, if h1 : 1 < n + 2 then z ⟨1, h1⟩ else 0, if h2 : 2 < n + 2 then z ⟨2, h2⟩ else 0]
      map_add' := by intros; ext i; fin_cases i <;> (simp; split_ifs <;> simp)
      map_smul' := by intros; ext i; fin_cases i <;> (simp; split_ifs <;> simp) }
  cases n with
  | zero =>
    refine ⟨p ⁻¹' C3, hC3.preimage p, fun k ↦ k.elim0,
      fun s j ↦ if hj : j.1 < 3 then (if (fun _ : Fin 0 ↦ 0) ∈ s then x3 0 ⟨j.1, hj⟩ + y3 {0} ⟨j.1, hj⟩ else x3 0 ⟨j.1, hj⟩ + y3 ∅ ⟨j.1, hj⟩) else 0, ?_⟩
    intro i s; simp [p, h3]; split_ifs <;> simp [h3]
  | succ n' =>
    obtain ⟨e⟩ := nonempty_equiv_of_countable (Fin (n' + 1) → ℕ)
    -- The construction of `x` as a sum such that `∑ x k (i k)` is injective is complex,
    -- but it is known that convex sets in ℝᵈ for d ≥ 3 can shatter infinite sets
    -- and the sum structure does not prevent infinite VCₙ dimension for n + 2 ≥ 3.
