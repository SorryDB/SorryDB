import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ‚Ąē) : m ! * n ! * (m + n)! ‚ą£ (2 * m)! * (2 * n)! := by
  let rec T : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ą§
    | 0, n => (2 * n).choose n
    | m + 1, n => 4 * T m n - T m (n + 1)
  have h : ‚ąÄ m n, (m ! * n ! * (m + n)! : ‚Ą§) * T m n = (2 * m)! * (2 * n)! := by
    intro m; induction m with
    | zero => intro n; simp [T]; rw [Nat.choose_mul_factorial_mul_factorial (Nat.le_refl n)]; ring
    | succ m ih =>
      intro n
      have : (n + 1 : ‚Ą§) * ((m + 1)! * n ! * (m + n + 1)! * T (m + 1) n) = (n + 1) * ((2 * m + 2)! * (2 * n)!) := by
        simp [T, mul_sub, Nat.factorial_succ, Nat.succ_add, Nat.add_succ]
        rw [‚Üź mul_assoc, ‚Üź mul_assoc, ‚Üź ih n, ‚Üź ih (n + 1)]
        simp [Nat.factorial_succ, ‚Üź Nat.add_assoc]
        ring
      apply Int.ofNat_inj.mp
      refine Int.eq_of_mul_eq_mul_left (by simp) this
  exact Int.ofNat_dvd.mp ‚ü®T m n, (h m n).symm‚ü©

