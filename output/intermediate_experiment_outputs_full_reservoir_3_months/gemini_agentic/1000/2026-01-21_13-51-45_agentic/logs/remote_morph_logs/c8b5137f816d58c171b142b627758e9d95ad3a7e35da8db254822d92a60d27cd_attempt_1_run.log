import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ‚Ąē) : m ! * n ! * (m + n)! ‚ą£ (2 * m)! * (2 * n)! := by
  let T : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ą§ := fun m => Nat.rec (fun n => ‚ÜĎ((2 * n).choose n)) (fun _ ih n => 4 * ih n - ih (n + 1)) m
  have h : ‚ąÄ m n, (‚ÜĎ(m ! * n ! * (m + n)!) : ‚Ą§) * T m n = ‚ÜĎ((2 * m)! * (2 * n)!) := by
    intro m; induction m with
    | zero =>
      intro n
      have h_T0 : T 0 n = ‚ÜĎ((2 * n).choose n) := rfl
      rw [h_T0]
      have h_sub : 2 * n - n = n := by omega
      have h_le : n ‚Č§ 2 * n := by omega
      push_cast
      rw [‚Üź Nat.choose_mul_factorial_mul_factorial h_le, h_sub]
      simp; ring
    | succ m ih =>
      intro n
      apply (Int.mul_eq_mul_left_iff (by omega : (‚ÜĎ(n + 1) : ‚Ą§) ‚Č† 0)).mp
      have h_Tm : T (m + 1) n = 4 * T m n - T m (n + 1) := rfl
      rw [h_Tm]
      simp only [Int.ofNat_mul, Int.ofNat_sub, mul_sub]
      have h1 : (‚ÜĎ(n + 1) : ‚Ą§) * (‚ÜĎ(m + 1)! * ‚ÜĎn ! * ‚ÜĎ(m + n + 1)! * (4 * T m n)) =
                (‚ÜĎ(n + 1) * ‚ÜĎ(m + 1) * ‚ÜĎ(m + n + 1) * 4) * (‚ÜĎm ! * ‚ÜĎn ! * ‚ÜĎ(m + n)! * T m n) := by
        simp [Nat.factorial_succ, Nat.succ_add, Nat.add_succ]
        push_cast; ring
      have h2 : (‚ÜĎ(n + 1) : ‚Ą§) * (‚ÜĎ(m + 1)! * ‚ÜĎn ! * ‚ÜĎ(m + n + 1)! * T m (n + 1)) =
                (‚ÜĎ(m + 1)) * (‚ÜĎm ! * ‚ÜĎ(n + 1)! * ‚ÜĎ(m + n + 1)! * T m (n + 1)) := by
        simp [Nat.factorial_succ, Nat.succ_add, Nat.add_succ]
        push_cast; ring
      rw [h1, h2, ih n, ih (n + 1)]
      simp [Nat.factorial_succ, Nat.succ_add, Nat.add_succ]
      push_cast; ring
  exact Int.ofNat_dvd.mp ‚ü®T m n, (h m n).symm‚ü©

