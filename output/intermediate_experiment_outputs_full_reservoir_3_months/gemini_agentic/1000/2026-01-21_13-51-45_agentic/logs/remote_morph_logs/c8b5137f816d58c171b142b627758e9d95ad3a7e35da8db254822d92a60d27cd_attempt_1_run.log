    intro m; induction m with
    | zero =>
      intro n
      simp only [Nat.factorial_zero, Nat.zero_add, Nat.cast_one, one_mul, Nat.rec_zero]
      have h_T0 : T 0 n = (2 * n).choose n := rfl
      rw [h_T0]
      push_cast
      rw [Nat.mul_comm (n.factorial * n.factorial), ‚Üź Nat.choose_mul_factorial_mul_factorial (by omega : n ‚Č§ 2 * n)]
      have : 2 * n - n = n := by omega
      rw [this]
      ring
    | succ m ih =>
      intro n
      apply (Int.mul_eq_mul_left_iff (by omega : (n + 1 : ‚Ą§) ‚Č† 0)).mp
      have h_T_succ : T (m + 1) n = 4 * T m n - T m (n + 1) := rfl
      rw [h_T_succ, Int.mul_sub]
      have h1 : (‚ÜĎ(n + 1) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial) * (4 * T m n) : ‚Ą§) =
                (4 * (‚ÜĎm + 1) * (‚ÜĎm + ‚ÜĎn + 1) * (‚ÜĎn + 1)) * (‚ÜĎm.factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + n).factorial * T m n) := by
        rw [Nat.factorial_succ m, Nat.add_right_comm m 1 n, Nat.factorial_succ (m + n)]
        push_cast; ring
      have h2 : (‚ÜĎ(n + 1) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial) * T m (n + 1) : ‚Ą§) =
                (‚ÜĎm + 1) * (‚ÜĎm.factorial * ‚ÜĎ(n + 1).factorial * ‚ÜĎ(m + n + 1).factorial * T m (n + 1)) := by
