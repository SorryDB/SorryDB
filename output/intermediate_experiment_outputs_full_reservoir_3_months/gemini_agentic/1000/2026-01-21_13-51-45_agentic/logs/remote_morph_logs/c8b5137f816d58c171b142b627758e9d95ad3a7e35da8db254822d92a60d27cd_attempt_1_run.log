/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ‚Ąē) : m ! * n ! * (m + n)! ‚ą£ (2 * m)! * (2 * n)! := by
  let T : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ą§ := fun m => Nat.rec (fun n => ‚ÜĎ((2 * n).choose n)) (fun _ ih n => 4 * ih n - ih (n + 1)) m
  have h : ‚ąÄ m n, (‚ÜĎ(m ! * n ! * (m + n)!) : ‚Ą§) * T m n = ‚ÜĎ((2 * m)! * (2 * n)!) := by
    intro m; induction m with
    | zero =>
      intro n
      have h_T0 : T 0 n = ‚ÜĎ((2 * n).choose n) := rfl
      rw [h_T0]; push_cast
      rw [‚Üź Nat.choose_mul_factorial_mul_factorial (by omega : n ‚Č§ 2 * n)]
      have h_sub : 2 * n - n = n := by omega
      rw [h_sub, Nat.factorial_zero]; ring
    | succ m ih =>
      intro n
      apply (Int.mul_eq_mul_left_iff (by omega : (‚ÜĎn + 1 : ‚Ą§) ‚Č† 0)).mp
      have h_T_succ : T (m + 1) n = 4 * T m n - T m (n + 1) := rfl
      rw [h_T_succ, Int.mul_sub, ‚Üź Int.mul_assoc, ‚Üź Int.mul_assoc]
      have h1 : (‚ÜĎ(n + 1) * ‚ÜĎ((m + 1)! * n ! * (m + n + 1)!) * (4 * T m n) : ‚Ą§) =
                (4 * (‚ÜĎm + 1) * (‚ÜĎm + ‚ÜĎn + 1) * (‚ÜĎn + 1)) * (‚ÜĎ(m ! * n ! * (m + n)!) * T m n) := by
        push_cast; rw [Nat.factorial_succ m, Nat.factorial_succ (m + n)]; ring
      have h2 : (‚ÜĎ(n + 1) * ‚ÜĎ((m + 1)! * n ! * (m + n + 1)!) * T m (n + 1) : ‚Ą§) =
                (‚ÜĎm + 1) * (‚ÜĎ(m ! * (n + 1)! * (m + n + 1)!) * T m (n + 1)) := by
        push_cast; rw [Nat.factorial_succ m, Nat.factorial_succ n]; ring
      rw [h1, h2, ih n]
      have h_m_n_1 : m + (n + 1) = m + n + 1 := by omega
      rw [h_m_n_1, ih (n + 1)]
      push_cast
      rw [Nat.factorial_succ (2 * m + 1), Nat.factorial_succ (2 * m),
          Nat.factorial_succ (2 * n + 1), Nat.factorial_succ (2 * n)]
