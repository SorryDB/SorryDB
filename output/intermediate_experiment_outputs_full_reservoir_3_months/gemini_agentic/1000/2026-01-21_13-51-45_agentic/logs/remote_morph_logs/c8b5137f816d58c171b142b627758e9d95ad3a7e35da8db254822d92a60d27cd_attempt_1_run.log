open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ‚Ąē) : m.factorial * n.factorial * (m + n).factorial ‚ą£ (2 * m).factorial * (2 * n).factorial := by
  let T : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ą§ := fun m => Nat.rec (motive := fun _ => ‚Ąē ‚Üí ‚Ą§)
    (fun n => ‚ÜĎ((2 * n).choose n))
    (fun _ ih n => 4 * ih n - ih (n + 1)) m
  have h : ‚ąÄ m n, (‚ÜĎm.factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + n).factorial * T m n : ‚Ą§) = ‚ÜĎ(2 * m).factorial * ‚ÜĎ(2 * n).factorial := by
    intro m; induction m with
    | zero =>
      intro n
      simp only [Nat.factorial_zero, Nat.zero_add, Nat.cast_one, one_mul]
      have hT0 : T 0 n = ‚ÜĎ((2 * n).choose n) := rfl
      rw [hT0, ‚Üź Nat.cast_mul, ‚Üź Nat.cast_mul]
      apply congr_arg Nat.cast
      rw [Nat.mul_comm, Nat.mul_assoc, Nat.choose_mul_factorial_mul_factorial (by omega)]
      congr; omega
    | succ m ih =>
      intro n
      have hT : T (m + 1) n = 4 * T m n - T m (n + 1) := rfl
      apply (Int.mul_eq_mul_left_iff (by omega : (‚ÜĎn + 1 : ‚Ą§) ‚Č† 0)).mp
      have h1 : (‚ÜĎn + 1 : ‚Ą§) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial * (4 * T m n)) =
                4 * (‚ÜĎm + 1) * (‚ÜĎm + ‚ÜĎn + 1) * (‚ÜĎn + 1) * (‚ÜĎ(2 * m).factorial * ‚ÜĎ(2 * n).factorial) := by
        rw [Nat.factorial_succ m, show m + 1 + n = m + n + 1 by omega, Nat.factorial_succ (m + n)]
        push_cast; rw [ih n]; ring
      have h2 : (‚ÜĎn + 1 : ‚Ą§) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial * T m (n + 1)) =
                (‚ÜĎm + 1) * (‚ÜĎ(2 * m).factorial * ‚ÜĎ(2 * (n + 1)).factorial) := by
        rw [Nat.factorial_succ m, Nat.factorial_succ n, show m + 1 + n = m + n + 1 by omega,
            show m + (n + 1) = m + n + 1 by omega]
        push_cast; rw [ih (n + 1)]; ring
      have split : (‚ÜĎn + 1 : ‚Ą§) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial * T (m + 1) n) =
                    (‚ÜĎn + 1 : ‚Ą§) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial * (4 * T m n)) -
                    (‚ÜĎn + 1 : ‚Ą§) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial * T m (n + 1)) := by
        rw [hT]; ring
      rw [split, h1, h2]
      rw [show 2 * (m + 1) = 2 * m + 2 by omega, show 2 * (n + 1) = 2 * n + 2 by omega]
      rw [Nat.factorial_succ (2 * m + 1), Nat.factorial_succ (2 * m),
          Nat.factorial_succ (2 * n + 1), Nat.factorial_succ (2 * n)]
      push_cast; ring
  exact Int.ofNat_dvd.mp ‚ü®T m n, (h m n).symm‚ü©

