/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ‚Ąē) : m.factorial * n.factorial * (m + n).factorial ‚ą£ (2 * m).factorial * (2 * n).factorial := by
  let T : ‚Ąē ‚Üí ‚Ąē ‚Üí ‚Ą§ := fun m => Nat.rec (motive := fun _ => ‚Ąē ‚Üí ‚Ą§) (fun n => ‚ÜĎ((2 * n).choose n)) (fun _ ih n => 4 * ih n - ih (n + 1)) m
  have hT0 : ‚ąÄ n, T 0 n = (2 * n).choose n := fun n => rfl
  have hTs : ‚ąÄ m n, T (m + 1) n = 4 * T m n - T m (n + 1) := fun m n => rfl
  have h : ‚ąÄ m n, (‚ÜĎm.factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + n).factorial * T m n : ‚Ą§) = ‚ÜĎ(2 * m).factorial * ‚ÜĎ(2 * n).factorial := by
    intro m; induction m with
    | zero =>
      intro n
      rw [hT0]
      have h_le : n ‚Č§ 2 * n := by omega
      have h_bin : (2 * n).choose n * n.factorial * n.factorial = (2 * n).factorial := by
        rw [‚Üź Nat.choose_mul_factorial_mul_factorial h_le]
        congr; omega
      simp only [Nat.factorial_zero, Nat.zero_add, Nat.cast_one, one_mul]
      rw [‚Üź h_bin]
      push_cast
      ring
    | succ m ih =>
      intro n
      apply (Int.mul_eq_mul_left_iff (by omega : (‚ÜĎn + 1 : ‚Ą§) ‚Č† 0)).mp
      rw [hTs, Int.mul_assoc, Int.mul_sub, Int.mul_sub]
      have h1 : (‚ÜĎ(n + 1) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial * (4 * T m n)) : ‚Ą§) =
                (4 * (‚ÜĎm + 1) * (‚ÜĎm + ‚ÜĎn + 1) * (‚ÜĎn + 1)) * (‚ÜĎ(2 * m).factorial * ‚ÜĎ(2 * n).factorial) := by
        rw [Nat.factorial_succ m]
        have : m + 1 + n = m + n + 1 := by omega
        rw [this, Nat.factorial_succ (m + n), ‚Üź ih n]
        push_cast; ring
      have h2 : (‚ÜĎ(n + 1) * (‚ÜĎ(m + 1).factorial * ‚ÜĎn.factorial * ‚ÜĎ(m + 1 + n).factorial * T m (n + 1)) : ‚Ą§) =
                (‚ÜĎm + 1) * (‚ÜĎ(2 * m).factorial * ‚ÜĎ(2 * (n + 1)).factorial) := by
        rw [Nat.factorial_succ m]
        have : m + 1 + n = m + n + 1 := by omega
        rw [this, Nat.factorial_succ n]
        have : m + n + 1 = m + (n + 1) := by omega
        rw [this, ‚Üź ih (n + 1)]
        push_cast; ring
      rw [h1, h2]
      have h_2m2 : 2 * (m + 1) = 2 * m + 2 := by omega
      have h_2n2 : 2 * (n + 1) = 2 * n + 2 := by omega
      rw [h_2m2, h_2n2, Nat.factorial_succ (2 * m + 1), Nat.factorial_succ (2 * m),
          Nat.factorial_succ (2 * n + 1), Nat.factorial_succ (2 * n)]
      push_cast; ring
