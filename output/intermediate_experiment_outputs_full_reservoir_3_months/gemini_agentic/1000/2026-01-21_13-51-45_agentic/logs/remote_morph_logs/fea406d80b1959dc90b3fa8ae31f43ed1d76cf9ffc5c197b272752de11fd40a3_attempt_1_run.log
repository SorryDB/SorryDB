import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  by_contra! h
  let m := (n + 1).sqrt
  have hm : 10 ≤ m := Nat.le_sqrt.mpr (by omega)
  let k := m - 1
  have hk : 9 ≤ k := by dsimp [k]; omega
  have h_m : m = k + 1 := by dsimp [k]; omega
  have h_m_sq_le : (k + 1) * (k + 1) ≤ n + 1 := by rw [← h_m]; exact Nat.sqrt_le (n + 1)
  have h_m_sq_lt : n + 1 < (k + 2) * (k + 2) := by rw [← h_m]; exact Nat.sqrt_lt.mp (Nat.lt_succ_self m)
  let a := 2 * k * k + 1
  let b := 2 * k * k - 4 * k
  let c := 2 * k * k + 4 * k
  have hb_val : (b : ℤ) = 2 * (k : ℤ) * k - 4 * k := by
    rw [Int.ofNat_sub]; nlinarith
  have ha_in : a ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; zify [hk] at *; constructor <;> nlinarith
  have hb_in : b ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; zify [hk] at *; rw [hb_val]; constructor <;> nlinarith
  have hc_in : c ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; zify [hk] at *; constructor <;> nlinarith
  have h_sq_logic (x y : ℕ) (hx : x ∈ Finset.Icc n (2 * n)) (hy : y ∈ Finset.Icc n (2 * n))
      (hxy : x ≠ y) (hsq : IsSquare (x + y)) : (x ∈ S ↔ y ∉ S) := by
    constructor
    · intro hxS hyS; exact h.1 x hxS y hyS hxy hsq
    · intro hnyS; by_contra hnxS; exact h.2 x (Finset.mem_sdiff.mpr ⟨hx, hnxS⟩) y (Finset.mem_sdiff.mpr ⟨hy, hnyS⟩) hxy hsq
  have sab : IsSquare (a + b) := ⟨2 * k - 1, by zify [hk, hb_val]; ring⟩
  have sbc : IsSquare (b + c) := ⟨2 * k, by zify [hk, hb_val]; ring⟩
  have sca : IsSquare (c + a) := ⟨2 * k + 1, by zify [hk, hb_val]; ring⟩
  have hab : a ≠ b := by zify [hk, hb_val]; nlinarith
  have hbc : b ≠ c := by zify [hk, hb_val]; nlinarith
  have hca : c ≠ a := by zify [hk, hb_val]; nlinarith
  have h_ab := h_sq_logic a b ha_in hb_in hab sab
  have h_bc := h_sq_logic b c hb_in hc_in hbc sbc
  have h_ca := h_sq_logic c a hc_in ha_in hca sca
  tauto

