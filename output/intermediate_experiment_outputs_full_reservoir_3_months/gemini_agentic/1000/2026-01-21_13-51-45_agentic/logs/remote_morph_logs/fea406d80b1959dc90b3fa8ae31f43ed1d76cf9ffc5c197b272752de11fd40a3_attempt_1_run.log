  have hk9 : 9 ≤ k := by
    by_contra! k_lt_9
    have : 2 * k * k - 4 * k ≤ 96 := by interval_cases k <;> norm_num
    have : 100 ≤ 2 * k * k - 4 * k := hn.trans hk_spec
    omega
  have ha_pos : 4 * k ≤ 2 * k * k := by nlinarith
