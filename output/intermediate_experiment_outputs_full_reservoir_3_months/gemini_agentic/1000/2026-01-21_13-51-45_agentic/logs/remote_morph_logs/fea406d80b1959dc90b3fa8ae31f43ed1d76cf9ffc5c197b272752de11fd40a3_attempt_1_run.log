import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  by_contra! h
  let k := (n + 1).sqrt - 1
  have hk : 9 ≤ k := by
    have : 10 * 10 ≤ n + 1 := by omega
    have : 10 ≤ (n + 1).sqrt := Nat.le_sqrt.mpr this
    omega
  let a := 2 * k * k + 1
  let b := 2 * k * k - 4 * k
  let c := 2 * k * k + 4 * k
  have h1 : (k + 1) * (k + 1) ≤ n + 1 := Nat.sqrt_le (n + 1)
  have h2 : n + 1 < (k + 2) * (k + 2) := Nat.sqrt_lt.mp (by dsimp [k]; omega)
  have ha : a ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; dsimp [a]; zify [hk] at *; nlinarith
  have hb : b ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; dsimp [b]; zify [hk] at *; nlinarith
  have hc : c ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; dsimp [c]; zify [hk] at *; nlinarith
  have h_sq_n_2n (x y : ℕ) (hx : x ∈ Finset.Icc n (2 * n)) (hy : y ∈ Finset.Icc n (2 * n))
      (hxy : x ≠ y) (hsq : IsSquare (x + y)) : (x ∈ S ↔ y ∉ S) := by
    constructor
    · intro hxS; by_contra hyS; exact h.1 x hxS y hyS hxy hsq
    · intro hnxS; by_contra hnyS
      exact h.2 x (Finset.mem_sdiff.mpr ⟨hx, hnxS⟩) y (Finset.mem_sdiff.mpr ⟨hy, hnyS⟩) hxy hsq
  have sab : IsSquare (a + b) := ⟨2 * k - 1, by dsimp [a, b]; zify [hk]; ring⟩
  have sbc : IsSquare (b + c) := ⟨2 * k, by dsimp [b, c]; zify [hk]; ring⟩
  have sca : IsSquare (c + a) := ⟨2 * k + 1, by dsimp [a, c]; zify [hk]; ring⟩
  have h_ab := h_sq_n_2n a b ha hb (by dsimp [a, b]; zify [hk]; nlinarith) sab
  have h_bc := h_sq_n_2n b c hb hc (by dsimp [b, c]; zify [hk]; nlinarith) sbc
  have h_ca := h_sq_n_2n c a hc ha (by dsimp [a, c]; zify [hk]; nlinarith) sca
  tauto

