  let k := m - 1
  have hk : 9 ≤ k := by dsimp [k]; omega
  have h_m : m = k + 1 := by dsimp [k]; omega
  have h_m_sq_le : (k + 1) * (k + 1) ≤ n + 1 := Nat.sqrt_le (n + 1)
  have h_m_sq_lt : n + 1 < (k + 2) * (k + 2) := by
    have h_lt := Nat.lt_succ_sqrt (n + 1)
    rw [h_m] at h_lt; exact h_lt
  let a := 2 * k * k + 1
  let b := 2 * k * k - 4 * k
  let c := 2 * k * k + 4 * k
  have hb_pos : 4 * k ≤ 2 * k * k := by nlinarith [hk]
  have h2k : 1 ≤ 2 * k := by nlinarith [hk]
  have h_sq_logic (x y : ℕ) (hx : x ∈ Finset.Icc n (2 * n)) (hy : y ∈ Finset.Icc n (2 * n))
      (hxy : x ≠ y) (hsq : IsSquare (x + y)) : (x ∈ S ↔ y ∉ S) := by
    constructor
    · intro hxS hyS; exact h.1 x hxS y hyS hxy hsq
    · intro hnyS; by_contra hnxS; exact h.2 x (Finset.mem_sdiff.mpr ⟨hx, hnxS⟩) y (Finset.mem_sdiff.mpr ⟨hy, hnyS⟩) hxy hsq
  have hb_in : b ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]
    zify [hb_pos, hk] at *
    constructor <;> nlinarith [h_m_sq_le, h_m_sq_lt]
  have ha_in : a ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]
    zify [hb_pos, hk] at *
    constructor <;> nlinarith [h_m_sq_le, h_m_sq_lt]
  have hc_in : c ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]
    zify [hb_pos, hk] at *
    constructor <;> nlinarith [h_m_sq_le, h_m_sq_lt]
  have sab : IsSquare (a + b) := ⟨2 * k - 1, by zify [hb_pos, h2k, hk]; dsimp [a, b]; ring⟩
  have sbc : IsSquare (b + c) := ⟨2 * k, by zify [hb_pos, hk]; dsimp [b, c]; ring⟩
  have sca : IsSquare (c + a) := ⟨2 * k + 1, by zify [hb_pos, hk]; dsimp [a, c]; ring⟩
  have hab : a ≠ b := by zify [hb_pos, hk]; dsimp [a, b]; nlinarith
  have hbc : b ≠ c := by zify [hb_pos, hk]; dsimp [b, c]; nlinarith
  have hca : c ≠ a := by zify [hb_pos, hk]; dsimp [c, a]; nlinarith
  have h1 := h_sq_logic a b ha_in hb_in hab sab
  have h2 := h_sq_logic b c hb_in hc_in hbc sbc
  have h3 := h_sq_logic c a hc_in ha_in hca sca
  tauto

