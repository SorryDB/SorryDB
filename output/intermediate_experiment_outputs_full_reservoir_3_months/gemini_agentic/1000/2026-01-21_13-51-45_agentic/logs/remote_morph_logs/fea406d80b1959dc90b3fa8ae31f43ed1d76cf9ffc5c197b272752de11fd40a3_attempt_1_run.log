import Mathlib


namespace IMO2021P1

theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  by_contra! h
  have hex : ∃ k, n ≤ 2 * k * k - 4 * k := by
    use n; nlinarith
  let k := Nat.find hex
  have hk_spec : n ≤ 2 * k * k - 4 * k := Nat.find_spec hex
  have hk_min : ∀ m < k, 2 * m * m - 4 * m < n := by
    intro m hm
    have := Nat.find_min hex hm
    omega
  have hk9 : 9 ≤ k := by
    by_contra! k_lt_9
    have : 2 * k * k - 4 * k ≤ 96 := by
      revert k; intro k hk; interval_cases k <;> norm_num
    omega
  have hnk2 : k * k + 2 * k ≤ n := by
    by_cases hk : k = 9
    · subst hk; omega
    · have hk10 : 10 ≤ k := by omega
      have h_k_min := hk_min (k - 1) (by omega)
      zify at h_k_min; nlinarith
  let a := 2 * k * k - 4 * k
  let b := 2 * k * k + 1
  let c := 2 * k * k + 4 * k
  have ha : 4 * k ≤ 2 * k * k := by nlinarith
  have a_in : a ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; constructor
    · exact hk_spec
    · nlinarith
  have b_in : b ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; constructor
    · nlinarith
    · nlinarith
  have c_in : c ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; constructor
    · nlinarith
    · nlinarith [hnk2]
  have sab : IsSquare (a + b) := by
    use 2 * k - 1; zify [ha, hk9]; ring
  have sbc : IsSquare (b + c) := by
    use 2 * k + 1; zify [hk9]; ring
  have sca : IsSquare (c + a) := by
    use 2 * k; zify [ha, hk9]; ring
  have hab : a ≠ b := by omega
  have hbc : b ≠ c := by omega
  have hca : c ≠ a := by omega
  have h_logic (x y : ℕ) (hx : x ∈ Finset.Icc n (2 * n)) (hy : y ∈ Finset.Icc n (2 * n))
      (hxy : x ≠ y) (hsq : IsSquare (x + y)) : (x ∈ S ↔ y ∉ S) := by
    constructor
    · intro hxS; by_contra hyS; exact h.1 x hxS y hyS hxy hsq
    · intro hyNS; by_contra hxNS
      exact h.2 x (Finset.mem_sdiff.mpr ⟨hx, hxNS⟩) y (Finset.mem_sdiff.mpr ⟨hy, hyNS⟩) hxy hsq
  have h1 := h_logic a b a_in b_in hab sab
  have h2 := h_logic b c b_in c_in hbc sbc
  have h3 := h_logic c a c_in a_in hca sca
  tauto

