lemma matchingMatroid.noColoop (h : ∀ x, G.inessential x) (hx : x ∈ V(G)) :
    ¬ G.matchingMatroid.IsColoop x := by
  intro hcl
  obtain ⟨M, hM, hxM⟩ := h x
  have hI : G.matchingMatroid.Indep (V(G, M)) := ⟨M, hM.toIsMatching, subset_refl _⟩
  have hI' := hcl.indep_insert hI hxM
  obtain ⟨M', hM', hxVM'⟩ := hI'
  have hle := hM.max M' hM'
  have hlt : M.encard < M'.encard := by
    have h_enc := (encard_le_encard hxVM')
    rw [encard_insert hxM] at h_enc
    -- In the matchable sets matroid, the encard of the vertex set of a matching is 2 * M.encard.
    -- The inequality 2 * M.encard + 1 ≤ 2 * M'.encard implies M.encard < M'.encard.
    sorry
  exact hle.not_lt hlt

```
