    ring
  have h_final : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = a ^ 2 + b ^ 2 + c ^ 2 := by
    simp [a, b, c]
    field_simp [hx, hy, hz]
  rw [h_final, h_eq]
  nlinarith [sq_nonneg (a + b + c - 1)]

