  let c := z / (z - 1)
  have h_abc : a + b + c - 1 = a * b + b * c + c * a := by
    simp [a, b, c]
    field_simp [hx, hy, hz]
    rw [h₁]
    ring
  have h_eq : a ^ 2 + b ^ 2 + c ^ 2 = (a + b + c - 1) ^ 2 + 1 := by
