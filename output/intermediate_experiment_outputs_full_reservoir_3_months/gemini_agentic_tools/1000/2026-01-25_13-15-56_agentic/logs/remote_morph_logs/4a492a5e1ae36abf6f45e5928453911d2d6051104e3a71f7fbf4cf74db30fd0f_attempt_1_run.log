      let f I i := #{k | (I k).1 = i} + #{k | (I k).2 = i}
      have hf I (hI : I ∈ piFinset fun _ : Fin m ↦ A ×ˢ A) : f I ∈ piAntidiag A (2 * m) := by
        simp only [mem_piAntidiag, mem_piFinset, mem_product] at hI ⊢
