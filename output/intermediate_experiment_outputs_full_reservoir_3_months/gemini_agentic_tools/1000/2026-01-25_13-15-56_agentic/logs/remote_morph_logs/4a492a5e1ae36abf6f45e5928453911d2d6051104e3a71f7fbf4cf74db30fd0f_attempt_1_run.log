          Fin.cast_apply, finProdFinEquiv_apply]
        rw [← card_union_eq, filter_union_right]
        · congr; ext k; fin_cases k <;> simp
        · rw [disjoint_filter]; intro k hk; fin_cases k <;> simp
      have h2 : {I ∈ piFinset fun _ ↦ A ×ˢ A | f I = w} = (Equiv.finsetCongr e).symm
        {J ∈ piFinset (fun _ ↦ A) | (fun i ↦ #{k | J k = i}) = w} := by
        ext I; simp only [e, Equiv.finsetCongr_apply, mem_piFinset, mem_product,
