    sorry

  completeness := by
    circuit_proof_start
    simp [circuit_norm, main, LessThan.main, Num2Bits.circuit] at *
    constructor
    · have h1 : ZMod.val ((2 : F p) ^ n) = 2 ^ n := by
        rw [ZMod.val_pow, ZMod.val_ofNat_of_lt]; simp_all; exact Fact.out; linarith [hn]
