      have h_coll := EuclideanGeometry.collinear_of_angle_eq_zero h_angle
      exact h_coll.mem_affineSpan_of_mem_of_ne (Set.mem_insert _ _) (Set.mem_insert_of_mem _ (Set.mem_insert _ _)) (Set.mem_insert_of_mem _ (Set.mem_insert_of_mem _ (Set.mem_singleton _))) hB_ne_C
    exact (⟨![A, B, C], affineIndependent_ABC⟩ : Triangle ℝ P).not_mem_line_of_mem_interior 0 D_mem_interior_ABC hD_BC
  have hO1O2 : O₁ ≠ O₂ := by
    intro h_eq
