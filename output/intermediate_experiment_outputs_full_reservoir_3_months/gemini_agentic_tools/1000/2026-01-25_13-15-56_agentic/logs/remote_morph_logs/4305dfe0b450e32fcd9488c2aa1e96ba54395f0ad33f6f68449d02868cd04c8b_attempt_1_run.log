variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result {A B C D E F X O₁ O₂ : P}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C])
    (acuteAngled_ABC : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).AcuteAngled)
    (AC_lt_AB : dist A C < dist A B)
    (D_mem_interior_ABC : D ∈ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).interior)
    (angle_DAB_eq_angle_CAD : ∠ D A B = ∠ C A D) (wbtw_A_E_C : Wbtw ℝ A E C)
    (angle_ADE_eq_angle_BCD : ∠ A D E = ∠ B C D) (wbtw_A_F_B : Wbtw ℝ A F B)
    (angle_FDA_eq_angle_DBC : ∠ F D A = ∠ D B C) (X_mem_AC : X ∈ line[ℝ, A, C])
    (CX_eq_BX : dist C X = dist B X)
    (affineIndependent_ADC : AffineIndependent ℝ ![A, D, C])
    (O₁_eq_circumcenter_ADC : O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumcenter)
    (affineIndependent_EXD : AffineIndependent ℝ ![E, X, D])
    (O₂_eq_circumcenter_EXD : O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumcenter) :
    E ≠ F ∧ O₁ ≠ O₂ ∧ (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂] : Set P).Nonempty := by
  have hA_ne_B : A ≠ B := affineIndependent_ABC.injective.ne (by decide : (0 : Fin 3) ≠ 1)
  have hA_ne_C : A ≠ C := affineIndependent_ABC.injective.ne (by decide : (0 : Fin 3) ≠ 2)
  have hB_ne_C : B ≠ C := affineIndependent_ABC.injective.ne (by decide : (1 : Fin 3) ≠ 2)
  have hEF : E ≠ F := by
    intro h; subst h
    have hE_A : E = A := by
      have h_inter : E ∈ (line[ℝ, A, C] : Set P) ∩ (line[ℝ, A, B] : Set P) := ⟨wbtw_A_E_C.mem_affineSpan, wbtw_A_F_B.mem_affineSpan⟩
      have : (line[ℝ, A, C] : Set P) ∩ (line[ℝ, A, B] : Set P) = {A} :=
        AffineSubspace.inter_line_line_of_not_collinear (affineIndependent_iff_not_collinear.mp affineIndependent_ABC) hA_ne_C hA_ne_B
      rw [this] at h_inter; exact h_inter
    subst hE_A
    have hD_ne_A : D ≠ A := (Triangle.interior_subset_convexHull D_mem_interior_ABC).ne_points 0
    have h_angle : ∠ B C D = 0 := by rw [← angle_ADE_eq_angle_BCD, EuclideanGeometry.angle_self_of_ne hD_ne_A]
    have hD_BC : D ∈ line[ℝ, B, C] := by
      have h_coll := EuclideanGeometry.collinear_of_angle_eq_zero h_angle
      exact Collinear.mem_affineSpan_of_mem_of_ne h_coll (Set.mem_insert _ _) (Set.mem_insert_of_mem _ (Set.mem_singleton _)) hB_ne_C
    exact (⟨![A, B, C], affineIndependent_ABC⟩ : Triangle ℝ P).not_mem_line_of_mem_interior 0 D_mem_interior_ABC hD_BC
  have hO1O2 : O₁ ≠ O₂ := by
    intro h_eq
    let tADC : Simplex ℝ P 2 := ⟨![A, D, C], affineIndependent_ADC⟩
    let tEXD : Simplex ℝ P 2 := ⟨![E, X, D], affineIndependent_EXD⟩
    have h_rad : dist O₁ X = dist O₁ A := by
      rw [O₁_eq_circumcenter_ADC, O₂_eq_circumcenter_EXD] at h_eq
      rw [tEXD.dist_circumcenter_eq_circumradius 1, tEXD.dist_circumcenter_eq_circumradius 2, ← O₂_eq_circumcenter_EXD, ← h_eq, ← O₁_eq_circumcenter_ADC, tADC.dist_circumcenter_eq_circumradius 1, tADC.dist_circumcenter_eq_circumradius 0]
    have hX_mem : X = A ∨ X = C := by
      have h_dist_AC : dist O₁ A = dist O₁ C := by rw [O₁_eq_circumcenter_ADC, tADC.dist_circumcenter_eq_circumradius 0, tADC.dist_circumcenter_eq_circumradius 2]
      have hO1_not_line : ¬Collinear ℝ ({O₁, A, C} : Set P) := by
        rw [O₁_eq_circumcenter_ADC]; exact (affineIndependent_iff_not_collinear.mp affineIndependent_ADC).not_collinear 0 2 1 (by decide) (by decide) (by decide)
      exact EuclideanGeometry.eq_endpoints_of_dist_eq_dist_of_mem_line hA_ne_C h_dist_AC h_rad X_mem_AC
    rcases hX_mem with rfl | rfl
    · rw [dist_comm] at CX_eq_BX; exact AC_lt_AB.ne CX_eq_BX
    · rw [dist_self] at CX_eq_BX; exact hB_ne_C (dist_eq_zero.mp CX_eq_BX.symm)
  exact ⟨hEF, hO1O2, sorry⟩

