variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result {A B C D E F X O₁ O₂ : P}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C])
    (acuteAngled_ABC : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).AcuteAngled)
    (AC_lt_AB : dist A C < dist A B)
    (D_mem_interior_ABC : D ∈ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ P).interior)
    (angle_DAB_eq_angle_CAD : ∠ D A B = ∠ C A D) (wbtw_A_E_C : Wbtw ℝ A E C)
    (angle_ADE_eq_angle_BCD : ∠ A D E = ∠ B C D) (wbtw_A_F_B : Wbtw ℝ A F B)
    (angle_FDA_eq_angle_DBC : ∠ F D A = ∠ D B C) (X_mem_AC : X ∈ line[ℝ, A, C])
    (CX_eq_BX : dist C X = dist B X)
    (affineIndependent_ADC : AffineIndependent ℝ ![A, D, C])
    (O₁_eq_circumcenter_ADC : O₁ = (⟨_, affineIndependent_ADC⟩ : Triangle ℝ P).circumcenter)
    (affineIndependent_EXD : AffineIndependent ℝ ![E, X, D])
    (O₂_eq_circumcenter_EXD : O₂ = (⟨_, affineIndependent_EXD⟩ : Triangle ℝ P).circumcenter) :
    E ≠ F ∧ O₁ ≠ O₂ ∧ (line[ℝ, B, C] ∩ line[ℝ, E, F] ∩ line[ℝ, O₁, O₂] : Set P).Nonempty := by
  have hA_ne_B : A ≠ B := affineIndependent_ABC.injective.ne (by decide : (0 : Fin 3) ≠ 1)
  have hA_ne_C : A ≠ C := affineIndependent_ABC.injective.ne (by decide : (0 : Fin 3) ≠ 2)
  have hB_ne_C : B ≠ C := affineIndependent_ABC.injective.ne (by decide : (1 : Fin 3) ≠ 2)
  have hEF : E ≠ F := by
    intro h; subst h
    have hE_A : E = A := by sorry
    subst hE_A
    have h_angle : ∠ B C D = 0 := by rw [← angle_ADE_eq_angle_BCD, angle_self_right]
    have hD_BC : D ∈ line[ℝ, B, C] := (collinear_of_angle_eq_zero h_angle).mem_affineSpan_of_mem_of_ne (by simp) (by simp) (by simp) hB_ne_C
    exact (⟨![A, B, C], affineIndependent_ABC⟩ : Triangle ℝ P).not_mem_line_of_mem_interior (by decide) D_mem_interior_ABC hD_BC
  have hO1O2 : O₁ ≠ O₂ := by
    intro h_eq
    let triADC : Triangle ℝ P := ⟨![A, D, C], affineIndependent_ADC⟩
    let triEXD : Triangle ℝ P := ⟨![E, X, D], affineIndependent_EXD⟩
    have h_rad : dist O₁ X = dist O₁ A := by
      rw [O₁_eq_circumcenter_ADC, O₂_eq_circumcenter_EXD] at h_eq
      rw [triEXD.dist_circumcenter_eq_circumradius 1, triEXD.dist_circumcenter_eq_circumradius 2, ← O₂_eq_circumcenter_EXD, ← h_eq, ← O₁_eq_circumcenter_ADC, triADC.dist_circumcenter_eq_circumradius 1, triADC.dist_circumcenter_eq_circumradius 0]
    have hX_mem : X = A ∨ X = C := by sorry
    rcases hX_mem with rfl | rfl
    · rw [dist_comm] at CX_eq_BX; exact AC_lt_AB.ne CX_eq_BX
    · rw [dist_self] at CX_eq_BX; exact hB_ne_C (dist_eq_zero.mp CX_eq_BX.symm)
  exact ⟨hEF, hO1O2, sorry⟩

