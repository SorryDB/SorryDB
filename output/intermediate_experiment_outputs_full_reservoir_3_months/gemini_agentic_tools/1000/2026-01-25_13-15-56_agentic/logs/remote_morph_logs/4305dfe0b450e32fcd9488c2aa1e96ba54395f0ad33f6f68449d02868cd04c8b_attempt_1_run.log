  have hA_ne_B : A ≠ B := affineIndependent_ABC.injective.ne (by decide : (0 : Fin 3) ≠ 1)
  have hA_ne_C : A ≠ C := affineIndependent_ABC.injective.ne (by decide : (0 : Fin 3) ≠ 2)
  have hB_ne_C : B ≠ C := affineIndependent_ABC.injective.ne (by decide : (1 : Fin 3) ≠ 2)
  have hEF : E ≠ F := by
    intro h; subst h
    have hE_A : E = A := by
      have h_mem : E ∈ (line[ℝ, A, C] : Set P) ∩ (line[ℝ, A, B] : Set P) := ⟨wbtw_A_E_C.mem_affineSpan, wbtw_A_F_B.mem_affineSpan⟩
      have h_inter : (line[ℝ, A, C] : Set P) ∩ (line[ℝ, A, B] : Set P) = {A} :=
        EuclideanGeometry.inter_line_line_eq_singleton_of_not_collinear hA_ne_C hA_ne_B (affineIndependent_iff_not_collinear.mp affineIndependent_ABC)
