  have hA_ne_C : A ≠ C := affineIndependent_ABC.injective.ne (by decide : (0 : Fin 3) ≠ 2)
  have hB_ne_C : B ≠ C := affineIndependent_ABC.injective.ne (by decide : (1 : Fin 3) ≠ 2)
  have hA_ne_D : A ≠ D := by
    intro h; subst h
    exact (Simplex.not_mem_boundary_of_mem_interior D_mem_interior_ABC) (Simplex.subset_convexHull _ (by simp))
  have hEF : E ≠ F := by
    intro h; subst h
    have hE_A : E = A := by
      have h_line : (line[ℝ, A, C] ∩ line[ℝ, A, B] : Set P) = {A} :=
        AffineSubspace.inter_line_line_eq_singleton_of_not_collinear (affineIndependent_iff_not_collinear.mp affineIndependent_ABC) hA_ne_C hA_ne_B
      exact Set.mem_singleton_iff.mp (h_line ▸ ⟨wbtw_A_E_C.mem_affineSpan, wbtw_A_F_B.mem_affineSpan⟩)
