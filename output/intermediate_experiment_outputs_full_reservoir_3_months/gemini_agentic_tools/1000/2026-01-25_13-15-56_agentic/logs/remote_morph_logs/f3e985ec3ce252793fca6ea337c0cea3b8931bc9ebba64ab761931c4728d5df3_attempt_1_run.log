open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f (T : Finset ℕ) : ℕ := ∑ x ∈ T, x
  have hf : ∀ T ∈ S.powerset, f T ∈ Finset.Icc 0 990 := by
    intro T hT
    rw [Finset.mem_powerset] at hT
    simp only [Finset.mem_Icc, zero_le, true_and]
    calc ∑ x ∈ T, x ≤ ∑ _x ∈ T, 99 := Finset.sum_le_sum (fun x hx ↦ Nat.lt_succ_iff.1 (Finset.mem_Ico.1 (h₁ (hT hx))).2)
         _ = T.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
         _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 ((Finset.card_le_of_subset hT).trans h₀.symm.le)
         _ = 990 := rfl
  have h_card : (Finset.Icc 0 990).card < S.powerset.card := by
    rw [Finset.card_Icc, Finset.card_powerset, h₀]; norm_num
  obtain ⟨A, hA, B, hB, hne, hfAB⟩ := Finset.exists_ne_map_eq_of_card_lt_card f hf h_card
  let S₁ := A \ B
  let S₂ := B \ A
  use S₁, S₂
  have hS1S : S₁ ⊆ S := (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA)
  have hS2S : S₂ ⊆ S := (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB)
  have hsum : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    have hA' := Finset.sum_sdiff_add_sum_inter A B
    have hB' := Finset.sum_sdiff_add_sum_inter B A
    linarith [hfAB, hA', hB', Finset.inter_comm A B]
  have hS1n : S₁.Nonempty := by
    by_contra h
    have hS1e : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.1 h
    have hS2e : S₂ = ∅ := by
      contrapose! hsum
      obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.2 hsum
      rw [hS1e, Finset.sum_empty]
      apply ne_of_gt
      apply Finset.sum_pos (fun y hy ↦ (by norm_num : 0 < 10).trans_le (Finset.mem_Ico.1 (h₁ (hS2S hy))).1) ⟨x, hx⟩
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS1e) (Finset.sdiff_eq_empty_iff_subset.1 hS2e))
  have hS2n : S₂.Nonempty := by
    by_contra h
    have hS2e : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.1 h
    have hS1e : S₁ = ∅ := by
      contrapose! hsum
      obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.2 hsum
      rw [hS2e, Finset.sum_empty, eq_comm]
      apply ne_of_gt
      apply Finset.sum_pos (fun y hy ↦ (by norm_num : 0 < 10).trans_le (Finset.mem_Ico.1 (h₁ (hS1S hy))).1) ⟨x, hx⟩
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS1e) (Finset.sdiff_eq_empty_iff_subset.1 hS2e))
  exact ⟨hS1n, hS1S, hS2n, hS2S, Finset.disjoint_sdiff_sdiff, hsum⟩

