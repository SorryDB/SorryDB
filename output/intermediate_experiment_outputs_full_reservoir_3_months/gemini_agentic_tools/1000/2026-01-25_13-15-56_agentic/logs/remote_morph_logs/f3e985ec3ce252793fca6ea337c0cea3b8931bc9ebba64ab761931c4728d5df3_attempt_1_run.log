import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f (T : Finset ℕ) := ∑ x in T, x
  have hf : ∀ T ∈ S.powerset, f T ∈ Finset.Icc 0 990 := by
    intro T hT
    simp only [Finset.mem_Icc, zero_le, true_and]
    refine (Finset.sum_le_card_nsmul T 99 (fun x hx ↦ ?_)).trans ?_
    · exact Nat.lt_succ_iff.1 (Finset.mem_Ico.1 (h₁ (Finset.mem_powerset.1 hT hx))).2
    · rw [Nat.nsmul_eq_mul, ← h₀]
      exact Nat.mul_le_mul_right 99 (Finset.card_le_of_subset (Finset.mem_powerset.1 hT))
  have h_card : (Finset.Icc 0 990).card < S.powerset.card := by
    rw [Finset.card_Icc, Finset.card_powerset, h₀]; norm_num
  obtain ⟨A, hA, B, hB, hne, hfAB⟩ := Finset.exists_ne_map_eq_of_card_lt_card f hf h_card
  let S₁ := A \ B
  let S₂ := B \ A
  use S₁, S₂
  have hS1S : S₁ ⊆ S := (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA)
  have hS2S : S₂ ⊆ S := (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB)
  have hsum : ∑ x in S₁, x = ∑ x in S₂, x := by
    have hA' := Finset.sum_sdiff_add_sum_inter A B
    have hB' := Finset.sum_sdiff_add_sum_inter B A
    rwa [Finset.inter_comm, ← hB', hfAB, add_left_inj] at hA'
  have hS1n : S₁.Nonempty := by
    by_contra h; rw [Finset.not_nonempty_iff_eq_empty] at h
    have hS2e : S₂ = ∅ := Finset.eq_empty_iff_forall_not_mem.2 (fun x hx ↦
      (Finset.mem_Ico.1 (h₁ (hS2S hx))).1.ne_bot (Finset.sum_eq_zero_iff.1 (by rwa [h, Finset.sum_empty] at hsum) x hx))
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 h) (Finset.sdiff_eq_empty_iff_subset.1 hS2e))
  have hS2n : S₂.Nonempty := by
    by_contra h; rw [Finset.not_nonempty_iff_eq_empty] at h
    have hS1e : S₁ = ∅ := Finset.eq_empty_iff_forall_not_mem.2 (fun x hx ↦
      (Finset.mem_Ico.1 (h₁ (hS1S hx))).1.ne_bot (Finset.sum_eq_zero_iff.1 (by rwa [h, Finset.sum_empty] at hsum.symm) x hx))
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS1e) (Finset.sdiff_eq_empty_iff_subset.1 h))
  exact ⟨hS1n, hS1S, hS2n, hS2S, Finset.disjoint_sdiff_sdiff, hsum⟩

