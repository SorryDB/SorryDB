import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f (T : Finset ℕ) : ℕ := ∑ x ∈ T, x
  have hf : ∀ T ∈ S.powerset, f T ∈ Finset.Icc 0 990 := by
    intro T hT
    simp only [Finset.mem_Icc, zero_le, true_and]
    have hTS : T ⊆ S := Finset.mem_powerset.1 hT
    calc ∑ x ∈ T, x ≤ ∑ _x ∈ T, 99 := Finset.sum_le_sum (fun x hx ↦ Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (hTS hx))).2)
         _ = T.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
         _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 ((Finset.card_le_card hTS).trans h₀.le)
         _ = 990 := rfl
  have h_card : (Finset.Icc 0 990).card < S.powerset.card := by
    rw [Finset.card_powerset, h₀, Nat.card_Icc]
    norm_num
  obtain ⟨A, hA, B, hB, hne, hfAB⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_card hf
  let S₁ := A \ B
  let S₂ := B \ A
  have hAS : A ⊆ S := Finset.mem_powerset.1 hA
  have hBS : B ⊆ S := Finset.mem_powerset.1 hB
  have hS1S : S₁ ⊆ S := (Finset.sdiff_subset A B).trans hAS
  have hS2S : S₂ ⊆ S := (Finset.sdiff_subset B A).trans hBS
  have hsum : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    have hA' : f A = f S₁ + f (A ∩ B) := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter A B), Finset.sdiff_union_inter]
    have hB' : f B = f S₂ + f (B ∩ A) := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter B A), Finset.sdiff_union_inter]
    rw [Finset.inter_comm] at hB'
    linarith [hfAB]
  have hS1n : S₁.Nonempty := by
    by_contra h
    have hS1e : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.1 h
    have hS2e : S₂ = ∅ := by
      rw [hS1e, Finset.sum_empty] at hsum
      refine Finset.eq_empty_iff_forall_not_mem.2 (fun x hx ↦ ?_)
      have hx0 : x = 0 := Finset.sum_eq_zero_iff.1 hsum.symm x hx
      have hx10 : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hS2S hx))).1
      linarith
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS1e) (Finset.sdiff_eq_empty_iff_subset.1 hS2e))
  have hS2n : S₂.Nonempty := by
    by_contra h
    have hS2e : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.1 h
    have hS1e : S₁ = ∅ := by
      rw [hS2e, Finset.sum_empty] at hsum
      refine Finset.eq_empty_iff_forall_not_mem.2 (fun x hx ↦ ?_)
      have hx0 : x = 0 := Finset.sum_eq_zero_iff.1 hsum x hx
      have hx10 : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hS1S hx))).1
      linarith
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS1e) (Finset.sdiff_eq_empty_iff_subset.1 hS2e))
  have hdisj : Disjoint S₁ S₂ := Finset.disjoint_left.2 (fun x hx hx' ↦ (Finset.mem_sdiff.1 hx).2 (Finset.mem_sdiff.1 hx').1)
  exact ⟨hS1n, hS1S, hS2n, hS2S, hdisj, hsum⟩

