lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra hφψ;
  replace ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφψ;
  have h_not_T : ∀ i Δ, ↑Δ ⊆ construction T hT i → Δ.conj ➝ ξ ∉ T.theory := by
    intro i; induction i with
    | zero =>
      intro Δ hΔ h; apply hT;
      have : χ ➝ Δ.conj ∈ T.theory := by
        induction Δ using Finset.induction_on with
        | empty => apply T.mem_of_provable; simp;
        | insert a Δ ih =>
          simp at hΔ; apply T.imp_closed (φ := (χ ➝ a) ⋏ (χ ➝ Δ.conj)) (by grind) (T.andIR hΔ.1 (ih hΔ.2));
      apply T.imp_closed (φ := Δ.conj ➝ ξ) (by grind) h; exact this;
    | succ i ih =>
      intro Δ hΔ h; dsimp [construction] at hΔ; split at hΔ;
      . rename_i δ hδ; split_ifs at hΔ with hcond;
        . by_cases hδΔ : δ ∈ Δ;
          . apply hcond (Δ.erase δ) (by intro x hx; apply hΔ; simp; apply Finset.mem_of_mem_erase hx);
            apply T.imp_closed (φ := Δ.conj) (by induction Δ using Finset.induction_on <;> grind) h;
          . apply ih Δ (by intro x hx; have := hΔ hx; simp at this; rcases this with (rfl|hx') <;> [contradiction, exact hx']) h;
        . exact ih hΔ h;
      . exact ih hΔ h;
  obtain ⟨i, hi⟩ := by simpa [construction_omega] using hφ;
  obtain ⟨j, hj⟩ := by simpa [construction_omega] using hψ;
  apply h_not_T (max i (max j (encode (φ ⋏ ψ)))) (insert φ (insert ψ Γ));
  . intro x hx; simp at hx; rcases hx with (rfl|rfl|hx) <;> (apply monotone_construction (by simp); assumption <;> assumption <;> apply hΓ₁; assumption);
  . apply T.imp_closed (φ := Γ.conj ⋏ (φ ⋏ ψ)) (by induction Γ using Finset.induction_on <;> grind) hΓ₂;
```
