lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra hφψ;
  replace ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφψ;
  have h_cons : ∀ m Δ, ↑Δ ⊆ construction T hT m → Δ.conj ➝ ξ ∈ T.theory → False := by
    intro m; induction m with
    | zero =>
      intro Δ hΔ h; apply hT;
      have h1 : χ ➝ Δ.conj ∈ T.theory := by
        induction Δ using Finset.induction_on with
        | empty => apply T.mem_of_provable; apply Logic.iff_provable.mp; simp
        | insert a Δ' ih_Δ =>
          apply T.imp_closed (φ := (χ ➝ a) ⋏ (χ ➝ Δ'.conj)) (by apply Logic.iff_provable.mp; simp) (T.andIR (hΔ (by simp)) (ih_Δ (by intro x hx; apply hΔ; simp [hx])));
      exact T.mem_trans h1 h;
    | succ m ih_m =>
      intro Δ hΔ h; dsimp [construction] at hΔ; split at hΔ;
      . rename_i δ hδ; split_ifs at hΔ with hcond;
        . by_cases hδΔ : δ ∈ Δ;
          . apply hcond (Δ.erase δ) (by
              intro x hx; have := hΔ (Finset.mem_of_mem_erase hx); simp at this; rcases this with (rfl | hx') <;> [exact (Finset.not_mem_erase _ _ hx).elim, exact hx'])
            apply T.imp_closed (φ := Δ.conj ➝ ξ) (by apply Logic.iff_provable.mp; simp) h;
          . apply ih_m Δ (by
              intro x hx; have := hΔ hx; simp at this; rcases this with (rfl | hx') <;> [contradiction, exact hx']) h;
      . exact ih_m Δ hΔ h;
  obtain ⟨i, hi⟩ := by simpa [construction_omega] using hφ;
  obtain ⟨j, hj⟩ := by simpa [construction_omega] using hψ;
  let k := max i (max j (encode (φ ⋏ ψ)));
  apply h_cons k (insert φ (insert ψ Γ));
  . intro x hx; simp at hx; rcases hx with (rfl | rfl | hx);
    . apply monotone_construction (by simp) hi;
    . apply monotone_construction (by simp) hj;
    . apply monotone_construction (by simp) hΓ₁; exact hx;
  . apply T.imp_closed (φ := Γ.conj ⋏ φ ⋏ ψ ➝ ξ) (by apply Logic.iff_provable.mp; simp) hΓ₂;
```
