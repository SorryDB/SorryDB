lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra! hC;
  obtain ⟨hφ, hψ⟩ := hC;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφ;
  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;

  let m := max (encode φ) (encode ψ);
  have hthis_subset : ↑(Γ ∪ Δ) ⊆ construction T hT m := by
    intro x hx; simp at hx;
    cases hx with
    | inl hx => apply monotone_construction (le_max_left _ _) (hΓ₁ hx);
    | inr hx => apply monotone_construction (le_max_right _ _) (hΔ₁ hx);
  have hthis_theory : ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) ➝ ξ ∈ T.theory := by
    apply T.imp_closed (φ := (Γ.conj ⋏ φ ➝ ξ) ⋏ (Δ.conj ⋏ ψ ➝ ξ));
    . apply Logic.iff_provable.mp; simp;
    . apply T.andIR hΓ₂ hΔ₂;

  let Φ := (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)
  have hΦ : Φ ∈ construction_omega T hT := by
    have h_conj_U : ∀ {Ω : Finset (Formula ℕ)}, (∀ x ∈ Ω, x ∈ construction_omega T hT) → Ω.conj ∈ construction_omega T hT := by
      intro Ω hΩ; induction Ω using Finset.induction_on
      case empty => apply construction_omega_L_subset; apply Logic.iff_provable.mp; simp
      case insert a s ih =>
        rw [Finset.conj_insert]; apply construction_omega_andClosed
        . apply hΩ; simp
        . apply ih; intro x hx; apply hΩ; simp [hx]
    apply construction_omega_andClosed
    . apply construction_omega_andClosed
      . apply h_conj_U; intro x hx; exact Set.mem_iUnion_of_mem m (hthis_subset (by simp [hx]))
      . apply h_conj_U; intro x hx; exact Set.mem_iUnion_of_mem m (hthis_subset (by simp [hx]))
    . exact hφψ

  rcases of_mem_construction_omega hΦ with h | h
  . exact hT (T.mem_trans h hthis_theory)
  . apply h ∅ (by simp)
    apply T.imp_closed (Logic.iff_provable.mp (by simp)) hthis_theory
