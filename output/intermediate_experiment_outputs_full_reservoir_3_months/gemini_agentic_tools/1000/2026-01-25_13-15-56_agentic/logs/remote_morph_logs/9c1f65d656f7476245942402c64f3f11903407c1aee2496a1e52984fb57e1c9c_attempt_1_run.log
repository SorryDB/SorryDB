lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra! hC;
  obtain ⟨hφ, hψ⟩ := hC;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφ;
  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;

  let m := max (encode φ) (encode ψ);
  have : ↑(Γ ∪ Δ) ⊆ construction T hT m := by
    intro x hx;
    simp at hx;
    cases hx with
    | inl hx => apply monotone_construction (le_max_left _ _) (hΓ₁ hx);
    | inr hx => apply monotone_construction (le_max_right _ _) (hΔ₁ hx);
  have : ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) ➝ ξ ∈ T.theory := by
    apply T.imp_closed ?_ $ T.andIR hΓ₂ hΔ₂;
    apply Logic.iff_provable.mpr;
    simp;
  have hTU : T.theory ⊆ construction_omega T hT := fun _ h => mem_omega_of_mem (T.imp_closed axiomI h);
  have h_conj {Ω : Finset (Formula ℕ)} (hΩ : ↑Ω ⊆ construction_omega T hT) : Ω.conj ∈ construction_omega T hT := by
    induction Ω using Finset.induction_on;
    . apply construction_omega_L_subset; apply Logic.iff_provable.mp; simp;
    . simp; apply construction_omega_andClosed;
      . apply hΩ; simp;
      . apply ih; intro x hx; apply hΩ; simp [hx];
  have h_all : (Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ) ∈ construction_omega T hT :=
    construction_omega_andClosed (construction_omega_andClosed
      (h_conj (by intro x hx; apply Set.mem_iUnion_of_mem (encode φ); exact hΓ₁ hx))
      (h_conj (by intro x hx; apply Set.mem_iUnion_of_mem (encode ψ); exact hΔ₁ hx))) hφψ;
  have h_xi : ξ ∈ construction_omega T hT :=
    construction_omega_impClosed (Logic.iff_provable.mpr $ by simp)
      (construction_omega_andClosed (hTU this) h_all);
  exact construction_omega_not_mem_csq h_xi
```
