      refine ⟨by simp [hc, lt_inf'_iff], Finset.sum_pos (fun i _ => hd i) hι, fun x => ⟨?_, ?_⟩⟩
      · obtain ⟨i₀, -, hx₀⟩ := univ.exists_max_image (fun i => ‖x i‖) hι
        have hx : ‖x‖ = ‖x i₀‖ := le_antisymm (univ.sup_le fun i _ => hx₀ i) (Pi.norm_le_norm x i₀)
        rw [re_sum, hx]
        apply le_trans _ (single_le_sum (fun i _ => inner_self_nonneg) (mem_univ i₀))
        apply le_trans _ (h i₀ (x i₀)).1
        exact mul_le_mul_of_nonneg_right (Finset.inf'_le _ (mem_univ i₀)) (pow_nonneg (norm_nonneg _) _)
      · rw [re_sum]
        apply le_trans (sum_le_sum fun i _ => (h i (x i)).2)
        rw [← sum_mul]
        apply sum_le_sum; intro i _
        apply mul_le_mul_of_nonneg_left (pow_le_pow_left (norm_nonneg _) (Pi.norm_le_norm x i) 2) (hd i).le
