import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, (by norm_num)
  intros n hn S hSn hS_dist
  have hS_nonempty : S.Nonempty := by rw [← Finset.card_pos]; exact Nat.lt_trans (by norm_num) hn
  let P_set := (S : Set P)
  let e := (Fact.out (p := finrank ℝ V = 2)).select_equiv
  have : ∃ (v : V) (t : ℝ), ‖v‖ = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ inner v (p₁ -ᵥ S.centroid ℝ) < t ∧ t < inner v (p₂ -ᵥ S.centroid ℝ)) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner v (p -ᵥ S.centroid ℝ) - t| := by
    set d := (n : ℝ) ^ (-1 / 3 : ℝ)
    let directions := {v : V | ‖v‖ = 1}
    let bad_directions (v : V) (t : ℝ) := ∃ p ∈ S, |inner v (p -ᵥ S.centroid ℝ) - t| < c * d
    obtain ⟨v, hv, t, h_sep, h_far⟩ : ∃ (v : V) (t : ℝ), ‖v‖ = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ inner v (p₁ -ᵥ S.centroid ℝ) < t ∧ t < inner v (p₂ -ᵥ S.centroid ℝ)) ∧
      ∀ p ∈ S, c * d ≤ |inner v (p -ᵥ S.centroid ℝ) - t| := by
      let f (v : V) := (S.image (fun p ↦ inner v (p -ᵥ S.centroid ℝ))).sort (· ≤ ·)
      have : ∃ v : V, ‖v‖ = 1 ∧ ∃ i < n - 1, (f v).get ⟨i + 1, by sorry⟩ - (f v).get ⟨i, by sorry⟩ ≥ 2 * c * d := by
        sorry
      obtain ⟨v, hv, i, hi, hgap⟩ := this
      let t := ((f v).get ⟨i, by sorry⟩ + (f v).get ⟨i+1, by sorry⟩) / 2
      use v, t, hv
      refine ⟨?_, ?_⟩
      · obtain ⟨p₁, hp₁, hf₁⟩ := Finset.mem_image.1 (List.get_mem _ _ _)
        obtain ⟨p₂, hp₂, hf₂⟩ := Finset.mem_image.1 (List.get_mem _ _ _)
        use p₁, p₂, hp₁, hp₂
        rw [hf₁, hf₂]
        constructor <;> linarith
      · intro p hp
        have hp_in : inner v (p -ᵥ S.centroid ℝ) ∈ f v := Finset.mem_image.2 ⟨p, hp, rfl⟩
        obtain ⟨j, hj, h_val⟩ := List.mem_iff_get.1 hp_in
        rw [← h_val]
        by_cases hji : j ≤ i
        · have : (f v).get ⟨j, hj⟩ ≤ (f v).get ⟨i, by sorry⟩ := List.Sorted.rel_get (List.sorted_sort (· ≤ ·) _) hji
          linarith
        · have : (f v).get ⟨i + 1, by sorry⟩ ≤ (f v).get ⟨j, hj⟩ := List.Sorted.rel_get (List.sorted_sort (· ≤ ·) _) (by linarith)
          linarith
    exact ⟨v, t, hv, h_sep, h_far⟩
  obtain ⟨v, t, hv, h_sep, h_far⟩ := this
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (S.centroid ℝ +ᵥ t • v) (ℝ ∙ v)ᗮ
  use l
  refine ⟨?_, ?_, ?_⟩
  · rw [AffineSubspace.direction_mk', Submodule.finrank_orthogonal, Submodule.finrank_span_singleton hv.ne_zero, Fact.out]
    norm_num
  · obtain ⟨p₁, p₂, hp₁, hp₂, h_sep1, h_sep2⟩ := h_sep
    use p₁, p₂, hp₁, hp₂
    rw [AffineSubspace.sOppSide_iff_side_sgn_eq_neg, AffineSubspace.side_sgn, AffineSubspace.side_sgn]
    have h_norm : ‖v‖ = 1 := hv
    have : ∀ p, (l.side (p : P)) = inner v (p -ᵥ (S.centroid ℝ +ᵥ t • v)) := by
      intro p; rw [AffineSubspace.side_mk', inner_comm, inner_sub_left, inner_smul_right, hv, mul_one]
    rw [this, this, v_sub_v_add_eq_v_sub_v_sub, v_sub_v_add_eq_v_sub_v_sub]
    rw [inner_sub_left, inner_sub_left, SignType.neg_iff, mul_neg_iff]
    left; constructor <;> apply Real.sign_eq_of_neg <;> linarith
  · intro p hp
    have h_infDist : Metric.infDist p l = |inner v (p -ᵥ (S.centroid ℝ +ᵥ t • v))| := by
      rw [Metric.infDist_eq_dist_orthogonalProjection, EuclideanGeometry.dist_orthogonalProjection_mk']
      simp [hv]
    rw [h_infDist, inner_sub_left, inner_smul_right, hv, mul_one, ← v_sub_v_add_eq_v_sub_v_sub, inner_sub_left]
    exact h_far p hp
