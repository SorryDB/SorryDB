import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, (by norm_num)
  intros n hn S hSn hS_dist
  have hSn_pos : 0 < (n : ℝ) := by rw [hSn]; linarith
  have hS_non : S.Nonempty := by rw [← Finset.card_pos, hSn]; linarith
  obtain ⟨p0, _hp0⟩ := hS_non
  have h_fin : finrank ℝ V = 2 := Fact.out
  haveI : FiniteDimensional ℝ V := .of_finrank_pos (by linarith [h_fin])
  obtain ⟨v, hv, t, h_sep, h_far⟩ : ∃ v : V, ‖v‖ = 1 ∧ ∃ t : ℝ,
    (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ inner (p₁ -ᵥ p0) v < t ∧ t < inner (p₂ -ᵥ p0) v) ∧
    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner (p -ᵥ p0) v - t| := by
    sorry
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (t • v +ᵥ p0) (Submodule.span ℝ {v})ᗮ
  use l
  constructor
  · rw [AffineSubspace.direction_mk']
    have h_orth := Submodule.finrank_add_finrank_orthogonal (Submodule.span ℝ {v})
    have h_v : v ≠ 0 := by
      intro h_zero
      rw [h_zero, norm_zero] at hv
      linarith
    rw [finrank_span_singleton h_v, h_fin] at h_orth
    linarith
  · constructor
    · obtain ⟨p₁, p₂, hp₁, hp₂, h1, h2⟩ := h_sep
      use p₁, p₂, hp₁, hp₂
      let r := (t - inner (p₁ -ᵥ p0) v) / (inner (p₂ -ᵥ p0) v - inner (p₁ -ᵥ p0) v)
      have h_den : 0 < inner (p₂ -ᵥ p0) v - inner (p₁ -ᵥ p0) v := by linarith
      have hr0 : 0 < r := div_pos (by linarith) h_den
      have hr1 : r < 1 := (div_lt_one h_den).mpr (by linarith)
      let p := r • (p₂ -ᵥ p₁) +ᵥ p₁
      have hps : Sbtw ℝ p₁ p p₂ := sbtw_iff_vadd_vsub_smul.mpr ⟨r, hr0, hr1, rfl⟩
      have hpl : p ∈ l := by
        rw [AffineSubspace.mem_mk', Submodule.mem_orthogonal_singleton_iff_inner_right_eq_zero]
        rw [vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_right, ← real_inner_self_eq_norm_sq, hv, one_pow, mul_one, sub_eq_zero]
        rw [vadd_vsub_assoc, inner_add_left, inner_smul_left, inner_sub_left, inner_comm (p₂ -ᵥ p0) v, inner_comm (p₁ -ᵥ p0) v]
        field_simp [h_den.ne']
        ring
      exact ⟨p, hpl, hps⟩
    · intro p hp
      haveI : Nonempty l := ⟨t • v +ᵥ p0, (AffineSubspace.mem_mk' _ _).mpr (vsub_self _ ▸ Submodule.zero_mem _)⟩
      rw [Metric.infDist_eq_dist_orthogonalProjection p (inferInstance : Nonempty l), dist_eq_norm_vsub V]
      set p_proj := orthogonalProjection l p
      have : p -ᵥ p_proj ∈ (Submodule.span ℝ {v}) := by
        rw [← Submodule.orthogonal_orthogonal (Submodule.span ℝ {v}), ← AffineSubspace.direction_mk' (t • v +ᵥ p0)]
        exact EuclideanGeometry.vsub_orthogonalProjection_mem_direction_orthogonal l p
      obtain ⟨r, hr⟩ := Submodule.mem_span_singleton.mp this
      rw [hr, norm_smul, hv, mul_one, Real.norm_eq_abs]
      have h_orth : inner (p_proj -ᵥ (t • v +ᵥ p0)) v = 0 := by
        rw [← Submodule.mem_orthogonal_singleton_iff_inner_right_eq_zero, ← AffineSubspace.direction_mk' (t • v +ᵥ p0)]
        exact AffineSubspace.vsub_mem_direction (orthogonalProjection l p) (by
          exact (AffineSubspace.mem_mk' (t • v +ᵥ p0) (Submodule.span ℝ {v})ᗮ).mpr (vsub_self _ ▸ Submodule.zero_mem _))
      have : r = inner (p -ᵥ (t • v +ᵥ p0)) v := by
        rw [← vsub_sub_vsub_cancel_right p p_proj (t • v +ᵥ p0), inner_sub_left, hr, inner_smul_left, ← real_inner_self_eq_norm_sq, hv, one_pow, mul_one, h_orth, sub_zero]
      rw [this, vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_right, ← real_inner_self_eq_norm_sq, hv, one_pow, mul_one, inner_comm (p -ᵥ p0) v]
      exact h_far p hp

