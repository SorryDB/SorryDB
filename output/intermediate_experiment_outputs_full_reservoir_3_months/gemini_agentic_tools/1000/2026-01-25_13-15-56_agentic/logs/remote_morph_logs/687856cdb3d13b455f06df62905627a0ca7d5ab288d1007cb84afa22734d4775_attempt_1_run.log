import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, (by norm_num)
  intros n hn S hSn hS_dist
  have hS_non : S.Nonempty := by
    rw [← Finset.card_pos, hSn]
    exact Nat.lt_trans (by norm_num) hn
  let p0 := hS_non.some
  obtain ⟨v, hv, t, h_sep, h_far⟩ : ∃ v : V, ‖v‖ = 1 ∧ ∃ t : ℝ,
    (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ inner v (p₁ -ᵥ p0) < t ∧ t < inner v (p₂ -ᵥ p0)) ∧
    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner v (p -ᵥ p0) - t| := by
    sorry
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (p0 +ᵥ t • v) (Submodule.span ℝ {v})ᗮ
  use l
  haveI : FiniteDimensional ℝ V := .of_finrank_pos (Fact.out.symm ▸ zero_lt_two)
  constructor
  · rw [AffineSubspace.direction_mk', Submodule.finrank_orthogonal,
      Submodule.finrank_span_singleton (by linarith [hv] : v ≠ 0), Fact.out]
    norm_num
  · constructor
    · obtain ⟨p₁, p₂, hp₁, hp₂, h1, h2⟩ := h_sep
      use p₁, p₂, hp₁, hp₂
      have h_side (p : P) : (inner v (p -ᵥ p0) - t) = inner v (p -ᵥ (p0 +ᵥ t • v)) := by
        rw [vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_right, hv, mul_one]
      have : (l : Set P) = {p | inner v (p -ᵥ (p0 +ᵥ t • v)) = 0} := by
        ext p; rw [AffineSubspace.mem_mk', Submodule.mem_orthogonal_singleton_iff_inner_left_eq_zero, inner_comm]
      let f : P →ᵃ[ℝ] ℝ := AffineMap.mk' (InnerProductSpace.toDual ℝ V v).toLinearMap (p0 +ᵥ t • v)
      have hf (p : P) : f p = inner v (p -ᵥ (p0 +ᵥ t • v)) := by
        rw [AffineMap.mk'_apply, ContinuousLinearMap.coe_coe, InnerProductSpace.toDual_apply]
      apply AffineSubspace.sOppSide_iff_exists_left_right.mpr
      refine ⟨f, ?_, ?_, ?_⟩
      · rw [hf, ← h_side]; linarith
      · rw [hf, ← h_side]; linarith
      · ext p; rw [this, Set.mem_setOf_eq, hf]
    · intro p hp
      have h_dist : Metric.infDist p (l : Set P) = |inner v (p -ᵥ (p0 +ᵥ t • v))| := by
        rw [Metric.infDist_eq_dist_orthogonalProjection, EuclideanGeometry.dist_orthogonalProjection_mk', hv, div_one]
        congr
      rw [h_dist, vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_right, hv, mul_one]
      exact h_far p hp

