import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, (by norm_num)
  intros n hn S hSn hS_dist
  have hS_non : S.Nonempty := by
    rw [← Finset.card_pos, hSn]
    linarith
  obtain ⟨p0, _hp0⟩ := hS_non
  have h_fin : finrank ℝ V = 2 := Fact.out
  haveI : FiniteDimensional ℝ V := .of_finrank_pos (by linarith [h_fin])
  obtain ⟨v, hv, t, h_sep, h_far⟩ : ∃ v : V, ‖v‖ = 1 ∧ ∃ t : ℝ,
    (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ ⟪v, p₁ -ᵥ p0⟫ < t ∧ t < ⟪v, p₂ -ᵥ p0⟫) ∧
    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |⟪v, p -ᵥ p0⟫ - t| := by
    sorry
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (p0 +ᵥ t • v) (Submodule.span ℝ {v})ᗮ
  use l
  constructor
  · rw [AffineSubspace.direction_mk']
    have h_orth := Submodule.finrank_add_finrank_orthogonal (Submodule.span ℝ {v})
    rw [finrank_span_singleton (by linarith [hv] : v ≠ 0), h_fin] at h_orth
    linarith
  · constructor
    · obtain ⟨p₁, p₂, hp₁, hp₂, h_sep1, h_sep2⟩ := h_sep
      use p₁, p₂, hp₁, hp₂
      let r := (t - ⟪v, p₁ -ᵥ p0⟫) / (⟪v, p₂ -ᵥ p0⟫ - ⟪v, p₁ -ᵥ p0⟫)
      have h_den : ⟪v, p₂ -ᵥ p0⟫ - ⟪v, p₁ -ᵥ p0⟫ ≠ 0 := by linarith
      let p := r • (p₂ -ᵥ p₁) +ᵥ p₁
      have hr : 0 < r ∧ r < 1 := ⟨div_pos (by linarith) (by linarith), (div_lt_one (by linarith)).mpr (by linarith)⟩
      use p
      constructor
      · rw [AffineSubspace.mem_mk', Submodule.mem_orthogonal_singleton_iff_inner_right_eq_zero, inner_comm]
        rw [vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_right, hv, mul_one, sub_eq_zero]
        rw [vadd_vsub_assoc, inner_add_left, inner_smul_left, inner_sub_left]
        rw [vsub_sub_vsub_cancel_right, inner_sub_right, inner_comm v (p₂ -ᵥ p0), inner_comm v (p₁ -ᵥ p0)]
        field_simp [h_den]
        ring
      · exact sbtw_iff_vadd_vsub_smul.mpr ⟨r, hr, rfl⟩
    · intro p hp
      have h_dist : Metric.infDist p l = |⟪v, p -ᵥ (p0 +ᵥ t • v)⟫| := by
        haveI : Nonempty l := ⟨p0 +ᵥ t • v, (AffineSubspace.mem_mk' _ _).mpr (vsub_self _ ▸ Submodule.zero_mem _)⟩
        rw [EuclideanGeometry.dist_orthogonalProjection_eq_infDist p l]
        rw [EuclideanGeometry.dist_orthogonalProjection_mk' hv]
      rw [h_dist, vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_right, hv, mul_one]
      exact h_far p hp
