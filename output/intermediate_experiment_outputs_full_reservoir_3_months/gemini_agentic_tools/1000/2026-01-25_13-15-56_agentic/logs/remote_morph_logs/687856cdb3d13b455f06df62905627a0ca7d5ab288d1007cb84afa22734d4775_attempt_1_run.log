    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner v (p -ᵥ S.centroid ℝ) - t| := by
    sorry
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (S.centroid ℝ +ᵥ t • v) (ℝ ∙ v)ᗮ
  use l
  constructor
  · rw [AffineSubspace.direction_mk', Submodule.finrank_orthogonal,
      Submodule.finrank_span_singleton hv.ne_zero, Fact.out]
    norm_num
  · constructor
    · obtain ⟨p₁, p₂, hp₁, hp₂, h1, h2⟩ := h_sep
      use p₁, p₂, hp₁, hp₂
