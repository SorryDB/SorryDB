import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, (by norm_num)
  intros n hn S hSn hS_dist
  have h_fin : finrank ℝ V = 2 := Fact.out
  haveI : FiniteDimensional ℝ V := .of_finrank_pos (by linarith [h_fin])
  have hS_non : S.Nonempty := by rw [← Finset.card_pos, hSn]; linarith
  obtain ⟨p0, _hp0⟩ := hS_non
  obtain ⟨v, hv, t, h_sep, h_far⟩ : ∃ v : V, ‖v‖ = 1 ∧ ∃ t : ℝ,
    (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ inner (p₁ -ᵥ p0) v < t ∧ t < inner (p₂ -ᵥ p0) v) ∧
    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner (p -ᵥ p0) v - t| := by
    sorry
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (t • v +ᵥ p0) (Submodule.span ℝ {v})ᗮ
  use l
  have h_v : v ≠ 0 := by intro h; rw [h, norm_zero] at hv; linarith
  have h_orth : finrank ℝ l.direction = 1 := by
    rw [AffineSubspace.direction_mk', Submodule.finrank_orthogonal]
    · rw [finrank_span_singleton h_v, h_fin]; norm_num
    · exact Submodule.finiteDimensional_span_singleton v
  constructor
  · exact h_orth
  · constructor
    · obtain ⟨p₁, p₂, hp₁, hp₂, h1, h2⟩ := h_sep
      use p₁, p₂, hp₁, hp₂
      let r := (t - inner (p₁ -ᵥ p0) v) / (inner (p₂ -ᵥ p0) v - inner (p₁ -ᵥ p0) v)
      have h_den : inner (p₂ -ᵥ p0) v - inner (p₁ -ᵥ p0) v ≠ 0 := by linarith
      let p := r • (p₂ -ᵥ p₁) +ᵥ p₁
      have hps : Sbtw ℝ p₁ p p₂ := by
        rw [sbtw_vadd_vsub_iff]
        use r
        have h_gt : 0 < inner (p₂ -ᵥ p0) v - inner (p₁ -ᵥ p0) v := by linarith
        refine ⟨div_pos (by linarith) h_gt, (div_lt_one h_gt).mpr (by linarith), rfl⟩
      have hpl : p ∈ l := by
        rw [AffineSubspace.mem_mk', Submodule.mem_orthogonal_span_singleton_iff_inner_right]
        rw [vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_left, real_inner_self_eq_norm_sq, hv, one_pow, mul_one, sub_eq_zero]
        rw [vadd_vsub_assoc, inner_add_left, inner_smul_left, inner_sub_left, inner_comm (p₂ -ᵥ p0) v, inner_comm (p₁ -ᵥ p0) v]
        field_simp [h_den]
        ring
      have h1_not_mem : p₁ ∉ l := by
        rw [AffineSubspace.mem_mk', Submodule.mem_orthogonal_span_singleton_iff_inner_right]
        rw [vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_left, real_inner_self_eq_norm_sq, hv, one_pow, mul_one, sub_eq_zero]
        linarith
      exact hps.sOppSide_of_notMem_of_mem h1_not_mem hpl
    · intro p hp
      haveI : Nonempty l := ⟨t • v +ᵥ p0, by rw [AffineSubspace.mem_mk']; exact vsub_self _ ▸ Submodule.zero_mem _⟩
      rw [← EuclideanGeometry.dist_orthogonalProjection_eq_infDist l p, dist_comm, dist_eq_norm_vsub V]
      let p_proj := EuclideanGeometry.orthogonalProjection l p
      have h_mem : p -ᵥ ↑p_proj ∈ l.directionᗮ := EuclideanGeometry.vsub_orthogonalProjection_mem_direction_orthogonal l p
      rw [AffineSubspace.direction_mk', Submodule.orthogonal_orthogonal] at h_mem
      obtain ⟨r, hr⟩ := Submodule.mem_span_singleton.mp h_mem
      rw [← hr, norm_smul, hv, mul_one, Real.norm_eq_abs]
      have : r = inner (p -ᵥ (t • v +ᵥ p0)) v := by
        rw [← vsub_sub_vsub_cancel_right p (↑p_proj) (t • v +ᵥ p0), inner_sub_left, ← hr, inner_smul_left, real_inner_self_eq_norm_sq, hv, one_pow, mul_one]
        have h_orth_proj : inner (↑p_proj -ᵥ (t • v +ᵥ p0)) v = 0 := by
          have : ↑p_proj -ᵥ (t • v +ᵥ p0) ∈ l.direction := AffineSubspace.vsub_mem_direction p_proj (by
            rw [AffineSubspace.mem_mk']; exact vsub_self _ ▸ Submodule.zero_mem _)
          rw [AffineSubspace.direction_mk'] at this
          exact Submodule.mem_orthogonal_span_singleton_iff_inner_right.mp this
        rw [h_orth_proj, sub_zero]
      rw [this, vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_left, real_inner_self_eq_norm_sq, hv, one_pow, mul_one]
      exact h_far p hp

end IMO2020P6

