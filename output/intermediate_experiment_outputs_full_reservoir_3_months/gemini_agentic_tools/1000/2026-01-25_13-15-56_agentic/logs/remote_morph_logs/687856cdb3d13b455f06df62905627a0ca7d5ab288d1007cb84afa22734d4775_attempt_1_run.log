import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, (by norm_num)
  intros n hn S hSn hS_dist
  have hS_non : S.Nonempty := by
    rw [← Finset.card_pos, hSn]
    linarith
  obtain ⟨p0, _hp0⟩ := hS_non
  have h_fin : finrank ℝ V = 2 := Fact.out
  haveI : FiniteDimensional ℝ V := .of_finrank_pos (by linarith [h_fin])
  obtain ⟨v, hv, t, h_sep, h_far⟩ : ∃ v : V, ‖v‖ = 1 ∧ ∃ t : ℝ,
    (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ inner v (p₁ -ᵥ p0) < t ∧ t < inner v (p₂ -ᵥ p0)) ∧
    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner v (p -ᵥ p0) - t| := by
    sorry
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (p0 +ᵥ t • v) (Submodule.span ℝ {v})ᗮ
  use l
  constructor
  · rw [AffineSubspace.direction_mk']
    have := Submodule.finrank_add_finrank_orthogonal (Submodule.span ℝ {v})
    rw [Module.finrank_span_singleton ℝ (by linarith [hv] : v ≠ 0), h_fin] at this
    linarith
  · constructor
    · obtain ⟨p₁, p₂, hp₁, hp₂, h1, h2⟩ := h_sep
      let r := (t - inner v (p₁ -ᵥ p0)) / (inner v (p₂ -ᵥ p0) - inner v (p₁ -ᵥ p0))
      have h_den : 0 < inner v (p₂ -ᵥ p0) - inner v (p₁ -ᵥ p0) := by linarith
      have hr0 : 0 < r := div_pos (by linarith) h_den
      have hr1 : r < 1 := (div_lt_one h_den).mpr (by linarith)
      let p := r • (p₂ -ᵥ p₁) +ᵥ p₁
      have hps : Sbtw ℝ p₁ p p₂ := sbtw_iff_vadd_vsub_smul.mpr ⟨r, ⟨hr0, hr1⟩, rfl⟩
      have hpl : p ∈ l := by
        rw [AffineSubspace.mem_mk', Submodule.mem_orthogonal_singleton_iff_inner_left_eq_zero,
          inner_comm, vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_right, hv,
          mul_one, sub_eq_zero, vadd_vsub_assoc, inner_add_left, inner_smul_left,
          inner_sub_left, inner_comm v (p₂ -ᵥ p₁), vsub_sub_vsub_cancel_right,
          inner_sub_right]
        field_simp [h_den.ne']
        ring
      exact ⟨p₁, p₂, hp₁, hp₂, p, hpl, hps⟩
    · intro p hp
      haveI : Nonempty l := ⟨p0 +ᵥ t • v, AffineSubspace.mem_mk' _ _ (Submodule.zero_mem _)⟩
      rw [← EuclideanGeometry.dist_orthogonalProjection_eq_infDist p l,
        EuclideanGeometry.dist_orthogonalProjection_mk' hv]
      rw [vsub_vadd_eq_vsub_sub, inner_sub_left, inner_smul_right, hv, mul_one]
      exact h_far p hp

