/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let x1 := ∠ P A B
  let x2 := ∠ P B C
  let x3 := ∠ P C A
  let y1 := ∠ P B A
  let y2 := ∠ P C B
  let y3 := ∠ P A C
  have h_pos : 0 < x1 ∧ 0 < x2 ∧ 0 < x3 ∧ 0 < y1 ∧ 0 < y2 ∧ 0 < y3 := sorry
  have h_sum : x1 + x2 + x3 + y1 + y2 + y3 = π := sorry
  have h_ceva : Real.sin x1 * Real.sin x2 * Real.sin x3 = Real.sin y1 * Real.sin y2 * Real.sin y3 := by
    have s1 : dist A P * Real.sin x1 = dist P B * Real.sin y1 := by
      rw [mul_comm, ← EuclideanGeometry.dist_sin_angle_p_p_p A P B, angle_comm]
    have s2 : dist B P * Real.sin x2 = dist P C * Real.sin y2 := by
      rw [mul_comm, ← EuclideanGeometry.dist_sin_angle_p_p_p B P C, angle_comm]
    have s3 : dist C P * Real.sin x3 = dist P A * Real.sin y3 := by
      rw [mul_comm, ← EuclideanGeometry.dist_sin_angle_p_p_p C P A, angle_comm]
    have h_dist_pos : dist A P > 0 ∧ dist B P > 0 ∧ dist C P > 0 := sorry
    have h_prod : (dist A P * dist B P * dist C P) * (Real.sin x1 * Real.sin x2 * Real.sin x3) =
                  (dist P B * dist P C * dist P A) * (Real.sin y1 * Real.sin y2 * Real.sin y3) := by
      calc (dist A P * dist B P * dist C P) * (Real.sin x1 * Real.sin x2 * Real.sin x3)
        _ = (dist A P * Real.sin x1) * (dist B P * Real.sin x2) * (dist C P * Real.sin x3) := by ring
        _ = (dist P B * Real.sin y1) * (dist P C * Real.sin y2) * (dist P A * Real.sin y3) := by rw [s1, s2, s3]
        _ = (dist P B * dist P C * dist P A) * (Real.sin y1 * Real.sin y2 * Real.sin y3) := by ring
    apply (mul_right_inj' _).1 h_prod
    positivity
  have hx : Real.sin x1 * Real.sin x2 * Real.sin x3 > 1 / 8 := by
    have h1 : Real.sin x1 > 1 / 2 := by
      have : x1 < π - x2 - x3 := by linarith
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    have h2 : Real.sin x2 > 1 / 2 := by
      have : x2 < π - x1 - x3 := by linarith
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    have h3 : Real.sin x3 > 1 / 2 := by
      have : x3 < π - x1 - x2 := by linarith
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    nlinarith
  have hy : Real.sin y1 * Real.sin y2 * Real.sin y3 < 1 / 8 := by
    have h_y_sum : y1 + y2 + y3 < π / 2 := by linarith
    have h_sin_y_prod : Real.sin y1 * Real.sin y2 * Real.sin y3 ≤ (Real.sin ((y1 + y2 + y3) / 3)) ^ 3 := sorry
    have h_sin_y_sum : Real.sin ((y1 + y2 + y3) / 3) < 1 / 2 := by
      rw [← sin_pi_div_six]
      apply Real.sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    nlinarith [pow_three_lt_pow_three_of_lt (by positivity) h_sin_y_sum]
  linarith [h_ceva, hx, hy]

