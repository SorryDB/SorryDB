  let y3 := ∠ P A C

  have h_mem := interior_convexHull_subset_convexHull _ _ hP
  have h_ne_P : P ≠ A ∧ P ≠ B ∧ P ≠ C := by
    have h_not_boundary : P ∉ {A, B, C} := by
      intro h_mem_sets
      have : P ∈ frontier (convexHull ℝ {A, B, C}) := subset_frontier_convexHull _ (by simpa using h_mem_sets)
      exact (frontier_inter_interior (convexHull ℝ {A, B, C})).subset_compl_right this hP
    simp at h_not_boundary
    exact h_not_boundary
  have h_dist_pos : 0 < dist A P ∧ 0 < dist B P ∧ 0 < dist C P :=
    ⟨dist_pos.mpr h_ne_P.1.symm, dist_pos.mpr h_ne_P.2.1.symm, dist_pos.mpr h_ne_P.2.2.symm⟩

  have h_abc_ne : A ≠ B ∧ B ≠ C ∧ C ≠ A := by
    constructor; exact hABC.ne 0 1 (by decide)
    constructor; exact hABC.ne 1 2 (by decide)
    exact (hABC.ne 2 0 (by decide)).symm

  have h_ceva : Real.sin x1 * Real.sin x2 * Real.sin x3 = Real.sin y1 * Real.sin y2 * Real.sin y3 := by
    have s1 : Real.sin (∠ P A B) * dist A P = Real.sin (∠ P B A) * dist B P := by
      rw [EuclideanGeometry.sin_angle_mul_dist_eq_sin_angle_mul_dist A B P, EuclideanGeometry.angle_comm]
    have s2 : Real.sin (∠ P B C) * dist B P = Real.sin (∠ P C B) * dist C P := by
      rw [EuclideanGeometry.sin_angle_mul_dist_eq_sin_angle_mul_dist B C P, EuclideanGeometry.angle_comm]
    have s3 : Real.sin (∠ P C A) * dist C P = Real.sin (∠ P A C) * dist A P := by
      rw [EuclideanGeometry.sin_angle_mul_dist_eq_sin_angle_mul_dist C A P, EuclideanGeometry.angle_comm]
    have h_prod : (Real.sin x1 * Real.sin x2 * Real.sin x3) * (dist A P * dist B P * dist C P) =
                  (Real.sin y1 * Real.sin y2 * Real.sin y3) * (dist A P * dist B P * dist C P) := by
      calc (Real.sin x1 * Real.sin x2 * Real.sin x3) * (dist A P * dist B P * dist C P)
        _ = (Real.sin x1 * dist A P) * (Real.sin x2 * dist B P) * (Real.sin x3 * dist C P) := by ring
        _ = (Real.sin y1 * dist B P) * (Real.sin y2 * dist C P) * (Real.sin y3 * dist A P) := by rw [s1, s2, s3]; ring
        _ = (Real.sin y1 * Real.sin y2 * Real.sin y3) * (dist A P * dist B P * dist C P) := by ring
    exact (mul_right_inj' (by positivity)).1 h_prod

  have h_angles_pos : 0 < x1 ∧ 0 < x2 ∧ 0 < x3 ∧ 0 < y1 ∧ 0 < y2 ∧ 0 < y3 := sorry
  have h_sum : x1 + x2 + x3 + y1 + y2 + y3 = π := sorry
  have h_x_pi : x1 < π ∧ x2 < π ∧ x3 < π ∧ y1 < π ∧ y2 < π ∧ y3 < π := sorry

  have hx : 1 / 8 < Real.sin x1 * Real.sin x2 * Real.sin x3 := by
    have h_sin (z : ℝ) (hz_gt : π / 6 < z) (hz_lt : z < 5 * π / 6) : 1 / 2 < Real.sin z := by
      apply Real.sin_lt_sin_of_lt_of_le_pi_div_two (by linarith [Real.pi_pos]) (by linarith)
      · apply (Real.sin_pi_div_six).symm.le.trans_lt'
        by_cases h_z_le : z ≤ π / 2
        · exact Real.sin_lt_sin_of_lt_of_le_pi_div_two (by linarith [Real.pi_pos]) (by linarith) h_z_le hz_gt
        · rw [← Real.sin_pi_sub]
          apply Real.sin_lt_sin_of_lt_of_le_pi_div_two (by linarith [Real.pi_pos]) (by linarith) (by linarith) (by linarith)
    have h1 := h_sin x1 hPAB (by linarith [h_sum, h_angles_pos])
    have h2 := h_sin x2 hPBC (by linarith [h_sum, h_angles_pos])
    have h3 := h_sin x3 hPCA (by linarith [h_sum, h_angles_pos])
    nlinarith

  have hy : Real.sin y1 * Real.sin y2 * Real.sin y3 < 1 / 8 := by
    have h_y_sum : y1 + y2 + y3 < π / 2 := by linarith
    have h_log_sin : ConcaveOn ℝ (Set.Icc 0 π) (Real.log ∘ Real.sin) := sorry
    have := h_log_sin.le_map_average (by norm_num) (by intros; simp; linarith [h_angles_pos, h_x_pi]) (by norm_num)
    have h_jensen : Real.sin y1 * Real.sin y2 * Real.sin y3 ≤ (Real.sin ((y1 + y2 + y3) / 3)) ^ 3 := sorry
    have h_sin_y_sum : Real.sin ((y1 + y2 + y3) / 3) < 1 / 2 := by
      rw [← Real.sin_pi_div_six]
      apply Real.sin_lt_sin_of_lt_of_le_pi_div_two (by linarith [Real.pi_pos, h_angles_pos]) (by linarith) (by linarith) (by linarith)
    have : (Real.sin ((y1 + y2 + y3) / 3)) ^ 3 < (1 / 2 : ℝ) ^ 3 := by
      apply pow_lt_pow_left h_sin_y_sum (by positivity) (by norm_num)
    linarith

  linarith
