import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let x1 := ∠ P A B
  let x2 := ∠ P B C
  let x3 := ∠ P C A
  let y1 := ∠ P B A
  let y2 := ∠ P C B
  let y3 := ∠ P A C
  open Real EuclideanGeometry
  have h_ne_P : P ≠ A ∧ P ≠ B ∧ P ≠ C := sorry
  have h_pos : 0 < x1 ∧ 0 < x2 ∧ 0 < x3 ∧ 0 < y1 ∧ 0 < y2 ∧ 0 < y3 := sorry
  have h_sum : x1 + x2 + x3 + y1 + y2 + y3 = π := sorry
  have h_ceva : sin x1 * sin x2 * sin x3 = sin y1 * sin y2 * sin y3 := sorry
  have hx : 1 / 8 < sin x1 * sin x2 * sin x3 := by
    have h_sin_gt (z : ℝ) (hz1 : π / 6 < z) (hz2 : z < 5 * π / 6) : 1 / 2 < sin z := sorry
    have h1 := h_sin_gt x1 hPAB (by linarith [h_sum, h_pos])
    have h2 := h_sin_gt x2 hPBC (by linarith [h_sum, h_pos])
    have h3 := h_sin_gt x3 hPCA (by linarith [h_sum, h_pos])
    nlinarith [h1, h2, h3]
  have hy : sin y1 * sin y2 * sin y3 < 1 / 8 := by
    have h_y_sum : y1 + y2 + y3 < π / 2 := by linarith
    have h_jensen : sin y1 * sin y2 * sin y3 ≤ (sin ((y1 + y2 + y3) / 3)) ^ 3 := sorry
    have h_sin_y_sum : sin ((y1 + y2 + y3) / 3) < 1 / 2 := by
      rw [← sin_pi_div_six]
      apply sin_lt_sin_of_lt_of_le_pi_div_two
      · linarith [pi_pos, h_pos]
      · linarith [h_pos, h_y_sum]
      · linarith [h_y_sum]
    have h_sin_y_pos : 0 < sin ((y1 + y2 + y3) / 3) := sorry
    nlinarith [h_sin_y_sum, h_sin_y_pos, h_jensen]
  linarith [h_ceva, hx, hy]
```
