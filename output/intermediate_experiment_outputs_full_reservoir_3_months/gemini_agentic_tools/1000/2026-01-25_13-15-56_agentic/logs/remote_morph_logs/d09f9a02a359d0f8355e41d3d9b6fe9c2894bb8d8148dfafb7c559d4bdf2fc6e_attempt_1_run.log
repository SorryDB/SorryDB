import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let x1 := ∠ P A B
  let x2 := ∠ P B C
  let x3 := ∠ P C A
  let y1 := ∠ P B A
  let y2 := ∠ P C B
  let y3 := ∠ P A C

  have h_P_ne : P ≠ A ∧ P ≠ B ∧ P ≠ C := by
    have h_mem := interior_convexHull_subset_convexHull _ _ hP
    have h_not_boundary : P ∉ {A, B, C} := by
      intro hP_mem
      have : P ∈ frontier (convexHull ℝ {A, B, C}) := by
        apply subset_frontier_convexHull
        simpa using hP_mem
      have : P ∉ interior (convexHull ℝ {A, B, C}) :=
        (frontier_inter_interior (convexHull ℝ {A, B, C})).symm.subset_compl_right this
      contradiction
    simp at h_not_boundary
    exact h_not_boundary

  have h_dist_pos : 0 < dist A P ∧ 0 < dist B P ∧ 0 < dist C P := by
    simp [dist_pos, h_P_ne.1, h_P_ne.2.1, h_P_ne.2.2]

  have h_ceva : sin x1 * sin x2 * sin x3 = sin y1 * sin y2 * sin y3 := by
    have s1 : dist A P * sin x1 = dist B P * sin y1 := by
      rw [mul_comm, ← sin_angle_mul_dist_eq_sin_angle_mul_dist P A B, angle_comm]
    have s2 : dist B P * sin x2 = dist C P * sin y2 := by
      rw [mul_comm, ← sin_angle_mul_dist_eq_sin_angle_mul_dist P B C, angle_comm]
    have s3 : dist C P * sin x3 = dist A P * sin y3 := by
      rw [mul_comm, ← sin_angle_mul_dist_eq_sin_angle_mul_dist P C A, angle_comm]
    have h_prod : (dist A P * dist B P * dist C P) * (sin x1 * sin x2 * sin x3) =
                  (dist B P * dist C P * dist A P) * (sin y1 * sin y2 * sin y3) := by
      calc (dist A P * dist B P * dist C P) * (sin x1 * sin x2 * sin x3)
        _ = (dist A P * sin x1) * (dist B P * sin x2) * (dist C P * sin x3) := by ring
        _ = (dist B P * sin y1) * (dist C P * sin y2) * (dist A P * sin y3) := by rw [s1, s2, s3]
        _ = (dist B P * dist C P * dist A P) * (sin y1 * sin y2 * sin y3) := by ring
    apply (mul_right_inj' _).1 h_prod
    positivity

  have h_x_range : ∀ i, x1 < π ∧ x2 < π ∧ x3 < π ∧ y1 < π ∧ y2 < π ∧ y3 < π := sorry
  have h_x_pos : ∀ i, 0 < x1 ∧ 0 < x2 ∧ 0 < x3 ∧ 0 < y1 ∧ 0 < y2 ∧ 0 < y3 := sorry
  have h_sum : x1 + x2 + x3 + y1 + y2 + y3 = π := sorry

  have hx : sin x1 * sin x2 * sin x3 > 1 / 8 := by
    have h1 : sin x1 > 1 / 2 := by
      apply sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
      linarith [sin_pi_div_six]
    have h2 : sin x2 > 1 / 2 := by
      apply sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
      linarith [sin_pi_div_six]
    have h3 : sin x3 > 1 / 2 := by
      apply sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
      linarith [sin_pi_div_six]
    nlinarith

  have hy : sin y1 * sin y2 * sin y3 < 1 / 8 := by
    have h_y_sum : y1 + y2 + y3 < π / 2 := by linarith
    have h_sin_pos : 0 < sin y1 ∧ 0 < sin y2 ∧ 0 < sin y3 := by
      constructor; apply sin_pos_of_mem_Ioo; constructor <;> linarith
      constructor; apply sin_pos_of_mem_Ioo; constructor <;> linarith
      apply sin_pos_of_mem_Ioo; constructor <;> linarith
    have h_jensen : (sin y1 * sin y2 * sin y3) ≤ (sin ((y1 + y2 + y3) / 3)) ^ 3 := sorry
    have h_sin_y_sum : sin ((y1 + y2 + y3) / 3) < 1 / 2 := by
      rw [← sin_pi_div_six]
      apply sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    have h_pow : (sin ((y1 + y2 + y3) / 3)) ^ 3 < (1 / 2 : ℝ) ^ 3 :=
      pow_lt_pow_left h_sin_y_sum (by positivity) (by norm_num)
    linarith

  linarith
