import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let x1 := ∠ P A B
  let x2 := ∠ P B C
  let x3 := ∠ P C A
  let y1 := ∠ P B A
  let y2 := ∠ P C B
  let y3 := ∠ P A C

  have h_ne_P : P ≠ A ∧ P ≠ B ∧ P ≠ C := sorry
  have h_pos : 0 < x1 ∧ 0 < x2 ∧ 0 < x3 ∧ 0 < y1 ∧ 0 < y2 ∧ 0 < y3 := sorry
  have h_sum : x1 + x2 + x3 + y1 + y2 + y3 = π := sorry

  have h_ceva : Real.sin x1 * Real.sin x2 * Real.sin x3 = Real.sin y1 * Real.sin y2 * Real.sin y3 := by
    have s1 : Real.sin x1 * dist A P = Real.sin y1 * dist B P := by
      have h := EuclideanGeometry.sin_angle_div_dist_eq_sin_angle_div_dist (p1 := B) (p2 := A) (p3 := P) h_ne_P.1.symm h_ne_P.2.1.symm
      rw [EuclideanGeometry.angle_comm B A P, dist_comm P B] at h
      field_simp [dist_pos.mpr h_ne_P.1.symm, dist_pos.mpr h_ne_P.2.1.symm] at h
      exact h
    have s2 : Real.sin x2 * dist B P = Real.sin y2 * dist C P := by
      have h := EuclideanGeometry.sin_angle_div_dist_eq_sin_angle_div_dist (p1 := C) (p2 := B) (p3 := P) h_ne_P.2.1.symm h_ne_P.2.2.symm
      rw [EuclideanGeometry.angle_comm C B P, dist_comm P C] at h
      field_simp [dist_pos.mpr h_ne_P.2.1.symm, dist_pos.mpr h_ne_P.2.2.symm] at h
      exact h
    have s3 : Real.sin x3 * dist C P = Real.sin y3 * dist A P := by
      have h := EuclideanGeometry.sin_angle_div_dist_eq_sin_angle_div_dist (p1 := A) (p2 := C) (p3 := P) h_ne_P.2.2.symm h_ne_P.1.symm
      rw [EuclideanGeometry.angle_comm A C P, dist_comm P A] at h
      field_simp [dist_pos.mpr h_ne_P.2.2.symm, dist_pos.mpr h_ne_P.1.symm] at h
      exact h
    have h_prod : (Real.sin x1 * Real.sin x2 * Real.sin x3) * (dist A P * dist B P * dist C P) =
                  (Real.sin y1 * Real.sin y2 * Real.sin y3) * (dist A P * dist B P * dist C P) := by
      calc (Real.sin x1 * Real.sin x2 * Real.sin x3) * (dist A P * dist B P * dist C P)
        _ = (Real.sin x1 * dist A P) * (Real.sin x2 * dist B P) * (Real.sin x3 * dist C P) := by ring
        _ = (Real.sin y1 * dist B P) * (Real.sin y2 * dist C P) * (Real.sin y3 * dist A P) := by rw [s1, s2, s3]; ring
        _ = (Real.sin y1 * Real.sin y2 * Real.sin y3) * (dist A P * dist B P * dist C P) := by ring
    have h_dist_pos : 0 < dist A P * dist B P * dist C P := by
      positivity [dist_pos.mpr h_ne_P.1.symm, dist_pos.mpr h_ne_P.2.1.symm, dist_pos.mpr h_ne_P.2.2.symm]
    exact (mul_right_inj' h_dist_pos.ne').1 h_prod

  have hx : 1 / 8 < Real.sin x1 * Real.sin x2 * Real.sin x3 := by
    have h_sin_gt_half : ∀ z, π / 6 < z ∧ z < 2 * π / 3 → 1 / 2 < Real.sin z := sorry
    have h1 := h_sin_gt_half x1 ⟨hPAB, by linarith [h_sum, h_pos]⟩
    have h2 := h_sin_gt_half x2 ⟨hPBC, by linarith [h_sum, h_pos]⟩
    have h3 := h_sin_gt_half x3 ⟨hPCA, by linarith [h_sum, h_pos]⟩
    nlinarith

  have hy : Real.sin y1 * Real.sin y2 * Real.sin y3 < 1 / 8 := by
    have h_y_sum : y1 + y2 + y3 < π / 2 := by linarith
    have h_jensen : Real.sin y1 * Real.sin y2 * Real.sin y3 ≤ (Real.sin ((y1 + y2 + y3) / 3)) ^ 3 := sorry
    have h_sin_y_sum : Real.sin ((y1 + y2 + y3) / 3) < 1 / 2 := by
      rw [← Real.sin_pi_div_six]
      apply Real.sin_lt_sin_of_lt_of_le_pi_div_two
      · linarith [Real.pi_pos, h_pos]
      · linarith [h_pos, h_y_sum]
      · linarith [h_y_sum]
    have h_y_pos : 0 < (y1 + y2 + y3) / 3 := by linarith [h_pos]
    have h_sin_y_pos : 0 < Real.sin ((y1 + y2 + y3) / 3) :=
      Real.sin_pos (by linarith [h_y_pos]) (by linarith [h_y_sum, Real.pi_pos])
    nlinarith [h_sin_y_sum, h_sin_y_pos, h_jensen]

  linarith [h_ceva, hx, hy]

