import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let x1 := ∠ P A B
  let x2 := ∠ P B C
  let x3 := ∠ P C A
  let y1 := ∠ P B A
  let y2 := ∠ P C B
  let y3 := ∠ P A C
  have h_pos : 0 < x1 ∧ 0 < x2 ∧ 0 < x3 ∧ 0 < y1 ∧ 0 < y2 ∧ 0 < y3 := sorry
  have h_sum : x1 + x2 + x3 + y1 + y2 + y3 = π := sorry
  have h_ceva : sin x1 * sin x2 * sin x3 = sin y1 * sin y2 * sin y3 := sorry
  have hx : sin x1 * sin x2 * sin x3 > 1 / 8 := by
    have s1 : sin x1 > 1/2 := by
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith [hPAB])
    have s2 : sin x2 > 1/2 := by
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith [hPBC])
    have s3 : sin x3 > 1/2 := by
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith [hPCA])
    nlinarith
  have hy : sin y1 * sin y2 * sin y3 < 1 / 8 := by
    have h_y_sum : y1 + y2 + y3 < π / 2 := by linarith
    have h_log_sin : ConcaveOn ℝ (Set.Icc 0 π) (fun x => log (sin x)) := sorry
    have : (sin y1 * sin y2 * sin y3) ≤ (sin ((y1 + y2 + y3) / 3)) ^ 3 := sorry
    have : (sin ((y1 + y2 + y3) / 3)) ^ 3 < (sin (π / 6)) ^ 3 := by
      apply pow_lt_pow_left (sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)) (by linarith) (by norm_num)
    linarith [sin_pi_div_six]
  linarith
