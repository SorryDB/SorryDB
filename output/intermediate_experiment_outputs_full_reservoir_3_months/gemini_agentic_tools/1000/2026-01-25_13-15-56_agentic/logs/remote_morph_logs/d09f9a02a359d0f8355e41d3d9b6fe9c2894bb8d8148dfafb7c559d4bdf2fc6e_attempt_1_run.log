import Mathlib

import ProblemExtraction

problem_file {
  tags := [.Geometry]
}

/-!
# International Mathematical Olympiad 1991, Problem 5

Let ABC be a triangle and P be an interior point of ABC.
Show that at least one of the angles ∠PAB, ∠PBC, ∠PCA is
less than or equal to 30°.

-/

namespace Imo1991P5

open scoped Affine EuclideanGeometry Real

problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra! h
  obtain ⟨hPAB, hPBC, hPCA⟩ := h
  let x1 := ∠ P A B
  let x2 := ∠ P B C
  let x3 := ∠ P C A
  let y1 := ∠ A B P
  let y2 := ∠ B C P
  let y3 := ∠ C A P
  have h_ceva : sin x1 * sin x2 * sin x3 = sin y1 * sin y2 * sin y3 := by
    have h1 := sin_angle_mul_dist_eq_sin_angle_mul_dist A B P
    have h2 := sin_angle_mul_dist_eq_sin_angle_mul_dist B C P
    have h3 := sin_angle_mul_dist_eq_sin_angle_mul_dist C A P
    have hA : P ≠ A := by sorry
    have hB : P ≠ B := by sorry
    have hC : P ≠ C := by sorry
    field_simp [x1, x2, x3, y1, y2, y3, dist_ne_zero.mpr hA, dist_ne_zero.mpr hB, dist_ne_zero.mpr hC] at *
    rw [mul_comm (sin y1), h1, mul_comm (sin y2), h2, mul_comm (sin y3), h3]
    ring
  have h_sum : x1 + x2 + x3 + y1 + y2 + y3 = π := by
    have hPAB : ∠ P A B + ∠ A B P + ∠ B P A = π := angle_add_angle_add_angle_eq_pi P A B (by sorry)
    have hPBC : ∠ P B C + ∠ B C P + ∠ C P B = π := angle_add_angle_add_angle_eq_pi P B C (by sorry)
    have hPCA : ∠ P C A + ∠ C A P + ∠ A P C = π := angle_add_angle_add_angle_eq_pi P C A (by sorry)
    have hP_sum : ∠ B P A + ∠ C P B + ∠ A P C = 2 * π := by sorry
    linarith
  have h_x_range : x1 < 5 * π / 6 ∧ x2 < 5 * π / 6 ∧ x3 < 5 * π / 6 := by
    have h_pos : 0 < y1 ∧ 0 < y2 ∧ 0 < y3 := by sorry
    linarith
  have hx : sin x1 * sin x2 * sin x3 > 1 / 8 := by
    have hx1 : sin x1 > 1/2 := by
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    have hx2 : sin x2 > 1/2 := by
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    have hx3 : sin x3 > 1/2 := by
      apply sin_gt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)
    nlinarith
  have hy : sin y1 * sin y2 * sin y3 < 1 / 8 := by
    have h_y_sum : y1 + y2 + y3 < π / 2 := by linarith
    have h_y_pos : 0 < y1 ∧ 0 < y2 ∧ 0 < y3 := by sorry
    have : sin y1 * sin y2 * sin y3 ≤ (sin ((y1 + y2 + y3) / 3)) ^ 3 := by sorry
    have : (sin ((y1 + y2 + y3) / 3)) ^ 3 < (sin (π / 6)) ^ 3 := by
      apply pow_lt_pow_left (sin_lt_sin_of_lt_of_le (by linarith) (by linarith) (by linarith)) (by linarith) (by norm_num)
    linarith [sin_pi_div_six]
  linarith
