def toOuterMeasure {α : Type*} [MeasurableSpace α] (E : ResolutionOfIdentity α H) (x : H) : OuterMeasure α where
  measureOf w := ENNReal.ofReal ‖E.measureOf' w x‖
  empty := by
    rw [E.empty']
    simp only [ContinuousLinearMap.zero_apply, norm_zero, ofReal_zero]
  mono {w₁ w₂} h := by
    rw [ENNReal.ofReal_le_ofReal_iff (norm_nonneg _)]
    by_cases h₁ : MeasurableSet w₁; swap
    · rw [E.not_measurable' h₁, norm_zero]
      exact norm_nonneg _
    by_cases h₂ : MeasurableSet w₂
    · rw [← Set.inter_eq_self_of_subset_left h, E.m_Inter' h₁ h₂]
      have hP := E.isOrthogonalProjection' w₁
      have : ‖E w₁ (E w₂ x)‖^2 = (⟪E w₂ x, E w₁ (E w₂ x)⟫_ℂ).re := by
        rw [hP.2, ← pow_two, ← hP.1]; rfl
      rw [this]
      exact (abs_re_le_norm _).trans (norm_inner_le _ _)
    · rw [E.not_measurable' h₂, norm_zero]
      have : E.measureOf' w₁ = 0 := by sorry
      rw [this, ContinuousLinearMap.zero_apply, norm_zero]
```
