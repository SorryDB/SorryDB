/-- Addition operation for points on the elliptic curve -/
def MordellWeilGroup.add (P Q : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point, Q.point with
  | none, _ => Q  -- P is infinity, so P + Q = Q
  | _, none => P  -- Q is infinity, so P + Q = P
  | some (xтВБ, yтВБ), some (xтВВ, yтВВ) =>
    if xтВБ = xтВВ then
      if yтВБ + yтВВ + E.val.aтВБ*xтВБ + E.val.aтВГ = 0 then
        -- P and Q are negatives of each other
        MordellWeilGroup.infinity E
      else
        -- Point doubling
        match MordellWeilGroup.slope E P Q with
        | none => MordellWeilGroup.infinity E
        | some s =>  -- Changed ╬╗ to s (for slope)
          let W := E.val
          let xтВГ := s^2 + W.aтВБ*s - W.aтВВ - xтВБ - xтВВ
          let yтВГ := s*(xтВБ - xтВГ) - yтВБ - W.aтВБ*xтВГ - W.aтВГ
          MordellWeilGroup.mk_point E xтВГ yтВГ (by
            rcases P with тЯиpP, onPтЯй; rcases Q with тЯиpQ, onQтЯй
            have hP : yтВБ^2 + W.aтВБ*xтВБ*yтВБ + W.aтВГ*yтВБ = xтВБ^3 + W.aтВВ*xтВБ^2 + W.aтВД*xтВБ + W.aтВЖ :=
              onP xтВБ yтВБ (by have : pP = some (xтВБ, yтВБ) := rfl; exact this)
            have hQ : yтВВ^2 + W.aтВБ*xтВВ*yтВВ + W.aтВГ*yтВВ = xтВВ^3 + W.aтВВ*xтВВ^2 + W.aтВД*xтВВ + W.aтВЖ :=
              onQ xтВВ yтВВ (by have : pQ = some (xтВВ, yтВВ) := rfl; exact this)
            have hs : MordellWeilGroup.slope E тЯиpP, onPтЯй тЯиpQ, onQтЯй = some s := rfl
            unfold MordellWeilGroup.slope at hs
            split_ifs at hs with hx_eq hv_eq <;> injection hs with hsv
            ┬╖ subst hx_eq hsv; field_simp at *; nlinarith [hP, hQ]
            ┬╖ subst hsv; field_simp at *; nlinarith [hP, hQ])
