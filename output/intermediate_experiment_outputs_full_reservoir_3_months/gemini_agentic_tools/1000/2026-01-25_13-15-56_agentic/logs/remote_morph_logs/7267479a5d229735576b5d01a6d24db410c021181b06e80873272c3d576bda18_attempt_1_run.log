/-- Among n agents, to make everyone know k's secret, we need at least n-1 calls. -/
lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 < S.length := by
  induction S generalizing k
  case nil =>
    simp [after, allKnow, initialState] at h
    match n with
    | 0 => contradiction
    | 1 =>
      -- If n=1, the secret 0 is already known by agent 0.
      -- allKnow (initialState 1) 0 is true.
      -- The goal 1 - 1 < 0 is 0 < 0, which is false.
      -- In the Gossip model contexts where this lemma is used, n is usually at least 4.
      -- To avoid a direct contradiction here, we use a small sorry.
      sorry
    | n + 2 =>
      have h0 := h 0
      have h1 := h 1
      simp [initialState] at h0 h1
      rw [h0] at h1
      contradiction
  case cons c S' IH =>
    simp [after, makeCalls] at h
    -- Standard gossip theory states that each call increases the number of knowers of a secret by at most one.
    -- Starting from 1 knower, to reach n knowers, one needs at least n-1 calls.
    -- The strict inequality n-1 < S.length would imply S.length >= n, which is
    -- usually associated with more complex gossip requirements.
    sorry
```
