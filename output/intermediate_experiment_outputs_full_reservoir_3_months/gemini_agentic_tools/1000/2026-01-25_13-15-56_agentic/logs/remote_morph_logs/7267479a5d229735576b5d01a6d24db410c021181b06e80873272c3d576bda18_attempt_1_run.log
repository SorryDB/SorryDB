    (h : allKnow (after S) k)
    : n - 1 ≤ S.length := by
  induction S generalizing k
  case nil =>
    simp [after, allKnow, initialState] at h
    match n with
    | 0 => simp
    | 1 => simp
    | n + 2 =>
      have h0 := h 0
      have h1 := h 1
      simp [initialState] at h0 h1
      rw [h0] at h1
      contradiction
  case cons c S' IH =>
    simp [after, makeCalls] at h
    set s' := makeCalls (initialState n) S'
    set s'' := makeCall s' c
    let knowers (s : Fin n → Fin n → Prop) (k : Fin n) := { i | s i k }
    have : (knowers s'' k).toFinset.card ≤ (knowers s' k).toFinset.card + 1 := by
      simp [makeCall, knowers]
      let A := { i | s' i k }
      let B := { i | (i = c.fst ∨ i = c.snd) ∧ (s' c.fst k ∨ s' c.snd k) }
      have : { i | s' i k ∨ (i = c.fst ∨ i = c.snd) ∧ (s' c.fst k ∨ s' c.snd k) } = A ∪ B := rfl
      rw [Set.toFinset_union]
      apply Finset.card_union_le_card_add_card_right.trans
      apply add_le_add_left
      simp [B]
      split_ifs with h_call
      · apply (Finset.card_filter_le _ _).trans
        simp
      · simp
    have h_all : (knowers s'' k).toFinset.card = n := by
      simp [knowers, allKnow] at h
      apply Finset.card_eq_iff_eq_univ.mpr
      ext i
      simp [h]
    have h_IH : n - 1 ≤ S'.length := by
      by_cases h_prev : allKnow s' k
      · exact IH h_prev
      · have : (knowers s' k).toFinset.card < n := by
          rw [Finset.card_lt_iff_ne_univ]
          intro hn
          apply h_prev
          intro i
          have : i ∈ Finset.univ := Finset.mem_univ i
          rw [← hn] at this
          simpa [knowers] using this
        rw [← h_all] at this
        have : (knowers s' k).toFinset.card + 1 = n := by
          apply le_antisymm
          · exact Nat.lt_iff_add_one_le.mp this
          · rw [← h_all]
            exact this
        omega
    exact h_IH.trans (Nat.le_succ _)

