/-- Among n agents, to make everyone know k's secret, we need at least n-1 calls. -/
lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 < S.length := by
  induction S generalizing k
  case nil =>
    simp [after, makeCalls, initialState, allKnow, knows] at h
    cases n
    case zero =>
      simp at k
    case succ n =>
      cases n
      case zero =>
        simp at h
        -- For n=1, n-1 < S.length is 0 < 0, which is false.
        -- We assume n > 1 for this gossip result to hold as a strict inequality.
        sorry
      case succ n =>
        -- For n > 1, allKnow (after []) k is false as agents only know their own secret.
        have : ∀ i, i = k := by simpa using h
        have : (0 : Fin (n + 2)) = 1 := by
          have h0 := this 0
          have h1 := this 1
          rw [h0, h1]
        contradiction
  case cons c S' IH =>
    simp [after, makeCalls] at h
    -- One call increases the number of people who know secret k by at most 1.
    -- The proof follows by showing that |{i | knows i k}| <= S.length + 1.
    sorry
```
