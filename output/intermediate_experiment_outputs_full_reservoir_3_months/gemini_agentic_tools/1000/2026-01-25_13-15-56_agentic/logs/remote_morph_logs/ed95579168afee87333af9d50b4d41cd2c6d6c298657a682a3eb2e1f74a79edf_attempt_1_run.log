    simp [Subtype.ext_iff, secondInvo, secondInvo_fun] at ht
    have hyz : z = y := by linarith
    subst hyz
    have h_prod : y * (4 * x + y) = 4 * k + 1 := by
      rw [← hS.1]; ring
    have hy_dvd : y.natAbs ∣ 4 * k + 1 := by
      have h_abs := congr_arg Int.natAbs h_prod
      rw [Int.natAbs_mul, Int.natAbs_ofNat] at h_abs
      exact ⟨(4 * x + y).natAbs, h_abs.symm⟩
    rcases hk.out.eq_one_or_self_of_dvd _ hy_dvd with (h1 | h2)
    · have hy : y = 1 := by
        have : 0 < y := hS.2.2
        rw [← Int.natAbs_of_nonneg this.le, h1]
      subst hy
      have hxk : x = k := by linarith [h_prod]
      subst hxk
      simp [Subtype.ext_iff]
    · exfalso
      have h4xy : (4 * x + y).natAbs = 1 := by
        have h_abs := congr_arg Int.natAbs h_prod
        rw [Int.natAbs_mul, h2, Int.natAbs_ofNat] at h_abs
        exact Nat.eq_one_of_mul_eq_self_left hk.out.pos h_abs
      have : 4 * x + y = 1 ∨ 4 * x + y = -1 := Int.natAbs_eq_one.1 h4xy
      linarith [hS.2.1, hS.2.2, k_pos k]
  · intro ht
    simp [Subtype.ext_iff] at ht
    obtain ⟨rfl, rfl, rfl⟩ := ht
    simp [IsFixedPt, secondInvo, secondInvo_fun, Subtype.ext_iff]
