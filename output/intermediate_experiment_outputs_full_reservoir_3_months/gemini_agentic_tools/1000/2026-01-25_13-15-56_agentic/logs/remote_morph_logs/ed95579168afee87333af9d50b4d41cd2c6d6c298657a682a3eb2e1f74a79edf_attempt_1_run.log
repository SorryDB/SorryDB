/-- Any fixed point of `secondInvo k` must be `(k, 1, 1)`. -/
theorem eq_of_mem_fixedPoints : fixedPoints (secondInvo k) = singletonFixedPoint k := by
  simp only [fixedPoints, IsFixedPt, secondInvo, secondInvo_fun,
    singletonFixedPoint, Prod.mk_one_one, Finset.coe_singleton]
  ext t
  constructor
  · intro ht
    simp at ht
    rcases t with ⟨⟨⟨x, y, z⟩, hS_eq, hx, hy⟩, hU⟩
    simp [Subtype.ext_iff] at ht
    have hyz : z = y := by linarith
    have h_prod : y * (4 * x + y) = 4 * k + 1 := by
      rw [← hS_eq, hyz]; ring
    have hy_dvd : y.natAbs ∣ 4 * k + 1 :=
      ⟨(4 * x + y).natAbs, by rw [← Int.natAbs_mul, h_prod]; simp⟩
    rcases hk.out.eq_one_or_self_of_dvd _ hy_dvd with hy1 | hy2
    · have hy1' : y = 1 := by
        cases' Int.natAbs_eq_iff.mp hy1 with h h <;> linarith
      have hx1 : x = k := by
        rw [hy1', one_mul] at h_prod
        linarith
      simp [Subtype.ext_iff, singletonFixedPoint, hx1, hy1', hyz]
    · exfalso
      have h_abs : (4 * k + 1) * (4 * x + y).natAbs = 4 * k + 1 := by
        rw [← Int.natAbs_mul, h_prod, Int.natAbs_mul, hy2, mul_comm]; simp
      have h4xy_abs : (4 * x + y).natAbs = 1 := by
        rwa [Nat.mul_right_eq_self_iff hk.out.pos] at h_abs
      cases' Int.natAbs_eq_iff.mp h4xy_abs with h h <;> linarith [k_pos k]
  · intro ht
    simp [singletonFixedPoint] at ht
    subst ht
    simp [IsFixedPt, secondInvo, secondInvo_fun, Subtype.ext_iff]
