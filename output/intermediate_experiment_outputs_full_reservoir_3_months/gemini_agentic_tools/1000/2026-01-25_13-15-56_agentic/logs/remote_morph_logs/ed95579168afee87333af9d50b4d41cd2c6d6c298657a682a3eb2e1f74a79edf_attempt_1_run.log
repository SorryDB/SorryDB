/-- Any fixed point of `secondInvo k` must be `(k, 1, 1)`. -/
theorem eq_of_mem_fixedPoints : fixedPoints (secondInvo k) = singletonFixedPoint k := by
  simp only [fixedPoints, IsFixedPt, singletonFixedPoint, Finset.coe_singleton]
  ext t
  constructor
  · intro ht
    rcases t with ⟨⟨⟨x, y, z⟩, hS_eq, hx, hy⟩, hU⟩
    simp [secondInvo, secondInvo_fun, Subtype.ext_iff] at ht
    have hyz : z = y := by linarith
    have h_prod : y * (4 * x + y) = 4 * k + 1 := by
      rw [← hS_eq, hyz]
      ring
    have h_abs : y.natAbs * (4 * x + y).natAbs = 4 * k + 1 := by
      rw [← Int.natAbs_mul, h_prod, Int.natAbs_ofNat]
    have hy_dvd : y.natAbs ∣ 4 * k + 1 := ⟨(4 * x + y).natAbs, h_abs⟩
    rcases hk.out.eq_one_or_self_of_dvd _ hy_dvd with hy1 | hy2
    · have hy_eq : y = 1 := by
        cases' Int.natAbs_eq_iff.mp hy1 with h h <;> linarith
      have hx_eq : x = k := by linarith [h_prod, hy_eq]
      simp [Subtype.ext_iff, hy_eq, hx_eq, hyz]
    · exfalso
      have hy_eq : y = 4 * k + 1 := by
        cases' Int.natAbs_eq_iff.mp hy2 with h h <;> linarith [k_pos k]
      have h4xy : 4 * x + y = 1 := by
        rw [hy_eq] at h_prod
        exact Int.mul_left_cancel (by linarith [k_pos k]) (h_prod.trans (mul_one (4 * k + 1 : ℤ)).symm)
      linarith [hx, k_pos k]
  · intro ht
    simp only [Set.mem_singleton_iff] at ht
    subst ht
    simp [IsFixedPt, secondInvo, secondInvo_fun, Subtype.ext_iff]
