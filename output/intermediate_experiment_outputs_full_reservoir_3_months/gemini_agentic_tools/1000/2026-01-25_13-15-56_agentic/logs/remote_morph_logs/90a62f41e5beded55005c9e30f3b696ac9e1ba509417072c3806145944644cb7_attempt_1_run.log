import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := {(5, 3), (2, 1)}

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro (h | h)
    · rcases h with ⟨rfl, rfl⟩
      refine Set.infinite_range_of_injective (fun (k : ℕ) => (k + 1 : ℤ)) (fun _ _ h => by simp at h; exact h).mono ?_
      rintro _ ⟨k, rfl⟩
      exact ⟨by simp, by rw [show (k + 1 : ℤ)^5 + (k + 1) - 1 = ((k + 1)^3 + (k + 1)^2 - 1) * ((k + 1)^2 - (k + 1) + 1) by ring]; exact dvd_mul_right _ _⟩
    · rcases h with ⟨rfl, rfl⟩
      refine Set.infinite_range_of_injective (fun (k : ℕ) => (k + 1 : ℤ)) (fun _ _ h => by simp at h; exact h).mono ?_
      rintro _ ⟨k, rfl⟩
      exact ⟨by simp, by rw [show (k + 1 : ℤ)^1 + (k + 1)^2 - 1 = (k + 1)^2 + (k + 1) - 1 by ring]; exact dvd_refl _⟩
  · intro h
    have h_poly : ∃ (q : Polynomial ℚ), (Polynomial.X ^ n + Polynomial.X ^ 2 - 1) * q = Polynomial.X ^ m + Polynomial.X - 1 := by
      have : (Polynomial.X ^ n + Polynomial.X ^ 2 - 1 : Polynomial ℤ) ∣ (Polynomial.X ^ m + Polynomial.X - 1 : Polynomial ℤ) := by
        refine Polynomial.dvd_of_infinite_ratio_at_ints _ _ h
        exact Polynomial.monic_X_pow_add_X_pow_sub_one (by nlinarith)
      rcases this with ⟨q, hq⟩
      use q.map (Int.castRingHom ℚ)
      rw [← hq, Polynomial.map_mul]
      simp only [Polynomial.map_add, Polynomial.map_pow, Polynomial.map_X, Polynomial.map_sub, Polynomial.map_one]
    let α : ℂ := Complex.ofReal (Exists.choose (Set.exists_between_zero_one (by
      have f : ℝ → ℝ := fun x => x^n + x^2 - 1
      have f0 : f 0 = -1 := by simp [f]
      have f1 : f 1 = 1 := by simp [f]
      exact ⟨f, by continuity, f0, f1⟩)))
    have h_α : α ^ n + α ^ 2 - 1 = 0 := by
      obtain ⟨x, ⟨hx0, hx1⟩, hfx⟩ := Set.exists_between_zero_one (show (0 : ℝ) < 1 by norm_num) (f := fun x => x^n + x^2 - 1) (by continuity) (by simp) (by simp)
      exact_mod_cast hfx
    have h_α_root : α ^ m + α - 1 = 0 := by
      rcases h_poly with ⟨q, hq⟩
      have := Polynomial.aeval_def (Polynomial.X ^ m + Polynomial.X - 1) α
      rw [← hq] at this
      simp [h_α] at this
      exact this
    have h_α_m : α ^ m = 1 - α := by linear_combination h_α_root
    have h_α_n : α ^ n = 1 - α ^ 2 := by linear_combination h_α
    have h_α_n_m : α ^ n = α ^ m * (1 + α) := by
      rw [h_α_n, h_α_m]
      ring
    have α_real : α.im = 0 := by simp [α]
    have α_pos : 0 < α.re := by
      obtain ⟨x, ⟨hx0, hx1⟩, hfx⟩ := Set.exists_between_zero_one (show (0 : ℝ) < 1 by norm_num) (f := fun x => x^n + x^2 - 1) (by continuity) (by simp) (by simp)
      simp [α]; exact hx0
    have α_lt_1 : α.re < 1 := by
      obtain ⟨x, ⟨hx0, hx1⟩, hfx⟩ := Set.exists_between_zero_one (show (0 : ℝ) < 1 by norm_num) (f := fun x => x^n + x^2 - 1) (by continuity) (by simp) (by simp)
      simp [α]; exact hx1
    have α_val : α = Complex.ofReal α.re := by ext <;> simp [α]
    have α_pow_pos {k : ℕ} (hk : 0 < k) : 0 < α.re ^ k := pow_pos α_pos k
    if hmn : n < m then
      have : α.re ^ (m - n) = (1 + α.re)⁻¹ := by
        have : α.re ^ n = α.re ^ m * (1 + α.re) := by exact_mod_cast h_α_n_m
        rw [this, pow_mul_pow_sub α.re (by linarith)]
        field_simp [α_pos.ne.symm]
      sorry
    else if hmn2 : n = m then
      sorry
    else
      sorry
    sorry

