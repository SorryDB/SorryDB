import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := {(5, 3)}

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · intro h
    rw [solution, Set.mem_singleton_iff, Prod.mk.inj_iff] at h
    rcases h with ⟨rfl, rfl⟩
    have h_inf : Set.Infinite {a : ℤ | 0 < a} :=
      Set.infinite_range_of_injective (fun n : ℕ => (n + 1 : ℤ)) (λ _ _ h => by simp at h; exact h)
    exact h_inf.mono (λ a ha => ⟨ha, by
      rw [show a ^ 5 + a - 1 = (a ^ 3 + a ^ 2 - 1) * (a ^ 2 - a + 1) by ring]
      exact dvd_mul_right _ _⟩)
  · intro h; sorry
```
