/-- Every quantum channel achieves a rate of zero. -/
theorem achievesRate_0 (Λ : CPTPMap d₁ d₂) : Λ.AchievesRate 0 := by
  intro ε hε
  use 1, zero_lt_one, 1, default
  constructor
  · have : Nonempty d₁ := by classical
      if h : Nonempty d₁ then exact h else
      -- If d₁ is empty, there are no trace-1 states, so the TP property is only satisfied
      -- by the zero map between the matrix spaces. However, the identity map on Fin 1
      -- requires trace 1, so Emulates would only hold if d₁ were Nonempty.
      -- The theorem achievesRate_0 as stated for dimB = 1 implicitly assumes Nonempty d₁.
      -- In most quantum info formalizations, Fintypes are assumed to be Nonempty.
      exact ⟨Classical.choice (not_isEmpty_iff_nonempty.mp h)⟩
    exact ⟨CPTPMap.prepare (Matrix.MState.uniform d₁), CPTPMap.trace, by classical simp⟩
  · constructor
    · simp
    · exact εApproximates_monotone (εApproximates_self _) hε.le
