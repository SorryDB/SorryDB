import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 3
    | n + 1 => ((Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)).totient * (a n + 1) + 2
  termination_by n => n
  have ha_zero : a 0 = 3 := rfl
  have ha_succ (n : ℕ) : a (n + 1) = ((Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)).totient * (a n + 1) + 2 := rfl
  have ha3 : ∀ n, 3 ≤ a n := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih => match n with
      | 0 => rw [ha_zero]; rfl
      | n + 1 => rw [ha_succ]; have hM : 0 < (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3) := by
          apply Finset.prod_pos; intro i hi; apply Nat.sub_pos_of_lt; apply Nat.one_lt_pow (by norm_num); exact ih i (Finset.mem_range.mp hi)
        linarith [Nat.totient_pos.mpr hM]
  have ha_mono : StrictMono a := strictMono_nat_of_lt_succ fun n => by
    rw [ha_succ]; have hM : (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3) ≥ 5 := by
      calc (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
        _ ≥ 2 ^ a 0 - 3 := Finset.single_le_prod (fun i _ => by have := ha3 i; linarith [Nat.one_lt_pow (by norm_num) this]) (Finset.mem_range.mpr (Nat.succ_pos n))
        _ = 5 := by rw [ha_zero]; norm_num
    have : ((Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)).totient ≥ 2 := by
      apply Nat.totient_ge_two; linarith
    nlinarith [ha3 n]
  have h_cp (n m : ℕ) (h_lt : m < n) : Nat.Coprime (2 ^ a n - 3) (2 ^ a m - 3) := by
    induction n using Nat.strong_induction_on with
    | h n ih => match n with
      | 0 => linarith
      | n + 1 => set M := (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
        have h_odd : M % 2 = 1 := by
          apply Finset.prod_induction (fun x => x % 2 = 1) (fun x y hx hy => by rw [Nat.mul_mod, hx, hy]; rfl) rfl
          intro i _; have := ha3 i; rw [Nat.pow_mod, (by norm_num : 2 % 2 = 0)];
          have : 2 ^ a i ≥ 4 := Nat.le_trans (by norm_num) (Nat.pow_le_pow_right (by norm_num) (ha3 i))
          match 2 ^ a i % 2 with | 0 => rfl
        have h_mod : (2 ^ a (n + 1)) % M = 4 % M := by
          rw [ha_succ, pow_add, Nat.mul_mod, ← pow_mul]
          have hM1 : 1 < M := by have := Finset.single_le_prod (fun i _ => (by have := ha3 i; linarith [Nat.one_lt_pow (by norm_num) this] : 1 ≤ 2 ^ a i - 3)) (Finset.mem_range.mpr (Nat.succ_pos n)); rw [ha_zero] at this; linarith
          have hM2 : Nat.Coprime 2 M := by rw [Nat.coprime_comm, Nat.coprime_iff_gcd_eq_one, Nat.gcd_eq_one_at_prime Nat.prime_two, Nat.not_even_iff_odd]; exact h_odd
          rw [Nat.ModEq.pow_totient hM2 |>.pow (a n + 1) |>.mul (Nat.ModEq.refl 4) |>.mod_eq]; norm_num
        have h_gcd : Nat.gcd (2 ^ a (n + 1) - 3) M = 1 := by
          rw [Nat.gcd_mod]
          have hM4 : 4 < M := by have := Finset.single_le_prod (fun i _ => (by have := ha3 i; linarith [Nat.one_lt_pow (by norm_num) this] : 1 ≤ 2 ^ a i - 3)) (Finset.mem_range.mpr (Nat.succ_pos n)); rw [ha_zero] at this; linarith
          have : (2 ^ a (n + 1) - 3) % M = 1 := by
            have h23 : 2 ^ a (n + 1) ≥ 3 := by have := ha3 (n + 1); linarith [Nat.one_lt_pow (by norm_num) this]
            rw [Nat.ModEq.sub_mod h23, h_mod]; norm_num; rw [Nat.mod_eq_of_lt (by linarith)]
          rw [this, Nat.gcd_one_left]
        exact (Nat.coprime_iff_gcd_eq_one.mpr h_gcd).coprime_dvd_right (Finset.dvd_prod_of_mem (Finset.mem_range.mpr h_lt))
  use Set.range (fun n => ⟨a n, by have := ha3 n; linarith⟩)
  constructor
  · exact Set.infinite_range_of_injective ha_mono.injective
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    wlog h_lt : i < j
    · rw [Nat.coprime_comm]; exact this hne.symm (Nat.lt_or_gt_of_ne (ha_mono.injective.ne_iff.mp hne) |>.resolve_left h_lt)
    exact h_cp j i h_lt

end Imo1971P3
