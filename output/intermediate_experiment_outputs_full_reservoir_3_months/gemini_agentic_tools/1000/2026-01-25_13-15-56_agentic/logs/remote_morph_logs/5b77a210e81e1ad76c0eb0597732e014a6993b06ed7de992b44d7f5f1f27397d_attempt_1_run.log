```lean
import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let P : ℕ → ℕ := fun n => Nat.rec 1 (fun _ p => p * (2 ^ (p.totient + 2) - 3)) n
  have hP : ∀ n, 0 < P n ∧ P n % 2 = 1 := by
    intro n; induction n with
    | zero => rw [P]; norm_num
    | succ n ih =>
      rw [P]; constructor
      · apply Nat.mul_pos ih.1
        have : (P n).totient + 2 ≥ 3 := by have := Nat.totient_pos.mpr ih.1; linarith
        have : 2 ^ ((P n).totient + 2) ≥ 8 := Nat.pow_le_pow_right (by norm_num) this
        omega
      · rw [Nat.mul_mod, ih.2]
        have h_odd : (2 ^ ((P n).totient + 2) - 3) % 2 = 1 := by
          have h_ev : 2 ^ ((P n).totient + 2) = 2 * 2 ^ ((P n).totient + 1) := by
            have : (P n).totient + 2 = (P n).totient + 1 + 1 := rfl
            rw [this, pow_succ]
          rw [h_ev, Nat.sub_add_comm (by have := Nat.totient_pos.mpr ih.1; linarith [Nat.pow_le_pow_right (by norm_num) (show (P n).totient + 2 ≥ 1 by linarith)]), Nat.add_mul_mod_self_left]
          norm_num
        rw [h_odd]; norm_num
  let a : ℕ → ℕ+ := fun n => ⟨(P n).totient + 2, by have := Nat.totient_pos.mpr (hP n).1; linarith⟩
  have h_dvd_P : ∀ i n, i < n → 2 ^ (a i).val - 3 ∣ P n := by
    intro i n hi
    induction n with
    | zero => linarith
    | succ n ih =>
      rw [P]
      rcases Nat.lt_or_eq_of_le (Nat.le_of_lt_succ hi) with h | rfl
      · exact (ih h).mul_right _
      · exact Nat.dvd_mul_left _ _
  have h_cp : ∀ m n, m < n → Nat.Coprime (2 ^ (a n).val - 3) (2 ^ (a m).val - 3) := by
    intro m n hmn
    have h_pow_tot : 2 ^ (P n).totient ≡ 1 [MOD P n] :=
      Nat.ModEq.pow_totient (Nat.coprime_two_left.mpr (Nat.odd_iff.mpr (hP n).2))
    have h_pow_a : 2 ^ (a n).val ≡ 4 [MOD P n] := by
      have : (a n).val = (P n).totient + 2 := rfl
      rw [this, pow_add]
      exact (h_pow_tot.mul (by rfl)).trans (by norm_num)
    have h_mod_1 : 2 ^ (a n).val - 3 ≡ 1 [MOD P n] := by
      have h1 : 3 ≤ 2 ^ (a n).val := by
        have := Nat.totient_pos.mpr (hP n).1
        have : (a n).val ≥ 3 := by linarith
        exact Nat.pow_le_pow_right (by norm_num) this
      have h2 : 3 ≤ 4 := by norm_num
      exact Nat.ModEq.sub_right h1 h2 h_pow_a
    have h_gcd_1 : Nat.gcd (2 ^ (a n).val - 3) (P n) = 1 := by
      rw [Nat.ModEq.gcd_eq h_mod_1, Nat.gcd_one_left]
    apply Nat.Coprime.coprime_dvd_right _ (Nat.coprime_iff_gcd_eq_one.mpr h_gcd_1)
    exact h_dvd_P m n hmn
  use Set.range a
  constructor
  · apply Set.infinite_range_of_injective
    intro i j heq
    by_contra hne
    rcases Nat.lt_or_gt_of_ne hne with hlt | hlt
    · have hcp := h_cp i j hlt; rw [heq] at hcp
      have : 2 ^ (a j).val - 3 = 1 := Nat.coprime_self_iff.mp hcp
      have : (a j).val = 2 := by
        have : 2 ^ (a j).val = 4 := by omega
        exact (Nat.pow_left_injective (by norm_num)).1 this
      have : (a j).val ≥ 3 := by have := Nat.totient_pos.mpr (hP j).1; linarith
      linarith
    · have hcp := h_cp j i hlt; rw [heq] at hcp
      have : 2 ^ (a i).val - 3 = 1 := Nat.coprime_self_iff.mp hcp
      have : (a i).val = 2 := by
        have : 2 ^ (a i).val = 4 := by omega
        exact (Nat.pow_left_injective (by norm_num)).1 this
      have : (a i).val ≥ 3 := by have := Nat.totient_pos.mpr (hP i).1; linarith
      linarith
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    rcases Nat.lt_or_gt_of_ne (fun h => hne (by rw [h])) with h | h
    · exact h_cp i j h
    · rw [Nat.coprime_comm]; exact h_cp j i h

end Imo1971P3

