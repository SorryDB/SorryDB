import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 3
    | n + 1 => ((Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)).totient + 2
  termination_by n => n
  have ha : ∀ n, a n ≥ 3 := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih => match n with
      | 0 => rw [a]; norm_num
      | n + 1 => rw [a]; linarith [Nat.totient_pos.mpr (Finset.prod_pos (fun i hi => by
          have := ih i (Finset.mem_range.1 hi); linarith [Nat.one_lt_pow (by norm_num) this]))]
  have h_coprime : ∀ n m, m < n → (2 ^ a n - 3).Coprime (2 ^ a m - 3) := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih => intro m hmn; match n with
      | 0 => linarith
      | n + 1 =>
        set M := (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
        have hM_odd : M % 2 = 1 := by
          apply Nat.odd_iff.1; apply Nat.Odd.prod; intro i _; have := ha i
          rw [Nat.odd_iff, Nat.sub_mod (by linarith [Nat.one_lt_pow (by norm_num) this]), Nat.pow_mod (show 2 > 0 by norm_num)]; simp
        have hM_gt_1 : M > 1 := by
          have x0_ge_5 : 2 ^ a 0 - 3 ≥ 5 := by rw [a]; norm_num
          exact Nat.lt_of_le_of_lt (by norm_num) (Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 (Nat.zero_lt_succ n)) |> Nat.le_of_dvd (by linarith))
        have h2M : Nat.Coprime 2 M := (Nat.Prime.coprime_iff_not_dvd Nat.prime_two).mpr (Nat.not_even_iff_odd.2 hM_odd)
        have : 2 ^ a (n + 1) % M = 4 % M := by rw [a, pow_add, Nat.mul_mod, Nat.pow_totient_mod_eq_one hM_gt_1 h2M]; simp
        have h_gcd : (2 ^ a (n + 1) - 3).gcd M = 1 := by
          rw [Nat.gcd_rec, ← Nat.sub_mod (by have := ha (n + 1); linarith [Nat.one_lt_pow (by norm_num) this]), this]
          norm_num; exact Nat.gcd_one_left M
        exact (Nat.coprime_iff_gcd_eq_one.2 h_gcd).coprime_dvd_right (Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 hmn))
  use Set.range (fun n => (⟨a n, by linarith [ha n]⟩ : ℕ+))
  constructor
  · apply Set.infinite_range_of_injective; apply StrictMono.injective; apply strictMono_nat_of_lt_succ
    intro n; rw [a]; match n with
    | 0 => rw [a]; norm_num
    | n + 1 =>
      set M := (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
      set x := 2 ^ a (n + 1) - 3
      have h_cp : M.Coprime x := Nat.coprime_prod_left.2 (fun i hi => h_coprime (n + 1) i (Finset.mem_range.1 hi))
      rw [Nat.totient_mul_of_coprime h_cp]
      have hx : x.totient > 1 := Nat.one_lt_totient.2 (by have := ha (n+1); linarith [Nat.one_lt_pow (by norm_num) this])
      have hM : M.totient > 0 := Nat.totient_pos.mpr (Finset.prod_pos (fun i hi => by have := ha i; linarith [Nat.one_lt_pow (by norm_num) this]))
      nlinarith
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    dsimp; wlog h_lt : i < j
    · rw [Nat.coprime_comm]; apply this hne.symm (Nat.lt_or_gt_of_ne hne |>.resolve_left h_lt)
    exact h_coprime j i h_lt
