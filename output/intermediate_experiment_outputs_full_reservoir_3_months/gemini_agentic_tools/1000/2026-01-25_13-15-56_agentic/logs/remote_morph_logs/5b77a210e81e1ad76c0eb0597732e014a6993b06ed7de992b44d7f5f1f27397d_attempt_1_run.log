import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 3
    | n + 1 => (∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)).totient + 2
  termination_by n => n
  decreasing_by exact Finset.mem_range.1 ‹_›

  have ha_0 : a 0 = 3 := rfl
  have ha_succ n : a (n + 1) = (∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)).totient + 2 := rfl

  have ha3 : ∀ n, 3 ≤ a n := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => rw [ha_0]; exact Nat.le_refl 3
      | n + 1 =>
        rw [ha_succ]
        have hM : 0 < ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3) := by
          apply Finset.prod_pos; intro i hi; have hi' := ih i (Finset.mem_range.1 hi); omega
        have htot := Nat.totient_pos.mpr hM
        linarith

  have h_cp : ∀ n m, m < n → Nat.Coprime (2 ^ a n - 3) (2 ^ a m - 3) := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih => match n with
      | 0 => intro m h; linarith
      | n + 1 =>
        intro m hmn
        let M := ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)
        have hM_odd : M % 2 = 1 := by
          rw [Nat.prod_mod]
          have : (∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3) % 2) % 2 = 1 := by
            rw [Finset.prod_congr rfl (fun i _ => (show (2 ^ a i - 3) % 2 = 1 by
              have hi3 := ha3 i; have : 2 ^ a i = 2 * 2 ^ (a i - 1) := by rw [← pow_succ, Nat.sub_add_cancel (by linarith)]
              omega))]
            simp only [Finset.prod_const, one_pow, Nat.one_mod]
          exact this
        have hM_pos : 4 < M := by
          have h0 : (2 ^ a 0 - 3) ∣ M := Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 (Nat.zero_lt_succ n))
          have : 2 ^ a 0 - 3 = 5 := by rw [ha_0]; norm_num
          rw [← this] at *; apply Nat.le_of_dvd (by apply Finset.prod_pos; intro i _; have := ha3 i; omega) h0
        have h_mod : 2 ^ a (n + 1) % M = 4 % M := by
          rw [ha_succ, pow_add]
          have h2M : Nat.Coprime 2 M := Nat.coprime_two_left.mpr (Nat.odd_iff.mpr hM_odd)
          have h_euler := Nat.ModEq.pow_totient h2M
          rw [Nat.ModEq, Nat.one_mod] at h_euler
          rw [Nat.mul_mod, h_euler]; norm_num
        have h_gcd : (2 ^ a (n + 1) - 3).gcd M = 1 := by
          rw [Nat.gcd_comm, Nat.gcd_rec]
          have h_mod_eq : (2 ^ a (n + 1) - 3) % M = 1 := by
            have h_eq : (2 ^ a (n + 1) - 3) ≡ (4 - 3) [MOD M] := by
              apply Nat.ModEq.sub_right (by norm_num) (by omega) h_mod
            rw [Nat.ModEq] at h_eq; rw [h_eq]; norm_num; exact Nat.mod_eq_of_lt (by linarith)
          rw [h_mod_eq]; exact Nat.gcd_one_left M
        apply (Nat.coprime_iff_gcd_eq_one.mpr h_gcd).coprime_dvd_right
        exact Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 hmn)

  have ha_mono : StrictMono a := by
    apply strictMono_nat_of_lt_succ; intro n
    match n with
    | 0 => rw [ha_0, ha_succ]; norm_num [ha_0]
    | n + 1 =>
      let M := ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)
      have h_succ : a (n + 2) = (M * (2 ^ a (n + 1) - 3)).totient + 2 := by rw [ha_succ, Finset.prod_range_succ]
      have h_prev : a (n + 1) = M.totient + 2 := rfl
      have h_cop : M.Coprime (2 ^ a (n + 1) - 3) := by
        apply Nat.Coprime.prod_left; intro i hi; rw [Nat.coprime_comm]; exact h_cp (n + 1) i (Finset.mem_range.1 hi)
      rw [h_succ, Nat.totient_mul h_cop, h_prev]
      have hM_pos : 0 < M := by apply Finset.prod_pos; intro i _; have := ha3 i; omega
      have hx : 4 ≤ M.totient := by
        have : 5 ∣ M := by rw [← (show 2 ^ a 0 - 3 = 5 by rw [ha_0]; norm_num)]; exact Finset.dvd_prod_of_mem _ (Finset.mem_range.2 (Nat.zero_lt_succ n))
        have : 4 ∣ M.totient := by rw [← (show Nat.totient 5 = 4 by norm_num)]; apply Nat.totient_dvd_of_dvd this
        apply Nat.le_of_dvd (Nat.totient_pos hM_pos) this
      have hy : 2 ≤ (2 ^ a (n + 1) - 3).totient := by
        apply Nat.totient_even; have : a (n + 1) ≥ 6 := by rw [h_prev]; linarith [Nat.totient_pos hM_pos]
        omega
      nlinarith

  use Set.range (fun n => (⟨a n, by linarith [ha3 n]⟩ : ℕ+))
  constructor
  · apply Set.infinite_range_of_injective
    intro i j h; have h1 := PNat.ext_iff.mp h; exact ha_mono.injective h1
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    have hne' : i ≠ j := by intro h; apply hne; subst h; rfl
    obtain hij | hji := Nat.lt_or_gt_of_ne hne'
    · exact h_cp j i hij
    · rw [Nat.coprime_comm]; exact h_cp i j hji

end Imo1971P3
```
