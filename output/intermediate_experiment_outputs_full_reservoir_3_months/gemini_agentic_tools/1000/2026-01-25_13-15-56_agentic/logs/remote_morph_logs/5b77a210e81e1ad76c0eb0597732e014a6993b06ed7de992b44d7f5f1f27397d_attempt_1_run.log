import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 3
    | n + 1 => (∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)).totient + 2
  termination_by n => n
  decreasing_by exact Finset.mem_range.1 ‹_›

  have ha_eq (n : ℕ) : a n = match n with
    | 0 => 3
    | n + 1 => (∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)).totient + 2 := by
    match n with | 0 => rfl | n + 1 => rfl

  have ha3 : ∀ n, 3 ≤ a n := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih =>
      rw [ha_eq]
      match n with
      | 0 => exact Nat.le_refl 3
      | n + 1 =>
        have hM : 0 < ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3) := by
          apply Finset.prod_pos; intro i hi
          have hi' := ih i (Finset.mem_range.1 hi)
          apply Nat.sub_pos_of_lt
          calc 3 < 8 := by norm_num
               _ ≤ 2 ^ a i := Nat.pow_le_pow_right (by norm_num) hi'
        have htot := Nat.totient_pos.mpr hM
        linarith

  have h_cp : ∀ n m, m < n → Nat.Coprime (2 ^ a n - 3) (2 ^ a m - 3) := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih => match n with
      | 0 => intro m h; linarith
      | n + 1 =>
        intro m hmn
        let M := ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)
        have hM_odd : M % 2 = 1 := by
          apply Nat.odd_iff.mp
          apply Nat.Odd.prod; intro i _
          apply Nat.odd_iff.mpr
          have hi := ha3 i
          have h2a : 2 ^ a i = 2 * 2 ^ (a i - 1) := by rw [← pow_succ, Nat.sub_add_cancel (by linarith)]
          rw [h2a, Nat.sub_add_comm (by linarith [Nat.pow_le_pow_right (by norm_num) hi]), Nat.add_mul_mod_self_left]
          norm_num
        have hM_pos : 4 < M := by
          have h0 : 2 ^ a 0 - 3 = 5 := by rw [ha_eq]; norm_num
          calc 4 < 5 := by norm_num
               _ = 2 ^ a 0 - 3 := h0.symm
               _ ≤ M := Finset.single_le_prod (fun i _ => by have hi := ha3 i; linarith [Nat.pow_le_pow_right (by norm_num) hi]) (Finset.mem_range.2 (Nat.zero_lt_succ n))
        have h_mod : 2 ^ a (n + 1) % M = 4 % M := by
          have h_succ : a (n + 1) = M.totient + 2 := by rw [ha_eq]
          rw [h_succ, pow_add, Nat.mul_mod]
          have h2M : Nat.Coprime 2 M := Nat.coprime_two_left.mpr (Nat.odd_iff.mpr hM_odd)
          have h_euler := Nat.ModEq.pow_totient h2M.symm
          rw [Nat.ModEq, Nat.one_mod] at h_euler
          rw [h_euler]; norm_num
        have h_gcd : (2 ^ a (n + 1) - 3).gcd M = 1 := by
          rw [Nat.gcd_comm, Nat.gcd_rec]
          have h_mod_eq : (2 ^ a (n + 1) - 3) % M = 1 := by
            have h_eq : (2 ^ a (n + 1) - 3) ≡ (4 - 3) [MOD M] := by
              apply Nat.ModEq.sub_right h_mod
              · linarith [ha3 (n + 1), Nat.pow_le_pow_right (by norm_num) (ha3 (n + 1))]
              · norm_num
            rw [Nat.ModEq] at h_eq
            rw [h_eq]; norm_num; exact Nat.mod_eq_of_lt (by linarith)
          rw [h_mod_eq]; exact Nat.gcd_one_left M
        apply (Nat.coprime_iff_gcd_eq_one.mpr h_gcd).coprime_dvd_right
        exact Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 hmn)

  have ha_mono : StrictMono a := by
    apply strictMono_nat_of_lt_succ; intro n
    match n with
    | 0 => rw [ha_eq, ha_eq]; norm_num
    | n + 1 =>
      let M := ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)
      have h_succ : a (n + 2) = (M * (2 ^ a (n + 1) - 3)).totient + 2 := by rw [ha_eq, Finset.prod_range_succ]
      have h_prev : a (n + 1) = M.totient + 2 := by rw [ha_eq]
      have h_cop : Nat.Coprime M (2 ^ a (n + 1) - 3) := by
        apply Nat.Coprime.prod_left; intro i hi
        exact h_cp (n + 1) i (Finset.mem_range.1 hi)
      rw [h_succ, Nat.totient_mul h_cop, h_prev]
      have h_M_ge_5 : 5 ≤ M := by
