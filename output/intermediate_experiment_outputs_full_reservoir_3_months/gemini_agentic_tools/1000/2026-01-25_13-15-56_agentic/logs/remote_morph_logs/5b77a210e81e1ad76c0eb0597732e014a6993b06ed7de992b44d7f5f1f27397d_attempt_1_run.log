import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 2
    | n + 1 => (Nat.totient ((Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3))) * a n + 2
  have ha_ge_2 : ∀ n, a n ≥ 2 := by
    intro n; induction n with
    | zero => exact Nat.le_refl 2
    | succ n ih => dsimp [a]; linarith
  have ha_strict_mono : StrictMono a := by
    apply strictMono_nat_of_lt_succ
    intro n; dsimp [a]
    have h_prod_pos : (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3) > 0 := by
      apply Finset.prod_pos; intro i _; have := ha_ge_2 i; linarith [Nat.one_lt_pow (show 2 > 1 by norm_num) this]
    have h_tot_pos : Nat.totient _ > 0 := Nat.totient_pos.mpr h_prod_pos
    linarith [ha_ge_2 n]
  use Set.range (fun n => ⟨a n, by have := ha_ge_2 n; linarith⟩)
  constructor
  · apply Set.infinite_range_of_injective; exact StrictMono.injective ha_strict_mono
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hij
    dsimp; rw [Nat.coprime_comm]
    wlog h_lt : i < j
    · exact (this j i (Set.mem_range_self j) (Set.mem_range_self i) hij.symm (hij.lt_or_lt.resolve_left h_lt)).symm
    set M := (Finset.range j).prod (fun k => 2 ^ a k - 3)
    have h_dvd : (2 ^ a i - 3) ∣ M := Finset.dvd_prod (Finset.mem_range.mpr h_lt)
    have h_m_odd : M % 2 = 1 := by
      apply Finset.prod_induction (fun x => x % 2 = 1) (fun x y hx hy => by rw [Nat.mul_mod, hx, hy]; rfl) rfl
      intro k _; have h2 := ha_ge_2 k
      have : 2 ^ a k = 2 ^ (a k - 2) * 4 := by rw [← pow_add, Nat.sub_add_cancel h2]
      rw [this]; norm_num
    have h_coprime_2_M : Nat.Coprime 2 M := by
      rw [Nat.coprime_comm, Nat.coprime_iff_gcd_eq_one, Nat.gcd_eq_one_at_prime Nat.prime_two]; exact Nat.not_even_iff_odd.mpr h_m_odd
    have h_mod_M : 2 ^ a j % M = 4 % M := by
      have hj : a j = (Nat.totient M) * a (j - 1) + 2 := by cases j; · linarith; · rfl
      rw [hj, pow_add, Nat.mul_mod, ← pow_mul, Nat.pow_mod, Nat.ModEq.pow_totient h_coprime_2_M]
      simp
    have h_gcd : Nat.gcd (2 ^ a j - 3) M = 1 := by
      rw [Nat.gcd_rec, ← Nat.sub_mod (by have := ha_ge_2 j; linarith [Nat.one_lt_pow (show 2 > 1 by norm_num) this]), h_mod_M]
      have h_M_ge_1 : M ≥ 1 := by apply Finset.prod_induction (fun x => x ≥ 1) (fun x y hx hy => by nlinarith) (by linarith); intro k _; have := ha_ge_2 k; linarith [Nat.one_lt_pow (show 2 > 1 by norm_num) this]
      rw [Nat.sub_mod (by nlinarith)]; simp; exact Nat.gcd_one_left M
    exact Nat.coprime_of_dvd_right h_dvd (Nat.coprime_iff_gcd_eq_one.mpr h_gcd)

```
