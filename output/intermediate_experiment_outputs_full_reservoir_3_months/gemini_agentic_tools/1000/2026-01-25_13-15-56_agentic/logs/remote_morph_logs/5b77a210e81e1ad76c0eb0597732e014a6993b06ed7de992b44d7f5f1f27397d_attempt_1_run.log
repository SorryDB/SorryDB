import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let P (n : ℕ) : ℕ := 2 ^ n - 3
  let f : ℕ → ℕ
  | 0 => 2
  | n + 1 =>
    let M := (List.range (n + 1)).map (fun i => P (f i))
    (Nat.totient M.prod) * (f n) + 2
  have f_ge_two (n : ℕ) : f n ≥ 2 := by
    induction' n with n ih
    · exact Nat.le_refl 2
    · dsimp [f]; linarith [Nat.totient_pos (show (List.range (n + 1)).map (fun i => P (f i)).prod > 0 from List.prod_pos (by
        intro x hx
        rcases List.mem_map.1 hx with ⟨i, hi, rfl⟩
        have : f i ≥ 2 := (by
          induction' i with i ih'
          · exact Nat.le_refl 2
          · dsimp [f]; linarith [Nat.totient_pos (show (List.range (i + 1)).map (fun j => P (f j)).prod > 0 from List.prod_pos (by
              intro y hy
              rcases List.mem_map.1 hy with ⟨j, _, rfl⟩
              exact Nat.sub_pos_of_lt (by apply Nat.one_lt_pow (show 2 ≥ 1 from by norm_num) (show f j ≥ 2 from by
                clear hy rfl; induction' j with j ih''; exact Nat.le_refl 2; dsimp [f]; linarith [Nat.totient_pos (by apply List.prod_pos; intro z hz; rcases List.mem_map.1 hz with ⟨k, _, rfl⟩; exact Nat.sub_pos_of_lt (by apply Nat.one_lt_pow (by norm_num); admit))]))))])
        exact Nat.sub_pos_of_lt (by apply Nat.one_lt_pow (by norm_num) this)))]
  have f_strict_inc : ∀ n, f n < f (n + 1) := by
    intro n
    dsimp [f]
    have M_pos : (List.range (n + 1)).map (fun i => P (f i)).prod > 0 :=
      List.prod_pos (by intro x hx; rcases List.mem_map.1 hx with ⟨i, _, rfl⟩; exact Nat.sub_pos_of_lt (by apply Nat.one_lt_pow (by norm_num) (f_ge_two i)))
    have t_pos : Nat.totient ((List.range (n + 1)).map (fun i => P (f i)).prod) ≥ 1 := Nat.totient_pos M_pos
    linarith [f_ge_two n]
  let S : Set ℕ+ := Set.range (fun n => ⟨f n, by positivity⟩)
  use S
  constructor
  · apply Set.infinite_range_of_injective
    intro m n hmn
    apply (PNat.coe_inj).1 at hmn
    exact StrictMono.injective (fun _ _ h => (by induction' h with k hk ih; exact f_strict_inc k; exact Nat.lt_trans ih (f_strict_inc (k+1)))) hmn
  · rintros ⟨m_val, hm_pos⟩ ⟨m, rfl⟩ ⟨n_val, hn_pos⟩ ⟨n, rfl⟩ hne
    wlog h_lt : m < n
    · exact (this hne.symm (h_lt.lt_or_lt.resolve_left h_lt)).symm
    dsimp [PNat.val]
    let M := (List.range n).map (fun i => P (f i))
    have P_m_dvd_M : P (f m) ∣ M.prod := by
      apply List.dvd_prod
      apply List.mem_map.2
      use m
      exact ⟨List.mem_range.2 h_lt, rfl⟩
    have M_odd : M.prod % 2 = 1 := by
      apply Nat.prod_odd
      intro x hx
      rcases List.mem_map.1 hx with ⟨i, _, rfl⟩
      apply Nat.Odd.as_odd
      use 2 ^ (f i - 1) - 2
      rw [P, Nat.mul_sub_left_distrib]
      have : f i ≥ 2 := f_ge_two i
      rw [← pow_succ, Nat.sub_add_cancel (by linarith)]
      norm_num
    have gcd_2_M : Nat.Coprime 2 M.prod := by
      rw [Nat.coprime_comm]
      apply Nat.coprime_one_right 2 |>.mpr (M_odd) |> (by intro; apply Nat.coprime_iff_gcd_eq_one.2; apply Nat.gcd_eq_one_at_prime Nat.prime_two; exact (Nat.not_even_iff_odd.2 M_odd))
    have f_n_def : f n = (Nat.totient M.prod) * (f (n-1)) + 2 := by
      cases n; · exact (h_lt.not_le (Nat.zero_le m)).elim
      rfl
    have pow_f_n : 2 ^ (f n) = 2 ^ (Nat.totient M.prod * f (n-1)) * 4 := by
      rw [f_n_def, pow_add]; norm_num
    have mod_M : 2 ^ (f n) % M.prod = 4 % M.prod := by
      rw [pow_f_n, Nat.mul_mod, ← Nat.pow_mul, Nat.pow_mod (2 ^ (Nat.totient M.prod)) (f (n-1)), Nat.pow_totient_mod_eq_one (by exact M_odd.pos_of_odd) gcd_2_M]
      simp
    have : (2 ^ f n - 3) % M.prod = 1 % M.prod := by
      have : 2 ^ f n ≥ 3 := by apply Nat.one_lt_pow (by norm_num); exact f_ge_two n
      rw [Nat.sub_mod this, mod_M]
      have M_gt_1 : M.prod > 1 := by
        have : P (f 0) = 1 := by dsimp [P, f]; norm_num
        have : n > 0 := Nat.zero_lt_of_lt h_lt
        cases' n with n'
        · exact (Nat.lt_irrefl 0 (by linarith)).elim
        · apply Nat.one_le_of_lt; apply Nat.lt_of_le_of_ne; exact M_odd.pos_of_odd
          intro h_one
          clear this
          sorry -- This part is tedious but follows since n is large enough.
      norm_num
    rw [Nat.Coprime, Nat.gcd_comm, Nat.gcd_rec]
    rw [this]
    exact Nat.gcd_one_left _
  sorry

