import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 3
    | n + 1 => (Nat.totient (∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3))) * a n + 2
  termination_by n => n
  have ha_zero : a 0 = 3 := rfl
  have ha_succ (n : ℕ) : a (n + 1) = (Nat.totient (∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3))) * a n + 2 := rfl
  have ha3 : ∀ n, 3 ≤ a n := by {
    intro n
    induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => rw [ha_zero]; rfl
      | n + 1 =>
        rw [ha_succ]
        have hM : 0 < ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3) := by {
          apply Finset.prod_pos
          intro i hi
          apply Nat.sub_pos_of_lt
          calc 3 < 8 := by norm_num
               _ ≤ 2 ^ a i := Nat.pow_le_pow_right (by norm_num) (ih i (Finset.mem_range.mp hi))
        }
        have h_tot_pos := Nat.totient_pos.mpr hM
        have h_an_pos := ih n (Nat.lt_succ_self n)
        linarith
  }
  have ha_mono : StrictMono a := strictMono_nat_of_lt_succ fun n => by {
    rw [ha_succ]
    have hM : 5 ≤ ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3) := by {
      calc 5 = 2 ^ a 0 - 3 := by rw [ha_zero]; norm_num
           _ ≤ ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3) := by {
             apply Finset.single_le_prod
             · intro i _; have hi3 := ha3 i; linarith [Nat.one_lt_pow (by norm_num) hi3]
             · exact Finset.mem_range.mpr (Nat.succ_pos n)
           }
    }
    have : 2 ≤ Nat.totient (∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)) := by {
      apply Nat.totient_ge_two; linarith
    }
    have h_an := ha3 n
    linarith
  }
  have h_cp (n m : ℕ) (h_lt : m < n) : Nat.Coprime (2 ^ a n - 3) (2 ^ a m - 3) := by {
    induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => linarith
      | n + 1 =>
        set M := ∏ i ∈ Finset.range (n + 1), (2 ^ a i - 3)
        have hM_pos : 0 < M := by {
          apply Finset.prod_pos; intro i hi; apply Nat.sub_pos_of_lt
          calc 3 < 8 := by norm_num
               _ ≤ 2 ^ a i := Nat.pow_le_pow_right (by norm_num) (ha3 i)
        }
        have h_odd : M % 2 = 1 := by {
          apply Finset.prod_induction (fun x => x % 2 = 1) (fun x y hx hy => by { rw [Nat.mul_mod, hx, hy]; rfl }) rfl
          intro i _; have hi3 := ha3 i
          have h_form : 2 ^ a i - 3 = 2 * (2 ^ (a i - 1) - 2) + 1 := by {
            have : 2 ^ a i = 2 * 2 ^ (a i - 1) := by rw [← pow_succ, Nat.sub_add_cancel (by linarith)]
            rw [this]
            linarith [Nat.one_lt_pow (by norm_num : 1 < 2) (by linarith : 1 ≤ a i)]
          }
          rw [h_form, Nat.add_mul_mod_self_left]; rfl
        }
        have h_mod : (2 ^ a (n + 1)) % M = 4 % M := by {
          rw [ha_succ, pow_add, Nat.mul_mod, ← pow_mul]
          have h2M : M.Coprime 2 := by {
            rw [Nat.coprime_comm, Nat.coprime_iff_gcd_eq_one, Nat.gcd_eq_one_at_prime Nat.prime_two, Nat.not_even_iff_odd, Nat.odd_iff]
            exact h_odd
          }
          have h_tot := Nat.ModEq.pow_totient h2M
          rw [Nat.ModEq] at h_tot
          rw [h_tot, Nat.one_pow, Nat.one_mul, Nat.mod_mod]
        }
        have h_gcd : Nat.gcd (2 ^ a (n + 1) - 3) M = 1 := by {
          rw [Nat.gcd_mod]
          have hM4 : 4 < M := by {
             have := Finset.single_le_prod (fun i _ => (by have := ha3 i; linarith [Nat.one_lt_pow (by norm_num) this] : 1 ≤ 2 ^ a i - 3)) (Finset.mem_range.mpr (Nat.succ_pos n))
             rw [ha_zero] at this; linarith
          }
          have h_mod_sub : (2 ^ a (n + 1) - 3) % M = 1 := by {
            have h2a : 2 ^ a (n + 1) = M * (2 ^ a (n + 1) / M) + 4 := by {
              rw [← h_mod, Nat.mod_eq_of_lt hM4, Nat.div_add_mod]
            }
            have h_sub : 2 ^ a (n + 1) - 3 = M * (2 ^ a (n + 1) / M) + 1 := by linarith
            rw [h_sub, Nat.add_mul_mod_self_left]; rfl
          }
          rw [h_mod_sub]; norm_num; exact Nat.gcd_one_left M
        }
        apply (Nat.coprime_iff_gcd_eq_one.mpr h_gcd).coprime_dvd_right
        exact Finset.dvd_prod_of_mem (Finset.mem_range.mpr h_lt)
  }
  use Set.range (fun n => (⟨a n, by { have := ha3 n; linarith }⟩ : ℕ+))
  constructor
  · exact Set.infinite_range_of_injective ha_mono.injective
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hij
    have h_ij : i ≠ j := by { intro h; subst h; exact hij rfl }
    obtain h_lt | h_gt := Nat.lt_or_gt_of_ne h_ij
    · exact h_cp j i h_lt
    · rw [Nat.coprime_comm]; exact h_cp i j h_gt

end Imo1971P3
