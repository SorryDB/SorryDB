import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 3
    | n + 1 => ((Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)).totient + 2
  termination_by n => n
  have ha : ∀ n, 3 ≤ a n := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => rfl
      | n + 1 =>
        show 3 ≤ (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3).totient + 2
        apply Nat.succ_le_succ; apply Nat.succ_le_succ; apply Nat.totient_pos.mpr
        apply Finset.prod_pos; intro i hi
        apply Nat.sub_pos_of_lt; apply Nat.one_lt_pow (by norm_num); exact ih i (Finset.mem_range.1 hi)
  have h_coprime : ∀ n m, m < n → Nat.Coprime (2 ^ a n - 3) (2 ^ a m - 3) := by
    intro n; induction n using Nat.strong_induction_on with
    | h n ih => intro m hmn; match n with
      | 0 => linarith
      | n + 1 =>
        let M := (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
        have hM_odd : M % 2 = 1 := by
          apply Nat.odd_iff.1; apply Nat.odd_prod.2; intro i _; apply Nat.Odd.sub_odd
          · apply Nat.even_iff.2; apply Nat.even_pow.2 ⟨by norm_num, by linarith [ha i]⟩
          · use 1; norm_num
        have hM_gt_1 : 1 < M := by
          have h0 : 2 ^ a 0 - 3 = 5 := by rfl
          have hM : M = (Finset.range n).prod (fun i => 2 ^ a i - 3) * (2 ^ a n - 3) := Finset.prod_range_succ _ _
          exact Nat.lt_of_lt_of_le (by norm_num) (Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 (Nat.zero_lt_succ n)) |> Nat.le_of_dvd (by linarith))
        have h2M : Nat.Coprime 2 M := (Nat.Prime.coprime_iff_not_dvd Nat.prime_two).mpr (Nat.not_even_iff_odd.2 (Nat.odd_iff.2 hM_odd))
        have h4 : 2 ^ a (n + 1) % M = 4 % M := by
          show 2 ^ (((Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)).totient + 2) % M = 4 % M
          rw [pow_add, Nat.mul_mod, Nat.pow_totient_mod_eq_one hM_gt_1 h2M]; norm_num
        have h_gcd : Nat.gcd (2 ^ a (n + 1) - 3) M = 1 := by
          rw [Nat.gcd_rec, ← Nat.sub_mod (by apply Nat.one_le_pow (by norm_num); exact ha (n + 1)), h4]
          have hM_gt_4 : 4 < M := hM_gt_1.trans_le' (by norm_num)
          rw [Nat.mod_eq_of_lt hM_gt_4, Nat.mod_eq_of_lt (hM_gt_4.trans_le' (by norm_num))]
          norm_num; exact Nat.gcd_one_left M
        exact (Nat.coprime_iff_gcd_eq_one.2 h_gcd).dvd_right (Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 hmn))
  have ha_strict_mono : StrictMono a := by
    apply strictMono_nat_of_lt_succ; intro n; match n with
    | 0 => show a 0 < a 1; have a0 : a 0 = 3 := rfl; have a1 : a 1 = 6 := by unfold a; simp; rw [a0]; norm_num
      rw [a0, a1]; norm_num
    | n + 1 =>
      let M := (Finset.range (n + 1)).prod (fun i => 2 ^ a i - 3)
      have h_cp : M.Coprime (2 ^ a (n + 1) - 3) := Nat.coprime_prod_left.2 (fun i hi => h_coprime (n + 1) i (Finset.mem_range.1 hi))
      show a (n + 1) < a (n + 2); show a (n + 1) < M.totient * (2 ^ a (n + 1) - 3).totient + 2
      rw [Nat.totient_mul_of_coprime h_cp]
      have h_M_tot : M.totient = a (n + 1) - 2 := rfl
      have h_x_tot : (2 ^ a (n + 1) - 3).totient ≥ 4 := by
        apply Nat.le_trans (Nat.totient_ge_two (n := 2 ^ a (n + 1) - 3) (by linarith [ha (n+1)]))
        apply Nat.totient_even; linarith [ha (n+1)]
      rw [h_M_tot]; nlinarith [ha (n+1)]
  use Set.range (fun n => (⟨a n, by linarith [ha n]⟩ : ℕ+))
  constructor
  · apply Set.infinite_range_of_injective; exact StrictMono.injective ha_strict_mono
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hij
    dsimp; wlog h_lt : i < j
    · rw [Nat.coprime_comm]; apply this hij.symm (Nat.lt_or_gt_of_ne (StrictMono.injective ha_strict_mono |>.ne_iff.1 hij) |>.resolve_left h_lt)
    exact h_coprime j i h_lt

