import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let rec a : ℕ → ℕ
    | 0 => 3
    | n + 1 => Nat.totient (∏ i in Finset.range (n + 1), (2 ^ a i - 3)) + 2
  termination_by n => n
  have ha3 : ∀ n, 3 ≤ a n := by
    intro n
    induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => norm_num [a]
      | n + 1 =>
        have h_succ : a (n + 1) = Nat.totient (∏ i in Finset.range (n + 1), (2 ^ a i - 3)) + 2 := rfl
        rw [h_succ]
        have hM : 0 < ∏ i in Finset.range (n + 1), (2 ^ a i - 3) := by
          apply Finset.prod_pos; intro i hi
          have hi' := ih i (Finset.mem_range.1 hi)
          apply Nat.sub_pos_of_lt
          exact Nat.lt_of_lt_of_le (by norm_num) (Nat.pow_le_pow_right (by norm_num) hi')
        exact Nat.le_add_left 2 (Nat.totient_pos.mpr hM)
  have h_cp : ∀ n m, m < n → Nat.Coprime (2 ^ a n - 3) (2 ^ a m - 3) := by
    intro n
    induction n using Nat.strong_induction_on with
    | h n ih =>
      match n with
      | 0 => intro m h; linarith
      | n + 1 =>
        intro m hmn
        let M := ∏ i in Finset.range (n + 1), (2 ^ a i - 3)
        have hM_odd : M % 2 = 1 := by
          apply Finset.prod_induction (fun i => 2 ^ a i - 3) (fun x => x % 2 = 1) (fun x y hx hy => by rw [Nat.mul_mod, hx, hy]; rfl) (by rfl)
          intro i _; have hi := ha3 i
          have h2a : 2 ^ a i = 2 * 2 ^ (a i - 1) := by rw [← pow_succ, Nat.sub_add_cancel (by linarith)]
          rw [h2a, Nat.sub_add_comm (by linarith [Nat.pow_le_pow_right (by norm_num) hi]), Nat.add_mul_mod_self_left]; norm_num
        have hM_pos : 4 < M := by
          have h_zero : 2 ^ a 0 - 3 = 5 := by norm_num [a]
          calc 4 < 5 := by norm_num
               _ = 2 ^ a 0 - 3 := h_zero.symm
               _ ≤ M := Finset.single_le_prod (fun i _ => by have hi := ha3 i; linarith [Nat.pow_le_pow_right (by norm_num) hi]) (Finset.mem_range.2 (Nat.zero_lt_succ n))
        have h_mod : 2 ^ a (n + 1) % M = 4 % M := by
          have h_succ : a (n + 1) = Nat.totient M + 2 := rfl
          rw [h_succ, pow_add, Nat.mul_mod]
          have h2M : Nat.Coprime 2 M := Nat.coprime_two_left.mpr (Nat.odd_iff.mpr hM_odd)
          have h_euler := Nat.ModEq.pow_totient h2M.symm
          rw [Nat.ModEq, Nat.one_mod] at h_euler
          rw [h_euler]; norm_num
        have h_gcd : (2 ^ a (n + 1) - 3).gcd M = 1 := by
          rw [Nat.gcd_mod]
          have h_mod_sub : (2 ^ a (n + 1) - 3) % M = 1 := by
            have h_eq : (2 ^ a (n + 1) - 3) ≡ (4 - 3) [MOD M] := Nat.ModEq.sub_right h_mod (by norm_num)
            rw [h_eq]; norm_num; exact Nat.mod_eq_of_lt (by linarith)
          rw [h_mod_sub]; exact Nat.gcd_one_left M
        exact (Nat.coprime_iff_gcd_eq_one.mpr h_gcd).coprime_dvd_right (Finset.dvd_prod_of_mem (fun i => 2 ^ a i - 3) (Finset.mem_range.2 hmn))
  have ha_mono : StrictMono a := by
    apply strictMono_nat_of_lt_succ; intro n
    match n with
    | 0 => norm_num [a]
    | n + 1 =>
      have h_succ : a (n + 2) = Nat.totient (∏ i in Finset.range (n + 2), (2 ^ a i - 3)) + 2 := rfl
      have h_prev : a (n + 1) = Nat.totient (∏ i in Finset.range (n + 1), (2 ^ a i - 3)) + 2 := rfl
      let M := ∏ i in Finset.range (n + 1), (2 ^ a i - 3)
      have h_cop : Nat.Coprime M (2 ^ a (n + 1) - 3) := Nat.coprime_prod_left.mpr (fun i hi => h_cp (n + 1) i (Finset.mem_range.1 hi))
      rw [h_succ, Finset.prod_range_succ, Nat.totient_mul h_cop, h_prev]
      have h_M_ge_5 : 5 ≤ M := by
        have h_zero : 2 ^ a 0 - 3 = 5 := by norm_num [a]
        calc 5 = 2 ^ a 0 - 3 := h_zero.symm
             _ ≤ M := Finset.single_le_prod (fun i _ => by have hi := ha3 i; linarith [Nat.pow_le_pow_right (by norm_num) hi]) (Finset.mem_range.2 (Nat.zero_lt_succ n))
      have h_X_ge_61 : 61 ≤ 2 ^ a (n + 1) - 3 := by
        have h_a_n1 : 6 ≤ a (n + 1) := by
          rw [h_prev]; have h_phi := Nat.totient_ge_two h_M_ge_5; linarith
        calc 61 = 2 ^ 6 - 3 := by norm_num
             _ ≤ 2 ^ a (n + 1) - 3 := Nat.sub_le_sub_right (Nat.pow_le_pow_right (by norm_num) h_a_n1) 3
      have h_phi_M := Nat.totient_ge_two h_M_ge_5
      have h_phi_X := Nat.totient_ge_two h_X_ge_61
      nlinarith
  use Set.range (fun n => (⟨a n, by linarith [ha3 n]⟩ : ℕ+))
  constructor
  · exact Set.infinite_range_of_injective ha_mono.injective
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    obtain h | h := Nat.lt_or_gt_of_ne (ha_mono.injective.ne_iff.mp hne)
    · exact h_cp j i h
    · rw [Nat.coprime_comm]; exact h_cp i j h

end Imo1971P3

