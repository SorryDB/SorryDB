```lean
import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let P : ℕ → ℕ := fun n => n.rec 1 (fun _ p => p * (2 ^ (Nat.totient p + 2) - 3))
  have hP_pos : ∀ n, 0 < P n := by
    intro n; induction n with
    | zero => norm_num
    | succ n ih =>
      simp only [Nat.rec_succ]
      apply Nat.mul_pos ih
      have h_pow : (Nat.totient (P n) + 2) ≥ 3 := by
        have := Nat.totient_pos.mpr ih; omega
      have : 2 ^ (Nat.totient (P n) + 2) ≥ 8 := Nat.pow_le_pow_right (by norm_num) h_pow
      omega
  have hP_odd : ∀ n, Odd (P n) := by
    intro n; induction n with
    | zero => norm_num
    | succ n ih =>
      simp only [Nat.rec_succ]; apply Odd.mul ih
      have h_pow_ge : 2 ^ (Nat.totient (P n) + 2) ≥ 8 := by
        have h_pow : (Nat.totient (P n) + 2) ≥ 3 := by have := Nat.totient_pos.mpr (hP_pos n); omega
        exact Nat.pow_le_pow_right (by norm_num) h_pow
      apply Nat.odd_iff.mp; rw [Nat.odd_sub h_pow_ge]
      simp [Nat.even_pow.mpr ⟨by norm_num, by have := Nat.totient_pos.mpr (hP_pos n); omega⟩]
  let a : ℕ → ℕ+ := fun n => ⟨Nat.totient (P n) + 2, by have := Nat.totient_pos.mpr (hP_pos n); omega⟩
  have a_val (n : ℕ) : (a n).val = Nat.totient (P n) + 2 := rfl
  have P_succ (n : ℕ) : P (n + 1) = P n * (2 ^ (a n).val - 3) := rfl
  have h_cp : ∀ m n, m < n → Nat.Coprime (2 ^ (a n).val - 3) (2 ^ (a m).val - 3) := by
    intro m n hmn
    have h_dvd : (2 ^ (a m).val - 3) ∣ P n := by
      induction n with
      | zero => linarith
      | succ n ih =>
        rcases Nat.lt_or_eq_of_le (Nat.le_of_lt_succ hmn) with h_lt | rfl
        · rw [P_succ]; exact (ih h_lt).mul_right _
        · rw [P_succ]; exact Nat.dvd_mul_left _ _
    have h_mod : 2 ^ (a n).val ≡ 4 [MOD P n] := by
      rw [a_val, pow_add]
      have h2P : (2).Coprime (P n) := Nat.coprime_two_left.mpr (Nat.odd_iff.mpr (hP_odd n))
      exact (Nat.ModEq.pow_totient h2P).mul (by rfl) |>.trans (by norm_num)
    have h_mod_1 : (2 ^ (a n).val - 3) ≡ 1 [MOD P n] := by
      have h1 : 3 ≤ 2 ^ (a n).val := by
        have := Nat.totient_pos.mpr (hP_pos n); have : (a n).val ≥ 3 := by omega
        exact Nat.pow_le_pow_right (by norm_num) this
      exact Nat.ModEq.sub_right h_mod h1 (by norm_num)
    have h_gcd : (2 ^ (a n).val - 3).gcd (P n) = 1 := by
      rw [Nat.ModEq.gcd_eq h_mod_1, Nat.gcd_one_left]
    exact Nat.Coprime.coprime_dvd_right h_dvd (Nat.coprime_iff_gcd_eq_one.mpr h_gcd)
  have ha_mono : StrictMono a := by
    apply strictMono_nat_of_lt_succ; intro n
    match n with
    | 0 => simp [a_val, P]; norm_num
    | n + 1 =>
      let x_n1 := 2 ^ (a (n + 1)).val - 3
      have h_gcd : (P (n + 1)).Coprime x_n1 := by
        have h_mod : x_n1 ≡ 1 [MOD P (n + 1)] := by
          have h2P : (2).Coprime (P (n + 1)) := Nat.coprime_two_left.mpr (Nat.odd_iff.mpr (hP_odd (n + 1)))
          have h_mod' : 2 ^ (a (n + 1)).val ≡ 4 [MOD P (n + 1)] := by
            rw [a_val, pow_add]; exact (Nat.ModEq.pow_totient h2P).mul (by rfl) |>.trans (by norm_num)
          apply Nat.ModEq.sub_right h_mod' (by have := Nat.totient_pos.mpr (hP_pos (n + 1)); omega) (by norm_num)
        exact Nat.coprime_iff_gcd_eq_one.mpr (by rw [Nat.ModEq.gcd_eq h_mod, Nat.gcd_one_left])
      rw [a_val, P_succ, Nat.totient_mul h_gcd, a_val]
      have h_x_tot : Nat.totient x_n1 ≥ 2 := by
        apply Nat.totient_even; have : (a (n + 1)).val ≥ 6 := by
          have : a 1 = 6 := by simp [a_val, P]; norm_num
          induction n with | zero => rw [this]; | succ n ih =>
            have h1 := ih (by intro i; exact ih i); omega
        omega
      have h_P_tot : Nat.totient (P (n + 1)) > 0 := Nat.totient_pos.mpr (hP_pos (n + 1))
      nlinarith
  use Set.range a; constructor
  · exact Set.infinite_range_of_injective ha_mono.injective
  · rintro _ ⟨i, rfl⟩ _ ⟨j, rfl⟩ hne
    have hne' : i ≠ j := by intro h; apply hne; rw [h]
    rcases Nat.lt_or_gt_of_ne hne' with hlt | hgt
    · exact h_cp i j hlt
    · rw [Nat.coprime_comm]; exact h_cp j i hgt

end Imo1971P3

```
