import Mathlib.Tactic

import ProblemExtraction

problem_file { tags := [.NumberTheory] }

/-!
# International Mathematical Olympiad 1971, Problem 3

Prove that we can find an infinite set of positive integers of the form 2^n - 3
(where n is a positive integer) every pair of which are relatively prime.
-/

namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  let P : ℕ → ℕ := fun n => n.rec 1 (fun _ p => p * (2 ^ (p.totient + 2) - 3))
  have hP_pos : ∀ n, 0 < P n := by
    intro n; induction n with
    | zero => norm_num
    | succ n ih =>
      have h_pow : (P n).totient + 2 ≥ 3 := by have := Nat.totient_pos.mpr ih; omega
      have h_x_pos : 2 ^ ((P n).totient + 2) - 3 > 0 := by
        have : 2 ^ ((P n).totient + 2) ≥ 8 := Nat.pow_le_pow_right (by norm_num) h_pow
        omega
      show 0 < P n * (2 ^ ((P n).totient + 2) - 3); exact Nat.mul_pos ih h_x_pos
  have hP_odd : ∀ n, P n % 2 = 1 := by
    intro n; induction n with
    | zero => rfl
    | succ n ih =>
      show (P n * (2 ^ ((P n).totient + 2) - 3)) % 2 = 1
      rw [Nat.mul_mod, ih, Nat.one_mul, Nat.mod_mod]
