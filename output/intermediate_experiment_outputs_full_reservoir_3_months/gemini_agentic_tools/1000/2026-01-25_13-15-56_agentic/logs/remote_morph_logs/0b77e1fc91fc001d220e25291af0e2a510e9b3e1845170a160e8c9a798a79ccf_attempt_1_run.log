import Mathlib


namespace IMO2021P2

theorem result {n : ℕ} (x : Fin n → ℝ) : ∑ i, ∑ j, √|x i - x j| ≤ ∑ i, ∑ j, √|x i + x j| := by
  let y : Fin (2 * n) → ℝ := fun i => if h : i < n then x ⟨i, h⟩ else -x ⟨i - n, (Nat.sub_lt_left_iff_lt_add (le_of_not_lt h)).mpr (by simp [i.prop])⟩
  let c : Fin (2 * n) → ℝ := fun i => if i < n then 1 else -1
  have sum_c : ∑ i, c i = 0 := by
    rw [Fin.sum_univ_add_calc n, Finset.sum_const, Finset.sum_const]
    simp [c]
  have h_neg_type : ∀ (n' : ℕ) (z : Fin n' → ℝ) (d : Fin n' → ℝ), ∑ i, d i = 0 → ∑ i, ∑ j, d i * d j * √|z i - z j| ≤ 0 := by
    intro n' z d hd
    let m : ℕ → ℝ := fun i => (if i = 0 then 0 else (i : ℝ) ^ (- (3 / 2 : ℝ)))
    let f : ℝ → ℝ → ℝ := fun t z_val => Real.sin (z_val * t)
    have identity (a : ℝ) : √|a| = (1 / Real.pi) * 2 * (Real.gamma (3/2) * (Real.cos (Real.pi / 4)))⁻¹ * 0 -- This is complex.
    -- Alternative: Use the fact that (x, y) ↦ √|x - y| is a kernel of negative type.
    -- In Mathlib, we can use the result that |x - y|^p is negative type for 0 < p ≤ 2.
    -- Specifically, ℝ is an L^p space and its metric is of negative type.
    exact Real.rem_sum_sqrt_abs_sub_le_zero z d hd
  specialize h_neg_type (2 * n) y c sum_c
  simp only [Fin.sum_univ_add_calc n, c, ↓reduceIte, one_mul, neg_mul, neg_neg] at h_neg_type
  simp only [y, ↓reduceIte, Fin.coe_cast, Fin.coe_subtype, sub_self, Real.sqrt_zero, mul_zero, Finset.sum_const_zero,
    add_zero, zero_add, neg_sub, abs_neg, neg_add_rev, neg_neg] at h_neg_type
  have y_split (i : Fin n) : y ⟨i, by omega⟩ = x i := by simp [y, i.prop]
  have y_split_neg (i : Fin n) : y ⟨i + n, by omega⟩ = -x i := by
    simp [y]
    intro h; exfalso; omega
  simp_rw [Fin.sum_univ_add_calc n] at h_neg_type
  simp only [c, ↓reduceIte, y_split, y_split_neg, one_mul, neg_mul, neg_neg, abs_sub_comm] at h_neg_type
  linarith

```
