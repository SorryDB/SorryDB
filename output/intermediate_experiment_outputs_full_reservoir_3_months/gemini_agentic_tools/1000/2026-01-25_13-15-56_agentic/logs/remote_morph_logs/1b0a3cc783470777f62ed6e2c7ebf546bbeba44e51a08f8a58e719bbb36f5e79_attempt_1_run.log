import FLT.DedekindDomain.FiniteAdeleRing.BaseChange
import FLT.HaarMeasure.HaarChar.FiniteDimensional
import FLT.Mathlib.MeasureTheory.Constructions.BorelSpace.AdicCompletion
import FLT.Mathlib.NumberTheory.NumberField.FiniteAdeleRing
import Mathlib.Algebra.Central.Basic
/-!

# Haar character of the finite adele ring of a number field

We prove the crucial result that left and right multiplication by an element of `D ⊗[K] 𝔸_K^f`
scale Haar measure by the same factor, if D is a finite-dimensional central simple `K`-alegbra.

-/

open NumberField

open scoped TensorProduct

variable (K : Type*) [Field K] [NumberField K]

variable (B : Type*) [Ring B] [Algebra K B] [FiniteDimensional K B]

open scoped TensorProduct

open NumberField MeasureTheory

-- in FLT#823
instance (k A B : Type*) [Field k] [CommRing A] [Ring B]
    [Algebra k A] [Algebra k B]
    [Algebra.IsCentral k B] :
    Algebra.IsCentral A (A ⊗[k] B) where
  out := by
    have h_cent : Subsemiring.center (A ⊗[k] B) =
        (Subalgebra.centralizer k (Algebra.TensorProduct.includeRight (R := k) (A := A) (B := B)).range : Set (A ⊗[k] B)) := by
      refine Set.ext fun x => ⟨fun hx y hy => by obtain ⟨b, rfl⟩ := hy; exact hx y, fun hx y => ?_⟩
      induction y using TensorProduct.induction_on with
      | zero => simp
      | tmul a b =>
        rw [← Algebra.TensorProduct.includeLeft_apply, ← Algebra.TensorProduct.includeRight_apply,
          mul_assoc, Algebra.commutes, ← mul_assoc, hx _ ⟨b, rfl⟩, mul_assoc]
      | add y1 y2 ih1 ih2 => rw [mul_add, add_mul, ih1, ih2]
    apply Subalgebra.ext
    intro x
    rw [Subalgebra.mem_center_iff, h_cent, Subalgebra.centralizer_range_includeRight_eq_center_tensorProduct,
      Algebra.IsCentral.out]
    constructor
    · rintro ⟨y, rfl⟩
      induction y using TensorProduct.induction_on with
      | zero => use 0; simp
      | tmul a b =>
        obtain ⟨r, rfl⟩ := Algebra.mem_bot.1 b.2
        use r • a
        simp [Algebra.smul_def, Algebra.TensorProduct.includeLeft_apply]
      | add y1 y2 ih1 ih2 =>
        obtain ⟨a1, rfl⟩ := ih1; obtain ⟨a2, rfl⟩ := ih2
        use a1 + a2; simp
    · rintro ⟨a, rfl⟩
      use a ⊗ₜ 1; simp [Algebra.TensorProduct.includeLeft_apply]

