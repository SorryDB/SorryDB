/-- For complex measures `μ`, `ν` and integrable function `f`: `∫ f d(μ + ν) = ∫ f dμ + ∫ f dν` -/
lemma integral_add (μ ν : ComplexMeasure α) (f : α → ℂ) :
    ∫ a, f a ∂(μ + ν) = ∫ a, f a ∂μ + ∫ a, f a ∂ν := by
  dsimp [integral]
  let λ := μ.var + ν.var + (μ + ν).var
  have hμ : μ ≪ᵥ λ := (VectorMeasure.absolutelyContinuous_ennrealToMeasure_variation μ).trans
    (Measure.absolutelyContinuous_of_le (Measure.le_add_right (Measure.le_add_right (le_refl _))))
  have hν : ν ≪ᵥ λ := (VectorMeasure.absolutelyContinuous_ennrealToMeasure_variation ν).trans
    (Measure.absolutelyContinuous_of_le (Measure.le_add_right (Measure.le_add_left _ _)))
  have hμν : μ + ν ≪ᵥ λ := (VectorMeasure.absolutelyContinuous_ennrealToMeasure_variation (μ + ν)).trans
    (Measure.absolutelyContinuous_of_le (Measure.le_add_left _ _))
  have hμ_var : μ.var ≪ λ := Measure.absolutelyContinuous_of_le (Measure.le_add_right (Measure.le_add_right (le_refl _)))
  have hν_var : ν.var ≪ λ := Measure.absolutelyContinuous_of_le (Measure.le_add_right (Measure.le_add_left _ _))
  have hμν_var : (μ + ν).var ≪ λ := Measure.absolutelyContinuous_of_le (Measure.le_add_left _ _)
  rw [integral_rnDeriv_smul hμ hμ_var, integral_rnDeriv_smul hν hν_var, integral_rnDeriv_smul hμν hμν_var]
  simp_rw [← integral_add, ← add_mul]
  apply integral_congr_ae
  filter_upwards [VectorMeasure.rnDeriv_add hμ hν] with x hx
  rw [hx]
```
