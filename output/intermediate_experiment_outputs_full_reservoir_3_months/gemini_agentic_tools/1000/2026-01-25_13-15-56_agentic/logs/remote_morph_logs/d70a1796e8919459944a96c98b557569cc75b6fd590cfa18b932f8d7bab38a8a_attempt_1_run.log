      case isFalse he0' =>
        simp [*] at *
  | assert_range w e c ih =>
    simp [Circuit.eval, to_cs, to_wg, wrap, Cs.eval, ih]
    split_ifs with h_range
    · rw [reduce]
      · exact ih
      · exact bits_good w _ e h_range
    · rw [fail]
      · exact bits_bad w _ e h_range

