/--
Conjecture: The gcd condition is equivalent to the prime power condition.
-/
@[category research open, AMS 11]
theorem gcdCondition_iff_primePowerCondition (k : ℕ) (hk : 2 ≤ k) :
    GCDCondition k ↔ PrimePowerCondition k := by
  let g := (Finset.range k).gcd (fun i => Nat.choose ((i + 2) * k) k)
  let P := ((Nat.divisors k).filter IsPrimePow).max.getD 0
  constructor
  · intro hGCD
    unfold GCDCondition at hGCD
    unfold PrimePowerCondition
    by_contra! hPP
    have hg : g = 1 := hGCD
    -- If k/P ≤ P, then there exists a prime p such that p divides all binomial coefficients.
    -- If k is a prime power p^e, then P = p^e and k/P = 1 ≤ P.
    -- If k is not a prime power, but k/P ≤ P, there's a more complex dependency.
    -- In all such cases, g > 1, which contradicts hg = 1.
    have : g > 1 := sorry
    exact (this.ne_one hg)
  · intro hPP
    unfold GCDCondition
    unfold PrimePowerCondition at hPP
    -- If k/P > P, then for every prime p, there exists some i < k such that p does not divide choose((i+2)k, k).
    -- This is equivalent to saying that for any prime p, there's no common carry in base p
    -- for all additions k + (i+1)k.
    -- This property holds when k/P > P.
    apply Nat.eq_one_of_forall_prime_not_dvd
    · apply Nat.pos_of_ne_zero
      intro h
      have : Nat.choose (2 * k) k ≠ 0 := Nat.choose_ne_zero (by linarith)
      have : g ≠ 0 := by
        intro hg0
        rw [Finset.gcd_eq_zero_iff] at hg0
        specialize hg0 0 (Finset.mem_range.mpr (by linarith))
        exact this hg0
      exact this h
    · intro p hp
      intro hpdvd
      rw [Finset.dvd_gcd_iff] at hpdvd
      -- Kummer's theorem: p ∣ choose(n, k) iff there is a carry in k + (n-k) in base p.
      -- Here n = (i+2)k, so n-k = (i+1)k.
      -- So p ∣ choose((i+2)k, k) for all i < k implies a carry in k + (i+1)k for all i < k.
      -- This contradicts the condition k/P > P.
      sorry
