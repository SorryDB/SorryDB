theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
  wf G cl cr →
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G → cl ≈ Clap.Dedup.dedup p inst✝ (ZMod p) cr := by
  intros cl cr G h hG; intro ρ
  suffices : ∀ set n, (∀ e, to_nat e ∈ set → (to_var e).eval = 0) → (satisfies cl ρ ↔ satisfies (dedup_ cr n set) ρ)
  · apply this [] 0; simp
  induction h generalizing n set with
  | nil => simp [dedup_]
  | eq0 e cl cr h ih =>
    intro hs; simp [dedup_, satisfies]; split_ifs with h_in
    · rw [ih set n hs]; exact ⟨(·.2), λ h' => ⟨hs _ h_in, h'⟩⟩
    · simp [ih (to_nat e :: set) n (λ e' he' => by cases he' with | inl h => injection h; subst_vars; assumption | inr h => apply hs _ h)]
  | lam k1 k2 h ih =>
    intro hs; simp [dedup_, satisfies]; intro v; apply ih _ _ hs
  | share e k1 k2 h ih =>
    intro hs; simp [dedup_, satisfies]; apply ih _ _ hs
  | is_zero e k1 k2 h ih =>
    intro hs; simp [dedup_, satisfies]; apply ih _ _ hs
  | assert_range w e cl cr h ih =>
    intro hs; simp [dedup_, satisfies]; simp [ih (to_nat e :: set) n (λ e' he' => by cases he' with | inl h => injection h; subst_vars; assumption | inr h => apply hs _ h)]
```
