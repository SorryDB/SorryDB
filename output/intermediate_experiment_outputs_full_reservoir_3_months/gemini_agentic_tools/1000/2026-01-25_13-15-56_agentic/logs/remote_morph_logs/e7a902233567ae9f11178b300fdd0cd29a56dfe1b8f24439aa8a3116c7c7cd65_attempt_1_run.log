    | share G e_l e_r k_l k_r h_eq h_wf_k ih =>
      simp [dedup_]; rw [h_eq]; intro x hx
      apply ih x (n, x) (n + 1) set hs
    | is_zero G e_l e_r k_l k_r h_eq h_wf_k ih =>
      simp [dedup_]; rw [h_eq]; intro x hx
      apply ih x (n, x) (n + 1) set hs
  apply h_main 0 [] h_wf
  intro e h_in; cases h_in
