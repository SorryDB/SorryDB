  let P (set : List (Exp (ZMod p) ℕ)) := ∀ e, to_nat e ∈ set → (to_var e).eval ρ = 0
  have h_ih : ∀ n set, P set → (satisfies cl ρ ↔ satisfies (dedup_ cr n set) ρ) := by
    induction h generalizing n set with
    | nil => intros; simp [dedup_, satisfies]
    | eq0 e cl cr h ih =>
