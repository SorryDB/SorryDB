theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.eval entry.r.2)) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G h_wf h_G
  let P (set : List (Exp (ZMod p) ℕ)) : Prop := ∀ (e : Exp (ZMod p) (ℕ × ZMod p)), to_nat e ∈ set → (to_var e).eval = 0
  have h_main : ∀ {cl cr G} n set, wf G cl cr → P set → (cl ≈ (dedup_ cr n set : Circuit p (ZMod p))) := by
    intros cl cr G n set h hs
    induction h generalizing n set with
