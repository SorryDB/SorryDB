theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let m := 2 * n + 1
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let C (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), ↑(m.choose (2 * k)) * (3 : ZMod 5) ^ k
  let S (m : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (m + 1), ↑(m.choose (2 * k + 1)) * (3 : ZMod 5) ^ k
  have h_recur : ∀ m, (C (m + 1) = C m + 3 * S m) ∧ (S (m + 1) = C m + S m) := by
    intro m; constructor
    · unfold C S; rw [Finset.sum_range_succ' _ m, Nat.choose_zero_right, Nat.cast_one, pow_zero, mul_one, add_comm]
      simp only [Nat.choose_succ_succ, Nat.cast_add, Finset.sum_add_distrib, add_mul, Finset.mul_sum, ← pow_succ]
      simp only [← Finset.sum_range_succ, Nat.choose_eq_zero_of_lt (by linarith)]
      ring
    · unfold C S; simp only [Nat.choose_succ_succ, Nat.cast_add, Finset.sum_add_distrib, add_mul]
      simp only [← Finset.sum_range_succ, Nat.choose_eq_zero_of_lt (by linarith)]
      ring
  have hM : ∀ m, M ^ m = !![C m, 3 * S m; S m, C m] := by
    intro m; induction m with
    | zero => ext i j; fin_cases i <;> fin_cases j <;> simp [C, S, Nat.choose]
    | succ m ih =>
      rw [pow_succ, ih]; ext i j; fin_cases i <;> fin_cases j
      <;> simp [Matrix.mul_apply, Fin.sum_univ_two, (h_recur m).1, (h_recur m).2, M] <;> ring
  rw [← ZMod.natCast_eq_zero_iff _ 5, Nat.cast_sum]
  simp only [Nat.cast_mul, Nat.cast_pow, (by norm_num : (2 : ZMod 5) ^ 3 = 3), ← pow_mul]
  have h_sum_eq : (∑ k ∈ Finset.range (n + 1), ↑(m.choose (2 * k + 1)) * (3 : ZMod 5) ^ k) = S m := by
    unfold S; refine Finset.sum_subset (Finset.range_subset.mpr (by linarith)) ?_
    intro k hk hnk; have : m < 2 * k + 1 := by simp only [Finset.mem_range] at hk hnk; linarith
    simp [Nat.choose_eq_zero_of_lt this]
