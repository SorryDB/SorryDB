    intro m; unfold S C; simp only [Nat.choose_succ_succ, Nat.cast_add, Finset.sum_add_distrib]
    rw [Finset.sum_range_succ (range (m + 1)), Finset.sum_range_succ (range (m + 1))]
    simp [Nat.choose_eq_zero_of_lt]
  have h_C_rec : ∀ m, C (m + 1) = C m + 3 * S m := by
    intro m; unfold S C; rw [Finset.sum_range_succ' _ _ 0]
    simp only [Nat.choose_zero_right, Nat.cast_one, pow_zero, mul_one, Nat.choose_succ_succ, Nat.cast_add, 
               Finset.sum_add_distrib, Finset.mul_sum, ← pow_succ]
    rw [Finset.sum_range_succ (range (m + 1)), Finset.sum_range_succ (range (m + 1))]
    simp [Nat.choose_eq_zero_of_lt]
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  have hM : ∀ m, M ^ m = !![C m, 3 * S m; S m, C m] := by
    intro m; induction m with
