  have hM6 : M ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    have h3 : M ^ 3 = !![0, 3; 1, 0] := by decide
    rw [show 6 = 3 + 3 by rfl, pow_add, h3]; decide
  rw [Nat.div_add_mod m 6, pow_add, pow_mul, hM6]
  simp only [Matrix.smul_pow, Matrix.one_pow, Matrix.smul_mul, Matrix.mul_one, Matrix.smul_apply, Pi.smul_apply, Matrix.one_apply, mul_eq_zero]
  simp [pow_ne_zero _ (by norm_num : (3 : ZMod 5) ≠ 0)]
  have hm : m % 6 = 1 ∨ m % 6 = 3 ∨ m % 6 = 5 := by
