import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat Matrix

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd, Nat.cast_sum]
  set M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  have h_pow (m : ℕ) : M ^ m = !![∑ k ∈ Finset.range (m + 1), (m.choose (2 * k) * 3 ^ k : ZMod 5),
                                 3 * ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k + 1) * 3 ^ k : ZMod 5);
                                 ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k + 1) * 3 ^ k : ZMod 5),
                                 ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k) * 3 ^ k : ZMod 5)] := by
    induction m with
    | zero => simp [range_succ]; rfl
    | succ m ih =>
      rw [pow_succ, ih, Matrix.mul_fin_two]
      ext i j; fin_cases i <;> fin_cases j <;> simp [sum_range_succ, choose_succ_succ, mul_add, add_mul, add_assoc] <;>
      (try rw [Nat.choose_zero_right]; simp) <;>
      (try repeat rw [Nat.choose_eq_zero_of_lt (by linarith)]);
      all_goals (simp; ring)
  have h_odd (m : ℕ) : (M ^ (2 * m + 1)) 1 0 ≠ 0 := by
    induction m using Nat.strong_induction_on with
    | h m ih =>
      rcases m with _|m
      · simp [pow_one]; decide
      rcases m with _|m
      · have : 2 * 1 + 1 = 3 := rfl
        simp [this, pow_succ, Matrix.mul_fin_two]; decide
      rcases m with _|m
      · have : 2 * 2 + 1 = 5 := rfl
        simp [this, pow_succ, Matrix.mul_fin_two]; decide
      · have h6 : M ^ 6 = 3 * (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by decide
        have h_red : 2 * (m + 3) + 1 = (2 * m + 1) + 6 := by ring
        rw [h_red, pow_add, h6, Matrix.mul_smul, Matrix.mul_one]
        simp [ih m (by linarith)]
  simp [← h_pow]
  exact h_odd n

