set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat Matrix

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let m := 2 * n + 1
  let J : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  have hM : M = 1 + J := by decide
  have hJ2 : J ^ 2 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by decide
  have h_sum : (∑ k in Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) : ZMod 5) * 3 ^ k) = (M ^ m) 1 0 := by
    rw [hM, (Commute.one_left J).add_pow, Matrix.sum_apply]
    rw [Finset.sum_range_even_odd (n := n + 1), Finset.sum_add_distrib]
    have hJ_even k : J ^ (2 * k) = (3 ^ k : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
      induction k with
      | zero => simp
      | succ k ih => rw [Nat.mul_succ, pow_add, ih, hJ2, Matrix.smul_mul, Matrix.mul_smul, Matrix.one_mul, Matrix.mul_one, ← smul_assoc, mul_comm, ← pow_succ]; rfl
    have hJ_odd k : J ^ (2 * k + 1) = (3 ^ k : ZMod 5) • J := by
      rw [pow_succ, hJ_even, Matrix.smul_mul, Matrix.one_mul]
    have hJ_even_10 k : (J ^ (2 * k)) 1 0 = 0 := by rw [hJ_even]; simp
    have hJ_odd_10 k : (J ^ (2 * k + 1)) 1 0 = 3 ^ k := by rw [hJ_odd]; simp
    simp [hJ_even_10, hJ_odd_10]
  rw [← ZMod.natCast_zmod_eq_zero_iff_dvd, Nat.cast_sum]
  have h8 : (2 : ZMod 5) ^ 3 = 3 := by norm_num
  simp only [Nat.cast_mul, Nat.cast_pow, Nat.cast_two, ← pow_mul, h8, h_sum]
  have hM3 : M ^ 3 = J := by decide
  have hM6 : M ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    rw [show 6 = 3 + 3 by rfl, pow_add, hM3, ← hJ2]; rfl
  rw [Nat.div_add_mod m 6, pow_add, pow_mul, hM6]
  simp only [smul_pow, Matrix.one_pow, Matrix.smul_mul, Matrix.mul_one, Matrix.smul_apply, Matrix.one_apply, Pi.smul_apply, Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_cons, mul_one, mul_zero]
  have h3p : ∀ q, (3 : ZMod 5) ^ q ≠ 0 := fun q => pow_ne_zero q (by norm_num)
  simp only [h3p, mul_eq_zero, false_or]
  have hm_mod6 : m % 6 = 2 * (n % 3) + 1 := by
    have : m = 6 * (n / 3) + (2 * (n % 3) + 1) := by rw [n.div_add_mod 3, m]; ring
    rw [this, Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt]
    linarith [n.mod_lt (by norm_num)]
  rw [hm_mod6]
  rcases n.mod_lt (by norm_num) with h0 | h1 | h2
  · rw [h0]; decide
  · rw [h1]; decide
  · rw [h2, show 2 * 2 + 1 = 3 + 2 by rfl, pow_add, hM3]
    have hM2 : M ^ 2 = !![4, 1; 2, 4] := by decide
    rw [hM2]; decide
