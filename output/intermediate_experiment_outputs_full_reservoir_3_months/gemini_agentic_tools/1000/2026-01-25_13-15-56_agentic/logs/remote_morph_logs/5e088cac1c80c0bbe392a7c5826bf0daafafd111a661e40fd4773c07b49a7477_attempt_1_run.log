    simp only [Finset.sum_range_succ, Nat.choose_eq_zero_of_lt (by linarith), Nat.cast_zero, zero_mul, add_zero]
    ring
  have hM : ∀ m, M ^ m = !![C m, 3 * S m; S m, C m] := by
