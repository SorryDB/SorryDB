theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5 ∣ ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  rw [← ZMod.natCast_eq_zero_iff 5, Nat.cast_sum]
  let m := 2 * n + 1
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  have h_pow (m : ℕ) : M ^ m = !![∑ k ∈ Finset.range (m + 1), (m.choose (2 * k) : ZMod 5) * 3 ^ k,
                                 3 * ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k;
                                 ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k,
                                 ∑ k ∈ Finset.range (m + 1), (m.choose (2 * k) : ZMod 5) * 3 ^ k] := by
    induction m with
    | zero => ext i j; fin_cases i <;> fin_cases j <;> simp [Finset.sum_range_succ]
    | succ m ih =>
      rw [pow_succ, ih, Matrix.mul_fin_two]
      ext i j; fin_cases i <;> fin_cases j <;>
      simp [Finset.sum_range_succ, Nat.choose_succ_succ, Nat.cast_add, add_mul, mul_add, 
            Nat.choose_zero_right, Nat.choose_succ_self, Finset.mul_sum]
      · rw [Finset.sum_range_succ' _ (m + 1)]; simp [Nat.choose_eq_zero_of_lt, Nat.cast_zero, zero_mul]; ring
      · ring
      · ring
      · rw [Finset.sum_range_succ' _ (m + 1)]; simp [Nat.choose_eq_zero_of_lt, Nat.cast_zero, zero_mul]; ring
  
  have h_sum_eq : (∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1) : ZMod 5) * (2 ^ (3 * k) : ℕ)) = (M ^ m) 1 0 := by
    rw [h_pow m]
    simp only [Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_cons, Nat.cast_pow, Nat.cast_two]
    have h8 : (2 : ZMod 5) ^ 3 = 3 := by norm_num
    simp only [← pow_mul, mul_comm 3 k, pow_mul, h8]
    refine Finset.sum_subset (Finset.range_subset.mpr (by linarith)) ?_
    intro k hk hnk; rw [Nat.choose_eq_zero_of_lt (by linarith), Nat.cast_zero, zero_mul]

  rw [h_sum_eq]
  have hM3 : M ^ 3 = !![0, 3; 1, 0] := by
    have hM2 : M ^ 2 = !![4, 1; 2, 4] := by rw [show 2 = 1 + 1 by rfl, pow_succ, pow_one]; decide
    rw [show 3 = 2 + 1 by rfl, pow_succ, hM2]; decide
  have hM6 : M ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by rw [show 6 = 3 + 3 by rfl, pow_add, hM3]; decide
  
  rw [Nat.div_add_mod m 6, pow_add, pow_mul, hM6]
  simp only [smul_pow, Matrix.one_pow, Matrix.smul_mul, Matrix.mul_one, Matrix.smul_apply, 
             Matrix.one_apply, Pi.smul_apply, Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_cons, mul_one, mul_zero]
  
  have h3q : (3 : ZMod 5) ^ (m / 6) ≠ 0 := pow_ne_zero _ (by norm_num)
  intro h_zero; apply h3q
  have hm_mod6 : m % 6 = 2 * (n % 3) + 1 := by
    rw [n.div_add_mod 3, m]; ring_nf
    rw [Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt]
    linarith [n.mod_lt (by norm_num : 0 < 3)]
  rcases (n.mod_lt (by norm_num : 0 < 3)) with h_mod | h_mod | h_mod <;>
  rw [hm_mod6, h_mod] at h_zero <;>
  simp [hM3, Matrix.mul_fin_two, Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_cons] at h_zero
  · norm_num at h_zero
  · norm_num at h_zero
  · have hM2 : M ^ 2 = !![4, 1; 2, 4] := by rw [show 2 = 1 + 1 by rfl, pow_succ, pow_one]; decide
