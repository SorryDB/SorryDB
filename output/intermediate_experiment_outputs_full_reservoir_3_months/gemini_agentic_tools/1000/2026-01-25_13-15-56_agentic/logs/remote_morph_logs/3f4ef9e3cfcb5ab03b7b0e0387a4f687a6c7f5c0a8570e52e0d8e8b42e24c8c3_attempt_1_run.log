theorem trivialInvo_fixedPoints : (fixedPoints (trivialInvo k)).Nonempty := by
  classical
  let f : Equiv.Perm (T k) :=
  { toFun := trivialInvo k,
    invFun := trivialInvo k,
    left_inv := fun ⟨⟨⟨x, y, z⟩, _⟩, _⟩ => rfl,
    right_inv := fun ⟨⟨⟨x, y, z⟩, _⟩, _⟩ => rfl }
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  have h_mod := Equiv.Perm.card_fixedPoints_modEq f (by ext x; exact f.left_inv x)
  have h_fixed_odd : Odd (Finset.card (Equiv.Perm.fixedPoints f)) := by
    rwa [Nat.odd_iff, ← h_mod, ← Nat.odd_iff]
    exact card_T_odd k
  obtain ⟨x, hx⟩ := Finset.card_pos.mp h_fixed_odd.pos
  exact ⟨x, hx⟩
```
