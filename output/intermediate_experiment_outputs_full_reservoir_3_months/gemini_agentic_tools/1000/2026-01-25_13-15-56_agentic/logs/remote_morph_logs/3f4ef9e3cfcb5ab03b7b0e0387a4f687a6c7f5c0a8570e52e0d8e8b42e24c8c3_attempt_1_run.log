  classical
  haveI : Fact (Nat.Prime 2) := ⟨Nat.prime_two⟩
  have hf2 : (trivialInvo k) ^ (2 ^ 1) = 1 := by
    rw [pow_one]
    ext x
    obtain ⟨⟨⟨x, y, z⟩, hS⟩, hT⟩ := x
