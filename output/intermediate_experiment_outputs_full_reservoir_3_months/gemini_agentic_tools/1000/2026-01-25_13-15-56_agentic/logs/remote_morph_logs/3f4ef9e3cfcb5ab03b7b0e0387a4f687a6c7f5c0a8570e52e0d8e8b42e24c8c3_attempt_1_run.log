  have h_mod := Equiv.Perm.card_fixedPoints_modEq (p := 2) (n := 1) hf2
  have h_odd : Odd (Fintype.card (fixedPoints (trivialInvo k))) := by
    rw [Nat.odd_iff, ← h_mod, ← Nat.odd_iff]
    exact card_T_odd k
  exact Set.nonempty_coe_sort.mp (Fintype.card_pos_iff.mp h_odd.pos)
```
