  constructor; · exact hfg
  intro t h_eq
  dsimp at h_eq
  rw [lineMap_eq_iff f g hfg] at h_eq
  obtain ⟨h1, h2⟩ := h_eq
  replace h1 := (interAlong f).injective h1
  replace h2 := (interAlong g).injective h2
  have h_n2 : (n - 2) % 2 = 1 := by omega
  have h_p : ∀ (dir : Bool) (ti : Fin (n - 1)), (clap dir ti).val % 2 = (ti.val + if dir then 1 else 0) % 2 := by
    intro dir ti; rw [clap_def]; split_ifs <;> simp [Fin.val_rev]
    · have : ti.val ≤ n - 2 := by omega
      rw [Nat.sub_mod this, h_n2]; simp
    · rfl
  have hf : (clap (b f) t).val % 2 = k f g hfg % 2 := by rw [h1]
  have hg : (clap (b g) t).val % 2 = k g f hfg.symm % 2 := by rw [h2]
  rw [h_p] at hf hg
  have h_sum : (k f g hfg + k g f hfg.symm) % 2 =
      ((t.val + if b f then 1 else 0) + (t.val + if b g then 1 else 0)) % 2 := by
    rw [← Nat.add_mod, ← hf, ← hg, Nat.add_mod]
  rw [hb f g hfg] at h_sum
  cases hbf : b f <;> cases hbg : b g <;> simp [hbf, hbg] at h_sum <;> omega
