  intro f g hfg
  constructor; · exact hfg
  intro t h_eq
  rw [lineMap_eq_iff f g hfg] at h_eq
  obtain ⟨h1, h2⟩ := h_eq
  have hf_cl := (interAlong f).injective h1
  have hg_cl := (interAlong g).injective h2
  have h_hb := hb f g hfg
  revert hf_cl hg_cl h_hb
  simp [clap_def]
  cases b f <;> cases b g <;> (
