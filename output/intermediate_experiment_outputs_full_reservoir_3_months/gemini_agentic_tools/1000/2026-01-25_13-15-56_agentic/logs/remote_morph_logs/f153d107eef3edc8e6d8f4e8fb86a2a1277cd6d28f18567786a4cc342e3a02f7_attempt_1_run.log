    obtain ⟨hwt_e, mi_ext, T, hb_ext, hf1, hf2⟩ := hwt
    specialize ih hwf hwt_e; obtain ⟨mi, hb, hwt_proof⟩ := ih
    obtain ⟨mod, hbuild, hmi_eq⟩ := build_module_build_module_interface' hb_ext
    subst mi_ext; have hmi_alt : build_module_interface' ε e = some mod.2.toModuleInterface := by
      dsimp [build_module_interface']; rw [hbuild]; rfl
    rw [hmi_alt] at hb; cases hb
    exists mi.eraseIO c.output c.input
    dsimp [well_typed', well_typed''] at *
    simp [build_module_interface', hb, hwt_proof]
    exists T; exact ⟨hf1, hf2⟩
