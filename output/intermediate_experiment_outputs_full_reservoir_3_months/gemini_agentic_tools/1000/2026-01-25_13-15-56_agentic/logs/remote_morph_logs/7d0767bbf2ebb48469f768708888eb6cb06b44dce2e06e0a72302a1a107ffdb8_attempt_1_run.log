  }
  letI cβ : Category β := {
    Hom := fun _ _ => PUnit,
    id := fun _ => (),
    comp := fun _ _ => (),
    id_comp := fun _ => rfl,
    comp_id := fun _ => rfl,
    assoc := fun _ _ _ => rfl
  }
  let F : Functor α β := {
