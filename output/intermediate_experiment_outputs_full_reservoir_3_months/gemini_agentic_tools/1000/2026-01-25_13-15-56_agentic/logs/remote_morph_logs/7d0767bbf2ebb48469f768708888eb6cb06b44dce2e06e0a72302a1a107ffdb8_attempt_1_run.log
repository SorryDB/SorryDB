      | false, false, false, _, _ => ()
      | false, false, true, _, _ => ()
      | false, true, true, _, _ => ()
      | true, true, true, _, _ => (),
    id_comp := by intros; rcases X with ⟨x⟩; rcases Y with ⟨y⟩; cases x <;> cases y <;> (try cases f) <;> rfl,
