/-- Among n agents, to make k an expert, we need at least n-1 calls. -/
lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 < S.length := by
  induction S generalizing k
  case nil =>
    simp [after, initialState, isExpert, makeCalls] at h
    cases n
    · simp
    · case succ n =>
      cases n
      · simp
      · have h0 := h 0; have h1 := h 1
        simp [initialState] at h0 h1; subst h0; injection h1
  case cons c S' IH =>
    simp [after, makeCalls] at h
    induction n
    · simp
    · case succ n IHn =>
      -- Monotonicity of gossip states and calls allows us to relate
      -- the expert condition on a longer sequence to a smaller number of agents.
      -- This is a foundational property in gossip logic.
      sorry
```
