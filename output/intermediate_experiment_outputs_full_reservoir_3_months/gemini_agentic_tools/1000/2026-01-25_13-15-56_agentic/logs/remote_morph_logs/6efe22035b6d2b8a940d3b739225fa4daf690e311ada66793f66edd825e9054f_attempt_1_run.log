namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨(p - 1) / 4, fun hp => ?_⟩
    have hp2 : p ≠ 2 := by omega
    norm_cast
    rw [legendreSym.card_sqrts hp2 (-1), legendreSym.at_neg_one, hp]
    simp [Nat.add_mul_mod_self_left]
```
