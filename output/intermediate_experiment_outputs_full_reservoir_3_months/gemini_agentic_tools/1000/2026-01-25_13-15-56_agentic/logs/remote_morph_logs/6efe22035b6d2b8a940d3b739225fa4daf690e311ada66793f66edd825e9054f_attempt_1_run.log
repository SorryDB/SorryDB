namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨(p - 1) / 4, fun hp => ?_⟩
    have hp2 : p ≠ 2 := by omega
    haveI : NeZero p := ⟨h.1.ne_zero⟩
    let s_set : Finset (ZMod p) := {s | s ^ 2 = -1}
    change s_set.card = 2
    have h_card := ZMod.card_sqrts p (-1)
    have h_legendre : legendreSym p (-1) = 1 := by
      rw [legendreSym.at_neg_one hp2, hp]
      simp [Nat.add_mul_mod_self_left]
    rw [h_legendre] at h_card
    exact_mod_cast h_card
```
