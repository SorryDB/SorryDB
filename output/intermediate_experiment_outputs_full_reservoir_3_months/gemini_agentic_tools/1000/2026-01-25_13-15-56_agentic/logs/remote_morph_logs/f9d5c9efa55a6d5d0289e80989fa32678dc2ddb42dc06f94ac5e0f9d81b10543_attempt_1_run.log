lemma isStable_stronglyMeasurable_uncurry [OrderBot őĻ] [TopologicalSpace őĻ]
    [SecondCountableTopology őĻ] [OrderTopology őĻ] [MeasurableSpace őĻ] [BorelSpace őĻ] :
    IsStable ūĚďē (fun (X : őĻ ‚Üí ő© ‚Üí E) ‚Ü¶ StronglyMeasurable (uncurry X)) := by
  intro X hX ŌĄ hŌĄ
  let M : őĻ √ó ő© ‚Üí őĻ √ó ő© := fun p ‚Ü¶ ((min ‚ÜĎp.1 (ŌĄ p.2)).untopA, p.2)
  have hM : Measurable M := (WithTop.measurable_coe.comp measurable_fst).min
      (hŌĄ.measurable'.comp measurable_snd) |>.untopA.prodMk measurable_snd
  have h_eq : uncurry (stoppedProcess (fun i ‚Ü¶ {ŌČ | ‚ä• < ŌĄ ŌČ}.indicator (X i)) ŌĄ) =
      {p | ‚ä• < ŌĄ p.2}.indicator (uncurry X ‚ąė M) := by
    ext ‚ü®t, ŌČ‚ü©
    simp only
        [uncurry, stoppedProcess, Set.indicator_apply, Set.mem_setOf_eq, Function.comp_apply, M]
  rw [h_eq]
  exact StronglyMeasurable.indicator (hX.comp_measurable hM)
    (measurableSet_lt measurable_const (hŌĄ.measurable'.comp measurable_snd))

lemma isStable_progMeasurable [OrderBot őĻ] [MeasurableSpace őĻ] [TopologicalSpace őĻ]
  [PseudoMetrizableSpace őĻ] [BorelSpace őĻ] [SecondCountableTopology őĻ] [OrderTopology őĻ] :
    IsStable (E := E) ūĚďē (ProgMeasurable ūĚďē) := by
  refine fun X hX ŌĄ hŌĄ ‚Ü¶ ProgMeasurable.stoppedProcess ?_ hŌĄ
  intro i
  have h_prog : MeasurableSet[ūĚďē i] {ŌČ | ‚ä• < ŌĄ ŌČ} := by
    have hw: {ŌČ | ‚ä• < ŌĄ ŌČ} = {ŌČ | ŌĄ ŌČ ‚Č§ ‚ä•}Š∂ú := by
      ext ŌČ
      simp only [Set.mem_setOf_eq, Set.mem_compl_iff]
      exact lt_iff_not_ge
    rw [hw]
    convert (MeasurableSet.compl (ūĚďē.mono bot_le _ (hŌĄ ‚ä•)))
  exact StronglyMeasurable.indicator (hX i) <| measurable_snd h_prog


lemma ProgMeasurable.stronglyMeasurable_uncurry_stoppedProcess_const
    [TopologicalSpace őĻ] [OrderTopology őĻ] [MeasurableSpace őĻ] [BorelSpace őĻ] [OrderBot őĻ]
    {X : őĻ ‚Üí ő© ‚Üí E} {ūĚďē : Filtration őĻ mő©} (hX : ProgMeasurable ūĚďē X) (t : őĻ) :
    (StronglyMeasurable <| uncurry (stoppedProcess X (fun _ ‚Ü¶ t))) := by
  let g : őĻ √ó ő© ‚Üí (Set.Iic t) √ó ő© := fun p ‚Ü¶ (‚ü®min p.1 t, min_le_right p.1 t‚ü©, p.2)
  have hg_meas : @Measurable _ _ _
      (MeasurableSpace.prod (inferInstance : MeasurableSpace (Set.Iic t)) (ūĚďē t)) g := by
    apply Measurable.prodMk _ (measurable_snd.mono le_rfl (ūĚďē.le t))
    exact ((continuous_id.min continuous_const).measurable.comp measurable_fst).subtype_mk
  exact StronglyMeasurable.comp_measurable (hX t) hg_meas

lemma ProgMeasurable.stronglyMeasurable_uncurry_of_isCountablyGenerated_atTop
    [OrderBot őĻ] [TopologicalSpace őĻ] [OrderTopology őĻ] [MeasurableSpace őĻ] [BorelSpace őĻ]
    [IsCountablyGenerated (atTop : Filter őĻ)] {X : őĻ ‚Üí ő© ‚Üí E} {ūĚďē : Filtration őĻ mő©}
    (hX : ProgMeasurable ūĚďē X) : (StronglyMeasurable (uncurry X)) := by
  rcases exists_seq_monotone_tendsto_atTop_atTop (őĪ := őĻ) with ‚ü®t, -, ht_lim‚ü©
  refine stronglyMeasurable_of_tendsto atTop
    (fun n ‚Ü¶ stronglyMeasurable_uncurry_stoppedProcess_const hX (t n)) ?_
  rw [tendsto_pi_nhds]
  intro ‚ü®s, ŌČ‚ü©
  apply tendsto_const_nhds.congr'
  filter_upwards [ht_lim.eventually (Filter.eventually_ge_atTop s)] with n hn
  simp only [uncurry_apply_pair, stoppedProcess]
  rw [‚ÜźWithTop.coe_min, WithTop.untopA_coe, min_eq_left hn]

private lemma ProgMeasurable.aestronglyMeasurable_stoppedValue_stoppedProcess
    [OrderBot őĻ] [TopologicalSpace őĻ] [OrderTopology őĻ] [MeasurableSpace őĻ] [NoMaxOrder őĻ]
    [BorelSpace őĻ] [SecondCountableTopology őĻ] [PseudoMetrizableSpace őĻ]
    {X : őĻ ‚Üí ő© ‚Üí E} (hX_prog : ProgMeasurable ūĚďē X) {ŌĄ : ő© ‚Üí WithTop őĻ} (hŌĄ : IsStoppingTime ūĚďē ŌĄ)
    (sigma : {T | IsStoppingTime ūĚďē T ‚ąß ‚ąÄ (ŌČ : ő©), T ŌČ ‚Č† ‚ä§}) :
    AEStronglyMeasurable
