/-- If `{stoppedValue X T : T is a bounded stopping time}` is uniformly integrable, then `X` is
of class D. -/
lemma classD_of_uniformIntegrable_bounded_stoppingTime {ūĚďē : Filtration őĻ mő©} {X : őĻ ‚Üí ő© ‚Üí E}
    (hX : UniformIntegrable (fun T : {T | IsStoppingTime ūĚďē T ‚ąß ‚ąÉ t : őĻ, ‚ąÄ ŌČ, T ŌČ ‚Č§ t}
      ‚Ü¶ stoppedValue X T) 1 P) (hm : ProgMeasurable ūĚďē X) :
    ClassD X ūĚďē P := by
  have (T : {T | IsStoppingTime ūĚďē T ‚ąß ‚ąÄ ŌČ, T ŌČ ‚Č† ‚ä§}) :
    ‚ąÉ N : ‚Ąē ‚Üí {T | IsStoppingTime ūĚďē T ‚ąß ‚ąÉ t : őĻ, ‚ąÄ ŌČ, T ŌČ ‚Č§ t},
    ‚ąÄŠĶź ŌČ ‚ąāP, Tendsto (fun n ‚Ü¶ stoppedValue X (N n).1 ŌČ) atTop (nhds (stoppedValue X T.1 ŌČ)) := by
    obtain ‚ü®v, hv‚ü© := exists_seq_monotone_tendsto_atTop_atTop őĻ
    refine ‚ü®fun n => ‚ü®(fun ŌČ => v n) ‚äď T.1, ‚ü®IsStoppingTime.min ?_ T.2.1, ?_‚ü©‚ü©, ?_‚ü©
    ¬∑ exact (isStoppingTime_const ūĚďē (v n))
    ¬∑ exact ‚ü®v n, fun ŌČ => by simp‚ü©
    ¬∑ filter_upwards with ŌČ
      simp_all only [tendsto_atTop_atTop, tendsto_atTop_nhds]
      intro U hU _
      obtain ‚ü®N, hN‚ü© := hv.2 (T.1 ŌČ).untopA
      refine ‚ü®N, fun n hn => ?_‚ü©
      have : (T.1 ŌČ).untopA = T.1 ŌČ := by simp [WithTop.untopA_eq_untop (T.2.2 ŌČ)]
      rw [stoppedValue, Pi.inf_apply, ‚Üź this, ‚Üź WithTop.coe_min (v n) (T.1 ŌČ).untopA,
        min_eq_right (hN n hn)]
      simpa using hU
  exact ‚ü®hm, (hX.uniformIntegrable_of_tendsto_ae 1).comp
    (fun T : {T | IsStoppingTime ūĚďē T ‚ąß ‚ąÄ ŌČ, T ŌČ ‚Č† ‚ä§} => ‚ü®stoppedValue X T.1, this T‚ü©)‚ü©

variable [NormedSpace ‚ĄĚ E] [CompleteSpace E]

