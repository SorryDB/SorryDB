  ¬∑ exact ((stronglyMeasurable_stoppedValue_of_le (hX1.1.progMeasurable_of_rightContinuous
      hX2) T.2.1 T.2.2).mono (ūĚďē.le' t)).aestronglyMeasurable
  ¬∑ have : stoppedValue X T.1 ‚Č§ŠĶź[P] P[stoppedValue X (fun ŌČ => t)|T.2.1.measurableSpace] := by
      suffices lem : stoppedValue X ((fun ŌČ => t) ‚äď T.1) ‚Č§ŠĶź[P]
        P[stoppedValue X (fun ŌČ => t)|T.2.1.measurableSpace] from by
