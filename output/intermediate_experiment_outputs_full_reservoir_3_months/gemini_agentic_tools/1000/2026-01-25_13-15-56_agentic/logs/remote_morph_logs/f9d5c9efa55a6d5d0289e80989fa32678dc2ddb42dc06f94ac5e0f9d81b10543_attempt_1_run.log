  have hY_prog := isStable_progMeasurable X hX_prog ŌĄ hŌĄ
  have hY_sm := ProgMeasurable.stronglyMeasurable_uncurry_of_isCountablyGenerated_atTop hY_prog
  let idx_map : ő© ‚Üí őĻ := fun ŌČ ‚Ü¶ (sigma.val ŌČ).untop (sigma.property.2 ŌČ)
  have h_idx_meas : @Measurable ő© őĻ mő© _ idx_map := by
