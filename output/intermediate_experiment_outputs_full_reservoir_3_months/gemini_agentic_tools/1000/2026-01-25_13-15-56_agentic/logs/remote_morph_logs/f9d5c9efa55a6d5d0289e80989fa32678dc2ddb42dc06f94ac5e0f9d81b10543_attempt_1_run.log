/-! # Locally integrable, class D, class DL

-/

open MeasureTheory Filter Function TopologicalSpace
open scoped ENNReal


/-- Helper Lemma -/
@[simp]
lemma WithTop.untopA_coe {őĪ : Type*} [Nonempty őĪ] {ŌÉ : őĪ} :
    (ŌÉ : WithTop őĪ).untopA = ŌÉ := rfl

namespace ProbabilityTheory

variable {őĻ ő© E : Type*} [NormedAddCommGroup E] {mő© : MeasurableSpace ő©} {P : Measure ő©}
  {X : őĻ ‚Üí ő© ‚Üí E}

/-- The condition that the running supremum process `(t, ŌČ) ‚Ü¶ sup_{s ‚Č§ t} ‚ÄĖX s ŌČ‚ÄĖ` is strongly
measurable as a function on the product. -/
def HasStronglyMeasurableSupProcess [LinearOrder őĻ] [MeasurableSpace őĻ] (X : őĻ ‚Üí ő© ‚Üí E) : Prop :=
  (StronglyMeasurable (fun (tŌČ : őĻ √ó ő©) ‚Ü¶ ‚®Ü s ‚Č§ tŌČ.1, ‚ÄĖX s tŌČ.2‚ÄĖ‚āĎ))

/-- A stochastic process has integrable supremum if the function `(t, ŌČ) ‚Ü¶ sup_{s ‚Č§ t} ‚ÄĖX s ŌČ‚ÄĖ`
is strongly measurable and if for all `t`, the random variable `ŌČ ‚Ü¶ sup_{s ‚Č§ t} ‚ÄĖX s ŌČ‚ÄĖ`
is integrable. -/
def HasIntegrableSup [LinearOrder őĻ] [MeasurableSpace őĻ] (X : őĻ ‚Üí ő© ‚Üí E)
    (P : Measure ő© := by volume_tac) : Prop :=
  (HasStronglyMeasurableSupProcess (mő©:= mő©) X) ‚ąß
     (‚ąÄ t, Integrable (fun ŌČ ‚Ü¶ ‚®Ü s ‚Č§ t, ‚ÄĖX s ŌČ‚ÄĖ‚āĎ) P)

/-- A stochastic process has locally integrable supremum if it satisfies locally the property that
for all `t`, the random variable `ŌČ ‚Ü¶ sup_{s ‚Č§ t} ‚ÄĖX s ŌČ‚ÄĖ` is integrable. -/
def HasLocallyIntegrableSup [LinearOrder őĻ] [OrderBot őĻ] [TopologicalSpace őĻ] [OrderTopology őĻ]
    [MeasurableSpace őĻ] (X : őĻ ‚Üí ő© ‚Üí E) (ūĚďē : Filtration őĻ mő©)
    (P : Measure ő© := by volume_tac) : Prop :=
  Locally (HasIntegrableSup ¬∑ P) ūĚďē X P

section Defs

variable [Preorder őĻ] [Nonempty őĻ] [MeasurableSpace őĻ]

/-- A stochastic process $(X_t)$ is of class D (or in the Doob-Meyer class) if it is adapted
and the set $\{X_\tau \mid \tau \text{ is a finite stopping time}\}$ is uniformly integrable. -/
structure ClassD (X : őĻ ‚Üí ő© ‚Üí E) (ūĚďē : Filtration őĻ mő©) (P : Measure ő©) :
    Prop where
  progMeasurable : ProgMeasurable ūĚďē X
  uniformIntegrable : UniformIntegrable
    (fun (ŌĄ : {T : ő© ‚Üí WithTop őĻ | IsStoppingTime ūĚďē T ‚ąß ‚ąÄ ŌČ, T ŌČ ‚Č† ‚ä§}) ‚Ü¶ stoppedValue X ŌĄ.1) 1 P

/-- A stochastic process $(X_t)$ is of class DL if it is adapted and for all $t$, the set
$\{X_\tau \mid \tau \text{ is a stopping time with } \tau \le t\}$ is uniformly integrable. -/
structure ClassDL (X : őĻ ‚Üí ő© ‚Üí E) (ūĚďē : Filtration őĻ mő©) (P : Measure ő©) :
    Prop where
  progMeasurable : ProgMeasurable ūĚďē X
  uniformIntegrable (t : őĻ) : UniformIntegrable
    (fun (ŌĄ : {T : ő© ‚Üí WithTop őĻ | IsStoppingTime ūĚďē T ‚ąß ‚ąÄ ŌČ, T ŌČ ‚Č§ t}) ‚Ü¶ stoppedValue X ŌĄ.1) 1 P

lemma ClassD.classDL {ūĚďē : Filtration őĻ mő©} {X : őĻ ‚Üí ő© ‚Üí E} (hX : ClassD X ūĚďē P) :
    ClassDL X ūĚďē P := by
  let f (t : őĻ) : {T | IsStoppingTime ūĚďē T ‚ąß ‚ąÄ (ŌČ : ő©), T ŌČ ‚Č§ t} ‚Üí
      {T | IsStoppingTime ūĚďē T ‚ąß ‚ąÄ (ŌČ : ő©), T ŌČ ‚Č† ‚ä§} :=
    fun ŌĄ => ‚ü®ŌĄ, ŌĄ.2.1, fun ŌČ => ne_of_lt
      (lt_of_le_of_lt (ŌĄ.2.2 ŌČ) (WithTop.coe_lt_top t))‚ü©
  exact ‚ü®hX.1, fun t => hX.2.comp (f t)‚ü©

end Defs

