lemma _root_.MeasureTheory.Submartingale.classDL (hX1 : Submartingale X ūĚďē P)
    (hX2 : ‚ąÄ ŌČ, RightContinuous (X ¬∑ ŌČ)) (hX3 : 0 ‚Č§ X) :
    ClassDL X ūĚďē P := by
