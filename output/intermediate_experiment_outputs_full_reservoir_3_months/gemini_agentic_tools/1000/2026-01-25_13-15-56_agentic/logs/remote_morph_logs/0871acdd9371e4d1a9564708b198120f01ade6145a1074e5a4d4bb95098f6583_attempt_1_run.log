/-- `unreverse x` has no reversible positions. -/
theorem not_reversible_unreverse (hy : y ∈ x.unreverse.moves p) : ¬ Reversible x.unreverse y p := by
  rw [moves_unreverse, Set.mem_iUnion₂] at hy
  obtain ⟨y, hy, ⟨z, hz, rfl⟩⟩ := hy
  by_cases h : Reversible x y p
  · cases p <;> rintro ⟨w', hw', hle⟩
    · rw [moves_unreverse, Set.mem_iUnion₂] at hw'
      obtain ⟨v, hv, ⟨w, hw, rfl⟩⟩ := hw'
      have := subposition_of_mem_reverseSet hv hw
      grw [unreverse_equiv, unreverse_equiv] at hle
      rw [reverseSet] at hw
      split_ifs at hw with h'
      · exact lf_right hw ((hle.trans h.choose_le).trans h'.le_choose)
      · subst hw
        exact mt h.choose_le.trans' (lf_right hv hle)
    · rw [moves_unreverse, Set.mem_iUnion₂] at hw'
      obtain ⟨v, hv, ⟨w, hw, rfl⟩⟩ := hw'
      have := subposition_of_mem_reverseSet hv hw
      grw [unreverse_equiv, unreverse_equiv] at hle
      rw [reverseSet] at hw
      split_ifs at hw with h'
      · exact left_lf hw (h'.choose_le.trans (h.le_choose.trans hle))
      · subst hw
        exact mt h.le_choose.trans (left_lf hv hle)
  · cases p <;> rintro ⟨w', hw', hle⟩
    · rw [reverseSet_of_not_reversible h] at hz
      subst hz
      rw [moves_unreverse, Set.mem_iUnion₂] at hw'
      obtain ⟨v, hv, ⟨w, hw, rfl⟩⟩ := hw'
      have := subposition_of_mem_reverseSet hv hw
      grw [unreverse_equiv, unreverse_equiv] at hle
      rw [reverseSet] at hw
      split_ifs at hw with h'
      · exact mt h.choose_le.trans (left_lf hv (h'.choose_le.trans hle))
      · subst hw
        exact h ⟨v, hv, hle⟩
    · rw [reverseSet_of_not_reversible h] at hz
      subst hz
      rw [moves_unreverse, Set.mem_iUnion₂] at hw'
      obtain ⟨v, hv, ⟨w, hw, rfl⟩⟩ := hw'
      have := subposition_of_mem_reverseSet hv hw
      grw [unreverse_equiv, unreverse_equiv] at hle
      rw [reverseSet] at hw
      split_ifs at hw with h'
      · exact mt h.le_choose.trans' (lf_right hv (hle.trans h'.le_choose))
      · subst hw
        exact h ⟨v, hv, hle⟩
