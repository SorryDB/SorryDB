/-- Given a noHo sequence, to make k an expert and make everyone know k, we need this many calls. -/
lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  -- For each agent j ≠ k, we consider the first call that carries j's secret to k,
  -- and the last call that carries k's secret to j. In a noHo sequence,
  -- these 2(n-1) calls are distinct unless they involve agent k.
  -- Thus, (n-1) + (n-1) ≤ S.length + v S k.
  have : 2 * n ≤ S.length + v S k + 2 := by
    induction S with
    | nil =>
      simp at h h2
      cases n with
      | zero => simp
      | succ n =>
        cases n with
        | zero => simp
        | succ n =>
          specialize h ⟨1, by omega⟩
          simp [after, makeCalls, initialState] at h
    | cons c S' ih =>
      -- The inequality follows from the distinctness of path-defining calls.
      -- In a noHo sequence, each call not involving k can serve at most one requirement.
      -- Each call involving k can serve at most two (one learning, one spreading).
      -- The total requirements for k to be an expert and spread his secret are 2(n-1).
      -- Thus 2(n-1) ≤ 1 * count(k ∉ c) + 2 * count(k ∈ c) = S.length + v S k.
      sorry
  omega
```
