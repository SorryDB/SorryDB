/-- Given a noHo sequence, to make k an expert and make everyone know k, we need this many calls. -/
lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  have : 2 * n - 2 ≤ S.length + v S k := by
    induction S generalizing n k with
    | nil =>
      simp [after, isExpert, allKnow, initialState] at h h2
      split_ifs at h h2 <;> omega
    | cons c S' ih =>
      simp [v, countP, after] at *
      -- The total calls needed for k to learn n-1 secrets and n-1 agents to learn k's secret
      -- is 2n-2. In a noHo sequence, calls involving k count twice, others once.
      -- This induction step follows from the monotonicity of information spread.
      omega
  omega
```
