/-- Given a noHo sequence, to make k an expert and make everyone know k, we need this many calls. -/
lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  -- use Lemma 6 "calls needed for both spreading and informing are those in v S k"
  have h_f_end : (Finset.univ.filter (λ j => (after S) k j)).card + (Finset.univ.filter (λ j => (after S) j k)).card = 2 * n := by
    have h1 : (Finset.univ.filter (λ j => (after S) k j)) = Finset.univ := by ext; simp; exact h _
    have h2' : (Finset.univ.filter (λ j => (after S) j k)) = Finset.univ := by ext; simp; exact h2 _
    rw [h1, h2']
    simp [Finset.card_univ, Fintype.card_fin, Nat.two_mul]
  have h_f_bound : (Finset.univ.filter (λ j => (after S) k j)).card + (Finset.univ.filter (λ j => (after S) j k)).card ≤ S.length + v S k + 2 := by
    sorry
  exact Nat.sub_le_of_le_add (Nat.sub_le_of_le_add (h_f_end ▸ h_f_bound))
```
