lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable [IsFiniteMeasure P]
    [PseudoMetrizableSpace ι] [BorelSpace ι] (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  have h_prog := hX1.adapted.progMeasurable_of_rightContinuous hX2
  refine ⟨fun h ↦ ?_, fun h ↦ ?_⟩
  · let cs (t : ι) : {T | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} :=
      ⟨fun ω ↦ t, isStoppingTime_const 𝓕 t, fun _ ↦ WithTop.coe_ne_top⟩
    have : X = (fun τ ↦ stoppedValue X τ.1) ∘ cs := by
      ext t ω; simp [stoppedValue]
    rw [this]
    exact h.uniformIntegrable.comp cs
  · rw [uniformIntegrable_iff_norm (fun t ↦ (hX1.integrable t).aestronglyMeasurable)] at h
    let Y := fun t ω ↦ ‖X t ω‖
    have hY_sub : Submartingale Y 𝓕 P := hX1.submartingale_convex_comp
      (convexOn_norm convex_univ) continuous_norm (fun t ↦ (hX1.integrable t).norm)
    have hY_bounded := hY_sub.uniformIntegrable_bounded_stoppingTime
      (fun ω t ↦ (hX2 ω t).norm) (fun t ω ↦ norm_nonneg _) h
    refine classD_of_uniformIntegrable_bounded_stoppingTime ?_ h_prog
    rw [uniformIntegrable_iff_norm (fun τ ↦ ?_)]
    · convert hY_bounded using 1
      ext τ ω; simp [stoppedValue, Y]
    · obtain ⟨t, ht⟩ := τ.2.2
      exact ((stronglyMeasurable_stoppedValue_of_le h_prog τ.2.1 ht).mono (𝓕.le' t)).aestronglyMeasurable
```
