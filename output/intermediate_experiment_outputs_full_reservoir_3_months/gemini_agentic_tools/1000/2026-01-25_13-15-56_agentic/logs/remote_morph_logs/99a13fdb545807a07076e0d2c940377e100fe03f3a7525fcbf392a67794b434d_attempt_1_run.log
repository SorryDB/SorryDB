lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable [IsFiniteMeasure P]
    [PseudoMetrizableSpace ι] [BorelSpace ι] (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  have h_prog := hX1.adapted.progMeasurable_of_rightContinuous hX2
  have hY_sub : Submartingale (fun t ω ↦ ‖X t ω‖) 𝓕 P := hX1.submartingale_convex_comp
    (convexOn_norm convex_univ) continuous_norm (fun t ↦ (hX1.integrable t).norm)
  refine ⟨fun h ↦ ?_, fun h ↦ ?_⟩
  · rw [uniformIntegrable_iff_norm (fun t ↦ (hX1.integrable t).aestronglyMeasurable)]
    let f (t : ι) : {T | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} :=
      ⟨fun ω ↦ t, isStoppingTime_const 𝓕 t, fun _ ↦ WithTop.coe_ne_top⟩
    exact h.uniformIntegrable.comp f
  · rw [uniformIntegrable_iff_norm (fun t ↦ (hX1.integrable t).aestronglyMeasurable)] at h
    have hY_UI := MeasureTheory.Submartingale.classD_iff_uniformIntegrable hY_sub
      (fun ω t ↦ (hX2 ω t).norm) (fun t ω ↦ norm_nonneg _) |>.mpr h
    refine ⟨h_prog, ?_⟩
    have h_ae (τ : {T | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤}) :
        AEStronglyMeasurable (stoppedValue X τ.1) P := by
      obtain ⟨v, hv⟩ := exists_seq_monotone_tendsto_atTop_atTop ι
      let τn (n : ℕ) : Ω → WithTop ι := (fun ω ↦ v n) ⊓ τ.1
      refine aestronglyMeasurable_of_tendsto_ae (fun n ↦ ?_) (Eventually.of_forall (fun ω ↦ ?_))
      · exact ((stronglyMeasurable_stoppedValue_of_le h_prog (τ.2.1.min (isStoppingTime_const 𝓕 (v n)))
          (fun ω ↦ inf_le_left)).mono (𝓕.le' (v n))).aestronglyMeasurable
      · obtain ⟨N, hN⟩ := hv.2 (τ.1 ω).untopA
        refine tendsto_atTop_nhds.mpr (fun s hs ↦ ⟨N, fun n hn ↦ ?_⟩)
        simp [τn, τ.2.2, hN n hn, stoppedValue]
        exact hs
    rw [uniformIntegrable_iff_norm h_ae]
    convert hY_UI.uniformIntegrable
    ext τ ω; simp [stoppedValue]
