lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable [IsFiniteMeasure P]
    [PseudoMetrizableSpace ι] [BorelSpace ι] (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  refine ⟨fun h ↦ ?_, fun h ↦ ?_⟩
  · let constT (t : ι) : {T | IsStoppingTime 𝓕 T ∧ ∀ ω, T ω ≠ ⊤} :=
      ⟨fun ω ↦ t, isStoppingTime_const 𝓕 t, fun _ ↦ WithTop.coe_ne_top⟩
    rw [show X = (fun τ ↦ stoppedValue X τ.1) ∘ constT by ext; simp [stoppedValue]]
    exact h.uniformIntegrable.comp constT
  · have h_prog := hX1.adapted.progMeasurable_of_rightContinuous hX2
    refine classD_of_uniformIntegrable_bounded_stoppingTime ?_ h_prog
    rw [uniformIntegrable_iff_norm]
    · let Y := fun t ω ↦ ‖X t ω‖
      have hY_sub := hX1.submartingale_convex_comp (convexOn_norm convex_univ)
        continuous_norm (fun t ↦ (hX1.integrable t).norm)
      have hY_UI : UniformIntegrable Y 1 P := (uniformIntegrable_iff_norm.1 h).1
      convert hY_sub.uniformIntegrable_bounded_stoppingTime (fun ω t ↦ (hX2 ω t).norm)
        (fun t ω ↦ norm_nonneg _) hY_UI
      ext; simp [stoppedValue]
    · intro τ; obtain ⟨t, ht⟩ := τ.2.2
      exact ((stronglyMeasurable_stoppedValue_of_le h_prog τ.2.1 ht).mono (𝓕.le' t)).aestronglyMeasurable
