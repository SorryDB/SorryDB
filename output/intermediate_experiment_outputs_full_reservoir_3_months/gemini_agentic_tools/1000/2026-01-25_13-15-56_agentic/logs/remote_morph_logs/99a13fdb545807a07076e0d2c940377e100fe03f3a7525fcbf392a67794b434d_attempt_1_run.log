lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  have h_prog := hX1.adapted.progMeasurable_of_rightContinuous hX2
  have : ClassD X 𝓕 P ↔ ClassD (fun t ω ↦ ‖X t ω‖) 𝓕 P := by
    refine ⟨fun h ↦ ⟨h_prog.norm, ?_⟩, fun h ↦ ⟨h_prog, ?_⟩⟩
    all_goals
      rw [uniformIntegrable_iff_norm]
      convert h.uniformIntegrable
      ext τ ω
      simp [stoppedValue]
  rw [this, uniformIntegrable_iff_norm]
  exact MeasureTheory.Submartingale.classD_iff_uniformIntegrable
    (hX1.submartingale_convex_comp (convexOn_norm convex_univ) continuous_norm
      (fun t ↦ (hX1.integrable t).norm)) (fun ω ↦ (hX2 ω).norm) (fun t ω ↦ norm_nonneg _)
```
