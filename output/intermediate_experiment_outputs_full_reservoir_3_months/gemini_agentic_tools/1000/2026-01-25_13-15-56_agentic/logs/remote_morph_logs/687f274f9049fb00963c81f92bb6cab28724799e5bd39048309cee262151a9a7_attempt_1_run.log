        · left; have : dz = 1 := by omega; have : c = 2 := by linarith; simp [*]
        · sorry
      · sorry
    · rcases (show a = 2 ∨ a = 3 ∨ a ≥ 4 by omega) with rfl | rfl | ha4
      · rcases (show dx = 0 ∨ dx ≥ 1 by omega) with rfl | hdx1
        · rcases (show dz = 4 ∨ dz ≠ 4 by omega) with rfl | hdz4
          · right; right; left; have : b = 6 := by linarith; have : c = 11 := by linarith; have : dy = 6 := by omega; simp [*]
          · sorry
        · sorry
      · rcases (show dx = 3 ∨ dx ≠ 3 by omega) with rfl | hdx3
        · rcases (show dz = 4 ∨ dz ≠ 4 by omega) with rfl | hdz4
          · right; right; right; have : b = 5 := by linarith; have : c = 7 := by linarith; have : dy = 5 := by omega; simp [*]
          · sorry
        · sorry
      · sorry
  · rintro (h | h | h | h) <;> rcases h with ⟨rfl, rfl, rfl⟩
    · refine ⟨2, 2, 2, ⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩, rfl⟩
