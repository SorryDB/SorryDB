    have ha1 : 2 ≤ a := by
      by_contra! h; have : a = 1 := by omega
      subst this; have : (2 : ℤ)^dx ≤ 0 := by linarith
      have : 1 ≤ (2 : ℤ) ^ dx := by apply one_le_pow₀; norm_num
      linarith
