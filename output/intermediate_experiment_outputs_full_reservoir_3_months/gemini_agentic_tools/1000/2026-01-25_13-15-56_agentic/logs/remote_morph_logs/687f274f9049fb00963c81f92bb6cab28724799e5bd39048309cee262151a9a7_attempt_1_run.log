      have : (2 : ℤ)^dx ≤ 0 := by linarith
      have : 1 ≤ (2 : ℤ)^dx := one_le_pow₀ (by norm_num)
      linarith
    have h1 : (a * a - 1) * b = a * 2^dx + 2^dz := by linear_combination a * hx + hz
    have h2 : (a * a - 1) * c = a * 2^dz + 2^dx := by linear_combination a * hz + hx
    rcases (show a = 2 ∨ a = 3 ∨ a ≥ 4 by omega) with (rfl | rfl | ha4)
    · rcases (show dx = 0 ∨ dx = 1 ∨ dx ≥ 2 by omega) with (rfl | rfl | hdx2)
      · rcases (show dz = 2 ∨ dz = 4 ∨ (dz ≠ 2 ∧ dz ≠ 4) by omega) with (rfl | rfl | hdz)
        · right; left; refine ⟨rfl, by nlinarith, by nlinarith⟩
        · right; right; left; refine ⟨rfl, by nlinarith, by nlinarith⟩
        · sorry
      · have hdz : dz = 1 := by
          have hbc_a : 9 * (b * c - 2) = 2 * (2^dz : ℤ)^2 + 10 * 2^dz - 10 := by nlinarith
          have : 2 * (2^dz : ℤ)^2 + 10 * 2^dz - 10 = 9 * 2^dy := by rw [← hy, hbc_a]; norm_cast
          cases dz with | zero => norm_num at this | succ dz =>
          cases dz with | zero => rfl | succ dz =>
          have : (2:ℤ)^(dz+2) * (2^(dz+2) + 5) = 9 * 2^dy + 5 := by norm_cast at this; linarith
          have h_even : Even ((2:ℤ)^(dz+2) * (2^(dz+2) + 5)) := by simp
          have h_odd : Odd (9 * 2^dy + 5) := by
            if h : dy = 0 then subst h; norm_num else
            have : Even (9 * 2^dy) := by simp [h]
            exact Even.add_odd this (by norm_num)
          rw [h_odd.even_iff] at h_even; contradiction
        subst hdz; left; refine ⟨rfl, by nlinarith, by nlinarith⟩
      · sorry
    · rcases (show dx = 3 ∨ dx ≠ 3 by omega) with (rfl | hdx3)
      · have hdz : dz = 4 := by
