/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩
  simp only [Set.mem_setOf_eq, Set.mem_insert_iff, Set.mem_singleton_iff, Prod.mk.injEq]
  try unfold answer
  constructor
  · rintro ⟨a_val, b_val, c_val, ⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨dx, hx⟩, ⟨dy, hy⟩, ⟨dz, hz⟩, h_eq⟩
