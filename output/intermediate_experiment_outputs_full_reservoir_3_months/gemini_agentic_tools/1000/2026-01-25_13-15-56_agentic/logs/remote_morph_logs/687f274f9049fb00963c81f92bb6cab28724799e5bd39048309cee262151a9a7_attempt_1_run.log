          have : b ≤ c := by linarith; nlinarith
        subst this; have : dy = 5 := by linarith; have : b = 5 := by linarith; have : c = 7 := by linarith; simp [*]
      · sorry
    · sorry
  · rintro (⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩)
