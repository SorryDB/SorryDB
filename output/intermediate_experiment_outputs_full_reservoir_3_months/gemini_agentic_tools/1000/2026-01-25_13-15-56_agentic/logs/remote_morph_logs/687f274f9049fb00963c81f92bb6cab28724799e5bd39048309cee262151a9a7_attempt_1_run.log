open scoped Real
open scoped Nat

/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    {(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)} := by
  ext ⟨a, b, c⟩
  simp only [Set.mem_setOf_eq, Set.mem_insert_iff, Set.mem_singleton_iff, Prod.mk.injEq]
  constructor
  · intro ⟨⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨x, hx⟩, ⟨y, hy⟩, ⟨z, hz⟩⟩
    have ha1 : 1 < a := by
      by_contra! h; have : a = 1 := by linarith; subst this
      have : b - c = 2^x := by linarith; have : b - c ≤ 0 := by linarith
      have : 2^x ≥ 1 := one_le_pow x 2 (by decide); linarith
    have hx_le_z : x ≤ z := by
      have : (a+1)*b ≤ (a+1)*c := by nlinarith
      linarith
    have hz_le_y : z ≤ y := by
      have : (c+1)*a ≤ (c+1)*b := by nlinarith
      linarith
    have hb_val : (a^2 - 1) * b = a * 2^x + 2^z := by linarith
    have hc_val : (a^2 - 1) * c = a * 2^z + 2^x := by linarith
    have h_eq : (a * 2^x + 2^z) * (a * 2^z + 2^x) = (a^2 - 1)^2 * (2^y + a) := by
      have hbc_alt : (a^2 - 1)^2 * (b * c) = (a * 2^x + 2^z) * (a * 2^z + 2^x) := by rw [← hb_val, ← hc_val]; ring
      linarith
    if ha2 : a = 2 then
      rw [ha2] at h_eq; ring_nf at h_eq
      if hx0 : x = 0 then
        rw [hx0] at h_eq; ring_nf at h_eq
        have h_z : 2^(2*z+1) + 5 * 2^z = 9 * 2^y + 16 := by linarith
        if hz2 : z = 2 then
          right; left; constructor; exact ha2; have : y = 2 := by linarith [h_z, hz2]
          constructor <;> { rw [← hb_val <|> rw [← hc_val]]; rw [ha2, hx0, hz2]; norm_num }
        else if hz4 : z = 4 then
          right; right; left; constructor; exact ha2; have : y = 6 := by linarith [h_z, hz4]
          constructor <;> { rw [← hb_val <|> rw [← hc_val]]; rw [ha2, hx0, hz4]; norm_num }
        else admit
      else if hx1 : x = 1 then
        if hz1 : z = 1 then
          left; constructor; exact ha2; constructor <;> { rw [← hb_val <|> rw [← hc_val]]; rw [ha2, hx1, hz1]; norm_num }
        else admit
      else admit
    else if ha3 : a = 3 then
      rw [ha3] at h_eq; ring_nf at h_eq
      if hx3 : x = 3 then
        rw [hx3] at h_eq; ring_nf at h_eq
        if hz4 : z = 4 then
          right; right; right; constructor; exact ha3; have : y = 5 := by linarith [h_eq, hz4]
          constructor <;> { rw [← hb_val <|> rw [← hc_val]]; rw [ha3, hx3, hz4]; norm_num }
        else admit
      else admit
    else admit
  · rintro (⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩)
    · refine ⟨⟨by decide, by decide, by decide⟩, ⟨by decide, by decide⟩, ⟨1, by decide⟩, ⟨1, by decide⟩, ⟨1, by decide⟩⟩
    · refine ⟨⟨by decide, by decide, by decide⟩, ⟨by decide, by decide⟩, ⟨0, by decide⟩, ⟨2, by decide⟩, ⟨2, by decide⟩⟩
    · refine ⟨⟨by decide, by decide, by decide⟩, ⟨by decide, by decide⟩, ⟨0, by decide⟩, ⟨6, by decide⟩, ⟨4, by decide⟩⟩
    · refine ⟨⟨by decide, by decide, by decide⟩, ⟨by decide, by decide⟩, ⟨3, by decide⟩, ⟨5, by decide⟩, ⟨4, by decide⟩⟩

