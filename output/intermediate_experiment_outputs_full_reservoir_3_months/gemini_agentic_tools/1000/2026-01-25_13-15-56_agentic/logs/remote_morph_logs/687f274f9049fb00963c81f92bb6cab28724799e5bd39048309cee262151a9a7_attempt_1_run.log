          have : (2^dz : ℤ) * (3 * 2^dz + 80) = 64 * 2^dy := by rw [← hy, hbc_a]; norm_cast
          cases dz with | zero => norm_num at this | succ dz =>
          cases dz with | zero => norm_num at this | succ dz =>
          cases dz with | zero => norm_num at this | succ dz =>
          cases dz with | zero => norm_num at this | succ dz =>
          cases dz with | zero => rfl | succ dz => sorry
        subst hdz; right; right; right; refine ⟨rfl, by nlinarith, by nlinarith⟩
