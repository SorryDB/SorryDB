        rcases (show dz = 2 ∨ dz = 4 ∨ (dz ≠ 2 ∧ dz ≠ 4) by omega) with (rfl | rfl | hdz)
        · right; left; have : dy = 2 := by linarith; have : b = 2 := by linarith; have : c = 3 := by linarith; simp [*]
        · right; right; left; have : dy = 6 := by linarith; have : b = 6 := by linarith; have : c = 11 := by linarith; simp [*]
        · sorry
