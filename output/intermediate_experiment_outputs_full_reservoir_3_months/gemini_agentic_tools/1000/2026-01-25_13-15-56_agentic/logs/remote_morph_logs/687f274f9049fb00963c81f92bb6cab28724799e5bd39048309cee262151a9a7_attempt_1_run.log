import Imo.ProblemImports

open scoped Real
open scoped Nat

/-- Find all positive integers $(a,b,c)$ such that
$$ab-c,\quad bc-a,\quad ca-b$$ are all powers of $2$.

[i]Proposed by Serbia[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2015_p2 :
    {(a, b, c) | (a : ℤ) (b : ℤ) (c : ℤ)
      (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
      (h₁ : a ≤ b ∧ b ≤ c)
      (h₂ : ∃ d : ℕ, a * b - c = 2^d)
      (h₃ : ∃ d : ℕ, b * c - a = 2^d)
      (h₄ : ∃ d : ℕ, c * a - b = 2^d)} =
    answer({(2, 2, 2), (2, 2, 3), (2, 6, 11), (3, 5, 7)}) := by
  ext ⟨a, b, c⟩
  simp only [Set.mem_setOf_eq, Set.mem_insert_iff, Set.mem_singleton_iff, Prod.mk.injEq]
  try (unfold answer)
  constructor
  · rintro ⟨a, b, c, ⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨dx, hx⟩, ⟨dy, hy⟩, ⟨dz, hz⟩, rfl⟩
    have ha_ge_2 : 2 ≤ a := by
      by_contra! h; have : a = 1 := by omega
      subst this; have : b - c = 2^dx := by linarith
      have : b ≤ c := by linarith
      have : (2:ℤ)^dx ≥ 1 := by norm_num; apply Nat.one_le_pow; exact dx; decide
      linarith
    have hb_val : (a^2 - 1) * b = a * 2^dx + 2^dz := by linarith
    have hc_val : (a^2 - 1) * c = a * 2^dz + 2^dx := by linarith
    have h_eq : (a^2 - 1)^2 * (2^dy + a) = a * 2^(2*dx) + (a^2 + 1) * 2^(dx + dz) + a * 2^(2 * dz) := by
      have : (a^2 - 1)^2 * (b * c) = (a * 2^dx + 2^dz) * (a * 2^dz + 2^dx) := by rw [← hb_val, ← hc_val]; ring
      linarith
    rcases (show a = 2 ∨ a = 3 ∨ a ≥ 4 by omega) with (rfl | rfl | ha4)
    · rcases (show dx = 0 ∨ dx = 1 ∨ dx ≥ 2 by omega) with (rfl | rfl | hdx2)
      · have h_z : 2 * 2^(2*dz) + 5 * 2^dz - 16 = 9 * 2^dy := by linarith
        rcases (show dz = 2 ∨ dz = 4 ∨ (dz ≠ 2 ∧ dz ≠ 4) by omega) with (rfl | rfl | hdz)
        · right; left; have : dy = 2 := by linarith; have : b = 2 := by linarith; have : c = 3 := by linarith; simp [*]
        · right; right; left; have : dy = 6 := by linarith; have : b = 6 := by linarith; have : c = 11 := by linarith; simp [*]
        · sorry
      · have : dz = 1 := by
          have : 3 * b = 4 + 2^dz := by linarith; have : 3 * c = 2 * 2^dz + 2 := by linarith
          have : b ≤ c := by linarith; nlinarith
        subst this; left; have : dy = 1 := by linarith; have : b = 2 := by linarith; have : c = 2 := by linarith; simp [*]
      · sorry
    · by_cases hdx3 : dx = 3
      · subst hdx3; right; right; right; have : dz = 4 := by
          have : 8 * b = 24 + 2^dz := by linarith; have : 8 * c = 3 * 2^dz + 8 := by linarith
          have : b ≤ c := by linarith; nlinarith
        subst this; have : dy = 5 := by linarith; have : b = 5 := by linarith; have : c = 7 := by linarith; simp [*]
      · sorry
    · sorry
  · rintro (⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩ | ⟨rfl, rfl, rfl⟩)
    · use 2, 2, 2; simp; refine ⟨⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩⟩
    · use 2, 2, 3; simp; refine ⟨⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨0, by norm_num⟩, ⟨2, by norm_num⟩, ⟨2, by norm_num⟩⟩
    · use 2, 6, 11; simp; refine ⟨⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨0, by norm_num⟩, ⟨6, by norm_num⟩, ⟨4, by norm_num⟩⟩
    · use 3, 5, 7; simp; refine ⟨⟨by norm_num, by norm_num, by norm_num⟩, ⟨by norm_num, by norm_num⟩, ⟨3, by norm_num⟩, ⟨5, by norm_num⟩, ⟨4, by norm_num⟩⟩

```
