/--Theorem: A context-free derivation tree has a number of leaves equal to
  the length of the result word.-/
theorem derivation_result_is_leaf_count :
  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  intro dt
  induction dt.depth using Nat.strong_induction_on generalizing dt
  case h n ih =>
    match h_tree : dt.tree with
    | .leaf t => cases t <;> rfl
    | .inner v ch p =>
      have h_ih : ∀ c ∈ dt.children, Word.len c.result = List.length c.collectLeaves' :=
        fun c hc => ih c.depth (ContextFreeGrammar.child_less_depth dt c hc) c
      have h_res : Word.len dt.result = (dt.children.map (fun c => Word.len c.result)).sum := by
        simp [h_tree, ContextFreeGrammar.DerivationTree.result, ContextFreeGrammar.PreDerivationTree.result,
              ContextFreeGrammar.NEPreDerivationTreeList.result, ContextFreeGrammar.DerivationTree.children,
              Word.len, List.length_join, List.length_flatten, List.length_append, List.map_map]
      have h_leaves : List.length dt.collectLeaves' = (dt.children.map (fun c => List.length c.collectLeaves')).sum := by
        simp [h_tree, ContextFreeGrammar.DerivationTree.collectLeaves', ContextFreeGrammar.DerivationTree.collectLeaves,
              ContextFreeGrammar.DerivationTree.children, List.length_join, List.length_flatten, List.length_append, List.map_map]
      rw [h_res, h_leaves]
      congr 1
      exact List.map_congr h_ih
```
