/--Theorem: A context-free derivation tree has a number of leaves equal to
  the length of the result word.-/
theorem derivation_result_is_leaf_count :
  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  intro dt
  induction dt
  case leaf t => rfl
  case node v ch sound ih =>
    simp [ContextFreeGrammar.DerivationTree.result, ContextFreeGrammar.DerivationTree.collectLeaves', Word.len]
    induction ch
    case nil => rfl
    case cons c cs ih_cs =>
      simp [Word.length_mul_eq_add]
      rw [ih c (List.mem_cons_self _ _)]
      apply ih_cs
      intro c' h'
      apply ih c' (List.mem_cons_of_mem _ h')
```
