          (h_in : ∀ t' ∈ l.elements, ∀ vt', ∃ dt_c ∈ (⟨tree, valid⟩ : G.DerivationTree).children, dt_c.tree = t' ∧ dt_c.valid = vt') :
          Word.len l.result = List.length l.collectLeaves :=
        match l with
        | .single t => by
            simp [ContextFreeGrammar.NEPreDerivationTreeList.result, ContextFreeGrammar.NEPreDerivationTreeList.collectLeaves]
            have vt : t.treeValid := by simp [ContextFreeGrammar.NEPreDerivationTreeList.treeValid] at hlv; exact hlv
            have ⟨dt_c, h_mem, h_te, h_ve⟩ := h_in t (by simp [ContextFreeGrammar.NEPreDerivationTreeList.elements]) vt
            rw [← h_te, ← h_ve]
            apply ih dt_c.depth (G.child_less_depth ⟨tree, valid⟩ dt_c h_mem) dt_c
        | .cons t ts => by
            simp [ContextFreeGrammar.NEPreDerivationTreeList.result, ContextFreeGrammar.NEPreDerivationTreeList.collectLeaves,
                  Word.length_mul_eq_add, List.length_append]
            simp [ContextFreeGrammar.NEPreDerivationTreeList.treeValid] at hlv
            have vt : t.treeValid := hlv.1
            have ⟨dt_c, h_mem, h_te, h_ve⟩ := h_in t (by simp [ContextFreeGrammar.NEPreDerivationTreeList.elements]) vt
            rw [← h_te, ← h_ve]
            rw [ih dt_c.depth (G.child_less_depth ⟨tree, valid⟩ dt_c h_mem) dt_c]
            apply list_lemma ts hlv.2.1
            intro t' ht' vt'
            apply h_in t' (by simp [ContextFreeGrammar.NEPreDerivationTreeList.elements, ht'])
      apply list_lemma ch vld.2.1
      intro t' elements_t' vt'
      exists ⟨t', vt'⟩
      simp [ContextFreeGrammar.DerivationTree.children, h_tree]
      exact ⟨t', elements_t', vt', rfl⟩
