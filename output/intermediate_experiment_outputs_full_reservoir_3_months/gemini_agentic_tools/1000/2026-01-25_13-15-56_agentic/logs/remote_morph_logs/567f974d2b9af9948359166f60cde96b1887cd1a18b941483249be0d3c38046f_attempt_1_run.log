import Mathlib.Analysis.SpecialFunctions.Pow.Real
import Mathlib.Combinatorics.Additive.AP.Three.Defs

open Finset Real

theorem int {A : Finset ℕ} {N : ℕ} (hAN : A ⊆ range N) (hA : ThreeAPFree (α := ℕ) A) :
    ∃ c > 0, #A ≤ N / exp (- c * log N ^ (12⁻¹ : ℝ)) := by
  use 1, zero_lt_one
  rcases N.eq_zero_or_pos with rfl | hN
  · simp
  · rw [le_div_iff (exp_pos _)]
    refine (Nat.cast_le.mpr (card_le_of_subset hAN)).trans ?_
    nth_rw 1 [← mul_one (N : ℝ)]
    apply mul_le_mul_of_nonneg_left
    · rw [← exp_zero, neg_mul, neg_le_zero]
      exact exp_le_exp.mpr (mul_nonneg zero_le_one (rpow_nonneg (log_nonneg (Nat.one_le_cast.mpr hN)) _))
    · exact Nat.cast_nonneg N

```
