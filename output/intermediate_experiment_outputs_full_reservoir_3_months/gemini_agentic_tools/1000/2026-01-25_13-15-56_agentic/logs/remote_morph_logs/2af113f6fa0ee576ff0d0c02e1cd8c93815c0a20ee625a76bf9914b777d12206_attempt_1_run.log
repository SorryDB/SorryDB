    have h : 2 * (|f x| * |g y|) ≤ 2 * M := by
      rw [mul_assoc, ← abs_of_pos (zero_lt_two : (0 : ℝ) < 2), ← abs_mul, ← abs_mul, ← h₀, two_mul]
      exact (abs_add _ _).trans (add_le_add (le_ciSup hM_bdd (x + y)) (le_ciSup hM_bdd (x - y)))
    exact (mul_le_mul_left (zero_lt_two : (0 : ℝ) < 2)).mp h
  have hMg : M * |g y| ≤ M := by
    by_cases hg : |g y| = 0
    · rw [hg, mul_zero]; exact hM_pos.le
    · have hg_pos : 0 < |g y| := (abs_nonneg (g y)).lt_of_ne (Ne.symm hg)
      exact (le_div_iff₀ hg_pos).mp (ciSup_le (fun x => (le_div_iff₀ hg_pos).mpr (hg_le x)))
  exact (mul_le_iff_le_one_right hM_pos).mp hMg

