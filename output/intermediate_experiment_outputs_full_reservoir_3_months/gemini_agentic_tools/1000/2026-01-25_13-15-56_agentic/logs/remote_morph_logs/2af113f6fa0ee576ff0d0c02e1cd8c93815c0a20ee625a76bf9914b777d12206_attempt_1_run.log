/--
$f$ and $g$ are real-valued functions defined on the real line. For all $x$ and $y, f(x+y)+f(x-y)=2f(x)g(y)$. $f$ is not identically zero and $|f(x)|\le1$ for all $x$. Prove that $|g(x)|\le1$ for all $x$. -/
@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  intro x
  let M := ⨆ z, |f z|
  have hM_bdd : BddAbove (Set.range (fun z => |f z|)) := ⟨1, Set.forall_mem_range.mpr h₂⟩
  have hM_pos : 0 < M := by
    obtain ⟨z, hz⟩ := not_forall.mp h₁
    exact (abs_pos.mpr hz).trans_le (le_ciSup hM_bdd z)
  have hg_le : ∀ z, |f z| * |g x| ≤ M := fun z => by
    have h : 2 * (|f z| * |g x|) ≤ 2 * M :=
      calc 2 * (|f z| * |g x|)
        _ = |2 * f z * g x| := by rw [mul_assoc, ← abs_mul, ← abs_mul, abs_of_pos (zero_lt_two : (0 : ℝ) < 2)]
        _ = |f (z + x) + f (z - x)| := by rw [← h₀]
        _ ≤ |f (z + x)| + |f (z - x)| := abs_add _ _
        _ ≤ M + M := add_le_add (le_ciSup hM_bdd (z + x)) (le_ciSup hM_bdd (z - x))
        _ = 2 * M := (two_mul M).symm
    exact (mul_le_mul_left (zero_lt_two : (0 : ℝ) < 2)).mp h
  refine le_of_not_lt (fun hgx => ?_)
  have hgx_pos : 0 < |g x| := (abs_nonneg (g x)).trans_lt hgx
  have hM_le : M ≤ M / |g x| := ciSup_le (fun z => le_div_of_mul_le hgx_pos (hg_le z))
  have hMg : M * |g x| ≤ M := (le_div_iff₀ hgx_pos).mp hM_le
  exact hgx.not_le ((mul_le_iff_le_one_right hM_pos).mp hMg)

