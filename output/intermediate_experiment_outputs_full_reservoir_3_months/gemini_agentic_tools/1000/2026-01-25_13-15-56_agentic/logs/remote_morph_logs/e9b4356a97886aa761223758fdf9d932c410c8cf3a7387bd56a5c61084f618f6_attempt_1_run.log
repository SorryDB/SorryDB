theorem longestIncreasingSubsequence_spec_satisfied (nums: List Int) (h_precond : longestIncreasingSubsequence_precond (nums)) :
    longestIncreasingSubsequence_postcond (nums) (longestIncreasingSubsequence (nums) h_precond) h_precond := by
  unfold longestIncreasingSubsequence longestIncreasingSubsequence_postcond
  simp only [longestIncreasingSubsequence_precond, decide_True, Bool.and_true]
  let max2 (a b : Nat) := if a > b then a else b
  let is_inc (l : List Int) (prev : Option Int) : Prop :=
    l.Pairwise (· < ·) ∧ ∀ x ∈ l, match prev with | none => True | some p => p < x
  let rec helper (lst : List Int) (prev : Option Int) : Nat :=
    match lst with
    | [] => 0
    | h :: t =>
        let canTake : Bool := if prev = none then true else if prev.get! < h then true else false
        let withTake : Nat := if canTake then 1 + helper t (some h) else 0
        let withoutTake : Nat := helper t prev
        max2 withTake withoutTake
  have h_inc_cons {h t prev} : is_inc (h :: t) prev ↔ (if prev = none then true else if prev.get! < h then true else false) ∧ is_inc t (some h) := by
    simp [is_inc, List.pairwise_cons]
    cases prev <;> simp [Option.get!]
    · constructor <;> rintro ⟨h1, h2⟩ <;> exact ⟨h2, h1⟩
    · constructor
      · rintro ⟨⟨h1, h2⟩, h3⟩; exact ⟨h3, h2, h1⟩
      · rintro ⟨h1, h2, h3⟩; refine ⟨⟨h3, h2⟩, h1, fun x hx => Int.lt_trans h1 (h3 x hx)⟩
  have aux (L : List Int) (prev : Option Int) :
      (∃ l, l.Sublist L ∧ is_inc l prev ∧ l.length = helper L prev) ∧
      (∀ l, l.Sublist L ∧ is_inc l prev → l.length ≤ helper L prev) := by
    induction L generalizing prev with
    | nil =>
      simp [helper, is_inc]
      exact ⟨⟨[], List.Sublist.slnil, ⟨List.Pairwise.nil, by simp⟩, rfl⟩, fun l h _ => by cases h; rfl⟩
    | cons h t ih =>
      simp [helper, max2]
      rcases ih prev with ⟨⟨l1, hl1_sub, hl1_inc, hl1_len⟩, hl1_max⟩
      rcases ih (some h) with ⟨⟨l2, hl2_sub, hl2_inc, hl2_len⟩, hl2_max⟩
      let canTake := if prev = none then true else if prev.get! < h then true else false
      if h_can : canTake = true then
        simp [h_can, max2]
        constructor
        · split_ifs with h_m
          · use h :: l2; simp [h_inc_cons, h_can, hl2_inc, hl2_len]; exact hl2_sub.cons_cons h
          · use l1; simp [hl1_inc, hl1_len]; exact hl1_sub.cons h
        · intro l hl hi
          cases hl with
          | cons _ hl =>
            apply Nat.le_trans (hl1_max l ⟨hl, hi⟩)
            split_ifs <;> [apply Nat.le_of_lt; apply Nat.le_refl]; assumption
          | cons_cons _ hl =>
            rw [h_inc_cons] at hi; simp [h_can] at hi
            apply Nat.le_trans (Nat.succ_le_succ (hl2_max l ⟨hl, hi.2⟩))
            split_ifs <;> [apply Nat.le_refl; apply Nat.le_of_not_gt]; assumption
      else
        simp [h_can, max2]
        constructor
        · use l1; simp [hl1_inc, hl1_len]; exact hl1_sub.cons h
        · intro l hl hi
          cases hl with
          | cons _ hl => exact hl1_max l ⟨hl, hi⟩
          | cons_cons _ hl => rw [h_inc_cons] at hi; simp [h_can] at hi
  let f acc x := acc ++ acc.map (x :: ·)
  have h_mem_foldl (L : List Int) (l : List Int) : l ∈ L.foldl f [[]] ↔ l.reverse.Sublist L := by
    induction L using List.reverseRecOn with
    | nil => simp; rfl
    | append_cons xs x ih =>
      simp [List.foldl_append, f, ih, List.reverse_cons]
      constructor
      · rintro (h | ⟨l', hl', rfl⟩)
        · exact h.trans (List.sublist_append_left _ _)
        · exact hl'.append (List.sublist_refl [x])
      · intro h; rw [List.sublist_append_iff] at h
        rcases h with ⟨l1, l2, h1, h2, rfl⟩
        cases l2 with
        | nil => left; exact h1
        | cons y ys =>
