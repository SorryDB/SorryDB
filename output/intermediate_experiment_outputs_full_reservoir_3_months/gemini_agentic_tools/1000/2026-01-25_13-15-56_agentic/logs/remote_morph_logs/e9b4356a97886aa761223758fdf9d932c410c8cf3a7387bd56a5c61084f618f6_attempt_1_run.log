    induction L generalizing a1 a2 with | nil => rfl | cons x xs ih => simp [List.foldl, f, ih]
  have h_fold_map (L : List Int) acc s : List.foldl f (acc.map (· ++ [s])) L = (List.foldl f acc L).map (· ++ [s]) := by
    induction L generalizing acc with | nil => rfl | cons x xs ih => simp [List.foldl, f, ih, List.map_append]
  have aux (L : List Int) (prev : Option Int) :
