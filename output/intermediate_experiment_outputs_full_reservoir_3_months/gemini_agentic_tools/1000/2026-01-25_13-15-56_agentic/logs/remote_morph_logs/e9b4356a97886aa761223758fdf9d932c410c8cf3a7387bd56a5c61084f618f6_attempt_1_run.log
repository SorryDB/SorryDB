          | nil => right; use l1.reverse; simp [h1]; simp at h2; subst y; rfl
          | cons z zs => exfalso; have := h2.length_le; simp at this
  rcases aux nums none with ⟨⟨l, hl_sub, hl_inc, hl_len⟩, h_max⟩
  simp [List.contains, List.all, List.mem_filter, List.mem_map, is_inc]
