  · use l; simp [hl_sub, hl_inc.1, hl_len]; rw [← List.mem_map, h_mem_foldl]; simp [hl_sub]
  · intro l' hl'_sub hl'_inc; exact h_max l' ⟨hl'_sub, hl'_inc, by simp⟩
