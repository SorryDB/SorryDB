    ext t; simp [integrableExpSet]
    have c01 : Integrable (fun (x : ℝ) ↦ Real.exp (t * x)) (semicircleReal μ v) := by
      set S := Icc (μ - 2 * √v) (μ + 2 * √v)
      have c011 : ∀ x, x ∈ S → |Real.exp (t * x)| ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by sorry
