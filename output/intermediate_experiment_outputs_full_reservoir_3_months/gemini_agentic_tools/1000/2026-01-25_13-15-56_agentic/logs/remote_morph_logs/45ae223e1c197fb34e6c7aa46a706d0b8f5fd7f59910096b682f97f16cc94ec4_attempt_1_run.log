    ext t; simp [integrableExpSet]
    have c01 : Integrable (fun (x : ℝ) ↦ Real.exp (t * x)) (semicircleReal μ v) := by
      set S := Icc (μ - 2 * √v) (μ + 2 * √v)
      have c011 : ∀ x, x ∈ S → |Real.exp (t * x)| ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by sorry
      have h_meas : AEStronglyMeasurable (fun x ↦ Real.exp (t * x)) (semicircleReal μ v) :=
        (continuous_id.const_mul t).exp.aestronglyMeasurable
      refine Integrable.of_bound (Real.exp (|t| * (|μ| + 2 * √v))) h_meas ?_
      by_cases hv : v = 0
      · rw [hv, semicircleReal_zero_var]
