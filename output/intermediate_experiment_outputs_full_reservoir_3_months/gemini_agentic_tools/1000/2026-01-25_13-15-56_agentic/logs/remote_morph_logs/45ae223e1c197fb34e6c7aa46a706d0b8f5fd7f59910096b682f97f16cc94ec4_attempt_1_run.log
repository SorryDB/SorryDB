/-- All the moments of a real semicircle distribution are finite. That is, the identity is in Lp for
all finite `p`. -/
lemma memLp_id_semicircleReal (p : ℝ≥0) : MemLp id p (semicircleReal μ v) := by
  refine memLp_of_mem_interior_integrableExpSet ?_ p
  have c0 : integrableExpSet id (semicircleReal μ v) = Set.univ := by
    ext t; simp [integrableExpSet]
    have c01 : Integrable (fun (x : ℝ) ↦ Real.exp (t * x)) (semicircleReal μ v) := by
      set S := Icc (μ - 2 * √v) (μ + 2 * √v)
      have c011 : ∀ x, x ∈ S → |Real.exp (t * x)| ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by
        intro x hx
        rw [Real.abs_exp, Real.exp_le_exp]
        calc t * x ≤ |t * x| := le_abs_self _
          _ = |t| * |x| := abs_mul t x
          _ ≤ |t| * (|μ| + 2 * √v) := mul_le_mul_of_nonneg_left
            ((abs_le.mpr ⟨by linarith [hx.1, Real.sqrt_nonneg (v : ℝ)], by linarith [hx.2, Real.sqrt_nonneg (v : ℝ)]⟩).trans (by linarith [abs_le.mp (le_refl |μ|)])) (abs_nonneg t)
      have hf : AEStronglyMeasurable (fun x ↦ Real.exp (t * x)) (semicircleReal μ v) :=
        (Real.continuous_exp.comp (continuous_mul_left t)).aestronglyMeasurable
      have h_supp : ∀ᵐ x ∂(semicircleReal μ v), x ∈ S := by
        by_cases hv : v = 0
        · rw [hv, semicircleReal_zero_var, ae_dirac_iff measurableSet_Icc]
          simp [S, hv, Real.sqrt_nonneg]
        · rw [semicircleReal_of_var_ne_zero _ hv, ae_withDensity_iff (measurable_semicirclePDF μ v)]
          filter_upwards [] with x hx
          apply support_semicirclePDF_inc μ v
          contrapose! hx
          simp [semicirclePDF, nmem_support.mp hx]
      exact Integrable.of_bound hf (integrable_const _) (by filter_upwards [h_supp] with x hx; rw [Real.norm_eq_abs]; exact c011 x hx)
    exact c01
  rw [c0, interior_univ]
  exact mem_univ 0
