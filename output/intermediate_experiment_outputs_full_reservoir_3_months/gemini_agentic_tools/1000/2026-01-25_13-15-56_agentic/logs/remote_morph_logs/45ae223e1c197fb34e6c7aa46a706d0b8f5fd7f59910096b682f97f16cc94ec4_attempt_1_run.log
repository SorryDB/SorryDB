/-- All the moments of a real semicircle distribution are finite. That is, the identity is in Lp for
all finite `p`. -/
lemma memLp_id_semicircleReal (p : ℝ≥0) : MemLp id p (semicircleReal μ v) := by
  refine memLp_of_mem_interior_integrableExpSet ?_ p
  have c0 : integrableExpSet id (semicircleReal μ v) = Set.univ := by
    ext t; simp [integrableExpSet]
    have c01 : Integrable (fun (x : ℝ) ↦ Real.exp (t * x)) (semicircleReal μ v) := by
      set S := Icc (μ - 2 * √v) (μ + 2 * √v)
      have c011 : ∀ x, x ∈ S → |Real.exp (t * x)| ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by
        intro x hx
        rw [Real.abs_exp]
        refine Real.exp_le_exp.mpr (le_trans (le_abs_self _) ?_)
        calc
          |t * x| = |t| * |x| := abs_mul t x
          _ ≤ |t| * (|μ| + 2 * √v) := by
            refine mul_le_mul_of_nonneg_left ?_ (abs_nonneg t)
            rw [Icc, mem_setOf_eq] at hx
            calc
              |x| = |(x - μ) + μ| := by rw [sub_add_cancel]
              _ ≤ |x - μ| + |μ| := abs_add (x - μ) μ
              _ = |μ| + |x - μ| := add_comm _ _
              _ ≤ |μ| + 2 * √v := by
                gcongr
                rw [abs_sub_le_iff]
                constructor
                · linarith
                · linarith
      have h_meas : Measurable (fun x ↦ Real.exp (t * x)) := (continuous_exp.comp (continuous_id.const_mul t)).measurable
      have h_finite : IsFiniteMeasure (semicircleReal μ v) := inferInstance
      apply integrable_of_ae_bound (Real.exp (|t| * (|μ| + 2 * √v)))
      · exact h_meas.aestronglyMeasurable
      · apply ae_of_all
        intro x
        by_cases hx : x ∈ S
        · exact c011 x hx
        · by_cases hv : v = 0
          · rw [hv, semicircleReal_zero_var] at hx ⊢
            simp at hx; absurd hx; rfl
          · rw [semicircleReal_apply_eq_integral _ hv]
            have h_supp : semicirclePDFReal μ v x = 0 := by
              contrapose! hx; exact support_semicirclePDF_inc μ v (Function.mem_support.mpr hx)
            simp [semicirclePDF, h_supp]
            exact Real.exp_pos _ |> le_of_lt
    exact c01
  rw [c0]; exact interior_univ
