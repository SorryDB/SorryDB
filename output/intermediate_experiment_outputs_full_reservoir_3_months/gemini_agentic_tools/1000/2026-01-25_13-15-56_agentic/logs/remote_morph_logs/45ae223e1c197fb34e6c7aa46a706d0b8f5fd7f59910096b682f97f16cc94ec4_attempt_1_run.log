/-- All the moments of a real semicircle distribution are finite. -/
lemma integrable_pow_semicircleReal (n : ℕ) : Integrable (fun x ↦ x ^ n) (semicircleReal μ v) :=
  (memLp_id_semicircleReal n).integrable (by norm_cast; linarith)

/-- The moments of the semicircle distribution -/
lemma semicircleReal_moment (n : ℕ) :
    ∫ x, x ^ n ∂(semicircleReal μ v) =
    if v = 0 then μ ^ n else ∑ k in Finset.range (n + 1), (n.choose k : ℝ) * μ ^ (n - k) *
      if (k % 2 = 1) then 0 else (k / 2).catalan * (v : ℝ) ^ (k / 2) := by
  sorry

/-- The odd central moments of the semicircle distribution are zero -/
lemma centralMoment_odd_semicircleReal (n : ℕ) :
    ∫ x, (x - μ) ^ (2 * n + 1) ∂(semicircleReal μ v) = 0 := by
  sorry

