      have c011 : ∀ x, x ∈ S → |Real.exp (t * x)| ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by sorry
      have hf : Continuous (fun x ↦ Real.exp (t * x)) := by continuity
      refine Integrable.of_bound (fun _ ↦ Real.exp (|t| * (|μ| + 2 * √v))) hf.aestronglyMeasurable
        (integrable_const _) ?_
      have h_supp : ∀ᵐ x ∂(semicircleReal μ v), x ∈ S := by
