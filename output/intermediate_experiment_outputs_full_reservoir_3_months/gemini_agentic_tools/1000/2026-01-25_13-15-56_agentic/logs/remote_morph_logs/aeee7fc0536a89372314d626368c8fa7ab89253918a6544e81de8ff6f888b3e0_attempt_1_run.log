lemma canonicalForm (z : D^) : ∃ (N : ℕ+) (z' : 𝓞^), z = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1 : D) * j₂ z' := by
  let P (x : D^) : Prop := ∃ (N : ℕ+) (z' : 𝓞^), x = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1) * j₂ z'
  have h_add {x y : D^} (hx : P x) (hy : P y) : P (x + y) := by
    obtain ⟨N1, z1', rfl⟩ := hx
    obtain ⟨N2, z2', rfl⟩ := hy
    use N1 * N2, (N2 : ℤ) • z1' + (N1 : ℤ) • z2'
    simp only [map_add, mul_add, ← smul_def, Algebra.smul_def, PNat.val_mul, Nat.cast_mul, mul_inv]
    rw [smul_mul_assoc, smul_mul_assoc, ← j₁.map_smul, ← j₂.map_smul]
    congr 2 <;>
    · rw [← TensorProduct.smul_tmul', smul_eq_mul, mul_comm, ← mul_assoc, inv_mul_cancel, one_mul]
      · rfl
      · norm_cast; exact PNat.ne_zero _
  induction z using TensorProduct.induction_on with
  | zero => use 1, 0; simp
  | add x y hx hy => exact h_add hx hy
  | tmul d zHat =>
    induction d using TensorProduct.induction_on with
    | zero => use 1, 0; simp
    | add x y hx hy => rw [TensorProduct.add_tmul]; exact h_add hx hy
    | tmul q o =>
      use ⟨q.den, q.den_pos⟩, q.num • (o ⊗ₜ zHat)
      rw [← j₂.map_smul, ← smul_mul_assoc, ← j₁.map_smul]
      apply (Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat).injective
      simp [j₁, j₂]
      rw [← TensorProduct.smul_tmul', Rat.num_div_den]
      rfl
