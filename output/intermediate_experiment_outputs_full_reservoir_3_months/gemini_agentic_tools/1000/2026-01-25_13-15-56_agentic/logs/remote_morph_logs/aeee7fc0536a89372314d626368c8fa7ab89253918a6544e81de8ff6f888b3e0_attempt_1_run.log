lemma canonicalForm (z : D^) : ∃ (N : ℕ+) (z' : 𝓞^), z = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1 : D) * j₂ z' := by
  let f := Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat
  let P (x : D^) : Prop := ∃ (N : ℕ+) (z' : 𝓞^), f x = (N : ℚ)⁻¹ ⊗ₜ z'
  have h_add {x y : D^} (hx : P x) (hy : P y) : P (x + y) := by
    obtain ⟨N1, z1', hx⟩ := hx; obtain ⟨N2, z2', hy⟩ := hy
    use N1 * N2, (N2 : ℤ) • z1' + (N1 : ℤ) • z2'
    simp only [map_add, hx, hy, TensorProduct.tmul_add, ← TensorProduct.smul_tmul]
    congr 1
    · rw [PNat.coe_mul, Nat.cast_mul, mul_inv, ← mul_assoc,
          zsmul_eq_mul, inv_mul_cancel (Nat.cast_ne_zero.mpr N2.ne_zero), one_mul]
    · rw [PNat.coe_mul, Nat.cast_mul, mul_inv, mul_comm (N2 : ℚ)⁻¹, ← mul_assoc,
          zsmul_eq_mul, inv_mul_cancel (Nat.cast_ne_zero.mpr N1.ne_zero), one_mul]
  have h_final (z : D^) : P z := by
    induction z using TensorProduct.induction_on with
    | zero => use 1, 0; simp only [f, map_zero, TensorProduct.tmul_zero]
    | tmul d zH =>
      induction d using TensorProduct.induction_on with
      | zero => use 1, 0; simp only [f, map_zero, TensorProduct.tmul_zero]
      | tmul q o =>
        use ⟨q.den, q.den_pos⟩, q.num • (o ⊗ₜ zH)
        simp only [f, Algebra.TensorProduct.assoc_tmul, ← TensorProduct.smul_tmul, zsmul_eq_mul, smul_eq_mul]
        congr
        field_simp [q.den_pos.ne']
        norm_cast
        exact Rat.num_div_den q
      | add d1 d2 h1 h2 => rw [TensorProduct.add_tmul]; exact h_add h1 h2
    | add x y hx hy => exact h_add hx hy
  obtain ⟨N, z', h_eq⟩ := h_final z
  use N, z'
  apply f.injective
  rw [h_eq, map_mul]
  simp only [f, j₁, j₂, AlgEquiv.toAlgHom_apply, AlgEquiv.apply_symm_apply,
    Algebra.TensorProduct.includeLeft_apply, Algebra.TensorProduct.assoc_tmul,
    Algebra.TensorProduct.includeRight_apply, one_mul,
    Algebra.TensorProduct.tmul_mul_tmul, mul_one]
