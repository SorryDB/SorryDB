-- should I rearrange tensors? Not sure if D^ should be (ℚ ⊗ 𝓞) ⊗ ℤhat or ℚ ⊗ (𝓞 ⊗ Zhat)
lemma canonicalForm (z : D^) : ∃ (N : ℕ+) (z' : 𝓞^), z = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1 : D) * j₂ z' := by
  let P (x : D^) : Prop := ∃ (N : ℕ+) (z' : 𝓞^), x = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1) * j₂ z'
  have h_add {x y : D^} (hx : P x) (hy : P y) : P (x + y) := by
    obtain ⟨N1, z1', rfl⟩ := hx
    obtain ⟨N2, z2', rfl⟩ := hy
    let N := N1 * N2
    use N, (N2 : ℤ) • z1' + (N1 : ℤ) • z2'
    rw [map_add, mul_add, ← _root_.map_add j₂]
    have h1 : j₁ ((N1 : ℚ)⁻¹ ⊗ₜ (1 : 𝓞)) = (N2 : ℤ) • j₁ ((N : ℚ)⁻¹ ⊗ₜ (1 : 𝓞)) := by
      rw [← _root_.map_smul, ← TensorProduct.smul_tmul, zsmul_eq_mul]
      congr 1; field_simp [N, N1, N2]; norm_cast; ring
    have h2 : j₁ ((N2 : ℚ)⁻¹ ⊗ₜ (1 : 𝓞)) = (N1 : ℤ) • j₁ ((N : ℚ)⁻¹ ⊗ₜ (1 : 𝓞)) := by
      rw [← _root_.map_smul, ← TensorProduct.smul_tmul, zsmul_eq_mul]
      congr 1; field_simp [N, N1, N2]; norm_cast; ring
    rw [h1, h2, smul_mul_assoc, smul_mul_assoc, ← mul_smul_comm, ← mul_smul_comm]
    rw [← _root_.map_smul j₂, ← _root_.map_smul j₂, ← mul_add]
  induction z using TensorProduct.induction_on with
  | zero => use 1, 0; simp
  | add x y hx hy => exact h_add hx hy
  | tmul d zHat =>
    induction d using TensorProduct.induction_on with
    | zero => use 1, 0; simp
    | add x y hx hy => rw [TensorProduct.add_tmul]; exact h_add hx hy
    | tmul q o =>
      let N : ℕ+ := ⟨q.den, Nat.pos_of_ne_zero q.den_nz⟩
      use N, q.num • (o ⊗ₜ zHat)
      apply (Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat).injective
      rw [map_mul, map_smul, Algebra.TensorProduct.assoc_tmul, AlgEquiv.apply_symm_apply]
      simp only [Algebra.TensorProduct.includeLeft_apply, Algebra.TensorProduct.assoc_tmul, one_mul]
      rw [← TensorProduct.tmul_smul, ← TensorProduct.smul_tmul, zsmul_eq_mul]
      congr; rw [Rat.num_div_den, mul_comm, div_eq_mul_inv]; congr; norm_cast
