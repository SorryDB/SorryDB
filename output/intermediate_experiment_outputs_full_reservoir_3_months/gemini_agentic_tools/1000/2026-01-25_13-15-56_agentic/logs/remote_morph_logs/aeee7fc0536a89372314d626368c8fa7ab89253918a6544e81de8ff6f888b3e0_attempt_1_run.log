-- should I rearrange tensors? Not sure if D^ should be (ℚ ⊗ 𝓞) ⊗ ℤhat or ℚ ⊗ (𝓞 ⊗ Zhat)
lemma canonicalForm (z : D^) : ∃ (N : ℕ+) (z' : 𝓞^), z = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1 : D) * j₂ z' := by
  let f := Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat
  let P (x : D^) : Prop := ∃ (N : ℕ+) (z' : 𝓞^), f x = (N : ℚ)⁻¹ ⊗ₜ z'
  have h_add {x y : D^} (hx : P x) (hy : P y) : P (x + y) := by
    obtain ⟨N1, z1', hx⟩ := hx; obtain ⟨N2, z2', hy⟩ := hy
    use N1 * N2, (N2 : ℤ) • z1' + (N1 : ℤ) • z2'
    rw [map_add f, hx, hy, TensorProduct.tmul_add]
    have h1 : (N1 : ℚ)⁻¹ ⊗ₜ[ℤ] z1' = (N1 * N2 : ℚ)⁻¹ ⊗ₜ[ℤ] ((N2 : ℤ) • z1') := by
      rw [← TensorProduct.smul_tmul]; congr 1
      push_cast; simp only [mul_inv, mul_assoc, inv_mul_cancel (Nat.cast_ne_zero.mpr N2.ne_zero), mul_one]
    have h2 : (N2 : ℚ)⁻¹ ⊗ₜ[ℤ] z2' = (N1 * N2 : ℚ)⁻¹ ⊗ₜ[ℤ] ((N1 : ℤ) • z2') := by
      rw [← TensorProduct.smul_tmul]; congr 1
      push_cast; simp only [mul_inv, mul_assoc, inv_mul_cancel (Nat.cast_ne_zero.mpr N1.ne_zero), mul_one, mul_comm (N2 : ℚ)⁻¹]
    rw [h1, h2]
  have h_final (z : D^) : P z := by
    induction z using TensorProduct.induction_on with
    | zero => use 1, 0; rw [map_zero f, TensorProduct.tmul_zero]
    | tmul d zH =>
      induction d using TensorProduct.induction_on with
      | zero => use 1, 0; rw [TensorProduct.zero_tmul, map_zero f, TensorProduct.tmul_zero]
      | tmul q o =>
        use ⟨q.den, q.den_pos⟩, q.num • (o ⊗ₜ zH)
        rw [Algebra.TensorProduct.assoc_tmul, TensorProduct.tmul_smul, ← TensorProduct.smul_tmul]
        congr 1
        · push_cast; rw [← Rat.num_div_den q, div_eq_mul_inv, mul_comm]
        · rfl
      | add d1 d2 h1 h2 => rw [TensorProduct.add_tmul]; exact h_add h1 h2
    | add x y hx hy => exact h_add hx hy
  obtain ⟨N, z', h_eq⟩ := h_final z
  use N, z'
  apply f.injective
  rw [h_eq, map_mul f, j₁, j₂, AlgHom.comp_apply, Algebra.TensorProduct.includeLeft_apply,
    Algebra.TensorProduct.includeRight_apply, AlgEquiv.apply_symm_apply,
    Algebra.TensorProduct.assoc_tmul, TensorProduct.tmul_mul_tmul, mul_one, one_mul]
