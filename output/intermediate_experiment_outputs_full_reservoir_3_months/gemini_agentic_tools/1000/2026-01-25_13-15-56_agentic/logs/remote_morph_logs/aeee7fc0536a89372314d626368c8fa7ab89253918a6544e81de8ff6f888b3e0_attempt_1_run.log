-- should I rearrange tensors? Not sure if D^ should be (ℚ ⊗ 𝓞) ⊗ ℤhat or ℚ ⊗ (𝓞 ⊗ Zhat)
lemma canonicalForm (z : D^) : ∃ (N : ℕ+) (z' : 𝓞^), z = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1 : D) * j₂ z' := by
  let f := Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat
  let P (x : D^) : Prop := ∃ (N : ℕ+) (z' : 𝓞^), f x = (N : ℚ)⁻¹ ⊗ₜ z'
  have h_add {x y : D^} (hx : P x) (hy : P y) : P (x + y) := by
    obtain ⟨N1, z1', hx⟩ := hx; obtain ⟨N2, z2', hy⟩ := hy
    use N1 * N2, (N2 : ℤ) • z1' + (N1 : ℤ) • z2'
    rw [f.map_add, hx, hy, TensorProduct.tmul_add]
    have h1 : (N1 * N2 : ℚ)⁻¹ ⊗ₜ[ℤ] ((N2 : ℤ) • z1') = (N1 : ℚ)⁻¹ ⊗ₜ z1' := by
      rw [← TensorProduct.smul_tmul]; push_cast; congr; field_simp; ring
    have h2 : (N1 * N2 : ℚ)⁻¹ ⊗ₜ[ℤ] ((N1 : ℤ) • z2') = (N2 : ℚ)⁻¹ ⊗ₜ z2' := by
      rw [← TensorProduct.smul_tmul]; push_cast; congr; field_simp; ring
    rw [h1, h2]
  have h_final (z : D^) : P z := by
    induction z using TensorProduct.induction_on with
    | zero => use 1, 0; rw [f.map_zero, TensorProduct.tmul_zero]
    | tmul d zH =>
      induction d using TensorProduct.induction_on with
      | zero => use 1, 0; rw [TensorProduct.zero_tmul, f.map_zero, TensorProduct.tmul_zero]
      | tmul q o =>
        use ⟨q.den, q.den_pos⟩, q.num • (o ⊗ₜ zH)
        rw [Algebra.TensorProduct.assoc_tmul, ← TensorProduct.smul_tmul]
        push_cast; congr; field_simp; exact (Rat.num_div_den q).symm
      | add d1 d2 h1 h2 => rw [TensorProduct.add_tmul]; exact h_add h1 h2
    | add x y hx hy => exact h_add hx hy
  obtain ⟨N, z', h_eq⟩ := h_final z
  use N, z'
  apply f.injective
  rw [h_eq, f.map_mul]
  simp [f, j₁, j₂, AlgEquiv.toAlgHom_apply, Algebra.TensorProduct.assoc_tmul,
    Algebra.TensorProduct.includeLeft_apply, AlgEquiv.apply_symm_apply,
    Algebra.TensorProduct.tmul_mul_tmul, AlgHom.comp_apply,
    Algebra.TensorProduct.includeRight_apply, one_mul, mul_one]
```
