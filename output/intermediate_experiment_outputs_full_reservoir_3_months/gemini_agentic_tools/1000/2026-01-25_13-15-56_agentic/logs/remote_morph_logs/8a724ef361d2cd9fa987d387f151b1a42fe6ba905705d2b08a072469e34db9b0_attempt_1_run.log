def SystemState.propagate : SystemState → RequestId → ThreadId → SystemState
  | state, reqId, thId => Id.run do
  match state.requests.getReq? reqId with
  | none => state
  | some req_old =>
    let req := req_old.propagate thId
    let requests' := state.requests.insert req
    let scope := state.scopes.jointScope thId req.thread
    let orderConstraints' := state.updateOrderConstraintsPropagate scope reqId thId
    let mut res := { state with
      requests := requests', orderConstraints := orderConstraints', removedCoherent := fun id h => by have h_in := state.removedCoherent id h; simp [requests', reqIds, RequestArray.insert, RequestArray.insertAtPosition, List.mem_filterMap, List.mem_set] at *; split at * <;> { try (simp [List.mem_filterMap] at h_in); by_cases heq : id = req.id <;> simp [heq, h_in, *] } }
    let writesOnThread := res.requests.filter λ w => w.isWrite && w.propagatedTo thId
    for write in writesOnThread do
      res := addNewPredecessors res write (res.requests.getReq! req.id) thId
    res := {res with orderConstraints := res.updateOrderConstraintsAfterPropagate thId}
    return res
