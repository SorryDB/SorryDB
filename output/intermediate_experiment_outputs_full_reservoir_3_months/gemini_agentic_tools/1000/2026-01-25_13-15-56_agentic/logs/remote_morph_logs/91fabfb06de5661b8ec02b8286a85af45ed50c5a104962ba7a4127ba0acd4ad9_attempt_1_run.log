import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hS : ∀ n, n ∈ S ↔ ∃ k : ℕ, n = 50 * k + 39 := by
    intro n; rw [h₀]; constructor
    · rintro ⟨-, h⟩
      have h1 : 14 * n ≡ 14 * 39 [MOD 100] := by rw [h]; norm_num
      have h2 : 7 * n ≡ 7 * 39 [MOD 50] := Nat.ModEq.mul_left_cancel (by norm_num) (by rwa [show 14 * n = 2 * (7 * n) by ring, show 14 * 39 = 2 * (7 * 39) by ring, show 100 = 2 * 50 by norm_num] at h1)
      have h3 : n ≡ 39 [MOD 50] := Nat.ModEq.cancel_left_of_coprime (by norm_num) h2
      use n / 50; rw [Nat.div_add_mod n 50, h3, Nat.mod_eq_of_lt (by norm_num)]
    · rintro ⟨k, rfl⟩; refine ⟨by norm_num, ?_⟩
      rw [show 14 * (50 * k + 39) = 100 * (7 * k + 5) + 46 by ring, Nat.add_mul_mod_self_left, Nat.mod_eq_of_lt (by norm_num)]
  have hu : u = 39 := by
    apply h₁.unique; constructor
    · rw [hS]; use 0; norm_num
    · intro n hn; rw [hS] at hn; obtain ⟨k, rfl⟩ := hn; linarith
  have hv : v = 89 := by
    apply h₂.unique; constructor
    · constructor
      · rw [hS]; use 1; norm_num
      · rw [hu]; norm_num
    · rintro n ⟨hnS, hnu⟩; rw [hS] at hnS; obtain ⟨k, rfl⟩ := hnS; rw [hu] at hnu
      have : k ≠ 0 := by intro h; apply hnu; rw [h]; norm_num
      have : k ≥ 1 := Nat.pos_of_ne_zero this
      linarith
  rw [hu, hv]; norm_num

