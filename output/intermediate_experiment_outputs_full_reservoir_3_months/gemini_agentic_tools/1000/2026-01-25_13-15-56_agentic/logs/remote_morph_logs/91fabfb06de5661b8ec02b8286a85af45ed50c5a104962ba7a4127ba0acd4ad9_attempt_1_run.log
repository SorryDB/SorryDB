theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hS : ∀ n, n ∈ S ↔ ∃ k : ℕ, n = 50 * k + 39 := by
    intro n; rw [h₀]; constructor
    · rintro ⟨_, hn⟩
      have h1 : 7 * n % 50 = 23 := by
        have h_mod : 2 * (7 * n % 50) = 46 := by
          rw [← Nat.mul_mod_mul_left 2 (7 * n) 50, show 2 * (7 * n) = 14 * n by ring, hn]
          rfl
        exact Nat.eq_of_mul_eq_mul_left (by norm_num) h_mod
      have h2 : 49 * n % 50 = 11 := by
        rw [show 49 * n = 7 * (7 * n) by ring, Nat.mul_mod, h1]
      use n / 50
      have h3 : (n + 49 * n) % 50 = 0 := by
        rw [show n + 49 * n = 50 * n by ring, Nat.mul_mod_right 50 n]
      have h4 : (n % 50 + 49 * n % 50) % 50 = 0 := by
        rw [← Nat.add_mod, h3]
      rw [h2] at h4
      omega
    · rintro ⟨k, rfl⟩; constructor; · omega
      · rw [show 14 * (50 * k + 39) = 100 * (7 * k + 5) + 46 by ring]
        rw [Nat.mul_add_mod_self_left]; rfl
  have hu : u = 39 := IsLeast.unique h₁
    ⟨(hS 39).mpr ⟨0, rfl⟩, fun n hn => by obtain ⟨k, rfl⟩ := (hS n).mp hn; omega⟩
  have hv : v = 89 := IsLeast.unique h₂
    ⟨⟨(hS 89).mpr ⟨1, rfl⟩, by rw [hu]; omega⟩, fun n hn => by
      obtain ⟨hSn, hne⟩ := hn; obtain ⟨k, rfl⟩ := (hS n).mp hSn
      rw [hu] at hne; have : k ≥ 1 := by omega
      omega⟩
  rw [hu, hv]
  norm_num

