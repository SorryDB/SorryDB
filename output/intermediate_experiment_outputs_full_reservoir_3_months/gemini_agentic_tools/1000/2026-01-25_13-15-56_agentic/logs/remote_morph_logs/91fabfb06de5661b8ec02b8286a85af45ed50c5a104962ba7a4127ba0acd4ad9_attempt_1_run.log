set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hS : ∀ n, n ∈ S ↔ ∃ k : ℕ, n = 50 * k + 39 := by
    intro n
    rw [h₀]
    constructor
    · rintro ⟨_, hn⟩
      have h1 : 2 * (7 * n % 50) = 2 * 23 := by
        rw [← Nat.mul_mod_mul_left, hn]
        norm_num
      have h2 : 7 * n % 50 = 23 := by linarith [h1]
      have h4 : (49 * n) % 50 = 11 := by
        have : (7 * (7 * n)) % 50 = 11 := by rw [Nat.mul_mod, h2]; norm_num
        ring_nf at this; exact this
      have h5 : (n + 11) % 50 = 0 := by
        have : (n + 49 * n) % 50 = (n + 11) % 50 := by
          rw [Nat.add_mod, h4]
          norm_num
        rw [show n + 49 * n = 50 * n by ring, Nat.mul_mod_right] at this
        exact this.symm
      have h6 : n % 50 = 39 := by
        have : (n % 50 + 11) % 50 = 0 := by rw [← h5, Nat.add_mod]
        have h_dvd : 50 ∣ (n % 50 + 11) := Nat.dvd_of_mod_eq_zero this
        rcases h_dvd with ⟨m, hm⟩
        have : n % 50 < 50 := Nat.mod_lt _ (by norm_num)
        have : m = 1 := by linarith
        subst this; linarith
      use n / 50
      rw [Nat.div_add_mod n 50, h6, add_comm]
    · rintro ⟨k, rfl⟩
      constructor
      · linarith
      · have : 14 * (50 * k + 39) = 100 * (7 * k + 5) + 46 := by ring
        rw [this, Nat.mul_add_mod_self_left]
        norm_num
  have hu : u = 39 := by
    apply h₁.unique
    constructor
    · rw [hS]; use 0; norm_num
    · intro n hn; rw [hS] at hn; obtain ⟨k, rfl⟩ := hn; linarith
  have hv : v = 89 := by
    apply h₂.unique
    constructor
    · constructor
      · rw [hS]; use 1; norm_num
      · rw [hu]; norm_num
    · rintro n ⟨hnS, hnu⟩
      rw [hS] at hnS; obtain ⟨k, rfl⟩ := hnS; rw [hu] at hnu
      have : k ≠ 0 := by intro h; apply hnu; rw [h]; norm_num
      have : k ≥ 1 := Nat.pos_of_ne_zero this
      linarith
  rw [hu, hv]
  norm_num

