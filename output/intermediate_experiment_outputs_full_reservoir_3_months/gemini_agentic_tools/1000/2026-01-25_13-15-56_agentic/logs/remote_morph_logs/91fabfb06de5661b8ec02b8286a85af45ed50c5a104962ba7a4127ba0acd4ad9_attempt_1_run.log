import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hS : ∀ n, n ∈ S ↔ ∃ k : ℕ, n = 50 * k + 39 := by
    intro n; rw [h₀]; constructor
    · rintro ⟨_, hn⟩
      have h1 : 7 * n % 50 = 23 := by
        have h2 := Nat.mul_mod_mul_left 2 (7 * n) 50
        rw [show 2 * (7 * n) = 14 * n by ring, show 2 * 50 = 100 by ring, hn] at h2
        omega
      have h2 : n % 50 = 39 := by
        have h3 : (7 * (7 * n)) % 50 = (7 * 23) % 50 := by rw [← Nat.mul_mod, h1]
        have h4 : 49 * n % 50 = 11 := by
          rw [show 49 * n = 7 * (7 * n) by ring]; exact h3
        have h8 : n % 50 < 50 := Nat.mod_lt _ (by norm_num)
        have h9 : (49 * n + n) % 50 = (11 + n % 50) % 50 := by
          rw [Nat.add_mod, h4, ← Nat.add_mod]
        have h10 : (50 * n) % 50 = 0 := by rw [Nat.mul_mod_right]
        rw [show 49 * n + n = 50 * n by ring, h10] at h9
        omega
      use n / 50; rw [Nat.div_add_mod n 50, h2, add_comm]
    · rintro ⟨k, rfl⟩; constructor; · linarith
      · rw [show 14 * (50 * k + 39) = 100 * (7 * k + 5) + 46 by ring]
        rw [Nat.mul_add_mod_self_left]; norm_num
  have hu : u = 39 := h₁.unique ⟨by rw [hS]; use 0; norm_num,
    fun n hn => by rw [hS] at hn; obtain ⟨k, rfl⟩ := hn; linarith⟩
  have hv : v = 89 := h₂.unique ⟨by
    constructor
    · constructor
      · rw [hS]; use 1; norm_num
      · rw [hu]; norm_num
    · rintro n ⟨hnS, hne⟩
      rw [hS] at hnS; obtain ⟨k, rfl⟩ := hnS; rw [hu] at hne
      have : k ≠ 0 := by intro h; subst h; norm_num at hne
      have : k ≥ 1 := Nat.pos_of_ne_zero this
      linarith⟩
  rw [hu, hv]
  norm_num

