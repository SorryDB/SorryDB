    (h₄ : ∀ n, f (4 * n + 3) + 2 * f n = 3 * f (2 * n + 1)) :
    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  have f_rev : ∀ (n : ℕ+), f n = n ↔ (Nat.digits 2 (n : ℕ)) = (Nat.digits 2 (n : ℕ)).reverse := by
    sorry
  let s := {n : ℕ+ | n ≤ 1988 ∧ f n = n}
  let t := (Finset.range 1989).filter (λ n => 0 < n ∧ Nat.digits 2 n = (Nat.digits 2 n).reverse)
  have h_inj : Set.InjOn (λ (n : ℕ+) => (n : ℕ)) s := λ _ _ _ _ h => Subtype.ext h
  have h_image : (λ (n : ℕ+) => (n : ℕ)) '' s = ↑t := by
    ext x
    constructor
    · rintro ⟨n, hn, rfl⟩
      simp only [s, Set.mem_setOf_eq] at hn
      simp only [Set.mem_coe, Finset.mem_filter, Finset.mem_range]
