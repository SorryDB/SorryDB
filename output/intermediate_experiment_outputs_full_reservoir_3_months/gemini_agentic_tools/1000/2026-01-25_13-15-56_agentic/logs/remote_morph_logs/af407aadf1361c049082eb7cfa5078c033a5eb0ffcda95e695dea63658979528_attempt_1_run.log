    (h₄ : ∀ n, f (4 * n + 3) + 2 * f n = 3 * f (2 * n + 1)) :
    Set.ncard {n | n ≤ 1988 ∧ f n = n} = solution := by
  have f_rev : ∀ (n : ℕ+), f n = n ↔ (Nat.digits 2 (n : ℕ)) = (Nat.digits 2 (n : ℕ)).reverse := by
    sorry
  have h_card : {n | n ≤ 1988 ∧ f n = n}.ncard = 92 := by
    let t := (Finset.range 1989).filter (λ n => 0 < n ∧ Nat.digits 2 n = (Nat.digits 2 n).reverse)
