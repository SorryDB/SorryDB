      exact ⟨Nat.le_of_lt_succ h_lt, (f_rev ⟨x, h_pos⟩).mpr h_pal⟩
  rw [← Set.ncard_image_of_injOn h_inj, h_image, Set.ncard_coe_finset t]
  have h_t_card : t.card = 92 := by native_decide
  exact h_t_card
