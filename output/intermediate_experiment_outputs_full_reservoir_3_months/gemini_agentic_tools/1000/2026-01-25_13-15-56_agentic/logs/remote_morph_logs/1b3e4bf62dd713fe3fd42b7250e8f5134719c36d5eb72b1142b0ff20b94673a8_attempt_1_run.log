    ∧ AntitoneOn (fun x ↦ ε₄ I (t₀ x) x (σ₂ x) K (T x)) (Set.Ioi (exp (I.R * exp 2))) ∧ AntitoneOn (fun x ↦ (ε₄ I (t₀ x) x (σ₂ x) K (T x)) * (t₀ x)^2 / (log (t₀ x))^3) (Set.Ioi (exp (I.R * exp 2)))
    := by
  intro t₀ T σ₂ w₁ C f
  exact sorryAx _ false
