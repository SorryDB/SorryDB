import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / (x : ℝ)}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  constructor
  · rintro ⟨hfpos, hf⟩
    ext x
    let y_x x := (hf x).exists.choose
    have hy_x x : (x : ℝ) * f (y_x x) + (y_x x) * f x ≤ 2 := (hf x).exists.choose_spec.1
    have h_y_x_unique x y : (x : ℝ) * f y + (y : ℝ) * f x ≤ 2 → y = y_x x := (hf x).exists.choose_spec.2
    have h_xfx_le_1 x : (x : ℝ) * f x ≤ 1 := by
      by_contra hgt
      push_neg at hgt
      let y0 := y_x x
      have h_y0_ne_x : y0 ≠ x := by
        intro h_eq; rw [h_eq] at hgt; linarith [hy_x x]
      have h_y_y0_is_x : y_x y0 = x := h_y_x_unique y0 x (by rw [add_comm]; exact hy_x x)
      have h_y0fy0_le_1 : (y0 : ℝ) * f y0 ≤ 1 := by
        have : 4 * ((x : ℝ) * f y0 * (y0 : ℝ) * f x) ≤ ((x : ℝ) * f y0 + (y0 : ℝ) * f x)^2 := by
          rw [← sub_nonneg]; ring_nf; exact pow_two_nonneg _
        have : 4 * ((x : ℝ) * f y0 * (y0 : ℝ) * f x) ≤ 4 := by
          calc 4 * ((x : ℝ) * f y0 * (y0 : ℝ) * f x)
            _ ≤ ((x : ℝ) * f y0 + (y0 : ℝ) * f x)^2 := this
            _ ≤ 2^2 := by gcongr; exact hy_x x
            _ = 4 := rfl
        have : (x : ℝ) * f y0 * (y0 : ℝ) * f x ≤ 1 := by linarith
        have : (y0 : ℝ) * f y0 * ((x : ℝ) * f x) ≤ 1 := by rw [mul_assoc, mul_comm (f y0) (x : ℝ)]; linarith
        exact (le_div_iff₀ hgt).mp (by rw [mul_comm]; exact this)
      have h_y_y0_is_y0 : y_x y0 = y0 := h_y_x_unique y0 y0 (by linarith)
      rw [h_y_y0_is_x] at h_y_y0_is_y0; exact h_y0_ne_x h_y_y0_is_y0.symm
    have h_xfx_ge_1 x : 1 ≤ (x : ℝ) * f x := by
      by_contra hlt; push_neg at hlt
      let ε := 1 / (x : ℝ) - f x
      have hε : 0 < ε := by field_simp; exact hlt
      let d_val := Real.sqrt (x.1^3 * ε / 8)
      let y_val := x.1 + min (x.1 / 2) d_val
      have hy_pos : 0 < y_val := by linarith [x.2]
      let y : ℝ+ := ⟨y_val, hy_pos⟩
      have hyne : y ≠ x := by
        intro h; have h_val := Subtype.ext_iff.mp h
        have : 0 < min (x.1 / 2) d_val := by apply lt_min (by linarith [x.2]); apply Real.sqrt_pos.mpr; positivity
        linarith
      have : (x : ℝ) * f y + (y : ℝ) * f x ≤ 2 := by
        have hfy : f y ≤ 1 / (y : ℝ) := (le_div_iff₀ y.2).mpr (by rw [mul_comm]; exact h_xfx_le_1 y)
        calc (x : ℝ) * f y + (y : ℝ) * f x
          _ ≤ (x : ℝ) / y + y * f x := by gcongr
          _ = (x : ℝ) / y + y * (1 / (x : ℝ) - ε) := rfl
          _ = (x : ℝ) / y + y / x - y * ε := by field_simp
          _ = 2 + (y - x)^2 / (x * y) - y * ε := by field_simp [x.2, y.2]; ring
          _ ≤ 2 := by
            rw [add_le_iff_nonpos_right, sub_nonpos, div_le_iff₀ (by positivity)]
            let diff := y_val - x.1
            have hdiff_pos : 0 < diff := by apply lt_min (by linarith [x.2]); apply Real.sqrt_pos.mpr; positivity
            calc diff^2 ≤ d_val^2 := pow_le_pow_left hdiff_pos.le (min_le_right _ _) 2
              _ = x.1^3 * ε / 8 := Real.sq_sqrt (by positivity)
              _ ≤ x.1 * (x.1 / 2) * (x.1 / 2) * ε := by ring
              _ ≤ (x.1 * y_val) * (y_val * ε) := by gcongr; linarith [x.2]; linarith [min_le_left (x.1 / 2) d_val]; linarith [min_le_left (x.1 / 2) d_val]; linarith [x.2]
      exact hyne (h_y_x_unique x y this)
    have h_xfx := le_antisymm (h_xfx_le_1 x) (h_xfx_ge_1 x)
    field_simp [h_xfx, x.2]; rw [h_xfx]
  · rintro (hf : f = fun x => 1 / (x : ℝ))
    rw [hf]; simp; intro x; use x; constructor
    · field_simp; exact le_refl 2
    · intro y hy; field_simp at hy
      have : (x : ℝ)^2 + (y : ℝ)^2 ≤ 2 * x * y := by field_simp [x.2, y.2] at hy; linarith
      have : ((x : ℝ) - (y : ℝ))^2 ≤ 0 := by linarith
      exact Subtype.ext (by linarith [pow_two_nonneg ((x : ℝ) - (y : ℝ))])

