namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x ↦ 1 / (x : ℝ)}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
