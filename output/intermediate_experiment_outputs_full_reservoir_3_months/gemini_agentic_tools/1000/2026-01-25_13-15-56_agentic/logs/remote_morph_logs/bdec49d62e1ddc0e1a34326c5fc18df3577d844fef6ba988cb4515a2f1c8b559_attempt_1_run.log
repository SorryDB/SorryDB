        have : 4 * ((x : ℝ) * f y * ((y : ℝ) * f x)) ≤ ((x : ℝ) * f y + (y : ℝ) * f x) ^ 2 := by
          have : 0 ≤ ((x : ℝ) * f y - (y : ℝ) * f x) ^ 2 := sq_nonneg _
          linarith
        have : 4 * ((x : ℝ) * f x * ((y : ℝ) * f y)) ≤ 2 ^ 2 := by
          have h_prod : ((x : ℝ) * f y * ((y : ℝ) * f x)) = ((x : ℝ) * f x * ((y : ℝ) * f y)) := by ring
          rw [← h_prod]
          exact this.trans (pow_le_pow_left₀ (by positivity) hy_spec 2)
        nlinarith
      have h_yy : (y : ℝ) * f y + (y : ℝ) * f y ≤ 2 := by nlinarith
      have h_yx : (y : ℝ) * f x + (x : ℝ) * f y ≤ 2 := by rwa [add_comm]
      have : x = y := (h_unique y).unique h_yx h_yy
      subst this
      linarith
    intro x
    by_contra h_xfx
    have h_gx_lt : (x : ℝ) * f x < 1 := (h_le_one x).lt_of_ne h_xfx
    obtain ⟨y_sol, hy_sol_le, hy_sol_uni⟩ := h_unique x
    have h_xx : (x : ℝ) * f x + (x : ℝ) * f x ≤ 2 := by nlinarith
    have h_x_eq_sol : x = y_sol := hy_sol_uni x h_xx
    let g := (x : ℝ) * f x
    let a := (1 + Real.sqrt (1 - g)) / g
    have ha_pos : 0 < a := by
      have hg_pos : 0 < g := by positivity
      apply div_pos _ hg_pos
      apply add_pos_of_pos_of_nonneg one_pos (Real.sqrt_nonneg _)
    let y : ℝ+ := ⟨a * x.1, mul_pos ha_pos x.2⟩
    have h_y_sol_for_x : (x : ℝ) * f y + (y : ℝ) * f x ≤ 2 := by
      calc (x : ℝ) * f y + (y : ℝ) * f x
        _ = (x.1 / y.1) * ((y : ℝ) * f y) + (y.1 / x.1) * ((x : ℝ) * f x) := by
          have hx0 : (x : ℝ) ≠ 0 := ne_of_gt x.2
