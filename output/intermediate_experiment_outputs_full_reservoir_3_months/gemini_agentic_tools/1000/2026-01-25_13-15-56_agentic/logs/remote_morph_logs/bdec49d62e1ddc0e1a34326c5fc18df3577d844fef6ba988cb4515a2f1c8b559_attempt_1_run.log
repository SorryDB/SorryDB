    have h_le_one : ∀ x : ℝ+, (x : ℝ) * f x ≤ 1 := by
      intro x
      obtain ⟨y, hy_sol, hy_uni⟩ := h_unique x
      have h_prod : ((x : ℝ) * f y) * ((y : ℝ) * f x) = ((x : ℝ) * f x) * ((y : ℝ) * f y) := by ring
      have h_sqrt : 2 * Real.sqrt (((x : ℝ) * f y) * ((y : ℝ) * f x)) ≤ (x : ℝ) * f y + (y : ℝ) * f x :=
        Real.two_sqrt_mul_le_add (mul_pos x.2 (hpos y)).le (mul_pos y.2 (hpos x)).le
      have h_gxgz : ((x : ℝ) * f x) * ((y : ℝ) * f y) ≤ 1 := by
        rw [← h_prod]
        have : Real.sqrt (((x : ℝ) * f y) * ((y : ℝ) * f x)) ≤ 1 := by linarith
        rwa [Real.sqrt_le_one (mul_pos x.2 (hpos y) |>.le)] at this
      by_contra h_gt
      have h_gx_gt : 1 < (x : ℝ) * f x := not_le.mp h_gt
      have h_gy_lt : (y : ℝ) * f y < 1 := by
        have : 0 < (x : ℝ) * f x := hgx x
        nlinarith
      have h_y_sol_y : (y : ℝ) * f y + (y : ℝ) * f y ≤ 2 := by linarith
      have h_x_sol_y : (y : ℝ) * f x + (x : ℝ) * f y ≤ 2 := by rwa [add_comm]
      have : x = y := (h_unique y).unique h_x_sol_y h_y_sol_y
      subst this
      linarith
    have h_one : ∀ x : ℝ+, (x : ℝ) * f x = 1 := by
      intro x
      by_contra h_ne
      have h_lt : (x : ℝ) * f x < 1 := (h_le_one x).lt_of_ne h_ne
      obtain ⟨y_sol, hy_sol, hy_uni⟩ := h_unique x
      have h_x_sol_x : (x : ℝ) * f x + (x : ℝ) * f x ≤ 2 := by linarith
      have h_x_eq : x = y_sol := hy_uni x h_x_sol_x
      let g := (x : ℝ) * f x
      let a := (1 + Real.sqrt (1 - g)) / g
      have ha : 0 < a := by
        have : 0 < g := hgx x
        positivity
      let y : ℝ+ := ⟨a * x, mul_pos ha x.2⟩
      have h_y_sol_x : (x : ℝ) * f y + (y : ℝ) * f x ≤ 2 := by
        calc (x : ℝ) * f y + (y : ℝ) * f x
          _ = (x : ℝ) / (y : ℝ) * ((y : ℝ) * f y) + (y : ℝ) / (x : ℝ) * g := by
            field_simp [ne_of_gt x.2, ne_of_gt y.2]; ring
          _ ≤ (x : ℝ) / (y : ℝ) * 1 + (y : ℝ) / (x : ℝ) * g := by
