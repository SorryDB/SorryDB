      linarith [h_le_one x]
    rw [answer, Set.mem_singleton_iff]
    funext x
    have h1 := h_one x
    field_simp [ne_of_gt x.2] at h1 ⊢
    exact h1
  · intro hf
    rw [answer, Set.mem_singleton_iff] at hf
    subst hf
    constructor
    · intro x; dsimp; positivity
    · intro x
      use x
      constructor
      · dsimp; field_simp [ne_of_gt x.2]; linarith
