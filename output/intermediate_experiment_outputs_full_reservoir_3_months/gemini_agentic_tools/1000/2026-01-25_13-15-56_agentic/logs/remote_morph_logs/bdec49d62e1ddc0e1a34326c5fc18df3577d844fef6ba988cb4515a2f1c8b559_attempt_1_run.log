import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x ↦ 1 / (x : ℝ)}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  constructor
  · rintro ⟨hpos, h_unique⟩
    rw [answer, Set.mem_singleton_iff]
    funext x
    let g := fun (z : ℝ+) ↦ (z : ℝ) * f z
    have hg_pos : ∀ z, 0 < g z := fun z ↦ mul_pos z.2 (hpos z)
    have hg_le : ∀ z, g z ≤ 1 := by
      intro z
      obtain ⟨y, hy_spec, _⟩ := h_unique z
      have h_gzgy : g z * g y ≤ 1 := by
        have h_sq := sq_nonneg (z.1 * f y - y.1 * f z)
        have h_mul : g z * g y = (z.1 * f y) * (y.1 * f z) := by dsimp [g]; ring
        nlinarith
      by_contra hgz
      have hgy_lt : g y < 1 := by
        have : 0 < g z := hg_pos z
        nlinarith [not_le.mp hgz]
      have h_yy : y.1 * f y + y.1 * f y ≤ 2 := by dsimp [g]; linarith
      have h_zy : y.1 * f z + z.1 * f y ≤ 2 := by dsimp [g]; rwa [add_comm]
      have z_eq_y : z = y := (h_unique y).unique h_zy h_yy
      subst z_eq_y
      nlinarith
    have hg_eq : ∀ z, g z = 1 := by
      intro z
      by_contra hgz
      have hgz_lt : g z < 1 := (hg_le z).lt_of_ne hgz
      obtain ⟨y_sol, _, hy_uniq⟩ := h_unique z
      have h_zz : z.1 * f z + z.1 * f z ≤ 2 := by dsimp [g]; linarith
      have z_eq_ysol : z = y_sol := hy_uniq z h_zz
      have hy_pos : 0 < z.1 / Real.sqrt (g z) := div_pos z.2 (Real.sqrt_pos.mpr (hg_pos z))
      let y : ℝ+ := ⟨z.1 / Real.sqrt (g z), hy_pos⟩
      have h_zy : z.1 * f y + y.1 * f z ≤ 2 := by
        have h_gz : 0 < g z := hg_pos z
        calc z.1 * f y + y.1 * f z
          _ = (z.1 / y.1) * g y + (y.1 / z.1) * g z := by dsimp [g]; field_simp [z.2.ne', y.2.ne']; ring
          _ ≤ (z.1 / y.1) * 1 + (y.1 / z.1) * g z := by
            gcongr
            exact hg_le y
          _ = Real.sqrt (g z) + (1 / Real.sqrt (g z)) * g z := by
            dsimp [y]; field_simp [z.2.ne', (Real.sqrt_pos.mpr h_gz).ne']
          _ = 2 * Real.sqrt (g z) := by
            rw [← Real.mul_self_sqrt h_gz.le]
            field_simp [Real.sqrt_ne_zero.mpr h_gz.ne']; ring
          _ < 2 := by
            have : Real.sqrt (g z) < 1 := Real.sqrt_lt_one (hg_pos z).le hgz_lt
            linarith
      have y_eq_ysol : y = y_sol := hy_uniq y h_zy.le
      have z_eq_y : z = y := z_eq_ysol.trans y_eq_ysol.symm
      have : Real.sqrt (g z) = 1 := by
        have h_val : z.1 = y.1 := Subtype.ext_iff.mp z_eq_y
        dsimp [y] at h_val
        field_simp [z.2.ne', (Real.sqrt_pos.mpr (hg_pos z)).ne'] at h_val
        exact h_val.symm
      nlinarith
    have hgx : (x : ℝ) * f x = 1 := hg_eq x
    field_simp [x.2.ne'] at hgx
    exact hgx
  · intro hf
    rw [answer, Set.mem_singleton_iff] at hf
    subst hf
    constructor
    · intro x; dsimp; exact one_div_pos.mpr x.2
    · intro x
      use x
      constructor
      · dsimp; field_simp [x.2.ne']; linarith
      · intro y hy
        dsimp at hy
        field_simp [x.2.ne', y.2.ne'] at hy
        apply Subtype.ext
        nlinarith [sq_nonneg (x.1 - y.1)]
