Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x ↦ 1 / (x : ℝ)}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  constructor
  · rintro ⟨hpos, h_unique⟩
    unfold answer; simp
    funext x
    let g := fun (z : ℝ+) ↦ (z : ℝ) * f z
    have hg_pos : ∀ z, 0 < g z := fun z ↦ mul_pos z.2 (hpos z)
    have hg_le_1 : ∀ z, g z ≤ 1 := by
      intro z
      obtain ⟨y, hy_spec, _⟩ := h_unique z
      have h_gz_gy : g z * g y ≤ 1 := by
        have h_sq := four_mul_le_add_sq (z.1 * f y) (y.1 * f z)
        have h_mul : (z.1 * f y) * (y.1 * f z) = g z * g y := by dsimp [g]; ring
        rw [h_mul] at h_sq
        nlinarith
      by_contra hgz
      have hgy : g y < 1 := by nlinarith [hg_pos z]
      obtain ⟨y_sol, _, hy_sol_uniq⟩ := h_unique y
      have h_zy : (y : ℝ) * f z + (z : ℝ) * f y ≤ 2 := by rwa [add_comm]
      have h_yy : (y : ℝ) * f y + (y : ℝ) * f y ≤ 2 := by dsimp [g]; linarith
      have hzy : z = y := by rw [hy_sol_uniq z h_zy, ← hy_sol_uniq y h_yy]
      subst hzy
      nlinarith
    have hg_eq_1 : ∀ z, g z = 1 := by
      intro z
      by_contra hgz
      have hgz_lt : g z < 1 := (hg_le_1 z).lt_of_ne hgz
      obtain ⟨y_sol, _, hy_uniq⟩ := h_unique z
      have h_zz : (z : ℝ) * f z + (z : ℝ) * f z ≤ 2 := by dsimp [g]; linarith [hg_le_1 z]
      have h_z_sol : z = y_sol := hy_uniq z h_zz
      let y_val := z.1 / Real.sqrt (g z)
      have hy_pos : 0 < y_val := by positivity
      let y : ℝ+ := ⟨y_val, hy_pos⟩
      have h_zy : (z : ℝ) * f y + (y : ℝ) * f z ≤ 2 := by
        calc (z : ℝ) * f y + (y : ℝ) * f z
          _ = (z.1 / y.1) * g y + (y.1 / z.1) * g z := by dsimp [g]; field_simp [z.2, y.2]; ring
          _ ≤ (z.1 / y.1) * 1 + (y.1 / z.1) * g z := by nlinarith [hg_le_1 y, hg_pos z, hg_pos y]
          _ = Real.sqrt (g z) + (1 / Real.sqrt (g z)) * g z := by dsimp [y]; field_simp [z.2, (hg_pos z).ne']
          _ = 2 * Real.sqrt (g z) := by
            rw [← Real.mul_self_sqrt (hg_pos z).le]
            field_simp [Real.sqrt_ne_zero.mpr (hg_pos z).ne']; ring
          _ < 2 := (mul_lt_iff_lt_one_right (zero_lt_two)).mpr (Real.sqrt_lt_one (hg_pos z).le hgz_lt)
      have h_y_sol : y = y_sol := hy_uniq y h_zy.le
      have hzy : z = y := by rw [h_z_sol, ← h_y_sol]
      have : Real.sqrt (g z) = 1 := by
        have h_val : z.1 = y.1 := Subtype.ext_iff.mp hzy
        dsimp [y] at h_val
        field_simp [z.2] at h_val
        exact h_val.symm
      nlinarith
    have hgx : (x : ℝ) * f x = 1 := hg_eq_1 x
    apply (mul_eq_iff_eq_div₀ x.2.ne').mp; exact hgx
  · intro hf
    unfold answer at hf; simp at hf
    subst hf
    constructor
    · intro x; dsimp; positivity
    · intro x
      use x
      constructor
      · dsimp; field_simp; linarith
      · intro y hy
        dsimp at hy
        field_simp [x.2, y.2] at hy
        have : (x : ℝ)^2 + (y : ℝ)^2 ≤ 2 * x * y := by nlinarith
        have : ((x : ℝ) - (y : ℝ))^2 ≤ 0 := by nlinarith
        apply Subtype.ext
        nlinarith [pow_two_nonneg ((x : ℝ) - (y : ℝ))]

