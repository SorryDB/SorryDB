import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x ↦ 1 / (x : ℝ)}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  constructor
  · rintro ⟨hpos, h_unique⟩
    rw [answer, Set.mem_singleton_iff]
    have h_sol : ∀ x, (x : ℝ) * f x ≤ 1 := by
      intro x
      obtain ⟨y, hy_spec, _⟩ := h_unique x
      have h_xy : (x.1 * f y) * (y.1 * f x) ≤ 1 := by
        have := four_mul_le_add_sq (x.1 * f y) (y.1 * f x)
        nlinarith
      by_contra h_xfx
      have h_y : (y : ℝ) * f y < 1 := by
        have : (x.1 * f x) * (y.1 * f y) = (x.1 * f y) * (y.1 * f x) := by ring
        nlinarith [hpos x, hpos y, x.2, y.2]
      have h_yy : (y : ℝ) * f y + (y : ℝ) * f y ≤ 2 := by nlinarith
      have h_xy' : (y : ℝ) * f x + (x : ℝ) * f y ≤ 2 := by rw [add_comm]; exact hy_spec
      obtain ⟨y_sol, _, hy_sol_uniq⟩ := h_unique y
      have : x = y := (hy_sol_uniq x h_xy').trans (hy_sol_uniq y h_yy).symm
      subst this
      nlinarith
    have h_eq : ∀ x, (x : ℝ) * f x = 1 := by
      intro x
      by_contra h_xfx
      have h_lt : (x : ℝ) * f x < 1 := (h_sol x).lt_of_ne h_xfx
      let y_val := x.1 / (Real.sqrt (x.1 * f x))
      have hy_pos : 0 < y_val := by positivity
      let y : ℝ+ := ⟨y_val, hy_pos⟩
      have h_xy : (x : ℝ) * f y + (y : ℝ) * f x ≤ 2 := by
        calc (x : ℝ) * f y + (y : ℝ) * f x
          _ = (x.1 / y.1) * (y.1 * f y) + (y.1 / x.1) * (x.1 * f x) := by field_simp [x.2, y.2]; ring
          _ ≤ (x.1 / y.1) * 1 + (y.1 / x.1) * (x.1 * f x) := by gcongr; apply h_sol
          _ = 2 * Real.sqrt (x.1 * f x) := by
            dsimp [y]; field_simp [x.2, hpos x]
            rw [← Real.mul_self_sqrt (mul_pos x.2 (hpos x)).le]; field_simp; ring
          _ < 2 := by nlinarith [Real.sqrt_lt_one (mul_pos x.2 (hpos x)).le h_lt]
      have h_xx : (x : ℝ) * f x + (x : ℝ) * f x ≤ 2 := by nlinarith [h_lt]
      obtain ⟨x_sol, _, hx_uniq⟩ := h_unique x
      have : x = y := (hx_uniq x h_xx).trans (hx_uniq y h_xy).symm
      have : x.1 = y.1 := Subtype.ext_iff.mp this
      dsimp [y] at this
      field_simp [x.2] at this
      have : Real.sqrt (x.1 * f x) = 1 := this.symm
      nlinarith
    funext x
    have := h_eq x
    field_simp [x.2] at this
    exact this
  · intro hf
    rw [answer, Set.mem_singleton_iff] at hf
    subst hf
    constructor
    · intro x; dsimp; positivity
    · intro x
      use x
      constructor
      · dsimp; field_simp; linarith
      · intro y hy
        dsimp at hy
        field_simp [x.2, y.2] at hy
        apply Subtype.ext
        nlinarith [pow_two_nonneg (x.1 - y.1)]
