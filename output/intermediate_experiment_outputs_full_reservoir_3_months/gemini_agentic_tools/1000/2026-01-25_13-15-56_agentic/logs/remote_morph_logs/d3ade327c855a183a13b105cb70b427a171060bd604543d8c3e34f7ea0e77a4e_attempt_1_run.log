theorem Params.initial.score (ε : ℝ) (hε : ε > 0) :
    ∀ᶠ n in Filter.atTop, ∃ P : Params, P.n = n ∧ P.initial.score P.L ≤ ε * n := by
  let M := ⌈4 / ε⌉₊
  have hM_pos : 0 < M := Nat.ceil_pos.mpr (by positivity)
  let L := M * M
  have hL_pos : 0 < L := by positivity
  have h_pi : Tendsto (fun n : ℕ ↦ (primeCounting n : ℝ) / n) atTop (𝓝 0) :=
    tendsto_primeCounting_div_n.comp tendsto_nat_cast_atTop
  filter_upwards [eventually_gt_atTop (L * L),
    h_pi.eventually (lt_mem_nhds (by positivity : 0 < ε / (4 * M * L ^ 3))),
    (tendsto_log_div_pow_atTop 1 (by positivity)).eventually (lt_mem_nhds (by positivity : 0 < ε / 4))] with n hnL hn_pi hn_log
  set P : Params := ⟨n, M, L, hL_pos, hnL⟩
  use P, rfl
  unfold Factorization.score
  have h_waste := P.initial.waste
  have h_penalty : (if P.initial.total_imbalance > 0 then log n else 0) ≤ log n := by split_ifs <;> positivity
  -- The total score is the sum of the waste, which is at most n * log (1 - 1/M)⁻¹ ≈ n/M,
  -- and the imbalances at each prime. By the lemmas Params.initial.balance_*, these are
  -- at most M or M log n, which combined with the density of primes leads to an o(n)
  -- contribution for large n. For sufficiently large n, the sum is less than εn.
