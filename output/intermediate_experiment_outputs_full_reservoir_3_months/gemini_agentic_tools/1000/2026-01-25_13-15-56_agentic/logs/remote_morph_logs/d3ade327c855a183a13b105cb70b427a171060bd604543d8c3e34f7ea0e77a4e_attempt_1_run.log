theorem Params.initial.score (ε : ℝ) (hε : ε > 0) :
    ∀ᶠ n in Filter.atTop, ∃ P : Params, P.n = n ∧ P.initial.score P.L ≤ ε * n := by
  let M := ⌈8 / ε⌉₊ + 2
  let L := M * M
  have hM_pos : 0 < M := Nat.succ_pos _
  have hL_pos : 0 < L := Nat.mul_pos hM_pos hM_pos
  have h_waste_lim : Tendsto (fun n : ℕ ↦ (n : ℝ) * log (1 - 1 / (M : ℝ))⁻¹ / n) atTop (𝓝 (log (1 - 1 / (M : ℝ))⁻¹)) :=
    tendsto_const_nhds.congr (fun n ↦ by rw [mul_div_cancel_left₀ _ (Nat.cast_ne_zero.mpr (pos_of_gt hnL).ne')]; intro; linarith)
  filter_upwards [Filter.eventually_ge_atTop (L * L + 1),
    tendsto_log_div_atTop.eventually (lt_mem_nhds (by positivity : 0 < ε / 8)),
    (tendsto_primeCounting_div_n).eventually (lt_mem_nhds (by positivity : 0 < ε / (8 * (M : ℝ) * L ^ 2)))] with n hnL h_log_n h_pi
  set P : Params := ⟨n, M, L, hL_pos, hnL⟩
  use P, rfl
  -- The score is composed of waste, a log n penalty, and the sum over primes.
  -- By the lemmas Params.initial.balance_*, we have waste ≤ n * log(1-1/M)⁻¹ ≈ n/M,
  -- and each prime's contribution in the sum is bounded by O(M log n) or similar.
  -- The log n term and the prime sum are o(n), while the waste is < εn/2 for large M.
