  let M := ⌈20 / ε⌉₊ + 1
  let L := M * M
  have hM_pos : 0 < M := Nat.succ_pos _
  have hL_pos : 0 < L := Nat.mul_pos hM_pos hM_pos
  have h_o_n : Filter.Tendsto (fun n : ℕ => (Real.log n + (M : ℝ) * (L : ℝ) ^ 2 * (Nat.primeCounting n : ℝ) / Real.log n) / n) Filter.atTop (Filter.nhds 0) := sorry
  filter_upwards [Filter.eventually_ge_atTop (L * L + 1),
    h_o_n.eventually (Filter.lt_mem_nhds (by positivity : 0 < ε / 2))] with n hnL ho
  set P : Params := ⟨n, M, L, hL_pos, hnL⟩
  use P, rfl
  unfold Factorization.score
  have h_waste := P.initial.waste
  have h_penalty : (if P.initial.total_imbalance > 0 then Real.log n else 0) ≤ Real.log n := by split_ifs <;> linarith
  have h_sum : ∑ p ∈ (n + 1).primesBelow, (if P.initial.balance p > 0 then (P.initial.balance p : ℝ) * Real.log p else if p ≤ L then (-P.initial.balance p : ℝ) * Real.log L else (-P.initial.balance p : ℝ) * Real.log (n / p)) ≤ ε / 2 * n := sorry
  have h_w_small : Real.log (1 - 1 / (M : ℝ))⁻¹ ≤ ε / 4 := sorry
  calc P.initial.waste + (if P.initial.total_imbalance > 0 then Real.log n else 0) + ∑ p ∈ (n + 1).primesBelow, if P.initial.balance p > 0 then (P.initial.balance p : ℝ) * Real.log p else if p ≤ L then (-P.initial.balance p : ℝ) * Real.log L else (-P.initial.balance p : ℝ) * Real.log (n / p)
    _ ≤ (P.n : ℝ) * Real.log (1 - 1 / (M : ℝ))⁻¹ + Real.log n + ε / 2 * n := by linarith
    _ ≤ (n : ℝ) * (ε / 4) + Real.log n + ε / 2 * n := by linarith
    _ ≤ ε * n := by linarith [ho]
