/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_not_le.mpr ⟨refinement_le B hB hB' hB'', fun h_refine ↦ ?_⟩
  rcases H with ⟨N, hN, h_ne⟩
  apply h_ne
  have h_subset : B N hN ⊆ {N} := by
    intro N' hN'_in
    have N'_mem : N' ∈ (refinement B hB hB' hB'').carrier :=
      Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hN'_in⟩⟩
    rcases h_refine N'_mem with ⟨S, S_sub, h_sSup⟩
    have S_sub_N : S ⊆ {N} := by
      intro A hA
      have hA_le_N : A ≤ N := by
        have hN'_le_N : N' ≤ N := by rw [hB N hN]; exact le_sSup hN'_in
        have hA_le_N' : A ≤ N' := by rw [h_sSup]; exact le_sSup hA
        exact hA_le_N'.trans hN'_le_N
      by_contra h_ne_AN
      have h_disj : Disjoint A N := D.sSupIndep.pairwiseDisjoint (S_sub hA) hN h_ne_AN
      have hA_eq_bot : A = ⊥ := h_disj.eq_bot_of_le hA_le_N
      have hA_in_D : A ∈ D := S_sub hA
      rw [hA_eq_bot] at hA_in_D
      exact D.not_bot_mem hA_in_D
    cases Set.eq_empty_or_nonempty S with
    | inl hS =>
      rw [hS, sSup_empty] at h_sSup
      rw [h_sSup] at hN'_in
      exact hB'' N hN hN'_in
    | inr hS =>
      have S_eq : S = {N} := by
        apply Set.Subset.antisymm S_sub_N
        rcases hS with ⟨x, hx⟩
        have : x = N := Set.mem_singleton_iff.mp (S_sub_N hx)
        rw [← this]
        exact Set.singleton_subset_iff.mpr hx
      have : N' = N := by rw [h_sSup, S_eq, sSup_singleton]
      exact Set.mem_singleton_iff.mpr this
  apply Set.Subset.antisymm h_subset
  intro x hx
  rw [Set.mem_singleton_iff] at hx; subst hx
  by_contra h_not_mem
  have h_empty : B N hN = ∅ := by
    apply Set.eq_empty_iff_forall_not_mem.mpr
    intro N' hN'_in
    have : N' = N := Set.mem_singleton_iff.mp (h_subset hN'_in)
    rw [this] at hN'_in
    exact h_not_mem hN'_in
  have : N = ⊥ := by rw [hB N hN, h_empty, sSup_empty]
  exact D.not_bot_mem (this ▸ hN)
