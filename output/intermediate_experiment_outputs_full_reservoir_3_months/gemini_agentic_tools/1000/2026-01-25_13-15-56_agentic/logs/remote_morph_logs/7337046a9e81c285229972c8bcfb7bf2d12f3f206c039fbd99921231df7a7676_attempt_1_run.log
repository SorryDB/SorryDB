/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine ⟨refinement_le B hB hB' hB'', fun h_refine ↦ ?_⟩
  rcases H with ⟨N, hN, h_ne⟩
  apply h_ne
  have h_subset : B N hN ⊆ {N} := by
    intro N' hN'
    have hN'_mem : N' ∈ (refinement B hB hB' hB'').carrier := Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hN'⟩⟩
    rcases h_refine hN'_mem with ⟨B'', hB''_sub, h_sSup⟩
    have h_B''_sub_N : ∀ A ∈ B'', A = N := by
      intro A hA
      have h_A_le_N : A ≤ N := (le_sSup hA).trans (h_sSup.trans_le (hB N hN ▸ le_sSup hN'))
      by_contra h_ne_AN
      exact D.not_bot_mem (disjoint_iff.mp ((D.sSupIndep.pairwiseDisjoint (hB''_sub hA) hN h_ne_AN).mono_left h_A_le_N) ▸ hB''_sub hA)
    cases Set.subset_singleton_iff_eq_empty_or_singleton.mp h_B''_sub_N with
    | inl h_empty => rw [h_empty, sSup_empty] at h_sSup; exact (hB'' N hN (h_sSup ▸ hN')).elim
    | inr h_singleton => exact Set.mem_singleton_iff.mpr (h_singleton ▸ sSup_singleton ▸ h_sSup)
  apply Set.Subset.antisymm h_subset
  intro x hx
  rw [Set.mem_singleton_iff] at hx; subst hx
  by_contra h_not_mem
  have h_empty : B N hN = ∅ := Set.subset_singleton_iff_eq_empty_or_singleton.mp h_subset |>.resolve_right h_not_mem
  have : N = ⊥ := h_empty ▸ hB N hN ▸ sSup_empty
  exact D.not_bot_mem (this ▸ hN)
```
