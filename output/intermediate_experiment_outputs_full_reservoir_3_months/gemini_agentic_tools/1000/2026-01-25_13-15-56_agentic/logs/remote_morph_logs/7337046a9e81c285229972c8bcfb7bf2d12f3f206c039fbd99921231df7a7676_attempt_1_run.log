/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_not_le.mpr ⟨refinement_le B hB hB' hB'', fun h_le ↦ ?_⟩
  obtain ⟨N, hN, h_ne⟩ := H
  apply h_ne
  have h_subset : B N hN ⊆ {N} := by
    intro N' hN'
    have h_mem : N' ∈ (refinement B hB hB' hB'').carrier := by
      simp only [refinement, Set.mem_iUnion]
      exact ⟨N, hN, hN'⟩
    obtain ⟨S, hS_sub, hS_sup⟩ := h_le h_mem
    have h_S_le_N : sSup S ≤ N := hS_sup.symm ▸ (hB N hN ▸ le_sSup hN')
    have h_S_sub : S ⊆ {N} := by
      intro A hA
      have h_A_le_N : A ≤ N := (le_sSup hA).trans h_S_le_N
      by_contra h_ne_AN
      have h_disj : Disjoint A N := D.sSupIndep.pairwiseDisjoint (hS_sub hA) hN h_ne_AN
      exact D.not_bot_mem (h_disj.eq_bot_of_le h_A_le_N ▸ hS_sub hA)
    have h_S_ne : S.Nonempty := by
      by_contra hS_empty
      have : N' = ⊥ := by
        rw [hS_sup, Set.not_nonempty_iff_eq_empty.mp hS_empty, sSup_empty]
      exact hB'' N hN (this ▸ hN')
    obtain ⟨A, hA⟩ := h_S_ne
    have h_A_eq_N : A = N := Set.mem_singleton_iff.mp (h_S_sub hA)
    have h_S_eq : S = {N} := Set.Subset.antisymm h_S_sub (h_A_eq_N ▸ Set.singleton_subset_iff.mpr hA)
    rw [hS_sup, h_S_eq, sSup_singleton]
  apply Set.Subset.antisymm h_subset
  intro x hx
  rw [Set.mem_singleton_iff] at hx; subst hx
  have h_B_ne : (B N hN).Nonempty := by
    by_contra h_empty
    have h_N_bot : N = ⊥ := by rw [hB N hN, Set.not_nonempty_iff_eq_empty.mp h_empty, sSup_empty]
    exact D.not_bot_mem (h_N_bot ▸ hN)
  obtain ⟨N'', hN''⟩ := h_B_ne
  have h_N''_eq_N : N'' = N := Set.mem_singleton_iff.mp (h_subset hN'')
  rwa [h_N''_eq_N] at hN''
