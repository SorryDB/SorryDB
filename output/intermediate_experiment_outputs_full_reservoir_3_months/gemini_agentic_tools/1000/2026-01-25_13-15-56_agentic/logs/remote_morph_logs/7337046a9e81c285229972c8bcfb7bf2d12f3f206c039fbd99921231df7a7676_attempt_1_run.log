/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_not_le.mpr ⟨refinement_le B hB hB' hB'', fun h_le ↦ ?_⟩
  rcases H with ⟨N₀, hN₀, h_ne⟩
  apply h_ne
  have h_subset : B N₀ hN₀ ⊆ {N₀} := by
    intro N' hN'
    have h_mem : N' ∈ (refinement B hB hB' hB'').carrier :=
      Set.mem_iUnion.mpr ⟨N₀, Set.mem_iUnion.mpr ⟨hN₀, hN'⟩⟩
    rcases h_le h_mem with ⟨S, hS_sub, hS_sup⟩
    have h_S_le_N₀ : sSup S ≤ N₀ := by
      rw [← hS_sup]
      exact (hB N₀ hN₀).symm ▸ le_sSup hN'
    have h_S_sub : S ⊆ {N₀} := by
      intro A hA
      by_contra h_ne_AN₀
      have h_disj : Disjoint A N₀ := D.sSupIndep.pairwiseDisjoint (hS_sub hA) hN₀ h_ne_AN₀
      have h_bot : A = ⊥ := h_disj.eq_bot_of_le ((le_sSup hA).trans h_S_le_N₀)
      exact D.not_bot_mem (h_bot ▸ hS_sub hA)
    have h_S_ne : S.Nonempty := by
      by_contra hS_empty
      have h_bot : N' = ⊥ := by
        rw [hS_sup, Set.not_nonempty_iff_eq_empty.mp hS_empty, sSup_empty]
      exact hB'' N₀ hN₀ (h_bot ▸ hN')
    rcases h_S_ne with ⟨A, hA⟩
    have h_A_eq : A = N₀ := Set.mem_singleton_iff.mp (h_S_sub hA)
    rw [hS_sup, Set.Subset.antisymm h_S_sub (h_A_eq ▸ Set.singleton_subset_iff.mpr hA), sSup_singleton]
    exact Set.mem_singleton N₀
  apply Set.Subset.antisymm h_subset
  intro x hx
  obtain rfl : x = N₀ := Set.mem_singleton_iff.mp hx
  have h_nonempty : (B N₀ hN₀).Nonempty := by
    by_contra h_empty
    have h_bot : N₀ = ⊥ := by
      rw [hB N₀ hN₀, Set.not_nonempty_iff_eq_empty.mp h_empty, sSup_empty]
    exact D.not_bot_mem (h_bot ▸ hN₀)
  rcases h_nonempty with ⟨N'', hN''⟩
  have h_N''_eq : N'' = N₀ := Set.mem_singleton_iff.mp (h_subset hN'')
  exact h_N''_eq ▸ hN''
