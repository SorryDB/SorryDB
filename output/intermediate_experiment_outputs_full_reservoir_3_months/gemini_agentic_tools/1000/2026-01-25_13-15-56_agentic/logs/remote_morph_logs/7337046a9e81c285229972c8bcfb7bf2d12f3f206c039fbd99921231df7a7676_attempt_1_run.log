/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_not_le.mpr ⟨refinement_le B hB hB' hB'', fun h_le ↦ ?_⟩
  obtain ⟨N, hN, h_ne⟩ := H
  apply h_ne
  have h_subset : B N hN ⊆ {N} := by
    intro N' hN'
    have h_mem : N' ∈ (refinement B hB hB' hB'').carrier :=
      Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hN'⟩⟩
    obtain ⟨S, hS_sub, hS_sup⟩ := h_le h_mem
    have h_N'_le_N : N' ≤ N := (hB N hN).symm ▸ le_sSup hN'
    have h_S_le_N : sSup S ≤ N := hS_sup.symm ▸ h_N'_le_N
    have h_S_sub_N : S ⊆ {N} := by
      intro A hA
      by_contra h_ne_AN
      have h_disj : Disjoint A N := (sSupIndep_iff_pairwiseDisjoint.mp D.sSupIndep) (hS_sub hA) hN h_ne_AN
      have h_bot : A = ⊥ := h_disj.eq_bot_of_le ((le_sSup hA).trans h_S_le_N)
      exact D.not_bot_mem (h_bot ▸ hS_sub hA)
    have h_S_ne : S.Nonempty := by
      by_contra h_empty
      have h_bot : N' = ⊥ := by rw [hS_sup, Set.not_nonempty_iff_eq_empty.mp h_empty, sSup_empty]
      exact hB'' N hN (h_bot ▸ hN')
    obtain ⟨A, hA⟩ := h_S_ne
    have h_A_eq : A = N := h_S_sub_N hA
    rw [hS_sup, Set.Subset.antisymm h_S_sub_N (Set.singleton_subset_iff.mpr (h_A_eq ▸ hA)), sSup_singleton]
    exact Set.mem_singleton N
  apply Set.Subset.antisymm h_subset
  intro x hx
  rw [Set.mem_singleton_iff] at hx; subst hx
  have h_nonempty : (B N hN).Nonempty := by
    by_contra h_empty
    have h_bot : N = ⊥ := by rw [hB N hN, Set.not_nonempty_iff_eq_empty.mp h_empty, sSup_empty]
    exact D.not_bot_mem (h_bot ▸ hN)
  obtain ⟨N'', hN''⟩ := h_nonempty
  have : N'' = N := h_subset hN''
  rwa [this] at hN''
