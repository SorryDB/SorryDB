namespace ArrayModel

open unitInterval

section Aux

-- from Mathlib PR #30112
theorem representation {α β : Type*} {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
    [Nonempty β] [StandardBorelSpace β]
    (κ : Kernel α β) [IsMarkovKernel κ] :
    ∃ (f : α → I → β), Measurable (Function.uncurry f) ∧ ∀ a, volume.map (f a) = κ a :=
  ProbabilityTheory.Kernel.exists_measurable_fun_uncurry_map_volume_eq κ

end Aux

end ArrayModel
