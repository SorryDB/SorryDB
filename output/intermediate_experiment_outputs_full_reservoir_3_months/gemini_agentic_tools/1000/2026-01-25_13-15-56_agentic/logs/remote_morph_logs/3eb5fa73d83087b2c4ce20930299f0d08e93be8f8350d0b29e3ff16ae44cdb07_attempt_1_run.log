namespace FinEnv

@[simp]
def toEnv {Ident Typ} [DecidableEq Typ] (ε : FinEnv Ident Typ) : Env Ident Typ := ε.find?

theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  induction a with
  | nil => exact ⟨[], rfl, fun _ _ h => by cases h, List.nodup_nil⟩
  | cons h t ih =>
    let ⟨bt, hlen, hfresh, hnodup⟩ := ih
    let forbidden := (ε.toList.map (fun p => p.1.2)) ++ bt
    let M := (forbidden.map String.length).foldr Nat.max 0
    let hb := String.mk (List.replicate (M + 1) 'a')
    have hb_fresh : hb ∉ forbidden := by
      intro h_mem
      have h_len : hb.length = M + 1 := by simp [hb, String.length]
      have h_le_M : hb.length ≤ M := by
        let lengths := forbidden.map String.length
        have h_in_lengths : hb.length ∈ lengths := List.mem_map_of_mem String.length h_mem
        induction lengths with
        | nil => cases h_in_lengths
        | cons s ss ih_s =>
          cases h_in_lengths with
          | head h_eq => exact h_eq ▸ Nat.le_max_left _ _
          | tail h_mem' => exact Nat.le_trans (ih_s h_mem') (Nat.le_max_right _ _)
      exact Nat.not_succ_le_self M (h_len ▸ h_le_M)
    exists hb :: bt
    constructor
    · simp [hlen]
    · constructor
      · intro a' b' h_zip
        simp [List.zip_cons] at h_zip
        cases h_zip with
        | head h_eq =>
          cases h_eq; intro h_cont
          apply hb_fresh
          apply List.mem_append_left
          induction ε with
          | nil => simp [Batteries.AssocList.contains] at h_cont
          | cons k v rest ih_ε =>
            simp [Batteries.AssocList.contains, Batteries.AssocList.toList] at h_cont ⊢
            if h_key : (h, hb) == k then
              left; exact (eq_of_beq_eq_true h_key) ▸ rfl
            else
              right; apply ih_ε; simp [h_key] at h_cont; exact h_cont
        | tail h_tail => exact hfresh a' b' h_tail
      · simp [hnodup]
        intro h_in_zip
        apply hb_fresh
        apply List.mem_append_right
        have h_map : (t.zip bt).map Prod.snd = bt := by
          induction t generalizing bt with
          | nil => simp at hlen; subst bt; rfl
          | cons th tt ih_t =>
            cases bt with
            | nil => simp at hlen
            | cons bth btt => simp; apply ih_t; simp at hlen; exact hlen
        rw [← h_map]
        exact List.mem_map_of_mem Prod.snd h_in_zip

end FinEnv
