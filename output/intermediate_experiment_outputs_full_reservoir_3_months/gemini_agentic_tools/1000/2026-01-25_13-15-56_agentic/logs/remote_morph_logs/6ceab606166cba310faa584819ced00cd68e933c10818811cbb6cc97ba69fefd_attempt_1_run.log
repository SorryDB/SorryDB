theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  have mem_add (t' : LabelledTree α) (a b : α) : b ∈ t'.addLabel a ↔ b ∈ t' ∨ b = a := by
    induction t' generalizing a with
    | leaf x =>
      simp [LabelledTree.addLabel, LabelledTree.mem, Membership.mem]
      split_ifs <;> simp [LabelledTree.mem, Membership.mem, *]
      · next h1 => rw [h1]; tauto
      · next h1 h2 => rw [h1] at h2; linarith
      · tauto
    | node v l r ihl ihr =>
      simp [LabelledTree.addLabel, LabelledTree.mem, Membership.mem]
      split_ifs <;> (simp [ihl, ihr, LabelledTree.mem, Membership.mem];
        apply Iff.intro <;> intro h <;> repeat (rcases h with h|h) <;> simp [*])
  induction t generalizing label with
  | leaf x =>
    simp [LabelledTree.addLabel, IsOrdered, LabelledTree.mem, Membership.mem]
    split_ifs <;> simp [IsOrdered, LabelledTree.mem, Membership.mem, *] <;> try linarith
    · intro y; simp [LabelledTree.mem, Membership.mem]; rintro rfl; linarith
    · intro y; simp [LabelledTree.mem, Membership.mem]; rintro rfl; linarith
  | node v l r ihl ihr =>
    simp [IsOrdered] at h; rcases h with ⟨hl, hr, hol, hor, hmem⟩
    simp [LabelledTree.addLabel, IsOrdered]; split_ifs with hle
    · specialize ihl label hol
      refine ⟨?_, hr, ihl, hor, ?_⟩
      · intro x hx; rw [mem_add] at hx; rcases hx with hx | rfl <;> [apply hl; assumption; assumption]
      · rw [mem_add]; rcases hmem with h | h <;> [left; left; assumption; right; assumption]
    · specialize ihr label hor
      refine ⟨hl, ?_, hol, ihr, ?_⟩
      · intro x hx; rw [mem_add] at hx; rcases hx with hx | rfl <;> [apply hr; assumption; linarith]
      · rw [mem_add]; rcases hmem with h | h <;> [left; assumption; right; left; assumption]

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, LabelledTree.mem, Membership.mem]
    exact beq_iff_eq x label
  | node v l r ihl ihr =>
    simp [IsOrdered] at h; rcases h with ⟨hleft, hright, ho_left, ho_right, hmem⟩
    simp [fastCheckMem]
    split_ifs with h_eq h_lt
    · rw [beq_iff_eq] at h_eq; subst v; simp [Membership.mem, hmem]
    · rw [ihl ho_left]
      rw [beq_iff_eq] at h_eq
      constructor <;> intro hin
      · left; assumption
      · rcases hin with hin | hin
        · assumption
        · exfalso; have := hright label hin; linarith
    · rw [ihr ho_right]
      rw [beq_iff_eq] at h_eq
      constructor <;> intro hin
      · right; assumption
      · rcases hin with hin | hin
        · exfalso; have := hleft label hin; linarith
        · assumption

def buildBST : List α → LabelledTree α
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)
  | [] => leaf (Inhabited.default)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    simp [buildBST]
    have h_fold (t : LabelledTree α) (l : List α) (h : IsOrdered t) :
      IsOrdered (l.foldl LabelledTree.addLabel t) := by
      induction l generalizing t with
      | nil => exact h
      | cons z zs ih => simp; apply ih; apply ordered_addLabel; exact h
    apply h_fold; simp [IsOrdered]

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil => simp [buildBST, fastCheckMem, List.Mem]; sorry
  | cons x xs =>
    rw [fastCheckMem_correct label _ (buildBST_ordered _)]
