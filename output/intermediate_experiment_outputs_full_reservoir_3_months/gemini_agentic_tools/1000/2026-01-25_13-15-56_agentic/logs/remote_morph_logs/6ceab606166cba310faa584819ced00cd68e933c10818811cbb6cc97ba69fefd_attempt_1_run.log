theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  have mem_addLabel (t' : LabelledTree α) (a b : α) :
    LabelledTree.mem (t'.addLabel a) b ↔ LabelledTree.mem t' b ∨ b = a := by
    induction t' generalizing a with
    | leaf x =>
      simp [LabelledTree.addLabel, LabelledTree.mem]
      split_ifs <;> (simp [LabelledTree.mem, *]; tauto)
    | node v l r ihl ihr =>
      simp [LabelledTree.addLabel, LabelledTree.mem]
      split_ifs <;> (simp [LabelledTree.mem, ihl, ihr]; tauto)
  induction t generalizing label with
  | leaf x =>
    simp [LabelledTree.addLabel, IsOrdered, LabelledTree.mem]
    split_ifs <;> simp [IsOrdered, LabelledTree.mem, *]
    · intro y hy; simp [LabelledTree.mem] at hy; subst hy; assumption
    · intro y hy; simp [LabelledTree.mem] at hy; rcases hy with rfl | rfl <;> linarith
    · intro y hy; simp [LabelledTree.mem] at hy; rcases hy with rfl | rfl <;> linarith
  | node v l r ihl ihr =>
    simp [IsOrdered] at h ⊢
    rcases h with ⟨hl, hr, hol, hor, hmem⟩
    simp [LabelledTree.addLabel]
    split_ifs with hle
    · specialize ihl label hol
      refine ⟨?_, hr, ihl, hor, ?_⟩
      · intro x hx; rw [mem_addLabel] at hx; rcases hx with hx | rfl <;> [apply hl; assumption; assumption]
      · rw [mem_addLabel]; rcases hmem with hM | hM <;> [left; left; exact hM; right; exact hM]
    · specialize ihr label hor
      refine ⟨hl, ?_, hol, ihr, ?_⟩
      · intro x hx; rw [mem_addLabel] at hx; rcases hx with hx | rfl <;> [apply hr; assumption; linarith]
      · rw [mem_addLabel]; rcases hmem with hM | hM <;> [left; exact hM; right; left; exact hM]

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, LabelledTree.mem, Membership.mem, beq_iff_eq]
  | node v l r ihl ihr =>
    simp [IsOrdered] at h; rcases h with ⟨hL, hR, hoL, hoR, hM⟩
    simp [fastCheckMem]
    split_ifs with h_eq h_lt
    · rw [beq_iff_eq] at h_eq; subst v; simp [Membership.mem, LabelledTree.mem, hM]
