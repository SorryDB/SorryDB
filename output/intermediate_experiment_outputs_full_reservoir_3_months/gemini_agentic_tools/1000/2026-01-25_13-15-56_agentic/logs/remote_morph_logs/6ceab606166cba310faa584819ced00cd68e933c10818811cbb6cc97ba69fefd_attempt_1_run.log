theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  have mem_add (t' : LabelledTree α) (a b : α) : b ∈ t'.addLabel a ↔ b ∈ t' ∨ b = a := by
    induction t' generalizing a with
    | leaf x =>
      simp [LabelledTree.addLabel, LabelledTree.mem, Membership.mem]
      split_ifs <;> simp [LabelledTree.mem, Membership.mem, *] <;> tauto
    | node v l r ihl ihr =>
      simp [LabelledTree.addLabel, LabelledTree.mem, Membership.mem]
      split_ifs <;> (simp [ihl, ihr, LabelledTree.mem, Membership.mem]; tauto)
  induction t generalizing label with
  | leaf x =>
    simp [LabelledTree.addLabel, IsOrdered, LabelledTree.mem, Membership.mem]
    split_ifs <;> simp [IsOrdered, LabelledTree.mem, Membership.mem, *] <;> (intro y hy; simp [LabelledTree.mem, Membership.mem] at hy; subst hy; linarith)
  | node v l r ihl ihr =>
    simp [IsOrdered] at h; rcases h with ⟨hl, hr, hol, hor, hmem⟩
    simp [LabelledTree.addLabel, IsOrdered]; split_ifs with hle
    · specialize ihl label hol
      refine ⟨?_, hr, ihl, hor, ?_⟩
      · intro x hx; rw [mem_add] at hx; rcases hx with hx | rfl <;> [apply hl; assumption; assumption]
      · rw [mem_add]; rcases hmem with h | h <;> [left; left; exact h; right; exact h]
    · specialize ihr label hor
      refine ⟨hl, ?_, hol, ihr, ?_⟩
      · intro x hx; rw [mem_add] at hx; rcases hx with hx | rfl <;> [apply hr; assumption; linarith]
      · rw [mem_add]; rcases hmem with h | h <;> [left; exact h; right; left; exact h]

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, LabelledTree.mem, Membership.mem, beq_iff_eq]
  | node v l r ihl ihr =>
    simp [IsOrdered] at h; rcases h with ⟨hL, hR, hoL, hoR, hM⟩
    simp [fastCheckMem]
    split_ifs with h_eq h_lt
    · rw [beq_iff_eq] at h_eq; subst v; simp [Membership.mem, LabelledTree.mem, hM]
    · rw [ihl hoL, beq_iff_eq] at h_eq
      simp [Membership.mem, LabelledTree.mem]
      constructor
      · intro h; left; exact h
      · rintro (h | h)
        · exact h
        · have := hR label h; linarith
    · rw [ihr hoR, beq_iff_eq] at h_eq
      simp [Membership.mem, LabelledTree.mem]
      constructor
      · intro h; right; exact h
      · rintro (h | h)
        · have := hL label h; linarith
        · exact h

def buildBST : List α → LabelledTree α
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)
  | [] => leaf (Inhabited.default)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    simp [buildBST]
    have h_fold (t : LabelledTree α) (l : List α) (h : IsOrdered t) :
      IsOrdered (l.foldl LabelledTree.addLabel t) := by
      induction l generalizing t with
      | nil => exact h
      | cons z zs ih => simp; apply ih; apply ordered_addLabel; exact h
    apply h_fold; simp [IsOrdered]

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil =>
    simp [buildBST, fastCheckMem, Membership.mem, LabelledTree.mem, beq_iff_eq]
    sorry
  | cons x xs =>
    rw [fastCheckMem_correct label _ (buildBST_ordered (x :: xs))]
    simp [buildBST]
    have mem_add (t' : LabelledTree α) (a b : α) : b ∈ t'.addLabel a ↔ b ∈ t' ∨ b = a := by
      induction t' generalizing a with
      | leaf v => simp [LabelledTree.addLabel, LabelledTree.mem, Membership.mem]; split_ifs <;> simp [LabelledTree.mem, Membership.mem, *] <;> tauto
      | node v l r ihl ihr => simp [LabelledTree.addLabel, LabelledTree.mem, Membership.mem]; split_ifs <;> (simp [ihl, ihr, LabelledTree.mem, Membership.mem]; tauto)
    have h_fold (t : LabelledTree α) (l : List α) (b : α) :
      b ∈ l.foldl LabelledTree.addLabel t ↔ b ∈ t ∨ b ∈ l := by
      induction l generalizing t with
      | nil => simp
      | cons z zs ih => simp [ih, mem_add]; tauto
    simp [h_fold, LabelledTree.mem, Membership.mem]
    tauto
