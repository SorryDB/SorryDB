theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  induction t generalizing label
  case leaf x =>
    simp [LabelledTree.addLabel, IsOrdered]
    split <;> (try split) <;> simp [IsOrdered, *] <;> (intro; try linarith)
  case node v l r ihl ihr =>
    simp [LabelledTree.addLabel, IsOrdered] at *
    rcases h with ⟨hl, hr, hol, hor, hmem⟩
    have mem_add (t' : LabelledTree α) (a b : α) : b ∈ t'.addLabel a ↔ b ∈ t' ∨ b = a := by
      induction t' generalizing a
      case leaf v => simp [LabelledTree.addLabel, Membership.mem, LabelledTree.mem]; split <;> (try split) <;> simp [Membership.mem, LabelledTree.mem, *]
      case node v l r ihl ihr => simp [LabelledTree.addLabel, Membership.mem, LabelledTree.mem]; split <;> (simp [ihl, ihr]; intro; rw [or_assoc, or_left_comm])
    split
    · specialize ihl label hol
      refine ⟨?_, hr, ihl, hor, ?_⟩
      · intro x hx; rw [mem_add] at hx; cases hx <;> (try subst x); (apply hl; assumption); assumption
      · rw [mem_add]; cases hmem <;> (try left; left; assumption); (try right; assumption)
    · specialize ihr label hor
      refine ⟨hl, ?_, hol, ihr, ?_⟩
      · intro x hx; rw [mem_add] at hx; cases hx <;> (try subst x); (apply hr; assumption); linarith
      · rw [mem_add]; cases hmem <;> (try left; assumption); (try right; left; assumption)

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l
  case leaf x =>
    simp [fastCheckMem, Membership.mem, LabelledTree.mem]; exact beq_iff_eq x label
  case node v left right ihl ihr =>
    simp [fastCheckMem, IsOrdered] at *; rcases h with ⟨hleft, hright, ho_left, ho_right, hmem⟩
    split
    · have h_eq := (beq_iff_eq v label).mp (by assumption); subst label; simp [hmem]
    · have h_ne := (beq_iff_eq v label).not.mp (by assumption); split
      · rw [ihl ho_left]; apply Iff.intro
        · intro; left; assumption
        · intro h; cases h; assumption
          have := hright label (by assumption); linarith
      · rw [ihr ho_right]; apply Iff.intro
        · intro; right; assumption
        · intro h; cases h; swap; assumption
          have := hleft label (by assumption); linarith

def buildBST : List α → LabelledTree α
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)
  | [] => leaf (Inhabited.default)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    induction xs generalizing x with
    | nil => simp [buildBST, IsOrdered]
    | cons y ys ih => simp [buildBST] at *; apply ih; apply ordered_addLabel; simp [IsOrdered]

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil => simp [buildBST, fastCheckMem]; intro h; exact False.elim (h rfl)
  | cons x xs =>
    rw [fastCheckMem_correct _ _ (buildBST_ordered _)]
    simp [buildBST]
    have mem_add (t' : LabelledTree α) (a b : α) : b ∈ t'.addLabel a ↔ b ∈ t' ∨ b = a := by
      induction t' generalizing a
      case leaf v => simp [LabelledTree.addLabel, Membership.mem, LabelledTree.mem]; split <;> (try split) <;> simp [Membership.mem, LabelledTree.mem, *]
      case node v l r ihl ihr => simp [LabelledTree.addLabel, Membership.mem, LabelledTree.mem]; split <;> (simp [ihl, ihr]; intro; rw [or_assoc, or_left_comm])
    induction xs generalizing x with
    | nil => simp [Membership.mem, LabelledTree.mem]
    | cons y ys ih => simp [ih, mem_add, or_assoc, or_left_comm]
