        · have := hL label h'; linarith
        · exact h'

def buildBST : List α → LabelledTree α
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)
  | [] => leaf (Inhabited.default)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => simp [buildBST, IsOrdered]
  | cons x xs =>
    simp [buildBST]
    have h_fold (t : LabelledTree α) (l : List α) (h : IsOrdered t) :
      IsOrdered (l.foldl LabelledTree.addLabel t) := by
      induction l generalizing t with
      | nil => exact h
      | cons z zs ih => simp; apply ih; apply ordered_addLabel; exact h
    apply h_fold; simp [IsOrdered]

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil =>
    simp [buildBST, fastCheckMem, Membership.mem, LabelledTree.mem, beq_iff_eq]
    sorry
  | cons x xs =>
    rw [fastCheckMem_correct label (buildBST (x :: xs)) (buildBST_ordered (x :: xs))]
    simp [buildBST]
    have h_mem (l : List α) (t : LabelledTree α) (b : α) :
      LabelledTree.mem (l.foldl LabelledTree.addLabel t) b ↔ LabelledTree.mem t b ∨ b ∈ l := by
      induction l generalizing t with
      | nil => simp [LabelledTree.mem]
      | cons z zs ih =>
        simp [ih]
        have mem_addLabel (t' : LabelledTree α) (a b' : α) :
          LabelledTree.mem (t'.addLabel a) b' ↔ LabelledTree.mem t' b' ∨ b' = a := by
          induction t' generalizing a with
          | leaf x =>
            simp [LabelledTree.addLabel, LabelledTree.mem]
            split_ifs <;> (simp [LabelledTree.mem, *]; tauto)
          | node v l r ihl ihr =>
            simp [LabelledTree.addLabel, LabelledTree.mem]
            split_ifs <;> (simp [ihl, ihr, LabelledTree.mem]; tauto)
        rw [mem_addLabel]; tauto
    simp [h_mem, LabelledTree.mem, Membership.mem]
    tauto
