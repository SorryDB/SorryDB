    induction t' generalizing a <;> (simp [LabelledTree.addLabel, LabelledTree.mem, Membership.mem] at *; split_ifs <;> (simp [LabelledTree.mem, Membership.mem, *] at *; try (rw [or_assoc, or_left_comm]; done); try (rw [or_comm]; done); try linarith))
  induction t generalizing label
  case leaf x => simp [LabelledTree.addLabel, IsOrdered]; split_ifs <;> simp [IsOrdered, LabelledTree.mem, *] <;> linarith
  case node v l r ihl ihr =>
    simp [IsOrdered] at h; rcases h with ⟨hl, hr, hol, hor, hmem⟩
    simp [LabelledTree.addLabel, IsOrdered]; split_ifs with hle <;> simp [ihl, ihr, hol, hor, hl, hr, mem_add, *]
    · exact hmem.imp (fun h => by rw [mem_add]; left; assumption) (fun h => h)
