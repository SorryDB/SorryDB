theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  -- two parts:
  -- (1) log x ≤ π x + 1
  -- (2) This implies that it is not bounded
  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
        by_cases hn : n = 0
        · subst hn; simp at hxge hxlt
          rw [sum_empty]
          exact Real.log_nonpos hxge hxlt.le
        · have hxpos : 0 < x := lt_of_lt_of_le (by norm_cast; exact Nat.pos_of_ne_zero hn) hxge
          refine (Real.log_le_log hxpos (by norm_cast; exact Nat.succ_pos n)).trans ?_
          have h_tel : Real.log (n + 1 : ℝ) = ∑ k ∈ range n, (Real.log (k + 2 : ℝ) - Real.log (k + 1 : ℝ)) := by
            rw [sum_range_sub (fun i ↦ Real.log (i + 1 : ℝ))]; simp
          have h_sum : ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ = ∑ k ∈ range n, (k + 1 : ℝ)⁻¹ := by
            rw [Nat.Icc_eq_Ico, sum_Ico_eq_sum_range]; simp
          rw [h_tel, h_sum]
          refine sum_le_sum fun k _ ↦ ?_
          have hk1 : (0 : ℝ) < k + 1 := by norm_cast; exact Nat.succ_pos k
          have hk2 : (0 : ℝ) < k + 2 := by norm_cast; exact Nat.succ_pos (k + 1)
          rw [← Real.log_div hk2.ne' hk1.ne', add_div, div_self hk1.ne', ← one_div]
          exact Real.log_add_one_le_self (lt_trans (by norm_num) (one_div_pos.mpr hk1))
      _ ≤ primeCountingReal x + 1 := by sorry
