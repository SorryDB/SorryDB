          have hk1 : (0 : ℝ) < k + 2 := by linarith [Nat.cast_nonneg k]
          rw [← Real.log_div hk1.ne' hk0.ne', add_div, div_self hk0.ne', ← one_div]
          exact Real.log_add_one_le_self (by linarith [Nat.cast_nonneg k])
