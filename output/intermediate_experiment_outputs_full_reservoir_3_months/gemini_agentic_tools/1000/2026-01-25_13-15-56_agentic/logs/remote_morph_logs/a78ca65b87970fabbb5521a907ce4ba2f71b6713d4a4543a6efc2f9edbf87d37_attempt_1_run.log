theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  -- two parts:
  -- (1) log x ≤ π x + 1
  -- (2) This implies that it is not bounded
  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
        by_cases hn : n = 0
        · subst hn; rw [Icc_eq_empty_of_lt Nat.one_pos, sum_empty]
          exact Real.log_nonpos (by linarith) (by linarith)
        · have hxpos : 0 < x := by linarith [Nat.cast_le.mpr (Nat.pos_of_ne_zero hn)]
          refine (Real.log_le_log hxpos (by linarith)).trans ?_
          have h_sum : ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ = ∑ k ∈ range n, (k + 1 : ℝ)⁻¹ := by
            rw [← Nat.Ico_succ_right, Finset.sum_Ico_eq_sum_range]; simp
          have h_tel : Real.log (n + 1 : ℝ) = ∑ k ∈ range n, (Real.log (k + 2 : ℝ) - Real.log (k + 1 : ℝ)) := by
            simp [sum_range_sub (fun i ↦ Real.log (i + 1 : ℝ))]
          rw [h_tel, h_sum]
          refine sum_le_sum fun k _ ↦ ?_
          have hk0 : 0 < (k + 1 : ℝ) := by linarith
          have hk1 : 0 < (k + 2 : ℝ) := by linarith
          rw [← Real.log_div hk1.ne' hk0.ne', show (k + 2 : ℝ) / (k + 1) = 1 + 1 / (k + 1) by { field_simp [hk0.ne']; ring }]
          exact Real.log_add_one_le_self (by linarith)
      _ ≤ primeCountingReal x + 1 := by sorry
