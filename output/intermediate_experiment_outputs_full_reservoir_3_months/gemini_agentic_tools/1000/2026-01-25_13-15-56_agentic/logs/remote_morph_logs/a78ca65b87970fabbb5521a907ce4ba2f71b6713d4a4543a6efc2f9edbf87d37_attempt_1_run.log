  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
        have h (n : ℕ) : Real.log (n + 1) ≤ ∑ k in Icc 1 n, (↑k)⁻¹ := by
          induction n with
          | zero => simp
          | succ n ih =>
            rw [sum_Icc_succ_top (Nat.one_le_succ n), ← Real.log_mul (Nat.cast_add_one_ne_zero n) (by positivity)]
            refine add_le_add ih ((Real.log_le_sub_one_of_pos (by positivity)).trans ?_)
            field_simp; ring
        cases n with
        | zero => exact Real.log_nonpos hxge (le_of_lt hxlt)
        | succ n => exact (Real.log_le_log_of_le (by linarith) (le_of_lt hxlt)).trans (h _)
