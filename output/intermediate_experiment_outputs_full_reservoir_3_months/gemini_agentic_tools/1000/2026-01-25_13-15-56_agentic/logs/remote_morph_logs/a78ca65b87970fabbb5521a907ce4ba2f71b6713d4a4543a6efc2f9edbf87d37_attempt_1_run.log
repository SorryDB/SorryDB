theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  -- two parts:
  -- (1) log x ≤ π x + 1
  -- (2) This implies that it is not bounded
  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
        by_cases hn : n = 0
        · subst hn
          rw [Finset.Icc_eq_empty_of_lt (by norm_num), sum_empty]
          exact Real.log_nonpos (by linarith) (by linarith)
        · have hxpos : 0 < x := by
            have : 1 ≤ n := Nat.pos_of_ne_zero hn
            linarith
          have h_sum : ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ = ∑ k ∈ range n, (k + 1 : ℝ)⁻¹ := by
            rw [← Nat.Ico_succ_right, Finset.sum_Ico_eq_sum_range, Nat.add_one_sub_one]
            congr; ext k; rw [add_comm]
          have h_tel : Real.log (n + 1 : ℝ) = ∑ k ∈ range n, (Real.log (k + 2 : ℝ) - Real.log (k + 1 : ℝ)) := by
            rw [Finset.sum_range_sub (fun i ↦ Real.log (i + 1 : ℝ))]; simp
          calc
            Real.log x ≤ Real.log (n + 1) := Real.log_le_log hxpos (by linarith)
            _ = ∑ k ∈ range n, (Real.log (k + 2) - Real.log (k + 1)) := h_tel
            _ ≤ ∑ k ∈ range n, (k + 1 : ℝ)⁻¹ := by
              apply sum_le_sum
              intro k _
              have hk1 : (0 : ℝ) < k + 1 := by norm_cast; linarith
              have hk2 : (0 : ℝ) < k + 2 := by norm_cast; linarith
              rw [← Real.log_div hk2.ne' hk1.ne', show (k + 2 : ℝ) / (k + 1) = 1 + 1 / (k + 1) by { field_simp [hk1.ne']; ring }]
              exact (Real.log_le_sub_one_of_pos (by linarith)).trans (by field_simp [hk1.ne']; ring_nf; rfl)
            _ = ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := h_sum.symm
      _ ≤ primeCountingReal x + 1 := by sorry
