/--
  # If P = NP, then the polynomial hierarchy collapses to P.

  The fundamental relationship between
  the P vs NP question and the structure of the polynomial hierarchy.
-/
theorem ph_collapse_if_p_eq_np :
  PEqualsNP → ∀ k, ∀ (α : Type) [inst : Primcodable α] (ea : FinEncoding α) (L : Language α),
    SigmakP k ea L ↔ InP ea L := by
  intro h k α inst ea L
  induction' k with k ih generalizing α inst ea L
  · rfl
  · rw [SigmakP]
    constructor
    · rintro ⟨β, iβ, eb, L', hL', p, hL⟩
      apply (h α ea L).mp
      refine ⟨β, iβ, eb, L', ?_, p, hL⟩
      cases k
      · exact hL'
      · exact sorry
    · intro hL
      rcases (h α ea L).mpr hL with ⟨β, iβ, eb, L', hL', p, hL⟩
      refine ⟨β, iβ, eb, L', ?_, p, hL⟩
      cases k
      · exact hL'
      · exact sorry
```
