/-- **Spec and proof concerning `montgomery.MontgomeryPoint.to_edwards`**:
- Returns None if u ≡ -1 (mod p)
- Returns None if the y-coordinate cannot be decompressed to a valid Edwards point
- Otherwise, returns Some(EdwardsPoint) where:
  - The y-coordinate satisfies: y * (u + 1) ≡ (u-1) (mod p)
  - The sign of x matches the input sign parameter
where p = 2^255 - 19
-/
@[progress]
theorem to_edwards_spec (mp : MontgomeryPoint) (sign : U8) :
    ∃ opt_e,
    to_edwards mp sign = ok opt_e ∧
    let u := U8x32_as_Nat mp

    ((u + 1) % p = 0 → opt_e = none) ∧

    ((u + 1) % p ≠ 0 →
      (opt_e = none ∨ -- can still return none if y cannot be decompressed into a valid Edwards point
       ∃ e x_sign,
       opt_e = some e ∧
       field.FieldElement51.is_negative e.X = ok x_sign ∧
       let y := Field51_as_Nat e.Y

       y * (u + 1) % p = (u - 1) % p ∧
       (x_sign.val = 1#u8 ↔ sign.val.testBit 0))) := by
  rw [to_edwards]
  progress as ⟨u_fe, h_u_fe⟩
  progress as ⟨one_fe, h_one_fe⟩
  progress as ⟨u_plus_1, h_up1⟩
  progress as ⟨is_zero, h_iz⟩
  let u := U8x32_as_Nat mp
  rw [field.FieldElement51.is_zero_spec] at h_iz
  rw [Field51_as_Nat_add, h_u_fe, Field51_as_Nat_one] at h_iz
  if h_z : is_zero.val = 1#u8 then
    simp [h_z]
    exists none
    simp [h_iz.mp h_z]
  else
    simp [h_z]
    have h_den : (u + 1) % p ≠ 0 := mt h_iz.mpr h_z
    progress as ⟨u_minus_1, h_um1⟩
    progress as ⟨inv_u_plus_1, h_inv⟩
    progress as ⟨y_fe, h_yfe⟩
    progress as ⟨y_bytes, h_yb⟩
    progress as ⟨opt_e, h_oe⟩
    exists opt_e
    simp [h_oe, h_den]
    intro e he; subst opt_e; right
    rw [edwards.EdwardsPoint.decompress_spec] at h_oe
    rcas h_oe with ⟨x_sign, h_xs, h_ey, h_sign⟩
    exists e, x_sign; simp [h_xs, h_sign]
    rw [h_ey, Field51_as_Nat_mul, h_yfe, h_um1, h_u_fe, Field51_as_Nat_one]
    apply Nat.eq_of_mod_eq_mod
    rw [Nat.mul_mod, ← Nat.mul_assoc, Nat.mul_mod _ (Field51_as_Nat inv_u_plus_1)]
    have h_inv_p : (Field51_as_Nat inv_u_plus_1 * (u + 1)) % p = 1 := by
      rw [← Field51_as_Nat_add, h_u_fe, Field51_as_Nat_one] at h_inv; exact h_inv h_den
    rw [h_inv_p, Nat.mul_one, Nat.mod_mod, Nat.mod_mod]
