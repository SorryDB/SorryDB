    exists none
    simp [h_iz_val]
    constructor
    · intro; rfl
    · intro h_nz
      have : (u + 1) % p = 0 := by rw [← h_up1_val, h_iz.mp h_iz_val]
      contradiction
  · rename_i h_iz_val
    have h_nz : (u + 1) % p ≠ 0 := by
      intro h_z
      have : Field51_as_Nat u_plus_1 = 0 := by rw [h_up1_val, h_z, Nat.zero_mod]
      have : is_zero.val = 1#u8 := h_iz.mpr this
