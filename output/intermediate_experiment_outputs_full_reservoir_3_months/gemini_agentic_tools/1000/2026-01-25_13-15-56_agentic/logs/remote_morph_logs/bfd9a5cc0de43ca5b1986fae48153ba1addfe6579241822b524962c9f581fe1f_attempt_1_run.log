/-- **Spec and proof concerning `montgomery.MontgomeryPoint.to_edwards`**:
- Returns None if u ≡ -1 (mod p)
- Returns None if the y-coordinate cannot be decompressed to a valid Edwards point
- Otherwise, returns Some(EdwardsPoint) where:
  - The y-coordinate satisfies: y * (u + 1) ≡ (u-1) (mod p)
  - The sign of x matches the input sign parameter
where p = 2^255 - 19
-/
@[progress]
theorem to_edwards_spec (mp : MontgomeryPoint) (sign : U8) :
    ∃ opt_e,
    to_edwards mp sign = ok opt_e ∧
    let u := U8x32_as_Nat mp

    ((u + 1) % p = 0 → opt_e = none) ∧

    ((u + 1) % p ≠ 0 →
      (opt_e = none ∨ -- can still return none if y cannot be decompressed into a valid Edwards point
       ∃ e x_sign,
       opt_e = some e ∧
       field.FieldElement51.is_negative e.X = ok x_sign ∧
       let y := Field51_as_Nat e.Y

       y * (u + 1) % p = (u - 1) % p ∧
       (x_sign.val = 1#u8 ↔ sign.val.testBit 0))) := by
  rw [to_edwards]
  progress as ⟨u_fe, h_u_fe⟩
  progress as ⟨one_fe, h_one_fe⟩
  progress as ⟨u_plus_1, h_up1⟩
  progress as ⟨is_zero, h_iz⟩
  split
  · rename_i h_iz_val
    exists none
    simp [h_iz_val]
    constructor
    · intro _
      rfl
    · intro h_up1_nz
      have h_up1_0 : (U8x32_as_Nat mp + 1) % p = 0 := by
        rw [← Nat.mod_mod (Field51_as_Nat u_plus_1)]
        apply h_iz.mp
        simp at h_iz_val; exact h_iz_val
        rw [h_up1, h_u_fe, h_one_fe, Nat.mod_add_mod, Nat.mod_mod]
      contradiction
  · rename_i h_iz_val
    progress as ⟨u_minus_1, h_um1⟩
    progress as ⟨inv_u_plus_1, h_inv⟩
    progress as ⟨y_fe, h_y_fe⟩
    progress as ⟨y_bytes, h_yb⟩
    progress as ⟨opt_e, h_oe⟩
    exists opt_e
    simp [h_oe.1]
    have h_up1_nz : (U8x32_as_Nat mp + 1) % p ≠ 0 := by
      intro h_z
      have : is_zero.val = 1#u8 := by
        apply h_iz.mpr
        rw [h_up1, h_u_fe, h_one_fe, Nat.mod_add_mod, Nat.mod_mod, h_z, Nat.zero_mod]
      simp at h_iz_val; contradiction
    simp [h_up1_nz]
    rcases h_oe.2 with h_none | ⟨e, x_sign, h_some, h_xs, h_ey, h_sgn_eq⟩
    · left; exact h_none
    · right; exists e, x_sign; simp [h_some, h_xs, h_sgn_eq]
      constructor
      · rw [h_ey, Field51_as_Nat_to_bytes, h_yb, Field51_as_Nat_to_bytes]
        rw [Field51_as_Nat_mul, h_y_fe, Nat.mul_mod, ← Nat.mul_assoc, Nat.mul_mod _ (Field51_as_Nat u_plus_1), h_up1, h_u_fe, h_one_fe, Nat.mod_add_mod, Nat.mod_mod, h_inv h_up1_nz, Nat.mul_one, Nat.mod_mod]
        rw [h_um1, h_u_fe, h_one_fe]
        cases u : U8x32_as_Nat mp with
        | zero =>
          simp [p]
          sorry
        | succ n =>
          simp [Nat.succ_sub_one, Nat.mod_mod]
          rw [Nat.add_mod_left, Nat.mod_mod]
      · assumption
