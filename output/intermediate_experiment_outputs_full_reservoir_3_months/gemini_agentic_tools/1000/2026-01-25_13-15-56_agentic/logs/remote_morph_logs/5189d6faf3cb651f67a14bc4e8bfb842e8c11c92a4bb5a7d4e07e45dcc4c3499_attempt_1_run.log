    -- Aux.c_v_alg is the same as Aux.c_v which is a homeomorphism
    -- so one only has to check that the span of the integral lattice is compact
    -- and I guess one could pick a basis and give it a try
lemma isCompact (v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ)) : IsCompact
  ((((Aux.c_v_alg V v)).toAddMonoidHom.comp
        (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
            (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                    v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range :
                    Set (V ⊗[ℚ] IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v)) := by
  letI : CompactSpace (v.adicCompletionIntegers ℚ) :=
    NumberField.instCompactSpaceAdicCompletionIntegers ℚ v
  let f := (Aux.c_v_alg V v).toLinearMap.comp
    (LinearMap.lTensor (IntegralLattice ℤ ℚ V) (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap)
  let b := IntegralLattice.basis ℤ ℚ V
  let x i := f (b i ⊗ₜ 1)
  let g (r : FiniteDimensional.Index ℚ V → v.adicCompletionIntegers ℚ) := ∑ i, r i • x i
  have h : (f.range : Set (V ⊗[ℚ] v.adicCompletion ℚ)) = Set.range g := by
    ext z; constructor
    · rintro ⟨y, rfl⟩
      let bT := b.baseChange (v.adicCompletionIntegers ℚ)
      use bT.repr y
      simp only [f, g, bT, Basis.sum_repr, LinearMap.map_sum, LinearMap.map_smul,
        LinearMap.coe_comp, Function.comp_apply, LinearMap.lTensor_tmul,
        LinearMap.toIntLinearMap_coe, Subring.toIntLinearMap_apply, Subring.coe_subtype,
        Basis.baseChange_apply, smul_tmul', smul_eq_mul, mul_one]
      congr; ext i
      exact (Aux.c_v_alg V v).map_smul (r i : v.adicCompletion ℚ) (b i ⊗ₜ 1)
    · rintro ⟨r, rfl⟩
      use ∑ i, (b i ⊗ₜ r i)
      simp only [f, x, g, LinearMap.map_sum, LinearMap.map_smul, LinearMap.coe_comp,
        Function.comp_apply, LinearMap.lTensor_tmul, LinearMap.toIntLinearMap_coe,
        Subring.toIntLinearMap_apply, Subring.coe_subtype, smul_tmul', smul_eq_mul, mul_one]
  rw [h]
  apply isCompact_range
  apply continuous_finset_sum
  intro i _
  apply Continuous.smul
  · exact continuous_apply i
  · exact continuous_const
