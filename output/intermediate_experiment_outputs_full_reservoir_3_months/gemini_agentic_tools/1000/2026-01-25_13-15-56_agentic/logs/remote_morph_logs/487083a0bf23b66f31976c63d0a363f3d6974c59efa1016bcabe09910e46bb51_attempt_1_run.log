  affine : Std.TreeMap String (ZMod p)

-- TODO could add a Prop item saying taht coefficients are never zero.

def AffineExpression.toConstant? {p : ℕ} (e : AffineExpression p) : Option (ZMod p) :=
  if e.affine.isEmpty then
    some e.offset
  else
    none

instance {p} : Add (AffineExpression p) where
  add x y := {
    offset := x.offset + y.offset,
    affine := (x.affine.mergeWith (fun _ v1 v2 => (v1 + v2)) y.affine).filter (fun _ v => v ≠ 0),
  }

def mul_by_number {p : ℕ} (e : AffineExpression p) (n : ZMod p) : AffineExpression p :=
  {
    offset := n * e.offset,
    affine := (e.affine.map (fun _ v => n * v)).filter (fun _ v => v ≠ 0),
  }

def mul? {p : ℕ} (x y : AffineExpression p) : Option (AffineExpression p) :=
  match (x.toConstant?, y.toConstant?) with
    | (some n1, _) => some (mul_by_number y n1)
    | (_, some n2) => some (mul_by_number x n2)
    | (none, none) => none

def AffineExpression.ofExpression? {p : ℕ} : Expression p → Option (AffineExpression p)
  | .const n => some { offset := n, affine := Std.TreeMap.empty }
  | .var x => some { offset := 0, affine := Std.TreeMap.empty.insert x 1 }
  | .add e1 e2 => match (ofExpression? e1, ofExpression? e2) with
      | (some v1, some v2) => some (v1 + v2)
      | _ => none
  | .mul e1 e2 => match (ofExpression? e1, ofExpression? e2) with
      | (some v1, some v2) => mul? v1 v2
      | _ => none

def AffineExpression.eval {p : ℕ} (e : AffineExpression p) (env : String → ZMod p) : ZMod p :=
  e.offset +
  e.affine.foldl (fun acc k v => acc + v * env k) 0

--- If an expression can be converted to an affine expression, then their evaluations are the same.
theorem ofExpression_correct (p : ℕ) (e : Expression p) (ae : AffineExpression p) :
  some ae = AffineExpression.ofExpression? e
  → ae.eval = e.eval := by
  funext env
  intro h
  induction e generalizing ae
  case const n =>
    simp [AffineExpression.ofExpression?, AffineExpression.eval, Std.TreeMap.foldl, Std.TreeMap.empty] at h
    injection h with h_ae; subst h_ae; simp [AffineExpression.eval, Std.TreeMap.foldl]
  case var x =>
    simp [AffineExpression.ofExpression?, AffineExpression.eval, Std.TreeMap.foldl, Std.TreeMap.empty, Std.TreeMap.insert, Std.TreeMap.foldl.loop] at h
    injection h with h_ae; subst h_ae; simp [AffineExpression.eval, Std.TreeMap.foldl, Std.TreeMap.foldl.loop]; ring
  case add e1 e2 ih1 ih2 =>
    simp [AffineExpression.ofExpression?] at h
    split at h <;> rename_i v1 h1; split at h <;> rename_i v2 h2 <;> try contradiction
    injection h with h_ae; subst h_ae; specialize ih1 v1 (Eq.refl _); specialize ih2 v2 (Eq.refl _)
    simp [AffineExpression.eval, Add.add, ih1, ih2]; ring
  case mul e1 e2 ih1 ih2 =>
    simp [AffineExpression.ofExpression?] at h
    split at h <;> rename_i v1 h1; split at h <;> rename_i v2 h2 <;> try contradiction
    specialize ih1 v1 (Eq.refl _); specialize ih2 v2 (Eq.refl _)
    simp [mul?] at h; split at h <;> rename_i n1 h_c1
    · injection h with h_ae; subst h_ae
      simp [AffineExpression.toConstant?] at h_c1; split at h_c1 <;> rename_i h_empty <;> try contradiction
      injection h_c1 with h_n1; subst h_n1
      have : v1.eval env = v1.offset := by
        simp [AffineExpression.eval, h_empty, Std.TreeMap.isEmpty, Std.TreeMap.foldl]
      simp [AffineExpression.eval, mul_by_number, ih1, ih2, this]; ring
    · split at h <;> rename_i n2 h_c2
      · injection h with h_ae; subst h_ae
        simp [AffineExpression.toConstant?] at h_c2; split at h_c2 <;> rename_i h_empty <;> try contradiction
        injection h_c2 with h_n2; subst h_n2
        have : v2.eval env = v2.offset := by
          simp [AffineExpression.eval, h_empty, Std.TreeMap.isEmpty, Std.TreeMap.foldl]
        simp [AffineExpression.eval, mul_by_number, ih1, ih2, this]; ring
      · contradiction
