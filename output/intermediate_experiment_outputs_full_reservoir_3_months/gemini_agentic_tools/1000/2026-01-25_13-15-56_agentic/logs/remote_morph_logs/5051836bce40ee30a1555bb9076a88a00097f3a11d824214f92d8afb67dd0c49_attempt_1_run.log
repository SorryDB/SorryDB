lemma offDiagonalHasLaw' (n : ℕ) {i j : Fin n} (h : i < j) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
  constructor
  · simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction, h, ne_of_lt h]
    rw [WignerMeasure]
    exact (measurable_pi_apply (⟨(i, j), le_of_lt h⟩ : Index n)).aemeasurable
  · simp [wignerMatrixMap, wignerMatrixMap', wignerMatrixEntryFunction, h, ne_of_lt h]
    rw [WignerMeasure]
    haveI : ∀ (p : Index n), IsProbabilityMeasure (wignerMeasureDist μ ν n p) := fun p ↦ by
      unfold wignerMeasureDist; split_ifs <;> assumption
    rw [MeasureTheory.measurePreserving_eval (⟨(i, j), le_of_lt h⟩ : Index n) |>.map_eq]
    simp [wignerMeasureDist, ne_of_lt h]
