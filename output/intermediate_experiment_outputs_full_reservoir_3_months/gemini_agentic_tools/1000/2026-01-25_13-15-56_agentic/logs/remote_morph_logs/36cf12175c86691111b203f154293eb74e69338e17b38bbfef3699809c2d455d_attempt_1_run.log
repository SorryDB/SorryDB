lemma indepFun_rewardByCount_of_ne [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) {a b : α} (hab : a ≠ b) :
    IndepFun (fun ω s ↦ rewardByCount A R a s ω) (fun ω s ↦ rewardByCount A R b s ω) 𝔓' := by
  let X (c : α) := fun ω n ↦ rewardByCount A R c (n + 1) ω
  have h_indep : IndepFun (X a) (X b) 𝔓' :=
    (iIndepFun_rewardByCount h).indepFun_precomp (fun n : ℕ ↦ (a, n)) (fun n : ℕ ↦ (b, n)) (by simp [hab])
  let F (y : ℕ → ℝ) (s : ℕ) := if s = 0 then 0 else y (s - 1)
  have h_rew (c : α) : (fun ω s ↦ rewardByCount A R c s ω) = fun ω ↦ F (X c ω) := by
    ext ω s; simp [F]; split <;> [rfl; (congr; omega)]
  rw [h_rew a, h_rew b]
  exact h_indep.comp (measurable_pi_iff.mpr fun s ↦ by fun_prop) (measurable_pi_iff.mpr fun s ↦ by fun_prop)
```
