example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  induction sl using dropWhileSL.induct with
  | case1 sl h =>
    unfold dropWhileSL
    rw [if_pos h]
    have ⟨as, bs, _⟩ := sl
    simp at h
    simp [fromSL, nil, h.1, h.2, dropWhile]
  | case2 sl h1 h2 =>
    unfold dropWhileSL
    rw [if_neg h1, h2]
    simp [fromSL, nil, dropWhile]
    have h_nil := headSL_none_iff_nilSL.mp h2
    rw [h_nil]; simp [fromSL, dropWhile]
  | case3 sl hsl h1 h2 h3 ih =>
    unfold dropWhileSL
    rw [if_neg h1, h2, if_pos h3]
    simp [Function.comp] at *
    have heq : (fromSL sl).head? = headSL sl := by
      cases sl with | mk as bs ok =>
      cases as with
      | nil =>
        simp [fromSL, headSL]
        simp at ok
        cases ok.1 (by simp) with
        | inl h => simp [h]
        | inr h =>
          cases bs with | nil => simp | cons b bs =>
            simp at h; subst bs; simp
      | cons a as => simp [fromSL, headSL]
    match h_fs : fromSL sl with
    | [] =>
      rw [h_fs] at heq; simp at heq; rw [heq] at h2; contradiction
    | x :: xs =>
      rw [h_fs] at heq; simp at heq; rw [heq] at h2; injection h2 with hx; subst x
      simp [dropWhile, h3, h_fs, ← ih]
      have h_tail : fromSL (tailSL sl) = (fromSL sl).tail := by
        cases sl with | mk as_ ys ok =>
        cases as_ with
        | nil =>
          cases ys with
          | nil => simp [tailSL, fromSL, nil]
          | cons b bs =>
            simp [fromSL, tailSL, nil]
            simp at ok
            cases ok.1 (by simp) with
            | inl h_bs => simp [h_bs]
            | inr h_bs => cases bs with | nil => simp | cons _ _ => simp at h_bs
