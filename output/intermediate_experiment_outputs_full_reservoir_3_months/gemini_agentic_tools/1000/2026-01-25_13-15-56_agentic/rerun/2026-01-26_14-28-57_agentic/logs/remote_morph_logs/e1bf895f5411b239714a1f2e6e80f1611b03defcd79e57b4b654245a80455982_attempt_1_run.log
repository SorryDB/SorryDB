def dest (self : StateCofixShrunk F α) : F (α ::: (StateCofixShrunk F α)) :=
  let f self := (TypeVec.id ::: corec self.dest') <$$> self.dest
  have h := by
    show ∀ a b, a ~ b → f a = f b
    rintro a b h_bisim
    have h_eq : Quot.mk (Coalg.Bisim) a = Quot.mk (Coalg.Bisim) b := Quot.sound h_bisim
    let G : StateCofixFinal F α → F (α ::: StateCofixShrunk F α) := fun x =>
        (TypeVec.id ::: ofLarge ∘ StateCofixFinal.ofCofix) <$$> Cofix.dest (StateCofixFinal.toCofix x)
    have hG (c : Coalg F α) : G (Quot.mk _ c) = (TypeVec.id ::: corec c.dest') <$$> c.dest' c.s := by
      simp only [G, StateCofixFinal.toCofix, Quot.lift_mk, Coalg.toCofix, Cofix.dest_corec, MvFunctor.map_map, TypeVec.appendFun_comp, TypeVec.id_comp]
      congr 1; funext s; rw [← StateCofixFinal.ofCofix_toCofix (Quot.mk _ (Coalg.corec c.dest' s))]
      simp [StateCofixFinal.toCofix, Coalg.toCofix, corec, StateCofixFinal.corec]
    simp only [f, Coalg.dest]
    rw [← hG a, ← hG b, h_eq]
  Quot.lift f h self.toLarge
