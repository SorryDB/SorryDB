    calc (#A : ℝ) ≤ #(A ^ 2) := mod_cast card_le_card_pow two_ne_zero
      _ ≤ K * #A := hA
  let S : Finset G := {g ∈ A⁻¹ * A | #A / (2 * K) ≤ #(A <• g ∩ A)}
  have hS₁ : 1 ∈ S := by simp [S, hA₀.ne_empty]; bound
  have hS₀ : S.Nonempty := ⟨1, hS₁⟩
  have hSA : S ⊆ A⁻¹ * A := filter_subset ..
  have hSsymm : S⁻¹ = S := by ext; simp [S]; sorry
  have hScard := calc
    (#S : ℝ) ≤ #(A⁻¹ * A) := by gcongr
    _ ≤ K ^ 2 * #A := by
      refine le_of_mul_le_mul_left (a := (#A : ℝ)) ?_ (by positivity)
      calc
        (#A : ℝ) * #(A⁻¹ * A) ≤ (#(A * A) : ℝ) * #(A * A) := by
          exact_mod_cast ruzsa_triangle_inequality_invMul_mul_mul A A A
        _ ≤ (K * #A) * (K * #A) := by
          rw [pow_two] at hA
          exact mul_le_mul hA hA (by positivity) (by positivity)
        _ = #A * (K ^ 2 * #A) := by ring
