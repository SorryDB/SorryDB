    · rw [inv_smul_eq_iff₀ (sub_ne_zero.2 h), ← hz j hj, lineMap_apply_module, hWj]
      rw [sub_smul, one_smul, ← add_sub_assoc, add_comm, add_sub_assoc]
      exact (sub_eq_zero.1 <| smul_left_injective 𝕜 (hs.exists_ne j).choose_spec.choose_spec.symm (by sorry))
  mpr := by
    rintro ⟨w, hw₀, hw₁, hwxy⟩
    refine ⟨s.centerMass w x, w, fun i hi ↦ ⟨hw₀ _ hi, ?_, ?_⟩⟩
    · rw [← hw₁]; exact single_le_sum (fun j hj ↦ hw₀ _ hj) hi
    · by_cases h : w i = 1
      · rw [h, lineMap_apply_one, ← hwxy, centerMass, sum_erase_eq_sub hi, h, hw₁, sub_self, inv_zero, zero_smul]
      · rw [← hwxy, lineMap_centerMass_sdiff_singleton_of_ne_one hi h hw₁]
