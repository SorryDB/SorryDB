/-- **Structure theorem of finitely generated torsion modules up to pseudo-isomorphism**:
A finitely generated torsion module over a Noetherian ring `A` satisfying
`HeightOneLocalizationIsPID` is pseudo-isomorphic to a finite product of some `A ⧸ pᵢ ^ eᵢ`
where the `pᵢ ^ eᵢ` are powers of height one primes of `A`. -/
theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  set σ := (Module.support A M) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}
  have hσ : σ.Finite := hMT.finite_primeHeight_one_support
  rcases σ.eq_empty_or_nonempty with h | h
  · refine ⟨PEmpty, inferInstance, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim, ?_⟩
    have : Module.IsPseudoNull A M := by
      rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
      intro p hp
      rcases hp.le_or_lt with h0 | h1
      · rw [Ideal.primeHeight_eq_zero_iff] at h0
        rw [LocalizedModule.subsingleton_iff]; intro m
        obtain ⟨a, han, ha⟩ := hMT m; use a, ?_, ha
        exact Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes h0 han
      · have : p.asIdeal.primeHeight = 1 := by
          rw [ENat.lt_one_iff_eq_zero] at h1
          exact (hp.le_or_lt.resolve_right (not_lt_of_le (ENat.le_of_lt_add_one (by simpa using hp)))).elim
        exact (h ⟨p, Module.mem_support_iff_of_finite.mpr (fun hz ↦ by
          rw [hz] at this; exact (Ideal.bot_prime.primeHeight_le_zero.trans_lt (by simp [this])).ne rfl), this⟩).elim
    exact ⟨this.isPseudoIsomorphism_zero.symm⟩
  · let S := ⨅ p ∈ σ, p.1.primeCompl
    haveI : IsDomain (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) h hσ).1
    haveI : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization σ (by simp) h hσ).2
    obtain ⟨ι, _, pS, hirr, e, ⟨hiso⟩⟩ := Module.equiv_directSum_of_isTorsion (Localization S) (LocalizedModule S M)
    let p := fun i ↦ PrimeSpectrum.comap (algebraMap A (Localization S)) ⟨Ideal.span {pS i}, (hirr i).prime⟩
    have hp : ∀ i, (p i).1.primeHeight = 1 := fun i ↦
      (PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one (Localization S) σ (by simp) h hσ ▸ Set.mem_union_left _ (Set.mem_range_self _)).2
    use ι, inferInstance, p, hp, e, (fun i ↦ (hirr i).ne_zero.bot_lt.ne.symm.bot_lt)
    let N := (i : ι) → A ⧸ (p i).1 ^ (e i)
    have : Nonempty (LocalizedModule S M ≃ₗ[Localization S] LocalizedModule S N) := by
      refine ⟨hiso.trans ?_⟩
      refine (DirectSum.linearEquivFunOnFintype _ _ _).symm.trans ?_
      refine LinearEquiv.piCongrLeft' _ (fun i ↦ ?_)
      let q := (p i).asIdeal
      have : LocalizedModule S (A ⧸ q ^ e i) ≃ₗ[Localization S] Localization S ⧸ Ideal.span {pS i} ^ e i := sorry
      exact this.symm
    obtain ⟨g⟩ := this
    obtain ⟨f, s, hf⟩ := IsLocalization.LinearMap.exists_map_isLocalization S M N g
    have : Bijective (LocalizedModule.map S f) := by
      rw [hf]; exact (g.symm.units_smul s).bijective
    exact ⟨(LinearMap.isPseudoIsomorphism_iff_bijective_map hMT (by intro x; obtain ⟨i, hi⟩ := x; exact (hp i).symm ▸ hMT.isTorsion_quotient_pow _ _) f).mpr this⟩

