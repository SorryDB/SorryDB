/-- There exists a set of infinite VCₙ dimension in ℝⁿ⁺². -/
lemma exists_convex_rn_add_two_vc_n_eq_infty (n : ℕ) :
    ∃ (C : Set (Fin (n + 2) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 2) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 2) → ℝ),
        ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s := by
  cases n with
  | zero =>
    let C : Set (Fin 2 → ℝ) := {v | 0 ≤ v 0}
    have hC : Convex ℝ C := convex_halfSpace_le (LinearMap.proj 0 : (Fin 2 → ℝ) →ₗ[ℝ] ℝ) 0 |>.neg
    let x : Fin 0 → ℕ → Fin 2 → ℝ := fun i ↦ i.elim0
    let i0 : Fin 0 → ℕ := fun a ↦ a.elim0
    let y (s : Set (Fin 0 → ℕ)) : Fin 2 → ℝ := if i0 ∈ s then 0 else fun j ↦ if j = 0 then -1 else 0
    refine ⟨C, hC, x, y, fun i s ↦ ?_⟩
    have : i = i0 := Subsingleton.elim _ _
    simp [C, y, this]
    by_cases h : i0 ∈ s <;> simp [h]
  | succ n =>
    obtain ⟨C, hC, x, y, hxy⟩ := exists_convex_r3_vc_eq_infty
    obtain ⟨f⟩ : Nonempty ((Fin (n + 1) → ℕ) ≃ ℕ) := ⟨Classical.choice (nonempty_equiv_nat _)⟩
    let C' : Set (Fin (n + 3) → ℝ) := {v | (fun i : Fin 3 ↦ v ⟨i, by omega⟩) ∈ C}
    have hC' : Convex ℝ C' := hC.linear_preimage {
      toFun := fun v i ↦ v ⟨i, by omega⟩
      map_add' := fun v w ↦ by ext i; rfl
      map_smul' := fun r v ↦ by ext i; rfl }
    let x' (k : Fin (n + 1)) (m : ℕ) : Fin (n + 3) → ℝ := fun j ↦
      if k = 0 ∧ j < 3 then x (f (fun i ↦ if i = 0 then m else 0)) ⟨j, by omega⟩ else 0
    let y' (s : Set (Fin (n + 1) → ℕ)) : Fin (n + 3) → ℝ := fun j ↦
      if j < 3 then y (f '' {i | i ∈ s ∧ ∀ k > 0, i k = 0}) ⟨j, by omega⟩ else 0
    refine ⟨C', hC', x', y', fun i s ↦ ?_⟩
    have hx' : (∑ k, x' k (i k)) = fun j ↦ if hj : j < 3 then x (f (fun k ↦ if k = 0 then i 0 else 0)) ⟨j, hj⟩ else 0 := by
      ext j; simp [x']; split_ifs with hj
      · rw [Finset.sum_eq_single 0]; · simp [hj]
        · intro k _ hk; simp [hk]
        · intro h; simp at h
      · rw [Finset.sum_eq_zero]; intro k _; simp [hj]
    simp [C', hx', y', hxy]
    let i_zero : Fin (n + 1) → ℕ := fun k ↦ if k = 0 then i 0 else 0
    have hi0 : ∀ k > 0, i_zero k = 0 := fun k hk ↦ by simp [i_zero, (ne_of_gt hk).symm]
    constructor
    · intro h
      by_cases hi : ∀ k > 0, i k = 0
      · have : i = i_zero := by ext k; by_cases hk : k = 0 <;> simp [i_zero, hi, *]
        rw [this] at h; exact ⟨i_zero, ⟨h, hi0⟩, rfl⟩
