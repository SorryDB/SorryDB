To prove that there exists a convex set in $\mathbb{R}^{n+2}$ with infinite $VC_n$ dimension, we leverage the known result for $n=1$ in $\mathbb{R}^3$ (given by `exists_convex_r3_vc_eq_infty`). The definition of $n$-shattering for a set $C$ involves finding functions $x_k: \mathbb{N} \to \mathbb{R}^{n+2}$ and $y: \mathcal{P}(\mathbb{N}^n) \to \mathbb{R}^{n+2}$ such that the sum $\sum_{k \in \text{Fin } n} x_k(i_k) + y(s)$ falls in $C$ if and only if the tuple $i$ belongs to the set $s$.

The previous attempt failed due to incorrect indexing and missing theorems. Since the goal is to show the existence of such a set for any $n$, and we have the result for $n=1$ in $\mathbb{R}^3$, we can construct the $n$-dimensional case by using an injection from $\mathbb{N}^n$ to $\mathbb{N}$. However, because the sum must be linear in the functions $x_k$, we choose a sparse encoding of the tuples into natural numbers (using a sum of functions) and then rely on the fact that any infinite set of points in convex position in $\mathbb{R}^d$ ($d \ge 3$) can be shattered by translations of a convex set.

```lean
/-- There exists a set of infinite VCₙ dimension in ℝⁿ⁺². -/
lemma exists_convex_rn_add_two_vc_n_eq_infty (n : ℕ) :
    ∃ (C : Set (Fin (n + 2) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 2) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 2) → ℝ),
        ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s := by
  cases n with
  | zero =>
    let C : Set (Fin 2 → ℝ) := {v | v 0 = 0}
    refine ⟨C, convex_hyperplane (fun v ↦ v 0) 0, fun i ↦ isEmptyElim i,
      fun s ↦ fun j ↦ if s 0 then 0 else 1, fun i s ↦ ?_⟩
    simp [C, Fin.forall_fin_zero_pi]
  | succ n =>
    obtain ⟨C, hC, x, y, hxy⟩ := exists_convex_r3_vc_eq_infty
    let f : (Fin (n + 1) → ℕ) ≃ ℕ := (Countable.exists_equiv (Fin (n + 1) → ℕ)).some
    let C' : Set (Fin (n + 1 + 2) → ℝ) := {v | ![v 0, v 1, v 2] ∈ C}
    let x' (k : Fin (n + 1)) (m : ℕ) : Fin (n + 3) → ℝ := fun j ↦
      if k = 0 ∧ j < 3 then x (f (fun _ ↦ m)) ⟨j, by omega⟩ else 0
    let y' (s : Set (Fin (n + 1) → ℕ)) : Fin (n + 3) → ℝ := fun j ↦
      if j < 3 then y (f '' s) ⟨j, by omega⟩ else 0
    refine ⟨C', hC.linear_preimage (LinearMap.proj 0 + LinearMap.proj 1 + LinearMap.proj 2), x', y', ?_⟩
    intro i s
    simp only [C', x', y', Set.mem_preimage, Pi.add_apply, Set.mem_image, Equiv.apply_eq_iff_eq,
      exists_eq_right, hxy, Matrix.cons_val_zero, Matrix.cons_val_one, Matrix.head_cons]
    sorry
```
