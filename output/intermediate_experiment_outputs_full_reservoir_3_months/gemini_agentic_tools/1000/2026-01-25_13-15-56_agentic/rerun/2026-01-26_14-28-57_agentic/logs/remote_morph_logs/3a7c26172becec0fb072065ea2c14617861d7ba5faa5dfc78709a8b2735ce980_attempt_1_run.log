lemma foo_of_forall_inessential (h : ∀ x, G.inessential x) :
    ∃ M, G.IsMatching M ∧ ∀ H : Graph α β, H.IsCompOf G → ∃! x, x ∈ V(H) ∧ x ∉ V(G, M) := by
  obtain hV | ⟨x₀, hx₀⟩ := G.vertexSet.eq_empty_or_nonempty
  · use ∅, (by simp [isMatching_iff, hV])
    intro H hH; exact (hH.nonempty.ne_empty (by simp [hV])).elim
  obtain ⟨M, hM, -⟩ := h x₀
  refine ⟨M, hM.toIsMatching, fun H hH ↦ ?_⟩
  let m := G.matchingMatroid
  have hB : m.Basis V(G, M) := by
    rw [Matroid.basis_iff_indep_maximal]
    refine ⟨⟨M, hM.toIsMatching, rfl.subset⟩, fun S ⟨M', hM', hS⟩ hMS ↦ ?_⟩
    have : M.encard < M'.encard := by
      rw [← encard_V_matching, ← encard_V_matching]
      exact (encard_lt_encard hMS).trans_le (encard_le_encard hS)
    exact (hM.max M' hM' |>.not_lt this).elim
  have h_diff : (V(H) \ V(G, M)).encard = 1 := by
    have hC : m.IsComponent V(H) := m.isComponent_of_isCompOf_graph hH
    rw [← hB.eRk_inter_eq_eRk_of_isComponent hC, encard_diff_left (hH.subset_ground.mono inter_subset_right)]
    · have h_rk : m.eRk V(H) = V(H).encard - 1 := by
        obtain h_sub | h_nt := V(H).subsingleton_or_nontrivial
        · obtain ⟨x, rfl⟩ := hH.nonempty.exists_eq_singleton_of_subsingleton h_sub
          have : ¬ m.Indep {x} := fun hi ↦ by
            obtain ⟨M', hM', hxM'⟩ := h x
            have hB' : m.Basis V(G, M') := by
              rw [Matroid.basis_iff_indep_maximal]
              refine ⟨⟨M', hM'.toIsMatching, rfl.subset⟩, fun S ⟨M'', hM'', hS'⟩ hMS' ↦ ?_⟩
              have : M'.encard < M''.encard := by
                rw [← encard_V_matching, ← encard_V_matching]
                exact (encard_lt_encard hMS').trans_le (encard_le_encard hS')
              exact (hM'.max M'' hM'' |>.not_lt this).elim
            exact hxM' (hB'.mem_of_isComponent_of_indep hC hi (by simp))
          simp [m.eRk_eq_zero_of_not_indep this]
        · have h_series : ∀ a ∈ V(H), ∀ b ∈ V(H), a ≠ b → m.Series a b := by
            intro a ha b hb hne
            obtain ⟨P, hP⟩ := hH.connected a ha b hb
            exact hP.series_of_adj (fun u v h_adj ↦ matchingMatroid.seriesPair_of_adj h h_adj)
          have := m.fooA hH.subset_ground h_nt h_series
          rw [m.eRk_add_eRk_compl_eq hC] at this
          exact add_right_cancel this
      rw [h_rk]
      exact ENat.sub_self_cancel (V(H).encard_lt_top) (by simp [hH.nonempty.encard_pos])
    exact hH.subset_ground.mono inter_subset_left
  rwa [encard_eq_one_iff_existsUnique] at h_diff
