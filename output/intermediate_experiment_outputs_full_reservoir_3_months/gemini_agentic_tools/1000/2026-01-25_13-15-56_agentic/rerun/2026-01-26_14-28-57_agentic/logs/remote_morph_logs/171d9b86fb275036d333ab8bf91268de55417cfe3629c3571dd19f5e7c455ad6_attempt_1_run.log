    let f_i_clm i : S →L[ℝ] S →L[ℝ] ℝ := (phi_star i).comp ((f_i i).comp (phi i))
    letI : AddCommGroup (S →L[ℝ] S →L[ℝ] ℝ) := inferInstance
    let f : S →L[ℝ] S →L[ℝ] ℝ := ∑ i, f_i_clm i
    let m : ∀ i, E i := fun i ↦ m_i i
    refine ⟨m, f, ?_, fun L ↦ ?_⟩
    · intro L
      simp only [f, sum_apply, comp_apply, flip_apply, compL_apply, toBilinForm_apply, f_i_clm]
