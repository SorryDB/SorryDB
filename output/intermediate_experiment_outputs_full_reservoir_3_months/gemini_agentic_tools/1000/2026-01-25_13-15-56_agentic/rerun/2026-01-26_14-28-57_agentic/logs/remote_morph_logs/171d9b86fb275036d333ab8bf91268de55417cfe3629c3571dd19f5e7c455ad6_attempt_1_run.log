open ContinuousLinearMap in
lemma iIndepFun.hasGaussianLaw {E : ι → Type*}
    [∀ i, NormedAddCommGroup (E i)] [∀ i, NormedSpace ℝ (E i)] [∀ i, MeasurableSpace (E i)]
    [∀ i, CompleteSpace (E i)] [∀ i, BorelSpace (E i)] [∀ i, SecondCountableTopology (E i)]
    {X : Π i, Ω → (E i)} (h : ∀ i, HasGaussianLaw (X i) P) (hX : iIndepFun X P) :
    HasGaussianLaw (fun ω ↦ (X · ω)) P where
  isGaussian_map := by
    have := hX.isProbabilityMeasure
    obtain hι | hι := isEmpty_or_nonempty ι
    · have : P.map (fun ω ↦ fun x ↦ X x ω) = .dirac hι.elim := by
        ext s -
        apply Subsingleton.set_cases (p := fun s ↦ Measure.map _ _ s = _)
        · simp
        simp only [measure_univ]
        exact @measure_univ _ _ _ (Measure.isProbabilityMeasure_map (by fun_prop))
      rw [this]
      infer_instance
    classical
    rw [isGaussian_iff_gaussian_charFunDual]
    choose m f h_semidef h_char using fun i ↦
      (isGaussian_iff_gaussian_charFunDual (μ := (P.map (X i)))).mp (h i).isGaussian_map
    let Φ i := ContinuousLinearMap.precompL ℝ ℝ (ContinuousLinearMap.single i (φ := E))
    let f' : StrongDual ℝ (∀ j, E j) →L[ℝ] StrongDual ℝ (∀ j, E j) →L[ℝ] ℝ :=
      ∑ i, (Φ i).dualMap.comp ((f i).comp (Φ i))
    refine ⟨m, f', ?_, fun L ↦ ?_⟩
    · intro L
      simp only [f', sum_apply, comp_apply, dualMap_apply, toBilinForm_apply]
      exact sum_nonneg (fun i _ ↦ (h_semidef i).apply (Φ i L))
    · rw [charFunDual, integral_map (by fun_prop) (by continuity),
        ← (hX.comp (fun i ↦ (continuous_exp.comp (continuous_mul_left I |>.comp (Φ i L).continuous)).measurable)).integral_prod]
      · simp_rw [← Complex.exp_sum, ← L.map_sum, Finset.sum_apply, single_apply,
          Pi.single_apply, Finset.sum_pi_single, Pi.eta]
      · intro i
        exact (continuous_exp.comp (continuous_mul_left I |>.comp (Φ i L).continuous)).aestronglyMeasurable.comp_aemeasurable (h i).aemeasurable
      · simp_rw [← charFunDual, h_char, Finset.prod_exp, ← exp_sum]
        simp only [Complex.ofReal_sub, Complex.ofReal_div, Complex.ofReal_mul, ofReal_sum,
          dualMap_apply, comp_apply, f']
        congr 1
        rw [Finset.sum_sub_distrib, ← L.map_sum, Finset.sum_div]
        simp [m, Φ, mul_comm I]
