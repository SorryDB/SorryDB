lemma IsMatching.exists_isAugPath_not_max (hM : G.IsMatching M) (hnotmax : ¬ G.IsMaxMatching M)
    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  obtain ⟨M', hM', hM'cd⟩ := by
    simpa only [isMaxMatching_iff, hM, true_and, not_forall, not_le] using hnotmax
  let H := hM.restrict₂ hM'
  have hmax := hM.symmDiff_maxDegree_le_two hM'
  by_contra! h_no_aug
  have h_card : ∀ (C : Graph α β), C.IsCompOf H → (E(C) ∩ M').encard ≤ (E(C) ∩ M).encard := by
    intro C hC
    obtain hP | hC_cyc := hC.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax
    · exact hP.encard_inter_le_of_not_isAugPath hM hM' (h_no_aug ·)
    · exact (hM.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM' hC_cyc hC).ge
  exact hM'cd.not_le (H.encard_le_of_inter_encard_le hM hM' h_card)
```
