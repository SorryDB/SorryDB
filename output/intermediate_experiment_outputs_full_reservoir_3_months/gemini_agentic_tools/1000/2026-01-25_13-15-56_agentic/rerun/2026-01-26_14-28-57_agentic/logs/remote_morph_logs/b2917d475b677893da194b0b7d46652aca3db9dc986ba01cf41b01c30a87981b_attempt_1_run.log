/-- There exists a set of infinite VC dimension in ℝ³. -/
lemma exists_convex_r3_vc_eq_infty :
    ∃ (C : Set (Fin 3 → ℝ)) (hC : Convex ℝ C) (x : ℕ → Fin 3 → ℝ) (y : Set ℕ → Fin 3 → ℝ),
      ∀ i s, x i + y s ∈ C ↔ i ∈ s := by
  let hf : ∃ f : Set ℕ → ℝ, Function.Injective f := sorry
  let f := Classical.choose hf
  let x (i : ℕ) : Fin 3 → ℝ := ![↑i, 0, ↑i ^ 2]
  let y (s : Set ℕ) : Fin 3 → ℝ := ![0, f s, (f s) ^ 2]
  let S := {p | ∃ (i : ℕ) (s : Set ℕ), i ∈ s ∧ p = x i + y s}
  refine ⟨convexHull ℝ S, convex_convexHull ℝ S, x, y, fun i s ↦ ⟨fun h ↦ ?_, fun h ↦ subset_convexHull ℝ S ⟨i, s, h, rfl⟩⟩⟩
  rw [mem_convexHull_iff_exists_fintype] at h
  obtain ⟨ι, _, w, z, hw0, hw1, hz, hsum⟩ := h
  have hzk : ∀ k, z k 2 = (z k 0) ^ 2 + (z k 1) ^ 2 := by
    intro k; obtain ⟨ik, sk, _, hk⟩ := hz k; simp [hk, x, y]
  have h0 : (↑i : ℝ) = ∑ k, w k * z k 0 := by
    have := congr_fun hsum 0; simpa [x, y, Finset.sum_apply]
  have h1 : f s = ∑ k, w k * z k 1 := by
    have := congr_fun hsum 1; simpa [x, y, Finset.sum_apply]
  have h2 : (↑i : ℝ) ^ 2 + (f s) ^ 2 = ∑ k, w k * z k 2 := by
    have := congr_fun hsum 2; simpa [x, y, Finset.sum_apply]
  have h_sum : ∑ k, w k * ((z k 0 - ↑i) ^ 2 + (z k 1 - f s) ^ 2) = 0 := by
    simp only [sub_sq, mul_add, Finset.sum_add_distrib, ← Finset.mul_sum, ← h0, ← h1, ← h2, hzk, hw1, mul_one]
    ring
  have h_eq : ∀ k, w k > 0 → z k 0 = ↑i ∧ z k 1 = f s := by
    intro k hk; have h := (Finset.sum_eq_zero_iff_of_nonneg ?_).1 h_sum k (Finset.mem_univ k)
    · replace h := (mul_eq_zero_iff.1 h).resolve_left hk.ne'
      exact (add_eq_zero_iff_of_nonneg (sq_nonneg _) (sq_nonneg _)).1 h
    · intro k _; exact mul_nonneg (hw0 k) (add_nonneg (sq_nonneg _) (sq_nonneg _))
  obtain ⟨k, hk⟩ : ∃ k, w k > 0 := by
    by_contra! h; have := hw1; simp [h] at this; exact zero_ne_one this
  obtain ⟨ik, sk, hik, hzk2⟩ := hz k; have := h_eq k hk; rw [hzk2] at this
  have hik_eq : (↑ik : ℝ) = ↑i := by simpa [x, y] using this.1
  have hsk_eq : f sk = f s := by simpa [x, y] using this.2
  rwa [Nat.cast_inj.1 hik_eq, Classical.choose_spec hf hsk_eq] at hik
