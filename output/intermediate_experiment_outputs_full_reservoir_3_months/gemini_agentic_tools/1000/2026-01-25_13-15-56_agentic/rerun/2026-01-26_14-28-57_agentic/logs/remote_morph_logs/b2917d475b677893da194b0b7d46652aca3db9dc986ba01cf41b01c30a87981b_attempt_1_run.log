/-- There exists a set of infinite VC dimension in ℝ³. -/
lemma exists_convex_r3_vc_eq_infty :
    ∃ (C : Set (Fin 3 → ℝ)) (hC : Convex ℝ C) (x : ℕ → Fin 3 → ℝ) (y : Set ℕ → Fin 3 → ℝ),
      ∀ i s, x i + y s ∈ C ↔ i ∈ s := by
  obtain ⟨f, hf⟩ : ∃ f : Set ℕ → ℝ, Function.Injective f := sorry
  let x (i : ℕ) : Fin 3 → ℝ := fun j ↦ if j = 0 then (i : ℝ) else if j = 2 then (i : ℝ) ^ 2 else 0
  let y (s : Set ℕ) : Fin 3 → ℝ := fun j ↦ if j = 1 then f s else if j = 2 then (f s) ^ 2 else 0
  let L (j : ℝ) (u : ℝ) (p : Fin 3 → ℝ) : ℝ := p 2 - 2 * j * p 0 - 2 * u * p 1 + j ^ 2 + u ^ 2
  let E := {p : Fin 3 → ℝ | p 2 ≥ p 0 ^ 2 + p 1 ^ 2}
  let H (j : ℕ) (t : Set ℕ) := {p : Fin 3 → ℝ | L (j : ℝ) (f t) p > 0}
  let C := E ∩ ⋂ (j : ℕ), ⋂ (t : Set ℕ), ⋂ (_ : j ∉ t), H j t
  have hE : Convex ℝ E := by
    intro p hp q hq a b ha hb hab; dsimp at hp hq ⊢
    have h0 : a * p 0 ^ 2 + b * q 0 ^ 2 ≥ (a * p 0 + b * q 0) ^ 2 := by
      have : a * p 0 ^ 2 + b * q 0 ^ 2 - (a * p 0 + b * q 0) ^ 2 = a * b * (p 0 - q 0) ^ 2 := by rw [← hab]; ring
      linarith [this, ha, hb, sq_nonneg (p 0 - q 0)]
    have h1 : a * p 1 ^ 2 + b * q 1 ^ 2 ≥ (a * p 1 + b * q 1) ^ 2 := by
      have : a * p 1 ^ 2 + b * q 1 ^ 2 - (a * p 1 + b * q 1) ^ 2 = a * b * (p 1 - q 1) ^ 2 := by rw [← hab]; ring
      linarith [this, ha, hb, sq_nonneg (p 1 - q 1)]
    linarith
  have hH j t : Convex ℝ (H j t) := by
    intro p hp q hq a b ha hb hab; dsimp at hp hq ⊢
    rcases ha.eq_or_lt with rfl | ha'
    · rw [zero_add] at hab; subst b; simp; exact hq
    · rcases hb.eq_or_lt with rfl | hb'
      · rw [add_zero] at hab; subst a; simp; exact hp
      · calc L (j : ℝ) (f t) (a • p + b • q)
            = a * L (j : ℝ) (f t) p + b * L (j : ℝ) (f t) q := by simp [L, Pi.add_apply, Pi.smul_apply]; rw [← hab]; ring
          _ > a * 0 + b * 0 := add_pos (mul_pos ha' hp) (mul_pos hb' hq)
          _ = 0 := by ring
  refine ⟨C, hE.inter (convex_iInter fun j ↦ convex_iInter fun t ↦ convex_iInter fun hj ↦ hH j t), x, y, fun i s ↦ ?_⟩
  constructor
  · intro h; simp [C, E, H, L] at h
    by_contra hni; have := Set.mem_iInter.1 (Set.mem_iInter.1 (Set.mem_iInter.1 h.2 i) s) hni
    simp [x, y, L, Pi.add_apply] at this; linarith
  · intro hi; simp [C, E, H, L]; constructor
    · simp [x, y, Pi.add_apply]; ring; linarith
    · intro j t hjnt; simp [x, y, L, Pi.add_apply]; ring
      obtain rfl | hij := Decidable.eq_or_ne i j
      · have hst : s ≠ t := by intro h; subst h; exact hjnt hi
        have : (f s - f t) ^ 2 > 0 := sq_pos_of_ne (hf.ne hst)
        linarith
      · have : (i : ℝ) ≠ (j : ℝ) := Nat.cast_inj.not.2 hij
        have : ((i : ℝ) - (j : ℝ)) ^ 2 > 0 := sq_pos_of_ne (sub_ne_zero.2 this)
        have : (f s - f t) ^ 2 ≥ 0 := sq_nonneg _
        linarith
