import Mathlib.NumberTheory.Cyclotomic.Basic

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro
    haveI : Algebra.IsAlgebraic K L := IsCyclotomicExtension.isAlgebraic {n | (n : K) ≠ 0} K L
    apply IsAlgClosure.of_splits
    intro f _ hf
    letI : Fintype K := Fintype.ofFinite K
    let n := f.natDegree
    let q := Fintype.card K
    have h0 : (q ^ n - 1 : K) ≠ 0 := by
      have : 1 < q := FiniteField.one_lt_card
      have : q ^ n ≠ 1 := (Nat.one_lt_pow n q hf.natDegree_pos this).ne'
      simp [FiniteField.cast_card_eq_zero K K, this]
    obtain ⟨ζ, hζ⟩ := IsCyclotomicExtension.exists_root_unity (S := {n | (n : K) ≠ 0}) (q ^ n - 1) h0
    have : f.splits (algebraMap K (Algebra.adjoin K {ζ})) := by
      apply FiniteField.splits_of_natDegree_dvd_finrank f hf.natDegree_pos
      rw [hζ.finrank_adjoin_eq_orderOf K, FiniteField.orderOf_card_pow_sub_one hf.natDegree_pos]
    exact Polynomial.splits_of_splits_of_algebraHom _ (Algebra.adjoin K {ζ}).val this
  · intro h
    haveI : IsAlgClosed L := IsAlgClosure.isAlgClosed K L
    haveI : Algebra.IsAlgebraic K L := IsAlgClosure.isAlgebraic K L
    constructor
    · intro n hn; exact IsAlgClosed.exists_primitive_root L hn
    · rw [eq_top_iff]; intro x _; rcases eq_or_ne x 0 with rfl | hx
      · exact Subalgebra.zero_mem _
      · let E := Algebra.adjoin K {x}
        letI : Fintype E := Fintype.ofFinite E
        let n := Fintype.card E - 1
        have h0 : (n : K) ≠ 0 := by
          have : 1 < Fintype.card E := FiniteField.one_lt_card
          simp [FiniteField.cast_card_eq_zero K E, (this).ne']
        obtain ⟨ζ, hζ⟩ := IsAlgClosed.exists_primitive_root L h0
        have : x ∈ (Algebra.adjoin K {ζ} : Subalgebra K L) := by
          have hx_pow : x ^ n = 1 := by
            have : (⟨x, Algebra.subset_adjoin rfl⟩ : E) ≠ 0 := fun h ↦ hx (Subtype.ext_iff.1 h)
            have := FiniteField.pow_card_sub_one_eq_one _ this
            exact Subtype.ext_iff.1 this
          obtain ⟨i, hi⟩ := hζ.eq_pow_of_pow_eq_one hx_pow n
          rw [hi]; exact Subalgebra.pow_mem _ (Algebra.subset_adjoin ⟨n, h0, hζ⟩)
        exact this
