module

public import Mathlib.NumberTheory.Cyclotomic.Basic

@[expose] public section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  rw [isAlgClosure_iff]
  constructor
  · intro
    have h_alg := IsCyclotomicExtension.isAlgebraic {n | ↑n ≠ 0} K L
    have h_closed : IsAlgClosed L := IsAlgClosed.of_exists_root _ fun f hf ↦ by
      letI : Fintype K := Fintype.ofFinite K
      let n := f.natDegree
      let q := Fintype.card K
      have h0 : (q ^ n - 1 : K) ≠ 0 := by
        rw [Nat.cast_sub (Nat.pow_pos (FiniteField.pos_of_gt FiniteField.one_lt_card) n),
          FiniteField.cast_card_eq_zero K K, Nat.cast_pow, zero_pow hf.natDegree_pos.ne', zero_sub]
        exact neg_ne_zero.2 one_ne_zero
      obtain ⟨ζ, hζ⟩ := IsCyclotomicExtension.exists_root_unity (S := {n | ↑n ≠ 0}) (q ^ n - 1) h0
      have : f.splits (Algebra.adjoin K {ζ}) := FiniteField.splits_of_natDegree_dvd_finrank f hf.natDegree_pos (by
        rw [IsPrimitiveRoot.adjoin_degree_eq_order hζ, FiniteField.orderOf_card_pow_sub_one hf.natDegree_pos])
      exact exists_root_of_splits _ this hf.ne_zero
    exact ⟨h_closed, h_alg⟩
  · intro h
    haveI : IsAlgClosed L := h.1
    haveI : Algebra.IsAlgebraic K L := h.2
    constructor
    · intro n hn; exact IsAlgClosed.exists_primitive_root L hn
    · rw [eq_top_iff]; intro x _; rcases eq_or_ne x 0 with rfl | hx
      · exact Subalgebra.zero_mem _
      · let E := Algebra.adjoin K {x}
        letI : Fintype E := Fintype.ofFinite E
        let n := Fintype.card E - 1
        have h0 : (n : K) ≠ 0 := by
          rw [Nat.cast_sub (FiniteField.one_lt_card (K := E)).le, FiniteField.cast_card_eq_zero K E, zero_sub]
          exact neg_ne_zero.2 one_ne_zero
        obtain ⟨ζ, hζ⟩ := IsAlgClosed.exists_primitive_root L h0
        obtain ⟨i, hi⟩ := hζ.eq_pow_of_pow_eq_one (by
          have := FiniteField.pow_card_sub_one_eq_one (⟨x, Algebra.subset_adjoin rfl⟩ : E) (by
            rw [ne_eq, Subtype.ext_iff, hx]; exact Submodule.zero_mem _)
          exact Subtype.ext_iff.1 this) n
        rw [hi]; exact Subalgebra.pow_mem _ (Algebra.subset_adjoin ⟨n, h0, hζ⟩)
