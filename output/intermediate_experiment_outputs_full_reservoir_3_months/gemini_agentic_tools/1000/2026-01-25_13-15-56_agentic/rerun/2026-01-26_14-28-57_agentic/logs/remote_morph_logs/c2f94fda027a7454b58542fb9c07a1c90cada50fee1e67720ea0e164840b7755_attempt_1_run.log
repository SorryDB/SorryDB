      have := FiniteField.one_lt_card (K := K)
      exact (Nat.one_lt_pow d q hf.natDegree_pos this).ne_bot)
    have h_splits : f.splits (algebraMap K (Algebra.adjoin K {ζ})) := by
      apply FiniteField.splits_of_natDegree_dvd_finrank f hf.natDegree_pos
      haveI : Fintype (Algebra.adjoin K {ζ}) := Fintype.ofFinite _
      have h_ζ_mem : ζ ∈ (Algebra.adjoin K {ζ} : Subalgebra K L) := Algebra.subset_adjoin (Set.mem_singleton _)
      let ζ' : (Algebra.adjoin K {ζ})ˣ := Units.mk0 ⟨ζ, h_ζ_mem⟩ (by
        intro h; have := hζ.ne_zero (Nat.pos_of_gt (by nlinarith [hqd, FiniteField.one_lt_card]));
        exact this (Subtype.ext_iff.1 h))
      have h_ord : orderOf ζ' = q ^ d - 1 := by
