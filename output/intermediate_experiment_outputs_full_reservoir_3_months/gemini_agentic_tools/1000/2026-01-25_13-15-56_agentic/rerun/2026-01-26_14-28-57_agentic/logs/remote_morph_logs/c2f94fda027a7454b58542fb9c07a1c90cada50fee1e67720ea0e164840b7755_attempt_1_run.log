import Mathlib.NumberTheory.Cyclotomic.Basic

section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  let S := {n : ℕ | (n : K) ≠ 0}
  constructor
  · intro
    haveI h_alg : Algebra.IsAlgebraic K L := IsCyclotomicExtension.isAlgebraic S K L
    apply IsAlgClosure.of_splits h_alg
    intro f hf
    letI : Fintype K := Fintype.ofFinite K
    let q := Fintype.card K
    let d := f.natDegree
    have hq : 1 < q := FiniteField.one_lt_card
    have hqd : (q ^ d - 1 : K) ≠ 0 := by
      have : q ^ d ≠ 1 := (Nat.one_lt_pow d q hf.natDegree_pos hq).ne'
      simp [FiniteField.cast_card_eq_zero K K, this]
    obtain ⟨ζ, hζ⟩ := IsCyclotomicExtension.exists_prim_root S K L (show q ^ d - 1 ∈ S from hqd)
    let E := IntermediateField.adjoin K {ζ}
    haveI : FiniteDimensional K E := IntermediateField.adjoin.finiteDimensional (h_alg ζ)
    haveI : Fintype E := Fintype.ofFinite E
    have h_dvd : d ∣ finrank K E := by
      have hζ0 : ζ ≠ 0 := hζ.ne_zero (Nat.sub_pos_of_lt (Nat.one_lt_pow d q hf.natDegree_pos hq)).ne'
      have : orderOf ζ ∣ Fintype.card E - 1 := by
        let ζ' : Eˣ := Units.mk0 ⟨ζ, IntermediateField.subset_adjoin K {ζ} (Set.mem_singleton ζ)⟩ (fun h ↦ hζ0 (Subtype.ext_iff.1 h))
        rw [← FiniteField.card_units, ← orderOf_units ζ']
        exact orderOf_dvd_card_univ
      rw [hζ.eq_orderOf, FiniteField.card_eq_pow_finrank K E] at this
      exact Nat.dvd_of_pow_sub_one_dvd_pow_sub_one hq this
    exact (FiniteField.splits_of_natDegree_dvd_finrank f hf.natDegree_pos h_dvd).map E.subtype
  · intro h
    haveI : IsAlgClosed L := h.isAlgClosed
    haveI : Algebra.IsAlgebraic K L := h.algebraic
    constructor
    · intro n hn; exact IsAlgClosed.exists_primitive_root L hn
    · rw [eq_top_iff]; intro x _; rcases eq_or_ne x 0 with rfl | hx
      · exact Subalgebra.zero_mem _
      · let E := IntermediateField.adjoin K {x}
        haveI : FiniteDimensional K E := IntermediateField.adjoin.finiteDimensional (h.algebraic x)
        letI : Fintype E := Fintype.ofFinite E
        let m := Fintype.card E - 1
        have hm : (m : K) ≠ 0 := by
          have : 1 < Fintype.card E := FiniteField.one_lt_card
          simp [FiniteField.cast_card_eq_zero K E, (this).ne', neg_ne_zero.2 one_ne_zero]
        obtain ⟨ζ, hζ⟩ := IsAlgClosed.exists_primitive_root L (show (m : L) ≠ 0 from (algebraMap K L).map_ne_zero.mpr hm)
        have hx_pow : x ^ m = 1 := Subtype.ext_iff.1 (FiniteField.pow_card_sub_one_eq_one (⟨x, IntermediateField.subset_adjoin K {x} (Set.mem_singleton x)⟩ : E) (fun h ↦ hx (Subtype.ext_iff.1 h)))
        obtain ⟨i, hi⟩ := hζ.eq_pow_of_pow_eq_one hx_pow
        rw [← hi]; exact Subalgebra.pow_mem _ (Algebra.subset_adjoin ⟨m, hm, hζ⟩) i

