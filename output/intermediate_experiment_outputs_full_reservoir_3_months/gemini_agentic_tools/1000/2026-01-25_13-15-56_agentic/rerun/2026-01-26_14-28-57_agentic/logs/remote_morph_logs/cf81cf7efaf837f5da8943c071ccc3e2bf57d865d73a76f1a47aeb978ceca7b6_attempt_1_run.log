def toCofix (self : StateCofixFinal F α) : Cofix F α :=
  have h := by
    rintro a b ⟨R, h_bisim, h_R⟩
    let G : (a.union b).σ → Cofix F α := fun
      | .inl s => Coalg.toCofix { a with s := s }
      | .inr t => Coalg.toCofix { b with s := t }
    apply MvQPF.Cofix.bisim (fun x y => ∃ s t, R s t ∧ x = G s ∧ y = G t)
    · rintro _ _ s t hR rfl rfl
      have hG (s) : (G s).dest = (TypeVec.id ::: G) <$$> (a.union b).dest' s := by
        cases s <;> simp [G, Coalg.toCofix, Cofix.dest_corec, Coalg.union_dest_eq_left, Coalg.union_dest_eq_right, map_map]
      have h := h_bisim _ _ hR
      rw [hG s, hG t, MvQPF.liftR_iff] at h ⊢
      rcases h with ⟨v, f₀, f₁, h₀, h₁, hr⟩
      use v, (TypeVec.id ::: G) ⊚ f₀, (TypeVec.id ::: G) ⊚ f₁
      refine ⟨by rw [MvQPF.abs_map, ← h₀], by rw [MvQPF.abs_map, ← h₁], ?_⟩
      intro i j; cases i
      · exact ⟨_, _, hr fz j, rfl, rfl⟩
      · exact hr (fs _) j
    · exact ⟨.inl a.s, .inr b.s, h_R, rfl, rfl⟩
  Quot.lift (fun c => c.toCofix) h self

theorem toCofix_ofCofix (fix : Cofix F α) : toCofix (ofCofix fix) = fix := by
  simp only [toCofix, ofCofix]
  apply MvQPF.Cofix.bisim (fun s t => s = Cofix.corec Cofix.dest t)
  · rintro _ x rfl
    rw [Cofix.dest_corec, MvQPF.liftR_iff]
    let r := repr x.dest
    use r.fst
    use ((TypeVec.id ::: Cofix.corec Cofix.dest) ⊚ r.snd)
    use r.snd
    simp only [r]
    and_intros
    · change _ = abs (_ <$$> repr _)
      simp [abs_repr, abs_map]
    · simp [abs_repr]
    · intro i j
      cases i
      <;> rfl
  · rfl

theorem ofCofix_toCofix (self : StateCofixFinal F α) : ofCofix (toCofix self) = self := by
  apply Quot.inductionOn self; intro c
  apply Quot.sound
  simpa using Coalg.ofCofix_toCofix _

end StateCofixFinal
