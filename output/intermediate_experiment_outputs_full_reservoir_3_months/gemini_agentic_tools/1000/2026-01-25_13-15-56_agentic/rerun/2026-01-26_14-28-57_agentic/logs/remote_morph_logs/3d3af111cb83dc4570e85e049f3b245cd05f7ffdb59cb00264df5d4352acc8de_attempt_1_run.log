    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C.IsCompOf (hM.restrict₂ hM')) :
    (E(C) ∩ M).encard = (E(C) ∩ M').encard := by
  obtain ⟨p, hp, hVC, hEC⟩ := hC
  have h_deg : ∀ v ∈ V(C), (E(C, v) ∩ M).encard = 1 ∧ (E(C, v) ∩ M').encard = 1 := by
    intro v hv
    have h2 : (E(C, v)).encard = 2 := hp.eDegree_eq_two v (hVC hv)
    have h_sub : E(C, v) ⊆ M ∆ M' := fun e he ↦ by
      have h_mem := hCG.1.1.le.2 (hEC (hp.mem_edgeSet_of_mem_inc v he))
      simpa [restrict₂, loopRemove] using h_mem
    have h_disj : Disjoint (E(C, v) ∩ M) (E(C, v) ∩ M') :=
      (hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.1.1.le).mono (inter_subset_right _ _) (inter_subset_right _ _)
    have h_union : E(C, v) = (E(C, v) ∩ M) ∪ (E(C, v) ∩ M') := by
      refine (subset_inter (subset_refl _) h_sub).antisymm ?_
      intro e he; obtain he_mem | he_mem := he.2 <;> [left; right] <;> exact ⟨he.1, he_mem.1⟩
    rw [h_union, Set.encard_union_of_disjoint h_disj] at h2
    have hM_le : (E(C, v) ∩ M).encard ≤ 1 := (encard_le_encard (inter_subset_right _ _)).trans (hM.degree_le_one v)
    have hM'_le : (E(C, v) ∩ M').encard ≤ 1 := (encard_le_encard (inter_subset_right _ _)).trans (hM'.degree_le_one v)
    exact ENat.add_eq_two_iff.1 h2 |>.imp (fun h => h.resolve_right (not_le_of_gt (by simpa using hM_le)))
      (fun h => h.resolve_right (not_le_of_gt (by simpa using hM'_le)))
  have h_sum (S : Set β) (hS : ∀ v ∈ V(C), (E(C, v) ∩ S).encard = 1) (hS' : S ⊆ E(C)) :
      2 * S.encard = V(C).encard := by
    rw [← C.sum_eDegree_eq_two_mul_encard_E, Set.sum_congr (rfl : V(C) = V(C)) (fun v hv ↦ by
      rw [eDegree_eq_encard_inc, inter_eq_self_of_subset_left (fun e he ↦ ⟨he.1, hS' he.1⟩), hS v hv]),
        Set.sum_const, nsmul_one]
  rw [← h_sum (E(C) ∩ M) (fun v hv ↦ (h_deg v hv).1) (inter_subset_left _ _),
      ← h_sum (E(C) ∩ M') (fun v hv ↦ (h_deg v hv).2) (inter_subset_left _ _)]
  refine (ENat.mul_left_inj (by simp) (by rw [← hVC]; exact (p.support.finite_toSet).encard_lt_top)).1 rfl
