lemma IsMatching.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C.IsCompOf (hM.restrict₂ hM')) :
    (E(C) ∩ M).encard = (E(C) ∩ M').encard := by
  have h_deg : ∀ v ∈ V(C), (E(C, v) ∩ M).encard = 1 ∧ (E(C, v) ∩ M').encard = 1 := by
    intro v hv
    obtain ⟨p, hp, hVC, hEC⟩ := hC
    have h2 : C.eDegree v = 2 := by
      rw [hEC, hVC]
      exact hp.eDegree_eq_two v hv
    have h_sub : E(C, v) ⊆ M ∆ M' := by
      intro e he
      have h_mem := hCG.1.1.subset.2 he
      simpa [restrict₂, loopRemove, mem_symmDiff] using h_mem
    have h_disj : Disjoint (E(C, v) ∩ M) (E(C, v) ∩ M') :=
      (hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.1.1).mono (Set.inter_subset_right _ _) (Set.inter_subset_right _ _)
    have hM_le : (E(C, v) ∩ M).encard ≤ 1 := (encard_le_encard (Set.inter_subset_right _ _)).trans (hM.degree_le_one v)
    have hM'_le : (E(C, v) ∩ M').encard ≤ 1 := (encard_le_encard (Set.inter_subset_right _ _)).trans (hM'.degree_le_one v)
    rw [eDegree_eq_encard_inc, ← Set.encard_union_of_disjoint h_disj, ← Set.inter_distrib_right,
        inter_eq_self_of_subset_left h_sub] at h2
    exact ENat.add_eq_two_iff.1 h2 |>.imp (fun h => h.resolve_right (not_le_of_gt (by simpa using hM_le)))
      (fun h => h.resolve_right (not_le_of_gt (by simpa using hM'_le)))
  have h_sum (S : Set β) (hS : ∀ v ∈ V(C), (E(C, v) ∩ S).encard = 1) (hS' : S ⊆ E(C)) :
      2 * S.encard = V(C).encard := by
    rw [← C.sum_eDegree_eq_two_mul_encard_edgeSet, Set.sum_congr (rfl : V(C) = V(C)) (fun v hv ↦ by rw [eDegree_eq_encard_inc, inter_eq_self_of_subset_left (fun e he ↦ ⟨he, hS' he⟩), hS v hv]),
        Set.sum_const, nsmul_one]
  rw [← h_sum (E(C) ∩ M) (fun v hv ↦ (h_deg v hv).1) (Set.inter_subset_left _ _),
      ← h_sum (E(C) ∩ M') (fun v hv ↦ (h_deg v hv).2) (Set.inter_subset_left _ _)]
  refine (ENat.mul_left_inj (by simp) (by
    by_contra h_inf
    obtain ⟨p, hp, hVC, hEC⟩ := hC
    have hV_inf : V(C).encard = ∞ := by
      rw [← h_sum (E(C) ∩ M) (fun v hv ↦ (h_deg v hv).1) (Set.inter_subset_left _ _), h_inf]
      simp
    exact hp.finite.not_infinite (V(C).encard_lt_top_iff.1 (hV_inf.symm ▸ V(C).encard_lt_top)))).1 rfl
