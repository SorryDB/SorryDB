lemma IsMatching.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C.IsCompOf (hM.restrict₂ hM')) :
    (E(C) ∩ M).encard = (E(C) ∩ M').encard := by
  have h_deg : ∀ v ∈ V(C), (E(C, v) ∩ M).encard = 1 ∧ (E(C, v) ∩ M').encard = 1 := by
    intro v hv
    have h2 := hC.eDegree_eq_two v hv
    have h_sub : E(C, v) ⊆ (M \ M') ∪ (M' \ M) := by
      intro e he; have h_mem := hCG.edgeSet_subset he.1
      simpa [restrict₂, loopRemove, mem_symmDiff] using h_mem
    have h_disj : Disjoint (E(C, v) ∩ M) (E(C, v) ∩ M') :=
      (hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.toSubgraph).mono (inter_subset_left _ _) (inter_subset_left _ _)
    have hM_le : (E(C, v) ∩ M).encard ≤ 1 := (encard_le_encard (inter_subset_right _ _)).trans (hM.degree_le_one v)
    have hM'_le : (E(C, v) ∩ M').encard ≤ 1 := (encard_le_encard (inter_subset_right _ _)).trans (hM'.degree_le_one v)
    rw [eDegree_eq_encard_inc, ← encard_union_of_disjoint h_disj, ← inter_distrib_right,
        inter_eq_self_of_subset_left h_sub] at h2
    exact ENat.add_eq_two_iff.1 h2 |>.imp (fun h => h.resolve_right (not_le_of_gt (by simpa using hM_le)))
      (fun h => h.resolve_right (not_le_of_gt (by simpa using hM'_le)))
  have h_sum (S : Set β) (hS : ∀ v ∈ V(C), (E(C, v) ∩ S).encard = 1) (hS' : S ⊆ E(C)) :
      2 * S.encard = V(C).encard := by
    rw [← C.sum_eDegree_eq_two_mul_encard_edgeSet (s := S),
        Set.sum_congr (rfl : V(C) = V(C)) (fun v hv ↦ by rw [eDegree_eq_encard_inc, inter_eq_self_of_subset_left (fun e he ↦ ⟨he.1, (hS' he.1)⟩), hS v hv]),
        sum_const, nsmul_one]
  rw [← h_sum (E(C) ∩ M) (fun v hv ↦ (h_deg v hv).1) (inter_subset_left _ _),
      ← h_sum (E(C) ∩ M') (fun v hv ↦ (h_deg v hv).2) (inter_subset_left _ _)]
  refine (ENat.mul_left_inj (by simp) (by
    by_contra h_inf; rw [h_sum (E(C) ∩ M) (fun v hv ↦ (h_deg v hv).1) (inter_subset_left _ _)] at h_inf
    exact (hC.finite_vertexSet_of_finite_edgeSet (by simpa using h_inf)).not_infinite (by simpa using h_inf))).1 rfl
