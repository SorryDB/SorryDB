      obtain ⟨k2, hk2⟩ := y.2
      rw [hk1, hk2] at h
      simp at h
      rw [hk1, hk2, h]
    · intros y
      use ⟨2 * y, ⟨y, rfl⟩⟩
      simp
      apply Int.mul_ediv_cancel_left
      decide
  · exact denum_Int
