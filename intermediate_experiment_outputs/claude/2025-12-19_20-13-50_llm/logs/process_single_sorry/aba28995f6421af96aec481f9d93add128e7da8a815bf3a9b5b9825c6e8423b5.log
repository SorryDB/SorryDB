Released under Apache 2.0 license as described in the file LICENSE.
Authors: Kevin Buzzard, William Coram
-/
import FLT.HaarMeasure.HaarChar.AdeleRing
import FLT.Mathlib.GroupTheory.DoubleCoset
import FLT.Mathlib.Topology.HomToDiscrete
/-

# Fujisaki's lemma

We prove a lemma which Voight (in his quaternion algebra book) attributes to Fujisaki:
if `D` is a finite-dimensional division algebra over a number field `K`
and if `U вҠҶ (D вҠ—[K] рқ”ё_K^infty)ЛЈ` is a compact open subgroup then the double coset
space `DЛЈ \ (D вҠ—[K] рқ”ё_K^infty)ЛЈ / U` is finite.

-/

suppress_compilation

open IsDedekindDomain MeasureTheory

open scoped TensorProduct

variable (K : Type*) [Field K] [NumberField K]
variable (D : Type*) [DivisionRing D] [Algebra K D]

namespace NumberField.AdeleRing.DivisionAlgebra

set_option quotPrecheck false in
/-- `D_рқ”ё` is notation for `D вҠ—[K] рқ”ё_K`. -/
notation "D_рқ”ё" => (D вҠ—[K] AdeleRing (рқ“һ K) K)

open scoped TensorProduct.RightActions

/-- The inclusion DЛЈ вҶ’ D_рқ”ёЛЈ as a group homomorphism. -/
noncomputable abbrev incl : DЛЈ вҶ’* D_рқ”ёЛЈ :=
  Units.map Algebra.TensorProduct.includeLeftRingHom.toMonoidHom

namespace Aux

/-- The inclusion of K^n into рқ”ё^n. -/
abbrev incl_Kn_рқ”ёKn : (Fin (Module.finrank K D) вҶ’ K) вҶ’
    (Fin (Module.finrank K D) вҶ’ AdeleRing (рқ“һ K) K) :=
  fun x i вҶҰ algebraMap K (AdeleRing (рқ“һ K) K) (x i)

theorem Kn_discrete : вҲҖ x : (Fin (Module.finrank K D) вҶ’ K),
    вҲғ U : Set (Fin (Module.finrank K D) вҶ’ AdeleRing (рқ“һ K) K),
    IsOpen U вҲ§ (incl_Kn_рқ”ёKn K D)вҒ»В№' U = {x} := by
  exact (DiscretePi (algebraMap K (AdeleRing (рқ“һ K) K)) (Module.finrank K D))
    (NumberField.AdeleRing.discrete K)

variable [FiniteDimensional K D]

/-- The K-algebra equivalence of D and K^n. -/
abbrev D_iso : (D вүғвӮ—[K] ((Fin (Module.finrank K D) вҶ’ K))) := Module.Finite.equivPi K D

-- Mathlib#29315....
attribute [local instance 1100] IsTopologicalSemiring.toIsModuleTopology

-- ...makes this work
example : IsModuleTopology (AdeleRing (рқ“һ K) K)
    ((Fin (Module.finrank K D) вҶ’ AdeleRing (рқ“һ K) K)) := inferInstance

/-- The рқ”ё-algebra equivalence of D_рқ”ё and рқ”ё^d. -/
abbrev Dрқ”ё_iso : (D_рқ”ё вүғвӮ—[(AdeleRing (рқ“һ K) K)] ((Fin (Module.finrank K D) вҶ’ AdeleRing (рқ“һ K) K))) :=
  ((TensorProduct.RightActions.Module.TensorProduct.comm _ _ _).symm).trans
    (TensorProduct.AlgebraTensorModule.finiteEquivPi K D (AdeleRing (рқ“һ K) K))

/-- The topological equivalence via Dрқ”ё_iso. -/
abbrev Dрқ”ё_iso_top : D_рқ”ё вүғL[(AdeleRing (рқ“һ K) K)]
    ((Fin (Module.finrank K D) вҶ’ AdeleRing (рқ“һ K) K)) :=
  IsModuleTopology.continuousLinearEquiv (Dрқ”ё_iso K D)

theorem D_discrete_extracted (U : Set (Fin (Module.finrank K D) вҶ’ AdeleRing (рқ“һ K) K)) :
    incl_Kn_рқ”ёKn K D вҒ»В№' U  = (D_iso K D) ''
    (вҮ‘(Dрқ”ё_iso_top K D) вҲҳ (Algebra.TensorProduct.includeLeft : D вҶ’вӮҗ[K] D_рқ”ё) вҒ»В№' U) := by
  ext x
  constructor
  В· intro hx
    use (D_iso K D).symm x
    simpa [вҶҗ Algebra.algebraMap_eq_smul_one] using hx
  В· intro вҹЁy, hy1, hy2вҹ©
    have : (Dрқ”ё_iso_top K D) вҲҳ (Algebra.TensorProduct.includeLeft : D вҶ’вӮҗ[K] D_рқ”ё) =
        (incl_Kn_рқ”ёKn K D) вҲҳ (D_iso K D) := by
      ext d n
      simp [вҶҗ Algebra.algebraMap_eq_smul_one]
    rw [this] at hy1
    simpa [вҶҗ hy2] using hy1

theorem D_discrete : вҲҖ x : D, вҲғ U : Set D_рқ”ё,
    IsOpen U вҲ§ (Algebra.TensorProduct.includeLeft : D вҶ’вӮҗ[K] D_рқ”ё) вҒ»В№' U = {x} := by
  apply Discrete_of_HomeoDiscrete (Y' := ((Fin (Module.finrank K D) вҶ’ AdeleRing (рқ“һ K) K)))
    (Algebra.TensorProduct.includeLeft : D вҶ’вӮҗ[K] D_рқ”ё) (Dрқ”ё_iso_top K D)
  apply Discrete_of_HomDiscrete (X' := Fin (Module.finrank K D) вҶ’ K)
    ((Dрқ”ё_iso_top K D) вҲҳ (Algebra.TensorProduct.includeLeft : D вҶ’вӮҗ[K] D_рқ”ё)) (D_iso K D)
  simpa [D_discrete_extracted] using Kn_discrete K D

variable [MeasurableSpace (D вҠ—[K] AdeleRing (рқ“һ K) K)] [BorelSpace (D вҠ—[K] AdeleRing (рқ“һ K) K)]

lemma existsE : вҲғ E : Set (D_рқ”ё), IsCompact E вҲ§
    вҲҖ ПҶ : D_рқ”ё вүғвӮң+ D_рқ”ё, addEquivAddHaarChar ПҶ = 1 вҶ’ вҲғ eвӮҒ вҲҲ E, вҲғ eвӮӮ вҲҲ E,
    eвӮҒ вү  eвӮӮ вҲ§ ПҶ eвӮҒ - ПҶ eвӮӮ вҲҲ Set.range (Algebra.TensorProduct.includeLeft : D вҶ’вӮҗ[K] D_рқ”ё) := by
  classical
  obtain вҹЁU, hUвҹ© := D_discrete K D 0
  refine вҹЁU, ?_, fun ПҶ _ => ?_вҹ©
  В· exact IsOpen.isCompact_iff_ne_univ.mpr вҹЁhU.1, ?_вҹ©
    intro h
    have : (0 : D) вҲҲ (Algebra.TensorProduct.includeLeft : D вҶ’вӮҗ[K] D_рқ”ё) вҒ»В№' U := by simp [hU.2]
    rw [Set.preimage_univ] at this
    exact absurd trivial this
  В· exact вҹЁ0, by simp [hU.2], 0, by simp [hU.2], by simp, by simpвҹ©
```
