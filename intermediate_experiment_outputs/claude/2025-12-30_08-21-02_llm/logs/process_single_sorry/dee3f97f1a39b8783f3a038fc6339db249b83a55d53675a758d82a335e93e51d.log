def mulPowX_equiv : ∀ (i j : ℕ),
  (mulPowX i p).coeff j = p.coeff (j - i) := by
  intro i j
  unfold mulPowX coeff mk
  rcases Nat.lt_or_ge j i with hj | hj
  · simp [hj, Nat.sub_eq_zero_of_le (Nat.le_of_lt hj)]
  · have hj' : j - i < p.size ∨ j - i ≥ p.size := Nat.lt_or_ge (j - i) p.size
