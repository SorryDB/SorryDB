        apply setLIntegral_congr_fun measurableSet_Ioi
        intro t ht
        simp [ENNReal.ofReal_rpow_of_pos ht]
    _ = eLpNorm f (.ofReal p.toReal) őľ := (eLpNorm_eq_distribution hf (ENNReal.toReal_pos p_zero p_eq_top)).symm
    _ = eLpNorm f p őľ := by congr; exact p_eq.symm


--TODO: generalize this?
lemma aeMeasurable_withDensity_inv {f : ‚ĄĚ‚Č•0 ‚Üí ‚ĄĚ‚Č•0‚ąě} (hf : AEMeasurable f) :
    AEMeasurable f (volume.withDensity (fun t ‚Ü¶ t‚ĀĽ¬Ļ)) := by
  have : AEMeasurable f (volume.withDensity (fun t ‚Ü¶ ENNReal.ofNNReal t‚ĀĽ¬Ļ)) := by
    rw [aemeasurable_withDensity_ennreal_iff measurable_inv]
    apply AEMeasurable.mul _ hf
    exact measurable_inv.aemeasurable.coe_nnreal_ennreal
  convert this using 1
  rw [withDensity_eq_iff_of_sigmaFinite]
  ¬∑ rw [Filter.eventuallyEq_iff_exists_mem]
    use {x | x ‚Č† 0}
    constructor
    ¬∑ rw [mem_ae_iff]
      simp only [ne_eq, Set.compl_ne_eq_singleton]
      apply measure_singleton
    ¬∑ intro x hx
      simp only [ne_eq, Set.mem_setOf_eq] at *
      exact Eq.symm (ENNReal.coe_inv hx)
  ¬∑ apply Measurable.aemeasurable
    measurability
  ¬∑ exact measurable_inv.aemeasurable.coe_nnreal_ennreal


--TODO: move to essSup.lean
lemma essSup_le_iSup {őĪ : Type*} {ő≤ : Type*} {m : MeasurableSpace őĪ} {őľ : Measure őĪ} [CompleteLattice ő≤]
    (f : őĪ ‚Üí ő≤) : essSup f őľ ‚Č§ ‚®Ü i, f i := by
  apply essSup_le_of_ae_le
  apply Filter.Eventually.of_forall
  intro i
  apply le_iSup

--TODO: move
lemma iSup_le_essSup {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě}
  (h : ‚ąÄ {x}, ‚ąÄ {a}, a < f x ‚Üí őľ {y | a < f y} ‚Č† 0) :
    ‚®Ü x, f x ‚Č§ essSup f őľ := by
  apply iSup_le
  intro i
  rw [essSup_eq_sInf]
  apply le_sInf
  intro b hb
  simp only [Set.mem_setOf_eq] at hb
  apply le_of_forall_lt
  intro c hc
  have := h hc
  contrapose! this
  rw [‚Üź ENNReal.bot_eq_zero, ‚Üź le_bot_iff] at *
  apply le_trans _ hb
  apply measure_mono
  intro x
  simp only [Set.mem_setOf_eq]
  intro hc
  exact lt_of_le_of_lt this hc

lemma helper {f : ‚ĄĚ‚Č•0‚ąě ‚Üí ‚ĄĚ‚Č•0‚ąě} {x : ‚ĄĚ‚Č•0‚ąě} (hx : x ‚Č† ‚ä§)
  (hf : ContinuousWithinAt f (Set.Ioi x) x)
  {a : ‚ĄĚ‚Č•0‚ąě} (ha : a < f x) :
    volume {y | a < f y} ‚Č† 0 := by
  unfold ContinuousWithinAt at hf
  set s := Set.Ioi a
  have mem_nhds_s : s ‚ąą nhds (f x) := by
    rw [IsOpen.mem_nhds_iff isOpen_Ioi]
    simpa
  have := hf mem_nhds_s
  simp only [Filter.mem_map] at this
  rw [‚Üź ENNReal.bot_eq_zero, ‚Üź bot_lt_iff_ne_bot]
  rw [mem_nhdsWithin] at this
  rcases this with ‚ü®u, u_open, x_in_u, u_inter_subset‚ü©
  calc _
    _ < volume (u ‚ą© Set.Ioi x) := by
      rw [bot_lt_iff_ne_bot]
      apply IsOpen.measure_ne_zero
      ¬∑ apply u_open.inter isOpen_Ioi
      apply nonempty_nhds_inter_Ioi (IsOpen.mem_nhds u_open x_in_u) (not_isMax_iff_ne_top.mpr hx)
    _ ‚Č§ volume (f ‚ĀĽ¬Ļ' s) := by
      apply measure_mono u_inter_subset
    _ ‚Č§ volume {y | a < f y} := by
      apply measure_mono
      unfold s Set.preimage
      simp only [Set.mem_Ioi, Set.setOf_subset_setOf]
      intro y h
      exact h

--TODO: move
theorem ContinuousWithinAt.ennreal_mul {X : Type*}
  [TopologicalSpace X] {f g : X ‚Üí ‚ĄĚ‚Č•0‚ąě} {s : Set X} {t : X} (hf : ContinuousWithinAt f s t)
  (hg : ContinuousWithinAt g s t)
  (h‚āĀ : f t ‚Č† 0 ‚ą® g t ‚Č† ‚ąě)
  (h‚āā : g t ‚Č† 0 ‚ą® f t ‚Č† ‚ąě) :
    ContinuousWithinAt (fun x ‚Ü¶ f x * g x) s t := fun _ hx =>
  ENNReal.Tendsto.mul hf h‚āĀ hg h‚āā hx

--TODO: move
nonrec theorem ContinuousWithinAt.ennrpow_const [TopologicalSpace őĪ] {f : őĪ ‚Üí ‚ĄĚ‚Č•0‚ąě} {s : Set őĪ} {x : őĪ}
  {p : ‚ĄĚ}
  (hf : ContinuousWithinAt f s x) :
    ContinuousWithinAt (fun x => f x ^ p) s x := by
  apply hf.ennrpow_const


lemma eLorentzNorm_eq_wnorm (hp : p ‚Č† 0) : eLorentzNorm f p ‚ąě őľ = wnorm f p őľ := by
  by_cases p_eq_top : p = ‚ąě
  ¬∑ rw [p_eq_top]
    simp
  rw [eLorentzNorm_eq_eLorentzNorm' hp p_eq_top, wnorm_ne_top p_eq_top]
  unfold eLorentzNorm' wnorm'
  simp only [ENNReal.inv_top, ENNReal.toReal_zero, ENNReal.rpow_zero, ENNReal.toReal_inv,
    eLpNorm_exponent_top, one_mul]
  unfold eLpNormEssSup
  simp only [enorm_eq_self]
  apply le_antisymm
  ¬∑ apply essSup_le_iSup
  ¬∑ apply iSup_le_essSup
    intro x a ha
    rw [ne_eq, withDensity_apply_eq_zero' (by measurability)]
    simp only [ne_eq, ENNReal.inv_eq_zero, ENNReal.coe_ne_top, not_false_eq_true, Set.setOf_true,
      Set.univ_inter]
    have : ENNReal.ofNNReal '' {y | a < ‚ÜĎy * distribution f (‚ÜĎy) őľ ^ p.toReal‚ĀĽ¬Ļ}
        = {y | a < y * distribution f y őľ ^ p.toReal‚ĀĽ¬Ļ} \ {‚ä§}:= by
      ext y
      simp only [Set.mem_image, Set.mem_setOf_eq, Set.mem_diff, Set.mem_singleton_iff]
      constructor
      ¬∑ rintro ‚ü®x, hx, hxy‚ü©
        rw [‚Üź hxy]
        use hx
        simp
      ¬∑ intro hy
        by_cases y_eq_top : y = ‚ä§
        ¬∑ exfalso
          exact hy.2 y_eq_top
        use y.toNNReal
        rw [ENNReal.coe_toNNReal y_eq_top]
        use hy.1
    rw [‚Üź ne_eq, NNReal.volume_eq_volume_ennreal]
    ¬∑ rw [this, measure_diff_null (measure_singleton ‚ä§)]
      apply @helper _ x
      ¬∑ simp
      ¬∑ apply ContinuousWithinAt.ennreal_mul continuous_id'.continuousWithinAt ((continuousWithinAt_distribution _).ennrpow_const _)
        ¬∑ rw [or_iff_not_imp_left]
          push_neg
          intro h
          exfalso
          rw [h] at ha
          simp at ha
        ¬∑ right
          simp
      ¬∑ exact ha
    rw [this]
    apply MeasurableSet.diff _ (measurableSet_singleton ‚ä§)
    refine measurableSet_lt measurable_const ?_
    measurability


lemma eLorentzNorm'_eq_integral_distribution_rpow :
    eLorentzNorm' f p 1 őľ = p * ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), distribution f t őľ ^ p.toReal‚ĀĽ¬Ļ := by
  unfold eLorentzNorm'
  simp only [inv_one, ENNReal.toReal_one, ENNReal.rpow_one, ENNReal.toReal_inv]
  congr
  rw [eLpNorm_eq_lintegral_rpow_enorm (by norm_num) (by norm_num)]
  rw [lintegral_withDensity_eq_lintegral_mul‚āÄ' (by measurability)
    (by apply aeMeasurable_withDensity_inv; apply AEMeasurable.pow_const; apply AEStronglyMeasurable.enorm; apply
      aestronglyMeasurable_iff_aemeasurable.mpr; apply Measurable.aemeasurable; measurability)]
  simp only [enorm_eq_self, ENNReal.toReal_one, ENNReal.rpow_one, Pi.mul_apply, ne_eq, one_ne_zero,
    not_false_eq_true, div_self]
  rw [lintegral_nnreal_eq_lintegral_toNNReal_Ioi, lintegral_nnreal_eq_lintegral_toNNReal_Ioi]
  apply setLIntegral_congr_fun measurableSet_Ioi
  intro x hx
  simp only
  rw [‚Üź mul_assoc, ENNReal.inv_mul_cancel, one_mul]
  ¬∑ rw [ENNReal.coe_ne_zero]
    symm
    apply ne_of_lt
    rw [Real.toNNReal_pos]
    exact hx
  ¬∑ exact ENNReal.coe_ne_top

lemma eLorentzNorm'_indicator {őĶ} [TopologicalSpace őĶ] [ENormedAddMonoid őĶ] {a : őĶ} (ha : ‚ÄĖa‚ÄĖ‚āĎ ‚Č† ‚ä§)
  {s : Set őĪ} (p_ne_zero : p ‚Č† 0) (p_ne_top : p ‚Č† ‚ä§) :
    eLorentzNorm' (s.indicator (Function.const őĪ a)) p 1 őľ = p * (‚ÄĖa‚ÄĖ‚āĎ * őľ s ^ p‚ĀĽ¬Ļ.toReal) := by
  rw [eLorentzNorm'_eq_integral_distribution_rpow]
  congr
  simp_rw [distribution_indicator_const (őĶ := őĶ) (őľ := őľ) (s := s) (a := a)]
  unfold Set.indicator
  simp only [ENNReal.toReal_inv, ite_pow]
  --rw [ENNReal.zero_rpow_of_pos (by simp only [inv_pos]; exact ENNReal.toReal_pos p_ne_zero p_ne_top)]
  --rw [‚Üź Set.indicator_apply, lintegral_indicator_const measurableSet_Iio, mul_comm]
  symm
  calc ‚ÄĖa‚ÄĖ‚āĎ * őľ s ^ p.toReal‚ĀĽ¬Ļ
    _ = (‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), (Set.Iio ‚ÄĖa‚ÄĖ‚āĎ.toNNReal).indicator (fun x ‚Ü¶ őľ s ^ p.toReal‚ĀĽ¬Ļ) t) := by
      rw [lintegral_indicator_const measurableSet_Iio, mul_comm]
      congr 1
      rw [NNReal.volume_Iio, ENNReal.coe_toNNReal ha]
  congr with t
  unfold Set.indicator
  rw [ENNReal.zero_rpow_of_pos (by simp only [inv_pos]; exact ENNReal.toReal_pos p_ne_zero p_ne_top)]
  congr 1
  simp only [Set.mem_Iio, eq_iff_iff]
  exact (ENNReal.coe_lt_iff_lt_toNNReal ha).symm



variable [TopologicalSpace őĶ] [ContinuousENorm őĶ]
/-- A function is in the Lorentz space L_{pr} if it is (strongly a.e.)-measurable and has finite Lorentz norm. -/
def MemLorentz (f : őĪ ‚Üí őĶ) (p r : ‚ĄĚ‚Č•0‚ąě) (őľ : Measure őĪ) : Prop :=
  AEStronglyMeasurable f őľ ‚ąß eLorentzNorm f p r őľ < ‚ąě

lemma MemLorentz_iff_MemLp {f : őĪ ‚Üí őĶ'} :
    MemLorentz f p p őľ ‚ÜĒ MemLp f p őľ := by
  unfold MemLorentz MemLp
  constructor
  ¬∑ intro h
    rwa [‚Üź eLorentzNorm_eq_eLpNorm h.1]
  ¬∑ intro h
    rwa [eLorentzNorm_eq_eLpNorm h.1]


-- TODO: could maybe be strengthened to ‚ÜĒ
lemma MemLorentz_of_MemLorentz_ge {őĶ : Type*} [ENorm őĶ] [TopologicalSpace őĶ]
  {f : őĪ ‚Üí őĶ} {p r‚āĀ r‚āā : ‚ĄĚ‚Č•0‚ąě} {őľ : Measure őĪ}
  (r‚āĀ_pos : 0 < r‚āĀ) (r‚āĀ_le_r‚āā : r‚āĀ ‚Č§ r‚āā) (hf : MemLorentz f p r‚āĀ őľ) :
    MemLorentz f p r‚āā őľ := by
  unfold MemLorentz at *
  rcases hf with ‚ü®meas_f, norm_f‚ü©
  use meas_f
  unfold eLorentzNorm at *
  split_ifs at * with h‚āÄ h‚āĀ h‚āā h‚āÉ h‚āĄ h‚āÖ h‚āÜ h‚āá h‚āą h‚āČ
  ¬∑ exact ENNReal.zero_lt_top
  ¬∑ exact ENNReal.zero_lt_top
  ¬∑ exact ENNReal.zero_lt_top
  ¬∑ exact ENNReal.zero_lt_top
  ¬∑ exfalso
    exact r‚āĀ_pos.ne h‚āÜ.symm
  ¬∑ exact norm_f
  ¬∑ rw [ENNReal.top_mul'] at norm_f
    split_ifs at norm_f with h
    ¬∑ rwa [h]
    ¬∑ exfalso
      exact (lt_self_iff_false ‚ä§).mp norm_f
  ¬∑ exfalso
    exact r‚āĀ_pos.ne h‚āą.symm
  ¬∑ exfalso
    rw [h‚āČ, top_le_iff] at r‚āĀ_le_r‚āā
    exact h‚āÖ r‚āĀ_le_r‚āā
  ¬∑ exact norm_f
  ¬∑ by_cases r‚āĀ_top : r‚āĀ = ‚ąě
    ¬∑ convert norm_f
      rw [r‚āĀ_top, top_le_iff] at r‚āĀ_le_r‚āā
      rw [r‚āĀ_top, r‚āĀ_le_r‚āā]
    --Now the only interesting case
    have measurable_mul_distribution_rpow : Measurable fun (t : ‚ĄĚ‚Č•0) ‚Ü¶ ‚ÜĎt * distribution f (‚ÜĎt) őľ ^ p‚ĀĽ¬Ļ.toReal := by measurability
    unfold eLorentzNorm' at norm_f
    rw [ENNReal.mul_lt_top_iff] at norm_f
    rcases norm_f with ‚ü®_, norm_lt_top‚ü© | p_zero | norm_zero
    ¬∑ wlog r‚āā_top : r‚āā = ‚ä§ generalizing r‚āā
      ¬∑ have memLp_r‚āĀ: MemLp (fun (t : ‚ĄĚ‚Č•0) ‚Ü¶ ‚ÜĎt * distribution f (‚ÜĎt) őľ ^ p‚ĀĽ¬Ļ.toReal) r‚āĀ
                        (volume.withDensity fun t ‚Ü¶ (‚ÜĎt)‚ĀĽ¬Ļ) := by
          constructor
          ¬∑ exact (aeMeasurable_withDensity_inv measurable_mul_distribution_rpow.aemeasurable).aestronglyMeasurable
          exact norm_lt_top
        have memLp_top : MemLp (fun (t : ‚ĄĚ‚Č•0) ‚Ü¶ ‚ÜĎt * distribution f (‚ÜĎt) őľ ^ p‚ĀĽ¬Ļ.toReal) ‚ä§
                          (volume.withDensity fun t ‚Ü¶ (‚ÜĎt)‚ĀĽ¬Ļ) := by
          constructor
          ¬∑ exact (aeMeasurable_withDensity_inv measurable_mul_distribution_rpow.aemeasurable).aestronglyMeasurable
          have := this le_top rfl
          unfold eLorentzNorm' at this
          rw [ENNReal.mul_lt_top_iff] at this
          rcases this with ‚ü®_, norm_lt_top‚ü© | p_zero | norm_zero
          ¬∑ exact norm_lt_top
          ¬∑ --TODO: duplicate from below
            exfalso
            rw [ENNReal.rpow_eq_zero_iff] at p_zero
            rcases p_zero with ‚ü®p_zero, _‚ü© | ‚ü®p_top, _‚ü©
            ¬∑ exact h‚āÄ p_zero
            ¬∑ exact h‚āĀ p_top
          ¬∑ rw [norm_zero]
            exact ENNReal.zero_lt_top
        unfold eLorentzNorm'
        rw [ENNReal.mul_lt_top_iff]
        left
        use ENNReal.rpow_lt_top_of_nonneg (by simp) h‚āĀ
        exact (MeasureTheory.memLp_of_memLp_le_of_memLp_ge r‚āĀ_pos ‚ü®r‚āĀ_le_r‚āā, le_top‚ü© memLp_r‚āĀ memLp_top).2

      /- Hardest part -/
      rw [eLpNorm_eq_lintegral_rpow_enorm r‚āĀ_pos.ne' r‚āĀ_top,
          lintegral_withDensity_eq_lintegral_mul‚āÄ (by measurability) (measurable_mul_distribution_rpow.aestronglyMeasurable.enorm.pow_const r‚āĀ.toReal),
          lintegral_nnreal_eq_lintegral_toNNReal_Ioi] at norm_lt_top
      simp only [ENNReal.toReal_inv, enorm_eq_self, Pi.mul_apply, one_div] at norm_lt_top
      rw [r‚āā_top, ‚Üź eLorentzNorm_eq_eLorentzNorm' h‚āÄ h‚āĀ, eLorentzNorm_eq_wnorm h‚āÄ, wnorm_ne_top h‚āĀ, wnorm']
      rw [iSup_lt_iff]

      have toReal_r‚āĀ_pos := ENNReal.toReal_pos r‚āĀ_pos.ne' r‚āĀ_top
      have : r‚āĀ ^ r‚āĀ.toReal‚ĀĽ¬Ļ < ‚ąě := ENNReal.rpow_lt_top_of_nonneg (by simp) r‚āĀ_top
      have norm_lt_top' := ENNReal.mul_lt_top norm_lt_top this
      exists _, norm_lt_top'
      intro s
      by_cases s_pos : ¬¨ 0 < NNReal.toReal s
      ¬∑ simp only [NNReal.coe_pos, not_lt, nonpos_iff_eq_zero] at s_pos
        rw [s_pos]
        simp
      push_neg at s_pos
      rw [‚Üź ENNReal.div_le_iff_le_mul (by left; apply (ENNReal.rpow_pos r‚āĀ_pos r‚āĀ_top).ne') (by left; exact this.ne)] --TODO: improve this
      calc _
        _ = distribution f (‚ÜĎs) őľ ^ p.toReal‚ĀĽ¬Ļ * (‚ÜĎs / r‚āĀ ^ r‚āĀ.toReal‚ĀĽ¬Ļ) := by
          rw [mul_comm, mul_div_assoc]
        _ = distribution f (‚ÜĎs) őľ ^ p.toReal‚ĀĽ¬Ļ * (s ^ r‚āĀ.toReal / r‚āĀ) ^ r‚āĀ.toReal‚ĀĽ¬Ļ := by
          rw [ENNReal.div_rpow_of_nonneg,
              ENNReal.rpow_rpow_inv (ENNReal.toReal_ne_zero.mpr ‚ü®r‚āĀ_pos.ne', r‚āĀ_top‚ü©)]
          simp only [inv_nonneg, ENNReal.toReal_nonneg]
        _ = (distribution f (‚ÜĎs) őľ ^ (p.toReal‚ĀĽ¬Ļ * r‚āĀ.toReal)) ^ r‚āĀ.toReal‚ĀĽ¬Ļ * (s ^ r‚āĀ.toReal / r‚āĀ) ^ r‚āĀ.toReal‚ĀĽ¬Ļ := by
          congr 1
          ¬∑ rw [ENNReal.rpow_mul, ENNReal.rpow_rpow_inv (ENNReal.toReal_ne_zero.mpr ‚ü®r‚āĀ_pos.ne', r‚āĀ_top‚ü©)]
          --¬∑
        _ = (distribution f (‚ÜĎs) őľ ^ (p.toReal‚ĀĽ¬Ļ * r‚āĀ.toReal)) ^ r‚āĀ.toReal‚ĀĽ¬Ļ * (‚ąę‚ĀĽ (x : ‚ĄĚ) in Set.Ioo 0 s.toReal, ENNReal.ofReal (x ^ (r‚āĀ.toReal - 1))) ^ r‚āĀ.toReal‚ĀĽ¬Ļ:= by
          congr
          rw [lintegral_rpow_of_gt s_pos (by linarith), ENNReal.ofReal_div_of_pos (by simpa),
              ‚Üź ENNReal.ofReal_rpow_of_nonneg NNReal.zero_le_coe (by linarith)]
          ring_nf
          rw [ENNReal.ofReal_toReal r‚āĀ_top, ENNReal.ofReal, Real.toNNReal_coe]
        _ = (‚ąę‚ĀĽ (x : ‚ĄĚ) in Set.Ioo 0 s.toReal, (‚ÜĎx.toNNReal)‚ĀĽ¬Ļ *
              (‚ÜĎx.toNNReal ^ r‚āĀ.toReal * distribution f s őľ ^ (p.toReal‚ĀĽ¬Ļ * r‚āĀ.toReal))) ^ r‚āĀ.toReal‚ĀĽ¬Ļ := by
          rw [‚Üź ENNReal.mul_rpow_of_nonneg, ‚Üź lintegral_const_mul]
          ¬∑ congr 1
            apply setLIntegral_congr_fun measurableSet_Ioo
            intro x hx
            simp only
            rw [mul_comm, ‚Üź mul_assoc]
            congr 1
            rw [‚Üź ENNReal.ofReal_rpow_of_pos hx.1, ‚Üź ENNReal.rpow_neg_one, ‚Üź ENNReal.rpow_add _ _ (by simp [hx.1]) (by simp), neg_add_eq_sub]
            congr
          ¬∑ measurability
          ¬∑ simp only [inv_nonneg, ENNReal.toReal_nonneg]
        _ = (‚ąę‚ĀĽ (x : ‚ĄĚ) in Set.Ioo 0 s.toReal, (‚ÜĎx.toNNReal)‚ĀĽ¬Ļ *
              (‚ÜĎx.toNNReal * distribution f s őľ ^ p.toReal‚ĀĽ¬Ļ) ^ r‚āĀ.toReal) ^ r‚āĀ.toReal‚ĀĽ¬Ļ := by
          congr with x
          rw [ENNReal.mul_rpow_of_nonneg, ENNReal.rpow_mul]
          exact ENNReal.toReal_nonneg
        _ ‚Č§ (‚ąę‚ĀĽ (x : ‚ĄĚ) in Set.Ioo 0 s.toReal, (‚ÜĎx.toNNReal)‚ĀĽ¬Ļ *
              (‚ÜĎx.toNNReal * distribution f (‚ÜĎx.toNNReal) őľ ^ p.toReal‚ĀĽ¬Ļ) ^ r‚āĀ.toReal) ^ r‚āĀ.toReal‚ĀĽ¬Ļ := by
          apply ENNReal.rpow_le_rpow _ (by simp only [inv_nonneg, ENNReal.toReal_nonneg])
          apply setLIntegral_mono' measurableSet_Ioo
          intro t ht
          gcongr
          exact Real.toNNReal_le_iff_le_coe.mpr ht.2.le
        _ ‚Č§ (‚ąę‚ĀĽ (x : ‚ĄĚ) in Set.Ioi 0, (‚ÜĎx.toNNReal)‚ĀĽ¬Ļ * (‚ÜĎx.toNNReal * distribution f (‚ÜĎx.toNNReal) őľ ^ p.toReal‚ĀĽ¬Ļ) ^ r‚āĀ.toReal) ^
            r‚āĀ.toReal‚ĀĽ¬Ļ := by
          gcongr
          exact Set.Ioo_subset_Ioi_self
    ¬∑ exfalso
      rw [ENNReal.rpow_eq_zero_iff] at p_zero
      rcases p_zero with ‚ü®p_zero, _‚ü© | ‚ü®p_top, _‚ü©
      ¬∑ exact h‚āÄ p_zero
      ¬∑ exact h‚āĀ p_top
    ¬∑ unfold eLorentzNorm'
      rw [ENNReal.mul_lt_top_iff]
      right; right
      rw [eLpNorm_eq_zero_iff measurable_mul_distribution_rpow.aestronglyMeasurable r‚āĀ_pos.ne'] at norm_zero
      rwa [eLpNorm_eq_zero_iff measurable_mul_distribution_rpow.aestronglyMeasurable (r‚āĀ_pos.trans_le r‚āĀ_le_r‚āā).ne']

lemma MemLorentz.memLp {f : őĪ ‚Üí őĶ'} (hf : MemLorentz f p r őľ) (h : r ‚ąą Set.Ioc 0 p) :
    MemLp f p őľ := by
  rw [‚Üź MemLorentz_iff_MemLp]
  apply MemLorentz_of_MemLorentz_ge h.1 h.2 hf


end Lorentz


variable {őĪ' őĶ‚āĀ őĶ‚āā : Type*} {m : MeasurableSpace őĪ'} [TopologicalSpace őĶ‚āĀ] [ENorm őĶ‚āĀ]
    [TopologicalSpace őĶ‚āā] [ENorm őĶ‚āā] {f : őĪ ‚Üí őĶ} {f‚āĀ : őĪ ‚Üí őĶ‚āĀ}

/-- An operator has Lorentz type `(p, r, q, s)` if it is bounded as a map
from `L^{q, s}` to `L^{p, r}`. `HasLorentzType T p r q s őľ őĹ c` means that
`T` has Lorentz type `(p, r, q, s)` w.r.t. measures `őľ`, `őĹ` and constant `c`. -/
def HasLorentzType (T : (őĪ ‚Üí őĶ‚āĀ) ‚Üí (őĪ' ‚Üí őĶ‚āā))
    (p r q s : ‚ĄĚ‚Č•0‚ąě) (őľ : Measure őĪ) (őĹ : Measure őĪ') (c : ‚ĄĚ‚Č•0‚ąě) : Prop :=
  ‚ąÄ f : őĪ ‚Üí őĶ‚āĀ, MemLorentz f p r őľ ‚Üí AEStronglyMeasurable (T f) őĹ ‚ąß
    eLorentzNorm (T f) q s őĹ ‚Č§ c * eLorentzNorm f p r őľ


lemma hasStrongType_iff_hasLorentzType {őĶ‚āĀ őĶ‚āā}
  [TopologicalSpace őĶ‚āĀ] [ENormedAddMonoid őĶ‚āĀ] [TopologicalSpace őĶ‚āā] [ENormedAddMonoid őĶ‚āā]
  {T : (őĪ ‚Üí őĶ‚āĀ) ‚Üí (őĪ' ‚Üí őĶ‚āā)}
  {p q : ‚ĄĚ‚Č•0‚ąě} {őľ : Measure őĪ} {őĹ : Measure őĪ'} {c : ‚ĄĚ‚Č•0‚ąě} :
    HasStrongType T p q őľ őĹ c ‚ÜĒ HasLorentzType T p p q q őľ őĹ c := by
  unfold HasStrongType HasLorentzType
  constructor
  ¬∑ intro h f hf
    unfold MemLp MemLorentz at *
    rw [eLorentzNorm_eq_eLpNorm hf.1] at *
    have := h f hf
    rwa [eLorentzNorm_eq_eLpNorm this.1]
  ¬∑ intro h f hf
    unfold MemLp MemLorentz at *
    rw [‚Üź eLorentzNorm_eq_eLpNorm hf.1] at *
    have := h f hf
    rwa [‚Üź eLorentzNorm_eq_eLpNorm this.1]

/-
-- TODO: find better name
lemma HasLorentzType_p_infty_qs {T : (őĪ ‚Üí őĶ‚āĀ) ‚Üí (őĪ' ‚Üí őĶ‚āā)} {p q s : ‚ĄĚ‚Č•0‚ąě}
  {őľ : Measure őĪ} {őĹ : Measure őĪ'} {c : ‚ĄĚ‚Č•0‚ąě} (h : 0 < c) (hT : AEStronglyMeasurable (T f) őĹ) :
  HasLorentzType T p ‚ąě q s őľ őĹ c := by
  intro f hf
-/

--TODO: what exactly should be the requirements on ūĚēā? Actually, we only need a 1 here.
--TODO: This could be more general, it currently assumes T f ‚Č• 0
variable {ő≤ : Type*} [Zero ő≤] [One ő≤] --[NormedField ūĚēā] --[ENormedAddMonoid ūĚēā] [Field ūĚēā] --[TopologicalSpace ūĚēā]
  --[TopologicalSpace ūĚēā] [ContinuousENorm ūĚēā] [NormedField ūĚēā]
  --[TopologicalSpace ūĚēā] [ENormedAddMonoid ūĚēā] --TODO: Actually, these last arguments should probably be infered

/-- Defines when an operator "has restricted weak type". This is an even weaker version
of `HasBoundedWeakType`. -/
def HasRestrictedWeakType (T : (őĪ ‚Üí ő≤) ‚Üí (őĪ' ‚Üí őĶ‚āā)) (p p' : ‚ĄĚ‚Č•0‚ąě)
  (őľ : Measure őĪ) (őĹ : Measure őĪ')
    (c : ‚ĄĚ‚Č•0‚ąě) : Prop :=
  ‚ąÄ (F : Set őĪ) (G : Set őĪ'), (MeasurableSet F) ‚Üí (őľ F < ‚ąě) ‚Üí (MeasurableSet G) ‚Üí (őĹ G < ‚ąě) ‚Üí
    AEStronglyMeasurable (T (F.indicator (fun _ ‚Ü¶ 1))) őĹ ‚ąß
      eLpNorm (T (F.indicator (fun _ ‚Ü¶ 1))) 1 (őĹ.restrict G)
        ‚Č§ c * (őľ F) ^ p‚ĀĽ¬Ļ.toReal * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal

lemma HasRestrictedWeakType.without_finiteness {őĶ‚āā} [TopologicalSpace őĶ‚āā] [ENormedAddMonoid őĶ‚āā]
    {T : (őĪ ‚Üí ő≤) ‚Üí (őĪ' ‚Üí őĶ‚āā)} {p p' : ‚ĄĚ‚Č•0‚ąě}
    (p_ne_zero : p ‚Č† 0) (p_ne_top : p ‚Č† ‚ä§) (p'_ne_zero : p' ‚Č† 0) (p'_ne_top : p' ‚Č† ‚ä§)
    {őľ : Measure őĪ} {őĹ : Measure őĪ'} {c : ‚ĄĚ‚Č•0} (c_pos : 0 < c) (hT : HasRestrictedWeakType T p p' őľ őĹ c)
    : --(h_zero : ‚ąÄ {f : őĪ ‚Üí ő≤}, ) :
  ‚ąÄ (F : Set őĪ) (G : Set őĪ'), (MeasurableSet F) ‚Üí (MeasurableSet G) ‚Üí
    eLpNorm (T (F.indicator (fun _ ‚Ü¶ 1))) 1 (őĹ.restrict G)
      ‚Č§ c * (őľ F) ^ p‚ĀĽ¬Ļ.toReal * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal := by
  intro F G hF hG
  have p_inv_pos : 0 < p‚ĀĽ¬Ļ.toReal := by
    simp only [ENNReal.toReal_inv, inv_pos, ENNReal.toReal_pos p_ne_zero p_ne_top]
  have p'_inv_pos : 0 < p'‚ĀĽ¬Ļ.toReal := by
    simp only [ENNReal.toReal_inv, inv_pos, ENNReal.toReal_pos p'_ne_zero p'_ne_top]
  by_cases hFG : őľ F < ‚ąě ‚ąß őĹ G < ‚ąě
  ¬∑ exact (hT F G hF hFG.1 hG hFG.2).2
  ¬∑ rw [not_and_or] at hFG
    rcases hFG with hF | hG
    ¬∑ by_cases G_zero : őĹ G = 0
      ¬∑ rw [G_zero, ENNReal.zero_rpow_of_pos p'_inv_pos]
        simp only [ENNReal.toReal_inv, mul_zero, nonpos_iff_eq_zero]
        convert eLpNorm_measure_zero
        simpa
      simp only [not_lt, top_le_iff] at hF
      rw [hF]
      convert le_top
      rw [ENNReal.mul_eq_top]
      right
      constructor
      ¬∑ rw [ENNReal.top_rpow_of_pos p_inv_pos, ENNReal.mul_top (by simp [c_pos.ne'])]
      simp only [ENNReal.toReal_inv, ne_eq, ENNReal.rpow_eq_zero_iff, inv_pos, inv_neg'', not_or,
        not_and, not_lt, ENNReal.toReal_nonneg, implies_true, and_true]
      intro h
      exfalso
      exact G_zero h
    ¬∑ by_cases F_zero : őľ F = 0
      ¬∑ rw [F_zero, ENNReal.zero_rpow_of_pos p_inv_pos]
        simp only [mul_zero, ENNReal.toReal_inv, zero_mul, nonpos_iff_eq_zero]
        apply eLpNorm_eq_zero_of_ae_zero
        sorry --TODO: need additional assumption for this!
      simp only [not_lt, top_le_iff] at hG
      rw [hG]
      convert le_top
      rw [ENNReal.mul_eq_top]
      left
      constructor
      ¬∑ simp only [ENNReal.toReal_inv, ne_eq, mul_eq_zero, ENNReal.rpow_eq_zero_iff, inv_pos,
          inv_neg'', not_or, not_and, not_lt, ENNReal.toReal_nonneg, implies_true, and_true]
        use (by simp [c_pos.ne'])
        intro h
        exfalso
        exact F_zero h
      rw [ENNReal.top_rpow_of_pos p'_inv_pos]


--TODO: Could probably weaken assumption to (h : ‚ąÄŠ∂† (x : ő≤) in f, u x ‚Č§ v x)
theorem Filter.mono_limsup {őĪ : Type*} {ő≤ : Type*} [CompleteLattice őĪ] {f : Filter ő≤}
    {u v : ő≤ ‚Üí őĪ} (h : ‚ąÄ (x : ő≤), u x ‚Č§ v x) : Filter.limsup u f ‚Č§ Filter.limsup v f := by
  refine Filter.limsup_le_limsup ?_
  apply Filter.Eventually.of_forall h

--TODO: move?
theorem Filter.limsup_le_of_le' {őĪ : Type*} {ő≤ : Type*} [CompleteLattice őĪ] {f : Filter ő≤}
    {u : ő≤ ‚Üí őĪ} {a : őĪ} (h : ‚ąÄŠ∂† (n : ő≤) in f, u n ‚Č§ a) :
  Filter.limsup u f ‚Č§ a := sInf_le h

--TODO: move?
theorem ENNReal.rpow_add_rpow_le_add' {p : ‚ĄĚ} (a b : ‚ĄĚ‚Č•0‚ąě) (hp1 : 1 ‚Č§ p) :
    a ^ p + b ^ p ‚Č§ (a + b) ^ p := by
  calc
    _ = ((a ^ p + b ^ p) ^ (1 / p)) ^ p := by
      rw [one_div, ENNReal.rpow_inv_rpow]
      linarith
    _ ‚Č§ (a + b) ^ p := by
      gcongr
      apply ENNReal.rpow_add_rpow_le_add _ _ hp1



