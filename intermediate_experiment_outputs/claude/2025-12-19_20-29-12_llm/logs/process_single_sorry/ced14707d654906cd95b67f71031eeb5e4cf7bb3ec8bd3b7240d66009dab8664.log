theorem HasRestrictedWeakType.hasLorentzType_helper [TopologicalSpace őĶ'] [ENormedSpace őĶ']
  {p p' : ‚ĄĚ‚Č•0‚ąě} {őľ : Measure őĪ} {őĹ : Measure őĪ'} {c : ‚ĄĚ‚Č•0} (c_pos : 0 < c) {T : (őĪ ‚Üí ‚ĄĚ‚Č•0) ‚Üí őĪ' ‚Üí őĶ'}
  (hT : HasRestrictedWeakType T p p' őľ őĹ c) --(T_zero : eLpNorm (T 0) 1 őĹ = 0)
  (hpp' : p.HolderConjugate p')
  (weakly_cont_T : WeaklyContinuous T p őľ őĹ)
  {G : Set őĪ'} (hG : MeasurableSet G) (hG' : őĹ G < ‚ä§)
  (T_subadditive : ‚ąÄ (f g : őĪ ‚Üí ‚ĄĚ‚Č•0), (MemLorentz f p 1 őľ) ‚Üí (MemLorentz g p 1 őľ) ‚Üí
    eLpNorm (T (f + g)) 1 (őĹ.restrict G) ‚Č§ eLpNorm (T f) 1 (őĹ.restrict G) + eLpNorm (T g) 1 (őĹ.restrict G))
  (T_submult : ‚ąÄ (f : őĪ ‚Üí ‚ĄĚ‚Č•0) (a : ‚ĄĚ‚Č•0), eLpNorm (T (a ‚ÄĘ f)) 1 (őĹ.restrict G) ‚Č§ eLpNorm (a ‚ÄĘ T f) 1 (őĹ.restrict G))
  {f : őĪ ‚Üí ‚ĄĚ‚Č•0} (hf : Measurable f) (hf' : MemLorentz f p 1 őľ) :
      eLpNorm (T f) 1 (őĹ.restrict G) ‚Č§ (c / p) * eLorentzNorm f p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
  by_cases p_ne_top : p = ‚ąě
  ¬∑ sorry --TODO: check whether this works or whether it should be excluded
  by_cases p'_ne_top : p' = ‚ąě
  ¬∑ sorry --TODO: check whether this works or whether it should be excluded
  have hp : 1 ‚Č§ p := hpp'.one_le --use: should follow from hpp'
  have p_ne_zero : p ‚Č† 0 := hpp'.ne_zero --TODO: easy
  rw [eLorentzNorm_eq_eLorentzNorm' p_ne_zero p_ne_top] --TODO: assumptions on p
  revert f
  apply @Measurable.nnreal_induction _ m0
  ¬∑ intro f
    induction f using SimpleFunc.induction''
    ¬∑ rename_i a s hs
      /-
      by_cases a_ne_top : a = ‚ä§
      ¬∑ sorry --TODO: add new lemma what eLorentzNorm does with indicator functions; could also be used for the other part
        --alternative: use that f is bounded in the eLorentzNorm
      -/
      simp only [SimpleFunc.const_zero, SimpleFunc.coe_piecewise, SimpleFunc.coe_const,
        SimpleFunc.coe_zero, Set.piecewise_eq_indicator]
      have : s.indicator (Function.const őĪ a) = a ‚ÄĘ (s.indicator (fun _ ‚Ü¶ 1)) := by
        ext x
        simp only [Pi.smul_apply, smul_eq_mul]
        rw [‚Üź Set.indicator_const_mul]
        congr
        simp
      intro hf'
      calc _
        _ = eLpNorm (T (a ‚ÄĘ (s.indicator (fun _ ‚Ü¶ 1)))) 1 (őĹ.restrict G) := by
          congr 1
          ext x
          congr
        _ ‚Č§ ‚ÄĖa‚ÄĖ‚āĎ * eLpNorm (T ((s.indicator (fun _ ‚Ü¶ 1)))) 1 (őĹ.restrict G) := by
          rw [‚Üź eLpNorm_const_smul']
          --apply eLpNorm_mono_enorm_ae
          apply T_submult
        _ ‚Č§ ‚ÄĖa‚ÄĖ‚āĎ * (c * (őľ s) ^ p‚ĀĽ¬Ļ.toReal * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal) := by
          gcongr
          apply hT.without_finiteness p_ne_zero p_ne_top hpp'.symm.ne_zero p'_ne_top c_pos s G hs hG
        _ = c * (‚ÄĖa‚ÄĖ‚āĎ * őľ s ^ p‚ĀĽ¬Ļ.toReal) * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal := by ring
        _ = (c / p) * eLorentzNorm' (s.indicator (Function.const őĪ a)) p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
          rw [eLorentzNorm'_indicator (by simp) p_ne_zero p_ne_top]
          rw [‚Üź mul_assoc (c / p), ENNReal.div_mul_cancel p_ne_zero p_ne_top]
    ¬∑ rename_i f a s hs hfs hf hg
      /-
      by_cases a_ne_top : a = ‚ä§
      ¬∑ sorry --TODO: add new lemma what eLorentzNorm does with indicator functions; could also be used for the other part
      --have hf' : MemLorentz f p 1 őľ := by sorry --TODO: get this from hfg' and measurability of f and g
      --have hg' : MemLorentz g p 1 őľ := by sorry
      -/
      rw [SimpleFunc.coe_add]
      set g := SimpleFunc.piecewise s hs (SimpleFunc.const őĪ a) (SimpleFunc.const őĪ 0) with g_def
      intro hfg'
      have hf' : MemLorentz f p 1 őľ := by sorry --TODO: get this from hfg' and measurability of f and g
      have hg' : MemLorentz g p 1 őľ := by sorry --TODO: use that g is an indicator function with finite value
      calc _
        _ ‚Č§ eLpNorm (T f) 1 (őĹ.restrict G) + eLpNorm (T g) 1 (őĹ.restrict G) := by
          apply T_subadditive f g hf' hg'
        _ ‚Č§ c / p * eLorentzNorm' f p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal + c / p *  eLorentzNorm' g p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
          gcongr
          ¬∑ exact hf hf'
          ¬∑ exact hg hg'
        _ = c / p * eLorentzNorm' (f + g) p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
          rw [‚Üź add_mul, ‚Üź mul_add]
          congr
          rw [eLorentzNorm'_eq_integral_distribution_rpow,
            eLorentzNorm'_eq_integral_distribution_rpow, eLorentzNorm'_eq_integral_distribution_rpow]
          rw [‚Üź mul_add] --TODO: measurability --‚Üź lintegral_add_left sorry
          congr 1
          rw [SimpleFunc.coe_add, g_def]
          simp only [SimpleFunc.const_zero, SimpleFunc.coe_piecewise,
            SimpleFunc.coe_const, SimpleFunc.coe_zero, Set.piecewise_eq_indicator]
          symm
          calc _
            _ = ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), (if t < a then őľ s else distribution f (t - a) őľ) ^ p.toReal‚ĀĽ¬Ļ := by
              congr with t
              rw [distribution_indicator_add_of_support_subset_nnreal (őľ := őľ) hfs]
              simp only [ENNReal.coe_lt_coe]
            _ = ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), if t < a then őľ s ^ p.toReal‚ĀĽ¬Ļ else distribution f (t - a) őľ ^ p.toReal‚ĀĽ¬Ļ := by
              simp only [ite_pow]
            _ = ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), (Set.Iio a).indicator (fun _ ‚Ü¶ őľ s ^ p.toReal‚ĀĽ¬Ļ) t
                  + (Set.Ici a).indicator (fun t ‚Ü¶ distribution f (t - a) őľ ^ p.toReal‚ĀĽ¬Ļ) t := by
              congr with t
              rw [‚Üź Set.compl_Iio, ‚Üź Pi.add_apply, Set.indicator_add_compl_eq_piecewise]
              unfold Set.piecewise
              simp
            _ = a * őľ s ^ p.toReal‚ĀĽ¬Ļ + ‚ąę‚ĀĽ (t : ‚ĄĚ‚Č•0), distribution f t őľ ^ p.toReal‚ĀĽ¬Ļ := by
              rw [lintegral_add_left (by measurability)]
              congr 1
              ¬∑ rw [lintegral_indicator_const measurableSet_Iio, NNReal.volume_Iio, mul_comm]
              ¬∑ rw [lintegral_indicator measurableSet_Ici, setLIntegral_Ici]
                simp
          rw [add_comm]
          congr
          apply (ENNReal.mul_right_inj p_ne_zero p_ne_top).mp
          rw [‚Üź eLorentzNorm'_eq_integral_distribution_rpow, eLorentzNorm'_indicator (by simp) p_ne_zero p_ne_top]
          simp
  ¬∑ intro f hf h hf'
    rw [‚Üź SimpleFunc.iSup_nnapprox hf] at hf'
    --have
    calc _
      _ ‚Č§ Filter.limsup (fun n ‚Ü¶ eLpNorm (T (SimpleFunc.nnapprox f n)) 1 (őĹ.restrict G)) Filter.atTop := by
        nth_rw 1 [‚Üź SimpleFunc.iSup_nnapprox hf]
        apply weakly_cont_T SimpleFunc.monotone_nnapprox hf' G
      _ ‚Č§ Filter.limsup (fun n ‚Ü¶ (c / p) * eLorentzNorm' (SimpleFunc.nnapprox f n) p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal) Filter.atTop := by
        apply Filter.mono_limsup
        intro n
        apply h n _
        sorry --use : all of these functions are bounded (by a constant / by f and this is MemLorentz)
      _ ‚Č§ (c / p) * eLorentzNorm' f p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
        simp_rw [mul_assoc]
        rw [ENNReal.limsup_const_mul_of_ne_top (ENNReal.div_ne_top (by simp) p_ne_zero)]
        gcongr
        --simp_rw [mul_comm]
        rw [ENNReal.limsup_mul_const_of_ne_top (ENNReal.rpow_ne_top_of_nonneg (by simp) hG'.ne)]
        gcongr
        apply Filter.limsup_le_of_le'
        apply Filter.Eventually.of_forall
        intro n
        apply eLorentzNorm'_mono
        apply Filter.Eventually.of_forall
        simp only [enorm_NNReal, ENNReal.coe_le_coe]
        intro x
        exact SimpleFunc.approx_le hf bot_eq_zero'
    /-
    intro fs monotone_fs hfs hf
    set f := (fun x ‚Ü¶ ‚®Ü n, (fs n) x)
    calc _
      _ ‚Č§ Filter.limsup (fun n ‚Ü¶ eLpNorm (T (fs n)) 1 (őĹ.restrict G)) Filter.atTop := by
        apply weakly_cont_T monotone_fs hf
      _ ‚Č§ Filter.limsup (fun n ‚Ü¶ (c / p) * eLorentzNorm' (fs n) p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal) Filter.atTop := by
        apply Filter.mono_limsup
        intro n
        apply hfs n _
        sorry --use : every (fs n) is bounded by f and this is MemLorentz
      _ ‚Č§ (c / p) * eLorentzNorm' f p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
        simp_rw [mul_assoc]
        rw [ENNReal.limsup_const_mul_of_ne_top sorry] --use : c_ne_top
        gcongr
        --simp_rw [mul_comm]
        rw [ENNReal.limsup_mul_const_of_ne_top (ENNReal.rpow_ne_top_of_nonneg (by simp) hG'.ne)]
        gcongr
        sorry --use: monotonicity of fs / def. of f
    -/

theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‚ÄĖ(RCLike.I : K)‚ÄĖ = if RCLike.I ‚Č† (0 : K) then 1 else 0 := by
  split_ifs with h
  ¬∑ apply RCLike.norm_I_of_ne_zero h
  ¬∑ push_neg at h
    simpa

lemma HasRestrictedWeakType.hasLorentzType [TopologicalSpace őĪ] {ūĚēā : Type*} /- [MeasurableSpace őĶ'] [BorelSpace őĶ'] -/
  --[ENormedAddMonoid őĶ']
  [RCLike ūĚēā] [TopologicalSpace őĶ'] [ENormedSpace őĶ']
  {T : (őĪ ‚Üí ūĚēā) ‚Üí (őĪ' ‚Üí őĶ')} {p p' : ‚ĄĚ‚Č•0‚ąě}
  {őľ : Measure őĪ} [IsLocallyFiniteMeasure őľ] {őĹ : Measure őĪ'} {c : ‚ĄĚ‚Č•0} (c_pos : 0 < c)
  (hT : HasRestrictedWeakType T p p' őľ őĹ c) (hpp' : p.HolderConjugate p')
  (T_meas : ‚ąÄ {f : őĪ ‚Üí ūĚēā}, (MemLorentz f p 1 őľ) ‚Üí AEStronglyMeasurable (T f) őĹ)
  (T_subadd : ‚ąÄ (f g : őĪ ‚Üí ūĚēā) (x : őĪ'), (MemLorentz f p 1 őľ) ‚Üí (MemLorentz g p 1 őľ) ‚Üí
    --‚ÄĖT (f + g) x‚ÄĖ‚āĎ ‚Č§ ‚ÄĖT f x‚ÄĖ‚āĎ + ‚ÄĖT g x‚ÄĖ‚āĎ)
    ‚ÄĖT (f + g) x‚ÄĖ‚āĎ ‚Č§ ‚ÄĖT f x + T g x‚ÄĖ‚āĎ)
  (T_submul : ‚ąÄ (a : ūĚēā) (f : őĪ ‚Üí ūĚēā) (x : őĪ'), ‚ÄĖT (a ‚ÄĘ f) x‚ÄĖ‚āĎ ‚Č§ ‚ÄĖa‚ÄĖ‚āĎ ‚ÄĘ ‚ÄĖT f x‚ÄĖ‚āĎ)
  (weakly_cont_T : ‚ąÄ {f : őĪ ‚Üí ūĚēā} {fs : ‚Ąē ‚Üí őĪ ‚Üí ūĚēā}
                     (f_locInt : LocallyIntegrable f őľ)
                     (hF_meas : ‚ąÄ (n : ‚Ąē), AEStronglyMeasurable (fs n) őľ)
                     (h_norm_monotone : ‚ąÄ (a : őĪ), Monotone (fun n ‚Ü¶ ‚ÄĖfs n a‚ÄĖ))
                     (h_lim : ‚ąÄ (a : őĪ), Filter.Tendsto (fun (n : ‚Ąē) => fs n a) Filter.atTop (nhds (f a)))
                     (G : Set őĪ'),
    eLpNorm (T f) 1 (őĹ.restrict G) ‚Č§ Filter.limsup (fun n ‚Ü¶ eLpNorm (T (fs n)) 1 (őĹ.restrict G)) Filter.atTop)

    :

  --(weakly_cont_T : WeaklyContinuous T őľ őĹ) : --TODO: correct assumption with modified T
    --TODO: might have to adjust the constant
    HasLorentzType T p 1 p ‚ąě őľ őĹ (4 * c / p) := by
  intro f hf
  --have hp : 1 ‚Č§ p := by sorry --use: should follow from hpp'
  have claim : ‚ąÄ (G : Set őĪ'), (MeasurableSet G) ‚Üí (őĹ G < ‚ąě) ‚Üí eLpNorm (T f) 1 (őĹ.restrict G)
    ‚Č§ (4 * c / p) * eLorentzNorm f p 1 őľ * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal := by
      intro G measurable_G G_finite
      rcases hf with ‚ü®aemeasurable_f, hf‚ü©
      revert f --TODO: go on here
      apply AEStronglyMeasurable.induction
      ¬∑ intro f g stronglyMeasurable_f hfg hf hg
        have : eLorentzNorm f p 1 őľ < ‚ä§ := by
          sorry --use: hg
        have hf := hf this
        sorry --use: hf
      intro g stronglyMeasurable_g hg

      --TODO: decompose g into 4 nonnegative parts with constant coefficients
      set g‚āĀ := fun x ‚Ü¶ Real.toNNReal (RCLike.re (g x))
      set g‚āā := fun x ‚Ü¶ Real.toNNReal (- RCLike.re (g x))
      set g‚āÉ := fun x ‚Ü¶ Real.toNNReal (RCLike.im (g x))
      set g‚āĄ := fun x ‚Ü¶ Real.toNNReal (- RCLike.im (g x))
      have g_decomposition : g = (1 : ūĚēā) ‚ÄĘ (algebraMap ‚ĄĚ ūĚēā ‚ąė NNReal.toReal ‚ąė g‚āĀ)
                                + (-1 : ūĚēā) ‚ÄĘ (algebraMap ‚ĄĚ ūĚēā ‚ąė NNReal.toReal ‚ąė g‚āā)
                                + (RCLike.I : ūĚēā) ‚ÄĘ (algebraMap ‚ĄĚ ūĚēā ‚ąė NNReal.toReal ‚ąė g‚āÉ)
                                + (-RCLike.I : ūĚēā) ‚ÄĘ (algebraMap ‚ĄĚ ūĚēā ‚ąė NNReal.toReal ‚ąė g‚āĄ) := by
        unfold g‚āĀ g‚āā g‚āÉ g‚āĄ
        ext x
        simp only [one_smul, neg_smul, Pi.add_apply, Function.comp_apply, Real.coe_toNNReal',
          Pi.neg_apply, Pi.smul_apply, smul_eq_mul]
        ring_nf
        rw [algebraMap]
        sorry --TODO: simple algebra
      set T' := T ‚ąė (fun f ‚Ü¶ (@RCLike.ofReal ūĚēā _) ‚ąė NNReal.toReal ‚ąė f)
      --TODO: use properties for T to get those for T'
      have hT' : HasRestrictedWeakType T' p p' őľ őĹ c := sorry
      have weaklyCont_T' : WeaklyContinuous T' p őľ őĹ := by
        unfold WeaklyContinuous T'
        intro fs hfs f hf G
        simp only [Function.comp_apply]
        apply weakly_cont_T
        ¬∑ --TODO: get this from (hf : MemLorentz f p 1 őľ)
          --TODO: add lemmas for locallyIntegrable
          --unfold LocallyIntegrable IntegrableAtFilter IntegrableOn

          --have : LocallyIntegrable f őľ :=
          --apply (hf.memLp _).locallyIntegrable
          sorry
        ¬∑ --apply Filter.Eventually.of_forall
          intro n
          apply Measurable.aestronglyMeasurable
          apply RCLike.measurable_ofReal.comp
          apply measurable_coe_nnreal_real.comp (SimpleFunc.measurable (fs n))
        ¬∑ intro x
          simp only [Function.comp_apply, norm_algebraMap', Real.norm_eq_abs, NNReal.abs_eq]
          exact fun ‚¶Éa b‚¶Ą a_1 ‚Ü¶ hfs a_1 x
        ¬∑ --apply Filter.Eventually.of_forall
          intro x
          --apply Filter.Tendsto.algebraMap
          --apply Filter.Tendsto.comp _
          --apply Filter.Tendsto.comp _
          sorry --TODO: use that f is the supremum; maybe need to add a condition implying that
          -- the (fs n) are really converging to f


      have T'_subadd : ‚ąÄ (f g : őĪ ‚Üí ‚ĄĚ‚Č•0),
        MemLorentz f p 1 őľ ‚Üí
          MemLorentz g p 1 őľ ‚Üí
            eLpNorm (T' (f + g)) 1 (őĹ.restrict G)
              ‚Č§ eLpNorm (T' f) 1 (őĹ.restrict G) + eLpNorm (T' g) 1 (őĹ.restrict G) := by
        intro f g hf hg
        unfold T'
        simp only [Function.comp_apply]
        have hf' : MemLorentz ((@RCLike.ofReal ūĚēā _) ‚ąė NNReal.toReal ‚ąė f) p 1 őľ := by
          constructor
          ¬∑ apply RCLike.measurable_ofReal.aestronglyMeasurable.comp_aemeasurable
            refine aestronglyMeasurable_iff_aemeasurable.mp ?_
            apply measurable_coe_nnreal_real.aestronglyMeasurable.comp_aemeasurable hf.1.aemeasurable
          ¬∑ sorry --TODO: get this from hf, maybe write additional lemma
        have hg' : MemLorentz ((@RCLike.ofReal ūĚēā _) ‚ąė NNReal.toReal ‚ąė g) p 1 őľ := by
          constructor
          ¬∑ apply RCLike.measurable_ofReal.aestronglyMeasurable.comp_aemeasurable
            refine aestronglyMeasurable_iff_aemeasurable.mp ?_
            apply measurable_coe_nnreal_real.aestronglyMeasurable.comp_aemeasurable hg.1.aemeasurable
          ¬∑ sorry --TODO: get this from hf, maybe write additional lemma
        apply le_trans _ (eLpNorm_add_le _ _ le_rfl)
        ¬∑ apply eLpNorm_mono_enorm
          intro x
          simp only [Pi.add_apply]
          apply le_of_eq_of_le _ (T_subadd _ _ _ hf' hg')
          congr with x
          simp
        ¬∑ apply AEStronglyMeasurable.restrict
          apply T_meas hf'
        ¬∑ apply AEStronglyMeasurable.restrict
          apply T_meas hg'
      have T'_submul : ‚ąÄ (f : őĪ ‚Üí ‚ĄĚ‚Č•0) (a : ‚ĄĚ‚Č•0), eLpNorm (T' (a ‚ÄĘ f)) 1 (őĹ.restrict G)
          ‚Č§ eLpNorm (a ‚ÄĘ T' f) 1 (őĹ.restrict G) := by
        intro f a
        apply eLpNorm_mono_enorm
        intro x
        unfold T'
        simp only [Function.comp_apply, Pi.smul_apply, enorm_smul_eq_smul]
        have : a ‚ÄĘ ‚ÄĖT (RCLike.ofReal ‚ąė NNReal.toReal ‚ąė f) x‚ÄĖ‚āĎ
          = ‚ÄĖa‚ÄĖ‚āĎ ‚ÄĘ ‚ÄĖT (RCLike.ofReal ‚ąė NNReal.toReal ‚ąė f) x‚ÄĖ‚āĎ := by
          congr
        rw [this]
        convert T_submul (NNReal.toReal a) _ x
        ¬∑ ext x
          simp
        congr
        simp
      have helper : ‚ąÄ {f : őĪ ‚Üí ‚ĄĚ‚Č•0} (hf : Measurable f) (hf' : MemLorentz f p 1 őľ),
          eLpNorm (T' f) 1 (őĹ.restrict G) ‚Č§ (c / p) * eLorentzNorm f p 1 őľ * őĹ G ^ p'‚ĀĽ¬Ļ.toReal := by
        intro f hf hf'
        apply HasRestrictedWeakType.hasLorentzType_helper c_pos hT' hpp' weaklyCont_T' measurable_G G_finite
          T'_subadd T'_submul hf hf'

      calc _
        _ ‚Č§ eLpNorm (enorm ‚ąė T' g‚āĀ + enorm ‚ąė T' g‚āā + enorm ‚ąė T' g‚āÉ + enorm ‚ąė T' g‚āĄ) 1 (őĹ.restrict G) := by
          have T_subadd' : ‚ąÄ (f‚āĀ f‚āā f‚āÉ f‚āĄ : őĪ ‚Üí ūĚēā) (x : őĪ'),
            (MemLorentz f‚āĀ p 1 őľ) ‚Üí (MemLorentz f‚āā p 1 őľ) ‚Üí (MemLorentz f‚āÉ p 1 őľ) ‚Üí (MemLorentz f‚āĄ p 1 őľ) ‚Üí
              ‚ÄĖT (f‚āĀ + f‚āā + f‚āÉ + f‚āĄ) x‚ÄĖ‚āĎ ‚Č§ ‚ÄĖT f‚āĀ x‚ÄĖ‚āĎ + ‚ÄĖT f‚āā x‚ÄĖ‚āĎ + ‚ÄĖT f‚āÉ x‚ÄĖ‚āĎ + ‚ÄĖT f‚āĄ x‚ÄĖ‚āĎ := by
            sorry --use: iterate T_subadd
          apply eLpNorm_mono_enorm
          intro x
          rw [g_decomposition]
          simp only [Pi.add_apply, Function.comp_apply, enorm_eq_self]
          apply (T_subadd' _ _ _ _ _ _ _ _ _).trans
          ¬∑ gcongr
            ¬∑ apply (T_submul _ _ _).trans
              unfold T'
              simp
            ¬∑ apply (T_submul _ _ _).trans
              unfold T'
              simp
            ¬∑ apply (T_submul _ _ _).trans
              rw [‚Üź ofReal_norm_eq_enorm]
              rw [RCLike.norm_I]
              unfold T'
              split_ifs <;> simp
            ¬∑ apply (T_submul _ _ _).trans
              rw [‚Üź ofReal_norm_eq_enorm, norm_neg]
              rw [RCLike.norm_I]
              unfold T'
              split_ifs <;> simp
          ¬∑ sorry --TODO: Do these later when sure that this is the right condition in T_subadd
          ¬∑ sorry
          ¬∑ sorry
          ¬∑ sorry
        _ ‚Č§ eLpNorm (T' g‚āĀ) 1 (őĹ.restrict G) + eLpNorm (T' g‚āā) 1 (őĹ.restrict G)
          + eLpNorm (T' g‚āÉ) 1 (őĹ.restrict G) + eLpNorm (T' g‚āĄ) 1 (őĹ.restrict G) := by
          apply (eLpNorm_add_le sorry sorry le_rfl).trans
          gcongr
          ¬∑ apply (eLpNorm_add_le sorry sorry le_rfl).trans
            gcongr <;> apply AEStronglyMeasurable.restrict <;> apply T_meas <;> sorry
          ¬∑ apply AEStronglyMeasurable.restrict
            apply T_meas
            sorry
