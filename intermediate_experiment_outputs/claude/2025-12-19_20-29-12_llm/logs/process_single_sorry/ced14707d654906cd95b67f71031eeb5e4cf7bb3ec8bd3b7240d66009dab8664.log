/-
def WeaklyContinuous [TopologicalSpace őĶ] (T : (őĪ ‚Üí őĶ) ‚Üí (őĪ' ‚Üí őĶ')) (őľ : Measure őĪ) (őĹ : Measure őĪ') : Prop :=
  ‚ąÄ {f : őĪ ‚Üí őĶ} {fs : ‚Ąē ‚Üí SimpleFunc őĪ őĶ}
  (hfs : ‚ąÄ (x : őĪ), Filter.Tendsto (fun (n : ‚Ąē) => (fs n) x) Filter.atTop (nhds (f x))) (G : Set őĪ'),
    eLpNorm (T f) 1 (őĹ.restrict G) ‚Č§ Filter.limsup (fun n ‚Ü¶ eLpNorm (T (fs n)) 1 (őĹ.restrict G)) Filter.atTop
-/

/-- The weak continuity assumption neede for `HasRestrictedWeakType.hasLorentzType_helper`. -/
def WeaklyContinuous [TopologicalSpace őĶ] [ENorm őĶ] [ENorm őĶ'] [SupSet őĶ] [Preorder őĶ] (T : (őĪ ‚Üí őĶ) ‚Üí (őĪ' ‚Üí őĶ')) (p : ‚ĄĚ‚Č•0‚ąě) (őľ : Measure őĪ) (őĹ : Measure őĪ') : Prop :=
  ‚ąÄ {fs : ‚Ąē ‚Üí SimpleFunc őĪ őĶ} (_ : Monotone fs),
  let f := fun x ‚Ü¶ ‚®Ü n, (fs n) x;
  ‚ąÄ (_ : MemLorentz f p 1 őľ) (G : Set őĪ'),
    eLpNorm (T f) 1 (őĹ.restrict G) ‚Č§ Filter.limsup (fun n ‚Ü¶ eLpNorm (T ‚áĎ(fs n)) 1 (őĹ.restrict G)) Filter.atTop
