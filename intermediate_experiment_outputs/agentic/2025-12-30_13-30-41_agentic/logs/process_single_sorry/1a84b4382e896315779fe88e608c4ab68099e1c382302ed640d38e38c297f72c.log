    have hnd : ∃ x, Doctor x ∧ ¬ Sane x := by
      by_contra h
      push_neg at h
      exact hnst (ax4.mpr h)
    have hd : ∃ x, ¬ Doctor x ∧ Sane x := by
      by_contra h
      push_neg at h
      exact hnst (ax6.mp (ax5.mpr h))
    obtain ⟨x, hx1, hx2⟩ := hnd
    obtain ⟨y, hy1, hy2⟩ := hd
