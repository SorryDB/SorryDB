    have hd : ∀ x, Doctor x → Sane x := ax4.mp hst
    have hnd : ∀ x, ¬ Doctor x → ¬ Sane x := ax5.mp (ax6.mpr hst)
    have h := hnd Tarr
    by_cases Doctor Tarr with
