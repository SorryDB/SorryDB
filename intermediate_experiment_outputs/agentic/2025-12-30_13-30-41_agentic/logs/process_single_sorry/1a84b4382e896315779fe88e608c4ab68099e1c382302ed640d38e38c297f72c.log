  (ax4 : Sane Tarr ↔ ∀ x, Doctor x → Sane x)
  (ax5 : Sane Fether ↔ ∀ x, ¬ Doctor x → ¬ (Sane x))
  (ax6 : Sane Fether ↔ Sane Tarr)
