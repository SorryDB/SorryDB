  (ax1 : ∀ x, Peculiar x ↔ (Sane x ↔ ¬ Doctor x))
  (ax2 : ∀ x, Special x ↔ ∀ y, (¬ Doctor y ↔ (Sane y ↔ Peculiar x)))
