def toCofix (self : StateCofixFinal F α) : Cofix F α :=
  have h := by
    -- to show: two bisimilar coalgebras generate the same cofix
    -- This is true, and proving it shouldn't be too hard
    rintro a b ⟨R, h_bisim, h_R⟩
    let R' : Cofix F α → Cofix F α → Prop := fun x y =>
      ∃ (s : a.σ) (t : b.σ),
          R (.inl s) (.inr t)
          ∧ x = Coalg.toCofix { a with s := s }
          ∧ y = Coalg.toCofix { b with s := t }
    apply MvQPF.Cofix.bisim R'
    · simp only [forall_exists_index, and_imp, R']
      rintro _ _ s t hR rfl rfl
      simp only [Coalg.toCofix, Cofix.dest_corec, MvQPF.liftR_map_left, MvQPF.liftR_map_right]
      let h_st := h_bisim (.inl s) (.inr t) hR
      rw [Coalg.union_dest_eq_left, Coalg.union_dest_eq_right] at h_st
      simp only [MvQPF.liftR_map_left, MvQPF.liftR_map_right] at h_st
      apply MvQPF.liftR_mono _ h_st
      rintro i u v huv
      cases i with
      | fs i => exact huv
      | fz => exact ⟨u, v, huv, rfl, rfl⟩
    · exact ⟨a.s, b.s, h_R, rfl, rfl⟩
  Quot.lift Coalg.toCofix h self
```
