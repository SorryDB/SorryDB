import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : тДЭ тЖТ тДЭ) (hтВБ : тИА x > 0, f x > 0) :
    (тИА w x y z : тДЭ, 0 < w тЖТ 0 < x тЖТ 0 < y тЖТ 0 < z тЖТ w * x = y * z тЖТ
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) тЖФ
    answer((тИА x > 0, f x = x) тИи тИА x > 0, f x = 1 / x) := by
  constructor
  ┬╖ intro h
    have hтВВ := h 1 1 1 1 (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
    have hтВГ := h 1 2 1 2 (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
    have hтВД := h 1 4 2 2 (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
    have hтВЕ : f 1 = 1 тИи f 1 = 1 := by
      field_simp at hтВВ hтВГ hтВД
      nlinarith
    cases' hтВЕ with hтВЕ hтВЕ <;> simp_all
    all_goals
      have hтВЖ : тИА x > 0, f x = x тИи f x = 1 / x := by
        intro x hx
        have hтВЗ := h x 1 (Real.sqrt x) (Real.sqrt x) hx (by norm_num) (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) (by rw [Real.mul_self_sqrt (le_of_lt hx)])
        field_simp at hтВЗ
        apply or_iff_not_imp_left.mpr
        intro hтВИ
        apply mul_left_cancelтВА (sub_ne_zero_of_ne hтВИ)
        nlinarith
      have hтВЗ : (тИА x > 0, f x = x) тИи тИА x > 0, f x = 1 / x := by
        by_contra! hтВИ
        rcases hтВИ with тЯитЯиx, hx, hтВЙтЯй, тЯиy, hy, hтВБтВАтЯйтЯй
        have hтВБтВБ := h x y (Real.sqrt (x * y)) (Real.sqrt (x * y)) hx hy (Real.sqrt_pos.mpr (mul_pos hx hy)) (Real.sqrt_pos.mpr (mul_pos hx hy)) (by rw [Real.mul_self_sqrt (le_of_lt (mul_pos hx hy))])
        field_simp at hтВБтВБ
        rw [hтВЙ, hтВБтВА] at hтВБтВБ
        nlinarith
      exact hтВЗ
  ┬╖ rintro (h | h) <;> intro w x y z hw hx hy hz hwx <;> simp_all
    <;> field_simp
    <;> ring
