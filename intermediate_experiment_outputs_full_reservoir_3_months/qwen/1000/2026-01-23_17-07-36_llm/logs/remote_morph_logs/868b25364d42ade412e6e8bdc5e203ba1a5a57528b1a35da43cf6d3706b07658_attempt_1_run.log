/-- WIP Lemma 6.15 (unloaded case only) -/
lemma PreState.pdlFormCase {ŌÄ : PreState bt} : ¬¨ őĪ.isAtomic ‚Üí (~‚ĆąőĪ‚ĆČŌÜ) ‚ąą ŌÄ.forms ‚Üí
    ‚ąÉ Xőī ‚ąą H őĪ, Xőī.1 ‚ą™ [~‚Ćą‚Ćąőī‚ĆČ‚ĆČŌÜ] ‚äÜ ŌÄ.forms := by
  intro h_nonatom h_in
  cases ŌÄ
  case fromRoot ŌÄp => 
    cases ŌÄp
    case stopLeaf h_leaf =>
      exfalso
      -- A leaf cannot contain a non-atomic box formula in its forms
      -- because leaves correspond to back-pointers which are basic sequents
      -- and basic sequents do not contain non-atomic box formulas
      have := h_nonatom
      contradiction
    case stopAtM e he =>
      exfalso
      -- This case stops at an M-step, but the formula is in forms,
      -- which should only contain non-loaded formulas from before the M-step
      -- Contradiction with the presence of a non-atomic box formula
      have := h_nonatom
      contradiction
    case edge e he ŌÄp =>
      -- By induction hypothesis on ŌÄp
      have ih := PreState.pdlFormCase ŌÄp h_nonatom h_in
      exact ih
  case fromMod e he ŌÄp =>
    -- By induction hypothesis on ŌÄp
    have ih := PreState.pdlFormCase ŌÄp h_nonatom h_in
    exact ih
