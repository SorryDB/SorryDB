theorem Params.initial.score (ε : ℝ) (hε : ε > 0) :
    ∀ᶠ n in Filter.atTop, ∃ P : Params, P.n = n ∧ P.initial.score P.L ≤ ε * n := by
  have h1 : ∀ᶠ n in Filter.atTop, n > 0 := by
    exact Filter.eventually_gt_atTop 0
  have h2 : ∀ᶠ n in Filter.atTop, ∃ M L : ℕ, M > 0 ∧ L > 0 ∧ n > L * L := by
    refine Filter.eventually_of_forall fun n => ?_
    use n + 1, n
    norm_num
    nlinarith
  have h3 : ∀ᶠ n in Filter.atTop, ∃ P : Params, P.n = n := by
    refine Filter.eventually_of_forall fun n => ?_
    obtain ⟨M, L, hM, hL, hn⟩ := h2.mp (by trivial)
    use { n := n, M := M, L := L, hL_pos := hL, hL := hn }
  have h4 : ∀ᶠ n in Filter.atTop, P.initial.waste ≤ ε * n / 3 := by
    sorry
  have h5 : ∀ᶠ n in Filter.atTop, ∑ p ∈ (n+1).primesBelow,
      (if P.initial.balance p > 0 then (P.initial.balance p : ℝ) * Real.log p
       else if p ≤ P.L then (-P.initial.balance p) * Real.log P.L
       else (-P.initial.balance p) * Real.log (n / p)) ≤ ε * n / 3 := by
    sorry
  have h6 : ∀ᶠ n in Filter.atTop, (if P.initial.total_imbalance > 0 then Real.log n else 0) ≤ ε * n / 3 := by
    refine Filter.eventually_of_forall fun n => ?_
    by_cases h : P.initial.total_imbalance > 0 <;> simp_all
    · have : Real.log n ≤ ε * n / 3 := by
        apply Real.log_le_sub_one_of_pos
        linarith
      linarith
    · linarith
  refine Filter.eventually_of_forall fun n => ?_
  obtain ⟨P, rfl⟩ := h3.mp (by trivial)
  have hwaste := h4.mp (by trivial)
  have hsum := h5.mp (by trivial)
  have hpenalty := h6.mp (by trivial)
  unfold Factorization.score
  linarith
```
