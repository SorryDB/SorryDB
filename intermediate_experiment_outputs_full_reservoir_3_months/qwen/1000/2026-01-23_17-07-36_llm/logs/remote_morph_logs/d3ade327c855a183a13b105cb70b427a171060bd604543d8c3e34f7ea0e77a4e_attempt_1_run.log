      split_ifs with h3
      · have h4 : -P.initial.balance p ≤ n / p := h1 p hp h3
        have h5 : 0 ≤ Real.log (n / p) := by
          apply Real.log_nonneg
          apply one_le_cast.mpr
          apply Nat.succ_le_of_lt
          apply Nat.div_pos
          linarith
