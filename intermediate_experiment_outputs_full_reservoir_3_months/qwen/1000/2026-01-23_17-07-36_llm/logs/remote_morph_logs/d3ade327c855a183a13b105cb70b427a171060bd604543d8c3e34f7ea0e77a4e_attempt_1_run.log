theorem Params.initial.score (ε : ℝ) (hε : ε > 0) :
    ∀ᶠ n in Filter.atTop, ∃ P : Params, P.n = n ∧ P.initial.score P.L ≤ ε * n := by
  have hM : ∃ M : ℕ, M > 0 ∧ (1 : ℝ) / M < ε / 4 := by
    obtain ⟨M, hM⟩ := exists_nat_one_div_lt (by positivity)
    exact ⟨M, Nat.pos_of_ne_zero (by rintro rfl; simp_all), by simpa using hM⟩
  obtain ⟨M, hM_pos, hM_bound⟩ := hM
  let L := M * M
  have hL_pos : L > 0 := by nlinarith
  have hL_sq : ∀ᶠ n in Filter.atTop, n > L * L := by
    apply Filter.eventually_atTop.mpr
    use L * L + 1
    intro n hn
    linarith
  have h_waste : ∀ᶠ n in Filter.atTop, (n : ℝ) * Real.log (1 - 1 / M)⁻¹ ≤ ε * n / 4 := by
    have h_log : Real.log (1 - 1 / M)⁻¹ < ε / 4 := by
      have h1 : (1 : ℝ) - 1 / M > 0 := by
        have : (M : ℝ) ≥ 1 := by exact_mod_cast Nat.succ_le_iff.mpr hM_pos
        rw [gt_iff_lt]; field_simp; rw [div_lt_one (by positivity)]; linarith
      have h2 : Real.log (1 - 1 / M)⁻¹ = -Real.log (1 - 1 / M) := by
        rw [Real.log_inv] <;> positivity
      rw [h2]
      have h3 : Real.log (1 - 1 / M) > -ε / 4 := by
        apply lt_of_sub_pos
        have : 1 - (1 - 1 / M) = 1 / M := by ring
        nlinarith [Real.log_one_sub_lt_neg (by linarith : (1 / M : ℝ) < 1)]
      linarith
    apply Filter.eventually_atTop.mpr
    use 1
    intro n _
    nlinarith
  have h_large_primes : ∀ᶠ n in Filter.atTop,
      (∑ p ∈ (n + 1).primesBelow, if p > n / L then
        max 0 (-P.initial.balance p) * Real.log (n / p) else 0) ≤ ε * n / 4 := by
    sorry
  have h_medium_primes : ∀ᶠ n in Filter.atTop,
      (∑ p ∈ (n + 1).primesBelow, if p > Real.sqrt n ∧ p ≤ n / L then
        max 0 (P.initial.balance p) * Real.log p +
        max 0 (-P.initial.balance p) * Real.log (n / p) else 0) ≤ ε * n / 4 := by
    sorry
  have h_small_primes : ∀ᶠ n in Filter.atTop,
      (∑ p ∈ (n + 1).primesBelow, if p ≤ Real.sqrt n then
        if p ≤ L then
          max 0 (-P.initial.balance p) * Real.log L
        else
          max 0 (P.initial.balance p) * Real.log p +
          max 0 (-P.initial.balance p) * Real.log (n / p)
        else 0) ≤ ε * n / 4 := by
    sorry
  filter_upwards [hL_sq, h_waste, h_large_primes, h_medium_primes, h_small_primes] with n hn h1 h2 h3 h4
  use ⟨n, M, L, hL_pos, by linarith⟩
  simp only [Factorization.score, Factorization.waste]
  split_ifs <;> nlinarith
