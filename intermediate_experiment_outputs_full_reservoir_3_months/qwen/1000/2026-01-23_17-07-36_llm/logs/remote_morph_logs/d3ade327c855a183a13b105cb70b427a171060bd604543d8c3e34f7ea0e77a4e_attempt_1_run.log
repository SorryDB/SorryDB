        rw [gt_iff_lt]
        apply sub_pos_of_lt
        rw [div_lt_one] <;> norm_num <;> linarith
      calc
        Real.log (1 - 1 / M)⁻¹ = -Real.log (1 - 1 / M) := by rw [Real.log_inv]
        _ < ε / 4 := by
          have : -Real.log (1 - 1 / M) < ε / 4 := by
            have h2 : Real.log (1 - 1 / M) > -ε / 4 := by
              apply Real.log_gt_sub_one_of_pos
              linarith
              linarith
            linarith
          exact this
    calc
      (n : ℝ) * Real.log (1 - 1 / M)⁻¹ ≤ (n : ℝ) * (ε / 4) := by gcongr
      _ = ε * n / 4 := by ring
  have h_large_primes : ∀ᶠ n in Filter.atTop,
      (∑ p ∈ (n + 1).primesBelow, if p > n / L then
        max 0 (-P.initial.balance p) * Real.log (n / p) else 0) ≤ ε * n / 4 := by
