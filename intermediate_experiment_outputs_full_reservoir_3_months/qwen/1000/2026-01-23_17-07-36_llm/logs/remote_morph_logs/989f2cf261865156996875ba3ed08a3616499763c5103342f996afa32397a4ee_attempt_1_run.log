lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h; unfold vectorSpaceToInternalTangentSpace at h
  simp only [InternalTangentSpace.lof, Submodule.Quotient.eq] at h
  have : (PreInternalTangentSpace.lof ⟨⟨1, fun t ↦ x + t 0 • v⟩, by
      refine ((dsmooth_add_left x).comp ?_).isPlot
      refine dsmooth_smul.comp (DSmooth.prod_mk ?_ dsmooth_const)
      exact (proj (𝕜 := ℝ) (0 : Fin 1)).dsmooth, by simp⟩ (.single 0 1) -
    PreInternalTangentSpace.lof ⟨⟨1, fun t ↦ x + t 0 • w⟩, by
      refine ((dsmooth_add_left x).comp ?_).isPlot
      refine dsmooth_smul.comp (DSmooth.prod_mk ?_ dsmooth_const)
      exact (proj (𝕜 := ℝ) (0 : Fin 1)).dsmooth, by simp⟩ (.single 0 1)) ∈
    Submodule.span ℝ {v : PreInternalTangentSpace x | ∃ p q : pointedPlots x,
      ∃ f : DSmoothMap (Eucl p.1.1) (Eucl q.1.1), ∃ w : Eucl p.1.1,
        v = PreInternalTangentSpace.lof p w - PreInternalTangentSpace.lof q (fderiv ℝ f 0 w)} := h
  -- In the fine diffeology, the only relations come from smooth maps between Euclidean spaces.
  -- The difference of the two generators corresponds to the plot t ↦ x + t•(v-w).
  -- If this is zero in the quotient, then v-w must be zero because the fine diffeology
  -- contains all smooth maps, so the tangent space is isomorphic to X itself.
  -- More precisely, consider the linear functional on X given by any continuous linear map φ : X → ℝ.
  -- Since X has the fine diffeology, φ is smooth, so it induces a map on tangent spaces.
  -- Applying the tangent map of φ to both sides gives φ(v) = φ(w) for all φ, hence v = w.
  have h' : ∀ (φ : X →L[ℝ] ℝ), φ v = φ w := by
    intro φ
    have hφ : DSmooth φ := by infer_instance
    let Tφ := internalTangentMap φ x
    have hTφ : Tφ (vectorSpaceToInternalTangentSpace x v) = vectorSpaceToInternalTangentSpace (φ x) (φ v) := by
      -- This would require a lemma that tangent map commutes with the canonical map,
      -- but since we don't have it, we use the definition directly.
      sorry
    have hTφ' : Tφ (vectorSpaceToInternalTangentSpace x w) = vectorSpaceToInternalTangentSpace (φ x) (φ w) := by
      sorry
    rw [h, hTφ, hTφ']
    -- Now, in ℝ, the canonical map sends r to the class of the plot t ↦ φ x + t * r,
    -- and this is injective because the only relation in ℝ is the usual one.
    -- So φ v = φ w.
    sorry
  -- By Hahn-Banach, if φ v = φ w for all continuous linear φ, then v = w.
  -- But in finite dimensions this is clear, and in general for topological vector spaces...
  -- However, we are in pure algebra: X is just a vector space with fine diffeology,
  -- which means all linear maps are smooth. So we can use algebraic dual.
  have h'' : ∀ (φ : X →ₗ[ℝ] ℝ), φ v = φ w := by
    intro φ
    -- Any linear map is smooth in the fine diffeology.
    have hφ : DSmooth φ := by
      apply DSmooth.of_linear
    -- Now repeat the above argument with algebraic dual.
    sorry
  -- In a vector space, if all linear functionals agree on v and w, then v = w.
  apply Subsingleton.elim
  apply Subtype.val_injective
  apply LinearMap.ext_iff.1
  intro φ
  apply h''
