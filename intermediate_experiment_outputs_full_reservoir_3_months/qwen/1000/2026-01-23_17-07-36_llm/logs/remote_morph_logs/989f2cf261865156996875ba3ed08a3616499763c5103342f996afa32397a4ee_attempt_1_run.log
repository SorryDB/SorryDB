/-- The canonical map from a fine diffeological vector space to its internal tangent space at a
point is injective.

Note that this isn't the case for arbitrary diffeological vector spaces, because e.g. any vector
space becomes a diffeological vector space with the coarse diffeology but internal tangent spaces
of coarse spaces are all trivial. -/
lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h; unfold vectorSpaceToInternalTangentSpace at h
  simp at h
  have h' : InternalTangentSpace.lof ⟨⟨1, fun t ↦ x + t 0 • v⟩, by
    refine ((dsmooth_add_left x).comp ?_).isPlot
    refine dsmooth_smul.comp (DSmooth.prod_mk ?_ dsmooth_const)
    exact (proj (𝕜 := ℝ) (0 : Fin 1)).dsmooth, by simp⟩ (.single 0 1) =
    InternalTangentSpace.lof ⟨⟨1, fun t ↦ x + t 0 • w⟩, by
      refine ((dsmooth_add_left x).comp ?_).isPlot
      refine dsmooth_smul.comp (DSmooth.prod_mk ?_ dsmooth_const)
      exact (proj (𝕜 := ℝ) (0 : Fin 1)).dsmooth, by simp⟩ (.single 0 1) := h
  rw [← Submodule.Quotient.eq] at h'
  simp only [Submodule.mem_span, Set.mem_setOf_eq] at h'
  obtain ⟨s, hs, hvw⟩ := h'
  -- In the fine diffeology, the only relations come from smooth reparametrizations.
  -- For linear paths t ↦ x + t•v, the derivative at 0 is v itself.
  -- Thus equality in the quotient implies v = w.
  have : v = w := by
    -- Use the universal property of the fine diffeology: plots are exactly smooth maps.
    -- The difference vector v - w must be zero because otherwise the two paths would not be related.
    -- More precisely, consider the evaluation functional on the tangent space.
    have eval : InternalTangentSpace x →ₗ[ℝ] X := by
      -- Define a linear map that sends the class of a plot p and vector u to fderiv ℝ p 0 u.
      refine LinearMap.mk₂ _ _ _ _ _ _
      · intro p u
        exact fderiv ℝ p.1.2 0 u
      · intros p u₁ u₂
        simp [fderiv_add]
      · intros p a u
        simp [fderiv_smul]
      · intros p₁ p₂ u
        -- Need to check compatibility with relations
        have : ∀ {q r : pointedPlots x} {f : DSmoothMap (Eucl q.1.1) (Eucl r.1.1)} {w},
            fderiv ℝ q.1.2 0 w - fderiv ℝ r.1.2 0 (fderiv ℝ f 0 w) = 0 := by
          intro q r f w
          have : q.1.2 = r.1.2 ∘ f := by
            -- This holds because in the relation, we have q.1.2 = r.1.2 ∘ f
            -- Actually, in our construction, the relation is generated by
            -- lof p w - lof q (fderiv f 0 w) when p.1.2 = q.1.2 ∘ f
            -- So we need to use the chain rule: fderiv (q.1.2 ∘ f) 0 w = fderiv q.1.2 0 (fderiv f 0 w)
            sorry
        sorry
      · sorry
    sorry
  exact this
