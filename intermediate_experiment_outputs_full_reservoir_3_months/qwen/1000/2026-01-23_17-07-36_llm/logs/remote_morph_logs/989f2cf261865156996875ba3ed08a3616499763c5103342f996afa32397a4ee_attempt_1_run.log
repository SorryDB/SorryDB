    InternalTangentSpace.lof ⟨⟨1, fun t ↦ x + t 0 • w⟩, by
      refine ((dsmooth_add_left x).comp ?_).isPlot
      refine dsmooth_smul.comp (DSmooth.prod_mk ?_ dsmooth_const)
      exact (proj (𝕜 := ℝ) (0 : Fin 1)).dsmooth, by simp⟩ (.single 0 1) := h
  have key : v = w := by
    let p_v : pointedPlots x := ⟨⟨1, fun t ↦ x + t 0 • v⟩, by
      refine ((dsmooth_add_left x).comp ?_).isPlot
      refine dsmooth_smul.comp (DSmooth.prod_mk ?_ dsmooth_const)
      exact (proj (𝕜 := ℝ) (0 : Fin 1)).dsmooth, by simp⟩
    let p_w : pointedPlots x := ⟨⟨1, fun t ↦ x + t 0 • w⟩, by
      refine ((dsmooth_add_left x).comp ?_).isPlot
      refine dsmooth_smul.comp (DSmooth.prod_mk ?_ dsmooth_const)
      exact (proj (𝕜 := ℝ) (0 : Fin 1)).dsmooth, by simp⟩
    have h_eq : lof p_v (.single 0 1) = lof p_w (.single 0 1) := h'
    have h_diff : lof p_v (.single 0 1) - lof p_w (.single 0 1) = 0 := by rw [h_eq]; simp
    have h_in_span : lof p_v (.single 0 1) - lof p_w (.single 0 1) ∈
        Submodule.span ℝ {v : PreInternalTangentSpace x | ∃ p q : pointedPlots x,
          ∃ f : DSmoothMap (Eucl p.1.1) (Eucl q.1.1), ∃ w : Eucl p.1.1,
            v = PreInternalTangentSpace.lof p w - PreInternalTangentSpace.lof q (fderiv ℝ f 0 w)} :=
      Submodule.Quotient.eq_zero_iff.1 h_diff
    obtain ⟨s, hs, h_finsum⟩ := Submodule.mem_span_iff_exists_finite.1 h_in_span
    -- In the fine diffeology, the only relations come from smooth reparametrizations.
    -- But the plots p_v and p_w are linear, so their derivatives at 0 are v and w respectively.
    -- If their images in the tangent space agree, then v = w.
    -- Use the universal property: define a linear map from PreInternalTangentSpace x to X
