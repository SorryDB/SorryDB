    have eval_v : eval (PreInternalTangentSpace.lof p_v (.single 0 1)) = v := by
      simp [eval, p_v, fderiv_add_const, fderiv_smul_const, fderiv_id']
    have eval_w : eval (PreInternalTangentSpace.lof p_w (.single 0 1)) = w := by
