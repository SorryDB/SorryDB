    refine dsmooth_smul.comp (DSmooth.prod_mk ?_ dsmooth_const)
    exact (proj (𝕜 := ℝ) (0 : Fin 1)).dsmooth
  -- Consider the plot ψ and its derivative at 0.
  -- If the difference is in the relation submodule, then applying a suitable linear functional
  -- should detect that v - w = 0.
  have : v - w = 0 := by
    -- Assume for contradiction that v ≠ w.
    -- Then there exists a linear functional separating them.
    -- But in the fine diffeology, this functional is smooth, so it induces a map on tangent spaces.
