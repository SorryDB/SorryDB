            simp [Multiset.Ico, Nat.sub_sub_self (div_le_self _ _)]
          calc
            (Multiset.Ico (P.n - P.n / P.M) P.n).map (·.factorization p) |>.sum
              ≤ (Multiset.Ico (P.n - P.n / P.M) P.n).card * (Nat.log p P.n + 1) := by
