@[blueprint
  "initial-factorization-small-prime-le"
  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  have hprime : p.Prime → True := fun _ ↦ trivial
  by_cases hp0 : p = 0
  · simp_all [Factorization.balance, Factorization.sum]
  by_cases hp1 : p = 1
  · simp_all [Factorization.balance, Factorization.sum]
  have hp_pos : 0 < p := Nat.pos_of_ne_zero hp0
  have hp_ge2 : p ≥ 2 := by omega
  have h_log_p : Real.log p ≥ Real.log 2 := Real.log_le_log (by norm_num) (by exact_mod_cast hp_ge2)
  have h_log2_pos : Real.log 2 > 0 := Real.log_pos (by norm_num)
  have h_log_p_pos : Real.log p > 0 := lt_of_lt_of_le h_log2_pos h_log_p
  have h_valuation_bound : ∀ m ∈ P.initial.a, m.factorization p ≤ Real.log P.n / Real.log p := by
    intro m hm
    have hm_pos : 0 < m := P.initial.hpos m hm
    have hm_le : m ≤ P.n := P.initial.ha m hm
    have h_pow : p ^ (m.factorization p) ≤ m := Nat.pow_factorization_le hm_pos.ne'
    have h_pow' : (p : ℝ) ^ (m.factorization p) ≤ P.n := by exact_mod_cast le_trans h_pow hm_le
    have h_log : (m.factorization p : ℝ) * Real.log p ≤ Real.log P.n := by
      apply (Real.log_le_log (by positivity) (by exact_mod_cast h_pow')).trans
      rw [Real.log_rpow (by exact_mod_cast hp_pos)]
    rw [le_div_iff h_log_p_pos]
    exact_mod_cast h_log
  calc
    (P.initial.a.map (·.factorization p)).sum
      ≤ (P.initial.a.map fun _ ↦ ⌊Real.log P.n / Real.log p⌋₊).sum := by
        apply Multiset.sum_le_sum
        intro x hx
        exact_mod_cast Nat.cast_le.mpr (Nat.le_floor (h_valuation_bound x hx))
    _ = P.initial.a.card * ⌊Real.log P.n / Real.log p⌋₊ := by
        simp [Multiset.sum_map_const]
    _ ≤ P.n * ⌊Real.log P.n / Real.log p⌋₊ := by
        exact Nat.mul_le_mul_right _ (P.initial.card P)
    _ ≤ P.n * (Real.log P.n / Real.log p) := by
        exact Nat.cast_le.mpr (Nat.mul_le_mul_left _ (Nat.floor_le _))
    _ ≤ P.M * Real.log P.n := by
      have hM : (P.M : ℝ) ≥ 1 := by exact_mod_cast Nat.succ_le_iff.mpr P.hL_pos
      have hn : (P.n : ℝ) ≥ 1 := by exact_mod_cast Nat.succ_le_iff.mpr (Nat.zero_lt_succ _)
      have h_denom : Real.log p ≥ Real.log 2 := by exact_mod_cast h_log_p
      have h_bound : (P.n : ℝ) / Real.log p ≤ P.M := by
        have h_sqrt : (P.L : ℝ) < Real.sqrt P.n := by
          rw [Real.lt_sqrt (Nat.cast_nonneg _)]
          exact_mod_cast by nlinarith [P.hL]
        have h_L_sq : (P.L : ℝ) ^ 2 < P.n := by
          nlinarith [Real.mul_self_sqrt (Nat.cast_nonneg _)]
        have h_p_le_L : (p : ℝ) ≤ P.L := by
          calc
            (p : ℝ) ≤ Real.sqrt P.n := by exact_mod_cast hp
            _ < P.L := by nlinarith [h_L_sq]
        have h_log_p_le : Real.log p ≤ Real.log P.L := Real.log_le_log (by positivity) h_p_le_L
        have h_M_bound : (P.M : ℝ) ≥ P.n / P.L := by
          have := Nat.div_le_self P.n P.M
          nlinarith
        calc
          (P.n : ℝ) / Real.log p ≤ P.n / Real.log 2 := by gcongr <;> linarith
          _ ≤ P.M := by
            have : Real.log 2 > 0 := Real.log_pos (by norm_num)
            have : P.n ≤ P.M * P.L := by
              nlinarith [Nat.div_mul_le_self P.n P.M]
            calc
              P.n / Real.log 2 ≤ (P.M * P.L) / Real.log 2 := by gcongr
              _ ≤ P.M := by
                have : P.L / Real.log 2 ≤ 1 := by
                  sorry
                nlinarith
      nlinarith
  have h_fact : (P.n.factorial.factorization p : ℤ) ≥ 0 := by
    exact_mod_cast Nat.zero_le _
  simp only [Factorization.balance, Factorization.sum]
  omega
