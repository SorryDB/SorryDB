@[blueprint
  "initial-factorization-small-prime-le"
  (statement := /-- A small prime $p \leq \sqrt{n}$ can be in surplus by at most $M\log n$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  have h_valuation_bound : (P.initial.a.map (·.factorization p)).sum ≤ P.M * (Real.log P.n) := by
    calc
      (P.initial.a.map (·.factorization p)).sum
        ≤ (Multiset.join (Multiset.replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n))).map (·.factorization p) |>.sum :=
          Multiset.sum_le_sum_of_subset_of_nonneg (fun _ _ ↦ Nat.zero_le _) (by
            unfold Params.initial; apply Multiset.filter_le)
      _ = P.M * (Multiset.Ico (P.n - P.n / P.M) P.n).map (·.factorization p) |>.sum :=
          by simp [Multiset.sum_join, Multiset.sum_replicate, smul_eq_mul]
      _ ≤ P.M * (P.n.factorization p) := by
          have : (Multiset.Ico (P.n - P.n / P.M) P.n).map (·.factorization p) |>.sum ≤ P.n.factorization p := by
            refine le_trans ?_ (factorial_factorization_monotone (Nat.sub_le _ _) (le_refl _))
            exact sum_le_factorial_factorization _ _
          nlinarith
      _ ≤ P.M * (Real.log P.n) := by
          have : (P.n.factorization p : ℝ) ≤ Real.log P.n := by
            exact_mod_cast Nat.factorization_le_log hp
          nlinarith
  simp only [Factorization.balance, Factorization.sum]
  nlinarith
