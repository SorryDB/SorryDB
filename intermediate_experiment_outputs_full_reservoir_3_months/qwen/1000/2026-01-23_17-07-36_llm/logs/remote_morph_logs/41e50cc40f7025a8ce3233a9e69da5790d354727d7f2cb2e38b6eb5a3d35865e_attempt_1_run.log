lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    rw [EquationOfMotion] at h_eq
    exact h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- The ODE is linear with constant coefficients; uniqueness follows from standard theory
    -- Since both x and trajectory S IC satisfy the same ODE and same initial conditions,
    -- they must be equal.
    have h1 : x 0 = IC.trajectory S 0 := by simp [h_x0, trajectory_position_at_zero]
    have h2 : ∂ₜ x 0 = ∂ₜ (IC.trajectory S) 0 := by simp [h_v0, trajectory_velocity_at_zero]
    -- Use uniqueness of solutions to second-order linear ODEs
    -- We can reduce to a first-order system and apply Picard-Lindelöf
    -- But since we're in a simple 1D case, we can use explicit energy conservation or direct computation
    -- However, given the context, we assume the standard uniqueness theorem for linear ODEs
    sorry
  exact h_sol
```
