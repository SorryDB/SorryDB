lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  -- The equation of motion is a second-order linear ODE with constant coefficients.
  -- By standard ODE uniqueness (Picard-Lindelöf), solutions are uniquely determined by initial conditions.
  -- Since both `x` and `IC.trajectory S` satisfy the same ODE and same initial conditions,
  -- they must be equal.
  apply funext
  intro t
  -- We use the fact that the space is 1-dimensional, so we can work component-wise.
  -- In Fin 1, there's only one component, so we can reduce to real-valued functions.
  have : ∀ i : Fin 1, x t i = IC.trajectory S t i := by
