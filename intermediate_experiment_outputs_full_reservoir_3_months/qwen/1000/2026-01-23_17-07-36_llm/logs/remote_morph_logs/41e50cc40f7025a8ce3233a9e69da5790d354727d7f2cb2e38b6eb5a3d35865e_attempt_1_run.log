lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  -- The equation of motion is a second-order linear ODE with constant coefficients.
  -- Its general solution is uniquely determined by initial position and velocity.
  -- Since both `x` and `IC.trajectory S` satisfy the same ODE and same initial conditions,
  -- they must be equal by uniqueness of solutions to ODEs.
  apply funext
  intro t
  -- We use the fact that the space is 1-dimensional, so we can work component-wise.
  -- Extract the scalar functions from the EuclideanSpace ℝ (Fin 1)
  let x₁ : Time → ℝ := fun t => x t 0
  let traj₁ : Time → ℝ := fun t => (IC.trajectory S t) 0
  -- Show that both satisfy the same scalar ODE: x'' + ω^2 x = 0
  have h_ode_x : ∀ t, deriv^[2] x₁ t + S.ω^2 * x₁ t = 0 := by
    intro t
    -- Use the vector equation of motion and extract component 0
    have h_vec := h_eq t
    simp only [PiLp.add_apply, PiLp.smul_apply, PiLp.zero_apply, smul_eq_mul] at h_vec
    exact h_vec 0
  have h_ode_traj : ∀ t, deriv^[2] traj₁ t + S.ω^2 * traj₁ t = 0 := by
    intro t
    -- Compute second derivative of trajectory explicitly
    have h_acc := congr_fun (trajectory_acceleration IC) t
    simp only [PiLp.add_apply, PiLp.smul_apply, PiLp.neg_apply, smul_eq_mul] at h_acc
    have h_pos := congr_fun (trajectory_eq IC) t
    simp only [PiLp.add_apply, PiLp.smul_apply, smul_eq_mul] at h_pos
    rw [← h_pos, ← h_acc]
    simp only [add_left_neg, mul_zero, zero_add]
  -- Initial conditions for scalar functions
  have h_x0₁ : x₁ 0 = IC.x₀ 0 := congr_fun h_x0 0
  have h_v0₁ : deriv x₁ 0 = IC.v₀ 0 := by
    -- Relate time derivative to scalar derivative
    have h_deriv := congr_fun h_v0 0
    simp only [Time.deriv_apply, ContinuousLinearMap.coe_fn_eq_coe, PiLp.smul_apply,
      smul_eq_mul, mul_one] at h_deriv
    exact h_deriv
  have h_traj0₁ : traj₁ 0 = IC.x₀ 0 := by
    simp [trajectory_eq, h_x0₁]
  have h_trajv0₁ : deriv traj₁ 0 = IC.v₀ 0 := by
    have h_deriv := congr_fun (trajectory_velocity IC) 0
    simp only [PiLp.add_apply, PiLp.smul_apply, smul_eq_mul, sin_zero, cos_zero, mul_zero,
      zero_add, mul_one] at h_deriv
    exact h_deriv 0
  -- Now apply uniqueness theorem for second-order linear ODEs
  -- We use the standard result that solutions to x'' + ω^2 x = 0 are unique given x(0) and x'(0)
  have h_unique : x₁ = traj₁ := by
    apply (second_order_linear_ode_unique S.ω_neq_zero).unique
    · exact h_ode_x
    · exact h_ode_traj
    · exact h_x0₁
    · exact h_traj0₁
    · exact h_v0₁
    · exact h_trajv0₁
  -- Lift back to EuclideanSpace
  ext i
  fin_cases i
  exact congr_fun h_unique 0
