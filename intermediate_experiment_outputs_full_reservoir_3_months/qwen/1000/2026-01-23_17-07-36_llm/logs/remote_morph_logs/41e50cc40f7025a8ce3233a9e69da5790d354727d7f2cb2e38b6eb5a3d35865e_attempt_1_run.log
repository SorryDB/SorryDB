lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- Use uniqueness of solutions to linear ODEs with given initial conditions
    -- Since both x and trajectory S IC satisfy the same second-order linear ODE
    -- and agree on initial position and velocity, they must be equal.
    have h1 : (IC.trajectory S) 0 = IC.x₀ := by simp
    have h2 : ∂ₜ (IC.trajectory S) 0 = IC.v₀ := by simp
    have h3 : ∀ t, ∂ₜ (∂ₜ (IC.trajectory S)) t = -S.ω^2 • (IC.trajectory S) t :=
      by simpa using trajectory_equationOfMotion IC
    -- Now use standard uniqueness theorem for linear ODEs
    -- In this simple case, we can compute the difference and show it's zero
    let y := fun t => x t - IC.trajectory S t
    have y_0 : y 0 = 0 := by simp [y, h_x0, h1]
    have y'_0 : ∂ₜ y 0 = 0 := by simp [y, h_v0, h2]
    have y'' : ∀ t, ∂ₜ (∂ₜ y) t = -S.ω^2 • y t := by
      intro t
      simp [y, h_ode t, h3 t]
      abel
    -- The only solution to y'' + ω^2 y = 0 with y(0)=0 and y'(0)=0 is y=0
    -- This follows from energy conservation or direct computation
    have energy_const : ∀ t, ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2 = 0 := by
      -- At t=0, energy is 0
      have energy_0 : ‖∂ₜ y 0‖^2 + S.ω^2 * ‖y 0‖^2 = 0 := by
        simp [y_0, y'_0]
      -- Energy is conserved for harmonic oscillator
      -- d/dt (‖y'‖^2 + ω^2‖y‖^2) = 2⟨y', y''⟩ + 2ω^2⟨y, y'⟩ = 2⟨y', -ω^2 y + ω^2 y⟩ = 0
      have energy_deriv : ∀ t, deriv (fun t => ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2) t = 0 := by
        intro t
        -- Compute derivative
        have : deriv (fun t => ‖∂ₜ y t‖^2) t = 2 * ⟪∂ₜ y t, ∂ₜ (∂ₜ y) t⟫ := by
          simp [norm_sq, inner_self_eq_norm_sq, deriv_inner]
        have : deriv (fun t => ‖y t‖^2) t = 2 * ⟪y t, ∂ₜ y t⟫ := by
          simp [norm_sq, inner_self_eq_norm_sq, deriv_inner]
        simp [*]
        rw [y'' t]
        ring
        <;> simp [inner_comm]
      -- Therefore energy is constant
      have : ∀ t, ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2 = ‖∂ₜ y 0‖^2 + S.ω^2 * ‖y 0‖^2 := by
        intro t
        apply eq_of_sub_eq_zero
        have := (eq_of_sub_eq_zero (by simpa using energy_deriv t))
        -- Actually, easier: since derivative is zero, function is constant
        have h_const : ∀ t, ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2 = ‖∂ₜ y 0‖^2 + S.ω^2 * ‖y 0‖^2 :=
          by
            intro t
            apply (const_of_deriv_zero (by intro s; simp [energy_deriv s])).symm
        exact h_const t
      simp [this, energy_0]
    have : ∀ t, y t = 0 := by
      intro t
      have : ‖y t‖^2 = 0 := by
        nlinarith [energy_const t, sq_nonneg (‖∂ₜ y t‖), sq_nonneg (S.ω)]
      simpa [norm_eq_zero] using this
    simp [y, this]
  exact h_sol
