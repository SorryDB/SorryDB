    rw [EquationOfMotion] at h_eq ⊢
    simp_all [PiLp.sub_apply, force_eq_linear, ω_sq]
    ext i
    simp only [PiLp.sub_apply, PiLp.smul_apply, smul_eq_mul]
    ring_nf
  -- Now we use that the only solution to the harmonic oscillator with zero initial data is zero.
  -- This follows from energy conservation or direct ODE uniqueness.
  have : y = fun _ => 0 := by
    -- Energy is conserved and initially zero, so always zero.
    have E := fun t => (1/2) * ‖∂ₜ y t‖^2 + (1/2) * S.ω^2 * ‖y t‖^2
    have E_0 : E 0 = 0 := by simp [E, y_0, y'_0]
    have E_const : ∀ t, E t = E 0 := by
      -- dE/dt = 0 by equation of motion
      sorry
    simp_all
  simp_all
