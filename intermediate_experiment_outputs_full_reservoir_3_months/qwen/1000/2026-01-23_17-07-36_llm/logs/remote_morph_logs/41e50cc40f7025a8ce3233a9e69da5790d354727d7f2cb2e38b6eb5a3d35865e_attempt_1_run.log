    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- Use uniqueness of solutions to linear ODEs
    -- Since both x and trajectory S IC satisfy the same second-order linear ODE
    -- with the same initial conditions, they must be equal.
    have h1 : (IC.trajectory S) 0 = IC.x₀ := by simp
    have h2 : ∂ₜ (IC.trajectory S) 0 = IC.v₀ := by simp
    have h3 : ∀ t, ∂ₜ (∂ₜ (IC.trajectory S)) t = -S.ω^2 • (IC.trajectory S) t := by
      intro t
      rw [trajectory_acceleration]
      simp [trajectory_eq]
      ext i
      simp only [PiLp.smul_apply, PiLp.neg_apply, smul_eq_mul, PiLp.cos_apply,
        PiLp.sin_apply, PiLp.add_apply, PiLp.sub_apply, PiLp.zero_apply]
      ring_nf
      rw [ω_sq]
      field_simp
      ring_nf
    -- Now use standard uniqueness theorem for linear ODEs
    -- Since we are in dimension 1, we can reduce to scalar case
    have h_scalar : ∀ t, (x t) 0 = (IC.trajectory S t) 0 := by
      have h_ode_scalar : ∀ t, deriv (deriv (fun t => (x t) 0)) t = -S.ω^2 * (x t) 0 := by
        intro t
        have h_ode_t := h_ode t
        simp only [PiLp.smul_apply, smul_eq_mul] at h_ode_t
        exact congr_arg (fun v => v 0) h_ode_t
      have h_sol_scalar : (fun t => (x t) 0) = (fun t => (IC.trajectory S t) 0) := by
        apply (Real.exists_unique_solution_of_linear_ode _ _ _ _).2
        · exact h_ode_scalar
        · simp [h_x0]
        · simp [h_v0]
        · exact ω_neq_zero S
      exact congr_fun h_sol_scalar t
    ext i
    fin_cases i
    exact h_scalar _
  exact h_sol
