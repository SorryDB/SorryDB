lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear, ω_sq] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- Use uniqueness of solutions to linear ODEs with given initial conditions
    -- Since both x and trajectory S IC satisfy the same second-order linear ODE
    -- and agree on initial position and velocity, they must be equal.
    have h1 : x 0 = IC.trajectory S 0 := by simp [h_x0]
    have h2 : ∂ₜ x 0 = ∂ₜ (IC.trajectory S) 0 := by simp [h_v0]
    -- The ODE is linear with constant coefficients, so uniqueness follows from standard theory
    -- We can use the fact that the difference satisfies the ODE with zero initial conditions
    have h_diff : ∀ t, ∂ₜ (∂ₜ (fun t => x t - IC.trajectory S t)) t = -S.ω^2 • (x t - IC.trajectory S t) := by
      intro t
      simp only [Pi.sub_apply, h_ode t, trajectory_acceleration, smul_sub]
      ring
    have h_diff_zero : (fun t => x t - IC.trajectory S t) 0 = 0 := by simp [h1]
    have h_diff_vzero : ∂ₜ (fun t => x t - IC.trajectory S t) 0 = 0 := by simp [h2]
    -- Now we need to show that the only solution with zero initial conditions is zero
    -- This follows from energy conservation or direct computation
    have h_energy : ∀ t, ‖∂ₜ (fun t => x t - IC.trajectory S t) t‖^2 + S.ω^2 * ‖(fun t => x t - IC.trajectory S t) t‖^2 = 0 := by
      -- Energy is conserved and initially zero
      have h_energy_deriv : ∀ t, deriv (fun t => ‖∂ₜ (fun t => x t - IC.trajectory S t) t‖^2 + S.ω^2 * ‖(fun t => x t - IC.trajectory S t) t‖^2) t = 0 := by
        intro t
        simp only [norm_sq_eq_inner, inner_add, inner_smul, inner_sub, h_diff t, h_diff_zero, h_diff_vzero]
        ring
      have h_energy_const : ∀ t, ‖∂ₜ (fun t => x t - IC.trajectory S t) t‖^2 + S.ω^2 * ‖(fun t => x t - IC.trajectory S t) t‖^2 =
        ‖∂ₜ (fun t => x t - IC.trajectory S t) 0‖^2 + S.ω^2 * ‖(fun t => x t - IC.trajectory S t) 0‖^2 := by
        intro t
        exact (eq_of_deriv_eq_zero h_energy_deriv).symm ▸ rfl
      simp [h_energy_const, h_diff_zero, h_diff_vzero]
    intro t
    have h_norm : ‖x t - IC.trajectory S t‖^2 = 0 := by
      have h_nonneg : 0 ≤ S.ω^2 * ‖x t - IC.trajectory S t‖^2 := by positivity
      nlinarith [h_energy t, h_nonneg]
    exact norm_eq_zero.mp (by nlinarith)
  exact h_sol
