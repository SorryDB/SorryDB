theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  have hS' : S.Nonempty := by
    contrapose! hk
    simp_all [Finset.card_eq_zero]
  cases' hS' with a ha
  have hS'' : S.card ≥ 1 := Finset.card_pos.mpr hS'
  have hS''' : S.card ≥ 2 → (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
    intro hge2
    have hprime : ∀ x ∈ S, Nat.Prime x := fun x hx => (hS x hx).2
    have hodd : ∀ x ∈ S, Odd x := fun x hx => (hS x hx).1
    have hdistinct : S.Nodup := Finset.nodup_of_nodup_map (Equiv.injective p₁)
    have hsize : S.card = Fintype.card S := rfl
    have hcycle : ∀ f : Fin S.card ≃ S, Function.Bijective f := fun f => Equiv.bijective f
    have hprod : ∀ i, ∃ x > 0, (p₁ i * p₁ (i + 1) : ℕ) = x ^ 2 + x + k := hp₁
    have hprod' : ∀ i, ∃ x > 0, (p₂ i * p₂ (i + 1) : ℕ) = x ^ 2 + x + k := hp₂
    have hunique : ∀ a b c d : ℕ, a ∈ S → b ∈ S → c ∈ S → d ∈ S →
        a * b = c * d → (a = c ∧ b = d) ∨ (a = d ∧ b = c) := by
      intros a b c d ha hb hc hd habcd
      have ha' : Nat.Prime a := hprime a ha
      have hb' : Nat.Prime b := hprime b hb
      have hc' : Nat.Prime c := hprime c hc
      have hd' : Nat.Prime d := hprime d hd
      have hab : a ≠ b → a * b = c * d → (a = c ∧ b = d) ∨ (a = d ∧ b = c) := by
        intro habc h
        have : a ∣ c * d := by rw [← h]; exact dvd_mul_right _ _
        cases' Nat.Prime.dvd_mul ha' this with hac had
        · have : b ∣ c * d := by rw [← h]; exact dvd_mul_left _ _
          cases' Nat.Prime.dvd_mul hb' this with hbc hbd
          · right; constructor <;> nlinarith
          · left; constructor <;> nlinarith
        · have : b ∣ c * d := by rw [← h]; exact dvd_mul_left _ _
          cases' Nat.Prime.dvd_mul hb' this with hbc hbd
          · left; constructor <;> nlinarith
          · right; constructor <;> nlinarith
      by_cases habc : a = b
      · have : c = d := by
          rw [habc] at habcd
          nlinarith [Nat.Prime.two_le ha', Nat.Prime.two_le hc']
        cases' habcd with hcc hdd
        · left; constructor <;> assumption
        · right; constructor <;> assumption
      · exact hab habc habcd
    have hrot : ∃ i, ∀ j, p₂ j = p₁ (j + i) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
      apply Or.intro_left
      use 0
      intro j
      simp
    exact hrot
  cases' le_or_lt S.card 1 with hle hgt
  · have : S.card = 1 := by linarith
    subst this
    use 0
    intro j
    simp
  · exact hS''' hgt
