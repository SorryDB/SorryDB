lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · use (p - 1) / 4
    intro hp
    rw [hp]
    have : Nat.Prime p := h.out
    have : p ≠ 0 := this.ne_zero
    have : p ≠ 1 := this.ne_one
    have : (4 * ((p - 1) / 4) + 1 : ℕ) = p := by omega
    clear this
    simp_all [Finset.card_eq_two]
    -- The equation x^2 = -1 in ZMod p has exactly two solutions when p ≡ 1 mod 4
    apply Eq.symm
    rw [← Nat.mod_add_div p 4]
    have : p % 4 = 1 := by omega
    rw [this]
    simp
    have : (-1 : ZMod p) ≠ 0 := by
      intro h
      have : p ∣ 1 := by simpa using h
      exact Nat.not_dvd_one (Nat.Prime.two_le h.out) this
    have : Polynomial.X ^ 2 + 1 = (Polynomial.X - (1 : ZMod p)) * (Polynomial.X + 1) → False := by
      intro h
      have : (1 : ZMod p) ^ 2 + 1 = 0 := by simpa using congr_arg (fun f => f.eval 1) h
      norm_num at this
      contradiction
    sorry
