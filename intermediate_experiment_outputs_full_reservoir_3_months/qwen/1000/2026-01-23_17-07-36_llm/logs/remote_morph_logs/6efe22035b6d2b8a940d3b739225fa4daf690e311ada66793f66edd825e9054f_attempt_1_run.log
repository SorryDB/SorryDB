lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · use (p - 1) / 4
    intro hp
    have h₁ : p ≠ 0 := Nat.Prime.ne_zero h.out
    have h₂ : p ≠ 1 := Nat.Prime.ne_one h.out
    have h₃ : p % 4 = 1 := by omega
    have h₄ : (-1 : ZMod p) ^ ((p - 1) / 2) = 1 := by
      rw [ZMod.pow_card_sub_one_eq_one]
      · simp [h₁]
      · omega
    have h₅ : ∃ x : ZMod p, x ^ 2 = -1 := by
      apply ZMod.exists_sq_eq_neg_one_of_mod_four_eq_one
      exact h₃
    have h₆ : Finset.card { s : ZMod p | s ^ 2 = -1 } = 2 := by
      obtain ⟨x, hx⟩ := h₅
      have h₇ : x ≠ -x := by
        intro h
        have h₈ : 2 * x = 0 := by simpa [h] using add_eq_zero_iff_eq_neg.mp (by simp [h])
        have h₉ : (2 : ZMod p) = 0 ∨ x = 0 := eq_zero_or_eq_zero_of_mul_eq_zero h₈
        cases' h₉ with h₉ h₉
        · have h₁₀ : p ∣ 2 := by simpa [ZMod.intCast_zmod_eq_zero_iff] using h₉
          have h₁₁ : p = 2 := Nat.Prime.eq_two_of_dvd_two h.out h₁₀
          omega
        · have h₁₂ : (-1 : ZMod p) = 0 := by simpa [hx, h₉] using hx
          have h₁₃ : p ∣ 1 := by simpa [ZMod.intCast_zmod_eq_zero_iff] using h₁₂
          exact Nat.not_dvd_one h.out h₁₃
      have h₈ : { s : ZMod p | s ^ 2 = -1 } = {x, -x} := by
        ext y
        simp only [Finset.mem_insert, Finset.mem_singleton, sq, neg_mul_neg]
        constructor
        · intro hy
          have h₉ : (y - x) * (y + x) = 0 := by simpa [hy, hx] using sub_eq_zero_of_sq_eq_sq hy hx
          have h₁₀ : y = x ∨ y = -x := by
            simpa [sub_eq_zero, add_eq_zero_iff_eq_neg] using eq_zero_or_eq_zero_of_mul_eq_zero h₉
          exact h₁₀
        · intro hy
          cases' hy with hy hy <;> simp [hy, hx]
      simp [h₈, h₇]
    exact h₆
