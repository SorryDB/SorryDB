lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · use (p - 1) / 4
    intro hp
    rw [hp]
    have h₁ : p ≠ 0 := Nat.Prime.ne_zero h.out
    have h₂ : p ≠ 1 := Nat.Prime.ne_one h.out
    have h₃ : (4 * ((p - 1) / 4) + 1 : ℕ) = p := by omega
    rw [h₃] at *
    have h₄ : (-1 : ZMod p) ≠ 0 := by
      intro h₅
      have h₆ : (p : ZMod p) = 0 := by simp
      have h₇ : (1 : ZMod p) = 0 := by simpa [h₅] using h₆
      exact absurd h₇ (one_ne_zero)
    have h₅ : (ZMod p).charP := inferInstance
    have h₆ : FiniteField (ZMod p) := inferInstance
    have h₇ : IsSquare (-1 : ZMod p) ↔ p % 4 = 1 := by
      apply FiniteField.isSquare_neg_one_iff
      exact h.out
    rw [hp] at h₇
    simp at h₇
    have h₈ : Fintype.card { s : ZMod p | s ^ 2 = -1 } = 2 := by
      have h₉ : ∃ x : ZMod p, x ^ 2 = -1 := by
        apply Exists.intro (sqrt (-1))
        simp [h₇]
      cases' h₉ with x hx
      have h₁₀ : (-x) ^ 2 = -1 := by
        rw [pow_two]
        simp [hx]
      have h₁₁ : x ≠ -x := by
        intro h₁₂
        have h₁₃ : 2 * x = 0 := by simpa [h₁₂] using add_eq_zero_iff_eq_neg.mp (Eq.refl _)
        have h₁₄ : (2 : ZMod p) = 0 ∨ x = 0 := eq_zero_or_eq_zero_of_mul_eq_zero h₁₃
        cases' h₁₄ with h₁₄ h₁₄
        · have h₁₅ : p ∣ 2 := by
            rw [← Nat.cast_eq_zero] at h₁₄
            exact mod_cast h₁₄
          have h₁₆ : p = 2 := Nat.Prime.eq_two_of_dvd_two h.out h₁₅
          rw [h₁₆] at hp
          omega
        · have h₁₅ : x = 0 := h₁₄
          rw [h₁₅] at hx
          have h₁₆ : (-1 : ZMod p) = 0 := hx
          exact absurd h₁₆ h₄
      have h₁₂ : { s : ZMod p | s ^ 2 = -1 } = {x, -x} := by
        ext y
        constructor
        · intro hy
          have h₁₃ : y ^ 2 = x ^ 2 := by simpa [hx] using hy
          have h₁₄ : y = x ∨ y = -x := by
            apply eq_or_eq_neg_of_sq_eq_sq
            exact h₁₃
          cases' h₁₄ with h₁₄ h₁₄
          · simp [h₁₄]
          · simp [h₁₄]
        · intro hy
          cases' hy with hy hy
          · rw [hy, hx]
          · rw [hy, h₁₀]
      rw [h₁₂]
      simp [h₁₁]
    exact h₈
