    have h15 : ∀ i : Fin m, m ^ (i + 1) = 0 := by
      intro i
      rw [hB i, h14 i]
    have h16 : m ^ 1 = 0 := h15 0
    norm_num at h16
    linarith
  have h12 : ∑ i : Fin m, (B i).card ≥ m := by
    have h13 : ∑ i : Fin m, m ^ (i + 1) ≥ m ^ 1 := by
      apply Finset.single_le_sum (fun i _ ↦ by positivity) 0
    calc
      ∑ i : Fin m, (B i).card
        ≥ ∑ i : Fin m, m ^ (i + 1) / (A.sup' (by aesop) fun x hx ↦ abs x) := by
          apply Finset.sum_le_sum
          intro i _
          apply Nat.div_le_of_le_mul
          nlinarith
      _ ≥ m ^ 1 / (A.sup' (by aesop) fun x hx ↦ abs x) := by
          apply Nat.div_le_div_right
          exact h13
      _ ≥ m / (A.sup' (by aesop) fun x hx ↦ abs x) := by
          simp
      _ ≥ m / m := by
          apply Nat.div_le_div_left
          linarith
          linarith
      _ = 1 := by
          field_simp
    linarith
  calc
    (m : ℚ) / 2 ≤ ↑A.card := by
      apply le_of_sub_nonneg
      field_simp
      ring_nf
      norm_cast
      omega
