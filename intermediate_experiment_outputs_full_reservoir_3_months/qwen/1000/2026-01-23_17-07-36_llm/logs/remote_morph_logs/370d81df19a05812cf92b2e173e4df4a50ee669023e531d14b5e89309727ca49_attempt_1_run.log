    exact Finset.abs_sum_le_sum_abs _
  have h7 : ∑ i : Fin m, ∑ j ∈ B i, |(j : ℤ)| ≤ ∑ i : Fin m, ∑ j ∈ B i, (A.sup' (by aesop) fun x hx ↦ abs x) := by
    apply Finset.sum_le_sum
    intro i _
    apply Finset.sum_le_sum
    intro j hj
    apply le_sup'
    exact hBA i hj
  have h8 : ∑ i : Fin m, ∑ j ∈ B i, (A.sup' (by aesop) fun x hx ↦ abs x) =
      (∑ i : Fin m, (B i).card) * (A.sup' (by aesop) fun x hx ↦ abs x) := by
    simp [Finset.mul_sum, Finset.sum_mul]
  have h9 : ∑ i : Fin m, m ^ (i + 1) = m * (m ^ m - 1) / (m - 1) := by
