import Mathlib


open scoped Finset

namespace IMO2021P6

theorem result {m : ℕ} (hm : 2 ≤ m) (A : Finset ℤ) (B : Fin m → Finset ℤ) (hBA : ∀ i, B i ⊆ A)
    (hB : ∀ k, ∑ i ∈ B k, i = m ^ ((k : ℕ) + 1)) : (m : ℚ) / 2 ≤ #A := by
  have h1 : ∑ k : Fin m, ∑ i ∈ B k, (1 : ℚ) = ∑ k : Fin m, (B k).card := by
    simp [Finset.sum_card]
  have h2 : ∑ k : Fin m, (B k).card ≥ ∑ k : Fin m, 1 := by
    apply Finset.sum_le_sum
    intro k _
    exact Nat.succ_le_iff.mpr (Finset.card_pos.mpr (by
      have h3 : ∑ i ∈ B k, i = m ^ (k + 1) := hB k
      have h4 : m ^ (k + 1) ≠ 0 := by
        exact pow_ne_zero _ (by linarith)
      contrapose! h4
      simp_all))
  simp at h2
  have h5 : ∑ k : Fin m, (B k).card ≤ m * A.card := by
    calc
      ∑ k : Fin m, (B k).card ≤ ∑ k : Fin m, A.card := by
        apply Finset.sum_le_sum
        intro k _
        exact Finset.card_le_of_subset (hBA k)
      _ = m * A.card := by simp [Finset.sum_const, nsmul_eq_mul]
  have h6 : (m : ℚ) ≤ ↑(m * A.card) := by
    exact_mod_cast Nat.cast_le.mpr (by linarith)
  have h7 : (m : ℚ) / 2 ≤ ↑A.card := by
    rw [div_le_iff] <;> norm_cast <;> nlinarith
  exact h7
