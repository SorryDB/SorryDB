    let VinterT := pullback (V ↘ Spec(k[M])) (Spec(k[G]) ↘ Spec(k[M]))
    refine ⟨AddSubgroup.closure (AddSubmonoid.closure (Set.image (Prod.map f f) s))⟩
    simp only [monoidIdeal, Set.image_image]
    rw [hsI]
    apply Ideal.eq_of_le_of_le
    · apply Ideal.span_le.mpr
      rintro _ ⟨⟨a, b⟩, h, rfl⟩
