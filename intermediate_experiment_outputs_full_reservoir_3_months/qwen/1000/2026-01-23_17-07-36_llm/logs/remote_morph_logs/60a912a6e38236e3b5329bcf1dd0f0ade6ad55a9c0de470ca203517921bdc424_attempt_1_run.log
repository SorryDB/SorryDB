lemma tutte_berge_of_maximal_vertexDelete (hX : Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X) :
    2 * ν(G - X) = (V(G) \ X).encard - (G - X).OddComponents.encard := by
  have hH : ∀ v ∈ V(G) \ X, ν(G - (X ∪ {v})) = ν(G - X) := by
    intro v hv
    have hmax := hX.maximal (by simp [hv]) (by simp [hv])
    simp [Set.encard_insert_of_not_mem hv] at hmax
    omega
  have hodd : ∀ H : Graph α β, H.IsCompOf (G - X) → Odd V(H).encard := by
    intro H hHcomp
    obtain ⟨v, hv⟩ := Set.encard_pos.mp (by simpa using hHcomp.nonempty)
    have hνeq := hH v (by simpa using hv)
    have hadd := MatchingNumber.additive_over_components (G - X) H hHcomp
    -- From hνeq and additivity, deduce that removing v from H doesn't change ν(H),
    -- which implies |V(H)| is odd.
    sorry
  have hmatch : ν(G - X) = ((V(G) \ X).encard - (G - X).OddComponents.encard) / 2 := by
    -- Each odd component contributes (|V(H)| - 1)/2 to the matching number.
    sorry
  omega
```
