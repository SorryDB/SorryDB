lemma tutte_berge_of_maximal_vertexDelete (hX : Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X) :
    2 * ν(G - X) = (V(G) \ X).encard - (G - X).OddComponents.encard := by
  have hH : ∀ v ∈ V(G) \ X, ν(G - (X ∪ {v})) = ν(G - X) := by
    intro v hv
    have hmax : ¬(ν(G - (X ∪ {v})) = ν(G) - (X ∪ {v}).encard) := hX.max (by simp [hv]) (by simp)
    rw [Set.encard_insert_of_not_mem (by simp [hv])] at hmax
    omega
  have hodd : ∀ H : Graph α β, H.IsCompOf (G - X) → Odd V(H).encard := by
    intro H hHcomp
    obtain ⟨v, hv⟩ := Set.exists_mem_of_nonempty (by simpa using hHcomp.nonempty_vertices)
    have hν : ν(H - {v}) = ν(H) := by
      rw [← Graph.MatchingNumber_subgraph_comp hHcomp, ← Graph.MatchingNumber_subgraph_comp (Graph.compOf_subgraph_erase hHcomp (by simp [hv]))]
      exact hH v (by simp [hv])
    have hfin : V(H).Finite := by
      sorry
    have hodd' : Odd V(H).encard := by
      sorry
    exact hodd'
  have heq : ν(G - X) = ((V(G) \ X).encard - (G - X).OddComponents.encard) / 2 := by
    sorry
  omega
