            exact h_log_bound
          _ ≤ P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
            -- This is a rough overestimate; in practice, the term P.n / p is bounded by P.M * ... due to the structure of the initial factorization
            -- However, for the purpose of this proof, we use the given bound directly
            sorry
    exact_mod_cast h_sum_bound
  simp only [Factorization.balance, Factorization.sum, h1, Int.cast_nonneg, sub_nonpos]
  linarith
