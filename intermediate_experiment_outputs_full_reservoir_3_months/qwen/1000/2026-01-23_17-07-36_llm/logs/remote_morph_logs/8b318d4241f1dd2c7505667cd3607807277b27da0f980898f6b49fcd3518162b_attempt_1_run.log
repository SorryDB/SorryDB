            exact Int.ofNat_le.mpr (Nat.div_le_div_left (Nat.one_le_pow (Finset.mem_Ico.mp hk).1 hp.pos) (by aesop))
          _ = (Nat.log p P.n : ℤ) * (P.n / p : ℤ) := by
            simp [Finset.sum_const, Finset.card_Ico]
          _ ≤ P.M * Real.log P.n + (P.n / p : ℤ) := by
            have h_log : (Nat.log p P.n : ℝ) ≤ Real.log P.n := by
              apply Nat.cast_log_le_log
              exact Nat.pos_of_ne_zero (by aesop)
            have h_M : (P.M : ℝ) ≥ 1 := by
