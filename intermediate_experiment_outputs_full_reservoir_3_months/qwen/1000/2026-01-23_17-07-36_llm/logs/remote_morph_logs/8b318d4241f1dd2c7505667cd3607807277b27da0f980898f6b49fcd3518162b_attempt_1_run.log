@[blueprint
  "initial-factorization-tiny-prime-ge"
  (statement := /-- A tiny prime $p \leq L$ can be in deficit by at most $M\log n + ML\pi(n)$.-/)
  (proof := /-- In addition to the Legendre calculations, one potentially removes factors of the
  form $plq$ with $l \leq L$ and $q \leq n$ a prime up to $M$ times each, with at most $L$ copies
  of $p$ removed at each factor.-/)]
theorem Params.initial.balance_tiny_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.L) :
    P.initial.balance p ≥ - P.M * (Real.log P.n) - P.M * P.L^2 * (primeCounting P.n) := by
  have h1 : (P.initial.a.map (·.factorization p)).sum ≥ 0 := by
    apply Multiset.sum_nonneg
    intro x hx
    exact Nat.cast_nonneg _
  have h2 : (P.n.factorial.factorization p : ℤ) ≤ P.n / p + P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
    have h_legendre : (P.n.factorial).factorization p = ∑ k in Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k := by
      rw [factorization_def]
      · have := Fact.mk (by aesop : p.Prime ∨ ¬p.Prime)
        cases' this with hp' hp' <;> simp_all [padicValNat_factorial]
      · aesop
    have h_bound : ∑ k in Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k ≤ P.n / p + P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
      have h_log : (Nat.log p P.n : ℝ) ≤ Real.log P.n := by
        apply Nat.cast_log_le_log
        aesop
      have h_sum : ∑ k in Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k ≤ P.n / p + ∑ k in Finset.Ico 2 (Nat.log p P.n + 1), P.n / p ^ k := by
        simp [Finset.sum_Ico_succ_top]
        linarith
      have h_tail : ∑ k in Finset.Ico 2 (Nat.log p P.n + 1), P.n / p ^ k ≤ P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
        calc
          _ ≤ ∑ k in Finset.Ico 2 (Nat.log p P.n + 1), P.n / p ^ 2 := by
            apply Finset.sum_le_sum
            intro k hk
            simp only [Finset.mem_Ico] at hk
            have hkp : k ≥ 2 := by linarith
            exact Nat.div_le_div_left (by aesop) (pow_le_pow_right (by aesop) hkp)
          _ = (Nat.log p P.n - 1) * (P.n / p ^ 2) := by
            simp [Finset.sum_const, Finset.card_Ico]
          _ ≤ (Real.log P.n) * (P.n / p ^ 2) := by
            gcongr
            all_goals norm_cast
            all_goals linarith
          _ ≤ P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
            have h_p_le_L : p ≤ P.L := hp
            have h_p_ge_2 : p ≥ 2 := by
              by_contra h
              push_neg at h
              have : p = 0 ∨ p = 1 := by omega
              cases' this with h0 h1 <;> simp_all [Nat.factorization_eq_zero_of_not_prime]
            have h_p2_ge_4 : p ^ 2 ≥ 4 := by
              calc
                p ^ 2 ≥ 2 ^ 2 := by gcongr
                _ = 4 := by norm_num
            have h_n_div_p2_le_n : P.n / p ^ 2 ≤ P.n := by
              apply Nat.div_le_self
            have h_n_le_ML2pi : P.n ≤ P.M * P.L ^ 2 * primeCounting P.n := by
              have h_pi_n_ge_1 : primeCounting P.n ≥ 1 := by
                apply Nat.succ_le_iff.mp
                apply primeCounting_pos.mpr
                have : P.n > 1 := by
                  nlinarith [P.hL, P.hL_pos]
                exact this
              have h_L2_ge_1 : P.L ^ 2 ≥ 1 := by
                apply Nat.one_le_pow
                linarith
                linarith
              have h_M_ge_1 : P.M ≥ 1 := by
                by_contra h
                push_neg at h
                have : P.M = 0 := by omega
                simp_all
              calc
                P.n ≤ P.M * P.L ^ 2 * primeCounting P.n := by
                  gcongr
            calc
              (Real.log P.n) * (P.n / p ^ 2) ≤ (Real.log P.n) * P.n := by
                gcongr
              _ ≤ (Real.log P.n) * (P.M * P.L ^ 2 * primeCounting P.n) := by
                gcongr
              _ ≤ P.M * Real.log P.n + P.M * P.L ^ 2 * primeCounting P.n := by
                have h_log_nonneg : Real.log P.n ≥ 0 := by
                  apply Real.log_nonneg
                  have : P.n ≥ 1 := by
                    nlinarith [P.hL, P.hL_pos]
                  exact_mod_cast this
                have h_ML2pi_nonneg : (P.M : ℝ) * (P.L : ℝ) ^ 2 * (primeCounting P.n : ℝ) ≥ 0 := by
                  positivity
                nlinarith
      linarith
    linarith
  simp only [Factorization.balance, Factorization.sum] at *
  linarith
