    exact Nat.cast_nonneg _
  have h2 : (P.n.factorial.factorization p : ℤ) ≤ P.n / p + P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
    have h_legendre : (P.n.factorial).factorization p = ∑ k in Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k := by
      rw [factorization_def]
      · have := Fact.mk (prime_of_dvd_factorial (by omega : p ≤ P.n) (by omega : p > 0))
        rw [padicValNat_factorial]; simp_all
      · exact prime_of_dvd_factorial (by omega : p ≤ P.n) (by omega : p > 0)
    have h_sum_bound : ∑ k in Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k ≤ P.n / p + P.M * Real.log P.n + P.M * P.L^2 * primeCounting P.n := by
      have h_log_bound : Nat.log p P.n ≤ Real.log P.n := by
        apply Nat.log_le_log
        · exact Nat.pos_of_ne_zero (by omega : p ≠ 0)
        · exact_mod_cast le_of_lt (by have : (0 : ℝ) < P.n := by exact_mod_cast (by omega : P.n > 0); linarith)
      calc
        ∑ k in Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k
          ≤ ∑ k in Finset.Ico 1 (Nat.log p P.n + 1), P.n / p := by
            apply Finset.sum_le_sum
            intro k hk
            have h_pow_ge : p ^ k ≥ p := by
              apply Nat.pow_le_pow_of_le_right
              · exact Nat.pos_of_ne_zero (by omega : p ≠ 0)
              · exact Nat.succ_le_iff.mpr (Finset.mem_Ico.mp hk).1
            exact Nat.div_le_div_left h_pow_ge (by omega)
          _ = (Nat.log p P.n) * (P.n / p) := by
            simp [Finset.sum_const, Finset.Ico.card]
          _ ≤ Real.log P.n * (P.n / p) := by
