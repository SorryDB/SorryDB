    have h1 : (P.n.factorial.factorization p : ℤ) ≤ P.n / p + P.M * Real.log P.n := by
      have h_legendre : (P.n.factorial).factorization p = ∑ k in Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k := by
        rw [padicValNat_factorial] <;> aesop
