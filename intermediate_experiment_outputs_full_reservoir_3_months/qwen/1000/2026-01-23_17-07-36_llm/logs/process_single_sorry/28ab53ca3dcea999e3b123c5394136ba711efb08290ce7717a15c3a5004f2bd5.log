theorem Category.split_epi_iff {X Y : α} (f : Hom X Y) :
    split_epi f ↔
    ∀ c : α, Function.Surjective (fun g : Hom Y c => f ≫ g) := by
  constructor
  · rintro ⟨g, hg⟩ c
    intro h
    use g ≫ h
    rw [← assoc, hg, id_comp]
  · intro H
    cases' H Y (id Y) with g hg
    use g
    exact hg
