import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have h₃ : u ∈ S := IsLeast.mem h₁
  have h₄ : v ∈ S \ {u} := IsLeast.mem h₂
  have h₅ : v ∈ S := Set.mem_of_mem_diff h₄
  have h₆ : u ≠ v := Set.ne_of_mem_diff h₄
  simp_all only [h₀, Set.mem_setOf_eq, Nat.cast_add, Nat.cast_one, Nat.cast_mul,
    Nat.cast_ofNat, Nat.cast_sub]
  norm_num
  have h₇ : 14 * u % 100 = 46 := by aesop
  have h₈ : 14 * v % 100 = 46 := by aesop
  have h₉ : ∃ k : ℕ, 14 * u = 100 * k + 46 := by
    use 14 * u / 100
    omega
  have h₁₀ : ∃ l : ℕ, 14 * v = 100 * l + 46 := by
    use 14 * v / 100
    omega
  cases' h₉ with k hk
  cases' h₁₀ with l hl
  have h₁₁ : u = (100 * k + 46) / 14 := by omega
  have h₁₂ : v = (100 * l + 46) / 14 := by omega
  have h₁₃ : 100 * k + 46 ≡ 0 [MOD 14] := by
    rw [Nat.modEq_zero_iff_dvd]
    omega
  have h₁₄ : 100 * l + 46 ≡ 0 [MOD 14] := by
    rw [Nat.modEq_zero_iff_dvd]
    omega
  norm_num at h₁₃ h₁₄
  have h₁₅ : k % 7 = 2 := by
    omega
  have h₁₆ : l % 7 = 2 := by
    omega
  have h₁₇ : k ≥ 2 := by
    omega
  have h₁₈ : l ≥ 2 := by
    omega
  have h₁₉ : u = 9 := by
    omega
  have h₂₀ : v = 119 := by
    omega
  norm_num [h₁₉, h₂₀]
