theorem findExponents_spec_satisfied (n: Nat) (primes: List Nat) (h_precond : findExponents_precond (n) (primes)) :
    findExponents_postcond (n) (primes) (findExponents (n) (primes) h_precond) h_precond := by
  unfold findExponents
  have h1 : n > 0 := h_precond.1
  have h2 : primes.length > 0 := h_precond.2.1
  have h3 : primes.all (fun p => Nat.Prime p) := h_precond.2.2.1
  have h4 : List.Nodup primes := h_precond.2.2.2
  clear h_precond
  induction primes with
  | nil => contradiction
  | cons p ps ih =>
    simp_all [List.all_cons, List.Nodup.cons]
    cases' countFactor n p 0 with e n'
    simp_all [List.foldl, Nat.pow_succ]
    constructor
    · -- First conjunct: n = product of p^e * rest
      have : n = p ^ e * n' := by
        revert n n'
        generalize hn : n = n₀
        generalize hn' : n' = n₁
        induction e with
        | zero => simp_all
        | succ e ih =>
          simp_all [Nat.pow_succ]
          omega
      rw [this]
      have := ih (by assumption)
      simp_all
    · constructor
      · -- Second conjunct: all primes in result are in input list
        simp_all
      · -- Third conjunct: every prime in input appears in result
        intro q hq
        cases' hq with rfl hq
        · simp_all
        · specialize ih hq
          simp_all
