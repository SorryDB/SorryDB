      "\n    have h1 : ∀ s ∈ Set.Icc (0 : ℝ) 1, |g'' s| ≤ n^2 * ε^2 := by\n      intro s hs\n      calc\n        |g'' s| = |∑ i, ∑ j, (y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - s) • x + s • y)| := rfl\n        _ ≤ ∑ i, ∑ j, |(y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - s) • x + s • y)| := by\n          exact (norm_sum_le _ _).trans (le_of_eq (sum_norm _ _))\n        _ = ∑ i, ∑ j, |y i - x i| * |y j - x j| * |(nth_partial i <| nth_partial j f) ((1 - s) • x + s • y)| := by\n          simp [abs_mul, abs_of_nonneg]\n        _ ≤ ∑ i, ∑ j, ε * ε * 1 := by\n          apply Finset.sum_le_sum\n          intro i _\n          apply Finset.sum_le_sum\n          intro j _\n          have hxi : |x i - y i| ≤ ε := hdiff i\n          have hxj : |x j - y j| ≤ ε := hdiff j\n          have hyi : |y i - x i| = |x i - y i| := by simp [abs_sub_comm]\n          have hyj : |y j - x j| = |x j - y j| := by simp [abs_sub_comm]\n          rw [hyi, hyj]\n          exact mul_le_mul (le_trans (by simp) hxi) (le_trans (by simp) hxj) (by norm_num) (by norm_num)\n        _ = ∑ i, ∑ j, ε^2 := by ring\n        _ = n^2 * ε^2 := by\n          simp [Finset.sum_const, Finset.card_fin, nsmul_eq_mul]\n          <;> ring\n    calc\n      ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| ≤ ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, n^2 * ε^2 := by\n        apply intervalIntegral.integral_le_integral\n        · exact Continuous.intervalIntegrable (by fun_prop) 0 1\n        · exact fun t ht => intervalIntegral.integral_le_integral\n            (Continuous.intervalIntegrable (by fun_prop) 0 t)\n            (fun s hs => le_trans (abs_nonneg _) (h1 s ⟨by linarith, by linarith⟩))\n      _ = ∫ (t : ℝ) in 0..1, t * (n^2 * ε^2) := by\n        rw [intervalIntegral.integral_const]\n        <;> simp\n      _ = n^2 * ε^2 * ∫ (t : ℝ) in 0..1, t := by\n        rw [intervalIntegral.integral_mul_left]\n      _ = n^2 * ε^2 * (1 / 2) := by\n        rw [intervalIntegral.integral_id]\n    