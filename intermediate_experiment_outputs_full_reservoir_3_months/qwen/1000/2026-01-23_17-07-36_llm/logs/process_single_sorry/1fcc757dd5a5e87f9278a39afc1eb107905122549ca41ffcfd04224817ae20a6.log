lemma forall_indep {S D : Set α} (R : refinement S) :
    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  have h_indep : sSupIndep I := R.carrier_indep I hI
  have h_not_bot : ⊥ ∉ I := R.bot_not_mem I hI
  have h_eq : a = sSup I := by
    have h_unique := R.carrier_span _ (by aesop)
    aesop
  have h_le : b ≤ sSup (I \ {a}) := by
    calc
      b ≤ sSup ((⋃ D ∈ R, D) \ {a}) := hb'
      _ ≤ sSup (I \ {a}) := by
        apply sSup_le_sSup
        intro x hx
        simp at hx
        obtain ⟨J, hJ, hxJ, hne⟩ := hx
        have h_unique_J := R.carrier_span x (by aesop)
        have h_unique_I := R.carrier_span x (by aesop)
        have h_eq_J_I : J = I := by
          aesop
        subst h_eq_J_I
        exact ⟨hxJ, hne⟩
  have h_inf : a ⊓ b = ⊥ := by
    calc
      a ⊓ b = sSup I ⊓ b := by rw [h_eq]
      _ = sSup (I.image (· ⊓ b)) := by rw [sSup_inf_eq_Inf_Sup]
      _ ≤ sSup (I \ {a}) := by
        apply sSup_le_sSup
        intro x hx
        simp at hx
        cases' hx with hx hx
        · exfalso
          have h_x_eq_a : x = a := by
            have h_unique_x := R.carrier_span x (by aesop)
            have h_unique_a := R.carrier_span a (by aesop)
            aesop
          subst h_x_eq_a
          exact hx
        · exact le_rfl
      _ ≤ b := by
        apply le_trans h_le
        apply sSup_le
        intro x hx
        exact le_of_eq (by aesop)
  have h_disjoint : Disjoint a b := by
    rw [disjoint_iff]
    exact h_inf
  have h_zero : b = ⊥ := by
    apply le_antisymm
    · exact hb'
    · apply bot_le
  rw [h_zero]
  exact le_rfl
