lemma forall_indep {S D : Set α} (R : refinement S) :
    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  have h_indep : sSupIndep I := R.carrier_indep I hI
  have h_a_not_bot : a ≠ ⊥ := by
    rintro rfl
    simp_all
  have h_b_le_sSup : b ≤ sSup (I \ {a}) := by
    calc
      b ≤ sSup ((⋃ D ∈ R, D) \ {a}) := hb'
      _ ≤ sSup (I \ {a}) := by
        apply sSup_mono
        intro x hx
        simp_rw [Set.mem_diff] at hx
        obtain ⟨hx₁, hx₂⟩ := hx
        simp_rw [Set.mem_iUnion] at hx₁
        obtain ⟨J, hJ, hxJ⟩ := hx₁
        have h_unique : J = I := by
          apply Eq.symm
          apply (R.carrier_span a hI').1
          use J
          constructor
          · exact hJ
          · exact hxJ
        rw [h_unique] at hxJ
        exact ⟨hxJ, hx₂⟩
  have h_abot : a ⊓ b = ⊥ := by
    apply le_antisymm
    · apply inf_le_inf_right
      exact le_bot_iff.mpr (h_indep a hI' b h_b_le_sSup (by simp [h_a_not_bot]))
    · apply bot_le
  have h_b_eq_bot : b = ⊥ := by
    apply le_antisymm
    · exact h_indep a hI' b h_b_le_sSup h_abot
    · apply bot_le
  rw [h_b_eq_bot]
  exact le_rfl
