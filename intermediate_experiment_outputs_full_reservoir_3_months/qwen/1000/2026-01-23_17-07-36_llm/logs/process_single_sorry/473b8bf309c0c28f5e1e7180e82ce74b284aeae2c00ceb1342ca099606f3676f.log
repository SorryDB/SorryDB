/-- **Hölder's inequality**, binary case. -/
lemma wInner_cWeight_le_cLpNorm_mul_cLpNorm (p q : ℝ≥0∞) [p.HolderConjugate q] :
    ⟪f, g⟫ₙ_[ℝ] ≤ ‖f‖ₙ_[p] * ‖g‖ₙ_[q] := by
  have h₀ : 0 ≤ fun i ↦ |f i| := fun i ↦ abs_nonneg _
  have h₁ : 0 ≤ fun i ↦ |g i| := fun i ↦ abs_nonneg _
  calc
    ⟪f, g⟫ₙ_[ℝ] ≤ ‖fun i ↦ |f i| * |g i|‖ₙ_[1] := by
      simp_rw [wInner_cWeight_eq_expect, cL1Norm_eq_expect_nnnorm]
      exact ENNReal.toReal_le_toReal (by
        simp_rw [← NNReal.coe_le_coe]
        exact expect_mono (by
          intro i
          simp only [abs_mul, nnabs_of_nonneg (abs_nonneg _), nnabs_of_nonneg (abs_nonneg _)]
          exact nnabs_abs _))
    _ = ⟪fun i ↦ |f i|, fun i ↦ |g i|⟫ₙ_[ℝ] := by
      rw [cL1Norm_mul_of_nonneg h₀ h₁]
    _ ≤ ‖fun i ↦ |f i|‖ₙ_[p] * ‖fun i ↦ |g i|‖ₙ_[q] := by
      exact discrete_hoelder_inequality p q (HolderConjugate.to_real_pos inst✝) _ _
    _ = ‖f‖ₙ_[p] * ‖g‖ₙ_[q] := by
      congr 1 <;> ext <;> simp [norm_eq_abs]
