theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · intro h
    rintro p hp
    obtain ⟨f, hf⟩ := h
    use LocalizedModule.mapEquiv p.1.primeCompl f hf
  · intro h
    set sigma := (Module.support A M ∪ Module.support A N) ∩
      {p : PrimeSpectrum A | p.1.primeHeight = 1} with hsigma
    set S := ⨅ p ∈ sigma, p.1.primeCompl with hS
    have hfin : sigma.Finite := by
      refine Set.Finite.union ?_ ?_
      all_goals exact Module.IsTorsion.finite_primeHeight_one_support ‹_›
    have hS' : S ≤ nonZeroDivisors A :=
      iInf_le_of_le (Set.nonempty_of_finite_of_nonempty hfin ?_) (by
        simp only [Set.mem_inter_iff, Set.mem_setOf_eq]
        intro p hp
        exact p.1.primeCompl_le_nonZeroDivisors)
    · haveI : IsDomain (Localization S) := IsLocalization.isDomain_localization hS'
      have hbijective : Function.Bijective (LocalizedModule.map S (LinearMap.id : M →ₗ[A] M)) := by
        apply LinearMap.isPseudoIsomorphism_iff_bijective_map.mp
        refine ⟨LinearMap.id, ?_⟩
        simp [isPseudoIsomorphism_iff]
      have hmap : LocalizedModule S M ≃ₗ[Localization S] LocalizedModule S N := by
        apply LinearEquiv.ofBijective
        · apply LocalizedModule.map
          apply LinearMap.id
        · exact hbijective
      refine ⟨LinearMap.id, ?_⟩
      simp [isPseudoIsomorphism_iff]
      intro p hp
      cases' lt_or_le p.1.primeHeight 1 with hlt hle
      · rw [ENat.lt_one_iff_eq_zero] at hlt
        rw [Ideal.primeHeight_eq_zero_iff] at hlt
        simp [LocalizedModule.subsingleton_iff, hMT, hNT, hlt]
      · have : p ∈ sigma := by
          simp only [sigma, Set.mem_inter_iff, Set.mem_setOf_eq, Set.mem_union]
          refine Or.inl ?_
          exact Module.mem_support_of_mem_support_union_left _ (Module.mem_support_self _)
        specialize h p hp
        obtain ⟨e⟩ := h
        have he := LocalizedModule.mapEquiv_injective p.1.primeCompl e
        simp_all
