theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · intro h
    rintro p hp
    obtain ⟨f, hf⟩ := h
    use LocalizedModule.mapEquiv p.1.primeCompl f.toLinearMap
    simp [hf.1, hf.2]
  · intro h
    set sigma := (Module.support A M ∪ Module.support A N) ∩
      {p : PrimeSpectrum A | p.1.primeHeight = 1}
    set S := ⨅ p ∈ sigma, p.1.primeCompl
    have hfin : sigma.Finite := by
      refine Set.Finite.union ?_ ?_
      · exact Module.IsTorsion.finite_primeHeight_one_support hMT
      · exact Module.IsTorsion.finite_primeHeight_one_support hNT
    haveI : IsDomain (Localization S) :=
      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization _ (by simp) (by aesop) hfin |>.1
    haveI : IsPrincipalIdealRing (Localization S) :=
      HeightOneLocalizationIsPID.isPrincipalIdealRing_localization _ (by simp) (by aesop) hfin |>.2
    have hbijective : Function.Bijective (LocalizedModule.map S (LinearMap.id : M →ₗ[A] M)) := by
      apply LinearMap.isPseudoIsomorphism_iff_bijective_map.mp
      refine ⟨Submodule.bot_eq_bot, Submodule.top_eq_top⟩
    have hequiv : LocalizedModule S M ≃ₗ[Localization S] LocalizedModule S N := by
      apply Module.linearEquiv_of_pid_of_same_invariants
      · infer_instance
      · infer_instance
      · intro p hp
        specialize h p hp
        obtain ⟨e⟩ := h
        exact e
    refine ⟨{ toLinearMap := LinearMap.id, ker_eq_bot := ?_, range_eq_top := ?_ }, ?_⟩
    · ext x
      simp
    · ext x
      simp
    · simp [hequiv]
