      rw [hij] at f
      have h_iso := LocalizedModule.pi_equiv_directSum _ _ _ f
      simp_all [LocalizedModule.directSum_equiv_pi, Submodule.pow_eq_bot_iff]
    -- Since the localizations determine the exponents uniquely,
    -- the two decompositions must be the same up to permutation.
