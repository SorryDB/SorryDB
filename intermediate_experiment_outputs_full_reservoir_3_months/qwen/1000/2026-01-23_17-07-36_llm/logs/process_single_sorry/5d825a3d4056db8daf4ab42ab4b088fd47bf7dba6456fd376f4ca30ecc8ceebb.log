      have hiso : Nonempty ((LocalizedModule S M) ≃ₗ[Localization S] (LocalizedModule S N)) := by
        apply Module.linearEquiv_of_isTorsion_of_isPrincipalIdealRing_of_same_support
          (α := Localization S) _ _ hMT' hNT'
        intro P hP
