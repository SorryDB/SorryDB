    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  refine ⟨fun h p hp ↦ ?_, fun h ↦ ?_⟩
  · obtain ⟨f, hf⟩ := h
    use LocalizedModule.mapEquiv _ f.toLinearMap
    simp [hf.1, hf.2]
  · have := Module.IsTorsion.isPseudoIsomorphic_pi hMT
    obtain ⟨ι, hι, p, hp, e, he, hM⟩ := this
    have := Module.IsTorsion.isPseudoIsomorphic_pi hNT
    obtain ⟨κ, hκ, q, hq, d, hd, hN⟩ := this
    suffices (Π i : ι, A ⧸ (p i).1 ^ (e i)) ∼ₚᵢₛ[A] (Π j : κ, A ⧸ (q j).1 ^ (d j)) by
      exact PseudoIsomorphism.trans hM (PseudoIsomorphism.trans this hN.symm)
    apply PseudoIsomorphism.pi_congr
    intro p₀ hp₀
    have h₁ := h p₀ hp₀
    have h₂ := hM.localizations_iso p₀ hp₀
    have h₃ := hN.localizations_iso p₀ hp₀
    exact Nonempty.map (fun e ↦ h₂.trans (e.trans h₃.symm)) h₁
