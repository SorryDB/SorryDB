    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · intro h
    obtain ⟨f, hf⟩ := h
    intro p hp
    use LocalizedModule.mapEquiv p.1.primeCompl f hf.1 hf.2
  · intro h
    set sigma := (Module.support A M ∪ Module.support A N) ∩
      {p : PrimeSpectrum A | p.1.primeHeight = 1} with hsigma
    set S := ⨅ p ∈ sigma, p.1.primeCompl with hS
    have hfin : sigma.Finite := by
      refine Set.Finite.union ?_ ?_
      all_goals exact Module.IsTorsion.finite_primeHeight_one_support ‹_›
    have hnonempty : sigma.Nonempty ∨ sigma = ∅ := by
      apply Set.eq_empty_or_nonempty
    cases' hnonempty with hne hempty
    · haveI := hfin.to_subtype
      have : Function.Bijective (LocalizedModule.map S (LinearMap.id : M →ₗ[A] M)) := by
        apply LinearMap.isPseudoIsomorphism_iff_bijective_map.mp
        refine ⟨LinearMap.id, ?_, ?_⟩
        · simp
        · simp
      have : Function.Bijective (LocalizedModule.map S (LinearMap.id : N →ₗ[A] N)) := by
        apply LinearMap.isPseudoIsomorphism_iff_bijective_map.mp
        refine ⟨LinearMap.id, ?_, ?_⟩
        · simp
        · simp
      have : ∀ p ∈ sigma, Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
        intro p hp
        rw [Set.mem_inter_iff] at hp
        exact h p hp.2
      have : Function.Bijective (LocalizedModule.map S (LinearMap.id : M →ₗ[A] N)) := by
        apply LinearMap.isPseudoIsomorphism_iff_bijective_map.mpr
        refine ⟨LinearMap.id, ?_, ?_⟩
        · simp
        · simp
      exact ⟨LinearMap.id, by simp, by simp⟩
    · have : Module.support A M ⊆ {p : PrimeSpectrum A | p.1.primeHeight ≠ 1} := by
        intro p hp
        rw [Set.mem_setOf_eq]
        intro h
        exfalso
        rw [hempty] at h
        simp_all
      have : Module.support A N ⊆ {p : PrimeSpectrum A | p.1.primeHeight ≠ 1} := by
        intro p hp
        rw [Set.mem_setOf_eq]
        intro h
        exfalso
        rw [hempty] at h
        simp_all
      have : M ∼ₚᵢₛ[A] 0 := by
        rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
        intro p hp
        rw [Decidable.le_iff_eq_or_lt] at hp
        cases' hp with hp hp
        · exfalso
          rw [← Set.not_mem_empty_iff] at hempty
          specialize hempty p
          simp_all
        · rw [Ideal.primeHeight_eq_zero_iff] at hp
          rw [LocalizedModule.subsingleton_iff]
          intro x
          obtain ⟨a, ha⟩ := hMT x
          use a, by
            have := Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes hp
            rw [Set.disjoint_right] at this
            apply this
            simpa using ha
      have : N ∼ₚᵢₛ[A] 0 := by
        rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
        intro p hp
        rw [Decidable.le_iff_eq_or_lt] at hp
        cases' hp with hp hp
        · exfalso
          rw [← Set.not_mem_empty_iff] at hempty
          specialize hempty p
          simp_all
        · rw [Ideal.primeHeight_eq_zero_iff] at hp
          rw [LocalizedModule.subsingleton_iff]
          intro x
          obtain ⟨a, ha⟩ := hNT x
          use a, by
            have := Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes hp
            rw [Set.disjoint_right] at this
            apply this
            simpa using ha
      exact PseudoIsomorphism.trans (PseudoIsomorphism.symm ‹_›) ‹_›
