    ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) \ (M ∩ M' ∩ E(G, v))).encard
      ≤ (M ∩ E(G, v)).encard + (M' ∩ E(G, v)).encard := by
        exact encard_union_le _ _
    _ ≤ 1 + 1 := by
        exact add_le_add (hM.degree_le_one v) (hM'.degree_le_one v)
    _ = 2 := by norm_num
