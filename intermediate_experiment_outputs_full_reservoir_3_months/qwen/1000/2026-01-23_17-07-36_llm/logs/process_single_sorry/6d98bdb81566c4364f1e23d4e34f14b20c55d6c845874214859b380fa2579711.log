  have : (M ∆ M') ∩ E(G, v) = (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) \ (M ∩ M' ∩ E(G, v)) := by
    ext e
    simp [symmDiff, Set.mem_union, Set.mem_diff, Set.mem_inter_iff]
  rw [this]
