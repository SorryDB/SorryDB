      "\n  have h₂ : ∑ x in S, x ≤ 945 := by\n    calc\n      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ (by simp)\n      _ = (Finset.Ico 10 100).sum id := rfl\n      _ = 4905 - 45 := by\n        rw [Finset.sum_Ico_eq_sum_range_sub_sum_range]\n        norm_num\n      _ = 4860 := by norm_num\n      _ ≤ 945 := by norm_num\n  have h₃ : 2 ^ 10 = 1024 := by norm_num\n  have h₄ : 1024 > 945 := by norm_num\n  have h₅ : Finset.powerset S has 1024 elements := by\n    rw [Finset.card_powerset, h₀]\n    norm_num\n  have h₆ : ∀ T ∈ Finset.powerset S, ∑ x in T, x ≤ 945 := by\n    intro T hT\n    exact Finset.sum_le_sum_of_subset_of_nonneg (Finset.mem_powerset.mp hT) (by simp)\n  have h₇ : ∃ T₁ T₂, T₁ ∈ Finset.powerset S ∧ T₂ ∈ Finset.powerset S ∧ T₁ ≠ T₂ ∧ ∑ x in T₁, x = ∑ x in T₂, x := by\n    apply Finset.exists_ne_map_eq_of_card_lt\n    · exact h₅.symm ▸ h₃.symm ▸ h₄\n    · intro T hT\n      exact Nat.cast_le.mpr (h₆ T hT)\n  obtain ⟨T₁, T₂, hT₁, hT₂, hne, heq⟩ := h₇\n  let S₁ := T₁ \\ T₂\n  let S₂ := T₂ \\ T₁\n  use S₁, S₂\n  constructor\n  · intro h\n    have : T₁ = T₂ := by\n      rw [Finset.ext_iff] at *\n      intro x\n      have h₁ : x ∈ T₁ ↔ x ∈ T₂ := by\n        specialize h x\n        simp_all\n      exact h₁\n    contradiction\n  · constructor\n    · exact Finset.diff_subset _ _\n    · constructor\n      · intro h\n        have : T₁ = T₂ := by\n          rw [Finset.ext_iff] at *\n          intro x\n          have h₁ : x ∈ T₁ ↔ x ∈ T₂ := by\n            specialize h x\n            simp_all\n          exact h₁\n        contradiction\n      · constructor\n        · exact Finset.diff_subset _ _\n        · constructor\n          · exact Finset.disjoint_diff _\n          · rw [Finset.sum_sdiff_add_sum_inter, Finset.sum_sdiff_add_sum_inter]\n            simp_all",
      "\n  have h₂ : ∑ x in S, x ≤ 945 := by\n    calc\n      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ (by simp)\n      _ = ∑ x in Finset.range 100, x - ∑ x in Finset.range 10, x := by\n        rw [Finset.sum_Ico_eq_sum_range_sub]\n      _ = (99 * 100) / 2 - (9 * 10) / 2 := by\n        simp [Finset.sum_range_id, Nat.mul_comm]\n      _ = 4950 - 45 := by norm_num\n      _ = 4905 := by norm_num\n      _ ≤ 945 := by norm_num\n  have h₃ : 2 ^ 10 > 945 := by norm_num\n  have h₄ : Finset.powerset S ≠ ∅ := by\n    apply Finset.powerset_nonempty\n    exact Finset.nonempty_of_ne_empty (by rintro rfl; simp_all)\n  have h₅ : ∃ T₁ T₂ : Finset ℕ, T₁ ∈ Finset.powerset S ∧ T₂ ∈ Finset.powerset S ∧ T₁ ≠ T₂ ∧ ∑ x in T₁, x = ∑ x in T₂, x := by\n    apply Finset.exists_distinct_sum_eq_of_card_lt\n    · exact h₀\n    · exact h₃\n  obtain ⟨T₁, T₂, hT₁, hT₂, hne, heq⟩ := h₅\n  let S₁ := T₁ \\ T₂\n  let S₂ := T₂ \\ T₁\n  use S₁, S₂\n  constructor\n  · apply Finset.nonempty_of_ne_empty\n    intro h\n    have hT₁' : T₁ ⊆ T₂ := by\n      rw [Finset.diff_eq_empty] at h\n      exact h\n    have hT₂' : T₂ ⊆ T₁ := by\n      rw [Finset.diff_eq_empty] at h\n      exact h.symm ▸ hT₁'\n    exact hne (Finset.subset_antisymm hT₁' hT₂')\n  constructor\n  · exact Finset.diff_subset\n  constructor\n  · apply Finset.nonempty_of_ne_empty\n    intro h\n    have hT₂' : T₂ ⊆ T₁ := by\n      rw [Finset.diff_eq_empty] at h\n      exact h\n    have hT₁' : T₁ ⊆ T₂ := by\n      rw [Finset.diff_eq_empty] at h\n      exact h.symm ▸ hT₂'\n    exact hne (Finset.subset_antisymm hT₁' hT₂')\n  constructor\n  · exact Finset.diff_subset\n  constructor\n  · exact Finset.disjoint_sdiff_sdiff\n  calc\n    ∑ x in S₁, x = ∑ x in T₁ \\ T₂, x := rfl\n    _ = ∑ x in T₁, x - ∑ x in T₁ ∩ T₂, x := by\n      rw [Finset.sum_sdiff]\n      exact Finset.sum_nonneg (by simp)\n    _ = ∑ x in T₂, x - ∑ x in T₁ ∩ T₂, x := by rw [heq]\n    _ = ∑ x in T₂ \\ T₁, x := by\n      rw [Finset.sum_sdiff]\n  