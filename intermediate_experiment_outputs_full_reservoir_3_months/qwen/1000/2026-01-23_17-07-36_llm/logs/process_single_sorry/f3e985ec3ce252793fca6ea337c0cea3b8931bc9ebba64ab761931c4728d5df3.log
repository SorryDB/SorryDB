import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h₂ : ∑ x in S, x ≤ 945 := by
    calc
      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ fun _ _ => by norm_num
      _ = 4905 - 45 := by decide
      _ = 4860 := by norm_num
      _ ≤ 945 := by norm_num
  have h₃ : 2 ^ 10 = 1024 := by norm_num
  have h₄ : 1024 > 945 := by norm_num
  have h₅ : Finset.powerset S ≠ ∅ := by
    apply Finset.nonempty_powerset
    exact Finset.nonempty_of_ne_empty (by rintro rfl; simp_all)
  have h₆ : Finset.card (Finset.powerset S) = 1024 := by
    rw [Finset.card_powerset, h₀]
    norm_num
  let f : Finset ℕ → ℕ := fun T => ∑ x in T, x
  have h₇ : ∀ T ∈ Finset.powerset S, f T ≤ 945 := by
    intro T hT
    have hT' : T ⊆ S := Finset.mem_powerset.mp hT
    calc
      f T = ∑ x in T, x := rfl
      _ ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset_of_nonneg hT' fun _ _ => by norm_num
      _ ≤ 945 := h₂
  have h₈ : ∃ T₁ T₂, T₁ ∈ Finset.powerset S ∧ T₂ ∈ Finset.powerset S ∧ T₁ ≠ T₂ ∧ f T₁ = f T₂ := by
    apply Finset.exists_ne_map_eq_of_card_lt
    · exact h₆.symm ▸ h₄
    · exact fun T hT => h₇ T hT
  obtain ⟨T₁, T₂, hT₁, hT₂, hne, heq⟩ := h₈
  let S₁ := T₁ \ T₂
  let S₂ := T₂ \ T₁
  have hS₁ : S₁ ⊆ S := Finset.diff_subset.trans (Finset.mem_powerset.mp hT₁)
  have hS₂ : S₂ ⊆ S := Finset.diff_subset.trans (Finset.mem_powerset.mp hT₂)
  have hdisj : Disjoint S₁ S₂ := Finset.disjoint_sdiff_sdiff
  have hsum : ∑ x in S₁, x = ∑ x in S₂, x := by
    calc
      ∑ x in S₁, x = ∑ x in T₁ \ T₂, x := rfl
      _ = ∑ x in T₁, x - ∑ x in T₁ ∩ T₂, x := by rw [Finset.sum_sdiff]
      _ = ∑ x in T₂, x - ∑ x in T₁ ∩ T₂, x := by rw [heq]
      _ = ∑ x in T₂ \ T₁, x := by rw [Finset.sum_sdiff]
      _ = ∑ x in S₂, x := rfl
  have hnon₁ : S₁.Nonempty ∨ S₂.Nonempty := by
    by_contra h
    push_neg at h
    have hT₁₂ : T₁ = T₂ := by
      ext x
      constructor <;> intro hx <;> by_contra hx' <;> simp_all [Finset.mem_diff]
    exact hne hT₁₂
  cases' hnon₁ with hnon₁ hnon₂
  · exact ⟨S₁, S₂, hnon₁, hS₁, S₂.Nonempty.mpr (by rintro rfl; simp_all [Finset.disjoint_empty]), hS₂, hdisj, hsum⟩
  · exact ⟨S₁, S₂, S₁.Nonempty.mpr (by rintro rfl; simp_all [Finset.disjoint_empty]), hS₁, hnon₂, hS₂, hdisj, hsum⟩
