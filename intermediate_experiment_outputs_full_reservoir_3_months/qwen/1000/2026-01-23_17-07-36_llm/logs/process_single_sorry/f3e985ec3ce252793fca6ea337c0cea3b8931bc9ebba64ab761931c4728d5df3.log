      "\n  have h₂ : ∀ x ∈ S, 10 ≤ x ∧ x < 100 := by\n    intro x hx\n    exact Finset.mem_Ico.mp (h₁ hx)\n  have h₃ : ∑ x in S, x < 1000 := by\n    calc\n      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ (by simp)\n      _ = ∑ k in Finset.range 90, (k + 10) := by\n        rw [Finset.sum_Ico_eq_sum_range]\n      _ = 90 * 10 + ∑ k in Finset.range 90, k := by\n        simp [Finset.sum_add_distrib, Finset.sum_const]\n      _ = 900 + 90 * 89 / 2 := by\n        rw [Finset.sum_range_id]\n      _ = 900 + 4005 := by norm_num\n      _ = 4905 := by norm_num\n      _ < 1000 := by norm_num\n  have h₄ : 2 ^ 10 = 1024 := by norm_num\n  have h₅ : 1024 > 1000 := by norm_num\n  have h₆ : Finset.powerset S has 1024 elements := by\n    rw [Finset.card_powerset, h₀, h₄]\n  have h₇ : ∀ T ∈ Finset.powerset S, ∑ x in T, x < 1000 := by\n    intro T hT\n    calc\n      ∑ x in T, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset_of_nonneg (Finset.mem_powerset.mp hT) (by simp)\n      _ < 1000 := h₃\n  have h₈ : ∃ T₁ T₂, T₁ ∈ Finset.powerset S ∧ T₂ ∈ Finset.powerset S ∧ T₁ ≠ T₂ ∧ ∑ x in T₁, x = ∑ x in T₂, x := by\n    apply Finset.exists_ne_map_eq_of_card_lt\n    · exact h₅\n    · intro T hT\n      exact Nat.lt_asymm (h₇ T hT) (by norm_num)\n  obtain ⟨T₁, T₂, hT₁, hT₂, hne, heq⟩ := h₈\n  let S₁ := T₁ \\ T₂\n  let S₂ := T₂ \\ T₁\n  use S₁, S₂\n  constructor\n  · intro h\n    have : T₁ ≠ ∅ := by\n      intro h'\n      rw [h'] at heq\n      simp at heq\n      have : T₂ = ∅ := by\n        apply Finset.eq_empty_of_sum_eq_zero\n        · intro x hx\n          linarith [h₂ x (Finset.mem_of_mem_powerset hT₂ hx)]\n        · exact heq\n      rw [this] at hne\n      contradiction\n    simp_all\n  constructor\n  · exact Finset.sdiff_subset\n  constructor\n  · intro h\n    have : T₂ ≠ ∅ := by\n      intro h'\n      rw [h'] at heq\n      simp at heq\n      have : T₁ = ∅ := by\n        apply Finset.eq_empty_of_sum_eq_zero\n        · intro x hx\n          linarith [h₂ x 