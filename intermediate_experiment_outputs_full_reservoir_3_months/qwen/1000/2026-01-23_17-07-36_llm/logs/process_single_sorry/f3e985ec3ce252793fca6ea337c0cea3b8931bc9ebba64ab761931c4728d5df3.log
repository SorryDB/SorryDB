open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h₂ : ∑ x in S, x ≤ 945 := by
    calc
      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ fun _ _ => by linarith
      _ = ∑ k in Finset.range 90, (k + 10) := by
        apply Finset.sum_bij
        · intro x hx; exact ⟨x - 10, by simp_all [Finset.mem_Ico]⟩
        · intro x hx; simp_all [Finset.mem_Ico]
        · intro x y hx hy h; simp_all
        · intro y hy; use y + 10; simp_all [Finset.mem_Ico]
      _ = ∑ k in Finset.range 90, k + ∑ k in Finset.range 90, 10 := by
        simp [Finset.sum_add_distrib]
      _ = 90 * 89 / 2 + 90 * 10 := by
        simp [Finset.sum_range_id, Finset.sum_const, nsmul_eq_mul]
      _ = 4005 + 900 := by norm_num
      _ = 4905 := by norm_num
      _ ≤ 945 := by norm_num
  have h₃ : 2 ^ 10 > 945 := by norm_num
  have h₄ : Finset.powerset S ≠ ∅ := by
    apply Finset.powerset_nonempty
  have h₅ : (Finset.powerset S).card = 2 ^ 10 := by
    rw [Finset.card_powerset, h₀]
  have h₆ : ∃ A B : Finset ℕ, A ∈ Finset.powerset S ∧ B ∈ Finset.powerset S ∧ A ≠ B ∧ ∑ x in A, x = ∑ x in B, x := by
    apply Finset.exists_ne_map_eq_of_card_lt
    · exact h₅.symm ▸ h₃
    · intro A hA
      have : ∑ x in A, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset_of_nonneg (Finset.subset_of_mem_powerset hA) fun _ _ => by linarith
      linarith
  obtain ⟨A, B, hA, hB, hAB, hsum⟩ := h₆
  let C := A \ B
  let D := B \ A
  have hC : C ⊆ S := Finset.diff_subset.trans (Finset.subset_of_mem_powerset hA) (by rfl)
  have hD : D ⊆ S := Finset.diff_subset.trans (Finset.subset_of_mem_powerset hB) (by rfl)
  have hCD : Disjoint C D := Finset.disjoint_sdiff_sdiff
  have hsum' : ∑ x in C, x = ∑ x in D, x := by
    calc
      ∑ x in C, x = ∑ x in A, x - ∑ x in A ∩ B, x := by
        rw [Finset.sum_sdiff (Finset.inter_subset_left A B)]
      _ = ∑ x in B, x - ∑ x in A ∩ B, x := by rw [hsum]
      _ = ∑ x in D, x := by
        rw [Finset.sum_sdiff (Finset.inter_subset_right A B)]
  have hCne : C.Nonempty ∨ D.Nonempty := by
    by_contra h
    push_neg at h
    have : A = B := by
      ext x
      constructor <;> intro hx <;> by_contra hx' <;> simp_all [Finset.mem_sdiff]
    contradiction
  cases' hCne with hCne hDne
  · exact ⟨C, D, hCne, hC, hDne, hD, hCD, hsum'⟩
  · exact ⟨D, C, hDne, hD, hCne, hC, hCD.symm, hsum'.symm⟩
