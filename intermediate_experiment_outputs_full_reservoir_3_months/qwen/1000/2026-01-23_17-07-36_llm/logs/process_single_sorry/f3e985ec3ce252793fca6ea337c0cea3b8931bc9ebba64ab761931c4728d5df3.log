      "\n  have h₂ : ∑ x in S, x ≤ 945 := by\n    calc\n      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ (by simp)\n      _ = ∑ x in Finset.range 100, x - ∑ x in Finset.range 10, x := by\n        rw [Finset.sum_Ico_eq_sum_range_sub]\n      _ = (99 * 100) / 2 - (9 * 10) / 2 := by\n        rw [Finset.sum_range_id, Finset.sum_range_id]\n      _ = 4950 - 45 := by norm_num\n      _ = 4905 := by norm_num\n      _ ≤ 945 := by norm_num\n  have h₃ : 2 ^ 10 = 1024 := by norm_num\n  have h₄ : 945 < 1024 := by norm_num\n  let P := { T : Finset ℕ | T ⊆ S }\n  have h₅ : P.card = 2 ^ 10 := by\n    rw [Finset.card_powerset, h₀]\n  have h₆ : ∀ T ∈ P, ∑ x in T, x ≤ 945 := by\n    intro T hT\n    calc\n      ∑ x in T, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset_of_nonneg (Finset.subset_of_mem_powerset hT) (by simp)\n      _ ≤ 945 := h₂\n  let f : P → Fin 946 := fun T => ⟨∑ x in T, x, Nat.lt_of_le_of_lt (h₆ T ‹_›) (by norm_num)⟩\n  have h₇ : P.card > 946 := by\n    rw [h₅, h₃]\n    norm_num\n  have h₈ : ¬Function.Injective f := by\n    apply Finset.not_injective_of_card_gt\n    exact h₇\n  obtain ⟨T₁, hT₁, T₂, hT₂, hne, heq⟩ := h₈\n  let S₁ := T₁ \\ T₂\n  let S₂ := T₂ \\ T₁\n  have hS₁ : S₁ ⊆ S := by\n    refine Finset.diff_subset.trans ?_\n    exact Finset.subset_of_mem_powerset hT₁\n  have hS₂ : S₂ ⊆ S := by\n    refine Finset.diff_subset.trans ?_\n    exact Finset.subset_of_mem_powerset hT₂\n  have hdisj : Disjoint S₁ S₂ := by\n    rw [Finset.disjoint_iff_inter_eq_empty]\n    simp [Finset.diff_inter_diff_self]\n  have hsum : ∑ x in S₁, x = ∑ x in S₂, x := by\n    rw [Finset.sum_sdiff_of_subset (Finset.inter_subset_left T₁ T₂),\n        Finset.sum_sdiff_of_subset (Finset.inter_subset_right T₁ T₂)]\n    rw [heq]\n    simp\n  have hS₁_nonempty : S₁.Nonempty ∨ S₂.Nonempty := by\n    by_contra h\n    push_neg at h\n    have hT₁_eq_T₂ : T₁ = T₂ := by\n      ext x\n      constructor <;> intro hx <;> simp_all [Finset.mem_diff]\n    exact hne hT₁