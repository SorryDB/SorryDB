      "\n  have h₂ : ∑ x in S, x ≤ 945 := by\n    calc\n      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ fun _ _ => by norm_num\n      _ = 4905 - 45 := by rfl\n      _ = 4860 := by norm_num\n      _ ≤ 945 := by norm_num\n  have h₃ : 2 ^ 10 = 1024 := by norm_num\n  have h₄ : 1024 > 945 := by norm_num\n  let P := {T : Finset ℕ | T ⊆ S}\n  have h₅ : P.card = 2 ^ 10 := by\n    rw [Finset.card_powerset]\n    exact h₀\n  have h₆ : ∀ T ∈ P, ∑ x in T, x ≤ 945 := by\n    intro T hT\n    calc\n      ∑ x in T, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset_of_nonneg (by aesop) fun _ _ => by norm_num\n      _ ≤ 945 := h₂\n  let f : P → ℕ := fun T => ∑ x in T, x\n  have h₇ : Set.InjOn f P → P.card ≤ 946 := by\n    intro hf\n    have h₈ : f '' P ⊆ Finset.Icc 0 945 := by\n      intro y hy\n      obtain ⟨T, hT, rfl⟩ := hy\n      refine' ⟨by simp [Finset.sum_nonneg], h₆ T hT⟩\n    calc\n      P.card = (f '' P).card := by rw [Set.card_image_of_injOn hf]\n      _ ≤ (Finset.Icc 0 945).card := Finset.card_le_card h₈\n      _ = 946 := by norm_num\n  have h₈ : ¬Set.InjOn f P := by\n    intro hf\n    linarith [h₇ hf]\n  obtain ⟨T₁, hT₁, T₂, hT₂, hne, heq⟩ := Set.not_injOn_iff.mp h₈\n  have h₉ : T₁ ≠ T₂ := hne\n  have h₁₀ : ∑ x in T₁, x = ∑ x in T₂, x := heq\n  let S₁ := T₁ \\ T₂\n  let S₂ := T₂ \\ T₁\n  have h₁₁ : S₁ ⊆ S := by\n    calc\n      S₁ = T₁ \\ T₂ ⊆ T₁ := Finset.sdiff_subset\n      _ ⊆ S := by aesop\n  have h₁₂ : S₂ ⊆ S := by\n    calc\n      S₂ = T₂ \\ T₁ ⊆ T₂ := Finset.sdiff_subset\n      _ ⊆ S := by aesop\n  have h₁₃ : Disjoint S₁ S₂ := by\n    rw [Finset.disjoint_sdiff_sdiff]\n  have h₁₄ : ∑ x in S₁, x = ∑ x in S₂, x := by\n    calc\n      ∑ x in S₁, x = ∑ x in T₁, x - ∑ x in T₁ ∩ T₂, x := by\n        rw [Finset.sum_sdiff]\n        exact Finset.sum_nonneg fun _ _ => by norm_num\n      _ = ∑ x in T₂, x - ∑ x in T₁ ∩ T₂, x := by rw [h₁₀]\n      _ = ∑ x in S₂, x := by\n        rw [Finset.sum_sdiff]\n        exact Finset.sum_nonneg fun _