      "\n  have h₂ : ∑ x in S, x ≤ 945 := by\n    calc\n      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ fun _ _ => by norm_num\n      _ = 4905 - 45 := by rfl\n      _ = 4860 := by norm_num\n      _ ≤ 945 := by norm_num\n  have h₃ : 2 ^ 10 = 1024 := by norm_num\n  have h₄ : 1024 > 945 := by norm_num\n  have h₅ : ∃ f : Finset ℕ → ℕ, Function.Injective f → False := by\n    intro f hf\n    have h₆ : Finset.card (Finset.powerset S) = 1024 := by\n      rw [Finset.card_powerset, h₀]\n      norm_num\n    have h₇ : Finset.card (Finset.image (fun T ↦ ∑ x in T, x) (Finset.powerset S)) ≤ 946 := by\n      apply Finset.card_image_le_of_subset\n      intro T hT\n      have h₈ : ∑ x in T, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset_of_nonneg (Finset.subset_of_mem_powerset hT) fun _ _ => by norm_num\n      linarith\n    have h₈ : 1024 ≤ 946 := by\n      calc\n        1024 = Finset.card (Finset.powerset S) := by rw [h₆]\n        _ ≤ Finset.card (Finset.image (fun T ↦ ∑ x in T, x) (Finset.powerset S)) := Finset.card_le_card_image_of_inj_on hf\n        _ ≤ 946 := h₇\n    linarith\n  have h₆ : ¬Function.Injective (fun T ↦ ∑ x in T, x) := by\n    intro h\n    exact h₅ (fun T ↦ ∑ x in T, x) h\n  push_neg at h₆\n  obtain ⟨A, B, hAB, hsum⟩ := h₆\n  have hA : A ⊆ S := Finset.subset_of_mem_powerset A.2\n  have hB : B ⊆ S := Finset.subset_of_mem_powerset B.2\n  have hAB' : A ≠ B := hAB\n  have hsum' : ∑ x in A, x = ∑ x in B, x := hsum\n  let C := A \\ B\n  let D := B \\ A\n  have hC : C ⊆ S := Finset.diff_subset A B ▸ hA\n  have hD : D ⊆ S := Finset.diff_subset B A ▸ hB\n  have hCD : Disjoint C D := Finset.disjoint_sdiff_sdiff A B\n  have hsumCD : ∑ x in C, x = ∑ x in D, x := by\n    calc\n      ∑ x in C, x = ∑ x in A, x - ∑ x in A ∩ B, x := by rw [Finset.sum_sdiff hA]\n      _ = ∑ x in B, x - ∑ x in A ∩ B, x := by rw [hsum']\n      _ = ∑ x in D, x := by rw [Finset.sum_sdiff hB]\n  have hCnon : C.Nonempty ∨ D.Nonempty := by\n    by_contra h\n    p