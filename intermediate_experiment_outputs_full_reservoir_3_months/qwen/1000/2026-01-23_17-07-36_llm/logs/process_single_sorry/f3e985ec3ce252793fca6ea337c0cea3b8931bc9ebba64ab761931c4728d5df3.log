open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h₂ : ∀ x ∈ S, 10 ≤ x ∧ x < 100 := by
    intro x hx
    exact Finset.mem_Ico.mp (h₁ hx)
  have h₃ : ∑ x in S, x ≤ 99 * 10 := by
    calc
      ∑ x in S, x ≤ ∑ x in S, 99 := Finset.sum_le_sum fun x hx => (h₂ x hx).2.le
      _ = 99 * S.card := by simp [Finset.sum_const]
      _ = 99 * 10 := by rw [h₀]
  have h₄ : ∑ x in S, x ≥ 10 * 10 := by
    calc
      ∑ x in S, x ≥ ∑ x in S, 10 := Finset.sum_le_sum fun x hx => (h₂ x hx).1
      _ = 10 * S.card := by simp [Finset.sum_const]
      _ = 10 * 10 := by rw [h₀]
  let P := { T : Finset ℕ | T ⊆ S ∧ T.Nonempty }
  have h₅ : P.card = 2 ^ 10 - 1 := by
    rw [Finset.card_sdiff]
    · simp [Finset.card_powerset, h₀]
    · simp
  have h₆ : ∀ T ∈ P, ∑ x in T, x ≤ ∑ x in S, x := by
    intro T hT
    exact Finset.sum_le_sum_of_subset_of_nonneg (hT.1) (by simp)
  have h₇ : ∀ T ∈ P, ∑ x in T, x ≥ 10 := by
    intro T hT
    obtain ⟨x, hx⟩ := hT.2
    calc
      ∑ x in T, x ≥ x := Finset.single_le_sum (fun y _ => by linarith [h₂ y (hT.1 y ‹_›)]) hx
      _ ≥ 10 := (h₂ x (hT.1 x hx)).1
  have h₈ : ∑ x in S, x ≤ 990 := by linarith
  have h₉ : ∀ T ∈ P, ∑ x in T, x ≤ 990 := by
    intro T hT
    linarith [h₆ T hT]
  have h₁₀ : ∀ T ∈ P, ∑ x in T, x ∈ Finset.Icc 10 990 := by
    intro T hT
    exact ⟨h₇ T hT, h₉ T hT⟩
  have h₁₁ : (Finset.image (fun T ↦ ∑ x in T, x) P).card ≤ 981 := by
    calc
      (Finset.image (fun T ↦ ∑ x in T, x) P).card ≤ (Finset.Icc 10 990).card := Finset.card_image_le.trans (Finset.card_filter_le _ _)
      _ = 990 - 10 + 1 := by simp
      _ = 981 := by norm_num
  have h₁₂ : P.card > 981 := by
    norm_num [h₅]
  have h₁₃ : ¬Function.Injective (fun T ↦ ∑ x in T, x : P → ℕ) := by
    intro h
    have := Finset.card_image_of_injOn (fun T ↦ ∑ x in T, x) (Set.injOn_of_injective h)
    linarith
  obtain ⟨T₁, hT₁, T₂, hT₂, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt h₁₃
  use T₁, T₂
  refine' ⟨hT₁.2, hT₁.1, hT₂.2, hT₂.1, _, heq⟩
  intro x hx₁ hx₂
  have hmem : x ∈ T₁ ∩ T₂ := ⟨hx₁, hx₂⟩
  have hdis : T₁ ∩ T₂ = ∅ := by
    contrapose! hne
    ext y
    simp_all
  contradiction
