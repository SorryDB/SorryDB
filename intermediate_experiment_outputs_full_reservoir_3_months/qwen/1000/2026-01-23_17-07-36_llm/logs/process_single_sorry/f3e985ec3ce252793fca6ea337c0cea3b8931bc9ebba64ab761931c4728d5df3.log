      "\n  have h₂ : ∑ x in S, x ≤ 945 := by\n    calc\n      ∑ x in S, x ≤ ∑ x in Finset.Ico 10 100, x := Finset.sum_le_sum_of_subset_of_nonneg h₁ fun _ _ => Nat.zero_le _\n      _ = ∑ x in Finset.range 100, x - ∑ x in Finset.range 10, x := by\n        rw [Finset.sum_Ico_eq_sum_range_sub]\n      _ = (99 * 100) / 2 - (9 * 10) / 2 := by\n        simp [Finset.sum_range_id, Nat.mul_comm]\n      _ = 4950 - 45 := by norm_num\n      _ = 4905 := by norm_num\n      _ ≤ 945 := by norm_num\n  have h₃ : 2 ^ 10 = 1024 := by norm_num\n  have h₄ : 1024 > 945 := by norm_num\n  have h₅ : ∃ f : Finset ℕ → ℕ, Function.Injective f → False := by\n    intro f hf\n    have h₆ : Finset.card (Finset.powerset S) = 1024 := by\n      rw [Finset.card_powerset, h₀]\n      norm_num\n    have h₇ : Finset.card (Finset.image f (Finset.powerset S)) = 1024 := by\n      rw [Finset.card_image_of_injective _ hf]\n    have h₈ : ∀ T ∈ Finset.powerset S, f T ≤ 945 := by\n      intro T hT\n      have h₉ : T ⊆ S := Finset.mem_powerset.mp hT\n      have h₁₀ : ∑ x in T, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset_of_nonneg h₉ fun _ _ => Nat.zero_le _\n      linarith\n    have h₁₁ : Finset.card (Finset.filter (fun x => x ≤ 945) (Finset.image f (Finset.powerset S))) ≤ 946 := by\n      apply Finset.card_filter_le\n    have h₁₂ : 1024 ≤ 946 := by\n      calc\n        1024 = Finset.card (Finset.image f (Finset.powerset S)) := h₇\n        _ = Finset.card (Finset.filter (fun x => x ≤ 945) (Finset.image f (Finset.powerset S))) := by\n          apply Finset.card_congr\n          intro x hx\n          simp only [Finset.mem_filter, Finset.mem_image] at hx ⊢\n          rcases hx with ⟨T, hT, rfl⟩\n          exact ⟨by apply h₈ T hT, by tauto⟩\n        _ ≤ 946 := h₁₁\n    linarith\n  have h₆ : ¬Function.Injective (fun T : Finset ℕ => if T = ∅ then 0 else ∑ x in T, x) := by\n    intro h\n    apply h₅ (fun T => if T = ∅ then 0 else ∑ x in T, x) h\n  push_neg at h₆\n  rcases h₆ with ⟨T₁, T₂, hT₁, hT₂, hT₁₂, hsum⟩\n  have hT