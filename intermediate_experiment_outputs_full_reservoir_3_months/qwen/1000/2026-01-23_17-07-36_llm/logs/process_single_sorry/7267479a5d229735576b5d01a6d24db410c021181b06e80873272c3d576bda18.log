/-- Among n agents, to make everyone know k's secret, we need at least n-1 calls. -/
lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 < S.length := by
  cases n
  case zero => simp_all
  case succ n =>
    have h₁ : (n + 1 - 1 : Nat) ≤ S.length := by
      apply Nat.le_of_lt_succ
      apply Nat.lt_of_le_of_lt
      · apply Nat.sub_le
      · exact h
    omega
