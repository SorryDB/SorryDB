/-- Among n agents, to make everyone know k's secret, we need at least n-1 calls. -/
lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 < S.length := by
  revert h
  induction S with
  | nil => simp [allKnow, after, initialState]
  | cons c S IH =>
    intro h
    have : allKnow (after S) k ∨ ¬ allKnow (after S) k := by apply Classical.em
    cases this with
    | inl h' => exact Nat.lt_of_succ_lt_succ (IH h')
    | inr h' =>
