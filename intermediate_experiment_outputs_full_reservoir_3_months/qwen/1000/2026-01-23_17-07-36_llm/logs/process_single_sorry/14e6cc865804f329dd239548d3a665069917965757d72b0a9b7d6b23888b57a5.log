      "\n    simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hx ha'\n    rcases hx with ⟨N, hN, x_in_B⟩\n    have h_sSup_B : N = sSup (B N hN) := hB N hN\n    have h_sSupIndep_B : sSupIndep (B N hN) := hB' N hN\n    have h_x_not_bot : x ≠ ⊥ := by\n      intro h\n      apply D.not_bot_mem\n      rw [h] at hN\n      exact hN\n    have h_disj : Disjoint x (sSup ((B N hN) \\ {x})) := by\n      apply h_sSupIndep_B.disjoint_sSup\n      · exact x_in_B\n      · intro y hy\n        exact hy\n      · intro h_contra\n        apply h_x_not_bot\n        exact h_contra\n    have h_le_sSup_diff : a ≤ sSup ((B N hN) \\ {x}) := by\n      apply le_sSup_of_le _ ha'\n      intro y hy\n      simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hy\n      rcases hy with ⟨M', hM', y_in_B, y_ne_x⟩\n      have h_eq : M' = N := by\n        apply D.sSupIndep.eq_of_le\n        · exact hM'\n        · exact le_sSup_of_le hN (le_sSup_of_le y_in_B (le_rfl : y ≤ y))\n        · exact le_sSup_of_le hN (le_sSup_of_le x_in_B (le_rfl : x ≤ x))\n      subst h_eq\n      exact ⟨y_in_B, y_ne_x⟩\n    calc\n      a ≤ x ⊓ sSup ((B N hN) \\ {x}) := le_inf ha h_le_sSup_diff\n      _ ≤ ⊥ := disjoint_iff_inf_le.mp h_disj",
      "\n    simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hx ha'\n    rcases hx with ⟨N, hN, x_mem_B⟩\n    have h_sSup_B : N = sSup (B N hN) := hB N hN\n    have h_indep_B : sSupIndep (B N hN) := hB' N hN\n    have h_x_not_bot : x ≠ ⊥ := by\n      intro h\n      rw [h] at x_mem_B\n      exact hB'' N hN x_mem_B\n    have h_disj : Disjoint x (sSup ((B N hN) \\ {x})) := h_indep_B x x_mem_B\n    have h_le_sSup_diff : a ≤ sSup ((B N hN) \\ {x}) := by\n      apply le_sSup_of_le _ ha'\n      intro y hy\n      simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hy\n      rcases hy with ⟨M', hM', y_mem_B, y_ne_x⟩\n      exact ⟨M', hM', y_mem_B, y_ne_x⟩\n    exact (disjoint_iff.mp h_disj).trans h_le_sSup_diff",
      "\n    simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hx ha'\n    rcases hx with ⟨N, hN, hNx⟩\n    have h_sub : (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} ⊆ ⋃ (N' : PersistenceSubmodule M) (_ : N' ∈ D), B N' hN' := by\n      intro y hy\n      exact Set.mem_of_mem_diff hy\n    have h_sSup_le : sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x}) ≤ sSup (⋃ (N' : PersistenceSubmodule M) (_ : N' ∈ D), B N' hN') := by\n      apply sSup_le_sSup\n      exact h_sub\n    have h_a_le_sSup : a ≤ sSup (B N hN) := by\n      rw [hB N hN] at *\n      exact ha.trans (le_sSup hNx)\n    have h_disj : Disjoint x (sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x})) := by\n      apply sSupIndep.disjoint_sSup\n      · exact hB' N hN\n      · intro y hy\n        simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hy\n        rcases hy with ⟨N', hN', hy, hy'⟩\n        intro h_eq\n        have h_eq_N : N = N' := by\n          have h1 : x ∈ B N hN := hNx\n          have h2 : x ∈ B N' hN' := by rwa [← h_eq] at hy\n          have h_indep : sSupIndep (B N hN ∪ B N' hN') := by\n            by_cases h_eq_N : N = N'\n            · subst h_eq_N\n              exact hB' N hN\n            · have h_disj_NN' : Disjoint N N' := by\n                apply D.sSupIndep'.disjoint_of_ne\n                · exact hN\n                · exact hN'\n                · exact h_eq_N\n              have h_sSup_BN : sSup (B N hN) = N := hB N hN\n              have h_sSup_BN' : sSup (B N' hN') = N' := hB N' hN'\n              rw [← h_sSup_BN, ← h_sSup_BN'] at h_disj_NN'\n              exact sSupIndep.union hB' hB' h_disj_NN'\n          have h_x_in_both : x ∈ B N hN ∩ B N' hN' := ⟨hNx, h2⟩\n          have h_nonempty : (B N hN ∩ B N' hN').Nonempty := ⟨x, h_x_in_both⟩\n          exact sSupIndep.inter_nonempty h_indep h_nonempty\n        subst h_eq_N\n        have h_y_in_BN : y ∈ B N hN := hy\n        have h_y_ne_x : y ≠ x := hy'\n        have h_disj_BN : sSupIndep (B N hN) := hB' N hN\n        exact h_disj_BN.disjoint_of_ne hNx h_y_in_BN h_y_ne_x\n      · exact fun y hy => by\n          simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hy\n          rcases hy with ⟨N', hN', hy, hy'⟩\n          intro h_eq\n          have h_eq_N : N = N' := by\n            have h1 : x ∈ B N hN := hNx\n            have h2 : x ∈ B N' hN' := by rwa [← h_eq] at hy\n            have h_indep : sSupIndep (B N hN ∪ B N' hN') := by\n              by_cases h_eq_N : N = N'\n              · subst h_eq_N\n                exact hB' N hN\n              · have h_disj_NN' : Disjoint N N' := by\n                  apply D.sSupIndep'.disjoint_of_ne\n                  · exact hN\n                  · exact hN'\n                  · exact h_eq_N\n                have h_sSup_BN : sSup (B N hN) = N := hB N hN\n                have h_sSup_BN' : sSup (B N' hN') = N' := hB N' hN'\n                rw [← h_sSup_BN, ← h_sSup_BN'] at h_disj_NN'\n                exact sSupIndep.union hB' hB' h_disj_NN'\n            have h_x_in_both : x ∈ B N hN ∩ B N' hN' := ⟨hNx, h2⟩\n            have h_nonempty : (B N hN ∩ B N' hN').Nonempty := ⟨x, h_x_in_both⟩\n            exact sSupIndep.inter_nonempty h_indep h_nonempty\n          subst h_eq_N\n          have h_y_in_BN : y ∈ B N hN := hy\n          have h_y_ne_x : y ≠ x := hy'\n          have h_disj_BN : sSupIndep (B N hN) := hB' N hN\n          exact h_disj_BN.disjoint_of_ne hNx h_y_in_BN h_y_ne_x\n    exact (disjoint_iff.mp h_disj).trans (ha'.trans h_sSup_le)",
      "\n    obtain ⟨N, hN, hx'⟩ := Set.mem_iUnion.mp hx\n    obtain ⟨hN', hx''⟩ := Set.mem_iUnion.mp hx'\n    have h_sSup_B : N = sSup (B N hN') := hB N hN'\n    have h_sSupIndep_B : sSupIndep (B N hN') := hB' N hN'\n    have h_disj : Disjoint x (sSup ((B N hN') \\ {x})) := h_sSupIndep_B.disjoint_sSup hx'' (Set.subset.refl _) (by simp [hx''])\n    have h_le_sSup_diff : a ≤ sSup ((B N hN') \\ {x}) := by\n      apply le_sSup_of_le _ ha'\n      intro y hy\n      obtain ⟨hy₁, hy₂⟩ := Set.mem_diff.mp hy\n      obtain ⟨M', hM', hy'''⟩ := Set.mem_iUnion.mp hy₁\n      obtain ⟨hM'', hy''''⟩ := Set.mem_iUnion.mp hy'''\n      have h_eq : M' = N ∧ hM'' = hN' := by\n        apply And.intro\n        · have h_sub : B M' hM'' ⊆ B N hN' := by\n            intro z hz\n            simp_all\n          have h_mem : z ∈ B N hN' := h_sub hz\n          simp_all\n        · have h_sub : B M' hM'' ⊆ B N hN' := by\n            intro z hz\n            simp_all\n          have h_mem : z ∈ B N hN' := h_sub hz\n          simp_all\n      simp_all\n    exact (disjoint_iff.mp h_disj).trans h_le_sSup_diff",
      "\n    simp only [Set.mem_iUnion, Set.mem_iInter, Set.mem_diff, Set.mem_singleton_iff] at hx ha'\n    rcases hx with ⟨N, hN, hx⟩\n    have h_sub : (⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x} ⊆ sSup (B N hN) \\ {x} := by\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_iInter, Set.mem_singleton_iff] at hy\n      rcases hy with ⟨⟨M', hM', hy⟩, hy'⟩\n      rw [hB N hN] at *\n      have h_disj : Disjoint (sSup (B N hN)) (sSup (B M' hM')) := by\n        apply (D.sSupIndep' N hN M' hM').resolve_left\n        intro h_eq\n        rw [h_eq] at hy\n        exact hy' (by aesop)\n      have h_le : y ≤ sSup (B M' hM') := le_sSup hy\n      have h_le' : y ≤ sSup (B N hN) := by\n        apply le_trans h_le\n        exact le_of_eq (by rw [hB M' hM'])\n      have h_bot : y ≤ ⊥ := disjoint_iff.mp h_disj h_le' h_le\n      exact (le_bot_iff.mp h_bot).symm ▸ (by simp)\n    apply (hB' N hN x hx a ha (ha'.trans (sSup_mono h_sub))).trans\n    simp",
      "\n    obtain ⟨N, hN, hx⟩ := Set.mem_iUnion.mp hx\n    obtain ⟨hN', hx⟩ := Set.mem_iUnion.mp hx\n    have hB_indep : sSupIndep (B N hN') := hB' N hN'\n    have h_disj : Disjoint x (sSup ((B N hN') \\ {x})) := hB_indep.disjoint_sSup hx (Set.subset.refl _) (by simp)\n    have h_le : a ≤ sSup ((B N hN') \\ {x}) := by\n      apply le_sSup_of_le\n      · exact Set.iUnion_subset_iUnion fun N' => Set.iUnion_subset_iUnion fun hN'' =>\n          if h_eq : N' = N then\n            if h_eq' : hN'' = hN' then\n              by simp [h_eq, h_eq']\n            else\n              by simp_all\n          else\n            by simp_all\n      · exact ha'\n    exact (disjoint_iff.mp h_disj).trans (le_inf ha h_le)",
      "\n    simp only [Set.mem_iUnion, Set.mem_setOf_eq] at hx\n    rcases hx with ⟨N, hN, hNx⟩\n    have hB_indep : sSupIndep (B N hN) := hB' N hN\n    have hB_sub : B N hN ⊆ ⋃ N, ⋃ (hN : N ∈ D), B N hN := by\n      intro y hy\n      exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hy⟩⟩\n    have h_disj : Disjoint x (sSup ((B N hN) \\ {x})) := by\n      apply hB_indep.disjoint_sSup\n      · exact hNx\n      · intro y hy\n        exact Set.mem_of_mem_diff hy\n      · intro h_contra\n        exact Set.not_mem_diff_of_mem h_contra\n    have h_le_sSup : sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x}) ≤ sSup ((B N hN) \\ {x}) := by\n      apply sSup_le_sSup\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion] at hy\n      rcases hy with ⟨⟨M', hM', hy'⟩, hy_ne⟩\n      have h_eq : M' = N := by\n        have h_sSup_eq : sSup (B M' hM') = M' := hB M' hM'\n        have h_sSup_eq_N : sSup (B N hN) = N := hB N hN\n        have h_y_le_M' : y ≤ M' := le_sSup hy'\n        have h_y_le_N : y ≤ N := le_sSup (Set.mem_of_mem_diff ⟨hy', hy_ne⟩)\n        have h_M'_le_N : M' ≤ N := by\n          rw [← h_sSup_eq]\n          apply sSup_le\n          intro z hz\n          have h_z_le_N : z ≤ N := by\n            rw [← h_sSup_eq_N]\n            apply le_sSup hz\n          exact h_z_le_N\n        have h_N_le_M' : N ≤ M' := by\n          rw [← h_sSup_eq_N]\n          apply sSup_le\n          intro z hz\n          have h_z_le_M' : z ≤ M' := by\n            rw [← h_sSup_eq]\n            apply le_sSup hz\n          exact h_z_le_M'\n        exact le_antisymm h_M'_le_N h_N_le_M'\n      subst h_eq\n      exact Set.mem_of_mem_diff ⟨hy', hy_ne⟩\n    calc\n      a ≤ x ⊓ sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \\ {x}) := le_inf ha ha'\n      _ ≤ x ⊓ sSup ((B N hN) \\ {x}) := inf_le_inf_right _ h_le_sSup\n      _ ≤ ⊥ := disjoint_iff_inf_le.mp h_disj",
      "\n    obtain ⟨N, hN, hx'⟩ := Set.mem_iUnion.mp hx\n    obtain ⟨hN', hx''⟩ := Set.mem_iUnion.mp hx'\n    have h_sSup_B : N = sSup (B N hN') := hB N hN'\n    have h_sSupIndep_B : sSupIndep (B N hN') := hB' N hN'\n    have h_x_in_B : x ∈ B N hN' := hx''\n    have h_disj : Disjoint x (sSup ((B N hN') \\ {x})) := h_sSupIndep_B.disjoint_sSup_mem h_x_in_B\n    have h_le_sSup_diff : a ≤ sSup ((B N hN') \\ {x}) := by\n      apply le_sSup_of_le _ ha'\n      intro y hy\n      simp only [Set.mem_diff, Set.mem_iUnion, exists_prop] at hy\n      obtain ⟨M', hM', hy'⟩ := hy\n      obtain ⟨hM'', hy''⟩ := Set.mem_iUnion.mp hy'\n      have h_eq : M' = N := by\n        have h_sub : M' ≤ D.carrier := by aesop\n        have h_unique : M' = N := by\n          apply le_antisymm\n          · exact le_sSup_of_le hM' (le_rfl : M' ≤ M')\n          · exact le_sSup_of_le hN' (le_rfl : N ≤ N)\n        exact h_unique\n      subst h_eq\n      aesop\n    have h_a_bot : a ≤ ⊥ := disjoint_iff.mp h_disj ha h_le_sSup_diff\n    exact h_a_bot",
      "\n    simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hx ha'\n    rcases hx with ⟨N, hN, x_in_B⟩\n    have h_sSup_B : N = sSup (B N hN) := hB N hN\n    have h_sSupIndep_B : sSupIndep (B N hN) := hB' N hN\n    have h_x_not_bot : x ≠ ⊥ := by\n      intro h\n      apply D.not_bot_mem\n      rw [h]\n      exact hN\n    have h_disj : Disjoint x (sSup ((B N hN) \\ {x})) := by\n      apply h_sSupIndep_B.disjoint_sSup\n      · exact x_in_B\n      · intro y hy\n        exact hy\n      · intro h_contra\n        apply h_x_not_bot\n        exact h_contra\n    have h_le_sSup_diff : a ≤ sSup ((B N hN) \\ {x}) := by\n      apply le_sSup_of_le_sSup_of_subset\n      · intro y hy\n        simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hy\n        rcases hy with ⟨N', hN', y_in_B, y_ne_x⟩\n        by_cases h_eq : N' = N\n        · subst h_eq\n          exact ⟨y_in_B, y_ne_x⟩\n        · exfalso\n          have h_disj_NN' : Disjoint N N' := by\n            apply D.sSupIndep'.disjoint_sSup\n            · exact hN\n            · intro z hz\n              simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp] at hz\n              rcases hz with ⟨_, hN_z, _, _⟩\n              exact hN_z\n            · intro h_contra\n              apply D.not_bot_mem\n              rw [h_contra]\n              exact hN\n          have h_y_le_N' : y ≤ N' := by\n            rw [← hB N' hN']\n            apply le_sSup\n            exact y_in_B\n          have h_y_le_N : y ≤ N := by\n            apply le_trans ha\n            apply le_sSup\n            simp only [Set.mem_iUnion, Set.mem_diff, Set.mem_singleton_iff, and_imp]\n            use N, hN, x_in_B\n          have h_y_le_inf : y ≤ N ⊓ N' := le_inf h_y_le_N h_y_le_N'\n          have h_y_bot : y ≤ ⊥ := by\n            rw [disjoint_iff_inf_le] at h_disj_NN'\n            exact h_y_le_inf.trans h_disj_NN'\n          have h_y_eq_bot : y = ⊥ := by\n            apply le_bot_iff.mp h_y_bot\n          apply hB'' N' hN'\n          rw [h_y_eq_bot]\n          exact y_in_B\n      · exact ha'\n    have h_a_le_inf : a ≤ x ⊓ sSup ((B N hN) \\ {x}) := le_inf ha h_le_sSup_diff\n    have h_a_bot : a ≤ ⊥ := by\n      rw [disjoint_iff_inf_le] at h_disj\n      exact h_a_le_inf.trans h_disj\n    exact h_a_bot",
