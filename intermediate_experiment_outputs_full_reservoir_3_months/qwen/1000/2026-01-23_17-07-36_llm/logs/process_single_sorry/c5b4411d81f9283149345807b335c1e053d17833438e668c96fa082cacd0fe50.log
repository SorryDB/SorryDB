  have h_unique : ∀ a b : ℕ, a ∈ S → b ∈ S → a * b = x ^ 2 + x + k → ∀ c d : ℕ, c ∈ S → d ∈ S → c * d = x ^ 2 + x + k → (a = c ∧ b = d) ∨ (a = d ∧ b = c) := by
    intros a b ha hb hab c d hc hd hcd
