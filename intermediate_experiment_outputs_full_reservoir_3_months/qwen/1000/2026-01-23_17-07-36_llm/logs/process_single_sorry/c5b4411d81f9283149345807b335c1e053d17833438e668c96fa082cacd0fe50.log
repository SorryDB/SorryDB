      "\n  have hS' : S.Nonempty := by\n    cases' S.eq_empty_or_nonempty with h h\n    · exfalso\n      rcases hp₁ ⟨0, by simp [h]⟩ with ⟨x, hx, _⟩\n      linarith\n    · exact h\n  cases' S.card_pos.mpr hS' with n hn\n  haveI : Fintype (Fin n) := inferInstance\n  have h1 : Function.Injective p₁ := Equiv.injective p₁\n  have h2 : Function.Injective p₂ := Equiv.injective p₂\n  have h3 : ∀ a b : ℕ, a ∈ S → b ∈ S → a * b = x^2 + x + k → a = b → False := by\n    intro a b ha hb hab heq\n    rw [heq] at hab\n    have hodd : Odd a := (hS a ha).1\n    have hprime : Nat.Prime a := (hS a ha).2\n    have hpos : 0 < a := Nat.Prime.pos hprime\n    have h4 : a * a = x^2 + x + k := hab\n    have h5 : x^2 < x^2 + x + k := by nlinarith\n    have h6 : x^2 + x + k < (x + 1)^2 := by nlinarith\n    have h7 : x^2 < a^2 ∧ a^2 < (x + 1)^2 := by\n      constructor <;> nlinarith\n    have h8 : x < a ∧ a < x + 1 := by\n      constructor <;> nlinarith\n    linarith\n  have h4 : ∀ i, ∃! x : ℕ, 0 < x ∧ (p₁ i * p₁ (i + 1) = x^2 + x + k) := by\n    intro i\n    refine' ⟨_, _⟩\n    · exact (hp₁ i).some\n    · intro y hy\n      have h5 : p₁ i * p₁ (i + 1) = y^2 + y + k := hy.2\n      have h6 : p₁ i * p₁ (i + 1) = (hp₁ i).some^2 + (hp₁ i).some + k := (hp₁ i).some_spec.2\n      have h7 : y = (hp₁ i).some := by\n        nlinarith\n      exact h7\n  have h5 : ∀ i, ∃! x : ℕ, 0 < x ∧ (p₂ i * p₂ (i + 1) = x^2 + x + k) := by\n    intro i\n    refine' ⟨_, _⟩\n    · exact (hp₂ i).some\n    · intro y hy\n      have h6 : p₂ i * p₂ (i + 1) = y^2 + y + k := hy.2\n      have h7 : p₂ i * p₂ (i + 1) = (hp₂ i).some^2 + (hp₂ i).some + k := (hp₂ i).some_spec.2\n      have h8 : y = (hp₂ i).some := by\n        nlinarith\n      exact h8\n  have h6 : ∀ i j, p₁ i = p₁ j → i = j := h1\n  have h7 : ∀ i j, p₂ i = p₂ j → i = j := h2\n  have h8 : S.card ≤ 2 → (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by\n    intro hcard\n    interval_cases S.card <;> simp_all [Fin.forall_fin_two]\n    <;> try { left; use 0; intro j; cases j <;> simp_all }\n    <;> try { right; use 0; intro j; cases j <;> simp_all }\n  have h9 : S.card > 2 → (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by\n    intro hcard\n    have h10 : ∀ i, p₁ i ≠ p₁ (i + 1) := by\n      intro i\n      intro h\n      have h11 : p₁ i * p₁ (i + 1) = p₁ i ^ 2 := by rw [h]\n      rcases hp₁ i with ⟨x, hx, h12⟩\n      have h13 : p₁ i ^ 2 = x^2 + x + k := by rw [←h12, h11]\n      have h14 : x^2 < x^2 + x + k := by nlinarith\n      have h15 : x^2 + x + k < (x + 1)^2 := by nlinarith\n      have h16 : x^2 < p₁ i ^ 2 ∧ p₁ i ^ 2 < (x + 1)^2 := by\n        constructor <;> nlinarith\n      have h17 : x < p₁ i ∧ p₁ i < x + 1 := by\n        constructor <;> nlinarith\n      linarith\n    have h11 : ∀ i, p₂ i ≠ p₂ (i + 1) := by\n      intro i\n      intro h\n      have h12 : p₂ i * p₂ (i + 1) = p₂ i ^ 2 := by rw [h]\n      rcases hp₂ i with ⟨x, hx, h13⟩\n      have h14 : p₂ i ^ 2 = x^2 + x + k := by rw [←h13, h12]\n      have h15 : x^2 < x^2 + x + k := by nlinarith\n      have h16 : x^2 + x + k < (x + 1)^2 := by nlinarith\n      have h17 : x^2 < p₂ i ^ 2 ∧ p₂ i ^ 2 < (x + 1)^2 := by\n        constructor <;> nlinarith\n      have h18 : x < p₂ i ∧ p₂ i < x + 1 := by\n        constructor <;> nlinarith\n      linarith\n    have h12 : ∀ i, ∃ j, p₂ i = p₁ j := by\n      intro i\n      have h13 : p₂ i ∈ S := by simp [Equiv.apply_symm_apply]\n      have h14 : p₂ i ∈ Set.range p₁ := by\n        rw [Set.mem_range]\n        use (p₁.symm (p₂ i))\n        simp\n      rcases h14 with ⟨j, hj⟩\n      use j\n      exact hj\n    have h13 : ∀ i, ∃! j, p₂ i = p₁ j := by\n      intro i\n      refine' ⟨_, _⟩\n      · rcases h12 i with ⟨j, hj⟩\n        exact j\n      · intro j1 j2 hj1 hj2\n        have h14 : p₁ j1 = p₁ j2 := by rw [←hj1, ←hj2]\n        exact h6 j1 j2 h14\n    have h14 : ∃ f : Fin n → Fin n, ∀ i, p₂ i = p₁ (f i) := by\n      use fun i => Classical.choose (h13 i)\n      intro i\n      exact Classical.choose