      "\n  have hS' : S.Nonempty := by\n    cases' S.eq_empty_or_nonempty with h h <;> simp_all\n  have hS'' : S.card ≥ 1 := Finset.card_pos.mpr hS'\n  have hS''' : S.card ≥ 2 ∨ S.card = 1 := by omega\n  cases' hS''' with hge h1\n  ·\n    have h_unique : ∀ a b : ℕ, a ∈ S → b ∈ S → a * b = x^2 + x + k → ∃! x : ℕ, 0 < x ∧ a * b = x^2 + x + k := by\n      intro a b ha hb hab\n      use Nat.find (exists_eq_sq_add_sq_add_k hab)\n      constructor\n      ·\n        exact Nat.find_spec (exists_eq_sq_add_sq_add_k hab)\n      ·\n        intro y hy\n        exact Nat.find_min (exists_eq_sq_add_sq_add_k hab) hy\n    have h_inj : Function.Injective p₁ := Equiv.injective p₁\n    have h_inj' : Function.Injective p₂ := Equiv.injective p₂\n    have h_surj : Function.Surjective p₁ := Equiv.surjective p₁\n    have h_surj' : Function.Surjective p₂ := Equiv.surjective p₂\n    have h_cycle : ∀ i, ∃! x : ℕ, 0 < x ∧ (p₁ i : ℕ) * (p₁ (i + 1) : ℕ) = x^2 + x + k := by\n      intro i\n      exact h_unique (p₁ i) (p₁ (i + 1)) (p₁.surjective i) (p₁.surjective (i + 1)) (hp₁ i)\n    have h_cycle' : ∀ i, ∃! x : ℕ, 0 < x ∧ (p₂ i : ℕ) * (p₂ (i + 1) : ℕ) = x^2 + x + k := by\n      intro i\n      exact h_unique (p₂ i) (p₂ (i + 1)) (p₂.surjective i) (p₂.surjective (i + 1)) (hp₂ i)\n    have h_match : ∀ i j, p₁ i = p₂ j → p₁ (i + 1) = p₂ (j + 1) ∨ p₁ (i + 1) = p₂ (j - 1) := by\n      intro i j hij\n      have h_prod : (p₁ i : ℕ) * (p₁ (i + 1) : ℕ) = (p₂ j : ℕ) * (p₂ (j + 1) : ℕ) ∨ (p₁ i : ℕ) * (p₁ (i + 1) : ℕ) = (p₂ j : ℕ) * (p₂ (j - 1) : ℕ) := by\n        apply Or.intro_left\n        rw [← hij]\n        exact Eq.symm (congrArg (fun x => x * _) (hp₁ i).choose_spec.2 ▸ (hp₂ j).choose_spec.2)\n      cases' h_prod with hprod hprod <;> simp_all [mul_right_inj, Nat.Prime.ne_zero]\n    have h_start : ∃ i, p₂ 0 = p₁ i := h_surj (p₂ 0)\n    cases' h_start with i hi\n    left\n    use -i\n    intro j\n    induction j using Fin.induction_on with\n    | zero => simp_all [Fin.add_zero]\n    | succ j ih =>\n      sp