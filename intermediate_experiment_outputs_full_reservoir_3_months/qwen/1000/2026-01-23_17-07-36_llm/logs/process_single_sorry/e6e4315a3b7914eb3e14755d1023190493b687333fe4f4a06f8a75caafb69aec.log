      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_cadlag : ‚ąÄ ŌČ, IsCadlag (X ¬∑ ŌČ) := hX.cadlag\n  have h_bounded : ‚®Ü i, eLpNorm (X i) 2 P < ‚ąě := hX.bounded\n  refine ‚ü®?_, ?_‚ü©\n  ¬∑ intro i\n    have h_adapted : Adapted ūĚďē X := h_mart.adapted\n    exact (h_adapted i).norm.pow 2\n  ¬∑ intro i j hij ŌČ\n    have h_cond : ‚ąÄŠĶź ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚Č§ ENNReal.ofReal (‚ąę‚ĀĽ ŌČ, ‚ÄĖX j ŌČ‚ÄĖ ^ 2 ‚ąā(P.restrict (ūĚďē i))) := by\n      apply h_mart.condexp_norm_sq_le hj\n    exact h_cond",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_int : ‚ąÄ i, Integrable (fun ŌČ ‚Ü¶ ‚ÄĖX i ŌČ‚ÄĖ ^ 2) P := fun i ‚Ü¶ hX.integrable_sq i\n  refine ‚ü®fun i ‚Ü¶ (hX.martingale.adapted i).norm.pow 2 |>.mono (ūĚďē.le i),\n    fun i j hij ŌČ ‚Ü¶ ?_‚ü©\n  have h_cond : ‚ąÄŠĶź ŌČ ‚ąāP, ENNReal.ofReal (‚ąę x, ‚ÄĖX j x‚ÄĖ ^ 2 ‚ąā(P.cond (ūĚďē i))) ŌČ ‚Č•\n      ENNReal.ofReal (‚ąę x, ‚ÄĖX i x‚ÄĖ ^ 2 ‚ąā(P.cond (ūĚďē i))) ŌČ := by\n    apply h_mart.norm_sq_submartingale hj\n  exact h_cond",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_int : ‚ąÄ i, Integrable (fun ŌČ ‚Ü¶ ‚ÄĖX i ŌČ‚ÄĖ ^ 2) P := fun i ‚Ü¶ hX.integrable_sq i\n  refine ‚ü®fun i ‚Ü¶ (hX.martingale.adapted i).norm_sq, fun i j hij ‚Ü¶ ?_‚ü©\n  have h_cond : ‚ąÄŠĶź ŌČ, ‚ąę x in ūĚďē i, X j x ‚ąāP = X i ŌČ := h_mart.condexp_eq hij\n  calc\n    ‚ąÄŠĶź ŌČ, ‚ąę x in ūĚďē i, ‚ÄĖX j x‚ÄĖ ^ 2 ‚ąāP ‚Č• ‚ÄĖ‚ąę x in ūĚďē i, X j x ‚ąāP‚ÄĖ ^ 2 := by\n      exact eventually_of_forall fun ŌČ ‚Ü¶ by\n        simpa using norm_condexp_le_Lp_sq_norm (h_mart.adapted j).aestronglyMeasurable P\n    _ = ‚ÄĖX i ŌČ‚ÄĖ ^ 2 := by\n      filter_upwards [h_cond] with ŌČ hŌČ\n      rw [hŌČ]",
      "\n  refine ‚ü®?_, ?_, ?_‚ü©\n  ¬∑ intro i\n    have h_meas : Measurable (X i) := (hX.martingale.adapted i).measurable\n    exact h_meas.norm.pow 2\n  ¬∑ intro i\n    exact hX.integrable_sq i\n  ¬∑ intro i j hij\n    have h_cond : ‚ąÄŠĶź ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚Č§ ‚®Ö (k ‚Č• i), ‚ÄĖX k ŌČ‚ÄĖ ^ 2 := by\n      apply hX.martingale.condexp_submartingale_sq_norm hij\n    filter_upwards [h_cond] with ŌČ\n    exact le_iInf_of_le j (le_refl _) (by simp_all)",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_int : ‚ąÄ i, Integrable (fun ŌČ ‚Ü¶ ‚ÄĖX i ŌČ‚ÄĖ ^ 2) P := fun i ‚Ü¶ hX.integrable_sq i\n  refine ‚ü®fun i ‚Ü¶ (hX.martingale.adapted i).norm.pow 2 |>.mono (ūĚďē.le i),\n    fun i j hij ŌČ ‚Ü¶ ?_‚ü©\n  have h_cond : ‚ąÄŠĶź ŌČ, ‚ąę x, X j x ‚ąā(P.cond (ūĚďē i)) = X i ŌČ := h_mart.condexp_eq hij\n  have h_norm_sq : ‚ąÄŠĶź ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚Č§ ‚ąę x, ‚ÄĖX j x‚ÄĖ ^ 2 ‚ąā(P.cond (ūĚďē i)) := by\n    filter_upwards [h_cond] with ŌČ hŌČ\n    exact ENNReal.ofReal_le_ofReal (by\n      calc ‚ÄĖX i ŌČ‚ÄĖ ^ 2\n          = ‚ÄĖ‚ąę x, X j x ‚ąā(P.cond (ūĚďē i))‚ÄĖ ^ 2 := by rw [hŌČ]\n        _ ‚Č§ (‚ąę x, ‚ÄĖX j x‚ÄĖ ‚ąā(P.cond (ūĚďē i))) ^ 2 := by\n            exact norm_integral_le_integral_norm _ _\n        _ ‚Č§ ‚ąę x, ‚ÄĖX j x‚ÄĖ ^ 2 ‚ąā(P.cond (ūĚďē i)) := by\n            exact Real.sq_integral_le_integral_sq (P.cond (ūĚďē i))\n              ((hX.martingale.adapted j).mono (ūĚďē.le j)).aestronglyMeasurable)\n  exact h_norm_sq",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_int : ‚ąÄ i, Integrable (fun ŌČ ‚Ü¶ ‚ÄĖX i ŌČ‚ÄĖ ^ 2) P := fun i ‚Ü¶ hX.integrable_sq i\n  refine ‚ü®fun i ‚Ü¶ (hX.martingale.adapted i).norm_sq, h_int, fun i j hij ŌČ ‚Ü¶ ?_‚ü©\n  exact ENNReal.ofReal_le_ofReal (by\n    have := h_mart.condexp_mono hij ŌČ\n    simp_all [condexp_norm_sq_le_of_martingale])",
      "\n  refine ‚ü®fun i ‚Ü¶ (hX.integrable_sq i).mono (ūĚďē.le i), fun i j hij ŌČ ‚Ü¶ ?_‚ü©\n  have h_mart : ‚ąÄ k l, k ‚Č§ l ‚Üí ‚ąę x, X l x ‚ąāP = ‚ąę x, X k x ‚ąāP := by\n    intro k l hkl\n    exact (hX.martingale.eq_condexp_of_le hkl).symm ‚Ėł rfl\n  calc\n    ‚ąę x, ‚ÄĖX i x‚ÄĖ ^ 2 ‚ąāP\n      = ‚ąę x, ‚ÄĖ(ūĚĒľ[X j | ūĚďē i]) x‚ÄĖ ^ 2 ‚ąāP := by\n        rw [‚Üź hX.martingale.eq_condexp_of_le hij]\n      _ ‚Č§ ‚ąę x, ‚ÄĖX j x‚ÄĖ ^ 2 ‚ąāP := by\n        apply condexp_norm_sq_le_integral_sq\n        exact (hX.martingale.adapted j).aestronglyMeasurable\n        exact hX.integrable_sq j",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_cadlag : ‚ąÄ ŌČ, IsCadlag (X ¬∑ ŌČ) := hX.cadlag\n  have h_bounded : ‚®Ü i, eLpNorm (X i) 2 P < ‚ąě := hX.bounded\n  refine submartingale_of_martingale_sq_norm h_mart ?_\n  exact fun i ‚Ü¶ hX.integrable_sq i",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_int : ‚ąÄ i, Integrable (fun ŌČ ‚Ü¶ ‚ÄĖX i ŌČ‚ÄĖ ^ 2) P := fun i ‚Ü¶ hX.integrable_sq i\n  refine ‚ü®fun i ‚Ü¶ (h_int i).aestronglyMeasurable, fun i j hij ŌČ ‚Ü¶ ?_‚ü©\n  have h_cond : AE P, fun ŌČ ‚Ü¶ ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚Č§ ūĚĒľ[P.ConditionalExpectation (ūĚďē i)] (fun ŌČ ‚Ü¶ ‚ÄĖX j ŌČ‚ÄĖ ^ 2) ŌČ := by\n    have h_mart_prop : ‚ąÄ k l, k ‚Č§ l ‚Üí AE P, fun ŌČ ‚Ü¶ X k ŌČ = ūĚĒľ[P.ConditionalExpectation (ūĚďē k)] (X l) ŌČ :=\n      h_mart.property\n    have h_jensen : ‚ąÄ k l, k ‚Č§ l ‚Üí AE P, fun ŌČ ‚Ü¶ ‚ÄĖX k ŌČ‚ÄĖ ^ 2 ‚Č§ ūĚĒľ[P.ConditionalExpectation (ūĚďē k)] (fun ŌČ ‚Ü¶ ‚ÄĖX l ŌČ‚ÄĖ ^ 2) ŌČ := by\n      intro k l hkl\n      have h_cond_exp : AE P, fun ŌČ ‚Ü¶ X k ŌČ = ūĚĒľ[P.ConditionalExpectation (ūĚďē k)] (X l) ŌČ := h_mart_prop k l hkl\n      have h_convex : ConvexOn ‚ĄĚ (Set.univ : Set E) (fun x ‚Ü¶ ‚ÄĖx‚ÄĖ ^ 2) := by\n        exact norm_sq_convex ‚ĄĚ E\n      exact h_convex.ae_conditional_expectation_le (h_mart.adapted k).aestronglyMeasurable\n        (h_mart.adapted l).aestronglyMeasurable h_cond_exp\n    exact h_jensen i j hij\n  exact h_cond",
      "\n  refine ‚ü®fun i ‚Ü¶ ?_, fun i j hij ‚Ü¶ ?_‚ü©\n  ¬∑ exact hX.integrable_sq i\n  ¬∑ have h_mart : Martingale X ūĚďē P := hX.martingale\n    have h_adapted : Adapted ūĚďē X := h_mart.adapted\n    have h_cond_exp : ‚ąÄ i j, i ‚Č§ j ‚Üí ENNReal.ofReal (‚ąę‚ĀĽ ŌČ, ‚ÄĖX j ŌČ‚ÄĖ ^ 2 ‚ąāP) ‚Č• ENNReal.ofReal (‚ąę‚ĀĽ ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚ąāP) := by\n      intro i j hij\n      have h_eq : ‚ąÄ A ‚ąą ūĚďē i, ‚ąę (ŌČ in A), X j ŌČ ‚ąāP = ‚ąę (ŌČ in A), X i ŌČ ‚ąāP := h_mart.eq i j hij\n      have h_sq : ‚ąÄ A ‚ąą ūĚďē i, ‚ąę (ŌČ in A), ‚ÄĖX j ŌČ‚ÄĖ ^ 2 ‚ąāP ‚Č• ‚ąę (ŌČ in A), ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚ąāP := by\n        intro A hA\n        have h_cond : ‚ąÄŠĶź ŌČ ‚ąāP, ŌČ ‚ąą A ‚Üí ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚Č§ ‚®Ö (B ‚ąą ūĚďē i) (_ : ŌČ ‚ąą B), ‚ąę (x in B), ‚ÄĖX j x‚ÄĖ ^ 2 ‚ąāP / P B := by\n          sorry\n        sorry\n      sorry\n    sorry",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_cadlag : ‚ąÄ ŌČ, IsCadlag (X ¬∑ ŌČ) := hX.cadlag\n  have h_bounded : ‚®Ü i, eLpNorm (X i) 2 P < ‚ąě := hX.bounded\n  refine ‚ü®?_, ?_‚ü©\n  ¬∑ intro i\n    have h_adapted : Adapted ūĚďē (X i) := (h_mart.adapted i)\n    exact h_adapted.mono (ūĚďē.le i) |>.norm.pow 2\n  ¬∑ intro i j hij ŌČ\n    have h_cond : ‚ąÄŠĶź ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚Č§ ūĚĒľ[fun ŌČ' ‚Ü¶ ‚ÄĖX j ŌČ'‚ÄĖ ^ 2 | ūĚďē i] ŌČ := by\n      have h_mart_prop : ‚ąÄŠĶź ŌČ, X i ŌČ = ūĚĒľ[X j | ūĚďē i] ŌČ := h_mart.conditional_expectation hij\n      have h_jensen : ‚ąÄŠĶź ŌČ, ‚ÄĖūĚĒľ[X j | ūĚďē i] ŌČ‚ÄĖ ^ 2 ‚Č§ ūĚĒľ[fun ŌČ' ‚Ü¶ ‚ÄĖX j ŌČ'‚ÄĖ ^ 2 | ūĚďē i] ŌČ :=\n        condexp_norm_pow_le_two_nonneg (hY := (h_mart.adapted j).mono (ūĚďē.le j)).aestronglyMeasurable\n      filter_upwards [h_mart_prop, h_jensen] with ŌČ h_eq h_ineq\n      rw [‚Üź h_eq]\n      exact h_ineq\n    exact h_cond",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_cadlag : ‚ąÄ ŌČ, IsCadlag (X ¬∑ ŌČ) := hX.cadlag\n  have h_bounded : ‚®Ü i, eLpNorm (X i) 2 P < ‚ąě := hX.bounded\n  refine ‚ü®?_, ?_‚ü©\n  ¬∑ intro i\n    have h_adapted : Adapted ūĚďē (X i) := (h_mart.adapted i)\n    exact h_adapted.mono (ūĚďē.le i) |>.norm.pow 2\n  ¬∑ intro i j hij ŌČ\n    have h_cond : ūĚĒľ[fun ŌČ' ‚Ü¶ X j ŌČ'] ūĚďē i ŌČ = X i ŌČ := h_mart.condexp_eq hij ŌČ\n    calc\n      ‚ÄĖX i ŌČ‚ÄĖ ^ 2 = ‚ÄĖūĚĒľ[fun ŌČ' ‚Ü¶ X j ŌČ'] ūĚďē i ŌČ‚ÄĖ ^ 2 := by rw [h_cond]\n      _ ‚Č§ ūĚĒľ[fun ŌČ' ‚Ü¶ ‚ÄĖX j ŌČ'‚ÄĖ ^ 2] ūĚďē i ŌČ := by\n        apply norm_condexp_le_condexp_norm\n        exact (h_mart.adapted j).mono (ūĚďē.le j) |>.aestronglyMeasurable",
      "\n  have h_mart : Martingale X ūĚďē P := hX.martingale\n  have h_int : ‚ąÄ i, Integrable (fun ŌČ ‚Ü¶ ‚ÄĖX i ŌČ‚ÄĖ ^ 2) P := fun i ‚Ü¶ hX.integrable_sq i\n  refine ‚ü®fun i ‚Ü¶ (hX.martingale.adapted i).norm.pow 2 |>.mono (ūĚďē.le i),\n    fun i j hij ŌČ ‚Ü¶ ?_‚ü©\n  calc\n    ‚ąę‚ĀĽ ŌČ, ‚ÄĖX j ŌČ‚ÄĖ ^ 2 ‚ąāP\n      = ‚ąę‚ĀĽ ŌČ, ‚ÄĖX i ŌČ + (X j ŌČ - X i ŌČ)‚ÄĖ ^ 2 ‚ąāP := by congr 1; exact_funext fun ŌČ ‚Ü¶ by simp [add_sub_cancel]\n    _ ‚Č• ‚ąę‚ĀĽ ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚ąāP := by\n      have h_ortho : ‚ąÄŠĶź ŌČ ‚ąāP, ‚ü™X i ŌČ, X j ŌČ - X i ŌČ‚üę = 0 := by\n        apply h_mart.orthogonal_diff hij\n      have h_nonneg : 0 ‚Č§ ‚ąę‚ĀĽ ŌČ, ‚ÄĖX j ŌČ - X i ŌČ‚ÄĖ ^ 2 ‚ąāP := by positivity\n      calc\n        ‚ąę‚ĀĽ ŌČ, ‚ÄĖX i ŌČ + (X j ŌČ - X i ŌČ)‚ÄĖ ^ 2 ‚ąāP\n          = ‚ąę‚ĀĽ ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 + 2 * ‚ü™X i ŌČ, X j ŌČ - X i ŌČ‚üę + ‚ÄĖX j ŌČ - X i ŌČ‚ÄĖ ^ 2 ‚ąāP := by\n            simp [norm_add_sq, inner_add_left, inner_add_right, mul_add, add_mul]\n        _ = ‚ąę‚ĀĽ ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚ąāP + ‚ąę‚ĀĽ ŌČ, ‚ÄĖX j ŌČ - X i ŌČ‚ÄĖ ^ 2 ‚ąāP := by\n            simp [lintegral_add, lintegral_const_mul, h_ortho, h_nonneg]\n        _ ‚Č• ‚ąę‚ĀĽ ŌČ, ‚ÄĖX i ŌČ‚ÄĖ ^ 2 ‚ąāP := by simp [le_add_iff_nonneg_right, h_nonneg]",
