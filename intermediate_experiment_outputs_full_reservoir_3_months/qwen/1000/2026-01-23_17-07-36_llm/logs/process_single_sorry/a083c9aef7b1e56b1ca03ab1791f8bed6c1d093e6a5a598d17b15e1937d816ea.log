theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, LabelledTree.mem]
    <;> aesop
  | node v l r ihl ihr =>
    simp [fastCheckMem, LabelledTree.mem, IsOrdered] at h ⊢
    rcases h with ⟨hl, hr, hl_ord, hr_ord, hv⟩
    split
    · intro h_fast
      cases le_or_lt label v with
      | inl h_le =>
        if h_eq : label = v then
          simp_all
        else
          have : label < v := lt_of_le_of_ne h_le h_eq
          simp_all
          exact Or.inl (ihl hl hl_ord this)
      | inr h_lt =>
        simp_all
        exact Or.inr (ihr hr hr_ord h_lt)
    · intro h_mem
      cases h_mem with
      | inl h_mem_l =>
        cases le_or_lt label v with
        | inl h_le =>
          if h_eq : label = v then
            simp_all
          else
            have : label < v := lt_of_le_of_ne h_le h_eq
            simp_all
            exact ihl.1 h_mem_l
        | inr h_lt =>
          exfalso
          have : ∀ x ∈ l, x ≤ v := hl
          have : label ≤ v := this _ h_mem_l
          exact h_lt.not_le this
      | inr h_mem_r =>
        cases le_or_lt label v with
        | inl h_le =>
          exfalso
          have : ∀ x ∈ r, v ≤ x := hr
          have : v ≤ label := this _ h_mem_r
          exact h_le.not_lt (lt_of_le_of_ne this (Ne.symm (Ne.symm ‹_›)))
        | inr h_lt =>
          simp_all
          exact ihr.1 h_mem_r
