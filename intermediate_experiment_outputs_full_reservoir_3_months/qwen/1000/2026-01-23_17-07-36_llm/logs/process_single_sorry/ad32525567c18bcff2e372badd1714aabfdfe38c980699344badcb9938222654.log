import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  apply Set.ext
  intro n
  constructor
  · intro h
    obtain ⟨n_pos, A, B, hA_sub_B, hA_card, hA_inter, hB_cov, hf⟩ := h
    obtain ⟨f, hf_val, hf_bal⟩ := hf
    have h_sum : ∑ i : Fin (2 * n + 1), ((A i).filter (f · = 0)).card = (2 * n + 1) * n := by
      simp [hf_bal, Finset.sum_const, Finset.card_fin]
    have h_double_count : ∑ x in B, (Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ)) *
      (if f x = 0 then 1 else 0) = (2 * n + 1) * n := by
      rw [← h_sum]
      clear h_sum
      simp_rw [Finset.sum_filter, Finset.sum_comm]
      congr
      ext x
      simp [Nat.cast_inj, hf_val]
    have h_r : ∀ x ∈ B, 2 ≤ Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) := by
      intro x hx
      obtain ⟨i, j, hij, hxi, hxj⟩ := hB_cov x hx
      exact by
        apply Finset.le_card_of_subset
        intro k hk
        simp at hk
        aesop
        apply Finset.mem_filter.mpr
        constructor
        · exact hk
        · aesop
    have h_even : Even ((2 * n + 1) * n) := by
      have h_total : ∑ x in B, (Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ)) *
        (if f x = 0 then 1 else 0) % 2 = 0 := by
        apply Nat.mod_eq_zero_of_dvd
        apply Nat.dvd_of_mod_eq_zero
        rw [h_double_count]
        simp [Nat.mul_mod, Nat.add_mod, Nat.mod_mod]
      simp_all [Nat.even_iff, Nat.mul_mod, Nat.add_mod]
    rw [Nat.even_mul] at h_even
    cases' h_even with h_even_left h_even_right
    · contradiction
    · exact h_even_right
  · intro h
    obtain ⟨hn_pos, hn_even⟩ := h
    use hn_pos
    use fun i => Finset.univ.filter (fun x => x.1 < 2 * n)
    use Finset.univ.filter (fun x => x.1 < 2 * n)
    repeat' constructor
    · intro i
      simp
    · intro i
      simp [Finset.card_filter, hn_pos]
    · intro i j hij
      simp [Finset.card_filter, hij]
    · intro x hx
      use 0, 1
      simp [hx, hn_pos]
    · use fun x => if x % 2 = 0 then 0 else 1
      constructor
      · intro x hx
        simp
      · intro i
        simp [Finset.card_filter, hn_even]
