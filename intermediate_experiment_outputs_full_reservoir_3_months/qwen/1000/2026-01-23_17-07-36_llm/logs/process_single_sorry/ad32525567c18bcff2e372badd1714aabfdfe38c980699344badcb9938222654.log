 % 2 else 0) % 2 := by\n        rw [h_total_zeros_alt]\n        simp [Finset.sum_mod, Nat.mul_mod]\n      rw [h_total_zeros_mod2]\n      simp_all [Nat.odd_mul, Nat.odd_add, Nat.odd_two_mul]\n    exact ⟨n_pos, Nat.even_iff.mp h_even⟩\n  · rintro ⟨n_pos, hn_even⟩\n    use n_pos\n    use fun i => Finset.univ.erase i\n    use Finset.univ\n    constructor\n    · intro i\n      apply Finset.erase_subset\n    constructor\n    · intro i\n      simp [Finset.card_erase_of_mem, Finset.mem_univ, Nat.succ_ne_zero]\n    constructor\n    · intro i j hij\n      simp [Finset.card_inter_erase_of_ne hij, Finset.mem_univ, Nat.succ_ne_zero]\n    constructor\n    · intro x hx\n      use 0, 1\n      simp_all [Finset.mem_univ, Nat.succ_ne_zero]\n    use fun x => if x % 2 = 0 then 0 else 1\n    constructor\n    · intro x hx\n      by_cases hx' : x % 2 = 0 <;> simp_all\n    intro i\n    have h_card : (Finset.univ.erase i).card = 2 * n := by\n      simp [Finset.card_erase_of_mem, Finset.mem_univ, Nat.succ_ne_zero]\n    have h_num_zeros : ((Finset.univ.erase i).filter (fun x => x % 2 = 0)).card = n := by\n      have h_even_n : Even n := hn_even\n      have h_even_2n : Even (2 * n) := by\n        apply Nat.even_mul_left\n        apply Nat.even_two\n      have h_num_evens : Finset.card (Finset.filter (fun x => x % 2 = 0) (Finset.range (2 * n + 1))) = n + 1 := by\n        simp [Finset.card_filter_range_even, h_even_2n]\n      have h_i_even : (i : ℕ) % 2 = 0 ∨ (i : ℕ) % 2 = 1 := by\n        omega\n      cases h_i_even with\n      | inl hi_even =>\n        calc\n          ((Finset.univ.erase i).filter (fun x => x % 2 = 0)).card\n            = (Finset.filter (fun x => x % 2 = 0) (Finset.range (2 * n + 1))).card - 1 := by\n              simp [Finset.filter_erase, hi_even]\n          _ = (n + 1) - 1 := by rw [h_num_evens]\n          _ = n := by simp\n      | inr hi_odd =>\n        calc\n          ((Finset.univ.erase i).filter (fun x => x % 2 = 0)).card\n            = (Finset.filter (fun x => x % 2 = 0) (Finset.range (2 * n + 1))).card := by\n              simp [Finset.filter_erase, hi_odd]\n          _ = n + 1 := by rw [h_num_evens]\n          _ = n := by\n              have h_even_n' : n % 2 = 0 := Nat.even_iff.mp h_even_n\n              omega\n    simp_all",
      "\n  ext n\n  constructor\n  · intro h\n    obtain ⟨n_pos, A, B, hA_sub_B, hA_card, hA_inter, hB_cov, ⟨f, hf_val, hf_bal⟩⟩ := h\n    have h_total_zero := ∑ i : Fin (2 * n + 1), ((A i).filter (f · = 0)).card\n    rw [Finset.sum_const, Nat.mul_comm]\n    · simp_all only [Finset.card_fin, Nat.cast_add, Nat.cast_one, Nat.cast_mul, Nat.cast_ofNat]\n      have h_double_count : ∑ x in B, (Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ)) =\n        ∑ i : Fin (2 * n + 1), (A i).card := by\n        apply Finset.sum_comm\n      have h_double_count_zero : ∑ x in B, (Finset.card (Finset.filter (fun i => x ∈ A i ∧ f x = 0) Finset.univ)) =\n        ∑ i : Fin (2 * n + 1), ((A i).filter (f · = 0)).card := by\n        apply Finset.sum_comm\n      rw [h_total_zero] at h_double_count_zero\n      have h_even : Even (∑ x in B, (Finset.card (Finset.filter (fun i => x ∈ A i ∧ f x = 0) Finset.univ))) := by\n        rw [h_double_count_zero]\n        exact even_mul_left _ _\n      have h_each_at_least_two : ∀ x ∈ B, 2 ≤ Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) := by\n        intro x hx\n        obtain ⟨i, j, hij, hxi, hxj⟩ := hB_cov x hx\n        exact Finset.le_card_of_subset (Finset.pair_subset_filter hij hxi hxj) (by simp)\n      have h_parity : ∀ x ∈ B, Even (Finset.card (Finset.filter (fun i => x ∈ A i ∧ f x = 0) Finset.univ)) ↔ f x = 0 := by\n        intro x hx\n        have h_in_A : ∃ k, x ∈ A k := by\n          obtain ⟨i, _, _, hxi, _⟩ := hB_cov x hx\n          exact ⟨i, hxi⟩\n        have h_common : ∀ i j, i ≠ j → x ∈ A i → x ∈ A j → A i ∩ A j = {x} := by\n          intro i j hij hxi hxj\n          have h_inter : (A i ∩ A j).card = 1 := hA_inter i j hij\n          have hx_in_inter : x ∈ A i ∩ A j := ⟨hxi, hxj⟩\n          exact Finset.card_eq_one.mp h_inter ▸ by simp [hx_in_inter]\n        have h_unique : ∀ i j, x ∈ A i → x ∈ A j → i = j ∨ A i ∩ A j = {x} := by\n          intro i j hxi hxj\n          by_cases hij : i = j\n          · exact Or.inl hij