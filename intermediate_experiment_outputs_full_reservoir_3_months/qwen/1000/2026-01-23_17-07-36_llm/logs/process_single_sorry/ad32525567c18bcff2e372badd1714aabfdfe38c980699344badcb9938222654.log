    obtain ⟨n_pos, A, B, hA_sub_B, hA_card, hA_inter, hB_cov, hf⟩ := h
    obtain ⟨f, hf_val, hf_bal⟩ := hf
    have key : (∑ i : Fin (2 * n + 1), ∑ x in A i, f x) = ∑ x in B, f x * (Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ)) := by
      rw [Finset.sum_comm]
