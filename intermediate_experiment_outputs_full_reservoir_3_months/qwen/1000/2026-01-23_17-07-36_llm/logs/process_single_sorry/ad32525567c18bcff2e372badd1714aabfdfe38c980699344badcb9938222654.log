import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  apply Set.ext
  intro n
  constructor
  · intro h
    obtain ⟨n_pos, A, B, hA_sub_B, hA_card, hA_inter, hB_cov, hf⟩ := h
    obtain ⟨f, hf_val, hf_bal⟩ := hf
    have h_sum : ∑ i : Fin (2 * n + 1), ((A i).filter (f · = 0)).card = (2 * n + 1) * n := by
      simp_all [Finset.sum_const, Finset.card_fin]
    have h_sum' : ∑ x in B, (Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ)) *
      (if f x = 0 then 1 else 0) = (2 * n + 1) * n := by
      rw [← h_sum]
      clear h_sum
      simp_rw [Finset.sum_filter, Finset.sum_comm]
      congr
      ext x
      simp [Nat.mul_comm]
    have h_deg : ∀ x ∈ B, 2 ≤ Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) := by
      intro x hx
      obtain ⟨i, j, hij, hxi, hxj⟩ := hB_cov x hx
      have h_mem : i ∈ Finset.filter (fun i => x ∈ A i) Finset.univ := by simp [hxi]
      have h_mem' : j ∈ Finset.filter (fun i => x ∈ A i) Finset.univ := by simp [hxj]
      have h_distinct : i ≠ j := hij
      exact Finset.card_le_of_subset (Finset.insert_subset.mpr ⟨h_mem, Finset.singleton_subset_iff.mpr h_mem'⟩) ▸
        by simp [h_distinct]
    have h_even : Even ((2 * n + 1) * n) := by
      have h_total : (2 * n + 1) * n = ∑ x in B, (Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ)) *
        (if f x = 0 then 1 else 0) := by rw [← h_sum']
      rw [h_total]
      apply Finset.sum_even
      intro x hx
      have h_coeff : 2 ≤ Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) := h_deg x hx
      have h_parity : Even (Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ)) := by
        have h_count : Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) = 
          Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) := rfl
        have h_eq : ∀ i j, i ≠ j → x ∈ A i ∩ A j → False := by
          intro i j hij hx_in
          have h_inter : (A i ∩ A j).card = 1 := hA_inter i j hij
          have h_x_unique : ∀ y ∈ A i ∩ A j, y = x := by
            intro y hy
            have h_card_one : (A i ∩ A j).card = 1 := h_inter
            have h_singleton : A i ∩ A j = {x} := by
              apply Finset.eq_singleton_of_card_one
              exact h_inter
              exact hx_in
            exact Finset.mem_singleton.mp (h_singleton ▸ hy)
          have h_contra : x ∈ A i ∩ A j := hx_in
          have h_other : ∃ k, k ≠ i ∧ k ≠ j ∧ x ∈ A k := by
            have h_ge_three : 3 ≤ Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) := by
              have h_ge_two : 2 ≤ Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) := h_coeff
              have h_not_two : ¬(Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) = 2) := by
                intro h_eq_two
                have h_exactly_two : ∃ i j, i ≠ j ∧
                  Finset.filter (fun k => x ∈ A k) Finset.univ = {i, j} := by
                  apply Finset.exists_eq_insert_of_ncard_eq_succ
                  exact h_eq_two
                obtain ⟨i', j', hij', h_filter_eq⟩ := h_exactly_two
                have h_x_in_i' : x ∈ A i' := by
                  rw [h_filter_eq] at hx
                  simp at hx
                  tauto
                have h_x_in_j' : x ∈ A j' := by
                  rw [h_filter_eq] at hx
                  simp at hx
                  tauto
                have h_inter_card : (A i' ∩ A j').card = 1 := hA_inter i' j' hij'
                have h_x_in_inter : x ∈ A i' ∩ A j' := ⟨h_x_in_i', h_x_in_j'⟩
                have h_only_x : A i' ∩ A j' = {x} := by
                  apply Finset.eq_singleton_of_card_one
                  exact h_inter_card
                  exact h_x_in_inter
                have h_forall_other : ∀ k, k ≠ i' → k ≠ j' → x ∉ A k := by
                  intro k hki hkj
                  have h_k_not_in_filter : k ∉ Finset.filter (fun l => x ∈ A l) Finset.univ := by
                    rw [h_filter_eq]
                    simp [hki, hkj]
                  simp at h_k_not_in_filter
                  exact h_k_not_in_filter
                have h_cover : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j := hB_cov
                have h_x_covered : ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j := h_cover x hx
                obtain ⟨i'', j'', hij'', hxi'', hxj''⟩ := h_x_covered
                have h_i''_eq : i'' = i' ∨ i'' = j' := by
                  have h_i''_in_filter : i'' ∈ Finset.filter (fun l => x ∈ A l) Finset.univ := by simp [hxi'']
                  rw [h_filter_eq] at h_i''_in_filter
                  simp at h_i''_in_filter
                  tauto
                have h_j''_eq : j'' = i' ∨ j'' = j' := by
                  have h_j''_in_filter : j'' ∈ Finset.filter (fun l => x ∈ A l) Finset.univ := by simp [hxj'']
                  rw [h_filter_eq] at h_j''_in_filter
                  simp at h_j''_in_filter
                  tauto
                cases h_i''_eq <;> cases h_j''_eq <;> simp_all
              linarith
            linarith
          exact h_other
        have h_mod_two : Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) % 2 = 0 := by
          have h_total_count : ∑ i : Fin (2 * n + 1), (if x ∈ A i then 1 else 0) =
            Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) := by
