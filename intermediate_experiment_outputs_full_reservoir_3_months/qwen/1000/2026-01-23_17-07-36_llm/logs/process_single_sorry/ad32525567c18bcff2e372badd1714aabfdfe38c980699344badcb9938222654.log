            apply le_antisymm
            · apply Finset.card_le_of_subset (Finset.subset_univ _)
            · have : ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j := hB_cov x hx
              obtain ⟨i, j, hij, hxi, hxj⟩ := this
              have : Finset.card (Finset.filter (fun i => x ∈ A i) Finset.univ) ≥ 2 := by
                apply Finset.card_le_of_subset
