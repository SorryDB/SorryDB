                  apply Finset.eq_singleton_of_card_one
                  exact h_inter_card
                  exact h_x_in_inter
                have h_forall_other : ∀ k, k ≠ i' → k ≠ j' → x ∉ A k := by
                  intro k hki hkj
                  have h_k_not_in_filter : k ∉ Finset.filter (fun l => x ∈ A l) Finset.univ := by
                    rw [h_filter_eq]
                    simp [hki, hkj]
