      · simp [Finset.mem_erase, Nat.succ_le_iff, Nat.lt_succ_iff]
        have h_mod : (x + 1) % (2 * n + 1) ≠ x := by
          apply Nat.mod_eq_of_lt
          linarith
        intro h_mem
        contradiction
    use fun x => if x % 2 = 0 then 0 else 1
    constructor
    · intro x hx
      by_cases h : x % 2 = 0 <;> simp [h]
    intro i
    have h_card : (A i).card = 2 * n := by simp [Finset.card_erase_of_mem]
    have h_even_n : Even n := hn_even
    have h_half : (Finset.filter (fun x => x % 2 = 0) (A i)).card = n := by
      sorry
    simp [h_half]
