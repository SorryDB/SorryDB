(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  constructor
  · intro h
    obtain ⟨n_pos, A, B, hA_sub_B, hA_card, hA_inter, hB_cov, ⟨f, hf_val, hf_bal⟩⟩ := h
    have key_sum : ∑ i : Fin (2 * n + 1), ((A i).filter (f · = 0)).card = (2 * n + 1) * n := by
      simp [hf_bal]
    have key_sum_alt : ∑ i : Fin (2 * n + 1), ((A i).filter (f · = 0)).card =
        ∑ x in B, (Finset.card (Finset.filter (fun i => x ∈ A i ∧ f x = 0) (Finset.univ : Finset (Fin (2 * n + 1))))) := by
      rw [Finset.sum_comm]
      apply Finset.sum_congr rfl
      intro x hx
      simp [Finset.sum_filter, Finset.mem_univ, true_and]
    have h_even : Even ((2 * n + 1) * n) := by
      rw [key_sum] at key_sum_alt
      rw [← key_sum_alt]
      apply Finset.even_sum
      intro x hx
      have h_x_in_at_least_two : ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j := hB_cov x hx
      obtain ⟨i, j, hij, hxi, hxj⟩ := h_x_in_at_least_two
      have h_count_ge_two : (Finset.card (Finset.filter (fun k => x ∈ A k) (Finset.univ : Finset (Fin (2 * n + 1))))) ≥ 2 := by
        apply Finset.le_card_of_subset
        · intro k hk
          simp at hk
          aesop
        · simp
          aesop
      have h_count_eq : (Finset.card (Finset.filter (fun k => x ∈ A k) (Finset.univ : Finset (Fin (2 * n + 1))))) = 2 := by
        have h_upper : (Finset.card (Finset.filter (fun k => x ∈ A k) (Finset.univ : Finset (Fin (2 * n + 1))))) ≤ 2 := by
          apply Nat.le_of_lt_succ
          intro h_ge_three
          obtain ⟨i, hi⟩ := Finset.exists_mem_of_nonempty (Finset.nonempty_of_ne_empty (by aesop))
          obtain ⟨j, hj⟩ := Finset.exists_mem_of_nonempty (Finset.nonempty_of_ne_empty (by aesop))
          obtain ⟨k, hk⟩ := Finset.exists_mem_of_nonempty (Finset.nonempty_of_ne_empty (by aesop))
          have h_distinct : i ≠ j ∧ i ≠ k ∧ j ≠ k := by
            aesop
          have h_inter_ij : (A i ∩ A j).card = 1 := hA_inter i j h_distinct.1
          have h_inter_ik : (A i ∩ A k).card = 1 := hA_inter i k h_distinct.2.1
          have h_inter_jk : (A j ∩ A k).card = 1 := hA_inter j k h_distinct.2.2
          have h_x_in_all : x ∈ A i ∩ A j ∩ A k := by
            aesop
          have h_card_ge_three : (A i ∩ A j ∩ A k).card ≥ 1 := by
            apply Finset.one_le_card
            aesop
          have h_card_le_one : (A i ∩ A j ∩ A k).card ≤ 1 := by
            calc
              (A i ∩ A j ∩ A k).card ≤ (A i ∩ A j).card := Finset.card_le_of_subset (Finset.inter_subset_inter_right _ _)
              _ = 1 := h_inter_ij
          linarith
        linarith
      have h_f_x_cases : f x = 0 ∨ f x = 1 := hf_val x hx
      cases' h_f_x_cases with hfx0 hfx1
      · rw [hfx0]
        simp
        exact h_count_eq
      · rw [hfx1]
        simp
    rw [Nat.even_mul] at h_even
    aesop
  · intro h
    obtain ⟨hn_pos, hn_even⟩ := h
    use hn_pos
    use fun i => Finset.univ.filter (fun j => j ≠ i)
    use Finset.univ
    constructor
    · intro i
      simp
    constructor
    · intro i
      simp [Finset.card_univ, Finset.filter_eq_univ_iff]
      omega
    constructor
    · intro i j hij
      simp [Finset.card_univ, Finset.filter_eq_univ_iff]
      omega
    constructor
    · intro x hx
      use 0, 1
      simp
      omega
    use fun x => if x % 2 = 0 then 0 else 1
    constructor
    · intro x hx
      simp
    intro i
    simp [Finset.card_univ, Finset.filter_eq_univ_iff]
    omega
