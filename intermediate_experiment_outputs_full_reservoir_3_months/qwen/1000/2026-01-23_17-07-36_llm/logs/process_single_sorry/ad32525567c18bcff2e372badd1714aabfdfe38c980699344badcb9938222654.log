import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Let $n$ be a positive integer and let $A_1,A_2,\ldots,A_{2n+1}$ be subsets of a set $B$. Suppose that:

(i) Each $A_i$ has exactly $2n$ elements,

(ii) The intersection of every two distinct $A_i$ contains exactly one element, and

(iii) Every element of $B$ belongs to at least two of the $A_i$.

\noindent For which values of $n$ can one assign to every element of $B$ one of the numbers $0$ and $1$ in such a way that each $A_i$ has $0$ assigned to exactly $n$ of its elements?

Solution: $n$ such that $2 | n$.
-/
@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  apply Set.ext
  intro n
  constructor
  · intro h
    obtain ⟨n_pos, A, B, hA_sub_B, hA_card, hA_inter, hB_cov, hf⟩ := h
    obtain ⟨f, hf_val, hf_count⟩ := hf
    have h_total_pairs : ∑ i : Fin (2 * n + 1), ∑ j : Fin (2 * n + 1), ite (i < j) ((A i ∩ A j).card) 0 = (2 * n + 1) * n := by
      calc
        _ = ∑ i : Fin (2 * n + 1), ∑ j : Fin (2 * n + 1), ite (i < j) 1 0 := by
          apply Finset.sum_congr rfl
          intro i _
          apply Finset.sum_congr rfl
          intro j _
          split_ifs with h_lt
          · exact hA_inter i j (Ne.symm (Fin.ne_of_lt h_lt))
          · rfl
        _ = (2 * n + 1) * n := by
          simp [Finset.sum_range_choose_two]
    have h_total_zero_pairs : ∑ i : Fin (2 * n + 1), ∑ j : Fin (2 * n + 1), ite (i < j) ((A i ∩ A j).filter (f · = 0)).card 0 = n * n := by
      calc
        _ = ∑ x ∈ B, choose ((Finset.univ.filter (λ i => x ∈ A i)).card) 2 * ite (f x = 0) 1 0 := by
          sorry
        _ = n * n := by sorry
    have h_even : 2 ∣ n := by
      sorry
    exact ⟨n_pos, h_even⟩
  · intro h
    obtain ⟨n_pos, hn⟩ := h
    use n_pos
    use fun i => Finset.univ.filter (fun x => x.1 < 2 * n)
    use Finset.univ.filter (fun x => x.1 < 2 * n + 1)
    repeat' constructor
    · intros i
      simp
    · intros i
      simp
    · intros i j hij
      simp
    · intros x hx
      use 0, 1
      simp
    · use fun x => if x % 2 = 0 then 0 else 1
      constructor
      · intros x hx
        split_ifs <;> simp
      · intros i
        simp
