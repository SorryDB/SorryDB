                  exact h_k_not_in_filter
                have h_cover : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j := hB_cov
                have h_x_covered : ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j := h_cover x hx
                obtain ⟨i'', j'', hij'', hxi'', hxj''⟩ := h_x_covered
                have h_i''_eq : i'' = i' ∨ i'' = j' := by
                  have h_i''_in_filter : i'' ∈ Finset.filter (fun l => x ∈ A l) Finset.univ := by simp [hxi'']
                  rw [h_filter_eq] at h_i''_in_filter
