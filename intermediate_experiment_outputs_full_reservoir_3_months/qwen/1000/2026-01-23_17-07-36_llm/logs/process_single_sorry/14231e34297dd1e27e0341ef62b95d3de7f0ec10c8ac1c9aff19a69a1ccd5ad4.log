open BigOperators Real Nat Topology Rat

theorem imo_1984_p6
  (a b c d k m : ℕ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d)
  (h₁ : Odd a ∧ Odd b ∧ Odd c ∧ Odd d)
  (h₂ : a < b ∧ b < c ∧ c < d)
  (h₃ : a * d = b * c)
  (h₄ : a + d = 2^k)
  (h₅ : b + c = 2^m) :
  a = 1 := by
  have h₆ : a ≤ b := by linarith
  have h₇ : b ≤ c := by linarith
  have h₈ : c ≤ d := by linarith
  have h₉ : a < d := by linarith
  have h₁₀ : a * d = b * c := h₃
  have h₁₁ : a + d = 2 ^ k := h₄
  have h₁₂ : b + c = 2 ^ m := h₅
  have h₁₃ : Odd a := h₁.1
  have h₁₄ : Odd d := h₁.2.2.2
  have h₁₅ : Even (a + d) := by
    rw [h₁₁]
    exact even_pow_two k
  have h₁₆ : Odd (a + d) := by
    apply odd_add
    exact h₁₃
    exact h₁₄
  exfalso
  exact even_ne_odd h₁₅ h₁₆
