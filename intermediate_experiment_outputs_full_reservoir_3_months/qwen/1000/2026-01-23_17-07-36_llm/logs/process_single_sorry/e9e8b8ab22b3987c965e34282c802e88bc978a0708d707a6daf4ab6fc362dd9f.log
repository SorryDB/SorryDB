def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same => sorry
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      have h_ne : u ≠ v := by
        intro h_eq
        have h_len : u.len = v.len := by rw [h_eq]
        have h_ex : ∀ symbol ∈ v, Sum.isRight symbol := h_exhaustive
        have h_u_has_var : ∃ symbol ∈ u, Sum.isLeft symbol := by
          have h_u_len : u.len = 1 := h_starts_in_1
          have h_u_mem : u.get ⟨0, by simp [h_u_len]⟩ ∈ u := by apply Word.get_mem
          use u.get ⟨0, by simp [h_u_len]⟩
          exact h_u_mem
        obtain ⟨symbol, h_mem, h_left⟩ := h_u_has_var
        have h_step_res : dstep.result = u' := sound
        have h_v_no_var : ¬ ∃ symbol ∈ v, Sum.isLeft symbol := by
          intro h_exists
          obtain ⟨s, hs_mem, hs_left⟩ := h_exists
          exact hs_left (h_ex s hs_mem)
        have h_u'_no_var : ¬ ∃ symbol ∈ u', Sum.isLeft symbol := by
          rw [← h_step_res]
          exact h_v_no_var
        have h_dstep_changes : u ≠ dstep.result := by
          apply ContextFreeDerivationStep.u_ne_result dstep
        rw [h_step_res] at h_dstep_changes
        have h_der_nonzero : u' ≠ v := by
          match derivation with
          | .same h => rw [h] at h_dstep_changes; contradiction
          | .step _ _ _ => exact Ne.symm (by apply h_dstep_changes)
        rw [h_eq] at h_der_nonzero
        contradiction
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive h_ne)[0]'sorry).fst
```
