def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same => sorry
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      have h_u_ne_v : u ≠ v := by
        intro h_eq
        have h_len : u.len = v.len := by rw [h_eq]
        have h_exhaustive_v : ∀ symbol ∈ v, Sum.isRight symbol := h_exhaustive
        have h_start : u.len = 1 := h_starts_in_1
        have h_step : dstep.result = u' := sound
        have h_deriv : derivation.exhaustiveCondition := 
          ContextFreeDerivation.exhaustive_imp_child_exhaustive cfd h_exhaustive u' dstep derivation sound rfl
        have h_v_no_vars : ¬ ∃ symbol ∈ v, Sum.isLeft symbol := by
          intro h_exists
          cases' h_exists with symbol h_mem
          exact h_exhaustive_v symbol h_mem (by simp)
        have h_u_has_var : ∃ symbol ∈ u, Sum.isLeft symbol := by
          have h_u_len : u.len = 1 := h_starts_in_1
          have h_u_singleton : ∃ x, u = [x] := by
            apply Word.length_eq_one.mp h_u_len
          cases' h_u_singleton with x hx
          rw [hx]
          have h_x_in_u : x ∈ u := by simp [hx]
          have h_x_is_left : Sum.isLeft x := by
            have h_x_in_GV_or_GZ : x ∈ G.V ⊕ G.Z := by
              simp [hx] at h_x_in_u
              exact h_x_in_u
            cases' x with xv xz
            · exact Or.inl rfl
            · exfalso
              have h_v_singleton : v = [Sum.inr xz] := by rw [h_eq, hx]
              have h_v_has_var : Sum.isLeft (Sum.inr xz) := by
                apply h_u_has_var.not
                simp [h_v_singleton]
              contradiction
          exact ⟨x, h_x_in_u, h_x_is_left⟩
        have h_v_has_var : ∃ symbol ∈ v, Sum.isLeft symbol := by
          rw [← h_eq]
          exact h_u_has_var
        exact h_v_no_vars h_v_has_var
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive h_u_ne_v)[0]'sorry).fst
