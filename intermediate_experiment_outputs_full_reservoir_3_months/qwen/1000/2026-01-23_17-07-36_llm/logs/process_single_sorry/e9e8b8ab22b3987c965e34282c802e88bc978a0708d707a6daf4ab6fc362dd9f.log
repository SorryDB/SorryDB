def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same => sorry
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      have h_u_ne_v : u ≠ v := by
        intro h
        have h_len : u.len = v.len := by rw [h]
        have h_exhaustive_v : ∀ symbol ∈ v, Sum.isRight symbol := h_exhaustive
        have h_start_in_1 : u.len = 1 := h_starts_in_1
        have h_step_nonempty : u'.len ≥ 0 := Nat.zero_le _
        have h_sound : dstep.result = u' := sound
        have h_dstep_lhs : ∃ x, Sum.inl x ∈ u := dstep.lhs_in_u
        cases' h_dstep_lhs with x hx
        have h_x_is_left : ¬ Sum.isRight (Sum.inl x) := by simp
        have h_v_no_left : ∀ symbol ∈ v, ¬ Sum.isLeft symbol := by
          intro symbol hs
          exact h_x_is_left (h_exhaustive_v symbol hs)
        have h_u_has_left : ∃ symbol ∈ u, Sum.isLeft symbol := ⟨Sum.inl x, hx⟩
        rw [h] at h_u_has_left
        cases' h_u_has_left with symbol hs
        exact h_v_no_left symbol hs
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive h_u_ne_v)[0]'sorry).fst
