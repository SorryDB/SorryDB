(Mx ∩ E(G, x)).Nonempty := by\n                exact Set.nonempty_of_mem h\n              contradiction\n            contradiction\n          have hgy : y ∉ V(G, g) := by\n            intro hgy\n            have hgy' : g ∈ E(G, y) := by\n              use y, hgy\n            have hgy'' : g ∈ Mx ∩ E(G, y) := by\n              exact ⟨hg, hgy'⟩\n            have hMx_sub : (Mx ∩ E(G, y)).Subsingleton := hMx.subsingleton_inc y\n            have hMx_empty : Mx ∩ E(G, y) = ∅ := by\n              intro h\n              have hMx_nonempty : (Mx ∩ E(G, y)).Nonempty := by\n                exact Set.nonempty_of_mem h\n              contradiction\n            contradiction\n          simp [heV, Set.disjoint_iff]\n          intro w hw\n          aesop\n        exact h_disj\n    have hMx_card' : (Mx ∪ {e}).encard = Mx.encard + 1 := by\n      rw [encard_insert_of_not_mem heMx]\n    have hMx_card'' : (Mx ∪ {e}).encard ≤ ν(G) := IsMatching.encard_le hMx_union\n    rw [hMx_card', hMx_card] at hMx_card''\n    linarith",
      "\n  rw [Matroid.Series]\n  refine ⟨by aesop, fun z hz ↦ ?_⟩\n  simp only [matchingMatroid, matchingIndepMatroid, IndepMatroid.matroid, Matroid.mk,\n    Matroid.eRk, Matroid.rankFunOfIndep] at *\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxM⟩ := hx'\n  obtain ⟨My, hMy, hyM⟩ := hy'\n  have hxy : x ≠ y := by\n    rintro rfl\n    have := hMx.subsingleton_inc x\n    simp_all [Set.mem_inter_iff, Set.mem_singleton_iff]\n  have hrank : G.matchingMatroid.eRk (V(G) \\ {x, y}) = G.matchingMatroid.eRk (V(G)) - 1 := by\n    sorry\n  sorry",
      "\n  rw [Matroid.Series]\n  intro S hS hx hy\n  obtain ⟨M, hM, hMS⟩ := hS\n  have hx' : x ∉ V(G, M) := by simpa using hx\n  have hy' : y ∉ V(G, M) := by simpa using hy\n  refine ⟨M ∪ {e}, ?_, ?_⟩\n  · refine ⟨?_, ?_⟩\n    · intro z hz\n      cases' hz with hz | rfl\n      · exact hMS hz\n      · simp_all [G.Adj, Set.mem_range]\n    · intro e₁ he₁ e₂ he₂ hne\n      cases' he₁ with he₁ | rfl <;> cases' he₂ with he₂ | rfl <;> simp_all\n      · exact hM.disjoint he₁ he₂ hne\n      · exfalso\n        apply hx'\n        simp_all [G.Adj, Set.mem_range]\n      · exfalso\n        apply hy'\n        simp_all [G.Adj, Set.mem_range]\n  · simp_all",
      "\n  rw [Matroid.Series]\n  refine ⟨?_, ?_⟩\n  · intro hx\n    obtain ⟨M, hM, hxM⟩ := h x\n    have hM' : G.IsMatching M := hM.toIsMatching\n    have hxy : x ≠ y := by\n      rintro rfl\n      have := hM'.subset\n      have := hM'.disjoint\n      simp_all [Graph.Adj, Set.mem_singleton_iff]\n    have hyM : y ∉ V(G, M) := by\n      intro hyM\n      have hxyM : Disjoint (V(G, e)) (V(G, f)) := hM'.disjoint (by aesop) (by aesop) (by aesop)\n      simp_all [Graph.Adj, Set.mem_singleton_iff]\n    exact hyM\n  · intro hy\n    obtain ⟨M, hM, hyM⟩ := h y\n    have hM' : G.IsMatching M := hM.toIsMatching\n    have hxy : x ≠ y := by\n      rintro rfl\n      have := hM'.subset\n      have := hM'.disjoint\n      simp_all [Graph.Adj, Set.mem_singleton_iff]\n    have hxM : x ∉ V(G, M) := by\n      intro hxM\n      have hxyM : Disjoint (V(G, e)) (V(G, f)) := hM'.disjoint (by aesop) (by aesop) (by aesop)\n      simp_all [Graph.Adj, Set.mem_singleton_iff]\n    exact hxM",
      "\n  rw [Matroid.Series]\n  refine' ⟨⟨x, y⟩, Set.pair_subset.mpr ⟨by simpa using h.1, by simpa using h.2⟩, _⟩\n  intro z hz\n  obtain rfl | hzx | hzy := Set.mem_pair.mp hz <;> simp_all",
      "\n  rw [Matroid.Series]\n  intro z hz\n  simp only [matchingMatroid, IndepMatroid.matroid, Matroid.mk, Matroid.eRk, Set.encard_diff_singleton_eq_ite,\n    Set.encard_singleton, Nat.cast_one, add_tsub_cancel_of_le, Nat.cast_add, Nat.cast_sub,\n    Nat.cast_zero, zero_add, one_add, add_comm, add_left_comm, add_assoc] at *\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxM⟩ := hx'\n  obtain ⟨My, hMy, hyM⟩ := hy'\n  -- Use the definition of series: for any z, rank(E\\{x,z}) = rank(E\\{y,z})\n  -- Since both x and y are inessential, removing either doesn't change the max matching size\n  -- And since they're adjacent, any matching covering one can be adjusted to cover the other\n  sorry",
      "\n  rw [Matroid.Series]\n  intro z hz\n  simp only [matchingMatroid, IndepMatroid.matroid, Matroid.mk, Matroid.closure, Set.mem_setOf_eq] at *\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxM⟩ := hx'\n  obtain ⟨My, hMy, hyM⟩ := hy'\n  use Mx\n  constructor\n  · exact hMx\n  · intro hzx\n    have hxy : G.Adj x y := h\n    obtain ⟨e, he⟩ := hxy\n    have hex : e ∈ E(G, x) := he.1\n    have hey : e ∈ E(G, y) := he.2\n    have hxe : x ∈ V(G, e) := by simpa using hex\n    have hye : y ∈ V(G, e) := by simpa using hey\n    have hne : x ≠ y := by\n      rintro rfl\n      have hloop : e ∈ E(G, x) ∧ e ∈ E(G, x) := ⟨hex, hey⟩\n      have hmatch : Disjoint V(G, e) V(G, e) := hMx.disjoint (by simpa using hMx.subset.hex) (by simpa using hMx.subset.hex) (by simp)\n      exact hmatch.not_mem hxe\n    have hnot : z ∉ V(G, Mx) := by\n      contrapose! hzx\n      exact hzx\n    have hz' : z ∈ V(G) := by\n      contrapose! hnot\n      simp_all\n    have hMx' : G.IsMatching (Mx ∪ {e}) := by\n      apply IsMatching.mk\n      · intro f hf\n        cases' hf with hf hf\n        · exact hMx.subset hf\n        · simp_all\n      · intro f g hf hg hfg\n        cases' hf with hf hf <;> cases' hg with hg hg <;> simp_all\n        · exact hMx.disjoint hf hg hfg\n        · have hfe : f = e := by simp_all\n          rw [hfe]\n          have hge : g = e := by simp_all\n          rw [hge] at hfg\n          contradiction\n        · have hge : g = e := by simp_all\n          rw [hge]\n          have hfe : f = e := by simp_all\n          rw [hfe] at hfg\n          contradiction\n        · have hfe : f = e := by simp_all\n          have hge : g = e := by simp_all\n          rw [hfe, hge] at hfg\n          contradiction\n    have hcard : (Mx ∪ {e}).encard = Mx.encard + 1 := by\n      rw [encard_insert_of_not_mem]\n      · simp\n      · intro heMx\n        have hxe' : x ∈ V(G, Mx) := by\n          use e, heMx\n          simp_all\n        contradiction\n    have hmax : G.IsMaxMatching Mx := by\n      apply IsMaxMatching.mk\n      · exact hMx\n      · intro M' hM'\n        have hcard' : M'.encard ≤ ν(G) := by\n          apply IsMatching.encard_le\n          exact hM'\n        have hcard'' : Mx.encard = ν(G) := by\n          apply IsMaxMatching.encard\n          apply IsMaxMatching.mk\n          · exact hMx\n          · intro M'' hM''\n            have hcard''' : M''.encard ≤ ν(G) := by\n              apply IsMatching.encard_le\n              exact hM''\n            simp_all\n        simp_all\n    have hcontradiction : Mx.encard + 1 ≤ Mx.encard := by\n      have hcard''' : (Mx ∪ {e}).encard ≤ ν(G) := by\n        apply IsMatching.encard_le\n        exact hMx'\n      have hcard'''' : ν(G) = Mx.encard := by\n        apply IsMaxMatching.encard\n        exact hmax\n      simp_all\n    linarith",
      "\n  rw [Matroid.Series]\n  refine ⟨by aesop, fun z hz ↦ ?_⟩\n  simp only [matchingMatroid, matchingIndepMatroid, IndepMatroid.matroid, Matroid.mk,\n    Matroid.eRk, SetLike.coe_sort, Set.mem_diff, Set.mem_singleton_iff] at *\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxMx⟩ := hx'\n  obtain ⟨My, hMy, hyMy⟩ := hy'\n  use Mx ∪ My\n  constructor\n  · exact ⟨by aesop, by aesop⟩\n  · aesop",
      "\n  apply Matroid.Series.iff_cocircuit.mpr\n  rw [Matroid.cocircuit_iff]\n  have hxy : x ≠ y := by\n    rintro rfl\n    exact G.loopless h\n  have hx : x ∈ V(G) := (G.Adj.mem_left h)\n  have hy : y ∈ V(G) := (G.Adj.mem_right h)\n  refine ⟨⟨by simp [hx, hy], ?_⟩, ?_⟩\n  · intro z hz\n    simp only [Set.mem_diff, Set.mem_singleton_iff] at hz\n    cases' hz with hz hzx\n    exfalso\n    exact hzx (by simp [hz])\n  · have hMx := h x\n    have hMy := h y\n    obtain ⟨Mx, hMx, hxMx⟩ := hMx\n    obtain ⟨My, hMy, hyMy⟩ := hMy\n    have hMx' : G.IsMaxMatching Mx := hMx\n    have hMy' : G.IsMaxMatching My := hMy\n    have hνx : Mx.encard = ν(G) := hMx'.encard\n    have hνy : My.encard = ν(G) := hMy'.encard\n    have hVx : V(G, Mx).encard = 2 * ν(G) := by\n      rw [← hνx, ← encard_image_of_injective _ (fun e ↦ (G.incidence e).some)]\n      · simp [V_def, Set.image_image]\n      · intro e he f hf h\n        exact (hMx.disjoint he hf (by aesop)).le_bot ⟨by aesop, by aesop⟩\n    have hVy : V(G, My).encard = 2 * ν(G) := by\n      rw [← hνy, ← encard_image_of_injective _ (fun e ↦ (G.incidence e).some)]\n      · simp [V_def, Set.image_image]\n      · intro e he f hf h\n        exact (hMy.disjoint he hf (by aesop)).le_bot ⟨by aesop, by aesop⟩\n    have hrank : G.matchingMatroid.eRk (V(G) \\ {x, y}) = 2 * ν(G) - 1 := by\n      have h1 : G.matchingMatroid.eRk (V(G) \\ {x}) = 2 * ν(G) := by\n        apply le_antisymm\n        · apply G.matchingMatroid.eRk_mono\n          simp\n        · apply G.matchingMatroid.eRk_le\n          use Mx\n          constructor\n          · exact hMx\n          · intro v hv\n            simp at hv\n            cases' hv with hv hv\n            · contradiction\n            · exact hv\n      have h2 : G.matchingMatroid.eRk (V(G) \\ {y}) = 2 * ν(G) := by\n        apply le_antisymm\n        · apply G.matchingMatroid.eRk_mono\n          simp\n        · apply G.matchingMatroid.eRk_le\n          use My\n          constructor\n          · exact hMy\n          · intro v hv\n            simp at hv\n            cases' hv with hv hv\n            · contradiction\n            · exact hv\n      have h3 : G.matchingMatroid.eRk (V(G) \\ {x, y}) ≤ 2 * ν(G) - 1 := by\n        apply G.matchingMatroid.eRk_le\n        use Mx\n        constructor\n        · exact hMx\n        · intro v hv\n          simp at hv\n          cases' hv with hv hv\n          · cases' hv with hv hv\n            · contradiction\n            · exact hv\n          · exact hv\n      have h4 : 2 * ν(G) - 1 ≤ G.matchingMatroid.eRk (V(G) \\ {x, y}) := by\n        have h5 : G.matchingMatroid.eRk (V(G) \\ {x}) ≤ G.matchingMatroid.eRk (V(G) \\ {x, y}) + 1 := by\n          apply G.matchingMatroid.eRk_dim\n          simp\n        rw [h1] at h5\n        omega\n      linarith\n    rw [hrank]\n    simp",
      "\n  rw [Matroid.Series]\n  refine ⟨⟨by simpa using h.1⟩, ?_⟩\n  intro z hz\n  simp only [matchingMatroid, matchingIndepMatroid, Matroid.matroid, IndepMatroid.matroid,\n    Matroid.closure, Set.mem_setOf_eq]\n  push_neg\n  intro hz'\n  obtain ⟨M, hM, hzM⟩ := hz\n  obtain ⟨M', hM', hxM'⟩ := h x\n  obtain ⟨M'', hM'', hyM''⟩ := h y\n  have hrank := G.matchingMatroid.eRank\n  have hnu := ν(G)\n  have hM'_card : M'.encard = hnu := by\n    apply IsMaxMatching.encard\n    exact ⟨hM', fun M''' hM''' => ?_⟩\n    have := h x\n    obtain ⟨Mx, hMx, _⟩ := this\n    exact (hMx : G.IsMaxMatching Mx).max M''' hM'''\n  have hM''_card : M''.encard = hnu := by\n    apply IsMaxMatching.encard\n    exact ⟨hM'', fun M''' hM''' => ?_⟩\n    have := h y\n    obtain ⟨My, hMy, _⟩ := this\n    exact (hMy : G.IsMaxMatching My).max M''' hM'''\n  have hM_card_le : M.encard ≤ hnu := by\n    apply IsMatching.encard_le hM\n  have hzM_not_both : ¬(x ∈ V(G, M) ∧ y ∈ V(G, M)) := by\n    intro hxy\n    have hM_aug : ∃ P, G.IsAugPath hM P := by\n      apply IsMatching.exists_isAugPath_not_max hM\n      intro hMmax\n      have := hMmax.max M' (hM' : G.IsMatching M')\n      linarith\n    obtain ⟨P, hP⟩ := hM_aug\n    have hP_first : P.first ∉ V(G, M) := hP.first_not_in\n    have hP_last : P.last ∉ V(G, M) := hP.last_not_in\n    have hP_nonempty : P.Nonempty := hP.nonempty\n    have hP_path : G.IsPath P := hP.toIsAltPath.toIsPath\n    have hP_edges : E(P) ⊆ E(G) := by\n      intro e he\n      obtain ⟨u, v, heuv⟩ := hP_path.edge_mem he\n      exact heuv.1\n    have hP_match : G.IsMatching (M ∆ E(P)) := hP.augment\n    have hP_vertex : V(G, M) ⊆ V(G, M ∆ E(P)) := hP.augment_vertex_subset\n    have hP_encard : (M ∆ E(P)).encard = M.encard + 1 := hP.augment_encard\n    have hP_encard_le : (M ∆ E(P)).encard ≤ hnu := by\n      apply IsMatching.encard_le hP_match\n    linarith\n  simp_all",
      "\n  apply Matroid.Series.iff_cocircuit.mpr\n  rw [Matroid.cocircuit_iff]\n  have hxy : x ≠ y := by\n    rintro rfl\n    exact G.loopless.not_adj rfl h\n  have hx : x ∈ V(G) := (G.Adj.mem_left h).1\n  have hy : y ∈ V(G) := (G.Adj.mem_right h).1\n  refine ⟨⟨by simp [hx, hy], ?_⟩, ?_⟩\n  · intro z hz\n    cases' hz with hzx hzy\n    · have := h x\n      obtain ⟨M, hM, hxM⟩ := this\n      have hMx : x ∉ V(G, M) := hxM\n      have hMy : y ∈ V(G, M) ∨ y ∉ V(G, M) := by tauto\n      cases' hMy with hMy hMy\n      · use M\n        constructor\n        · exact hM\n        · simp [hMx, hMy]\n      · have := h y\n        obtain ⟨M', hM', hyM'⟩ := this\n        have hM'y : y ∉ V(G, M') := hyM'\n        have hM'x : x ∈ V(G, M') ∨ x ∉ V(G, M') := by tauto\n        cases' hM'x with hM'x hM'x\n        · use M'\n          constructor\n          · exact hM'\n          · simp [hM'x, hM'y]\n        · exfalso\n          have hM'' : G.IsMatching (M ∪ M') := by\n            sorry\n          sorry\n    · have := h y\n      obtain ⟨M, hM, hyM⟩ := this\n      have hMy : y ∉ V(G, M) := hyM\n      have hMx : x ∈ V(G, M) ∨ x ∉ V(G, M) := by tauto\n      cases' hMx with hMx hMx\n      · use M\n        constructor\n        · exact hM\n        · simp [hMx, hMy]\n      · have := h x\n        obtain ⟨M', hM', hxM'⟩ := this\n        have hM'x : x ∉ V(G, M') := hxM'\n        have hM'y : y ∈ V(G, M') ∨ y ∉ V(G, M') := by tauto\n        cases' hM'y with hM'y hM'y\n        · use M'\n          constructor\n          · exact hM'\n          · simp [hM'x, hM'y]\n        · exfalso\n          have hM'' : G.IsMatching (M ∪ M') := by\n            sorry\n          sorry\n  · intro S hS\n    have hS' : S ⊆ V(G) := by\n      intro z hz\n      cases' hz with hzx hzy\n      · exact hx\n      · exact hy\n    have hrank : G.matchingMatroid.eRk S = 2 * ν(G) - 1 := by\n      sorry\n    exact hrank",
      "\n  rw [Matroid.Series]\n  intro z hz\n  simp only [matchingMatroid, IndepMatroid.matroid, Matroid.mk, Matroid.closure, Set.mem_setOf_eq] at *\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxM⟩ := hx'\n  obtain ⟨My, hMy, hyM⟩ := hy'\n  use Mx\n  constructor\n  · exact hMx\n  · intro hzx\n    have hxy : G.Adj x y := h\n    have hmatch : G.IsMatching Mx := hMx\n    have hnotx : x ∉ V(G, Mx) := hxM\n    have hnotz : z ∉ V(G, Mx) := by\n      rintro hzV\n      have hz' : z ∈ V(G, Mx) := hzV\n      have hz'' : z = x ∨ z = y := by\n        apply Or.intro_left\n        sorry\n      cases hz'' with\n      | inl hzx => contradiction\n      | inr hzy =>\n        have hyin : y ∈ V(G, Mx) := by\n          apply Set.mem_of_mem_of_subset\n          · exact hzy.symm ▸ hzx\n          · sorry\n        contradiction\n    exact hz",
      "\n  rw [Matroid.Series]\n  intro z hz\n  simp only [matchingMatroid, matchingIndepMatroid, IndepMatroid.matroid, Matroid.mk,\n    Matroid.closure, Set.mem_setOf_eq] at *\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxM⟩ := hx'\n  obtain ⟨My, hMy, hyM⟩ := hy'\n  use Mx\n  constructor\n  · exact hMx\n  · intro hzx\n    have hxy : G.Adj x y := h\n    obtain ⟨e, he⟩ := hxy\n    have hxe : x ∈ V(G, e) := he.1\n    have hye : y ∈ V(G, e) := he.2\n    have hne : x ≠ y := by\n      rintro rfl\n      simp_all [Graph.Adj, Set.mem_singleton_iff]\n    have hdisj := hMx.disjoint\n    have hxnot : x ∉ V(G, Mx) := hxM\n    have hyin : y ∈ V(G, Mx) ∨ y ∉ V(G, Mx) := by apply Classical.em\n    cases hyin with\n    | inl hyinMx =>\n      exfalso\n      have hme : e ∈ Mx ∨ e ∉ Mx := by apply Classical.em\n      cases hme with\n      | inl hem =>\n        have hxe' : x ∈ V(G, e) := he.1\n        have hxe'' : x ∈ V(G, Mx) := by\n          refine Set.mem_iUnion₂.mpr ⟨e, hem, hxe'⟩\n        contradiction\n      | inr hem =>\n        have hmatch : ∃ f ∈ Mx, y ∈ V(G, f) := by\n          refine Set.mem_iUnion₂.mp hyinMx\n        obtain ⟨f, hfm, hyf⟩ := hmatch\n        have hdisj' := hMx.disjoint hem hfm (by simp_all)\n        have hdisj'' := hdisj'.le_bot\n        have hxf : x ∈ V(G, f) ∨ x ∉ V(G, f) := by apply Classical.em\n        cases hxf with\n        | inl hxf =>\n          have hboth : x ∈ V(G, e) ∩ V(G, f) := by\n            constructor <;> assumption\n          contradiction\n        | inr hxf =>\n          have hye' : y ∈ V(G, e) := he.2\n          have hyf' : y ∈ V(G, f) := hyf\n          have hboth : y ∈ V(G, e) ∩ V(G, f) := by\n            constructor <;> assumption\n          have hdisj''' := hMx.disjoint hem hfm (by simp_all)\n          contradiction\n    | inr hyout =>\n      have hmatch : z ∈ V(G, Mx) := hzx\n      have hz : z ∈ V(G) := by\n        refine Set.mem_iUnion₂.mp hmatch\n        obtain ⟨e, he, hze⟩ := this\n        exact hze.1\n      have hz' : z ∈ V(G, Mx) := hmatch\n      exact hz'",
      "\n  rw [Matroid.Series]\n  refine ⟨by aesop, fun z hz ↦ ?_⟩\n  rw [Matroid.IsCocircuit, Matroid.closure_eq_closure]\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxMx⟩ := hx'\n  obtain ⟨My, hMy, hyMy⟩ := hy'\n  simp_all [matchingMatroid, matchingIndepMatroid, Matroid.rank_def]",
      "\n  rw [Matroid.Series]\n  simp_rw [matchingMatroid, IndepMatroid.matroid, Matroid.dual, Matroid.IsParallel]\n  intro z hz\n  obtain ⟨M, hM, hxM⟩ := h x\n  obtain ⟨M', hM', hyM'⟩ := h y\n  use M ∪ M'\n  constructor\n  · exact ⟨by\n      intro e he\n      cases' he with he he <;> [exact hM.subset he, exact hM'.subset he]⟩\n  · simp [Set.mem_union, hxM, hyM']",
      "\n  rw [Matroid.Series]\n  refine ⟨?_, ?_⟩\n  · intro hx\n    obtain ⟨M, hM, hxM⟩ := h x\n    have hM' : G.IsMatching M := hM.toIsMatching\n    have hyM : y ∉ V(G, M) := by\n      contrapose! hxM\n      exact hM'.subset (G.mem_inc_of_adj h) hxM\n    exact ⟨M, hM', hyM⟩\n  · intro hy\n    obtain ⟨M, hM, hyM⟩ := h y\n    have hM' : G.IsMatching M := hM.toIsMatching\n    have hxM : x ∉ V(G, M) := by\n      contrapose! hyM\n      exact hM'.subset (G.mem_inc_of_adj h.symm) hyM\n    exact ⟨M, hM', hxM⟩",
      "\n  rw [Matroid.Series]\n  refine ⟨by aesop, fun z hz ↦ ?_⟩\n  cases' hz with hzx hzy <;> subst_vars\n  all_goals\n    obtain ⟨M, hM, hxM⟩ := h x\n    obtain ⟨M', hM', hyM'⟩ := h y\n    use M\n    aesop",
      "\n  apply Matroid.Series.iff_cocircuit.mpr\n  rw [Matroid.cocircuit_iff]\n  have hxy : x ≠ y := by\n    rintro rfl\n    exact G.loopless h\n  use V(G) \\ {x, y}\n  constructor\n  · intro z hz\n    simp at hz\n    cases' hz with hzx hzy <;> simp_all\n  · have rx := h x\n    have ry := h y\n    obtain ⟨Mx, hMx, hx⟩ := rx\n    obtain ⟨My, hMy, hy⟩ := ry\n    have hMx' : G.IsMaxMatching Mx := hMx\n    have hMy' : G.IsMaxMatching My := hMy\n    have hMx_encard : Mx.encard = ν(G) := hMx'.encard\n    have hMy_encard : My.encard = ν(G) := hMy'.encard\n    have hVx : V(G, Mx).encard = 2 * ν(G) := by\n      rw [← hMx_encard]\n      exact (G.IsMatching.card_vertex_set_eq hMx.toIsMatching)\n    have hVy : V(G, My).encard = 2 * ν(G) := by\n      rw [← hMy_encard]\n      exact (G.IsMatching.card_vertex_set_eq hMy.toIsMatching)\n    have hrank : G.matchingMatroid.eRk (V(G) \\ {x, y}) = 2 * ν(G) - 1 := by\n      sorry\n    rw [hrank]\n    simp",
      "\n  rw [Matroid.Series]\n  refine ⟨⟨x, y⟩, ?_, ?_⟩\n  · intro z hz\n    obtain rfl | rfl := hz\n    · exact Or.inl rfl\n    · exact Or.inr rfl\n  · simp_rw [Matroid.IsCocircuit, Matroid.eRk_eq_rank, ← Matroid.rank_eq_coe_encard_basis]\n    have hx' : ∃ M, G.IsMaxMatching M ∧ x ∉ V(G, M) := h x\n    have hy' : ∃ M, G.IsMaxMatching M ∧ y ∉ V(G, M) := h y\n    obtain ⟨Mx, hMx, hxMx⟩ := hx'\n    obtain ⟨My, hMy, hyMy⟩ := hy'\n    have hrank : G.matchingMatroid.eRank = 2 * ν(G) := by\n      rw [matchingMatroid, IndepMatroid.matroid_eRank]\n      refine le_antisymm ?_ ?_\n      · intro S hS\n        obtain ⟨M, hM, hSM⟩ := hS\n        calc\n          S.encard ≤ V(G, M).encard := encard_mono hSM\n          _ = 2 * M.encard := by\n            have : Disjoint (M ∩ E(G, v)) (M ∩ E(G, w)) := by\n              intro e he hf\n              exact (hM.disjoint he.1 hf.1 (by aesop)).le_bot ⟨he.2, hf.2⟩\n            sorry\n          _ ≤ 2 * ν(G) := by\n            apply mul_le_mul_of_nonneg_left\n            · exact hM.encard_le\n            · exact Nat.cast_nonneg 2\n      · obtain ⟨M, hM, rfl⟩ := IsMaxMatching.encard hMx\n        use V(G, M)\n        exact ⟨⟨M, hM, subset_rfl⟩, by simp [hxMx]⟩\n    have hrankx : G.matchingMatroid.eRk (V(G) \\ {x}) = G.matchingMatroid.eRank := by\n      rw [hrank]\n      obtain ⟨M, hM, hxM⟩ := h x\n      have hMmax : G.IsMaxMatching M := hM\n      have hVM : V(G, M) ⊆ V(G) \\ {x} := by\n        intro v hv\n        simp\n        intro hvx\n        apply hxM\n        exact hv\n      calc\n        G.matchingMatroid.eRk (V(G) \\ {x}) ≥ V(G, M).encard := by\n          apply G.matchingMatroid.eRk_mono\n          exact hVM\n        _ = 2 * M.encard := by\n          sorry\n        _ = 2 * ν(G) := by rw [IsMaxMatching.encard hMmax]\n        _ = G.matchingMatroid.eRank := by rw [hrank]\n    have hranky : G.matchingMatroid.eRk (V(G) \\ {y}) = G.matchingMatroid.eRank := by\n      rw [hrank]\n      obtain ⟨M, hM, hyM⟩ := h y\n      have hMmax : G.IsMaxMat