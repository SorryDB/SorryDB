lemma matchingMatroid.seriesPair_of_adj (h : ∀ x, G.inessential x) (h : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  rw [Matroid.Series]
  refine ⟨⟨by simpa using h.1⟩, ?_⟩
  intro z hz
  simp only [matchingMatroid, matchingIndepMatroid, Matroid.matroid, IndepMatroid.matroid,
    Matroid.closure, Set.mem_setOf_eq]
  push_neg
  intro hz'
  obtain ⟨M, hM, hzM⟩ := hz
  obtain ⟨M', hM', hxM'⟩ := h x
  obtain ⟨M'', hM'', hyM''⟩ := h y
  have hrank := G.matchingMatroid.eRank
  have hnu := ν(G)
  have hM'_card : M'.encard = hnu := by
    apply IsMaxMatching.encard
    exact ⟨hM', fun M''' hM''' => ?_⟩
    have := h x
    obtain ⟨Mx, hMx, _⟩ := this
    exact (hMx : G.IsMaxMatching Mx).max M''' hM'''
  have hM''_card : M''.encard = hnu := by
    apply IsMaxMatching.encard
    exact ⟨hM'', fun M''' hM''' => ?_⟩
    have := h y
    obtain ⟨My, hMy, _⟩ := this
    exact (hMy : G.IsMaxMatching My).max M''' hM'''
  have hM_card_le : M.encard ≤ hnu := by
    apply IsMatching.encard_le hM
  have hzM_not_both : ¬(x ∈ V(G, M) ∧ y ∈ V(G, M)) := by
    intro hxy
    have hM_aug : ∃ P, G.IsAugPath hM P := by
      apply IsMatching.exists_isAugPath_not_max hM
      intro hMmax
      have := hMmax.max M' (hM' : G.IsMatching M')
      linarith
    obtain ⟨P, hP⟩ := hM_aug
    have hP_first : P.first ∉ V(G, M) := hP.first_not_in
    have hP_last : P.last ∉ V(G, M) := hP.last_not_in
    have hP_nonempty : P.Nonempty := hP.nonempty
    have hP_path : G.IsPath P := hP.toIsAltPath.toIsPath
    have hP_edges : E(P) ⊆ E(G) := by
      intro e he
      obtain ⟨u, v, heuv⟩ := hP_path.edge_mem he
      exact heuv.1
    have hP_match : G.IsMatching (M ∆ E(P)) := hP.augment
    have hP_vertex : V(G, M) ⊆ V(G, M ∆ E(P)) := hP.augment_vertex_subset
    have hP_encard : (M ∆ E(P)).encard = M.encard + 1 := hP.augment_encard
    have hP_encard_le : (M ∆ E(P)).encard ≤ hnu := by
      apply IsMatching.encard_le hP_match
    linarith
  simp_all
