    obtain ⟨M, hM, hxM⟩ := h x
    have hM' : G.IsMatching M := hM.toIsMatching
    have hyM : y ∉ V(G, M) := by
      contrapose! hxM
      exact hM'.subset (G.mem_inc_of_adj h) hxM
    exact ⟨M, hM', hyM⟩
