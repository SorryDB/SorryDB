      · intro e he f hf h
        exact (hMy.disjoint he hf (by aesop)).le_bot ⟨by aesop, by aesop⟩
    have hrank : G.matchingMatroid.eRk (V(G) \ {x, y}) = 2 * ν(G) - 1 := by
