          use My
          constructor
          · exact hMy
          · intro v hv
            simp at hv
            cases' hv with hv hv
            · contradiction
            · exact hv
      have h3 : G.matchingMatroid.eRk (V(G) \ {x, y}) ≤ 2 * ν(G) - 1 := by
        apply G.matchingMatroid.eRk_le
        use Mx
        constructor
        · exact hMx
        · intro v hv
          simp at hv
          cases' hv with hv hv
          · cases' hv with hv hv
            · contradiction
            · exact hv
          · exact hv
      have h4 : 2 * ν(G) - 1 ≤ G.matchingMatroid.eRk (V(G) \ {x, y}) := by
        have h5 : G.matchingMatroid.eRk (V(G) \ {x}) ≤ G.matchingMatroid.eRk (V(G) \ {x, y}) + 1 := by
          apply G.matchingMatroid.eRk_dim
          simp
        rw [h1] at h5
        omega
      linarith
    rw [hrank]
    simp
