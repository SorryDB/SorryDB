he\n                have : (V(G, e)).encard ≤ 2 := by\n                  have : V(G, e) ⊆ V(G) := by\n                    intro v hv\n                    exact (G.edge_mem_ground (by simpa using he)).1 hv\n                  have : (V(G, e)).encard ≤ 2 := by\n                    match G.V e with\n                    | .nil => simp\n                    | .cons u (.nil v) =>\n                      simp\n                      have : u ≠ v := by\n                        intro huv\n                        have : G.IsLoop e := by\n                          rw [Graph.IsLoop, Graph.V_cons_nil]\n                          simp [huv]\n                        exact G.loopless.not_loop this\n                      simp [Nat.card_pair, this]\n                    | .cons u (.cons v (.nil w)) =>\n                      simp at this\n                    | .cons u (.cons v (.cons w l)) =>\n                      simp at this\n                  exact this\n                exact this\n              _ = 2 * M.encard := by simp [Finset.sum_const, nsmul_eq_mul]\n          exact this\n        _ ≤ 2 * ν(G) := by gcongr\n    have hmin_V_not_z : 2 * ν(G) ≤ (G.matchingMatroid.eRk (V(G) \\ {z})) := by\n      have : V(G, Mz) ⊆ V(G) \\ {z} := by\n        intro v hv\n        simp\n        intro hvz\n        apply hz_notin\n        exact hv\n      have : (V(G, Mz)).encard ≤ (G.matchingMatroid.eRk (V(G) \\ {z})) := by\n        apply G.matchingMatroid.eRk_mono\n        exact this\n      calc\n        2 * ν(G) = 2 * Mz.encard := by rw [hMz_size]\n        _ = (V(G, Mz)).encard := by\n          have : (V(G, Mz)).encard = 2 * Mz.encard := by\n            have : ∀ e ∈ Mz, (V(G, e)).encard = 2 := by\n              intro e he\n              have : ¬ G.IsLoop e := by\n                intro hloop\n                have : e ∈ E(G) := by simpa using hMz.subset he\n                have : G.IsLoop e := hloop\n                exact G.loopless.not_loop this\n              have : (V(G, e)).encard = 2 := by\n                match G.V e with\n                | .nil => simp at this\n                | .cons u (.nil v) =>\n                  simp\n                  have : u ≠ v := by\n                    intro huv\n                    have : G.IsLoop e := by\n                      rw [Graph.IsLoop, Graph.V_cons_nil]\n                      simp [huv]\n                    exact G.loopless.not_loop this\n                  simp [Nat.card_pair, this]\n                | .cons u (.cons v (.nil w)) =>\n                  simp at this\n                | .cons u (.cons v (.cons w l)) =>\n                  simp at this\n              exact this\n            have : (V(G, Mz)).encard = ∑ e ∈ Mz, (V(G, e)).encard := by\n              rw [V_union]\n              apply encard_iUnion_eq_of_disjoint\n              intro e he f hf hne\n              exact (hMz.disjoint he hf hne).eq_bot\n            rw [this]\n            simp [this]\n          exact this\n        _ ≤ (G.matchingMatroid.eRk (V(G) \\ {z})) := by assumption\n    linarith\n  have hrank_V_not_x : (G.matchingMatroid.eRk (V(G) \\ {x})) = 2 * ν(G) := by\n    exact hrank_V_not_z\n  have hrank_V_not_y : (G.matchingMatroid.eRk (V(G) \\ {y})) = 2 * ν(G) := by\n    exact hrank_V_not_z\n  have hrank_V_not_xy : (G.matchingMatroid.eRk (V(G) \\ {x, y})) = 2 * ν(G) - 1 := by\n    have hle : (G.matchingMatroid.eRk (V(G) \\ {x, y})) ≤ 2 * ν(G) - 1 := by\n      have : (V(G) \\ {x, y}) ⊆ V(G) := by\n        intro v hv\n        simp at hv\n        exact hv.1\n      have : (G.matchingMatroid.eRk (V(G) \\ {x, y})) ≤ (G.matchingMatroid.eRk (V(G))) := by\n        apply G.matchingMatroid.eRk_mono\n        exact this\n      have : (G.matchingMatroid.eRk (V(G))) = 2 * ν(G) := by\n        have : ∃ M, G.IsMatching M ∧ V(G) ⊆ V(G, M) := by\n          obtain ⟨M, hM, hM_max⟩ := Classical.choose_spec (Classical.em (∃ M, G.IsMaxMatching M))\n          use M\n          constructor\n          · exact hM\n          · intro v hv\n            have : v ∈ V(G, M) := by\n              sorry\n        sorry\n      sorry\n    have hge : 2 * ν(G) - 1 ≤ (G.matchingMatroid.eRk (V(G) \\ {x, y})) := by\n      sorry\n    linarith\n  simp [hrank_V_not_xy, hrank_V_not_x, hrank_V_not_y]",
      "\n  rw [Matroid.Series]\n  intro z hz\n  simp only [matchingMatroid, IndepMatroid.matroid, Matroid.mk, Matroid.eRk, Matroid.E]\n  simp only [matchingIndepMatroid, IndepMatroid.mk, exists_prop, Set.mem_setOf_eq]\n  constructor\n  · intro ⟨M, hM, hzM⟩\n    use M\n    exact ⟨hM, by aesop⟩\n  · intro ⟨M, hM, hzM⟩\n    use M\n    exact ⟨hM, by aesop⟩",
      "\n  rw [Matroid.Series]\n  refine ⟨by aesop, fun z hz ↦ ?_⟩\n  simp only [matchingMatroid, matchingIndepMatroid, IndepMatroid.matroid, Matroid.mk,\n    Matroid.eRk, Matroid.rankFunOfIndep] at *\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxM⟩ := hx'\n  obtain ⟨My, hMy, hyM⟩ := hy'\n  use Mx\n  constructor\n  · exact hMx\n  · intro hzx\n    have hxy : x ≠ y := by\n      rintro rfl\n      have := hMx.subsingleton_inc x\n      simp_all [Set.Subsingleton, Set.Nonempty]\n    have hz : z = x ∨ z = y := by\n      contrapose! hzx\n      aesop\n    cases' hz with hz hz <;> subst_vars <;> simp_all",
      "\n  rw [Matroid.Series]\n  intro z hz\n  simp only [matchingMatroid, IndepMatroid.matroid, Matroid.mk, Matroid.closure, Set.mem_setOf_eq] at *\n  simp_all [Matroid.IsColoop, Matroid.rankFun, matchingIndepMatroid]",
      "\n  rw [Matroid.Series]\n  intro z hz\n  simp only [matchingMatroid, IndepMatroid.matroid, Matroid.mk, Matroid.eRk, Matroid.E]\n  simp only [matchingIndepMatroid, IndepMatroid.mk, exists_prop, Set.mem_setOf_eq]\n  have hx' := h x\n  have hy' := h y\n  obtain ⟨Mx, hMx, hxM⟩ := hx'\n  obtain ⟨My, hMy, hyM⟩ := hy'\n  use Mx\n  constructor\n  · exact hMx\n  · intro hzx\n    have hxy : x ≠ y := by\n      rintro rfl\n      simp_all [Graph.Adj, Set.mem_singleton_iff]\n    have hz_not_in_Mx : z ∉ V(G, Mx) := by\n      contrapose! hzx\n      simp_all [Set.mem_insert_iff]\n    have hMx_max : G.IsMaxMatching Mx := by\n      refine ⟨hMx, fun M' hM' ↦ ?_⟩\n      have hMx_card : Mx.encard = ν(G) := by\n        apply IsMaxMatching.encard\n        refine ⟨hMx, fun M' hM' ↦ ?_⟩\n        exact le_of_lt (lt_of_le_of_ne (IsMatching.encard_le hM') (Ne.symm (by aesop)))\n      rw [← hMx_card]\n      exact IsMatching.encard_le hM'\n    have hMx_card : Mx.encard = ν(G) := IsMaxMatching.encard hMx_max\n    have hMy_card : My.encard = ν(G) := by\n      apply IsMaxMatching.encard\n      refine ⟨hMy, fun M' hM' ↦ ?_⟩\n      exact le_of_lt (lt_of_le_of_ne (IsMatching.encard_le hM') (Ne.symm (by aesop)))\n    rw [← hMx_card, ← hMy_card]\n    have h_edge : ∃ e, e ∈ E(G) ∧ V(G, e) = {x, y} := by\n      obtain ⟨e, he⟩ := h\n      exact ⟨e, he.1, by aesop⟩\n    obtain ⟨e, heE, heV⟩ := h_edge\n    have heMx : e ∉ Mx := by\n      intro heMx\n      have hx_in : x ∈ V(G, Mx) := by\n        use e, heMx\n        simp [heV]\n      contradiction\n    have heMy : e ∉ My := by\n      intro heMy\n      have hy_in : y ∈ V(G, My) := by\n        use e, heMy\n        simp [heV]\n      contradiction\n    have hMx_union : G.IsMatching (Mx ∪ {e}) := by\n      refine ⟨by aesop, fun f g hf hg hfg ↦ ?_⟩\n      cases' hf with hf hf <;> cases' hg with hg hg <;> simp_all\n      · exact hMx.disjoint hf hg hfg\n      · have hfg' : f ≠ e := by aesop\n        have h_disj : Disjoint V(G, f) V(G, e) := by\n          have hfx : x ∉ V(G, f) := by\n            intro hfx\n            have hfx' : f ∈ E(G, x) := by\n              use x, hfx\n            have hfx'' : f ∈ Mx ∩ E(G, x) := by\n              exact ⟨hf, hfx'⟩\n            have hMx_sub : (Mx ∩ E(G, x)).Subsingleton := hMx.subsingleton_inc x\n            have hMx_empty : Mx ∩ E(G, x) = ∅ := by\n              intro h\n              have hMx_nonempty : (Mx ∩ E(G, x)).Nonempty := by\n                exact Set.nonempty_of_mem h\n              contradiction\n            contradiction\n          have hfy : y ∉ V(G, f) := by\n            intro hfy\n            have hfy' : f ∈ E(G, y) := by\n              use y, hfy\n            have hfy'' : f ∈ Mx ∩ E(G, y) := by\n              exact ⟨hf, hfy'⟩\n            have hMx_sub : (Mx ∩ E(G, y)).Subsingleton := hMx.subsingleton_inc y\n            have hMx_empty : Mx ∩ E(G, y) = ∅ := by\n              intro h\n              have hMx_nonempty : (Mx ∩ E(G, y)).Nonempty := by\n                exact Set.nonempty_of_mem h\n              contradiction\n            contradiction\n          simp [heV, Set.disjoint_iff]\n          intro w hw\n          aesop\n        exact h_disj\n      · have hfg' : g ≠ e := by aesop\n        have h_disj : Disjoint V(G, g) V(G, e) := by\n          have hgx : x ∉ V(G, g) := by\n            intro hgx\n            have hgx' : g ∈ E(G, x) := by\n              use x, hgx\n            have hgx'' : g ∈ Mx ∩ E(G, x) := by\n              exact ⟨hg, hgx'⟩\n            have hMx_sub : (Mx ∩ E(G, x)).Subsingleton := hMx.subsingleton_inc x\n            have hMx_empty : Mx ∩ E(G, x) = ∅ := by\n              intro h\n              have hMx_nonempty : (Mx ∩ E(G, x)).Nonempty := by\n                exact Set.nonempty_of_mem h\n              contradiction\n            contradiction\n          have hgy : y ∉ V(G, g) := by\n            intro hgy\n            have hgy' : g ∈ E(G, y) := by\n              use y, hgy\n            have hgy'' : g ∈ Mx ∩ E(G, y) := by\n              exact ⟨hg, hgy'