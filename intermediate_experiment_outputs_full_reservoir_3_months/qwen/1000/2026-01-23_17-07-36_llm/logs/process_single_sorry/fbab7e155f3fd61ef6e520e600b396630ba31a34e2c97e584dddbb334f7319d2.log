instance (K : Type*) [CommRing K] [ValuativeRel K]
    (L : Type*) [CommRing L] [ValuativeRel L]
    [Algebra K L] [ValuativeExtension K L] :
    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨algebraMap K L r.1, by
      obtain ⟨r, hr⟩ := r
      rw [Valuation.mem_integer_iff] at hr ⊢
      rw [Algebra.smul_def, Valuation.map_one]
      apply le_of_eq
      rw [ValuativeExtension.rel_iff_rel]
      exact hr⟩
    map_add' := fun x y ↦ Subtype.ext (algebraMap_add _ _)
    map_one' := Subtype.ext algebraMap_one
    map_mul' := fun x y ↦ Subtype.ext (algebraMap_mul _ _)
  }
```
