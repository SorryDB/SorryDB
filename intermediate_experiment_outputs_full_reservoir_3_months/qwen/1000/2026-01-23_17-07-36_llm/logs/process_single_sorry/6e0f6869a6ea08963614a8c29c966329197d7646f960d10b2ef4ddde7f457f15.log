def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  by
  unfold beq
  induction w with
  | zero => simp [BitVec.eq_iff]
  | succ w ih =>
    simp_all [BitVec.eq_iff, Nat.sub_zero, Nat.sub_succ]
    <;> try rfl
```
