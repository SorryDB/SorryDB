    [MeasurableSpace ι]
    (hX1 : HasLocallyIntegrableSup X 𝓕 P) (hX2 : Adapted 𝓕 X) (h𝓕 : 𝓕.IsRightContinuous) :
    Locally (ClassDL · 𝓕 P) 𝓕 X P := by
  refine hX1.elim fun t ht => ?_
  have h_prog : ProgMeasurable 𝓕 X := hX2.progMeasurable_of_rightContinuous h𝓕
  refine ⟨t, ht, ⟨h_prog, fun s => ?_⟩⟩
