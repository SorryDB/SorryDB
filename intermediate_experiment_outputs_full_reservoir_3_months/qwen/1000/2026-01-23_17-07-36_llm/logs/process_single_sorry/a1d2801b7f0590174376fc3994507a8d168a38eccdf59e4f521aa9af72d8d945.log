    simp_all only [h_val_y1]
    have h_assump : x.val < 2^n ∧ ZMod.val (y + 1) ≤ 2^n := by
      simp_all only [h_val_y1]
    have h_lt : 2^(n+1) < p := hn
    have h_bound : ZMod.val (y + 1) < 2^(n+1) := by
      calc
        ZMod.val (y + 1) = y.val + 1 := h_val_y1
        _ ≤ 2^n := h_y1
        _ < 2^(n+1) := by gcongr; linarith
    exact ⟨h_bound, h_env.right⟩
