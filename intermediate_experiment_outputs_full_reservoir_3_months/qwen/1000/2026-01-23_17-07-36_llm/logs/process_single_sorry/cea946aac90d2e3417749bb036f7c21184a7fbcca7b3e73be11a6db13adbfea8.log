ends\n  have hu : u ∉ V(G, M) := by\n    intro huM\n    have huM' : u ∈ V(G, M') := by\n      have huG' : u ∈ V(G') := by simp [hV]; aesop\n      have huG : u ∈ V(G) := (hG'comp.subgraph).verts_subset huG'\n      have huM'M : u ∈ V(G, M ∆ M') := by\n        apply (hG'comp.subgraph).verts_subset\n        simp [hV]; aesop\n      simp at huM'M\n      aesop\n    have huMM' : u ∈ V(G, M ∩ M') := by aesop\n    have huM'' : u ∈ V(G, M') := by aesop\n    have huM : u ∈ V(G, M) := by aesop\n    have huM' : u ∈ V(G, M') := by aesop\n    have huMM' : u ∈ V(G, M ∩ M') := by aesop\n    have huM'' : u ∈ V(G, M') := by aesop\n    contradiction\n  have hv : v ∉ V(G, M) := by\n    intro hvM\n    have hvM' : v ∈ V(G, M') := by\n      have hvG' : v ∈ V(G') := by simp [hV]; aesop\n      have hvG : v ∈ V(G) := (hG'comp.subgraph).verts_subset hvG'\n      have hvM'M : v ∈ V(G, M ∆ M') := by\n        apply (hG'comp.subgraph).verts_subset\n        simp [hV]; aesop\n      simp at hvM'M\n      aesop\n    have hvMM' : v ∈ V(G, M ∩ M') := by aesop\n    have hvM'' : v ∈ V(G, M') := by aesop\n    have hvM : v ∈ V(G, M) := by aesop\n    have hvM' : v ∈ V(G, M') := by aesop\n    have hvMM' : v ∈ V(G, M ∩ M') := by aesop\n    have hvM'' : v ∈ V(G, M') := by aesop\n    contradiction\n  have hP : ∃ P, G'.IsPath P ∧ P.first = u ∧ P.last = v := by\n    apply hG'path.exists_path\n  obtain ⟨P, hPpath, hPfirst, hPlast⟩ := hP\n  have hPalt : G.IsAltPath hM P := by\n    apply hG'comp.subgraph.isAltPath_of_isPath\n    exact hPpath\n    intro e he\n    simp [restrict₂, loopRemove, subgraph, edgeSet, symmDiff]\n    aesop\n  exact ⟨P, hPalt, hP.nonempty_of_length_pos (by aesop), hu, hv⟩",
      "\n  have hG' : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmax := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax\n  have hdiff : (M ∆ M').encard = M.encard + M'.encard - 2 * (M ∩ M').encard := by\n    rw [symmDiff_encard, add_comm]\n  have hodd : Odd ((M ∆ M').encard) := by\n    rw [hdiff]\n    omega\n  have hpath : ∃ G' : Graph α β, G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph := by\n    contrapose! hodd\n    have hcycle : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsCycleGraph :=\n      fun G' hG' ↦ (hcomp G' hG').resolve_left (hodd G' hG')\n    have heq : (M ∆ M').encard = ∑ G' in (hM.restrict₂ hM').components, E(G').encard := by\n      simp [edge_partition_components]\n    rw [heq]\n    refine Finset.sum_even (fun G' _ ↦ ?_)\n    have hG' : G'.IsCompOf (hM.restrict₂ hM') := (hM.restrict₂ hM').mem_components.mp ‹_›\n    have hcyc : G'.IsCycleGraph := hcycle G' hG'\n    have heven : Even (E(G').encard) := hcyc.encard_eq_card_verts |>.symm ▸ hcyc.card_verts_even\n    exact even_iff_not_odd.mp heven\n  obtain ⟨G', hG'comp, hG'path⟩ := hpath\n  have hends : ∃ u v, u ≠ v ∧ u ∈ V(G') ∧ v ∈ V(G') ∧\n      (∀ w ∈ V(G'), w = u ∨ w = v ∨ (M ∩ E(G, w)).Nonempty ∧ (M' ∩ E(G, w)).Nonempty) := by\n    have hdeg : ∀ w ∈ V(G'), (E(G', w).encard = 1 ↔ w = G'.first ∨ w = G'.last) := by\n      simp_all [hG'path.first_mem, hG'path.last_mem, hG'path.first_ne_last]\n    use G'.first, G'.last\n    constructor\n    · exact hG'path.first_ne_last\n    · constructor\n      · exact hG'path.first_mem\n      · constructor\n        · exact hG'path.last_mem\n        · intro w hw\n          by_cases hfw : w = G'.first\n          · simp_all\n          by_cases hlw : w = G'.last\n          · simp_all\n          have hdeg2 : E(G', w).encard = 2 := by\n            simp_all [hdeg, hfw, hlw]\n          have hboth : (M ∩ E(G, w)).Nonempty ∧ (M' ∩ E(G, w)).Nonempty := by\n            have hG'le : G' ≤ hM.restrict₂ hM' := hG'comp.toEmbedding.le\n            have hw' : w ∈ V(hM.restrict₂ hM') := hG'le.V_mono hw\n            simp_all [restrict₂, loopRemove, edgeSet, inter_subset_inter_left]\n            have hdegM : (M ∩ E(G, w)).encard ≤ 1 := hM.degree_le_one w\n            have hdegM' : (M' ∩ E(G, w)).encard ≤ 1 := hM'.degree_le_one w\n            have hdegsum : (M ∩ E(G, w)).encard + (M' ∩ E(G, w)).encard = 2 := by\n              calc\n                (M ∩ E(G, w)).encard + (M' ∩ E(G, w)).encard\n                  = (M ∩ E(G, w) ∪ M' ∩ E(G, w)).encard := by\n                    rw [encard_union_add, encard_inter_le_encard_inter]\n                    · rfl\n                    · exact (hM.subsingleton_inc w).inter (hM'.subsingleton_inc w)\n                _ = E(G', w).encard := by\n                    simp_all [restrict₂, loopRemove, edgeSet, inter_subset_inter_left]\n                _ = 2 := hdeg2\n            have hMnon : (M ∩ E(G, w)).Nonempty := by\n              by_contra h\n              simp_all at hdegsum\n            have hM'non : (M' ∩ E(G, w)).Nonempty := by\n              by_contra h\n              simp_all at hdegsum\n            exact ⟨hMnon, hM'non⟩\n          exact Or.inr hboth\n  obtain ⟨u, v, huv, hu, hv, hends⟩ := hends\n  have hu' : u ∉ V(G, M) := by\n    intro h\n    obtain ⟨e, heM, he⟩ := h\n    have heG' : e ∈ E(G') := by\n      simp_all [restrict₂, loopRemove, edgeSet, inter_subset_inter_left]\n    have hdeg1 : E(G', u).encard = 1 := by\n      simp_all [hG'path.first_mem, hG'path.last_mem, hG'path.first_ne_last]\n    have hdegM : (M ∩ E(G, u)).encard = 1 := by\n      simp_all [encard_pos]\n    have hdegM' : (M' ∩ E(G, u)).encard = 0 := by\n      have hboth : (M ∩ E(G, u)).Nonempty ∧ (M' ∩ E(G, u)).Nonempty → False := by\n        intro h\n        have hu'' : u = u ∨ u = v ∨ (M ∩ E(G, u)).Nonempty ∧ (M' ∩ E(G, u)).Nonempty := hends u hu\n        simp_