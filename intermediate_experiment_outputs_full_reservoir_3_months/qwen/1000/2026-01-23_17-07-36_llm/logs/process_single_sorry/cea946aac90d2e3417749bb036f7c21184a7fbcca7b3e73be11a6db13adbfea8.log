      "\n  have hsymm : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmaxdeg : (hM.restrict₂ hM').MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmaxdeg\n  have hdiff : (M' \\ M).encard > (M \\ M').encard := by\n    rw [← encard_sdiff_add_encard_inter, ← encard_sdiff_add_encard_inter] at hM'cd\n    omega\n  have hpath : ∃ G' : Graph α β, G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph := by\n    contrapose! hdiff\n    have : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsCycleGraph :=\n      fun G' hG' ↦ (hcomp G' hG').resolve_left (hdiff G' hG')\n    have : (M \\ M').encard = (M' \\ M).encard := by\n      calc\n        (M \\ M').encard = ∑ G' in (hM.restrict₂ hM').components, (E(G') ∩ M).encard := by\n          sorry\n        _ = ∑ G' in (hM.restrict₂ hM').components, (E(G') ∩ M').encard := by\n          sorry\n        _ = (M' \\ M).encard := by\n          sorry\n    exact le_antisymm (by linarith) (by linarith)\n  obtain ⟨G', hG'comp, hG'path⟩ := hpath\n  have hG'odd : Odd (V(G')).encard := by\n    sorry\n  have hends : ∃ u v, u ∈ V(G') ∧ v ∈ V(G') ∧ u ≠ v ∧ u ∉ V(G, M) ∧ v ∉ V(G, M) := by\n    sorry\n  obtain ⟨u, v, hu, hv, huv, hum, hvm⟩ := hends\n  have hP : ∃ P, G'.IsPath P ∧ P.first = u ∧ P.last = v := by\n    exact hG'path.exists_path hu hv\n  obtain ⟨P, hPpath, hPfirst, hPlast⟩ := hP\n  refine ⟨P, ?_⟩\n  refine ⟨⟨⟨hPpath.le hG'comp.toEmbedding, ?_⟩, ?_⟩, ?_, hum, hvm⟩\n  · simp_all [WList.edge]\n  · simp_all [WList.edge]\n  · simp_all",
      "\n  have hG' : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmax := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax\n  have hne : (hM.restrict₂ hM').V.Nonempty := by\n    contrapose! hM'cd\n    simp_all [encard_eq_zero_iff, Set.subset_empty_iff]\n  obtain ⟨G', hG'comp, hG'path⟩ := by\n    apply Exists.intro (hM.restrict₂ hM').components.some\n    apply And.intro (hM.restrict₂ hM').components.some_spec\n    cases hcomp (hM.restrict₂ hM').components.some (hM.restrict₂ hM').components.some_spec <;> assumption\n  cases hG'path\n  case inl hG'path =>\n    use WList.ofPathGraph hG'path\n    simp_all [isAugPath_iff, isAltPath_iff, WList.ofPathGraph_edge, WList.ofPathGraph_first,\n      WList.ofPathGraph_last, V_restr_eq_inter]\n    <;> aesop\n  case inr hG'cycle =>\n    have hencard : (E(G') ∩ M).encard = (E(G') ∩ M').encard :=\n      hM.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM' hG'cycle hG'comp\n    have hencard' : M.encard = M'.encard := by\n      calc\n        M.encard = (M ∩ E(G')).encard + (M \\ E(G')).encard := by\n          rw [encard_union_add_encard_diff (Set.inter_subset_left _ _)]\n        _ = (M' ∩ E(G')).encard + (M \\ E(G')).encard := by rw [hencard]\n        _ = (M' ∩ E(G')).encard + (M' \\ E(G')).encard := by\n          sorry\n        _ = M'.encard := by\n          rw [encard_union_add_encard_diff (Set.inter_subset_left _ _)]\n    exact (lt_irrefl _ (by linarith : M.encard < M.encard))",
      "\n  have hmax := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax\n  have hdiff : (M' \\ M).encard > (M \\ M').encard := by\n    rw [← encard_sdiff_add_encard_inter, ← encard_sdiff_add_encard_inter]\n    omega\n  have hpath : ∃ G' : Graph α β, G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph := by\n    contrapose! hdiff\n    have hcycle : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsCycleGraph :=\n      fun G' hG' ↦ (hcomp G' hG').resolve_left (hdiff G' hG')\n    calc\n      (M' \\ M).encard = ∑ H in (OddComponents (hM.restrict₂ hM')).toFinset, (E(H) ∩ M').encard := by\n        sorry\n      _ = ∑ H in (OddComponents (hM.restrict₂ hM')).toFinset, (E(H) ∩ M).encard := by\n        sorry\n      _ = (M \\ M').encard := by\n        sorry\n  obtain ⟨G', hG'comp, hG'path⟩ := hpath\n  have hends : ∃ u v, u ≠ v ∧ u ∈ V(G') ∧ v ∈ V(G') ∧ u ∉ V(G, M) ∧ v ∉ V(G, M) := by\n    sorry\n  obtain ⟨u, v, huv, hu, hv, hun, hvn⟩ := hends\n  have hP : ∃ P, G'.IsPath P ∧ P.first = u ∧ P.last = v := by\n    exact hG'path.exists_path hu hv\n  obtain ⟨P, hPpath, hPfirst, hPlast⟩ := hP\n  refine ⟨P, ?_⟩\n  constructor\n  · exact hPpath.toIsPath\n  · simp_all",
