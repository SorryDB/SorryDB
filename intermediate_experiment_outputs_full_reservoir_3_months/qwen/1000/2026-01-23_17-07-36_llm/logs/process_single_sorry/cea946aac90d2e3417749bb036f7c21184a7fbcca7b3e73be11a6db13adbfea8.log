      "\n  have hG' : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmax : (hM.restrict₂ hM').MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax\n  have hpath : ∃ G' : Graph α β, G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph := by\n    contrapose! hM'cd\n    have : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsCycleGraph :=\n      fun G' hG' ↦ (hcomp G' hG').resolve_left (hM'cd G' hG')\n    calc\n      M'.encard = (∑ C in (hM.restrict₂ hM').Components, (E(C) ∩ M').encard) := by\n        sorry\n      _ = (∑ C in (hM.restrict₂ hM').Components, (E(C) ∩ M).encard) := by\n        sorry\n      _ = M.encard := by\n        sorry\n  obtain ⟨G', hG'comp, hG'path⟩ := hpath\n  have hG'fin : V(G').Finite := by\n    sorry\n  have hG'odd : Odd V(G').encard ∨ Even V(G').encard := by\n    sorry\n  have hends : ∃ u v, u ≠ v ∧ u ∈ V(G') ∧ v ∈ V(G') ∧\n      (u ∉ V(G, M) ∨ v ∉ V(G, M)) := by\n    sorry\n  obtain ⟨u, v, huv, hu, hv, huv'⟩ := hends\n  have hP : ∃ P, G'.IsPath P ∧ P.first = u ∧ P.last = v := by\n    sorry\n  obtain ⟨P, hPpath, hPfirst, hPlast⟩ := hP\n  have hPalt : G.IsAltPath hM P := by\n    sorry\n  have hPaug : G.IsAugPath hM P := by\n    sorry\n  exact ⟨P, hPaug⟩",
      "\n  have hG' : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmax : (hM.restrict₂ hM').MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax\n  have hodd : ∃ G', G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph ∧ Odd (V(G').encard) := by\n    have hdiff : (M' \\ M).encard > (M \\ M').encard := by\n      rw [← encard_sdiff_add_encard_inter, ← encard_sdiff_add_encard_inter]\n      omega\n    have hsum : (∑ G' in (hM.restrict₂ hM').components, (E(G') ∩ M').encard - (E(G') ∩ M).encard) = (M' \\ M).encard - (M \\ M').encard := by\n      sorry\n    sorry\n  obtain ⟨G', hG'comp, hG'path, hG'odd⟩ := hodd\n  have hG'ends : ∃ u v, u ≠ v ∧ G'.IsPathFromTo u v := by\n    exact hG'path.exists_ends\n  obtain ⟨u, v, huv, hG'uv⟩ := hG'ends\n  have hu : u ∉ V(G, M) := by\n    sorry\n  have hv : v ∉ V(G, M) := by\n    sorry\n  have hP : ∃ P, G.IsPath P ∧ P.edge = E(G') := by\n    exact hG'uv.toWList\n  obtain ⟨P, hPpath, hPedge⟩ := hP\n  refine ⟨P, ?_⟩\n  constructor\n  · constructor\n    · exact hPpath\n    · sorry\n  · constructor\n    · intro hPne\n      exact hPne\n    · constructor\n      · exact hu\n      · exact hv",
      "\n  have hsymm : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmaxdeg : (hM.restrict₂ hM').MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∃ G' : Graph α β, G'.IsCompOf (hM.restrict₂ hM') ∧ ¬G'.IsCycleGraph := by\n    contrapose! hM'cd\n    have : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsCycleGraph := by\n      intro G' hG'\n      exact hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmaxdeg |>.resolve_left (hM'cd G' hG')\n    have : M.encard = M'.encard := by\n      calc\n        M.encard = ∑ C in (hM.restrict₂ hM').components, (E(C) ∩ M).encard := by\n          sorry\n        _ = ∑ C in (hM.restrict₂ hM').components, (E(C) ∩ M').encard := by\n          apply Finset.sum_congr rfl\n          intro C hC\n          exact hM.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM' (this C hC) hC\n        _ = M'.encard := by\n          sorry\n    exact le_antisymm (by linarith) (by linarith)\n  obtain ⟨G', hG'comp, hG'notcycle⟩ := hcomp\n  have hG'path : G'.IsPathGraph := hG'comp.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmaxdeg |>.resolve_right hG'notcycle\n  have hends : G'.V.encard ≥ 2 := by\n    apply Nat.succ_le_iff.mpr\n    exact hG'path.nonempty\n  have hfirstlast : ∃ x y, x ≠ y ∧ G'.V = {x, y} ∪ (G'.V \\ {x, y}) := by\n    obtain ⟨x, hx⟩ := Set.exists_mem_of_nonempty (by simpa using hG'path.nonempty)\n    obtain ⟨y, hy, hxy⟩ := Set.exists_of_ssubset (Set.ssubset_insert_iff.mpr ⟨hx, by simpa using hends⟩)\n    use x, y\n    simp [hxy]\n  obtain ⟨x, y, hxy, hV⟩ := hfirstlast\n  have hxnot : x ∉ V(G, M) ∨ x ∉ V(G, M') := by\n    by_contra h\n    push_neg at h\n    have : E(G', x).encard ≥ 2 := by\n      sorry\n    have : E(hM.restrict₂ hM', x).encard ≤ 2 := by\n      apply hmaxdeg\n      simp [hV]\n    linarith\n  have hynot : y ∉ V(G, M) ∨ y ∉ V(G, M') := by\n    by_contra h\n    push_neg at h\n    have : E(G', y).encard ≥ 2 := by\n      sorry\n    have : E(hM.restrict₂ hM', y).encard ≤ 2 := by\n      apply hmaxdeg\n      simp [hV]\n    linarith\n  cases' hxnot with hxnotM hxnotM' <;> cases' hynot with hynotM hynotM' <;>\n    try\n      {\n        use G'.toWList\n        constructor\n        · exact hG'path.toPath\n        · simp [hxnotM, hynotM, hG'comp.subgraph_edge_subset]\n      }\n  all_goals\n    {\n      have : M.encard = M'.encard := by\n        sorry\n      linarith\n    }",
