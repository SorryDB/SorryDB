      "\n  have hG' : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmax := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax\n  have hdiff : (M ∆ M').encard = M.encard + M'.encard - 2 * (M ∩ M').encard := by\n    rw [symmDiff_encard, add_tsub_cancel_of_le]\n    exact le_add_right (le_mul_of_one_le_left (by norm_num) (encard_nonneg _))\n  have hodd : Odd ((M ∆ M').encard) := by\n    rw [hdiff]\n    omega\n  have hpath : ∃ G' : Graph α β, G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph := by\n    contrapose! hodd\n    have hcycle : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsCycleGraph :=\n      fun G' hG' ↦ (hcomp G' hG').resolve_left (hodd G' hG')\n    have heq : (M ∆ M').encard = ∑ C in (hM.restrict₂ hM').components, E(C).encard := by\n      rw [edge_partition_components]\n    rw [heq]\n    refine Finset.sum_even (fun C hC ↦ ?_)\n    have hC' : C.IsCycleGraph := hcycle C (mem_components.mp hC)\n    have henc : (E(C) ∩ M).encard = (E(C) ∩ M').encard :=\n      hM.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM' hC' (mem_components.mp hC)\n    rw [← two_mul, ← Nat.add_sub_assoc, add_comm]\n    simp_all [Nat.even_add, Nat.even_sub, Nat.even_mul, Nat.even_two]\n  obtain ⟨G', hG'comp, hG'path⟩ := hpath\n  have hends : ∃ u v, G'.IsPathFromTo u v := hG'path\n  obtain ⟨u, v, huv⟩ := hends\n  have hu : u ∉ V(G, M) := by\n    intro hu\n    have h1 : (M ∩ E(G, u)).encard = 1 := by\n      apply encard_eq_one_of_mem\n      exact ⟨hM.subset, ?_⟩\n      use u\n      simp\n    have h2 : (M' ∩ E(G, u)).encard = 0 := by\n      apply encard_eq_zero\n      intro e he\n      have h3 : e ∈ M ∆ M' := by\n        simp_all\n      have h4 : e ∈ E(G', u) := by\n        simp_all [hG'comp.mem_edge]\n      have h5 : (M ∩ E(G', u)).encard ≤ 1 := by\n        apply encard_le_encard\n        rintro e ⟨w, hw⟩\n      