      "\n  have hG' : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmax : (hM.restrict₂ hM').MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax\n  have hpath : ∃ G' : Graph α β, G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph := by\n    contrapose! hM'cd\n    have : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsCycleGraph :=\n      fun G' hG' ↦ (hcomp G' hG').resolve_left (hM'cd G' hG')\n    have : (M ∆ M').encard = 0 := by\n      calc\n        (M ∆ M').encard = ∑ C in (hM.restrict₂ hM').components, E(C).encard := by\n          simp [symmDiff_encard_components]\n        _ = ∑ C in (hM.restrict₂ hM').components, 2 * (E(C) ∩ M).encard := by\n          apply Finset.sum_congr rfl\n          intro C hC\n          rw [← hM.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM' (this C hC).out]\n          rw [encard_inter_union_compl, add_comm]\n          omega\n        _ = 2 * ∑ C in (hM.restrict₂ hM').components, (E(C) ∩ M).encard := by\n          simp [Finset.mul_sum]\n        _ = 2 * M.encard := by\n          simp [symmDiff_encard_components, hM.subsingleton_inc]\n    have : M.encard = M'.encard := by\n      rw [← encard_symmDiff_add_encard_inter, ← encard_symmDiff_add_encard_inter]\n      simp [*]\n    omega\n  obtain ⟨G', hG'comp, hG'path⟩ := hpath\n  have hG'fin : V(G').Finite := hG'comp.finite\n  have hG'odd : Odd V(G').encard ∨ Even V(G').encard := by\n    apply Nat.even_or_odd\n  cases' hG'odd with hodd heven\n  · have : ∃ x ∈ V(G'), x ∉ V(G, M) := by\n      have : V(G').encard > 0 := by\n        apply Nat.pos_of_ne_zero\n        intro h\n        have : V(G') = ∅ := by\n          apply Set.eq_empty_of_encard_eq_zero\n          exact h\n        simp_all\n      have : V(G').encard ≥ 2 := by\n        omega\n      have : V(G', M ∩ E(G')).encard ≤ V(G').encard / 2 := by\n     