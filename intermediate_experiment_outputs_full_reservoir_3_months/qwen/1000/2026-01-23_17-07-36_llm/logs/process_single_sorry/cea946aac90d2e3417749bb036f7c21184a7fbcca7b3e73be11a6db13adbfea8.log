lemma IsMatching.exists_isAugPath_not_max (hM : G.IsMatching M) (hnotmax : ¬ G.IsMaxMatching M)
    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  obtain ⟨M', hM', hM'cd⟩ := by
    simpa only [isMaxMatching_iff, hM, true_and, not_forall, not_le] using hnotmax
  have hmax := hM.symmDiff_maxDegree_le_two hM'
  have hcomp := (hM.restrict₂ hM').components_finite_of_edgeFinite
  have hdiff : (M ∆ M').encard = M.encard + M'.encard - 2 * (M ∩ M').encard := by
    rw [symmDiff_encard, add_tsub_cancel_of_le]
    exact encard_inter_le_left _ _
  have hodd : Odd ((M ∆ M').encard) := by
    rw [hdiff]
    omega
  obtain ⟨C, hCcomp, hCodd⟩ := exists_odd_component_of_symmDiff_encard_odd hM hM' hM'cd
  have hCpath : C.IsPathGraph := by
    apply hCcomp.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax |>.resolve_right
    intro hCcycle
    have := hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hCcycle (by exact hCcomp.le)
    simp_all [Disjoint, Set.inter_comm]
  obtain ⟨x, hx⟩ := hCpath.exists_start
  obtain ⟨y, hy⟩ := hCpath.exists_end
  have hxM : x ∉ V(G, M) := by
    intro hxM
    have := hM.subsingleton_inc x
    simp_all [V_eq_union_inc, Set.mem_union]
  have hyM : y ∉ V(G, M) := by
    intro hyM
    have := hM.subsingleton_inc y
    simp_all [V_eq_union_inc, Set.mem_union]
  refine ⟨C.toWList, ?_⟩
  simp_all [isAugPath_iff, isAltPath_iff, hCpath.toWList_isPath]
