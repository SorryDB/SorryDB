lemma IsMatching.exists_isAugPath_not_max (hM : G.IsMatching M) (hnotmax : ¬ G.IsMaxMatching M)
    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  obtain ⟨M', hM', hM'cd⟩ := by
    simpa only [isMaxMatching_iff, hM, true_and, not_forall, not_le] using hnotmax
  have h : M.encard < M'.encard := hM'cd
  let G' := hM.restrict₂ hM'
  have hG' : G'.EdgeFinite := hM.restrict₂.edgeFinite hM'
  have hmaxdeg : G'.MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'
  have hcomp : ∀ H, H.IsCompOf G' → H.IsPathGraph ∨ H.IsCycleGraph :=
    fun H hH ↦ hH.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmaxdeg
  have hdiff : (M' \ M).encard > (M \ M').encard := by
    rw [← encard_sdiff_add_encard_inter, ← encard_sdiff_add_encard_inter]
    omega
  have hpath : ∃ H, H.IsCompOf G' ∧ H.IsPathGraph ∧ Odd (E(H) ∩ M').encard := by
    sorry
  obtain ⟨H, hHcomp, hHpath, hHodd⟩ := hpath
  have hends : ∃ u v, H.first = u ∧ H.last = v ∧ u ∉ V(G, M) ∧ v ∉ V(G, M) := by
    sorry
  obtain ⟨u, v, hu, hv, hun, hvn⟩ := hends
  use H.toWList
  simp_all [isAugPath_iff, isAltPath_iff]
