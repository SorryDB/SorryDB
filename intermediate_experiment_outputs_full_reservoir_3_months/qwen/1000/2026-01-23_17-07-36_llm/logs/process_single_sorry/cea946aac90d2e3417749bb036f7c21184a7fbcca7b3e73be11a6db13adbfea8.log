V(G, M)) := by\n    sorry\n  obtain ⟨u, v, hu, hv, huv, hnotboth⟩ := hends\n  have hP : ∃ P, G'.IsPath P ∧ P.first = u ∧ P.last = v := by\n    exact hG'path.exists_path hu hv huv\n  obtain ⟨P, hPpath, hPfirst, hPlast⟩ := hP\n  have hPaltpath : G.IsAltPath hM P := by\n    refine ⟨?_, ?_⟩\n    · exact hG'comp.subgraph.isPath_of_le hPpath\n    · simp_all [WList.edge_cons, WList.edge_nil]\n  have hPaug : G.IsAugPath hM P := by\n    refine ⟨hPaltpath, ?_, ?_, ?_⟩\n    · exact hPpath.nonempty_of_length_pos (by aesop)\n    · sorry\n    · sorry\n  exact ⟨P, hPaug⟩",
