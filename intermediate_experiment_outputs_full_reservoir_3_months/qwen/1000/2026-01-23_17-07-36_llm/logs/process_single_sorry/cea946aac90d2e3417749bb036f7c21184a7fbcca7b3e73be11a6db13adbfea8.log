      "\n  have hG' : (hM.restrict₂ hM').EdgeFinite := inferInstance\n  have hmax := hM.symmDiff_maxDegree_le_two hM'\n  have hcomp : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsPathGraph ∨ G'.IsCycleGraph :=\n    fun G' hG' ↦ hG'.isPathGraph_or_isCycleGraph_of_maxDegreeLE hmax\n  have hpath : ∃ G', G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph := by\n    contrapose! hM'cd\n    have hcycle : ∀ (G' : Graph α β), G'.IsCompOf (hM.restrict₂ hM') → G'.IsCycleGraph :=\n      fun G' hG' ↦ (hcomp G' hG').resolve_left (hM'cd G' hG')\n    calc\n      M'.encard = (∑ C in (hM.restrict₂ hM').Components, (E(C) ∩ M').encard) := by\n        rw [← encard_iUnion_of_disjoint (hM.restrict₂ hM').edgePartition_components]\n        congr; ext e; simp [hM.restrict₂, symmDiff, Set.mem_inter_iff, Set.mem_diff]\n      _ = (∑ C in (hM.restrict₂ hM').Components, (E(C) ∩ M).encard) := by\n        apply Finset.sum_congr rfl\n        intro C hC\n        exact hM.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM' (hcycle C hC) hC\n      _ = M.encard := by\n        rw [← encard_iUnion_of_disjoint (hM.restrict₂ hM').edgePartition_components]\n        congr; ext e; simp [hM.restrict₂, symmDiff, Set.mem_inter_iff, Set.mem_diff]\n  obtain ⟨G', hG'comp, hG'path⟩ := hpath\n  have hends : ∃ u v, G'.IsPathFromTo u v ∧ u ∉ V(G, M) ∧ v ∉ V(G, M) := by\n    have hdeg : ∀ x ∈ V(G'), E(G', x).encard ≤ 1 := by\n      intro x hx\n      have := hmax x (by simpa using hx)\n      rwa [eDegree_eq_encard_inc] at this\n    have hodd : Odd (V(G') \\ V(G, M)).encard := by\n      calc\n        (V(G') \\ V(G, M)).encard = V(G').encard - (V(G') ∩ V(G, M)).encard := by\n          rw [encard_diff_inter]\n        _ = V(G').encard - 2 * (E(G') ∩ M).encard := by\n          have : (V(G') ∩ V(G, M)).encard = 2 * (E(G') ∩ M).encard := by\n            calc\n              _ = (∑ e in E(G') ∩ M, V(G, e).encard) := by\n                rw [← encard_iUnion_of_disjoint (hM.subsingleton_inc ·)]\n                congr; ext