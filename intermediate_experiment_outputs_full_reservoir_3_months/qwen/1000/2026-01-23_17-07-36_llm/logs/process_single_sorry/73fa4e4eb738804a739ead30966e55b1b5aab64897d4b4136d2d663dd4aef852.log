lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- Use uniqueness of solutions to linear ODEs with given initial conditions
    -- The trajectory is known to satisfy the same ODE and initial conditions
    have h_traj_eq : S.EquationOfMotion (IC.trajectory S) := trajectory_equationOfMotion IC
    have h_traj_x0 : IC.trajectory S 0 = IC.x₀ := trajectory_position_at_zero IC
    have h_traj_v0 : ∂ₜ (IC.trajectory S) 0 = IC.v₀ := trajectory_velocity_at_zero IC
    -- Since both x and trajectory satisfy the same second-order linear ODE
    -- and same initial conditions, they must be equal
    -- This follows from standard ODE uniqueness (Picard-Lindelöf for linear systems)
    -- We can reduce to a first-order system and apply uniqueness
    sorry
  exact h_sol
