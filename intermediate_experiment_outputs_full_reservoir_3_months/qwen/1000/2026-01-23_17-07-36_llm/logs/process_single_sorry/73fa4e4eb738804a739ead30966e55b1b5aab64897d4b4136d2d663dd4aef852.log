    -- and have the same initial position and velocity, they must be equal
    -- This follows from standard uniqueness for linear ODEs
    exact (by
      have : ∀ t, x t = IC.trajectory S t := by
        -- We can use the fact that the difference satisfies a homogeneous ODE
        -- with zero initial conditions, hence is identically zero
        let y := fun t => x t - IC.trajectory S t
        have y_ode : ∀ t, ∂ₜ (∂ₜ y) t = -S.ω^2 • y t := by
          intro t
          simp only [Pi.sub_apply, PiLp.sub_apply]
          rw [h_ode t, h_traj_ode t]
          simp [smul_sub]
        have y0 : y 0 = 0 := by simp [h_x0, h_traj_x0]
        have y0' : ∂ₜ y 0 = 0 := by simp [h_v0, h_traj_v0]
        -- For the harmonic oscillator, if a solution has zero initial position
        -- and zero initial velocity, it must be identically zero
        -- This can be shown using energy conservation or direct computation
        have energy_const : ∀ t, ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2 = 0 := by
          intro t
          -- The energy is constant and zero at t=0
          have dE_dt : ∀ t, deriv (fun s => ‖∂ₜ y s‖^2 + S.ω^2 * ‖y s‖^2) t = 0 := by
