    -- This follows from standard ODE theory, which should be available in Mathlib
    -- We can use the uniqueness theorem for second-order linear ODEs
    have h_uniq : ∀ t, x t = IC.trajectory S t := by
      -- We'll use the fact that the difference y = x - trajectory satisfies y'' + ω^2 y = 0
      -- with y(0) = 0 and y'(0) = 0, so y = 0
      let y := fun t => x t - IC.trajectory S t
      have y_ode : ∀ t, ∂ₜ (∂ₜ y) t = -S.ω^2 • y t := by
        intro t
        simp only [y, Pi.sub_apply, PiLp.sub_apply]
        rw [← sub_eq_zero]
        have h1 : ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := h_ode t
        have h2 : ∂ₜ (∂ₜ (IC.trajectory S)) t = -S.ω^2 • IC.trajectory S t :=
