lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  -- The equation of motion is a second-order linear ODE with constant coefficients.
  -- Its general solution is determined uniquely by initial position and velocity.
  -- Since both x and IC.trajectory S satisfy the same ODE and same initial conditions,
  -- they must be equal by uniqueness of solutions to ODEs.
  -- In this formalization, we can use the fact that the difference satisfies a homogeneous ODE
  -- with zero initial conditions, hence is identically zero.
  have h_diff : S.EquationOfMotion (fun t => x t - IC.trajectory S t) := by
    rw [EquationOfMotion] at h_eq ⊢
    simp_all [PiLp.sub_apply, force_eq_linear, ω_sq]
    intro t
    simp only [PiLp.sub_apply, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply, smul_eq_mul]
    ring_nf
  have h_diff_zero : (fun t => x t - IC.trajectory S t) 0 = 0 := by
    simp [h_x0, trajectory_position_at_zero]
  have h_diff_vel_zero : ∂ₜ (fun t => x t - IC.trajectory S t) 0 = 0 := by
    simp [h_v0, trajectory_velocity_at_zero]
  -- Now we use the fact that the only solution to the harmonic oscillator equation
  -- with zero initial conditions is the zero function.
  -- This follows from energy conservation or direct computation.
  have h_energy_zero : ∀ t, x t - IC.trajectory S t = 0 := by
    intro t
    -- Define the energy of the difference trajectory
    have E := fun t =>
      (1/2) * ‖∂ₜ (fun t => x t - IC.trajectory S t) t‖^2 +
      (1/2) * S.ω^2 * ‖(fun t => x t - IC.trajectory S t) t‖^2
    -- Show energy is constant
    have dE_dt : ∀ t, deriv E t = 0 := by
      intro t
      -- Compute derivative using product rule and chain rule
      -- This uses the equation of motion for the difference
      sorry
    -- Since energy is constant and zero at t=0, it's zero everywhere
    have E_zero : ∀ t, E t = 0 := by
      intro t
      have := dE_dt t
      -- Energy at t=0 is zero due to zero initial conditions
      have E0 : E 0 = 0 := by
        simp [h_diff_zero, h_diff_vel_zero]
      -- Since derivative is zero, E is constant
      sorry
    -- If energy is zero, then both position and velocity differences are zero
    have pos_zero : ‖(fun t => x t - IC.trajectory S t) t‖ = 0 := by
      have := E_zero t
      simp [E] at this
      nlinarith
    exact norm_eq_zero.mp pos_zero
  funext t
  exact h_energy_zero t
