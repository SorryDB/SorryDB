lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- Use uniqueness of solutions to linear ODEs with given initial conditions
    -- The equation is x'' + ω^2 x = 0, which has unique solution given x(0), x'(0)
    -- Since both x and trajectory S IC satisfy the same ODE and same initial conditions,
    -- they must be equal.
    have h1 : x 0 = IC.trajectory S 0 := by simp [h_x0, trajectory_position_at_zero]
    have h2 : ∂ₜ x 0 = ∂ₜ (IC.trajectory S) 0 := by simp [h_v0, trajectory_velocity_at_zero]
    -- Now use the fact that the ODE is linear with constant coefficients and has unique solutions
    -- This requires invoking a uniqueness theorem for second-order linear ODEs
    -- Since we don't have such a theorem in the current context, we use the explicit form
    -- and show that the difference satisfies the ODE with zero initial conditions
    let y := fun t => x t - IC.trajectory S t
    have y_0 : y 0 = 0 := by simp [y, h1]
    have y'_0 : ∂ₜ y 0 = 0 := by simp [y, h2, Time.deriv_sub]
    have y_ode : ∀ t, ∂ₜ (∂ₜ y) t = -S.ω^2 • y t := by
      intro t
      simp [y, Time.deriv_sub, h_ode t, trajectory_acceleration]
      simp only [PiLp.sub_apply, PiLp.smul_apply, smul_sub, sub_sub_sub_cancel_right]
    -- Now we need to show y = 0
    -- Consider the energy E = (1/2)(y'^2 + ω^2 y^2)
    -- dE/dt = y' y'' + ω^2 y y' = y'(y'' + ω^2 y) = 0
    -- So E is constant, and E(0) = 0, so E(t) = 0 for all t, so y = 0
    have energy_const : ∀ t, (1/2) • (∂ₜ y t • ∂ₜ y t + S.ω^2 • (y t • y t)) = 0 := by
      -- At t = 0, this is 0
      have energy_0 : (1/2) • (∂ₜ y 0 • ∂ₜ y 0 + S.ω^2 • (y 0 • y 0)) = 0 := by
        simp [y_0, y'_0]
      -- Show derivative is 0
      have energy_deriv : ∀ t, ∂ₜ (fun t => (1/2) • (∂ₜ y t • ∂ₜ y t + S.ω^2 • (y t • y t))) t = 0 := by
        intro t
        simp [Time.deriv, fderiv_smul_const, fderiv_add, fderiv_mul, y_ode t]
        ring_nf
      -- Since derivative is 0 and value at 0 is 0, value is always 0
      intro t
      have := congr_arg (fun f => f t) (funext energy_deriv)
      simp at this
      -- This approach is getting too complex without proper energy lemmas
      -- Instead, since we know the explicit solution form, and both satisfy the same ODE
      -- with same initial conditions, they must be equal by standard ODE uniqueness
      -- Given the context, we can use the fact that the solution space is 2-dimensional
      -- and our trajectory spans it with the given initial conditions
      sorry
    sorry
  exact h_sol
