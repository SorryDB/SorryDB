lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear, ω_sq] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- The ODE is linear with constant coefficients; uniqueness follows from standard theory
    -- Since both x and trajectory S IC satisfy the same ODE and initial conditions, they are equal
    have h1 : (IC.trajectory S) 0 = IC.x₀ := by simp
    have h2 : ∂ₜ (IC.trajectory S) 0 = IC.v₀ := by simp
    have h3 : ∀ t, ∂ₜ (∂ₜ (IC.trajectory S)) t = -S.ω^2 • (IC.trajectory S) t :=
      by simpa [trajectory_acceleration, trajectory_eq, ω_sq] using rfl
    -- Use uniqueness of solutions to linear ODEs
    -- We can use the fact that the difference satisfies a homogeneous ODE with zero initial conditions
    let y := fun t => x t - IC.trajectory S t
    have y_0 : y 0 = 0 := by simp [y, h_x0, h1]
    have y'_0 : ∂ₜ y 0 = 0 := by simp [y, h_v0, h2]
    have y'' : ∀ t, ∂ₜ (∂ₜ y) t = -S.ω^2 • y t := by
      intro t
      simp [y, h_ode t, h3 t]
      ring
    -- Now show y is identically zero
    -- This follows from energy conservation or direct integration
    -- For simplicity, we use the fact that the only solution to y'' + ω^2 y = 0 with y(0)=y'(0)=0 is y=0
    have energy_conserved : ∀ t, ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2 = 0 := by
      intro t
      have ddt_energy : ∀ t, deriv (fun t => ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2) t = 0 := by
        intro t
        -- Compute derivative of energy
        -- d/dt (v^2 + ω^2 x^2) = 2 v a + 2 ω^2 x v = 2 v (a + ω^2 x) = 0
        simp [y'', inner_self_nonneg]
        ring
      have energy_const : ∀ t, ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2 = ‖∂ₜ y 0‖^2 + S.ω^2 * ‖y 0‖^2 := by
        intro t
        apply eq_of_sub_eq_zero
        have := deriv_is_constant_of_deriv_zero (fun t => ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2) ddt_energy
        simpa using this t 0
      simpa [y_0, y'_0, norm_eq_zero] using energy_const t
    have y_zero : ∀ t, y t = 0 := by
      intro t
      have h_norm : ‖y t‖^2 = 0 := by
        nlinarith [energy_conserved t, sq_nonneg (‖∂ₜ y t‖), sq_nonneg (S.ω)]
      simpa [norm_eq_zero] using h_norm
    simpa [y] using y_zero
  exact h_sol
