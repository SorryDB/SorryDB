```lean
lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  -- The equation of motion is a second-order linear ODE with constant coefficients.
  -- By standard ODE uniqueness (Picard-Lindelöf for linear systems), the solution
  -- is uniquely determined by initial position and velocity.
  -- Since both `x` and `IC.trajectory S` satisfy the same ODE and same initial conditions,
  -- they must be equal.
  -- In this formalization, we can use the fact that the difference satisfies the homogeneous
  -- equation with zero initial conditions, hence is identically zero.
  have diff_eq : S.EquationOfMotion (fun t => x t - IC.trajectory S t) := by
    rw [EquationOfMotion] at h_eq ⊢
    simp_all [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear, trajectory_equationOfMotion]
    funext t i
    simp only [PiLp.sub_apply, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply, smul_eq_mul]
    ring
  have diff_x0 : (fun t => x t - IC.trajectory S t) 0 = 0 := by
    simp [h_x0, trajectory_position_at_zero]
  have diff_v0 : ∂ₜ (fun t => x t - IC.trajectory S t) 0 = 0 := by
    simp [h_v0, trajectory_velocity_at_zero]
  -- Now we use the fact that the only solution to the harmonic oscillator with zero
  -- initial conditions is the zero function. This follows from energy conservation
  -- or direct computation.
  have energy_conserved : ∀ t, 
    (∂ₜ (fun t => x t - IC.trajectory S t) t)^2 + (S.ω^2) * ((fun t => x t - IC.trajectory S t) t)^2 = 0 := by
    -- Energy is conserved and initially zero
    have E0 : (∂ₜ (fun t => x t - IC.trajectory S t) 0)^2 + (S.ω^2) * ((fun t => x t - IC.trajectory S t) 0)^2 = 0 := by
      simp [diff_v0, diff_x0]
    -- dE/dt = 0 by the equation of motion
    have dE_dt : ∀ t, deriv (fun t => (∂ₜ (fun t => x t - IC.trajectory S t) t)^2 + (S.ω^2) * ((fun t => x t - IC.trajectory S t) t)^2) t = 0 := by
      intro t
      simp only [deriv_add, deriv_mul_const, deriv_pow, deriv_comp]
      rw [← trajectory_acceleration]
      nlinarith [diff_eq t]
    -- Therefore energy is constant and zero
    intro t
    have := (const_of_deriv_zero (dE_dt := dE_dt) : ∀ t, (∂ₜ (fun t => x t - IC.trajectory S t) t)^2 + (S.ω^2) * ((fun t => x t - IC.trajectory S t) t)^2 = (∂ₜ (fun t => x t - IC.trajectory S t) 0)^2 + (S.ω^2) * ((fun t => x t - IC.trajectory S t) 0)^2)
    simp [this, E0]
  -- Since sum of squares is zero, each term is zero
  have pos_zero : ∀ t, (fun t => x t - IC.trajectory S t) t = 0 := by
    intro t
    have h1 : (S.ω^2) * ((fun t => x t - IC.trajectory S t) t)^2 = 0 := by
      nlinarith [energy_conserved t]
    have h2 : S.ω ≠ 0 := S.ω_neq_zero
    have h3 : S.ω^2 > 0 := by positivity
    nlinarith
  funext t
  exact pos_zero t
