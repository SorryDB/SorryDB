            rw [inner_add_left, inner_add_right]
            simp only [inner_self_eq_norm_sq, ← two_mul, ← deriv_smul]
            rw [← h_ode t, ← h_traj_ode t]
            simp [inner_comm, smul_eq_mul, mul_assoc, mul_comm, mul_left_comm]
            nlinarith
          have E0 : ‖∂ₜ y 0‖^2 + S.ω^2 * ‖y 0‖^2 = 0 := by simp [y0, y0']
          have Et : ∀ t, ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2 = 0 := by
            intro t
            have := (const_of_deriv_zero (fun s => ‖∂ₜ y s‖^2 + S.ω^2 * ‖y s‖^2) dE_dt) t 0
            simp_all
          exact Et t
        have y_t : ∀ t, y t = 0 := by
          intro t
          have h1 : ‖y t‖^2 = 0 := by
            nlinarith [energy_const t]
          simpa [norm_eq_zero, h1] using norm_eq_zero.mp h1
        exact fun t => sub_eq_zero.mp (y_t t))
