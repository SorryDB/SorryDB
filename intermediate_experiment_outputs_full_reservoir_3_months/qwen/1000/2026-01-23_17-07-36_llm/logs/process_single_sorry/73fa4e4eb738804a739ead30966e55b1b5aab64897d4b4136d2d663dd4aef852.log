      have : ∀ t, x t = IC.trajectory S t := by
        -- We can use the fact that the difference satisfies a homogeneous ODE
        -- with zero initial conditions, hence is identically zero
        let y := fun t => x t - IC.trajectory S t
        have y_ode : ∀ t, ∂ₜ (∂ₜ y) t = -S.ω^2 • y t := by
          intro t
          simp only [PiLp.sub_apply, PiLp.smul_apply, smul_sub]
          rw [h_ode t, h_traj_ode t]
