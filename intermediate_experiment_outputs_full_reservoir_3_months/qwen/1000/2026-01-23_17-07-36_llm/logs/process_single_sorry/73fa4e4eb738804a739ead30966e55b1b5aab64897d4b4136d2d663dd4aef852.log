lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear, ω_sq] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- Use uniqueness of solutions to linear ODEs with given initial conditions
    -- The trajectory is known to satisfy the same ODE and initial conditions
    have h_traj_ode : ∀ t, ∂ₜ (∂ₜ (IC.trajectory S)) t = -S.ω^2 • (IC.trajectory S) t :=
      by simpa [trajectory_equationOfMotion, EquationOfMotion, gradLagrangian_eq_force,
        force_eq_linear, ω_sq] using (trajectory_equationOfMotion IC)
    have h_traj_x0 : (IC.trajectory S) 0 = IC.x₀ := by simp
    have h_traj_v0 : ∂ₜ (IC.trajectory S) 0 = IC.v₀ := by simp
    -- Since both x and trajectory satisfy the same second-order linear ODE
    -- and have the same initial position and velocity, they must be equal
    -- This follows from standard uniqueness for linear ODEs
    exact (by
      have : ∀ t, x t = IC.trajectory S t := by
        -- We can use the fact that the difference satisfies a homogeneous ODE
        -- with zero initial conditions, hence is identically zero
        let y := fun t => x t - IC.trajectory S t
        have y_ode : ∀ t, ∂ₜ (∂ₜ y) t = -S.ω^2 • y t := by
          intro t
          simp only [Pi.sub_apply, PiLp.sub_apply]
          rw [h_ode t, h_traj_ode t]
          simp [sub_eq_add_neg, add_assoc, add_left_comm, add_comm]
          ring
        have y0 : y 0 = 0 := by simp [h_x0, h_traj_x0]
        have y0' : ∂ₜ y 0 = 0 := by simp [h_v0, h_traj_v0]
        -- Now show y is identically zero
        -- For harmonic oscillator, energy is conserved: E = (1/2)(v^2 + ω^2 x^2)
        -- If E(0) = 0 then E(t) = 0 for all t, so x(t) = 0 and v(t) = 0
        have energy_conserved : ∀ t, (1/2) * (∂ₜ y t).normSq + (1/2) * S.ω^2 * (y t).normSq =
            (1/2) * (∂ₜ y 0).normSq + (1/2) * S.ω^2 * (y 0).normSq := by
          -- Compute derivative of energy
          have dE : ∀ t, deriv (fun t => (1/2) * (∂ₜ y t).normSq + (1/2) * S.ω^2 * (y t).normSq) t = 0 := by
            intro t
            -- Use product rule and ODE
            have : deriv (fun t => (∂ₜ y t).normSq) t = 2 * ⟪∂ₜ y t, ∂ₜ (∂ₜ y) t⟫ := by
              simp [inner_deriv, deriv_inner]
            have : deriv (fun t => (y t).normSq) t = 2 * ⟪y t, ∂ₜ y t⟫ := by
              simp [inner_deriv, deriv_inner]
            simp_all only [mul_assoc, mul_comm, mul_left_comm]
            rw [y_ode t]
            simp [inner_smul_left, inner_smul_right]
            ring
          exact fun t => by
            have := integral_of_deriv_eq_sub (fun t => (1/2) * (∂ₜ y t).normSq + (1/2) * S.ω^2 * (y t).normSq)
            simp_all
        have energy_zero : ∀ t, (1/2) * (∂ₜ y t).normSq + (1/2) * S.ω^2 * (y t).normSq = 0 := by
          intro t
          rw [energy_conserved t, y0', y0]
          simp
        have y_zero : ∀ t, y t = 0 := by
          intro t
          have : (y t).normSq = 0 := by
            have := energy_zero t
            field_simp at this
            nlinarith [S.ω_pos.le]
          exact normSq_eq_zero.mp this
        exact fun t => by simp [y, y_zero t])
      exact this t)
  exact h_sol
