    -- The trajectory is known to satisfy the same ODE and initial conditions
    have h_traj_ode : ∀ t, ∂ₜ (∂ₜ (IC.trajectory S)) t = -S.ω^2 • (IC.trajectory S) t :=
      by simpa [trajectory_equationOfMotion, EquationOfMotion, gradLagrangian_eq_force,
        force_eq_linear, ω_sq] using (trajectory_equationOfMotion IC)
    have h_traj_x0 : (IC.trajectory S) 0 = IC.x₀ := by simp
    have h_traj_v0 : ∂ₜ (IC.trajectory S) 0 = IC.v₀ := by simp
