lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- Use uniqueness of solutions to linear ODEs with given initial conditions
    -- The trajectory we defined is the unique solution to x'' + ω^2 x = 0 with given ICs
    have h1 : (IC.trajectory S) 0 = IC.x₀ := by simp
    have h2 : ∂ₜ (IC.trajectory S) 0 = IC.v₀ := by simp
    have h3 : ∀ t, ∂ₜ (∂ₜ (IC.trajectory S)) t = -S.ω^2 • (IC.trajectory S) t :=
      by simpa using trajectory_equationOfMotion IC
    -- Since both x and trajectory satisfy the same ODE and same initial conditions,
    -- they must be equal. This follows from standard ODE uniqueness.
    -- In Lean, we can use the fact that the difference satisfies a homogeneous ODE
    -- with zero initial conditions, hence is identically zero.
    have h_diff : ∀ t, x t - IC.trajectory S t = 0 := by
      have h_diff_ode : ∀ t, ∂ₜ (∂ₜ (fun t => x t - IC.trajectory S t)) t =
        -S.ω^2 • (x t - IC.trajectory S t) := by
