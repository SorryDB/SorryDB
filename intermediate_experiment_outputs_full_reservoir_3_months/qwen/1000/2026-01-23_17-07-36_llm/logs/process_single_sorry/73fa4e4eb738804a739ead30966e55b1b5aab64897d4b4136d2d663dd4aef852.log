            rw [← PiLp.inner_eq_dotProduct]
            simp only [inner_add_left, inner_sub_left, inner_smul_left, inner_self_eq_norm_sq]
            nlinarith [y_ode t]
          have energy0 : ‖∂ₜ y 0‖^2 + S.ω^2 * ‖y 0‖^2 = 0 := by simp [y0, y0']
          have energy_t : ∀ t, ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2 = 0 := by
            intro t
            exact (eq_of_deriv_eq_zero (fun _ => by continuity) d_energy).trans energy0
          exact energy_t t
