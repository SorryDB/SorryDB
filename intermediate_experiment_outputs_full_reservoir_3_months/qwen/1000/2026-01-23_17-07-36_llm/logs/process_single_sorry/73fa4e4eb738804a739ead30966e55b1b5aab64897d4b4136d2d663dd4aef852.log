lemma trajectories_unique (IC : InitialConditions) (x : Time → Space 1) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  have h_eq : S.EquationOfMotion x := h.1
  have h_x0 : x 0 = IC.x₀ := h.2.1
  have h_v0 : ∂ₜ x 0 = IC.v₀ := h.2.2
  have h_ode : ∀ t, ∂ₜ (∂ₜ x) t = -S.ω^2 • x t := by
    simpa [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear] using h_eq
  have h_sol : x = IC.trajectory S := by
    apply funext
    intro t
    -- The ODE is linear with constant coefficients; uniqueness follows from standard theory
    -- Since both x and trajectory S IC satisfy the same second-order linear ODE
    -- and agree on initial position and velocity, they must be equal.
    have h1 : x = IC.trajectory S := by
      apply Eq.symm
      apply Eq.symm
      -- Use the fact that the solution space is 2-dimensional and determined by initial conditions
      sorry
    exact h1
  exact h_sol
