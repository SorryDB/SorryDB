lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  have h₁ : ContinuousOn f s := by
    apply ContinuousOn.of_locally_continuous_on
    intro x hx
    rcases hf.left_limit x with ⟨l, hl⟩
    have h₂ : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x
    have h₃ : ContinuousWithinAt f (Set.Iic x) x := by
      apply ContinuousWithinAt.mono hl
      exact nhdsWithin_le_nhdsWithin (Set.inter_subset_left _ _)
    have h₄ : ContinuousAt f x := by
      apply ContinuousAt.congr_mono h₂
      apply Filter.EventuallyEq.symm
      apply Filter.EventuallyEq.mono (mem_nhds_iff.mpr ⟨Set.Ioi x ∪ Set.Iic x, by
        simp only [Set.mem_union, Set.mem_Ioi, Set.mem_Iic, or_true]
        tauto⟩)
      intro y hy
      cases' lt_or_le y x with h h <;> simp_all
    exact ⟨s, Set.subset.rfl, h₄.continuousWithinAt⟩
  exact h₁.isBounded_image hs
