def functor (c : ℤ) : FintypeCat ⥤ LightProfinite where
  obj Si := component Si c
  map := fun X Y f => FintypeCat.toLightProfinite.map (Set.imageFactorization (fun a => Finsupp.comp a f) (set X c) (set Y c) (by
    intro a ha
    simp only [set, Finsupp.mem_support_iff, Finsupp.comp_apply, Set.mem_setOf_eq] at *
    calc
      ∑ i ∈ (Finsupp.comp a f).support, |(Finsupp.comp a f) i|
        = ∑ i ∈ (f '' a.support), |a (f i)| := by
          rw [Finsupp.support_comp]
          congr
          ext x
          simp [Finsupp.mem_support_iff]
      _ ≤ ∑ i ∈ a.support, |a i| := by
          apply Finset.sum_le_sum_of_subset_of_nonneg
          · rintro x ⟨hx, rfl⟩
            exact ⟨hx, rfl⟩
          · intro i _ _
            exact abs_nonneg _
      _ ≤ c := ha))
  map_id := fun X => by
    ext1
    simp
```
