lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  rw [trajectory_velocity]
  simp only [Fin.isValue, neg_smul]
  have hω : S.ω ≠ 0 := ω_neq_zero S
  constructor
  · intro h
    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 := by
      simpa [PiLp.ext_iff] using h
    have h2 : sin (S.ω * t.val) * IC.x₀ = (cos (S.ω * t.val) / S.ω) • IC.v₀ := by
      rw [← sub_eq_zero] at h1
      field_simp at h1 ⊢
      linarith
    calc
      ‖IC.trajectory S t‖
        = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ := rfl
      _ = ‖cos (S.ω * t.val) • IC.x₀ + (cos (S.ω * t.val) / S.ω ^ 2) • IC.v₀‖ := by
          rw [← h2]
          congr 1
          field_simp
          ring
      _ = |cos (S.ω * t.val)| * ‖IC.x₀ + (1 / S.ω ^ 2) • IC.v₀‖ := by
          simp [norm_smul, abs_mul]
      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by
          -- Use the fact that when velocity is zero, energy is purely potential
          -- and equals total energy
          have hE : S.energy (IC.trajectory S) t = 1/2 * (S.m * ‖IC.v₀‖^2 + S.k * ‖IC.x₀‖^2) :=
            trajectory_energy IC t
          simp [energy, kineticEnergy, potentialEnergy, h, real_inner_self_eq_norm_sq] at hE
          field_simp [S.k_eq_ω_sq_m] at hE
          nlinarith [Real.sqrt_nonneg (‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2),
            Real.sq_sqrt (show 0 ≤ ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 from by positivity)]
  · intro h
    have hE : S.energy (IC.trajectory S) t = 1/2 * (S.m * ‖IC.v₀‖^2 + S.k * ‖IC.x₀‖^2) :=
      trajectory_energy IC t
    simp [energy, kineticEnergy, potentialEnergy, real_inner_self_eq_norm_sq] at hE
    field_simp [S.k_eq_ω_sq_m] at hE
    have hv : ∂ₜ (IC.trajectory S) t = 0 := by
      -- If norm equals max amplitude, then velocity must be zero
      -- This follows from energy conservation: KE = 0 when PE = total energy
      have hKE : 1/2 * S.m * ‖∂ₜ (IC.trajectory S) t‖^2 = 0 := by
        nlinarith [Real.sqrt_nonneg (‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2),
          Real.sq_sqrt (show 0 ≤ ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 from by positivity)]
      simp [norm_eq_zero, hKE]
    exact hv
