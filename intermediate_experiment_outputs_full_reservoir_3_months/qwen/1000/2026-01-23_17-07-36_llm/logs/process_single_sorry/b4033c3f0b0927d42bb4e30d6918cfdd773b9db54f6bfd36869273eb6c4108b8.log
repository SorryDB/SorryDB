lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  rw [trajectory_velocity]
  simp only [Fin.isValue, neg_smul]
  have hω : S.ω ≠ 0 := ω_neq_zero S
  constructor
  · intro h
    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 := by
      simpa using h
    have h2 : S.ω * sin (S.ω * t.val) * IC.x₀ = cos (S.ω * t.val) • IC.v₀ := by
      rw [← sub_eq_zero] at h1
      simpa using h1
    calc
      ‖IC.trajectory S t‖
        = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ := by
          rw [trajectory_eq]
      _ = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ := rfl
      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by
        rw [← Real.sqrt_sq_eq_abs, ← Real.norm_eq_abs]
        have h3 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖^2 =
            ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 := by
          simp [norm_add_sq_real, h2, mul_comm, mul_left_comm, mul_assoc, hω]
          field_simp
          ring
        rw [Real.sqrt_eq_sqrt (by positivity) h3]
  · intro h
    have h1 : ‖IC.trajectory S t‖^2 = ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 := by
      rw [h, Real.sq_sqrt (by positivity)]
    rw [trajectory_eq] at h1
    simp [norm_add_sq_real] at h1
    have h2 : -S.ω * sin (S.ω * t.val) * IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 := by
      apply eq_of_sub_eq_zero
      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val), h1, hω]
    simpa using h2
