      simpa [trajectory] using h
    have h2 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖^2 =
        ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 := by
