      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      funext i\n      fin_cases i\n      exact congr_fun h i\n    have h2 : Real.cos (S.ω * t.val) * IC.v₀ 0 = S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 := by\n      linarith\n    calc\n      ‖IC.trajectory S t‖\n        = ‖Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0‖ := by\n          simp [trajectory_eq]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| := by\n          simp [norm_eq_abs]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| := by\n          field_simp\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 / (S.ω * Real.cos (S.ω * t.val)))| := by\n          rw [← h2]; field_simp [hω]\n      _ = |IC.x₀ 0| * √(Real.cos (S.ω * t.val) ^ 2 + Real.sin (S.ω * t.val) ^ 2) := by\n          sorry\n      _ = |IC.x₀ 0| := by\n          rw [Real.cos_sq_add_sin_sq]; simp\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          sorry\n  · intro h\n    sorry",
      "\n  rw [trajectory_velocity, trajectory_eq]\n  simp only [Fin.isValue, neg_smul, PiLp.smul_apply, smul_eq_mul, PiLp.add_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa [Fin.isValue] using congr_fun h 0\n    have h2 : (IC.trajectory S t 0) ^ 2 = (IC.x₀ 0 * Real.cos (S.ω * t.val) + IC.v₀ 0 / S.ω * Real.sin (S.ω * t.val)) ^ 2 := by\n      simp [Fin.isValue]\n    rw [← Real.sqrt_sq_eq_abs, ← Real.sqrt_sq_eq_abs]\n    apply Eq.symm\n    field_simp [hω.ne']\n    nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val), h1]\n  · intro h\n    have h1 : (IC.trajectory S t 0) ^ 2 = (IC.x₀ 0 * Real.cos (S.ω * t.val) + IC.v₀ 0 / S.ω * Real.sin (S.ω * t.val)) ^ 2 := by\n      simp [Fin.isValue]\n    rw [← Real.sqrt_sq_eq_abs, ← Real.sqrt_sq_eq_abs] at h\n    field_simp [hω.ne'] at h\n    nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val),\n      mul_self_nonneg (IC.x₀ 0 * Real.sin (S.ω * t.val) - IC.v₀ 0 / S.ω * Real.cos (S.ω * t.val))]",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa [PiLp.ext_iff] using congr_fun h 0\n    have h2 : Real.cos (S.ω * t.val) * IC.v₀ 0 = S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 := by linarith\n    calc\n      ‖IC.trajectory S t‖\n        = ‖Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0‖ := by\n          simp [trajectory, PiLp.ext_iff]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| := by\n          simp [norm_eq_abs]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| := by\n          ring\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          rw [← Real.sqrt_sq_eq_abs]\n          field_simp [h2]\n          ring\n          <;> try norm_num\n  · intro h\n    have h1 : ‖IC.trajectory S t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := h\n    have h2 : (Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0)^2 =\n        ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 := by\n      rw [← Real.sq_sqrt (show 0 ≤ ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 from by positivity)]\n      rw [← h1]\n      simp [trajectory, norm_eq_abs, abs_pow]\n    have h3 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val),\n        mul_self_nonneg (Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0),\n        mul_self_nonneg (Real.sin (S.ω * t.val) * IC.x₀ 0 - Real.cos (S.ω * t.val) / S.ω * IC.v₀ 0)]\n    ext i\n    fin_cases i\n    simp_all",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa using congr_fun h 0\n    have h2 : Real.cos (S.ω * t.val) * IC.v₀ 0 = S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 := by linarith\n    calc\n      ‖IC.trajectory S t‖\n        = ‖Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0‖ := by\n          simp [trajectory_eq, Fin.isValue]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| := by\n          simp [norm_eq_abs]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| := by\n          field_simp\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 / (S.ω * Real.cos (S.ω * t.val)))| := by\n          rw [h2]; by_cases hc : Real.cos (S.ω * t.val) = 0 <;> field_simp [hc] <;> ring\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          simp [norm_eq_abs, abs_of_nonneg, sq_sqrt, add_nonneg, sq_nonneg, div_nonneg,\n            norm_nonneg, hω.ne', hx]\n  · intro h\n    have h1 : ‖IC.trajectory S t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := h\n    have h2 : (Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0)^2 =\n        ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 := by\n      rw [← Real.sqrt_sq_eq_abs, ← h1, norm_eq_abs]\n      exact Real.sqrt_sq (by positivity)\n    have h3 : (-S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0) = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val), h2, sq_nonneg (IC.x₀ 0), sq_nonneg (IC.v₀ 0)]\n    ext i\n    fin_cases i\n    simp_all",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa [PiLp.smul_apply, PiLp.add_apply, PiLp.neg_apply, smul_eq_mul] using congr_fun h 0\n    have h2 : (IC.trajectory S t) 0 = cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω) := by\n      simpa [trajectory, PiLp.smul_apply, PiLp.add_apply, smul_eq_mul] using rfl\n    calc\n      ‖IC.trajectory S t‖\n        = |(IC.trajectory S t) 0| := by simp [norm_eq_abs]\n      _ = |cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| := by rw h2\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n        have h3 : (cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω))^2 =\n          (IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2 := by\n          nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val), h1, mul_self_nonneg (cos (S.ω * t.val)),\n            mul_self_nonneg (sin (S.ω * t.val))]\n        rw [← Real.sqrt_sq_eq_abs, h3]\n        simp [norm_eq_abs, pow_two]\n  · intro h\n    have h1 : (IC.trajectory S t) 0 = cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω) := by\n      simpa [trajectory, PiLp.smul_apply, PiLp.add_apply, smul_eq_mul] using rfl\n    have h2 : |cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| =\n      √((IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2) := by\n      rw [← h, norm_eq_abs]\n      simp [norm_eq_abs]\n    have h3 : (cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω))^2 =\n      (IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2 := by\n      rw [← Real.sqrt_sq_eq_abs] at h2\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]\n    have h4 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val), h3]\n    ext i\n    fin_cases i\n    simp [PiLp.smul_apply, PiLp.add_apply, PiLp.neg_apply, smul_eq_mul, h4]",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * (IC.x₀ 0) + Real.cos (S.ω * t.val) * (IC.v₀ 0) = 0 := by\n      simpa using congr_fun h 0\n    have h2 : Real.cos (S.ω * t.val) * (IC.v₀ 0) = S.ω * Real.sin (S.ω * t.val) * (IC.x₀ 0) := by linarith\n    calc\n      ‖IC.trajectory S t‖\n        = ‖Real.cos (S.ω * t.val) * (IC.x₀ 0) + (Real.sin (S.ω * t.val) / S.ω) * (IC.v₀ 0)‖ := by\n          simp [trajectory_eq, Fin.isValue]\n      _ = |Real.cos (S.ω * t.val) * (IC.x₀ 0) + (Real.sin (S.ω * t.val) / S.ω) * (IC.v₀ 0)| := by\n          simp [norm_eq_abs]\n      _ = |Real.cos (S.ω * t.val) * (IC.x₀ 0) + Real.sin (S.ω * t.val) * (IC.v₀ 0) / S.ω| := by ring\n      _ = |(Real.cos (S.ω * t.val) * (IC.x₀ 0) * S.ω + Real.sin (S.ω * t.val) * (IC.v₀ 0)) / S.ω| := by\n          field_simp\n      _ = |(Real.cos (S.ω * t.val) * (IC.x₀ 0) * S.ω + S.ω * Real.sin (S.ω * t.val) * (IC.x₀ 0)) / S.ω| := by\n          rw [h2]\n      _ = |S.ω * (Real.cos (S.ω * t.val) * (IC.x₀ 0) + Real.sin (S.ω * t.val) * (IC.x₀ 0)) / S.ω| := by\n          ring\n      _ = |Real.cos (S.ω * t.val) * (IC.x₀ 0) + Real.sin (S.ω * t.val) * (IC.x₀ 0)| := by\n          field_simp [hω]\n      _ = |IC.x₀ 0| * |Real.cos (S.ω * t.val) + Real.sin (S.ω * t.val)| := by\n          simp [abs_mul]\n      sorry\n  · intro h\n    sorry",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa [PiLp.smul_apply, PiLp.add_apply, PiLp.neg_apply, smul_eq_mul] using congr_fun h 0\n    have h2 : sin (S.ω * t.val) * IC.x₀ 0 = cos (S.ω * t.val) * (IC.v₀ 0 / S.ω) := by\n      field_simp at h1 ⊢\n      linarith\n    calc\n      ‖IC.trajectory S t‖\n        = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ := rfl\n      _ = √((cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) / S.ω * IC.v₀ 0)^2) := by\n          simp [norm_eq_abs, abs_of_nonneg, sq_sqrt, add_sq, mul_pow, div_pow]\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          rw [← h2]\n          ring_nf\n          <;> simp [norm_eq_abs, abs_mul, abs_div, abs_of_nonneg, sq_sqrt, hω.ne']\n  · intro h\n    have h1 : ‖IC.trajectory S t‖^2 = ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 := by\n      rw [h, Real.sq_sqrt]\n      positivity\n    simp [trajectory, norm_eq_abs, abs_mul, abs_div, sq, ← sub_eq_add_neg] at h1\n    have h2 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]\n    ext i\n    fin_cases i\n    simp [PiLp.smul_apply, PiLp.add_apply, PiLp.neg_apply, smul_eq_mul, h2]",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa [PiLp.smul_apply, PiLp.add_apply, PiLp.neg_apply, smul_eq_mul] using congr_fun h 0\n    have h2 : (IC.trajectory S t) 0 = cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω) := by\n      simpa [trajectory, PiLp.smul_apply, PiLp.add_apply, smul_eq_mul] using rfl\n    calc\n      ‖IC.trajectory S t‖\n        = |(IC.trajectory S t) 0| := by\n          simp [norm_eq_abs, Fin.isValue]\n      _ = |cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| := by rw h2\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          have h3 : (cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω))^2 =\n            (IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2 := by\n            nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val), h1]\n          rw [← Real.sqrt_sq_eq_abs, h3]\n          simp [norm_eq_abs, Fin.isValue]\n  · intro h\n    have h1 : (IC.trajectory S t) 0 = cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω) := by\n      simpa [trajectory, PiLp.smul_apply, PiLp.add_apply, smul_eq_mul] using rfl\n    have h2 : |(IC.trajectory S t) 0| = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n      simpa [norm_eq_abs, Fin.isValue] using h\n    have h3 : (cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) * (IC.v₀ 0 / S.ω))^2 =\n      (IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2 := by\n      rw [← Real.sqrt_sq_eq_abs] at h2\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]\n    have h4 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val), h3]\n    ext i\n    fin_cases i\n    simpa [PiLp.smul_apply, PiLp.add_apply, PiLp.neg_apply, smul_eq_mul] using h4",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * (IC.x₀ 0) + Real.cos (S.ω * t.val) * (IC.v₀ 0) = 0 := by\n      simpa [Fin.isValue] using congr_fun h 0\n    have h2 : Real.cos (S.ω * t.val) * (IC.v₀ 0) = S.ω * Real.sin (S.ω * t.val) * (IC.x₀ 0) := by linarith\n    calc\n      ‖IC.trajectory S t‖\n        = Real.sqrt ((Real.cos (S.ω * t.val) * (IC.x₀ 0) + Real.sin (S.ω * t.val) / S.ω * (IC.v₀ 0)) ^ 2) := by\n          simp [trajectory, Fin.isValue, norm_eq_abs, abs_of_nonneg, sq_sqrt]\n      _ = Real.sqrt ((Real.cos (S.ω * t.val) * (IC.x₀ 0) + Real.sin (S.ω * t.val) / S.ω * (S.ω * Real.sin (S.ω * t.val) * (IC.x₀ 0) / Real.cos (S.ω * t.val))) ^ 2) := by\n          rw [h2]\n      _ = Real.sqrt ((Real.cos (S.ω * t.val) * (IC.x₀ 0) + Real.sin (S.ω * t.val) ^ 2 * (IC.x₀ 0) / Real.cos (S.ω * t.val)) ^ 2) := by\n          field_simp [hω]\n      _ = Real.sqrt (((Real.cos (S.ω * t.val) ^ 2 + Real.sin (S.ω * t.val) ^ 2) * (IC.x₀ 0) / Real.cos (S.ω * t.val)) ^ 2) := by\n          field_simp [Real.cos_sq_add_sin_sq]\n      _ = Real.sqrt ((IC.x₀ 0 / Real.cos (S.ω * t.val)) ^ 2) := by\n          simp [Real.cos_sq_add_sin_sq]\n      _ = |IC.x₀ 0 / Real.cos (S.ω * t.val)| := by\n          rw [Real.sqrt_sq_eq_abs]\n      _ = Real.sqrt ((IC.x₀ 0) ^ 2 + (IC.v₀ 0 / S.ω) ^ 2) := by\n          have h3 : (IC.x₀ 0) ^ 2 + (IC.v₀ 0 / S.ω) ^ 2 = (IC.x₀ 0 / Real.cos (S.ω * t.val)) ^ 2 := by\n            field_simp [h2, Real.cos_sq_add_sin_sq]\n            ring\n          rw [h3, Real.sqrt_sq_eq_abs]\n  · intro h\n    have h1 : ‖IC.trajectory S t‖ ^ 2 = ‖IC.x₀‖ ^ 2 + (‖IC.v₀‖ / S.ω) ^ 2 := by\n      rw [h]\n      exact Real.sq_sqrt (by positivity)\n    simp [trajectory, Fin.isValue, norm_eq_abs, sq, mul_pow] at h1\n    have h2 : (-S.ω * Real.sin (S.ω * t.val) * (IC.x₀ 0) + Real.cos (S.ω * t.val) * (IC.v₀ 0)) ^ 2 = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]\n    have h3 : -S.ω * Real.sin (S.ω * t.val) * (IC.x₀ 0) + Real.cos (S.ω * t.val) * (IC.v₀ 0) = 0 := by\n      nlinarith\n    ext i\n    fin_cases i\n    simp [Fin.isValue]\n    exact h3",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply, smul_eq_mul]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa using congr_fun h 0\n    have h2 : Real.cos (S.ω * t.val) * IC.v₀ 0 = S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 := by linarith\n    calc\n      ‖IC.trajectory S t‖\n        = ‖Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0‖ := by\n          simp [trajectory_eq, Fin.isValue]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| := by\n          simp [norm_eq_abs]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| := by\n          ring\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          rw [← Real.sqrt_sq_eq_abs]\n          field_simp [h2]\n          ring\n          <;> try norm_num\n  · intro h\n    have h1 : ‖IC.trajectory S t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := h\n    have h2 : (Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0)^2 =\n        ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 := by\n      rw [← Real.sq_sqrt (show 0 ≤ ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 from by positivity)]\n      simp [h1, norm_eq_abs]\n      ring\n    have h3 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val),\n        mul_self_nonneg (Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0),\n        mul_self_nonneg (Real.sin (S.ω * t.val) * IC.x₀ 0 - Real.cos (S.ω * t.val) / S.ω * IC.v₀ 0)]\n    ext i\n    fin_cases i\n    simp_all",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 := by\n      simpa using h\n    have h2 : cos (S.ω * t.val) • IC.v₀ = S.ω * sin (S.ω * t.val) • IC.x₀ := by\n      rw [← sub_eq_zero] at h1\n      simpa using h1\n    calc\n      ‖IC.trajectory S t‖\n        = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ := by\n          simp [trajectory]\n      _ = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ := rfl\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by\n        rw [← Real.sqrt_sq_eq_abs, ← Real.norm_eq_abs]\n        field_simp [h2, Real.sin_sq_add_cos_sq]\n        ring\n  · intro h\n    have h1 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ =\n        √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by\n      simpa [trajectory] using h\n    have h2 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖^2 =\n        ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 := by\n      rw [h1, Real.sq_sqrt]\n      positivity\n    simp [Real.norm_eq_abs, Real.sq_abs, Real.sin_sq_add_cos_sq] at h2\n    field_simp [hω.ne'] at h2\n    ring_nf at h2\n    have h3 : -S.ω * sin (S.ω * t.val) * IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 := by\n      apply eq_of_sub_eq_zero\n      nlinarith\n    simpa [h3] using h3",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ + cos (S.ω * t.val) • IC.v₀ = 0 := by\n      simpa [PiLp.ext_iff] using h\n    have h2 : S.ω * sin (S.ω * t.val) * IC.x₀ = cos (S.ω * t.val) • IC.v₀ := by\n      rw [← sub_eq_zero] at h1\n      simpa using h1\n    calc\n      ‖IC.trajectory S t‖\n        = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ := by rw [trajectory]\n      _ = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • (S.ω * sin (S.ω * t.val) / cos (S.ω * t.val)) • IC.x₀‖ := by\n          rw [← h2]; field_simp [hω]\n      _ = ‖(cos (S.ω * t.val) + sin (S.ω * t.val) ^ 2 / cos (S.ω * t.val)) • IC.x₀‖ := by\n          ring\n      _ = ‖(1 / cos (S.ω * t.val)) • IC.x₀‖ := by\n          field_simp [Real.sin_sq_add_cos_sq]\n      _ = |1 / cos (S.ω * t.val)| * ‖IC.x₀‖ := by simp [norm_smul]\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by\n          have h3 : cos (S.ω * t.val) ≠ 0 := by\n            intro hc\n            rw [hc] at h1\n            simp at h1\n            cases' hx with hx hx <;> simp_all\n          field_simp [h3]\n          rw [Real.sqrt_eq_rpow, ← Real.rpow_two]\n          ring_nf\n          nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val)]\n  · intro h\n    have h1 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ =\n        √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by rw [trajectory] at h; exact h\n    have h2 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖^2 =\n        ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 := by\n      rw [h1, Real.sq_sqrt]\n      positivity\n    simp [norm_add_sq_real, norm_smul, Real.sin_sq_add_cos_sq] at h2\n    nlinarith",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      funext i\n      fin_cases i\n      exact congr_fun h i\n    have h2 : S.ω * sin (S.ω * t.val) * IC.x₀ 0 = cos (S.ω * t.val) * IC.v₀ 0 := by\n      linarith\n    calc\n      ‖IC.trajectory S t‖\n        = √((cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) / S.ω * IC.v₀ 0) ^ 2) := by\n          simp [trajectory, norm_eq_abs, abs_of_nonneg, sq_nonneg]\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          field_simp [h2, hω]\n          ring_nf\n          <;> simp_all [norm_eq_abs, sq_abs]\n  · intro h\n    have h1 : (cos (S.ω * t.val) * IC.x₀ 0 + sin (S.ω * t.val) / S.ω * IC.v₀ 0) ^ 2 =\n        ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 := by\n      rw [← Real.sqrt_inj (by positivity) (by positivity)] at h\n      simp_all [norm_eq_abs, sq_abs]\n    have h2 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val), h1]\n    funext i\n    fin_cases i\n    simp_all",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa using congr_fun h 0\n    have h2 : Real.cos (S.ω * t.val) * IC.v₀ 0 = S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 := by\n      linarith\n    calc\n      ‖IC.trajectory S t‖\n        = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| := by\n          simp [trajectory, norm_eq_abs, Fin.isValue]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| := by\n          field_simp\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (Real.cos (S.ω * t.val) * IC.x₀ 0 / Real.sin (S.ω * t.val))| := by\n          rw [← h2]; field_simp [hω]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 * (1 + Real.cos (S.ω * t.val) / Real.cos (S.ω * t.val))| := by\n          sorry\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by sorry\n  · intro h\n    sorry",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa using congr_fun h 0\n    have h2 : Real.cos (S.ω * t.val) * IC.v₀ 0 = S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 := by\n      linarith\n    calc\n      ‖IC.trajectory S t‖\n        = ‖Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0‖ := by\n          simp [trajectory_eq, Fin.isValue]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| := by\n          simp [norm_eq_abs]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) * (IC.v₀ 0 / S.ω)| := by\n          ring\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          rw [← Real.sqrt_sq_eq_abs]\n          field_simp [h2, Real.sin_sq_add_cos_sq]\n          ring\n  · intro h\n    have h1 : |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| =\n        √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n      rw [← h, trajectory_eq, Fin.isValue]\n      simp [norm_eq_abs]\n    have h2 : (Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0)^2 =\n        ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 := by\n      rw [← Real.sq_sqrt (show 0 ≤ ‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2 from by positivity)]\n      nlinarith [Real.abs_mul_abs_self _]\n    have h3 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val),\n        mul_self_nonneg (Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0),\n        mul_self_nonneg (Real.sin (S.ω * t.val) * IC.x₀ 0 - Real.cos (S.ω * t.val) / S.ω * IC.v₀ 0)]\n    ext i\n    fin_cases i\n    simp_all",
      "\n  rw [trajectory_velocity]\n  simp only [Fin.isValue, neg_smul]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa [PiLp.smul_apply, smul_eq_mul, PiLp.add_apply, PiLp.neg_apply] using congr_fun h 0\n    have h2 : S.ω * sin (S.ω * t.val) * IC.x₀ 0 = cos (S.ω * t.val) * IC.v₀ 0 := by linarith\n    calc\n      ‖IC.trajectory S t‖\n        = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ := rfl\n      _ = |cos (S.ω * t.val)| * ‖IC.x₀‖ + |sin (S.ω * t.val) / S.ω| * ‖IC.v₀‖ := by\n          simp [norm_add_le, norm_smul, abs_mul, abs_div, hω.ne']\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by\n          rw [← Real.sqrt_sq_eq_abs]\n          field_simp [h2, Real.sin_sq_add_cos_sq]\n          ring\n  · intro h\n    have h1 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ =\n        √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := h\n    have h2 : (-S.ω * sin (S.ω * t.val) * IC.x₀ 0 + cos (S.ω * t.val) * IC.v₀ 0) = 0 := by\n      nlinarith [Real.sin_sq_add_cos_sq (S.ω * t.val),\n        sq_nonneg (S.ω * sin (S.ω * t.val) * IC.x₀ 0 - cos (S.ω * t.val) * IC.v₀ 0)]\n    ext i\n    fin_cases i\n    simpa [PiLp.smul_apply, smul_eq_mul, PiLp.add_apply, PiLp.neg_apply] using h2",
      "\n  rw [trajectory_velocity, trajectory_eq]\n  simp only [Fin.isValue, neg_smul, PiLp.add_apply, PiLp.neg_apply, PiLp.smul_apply,\n    smul_eq_mul, PiLp.zero_apply]\n  have hω : S.ω ≠ 0 := ω_neq_zero S\n  constructor\n  · intro h\n    have h1 : -S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 + Real.cos (S.ω * t.val) * IC.v₀ 0 = 0 := by\n      simpa using congr_fun h 0\n    have h2 : Real.cos (S.ω * t.val) * IC.v₀ 0 = S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 := by\n      linarith\n    calc\n      ‖IC.trajectory S t‖\n        = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| := by\n          simp [norm_eq_abs, Fin.isValue]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * (S.ω * Real.sin (S.ω * t.val) * IC.x₀ 0 / Real.cos (S.ω * t.val))| := by\n          rw [h2]\n      _ = |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) ^ 2 * IC.x₀ 0 / Real.cos (S.ω * t.val)| := by\n          field_simp [hω]\n      _ = |(Real.cos (S.ω * t.val) ^ 2 + Real.sin (S.ω * t.val) ^ 2) * IC.x₀ 0 / Real.cos (S.ω * t.val)| := by\n          field_simp [Real.cos_sq_add_sin_sq]\n      _ = |IC.x₀ 0 / Real.cos (S.ω * t.val)| := by\n          simp [Real.cos_sq_add_sin_sq]\n      _ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by\n          have h3 : (IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2 = (IC.x₀ 0 / Real.cos (S.ω * t.val))^2 := by\n            field_simp [h2, Real.cos_sq_add_sin_sq]\n            ring\n          rw [← Real.sqrt_sq_eq_abs, ← h3, norm_eq_abs, norm_eq_abs]\n          positivity\n  · intro h\n    have h1 : |Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0| =\n      √((IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2) := by\n      rw [← h, norm_eq_abs, norm_eq_abs]\n    have h2 : (Real.cos (S.ω * t.val) * IC.x₀ 0 + Real.sin (S.ω * t.val) / S.ω * IC.v₀ 0)^2 =\n      (IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2 := by\n      rw [← Real.sq_sqrt (show 0 ≤ (IC.x₀ 0)^2 + (IC.v₀ 0 / S.ω)^2 from by positivity),\n        ← h1, abs_pow_two]\n    have h3 : -S.ω