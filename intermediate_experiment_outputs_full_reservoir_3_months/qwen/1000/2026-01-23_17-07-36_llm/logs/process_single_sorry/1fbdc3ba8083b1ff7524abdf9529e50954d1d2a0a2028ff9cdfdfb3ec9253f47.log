lemma Locally.rightContinuous
    (hX : Locally (fun X ↦ ∀ ω, Function.RightContinuous (X · ω)) 𝓕 X P) :
    ∀ᵐ ω ∂P, Function.RightContinuous (X · ω) := by
  have h := hX.IsLocalizingSequence.tendsto_top
  filter_upwards [h] with ω hω
  have h' := hX.stoppedProcess
  specialize h' 0
  simp only [stoppedProcess, Set.indicator_apply] at h'
  have h'' := hω 0
  simp only [WithTop.tendsto_atTop_nhds_top_iff] at h''
  obtain ⟨N, hN⟩ := h'' 0
  specialize hN N le_rfl
  simp at hN
  exact h' ω
