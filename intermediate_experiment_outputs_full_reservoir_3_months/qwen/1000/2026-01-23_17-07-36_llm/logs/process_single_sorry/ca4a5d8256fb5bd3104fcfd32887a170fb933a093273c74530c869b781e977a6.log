theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  have h1 : 0 < e := by
    rw [e]
    exact Real.exp_pos 1
  have h2 : 0 < n := Nat.zero_lt_of_lt hn
  have h3 : 0 < (n : ℝ) := by positivity
  have h4 : 0 < (n : ℝ) / e := div_pos h3 h1
  have h5 : Real.log (n.factorial : ℝ) > Real.log (e * (n / e) ^ n) := by
    calc
      Real.log (n.factorial : ℝ)
        = ∑ k in Finset.Icc 1 n, Real.log k := by
          simp [Real.log_natFactorial]
      _ > ∫ x in (1:ℝ)..n, Real.log x := by
          apply Real.sum_log_Icc_gt_integral_log
          exact_mod_cast hn
      _ = n * Real.log n - n + 1 := by
          rw [integral_log]
      _ = Real.log (e * (n / e) ^ n) := by
          field_simp [Real.log_mul, Real.log_rpow, Real.log_exp, h1.ne']
          ring
  exact Real.log_lt_log_iff (by positivity) (by positivity) |>.mpr h5
