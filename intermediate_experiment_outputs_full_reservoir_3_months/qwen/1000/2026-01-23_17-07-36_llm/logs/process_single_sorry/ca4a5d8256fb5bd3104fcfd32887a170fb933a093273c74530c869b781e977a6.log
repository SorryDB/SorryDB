  n.factorial > e * (n / e) ^ n := by
  have h1 : 0 < e := by
    rw [e]
    exact Real.exp_pos 1
  have h2 : 0 < n := Nat.zero_lt_of_lt hn
  have h3 : 0 < (n : ℝ) := by positivity
  have h4 : 0 < (n : ℝ) / e := div_pos h3 h1
  have h5 : Real.log (n.factorial : ℝ) > Real.log (e * (n / e) ^ n) := by
    calc
      Real.log (n.factorial : ℝ)
        = ∑ k in Finset.Icc 1 n, Real.log k := by
          simp [Real.log_natCast, Finset.sum_Icc_succ_top, Nat.cast_one, Nat.cast_zero,
            Real.log_one, add_zero, Nat.succ_le_iff.mpr hn]
      _ ≥ ∫ x in (1:ℝ)..n, Real.log x := by
          apply Finset.le_sum_integral_of_monotone
          · exact fun x hx => Real.log_le_log (by linarith) (by linarith)
          · exact fun x hx => Real.log_le_log (by linarith) (by linarith)
      _ = n * Real.log n - n + 1 := by
          field_simp [Real.integral_log]
      _ > Real.log e + n * Real.log (n / e) := by
          rw [e, Real.log_exp]
          field_simp [Real.log_div h3.ne' h1.ne']
          nlinarith [Real.log_le_sub_one_of_pos h3]
      _ = Real.log (e * (n / e) ^ n) := by
          rw [Real.log_mul (by positivity) (by positivity), Real.log_rpow h4]
  exact Real.log_lt_log_iff (by positivity) (by positivity) |>.mpr h5
