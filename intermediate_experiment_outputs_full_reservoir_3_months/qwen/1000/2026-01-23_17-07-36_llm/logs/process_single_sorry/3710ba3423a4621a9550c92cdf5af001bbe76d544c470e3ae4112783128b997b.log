`I ⊆ X` is finite and `x ∈ I`, then `x ∈ A`has small conditional variance conditioned on `y ∈ A`
for each `y ∈ I \ {x}`. -/
theorem small_condVar_of_isNIPWith (isNIPWith_𝓕 : IsNIPWith d (𝓕 : Set (Set X)))
    (hA : ∀ᵐ ω ∂μ, A ω ∈ 𝓕) : Var[fun ω ↦ (A ω).indicator 1 x ; μ | .generateFrom sorry] ≤ 1 / 4 :=
  by
  have h₁ : ∀ᵐ ω ∂μ, (A ω).indicator 1 x = Set.indicator (A ω) (fun _ => 1) x := by
    filter_upwards [hA] with ω hω
    simp [Set.indicator]
  rw [condVar_eq_integral_norm_sub_condexp_sq]
  apply le_of_sub_nonneg
  have h₂ : ∀ᵐ ω ∂μ, (A ω).indicator 1 x ∈ Set.Icc (0 : ℝ) 1 := by
    filter_upwards [hA] with ω hω
    simp [Set.indicator, Set.mem_Icc]
  have h₃ : ∀ᵐ ω ∂μ, ((A ω).indicator 1 x - condexp (MeasurableSpace.generateFrom sorry) μ (fun ω => (A ω).indicator 1 x) ω) ^ 2 ≤ 1 / 4 := by
    filter_upwards [hA, h₂, ae_condexp_mem_Icc h₂] with ω hω h₂ω h₃ω
    nlinarith [sq_nonneg (Set.indicator (A ω) (fun _ => 1) x - condexp (MeasurableSpace.generateFrom sorry) μ (fun ω => (A ω).indicator 1 x) ω)]
  exact integral_nonneg_of_ae_nonneg fun ω => by
    filter_upwards [h₃] with ω hω
    linarith
