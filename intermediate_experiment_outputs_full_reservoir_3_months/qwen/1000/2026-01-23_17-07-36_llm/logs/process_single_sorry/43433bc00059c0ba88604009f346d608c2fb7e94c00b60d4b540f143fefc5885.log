    obtain ⟨hn, hk, hkn⟩ := h
    have : SM.Nonempty := by
      let s : Fin (k + 1) → Fin (2 * n) → Bool :=
        fun t i =>
          if i.val < n then
            if t.val % 2 = 0 then false else true
          else false
      -- This construction is not precise, but we only need non-emptiness.
      -- Since k ≥ n and k - n is even, we can construct a valid sequence in SM.
      -- For example, toggle each of the first n lamps once, then toggle any of them
      -- (k - n) times in pairs to keep them on. This yields a valid sequence.
      apply Finset.nonempty_of_ne_empty
      intro hSM_empty
      have hM_zero : M = 0 := by simp [h₃.2, hSM_empty]
      have hN_zero : N = 0 := by
        -- If M = 0, then there are no sequences that never touch the last n lamps.
        -- But since k - n is even and ≥ 0, we can always construct such a sequence,
        -- contradiction. So M ≠ 0.
        sorry
      sorry
    sorry
