private lemma _root_.IsNIPWith.card_hypercubeEdgeFinset_le_of_finite [Finite α]
    (h𝓕 : IsNIPWith d (𝓕 : Set (Set α))) : #(hypercubeEdgeFinset 𝓕) ≤ d * #𝓕 := by
  have h1 : (finiteSymmDiffFinpartition 𝓕).parts.sup hypercubeEdgeFinset = hypercubeEdgeFinset 𝓕 :=
    sup_finiteSymmDiffFinpartition_hypercubeEdgeFinset 𝓕
  rw [h1]
  refine Finset.sum_le_card_nsmul _ _
  intro 𝓒 h𝓒
  have h2 : IsNIPWith d (restrictFiniteSymmDiffComponent 𝓒 : Set (Set ↑((⋃ A ∈ 𝓒, A) \ ⋂ A ∈ 𝓒, A))) :=
    h𝓕.restrictFiniteSymmDiffComponent
  have h3 : Finite ((⋃ A ∈ 𝓒, A) \ ⋂ A ∈ 𝓒, A) :=
    finite_iUnion_sdiff_iInter_of_mem_finiteSymmDiffFinpartition h𝓒
  have h4 : #(hypercubeEdgeFinset 𝓒) ≤ d * #𝓒 := by
    calc
      #(hypercubeEdgeFinset 𝓒) = #(hypercubeEdgeFinset (restrictFiniteSymmDiffComponent 𝓒)) := by
        simp [hypercubeEdgeFinset, restrictFiniteSymmDiffComponent, symmDiff_def, Set.ncard_eq_one]
      _ ≤ d * #(restrictFiniteSymmDiffComponent 𝓒) := by
        exact h2.card_hypercubeEdgeFinset_le_of_finite
      _ = d * #𝓒 := by simp
  exact h4
