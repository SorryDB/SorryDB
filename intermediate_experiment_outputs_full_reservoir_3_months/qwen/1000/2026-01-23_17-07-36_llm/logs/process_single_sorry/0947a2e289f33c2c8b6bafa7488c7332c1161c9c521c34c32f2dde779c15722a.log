lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₁ : ∀ x ∈ Set.Icc 0 π, DifferentiableAt ℝ cos x := by
    intro x hx
    exact differentiable_cos x
  have h₂ : ∀ x ∈ Set.Icc 0 π, deriv cos x = -sin x := by
    intro x hx
    simp [deriv_cos]
  have h₃ : ContinuousOn cos (Set.Icc 0 π) := continuous_cos.continuousOn
  have h₄ : MonotoneOn cos (Set.Icc 0 π) := by
    intro x hx y hy hxy
    exact neg_le_neg (sin_nonneg_of_mem_Icc ⟨by linarith [hx.1, hx.2], by linarith [hy.1, hy.2]⟩)
      |>.mpr (sin_le_sin_of_le_of_le_pi_div_two (by linarith [hx.1, hx.2]) (by linarith [hy.1, hy.2]) hxy)
  have h₅ : cos '' Set.Icc 0 π = Set.Icc (-1) 1 := by
    ext y
    constructor
    · rintro ⟨x, ⟨hx₁, hx₂⟩, rfl⟩
      exact ⟨neg_one_le_cos x, cos_le_one x⟩
    · intro hy
      obtain ⟨hy₁, hy₂⟩ := hy
      use arccos y
      constructor
      · exact arccos_mem_Icc y
      · rw [cos_arccos hy₁ hy₂]
  rw [← integral_comp_smul_deriv' (f := f) (g := cos) (a := 0) (b := π)]
  · simp_all
  all_goals
    aesop
