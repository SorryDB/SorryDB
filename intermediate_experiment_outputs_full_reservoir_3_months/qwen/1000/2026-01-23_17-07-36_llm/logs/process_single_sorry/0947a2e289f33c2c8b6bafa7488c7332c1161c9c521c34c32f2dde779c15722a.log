lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h₁ : ∀ x ∈ Set.Icc 0 π, DifferentiableAt ℝ cos x := by
    intro x hx
    exact differentiableAt_cos
  have h₂ : ∀ x ∈ Set.Icc 0 π, deriv cos x = -sin x := by
    intro x hx
    exact deriv_cos x
  have h₃ : ContinuousOn sin (Set.Icc 0 π) := continuous_sin.continuousOn
  have h₄ : ContinuousOn cos (Set.Icc 0 π) := continuous_cos.continuousOn
  have h₅ : Set.range (fun x : Set.Icc 0 π => cos x) = Set.Icc (-1) 1 := by
    ext y
    simp [Set.mem_Icc, cos_le_one, neg_one_le_cos]
    constructor
    · intro ⟨x, hx, rfl⟩
      exact ⟨neg_one_le_cos _, cos_le_one _⟩
    · intro hy
      obtain ⟨hy₁, hy₂⟩ := hy
      use ⟨Real.arccos y, by simp [Real.arccos_mem_Icc, hy₁, hy₂]⟩
      simp [Real.cos_arccos hy₁ hy₂]
  rw [← integral_comp_smul_deriv _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _]
  · simp_all
  all_goals
    try
      simp_all [Set.Icc, Set.mem_Icc, Real.pi_pos.le]
