lemma variance_dual_stdGaussianMulti (L : StrongDual ℝ E) :
    Var[L; stdGaussianMulti E] = ∑ i, L (stdOrthonormalBasis ℝ E i) ^ 2 := by
  rw [variance_eq_integral_sq_sub_sq_integral]
  simp [isCentered_stdGaussianMulti]
  rw [stdGaussianMulti, integral_map _ (by fun_prop)]
  swap; · exact (Finset.measurable_sum _ (by fun_prop)).aemeasurable
  simp only [map_sum, map_smul, smul_eq_mul]
  rw [integral_finset_sum]
  swap
  · intro i _
    refine Integrable.mul_const ?_ _
    convert integrable_eval_pi (i := i) (f := id) ?_
    · infer_instance
    · rw [← memLp_one_iff_integrable]
      exact memLp_id_gaussianReal 1
  rw [Finset.sum_sq]
  apply Finset.sum_congr rfl
  intro i _
  rw [integral_mul_const]
  have : (∫ (a : Fin (Module.finrank ℝ E) → ℝ), a i ^ 2 ∂Measure.pi fun x ↦ gaussianReal 0 1)
      = ∫ x, x ^ 2 ∂gaussianReal 0 1 := by
    convert integral_eval_pi (i := i) ?_
    · rfl
    · infer_instance
    · rw [← memLp_one_iff_integrable]
      exact memLp_pow_gaussianReal 2 1
  simp [this]
  rw [integral_gaussianReal_sq]
  norm_num
