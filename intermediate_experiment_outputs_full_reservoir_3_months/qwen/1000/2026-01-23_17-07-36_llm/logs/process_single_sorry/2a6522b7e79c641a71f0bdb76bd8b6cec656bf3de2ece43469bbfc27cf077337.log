      "\n  have h₁ : (after S) k = Finset.univ := h\n  have h₂ : (initialState n) k = {k} := rfl\n  have h₃ : ∀ (σ : List (Call n)), (after σ) k ⊆ Finset.univ := by\n    intro σ; exact Finset.subset_univ _\n  have h₄ : ∀ (σ : List (Call n)), (after σ).length ≤ σ.length + n := by\n    intro σ\n    induction σ with\n    | nil => simp [after, initialState]\n    | cons c σ ih =>\n      simp_all [after, makeCalls, updateCall]\n      apply Nat.le_of_add_le_add_left\n      omega\n  have h₅ : Finset.card ((after S) k) = n := by\n    rw [h₁]; exact Finset.card_univ\n  have h₆ : Finset.card ((initialState n) k) = 1 := by\n    simp [initialState]\n  have h₇ : ∀ (σ : List (Call n)), Finset.card ((after σ) k) ≤ 1 + σ.length := by\n    intro σ\n    induction σ with\n    | nil => simp [after, initialState]\n    | cons c σ ih =>\n      simp_all [after, makeCalls, updateCall]\n      cases' c with a b\n      cases' decEq a k with ha ha <;> cases' decEq b k with hb hb <;>\n        simp_all [Finset.card_insert_of_not_mem]\n      all_goals omega\n  linarith [h₅, h₆, h₇ S]",
