      "\n  have h₁ : (after S) k = Set.univ := h\n  have h₂ : (initialState n) k = {k.val} := rfl\n  have h₃ : ∀ s ∈ S, ∃ a b, s = (a, b) := by\n    intro s hs\n    cases s\n    exact ⟨_, _, rfl⟩\n  have h₄ : ∀ t : List (Call n), (after t) k ⊆ Set.univ := by\n    intro t\n    apply Set.Subset.univ\n  have h₅ : (after S) k = (initialState n) k ∪ (⋃ i ∈ S.toFinset, \n    match i with\n    | (a, b) => if k = a then (after (S.take (S.indexOf i))) b else \n                if k = b then (after (S.take (S.indexOf i))) a else ∅) := by\n    sorry\n  have h₆ : (after S) k ⊇ {i | i < n} := by\n    rw [h₁]\n    simp\n  have h₇ : (after S) k = {i | i < n} := by\n    ext i\n    constructor <;> intro hi <;> simp_all [Fin.val_mk]\n  have h₈ : (initialState n) k = {k.val} := rfl\n  have h₉ : ∀ i ∈ S, (after (S.take (S.indexOf i + 1))) k ⊇ (after (S.take (S.indexOf i))) k := by\n    intro i hi\n    cases i\n    simp [after, makeCalls, initialState]\n    apply Set.Subset.trans\n    · apply Set.Subset.refl\n    · apply Set.Subset.trans\n      · apply Set.Subset.refl\n      · apply Set.Subset.refl\n  have h₁₀ : (after S) k ⊇ {k.val} := by\n    apply Set.Subset.trans\n    · apply Set.Subset.refl\n    · apply Set.Subset.trans\n      · apply Set.Subset.refl\n      · apply Set.Subset.refl\n  have h₁₁ : (after S) k = {i | i < n} := h₇\n  have h₁₂ : Finset.card (Finset.univ : Finset (Fin n)) = n := by\n    simp\n  have h₁₃ : Set.ncard (after S) k = n := by\n    rw [h₁₁]\n    simp [Set.ncard_Iio]\n  have h₁₄ : Set.ncard (initialState n) k = 1 := by\n    simp [initialState]\n  have h₁₅ : ∀ i ∈ S, Set.ncard (after (S.take (S.indexOf i + 1))) k ≤ \n    Set.ncard (after (S.take (S.indexOf i))) k + 1 := by\n    intro i hi\n    cases i\n    simp [after, makeCalls, initialState]\n    apply Nat.le_succ_of_le\n    apply Set.ncard_mono\n    apply Set.Subset.trans\n    · apply Set.Subset.refl\n    · apply Set.Subset.trans\n      · apply Set.Subset.refl\n      · apply Set.Subset.refl\n  have h₁₆ : Set.nca