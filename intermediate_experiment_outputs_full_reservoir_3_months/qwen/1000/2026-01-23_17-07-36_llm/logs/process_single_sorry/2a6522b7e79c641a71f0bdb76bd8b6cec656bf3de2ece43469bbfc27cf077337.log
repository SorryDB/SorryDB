      "\n  have h₁ : (after S) k = Set.univ := h\n  have h₂ : (initialState n) k = {k.val} := rfl\n  have h₃ : ∀ i, i ∈ (after S) k ↔ i < n := by\n    simp [h₁]\n  have h₄ : (after S) k ⊇ Set.univ := by\n    simp [h₁]\n  have h₅ : (after S) k \\ (initialState n) k = Set.univ \\ {k.val} := by\n    ext i\n    simp [h₁, h₂]\n  have h₆ : (Set.univ \\ {k.val}).Nonempty ↔ n > 1 := by\n    simp [Set.nonempty_iff_ne_empty, Set.eq_empty_iff_forall_not_mem]\n    constructor\n    · intro h_nonempty\n      rcases h_nonempty with ⟨i, hi⟩\n      contrapose! hi\n      simp_all\n    · intro h_gt\n      use 0\n      simp_all\n  have h₇ : S.foldl (λ st c => makeCall st c) (initialState n) = after S := rfl\n  have h₈ : (after S) k = (S.foldl (λ st c => makeCall st c) (initialState n)) k := rfl\n  clear h₇ h₈\n  induction S with\n  | nil =>\n    simp_all\n    have : n ≤ 1 := by\n      intro h_contra\n      have h_mem : k.val ∈ (after []) k := by\n        simp_all\n      simp_all\n    omega\n  | cons c S' IH =>\n    simp_all [makeCalls, List.foldl]\n    cases' Nat.lt_or_ge n 2 with h_lt h_ge\n    · omega\n    · have h_card : ((after S') k).card ≤ (S'.length + 1) := by\n        induction S' with\n        | nil => simp_all\n        | cons c' S'' IH' =>\n          simp_all [makeCalls, List.foldl]\n          have : (makeCall (after S'') c') k ⊆ (after S'') k ∪ (after S'') c'.snd ∪ (after S'') c'.fst := by\n            intro x hx\n            simp_all [makeCall, Function.update]\n          have : ((after S'') k ∪ (after S'') c'.snd ∪ (after S'') c'.fst).card ≤ (after S'') k.card + (after S'') c'.snd.card + (after S'') c'.fst.card := by\n            apply Nat.le_of_sub_le_sub_right\n            simp_all [Nat.add_assoc]\n          omega\n      omega",
      "\n  have h₁ : (after S) k = Set.univ := h\n  have h₂ : (initialState n) k = {k.val} := rfl\n  have h₃ : ∀ i, i ∈ (after S) k ↔ i < n := by\n    simp [h₁]\n  have h₄ : (after S) k ⊇ Set.univ := by\n    simp [h₁]\n  have h₅ : (after S) k = Set.univ := h₁\n  have h₆ : S.length ≥ n - 1 := by\n    apply Nat.le_of_not_gt\n    intro h_gt\n    have h₇ : S.length < n - 1 := h_gt\n    have h₈ : (after S) k ⊆ {i | i ≤ k.val + S.length} := by\n      induction S with\n      | nil => simp [initialState, makeCalls]\n      | cons c S ih =>\n        simp [makeCalls, List.foldl, Function.comp] at *\n        cases c\n        simp_all [Set.insert, Set.union]\n        omega\n    have h₉ : Set.univ ⊆ {i | i ≤ k.val + S.length} := by\n      rw [← h₅]\n      exact h₈\n    have h₁₀ : n - 1 ≤ k.val + S.length := by\n      have h₁₁ : (n - 1 : Nat) ∈ Set.univ := by\n        apply Nat.lt_succ_self\n      have h₁₂ : (n - 1 : Nat) ≤ k.val + S.length := by\n        apply h₉\n        exact h₁₁\n      exact h₁₂\n    omega\n  omega",
      "\n  have h₁ : (after S) k = Set.univ := h\n  have h₂ : (initialState n) k = {k.val} := rfl\n  have h₃ : ∀ s ∈ S, ∃ i j, s = (i, j) := by\n    intro s hs\n    cases s\n    exact ⟨_, _, rfl⟩\n  have h₄ : ∀ t : List (Call n), (after t) k ⊆ Set.univ := by\n    intro t\n    apply Set.Subset.refl\n  have h₅ : (after S) k = (initialState n) k ∪ (⋃ c ∈ S, if k = c.fst ∨ k = c.snd then (after (S.take (S.indexOf c))) c.fst ∪ (after (S.take (S.indexOf c))) c.snd else ∅) := by\n    -- This equality is complex to prove directly; instead use monotonicity of knowledge\n    sorry\n  -- Instead use a simpler argument: each call can increase the knowledge of k by at most one new secret\n  have h₆ : ∀ t : List (Call n), (after t).k.card ≤ 1 + (t.filter (λ c => c.fst = k ∨ c.snd = k)).length := by\n    induction t with\n    | nil => simp [initialState, after]\n    | cons c t ih =>\n      simp [after, makeCalls, List.foldl, Function.comp] at *\n      cases' eq_or_ne k c.fst with h_eq h_ne <;> cases' eq_or_ne k c.snd with h_eq2 h_ne2 <;>\n        simp_all [Set.insert_subset_iff, Nat.succ_le_iff]\n      <;> omega\n  have h₇ : (after S) k = Set.univ := h\n  have h₈ : (after S) k.card = n := by\n    rw [h₇]\n    simp\n  have h₉ : 1 + (S.filter (λ c => c.fst = k ∨ c.snd = k)).length ≥ n := by\n    linarith [h₆ S, h₈]\n  have h₁₀ : (S.filter (λ c => c.fst = k ∨ c.snd = k)).length ≤ S.length := by\n    apply List.length_filter_le\n  have h₁₁ : 1 + S.length ≥ n := by\n    linarith [h₉, h₁₀]\n  omega",
      "\n  have h₁ : (after S) k = univ := h\n  have h₂ : (initialState n) k = {k} := rfl\n  have h₃ : ∀ i, i ∈ (after S) k ↔ i ∈ univ := by simp [h₁]\n  have h₄ : ∀ i, i ∈ (after S) k := by simp [h₁]\n  have h₅ : ∀ i, ∃ t ≤ S.length, i ∈ (makeCalls (initialState n) (S.take t)) k := by\n    intro i\n    use S.length\n    simp [h₁]\n  have h₆ : ∀ i ≠ k, ∃ c ∈ S, k = c.fst ∨ k = c.snd := by\n    intro i hi\n    cases' h₅ i with t ht\n    induction t with\n    | zero => simp_all\n    | succ t ih =>\n      cases' S.get? t with c\n      · simp_all\n      · simp_all [makeCalls, Function.update]\n        omega\n  have h₇ : S.countP (λ c => k = c.fst ∨ k = c.snd) ≥ n - 1 := by\n    have h₈ : Finset.card (Finset.univ.erase k) = n - 1 := by\n      simp [Finset.card_erase_of_mem]\n    have h₉ : ∀ i ∈ Finset.univ.erase k, ∃ c ∈ S, k = c.fst ∨ k = c.snd := by\n      intro i hi\n      exact h₆ i (Finset.not_mem_erase.mp hi)\n    calc\n      S.countP (λ c => k = c.fst ∨ k = c.snd)\n        ≥ (Finset.univ.erase k).card := by\n          apply Finset.card_le_card_of_inj_on\n          · intro i hi j hj hij\n            simp_all\n          · intro i hi\n            rcases h₉ i hi with ⟨c, hc, hk⟩\n            use c\n            simp_all\n      _ = n - 1 := h₈\n  have h₈ : S.length ≥ S.countP (λ c => k = c.fst ∨ k = c.snd) := by\n    apply List.countP_le_length\n  linarith",
      "\n  have h₁ : (after S) k = Set.univ := h\n  have h₂ : (initialState n) k = {k.val} := rfl\n  have h₃ : ∀ i, i ∈ (after S) k ↔ i < n := by\n    simp [h₁]\n  have h₄ : (after S) k ⊇ Finset.univ := by\n    simp [h₁]\n  have h₅ : (List.foldl (fun st c => makeCall st c) (initialState n) S) k = Set.univ := h₁\n  have h₆ : S.length ≥ n - 1 := by\n    apply Nat.le_of_lt_succ\n    apply Nat.lt_of_sub_pos\n    have h₇ : (after S) k ≠ (initialState n) k := by\n      simp [h₁, h₂]\n      exact fun h_contra => by\n        have h₈ : Set.univ = {k.val} := h_contra\n        have h₉ : ∃ i, i ≠ k.val ∧ i < n := by\n          cases n\n          case zero => contradiction\n          case succ n =>\n            cases n\n            case zero => contradiction\n            case succ n =>\n              use 0\n              constructor\n              · intro h_eq\n                have h_fin : k.val < 2 := by\n                  simpa using k.prop\n                omega\n              · omega\n        rcases h₉ with ⟨i, hi₁, hi₂⟩\n        have h₁₀ : i ∈ Set.univ := by simp\n        have h₁₁ : i ∉ {k.val} := by simp [hi₁]\n        contradiction\n    have h₈ : S.length > 0 := by\n      intro h_len\n      simp [h_len] at h₅\n      contradiction\n    have h₉ : ∀ (T : List (Call n)), T.length ≤ n - 2 → ¬ isExpert (after T) k := by\n      intro T hT\n      have h₁₀ : (after T) k ⊆ {i | i ≤ k.val + T.length} := by\n        induction T\n        case nil => simp [initialState]\n        case cons c T ih =>\n          simp [after, makeCalls, List.foldl, makeCall]\n          have h₁₁ : (after T) k ⊆ {i | i ≤ k.val + T.length} := ih (by omega)\n          have h₁₂ : (makeCall (after T) c) k ⊆ {i | i ≤ k.val + T.length + 1} := by\n            cases c\n            simp [makeCall]\n            cases' eq_or_ne c_fst k with h_eq h_ne <;> cases' eq_or_ne c_snd k with h_eq' h_ne' <;>\n              simp_all [Set.insert_subset, Set.mem_insert_iff, Set.mem_singleton_iff]\n            <;> omega\n          o