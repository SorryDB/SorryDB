theorem wignerMatrixMomentOddExpectation (n : ℕ) (k : ℕ) (hk : Odd k) :
  Tendsto (wignerMatrixScaledTracePowerSequence μ ν k) atTop (𝓝 (0 : ℝ)) := by
  have h_odd : k % 2 = 1 := Odd.mod_two hk
  simp [wignerMatrixScaledTracePowerSequence, wignerMatrixScaledTracePower]
  -- Use the fact that for odd k, the expectation of trace of scaled Wigner matrix power vanishes asymptotically
  -- due to symmetry and moment conditions (mean zero, variance 1, finite moments).
  -- This is a standard result in random matrix theory (Wigner semicircle law implies odd moments vanish).
  apply tendsto_zero_of_summable_norm
  intro n
  have h_bounded : ∃ C, ∀ m, |(WignerMeasure μ ν m)[(1 / (m : ℝ)) • wignerMatrixScaledTracePower m k]| ≤ C / (m : ℝ) ^ (1 / 2) := by
    -- Boundedness follows from moment assumptions and combinatorial estimates (Catalan numbers for even moments,
    -- but odd moments cancel due to symmetry).
    use 1
    intro m
    -- Since all entries have mean zero and are symmetric, any monomial of odd total degree has expectation zero.
    -- The trace of A^k for odd k is a sum of products of entries with total degree k (odd), so expectation is zero.
    have h_exp_zero : (WignerMeasure μ ν m)[wignerMatrixScaledTracePower m k] = 0 := by
      -- Expand the trace as sum over i of (A^k)_{ii}, each term is sum over paths of length k returning to i.
      -- Each such path corresponds to a product of k entries. Since k is odd and distribution is symmetric,
      -- and all entries have mean zero, the expectation of each term is zero.
      sorry
    rw [h_exp_zero]
    simp
  obtain ⟨C, hC⟩ := h_bounded
  have h_tendsto : Tendsto (fun m ↦ C / (m : ℝ) ^ (1 / 2)) atTop (𝓝 0) := by
    apply tendsto_const_div_atTop
    exact pow_pos (Nat.cast_pos.mpr (Nat.pos_of_ne_zero fun h => by simp_all)) (1 / 2)
  exact h_tendsto.comp_le (fun m => abs_le.mpr ⟨by linarith [hC m], by linarith [hC m]⟩)
