theorem wignerMatrixMomentOddExpectation (n : ℕ) (k : ℕ) (hk : Odd k) :
  Tendsto (wignerMatrixScaledTracePowerSequence μ ν k) atTop (𝓝 (0 : ℝ)) := by
  have h_odd : k % 2 = 1 := Odd.mod_two hk
  simp [wignerMatrixScaledTracePowerSequence, wignerMatrixScaledTracePower]
  -- The expectation of the trace of an odd power of a Wigner matrix is zero due to symmetry
  -- and the fact that all entries have mean zero. After scaling by 1/n, it still tends to 0.
  apply tendsto_const_nhds
