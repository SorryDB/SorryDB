/--
Let $A$ and $E$ be opposite vertices of an octagon. A frog starts at vertex $A$. From any vertex except $E$ it jumps to one of the two adjacent vertices. When it reaches $E$ it stops. Let $a_n$ be the number of distinct paths of exactly $n$ jumps ending at $E$. Prove that: $a_{2n-1}=0,a_{2n}={(2+\sqrt2)^{n-1}\over\sqrt2}-{(2-\sqrt2)^{n-1}\over\sqrt2}$. -/
theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def]
  suffices : (∑ i : Fin (2 * n - 1), (p i : Fin 8)) ≠ 4 for all p : Fin (2 * n - 1) → ℤˣ by
    simp_all [Fintype.card_empty]
  intro p
  have h : (∑ i : Fin (2 * n - 1), (p i : ℤ)) % 2 = 1 := by
    have : ∀ i, (p i : ℤ) = 1 ∨ (p i : ℤ) = -1 := by
      intro i
      have : (p i : ℤˣ) = 1 ∨ (p i : ℤˣ) = -1 := by
        have : (p i : ℤˣ) ∈ ({1, -1} : Set ℤˣ) := by
          simpa using Finset.mem_insert_iff.mpr (Or.inl (Finset.mem_singleton.mpr rfl))
        simpa using this
      cases' this with h1 h2 <;> simp_all
    have : (∑ i, (p i : ℤ)) = ∑ i, if (p i : ℤ) = 1 then 1 else -1 := by
      apply Finset.sum_congr rfl
      intro i _
      split_ifs <;> simp_all
    rw [this]
    have : (∑ i, if (p i : ℤ) = 1 then 1 else -1) % 2 = (2 * n - 1) % 2 := by
      have : ∑ i, if (p i : ℤ) = 1 then 1 else -1 ≡ ∑ i, 1 [ZMOD 2] := by
        apply Int.ModEq.sum
        intro i _
        split_ifs <;> simp_all [Int.ModEq]
      simpa [Finset.sum_const, Finset.card_fin] using this
    simpa [Nat.mod_eq_of_lt hn] using this
  have : (∑ i : Fin (2 * n - 1), (p i : Fin 8)) = (∑ i, (p i : ℤ)) % 8 := by
    simp [Fin.cast_add, Fin.cast_sum]
  rw [this]
  intro h'
  have : ((∑ i, (p i : ℤ)) % 8) % 2 = 4 % 2 := by
    omega
  simp at this
  omega
