@[imo_problem_subject algebra]
theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
