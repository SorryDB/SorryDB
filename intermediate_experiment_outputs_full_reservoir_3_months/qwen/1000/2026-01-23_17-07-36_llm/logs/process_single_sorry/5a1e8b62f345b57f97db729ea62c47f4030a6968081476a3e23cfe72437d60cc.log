              specialize ih (2 * (n / 4) + 1) (by omega)
              simp_all [Nat.digits_add, Nat.digits_mul, List.reverse_cons]
            · have : n = 4 * (n / 4) + 3 := by omega
              rw [this, h₅] <;> try omega
              specialize ih (n / 4) (by omega)
              specialize ih (2 * (n / 4) + 1) (by omega)
              simp_all [Nat.digits_add, Nat.digits_mul, List.reverse_cons]
  rw [Finset.card_filter]
  have : (Finset.filter (fun n => n.digits 2 = List.reverse (n.digits 2)) (Finset.Icc 1 1988)).card = 92 := by
    decide
  simpa [h] using this
