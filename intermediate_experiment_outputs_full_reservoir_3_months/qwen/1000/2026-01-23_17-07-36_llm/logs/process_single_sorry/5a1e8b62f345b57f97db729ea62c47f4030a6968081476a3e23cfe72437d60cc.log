  have h : ∀ n ∈ Finset.Icc 1 1988, f n = n ↔ n.digits 2 = List.reverse (n.digits 2) := by
    intro n hn
    have hn' : 1 ≤ n ∧ n ≤ 1988 := Finset.mem_Icc.mp hn
    clear hn
    induction' n using Nat.strong_induction_on with n ih
    cases' n with n
    · simp_all
    · cases' n with n
      · simp_all
      · cases' n % 2 with r
        · have : n = 2 * (n / 2) := by omega
          rw [this, h₃] <;> try omega
          specialize ih (n / 2) (by omega)
          simp_all [Nat.digits_add, Nat.digits_mul, List.reverse_cons]
        · cases' n % 4 with r
          · have : n = 4 * (n / 4) := by omega
            rw [this, h₃] <;> try omega
            specialize ih (n / 4) (by omega)
            simp_all [Nat.digits_add, Nat.digits_mul, List.reverse_cons]
          · cases' r with r
            · have : n = 4 * (n / 4) + 1 := by omega
              rw [this, h₄] <;> try omega
