problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  simp [unifDistN, good_seqs, is_good_seq, to_nat_digit, solution]
  rw [PMF.toOuterMeasure_apply_of_finite]
  · apply Eq.symm
    rw [Finset.card_filter]
    norm_num
    have h₁ : (Finset.univ : Finset (DigitSeq n)).card = 9 ^ n := by
      simp [Fintype.card_fun]
    have h₂ : (Finset.filter (fun s ↦ ¬(10 ∣ ∏ a, (s a + 1))) Finset.univ).card =
        (8 ^ n + 5 ^ n - 4 ^ n) := by
      -- Count sequences missing factor 2 or 5
      -- Total - (no 2s) - (no 5s) + (no 2s and no 5s)
      -- Digits 1-9: evens={2,4,6,8} (4 digits), odds={1,3,5,7,9} (5 digits)
      -- Digits without 2s: {1,3,5,7,9} → 5 choices → 5^n
      -- Digits without 5s: {1,2,3,4,6,7,8,9} → 8 choices → 8^n
      -- Digits without 2s and 5s: {1,3,7,9} → 4 choices → 4^n
      -- So bad sequences = 8^n + 5^n - 4^n
      rfl
    rw [h₂, h₁]
    field_simp
    ring
  · exact Set.Finite.subset (Set.finite_mem_finset _) (by simp)
