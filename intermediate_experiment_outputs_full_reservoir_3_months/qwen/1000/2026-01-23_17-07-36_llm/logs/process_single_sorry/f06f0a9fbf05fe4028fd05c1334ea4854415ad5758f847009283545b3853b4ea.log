      "by\n  simp only [good_seqs, is_good_seq, unifDistN, PMF.toOuterMeasure, PMF.uniformOfFintype,\n    Set.indicator_apply, Set.mem_setOf_eq]\n  rw [PMF.probabilityOfSet_eq_card_div_card]\n  · field_simp [Nat.factorial_ne_zero]\n    rw [← Nat.cast_inj]\n    norm_num\n    apply Eq.symm\n    rw [Nat.card_filter_of_subtype, Nat.card_fin]\n    congr\n    ext s\n    simp only [is_good_seq, to_nat_digit, Fin.prod_univ_succ, Nat.dvd_iff_mod_eq_zero,\n      Nat.mod_eq_zero_of_dvd]\n    have h₁ : (∏ i : Fin n, (s i + 1)) % 10 = 0 ↔\n      ((∏ i : Fin n, (s i + 1)) % 2 = 0 ∧ (∏ i : Fin n, (s i + 1)) % 5 = 0) := by\n      omega\n    rw [h₁]\n    have h₂ : (∏ i : Fin n, (s i + 1)) % 2 = 0 ↔ ∃ i, (s i + 1) % 2 = 0 := by\n      simp [Finset.prod_eq_zero_iff, Nat.mod_eq_zero_of_dvd]\n    have h₃ : (∏ i : Fin n, (s i + 1)) % 5 = 0 ↔ ∃ i, (s i + 1) % 5 = 0 := by\n      simp [Finset.prod_eq_zero_iff, Nat.mod_eq_zero_of_dvd]\n    rw [h₂, h₃]\n    push_neg\n    simp only [not_exists, not_and, not_or]\n    have h₄ : ∀ i, (s i + 1) % 2 ≠ 0 ↔ s i + 1 ∈ ({1, 3, 5, 7, 9} : Finset ℕ) := by\n      intro i\n      have : s i + 1 ≤ 9 := by\n        exact Nat.succ_le_succ (Fin.is_lt _)\n      interval_cases (s i + 1) <;> simp_all\n    have h₅ : ∀ i, (s i + 1) % 5 ≠ 0 ↔ s i + 1 ∈ ({1, 2, 3, 4, 6, 7, 8, 9} : Finset ℕ) := by\n      intro i\n      have : s i + 1 ≤ 9 := by\n        exact Nat.succ_le_succ (Fin.is_lt _)\n      interval_cases (s i + 1) <;> simp_all\n    simp_rw [h₄, h₅]\n    have h₆ : {1, 3, 5, 7, 9} ∩ {1, 2, 3, 4, 6, 7, 8, 9} = {1, 3, 7, 9} := by\n      ext x\n      constructor <;> intro hx <;> simp_all\n    simp [h₆]\n    congr\n    ext\n    simp\n  · exact Finset.univ_nonempty",
      "by\n  simp only [unifDistN, good_seqs, is_good_seq, to_nat_digit]\n  rw [PMF.toOuterMeasure_apply, PMF.uniformOfFintype_apply]\n  norm_num\n  apply Eq.symm\n  rw [Finset.card_filter]\n  congr\n  ext s\n  simp only [Finset.mem_univ, true_and, Finset.sum_const, nsmul_eq_mul, Finset.card_univ,\n    Fintype.card_fun, Fintype.card_fin, Nat.cast_ofNat]\n  norm_num\n  have h₁ : (∏ a : Fin n, (s a + 1)) % 10 = 0 ↔ (∃ i, (s i + 1) % 2 = 0) ∧ (∃ i, (s i + 1) % 5 = 0) := by\n    constructor\n    · intro h\n      have h₂ : 2 ∣ ∏ a : Fin n, (s a + 1) := by\n        exact Nat.dvd_of_mod_eq_zero (by omega)\n      have h₃ : 5 ∣ ∏ a : Fin n, (s a + 1) := by\n        exact Nat.dvd_of_mod_eq_zero (by omega)\n      exact ⟨Finset.prod_dvd_of_mem (by simpa using h₂), Finset.prod_dvd_of_mem (by simpa using h₃)⟩\n    · rintro ⟨⟨i, hi⟩, ⟨j, hj⟩⟩\n      have h₂ : 2 ∣ ∏ a : Fin n, (s a + 1) := by\n        apply Finset.dvd_prod_of_mem\n        simpa using hi\n      have h₃ : 5 ∣ ∏ a : Fin n, (s a + 1) := by\n        apply Finset.dvd_prod_of_mem\n        simpa using hj\n      omega\n  simp_rw [h₁]\n  have h₂ : Fintype.card {s : DigitSeq n // ¬∃ i, (s i + 1) % 2 = 0} = 5 ^ n := by\n    apply Fintype.card_subtype_eq\n    intro s\n    simp only [not_exists, not_and_or, not_not]\n    have : (∀ i, (s i + 1) % 2 ≠ 0) ↔ ∀ i, s i ∈ ({0, 2, 4, 6, 8} : Finset (Fin 9)) := by\n      simp only [Finset.mem_insert, Finset.mem_singleton, Fin.val_eq_zero, Nat.succ_ne_zero,\n        Nat.zero_add, Nat.add_succ, Nat.mod_eq_of_lt, Nat.succ_pos', Nat.zero_lt_succ]\n      constructor\n      · intro h i\n        have : s i + 1 ∈ ({1, 3, 5, 7, 9} : Finset ℕ) := by\n          have : (s i + 1) % 2 ≠ 0 := h i\n          have : s i + 1 ≤ 9 := by\n            exact Nat.succ_le_succ (Fin.is_lt _)\n          interval_cases (s i + 1) <;> simp_all\n        simpa using this\n      · intro h i\n        have : s i ∈ ({0, 2, 4, 6, 8} : Finset (Fin 9)) := h i\n        interval_cases s i <;> simp_all\n    simp_rw [this]\n    simp [Fintype.card_pi, Fintype.card_fin]\n  have h₃ : Fintype.card {s : DigitSeq n // ¬∃ i, (s i + 1) % 5 = 0} = 8 ^ n := by\n    apply Fintype.card_subtype_eq\n    intro s\n    simp only [not_exists, not_and_or, not_not]\n    have : (∀ i, (s i + 1) % 5 ≠ 0) ↔ ∀ i, s i ∈ ({0, 1, 2, 3, 5, 6, 7, 8} : Finset (Fin 9)) := by\n      simp only [Finset.mem_insert, Finset.mem_singleton, Fin.val_eq_zero, Nat.succ_ne_zero,\n        Nat.zero_add, Nat.add_succ, Nat.mod_eq_of_lt, Nat.succ_pos', Nat.zero_lt_succ]\n      constructor\n      · intro h i\n        have : s i + 1 ∈ ({1, 2, 3, 4, 6, 7, 8, 9} : Finset ℕ) := by\n          have : (s i + 1) % 5 ≠ 0 := h i\n          have : s i + 1 ≤ 9 := by\n            exact Nat.succ_le_succ (Fin.is_lt _)\n          interval_cases (s i + 1) <;> simp_all\n        simpa using this\n      · intro h i\n        have : s i ∈ ({0, 1, 2, 3, 5, 6, 7, 8} : Finset (Fin 9)) := h i\n        interval_cases s i <;> simp_all\n    simp_rw [this]\n    simp [Fintype.card_pi, Fintype.card_fin]\n  have h₄ : Fintype.card {s : DigitSeq n // (¬∃ i, (s i + 1) % 2 = 0) ∧ (¬∃ i, (s i + 1) % 5 = 0)} = 4 ^ n := by\n    apply Fintype.card_subtype_eq\n    intro s\n    simp only [not_exists, not_and_or, not_not]\n    have : (∀ i, (s i + 1) % 2 ≠ 0 ∧ (s i + 1) % 5 ≠ 0) ↔ ∀ i, s i ∈ ({0, 2, 6, 8} : Finset (Fin 9)) := by\n      simp only [Finset.mem_insert, Finset.mem_singleton, Fin.val_eq_zero, Nat.succ_ne_zero,\n        Nat.zero_add, Nat.add_succ, Nat.mod_eq_of_lt, Nat.succ_pos', Nat.zero_lt_succ]\n      constructor\n      · intro h i\n        have : s i + 1 ∈ ({1, 3, 7, 9} : Finset ℕ) := by\n          have : (s i + 1) % 2 ≠ 0 := (h i).1\n          have : (s i + 1) % 5 ≠ 0 := (h i).2\n          have : s i + 1 ≤ 9 := by\n            exact Nat.succ_le_succ (Fin.is_lt _)\n          interval_cases (s i + 1) <;> simp_all\n        simpa using this\n      · intro h i\n        have : s i ∈ ({0, 2, 6, 8} : Finset (Fin 9)) := h i\n        interval_cases s i <;> simp_all\n    simp_rw [this]\n    simp [Fintype.card_pi, Fintype.card_fin]\n  simp_all [Nat.cast_pow]\n  <;> field_simp",
      "by\n  simp only [unifDistN, good_seqs, is_good_seq, to_nat_digit]\n  rw [PMF.toOuterMeasure_set_eq]\n  · simp [PMF.uniformOfFintype_apply]\n    rw [Finset.card_filter]\n    have : ∀ s : DigitSeq n, (10 ∣ ∏a, (s a + 1)) ↔ (∃ a, s a = 0) ∧ (∃ a, s a = 4) := by\n      intro s\n      constructor\n      · intro h\n        have h₁ : (2 : ℕ) ∣ ∏a, (s a + 1) := Nat.dvd_trans (by norm_num) h\n        have h₂ : (5 : ℕ) ∣ ∏a, (s a + 1) := Nat.dvd_trans (by norm_num) h\n        refine' ⟨_, _⟩\n        · contrapose! h₁\n          simp_all [Nat.Prime.dvd_prod, Nat.succ_pos]\n          intro i\n          have : s i + 1 ∈ ({1, 3, 5, 7, 9} : Finset ℕ) := by\n            have : s i ∈ Finset.univ := Finset.mem_univ _\n            simp_all [Fin.val_lt]\n          simp_all [Nat.Prime.dvd_mul, Nat.succ_pos]\n        · contrapose! h₂\n          simp_all [Nat.Prime.dvd_prod, Nat.succ_pos]\n          intro i\n          have : s i + 1 ∈ ({1, 2, 3, 4, 6, 7, 8, 9} : Finset ℕ) := by\n            have : s i ∈ Finset.univ := Finset.mem_univ _\n            simp_all [Fin.val_lt]\n          simp_all [Nat.Prime.dvd_mul, Nat.succ_pos]\n      · rintro ⟨⟨a, ha⟩, ⟨b, hb⟩⟩\n        rw [← Nat.dvd_lcm, Nat.lcm_comm]\n        apply Nat.dvd_of_mod_eq_zero\n        simp_all [Nat.mul_mod, Nat.add_mod]\n    simp_all only [this]\n    rw [Finset.card_compl, Finset.card_univ]\n    simp [Fintype.card_fun]\n    ring\n  · exact Set.Finite.subset (Set.finite_univ _) _",
      "by\n  rw [solution]\n  simp [good_seqs, is_good_seq, to_nat_digit]\n  rw [PMF.toOuterMeasure_apply_of_finite]\n  · rw [Finset.card_filter]\n    have h₁ : ∀ s : DigitSeq n, (∏ a, (s a + 1)) % 10 = 0 ↔ (∃ a, (s a + 1) % 2 = 0) ∧ (∃ a, (s a + 1) % 5 = 0) := by\n      intro s\n      constructor\n      · intro h\n        refine' ⟨_, _⟩\n        · contrapose! h\n          simp_all [Nat.mul_mod, Nat.ModEq]\n          omega\n        · contrapose! h\n          simp_all [Nat.mul_mod, Nat.ModEq]\n          omega\n      · rintro ⟨⟨a, ha⟩, ⟨b, hb⟩⟩\n        simp_all [Nat.mul_mod, Nat.ModEq]\n        omega\n    simp_rw [h₁]\n    simp [Finset.filter, Finset.card]\n    have h₂ : Fintype.card (DigitSeq n) = 9 ^ n := by\n      simp [DigitSeq, Fintype.card_pi, Digit]\n    rw [h₂]\n    have h₃ : Fintype.card {s : DigitSeq n | ¬∃ a, (s a + 1) % 2 = 0} = 5 ^ n := by\n      apply Eq.symm\n      calc\n        Fintype.card {s : DigitSeq n | ∀ a, (s a + 1) % 2 ≠ 0}\n          = Fintype.card (Fin n → {d : Digit | (d + 1) % 2 ≠ 0}) := by\n            apply Fintype.card_congr\n            exact Equiv.subtypeEquiv (Equiv.refl _) fun s ↦ by\n              simp [Function.funext_iff]\n        _ = 5 ^ n := by\n          have : Fintype.card {d : Digit | (d + 1) % 2 ≠ 0} = 5 := by\n            decide\n          simp [this, Fintype.card_pi]\n    have h₄ : Fintype.card {s : DigitSeq n | ¬∃ a, (s a + 1) % 5 = 0} = 8 ^ n := by\n      apply Eq.symm\n      calc\n        Fintype.card {s : DigitSeq n | ∀ a, (s a + 1) % 5 ≠ 0}\n          = Fintype.card (Fin n → {d : Digit | (d + 1) % 5 ≠ 0}) := by\n            apply Fintype.card_congr\n            exact Equiv.subtypeEquiv (Equiv.refl _) fun s ↦ by\n              simp [Function.funext_iff]\n        _ = 8 ^ n := by\n          have : Fintype.card {d : Digit | (d + 1) % 5 ≠ 0} = 8 := by\n            decide\n          simp [this, Fintype.card_pi]\n    have h₅ : Fintype.card {s : DigitSeq n | (¬∃ a, (s a + 1) % 2 = 0) ∨ (¬∃ a, (s a + 1) % 5 = 0)} =\n      5 ^ n + 8 ^ n - 4 ^ n := by\n      have : Fintype.card {s : DigitSeq n | (¬∃ a, (s a + 1) % 2 = 0) ∧ (¬∃ a, (s a + 1) % 5 = 0)} = 4 ^ n := by\n        apply Eq.symm\n        calc\n          Fintype.card {s : DigitSeq n | ∀ a, (s a + 1) % 2 ≠ 0 ∧ (s a + 1) % 5 ≠ 0}\n            = Fintype.card (Fin n → {d : Digit | (d + 1) % 2 ≠ 0 ∧ (d + 1) % 5 ≠ 0}) := by\n              apply Fintype.card_congr\n              exact Equiv.subtypeEquiv (Equiv.refl _) fun s ↦ by\n                simp [Function.funext_iff]\n            _ = 4 ^ n := by\n              have : Fintype.card {d : Digit | (d + 1) % 2 ≠ 0 ∧ (d + 1) % 5 ≠ 0} = 4 := by\n                decide\n              simp [this, Fintype.card_pi]\n      rw [Finset.card_union]\n      · omega\n      · ext s\n        simp\n    rw [← Nat.cast_inj]\n    push_cast\n    field_simp\n    ring\n  · exact Set.Finite.subset (Set.finite_mem_finset _) (by simp)",
      "by\n  rw [solution]\n  simp only [good_seqs, is_good_seq, Set.mem_setOf_eq]\n  have h₁ : (unifDistN n).toOuterMeasure {s | 10 ∣ ∏ a, to_nat_digit (s a)} =\n    1 - (unifDistN n).toOuterMeasure {s | ¬(10 ∣ ∏ a, to_nat_digit (s a))} := by\n    rw [PMF.toOuterMeasure_compl]\n    simp\n  rw [h₁]\n  have h₂ : {s | ¬(10 ∣ ∏ a, to_nat_digit (s a))} =\n    {s | ∀ a, to_nat_digit (s a) % 2 ≠ 0} ∪ {s | ∀ a, to_nat_digit (s a) % 5 ≠ 0} := by\n    ext s\n    simp only [Nat.dvd_iff_mod_eq_zero, Nat.mod_eq_zero_of_dvd, not_forall, not_exists,\n      not_and, exists_prop, Prod.exists, Fin.prod_univ_succ, Fin.prod_univ_zero]\n    constructor\n    · intro h\n      by_contra! h'\n      apply h\n      exact Nat.dvd_of_mod_eq_zero (by\n        have h₃ : (∏ a, to_nat_digit (s a)) % 2 = 0 := by\n          apply Nat.mod_eq_zero_of_dvd\n          apply Nat.dvd_of_mod_eq_zero\n          intro a\n          have h₄ : to_nat_digit (s a) % 2 = 0 ∨ to_nat_digit (s a) % 5 = 0 := by\n            apply h'\n            tauto\n          cases' h₄ with h₄ h₄ <;> simp_all\n        have h₃' : (∏ a, to_nat_digit (s a)) % 5 = 0 := by\n          apply Nat.mod_eq_zero_of_dvd\n          apply Nat.dvd_of_mod_eq_zero\n          intro a\n          have h₄ : to_nat_digit (s a) % 2 = 0 ∨ to_nat_digit (s a) % 5 = 0 := by\n            apply h'\n            tauto\n          cases' h₄ with h₄ h₄ <;> simp_all\n        omega)\n    · intro h\n      cases' h with h h <;> intro hh <;> simp_all\n  rw [h₂]\n  have h₃ : (unifDistN n).toOuterMeasure ({s | ∀ a, to_nat_digit (s a) % 2 ≠ 0} ∪\n    {s | ∀ a, to_nat_digit (s a) % 5 ≠ 0}) =\n    (unifDistN n).toOuterMeasure {s | ∀ a, to_nat_digit (s a) % 2 ≠ 0} +\n    (unifDistN n).toOuterMeasure {s | ∀ a, to_nat_digit (s a) % 5 ≠ 0} -\n    (unifDistN n).toOuterMeasure ({s | ∀ a, to_nat_digit (s a) % 2 ≠ 0} ∩\n    {s | ∀ a, to_nat_digit (s a) % 5 ≠ 0}) := by\n    rw [PMF.toOuterMeasure_union]\n  rw [h₃]\n  have h₄ : (unifDistN n).toOuterMeasure {s | ∀ a, to_nat_digit (s a) % 2 ≠ 0} = (5 / 9) ^ n := by\n    simp [unifDistN, PMF.uniformOfFintype, PMF.toOuterMeasure_singleton]\n    rfl\n  have h₅ : (unifDistN n).toOuterMeasure {s | ∀ a, to_nat_digit (s a) % 5 ≠ 0} = (8 / 9) ^ n := by\n    simp [unifDistN, PMF.uniformOfFintype, PMF.toOuterMeasure_singleton]\n    rfl\n  have h₆ : (unifDistN n).toOuterMeasure ({s | ∀ a, to_nat_digit (s a) % 2 ≠ 0} ∩\n    {s | ∀ a, to_nat_digit (s a) % 5 ≠ 0}) = (4 / 9) ^ n := by\n    simp [unifDistN, PMF.uniformOfFintype, PMF.toOuterMeasure_singleton]\n    rfl\n  rw [h₄, h₅, h₆]\n  ring",
      "by\n  rw [solution]\n  simp only [good_seqs, is_good_seq, unifDistN, PMF.toOuterMeasure]\n  rw [PMF.probability_of_set_eq_card_div_card]\n  swap\n  · infer_instance\n  · rfl\n  classical\n  rw [Nat.card_fin]\n  norm_num\n  have h₁ : (Finset.univ : Finset (DigitSeq n)).card = 9 ^ n := by\n    simp [Nat.card_fin, Fintype.card_fun]\n  rw [h₁]\n  have h₂ : (Finset.filter (fun s ↦ 10 ∣ ∏a, to_nat_digit (s a)) Finset.univ).card =\n      9 ^ n - 8 ^ n - 5 ^ n + 4 ^ n := by\n    have : ∀ s : DigitSeq n, (10 ∣ ∏a, to_nat_digit (s a)) ↔\n        (∃ i, to_nat_digit (s i) = 2 ∨ to_nat_digit (s i) = 4 ∨ to_nat_digit (s i) = 6 ∨ to_nat_digit (s i) = 8) ∧\n        (∃ i, to_nat_digit (s i) = 5) := by\n      intro s\n      constructor\n      · intro h\n        have h₁ : 2 ∣ ∏a, to_nat_digit (s a) := Nat.dvd_trans (by decide) h\n        have h₂ : 5 ∣ ∏a, to_nat_digit (s a) := Nat.dvd_trans (by decide) h\n        constructor\n        · contrapose! h₁\n          simp_all [Nat.Prime.dvd_prod]\n          <;> omega\n        · contrapose! h₂\n          simp_all [Nat.Prime.dvd_prod]\n          <;> omega\n      · rintro ⟨⟨i, hi⟩, ⟨j, hj⟩⟩\n        have h₁ : 2 ∣ to_nat_digit (s i) := by\n          cases' hi with h h <;> cases' h with h h <;> subst_vars <;> decide\n        have h₂ : 5 ∣ to_nat_digit (s j) := by\n          subst_vars\n          decide\n        exact Nat.dvd_mul_of_dvd_left (Nat.dvd_trans h₁ (Nat.dvd_mul_right _ _)) _\n    rw [this]\n    simp only [Finset.card_filter, Finset.mem_univ, forall_true_left]\n    rw [Finset.card_compl, Finset.card_compl]\n    simp only [Finset.card_univ, Nat.card_fin, Fintype.card_fun]\n    norm_num\n    have A : (Finset.filter (fun s ↦ ¬∃ i, to_nat_digit (s i) = 2 ∨ to_nat_digit (s i) = 4 ∨ to_nat_digit (s i) = 6 ∨ to_nat_digit (s i) = 8) Finset.univ).card = 5 ^ n := by\n      apply Eq.symm\n      rw [Finset.card_filter]\n      congr\n      ext s\n      simp only [Finset.mem_univ, forall_true_left, not_exists, not_or]\n      have : ∀ d : Digit