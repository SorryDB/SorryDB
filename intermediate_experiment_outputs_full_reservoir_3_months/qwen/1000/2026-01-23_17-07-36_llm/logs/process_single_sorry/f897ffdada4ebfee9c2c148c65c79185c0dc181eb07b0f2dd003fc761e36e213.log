      "\n  have h1 : Disjoint (M ∩ E(P)) (E(P) \\ M) := by\n    apply disjoint_sdiff\n  rw [symmDiff_eq_union_sdiff, encard_union_disjoint h1]\n  have h2 : (E(P) \\ M).encard = (E(P)).encard - (M ∩ E(P)).encard := by\n    rw [encard_sdiff_le, tsub_eq_iff_eq_add_of_le] <;> exact encard_inter_le_left\n  rw [h2, add_tsub_cancel_right]\n  have h3 : (E(P)).encard = (M ∩ E(P)).encard + 1 := by\n    have h4 : P.Nonempty := h.nonempty\n    have h5 : Odd (E(P)).encard := by\n      cases' P with u | u e w\n      · contradiction\n      · simp_all [WList.edgeSet_cons]\n        exact odd_iff_not_even.mpr (by simpa using h.first_not_in)\n    have h6 : (M ∩ E(P)).encard = (E(P)).encard / 2 := by\n      have h7 : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n      have h8 : ∀ i, i < (E(P)).encard → (P.edge.get? i).getD default ∈ M ↔ i % 2 = 0 := by\n        induction (E(P)).encard with\n        | zero => simp_all\n        | succ n ih =>\n          cases n\n          · simp_all\n          · simp_all [List.isChain_cons_cons]\n      simp_all [encard_eq_toFinset_card]\n    omega\n  omega",
