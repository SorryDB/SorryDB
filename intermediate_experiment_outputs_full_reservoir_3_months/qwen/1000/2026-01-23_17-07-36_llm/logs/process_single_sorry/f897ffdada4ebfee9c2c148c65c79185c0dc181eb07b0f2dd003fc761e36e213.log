 ∧ e₂ ∈ E(P) ∧ e₁ ≠ e₂ ∧ e₁ ∈ E(G, v) ∧ e₂ ∈ E(G, v) := by\n                    apply WList.internal_vertex_has_two_edges h_path h_v_not_first h_v_not_last\n                  obtain ⟨e₁, e₂, he₁, he₂, he₁₂, he₁v, he₂v⟩ := h_v_internal\n                  have he₁M : e₁ ∈ M ↔ e ∉ M := by\n                    apply h_alt.chain_take.1\n                    exact List.take_prefix _ _\n                  have he₂M : e₂ ∈ M ↔ e ∉ M := by\n                    apply h_alt.chain_drop.1\n                    exact List.drop_suffix _ _\n                  have he₁M' : e₁ ∈ M := by\n                    rw [he₁M]\n                    exact not_not_intro h_both.1\n                  have he₂M' : e₂ ∈ M := by\n                    rw [he₂M]\n                    exact not_not_intro h_both.1\n                  have he₁e₂_disj : Disjoint V(G, e₁) V(G, e₂) := h_match.disjoint he₁M' he₂M' he₁₂\n                  have h_v_e₁ : v ∈ V(G, e₁) := he₁v\n                  have h_v_e₂ : v ∈ V(G, e₂) := he₂v\n                  exact he₁e₂_disj.not_mem_of_mem_left h_v_e₁ h_v_e₂\n                · obtain ⟨w, hw1, hw2, hw3⟩ := h_inc_f\n                  have h_v_e : v ∈ V(G, e) := by\n                    apply V_inc_iff.2\n                    exact ⟨e, h_path.edge_subset h_both.1, h_inc_e⟩\n                  have h_w_f : w ∈ V(G, f) := by\n                    apply V_inc_iff.2\n                    exact ⟨f, h_path.edge_subset h_both.2, hw3⟩\n                  have h_v_not_first : v ≠ P.first := h_inc_e.1\n                  have h_v_not_last : v ≠ P.last := h_inc_e.2\n                  have h_w_not_first : w ≠ P.first := hw1\n                  have h_w_not_last : w ≠ P.last := hw2\n                  have h_v_w : v = w := by\n                    apply h_path.simple_iff.1 h_path.isSimple |>.eq_of_adjacent hef\n                    · exact h_inc_e.2.2\n                    · exact hw3\n                  rw [h_v_w] at h_w_f\n                  have h_v_internal : ∃ e₁ e₂, e₁ ∈ E(P) ∧ e₂ ∈ E(P) ∧ e₁ ≠ e₂ ∧ e₁ ∈ E