lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.toIsAltPath.mem_matching_iff
  have h_odd : Odd P.length := by
    have : P.Nonempty := h.nonempty
    have : P.first ∉ V(G, M) := h.first_not_in
    have : P.last ∉ V(G, M) := h.last_not_in
    cases' P with u
    · contradiction
    · induction P with
      | nil => contradiction
      | cons u e P ih =>
        simp_all [WList.length, WList.edge]
        have : (e ∈ M) ↔ (P.edge.head? ≠ none → P.edge.head? = some f → f ∉ M) := by
          simpa using h_alt
        omega
  rw [symmDiff_encard_eq_add_sub_mul_inter]
  have : (M ∩ E(P)).encard = P.length / 2 := by
    sorry
  have : (Mᶜ ∩ E(P)).encard = (P.length + 1) / 2 := by
    sorry
  omega
