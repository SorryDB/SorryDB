      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_path : G.IsPath P := h.toIsPath\n  have h_match : G.IsMatching M := hM\n  have h_edges : E(P) ⊆ E(G) := h_path.edge_subset\n  have h_disj : Disjoint (M ∩ E(P)) (E(P) \\ M) := by\n    apply Set.disjoint_sdiff_right\n  calc\n    (M ∆ E(P)).encard = (M \\ E(P)).encard + (E(P) \\ M).encard := by\n      rw [symmDiff_eq_union_diff, encard_union_of_disjoint h_disj]\n    _ = M.encard - (M ∩ E(P)).encard + (E(P) \\ M).encard := by\n      rw [encard_sdiff_eq_sub h_match.subset h_edges]\n    _ = M.encard + ((E(P) \\ M).encard - (M ∩ E(P)).encard) := by\n      rw [add_comm, add_tsub_assoc_of_le (by apply le_of_lt; apply Nat.lt_succ_self)]\n    _ = M.encard + 1 := by\n      have h_odd : Odd (E(P)).encard := by\n        have h_len : E(P).encard = P.length := by\n          rw [← WList.length_edgeSet, WList.length_eq_encard_edgeSet]\n        have h_alt_len : Even (P.length) ∨ Odd (P.length) := by\n          apply Nat.even_or_odd\n        cases' h_alt_len with h_even h_odd\n        · exfalso\n          have h_endpoints : P.first ≠ P.last := by\n            intro h_eq\n            have h_cycle : G.IsCycleGraph (G ↾ E(P)) := by\n              apply Subgraph.isCycleGraph_of_isTrail_isClosed\n              exact h_path.toIsTrail\n              simp [h_eq]\n            have h_match_cycle : (E(P) ∩ M).encard = (E(P) \\ M).encard := by\n              apply h_match.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM\n              apply Subgraph.isCompOf_of_isConnected\n              apply Subgraph.isConnected_of_isPathGraph\n              apply Subgraph.isPathGraph_of_isPath\n              exact h_path\n            have h_contra : (E(P) \\ M).encard = (E(P) ∩ M).encard := by\n              rw [h_match_cycle]\n            have h_parity : Even (E(P)).enca