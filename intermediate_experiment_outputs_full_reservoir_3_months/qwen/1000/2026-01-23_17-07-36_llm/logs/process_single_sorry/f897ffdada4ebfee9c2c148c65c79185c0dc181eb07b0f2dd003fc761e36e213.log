        have h_v_not_last : v ≠ P.last := hv2\n                have h_v_internal : ∃ e₁ e₂, e₁ ∈ E(P) ∧ e₂ ∈ E(P) ∧ e₁ ≠ e₂ ∧ e₁ ∈ E(G, v) ∧ e₂ ∈ E(G, v) := by\n                  apply WList.internal_vertex_has_two_edges h_path h_v_not_first h_v_not_last\n                obtain ⟨e₁, e₂, he₁, he₂, he₁₂, he₁v, he₂v⟩ := h_v_internal\n                have he₁M : e₁ ∈ M ↔ e ∉ M := by\n                  apply h_alt.chain_take.1\n                  exact List.take_prefix _ _\n                have he₂M : e₂ ∈ M ↔ e ∉ M := by\n                  apply h_alt.chain_drop.1\n                  exact List.drop_suffix _ _\n                have he₁M' : e₁ ∈ M := by\n                  rw [he₁M]\n                  exact not_not_intro h_both.1\n                have he₂M' : e₂ ∈ M := by\n                  rw [he₂M]\n                  exact not_not_intro h_both.1\n                have he₁e₂_disj : Disjoint V(G, e₁) V(G, e₂) := h_match.disjoint he₁M' he₂M' he₁₂\n                have h_v_e₁ : v ∈ V(G, e₁) := he₁v\n                have h_v_e₂ : v ∈ V(G, e₂) := he₂v\n                exact he₁e₂_disj.not_mem_of_mem_left h_v_e₁ h_v_e₂\n          · cases' h_inc_e with h_inc_e h_inc_e\n            · cases' h_inc_f with h_inc_f h_inc_f\n              · have h_last_e : P.last ∈ V(G, e) := by\n                  apply V_inc_iff.2\n                  exact ⟨e, h_path.edge_subset h_both.1, h_inc_e⟩\n                have h_first_f : P.first ∈ V(G, f) := by\n                  apply V_inc_iff.2\n                  exact ⟨f, h_path.edge_subset h_both.2, h_inc_f⟩\n                have h_first_last : P.first = P.last := by\n                  apply h_path.simple_iff.1 h_path.isSimple |>.eq_of_adjacent hef.symm\n                  · exact h_inc_f\n                  · exact h_inc_e\n                rw [h_first_last] at h_last_e\n                exact h_disj.not_mem_of_mem_left h_last_e h_first_f\n              · have h_last_e : P.last ∈ V(G, e) := by\n                  apply V_inc_iff.2\n                  exact ⟨e,