      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_odd : Odd P.edge.length := by\n    have h_first : P.first ∉ V(G, M) := h.first_not_in\n    have h_last : P.last ∉ V(G, M) := h.last_not_in\n    cases' P with x\n    · contradiction\n    · induction P with\n      | nil => contradiction\n      | cons u e P ih =>\n        cases' P with v\n        · simp_all\n        ·\n          have h_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt.of_cons\n          have h_ind : Odd P.edge.length → (M ∆ E(P.cons u e)).encard = M.encard + 1 := by\n            sorry\n          sorry\n  sorry",
      "\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_odd : Odd P.length := by\n    have : P.Nonempty := h.nonempty\n    cases' P with u\n    · contradiction\n    induction P with\n    | nil => contradiction\n    | cons u e P ih =>\n      cases' P with v\n      · simp [WList.length]\n      have : P.Nonempty → Odd P.length → Even (P.length + 2) := fun _ hodd => by\n        rw [Nat.even_add, Nat.even_two]\n        exact Nat.odd_iff_not_even.mp hodd\n      simp_all [WList.length]\n  have h_disj : Disjoint (M ∩ E(P)) (E(P) \\ M) := by\n    apply Disjoint.mono_right\n    apply Set.diff_subset\n  calc\n    (M ∆ E(P)).encard = (M \\ E(P)).encard + (E(P) \\ M).encard := by\n      rw [symmDiff_eq_union_diff, encard_union_of_disjoint h_disj]\n    _ = M.encard - (M ∩ E(P)).encard + (E(P) \\ M).encard := by\n      rw [encard_diff_eq_sub hM.subset]\n    _ = M.encard + ((E(P) \\ M).encard - (M ∩ E(P)).encard) := by\n      rw [add_comm, add_tsub_assoc_of_le (by apply encard_mono; apply inter_subset_left)]\n    _ = M.encard + 1 := by\n      have h_match : (E(P) \\ M).encard = (M ∩ E(P)).encard + 1 := by\n        have : P.edge.Nodup := h.toIsPath.isTrail.edge_nodup\n        have : P.edge.length = (E(P) \\ M).encard + (M ∩ E(P)).encard := by\n          rw [← encard_union_of_disjoint (disjoint_sdiff_inter _ _), ← Set.union_sdiff_distrib_left,\n            Set.union_comm, Set.union_sdiff_self, Set.union_empty]\n          exact encard_eq_of_nodup this\n        have : Odd P.edge.length := by simpa [WList.length] using h_odd\n        have : Even ((M ∩ E(P)).encard + (M ∩ E(P)).encard) := by\n          rw [add_comm]; exact even_add_self _\n        have : Odd ((M ∩ E(P)).encard + (M ∩ E(P)).encard + 1) := by\n          simpa using Nat.odd_add Nat.even_iff.mp this\n        have : (E(P) \\ M).encard = (M ∩ E(P)).encard + 1 := by\n          omega\n        exact this\n      omega",
      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_odd : Odd P.edge.length := by\n    cases' P with u\n    · contradiction\n    cases' P.tail with v\n    · simp_all\n    have h_first : P.first ∉ V(G, M) := h.first_not_in\n    have h_last : P.last ∉ V(G, M) := h.last_not_in\n    have h_match : ∀ e ∈ P.edge, e ∈ M ↔ ¬(e ∈ M) := by\n      intro e he\n      cases' P.edge with e0 es\n      · contradiction\n      induction es generalizing e <;> simp_all [List.isChain_cons_cons]\n    simp_all [symmDiff_encard, encard_edgeSet_of_nodup, h.toIsPath.isTrail.edge_nodup]\n  rw [symmDiff_encard, add_comm]\n  simp_all [Odd.elim, Nat.add_sub_cancel]",
      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_path : G.IsPath P := h.toIsPath\n  have h_trail : P.IsTrail := h_path.isTrail\n  have h_nodup : P.edge.Nodup := h_trail.edge_nodup\n  have h_edges : E(P) = P.edge.toFinset := by\n    ext e\n    simp [edgeSet_eq_edge_toFinset]\n  rw [h_edges]\n  clear h_edges\n  have h_match_edges : ∀ e ∈ P.edge, e ∈ M ↔ ¬(e ∈ M) → False := by\n    intro e he\n    simp\n  have h_odd : Odd P.edge.length := by\n    cases' P with u\n    · contradiction\n    cases' P with v\n    · simp_all\n    induction P generalizing u v\n    · simp_all\n    simp_all [List.isChain_cons_cons, List.length]\n    omega\n  have h_symmDiff : (M ∆ P.edge.toFinset).encard = M.encard + 1 := by\n    have h_disj : Disjoint (M ∩ P.edge.toFinset) (P.edge.toFinset \\ M) := by\n      apply Set.disjoint_left\n      intro x hx\n      simp_all\n    calc\n      (M ∆ P.edge.toFinset).encard\n        = (M \\ P.edge.toFinset).encard + (P.edge.toFinset \\ M).encard := by\n          rw [symmDiff_eq_union_diff, encard_union_of_disjoint h_disj]\n      _ = M.encard - (M ∩ P.edge.toFinset).encard + (P.edge.toFinset \\ M).encard := by\n          rw [encard_diff_eq_sub]\n      _ = M.encard + ((P.edge.toFinset \\ M).encard - (M ∩ P.edge.toFinset).encard) := by\n          omega\n      _ = M.encard + 1 := by\n          have h_match_count : (M ∩ P.edge.toFinset).encard = (P.edge.toFinset \\ M).encard - 1 := by\n            have h_alt_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt\n            have h_start : P.edge.head! ∉ M := by\n              have h_first_edge : P.edge.head! ∈ E(G, P.first) := by\n                cases' P with u\n                · contradiction\n                cases' P with v\n                · simp_all\n                simp_all [WList.edge_cons]\n              intro hM