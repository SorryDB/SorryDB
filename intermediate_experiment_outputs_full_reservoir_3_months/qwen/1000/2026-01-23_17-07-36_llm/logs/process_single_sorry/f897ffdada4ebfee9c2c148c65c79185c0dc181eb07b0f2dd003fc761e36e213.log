      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_path : G.IsPath P := h.toIsPath\n  have h_edges : E(P) ⊆ E(G) := h_path.edge_subset\n  have h_match : G.IsMatching M := hM\n  have h_disj : ∀ e ∈ E(P), e ∈ M → False := by\n    intro e he heM\n    have h_inc : e ∈ E(G, P.first) ∨ e ∈ E(G, P.last) ∨ ∃ v, v ≠ P.first ∧ v ≠ P.last ∧ e ∈ E(G, v) := by\n      apply WList.edge_mem_inc_iff.1 he\n    cases' h_inc with h_inc h_inc\n    · exact h_first (V_inc_iff.2 ⟨e, heM, h_inc⟩)\n    · cases' h_inc with h_inc h_inc\n      · exact h_last (V_inc_iff.2 ⟨e, heM, h_inc⟩)\n      · obtain ⟨v, hv1, hv2, hve⟩ := h_inc\n        have h_match_v : (M ∩ E(G, v)).Subsingleton := h_match.subsingleton_inc v\n        have h_e_v : e ∈ M ∩ E(G, v) := ⟨heM, hve⟩\n        have h_other : ∃ f ∈ E(P), f ≠ e ∧ f ∈ E(G, v) := by\n          apply WList.exists_other_edge_of_internal_vertex h_path hv1 hv2\n        obtain ⟨f, hf, hfe, hfv⟩ := h_other\n        have hfM : f ∈ M ↔ e ∉ M := by\n          apply List.isChain_pair h_alt (by aesop) (by aesop)\n        simp_all\n  have h_disj' : Disjoint (E(P) ∩ M) (E(P) \\ M) := by\n    apply disjoint_left.2\n    intro e he\n    simp_all\n  calc\n    (M ∆ E(P)).encard = (M \\ E(P)).encard + (E(P) \\ M).encard := by\n      rw [symmDiff_eq_union_diff, encard_union_of_disjoint]\n      apply disjoint_diff_diff\n    _ = M.encard - (E(P) ∩ M).encard + (E(P) \\ M).encard := by\n      rw [encard_diff_eq_sub] <;> apply Set.encard_mono <;> aesop\n    _ = M.encard + (E(P) \\ M).encard := by\n      rw [sub_zero] <;> apply encard_eq_zero_of_forall_not_mem <;> intro e he <;> simp_all\n    _ = M.encard + E(P).encard := by\n      rw [encard_diff_eq_sub] <;> apply Set.encard_mono <;> aesop\n    _ = M.encard + (P.length) := by\n      rw [WList.encard_edgeSet_eq_length]\n    _ = M.encard + 1 :=