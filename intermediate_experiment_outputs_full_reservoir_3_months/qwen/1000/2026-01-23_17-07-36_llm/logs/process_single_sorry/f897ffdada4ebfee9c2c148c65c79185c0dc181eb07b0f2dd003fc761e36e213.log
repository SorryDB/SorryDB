      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_path : G.IsPath P := h.toIsPath\n  have h_match : G.IsMatching M := hM\n  have h_edge_set : E(P) = P.edgeSet := rfl\n  rw [← h_edge_set]\n  have h_disj : Disjoint (M ∩ E(P)) (E(P) \\ M) := by\n    apply Set.disjoint_left\n    intro x hx\n    simp_all\n  have h_encard : (M ∆ E(P)).encard = (M \\ E(P)).encard + (E(P) \\ M).encard := by\n    rw [symmDiff_eq_union_diff, encard_union_of_disjoint h_disj]\n  have h_odd : Odd P.length := by\n    cases' hP with u e Q\n    · contradiction\n    · have h_len : P.length = List.length P.edge := rfl\n      have h_alt_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt\n      have h_start : P.edge.head! ∉ M := by\n        have h_first_inc : P.edge.head! ∈ E(G, P.first) := by\n          cases' P with u\n          · contradiction\n          · simp_all\n        intro hM_head\n        exact h_first (V_incidence_mem hM_head h_first_inc)\n      have h_end : P.edge.getLast! ∉ M := by\n        have h_last_inc : P.edge.getLast! ∈ E(G, P.last) := by\n          cases' P with u\n          · contradiction\n          · simp_all\n        intro hM_last\n        exact h_last (V_incidence_mem hM_last h_last_inc)\n      have h_parity : Even (List.length P.edge) → False := by\n        intro h_even\n        induction' P.edge with e es ih\n        · contradiction\n        · cases' es with f fs\n          · simp_all\n          · simp_all [List.IsChain, h_alt_chain]\n            specialize ih (by simp_all)\n            simp_all\n      exact odd_of_not_even h_parity\n  have h_diff : (E(P) \\ M).encard = (M \\ E(P)).encard + 1 := by\n    cases' hP with u e Q\n    · contradiction\n    · have h_len : P.length = List.length P.edge := rfl\n      have h_alt_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt\n     