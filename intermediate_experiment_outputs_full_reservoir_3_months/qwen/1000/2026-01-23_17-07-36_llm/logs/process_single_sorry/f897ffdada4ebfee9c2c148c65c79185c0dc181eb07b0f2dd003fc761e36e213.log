      "\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.toIsAltPath.mem_matching_iff\n  have h_odd : Odd P.edge.length := by\n    have : P.Nonempty := h.nonempty\n    have : P.first ∉ V(G, M) := h.first_not_in\n    have : P.last ∉ V(G, M) := h.last_not_in\n    cases' P with u\n    · contradiction\n    induction P with\n    | nil => contradiction\n    | cons u e P ih =>\n      cases' P with v\n      · simp_all\n      have : e ∉ M := by\n        intro he\n        have : u ∈ V(G, M) := ⟨e, he, (G.incidence e).mem_of_mem_left⟩\n        contradiction\n      have : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt.of_cons\n      have : Odd P.edge.length := by\n        apply ih\n        · exact h.toIsAltPath.of_cons\n        · simp_all\n        · simp_all\n      simp_all [symmDiff_encard, Nat.add_comm]\n  rw [symmDiff_encard]\n  have : Disjoint (M \\ E(P)) (E(P) \\ M) := by\n    apply disjoint_sdiff_sdiff\n  have : (M \\ E(P)).encard + (E(P) \\ M).encard = M.encard + 1 := by\n    have : (E(P) \\ M).encard = (M \\ E(P)).encard + 1 := by\n      have : E(P).encard = (E(P) ∩ M).encard + (E(P) \\ M).encard := by\n        rw [encard_union_add (disjoint_sdiff_inter_right _ _)]\n        rw [union_sdiff_inter_of_subset (inter_subset_left _ _)]\n      have : M.encard = (M ∩ E(P)).encard + (M \\ E(P)).encard := by\n        rw [encard_union_add (disjoint_inter_sdiff _ _)]\n        rw [union_inter_sdiff_of_subset (inter_subset_left _ _)]\n      have : (E(P) ∩ M).encard = (M ∩ E(P)).encard := by\n        rw [inter_comm]\n      have : E(P).encard = P.edge.length := by\n        simp [edgeSet_eq_edge]\n      have : Odd P.edge.length := h_odd\n      have : (E(P) ∩ M).encard = P.edge.length / 2 := by\n        apply Nat.div_two_of_isChain_alternating h_alt\n      have : (E(P) \\ M).encard = P.edge.length - (E(P) ∩ M).encard := by\n        rw [← encard_sdiff_eq_encard_sub_encard_inter]\n      omega\n    omega\n  omega",
      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_odd : Odd P.edge.length := by\n    have : P.edge.length % 2 = 1 := by\n      cases' P with u\n      · contradiction\n      induction P with\n      | nil => contradiction\n      | cons u e P ih =>\n        cases' P with v\n        · simp [WList.cons_edge]\n        ·\n          have := h_alt\n          simp only [WList.cons_edge, List.isChain_cons_cons] at this\n          obtain ⟨hef, _⟩ := this\n          have := ih (by simpa using h.suffix (by apply WList.IsSuffix.cons; apply WList.IsSuffix.nil))\n          omega\n    exact ⟨this⟩\n  have h_disj : Disjoint (M ∩ E(P)) (E(P) \\ M) := by\n    apply Set.disjoint_left\n    intro x hx\n    simp at hx\n    tauto\n  calc\n    (M ∆ E(P)).encard = (M \\ E(P)).encard + (E(P) \\ M).encard := by\n      rw [symmDiff_eq_union_diff, encard_union_of_disjoint h_disj]\n    _ = M.encard - (M ∩ E(P)).encard + (E(P) \\ M).encard := by\n      rw [encard_diff_eq_sub_of_subset (Set.inter_subset_left _ _)]\n    _ = M.encard + ((E(P) \\ M).encard - (M ∩ E(P)).encard) := by\n      omega\n    _ = M.encard + 1 := by\n      have : (E(P) \\ M).encard = (M ∩ E(P)).encard + 1 := by\n        have : P.edge.length = (M ∩ E(P)).encard + (E(P) \\ M).encard := by\n          rw [← encard_union_of_disjoint h_disj.symm, Set.union_comm]\n          rw [Set.union_eq_symmDiff_union_inter, symmDiff_eq_union_diff]\n          rw [encard_union_of_disjoint (Set.disjoint_left.mpr (fun x hx ↦ by simp_all))]\n          simp [encard_edgeSet]\n        omega\n      omega",
      "\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_nonempty : P.Nonempty := h.nonempty\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_path : G.IsPath P := h.toIsPath\n  have h_edges : E(P) ⊆ E(G) := h_path.edge_subset\n  have h_match : G.IsMatching M := hM\n  have h_disj : ∀ e ∈ E(P), ∀ f ∈ E(P), e ≠ f → Disjoint V(G, e) V(G, f) := by\n    intro e he f hf hne\n    have h_trail : P.IsTrail := h_path.isTrail\n    have h_nodup : P.edge.Nodup := h_trail.edge_nodup\n    have h_inc : e ∈ P.edge ∧ f ∈ P.edge := ⟨he, hf⟩\n    exact h_nodup.pairwise_disjoint_of_nodup (by simp_all) (by simp_all)\n  have h_parity : Odd P.edge.length := by\n    have h_start : P.edge.head? = some (P.edge.get ⟨0, by simp [h_nonempty]⟩) := by simp [h_nonempty]\n    have h_end : P.edge.getLast? = some (P.edge.get ⟨P.edge.length - 1, by simp [h_nonempty]⟩) := by simp [h_nonempty]\n    have h_alt_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt\n    have h_first_edge : P.edge.get ⟨0, by simp [h_nonempty]⟩ ∉ M := by\n      have h_first_vert : P.first ∉ V(G, M) := h_first\n      have h_inc_first : P.first ∈ V(G, P.edge.get ⟨0, by simp [h_nonempty]⟩) := by\n        apply h_path.start_mem\n      intro h_mem\n      exact h_first_vert (Set.mem_of_mem_inter_right ⟨h_mem, h_inc_first⟩)\n    have h_last_edge : P.edge.get ⟨P.edge.length - 1, by simp [h_nonempty]⟩ ∉ M := by\n      have h_last_vert : P.last ∉ V(G, M) := h_last\n      have h_inc_last : P.last ∈ V(G, P.edge.get ⟨P.edge.length - 1, by simp [h_nonempty]⟩) := by\n        apply h_path.end_mem\n      intro h_mem\n      exact h_last_vert (Set.mem_of_mem_inter_right ⟨h_mem, h_inc_last⟩)\n    have h_alt_parity : (P.edge.get ⟨0, by simp [h_nonempty]⟩ ∈ M) ↔ (P.edge.length % 2 = 0) := by\n      induction' P.edge.length with n ih\n      · simp_all\n      · cases n\n        · simp_all\n        · simp_all [List.IsChain, Nat.succ_eq_add_one, Nat.add_mod_right]\n    simp_all [Nat.odd_iff_not_even]\n  have h_symm_diff : (M ∆ E(P)).encard = M.encard + E(P).encard - 2 * (M ∩ E(P)).encard := by\n    rw [symmDiff_encard, add_comm]\n  have h_match_inter : (M ∩ E(P)).encard = E(P).encard / 2 := by\n    have h_match_inter_card : (M ∩ E(P)).encard + (E(P) \\ M).encard = E(P).encard := by\n      rw [← encard_union_add_encard_inter, Set.union_sdiff_of_subset (Set.inter_subset_left _ _)]\n      · rfl\n      · exact Set.inter_subset_left _ _\n    have h_match_inter_eq : (M ∩ E(P)).encard = (E(P) \\ M).encard := by\n      have h_match_inter_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt\n      have h_match_inter_parity : Odd P.edge.length := h_parity\n      have h_match_inter_first : P.edge.get ⟨0, by simp [h_nonempty]⟩ ∉ M := by\n        have h_first_vert : P.first ∉ V(G, M) := h_first\n        have h_inc_first : P.first ∈ V(G, P.edge.get ⟨0, by simp [h_nonempty]⟩) := by\n          apply h_path.start_mem\n        intro h_mem\n        exact h_first_vert (Set.mem_of_mem_inter_right ⟨h_mem, h_inc_first⟩)\n      have h_match_inter_last : P.edge.get ⟨P.edge.length - 1, by simp [h_nonempty]⟩ ∉ M := by\n        have h_last_vert : P.last ∉ V(G, M) := h_last\n        have h_inc_last : P.last ∈ V(G, P.edge.get ⟨P.edge.length - 1, by simp [h_nonempty]⟩) := by\n          apply h_path.end_mem\n        intro h_mem\n        exact h_last_vert (Set.mem_of_mem_inter_right ⟨h_mem, h_inc_last⟩)\n      simp_all [List.IsChain, Nat.odd_iff_not_even]\n    omega\n  rw [h_symm_diff, h_match_inter]\n  have h_edge_card : E(P).encard = P.edge.length := by\n    rw [← List.encard_eq_length, WList.edgeSet_eq_edge_toSet]\n  rw [h_edge_card]\n  have h_odd : Odd P.edge.length := h_parity\n  have h_even : Even (P.edge.length / 2 * 2) := by\n    apply Nat.even_mul\n    apply Nat.even_two\n  omega",
      "\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.toIsAltPath.mem_matching_iff\n  have h_nonempty : P.Nonempty := h.nonempty\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_path : G.IsPath P := h.toIsAltPath.toIsPath\n  have h_trail : G.IsTrail P := h_path.isTrail\n  have h_nodup : P.edge.Nodup := h_trail.edge_nodup\n  have h_edges : E(P) = P.edge.toFinset := rfl\n  rw [symmDiff_encard_eq_add_sub_mul_inter_encard]\n  have h_inter : (M ∩ E(P)).encard = (E(P) \\ M).encard - 1 := by\n    cases' P with u\n    · exfalso; exact h_nonempty (.nil u)\n    induction' P with u e P IH\n    · simp_all\n    · simp_all [WList.cons_edge, List.isChain_cons_cons, symmDiff, Set.encard_insert_of_not_mem]\n      have h_e_notin_M : e ∉ M := by\n        intro he\n        have h_u_in : u ∈ V(G, M) := ⟨e, he, (G.incidence e).mem_left⟩\n        exact h_first h_u_in\n      have h_P_ind : (M ∩ E(P)).encard = (E(P) \\ M).encard - 1 := by\n        apply IH\n        · exact h.toIsAltPath.of_cons\n        · exact h_first\n        · exact h_last\n      simp_all [Set.encard_insert_of_not_mem, h_e_notin_M, h_P_ind]\n  rw [h_inter]\n  simp_all [Nat.add_sub_cancel]",
      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_path : G.IsPath P := h.toIsPath\n  have h_edges : E(P) ⊆ E(G) := h_path.edge_subset\n  have h_match : G.IsMatching M := hM\n  have h_disj : ∀ e ∈ E(P), e ∈ M → e ∉ M ∨ e ∈ M := by\n    intro e he hM_e\n    exact Or.inr hM_e\n  have h_len_odd : Odd P.edge.length := by\n    cases' P with u\n    · contradiction\n    · induction P with\n      | nil => contradiction\n      | cons u e P ih =>\n        cases' P with v\n        · simp_all [WList.edge]\n        · simp_all [WList.edge, List.length]\n          have : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt.of_cons\n          have : Odd P.edge.length := by\n            apply ih\n            assumption\n          omega\n  rw [symmDiff_encard_add, add_comm]\n  have h_inter : (M ∩ E(P)).encard = P.edge.length / 2 := by\n    cases' P with u\n    · contradiction\n    · induction P with\n      | nil => contradiction\n      | cons u e P ih =>\n        cases' P with v\n        · simp_all [WList.edge, Set.encard_empty]\n        · simp_all [WList.edge, Set.encard_insert_of_not_mem]\n          have : e ∈ M ↔ P.edge.head! ∉ M := by\n            simpa using h_alt.head\n          have : (M ∩ E(P)).encard = P.edge.length / 2 := ih (by assumption)\n          cases' this with\n          | inl h_em =>\n            simp_all\n            omega\n          | inr h_nem =>\n            simp_all\n            omega\n  have h_diff : (E(P) \\ M).encard = (P.edge.length + 1) / 2 := by\n    cases' P with u\n    · contradiction\n    · induction P with\n      | nil => contradiction\n      | cons u e P ih =>\n        cases' P with v\n        · simp_all [WList.edge, Set.encard_singleton]\n        · simp_all [WList.edge, Set.encard_insert_of_not_mem]\n          have : e ∈ M ↔ P.edge.head! ∉ M := by\n            simpa using h_alt.head\n          have : (E(P) \\ M).encard = (P.edge.length + 1) / 2 := ih (by assumption)\n          cases' this with\n          | inl h_em =>\n            simp_all\n            omega\n          | inr h_nem =>\n            simp_all\n            omega\n  rw [h_inter, h_diff]\n  omega",
      "\n  have hP : P.Nonempty := h.nonempty\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_path : G.IsPath P := h.toIsPath\n  have h_match : G.IsMatching M := hM\n  have h_edge_disj : ∀ e ∈ E(P), e ∈ M → False := by\n    intro e heM\n    have h_inc : e ∈ E(G, P.first) ∨ e ∈ E(G, P.last) ∨ ∃ v, v ≠ P.first ∧ v ≠ P.last ∧ e ∈ E(G, v) := by\n      apply WList.edge_mem_iff_vertex_inc.1 heM\n      exact h_path.edge_subset heM\n    cases' h_inc with h_inc h_inc\n    · exact h_first (V_inc_iff.2 ⟨e, h_path.edge_subset heM, h_inc⟩)\n    cases' h_inc with h_inc h_inc\n    · exact h_last (V_inc_iff.2 ⟨e, h_path.edge_subset heM, h_inc⟩)\n    obtain ⟨v, hv1, hv2, hv3⟩ := h_inc\n    have h_sub : M ∩ E(G, v).Subsingleton := h_match.subsingleton_inc v\n    have h_v_in_M : v ∈ V(G, M) := ⟨e, heM, hv3⟩\n    have h_v_deg : (M ∩ E(G, v)).encard ≤ 1 := h_match.degree_le_one v\n    have h_v_exact : (M ∩ E(G, v)).encard = 1 := by\n      apply encard_eq_one_of_nonempty_subsingleton\n      exact ⟨e, heM, hv3⟩\n      exact h_sub\n    have h_v_unique : ∀ f ∈ M, f ∈ E(G, v) → f = e := by\n      intro f hfM hf_inc\n      exact Subsingleton.elim h_sub ⟨e, heM, hv3⟩ ⟨f, hfM, hf_inc⟩\n    have h_v_not_end : v ≠ P.first ∧ v ≠ P.last := ⟨hv1, hv2⟩\n    have h_v_internal : ∃ e₁ e₂, e₁ ∈ E(P) ∧ e₂ ∈ E(P) ∧ e₁ ≠ e₂ ∧ e₁ ∈ E(G, v) ∧ e₂ ∈ E(G, v) := by\n      apply WList.internal_vertex_has_two_edges h_path h_v_not_end.1 h_v_not_end.2\n    obtain ⟨e₁, e₂, he₁, he₂, he₁₂, he₁v, he₂v⟩ := h_v_internal\n    have he₁M : e₁ ∈ M ↔ e ∉ M := by\n      apply h_alt.chain_take.1\n      exact List.take_prefix _ _\n    have he₂M : e₂ ∈ M ↔ e ∉ M := by\n      apply h_alt.chain_drop.1\n      exact List.drop_suffix _ _\n    have he₁M' : e₁ ∈ M := by\n      rw [he₁M]\n      exact not_not_intro heM\n    have he₂M' : e₂ ∈ M := by\n      rw [he₂M]\n      exact not_not_intro heM\n    have he₁e₂_disj : Disjoint V(G, e₁) V(G, e₂) := h_match.disjoint he₁M' he₂M' he₁₂\n    have h_v_e₁ : v ∈ V(G, e₁) := he₁v\n    have h_v_e₂ : v ∈ V(G, e₂) := he₂v\n    exact he₁e₂_disj.not_mem_of_mem_left h_v_e₁ h_v_e₂\n  have h_edge_disj' : ∀ e ∈ E(P), e ∉ M := by\n    intro e he\n    exact h_edge_disj e he\n  have h_symmDiff : M ∆ E(P) = M ∪ E(P) := by\n    ext e\n    simp [symmDiff, h_edge_disj']\n  rw [h_symmDiff]\n  have h_disj : Disjoint M E(P) := by\n    intro e heM heP\n    exact h_edge_disj e heP heM\n  rw [encard_union h_disj]\n  have h_path_len : E(P).encard = P.length := by\n    rw [← WList.length_eq_encard_edgeSet]\n  have h_odd : Odd P.length := by\n    apply WList.alt_path_length_odd h_alt h_first h_last\n  have h_len_pos : 0 < P.length := by\n    apply Nat.pos_of_ne_zero\n    intro h_len_zero\n    rw [h_len_zero] at hP\n    exact WList.nonempty_of_length_pos (by simp) hP\n  have h_len_succ : P.length = 2 * (P.length / 2) + 1 := by\n    apply Nat.odd_iff.mp h_odd\n  have h_encard_E : E(P).encard = 2 * (P.length / 2) + 1 := by\n    rw [h_path_len, h_len_succ]\n  have h_encard_half : (E(P) ∩ M).encard = 0 := by\n    apply encard_eq_zero_of_forall_not_mem\n    intro e he\n    exact h_edge_disj e he.2 he.1\n  have h_encard_diff : (M ∆ E(P)).encard = M.encard + E(P).encard := by\n    rw [h_symmDiff, encard_union h_disj]\n  rw [h_encard_diff]\n  have h_final : E(P).encard = 1 := by\n    have h_min : P.length ≥ 1 := by\n      apply Nat.succ_le_iff.mpr\n      exact h_len_pos\n    have h_min' : P.length = 1 := by\n      apply Nat.le_antisymm h_min\n      apply Nat.le_of_lt_succ\n      have h_alt_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt\n      have h_alt_chain' : P.edge.length ≤ 1 := by\n        apply List.isChain_length_le_one\n        intro e f hef\n        have h_not_both : ¬(e ∈ M ∧ f ∈ M) := by\n          intro h_both\n          have h_disj := h_match.disjoint h_both.1 h_both.2 hef\n          have h_inc_e : e ∈ E(G, P.first) ∨ e ∈ E(G