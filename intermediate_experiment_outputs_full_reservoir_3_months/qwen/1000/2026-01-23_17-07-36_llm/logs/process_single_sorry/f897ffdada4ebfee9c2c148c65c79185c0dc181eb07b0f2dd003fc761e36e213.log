lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.toIsAltPath.mem_matching_iff
  have h_nonempty : P.Nonempty := h.nonempty
  have h_first : P.first ∉ V(G, M) := h.first_not_in
  have h_last : P.last ∉ V(G, M) := h.last_not_in
  have h_path : G.IsPath P := h.toIsAltPath.toIsPath
  have h_trail : G.IsTrail P := h_path.isTrail
  have h_nodup : P.edge.Nodup := h_trail.edge_nodup
  have h_edges : E(P) = P.edgeSet := rfl
  rw [← h_edges]
  have h_odd : Odd P.edge.length := by
    cases' P with u
    · contradiction
    · induction' P with v e w ih
      · simp_all
      · cases' w with x
        · simp_all
        · simp_all [List.length, Nat.succ_eq_add_one]
  have h_diff : (M ∆ P.edgeSet).encard = M.encard + P.edgeSet.encard - 2 * (M ∩ P.edgeSet).encard := by
    rw [symmDiff_encard, add_comm]
  have h_match_inter : (M ∩ P.edgeSet).encard = P.edgeSet.encard / 2 := by
    have h_alt_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt
    have h_start : P.edge.head? ≠ none := by
      cases' h_nonempty with e he
      exact Option.some_ne_none
    cases' P.edge with e es
    · simp_all
    · simp_all [List.IsChain, List.head?, List.tail]
      have h_even_or_odd : Even (P.edge.length) ∨ Odd (P.edge.length) := by
        apply Nat.even_or_odd
      cases' h_even_or_odd with h_even h_odd
      · exfalso
        have h_end_in_M : P.last ∈ V(G, M) := by
          sorry
        contradiction
      · simp_all [Nat.odd_iff_not_even, Nat.even_iff]
        omega
  rw [h_diff, h_match_inter]
  have h_len : P.edgeSet.encard = P.edge.length := by
    rw [← List.toFinset_card_of_nodup h_nodup]
    simp [Set.encard_eq_finset_card]
  rw [h_len]
  have h_odd_len : Odd P.edge.length := h_odd
  have h_val : P.edge.length = 2 * (P.edge.length / 2) + 1 := by
    rw [Nat.two_mul, Nat.add_comm]
    exact Nat.mod_add_div P.edge.length 2 |>.symm |>.trans (congrArg _ (Nat.mod_two_of_odd h_odd))
  rw [h_val]
  ring
