      "\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.toIsAltPath.mem_matching_iff\n  have h_first : P.first ∉ V(G, M) := h.first_not_in\n  have h_last : P.last ∉ V(G, M) := h.last_not_in\n  have h_nonempty : P.Nonempty := h.nonempty\n  have h_path : G.IsPath P := h.toIsAltPath.toIsPath\n  have h_trail : G.IsTrail P := h_path.isTrail\n  have h_nodup : P.edge.Nodup := h_trail.edge_nodup\n  have h_edges : E(P) = P.edge.toFinset := by\n    ext e\n    simp [edgeSet_eq_edge_toFinset]\n  rw [h_edges]\n  clear h_edges\n  have h_symmDiff : M ∆ P.edge.toFinset = (M \\ P.edge.toFinset) ∪ (P.edge.toFinset \\ M) := by\n    ext x\n    simp [symmDiff, Set.mem_union, Set.mem_diff]\n  rw [h_symmDiff]\n  have h_disjoint : Disjoint (M \\ P.edge.toFinset) (P.edge.toFinset \\ M) := by\n    apply Disjoint.symm\n    apply Disjoint.diff_right\n  rw [encard_union h_disjoint]\n  have h_encard_diff : (M \\ P.edge.toFinset).encard = M.encard - (M ∩ P.edge.toFinset).encard := by\n    rw [encard_diff_inter]\n  have h_encard_diff' : (P.edge.toFinset \\ M).encard = P.edge.toFinset.encard - (M ∩ P.edge.toFinset).encard := by\n    rw [encard_diff_inter]\n  rw [h_encard_diff, h_encard_diff']\n  have h_match_edges : (M ∩ P.edge.toFinset).encard = P.edge.toFinset.encard / 2 := by\n    have h_alt_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt\n    have h_start_not_in : P.edge.head? ≠ none → P.edge.headD ∉ M := by\n      intro h_head\n      have h_first_edge : ∃ v, G.Adj P.first (P.edge.headD) v := by\n        cases P with\n        | nil => contradiction\n        | cons u e w => simp_all\n      have h_first_not_incident : P.first ∉ V(G, M) := h_first\n      have h_first_not_in_M : P.edge.headD ∉ M := by\n        intro hM_head\n        have h_incident : P.first ∈ V(G, P.edge.headD) := (G.adj_mk (by aesop)).left_mem\n        have h_in_M : P.first ∈ V(G, M) := ⟨hM_head, P.first, h_incident⟩\n        contradiction\n      exact h_first_not_in_M\n    have h_alternating : ∀ (e f : β), e ∈ P.edge.toFinset → f ∈ P.edge.toFinset → e ≠ f → (e ∈ M ↔ f ∉ M) := by\n      intro e f he hf hne\n      have h_chain : P.edge.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h_alt\n      have h_adjacent : ∃ l₁ l₂, P.edge = l₁ ++ e :: f :: l₂ ∨ P.edge = l₁ ++ f :: e :: l₂ := by\n        apply List.nodup_pairwise_adjacent_of_mem h_nodup\n        simp_all\n      cases h_adjacent with\n      | inl h_split =>\n        cases h_split with\n        | intro l₁ l₂ h_eq =>\n          rw [h_eq] at h_chain\n          simp_all [List.isChain_append, List.isChain_cons_cons]\n      | inr h_split =>\n        cases h_split with\n        | intro l₁ l₂ h_eq =>\n          rw [h_eq] at h_chain\n          simp_all [List.isChain_append, List.isChain_cons_cons]\n    have h_odd_length : Odd P.edge.length := by\n      have h_endpoints_not_covered : P.first ∉ V(G, M) ∧ P.last ∉ V(G, M) := ⟨h_first, h_last⟩\n      have h_path_length : P.edge.length = (P.length - 1) := by\n        cases P with\n        | nil => contradiction\n        | cons u e w => simp_all\n      have h_vertices : P.length = P.edge.length + 1 := by\n        cases P with\n        | nil => contradiction\n        | cons u e w => simp_all\n      have h_unmatched_endpoints : ¬(P.first ∈ V(G, M)) ∧ ¬(P.last ∈ V(G, M)) := ⟨h_first, h_last⟩\n      have h_matching_edges : ∀ e ∈ P.edge.toFinset, e ∈ M → ∃! v ∈ V(G, e), v ∈ V(G, M) := by\n        intro e he hM_e\n        have h_edge_in_G : e ∈ E(G) := hM.subset hM_e\n        have h_vertices_e : V(G, e).encard ≤ 2 := by\n          apply G.edgeVertexFinite.encard_le_two\n        cases h_vertices_e with\n        | le_of_eq h_eq =>\n          have h_loop : V(G, e).encard = 1 := h_eq\n          have h_vertex : ∃ v, V(G, e) = {v} := by\n            apply encard_eq_one.1\n            exact h_loop\n          cases h_vertex with\n          | intro v hv =>\n            have h_v_in_M : v ∈ V(G, M) := ⟨hM_e, v, by simp [hv]⟩\n            use v\n            constructor\n            · simp [hv]\n              exact h_v_in_M\n            · intro w hw\n              simp [hv] at hw\n              aesop\n        | le_of_lt h_lt =>\n          have h_two_vertices : V(G, e).encard = 2 := by\n            apply Nat.eq_of_le_of_lt_succ\n            exact h_lt\n          have h_vertices_pair : ∃ v w, v ≠ w ∧ V(G, e) = {v, w} := by\n            apply encard_eq_two.1\n            exact h_two_vertices\n          cases h_vertices_pair with\n          | intro v hv =>\n            cases hv with\n            | intro w hw =>\n              cases hw with\n              | intro h_ne hV =>\n                have h_v_or_w_in_M : v ∈ V(G, M) ∨ w ∈ V(G, M) := by\n                  apply Or.intro_left\n                  use hM_e, v\n                  simp [hV]\n                cases h_v_or_w_in_M with\n                | inl h_v_in_M =>\n                  use v\n                  constructor\n                  · simp [hV]\n                    exact h_v_in_M\n                  · intro x hx\n                    simp [hV] at hx\n                    cases hx with\n                    | inl h_x_eq_v => subst h_x_eq_v; rfl\n                    | inr h_x_eq_w =>\n                      have h_w_not_in_M : w ∉ V(G, M) := by\n                        intro h_w_in_M\n                        have h_disjoint : Disjoint V(G, e) V(G, e) := hM.disjoint hM_e hM_e (by aesop)\n                        have h_empty : V(G, e) = ∅ := by\n                          apply Disjoint.eq_empty_of_subset_right\n                          exact h_disjoint\n                          simp [hV]\n                        contradiction\n                      contradiction\n                | inr h_w_in_M =>\n                  use w\n                  constructor\n                  · simp [hV]\n                    exact h_w_in_M\n                  · intro x hx\n                    simp [hV] at hx\n                    cases hx with\n                    | inl h_x_eq_v =>\n                      have h_v_not_in_M : v ∉ V(G, M) := by\n     