      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_sSup_of_mem (by use M; exact ⟨hM, rfl⟩))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp_all [Set.mem_diff, Set.mem_sep]\n      · intro e f he hf hne\n        apply (hM.disjoint he.1 hf.1 hne)\n    calc\n      ν(G) = M.encard := rfl\n      _ ≤ M'.encard + Y.encard := by\n        have : M ⊆ M' ∪ E(G, Y) := by\n          intro e he\n          by_cases h : e ∈ E(G, Y)\n          · right; exact h\n          · left; simp_all\n        calc\n          M.encard ≤ (M' ∪ E(G, Y)).encard := encard_mono this\n          _ ≤ M'.encard + E(G, Y).encard := encard_union_le\n          _ ≤ M'.encard + Y.encard := by\n            -- Each edge in E(G, Y) is incident to at least one vertex in Y\n            -- and since G is finite, we can bound the number of such edges\n            -- but actually we only need that |E(G,Y)| ≤ |Y| * Δ, however\n            -- a simpler approach: note that in any matching, each vertex\n            -- in Y can be incident to at most one edge, so |M ∩ E(G,Y)| ≤ |Y|\n            -- But here we are not restricting to matchings, so we need another way.\n            -- Actually, we don't need this general bound. Instead, observe:\n            -- The number of edges in M that are removed is at most |Y|,\n            -- because each vertex in Y can be incident to at most one edge in M\n            -- (since M is a matching).\n            have : (M ∩ E(G, Y)).encard ≤ Y.encard := by\n              calc\n                (M ∩ E(G, Y)).encard ≤ Y.encard := by\n                  -- Map each edge in M ∩ E(G, Y) to one of its endpoints in Y\n                  -- This map is injective because M is a matching\n                  apply encard_le_encard_of_injective\n                  · intro e he\n                    obtain ⟨v, hv⟩ := he.2\n                    exact