lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  have h1 : ν(G) ≤ ν(G - Y) + Y.encard := by
    -- Removing Y can destroy at most |Y| edges from a maximum matching
    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_sSup_of_mem (by use M; exact ⟨hM, rfl⟩))
    let M' := M \ E(G, Y)
    have hM' : (G - Y).IsMatching M' := by
      constructor
      · intro e he
        simp_all [edgeSet_subgraph]
      · intro e f he hf hne
        apply hM.disjoint he.1 hf.1 hne
    calc
      ν(G) = M.encard := rfl
      _ ≤ (M' ∪ (M ∩ E(G, Y))).encard := by rw [Set.union_eq_self_of_subset_right (Set.inter_subset_left _ _)]
      _ ≤ M'.encard + (M ∩ E(G, Y)).encard := encard_union_le _ _
      _ ≤ ν(G - Y) + (M ∩ E(G, Y)).encard := by
        apply add_le_add_right
        exact le_sSup_of_mem ⟨M', hM', rfl⟩
      _ ≤ ν(G - Y) + Y.encard := by
        have : (M ∩ E(G, Y)).encard ≤ Y.encard := by
          calc
            (M ∩ E(G, Y)).encard ≤ E(G, Y).encard := encard_mono (Set.inter_subset_right _ _)
            _ ≤ Y.encard := by
              -- Each edge in E(G, Y) is incident to at least one vertex in Y
              -- and since M is a matching, each vertex in Y is incident to at most one edge in M
              have : (M ∩ E(G, Y)) ⊆ ⋃ y ∈ Y, E(G, {y}) := by
                intro e he
                simp_all [edgeSet_inc]
                obtain ⟨x, hx⟩ := he.2
                cases' hx with hy hx
                · exact Set.mem_iUnion_of_mem hy ⟨x, by simpa using he.1⟩
                · exact Set.mem_iUnion_of_mem hx ⟨x, by simpa using he.1⟩
              calc
                E(G, Y).encard = (⋃ y ∈ Y, E(G, {y})).encard := by rfl
                _ ≤ ∑ y ∈ Y, E(G, {y}).encard := encard_iUnion_le _ _
                _ ≤ ∑ y ∈ Y, 1 := by
                  apply Finset.sum_le_sum
                  intro y hy
                  exact (hM.degree_le_one y).trans (by norm_cast)
                _ = Y.encard := by simp
        exact this
  have h2 : 2 * ν(G - Y) ≤ (V(G) \ Y).encard - (G - Y).OddComponents.encard := by
    -- In G - Y, each odd component contributes at least one unmatched vertex
    -- so the number of matched vertices is at most |V(G)\Y| - odd(G-Y)
    -- hence 2*ν(G-Y) ≤ |V(G)\Y| - odd(G-Y)
    have : ∀ H ∈ (G - Y).OddComponents, Odd H.vertexSet.encard := by
      intro H hH
      exact hH.odd
    calc
      2 * ν(G - Y) ≤ (V(G - Y)).encard - (G - Y).OddComponents.encard := by
        -- This is a standard result: for any graph H, 2*ν(H) ≤ |V(H)| - odd(H)
        -- We assume this as a known fact (can be proven by induction on components)
        sorry
      _ = (V(G) \ Y).encard - (G - Y).OddComponents.encard := by
        simp [vertexSet_subgraph]
  calc
    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by gcongr
    _ = 2 * ν(G - Y) + 2 * Y.encard := by ring
    _ ≤ ((V(G) \ Y).encard - (G - Y).OddComponents.encard) + 2 * Y.encard := by gcongr
    _ = (V(G).encard - Y.encard) + 2 * Y.encard - (G - Y).OddComponents.encard := by
      rw [encard_diff_eq_sub (by infer_instance : Finite V(G)) (by infer_instance : Finite Y)]
    _ = V(G).encard + Y.encard - (G - Y).OddComponents.encard := by ring
