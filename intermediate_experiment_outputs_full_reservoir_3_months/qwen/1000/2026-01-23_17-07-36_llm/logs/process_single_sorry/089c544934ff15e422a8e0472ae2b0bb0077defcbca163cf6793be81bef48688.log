      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_csupr (by simp) ⟨M, hM, rfl⟩)\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp only [Set.mem_diff, Set.mem_preimage, Set.mem_compl_iff] at he\n        exact (hM.subset he.1) (by simp [he.2])\n      · intro e f he hf hne\n        apply hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := (IsMaxMatching.encard (by assumption)).symm\n      _ ≤ M'.encard + Y.encard := by\n        have : M ⊆ M' ∪ E(G, Y) := by\n          intro e he\n          by_cases h : e ∈ E(G, Y)\n          · right; exact h\n          · left; simp [h, Set.mem_diff, he]\n        calc\n          M.encard ≤ (M' ∪ E(G, Y)).encard := encard_mono this\n          _ ≤ M'.encard + E(G, Y).encard := encard_union_le\n          _ ≤ M'.encard + Y.encard := by\n            -- Each edge in E(G, Y) is incident to at least one vertex in Y\n            -- and since M is a matching, each vertex in Y is incident to at most one edge in M\n            -- so |E(G, Y) ∩ M| ≤ |Y|\n            have : (E(G, Y) ∩ M).encard ≤ Y.encard := by\n              calc\n                (E(G, Y) ∩ M).encard ≤ Y.encard := by\n                  apply encard_le_of_injective\n                  · intro v _\n                    exact v\n                  · intro v hv w hw h\n                    simp_all\n                    -- If two edges in M are incident to the same vertex in Y,\n                    -- they would share a vertex, contradicting M being a matching\n                    have hv' : v ∈ V(G, M) := by\n                      obtain ⟨e, he, hev⟩ := hv\n                      exact ⟨e, he.1, hev⟩\n                    have hw' : w ∈ V(G, M) := by\n                      obtain ⟨e, he, hew⟩ := hw\n                      exact ⟨e, he.1, hew⟩\n                    -- But we don't need this level of detail; we can use:\n                    sorry\n            sorry\n      _ ≤ ν(G - Y) + Y.encard := by\n        apply add_le_add_right\n        apply le_of_eq\n        rw [MatchingNumber_def]\n        apply csupr_ge\n        exact ⟨M', hM', rfl⟩\n  have h2 : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    -- In G - Y, each odd component must have at least one unmatched vertex\n    -- So the number of matched vertices is at most |V(G - Y)| - odd(G - Y)\n    -- Hence 2 * ν(G - Y) ≤ |V(G - Y)| - odd(G - Y)\n    sorry\n  calc\n    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by gcongr\n    _ = 2 * ν(G - Y) + 2 * Y.encard := by ring\n    _ ≤ ((V(G) \\ Y).encard - (G - Y).OddComponents.encard) + 2 * Y.encard := by gcongr\n    _ = (V(G).encard - Y.encard) - (G - Y).OddComponents.encard + 2 * Y.encard := by\n      rw [Set.encard_diff_eq_sub (Set.encard_mono (Set.subset_union_left _ _))]\n    _ = V(G).encard + Y.encard - (G - Y).OddComponents.encard := by ring",
