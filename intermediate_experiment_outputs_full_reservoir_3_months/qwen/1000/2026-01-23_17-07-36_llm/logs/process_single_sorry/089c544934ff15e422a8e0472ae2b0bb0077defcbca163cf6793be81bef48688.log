lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  have h1 : ν(G) ≤ ν(G - Y) + Y.encard := by
    -- Removing Y can destroy at most |Y| edges from a maximum matching
    obtain ⟨M, hM, rfl⟩ := Classical.choose_spec (sSup_mem (hne := by
      use ∅; simp))
    have h2 : M.encard ≤ ν(G - Y) + (M ∩ E(G, Y)).encard := by
      -- Split matching into edges incident to Y and not
      have h3 : M = (M ∩ E(G - Y)) ∪ (M ∩ E(G, Y)) := by
        ext e; simp [Set.mem_union, Set.mem_inter_iff, edgeSet_diff]
      rw [h3, encard_union_le]
      refine le_add_of_le_left ?_
      exact encard_mono (by simp [edgeSet_diff])
    have h4 : (M ∩ E(G, Y)).encard ≤ Y.encard := by
      -- Each edge in M ∩ E(G, Y) is incident to a distinct vertex in Y (matching property)
      calc
        (M ∩ E(G, Y)).encard ≤ ∑ y in Y, (M ∩ E(G, y)).encard := by
          apply encard_le_sum_encard_inter_fiber
        _ ≤ ∑ y in Y, 1 := by
          apply Finset.sum_le_sum
          intro y _
          exact (hM.degree_le_one y)
        _ = Y.encard := by simp
    calc
      ν(G) = M.encard := by rw [← hM.encard]
      _ ≤ ν(G - Y) + Y.encard := by linarith
  have h2 : 2 * ν(G - Y) ≤ (V(G) \ Y).encard - (G - Y).OddComponents.encard := by
    -- In G - Y, each odd component contributes at least one unmatched vertex
    sorry
  calc
    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by gcongr
    _ = 2 * ν(G - Y) + 2 * Y.encard := by ring
    _ ≤ ((V(G) \ Y).encard - (G - Y).OddComponents.encard) + 2 * Y.encard := by linarith
    _ = (V(G).encard - Y.encard) - (G - Y).OddComponents.encard + 2 * Y.encard := by
        rw [encard_diff_eq_sub (by infer_instance)]
    _ = V(G).encard + Y.encard - (G - Y).OddComponents.encard := by ring
