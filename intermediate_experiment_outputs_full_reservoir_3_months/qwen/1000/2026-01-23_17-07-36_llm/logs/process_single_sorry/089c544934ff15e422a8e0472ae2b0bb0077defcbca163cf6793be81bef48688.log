      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_csupr (by simp) ν(G))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp only [Set.mem_diff, Set.mem_inter_iff] at he\n        exact hM.subset he.1\n      · intro e f he hf hne\n        simp only [Set.mem_diff, Set.mem_inter_iff] at he hf\n        exact hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := by rw [MatchingNumber_def.mp (le_csupr (by simp) ν(G))]\n      _ ≤ M'.encard + Y.encard := by\n        have : M ⊆ M' ∪ E(G, Y) := by\n          intro e he\n          by_cases h : e ∈ E(G, Y)\n          · right; exact h\n          · left; simp [h]\n        calc\n          M.encard ≤ (M' ∪ E(G, Y)).encard := encard_mono this\n          _ ≤ M'.encard + E(G, Y).encard := encard_union_le _ _\n          _ ≤ M'.encard + Y.encard := by\n            -- Each edge in E(G, Y) is incident to at least one vertex in Y,\n            -- and since M is a matching, each vertex in Y is incident to at most one edge in M.\n            -- So |E(G, Y) ∩ M| ≤ |Y|, but here we have E(G, Y) not intersected with M,\n            -- however we can use that the number of edges incident to Y is at most |Y| * Δ,\n            -- but actually for the inequality ν(G) ≤ ν(G-Y) + |Y|, we can argue directly:\n            -- In any matching, at most |Y| edges are incident to Y, so removing Y removes at most |Y| edges.\n            -- Hence |M| ≤ |M'| + |Y|.\n            -- To formalize: the map from M \\ M' to Y sending an edge to one of its endpoints in Y is injective.\n            sorry\n      _ ≤ ν(G - Y) + Y.encard := by\n        refine add_le_add_right ?_ _\n        exact le_csupr (by simp) ν(G - Y)\n  have h2 : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    -- In G - Y, each odd component must have at least one unmatched vertex,\n    -- so the number of matched vertices is at most |V(G)\\Y| - odd(G-Y),\n    -- hence 2*ν(G-Y) ≤ |V(G)\\Y| - odd(G-Y).\n    sorry\n  calc\n    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by gcongr\n    _ = 2 * ν(G - Y) + 2 * Y.encard := by ring\n    _ ≤ ((V(G) \\ Y).encard - (G - Y).OddComponents.encard) + 2 * Y.encard := by gcongr\n    _ = (V(G).encard - Y.encard) - (G - Y).OddComponents.encard + 2 * Y.encard := by\n      rw [encard_diff_eq_sub_of_subset (Set.diff_subset _ _)]\n    _ = V(G).encard + Y.encard - (G - Y).OddComponents.encard := by ring",
      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_sSup_of_mem (by use M; exact ⟨hM, rfl⟩))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp only [Set.mem_diff, Set.mem_preimage, Set.mem_compl_iff] at he\n        exact (hM.subset he.1) |>.of_not_mem_inc_left he.2\n      · intro e he f hf hne\n        apply hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := rfl\n      _ ≤ M'.encard + Y.encard := by\n        have : M ⊆ M' ∪ E(G, Y) := by\n          intro e he\n          by_cases h : e ∈ E(G, Y)\n          · right; exact h\n          · left; simp [Set.mem_diff, h]\n        calc\n          M.encard ≤ (M' ∪ E(G, Y)).encard := encard_mono this\n          _ ≤ M'.encard + E(G, Y).encard := encard_union_le\n          _ ≤ M'.encard + Y.encard := by\n            refine add_le_add_left ?_ _\n            exact (encard_inc_le_encard_vertex G Y)\n      _ ≤ ν(G - Y) + Y.encard := by\n        refine add_le_add_right ?_ _\n        exact le_sSup (by use M'; exact ⟨hM', rfl⟩)\n  have h2 : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    -- In G - Y, each odd component contributes at least one unmatched vertex\n    sorry\n  calc\n    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by gcongr\n    _ = 2 * ν(G - Y) + 2 * Y.encard := by ring\n    _ ≤ ((V(G) \\ Y).encard - (G - Y).OddComponents.encard) + 2 * Y.encard := by gcongr\n    _ = (V(G).encard - Y.encard) - (G - Y).OddComponents.encard + 2 * Y.encard := by\n      rw [encard_diff_eq_sub (G.Finite.vertexSet) (Set.encard_le_encard Y V(G))]\n    _ = V(G).encard + Y.encard - (G - Y).OddComponents.encard := by ring",
      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_sSup_of_mem (by use M; exact ⟨hM, rfl⟩))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp only [Set.mem_diff, Set.mem_inter_iff] at he\n        exact (hM.subset he.1).trans (by simp [edgeSet_sub])\n      · intro e f he hf hne\n        simp only [Set.mem_diff, Set.mem_inter_iff] at he hf\n        exact hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := rfl\n      _ ≤ (M'.encard + (M ∩ E(G, Y)).encard) := by\n        rw [← encard_union_add_encard_inter]\n        apply le_of_eq\n        ext e\n        simp only [Set.mem_diff, Set.mem_union, Set.mem_inter_iff, not_and_or]\n        tauto\n      _ ≤ ν(G - Y) + Y.encard := by\n        refine add_le_add (le_sSup_of_mem ⟨M', hM', rfl⟩) ?_\n        calc\n          (M ∩ E(G, Y)).encard ≤ E(G, Y).encard := encard_mono (Set.inter_subset_right _ _)\n          _ ≤ Y.encard := by\n            apply encard_le_of_injective\n            intro e he\n            obtain ⟨v, hv⟩ := edgeIncidence.mp he\n            exact v\n            intro e f he hf h\n            simp only [edgeIncidence, Set.mem_setOf_eq] at he hf\n            obtain ⟨⟨u, hu⟩, ⟨v, hv⟩⟩ := he\n            obtain ⟨⟨u', hu'⟩, ⟨v', hv'⟩⟩ := hf\n            simp_all\n  have h2 : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    -- In G - Y, each odd component leaves at least one vertex unmatched\n    sorry\n  calc\n    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by gcongr\n    _ = 2 * ν(G - Y) + 2 * Y.encard := by ring\n    _ ≤ ((V(G) \\ Y).encard - (G - Y).OddComponents.encard) + 2 * Y.encard := by gcongr\n    _ = (V(G).encard - Y.encard) + 2 * Y.encard - (G - Y).OddComponents.encard := by\n      rw [encard_diff_eq_sub (Set.encard_mono (Set.subset_union_left _ _))]\n    _ = V(G).encard + Y.encard - (G - Y).OddComponents.encard := by 