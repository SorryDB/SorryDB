      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_csupr (by simp) ν(G))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp_all [Set.mem_diff, Set.mem_inter_iff]\n      · intro e f he hf hne\n        apply hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := rfl\n      _ ≤ M'.encard + (M ∩ E(G, Y)).encard := by\n        rw [← encard_union_add_encard_inter (by simp : Disjoint M' (M ∩ E(G, Y)))]\n        exact le_of_eq (encard_union_of_disjoint (by simp : Disjoint M' (M ∩ E(G, Y))))\n      _ ≤ ν(G - Y) + (M ∩ E(G, Y)).encard := by\n        gcongr\n        exact le_csupr (by simp) _\n      _ ≤ ν(G - Y) + Y.encard := by\n        calc\n          (M ∩ E(G, Y)).encard ≤ E(G, Y).encard := encard_mono (by simp)\n          _ ≤ Y.encard := by\n            -- Each edge in E(G, Y) is incident to at least one vertex in Y,\n            -- and since G is finite, we can bound the number of such edges\n            -- by the number of vertices in Y (though this is not tight, it suffices)\n            -- However, a better bound: each edge in M ∩ E(G, Y) is incident to exactly one vertex in Y\n            -- because M is a matching, so the number of such edges is at most |Y|\n            have : (M ∩ E(G, Y)).encard ≤ Y.encard := by\n              apply encard_le_of_injective\n              · intro e he\n                obtain ⟨v, hv⟩ := mem_E_inc.mp (he.2)\n                use v\n                simp_all\n              · intro e f he hf h\n                obtain ⟨v, hv⟩ := mem_E_inc.mp (he.2)\n                obtain ⟨w, hw⟩ := mem_E_inc.mp (hf.2)\n                have : v = w := by\n                  apply hM.subsingleton_inc v\n                  · exact he.1\n                  · exact hf.1\n                  · intro hne\n                    exact (hM.disjoint he.1 hf.1 hne).le_bot ⟨hv.2, hw.2⟩\n                simp_all\n 