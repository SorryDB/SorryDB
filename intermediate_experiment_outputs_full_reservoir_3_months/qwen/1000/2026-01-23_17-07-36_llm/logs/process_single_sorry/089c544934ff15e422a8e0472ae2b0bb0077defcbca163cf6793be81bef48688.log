                  · right; exact ⟨he, h⟩
                  · left; simp_all
                · rintro (he | ⟨he, h⟩)
                  · exact he
                  · exact he
              _ ≤ M'.encard + (M ∩ E(G, Y)).encard := encard_union_le
              _ ≤ M'.encard + Y.encard := add_le_add_left this _
      _ ≤ ν(G - Y) + Y.encard := by
