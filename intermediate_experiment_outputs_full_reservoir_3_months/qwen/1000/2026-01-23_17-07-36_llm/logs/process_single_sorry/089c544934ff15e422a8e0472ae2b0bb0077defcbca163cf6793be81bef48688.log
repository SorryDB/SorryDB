      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_of_eq (MatchingNumber_def.mpr ⟨ν(G), ⟨M, hM, rfl⟩⟩))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp_all [Set.mem_diff, Set.mem_sep]\n      · intro e he f hf hne\n        exact hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := rfl\n      _ ≤ M'.encard + Y.encard := by\n        have : M ⊆ M' ∪ E(G, Y) := by\n          intro e he\n          by_cases h : e ∈ E(G, Y)\n          · right; exact h\n          · left; simp [h, Set.mem_diff, he]\n        calc\n          M.encard ≤ (M' ∪ E(G, Y)).encard := encard_mono this\n          _ ≤ M'.encard + E(G, Y).encard := encard_union_le\n          _ ≤ M'.encard + Y.encard := by\n            -- Each edge in E(G, Y) is incident to at least one vertex in Y,\n            -- and since M is a matching, each vertex in Y is incident to at most one edge in M.\n            -- So |E(G, Y) ∩ M| ≤ |Y|, but here we have E(G, Y) not intersected with M.\n            -- However, we only need an upper bound, and |E(G, Y)| could be large.\n            -- Instead, note that the number of edges in M incident to Y is at most |Y|,\n            -- so |M| ≤ |M'| + |Y|.\n            -- But M' = M \\ E(G, Y), so M = M' ∪ (M ∩ E(G, Y)), disjoint union.\n            -- Thus |M| = |M'| + |M ∩ E(G, Y)| ≤ |M'| + |Y|.\n            sorry\n      _ ≤ ν(G - Y) + Y.encard := by\n        apply add_le_add_right\n        exact IsMatching.encard_le hM'\n  have h2 : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    -- In G - Y, each odd component must have at least one unmatched vertex in any matching.\n    -- So the number of matched vertices is at most |V(G - Y)| - odd(G - Y).\n    -- Since each edge matches two vertices, 2 * ν(G - Y) ≤ |V(G - Y)| - odd(G - Y).\n    sorry\n  calc\n    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := b