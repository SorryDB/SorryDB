      _ ≤ M'.encard + (M ∩ E(G, Y)).encard := by
        rw [← encard_union_add_encard_inter (Set.subset_union_left _ _)]
        exact le_rfl
      _ ≤ ν(G - Y) + Y.encard := by
        refine add_le_add (le_csupr (Set.nonempty_of_mem ⟨M', hM'⟩) ⟨M', hM'⟩) ?_
