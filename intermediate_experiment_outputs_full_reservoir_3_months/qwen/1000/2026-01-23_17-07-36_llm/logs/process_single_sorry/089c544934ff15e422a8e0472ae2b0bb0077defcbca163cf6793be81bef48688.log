      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_sSup_of_mem (by use M; exact ⟨hM, rfl⟩) (by rfl))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp only [Set.mem_diff, Set.mem_inter_iff] at he\n        exact (hM.subset he.1).trans (by simp [edgeSet_sub])\n      · intro e f he hf hne\n        apply hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := rfl\n      _ ≤ (M' ∪ (M ∩ E(G, Y))).encard := by rw [Set.union_diff_cancel hM.subset]\n      _ ≤ M'.encard + (M ∩ E(G, Y)).encard := encard_union_le _ _\n      _ ≤ ν(G - Y) + (M ∩ E(G, Y)).encard := by\n        apply add_le_add_right\n        exact le_sSup_of_mem (by use M'; exact ⟨hM', rfl⟩) (by rfl)\n      _ ≤ ν(G - Y) + Y.encard := by\n        have : (M ∩ E(G, Y)).encard ≤ Y.encard := by\n          calc\n            (M ∩ E(G, Y)).encard ≤ E(G, Y).encard := encard_mono (Set.inter_subset_right _ _)\n            _ ≤ Y.encard := by\n              apply encard_le_of_injective\n              rintro e ⟨v, hv⟩\n              exact v\n              rintro e₁ ⟨v₁, hv₁⟩ e₂ ⟨v₂, hv₂⟩ he\n              have := hM.subsingleton_inc v₁\n              have := hM.subsingleton_inc v₂\n              simp_all\n        exact this\n  have h2 : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    -- In G - Y, each odd component contributes at least one unmatched vertex\n    sorry\n  calc\n    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := by gcongr\n    _ = 2 * ν(G - Y) + 2 * Y.encard := by ring\n    _ ≤ ((V(G) \\ Y).encard - (G - Y).OddComponents.encard) + 2 * Y.encard := by gcongr\n    _ = (V(G).encard - Y.encard) + 2 * Y.encard - (G - Y).OddComponents.encard := by\n      rw [encard_diff_eq_encard_sub_encard (Set.finite_subset G.finite_vertexSet (Set.diff_subset _ _))]\n    _ = V(G).encard + Y.encard - (G - Y).OddComponents.encard := by ring",
      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_csupr (Set.nonempty_of_mem ⟨∅, by simp⟩) (ν(G)))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp_all [edgeSet_subgraph_diff]\n      · intro e f he hf hne\n        apply hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := by rw [MatchingNumber_def] at *; aesop\n      _ ≤ M'.encard + Y.encard := by\n        have : M ⊆ M' ∪ E(G, Y) := by\n          intro e he\n          by_cases h : e ∈ E(G, Y)\n          · right; exact h\n          · left; simp_all\n        calc\n          M.encard ≤ (M' ∪ E(G, Y)).encard := encard_mono this\n          _ ≤ M'.encard + E(G, Y).encard := encard_union_le\n          _ ≤ M'.encard + Y.encard := by\n            -- Each edge in E(G, Y) is incident to at least one vertex in Y\n            -- and since G is finite, we can bound the number of such edges\n            -- but actually we only need that |E(G,Y)| ≤ |Y| * Δ, however\n            -- a simpler approach: note that in any matching, |M ∩ E(G,Y)| ≤ |Y|\n            -- but here we are not assuming M is a matching for the bound on E(G,Y)\n            -- However, observe that for the purpose of this inequality,\n            -- we can use that in the worst case, each vertex in Y can be incident\n            -- to many edges, but we don't need a tight bound here because:\n            -- Actually, reconsider: the standard argument is that removing Y\n            -- can remove at most |Y| edges from a matching, so |M| ≤ |M'| + |Y|\n            -- which is what we want. So we should argue directly on the matching.\n            sorry\n      _ ≤ ν(G - Y) + Y.encard := by\n        apply add_le_add_right\n        apply le_of_eq\n        rw [MatchingNumber_def]\n        apply csupr_ge\n        use M', hM'\n  have h2 : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard :=