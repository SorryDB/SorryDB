      "\n    -- Removing Y can destroy at most |Y| edges from a maximum matching\n    obtain ⟨M, hM, rfl⟩ := MatchingNumber_def.mp (le_csupr (by simp) ν(G))\n    let M' := M \\ E(G, Y)\n    have hM' : (G - Y).IsMatching M' := by\n      constructor\n      · intro e he\n        simp only [Set.mem_diff, Set.mem_inter_iff] at he\n        exact (hM.subset he.1) (by simp [he.2])\n      · intro e f he hf hne\n        apply hM.disjoint he.1 hf.1 hne\n    calc\n      ν(G) = M.encard := rfl\n      _ ≤ (M' ∪ (M ∩ E(G, Y))).encard := by rw [Set.union_diff_cancel hM.subset]\n      _ ≤ M'.encard + (M ∩ E(G, Y)).encard := encard_union_le _ _\n      _ ≤ ν(G - Y) + (M ∩ E(G, Y)).encard := add_le_add_right (le_csupr (by simp) ν(G - Y)) _\n      _ ≤ ν(G - Y) + Y.encard := by\n        have : (M ∩ E(G, Y)).encard ≤ Y.encard := by\n          calc\n            (M ∩ E(G, Y)).encard ≤ E(G, Y).encard := encard_mono (Set.inter_subset_right _ _)\n            _ ≤ Y.encard := by\n              -- Each edge in E(G, Y) is incident to at least one vertex in Y\n              -- and since M is a matching, each vertex in Y is incident to at most one edge in M\n              have : (M ∩ E(G, Y)).encard ≤ Y.encard := by\n                have : (M ∩ E(G, Y)) ⊆ ⋃ y ∈ Y, E(G, y) := by\n                  rintro e ⟨heM, heY⟩\n                  obtain ⟨v, hv, rfl⟩ := heY\n                  exact Set.mem_iUnion_of_mem ⟨v, hv, by simp [heM]⟩\n                calc\n                  (M ∩ E(G, Y)).encard ≤ (⋃ y ∈ Y, E(G, y)).encard := encard_mono this\n                  _ ≤ ∑ y ∈ Y, E(G, y).encard := encard_iUnion_le _ _\n                  _ ≤ ∑ y ∈ Y, 1 := by\n                    apply Finset.sum_le_sum\n                    intro y hy\n                    exact (hM.degree_le_one y).trans (by simp)\n                  _ = Y.encard := by simp\n              exact this\n        exact this\n  have h2 : 2 * ν(G - Y) ≤ (V(G) \\ Y).encard - (G - Y).OddComponents.encard := by\n    -- In G - Y, each odd component contribu