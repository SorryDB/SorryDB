  L.IsGG ↔ ∃ k : KurodaGrammar T, k.language = L :=
by
  constructor
  · intro h
    obtain ⟨g, hg⟩ := h
    use KurodaGrammar.mk g.nt g.initial (List.map (fun r => 
      match r with
      | Grule.mk [] A [] [Symbol.nonterminal B, Symbol.nonterminal C] => KurodaRule.one_two A B C
      | Grule.mk [] A [] [Symbol.terminal t] => KurodaRule.one_one A t
      | Grule.mk [] A [] [] => KurodaRule.one_nil A
      | Grule.mk [] A [Symbol.nonterminal B] [Symbol.nonterminal C, Symbol.nonterminal D] => KurodaRule.two_two A B C D
      | _ => KurodaRule.one_nil A
    ) g.rules)
    simp [KurodaGrammar.language, Grammar.language, hg]
    ext w
    rw [KurodaGrammar.deri_iff]
    rfl
