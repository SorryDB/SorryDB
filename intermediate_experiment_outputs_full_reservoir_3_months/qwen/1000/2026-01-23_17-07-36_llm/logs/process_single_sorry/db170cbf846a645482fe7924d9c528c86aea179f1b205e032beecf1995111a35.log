lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    have : M'.encard ≤ M.encard := by
      calc
        M'.encard = V(G, M').encard / 2 := by
          rw [encard_eq_half_encard_vertexSet_of_matching hM']
        _ ≤ V(G).encard / 2 := by gcongr; exact subset_vertexSet_incidence hM'
        _ ≤ V(G, M).encard / 2 := by gcongr; exact hsu
        _ = M.encard := by rw [encard_eq_half_encard_vertexSet_of_matching hM]
    exact this
