  toIsMatching := hM
  max M' hM' := by
    have : M'.encard ≤ M.encard := by
      have h1 : M'.encard ≤ V(G, M').encard / 2 := by
        calc
          M'.encard ≤ V(G, M').encard / 2 := by
            apply Nat.div_le_of_le_mul
            rw [mul_comm]
            exact (hM'.degree_le_one _).trans (by norm_num)
          _ = V(G, M').encard / 2 := by rfl
      have h2 : V(G, M') ⊆ V(G) := by
        exact subset_vertexSet _
      have h3 : V(G, M') ⊆ V(G, M) := hsu.trans h2
      have h4 : V(G, M').encard ≤ V(G, M).encard := encard_mono h3
      have h5 : V(G, M).encard ≤ 2 * M.encard := by
        calc
          V(G, M).encard ≤ ∑ v ∈ V(G, M), 1 := by
            simp [encard_eq_sum_ones]
          _ ≤ ∑ v ∈ V(G, M), (M ∩ E(G, v)).encard := by
