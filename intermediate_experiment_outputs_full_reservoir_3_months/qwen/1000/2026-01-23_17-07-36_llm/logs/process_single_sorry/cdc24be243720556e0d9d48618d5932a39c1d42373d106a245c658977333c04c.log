    have ⟨cy,dy,hcy,hdy,_hy⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=Y)
    apply Exists.intro (min cx cy)
    apply Exists.intro (dx + dy)
    constructor
    · exact lt_min hcx hcy
    constructor
    · positivity
    · intro (x,y)
      have hx' := _hx x
      have hy' := _hy y
      constructor
      · calc
          min cx cy • ‖(x, y)‖ ^ 2
            = min cx cy • (max ‖x‖ ‖y‖) ^ 2 := by simp [norm_prod]
          _ ≤ min cx cy • (‖x‖ ^ 2 + ‖y‖ ^ 2) := by
              gcongr
              nlinarith [sq_nonneg (‖x‖ - ‖y‖)]
          _ ≤ cx • ‖x‖ ^ 2 + cy • ‖y‖ ^ 2 := by
              cases le_total cx cy <;> simp_all [min_eq_left, min_eq_right] <;> nlinarith
          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by
              nlinarith [hx'.1, hy'.1]
