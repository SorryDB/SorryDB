    · intro (x,y)
      have hx := _hx x
      have hy := _hy y
      constructor
      · calc
          (cx * cx + cy * cy) • ‖(x, y)‖ ^ 2
            = (cx * cx + cy * cy) • (max ‖x‖ ‖y‖) ^ 2 := by simp [norm_prod]
          _ ≤ (cx * cx + cy * cy) • (‖x‖ ^ 2 + ‖y‖ ^ 2) := by
              gcongr
              apply le_of_sub_nonneg
              nlinarith [sq_nonneg (‖x‖ - ‖y‖)]
          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by
              nlinarith [hx.1, hy.1]
          _ = re (⟪x, x⟫_𝕜 + ⟪y, y⟫_𝕜) := by simp [re_add]
          _ = re ⟪(x, y), (x, y)⟫_𝕜 := by simp [AdjointSpace.inner]
      · calc
          re ⟪(x, y), (x, y)⟫_𝕜
            = re (⟪x, x⟫_𝕜 + ⟪y, y⟫_𝕜) := by simp [AdjointSpace.inner]
          _ = re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by simp [re_add]
          _ ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by nlinarith [hx.2, hy.2]
          _ ≤ (dx * dx + dy * dy) • (max ‖x‖ ‖y‖) ^ 2 := by
              gcongr
              all_goals nlinarith
          _ = (dx * dx + dy * dy) • ‖(x, y)‖ ^ 2 := by simp [norm_prod]
