instance : AdjointSpace 𝕜 (X×Y) where
  inner := fun (x,y) (x',y') => ⟪x,x'⟫_𝕜 + ⟪y,y'⟫_𝕜
  inner_top_equiv_norm := by
    have ⟨cx,dx,hcx,hdx,_hx⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=X)
    have ⟨cy,dy,hcy,hdy,_hy⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=Y)
    apply Exists.intro (min cx cy)
    apply Exists.intro (dx + dy)
    constructor
    · exact lt_min hcx hcy
    constructor
    · positivity
    · intro (x,y)
      have hx' := _hx x
      have hy' := _hy y
      constructor
      · calc
          min cx cy • ‖(x, y)‖ ^ 2
            = min cx cy • (max ‖x‖ ‖y‖) ^ 2 := by simp [norm_prod]
          _ ≤ min cx cy • (‖x‖ ^ 2 + ‖y‖ ^ 2) := by
              apply mul_le_mul_of_nonneg_left
              · nlinarith [sq_nonneg (‖x‖ - ‖y‖)]
              · exact le_of_lt (lt_min hcx hcy)
          _ ≤ cx • ‖x‖ ^ 2 + cy • ‖y‖ ^ 2 := by
              nlinarith [min_le_left cx cy, min_le_right cx cy]
          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by
              nlinarith [hx'.1, hy'.1]
          _ = re (⟪x, x⟫_𝕜 + ⟪y, y⟫_𝕜) := by simp [re_add]
          _ = re ⟪(x, y), (x, y)⟫_𝕜 := by simp
      · calc
          re ⟪(x, y), (x, y)⟫_𝕜
            = re (⟪x, x⟫_𝕜 + ⟪y, y⟫_𝕜) := by simp
          _ = re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by simp [re_add]
          _ ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by
              nlinarith [hx'.2, hy'.2]
          _ ≤ (dx + dy) • (max ‖x‖ ‖y‖) ^ 2 := by
              apply le_of_sub_nonneg
              ring_nf
              nlinarith [sq_nonneg (‖x‖ - ‖y‖), hdx.le, hdy.le]
          _ = (dx + dy) • ‖(x, y)‖ ^ 2 := by simp [norm_prod]
  conj_symm := by
    intro (x,y) (x',y')
    simp [inner, conj_add, conj_symm]
  add_left := by
    intro (x₁,y₁) (x₂,y₂) (x₃,y₃)
    simp [inner, add_left]
  smul_left := by
    intro (x,y) (x',y') r
    simp [inner, smul_left, conj_add]
