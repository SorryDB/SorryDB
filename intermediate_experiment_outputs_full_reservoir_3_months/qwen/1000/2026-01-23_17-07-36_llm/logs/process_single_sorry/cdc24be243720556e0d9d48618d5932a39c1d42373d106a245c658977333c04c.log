instance : AdjointSpace 𝕜 (X×Y) where
  inner := fun (x,y) (x',y') => ⟪x,x'⟫_𝕜 + ⟪y,y'⟫_𝕜
  inner_top_equiv_norm := by
    have ⟨cx,dx,hcx,hdx,_hx⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=X)
    have ⟨cy,dy,hcy,hdy,_hy⟩ := inner_top_equiv_norm (𝕜:=𝕜) (E:=Y)
    apply Exists.intro (min cx cy)
    apply Exists.intro (dx + dy)
    constructor
    · exact lt_min hcx hcy
    constructor
    · positivity
    · intro (x,y)
      have hx' := _hx x
      have hy' := _hy y
      constructor
      · calc
          (min cx cy) • ‖(x, y)‖ ^ 2
            ≤ (min cx cy) • (‖x‖ ^ 2 + ‖y‖ ^ 2) := by gcongr <;> simp [norm_prod_le]
          _ ≤ cx • ‖x‖ ^ 2 + cy • ‖y‖ ^ 2 := by
              cases' le_total cx cy with h h <;> simp_all [min_eq_left, min_eq_right] <;>
                nlinarith
          _ ≤ re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by nlinarith
          _ = re (⟪x, x⟫_𝕜 + ⟪y, y⟫_𝕜) := by simp [re_add]
          _ = re ⟪(x, y), (x, y)⟫_𝕜 := by rfl
      · calc
          re ⟪(x, y), (x, y)⟫_𝕜
            = re (⟪x, x⟫_𝕜 + ⟪y, y⟫_𝕜) := by rfl
          _ = re ⟪x, x⟫_𝕜 + re ⟪y, y⟫_𝕜 := by simp [re_add]
          _ ≤ dx • ‖x‖ ^ 2 + dy • ‖y‖ ^ 2 := by nlinarith
          _ ≤ (dx + dy) • (‖x‖ ^ 2 + ‖y‖ ^ 2) := by nlinarith
          _ ≤ (dx + dy) • ‖(x, y)‖ ^ 2 := by gcongr <;> simp [norm_prod_le]
