lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨g, hg_hull, hg_cauchy⟩ := komlos_convex (fun x ↦ ‖x‖^2) (fun _ ↦ sq_nonneg _) (by
    obtain ⟨M, hM⟩ := h_bdd
    refine ⟨(max 0 M) ^ 2, fun n ↦ sq_le_sq.mpr ?_⟩
    simp only [abs_norm, le_max_iff]
    left; exact hM n)
  have hg_cau : CauchySeq g := cauchySeq_of_forall_epsilon_exists_N fun ε εpos ↦ by
    obtain ⟨N, hN⟩ := hg_cauchy (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [dist_eq_norm, ← sq_lt_sq, norm_norm]
    · simp only [two_inv_smul, norm_smul, NNReal.norm_eq, NNReal.coe_inv, NNReal.coe_two,
        norm_inv, norm_two, sq_inv, sq_two] at hN
      linarith [norm_sub_sq (g n) (g m), norm_add_sq (g n) (g m)]
    · exact εpos.le
    · exact norm_nonneg _
  obtain ⟨x, hx⟩ := cauchySeq_tendsto_atTop hg_cau
  exact ⟨g, x, fun n ↦ convexHull_min (Set.subset_convexHull ℝ _)
    ((convex_convexHull ℝ _).restrict_scalars ℝ≥0) (hg_hull n), hx⟩

```
