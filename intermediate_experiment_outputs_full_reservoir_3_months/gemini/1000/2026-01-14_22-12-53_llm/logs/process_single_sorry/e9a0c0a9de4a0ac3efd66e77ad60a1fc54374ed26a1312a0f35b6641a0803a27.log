import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1988_p6 (a b : ℕ) (h₀ : 0 < a ∧ 0 < b) (h₁ : a * b + 1 ∣ a ^ 2 + b ^ 2) :
  ∃ x : ℕ, (x ^ 2 : ℝ) = (a ^ 2 + b ^ 2) / (a * b + 1) := by
  obtain ⟨k, hk⟩ : a * b + 1 ∣ a ^ 2 + b ^ 2 := h₁
  have h_sq : ∃ x, x ^ 2 = k := by
    let S := { p : ℕ × ℕ | 0 < p.1 ∧ 0 < p.2 ∧ p.1 ^ 2 + p.2 ^ 2 = k * (p.1 * p.2 + 1) }
    obtain ⟨⟨m, n⟩, ⟨hm, hn, hmn⟩, hmin⟩ := WellFounded.has_min (measure (fun p : ℕ × ℕ => p.1 + p.2)).wf S ⟨(a, b), h₀.1, h₀.2, hk⟩
    have : n ≤ m := by
      by_contra' hlt; exact hmin ⟨n, m⟩ ⟨hn, hm, by rwa [add_comm, mul_comm]⟩ (by rwa [add_comm])
    let m' : ℤ := k * n - m
    have hm'm : m' * m = n ^ 2 - k := by zify at hmn; nlinarith
    have hm'sq : m' ^ 2 + n ^ 2 = k * (m' * n + 1) := by zify at hmn; nlinarith
    if h0 : m' = 0 then exists n; zify at hm'm; linarith
    else if hneg : m' < 0 then by nlinarith
    else
      have hlt : m'.toNat + n < m + n := by zify [m', hneg] at *; nlinarith
      exact (hmin ⟨m'.toNat, n⟩ ⟨Int.toNat_pos.2 (by linarith), hn, by zify; rwa [Int.toNat_sq, Int.toNat_mul_toNat, Int.toNat_pos.2 (by linarith)]⟩ hlt).elim
  obtain ⟨x, hx⟩ := h_sq
  exists x; rw [hk, Nat.cast_div h₁ (by linarith), ← hx]; push_cast; ring
