import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  rw [← Nat.cast_id (∑ k in Finset.range (n + 1), (2 * n + 1).choose (2 * k + 1) * 2 ^ (3 * k)),
      ← ZMod.int_cast_zmod_eq_zero (∑ k in Finset.range (n + 1), (2 * n + 1).choose (2 * k + 1) * 8 ^ k) 5]
  push_cast
  let S : ℕ → ZMod 5 := fun n => ∑ k in Finset.range (n + 1), (2 * n + 1).choose (2 * k + 1) * 3 ^ k
  let A : ℕ → ZMod 5 := fun n => ∑ k in Finset.range (n + 1), (2 * n + 1).choose (2 * k) * 3 ^ k
  have h_rec (n : ℕ) : S (n + 1) = 2 * A n + 4 * S n ∧ A (n + 1) = 4 * A n + 4 * S n := by
    induction' n with n _
    · simp [S, A]; rfl
    · have h1 (m k : ℕ) : (m + 2).choose (k + 1) = m.choose (k + 1) + 2 * m.choose k + m.choose (k - 1) := by
        rw [Nat.choose_succ_succ, Nat.choose_succ_succ m, add_assoc, add_assoc, ← Nat.choose_succ_succ]
        cases k <;> simp [Nat.choose_succ_succ]
      simp only [S, A, Finset.sum_range_succ, h1 (2 * n + 1), Nat.mul_choose_eq_succ_mul,
        Nat.cast_add, Nat.cast_mul, Nat.cast_sum, pow_succ, mul_assoc]
      have s_rel : S (n + 1) = ∑ k in Finset.range (n + 2), ((2 * n + 1).choose (2 * k + 1) + 2 * (2 * n + 1).choose (2 * k) + (2 * n + 1).choose (2 * k - 1)) * 3 ^ k := by
        apply Finset.sum_congr rfl; intro k _; rw [h1]; push_cast; rfl
      have a_rel : A (n + 1) = ∑ k in Finset.range (n + 2), ((2 * n + 1).choose (2 * k) + 2 * (2 * n + 1).choose (2 * k - 1) + (2 * n + 1).choose (2 * k - 2)) * 3 ^ k := by
        apply Finset.sum_congr rfl; intro k _; rw [h1]; push_cast; rfl
      simp only [s_rel, a_rel, Finset.sum_add_distrib, ← Finset.mul_sum]
      let S_n := S n; let A_n := A n
      have hS : (∑ k in Finset.range (n + 2), (2 * n + 1).choose (2 * k + 1) * (3 : ZMod 5) ^ k) = S_n := by
        rw [Finset.sum_range_succ]; simp [S_n, Nat.choose_eq_zero_of_lt]
      have hA : (∑ k in Finset.range (n + 2), (2 * n + 1).choose (2 * k) * (3 : ZMod 5) ^ k) = A_n := by
        rw [Finset.sum_range_succ]; simp [A_n, Nat.choose_eq_zero_of_lt]
      have hS' : (∑ k in Finset.range (n + 2), (2 * n + 1).choose (2 * k - 1) * (3 : ZMod 5) ^ k) = 3 * S_n := by
        rw [Finset.sum_range_succ', Finset.sum_range_succ]; simp [S_n, Nat.choose_eq_zero_of_lt, Finset.sum_range_succ', mul_assoc, ← pow_succ]
        rw [← Finset.mul_sum]; rfl
      have hA' : (∑ k in Finset.range (n + 2), (2 * n + 1).choose (2 * k - 1) * (3 : ZMod 5) ^ k) = 3 * S_n := hS'
      have hA'' : (∑ k in Finset.range (n + 2), (2 * n + 1).choose (2 * k - 2) * (3 : ZMod 5) ^ k) = 3 * A_n := by
        rw [Finset.sum_range_succ', Finset.sum_range_succ', Finset.sum_range_succ]; simp [A_n, Nat.choose_eq_zero_of_lt, mul_assoc, ← pow_succ]
        rw [← Finset.mul_sum]; rfl
      exact ⟨by rw [hS, hA, hS']; ring, by rw [hA, hA', hA'']; ring⟩
  let v (n : ℕ) : ZMod 5 × ZMod 5 := (A n, S n)
  have v_rec (n : ℕ) : v (n + 1) = (4 * (v n).1 + 4 * (v n).2, 2 * (v n).1 + 4 * (v n).2) := by
    let h := h_rec n; simp [v, h.1, h.2]; ring_nf; exact ⟨rfl, rfl⟩
  have v_p (n : ℕ) : v (n + 12) = v n := by
    induction' n with n ih; swap; · rw [v_rec, v_rec, ih]
    iterate 12 (rw [v_rec]); rfl
  intro h0; have : (v n).2 = 0 := h0
  revert this; apply Nat.le_induction (m := n % 12)
  · iterate 12 (· intro h; try { rw [v_rec] at h }; revert h)
    · simp [v, S, A]; rfl
  · intro m _ _; rw [v_p m]; exact id

