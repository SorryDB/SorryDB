module

public import Mathlib.NumberTheory.Cyclotomic.Basic

@[expose] public section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro h
    haveI := h.isAlgebraic K L
    apply IsAlgClosure.of_isAlgebraic ‹_›
    intro f hf
    obtain ⟨n, -, hn, ζ, hζ, hfζ⟩ := FiniteField.exists_root_isPrimitiveRoot_of_irreducible K f hf
    obtain ⟨ζ', hζ'⟩ := h.exists_root (by exact_mod_cast hn)
    have : f.HasRoot (adjoin K {ζ | ∃ n ∈ {n | (n : K) ≠ 0}, IsPrimitiveRoot ζ n}) := by
      letI := IsPrimitiveRoot.isCyclotomicExtension hζ'
      letI := IsPrimitiveRoot.isCyclotomicExtension hζ
      let i := (IsCyclotomicExtension.splittingField_iff (n := n) K (adjoin K {ζ | ∃ n ∈ {n | (n : K) ≠ 0}, IsPrimitiveRoot ζ n})).mpr ⟨ζ', hζ', (IsCyclotomicExtension.adjoin_primitive_root n _)⟩
      let j := (IsCyclotomicExtension.splittingField_iff (n := n) K (adjoin K {ζ | IsPrimitiveRoot ζ n})).mpr ⟨ζ, hζ, (IsCyclotomicExtension.adjoin_primitive_root n _)⟩
      obtain ⟨e⟩ := IsSplittingField.algEquiv K (adjoin K {ζ | IsPrimitiveRoot ζ n}) (adjoin K {ζ | ∃ n ∈ {n | (n : K) ≠ 0}, IsPrimitiveRoot ζ n}) (X ^ n - 1)
      exact ⟨e ζ, by rw [← e.isRoot_poly, hfζ.isRoot_X_pow_sub_one]⟩
    rwa [h.adjoin_roots] at this
  · intro h
    haveI := h.algebraic
    constructor
    · intro n hn; exact IsAlgClosed.exists_primitive_root n hn
    · rw [Algebra.adjoin_eq_top_iff]
      intro x
      rcases eq_or_ne x 0 with rfl | hx
      · exact Subalgebra.zero_mem _
      · obtain ⟨n, hn, hx_pow⟩ := IsAlgebraic.isUnit_is_root_of_unity x ‹_› (IsUnit.mk0 x hx)
        obtain ⟨m, -, hm, hmx⟩ := root_of_unity_order_coprime K x hn hx_pow
        obtain ⟨ζ, hζ⟩ := IsAlgClosed.exists_primitive_root m (by exact_mod_cast hm)
        exact (adjoin_le_adjoin_roots _ _) (Subalgebra.mem_top (adjoin K {ζ | ∃ n ∈ {n | (n : K) ≠ 0}, IsPrimitiveRoot ζ n}))
```
