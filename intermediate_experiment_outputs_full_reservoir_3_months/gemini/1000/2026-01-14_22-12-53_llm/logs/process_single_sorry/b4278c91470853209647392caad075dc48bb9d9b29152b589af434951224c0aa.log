/-- The integral of a Borel function `f` against `E_{a, x ,y}` is bounded by `‖x‖ * ‖y‖`.
We should have an analogue of `MeasureTheory.lintegral_le_const` for `ComplexMeasure.integral`.
-/
lemma bfc_bounded (x y : H) {C : ℝ} {f : (spectrum ℂ a) → ℂ}  (hf_bounded : ∀ x, ‖f x‖ ≤ C)
    (hX : @Measurable _ _ (borel (spectrum ℂ a)) _ f) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
  apply (ComplexMeasure.norm_integral_le_of_norm_le hX hf_bounded).trans
  by_cases hx : x = 0
  · have : (cfc_toComplexMeasure ha x y).variation Set.univ = 0 :=
      le_bot_iff.mp (by simpa [hx] using cfc_variation_toComplexMeasure_bounded ha 0 y)
    simp [this, hx]
  · haveI : Nontrivial H := nontrivial_of_ne x 0 hx
    have hC : 0 ≤ C := (norm_nonneg (f (spectrum.nonempty ℂ a).some)).trans (hf_bounded _)
    rw [max_eq_left hC, mul_comm]
    apply mul_le_mul_of_nonneg_left _ hC
    apply (ENNReal.toReal_le_toReal (ComplexMeasure.variation_lt_top _ _).ne (by simp)).mpr
    exact cfc_variation_toComplexMeasure_bounded ha x y

```
