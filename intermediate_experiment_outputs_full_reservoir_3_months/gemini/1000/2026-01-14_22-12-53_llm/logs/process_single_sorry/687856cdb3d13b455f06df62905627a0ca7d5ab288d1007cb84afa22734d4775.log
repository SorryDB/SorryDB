import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  use 2⁻²¹
  constructor
  · norm_num
  · intro n hn S hS hS_pair
    let D := S.sup fun p₁ ↦ S.sup fun p₂ ↦ dist p₁ p₂
    have hD_pos : 0 < D := by
      obtain ⟨p1, h1, p2, h2, h12⟩ := S.one_lt_card_iff.1 (hS.symm ▸ hn)
      exact (hS_pair h1 h2 h12).trans_lt' (by norm_num) |>.trans_le (Finset.le_sup h1 (Finset.le_sup h2 (by refl)))
    have hS_ne : S.Nonempty := by rw [← Finset.card_pos, hS]; exact hn.trans_lt' (by norm_num)
