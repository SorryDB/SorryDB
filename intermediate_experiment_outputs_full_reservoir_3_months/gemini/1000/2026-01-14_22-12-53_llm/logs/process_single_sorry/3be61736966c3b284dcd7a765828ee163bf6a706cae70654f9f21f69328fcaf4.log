import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h2 : ∀ c > 0, f c = f (Real.sqrt c) ^ 2 := fun c hc ↦ by
      specialize h (Real.sqrt c) (Real.sqrt c) (Real.sqrt c) (Real.sqrt c) (Real.sqrt_pos.mpr hc) (Real.sqrt_pos.mpr hc) (Real.sqrt_pos.mpr hc) (Real.sqrt_pos.mpr hc) (by field_simp)
      field_simp [hc] at h; exact ((mul_right_inj' (by linarith [h₁ c])).mp h).symm
    have hf1 : f 1 = 1 := by
      have := h2 1 (by norm_num); rw [Real.sqrt_one] at this
      exact (mul_self_eq_self.mp this.symm).resolve_left (ne_of_gt (h₁ 1))
    have hfx : ∀ u > 0, f u = u ∨ f u = 1 / u := fun u hu ↦ by
      have h4 : f u + f (1 / u) = u + 1 / u := by
        specialize h 1 1 (Real.sqrt u) (1 / Real.sqrt u) (by norm_num) (by norm_num) (Real.sqrt_pos.mpr hu) (one_div_pos.mpr (Real.sqrt_pos.mpr hu)) (by field_simp)
        rw [hf1, ← h2 u hu, ← h2 (1 / u) (one_div_pos.mpr hu), Real.sq_sqrt (le_of_lt hu), Real.sq_sqrt (le_of_lt (one_div_pos.mpr hu)), Real.sqrt_one] at h
        field_simp [h₁ u, h₁ (1 / u), hu] at h; linarith
      have h5 : f u ^ 2 + f (1 / u) ^ 2 = u ^ 2 + 1 / u ^ 2 := by
        specialize h u (1 / u) 1 1 hu (one_div_pos.mpr hu) (by norm_num) (by norm_num) (by field_simp)
        rw [hf1, Real.sq_sqrt (le_of_lt (by norm_num))] at h; field_simp [h₁ 1] at h; linarith
      have : (f u - u) * (f u - 1 / u) = 0 := by
        have : f u * f (1 / u) = 1 := by nlinarith
        field_simp [hu]; nlinarith
      exact eq_zero_or_eq_zero.mp this
    by_contra h_not; push_neg at h_not; obtain ⟨⟨a, ha, ha_ne⟩, ⟨b, hb, hb_ne⟩⟩ := h_not
    have fa : f a = 1 / a := (hfx a ha).resolve_left ha_ne
    have fb : f b = b := (hfx b hb).resolve_right hb_ne
    specialize h a b (Real.sqrt (a * b)) (Real.sqrt (a * b)) ha hb (Real.sqrt_pos.mpr (mul_pos ha hb)) (Real.sqrt_pos.mpr (mul_pos ha hb)) (by rw [Real.mul_self_sqrt (le_of_lt (mul_pos ha hb))])
    rw [fa, fb, Real.sq_sqrt (le_of_lt (mul_pos ha hb)), ← h2 (a * b) (mul_pos ha hb)] at h
    field_simp [h₁ (a * b), ha, hb] at h
    cases hfx (a * b) (mul_pos ha hb) with
    | inl h_ab => rw [h_ab] at h; field_simp [ha, hb] at h; have : b = 1 := by nlinarith; absurd hb_ne; rw [this, hf1, one_div_one]
    | inr h_ab => rw [h_ab] at h; field_simp [ha, hb] at h; have : a = 1 := by nlinarith; absurd ha_ne; rw [this, hf1]
  · rintro (hf | hf) w x y z hw hx hy hz heq
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2), heq]
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
      field_simp [hw, hx, hy, hz]; rw [← mul_pow, heq, mul_pow]; ring

