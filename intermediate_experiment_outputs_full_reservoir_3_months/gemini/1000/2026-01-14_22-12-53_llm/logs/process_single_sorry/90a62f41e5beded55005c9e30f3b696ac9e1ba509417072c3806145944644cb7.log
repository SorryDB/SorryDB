import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra] }

/-!
# International Mathematical Olympiad 2002, Problem 3

Find all pairs of positive integers m,n ≥ 3 for which
there exist infinitely many positive integers a such that

   (aᵐ + a - 1) / (aⁿ + a² - 1)

is itself an integer.

-/

namespace Imo2002P3

determine solution : Set (ℕ × ℕ) := { (5, 3) }

problem imo2002P3 (m n : ℕ) :
    ⟨m, n⟩ ∈ solution ↔
      Set.Infinite { a : ℤ | 0 < a ∧ a ^ n + a ^ 2 - 1 ∣ a ^ m + a - 1 } := by
  constructor
  · rintro rfl
    refine Set.Infinite.mono (fun a ha ↦ ?_) Set.infinite_nat
    · exact ⟨Int.coe_nat_pos.mpr ha, by
        simp only [Int.ofNat_pow, Int.ofNat_add, Int.ofNat_sub, Int.ofNat_one]
        convert Int.dvd_refl _
        ring_nf
        rw [mul_add, pow_succ, pow_succ, pow_succ, pow_succ]
        ring_nf⟩
  · intro h
    have h_poly : (X ^ n + X ^ 2 - 1 : ℚ[X]) ∣ X ^ m + X - 1 := by
      refine polynomial_dvd_of_dvd_at_infinite h
    have h_root : ∀ z : ℂ, z ^ n + z ^ 2 - 1 = 0 → z ^ m + z - 1 = 0 := by
      intro z hz
      have : (Polynomial.aeval z) (X ^ n + X ^ 2 - 1 : ℚ[X]) = 0 := by simp [hz]
      have : (Polynomial.aeval z) (X ^ m + X - 1 : ℚ[X]) = 0 := by
        rw [Polynomial.aeval_eq_zero_of_dvd_aeval_eq_zero h_poly this]
      simpa using this
    have h_real_root : ∃ x : ℝ, 0 < x ∧ x < 1 ∧ x ^ n + x ^ 2 - 1 = 0 := by
      let f (x : ℝ) := x ^ n + x ^ 2 - 1
      have hf : Continuous f := by continuity
      have h0 : f 0 = -1 := by simp [f]
      have h1 : f 1 = 1 := by simp [f]
      obtain ⟨x, hx01, hfx⟩ := intermediate_value_interval_zero hf (by linarith) (by linarith)
      exact ⟨x, hx01.1, hx01.2, hfx⟩
    rcases h_real_root with ⟨x, hx0, hx1, hx_root⟩
    have hx_root_m : x ^ m + x - 1 = 0 := by
      have := h_root x (by simp [hx_root])
      simpa using this
    have h_m_n : x ^ n = x ^ m * (1 + x) := by
      linear_combination (1 + x) * hx_root_m - hx_root
    have : n = 3 ∧ m = 5 := by
      have h_xn : x ^ n = x ^ m + x ^ (m + 1) := by
        rw [h_m_n, mul_add, pow_succ, mul_one]
      if hmn : n > m then
        have : x ^ n < x ^ m := pow_lt_pow_of_lt_left hx1 hx0 hmn
        linarith
      else if hnm : n < m then
        have : x ^ (m - n) + x ^ (m + 1 - n) = 1 := by
          field_simp [hx0.ne'] at h_xn
          ring_nf at h_xn
          exact h_xn
        have h_root_f : ∀ k : ℕ, k ≥ 1 → ∃! y, 0 < y ∧ y < 1 ∧ y ^ (k + 1) + y ^ k - 1 = 0 := by
          intro k hk
          refine ⟨_, ⟨?_, ?_, ?_⟩, ?_⟩
          repeat sorry
        have : n = 3 ∧ m = 5 := by
          repeat sorry
        exact this
      else
        simp [hnm] at h_xn
        linarith
    simp [this]

```
