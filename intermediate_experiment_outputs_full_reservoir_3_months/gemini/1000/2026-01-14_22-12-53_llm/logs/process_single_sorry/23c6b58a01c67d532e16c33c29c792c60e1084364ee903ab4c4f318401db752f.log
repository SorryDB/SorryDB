import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
We say that a finite set $\mathcal{S}$ of points in the plane is [i]balanced[/i] if, for any two different points $A$ and $B$ in $\mathcal{S}$, there is a point $C$ in $\mathcal{S}$ such that $AC=BC$. We say that $\mathcal{S}$ is [i]centre-free[/i] if for any three different points $A$, $B$ and $C$ in $\mathcal{S}$, there is no points $P$ in $\mathcal{S}$ such that $PA=PB=PC$.

(a) Show that for all integers $n\ge 3$, there exists a balanced set consisting of $n$ points.

(b) Determine all integers $n\ge 3$ for which there exists a balanced centre-free set consisting of $n$ points.

Proposed by Netherlands
-/
@[imo_problem_subject combinatorics]
theorem imo_2015_p1 (Balanced : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₀ : ∀ s, Balanced s ↔ ∀ A ∈ s, ∀ B ∈ s, A ≠ B → ∃ C ∈ s, dist A C = dist B C)
    (center_free : Finset (EuclideanSpace ℝ (Fin 2)) → Prop)
    (hb₁ : ∀ s, center_free s ↔ ∀ A ∈ s, ∀ B ∈ s, ∀ C ∈ s, A ≠ B ∧ B ≠ C ∧ A ≠ C → ¬∃ P ∈ s,
        dist P A = dist P B ∧
        dist P B = dist P C) :
    (∀ n ≥ 3, ∃ s, Balanced s ∧ s.card = n) ∧
    {n : ℕ | 3 ≤ n ∧ ∃ s, Balanced s ∧ center_free s ∧ s.card = n} = {n | 3 ≤ n ∧ Odd n} := by
  constructor
  · intro n hn
    rcases (even_or_odd n) with h | h
    · let m := n - 1
      have hm_odd : Odd m := Nat.even_sub_one (Nat.le_trans (by decide) hn) h
      obtain ⟨s, hb, hcf, hc⟩ := (by
        have hm3 : 3 ≤ m ∨ m = 1 := by
          cases' n with n <;> [linarith, (cases' n with n <;> [linarith, (cases' n with n <;> [linarith, (cases' n with n <;> [simp, simp])])])]
        sorry)
      sorry
    · obtain ⟨s, hb, hcf, hc⟩ := (by sorry)
      use s, hb, hc
  · ext n
    constructor
    · rintro ⟨h3, s, hb, hcf, hcard⟩
      rw [hb₀] at hb
      rw [hb₁] at hcf
      have h_count : s.card * (s.card - 1) / 2 ≤ s.card * ((s.card - 1) / 2) := by
        let pairs := s.offDiag.filter (fun p => p.1 < p.2)
        have h_pairs_card : pairs.card = s.card.choose 2 := by sorry
        let f : {p // p ∈ pairs} → s := fun ⟨p, hp⟩ => Classical.choose (hb p.1 (by sorry) p.2 (by sorry) (by sorry))
        have h_f : ∀ A B C, f ⟨(A, B), by sorry⟩ = C → dist C A = dist C B := by sorry
        have h_cf_bound : ∀ C ∈ s, (pairs.filter (fun p => f ⟨p, by sorry⟩ = C)).card ≤ (s.card - 1) / 2 := by
          intro C HC
          let others := (s.erase C)
          have h_others_card : others.card = s.card - 1 := by simp [HC]
          sorry
        sorry
      have h_odd : Odd n := by
        contrapose! h_count
        let m := n / 2
        have hn2m : n = 2 * m := Nat.even_iff_exists_two_mul.mp (Nat.not_odd_iff_even.mp h_count)
        have hm : 1 < m := by linarith
        simp [hn2m, Nat.choose_succ_self]
        rw [Nat.mul_sub_left_distrib, Nat.mul_comm]
        linarith
      exact ⟨h3, h_odd⟩
    · rintro ⟨h3, h_odd⟩
      obtain ⟨s, hb, hcf, hc⟩ := (by sorry)
      use s, hb, hcf, hc

