    have := congr_fun ha 2; simp only [p, ↓reduceDIte, Fin.val_natCast, Nat.reduceMod, Fin.val_two, 
      lt_self_iff_false, sum_apply, Pi.smul_apply, smul_eq_mul, mul_one] at this
    rw [← Set.Finite.sum_toFinset_filt_complement (Set.toFinite (Set.univ : Set (Fin 4))) (fun i ↦ 0 < a i)] at this
    simp only [Set.mem_univ, true_and, Set.Finite.toFinset_toFinite, Set.Finite.sum_toFinset_filt_complement] at this
    rw [← sum_neg_distrib, ← this]; apply sum_congr rfl; intro i hi; simp only [Set.mem_setOf_eq, not_lt] at hi
    exact if h : a i = 0 then by simp [h] else by simp [hi.lt_of_ne h]
  let A := ∑ i in I.toFinite.toFinset, a i
