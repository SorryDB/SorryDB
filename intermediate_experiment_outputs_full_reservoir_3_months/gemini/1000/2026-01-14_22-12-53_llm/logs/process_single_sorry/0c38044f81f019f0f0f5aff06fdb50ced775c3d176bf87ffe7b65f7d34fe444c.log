        subst this; exact ha0 (funext (fun i ↦ if h : 0 < a i then (Set.eq_empty_iff_forall_not_mem.mp ‹I = ∅› i h).elim else if h' : a i < 0 then (Set.eq_empty_iff_forall_not_mem.mp ‹J = ∅› i h').elim else (not_lt.mp h).antisymm h')))
  let z := A⁻¹ • ∑ i in I.toFinite.toFinset, a i • x i
  have h_zI : z ∈ convexHull ℝ (x '' I) := (convexHull_eq_sum ℝ).mpr ⟨I.toFinite.toFinset, fun i hi ↦ 
    (Set.Finite.mem_toFinset.mp hi), fun i hi ↦ (mul_pos (inv_pos.mpr hA) (Set.mem_setOf_eq.mp (Set.Finite.mem_toFinset.mp hi))).le, by rw [← mul_sum, hA, inv_mul_cancel hA.ne.symm], rfl⟩
  have h_zJ : z ∈ convexHull ℝ (x '' J) := (convexHull_eq_sum ℝ).mpr ⟨J.toFinite.toFinset, fun i hi ↦ 
