@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hp_prime : p.Prime
  · rw [Factorization.balance, Factorization.sum, Params.initial.factorial_factorization_eq_div hp_prime hp']
    have h_count : (P.initial.a.map (·.factorization p)).sum = P.M * (Finset.filter (p ∣ ·) (.Ico (P.n - P.n / P.M) P.n)).card := by
      simp only [Params.initial, Multiset.mem_filter, Multiset.map_filter, Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate, smul_eq_mul]
      congr 1; rw [Multiset.Ico, ← Finset.sum_eq_multiset_sum, Finset.sum_filter, Finset.sum_congr rfl]
      intro m hm; split_ifs with hpm
      · have : m.factorization p = 1 := by
          refine (hp_prime.factorization_pos.mpr hpm).antisymm ?_
          have h_m : (m : ℝ) < (p : ℝ)^2 := by
            have : (m : ℝ) < P.n := cast_lt.mpr (Finset.mem_Ico.mp hm).2
            nlinarith [sqrt_nonneg (P.n : ℝ), mul_self_sqrt (cast_nonneg (P.n : ℝ))]
          exact Nat.Prime.factorization_le_one hp_prime (by norm_cast)
        have h_smooth : m ∈ (P.n / P.L).smoothNumbers := by
          rw [mem_smoothNumbers]; refine ⟨pos_of_ne_zero (by linarith [(Finset.mem_Ico.mp hm).1, P.hL_pos]), fun q hq hqm ↦ ?_⟩
          by_cases hqp : q = p
          · subst hqp; exact hp
          · have hq_le : q ≤ m / p := Nat.le_of_dvd (Nat.div_pos (Nat.le_of_dvd (by linarith [(Finset.mem_Ico.mp hm).1]) hpm) hp_prime.pos) (Nat.dvd_div_of_mul_dvd (Nat.mul_dvd_of_coprime hq.coprime_prime_right hpm))
            refine hq_le.trans (Nat.le_of_lt_succ (lt_of_le_of_lt (cast_le.mp ?_) (Nat.lt_succ_of_le (P.n.div_le_div_left P.hL_pos.le P.hL.le))))
            rw [cast_div_le (cast_pos.mpr hp_prime.pos), ← Real.sqrt_le (cast_nonneg _), Real.mul_self_sqrt (cast_nonneg _)]
            exact (cast_lt.mpr (Finset.mem_Ico.mp hm).2).le
        simp [h_smooth, this]
      · simp [hpm, factorization_eq_zero_iff]
    have h_card : (P.n / P.M) / p ≤ (Finset.filter (p ∣ ·) (.Ico (P.n - P.n / P.M) P.n)).card := by
      rw [← Nat.sub_sub_self (div_le_self P.n P.M)]; exact Nat.div_le_card_filter_dvd_Ico _ _ _
    have h_bound : (P.n / p : ℤ) ≤ (P.M : ℤ) * ((P.n / P.M) / p) + P.M := by
      rw [Nat.div_div_eq_div_mul]; linarith [Nat.mul_div_le P.n (P.M * p)]
    nlinarith
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hp_prime]
