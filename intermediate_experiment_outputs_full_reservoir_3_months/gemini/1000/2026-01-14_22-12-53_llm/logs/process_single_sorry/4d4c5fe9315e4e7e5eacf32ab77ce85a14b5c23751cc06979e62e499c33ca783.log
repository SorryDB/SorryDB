import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  have h_inf := Nat.exists_infinite_primes_modEq_one 4 (by norm_num)
  obtain ⟨p, hp, hp1, hp_large⟩ := h_inf.exists_gt (max 13 (N ^ 2 + 1))
  have ⟨x, hx⟩ := (ZMod.exists_sq_eq_neg_one_iff_mod_four p hp).mpr (by rw [hp1]; exact Nat.modEq_one)
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have h_n_sq : (n : ZMod p) ^ 2 = -1 := by split_ifs <;> { simp [ZMod.coe_val_p, hx] }
  have h_p_dvd : p ∣ n ^ 2 + 1 := by
    apply Nat.dvd_of_mod_eq_zero
    apply ZMod.val_eq_zero.mp
    simp [h_n_sq]
  have h_n_bound : n ≤ p / 2 := by
    split_ifs <;> [assumption; apply Nat.le_of_lt_succ; apply Nat.sub_lt_succ (Nat.div_pos (Nat.Prime.two_le hp) (by norm_num))]
    exact Nat.div_le_self p 2
  have h_n_ge_N : n ≥ N := by
    have h_n2 : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos _) h_p_dvd
    have : n ^ 2 + 1 > N ^ 2 + 1 := h_n2.trans_lt' hp_large
    exact Nat.lt_of_pow_lt_pow_left 2 (by norm_num) (Nat.lt_of_succ_lt_succ this)
  refine ⟨n, h_n_ge_N, p, hp, h_p_dvd, ?_⟩
  set h := p - 2 * n with h_def
  have h_pos : h > 0 := by
    have : 2 * n < p := by
      apply Nat.lt_of_le_of_ne (Nat.le_of_lt_succ (Nat.lt_succ_of_le (Nat.mul_div_le_p 2 n).symm.trans (by rw [Nat.mul_comm]; exact Nat.mul_le_mul_left 2 h_n_bound)))
      intro h_eq; have := hp.one_lt.trans_le (h_eq.symm.sub_le 0); rw [← h_eq] at hp; exact Nat.not_prime_even hp (Nat.lt_of_succ_lt this) rfl
    exact Nat.sub_pos_of_lt this
  have h_p_dvd_h2 : p ∣ h ^ 2 + 4 := by
    have : (h : ZMod p) ^ 2 + 4 = (p - 2 * n : ZMod p) ^ 2 + 4 := rfl
    rw [ZMod.coe_sub, ZMod.coe_mul, ZMod.coe_nat_cast, ZMod.coe_nat_cast, ZMod.zero_sub, neg_sq, mul_pow, h_n_sq] at this
    exact ZMod.val_eq_zero.mp (by simp [this])
  have h_h_odd : h % 2 = 1 := by
    rw [h_def, Nat.sub_mod, Nat.Prime.mod_two_eq_one_of_odd hp (hp.odd_of_poly_special (Nat.mod_eq_zero_of_dvd h_p_dvd)), Nat.mul_mod_right]
    rfl
  have k_odd : ((h ^ 2 + 4) / p) % 2 = 1 := by
    apply Nat.odd_of_mul_odd (a := p)
    rw [Nat.mul_div_cancel' h_p_dvd_h2, Nat.add_mod, Nat.pow_mod, h_h_odd]
    norm_num
  have k_not_three : (h ^ 2 + 4) / p ≠ 3 := by
    intro h_eq; have := Nat.mul_div_cancel' h_p_dvd_h2; rw [h_eq] at this
    have h_mod3 : (h ^ 2 + 4) % 3 = (3 * p) % 3 := congr_arg (· % 3) this
    simp [Nat.add_mod, Nat.pow_mod] at h_mod3
    cases h % 3 <;> rename_i v <;> linarith [h_mod3]
  have h2_gt_2n : h ^ 2 > 2 * n := by
    have k_val : (h ^ 2 + 4) / p ≥ 1 := Nat.div_pos (h_pos.trans_le (Nat.le_pow_self (by norm_num) _)) (Nat.Prime.pos hp)
    if h_k : (h ^ 2 + 4) / p = 1 then
      have hp4 : p = h ^ 2 + 4 := (Nat.div_eq_one_iff (Nat.Prime.pos hp)).mp h_k
      have : h > 4 := by
        have : h ^ 2 = p - 4 := by rw [hp4, Nat.add_sub_cancel]
        have : h ^ 2 > 9 := this.symm.trans_gt (Nat.sub_lt_left (by norm_num) hp_large).symm
        exact Nat.lt_of_pow_lt_pow_left 2 (by norm_num) this
      rw [← Nat.sub_lt_iff_lt_add' (Nat.mul_le_mul_left 2 h_n_bound), ← h_def, hp4, Nat.add_sub_cancel_left]
      exact this.trans_le (Nat.le_pow_self (by norm_num) h)
    else
      have : (h ^ 2 + 4) / p ≥ 5 := by
        have := Nat.lt_of_le_of_ne (Nat.succ_le_of_lt (Nat.lt_of_le_of_ne k_val (Ne.symm h_k))) (Ne.symm k_not_three)
        exact Nat.succ_le_of_lt (Nat.lt_of_le_of_ne this (by intro h_eq; rw [h_eq] at k_odd; norm_num at k_odd))
      have : h ^ 2 + 4 ≥ 5 * p := (Nat.le_div_iff_mul_le (Nat.Prime.pos hp)).mp this
      have : h ^ 2 ≥ 5 * p - 4 := Nat.le_sub_of_add_le this
      exact this.trans_gt (by linarith [hp_large, Nat.mul_le_mul_left 2 h_n_bound])
  rw [h_def] at h2_gt_2n
  rw [Real.sqrt_lt, ← Real.coe_nat_cast, ← Real.coe_nat_cast, ← Real.coe_nat_sub (Nat.mul_le_mul_left 2 h_n_bound)] at h2_gt_2n
  · linarith
  · exact Nat.cast_nonneg (2 * n)
