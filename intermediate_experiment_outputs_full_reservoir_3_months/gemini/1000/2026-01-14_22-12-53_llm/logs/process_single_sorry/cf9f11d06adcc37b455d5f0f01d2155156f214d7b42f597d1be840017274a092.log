set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1979_p1 (p q : ℕ) (h₀ : 0 < q)
  (h₁ : (∑ k ∈ Finset.Icc (1 : ℕ) 1319, (-1) ^ (k + 1) * ((1 : ℝ) / k)) = p / q) : 1979 ∣ p := by
  have h_prime : (1979 : ℕ).Prime := by norm_num
  have h_id : (p : ℚ) / q = ∑ k in Finset.Icc 660 1319, 1 / k := by
    have : ∀ n > 0, ∑ k in Finset.Icc 1 (2 * n - 1), (-1 : ℚ) ^ (k + 1) / k = ∑ k in Finset.Icc n (2 * n - 1), 1 / k := by
      intro n hn; induction' n, hn using Nat.le_induction with n hn ih; · simp
      rw [Finset.sum_Icc_succ_top (by linarith), Finset.sum_Icc_succ_top (by linarith), ih, Finset.sum_Icc_succ_top (by linarith), Finset.sum_Icc_succ_top (by linarith), Finset.sum_Icc_insert_at_front (by linarith)]
      field_simp; ring
    norm_cast at h₁; rw [← h₁]; exact this 660 (by norm_num)
  let B : ℕ := ∏ k in Finset.Icc 660 1319, k
  let A : ℕ := ∑ k in Finset.Icc 660 1319, B / k
  have h_pB : p * B = q * A := by
    apply (Rat.coe_nat_inj _ _).mp; push_cast
    rw [h_id, Finset.sum_div, Finset.mul_sum]
    refine Finset.sum_congr rfl (λ k hk => ?_)
    have : k ∣ B := Finset.dvd_prod_of_mem (λ i => i) hk
    simp [Nat.cast_div this, h₀.ne', (Finset.prod_pos (λ k hk => by linarith [Finset.mem_Icc.mp hk])).ne']
  have h_B_mod : (B : ZMod 1979) ≠ 0 := by
    simp [B, h_prime.pair_ne, Finset.prod_ne_zero_iff]
    intro k hk; exact (h_prime.not_dvd_one.mpr (by linarith [Finset.mem_Icc.mp hk])).ne'
  have h_A_mod : (A : ZMod 1979) = 0 := by
    simp [A, ← ZMod.coe_nat_cast, Nat.cast_div__iff_mul_eq (λ k hk => Finset.dvd_prod_of_mem _ hk), ← ZMod.inv_mul_eq_div]
    rw [← Finset.mul_sum, Finset.sum_Icc_reflect (λ k => (k : ZMod 1979)⁻¹)]
    simp [← Finset.sum_add_distrib, add_inv_allowed, (by norm_num : 1319 + 660 = 1979)]
  have : (p : ZMod 1979) * B = 0 := by rw [← Nat.cast_mul, h_pB, Nat.cast_mul, h_A_mod, mul_zero]
  exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd p 1979).mp (mul_eq_zero.mp this |>.resolve_right h_B_mod)

