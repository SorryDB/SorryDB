/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 := by
  let s : ℂ := -2 * n
  have h_zeta : riemannZeta = fun z => (2 ^ z * π ^ (z - 1) * Gamma (1 - z) * riemannZeta (1 - z)) * sin (π * z / 2) :=
    funext (fun z => by rw [riemannZeta_functional_equation, mul_comm])
  have hg : (fun z => sin (π * z / 2)) s = 0 := by
    simp [s, Complex.sin_neg, Complex.sin_nat_mul_pi]
  have hf : DifferentiableAt ℂ (fun z => 2 ^ z * π ^ (z - 1) * Gamma (1 - z) * riemannZeta (1 - z)) s := by
    repeat' apply DifferentiableAt.mul
    · apply differentiableAt_cpow_const; left; norm_num
    · apply DifferentiableAt.cpow_const; apply DifferentiableAt.sub_const; apply differentiableAt_id; left; exact Complex.pi_ne_zero
    · apply DifferentiableAt.Gamma; simp [s]; linarith [show (n : ℝ) > 0 from Nat.cast_pos.mpr hn]
    · apply differentiableAt_riemannZeta; simp [s]; linarith [show (n : ℝ) > 0 from Nat.cast_pos.mpr hn]
  have hg' : HasDerivAt (fun z => sin (π * z / 2)) (π / 2 * (-1 : ℂ) ^ n) s := by
    convert (hasDerivAt_sin (π * s / 2)).comp s (hasDerivAt_mul_const (π / 2)) using 1
    simp [s, Complex.cos_neg, Complex.cos_nat_mul_pi]
  rw [h_zeta, deriv_mul_eq_right_of_eval_eq_zero hg hf hg'.differentiableAt, hg'.deriv]
  repeat' apply mul_ne_zero
  · exact Complex.cpow_ne_zero 2 s (by norm_num)
  · exact Complex.cpow_ne_zero Complex.pi (s - 1) Complex.pi_ne_zero
  · apply Gamma_ne_zero; simp [s]; linarith [show (n : ℝ) > 0 from Nat.cast_pos.mpr hn]
  · apply riemannZeta_ne_zero_of_one_lt_re; simp [s]; linarith [show (n : ℝ) > 0 from Nat.cast_pos.mpr hn]
  · exact div_ne_zero Complex.pi_ne_zero two_ne_zero
  · exact pow_ne_zero n (by norm_num)

```
