theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  if h : biasedIsFixedPoint net x then
    exact ⟨BiasedUpdateSeq.nil x, h⟩
  else
    let i := Classical.choose (Classical.not_forall.mp h)
    let next_x := biasedUpdateState net x i
    let ⟨seq, hseq⟩ := biased_asynchronous_update_convergence next_x
    exact ⟨BiasedUpdateSeq.cons x i seq, hseq⟩
termination_by x => (Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net x)).card
decreasing_by
  simp_wf; apply Finset.card_lt_card; rw [Finset.ssubset_iff]
  let i := Classical.choose (Classical.not_forall.mp h)
  let next_x := biasedUpdateState net x i
  have hlt : biasedEnergy net next_x < biasedEnergy net x :=
    (biasedEnergy_decreasing net x i).lt_of_ne (by
      rw [ne_comm, ← biasedEnergy_fixed_point_iff_no_change]
      exact Classical.choose_spec (Classical.not_forall.mp h))
  refine ⟨next_x, by simp [hlt], fun y hy => ?_⟩
  simp at hy ⊢; exact hy.trans hlt
