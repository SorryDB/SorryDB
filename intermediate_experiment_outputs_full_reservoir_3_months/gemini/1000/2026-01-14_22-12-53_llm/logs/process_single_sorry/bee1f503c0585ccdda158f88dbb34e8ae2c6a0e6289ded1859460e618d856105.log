```lean
theorem imo_1979_p6.parts.odd
    -- We label the vertices of an octagon by `Fin 8`.
    -- (Let's also say for later that jumping 0 -> 1 -> 2 -> .. is in the clockwise direction)
    (A E : Fin 8)
    -- `E` is the opposite of `A`
    (hE : E = A + 4)
    -- Let `a` be the function such that `a n` is the number of distinct sequences of `n` jumps
    -- ending exactly at `E`.
    (a : ℕ → ℕ)
    -- We formulate a path as a function `Fin n → Fin 2`, where `p i = 0` means that the `i+1`th
    -- jump is clockwise.
    (ha_def : ∀ n, a n =
      Fintype.card {p : Fin n → ℤˣ // A + ∑ i, (p i : Fin 8) = E})
    (n : ℕ) (hn : 0 < n) :
    a (2*n - 1 : ℕ) = 0 := by
  rw [ha_def, Fintype.card_eq_zero_iff]
  rintro ⟨p, hp⟩
  let f : Fin 8 →+* ZMod 2 := ZMod.castHom (by norm_num) (ZMod 2)
  have hf : ∀ i, f (↑↑(p i)) = 1 := by
    intro i
    rcases Units.val_eq_one_or_neg_one (p i) with h | h <;> simp [h]
  have h_sum := congr_arg f hp
  simp [hE, map_sum, hf] at h_sum
  have h_dv : 2 ∣ 2 * n - 1 := (ZMod.natCast_eq_zero_iff_dvd (2 * n - 1) 2).mp h_sum
  omega
```
