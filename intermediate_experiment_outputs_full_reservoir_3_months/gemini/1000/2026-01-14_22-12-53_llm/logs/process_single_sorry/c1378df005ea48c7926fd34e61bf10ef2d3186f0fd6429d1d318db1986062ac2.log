open Classical in
instance : AdjointSpace 𝕜 ((i : ι) → E i) where
  inner := fun x y => ∑ i, ⟪x i, y i⟫_𝕜
  inner_top_equiv_norm := by
    choose c d hc hd hcd using fun i => AdjointSpace.inner_top_equiv_norm (𝕜:=𝕜) (E:=E i)
    by_cases hι : Nonempty ι
    · use Finset.univ.inf' hι c, ∑ i, d i
      refine ⟨by simp [hc], Finset.sum_pos (fun i _ => hd i) (Finset.univ_nonempty.mpr hι), fun x => ?_⟩
      obtain ⟨i₀, -, hi₀⟩ := Finset.exists_mem_arg_max Finset.univ (fun i => ‖x i‖) (Finset.univ_nonempty.mpr hι)
      constructor
      · calc (Finset.univ.inf' hι c) • ‖x‖ ^ 2
            ≤ c i₀ * ‖x i₀‖ ^ 2 := by rw [hi₀]; exact mul_le_mul_of_nonneg_right (Finset.inf'_le _ (Finset.mem_univ i₀)) (by positivity)
          _ ≤ re ⟪x i₀, x i₀⟫ := (hcd i₀ (x i₀)).1
          _ ≤ ∑ i, re ⟪x i, x i⟫ := Finset.single_le_sum (fun i _ => inner_self_nonneg) (Finset.mem_univ i₀)
          _ = re ⟪x, x⟫ := by rw [map_sum]
      · calc re ⟪x, x⟫ = ∑ i, re ⟪x i, x i⟫ := by rw [map_sum]
          _ ≤ ∑ i, d i * ‖x i‖ ^ 2 := Finset.sum_le_sum (fun i _ => (hcd i _).2)
          _ ≤ ∑ i, d i * ‖x‖ ^ 2 := Finset.sum_le_sum (fun i _ => mul_le_mul_of_nonneg_left (pow_le_pow_left (norm_nonneg _) (norm_le_pi_norm _ _) _) (hd i).le)
          _ = (∑ i, d i) • ‖x‖ ^ 2 := by rw [Finset.sum_mul]; rfl
    · use 1, 1, by norm_num, by norm_num, fun x => by
        have : ‖x‖ = 0 := by simp [Pi.norm_def, hι]
        simp [this, hι, map_sum]
