import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have h_pos : (p : ℝ) > 0 := by
    rw [hp]
    have h_nonneg : ∀ i, 0 ≤ dist (P i) (P (i + 1)) := fun i => dist_nonneg
    have h_not_all_zero : ∃ i, 0 < dist (P i) (P (i + 1)) := by
      use 0; refine dist_pos.mpr ?_; intro h; have := hP 1 2 (by simp; omega) (by simp); rw [←h] at this; simp at this
    exact Finset.sum_pos (λ i _ => h_nonneg i) (Finset.mem_univ_iff.mpr (by use 0; simp)) h_not_all_zero
  constructor
  · rw [show (2 * d / p : ℝ) = (∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j)) / p by field_simp [hd]]
    suffices ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j) > (n - 3) * p by
      exact (lt_div_iff h_pos).mpr this
    have h_star : ∀ k : ℕ, 1 < k ∧ k < n - 1 → ∑ i : Fin n, dist (P i) (P (i + k)) > p := by sorry
    rw [show ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j) = ∑ k in Finset.Icc 2 (n - 2), ∑ i : Fin n, dist (P i) (P (i + k)) by sorry]
    have h_count : (Finset.Icc 2 (n - 2)).card = n - 3 := by rw [Finset.card_Icc]; omega
    refine (n - 3 : ℝ).sum_induction (λ s => s > (n - 3) * p) (by sorry) (by sorry) (by sorry)
    sorry
  · rw [show (2 * d / p : ℝ) = (∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j)) / p by field_simp [hd]]
    suffices ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j) < (⌊(n : ℝ) / 2⌋ * ⌊((n : ℝ) + 1) / 2⌋ - 2) * p by
      exact (div_lt_iff h_pos).mpr this
    have h_dist_bound : ∀ i j, dist (P i) (P j) < (p : ℝ) / 2 := by sorry
    have h_diag_sum : ∀ k : ℕ, 1 < k ∧ k < n - 1 → ∑ i : Fin n, dist (P i) (P (i + k)) < (if n % 2 = 0 ∧ k = n / 2 then (n / 2) * p else (min k (n - k)) * p) := by sorry
    sorry
