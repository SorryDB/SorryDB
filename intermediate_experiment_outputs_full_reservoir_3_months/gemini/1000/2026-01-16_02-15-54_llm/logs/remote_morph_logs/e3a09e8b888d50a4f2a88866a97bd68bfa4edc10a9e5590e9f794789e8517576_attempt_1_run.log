instance : HasLimitsOfSize.{0, 0} Solid where
  has_limits_of_shape J _ := {
    has_limit := fun F ↦
      letI : IsSolid (limit (F ⋙ solidToCondensed)) := ⟨by
        let f := oneMinusShift ℤ
        let i := PreservesLimit.iso (ihom (P ℤ)) (F ⋙ solidToCondensed)
