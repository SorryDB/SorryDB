def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext; constructor
  · rintro rfl; unfold beq; induction w - 1 <;> simp [beq.go, *]
  · intro h; apply BitVec.eq_of_getLsbD_eq; intro i hi; unfold beq at h
    let m := w - 1
    have : ∀ n, beq.go x y n = true → ∀ j, m - n ≤ j ∧ j ≤ m → x.getLsbD j = y.getLsbD j := by
      intro n hgo; induction n with
      | zero => intro j hj; have : j = m := by omega; simp_all [beq.go]
      | succ n ih =>
        intro j hj; simp [beq.go] at hgo
        if h_j : j = m - (n + 1) then simp_all
        else apply ih hgo.2 j; omega
    apply this m h i; omega
```
