def beq (x : BitVec w) (y : BitVec w) : Bool :=
  go (w - 1)
where
  go : Nat → Bool
    | 0     => x.getLsbD (w - 1) == y.getLsbD (w - 1)
    | i + 1 => x.getLsbD ((w - 1) - (i + 1)) == y.getLsbD ((w - 1) - (i + 1)) && go i

def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext; constructor
  · intro h; subst h; induction w - 1 with
    | zero => simp [beq, beq.go]
    | succ i ih => simp [beq, beq.go, ih]
  · intro h; apply BitVec.eq_of_getLsbD; intro i hi
    have help : ∀ k, beq.go x y k → ∀ j ≤ k, x.getLsbD (w - 1 - j) = y.getLsbD (w - 1 - j) := by
      intro k; induction k with
      | zero => intro h j hj; simp [beq.go] at h; rwa [Nat.le_zero_eq.mp hj]
      | succ k ih => intro h j hj; simp [beq.go] at h; cases hj with
        | refl => exact h.1
        | step hj => exact ih h.2 _ hj
    cases w with
    | zero => cases hi
    | succ w' =>
      have h := help w' h (w' - i) (Nat.sub_le _ _)
      rwa [Nat.sub_sub_self (Nat.le_of_lt_succ hi)] at h
```
