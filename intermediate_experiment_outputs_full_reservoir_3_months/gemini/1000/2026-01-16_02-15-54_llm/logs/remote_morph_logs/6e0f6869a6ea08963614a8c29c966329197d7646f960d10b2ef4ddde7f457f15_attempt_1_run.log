def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = (x.beq y = true) := by
  apply propext; constructor
  · intro h; subst h; unfold beq; induction w - 1 <;> simp [beq.go, *]
  · intro h; apply BitVec.eq_of_getLsbD; intro i
    if hi : i < w then
      unfold beq at h; let n := w - 1; have hi' : i ≤ n := Nat.le_sub_one_of_lt hi
      have : ∀ j k, k ≤ j → beq.go x y j = true → x.getLsbD (n - k) = y.getLsbD (n - k) := by
        intro j k hk hj; induction j arbitrary: k with
        | zero => have := Nat.eq_zero_of_le_zero hk; subst k; simp [beq.go] at hj; exact hj
        | succ j ih =>
          simp [beq.go] at hj; cases Nat.eq_or_lt_of_le hk with
          | inl h_eq => subst h_eq; simp [hj]
          | inr h_lt => exact ih _ (Nat.le_of_lt_succ h_lt) hj.2
      have := this n (n - i) (Nat.sub_le n i) h
      rwa [Nat.sub_sub_self hi'] at this
    else simp [BitVec.getLsbD_ge hi]
```
