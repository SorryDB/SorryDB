def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext; constructor
  · rintro rfl; unfold beq
    induction w - 1 <;> simp [beq.go, *]
  · intro h; apply BitVec.ext; intro i hi
    unfold beq at h
    let rec go_spec n j (h : beq.go n) (hj : j ≤ n) : x.getLsbD (w - 1 - j) = y.getLsbD (w - 1 - j) :=
      match n, j with
      | 0, _ => by simpa [beq.go] using h
      | n + 1, j => by
        simp [beq.go] at h
        if hj' : j = n + 1 then exact h.1
        else exact go_spec n j h.2 (Nat.le_of_lt_succ (Nat.lt_of_le_of_ne hj hj'))
    have hi' := Nat.le_sub_one_of_lt hi
    rw [← Nat.sub_sub_self hi', go_spec (w - 1) (w - 1 - i) h (Nat.sub_le _ _)]
```
