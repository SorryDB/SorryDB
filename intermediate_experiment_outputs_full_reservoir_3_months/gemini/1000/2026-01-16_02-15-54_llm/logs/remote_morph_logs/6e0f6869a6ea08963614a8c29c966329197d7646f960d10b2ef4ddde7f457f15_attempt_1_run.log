    have hb : ∀ n j, beq.go x y n = true → j ≤ n → x.getLsbD ((w - 1) - j) = y.getLsbD ((w - 1) - j) := by
      intro n j hn hj; induction n generalizing j with
      | zero => cases Nat.le_zero.1 hj; simp [beq.go] at hn; exact hn
      | succ n ih =>
        simp [beq.go] at hn
        if hj : j = n + 1 then simp [hj, hn.1] else exact ih j hn.2 (by omega)
    have := hb (w - 1) (w - 1 - i) h (by omega)
    rw [Nat.sub_sub_self (by omega)] at this; exact this
