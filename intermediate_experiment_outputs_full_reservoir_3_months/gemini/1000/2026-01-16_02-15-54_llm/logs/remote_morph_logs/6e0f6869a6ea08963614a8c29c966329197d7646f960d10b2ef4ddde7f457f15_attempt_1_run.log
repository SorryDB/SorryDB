def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext; constructor
  · rintro rfl; simp [beq]; induction (w - 1) <;> simp [beq.go, *]
  · intro h; apply BitVec.eq_of_getLsbD; intro i hi
    simp [beq] at h
    let rec spec n (h : beq.go x y n = true) (hn : (w - 1) - n ≤ i) : x.getLsbD i = y.getLsbD i :=
      match n with
      | 0 => by
        have : i = w - 1 := Nat.le_antisymm (Nat.le_sub_one_of_lt hi) hn
        simpa [this, beq.go] using h
      | n + 1 => by
        simp [beq.go] at h
        if heq : i = (w - 1) - (n + 1) then simpa [heq] using h.1
        else
          apply spec n h.2
          if h_wn : n + 1 ≤ w - 1 then
            exact Nat.le_of_lt_succ (Nat.sub_lt_sub_left h_wn (Nat.lt_succ_self n) ▸ Nat.lt_of_le_of_ne hn (Ne.symm heq))
          else
            exact (Nat.sub_eq_zero_of_le (Nat.le_of_not_lt h_wn)).symm ▸ Nat.zero_le _
    exact spec (w - 1) h (Nat.zero_le _)
