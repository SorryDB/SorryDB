  intro h
  specialize hf c (-f c / 2) (by bound)
  choose δ hδpos hδ using hf
  have cpd : c + δ / 2 ≤ b := by
    by_contra hb
    push_neg at hb
    have hbc : |b - c| < δ := by
      rewrite [abs_lt]
      split_ands
      linarith [c_le_b, hδpos]
