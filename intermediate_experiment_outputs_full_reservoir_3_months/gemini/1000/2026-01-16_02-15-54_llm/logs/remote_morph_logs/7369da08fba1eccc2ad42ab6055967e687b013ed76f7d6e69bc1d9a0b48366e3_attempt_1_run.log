/-- Addition operation for points on the elliptic curve -/
def MordellWeilGroup.add (P Q : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point, Q.point with
  | none, _ => Q  -- P is infinity, so P + Q = Q
  | _, none => P  -- Q is infinity, so P + Q = P
  | some (x₁, y₁), some (x₂, y₂) =>
    if x₁ = x₂ then
      if y₁ + y₂ + E.val.a₁*x₁ + E.val.a₃ = 0 then
        -- P and Q are negatives of each other
        MordellWeilGroup.infinity E
      else
        -- Point doubling
        match MordellWeilGroup.slope E P Q with
        | none => MordellWeilGroup.infinity E
        | some s =>  -- Changed λ to s (for slope)
          let W := E.val
          let x₃ := s^2 + W.a₁*s - W.a₂ - x₁ - x₂
          let y₃ := s*(x₁ - x₃) - y₁ - W.a₁*x₃ - W.a₃
          MordellWeilGroup.mk_point E x₃ y₃ (by
            have hP := P.on_curve x₁ y₁ rfl
            have hQ := Q.on_curve x₂ y₂ rfl
            unfold MordellWeilGroup.slope at *; split_ifs at *
            injection ‹MordellWeilGroup.slope E P Q = some s› with h; subst h x₃ y₃
            have : y₁ = y₂ := by
              have h₁ : y₁^2 + (E.val.a₁ * x₁ + E.val.a₃) * y₁ = y₂^2 + (E.val.a₁ * x₁ + E.val.a₃) * y₂ := by
                rw [‹x₁ = x₂›] at hP; rw [hP, hQ]
              exact eq_of_mul_eq_zero_left (by rw [show (y₁ - y₂) * (y₁ + y₂ + E.val.a₁ * x₁ + E.val.a₃) = y₁^2 + (E.val.a₁ * x₁ + E.val.a₃) * y₁ - (y₂^2 + (E.val.a₁ * x₁ + E.val.a₃) * y₂) by ring, h₁]; ring) ‹_ ≠ 0›
            subst this; field_simp; ring)
