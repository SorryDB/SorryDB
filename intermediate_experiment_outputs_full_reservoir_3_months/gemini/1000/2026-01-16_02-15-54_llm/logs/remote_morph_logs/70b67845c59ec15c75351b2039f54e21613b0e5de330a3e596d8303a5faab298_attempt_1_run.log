/-- Every convex set in ℝⁿ⁺¹ has VC₂ dimension at most 1. -/
lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨4, fun C hC x y hxy ↦
    let x' (i : Fin 4) : Fin n → ℕ := fun k ↦ if k = 0 then i else 0
    let y' (s : Set (Fin 4)) : Set (Fin n → ℕ) := {j | ∃ i ∈ s, x' i = j}
    let x'' (i : Fin 4) : Fin (n + 1) → ℝ := ∑ k, x k (x' i k)
    let y'' (s : Set (Fin 4)) : Fin (n + 1) → ℝ := y (y' s)
    have h (i s) : x'' i + y'' s ∈ C ↔ i ∈ s := by
      rw [x'', y'', hxy]
      simp [x', y', Function.Injective.mem_set_image (fun i j h ↦ by simpa [x', Function.funext_iff] using h)]
    sorry⟩
```
