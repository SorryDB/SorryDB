/-- Every convex set in ℝⁿ⁺¹ has VC₂ dimension at most 1. -/
lemma exists_vcn_le_of_convex_rn_add_one (n : ℕ) :
    ∃ d : ℕ, ∀ (C : Set (Fin (n + 1) → ℝ)) (hC : Convex ℝ C) (x : Fin n → ℕ → Fin (n + 1) → ℝ)
      (y : Set (Fin n → ℕ) → Fin (n + 1) → ℝ) (hxy : ∀ i s, ∑ k, x k (i k) + y s ∈ C ↔ i ∈ s),
        False :=
  ⟨2, fun _ hC _ _ hxy ↦ by
    let i0 : Fin n → ℕ := fun _ ↦ 0
    let i1 : Fin n → ℕ := fun _ ↦ 1
    let s : Set (Fin n → ℕ) := {i0, i1}
    let p0 := ∑ k, x k (i0 k)
    let p1 := ∑ k, x k (i1 k)
    let y0 := y {i0}
    let y1 := y {i1}
    let ys := y s
    let y_empty := y ∅
    have h0 : p0 + y0 ∈ C := (hxy i0 {i0}).2 (Set.mem_singleton i0)
    have h1 : p1 + y1 ∈ C := (hxy i1 {i1}).2 (Set.mem_singleton i1)
    have hs0 : p0 + ys ∈ C := (hxy i0 s).2 (Set.mem_insert i0 {i1})
    have hs1 : p1 + ys ∈ C := (hxy i1 s).2 (Set.mem_insert_of_mem i0 (Set.mem_singleton i1))
    have h_not0 : p0 + y1 ∉ C := (hxy i0 {i1}).1.mt (fun h ↦ by cases h <;> contradiction)
    have h_not1 : p1 + y0 ∉ C := (hxy i1 {i0}).1.mt (fun h ↦ by cases h <;> contradiction)
    have h_not_empty0 : p0 + y_empty ∉ C := (hxy i0 ∅).1.mt (Set.not_mem_empty i0)
    have h_not_empty1 : p1 + y_empty ∉ C := (hxy i1 ∅).1.mt (Set.not_mem_empty i1)
    sorry⟩
