        sorry), sorry⟩
lemma restrict_winning (h : S.pre.IsWinning (G := interGame V PO)) :
    (restrict hWV hW S).pre.IsWinning (G := interGame W PO) := by
    intro x hx; apply h; exact restrict_tree hWV hW S x hx
