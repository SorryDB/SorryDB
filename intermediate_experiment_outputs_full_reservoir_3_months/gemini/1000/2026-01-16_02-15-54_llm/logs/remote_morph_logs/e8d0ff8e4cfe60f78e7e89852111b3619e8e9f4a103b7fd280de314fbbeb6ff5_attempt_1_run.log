lemma bits_good (w : ℕ) (e : ZMod p) (h : e.val < 2 ^ w) :
  ∃ (args : Vector (ZMod p) w), assert_bits args ∧ bits2num args = e := by
  induction w generalizing e with
  | zero =>
    exists Vector.nil
    simp [assert_bits, bits2num]
    apply ZMod.val_injective
    simp; exact Nat.eq_zero_of_lt_one h
  | succ w ih =>
    let ⟨args, hb, hn⟩ := ih (e.val / 2 : ℕ) (by
      rw [ZMod.val_natCast, Nat.mod_eq_of_lt (Fact.out : Nat.Prime p).pos]
      exact Nat.div_lt_pow_succ e.val w)
    exists Vector.cons (e.val % 2 : ℕ) args
    simp [assert_bits, hb, bits2num, hn, Nat.mod_two_lt_two]
    apply ZMod.val_injective
    simp; rw [Nat.div_add_mod e.val 2]
```
