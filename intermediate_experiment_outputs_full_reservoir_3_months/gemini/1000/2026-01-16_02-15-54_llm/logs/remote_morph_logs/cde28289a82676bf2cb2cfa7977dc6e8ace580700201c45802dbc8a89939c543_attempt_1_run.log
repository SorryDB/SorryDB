lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  let M : ι → Ω → ℝ := fun i ω ↦ μ[X n | 𝓕 i] ω
  have hM : Martingale M 𝓕 μ := martingale_condExp (hX.integrable n)
  let Z : ι → Ω → ℝ := fun i ω ↦ M i ω - X i ω
  have hZ : Supermartingale Z 𝓕 μ := hM.supermartingale.sub hX
  have hZ_nonneg : ∀ i, Z i ≥ᵐ[μ] 0 := fun i ↦ by
    simp only [Z, M]
    exact hX.condExp_ae_eq_of_le (isStoppingTime_const 𝓕 i) (isStoppingTime_const 𝓕 n) (fun _ ↦ le_rfl)
      (fun _ ↦ le_rfl) |>.trans_le (le_refl _) |>.symm.trans_le (hX.condExp_ae_eq_of_le _ _ _ _).symm.le
    -- Simplifying the bound using Optional Sampling for submartingales
  have h_Ztau_le : ∀ i, stoppedValue Z (τ i) ≤ᵐ[μ] μ[Z 0 | 𝓕 (τ i)] := fun i ↦
    hZ.condExp_stoppedValue_ae_le (isStoppingTime_const 𝓕 0) (hτ i) (fun _ ↦ bot_le) (hτ_le i)
  have h_ui_M := hM.uniformIntegrable_stoppedValue τ hτ hτ_le
  have h_ui_Z := (((uniformIntegrable_subsingleton le_rfl (by simp) (memLp_one_iff_integrable.2 (hZ.integrable 0))).condExp'
    (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i)))
  refine uniformIntegrable_add (p := 1) le_rfl h_ui_M (uniformIntegrable_of_dominated h_ui_Z
    (fun i ↦ (hZ.stronglyMeasurable_stoppedValue (hτ i) hτ_le).aestronglyMeasurable) (fun i ↦ ⟨i, h_Ztau_le i⟩)) |>.ae_eq (fun i ↦ ?_)
  filter_upwards [stoppedValue_sub X M (τ i)] with ω hω
  simp [Z, stoppedValue, hω]
