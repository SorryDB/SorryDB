lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
  have hX_int : ∀ i, Integrable (X i) μ := fun i ↦ hX.integrable i
  have hX_pos : Submartingale (fun t ω ↦ (X t ω)⁺) 𝓕 μ :=
    hX.convex_increasing (fun x ↦ x⁺) (fun _ _ hxy ↦ hxy.pos) (fun _ ↦ convex_pos)
      (fun i ↦ (hX_int i).pos)
  have hX_pos_ui : UniformIntegrable (fun i ↦ (stoppedValue X (τ i))⁺) 1 μ :=
    uniformIntegrable_of_dominated (κ := ℕ)
      (((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ (X n)⁺) le_rfl (by simp)
        (memLp_one_iff_integrable.2 (hX_int n).pos)).condExp'
        (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i)))
      (fun i ↦ (hτ i).aestronglyMeasurable_stoppedValue hX_pos.stronglyMeasurable)
      (fun i ↦ ⟨i, (hτ i).stoppedValue_le_condExp hX_pos (isStoppingTime_const _ n) (hτ_le i)
        (fun _ ↦ le_rfl) |>.mono (fun ω hω ↦ by
        rw [← stoppedValue_pos, Real.norm_coe_nat, Real.norm_eq_abs, abs_of_nonneg (stoppedValue_nonneg _ _)]
        exact hω.trans (le_abs_self _))⟩)
  have hX_ui : UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
    uniformIntegrable_of_dominated (κ := ℕ × Fin 2)
      ((((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ (X n)⁺ + (X n)⁻ + (X 0)⁻) le_rfl (by simp)
        (memLp_one_iff_integrable.2 <| ((hX_int n).pos.add (hX_int n).neg).add (hX_int 0).neg)).condExp'
        (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))).add
        (uniformIntegrable_const le_rfl (by simp) (memLp_one_iff_integrable.2 (hX_int 0).norm)))
      (fun i ↦ (hτ i).aestronglyMeasurable_stoppedValue hX.stronglyMeasurable)
      (fun i ↦ ⟨i, Filter.eventually_of_forall fun ω ↦ sorry⟩)
  hX_ui
