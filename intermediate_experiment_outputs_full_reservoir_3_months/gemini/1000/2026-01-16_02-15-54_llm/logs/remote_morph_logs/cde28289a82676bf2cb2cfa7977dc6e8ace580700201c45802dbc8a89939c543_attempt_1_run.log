```lean
lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
  let M := fun i ↦ μ[X n | (hτ i).measurableSpace]
  let hM : UniformIntegrable M 1 μ :=
    ((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X n) le_rfl (by simp)
      (memLp_one_iff_integrable.2 (hX.integrable n))).condExp'
      (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))
  have h_le : ∀ i, stoppedValue X (τ i) ≤ᵐ[μ] M i :=
    fun i ↦ stoppedValue_ae_le_condExp_of_le hX (isStoppingTime_const 𝓕 n) (hτ i) (hτ_le i) (fun _ ↦ le_rfl)
  have h_ge : ∀ i, μ[X ⊥ | (hτ i).measurableSpace] ≤ᵐ[μ] stoppedValue X (τ i) :=
    fun i ↦ condExp_le_stoppedValue_ae hX (isStoppingTime_const 𝓕 ⊥) (hτ i) (fun _ ↦ bot_le)
  uniformIntegrable_iff_norm (fun i ↦ (hτ i).aestronglyMeasurable_stoppedValue) |>.2 <|
    uniformIntegrable_of_dominated (hM.norm.add (((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X ⊥)
      le_rfl (by simp) (memLp_one_iff_integrable.2 (hX.integrable ⊥))).condExp'
      (fun i ↦ (hτ i).measurableSpace_le)).comp (fun i ↦ ((), i))).norm)
      (fun i ↦ (hτ i).aestronglyMeasurable_stoppedValue.norm)
      (fun i ↦ ⟨i, by
        filter_upwards [h_le i, h_ge i] with ω hle hge
        rw [Real.norm_eq_abs, abs_le]
        constructor
        · calc -(|M i ω| + |μ[X ⊥ | (hτ i).measurableSpace] ω|)
            _ ≤ -|μ[X ⊥ | (hτ i).measurableSpace] ω| := by simp
            _ ≤ μ[X ⊥ | (hτ i).measurableSpace] ω := neg_abs_le_self _
            _ ≤ stoppedValue X (τ i) ω := hge
        · calc stoppedValue X (τ i) ω
            _ ≤ M i ω := hle
            _ ≤ |M i ω| := le_abs_self _
            _ ≤ |M i ω| + |μ[X ⊥ | (hτ i).measurableSpace] ω| := by simp ⟩)
```
