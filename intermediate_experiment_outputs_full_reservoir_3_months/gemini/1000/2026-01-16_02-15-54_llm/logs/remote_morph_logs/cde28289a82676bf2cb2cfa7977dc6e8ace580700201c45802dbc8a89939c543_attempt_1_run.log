```lean
lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
  let M := fun (p : Unit × ℕ) ↦ μ[X n | (hτ p.2).measurableSpace]
  have hM : UniformIntegrable M 1 μ :=
    (uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X n) le_rfl (by simp)
      (memLp_one_iff_integrable.2 (hX.integrable n))).condExp' (fun i ↦ (hτ i).measurableSpace_le)
  let W := fun (p : Unit × ℕ) ↦ μ[X ⊥ | (hτ p.2).measurableSpace]
  have hW : UniformIntegrable W 1 μ :=
    (uniformIntegrable_subsingleton (f := fun _ : Unit ↦ X ⊥) le_rfl (by simp)
      (memLp_one_iff_integrable.2 (hX.integrable ⊥))).condExp' (fun i ↦ (hτ i).measurableSpace_le)
  have h_bdd i : ‖stoppedValue X (τ i)‖ ≤ᵐ[μ] ‖M ((), i)‖ + ‖W ((), i)‖ := by
    filter_upwards [stoppedValue_ae_le_condExp_of_le hX (isStoppingTime_const 𝓕 n) (hτ i) (hτ_le i) (fun _ ↦ le_rfl),
      condExp_stoppedValue_ae_ge hX (isStoppingTime_const 𝓕 ⊥) (hτ i) (fun _ ↦ bot_le)] with ω hle hge
    rw [Real.norm_eq_abs, abs_le]; constructor
    · exact (neg_le_neg (le_abs_self _)).trans (neg_abs_le_self _ |>.trans hge)
    · exact hle.trans (le_abs_self _) |>.trans (le_add_of_nonneg_right (abs_nonneg _))
  uniformIntegrable_of_dominated (hM.norm.add hW.norm).comp (fun i ↦ ((), i))
    (fun i ↦ (hτ i).aestronglyMeasurable_stoppedValue) (fun i ↦ ⟨i, h_bdd i⟩)
```
Final check, `condExp_stoppedValue_ae_ge` is the most common name for $E[X_\tau | \mathcal{F}_\sigma] \ge X_\sigma$ related things.

