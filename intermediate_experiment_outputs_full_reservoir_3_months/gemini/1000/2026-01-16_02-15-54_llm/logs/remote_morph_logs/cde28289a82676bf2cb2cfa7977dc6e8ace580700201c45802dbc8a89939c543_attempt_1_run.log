lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
  have hXn : MemLp (X n) 1 μ := memLp_one_iff_integrable.2 (hX.integrable n)
  have hX0 : MemLp (X 0) 1 μ := memLp_one_iff_integrable.2 (hX.integrable 0)
  have h_m : ∀ i, AEStronglyMeasurable (stoppedValue X (τ i)) μ :=
    fun i ↦ (hτ i).aeStronglyMeasurable_stoppedValue hX.aeStronglyMeasurable
  uniformIntegrable_of_dominated
    ((uniformIntegrable_subsingleton (f := fun _ : Unit ↦ ‖X n‖ + ‖X 0‖) le_rfl (by simp)
      (hXn.norm.add hX0.norm)).condExp' (fun i ↦ (hτ i).measurableSpace_le)) h_m
