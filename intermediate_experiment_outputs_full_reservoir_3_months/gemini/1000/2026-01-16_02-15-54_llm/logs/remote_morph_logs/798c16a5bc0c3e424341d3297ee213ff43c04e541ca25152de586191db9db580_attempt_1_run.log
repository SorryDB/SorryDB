              · cases hd ; aesop;
                · exact mem_of_mem_head? rfl;
                · (expose_names; exact mem_of_mem_tail (p_ih d h_1));
            exact List.mem_toFinset.mpr ( h_support _ _ hd₁ ) ) ;
