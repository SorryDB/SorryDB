import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k
  induction' k with k ih
  · exact ⟨1, Nat.zero_lt_one, by simp, by simp⟩
  · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
    if h : k = 0 then
      exact ⟨3, Nat.succ_pos 2, by simp, by linarith⟩
    else if h' : k = 1 then
      -- n must be 3^m, the only case where n | 2^n + 1 and card = 1.
      -- For n = 9, 2^9 + 1 = 513 = 19 * 27, so n' = 171 = 9 * 19 works.
      exact ⟨171, by linarith, by decide, by decide⟩
    else
      -- For k ≥ 2, n has at least 2 prime factors, so n ≥ 3 * 19 = 57.
      -- By Zsigmondy's Theorem, 2^(2n) - 1 has a prime factor p that does not divide 2^d - 1 for d < 2n.
      -- This p must divide 2^n + 1 and p > n, so p is a new prime factor.
      -- Then n' = n * p has k + 1 prime factors and n' | 2^n' + 1.
      sorry
