import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k : ℕ, ∃ n : ℕ, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k
  induction' k with k ih
  · exact ⟨1, by norm_num, by simp, by norm_num⟩
  · obtain ⟨n, n_pos, n_card, n_dvd⟩ := ih
    have n_odd : Odd n := by
      by_cases h1 : n = 1
      · rw [h1]; exact ⟨0, rfl⟩
      · have : 2 ∣ 2 ^ n := Nat.dvd_pow (by norm_num) (Nat.pos_of_ne_zero (by rintro rfl; contradiction))
        have : ¬ 2 ∣ 2 ^ n + 1 := by rw [Nat.dvd_add_right this]; norm_num
        exact Nat.odd_iff_not_even.mpr (mt Nat.even_iff_two_dvd.mp this)
    let m := 2 ^ n + 1
    have n_dvd_m : n ∣ m := n_dvd
    have m_odd : Odd m := ⟨2 ^ (n - 1), by rcases n_odd with ⟨j, rfl⟩; rcases j <| ⟨0, rfl⟩; norm_num; rw [← Nat.pow_succ]; congr; omega⟩
    have m_gt_n : n < m := (Nat.lt_pow_self one_lt_two n).trans_le (Nat.le_add_right _ _)
    let p := (m / n).minFac
    have m_div_n_gt_1 : 1 < m / n := Nat.one_lt_div_iff.mpr ⟨n_dvd_m, m_gt_n⟩
    have p_prime : p.Prime := Nat.minFac_prime (Nat.ne_of_gt m_div_n_gt_1)
    have p_dvd_m : p ∣ m := (Nat.minFac_dvd (m / n)).trans (Nat.div_dvd_of_dvd n_dvd_m)
    have p_not_dvd_n : ¬ p ∣ n := by
      intro p_dvd_n
      have p_dvd_2n : p ∣ 2 * n := p_dvd_n.trans (Nat.dvd_mul_left n 2)
      have p_dvd_2_pow_n : p ∣ 2 ^ n := by
        have : p ∣ (2 ^ n + 1) := p_dvd_m
        have : p ∣ (2 ^ n + 1) - 1 := by
          have : p ≥ 3 := p_prime.three_le m_odd.pow.mpr (by intro h; have := p_dvd_m; rw [h] at this; contradiction)
          sorry
        sorry
      sorry
    refine ⟨n * p, Nat.mul_pos n_pos p_prime.pos, ?_, ?_⟩
    · rw [Nat.primeFactors_mul n_pos.ne' p_prime.ne', n_card]
      have : p ∉ n.primeFactors := by
        rw [Nat.mem_primeFactors]; simp [p_prime, p_not_dvd_n]
      simp [this, p_prime]
    · have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
        apply Nat.dvd_pow_add_pow_of_odd n p 1 (by rwa [Nat.mul_one]) (p_prime.odd_of_ne (by rintro rfl; norm_num at p_dvd_m))
      exact (Nat.dvd_mul_right n p).trans (n_dvd_m.trans this)

