import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  rw [solution, iff_true]
  let S := {n : ℕ | 0 < n ∧ n ∣ 2 ^ n + 1}
  suffices ∀ k ≥ 1, ∃ n ∈ S, n.primeFactors.card = k ∧ 9 ≤ n from
    let ⟨n, hS, hω, _⟩ := this 2000 (by norm_num); ⟨n, hS.1, hω, hS.2⟩
  intro k hk; induction' k, hk using Nat.le_induction with k hk IH
  · exact ⟨9, ⟨by norm_num, by norm_num⟩, by norm_num, le_refl 9⟩
  · obtain ⟨n, ⟨hn0, hnd⟩, hω, hn9⟩ := IH
    obtain ⟨p, hp, hpd, hpn⟩ := Zsigmondy.exists_prime_factor_pow_sub_one_not_dvd_pow_sub_one 2 1 (2 * n) (by linarith) (by norm_num)
    have h1 : p ∣ 2 ^ n + 1 := (hp.dvd_or_dvd (pow_mul_two 2 n ▸ hpd)).resolve_left hpn
    have hord := Zsigmondy.is_primitive_root_pow_sub_one hp hpn hpd
    have h2 : p ∤ n := fun h => (by
      have := (hord.symm ▸ orderOf_le_card_sub_one hp.pos).trans (Nat.sub_le p 1)
      have := (Nat.le_of_dvd hn0 h).trans this; linarith : False)
    have h3 : Odd p := hp.odd_of_ne_two (fun h => by norm_num [h] at h1)
    have h4 : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
      rw [pow_mul]; exact Int.natCast_dvd_natCast.mp (h3.add_dvd_pow_add_pow (2 ^ n : ℤ) 1)
    refine ⟨n * p, ⟨by positivity, ?_⟩, ?_, ?_⟩
    · exact Nat.dvd_of_coprime (Nat.coprime_of_prime_not_dvd hp h2).symm (hnd.trans h4) (h1.trans h4)
    · rw [Nat.primeFactors_mul hn0.ne' hp.ne_zero, hω, Nat.primeFactors_prime hp, Finset.card_singleton,
        Finset.card_disjoint_union (Finset.disjoint_singleton_right.mpr (by simpa)), add_comm]
    · exact hn9.trans (Nat.le_mul_of_pos_right hn0 hp.pos)
