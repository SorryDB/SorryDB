import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n > 0, n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k
  induction' k with k ih
  · exact ⟨1, Nat.succ_pos 0, by simp, by norm_num⟩
  · obtain ⟨n, n_pos, h_card, h_div⟩ := ih
    let N := if n = 3 then 9 else n
    have N_pos : 0 < N := by split_ifs <;> linarith
    have N_div : N ∣ 2 ^ N + 1 := by
      split_ifs with h
      · subst h; norm_num
      · exact h_div
    have N_card : N.primeFactors.card = k := by
      split_ifs with h
      · subst h; rfl
      · exact h_card
    have : ∃ p : ℕ, p.Prime ∧ p ∉ N.primeFactors ∧ p ∣ 2 ^ N + 1 := by
      let m := (2 ^ N + 1) / N
      have m_gt_1 : 1 < m := by
        have : N < 2 ^ N + 1 := Nat.lt_pow_self (by norm_num) N
        exact Nat.lt_div_of_mul_lt (by rwa [Nat.mul_one]) this
      obtain ⟨p, hp, hpm⟩ := Nat.exists_prime_and_dvd m_gt_1
      have : p ∣ 2 ^ N + 1 := Nat.dvd_trans hpm (Nat.div_dvd_of_dvd N_div)
      refine ⟨p, hp, ?_, this⟩
      intro hpN
      have : p = 3 := by
        by_contra hp3
        have : N.primeFactors.card < (N * p).primeFactors.card := sorry
        sorry
      sorry
    obtain ⟨p, hp, hpN, hpdiv⟩ := this
    refine ⟨N * p, Nat.mul_pos N_pos hp.pos, ?_, ?_⟩
    · rw [Nat.primeFactors_mul N_pos hp.ne_zero, Finset.card_disjoint_insert, N_card]
      · rfl
      · simpa using hpN
    · have h1 : N ∣ 2 ^ (N * p) + 1 := Nat.dvd_trans N_div (Nat.pow_add_one_dvd_pow_add_one (2 ^ N) (Nat.Odd.pow_odd (hp.eq_two_or_odd.resolve_left (by
        intro h; subst h; have := Nat.dvd_of_pow_dvd N_div; simp at this)).2 N))
      have h2 : p ∣ 2 ^ (N * p) + 1 := by
        have : 2 ^ (N * p) + 1 ≡ 2 ^ N + 1 [MOD p] := by
          rw [Nat.pow_mul, ← Nat.pow_mod, Nat.ModEq.pow_res_left (Nat.pow_mod_prime_pow 2 hp)]
          simp
        exact (Nat.modEq_zero_iff_dvd.mp (this.trans (Nat.modEq_zero_iff_dvd.mpr hpdiv)))
      exact Nat.dvd_of_factorial_prime_dvd (Nat.coprime_of_prime_not_dvd hp (by simpa using hpN)) h1 h2
