import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp only [solution, Bool.reduceEq]
  let P : ℕ → Prop := fun k => ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2^n + 1
  suffices ∀ k, P k from this 2000
  intro k
  induction' k with k ih
  · exact ⟨1, Nat.zero_lt_one, by simp, one_dvd _⟩
  · obtain ⟨n, n_pos, n_card, n_dvd⟩ := ih
    let m := if n = 1 then 3 else (if n.primeFactors.card = 1 ∧ n.primeFactors = {3} then 9 else n)
    have m_pos : 0 < m := by
      rcases n_pos with _ | _ <;> rcases h : n == 3 with _ | _ <;> simp
    have m_dvd : m ∣ 2 ^ m + 1 := by
      split_ifs with h1 h2
      · simp [h1]
      · simp [h2.1]
      · exact n_dvd
    have m_card : m.primeFactors.card = if n = 1 then 1 else k := by
      split_ifs with h1 h2
      · simp [h1, Nat.primeFactors, Nat.Prime.primeFactors]
      · simp [h2.1, Nat.primeFactors, Nat.Prime.primeFactors]
      · exact n_card
    have m_gt_3 : m = 1 ∨ m = 3 ∨ m > 3 := by
      if h : m = 1 then left else if h' : m = 3 then right; left else right; right; omega
    have : ∃ p, p.Prime ∧ p ∣ 2 ^ m + 1 ∧ p ∉ m.primeFactors := by
      if hm : m = 1 then
        use 3; simp [hm, Nat.primeFactors]
      else if hm' : m = 3 then
        use 3; -- Still the same prime, but for m=9 it changes
        if hm'' : m = 3 then
          use 19; -- Since 2^9+1 = 513 = 27 * 19
          refine ⟨by norm_num, by norm_num, by simp [Nat.primeFactors]; norm_num⟩
        else
          use 3; simp
      else
        -- For m > 3, 2^m+1 has a Zsigmondy prime factor p > m
        have h_m_gt_3 : m > 3 := by
          rcases m_gt_3 with hm1 | hm2 | hm3
          · contradiction
          · contradiction
          · exact hm3
        obtain ⟨p, hp_prime, -, hp_new⟩ := zsigmondy_pow_add_one (by norm_num : 2 > 1) (by norm_num) h_m_gt_3
        refine ⟨p, hp_prime, hp_new.1, ?_⟩
        intro hp_mem
        have hp_dvd_m : p ∣ m := Nat.mem_primeFactors.mp hp_mem |>.right
        have hp_ge_m : p ≥ 2 * m + 1 := Nat.orderOf_le_phi_prime hp_prime ▸ (by
          have : orderOf 2 p = 2 * m := hp_new.2
          have : 2 * m ∣ p - 1 := this ▸ Nat.orderOf_dvd_card_univ
          omega)
        omega
    obtain ⟨p, hp_prime, hp_dvd, hp_not_mem⟩ := this
    refine ⟨m * p, Nat.mul_pos m_pos hp_prime.pos, ?_, ?_⟩
    · rw [Nat.primeFactors_mul m_pos.ne' hp_prime.ne_zero, Nat.card_union_eq, m_card,
        Nat.Prime.primeFactors hp_prime, Finset.card_singleton]
      · split_ifs; exacts [rfl, rfl]
      · rw [Nat.Prime.primeFactors hp_prime, Finset.disjoint_singleton_right]
        exact hp_not_mem
    · have : 2 ^ m + 1 ∣ 2 ^ (m * p) + 1 := Nat.pow_odd_add_pow_odd_dvd (2 ^ m) 1 1 hp_prime.odd_of_ne_two (by norm_num)
      exact (Nat.mul_dvd_of_dvd_of_dvd m_dvd (hp_dvd.trans this) (by
        refine Nat.coprime_of_dvd_of_dvd ?_
        · intro q q_prime q_dvd_m q_dvd_p
          exact hp_not_mem (Nat.mem_primeFactors.mpr ⟨q_prime, m_pos.ne', (Nat.Prime.dvd_iff_eq q_prime hp_prime).mp q_dvd_p ▸ q_dvd_m⟩)))
```
