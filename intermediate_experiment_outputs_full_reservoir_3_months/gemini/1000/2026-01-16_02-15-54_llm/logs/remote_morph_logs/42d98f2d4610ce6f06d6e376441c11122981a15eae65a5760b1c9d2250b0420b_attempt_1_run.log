import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n > 0, n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k
  induction' k with k ih
  · exact ⟨1, Nat.succ_pos _, by simp⟩
  · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
    by_cases h1 : n = 1
    · refine ⟨3, by decide, by simp [h1, Nat.primeFactors]⟩
    · let n_next := if n = 3 then 9 else n
      have n_next_div : n_next ∣ 2 ^ n_next + 1 := by
        split <;> (try simp [*]); decide
      have h_zsig : ∃ p : ℕ, p.Prime ∧ p ∣ 2 ^ n_next + 1 ∧ p ∉ n_next.primeFactors := by
        obtain ⟨p, hp_prime, hp_dvd, hp_fresh⟩ := Nat.exists_prime_factor_pow_sub_one 2 (2 * n_next) (by decide) (by
          split at n_next_div <;> linarith [n_pos, Nat.pos_of_mem_primeFactors (s := n.primeFactors) (by rw [n_card]; decide)]) (by
          intro h; split at n_next_div <;> linarith [n_pos, Nat.pos_of_mem_primeFactors (s := n.primeFactors) (by rw [n_card]; decide)]) (by simp)
        refine ⟨p, hp_prime, (hp_prime.dvd_or_dvd (by rw [← Nat.pow_two, ← Nat.pow_mul]; exact hp_dvd)).resolve_left (hp_fresh n_next (by linarith)), ?_⟩
        intro h_mem; have : 2 * n_next ∣ p - 1 := (Nat.orderOf_prime_eq_of_dvd_pow_sub_one_and_forall_lt_dvd_pow_sub_one hp_prime hp_dvd hp_fresh).symm ▸ hp_prime.orderOf_dvd_card_univ 2
        have : p ≤ n_next := Nat.le_of_dvd (by positivity) (Nat.mem_primeFactors.mp h_mem).2
        linarith [hp_prime.pos, Nat.le_of_dvd (by positivity) this]
      obtain ⟨p, hp_prime, hp_dvd_add, hp_not_mem⟩ := h_zsig
      refine ⟨n_next * p, by positivity, ?_, ?_⟩
      · rw [Nat.primeFactors_mul (by positivity) hp_prime.pos, Finset.card_disjoint_insert hp_not_mem, ← n_card]
        split <;> (try simp [*]); linarith
      · have hp_odd : p % 2 = 1 := hp_prime.odd_of_dvd_2_pow_plus_one (by linarith) hp_dvd_add
        exact Nat.dvd_of_coprime_of_dvd_of_dvd (Nat.coprime_of_prime_not_dvd hp_prime hp_not_mem)
          (n_next_div.trans (Nat.dvd_pow_plus_one_of_dvd (Nat.dvd_refl _) hp_odd))
          (hp_dvd_add.trans (Nat.dvd_pow_plus_one_of_dvd (Nat.dvd_refl _) (by decide)))

