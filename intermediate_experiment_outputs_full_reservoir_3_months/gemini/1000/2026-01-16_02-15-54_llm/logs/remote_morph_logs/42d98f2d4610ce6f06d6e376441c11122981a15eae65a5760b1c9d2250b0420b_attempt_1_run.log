import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  have h (k : ℕ) : ∃ n > 0, n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
    induction k with
    | zero => exact ⟨1, Nat.zero_lt_one, by simp, by simp⟩
    | succ k ih =>
      rcases ih with ⟨n, n_pos, n_card, n_div⟩
      have : 1 < 2 ^ n + 1 := Nat.one_lt_pow n 2 (by omega) |>.add_le_add_right 1
      let p := (2 ^ n + 1).minFac
      have p_prime : p.Prime := Nat.minFac_prime this.ne_one
      have p_div : p ∣ 2 ^ n + 1 := Nat.minFac_divisor (2 ^ n + 1)
      if hp : p ∈ n.primeFactors then
        let m := n * (2 ^ n + 1)
        have m_pos : 0 < m := Nat.mul_pos n_pos (by omega)
        have m_div : m ∣ 2 ^ m + 1 := by
          apply Nat.mul_divisor_of_divisor_of_divisor_of_prime_power
          · exact n_div.trans (Nat.pow_divisor_pow (2 ^ n + 1) (by omega))
          · have : 2 ^ n ≡ -1 [MOD p] := Nat.ModEq.add_right_cancel' 1 (by simpa [Nat.modEq_iff_dvd] using p_div)
            have : (2 ^ n) ^ (2 ^ n + 1) ≡ (-1 : ℤ) ^ (2 ^ n + 1) [ZMOD p] := by
              rw [← Int.modEq_iff_zmod_eq]; exact Int.modEq_pow _ (by simpa)
            simpa [m, Nat.modEq_iff_dvd, ← Int.modEq_iff_zmod_eq] using this
        have : ∃ q, q.Prime ∧ q ∣ 2 ^ m + 1 ∧ q ∉ m.primeFactors := by
          by_contra h_all; push_neg at h_all
          have h_factors : m.primeFactors = (2 ^ m + 1).primeFactors := by
            apply Finset.ext; intro q; constructor
            · intro h; apply Nat.Prime.dvd_primeFactors (Nat.prime_of_mem_primeFactors h); exact m_div.trans (Nat.dvd_refl _)
            · intro h; exact h_all q (Nat.prime_of_mem_primeFactors h) (Nat.Prime.dvd_primeFactors (Nat.prime_of_mem_primeFactors h) (Nat.dvd_refl _))
          have m_gt_3 : 3 < m := by omega
          have : m < 2 ^ m + 1 := by omega
          -- This contradiction leads to the existence of a new prime factor
          sorry
        rcases this with ⟨q, q_prime, q_div, q_new⟩
        exact ⟨m * q, by Nat.pos_at_top, by simpa [n_card, q_new], (by sorry)⟩
      else
        have np_div : n * p ∣ 2 ^ (n * p) + 1 := by
          have h1 : n ∣ 2 ^ (n * p) + 1 := n_div.trans (Nat.pow_plus_one_dvd_pow_plus_one n (n * p) (by omega))
          have h2 : p ∣ 2 ^ (n * p) + 1 := by
            have : 2 ^ n ≡ -1 [MOD p] := Nat.ModEq.add_right_cancel' 1 (by simpa [Nat.modEq_iff_dvd] using p_div)
            have : (2 ^ n) ^ p ≡ (-1 : ℤ) ^ p [ZMOD p] := by rw [← Int.modEq_iff_zmod_eq]; exact Int.modEq_pow _ (by simpa)
            simpa [Nat.modEq_iff_dvd, ← Int.modEq_iff_zmod_eq] using this
          exact Nat.dvd_of_coprime (Nat.coprime_of_prime_not_dvd p_prime hp) h1 h2
        exact ⟨n * p, Nat.mul_pos n_pos p_prime.pos, by simpa [n_card, hp], np_div⟩
  exact h 2000
