namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp
  have h (k : ℕ) : ∃ n : ℕ, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
    induction' k with k ih
    · exact ⟨1, by simp⟩
    · obtain ⟨n, h0, hcard, hdiv⟩ := ih
      have h1 : 2 ^ (2 * n) - 1 = (2 ^ n - 1) * (2 ^ n + 1) := by ring
      obtain ⟨p, hp⟩ : ∃ p, p.Prime ∧ p ∣ 2 ^ n + 1 ∧ ¬p ∣ n := by
        match n with
        | 1 => exact ⟨3, Nat.prime_three, by simp, by simp⟩
        | 3 => exact ⟨19, by norm_num, by norm_num, by norm_num⟩
        | n + 1 =>
          have : 2 * (n + 1) > 6 ∨ 2 * (n + 1) = 6 := by omega
          cases' this with h6 h6
          · obtain ⟨p, hpp, hord⟩ := Nat.exists_prime_factor_ord_eq (by omega) h6
            have hdiv2 : p ∣ 2 ^ (2 * (n + 1)) - 1 := Nat.ord_div_iff_pow_eq_one.mp hord
            have hnot : ¬p ∣ 2 ^ (n + 1) - 1 := fun h => by
              have : Nat.ord p 2 ∣ n + 1 := Nat.ord_div_iff_pow_eq_one.mp h
              omega
            have hpdiv : p ∣ 2 ^ (n + 1) + 1 := by
              rw [h1] at hdiv2; exact (Nat.Prime.dvd_mul hpp).mp hdiv2 |>.resolve_left hnot
            refine ⟨p, hpp, hpdiv, fun h => ?_⟩
            have : p ∣ 2 * (n + 1) := Nat.dvd_trans h (by omega)
            have : p ≤ 2 * (n + 1) := Nat.le_of_dvd (by omega) this
