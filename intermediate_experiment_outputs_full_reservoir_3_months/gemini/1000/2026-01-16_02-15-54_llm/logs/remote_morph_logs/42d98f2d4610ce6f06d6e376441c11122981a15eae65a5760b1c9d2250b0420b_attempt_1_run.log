import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]; suffices ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k; induction' k with k ih
  · use 1; simp
  · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
    if hk : k = 0 then
      use 9; simp [Nat.primeFactors, Nat.factors]; decide
    else
      have n_gt_3 : 3 ≤ n := by
        have : n.primeFactors.nonempty := by rw [← Finset.card_pos, n_card]; linarith
        obtain ⟨p, hp⟩ := this
        have hpn := (Nat.mem_primeFactors n_pos.ne').mp hp
        have : p ≠ 2 := by intro h; have := hpn.1.left.trans n_div; rw [h] at this; norm_num at this
        linarith [Nat.le_of_dvd n_pos hpn.1.left, hpn.1.right.two_le.lt_of_ne this.symm]
      obtain ⟨p, hp, hpd, hpm⟩ := Nat.exists_prime_divisor_pow_sub_one (ha := 2) (hn := 2 * n) (by norm_num) (by linarith) (by linarith) (by simp; linarith)
      use n * p
      have hp_odd : p.Odd := hp.odd_of_ne_two (by
        intro h; subst h;
        have := (hp.dvd_or_dvd (by rw [← Nat.pow_mul] at hpd; exact hpd : p ∣ (2^n-1)*(2^n+1))).resolve_left (hpm n (by linarith))
        norm_num at this)
      have hpn : ¬p ∣ n := λ h => by
        have : 2 * n ∣ p - 1 := Nat.order_of_dvd_of_pow_eq_one (Nat.Prime.orderOf_two_eq_pow_sub_one hp hpm) (by rw [← Nat.pow_mul]; exact hpd)
        linarith [Nat.le_of_dvd n_pos h]
      have hp_div_np : p ∣ 2 ^ (n * p) + 1 := by
        have h1 : p ∣ 2 ^ n + 1 := (hp.dvd_or_dvd (by rw [← Nat.pow_mul] at hpd; exact hpd)).resolve_left (hpm n (by linarith))
        have h2 : p ∣ (2 ^ n) ^ p + 1 := Nat.dvd_pow_add_pow_of_odd h1 hp_odd
        rwa [Nat.pow_mul] at h2
      simp [Nat.primeFactors_mul n_pos.ne' hp.ne_zero, hpn, n_card, n_div, hp, n_pos]
      exact ⟨n_div.trans (Nat.pow_dvd_pow 2 (Nat.le_mul_of_pos_right _ hp.pos)), hp_div_np⟩

```
