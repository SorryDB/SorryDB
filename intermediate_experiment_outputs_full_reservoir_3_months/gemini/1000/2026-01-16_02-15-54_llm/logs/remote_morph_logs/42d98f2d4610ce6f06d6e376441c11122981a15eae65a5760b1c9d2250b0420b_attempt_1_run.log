          intro h2; have := Nat.dvd_of_mul_dvd_right h4; rw [h2] at this; norm_num at this))
      exact Nat.mul_dvd_of_dvd_of_dvd (Nat.dvd_trans h3 h_pow) (Nat.dvd_trans h4 h_pow)⟩
