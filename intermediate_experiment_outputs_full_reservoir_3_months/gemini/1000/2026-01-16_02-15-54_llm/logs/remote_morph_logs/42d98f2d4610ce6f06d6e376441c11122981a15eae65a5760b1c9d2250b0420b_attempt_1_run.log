import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n > 0, n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k; induction' k with k ih
  · exact ⟨1, Nat.zero_lt_one, by simp, one_dvd _⟩
  · obtain ⟨n, h1, h2, h3⟩ := ih
    let N := if n = 1 then 9 else n
    have hN : N ∣ 2 ^ N + 1 ∧ 0 < N ∧ N.primeFactors.card = (if n = 1 then 1 else k) := by
      split_ifs with hn <;> (subst_vars; norm_num; exact ⟨h3, h1, h2⟩)
    have hN3 : N > 3 := by split_ifs with hn <;> (subst_vars; norm_num; linarith)
    have hN_odd : N % 2 = 1 := by
      have : N ∣ 2 ^ N + 1 := hN.1
      have : (2 ^ N + 1) % 2 = 1 := by rw [Nat.add_mod, Nat.pow_mod]; norm_num; linarith
      exact Nat.odd_of_dvd_odd hN.1 (Nat.odd_iff_mod_two_eq_one.mp this)
    obtain ⟨p, hp, hpd, hpp⟩ : ∃ p, Nat.Prime p ∧ p ∣ 2 ^ N + 1 ∧ p ∉ N.primeFactors := by
      have h2N : 1 < 2 * N := by linarith
      have h_not : ¬(2 = 2 ∧ 1 = 1 ∧ 2 * N = 6) ∧ ¬(2 + 1 = 2 ^ 1 ∧ 2 * N = 2) := by
        constructor <;> rintro ⟨_⟩ <;> linarith
      obtain ⟨p, pp, pdiv, pprim⟩ := zsigmondy_exists_prime_factor (Nat.coprime_two_left.mpr hN_odd) (by norm_num) h2N h_not
      have p_dvd_plus : p ∣ 2 ^ N + 1 := by
        have : p ∣ (2 ^ N - 1) * (2 ^ N + 1) := by rw [← Nat.pow_mul]; exact pdiv
        exact (pp.dvd_or_dvd this).resolve_left (pprim N (by linarith))
      refine ⟨p, pp, p_dvd_plus, ?_⟩
      rw [Nat.mem_primeFactors hN.2.1.ne', Nat.prime_dvd_iff_not_coprime pp]
      intro h_not_coprime
      have p_dvd_N : p ∣ N := pp.dvd_of_not_coprime h_not_coprime
      have : p ≤ N := Nat.le_of_dvd hN.2.1 p_dvd_N
      have : p > 2 * N := by
        have : ord_p 2 = 2 * N := by
          apply Nat.Prime.ord_eq_of_coprime pp (Nat.coprime_two_right.mpr (pp.odd_of_dvd_odd p_dvd_plus (by simp [hN_odd])))
          · rw [Nat.pow_mul, Nat.sub_one_mul_add_one]; exact pdiv
          · intro m hm; apply pprim; exact hm
        rw [← this]; exact Nat.ord_le_ppm_sub_one pp (by norm_num)
      linarith
    refine ⟨N * p, Nat.mul_pos hN.2.1 hp.pos, ?_, ?_⟩
    · rw [Nat.primeFactors_mul hN.2.1.ne' hp.ne_zero (Nat.coprime_of_prime_dvd_not_dvd hp hpp).symm]
      simp [hN.2.2, hp, hpp]; split_ifs <;> rfl
    · have p_odd : p % 2 = 1 := Nat.odd_iff_mod_two_eq_one.mp (Nat.odd_of_dvd_odd hp2 (by simp [Nat.add_mod, Nat.pow_mod, hN.2.1]))
      exact (Nat.mul_dvd_mul_right hN.1 p).trans (Nat.pow_plus_one_dvd_pow_mul_plus_one 2 N p_odd)

