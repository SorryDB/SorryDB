import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k
  induction' k with k ih
  · use 1; simp
  · rcases ih with ⟨n, npos, ncard, ndvd⟩
    let N := if n = 3 then 9 else n
    have Ndvd : N ∣ 2 ^ N + 1 := by
      rcases (by exact em (n = 3) : n = 3 ∨ n ≠ 3) with rfl | hn3
      · decide
      · exact ndvd.trans (Nat.pow_dvd_pow_of_dvd_index 2 (Nat.odd_iff_not_even.mp (Nat.Odd.of_dvd_pow (by use 2 ^ n; rwa [← Nat.pow_succ]) ndvd)) (by rwa [if_neg hn3]))
    have h_card : N.primeFactors.card = k := by
      rcases (by exact em (n = 3) : n = 3 ∨ n ≠ 3) with rfl | hn3
      · simp [ncard]
      · rwa [if_neg hn3]
    have h_new : ∃ p, p.Prime ∧ p ∤ N ∧ p ∣ 2 ^ N + 1 := by
      let m := 2 ^ N + 1
      have m3 : 3 ^ (N.primeFactors.card + 1) ∣ m := by
        have : 3 ∣ N := by
          by_contra h3
          let q := N.minFac
          have qN : q ∣ N := Nat.minFac_dvd N
          have q2 : q ∣ 2 ^ N + 1 := Ndvd.trans' qN
          have : q = 3 := by
            have hq : q ∣ 2 ^ (2 * N) - 1 := by
              rw [Nat.pow_mul, Nat.sq_sub_sq]; exact Nat.dvd_mul_of_dvd_left (by simpa) _
            have ordq : (orderOf 2 q) ∣ 2 * N ∧ (orderOf 2 q) ∤ N := ⟨OrderOf.dvd_of_pow_eq_one (by simpa), by intro h; have := OrderOf.pow_eq_one_iff.mp h; contradiction⟩
            have : 2 ∣ orderOf 2 q := by
              contrapose! ordq; cases' Nat.dvd_prime (Nat.Prime.minFac (by rcases (by exact em (N = 1) : N = 1 ∨ N > 1) with rfl | h1; · simp at ncard; rwa [ncard] at k; · exact (Nat.minFac_prime (Nat.one_lt_iff_ne_zero_and_ne_one.mpr ⟨npos.ne', h1.ne'⟩)))) with _ _ <;> sorry
            sorry
          sorry
        sorry
      sorry
    rcases h_new with ⟨p, pp, pN, p2N⟩
    use N * p
    refine ⟨Nat.mul_pos (by rcases (by exact em (n = 3) : n = 3 ∨ n ≠ 3) with rfl | hn3 <;> simp [npos]) pp.pos, ?_, ?_⟩
    · rw [Nat.primeFactors_mul (by rcases (by exact em (n = 3) : n = 3 ∨ n ≠ 3) with rfl | hn3 <;> simp [npos]) pp.ne_zero (by rwa [Nat.gcd_comm, Nat.gcd_prime_left pp])]
      simp [h_card]
    · apply Nat.dvd_trans _ (Nat.pow_dvd_pow_of_dvd_index 2 (by apply Nat.Odd.of_dvd_pow (by use 2^(N*p); rwa [← Nat.pow_succ]) (Ndvd.trans (Nat.pow_dvd_pow_of_dvd_index 2 (by rcases (by exact em (n = 3) : n = 3 ∨ n ≠ 3) with rfl | hn3 <;> decide) (by rcases (by exact em (n = 3) : n = 3 ∨ n ≠ 3) with rfl | hn3 <;> simp [npos])))) (Nat.dvd_mul_right N p))
      exact Nat.dvd_of_mul_dvd_mul_left (by rcases (by exact em (n = 3) : n = 3 ∨ n ≠ 3) with rfl | hn3 <;> simp [npos]) (by sorry)

```
