import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp only [solution, Bool.coe_true, iff_true]
  suffices ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k; induction' k with k ih
  · exact ⟨1, Nat.zero_lt_one, by simp, by simp⟩
  · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
    if h1 : n = 1 then
      use 3; simp [n_card, h1]
    else
      let L := 2 * n
      have hL : 1 < L := by linarith
      have hL6 : L ≠ 6 := by
        intro h; have : n = 3 := by linarith
        subst this; norm_num at n_card
      have hL26 : (2, L) ≠ (2, 6) := by simp [hL6]
      obtain ⟨p, hp, hpd, hpm⟩ := Nat.exists_prime_factor_pow_minus_one_not_dvd_pow_minus_one (a := 2) hL hL6 hL26
      have p_dvd : p ∣ 2 ^ n + 1 := by
        have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by rw [← Nat.pow_two, ← Nat.pow_mul, Nat.mul_comm]; exact hpd
        exact (hp.dvd_or_dvd this).resolve_left (hpm n (by linarith))
      have p_new : p ∉ n.primeFactors := by
        intro hpn
        have p_odd : p % 2 = 1 := by
          apply (Nat.Prime.eq_two_or_odd hp).resolve_left; intro hp2
          subst hp2; norm_num at p_dvd
        have p_le_n : p ≤ n := Nat.le_of_mem_primeFactors hpn
        have : p ∣ 2 ^ (p - 1) - 1 := Nat.ModEq.sub_mem (Nat.ModEq.pow_totient (by norm_num) hp)
        have d_dvd : (Nat.gcd (2 * n) (p - 1)) = 2 * (Nat.gcd n ((p - 1) / 2)) := by sorry
        have : p ∣ 2 ^ (Nat.gcd (2 * n) (p - 1)) - 1 := Nat.dvd_pow_gcd_minus_one_of_dvd_pow_minus_one_of_dvd_pow_minus_one p 2 (2 * n) (p - 1) hpd this
        have : Nat.gcd (2 * n) (p - 1) < 2 * n := by linarith
        exact hpm (Nat.gcd (2 * n) (p - 1)) this ‹_›
      use n * p
      constructor
      · exact Nat.mul_pos n_pos hp.pos
      · constructor
        · rw [Nat.primeFactors_mul n_pos hp.pos, Finset.card_disjoint_union, n_card, Nat.primeFactors_prime hp, Finset.card_singleton]
          · exact Finset.disjoint_singleton_right.mpr p_new
        · have n_odd : n % 2 = 1 := by
            have : n ∣ 2 ^ n + 1 := n_div
            if hn2 : 2 ∣ n then
              have : 2 ∣ 2 ^ n + 1 := hn2.trans n_div
              norm_num at this
            else exact Nat.mod_two_ne_zero.mp hn2
          exact Nat.dvd_trans (Nat.mul_dvd_mul n_div p_dvd) (Nat.dvd_pow_add_pow_of_odd (2 ^ n) 1 hp.odd)

