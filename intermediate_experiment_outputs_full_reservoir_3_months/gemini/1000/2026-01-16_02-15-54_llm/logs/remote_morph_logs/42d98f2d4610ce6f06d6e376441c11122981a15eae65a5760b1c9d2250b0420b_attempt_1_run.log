```lean
determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n : ℕ, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k; induction' k with k ih
  · exists 1; simp
  · obtain ⟨n, h0, h1, h2⟩ := ih
    let n' := if n = 1 then 3 else if n = 3 then 9 else n
    have n'S : 0 < n' ∧ n' ∣ 2 ^ n' + 1 ∧ (n' = 1 ∨ n'.primeFactors.card = k) := by
      if h : n = 1 then subst h; norm_num
      else if h' : n = 3 then subst h'; norm_num; simp [h1]
      else exact ⟨h0, h2, Or.inr h1⟩
    have : ∃ p, p.Prime ∧ p ∣ 2 ^ n' + 1 ∧ p ∤ n' := by
      if h : n' = 1 then use 3; simp [h]
      else if h' : n' = 9 then use 19; norm_num
      else sorry
    obtain ⟨p, hp, hpd, hpn⟩ := this
    refine ⟨n' * p, by positivity, ?_, ?_⟩
    · rw [Nat.primeFactors_mul (by positivity) (by positivity) (Nat.Prime.coprime_iff_not_dvd hp hpn)]
      simp [hp, h1, n'S]
    · have : 2 ^ n' + 1 ∣ 2 ^ (n' * p) + 1 := by
        apply Nat.dvd_pow_add_pow_of_odd
        exact Nat.Prime.odd_of_ne_two hp (by rintro rfl; norm_num [n'S] at hpd)
      exact (Nat.mul_dvd_mul n'S.2.2 hpd).trans (Nat.mul_dvd_of_dvd_right this (by positivity))
```
