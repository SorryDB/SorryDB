import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n > 0, n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k; induction' k with k ih
  · exact ⟨1, Nat.zero_lt_one, by simp, by norm_num⟩
  · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
    let m := if n = 1 then 3 else if n = 3 then 9 else n
    have m_odd : Odd m := by
      rcases (show n = 1 ∨ n = 3 ∨ (n > 3 ∧ Odd n) from sorry) with rfl | rfl | ⟨-, h⟩
      · norm_num
      · norm_num
      · exact h
    have m_div : m ∣ 2 ^ m + 1 := by
      rcases (show n = 1 ∨ n = 3 ∨ (n > 3 ∧ n ∣ 2 ^ n + 1) from sorry) with rfl | rfl | ⟨h_n3, h_ndiv⟩
      · norm_num
      · norm_num
      · exact Nat.pow_add_one_dvd_pow_add_one 2 (by omega) |> Nat.dvd_trans h_ndiv
    obtain ⟨p, hp_prime, hp_div, hp_new⟩ : ∃ p, p.Prime ∧ p ∣ 2 ^ m + 1 ∧ p ∉ m.primeFactors := by
      have h_zsig : ∃ p, p.Prime ∧ p ∣ 2 ^ (2 * m) - 1 ∧ ∀ d < 2 * m, ¬(p ∣ 2 ^ d - 1) := by
        refine Nat.exists_prime_factor_pow_minus_one_not_dvd_pow_minus_one 2 1 (2 * m) (by norm_num) (by norm_num) (by norm_num) ?_ ?_ ?_
        · rcases (show m = 1 ∨ m = 3 ∨ m > 3 from sorry) with rfl | rfl | h <;> linarith
        · intro h; rcases h with ⟨-, -, hm⟩; norm_num at hm; linarith
        · intro h; rcases h with ⟨hm, -⟩; norm_num at hm
      obtain ⟨p, hp, h_ord, h_new⟩ := h_zsig
      have p_dvd_add : p ∣ 2 ^ m + 1 := by
        have : p ∣ (2 ^ m - 1) * (2 ^ m + 1) := by rw [← Nat.pow_two, ← Nat.pow_mul]; exact h_ord
        exact (hp.dvd_or_dvd this).resolve_left (h_new m (by linarith))
      refine ⟨p, hp, p_dvd_add, ?_⟩
      rw [Nat.primeFactors, Nat.mem_primeFactors]; intro h; rcases h with ⟨-, h_p_dvd_m⟩
      have : p - 1 < 2 * m := by
        have : p ∣ 2 ^ (p - 1) - 1 := Nat.Prime.dvd_pow_order_of_sub_one hp (by norm_num)
        have : 2 * m ≤ p - 1 := (Nat.Prime.orderOf_dvd_iff_pow_eq_one hp (by norm_num)).mpr h_ord |> sorry
        linarith
      exact h_new (p - 1) (by linarith) (Nat.Prime.dvd_pow_order_of_sub_one hp (by norm_num))
    refine ⟨m * p, Nat.mul_pos (by rcases (show m = 3 ∨ m = 9 ∨ m > 3 from sorry) with rfl | rfl | h <;> linarith) hp_prime.pos, ?_, ?_⟩
    · rw [Nat.primeFactors_mul (by rcases (show m = 3 ∨ m = 9 ∨ m > 3 from sorry) with rfl | rfl | h <;> linarith) hp_prime.pos, Nat.card_union_of_disjoint]
      · simp [hp_prime, n_card]; rcases (show n = 1 ∨ n = 3 ∨ n > 3 from sorry) with rfl | rfl | h <;> simp [*]
      · simp [hp_new, hp_prime]
    · have : 2 ^ m + 1 ∣ 2 ^ (m * p) + 1 := Nat.pow_add_one_dvd_pow_add_one 2 (Nat.Prime.odd_of_ne_two hp_prime (by rcases (show m = 3 ∨ m = 9 ∨ m > 3 from sorry) with rfl | rfl | h <;> (have := hp_prime; have := hp_div; have := m_div; sorry)))
      exact Nat.lcm_dvd (Nat.dvd_trans m_div this) (Nat.dvd_trans hp_div this)
