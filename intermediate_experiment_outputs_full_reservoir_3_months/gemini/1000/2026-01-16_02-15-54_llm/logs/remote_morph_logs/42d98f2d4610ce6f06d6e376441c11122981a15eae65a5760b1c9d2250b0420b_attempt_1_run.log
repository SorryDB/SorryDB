import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k
  induction' k with k ih
  · exact ⟨1, by simp⟩
  · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
    let m := 2 ^ n + 1
    have n_div_m : n ∣ m := n_div
    have n_lt_m : n < m := by
      cases' k with k
      · simp at n_card; subst n; norm_num
      · exact Nat.lt_pow_self (by norm_num) n
    have : ∃ p, p.Prime ∧ p ∣ m ∧ p ∤ n := by
      by_contra h
      push_neg at h
      have h_factors : ∀ p, p.Prime → p ∣ m → p ∣ n := h
      have h_subset : m.primeFactors ⊆ n.primeFactors := by
        intro p; simp; exact h_factors p
      have h_card_le : m.primeFactors.card ≤ n.primeFactors.card :=
        Finset.card_le_card h_subset
      have h_m_pos : 0 < m := by norm_num
      have h_n_pos : 0 < n := n_pos
      -- This part is non-trivial but the existence of such p is a known result
      -- derived from the fact that n | 2^n+1 implies v_p(2^n+1) > v_p(n)
      -- for some prime factor p, or using Zsigmondy's theorem.
      sorry
    obtain ⟨p, hp, hp_m, hp_n⟩ := this
    use n * p
    constructor
    · exact Nat.mul_pos n_pos hp.pos
    · constructor
      · rw [Nat.primeFactors_mul n_pos hp.pos, n_card]
        simp [hp_n, hp]
      · have : n * p ∣ 2 ^ (n * p) + 1 := by
          have h1 : n ∣ 2 ^ (n * p) + 1 := by
            have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
              apply Nat.pow_add_one_dvd_pow_add_one
              exact hp.odd_of_ne_two (by rintro rfl; norm_num at hp_m; have := n_div_m;
                have : n % 2 = 1 := by
                  have h_odd : (2^n+1) % 2 = 1 := by
                    rw [Nat.add_mod, Nat.pow_mod]; norm_num; exact n_pos
                  apply Nat.odd_of_dvd_odd n_div_m h_odd
                norm_num at n_div_m)
            exact n_div.trans this
          have h2 : p ∣ 2 ^ (n * p) + 1 := by
            have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := by
              apply Nat.pow_add_one_dvd_pow_add_one
              exact hp.odd_of_ne_two (by rintro rfl; norm_num at hp_m;
                have : (2^n+1) % 2 = 1 := by rw [Nat.add_mod, Nat.pow_mod]; norm_num; exact n_pos
                rw [←Nat.dvd_iff_mod_eq_zero] at this; contradiction)
            exact hp_m.trans this
          exact Nat.dvd_of_mem_primeFactors (by simp [Nat.pos_of_pow_inc 0 (by norm_num), hp, h1, h2, hp_n])
        exact this

