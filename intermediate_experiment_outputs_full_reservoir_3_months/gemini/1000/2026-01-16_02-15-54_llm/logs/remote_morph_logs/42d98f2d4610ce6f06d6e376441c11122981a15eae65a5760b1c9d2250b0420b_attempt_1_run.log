import Mathlib

import ProblemExtraction

problem_file { tags := [.Algebra, .NumberTheory] }

/-!
# International Mathematical Olympiad 2000, Problem 5

Does there exist a positive integer n such that n has exactly
2000 distinct prime divisors and n divides 2ⁿ + 1?

-/

namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  rw [solution]
  simp only [iff_true]
  suffices ∀ k, ∃ n > 0, n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 by
    exact this 2000
  intro k
  induction' k with k ih
  · use 1; simp
  · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
    obtain ⟨p, hp, p_div, p_new⟩ : ∃ p, p.Prime ∧ p ∣ 2 ^ n + 1 ∧ p ∤ n := by
      by_cases h1 : n = 1
      · use 3; simp [h1]
      by_cases h3 : n = 3
      · use 19; norm_num; simp [h3]
      · have h_zsig : 2 * n ≠ 1 ∧ 2 * n ≠ 6 ∧ ¬(2 + 1 = 2 ^ 2 ∧ 2 * n = 2) := by
          simp [h1, h3]; omega
        obtain ⟨p, hp, p_dvd, p_prim⟩ := Zsigmondy.exists_prime_factor (Nat.coprime_one_right 2) (by norm_num) (by norm_num) (2 * n) (by omega) (by simp [h_zsig]) (by simp [h_zsig])
        have p_div_n : p ∣ 2 ^ n + 1 := by
          have := hp.dvd_or_dvd (by rw [← Nat.pow_two_sub_pow_two, ← pow_mul]; exact p_dvd)
          exact this.resolve_left (p_prim n (by omega))
        use p, hp, p_div_n
        intro p_n
        have h_order : orderOf (2 : ZMod p) = 2 * n := by
          refine orderOf_eq_of_pow_and_forall_dvd_one (by omega) (by simp [ZMod.nat_cast_eq_one_iff_dvd, p_dvd]) ?_
          intro m m_div m_lt
          simpa [ZMod.nat_cast_eq_one_iff_dvd] using p_prim m m_lt
        have : 2 * n ∣ p - 1 := by
          rw [← h_order]; apply orderOf_dvd_card_sub_one; simpa [ZMod.nat_cast_eq_zero_iff_dvd] using hp.ne_two
        omega
    use n * p
    refine ⟨by omega, ?_, ?_⟩
    · rw [Nat.primeFactors_mul n_pos.ne' hp.ne_zero, n_card, Nat.primeFactors_prime hp, Finset.card_insert_of_not_mem]
      · rfl
      · simpa [Nat.mem_primeFactors, hp]
    · have h_odd : Odd p := hp.odd_of_ne_two (by intro h; subst h; norm_num at p_div)
      have h1 : n ∣ 2 ^ (n * p) + 1 := n_div.trans (by convert dvd_pow_add_pow_of_odd (2^n) 1 p h_odd; simp)
      have h2 : p ∣ 2 ^ (n * p) + 1 := p_div.trans (by convert dvd_pow_add_pow_of_odd (2^n) 1 p h_odd; simp)
      exact Nat.dvd_of_coprime_of_dvd_of_dvd (hp.coprime_iff_not_dvd.mpr p_new).symm h1 h2

