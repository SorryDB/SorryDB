determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n, 0 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k; induction' k with k ih
  · exact ⟨1, by simp⟩
  · obtain ⟨n, n_pos, n_card, n_div⟩ := ih
    rcases k with rfl
    · use 3; simp [Nat.primeFactors, Nat.factors]; norm_num
    rcases k with rfl
    · use 3 * 19; norm_num [Nat.primeFactors, Nat.factors, Nat.prime_three, Nat.prime_nineteen]
    have n_gt_3 : n > 3 := by
      have h_odd : n % 2 = 1 := by
        have : n ∣ 2 ^ n + 1 := n_div
        rcases n with rfl | ⟨n'⟩
        · norm_num at n_pos
        have : ¬ 2 ∣ 2 ^ (n' + 1) + 1 := by norm_num [Nat.add_mod]
        exact Nat.odd_iff.mp (Nat.odd_of_dvd_odd n_div (by norm_num))
      have : n.primeFactors.card = 2 := n_card
      obtain ⟨p, q, hp, hq, hneq, hseq⟩ := Finset.card_eq_two.mp this
      have hp' : p.Prime := Nat.prime_of_mem_primeFactors (hseq ▸ Finset.mem_insert_self p {q})
      have hq' : q.Prime := Nat.prime_of_mem_primeFactors (hseq ▸ Finset.mem_insert_of_mem (Finset.mem_singleton.mpr rfl))
      have : p ≥ 3 ∧ q ≥ 3 := ⟨hp'.eq_two_or_odd.resolve_left (fun e => by simp [e] at h_odd), hq'.eq_two_or_odd.resolve_left (fun e => by simp [e] at h_odd)⟩
      have : n ≥ 3 * 5 := by
        obtain ⟨hp_val, hq_val⟩ := this
        have : p * q ∣ n := by
          apply Nat.mul_dvd_of_coprime (Nat.coprime_of_lt_prime hp' hq' (by apply hneq.lt_or_gt.resolve_right; intro; linarith))
          · exact Nat.dvd_of_mem_primeFactors (hseq ▸ Finset.mem_insert_self p {q})
          · exact Nat.dvd_of_mem_primeFactors (hseq ▸ Finset.mem_insert_of_mem (Finset.mem_singleton.mpr rfl))
        apply Nat.le_of_dvd n_pos this
      linarith
    obtain ⟨p, hp, hpd, -, hpm⟩ := Nat.exists_prime_divisor_two_pow_add_one n_gt_3.ne' n_pos.ne'
    refine ⟨n * p, Nat.mul_pos n_pos hp.pos, ?_, ?_⟩
    · rw [Nat.primeFactors_mul n_pos.ne' hp.pos.ne', Finset.card_disjoint_union, n_card]
      · simp
      · rw [Finset.disjoint_singleton_right, Nat.mem_primeFactors]
        simp [hp.ne_one, hp]
        intro; have := hpm hpd; linarith
    · have : 2 ^ (n * p) + 1 = (2 ^ n) ^ p + 1 := by rw [Nat.pow_mul]
      have h_div_p : p ∣ (2 ^ n) ^ p + 1 := by
        have : 2 ^ n ≡ -1 [MOD p] := Nat.ModEq.equiv (by apply Nat.mod_eq_of_dvd; exact hpd) (by simp)
        have : (2 ^ n) ^ p ≡ (-1 : ℤ) ^ p [ZMOD p] := by
          apply Int.ModEq.pow; exact_mod_cast this
        have : (2 ^ n) ^ p ≡ -1 [ZMOD p] := by
          rwa [Int.neg_one_pow (Nat.Prime.odd_of_ne_two hp (by linarith))] at this
        exact_mod_cast (Int.modEq_zero_iff_dvd.mp (Int.ModEq.add_right 1 this))
      apply Nat.dvd_trans _ (Nat.dvd_pow_add_pow_of_odd (2 ^ n) 1 (Nat.Prime.odd_of_ne_two hp (by linarith)))
      rw [Nat.mul_comm]; apply Nat.mul_dvd_of_coprime _ n_div hpd
      apply Nat.coprime_of_lt_prime hp
      intro; have := hpm hpd; linarith

end Imo2000P5
