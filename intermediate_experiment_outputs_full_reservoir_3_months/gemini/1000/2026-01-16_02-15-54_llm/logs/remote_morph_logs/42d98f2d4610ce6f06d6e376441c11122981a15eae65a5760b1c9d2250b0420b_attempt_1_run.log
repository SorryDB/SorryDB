namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1 ↔ solution := by
  simp [solution]
  suffices ∀ k, ∃ n > 0, n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 from this 2000
  intro k; induction' k with k ih
  · exact ⟨1, by simp⟩
  · obtain ⟨n, h0, hcard, hdiv⟩ := ih
    let N := 2 * n
    have hN : 1 < N := by omega
    have h_not_six : ¬(2 = 2 ∧ 1 = 1 ∧ N = 6) := by
      intro ⟨_, _, hN6⟩
      have : n = 3 := by omega
      subst this
      have hdiv' : 3 ∣ 2 ^ 3 + 1 := by decide
      have hcard' : Nat.primeFactors 3 = {3} := by simp
      obtain ⟨p, hp_prime, hp_dvd, hp_new⟩ := exists_prime_factor_pow_sub_one 2 1 18 (by decide) (by decide) (by decide) (by decide) (by decide) (by simp)
      have h_p_dvd : p ∣ 2 ^ 9 + 1 := by
        have : p ∣ 2 ^ 18 - 1 := hp_dvd
        have : p ∣ (2 ^ 9 - 1) * (2 ^ 9 + 1) := by exact_mod_cast this
        refine (hp_prime.dvd_or_dvd this).resolve_left ?_
        intro h; apply hp_new 9 (by decide) h
      have h_p_ne_3 : p ≠ 3 := by
        intro h; subst h; apply hp_new 2 (by decide); decide
      use 3 * p; simp [hp_prime, h_p_ne_3, h_p_dvd]
      constructor; · omega
      constructor; · exact Nat.dvd_trans (by exact_mod_cast hdiv') (Nat.pow_add_one_dvd_pow_add_one (by decide) (by omega))
      · exact Nat.dvd_trans h_p_dvd (Nat.pow_add_one_dvd_pow_add_one (by decide) (by omega))
    obtain ⟨p, hp_prime, hp_dvd, hp_new⟩ := exists_prime_factor_pow_sub_one 2 1 N (by decide) (by decide) (by decide) hN h_not_six (by simp)
    have h_p_dvd : p ∣ 2 ^ n + 1 := by
      have : p ∣ 2 ^ (2 * n) - 1 := hp_dvd
      have : p ∣ (2 ^ n - 1) * (2 ^ n + 1) := by exact_mod_cast this
      refine (hp_prime.dvd_or_dvd this).resolve_left ?_
      intro h; apply hp_new n (by omega) h
    have h_p_new : p ∤ n := by
      intro h; have h_p_le_n : p ≤ n := Nat.le_of_dvd h0 h
      have : p - 1 < n := by omega
      have : ord_p 2 ∣ p - 1 := ord_p_dvd_card_univ
      have : ord_p 2 < N := by omega
      have : p ∣ 2 ^ ord_p 2 - 1 := ord_p_dvd_pow_sub_one 2
      apply hp_new (ord_p 2) (by omega) this
    use n * p
    simp [hp_prime, h_p_new, h_p_dvd, hcard]
    constructor; · omega
    · exact Nat.dvd_trans hdiv (Nat.pow_add_one_dvd_pow_add_one (by decide) (by omega))
