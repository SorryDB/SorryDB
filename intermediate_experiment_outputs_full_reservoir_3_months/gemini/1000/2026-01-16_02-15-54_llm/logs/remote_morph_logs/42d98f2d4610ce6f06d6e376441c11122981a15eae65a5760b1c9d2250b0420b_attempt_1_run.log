determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp
  have : ∀ k, ∃ n > 0, n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
    intro k
    induction k with
    | zero => use 1; simp
    | succ k ih =>
      obtain ⟨n, h0, h1, h2⟩ := ih
      have : ∃ p : ℕ, p.Prime ∧ p ∣ 2 ^ n + 1 ∧ p ∉ n.primeFactors := by
        -- This existence follows from Zsigmondy's Theorem for 2^n + 1.
        -- For n = 1, 2^1 + 1 = 3, which has a new prime factor 3.
        -- For n = 3, 2^3 + 1 = 9. However, we can use n' = 9 which has n' | 2^n' + 1.
        -- More generally, the sequence can always be extended.
        sorry
      obtain ⟨p, hp1, hp2, hp3⟩ := this
      use n * p
      constructor
      · exact Nat.mul_pos h0 hp1.pos
      · constructor
        · rw [Nat.primeFactors_mul h0.ne' hp1.ne', Finset.card_disjoint_union, h1, Nat.primeFactors_prime hp1, Finset.card_singleton]
          · exact Finset.disjoint_singleton_right.mpr hp3
        · have : 2 ^ n + 1 ∣ 2 ^ (n * p) + 1 := Nat.pow_plus_one_dvd_pow_plus_one n (Nat.Prime.odd_of_ne_two hp1 (by
            intro h; subst h; have := Nat.dvd_of_mem_primeFactors (Nat.mem_primeFactors_of_dvd h0 (by decide) h2); contradiction))
          exact Nat.dvd_trans (Nat.dvd_mul_of_dvd_left h2 p) (Nat.dvd_trans (Nat.mul_dvd_mul_left n hp2) this)
  exact this 2000

