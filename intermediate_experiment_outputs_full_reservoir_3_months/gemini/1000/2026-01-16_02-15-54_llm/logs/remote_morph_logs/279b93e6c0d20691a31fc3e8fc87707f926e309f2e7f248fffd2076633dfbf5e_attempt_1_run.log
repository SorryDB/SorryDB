def circuit (n r : ℕ) [NeZero n] : FormalCircuit (F p) (fields n) (fields n) where
  main := main n r

  localLength _ := n

  Spec input output := output = input.rotate r

  soundness := by
    circuit_proof_start
    simp [h_holds, ← h_input, Vector.rotate, Vector.map_mapFinRange, Vector.get_map]
