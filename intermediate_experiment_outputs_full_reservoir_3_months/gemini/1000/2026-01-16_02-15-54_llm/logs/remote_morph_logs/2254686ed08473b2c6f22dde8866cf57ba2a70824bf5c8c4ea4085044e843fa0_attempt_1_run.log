-/
lemma logCounting_circleIntegrable {r : ℝ} {f : ℂ → ℂ} (h : Meromorphic f) :
    CircleIntegrable (logCounting f · r) 0 1 := by
  exact (continuous_logCounting h r).circleIntegrable 0 1

```
