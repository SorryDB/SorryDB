open BigOperators Real Nat Topology Rat

theorem mathd_algebra_282 (f : ℝ → ℝ) (h₀ : ∀ x : ℝ, ¬ (Irrational x) → f x = abs (Int.floor x))
  (h₁ : ∀ x, Irrational x → f x = (Int.ceil x) ^ 2) :
  f (8 ^ (1 / 3)) + f (-Real.pi) + f (Real.sqrt 50) + f (9 / 2) = 79 := by
  have h1 : f (8 ^ (1 / 3)) = 2 := by
    rw [h₀] <;> norm_num [Irrational]
  have h2 : f (-Real.pi) = 9 := by
    rw [h₁ _ (irrational_neg.mpr irrational_pi)]
    have : ⌈-Real.pi⌉ = -3 := by
      apply Int.ceil_eq_iff.mpr
      constructor <;> linarith [three_lt_pi, pi_lt_four]
    rw [this]; norm_num
  have h3 : f (Real.sqrt 50) = 64 := by
    have ir : Irrational (Real.sqrt 50) := by
      rw [show (50 : ℝ) = 25 * 2 by norm_num, Real.sqrt_mul (by norm_num)]
      rw [show Real.sqrt 25 = 5 by norm_num]
      exact Irrational.rat_mul irrational_sqrt_two (by norm_num)
    rw [h₁ _ ir]
    have : ⌈Real.sqrt 50⌉ = 8 := by
      apply Int.ceil_eq_iff.mpr
      constructor
      · rw [Real.sqrt_lt]; norm_num
      · rw [Real.sqrt_le_iff (by norm_num)]; norm_num
    rw [this]; norm_num
  have h4 : f (9 / 2) = 4 := by
    rw [h₀] <;> norm_num [Irrational]
  rw [h1, h2, h3, h4]; norm_num
