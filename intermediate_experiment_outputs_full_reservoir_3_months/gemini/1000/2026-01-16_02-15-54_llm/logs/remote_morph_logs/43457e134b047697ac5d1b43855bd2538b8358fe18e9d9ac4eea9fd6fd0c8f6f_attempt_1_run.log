/--An attempt at proving the pumping lemma for context-free languages.-/
theorem PumpingLemma :
  ∀ language : ContextFreeLanguage, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
    intro language
    by_cases ε ∈ language.1
    case pos =>
      --Ignoriere den Fall ε ∈ L
      have h_cf : (fun w => w ∈ language.val ∧ w ≠ ε).is_context_free := sorry
      obtain ⟨n, hn⟩ := PumpingLemma ⟨_, h_cf⟩
      use n
      intro z
      have h_z : z.val ∈ (fun w => w ∈ language.val ∧ w ≠ ε) := ⟨z.2.1, by intro h; rw [h] at z; have := z.2.2; simp [h, Word.len] at this; linarith⟩
      obtain ⟨u, v, w, x, y, h_eq, h_vx, h_vwx, h_pump⟩ := hn ⟨z.val, h_z, z.2.2⟩
      use u, v, w, x, y
      exact ⟨h_eq, h_vx, h_vwx, fun k => (h_pump k).1⟩
    case neg h_neg =>
      sorry
