/--An attempt at proving the pumping lemma for context-free languages.-/
theorem PumpingLemma :
  ∀ language : ContextFreeLanguage, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
    intro language
    by_cases ε ∈ language.1
    case pos =>
      -- If ε is in the language, we can reduce this to the case where ε ∉ L.
      -- Since any word z with |z| ≥ n ≥ 1 is not ε, the pumping property holds the same.
      have ⟨n, hn⟩ : ∃ n, ∀ z : {z | z ∈ {w | w ∈ language.1 ∧ w ≠ ε} ∧ z.len ≥ n},
        ∃ u v w x y, z.val = u * v * w * x * y ∧ (v * x).len ≥ 1 ∧ (v * w * x).len ≤ n ∧
        ∀ k, u * v ^ k * w * x ^ k * y ∈ {w | w ∈ language.1 ∧ w ≠ ε} := sorry
      exists n
      intro z
      have z' : z.1 ∈ {w | w ∈ language.1 ∧ w ≠ ε} := ⟨z.2.1, λ h => by subst h; linarith [z.2.2]⟩
      obtain ⟨u, v, w, x, y, h⟩ := hn ⟨z.1, ⟨z', z.2.2⟩⟩
      exact ⟨u, v, w, x, y, h.1, h.2.1, h.2.2.1, λ k => (h.2.2.2 k).1⟩
    case neg h_neg =>
      obtain ⟨nt, cfg, h_cfg⟩ := language.2
      obtain ⟨cfg_cnf, h_cnf⟩ := equivalent_CNF_Grammar α nt nt ⟨cfg, by rwa [h_cfg]⟩
      let n := 2 ^ cfg_cnf.val.V.card + 1
      use n
      intro z
      obtain ⟨z_in_L, z_len⟩ := z.2
      have z_in_cnf : z.1 ∈ cfg_cnf.val.GeneratedLanguage := sorry
      -- Using derivation_path_length and derivation_len_over_V_imp_double_var
      sorry
