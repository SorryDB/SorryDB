theorem PumpingLemma :
  ∀ language : ContextFreeLanguage, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
    intro language
    by_cases ε ∈ language.1
    case pos =>
      obtain ⟨n, hn⟩ := (sorry : ∃ n, ∀ z : {z ∈ (fun w => w ∈ language.val ∧ w ≠ ε) | z.len ≥ n}, ∃ u v w x y, z.val = u * v * w * x * y ∧ (v * x).len ≥ 1 ∧ (v * w * x).len ≤ n ∧ (∀ k, u * v^k * w * x^k * y ∈ language.val))
      exact ⟨n + 1, fun ⟨z, hz_mem, hz_len⟩ => hn ⟨z, ⟨hz_mem, (by intro h; rw [h, Word.eps_len_0] at hz_len; cases hz_len)⟩, (by exact Nat.le_of_succ_le hz_len)⟩⟩
    case neg =>
      obtain ⟨nt, cfg, h_cfg⟩ := language.2
      have h_no_eps : ε ∉ cfg.GeneratedLanguage := by
        rw [← coerceLang_not_mem, h_cfg]
        exact h
      obtain ⟨cfg_cnf, h_cnf_eq⟩ := equivalent_CNF_Grammar α nt nt ⟨cfg, h_no_eps⟩
      let n := 2 ^ cfg_cnf.val.V.card + 1
      use n
      intro z
      obtain ⟨hz_mem, hz_len⟩ := z.2
      rw [← h_cfg, ← h_cnf_eq] at hz_mem
      obtain ⟨z_word, hz_word_mem, rfl⟩ := hz_mem
      sorry
