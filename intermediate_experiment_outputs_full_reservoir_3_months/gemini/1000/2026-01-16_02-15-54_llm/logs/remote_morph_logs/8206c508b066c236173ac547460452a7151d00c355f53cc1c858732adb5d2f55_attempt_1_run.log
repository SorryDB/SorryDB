    theorem RelIO.liftFinf_get {S} {n : Nat} {i : Fin n} {f : Fin n → RelIO S}:
      (RelIO.liftFinf n f).getIO i = f i := by
      induction n generalizing i f with
      | zero => exact i.elim0
      | succ n ih =>
        cases i using Fin.cases with
        | zero => rfl
