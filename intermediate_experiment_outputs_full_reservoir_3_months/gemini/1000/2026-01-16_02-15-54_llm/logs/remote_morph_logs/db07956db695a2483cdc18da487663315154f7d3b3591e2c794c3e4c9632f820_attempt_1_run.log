      · exact hS.card_pos.ne'
    have : ((deck j + deck k : ℚ) / 2) ^ S.card = ∏ i ∈ S, (deck i : ℚ) := by
      apply (Rat.cast_inj (R := ℝ)).1
      simp only [Rat.cast_pow, Rat.cast_div, Rat.cast_add, Rat.cast_natCast, Rat.cast_ofNat]
