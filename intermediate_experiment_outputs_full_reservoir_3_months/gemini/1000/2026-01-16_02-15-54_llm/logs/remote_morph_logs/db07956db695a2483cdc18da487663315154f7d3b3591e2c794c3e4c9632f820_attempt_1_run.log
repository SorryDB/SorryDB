    have h_odd : ∃ m, 1 < 2 * m + 1 ∧ (2 * m + 1 : ℕ) ∣ n := by
      rcases Nat.exists_odd_divisor_gt_one_of_not_isPowTwo (by rintro h; exact h_not_pow2 h.isPowTwo) h1 with ⟨m, hm_odd, hm_gt1, hm_div⟩
