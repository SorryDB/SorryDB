      use (∏ l in S, deck l).nthRoot S.card
      rw [← Real.nat_cast_pow, ← Real.nat_cast_mul, ← Real.nat_cast_pow, ← Real.nat_cast_pow] at this
      rw [← (Real.nat_cast_inj).2 (Nat.pow_left_inj hS.card.pos_iff.1 (Nat.pow_pos (hpos i) _) (Nat.pow_pos (hpos j) _) (Nat.cast_inj.1 this)),
        Nat.cast_pow, Real.mul_rpow, Real.rpow_nat_cast, Real.rpow_nat_cast, ← mul_pow,
        Real.rpow_inv_nat_cast_pow _ hS.ne_empty] <;> positivity
