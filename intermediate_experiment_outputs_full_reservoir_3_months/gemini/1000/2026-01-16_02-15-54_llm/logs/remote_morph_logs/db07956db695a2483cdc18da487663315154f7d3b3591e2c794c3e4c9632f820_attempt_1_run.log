  refine ⟨fun h => h.1, fun hn => ⟨hn, fun deck hpos hpair => ?_⟩⟩
  have h_int : ∀ j k, (↑(deck j) + ↑(deck k)) / (2 : ℝ) = ↑((deck j + deck k) / 2) ∧ (deck j + deck k) % 2 = 0 := by
    intro j k
    rcases hpair j k with ⟨S, hSn, hG⟩
    have : (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ)) = ((∏ i ∈ S, deck i) : ℕ) ^ (1 / (#S : ℝ)) := by
      rw [Nat.cast_prod]; rfl
    rw [this] at hG
    have h_gm_nat : ∃ m : ℕ, (↑(deck j) + ↑(deck k)) / 2 = (m : ℝ) := by
      use ((deck j + deck k) / 2)
      have : (deck j + deck k) % 2 = 0 := by
        have h_gm_pow : ((deck j + deck k : ℝ) / 2) ^ (#S : ℕ) = (∏ i ∈ S, deck i) := by
          rw [hG, ← Real.rpow_nat_cast, ← Real.rpow_mul] <;> simp [hSn.ne_empty]
        have h_rat : (deck j + deck k : ℚ) / 2 = (((deck j + deck k : ℝ) / 2) : ℝ) := rfl
        have h_q : ((deck j + deck k : ℚ) / 2) ^ (#S : ℕ) = (∏ i ∈ S, deck i) := by
          apply (Rational.cast_inj (K := ℝ)).1; simp [h_gm_pow]
        have h_z : ∃ m : ℤ, (deck j + deck k : ℚ) / 2 = m := by
          apply Rational.isInteger_iff_pow_isInteger.2 (n := #S.card)
          · simp [hSn.ne_empty]
          · rw [h_q]; use (∏ i ∈ S, deck i : ℤ); simp
        rcases h_z with ⟨m, hm⟩
        have : (deck j + deck k : ℚ) = 2 * m := by rw [← hm]; field_simp
        have h_2m : (deck j + deck k : ℤ) = 2 * m := by apply (Rational.cast_inj (K := ℚ)).1; simp [this]
