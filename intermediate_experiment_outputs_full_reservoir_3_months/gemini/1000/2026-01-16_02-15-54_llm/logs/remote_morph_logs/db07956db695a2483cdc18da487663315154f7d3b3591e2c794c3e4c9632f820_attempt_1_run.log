/-
Copyright (c) 2025 Joseph Myers. All rights reserved.
Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n; simp [answer]
  refine ⟨fun h ↦ h.1, fun h1 ↦ ⟨h1, ?_⟩⟩
  intro deck h_pos h_mean i j
  by_contra h_neq
  let s := ∑ i, deck i
  have : ∀ d : Fin n → ℕ, (∀ i, 0 < d i) → (Pairwise fun j k ↦ ∃ S, S.Nonempty ∧ (d j + d k : ℝ) / 2 = (∏ i ∈ S, (d i : ℝ)) ^ (1 / (#S : ℝ))) → (∃ i j, d i ≠ d j) → False := by
    intro d hp hm hne
    have h_parity : ∀ j k, (d j + d k) % 2 = 0 := by
      intro j k; by_cases hjk : j = k; · simp [hjk]
      obtain ⟨S, hS, hGM⟩ := hm hjk
      have : ∃ m : ℕ, (d j + d k : ℝ) / 2 = m := by
        have : (∏ i ∈ S, (d i : ℝ)) ^ (1 / (#S : ℝ)) = (∏ i ∈ S, d i : ℕ) ^ (1 / (#S : ℝ)) := by simp
        rw [this] at hGM; have h_rat : ((d j + d k : ℚ) / 2) ^ (#S : ℕ) = (∏ i ∈ S, d i : ℕ) := by
          rw [← (Real.coe_nat_inj), Real.norm_num_pow, ← hGM]; field_simp; ring
        obtain ⟨m, hm⟩ := @Nat.pow_mem_range_pow_abs_eq_one_iff_mem_range_one ℚ _ ((d j + d k : ℚ) / 2) (#S) (by simp [hS.ne_empty]) (by rw [h_rat]; norm_cast)
        exact ⟨m, by norm_cast at hm⟩
      obtain ⟨m, hm⟩ := this; use m; rw [← hm]; field_simp; ring
    have h_all_parity : ∀ j, d j % 2 = d 0 % 2 := fun j ↦ by
      have : (d j + d 0) % 2 = 0 := h_parity j 0
      omega
    let d' := if d 0 % 2 = 0 then (fun i ↦ d i / 2) else (fun i ↦ (d i + 1) / 2)
    have : ∑ i, d' i < ∑ i, d i := by sorry
    sorry
  exact this deck h_pos h_mean (not_forall.mp (not_forall.mp h_neq))
```
