    have h_deck_pos : ∀ i, 0 < deck i := by intro i; dsimp [deck, a]; split_ifs <;> norm_num
    have h_am_gm : Pairwise (fun j k ↦ ∃ S : Finset (Fin n), S.Nonempty ∧ (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) := by
      intro j k hjk
      by_cases hj : j % (2 * m + 1) < 2 * m + 1 ∧ k % (2 * m + 1) < 2 * m + 1
      · use {j, k}
        sorry -- the actual proof is very involved
      · sorry
    have h_not_equal : ¬∀ i j, deck i = deck j := by
      use ⟨0, h1⟩, ⟨1, h1⟩
      sorry
    exact h_not_equal (h deck h_deck_pos h_am_gm)
  · rintro ⟨h_pow2, h1⟩
    refine ⟨h1, ?_⟩
    intro deck h_pos h_pair
    sorry
