          apply Int.cast_inj (R := ℤ).1; simp [h_2m, Int.toNat_of_nonneg]
        rw [this]; simp
      rw [Nat.cast_div (Nat.dvd_of_mod_eq_zero this) 2]; field_simp
    rcases h_gm_nat with ⟨m, hm⟩
