Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  simp only [answer, Set.ext_iff, Set.mem_setOf_eq, and_iff_left_iff_imp]
  intro n hn deck h_pos h_deck
  by_contra h_neq
  have h_pair : ∀ j k, (deck j + deck k : ℝ) / 2 ≥ (min (deck j) (deck k) : ℝ) := by
    intro j k; rw [← min_add_max j k]; simp only [Nat.cast_add, min_def, max_def]
    split_ifs <;> linarith
  let m := Finset.univ.image deck
  have m_nonempty : m.Nonempty := Finset.Nonempty.image Finset.univ_nonempty deck
  let a_max := m.max' m_nonempty
  let a_min := m.min' m_nonempty
  have h_all_max : ∀ i, deck i = a_max := by
    by_contra h_not_all_max
    let S_max := {i | deck i = a_max}.toFinset
    let S_not_max := {i | deck i < a_max}.toFinset
    have h_S_max_nonempty : S_max.Nonempty := by
      obtain ⟨i, hi⟩ := Finset.mem_image.mp (m.max'_mem m_nonempty)
      exact ⟨i, by simp [S_max, hi.2]⟩
    have h_S_not_max_nonempty : S_not_max.Nonempty := by
      obtain ⟨i, hi⟩ := not_forall.mp h_not_all_max
      exact ⟨i, by simp [S_not_max, lt_of_le_of_ne (Finset.le_max' m _ (Finset.mem_image_of_mem _ (Finset.mem_univ i))) hi]⟩
    obtain ⟨j, hj⟩ := h_S_max_nonempty
    obtain ⟨k, hk⟩ := h_S_not_max_nonempty
    obtain ⟨S, hS_none, hS_eq⟩ := h_deck (by simp at hj hk; exact hj.symm.ne hk)
    have h_am : (deck j + deck k : ℝ) / 2 < a_max := by
      simp at hj hk; linarith
    have h_gm : (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ)) = a_max → ∀ i ∈ S, deck i = a_max := by
      intro h; rw [← h]
      exact (Real.geom_mean_eq_max (by intro i hi; exact Nat.cast_nonneg _) hS_none).mp h
    have h_gm_le_max : (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ)) ≤ a_max := by
      apply Real.geom_mean_le_max
      intro i hi; exact Nat.cast_nonneg _
    linarith
  intro i j; rw [h_all_max i, h_all_max j]
