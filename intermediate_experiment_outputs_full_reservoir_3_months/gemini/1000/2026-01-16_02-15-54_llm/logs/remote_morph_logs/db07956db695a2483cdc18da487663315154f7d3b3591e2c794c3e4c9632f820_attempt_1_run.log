def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  simp only [answer, Set.mem_setOf_eq, and_iff_right_iff_imp]
  intro hn deck hpos hgm
  by_contra! h_any
  let S_val := Finset.univ.image deck
  let d_max := S_val.max' (Finset.Nonempty.image Finset.univ_nonempty deck)
  let d_min := S_val.min' (Finset.Nonempty.image Finset.univ_nonempty deck)
  have h_diff : d_max > d_min := by
    rcases h_any with ⟨i, j, hij⟩
    exact lt_of_le_of_ne (Finset.min'_le _ _ (Finset.mem_image_of_mem _ (Finset.mem_univ _)))
      (fun h_eq ↦ hij (deck.injective_iff.mp (fun _ _ _ ↦ (by
        have := Finset.max'_le _ _ (Finset.mem_image_of_mem _ (Finset.mem_univ i))
        have := Finset.min'_le _ _ (Finset.mem_image_of_mem _ (Finset.mem_univ j))
        rw [h_eq] at this
        exact le_antisymm (by assumption) (by assumption))) i j))
  let s := fun (deck : Fin n → ℕ) ↦ (Finset.univ.image deck).max' (by simp) - (Finset.univ.image deck).min' (by simp)
  have : ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦ ∃ S, S.Nonempty ∧
    (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) → (∀ i j, deck i = deck j) := by
    intro d hp hg
    let f := fun (d : Fin n → ℕ) ↦ (Finset.univ.image d).max' (by simp) - (Finset.univ.image d).min' (by simp)
    let inv := fun (d : Fin n → ℕ) ↦ (∀ i j, d i = d j)
    apply WellFounded.induction (wellFounded_lt.measure f) d
    intro d' ih h'p h'g
    by_cases h_inv : inv d'
    · exact h_inv
    · have h_parity : ∀ i j, d' i % 2 = d' j % 2 := by
        intro i j
        by_cases hij : i = j
        · rw [hij]
        obtain ⟨S, hS, hGM⟩ := h'g hij
        have h_pow : ((d' i + d' j : ℝ) / 2) ^ S.card = ∏ k ∈ S, (d' k : ℝ) := by
          rw [hGM, Real.rpow_natCast_inv (by simp) (by simp), Real.rpow_natCast]
        have h_int : ∃ (m : ℕ), (d' i + d' j : ℝ) / 2 = m := by
          have h_prod_int : ∏ k ∈ S, (d' k : ℝ) = (∏ k ∈ S, d' k : ℕ) := by simp
          rw [h_prod_int] at h_pow
          have h_q : ((d' i + d' j : ℚ) / 2) ^ S.card = (∏ k ∈ S, d' k : ℕ) := by
            apply (Rat.cast_inj (K := ℝ)).mp
            simp only [Rat.cast_pow, Rat.cast_div, Rat.cast_add, Rat.cast_natCast, Rat.cast_ofNat, h_pow]
          obtain ⟨m, hm⟩ := Nat.pow_mem_range_pow_abs h_q
          exact ⟨m, by simp [hm]⟩
        obtain ⟨m, hm⟩ := h_int
        have h_even : (d' i + d' j) % 2 = 0 := by
          have : (d' i + d' j : ℚ) = 2 * m := by
            simp only [div_eq_mul_inv, Rat.mul_inv_eq_iff (by simp : (2 : ℚ) ≠ 0)] at hm
            exact_mod_cast hm
          rw [← Nat.cast_add] at this
          exact_mod_cast (Nat.dvd_of_mod_eq_zero (by
            rw [← Nat.mod_eq_zero_of_dvd (by use m); exact_mod_cast this]))
        exact Nat.mod_eq_mod_iff_add_even.mpr h_even
      let r := d' 0 % 2
      let d'' := if r = 0 then (fun i ↦ d' i / 2) else (fun i ↦ (d' i - 1) / 2)
      have h_f : f d'' < f d' := by
        simp only [f, d'', ite_self]
        rcases r with _| _
        · simp only [Nat.div_div_eq_div_mul, Nat.sub_div, (by simp : 2 ≠ 0)]
          apply Nat.div_lt_of_lt_mul
          -- Parity and d_max > d_min ensure reduction
          sorry
        · sorry
      exact ih d'' h_f (by sorry) (by sorry)
  exact this deck hpos hgm
