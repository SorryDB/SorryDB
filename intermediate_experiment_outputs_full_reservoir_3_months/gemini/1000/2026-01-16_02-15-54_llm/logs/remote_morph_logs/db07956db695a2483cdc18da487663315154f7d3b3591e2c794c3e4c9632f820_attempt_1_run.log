Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n; simp [answer]; intro hn; constructor; swap
  · intro h deck hpos hgm i j
    have : ∀ i j, deck i = deck j := by
      let m := (Finset.univ.image deck).max' (Finset.Nonempty.image Finset.univ_nonempty _)
      let s := Finset.univ.filter (λ i => deck i = m)
      have hsn : s.card = n := by
        by_contra hsc
        have hsc' : s.card < n := Nat.lt_of_le_of_ne (Finset.card_le_univ _) hsc
        obtain ⟨j, hj⟩ := Finset.exists_not_mem_of_card_lt_univ hsc'
        obtain ⟨k, hk⟩ := Finset.Nonempty.exists_mem (s.nonempty_iff.mpr (Finset.card_pos.mp (Finset.card_pos.mpr ⟨Finset.univ.max' _, (by simp)⟩)))
        obtain ⟨S, hSe, hgm_jk⟩ := hgm (ne_of_mem_of_not_mem hk hj)
        have h_gm_le : (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ)) ≤ m := by
          rw [←Real.rpow_one (m : ℝ)]; apply Real.rpow_le_rpow_of_exponent_le
          · apply Real.geom_mean_le_arith_mean hSe; intro i _; positivity
          · exact (one_div_le_one_div_of_pos (by positivity) (by exact_mod_cast hSe.card_pos)).mpr (by exact_mod_cast hSe.card_pos)
        have : (deck j + deck k : ℝ) / 2 < m := by
          simp at hj; have : deck j < m := (Finset.max'_le _ _ (Finset.mem_image_of_mem _ (Finset.mem_univ j))).lt_of_ne hj
          linarith [hk, hj, this]
        linarith [hgm_jk, h_gm_le]
      intro i j; rw [←Finset.mem_filter, ←Finset.mem_filter]
      revert i j; rw [←Finset.eq_univ_iff_forall.mpr hsn]; simp
    apply this
  · intro h; exact hn
