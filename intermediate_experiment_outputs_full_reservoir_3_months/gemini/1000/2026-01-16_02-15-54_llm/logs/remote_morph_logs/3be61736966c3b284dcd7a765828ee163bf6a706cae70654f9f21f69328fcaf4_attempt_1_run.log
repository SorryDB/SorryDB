    rw [hb2, ha2, h1] at h
    cases h_quad (b ^ 2 * a ^ 2) (by positivity) with
    | inl h_eq1 => rw [h_eq1] at h; field_simp at h; have : a^2 = 1 := by nlinarith; exact ha1 (by nlinarith)
    | inr h_eq2 => rw [h_eq2] at h; field_simp at h; have : b^2 = 1 := by nlinarith; exact hb1 (by nlinarith)
