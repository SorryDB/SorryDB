import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    (∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x := by
  constructor
  · intro h
    have f1 : f 1 = 1 := by
      specialize h 1 1 1 1 zero_lt_one zero_lt_one zero_lt_one zero_lt_one rfl
      simp [h₁] at h; exact h
    have fsq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by
      intro x hx; specialize h x x x x hx hx hx hx rfl
      simp at h; exact h.symm
    have f_choice : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h x x 1 (x ^ 2) hx hx zero_lt_one (pow_pos hx 2) (by simp)
      rw [f1, fsq, fsq] at h
      have : f x ^ 2 = x ^ 2 ∨ f x ^ 2 = 1 / x ^ 2 := by
        field_simp [hx, h₁ x hx] at h
        nlinarith
      rcases this with h2 | h2
      · left; exact (Real.sqrt_eq_iff_sq_eq (h₁ x hx).le hx.le).mpr h2
      · right; exact (Real.sqrt_eq_iff_sq_eq (h₁ x hx).le (inv_pos.mpr hx).le).mpr (by rw [h2, one_div, inv_pow])
    by_contra! h_neg
    obtain ⟨⟨a, ha_pos, ha_neq_a⟩, ⟨b, hb_pos, hb_neq_inv_b⟩⟩ := h_neg
    have ha_inv : f a = 1 / a := (f_choice a ha_pos).resolve_left ha_neq_a
    have hb_id : f b = b := (f_choice b hb_pos).resolve_right hb_neq_inv_b
    have ha1 : a ≠ 1 := by rintro rfl; simp [f1] at ha_neq_a
    have hb1 : b ≠ 1 := by rintro rfl; simp [f1] at hb_neq_inv_b
    specialize h b a 1 (b * a) hb_pos ha_pos zero_lt_one (mul_pos hb_pos ha_pos) (by simp)
    rw [f1, fsq, fsq (b * a) (mul_pos hb_pos ha_pos), hb_id, ha_inv] at h
    rcases f_choice (b * a) (mul_pos hb_pos ha_pos) with hba | hba <;> rw [hba] at h <;> field_simp [ha_pos, hb_pos, h₁] at h
    · nlinarith
    · nlinarith
  · rintro (h | h) w x y z hw hx hy hz hwxyz
    · rw [h w, h x, h (y ^ 2), h (z ^ 2), hwxyz]
    · rw [h w, h x, h (y ^ 2), h (z ^ 2)]
      field_simp [hw.ne', hx.ne', hy.ne', hz.ne']
      rw [hwxyz]
      ring
