    | inl hab => rw [hab] at h; have := h₁ (a * b) (by positivity); field_simp [ha, hb] at h; have : b = 1 := by nlinarith [hb]; simp [this, h1] at hnb
    | inr hab => rw [hab] at h; have := h₁ (a * b) (by positivity); field_simp [ha, hb] at h; have : a = 1 := by nlinarith [ha]; simp [this, h1] at hna
