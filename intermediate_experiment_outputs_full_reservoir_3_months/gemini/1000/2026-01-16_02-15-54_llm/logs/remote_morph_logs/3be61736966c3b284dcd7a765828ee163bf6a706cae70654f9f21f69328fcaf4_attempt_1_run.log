import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  unfold answer
  constructor
  · intro h
    have f1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
      simp [h₁ 1 (by norm_num)] at h
      field_simp [h₁ 1 (by norm_num)] at h
      nlinarith [h₁ 1 (by norm_num)]
    have f_or : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h x 1 (Real.sqrt x) (Real.sqrt x) hx (by norm_num) (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) (by simp [Real.mul_self_sqrt (le_of_lt hx)])
      simp [f1, Real.mul_self_sqrt (le_of_lt hx)] at h
      have hfx := h₁ x hx
      field_simp [hx.ne.symm, hfx.ne.symm] at h
      have : (x * f x - 1) * (f x - x) = 0 := by nlinarith
      rcases mul_eq_zero.mp this with h2 | h2
      · right; field_simp [hx.ne.symm] at h2; exact h2
      · left; exact h2
    by_contra hn
    push_neg at hn
    rcases hn with ⟨⟨a, ha, hna⟩, ⟨b, hb, hnb⟩⟩
    have fa : f a = 1 / a := (f_or a ha).resolve_left hna
    have fb : f b = b := (f_or b hb).resolve_right hnb
    have a1 : a ≠ 1 := by intro h; rw [h, f1] at hna; exact hna (by norm_num)
    have b1 : b ≠ 1 := by intro h; rw [h, f1] at hnb; exact hnb (by norm_num)
    specialize h a b (Real.sqrt (a * b)) (Real.sqrt (a * b)) ha hb (Real.sqrt_pos.mpr (mul_pos ha hb)) (Real.sqrt_pos.mpr (mul_pos ha hb)) (by simp [Real.mul_self_sqrt (le_of_lt (mul_pos ha hb))])
    rw [fa, fb, Real.mul_self_sqrt (le_of_lt (mul_pos ha hb))] at h
    rcases f_or (a * b) (mul_pos ha hb) with fab | fab
    · rw [fab] at h
      field_simp [ha.ne.symm, hb.ne.symm, h₁ (a * b) (mul_pos ha hb)] at h
      have : a ^ 4 = 1 ^ 4 := by nlinarith
      exact a1 ((pow_left_inj (le_of_lt ha) (by norm_num) (by norm_num)).mp this)
    · rw [fab] at h
      field_simp [ha.ne.symm, hb.ne.symm, h₁ (a * b) (mul_pos ha hb)] at h
      have : b ^ 4 = 1 ^ 4 := by nlinarith
      exact b1 ((pow_left_inj (le_of_lt hb) (by norm_num) (by norm_num)).mp this)
  · rintro (h | h) w x y z hw hx hy hz hprod
    · simp [h, hw, hx, hy, hz, hprod, pow_pos]
    · simp [h, hw, hx, hy, hz, pow_pos]
      field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm]
      rw [← mul_pow, ← mul_pow, hprod]
      field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm]
      ring

