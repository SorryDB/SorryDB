import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by linarith) (by linarith) (by linarith) (by linarith) (by rfl)
      simp [h₁ 1 (by linarith)] at h
      exact h
    have h_choice : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h 1 x (Real.sqrt x) (Real.sqrt x) (by linarith) hx (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) (by field_simp)
      simp [h1, Real.mul_self_sqrt (le_of_lt hx)] at h
      field_simp [h₁ x hx, hx] at h
      have : (x * f x - 1) * (f x - x) = 0 := by nlinarith
      cases' mul_eq_zero.mp this with hf hf
      · right; field_simp [hx] at hf; exact hf
      · left; exact hf
    by_contra h_neg
    push_neg at h_neg
    rcases h_neg with ⟨⟨a, ha, hfa_neq_a⟩, ⟨b, hb, hfb_neq_inv_b⟩⟩
    have hfa : f a = 1 / a := (h_choice a ha).resolve_left hfa_neq_a
    have hfb : f b = b := (h_choice b hb).resolve_right hfb_neq_inv_b
    have ha1 : a ≠ 1 := by rintro rfl; exact hfa_neq_a h1
    have hb1 : b ≠ 1 := by rintro rfl; rw [inv_one] at hfb_neq_inv_b; exact hfb_neq_inv_b h1
    let y := Real.sqrt (a * b)
    have hy : y > 0 := Real.sqrt_pos.mpr (mul_pos ha hb)
    specialize h a b y y ha hb hy hy (by simp [y, Real.mul_self_sqrt (mul_pos ha hb).le])
    simp [hfa, hfb, Real.mul_self_sqrt (mul_pos ha hb).le] at h
    cases' h_choice (a * b) (mul_pos ha hb) with hab hab
    · field_simp [hab, ha, hb] at h
      have : a = 1 := by nlinarith [ha]
      exact ha1 this
    · field_simp [hab, ha, hb] at h
      have : b = 1 := by nlinarith [hb]
      exact hb1 this
  · rintro (hf | hf) w x y z hw hx hy hz hwx
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
      field_simp [hw, hx, hy, hz]
      rw [← hwx]
      field_simp [hw, hx]
      ring
