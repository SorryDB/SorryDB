import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have hf2 : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by
      intro x hx
      specialize h x x x x hx hx hx hx rfl
      field_simp [h₁, hx] at h
      exact h.symm
    have hf1 : f 1 = 1 := (eq_one_or_zero_of_mul_eq_self (hf2 1 zero_lt_one).symm).resolve_right (h₁ 1 zero_lt_one).ne.symm
    have h_root : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h x 1 (sqrt x) (sqrt x) hx zero_lt_one (sqrt_pos.mpr hx) (sqrt_pos.mpr hx) (by simp [hx.le])
      simp [hf1, hf2, hx.le] at h
      have : (x * f x - 1) * (f x - x) = 0 := by
        field_simp [h₁, hx, hx.ne.symm] at h
        rw [← mul_left_inj' (show (2 : ℝ) ≠ 0 by norm_num)]
        ring_nf; rw [h]; ring
      exact mul_eq_zero.mp this
    by_contra! h_not
    rcases h_not with ⟨⟨a, ha, h_af⟩, ⟨b, hb, h_bf⟩⟩
    have ha_ne_1 : a ≠ 1 := fun h => h_af (h ▸ hf1)
    have hb_ne_1 : b ≠ 1 := fun h => h_bf (h ▸ hf1)
    have h_a : f a = 1 / a := (h_root a ha).resolve_left h_af
    have h_b : f b = b := (h_root b hb).resolve_right h_bf
    specialize h a b (sqrt (a * b)) (sqrt (a * b)) ha hb (sqrt_pos.mpr (mul_pos ha hb)) (sqrt_pos.mpr (mul_pos ha hb)) (by simp [mul_pos ha hb |>.le])
    simp [hf2, mul_pos ha hb |>.le] at h
    rw [h_a, h_b] at h
    cases h_root (a * b) (mul_pos ha hb) with
    | inl hab =>
      rw [hab] at h
      field_simp [ha.ne.symm, hb.ne.symm, (mul_pos ha hb).ne.symm, h₁] at h
      have : a ^ 4 = 1 := by rw [← mul_left_inj' (show b * a ^ 2 ≠ 0 by positivity)]; ring_nf; rw [h]; ring
      exact ha_ne_1 ((pow_left_inj ha.le zero_le_one (by norm_num)).mp (this.trans (one_pow 4).symm))
    | inr hab =>
      rw [hab] at h
      field_simp [ha.ne.symm, hb.ne.symm, (mul_pos ha hb).ne.symm, h₁] at h
      have : b ^ 4 = 1 := by rw [← mul_left_inj' (show a * b ^ 2 ≠ 0 by positivity)]; ring_nf; rw [h]; ring
      exact hb_ne_1 ((pow_left_inj hb.le zero_le_one (by norm_num)).mp (this.trans (one_pow 4).symm))
  · rintro (h | h) w x y z hw hx hy hz heq
    · simp [h hw, h hx, h (pow_pos hy 2), h (pow_pos hz 2), heq]
    · simp [h hw, h hx, h (pow_pos hy 2), h (pow_pos hz 2)]
      field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm, (h₁ hw).ne.symm, (h₁ hx).ne.symm]
      rw [heq]
      field_simp
      ring

