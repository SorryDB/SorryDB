[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
      simp at h; field_simp [h₁ 1] at h; exact h
    have h2 : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by
      intro x hx
      specialize h x x x x hx hx hx hx (by norm_num)
      simp at h; field_simp [h₁ x, h₁ (x^2)] at h; exact h.symm
    have h3 : ∀ w x, 0 < w → 0 < x → f w ^ 2 + f x ^ 2 = (w / x + x / w) * f (w * x) := by
      intro w x hw hx
      let y := Real.sqrt (w * x)
      have hy : 0 < y := Real.sqrt_pos.mpr (mul_pos hw hx)
      specialize h w x y y hw hx hy hy (by simp [Real.mul_self_sqrt (mul_pos hw hx).le])
      simp [h2 y hy, Real.mul_self_sqrt (mul_pos hw hx).le, h₁ (w * x)] at h
      field_simp [h]; ring
    have h4 : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h3 x 1 hx (by norm_num)
      rw [h1, mul_one, one_div_one, add_comm] at h3
      have : (f x - x) * (f x - 1 / x) = 0 := by field_simp [hx]; nlinarith
      exact (mul_eq_zero.mp this).imp_left (fun h => sub_eq_zero.mp h) |>.imp_right (fun h => sub_eq_zero.mp h)
    by_cases h_all_x : ∀ x > 0, f x = x
    · left; exact h_all_x
    · right; intro x hx
      by_cases h_x1 : x = 1
      · rw [h_x1, h1, one_div_one]
      · rcases h4 x hx with hfx | hfx
        · exfalso; push_neg at h_all_x
          rcases h_all_x with ⟨w, hw, hwf⟩
          have hfw : f w = 1 / w := (h4 w hw).resolve_left hwf
          specialize h3 w x hw hx; rw [hfw, hfx] at h3
          rcases h4 (w * x) (mul_pos hw hx) with hfwx | hfwx
          · rw [hfwx] at h3; field_simp [hw, hx] at h3; have : w = 1 := by nlinarith [hw]
            exact hwf (by rw [this, h1])
          · rw [hfwx] at h3; field_simp [hw, hx] at h3; have : x = 1 := by nlinarith [hx]
            exact h_x1 this
        · exact hfx
  · intro h w x y z hw hx hy hz hwx
    rcases h with hf | hf
    · repeat rw [hf _ (by assumption)]; repeat rw [hf _ (by positivity)]
      simp
    · repeat rw [hf _ (by assumption)]; repeat rw [hf _ (by positivity)]
      field_simp [hw, hx, hy, hz]; rw [← mul_pow, hwx]; ring
```
