    rcases h_neg with ⟨⟨a, ha, hna⟩, ⟨b, hb, hnb⟩⟩
    have fa := (f_val a ha).resolve_left hna; have fb := (f_val b hb).resolve_right hnb
    specialize f_mix a b ha hb; rw [fa, fb] at f_mix
    cases f_val (a * b) (mul_pos ha hb) with
