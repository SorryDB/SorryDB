import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    (∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x := by
  constructor
  · intro h
    have hfsq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := fun x hx ↦ by
      specialize h x x x x hx hx hx hx rfl; simp [hx.ne', (h₁ _ hx).ne'] at h; exact h.symm
    have hf1 : f 1 = 1 := (mul_self_eq_self (f 1)).mp (hfsq 1 zero_lt_one).symm |>.resolve_left (h₁ 1 zero_lt_one).ne'
    have hf_prod : ∀ w x > 0, f (w * x) = w * x * (f w ^ 2 + f x ^ 2) / (w ^ 2 + x ^ 2) := by
      intro w x hw hx
      specialize h w x (Real.sqrt (w * x)) (Real.sqrt (w * x)) hw hx (Real.sqrt_pos.mpr (mul_pos hw hx)) (Real.sqrt_pos.mpr (mul_pos hw hx)) (by simp [Real.mul_self_sqrt (mul_pos hw hx).le])
      rwa [Real.sq_sqrt (mul_pos hw hx).le, ← hfsq _ (Real.sqrt_pos.mpr (mul_pos hw hx)), Real.sq_sqrt (mul_pos hw hx).le, ← two_mul, ← two_mul, mul_div_mul_left _ _ (two_ne_zero)] at h
    have hfx : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      have hx1 := hf_prod x 1 hx zero_lt_one; simp [hf1] at hx1
      have : (f x - x) * (x * f x - 1) = 0 := by
        field_simp [hx.ne', (by nlinarith : x ^ 2 + 1 ≠ 0), (h₁ x hx).ne'] at hx1
        linear_combination hx1
      cases' mul_eq_zero.mp this with hx_eq hx_inv
      · left; exact hx_eq
      · right; rw [← hx_inv]; field_simp [hx.ne']
    by_cases h_id : ∀ x > 0, f x = x
    · left; exact h_id
    · right; intro b hb
      by_cases hb1 : b = 1; · rw [hb1, hf1, one_div_one]
      have : ∃ a > 0, f a = 1 / a ∧ a ≠ 1 := by
        push_neg at h_id; rcases h_id with ⟨a, ha, hfa⟩
        use a, ha; cases' hfx a ha with h_ h_
        · exact (hfa h_).elim
        · exact ⟨h_, fun ha1 ↦ hfa (by rw [ha1, hf1])⟩
      rcases this with ⟨a, ha, hfa, ha1⟩; cases' hfx b hb with hb_eq hb_inv; swap; · exact hb_inv
      have hab := hf_prod a b ha hb; rw [hb_eq, hfa] at hab
      cases' hfx (a * b) (mul_pos ha hb) with hab_eq hab_inv
      · rw [hab_eq] at hab; have : a ^ 4 = 1 := by
          field_simp [ha.ne', hb.ne', (by nlinarith : a ^ 2 + b ^ 2 ≠ 0)] at hab
          linear_combination hab
        absurd ha1; rw [← one_pow 4] at this; exact pow_left_inj ha.le (zero_le_one) (by norm_num) |>.mp this
      · rw [hab_inv] at hab; have : b ^ 4 = 1 := by
          field_simp [ha.ne', hb.ne', (by nlinarith : a ^ 2 + b ^ 2 ≠ 0)] at hab
          linear_combination hab / (a ^ 2)
        absurd hb1; rw [← one_pow 4] at this; exact pow_left_inj hb.le (zero_le_one) (by norm_num) |>.mp this
  · rintro (h | h) w x y z hw hx hy hz heq
    · rw [h w hw, h x hx, h (y ^ 2) (pow_pos hy 2), h (z ^ 2) (pow_pos hz 2)]
    · rw [h w hw, h x hx, h (y ^ 2) (pow_pos hy 2), h (z ^ 2) (pow_pos hz 2)]
      field_simp [hw.ne', hx.ne', hy.ne', hz.ne']; rw [heq]; ring
