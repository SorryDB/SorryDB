open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have f1 : f 1 = 1 := by
      have h1 := h 1 1 1 1 (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
      field_simp [h₁ 1] at h1; nlinarith [h₁ 1]
    have fx : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      have hx1 := h x 1 (Real.sqrt x) (Real.sqrt x) hx (by norm_num) (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) (by rw [Real.mul_self_sqrt hx.le]; simp)
      rw [f1, Real.sq_sqrt hx.le] at hx1
      field_simp [h₁ x, h₁ 1, h₁ (Real.sqrt x)] at hx1; nlinarith
    by_cases hx : ∀ x > 0, f x = x
    · left; exact hx
    · right; intro b hb
      by_cases hb1 : b = 1
      · rw [hb1, f1]; norm_num
      · rcases fx b hb with rb | rb; swap; exact rb
        exfalso; push_neg at hx; rcases hx with ⟨a, ha, nfa⟩
        have ra : f a = 1 / a := (fx a ha).resolve_left nfa
        specialize h a b (Real.sqrt (a * b)) (Real.sqrt (a * b)) ha hb (Real.sqrt_pos.mpr (mul_pos ha hb)) (Real.sqrt_pos.mpr (mul_pos ha hb)) (by rw [Real.mul_self_sqrt (mul_pos ha hb).le])
        rw [Real.sq_sqrt (mul_pos ha hb).le, ra, rb] at h
        rcases fx (a * b) (mul_pos ha hb) with fab | fab <;> rw [fab] at h <;>
        field_simp [ha.ne', hb.ne', (mul_pos ha hb).ne', h₁ _] at h <;> nlinarith
  · rintro (hf | hf) w x y z hw hx hy hz heq <;>
    rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
