import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h1 : f 1 = 1 := by
      specialize h 1 1 1 1 zero_lt_one zero_lt_one zero_lt_one zero_lt_one rfl
      field_simp [h₁ 1] at h; nlinarith [h₁ 1]
    have h_sq : ∀ x > 0, f (x ^ 2) = (f x) ^ 2 := by
      intro x hx
      specialize h x 1 x 1 hx zero_lt_one hx zero_lt_one (by ring)
      simp [h1, h₁ x, h₁ (x ^ 2)] at h; exact h.symm
    have h_cases : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h (Real.sqrt x) (Real.sqrt x) x 1 (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) hx zero_lt_one (by simp [hx.le])
      simp [h1, h_sq, hx, Real.sqrt_sq hx.le, h₁ x] at h
      have h2 : (f x - x) * (x * f x - 1) = 0 := by field_simp [hx.ne.symm, h₁ x] at h; nlinarith
      rw [mul_eq_zero] at h2; rcases h2 with h3 | h3
      · left; exact h3
      · right; field_simp [hx.ne.symm] at h3 ⊢; linarith
    by_contra h_not; push_neg at h_not
    rcases h_not with ⟨⟨a, ha, h_fa1⟩, ⟨b, hb, h_fb1⟩⟩
    have h_fa : f a = 1 / a := (h_cases a ha).resolve_left h_fa1
    have h_fb : f b = b := (h_cases b hb).resolve_right h_fb1
    specialize h a b (Real.sqrt (a * b)) (Real.sqrt (a * b)) ha hb (Real.sqrt_pos.mpr (mul_pos ha hb)) (Real.sqrt_pos.mpr (mul_pos ha hb)) (by simp [ha.le, hb.le])
    simp [h_fa, h_fb, h_sq, Real.sqrt_sq (mul_pos ha hb).le, h₁ (a * b)] at h
    rcases h_cases (a * b) (mul_pos ha hb) with hab | hab
    · field_simp [ha.ne.symm, hb.ne.symm, hab] at h
      have : a ^ 2 = 1 := by nlinarith
      exact h_fa1 (by nlinarith [Real.sq_eq_one_iff.mp this])
    · field_simp [ha.ne.symm, hb.ne.symm, hab] at h
      have : b ^ 2 = 1 := by nlinarith
      exact h_fb1 (by nlinarith [Real.sq_eq_one_iff.mp this])
  · rintro (h | h) <;> intro w x y z hw hx hy hz heq
    · simp [h w hw, h x hx, h (y ^ 2) (by positivity), h (z ^ 2) (by positivity)]
    · simp [h w hw, h x hx, h (y ^ 2) (by positivity), h (z ^ 2) (by positivity)]
      field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm]
      rw [heq]; ring
