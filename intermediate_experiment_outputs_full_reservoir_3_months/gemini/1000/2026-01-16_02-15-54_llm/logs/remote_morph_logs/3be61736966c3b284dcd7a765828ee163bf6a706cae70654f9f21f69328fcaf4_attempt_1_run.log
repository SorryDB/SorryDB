import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have f1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
      have hf1 := h₁ 1 (by norm_num)
      field_simp at h
      nlinarith
    have h_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by
      intro x hx
      specialize h x 1 x 1 hx (by norm_num) hx (by norm_num) (by norm_num)
      simp [f1] at h
      field_simp [h₁ (x ^ 2) (pow_pos hx 2), h₁ 1 (by norm_num)] at h
      nlinarith
    have h_val : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h (Real.sqrt x) (Real.sqrt x) x 1 (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) hx (by norm_num) (by simp [Real.mul_self_sqrt hx.le])
      rw [h_sq, f1] at h
      rw [h_sq (Real.sqrt x) (Real.sqrt_pos.mpr hx), Real.sq_sqrt hx.le] at h
      field_simp [h₁ (x ^ 2) (pow_pos hx 2), h₁ 1 (by norm_num)] at h
      nlinarith
    by_contra! hn
    rcases hn with ⟨⟨a, ha, hna⟩, ⟨b, hb, hnb⟩⟩
    have hfa : f a = 1 / a := (h_val a ha).resolve_left hna
    have hfb : f b = b := (h_val b hb).resolve_right hnb
    have hab_pos : a * b > 0 := mul_pos ha hb
    specialize h a b (Real.sqrt (a * b)) (Real.sqrt (a * b)) ha hb (Real.sqrt_pos.mpr hab_pos) (Real.sqrt_pos.mpr hab_pos) (by simp [Real.mul_self_sqrt hab_pos.le])
    simp [hfa, hfb, Real.sq_sqrt hab_pos.le] at h
    rcases h_val (a * b) hab_pos with hab | hab
    · rw [hab] at h; field_simp [ha.ne', hb.ne', h₁ (a * b) hab_pos] at h; nlinarith
    · rw [hab] at h; field_simp [ha.ne', hb.ne', h₁ (a * b) hab_pos] at h; nlinarith
  · rintro (hf | hf) <;> intro w x y z hw hx hy hz heq
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
      field_simp [hw.ne', hx.ne', hy.ne', hz.ne']
      rw [heq]
      ring
