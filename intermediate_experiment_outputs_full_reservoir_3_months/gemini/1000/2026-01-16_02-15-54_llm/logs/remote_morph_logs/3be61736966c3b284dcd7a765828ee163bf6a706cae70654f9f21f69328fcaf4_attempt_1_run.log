import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    (∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x := by
  constructor
  · intro h
    have f_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := fun x hx ↦ by
      have := h x x x x hx hx hx hx rfl
      simp at this; exact this.symm
    have f_1 : f 1 = 1 := by
      have := f_sq 1 (by norm_num)
      simp at this
      exact (h₁ 1 (by norm_num)).symm.one_of_pow_eq (by norm_num) this
    have f_val : ∀ x > 0, f x = x ∨ f x = 1 / x := fun x hx ↦ by
      have h_sqrt := h x 1 (Real.sqrt x) (Real.sqrt x) hx (by norm_num) (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) (by simp [Real.mul_self_sqrt hx.le])
      simp [f_sq, f_1, Real.mul_self_sqrt hx.le] at h_sqrt
      have h_f : x * f x ^ 2 - (x ^ 2 + 1) * f x + x = 0 := by
        field_simp [h₁ x hx, hx.ne', h₁ 1 (by norm_num), h₁ (Real.sqrt x) (Real.sqrt_pos.mpr hx)] at h_sqrt
        ring_nf at h_sqrt ⊢; exact h_sqrt
      have h_mul : (x * f x - 1) * (f x - x) = 0 := by ring_nf; exact h_f
      rcases mul_eq_zero.mp h_mul with hf | hf
      · right; field_simp [hx.ne'] at hf; exact hf.symm
      · left; exact hf
    by_cases h_id : ∀ x > 0, f x = x
    · left; exact h_id
    · right
      push_neg at h_id; rcases h_id with ⟨a, ha_pos, ha_na⟩
      have ha_v : f a = 1 / a := (f_val a ha_pos).resolve_left ha_na
      have ha1 : a ≠ 1 := by rintro rfl; simp [f_1] at ha_na
      intro x hx
      by_cases hx1 : x = 1; · rw [hx1, f_1, one_div_one]
      rcases f_val x hx with hx_v | hx_v; swap; · exact hx_v
      have h_ax := h a x (Real.sqrt (a * x)) (Real.sqrt (a * x)) ha_pos hx (Real.sqrt_pos.mpr (mul_pos ha_pos hx)) (Real.sqrt_pos.mpr (mul_pos ha_pos hx)) (by simp [Real.mul_self_sqrt (mul_pos ha_pos hx).le])
      simp [f_sq, ha_v, hx_v, Real.mul_self_sqrt (mul_pos ha_pos hx).le] at h_ax
      rcases f_val (a * x) (mul_pos ha_pos hx) with fax | fax
      · rw [fax] at h_ax; field_simp [ha_pos, hx, ha1, hx1, h₁ (Real.sqrt (a * x))] at h_ax
        have : a^4 = 1 := by nlinarith; exact ha1 (by nlinarith)
      · rw [fax] at h_ax; field_simp [ha_pos, hx, ha1, hx1, h₁ (Real.sqrt (a * x))] at h_ax
        have : x^4 = 1 := by nlinarith; exact hx1 (by nlinarith)
  · intro h w x y z hw hx hy hz hwx
    rcases h with h | h
    · simp [h hw, h hx, h (pow_pos hy 2), h (pow_pos hz 2), hwx]
    · simp [h hw, h hx, h (pow_pos hy 2), h (pow_pos hz 2)]
      field_simp [hw.ne', hx.ne', hy.ne', hz.ne']
      rw [mul_comm (y^2), ← (mul_pow y z 2), ← (mul_pow w x 2), hwx, mul_comm (w^2)]

