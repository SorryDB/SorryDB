import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have hf2 : ∀ x > 0, f (x ^ 2) = f x ^ 2 := fun x hx ↦ by
      specialize h x x x x hx hx hx hx rfl; field_simp [h₁] at h; exact h.symm
    have hf1 : f 1 = 1 := by
      have hf11 := hf2 1 zero_lt_one; simp at hf11
      exact (sq_eq_self_iff.1 hf11.symm).resolve_left (h₁ 1 zero_lt_one).ne'
    have hfx : ∀ x > 0, f x = x ∨ f x = 1 / x := fun x hx ↦ by
      specialize h x 1 (Real.sqrt x) (Real.sqrt x) hx zero_lt_one (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) (by simp; exact Real.mul_self_sqrt hx.le)
      simp [hf2, hf1, Real.mul_self_sqrt hx.le] at h
      have : (f x - x) * (x * f x - 1) = 0 := by field_simp [h₁ x hx, hx.ne'] at h; nlinarith
      rcases mul_eq_zero.1 this with hf | hf
      · left; exact hf
      · right; field_simp [hx.ne'] at hf; exact hf
    by_contra! hn; rcases hn with ⟨⟨a, ha, hfa⟩, ⟨b, hb, hfb⟩⟩
    have hfa' : f a = 1 / a := (hfx a ha).resolve_left hfa
    have hfb' : f b = b := (hfx b hb).resolve_right hfb
    specialize h a b (Real.sqrt (a * b)) (Real.sqrt (a * b)) ha hb (Real.sqrt_pos.mpr (mul_pos ha hb)) (Real.sqrt_pos.mpr (mul_pos ha hb)) (by simp; exact Real.mul_self_sqrt (mul_pos ha hb).le)
    simp [hf2, hfa', hfb', Real.mul_self_sqrt (mul_pos ha hb).le] at h
    rcases hfx (a * b) (mul_pos ha hb) with hab | hab
    · rw [hab] at h; have : a = 1 := by field_simp [ha, hb, h₁] at h; nlinarith [ha]
      exact hfa (by rw [this, hf1])
    · rw [hab] at h; have : b = 1 := by field_simp [ha, hb, h₁] at h; nlinarith [hb]
      exact hfb (by rw [this, hf1])
  · rintro (rfl | rfl) w x y z hw hx hy hz he <;> field_simp [hw.ne', hx.ne', hy.ne', hz.ne', ← mul_pow, he] <;> ring
