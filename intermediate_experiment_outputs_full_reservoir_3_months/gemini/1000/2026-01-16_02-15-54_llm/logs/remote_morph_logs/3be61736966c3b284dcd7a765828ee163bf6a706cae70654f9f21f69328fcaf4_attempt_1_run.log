    have h1 : f 1 = 1 := by
      have := h_sq 1 (by norm_num)
      have := h₁ 1 (by norm_num)
      nlinarith
    have h_f_val : ∀ x > 0, f x = x ∨ f x = 1 / x := fun x hx => by
      specialize h x 1 (Real.sqrt x) (Real.sqrt x) hx (by norm_num) (Real.sqrt_pos.mpr hx) (Real.sqrt_pos.mpr hx) (by simp [hx.le])
      simp [h1, h_sq x hx, h_sq (Real.sqrt x) (Real.sqrt_pos.mpr hx), Real.mul_self_sqrt hx.le] at h
      field_simp [h₁ x hx] at h
      nlinarith
    have h_xy : ∀ x y > 0, f (x * y) * (x ^ 2 + y ^ 2) = x * y * (f x ^ 2 + f y ^ 2) := fun x y hx hy => by
