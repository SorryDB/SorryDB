import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    ((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := fun x hx => by
      specialize h x x x x hx hx hx hx rfl
      field_simp [h₁ _ hx, h₁ _ (pow_two_pos hx)] at h
      exact h.symm
    have h_f1 : f 1 = 1 := by
      have h1 := h_sq 1 zero_lt_one; simp at h1
      exact (h₁ 1 zero_lt_one).ne_zero.symm.red (mul_self_eq_self.mp h1.symm)
    have h_fuv : ∀ u v : ℝ, 0 < u → 0 < v → (f u + f v) / (u + v) = (f (u * v) + 1) / (u * v + 1) := by
      intro u v hu hv
      specialize h (sqrt u) (sqrt v) (sqrt (u * v)) 1 (sqrt_pos.mpr hu) (sqrt_pos.mpr hv) (sqrt_pos.mpr (mul_pos hu hv)) zero_lt_one (by simp [← sqrt_mul hu.le])
      rwa [h_sq _ (sqrt_pos.mpr hu), h_sq _ (sqrt_pos.mpr hv), h_sq _ (sqrt_pos.mpr (mul_pos hu hv)), h_sq _ zero_lt_one, h_f1, one_pow, sq_sqrt hu.le, sq_sqrt hv.le, sq_sqrt (mul_pos hu hv).le, one_pow] at h
    have h_fx : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      have h_sum : f x + f (1 / x) = x + 1 / x := by
        specialize h_fuv x (1 / x) hx (one_div_pos.mpr hx)
        simp [h_f1, mul_one_div_cancel hx.ne_zero] at h_fuv
        field_simp [hx.ne_zero, (h₁ (1/x) (one_div_pos.mpr hx)).ne_zero] at h_fuv ⊢; exact h_fuv
      have h_inv : f (1 / x) = 1 / f x := by
        specialize h_fuv (sqrt x) (1 / sqrt x) (sqrt_pos.mpr hx) (one_div_pos.mpr (sqrt_pos.mpr hx))
        simp [h_f1, mul_one_div_cancel (sqrt_pos.mpr hx).ne_zero] at h_fuv
        have h_sq_sum : f (sqrt x) ^ 2 + f (1 / sqrt x) ^ 2 = x + 1 / x := by
          rw [← h_sq, ← h_sq, sq_sqrt hx.le, sq_sqrt (one_div_pos.mpr hx).le]
          exacts [one_div_pos.mpr hx, hx]
        have h_sqrt_sum : f (sqrt x) + f (1 / sqrt x) = sqrt x + 1 / sqrt x := by
          field_simp [sqrt_pos.mpr hx, h₁] at h_fuv ⊢; exact h_fuv
        have := (pow_two (f (sqrt x) + f (1 / sqrt x))).symm.trans (congr_arg (λ x => x^2) h_sqrt_sum)
        rw [add_sq, h_sq_sum, add_sq, sq_sqrt hx.le, sq_sqrt (one_div_pos.mpr hx).le, mul_one_div_cancel (sqrt_pos.mpr hx).ne_zero] at this
        have : f (sqrt x) * f (1 / sqrt x) = 1 := by linarith
        rw [← h_sq _ hx, ← h_sq _ (one_div_pos.mpr hx), ← mul_pow, this, one_pow]
      field_simp [h_inv, (h₁ x hx).ne_zero, hx.ne_zero] at h_sum
      nlinarith
    by_contra' h_false
    rcases h_false with ⟨⟨a, ha, hfa_x⟩, ⟨b, hb, hfb_inv⟩⟩
    have hfa_inv : f a = 1 / a := (h_fx a ha).resolve_left hfa_x
    have hfb_x : f b = b := (h_fx b hb).resolve_right hfb_inv
    specialize h_fuv a b ha hb
    rcases h_fx (a * b) (mul_pos ha hb) with hab_x | hab_inv
    · rw [hfa_inv, hfb_x, hab_x] at h_fuv
      field_simp [ha.ne_zero, hb.ne_zero, (1 + a * b).ne_zero, (a + b).ne_zero] at h_fuv
      have : a = 1 := by nlinarith [ha]
      absurd hfa_x; rw [this, h_f1]
    · rw [hfa_inv, hfb_x, hab_inv] at h_fuv
      field_simp [ha.ne_zero, hb.ne_zero, (1 + a * b).ne_zero, (a + b).ne_zero, (a * b).ne_zero] at h_fuv
      have : b = 1 := by nlinarith [hb]
      absurd hfb_inv; rw [this, h_f1, one_div_one]
  · rintro (hf | hf) w x y z hw hx hy hz hwx
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]; field_simp [hw.ne_zero]
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
      field_simp [hw.ne_zero, hx.ne_zero, hy.ne_zero, hz.ne_zero]
      rw [← hwx]; field_simp; ring

