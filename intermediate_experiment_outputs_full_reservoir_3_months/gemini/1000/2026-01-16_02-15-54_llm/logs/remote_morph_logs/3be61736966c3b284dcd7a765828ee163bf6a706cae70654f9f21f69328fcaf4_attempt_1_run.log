import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have h1_1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by norm_num) (by norm_num) (by norm_num) (by norm_num) (by norm_num)
      simp [h₁ 1 (by norm_num)] at h
      exact h
    have h_g : ∀ w x, 0 < w → 0 < x → (f w ^ 2 + f x ^ 2) / (2 * f (w * x)) = (w ^ 2 + x ^ 2) / (2 * w * x) := by
      intro w x hw hx
      let yz := Real.sqrt (w * x)
      have hyz : 0 < yz := Real.sqrt_pos.mpr (mul_pos hw hx)
      specialize h w x yz yz hw hx hyz hyz (by simp [yz, Real.mul_self_sqrt (mul_pos hw hx).le])
      simp [yz, Real.mul_self_sqrt (mul_pos hw hx).le] at h
      field_simp [h₁ (w * x) (mul_pos hw hx)] at h ⊢; linear_combination h
    have h_f_val : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h_g 1 x (by norm_num) hx
      rw [h1_1] at h_g
      have h_eq : x * f x ^ 2 - (x ^ 2 + 1) * f x + x = 0 := by
        field_simp [h₁ x hx, hx.ne.symm] at h_g; linear_combination h_g / 2
      have : (x * f x - 1) * (f x - x) = x * f x ^ 2 - (x ^ 2 + 1) * f x + x := by ring
      rw [← this, mul_eq_zero] at h_eq
      cases h_eq with
      | inl hv => right; intro; field_simp [hx.ne.symm]; linear_combination hv
      | inr hv => left; exact hv
    by_contra h_neg
    push_neg at h_neg; rcases h_neg with ⟨⟨a, ha, hfa⟩, ⟨b, hb, hfb⟩⟩
    have hf_a : f a = 1 / a := (h_f_val a ha).resolve_left hfa
    have hf_b : f b = b := (h_f_val b hb).resolve_right hfb
    specialize h_g a b ha hb
    rw [hf_a, hf_b] at h_g
    cases h_f_val (a * b) (mul_pos ha hb) with
    | inl h_ab =>
      rw [h_ab] at h_g; field_simp [ha.ne.symm, hb.ne.symm, (a^2+b^2).ne.symm] at h_g
      have : b^4 = 1 := by nlinarith [h_g]; exact hfb (by nlinarith [hb, this, h1_1])
    | inr h_ab =>
      rw [h_ab] at h_g; field_simp [ha.ne.symm, hb.ne.symm, (a^2+b^2).ne.symm] at h_g
      have : a^4 = 1 := by nlinarith [h_g]; exact hfa (by nlinarith [ha, this, h1_1])
  · intro h w x y z hw hx hy hz hwz
    rcases h with h | h
    · simp [h, hw, hx, hy, hz, hwz]
    · simp [h, hw, hx, hy, hz, hwz]; field_simp [hw.ne.symm, hx.ne.symm, hy.ne.symm, hz.ne.symm]; rw [hwz]; ring
