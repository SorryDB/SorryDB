      have : a = 1 := by nlinarith [ha]
      exact fa_ne_a (by rw [this, f1])
    · rw [hab_eq_inv_ab] at h_xy
      field_simp [ha, hb] at h_xy
      have : b = 1 := by nlinarith [hb]
      exact fb_ne_inv_b (by rw [this, f1])
  · intro h w x y z hw hx hy hz hwx
    rcases h with h | h
    · repeat rw [h _ hw, h _ hx, h _ (pow_pos hy 2), h _ (pow_pos hz 2)]; rw [hwx]
