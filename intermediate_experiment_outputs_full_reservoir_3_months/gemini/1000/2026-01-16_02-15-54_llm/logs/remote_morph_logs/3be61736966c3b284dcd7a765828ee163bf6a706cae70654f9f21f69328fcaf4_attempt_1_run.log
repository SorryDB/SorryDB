    | inr hfab => rw [hfab] at f_mix; field_simp [ha, hb, f1, mul_pos ha hb] at f_mix; nlinarith
  · rintro (h | h) w x y z hw hx hy hz hmul <;> simp [h, hw, hx, hy, hz, pow_pos, hmul]
