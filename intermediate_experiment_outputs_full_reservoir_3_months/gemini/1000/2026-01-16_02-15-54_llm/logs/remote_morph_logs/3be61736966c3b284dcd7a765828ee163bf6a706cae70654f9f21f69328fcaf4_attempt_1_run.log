      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    answer((∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x) := by
  constructor
  · intro h
    have f1 : f 1 = 1 := by
      have := h 1 1 1 1 (by norm_num) (by norm_num) (by norm_num) (by norm_num) rfl
      field_simp [h₁] at this; exact this
    have h_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := fun x hx => by
      have := h x x x x hx hx hx hx rfl
      field_simp [h₁] at this; exact this.symm
    have h_val : ∀ x > 0, f x = x ∨ f x = 1 / x := fun x hx => by
      have h1 := h x 1 (Real.sqrt x) (Real.sqrt x) hx (by norm_num) (Real.sqrt_pos.2 hx) (Real.sqrt_pos.2 hx) (by simp [Real.sqrt_mul_self hx.le])
      rw [f1, h_sq, h_sq, Real.sq_sqrt hx.le] at h1
      field_simp [h₁, hx] at h1
      have : (f x - x) * (f x * x - 1) = 0 := by ring_nf; rw [h1]; ring
      rcases eq_zero_or_eq_zero_of_mul_eq_zero this with h2 | h2
      · left; exact h2
      · right; field_simp [hx]; rw [← h2]; ring
    by_contra h_neg
    rcases not_or_distrib.mp h_neg with ⟨h_not_id, h_not_inv⟩
    push_neg at h_not_id h_not_inv
    rcases h_not_id with ⟨a, ha, fa_ne_a⟩
    rcases h_not_inv with ⟨b, hb, fb_ne_inv_b⟩
    have fa : f a = 1 / a := (h_val a ha).resolve_left fa_ne_a
    have fb : f b = b := (h_val b hb).resolve_right fb_ne_inv_b
    have a_ne_1 : a ≠ 1 := fun h => by simp [h, f1] at fa_ne_a
    have b_ne_1 : b ≠ 1 := fun h => by simp [h, f1] at fb_ne_inv_b
    let ab := a * b
    have hab : 0 < ab := mul_pos ha hb
    have h_ab := h a b (Real.sqrt ab) (Real.sqrt ab) ha hb (Real.sqrt_pos.2 hab) (Real.sqrt_pos.2 hab) (by simp [Real.sqrt_mul_self hab.le])
    rw [h_sq, h_sq, Real.sq_sqrt hab.le, fa, fb] at h_ab
    rcases h_val ab hab with fab | fab
    · rw [fab] at h_ab; field_simp [ha, hb, hab, h₁] at h_ab
      have : a = 1 := by nlinarith
      exact a_ne_1 this
    · rw [fab] at h_ab; field_simp [ha, hb, hab, h₁] at h_ab
      have : b = 1 := by nlinarith
      exact b_ne_1 this
  · rintro (hf | hf) w x y z hw hx hy hz heq
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2), heq]
    · rw [hf w hw, hf x hx, hf (y ^ 2) (pow_pos hy 2), hf (z ^ 2) (pow_pos hz 2)]
      field_simp [hw, hx, hy, hz]
      rw [← heq]
      ring
