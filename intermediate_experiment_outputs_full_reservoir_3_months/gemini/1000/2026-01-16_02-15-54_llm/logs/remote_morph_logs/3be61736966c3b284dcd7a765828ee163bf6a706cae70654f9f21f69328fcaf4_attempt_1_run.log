      have hsqyz : 0 < Real.sqrt (y * z) := Real.sqrt_pos.mpr hyz
      specialize h hsqyz hsqyz hy hz (by simp [Real.mul_self_sqrt hyz.le])
      rw [f_sq _ hsqyz, Real.mul_self_sqrt hyz.le, f_sq _ hy, f_sq _ hz] at h
      field_simp [h₁, hyz, hy, hz] at h
      nlinarith
    have h_xor : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h_xy x hx 1 zero_lt_one
      rw [f1] at h_xy
      have : (x * f x - 1) * (f x - x) = 0 := by nlinarith
      rcases eq_zero_or_eq_zero_of_mul_eq_zero this with h2 | h2
      · right; field_simp [hx]; nlinarith
      · left; exact h2
    by_contra h_neg
    push_neg at h_neg
    rcases h_neg with ⟨⟨a, ha, fa_ne_a⟩, ⟨b, hb, fb_ne_inv_b⟩⟩
    have fa_eq_inv_a : f a = 1 / a := (h_xor a ha).resolve_left fa_ne_a
    have fb_eq_b : f b = b := (h_xor b hb).resolve_right fb_ne_inv_b
    specialize h_xy a ha b hb
    rw [fa_eq_inv_a, fb_eq_b] at h_xy
    rcases h_xor (a * b) (mul_pos ha hb) with hab_eq_ab | hab_eq_inv_ab
    · rw [hab_eq_ab] at h_xy
