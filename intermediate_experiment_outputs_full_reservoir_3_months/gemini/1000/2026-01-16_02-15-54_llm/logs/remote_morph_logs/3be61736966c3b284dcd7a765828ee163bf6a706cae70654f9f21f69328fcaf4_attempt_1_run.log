@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    (∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x := by
  constructor
  · intro h
    have f1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by linarith) (by linarith) (by linarith) (by linarith) (by rfl)
      simp [h₁] at h; exact h
    have f_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by
      intro x hx
      specialize h 1 x 1 x (by linarith) hx (by linarith) hx (by simp)
      simp [f1] at h; field_simp at h; linear_combination h
    have f_val : ∀ x > 0, f x = x ∨ f x = 1 / x := by
      intro x hx
      specialize h 1 1 (sqrt x) (1 / sqrt x) (by linarith) (by linarith) (sqrt_pos.mpr hx) (one_div_pos.mpr (sqrt_pos.mpr hx)) (by field_simp)
      simp [f1, f_sq, hx, one_div_pos.mpr (sqrt_pos.mpr hx)] at h
      have h_sum : f x + f (1 / x) = x + 1 / x := by field_simp [hx] at h; exact h.symm
      specialize h (sqrt 1) (sqrt 1) x (1 / x) (by linarith) (by linarith) hx (one_div_pos.mpr hx) (by field_simp)
      simp [f1, f_sq, hx, one_div_pos.mpr hx] at h
      have h_sq_sum : f x ^ 2 + f (1 / x) ^ 2 = x ^ 2 + (1 / x) ^ 2 := by field_simp [hx] at h; exact h.symm
      have h_prod : f x * f (1 / x) = 1 := by linear_combination ((h_sum ^ 2 - h_sq_sum) / 2)
      have : (f x - x) * (f x - 1 / x) = 0 := by linear_combination f x * h_sum - h_prod - f x ^ 2
      exact eq_zero_or_eq_zero_of_mul_eq_zero this
    have f_mix : ∀ w x, 0 < w → 0 < x → (f w + f x) / (1 + f (w * x)) = (w + x) / (1 + w * x) := by
      intro w x hw hx
      specialize h (sqrt w) (sqrt x) 1 (sqrt (w * x)) (sqrt_pos.mpr hw) (sqrt_pos.mpr hx) (by linarith) (sqrt_pos.mpr (mul_pos hw hx)) (by simp [← sqrt_mul (le_of_lt hw)])
      rw [f1, ← f_sq _ (sqrt_pos.mpr hw), ← f_sq _ (sqrt_pos.mpr hx)] at h
      rw [sq_sqrt (le_of_lt hw), sq_sqrt (le_of_lt hx), sq_sqrt (le_of_lt (mul_pos hw hx))] at h
      exact h
