import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    (∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x := by
  constructor
  · intro h
    have h1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by positivity) (by positivity) (by positivity) (by positivity) rfl
      simp [h₁ 1 (by positivity)] at h; exact h
    have h_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := fun x hx => by
      specialize h x x x x hx hx hx hx rfl
      simp at h; exact h.symm
    have h_quad : ∀ x > 0, f x = x ∨ f x = 1 / x := fun x hx => by
      have h_sum : f x + f (1 / x) = x + 1 / x := by
        specialize h (Real.sqrt x) (1 / Real.sqrt x) 1 1 (by positivity) (by positivity) (by positivity) (by positivity) (by simp [hx.le])
        simp [h1, h_sq, hx] at h; repeat rw [Real.sq_sqrt (by positivity)] at h; exact h.symm
      have h_sq_sum : f x ^ 2 + f (1 / x) ^ 2 = x ^ 2 + (1 / x) ^ 2 := by
        specialize h x (1 / x) 1 1 hx (by positivity) (by positivity) (by positivity) (by simp)
        simp [h1, h_sq, hx] at h; field_simp [h1] at h; exact h
      have h_prod : f x * f (1 / x) = 1 := by nlinarith [h_sum, h_sq_sum]
      have : (f x - x) * (f x - 1 / x) = 0 := by field_simp [h₁ x hx]; nlinarith [h_sum, h_prod]
      exact eq_zero_or_eq_zero_of_mul_eq_zero this
    have h_g : ∀ w x, 0 < w → 0 < x → (f w + f x) / (1 + f (w * x)) = (w + x) / (1 + w * x) := fun w x hw hx => by
      specialize h (Real.sqrt w) (Real.sqrt x) 1 (Real.sqrt (w * x)) (by positivity) (by positivity) (by positivity) (by positivity) (by simp [Real.sqrt_mul, hw.le, hx.le])
      simp [h1, h_sq, hw, hx] at h; repeat rw [Real.sq_sqrt (by positivity)] at h; exact h
    by_contra' h_not; rcases h_not with ⟨⟨a, ha, h_fa_a⟩, ⟨b, hb, h_fb_b⟩⟩
    have h_fa : f a = 1 / a := (h_quad a ha).resolve_left h_fa_a
    have h_fb : f b = b := (h_quad b hb).resolve_right h_fb_b
    specialize h_g a b ha hb; rw [h_fa, h_fb] at h_g
    rcases h_quad (a * b) (by positivity) with hab | hab
    · rw [hab] at h_g; field_simp [ha.ne', (1 + a * b).ne'] at h_g; have : a = 1 := by nlinarith
      rw [this] at h_fa_a; simp [h1] at h_fa_a
    · rw [hab] at h_g; field_simp [ha.ne', hb.ne', (a * b).ne', (1 + a * b).ne'] at h_g; have : b = 1 := by nlinarith
      rw [this] at h_fb_b; simp [h1] at h_fb_b
  · rintro (h | h) w x y z hw hx hy hz heq
    · simp [h, hw, hx, hy, hz, heq]
    · simp [h, hw, hx, hy, hz]; field_simp [hw.ne', hx.ne', hy.ne', hz.ne']
      rw [← mul_pow, ← mul_pow, heq]
