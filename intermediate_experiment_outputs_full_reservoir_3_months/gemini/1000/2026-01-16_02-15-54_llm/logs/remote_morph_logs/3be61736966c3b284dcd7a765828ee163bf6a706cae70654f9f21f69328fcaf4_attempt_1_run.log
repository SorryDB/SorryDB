import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Find all functions $ f: (0, \infty) \mapsto (0, \infty)$ (so $ f$ is a function from the positive real numbers) such that
\[ \frac {\left( f(w) \right)^2 + \left( f(x) \right)^2}{f(y^2) + f(z^2) } = \frac {w^2 + x^2}{y^2 + z^2}
\]
for all positive real numbers $ w,x,y,z,$ satisfying $ wx = yz.$


[i]Author: Hojoo Lee, South Korea[/i]

Solution: $f(x) = x$, $f(x) = \frac{1}{x}$.
-/
@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    (∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x := by
  constructor
  · intro h
    have h1 : f 1 = 1 := by
      specialize h 1 1 1 1 (by linarith) (by linarith) (by linarith) (by linarith) rfl
      field_simp [h₁ 1 (by linarith)] at h; exact h
    have hq {x} (hx : 0 < x) : f x = x ∨ f x = 1 / x := by
      specialize h x 1 (Real.sqrt x) (Real.sqrt x) hx (by linarith) (Real.sqrt_pos.2 hx) (Real.sqrt_pos.2 hx) (by simp [Real.mul_self_sqrt hx.le])
      field_simp [h1, Real.mul_self_sqrt hx.le, h₁] at h
      have : (f x - x) * (f x * x - 1) = 0 := by nlinarith
      cases eq_zero_or_eq_zero_of_mul_eq_zero this with
      | inl hf => left; exact hf
      | inr hf => right; field_simp [hx.ne.symm]; nlinarith
    by_contra! hf
    obtain ⟨⟨a, ha, hfa⟩, ⟨b, hb, hfb⟩⟩ := hf
    have hfa' : f a = 1 / a := (hq ha).resolve_left hfa
    have hfb' : f b = b := (hq hb).resolve_right hfb
    specialize h a b (Real.sqrt (a * b)) (Real.sqrt (a * b)) ha hb (Real.sqrt_pos.2 (by nlinarith)) (Real.sqrt_pos.2 (by nlinarith)) (by simp [Real.mul_self_sqrt (by nlinarith : 0 ≤ a * b)])
    field_simp [hfa', hfb', h₁] at h
    cases hq (by nlinarith : 0 < a * b) with
    | inl hab => field_simp [hab] at h; nlinarith [h1, Real.pow_four_eq_one_iff.1 (by nlinarith : a^4=1)]
    | inr hab => field_simp [hab] at h; nlinarith [h1, Real.pow_four_eq_one_iff.1 (by nlinarith : b^4=1)]
  · rintro (h | h) w x y z hw hx hy hz heq
    · simp [h, hw, hx, hy, hz, heq]
    · simp [h, hw, hx, hy, hz, heq]
      field_simp [hw.ne', hx.ne', hy.ne', hz.ne']
      rw [← mul_pow, heq, mul_pow]; ring

