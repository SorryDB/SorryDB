@[imo_problem_subject algebra]
theorem imo_2008_p4 (f : ℝ → ℝ) (h₁ : ∀ x > 0, f x > 0) :
    (∀ w x y z : ℝ, 0 < w → 0 < x → 0 < y → 0 < z → w * x = y * z →
      (f w ^ 2 + f x ^ 2) / (f (y ^ 2) + f (z ^ 2)) = (w ^ 2 + x ^ 2) / (y ^ 2 + z ^ 2)) ↔
    (∀ x > 0, f x = x) ∨ ∀ x > 0, f x = 1 / x := by
  constructor
  · intro h
    have f1 : f 1 = 1 := by
      specialize h 1 1 1 1 zero_lt_one zero_lt_one zero_lt_one zero_lt_one rfl
      field_simp [h₁] at h
      exact h
    have f_sq : ∀ x > 0, f (x ^ 2) = f x ^ 2 := by
      intro x hx
      specialize h x 1 1 x hx zero_lt_one zero_lt_one hx (by ring)
      rw [f1] at h
      field_simp [h₁] at h
      nlinarith
    have h_xy : ∀ y > 0, ∀ z > 0, f (y * z) * (y ^ 2 + z ^ 2) = (y * z) * (f y ^ 2 + f z ^ 2) := by
      intro y hy z hz
