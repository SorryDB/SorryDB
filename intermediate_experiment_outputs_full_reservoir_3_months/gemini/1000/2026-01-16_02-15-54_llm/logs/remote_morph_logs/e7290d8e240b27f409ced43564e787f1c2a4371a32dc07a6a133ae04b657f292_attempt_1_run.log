open BigOperators Real Nat Topology Rat

theorem imo_1964_p2
  (a b c : ℝ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
  (h₁ : c < a + b)
  (h₂ : b < a + c)
  (h₃ : a < b + c) :
  a^2 * (b + c - a) + b^2 * (c + a - b) + c^2 * (a + b - c) ≤ 3 * a * b * c := by
  have : 2 * (3 * a * b * c - (a^2 * (b + c - a) + b^2 * (c + a - b) + c^2 * (a + b - c))) =
    (a + b - c) * (a - b)^2 + (b + c - a) * (b - c)^2 + (c + a - b) * (c - a)^2 := by ring
  nlinarith
