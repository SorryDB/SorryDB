import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1964_p2
  (a b c : ℝ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c)
  (h₁ : c < a + b)
  (h₂ : b < a + c)
  (h₃ : a < b + c) :
  a^2 * (b + c - a) + b^2 * (c + a - b) + c^2 * (a + b - c) ≤ 3 * a * b * c := by
  let x := (b + c - a) / 2
  let y := (a + c - b) / 2
  let z := (a + b - c) / 2
  have hx : 0 ≤ x := by linarith
  have hy : 0 ≤ y := by linarith
  have hz : 0 ≤ z := by linarith
  have ha : a = y + z := by linarith
  have hb : b = x + z := by linarith
  have hc : c = x + y := by linarith
  nlinarith [pow_two_nonneg (x - y), pow_two_nonneg (y - z), pow_two_nonneg (z - x)]

