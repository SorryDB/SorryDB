    have h0 := (stF.toKnowledgeStateFunction init impl oneShotE).toFun_empty stmtIn (cast oneShotE.toRoundByRound.eqIn.symm wit) |>.mpr h_wit
    sorry -- This follows by induction on rounds using KnowledgeStateFunction.toFun_next
  simp_all [h_not_lang, relIn.not_mem_language, stF.toFun_empty]
