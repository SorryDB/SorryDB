  simp at h ⊢
  clear h
  refine le_trans ?_ this
  simp
  refine probEvent_mono ?_
  intro ⟨tr, chal, ql⟩ ⟨witMid, h_not_k, h_k⟩
  simp [Extractor.RoundByRoundOneShot.toRoundByRound, Verifier.KnowledgeStateFunctionOneShot.toKnowledgeStateFunction] at h_not_k h_k ⊢
  have h_not_lang : stmtIn ∉ relIn.language := by
