    simp only [Expression.eval_var, h_map, Vector.get_map, Expression.eval_neg, Expression.eval_mul, Expression.eval_add, Expression.eval_const, Expression.eval_sub, Vector.ofFn_get]
    have hp : p > 2^135 := by linarith [‹Fact (p > 2^253)›.elim]
    have h_val_parts : ∀ i : Fin 127, (Expression.eval env (Vector.ofFn (fun i => if (c >>> (↑i * 2 + 1) &&& 1 == 0 && c >>> (↑i * 2) &&& 1 == 0) = true then -Expression.const ↑(2 ^ 128 - 2 ^ ↑i) * input_var[↑i * 2 + 1] * input_var[↑i * 2] + Expression.const ↑(2 ^ 128 - 2 ^ ↑i) * input_var[↑i * 2 + 1] + Expression.const ↑(2 ^ 128 - 2 ^ ↑i) * input_var[↑i * 2] else if (c >>> (↑i * 2 + 1) &&& 1 == 0 && c >>> (↑i * 2) &&& 1 == 1) = true then Expression.const ↑(2 ^ ↑i) * input_var[↑i * 2 + 1] * input_var[↑i * 2] - Expression.const ↑(2 ^ ↑i) * input_var[↑i * 2] + Expression.const ↑(2 ^ 128 - 2 ^ ↑i) * input_var[↑i * 2 + 1] - Expression.const ↑(2 ^ ↑i) * input_var[↑i * 2 + 1] + Expression.const ↑(2 ^ ↑i) else if (c >>> (↑i * 2 + 1) &&& 1 == 1 && c >>> (↑i * 2) &&& 1 == 0) = true then Expression.const ↑(2 ^ 128 - 2 ^ ↑i) * input_var[↑i * 2 + 1] * input_var[↑i * 2] - Expression.const ↑(2 ^ ↑i) * input_var[↑i * 2 + 1] + Expression.const ↑(2 ^ ↑i) else -Expression.const ↑(2 ^ ↑i) * input_var[↑i * 2 + 1] * input_var[↑i * 2] + Expression.const ↑(2 ^ ↑i)) i)).val < p := sorry
