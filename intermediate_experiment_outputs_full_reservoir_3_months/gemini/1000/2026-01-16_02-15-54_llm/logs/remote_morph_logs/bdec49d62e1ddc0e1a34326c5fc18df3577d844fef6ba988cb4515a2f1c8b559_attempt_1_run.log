      have := Real.geom_mean_le_arith_mean2 (x/y) (y/x) (by positivity) (by positivity)
      have : (x/y : ℝ) = 1 := by nlinarith [sq_le_one_iff_abs_le_one.mp (by nlinarith : (x/y * (y/x) : ℝ) ≤ 1)]
