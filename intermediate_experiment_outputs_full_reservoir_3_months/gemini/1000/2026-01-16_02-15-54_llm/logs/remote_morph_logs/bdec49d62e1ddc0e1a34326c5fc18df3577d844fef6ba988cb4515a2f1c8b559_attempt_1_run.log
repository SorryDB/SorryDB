          ⟨⟨2 * x + 1, by linarith [x.2]⟩, by nlinarith [x.2]⟩
        linarith [hpos y, h_f y]
      have h2 x : (x : ℝ) * f x ≤ 1 := by
        have hg_inv x : g (g x) = x := (hg2 (g x) x).1 (by rw [add_comm]; exact hg1 x)
        have := h1 x; have := h1 (g x); nlinarith [hg1 x]
      exact le_antisymm (h2 x) (h1 x)
    field_simp [h_xfx x, (ne_of_gt x.2)]
  · rintro rfl
    simp only [Set.mem_setOf_eq, one_div, inv_pos, Subtype.forall, Subtype.coe_mk, implies_true, true_and]
