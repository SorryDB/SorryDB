        _ < 2 := by nlinarith [Real.sqrt_lt_one.mpr hx]
      · simp [a, y]; field_simp; ring
    field_simp [y] at hy; nlinarith
  · intro h; subst h; intro x; use x; simp [two_mul, ← mul_inv_cancel_left₀ (by positivity : (2 : ℝ) ≠ 0) (x * (x : ℝ)⁻¹)]; constructor
    · linarith
