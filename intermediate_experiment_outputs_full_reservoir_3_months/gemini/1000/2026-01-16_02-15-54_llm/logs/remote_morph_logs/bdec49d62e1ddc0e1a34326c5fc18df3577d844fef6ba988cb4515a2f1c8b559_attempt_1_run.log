    have hg1 x : (x : ℝ) * f (g x) + (g x : ℝ) * f x ≤ 2 := (h x).exists.choose_spec.1
    have hg2 x y : (x : ℝ) * f y + (y : ℝ) * f x ≤ 2 ↔ y = g x := ⟨(h x).unique, fun h' => h' ▸ hg1 x⟩
    have h_xfx x : (x : ℝ) * f x = 1 := by
      have h1 x : (x : ℝ) * f x ≥ 1 := by
        by_contra! hlt
        have h_gx : g x = x := (hg2 x x).1 (by nlinarith)
        have h_f y : (x : ℝ) * f y + (y : ℝ) * f x ≥ 2 * (x : ℝ) * f x := by
          by_cases hy : y = x
