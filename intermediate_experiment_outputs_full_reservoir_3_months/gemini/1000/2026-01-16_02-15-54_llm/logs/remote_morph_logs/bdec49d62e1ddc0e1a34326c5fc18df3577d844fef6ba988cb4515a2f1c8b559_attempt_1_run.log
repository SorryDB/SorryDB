import Mathlib

namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  simp only [answer, Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · intro ⟨hpos, huni⟩
    have hxfx : ∀ x, x * f x ≤ 1 := fun x => by
      rcases huni x with ⟨y, h1, -⟩
      by_contra h; push_neg at h
      have : x * f y + y * f x ≥ 2 * Real.sqrt (x * f x * (y * f y)) :=
        two_sqrt_mul_le_add (by positivity) (by positivity)
      linarith [two_le_div_add_div_of_pos x.2 y.2]
    have hxfx1 : ∀ x, x * f x = 1 := fun x => by
      specialize hxfx x
      rcases huni x with ⟨y, h1, h2⟩
      have : x = y := by
        by_contra hne
        specialize h2 x hne
        linarith [hxfx]
      rw [this] at h1
      linarith
    ext x
    exact (eq_one_div_of_mul_eq_one_right (hxfx1 x)).symm
  · intro hf
    subst hf
    refine ⟨λ x => one_div_pos.mpr x.2, λ x => ?_⟩
    use x
    simp only [one_div, mul_inv_cancel x.2.ne.symm, add_refl, le_refl, true_and]
    intro y hy
    have := two_le_div_add_div_of_pos x.2 y.2
    have : (x : ℝ) / y + (y : ℝ) / x = (x : ℝ) * (1 / y) + (y : ℝ) * (1 / x) := by
      simp only [mul_one_div]
    linarith
