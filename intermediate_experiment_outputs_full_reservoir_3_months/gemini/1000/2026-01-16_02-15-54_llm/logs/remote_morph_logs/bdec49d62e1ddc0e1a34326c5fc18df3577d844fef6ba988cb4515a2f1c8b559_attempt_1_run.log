import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  simp only [answer, Set.mem_singleton_iff, Set.mem_setOf_eq]
  constructor
  · intro ⟨hf0, hf1⟩
    let g x := (hf1 x).exists.choose
    have hg x : (x : ℝ) * f (g x) + (g x : ℝ) * f x ≤ 2 := (hf1 x).exists.choose_spec
    have g_inv x : g (g x) = x := (hf1 (g x)).unique (by rw [add_comm]; exact hg x) (hg (g x))
    have h_fx x : f x = 1 / x := by
      have h_fge x : 1 / (x : ℝ) ≤ f x := by
        by_contra! h
        have hx : (x : ℝ) * f x + (x : ℝ) * f x < 2 := by nlinarith [hf0 x]
        have : g x = x := (hf1 x).unique (hg x) hx
        nlinarith [g_inv x]
      have h_gx x : g x = x := by
        by_contra! hne
        have h_amgm : 2 < (x : ℝ) / (g x : ℝ) + (g x : ℝ) / (x : ℝ) := by
          have hx : (x : ℝ) > 0 := x.2; have hgx : (g x : ℝ) > 0 := (g x).2
          nlinarith [sq_pos_iff.mpr (sub_ne_zero.mpr (Subtype.coe_ne_coe.mpr hne))]
        have : (x : ℝ) / (g x : ℝ) + (g x : ℝ) / (x : ℝ) ≤ (x : ℝ) * f (g x) + (g x : ℝ) * f x := by
          have hx : (x : ℝ) > 0 := x.2; have hgx : (g x : ℝ) > 0 := (g x).2
          have fx := h_fge x; have fgx := h_fge (g x)
          nlinarith
        nlinarith [hg x]
      have h_fle x : f x ≤ 1 / (x : ℝ) := by
        have h1 := hg x; rw [h_gx x] at h1; nlinarith [x.2]
      exact le_antisymm (h_fle x) (h_fge x)
    ext x; exact h_fx x
  · intro hf; rw [hf]; simp only [one_div, Subtype.coe_pos, inv_pos, true_and]
    intro x; use x; simp only [mul_inv_cancel (Subtype.coe_ne_zero x), add_self, le_refl, true_and]
    intro y hy; rw [← Subtype.coe_inj]
    have : 2 ≤ (x : ℝ) / (y : ℝ) + (y : ℝ) / (x : ℝ) := by
      have hx : (x : ℝ) > 0 := x.2; have hy : (y : ℝ) > 0 := y.2
      nlinarith [sq_nonneg (x - y)]
    nlinarith
