    let y : ℝ+ := ⟨x / r, by positivity⟩
    have : (x : ℝ) * f y + y * f x ≤ 2 := by
      have hfy : f y ≤ 1 / y := (le_div_iff y.2).mpr (h_le y)
      calc (x : ℝ) * f y + y * f x ≤ x / y + y * f x := by gcongr
        _ = r + (1 / r) * (1 - ε) := by field_simp [y, r]
        _ = r + (1 + Real.sqrt ε) := by
