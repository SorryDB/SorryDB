      have : a x * a y ≤ 1 := by
        have := Real.geom_mean_le_arith_mean2 (x * f y) (y * f x) (by positivity) (by positivity)
        rw [h] at this; have := sq_le_one_iff_abs_le_one.mp (by nlinarith) |>.2
        rwa [mul_assoc, ← mul_assoc (f y), mul_comm (f y), mul_assoc, ← mul_assoc (y * f x), a, a] at this
      have : g y = y := (H1 y y).mp (by dsimp [a] at *; nlinarith)
      have : y = x := by
        have H2 x : g (g x) = x := by
          have := (Classical.choose_spec (hu x).exists).1; rw [add_comm] at this; exact (H1 _ _).mp this
        rw [← H2 x, this]
      nlinarith
    have H4 x : g x = x := (H1 x x).mp (by dsimp [a]; nlinarith [H3 x])
    by_contra' hx; let y : ℝ+ := ⟨x * (Real.sqrt (a x))⁻¹, by positivity⟩
    have hy : y = x := by
