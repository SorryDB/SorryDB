import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  simp only [answer, Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · rintro ⟨hpos, hunique⟩
    have hg (x : ℝ+) : (x : ℝ) * f x ≤ 1 := by
      obtain ⟨y, hy, -⟩ := hunique x
      have := two_sqrt_le_add (by positivity) (by positivity)
      nlinarith
    have h_sol (x : ℝ+) : (x : ℝ) * f x + (x : ℝ) * f x ≤ 2 := by nlinarith [hg x]
    have h_eq (x : ℝ+) : (hunique x).choose = x := (hunique x).unique (hunique x).choose_spec.1 (h_sol x)
    funext x
    have hf (x : ℝ+) : (x : ℝ) * f x = 1 := by
      by_contra h_lt
      have : (x : ℝ) * f x < 1 := by nlinarith [hg x]
      obtain ⟨y, hy, hyx⟩ := hunique x
      rw [h_eq x] at hy
      have : (x : ℝ) * f x + (x : ℝ) * f x < 2 := by nlinarith
      sorry -- Final proof that x * f x = 1 is non-trivial but f x = 1/x is the only solution.
    field_simp [hf x]
  · rintro rfl
    simp only [one_div, mul_inv_cancel (pos_iff_ne_zero.1 _), add_refl, le_refl, true_and]
    intro x
    refine ⟨x, by simp, fun y hy => ?_⟩
    have hxy := two_sqrt_le_add (show 0 < (x : ℝ) / y by positivity) (show 0 < (y : ℝ) / x by positivity)
    have : (x : ℝ) / y + y / x ≤ 2 := hy
    have : (x : ℝ) / y + y / x = 2 := by nlinarith
    have hsqrt : Real.sqrt ((x : ℝ) / y * (y : ℝ) / x) = 1 := by
      field_simp; rw [Real.sqrt_one]
    nlinarith [hxy]
