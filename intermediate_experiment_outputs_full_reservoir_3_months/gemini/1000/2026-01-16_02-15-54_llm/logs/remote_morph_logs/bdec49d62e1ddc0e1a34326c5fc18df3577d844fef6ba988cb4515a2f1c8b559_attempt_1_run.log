import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f; simp [answer]; constructor
  · intro ⟨hpos, h⟩
    have hg x : (x : ℝ) * f x ≤ 1 := by
      obtain ⟨y, hy, hyu⟩ := h x
      by_contra! hx
      have hgy : (y : ℝ) * f y < 1 := by
        have := Real.geom_mean_le_arith_mean2 (by positivity) (by positivity) hy
        nlinarith
      have : y = x := (hyu y hy).trans (hyu x (by nlinarith [hx])).symm
      nlinarith
    ext x; apply le_antisymm (hg x)
    by_contra! hx; let c := (x : ℝ) * f x; have hcpos : 0 < c := by positivity
    let y : ℝ+ := ⟨x / Real.sqrt c, by positivity⟩
    have hy : (x : ℝ) * f y + (y : ℝ) * f x < 2 := by
      calc (x : ℝ) * f y + (y : ℝ) * f x ≤ (x : ℝ) / y + (y : ℝ) * c / x := by nlinarith [hg y]
        _ = 2 * Real.sqrt c := by field_simp [y, x.2, Real.sqrt_ne_zero.mpr (by positivity)]; ring
        _ < 2 := by nlinarith [Real.sqrt_lt_one.2 ⟨hcpos, hx⟩]
    obtain ⟨_, _, hyu⟩ := h x
    have : y = x := (hyu y (by nlinarith)).trans (hyu x (by nlinarith [hg x])).symm
    nlinarith [Subtype.ext_iff.1 this, Real.sqrt_eq_one.2 (by nlinarith)]
  · rintro rfl x; use x; simp; intro y hy; rw [Subtype.ext_iff]; field_simp at hy; nlinarith
