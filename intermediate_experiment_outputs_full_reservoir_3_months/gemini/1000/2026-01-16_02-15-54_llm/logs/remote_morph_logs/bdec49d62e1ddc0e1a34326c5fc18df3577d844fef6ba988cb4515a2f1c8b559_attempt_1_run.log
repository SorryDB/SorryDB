import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f; constructor
  · rintro ⟨hpos, hunique⟩
    have hle (x : ℝ+) : f x ≤ 1 / x := by
      obtain ⟨y, hy, -⟩ := hunique x
      have := (Real.geom_mean_le_arith_mean2 (x * f y) (y * f x) (by positivity) (by positivity)).trans hy
      rw [← Real.sqrt_mul, mul_assoc, ← mul_assoc (f y), mul_comm (f y), mul_assoc] at this
      have hsq : (x * y) * (f x * f y) ≤ 1 := Real.le_one_of_sqrt_le this
      obtain ⟨z, hz, -⟩ := hunique y
      have := (Real.geom_mean_le_arith_mean2 (y * f z) (z * f y) (by positivity) (by positivity)).trans hz
      have hsq' : (y * z) * (f y * f z) ≤ 1 := Real.le_one_of_sqrt_le this
      by_contra hgt; have : f x > 1 / x := not_le.mp hgt
      have := hunique x; sorry
    funext x
    have : f x ≥ 1 / x := by
      by_contra hlt; have hlt : f x < 1 / x := not_le.mp hlt
      obtain ⟨y, hy, huni⟩ := hunique x
      have : y = x := by
        have hxx : x * f x + x * f x < 2 := by nlinarith [hlt.le, (Subtype.prop x)]
        exact (huni x hxx.le).symm
      have hlow : ∀ z, z ≠ x → x * f z + z * f x > 2 := by
        intro z hz; by_contra hle2; exact hz (huni z hle2)
      have hlim : ∀ z, x / z + z * f x > 2 := by
        intro z hz; exact (hlow z hz).trans_le' (add_le_add_right (mul_le_mul_of_nonneg_left (hle z) x.prop) _)
      have h_amgm := 2 * Real.sqrt (x * f x)
      have hmin : x / Real.sqrt (x / f x) + Real.sqrt (x / f x) * f x = h_amgm := by
        field_simp [Real.sqrt_pos.mpr (by positivity), hpos x]; ring
      sorry
    exact (hle x).antisymm this
  · rintro rfl x; use x; simp [Subtype.ext_iff]
    intro y hy
    have h := Real.geom_mean_le_arith_mean2 (x / y) (y / x) (by positivity) (by positivity)
    exact Subtype.ext (by simpa [Subtype.ext_iff] using (x / y).add_inv_eq_two (by positivity) (hy.antisymm (by simpa using h)))

