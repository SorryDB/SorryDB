import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  constructor
  · rintro ⟨hpos, hf⟩
    have h_le x : (x : ℝ) * f x ≤ 1 := by
      obtain ⟨y, hy, hf_unique⟩ := hf x
      have h_gm : 2 * Real.sqrt (x * f x * (y * f y)) ≤ x * f y + y * f x := by
        rw [mul_comm x, mul_comm y, ← mul_assoc, mul_comm (f x)]
        apply Real.two_sqrt_mul_le_add <;> positivity
      have h_xy : x * f x * (y * f y) ≤ 1 := by
        have : Real.sqrt (x * f x * (y * f y)) ≤ 1 := by nlinarith
        rw [Real.sqrt_le_one_iff] at this; exact this; positivity
      by_contra h; have h_y : y * f y < 1 := by nlinarith
      have : y = x := (hf y).unique (by nlinarith [hy])
      nlinarith
    have h_ge x : (x : ℝ) * f x ≥ 1 := by
      have : ∀ y : ℝ+, (x : ℝ) / y + (y : ℝ) * f x ≥ 2 := by
        intro y; by_cases hxy : y = x
        · rw [hxy]; field_simp; nlinarith [h_le x]
        · have : ¬ (x * f y + y * f x ≤ 2) := fun h => hxy ((hf x).unique h)
          nlinarith [h_le y]
      let y0 : ℝ+ := ⟨1 / f x, by positivity⟩
      have := this y0; simp [y0] at this; field_simp [hpos x] at this; nlinarith
    funext x; apply eq_one_div_of_mul_eq_one_right; nlinarith [h_le x, h_ge x]
  · rintro rfl
    simp only [Set.mem_singleton_iff, Set.mem_setOf_eq]
    constructor
    · intro x; positivity
    · intro x
      use x
      simp only [one_div, mul_inv_cancel (Subtype.coe_prop x), le_refl, true_and]
      intro y hy
      have hx : 0 < (x : ℝ) := x.prop
      have hy_pos : 0 < (y : ℝ) := y.prop
      have : (x : ℝ) / y + (y : ℝ) / x ≤ 2 := hy
      have : (x - y) ^ 2 ≤ 0 := by field_simp at hy; nlinarith
      exact Subtype.ext (by nlinarith)

