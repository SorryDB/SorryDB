import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  constructor
  · rintro ⟨hf, h⟩
    ext x
    let φ : ℝ+ → ℝ+ := fun x => (h x).exists.choose
    have hφ : ∀ x, (x : ℝ) * f (φ x) + (φ x) * f x ≤ 2 := fun x => (h x).exists.choose_spec
    have φ_unique : ∀ {x y}, (x : ℝ) * f y + (y : ℝ) * f x ≤ 2 → y = φ x := fun {x y} hy => (h x).unique hy (hφ x)
    have φ_inv : ∀ x, φ (φ x) = x := fun x => (φ_unique (by rw [add_comm]; exact hφ x)).symm
    have h_xfx_le_1 : ∀ x, (x : ℝ) * f x ≤ 1 := by
      intro x
      by_contra! h_gt
      have h_φx_ne_x : φ x ≠ x := fun h_eq => by nlinarith [hφ x, h_eq]
      have h_fφx : (φ x : ℝ) * f (φ x) < 1 := by
        have h1 : 0 < (x : ℝ) * f (φ x) := by positivity
        have h2 : 0 < (φ x : ℝ) * f x := by positivity
        have := two_mul_sqrt_le_add h1 h2
        nlinarith [this.trans (hφ x)]
      have h_φφx_eq_φx : φ (φ x) = φ x := by
        have : (φ x : ℝ) * f (φ x) + (φ x : ℝ) * f (φ x) ≤ 2 := by nlinarith [h_fφx]
        exact φ_unique this
      exact h_φx_ne_x (φ_inv x ▸ h_φφx_eq_φx)
    have h_xfx_ge_1 : ∀ x, (x : ℝ) * f x ≥ 1 := by
      intro x
      by_contra! h_lt
      have h_φx_eq_x : φ x = x := φ_unique (by nlinarith [h_lt])
      let y : ℝ+ := ⟨(x : ℝ) * (2 / ((x : ℝ) * f x + 1)), by positivity⟩
      have hy : y > x := by
        have : (x : ℝ) * f x + 1 < 2 := by nlinarith
        exact (lt_mul_iff_one_lt_right (by positivity)).mpr (by rw [one_lt_div (by positivity)]; nlinarith)
      have h_ge : (x : ℝ) * f y + (y : ℝ) * f x > 2 := by
        by_contra! h_le
        have : y = φ x := φ_unique (by rwa [add_comm] at h_le)
        rw [h_φx_eq_x] at this
        exact hy.ne this
      have : (x : ℝ) / y + (y : ℝ) * f x > 2 := by nlinarith [h_xfx_le_1 y, h_ge]
      field_simp [y] at this; nlinarith
    have : f x = 1 / x := by field_simp; nlinarith [h_xfx_le_1 x, h_xfx_ge_1 x]
    exact this
  · rintro rfl
    constructor
    · intro x; positivity
    · intro x; use x; simp
      constructor
      · exact (Real.add_one_div_self_le_two (by positivity)).trans (by rfl)
      · intro y hy
        have h1 : (x : ℝ) / y > 0 := by positivity
        have : (x : ℝ) / y + y / x = 2 := by simpa using hy
        simpa [h1] using (Real.add_one_div_self_le_two_iff h1).mp this
