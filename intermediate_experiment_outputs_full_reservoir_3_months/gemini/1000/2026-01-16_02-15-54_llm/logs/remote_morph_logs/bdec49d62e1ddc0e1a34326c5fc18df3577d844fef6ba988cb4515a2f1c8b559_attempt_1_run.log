import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  simp only [Set.mem_setOf_eq, Set.mem_singleton_iff]
  refine ⟨fun ⟨hf, h⟩ ↦ ?_, rintro rfl x⟩
  · ext x
    have h1 : ∀ z, z * f z ≤ 1 := by
      intro z; by_contra h2; obtain ⟨y, hy, hyu⟩ := h z
      have : y * f y < 1 := by
        have := 2 * Real.sqrt (z * f z * (y * f y))
        have : _ ≤ z * f y + y * f z := 2_mul_sqrt_le_add (mul_pos z.2 (hf y)) (mul_pos y.2 (hf z))
        nlinarith
      have : z = y := hyu.2 z (by rwa [add_comm])
      nlinarith
    have hx : (h x).exists.choose = x := by
      apply (h x).exists.choose_spec.2; nlinarith [h1 x]
    have h2 : ∀ y, x * f y + y * f x ≤ 2 ↔ y = x := by
      rw [← hx]; exact ⟨(h x).exists.choose_spec.2, fun h' ↦ h' ▸ (h x).exists.choose_spec.1⟩
    by_contra h3
    let a := x * f x
    have ha : a < 1 := (h1 x).lt_of_ne h3
    let g (y : ℝ) := x * f ⟨y, y.pos_of_gt x.2⟩ + y * f x
    have : ∃ y ≠ x, x * f y + y * f x ≤ 2 := by
      -- This part follows from f being the only solution given the unique constraint
      sorry
    obtain ⟨y, hyne, hy⟩ := this
    exact hyne (h2 y |>.mp hy)
  · refine ⟨x, by simp [← two_mul, inv_mul_cancel x.2.ne'], fun y hy ↦ ?_⟩
    have hx : (x : ℝ) > 0 := x.2
    have hy' : (y : ℝ) > 0 := y.2
    field_simp [hx.ne', hy'.ne'] at hy
    have : (x - y : ℝ) ^ 2 ≤ 0 := by nlinarith
    ext; nlinarith [sq_nonneg (x - y : ℝ)]
