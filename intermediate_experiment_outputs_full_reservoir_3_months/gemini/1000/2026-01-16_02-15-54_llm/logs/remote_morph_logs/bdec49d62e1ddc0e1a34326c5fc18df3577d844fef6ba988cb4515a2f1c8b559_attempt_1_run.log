namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {f | ∀ x, f x = 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f
  simp only [Set.mem_setOf_eq]
  constructor
  · rintro ⟨hpos, hux⟩
    have hle : ∀ x, x * f x ≤ 1 := by
      intro x
      by_contra! h
      obtain ⟨y, hy, -⟩ := hux x
      have h_y : y * f y < 1 := by
        by_contra! h_y_gt
        have := (x * f y + y * f x) ^ 2
        nlinarith [sq_nonneg (x * f y - y * f x), hpos x, hpos y]
      have : x = y := (hux y).unique (by rwa [add_comm]) (by nlinarith [h_y])
      nlinarith
    have heq : ∀ x, x * f x = 1 := by
      intro x
      by_contra! h
      have hlt : x * f x < 1 := (hle x).lt_of_ne h
      let y : ℝ+ := ⟨Real.sqrt (x / f x), Real.sqrt_pos.2 (div_pos x.2 (hpos x))⟩
      have h_xy : (x : ℝ) * f y + y * f x < 2 := by
        have hfy : f y ≤ 1 / y := (le_div_iff y.2).2 (hle y)
        calc (x : ℝ) * f y + y * f x ≤ x / y + y * f x := by nlinarith [hpos y]
          _ = 2 * Real.sqrt (x * f x) := by
            field_simp [Real.sq_sqrt (div_pos x.2 (hpos x)).le, y.2.ne.symm]
            ring
          _ < 2 := by nlinarith [Real.sqrt_lt_one.2 (mul_pos x.2 (hpos x)) hlt]
      have : y = x := (hux x).unique h_xy.le (by nlinarith [hlt])
      have h_yval : (y : ℝ) = x := Subtype.ext_iff.1 this
      have : (x : ℝ)^2 = x / f x := by rw [← h_yval, Real.sq_sqrt (div_pos x.2 (hpos x)).le]
      nlinarith
    ext x
    field_simp [heq x]
  · rintro rfl
    intro x
    simp only [one_div, inv_pos, Subtype.pos, true_and]
    use x
    simp only [mul_inv_cancel (ne_of_gt x.2), add_self_le_two, true_and]
    intro y hy
    rw [Subtype.ext_iff]
    field_simp at hy
    have : 0 ≤ ((x : ℝ) - y)^2 := sq_nonneg (x - y)
    nlinarith
