Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f; simp only [answer, Set.mem_setOf_eq, Set.mem_singleton_iff]; constructor
  · rintro ⟨hf, h⟩; funext x; let g := fun x : ℝ+ ↦ (x : ℝ) * f x
    have hle : ∀ x, g x ≤ 1 := fun x ↦ by
      obtain ⟨y, hy, -⟩ := h x; have hgy : g x * g y ≤ 1 := by
        have := Real.geom_mean_le_arith_mean2 (x * f y) (y * f x) (by positivity) (by positivity)
        rw [mul_comm (f y), ← mul_assoc, mul_assoc (x : ℝ), mul_comm (f x)] at this
        exact (Real.sqrt_le_one_iff).1 (le_trans this hy)
      have : (h y).choose = x := ((h y).unique (by rw [add_comm]; exact hy) (h y).choose_spec.1).symm
      by_contra hg; have : g x > 1 := by linarith
      have : g y < 1 := by nlinarith [hgy]
      have : (h y).choose = y := (h y).unique (by linarith [this]) (h y).choose_spec.1
      nlinarith
    have h_eq : ∀ x, g x = 1 := fun x ↦ by
      let y : ℝ+ := ⟨x / g x, by positivity⟩
      have : x * f y + y * f x ≤ 2 := by
        calc (x:ℝ) * f y + (y:ℝ) * f x ≤ x * (1 / y) + y * f x := by
          apply add_le_add_right; rw [mul_comm]; apply (le_div_iff y.2).2 (hle y)
        _ = g x + 1 := by simp [y, g]; field_simp; ring
        _ ≤ 2 := by linarith [hle x]
      have : y = x := (h x).unique this (by linarith [hle x])
      field_simp [y] at this; exact this
    exact eq_one_div_of_mul_eq_one_right (h_eq x)
  · rintro rfl; simp; intro x; use x; simp; intro y hy
    have h : (x:ℝ)/y + (y:ℝ)/x ≤ 2 := by exact_mod_cast hy
    have : (x:ℝ)^2 + (y:ℝ)^2 ≤ 2 * x * y := by
      field_simp [ne_of_gt x.2, ne_of_gt y.2] at h ⊢; nlinarith
    exact Subtype.ext (by nlinarith [pow_two_nonneg ((x : ℝ) - y)])
