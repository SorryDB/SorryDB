import Mathlib


namespace IMO2022P2

notation "ℝ+" => Set.Ioi (0 : ℝ)

/-- The answer to be determined. -/
def answer : Set (ℝ+ → ℝ) := {f | f = fun x => 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  ext f; constructor
  · rintro ⟨hf, hf'⟩; funext x
    let g x := (hf' x).choose
    have hg x : (x : ℝ) * f (g x) + (g x) * f x ≤ 2 := (hf' x).choose_spec.1
    have hg' x y : (x : ℝ) * f y + (y : ℝ) * f x ≤ 2 ↔ y = g x := ⟨(hf' x).choose_spec.2 y, (·.symm ▸ hg x)⟩
    have hgg x : g (g x) = x := (hg' (g x) x).1 (by rw [add_comm]; exact hg x)
    have h1 : ∀ x, (x : ℝ) * f x ≤ 1 := by
      intro x; by_contra! hx
      have hgxf : (g x : ℝ) * f (g x) < 1 := by
        have := Real.two_mul_sqrt_le_add (mul_pos x.2 (hf x)) (mul_pos (g x).2 (hf (g x)))
        nlinarith [hg x, Real.sqrt_mul (by positivity) ((g x : ℝ) * f (g x))]
      have : g (g x) = g x := (hg' (g x) (g x)).1 (by linarith)
      linarith [hgg x]
    have h2 : ∀ x, (x : ℝ) * f x = 1 := by
      intro x; apply le_antisymm (h1 x); by_contra! hx
      have hgx : g x = x := (hg' x x).1 (by linarith)
      let y : ℝ+ := ⟨1 / f x, by positivity⟩
      have : y ≠ x := by intro h; linarith [congr_arg Subtype.val h]
      have : (x : ℝ) * f y + (y : ℝ) * f x > 2 := (hg' x y).not.mpr this
      have := h1 y; nlinarith
    have := h2 x; field_simp [x.2.ne.symm] at this; exact this
  · rintro rfl; simp only [Set.mem_setOf_eq, inv_pos, implies_true, true_and]
    intro x; use x; simp [Real.add_div_self_le_two_iff, x.2]

