instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f h := by
    let L := lightToProfinite
    letI : Nonempty (S.component 0) := Nonempty.map (S.proj 0) inferInstance
    haveI (n : ℕ) : Epi (L.map (S.transitionMap n)) := (epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    obtain ⟨k0, h0⟩ := Injective.factors (g ≫ L.map (S.proj 0)) f
    have h_step (n : ℕ) (k : Y ⟶ L.obj (S.component n)) (hk : f ≫ k = g ≫ L.map (S.proj n)) :=
      profinite_key_extension_lemma _ _ _ _ f (L.map (S.transitionMap n)) (g ≫ L.map (S.proj (n+1))) k
        (by rw [hk, ← L.map_comp, S.proj_comp_transitionMap])
    let k_seq (n : ℕ) : { k : Y ⟶ L.obj (S.component n) // f ≫ k = g ≫ L.map (S.proj n) } :=
      Nat.rec ⟨k0, h0⟩ (fun n k ↦ ⟨Classical.choose (h_step n k.1 k.2), (Classical.choose_spec (h_step n k.1 k.2)).2⟩) n
    let k_cone : Cone (S.diagram ⋙ L) := { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).1)
      (fun n ↦ (Classical.choose_spec (h_step n (k_seq n).1 (k_seq n).2)).1.symm) }
    let S_limit := L.mapLimitCone S.asLimit
    use S_limit.isLimit.lift k_cone
    apply S_limit.isLimit.uniq (k_cone.extend f)
    intro n; exact (k_seq n.unop).2
