instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f _ := by
    haveI (n : ℕ) : Finite (S.component n) := inferInstance
    haveI : Nonempty (S.component 0) := Nonempty.map (S.proj 0) inferInstance
    haveI (n : ℕ) : Epi (lightToProfinite.map (S.transitionMap n)) :=
      (LightProfinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    have h_step (n : ℕ) (k : Y ⟶ lightToProfinite.obj (S.component n))
      (h_down : f ≫ k = g ≫ lightToProfinite.map (S.proj n)) :
      ∃ k' : Y ⟶ lightToProfinite.obj (S.component (n+1)),
      k' ≫ lightToProfinite.map (S.transitionMap n) = k ∧ f ≫ k' = g ≫ lightToProfinite.map (S.proj (n+1)) :=
      profinite_key_extension_lemma _ _ _ _ f (lightToProfinite.map (S.transitionMap n))
        (g ≫ lightToProfinite.map (S.proj (n+1))) k (by rw [h_down, ← lightToProfinite.map_comp, S.proj_comp_transitionMap])
    obtain ⟨k0, h0⟩ := Injective.factors (g ≫ lightToProfinite.map (S.proj 0)) f
    let lifts (n : ℕ) := { k : Y ⟶ lightToProfinite.obj (S.component n) // f ≫ k = g ≫ lightToProfinite.map (S.proj n) }
    let next (n : ℕ) (k : lifts n) : lifts (n+1) := ⟨Classical.choose (h_step n k.1 k.2),
      (Classical.choose_spec (h_step n k.1 k.2)).2⟩
    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h0⟩ next n
    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).1) (fun n ↦ (Classical.choose_spec (h_step n (k_seq n).1 (k_seq n).2)).1.symm) }
    let iL := isLimitOfPreserves lightToProfinite S.asLimit.isLimit
    use iL.lift k_cone
    apply iL.hom_ext; intro n; simp [k_cone, iL.fac k_cone n, (k_seq n.unop).2]
