instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f _ := by
    haveI (n : ℕ) : Finite (S.component n) :=
      inferInstanceAs (Finite (FintypeCat.toLightProfinite.obj _))
    haveI : Nonempty (S.component 0) := Nonempty.map (S.proj 0) inferInstance
    haveI (n : ℕ) : Epi (lightToProfinite.map (S.transitionMap n)) :=
      (epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ lightToProfinite.map (S.proj 0)) f
    let h_step (n : ℕ) (k : Y ⟶ lightToProfinite.obj (S.component n))
        (h_down : f ≫ k = g ≫ lightToProfinite.map (S.proj n)) :=
      profinite_key_extension_lemma _ _ _ _ f (lightToProfinite.map (S.transitionMap n))
        (g ≫ lightToProfinite.map (S.proj (n + 1))) k
        (by rw [h_down, ← lightToProfinite.map_comp, S.proj_comp_transitionMap])
    let lifts n := { k : Y ⟶ lightToProfinite.obj (S.component n) // f ≫ k = g ≫ lightToProfinite.map (S.proj n) }
    let next n k := (⟨Classical.choose (h_step n k.val k.property), (Classical.choose_spec (h_step n k.val k.property)).2⟩ : lifts (n+1))
    let k_seq n := Nat.rec (⟨k0, h_down0⟩ : lifts 0) next n
    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val)
        (fun n ↦ (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1.symm) }
    let iS := isLimitOfPreserves lightToProfinite S.asLimit
    use iS.lift k_cone
    apply iS.uniq (k_cone.extend f) g
    intro n
    exact (k_seq n.unop).property.symm
