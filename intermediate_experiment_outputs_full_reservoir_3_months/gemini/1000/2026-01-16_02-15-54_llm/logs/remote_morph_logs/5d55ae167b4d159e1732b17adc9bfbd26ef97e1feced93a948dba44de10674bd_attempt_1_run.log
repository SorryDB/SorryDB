    haveI (n : ℕ) : Finite (S.component n) := inferInstanceAs (Finite (FintypeCat.toLightProfinite.obj _))
    haveI : Nonempty (S.component 0) := Nonempty.map (S.proj 0) inferInstance
    haveI (n : ℕ) : Epi (lightToProfinite.map (S.transitionMap n)) :=
      (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    obtain ⟨k0, h0⟩ := Injective.factors (g ≫ lightToProfinite.map (S.proj 0)) f
    let step n k hk := profinite_key_extension_lemma _ _ _ _ f (lightToProfinite.map (S.transitionMap n))
      (g ≫ lightToProfinite.map (S.proj (n+1))) k (by rw [hk, ← lightToProfinite.map_comp, S.proj_comp_transitionMap])
    let k (n : ℕ) : { k : Y ⟶ lightToProfinite.obj (S.component n) // f ≫ k = g ≫ lightToProfinite.map (S.proj n) } :=
      Nat.rec ⟨k0, h0⟩ (fun n k ↦ ⟨Classical.choose (step n k.1 k.2), (Classical.choose_spec (step n k.1 k.2)).2⟩) n
    let L := isLimitOfPreserves lightToProfinite S.asLimit.isLimit
    let C : Cone (S.diagram ⋙ lightToProfinite) := { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k n).1)
      (fun n ↦ (Classical.choose_spec (step n (k n).1 (k n).2)).1.symm) }
    use L.lift C
    apply L.hom_ext; intro n; rw [Category.assoc, L.fac, (k n.unop).2]
