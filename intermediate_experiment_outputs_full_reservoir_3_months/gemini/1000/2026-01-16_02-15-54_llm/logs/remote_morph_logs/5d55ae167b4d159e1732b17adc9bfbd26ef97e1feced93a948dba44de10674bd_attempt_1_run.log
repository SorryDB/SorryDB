instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f _ := by
    let L := lightToProfinite
    let hS := isLimitOfPreserves L S.asLimit
    haveI (n : ℕ) : Finite (S.component n) := inferInstance
    haveI : Nonempty (S.component 0) := Nonempty.map (S.proj 0) inferInstance
    haveI (n : ℕ) : Epi (L.map (S.transitionMap n)) := (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    let lifts n := { k : Y ⟶ L.obj (S.component n) // f ≫ k = g ≫ L.map (S.proj n) }
    have h_step n (k : lifts n) : ∃ k' : lifts (n+1), k'.1 ≫ L.map (S.transitionMap n) = k.1 := by
      obtain ⟨k', h1, h2⟩ := profinite_key_extension_lemma _ _ _ _ f (L.map (S.transitionMap n)) (g ≫ L.map (S.proj (n+1))) k.1 (by rw [k.2, ← L.map_comp, S.proj_comp_transitionMap])
      exact ⟨⟨k', h2⟩, h1⟩
    let k0 := Injective.factors (g ≫ L.map (S.proj 0)) f
    let k_seq n := Nat.rec (⟨Classical.choose k0, Classical.choose_spec k0⟩ : lifts 0) (fun n k ↦ Classical.choose (h_step n k)) n
    let k_cone : Cone (S.diagram ⋙ L) := { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).1) (fun n ↦ (Classical.choose_spec (h_step n (k_seq n))).symm) }
    use hS.lift k_cone
    apply hS.uniq (k_cone.extend f) g
    intro n; simp [k_cone, (k_seq n.unop).2]
