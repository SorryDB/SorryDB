instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f h := by
    haveI (n : ℕ) : Finite (lightToProfinite.obj (S.component n)) :=
      inferInstanceAs (Finite (S.component n))
    haveI : Nonempty (lightToProfinite.obj (S.component 0)) := Nonempty.map (lightToProfinite.map (S.proj 0)) inferInstance
    haveI (n : ℕ) : Epi (lightToProfinite.map (S.transitionMap n)) := (epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ lightToProfinite.map (S.proj 0)) f
    let h_step (n : ℕ) (k : Y ⟶ lightToProfinite.obj (S.component n)) (h_down : f ≫ k = g ≫ lightToProfinite.map (S.proj n)) :
      ∃ k' : Y ⟶ lightToProfinite.obj (S.component (n+1)), k' ≫ lightToProfinite.map (S.transitionMap n) = k ∧ f ≫ k' = g ≫ lightToProfinite.map (S.proj (n+1)) := by
      have h_comm : f ≫ k = g ≫ lightToProfinite.map (S.proj (n+1)) ≫ lightToProfinite.map (S.transitionMap n) := by
        rw [h_down, ← lightToProfinite.map_comp, S.proj_comp_transitionMap]
      exact Profinite.profinite_key_extension_lemma _ _ _ _ f (lightToProfinite.map (S.transitionMap n)) (g ≫ lightToProfinite.map (S.proj (n+1))) k h_comm
    let lifts (n : ℕ) := { k : Y ⟶ lightToProfinite.obj (S.component n) // f ≫ k = g ≫ lightToProfinite.map (S.proj n) }
    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=
      ⟨Classical.choose (h_step n k.1 k.2), (Classical.choose_spec (h_step n k.1 k.2)).2⟩
    let k_seq (n : Nat) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n
    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ lightToProfinite.map (S.transitionMap n) = (k_seq n).val := by
      induction n with | zero => exact (Classical.choose_spec (h_step 0 k0 h_down0)).1
                       | succ n ih => exact (Classical.choose_spec (h_step (n+1) (k_seq (n+1)).val (k_seq (n+1)).property)).1
    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }
    use S.asLimit.lift k_cone
    have hg : g = S.asLimit.lift (k_cone.extend f) := by
      apply S.asLimit.uniq; intro n; simp [NatTrans.ofOpSequence_app, (k_seq n.unop).property]
    rw [hg]
    apply S.asLimit.uniq; intro n; simp
