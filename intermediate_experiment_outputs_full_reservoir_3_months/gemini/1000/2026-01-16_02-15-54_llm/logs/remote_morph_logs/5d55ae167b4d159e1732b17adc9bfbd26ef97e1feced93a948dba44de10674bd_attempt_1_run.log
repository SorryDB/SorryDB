instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f _ := by
    let D := S.diagram ⋙ lightToProfinite
    let SL_lim := isLimitOfPreserves lightToProfinite S.asLimit.isLimit
    haveI (n : ℕ) : Finite (D.obj (Opposite.op n)) :=
      inferInstanceAs (Finite (S.component n))
    haveI : Nonempty (D.obj (Opposite.op 0)) := Nonempty.map (S.proj 0) inferInstance
    haveI (n : ℕ) : Epi (lightToProfinite.map (S.transitionMap n)) :=
      (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    obtain ⟨k0, h0⟩ := Injective.factors (g ≫ lightToProfinite.map (S.proj 0)) f
    let h_step n k h := profinite_key_extension_lemma _ _ _ _ f (lightToProfinite.map (S.transitionMap n))
      (g ≫ lightToProfinite.map (S.proj (n+1))) k (by
        rw [h, ← lightToProfinite.map_comp, S.proj_comp_transitionMap]; rfl)
    let lifts n := { k : Y ⟶ D.obj (Opposite.op n) // f ≫ k = g ≫ lightToProfinite.map (S.proj n) }
    let next n k := (⟨Classical.choose (h_step n k.1 k.2), (Classical.choose_spec (h_step n k.1 k.2)).2⟩ : lifts (n+1))
    let k_seq n := Nat.rec (⟨k0, h0⟩ : lifts 0) next n
    let k_cone : Cone D := { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).1)
      (fun n ↦ (Classical.choose_spec (h_step n (k_seq n).1 (k_seq n).2)).1.symm) }
    use SL_lim.lift k_cone
    rw [← SL_lim.lift_comp, ← SL_lim.uniq (k_cone.extend f) g]
    intro n; simp [show k_cone.π.app n = (k_seq n.unop).1 from rfl, (k_seq n.unop).2]
