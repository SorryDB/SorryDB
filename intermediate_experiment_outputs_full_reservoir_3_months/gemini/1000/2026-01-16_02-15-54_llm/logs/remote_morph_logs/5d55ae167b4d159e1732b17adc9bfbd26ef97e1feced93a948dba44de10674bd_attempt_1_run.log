instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f h := by
    haveI (n : ℕ) : Finite (S.component n) := inferInstance
    haveI : Nonempty (S.component 0) := Nonempty.map (S.proj 0) inferInstance
    let p n := lightToProfinite.map (S.proj n)
    let t n := lightToProfinite.map (S.transitionMap n)
    haveI (n : ℕ) : Epi (t n) := (epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ p 0) f
    have h_step (n : ℕ) (k : Y ⟶ lightToProfinite.obj (S.component n)) (h_down : f ≫ k = g ≫ p n) :
      ∃ k' : Y ⟶ lightToProfinite.obj (S.component (n+1)), k' ≫ t n = k ∧ f ≫ k' = g ≫ p (n+1) := by
      have h_comm : f ≫ k = g ≫ p (n+1) ≫ t n := by
        rw [h_down, ← lightToProfinite.map_comp, S.proj_comp_transitionMap]
      exact profinite_key_extension_lemma _ _ _ _ f (t n) (g ≫ p (n+1)) k h_comm
    let lifts n := { k : Y ⟶ lightToProfinite.obj (S.component n) // f ≫ k = g ≫ p n }
    let next n k := ⟨Classical.choose (h_step n k.val k.property), (Classical.choose_spec (h_step n k.val k.property)).2⟩
    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n
    have h_up n : (k_seq (n+1)).val ≫ t n = (k_seq n).val := (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1
    let k_cone : Cone (S.diagram ⋙ FintypeCat.toLightProfinite ⋙ lightToProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }
    let s_isLimit := lightToProfinite.isLimitOfPreserves S.asLimit.isLimit
    use s_isLimit.lift k_cone
    apply s_isLimit.hom_ext; intro n; exact (k_seq n.unop).property
