      ⟨Classical.choose (h_step n k.val k.property), (Classical.choose_spec (h_step n k.val k.property)).2⟩
    let k_seq (n : Nat) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n
    let k_cone : Cone (S.diagram ⋙ FintypeCat.toProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val)
        (fun n ↦ (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1.symm) }
    let hL := isLimitOfPreserves lightToProfinite S.asLimit.isLimit
    use hL.lift k_cone
    apply hL.hom_ext; intro n; rw [Category.assoc, hL.fac, (k_seq n.unop).property]

end LightProfinite
