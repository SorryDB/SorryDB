instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f _ := by
    let S_ n := lightToProfinite.obj (S.component n)
    let g' n := g ≫ lightToProfinite.map (S.proj n)
    let f' n := lightToProfinite.map (S.transitionMap n)
    haveI (n : ℕ) : Finite (S_ n) := inferInstance
    haveI : Nonempty (S_ 0) := Nonempty.map (S.proj 0) inferInstance
    haveI (n : ℕ) : Epi (f' n) := (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    obtain ⟨k0, h0⟩ := Injective.factors (g' 0) f
    have h_step (n : ℕ) (k : Y ⟶ S_ n) (hk : f ≫ k = g' n) :
      ∃ k' : Y ⟶ S_ (n+1), k' ≫ f' n = k ∧ f ≫ k' = g' (n+1) :=
      profinite_key_extension_lemma _ _ _ _ f (f' n) (g' (n+1)) k
        (by rw [hk, g', ← lightToProfinite.map_comp, S.proj_comp_transitionMap])
    let lifts n := { k : Y ⟶ S_ n // f ≫ k = g' n }
    let k_seq n : lifts n := Nat.rec ⟨k0, h0⟩ (fun n k ↦ ⟨Classical.choose (h_step n k.1 k.2), (Classical.choose_spec (h_step n k.1 k.2)).2⟩) n
    let k_cone : Cone (S.diagram ⋙ lightToProfinite) := { pt := Y,
      π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).1) (fun n ↦ (Classical.choose_spec (h_step n (k_seq n).1 (k_seq n).2)).1.symm) }
    use S.asLimit.lift k_cone
    rw [S.asLimit.uniq (S.asLimit.cone.extend g) g (fun n ↦ rfl)]
    apply S.asLimit.uniq (S.asLimit.cone.extend g)
    intro n
    simp [k_cone, (k_seq n.unop).2]
