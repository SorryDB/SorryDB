            unfold Word.VZtoZ at lemma_deriv_leaf_count
            unfold Word.len at lemma_deriv_leaf_count
            rw [List.length_map, List.length_attach] at lemma_deriv_leaf_count
            simp at lemma_deriv_leaf_count
