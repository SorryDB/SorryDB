          --• Also kann der Baum unterhalb dieses Vorkommens maximal 2|V| = n Blätter haben
          --(dies sind die Symbole in vwx)
          obtain ⟨u, v, w, x, y, h_split, h_vx, h_vwx, h_pump⟩ := (sorry : ∃ u v w x y, ↑z = u * v * w * x * y ∧ (v * x).len ≥ 1 ∧ (v * w * x).len ≤ 2 ^ (↑cfg_CNF).V.card ∧ ∀ k, u * v ^ k * w * x ^ k * y ∈ ↑language)
          use u, v, w, x, y, h_split, h_vx, h_vwx, h_pump
