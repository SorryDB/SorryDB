theorem imo_2008_p2.parts.ii :
    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  let f : ℕ → ℚ × ℚ × ℚ := fun k =>
    let k' : ℚ := k
    (-(k' + 1) * (k' + 2), (k' + 1) / (k' + 2) ^ 2, -(k' + 2) / (k' + 1) ^ 2)
  apply Set.Infinite.mono (s := Set.range f)
