/-- [b](a)[/b] Prove that
\[\frac {x^{2}}{\left(x -{} 1\right)^{2}} +{} \frac {y^{2}}{\left(y -{} 1\right)^{2}} +{} \frac {z^{2}}{\left(z -{} 1\right)^{2}} \geq 1\] for all real numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[b](b)[/b] Prove that equality holds above for infinitely many triples of rational numbers $x$, $y$, $z$, each different from $1$, and satisfying $xyz=1$.

[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.ii :
    Set.Infinite {
      (x, y, z) |
      (x : ℚ) (y : ℚ) (z : ℚ)
      (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1)
      (h₁ : x * y * z = 1)
      (h₂ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1) } := by
  let f : ℕ → ℚ × ℚ × ℚ := λ n =>
    let m : ℚ := n + 2
    (2 * (m - 1) / (m + 1)^2, -2 * (m + 1) / (m - 1)^2, (1 - m^2) / 4)
  apply Set.Infinite.of_injective f
  · intro n1 n2 h; simp [f] at h; nlinarith
  · intro n; simp [f]
    let m : ℚ := n + 2
    let x : ℚ := 2 * (m - 1) / (m + 1)^2
    let y : ℚ := -2 * (m + 1) / (m - 1)^2
    let z : ℚ := (1 - m^2) / 4
    have hx : x ≠ 1 := by field_simp [x]; nlinarith
    have hy : y ≠ 1 := by field_simp [y]; nlinarith
    have hz : z ≠ 1 := by field_simp [z]; nlinarith
    refine ⟨x, y, z, ⟨hx, hy, hz⟩, ?_, ?_, rfl⟩
    · field_simp [x, y, z]; ring
    · field_simp [sub_ne_zero.2 hx, sub_ne_zero.2 hy, sub_ne_zero.2 hz, x, y, z]; ring
```
