      k - 1#u32 = ok km1 ∧
      mul_by_pow_2 e km1 = ok e_km1 ∧
      double e_km1 = ok e_km1_double ∧
      ConstantTimeEqcurve25519_dalekedwardsEdwardsPoint.ct_eq e_result e_km1_double = ok eq_choice ∧
      eq_choice = Choice.one) := by
    rw [mul_by_pow_2]
    split_ifs with h <;> simp [h, hk]
    · cases hd : e.double <;> simp [hd]
      refine ⟨_, rfl, (fun _ => ⟨_, Choice.one, hd, by simp [ConstantTimeEqcurve25519_dalekedwardsEdwardsPoint.ct_eq], rfl⟩), by simp [h, hk]⟩
