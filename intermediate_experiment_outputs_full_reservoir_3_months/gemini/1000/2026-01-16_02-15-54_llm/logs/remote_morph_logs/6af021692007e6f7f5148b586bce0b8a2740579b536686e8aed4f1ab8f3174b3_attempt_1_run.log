      cases h3 : _.double <;> simp [h3]
      refine ⟨_, rfl, (by simp [h]), (fun _ => ⟨_, _, _, Choice.one, h1, h2, h3, by simp [ConstantTimeEqcurve25519_dalekedwardsEdwardsPoint.ct_eq], rfl⟩)⟩

