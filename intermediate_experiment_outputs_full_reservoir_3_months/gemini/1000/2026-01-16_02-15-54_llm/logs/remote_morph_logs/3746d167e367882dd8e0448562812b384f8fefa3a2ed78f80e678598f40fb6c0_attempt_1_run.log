/-- Every convex set in ℝ³ has VC₂ dimension at most 1.

In fact, this set n-shatters an infinite set. -/
lemma vc2_lt_two_of_convex_r3 {C : Set (Fin 3 → ℝ)} (hC : Convex ℝ C)
    {x y : Fin 2 → Fin 3 → ℝ} {z : Set (Fin 2 × Fin 2) → Fin 3 → ℝ}
    (hxy : ∀ i j s, x i + y j + z s ∈ C ↔ (i, j) ∈ s) : False := by
  let s1 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1)}
  let s2 : Set (Fin 2 × Fin 2) := {(0, 1), (1, 0)}
  have h1 : x 0 + y 0 + z s1 ∈ C := (hxy 0 0 s1).2 (by simp)
  have h2 : x 1 + y 1 + z s1 ∈ C := (hxy 1 1 s1).2 (by simp)
  have h3 : x 0 + y 1 + z s2 ∈ C := (hxy 0 1 s2).2 (by simp)
  have h4 : x 1 + y 0 + z s2 ∈ C := (hxy 1 0 s2).2 (by simp)
  let m1 := (1 / 2 : ℝ) • (x 0 + y 0 + z s1) + (1 / 2 : ℝ) • (x 1 + y 1 + z s1)
  let m2 := (1 / 2 : ℝ) • (x 0 + y 1 + z s2) + (1 / 2 : ℝ) • (x 1 + y 0 + z s2)
  have hm1 : m1 ∈ C := hC.add_convex h1 h2 (by norm_num) (by norm_num) (by norm_num)
  have hm2 : m2 ∈ C := hC.add_convex h3 h4 (by norm_num) (by norm_num) (by norm_num)
  have h_eq : m1 - z s1 = m2 - z s2 := by
    simp [m1, m2]; ext k; simp [add_mul, smul_add]; ring
  set C' : Set (Fin 3 → ℝ) := {p | p + z s1 ∈ C}
  have hC' : Convex ℝ C' := hC.translate _
  have h_m1 : (1 / 2 : ℝ) • (x 0 + y 1) + (1 / 2 : ℝ) • (x 1 + y 0) ∈ C' := by
    rw [mem_setOf_eq, ← m1, h_eq]; exact hm2
  let s3 : Set (Fin 2 × Fin 2) := {(0, 0), (1, 1), (0, 1), (1, 0)}
  let s4 : Set (Fin 2 × Fin 2) := ∅
  sorry
