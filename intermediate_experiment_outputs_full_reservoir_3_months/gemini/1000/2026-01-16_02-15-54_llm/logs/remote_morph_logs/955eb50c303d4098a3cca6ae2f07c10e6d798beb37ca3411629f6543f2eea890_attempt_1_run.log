/-- A pure-state ensemble mixes into a pure state if and only if
the only states in the ensemble with nonzero probability are equal to `ψ`  -/
theorem mix_pEnsemble_pure_iff_pure {e : PEnsemble d α} :
  mix (toMEnsemble e) = MState.pure ψ ↔ ∀ i : α, e.distr i ≠ 0 → e.states i = ψ := by
  constructor
  · intro h i hi
    have h_sum : ∑ j, (e.distr j : ℝ) * (MState.pure (e.states j)).exp_val (MState.pure ψ) = 1 := by
      simp only [mix_of, toMEnsemble_mk, MState.exp_val, Trace.sum, Trace.smul, h, MState.exp_val_pure_self]
    have h_le : ∀ j, (MState.pure (e.states j)).exp_val (MState.pure ψ) ≤ 1 := fun j ↦ MState.exp_val_le_one _ _
    have h_eq : (MState.pure (e.states i)).exp_val (MState.pure ψ) = 1 := by
      refine' eq_of_le_of_not_lt (h_le i) (fun hlt ↦ _)
      have := Finset.sum_lt_sum (fun j _ ↦ mul_le_of_le_one_right (Prob.coe_nonneg _) (h_le j)) ⟨i, Finset.mem_univ i, mul_lt_of_lt_one_right (Prob.coe_pos.mpr hi) hlt⟩
      simp [e.distr.normalized, h_sum] at this
    exact MState.pure_inj.mp ((MState.exp_val_pure_eq_one_iff _ _).mp h_eq).symm
  · intro h
    simp [mix, toMEnsemble, Distribution.expect_val, Distribution.map, h]
