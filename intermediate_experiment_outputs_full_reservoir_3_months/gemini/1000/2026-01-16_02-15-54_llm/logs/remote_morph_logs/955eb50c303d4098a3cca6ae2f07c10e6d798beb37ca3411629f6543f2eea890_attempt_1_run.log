/-- A pure-state ensemble mixes into a pure state if and only if
the only states in the ensemble with nonzero probability are equal to `ψ`  -/
theorem mix_pEnsemble_pure_iff_pure {e : PEnsemble d α} :
  mix (toMEnsemble e) = MState.pure ψ ↔ ∀ i : α, e.distr i ≠ 0 → e.states i = ψ := by
  constructor
  · intro h
    have h_sum : ∑ i, (e.distr i : ℝ) * (MState.pure (e.states i)).exp_val (MState.pure ψ) = 1 := by
      simp [← MState.exp_val_expect_val, toMEnsemble, mix, h, MState.exp_val_pure_self]
    have h_all := (sum_prob_mul_eq_one_iff (λ i => ↑(e.distr i)) (λ i => (MState.pure (e.states i)).exp_val (MState.pure ψ)) (λ i => (e.distr i).2) Distribution.normalized (λ i => MState.exp_val_le_one _ _)).mp h_sum
    intro i hi
    exact MState.pure_inj (MState.exp_val_pure_pure_eq_one_iff.mp (h_all i hi))
  · intro h
    apply Mixable.to_U_inj
    simp [mix, toMEnsemble, Distribution.expect_val]
    rw [← Finset.sum_smul, Distribution.normalized, one_smul]
    intro i hi
    rw [h i (by simpa [Distribution.distr_ne_zero_iff] using hi)]

/-- The average of `f : Ket d → T` on an ensemble that mixes to a pure state `ψ` is `f ψ` -/
```
