/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 := by
  let s : ℂ := -2 * n
  have hs : s ≠ 1 := by intro h; apply_fun Complex.re at h; simp [s] at h; linarith
  have h_diff : DifferentiableAt ℂ (fun s => 2 ^ s * π ^ (s - 1) * Gamma (1 - s) * riemannZeta (1 - s)) s := by
    refine (((differentiableAt_cpow_const (Or.inl (by norm_num))).mul
      (differentiableAt_cpow_const (Or.inl (by norm_num)))).mul ?_).mul ?_
    · exact (differentiableAt_Gamma (by simp [s]; linarith)).comp (differentiableAt_const.sub differentiableAt_id)
    · exact (differentiableAt_riemannZeta (by simp [s]; linarith)).comp (differentiableAt_const.sub differentiableAt_id)
  rw [deriv_eq_of_hasDerivAt (hasDerivAt_riemannZeta hs),
      show riemannZeta = fun z => (2 ^ z * π ^ (z - 1) * Gamma (1 - z) * riemannZeta (1 - z)) * sin (π * z / 2) from
        funext (fun z => if hz : z = 1 then by simp [hz] else riemannZeta_functional_equation z),
      deriv_mul h_diff (differentiableAt_sin.comp (differentiableAt_id.mul_const _)), by simp [s], mul_zero, add_zero]
  repeat' apply mul_ne_zero
  · exact Complex.cpow_ne_zero _ (by norm_num)
  · exact Complex.cpow_ne_zero _ (by norm_num)
  · exact Complex.Gamma_ne_zero _ (by simp [s]; intro h; linarith)
  · apply riemannZeta_ne_zero_of_one_le_re; simp [s]; linarith
  · simp [s, Complex.cos_nat_mul_pi, Real.pi_ne_zero]
```
