import Seymour.Results.EasyDirection


variable {α : Type*} [DecidableEq α]

/-- The hard direction of the Seymour's theorem (restricted to matroids of finite rank). -/
theorem Matroid.IsRegular.isGood_of_rankFinite {M : Matroid α} (hM : M.IsRegular) (hM' : M.RankFinite) : M.IsGood := by
  induction hM' using Matroid.RankFinite.induction_on_card generalizing hM with M hM' IH
  rcases hM.exists_graphic_or_cographic_or_r10_or_sum hM' with (h | h | h | ⟨M1, M2, hsum⟩)
  · exact .graphic h
  · exact .cographic h
  · exact .r10 h
  · exact .sum hsum (IH M1 _ (hsum.card_lt_left hM') (hsum.isRegular_left hM))
      (IH M2 _ (hsum.card_lt_right hM') (hsum.isRegular_right hM))

```
