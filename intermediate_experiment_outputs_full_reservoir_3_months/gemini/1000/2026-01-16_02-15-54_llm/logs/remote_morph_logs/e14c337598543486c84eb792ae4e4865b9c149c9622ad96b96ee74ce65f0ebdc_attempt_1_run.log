            exact h_c Γ'' hG'' (T.imp_closed (by grind) hC);
          . exact ih Γ' hΓ' hC;
        . exact ih Γ' hΓ' hC;
    exact hP (encode φ) (insert φ Γ) (by simp [hΓ, monotone_construction (zero_le _) (by simp [construction, h])]) (T.imp_closed (by grind) hφ);
