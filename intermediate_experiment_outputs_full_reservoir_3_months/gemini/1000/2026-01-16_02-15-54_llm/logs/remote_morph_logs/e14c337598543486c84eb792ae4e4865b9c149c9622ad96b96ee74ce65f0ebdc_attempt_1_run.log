  induction i with
  | zero =>
    simp [construction];
    intro h;
    have hP i Γ' (hΓ' : ↑Γ' ⊆ construction T hT i) : Γ'.conj ⋏ χ ➝ ξ ∉ T.theory := by
      induction i generalizing Γ' with
      | zero =>
        intro hC; apply hT;
        have hG : χ ➝ Γ'.conj ∈ T.theory := by
          induction Γ' using Finset.induction_on <;> simp [*] at *;
          . apply mem_of_provable; exact verum;
          . apply T.andIR (hΓ' (by simp)) (by assumption);
        exact mem_trans (T.andIR hG (mem_of_provable Deduction.id)) hC;
      | succ i ih =>
