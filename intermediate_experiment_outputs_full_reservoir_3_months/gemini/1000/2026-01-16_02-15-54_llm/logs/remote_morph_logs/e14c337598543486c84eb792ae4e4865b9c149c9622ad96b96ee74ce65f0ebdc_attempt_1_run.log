  | zero =>
    simp [construction];
    intro h;
    have h_no_xi : ∀ i Γ, ↑Γ ⊆ construction T hT i → Γ.conj ➝ ξ ∉ T.theory := by
      intro i; induction i with
      | zero =>
        intro Γ hΓ h_conj; apply hT;
        have : χ ➝ Γ.conj ∈ T.theory := by
          induction Γ using Finset.induction <;> simp [*] at *;
          . apply mem_of_provable; exact verum;
          . apply T.andIR <;> assumption;
        exact T.imp_closed (af h_conj) this;
      | succ i ih =>
        intro Γ hΓ h_conj; dsimp [construction] at hΓ; split at hΓ <;> (try exact ih Γ hΓ h_conj);
        split_ifs at hΓ with h_if <;> (try exact ih Γ hΓ h_conj);
