lemma not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction]; intro hχφ;
    have hP : ∀ i Δ, ↑Δ ⊆ construction T hT i → Δ.conj ➝ ξ ∉ T.theory := by
      intro i Δ hΔ; induction i with
      | zero =>
        intro h; apply hT; apply mem_trans _ h;
        induction Δ using Finset.induction with
        | empty => apply mem_of_provable; simp;
        | insert δ Δ' ih' =>
          simp at hΔ; apply T.imp_closed (φ := (χ ➝ Δ'.conj) ⋏ (χ ➝ δ)) (by grind) (T.andIR (ih' hΔ.1) hΔ.2);
      | succ i ih' =>
        intro h; dsimp [construction] at hΔ; split at hΔ;
        . rename_i δ hdec; split_ifs at hΔ with hcond;
          . by_cases hδ : δ ∈ Δ;
            . apply hcond (Δ.erase δ);
              . intro x hx; have := hΔ (Finset.mem_of_mem_erase hx); simp [hdec] at this;
                rcases this with (rfl | hx); { exfalso; exact Finset.not_mem_erase _ _ hx; } { assumption; }
              . apply T.imp_closed _ h; grind;
            . apply ih' Δ;
              intro x hx; have := hΔ hx; simp [hdec] at this;
              rcases this with (rfl | hx); { exfalso; exact hδ hx; } { assumption; }
        . apply ih' Δ hΔ h;
    apply hP (encode φ) (insert φ Γ);
    . intro x hx; simp at hx; rcases hx with (rfl | hx);
      . apply monotone_construction (Nat.zero_le (encode φ)); simp [construction]; assumption;
      . apply hΓ hx;
    . apply T.imp_closed _ hφ; grind;
