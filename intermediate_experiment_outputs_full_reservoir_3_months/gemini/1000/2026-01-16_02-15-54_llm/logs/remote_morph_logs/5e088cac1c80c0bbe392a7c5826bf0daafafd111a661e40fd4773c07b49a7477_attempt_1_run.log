    simp only [Finset.mem_range]
    constructor
    · intro hk; exact Nat.lt_trans hk (Nat.lt_succ_of_le (Nat.le_add_left (n + 1) n))
    · intro hk; apply Nat.lt_of_succ_le; rw [Nat.succ_eq_add_one]; apply Nat.le_of_choose_pos
      exact_mod_cast (Nat.pos_of_choose_pos hk)
  have h_norm_m := h_norm m
  rw [h_sm, mul_zero, sub_zero] at h_norm_m
