  have h_base : c 0 = 1 ∧ s 0 = 0 := ⟨rfl, rfl⟩
  have h_step (m : ℕ) : c (m + 1) = c m + 3 * s m ∧ s (m + 1) = c m + s m := by
    constructor
    · simp [c, s, Finset.sum_range_succ, Nat.choose_succ_succ]
      rw [Finset.sum_range_succ]
      simp [Nat.choose_succ_self]
      rw [← Finset.sum_add_distrib]
      apply Finset.sum_congr rfl
      intro k _
      rw [Nat.choose_succ_succ, Nat.cast_add, add_mul, ← mul_assoc, ← pow_succ]
      cases k <;> simp [Nat.choose_zero_right]
    · simp [c, s, Finset.sum_range_succ, Nat.choose_succ_succ]
      rw [Finset.sum_range_succ]
      simp [Nat.choose_succ_self]
      rw [← Finset.sum_add_distrib]
      apply Finset.sum_congr rfl
      intro k _
      rw [Nat.choose_succ_succ, Nat.cast_add, add_mul]
  have h_norm (m : ℕ) : (c m)^2 - 3 * (s m)^2 = (-2 : ZMod 5)^m := by
    induction m with
    | zero => rfl
    | succ m ih =>
      obtain ⟨hc, hs⟩ := h_step m
      rw [hc, hs, ih]
      ring
  intro h5
  let m := 2 * n + 1
  have h_sm : s m = 0 := by
    have : (∑ k in Finset.range (n + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k) = 0 := by
      rw [← Nat.cast_sum, ← Nat.cast_mul, ← Nat.cast_zero (R := ZMod 5)]
