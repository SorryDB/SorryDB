  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let u (m : ℕ) : Zmod 5 := ∑ k in Finset.range (m + 1), (m.choose (2 * k + 1) : Zmod 5) * 3^k
  let v (m : ℕ) : Zmod 5 := ∑ k in Finset.range (m + 1), (m.choose (2 * k) : Zmod 5) * 3^k
  have hu : ∀ m, u (m + 1) = u m + v m := by
    intro m; simp [u, v, Finset.sum_range_succ, Nat.choose_succ_succ, Finset.sum_add_distrib]
  have hv : ∀ m, v (m + 1) = 3 * u m + v m := by
