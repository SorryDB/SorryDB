    intro m; obtain ⟨h1, h2⟩ := h m; simp [f, h1, h2]
  have f_6 : ∀ m, f (m + 6) = (3 * f m.1, 3 * f m.2) := by
    intro m; iterate 6 (rw [f_step]; simp; ring_nf)
  have s_6 : ∀ m, s m = 0 ↔ s (m % 6) = 0 := by
