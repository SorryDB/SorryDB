open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s : ℕ → ZMod 5 := fun n => ∑ k in Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) : ZMod 5) * 3 ^ k
  let c : ℕ → ZMod 5 := fun n => ∑ k in Finset.range (n + 1), ((2 * n + 1).choose (2 * k) : ZMod 5) * 3 ^ k
  have h (n : ℕ) : s (n + 1) = 4 * s n + 2 * c n ∧ c (n + 1) = s n + 4 * c n := by
    induction' n with n _
    · decide
    · have h1 : ∀ n k, (n + 2).choose (k + 2) = n.choose (k + 2) + 2 * n.choose (k + 1) + n.choose k := by
        intro n k; rw [Nat.choose_succ_succ, Nat.choose_succ_succ, Nat.choose_succ_succ, add_assoc, add_left_comm, ← add_assoc, ← two_mul]
      simp [s, c, h1, Finset.sum_range_succ, Finset.sum_add_distrib, Finset.mul_sum, ← Finset.sum_add_distrib]
      constructor <;>
      · apply Finset.sum_congr rfl; intro k _; ring
  have hn (n : ℕ) : s n ≠ 0 ∧ (s n = 1 ∨ s n = 2 ∨ s n = 3 ∨ s n = 4) := by
    induction' n with n ih
    · simp [s]; decide
    · rc cases ih.2 with h1 | h1 | h1 | h1 <;>
      ( have h2 := (h n).1; have h3 := (h n).2
        rcases (show c n ∈ ({0, 1, 2, 3, 4} : Set (ZMod 5)) by decide) with h4 | h4 | h4 | h4 | h4 <;>
        ( rw [h1, h4] at h2 h3; simp [h2, h3] ) )
  exact_mod_cast (hn n).1

