    rw [← Nat.mod_eq_sub_mod (Nat.not_lt.1 h_m), ← ih _ this]
    have : f m = (3 : ZMod 5) * f (m - 6) := by
      have := f_6 (m - 6); rw [Nat.sub_add_cancel (Nat.not_lt.1 h_m)] at this; exact this
    simp [f, this]
  have s_odd : ∀ m, m % 6 ∈ [1, 3, 5] → s m ≠ 0 := by
    intro m hm; rw [s_6]; revert hm; match m % 6 with
