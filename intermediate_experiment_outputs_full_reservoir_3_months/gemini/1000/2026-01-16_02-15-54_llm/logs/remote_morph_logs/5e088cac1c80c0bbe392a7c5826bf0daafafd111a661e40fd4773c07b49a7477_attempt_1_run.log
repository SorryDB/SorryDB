import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let s (n : ℕ) : ZMod 5 := ∑ k in Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) : ZMod 5) * 3 ^ k
  let a (n : ℕ) : ZMod 5 := ∑ k in Finset.range (n + 1), ((2 * n + 1).choose (2 * k) : ZMod 5) * 3 ^ k
  have h_base : s 0 = 1 ∧ a 0 = 1 := by decide
  have h_step : ∀ n, s (n + 1) = 4 * s n + 2 * a n ∧ a (n + 1) = a n + s n := by
    intro n
    let x : Zsqrtd 3 := ⟨1, 1⟩
    have hx : ∀ m, (x ^ m).re = (∑ k in Finset.range (m / 2 + 1), (m.choose (2 * k) : ZMod 5) * 3 ^ k) ∧
                  (x ^ m).im = (∑ k in Finset.range ((m - 1) / 2 + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k) := by
      intro m; induction' m with m ih
      · decide
      · obtain ⟨hre, him⟩ := ih; simp [pow_succ, Zsqrtd.mul]; constructor
        · rw [hre, him]; simp [Nat.choose_succ_succ]; rfl
        · rw [hre, him]; simp [Nat.choose_succ_succ]; rfl
    have h2n1 : ∀ m, a m = (x ^ (2 * m + 1)).re ∧ s m = (x ^ (2 * m + 1)).im := by
      intro m; have := hx (2 * m + 1); simp at this; exact this
    obtain ⟨ha1, hs1⟩ := h2n1 (n + 1); obtain ⟨ha0, hs0⟩ := h2n1 n
    rw [pow_add, pow_two] at ha1 hs1; simp [Zsqrtd.mul] at ha1 hs1; constructor
    · rw [hs1, ha0, hs0]; decide
    · rw [ha1, ha0, hs0]; decide
  have h_rec : ∀ n, n > 0 → s (n + 1) = 3 * s n + s (n - 1) := by
    intro n hn; obtain ⟨hs1, -⟩ := h_step n; obtain ⟨hs0, ha0⟩ := h_step (n - 1)
    have : n - 1 + 1 = n := Nat.sub_add_cancel hn
    rw [this] at hs0 ha0; rw [hs1, ha0]; ring
  have h_inv : ∀ n, s (n + 1)^2 - 3 * s (n + 1) * s n - s n^2 = 2 * (-1)^n := by
    intro n; induction' n with n ih
    · decide
    · rw [h_rec (n + 1) (Nat.succ_pos n), pow_succ, neg_one_mul]; linear_combination -ih
  intro h5; have hs_mod : s n = 0 := by
    rw [← ZMod.nat_cast_zmod_eq_zero_iff_prime] at h5; convert h5
    simp only [Nat.cast_sum, Nat.cast_mul, Nat.choose_cast, Nat.cast_pow]; congr; funext k
    congr 2; rw [← ZMod.nat_cast_eq_nat_cast_iff]; norm_num
  cases n with
  | zero => simp [hs_mod] at h_base
  | succ n =>
    have hq := h_inv n; rw [hs_mod] at hq; simp at hq
    have hsq : s (n + 1)^2 = 2 ∨ s (n + 1)^2 = 3 := by
      cases' n % 2 with h_even h_odd <;> simp [h_even] at hq <;> [left; right] <;> exact hq
    apply Or.elim hsq <;> intro h <;> revert h <;> decide

