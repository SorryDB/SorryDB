import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let S := ∑ k ∈ Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) : ZMod 5) * 3 ^ k
  have hS : (∑ k ∈ Finset.range (n + 1), (2 * n + 1).choose (2 * k + 1) * 2 ^ (3 * k) : ZMod 5) = S := by
    simp [S, ← pow_mul]
  rw [← CharP.cast_eq_zero_iff (ZMod 5) 5, hS]
  let a : ℕ → ZMod 5 := fun m => ∑ k in Finset.range (m + 1), (m.choose (2 * k) : ZMod 5) * 3 ^ k
  let b : ℕ → ZMod 5 := fun m => ∑ k in Finset.range (m + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k
  have hb : b (2 * n + 1) = S := by
    simp [b, S]
    apply Finset.sum_congr (by simp)
    intro k hk
    rw [Finset.mem_range] at hk
    rfl
  have hab : ∀ m, a (m + 1) = a m + 3 * b m ∧ b (m + 1) = a m + b m := by
    intro m
    constructor
    · simp [a, b, Nat.choose_succ_succ, Finset.sum_range_succ, Finset.mul_sum, ← Finset.sum_add_distrib]
      rw [Finset.sum_range_succ' _ 0]; simp
      apply Finset.sum_congr rfl
      intro k _
      rw [add_comm, mul_comm, ← Nat.choose_succ_succ, Nat.choose_succ_succ]
      rfl
    · simp [a, b, Nat.choose_succ_succ, Finset.sum_range_succ, ← Finset.sum_add_distrib]
      apply Finset.sum_congr rfl
      intro k _
      rw [add_comm, ← Nat.choose_succ_succ, Nat.choose_succ_succ]
      rfl
  have h_norm : ∀ m, (a m)^2 - 3 * (b m)^2 = (3 : ZMod 5)^m := by
    intro m; induction' m with m ih
    · simp [a, b]
    · rw [(hab m).1, (hab m).2, pow_succ]; simp [ih.symm]; ring
  intro hS0
  have h_final := h_norm (2 * n + 1)
  rw [hb, hS0] at h_final
  simp at h_final
  have h_pow3 : (3 : ZMod 5) ^ (2 * n + 1) = 3 * 4 ^ n := by rw [pow_succ, ← pow_mul]; rfl
  rw [h_pow3] at h_final
  let x := a (2 * n + 1)
  cases' (even_or_odd n) with hn hn
  · obtain ⟨k, rfl⟩ := hn; rw [pow_mul, ← pow_mul] at h_final; simp at h_final
    revert h_final; dec_trivial
  · obtain ⟨k, rfl⟩ := hn; rw [pow_add, pow_mul, ← pow_mul] at h_final; simp at h_final
    revert h_final; dec_trivial

