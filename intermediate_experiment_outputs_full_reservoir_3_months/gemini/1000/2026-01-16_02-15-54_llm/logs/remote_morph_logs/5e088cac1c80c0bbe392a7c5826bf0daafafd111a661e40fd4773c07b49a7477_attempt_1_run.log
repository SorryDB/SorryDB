      match m % 6 with | 0 => simp | 1 => simp | 2 => simp | 3 => simp | 4 => simp | 5 => simp
  have h_sum : (∑ k in Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) : Zmod 5) = u (2 * n + 1) := by
    simp [u]; apply Finset.sum_congr rfl; intro k _; rw [Nat.pow_mul]; norm_num
  rw [←Zmod.natCast_zmod_eq_zero_iff_dvd, h_sum, (h_pair (2 * n + 1)).2]
