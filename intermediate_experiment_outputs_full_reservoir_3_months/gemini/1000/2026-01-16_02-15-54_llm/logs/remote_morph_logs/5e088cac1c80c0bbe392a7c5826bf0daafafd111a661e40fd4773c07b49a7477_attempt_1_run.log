    intro m; simp only [Nat.choose_succ_succ, Nat.cast_add, Nat.cast_mul, Nat.cast_pow,
      Finset.sum_range_succ, Nat.choose_zero_succ, Nat.cast_zero, zero_mul, add_zero,
      Nat.choose_succ_self, mul_zero, ← Finset.sum_add_distrib, Finset.mul_sum]
