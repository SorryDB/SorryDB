import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd]
  let s n := ∑ k in Finset.range (2 * n + 2), (Nat.choose (2 * n + 1) (2 * k + 1) : ZMod 5) * 3 ^ k
  let c n := ∑ k in Finset.range (2 * n + 2), (Nat.choose (2 * n + 1) (2 * k) : ZMod 5) * 3 ^ k
  have succ n : s (n + 1) = 4 * s n + 2 * c n ∧ c (n + 1) = s n + 4 * c n := by
    induction n with
    | zero => simp [s, c]; rfl
    | succ n ih =>
      simp only [s, c, Finset.sum_range_succ, Nat.choose_succ_succ] at *
      simp only [Nat.choose_succ_succ]; ring
  have s_rec n : s (n + 2) = 3 * s (n + 1) + s n := by
    rcases succ (n + 1) with ⟨h1, _⟩; rcases succ n with ⟨h2, h3⟩
    rw [h1, h2, h3]; ring
  have s_nz n : s n ≠ 0 := by
    let f m := (s m, s (m + 1))
    have f_succ m : f (m + 1) = (f m).2, 3 * (f m).2 + (f m).1 := by simp [f, s_rec]
    have : f n ∈ [(1,1), (1,4), (4,3), (3,3), (3,2), (2,4), (4,4), (4,1), (1,2), (2,2), (2,3), (3,1)] := by
      induction n with
      | zero => simp [f, s, c]; rfl
      | succ n ih =>
        rcases ih with h|h|h|h|h|h|h|h|h|h|h|h <;> { rw [f_succ, h]; simp; repeat (first | left | right); rfl }
    rcases this with h|h|h|h|h|h|h|h|h|h|h|h <;> { rw [←h]; simp }
  convert s_nz n
  simp [s]
  apply Finset.sum_subset
  · simp; linarith
  · intro k _ hk; simp at hk; rw [Nat.choose_eq_zero_of_lt]; simp; linarith

