import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  apply discreteTopology_iff_isOpen_singleton_one.mpr
  have hU : IsOpen {z : Circle | 0 < (z : ℂ).re} :=
    isOpen_Ioi.preimage (Complex.continuous_re.comp continuous_subtype_val)
  have hV : IsOpen {f : M →C Circle | ∀ x, 0 < (f x : ℂ).re} :=
    isOpen_set_continuous_compact isCompact_univ hU
  refine ⟨_, hV, ?_⟩
  ext f
  simp only [Set.mem_preimage, Set.mem_setOf_eq, Set.mem_singleton_iff]
  constructor
  · rintro rfl x
    simp
  · intro hf
    ext x
    exact Circle.eq_one_of_forall_pow_re_pos fun n ↦ by rw [← map_pow]; exact hf (x ^ n)

