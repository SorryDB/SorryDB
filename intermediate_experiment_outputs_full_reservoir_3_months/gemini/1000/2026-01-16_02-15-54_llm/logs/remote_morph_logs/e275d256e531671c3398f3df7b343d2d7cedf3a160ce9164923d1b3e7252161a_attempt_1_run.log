import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  apply discreteTopology_iff_isOpen_singleton_one.mpr
  obtain ⟨U, hU, hU'⟩ := NoSmallSubgroups.exists_nhds_one_trivial_subgroup (G := Circle)
  have : {f : PontryaginDual M | ∀ x, f x ∈ U} ∈ 𝓝 (1 : PontryaginDual M) :=
    continuous_induced_dom.tendsto_nhds_one (ContinuousMap.nhds_basis_univ.mem_of_mem hU)
  filter_upwards [this] with f hf
  ext x
  have h : IsGroup (MonoidHom.mrange f.toMonoidHom : Set Circle) :=
    IsCompact.isGroup (isCompact_range f.continuous_toFun)
  exact Subgroup.mem_bot.mp (hU' (Submonoid.toSubgroup f.toMonoidHom.mrange h) (Set.range_subset_iff.mpr hf) ⟨x, rfl⟩)

end PontryaginDual
```
