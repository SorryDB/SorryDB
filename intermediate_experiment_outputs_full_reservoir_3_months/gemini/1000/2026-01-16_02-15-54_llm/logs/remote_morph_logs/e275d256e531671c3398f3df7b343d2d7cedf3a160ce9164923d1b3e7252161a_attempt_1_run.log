import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  apply discreteTopology_iff_isOpen_singleton_one.mpr
  let U := {z : Circle | 0 < (z : ℂ).re}
  have hU : IsOpen U := continuous_re.comp continuous_induced_dom |>.isOpen_preimage _ isOpen_Ioi
  have hfU : IsOpen {f : PontryaginDual M | ∀ x, f x ∈ U} :=
    continuous_induced_dom.isOpen_preimage _ (ContinuousMap.isOpen_set_cl_subset isCompact_univ hU)
  convert hfU
  ext f
  simp only [Set.mem_setOf_eq, Set.mem_singleton_iff, Set.image_univ_subset_iff]
  refine ⟨fun hf ↦ ?_, fun hf x ↦ hf.symm ▸ by simp⟩
  ext x
  let S := (f : M →* Circle).range
  let S' : Subgroup Circle := { S with inv_mem' := IsCompact.isSubgroup_of_isSubmonoid (isCompact_range f.continuous) }
  have : S' = ⊥ := Circle.subgroup_eq_bot_of_subset_re_pos S' (by rintro - ⟨y, rfl⟩; exact hf y)
  exact Subgroup.ext_iff.mp this (f x) ⟨x, rfl⟩

end PontryaginDual
```
