  apply discreteTopology_iff_isOpen_singleton_one.mpr
  let hU : IsOpen {z : Circle | 0 < (z : ℂ).re} :=
    Complex.continuous_re.comp continuous_subtype_val |>.isOpen_preimage _ isOpen_Ioi
  have hV := ContinuousMap.isOpen_gen_compact isCompact_univ hU
  have h : IsOpen {f : PontryaginDual M | ∀ x, 0 < (f x : ℂ).re} :=
    continuous_subtype_val.isOpen_preimage _ hV
  convert h
  ext f
  simp only [Set.mem_singleton_iff, Set.mem_setOf_eq, ContinuousMonoidHom.ext_iff]
  refine ⟨fun hx x ↦ by simp [hx], fun hf x ↦ ?_⟩
  apply Circle.re_pow_nonneg_iff_eq_one.mp
  intro n
  exact le_of_lt (by simpa [← map_pow] using hf (x ^ n))

