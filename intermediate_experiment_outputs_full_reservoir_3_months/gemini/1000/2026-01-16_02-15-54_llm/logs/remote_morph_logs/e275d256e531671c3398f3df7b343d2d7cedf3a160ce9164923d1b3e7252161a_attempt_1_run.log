```lean
import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  apply topologicalGroup_discreteTopology_of_isOpen_singleton_one
  let V : Set Circle := {z | 0 < (z : ℂ).re}
  have hV : IsOpen V := isOpen_lt continuous_const (Complex.continuous_re.comp continuous_subtype_val)
  have h : IsOpen {f : PontryaginDual M | ∀ x, f x ∈ V} :=
    (ContinuousMap.isOpen_set_mapsTo isCompact_univ hV).preimage
      ContinuousMonoidHom.continuous_toContinuousMap
  convert h
  ext f
  refine ⟨fun hf ↦ ?_, rintro rfl x; exact zero_lt_one⟩
  ext x
  have : f x ∈ (f : M →* Circle).range := ⟨x, rfl⟩
  rw [Circle.submonoid_eq_bot_of_subset_halfplane (f : M →* Circle).range (by rintro z ⟨y, rfl⟩; exact hf y)] at this
  exact Submonoid.mem_bot.1 this

end PontryaginDual
```
