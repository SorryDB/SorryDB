/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  rw [deriv, deriv]
  simp only [LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk',
    LinearMap.smul_apply, ContinuousLinearMap.smul_apply]
  rw [SpaceTime.distDeriv_comp_lorentz_group_action]
  simp_rw [smul_tmul, tmul_smul, smul_smul]
  conv_lhs =>
    enter [1, μ, 2, ν, 2, κ, 2, ρ]
    rw [mul_comm, ← smul_eq_mul, ← smul_eq_mul, mul_comm]
  simp_rw [← Finset.sum_smul, ← Finset.smul_sum, ← Lorentz.CoVector.smul_basis,
    ← Lorentz.Vector.smul_basis, Tensorial.smul_prod]
  rw [Finset.sum_comm]
  simp_rw [Finset.sum_comm (s := Finset.univ)]
  rfl

end DistElectromagneticPotential
```
