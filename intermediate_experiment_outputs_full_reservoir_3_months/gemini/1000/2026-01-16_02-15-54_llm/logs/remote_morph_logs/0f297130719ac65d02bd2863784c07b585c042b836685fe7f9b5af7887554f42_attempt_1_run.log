/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  simp only [deriv, LinearMap.coe_mk, ContinuousLinearMap.coe_mk', SchwartzMap.smul_apply]
  calc _
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (Λ.1 ν κ * Λ⁻¹.1 ρ μ * distDeriv ρ A (Λ⁻¹ • ε) κ) •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
      simp only [distDeriv, SchwartzMap.smul_apply, ContinuousLinearMap.smul_apply,
        Lorentz.Vector.smul_eq_sum, SpaceTime.deriv_comp_lorentz_action,
        SchwartzMap.compLorentz_apply, ContinuousLinearMap.coe_sum',
        ContinuousLinearMap.coe_smul', Finset.sum_apply, Pi.smul_apply,
        smul_eq_mul, Finset.sum_smul, Finset.mul_sum, Finset.sum_mul]
      simp_rw [mul_assoc, mul_comm (Λ⁻¹.1 _ _)]
      rfl
    _ = ∑ κ, ∑ ρ, (distDeriv ρ A (Λ⁻¹ • ε) κ) • (∑ μ, Λ⁻¹.1 ρ μ • Lorentz.CoVector.basis μ) ⊗ₜ[ℝ]
        (∑ ν, Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      simp_rw [smul_tmul, tmul_smul, smul_smul, ← tmul_sum, ← sum_tmul, ← Finset.smul_sum]
      simp only [Finset.sum_comm]
      simp only [smul_eq_mul]
      refine Finset.sum_congr rfl (fun κ _ => Finset.sum_congr rfl (fun ρ _ => ?_))
      ring
    _ = ∑ κ, ∑ ρ, (distDeriv ρ A (Λ⁻¹ • ε) κ) • (Λ • Lorentz.CoVector.basis ρ) ⊗ₜ[ℝ]
        (Λ • Lorentz.Vector.basis κ) := by
      simp_rw [Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis]
    _ = Λ • deriv A (Λ⁻¹ • ε) := by
      simp_rw [Tensorial.smul_prod, ← Finset.smul_sum, deriv]
      simp only [LinearMap.coe_mk, ContinuousLinearMap.coe_mk', Finset.sum_comm]
      rfl

end DistElectromagneticPotential
