/-!

### C.3. Equivariance of the derivative distribution

-/

@[sorryful]
lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  rw [Distribution.smul_apply]
  simp only [deriv, LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk',
    SpaceTime.distDeriv_smul]
  simp only [Lorentz.Vector.smul_eq_sum, Lorentz.Vector.apply_sum, smul_eq_mul, Finset.sum_smul,
    Finset.mul_sum, smul_tmul, tmul_smul, smul_smul, ← tmul_sum, ← sum_tmul, Finset.sum_comm,
    Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis, Tensorial.smul_prod]
  rw [← Tensorial.smulLinearMap_apply]
  simp [deriv, Finset.sum_comm]

end DistElectromagneticPotential
