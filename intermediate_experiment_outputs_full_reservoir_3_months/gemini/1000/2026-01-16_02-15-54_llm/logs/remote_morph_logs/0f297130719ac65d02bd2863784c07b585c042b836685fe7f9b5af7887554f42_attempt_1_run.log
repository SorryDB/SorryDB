/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  simp only [smul_apply, deriv, LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk',
    distDeriv, Lorentz.Vector.smul_eq_sum, ContinuousLinearMap.coe_sum', Finset.sum_apply,
    Pi.smul_apply, smul_eq_mul, ← Finset.sum_neg_distrib, ← Finset.mul_sum,
    ← A.map_sum, ← A.map_smul, ← A.map_neg]
  have h1 : ∀ μ, (fun x => ∂_ μ ε (Λ • x)) = ∑ ρ, Λ⁻¹.1 ρ μ • ∂_ ρ (fun x => ε (Λ • x)) := by
    intro μ; ext x; simp_rw [SpaceTime.deriv_comp_lorentz_action (Λ := Λ⁻¹)]
    · simp [← Finset.sum_mul, LorentzGroup.sum_Λ_mul_Λ_inv]
    · exact ε.differentiable ℝ
  simp_rw [h1, smul_tmul, tmul_smul, smul_smul, ← Finset.sum_smul, ← Finset.mul_sum,
    Finset.sum_comm, ← smul_smul, ← tmul_smul, ← smul_tmul, ← Finset.smul_sum,
    ← sum_tmul, ← tmul_sum, Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis,
    Tensorial.smul_prod, ← Tensorial.smulLinearMap_apply, Finset.sum_comm]
  rfl

end DistElectromagneticPotential
