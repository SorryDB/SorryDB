/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  simp only [deriv, ContinuousLinearMap.smul_apply, LinearMap.coe_mk, AddHom.coe_mk,
    ContinuousLinearMap.coe_mk', Pi.smul_apply]
  calc
    _ = ∑ μ, ∑ ν, (Λ • (∑ ρ, Λ⁻¹.1 ρ μ • SpaceTime.distDeriv ρ A (ε ∘ Λ))) ν •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
      simp only [SpaceTime.distDeriv_comp_lorentz_action]
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (Λ.1 ν κ * (Λ⁻¹.1 ρ μ * SpaceTime.distDeriv ρ A (ε ∘ Λ) κ)) •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
      simp only [Lorentz.Vector.smul_eq_sum, Lorentz.Vector.apply_sum, Finset.sum_smul,
        smul_smul, smul_eq_mul, mul_assoc]
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (distDeriv ρ A (ε ∘ Λ) κ) •
        (Λ⁻¹.1 ρ μ • (Lorentz.CoVector.basis μ)) ⊗ₜ[ℝ] (Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      refine Finset.sum_congr rfl (fun μ _ => ?_)
      refine Finset.sum_congr rfl (fun ν _ => ?_)
      refine Finset.sum_congr rfl (fun κ _ => ?_)
      refine Finset.sum_congr rfl (fun ρ _ => ?_)
      rw [smul_tmul, tmul_smul, tmul_smul, smul_smul, smul_smul]
      congr 1; ring
    _ = ∑ κ, ∑ ρ, (distDeriv ρ A (ε ∘ Λ) κ) • (∑ μ, Λ⁻¹.1 ρ μ • (Lorentz.CoVector.basis μ)) ⊗ₜ[ℝ]
        (∑ ν, Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      conv_lhs => enter [2, μ]; rw [Finset.sum_comm]
      conv_lhs => rw [Finset.sum_comm]
      conv_lhs => enter [2, κ, 2, μ]; rw [Finset.sum_comm]
      conv_lhs => enter [2, κ]; rw [Finset.sum_comm]
      simp_rw [sum_tmul, tmul_sum, Finset.smul_sum]
    _ = ∑ κ, ∑ ρ, (distDeriv ρ A (ε ∘ Λ) κ) • (Λ • (Lorentz.CoVector.basis ρ)) ⊗ₜ[ℝ]
        (Λ • Lorentz.Vector.basis κ) := by
      simp only [Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis]
    _ = ∑ κ, ∑ ρ, (distDeriv ρ A (ε ∘ Λ) κ) • Λ • ((Lorentz.CoVector.basis ρ) ⊗ₜ[ℝ]
        Lorentz.Vector.basis κ) := by
      simp only [Tensorial.smul_prod]
    _ = (Λ • deriv A) ε := by
      simp [deriv, ContinuousLinearMap.smul_apply, Finset.smul_sum]

end DistElectromagneticPotential
