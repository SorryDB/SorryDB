/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  simp only [SpaceTime.LorentzGroup_smul_dist_apply, deriv, LinearMap.coe_mk, AddHom.coe_mk,
    ContinuousLinearMap.coe_mk', map_sum, map_smul]
  calc _
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (Λ.1 ν κ * Λ⁻¹.1 ρ μ * distDeriv ρ A (Λ⁻¹ • ε) κ) •
        Lorentz.CoVector.basis μ ⊗ₜ[ℝ] Lorentz.Vector.basis ν := by
      simp only [SpaceTime.distDeriv_apply, SpaceTime.LorentzGroup_smul_dist_apply,
        Lorentz.Vector.smul_eq_sum, Finset.sum_apply, Pi.smul_apply, smul_eq_mul,
        SpaceTime.deriv_comp_lorentz_action, map_sum, map_smul, Finset.sum_smul]
      apply Finset.sum_congr rfl (fun μ _ => Finset.sum_congr rfl (fun ν _ => ?_))
      simp only [Finset.mul_sum, Finset.sum_mul]
      apply Finset.sum_congr rfl (fun κ _ => Finset.sum_congr rfl (fun ρ _ => ?_))
      ring
    _ = ∑ μ, ∑ ν, ∑ κ, ∑ ρ, (distDeriv ρ A (Λ⁻¹ • ε) κ) •
        (Λ⁻¹.1 ρ μ • Lorentz.CoVector.basis μ) ⊗ₜ[ℝ] (Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      simp only [smul_tmul, tmul_smul, smul_smul, smul_eq_mul]
      apply Finset.sum_congr rfl (fun μ _ => Finset.sum_congr rfl (fun ν _ => ?_))
      apply Finset.sum_congr rfl (fun κ _ => Finset.sum_congr rfl (fun ρ _ => ?_))
      congr 1; ring
    _ = ∑ κ, ∑ ρ, (distDeriv ρ A (Λ⁻¹ • ε) κ) • (∑ μ, Λ⁻¹.1 ρ μ • Lorentz.CoVector.basis μ) ⊗ₜ[ℝ]
        (∑ ν, Λ.1 ν κ • Lorentz.Vector.basis ν) := by
      simp_rw [sum_tmul, tmul_sum, Finset.smul_sum, Finset.sum_comm]
    _ = ∑ κ, ∑ ρ, (distDeriv ρ A (Λ⁻¹ • ε) κ) • (Λ • Lorentz.CoVector.basis ρ) ⊗ₜ[ℝ]
        (Λ • Lorentz.Vector.basis κ) := by
      simp only [Lorentz.CoVector.smul_basis, Lorentz.Vector.smul_basis]
    _ = Λ • deriv A (Λ⁻¹ • ε) := by
      simp only [deriv, Tensorial.smul_prod, map_sum, map_smul, LinearMap.coe_mk, AddHom.coe_mk,
        ContinuousLinearMap.coe_mk']

end DistElectromagneticPotential
