/-!

### C.3. Equivariance of the derivative distribution

-/

lemma deriv_equivariant {d} {A : DistElectromagneticPotential d}
    (Λ : LorentzGroup d) : deriv (Λ • A) = Λ • deriv A := by
  ext ε
  simp only [deriv, LinearMap.coe_mk, AddHom.coe_mk, ContinuousLinearMap.coe_mk',
    SchwartzMap.distributionAction_apply, LinearMap.smul_apply, ContinuousLinearMap.smul_apply]
  rw [SpaceTime.distDeriv_action_eq_sum]
  conv_lhs =>
    enter [2, μ, 2, ν]
    rw [Finset.sum_smul]
    enter [2, κ]
    rw [Finset.sum_smul]
  simp only [Nat.reduceSucc, smul_smul, smul_eq_mul]
  conv_lhs =>
    enter [2, μ, 2, ν, 2, κ, 2, ρ]
    rw [mul_comm, ← mul_assoc, smul_tmul, tmul_smul, tmul_smul, smul_smul, smul_smul]
  simp only [Nat.reduceSucc, mul_comm, smul_eq_mul]
  conv_lhs => enter [2, μ]; rw [Finset.sum_comm]
  rw [Finset.sum_comm]
  conv_lhs => enter [2, κ, 2, μ]; rw [Finset.sum_comm]
  conv_lhs => enter [2, κ]; rw [Finset.sum_comm]
  simp_rw [sum_tmul, tmul_sum, Finset.smul_sum, ← Lorentz.CoVector.smul_basis,
    ← Lorentz.Vector.smul_basis, Tensorial.smul_prod]
  rw [← Tensorial.smulLinearMap_apply]
  simp only [Nat.reduceSucc, Finset.sum_comm]

end DistElectromagneticPotential
