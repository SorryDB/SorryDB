def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hNI hB
    obtain ⟨MI, hMI, hIMI⟩ := hI
    obtain ⟨MB, hMB, hBMB⟩ := hB.1
    have hI_not_max : ¬ G.IsMaxMatching MI := by
      intro h_max
      apply hNI
      refine ⟨hI, fun J hJ hIJ ↦ hIJ.antisymm fun x hxJ ↦ ?_⟩
      obtain ⟨MJ, hMJ, hJMJ⟩ := hJ
      have h_MJ_le := h_max.max MJ hMJ
      sorry
    obtain ⟨P, hP⟩ := hMI.exists_isAugPath_not_max hI_not_max
    sorry
```
