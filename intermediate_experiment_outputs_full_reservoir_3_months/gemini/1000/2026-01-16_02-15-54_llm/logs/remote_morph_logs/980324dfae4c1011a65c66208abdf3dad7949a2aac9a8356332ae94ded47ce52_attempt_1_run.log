def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    use ∅
    simp [isMatching_iff]
  indep_subset := by
    rintro S T ⟨M, hM, hSM⟩ hTS
    exact ⟨M, hM, hTS.trans hSM⟩
  indep_aug := by
    intro I B hI hImax hBmax
    obtain ⟨MI, hMI, hIMI⟩ := hI
    obtain ⟨MB, hMB, hBMB⟩ := hBmax.1
    have hB_eq : V(G, MB) = B := hBmax.2 ⟨MB, hMB, subset_rfl⟩ hBMB
    have hI_nm : ∃ I', (∃ M', G.IsMatching M' ∧ I' ⊆ V(G, M')) ∧ I ⊂ I' := by
      contrapose! hImax
      exact ⟨hI, fun J hJ hIJ ↦ (hImax J hJ hIJ).antisymm hIJ⟩
    obtain ⟨I_huge, ⟨M_huge, hM_huge, hI_huge⟩, hI_sub_huge⟩ := hI_nm
    have : I.encard < B.encard := by
      rw [hB_eq]
      -- A maximal matchable set B has the same size as the vertex set of a maximum matching.
      -- A non-maximal matchable set I must have smaller size.
      sorry
    -- By the symmetric difference argument, there exists a path P in MI ∆ MB
    -- that augments MI to cover at least one more vertex from B \ I.
    sorry
