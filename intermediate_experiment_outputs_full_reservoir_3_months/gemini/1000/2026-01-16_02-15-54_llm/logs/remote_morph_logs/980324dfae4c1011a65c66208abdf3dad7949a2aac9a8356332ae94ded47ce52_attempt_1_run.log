def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    use ∅
    simp [isMatching_iff]
  indep_subset := by
    rintro I J ⟨M, hM, hJ⟩ hIJ
    exact ⟨M, hM, hIJ.trans hJ⟩
  indep_aug := by
    intro I B hI hInm hBm
    obtain ⟨MI, hMI, hIMI⟩ := hI
    obtain ⟨MB, hMB, hBMB⟩ := hBm.1
    have hB : B = V(G, MB) := hBm.2 ⟨MB, hMB, rfl.subset⟩ hBMB
    obtain ⟨J, hJ, hIJ⟩ := not_maximal_iff.mp hInm
    have : I.encard < B.encard := hIJ.2.encard_lt_encard_of_subset_of_maximal hJ hBm
    obtain ⟨x, hxB, M', hM', hIx⟩ : ∃ x ∈ B \ I, ∃ M, G.IsMatching M ∧ insert x I ⊆ V(G, M) := by
      have hMI_not_max : ¬G.IsMaxMatching MI := by
        intro hMax
        apply hInm
        refine hBm.mono hIJ.1 ⟨MI, hMI, hIMI⟩
      obtain ⟨P, hP⟩ := hMI.exists_isAugPath_not_max hMI_not_max
      let MI' := MI ∆ E(P)
      have hMI' : G.IsMatching MI' := hP.augment
      have hIMI' : V(G, MI) ⊆ V(G, MI') := hP.augment_vertex_subset
      have hx : hP.toWList.first ∉ V(G, MI) := hP.first_not_in
      have hy : hP.toWList.last ∉ V(G, MI) := hP.last_not_in
      have hxy : {hP.toWList.first, hP.toWList.last} ⊆ V(G, MI') := by
        sorry
      sorry
    exact ⟨x, hxB, M', hM', hIx⟩
