      ContinuousLinearMap.proj_apply, EuclideanSpace.single_apply, if_pos rfl, smul_eq_mul, mul_one]
    exacts [contDiff_const, (EuclideanSpace.proj 0).contDiff]
  exact (h_val v).symm.trans (hL ▸ h_val w)
