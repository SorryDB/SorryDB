space becomes a diffeological vector space with the coarse diffeology but internal tangent spaces
of coarse spaces are all trivial. -/
lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h; refine (Module.Dual.separating_points ℝ X).eq v w (fun f ↦ ?_)
  let fs := IsFineDiffeology.dsmooth_linearMap f
  let Ev : InternalTangentSpace (f x) →ₗ[ℝ] ℝ := Submodule.liftQ _ (toModule ℝ _ _ (fun p ↦ fderiv ℝ p.1.2 0)) (by
    rintro _ ⟨p, q, g, w, rfl⟩; simp [toModule_lof]
    try rw [fderiv_comp q.2.1.contDiff.differentiableAt g.2.contDiff.differentiableAt]; rfl)
  have h_ev (u : X) : Ev (internalTangentMap f x (vectorSpaceToInternalTangentSpace x u)) = f u := by
    simp [internalTangentMap, vectorSpaceToInternalTangentSpace, preInternalTangentMap, fs,
      pointedPlots_map, InternalTangentSpace.lof, toModule_lof, Submodule.liftQ_apply]
