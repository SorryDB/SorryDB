/-- The canonical map from a fine diffeological vector space to its internal tangent space at a
point is injective.

Note that this isn't the case for arbitrary diffeological vector spaces, because e.g. any vector
space becomes a diffeological vector space with the coarse diffeology but internal tangent spaces
of coarse spaces are all trivial. -/
lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h
  let b := Basis.ofVectorSpace ℝ X
  apply b.ext_elem; intro i
  let L := b.coord i
  have Ls : DSmooth L := IsFineDiffeology.dsmooth_of_linear L
  have hL := congr_arg (internalTangentMap L x) h
  let E : InternalTangentSpace (L x) →ₗ[ℝ] ℝ :=
    Submodule.liftQ _ (toModule ℝ _ _ (fun p ↦ (fderiv ℝ p.1.2 0).toLinearMap)) (by
      intro v' hv'; apply Submodule.span_induction hv'
      rintro _ ⟨p, q, f, w, rfl⟩
      simp only [LinearMap.sub_apply, toModule_lof, sub_eq_zero]
      exact (fderiv_comp 0 q.2.1 f.dsmooth.contDiff).trans (by rw [q.2.2]; rfl))
