namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · use (p - 1) / 4
    intro hp
    have h2 : p ≠ 2 := by rw [hp]; linarith
    obtain ⟨s, hs⟩ := (ZMod.exists_sq_eq_neg_one_iff p).mpr (Or.inr (by rw [hp]; norm_num))
    have hne : s ≠ -s := by
      intro h; rw [← add_eq_zero_iff_neg_eq, ← two_mul, mul_eq_zero] at h
      cases' h with h h
      · rw [ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h; exact h2 (Nat.Prime.eq_two_of_dvd h.out h)
      · rw [h] at hs; simp [ZMod.one_ne_zero p] at hs
    have : ({s, -s} : Finset (ZMod p)) = {s | s ^ 2 = -1} := by
      ext x; simp [hs, ← sq_eq_sq]
    rw [← this, Finset.card_doubleton hne]
