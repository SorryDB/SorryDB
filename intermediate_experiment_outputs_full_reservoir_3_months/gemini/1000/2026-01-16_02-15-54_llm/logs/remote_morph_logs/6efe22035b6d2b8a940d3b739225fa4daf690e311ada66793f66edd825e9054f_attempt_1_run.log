namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · use p / 4
    intro hp
    haveI : NeZero (2 : ZMod p) := ⟨by rw [hp, ZMod.nat_cast_zmod_eq_zero_iff]; intro; linarith⟩
    have : p % 4 = 1 := by rw [hp, Nat.add_mod, Nat.mul_mod_right]; rfl
    simp [ZMod.card_sq_eq, legendreSym.at_neg_one, this]
```
