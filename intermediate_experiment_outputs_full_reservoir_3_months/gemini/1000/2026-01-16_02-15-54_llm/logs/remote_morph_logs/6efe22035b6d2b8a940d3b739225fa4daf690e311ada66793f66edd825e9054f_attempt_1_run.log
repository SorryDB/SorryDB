namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · use p / 4
    intro hp
    have h1 : p % 4 = 1 := by rw [hp]; simp
    have ⟨s, hs⟩ : ∃ s : ZMod p, s ^ 2 = -1 :=
      ZMod.exists_sq_eq_neg_one_iff.mpr (by rw [h1]; norm_num)
    have hne : s ≠ -s := by
      intro h_eq
      have h2 : (2 : ZMod p) ≠ 0 := by
        intro h_zero
        have : p = 2 := (ZMod.nat_cast_zmod_eq_zero_iff_dvd 2 p).mp h_zero
        rw [this] at hp; norm_num at hp
      have : s = 0 := by
        rw [← sub_eq_zero, sub_neg_eq_add, ← two_mul] at h_eq
        exact (mul_eq_zero.mp h_eq).resolve_left h2
      simp [this] at hs; contradiction
    have : {s | s ^ 2 = -1} = {s, -s} := by
      apply Finset.ext; intro x
      simp [← hs, sq_eq_sq]
    rw [this, Finset.card_pair hne]
