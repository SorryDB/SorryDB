          case h_1 v3 h_eq_v3 =>
            rw [h_eq_v3, ←c_read3]
            simp [circuit_norm, explicit_provable_type]

            split at c_next
            case h_2 =>
              -- impossible, nextState ensures that
              -- state transition is always successful
              contradiction
            case h_1 next_state h_eq_next =>
              rw [←c_next]
              simp [explicit_provable_type, circuit_norm]

