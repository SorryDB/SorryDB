lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 < S.length := by
  induction S generalizing k
  case nil =>
    simp [after, makeCalls, initialState, isExpert] at h
    match n with
    | 0 => simp
    | 1 => simp
    | n + 2 =>
      have h0 := h 0
      have h1 := h 1
      simp [initialState] at h0 h1
      have : (0 : Fin (n + 2)) = (1 : Fin (n + 2)) := by
        cases k
        case mk val property =>
          simp [val] at h0 h1
          rw [← h0, ← h1]
      simp at this
  case cons c S IH =>
    simp at *
    sorry
```
