lemma reduce₂ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {e : Exp (ZMod p) (ZMod p)} {cs : Cs p (ZMod p)},
    e.eval = bits2num args -> (Cs.eq0 (bits2num_e args - e) cs).eval = cs.eval := by
