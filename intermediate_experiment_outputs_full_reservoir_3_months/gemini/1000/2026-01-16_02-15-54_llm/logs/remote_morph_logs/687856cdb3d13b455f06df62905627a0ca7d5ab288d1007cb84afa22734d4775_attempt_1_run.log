  let f (u : V) (p : P) : ℝ := ⟪u, (p -ᵥ (0 : P))⟫
  have h_S_nonempty : S.Nonempty := by rw [← Finset.card_pos, hS]; exact Nat.zero_lt_of_lt hn
  let g (u : V) := (S.image (f u)).sort (· ≤ ·)
  let max_gap (u : V) := (List.zipWith (fun x y ↦ y - x) (g u) (g u).tail).max
  have : ∃ u : V, norm u = 1 ∧ (n : ℝ) ^ (-1 / 3 : ℝ) / 8 ≤ (max_gap u).getD 0 := sorry
  obtain ⟨u, hu, h_gap⟩ := this
  let gaps := List.zipWith (fun x y ↦ y - x) (g u) (g u).tail
  have h_gaps_len : gaps.length = n - 1 := sorry
  have h_gaps_max : (gaps.max).getD 0 ≥ (n : ℝ) ^ (-1 / 3 : ℝ) / 8 := h_gap
  obtain ⟨i, hi, h_gi⟩ := List.mem_iff_get.1 (List.max_mem (by rw [h_gaps_len]; exact Nat.sub_pos_of_lt hn))
