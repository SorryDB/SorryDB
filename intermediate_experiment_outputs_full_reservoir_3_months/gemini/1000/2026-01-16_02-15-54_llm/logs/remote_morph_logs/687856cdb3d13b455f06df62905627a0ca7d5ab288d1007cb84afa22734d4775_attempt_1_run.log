import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, by norm_num
  intros n hn S hS hsep
  let d : ℝ := (n : ℝ) ^ (-1 / 3 : ℝ)
  let f (v : V) : ℝ := (S.image (fun p ↦ inner ℝ v (p -ᵥ S.arbitrary))).max.getD 0 -
                       (S.image (fun p ↦ inner ℝ v (p -ᵥ S.arbitrary))).min.getD 0
  let gaps (v : V) : Finset ℝ :=
    let projections := (S.image (fun p ↦ inner ℝ v (p -ᵥ S.arbitrary))).sort (· ≤ ·)
    (Finset.range (n - 1)).image (fun i ↦ projections.get ⟨i + 1, by
      have : projections.length = n := by rw [List.length_sort, Finset.length_image_of_pairwise_distinct]; exact hS; intros x hx y hy hxy; exact (hsep (Finset.mem_coe.1 hx) (Finset.mem_coe.1 hy) hxy).ne
      omega⟩ - projections.get ⟨i, by
      have : projections.length = n := by rw [List.length_sort, Finset.length_image_of_pairwise_distinct]; exact hS; intros x hx y hy hxy; exact (hsep (Finset.mem_coe.1 hx) (Finset.mem_coe.1 hy) hxy).ne
      omega⟩)
  have h_S_ne : S.Nonempty := by rw [← Finset.card_pos, hS]; exact Nat.zero_lt_of_lt hn
