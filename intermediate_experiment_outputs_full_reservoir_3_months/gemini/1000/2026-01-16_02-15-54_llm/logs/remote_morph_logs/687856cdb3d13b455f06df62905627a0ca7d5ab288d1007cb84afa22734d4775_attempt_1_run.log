import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  use (1 / 32 : ℝ), by norm_num
  intro n hn S hS hdist
  let c := (1 / 32 : ℝ)
  let r := c * (n : ℝ) ^ (-1 / 3 : ℝ)
  let directions := {v : V | ‖v‖ = 1}
  have hS_pos : 0 < S.card := by rw [hS]; exact Nat.zero_lt_of_lt hn
  have hS_nonempty : S.Nonempty := Finset.card_pos.mp hS_pos
  let gap (v : V) := (S.image (fun p ↦ inner v (p -ᵥ Classical.choice hS_nonempty) : ℝ)).sort (· ≤ ·)
  let max_gap (v : V) := (List.zipWith (fun a b ↦ b - a) (gap v) (gap v).tail).max.getD 0
  have : ∃ v ∈ directions, 2 * r ≤ max_gap v := by
    by_contra! h_max
    let bad_measure := (S.offDiag.sum (fun (pq : P × P) ↦ 4 * r / dist pq.1 pq.2))
    have : bad_measure < Real.pi := sorry
    exact this.not_le (sorry)
  obtain ⟨v, hv_unit, h_gap⟩ := this
  let g := gap v
  let diffs := List.zipWith (fun a b ↦ b - a) g g.tail
  obtain ⟨i, hi_gap⟩ : ∃ i, (g.get? (i + 1)).getD 0 - (g.get? i).getD 0 = max_gap v := sorry
  let midpoint := ((g.get? i).getD 0 + (g.get? (i + 1)).getD 0) / 2
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (Classical.choice hS_nonempty +ᵥ midpoint • v) (Submodule.span ℝ {v}).orthogonal
  refine ⟨by sorry, ⟨?_, ?_⟩, ?_⟩
  · obtain ⟨p1, p2, hp1, hp2, h_sep⟩ := sorry
    exact ⟨p1, p2, hp1, hp2, h_sep⟩
  · intro p hp
    have : Metric.infDist p l = |inner v (p -ᵥ Classical.choice hS_nonempty) - midpoint| := sorry
    rw [this]
    sorry

