import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  refine ⟨1 / 8, by norm_num, fun {n} hn S hS hdist ↦ ?_⟩
  let m := (n : ℝ) ^ (1 / 3 : ℝ)
  let θs := (Finset.range (Nat.ceil (Real.pi * m))).map ⟨fun k ↦ (k : ℝ) * Real.pi / (Nat.ceil (Real.pi * m)), fun _ _ h ↦ by norm_cast at h⟩
  have ⟨v, hv, h_gap⟩ : ∃ v : V, ‖v‖ = 1 ∧ ∃ i, ∃ x_gap, ∀ p ∈ S, 1 / 4 * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ |inner v (p -ᵥ (S.choose (fun _ ↦ True) (S.nonempty_of_ne_empty (by intro h; rw [h, Finset.card_empty] at hS; linarith)))) - x_gap| := by
    classical
    let p0 := S.choose (fun _ ↦ True) (S.nonempty_of_ne_empty (by intro h; rw [h, Finset.card_empty] at hS; linarith))
    let f (v : V) (p : P) : ℝ := inner v (p -ᵥ p0)
    let max_gap (v : V) := (S.image (f v)).sort (· ≤ ·)
    have : ∀ v, ‖v‖ = 1 → ∃ i < n - 1, (max_gap v).nthLe (i + 1) (by simp; linarith) - (max_gap v).nthLe i (by simp; linarith) ≥ (1 / 4) * (n : ℝ) ^ (-1 / 3 : ℝ) := sorry
    sorry
  obtain ⟨v, hv, i, x_gap, hx⟩ := h_gap
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (S.choose (fun _ ↦ True) (S.nonempty_of_ne_empty (by intro h; rw [h, Finset.card_empty] at hS; linarith)) +ᵥ x_gap • v) (InnerProductSpace.orthogonal  spanℝ {v})
  use l
  constructor
  · have hdir : l.direction = InnerProductSpace.orthogonal (span ℝ {v}) := rfl
    rw [hdir, finrank_orthogonal_span_singleton hv, Fact.out]
  · constructor
    · sorry
    · intro p hp
      have hdist : Metric.infDist p l = |inner v (p -ᵥ (S.choose (fun _ ↦ True) (S.nonempty_of_ne_empty (by intro h; rw [h, Finset.card_empty] at hS; linarith)) +ᵥ x_gap • v))| := sorry
      rw [hdist]
      simp [inner_sub_right, inner_smul_right, hv]
      exact hx p hp

