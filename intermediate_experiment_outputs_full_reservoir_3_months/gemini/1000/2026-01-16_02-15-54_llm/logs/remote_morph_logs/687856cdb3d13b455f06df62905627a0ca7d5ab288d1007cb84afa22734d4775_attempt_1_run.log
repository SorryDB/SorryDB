import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, by norm_num
  intro n hn S hS hdist
  let R := (4 * (n : ℝ) ^ (2 / 3 : ℝ))
  let d_max := (S : Set P).Pairwise fun x y ↦ dist x y
  let diam := iSup fun x : S ↦ iSup fun y : S ↦ dist (x : P) (y : P)
  have : ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
    (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
    ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
    by_cases h_diam : diam ≥ R
    · obtain ⟨p1, p2, hp1, hp2, h_dist12⟩ := exists_mem_convexhull_nndist_le S hS
      sorry
    · sorry
  sorry
