import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c
  constructor
  · norm_num
  intros n hn S hS hsep
  let r := (n : ℝ) ^ (-1 / 3 : ℝ)
  let f (v : V) := (S.image (fun p ↦ inner (p -ᵥ S.choose (Finset.card_pos.mp (by omega))) v)).max' (by simp [hS, hn]) -
    (S.image (fun p ↦ inner (p -ᵥ S.choose (Finset.card_pos.mp (by omega))) v)).min' (by simp [hS, hn])
  obtain ⟨v, hv⟩ : ∃ v : V, ‖v‖ = 1 := by
    obtain ⟨w, hw⟩ := (finrank_eq_two_iff ℝ V).mp Fact.out
    use w / ‖w‖; simp [hw]
  let proj (v : V) (p : P) : ℝ := inner (p -ᵥ S.choose (Finset.card_pos.mp (by omega))) v
  let S' (v : V) := (S.image (proj v)).sort (≤)
  have hS' (v : V) : (S' v).length = n := by simp [S', hS]
  let gaps (v : V) := (List.range (n - 1)).map (fun i ↦ (S' v).get ⟨i + 1, by omega⟩ - (S' v).get ⟨i, by omega⟩)
  have h_gaps (v : V) : (gaps v).sum = (S' v).getLast (by omega) - (S' v).head (by omega) := by
    apply List.sum_range_induction; intros; rfl; intros; simp; ring
  obtain ⟨v_opt, hv_opt, i_opt, hi_opt⟩ : ∃ v : V, ‖v‖ = 1 ∧ ∃ i < n - 1, (S' v).get ⟨i + 1, by omega⟩ - (S' v).get ⟨i, by omega⟩ ≥ 2 * c * r := by
    sorry -- The core geometric estimate of IMO 2020 P6
  let mid_proj := ((S' v_opt).get ⟨i_opt + 1, by omega⟩ + (S' v_opt).get ⟨i_opt, by omega⟩) / 2
  let l : AffineSubspace ℝ P := { p | proj v_opt p = mid_proj }
  use l
  constructor
  · sorry -- finrank ℝ l.direction = 1
  constructor
  · obtain ⟨p1, hp1, hproj1⟩ := (Finset.mem_image).mp (List.mem_iff_get.mpr ⟨⟨i_opt, by omega⟩, rfl⟩)
    obtain ⟨p2, hp2, hproj2⟩ := (Finset.mem_image).mp (List.mem_iff_get.mpr ⟨⟨i_opt + 1, by omega⟩, rfl⟩)
    use p1, p2, hp1, hp2
    sorry -- l.SOppSide p1 p2
  · intro p hp
    sorry -- c * n^(-1/3) ≤ Metric.infDist p l
