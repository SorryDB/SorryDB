import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c, (by norm_num)
  intro n hn S hS hS_sep
  let v : V := Classical.choose (Set.exists_mem_of_nonempty (V := V) (Set.nonempty_of_finrank_pos (by rw [Fact.out (p := finrank ℝ V = 2)]; norm_num)))
  let p₀ : P := S.choose (Finset.nonempty_of_ne_empty (by rintro rfl; simp at hS; linarith))
  let proj (p : P) : ℝ := inner v (p -ᵥ p₀)
  let S_proj := S.image proj
  let L := (S_proj.max' (by simpa using Finset.nonempty_of_ne_empty (by rintro rfl; simp at hS; linarith))) - (S_proj.min' (by simpa using Finset.nonempty_of_ne_empty (by rintro rfl; simp at hS; linarith)))
  let d := c * (n : ℝ) ^ (-1 / 3 : ℝ)
  have : ∃ (l : AffineSubspace ℝ P), finrank ℝ l.direction = 1 ∧ (∃ p1 p2, p1 ∈ S ∧ p2 ∈ S ∧ l.SOppSide p1 p2) ∧ ∀ p ∈ S, d ≤ Metric.infDist p l := by
    let directions := {u : V | ‖u‖ = 1}
    let gap (u : V) := (S.image (fun p ↦ inner u (p -ᵥ p₀))).sort (· ≤ ·)
    let max_gap (u : V) := (List.range (n - 1)).map (fun i ↦ (gap u).get ⟨i + 1, by linarith⟩ - (gap u).get ⟨i, by linarith⟩)
    let best_gap (u : V) := (max_gap u).maximum?.getD 0
    have h_cont : ContinuousOn (fun u ↦ best_gap u) directions := by sorry
    have h_comp : IsCompact directions := isCompact_sphere 0 1
    obtain ⟨u, hu_mem, hu_max⟩ := h_comp.exists_isMaxOn (by simpa using (Nonempty.intro (Set.nonempty_of_finset_image _ (by simpa using hn.le)))) h_cont
    let u_unit : V := u
    let g := best_gap u_unit
    have hg : 2 * d ≤ g := by sorry
    obtain ⟨i, hi⟩ : ∃ i < n - 1, (gap u_unit).get ⟨i + 1, by linarith⟩ - (gap u_unit).get ⟨i, by linarith⟩ = g := by sorry
    let mid := ((gap u_unit).get ⟨i + 1, by linarith⟩ + (gap u_unit).get ⟨i, by linarith⟩) / 2
    let l : AffineSubspace ℝ P := AffineSubspace.mk' p₀ (ContinuousLinearMap.ker (InnerProductSpace.toDual ℝ V u_unit)) (by
      rw [finrank_direction_toDual_ker]; exact Fact.out (p := finrank ℝ V = 2))
    use l
    refine ⟨by rw [finrank_direction_toDual_ker]; exact Fact.out (p := finrank ℝ V = 2), ?_, ?_⟩
    · obtain ⟨p1, hp1_S, hp1_gap⟩ := Finset.mem_image.1 (Finset.sort_mem (gap u_unit) ⟨i, by linarith⟩)
      obtain ⟨p2, hp2_S, hp2_gap⟩ := Finset.mem_image.1 (Finset.sort_mem (gap u_unit) ⟨i + 1, by linarith⟩)
      use p1, p2, hp1_S, hp2_S
      sorry
    · intro p hp
      rw [Metric.infDist_affineSubspace_mk' p₀]
      · have : |inner u_unit (p -ᵥ p₀) - mid| ≥ g / 2 := by sorry
        exact this.trans (by linarith)
      · rwa [hu_mem]
  exact this
