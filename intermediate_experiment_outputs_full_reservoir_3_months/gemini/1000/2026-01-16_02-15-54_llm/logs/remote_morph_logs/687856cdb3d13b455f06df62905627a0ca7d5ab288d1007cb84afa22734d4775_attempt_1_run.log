import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  use 3⁻¹ / 2
  refine ⟨by positivity, fun {n} hn S hS hdist ↦ ?_⟩
  have hS_nonempty : S.Nonempty := by rw [← Finset.card_pos, hS]; exact Nat.pos_of_gt hn
  let hull := convexHull ℝ (S : Set P)
  have h_compact : IsCompact hull := S.isCompact_convexHull
  let directions := {v : V | ‖v‖ = 1}
  have h_dirs_compact : IsCompact directions := isCompact_unit_sphere
  let f (v : V) := (S.image (fun p ↦ inner (p -ᵥ (S.anyP hS_nonempty)) v)).sort (≤)
  let gap (v : V) := (List.zipWith (fun x y ↦ y - x) (f v) (f v).tail).max.getD 0
  have : ∃ v ∈ directions, ∃ i, (gap v) / 2 ≥ (3⁻¹ / 2) * (n : ℝ) ^ (-1 / 3 : ℝ) := by sorry
  obtain ⟨v, hv, i, hgap⟩ := this
  let a := ((f v).get? i).getD 0 + (gap v) / 2
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (S.anyP hS_nonempty) (ℝ ∙ v)ᗮ a
  refine ⟨l, ?_, ?_, ?_⟩
  · rw [AffineSubspace.direction_mk', Submodule.finrank_orthogonal_span_singleton hv.1]
    exact Fact.out (finrank ℝ V = 2).symm.trans (by simp)
    sorry
  · sorry
  · sorry
