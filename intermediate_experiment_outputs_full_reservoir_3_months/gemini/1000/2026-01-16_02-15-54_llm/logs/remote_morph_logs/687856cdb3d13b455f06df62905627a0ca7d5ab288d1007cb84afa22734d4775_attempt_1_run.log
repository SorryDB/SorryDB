theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  refine ⟨1 / 8, by norm_num, fun {n} hn S hS hdist ↦ ?_⟩
  let D := Finset.sup (Finset.product S S) (fun (p, q) ↦ dist p q)
  have hS_nonempty : S.Nonempty := by rw [← Finset.card_pos]; exact Nat.lt_trans (by norm_num) hn
  obtain ⟨⟨p_max1, p_max2⟩, _, hD⟩ : ∃ x ∈ Finset.product S S, dist x.1 x.2 = D :=
    Finset.exists_mem_eq_sup _ (S.product_nonempty_iff.mpr hS_nonempty) _
  by_cases hD_large : D ≥ (n : ℝ) ^ (2 / 3 : ℝ)
  · obtain ⟨v⟩ : ∃ v : V, ‖v‖ = 1 := exists_norm_eq_one ℝ V
    let proj (p : P) : ℝ := inner v (p -ᵥ p_max1)
    let sorted := (S.image proj).sort (· ≤ ·)
    have h_card : (S.image proj).card ≤ n := (Finset.card_image_le.trans_eq hS)
    obtain ⟨i, hi, hgap⟩ : ∃ i < (S.image proj).card - 1, sorted.get ⟨i + 1, by omega⟩ - sorted.get ⟨i, by omega⟩ ≥ D / (n - 1) := by
      sorry
    sorry
  · sorry
