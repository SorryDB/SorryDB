import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  refine ⟨1 / 32, by norm_num, fun {n} hn S hS hS_dist ↦ ?_⟩
  let f (v : V) : ℝ := (S.image (fun p ↦ inner v (p -ᵥ (Classical.arbitrary P) : V))).sup id -
    (S.image (fun p ↦ inner v (p -ᵥ (Classical.arbitrary P) : V))).inf id
  let directions := {v : V | ‖v‖ = 1}
  have h_diam : ∃ v ∈ directions, f v ≥ Real.sqrt n / 2 := by
    sorry
  obtain ⟨v, hv, h_f⟩ := h_diam
  let projections := S.image (fun p ↦ inner v (p -ᵥ (Classical.arbitrary P) : V))
  let sorted := projections.sort (· ≤ ·)
  have h_sorted_len : sorted.length = n := by
    rw [List.length_sort, projections.card_image_of_injOn, hS]
    intro x hx y hy hxy
    sorry
  have h_gap : ∃ i : ℕ, i < n - 1 ∧ sorted.get ⟨i + 1, by sorry⟩ - sorted.get ⟨i, by sorry⟩ ≥ 2 * (1 / 32) * (n : ℝ) ^ (-1 / 3 : ℝ) := by
    sorry
  obtain ⟨i, hi, hg⟩ := h_gap
  let mid := (sorted.get ⟨i, by sorry⟩ + sorted.get ⟨i + 1, by sorry⟩) / 2
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (Classical.arbitrary P +ᵥ (mid • v)) (Submodule.span ℝ {v}).orthogonal
  use l
  constructor
  · rw [AffineSubspace.direction_mk', Submodule.finrank_orthogonal]
    · rw [Fact.out (p := finrank ℝ V = 2), Submodule.finrank_span_singleton]
      · norm_num
      · intro hv0; rw [hv0, norm_zero] at hv; norm_num at hv
  · constructor
    · sorry
    · intro p hp
      sorry
