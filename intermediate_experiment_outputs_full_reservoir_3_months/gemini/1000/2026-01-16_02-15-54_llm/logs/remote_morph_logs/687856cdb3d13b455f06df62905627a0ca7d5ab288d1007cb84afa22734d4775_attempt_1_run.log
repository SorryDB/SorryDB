import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := 1 / 32
  use c
  constructor
  · norm_num
  · intro n hn S hS hSep
    let R : ℝ := (n : ℝ) ^ (1 / 3 : ℝ)
    let k : ℕ := ⌈8 * R⌉₊
    have hk : 0 < k := by
      refine Nat.ceil_pos.mpr (mul_pos (by norm_num) (Real.rpow_pos_of_pos (by linarith) _))
    let directions : Finset V := Finset.image (fun i : ℕ ↦ 
      let θ := (i : ℝ) * Real.pi / k
      (Real.cos θ • Classical.choice (Fact.out (finrank ℝ V = 2) : Nonempty (Basis (Fin 2) ℝ V))) 0 + 
      (Real.sin θ • Classical.choice (Fact.out (finrank ℝ V = 2) : Nonempty (Basis (Fin 2) ℝ V))) 1) (Finset.range k)
    let proj (u : V) (p : P) : ℝ := inner u (p -ᵥ (S.choose (fun _ ↦ True) (by linarith [hS])))
    have exists_gap : ∃ u ∈ directions, ∃ (i : ℕ), i < n - 1 ∧ 
      let sorted := (S.toAntidiagonal.image (fun p ↦ proj u p)).sort (· ≤ ·)
      sorted.nth (i + 1) - sorted.nth i ≥ 2 * c * (n : ℝ) ^ (-1 / 3 : ℝ) := sorry
    rcases exists_gap with ⟨u, hu, i, hi, h_gap⟩
    let sorted := (S.toAntidiagonal.image (fun p ↦ proj u p)).sort (· ≤ ·)
    let mid := (sorted.nth i + sorted.nth (i + 1)) / 2
    let l : AffineSubspace ℝ P := {
      carrier := {p | proj u p = mid}
      direction := Submodule.orthogonal (Submodule.span ℝ {u})
      nonempty := sorry
      direction_ae := sorry
    }
    use l
    refine ⟨sorry, ⟨sorry, sorry, sorry⟩, fun p hp ↦ sorry⟩
