import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  refine ⟨1 / 32, by norm_num, fun hn S hS hdist ↦ ?_⟩
  let r := (n : ℝ) ^ (-1 / 3 : ℝ) / 32
  let directions := (Finset.range (n + 1)).map ⟨fun i ↦ (i : ℝ) * Real.pi / (n + 1), fun _ _ h ↦ by simp at h; exact h⟩
  have : ∃ v : V, norm v = 1 ∧ ∃ (gap : ℝ) (p₁ p₂ : P), p₁ ∈ S ∧ p₂ ∈ S ∧ 2 * r ≤ gap ∧ 
    ∀ p ∈ S, r ≤ |inner v (p -ᵥ p₁)| ∧ (inner v (p₂ -ᵥ p₁) < 0 → inner v (p -ᵥ p₁) < -r ∨ r < inner v (p -ᵥ p₁)) := by
    sorry
  obtain ⟨v, hv, gap, p1, p2, hp1, hp2, hgap, hS⟩ := this
  let l : AffineSubspace ℝ P := AffineSubspace.mk' p1 (Submodule.orthogonal (Subspace.span ℝ {v}))
  use l
  refine ⟨?_, ?_, ?_⟩
  · have h_dim := finrank_orthogonal (Subspace.span ℝ {v})
    rw [finrank_span_singleton (ne_zero_of_mem_unit_sphere ⟨v, hv⟩)] at h_dim
    rw [Fact.out (p := finrank ℝ V = 2)] at h_dim
    exact Nat.succ_inj.mp h_dim
  · use p1, p2, hp1, hp2
    rw [AffineSubspace.sOppSide_mk'_iff]
    · use -inner v (p2 -ᵥ p1)
      simp
      sorry
    · rw [Submodule.mem_orthogonal]
      intro w hw
      obtain ⟨k, rfl⟩ := Subspace.mem_span_singleton.mp hw
      simp [inner_smul_left, hv]
  · intro p hp
    rw [Metric.infDist_affineSubspace_mk' p1 (Submodule.orthogonal (Subspace.span ℝ {v})) p]
    have hv_nz : v ≠ 0 := ne_zero_of_mem_unit_sphere ⟨v, hv⟩
    let proj := orthogonalProjection (Subspace.span ℝ {v}) (p -ᵥ p1)
    have h_proj : proj = (inner v (p -ᵥ p1)) • v := by
      rw [orthogonalProjection_span_singleton v (p -ᵥ p1)]
      simp [hv]
    rw [h_proj, norm_smul, hv, mul_one]
    apply (hS p hp).1
