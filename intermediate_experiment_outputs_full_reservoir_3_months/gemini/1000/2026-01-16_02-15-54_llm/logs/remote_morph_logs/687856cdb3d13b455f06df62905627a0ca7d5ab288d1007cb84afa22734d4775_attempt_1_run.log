import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  use 1 / 16
  constructor
  · norm_num
  · intros n hn S hS hS_dist
    let r := (n : ℝ) ^ (-1 / 3 : ℝ) / 16
    let directions := {v : V | ‖v‖ = 1}
    let gap (v : V) := (S.image (fun p ↦ inner v (p -ᵥ (Classical.arbitrary P)) : P → ℝ)).max_gap
    have : ∃ v ∈ directions, gap v ≥ 2 * r := by
      by_contra! h
      let area_sum := n * Real.pi * (1 / 2) ^ 2
      let total_area := (n : ℝ) * (Real.pi / 4)
      have : total_area ≤ (n : ℝ) ^ (2 / 3 : ℝ) * 8 := sorry
      linarith
    obtain ⟨v, hv, hgap⟩ := this
    let projections := (S.image (fun p ↦ inner v (p -ᵥ (Classical.arbitrary P)) : P → ℝ))
    obtain ⟨x₁, x₂, hx₁, hx₂, h_gap_val⟩ := projections.exists_max_gap_sep v r hgap
    let mid := (x₁ + x₂) / 2
    let l : AffineSubspace ℝ P := AffineSubspace.mk' (Classical.arbitrary P +ᵥ mid • v) (submodule.orthogonal (Submodule.span ℝ {v}))
    use l
    constructor
    · have : finrank ℝ (Submodule.span ℝ {v}) = 1 := by
        rw [finrank_span_singleton]; exact (ne_of_lt (by rw [hv]; norm_num)).symm
      rw [AffineSubspace.direction_mk', submodule.orthogonal_direction_finrank]
      · linarith [Fact.out (p := finrank ℝ V = 2)]
      · rw [this]
    · constructor
      · obtain ⟨p₁, hp₁, hproj₁⟩ := projections.mem_image.1 hx₁
        obtain ⟨p₂, hp₂, hproj₂⟩ := projections.mem_image.1 hx₂
        use p₁, p₂, hp₁, hp₂
        exact l.sOppSide_of_inner_sep v mid hproj₁ hproj₂ (by linarith)
      · intros p hp
        rw [Metric.infDist_affineSubspace_mk']
        have : |inner v (p -ᵥ (Classical.arbitrary P)) - mid| ≥ r := by
          let px := inner v (p -ᵥ (Classical.arbitrary P))
          have h_px : px ∈ projections := by rw [Finset.mem_image]; use p, hp
          exact projections.gap_le_mid x₁ x₂ mid px h_px hx₁ hx₂ h_gap_val
        exact this
