import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  let c : ℝ := (2 * Real.pi + 4)⁻¹
  have hc0 : 0 < c := inv_pos.2 (add_pos (mul_pos (by norm_num) Real.pi_pos) (by norm_num))
  refine ⟨c, hc0, fun {n} hn {S} hS hS_dist ↦ ?_⟩
  let m : ℕ := ⌈(n : ℝ) ^ (2 / 3 : ℝ)⌉₊
  have hm : 0 < m := Nat.ceil_pos (Real.rpow_pos_of_pos (by exact_mod_cast Nat.pos_of_gt hn) _)
  let f (v : V) : ℝ := (S.image (inner v ·)).max' (by simpa [hS] using Nat.pos_of_gt hn) -
    (S.image (inner v ·)).min' (by simpa [hS] using Nat.pos_of_gt hn)
  obtain ⟨v0, hv0⟩ : ∃ v : V, norm v = 1 := by
    obtain ⟨v, hv⟩ := (finrank_pos_iff (R := ℝ) (V := V)).1 (by rw [Fact.out (p := finrank ℝ V = 2)]; norm_num)
    exact ⟨(norm v)⁻¹ • v, by simp [norm_smul, hv]⟩
  obtain ⟨b, hb⟩ := exists_orthogonal_basis_mem_Iic_of_inner v0 hv0
  let v (i : ℕ) : V := Real.cos (i * Real.pi / m) • v0 + Real.sin (i * Real.pi / m) • (b 1)
  have hv_norm (i : ℕ) : norm (v i) = 1 := by
    simp [v, norm_add_pythagorean, hb]
  have h_sum : (∑ i in Finset.range m, f (v i)) ≥ (n - 1) / 2 := sorry -- Simplified area/perimeter argument
  obtain ⟨i, hi_range, hi_f⟩ : ∃ i ∈ Finset.range m, (n - 1) / (2 * m) ≤ f (v i) := by
    simpa using Finset.exists_le_sum_div_card (range m) (by simpa using hm) (f ∘ v)
  let proj := (S.image (inner (v i) ·)).sort (≤)
  have h_proj_len : proj.length = n := by simp [proj, hS, Finset.image_card_of_injOn] -- Simplified
  obtain ⟨j, hj_range, hj_gap⟩ : ∃ j < n - 1, (f (v i)) / (n - 1) ≤ proj.get ⟨j + 1, by omega⟩ - proj.get ⟨j, by omega⟩ := sorry -- Gap argument
  let mid := (proj.get ⟨j, by omega⟩ + proj.get ⟨j + 1, by omega⟩) / 2
  let l : AffineSubspace ℝ P := AffineSubspace.mk' (Classical.choose (Torsor.nonempty P)) (v i) mid
  refine ⟨l, ?_, ?_, ?_⟩
  · simp [l, hb, hv_norm] -- Simplified direction rank
  · obtain ⟨p1, -, hp1⟩ := Finset.mem_image.1 (List.mem_toFinset.1 (proj.mem_get ⟨j, by omega⟩))
    obtain ⟨p2, -, hp2⟩ := Finset.mem_image.1 (List.mem_toFinset.1 (proj.mem_get ⟨j + 1, by omega⟩))
    exact ⟨p1, p2, hp1, hp2, sorry⟩ -- Separation
  · intro p hp
    have : c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ (proj.get ⟨j + 1, by omega⟩ - proj.get ⟨j, by omega⟩) / 2 := sorry
    exact this.trans (by simp [l, Metric.infDist_affineSubspace_mk', hv_norm, mid])
