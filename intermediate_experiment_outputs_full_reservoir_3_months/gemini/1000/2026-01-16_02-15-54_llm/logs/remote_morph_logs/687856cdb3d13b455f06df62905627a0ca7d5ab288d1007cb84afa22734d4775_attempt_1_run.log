import Mathlib


open scoped Finset
open Module

namespace IMO2020P6

variable {V P : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace P]
variable [NormedAddTorsor V P] [Fact (finrank ℝ V = 2)]

theorem result : ∃ c : ℝ, 0 < c ∧ ∀ {n : ℕ}, 1 < n → ∀ {S : Finset P}, #S = n →
    ((S : Set P).Pairwise fun x y ↦ 1 ≤ dist x y) →
    ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧
      ∀ p ∈ S, c * (n : ℝ) ^ (-1 / 3 : ℝ) ≤ Metric.infDist p l := by
  use 1 / 32, by norm_num
  intro n hn S hS hdist
  let R := (n : ℝ) ^ (-1 / 3 : ℝ) / 32
  let directions := {v : V | ‖v‖ = 1}
  have : S.Nonempty := by rw [← Finset.card_pos, hS]; exact Nat.zero_lt_of_lt hn
  have : ∃ v : V, ‖v‖ = 1 ∧ ∃ l : AffineSubspace ℝ P, finrank ℝ l.direction = 1 ∧
      (∃ p₁ p₂, p₁ ∈ S ∧ p₂ ∈ S ∧ l.SOppSide p₁ p₂) ∧ ∀ p ∈ S, R ≤ Metric.infDist p l := by
    let f (v : V) := (S.image (fun p => inner v (p -ᵥ (0 : P)) : ℝ)).sort (· ≤ ·)
    let max_gap (v : V) := (List.zipWith (fun a b => b - a) (f v) (f v).tail).max.getD 0
    have h_avg : ∃ v, ‖v‖ = 1 ∧ 2 * R ≤ max_gap v := sorry
    obtain ⟨v, hv, hg⟩ := h_avg
    let sorted_projs := f v
    have : sorted_projs.length = n := by rw [← hS, ← Finset.card_image_of_injective]; sorry; sorry
    obtain ⟨i, hi, h_gap⟩ := List.exists_mem_zipWith_of_max_eq hg
    let d := (sorted_projs.get ⟨i, hi⟩ + sorted_projs.get ⟨i + 1, by sorry⟩) / 2
    let l : AffineSubspace ℝ P := AffineSubspace.mk' (vLine V P (0 : P) v) (d • v +ᵥ (0 : P))
    use v, hv, l; sorry
  obtain ⟨v, hv, l, hl1, hl2, hl3⟩ := this
  use l, hl1, hl2, hl3
