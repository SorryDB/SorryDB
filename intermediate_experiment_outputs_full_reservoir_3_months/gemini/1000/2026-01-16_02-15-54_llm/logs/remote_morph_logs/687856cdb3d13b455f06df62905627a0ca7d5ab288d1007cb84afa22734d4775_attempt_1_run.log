    have : ∃ v, ∃ i, (gaps v).get (i + 1) - (gaps v).get i ≥ 2 * (1 / 32 * n_real ^ (-1 / 3 : ℝ)) := by
      sorry
    obtain ⟨v, i, hgap⟩ := this
    let mid := ((gaps v).get i + (gaps v).get (i + 1)) / 2
    let l : AffineSubspace ℝ P := AffineSubspace.mk' (S.choose (fun _ ↦ True) (by subst hS; exact Nat.pos_of_gt hn)) (orthogonal ℝ v.1) mid
    use l
    constructor
    · sorry
    · constructor
      · sorry
      · intro p hp
        sorry
  exact this
