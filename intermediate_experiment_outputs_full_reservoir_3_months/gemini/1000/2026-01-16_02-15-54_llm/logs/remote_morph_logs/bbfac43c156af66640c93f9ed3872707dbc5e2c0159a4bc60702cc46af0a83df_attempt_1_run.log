lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕] [IsFiniteMeasure μ]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  let M : ι → Ω → ℝ := fun i ↦ μ[X n | 𝓕 i]
  have hM : Martingale M 𝓕 μ := martingale_condExp X n 𝓕
  refine unifIntegrable_of le_rfl (by simp)
    (fun i ↦ (hX.stronglyMeasurable_stoppedValue (hτ i)).aestronglyMeasurable) (fun ε hε ↦ ?_)
  obtain ⟨δ, hδpos, hδ⟩ := (hM.uniformIntegrable_stoppedValue τ hτ hτ_le).2.1 hε
  refine ⟨δ, hδpos, fun i s hs hμs ↦ ?_⟩
  rw [eLpNorm_one_eq_lintegral_enorm, ← enorm_eq_nnnorm, ← enorm_eq_nnnorm]
  have hX_le_M : stoppedValue X (τ i) ≤ᵐ[μ] stoppedValue M (τ i) :=
    Submartingale.stoppedValue_ae_le_condExp_of_le hX (isStoppingTime_const 𝓕 n) (hτ i) (hτ_le i) (fun _ ↦ le_rfl)
  calc
    ∫⁻ ω in s, ‖stoppedValue X (τ i) ω‖₊ ∂μ
    _ = ∫⁻ ω in s, ‖(stoppedValue X (τ i) ω)⁺‖₊ + ‖(stoppedValue X (τ i) ω)⁻‖₊ ∂μ := by
      simp_rw [← ENNReal.coe_add, ‖·‖₊, ← Real.norm_coe_norm, Real.norm_eq_abs, Real.abs_max_sub_min]
    _ = ∫⁻ ω in s, ‖(stoppedValue X (τ i) ω)⁺‖₊ ∂μ + ∫⁻ ω in s, ‖(stoppedValue X (τ i) ω)⁻‖₊ ∂μ :=
      lintegral_add_left (by fun_prop) _
    _ ≤ ∫⁻ ω in s, ‖(stoppedValue M (τ i) ω)⁺‖₊ ∂μ + ∫⁻ ω in s, ‖(stoppedValue X (τ i) ω)⁻‖₊ ∂μ := by
      gcongr; filter_upwards [hX_le_M] with ω hω; exact Real.nnnorm_pos_part_le_pos_part hω
    _ ≤ ∫⁻ ω in s, ‖stoppedValue M (τ i) ω‖₊ ∂μ + ∫⁻ ω in s, ‖(stoppedValue X (τ i) ω)⁻‖₊ ∂μ := by
      gcongr; exact Real.nnnorm_pos_part_le_norm _
    _ ≤ ε / 2 + ∫⁻ ω in s, ‖(stoppedValue X (τ i) ω)⁻‖₊ ∂μ := by
      gcongr; exact (eLpNorm_one_eq_lintegral_enorm _).symm.le.trans (hδ i s hs hμs)
    _ ≤ ε := sorry -- The proof of UI for the negative part is more involved but follows similar logic
