lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
  have : ∀ i, AEStronglyMeasurable (stoppedValue X (τ i)) μ :=
    fun i ↦ hX.aestronglyMeasurable_stoppedValue (hτ i)
  uniformIntegrable_of_dominated (κ := ℕ × ℕ)
    ((Martingale.uniformIntegrable_stoppedValue (hX.𝓕.martingale_condExp (fun ω ↦ (X n ω)⁺)) τ hτ hτ_le).add le_rfl
    (Martingale.uniformIntegrable_stoppedValue (hX.𝓕.martingale_condExp (fun ω ↦ (X n ω)⁺ - X 0 ω)) τ hτ hτ_le))
    this (fun i ↦ ⟨(i, i), by
      filter_upwards [hX.stoppedValue_le_condExp (hτ i) (hτ_le i),
        hX.condExp_stoppedValue_le (isStoppingTime_const _ 0) (hτ i) (by simp)] with ω h_up h_down
      rw [Real.norm_eq_abs, abs_le]
      refine ⟨?_, h_up.trans (le_add_of_nonneg_right (sub_nonneg.2 (hX.le_condExp_pos (hτ i) (hτ_le i) ω)))⟩
      calc -((X n ω)⁺ + ((X n ω)⁺ - X 0 ω))
        _ ≤ -((X n ω)⁺ - X 0 ω) := by linarith [hX.le_condExp_pos (hτ i) (hτ_le i) ω]
        _ ≤ -((stoppedValue X (τ i) ω)⁺ - X 0 ω) := by gcongr; exact hX.stoppedValue_le_condExp_pos (hτ i) (hτ_le i) ω
        _ ≤ -((stoppedValue X (τ i) ω)⁺ - μ[stoppedValue X (τ i) | 𝓕 0] ω) := by gcongr; exact hX.le_condExp 0 (hτ i) ω
        _ = stoppedValue X (τ i) ω - (stoppedValue X (τ i) ω)⁺ + μ[stoppedValue X (τ i) | 𝓕 0] ω := by ring
        _ = -(stoppedValue X (τ i) ω)⁻ + μ[stoppedValue X (τ i) | 𝓕 0] ω := by rw [Real.pos_sub_neg]
        _ ≤ stoppedValue X (τ i) ω := by linarith [h_down, (stoppedValue X (τ i) ω)⁻.2]⟩)
