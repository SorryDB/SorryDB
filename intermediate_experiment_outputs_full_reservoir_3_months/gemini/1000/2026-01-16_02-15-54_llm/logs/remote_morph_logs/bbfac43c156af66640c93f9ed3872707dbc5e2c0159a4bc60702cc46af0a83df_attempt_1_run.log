lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕] [IsFiniteMeasure μ]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  let M i := μ[X n | (hτ i).measurableSpace]
  have hM : UniformIntegrable M 1 μ :=
    (uniformIntegrable_const (p := 1) le_rfl (by simp) (hX.integrable n)).condExp (fun i ↦ (hτ i).measurableSpace_le)
  have hX_le_M i : stoppedValue X (τ i) ≤ᵐ[μ] M i := hX.stoppedValue_ae_le_condExp_of_le (hτ i) (isStoppingTime_const _ _) (hτ_le i) (fun _ ↦ le_rfl)
  let X_0_M i := μ[X 0 | (hτ i).measurableSpace]
  have hX_0_M : UniformIntegrable X_0_M 1 μ :=
    (uniformIntegrable_const (p := 1) le_rfl (by simp) (hX.integrable 0)).condExp (fun i ↦ (hτ i).measurableSpace_le)
  refine uniformIntegrable_of_dominated (hM.norm.add le_rfl hX_0_M.norm) (fun i ↦ hX.stronglyMeasurable_stoppedValue (hτ i) |>.aestronglyMeasurable) (fun i ↦ ?_)
  filter_upwards [hX_le_M i, hX.condExp_stoppedValue_le (isStoppingTime_const _ 0) (hτ i) (by simp [hτ_le]) (fun _ ↦ bot_le)] with ω hω_le hω_ge
  rw [Real.norm_eq_abs]
  refine abs_le_of_le_of_neg_le hω_le ?_
  · simp only [X_0_M, neg_le_iff_add_right_pos]
    exact (neg_le_self (‖X_0_M i ω‖ + ‖M i ω‖)).trans (by (norm_cast; simp))
  · exact (neg_le_iff_add_right_pos.2 (by (norm_cast; simp))).trans_le' (le_trans (neg_le_neg hω_ge) (by (simp [Real.norm_eq_abs]; exact (le_abs_self _).trans (le_add_of_nonneg_left (norm_nonneg _)))))
