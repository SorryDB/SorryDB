lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  let M := fun i ↦ μ[X n | 𝓕 i]
  have hM : Martingale M 𝓕 μ := martingale_condExp X n 𝓕
  let Y := fun i ↦ M i - X i
  have hY : Supermartingale Y 𝓕 μ := hM.supermartingale.sub hX
  have hY_pos : ∀ i, 0 ≤ᵐ[μ] Y i := fun i ↦ sub_nonneg.2 (hX.le_condExp i n (le_refl n))
  have hY_tau : ∀ i, stoppedValue Y (τ i) ≤ᵐ[μ] μ[Y 0 | (hτ i).measurableSpace] :=
    fun i ↦ hY.stoppedValue_ae_le_condExp_of_le (isStoppingTime_const 𝓕 0) (hτ i) (fun _ ↦ bot_le) (hτ_le i)
  have hX_tau : ∀ i, stoppedValue X (τ i) =ᵐ[μ] stoppedValue M (τ i) - stoppedValue Y (τ i) :=
    fun i ↦ univ_mem' (fun ω ↦ by simp [stoppedValue])
  refine ((hM.uniformIntegrable_stoppedValue τ hτ hτ_le).add (p := 1) le_rfl ?_).ae_eq (fun i ↦ (hX_tau i).symm)
  refine uniformIntegrable_of_dominated (κ := ℕ × {0, 1})
    ((uniformIntegrable_const (p := 1) le_rfl (by simp) (hY.integrable 0)).condExp' (fun i ↦ (hτ i.1).measurableSpace_le))
    (fun i ↦ (hY.stronglyMeasurable_stoppedValue (hτ i) (hτ_le i)).aestronglyMeasurable) (fun i ↦ ?_)
  refine ⟨(i, 0), ?_⟩
  filter_upwards [hY_pos (stoppedValue τ i), hY_tau i] with ω hY_pos' hY_tau'
  simp only [norm_eq_abs, abs_of_nonneg hY_pos']
  exact hY_tau'.trans (Real.le_norm_self _)
