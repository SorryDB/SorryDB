    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  let M := fun i ω ↦ μ[X n | 𝓕 i]
  have hM : Martingale M 𝓕 μ := martingale_condExp (X n) 𝓕 μ
  have hM_ui : UniformIntegrable (fun i ↦ stoppedValue M (τ i)) 1 μ :=
    Martingale.uniformIntegrable_stoppedValue hM τ hτ hτ_le
  refine uniformIntegrable_of_dominated (κ := ℕ × ℕ) (hM_ui.add le_rfl hM_ui) ?_ ?_
  · exact fun i ↦ hX.stronglyMeasurable_stoppedValue (hτ i)
  · intro i
    refine ⟨(i, i), ?_⟩
    filter_upwards [hX.stoppedValue_ae_le_condExp_of_le (isStoppingTime_const 𝓕 n) (hτ i) (hτ_le i)
      (fun _ ↦ le_rfl)] with ω hω
    simp only [M, Pi.add_apply, norm_eq_abs]
    rw [abs_le]
    constructor
    · calc -|stoppedValue M (τ i) ω| - |stoppedValue M (τ i) ω|
          _ ≤ -|stoppedValue M (τ i) ω| := by linarith [abs_nonneg (stoppedValue M (τ i) ω)]
          _ ≤ stoppedValue M (τ i) ω := by linarith [abs_le.1 (le_refl _)]
          _ ≤ stoppedValue X (τ i) ω := sorry -- This direction is harder for submartingales
    · exact hω.trans (le_abs_self _)
