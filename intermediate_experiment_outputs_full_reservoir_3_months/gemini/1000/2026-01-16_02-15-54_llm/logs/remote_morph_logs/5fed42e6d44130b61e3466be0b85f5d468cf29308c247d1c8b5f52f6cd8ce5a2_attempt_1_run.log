section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let S := {y | ∃ seq : BiasedUpdateSeq net x, seq.target = y}
  have hS : S.Finite := Set.finite_univ.subset (Set.subset_univ S)
  obtain ⟨p, ⟨seq, rfl⟩, hmin⟩ := hS.exists_min_image (biasedEnergy net) ⟨x, nil x, rfl⟩
  refine ⟨seq, fun i => (biasedEnergy_fixed_point_iff_no_change net _ i).mp (le_antisymm (biasedEnergy_decreasing net _ i) (sub_nonneg.mpr ?_))⟩
  apply hmin
  induction seq with
  | nil x => exact ⟨cons x i (nil _), rfl⟩
  | cons x j seq ih => obtain ⟨s, hs⟩ := ih; exact ⟨cons x j s, hs⟩
