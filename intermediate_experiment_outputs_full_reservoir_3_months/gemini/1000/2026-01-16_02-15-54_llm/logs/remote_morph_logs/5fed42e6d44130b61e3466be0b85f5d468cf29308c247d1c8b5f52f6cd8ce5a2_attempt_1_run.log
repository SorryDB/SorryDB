section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let f x := (Finset.univ.filter (fun y ↦ biasedEnergy net y < biasedEnergy net x)).card
  induction x using WellFounded.induction (WellFounded.measure f)
  next x ih =>
    if hfp : biasedIsFixedPoint net x then exact ⟨.nil x, hfp⟩ else
    let ⟨i, hi⟩ := Classical.exists_not_of_not_forall hfp
    have h_lt : biasedEnergy net (biasedUpdateState net x i) < biasedEnergy net x :=
      lt_of_sub_neg ((biasedEnergy_decreasing net x i).lt_of_ne (by rwa [biasedEnergy_fixed_point_iff_no_change]))
    have h_f : f (biasedUpdateState net x i) < f x := Finset.card_lt_card <| by
      rw [Finset.ssubset_iff]; refine ⟨fun y hy ↦ ?_, biasedUpdateState net x i, ?_⟩
      · simp [Finset.mem_filter] at hy ⊢; exact hy.trans h_lt
      · simp [Finset.mem_filter, h_lt, lt_irrefl]
    let ⟨seq, hseq⟩ := ih (biasedUpdateState net x i) h_f
    exact ⟨.cons x i seq, hseq⟩
```
