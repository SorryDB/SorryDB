/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  if h : biasedIsFixedPoint net x then exact ⟨.nil x, rfl, h⟩ else
  let i := Classical.choose (not_forall.mp h)
  have hi : biasedUpdateState net x i ≠ x := Classical.choose_spec (not_forall.mp h)
  let x' := biasedUpdateState net x i
  have h_lt : biasedEnergy net x' < biasedEnergy net x :=
    (biasedEnergy_decreasing net x i).lt_of_ne (fun h' => hi ((biasedEnergy_fixed_point_iff_no_change net x i).mp (by simpa [biasedEnergyDiff, x'] using h')))
  obtain ⟨seq, hseq⟩ := biased_asynchronous_update_convergence x'
  exact ⟨.cons x i seq, hseq⟩
termination_by x => (Finset.univ.filter (fun s => biasedEnergy net s < biasedEnergy net x)).card
decreasing_by
  apply Finset.card_lt_card
  rw [Finset.ssubset_iff]
  refine ⟨x', by simp [h_lt], fun y hy => by simp at hy; simp [lt_trans hy h_lt]⟩
