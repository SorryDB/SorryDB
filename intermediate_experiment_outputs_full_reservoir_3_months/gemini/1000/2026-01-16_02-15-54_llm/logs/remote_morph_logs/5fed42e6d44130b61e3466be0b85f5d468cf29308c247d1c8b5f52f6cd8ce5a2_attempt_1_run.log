section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let R := {y | ∃ seq : BiasedUpdateSeq net x, seq.target = y}
  have ⟨p, hpR, hmin⟩ := (Set.toFinite R).exists_minimize (biasedEnergy net) ⟨x, nil x, rfl⟩
  obtain ⟨seq, hseq⟩ := hpR
  use seq; rw [hseq]; intro i; by_contra hne
  have hlt : biasedEnergy net (biasedUpdateState net p i) < biasedEnergy net p :=
    lt_of_le_of_ne (biasedEnergy_decreasing net p i) ((biasedEnergy_fixed_point_iff_no_change net p i).not.mpr hne)
  have hmem : biasedUpdateState net p i ∈ R := by
    rw [← hseq]; induction seq with
    | nil x => exact ⟨cons x i (nil _), rfl⟩
    | cons x j s ih => obtain ⟨s', hs'⟩ := ih; exact ⟨cons x j s', hs'⟩
  exact hlt.not_le (hmin _ hmem)
