/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let S := { y | ∃ seq : BiasedUpdateSeq net x, seq.target = y }
  have hf : S.Finite := Set.finite_univ.subset (Set.subset_univ S)
  have hne : S.Nonempty := ⟨x, nil x, rfl⟩
  rcases hf.exists_min_image (biasedEnergy net) hne with ⟨p, hpS, hmin⟩
  rcases hpS with ⟨seq, rfl⟩
  refine ⟨seq, fun i => ?_⟩
  let p' := biasedUpdateState net seq.target i
  have hp' : p' ∈ S := by
    let rec append {y z} (s1 : BiasedUpdateSeq net y) (h : s1.target = z) (s2 : BiasedUpdateSeq net z) : BiasedUpdateSeq net y :=
      match s1 with
      | nil _ => h ▸ s2
      | cons y' j s' => cons y' j (append s' h s2)
    exact ⟨append seq rfl (cons seq.target i (nil p')), rfl⟩
  have h_zero : biasedEnergyDiff net seq.target i = 0 :=
    (biasedEnergy_decreasing net seq.target i).antisymm (sub_nonneg.mpr (hmin p' hp'))
  exact (biasedEnergy_fixed_point_iff_no_change net seq.target i).mp h_zero

