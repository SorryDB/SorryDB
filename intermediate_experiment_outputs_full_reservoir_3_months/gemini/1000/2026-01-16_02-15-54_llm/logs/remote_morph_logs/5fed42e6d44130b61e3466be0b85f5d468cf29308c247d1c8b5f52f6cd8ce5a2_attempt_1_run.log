section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let r := fun y x => biasedEnergy net y < biasedEnergy net x
  have hwf : WellFounded r := Finite.wellFounded_of_trans_of_irrefl r (fun _ _ _ => lt_trans) (fun _ => lt_irrefl _)
  induction x using hwf.induction with
  | h x ih =>
    by_cases hf : biasedIsFixedPoint net x
    · exact ⟨nil x, hf⟩
    · push_neg at hf
      obtain ⟨i, hi⟩ := hf
      have h_lt : biasedEnergy net (biasedUpdateState net x i) < biasedEnergy net x :=
        lt_of_le_of_ne (biasedEnergy_decreasing net x i)
          (fun h_eq => hi ((biasedEnergy_fixed_point_iff_no_change net x i).mp (sub_eq_zero.mpr h_eq)))
      obtain ⟨seq, h_fp⟩ := ih (biasedUpdateState net x i) h_lt
      exact ⟨cons x i seq, h_fp⟩
