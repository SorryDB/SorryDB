lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = bits2num args) := by
  intros w args e h ⟨hb, he⟩
  rw [he] at h; simp [Exp.eval, bits2num] at h; apply h
  generalize hacc : (0 : ZMod p) = acc
  have : acc.val < 2^0 := by simp [←hacc, ZMod.val_zero]
  revert acc args; induction w with
  | zero => intros args acc _ hacc; simp [Vector.foldl] at *; exact hacc
  | succ w ih =>
    intros args acc hb hacc
    rw [Vector.cons_head_tail args, Vector.foldl_cons]
    apply ih args.tail (args.head + 2 * acc)
    · simp [assert_bits, Vector.all_eq_true] at hb ⊢; intro i; exact hb i.succ
    · rw [ZMod.val_add, ZMod.val_mul, ZMod.val_two]
      apply Nat.lt_of_le_of_lt (Nat.mod_le _ _)
      have hb0 : (args.head).val < 2 := by
        simp [assert_bits, Vector.all_eq_true] at hb
        have := hb 0; simp [beq_iff_eq] at this
        rcases this with rfl | rfl <;> simp [ZMod.val_zero, ZMod.val_one]
      linarith
