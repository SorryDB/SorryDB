  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = Exp.c (bits2num args)) := by
  contrapose!
  rintro ⟨h_bits, rfl⟩
  simp only [Exp.eval]
  induction w generalizing args with
  | zero =>
    have : args = #v[] := by simp
    simp [this, bits2num, Vector.foldl]
    exact Nat.zero_lt_one
  | succ w ih =>
    simp [bits2num, Vector.foldl, assert_bits] at h_bits ⊢
    obtain ⟨h_head, h_tail⟩ := h_bits
    have h_val : (args.head.val = 0 ∨ args.head.val = 1) := by
      rcases (beq_iff_eq.mp (Bool.or_eq_true.mp h_head).left) with h | h
      · left; exact (ZMod.val_eq_zero.mpr h)
      · right; exact (ZMod.val_eq_one.mpr h)
    have ih_val := ih args.tail h_tail
    have h_sum := ZMod.val_add args.head (2 * bits2num args.tail)
    have h_mul := ZMod.val_mul 2 (bits2num args.tail)
    set S := args.head.val + (2 * (bits2num args.tail).val)
    have hS : S < 2^(w+1) := by
      rcases h_val with h | h
      · rw [h, zero_add]; linarith
      · rw [h]; linarith
    exact (Nat.mod_le S p).trans_lt hS
