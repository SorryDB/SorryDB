lemma isCompact (v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ)) : IsCompact
  ((((Aux.c_v_alg V v)).toAddMonoidHom.comp
        (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
            (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                    v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range :
                    Set (V ⊗[ℚ] IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v)) := by
  classical
  letI : CompactSpace (v.adicCompletionIntegers ℚ) :=
    NumberField.instCompactSpaceAdicCompletionIntegers ℚ
  let b := IntegralLattice.basis ℤ ℚ V
  let f := (Aux.c_v_alg V v).toLinearMap.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V) v.adicCompletionIntegers.subtype)
  have : (f.toAddMonoidHom).range = Set.range (fun (x : _ → v.adicCompletionIntegers ℚ) ↦ ∑ i, x i • f (b i ⊗ₜ 1)) := by
    ext x; simp only [AddMonoidHom.mem_range, LinearMap.toAddMonoidHom_coe, LinearMap.mem_range]
    refine ⟨fun ⟨u, hu⟩ ↦ ⟨fun i ↦ TensorProduct.coord b i u, by
      simp [← hu, ← LinearMap.map_sum, ← LinearMap.map_smul, ← TensorProduct.sum_basis_left b u, LinearMap.lTensor_tmul]⟩,
