                    Set (V ⊗[ℚ] IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v)) := by
  letI : CompactSpace (v.adicCompletionIntegers ℚ) := NumberField.instCompactSpaceAdicCompletionIntegers ℚ
  let b := IntegralLattice.basis ℤ ℚ V
  let v_i := fun i ↦ Aux.c_v_alg V v (b i ⊗ₜ 1)
  let f : (Free.chooseBasisIndex ℤ (IntegralLattice ℤ ℚ V) → v.adicCompletionIntegers ℚ) → V ⊗[ℚ] v.adicCompletion ℚ :=
    fun x ↦ ∑ i, x i • v_i i
  have : (↑((↑(@Aux.c_v_alg V _ _ v)).toAddMonoidHom.comp
        (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
            (v.adicCompletionIntegers ℚ).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range) = Set.range f := by
    ext y; simp only [f, Set.mem_range, LinearMap.coe_toAddMonoidHom, LinearMap.coe_comp,
      AddMonoidHom.coe_comp, Function.comp_apply, LinearMap.lTensor_tmul,
      LinearMap.coe_toIntLinearMap, Subtype.coe_subtype]
    constructor
    · rintro ⟨x, rfl⟩
      induction x using TensorProduct.induction_on with
      | zero => use 0; simp
      | tmul n r => use fun i ↦ (b.repr n i) • r; simp [v_i, Basis.sum_repr, TensorProduct.sum_tmul, smul_assoc]
      | add x y hx hy => obtain ⟨fx, rfl⟩ := hx; obtain ⟨fy, rfl⟩ := hy; use fx + fy; simp [v_i, add_smul, Finset.sum_add_distrib]
    · rintro ⟨x, rfl⟩; use ∑ i, (b i ⊗ₜ x i); simp [v_i, TensorProduct.sum_tmul, smul_assoc]
  rw [this]
  apply isCompact_range_of_continuous
