        simp [hx, LinearMap.map_sum, LinearMap.map_smul, LinearMap.lTensor_tmul]⟩]
  rw [this]; apply isCompact_range
  exact continuous_finset_sum _ (fun i _ ↦ (continuous_apply i).smul continuous_const)
