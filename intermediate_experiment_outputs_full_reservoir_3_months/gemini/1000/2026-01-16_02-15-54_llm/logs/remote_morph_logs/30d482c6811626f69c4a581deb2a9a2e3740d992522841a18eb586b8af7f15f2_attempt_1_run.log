lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  -- Each of the n-1 secrets must reach k, and k's secret must reach all n-1 others.
  -- In a noHo sequence, a call can contribute to both k becoming an expert 
  -- and spreading k's secret if and only if k is a participant in that call.
  -- Thus, the total number of calls satisfies |S| ≥ (n-1) + (n-1) - v S k.
  have h_exp := exp_needs_n_min_one_calls S h
  have h_known := known_needs_n_min_one_calls S h2
  have h_v : v S k ≤ S.length := List.countP_le_length _ _
  induction n
  case zero => simp
  case succ n IH =>
    induction S generalizing k
    case nil =>
      simp [v, initialState, after, isExpert, allKnow] at *
      cases n <;> simp at *
    case cons c S' IH_S =>
      -- The proof follows from Lemma 6 of Baker and Shostak (1972)
      -- which relates the size of the set of calls to the degree of k.
      sorry
```
