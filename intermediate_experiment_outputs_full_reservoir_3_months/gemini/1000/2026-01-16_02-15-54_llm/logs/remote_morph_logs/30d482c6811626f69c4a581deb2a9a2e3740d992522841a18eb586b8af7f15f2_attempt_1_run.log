/-- Given a noHo sequence, to make k an expert and make everyone know k, we need this many calls. -/
lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  have h_in := exp_needs_n_min_one_calls S h
  have h_out := known_needs_n_min_one_calls S h2
  zify [v]
  have h_sum : (2 * n : ℤ) - 2 ≤ S.length + v S k := by
    /-
      This is Lemma 6 from Baker and Shostak (1972).
      The number of calls S.length + v S k counts each call involving agent k twice
      and each call not involving agent k once.
      For each agent j ≠ k, we identify two critical events:
      1. The first call where j learns k's secret.
      2. The last call that conveys information from j to k.
      Due to the noHo property, these 2(n-1) events must correspond to distinct
      agent-call pairs (j, c).
      - If k ∈ c, the call c can account for both j learning k's secret and k learning j's secret.
      - If k ∉ c, the call c can account for at most one such event.
      Thus, 2(n-1) ≤ 2 * (calls with k) + 1 * (calls without k) = S.length + v S k.
    -/
    sorry
  omega
```
