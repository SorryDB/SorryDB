TheoremDoc RiemannSumRefinement as "RiemannSumRefinement" in "∫f"

Statement RiemannSumRefinement (f : ℝ → ℝ) {a b : ℝ} (hab : a < b) {n k : ℕ}
    (hn : n ≠ 0) (hk : k ≠ 0)
    {ε δ : ℝ} (hε : ε > 0) (hδ : δ > 0)
