@[sorryful]
override lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have hE := congr_fun (trajectory_energy S IC) t
  simp [energy, kineticEnergy, potentialEnergy] at hE
  rw [← norm_sq_eq_zero, ← mul_left_inj' (show S.m / 2 ≠ 0 from by simp [S.m_pos.ne.symm])]
  rw [← add_right_inj (b := S.k / 2 * ‖IC.trajectory S t‖^2), hE, zero_add]
  rw [eq_comm (a := ‖IC.trajectory S t‖), sqrt_eq_iff_sq_eq (add_nonneg (sq_nonneg _) (sq_nonneg _)) (norm_nonneg _)]
  have h_m : S.m ≠ 0 := S.m_pos.ne.symm
  have h_k : S.k ≠ 0 := S.k_pos.ne.symm
  have h_ω : S.ω ≠ 0 := ω_neq_zero S
  field_simp [h_m, h_k, h_ω]
  rw [ω_sq]
  field_simp [h_m]
  ring
```
