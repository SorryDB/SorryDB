    rw [mul_add, mul_div_cancel' _ (pow_ne_zero 2 h_ω)] at h1
    rw [add_comm (S.ω ^ 2 * _), add_right_cancel_iff, add_right_cancel_iff] at h1
    exact norm_eq_zero.mp (pow_eq_zero h1)
