  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let n := 2021
  let S (k : ℕ) (q : Position) : Finset (Fin n) := Finset.univ.filter (fun i => q i < k)
  let B (k : ℕ) (q : Position) : ℕ := (Finset.univ.filter (fun i : Fin n => (i ∈ S k q) ≠ (i + 1 ∈ S k q))).card / 2
  by_contra! h
  have h_step : ∀ k : Fin n, B (k.1 + 1) (p.nth k.next) ≡ B k.1 (p.nth k) + 1 [PMOD 2] := by
    intro k
    let pk := p.nth k
    let a := (pk.swapped k).1
    let b := (pk.swapped k).2
    have hk : (a < k ∧ b < k) ∨ (k < a ∧ k < b) := by
      have := h k
      revert this; simp only [not_or, not_and, not_lt, ← le_iff_lt, le_anticyclotomic_iff_not_between]
      intro h; cases h.1 <;> cases h.2 <;> omega
    sorry
  have h_final : B n (p.nth (Fin.last 2020)) ≡ B 0 (p.nth 0) + n [PMOD 2] := by
    -- This follows from h_step by induction
    sorry
  simp [B, S] at h_final
  norm_num at h_final
