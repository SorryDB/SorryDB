import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let n := 2021
  let f : Fin n → ℤ := λ k => if ((p.nth k).swapped k).1 < k then 1 else -1
  have hf : ∀ k, ((p.nth k).swapped k).1 < k ↔ ((p.nth k).swapped k).2 < k :=
    λ k => ⟨λ h1 => by
      have h2 := h k
      rcases h2 with ⟨h2a, h2b⟩ | ⟨h2a, h2b⟩
      · exact h2b
      · exact False.elim (h2a.not_lt h1),
    λ h1 => by
      have h2 := h k
      rcases h2 with ⟨h2a, h2b⟩ | ⟨h2a, h2b⟩
      · exact False.elim (h2b.not_lt h1)
      · exact h2a⟩
  let s (k : Fin n) : SignType := if ((p.nth k).swapped k).1 < k then -1 else 1
  have h_swap : ∀ k, Equiv.swap ((p.nth k).swapped k).1 ((p.nth k).swapped k).2 ≠ 1 :=
    λ k => by
      intro h_eq
      have h_noneq := Equiv.swap_eq_one_iff.not.mpr (by
        intro h_sw
        have h_cond := h k
        cases h_cond <;> linarith)
      exact h_noneq h_eq
  have sign_prod : (∏ k, (Equiv.swap ((p.nth k).swapped k).1 ((p.nth k).swapped k).2).sign) = (-1 : ℤ)^n := by
    simp [Equiv.SignType.sign_swap (h_swap _), n]
  have sign_val : ∀ k, (Equiv.swap ((p.nth k).swapped k).1 ((p.nth k).swapped k).2).sign = 1 :=
    λ k => by
      simp [Equiv.SignType.sign_swap (h_swap _)]
      have h_k := hf k
      by_cases h1 : ((p.nth k).swapped k).1 < k
      · have h2 := h_k.mp h1
        exact False.elim (by
          rcases h k with ⟨ha, hb⟩ | ⟨ha, hb⟩
          · exact ha.not_lt h1
          · exact hb.not_lt h2)
      · exact rfl
  simp [sign_val] at sign_prod
  norm_num at sign_prod
