import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let n := 2021
  let c (k : ℕ) (h : Fin n) : ℤ := if (move^[k] (p, 0)).1 h >= k then 1 else -1
  let V (k : ℕ) : ℤ := ∑ i : Fin n, |c k i - c k (i + 1)|
  have hV : ∀ k < n, ((((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
    (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1)) ∨ V (k + 1) ≡ V k + 2 [ZMOD 4] := by
    intro k hk
    let p_k := (move^[k] (p, 0)).1
    let h_k := p_k.symm k
    let a := p_k (h_k - 1)
    let b := p_k (h_k + 1)
    let s_a := if a >= k then (1 : ℤ) else -1
    let s_b := if b >= k then (1 : ℤ) else -1
    by_cases h : (a < k ∧ k < b) ∨ (b < k ∧ k < a)
    · left; exact h
    · right
      have h_ab : s_a = s_b := by
        simp only [s_a, s_b, Int.reduceNeg, ite_self]
        rcases (Fin.lt_or_gt_of_ne (Equiv.symm_apply_eq.not.mp (p_k.symm.injective.ne (Fin.ne_of_gt (Fin.sub_one_lt h_k))))) with h_a | h_a
        rcases (Fin.lt_or_gt_of_ne (Equiv.symm_apply_eq.not.mp (p_k.symm.injective.ne (Fin.ne_of_lt (Fin.lt_add_one h_k))))) with h_b | h_b
        all_goals (simp_all; omega)
      let p_next := (move^[k + 1] (p, 0)).1
      have : V (k + 1) - V k = 2 * s_a + 2 * s_b ∨ V (k + 1) - V k = 2 * s_a + 2 * s_b + 4 ∨ V (k + 1) - V k = 2 * s_a + 2 * s_b - 4 := sorry
      rw [h_ab] at this
      rcases this with hV | hV | hV
      all_goals (rw [hV]; rcases (show s_a = 1 ∨ s_a = -1 by omega) with ha | ha <;> rw [ha] <;> norm_num)
  contrapose! hV
  have h_sum : ∑ k : Fin n, (V (k + 1) - V k) ≡ ∑ k : Fin n, 2 [ZMOD 4] := by
    apply Int.ModEq.sum
    intro k _
    specialize hV k k.is_lt
    specialize hV k.is_lt
    rcases (hV k k.is_lt) with ⟨_, h_mod⟩
    exact Int.ModEq.sub_right h_mod
  simp only [Finset.sum_range_reflect, Finset.sum_sub_distrib, Finset.sum_const, Finset.card_fin, n] at h_sum
  have : V n = 0 ∧ V 0 = 0 := by
    constructor
    · apply Finset.sum_eq_zero; intro i _; show |(if (move^[n] (p, 0)).1 i ≥ n then 1 else -1) - (if (move^[n] (p, 0)).1 (i + 1) ≥ n then 1 else -1)| = 0
      have : ∀ j : Fin n, (move^[n] (p, 0)).1 j < n := fun j => j.is_lt
      simp [this]
    · apply Finset.sum_eq_zero; intro i _; show |(if p i ≥ 0 then 1 else -1) - (if p (i + 1) ≥ 0 then 1 else -1)| = 0
      have : ∀ j : Fin n, p j ≥ 0 := fun _ => Nat.zero_le _
      simp [this]
  rw [this.1, this.2, sub_self] at h_sum
  norm_num at h_sum
