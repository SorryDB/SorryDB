import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let n := 2021
  by_contra! h
  let h_k (k : ℕ) : Fin n := (p.nth (Fin.ofNat' n k)).symm (Fin.ofNat' n k)
  let S (k : ℕ) : Finset (Fin n) := Finset.univ.filter (λ i => (p.nth (Fin.ofNat' n k)) i < (k : ℕ))
  let boundary_count (k : ℕ) : ℕ := (Finset.univ.filter (λ i : Fin n => i ∈ S k ∧ i + 1 ∉ S k)).card
  have h_step : ∀ k < n, boundary_count (k + 1) = boundary_count k + 1 ∨ boundary_count (k + 1) = boundary_count k - 1 := by
    intro k hk
    let p_k := p.nth (Fin.ofNat' n k)
    let p_k1 := p.nth (Fin.ofNat' n (k + 1))
    let hole_k := h_k k
    have h_swap : p_k1 = p_k.trans (Equiv.swap (p_k.swapped (Fin.ofNat' n k)).1 (p_k.swapped (Fin.ofNat' n k)).2) := by rfl
    have h_S_eq : (S (k + 1)) = (S k).insert hole_k := by
      ext i
      simp [S, h_swap, Position.swapped, Equiv.trans_apply, Equiv.swap_apply_def]
      split_ifs with h1 h2
      · have : (p_k i < k) ↔ (p_k1 i < k) := by simp [h_swap, h1, Position.swapped]
        simp [this, k.succ_eq_add_one]
        exact ⟨λ hi => Or.inl (Or.inl hi.left), λ hi => by cases hi with | inl hi => cases hi with | inl hi => exact ⟨hi, λ _ => by linarith⟩ | inr hi => linarith | inr hi => linarith⟩
      · have : (p_k i < k) ↔ (p_k1 i < k) := by simp [h_swap, h2, Position.swapped]
        simp [this, k.succ_eq_add_one]
        exact ⟨λ hi => Or.inl (Or.inl hi.left), λ hi => by cases hi with | inl hi => cases hi with | inl hi => exact ⟨hi, λ _ => by linarith⟩ | inr hi => linarith | inr hi => linarith⟩
      · simp [k.succ_eq_add_one]
        by_cases hik : i = hole_k
        · simp [hik, p_k.apply_symm_apply]
        · have : p_k1 i = p_k i := by simp [h_swap, Equiv.trans_apply, Equiv.swap_apply_of_ne_pos (by rwa [p_k.apply_eq_iff_eq_symm]) (by rwa [p_k.apply_eq_iff_eq_symm])]
          simp [this, hik]
          exact ⟨λ hi => Or.inl (Or.inl hi), λ hi => by cases hi with | inl hi => cases hi with | inl hi => exact hi | inr hi => contradiction | inr hi => linarith [p_k.apply_eq_iff_eq_symm.mp hi.symm]⟩
    let b k := boundary_count k
    have : b (k + 1) = if (hole_k - 1 ∈ S k) ∧ (hole_k + 1 ∈ S k) then b k - 1 else if (hole_k - 1 ∉ S k) ∧ (hole_k + 1 ∉ S k) then b k + 1 else b k := by
      simp [boundary_count, h_S_eq, Finset.filter_insert, Finset.card_insert_of_not_mem]
      sorry
    specialize h k
    simp [Position.swapped, h_k] at h
    have h_cases : (hole_k - 1 ∈ S k ∧ hole_k + 1 ∈ S k) ∨ (hole_k - 1 ∉ S k ∧ hole_k + 1 ∉ S k) := by
      simp [S]
      cases h with | inl h => cases h; contradiction | inr h => cases h; contradiction
    cases h_cases <;> simp [this, *]
  have h_parity : ∀ k ≤ n, (boundary_count k : ℤ) ≡ (k : ℤ) [ZMOD 2] := by
    intro k hk
    induction k with
    | zero => simp [boundary_count, S]
    | succ k ih =>
      have hk' : k < n := by linarith
      specialize ih (by linarith)
      cases h_step k hk' <;> simp [Int.ModEq] at * <;>
      · rw [← ih]; simp [Int.mod_two_eq_zero_iff_even]
  specialize h_parity n (by linarith)
  have h_bn : boundary_count n = 0 := by simp [boundary_count, S, Finset.card_eq_zero]
  simp [h_bn, n] at h_parity
