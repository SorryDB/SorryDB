import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let n := 2021
  let edges (q : Position) : Finset (Fin n × Fin n) :=
    Finset.univ.map ⟨fun i => (q i, q (i + 1)), fun i j hij => by
      simp at hij; exact hij⟩
  let crossing (q : Position) (k : ℕ) : ℤ :=
    (edges q).sum (fun e => if (e.1.1 < k ∧ k ≤ e.2.1) then (1 : ℤ) else if (e.2.1 < k ∧ k ≤ e.1.1) then -1 else 0)
  let f (k : ℕ) : ℤ := crossing (p.nth (Fin.ofNat k)) k
  have h_step (k : Fin n) : f (k.1 + 1) = f k.1 + if k < (p.nth k).swapped k.1 then 2 else -2 := by sorry
  have h_f0 : f 0 = 0 := by sorry
  have h_fn : f n = 0 := by sorry
  have : (Finset.univ : Finset (Fin n)).sum (fun k => if k < (p.nth k).swapped k.1 then (1 : ℤ) else -1) = 0 := by
    rw [← Int.mul_ediv_cancel (a := 2) (b := (Finset.univ : Finset (Fin n)).sum (fun k => if k < (p.nth k).swapped k.1 then (1 : ℤ) else -1)) (by norm_num)]
    simp [Finset.sum_range]
    sorry
  have h_odd : (Finset.univ : Finset (Fin n)).card % 2 = 0 := by
    rw [← Int.natAbs_even, ← Int.even_coe_nat]
    convert Int.even_sum_iff.mpr (by simp; exact this)
    simp
  norm_num at h_odd
