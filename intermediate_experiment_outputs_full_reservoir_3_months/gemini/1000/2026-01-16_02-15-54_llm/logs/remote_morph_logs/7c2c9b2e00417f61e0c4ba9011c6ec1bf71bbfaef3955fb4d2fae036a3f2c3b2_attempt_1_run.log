import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let n := 2021
  let q (k : Fin n) := p.nth k
  have h_symm (k : Fin n) : (q k).symm k = p.symm k := by
    induction k using Fin.induction with
    | zero => rfl
    | succ k ih => rw [Position.nth, Function.iterate_succ', Function.comp_apply, move]; simp [ih, Position.swapped]
  let s (k : Fin n) (i : Fin n) : Prop := q k i < k
  have h_s (k : Fin n) (i : Fin n) : s k i ↔ p i < k := by
    induction k using Fin.induction with
    | zero => simp [s]
    | succ k ih =>
      rw [Position.nth, Function.iterate_succ', Function.comp_apply, move]
      simp [Position.swapped, h_symm, s] at ih ⊢
      have h_not : ¬(k < q k (p.symm k - 1) ∧ q k (p.symm k - 1) < k) := by simp
      have h_cond : q k (p.symm k - 1) < k ↔ q k (p.symm k + 1) < k := by
        specialize h k; simp [Position.swapped, h_symm] at h; cases h <;> itauto
      split_ifs with heq <;> simp [ih, h_cond]
      · rw [heq]; simp [ih]
      · have : p i ≠ k := by intro he; have := p.symm_apply_apply i; rw [he, ← h_symm] at this;
          have := (q k).apply_symm_apply k; contradiction
        rcases this.lt_or_lt with hlt | hlt <;> simp [ih, hlt, Nat.lt_succ_iff_lt_or_eq]
  let v (i : Fin n) : Fin n := p i
  have h_max_min (i : Fin n) : (v (i - 1) < v i ∧ v (i + 1) < v i) ∨ (v i < v (i - 1) ∧ v i < v (i + 1)) := by
    let k := v i
    have hi : i = p.symm k := by simp [v]
    specialize h k; rw [hi, Position.swapped, h_symm] at h
    have h1 : q k (i - 1) < k ↔ v (i - 1) < k := h_s k (i - 1)
    have h2 : q k (i + 1) < k ↔ v (i + 1) < k := h_s k (i + 1)
    rw [h1, h2] at h; cases h <;> itauto
  let f (i : Fin n) : Fin 2 := if v i < v (i + 1) then 0 else 1
  have h_alt (i : Fin n) : f i ≠ f (i + 1) := by
    simp [f]; split_ifs <;> (specialize h_max_min (i + 1); simp [v] at *; rcases h_max_min with h' | h' <;> itauto)
  have h_false : (n : ℕ) % 2 = 0 := by
    have : ∀ i : ℕ, (f i : ℕ) = (i + (f 0 : ℕ)) % 2 := by
      intro i; induction i with
      | zero => simp
      | succ i ih =>
        have h_f : f (i + 1) = 1 - f i := by
          have := h_alt i; cases h1 : f i <;> cases h2 : f (i + 1) <;>
          simp [h1, h2] at * <;> try contradiction; rfl
        rw [h_f, ih]; simp [Fin.val_one, Nat.sub_mod]; omega
    specialize this n; simp at this; rw [← this]
    have : f n = f 0 := rfl
    rw [this]; simp; omega
  exact Nat.odd_iff_not_even.mp (by decide) (Nat.even_iff_mod_two_eq_zero.mpr h_false)

end IMO2021P5
