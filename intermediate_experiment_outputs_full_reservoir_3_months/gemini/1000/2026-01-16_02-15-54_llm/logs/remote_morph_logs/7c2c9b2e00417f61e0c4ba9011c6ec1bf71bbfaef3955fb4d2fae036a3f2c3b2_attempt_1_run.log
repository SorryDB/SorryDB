import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let n := 2021
  let pos : ℕ → Position := fun k => (move^[k] (p, 0)).1
  let c : ℕ → ℤ := fun k => (Finset.univ.filter (fun i : Fin n =>
    (pos k i < k ∧ pos k (i + 1) ≥ k))).card
  have h_base : c 0 = 0 := by simp [c]
  have h_step : ∀ k < n, (¬ (((pos k).swapped k).1 < k ∧ k < ((pos k).swapped k).2) ∧
    ¬ (((pos k).swapped k).2 < k ∧ k < ((pos k).swapped k).1)) →
    c (k + 1) = c k + 1 ∨ c (k + 1) = c k - 1 := sorry
  have h_parity : ∀ k ≤ n, (∀ m < k, ¬ ((((pos m).swapped m).1 < m ∧ m < ((pos m).swapped m).2) ∨
    (((pos m).swapped m).2 < m ∧ m < ((pos m).swapped m).1))) → c k ≡ k [ZMOD 2] := by
    intro k hk h; induction k with
    | zero => simp [h_base]
    | succ k ih =>
      have hk_lt : k < n := by omega
      have h_not := h k hk_lt
      have h_prev := ih (by omega) (fun m hm => h m (by omega))
      rw [h_step k hk_lt h_not]
      rcall h_prev using h_p; simp [h_p]; apply Int.ModEq.add_right; apply Int.modEq_neg.mpr; simp
  by_contra! h
  have h_last := h_parity n (by omega) (fun k hk => h k)
  have h_cn : c n = 0 := by
    simp [c, pos]; apply Finset.card_eq_zero.mpr; apply Finset.filter_eq_empty_iff.mpr
    intro i _; have hi := (pos n i).is_lt; simp [hi]
  simp [h_cn] at h_last; contradiction

