import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let n := 2021
  let S : ℕ → Finset (Fin n) := λ k => (Finset.range k).attach.map
    ⟨λ i => (p.nth ⟨i.1, (Finset.mem_range.1 i.2).trans_le (by simp [n])⟩).symm
    ⟨i.1, (Finset.mem_range.1 i.2).trans_le (by simp [n])⟩, by
    intro i j hij; simp at hij; exact Subtype.ext hij⟩
  let b (k : ℕ) : ℕ := (S k).filter (λ i => (i + 1) ∉ S k).card
  have hb : ∀ k < n, b (k + 1) % 2 ≠ b k % 2 := by
    intro k hk
    have : S (k + 1) = S k ∪ {(p.nth ⟨k, hk⟩).symm ⟨k, hk⟩} := by
      simp [S, Finset.range_succ]; rfl
    have h_hk : (p.nth ⟨k, hk⟩).symm ⟨k, hk⟩ ∉ S k := by
      simp [S]; intro i hi; simp at hi; apply (p.nth ⟨k, hk⟩).symm.injective
      intro h; apply hi; apply_fun (p.nth ⟨k, hk⟩) at h; exact h
    rw [this, Nat.mod_two_ne_iff]
    let h_pos := (p.nth ⟨k, hk⟩).symm ⟨k, hk⟩
    have h_adj : ∀ j < k, (p.nth ⟨k, hk⟩).symm ⟨j, by omega⟩ = (p.nth ⟨j, by omega⟩).symm ⟨j, by omega⟩ := by sorry
    have h_ext : ((p.nth ⟨k, hk⟩).swapped ⟨k, hk⟩).1 < ⟨k, hk⟩ ↔ (h_pos - 1) ∈ S k := by sorry
    have h_ext2 : ((p.nth ⟨k, hk⟩).swapped ⟨k, hk⟩).2 < ⟨k, hk⟩ ↔ (h_pos + 1) ∈ S k := by sorry
    have : (h_pos - 1 ∈ S k) = (h_pos + 1 ∈ S k) := by
      specialize h ⟨k, hk⟩; simpa [h_ext, h_ext2] using h
    sorry
  have h0 : b 0 = 0 := by simp [b, S]
  have hn : b n = 0 := by
    simp [b, S, n]
    have : S n = Finset.univ := by
      apply Finset.eq_univ_of_card; simp [S, n]; rw [Finset.card_map]
      simp [Finset.card_range]
    simp [this]
  have h_parity : b n % 2 = n % 2 := by
    induction n with | zero => rfl | succ m ih =>
      rw [hb m (by omega), ih, Nat.succ_mod_two]; exact Nat.mod_two_ne_iff.1 (by assumption)
  simp [h0, hn, n] at h_parity
