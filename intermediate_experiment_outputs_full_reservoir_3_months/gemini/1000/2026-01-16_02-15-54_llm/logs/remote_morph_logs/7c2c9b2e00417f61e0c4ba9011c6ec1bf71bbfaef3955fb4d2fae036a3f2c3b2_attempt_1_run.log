import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let n := 2021
  let c (q : Position) (k : ℕ) : ℤ := (Finset.univ.filter (λ i : Fin n => q i < k ∧ q (i + 1) ≥ k)).card
  by_contra h
  simp only [not_exists, not_or, not_and, not_lt, @and_comm (_ ≤ _), ← not_lt] at h
  have h_swap : ∀ k : Fin n, (p.nth k).swapped k = (a, b) → (a < k ↔ b < k) := by
    intro k a_b_eq
    have h_k := h k
    rw [a_b_eq] at h_k
    rcases h_k with ⟨h1, h2⟩
    constructor <;> intro hk
    · by_contra hb; exact h1 hk (not_lt.mp hb)
    · by_contra ha; exact h2 hk (not_lt.mp ha)
  have h_step : ∀ k : Fin n, c (p.nth (k + 1)) (k + 1) = c (p.nth k) k + 1 := by
    intro k
    let pk := p.nth k
    let h_k := pk.symm k
    let a := pk (h_k - 1)
    let b := pk (h_k + 1)
    have ha_hb : pk.swapped k = (a, b) := rfl
    have h_ab := h_swap k ha_hb
    let pk1 := (move (pk, k)).1
    have h_c_pk1 : c pk1 k = c pk k := by
      let s (q : Position) := (Finset.univ.filter (λ i : Fin n => q i < k ∧ q (i + 1) ≥ k))
      have : s pk1 = s pk := by
        ext i
        simp only [Finset.mem_filter, Finset.mem_univ, true_and]
        let h_i := i; let h_i1 := i + 1
        if hi : h_i = h_k - 1 then
          simp [hi, pk1, a, b]; constructor <;> intro ⟨h_1, h_2⟩ <;> refine ⟨?_, ?_⟩
          · rwa [← h_ab]
          · exact h_2
          · rwa [h_ab]
          · exact h_2
        else if hi' : h_i1 = h_k - 1 then
          simp [hi', pk1, a, b]; constructor <;> intro ⟨h_1, h_2⟩ <;> refine ⟨?_, ?_⟩
          · exact h_1
          · rwa [← h_ab]
          · exact h_1
          · rwa [h_ab]
        else if hj : h_i = h_k then
          simp [hj, pk1, a, b]
        else if hj' : h_i1 = h_k then
          simp [hj', pk1, a, b]
        else
          have : pk1 h_i = pk h_i ∧ pk1 h_i1 = pk h_i1 := by
            simp [pk1, a, b]; constructor <;> apply Equiv.swap_apply_of_ne_of_ne <;>
            intro heq <;> apply_fun pk.symm at heq <;> simp at heq
            · exact hi (heq.symm)
            · have : h_i = h_k + 1 := heq.symm; exact hj (this ▸ rfl)
            · have : h_i1 = h_k - 1 := heq.symm; exact hi' (this ▸ rfl)
            · exact hj' (heq.symm)
          rw [this.1, this.2]
      simp [c, this]
    have h_c_next : c pk1 (k + 1) = c pk1 k + 1 := by
      let s (k' : ℕ) := (Finset.univ.filter (λ i : Fin n => pk1 i < k' ∧ pk1 (i + 1) ≥ k'))
      have : (s (k + 1)).card = (s k).card + 1 := by
        have : ∀ i, (pk1 i < k + 1 ∧ pk1 (i + 1) ≥ k + 1) ↔ (pk1 i < k ∧ pk1 (i + 1) ≥ k) ∨ (pk1 i = k ∧ pk1 (i + 1) > k) := by
          intro i; constructor <;> intro h_cond
          · by_cases h_pk : pk1 i = k
            · right; exact ⟨h_pk, h_cond.2⟩
            · left; exact ⟨lt_of_le_of_ne (nat_le_of_lt_succ h_cond.1) h_pk, h_cond.2⟩
          · rcases h_cond with ⟨h1, h2⟩ | ⟨h1, h2⟩
            · exact ⟨h1.trans (lt_add_one k), h2⟩
            · exact ⟨h1.symm ▸ (lt_add_one k), h2⟩
        have h_disj : ∀ i, ¬((pk1 i < k ∧ pk1 (i + 1) ≥ k) ∧ (pk1 i = k ∧ pk1 (i + 1) > k)) := by intro i h_c; simp at h_c; exact h_c.2.1.ne h_c.1.1.ne.symm
        rw [Finset.filter_or]
        simp [Finset.card_union_of_disjoint (Finset.disjoint_filter.mpr h_disj)]
        have : (Finset.univ.filter (λ i => pk1 i = k ∧ pk1 (i + 1) > k)).card = 1 := by
          have : ∃! i, pk1 i = k := ⟨pk1.symm k, by simp, λ i hi => by simp [← hi]⟩
          rcases this with ⟨i, hi, h_uni⟩
          have h_next : pk1 (i + 1) > k := by
            have : pk1 (i + 1) ≠ pk1 i := pk1.injective.ne (Fin.ne_of_vne (by simp))
            rw [hi] at this; exact lt_of_le_of_ne (Fin.zero_le _) this.symm
          simp [hi, h_next]; exact Finset.card_singleton i
        exact this
      exact this
    rw [h_c_next, h_c_pk1, Nat.cast_add, Nat.cast_one]
  have : c (p.nth n) n = n := by
    induction n with
    | zero => simp [c]
    | succ k ih =>
      have h_k : (k : Fin 2021) := ⟨k, Nat.lt_succ_self k⟩
      rw [h_step h_k, ih, Nat.cast_add, Nat.cast_one]
  have h_cn : c (p.nth n) n = 0 := by
    simp [c]; ext i; simp [Fin.is_lt]
  simp [h_cn] at this
