import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  contrapose!
  intro h
  let n := 2021
  let w1 k := ((p.nth k).swapped k).1
  let w2 k := ((p.nth k).swapped k).2
  have h_sign k : (w1 k < k ∧ w2 k < k) ∨ (w1 k > k ∧ w2 k > k) := by
    have h1 := h k
    have h2 : w1 k ≠ k := by
      intro h_eq
      have : (p.nth k) ((p.nth k).symm k - 1) = k := h_eq
      have : (p.nth k).symm k - 1 = (p.nth k).symm k := (p.nth k).injective this
      exact (show (1 : Fin n) ≠ 0 by decide) (sub_eq_iff_eq_add.mp this.symm)
    have h3 : w2 k ≠ k := by
      intro h_eq
      have : (p.nth k) ((p.nth k).symm k + 1) = k := h_eq
      have : (p.nth k).symm k + 1 = (p.nth k).symm k := (p.nth k).injective this
      exact (show (1 : Fin n) ≠ 0 by decide) (add_left_eq_self.mp this)
    omega
  let L := {k : Fin n | w1 k < k ∧ w2 k < k}
  let R := {k : Fin n | w1 k > k ∧ w2 k > k}
  have h_union : L ∪ R = Set.univ := by
    ext k; simp [L, R]; exact h_sign k
  have h_disj : Disjoint L R := Set.disjoint_left.mpr (fun k hl hr ↦ by omega)
  have h_sum : ∑ k, (w1 k + w2 k) = 2 * ∑ k, k := by
    let f k h := if h = (p.nth k).symm k - 1 ∨ h = (p.nth k).symm k + 1 then 1 else 0
    have h1 : ∑ k, (w1 k + w2 k) = ∑ k, ∑ h, f k h * (p.nth k) h := by
      apply Fintype.sum_congr; intro k
      simp [f, w1, w2, Fin.sum_univ_two, add_comm]
      have : (p.nth k).symm k - 1 ≠ (p.nth k).symm k + 1 := by
        intro h_eq
        have : (1 : Fin n) = -1 := add_left_cancel (sub_eq_iff_eq_add.mp h_eq.symm)
        exact (show (2 : Fin n) ≠ 0 by decide) (add_eq_zero_iff_neg_eq.mpr this)
      simp [this, add_comm]
    have h2 : ∑ k, ∑ h, f k h * (p.nth k) h = ∑ h, ∑ k, f k h * (p.nth k) h := Finset.sum_comm
    have h3 h : ∑ k, f k h = 2 := by
      simp [f, ← Set.mem_setOf_eq, (show 2 = Fintype.card (Fin 2) by decide)]
      let g (k : Fin n) : Fin n := (p.nth k).symm k
      have : ∀ k, p.nth (k + 1) = (p.nth k).trans (Equiv.swap (w1 k) (w2 k)) := fun k ↦ rfl
      have : ∀ k, (p.nth (k + 1)).symm k = (p.nth k).symm k := fun k ↦ by
        simp [this, w1, w2]; rw [Equiv.swap_apply_of_ne_of_ne] <;>
        { intro h_eq; have := (p.nth k).injective h_eq; exact (show (1 : Fin n) ≠ 0 by decide) (by omega) }
      have h_idx k : g k = (p.nth 0).symm k := by
        induction k using Fin.induction with | zero => rfl | succ k ih => rw [← ih]; exact (this k).symm
      simp [g, h_idx, (p.nth 0).symm.injective.eq_iff]
      exact (show Fintype.card {k | k = h + 1 ∨ k = h - 1} = 2 by apply Fintype.card_eq_of_equiv; exact Equiv.sumCompl _ _)
