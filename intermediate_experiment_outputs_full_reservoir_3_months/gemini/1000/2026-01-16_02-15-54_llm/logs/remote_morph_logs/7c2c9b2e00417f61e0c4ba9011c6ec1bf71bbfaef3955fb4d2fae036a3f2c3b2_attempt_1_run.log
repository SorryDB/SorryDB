    let S (k' : ℕ) := (Finset.univ : Finset (Fin n)).filter (λ i => pk k' i < k ∧ pk k' (i + 1) < k)
    have h_Sk : m k = (S k).card := rfl
    have h_Sk1 : m (k + 1) ≡ (S (k + 1)).card + (if a < k ∧ b < k then 2 else 0) [MOD 2] := by
      let Sk1_edges := (Finset.univ : Finset (Fin n)).filter (λ i => pk (k + 1) i < k + 1 ∧ pk (k + 1) (i + 1) < k + 1)
      have : m (k + 1) = Sk1_edges.card := rfl
      let Sk1_no_k := Sk1_edges.filter (λ i => pk (k + 1) i ≠ k ∧ pk (k + 1) (i + 1) ≠ k)
      let Sk1_with_k := Sk1_edges.filter (λ i => pk (k + 1) i = k ∨ pk (k + 1) (i + 1) = k)
      have h_disj : Disjoint Sk1_no_k Sk1_with_k := Finset.disjoint_filter.mpr (λ x _ => by simp)
      rw [this, ← Finset.card_union_of_disjoint h_disj, ← Sk1_no_k.union_filter_filter_clear]
      have : Sk1_no_k = S (k + 1) := by
        ext i; simp [S, pk, h_next]; constructor <;> intros <;> (try constructor) <;> (try assumption) <;> omega
      have : Sk1_with_k.card = if a < k ∧ b < k then 2 else 0 := by
