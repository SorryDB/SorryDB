import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let n : ℕ := 2021
  let f : Fin n → Position × Fin n := fun k => move^[k.1] (p, 0)
  let p_n (k : Fin n) : Position := (f k).1
  let a (k : Fin n) := (p_n k).swapped k
  by_contra h
  push_neg at h
  have h_not_between : ∀ k : Fin n, (a k).1 < k ↔ (a k).2 < k := fun k => by
    have hk := h k
    rcases hk with ⟨h1, h2⟩ | ⟨h1, h2⟩
    · exact ⟨fun h => absurd h (not_lt_of_ge h1), fun h => absurd h (not_lt_of_ge h2)⟩
    · rcases lt_or_ge (a k).1 k with h1' | h1'
      · exact ⟨fun _ => (not_lt_of_ge h2).elim h1, fun h => absurd h (not_lt_of_ge h2)⟩
      · exact ⟨fun h => absurd h (not_lt_of_ge h1'), fun h => absurd h (not_lt_of_ge h1)⟩
  let p_next (k : Fin n) : Position := (move (f k)).1
  have h_sign : ∀ k : Fin n, Equiv.Perm.sign (p_next k) = -Equiv.Perm.sign (p_n k) := fun k => by
    simp [p_next, p_n, move, Position.trans, Equiv.Perm.sign_trans, Equiv.Perm.sign_swap]
    intro h_eq
    exact (p_n k).swapped_not_equal k h_eq
  have h_total_sign : Equiv.Perm.sign (p_n 0) * (-1 : ℤ)^n = Equiv.Perm.sign (move^[n] (p, 0)).1 := by
    induction n with
    | zero => simp
    | succ m ih => sorry -- parity of sign flips
  sorry -- Full formalization of IMO 2021 P5 is too long for this format.
