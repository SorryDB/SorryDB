import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let n := 2021
  by_contra! h
  let S (k : ℕ) := {i : Fin n | (Position.nth p (k : Fin n) i).1 < k}
  let E (k : ℕ) := (Finset.univ : Finset (Fin n)).filter (fun i ↦ (i ∈ S k) ≠ (i + 1 ∈ S k))
  have hE : ∀ k : Fin n, (E (k + 1)).card ≡ (E k).card + 2 [ZMOD 4] := fun k ↦ by
    let pk := Position.nth p k; let hk := pk.symm k
    let a := (pk.swapped k).1; let b := (pk.swapped k).2
    have hab : (a < k) = (b < k) := by
      let h_k := h k; simp [Position.swapped] at h_k
      cases' (a : Fin n).lt_or_gt k with ha ha
      · cases' (b : Fin n).lt_or_gt k with hb hb
        · rfl
        · exact (h_k.1 ha hb).elim
      · cases' (b : Fin n).lt_or_gt k with hb hb
        · exact (h_k.2 hb ha).elim
        · rfl
    have p_next : Position.nth p (k + 1 : ℕ) = pk.trans (Equiv.swap a b) := by
      rw [Position.nth, Function.iterate_succ', move]; rfl
    have hSk : S (k + 1) = S k ∪ {hk} := by
      ext i; simp [S, p_next]; rw [Equiv.trans_apply, Equiv.swap_apply]
      split_ifs with h1 h2
      · simp [h1, ← pk.apply_symm_apply k]; exact ⟨fun _ ↦ Nat.lt_succ_self _, fun _ ↦ ⟨a, hab.symm.trans (pk.symm_apply_apply i ▸ h1 ▸ pk.apply_symm_apply k ▸ ha)⟩⟩
      · rw [h2, ← pk.apply_symm_apply k]; exact ⟨fun _ ↦ Nat.lt_succ_self _, fun _ ↦ ⟨b, hab.trans (pk.symm_apply_apply i ▸ h2 ▸ pk.apply_symm_apply k ▸ hb)⟩⟩
      · have : pk i ≠ k := fun h_eq ↦ h1 (pk.symm_apply_eq.2 h_eq.symm)
        rw [Nat.lt_succ_iff, ← pk.apply_symm_apply k, Nat.lt_iff_le_and_ne, and_comm, ne_comm]
        exact and_congr_left (fun _ ↦ this)
    have h_cut : (E (k + 1)).card = (E k).card + 2 - 4 * (if hk - 1 ∈ S k then 1 else 0) := by
      simp [E, hSk]; set d := if hk - 1 ∈ S k then 1 else 0
      have : (hk ∈ S k) = False := by simp [S, pk.apply_symm_apply k]
      have : (hk - 1 ∈ S k) = (hk + 1 ∈ S k) := by simp [S, Position.swapped] at hab; exact hab
      generalize h_m1 : hk - 1 = m1; generalize h_p1 : hk + 1 = p1
      have h_m1_ne : m1 ≠ hk := by rw [← h_m1]; exact (pk.symm_apply_apply k).symm ▸ (Fin.sub_one_ne_self hk (by decide))
      have h_p1_ne : p1 ≠ hk := by rw [← h_p1]; exact (pk.symm_apply_apply k).symm ▸ (Fin.add_one_ne_self hk (by decide))
      rw [Finset.card_filter_ne_adj, Finset.card_filter_ne_adj]
      repeat rw [Finset.sum_ite, Finset.sum_ite]; simp [this]
      rw [Finset.sum_singleton, Finset.sum_singleton, Finset.sum_singleton, Finset.sum_singleton]
      simp [h_m1_ne, h_p1_ne]; split_ifs <;> omega
    rw [Int.ModEq, h_cut]; simp; ring_nf; rfl
  have h0 : (E 0).card = 0 := by simp [E, S, Position.nth]
  have hn : (E n).card = 0 := by simp [E, S, n, Position.nth]; exact Finset.card_eq_zero.2 (by simp)
  have : (E n).card ≡ (E 0).card + 2 * n [ZMOD 4] := by
    clear hn h0; induction' n with k ih; · rfl
    rw [Nat.cast_succ, mul_add, ← Int.add_assoc]; exact ih.trans (hE (k : Fin 2021))
  simp [h0, hn, n] at this
  norm_num at this
