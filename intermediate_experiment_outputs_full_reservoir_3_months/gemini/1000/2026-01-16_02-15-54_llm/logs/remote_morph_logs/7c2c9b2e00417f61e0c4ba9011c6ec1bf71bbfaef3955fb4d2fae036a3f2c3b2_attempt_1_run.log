import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  by_contra! h
  let pk (k : ℕ) := (move^[k] (p, 0)).1
  let V (k : ℕ) (i : Fin 2021) := pk k i < (k : ℕ)
  let E (k : ℕ) := (Finset.univ : Finset (Fin 2021)).filter (λ i => V k i ∧ V k (i + 1)).card
  have step (k : ℕ) (hk : k < 2021) : E (k + 1) % 2 = E k % 2 := by
    let sk := (pk k).swapped (k : Fin 2021)
    have sab : sk.1 < (k : ℕ) ↔ sk.2 < (k : ℕ) := by
      have := h k; have h1 : sk.1 ≠ (k : ℕ) := by simp [sk, Position.swapped, pk]; have h2 : sk.2 ≠ (k : ℕ) := by simp [sk, Position.swapped, pk]; omega
    have hV : ∀ i, V (k + 1) i = (V k i || (i == (pk k).symm (k : Fin 2021))) := by
      intro i; simp [V, pk, pk, sab, Nat.lt_succ_iff_lt_or_eq]; apply or_congr_left; simp [move, Position.swapped]; let a := sk.1; let b := sk.2; let x := pk k i
      cases Equiv.swap a b x < (k : ℕ) <;> cases x < (k : ℕ) <;> simp_all [a, b, x, Equiv.swap_apply_def] <;> omega
    let hk := (pk k).symm (k : Fin 2021)
    have : (pk k) hk = (k : ℕ) := by simp [hk]
    have : ¬V k hk := by simp [V, this]
    simp [E, hV, Finset.filter_or, Finset.filter_and, this]
    repeat rw [Finset.card_union_eq_empty_inter]
    · simp; let c1 := (if V k (hk + 1) then 1 else 0); let c2 := (if V k (hk - 1) then 1 else 0)
      have : c1 = c2 := by simp [c1, c2, V, Position.swapped, sab, hk]
      omega
    all_goals { simp [Finset.disjoint_left]; intro x; simp; intro hx; cases hx <;> omega }
  have : E 2021 % 2 = E 0 % 2 := by
    let rec ind : ∀ k ≤ 2021, E k % 2 = E 0 % 2
      | 0, _ => rfl
      | k + 1, hk => by rw [step k (by omega), ind k (by omega)]
    apply ind 2021 (by omega)
  simp [E, V, pk] at this
