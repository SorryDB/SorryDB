import Mathlib


namespace IMO2021P5

/-- The arrangement of walnuts, as an equiv from holes to walnuts (0-based). -/
abbrev Position : Type := Fin 2021 ≃ Fin 2021

/-- The numbers of the walnuts swapped in move `k` (0-based), given the position. -/
def Position.swapped (p : Position) (k : Fin 2021) : Fin 2021 × Fin 2021 :=
  (p ((p.symm k) - 1), p ((p.symm k) + 1))

/-- A single move, on a pair of position and move number. -/
def move (p : Position × Fin 2021) : Position × Fin 2021 :=
  (p.1.trans (Equiv.swap (p.1.swapped p.2).1 (p.1.swapped p.2).2), p.2 + 1)

/-- The position after `n` moves. -/
def Position.nth (p : Position) (n : Fin 2021) : Position := (move^[n] (p, 0)).1

theorem result (p : Position) :
    ∃ k, (((p.nth k).swapped k).1 < k ∧ k < ((p.nth k).swapped k).2) ∨
      (((p.nth k).swapped k).2 < k ∧ k < ((p.nth k).swapped k).1) := by
  let n := 2021
  let x (k : Fin n) (w : Fin n) : Fin n := (p.nth k).symm w
  let a (k : Fin n) : Fin n := ((p.nth k).swapped k).1
  let b (k : Fin n) : Fin n := ((p.nth k).swapped k).2
  let s (k : Fin n) := (a k < k ∧ k < b k) ∨ (b k < k ∧ k < a k)
  by_contra h; push_neg at h
  have h_move (k : Fin n) : (p.nth (k + 1)) = (p.nth k).trans (Equiv.swap (a k) (b k)) := by
    rw [Position.nth, Function.iterate_succ', Function.comp_apply, move]
    congr; simp [Position.nth, a, b]
  have h_sgn (k : Fin n) : Equiv.Perm.sign (p.nth (k + 1)).symm = - Equiv.Perm.sign (p.nth k).symm := by
    rw [h_move, Equiv.trans_assoc, Equiv.symm_trans, Equiv.Perm.sign_trans, Equiv.Perm.sign_swap (Fin.ne_of_gt (by
      have := h k; cases this with | h1 => exact h1.1.trans h1.2 | h2 => exact h2.1.trans h2.2))]
    simp
  have h_sgn_n : Equiv.Perm.sign (move^[n] (p, 0)).1.symm = - Equiv.Perm.sign p.symm := by
    let f (i : ℕ) := Equiv.Perm.sign (move^[i] (p, 0)).1.symm
    have hf (i : Fin n) : f (i + 1) = - f i := by
      convert h_sgn i using 1
      · rfl
      · rfl
    have : f n = (-1)^n * f 0 := by
      induction n with
      | zero => simp
      | succ n ih =>
        rw [pow_succ, mul_assoc, ← ih, ← hf]
        · congr
        · simp [n]
    rw [this]; simp [n]
  let inv_sum (p : Position) : ℤ := ∑ i : Fin n, ∑ j : Fin n, if i < j ∧ p.symm j < p.symm i then (1 : ℤ) else 0
