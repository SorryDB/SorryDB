  let bd (k : ℕ) : ℕ := (Finset.univ : Finset (Fin n)).filter (λ j => pos k j < k ∧ pos k (j + 1) ≥ k).card
  have step (k : Fin n) : bd (k + 1) % 2 = (bd k + 1) % 2 := by
    let pk := pos k
    let jk := pk.symm k
    let a := pk (jk - 1)
    let b := pk (jk + 1)
    have ha : a < k ∨ a > k := by
