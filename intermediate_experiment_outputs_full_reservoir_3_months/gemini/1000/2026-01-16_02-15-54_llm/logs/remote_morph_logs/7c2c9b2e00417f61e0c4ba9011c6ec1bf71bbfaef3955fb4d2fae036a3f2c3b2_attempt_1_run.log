        refine Finset.card_congr (λ j _ => j) ?_ ?_ ?_ <;> simp [S, h_holes]
      have h2 : (S (k + 1) pk1).card % 2 = ((S k pk1).card + 1) % 2 := by
        let H := (Finset.univ : Finset (Fin n)).filter (λ j => pk1 j < k)
