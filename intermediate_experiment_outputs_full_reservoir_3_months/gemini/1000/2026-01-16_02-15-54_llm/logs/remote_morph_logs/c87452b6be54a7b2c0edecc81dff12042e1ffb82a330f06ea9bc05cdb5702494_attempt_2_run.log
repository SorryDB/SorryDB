    cases ra : roleOfIn a C -- "For σ = τ.acᴷ ..."
    case Caller =>
      -- "... we distinguish two cases."
      by_cases h : eval S ⟨σ,⁻o⟩ (Kv a b)
      · -- "Either already ...""
        specialize IH (⁻o) h
