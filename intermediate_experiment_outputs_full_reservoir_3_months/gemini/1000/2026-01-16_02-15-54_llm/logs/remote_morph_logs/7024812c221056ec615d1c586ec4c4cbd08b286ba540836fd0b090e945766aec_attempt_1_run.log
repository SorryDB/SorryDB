  otherWrites.any fun write' =>
    let scope1 := state.scopes.jointScope previousWrite.thread write'.thread;
    state.orderConstraints.lookup scope1 previousWrite.id write'.id &&
      let scope2 := state.scopes.jointScope rmwWrite.thread write'.thread;
      state.orderConstraints.lookup scope2 write'.id rmwWrite.id
failedOtherRMW : Bool :=
  (List.filter (fun req => Option.map Request.id (state.rmwGetPreviousWrite? req.id) == some previousWrite.id)
        otherWrites).any
    Request.conditionalSucceeded
failed : Bool := failedWriteBetween || failedOtherRMW
rmwWrite' : Request :=
  if failed = true then rmwWrite.updateValue none
  else
    if (!rmwWrite.conditionalTentativeOrSuccessful) = true then rmwWrite.updateValue previousWrite.value? else rmwWrite
removedWrites : List Request :=
  state.requests.filter Request.conditionalFailed ++ if failed = true then [rmwWrite'] else []
removed' : List Request := ((removedWrites ++ state.removed).toArray.qsort fun r₁ r₂ => Nat.ble r₁.id r₂.id).toList
requestsRemoved : RequestArray := List.foldl (fun arr req => arr.remove req.id) state.requests removedWrites
requests' : RequestArray := if failed = true then requestsRemoved else requestsRemoved.insert rmwWrite'
⊢ ∀ (a : Request), a ∈ removed' → a.id ∈ reqIds requests'
  state.removedCoherent

