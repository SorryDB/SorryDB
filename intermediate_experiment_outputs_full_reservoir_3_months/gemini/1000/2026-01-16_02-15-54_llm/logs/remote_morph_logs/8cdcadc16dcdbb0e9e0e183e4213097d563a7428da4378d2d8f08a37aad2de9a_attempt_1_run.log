  have hb : 0 < b := by linarith
  have hc : 0 < c := by linarith
  have h_jensen : a * Real.log a + b * Real.log b + c * Real.log c + d * Real.log d ≤ Real.log (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) := by
    let w : Fin 4 → ℝ := ![a, b, c, d]
    let z : Fin 4 → ℝ := ![a, b, c, d]
    have h_sum_w : ∑ i, w i = 1 := by simp [w, Fin.sum_univ_four, h1]
    convert Real.concaveOn_log.map_sum_le h_sum_w (λ i _ => (by fin_cases i <;> linarith : 0 ≤ w i)) (λ i _ => (by fin_cases i <;> linarith : z i ∈ Set.Ioi 0))
    simp [w, z, Fin.sum_univ_four]
  calc
    (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d
        = Real.exp (Real.log (a + 2 * b + 3 * c + 4 * d) + a * Real.log a + b * Real.log b + c * Real.log c + d * Real.log d) := by
      rw [Real.exp_add, Real.exp_log (by linarith)]
      simp_rw [Real.rpow_def_of_pos (by linarith), ← Real.exp_add]
    _ ≤ Real.exp (Real.log (a + 2 * b + 3 * c + 4 * d) + Real.log (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2)) := by
      gcongr
    _ = (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) := by
      rw [← Real.log_mul (by linarith) (by positivity), Real.exp_log (by positivity)]
    _ < 1 := by
      nlinarith

