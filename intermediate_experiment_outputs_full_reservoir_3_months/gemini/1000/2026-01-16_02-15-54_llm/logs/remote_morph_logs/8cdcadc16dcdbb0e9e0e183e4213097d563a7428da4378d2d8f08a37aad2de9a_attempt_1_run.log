import Mathlib


namespace IMO2020P2

theorem result {a b c d : ℝ} (hd0 : 0 < d) (hdc : d ≤ c) (hcb : c ≤ b) (hba : b ≤ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have ha : 0 < a := by linarith
  have hb : 0 < b := by linarith
  have hc : 0 < c := by linarith
  have hd : 0 < d := hd0
  have h_jensen : a * Real.log a + b * Real.log b + c * Real.log c + d * Real.log d ≤
      Real.log (a * a + b * b + c * c + d * d) := by
    let w : Fin 4 → ℝ := ![a, b, c, d]
    let x : Fin 4 → ℝ := ![a, b, c, d]
    have hw : ∑ i, w i = 1 := by rw [Fin.sum_univ_four]; exact h1
    have hw_pos : ∀ i, w i ∈ Set.Ici 0 := by intro i; fin_cases i <;> linarith
    have hx_pos : ∀ i, x i ∈ Set.Ioi 0 := by intro i; fin_cases i <;> linarith
    have hj := Real.concaveOn_log.sum_le_log_sum hw hw_pos hx_pos
    rw [Fin.sum_univ_four, Fin.sum_univ_four] at hj
    exact hj
  have h_prod : a ^ a * b ^ b * c ^ c * d ^ d ≤ a * a + b * b + c * c + d * d := by
    rw [Real.rpow_def_of_pos ha, Real.rpow_def_of_pos hb, Real.rpow_def_of_pos hc, Real.rpow_def_of_pos hd]
    rw [← Real.exp_add, ← Real.exp_add, ← Real.exp_add, ← Real.log_exp (a * a + b * b + c * c + d * d)]
    apply Real.exp_le_exp.mpr
    rw [Real.log_exp]
    exact h_jensen
  have h_poly : (a + 2 * b + 3 * c + 4 * d) * (a * a + b * b + c * c + d * d) < 1 := by
    have h_diff : (a + b + c + d) ^ 3 - (a + 2 * b + 3 * c + 4 * d) * (a * a + b * b + c * c + d * d) =
      a^2 * (b - d) + b^2 * (2 * a - b + c - d) + c^2 * (2 * a + b - 2 * c + d) +
      d^2 * (2 * a + 2 * b + 3 * c - 3 * d) + 6 * a * b * c + 6 * a * b * d + 6 * a * c * d + 6 * b * c * d := by ring
    rw [← h1, ← h_diff]
    have : 0 < a^2 * (b - d) + b^2 * (2 * a - b + c - d) + c^2 * (2 * a + b - 2 * c + d) +
      d^2 * (2 * a + 2 * b + 3 * c - 3 * d) + 6 * a * b * c + 6 * a * b * d + 6 * a * c * d + 6 * b * c * d := by
      have h1 : 0 ≤ a^2 * (b - d) := by nlinarith
      have h2 : 0 < b^2 * (2 * a - b + c - d) := by nlinarith
      have h3 : 0 < c^2 * (2 * a + b - 2 * c + d) := by nlinarith
      have h4 : 0 < d^2 * (2 * a + 2 * b + 3 * c - 3 * d) := by nlinarith
      nlinarith
    linarith
  have h_apow_pos : 0 < a ^ a * b ^ b * c ^ c * d ^ d := by
    repeat apply mul_pos <;> apply Real.rpow_pos_of_pos <;> linarith
  have h_S_pos : 0 < a + 2 * b + 3 * c + 4 * d := by linarith
  nlinarith

