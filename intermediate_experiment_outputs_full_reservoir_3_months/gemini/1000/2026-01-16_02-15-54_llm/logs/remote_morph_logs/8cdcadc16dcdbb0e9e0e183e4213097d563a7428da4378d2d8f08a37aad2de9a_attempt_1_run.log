  have h_jensen : a * Real.log a + b * Real.log b + c * Real.log c + d * Real.log d ≤ Real.log (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) := by
    let w : Fin 4 → ℝ := ![a, b, c, d]
    let x : Fin 4 → ℝ := ![a, b, c, d]
    have hsum : ∑ i, w i = 1 := by simp [w, h1]
    have h_concave : ConcaveOn ℝ (Set.Ioi 0) Real.log := Real.concaveOn_log
