theorem result {a b c d : ℝ} (hd0 : 0 < d) (hdc : d ≤ c) (hcb : c ≤ b) (hba : b ≤ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have ha : 0 < a := hd0.trans_le (hdc.trans (hcb.trans hba))
  have hb : 0 < b := hd0.trans_le (hdc.trans hcb)
  have hc : 0 < c := hd0.trans_le hdc
  have h_am_gm : a ^ a * b ^ b * c ^ c * d ^ d ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2 := by
    let w : Fin 4 → ℝ := ![a, b, c, d]
    let x : Fin 4 → ℝ := ![a, b, c, d]
    have hw : ∀ i, 0 ≤ w i := by intro i; fin_cases i <;> dsimp <;> linarith
    have hsw : ∑ i, w i = 1 := by simp [h1]
    have hx : ∀ i, 0 ≤ x i := by intro i; fin_cases i <;> dsimp <;> linarith
    have h := Real.geom_mean_le_arith_mean_weighted Finset.univ w x (λ i _ => hw i) hsw (λ i _ => hx i)
    simp [Finset.sum_univ_four, Finset.prod_univ_four, pow_two] at h
    exact h
  have h_poly : (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) < 1 := by
    calc
      (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2)
        < (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) +
          (a^2*(b-d) + b^2*(2*a-b-d) + c^2*(2*a+b-2*c-d) + d^2*(2*a+b-3*d) + 6*(a*b*c+a*b*d+a*c*d+b*c*d)) := by nlinarith
      _ = (a + b + c + d) ^ 3 := by ring
      _ = 1 := by rw [h1]; norm_num
  nlinarith

