theorem result {a b c d : ℝ} (hd0 : 0 < d) (hdc : d ≤ c) (hcb : c ≤ b) (hba : b ≤ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have h_pos : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d := by nlinarith
  have h_am_gm : a ^ a * b ^ b * c ^ c * d ^ d ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2 := by
    rw [Real.rpow_def h_pos.1, Real.rpow_def h_pos.2.1, Real.rpow_def h_pos.2.2.1, Real.rpow_def h_pos.2.2.2]
    rw [← Real.exp_add, ← Real.exp_add, ← Real.exp_add]
    apply Real.exp_le_of_add_le
    let w : Fin 4 → ℝ := ![a, b, c, d]
    let x : Fin 4 → ℝ := ![a, b, c, d]
    have hw : ∀ i, 0 ≤ w i := by intro i; fin_cases i <;> (simp [w]; nlinarith)
    have hws : ∑ i, w i = 1 := by simp [w, h1]
    have hx : ∀ i, 0 < x i := by intro i; fin_cases i <;> (simp [x]; nlinarith)
    have hj := concaveOn_log_Ioi.map_sum_le hw hws (λ i _ => hx i)
    simp [w, x] at hj
    exact hj
  have h_poly : (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) < 1 := by
    have h_exp : (a + b + c + d) ^ 3 - (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) =
      a ^ 2 * (b - d) + b ^ 2 * (2 * a - b - d) + c ^ 2 * (2 * a + b - 2 * c - d) +
      d ^ 2 * (2 * a + b - 3 * d) + 6 * a * b * c * d := by ring
