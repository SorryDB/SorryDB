theorem result {a b c d : ℝ} (hd0 : 0 < d) (hdc : d ≤ c) (hcb : c ≤ b) (hba : b ≤ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have hc : 0 < c := hd0.trans_le hdc
  have hb : 0 < b := hc.trans_le hcb
  have ha : 0 < a := hb.trans_le hba
  have h_jensen : a * Real.log a + b * Real.log b + c * Real.log c + d * Real.log d ≤ Real.log (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) := by
    let w : Fin 4 → ℝ := ![a, b, c, d]
    let x : Fin 4 → ℝ := ![a, b, c, d]
    have hw : (∑ i, w i) = 1 := by simp [h1]
    have h_w_pos : ∀ i, 0 ≤ w i := by intro i; fin_cases i <;> linarith
    have h_mem : ∀ i, x i ∈ Set.Ioi 0 := by intro i; fin_cases i <;> simp [*]
    convert Real.concaveOn_log.le_log_sum_weight h_w_pos hw h_mem
    simp; ring
  have h_rpow : a ^ a * b ^ b * c ^ c * d ^ d ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2 := by
    rw [Real.rpow_def ha, Real.rpow_def hb, Real.rpow_def hc, Real.rpow_def hd,
        ← Real.exp_add, ← Real.exp_add, ← Real.exp_add]
    apply Real.exp_le_of_le_log
    · nlinarith
    · exact h_jensen
  have h_poly : (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) < 1 := by
    nlinarith
  calc (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d
    _ ≤ (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) := by
      gcongr
      nlinarith
    _ < 1 := h_poly

end IMO2020P2
