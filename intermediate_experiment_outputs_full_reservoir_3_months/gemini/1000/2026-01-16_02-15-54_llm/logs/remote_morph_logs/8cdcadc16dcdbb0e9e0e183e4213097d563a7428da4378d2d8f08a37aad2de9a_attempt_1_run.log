namespace IMO2020P2

theorem result {a b c d : ℝ} (hd0 : 0 < d) (hdc : d ≤ c) (hcb : c ≤ b) (hba : b ≤ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have h_a_pos : 0 < a := hd0.trans_le (hdc.trans (hcb.trans hba))
  have h_b_pos : 0 < b := hd0.trans_le (hdc.trans hcb)
  have h_c_pos : 0 < c := hd0.trans_le hdc
  have hj : a * Real.log a + b * Real.log b + c * Real.log c + d * Real.log d ≤ Real.log (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) := by
    let w : Fin 4 → ℝ := ![a, b, c, d]
    have := Real.concaveOn_log.map_sum_le (by simp [w, h1] : ∑ i, w i = 1) (by simp [w]; intro i; fin_cases i <;> linarith) (by simp [w]; intro i; fin_cases i <;> linarith)
    simpa [Finset.univ_fin_four, w, sq] using this
  have h_exp_le : a ^ a * b ^ b * c ^ c * d ^ d ≤ a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2 := by
    rw [Real.rpow_def h_a_pos, Real.rpow_def h_b_pos, Real.rpow_def h_c_pos, Real.rpow_def hd0]
    rw [← Real.exp_add, ← Real.exp_add, ← Real.exp_add]
    refine (Real.exp_le_exp.mpr hj).trans_eq ?_
    rw [Real.exp_log]; nlinarith
  have h_poly : (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) < 1 := by
    have : (a + 2 * b + 3 * c + 4 * d) * (a ^ 2 + b ^ 2 + c ^ 2 + d ^ 2) + a ^ 2 * (b - d) + (b ^ 2 * (a - d) + a * b ^ 2 - b ^ 3) + (c ^ 2 * (a - d) + c ^ 2 * (a + b - 2 * c)) + (d ^ 2 * (a - d) + d ^ 2 * (a + 2 * b - 2 * d)) + 6 * (a * b * c + a * b * d + a * c * d + b * c * d) = (a + b + c + d) ^ 3 := by ring
    nlinarith [this, h1]
  nlinarith [h_exp_le]
