import Mathlib


namespace IMO2020P2

theorem result {a b c d : ℝ} (hd0 : 0 < d) (hdc : d ≤ c) (hcb : c ≤ b) (hba : b ≤ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have h_a_pos : 0 < a := hd0.trans_le (hdc.trans (hcb.trans hba))
  have h_b_pos : 0 < b := hd0.trans_le (hdc.trans hcb)
  have h_c_pos : 0 < c := hd0.trans_le hdc
  have h_all_pos : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d := ⟨h_a_pos, h_b_pos, h_c_pos, hd0⟩
  have h_sum_sq : a * a + b * b + c * c + d * d < 1 := by
    have h_a_lt_1 : a < 1 := by linarith
    calc a * a + b * b + c * c + d * d
      ≤ a * a + b * a + c * a + d * a := by nlinarith
      _ = a * (a + b + c + d) := by ring
      _ = a := by rw [h1]; ring
      _ < 1 := h_a_lt_1
  let w : Fin 4 → ℝ := ![a, b, c, d]
  let z : Fin 4 → ℝ := ![a, b, c, d]
  have h_w_pos : ∀ i, 0 < w i := by intro i; fin_cases i <;> aesop
