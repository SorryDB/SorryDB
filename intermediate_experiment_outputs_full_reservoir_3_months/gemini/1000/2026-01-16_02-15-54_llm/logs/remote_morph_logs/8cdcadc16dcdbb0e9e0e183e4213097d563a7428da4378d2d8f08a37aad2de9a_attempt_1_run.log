import Mathlib


namespace IMO2020P2

theorem result {a b c d : ℝ} (hd0 : 0 < d) (hdc : d ≤ c) (hcb : c ≤ b) (hba : b ≤ a)
    (h1 : a + b + c + d = 1) : (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d < 1 := by
  have ha0 : 0 < a := hd0.trans_le (hdc.trans (hcb.trans hba))
  have hb0 : 0 < b := hd0.trans_le (hdc.trans hcb)
  have hc0 : 0 < c := hd0.trans_le hdc
  have hl : a * Real.log a + b * Real.log b + c * Real.log c + d * Real.log d ≤ Real.log (a^2 + b^2 + c^2 + d^2) := by
    have := Real.concaveOn_log.convex_le_sum ha0 hb0 hc0 hd0 (by linarith) (by linarith) (by linarith) (by linarith) h1
    simp only [Real.log_pow, inv_one, id_eq, map_one, one_mul] at this
    exact this
  have h_exp : a^a * b^b * c^c * d^d ≤ a^2 + b^2 + c^2 + d^2 := by
    rw [← Real.exp_log (by positivity), Real.log_mul (by positivity) (by positivity), Real.log_mul (by positivity) (by positivity), Real.log_mul (by positivity) (by positivity)]
    simp only [Real.log_rpow ha0, Real.log_rpow hb0, Real.log_rpow hc0, Real.log_rpow hd0]
    exact (Real.exp_le_exp.mpr hl).trans (by rw [Real.exp_log]; linarith [ha0, hb0, hc0, hd0])
    all_goals positivity
  have h_poly : (a + 2 * b + 3 * c + 4 * d) * (a^2 + b^2 + c^2 + d^2) < 1 := by
    have h1a : a = 1 - b - c - d := by linarith
    have hb : b ≤ (1 - c - d) / 2 := by linarith
    have hc : c ≤ (1 - d) / 3 := by linarith
    have hd : d ≤ 1 / 4 := by linarith
    nlinarith
  calc (a + 2 * b + 3 * c + 4 * d) * a ^ a * b ^ b * c ^ c * d ^ d
    _ ≤ (a + 2 * b + 3 * c + 4 * d) * (a^2 + b^2 + c^2 + d^2) := by
      apply mul_le_mul_of_nonneg_left h_exp
      linarith
    _ < 1 := h_poly

