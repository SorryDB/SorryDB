      d ^ 2 * (2 * a + b - 3 * d) + 6 * a * b * c * d := by nlinarith
    rw [h1] at h_exp
    nlinarith
  exact (mul_le_mul_of_nonneg_left h_am_gm (by nlinarith)).trans_lt h_poly

