  · -- Goal 11: Precondition for `ZZ2`
    sorry
  · -- Goal 12: Precondition for `YY_minus_XX`
    intro i hi
    have hx := h_qX_bounds i hi
    have hy := h_qY_bounds i hi
    scalar_tac
