    match h_constructor : cfd with
    | .same h_same => sorry
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive sorry)[0]'(by simp [h_constructor, ContextFreeDerivation.collectDerivationTreeNodes])).fst
