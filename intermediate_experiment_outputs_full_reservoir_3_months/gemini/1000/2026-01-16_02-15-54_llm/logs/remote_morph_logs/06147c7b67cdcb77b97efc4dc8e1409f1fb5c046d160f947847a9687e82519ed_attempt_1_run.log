open Complex Real in
instance Circle.hasEnoghRootsOfUnity {n : ℕ} [NeZero n] : HasEnoughRootsOfUnity Circle n where
  prim := by
    refine ⟨⟨cexp ((2 * π / n :) * I), ?_⟩, ?_⟩
    · simpa only [Submonoid.mem_unitSphere] using norm_exp_ofReal_mul_I (2 * π / ↑n)
