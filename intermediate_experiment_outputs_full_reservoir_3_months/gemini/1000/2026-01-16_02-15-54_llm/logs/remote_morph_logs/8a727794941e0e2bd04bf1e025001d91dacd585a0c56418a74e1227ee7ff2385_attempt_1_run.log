/--Theorem: A context-free derivation tree has a number of leaves equal to
  the length of the result word.-/
theorem derivation_result_is_leaf_count :
  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  induction dt
  case leaf => rfl
  case inner A children prod ih =>
    simp [ContextFreeGrammar.DerivationTree.result, ContextFreeGrammar.DerivationTree.collectLeaves', Word.len, Word.mk]
    induction children with
    | nil => rfl
    | cons hd tl ih_l =>
      simp [Word.length_mul_eq_add, List.length_append, ih hd (List.mem_cons_self _ _), ih_l]
```
