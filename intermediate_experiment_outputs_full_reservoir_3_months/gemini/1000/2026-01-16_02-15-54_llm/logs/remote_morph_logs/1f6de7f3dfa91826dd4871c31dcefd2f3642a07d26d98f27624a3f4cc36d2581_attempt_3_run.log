import Mathlib


namespace IMO2025P3

/-- The condition on functions in the problem. -/
def Bonza (f : ℕ+ → ℕ+) : Prop := ∀ a b : ℕ+, (f a : ℤ) ∣ (b ^ (a : ℕ) : ℤ) - (f b ^ (f a : ℕ) : ℤ)

/-- The answer to be determined. -/
def answer : ℝ := 4

theorem result : IsLeast {c : ℝ | ∀ f : ℕ+ → ℕ+, Bonza f → ∀ n, f n ≤ c * n}
    answer := by
  refine ⟨fun f hf n ↦ ?_, fun c hc ↦ ?_⟩
  · have h1 : f 1 = 1 := by
      have hf1 : (f 1 : ℤ) ∣ (1 : ℤ) - (f 1 ^ (f 1 : ℕ) : ℤ) := by simpa using hf 1 1
      have : f 1 ∣ 1 ^ (1 : ℕ) - (f 1 ^ (f 1 : ℕ) : ℕ) := by exact_mod_cast hf1
      apply PNat.eq_one_of_dvd_one
      rw [PNat.dvd_iff, Nat.dvd_one_iff_coe, PNat.coe_one]
      exact (Nat.dvd_sub_self (Nat.pow_pos (PNat.pos (f 1)) (f 1))).mp (by exact_mod_cast hf1)
    have h_pow2 : ∀ n, ∃ k, f n = 2^k := by
      intro n
      by_contra hn
      obtain ⟨p, hp, hpd⟩ := Nat.exists_prime_and_dvd (by intro h; cases h; exact hn (by simp))
      obtain ⟨p, hp, hpd⟩ : ∃ p : ℕ, p.Prime ∧ p ∣ f n := ⟨p, hp, hpd⟩
      if hp2 : p = 2 then
        obtain ⟨q, hq, hqd⟩ := Nat.exists_prime_and_dvd (Nat.le_of_dvd (PNat.pos (f n)) hpd)
        sorry -- This path would show f n must be a power of 2
      else
        sorry
    have h_val : ∀ n, (f n : ℤ) ∣ (3 ^ (n : ℕ) : ℤ) - 1 := by
      intro n; simpa [h1] using hf n 1
    have h_v2 : ∀ n, (f n : ℕ) ≤ 2^(n.val.v2 + 2) := sorry
    calc (f n : ℝ) ≤ 2^(n.val.v2 + 2) := by exact_mod_cast h_v2 n
      _ = 4 * 2^n.val.v2 := by rw [pow_add]; norm_num
      _ ≤ 4 * n := by gcongr; exact Nat.pow_v2_le_self n.val n.pos
  · specialize hc (fun n ↦ if n = 1 then 1 else if n.val.IsPowTwo then 2^(n.val.v2 + 2) else 1) sorry 4
    simpa using hc
