    apply Nat.le_trans (Finset.sum_le_card_nsmul S (fun x => x) (fun x hx => Nat.le_of_lt_succ (h₁ hx).2))
    rw [h₀]; norm_num
  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_card (fun A => ∑ x in A, x)
    (by rw [h_card_S_powerset, Finset.card_Icc]; norm_num) h_range
  let S₁ := A \ B
  let S₂ := B \ A
  use S₁, S₂
  have h_sum : ∑ x in S₁, x = ∑ x in S₂, x := by
    have hA' := Finset.sum_subset_add_sum_sdiff (Finset.inter_subset_left A B) (fun x => x)
    have hB' := Finset.sum_subset_add_sum_sdiff (Finset.inter_subset_right A B) (fun x => x)
    rw [Finset.inter_comm] at hB'
    linarith
  have hS1S : S₁ ⊆ S := Finset.subset_trans (Finset.sdiff_subset _ _) (Finset.mem_powerset.1 hA)
  have hS2S : S₂ ⊆ S := Finset.subset_trans (Finset.sdiff_subset _ _) (Finset.mem_powerset.1 hB)
  have hS1ne : S₁.Nonempty := by
