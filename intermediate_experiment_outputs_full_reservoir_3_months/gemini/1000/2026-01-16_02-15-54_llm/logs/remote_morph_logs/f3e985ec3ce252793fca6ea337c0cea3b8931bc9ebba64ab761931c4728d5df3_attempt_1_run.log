import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f : Finset ℕ → ℕ := fun A => ∑ x in A, x
  have hf : ∀ A ∈ S.powerset, f A ∈ Finset.range 991 := by
    intro A hA
    rw [Finset.mem_range]
    calc ∑ x in A, x ≤ ∑ x in A, 99 := Finset.sum_le_sum fun x hx =>
          Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (Finset.mem_powerset.1 hA hx))).2
      _ = A.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
      _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (Finset.card_le_card (Finset.mem_powerset.1 hA) |>.trans h₀.le)
      _ = 990 := rfl
      _ < 991 := by norm_num
  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_card (by
    rw [Finset.card_powerset, h₀, Finset.card_range]; norm_num) f hf
  let S₁ := A \ B
  let S₂ := B \ A
  have hsum12 : ∑ x in S₁, x = ∑ x in S₂, x := by
    have hA' := Finset.sum_sdiff_add_sum_inter (Finset.inter_subset_left A B) (fun x => x)
    have hB' := Finset.sum_sdiff_add_sum_inter (Finset.inter_subset_right A B) (fun x => x)
    rwa [Finset.inter_comm, hsum, Nat.add_right_cancel_iff] at hA'
  have h_empty (T : Finset ℕ) (hT : T ⊆ S) (hTsum : ∑ x in T, x = 0) : T = ∅ := by
    by_contra hTne
    obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.2 hTne
    have : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hT hx))).1
    linarith [Finset.single_le_sum (fun _ _ => Nat.zero_le _) hx]
  have S₁n : S₁.Nonempty := by
    by_contra hS₁ne
    have hS₁e := Finset.not_nonempty_iff_eq_empty.1 hS₁ne
    have hS₂e := h_empty S₂ (Finset.sdiff_subset B A |>.trans (Finset.mem_powerset.1 hB)) (by rwa [← hsum12, hS₁e, Finset.sum_empty])
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁e) (Finset.sdiff_eq_empty_iff_subset.1 hS₂e))
  have S₂n : S₂.Nonempty := by
    by_contra hS₂ne
    have hS₂e := Finset.not_nonempty_iff_eq_empty.1 hS₂ne
    have hS₁e := h_empty S₁ (Finset.sdiff_subset A B |>.trans (Finset.mem_powerset.1 hA)) (by rwa [hsum12, hS₂e, Finset.sum_empty])
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₁e) (Finset.sdiff_eq_empty_iff_subset.1 hS₂e))
  use S₁, S₂
  exact ⟨S₁n, (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA),
    S₂n, (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB), Finset.disjoint_sdiff_sdiff, hsum12⟩

