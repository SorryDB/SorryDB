import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let R := Finset.Icc 0 (∑ x in S, x)
  have h_range : ∀ A ∈ S.powerset, (∑ x in A, x) ∈ R := by
    intro A hA
    simp only [Finset.mem_Icc, Nat.zero_le, true_and]
    exact Finset.sum_le_sum_of_subset (Finset.mem_powerset.1 hA) (fun _ _ ↦ Nat.zero_le _)
  have h_card_R : R.card ≤ 991 := by
    rw [Finset.card_Icc, Nat.sub_zero]
    calc (∑ x in S, x) + 1 ≤ 10 * 99 + 1 := Nat.add_le_add_right (Finset.sum_le_card_nsmul (fun x hx ↦ Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2) |>.trans (by rw [h₀]; rfl)) 1
      _ = 991 := rfl
  have h_card_P : S.powerset.card = 1024 := by rw [Finset.card_powerset, h₀]; rfl
  obtain ⟨A, hA, B, hB, hne, hfAB⟩ := Finset.exists_ne_map_eq_of_card_lt_card (fun A ↦ ∑ x in A, x) h_range (by linarith [h_card_P, h_card_R])
  let S₁ := A \ B
  let S₂ := B \ A
  have hS1S : S₁ ⊆ S := (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA)
  have hS2S : S₂ ⊆ S := (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB)
  have hsum : ∑ x in S₁, x = ∑ x in S₂, x := by
    apply Nat.add_left_cancel (m := ∑ x in A ∩ B, x)
    rw [add_comm, Finset.sum_sdiff_add_sum_inter, Finset.inter_comm, add_comm, Finset.sum_sdiff_add_sum_inter, hfAB]
  have hS_pos : ∀ {C}, C ⊆ S → C.Nonempty → 0 < ∑ x in C, x := by
    intro C hCS ⟨x, hx⟩
    calc 0 < 10 := by norm_num
      _ ≤ x := (Finset.mem_Ico.1 (h₁ (hCS hx))).1
      _ ≤ ∑ x in C, x := Finset.single_le_sum (fun _ _ ↦ Nat.zero_le _) hx
  have hS1ne : S₁.Nonempty := by
    by_contra hS1
    have h1 : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.1 hS1
    have h2 : S₂ = ∅ := by
      by_contra hS2
      have := hS_pos hS2S (Finset.nonempty_iff_ne_empty.2 hS2)
      rw [← hsum, h1] at this
      simp at this
    exact hne (Finset.sdiff_eq_empty_iff_subset.1 h1 |>.antisymm (Finset.sdiff_eq_empty_iff_subset.1 h2))
  have hS2ne : S₂.Nonempty := by
    by_contra hS2
    have h2 : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.1 hS2
    have := hS_pos hS1S hS1ne
    rw [hsum, h2] at this
    simp at this
  use S₁, S₂
  exact ⟨hS1ne, hS1S, hS2ne, hS2S, Finset.disjoint_sdiff_sdiff, hsum⟩

