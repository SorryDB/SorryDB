import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f (A : Finset ℕ) : ℕ := ∑ x in A, x
  have h_range : ∀ SA ∈ S.powerset, f SA ∈ Finset.range 1000 := by
    intro SA hSA
    have hSAS : SA ⊆ S := Finset.mem_powerset.mp hSA
    apply Finset.mem_range.mpr
    calc f SA ≤ f S := Finset.sum_le_sum_of_subset hSAS (λ _ _ => Nat.zero_le _)
         _ ≤ S.card * 99 := Finset.sum_le_card_nsmul S 99 (λ x hx => (Nat.le_of_lt_succ (Finset.mem_Ico.mp (h₁ hx)).2))
         _ = 10 * 99 := by rw [h₀]
         _ < 1000 := by norm_num
  have h_exists : ∃ SA ∈ S.powerset, ∃ SB ∈ S.powerset, SA ≠ SB ∧ f SA = f SB :=
    Finset.exists_ne_map_eq_of_card_lt_card h_range (by rw [Finset.card_powerset, h₀, Finset.card_range]; norm_num)
  rcases h_exists with ⟨SA, hSA, SB, hSB, hne, hsum⟩
  let S1 := SA \ SB
  let S2 := SB \ SA
  have h1S : S1 ⊆ S := (Finset.sdiff_subset ..).trans (Finset.mem_powerset.mp hSA)
  have h2S : S2 ⊆ S := (Finset.sdiff_subset ..).trans (Finset.mem_powerset.mp hSB)
  have h_empty A (hA : A ⊆ S) : f A = 0 ↔ A = ∅ := by
    refine ⟨λ h => Finset.eq_empty_of_forall_not_mem (λ x hx => ?_), λ h => by rw [h]; rfl⟩
    have := (Finset.mem_Ico.mp (h₁ (hA hx))).1
    have := Finset.le_sum_of_mem hx (λ _ _ => Nat.zero_le _)
    linarith
  have h12 : f S1 = f S2 := by
    have hA := Finset.sum_sdiff_add_sum_inter (Finset.inter_subset_left SA SB)
    have hB := Finset.sum_sdiff_add_sum_inter (Finset.inter_subset_right SA SB)
    rw [Finset.sdiff_inter_self_left] at hA
    rw [Finset.inter_comm, Finset.sdiff_inter_self_left] at hB
    linarith
  have h1n : S1.Nonempty := by
    by_contra h
    have hS1 := Finset.not_nonempty_iff_eq_empty.mp h
    have hS2 : S2 = ∅ := by rwa [← h_empty S2 h2S, ← h12, h_empty S1 h1S]
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.mp hS1) (Finset.sdiff_eq_empty_iff_subset.mp hS2))
  have h2n : S2.Nonempty := by rwa [Finset.nonempty_iff_ne_empty, ← h_empty S2 h2S, ← h12, h_empty S1 h1S, ← Finset.nonempty_iff_ne_empty] at h1n
  use S1, S2, h1n, h1S, h2n, h2S, Finset.disjoint_sdiff_sdiff, h12

