import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f : Finset ℕ → ℕ := fun A ↦ ∑ x ∈ A, x
  obtain ⟨Sa, hSa, Sb, hSb, hne, hf⟩ := S.powerset.exists_ne_map_eq_of_card_lt_card
    (show ∀ A ∈ S.powerset, f A ∈ Finset.range 991 from fun A hA ↦
      Finset.mem_range.2 (by
        have hAS : A ⊆ S := Finset.mem_powerset.1 hA
        calc f A ≤ ∑ x ∈ A, 99 := Finset.sum_le_sum (fun x hx ↦ Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (hAS hx))).2)
             _ = A.card * 99 := by simp
             _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (Finset.card_le_card hAS |>.trans h₀.le)
             _ < 991 := by norm_num))
    (by rw [Finset.card_powerset, h₀]; norm_num)
  let S1 := Sa \ Sb; let S2 := Sb \ Sa
  have hS1 : S1 ⊆ S := (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.1 hSa)
  have hS2 : S2 ⊆ S := (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.1 hSb)
  have hf' : f S1 = f S2 := by
    rw [f, ← Finset.sum_inter_add_sum_diff Sa Sb, ← Finset.sum_inter_add_sum_diff Sb Sa, hf, Finset.inter_comm]
    simp
  have h_empty {A} (hAS : A ⊆ S) (hsum : f A = 0) : A = ∅ := by
    by_contra hA; obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.2 hA
    have := calc 0 = f A := hsum.symm
      _ ≥ x := Finset.single_le_sum (fun _ _ ↦ Nat.zero_le _) hx
      _ ≥ 10 := (Finset.mem_Ico.1 (h₁ (hAS hx))).1
    linarith
  have h1n : S1.Nonempty := by
    by_contra h; have hSaSb : Sa ⊆ Sb := Finset.sdiff_eq_empty_iff_subset.1 (Finset.not_nonempty_iff_eq_empty.1 h)
    have hSbSa : Sb ⊆ Sa := Finset.sdiff_eq_empty_iff_subset.1 (h_empty hS2 (by rwa [← hf', Finset.not_nonempty_iff_eq_empty.1 h, f, Finset.sum_empty]))
    exact hne (hSaSb.antisymm hSbSa)
  have h2n : S2.Nonempty := by
    by_contra h; have hSbSa : Sb ⊆ Sa := Finset.sdiff_eq_empty_iff_subset.1 (Finset.not_nonempty_iff_eq_empty.1 h)
    have hSaSb : Sa ⊆ Sb := Finset.sdiff_eq_empty_iff_subset.1 (h_empty hS1 (by rwa [hf', Finset.not_nonempty_iff_eq_empty.1 h, f, Finset.sum_empty]))
    exact hne (hSaSb.antisymm hSbSa)
  exact ⟨h1n, hS1, h2n, hS2, Finset.disjoint_sdiff_sdiff, hf'⟩

