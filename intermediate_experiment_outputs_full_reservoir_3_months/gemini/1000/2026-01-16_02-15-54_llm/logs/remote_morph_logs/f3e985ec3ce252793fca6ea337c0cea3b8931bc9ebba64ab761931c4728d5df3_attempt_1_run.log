      exact (Finset.sum_pos (fun x hx => h_pos x (hS2S hx)) (Finset.nonempty_iff_ne_empty.mpr h2)).ne' hsum12.symm
    exact hne (Finset.sdiff_eq_empty_iff_subset.mp h |> fun hAB => hAB.antisymm (Finset.sdiff_eq_empty_iff_subset.mp hS2e))
  have hS2ne : S₂.Nonempty := by
    by_contra h; rw [Finset.not_nonempty_iff_eq_empty] at h
    rw [h, Finset.sum_empty] at hsum12
    exact (Finset.sum_pos (fun x hx => h_pos x (hS1S hx)) hS1ne).ne' hsum12
  use S₁, S₂
  exact ⟨hS1ne, hS1S, hS2ne, hS2S, Finset.disjoint_sdiff_sdiff, hsum12⟩

