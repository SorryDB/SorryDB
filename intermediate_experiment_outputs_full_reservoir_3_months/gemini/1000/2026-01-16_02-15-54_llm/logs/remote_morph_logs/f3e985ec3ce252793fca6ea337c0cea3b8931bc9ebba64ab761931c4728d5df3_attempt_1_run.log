import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_card (fun T => ∑ x in T, x)
    (by rw [Finset.card_powerset, h₀, Finset.card_Icc]; norm_num : (Finset.Icc 0 990).card < S.powerset.card)
    (fun T hT => Finset.mem_Icc.2 ⟨Nat.zero_le _, by
      rw [Finset.mem_powerset] at hT
      calc ∑ x in T, x ≤ ∑ x in T, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (h₁ (hT hx)).2)
        _ = T.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
        _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (Finset.card_le_card hT |>.trans h₀.le)
        _ = 990 := rfl ⟩)
  let S₁ := A \ B; let S₂ := B \ A
  use S₁, S₂
  rw [Finset.mem_powerset] at hA hB
  have hS1S2 : ∑ x in S₁, x = ∑ x in S₂, x := by
    linarith [Finset.sum_sdiff_add_sum_inter A B (fun x => x), Finset.sum_sdiff_add_sum_inter B A (fun x => x), hsum, Finset.inter_comm A B]
  have h_empty : ∀ {T}, T ⊆ S → ∑ x in T, x = 0 → T = ∅ := fun hT fT =>
    Finset.eq_empty_iff_forall_not_mem.2 fun x hx =>
      by have := Finset.sum_eq_zero_iff.1 fT x hx; have := (h₁ (hT hx)).1; linarith
  have hS1ne : S₁.Nonempty := Finset.nonempty_iff_ne_empty.2 fun h =>
    hne (by have hfS2 : ∑ x in S₂, x = 0 := by linarith; have hS2e := h_empty (Finset.sdiff_subset.trans hB) hfS2;
            exact (Finset.sdiff_eq_empty_iff_subset.1 h).antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS2e))
  have hS2ne : S₂.Nonempty := Finset.nonempty_iff_ne_empty.2 fun h =>
    hne (by have hfS1 : ∑ x in S₁, x = 0 := by linarith; have hS1e := h_empty (Finset.sdiff_subset.trans hA) hfS1;
            exact (Finset.sdiff_eq_empty_iff_subset.1 hS1e).antisymm (Finset.sdiff_eq_empty_iff_subset.1 h))
  exact ⟨hS1ne, Finset.sdiff_subset.trans hA, hS2ne, Finset.sdiff_subset.trans hB, Finset.disjoint_sdiff_sdiff, hS1S2⟩

