import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f (s : Finset ℕ) : ℕ := ∑ x in s, x
  have h_range : ∀ s ∈ S.powerset, f s ∈ Finset.range (∑ x in S, x + 1) := by
    intro s hs
    apply Finset.mem_range.2
    apply Nat.lt_succ_of_le
    apply Finset.sum_le_sum_of_subset (Finset.mem_powerset.1 hs)
    intro x _; exact Nat.zero_le x
  have h_card : (Finset.range (∑ x in S, x + 1)).card < S.powerset.card := by
    rw [Finset.card_range, Finset.card_powerset, h₀]
    have : ∑ x in S, x ≤ 10 * 99 := by
      calc ∑ x in S, x ≤ ∑ x in S, 99 := Finset.sum_le_sum (λ x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
           _ = S.card * 99 := Finset.sum_const 99
           _ = 10 * 99 := by rw [h₀]
    omega
  obtain ⟨s1, hs1, s2, hs2, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_card f h_card h_range
  use s1 \ s2, s2 \ s1
  have h_s1'_sub : s1 \ s2 ⊆ S := (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.1 hs1)
  have h_s2'_sub : s2 \ s1 ⊆ S := (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.1 hs2)
  have h_s1'_s2'_sum : ∑ x in s1 \ s2, x = ∑ x in s2 \ s1, x := by
    rw [f] at hsum
    rw [← Nat.add_right_cancel_iff (∑ x in s1 ∩ s2, x)]
    rw [← Finset.sum_union Finset.disjoint_sdiff_inter, Finset.sdiff_union_inter]
    rw [Finset.inter_comm, ← Finset.sum_union Finset.disjoint_sdiff_inter, Finset.sdiff_union_inter, hsum]
  have h_s1'_ne : (s1 \ s2).Nonempty := by
    by_contra h_empty
    have h_s1_sub_s2 : s1 ⊆ s2 := Finset.sdiff_eq_empty_iff_subset.1 (Finset.not_nonempty_iff_eq_empty.1 h_empty)
    have h_s2_s1_sum : ∑ x in s2 \ s1, x = 0 := by
      rw [← h_s1'_s2'_sum, Finset.not_nonempty_iff_eq_empty.1 h_empty, Finset.sum_empty]
    have h_s2_sub_s1 : s2 ⊆ s1 := by
      intro x hx
      by_contra hx_not_s1
      have : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (h_s2'_sub (Finset.mem_sdiff.2 ⟨hx, hx_not_s1⟩)))).1
      have : 10 ≤ ∑ y in s2 \ s1, y := this.trans (Finset.single_le_sum (λ _ _ => Nat.zero_le _) (Finset.mem_sdiff.2 ⟨hx, hx_not_s1⟩))
      omega
    exact hne (Finset.subset_antisymm h_s1_sub_s2 h_s2_sub_s1)
  have h_s2'_ne : (s2 \ s1).Nonempty := by
    obtain ⟨x, hx⟩ := h_s1'_ne
    have : 10 ≤ ∑ x in s1 \ s2, x := (Finset.mem_Ico.1 (h₁ (h_s1'_sub hx))).1.trans (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hx)
    rw [h_s1'_s2'_sum] at this
    exact Finset.nonempty_of_sum_ne_zero (by omega)
  exact ⟨h_s1'_ne, h_s1'_sub, h_s2'_ne, h_s2'_sub, Finset.disjoint_sdiff_sdiff, h_s1'_s2'_sum⟩
