/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f : Finset ℕ → ℕ := fun T => ∑ x ∈ T, x
  have h_f_bound : ∀ T ∈ S.powerset, f T ≤ 990 := by
    intro T hT
    have hT_S : T ⊆ S := Finset.mem_powerset.1 hT
    calc ∑ x ∈ T, x ≤ ∑ _x ∈ T, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (hT_S hx))).2)
      _ = T.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
      _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (h₀ ▸ Finset.card_le_card hT_S)
      _ = 990 := rfl
  have h_card : (Finset.range 991).card < S.powerset.card := by
    rw [Finset.card_powerset, h₀, Finset.card_range]; norm_num
  rcases Finset.exists_ne_map_eq_of_card_lt_card f h_card (fun T hT => Finset.mem_range.2 ((h_f_bound T hT).trans_lt (by norm_num))) with ⟨S_A, hA, S_B, hB, h_ne, h_eq⟩
  let S₁ := S_A \ S_B
  let S₂ := S_B \ S_A
  have h_S1_S2 : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    rw [← Finset.sum_sdiff_add_sum_inter S_A S_B (fun x => x), ← Finset.sum_sdiff_add_sum_inter S_B S_A (fun x => x), Finset.inter_comm] at h_eq
    exact add_right_cancel h_eq
  have h_S1_sub : S₁ ⊆ S := (Finset.sdiff_subset ..).trans (Finset.mem_powerset.1 hA)
  have h_S2_sub : S₂ ⊆ S := (Finset.sdiff_subset ..).trans (Finset.mem_powerset.1 hB)
  have h_empty : ∀ {T}, T ⊆ S → (∑ x ∈ T, x = 0 ↔ T = ∅) := fun hT_sub =>
    ⟨fun h_sum => T.eq_empty_or_nonempty.elim id fun h_ne =>
      ((Finset.sum_pos (fun x hx => (Finset.mem_Ico.1 (h₁ (hT_sub hx))).1.trans_lt' (by norm_num)) h_ne).ne' h_sum).elim,
     fun h => h.symm ▸ Finset.sum_empty⟩
  have h_S1_S2_empty : S₁ = ∅ ↔ S₂ = ∅ := by rw [← h_empty h_S1_sub, h_S1_S2, h_empty h_S2_sub]
  have h_S1_ne : S₁.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro h_S1_e
    exact h_ne (Finset.sdiff_eq_empty_iff_subset.1 h_S1_e |>.antisymm (Finset.sdiff_eq_empty_iff_subset.1 (h_S1_S2_empty.1 h_S1_e)))
  use S₁, S₂
  exact ⟨h_S1_ne, h_S1_sub, Finset.nonempty_iff_ne_empty.2 (h_S1_S2_empty.2.mt h_S1_ne.ne_empty), h_S2_sub, Finset.disjoint_sdiff_sdiff, h_S1_S2⟩

