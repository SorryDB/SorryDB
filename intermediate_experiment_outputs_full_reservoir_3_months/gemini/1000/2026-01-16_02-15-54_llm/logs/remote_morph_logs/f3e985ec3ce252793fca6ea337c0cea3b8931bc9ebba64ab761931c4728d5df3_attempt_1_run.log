import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f : Finset ℕ → ℕ := λ A ↦ ∑ x in A, x
  have hfA : ∀ A ∈ S.powerset, f A ∈ Finset.range 1000 := by
    intro A hA
    apply Finset.mem_range.2
    apply (Finset.sum_le_sum_of_subset (Finset.mem_powerset.1 hA) (fun _ _ ↦ Nat.zero_le _)).trans
    apply (Finset.sum_le_card_nsmul S 99 (fun x hx ↦ Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)).trans
    simp [h₀]
  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to f hfA (by rw [Finset.card_powerset, h₀]; norm_num)
  let S₁ := A \ B; let S₂ := B \ A
  have hS1S : S₁ ⊆ S := (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA)
  have hS2S : S₂ ⊆ S := (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB)
  have hf12 : ∑ x in S₁, x = ∑ x in S₂, x := by
    have hA_sum := Finset.sum_sdiff_add_sum_inter A B
    have hB_sum := Finset.sum_sdiff_add_sum_inter B A
    rw [heq, ← hB_sum, Finset.inter_comm] at hA_sum
    exact Nat.add_right_cancel hA_sum
  have h_empty : ∀ {T}, T ⊆ S → (∑ x in T, x = 0 ↔ T = ∅) := fun hT ↦ ⟨fun hz ↦
    Finset.eq_empty_iff_forall_not_mem.2 (fun x hx ↦ (Finset.mem_Ico.1 (h₁ (hT hx))).1.ne'
    (Finset.sum_eq_zero_iff_of_nonneg (fun _ _ ↦ Nat.zero_le _) |>.1 hz x hx)), fun h ↦ h.symm ▸ Finset.sum_empty⟩
  have hS12n : S₁.Nonempty ∧ S₂.Nonempty := by
    by_contra! h
    have h12 : S₁ = ∅ ∧ S₂ = ∅ := by
      cases h with
      | inl h1 =>
        have h1 := Finset.not_nonempty_iff_eq_empty.1 h1
        exact ⟨h1, (h_empty hS2S).1 (hf12 ▸ (h_empty hS1S).2 h1)⟩
      | inr h2 =>
        have h2 := Finset.not_nonempty_iff_eq_empty.1 h2
        exact ⟨(h_empty hS1S).1 (hf12.trans (h_empty hS2S).2 h2), h2⟩
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h12.1) (Finset.sdiff_eq_empty_iff_subset.1 h12.2))
  use S₁, S₂
  exact ⟨hS12n.1, hS1S, hS12n.2, hS2S, Finset.disjoint_sdiff_sdiff, hf12⟩
