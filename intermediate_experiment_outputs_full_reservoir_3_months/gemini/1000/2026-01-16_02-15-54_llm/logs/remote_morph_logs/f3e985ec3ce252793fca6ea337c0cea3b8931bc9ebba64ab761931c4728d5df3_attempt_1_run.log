      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f : Finset ℕ → ℕ := fun A => ∑ x in A, x
  have h_card_pow : S.powerset.card = 1024 := by rw [Finset.card_powerset, h₀]; rfl
  have h_f_range : S.powerset.image f ⊆ Finset.range 991 := by
    intro s hs
    obtain ⟨A, hA, rfl⟩ := Finset.mem_image.1 hs
    simp [Finset.mem_powerset] at hA
    rw [Finset.mem_range]
    calc ∑ x in A, x ≤ ∑ x in A, 99 := Finset.sum_le_sum (fun x hx => by
           have hxr := h₁ (hA hx); simp at hxr; omega)
         _ = A.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
         _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (h₀ ▸ Finset.card_le_card hA)
         _ = 990 := rfl
  have h_card_img : (S.powerset.image f).card < S.powerset.card := by
    apply (Finset.card_le_card h_f_range).trans_lt
    rw [Finset.card_range, h_card_pow]; omega
  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_card h_card_img
  rw [Finset.mem_powerset] at hA hB
  let S1 := A \ B
  let S2 := B \ A
  use S1, S2
  have hS1S : S1 ⊆ S := (Finset.sdiff_subset _ _).trans hA
  have hS2S : S2 ⊆ S := (Finset.sdiff_subset _ _).trans hB
  have h_sum : ∑ x in S1, x = ∑ x in S2, x := by
    have h1 := Finset.sum_sdiff_add_sum_inter A B (fun x => x)
    have h2 := Finset.sum_sdiff_add_sum_inter B A (fun x => x)
    rw [Finset.inter_comm] at h2
    dsimp [f] at heq
    linarith [heq, h1, h2]
  have h_pos : ∀ x ∈ S, 0 < x := by
    intro x hx; have hxr := h₁ hx; simp at hxr; omega
  have hne' : S1.Nonempty ∨ S2.Nonempty := by
    contrapose! hne
    rw [Finset.not_nonempty_iff_eq_empty, Finset.not_nonempty_iff_eq_empty] at hne
    exact Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hne.1) (Finset.sdiff_eq_empty_iff_subset.1 hne.2)
  have hS1ne : S1.Nonempty := by
    cases hne' with
    | inl h1 => exact h1
    | inr h2 =>
      have : 0 < ∑ x in S2, x := Finset.sum_pos (fun x hx => h_pos (hS2S hx)) h2
      rw [← h_sum] at this
      exact Finset.nonempty_of_sum_pos this
  have hS2ne : S2.Nonempty := by
    have : 0 < ∑ x in S1, x := Finset.sum_pos (fun x hx => h_pos (hS1S hx)) hS1ne
    rw [h_sum] at this
    exact Finset.nonempty_of_sum_pos this
  exact ⟨hS1ne, hS1S, hS2ne, hS2S, Finset.disjoint_sdiff_sdiff, h_sum⟩

