open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  obtain ⟨A, hA, B, hB, hne, hfAB⟩ := Finset.exists_ne_map_eq_of_card_lt_card (λ A => ∑ x in A, x) (by
    rw [Finset.card_powerset, h₀]
    norm_num) (by
    intro A hA
    rw [Finset.mem_range]
    calc ∑ x in A, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset (Finset.mem_powerset.1 hA)
      _ ≤ ∑ x in S, 99 := Finset.sum_le_sum (fun x hx => by linarith [Finset.mem_Ico.1 (h₁ hx)])
      _ = 10 * 99 := by rw [Finset.sum_const, h₀]; rfl
      _ < 1024 := by norm_num)
  let S₁ := A \ B
  let S₂ := B \ A
  have hS₁S : S₁ ⊆ S := (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.1 hA)
  have hS₂S : S₂ ⊆ S := (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.1 hB)
  have hsum : ∑ x in S₁, x = ∑ x in S₂, x := by
    apply Nat.add_right_cancel (k := ∑ x in A ∩ B, x)
    rw [← Finset.sum_union (Finset.disjoint_sdiff_inter A B),
        ← Finset.sum_union (Finset.disjoint_sdiff_inter B A),
        Finset.sdiff_union_inter, Finset.inter_comm, Finset.sdiff_union_inter, hfAB]
  have h_empty (T : Finset ℕ) (hTS : T ⊆ S) (hTsum : ∑ x in T, x = 0) : T = ∅ := by
    by_contra hTne
    obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.2 hTne
    have : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hTS hx))).1
    linarith [Finset.single_le_sum (λ _ _ => Nat.zero_le _) hx]
  have hS₁n : S₁.Nonempty := by
    by_contra h
    have hS₁ : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.1 h
    have hS₂ : S₂ = ∅ := h_empty S₂ hS₂S (by rw [← hsum, hS₁, Finset.sum_empty])
    exact hne (Finset.sdiff_eq_empty_iff_subset.1 hS₁ |>.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₂))
  have hS₂n : S₂.Nonempty := by
    by_contra h
    have hS₂ : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.1 h
    have hS₁ : S₁ = ∅ := h_empty S₁ hS₁S (by rw [hsum, hS₂, Finset.sum_empty])
    exact hne (Finset.sdiff_eq_empty_iff_subset.1 hS₁ |>.antisymm (Finset.sdiff_eq_empty_iff_subset.1 hS₂))
  exact ⟨hS₁n, hS₁S, hS₂n, hS₂S, Finset.disjoint_sdiff_sdiff, hsum⟩

