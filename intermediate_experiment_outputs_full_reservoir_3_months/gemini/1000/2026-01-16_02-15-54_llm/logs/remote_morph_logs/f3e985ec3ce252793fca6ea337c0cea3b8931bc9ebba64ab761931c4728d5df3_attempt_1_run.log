  have h_card_S_powerset : S.powerset.card = 1024 := by rw [Finset.card_powerset, h₀]; norm_num
  have h_range : ∀ A ∈ S.powerset, ∑ x in A, x ∈ Finset.Icc 0 990 := by
    intro A hA
    rw [Finset.mem_powerset] at hA
