import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f := fun A : Finset ℕ => ∑ x in A, x
  have h_bound : ∀ A ⊆ S, f A ≤ 990 := by
    intro A hA
    calc ∑ x in A, x ≤ ∑ _ in A, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (hA hx))).2)
         _ = A.card * 99 := by simp
         _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 ((Finset.card_le_card hA).trans h₀.le)
         _ = 990 := by norm_num
  have h_f_mem : ∀ A ∈ S.powerset, f A ∈ Finset.range 991 := fun A hA =>
    Finset.mem_range.2 ((h_bound (Finset.mem_powerset.1 hA)).trans_lt (Nat.lt_succ_self 990))
  have h_card : (Finset.range 991).card < S.powerset.card := by
    simp [h₀, Finset.card_powerset]; norm_num
  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_card h_f_mem h_card
  let S₁ := A \ B
  let S₂ := B \ A
  have hA_sub : A ⊆ S := Finset.mem_powerset.1 hA
  have hB_sub : B ⊆ S := Finset.mem_powerset.1 hB
  have h_S_pos : ∀ x ∈ S, 0 < x := fun x hx => (Finset.mem_Ico.1 (h₁ hx)).1.trans_lt' (by norm_num)
  have hsum' : ∑ x in S₁, x = ∑ x in S₂, x := by
    have h1 := Finset.sum_sdiff_add_sum_inter A B (fun x => x)
    have h2 := Finset.sum_sdiff_add_sum_inter B A (fun x => x)
    rw [Finset.inter_comm] at h2
    dsimp [f] at hsum
    linarith
  have hS1ne : S₁.Nonempty := by
    by_contra h
    have h1 : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.1 h
    have h2 : S₂ = ∅ := by
      rw [h1, Finset.sum_empty] at hsum'
      exact Finset.eq_empty_of_sum_eq_zero (fun x hx => h_S_pos x (hB_sub (Finset.mem_sdiff.1 hx).1)) hsum'.symm
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h1) (Finset.sdiff_eq_empty_iff_subset.1 h2))
  have hS2ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]; intro hS2
    rw [hS2, Finset.sum_empty] at hsum'
    exact hS1ne.ne_empty (Finset.eq_empty_of_sum_eq_zero (fun x hx => h_S_pos x (hA_sub (Finset.mem_sdiff.1 hx).1)) hsum')
  exact ⟨S₁, S₂, hS1ne, Finset.sdiff_subset A B |>.trans hA_sub, hS2ne, Finset.sdiff_subset B A |>.trans hB_sub, Finset.disjoint_sdiff_sdiff, hsum'⟩

