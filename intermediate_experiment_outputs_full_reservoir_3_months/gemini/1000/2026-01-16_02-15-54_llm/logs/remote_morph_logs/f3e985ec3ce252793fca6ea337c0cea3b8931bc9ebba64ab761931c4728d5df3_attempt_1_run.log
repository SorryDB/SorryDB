  have hS₂S : S₂ ⊆ S := (Finset.sdiff_subset).trans (Finset.mem_powerset.1 hB)
  have hsumeq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    apply Nat.add_right_cancel (n := ∑ x ∈ A ∩ B, x)
    rw [Finset.sum_sdiff_add_sum_inter, Finset.inter_comm, Finset.sum_sdiff_add_sum_inter, hsum]
  have h_empty {T : Finset ℕ} (hT : T ⊆ S) : ∑ x ∈ T, x = 0 ↔ T = ∅ :=
