      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_card
    (fun X ↦ ∑ x in X, x)
    (by rw [Finset.card_powerset, h₀, Finset.card_range]; norm_num)
    (by
      intro X hX; rw [Finset.mem_powerset] at hX; rw [Finset.mem_range]
      calc ∑ x in X, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset hX
        _ ≤ ∑ _ in S, 99 := Finset.sum_le_sum (fun x hx ↦ Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
        _ = 10 * 99 := by rw [Finset.sum_const, h₀, Nat.nsmul_eq_mul]
        _ < 991 := by norm_num)
  let S₁ := A \ B
  let S₂ := B \ A
  have hS12 : ∑ x in S₁, x = ∑ x in S₂, x := by
    rw [S₁, S₂, ← Nat.add_right_cancel_iff (n := ∑ x in A ∩ B, x), Finset.sum_sdiff_inter,
        Finset.inter_comm, Finset.sum_sdiff_inter, hsum]
  have h_pos : ∀ x ∈ S, 0 < x := fun x hx ↦ (Finset.mem_Ico.1 (h₁ hx)).1
  have hS_empty : ∀ {X}, X ⊆ S → ∑ x in X, x = 0 → X = ∅ := fun {X} hX hsumX ↦
    Finset.eq_empty_of_forall_not_mem (fun x hx ↦ (h_pos (hX hx)).ne' (Finset.sum_eq_zero_iff.1 hsumX x hx))
  have hS1ne : S₁.Nonempty := by
    by_contra h; rw [Finset.not_nonempty_iff_eq_empty] at h
    have hS2e : S₂ = ∅ := hS_empty (Finset.sdiff_subset .. |>.trans (Finset.mem_powerset.1 hB)) (hS12 ▸ h.symm ▸ Finset.sum_empty)
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h) (Finset.sdiff_eq_empty_iff_subset.1 hS2e))
  have hS2ne : S₂.Nonempty := by
    by_contra h; rw [Finset.not_nonempty_iff_eq_empty] at h
    have hS1e : S₁ = ∅ := hS_empty (Finset.sdiff_subset .. |>.trans (Finset.mem_powerset.1 hA)) (hS12.trans (h.symm ▸ Finset.sum_empty))
    exact hS1ne (Finset.nonempty_iff_ne_empty.2 hS1e)
