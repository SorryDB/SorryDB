    have hS2e : S₂ = ∅ := by
      apply Finset.eq_empty_of_forall_not_mem; intro x hx
      have : x = 0 := Finset.sum_eq_zero_iff.1 (by rw [← h_sum, h, Finset.sum_empty]) x hx
      linarith [(h₁ (hS2S hx)).1]
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h) (Finset.sdiff_eq_empty_iff_subset.1 hS2e))
  have hS2ne : S₂.Nonempty := by
