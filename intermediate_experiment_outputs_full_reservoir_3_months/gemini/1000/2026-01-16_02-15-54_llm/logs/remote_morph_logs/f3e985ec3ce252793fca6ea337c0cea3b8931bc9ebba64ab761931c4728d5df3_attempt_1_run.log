  have hS2S : S₂ ⊆ S := (Finset.sdiff_subset B A).trans (Finset.mem_powerset.mp hB)
  have hsum12 : ∑ x in S₁, x = ∑ x in S₂, x := by
    rw [← Finset.sum_sdiff_add_sum_inter A B, ← Finset.sum_sdiff_add_sum_inter B A, Finset.inter_comm] at hsum
