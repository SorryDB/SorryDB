open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f : Finset ℕ → ℕ := λ A => ∑ x in A, x
  have hfS : ∀ A ∈ S.powerset, f A ∈ Finset.Icc 0 990 := by
    intro A hA
    rw [Finset.mem_powerset] at hA
    refine Finset.mem_Icc.2 ⟨Nat.zero_le _, ?_⟩
    calc f A ≤ ∑ _ in A, 99 := Finset.sum_le_sum (λ x hx => Nat.le_of_lt_add_one (Finset.mem_Ico.1 (h₁ (hA hx))).2)
         _ = A.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
         _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 ((Finset.card_le_card hA).trans h₀.le)
         _ = 990 := rfl
  have : (Finset.Icc 0 990).card < S.powerset.card := by
    rw [Finset.card_Icc, Nat.sub_zero, Finset.card_powerset, h₀]; norm_num
  rcases Finset.exists_ne_map_eq_of_card_lt_card this hfS with ⟨S_A, hA, S_B, hB, hne, heq⟩
  rw [Finset.mem_powerset] at hA hB
  let S₁ := S_A \ S_B; let S₂ := S_B \ S_A
  have h_eq : ∑ x in S₁, x = ∑ x in S₂, x := by
    apply Nat.add_right_cancel (n := ∑ x in S_A ∩ S_B, x)
    rw [Finset.sum_sdiff_add_sum_inter, heq, Finset.inter_comm, Finset.sum_sdiff_add_sum_inter]
  have h_sum_zero : ∀ {A}, A ⊆ S → ∑ x in A, x = 0 → A = ∅ := by
    intro A hAS hsum
    rw [Finset.sum_eq_zero_iff] at hsum
    apply Finset.eq_empty_of_forall_not_mem
    intro x hx
    exact ((Finset.mem_Ico.1 (h₁ (hAS hx))).1.ne' (hsum x hx)).elim
  have h1ne : S₁.Nonempty := by
    apply Finset.nonempty_iff_ne_empty.2; intro h1
    have h2 : S₂ = ∅ := h_sum_zero ((Finset.sdiff_subset S_B S_A).trans hB) (h_eq ▸ h1.symm ▸ Finset.sum_empty)
    exact hne (Finset.sdiff_eq_empty_iff_subset.1 h1 |>.antisymm (Finset.sdiff_eq_empty_iff_subset.1 h2))
  have h2ne : S₂.Nonempty := by
    apply Finset.nonempty_iff_ne_empty.2; intro h2
    have h1 : S₁ = ∅ := h_sum_zero ((Finset.sdiff_subset S_A S_B).trans hA) (h_eq.trans (h2.symm ▸ Finset.sum_empty))
    exact hne (Finset.sdiff_eq_empty_iff_subset.1 h1 |>.antisymm (Finset.sdiff_eq_empty_iff_subset.1 h2))
  use S₁, S₂
  exact ⟨h1ne, (Finset.sdiff_subset _ _).trans hA, h2ne, (Finset.sdiff_subset _ _).trans hB, Finset.disjoint_sdiff_sdiff, h_eq⟩

