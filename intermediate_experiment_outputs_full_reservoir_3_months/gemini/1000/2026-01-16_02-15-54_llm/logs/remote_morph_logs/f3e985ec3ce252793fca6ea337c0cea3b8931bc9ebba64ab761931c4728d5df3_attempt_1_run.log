import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h_pos : ∀ x ∈ S, 0 < x := fun x hx => (Finset.mem_Ico.1 (h₁ hx)).1.trans_lt' (by norm_num)
  let f : Finset ℕ → ℕ := fun A => ∑ x in A, x
  have h_range : ∀ A ∈ S.powerset, f A ∈ Finset.range 991 := by
    intro A hA
    simp only [f, Finset.mem_range, Finset.mem_powerset] at hA ⊢
    calc ∑ x in A, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset hA
         _ ≤ S.card * 99 := Finset.sum_le_card_nsmul S 99 (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)
         _ = 10 * 99 := by rw [h₀]
         _ < 991 := by norm_num
  have h_card : (Finset.range 991).card < S.powerset.card := by
    simp only [Finset.card_powerset, h₀, Finset.card_range]
    norm_num
  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_card h_range h_card
  rw [Finset.mem_powerset] at hA hB
  have h_Sne : ∀ {A B : Finset ℕ}, A ⊆ S → B ⊆ S → A ≠ B → f A = f B → (A \ B).Nonempty := by
    intro A B hAs hBs hne' heqf
    refine Finset.nonempty_of_ne_empty (fun h_empty => ?_)
    have hsub : A ⊆ B := Finset.sdiff_eq_empty_iff_subset.1 h_empty
    have hssub : A ⊂ B := Finset.ssubset_of_subset_of_ne hsub hne'
    obtain ⟨x, hxB, hxA⟩ := Finset.exists_of_ssubset hssub
    have : f A < f B := by
      simp only [f]
      rw [← Finset.sum_sdiff hsub]
      refine Nat.lt_add_of_pos_right (Finset.sum_pos (fun y hy => h_pos y (hBs (Finset.sdiff_subset _ _ hy))) ?_)
      exact ⟨x, Finset.mem_sdiff.2 ⟨hxB, hxA⟩⟩
    exact this.ne heqf
  use A \ B, B \ A
  refine ⟨h_Sne hA hB hne heq, Finset.sdiff_subset .. |>.trans hA,
          h_Sne hB hA hne.symm heq.symm, Finset.sdiff_subset .. |>.trans hB,
          Finset.disjoint_sdiff_sdiff, ?_⟩
  simp only [f] at heq
  apply Nat.add_right_cancel (m := ∑ x in A ∩ B, x)
  rw [Finset.sum_sdiff_add_sum_inter, ← Finset.inter_comm, Finset.sum_sdiff_add_sum_inter, heq]
