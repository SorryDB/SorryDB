import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  have h_card : (Finset.range 1000).card < S.powerset.card := by
    rw [Finset.card_range, Finset.card_powerset, h₀]
    norm_num
  have h_map : ∀ A ∈ S.powerset, (∑ x in A, x) ∈ Finset.range 1000 := by
    intro A hA
    apply Finset.mem_range.mpr
    have hAS : A ⊆ S := Finset.mem_powerset.mp hA
    have hS_sum : ∑ x in S, x ≤ 990 := by
      calc ∑ x in S, x ≤ ∑ x in S, 99 := Finset.sum_le_sum (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.mp (h₁ hx)).right)
           _ = 10 * 99 := by simp [h₀, nsmul_eq_mul]
           _ = 990 := rfl
    exact (Finset.sum_le_sum_of_subset hAS).trans_lt (hS_sum.trans_lt (by norm_num))
  obtain ⟨S1', hS1', S2', hS2', hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_card h_card h_map
  let S1 := S1' \ S2'
  let S2 := S2' \ S1'
  have hS1_sub_S : S1 ⊆ S := (Finset.sdiff_subset S1' S2').trans (Finset.mem_powerset.mp hS1')
  have hS2_sub_S : S2 ⊆ S := (Finset.sdiff_subset S2' S1').trans (Finset.mem_powerset.mp hS2')
  have h_sum_eq : ∑ x in S1, x = ∑ x in S2, x := by
    have h1 := Finset.sum_sdiff_add_sum_inter S1' S2'
    have h2 := Finset.sum_sdiff_add_sum_inter S2' S1'
    rw [Finset.inter_comm] at h2
    exact Nat.add_right_cancel (h1.trans (hsum.trans h2.symm))
  have hS1_ne : S1.Nonempty := by
    by_contra hS1e
    have h1 : S1' ⊆ S2' := Finset.sdiff_eq_empty_iff_subset.mp (Finset.not_nonempty_iff_eq_empty.mp hS1e)
    have h2 : S2 = ∅ := by
      have h_sum_S2 : ∑ x in S2, x = 0 := by rw [← h_sum_eq, Finset.not_nonempty_iff_eq_empty.mp hS1e, Finset.sum_empty]
      by_contra hS2ne
      obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.mpr hS2ne
      exact (Finset.sum_pos (fun y hy => (Finset.mem_Ico.mp (h₁ (hS2_sub_S hy))).left.trans_lt' (by norm_num)) ⟨x, hx⟩).ne' h_sum_S2
    exact hne (Finset.subset_antisymm h1 (Finset.sdiff_eq_empty_iff_subset.mp h2))
  have hS2_ne : S2.Nonempty := by
    have hS1_pos : 0 < ∑ x in S1, x := Finset.sum_pos (fun x hx => (Finset.mem_Ico.mp (h₁ (hS1_sub_S hx))).left.trans_lt' (by norm_num)) hS1_ne
    exact Finset.nonempty_of_sum_pos (h_sum_eq ▸ hS1_pos)
  use S1, S2, hS1_ne, hS1_sub_S, hS2_ne, hS2_sub_S, Finset.disjoint_sdiff_sdiff, h_sum_eq
