import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f (A : Finset ℕ) : ℕ := ∑ x in A, x
  have h_sum_S : ∑ x in S, x ≤ 990 := by
    calc ∑ x in S, x ≤ S.card * 99 := by
        rw [← Nat.nsmul_eq_mul]; apply Finset.sum_le_card_nsmul
        intro x hx; exact Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2
      _ = 990 := by rw [h₀]; rfl
  have hf : ∀ A ∈ S.powerset, f A ∈ Finset.Icc 0 990 := fun A hA =>
    Finset.mem_Icc.mpr ⟨Nat.zero_le _, (Finset.sum_le_sum_of_subset (Finset.mem_powerset.mp hA)).trans h_sum_S⟩
  have h_card : (Finset.Icc 0 990).card < S.powerset.card := by
    rw [Finset.card_Icc, Nat.sub_zero, Finset.card_powerset, h₀]; norm_num
  obtain ⟨A, hA, B, hB, hne, hsumf⟩ := Finset.exists_ne_map_eq_of_card_lt_card hf h_card
  rw [Finset.mem_powerset] at hA hB
  let S₁ := A \ B
  let S₂ := B \ A
  have hsum : ∑ x in S₁, x = ∑ x in S₂, x := by
    have h1 : ∑ x in S₁, x + ∑ x in A ∩ B, x = ∑ x in A, x := by
      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter A B), Finset.sdiff_union_inter]
    have h2 : ∑ x in S₂, x + ∑ x in A ∩ B, x = ∑ x in B, x := by
      rw [Finset.inter_comm, ← Finset.sum_union (Finset.disjoint_sdiff_inter B A), Finset.sdiff_union_inter]
    exact Nat.add_right_cancel (h1.trans (hsumf.trans h2.symm))
  have hS_pos : ∀ {T}, T ⊆ S → ∑ x in T, x = 0 → T = ∅ := fun {T} hT hsumT => by
    ext x; constructor; swap; intro hx; exfalso; exact Finset.not_mem_empty x hx
    intro hx
    have : 10 ≤ x := (Finset.mem_Ico.1 (h₁ (hT hx))).1
    have : x ≤ ∑ y in T, y := Finset.single_le_sum (fun _ _ => Nat.zero_le _) hx
    linarith
  have hS₁ne : S₁.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro h_empty_S₁
    have h_empty_S₂ : S₂ = ∅ := hS_pos ((Finset.sdiff_subset B A).trans hB) (by rw [← hsum, h_empty_S₁, Finset.sum_empty])
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h_empty_S₁) (Finset.sdiff_eq_empty_iff_subset.1 h_empty_S₂))
  have hS₂ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro h_empty_S₂
    have h_empty_S₁ : S₁ = ∅ := hS_pos ((Finset.sdiff_subset A B).trans hA) (by rw [hsum, h_empty_S₂, Finset.sum_empty])
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h_empty_S₁) (Finset.sdiff_eq_empty_iff_subset.1 h_empty_S₂))
  exact ⟨hS₁ne, (Finset.sdiff_subset A B).trans hA, hS₂ne, (Finset.sdiff_subset B A).trans hB, Finset.disjoint_sdiff_sdiff, hsum⟩

