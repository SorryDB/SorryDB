import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f : Finset ℕ → ℕ := fun A => ∑ x in A, x
  have hf : ∀ A ∈ S.powerset, f A ∈ Finset.range 1001 := by
    intro A hA
    apply Nat.lt_succ_of_le
    calc ∑ x in A, x ≤ ∑ x in S, x := Finset.sum_le_sum_of_subset (Finset.mem_powerset.1 hA)
      _ ≤ ∑ x in S, 100 := Finset.sum_le_sum (fun x hx => by
        have := h₁ hx; simp at this; omega)
      _ = 10 * 100 := by rw [Finset.sum_const, h₀]
      _ = 1000 := by norm_num
  obtain ⟨A, hA, B, hB, hne, heq⟩ :=
    Finset.exists_ne_map_eq_of_card_lt_card S.powerset (Finset.range 1001) hf (by
      rw [Finset.card_powerset, h₀]; simp)
  let S1 := A \ B
  let S2 := B \ A
  have h1S : S1 ⊆ S := (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA)
  have h2S : S2 ⊆ S := (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB)
  have hsum : ∑ x in S1, x = ∑ x in S2, x := by
    apply Nat.add_left_cancel (G := ℕ) (n := ∑ x in A ∩ B, x)
    rw [Finset.sum_inter_add_sum_diff, Finset.inter_comm, Finset.sum_inter_add_sum_diff, heq]
  have h_empty {X : Finset ℕ} (hX : X ⊆ S) (hx0 : ∑ x in X, x = 0) : X = ∅ := by
    rw [Finset.sum_eq_zero_iff] at hx0; apply Finset.eq_empty_of_forall_not_mem
    intro x hx; have := h₁ (hX hx); simp at this; specialize hx0 x hx; omega
  have h1ne : S1.Nonempty := by
    by_contra h; have h1e := Finset.not_nonempty_iff_eq_empty.1 h
    have h2e : S2 = ∅ := h_empty h2S (by rw [← hsum, h1e, Finset.sum_empty])
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h1e)
      (Finset.sdiff_eq_empty_iff_subset.1 h2e))
  have h2ne : S2.Nonempty := by
    by_contra h; have h2e := Finset.not_nonempty_iff_eq_empty.1 h
    have h1e : S1 = ∅ := h_empty h1S (by rw [hsum, h2e, Finset.sum_empty])
    exact hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h1e)
      (Finset.sdiff_eq_empty_iff_subset.1 h2e))
  use S1, S2, h1ne, h1S, h2ne, h2S, Finset.disjoint_sdiff_sdiff, hsum
