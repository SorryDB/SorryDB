import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let s := S.powerset
  let t := Finset.range 991
  have h_card : t.card < s.card := by
    simp [Finset.card_powerset, h₀]
    norm_num
  have h_maps : ∀ A ∈ s, (∑ x in A, x) ∈ t := by
    intro A hA
    simp only [Finset.mem_powerset] at hA
    simp only [Finset.mem_range]
    calc
      ∑ x in A, x ≤ ∑ _ in A, 99 := Finset.sum_le_sum (λ x hx => by linarith [(Finset.mem_Ico.1 (h₁ (hA hx))).2])
      _ = A.card * 99 := by simp
      _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (h₀ ▸ Finset.card_le_card hA)
      _ < 991 := by norm_num
  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_card h_maps
  let S1 := A \ B
  let S2 := B \ A
  have hS1S : S1 ⊆ S := (Finset.sdiff_subset A B).trans (Finset.mem_powerset.1 hA)
  have hS2S : S2 ⊆ S := (Finset.sdiff_subset B A).trans (Finset.mem_powerset.1 hB)
  have h_sum_sdiff : ∑ x in S1, x = ∑ x in S2, x := by
    have h1 := Finset.sum_sdiff_add_sum_inter A B (λ x => x)
    have h2 := Finset.sum_sdiff_add_sum_inter B A (λ x => x)
    rw [Finset.inter_comm] at h2
    linarith [h1, h2, hsum]
  have hS1ne : S1.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS1e
    have hS2e : S2 = ∅ := by
      rw [Finset.sum_eq_zero_iff] at h_sum_sdiff
      · exact Finset.eq_empty_of_forall_not_mem (λ x hx => by linarith [(Finset.mem_Ico.1 (h₁ (hS2S hx))).1, h_sum_sdiff x hx])
      · rwa [hS1e, Finset.sum_empty] at h_sum_sdiff
    exact hne (by rw [← Finset.sdiff_union_inter A B, ← Finset.sdiff_union_inter B A, hS1e, hS2e, Finset.inter_comm])
  have hS2ne : S2.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty]
    intro hS2e
    rw [hS2e, Finset.sum_empty] at h_sum_sdiff
    have hS1e : S1 = ∅ := Finset.sum_eq_zero_iff.1 h_sum_sdiff (λ x hx => by linarith [(Finset.mem_Ico.1 (h₁ (hS1S hx))).1])
    exact hS1ne (Finset.nonempty_iff_ne_empty.2 hS1e)
  exists S1, S2
  exact ⟨hS1ne, hS1S, hS2ne, hS2S, Finset.disjoint_sdiff_sdiff, h_sum_sdiff⟩
```
