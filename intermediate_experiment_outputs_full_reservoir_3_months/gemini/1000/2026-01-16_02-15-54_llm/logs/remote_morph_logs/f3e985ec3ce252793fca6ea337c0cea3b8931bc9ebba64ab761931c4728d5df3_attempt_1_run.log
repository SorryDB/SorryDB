import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f (A : Finset ℕ) : ℕ := ∑ x ∈ A, x
  have hf : ∀ A ∈ S.powerset, f A ∈ Finset.range 991 := by
    intro A hA
    have hAS : A ⊆ S := Finset.mem_powerset.1 hA
    apply Finset.mem_range.2
    have h99 : ∀ x ∈ A, x ≤ 99 := by
      intro x hx
      have := h₁ (hAS hx)
      simp at this; omega
    calc f A ≤ ∑ x ∈ A, 99 := Finset.sum_le_sum h99
         _ = A.card * 99 := by simp
         _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 ((Finset.card_le_card hAS).trans h₀.le)
         _ < 991 := by norm_num
  have h_card : (Finset.range 991).card < S.powerset.card := by
    rw [Finset.card_range, Finset.card_powerset, h₀]
    norm_num
  obtain ⟨A, hA, B, hB, hAB_ne, hAB_eq⟩ := Finset.exists_ne_map_eq_of_card_lt_card f hf h_card
  let S₁ := A \ B; let S₂ := B \ A
  have hS1S : S₁ ⊆ S := (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.1 hA)
  have hS2S : S₂ ⊆ S := (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.1 hB)
  have h_sum : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
    have h1 := Finset.sum_sdiff_add_sum_inter A B
    have h2 := Finset.sum_sdiff_add_sum_inter B A
    rw [f] at hAB_eq; rw [Finset.inter_comm] at h2; omega
  have h_empty {T : Finset ℕ} (hT : T ⊆ S) : ∑ x ∈ T, x = 0 ↔ T = ∅ := by
    constructor
    · intro h; by_contra hne
      obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.2 hne
      have : 10 ≤ x := by have := h₁ (hT hx); simp at this; omega
      have : 0 < ∑ x ∈ T, x := Nat.pos_of_mem_sum hx (by omega)
      omega
    · rintro rfl; simp
  have h_S1_ne : S₁.Nonempty := by
    by_contra hS1ne
    have hS1 : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.1 hS1ne
    have hS2 : S₂ = ∅ := (h_empty hS2S).1 (by rw [← h_sum, (h_empty hS1S).2 hS1])
    apply hAB_ne; rw [← Finset.sdiff_eq_empty_iff_subset] at hS1 hS2; exact Finset.subset_antisymm hS1 hS2
  have h_S2_ne : S₂.Nonempty := by
    rw [Finset.nonempty_iff_ne_empty, ← h_empty hS2S, h_sum, h_empty hS1S]
    exact h_S1_ne.ne_empty
  use S₁, S₂; exact ⟨h_S1_ne, hS1S, h_S2_ne, hS2S, Finset.disjoint_sdiff_sdiff, h_sum⟩

