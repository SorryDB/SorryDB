import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Given any set of ten distinct numbers in the range $10,11,\ldots,99$, prove that we can always find two disjoint subsets with the same sum. -/
@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  obtain ⟨A, hA, B, hB, hAB_ne, hAB_eq⟩ : ∃ A ∈ S.powerset, ∃ B ∈ S.powerset, A ≠ B ∧ ∑ x in A, x = ∑ x in B, x := by
    apply Finset.exists_ne_map_eq_of_card_lt_card (fun T hT => Finset.mem_range.2 ?_)
    · have hT_sub : T ⊆ S := Finset.mem_powerset.1 hT
      calc ∑ x in T, x ≤ ∑ _ in T, 99 := Finset.sum_le_sum (fun x hx => by have := h₁ (hT_sub hx); rw [Finset.mem_Ico] at this; omega)
           _ = T.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
           _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 ((Finset.card_le_card hT_sub).trans_eq h₀)
           _ < 1024 := by decide
    · rw [Finset.card_powerset, h₀, Finset.card_range]; decide
  rw [Finset.mem_powerset] at hA hB
  let S₁ := A \ B; let S₂ := B \ A
  have h_sum : ∑ x in S₁, x = ∑ x in S₂, x := by
    rw [← Finset.sum_sdiff_add_sum_inter A B, ← Finset.sum_sdiff_add_sum_inter B A, Finset.inter_comm] at hAB_eq
    exact Nat.add_right_cancel hAB_eq
  have h_empty {T : Finset ℕ} (hT : T ⊆ S) (hsum : ∑ x in T, x = 0) : T = ∅ := by
    apply Finset.eq_empty_of_forall_not_mem; intro x hx
    have := Finset.le_sum_of_mem hx (f := id); rw [hsum] at this
    have := h₁ (hT hx); rw [Finset.mem_Ico] at this; omega
  have hS1 : S₁.Nonempty := by
    by_contra h; have h1 := Finset.not_nonempty_iff_eq_empty.1 h
    have h2 : S₂ = ∅ := h_empty (Finset.sdiff_subset.trans hB) (by rw [← h_sum, h1, Finset.sum_empty])
    exact hAB_ne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.1 h1) (Finset.sdiff_eq_empty_iff_subset.1 h2))
  have hS2 : S₂.Nonempty := by
    by_contra h; have h2 := Finset.not_nonempty_iff_eq_empty.1 h
    have h1 : S₁ = ∅ := h_empty (Finset.sdiff_subset.trans hA) (by rw [h_sum, h2, Finset.sum_empty])
    exact hS1.ne_empty h1
  use S₁, S₂
  exact ⟨hS1, Finset.sdiff_subset.trans hA, hS2, Finset.sdiff_subset.trans hB, Finset.disjoint_sdiff_sdiff, h_sum⟩

