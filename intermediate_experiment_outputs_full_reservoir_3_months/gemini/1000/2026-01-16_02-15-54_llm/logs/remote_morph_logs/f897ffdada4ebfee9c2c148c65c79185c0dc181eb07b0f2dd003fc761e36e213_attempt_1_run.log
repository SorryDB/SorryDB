lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_fin := h.edgeSet_finite
  have h_sdiff : (E(P) \ M).encard = (M ∩ E(P)).encard + 1 := by
    obtain ⟨L, hL, hL_alt, hL_nonempty, hL_first, hL_last⟩ : ∃ L : List β, E(P) = L.toSet ∧
      L.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) ∧ L ≠ [] ∧ L.head! ∉ M ∧ L.last! ∉ M := by
      use P.edge, rfl, h.mem_matching_iff
      refine ⟨by simpa using h.nonempty, ?_, ?_⟩
      · intro he; apply h.first_not_in; exact ⟨_, he, h.toIsPath.head_mem⟩
      · intro he; apply h.last_not_in; exact ⟨_, he, h.toIsPath.last_mem⟩
    have h_nodup : L.Nodup := h.isTrail.edge_nodup
    rw [hL, encard_le_coe_iff.mpr ⟨L.length, rfl⟩]
    have : (L.filter (· ∉ M)).length = (L.filter (· ∈ M)).length + 1 := by
      induction L using List.reverseRecOn with
      | nil => contradiction
      | append_single e L' ih =>
        obtain rfl | hL'ne := L'.eq_nil_or_nonempty
        · simp at hL_last hL_alt hL_first; simp [hL_first]
        · have hL'alt := List.isChain_append.mp hL_alt |>.1
          have hL'last : L'.last hL'ne ∈ M := by
            have := List.isChain_append.mp hL_alt |>.2
            simpa [List.chain_singleton, hL_last] using this
          have h_len := ih hL'alt hL'ne (by simpa using hL_first) hL'last
          simp [List.filter_append, hL_last, h_len, Nat.add_comm]
    simp [this, encard_le_coe_iff.mpr ⟨_, rfl⟩, ← Nat.cast_add, h_nodup]
  rw [symmDiff_def, encard_union_eq_add_encard_of_disjoint disjoint_sdiff_sdiff,
    M_eq_sdiff_union_inter M E(P), encard_union_eq_add_encard_of_disjoint disjoint_sdiff_inter,
    h_sdiff, ← add_assoc, add_comm (1 : ℕ∞), add_assoc]
