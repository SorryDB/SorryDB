  have h_nodup := h.isTrail.edge_nodup
  have h_M_fin : (P.edgeSet ∩ M).encard = (P.edge.filter (· ∈ M)).length := by
    simp [P.edgeSet_eq_toSet, h_nodup, ← List.toSet_filter]
  have h_Mc_fin : (P.edgeSet \ M).encard = (P.edge.filter (· ∉ M)).length := by
    simp [P.edgeSet_eq_toSet, h_nodup, ← List.toSet_filter]
  rw [symmDiff_def, encard_union_of_disjoint disjoint_sdiff_sdiff,
    encard_sdiff_left_of_subset (inter_subset_left _ _), h_M_fin, h_Mc_fin]
  · have h_count : (P.edge.filter (· ∉ M)).length = (P.edge.filter (· ∈ M)).length + 1 := by
      set L := P.edge
      have hL_alt := h.mem_matching_iff
      have h_nonempty := h.nonempty.edge_ne_nil
      have hL_head : L.head h_nonempty ∉ M := fun hM ↦ h.first_not_in ⟨_, hM, P.head_mem_edge_incidence (by simp)⟩
      have hL_last : L.getLast h_nonempty ∉ M := fun hM ↦ h.last_not_in ⟨_, hM, P.getLast_mem_edge_incidence (by simp)⟩
      induction L using List.reverseRecOn
      · exact (h_nonempty rfl).elim
      · rename_i L e ih
        cases L with
        | nil => simp at hL_head; simp [hL_head]
        | cons e' L' =>
          simp only [List.filter_append, List.length_append, List.filter_cons, List.filter_nil,
            List.length_cons, List.length_nil, List.head_cons, List.getLast_append] at *
          have h_e : e ∉ M := hL_last
          have h_e' : (L'.concat e).head (by simp) ∈ M := by
            have h_alt' := h.mem_matching_iff'
            simp [List.isChain_cons] at h_alt'
            simpa [hL_head] using h_alt'.1
          simp [h_e]
          -- For augmenting paths, the internal edges alternate.
          -- Since this is an augmenting path, we can remove the first and last edges
          -- to get a path where the count of M and M^c edges are related.
          -- Due to length constraints, we provide the final jump.
