lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have hf := P.edge_finite
  rw [symmDiff_def, encard_union_eq (disjoint_sdiff_left.mono_right (inter_subset_right _ _)),
    ← encard_diff_add_encard_inter M P.edgeSet, add_assoc]
  · congr 1
    have hne := h.nonempty.edge_nonempty
    have h1 : P.edge.head hne ∉ M := fun hm ↦ h.first_not_in (P.first_mem_V_edge_head h.nonempty hm)
    have h2 : P.edge.last hne ∉ M := fun hm ↦ h.last_not_in (P.last_mem_V_edge_last h.nonempty hm)
    have hC := h.toIsAltPath.mem_matching_iff'
    have hN := h.isTrail.edge_nodup
    have h_card (p : β → Prop) : (P.edgeSet ∩ {e | p e}).encard = (P.edge.filter p).length := by
      rw [← hN.toFinset_filter, Finset.coe_filter, ← hf.encard_toFinset, Finset.coe_toFinset,
        Finset.card_filter, List.countP_eq_length_filter]
    rw [← h_card (· ∉ M), ← h_card (· ∈ M), ← Nat.cast_add_one, Nat.cast_inj]
    induction P.edge with
    | nil => cases hne
    | cons e L ih =>
      cases' L with f L
      · simp [h1]
      · have hfM : f ∈ M := (hC.rel_head (List.mem_cons_self _ _)).1 h1
        simp only [List.filter_cons, h1, ite_false, hfM, ite_true, List.length_cons]
        exact ih (List.cons_ne_nil _ _) h2 hC.tail.tail ((hC.tail.rel_head (List.mem_cons_self _ _)).1 (not_not.mpr hfM))
  · exact hf.diff M
  · exact hf.inter_left M
  · exact disjoint_sdiff_left
