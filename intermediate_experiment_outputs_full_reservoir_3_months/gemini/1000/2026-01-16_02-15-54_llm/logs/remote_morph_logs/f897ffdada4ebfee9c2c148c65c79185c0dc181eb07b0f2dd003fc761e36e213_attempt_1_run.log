lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have hfin := P.edgeSet_finite
  have h_nodup := h.isTrail.edge_nodup
  have h_ne := WList.edge_nonempty_iff.mpr h.nonempty
  have h_alt := h.mem_matching_iff
  have h_head : P.edge.head h_ne ∉ M := fun hM' ↦ h.first_not_in ⟨_, hM', P.head_mem_edge_V_inc h_ne⟩
  have h_last : P.edge.last h_ne ∉ M := fun hM' ↦ h.last_not_in ⟨_, hM', P.last_mem_edge_V_inc h_ne⟩
  have h1 : (E(P) \ M).encard = (M ∩ E(P)).encard + 1 := by
    simp_rw [encard_eq_coe_ncard (hfin.diff M), encard_eq_coe_ncard (hfin.inter_left M),
      ncard_diff_list_filter h_nodup, ncard_inter_list_filter h_nodup]
    generalize hl : P.edge = L
    have hL_ne : L ≠ [] := by rw [← hl]; exact h_ne
    have hL_alt : L.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := by rw [← hl]; exact h_alt
    have hL_head : L.head hL_ne ∉ M := by rw [← hl]; exact h_head
    have hL_last : L.last hL_ne ∉ M := by rw [← hl]; exact h_last
    clear hl h hfin h_nodup h_ne h_alt h_head h_last
    induction L with
    | nil => contradiction
    | cons e1 tail ih =>
      match tail with
      | [] => simp at hL_head hL_last; simp [hL_head]
      | e2 :: tail' =>
        simp at hL_alt hL_head hL_last
        have h_e2 : e2 ∈ M := by rwa [hL_head, false_iff] at hL_alt
        have h_t_ne : tail' ≠ [] := by intro h_t; simp [h_t] at hL_last; contradiction
        have h_t_head : tail'.head h_t_ne ∉ M := by
          have h_alt2 := hL_alt.2.1; rwa [h_e2, true_iff] at h_alt2
        simp [hL_head, h_e2, ih hL_alt.2.2 h_t_head hL_last]
        rw [Nat.add_succ, Nat.succ_add]
  rw [encard_symmDiff, encard_diff_left M hfin, h1, ← add_assoc, add_comm 1, add_assoc, encard_diff_add_inter M hfin]
