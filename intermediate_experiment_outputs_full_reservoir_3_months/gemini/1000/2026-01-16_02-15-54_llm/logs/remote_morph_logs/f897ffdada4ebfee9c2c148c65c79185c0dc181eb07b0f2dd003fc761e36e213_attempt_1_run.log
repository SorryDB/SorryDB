lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have hf := h.toIsPath.edgeSet_finite
  rw [symmDiff_eq_diff_union, encard_union_eq disjoint_diff_diff_left,
    encard_diff_finite M hf, ← encard_inter_add_diff M hf, add_assoc, add_comm (1 : ℕ∞), add_assoc]
  congr 1
  let L := P.edge
  have hne := h.nonempty.edge_nonempty
  have h_alt : L.Chain' (fun e f ↦ (e ∈ M) ↔ (f ∉ M)) := h.mem_matching_iff
  have h_head : L.head hne ∉ M := fun hm ↦ h.first_not_in (G.mem_v_of_mem_e hm (P.first_mem_inc_head hne))
  have h_last : L.last hne ∉ M := fun hm ↦ h.last_not_in (G.mem_v_of_mem_e hm (P.last_mem_inc_last hne))
  have h_diff : (E(P) \ M).encard = (L.filter (· ∉ M)).length := by
    rw [encard_eq_coe_size, ← List.toFinset_filter, List.toFinset_card_of_nodup h.isTrail.edge_nodup]
    rfl
  have h_inter : (M ∩ E(P)).encard = (L.filter (· ∈ M)).length := by
    rw [inter_comm, encard_eq_coe_size, ← List.toFinset_filter, List.toFinset_card_of_nodup h.isTrail.edge_nodup]
    rfl
  rw [h_diff, h_inter]
  norm_cast
  induction L with
  | nil => contradiction
  | cons e L ih =>
    cases L with
    | nil => simp at h_head h_last; simp [h_head, h_last]
    | cons f L =>
      simp only [List.chain'_cons, List.head_cons, List.filter_cons] at h_alt h_head h_last ⊢
      obtain ⟨hef, hfL⟩ := h_alt
      simp only [h_head, ↓reduce_not, hfL.head.1 h_head, ↓reduce_if, List.length_cons, ih hfL (hfL.head.1 h_head) h_last]
