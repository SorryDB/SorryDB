      rw [ih h_alt.2 (by simp) (by simpa [hf'] using h_alt.2.1) h_l, add_comm]
  rw [← List.toSet_filter, ← List.toSet_filter, List.encard_toSet (h_nodup.filter _),
    List.encard_toSet (h_nodup.filter _), h_len, Nat.cast_add, Nat.cast_one]
