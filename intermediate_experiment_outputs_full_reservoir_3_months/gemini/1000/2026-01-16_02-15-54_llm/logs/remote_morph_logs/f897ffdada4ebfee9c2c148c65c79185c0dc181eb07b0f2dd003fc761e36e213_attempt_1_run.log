  have h_head : L.head h_ne ∉ M := fun hm ↦ h.first_not_in ⟨L.head h_ne, hm, (P.first_mem_edge h_ne).left_mem⟩
  have h_last : L.last h_ne ∉ M := fun hm ↦ h.last_not_in ⟨L.last h_ne, hm, (P.last_mem_edge h_ne).right_mem⟩
  rw [h_fin.ncard_eq_filter_count, h_fin.ncard_eq_filter_count, List.countP_eq_length_filter, List.countP_eq_length_filter]
  clear h_fin h_inter_fin h_diff_fin h_nodup hM G h
  induction L using List.reverseRecOn with
  | nil => contradiction
  | last e L ih =>
    by_cases hL : L = []
    · subst hL; simp at h_head h_last; simp [h_head]
    · have h_ne' : L ≠ [] := hL
      have h_alt' : L.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := List.isChain_append.mp h_alt |>.1
