lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  rw [← encard_diff_add_encard_inter M E(P), symmDiff_eq_sdiff_union,
    encard_union (disjoint_sdiff_left.mono_right (diff_subset _ _)), ← encard_sep, ← encard_sep]
  congr 1
  have hP := h.toIsPath; have hne : P.edge ≠ [] := by
    intro he; obtain ⟨v, rfl⟩ := WList.eq_nil_of_edge_eq_nil he; exact h.nonempty.ne_nil rfl
  set l := P.edge
  rw [← hP.edge_nodup.encard_filter, ← hP.edge_nodup.encard_filter]
  exact_mod_cast (by
    have h_alt : l.Chain (· ∈ M ↔ · ∉ M) := h.mem_matching_iff
    have h_last : l.last hne ∉ M := fun hi ↦ h.last_not_in (G.mem_vinc_of_mem_edge hi (P.last_mem_vinc h.nonempty))
    have h_head : l.head hne ∉ M := fun hi ↦ h.first_not_in (G.mem_vinc_of_mem_edge hi (P.first_mem_vinc h.nonempty))
    induction l using List.induction_on generalizing h_head with
    | nil => exact (hne rfl).elim
    | cons e l ih =>
      obtain rfl | hlne := l.eq_nil_or_nonempty
      · simp [h_head, h_last]
      · have h_alt' := h_alt.tail; have h_last' : l.last hlne ∉ M := by rwa [List.last_cons hlne] at h_last
        simp [h_head, h_alt.1, ih hlne h_alt' h_last' (by simpa [h_head] using h_alt.1)]
        split_ifs <;> simp_all)
```
