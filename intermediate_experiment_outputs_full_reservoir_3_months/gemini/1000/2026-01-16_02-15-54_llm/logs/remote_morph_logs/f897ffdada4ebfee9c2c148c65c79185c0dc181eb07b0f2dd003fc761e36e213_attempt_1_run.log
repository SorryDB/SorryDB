lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have hf := P.edgeSet_finite
  have h_diff : (E(P) \ M).encard = (E(P) ∩ M).encard + 1 := by
    let L := P.edge; have hnodup := h.toIsAltPath.isTrail.edge_nodup; have hne := h.nonempty.edge_nonempty
    rw [← hnodup.encard_filter, ← hnodup.encard_filter]; have h_alt := h.toIsAltPath.mem_matching_iff
    have h_first : L.head hne ∉ M := fun hm ↦ h.first_not_in ⟨L.head hne, h.toIsPath.first_mem_edge_v hne, hm⟩
    have h_last : L.last hne ∉ M := fun hm ↦ h.last_not_in ⟨L.last hne, h.toIsPath.last_mem_edge_v hne, hm⟩
    norm_cast; clear hf hnodup hM G; induction L with
    | nil => exact (hne rfl).elim
    | cons e L IH =>
      cases L with
      | nil => simp_all
      | cons f L =>
        simp only [List.filter_cons, List.length_cons]; have h_alt_ef := h_alt.head
        have hMe : e ∉ M := h_first; have hMf : f ∈ M := h_alt_ef.mp hMe
        rw [if_neg hMe, if_pos hMf]; simp [add_comm, add_left_comm, add_assoc]
        apply IH (List.cons_ne_nil _ _) h_alt.tail.tail (h_alt.tail.head.mp hMf) h_last
  rw [symmDiff_def, encard_union_eq disjoint_sdiff_sdiff, ← encard_diff_add_encard_inter M E(P),
    h_diff, add_assoc, add_comm (encard (M ∩ E(P))), ← add_assoc]
