    ← encard_inter_add_encard_diff M hE, add_assoc, add_comm (E(P) ∩ M).encard]
  have h_alt : (E(P) \ M).encard = (E(P) ∩ M).encard + 1 := by
    set L := P.edge
    have h_nodup := h.toIsPath.edge_nodup
    have h_alt_list : (L.filter (· ∉ M)).length = (L.filter (· ∈ M)).length + 1 := by
      induction P with
      | nil x => exact (h.nonempty.not_nil rfl).elim
      | cons u e P ih =>
        have heM : e ∉ M := by
          intro h_in; apply h.first_not_in; rw [V_M_iff]
          exact ⟨e, h_in, by simp [WList.first, WList.edge]⟩
        obtain ⟨v, rfl⟩ | hP := P.exists_eq_nil_or_nonempty
