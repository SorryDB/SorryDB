lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_disj := disjoint_symmDiff_inter M E(P)
  have h_union : M ∆ E(P) ∪ M ∩ E(P) = M ∪ E(P) := by
    rw [symmDiff_def, union_comm, ← union_assoc, inter_union_diff, union_comm]
  have h_enc := (encard_union h_disj).symm.trans (by rw [h_union, ← encard_union disjoint_sdiff_left, union_sdiff_self_right])
  have h_count : (E(P) \ M).encard = (M ∩ E(P)).encard + 1 := by
    let L := P.edge
    have h_nodup : L.Nodup := h.isTrail.edge_nodup
    have h_eq (s : Set β) : (E(P) ∩ s).encard = (L.filter (· ∈ s)).length := by
      rw [E(P), ← List.toSet_filter, List.toSet_encard (h_nodup.filter _)]
    rw [h_eq M, Set.diff_eq, h_eq Mᶜ]
    have h_L_ne : L ≠ [] := h.nonempty
    have h_head : L.head h_L_ne ∉ M := by
      intro h_in; apply h.first_not_in; obtain ⟨u, e, P', hP⟩ := h.nonempty.exists_cons
      simp [hP, WList.first, WList.edge] at h_in ⊢; exact ⟨e, h_in, (h.toIsPath.toIsWalk.head_walk_isinc h_L_ne).inc_left⟩
    have h_last : L.getLast h_L_ne ∉ M := by
      intro h_in; apply h.last_not_in; obtain ⟨P', e, v, hP⟩ := h.nonempty.exists_concat
      simp [hP, WList.last, WList.edge] at h_in ⊢; exact ⟨e, h_in, (h.toIsPath.toIsWalk.last_walk_isinc h_L_ne).inc_right⟩
    clear h_disj h_union h_enc h_nodup h_eq
    induction L using List.rec with
    | nil => contradiction
    | cons e1 L' ih =>
      match L' with
      | [] => simp at h_head h_last; simp [h_head, h_last]
      | e2 :: L'' =>
        have h_chain := h.mem_matching_iff
        simp at h_head h_chain
        have h_e2 : e2 ∈ M := h_chain.left.mp h_head
        simp [h_head, h_e2, ih h_chain.right.right (by simp) (by simpa [h_e2] using h_chain.right.left) h_last]
  rw [h_count, ← add_assoc] at h_enc
  exact ENat.add_right_cancel h_enc (h.finite_edgeSet.inter_left M).encard_lt_top.ne
