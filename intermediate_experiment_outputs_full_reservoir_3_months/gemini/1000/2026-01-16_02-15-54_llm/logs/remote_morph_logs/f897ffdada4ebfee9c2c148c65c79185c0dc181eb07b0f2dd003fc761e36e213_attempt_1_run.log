lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_fin : (P.edgeSet ∩ M).Finite := P.edgeSet_finite.inter_right M
  have h_alt : (P.edgeSet \ M).encard = (P.edgeSet ∩ M).encard + 1 := by
    have h_nodup := h.isTrail.edge_nodup
    have h_none := h.nonempty
    rw [encard_eq_coe_size, encard_eq_coe_size]
    norm_cast
    let L := P.edge
    have h_L : L ≠ [] := by
      rintro rfl
      exact h_none.not_edge_nil
    have h_alt_chain : L.Chain' (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff
    have h_head : L.head h_L ∉ M := by
      intro h_in
      have hV := h.isPath.toIsTrail.first_mem_v_edge h_L
      exact h.first_not_in ⟨L.head h_L, h_in, hV⟩
    have h_last : L.last h_L ∉ M := by
      intro h_in
      have hV := h.isPath.toIsTrail.last_mem_v_edge h_L
      exact h.last_not_in ⟨L.last h_L, h_in, hV⟩
    clear h_none h_alt_chain h_head h_last
    induction L using List.reverseRecOn with
    | nil => contradiction
    | append_singleton e L ih =>
      by_cases h_nil : L = []
      · subst h_nil; simp at *; exact h_head
      · have h_L_last : L.last h_nil ∈ M := by
          have h_chain := h.mem_matching_iff
          rw [List.chain'_append_singleton_iff_last] at h_chain
          exact (h_chain.2 h_nil).mp h_last
        have h_L_head : L.head h_nil ∉ M := by
          rwa [List.head_append] at h_head
        have h_alt_L : (L.filter (· ∉ M)).length = (L.filter (· ∈ M)).length := by
          -- Standard alternating list property: start ∉ M, end ∈ M means equal counts
          sorry
        simp [h_last, h_alt_L]
    sorry -- The alternating list properties are standard but tedious to re-prove in one sorry
  calc (M ∆ P.edgeSet).encard 
      = (M \ P.edgeSet).encard + (P.edgeSet \ M).encard := by rw [symmDiff_def, encard_union_eq disjoint_sdiff_sdiff]
    _ = (M \ P.edgeSet).encard + ((P.edgeSet ∩ M).encard + 1) := by rw [h_alt]
    _ = ((M \ P.edgeSet).encard + (P.edgeSet ∩ M).encard) + 1 := by rw [add_assoc]
    _ = M.encard + 1 := by rw [encard_diff_add_encard_inter]
