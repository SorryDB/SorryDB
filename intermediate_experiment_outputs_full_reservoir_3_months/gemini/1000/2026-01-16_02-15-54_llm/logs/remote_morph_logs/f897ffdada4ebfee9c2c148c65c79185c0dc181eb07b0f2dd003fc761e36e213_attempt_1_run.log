        have ih' := ih h_aug; simp [WList.edge, heM, hfM] at ih' ⊢; exact ih'
    rw [← encard_coe, ← encard_coe, ← List.toFinset_coe, ← List.toFinset_coe, 
      Finset.coe_filter, Finset.coe_filter, ← List.toFinset_coe, Finset.coe_card, 
      Finset.coe_card, h_nodup.toFinset_card_filter, h_nodup.toFinset_card_filter, h_alt_list]
    simp [edgeSet]
  rw [h_alt, add_assoc, ← add_assoc 1, add_comm 1, add_assoc]
