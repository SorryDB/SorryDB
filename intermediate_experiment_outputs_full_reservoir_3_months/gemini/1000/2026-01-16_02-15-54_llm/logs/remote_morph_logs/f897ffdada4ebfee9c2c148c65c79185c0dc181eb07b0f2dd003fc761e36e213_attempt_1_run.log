lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have hE := h.toIsPath.finite_edgeSet
  have h_nodup := h.toIsPath.edge_nodup
  rw [symmDiff_def, encard_union_of_disjoint disjoint_sdiff_sdiff,
    ← encard_inter_add_diff M P.edgeSet, add_comm (encard (M \ P.edgeSet)), ← add_assoc]
  congr 1
  have : (P.edgeSet \ M).encard = (P.edgeSet ∩ M).encard + 1 := by
    revert h h_nodup
    induction P using WList.recOn with
    | nil u => intro h; exact (h.nonempty.ne_nil rfl).elim
    | cons u e P ih =>
      intro h h_nodup
      obtain ⟨v, rfl⟩ | hPne := P.exists_eq_nil_or_nonempty
      · simp only [edgeSet_cons, WList.edgeSet_nil, union_empty, diff_singleton_eq_self,
          inter_singleton_eq_empty, encard_singleton, encard_empty, zero_add]
        intro heM; exact h.first_not_in ⟨e, heM, by simp [h.toIsPath.hl]⟩
      · obtain ⟨v, f, w, P', rfl⟩ := hPne.exists_cons
        have h_alt := h.mem_matching_iff
        simp only [WList.cons_edge, List.isChain_cons_cons] at h_alt
        have heM : e ∉ M := fun heM ↦ h.first_not_in ⟨e, heM, by simp [h.toIsPath.hl]⟩
        have hfM : f ∈ M := h_alt.1.1.1.mp heM
        have h_nodup' : (WList.cons w f P').edge.Nodup := by
          simpa [WList.cons_edge] using h_nodup
        have h_aug : G.IsAugPath hM (WList.cons w f P') := by
          refine ⟨h.toIsPath.tail.tail, h.mem_matching.of_cons.of_cons, hPne.tail, ?_, h.last_not_in⟩
          intro hwM; exact (hM.subsingleton_inc v).eq ⟨hfM, by simp [h.toIsPath.tail.hl]⟩
            ⟨hwM, by simp [h.toIsPath.tail.hl]⟩ |>.symm.elim (h_nodup.not_mem_tail (by simp))
        specialize ih h_aug h_nodup'
        simp only [edgeSet_cons, diff_union_self, inter_union_self, encard_union_of_disjoint,
          disjoint_singleton_left, mem_diff, mem_inter_iff, heM, hfM, not_false_iff, true_and,
          encard_singleton, ih, add_assoc, add_comm 1]
        · rw [add_comm, ← add_assoc, add_comm 1]
        · exact disjoint_singleton_left.2 (fun hf ↦ h_nodup.not_mem_tail (by simp [hf]))
        · exact disjoint_singleton_left.2 (fun he ↦ h_nodup.not_mem_tail (by simp [he]))
  exact this
