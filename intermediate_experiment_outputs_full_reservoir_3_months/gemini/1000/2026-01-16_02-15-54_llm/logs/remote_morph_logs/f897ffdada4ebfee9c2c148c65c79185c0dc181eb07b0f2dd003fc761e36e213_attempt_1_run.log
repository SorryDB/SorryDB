    obtain ⟨u, e, w, rfl⟩ := h.nonempty.exists_cons
    simp [WList.cons_edge]
  have h_first : e1 ∉ M := by
    intro he1M
    obtain ⟨u, e, w, rfl⟩ := h.nonempty.exists_cons
    simp [WList.cons_edge] at h_e1
    subst e
    exact h.first_not_in (vDegree_gt_zero_iff_mem.1 (h.isPath.toIsWalk.vDegree_first_gt_zero h.nonempty)).1 e1 (by simp [he1M])
  have h_ek : P.edge.last? = some (P.edge.last h_none) := List.last?_eq_last h_none
  have h_last : P.edge.last h_none ∉ M := by
    intro hekM
    exact h.last_not_in (vDegree_gt_zero_iff_mem.1 (h.isPath.toIsWalk.vDegree_last_gt_zero h.nonempty)).1 _ (by simp [hekM])
  have h_len_odd : Odd P.edge.length := by
    obtain ⟨k, hk⟩ := List.IsChain.exists_odd_length_of_bool_alternating h_alt h_first h_last
    exact ⟨k, hk⟩
  have h_count : P.edge.length = 2 * (P.edge.filter (· ∈ M)).length + 1 := by
    rw [List.IsChain.length_filter_alternating_of_not_mem_ends h_alt h_first h_last]
