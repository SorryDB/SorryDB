          exact h_chain.1.1.1 heM
        have h_aug : G.IsAugPath hM (WList.cons w f P') := by
          refine ⟨h.toIsAltPath.suffix (WList.suffix_cons_cons _ _ _ _), hP, ?_, h.last_not_in⟩
          simp only [WList.first]; intro h_in; obtain ⟨e', he'M, hw⟩ := h_in
