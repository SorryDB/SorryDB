open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have h_S : ∀ n, n ∈ S ↔ ∃ k : ℕ, n = 50 * k + 39 := by
    intro n; rw [h₀]; constructor
    · rintro ⟨_, hmod⟩
      have h1 : 7 * n ≡ 23 [MOD 50] := (Nat.mul_mod_mul_iff_nat (by norm_num)).1 hmod
      have h2 : 7 * n ≡ 7 * 39 [MOD 50] := h1.trans (by norm_num [Nat.ModEq])
      have h3 : n ≡ 39 [MOD 50] := Nat.ModEq.cancel_left_coprime (by norm_num) h2
      exact ⟨n / 50, (Nat.mod_add_div n 50).symm.trans (by rw [h3]; norm_num [Nat.ModEq])⟩
    · rintro ⟨k, rfl⟩; constructor; · omega
      · rw [show 14 * (50 * k + 39) = 100 * (7 * k + 5) + 46 by ring, Nat.add_mul_mod_self_left]; norm_num
  have hu : u = 39 := by
    have h39 : 39 ∈ S := (h_S 39).mpr ⟨0, rfl⟩
    have : u ≤ 39 := h₁.2 h39
    obtain ⟨k, rfl⟩ := (h_S u).mp h₁.1; omega
  have hv : v = 89 := by
    have h89 : 89 ∈ S \ {u} := ⟨(h_S 89).mpr ⟨1, rfl⟩, by omega⟩
    have : v ≤ 89 := h₂.2 h89
    obtain ⟨k, rfl⟩ := (h_S v).mp h₂.1.1; have : v ≠ 39 := by omega
    omega
  norm_num [hu, hv]
