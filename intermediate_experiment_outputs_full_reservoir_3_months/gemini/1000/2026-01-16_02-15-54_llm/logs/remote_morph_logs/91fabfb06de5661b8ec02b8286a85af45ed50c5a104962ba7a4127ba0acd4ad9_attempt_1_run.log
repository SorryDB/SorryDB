open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hS : ∀ n ∈ S, n % 50 = 39 := by
    intro n hn; rw [h₀] at hn; obtain ⟨_, hmod⟩ := hn
    have h1 : 7 * n % 50 = 23 := (Nat.mul_right_inj (by norm_num)).mp (by
      rw [← Nat.mul_mod_mul_left 2 (7 * n) 50, hmod])
    have h2 : 49 * n % 50 = 11 := by
      have h2' := Nat.ModEq.mul_left 7 (a := 7 * n) (b := 23) (n := 50) h1
      rw [← Nat.mul_assoc] at h2'; norm_num at h2'; exact h2'
    have h3 : (11 + n) % 50 = 0 := by
      rw [← Nat.mod_add_mod, ← h2, Nat.mod_add_mod, ← Nat.add_mul]; norm_num; rw [Nat.mul_mod_right]
    apply Nat.ModEq.add_left_cancel (a := 11); rw [Nat.ModEq, h3]; norm_num
  have hu : u = 39 := h₁.unique ⟨by rw [h₀]; norm_num, fun n hn ↦ by
    rw [← Nat.div_add_mod n 50, hS n hn]; exact Nat.le_add_left 39 _⟩
  have hv : v = 89 := h₂.unique ⟨⟨by rw [h₀]; norm_num, by rw [hu]; norm_num⟩, fun n ⟨hn, hnu⟩ ↦ by
    have hsn := hS n hn
    have : n / 50 ≠ 0 := by intro h; have : n = 39 := by rw [← Nat.div_add_mod n 50, hsn, h]; norm_num
      rw [this, hu] at hnu; exact hnu rfl
    rw [← Nat.div_add_mod n 50, hsn]; have : 1 ≤ n / 50 := Nat.pos_iff_ne_zero.mpr this; linarith⟩
  rw [hu, hv]; norm_num
