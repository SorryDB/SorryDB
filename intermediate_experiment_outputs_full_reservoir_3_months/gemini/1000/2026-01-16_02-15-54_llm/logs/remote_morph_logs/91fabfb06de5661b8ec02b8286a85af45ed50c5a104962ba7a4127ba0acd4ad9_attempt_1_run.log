    · rintro ⟨_, h14n⟩
      have h : 14 * n ≡ 14 * 39 [MOD 100] := by rwa [h14n]; norm_num
      have h : 7 * n ≡ 7 * 39 [MOD 50] := Nat.ModEq.of_mul_left 2 h
      have h : n ≡ 39 [MOD 50] := Nat.ModEq.cancel_left_gcd (by norm_num) h
      use n / 50; rw [Nat.div_add_mod n 50, h]; norm_num
    · rintro ⟨k, rfl⟩; constructor; norm_num; rw [mul_add]; norm_num
  have hu : u = 39 := h₁.unique ⟨(hS 39).mpr ⟨0, rfl⟩, by rintro n hn; obtain ⟨k, rfl⟩ := (hS n).mp hn; linarith⟩
  have hv : v = 89 := h₂.unique ⟨⟨(hS 89).mpr ⟨1, rfl⟩, by simp [hu]⟩, by rintro n ⟨hn, hne⟩; obtain ⟨k, rfl⟩ := (hS n).mp hn; simp [hu] at hne; have : 0 < k := Nat.pos_of_ne_zero hne; linarith⟩
  rw [hu, hv]; norm_num
