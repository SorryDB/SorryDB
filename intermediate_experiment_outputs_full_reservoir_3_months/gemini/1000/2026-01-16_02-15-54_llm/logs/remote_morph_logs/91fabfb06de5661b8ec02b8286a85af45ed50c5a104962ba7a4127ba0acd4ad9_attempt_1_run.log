import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have hS : ∀ n, n ∈ S ↔ ∃ k, n = 50 * k + 39 := by
    intro n; rw [h₀]; constructor
    · rintro ⟨hpos, hmod⟩
      have h1 : 7 * n % 50 = 23 := Nat.mul_left_cancel (by norm_num) (by rw [← Nat.mul_mod, hmod]; norm_num)
      have h2 : n % 50 = 39 := by
        have := congr_arg (fun x => 43 * x % 50) h1
        rw [Nat.mul_mod, ← Nat.mul_assoc] at this; norm_num at this
      exact ⟨n / 50, by rw [← h2, Nat.div_add_mod]⟩
    · rintro ⟨k, rfl⟩; refine ⟨by linarith, ?_⟩
      rw [Nat.mul_add, ← Nat.mul_assoc]; have : 14 * 50 * k = 100 * (7 * k) := by ring
      rw [this, Nat.mul_add_mod_self_left]; norm_num
  have hu : u = 39 := h₁.unique ⟨hS.2 ⟨0, rfl⟩, fun n hn => by rcases hS.1 hn with ⟨k, rfl⟩; linarith⟩
  have hv : v = 89 := h₂.unique ⟨⟨hS.2 ⟨1, rfl⟩, by linarith⟩, fun n ⟨hn, hnu⟩ => by
    rcases hS.1 hn with ⟨k, rfl⟩; have : k ≠ 0 := by rintro rfl; linarith
    have : k ≥ 1 := Nat.succ_le_iff.mpr (Nat.pos_of_ne_zero this); linarith⟩
  rw [hu, hv]; norm_num
