    have h (ys : List a) (sl₁ sl₂ : SymList a) (hf : SymList.fromSL sl₁ = x :: SymList.fromSL sl₂) :
        List.map SymList.fromSL (List.scanl (flip SymList.snocSL) sl₁ ys) =
        List.map (fun l => x :: l) (List.map SymList.fromSL (List.scanl (flip SymList.snocSL) sl₂ ys)) := by
