              case pos h_pos =>
                apply h_s_e at h_pos
                apply Or.inr
                simp [h_pos]
              case neg h_neg =>
                apply Or.inl
                exact h_neg
            by_contra h_contra
            rw [h_contra] at h_u'_has_var
            contradiction))
