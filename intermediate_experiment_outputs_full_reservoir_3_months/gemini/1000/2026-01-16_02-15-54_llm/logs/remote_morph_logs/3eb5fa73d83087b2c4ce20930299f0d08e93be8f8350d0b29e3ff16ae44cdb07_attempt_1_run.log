      grind
  · intro hwf
    dsimp [well_formed, well_formed_alt] at *
    intro s hsome
    have ⟨y, hsome'⟩ := Option.isSome_iff_exists.mp hsome
    specialize hwf _ _ hsome'
    dsimp [well_formed'', well_formed'] at *
    split at hwf
    all_goals
      try obtain ⟨T, ht⟩ := hwf; exists T
      grind

end Env

