  | "tagger_untagger_val_ghost" => ∃ (T : Sigma (λ x => DecidableEq x) × Type _), ε s = some ⟨_, @StringModule.tagger_untagger_val_ghost T.1.1 T.1.2 T.2⟩
  | _ => True

def well_formed {α} (ε : Env String (String × α)) : Prop :=
