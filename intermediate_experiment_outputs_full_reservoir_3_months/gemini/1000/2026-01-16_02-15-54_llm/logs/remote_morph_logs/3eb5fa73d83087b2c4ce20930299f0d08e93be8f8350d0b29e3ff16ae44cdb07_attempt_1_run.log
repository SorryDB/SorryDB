def well_formed {α} (ε : Env String (String × α)) : Prop :=
  ∀ s, (ε s).isSome → well_formed' ε s

def well_formed_alt {α} (ε : Env String (String × α)) : Prop :=
  ∀ s y, ε s = some y → well_formed'' s.1 y

