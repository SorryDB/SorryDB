  | "join" => ∃ (T : Type _ × Type _), ε s = some ⟨_, StringModule.join T.1 T.2⟩
  | "load" => ∃ (T : Type _ × Type _), ε s = some ⟨_, StringModule.load T.1 T.2⟩
