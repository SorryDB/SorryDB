  | "operator3" => ∃ (T : Type _ × Type _ × Type _ × (Sigma (λ x => Inhabited x)) × String), m = ⟨_, @StringModule.operator3 T.1 T.2.1 T.2.2.1 T.2.2.2.1.1 T.2.2.2.1.2 T.2.2.2.2⟩
