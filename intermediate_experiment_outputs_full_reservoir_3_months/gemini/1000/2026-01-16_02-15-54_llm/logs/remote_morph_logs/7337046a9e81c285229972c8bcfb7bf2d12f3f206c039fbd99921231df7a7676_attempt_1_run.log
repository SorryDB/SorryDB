/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_and_ne.mpr ⟨refinement_le B hB hB' hB'', fun h ↦ ?_⟩
  rcases H with ⟨N, hN, hB_ne⟩
  apply hB_ne
  have h_sub : B N hN ⊆ D.carrier := by
    intro x hx
    have : x ∈ refinement B hB hB' hB'' := by simp [refinement]; exact ⟨N, hN, hx⟩
    rwa [← SetLike.ext_iff.mp h] at this
  apply Set.Subset.antisymm
  · intro x hx
    have x_le : x ≤ N := (hB N hN).symm ▸ le_sSup hx
    if h_x : x = N then exact h_x else
      have : x ≤ ⊥ := (D.sSupIndep N hN).mono_left x_le |>.eq_bot_of_le (le_sSup ⟨h_sub hx, h_x⟩)
      exact (hB'' N hN (le_bot_iff.mp this ▸ hx)).elim
  · intro x hx; rw [Set.mem_singleton_iff] at hx; subst hx
    by_contra h_N
    have : N ≤ ⊥ := (D.sSupIndep N hN).eq_bot_of_le (hB N hN ▸ sSup_le_sSup (fun y hy ↦ ⟨h_sub hy, fun he ↦ h_N (he ▸ hy)⟩))
    exact D.not_bot_mem (le_bot_iff.mp this ▸ hN)
