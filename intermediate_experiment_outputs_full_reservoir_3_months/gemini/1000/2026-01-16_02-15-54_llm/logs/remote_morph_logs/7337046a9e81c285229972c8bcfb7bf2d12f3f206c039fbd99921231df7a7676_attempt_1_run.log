/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_and_ne.mpr ⟨refinement_le B hB hB' hB'', ?_⟩
  intro h_eq
  rcases H with ⟨N, hN, h_B_ne⟩
  apply h_B_ne
  have h_sub : B N hN ⊆ D := by
    intro x hx; rw [h_eq]
    exact Set.mem_iUnion_of_mem N (Set.mem_iUnion_of_mem hN hx)
  apply Set.Subset.antisymm
  · intro x hx
    by_contra h_ne
    have h_disj := sSupIndep.disjoint_sSup D.sSupIndep (h_sub hx) (Set.singleton_subset_iff.mpr hN) h_ne
    have h_le : x ≤ N := hB N hN.symm ▸ le_sSup hx
    exact hB'' N hN (Disjoint.eq_bot_of_le h_disj h_le ▸ hx)
  · intro x hx
    rw [Set.mem_singleton_iff] at hx; subst x
    by_contra h_not
    have h_disj := sSupIndep.disjoint_sSup D.sSupIndep hN h_sub h_not
    rw [← hB N hN] at h_disj
    exact D.not_bot_mem (h_disj.eq_bot ▸ hN)
