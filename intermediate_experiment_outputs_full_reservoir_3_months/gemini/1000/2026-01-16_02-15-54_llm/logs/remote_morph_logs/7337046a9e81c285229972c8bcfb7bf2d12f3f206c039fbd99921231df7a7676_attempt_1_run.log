/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine' ⟨refinement_le B hB hB' hB'', fun hle => _⟩
  rcases H with ⟨N, hN, hne⟩
  apply hne
  rw [Set.eq_singleton_iff_nonempty_unique_mem]
  have h_ne : (B N hN).Nonempty := by
    by_contra h; have hNbot : N = ⊥ := by rw [hB N hN, Set.not_nonempty_iff_eq_empty.mp h, sSup_empty]
    exact D.not_bot_mem (hNbot ▸ hN)
  refine' ⟨h_ne, fun N' hN' => ?_⟩
  rcases hle (Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hN'⟩⟩) with ⟨B', hB', hN'eq⟩
  have : B' = {N} := by
    have h_sub : B' ⊆ {N} := fun x hx => by
      by_contra h; exact D.not_bot_mem (Disjoint.eq_bot_of_le (D.sSupIndep.disjoint_mem (hB' hx) hN h) (le_trans (le_sSup hx) (hN'eq ▸ hB N hN ▸ le_sSup hN')) ▸ hB' hx)
    have h_B'ne : B'.Nonempty := by
      by_contra h; have hN'bot : N' = ⊥ := by rw [hN'eq, Set.not_nonempty_iff_eq_empty.mp h, sSup_empty]
      exact hB'' N hN (hN'bot ▸ hN')
    exact Set.eq_singleton_iff_nonempty_unique_mem.mpr ⟨h_B'ne, h_sub⟩
  rw [hN'eq, this, sSup_singleton]
