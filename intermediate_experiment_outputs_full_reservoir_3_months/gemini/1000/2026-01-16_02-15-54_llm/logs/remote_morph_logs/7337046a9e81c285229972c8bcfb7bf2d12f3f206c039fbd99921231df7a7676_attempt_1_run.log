lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine' lt_iff_le_and_ne.mpr ⟨refinement_le B hB hB' hB'', fun h_eq => _⟩
  rcases H with ⟨N, hN, hB_ne⟩
  apply hB_ne
  have h_sub : B N hN ⊆ D.carrier := by
    rw [congr_arg carrier h_eq]
    intro b hb; exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hb⟩⟩
  have h_all : ∀ b ∈ B N hN, b = N := by
    intro b hb
    have hb_le : b ≤ N := hB N hN ▸ le_sSup hb
    by_contra hb_ne
    have : b ≤ N ⊓ sSup (D.carrier \ {N}) := le_inf hb_le (le_sSup ⟨h_sub hb, hb_ne⟩)
    exact hB'' N hN (hb ▸ le_bot_iff.mp (this.trans (D.sSupIndep N hN).le_bot))
  apply Set.Subset.antisymm (fun b hb => Set.mem_singleton_iff.mpr (h_all b hb))
  intro b hb; rw [Set.mem_singleton_iff] at hb; subst hb
  have h_nonempty : (B N hN).Nonempty := by
    by_contra h_empty
    have : N = ⊥ := by rw [hB N hN, Set.not_nonempty_iff_eq_empty.mp h_empty, sSup_empty]
    exact D.not_bot_mem (this ▸ hN)
  rcases h_nonempty with ⟨b, hb⟩
  rwa [h_all b hb]
