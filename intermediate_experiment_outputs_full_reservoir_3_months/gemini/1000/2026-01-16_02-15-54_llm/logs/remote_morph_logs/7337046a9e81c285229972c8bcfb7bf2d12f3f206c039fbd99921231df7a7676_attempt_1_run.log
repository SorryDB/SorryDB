/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_and_ne.mpr ⟨refinement_le B hB hB' hB'', ?_⟩
  intro h_eq
  rcases H with ⟨N₀, hN₀, h_ne⟩
  have h_sub : B N₀ hN₀ ⊆ D.carrier := by
    rw [h_eq]
    intro N' hN'
    exact Set.mem_iUnion.mpr ⟨N₀, Set.mem_iUnion.mpr ⟨hN₀, hN'⟩⟩
  have h_forall : ∀ N' ∈ B N₀ hN₀, N' = N₀ := by
    intro N' hN'
    have h_le : N' ≤ N₀ := (hB N₀ hN₀).symm ▸ le_sSup hN'
    by_contra h_ne'
    have h_disj := D.sSupIndep.disjoint_sSup (h_sub hN') (Set.singleton_subset_iff.mpr hN₀) h_ne'
    rw [sSup_singleton] at h_disj
    exact hB'' N₀ hN₀ (h_disj.eq_bot_of_le h_le ▸ hN')
  apply h_ne
  apply Set.Subset.antisymm
  · intro N' hN'; exact Set.mem_singleton_iff.mpr (h_forall N' hN')
  · have ⟨N', hN'⟩ : (B N₀ hN₀).Nonempty := by
      by_contra h_empty
      have h_bot : N₀ = ⊥ := by rw [hB N₀ hN₀, Set.not_nonempty_iff_eq_empty.mp h_empty, sSup_empty]
      exact D.not_bot_mem (h_bot ▸ hN₀)
    exact Set.singleton_subset_iff.mpr (h_forall N' hN' ▸ hN')
```
