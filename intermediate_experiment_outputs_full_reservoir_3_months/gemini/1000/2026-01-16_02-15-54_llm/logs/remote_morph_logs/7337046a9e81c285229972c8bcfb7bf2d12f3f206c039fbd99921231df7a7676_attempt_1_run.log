    by_contra h_N_not_in_B
    have : Disjoint N N := hB N hN ▸ sSupIndep.disjoint_sSup D.sSupIndep hN h_sub h_N_not_in_B
    exact D.not_bot_mem (Disjoint.eq_bot_of_self this ▸ hN)
