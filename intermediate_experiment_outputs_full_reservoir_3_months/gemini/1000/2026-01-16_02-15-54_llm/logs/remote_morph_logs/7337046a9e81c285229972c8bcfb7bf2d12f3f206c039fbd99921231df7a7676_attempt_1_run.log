    D < refinement B hB hB' hB'' := by
  refine lt_iff_le_and_ne.mpr ⟨refinement_le B hB hB' hB'', fun h_eq => ?_⟩
  rcases H with ⟨N, hN, h_ne⟩
  have h_eq_of_le {a b} (ha : a ∈ D) (hb : b ∈ D) (hab : a ≤ b) : a = b :=
    by_contra fun hab_ne =>
      have : a = ⊥ := (D.sSupIndep ha).eq_bot_of_le (hab.trans (le_sSup ⟨hb, hab_ne.symm⟩))
      D.not_bot_mem (this ▸ ha)
