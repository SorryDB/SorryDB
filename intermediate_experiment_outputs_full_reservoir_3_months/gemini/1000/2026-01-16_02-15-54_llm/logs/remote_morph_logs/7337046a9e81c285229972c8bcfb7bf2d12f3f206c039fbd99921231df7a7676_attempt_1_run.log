    D < refinement B hB hB' hB'' :=
  lt_iff_le_and_ne.mpr ⟨refinement_le B hB hB' hB'', fun h_eq => by
    rcases H with ⟨N, hN, h_ne⟩
    apply h_ne
    have h_sub : B N hN ⊆ D.carrier := h_eq.symm ▸ Set.subset_iUnion₂ N hN
    have ⟨M₀, hM₀⟩ : (B N hN).Nonempty := by
