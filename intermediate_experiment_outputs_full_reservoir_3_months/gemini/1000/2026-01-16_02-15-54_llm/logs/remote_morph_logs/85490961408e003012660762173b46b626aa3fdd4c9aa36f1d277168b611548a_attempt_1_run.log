variable {V Pt : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace Pt]
variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {A B C I X Y P K L : Pt} {ω : Sphere Pt}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C]) (AB_lt_AC : dist A B < dist A C)
    (AC_lt_BC : dist A C < dist B C)
    (incenter_eq_I : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).incenter = I)
    (incircle_eq_ω : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).insphere = ω)
    (X_mem_BC : X ∈ line[ℝ, B, C]) (X_ne_C : X ≠ C)
    (isTangent_mk'_X_parallel_AC : ω.IsTangent (AffineSubspace.mk' X line[ℝ, A, C].direction))
    (Y_mem_BC : Y ∈ line[ℝ, B, C]) (Y_ne_B : Y ≠ B)
    (isTangent_mk'_Y_parallel_AB : ω.IsTangent (AffineSubspace.mk' Y line[ℝ, A, B].direction))
    (P_mem_inter :
      P ∈ (line[ℝ, A, I] ∩ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).circumsphere : Set Pt))
    (P_ne_A : P ≠ A) (K_eq_midpoint_AC : K = midpoint ℝ A C)
    (L_eq_midpoint_AB : L = midpoint ℝ A B) : ∠ K I L + ∠ Y P X = π := by
  have h_abc : dist A B < dist A C ∧ dist A C < dist B C := ⟨AB_lt_AC, AC_lt_BC⟩
  have h_I : I = (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).incenter := incenter_eq_I
  have h_P : P ∈ line[ℝ, A, I] ∧ P ∈ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).circumsphere := by
    simpa [Set.mem_inter_iff] using P_mem_inter
  have h_K : K = midpoint ℝ A C := K_eq_midpoint_AC
  have h_L : L = midpoint ℝ A B := L_eq_midpoint_AB
  let T := (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt)
  let a := dist B C
  let b := dist A C
  let c := dist A B
  let s := (a + b + c) / 2
  have h_side_pos : 0 < a ∧ 0 < b ∧ 0 < c :=
    ⟨dist_pos.mpr (affineIndependent_ABC.ne 1 2),
     dist_pos.mpr (affineIndependent_ABC.ne 0 2),
     dist_pos.mpr (affineIndependent_ABC.ne 0 1)⟩
  have h_s_a : 0 < s - a := by linarith [T.dist_left_add_dist_right_gt_dist_bottom 0]
  have h_s_b : 0 < s - b := by linarith [T.dist_left_add_dist_right_gt_dist_bottom 1]
  have h_s_c : 0 < s - c := by linarith [T.dist_left_add_dist_right_gt_dist_bottom 2]
  have h_PI : dist P I = dist P B ∧ dist P I = dist P C := by
    have hP : P = T.circumsphere.center +ᵥ (T.circumsphere.radius • (P -ᵥ T.circumsphere.center)) := sorry
    exact ⟨sorry, sorry⟩
  have h_cos_KIL : Real.cos (∠ K I L) = (dist I K ^ 2 + dist I L ^ 2 - dist K L ^ 2) / (2 * dist I K * dist I L) :=
    LawOfCosines.cos_angle_dist (affineIndependent_ABC.ne 0 2) (affineIndependent_ABC.ne 0 1)
  have h_cos_YPX : Real.cos (∠ Y P X) = (dist P Y ^ 2 + dist P X ^ 2 - dist Y X ^ 2) / (2 * dist P Y * dist P X) :=
    LawOfCosines.cos_angle_dist (by sorry) (by sorry)
  have h_ratios : dist P X ^ 2 / dist I L ^ 2 = (a ^ 2 * b) / (s * c * (s - a)) ∧
                  dist P Y ^ 2 / dist I K ^ 2 = (a ^ 2 * c) / (s * b * (s - a)) ∧
                  dist Y X ^ 2 / dist K L ^ 2 = (4 * (s - a) ^ 2) / s ^ 2 := sorry
  have h_cos_sum : Real.cos (∠ K I L) = -Real.cos (∠ Y P X) := by
    rw [h_cos_KIL, h_cos_YPX]
    field_simp [h_side_pos.1, h_side_pos.2.1, h_side_pos.2.2]
    sorry
  rw [← Real.cos_pi_sub] at h_cos_sum
  exact sorry
