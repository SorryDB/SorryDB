variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {A B C I X Y P K L : Pt} {ω : Sphere Pt}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C]) (AB_lt_AC : dist A B < dist A C)
    (AC_lt_BC : dist A C < dist B C)
    (incenter_eq_I : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).incenter = I)
    (incircle_eq_ω : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).insphere = ω)
    (X_mem_BC : X ∈ line[ℝ, B, C]) (X_ne_C : X ≠ C)
    (isTangent_mk'_X_parallel_AC : ω.IsTangent (AffineSubspace.mk' X line[ℝ, A, C].direction))
    (Y_mem_BC : Y ∈ line[ℝ, B, C]) (Y_ne_B : Y ≠ B)
    (isTangent_mk'_Y_parallel_AB : ω.IsTangent (AffineSubspace.mk' Y line[ℝ, A, B].direction))
    (P_mem_inter :
      P ∈ (line[ℝ, A, I] ∩ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).circumsphere : Set Pt))
    (P_ne_A : P ≠ A) (K_eq_midpoint_AC : K = midpoint ℝ A C)
    (L_eq_midpoint_AB : L = midpoint ℝ A B) : ∠ K I L + ∠ Y P X = π := by
  let T := (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt)
  have h_angle : ∠ K I L = Real.arccos ((dist I K ^ 2 + dist I L ^ 2 - dist K L ^ 2) / (2 * dist I K * dist I L)) := law_cos_angle K I L
  have h_angle_P : ∠ Y P X = Real.arccos ((dist P Y ^ 2 + dist P X ^ 2 - dist Y X ^ 2) / (2 * dist P Y * dist P X)) := law_cos_angle Y P X
  have h_cos_sum : Real.cos (∠ K I L) = -Real.cos (∠ Y P X) := by
    let a := dist B C; let b := dist A C; let c := dist A B; let s := (a + b + c) / 2
    let r := T.insphere.radius
    have r_sq : r ^ 2 = (s - a) * (s - b) * (s - c) / s := T.insphere_radius_sq
    have hIK : dist I K ^ 2 = r ^ 2 + (s - c - b / 2) ^ 2 := T.dist_incenter_midpoint_side_sq (Fin.fixed 1)
    have hIL : dist I L ^ 2 = r ^ 2 + (s - b - c / 2) ^ 2 := T.dist_incenter_midpoint_side_sq (Fin.fixed 2)
    have hKL : dist K L = a / 2 := by rw [K_eq_midpoint_AC, L_eq_midpoint_AB, dist_midpoint_midpoint_side_triangle]
    have hBY : dist B Y = a * c / s := by
      have hY : dist Y (line[ℝ, A, B]) = 2 * r := by
        rw [incircle_eq_ω] at isTangent_mk'_Y_parallel_AB
        exact T.dist_parallel_tangent_insphere (Fin.fixed 2) Y_mem_BC isTangent_mk'_Y_parallel_AB Y_ne_B
      have h_sim : dist B Y / a = 2 * r / (2 * T.area / c) := by
        rw [← T.dist_vertex_side (Fin.fixed 2)]
        exact T.dist_side_ratio_alt (Fin.fixed 2) Y_mem_BC hY
      field_simp [T.area_eq_r_mul_s] at h_sim; exact h_sim
    have hCX : dist C X = a * b / s := by
      have hX : dist X (line[ℝ, A, C]) = 2 * r := by
        rw [incircle_eq_ω] at isTangent_mk'_X_parallel_AC
        exact T.dist_parallel_tangent_insphere (Fin.fixed 1) X_mem_BC isTangent_mk'_X_parallel_AC X_ne_C
      have h_sim : dist C X / a = 2 * r / (2 * T.area / b) := by
        rw [← T.dist_vertex_side (Fin.fixed 1)]
        exact T.dist_side_ratio_alt (Fin.fixed 1) X_mem_BC hX
      field_simp [T.area_eq_r_mul_s] at h_sim; exact h_sim
    have hXY : dist Y X = a * (b + c - a) / (2 * s) := by
      have : dist Y X = |a - (dist B Y + dist C X)| := by sorry
      field_simp [hBY, hCX, s]; ring_nf; sorry
    have hPY : dist P Y ^ 2 = (a / (2 * Real.cos (T.angle (Fin.fixed 0) / 2))) ^ 2 + (a / 2 - a * c / s) ^ 2 := sorry
    have hPX : dist P X ^ 2 = (a / (2 * Real.cos (T.angle (Fin.fixed 0) / 2))) ^ 2 + (a / 2 - a * b / s) ^ 2 := sorry
    sorry
  rw [h_angle, h_angle_P, Real.arccos_eq_pi_sub_arccos_neg]
  congr; exact h_cos_sum

end IMO2024P4

