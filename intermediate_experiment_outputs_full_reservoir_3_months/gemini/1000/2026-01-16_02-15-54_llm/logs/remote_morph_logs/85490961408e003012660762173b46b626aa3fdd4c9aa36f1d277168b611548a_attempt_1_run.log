import Mathlib


open scoped Real
open Affine EuclideanGeometry Module

namespace IMO2024P4

variable {V Pt : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace Pt]
variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {A B C I X Y P K L : Pt} {ω : Sphere Pt}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C]) (AB_lt_AC : dist A B < dist A C)
    (AC_lt_BC : dist A C < dist B C)
    (incenter_eq_I : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).incenter = I)
    (incircle_eq_ω : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).insphere = ω)
    (X_mem_BC : X ∈ line[ℝ, B, C]) (X_ne_C : X ≠ C)
    (isTangent_mk'_X_parallel_AC : ω.IsTangent (AffineSubspace.mk' X line[ℝ, A, C].direction))
    (Y_mem_BC : Y ∈ line[ℝ, B, C]) (Y_ne_B : Y ≠ B)
    (isTangent_mk'_Y_parallel_AB : ω.IsTangent (AffineSubspace.mk' Y line[ℝ, A, B].direction))
    (P_mem_inter :
      P ∈ (line[ℝ, A, I] ∩ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).circumsphere : Set Pt))
    (P_ne_A : P ≠ A) (K_eq_midpoint_AC : K = midpoint ℝ A C)
    (L_eq_midpoint_AB : L = midpoint ℝ A B) : ∠ K I L + ∠ Y P X = π := by
  let a := dist B C
  let b := dist A C
  let c := dist A B
  let s := (a + b + c) / 2
  have hI : I = (a / (2 * s)) • A + (b / (2 * s)) • B + (c / (2 * s)) • C := by
    rw [← incenter_eq_I, Triangle.incenter_eq_weighted_average_vertices]
    simp [a, b, c, s, divide_apply, mul_comm]
  have hK : K = (1 / 2 : ℝ) • A + (1 / 2 : ℝ) • C := by rw [K_eq_midpoint_AC, midpoint_eq_weighted_average_vertices]
  have hL : L = (1 / 2 : ℝ) • A + (1 / 2 : ℝ) • B := by rw [L_eq_midpoint_AB, midpoint_eq_weighted_average_vertices]
  have dist_sq_IK : dist I K ^ 2 = (b * (s - b) * (s - a)) / s := by sorry
  have dist_sq_IL : dist I L ^ 2 = (c * (s - c) * (s - a)) / s := by sorry
  have dist_sq_KL : dist K L ^ 2 = a ^ 2 / 4 := by
    rw [K_eq_midpoint_AC, L_eq_midpoint_AB, dist_midpoint_midpoint_common_left, a]
    field_simp
  have hCX : dist C X = (a * b) / s := by sorry
  have hBY : dist B Y = (a * c) / s := by sorry
  have dist_sq_PI : dist P I ^ 2 = (a ^ 2 * b * c) / ((2 * s - 2 * b) * (2 * s - 2 * c)) := by sorry
  have dist_sq_PX : dist P X ^ 2 = (dist P I ^ 2 * (s - b) * b) / (s * (s - c)) := by sorry
  have dist_sq_PY : dist P Y ^ 2 = (dist P I ^ 2 * (s - c) * c) / (s * (s - b)) := by sorry
  have dist_sq_XY : dist X Y ^ 2 = (a * (b - c) / s) ^ 2 := by sorry
  have cos_KIL : Real.cos (∠ K I L) = (dist I K ^ 2 + dist I L ^ 2 - dist K L ^ 2) / (2 * dist I K * dist I L) := by
    rw [dist_sq_eq_dist_sq_add_dist_sq_sub_two_mul_dist_mul_dist_mul_cos_angle]
    field_simp; ring
  have cos_YPX : Real.cos (∠ Y P X) = (dist P Y ^ 2 + dist P X ^ 2 - dist X Y ^ 2) / (2 * dist P Y * dist P X) := by
    rw [dist_sq_eq_dist_sq_add_dist_sq_sub_two_mul_dist_mul_dist_mul_cos_angle]
    field_simp; ring
  have h_cos_sum : Real.cos (∠ K I L) = -Real.cos (∠ Y P X) := by sorry
  rw [← Real.cos_pi_sub] at h_cos_sum
  apply (Real.angle_inj _ _).1
  · exact h_cos_sum
  · sorry
  · sorry
