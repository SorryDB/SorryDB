import Mathlib


open scoped Real
open Affine EuclideanGeometry Module

namespace IMO2024P4

variable {V Pt : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace Pt]
variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {A B C I X Y P K L : Pt} {ω : Sphere Pt}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C]) (AB_lt_AC : dist A B < dist A C)
    (AC_lt_BC : dist A C < dist B C)
    (incenter_eq_I : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).incenter = I)
    (incircle_eq_ω : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).insphere = ω)
    (X_mem_BC : X ∈ line[ℝ, B, C]) (X_ne_C : X ≠ C)
    (isTangent_mk'_X_parallel_AC : ω.IsTangent (AffineSubspace.mk' X line[ℝ, A, C].direction))
    (Y_mem_BC : Y ∈ line[ℝ, B, C]) (Y_ne_B : Y ≠ B)
    (isTangent_mk'_Y_parallel_AB : ω.IsTangent (AffineSubspace.mk' Y line[ℝ, A, B].direction))
    (P_mem_inter :
      P ∈ (line[ℝ, A, I] ∩ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).circumsphere : Set Pt))
    (P_ne_A : P ≠ A) (K_eq_midpoint_AC : K = midpoint ℝ A C)
    (L_eq_midpoint_AB : L = midpoint ℝ A B) : ∠ K I L + ∠ Y P X = π := by
  let T := (⟨![A, B, C], affineIndependent_ABC⟩ : Triangle ℝ Pt)
  let a := dist B C
  let b := dist A C
  let c := dist A B
  let s := (a + b + c) / 2
  have hP : P = T.circumcenter_midpoint_arc 0 := by
    rcases P_mem_inter with ⟨hPI, hPC⟩
    have hAI : A ∈ line[ℝ, A, I] := left_mem_line ℝ A I
    have hI : I ∈ line[ℝ, A, I] := right_mem_line ℝ A I
    have hA : A ∈ T.circumsphere := T.mem_circumsphere 0
    refine T.eq_circumcenter_midpoint_arc_of_mem_bisector_circumcircle 0 P P_ne_A ?_ hPC
    simpa [incenter_eq_I] using hPI
  have hX : dist C X = a * b / s := by
    have h_parallel : line[ℝ, A, C].direction = (AffineSubspace.mk' X (line[ℝ, A, C].direction)).direction := rfl
    have h_dist : dist I (line[ℝ, A, C] : Set Pt) = T.insphere.radius := by
      rw [← incircle_eq_ω, ← incenter_eq_I]
      exact T.dist_incenter_side 1
    have h_dist_X : dist I (AffineSubspace.mk' X line[ℝ, A, C].direction : Set Pt) = T.insphere.radius := by
      rw [← incircle_eq_ω, ← incenter_eq_I]
      exact isTangent_mk'_X_parallel_AC
    have h_X_BC : X ∈ line[ℝ, B, C] := X_mem_BC
    have h_C_BC : C ∈ line[ℝ, B, C] := right_mem_line ℝ B C
    have h_dist_between : dist (line[ℝ, A, C] : Set Pt) (AffineSubspace.mk' X line[ℝ, A, C].direction : Set Pt) = 2 * T.insphere.radius := by
      rw [dist_parallel_line_of_dist_eq (by rw [h_parallel]) h_dist h_dist_X]
      apply Or.resolve_left
      intro h_zero
      have h_X_AC : X ∈ line[ℝ, A, C] := by
        simpa [h_zero] using AffineSubspace.mem_mk' X (line[ℝ, A, C].direction)
      have h_X_C : X = C := (affineIndependent_ABC.line_inter_line 1 2).mp ⟨h_X_AC, h_X_BC⟩
      exact X_ne_C h_X_C
    have h_height : dist B (line[ℝ, A, C] : Set Pt) = 2 * T.area / b := T.dist_point_side 1
    have h_ratio : dist C X / a = (2 * T.insphere.radius) / (2 * T.area / b) := by
      rw [dist_line_line_ratio h_X_BC h_C_BC (by simpa [h_parallel])]
      field_simp [h_height, h_dist_between]
    rw [T.insphere_radius_eq_area_div_semiperimeter, s] at h_ratio
    field_simp at h_ratio
    exact h_ratio
  have hY : dist B Y = a * c / s := by
    have h_parallel : line[ℝ, A, B].direction = (AffineSubspace.mk' Y (line[ℝ, A, B].direction)).direction := rfl
    have h_dist : dist I (line[ℝ, A, B] : Set Pt) = T.insphere.radius := by
      rw [← incircle_eq_ω, ← incenter_eq_I]
      exact T.dist_incenter_side 2
    have h_dist_Y : dist I (AffineSubspace.mk' Y line[ℝ, A, B].direction : Set Pt) = T.insphere.radius := by
      rw [← incircle_eq_ω, ← incenter_eq_I]
      exact isTangent_mk'_Y_parallel_AB
    have h_Y_BC : Y ∈ line[ℝ, B, C] := Y_mem_BC
    have h_B_BC : B ∈ line[ℝ, B, C] := left_mem_line ℝ B C
    have h_dist_between : dist (line[ℝ, A, B] : Set Pt) (AffineSubspace.mk' Y line[ℝ, A, B].direction : Set Pt) = 2 * T.insphere.radius := by
      rw [dist_parallel_line_of_dist_eq (by rw [h_parallel]) h_dist h_dist_Y]
      apply Or.resolve_left
      intro h_zero
      have h_Y_AB : Y ∈ line[ℝ, A, B] := by
        simpa [h_zero] using AffineSubspace.mem_mk' Y (line[ℝ, A, B].direction)
      have h_Y_B : Y = B := (affineIndependent_ABC.line_inter_line 2 0).mp ⟨h_Y_AB, h_Y_BC⟩
      exact Y_ne_B h_Y_B
    have h_height : dist C (line[ℝ, A, B] : Set Pt) = 2 * T.area / c := T.dist_point_side 2
    have h_ratio : dist B Y / a = (2 * T.insphere.radius) / (2 * T.area / c) := by
      rw [dist_line_line_ratio h_Y_BC h_B_BC (by simpa [h_parallel])]
      field_simp [h_height, h_dist_between]
    rw [T.insphere_radius_eq_area_div_semiperimeter, s] at h_ratio
    field_simp at h_ratio
    exact h_ratio
  have hPX : dist P X = dist P L * (2 * (s - a) / s) := sorry
  have hPY : dist P Y = dist P K * (2 * (s - a) / s) := sorry
  have hXY : dist X Y = dist L K * (2 * (s - a) / s) := sorry
  have h_sim : Triangle.IsSimilar (Triangle.mk ![P, Y, X]) (Triangle.mk ![I, K, L]) := sorry
  rw [angle_comm K I L]
  exact T.angle_incenter_midpoint_sum_angle_circumcenter_midpoint_midpoint_arc h_P hX hY K_eq_midpoint_AC L_eq_midpoint_AB
