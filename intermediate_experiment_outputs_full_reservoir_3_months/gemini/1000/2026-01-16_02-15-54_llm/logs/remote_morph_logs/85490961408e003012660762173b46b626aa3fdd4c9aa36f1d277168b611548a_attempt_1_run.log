variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {A B C I X Y P K L : Pt} {ω : Sphere Pt}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C]) (AB_lt_AC : dist A B < dist A C)
    (AC_lt_BC : dist A C < dist B C)
    (incenter_eq_I : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).incenter = I)
    (incircle_eq_ω : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).insphere = ω)
    (X_mem_BC : X ∈ line[ℝ, B, C]) (X_ne_C : X ≠ C)
    (isTangent_mk'_X_parallel_AC : ω.IsTangent (AffineSubspace.mk' X line[ℝ, A, C].direction))
    (Y_mem_BC : Y ∈ line[ℝ, B, C]) (Y_ne_B : Y ≠ B)
    (isTangent_mk'_Y_parallel_AB : ω.IsTangent (AffineSubspace.mk' Y line[ℝ, A, B].direction))
    (P_mem_inter :
      P ∈ (line[ℝ, A, I] ∩ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).circumsphere : Set Pt))
    (P_ne_A : P ≠ A) (K_eq_midpoint_AC : K = midpoint ℝ A C)
    (L_eq_midpoint_AB : L = midpoint ℝ A B) : ∠ K I L + ∠ Y P X = π := by
  let T := (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt)
  let a := dist B C
  let b := dist A C
  let c := dist A B
  let s := (a + b + c) / 2
  have hP : dist P B = dist P I ∧ dist P C = dist P I := by
    have hPI := T.dist_incenter_midpoint_arc 0 1 2 (by norm_num) (by norm_num) (by norm_num)
    have hP_mem : P = T.circumcircle.arcMidpoint 1 2 0 := by
      rcases P_mem_inter with ⟨hAI, hCircum⟩
      exact T.circumcircle_arcMidpoint_eq_dist_incenter_of_mem_bisector hAI hCircum P_ne_A
    rw [hP_mem]
    exact ⟨hPI.1, hPI.2⟩
  have hX : dist P X * dist P K = (dist P I) ^ 2 := by
    have hCX : dist C X = a * b / s := by sorry
    have hPK : dist P K = (dist P C ^ 2) / (2 * dist P C * cos (∠ P C K)) := by sorry
    sorry
  have hY : dist P Y * dist P L = (dist P I) ^ 2 := by
    have hBY : dist B Y = a * c / s := by sorry
    sorry
  have hPXK : Triangle.IsSimilar (Triangle.mk P X Y) (Triangle.mk P L K) := by
    apply Triangle.isSimilar_S_A_S
    · field_simp [hX, hY]
      rw [mul_comm, hY, hX]
    · exact angle_self_el_el P X Y L K
  have h_cycl : Concyclic ![P, K, I, L] := by sorry
  rw [← Triangle.IsSimilar.angle_eq hPXK 0 2 1]
  exact h_cycl.angle_sum_eq_pi 0 2 1 3
