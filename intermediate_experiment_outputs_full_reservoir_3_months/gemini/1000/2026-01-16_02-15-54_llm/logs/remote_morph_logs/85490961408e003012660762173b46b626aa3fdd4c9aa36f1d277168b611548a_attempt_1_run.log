import Mathlib


open scoped Real
open Affine EuclideanGeometry Module

namespace IMO2024P4

variable {V Pt : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace Pt]
variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {A B C I X Y P K L : Pt} {ω : Sphere Pt}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C]) (AB_lt_AC : dist A B < dist A C)
    (AC_lt_BC : dist A C < dist B C)
    (incenter_eq_I : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).incenter = I)
    (incircle_eq_ω : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).insphere = ω)
    (X_mem_BC : X ∈ line[ℝ, B, C]) (X_ne_C : X ≠ C)
    (isTangent_mk'_X_parallel_AC : ω.IsTangent (AffineSubspace.mk' X line[ℝ, A, C].direction))
    (Y_mem_BC : Y ∈ line[ℝ, B, C]) (Y_ne_B : Y ≠ B)
    (isTangent_mk'_Y_parallel_AB : ω.IsTangent (AffineSubspace.mk' Y line[ℝ, A, B].direction))
    (P_mem_inter :
      P ∈ (line[ℝ, A, I] ∩ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).circumsphere : Set Pt))
    (P_ne_A : P ≠ A) (K_eq_midpoint_AC : K = midpoint ℝ A C)
    (L_eq_midpoint_AB : L = midpoint ℝ A B) : ∠ K I L + ∠ Y P X = π := by
  let T : Triangle ℝ Pt := ⟨![A, B, C], affineIndependent_ABC⟩
  let a := dist B C
  let b := dist A C
  let c := dist A B
  let s := (a + b + c) / 2
  have h_a_pos : 0 < a := dist_pos.mpr (affineIndependent_ABC.injective.ne (by norm_num) (by norm_num))
  have h_b_pos : 0 < b := dist_pos.mpr (affineIndependent_ABC.injective.ne (by norm_num) (by norm_num))
  have h_c_pos : 0 < c := dist_pos.mpr (affineIndependent_ABC.injective.ne (by norm_num) (by norm_num))
  have s_pos : 0 < s := by linarith
  have h_s_a : s - a = (b + c - a) / 2 := by ring
  have h_s_b : s - b = (a + c - b) / 2 := by ring
  have h_s_c : s - c = (a + b - c) / 2 := by ring
  have h_s_a_pos : 0 < s - a := by rw [h_s_a]; linarith [T.dist_less_add 1 2 0]
  have h_s_b_pos : 0 < s - b := by rw [h_s_b]; linarith [T.dist_less_add 0 2 1]
  have h_s_c_pos : 0 < s - c := by rw [h_s_c]; linarith [T.dist_less_add 0 1 2]
  have hP : P = T.circumcircle.center + (T.circumcircle.radius / dist T.incenter (line[ℝ, A, I].project I)) • (I -ᵥ line[ℝ, A, I].project I) := sorry
  have h_dist_CX : dist C X = a * b / s := sorry
  have h_dist_BY : dist B Y = a * c / s := sorry
  have h_dist_XY : dist X Y = a * (s - a) / s := sorry
  have h_dist_PX : dist P X = dist P Y := sorry
  have h_dist_IL : (dist I L) ^ 2 = (a - b) ^ 2 / 4 + T.insphere.radius ^ 2 := sorry
  have h_dist_IK : (dist I K) ^ 2 = (a - c) ^ 2 / 4 + T.insphere.radius ^ 2 := sorry
  have h_cos_KIL : Real.cos (∠ K I L) = (dist I K ^ 2 + dist I L ^ 2 - (a / 2) ^ 2) / (2 * dist I K * dist I L) := sorry
  have h_cos_YPX : Real.cos (∠ Y P X) = (2 * dist P X ^ 2 - (dist X Y) ^ 2) / (2 * dist P X ^ 2) := sorry
  have h_cos_sum : Real.cos (∠ K I L) = - Real.cos (∠ Y P X) := sorry
  exact (Real.angle_add_eq_pi_iff_cos_eq_neg).mpr h_cos_sum

end IMO2024P4
