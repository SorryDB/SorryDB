import Mathlib


open scoped Real
open Affine EuclideanGeometry Module

namespace IMO2024P4

variable {V Pt : Type*} [NormedAddCommGroup V] [InnerProductSpace ℝ V] [MetricSpace Pt]
variable [NormedAddTorsor V Pt] [Fact (finrank ℝ V = 2)]

theorem result {A B C I X Y P K L : Pt} {ω : Sphere Pt}
    (affineIndependent_ABC : AffineIndependent ℝ ![A, B, C]) (AB_lt_AC : dist A B < dist A C)
    (AC_lt_BC : dist A C < dist B C)
    (incenter_eq_I : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).incenter = I)
    (incircle_eq_ω : (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).insphere = ω)
    (X_mem_BC : X ∈ line[ℝ, B, C]) (X_ne_C : X ≠ C)
    (isTangent_mk'_X_parallel_AC : ω.IsTangent (AffineSubspace.mk' X line[ℝ, A, C].direction))
    (Y_mem_BC : Y ∈ line[ℝ, B, C]) (Y_ne_B : Y ≠ B)
    (isTangent_mk'_Y_parallel_AB : ω.IsTangent (AffineSubspace.mk' Y line[ℝ, A, B].direction))
    (P_mem_inter :
      P ∈ (line[ℝ, A, I] ∩ (⟨_, affineIndependent_ABC⟩ : Triangle ℝ Pt).circumsphere : Set Pt))
    (P_ne_A : P ≠ A) (K_eq_midpoint_AC : K = midpoint ℝ A C)
    (L_eq_midpoint_AB : L = midpoint ℝ A B) : ∠ K I L + ∠ Y P X = π := by
  let t : Triangle ℝ Pt := ⟨![A, B, C], affineIndependent_ABC⟩
  let r := t.insphere.radius
  let a := dist B C
  let b := dist A C
  let c := dist A B
  let s := (a + b + c) / 2
  have hI : I = t.incenter := incenter_eq_I
  have hω : ω = t.insphere := incircle_eq_ω
  have h_PI : dist P I = dist P B ∧ dist P C = dist P I := by
    have h_circ : P ∈ (t.circumsphere : Set Pt) := P_mem_inter.2
    have h_bis : P ∈ line[ℝ, A, I] := P_mem_inter.1
    exact ⟨dist_incenter_eq_dist_circumcircle_bisector_angle_arc_midpoint affineIndependent_ABC h_circ h_bis P_ne_A, 
           (dist_incenter_eq_dist_circumcircle_bisector_angle_arc_midpoint affineIndependent_ABC h_circ h_bis P_ne_A).symm.trans 
           (dist_circumcircle_bisector_angle_arc_midpoint_is_bisector affineIndependent_ABC h_circ h_bis P_ne_A)⟩
  have hX : X = (1 - b / s) • B + (b / s) • C := by
    have hX_line : X ∈ line[ℝ, B, C] := X_mem_BC
    have h_dist : dist_point_line X line[ℝ, A, C] = 2 * r := by
      rw [← t.insphere_radius_eq_dist_incenter_side (0 : Fin 3) (1 : Fin 3)]
      exact ω.dist_affineSubspace_mk'_of_isTangent_parallel isTangent_mk'_X_parallel_AC (t.side_line (0 : Fin 3) (2 : Fin 3))
    sorry
  have hY : Y = (1 - c / s) • C + (c / s) • B := by
    have hY_line : Y ∈ line[ℝ, B, C] := Y_mem_BC
    have h_dist : dist_point_line Y line[ℝ, A, B] = 2 * r := by
      rw [← t.insphere_radius_eq_dist_incenter_side (0 : Fin 3) (2 : Fin 3)]
      exact ω.dist_affineSubspace_mk'_of_isTangent_parallel isTangent_mk'_Y_parallel_AB (t.side_line (0 : Fin 3) (1 : Fin 3))
    sorry
  have h_sim1 : similarity_with (dist P B / dist I L) ![P, B, X] ![I, L, A] := sorry
  have h_sim2 : similarity_with (dist P C / dist I K) ![P, C, Y] ![I, K, A] := sorry
  have h_ratio : dist P X / dist I L = dist P Y / dist I K := sorry
  have h_angle : ∠ X P Y = π - ∠ L I K := sorry
  rw [angle_comm K I L, ← h_angle, angle_comm Y P X]
  simp
