have Npos : 0 < N := by exact_mod_cast NposR
have npos : 0 < n := by bound
have mpos : 0 < m := by bound
change |RiemannSum f a b m - RiemannSum f a b n| < őĶ
have hn_small : 2 * (b - a) / n < őī := by
  field_simp [hőī‚āĀ, hab] at hN
  have : (0 : ‚ĄĚ) < n := by exact_mod_cast npos
  field_simp [hőī‚āĀ, this] at *
  linarith
