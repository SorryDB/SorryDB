  let ps := (List.range (2 ^ nums.length)).map fun mask =>
    (List.range nums.length).foldr (fun i acc => if (mask.shiftRight i).land 1 == 1 then nums[i]! :: acc else acc) []
  let products := (ps.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  let products' := (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  have h_products_ne : products ≠ [] := by
    match nums with
    | x :: xs =>
      have : 1 < 2 ^ (x :: xs).length := by simp [List.length_cons]; apply Nat.one_lt_pow <;> simp
      use x
      simp [List.mem_map, List.mem_filter]
      refine ⟨⟨1, by simp [this], ?_⟩, by simp⟩
      simp [List.range, List.foldr]
      use 0; simp
  have h_max_some : products.max? = some (maxStrength nums h_precond) := by
    cases h : products.max? <;> simp_all
  have h_max := List.max?_eq_some_iff.1 h_max_some
  have h_eq : products.toFinset = products'.toFinset := by
    apply Finset.ext; intro x; simp; constructor
    · rintro ⟨s, ⟨⟨mask, _, rfl⟩, hs_ne⟩, rfl⟩
      refine ⟨s, ⟨?_, hs_ne⟩, rfl⟩
      induction nums generalizing mask with
      | nil => simp at hs_ne
      | cons y ys ih =>
        simp [List.range, List.foldr, List.sublists_cons]
        by_cases h : mask.land 1 = 1 <;> simp [h]
    · rintro ⟨s, ⟨hs_sub, hs_ne⟩, rfl⟩
      refine ⟨s, ⟨?_, hs_ne⟩, rfl⟩
      induction hs_sub with
      | slnil => simp at hs_ne
      | cons y ys _ ih =>
        match nums with | z :: zs =>
          obtain ⟨mask, h_mask, rfl⟩ := ih hs_ne
          use mask * 2; refine ⟨?_, ?_⟩
          · simp [h_mask]; apply Nat.mul_lt_mul_of_pos_right <;> simp [Nat.pow_pos]
          · simp [List.range, List.foldr]; split <;> simp_all
      | cons_same y ys _ ih =>
        match nums with | z :: zs =>
          by_cases hne : ys = []
          · use 1; simp [hne, List.range, List.foldr]; use 0; simp
