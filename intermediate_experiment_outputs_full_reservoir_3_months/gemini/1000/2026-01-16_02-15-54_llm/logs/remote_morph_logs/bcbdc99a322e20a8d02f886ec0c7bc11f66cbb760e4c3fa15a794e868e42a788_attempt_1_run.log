theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  unfold maxStrength maxStrength_postcond maxStrength_precond
  let ps mask := (List.range nums.length).foldr (fun i acc => if (mask.shiftRight i).land 1 == 1 then nums.get! i :: acc else acc) []
  let p1 := (List.range (2 ^ nums.length)).map ps |>.filter (· ≠ []) |>.map (List.foldl (· * ·) 1)
  let p2 := nums.sublists.filter (· ≠ []) |>.map (List.foldl (· * ·) 1)
  have hp1 : p1 ≠ [] := by
    simp; use 1; simp [List.length_pos_of_ne_empty h_precond, List.range, List.foldr]
    intro h; cases h
  have h_m : p1.max? = Some ((List.max? p1).getD (-1000000)) := by
    match h : p1.max? with
    | some m => simp [h]
    | none => simp [h] at hp1
  let m := (List.max? p1).getD (-1000000)
  simp only [h_m, List.getD_some, List.mem_filter, List.mem_map, List.mem_sublists, List.all_iff]
  have h_p1_p2 : ∀ x, x ∈ p1 ↔ ∃ s, s <+ nums ∧ s ≠ [] ∧ s.foldl (· * ·) 1 = x := by
    intro x; simp [p1]; constructor
    · rintro ⟨mask, -, hne, rfl⟩
      refine ⟨ps mask, ⟨?_, hne⟩, rfl⟩
      induction nums generalizing mask with
      | nil => simp [ps, List.range]
      | cons a l ih =>
        simp [ps, List.range, List.foldr]
        split <;> simp [*]
        · apply List.Sublist.cons₂; apply ih
        · apply List.Sublist.cons; apply ih
    · rintro ⟨s, hs, hne, rfl⟩
      let rec get_mask : ∀ {l s}, s <+ l → ℕ
        | _, _, .slnil => 0
        | a::l, _, .cons _ h => 2 * get_mask h
        | a::l, _, .cons₂ _ h => 2 * get_mask h + 1
      use get_mask hs
      constructor
      · constructor
        · induction hs with
          | slnil => simp [get_mask]
          | cons a h ih =>
            simp [get_mask]; calc
              2 * get_mask h < 2 * 2 ^ List.length _ := by linarith
              _ = 2 ^ (List.length _ + 1) := by simp [pow_succ]
          | cons₂ a h ih =>
            simp [get_mask]; calc
              2 * get_mask h + 1 ≤ 2 * (2 ^ List.length _ - 1) + 1 := by linarith
              _ = 2 * 2 ^ List.length _ - 1 := by linarith
              _ < 2 ^ (List.length _ + 1) := by simp [pow_succ]; linarith
        · induction hs with
          | slnil => simp [ps, List.range, List.foldr]
          | cons a h ih =>
            simp [ps, List.range, List.foldr, get_mask, Nat.shiftRight_succ]
            exact ih
          | cons₂ a h ih =>
            simp [ps, List.range, List.foldr, get_mask, Nat.shiftRight_succ]
            exact ih
      · exact hne
  have h_mem := List.max?_mem hp1
  have h_le := List.le_max?_of_mem (L := p1)
  rw [h_m] at h_mem h_le
  simp [h_p1_p2] at h_mem h_le
  exact ⟨h_mem, fun x hx => h_le x (h_p1_p2 x |>.mpr hx)⟩
