            use mask * 2 + 1; refine ⟨?_, ?_⟩
            · simp [h_mask]; omega
            · simp [List.range, List.foldr]; split <;> simp_all; split <;> simp_all
  simp_all [← List.mem_toFinset]
  exact ⟨h_max.1, fun x hx => h_max.2 x hx⟩
