import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  refine ⟨fun h ↦ h.1, fun hn ↦ ⟨hn, fun deck hpos hp ↦ ?_⟩⟩
  have h_int (j k : Fin n) : ∃ m : ℕ, (deck j + deck k : ℝ) / 2 = m := by
    rcases hp (j := j) (k := k) (by sorry) with ⟨S, hSn, hG⟩
    have : (deck j + deck k : ℝ) / 2 ^ (#S) = ∏ i ∈ S, (deck i : ℝ) := by sorry
    sorry
  have h_all_eq : ∀ j k, deck j = deck k := by
    let m := Finset.univ.sup deck
    let S_max := Finset.univ.filter (deck · = m)
    if h : S_max.card = n then
      intro j k; have : deck j = m ∧ deck k = m := by sorry
      rw [this.1, this.2]
    else
      have ⟨i, hi⟩ : ∃ i, deck i < m ∧ ∀ j, deck j < m → deck j ≤ deck i := by sorry
      rcases hp i (S_max.toList.head (by sorry)) (by sorry) with ⟨S, hSn, hG⟩
      have : (deck i + m : ℝ) / 2 ≤ (m : ℝ) := by sorry
      sorry
  intro i j; exact h_all_eq i j

