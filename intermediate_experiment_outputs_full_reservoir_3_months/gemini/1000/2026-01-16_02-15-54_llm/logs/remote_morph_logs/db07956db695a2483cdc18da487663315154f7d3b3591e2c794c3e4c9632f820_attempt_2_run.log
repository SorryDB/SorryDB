    let deck := fun (i : Fin n) ↦ if i.val < p then (2 : ℕ) else (1 : ℕ)
    have h0 : ∀ i, 0 < deck i := by intro i; dsimp [deck]; split <;> norm_num
    have h_not_eq : ∃ i j, deck i ≠ deck j := by
