import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  refine ⟨fun h ↦ h.1, fun hn ↦ ⟨hn, fun deck hpos hpair ↦ ?_⟩⟩
  by_contra! h_not_all_equal
  let s := ∑ i, deck i
  have : ∀ deck' : Fin n → ℕ, (∀ i, 0 < deck' i) → (Pairwise fun j k ↦
    ∃ S : Finset (Fin n), S.Nonempty ∧
      (deck' j + deck' k : ℝ) / 2 = (∏ i ∈ S, (deck' i : ℝ)) ^ (1 / (#S : ℝ))) →
    (∃ i j, deck' i ≠ deck' j) → ∑ i, deck' i ≥ s := fun _ _ _ _ ↦ s.le_refl
  have h_even : ∀ i j, (deck i + deck j) % 2 = 0 := fun i j ↦ by
    obtain ⟨S, hS, hG⟩ := if h : i = j then ⟨{i}, Finset.singleton_nonempty i, by simp [h]⟩ else hpair i j h
    have h_pow : ((deck i + deck j : ℝ) / 2) ^ S.card = ∏ k ∈ S, (deck k : ℝ) := by
      rw [hG, ← Real.rpow_natCast, ← Real.rpow_mul] <;> simp [hS.ne_empty]
    have h_rat : ∃ q : ℚ, (deck i + deck j : ℝ) / 2 = q := ⟨(deck i + deck j : ℚ) / 2, rfl⟩
    rcases h_rat with ⟨q, hq⟩
    have h_int : ∃ m : ℕ, (deck i + deck j : ℚ) / 2 = m := by
      have h_q_pow : (q ^ S.card).Denom = 1 := by
        have : (q : ℝ) ^ S.card = (∏ k ∈ S, (deck k : ℕ) : ℕ) := by rw [← h_pow]; rfl
        norm_cast at this
      exact ⟨q.num.toNat, by simpa [q.denom_eq_one_iff.mp h_q_pow] using q.num_nonneg.mpr (by simp [hq, hpos])⟩
    rcases h_int with ⟨m, hm⟩
    have : (deck i + deck j) = 2 * m := by
      have : (deck i + deck j : ℚ) = 2 * m := by simpa using hm
      norm_cast at this
    rw [this]; exact Nat.mul_mod_right 2 m
  have h_same_parity : ∀ i j, deck i % 2 = deck j % 2 := fun i j ↦ by
    have h1 := h_even i j
    have h2 := h_even i i
    simp [Nat.add_mod, h1, h2] at *
    omega
  if h_all_even : ∀ i, deck i % 2 = 0 then
    let deck' := fun i ↦ deck i / 2
    have h_deck' : ∀ i, 0 < deck' i := fun i ↦ Nat.pos_of_dvd_of_pos (by simp) (hpos i)
    have h_sum : ∑ i, deck' i < s := by
      rw [Finset.sum_hom (f := fun x ↦ x / 2)]; swap; · intros; simp [Nat.add_div]
      apply Nat.div_lt_of_quot_lt (Nat.lt_of_succ_le hn)
      simp [s, hpos]
    exact h_sum.not_le (this deck' h_deck' (fun j k hjk ↦ by
      obtain ⟨S, hS, hG⟩ := hpair j k hjk
      use S, hS
      simp [deck', hG]
      field_simp; ring_nf) h_not_all_equal)
  else
    have h_all_odd : ∀ i, deck i % 2 = 1 := fun i ↦ by
      have := h_same_parity i (choose (not_forall.mp h_all_even))
      omega
    let deck' := fun i ↦ deck i -- This part of the proof for odd deck elements is more involved.
    sorry
