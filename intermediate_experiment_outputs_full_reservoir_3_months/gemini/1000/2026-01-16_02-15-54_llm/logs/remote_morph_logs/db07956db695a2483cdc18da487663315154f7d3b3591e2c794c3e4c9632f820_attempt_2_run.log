import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n; simp [answer]; refine ⟨(·.1), fun hn deck h_pos h_mean ↦ ?_⟩
  by_contra! h_deck; let s := Finset.univ.image deck
  have h_s : 1 < s.card := Finset.one_lt_card_iff.mpr (let ⟨i, j, h⟩ := h_deck; ⟨deck i, by simp, deck j, by simp, h⟩)
  let y_m := s.max' (by simpa using pos_of_gt h_s); let s' := s.erase y_m
  let y_m1 := s'.max' (by simpa using nat_sub_one_pos_iff_le.mpr h_s)
  have h_y_m1_lt : y_m1 < y_m := Finset.max'_lt_max' _ _ (Finset.erase_subset _ _) (by simp) (Finset.max'_mem _ _)
  obtain ⟨j, k, hjk, hj, hk⟩ : ∃ j k, j ≠ k ∧ deck j = y_m1 ∧ deck k = y_m := by
    obtain ⟨j, hj⟩ := Finset.mem_image.mp (Finset.max'_mem s' (by simpa using nat_sub_one_pos_iff_le.mpr h_s))
    obtain ⟨k, hk⟩ := Finset.mem_image.mp (Finset.max'_mem s (by simpa using pos_of_gt h_s))
    exact ⟨j, k, by intro h; subst h; linarith, hj.2, hk.2⟩
  obtain ⟨S, hS, hGM⟩ := h_mean hjk
  have h_GM_le : (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ)) ≤ (∑ i ∈ S, (deck i : ℝ)) / #S := Real.geom_mean_le_arith_mean hS.to_multiset (by simp; intro i _; exact Nat.cast_nonneg _)
  have h_sum : ∑ i ∈ S, (deck i : ℝ) ≤ ((#S - 1 : ℕ) * y_m + y_m1 : ℕ) := by
    have h_le_m : ∀ i ∈ S, deck i ≤ y_m := fun i _ ↦ s.le_max' (deck i) (by simp)
    obtain ⟨i, hi⟩ := hS; by_cases h_im : deck i = y_m
    · have h_any : ∃ l ∈ S, deck l < y_m := by
        by_contra! h_all_m; have h_gm_m : (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ)) = y_m := by
          rw [show ∏ i ∈ S, (deck i : ℝ) = (y_m : ℝ) ^ #S by simp [h_all_m], Real.rpow_nat_inv_pow (Nat.cast_nonneg _) (by simp [hS.ne_empty])]
        rw [h_gm_m, hj, hk] at hGM; linarith
      obtain ⟨l, hl, hlt⟩ := h_any; rw [Finset.sum_eq_add_sum_diff hl]; gcongr
      · exact s.le_max' (deck l) (by simp [s', hlt.ne, h_le_m l hl])
      · exact Finset.sum_le_card_nsmul _ _ _ (fun x hx ↦ h_le_m x (Finset.mem_of_mem_diff hx))
    · rw [Finset.sum_eq_add_sum_diff hi]; gcongr
      · exact s.le_max' (deck i) (by simp [s', h_im, h_le_m i hi])
      · exact Finset.sum_le_card_nsmul _ _ _ (fun x hx ↦ h_le_m x (Finset.mem_of_mem_diff hx))
  rw [hGM, hj, hk] at h_GM_le; field_simp at h_GM_le h_sum; linarith
