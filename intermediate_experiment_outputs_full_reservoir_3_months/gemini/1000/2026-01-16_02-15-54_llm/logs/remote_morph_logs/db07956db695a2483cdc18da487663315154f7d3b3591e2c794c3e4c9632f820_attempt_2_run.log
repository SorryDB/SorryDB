Released under Apache 2.0 license as described in the file LICENSE.
Authors: Joseph Myers
-/
import Mathlib


open scoped Finset

namespace IMO2020P5

/-- The answer to be determined. -/
def answer : Set ℕ := {n | 1 < n}

theorem result :
    {n : ℕ | 1 < n ∧ ∀ (deck : Fin n → ℕ), (∀ i, 0 < deck i) → (Pairwise fun j k ↦
      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  simp only [answer, Set.mem_setOf_eq, and_iff_right_iff_imp]
  intro n hn deck h_pos h_mean
  let v (k : ℕ) := ∀ i j, deck i ≡ deck j [MOD 2 ^ k]
  have h_same_parity (k : ℕ) : v k := by
    induction k with
    | zero => intros i j; simp
    | succ k ih =>
      intros i j
      have h_am_eq_gm j' k' : ∃ S, S.Nonempty ∧ (deck j' + deck k' : ℝ) / 2 = (∏ i' ∈ S, (deck i' : ℝ)) ^ (1 / (#S : ℝ)) := h_mean j' k'
      have h_v2 (x y : ℕ) (hx : 0 < x) (hy : 0 < y) : (x + y) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ)) → x ≡ y [MOD 2] := sorry
      sorry
  have h_all_equal i j : deck i = deck j := by
    apply Nat.eq_of_forall_mod_pow_two_eq
    intro k
    exact h_same_parity k i j
  exact h_all_equal
