import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := Nat.max 14 (N ^ 2 + 1)
  let A := (Nat.factorial M) ^ 2 + 1
  have hA : A > 1 := Nat.succ_lt_succ (Nat.pow_pos (Nat.factorial_pos M) 2)
  obtain ⟨p, hp, hpdvd⟩ := Nat.exists_prime_factor hA
  have hp_gt_M : p > M := by
    by_contra! hpm
    have hp_dvd_fact : p ∣ Nat.factorial M := Nat.dvd_factorial (Nat.prime_pos hp) hpm
    have hp_dvd_one : p ∣ 1 := by
      have h1 := Nat.dvd_pow hp_dvd_fact (Nat.le_refl 2)
      exact (Nat.dvd_add_right h1).mp hpdvd
    exact Nat.Prime.not_dvd_one hp hp_dvd_one
  have hp_odd : p % 2 = 1 := by
    by_contra! h_even
    have hp2 : p = 2 := (Nat.prime_dvd_prime hp Nat.prime_two).mp (Nat.dvd_of_mod_eq_zero h_even)
    rw [hp2] at hp_gt_M
    exact (by norm_num : 2 > 14).mp (hp_gt_M.trans_le (Nat.le_max_left 14 (N ^ 2 + 1)))
  obtain ⟨n, hn_lt, hnp⟩ := Nat.sq_mod_p_inv hp hpdvd
  let m := p - 2 * n
  have hm_pos : m > 0 := by
    have : 2 * n < p := hn_lt
    exact Nat.sub_pos_of_lt this
  have hm_odd : m % 2 = 1 := by
    rw [Nat.sub_mod, hp_odd]
    simp only [Nat.mul_mod_right, Nat.zero_mod, Nat.sub_zero, Nat.one_mod]
  have hm_sq_mod : (m ^ 2 + 4) % p = 0 := by
    have : m ^ 2 ≡ (p - 2 * n) ^ 2 [MOD p] := rfl
    have : (p - 2 * n) ^ 2 ≡ (2 * n) ^ 2 [MOD p] := Nat.ModEq.pow 2 (Nat.modEq_sub hn_lt.le)
    have : (2 * n) ^ 2 = 4 * n ^ 2 := by ring
    have h_n2 : n ^ 2 ≡ p - 1 [MOD p] := Nat.modEq_sub_p hp hnp
    have : 4 * n ^ 2 ≡ 4 * (p - 1) [MOD p] := Nat.ModEq.mul_left 4 h_n2
    have : 4 * (p - 1) ≡ p - 4 [MOD p] := by
      if hp4 : p < 4 then
        have : p = 3 := by
          have : p ≥ 15 := hp_gt_M.trans_le (Nat.le_max_left 14 (N ^ 2 + 1))
          linarith
        linarith
      else
        have : 4 * (p - 1) = 4 * p - 4 := by ring
        rw [this]
        exact Nat.ModEq.add_left_cancel (a := 4) (by rw [Nat.sub_add_cancel (by linarith)]; exact Nat.modEq_zero.mpr (Nat.dvd_mul_left p 4))
    have h_m2 : m ^ 2 ≡ p - 4 [MOD p] := this.trans (by exact this)
    rw [Nat.modEq_zero, Nat.add_mod, Nat.modEq_zero.mp h_m2]
    exact (Nat.sub_add_cancel (Nat.Prime.ge_two hp).trans (hp_gt_M.trans_le (Nat.le_max_left 14 (N ^ 2 + 1)))).symm
  have hm_ge_p : m ^ 2 + 4 ≥ p := Nat.le_of_dvd (Nat.add_pos (Nat.pow_pos hm_pos 2) (by norm_num)) (Nat.modEq_zero.mp hm_sq_mod)
  have hm_ge_5 : m ≥ 5 := by
    by_contra! hm_lt_5
    interval_cases m
    case ih1 => rw [ih1] at hm_sq_mod; norm_num at hm_sq_mod; exact (Nat.Prime.not_dvd_one hp) (Nat.modEq_zero.mp hm_sq_mod)
    case ih3 => rw [ih3] at hm_sq_mod; norm_num at hm_sq_mod; have hp13 := Nat.prime_dvd_prime hp (by norm_num) (Nat.modEq_zero.mp hm_sq_mod); rw [hp13] at hp_gt_M; linarith [hp_gt_M.trans_le (Nat.le_max_left 14 (N ^ 2 + 1))]
    case ih2 => linarith [hm_odd]
    case ih4 => linarith [hm_odd]
  use n
  constructor
  · have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos (n ^ 2)) hnp
    have : n ^ 2 + 1 > N ^ 2 + 1 := this.trans_gt (hp_gt_M.trans_le (Nat.le_max_right 14 (N ^ 2 + 1)))
    exact Nat.le_of_pow_le_pow_left (by norm_num) (Nat.le_of_lt (Nat.lt_of_add_lt_add_right this))
  · use p
    refine ⟨hp, hnp, ?_⟩
    have : (m : ℝ) ^ 2 ≥ p - 4 := by
      rw [← Nat.cast_pow, ← Nat.cast_four]
      exact Nat.mono_cast (Nat.le_sub_of_add_le hm_ge_p)
    have : (m : ℝ) ^ 2 > p - m := by
      calc (m : ℝ) ^ 2 ≥ (p : ℝ) - 4
           _ > (p : ℝ) - m := by linarith
    have : (m : ℝ) > Real.sqrt (p - m) := (Real.lt_sqrt (Nat.cast_nonneg m) (by linarith)).mpr this
    rw [show (m : ℝ) = p - 2 * n by norm_cast, show p - m = 2 * n by linarith] at this
    linarith
