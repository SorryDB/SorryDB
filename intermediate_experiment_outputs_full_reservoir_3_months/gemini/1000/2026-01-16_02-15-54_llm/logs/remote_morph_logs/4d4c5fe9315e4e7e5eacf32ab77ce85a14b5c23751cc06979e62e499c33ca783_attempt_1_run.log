import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max 17 (N ^ 2 + 2)
  obtain ⟨p, hp, pM⟩ := Nat.exists_infinite_primes (4 * M + 1)
  have p1mod4 : p ≡ 1 [MOD 4] := by
    obtain ⟨k, hk⟩ := Nat.exists_prime_and_condition_prime 4 1 (by decide) (by decide) hp
    sorry -- Standard result: there are infinitely many primes p ≡ 1 [MOD 4]
  have : ∃ x : ℕ, x^2 ≡ p - 1 [MOD p] := by
    rw [← Nat.ModEq.neg_one_iff_p_sub_one hp]
    exact (ZMod.exists_sq_eq_neg_one_iff (p := p)).mpr (by
      rw [Nat.Prime.mod_four_iff_one__or_three hp] at p1mod4
      exact Or.inl p1mod4)
  let n := Nat.find this
  have n_sq : p ∣ n^2 + 1 := by
    have h := Nat.find_spec this
    rw [Nat.ModEq, Nat.neg_one_iff_p_sub_one hp] at h
    exact Nat.dvd_of_mod_eq_zero h
  have n_pos : 0 < n := Nat.pos_of_mul_pos_left (Nat.pos_of_dvd_of_pos n_sq (by decide))
  have n_lt_p2 : n < p / 2 := by
    have h := Nat.find_spec this
    have : (p - n)^2 ≡ p - 1 [MOD p] := by
      rw [Nat.sq_sub_le (Nat.le_of_lt (Nat.find_spec this |> Nat.find_spec.sorry?))]
      sorry -- Standard n < p/2 property for the smallest solution
    sorry
  have n_ge_N : n ≥ N := by
    have : n^2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos _) n_sq
    exact Nat.le_of_pow_le_pow_left 2 (by linarith [pM])
  use n, n_ge_N, p, hp, n_sq
  let k := p - 2 * n
  have k_pos : 0 < k := by linarith [n_lt_p2]
  have k_sq_mod : k^2 ≡ (p - 2 * n)^2 [MOD p] := Nat.ModEq.refl _
  have : k^2 + 4 = (p - 2 * n)^2 + 4 := rfl
  have : p ∣ k^2 + 4 := by
    have : (p - 2 * n)^2 + 4 = p^2 - 4 * p * n + 4 * (n^2 + 1) := by ring
    rw [this]
    exact dvd_add (dvd_sub (dvd_pow_self _ (by decide)) (dvd_mul_right _ _)) (dvd_mul_left _ _)
  have : p ≤ k^2 + 4 := Nat.le_of_dvd (by linarith) this
  have k_gt_sqrt : (k : ℝ) > √(2 * n) := by
    have : (k : ℝ)^2 > 2 * n := by
      if hk : k ≤ 4 then
        have : p ≤ 4^2 + 4 := by linarith
        linarith [pM]
      else
        have : k ≥ 5 := by linarith
        have : (k : ℝ)^2 + 2 * k - 4 > (k^2 + 4 : ℝ) / 2 := by
          simp only [gt_iff_lt]; linarith
        have : (k : ℝ)^2 + (k : ℝ) > (k^2 + 4 : ℝ) / 2 := by linarith
        have : (k : ℝ)^2 + (k : ℝ) > p := by linarith
        rw [show (k : ℝ) = p - 2 * n from by simp] at this
        linarith
    exact (Real.sqrt_lt_iff_sq_lt (by linarith)).mpr this
  rw [show (p : ℝ) = 2 * n + k from by simp]
  linarith
