import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  obtain ⟨p, hN, hp, hmod⟩ := Nat.exists_prime_ge_modeq_one (max 30 (N ^ 2 + 1)) 4 (by norm_num)
  have : ∃ x : ZMod p, x ^ 2 = -1 := (ZMod.exists_sq_eq_neg_one_iff_exp p).mpr (by simp [hp]; exact (Nat.modeq_iff_dvd' (by norm_num)).mp hmod)
  obtain ⟨x, hx⟩ := this
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have h_n_le : n ≤ p / 2 := by simp [n]; split_ifs <;> omega
  have h_p_dvd : p ∣ n ^ 2 + 1 := by
    apply (CharP.ZMod.cast_eq_zero_iff p p _).mp
    simp [n]; split_ifs <;> { ring_nf; rw [hx]; simp }
  have h_n_ge : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (by positivity) h_p_dvd
    have : p > N ^ 2 + 1 := by linarith [hN]
    nlinarith
  refine ⟨n, h_n_ge, p, hp, h_p_dvd, ?_⟩
  let k := p - 2 * n
  have h_p_dvd_k : p ∣ k ^ 2 + 4 := by
    have : (2 * n : ℤ) ≡ (p - k : ℤ) [ZMOD p] := by simp [k]; omega
    have h4 : (p : ℤ) ∣ 4 * (n ^ 2 + 1) := Int.coe_nat_dvd.mpr (dvd_mul_of_dvd_right h_p_dvd 4)
    have : (4 * (n ^ 2 + 1) : ℤ) ≡ (k ^ 2 + 4 : ℤ) [ZMOD p] := by
      apply Int.ModEq.add (by ring_nf; apply Int.ModEq.pow 2 (by simp [k]; omega)) (Int.ModEq.refl 4)
    exact Int.coe_nat_dvd.mp (Int.modEq_zero_iff_dvd.mp (this.symm.trans (Int.modEq_zero_iff_dvd.mpr h4)))
  have h_kp : k ^ 2 + k > p := by
    obtain ⟨L, hL⟩ := h_p_dvd_k
    have hL4 : L % 4 = 1 := by
      have : (L * p) % 4 = (k ^ 2 + 4) % 4 := by rw [hL]
      have : p % 4 = 1 := (Nat.modeq_iff_dvd' (by norm_num)).mp hmod
      have : k % 2 = 1 := by
        have : p % 2 = 1 := hp.mod_two_eq_one_if_gt (by linarith)
        omega
      have : k ^ 2 % 4 = 1 := Nat.Odd.pow_two_mod_four (by omega)
      rw [this] at this; omega
    if hL1 : L = 1 then
      rw [hL1, one_mul] at hL; have : k ≥ 5 := by have : k % 2 = 1 := by omega; linarith [hL, hN]
      omega
    else
      have : L ≥ 5 := by omega
      nlinarith
  have : (k : ℝ) > √(2 * n) := (Real.lt_sqrt (by positivity)).mpr (by
    rw [← Nat.cast_pow, ← Nat.cast_mul]; exact Nat.cast_lt.mpr (by omega))
  calc (p : ℝ) = 2 * n + k := by push_cast; omega
    _ > 2 * n + √(2 * n) := by linarith
