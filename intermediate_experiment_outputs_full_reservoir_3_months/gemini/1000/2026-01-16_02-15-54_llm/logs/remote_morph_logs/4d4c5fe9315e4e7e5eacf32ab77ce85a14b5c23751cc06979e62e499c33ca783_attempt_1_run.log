    have : n₀ % p < p := Nat.mod_lt _ hp_prime.pos
    rw [Nat.mul_two]
    exact Nat.min_le_iff.mpr (Or.inr (Nat.sub_le_self _ _)))
  have hn_pos : n > 0 := by
    refine Nat.pos_of_ne_zero fun h => ?_
    subst h; simp at hn_div; exact hp_prime.not_dvd_one hn_div
  have hn_ge_N : n ≥ N := by
    have : p ≤ n ^ 2 + 1 := Nat.le_of_dvd (Nat.add_pos_left (Nat.pow_pos hn_pos) 1) hn_div
    by_contra! h
