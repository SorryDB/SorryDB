import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := N ^ 2 + N + 21
  obtain ⟨p, hp, p_gt_M, hp4⟩ := Nat.Prime.infinite_occurrence_mod 4 1 (by decide) M
  obtain ⟨x, hx⟩ := (ZMod.exists_sq_eq_neg_one_iff (p := p) hp).mpr (by simp [hp4])
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have h_p_dvd : p ∣ n ^ 2 + 1 := by
    apply (ZMod.Nat.zmod_eq_zero_iff_dvd p _).mp
    rcases (em (x.val ≤ p / 2)) with h | h <;> simp [n, h, hx]
    · have : (n : ZMod p) = -x := by simp [n, h]
      rw [this, neg_sq, hx]; simp
  use n
  constructor
  · have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (by omega) h_p_dvd
    nlinarith
  use p, hp, h_p_dvd
  have h_p_le : (p : ℝ) ≤ ((p : ℝ) - 2 * n) ^ 2 + 4 := by
    have : (p : ℤ) ∣ (p - 2 * (n : ℕ) : ℤ) ^ 2 + 4 := by
      use (p : ℤ) - 4 * n + 4 * ((n ^ 2 + 1) / p : ℕ)
      zify [Nat.div_mul_cancel h_p_dvd]; ring
    have h_pos : (0 : ℤ) < (p - 2 * (n : ℕ) : ℤ) ^ 2 + 4 := by nlinarith
    have := Int.le_of_dvd h_pos this
    norm_cast
  have h_delta : (p : ℝ) - 2 * n ≥ √(p - 4) := by
    rw [Real.le_sqrt (by omega) (by linarith), ← sq_abs (p - 2 * n)]; simp; linarith
  have : √(p - 4) > √(2 * n) := by
    rw [Real.sqrt_gt_sqrt_iff]
    · apply lt_of_lt_of_le (by apply Real.sqrt_lt_self; linarith)
      have : n ≤ p / 2 := by split_ifs <;> (have := x.val_lt; omega)
      norm_cast; linarith
    · have : n ≠ 0 := by intro h; subst h; simp at h_p_dvd; exact Nat.Prime.not_dvd_one hp h_p_dvd
      omega
  linarith
