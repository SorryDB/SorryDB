```lean
import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  obtain ⟨p, hp⟩ := Nat.exists_infinite_primes_congruent_mod 4 1 (max N 100 ^ 2)
  obtain ⟨x, y, hxy⟩ := Nat.Prime.sq_add_sq hp.2.1 hp.2.2
  let n := if x > y then (if y = 1 then x else (p + x) / y) else (if x = 1 then y else (p + y) / x)
  use n
  sorry
```

