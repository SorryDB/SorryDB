  obtain ⟨x, hx⟩ := (ZMod.exists_sq_eq_neg_one_iff (p := p)).mpr (by simp [hp_mod])
  let n' := x.val
  let n := if n' ≤ p / 2 then n' else p - n'
  have h_n_sq : (n : ZMod p) ^ 2 = -1 := by dsimp [n]; split_ifs <;> (simp [hx])
  have h_p_div : p ∣ n ^ 2 + 1 := by
    rw [← ZMod.nat_coe_zmod_eq_zero_iff_dvd, Nat.cast_add, Nat.cast_pow, h_n_sq]; simp
  have h_n_ge_N : n ≥ N := by
    have h_p_le_n_sq : p ≤ n ^ 2 + 1 := Nat.le_of_dvd (by omega) h_p_div
    exact (pow_lt_pow_left_iff (by omega)).mp (by omega [hp_gt])
  use n, h_n_ge_N, p, hp_prime, h_p_div
  have h_n_lt_p2 : 2 * n < p := by
    have h_n_le' : 2 * n ≤ p := by dsimp [n]; split_ifs <;> omega
    have h_n_neq_p2 : 2 * n ≠ p := by
      intro h_eq
      have : (2 * n : ZMod p) = 0 := by rw [h_eq]; exact ZMod.nat_cast_self p
      have : (n : ZMod p) ^ 2 = -1 := h_n_sq
      have h_p2 : (2 : ZMod p) ≠ 0 := by intro h_eq2; have := (ZMod.nat_coe_zmod_eq_zero_iff_dvd 2 p).mp h_eq2; omega
      have : (n : ZMod p) = 0 := by rw [← @mul_left_cancel_iff _ _ _ (2 : ZMod p) _ _ h_p2]; simp [this]
      simp [this] at h_n_sq
    omega
  let k := p - 2 * n
  have hp_k : p = 2 * n + k := by omega
  have h_k_sq : p ∣ k ^ 2 + 4 := by
    have : (4 * (n ^ 2 + 1) : ℤ) = (2 * n : ℤ) ^ 2 + 4 := by ring
    have : (2 * n : ℤ) ≡ -k [ZMOD p] := by rw [hp_k]; simp [Int.mod_eq_zero]
    have h_mod : (4 * (n ^ 2 + 1) : ℤ) ≡ k ^ 2 + 4 [ZMOD p] := by rw [this]; gcongr; ring
    apply Int.coe_nat_dvd.mp; rw [Int.mod_eq_zero] at h_mod; rw [← h_mod]; exact Int.coe_nat_dvd.mpr (dvd_mul_of_dvd_right h_p_div 4)
  obtain ⟨m, hm⟩ := h_k_sq
  have h_m_mod : m % 4 = 1 := by
    have : (m * p) % 4 = (k ^ 2 + 4) % 4 := by rw [hm]
    have : (k ^ 2 + 4) % 4 = 1 := by
      have : k % 2 = 1 := by have := hp_prime.mod_two_eq_one_iff_ne_two.mpr (by omega); omega
      have : k % 4 = 1 ∨ k % 4 = 3 := by omega
      rcases this with h | h <;> { rw [Nat.add_mod, Nat.pow_mod, h]; norm_num }
    omega [hp_mod]
  have h_k_gt_sqrt : (k : ℝ) ^ 2 > 2 * n := by
    have h_mk : (m : ℝ) * ((k : ℝ) ^ 2 + k) > (m : ℝ) * p := by
      rw [← hm]; norm_cast
      if h_m1 : m = 1 then
        simp [h_m1] at hm ⊢; have : k ^ 2 > 9 := by omega [hp_gt]
        have : k ≥ 5 := by omega
        omega
      else
        have h_m5 : m ≥ 5 := by omega
        have : (k : ℝ) ≥ 1 := by omega
