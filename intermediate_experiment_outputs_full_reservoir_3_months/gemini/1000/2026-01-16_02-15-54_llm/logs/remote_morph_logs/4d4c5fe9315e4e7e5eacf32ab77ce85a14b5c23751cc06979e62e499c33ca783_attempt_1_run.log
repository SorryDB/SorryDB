```lean
import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := {p | Nat.Prime p ∧ p % 4 = 1}
  have h_inf : S.Infinite := Nat.Prime.infinite_setOf_prime_mod_four_eq_one
  let f (p : ℕ) : ℕ := (Nat.sq_mod_inv p).min (p - (Nat.sq_mod_inv p).min)
  have hf (p : ℕ) (hp : p ∈ S) : f p < p / 2 := by
    have h1 : p % 4 = 1 := hp.2
    have h_ne_2 : p ≠ 2 := by intro h; rw [h] at h1; norm_num at h1
    have h_sq : (Nat.sq_mod_inv p).min ^ 2 % p = p - 1 % p := Nat.sq_mod_inv_spec hp.1 (by rw [h1]; norm_num)
    have h_lt : (Nat.sq_mod_inv p).min < p := (Nat.sq_mod_inv p).min_lt hp.1
    have h_nz : (Nat.sq_mod_inv p).min ≠ 0 := by intro h; rw [h] at h_sq; norm_num at h_sq; exact h_ne_2 (by omega)
    have h_ne_half : (Nat.sq_mod_inv p).min * 2 ≠ p := by intro h; have := hp.1.eq_two_or_odd; omega
    unfold f; apply Nat.min_lt_of_ne_left; omega
  have h_p_mid (p : ℕ) (hp : p ∈ S) : p ∣ (f p) ^ 2 + 1 := by
    have h1 : p % 4 = 1 := hp.2
    have h_sq : (Nat.sq_mod_inv p).min ^ 2 % p = p - 1 % p := Nat.sq_mod_inv_spec hp.1 (by rw [h1]; norm_num)
    unfold f; split_ifs
    · apply Nat.dvd_of_mod_eq_zero; rw [Nat.add_mod, h_sq]; norm_num; apply Nat.mod_self
    · apply Nat.dvd_of_mod_eq_zero; rw [Nat.add_mod, Nat.pow_two, Nat.mul_mod]; set a := (Nat.sq_mod_inv p).min
      have : (p - a) * (p - a) % p = a * a % p := by
        rw [Nat.sub_mul_mod, Nat.mul_sub_mod, Nat.mul_mod_self, Nat.mul_mod_self, Nat.zero_sub_mod, Nat.zero_sub_mod]
      rw [this, ← Nat.pow_two, h_sq]; norm_num; apply Nat.mod_self
  have h_range_inf : {f p | p ∈ S}.Infinite := by
    contrapose! h_inf
    refine h_inf.mono (λ p hp => ?_)
    exact ⟨f p, ⟨hp, rfL⟩⟩
  obtain ⟨n, hn_range, hnN⟩ := h_range_inf.exists_gt N
  obtain ⟨p, hp, rfl⟩ := hn_range
  use n, hnN, p, hp.1, h_p_mid p hp
  let x := Nat.sqrt (p - 1); let y := 1
  have p_ge_5 : p ≥ 5 := by have := hp.2; have := hp.1.five_le_of_mod_four_eq_one; omega
  have p_float : (p : ℝ) > 2 * n + √(2 * n) := by
    have h_sq_p : ∃ x y : ℕ, x > 0 ∧ y > 0 ∧ p = x ^ 2 + y ^ 2 := Nat.Prime.sq_add_sq hp.1 hp.2
    obtain ⟨x, y, hx, hy, hxy⟩ := h_sq_p
    let x' := Nat.max x y; let y' := Nat.min x y
    have hx'y' : x' > y' ∧ y' > 0 ∧ p = x' ^ 2 + y' ^ 2 := by
      have : x ≠ y := by intro h; rw [h, ← Nat.mul_two] at hxy; exact hp.1.eq_two_or_odd.elim (λ h2 => by omega) (λ hodd => by omega)
      unfold x' y'; omega
    obtain ⟨x, y, hx, hy, hxy⟩ := ⟨x', y', hx'y'.1, hx'y'.2.1, hx'y'.2.2⟩
    have n_val : n * y = x ∨ n * y = p - x ∨ (n * y ≥ p + x) := by
      have : (n * y) ^ 2 % p = x ^ 2 % p := by
        rw [Nat.pow_two, Nat.mul_mod, ← Nat.pow_two, ← Nat.pow_two, ← Nat.sub_eq_of_add_eq hxy]
        have : (p - y ^ 2) % p = (n ^ 2 * y ^ 2) % p := by
          have : p ∣ (n ^ 2 + 1) * y ^ 2 := Nat.dvd_mul_of_dvd_left (h_p_mid p hp) (y ^ 2)
          rw [Nat.add_mul, Nat.one_mul] at this
          apply Nat.mod_eq_of_dvd; rw [← Nat.mod_eq_zero_iff_dvd]; rw [Nat.add_mod] at this; omega
        rw [← this, Nat.sub_mod_self, Nat.mod_self]; rfl
      have : p ∣ (n * y - x) * (n * y + x) := by
        rw [Nat.mul_add_sub_mul, ← Nat.pow_two, ← Nat.pow_two]; apply Nat.dvd_of_mod_eq_zero; omega
      apply hp.1.dvd_or_dvd at this; cases this <;> omega
    have n_le : n ≤ (p - x) / y := by
      have h1 : (n * y) ≠ x := by intro h; rw [h, ← Nat.mul_two] at hxy; omega
      have h2 : n < p / 2 := hf p hp; omega
    have h_case : (p : ℝ) > 2 * n + √(2 * n) := by
      have h_f : ∀ (p n : ℝ), p > 2 * n + √(2 * n) ↔ (p - 2 * n) ^ 2 > 2 * n := by
        intro p n; constructor <;> intro h <;> [have : p - 2 * n > 0 := by omega; rw [← Real.sqrt_lt_iff_lt_sq this]; exact h;
        have : p - 2 * n > Real.sqrt (2 * n) := by rwa [Real.lt_sqrt (by omega)]; omega]
      rw [h_f]; have hn_p : (n : ℝ) ≤ ((p : ℝ) - x) / y := by exact_mod_cast n_le
      have : (p - 2 * n) ≥ (p - 2 * (p - x) / y) := by exact_mod_cast (by omega)
      if hy1 : y = 1 then
        subst hy1; have : p = x ^ 2 + 1 := by omega; have : n = x := by omega
        subst this; simp; ring_nf; cases x with | zero => omega | succ x => cases x <;> norm_num; omega
      else if hy2 : y = 2 then
        subst hy2; have : p = x ^ 2 + 4 := by omega; have : n = (p - x) / 2 := by omega
        subst this; have : (p - 2 * n : ℝ) = x := by omega
        rw [this]; have : (2 * n : ℝ) = p - x := by omega
        rw [this, hxy]; simp; omega
      else
        have : (p - 2 * n : ℝ) ≥ (p : ℝ) / y := by field_simp; omega
        have : ((p : ℝ) / y) ^ 2 > 2 * (p / y) := by field_simp; rw [hxy]; nlinarith
        nlinarith
    exact h_case
  exact p_float
