import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := {p | Nat.Prime p ∧ p ≡ 1 [MOD 4]}
  have h_inf : S.Infinite := Nat.Infinite.setOf_prime_mod_4_eq_1
  let f (p : ℕ) : ℕ := (Nat.sqrt (p - 1))
  have h_p_bound : ∀ p ∈ S, p > 13 → ∃ n < p / 2, p ∣ n^2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
    intro p hp hp13
    obtain ⟨n, hn_bound, hn_sq⟩ := Nat.sq_mod_p_inv_one hp.1 (by
      obtain ⟨k, hk⟩ := hp.2
      rw [hk]
      decide)
    use n, hn_bound
    constructor
    · exact hn_sq
    · set d := p - 2 * n
      have h_d_odd : d % 2 = 1 := by
        have : p % 2 = 1 := Nat.Prime.mod_two_eq_one hp.1 (by rintro rfl; exact hp.2 (by decide))
        rw [← Nat.mod_add_mod, Nat.mul_mod_right, Nat.add_zero] at this
        have h_p_eq : p = 2 * n + d := (Nat.add_sub_cancel' (Nat.le_of_lt (Nat.mul_lt_mul_of_pos_left hn_bound (by decide)))).symm
        rw [h_p_eq] at this
        exact this
      have h_M : (d^2 + 4) % p = 0 := by
        have : (2 * n)^2 ≡ (-d)^2 [MOD p] := by
          apply Nat.ModEq.pow
          rw [Nat.ModEq, Nat.sub_mod (Nat.le_of_lt hn_bound), Nat.mul_mod_right]
          have h_p_eq : p = 2 * n + d := (Nat.add_sub_cancel' (Nat.le_of_lt (Nat.mul_lt_mul_of_pos_left hn_bound (by decide)))).symm
          rw [h_p_eq, Nat.add_mod, Nat.mul_mod_right, Nat.zero_add]
        have h_4n2 : 4 * (n^2 + 1) = (2 * n)^2 + 4 := by ring
        have : (2 * n)^2 + 4 ≡ d^2 + 4 [MOD p] := Nat.ModEq.add this (Nat.ModEq.refl 4)
        rw [Nat.ModEq, ← h_4n2, Nat.mul_mod, hn_sq, Nat.zero_mul, Nat.zero_mod] at this
        exact this.symm
      let M := (d^2 + 4) / p
      have h_M_pos : M > 0 := Nat.div_pos (Nat.succ_le_of_lt (Nat.add_pos_left (Nat.pos_pow_of_pos 2 (Nat.pos_of_odd h_d_odd)) 4)) (Nat.Prime.pos hp.1)
      have h_M_val : M * p = d^2 + 4 := Nat.mul_div_cancel' h_M
      if hM1 : M = 1 then
        have h_p_d : p = d^2 + 4 := by rwa [hM1, Nat.one_mul] at h_M_val
        have : d > 4 := by
          by_contra' hle; revert hp13; rw [h_p_d]
          have : d ∈ ({1, 3} : Set ℕ) := by
            have : d < 5 := hle
            interval_cases d <;> norm_num at h_d_odd
            · exact Set.mem_insert 1 {3}
            · exact Set.mem_insert_of_mem 1 (Set.mem_singleton 3)
          rcases this with rfl | rfl <;> norm_num
        rw [h_p_d, Nat.add_comm, Nat.add_sub_assoc (by decide), Nat.add_comm]
        have : d^2 + d > d^2 + 4 := Nat.add_lt_add_left this (d^2)
        have : (d : ℝ) > √(2 * n) := by
          rw [Real.sqrt_lt (by exact Nat.cast_nonneg (2 * n)), ← Nat.cast_mul, ← Nat.cast_pow, Nat.cast_lt]
          have h_2n : 2 * n = p - d := (Nat.sub_eq_of_add_eq (Nat.add_sub_cancel' (Nat.le_of_lt (Nat.mul_lt_mul_of_pos_left hn_bound (by decide)))).symm).symm
          rw [h_2n, h_p_d, Nat.add_sub_cancel_left]
          exact this
        rw [Nat.cast_add, Nat.cast_mul, h_p_d, Nat.cast_add, Nat.cast_pow]
        linarith
      else
        have hM2 : M ≥ 2 := Nat.succ_le_of_lt (Nat.lt_of_le_of_ne h_M_pos (Ne.symm hM1))
        have h_d2 : d^2 + 4 ≥ 2 * p := by rw [← h_M_val]; exact Nat.mul_le_mul_right p hM2
        have h_d_ge_sqrt : (d : ℝ) > √(2 * n) := by
          apply Real.sqrt_lt_sep
          rw [← Nat.cast_mul, ← Nat.cast_pow, Nat.cast_lt]
          have h_2n : 2 * n < p := by linarith [hn_bound]
          linarith [h_d2, h_2n]
        have h_p_val : (p : ℝ) = 2 * n + d := by rw [← Nat.cast_add, Nat.add_sub_cancel' (Nat.le_of_lt (Nat.mul_lt_mul_of_pos_left hn_bound (by decide)))]
        rw [h_p_val, Nat.cast_mul]
        linarith
  obtain ⟨p, hpS, hp_large⟩ := h_inf.exists_gt (Nat.max 13 (2 * N^2 + 2 * N + 1))
  obtain ⟨n, _, p_div, h_cond⟩ := h_p_bound p hpS (by linarith)
  have n_ge_N : n ≥ N := by
    by_contra' hnN
    have : n^2 + 1 < N^2 + 1 := Nat.add_lt_add_right (Nat.pow_lt_pow_left hnN (by decide) (by decide)) 1
    have p_le : p ≤ n^2 + 1 := Nat.le_of_dvd (Nat.add_pos_left (Nat.pow_pos (Nat.zero_le n)) 1) p_div
    linarith
  exact ⟨n, n_ge_N, p, hpS.1, p_div, h_cond⟩

