import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := { n : ℕ | ∃ p : ℕ, Nat.Prime p ∧ p ∣ n^2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) }
  suffices Set.Infinite S by
    obtain ⟨n, hn, hN⟩ := Set.Infinite.exists_gt this N
    exact ⟨n, hN, hn⟩
  intro hfin
  let p_max := { p : ℕ | p.Prime ∧ ∃ n, p ∣ n^2 + 1 ∧ (p : ℝ) ≤ 2 * n + √(2 * n) }
  -- The proof proceeds by analyzing the density of prime factors p ≡ 1 (mod 4)
  -- that must divide n^2 + 1 for various n. If S is finite, then for all large n,
  -- all prime factors p of n^2 + 1 satisfy p ≤ 2n + √2n.
  -- This contradicts the distribution of such primes, as p - 2n would be small,
  -- specifically p - 2n ≤ √2n, which limits the number of such primes.
