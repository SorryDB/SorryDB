import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  have h_inf : {p | Nat.Prime p ∧ p % 4 = 1}.Infinite := Nat.Prime.infinite_congr_one 4 1
  obtain ⟨p, ⟨hp, hp4⟩, hp_gt⟩ := h_inf.exists_gt (max 20 (N ^ 2 + 1))
  obtain ⟨n, hn_lt, hn_sq⟩ := hp.exists_sq_eq_neg_one_mod_of_one_mod_four hp4
  have h_div : p ∣ n ^ 2 + 1 := by
    obtain ⟨k, hk⟩ := hn_sq
    use k; rw [← hk, Nat.add_comm]; rfl
  have hn_large : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos _) h_div
    have : n ^ 2 + 1 > N ^ 2 + 1 := by linarith
    exact Nat.lt_of_pow_lt_pow 2 (by decide) this
  use n, hn_large, p, hp, h_div
  let k := p - 2 * n
  have hk_sq : p ∣ k ^ 2 + 4 := by
    have h_rew : k ^ 2 + 4 = p ^ 2 - 4 * p * n + 4 * (n ^ 2 + 1) := by
      rw [Nat.sub_sq hn_lt.le]; ring
    rw [h_rew]
    exact Nat.dvd_add (Nat.dvd_sub (Nat.dvd_pow_self _ (by decide)) (by apply Nat.dvd_mul_right)) (Nat.dvd_mul_of_dvd_right h_div 4)
  have hk_ge : (k : ℝ) ≥ Real.sqrt (p - 4) := by
    have : k ^ 2 + 4 ≥ p := Nat.le_of_dvd (Nat.add_pos_left (by decide) _) hk_sq
    have : (k : ℝ) ^ 2 ≥ (p : ℝ) - 4 := by rw [← Real.sqrt_sq (by linarith)]; nlinarith
    exact (Real.le_sqrt (by linarith) (by linarith)).mpr this
  have hk_gt_4 : (k : ℝ) > 4 := by
    apply Real.lt_of_lt_of_le (Real.sqrt_lt_sqrt (by linarith) (by linarith)) hk_ge
  have h_p_gt : (p : ℝ) > 2 * n + Real.sqrt (2 * n) := by
    have : (p : ℝ) - 2 * n = k := by rw [Nat.cast_sub hn_lt.le]
    rw [← this, Real.lt_sub_iff_add_last]
    apply lt_of_lt_of_le (Real.sqrt_lt_sqrt (by linarith) (by linarith)) hk_ge
    rw [Real.le_sqrt (by linarith) (by linarith)]
    calc (p : ℝ) - 4 > (p : ℝ) - k := by linarith
      _ = 2 * n := by linarith
  exact h_p_gt

