import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let s : Set ℕ := {n | ∃ p, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n)}
  apply Set.Infinite.of_not_bddAbove
  intro ⟨M, hM⟩
  let K := (Nat.factorial (M + N + 100))
  let s_primes : Set ℕ := {p | Nat.Prime p ∧ p % 4 = 1 ∧ p > 2 * (M + N + 100) ^ 2}
  have h_inf_primes : s_primes.Infinite := by
    apply Set.Infinite.of_not_bddAbove
    intro ⟨B, _⟩
    let L := Nat.factorial (max B (M + N + 100))
    obtain ⟨p, hp, hpd⟩ := Nat.exists_prime_factor (Nat.ne_of_gt (show L^2 + 1 > 1 by nlinarith))
    have h_p_gt : p > max B (M + N + 100) := by
      by_contra! hpm
      have h1 : p ∣ L ^ 2 := Nat.dvd_pow (Nat.dvd_factorial (Nat.Prime.pos hp) hpm) (by Nat.norm_num)
      have h2 : p ∣ 1 := (Nat.dvd_add_iff_right h1).mpr hpd
      exact Nat.Prime.not_dvd_one hp h2
    refine ⟨p, ⟨hp, ?_, by nlinarith⟩, by nlinarith⟩
    exact (Nat.Prime.mod_four_eq_one_iff_exists_sq_eq_neg_one hp).mpr ⟨L, by
      zify [hpd]; rw [← Int.mod_eq_zero_iff_dvd] at hpd; rw [Int.add_mod, Int.pow_mod] at hpd
      linear_combination hpd⟩
  obtain ⟨p, ⟨hp, h_p4, h_pgt⟩, h_p_large⟩ := h_inf_primes.exists_gt 1000
  obtain ⟨x, hx⟩ := (Nat.Prime.mod_four_eq_one_iff_exists_sq_eq_neg_one hp).mp h_p4
  let n0 := x % p
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have h_n_le : n ≤ p / 2 := by dsimp [n]; split <;> omega
  have h_p_div : p ∣ n^2 + 1 := by
    dsimp [n]; split
    · exact (Nat.dvd_add_iff_left (Nat.dvd_pow_self _ (by Nat.norm_num))).mpr (Nat.mod_dvd_mod hx)
    · have h_sq : (p - n0)^2 + 1 = p^2 - 2*p*n0 + n0^2 + 1 := by ring
      rw [h_sq]; refine Nat.dvd_add (Nat.dvd_sub (Nat.dvd_pow_self _ (by Nat.norm_num)) (by nlinarith)) ?_
      exact (Nat.dvd_add_iff_left (Nat.dvd_pow_self _ (by Nat.norm_num))).mpr (Nat.mod_dvd_mod hx)
  have h_p_bound : (p : ℝ) > 2 * n + √(2 * n) := by
    have : (n : ℝ) ≤ p / 2 := by exact_mod_cast h_n_le
    have h_p_sq : (p : ℝ)^2 - (4 * (n^2 + 1) / p + 2) * p + p^2 > 0 := by nlinarith
    let k := (n^2 + 1) / p
