import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max 14 (4 * N ^ 2 + 3)
  obtain ⟨p, hp_p, hp_M, hp_mod⟩ := Nat.exists_prime_ge_modeq_one M 1 (by decide)
  have : p ≠ 2 := Nat.Prime.ne_of_odd hp_p (hp_mod.symm ▸ (by decide))
  obtain ⟨n_val, hn_val⟩ := (ZMod.exists_sq_eq_neg_one_iff hp_p).mpr (Or.inr (hp_mod.symm ▸ (by decide)))
  let n₀ := n_val.val
  let n := if n₀ ≤ p / 2 then n₀ else p - n₀
  have hn_pos : n > 0 := by
    by_contra! h
    have : n = 0 := Nat.eq_zero_of_le_zero h
    have : p ∣ 1 := by
      subst this
      have hn_sq_mod : (n : ZMod p) ^ 2 = -1 := by
        split_ifs at hn_val <;> [exact hn_val; simp [← hn_val]]
      have : (0 : ZMod p) ^ 2 = -1 := by rwa [← this]
      exact (ZMod.zero_eq_neg_one_iff p).mp this.symm
    exact Nat.Prime.not_dvd_one hp_p this
  have hn_sq_mod : p ∣ n ^ 2 + 1 := by
    rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd, Nat.cast_add, Nat.cast_pow, Nat.cast_one]
    split_ifs at n <;> [exact hn_val.symm ▸ (by simp); simp [← hn_val]]
  have hn_le : 2 * n < p := by
    have h_ne : n₀ * 2 ≠ p := by
      intro h
      have : p ∣ n₀ ^ 2 + 1 := by rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd, Nat.cast_add, Nat.cast_pow, Nat.cast_one, hn_val]; simp
      have : n₀ * 2 = p := h
      have : p ∣ n₀ * 2 := by rw [this]
      have : p ∣ 2 := (Nat.Prime.dvd_mul hp_p).mp this |>.resolve_left (by exact Nat.Prime.dvd_at_most_one hp_p (by decide) this)
      exact (by linarith)
    split_ifs at n
    · exact Nat.lt_of_le_of_ne (Nat.le_of_mul_le_left (Nat.div_mul_le_self p 2) (by decide)) h_ne
    · have h_n : n = p - n₀ := rfl
      have : n₀ > p / 2 := by linarith
      have : 2 * n₀ > p := by linarith [Nat.div_add_mod p 2]
      linarith [Nat.div_add_mod p 2]
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos _) hn_sq_mod
    have : n ^ 2 + 1 > 4 * N ^ 2 + 2 := by linarith
    have : n ^ 2 > 4 * N ^ 2 := by linarith
    exact Nat.le_of_pow_le_pow_left 2 (by decide) (by linarith)
  refine ⟨n, hn_ge_N, p, hp_p, hn_sq_mod, ?_⟩
  let m := p - 2 * n
  have hm_odd : m % 2 = 1 := by
    have : p % 2 = 1 := Nat.Prime.mod_two_eq_one_of_ne_two hp_p this
    rw [Nat.sub_mod this, Nat.mul_mod, (by decide : 2 % 2 = 0)]
    simp
  have hp_dvd_m2 : p ∣ m ^ 2 + 4 := by
    have : (2 * n : ℤ) ≡ -m [ZMOD p] := by
      rw [show (2 * n : ℤ) = (p : ℤ) - m by linarith]
      exact Int.modEq_sub p m
    have : (2 * n : ℤ) ^ 2 + 4 = 4 * (n ^ 2 + 1) := by ring
    have : (4 * (n ^ 2 + 1) : ℤ) ≡ 0 [ZMOD p] := Int.modEq_zero_iff_dvd.mpr (by simp [hn_sq_mod])
    have : ((-m : ℤ) ^ 2 + 4) ≡ 0 [ZMOD p] := by rwa [← this] at hn_sq_mod; exact Int.ModEq.add (Int.ModEq.pow 2 this) (by simp)
    simp at this
    exact Int.modEq_zero_iff_dvd.mp this
  have hm_gt_4 : m > 4 := by
    by_contra! h
    have : m ∈ [1, 3] := by
      match m, hm_odd with | 1, _ => simp | 3, _ => simp
    rcases this with rfl | rfl
    · have : p ∣ 5 := by exact hp_dvd_m2
      linarith [Nat.le_of_dvd (by decide) this]
    · have : p ∣ 13 := by exact hp_dvd_m2
      linarith [Nat.le_of_dvd (by decide) this]
  have : m ^ 2 + m > p := by
    have : p ≤ m ^ 2 + 4 := Nat.le_of_dvd (by linarith) hp_dvd_m2
    linarith
  have : (m : ℝ) > Real.sqrt (2 * n) := by
    rw [Real.lt_sqrt (by linarith), ← Nat.cast_pow, ← Nat.cast_mul]
    norm_cast
    linarith
  linarith
