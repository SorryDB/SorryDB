import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := N ^ 2 + 14
  obtain ⟨p, hp, hpM, hp1⟩ := Nat.exists_prime_ge_modeq_one 4 1 M (by norm_num) (by norm_num)
  haveI : Fact p.Prime := ⟨hp⟩
  obtain ⟨x, hx⟩ := (ZMod.exists_sq_eq_neg_one_iff p).mpr (by have : p % 4 = 1 := hp1; omega)
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have h_pn2 : p ∣ n ^ 2 + 1 := by
    apply (ZMod.natCast_zmod_eq_zero_iff_dvd (n ^ 2 + 1) p).mp
    dsimp [n]; split_ifs <;> (simp [hx]; ring)
  have hnN : n ≥ N := by
    have := Nat.le_of_dvd (Nat.succ_pos _) h_pn2
    omega
  refine ⟨n, hnN, p, hp, h_pn2, ?_⟩
  let d := p - 2 * n
  have h_pd : p ∣ d ^ 2 + 4 := by
    apply (ZMod.natCast_zmod_eq_zero_iff_dvd (d ^ 2 + 4) p).mp
    have : (d : ZMod p) = -(2 * n) := by dsimp [d]; omega
    rw [this]; ring_nf
    have : (n ^ 2 + 1 : ZMod p) = 0 := by dsimp [n]; split_ifs <;> (simp [hx]; ring)
    rw [show (4 : ZMod p) * n ^ 2 + 4 = 4 * (n ^ 2 + 1) by ring, this]; simp
  have : d * d > 2 * n := by
    let k := (d ^ 2 + 4) / p
    have hk1 : k * p = d ^ 2 + 4 := Nat.div_mul_cancel h_pd
    have hk_mod : k % 4 = 1 := by
      have h1 : (k * p) % 4 = (d ^ 2 + 4) % 4 := by rw [hk1]
      have : p % 4 = 1 := hp1
      have : d % 2 = 1 := by omega
      have : d * d % 4 = 1 := by revert this; intro; omega
      revert h1 this; intro; omega
    obtain (rfl | hk5) : k = 1 ∨ k ≥ 5 := by omega
    · have : p = d * d + 4 := by omega
      omega
    · have : d * d + 4 ≥ 5 * (2 * n + d) := by omega
      omega
  rw [gt_iff_lt, add_comm, ← sub_lt_iff_lt_add]
  · rw [Real.sqrt_lt_iff_sq_lt] <;> (norm_cast; omega)
  · omega
