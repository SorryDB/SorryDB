/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S : Set ℕ := {p | Nat.Prime p ∧ ∃ n, p ∣ n ^ 2 + 1}
  have h_inf : S.Infinite := by
    apply Nat.Infinite.mono (fun p hp => ⟨hp.1, hp.2⟩)
    exact Nat.infinite_setOf_prime_div_sq_add_one
  have h_large : ∃ p ∈ S, p > (2 * N + 1) ^ 2 + 1 ∧ p > 13 := by
    obtain ⟨p, hpS, hp_gt⟩ := h_inf.exists_gt (max ((2 * N + 1) ^ 2 + 1) 13)
    exact ⟨p, hpS, (max_lt_iff.1 hp_gt)⟩
  obtain ⟨p, ⟨hp_prime, n₀, hp_div⟩, hp_gt_N, hp_gt_13⟩ := h_large
  let n := min (n₀ % p) (p - (n₀ % p))
  have hn_sq : n ^ 2 ≡ p - 1 [MOD p] := by
    have : n₀ % p < p := Nat.mod_lt _ hp_prime.pos
    cases' Nat.min_choice (n₀ % p) (p - (n₀ % p)) with h h
    · rw [h]; exact (Nat.ModEq.pow 2 (Nat.mod_mod n₀ p).symm).trans (Nat.ModEq.mod_p_sq_add_one hp_prime hp_div)
    · rw [h]; apply Nat.ModEq.pow; exact (Nat.mod_mod n₀ p).symm.trans (Nat.mod_eq_zero_of_dvd (by simp)).symm |>.trans (Nat.ModEq.sub_self _ _ |>.symm)
  have hn_div : p ∣ n ^ 2 + 1 := by
    rw [Nat.modEq_iff_dvd' (by simp [Nat.pow_two_pos (hp_prime.pos)])] at hn_sq
    exact hn_sq
