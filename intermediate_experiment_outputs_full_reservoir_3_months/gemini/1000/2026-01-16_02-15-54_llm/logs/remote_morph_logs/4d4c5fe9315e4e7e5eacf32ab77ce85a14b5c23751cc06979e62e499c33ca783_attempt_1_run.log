import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := {p | Nat.Prime p ∧ p ≡ 1 [MOD 4]}
  have hS : S.Infinite := Nat.Infinite.setOf_prime_modEq_one (by decide)
  let f (p : ℕ) : ℕ :=
    if h : p ∈ S then
      let ⟨x, y, hxy⟩ := (Nat.Prime.sq_add_sq h.1 h.2).1
      let x' := max x y
      let y' := min x y
      let n := (Nat.ChineseRemainder h.1 1 y' x' 1).2 % p
      if n < p / 2 then n else p - n
    else 0
  have h_inf : Set.Infinite (Set.range f) := by
    apply Set.Infinite.range_of_infinite hS
    intro p hp q hq hfq
    have : p ∣ (f p)^2 + 1 := sorry
    have : q ∣ (f q)^2 + 1 := sorry
    sorry
  obtain ⟨n, ⟨p, hp, rfl⟩, hnN⟩ := h_inf.exists_nat_ge N
  use n, hnN, p, hp.1
  sorry
