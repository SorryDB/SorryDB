      have : (p : ℤ) % 2 = 0 := by rw [← this]; norm_num
      have : p % 2 = 0 := by exact_mod_cast this
      linarith [hp.odd_of_ne_two (by linarith)]
    dsimp [n]
    have : (x.val : ℝ) < p := by exact_mod_cast x.val_lt
    have : (x.val : ℝ) ≤ p / 2 ∨ (p - x.val : ℝ) < p / 2 := by linarith
    rcases this with h | h
    · exact lt_of_le_of_ne h (by exact_mod_cast x_val_ne_half)
    · exact lt_min_iff.mp (by linarith) |>.2
  have p_dvd : p ∣ n ^ 2 + 1 := by
    have : ((n : ZMod p) ^ 2 + 1) = 0 := by
