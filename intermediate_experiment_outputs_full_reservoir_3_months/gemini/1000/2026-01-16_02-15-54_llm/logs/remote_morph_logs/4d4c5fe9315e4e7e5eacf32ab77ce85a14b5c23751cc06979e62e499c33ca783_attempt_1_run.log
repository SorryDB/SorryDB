import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := {p | Nat.Prime p ∧ p % 4 = 1}
  have hS : S.Infinite := Nat.infinite_setOf_prime_mod_eq_one 4 1
  obtain ⟨p, ⟨hp, hp4⟩, hpM⟩ := hS.exists_gt (max 20 (N ^ 2))
  obtain ⟨x, hx⟩ := Nat.Prime.exists_sq_eq_neg_one_mod hp4
  let x0 := x % p
  let n := if x0 ≤ p / 2 then x0 else p - x0
  have hn : n ^ 2 ≡ -1 [MOD p] := by
    dsimp [n]; split_ifs <;> (rw [Nat.ModEq, Nat.pow_two, Nat.mul_mod]; simp [hx])
    rw [Nat.sub_mod_sq hp.pos, hx]; simp
  have hn2 : p ∣ n ^ 2 + 1 := (Nat.modEq_zero_iff_dvd).mp (by
    rw [Nat.ModEq, Nat.add_mod, hn]; simp [Nat.mod_eq_of_lt hp.one_lt])
  have h2n : 2 * n < p := by
    dsimp [n]; split_ifs with h
    · have : x0 ≠ 0 := by
        intro hx0; simp [hx0] at hn; exact hp.not_dvd_one (Nat.modEq_zero_iff_dvd.mp hn)
      linarith [Nat.lt_of_le_and_ne (Nat.le_of_lt_succ (by rwa [Nat.le_div_iff_mul_le (by norm_num)] at h)) (by linarith)]
    · linarith [Nat.div_lt_self hp.pos (by norm_num)]
  have hN : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (by linarith) hn2
    exact Nat.le_of_pow_le_pow_left 2 (by norm_num) (by linarith)
  use n, hN, p, hp, hn2
  let k := p - 2 * n
  have h_p_div_k : p ∣ k ^ 2 + 4 := by
    have : (k : ZMod p) ^ 2 + 4 = (p - 2 * n : ZMod p) ^ 2 + 4 := by norm_cast
    simp [this]; have : (n : ZMod p) ^ 2 = -1 := (ZMod.Nat.cast_eq_neg_one_iff p (n ^ 2)).mpr hn
    rw [this]; ring
  have : (p : ℝ) > 2 * n + √(2 * n) := by
    rw [gt_iff_lt, ← Real.lt_sub_iff_add_lt', ← Real.sqrt_lt (by linarith)]
    · have : 2 * n < k ^ 2 := by
        have : p ≤ k ^ 2 + 4 := Nat.le_of_dvd (by linarith) h_p_div_k
        have : k ≥ 5 := by
          have : k ^ 2 + 4 ≥ 21 := by linarith
          exact Nat.lt_of_pow_lt_pow 2 (by norm_num) (by linarith)
        linarith
      norm_cast; rwa [Real.sqrt_sq (by linarith)]
    · exact Real.sqrt_nonneg _
