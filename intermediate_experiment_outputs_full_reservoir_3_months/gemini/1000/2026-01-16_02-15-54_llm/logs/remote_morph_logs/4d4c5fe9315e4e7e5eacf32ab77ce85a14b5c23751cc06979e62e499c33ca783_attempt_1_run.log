import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := {p | Nat.Prime p ∧ p ≡ 1 [MOD 4] ∧ p > 4 * N ^ 2 + 1}
  have h_inf : S.Infinite := Nat.Prime.infinite_setOf_modEq_one 4 (by decide) |>.mono (by
    intro p hp; exact ⟨hp.1, hp.2, (by sorry)⟩)
  obtain ⟨p, hp_S⟩ := h_inf.nonempty
  obtain ⟨hp_prime, hp_mod, hp_gt⟩ := hp_S
  obtain ⟨x, hx_lt, hx_sq⟩ := Nat.Prime.sq_add_one_exists hp_prime hp_mod
  let n := if x ≤ p / 2 then x else p - x
  have h_n_lt : n < p / 2 := by
    dsimp [n]; split_ifs with h
    · exact hx_lt.le.lt_of_ne (λ h_eq => by
        have : (p/2)^2 + 1 ≡ 0 [MOD p] := h_eq ▸ hx_sq
        sorry)
    · exact Nat.sub_lt_of_pos_le (p - x) p (by sorry) (by sorry)
  have h_n_sq : n ^ 2 + 1 ≡ 0 [MOD p] := by
    dsimp [n]; split_ifs
    · exact hx_sq
    · rw [Nat.ModEq, Nat.pow_two, ← Nat.sub_mul_mod, Nat.mul_sub_left_distrib, ← Nat.pow_two]
      sorry
  have h_p_div : p ∣ n ^ 2 + 1 := Nat.modEq_zero_iff_dvd.mp h_n_sq
  use n
  have h_p_gt_2n : p > 2 * n := by linarith [h_n_lt]
  have h_n_ge_N : n ≥ N := by sorry
  refine ⟨h_n_ge_N, p, hp_prime, h_p_div, ?_⟩
  let m := p - 2 * n
  have h_m_pos : m > 0 := by linarith
  have h_disc : ∃ d : ℕ, 4 * (( (n^2+1)/p )^2 + ( (n^2+1)/p ) * m - 1) = d^2 := by sorry
  sorry
