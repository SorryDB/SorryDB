import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := {p | Nat.Prime p ∧ ∃ n, p ∣ n ^ 2 + 1}
  have h_inf : S.Infinite := Nat.Prime.infinite_setOf_prime_dvd_sq_add_one
  obtain ⟨p, hpS, hp_gt⟩ := h_inf.exists_gt (max 30 (N ^ 2 + 1))
  obtain ⟨hp, n0, hpn0⟩ := hpS
  let n := n0 % p
  have hpn : p ∣ n ^ 2 + 1 := by
    have : n ≡ n0 [MOD p] := Nat.mod_mod_congr n0 p
    exact (Nat.mod_congr n0 p).sq.add_right 1 |>.mp hpn0
  have hn_pos : n > 0 := by
    intro h
    subst h
    simp at hpn
    exact Nat.Prime.not_dvd_one hp hpn
  let n1 := min n (p - n)
  have hn1 : n1 ≤ p / 2 := by
    simp [n1]
    apply Nat.le_div_of_mul_le (by norm_num)
    omega
  have hpn1 : p ∣ n1 ^ 2 + 1 := by
    cases (show n1 = n ∨ n1 = p - n from by simp [n1, Nat.min_def]; split <;> omega) with
    | h1 => rwa [h1]
    | h2 =>
      rw [h2]
      have : (p - n) ^ 2 + 1 = p ^ 2 - 2 * p * n + n ^ 2 + 1 := by
        rw [Nat.sub_sq]
        omega
      rw [this]
      apply dvd_add _ hpn
      apply dvd_sub
      · apply dvd_pow hp; omega
      · apply dvd_mul_of_dvd_left hp.dvd_refl
  have hn1_pos : n1 > 0 := by
    simp [n1]
    omega
  let h := p - 2 * n1
  have h_odd : h % 2 = 1 := by
    have hp_odd : p % 2 = 1 := hp.even_spec.mp.mt (by omega)
    simp [h, hp_odd]
  have h_pos : h ≥ 1 := by omega
  have h_dvd : p ∣ h ^ 2 + 4 := by
    have : h ^ 2 + 4 = (p - 2 * n1) ^ 2 + 4 := rfl
    rw [Nat.sub_sq] at this
    · have : p ^ 2 - 2 * p * (2 * n1) + (2 * n1) ^ 2 + 4 = p ^ 2 - 4 * p * n1 + 4 * (n1 ^ 2 + 1) := by omega
      rw [this] at hpn1
      apply dvd_add (dvd_sub (dvd_pow hp (by omega)) (by omega)) (by simp [hpn1])
    · omega
  have h_bound : p ≤ h ^ 2 + 4 := Nat.le_of_dvd (by omega) h_dvd
  have hn1_inf : n1 ≥ (p - (h : ℤ)) / 2 := by omega
  have hn1_large : n1 ≥ N := by
    have : (p : ℚ) ≥ (h ^ 2 : ℚ) - 4 := by
      push_cast at h_bound; linarith
    have : (p : ℚ) > N ^ 2 + 1 := by push_cast; linarith
    omega
  use n1, hn1_large, p, hp, hpn1
  have : (p : ℝ) > 2 * n1 + √(2 * n1) ↔ (p - 2 * n1) ^ 2 > 2 * n1 := by
    rw [Real.gt_iff_lt, Real.add_comm, ← Real.lt_sub_iff_add_lt', Real.sqrt_lt_iff_sq_lt]
    · push_cast; ring_nf
    · omega
    · apply Real.sqrt_nonneg
  rw [this]
  have h_sq_gt_2n1 : h ^ 2 > p - h := by
    if h_case : h ^ 2 + 4 = p then
      rw [← h_case]
      omega
    else
      have : h ^ 2 + 4 ≥ 2 * p := by
        have : h ^ 2 + 4 = k * p := Nat.exists_eq_mul_left_of_dvd h_dvd |>.choose_spec
        have k_gt_1 : h ^ 2 + 4 / p ≥ 2 := by
          apply Nat.succ_le_of_lt
          apply Nat.lt_of_le_and_ne
          · apply Nat.div_le_of_le_mul; omega
          · intro h_eq; apply h_case; omega
        omega
      omega
  push_cast; omega
