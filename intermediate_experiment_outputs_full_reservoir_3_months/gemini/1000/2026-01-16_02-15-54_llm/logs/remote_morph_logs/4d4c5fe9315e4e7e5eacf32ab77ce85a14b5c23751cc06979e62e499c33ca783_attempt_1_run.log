import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  obtain ⟨p, hp, hpN, hpm⟩ := Nat.exists_prime_ge_modeq_one 4 1 (max (N ^ 2 + 1) 14)
  obtain ⟨x, hx⟩ := Nat.exists_sq_eq_neg_one_mod_p hp hpm
  let n₀ := x % p
  let n := if n₀ ≤ p / 2 then n₀ else p - n₀
  have hn_lt : n ≤ p / 2 := by split <;> linarith [Nat.div_add_mod p 2]
  have hn_dvd : p ∣ n ^ 2 + 1 := by
    have : (n : ZMod p) ^ 2 = -1 := by
      rcases em (n₀ ≤ p / 2) with h | h
      · simp [n, h]; rw [← ZMod.coe_pow, ZMod.coe_nat_cast, hx]
      · simp [n, h]; rw [← ZMod.coe_pow, ZMod.coe_nat_cast, hx]; ring
    exact (CharP.congr_nmul_nmul (ZMod p) p ((n : ZMod p) ^ 2) (-1)).mp this
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos _) hn_dvd
    have : n ^ 2 + 1 > N ^ 2 + 1 := by linarith [le_max_left (N ^ 2 + 1) 14]
    exact Nat.pow_le_pow_iff_left (by linarith) (by simp).ge |>.mp (by linarith)
  refine ⟨n, hn_ge_N, p, hp, hn_dvd, ?_⟩
  have hp13 : p > 13 := by linarith [le_max_right (N ^ 2 + 1) 14]
  by_contra! h
  have h2n_lt_p : 2 * n < p := by
    have hodd : p % 2 = 1 := Nat.Prime.mod_two_eq_one_of_ne_two hp (by linarith)
    have : 2 * n ≠ p := fun e => by rw [← e] at hodd; simp at hodd
    linarith [Nat.div_add_mod p 2]
  let k := p - 2 * n
  have hk_pos : k > 0 := Nat.sub_pos_of_lt h2n_lt_p
  have hk_sq : (k : ℝ) ^ 2 ≤ 2 * n := by
    rw [← Real.sqrt_le_iff (by linarith)] at h
    · linarith
    · exact Nat.cast_nonneg k
  have : p ∣ k ^ 2 + 4 := by
    have : (2 * n + k) ^ 2 + 4 = p ^ 2 + 4 := by rw [Nat.add_sub_cancel' (by linarith)]
    have : 4 * (n ^ 2 + 1) + k ^ 2 + 4 * n * k = p ^ 2 + 4 := by nlinarith
    have : p ∣ 4 * (n ^ 2 + 1) + k ^ 2 + 4 * n * k := by rw [this]; exact Nat.dvd_add (Nat.dvd_pow_self _ (by linarith)) (hp.dvd_refl.mpr (by linarith))
    exact (Nat.dvd_add_left (Nat.dvd_add (Nat.dvd_mul_left p 4) (Nat.dvd_mul_right p (4 * n)))).mp (by exact_mod_cast this)
  have hk_large : k ^ 2 + 4 < p + 4 := by
    have : (k : ℝ) ^ 2 + 4 ≤ 2 * n + 4 := by linarith
    have : (2 * n : ℝ) + 4 < p + 4 := by linarith
    exact_mod_cast this
  have : k ^ 2 + 4 = p := by
    have : k ^ 2 + 4 > 0 := Nat.succ_pos _
    obtain ⟨m, hm⟩ := this; rw [hm] at hk_large
    have : m = 1 := by linarith
    rw [this, Nat.one_mul] at hm; exact hm.symm
  have : (k : ℝ) ^ 2 > 2 * n := by
    have : (k : ℝ) ^ 2 = p - 4 := by rw [← this]; simp
    have : (2 * n : ℝ) = p - k := by rw [← Nat.cast_sub (by linarith)]; simp
    have : p - 4 > p - k ↔ (k : ℝ) > 4 := by linarith
    rw [this]; have : p > 13 := by linarith; rw [← ‹k ^ 2 + 4 = p›] at this
    have : k ^ 2 > 9 := by linarith
    have : k % 2 = 1 := by rw [← Nat.mod_add_mod, ‹k ^ 2 + 4 = p›, hpm]; simp [Nat.pow_mod]
    have : k > 3 := Nat.pow_le_pow_iff_left (by linarith) (by simp).ge |>.mp (by linarith)
    linarith [this]
  linarith
