import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := (Finset.range N).prod (fun i => i ^ 2 + 1)
  obtain ⟨p, hp, hge, hmod⟩ := Nat.exists_prime_ge_modeq_one 4 1 (max (M + 1) 14)
  have h2p : p ≠ 2 := hp.ne_two
  obtain ⟨x, hx⟩ := (ZMod.exists_sq_eq_neg_one_iff p).mpr (Or.inr ⟨h2p, hmod⟩)
  let n := if x.val ≤ p / 2 then x.val else p - x.val
  have h_n_sq : (n : ZMod p) ^ 2 = -1 := by
    split_ifs with h
    · rw [ZMod.nat_cast_zmod_val]; exact hx
    · rw [Nat.cast_sub (le_of_lt x.val_lt), Nat.cast_zero, zero_sub, neg_sq, ZMod.nat_cast_zmod_val]; exact hx
  have h_p_dvd : p ∣ n ^ 2 + 1 := (ZMod.Nat.zmod_eq_zero_iff_dvd p _).mp (by simp [h_n_sq])
  have hnN : n ≥ N := by
    by_contra hLT
    have : p ∣ M := Finset.dvd_prod_of_mem (λ i => i ^ 2 + 1) (Finset.mem_range.mpr (Nat.not_le.mp hLT))
    exact (hge.trans (Nat.le_of_dvd (Finset.prod_pos (λ _ _ => by positivity)) this)).not_lt (Nat.lt_succ_self M)
  use n, hnN, p, hp, h_p_dvd
  have hnp : n < p / 2 := by
    have h_x_val := x.val_lt
    split_ifs with h
    · exact Nat.lt_of_le_of_lt h (Nat.div_lt_self (by omega) (by decide))
    · omega
  let k := p - 2 * n
  have h_p_dvd_k2_4 : p ∣ k ^ 2 + 4 := by
    apply (ZMod.Nat.zmod_eq_zero_iff_dvd p _).mp
    have : (k : ZMod p) = - 2 * n := by rw [Nat.cast_sub (by omega)]; simp
    rw [show (k ^ 2 + 4 : ZMod p) = (k : ZMod p) ^ 2 + 4 by simp, this]; ring; rw [h_n_sq]; simp
  have h_k2_k_gt_p : k ^ 2 + k > p := by
    obtain ⟨m, hm⟩ := h_p_dvd_k2_4
    have hm_pos : 0 < m := Nat.pos_of_gt (by nlinarith)
    if hm1 : m = 1 then
      have : k ^ 2 + 4 = p := by omega
      have : k > 4 := by have : k ^ 2 = p - 4 := by omega; have : k ^ 2 > 9 := by omega; exact Nat.pos_pow_lt.mp (by exact_mod_cast this)
      omega
    else if hm2 : m = 2 then
      have : k ^ 2 + 4 = 2 * p := by omega
      have : k % 2 = 0 := by have : (k ^ 2 + 4) % 2 = 0 := by rw [congr_arg (· % 2) ‹k ^ 2 + 4 = 2 * p›]; simp; omega
      obtain ⟨j, rfl⟩ := Nat.even_iff.mp this
      have : (4 * j ^ 2 + 4) % 4 = (2 * p) % 4 := by rw [‹k ^ 2 + 4 = 2 * p›]; ring
      have : 2 * p % 4 = 2 := by rw [show 2 * p = 2 * (p / 4 * 4 + 1) by omega]; ring_nf; simp
      simpa [this] using ‹(4 * j ^ 2 + 4) % 4 = (2 * p) % 4›
    else
      have : m ≥ 3 := by omega
      nlinarith
  rw [Real.gt_iff_lt, ← Real.sub_lt_iff_lt_add, show (p : ℝ) - 2 * n = k by exact_mod_cast Nat.sub_eq_of_eq_add (by omega)]
  rw [Real.sqrt_lt_iff_sq_lt (by positivity), ← Nat.cast_mul, ← Nat.cast_pow]
  exact_mod_cast (by omega)

