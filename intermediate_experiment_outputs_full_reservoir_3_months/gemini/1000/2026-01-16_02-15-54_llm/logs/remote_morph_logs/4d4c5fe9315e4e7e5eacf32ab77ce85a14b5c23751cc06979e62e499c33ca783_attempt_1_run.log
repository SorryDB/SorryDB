import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let A := {n : ℕ | ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n)}
  have hA : Set.Infinite A := by
    refine Set.Infinite.mono (fun p hp => ?_) ((Nat.Infinite_setOf_prime_mod_eq_one 4 1 (by decide)).diff (Set.toFinite {p | p ≤ 13}))
    simp only [Set.mem_diff, Set.mem_setOf_eq, and_imp]; intro h_prime h_mod h_gt_13
    haveI : Fact (Nat.Prime p) := Fact.mk h_prime
    let v := (ZMod.sq_root_neg_one p).val
    let n := if v ≤ p / 2 then v else p - v
    have h_div : p ∣ n ^ 2 + 1 := by
      rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd]; simp [n]; split_ifs <;> simp [ZMod.sq_root_neg_one_sq]
    use n; simp [h_prime, h_div, A]
    let k := p - 2 * n
    have h_p_div_k : p ∣ k ^ 2 + 4 := by
      have : (p - 2 * n : ℤ) ^ 2 + 4 = p * (p - 4 * n) + 4 * (n ^ 2 + 1) := by ring
      rw [← Int.natAbs_dvd_natAbs, Int.natAbs_ofNat]; exact_mod_cast (Int.dvd_add (Int.dvd_mul_right _ _) (Int.dvd_mul_left 4 (by norm_cast; exact h_div)))
    have h_k_sq_ge_p : k ^ 2 + 4 ≥ p := Nat.le_of_dvd (by omega) h_p_div_k
    if h_m1 : k ^ 2 + 4 = p then
      have : k > 4 := by
        have : k % 2 = 1 := by
          rw [← Nat.odd_iff, ← Nat.even_add_one, ← h_m1, Nat.even_add]; simp; exact h_prime.odd_of_ne_two (by omega)
        have : k ≠ 1 ∧ k ≠ 3 := by constructor <;> (intro h; rw [h] at h_m1; omega)
        omega
      rw [Real.gt_iff_lt, Real.add_comm, ← Real.lt_diff_iff_get_lt, (by norm_cast : (p : ℝ) - 2 * n = k), Real.sqrt_lt_left (by norm_cast)]; norm_cast; omega
    else
      have : k ^ 2 + 4 ≥ 2 * p := by
        obtain ⟨m, hm⟩ := h_p_div_k; have : m ≥ 2 := by omega
        rw [hm]; exact Nat.mul_le_mul_left p this
      rw [Real.gt_iff_lt, Real.add_comm, ← Real.lt_diff_iff_get_lt, (by norm_cast : (p : ℝ) - 2 * n = k), Real.sqrt_lt_left (by norm_cast)]; norm_cast; omega
  obtain ⟨n, hn_ge, hn_A⟩ := hA.exists_ge N
  exact ⟨n, hn_ge, hn_A⟩

