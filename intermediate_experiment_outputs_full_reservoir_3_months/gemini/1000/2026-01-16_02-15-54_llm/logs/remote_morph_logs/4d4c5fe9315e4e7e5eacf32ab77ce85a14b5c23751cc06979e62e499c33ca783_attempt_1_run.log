  use n, hn_ge_N, p, hp_prime, hn_div
  have m_def : ∃ m, n ^ 2 + 1 = m * p := ⟨(n ^ 2 + 1) / p, (Nat.div_mul_cancel hn_div).symm⟩
  obtain ⟨m, hm⟩ := m_def
  have hm_bound : m < n / 2 + 1 := by
    have : p ≥ 2 * n + 1 := by
      have : 2 * n ≤ p := by linarith [Nat.div_add_mod p 2, hn_le]
      have : 2 * n ≠ p := by rintro rfl; have := hn_div; simp at this; exact hp_prime.not_dvd_one this
