import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  have h_inf : {p : ℕ | p.Prime ∧ p % 4 = 1}.Infinite :=
    Nat.Prime.exists_infinite_mod_eq_one 4 (by omega)
  obtain ⟨p, ⟨hp, hmod⟩, hpgt⟩ := h_inf.exists_gt (max 13 (N^2 + 1))
  obtain ⟨n, hn_lt, hn_sq⟩ := (Nat.Prime.sq_mod_eq_neg_one_iff hp).mpr (by simp [hmod])
  let n' := min n (p - n)
  have hpn' : p ∣ n' ^ 2 + 1 := by
    rw [Nat.min_def]; split <;> rename_i h
    · exact hn_sq
    · have : (p - n) ^ 2 + 1 = p ^ 2 + (n ^ 2 + 1) - 2 * p * n := by
        rw [Nat.sub_sq hn_lt.le]; omega
      rw [this, Nat.add_comm]; apply Nat.dvd_sub (Nat.dvd_add _ hn_sq) (by simp)
      · apply Nat.le_add_left
      · exact Nat.dvd_pow_self p (by omega)
  have hn'gt : n' ≥ N := by
    have : n' ^ 2 + 1 ≥ p := Nat.le_of_dvd (by omega) hpn'
    have : N ^ 2 + 1 < p := by omega
    exact Nat.le_of_pow_le_pow_left 2 (by omega) (by omega)
  use n', hn'gt, p, hp, hpn'
  have : (p : ℝ) > 2 * n' + √(2 * n') := by
    have hn'p : 2 * n' < p := by
      have : n' ≤ p / 2 := by
        rw [Nat.min_def]; split <;> omega
      omega
    let k := p - 2 * n'
    have hk : k ≥ 5 := by
      have hodd : Odd k := by
        rw [Nat.odd_iff, Nat.sub_mod (by omega), hmod]
        simp
      have hpk : p ∣ k ^ 2 + 4 := by
        have : k ^ 2 + 4 = (p - 2 * n') ^ 2 + 4 := rfl
        have : (p - 2 * n') ^ 2 + 4 = p ^ 2 - 4 * p * n' + 4 * (n' ^ 2 + 1) := by ring
        rw [this]; exact Nat.dvd_add (Nat.dvd_sub (Nat.dvd_pow_self _ (by omega)) (by simp)) (by simp [hpn'])
      have : p ≤ k ^ 2 + 4 := Nat.le_of_dvd (by nlinarith) hpk
      have : k ≠ 1 ∧ k ≠ 3 := by
        constructor <;> intro h <;> rw [h] at this <;> omega
      have : k > 0 := by omega
      have h_even : ¬ Even k := by rw [← Nat.odd_iff_not_even]; exact hodd
      repeat' (have : k ≠ _ := by intro h; rw [h] at h_even; norm_num at h_even; omega)
      omega
    have : (k : ℝ) > √(2 * n') := by
      apply Real.sqrt_lt.mpr
      have : (k : ℤ) ^ 2 > (2 * n' : ℤ) := by
        have : (k : ℤ) ^ 2 + 4 ≥ (p : ℤ) := by
          have : (p : ℕ) ∣ k ^ 2 + 4 := by
            have : k ^ 2 + 4 = (p - 2 * n') ^ 2 + 4 := rfl
            have : (p - 2 * n') ^ 2 + 4 = p ^ 2 - 4 * p * n' + 4 * (n' ^ 2 + 1) := by ring
            rw [this]; exact Nat.dvd_add (Nat.dvd_sub (Nat.dvd_pow_self _ (by omega)) (by simp)) (by simp [hpn'])
          exact Int.le_of_dvd (by nlinarith) (by zify; exact this)
        zify [k] at hk; nlinarith
      zify; exact this
    rw [show (p : ℝ) = 2 * n' + k by zify [k]; omega]
    linarith
  exact this

