import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  obtain ⟨p, hp, hp1, hpgt⟩ := Nat.Prime.exists_infinite_mod_four_eq_one (max 22 (N ^ 2 + 1))
  obtain ⟨x, hx⟩ := hp.exists_sq_add_one_mod_prime_eq_zero_iff.mpr (Or.inr hp1)
  let n := min (x % p) (p - x % p)
  have hodd : p % 2 = 1 := hp.mod_two_eq_one_iff_ne_two.mpr (by linarith)
  have h2n_lt_p : 2 * n < p := by
    have : n ≤ p / 2 := Nat.min_le_of_left_or_right (by
      apply Or.inr
      have hx_lt : x % p < p := Nat.mod_lt _ hp.pos
      omega)
    omega
  have hp_dvd_n2 : p ∣ n ^ 2 + 1 := by
    have : (n : ℤ) ^ 2 + 1 ≡ (x : ℤ) ^ 2 + 1 [ZMOD p] := by
      simp [n]
      split
      · apply Int.ModEq.add_right; apply Int.ModEq.pow
        apply Int.modEq_zero_iff_dvd.mpr; simp
      · apply Int.ModEq.add_right
        have : (p - x % p : ℤ) ^ 2 ≡ (-(x % p : ℤ)) ^ 2 [ZMOD p] := by
          apply Int.ModEq.pow; apply Int.modEq_zero_iff_dvd.mpr; simp
        norm_cast at this; rw [neg_sq] at this
        apply this.trans
        apply Int.ModEq.pow; apply Int.modEq_zero_iff_dvd.mpr; simp
    rw [← Int.coe_nat_dvd, ← Int.modEq_zero_iff_dvd]
    apply this.trans; rw [Int.modEq_zero_iff_dvd, Int.coe_nat_dvd]; exact hx
  have hn_ge_N : n ≥ N := by
    have : n ^ 2 + 1 ≥ p := Nat.le_of_dvd (Nat.succ_pos _) hp_dvd_n2
    have : n ^ 2 > N ^ 2 := by linarith
    exact Nat.le_of_pow_le_pow 2 (by linarith) (by linarith)
  exists n, hn_ge_N, p, hp, hp_dvd_n2
  let k := p - 2 * n
  have hp_dvd_k2 : p ∣ k ^ 2 + 4 := by
    have : (k : ℤ) ^ 2 + 4 ≡ (-2 * (n : ℤ)) ^ 2 + 4 [ZMOD p] := by
      apply Int.ModEq.add_right; apply Int.ModEq.pow
      rw [Int.modEq_zero_iff_dvd.mpr (by simp [k])]
      ring_nf; rfl
    have : (k : ℤ) ^ 2 + 4 ≡ 4 * (n ^ 2 + 1) [ZMOD p] := by
      convert this using 1; ring
    rw [Int.modEq_zero_iff_dvd, ← Int.coe_nat_dvd] at this
    apply this.trans; norm_cast; exact hp_dvd_n2.mul_left 4
  have hk_ge_5 : k ≥ 5 := by
    have : p ≤ k ^ 2 + 4 := Nat.le_of_dvd (by linarith) hp_dvd_k2
    omega
  have : (p : ℝ) > 2 * n + √(2 * n) := by
    rw [← Real.lt_sub_iff_add_lt, Real.sqrt_lt_iff_lt_sq (by norm_cast; linarith)]
    · norm_cast; linarith [Nat.le_of_dvd (by linarith) hp_dvd_k2]
    · norm_cast; linarith
