import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let S := {p | Nat.Prime p ∧ p % 4 = 1}
  have hS_inf : S.Infinite := Nat.exists_infinite_primes_congruent_mod 4 1
  contrapose! hS_inf
  obtain ⟨M, hM⟩ := hS_inf
  let B := max N M
  let p_set := {p ∈ S | ∃ n < p / 2, p ∣ n ^ 2 + 1 ∧ (p : ℝ) ≤ 2 * n + √(2 * n)}
  have h_p_set : p_set.Finite := by
    have : ∀ p ∈ p_set, ∃ n, n < p / 2 ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) ≤ 2 * n + √(2 * n) := fun p hp => hp.2
    let f : (p : ℕ) → p ∈ p_set → ℕ := fun p hp => Nat.find (this p hp)
    have hf_bound : ∀ p (hp : p ∈ p_set), (p : ℝ) ≤ 2 * f p hp + √(2 * f p hp) := fun p hp => (Nat.find_spec (this p hp)).2.2
    have hf_n : ∀ p (hp : p ∈ p_set), f p hp < p / 2 := fun p hp => (Nat.find_spec (this p hp)).1
    have hf_p : ∀ p (hp : p ∈ p_set), p ∣ (f p hp)^2 + 1 := fun p hp => (Nat.find_spec (this p hp)).2.1
    have hf_finite : (Set.range fun p : {p // p ∈ p_set} => f p.1 p.2).Finite := by
      refine Set.Finite.subset (Set.finite_le_nat (B + (B ^ 2 + 1))) (fun n hn => ?_)
