theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  constructor
  · rintro ⟨f, h_inj, h_onto⟩
    let g := fun y => Classical.choose (h_onto y)
    refine ⟨f, g, funext (fun y => Classical.choose_spec (h_onto y)),
      funext (fun x => h_inj (Classical.choose_spec (h_onto (f x))))⟩
  · rintro ⟨f, g, hfg, hgf⟩
    refine ⟨f, fun h => by rw [← congr_fun hgf _, ← congr_fun hgf _, h],
      fun y => ⟨g y, congr_fun hfg y⟩⟩
