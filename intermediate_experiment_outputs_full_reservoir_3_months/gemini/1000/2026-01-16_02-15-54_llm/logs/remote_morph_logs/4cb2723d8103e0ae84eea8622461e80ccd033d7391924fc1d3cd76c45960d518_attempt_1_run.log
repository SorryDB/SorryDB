  · -- Goal 6: Precondition for `YY_plus_XX`
    sorry
  · -- Goal 7: Precondition for `YY`
    sorry
  · -- Goal 8: Precondition for `XX`
    sorry
  · -- Goal 9: Precondition for `X_plus_Y_sq`
    sorry
  · -- Goal 10: Precondition for `YY_plus_XX`
    sorry
  · -- Goal 11: Precondition for `ZZ2`
    intro i hi
    scalar_tac
