          w ^ 2 / (6 ^ 2 - 7 ^ 2) =
        1)
    (h₃ :
      x ^ 2 / (8 ^ 2 - 1) + y ^ 2 / (8 ^ 2 - 3 ^ 2) + z ^ 2 / (8 ^ 2 - 5 ^ 2) +
          w ^ 2 / (8 ^ 2 - 7 ^ 2) =
        1) :
    x ^ 2 + y ^ 2 + z ^ 2 + w ^ 2 = 36 := by
  norm_num at h₀ h₁ h₂ h₃
  let p : ℝ[X] := (Polynomial.X - 1) * (Polynomial.X - 9) * (Polynomial.X - 25) * (Polynomial.X - 49) -
