theorem aime_1984_p15 (x y z w : ℝ)
    (h₀ :
      x ^ 2 / (2 ^ 2 - 1) + y ^ 2 / (2 ^ 2 - 3 ^ 2) + z ^ 2 / (2 ^ 2 - 5 ^ 2) +
          w ^ 2 / (2 ^ 2 - 7 ^ 2) =
        1)
    (h₁ :
      x ^ 2 / (4 ^ 2 - 1) + y ^ 2 / (4 ^ 2 - 3 ^ 2) + z ^ 2 / (4 ^ 2 - 5 ^ 2) +
          w ^ 2 / (4 ^ 2 - 7 ^ 2) =
        1)
    (h₂ :
      x ^ 2 / (6 ^ 2 - 1) + y ^ 2 / (6 ^ 2 - 3 ^ 2) + z ^ 2 / (6 ^ 2 - 5 ^ 2) +
          w ^ 2 / (6 ^ 2 - 7 ^ 2) =
        1)
    (h₃ :
      x ^ 2 / (8 ^ 2 - 1) + y ^ 2 / (8 ^ 2 - 3 ^ 2) + z ^ 2 / (8 ^ 2 - 5 ^ 2) +
          w ^ 2 / (8 ^ 2 - 7 ^ 2) =
        1) :
    x ^ 2 + y ^ 2 + z ^ 2 + w ^ 2 = 36 := by
  let p : ℝ[X] := (X - 4) * (X - 16) * (X - 36) * (X - 64)
  let q : ℝ[X] := (X - 1) * (X - 9) * (X - 25) * (X - 49) - (x ^ 2 * (X - 9) * (X - 25) * (X - 49) + y ^ 2 * (X - 1) * (X - 25) * (X - 49) + z ^ 2 * (X - 1) * (X - 9) * (X - 49) + w ^ 2 * (X - 1) * (X - 9) * (X - 25))
  have h_roots : ∀ t ∈ ({4, 16, 36, 64} : Finset ℝ), (p - q).eval t = 0 := by
    intro t ht
    rcases ht with (rfl | rfl | rfl | rfl)
    · field_simp [h₀] at h₀; simp [p, q]; linear_combination h₀
    · field_simp [h₁] at h₁; simp [p, q]; linear_combination h₁
    · field_simp [h₂] at h₂; simp [p, q]; linear_combination h₂
    · field_simp [h₃] at h₃; simp [p, q]; linear_combination h₃
  have h_eq : p = q := by
    apply sub_eq_zero.1; apply eq_of_degree_le_of_card_le_eval_eq (p := p - q) (q := 0) (n := 3)
    · apply degree_le_of_degree_lt; apply degree_sub_lt <;> (simp [p, q, coeff_mul, coeff_X_sub_C]; norm_num)
    · simp
    · simp; norm_num; exact h_roots
  have h_coeff : p.coeff 3 = q.coeff 3 := congr_arg (coeff · 3) h_eq
  simp [p, q, coeff_mul, coeff_X_sub_C] at h_coeff
  linarith
