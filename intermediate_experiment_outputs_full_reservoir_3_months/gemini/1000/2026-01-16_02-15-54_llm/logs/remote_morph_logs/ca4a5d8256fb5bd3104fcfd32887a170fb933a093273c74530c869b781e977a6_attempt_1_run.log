  n.factorial > e * (n / e) ^ n := by
  have hn_pos : 0 < (n : ℝ) := cast_pos.mpr (zero_lt_one.trans hn)
  have h_fact_pos : 0 < (n.factorial : ℝ) := cast_pos.mpr (factorial_pos n)
  have he_pos : 0 < e := exp_pos 1
  rw [← log_lt_log (mul_pos he_pos (pow_pos (div_pos hn_pos he_pos) n)) h_fact_pos]
  rw [log_nat_factorial, log_mul he_pos.ne' (pow_pos (div_pos hn_pos he_pos) n).ne', log_pow,
    log_div hn_pos.ne' he_pos.ne', e, log_exp, log_exp, mul_sub, mul_one]
  let f : ℝ → ℝ := fun x => x * log x - x
  have hf : ∀ x ∈ Set.Ioi (0 : ℝ), HasDerivAt f (log x) x := fun x hx => by
    convert (hasDerivAt_id x).xlogx hx.ne' |>.sub (hasDerivAt_id x)
    rw [mul_one]
  have : f n - f 1 < ∑ i in Finset.range (n - 1), log (i + 2) := by
    rw [← Finset.sum_range_sub (fun i => f (i + 1)) (n - 1)]
    refine Finset.sum_lt_sum (fun i _ => ?_) ⟨0, Finset.mem_range.mpr (Nat.sub_pos_of_lt hn)⟩
    let a := (i + 1 : ℝ)
    have ha_pos : 0 < a := by positivity
