theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  let f (x : ℝ) := x * log x - x
  have hf' : ∀ x ∈ Set.Ioi (0 : ℝ), HasDerivAt f (log x) x := by
    intro x hx
    convert (hasDerivAt_id x).mul (hasDerivAt_log hx.ne') |>.sub (hasDerivAt_id x)
    simp [hx.ne']
  have h_sum_lt : f n - f 1 < log n.factorial := by
    rw [Nat.cast_factorial, log_prod (fun i _ => by norm_cast; linarith),
      Finset.sum_range_succ' (fun i => log (i + 1)) (n - 1)]
    · rw [log_one, zero_add, ← Finset.sum_range_sub fun i => f (i + 1),
        Nat.sub_add_cancel (Nat.one_le_of_lt hn)]
      apply Finset.sum_lt_sum
      · intro i hi
        have h_range : (i + 1 : ℝ) < (i + 2 : ℝ) := by linarith
        have : ∃ c, c ∈ Set.Ioo (i + 1 : ℝ) (i + 2 : ℝ) ∧ f (i + 2) - f (i + 1) = log c := by
          apply exists_deriv_eq_slope f log h_range
          · apply continuousOn_id.mul continuousOn_log |>.sub continuousOn_id |>.mono
            intro x hx; simp at hx; linarith
          · intro x hx; apply hf'; simp at hx; linarith
        rcases this with ⟨c, hc, h_eq⟩
        rw [h_eq]
        exact log_lt_log (by linarith) hc.2
      · use 0; simp; linarith [hn]
    · rwa [Nat.sub_add_cancel (Nat.one_le_of_lt hn)]
  have h_log_goal : log (e * (n / e) ^ n) = f n - f 1 := by
    have e_pos : 0 < e := exp_pos 1
    have n_pos : 0 < (n : ℝ) := by linarith
    rw [log_mul e_pos.ne' (pow_pos (div_pos n_pos e_pos) n).ne', (by dsimp [e]; rw [log_exp]),
      log_pow, log_div n_pos.ne' e_pos.ne', (by dsimp [e]; rw [log_exp])]
    simp [f]; ring
  rw [← log_lt_log_iff]
  · rwa [h_log_goal]
  · exact mul_pos (exp_pos 1) (pow_pos (div_pos (by linarith) (exp_pos 1)) n)
  · exact_mod_cast n.factorial_pos
