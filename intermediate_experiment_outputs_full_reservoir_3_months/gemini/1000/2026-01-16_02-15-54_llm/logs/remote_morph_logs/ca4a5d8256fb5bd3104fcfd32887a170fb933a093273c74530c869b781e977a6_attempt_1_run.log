  have hf_deriv : ∀ x ∈ Set.Ioi (0 : ℝ), HasDerivAt f (log x) x := fun x hx => by
    convert (hasDerivAt_id x).mul (hasDerivAt_log hx.ne') |>.sub (hasDerivAt_id x)
    rw [id, id, mul_inv_cancel hx.ne']; ring
  have hf_convex : StrictConvexOn ℝ (Set.Ioi 0) f :=
    strictConvexOn_of_deriv_strict_mono (convex_Ioi 0) hf_deriv strictMonoOn_log
  have h_n_pos : 0 < (n : ℝ) := by positivity
