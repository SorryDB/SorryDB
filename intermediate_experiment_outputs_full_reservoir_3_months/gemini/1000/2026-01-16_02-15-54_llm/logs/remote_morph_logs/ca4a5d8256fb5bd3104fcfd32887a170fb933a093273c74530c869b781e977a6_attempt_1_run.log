/-- The base of the natural logarithm. -/
noncomputable def e := exp 1

theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  induction n, hn using Nat.le_induction with
  | base =>
    simp [e, div_pow]
    field_simp [exp_pos]
    rw [show (4 : ℝ) = 2 * 2 by norm_num, mul_lt_mul_left (by positivity)]
    exact one_add_lt_exp (by norm_num)
  | succ n hn IH =>
    rw [Nat.factorial_succ, Nat.cast_mul, Nat.cast_add_one]
    refine lt_of_lt_of_le (mul_lt_mul_of_pos_left IH (by positivity)) ?_
    simp [e, div_pow]
    field_simp [exp_pos, (by positivity : 0 < (n : ℝ))]
    rw [pow_succ (exp 1), pow_succ (↑n + 1)]
    field_simp [exp_pos, (by positivity : 0 < (n : ℝ))]
    rw [← div_le_iff' (pow_pos (by positivity) n), ← div_pow, Nat.cast_add_one, add_div, div_self (by positivity)]
    exact one_add_div_pow_le_exp 1 n
