/-- The base of the natural logarithm. -/
noncomputable def e := exp 1

theorem bound_factorial {n : ℕ} (hn : 1 < n):
  n.factorial > e * (n / e) ^ n := by
  have hn_pos : 0 < (n : ℝ) := by positivity
  have he_pos : 0 < e := exp_pos 1
  have h_fact_pos : 0 < (n.factorial : ℝ) := by positivity
  have h_rhs_pos : 0 < e * ((n : ℝ) / e) ^ n := by positivity
  rw [← log_lt_log h_rhs_pos h_fact_pos]
  have h_log_fact : log n.factorial = ∑ i in Finset.range n, log (i + 1) := by
    rw [Nat.factorial_eq_prod_range, Nat.cast_prod, log_prod]
    · rfl
    · intro i _; positivity
  have h_log_rhs : log (e * (n / e) ^ n) = n * log n - n + 1 := by
    rw [log_mul he_pos.ne' (pow_pos (div_pos hn_pos he_pos) n).ne', log_exp 1, log_pow, log_div hn_pos.ne' he_pos.ne', log_exp 1]
    ring
  rw [h_log_fact, h_log_rhs]
  let g (i : ℝ) := i * log i - i
  have h_sum_sub : (∑ i in Finset.range (n - 1), (g (i + 2) - g (i + 1))) = g n - g 1 := by
    rw [← Finset.sum_range_sub (fun i => g (i + 1)) (n - 1)]
    simp [Nat.sub_add_cancel (le_of_lt hn)]
  have hg1 : g 1 = -1 := by dsimp [g]; rw [log_one, mul_zero, zero_sub]
  have hgn : g n = n * log n - n := rfl
  rw [← hg1, ← hgn, ← h_sum_sub]
  refine' (Finset.sum_lt_sum_of_nonempty (Finset.nonempty_range.mpr (by omega)) _).trans_le _
  · intro i hi
    have hk : 0 < (i + 1 : ℝ) := by positivity
    have h_log_lt : log ((i + 2 : ℝ) / (i + 1)) < 1 / (i + 1) := by
      have h1 : (1 : ℝ) < (i + 2) / (i + 1) := by
        rw [lt_div_iff (by positivity)]; linarith
      have h2 : 0 < (i + 2 : ℝ) / (i + 1) := by positivity
      convert log_lt_sub_one h2 h1.ne'
      field_simp
    calc g (i + 2) - g (i + 1)
      = (i + 1) * (log (i + 2) - log (i + 1)) + log (i + 2) - 1 := by dsimp [g]; ring
    _ = (i + 1) * log ((i + 2) / (i + 1)) + log (i + 2) - 1 := by rw [log_div (by positivity) hk.ne']; ring
    _ < (i + 1) * (1 / (i + 1)) + log (i + 2) - 1 := by linarith
    _ = log (i + 2) := by rw [mul_one_div, div_self hk.ne']; ring
  · rw [← Nat.sub_add_cancel (le_of_lt hn), Finset.sum_range_succ', log_one, zero_add]
