/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  let q := x * y + y * z + z * x
  let r := x * y * z
  constructor
  · calc 0 ≤ x * y * (x + y) + y * z * (y + z) + z * x * (z + x) + r := by nlinarith
      _ = q - 2 * r := by rw [← h₁]; ring
  · have hq : q ≤ 1 / 3 := by
      have : 1 - 3 * q = ((x - y)^2 + (y - z)^2 + (z - x)^2) / 2 := by rw [← h₁]; ring
      nlinarith
    have h_schur : 4 * q - 9 * r ≤ 1 := by
      wlog h_le : x ≤ y ∧ y ≤ z generalizing x y z
      · have : (4 * (x * y + y * z + z * x) - 9 * (x * y * z)) = (4 * (y * x + x * z + z * y) - 9 * (y * x * z)) := by ring
        exact this ▸ (this ▸ this ▸ this ▸ this ▸ this ▸ (by
          by_cases hxy : x ≤ y
          · by_cases hyz : y ≤ z
            · exact this x y z h₀ h₁ ⟨hxy, hyz⟩
            · by_cases hxz : x ≤ z
              · exact this x z y h₀ (by rw [add_comm z y, ← h₁]) ⟨hxz, (by nlinarith)⟩
              · exact this z x y h₀ (by rw [add_rotate z x y, ← h₁]) ⟨(by nlinarith), hxy⟩
          · by_cases hxz : x ≤ z
            · exact this y x z h₀ (by rw [add_comm x y, ← h₁]) ⟨(by nlinarith), hxz⟩
            · by_cases hyz : y ≤ z
              · exact this y z x h₀ (by rw [add_rotate y z x, ← h₁]) ⟨hyz, (by nlinarith)⟩
              · exact this z y x h₀ (by rw [add_comm z y, add_comm (z + y) x, ← h₁]) ⟨(by nlinarith), (by nlinarith)⟩))
      · have : 1 - (4 * q - 9 * r) = x * (y - x) * (z - x) + (z - y) * (z * (z - x) - y * (y - x)) := by rw [← h₁]; ring
        rw [← sub_nonneg, this]
        have : z * (z - x) ≥ y * (y - x) := by nlinarith
        nlinarith
    calc q - 2 * r = (1 - 3 * q) / 27 + 2 * (1 - (4 * q - 9 * r)) / 9 + q - 2 * r := by ring -- to show the sum is q-2r
      _ = 7 / 27 - ((1 - 3 * q) / 27 + 2 * (1 - (4 * q - 9 * r)) / 9) := by ring
      _ ≤ 7 / 27 := by nlinarith

