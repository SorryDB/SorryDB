    rw [this]
    have : x ≤ 1 ∧ y ≤ 1 ∧ z ≤ 1 := by constructor <;> linarith
    positivity
  · let s := x + y
    have hf : y * z + z * x + x * y - 2 * x * y * z = s - s ^ 2 + x * y * (2 * s - 1) := by dsimp [s]; linarith
    if h2s : 1 / 2 ≤ s then
      have hxy : x * y ≤ s ^ 2 / 4 := by dsimp [s]; nlinarith
      have h_expr : s - s ^ 2 + (s ^ 2 / 4) * (2 * s - 1) = 7 / 27 - (2 - 3 * s) ^ 2 * (7 - 6 * s) / 108 := by ring
      have : s ≤ 1 := by linarith
      rw [hf, h_expr]
      nlinarith
    else
      have : s - s ^ 2 ≤ 1 / 4 := by nlinarith
      have : x * y * (2 * s - 1) ≤ 0 := by nlinarith
      rw [hf]
      linarith [show (1 : ℝ) / 4 ≤ 7 / 27 by norm_num]

