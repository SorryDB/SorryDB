/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have hx : x ≤ 1 := by linarith
    have hy : y ≤ 1 := by linarith
    have hz : z ≤ 1 := by linarith
    calc y * z + z * x + x * y - 2 * x * y * z
      _ = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z := by ring
      _ ≥ 0 := by positivity
  · let a := 1 - 2 * x
    let b := 1 - 2 * y
    let c := 1 - 2 * z
    have h_id : 4 * (y * z + z * x + x * y - 2 * x * y * z) = a * b * c + 2 * (x + y + z) - 1 := by ring
    rw [h₁, h_id]
    suffices a * b * c ≤ (1 : ℝ) / 27 by linarith
    by_cases h_pos : 0 < a * b * c
    · have h_nonneg : 0 ≤ a ∧ 0 ≤ b ∧ 0 ≤ c := by
        have hab : 0 ≤ a + b := by linarith
        have hbc : 0 ≤ b + c := by linarith
        have hca : 0 ≤ c + a := by linarith
        constructor
        · by_contra; nlinarith
        constructor
        · by_contra; nlinarith
        · by_contra; nlinarith
      have : b * c ≤ (1 - a) ^ 2 / 4 := by
        have : b + c = 1 - a := by linarith
        nlinarith
      have : a * b * c ≤ a * (1 - a) ^ 2 / 4 := by nlinarith
      have : a * (1 - a) ^ 2 = 4 / 27 - (a - 1 / 3) ^ 2 * (4 / 3 - a) := by ring
      have : a ≤ 1 ∧ 0 ≤ (a - 1 / 3) ^ 2 := by constructor <;> positivity
      nlinarith
    · linarith
