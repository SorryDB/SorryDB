import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · calc y * z + z * x + x * y - 2 * x * y * z
      _ = (y * z + z * x + x * y) * (x + y + z) - 2 * x * y * z := by rw [h₁, mul_one]
      _ = x^2 * y + x * z^2 + y^2 * z + y * x^2 + z^2 * y + z * x^2 + x * y * z := by ring
      _ ≥ 0 := by positivity
  · have hf : y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - 2 * x) + x * (1 - x) := by
      rw [← h₁]; ring
    by_cases hx : x ≤ 1 / 2
    · have hyz : y * z ≤ (1 - x)^2 / 4 := by
        have : y + z = 1 - x := by linarith
        nlinarith [sq_nonneg (y - z)]
      rw [hf]
      have : y * z * (1 - 2 * x) + x * (1 - x) ≤ (1 - x)^2 / 4 * (1 - 2 * x) + x * (1 - x) := by
        have h2x : 0 ≤ 1 - 2 * x := by linarith
        exact add_le_add_right (mul_le_mul_of_nonneg_right hyz h2x) (x * (1 - x))
      apply this.trans
      have hg : (1 - x)^2 / 4 * (1 - 2 * x) + x * (1 - x) = (1 / 4) * (-2 * x^3 + x^2 + 1) := by ring
      rw [hg, ← sub_nonneg]
      have h3 : 7 / 27 - (1 / 4) * (-2 * x^3 + x^2 + 1) = (3 * x - 1)^2 * (6 * x + 1) / 108 := by ring
      rw [h3]
      positivity
    · rw [hf]
      have : y * z * (1 - 2 * x) ≤ 0 := by
        have : 0 ≤ y * z := by positivity
        have : 1 - 2 * x < 0 := by linarith
        exact mul_nonpos_of_nonneg_of_nonpos this (by linarith)
      have : x * (1 - x) ≤ 1 / 4 := by nlinarith [sq_nonneg (x - 1 / 2)]
      linarith

