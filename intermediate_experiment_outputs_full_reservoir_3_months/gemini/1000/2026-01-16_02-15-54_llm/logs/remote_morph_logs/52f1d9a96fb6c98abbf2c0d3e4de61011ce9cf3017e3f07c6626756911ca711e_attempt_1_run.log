/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  wlog h_le : x ≤ y ∧ x ≤ z generalizing x y z
  · have hx_le : x ≤ 1 / 3 := by linarith
    have hf : y * z + z * x + x * y - 2 * x * y * z = x * (1 - x) + y * z * (1 - 2 * x) := by rw [← h₁]; ring
    constructor
    · rw [hf]; nlinarith
    · rw [hf]
      have hyz : y * z ≤ (1 - x) ^ 2 / 4 := by
        have : y + z = 1 - x := by linarith
        nlinarith
      have hup : x * (1 - x) + y * z * (1 - 2 * x) ≤ x * (1 - x) + (1 - x) ^ 2 / 4 * (1 - 2 * x) := by nlinarith
      refine hup.trans ?_
      have : 7 / 27 - (x * (1 - x) + (1 - x) ^ 2 / 4 * (1 - 2 * x)) = (3 * x - 1) ^ 2 * (6 * x + 1) / 108 := by ring
      linarith
  · obtain h | h | h : (x ≤ y ∧ x ≤ z) ∨ (y ≤ x ∧ y ≤ z) ∨ (z ≤ x ∧ z ≤ y) := by linarith
    · exact h_le x y z h₀ h₁ h
    · exact h_le y z x ⟨h₀.2.1, h₀.2.2, h₀.1⟩ (by linarith) h
    · exact h_le z x y ⟨h₀.2.2, h₀.1, h₀.2.1⟩ (by linarith) h

