import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · rw [show y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z by rw [← h₁]; ring]
    have : 0 ≤ 1 - x ∧ 0 ≤ 1 - y ∧ 0 ≤ 1 - z := by constructor <;> linarith
    positivity
  · have h_main {a b c : ℝ} (ha : 0 ≤ a) (hb : 0 ≤ b) (hc : 0 ≤ c) (hsum : a + b + c = 1) (hc2 : c ≤ (1 / 2 : ℝ)) :
        a * b + b * c + c * a - 2 * a * b * c ≤ (7 : ℝ) / (27 : ℝ) := by
      have : a * b + b * c + c * a - 2 * a * b * c = a * b * (1 - 2 * c) + c * (1 - c) := by rw [← hsum]; ring
      rw [this]
      have : a * b ≤ (1 - c)^2 / 4 := by
        have : a + b = 1 - c := by linarith
        nlinarith [sq_nonneg (a - b)]
      have : a * b * (1 - 2 * c) + c * (1 - c) ≤ (1 - c)^2 / 4 * (1 - 2 * c) + c * (1 - c) := by
        apply add_le_add_right; apply mul_le_mul_of_nonneg_right <;> linarith
      apply this.trans
      have : (7 : ℝ) / 27 - ((1 - c)^2 / 4 * (1 - 2 * c) + c * (1 - c)) = (3 * c - 1)^2 * (6 * c + 1) / 108 := by ring
      have : 0 ≤ (3 * c - 1)^2 * (6 * c + 1) / 108 := by
        have : 0 ≤ 6 * c + 1 := by linarith
        positivity
      linarith
    have : x ≤ 1 / 2 ∨ y ≤ 1 / 2 ∨ z ≤ 1 / 2 := by linarith
    rcases this with h | h | h
    · exact h_main h₀.2.1 h₀.2.2 h₀.1 (by linarith) h
    · exact h_main h₀.2.2 h₀.1 h₀.2.1 (by linarith) h
    · exact h_main h₀.1 h₀.2.1 h₀.2.2 h₁ h
