import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  have hx1 : x ≤ 1 := by linarith
  have hy1 : y ≤ 1 := by linarith
  have hz1 : z ≤ 1 := by linarith
  constructor
  · rw [show y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - x) + z * x * (1 - y) + x * y * (1 - z) + x * y * z by ring]
    positivity
  · let a := 1 - 2 * x; let b := 1 - 2 * y; let c := 1 - 2 * z
    have h_abc : y * z + z * x + x * y - 2 * x * y * z = (1 + a * b * c) / 4 := by ring
    rw [h_abc]
    have h_sum : a + b + c = 1 := by linarith
    if hx : 1 / 2 < x then
      have : a < 0 ∧ b ≥ 0 ∧ c ≥ 0 := by linarith
      have : a * b * c ≤ 0 := by nlinarith
      linarith
    else if hy : 1 / 2 < y then
      have : a ≥ 0 ∧ b < 0 ∧ c ≥ 0 := by linarith
      have : a * b * c ≤ 0 := by nlinarith
      linarith
    else if hz : 1 / 2 < z then
      have : a ≥ 0 ∧ b ≥ 0 ∧ c < 0 := by linarith
      have : a * b * c ≤ 0 := by nlinarith
      linarith
    else
      have ha : 0 ≤ a := by linarith
      have hb : 0 ≤ b := by linarith
      have hc : 0 ≤ c := by linarith
      have h_am_gm := Real.geom_mean_le_arith_mean3 ha hb hc
      rw [h_sum] at h_am_gm
      have : a * b * c ≤ 1 / 27 := by
        have h1 : (a * b * c) ^ (1 / 3 : ℝ) ≤ 1 / 3 := by linarith
        have h2 : ((a * b * c) ^ (1 / 3 : ℝ)) ^ 3 ≤ (1 / 3 : ℝ) ^ 3 := pow_le_pow_left₀ (by positivity) h1 3
        rwa [Real.rpow_inv_nat_cast_pow (by positivity) 3, show (1 / 3 : ℝ) ^ 3 = 1 / 27 by ring] at h2
      linarith
