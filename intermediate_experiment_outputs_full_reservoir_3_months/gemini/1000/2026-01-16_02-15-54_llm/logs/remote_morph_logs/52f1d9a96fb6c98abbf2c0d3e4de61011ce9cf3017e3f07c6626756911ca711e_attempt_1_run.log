open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · rw [show y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - x) + z * x * (1 - y) + x * y * (1 - z) + x * y * z by ring]
    repeat' apply add_nonneg <;> apply mul_nonneg <;> try assumption <;> linarith
  · have h_symm (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) (h : x ≤ y ∧ x ≤ z) :
          y * z + z * x + x * y - 2 * x * y * z ≤ 7 / 27 := by
      have h_yz : y * z ≤ (1 - x) ^ 2 / 4 := by
        have : 4 * (y * z) ≤ (y + z) ^ 2 := by
          have : 0 ≤ (y - z) ^ 2 := sq_nonneg (y - z)
          linarith
        have : y + z = 1 - x := by linarith
        linarith
      rw [show y * z + z * x + x * y - 2 * x * y * z = x * (1 - x) + y * z * (1 - 2 * x) by rw [← h₁]; ring]
      apply (add_le_add_left (mul_le_mul_of_nonneg_right h_yz (by linarith)) _).trans
      rw [show x * (1 - x) + (1 - x) ^ 2 / 4 * (1 - 2 * x) = 7 / 27 - (1 - 3 * x) ^ 2 * (1 + 6 * x) / 108 by ring]
      linarith [sq_nonneg (1 - 3 * x), h₀.1]
    rcases show x ≤ y ∧ x ≤ z ∨ y ≤ x ∧ y ≤ z ∨ z ≤ x ∧ z ≤ y by linarith [le_total x y, le_total y z, le_total x z] with h | h | h
    · exact h_symm x y z h₀ h₁ h
    · exact h_symm y x z ⟨h₀.2.1, h₀.1, h₀.2.2⟩ (by linarith) h
    · exact h_symm z x y ⟨h₀.2.2, h₀.1, h₀.2.1⟩ (by linarith) h

