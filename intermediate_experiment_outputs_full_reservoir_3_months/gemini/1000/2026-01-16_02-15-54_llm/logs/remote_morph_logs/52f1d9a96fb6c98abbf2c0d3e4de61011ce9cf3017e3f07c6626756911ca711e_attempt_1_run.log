import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · calc y * z + z * x + x * y - 2 * x * y * z
          = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z := by ring
        _ ≥ 0 := by
          have : x ≤ 1 := by linarith [h₀.2.1, h₀.2.2, h₁]
          have : y ≤ 1 := by linarith [h₀.1, h₀.2.2, h₁]
          have : z ≤ 1 := by linarith [h₀.1, h₀.2.1, h₁]
          nlinarith
  · have h_yz : y * z ≤ ((y + z) / 2) ^ 2 := by
      have : 0 ≤ (y - z) ^ 2 := by nlinarith
      linarith
    have h_yz_sum : y + z = 1 - x := by linarith
    have h_expr : y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - 2 * x) + x * (1 - x) := by ring
    by_cases hx : x ≤ 1 / 2
    · have h_le_g : y * z + z * x + x * y - 2 * x * y * z ≤ ((1 - x) / 2) ^ 2 * (1 - 2 * x) + x * (1 - x) := by
        rw [h_expr]
        have : 0 ≤ 1 - 2 * x := by linarith
        nlinarith [h_yz, h_yz_sum]
      apply h_le_g.trans
      have h_id : 108 * (7 / 27 - (((1 - x) / 2) ^ 2 * (1 - 2 * x) + x * (1 - x))) = (3 * x - 1) ^ 2 * (6 * x + 1) := by ring
      have : 0 ≤ (3 * x - 1) ^ 2 := by nlinarith
      have : 0 ≤ 6 * x + 1 := by linarith [h₀.1]
      linarith [h_id]
    · have h_le_q : y * z + z * x + x * y - 2 * x * y * z ≤ x * (1 - x) := by
        rw [h_expr]
        have : 1 - 2 * x < 0 := by linarith
        nlinarith [h₀.2.1, h₀.2.2]
      apply h_le_q.trans
      have h_id : 27 * (7 / 27 - x * (1 - x)) = 27 * (x - 1 / 2) ^ 2 + 1 / 4 := by ring
      have : 0 ≤ (x - 1 / 2) ^ 2 := by nlinarith
      linarith [h_id]

