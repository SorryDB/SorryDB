@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have : y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z := by
      rw [← h₁]; ring
    rw [this]
    have : 0 ≤ 1 - x ∧ 0 ≤ 1 - y ∧ 0 ≤ 1 - z := ⟨by linarith, by linarith, by linarith⟩
    positivity
  · by_cases h : z ≤ 1 / 2
    · have h_val : y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - 2 * z) + z * (1 - z) := by
        rw [← h₁]; ring
      rw [h_val]
      have hxy : x * y ≤ ((1 - z) / 2) ^ 2 := by
        have : x + y = 1 - z := by linarith
        nlinarith
      have h_le_f : x * y * (1 - 2 * z) + z * (1 - z) ≤ ((1 - z) / 2) ^ 2 * (1 - 2 * z) + z * (1 - z) := by
        nlinarith
      apply h_le_f.trans
      have : ((1 - z) / 2) ^ 2 * (1 - 2 * z) + z * (1 - z) = 7 / 27 - (3 * z - 1) ^ 2 * (6 * z + 1) / 108 := by ring
      rw [this]
      nlinarith
    · push_neg at h
      have : y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - 2 * z) + z * (1 - z) := by
        rw [← h₁]; ring
      rw [this]
      have : x * y * (1 - 2 * z) ≤ 0 := by
        have : x * y ≥ 0 := by positivity
        have : 1 - 2 * z < 0 := by linarith
        nlinarith
      have : z * (1 - z) ≤ 1 / 4 := by nlinarith
      linarith

