import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have : x ≤ 1 ∧ y ≤ 1 ∧ z ≤ 1 := by linarith [h₀.1, h₀.2.1, h₀.2.2, h₁]
    rw [show y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z by ring]
    positivity
  · let s := x + y
    have hs : s = 1 - z := by linarith
    have hf : y * z + z * x + x * y - 2 * x * y * z = s - s ^ 2 - x * y * (1 - 2 * s) := by rw [hs]; ring
    have hxy₀ : 0 ≤ x * y := by positivity
    have hxy₁ : x * y ≤ s ^ 2 / 4 := by
      have : 4 * (x * y) ≤ (x + y) ^ 2 := by nlinarith
      linarith
    rw [hf]
    if h2s : 1 - 2 * s ≥ 0 then
      have : s - s ^ 2 - x * y * (1 - 2 * s) ≤ s - s ^ 2 := by nlinarith
      have : s - s ^ 2 ≤ 1 / 4 := by nlinarith
      linarith [show (1 : ℝ) / 4 ≤ 7 / 27 by norm_num]
    else
      have : s - s ^ 2 - x * y * (1 - 2 * s) ≤ s ^ 3 / 2 - 5 * s ^ 2 / 4 + s := by
        have : 1 - 2 * s < 0 := by linarith
        nlinarith
      have : 7 / 27 - (s ^ 3 / 2 - 5 * s ^ 2 / 4 + s) = (3 * s - 2) ^ 2 * (7 - 6 * s) / 108 := by ring
      have : s ≤ 1 := by linarith [h₀.2.2, h₁]
      nlinarith

