open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have : y * z + z * x + x * y - 2 * x * y * z = x * y + z * (x * (1 - y) + y * (1 - x)) := by
      rw [← h₁]; ring
    have : x ≤ 1 ∧ y ≤ 1 := by constructor <;> linarith
    nlinarith
  · let s := x + y
    have hf : y * z + z * x + x * y - 2 * x * y * z = x * y * (2 * s - 1) + s * (1 - s) := by
      rw [← h₁]; ring
    have hs : 0 ≤ s ∧ s ≤ 1 := by constructor <;> linarith
    rw [hf]
    by_cases h : 2 * s - 1 ≤ 0
    · have : x * y * (2 * s - 1) ≤ 0 := by
        have : 0 ≤ x * y := by nlinarith
        nlinarith
      have : s * (1 - s) ≤ 1 / 4 := by
        have : 0 ≤ (s - 1 / 2)^2 := pow_two_nonneg (s - 1 / 2)
        linarith
      have : (1 : ℝ) / 4 ≤ 7 / 27 := by norm_num
      linarith
    · have hxy : x * y ≤ s^2 / 4 := by
        have : 0 ≤ (x - y)^2 := pow_two_nonneg (x - y)
        linarith
      have : x * y * (2 * s - 1) ≤ (s^2 / 4) * (2 * s - 1) := by
        have : 0 ≤ 2 * s - 1 := by linarith
        nlinarith
      have : (s^2 / 4) * (2 * s - 1) + s * (1 - s) ≤ 7 / 27 := by
        have : 7 / 27 - ((s^2 / 4) * (2 * s - 1) + s * (1 - s)) = (3 * s - 2)^2 * (7 - 6 * s) / 108 := by ring
        have : 0 ≤ (3 * s - 2)^2 := pow_two_nonneg (3 * s - 2)
        have : 0 ≤ 7 - 6 * s := by linarith
        nlinarith
      linarith

