import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  wlog hmin : x ≤ y ∧ x ≤ z using x y z
  · have h_symm := this y x z ⟨h₀.2.1, h₀.1, h₀.2.2⟩ (by linarith)
    have h_symm' := this z y x ⟨h₀.2.2, h₀.2.1, h₀.1⟩ (by linarith)
    have h_symm'' := this y z x ⟨h₀.2.1, h₀.2.2, h₀.1⟩ (by linarith)
    have h_symm''' := this x z y ⟨h₀.1, h₀.2.2, h₀.2.1⟩ (by linarith)
    have h_symm'''' := this z x y ⟨h₀.2.2, h₀.1, h₀.2.1⟩ (by linarith)
    rcases (⟨(by linarith), (by linarith)⟩ : (∃ a b c, (a ≤ b ∧ a ≤ c) ∧ (a, b, c).perm (x, y, z))) with ⟨a, b, c, hp, hperm⟩
    obtain ⟨hP1, hP2, hP3⟩ : 0 ≤ a ∧ 0 ≤ b ∧ 0 ≤ c := by
      rcases hperm with (_|_|_|_|_|_) <;> simp_all
    obtain hS : a + b + c = 1 := by
      rcases hperm with (_|_|_|_|_|_) <;> simp_all
    have h_final := this a b c ⟨hP1, hP2, hP3⟩ hS hp
    rcases hperm with (_|_|_|_|_|_) <;> simp_all [mul_assoc, add_assoc] <;> ring_nf <;> exact h_final
  have hx_max : x ≤ 1 / 3 := by linarith
  have hf : y * z + z * x + x * y - 2 * x * y * z = x * (1 - x) + y * z * (1 - 2 * x) := by
    rw [← h₁]; ring
  constructor
  · rw [hf]
    have h12x : 0 ≤ 1 - 2 * x := by linarith
    apply add_nonneg
    · apply mul_nonneg h₀.1; linarith
    · apply mul_nonneg (mul_nonneg h₀.2.1 h₀.2.2) h12x
  · rw [hf]
    have h12x : 0 ≤ 1 - 2 * x := by linarith
    have hyz : y * z ≤ (1 - x) ^ 2 / 4 := by
      have : 4 * y * z ≤ (y + z) ^ 2 := by nlinarith
      have : y + z = 1 - x := by linarith
      nlinarith
    have h_ub : x * (1 - x) + y * z * (1 - 2 * x) ≤ x * (1 - x) + (1 - x) ^ 2 / 4 * (1 - 2 * x) := by
      nlinarith
    apply h_ub.trans
    have h_poly : x * (1 - x) + (1 - x) ^ 2 / 4 * (1 - 2 * x) = (1 + x ^ 2 - 2 * x ^ 3) / 4 := by ring
    rw [h_poly]
    suffices 27 * (1 + x ^ 2 - 2 * x ^ 3) ≤ 28 by linarith
    suffices 0 ≤ 1 - 27 * x ^ 2 + 54 * x ^ 3 by linarith
    have h_factor : 1 - 27 * x ^ 2 + 54 * x ^ 3 = (3 * x - 1) ^ 2 * (6 * x + 1) := by ring
    rw [h_factor]
    nlinarith

