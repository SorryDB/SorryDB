import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · calc y * z + z * x + x * y - 2 * x * y * z
      _ = x * y * (1 - z) + y * z * (1 - x) + z * x * (1 - y) + x * y * z := by ring
      _ ≥ 0 := by
        repeat (apply add_nonneg)
        all_goals (apply mul_nonneg; (first | exact h₀.1 | exact h₀.2.1 | exact h₀.2.2 | linarith); linarith)
  · have h_main (a b c : ℝ) (ha : 0 ≤ a) (hb : 0 ≤ b) (hc : 0 ≤ c) (habc : a + b + c = 1) (hc_min : c ≤ 1 / 3) :
        a * b + b * c + c * a - 2 * a * b * c ≤ 7 / 27 := by
      have : a * b + b * c + c * a - 2 * a * b * c = c * (1 - c) + a * b * (1 - 2 * c) := by rw [← habc]; ring
      rw [this]
      have : a * b ≤ (1 - c) ^ 2 / 4 := by
        have : a + b = 1 - c := by linarith
        have : 0 ≤ (a - b) ^ 2 := pow_two_nonneg (a - b)
        linarith
      have : c * (1 - c) + a * b * (1 - 2 * c) ≤ c * (1 - c) + (1 - c) ^ 2 / 4 * (1 - 2 * c) := by
        apply add_le_add_left
        apply mul_le_mul_of_nonneg_right <;> linarith
      have : c * (1 - c) + (1 - c) ^ 2 / 4 * (1 - 2 * c) = 7 / 27 - (3 * c - 1) ^ 2 * (6 * c + 1) / 108 := by ring
      linarith [pow_two_nonneg (3 * c - 1)]
    have h_min : x ≤ 1 / 3 ∨ y ≤ 1 / 3 ∨ z ≤ 1 / 3 := by linarith
    have h_sym : y * z + z * x + x * y - 2 * x * y * z = x * y + y * z + z * x - 2 * x * y * z := by ring
    rw [h_sym]
    rcases h_min with hx | hy | hz
    · rw [add_comm (x * y), add_assoc, ← add_comm (x * z)]
      exact h_main y z x h₀.2.1 h₀.2.2 h₀.1 h₁ hx
    · rw [add_comm (x * y), add_assoc, ← add_comm (x * z)]
      exact h_main x z y h₀.1 h₀.2.2 h₀.2.1 h₁ hy
    · exact h_main x y z h₀.1 h₀.2.1 h₀.2.2 h₁ hz

