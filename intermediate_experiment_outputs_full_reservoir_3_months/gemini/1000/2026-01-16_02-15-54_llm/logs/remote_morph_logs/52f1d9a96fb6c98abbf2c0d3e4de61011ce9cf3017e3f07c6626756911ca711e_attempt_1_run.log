      rw [← h₁]; ring
    by_cases hx : x ≤ 1 / 2
    · have h_yz : y * z ≤ (1 - x)^2 / 4 := by
        have : y + z = 1 - x := by linarith
        nlinarith
      have : y * z + z * x + x * y - 2 * x * y * z ≤ (-2 * x^3 + x^2 + 1) / 4 := by
        rw [hf]
        nlinarith
      have : (-2 * x^3 + x^2 + 1) / 4 ≤ 7 / 27 := by
        have : 54 * x^3 - 27 * x^2 + 1 = (3 * x - 1)^2 * (6 * x + 1) := by ring
        nlinarith [h₀.1]
      linarith
    · have : y * z + z * x + x * y - 2 * x * y * z ≤ x * (1 - x) := by
        rw [hf]
        nlinarith [h₀.2.1, h₀.2.2]
      have : x * (1 - x) ≤ 1 / 4 := by nlinarith
      linarith

