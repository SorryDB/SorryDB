import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have : y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - x) + z * x * (1 - y) + x * y * (1 - z) + x * y * z := by ring
    rw [this]
    nlinarith [h₀.1, h₀.2.1, h₀.2.2, h₁]
  · have h_symm (a b c : ℝ) (ha₀ : 0 ≤ a ∧ 0 ≤ b ∧ 0 ≤ c) (ha₁ : a + b + c = 1) (ha₂ : a ≤ 1 / 2) :
        b * c + c * a + a * b - 2 * a * b * c ≤ 7 / 27 := by
      have h1 : b * c + c * a + a * b - 2 * a * b * c = a * (1 - a) + b * c * (1 - 2 * a) := by rw [← ha₁]; ring
      calc b * c + c * a + a * b - 2 * a * b * c
        _ = a * (1 - a) + b * c * (1 - 2 * a) := h1
        _ ≤ a * (1 - a) + (1 - a) ^ 2 / 4 * (1 - 2 * a) := by
          have : b + c = 1 - a := by linarith
          nlinarith [ha₀.1, ha₀.2.1, ha₀.2.2, ha₂]
        _ = 7 / 27 - (3 * a - 1) ^ 2 * (6 * a + 1) / 108 := by ring
        _ ≤ 7 / 27 := by nlinarith [ha₀.1]
    rcases (show x ≤ 1 / 2 ∨ y ≤ 1 / 2 ∨ z ≤ 1 / 2 by linarith) with h | h | h
    · exact h_symm x y z h₀ h₁ h
    · convert h_symm y x z ⟨h₀.2.1, h₀.1, h₀.2.2⟩ (by linarith) h using 1; ring
    · convert h_symm z x y ⟨h₀.2.2, h₀.1, h₀.2.1⟩ (by linarith) h using 1; ring

