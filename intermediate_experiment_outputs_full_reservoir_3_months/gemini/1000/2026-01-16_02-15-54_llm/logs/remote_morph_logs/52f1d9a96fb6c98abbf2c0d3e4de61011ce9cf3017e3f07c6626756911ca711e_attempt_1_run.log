import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $0\le yz+zx+xy-2xyz\le{7\over27}$, where $x,y$ and $z$ are non-negative real numbers satisfying $x+y+z=1$. -/
@[imo_problem_subject algebra]
theorem imo_1984_p1 (x y z : ℝ) (h₀ : 0 ≤ x ∧ 0 ≤ y ∧ 0 ≤ z) (h₁ : x + y + z = 1) :
    0 ≤ y * z + z * x + x * y - 2 * x * y * z ∧
      y * z + z * x + x * y - 2 * x * y * z ≤ (7 : ℝ) / (27 : ℝ) := by
  constructor
  · have : y * z + z * x + x * y - 2 * x * y * z = y * z * (1 - x) + z * x * (1 - y) + x * y := by ring
    rw [this]
    have : 1 - x = y + z := by linarith
    have : 1 - y = x + z := by linarith
    rw [this, this]
    repeat' apply add_nonneg
    all_goals first | apply mul_nonneg | assumption
  · have h_expr : y * z + z * x + x * y - 2 * x * y * z = x * y * (1 - 2 * z) + z * (1 - z) := by rw [← h₁]; ring
    by_cases h_z : z ≤ 1 / 2
    · have h_xy : x * y ≤ (1 - z) ^ 2 / 4 := by
        have : 4 * x * y ≤ (x + y) ^ 2 := by linarith [pow_two_nonneg (x - y)]
        linarith [h₁]
      have h_E : y * z + z * x + x * y - 2 * x * y * z ≤ (1 - z) ^ 2 / 4 * (1 - 2 * z) + z * (1 - z) := by
        rw [h_expr]; have : 0 ≤ 1 - 2 * z := by linarith; nlinarith
      have : (1 - z) ^ 2 / 4 * (1 - 2 * z) + z * (1 - z) = 7 / 27 - (3 * z - 1) ^ 2 * (6 * z + 1) / 108 := by ring
      have : 0 ≤ (3 * z - 1) ^ 2 := pow_two_nonneg (3 * z - 1)
      linarith [h_E, this, h₀.2.2]
    · have : x * y * (1 - 2 * z) ≤ 0 := by
        have : 0 ≤ x * y := mul_nonneg h₀.1 h₀.2.1
        have : 1 - 2 * z ≤ 0 := by linarith
        exact mul_nonpos_of_nonneg_of_nonpos this this
      have : z * (1 - z) ≤ 1 / 4 := by nlinarith
      linarith [h_expr]

