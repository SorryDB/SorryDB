lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  rw [arrayMeasure]
  have h1 : IndepFun (fun ω : (ℕ → I) × (ℕ → α → R) ↦ ω.1 (n + 1))
      (fun ω ↦ (fun i : Iic n ↦ ω.1 i)) (Measure.infinitePi (fun _ ↦ volume)).prod (Bandit.streamMeasure ν) :=
    indepFun_fst_prod (by fun_prop) (by fun_prop) (indepFun_proj_infinitePi _ (by grind))
  have h2 : IndepFun (fun ω : (ℕ → I) × (ℕ → α → R) ↦ ω.1 (n + 1)) (fun ω ↦ ω.2)
      (Measure.infinitePi (fun _ ↦ volume)).prod (Bandit.streamMeasure ν) :=
    (indepFun_fst_snd _ _).comp (by fun_prop) (by fun_prop)
  exact (h1.indepFun_prod_mk_right h2).comp (by fun_prop) (measurable_hist _ _)

end ArrayModel
```
