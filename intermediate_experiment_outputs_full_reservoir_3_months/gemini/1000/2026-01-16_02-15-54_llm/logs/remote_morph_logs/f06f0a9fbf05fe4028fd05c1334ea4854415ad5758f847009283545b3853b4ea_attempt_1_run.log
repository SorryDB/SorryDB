Released under Apache 2.0 license as described in the file LICENSE.
Authors: Shalev Wengrowsky
-/

import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_apply, PMF.uniformOfFintype_apply]
  simp only [DigitSeq, Digit, Fintype.card_fin, Fintype.card_pi, Nat.cast_pow, Nat.cast_ofNat]
  let p2 (d : Digit) := (to_nat_digit d) % 2 ≠ 0
  let p5 (d : Digit) := (to_nat_digit d) % 5 ≠ 0
  have h_good : ∀ s, is_good_seq s ↔ ¬(∀ i, p2 (s i)) ∧ ¬(∀ i, p5 (s i)) := by
    intro s; simp [is_good_seq, to_nat_digit, p2, p5, Nat.dvd_prime_mul Nat.prime_two Nat.prime_five (by norm_num), Nat.prime_two.dvd_prod_iff, Nat.prime_five.dvd_prod_iff, Nat.mod_eq_zero_iff_dvd]
  have h_card : (Finset.univ.filter is_good_seq).card = 9^n - (5^n + 8^n - 4^n) := by
    simp_rw [h_good, ← not_or]; rw [Finset.card_filter_not, Finset.card_union, Finset.card_pi, Finset.card_pi, Finset.card_pi]
    all_goals simp [Digit, p2, p5, to_nat_digit, Finset.card_fin, Finset.filter_univ, (by norm_num : (Finset.univ.filter fun (x : Fin 9) => (x.1 + 1) % 2 ≠ 0).card = 5), (by norm_num : (Finset.univ.filter fun (x : Fin 9) => (x.1 + 1) % 5 ≠ 0).card = 8), (by norm_num : (Finset.univ.filter fun (x : Fin 9) => (x.1 + 1) % 2 ≠ 0 ∧ (x.1 + 1) % 5 ≠ 0).card = 4)]
  rw [h_card]
  have h_le : 5^n + 8^n - 4^n ≤ 9^n := by
    induction' n with n _
    · norm_num
    · rw [Nat.pow_succ, Nat.pow_succ, Nat.pow_succ, Nat.pow_succ]; linarith [Nat.pow_le_pow_of_le_left (by norm_num : 8 ≤ 9) n]
  have h_le' : 4^n ≤ 5^n + 8^n := by linarith [Nat.pow_le_pow_of_le_left (by norm_num : 4 ≤ 5) n]
  simp only [Nat.cast_sub h_le, Nat.cast_sub h_le', Nat.cast_add, Nat.cast_pow, Nat.cast_ofNat]
  field_simp
