import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_apply, PMF.uniformOfFintype_apply,
      ENNReal.tsum_fintype, Finset.sum_const, nsmul_eq_mul,
      Fintype.card_fun, Fintype.card_fin, ENNReal.div_eq_inv_mul]
  simp only [good_seqs, is_good_seq, to_nat_digit, Digit]
  let s2 := {s : Fin n → Fin 9 | ∀ i, (s i).val + 1 ≠ 5}
  let s5 := {s : Fin n → Fin 9 | ∀ i, ((s i).val + 1) % 2 ≠ 0}
  let s25 := s2 ∩ s5
  have h2 : Fintype.card s2 = 8 ^ n := by simp [Fintype.card_fun, Fintype.card_fin]; rfl
  have h5 : Fintype.card s5 = 5 ^ n := by
    simp [Fintype.card_fun, Fintype.card_fin]
    have : (Finset.univ.filter fun (x : Fin 9) => (x.val + 1) % 2 ≠ 0).card = 5 := by norm_num
    rw [this]
  have h25 : Fintype.card s25 = 4 ^ n := by
    simp [s2, s5, s25, Fintype.card_fun, Fintype.card_fin]
    have : (Finset.univ.filter fun (x : Fin 9) => x.val + 1 ≠ 5 ∧ (x.val + 1) % 2 ≠ 0).card = 4 := by norm_num
    rw [this]
  have h_good : (Finset.univ.filter is_good_seq).card = 9 ^ n - (8 ^ n + 5 ^ n - 4 ^ n) := by
    simp only [is_good_seq]
    have h_not : ∀ s, ¬is_good_seq s ↔ s ∈ s2 ∨ s ∈ s5 := by
      intro s
      simp [is_good_seq, s2, s5, Nat.dvd_iff_prime_pow_dvd_factorial, Nat.prime_two, Nat.prime_five]
      rw [Nat.dvd_prod_iff 5, Nat.dvd_prod_iff 2]
      simp [to_nat_digit]
      intro; constructor <;> intro h <;> (try constructor) <;> (try assumption)
      · rintro ⟨i, hi⟩; exact h i hi
      · rintro ⟨i, hi⟩; exact h i hi
      · intro i; have := h i; norm_num at this; exact this
    have : (Finset.univ.filter is_good_seq).card = 9 ^ n - (Finset.univ.filter (fun s => ¬is_good_seq s)).card := by
      rw [Finset.card_filter_compl, Fintype.card_fun, Fintype.card_fin]
    rw [this, Finset.card_congr (fun s _ => s)]
    · rw [Finset.card_union, h2, h5, h25]
      · simp [s2, s5, s25, Set.Inter]
    · intros; simp [h_not]
    · intros; simp
    · intros; exists x
  rw [h_good]
  simp only [Nat.cast_add, Nat.cast_sub, ENNReal.ofReal_pow, ENNReal.ofReal_div_of_pos]
  repeat rw [ENNReal.sub_mul]
  rw [ENNReal.add_mul]
  simp only [ENNReal.mul_inv_cancel (by simp) (by simp), one_mul]
  congr 1 <;> rw [← ENNReal.div_eq_inv_mul, ENNReal.div_pow] <;> simp
