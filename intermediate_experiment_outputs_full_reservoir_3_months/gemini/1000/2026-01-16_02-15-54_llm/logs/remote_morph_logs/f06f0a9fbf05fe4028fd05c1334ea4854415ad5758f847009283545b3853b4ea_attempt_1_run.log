import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure (good_seqs) = solution n := by
  unfold solution
  rw [PMF.toOuterMeasure_apply, PMF.uniformOfFintype_apply, Finset.sum_const, nsmul_eq_mul]
  simp only [Finset.card_univ, Fintype.card_fun, Fintype.card_fin, Nat.cast_pow, Nat.cast_ofNat]
  let E5 := {s : DigitSeq n | ∀ a, to_nat_digit (s a) ≠ 5}
  let E2 := {s : DigitSeq n | ∀ a, (to_nat_digit (s a)) % 2 ≠ 0}
  have h_compl : (good_seqs : Set (DigitSeq n))ᶜ = E5 ∪ E2 := by
    ext s
    simp [good_seqs, is_good_seq, to_nat_digit, Nat.dvd_prod_iff, Nat.prime_five, Nat.prime_two, not_and_or]
    rfl
  have h_E5 : (Finset.univ.filter (· ∈ E5)).card = 8 ^ n := by
    simp only [E5, to_nat_digit, Finset.univ_filter_card_fn, Fintype.card_fun, Fintype.card_fin]
    congr; simp [Finset.filter_ne, Finset.card_fin]
  have h_E2 : (Finset.univ.filter (· ∈ E2)).card = 5 ^ n := by
    simp only [E2, to_nat_digit, Finset.univ_filter_card_fn, Fintype.card_fun, Fintype.card_fin]
    congr; simp [Finset.filter_def, Finset.card_fin, Finset.filter_fin_lt]
    native_decide
  have h_E52 : (Finset.univ.filter (fun s => s ∈ E5 ∧ s ∈ E2)).card = 4 ^ n := by
    simp only [E5, E2, to_nat_digit, Finset.univ_filter_card_fn, Fintype.card_fun, Fintype.card_fin]
    congr; simp [Finset.filter_def, Finset.card_fin, Finset.filter_fin_lt]
    native_decide
  have h_union : (Finset.univ.filter (· ∈ E5 ∪ E2)).card = 8 ^ n + 5 ^ n - 4 ^ n := by
    rw [Finset.filter_or, Finset.card_union_add_card_inter, h_E5, h_E2, h_E52, Nat.add_sub_cancel']
    apply Nat.pow_le_pow_of_le_left (by norm_num)
  have h_good : (Finset.univ.filter (· ∈ good_seqs)).card = 9 ^ n - (8 ^ n + 5 ^ n - 4 ^ n) := by
    rw [← Finset.card_compl, Finset.compl_filter, h_compl, h_union, Finset.card_univ, Fintype.card_fun, Fintype.card_fin]
  rw [h_good, Nat.cast_sub (Nat.le_of_lt (Nat.pow_lt_pow_of_lt_left (by norm_num) (Nat.zero_lt_of_lt (by norm_num)))),
    Nat.cast_sub (Nat.le_of_lt (Nat.pow_lt_pow_of_lt_left (by norm_num) (Nat.zero_lt_of_lt (by norm_num)))),
    ENNReal.sub_sub_add, div_eq_mul_inv, ENNReal.sub_mul, ENNReal.sub_mul, ENNReal.add_mul, ← Nat.cast_pow, ← Nat.cast_pow, ← Nat.cast_pow, ← Nat.cast_pow]
  · simp [div_eq_mul_inv]
  · exact Nat.pow_le_pow_of_le_left (by norm_num) n
  · exact Nat.pow_le_pow_of_le_left (by norm_num) n
