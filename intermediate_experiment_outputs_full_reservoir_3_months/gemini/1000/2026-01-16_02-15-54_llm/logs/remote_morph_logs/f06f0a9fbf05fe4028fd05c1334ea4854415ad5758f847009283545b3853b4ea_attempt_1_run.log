import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [PMF.toOuterMeasure_apply, unifDistN, PMF.uniformOfFintype_apply, Finset.sum_const, nsmul_eq_mul,
    Fintype.card_fun, Fintype.card_fin, Nat.cast_pow, Nat.cast_ofNat]
  let s2 (n : ℕ) := {s : DigitSeq n | ∀ i, to_nat_digit (s i) % 2 ≠ 0}
  let s5 (n : ℕ) := {s : DigitSeq n | ∀ i, to_nat_digit (s i) % 5 ≠ 0}
  have h2 : (s2 n).toFinset.card = 5 ^ n := by
    simp [s2, to_nat_digit, DigitSeq, Fintype.card_fun, Fintype.card_fin, (by norm_num : (Finset.univ.filter fun (x : Fin 9) => (x.val + 1) % 2 ≠ 0).card = 5)]
  have h5 : (s5 n).toFinset.card = 8 ^ n := by
    simp [s5, to_nat_digit, DigitSeq, Fintype.card_fun, Fintype.card_fin, (by norm_num : (Finset.univ.filter fun (x : Fin 9) => (x.val + 1) % 5 ≠ 0).card = 8)]
  have h25 : (s2 n ∩ s5 n).toFinset.card = 4 ^ n := by
    simp [s2, s5, to_nat_digit, DigitSeq, Fintype.card_fun, Fintype.card_fin, (by norm_num : (Finset.univ.filter fun (x : Fin 9) => (x.val + 1) % 2 ≠ 0 ∧ (x.val + 1) % 5 ≠ 0).card = 4)]
  have h_good : good_seqs = ((s2 n) ∪ (s5 n))ᶜ := by
    ext s; simp [good_seqs, s2, s5, is_good_seq, to_nat_digit, Nat.dvd_iff_prime_pow_dvd_atomics, Nat.prime_two, Nat.prime_five, Nat.Prime.dvd_finset_prod]
  have h_card : (good_seqs n).toFinset.card = 9 ^ n - (8 ^ n + 5 ^ n - 4 ^ n) := by
    rw [h_good, Set.toFinset_compl, Finset.card_compl, Fintype.card_fun, Fintype.card_fin, Set.toFinset_union, Finset.card_union_eq, h2, h5, h25]
    exacts [Finset.card_le_univ _, by rw [Set.toFinset_inter]; exact h25.symm.subst (Nat.pow_le_pow_of_le_left (by norm_num) _)]
  rw [h_card, solution]; simp only [ENNReal.div_pow, ENNReal.inv_pow, Nat.cast_pow, Nat.cast_ofNat]
  rw [ENNReal.sub_div, ENNReal.sub_div, ENNReal.add_div, ENNReal.div_self (pow_ne_zero _ (by norm_num)) (ENNReal.pow_ne_top (by norm_num))]
  all_goals norm_num

