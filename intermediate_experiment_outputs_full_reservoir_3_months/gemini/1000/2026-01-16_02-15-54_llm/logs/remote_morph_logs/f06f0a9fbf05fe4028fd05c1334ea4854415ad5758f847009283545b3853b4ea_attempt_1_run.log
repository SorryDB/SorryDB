  unfold solution unifDistN good_seqs is_good_seq to_nat_digit
  rw [PMF.toOuterMeasure_apply]
  simp only [PMF.uniformOfFintype_apply, Finset.sum_const, Finset.card_univ, Fintype.card_fun,
    Fintype.card_fin, Nat.cast_pow, Nat.cast_ofNat]
