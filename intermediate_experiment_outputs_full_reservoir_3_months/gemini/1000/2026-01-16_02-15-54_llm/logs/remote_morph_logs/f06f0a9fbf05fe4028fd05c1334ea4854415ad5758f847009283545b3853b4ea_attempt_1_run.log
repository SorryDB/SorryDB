import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [PMF.toOuterMeasure_apply_fintype, PMF.uniformOfFintype_apply]
  simp only [Set.indicator_apply, Set.mem_setOf_eq, Finset.sum_ite, Finset.filter_congr,
    Finset.card_univ, Fintype.card_pi, Fintype.card_fin, Nat.cast_pow, Nat.cast_ofNat]
  let s_all := Finset.univ (Fintype := Fintype.of (DigitSeq n))
  let s2 := s_all.filter (fun s ↦ ∀ i, to_nat_digit (s i) % 2 ≠ 0)
  let s5 := s_all.filter (fun s ↦ ∀ i, to_nat_digit (s i) % 5 ≠ 0)
  let s10c := s_all.filter (fun s ↦ ¬ is_good_seq s)
  have h_s10c : s10c = s2 ∪ s5 := by
    ext s; simp [is_good_seq, s10c, s2, s5, Nat.dvd_iff_mod_eq_zero, Nat.prime_two,
      Nat.prime_five, Nat.prod_mod_prime_eq_zero_iff, to_nat_digit]
  have h_card_s2 : s2.card = 5 ^ n := by
    simp [s2, to_nat_digit, Digit, Finset.card_univ, Fintype.card_pi, Fintype.card_fin,
      ←Fintype.card_pi, ←Fintype.card_fin 5]; apply Fintype.card_congr;
    exact Equiv.piCongrRight (fun _ ↦ (Equiv.ofCardEq (by simp)).symm)
  have h_card_s5 : s5.card = 8 ^ n := by
    simp [s5, to_nat_digit, Digit, Finset.card_univ, Fintype.card_pi, Fintype.card_fin,
      ←Fintype.card_pi, ←Fintype.card_fin 8]; apply Fintype.card_congr;
    exact Equiv.piCongrRight (fun _ ↦ (Equiv.ofCardEq (by simp)).symm)
  have h_card_s25 : (s2 ∩ s5).card = 4 ^ n := by
    simp [s2, s5, to_nat_digit, Digit, Finset.card_univ, Fintype.card_pi, Fintype.card_fin,
      ←Fintype.card_pi, ←Fintype.card_fin 4]; apply Fintype.card_congr;
    exact Equiv.piCongrRight (fun _ ↦ (Equiv.ofCardEq (by simp)).symm)
  have h_card_s10c : s10c.card = 5^n + 8^n - 4^n := by
    rw [h_s10c, Finset.card_union, h_card_s2, h_card_s5, h_card_s25]
  have h_card_good : (s_all.filter is_good_seq).card = 9^n - (5^n + 8^n - 4^n) := by
    rw [←Finset.card_compl, ←s10c]; simp [s10c, h_card_s10c, Fintype.card_pi, Fintype.card_fin]
  rw [h_card_good]; simp only [solution, Nat.cast_sub, Nat.cast_pow, Nat.cast_ofNat]
  field_simp [ENNReal.one_def]
  rw [Nat.cast_sub]
  · field_simp; ring
  · rw [h_s10c, ←Nat.cast_le (α := ℚ)]; repeat rw [Nat.cast_pow]
    exact_mod_cast (prob_le_one (s10c : Set (DigitSeq n)))
```
