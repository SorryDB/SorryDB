import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, PMF.toOuterMeasure_apply_fintype]
  simp only [unifDistN, DigitSeq, PMF.uniformOfFintype_apply, Fintype.card_fun, Fintype.card_fin, ENNReal.div_eq_inv_mul]
  let s2 : Set (DigitSeq n) := {s | 2 ∣ ∏ i, to_nat_digit (s i)}
  let s5 : Set (DigitSeq n) := {s | 5 ∣ ∏ i, to_nat_digit (s i)}
  have h_good : good_seqs = s2 ∩ s5 := by
    simp [good_seqs, is_good_seq, s2, s5, Nat.dvd_and_dvd_iff_lcm_dvd, Nat.lcm_two_five]
  have h_card_s2c : Fintype.card (s2ᶜ : Set (DigitSeq n)) = 5^n := by
    simp [s2, to_nat_digit, Nat.dvd_prod_iff, Nat.prime_two, Digit]
    exact Fintype.card_fun_of_fintype
  have h_card_s5c : Fintype.card (s5ᶜ : Set (DigitSeq n)) = 8^n := by
    simp [s5, to_nat_digit, Nat.dvd_prod_iff, Nat.prime_five, Digit]
    exact Fintype.card_fun_of_fintype
  have h_card_s2c_cap_s5c : Fintype.card (s2ᶜ ∩ s5ᶜ : Set (DigitSeq n)) = 4^n := by
    simp [s2, s5, to_nat_digit, Nat.dvd_prod_iff, Nat.prime_two, Nat.prime_five, Digit]
    exact Fintype.card_fun_of_fintype
  have h_card_union : Fintype.card (s2ᶜ ∪ s5ᶜ : Set (DigitSeq n)) = 5^n + 8^n - 4^n := by
    rw [Set.toFinset_card, Set.toFinset_union, Finset.card_union_eq, ← Set.toFinset_card, ← Set.toFinset_card, ← Set.toFinset_card, h_card_s2c, h_card_s5c, h_card_s2c_cap_s5c]
    rfl
  have h_card_good : Fintype.card (good_seqs : Set (DigitSeq n)) = 9^n - (5^n + 8^n - 4^n) := by
    rw [h_good, ← Set.compl_union, Set.card_compl, Fintype.card_fun, Fintype.card_fin, h_card_union]
  rw [h_card_good]
  simp only [Nat.cast_sub, Nat.cast_add, ENNReal.sub_div, ENNReal.add_div, ENNReal.mul_pow, ENNReal.inv_pow]
  congr <;> simp [ENNReal.div_eq_inv_mul]
