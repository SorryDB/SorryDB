import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [PMF.toOuterMeasure_apply_uniformOfFintype, solution]
  · simp only [DigitSeq, Digit, to_nat_digit, Fintype.card_fun, Fintype.card_fin, Nat.cast_pow,
      Nat.cast_ofNat, good_seqs, Set.mem_setOf_eq, is_good_seq, ENNReal.div_eq_inv_mul]
    let S := Fin n → Fin 9
    let A : Set S := {s | ∀ i, 2 ∤ (s i : ℕ) + 1}
    let B : Set S := {s | ∀ i, 5 ∤ (s i : ℕ) + 1}
    have h_compl : {s : S | 10 ∣ ∏ i, (s i : ℕ) + 1}ᶜ = A ∪ B := by
      ext s; simp [A, B, Nat.dvd_prime (show Nat.Prime 2 by norm_num),
        Nat.dvd_prime (show Nat.Prime 5 by norm_num), Nat.prod_dvd_iff]
    have h_card_A : Fintype.card A = 5^n := by
      simp [A, Fintype.card_fun, ←Set.pi_univ, Fintype.card_pi]; congr;
      exact (Finset.filter (fun d : Fin 9 => ¬ 2 ∣ (d : ℕ) + 1) Finset.univ).card_reg_congr (by norm_num)
    have h_card_B : Fintype.card B = 8^n := by
      simp [B, Fintype.card_fun, ←Set.pi_univ, Fintype.card_pi]; congr;
      exact (Finset.filter (fun d : Fin 9 => ¬ 5 ∣ (d : ℕ) + 1) Finset.univ).card_reg_congr (by norm_num)
    have h_card_AB : Fintype.card (A ∩ B) = 4^n := by
      simp [A, B, ←Set.setOf_and, Fintype.card_fun, ←Set.pi_univ, Fintype.card_pi]; congr;
      exact (Finset.filter (fun d : Fin 9 => ¬ 2 ∣ (d : ℕ) + 1 ∧ ¬ 5 ∣ (d : ℕ) + 1) Finset.univ).card_reg_congr (by norm_num)
    have h_card_union : Fintype.card (A ∪ B) = 5^n + 8^n - 4^n := by
      rw [Fintype.card_union_eq, h_card_A, h_card_B, h_card_AB]; exact Set.fintypeIntersection A B
    rw [←ENNReal.one_sub_inv_mul_rdist, h_compl, h_card_union]
    · simp only [Nat.cast_sub (show 4^n ≤ 5^n + 8^n by linarith), Nat.cast_add, ENNReal.inv_pow,
        ENNReal.mul_sub, ENNReal.mul_add, ←ENNReal.div_eq_inv_mul]
      repeat rw [←ENNReal.div_pow]
      simp only [Nat.cast_ofNat, one_mul, ENNReal.one_sub_inv_mul_rdist]
      ring_nf
    · simp
  · exact Set.fintypeSet _

end Usa1972P3
