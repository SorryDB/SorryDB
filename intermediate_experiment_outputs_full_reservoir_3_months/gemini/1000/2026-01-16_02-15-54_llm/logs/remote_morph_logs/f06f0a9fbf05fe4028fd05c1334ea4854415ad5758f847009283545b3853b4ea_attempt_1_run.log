import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [unifDistN, PMF.toOuterMeasure_apply, PMF.uniformOfFintype_apply, tsum_fintype,
    Fintype.card_pi, Fintype.card_fin, solution]
  simp only [good_seqs, is_good_seq, to_nat_digit, Nat.dvd_iff_mod_eq_zero,
    Nat.prod_mod 2, Nat.prod_mod 5, Finset.prod_eq_zero_iff, Nat.cast_pow, Nat.cast_ofNat]
  let s_all := (Finset.univ : Finset (DigitSeq n))
  let s_even := s_all.filter (∃ i, (s i : ℕ) + 1 % 2 = 0)
  let s_five := s_all.filter (∃ i, (s i : ℕ) + 1 % 5 = 0)
  let p_even := 1 - (5 / 9 : ENNReal) ^ n
  let p_five := 1 - (8 / 9 : ENNReal) ^ n
  let p_even_and_five := p_even + p_five - (1 - (4 / 9 : ENNReal) ^ n)
  have h_even : (s_all.filter (fun s => ∃ i, ((s i : ℕ) + 1) % 2 = 0)).card = 9^n - 5^n := by
    rw [←Finset.card_compl_filter, Fintype.card_pi, Fintype.card_fin, Finset.card_pi]
    simp [Finset.card_univ, Fintype.card_fin, Finset.filter_univ, Digit]; rfl
  have h_five : (s_all.filter (fun s => ∃ i, ((s i : ℕ) + 1) % 5 = 0)).card = 9^n - 8^n := by
    rw [←Finset.card_compl_filter, Fintype.card_pi, Fintype.card_fin, Finset.card_pi]
    simp [Finset.card_univ, Fintype.card_fin, Finset.filter_univ, Digit]; rfl
  have h_both : (s_all.filter (fun s => (∀ i, ((s i : ℕ) + 1) % 2 ≠ 0) ∨ (∀ i, ((s i : ℕ) + 1) % 5 ≠ 0))).card = 5^n + 8^n - 4^n := by
    rw [Finset.filter_or, Finset.card_union_add_card_inter]
    simp only [Digit, Fintype.card_pi, Fintype.card_fin, Finset.card_pi, Finset.filter_univ,
      Finset.card_univ, Finset.filter_filter, ←and_assoc, Finset.card_pi]
    rfl
  have h_good : (s_all.filter (fun s => (∃ i, ((s i : ℕ) + 1) % 2 = 0) ∧ (∃ i, ((s i : ℕ) + 1) % 5 = 0))).card = 9^n - (5^n + 8^n - 4^n) := by
    rw [←Finset.card_compl_filter]
    simp only [not_and_or, not_exists, Ne.def, not_not, h_both, Fintype.card_pi, Fintype.card_fin]
  rw [h_good, Nat.cast_sub (Nat.le_of_lt (Nat.pow_lt_pow_left (by norm_num) (by simp)))]
  simp only [Nat.cast_sub, Nat.cast_add, Nat.cast_pow, Nat.cast_ofNat, ENNReal.sub_add_eq_sub_sub]
  · field_simp
  · exact Nat.le_trans (Nat.pow_le_pow_left (by norm_num) n) (Nat.le_add_left _ _)
