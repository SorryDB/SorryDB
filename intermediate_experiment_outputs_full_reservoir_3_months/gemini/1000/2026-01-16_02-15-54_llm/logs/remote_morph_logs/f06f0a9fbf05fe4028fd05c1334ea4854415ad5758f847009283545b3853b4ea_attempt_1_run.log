import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [PMF.toOuterMeasure_apply_fintype, PMF.uniformOfFintype_apply]
  simp only [good_seqs, is_good_seq, DigitSeq, Fintype.card_fin, Fintype.card_fun,
    Finset.sum_const, nsmul_eq_mul, ENNReal.mul_inv_eq_div, solution, to_nat_digit]
  let s2 := {s : Fin n → Fin 9 | ¬ 2 ∣ ∏ i, (s i + 1)}
  let s5 := {s : Fin n → Fin 9 | ¬ 5 ∣ ∏ i, (s i + 1)}
  have h10 : ∀ x : ℕ, 10 ∣ x ↔ 2 ∣ x ∧ 5 ∣ x := fun x ↦ Nat.dvd_and_dvd_iff_lcm_dvd Nat.prime_two Nat.prime_five |>.symm.trans (by simp [Nat.lcm_two_five])
  have h_comp : {s | 10 ∣ ∏ i, (s i + 1)}ᶜ = s2 ∪ s5 := by ext s; simp [s2, s5, h10, to_nat_digit]
  have h_card : (Finset.univ.filter is_good_seq).card = 9^n - (Finset.univ.filter (fun s ↦ s ∈ s2 ∪ s5)).card := by
    rw [Finset.card_compl_filter, Fintype.card_fun, Fintype.card_fin]; rfl
  rw [h_card, ENNReal.sub_div, ENNReal.div_self (by simp) (by simp), ENNReal.div_eq_inv_mul, ← ENNReal.pow_div, ← ENNReal.pow_div, ← ENNReal.pow_div]
  have h_union : (Finset.univ.filter (fun s ↦ s ∈ s2 ∪ s5)).card = (Finset.univ.filter (· ∈ s2)).card + (Finset.univ.filter (· ∈ s5)).card - (Finset.univ.filter (fun s ↦ s ∈ s2 ∧ s ∈ s5)).card := by
    rw [Finset.filter_or, Finset.card_union, Finset.filter_and]; rfl
  have h_s2 : (Finset.univ.filter (· ∈ s2)).card = 5^n := by
    simp only [s2, ← Nat.not_even_iff_odd, Nat.even_prod, Finset.mem_univ, true_and, not_exists, Digit]
    rw [← Fintype.card_fun, Fintype.card_fin_filter]; simp [to_nat_digit]; decide
  have h_s5 : (Finset.univ.filter (· ∈ s5)).card = 8^n := by
    simp only [s5, Nat.prime_five.dvd_prod, Finset.mem_univ, true_and, not_exists, Digit]
    rw [← Fintype.card_fun, Fintype.card_fin_filter]; simp [to_nat_digit]; decide
  have h_s25 : (Finset.univ.filter (fun s ↦ s ∈ s2 ∧ s ∈ s5)).card = 4^n := by
    simp only [s2, s5, ← Nat.not_even_iff_odd, Nat.even_prod, Nat.prime_five.dvd_prod, Finset.mem_univ, true_and, not_exists, Digit]
    rw [← Fintype.card_fun, Fintype.card_fin_filter]; simp [to_nat_digit]; decide
  rw [h_union, h_s2, h_s5, h_s25]
  norm_cast; simp only [ENNReal.div_eq_inv_mul, ← ENNReal.pow_div]; rw [ENNReal.sub_sub_add]

