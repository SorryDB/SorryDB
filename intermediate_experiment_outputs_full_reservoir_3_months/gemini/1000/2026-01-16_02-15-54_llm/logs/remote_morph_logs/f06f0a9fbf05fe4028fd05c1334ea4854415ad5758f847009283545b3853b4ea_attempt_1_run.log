import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  unfold solution good_seqs unifDistN
  rw [PMF.toOuterMeasure_apply]
  simp only [PMF.uniformOfFintype_apply, Finset.sum_const, Set.mem_setOf_eq, DigitSeq, Digit, Fintype.card_fun,
    Fintype.card_fin, Nat.cast_pow, Nat.cast_ofNat, one_div, ENNReal.inv_pow]
  let S := Finset.univ (α := Fin n → Fin 9)
  let A := S.filter (fun s ↦ ∀ i, to_nat_digit (s i) % 2 ≠ 0)
  let B := S.filter (fun s ↦ ∀ i, to_nat_digit (s i) % 5 ≠ 0)
  have hA : A.card = 5^n := by simp [A, to_nat_digit, Finset.card_univ_filter_fin_ra_pow, (by norm_num : (Finset.univ : Finset (Fin 9)).filter (fun d ↦ (d.1 + 1) % 2 ≠ 0).card = 5)]
  have hB : B.card = 8^n := by simp [B, to_nat_digit, Finset.card_univ_filter_fin_ra_pow, (by norm_num : (Finset.univ : Finset (Fin 9)).filter (fun d ↦ (d.1 + 1) % 5 ≠ 0).card = 8)]
  have hAB : (A ∩ B).card = 4^n := by simp [A, B, to_nat_digit, ← Finset.filter_and, Finset.card_univ_filter_fin_ra_pow, (by norm_num : (Finset.univ : Finset (Fin 9)).filter (fun d ↦ (d.1 + 1) % 2 ≠ 0 ∧ (d.1 + 1) % 5 ≠ 0).card = 4)]
  have h_compl : (S.filter is_good_seq).card = 9^n - (A ∪ B).card := by
    rw [Finset.card_sdiff (Finset.subset_univ _), Finset.card_univ, Fintype.card_fun, Fintype.card_fin]
    congr; ext s; simp [is_good_seq, to_nat_digit, Nat.dvd_and_prime_refl_iff, A, B, Nat.prime_two, Nat.prime_five]
  rw [h_compl, Finset.card_union_eq A B, hA, hB, hAB, Nat.cast_sub (by
    have : (A ∪ B).card ≤ 9^n := Finset.card_le_univ (A ∪ B)
    rw [Finset.card_univ, Fintype.card_fun, Fintype.card_fin] at this
    exact this)]
  simp only [Nat.cast_add, Nat.cast_sub (Nat.le_add_left 4^n 5^n), Nat.cast_pow, Nat.cast_ofNat]
  field_simp [ENNReal.pow_neq_zero]
  cases n with
  | zero => simp
  | succ n =>
    have h1 : 5^(n+1) + 8^(n+1) ≥ 4^(n+1) := by linarith [Nat.pow_le_pow_of_le_left (by norm_num : 4 ≤ 5) (n+1)]
    have h2 : 9^(n+1) + 4^(n+1) ≥ 8^(n+1) + 5^(n+1) := by
      induction n with
      | zero => norm_num
      | succ n ih =>
        have : 9^(n+2) + 4^(n+2) = 9*9^(n+1) + 4*4^(n+1) := by ring
        have : 8^(n+2) + 5^(n+2) = 8*8^(n+1) + 5*5^(n+1) := by ring
        nlinarith [Nat.pow_le_pow_of_le_left (by norm_num : 8 ≤ 9) (n+1), Nat.pow_le_pow_of_le_left (by norm_num : 5 ≤ 9) (n+1)]
    rw [ENNReal.sub_add_eq_add_sub, ENNReal.sub_sub]
    repeat' rw [ENNReal.sub_eq_of_add_eq (rfl : _ = _)]
    repeat' rw [← Nat.cast_pow, ← Nat.cast_add]
    rw [Nat.cast_sub h1, ← Nat.cast_sub h2]
    repeat' rw [Nat.cast_pow, Nat.cast_add, Nat.cast_sub h1]
    ring
