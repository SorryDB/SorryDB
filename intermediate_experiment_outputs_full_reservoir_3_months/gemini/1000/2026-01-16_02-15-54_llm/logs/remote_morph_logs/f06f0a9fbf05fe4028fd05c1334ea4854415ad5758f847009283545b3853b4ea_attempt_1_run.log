import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [unifDistN, PMF.toOuterMeasure_apply, PMF.uniformOfFintype_apply]
  simp [solution, good_seqs, is_good_seq, to_nat_digit, DigitSeq, Fintype.card_fun, Fintype.card_fin]
  simp_rw [← Finset.mem_univ, ← Finset.sum_filter, Finset.sum_const, nsmul_eq_mul, mul_one]
  let s1 := (Finset.univ : Finset (DigitSeq n)).filter (fun s => ∀ i, (s i : ℕ) + 1 ≠ 5)
  let s2 := (Finset.univ : Finset (DigitSeq n)).filter (fun s => ∀ i, ((s i : ℕ) + 1) % 2 ≠ 0)
  have h_not : (Finset.univ.filter fun s ↦ ¬is_good_seq s) = s1 ∪ s2 := by
    ext s; simp [is_good_seq, s1, s2, Nat.dvd_and_dvd_iff_lcm_dvd, Nat.lcm_two_five, Nat.dvd_prod, Nat.prime_two, Nat.prime_five]
    exact ⟨fun h ↦ Nat.eq_of_prime_dvd Nat.prime_five (by norm_num) h, by rintro rfl; norm_num⟩
  have h1 : s1.card = 8 ^ n := by simp [s1, Finset.card_univ_pi, Finset.card_filter, Finset.card_fin]; norm_num
  have h2 : s2.card = 5 ^ n := by simp [s2, Finset.card_univ_pi, Finset.card_filter, Finset.card_fin]; norm_num
  have h12 : (s1 ∩ s2).card = 4 ^ n := by simp [s1, s2, ← Finset.filter_and, Finset.card_univ_pi, Finset.card_filter, Finset.card_fin]; norm_num
  have : (Finset.univ.filter is_good_seq).card + (s1 ∪ s2).card = 9 ^ n := by
    rw [← Finset.card_union_of_disjoint, Finset.filter_union_filter_not_eq]; simp [h_not, Finset.disjoint_filter, is_good_seq]
  rw [← ENNReal.one_sub_div (by norm_num), ← this, Nat.cast_add, ENNReal.add_div, ENNReal.add_sub_cancel_left, Finset.card_union, h1, h2, h12, Nat.cast_sub (Nat.pow_le_pow_of_le_left (by norm_num) _), ENNReal.sub_div, ENNReal.add_div]
  norm_num
