import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  unfold solution unifDistN good_seqs is_good_seq to_nat_digit
  rw [PMF.toOuterMeasure_apply, PMF.uniformOfFintype_apply, ENNReal.tsum_fintype,
    Finset.sum_const, Finset.card_univ, nsmul_eq_mul, ← ENNReal.div_eq_inv_mul]
  simp only [Fintype.card_fun, Fintype.card_fin, Nat.cast_pow, Nat.cast_ofNat]
  have h10 (m : ℕ) : 10 ∣ m ↔ 2 ∣ m ∧ 5 ∣ m := by
    rw [Nat.lcm_two_five, Nat.lcm_dvd_iff]
  have h2 (s : DigitSeq n) : 2 ∣ ∏ a, (s a + 1) ↔ ∃ a, 2 ∣ (s a + 1) := Nat.Prime.dvd_prod_iff Nat.prime_two
  have h5 (s : DigitSeq n) : 5 ∣ ∏ a, (s a + 1) ↔ ∃ a, 5 ∣ (s a + 1) := Nat.Prime.dvd_prod_iff (by norm_num)
  let S := Finset.univ (Fintype := (Fintype.of (DigitSeq n)))
  let A := S.filter (fun s ↦ ∀ a, ¬ 2 ∣ (s a + 1))
  let B := S.filter (fun s ↦ ∀ a, ¬ 5 ∣ (s a + 1))
  have card_A : A.card = 5 ^ n := by
    simp [A, Finset.filter_univ, Fintype.card_fun, Fintype.card_fin, ← Finset.univ_product_univ, ← Finset.card_univ]
    rw [← Fintype.card_fun]; congr; apply Fintype.card_congr
    exact ⟨fun ⟨x, hx⟩ ↦ ⟨x, by revert hx; norm_num; intro h; contrapose h; norm_num; cases x using Fin.cases <;> norm_num⟩,
           fun ⟨x, hx⟩ ↦ ⟨x, by revert hx; norm_num; intro h; contrapose h; norm_num; cases x using Fin.cases <;> norm_num⟩,
           by intro; simp, by intro; simp⟩
  have card_B : B.card = 8 ^ n := by
    simp [B, Finset.filter_univ, Fintype.card_fun, Fintype.card_fin]
    rw [← Fintype.card_fun]; congr; apply Fintype.card_congr
    exact ⟨fun ⟨x, hx⟩ ↦ ⟨x, by revert hx; norm_num; intro h; exact (Nat.dvd_prime (by norm_num)).1 h⟩,
           fun ⟨x, hx⟩ ↦ ⟨x, by revert hx; norm_num; intro h; exact (Nat.dvd_prime (by norm_num)).1 h⟩,
           by intro; simp, by intro; simp⟩
  have card_AB : (A ∩ B).card = 4 ^ n := by
    simp [A, B, Finset.filter_univ, Fintype.card_fun, Fintype.card_fin]
    rw [← Fintype.card_fun]; congr; apply Fintype.card_congr
    exact ⟨fun ⟨x, hx⟩ ↦ ⟨x, by revert hx; norm_num; cases x using Fin.cases <;> norm_num⟩,
           fun ⟨x, hx⟩ ↦ ⟨x, by revert hx; norm_num; cases x using Fin.cases <;> norm_num⟩,
           by intro; simp, by intro; simp⟩
  have h_card : (S.filter (fun s ↦ 10 ∣ ∏ a, (s a + 1))).card = 9 ^ n - (5 ^ n + 8 ^ n - 4 ^ n) := by
    simp_rw [h10, h2, h5, ← not_or, ← not_forall, ← not_forall, ← Finset.filter_not, ← Finset.filter_or]
    rw [Finset.card_compl_eq_card_univ_sub, Finset.card_union, card_A, card_B, card_AB]; rfl
  rw [h_card, Nat.cast_sub (by rcases n with rfl | n <;> norm_num; apply Nat.pow_le_pow_of_le_left; norm_num)]
  rw [Nat.cast_sub (by rcases n with rfl | n <;> norm_num; apply Nat.add_le_of_le_sub; norm_num)]
  field_simp; ring_nf
