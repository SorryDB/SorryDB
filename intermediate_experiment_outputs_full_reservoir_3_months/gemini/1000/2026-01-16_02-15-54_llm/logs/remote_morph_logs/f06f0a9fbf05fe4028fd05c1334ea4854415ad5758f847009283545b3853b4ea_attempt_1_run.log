Released under Apache 2.0 license as described in the file LICENSE.
Authors: Shalev Wengrowsky
-/

import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [unifDistN, PMF.toOuterMeasure_uniformOfFintype, solution]
  simp only [DigitSeq, Digit, Nat.card_eq_fintype_card, Fintype.card_fun, Fintype.card_fin,
    ENNReal.ofNat_pow, ENNReal.ofNat_div_ofNat]
  have h_card {P : Digit → Prop} [DecidablePred P] :
    (Finset.univ.filter fun s : DigitSeq n ↦ ∀ i, P (s i)).card = (Finset.univ.filter P).card ^ n := by
    rw [← Fintype.card_subtype, ← Fintype.card_fun, Fintype.card_congr (Equiv.piSubtype (fun _ ↦ Digit) (fun _ ↦ P)).symm]
    simp [Fintype.card_subtype, card_filter]
  have h_bad : (Finset.univ.filter fun s ↦ ¬ is_good_seq s) =
      (Finset.univ.filter fun s ↦ ∀ a, ¬ 2 ∣ to_nat_digit (s a)) ∪
      (Finset.univ.filter fun s ↦ ∀ a, ¬ 5 ∣ to_nat_digit (s a)) := by
    ext s; simp [is_good_seq, to_nat_digit, Nat.mul_dvd_iff_dvd_and_dvd_of_coprime (by norm_num),
      Nat.Prime.dvd_prod_iff (show Nat.Prime 2 by norm_num), Nat.Prime.dvd_prod_iff (show Nat.Prime 5 by norm_num),
      not_and_or, not_exists, not_not]
  have h_total : (Finset.univ.filter is_good_seq).card + (Finset.univ.filter fun s ↦ ¬ is_good_seq s).card = 9^n := by
    rw [Finset.card_add_card_compl, Fintype.card_fun, Fintype.card_fin]; simp
  rw [← ENNReal.ofNat_inj, ENNReal.ofNat_sub (h_total ▸ Nat.le_add_left _ _), ← h_total, Nat.add_sub_cancel]
  rw [ENNReal.sub_div, ENNReal.div_self (by norm_num), h_bad, Finset.card_union, h_card, h_card,
    ← Finset.filter_and, h_card]
  · simp only [ENNReal.ofNat_sub (Nat.pow_le_pow_left (by norm_num) n), ENNReal.ofNat_add,
      ENNReal.ofNat_pow, ENNReal.sub_div, ENNReal.add_div, ← forall_and]
    norm_num [to_nat_digit, Fin.forall_fin_succ]
  · ext s; simp [← forall_and]

