import Mathlib.Probability.Distributions.Uniform

import ProblemExtraction

problem_file { tags := [.Combinatorics, .NumberTheory] }

/-!
# USA Mathematical Olympiad 1972, Problem 3

n digits, none of them 0, are randomly (and independently) generated,
find the probability that their product is divisible by 10.
-/

namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 - (8 / 9) ^ n - (5 / 9) ^ n + (4 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [PMF.toOuterMeasure_apply, PMF.uniformOfFintype_apply, ENNReal.tsum_const_fintype, solution]
  simp only [good_seqs, is_good_seq, Nat.prime_two.dvd_prod_iff, Nat.prime_five.dvd_prod_iff,
    Finset.mem_univ, true_and, DigitSeq, Digit, Fintype.card_fin, Fintype.card_fun]
  let s2 := {s : Fin n → Fin 9 | ∀ i, ¬ 2 ∣ to_nat_digit (s i)}
  let s5 := {s : Fin n → Fin 9 | ∀ i, ¬ 5 ∣ to_nat_digit (s i)}
  have h_compl : {s | (∃ i, 2 ∣ to_nat_digit (s i)) ∧ (∃ i, 5 ∣ to_nat_digit (s i))}ᶜ = s2 ∪ s5 := by
    ext s; simp [s2, s5]
  have h_card : (Finset.univ.filter (fun s ↦ (∃ i, 2 ∣ to_nat_digit (s i)) ∧ (∃ i, 5 ∣ to_nat_digit (s i)))).card = 9^n - (5^n + 8^n - 4^n) := by
    rw [← Finset.card_compl, h_compl]
    have h1 : Fintype.card s2 = 5^n := by simp [s2, to_nat_digit, ← Fintype.card_fun, Fintype.card_subtype, Finset.card_univ, (by dec_trivial : (Finset.univ.filter fun (d : Fin 9) ↦ ¬2 ∣ d.val + 1).card = 5)]
    have h2 : Fintype.card s5 = 8^n := by simp [s5, to_nat_digit, ← Fintype.card_fun, Fintype.card_subtype, Finset.card_univ, (by dec_trivial : (Finset.univ.filter fun (d : Fin 9) ↦ ¬5 ∣ d.val + 1).card = 8)]
    have h3 : Fintype.card (s2 ∩ s5) = 4^n := by simp [s2, s5, to_nat_digit, ← Fintype.card_fun, Fintype.card_subtype, Finset.card_univ, (by dec_trivial : (Finset.univ.filter fun (d : Fin 9) ↦ ¬2 ∣ d.val + 1 ∧ ¬5 ∣ d.val + 1).card = 4)]
    simp [Set.toFinset_union, Finset.card_union, h1, h2, h3, Set.toFinset_setOf, Fintype.card_ofFinset]
  rw [h_card]; simp only [Nat.cast_sub, Nat.cast_add, Nat.cast_pow, Nat.cast_ofNat]
  have h_bound : 5^n + 8^n ≥ 4^n := Nat.le_add_left _ _
  have h_bound2 : 9^n ≥ 5^n + 8^n - 4^n := by induction n <;> [dec_trivial; (rename_i n ih; apply Nat.le_of_mul_le_mul_right (a := 9); apply ih.trans; dec_trivial)]
  rw [ENNReal.ofNat_sub h_bound2, ENNReal.ofNat_sub h_bound, ENNReal.ofNat_add]
  repeat rw [ENNReal.sub_div, ENNReal.add_div, ← ENNReal.pow_div]; norm_num
