  let B : Finset (DigitSeq n) := Finset.univ.filter (λ s => ∀ i, (s i + 1 : ℕ) ≠ 5)
  have hA : (A.card : ENNReal) / 9 ^ n = (5 / 9) ^ n := by
    simp [A, Fintype.card_fun, Finset.card_univ, ← Fintype.piFinset_univ (λ _ => (Finset.univ.filter (λ d : Digit => (d + 1 : ℕ) % 2 ≠ 0))),
      Finset.card_piFinset, Finset.filter_fin_one, Finset.card_filter, Nat.cast_pow]
    rfl
  have hB : (B.card : ENNReal) / 9 ^ n = (8 / 9) ^ n := by
    simp [B, Fintype.card_fun, Finset.card_univ, ← Fintype.piFinset_univ (λ _ => (Finset.univ.filter (λ d : Digit => (d + 1 : ℕ) ≠ 5))),
      Finset.card_piFinset, Finset.filter_fin_one, Finset.card_filter, Nat.cast_pow]
    rfl
  have hAB : ((A ∩ B).card : ENNReal) / 9 ^ n = (4 / 9) ^ n := by
    simp [A, B, Fintype.card_fun, Finset.card_univ, ← Fintype.piFinset_univ (λ _ => (Finset.univ.filter (λ d : Digit => (d + 1 : ℕ) % 2 ≠ 0 ∧ (d + 1 : ℕ) ≠ 5))),
      Finset.card_piFinset, Finset.filter_fin_one, Finset.card_filter, Nat.cast_pow]
    rfl
  have h_compl : (Finset.univ.filter (λ s => ¬ is_good_seq s)) = A ∪ B := by
    ext s; simp [is_good_seq, A, B, to_nat_digit, Nat.dvd_prime Nat.prime_two, Nat.dvd_prime Nat.prime_five]
    rw [← Nat.prime_two.dvd_prod_iff, ← Nat.prime_five.dvd_prod_iff]
    simp [Nat.not_even_iff_not_two_dvd, Nat.isUnit_iff]
    aesop
  have h_union : ((A ∪ B).card : ENNReal) / 9 ^ n = (5 / 9) ^ n + (8 / 9) ^ n - (4 / 9) ^ n := by
    rw [Finset.card_union_add_card_inter, Nat.cast_add, ← hA, ← hB, ← hAB]
    field_simp; ring
  rw [← Finset.card_univ_diff_filter, Nat.cast_sub (Finset.filter_subset _ _),
    ENNReal.sub_div, h_compl, h_union, Nat.cast_pow, Nat.cast_ofNat, ENNReal.div_self]
