          have : Nat.card E = (Nat.card K) ^ (FiniteDimensional.finrank K E) := FiniteField.card_eq_pow_finrank K E
          rw [this, Nat.cast_sub hn, Nat.cast_pow, ← Nat.cast_pow, ← FiniteField.card_eq_pow_ringChar,
            CharP.cast_eq_zero K (ringChar K), zero_pow (Nat.pos_of_lt (FiniteField.card_pos E)).ne', zero_sub]
          exact neg_ne_zero.mpr one_ne_zero
        exact Algebra.subset_adjoin ⟨⟨n, hn, this⟩, by
          simpa using congr_arg Units.val (FiniteField.zpow_card_sub_one_eq_one (Units.mk0 _ hx'))⟩
