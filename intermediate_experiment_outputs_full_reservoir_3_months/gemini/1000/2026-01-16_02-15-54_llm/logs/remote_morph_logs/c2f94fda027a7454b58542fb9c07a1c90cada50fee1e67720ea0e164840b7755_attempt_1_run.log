      have hq' : (q : K) = 0 := by
        rw [← Nat.card_congr (Equiv.refl K), FiniteField.card_eq_pow_ringChar]
        simp only [Nat.cast_pow, CharP.cast_eq_zero, zero_pow (ringChar.pos K _).ne',
          ringChar.pos_iff, field_char_ne_zero K]
      rw [Nat.cast_sub (Nat.pow_pos (FiniteField.card_pos K) n), Nat.cast_pow, hq',
        zero_pow (Nat.pos_of_gt (hf.degree_le_natDegree : 0 < n)).ne', zero_sub]
      exact neg_ne_zero.mpr one_ne_zero
    obtain ⟨ζ, hζ⟩ := h.exists_root_of_unity ⟨q ^ n - 1, Nat.pos_of_ne_zero (fun h ↦ hq (h ▸ rfl)), hq⟩
