Released under Apache 2.0 license as described in the file LICENSE.
Authors: Jz Pan
-/
module

public import Mathlib.NumberTheory.Cyclotomic.Basic

@[expose] public section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro h
    haveI := h.isAlgebraic K L
    refine .of_isAlgebraic L ‹_› ⟨fun f hf ↦ ?_⟩
    letI : IsAlgebraicallyClosed (AlgebraicClosure L) := inferInstance
    letI : IsAlgClosure L (AlgebraicClosure L) := AlgebraicClosure.isAlgClosure L
    letI : IsAlgClosure K (AlgebraicClosure L) := .of_algebraic_extension K L (AlgebraicClosure L)
    have : IsAlgebraicallyClosed L := by
      rw [isAlgebraicallyClosed_iff_forall_finite_extension]
      intro E _ _ _
      letI := FiniteField.isCyclotomicExtension_nth_roots_unity K E
      have : E ≤ (adjoin K {ζ : L | ∃ n, (n : K) ≠ 0 ∧ IsPrimitiveRoot ζ n}).toSubfield := by
        rw [h.adjoin_roots]; exact le_top
      exact this
    exact IsAlgebraicallyClosed.splits f
  · intro h
    constructor
    · intro n hn; exact h.is_algebraically_closed.exists_primitive_root hn
    · rw [eq_top_iff]; intro x _
      rcases eq_or_ne x 0 with rfl | hx
      · exact Subalgebra.zero_mem _
      · obtain ⟨n, hn, hnx⟩ := h.algebraic.isUnit_root_unity x hx
        obtain ⟨m, hm, hmx⟩ := IsPrimitiveRoot.exists_isPrimitiveRoot n hnx
        exact subset_adjoin ⟨m, ⟨by rw [← natCast_ne_zero, ← hm.done]; exact hm.ne_zero, hmx⟩⟩

