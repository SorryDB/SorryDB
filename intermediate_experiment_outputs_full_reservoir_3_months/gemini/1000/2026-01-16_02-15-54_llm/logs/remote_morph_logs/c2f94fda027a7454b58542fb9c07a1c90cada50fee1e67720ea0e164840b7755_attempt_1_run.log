/-
Copyright (c) 2025 Jz Pan. All rights reserved.
Released under Apache 2.0 license as described in the file LICENSE.
Authors: Jz Pan
-/
module

public import Mathlib.NumberTheory.Cyclotomic.Basic

@[expose] public section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro
    haveI := IsCyclotomicExtension.algebraic {n | (n : K) ≠ 0} K L
    refine ⟨‹_›, isAlgClosed_iff_forall_has_root.mpr fun f hf ↦ ?_⟩
    letI := FiniteField.finite_splittingField f
    let n := Fintype.card f.SplittingField - 1
    have hn : (n : K) ≠ 0 := by
      have h := FiniteField.cast_card_eq_zero f.SplittingField
      intro h0; rw [h0] at h; exact one_ne_zero (by simpa using h)
    obtain ⟨ζ, hζ⟩ := IsCyclotomicExtension.exists_prim_root {n | (n : K) ≠ 0} K L n hn
    letI := hζ.isSplittingField_X_pow_sub_one
    let i := IsSplittingField.lift f.SplittingField (X ^ n - 1) (algebraMap K L)
    exact ⟨i (exists_root_of_splits _ (FiniteField.splits_f_splittingField f) hf.ne_zero).some, by simp⟩
  · intro h
    constructor
    · intro n hn; exact IsAlgClosed.exists_primitiveRoot L hn
    · refine (Algebra.adjoin_eq_top_iff_of_algebraic h.algebraic).mpr fun x ↦ ?_
      rcases eq_or_ne x 0 with rfl | hx
      · exact Subalgebra.zero_mem _
      · letI := FiniteField.finite_adjoin_singleton K x
        let n := Fintype.card (Algebra.adjoin K {x}) - 1
        have hx' : (⟨x, Algebra.self_mem_adjoin K {x}⟩ : Algebra.adjoin K {x}) ^ n = 1 := by
          have := FiniteField.pow_card_sub_one_eq_one (Units.mk0 (⟨x, Algebra.self_mem_adjoin K {x}⟩ : Algebra.adjoin K {x}) (by simp [hx]))
          simpa using this
        obtain ⟨d, _, hpd⟩ := IsPrimitiveRoot.exists_primitiveRoot_of_pow_eq_one hx'
        exact Algebra.subset_adjoin ⟨d, (by
          have h := FiniteField.cast_card_eq_zero (Algebra.adjoin K {x})
          intro h0; rw [h0] at h; exact one_ne_zero (by simpa using h)), hpd⟩
