Released under Apache 2.0 license as described in the file LICENSE.
Authors: Jz Pan
-/
module

public import Mathlib.NumberTheory.Cyclotomic.Basic

@[expose] public section

/-!

# Cyclotomic extension of finite field

-/

theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro h
    haveI := h.isAlgebraic
    apply IsAlgClosure.of_algebraic_extension this
    intro f hf
    rcases eq_or_ne f Polynomial.X with rfl | hfX
    · exact ⟨0, by simp⟩
    let n : ℕ+ := ⟨Finite.card K ^ f.natDegree - 1, by
      have := hf.natDegree_pos; nlinarith [Finite.card_pos (G := K)]⟩
    have hn : (n : K) ≠ 0 := by simp [n, FiniteField.cast_card K]; norm_num
    obtain ⟨ζ, hζ⟩ := h.exists_root hn
    have hf_div : f ∣ Polynomial.X ^ (n : ℕ) - 1 :=
      (FiniteField.X_pow_card_pow_natDegree_minus_X f).trans
        (FiniteField.X_pow_card_pow_natDegree_minus_one_sub_one K f.natDegree).X_mul_dvd_right.2
    exact ⟨(exists_root_of_splits _ hζ.splits_X_pow_sub_one hf.degree_ne_zero).some,
      (exists_root_of_splits _ hζ.splits_X_pow_sub_one hf.degree_ne_zero).some_spec hf_div⟩
  · intro h
    haveI := h.algebraicallyClosed
    constructor
    · intro n hn; exact exists_primitive_root L hn
    · refine (Algebra.adjoin_eq_top_iff _).mpr fun x ↦ ?_
      rcases eq_or_ne x 0 with rfl | hx
      · exact Subalgebra.zero_mem _
      · obtain ⟨n, hn, hx⟩ := FiniteField.isRootOfUnity h.isAlgebraic x hx
        exact Algebra.subset_adjoin ⟨n, hn, hx⟩
