theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  rw [IsAlgClosure.iff_isAlgebraic_isAlgebraicallyClosed]
  constructor
  · intro h
    haveI := h.isAlgebraic
    refine IsAlgClosure.of_algebraic_and_closed ‹_› (IsAlgebraicallyClosed.of_exists_root fun f hf ↦ ?_)
    letI : Finite f.SplittingField := FiniteField.finite_splittingField f
    let n := Fintype.card f.SplittingField.Units
    obtain ⟨ζ, hζ⟩ := h.exists_root_mem n (FiniteField.characteristic_not_dvd_card_units _)
    exact hζ.isCyclotomicExtension.exists_root f hf
  · intro h
    haveI := h.isAlgebraic; haveI := h.isAlgebraicallyClosed
    refine ⟨fun n hn ↦ IsAlgebraicallyClosed.exists_primitive_root L hn, fun x ↦ ?_⟩
    rcases eq_or_ne x 0 with rfl | hx
    · exact Subalgebra.zero_mem _
    · letI : Finite (adjoin K {x}) := Finite.of_fintype (adjoin K {x})
      let u := Units.mk0 (⟨x, subset_adjoin (Set.mem_singleton x)⟩ : adjoin K {x}) hx
      let n := orderOf u
      have hn : (n : K) ≠ 0 := by
        have := CharP.cast_eq_zero_iff K (characteristic K) n
        rw [this, characteristic.characteristic_eq_prime K]
        intro h_dvd
        have h_n_dvd := Units.orderOf_dvd_card_units u
        have h_char_dvd := FiniteField.characteristic_dvd_card (adjoin K {x})
        have h_char_dvd_units := FiniteField.characteristic_not_dvd_card_units (adjoin K {x})
        exact h_char_dvd_units (dvd_trans h_dvd h_n_dvd)
      exact Subalgebra.subset_adjoin ⟨n, hn, IsPrimitiveRoot.orderOf x⟩

