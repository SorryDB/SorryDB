theorem FiniteField.isCyclotomicExtension_iff_isAlgClosure (K L : Type*) [Field K] [Field L]
    [Algebra K L] [Finite K] : IsCyclotomicExtension {n | (n : K) ≠ 0} K L ↔ IsAlgClosure K L := by
  constructor
  · intro
    haveI := IsCyclotomicExtension.algebraic {n | (n : K) ≠ 0} K L
    refine IsAlgClosure.iff_algebraic_and_splits.2 ⟨inferInstance, fun f hf ↦ ?_⟩
    obtain ⟨n, hn, hI⟩ := FiniteField.exists_isCyclotomicExtension K hf
    obtain ⟨ζ, hζ⟩ := IsCyclotomicExtension.exists_root n hn ‹_›
    haveI : IsCyclotomicExtension {n} K (adjoin K {ζ} : Subalgebra K L) := hζ.isCyclotomicExtension n
    let i := (IsCyclotomicExtension.algEquiv n K (splittingField f) (adjoin K {ζ} : Subalgebra K L)).some
    exact (i.toAlgHom.splits_iff.mpr (splittingField.splits f)).map (adjoin K {ζ}).val
  · intro
    constructor
    · intro n hn
      exact IsPrimitiveRoot.exists_root_cyclotomic n (IsAlgClosure.splits_codomain _)
        (cyclotomic.degree_pos n K (pos_of_ne_zero (fun h ↦ hn (by simp [h])))).ne'
    · refine Algebra.eq_top_iff.2 fun x ↦ ?_
      obtain ⟨n, hn, hI⟩ := FiniteField.exists_isCyclotomicExtension K (minpoly K x).irreducible
      obtain ⟨ζ, hζ⟩ := IsPrimitiveRoot.exists_root_cyclotomic n (IsAlgClosure.splits_codomain _)
        (cyclotomic.degree_pos n K (pos_of_ne_zero (fun h ↦ hn (by simp [h])))).ne'
      haveI : IsCyclotomicExtension {n} K (adjoin K {ζ} : Subalgebra K L) := hζ.isCyclotomicExtension n
      let i := (IsCyclotomicExtension.algEquiv n K (splittingField (minpoly K x)) (adjoin K {ζ} : Subalgebra K L)).some
      exact adjoin_mono (fun ζ' hζ' ↦ ⟨n, hn, hζ'⟩) (Polynomial.Splits.rootSet_subset (i.toAlgHom.splits_iff.mpr (splittingField.splits _)) (IsAlgClosure.splits_codomain _) (by simp [mem_rootSet, minpoly.ne_zero]))

