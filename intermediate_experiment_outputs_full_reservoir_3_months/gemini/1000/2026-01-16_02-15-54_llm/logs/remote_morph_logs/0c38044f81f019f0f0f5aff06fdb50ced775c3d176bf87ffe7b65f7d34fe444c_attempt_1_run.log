/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  have : ¬ AffinelyIndependent ℝ x := not_affinelyIndependent_of_field_dimension_lt (by simp)
  obtain ⟨w, hw₀, hw₁, hx⟩ := (not_affinelyIndependent_iff_exists_std_basis ℝ x).1 this
  let spos := {i | 0 < w i}
  let sneg := {i | w i < 0}
  have hpos : spos.Nonempty := exists_pos_of_sum_eq_zero _ hw₁ hw₀
  have hneg : sneg.Nonempty := exists_neg_of_sum_eq_zero _ hw₁ hw₀
  let W := ∑ i in spos, w i
  have hW : 0 < W := Finset.sum_pos (λ i hi ↦ hi) hpos
  let p := W⁻¹ • ∑ i in spos, w i • x i
