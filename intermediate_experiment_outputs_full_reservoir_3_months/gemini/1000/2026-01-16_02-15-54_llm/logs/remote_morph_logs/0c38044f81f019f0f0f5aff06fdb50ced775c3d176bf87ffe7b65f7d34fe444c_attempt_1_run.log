  have h_mem1 : z ∈ C' {0, 2} := h_conv {0, 2} hz1
  have h_mem2 : z ∈ C' {1, 3} := h_conv {1, 3} hz2
  sorry -- Full contradiction follows from the number of intersection points of boundaries
