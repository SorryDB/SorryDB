/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  have h_convex : ∀ s, Convex ℝ {z | z + y s ∈ C} := fun s ↦ hC.translate (y s)
  let K s := {z | z + y s ∈ C}
  have h_shatter : ∀ i s, x i ∈ K s ↔ i ∈ s := hxy
  let S := (Set.range x)
  have : ∀ i, x i ∉ convexHull ℝ (x '' {j | j ≠ i}) := by
    intro i hi
    let s := {j | j ≠ i}
    have : x i ∈ K s := (convexHull_min (by intro j hj; obtain ⟨k, hk, rfl⟩ := hj; exact (h_shatter k s).mpr hk) (h_convex s)) hi
    exact ((h_shatter i s).mp this).elim rfl
  have h_diag : (convexHull ℝ (x '' {0, 2}) ∩ convexHull ℝ (x '' {1, 3})).Nonempty ∨
               (convexHull ℝ (x '' {0, 1}) ∩ convexHull ℝ (x '' {2, 3})).Nonempty ∨
               (convexHull ℝ (x '' {0, 3}) ∩ convexHull ℝ (x '' {1, 2})).Nonempty := sorry
  obtain ⟨p, hp1, hp2⟩ := h_diag
  let s02 := {0, 2}
  let s13 := {1, 3}
  have hp_in : p ∈ K s02 := convexHull_min (by intro j hj; obtain ⟨k, (rfl|rfl), rfl⟩ := hj <;> exact (h_shatter _ _).mpr (by (repeat constructor))) (h_convex _) hp1
  have hp_out : p ∈ K s13 := convexHull_min (by intro j hj; obtain ⟨k, (rfl|rfl), rfl⟩ := hj <;> exact (h_shatter _ _).mpr (by (repeat constructor))) (h_convex _) hp2
  sorry
