/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  have h (s : Set (Fin 4)) : convexHull ℝ (x '' s) + {y s} ⊆ C := by
    rw [← image_add_right, convexHull_subset_iff hC]
    intro _ hx; obtain ⟨i, hi, rfl⟩ := hx; exact (hxy i s).2 hi
  let S : Set (Fin 4) := Set.univ
  obtain ⟨I, J, hI, hJ, hIJ, hIJ', p, hpI, hpJ⟩ :=
    Radon.exists_partition_convexHull_intersect (n := 2) x
  have hp_mem (s : Set (Fin 4)) (hs : s ⊆ S) (hIs : I ⊆ s) : p + y s ∈ C :=
    h s $ Set.mem_image_of_mem _ $ Set.image_subset _ hIs hpI
  have hp_mem' (s : Set (Fin 4)) (hs : s ⊆ S) (hJs : J ⊆ s) : p + y s ∈ C :=
    h s $ Set.mem_image_of_mem _ $ Set.image_subset _ hJs hpJ
  exact absurd (hp_mem I (Set.subset_univ _) (Set.Subset.refl _)) (by sorry)
