import Mathlib.Analysis.Convex.Basic
import Mathlib.Data.Real.Basic

/-!
# VCₙ dimension of convex sets in ℝⁿ⁺¹, ℝⁿ⁺²

In the literature it is known that every convex set in ℝ² has VC dimension at most 3,
and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  have h_aff : ∃ (c : Fin 4 → ℝ), (∑ i, c i = 0) ∧ (∑ i, c i • x i = 0) ∧ (c ≠ 0) := by
    apply exists_linear_dependent_vec_of_finrank_lt_card (ι := Fin 4) (V := Fin 2 → ℝ)
    simp [FiniteDimensional.finrank_fintype_fun]
  rcases h_aff with ⟨c, hc_sum, hc_x, hc_nz⟩
  let I := {i | 0 < c i}
  let J := {j | c j < 0}
  have hIJ : Disjoint I J := Set.disjoint_left.mpr (λ i hi hj => (hi.trans_refl hj).ne rfl)
  let sum_pos := ∑ i in I, c i
  let sum_neg := ∑ j in J, -c j
  have h_sum : sum_pos = sum_neg := by
    rw [← sub_eq_zero, ← hc_sum, sum_pos, sum_neg, ← Finset.sum_filter, ← Finset.sum_filter]
    simp [I, J]; rw [← Finset.sum_add_sum_compl (Finset.univ.filter (λ i => 0 < c i))]
    sorry
  have h_conv : (convexHull ℝ (x '' I) ∩ convexHull ℝ (x '' J)).Nonempty := sorry
  rcases h_conv with ⟨p, hpI, hpJ⟩
  have hp_trans (s : Set (Fin 4)) : p + y s ∈ convexHull ℝ ((λ i => x i + y s) '' I) ∩ convexHull ℝ ((λ i => x i + y s) '' J) := sorry
  have h_in_C (s : Set (Fin 4)) (hs : I ⊆ s) : p + y s ∈ C := by
    apply hC.convexHull_subset
    intro z hz
    rcases hz with ⟨i, hi, rfl⟩
    exact (hxy i s).mpr (hs hi)
  have h_not_in_C (s : Set (Fin 4)) (hs : J ∩ s = ∅) : p + y s ∉ C := sorry
  exact h_not_in_C I (Set.disjoint_iff_inter_eq_empty.mp hIJ.symm) (h_in_C I (Set.Subset.refl I))
