import Mathlib.Analysis.Convex.Basic
import Mathlib.Data.Real.Basic

/-!
# VCₙ dimension of convex sets in ℝⁿ⁺¹, ℝⁿ⁺²

In the literature it is known that every convex set in ℝ² has VC dimension at most 3,
and there exists a convex set in ℝ³ with infinite VC dimension (even more strongly,
which shatters an infinite set).

This file proves that every convex set in ℝⁿ has finite VCₙ dimension, constructs a convex set in
ℝⁿ⁺² with infinite VCₙ dimension (even more strongly, which n-shatters an infinite set),
and conjectures that every convex set in ℝⁿ⁺¹ has finite VCₙ dimension.
-/

/-! ### What's known -/

/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  have h_conv (s : Set (Fin 4)) : convexHull ℝ (x '' s) + {y s} ⊆ C := by
    rw [add_comm, Set.add_singleton_subset_iff]
    apply hC.convexHull_subset
    intro z hz
    rcases hz with ⟨i, hi, rfl⟩
    exact (hxy i s).mpr hi
  have h_not_mem (i : Fin 4) (s : Set (Fin 4)) (hi : i ∉ s) : x i + y s ∉ C := (hxy i s).not.mpr hi
  let pts : Fin 4 → Fin 2 → ℝ := x
  have ∃ (a : Fin 4 → ℝ), (∑ i, a i • pts i = 0) ∧ (∑ i, a i = 0) ∧ (a ≠ 0) := by
    apply exists_nonzero_linear_dependent_vec_of_card_gt_fin_dim
    simp
  rcases this with ⟨a, h_sum, h_sum_a, h_nonzero⟩
  let I := {i | a i > 0}
  let J := {j | a j < 0}
  have hIJ : Disjoint I J := Set.disjoint_left.mpr (λ i hi hj ↦ by dsimp [I, J] at hi hj; linarith)
  have h_I_nonempty : I.Nonempty := by
    contrapose! h_nonzero; have hJ : J = ∅ := by
      ext j; simp [J]; intro hj; have := h_sum_a; rw [← Set.sum_compl_add_sum I] at this; simp [h_nonzero] at this
      linarith [hj]
    ext i; dsimp [I, J] at h_nonzero hJ; split_ifs with h1 h2 <;> linarith
  have h_J_nonempty : J.Nonempty := by
    contrapose! h_nonzero; have hI : I = ∅ := by
      ext i; simp [I]; intro hi; have := h_sum_a; rw [← Set.sum_compl_add_sum J] at this; simp [h_nonzero] at this
      linarith [hi]
    ext i; dsimp [I, J] at h_nonzero hI; split_ifs with h1 h2 <;> linarith
  let S := ∑ i in I, a i
  have hS : S > 0 := Finset.sum_pos (λ i hi ↦ (by dsimp [I] at hi; exact hi)) h_I_nonempty.to_subtype
  let p := ∑ i in I, (a i / S) • pts i
  have hpI : p ∈ convexHull ℝ (x '' I) := by
    apply sum_mem_convexHull (λ i hi ↦ by dsimp [I] at hi; linarith)
    simp [S, Finset.sum_div, ← Finset.sum_div, div_self (ne_of_gt hS)]
  have hpJ : p ∈ convexHull ℝ (x '' J) := by
    have h_sum' : ∑ i in I, a i • pts i = ∑ j in J, (-a j) • pts j := by
      rw [← sub_eq_zero, ← Finset.sum_negdistrib]; have := h_sum; rw [← Finset.sum_union hIJ.symm.finset_disjoint] at this
      simp [I, J] at *; exact this
    have hS' : S = ∑ j in J, -a j := by
      have := h_sum_a; rw [← Finset.sum_union hIJ.symm.finset_disjoint] at this; simp [I, J] at *; linarith
    simp [p, Finset.sum_div, h_sum', hS']; apply sum_mem_convexHull
    · intro j hj; dsimp [J] at hj; linarith
    · simp [← Finset.sum_div, div_self (ne_of_gt hS)]
  have h_contra (s : Set (Fin 4)) (hIs : I ⊆ s) (hJs : Disjoint J s) : False := by
    have hpCs : p + y s ∈ C := h_conv s (convexHull_mono (Set.image_mono hIs) hpI)
    have hpNotCs : p + y s ∉ C := by
      intro h; apply hC.convexHull_subset _ hpJ
      intro z hz; rcases hz with ⟨j, hj, rfl⟩
      exact h_not_mem j s (hJs.symm.mono_right (Set.subset_refl _) hj) (by rwa [add_comm, Set.add_singleton_subset_iff] at h)
    exact hpNotCs hpCs
  exact h_contra I (Set.subset_refl I) hIJ
