/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  have h_conv (s : Set (Fin 4)) : convex_hull ℝ (x '' s) + {y s} ⊆ C := by
    rw [add_singleton, image_add_right, convex_hull_subset_iff]
    · intro _ ⟨i, hi, h_xi⟩
      subst h_xi
      exact (hxy i s).2 hi
    · exact hC.translate (y s)
  have h_not (i : Fin 4) (s : Set (Fin 4)) (hi : i ∉ s) : x i + y s ∉ C := (hxy i s).not.2 hi
  let pts : Fin 4 → (Fin 2 → ℝ) × ℝ := fun i ↦ (x i, 1)
  have : ¬ LinearIndependent ℝ pts := by
    apply (LinearIndependent.card_le_finrank (v := pts)).not.2
    simp [FiniteDimensional.finrank_prod, FiniteDimensional.finrank_self]
  obtain ⟨w, hw, hw_sum, i, hi⟩ := exists_linear_dependent_vecpts_of_card_lt_finrank this (by simp)
  let I := {i | 0 < w i}
  let J := {i | w i < 0}
  have hI : I.Nonempty := exists_pos_of_sum_zero hw_sum hw hi
  have hJ : J.Nonempty := exists_neg_of_sum_zero hw_sum hw hi
  let sI : Set (Fin 4) := {i | 0 < w i}
  let sJ : Set (Fin 4) := {i | w i < 0}
  let WI := ∑ i ∈ I, w i
  let WJ := ∑ j ∈ J, -w j
  have hW : WI = WJ := by
    rw [← sub_eq_zero, ← hw_sum, ← Finset.sum_filter_add_sum_filter_not (Finset.univ) (fun i ↦ 0 < w i)]
    simp [WI, WJ, I, sI, sJ, Finset.sum_neg_distrib]
    sorry
  sorry
