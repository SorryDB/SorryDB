/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False := by
  let f (i : Fin 4) : Fin 3 → ℝ := (fun j => if j < 2 then x i j else 1)
  obtain ⟨w, hw1, hw2⟩ := FiniteDimensional.exists_linearIndependent_ge (Fin 3 → ℝ)
    (Set.range f) (by simp; exact fun h => by mono)
  obtain ⟨c, hc1, hc2⟩ := exists_linear_combination_zero_of_length_pos (by
    rw [← Fintype.card_fin 4]; exact Nat.lt_succ_self 3) f
  let I := {i | 0 < c i}
  let J := {j | c j < 0}
  let A := ∑ i in I, c i
  let B := ∑ j in J, -c j
  have hAB : A = B := by
    rw [← sub_eq_zero, ← sum_filter_add_sum_filter_not (fun i => 0 < c i) c]
    simp [I, J, ← hc1, (by
      intro i hi; have : c i < 0 := by
        contrapose! hi; exact (lt_or_eq_of_le hi).resolve_right (fun h => hc2 i h)
      simp [this])]; exact (by
      intro i hi; have : c i = 0 := by
        contrapose! hi; exact (lt_or_eq_of_le (not_lt.1 hi)).resolve_left (not_lt.1 hi)
      exact this)
  have hA : 0 < A := by
    obtain ⟨i, hi⟩ : ∃ i, c i ≠ 0 := by
      contrapose! hc2; exact fun i => hc2 i
    cases' lt_or_gt_of_ne hi with h h
    · rw [hAB]; exact sum_pos (fun _ _ => by simp) ⟨i, by simp [J, h]⟩
    · exact sum_pos (fun _ _ => by simp) ⟨i, by simp [I, h]⟩
  let p := ∑ i in I, (c i / A) • x i
  have hpI : p ∈ convexHull ℝ (x '' I) := by
    refine' sum_convex_combination (by
      intro i hi; exact div_nonneg (le_of_lt (by simp [I] at hi; exact hi)) (le_of_lt hA)) (by
      rw [← sum_div, (by simp [I])]; exact div_self (ne_of_gt hA)) (by
      intro i hi; exact Set.mem_image_of_mem x hi)
  have hpJ : p ∈ convexHull ℝ (x '' J) := by
    rw [← hAB] at hA; refine' sum_convex_combination (by
      intro j hj; exact div_nonneg (neg_nonneg.2 (le_of_lt (by simp [J] at hj; exact hj))) (le_of_lt hA)) (by
      rw [← sum_div, (by simp [J])]; exact div_self (ne_of_gt hA)) (by
      intro j hj; exact Set.mem_image_of_mem x hj)
  let s := I
  have h1 : ∀ i ∈ I, x i + y s ∈ C := fun i hi => (hxy i s).2 hi
  have h2 : p + y s ∈ C := by
    rw [sum_add_distrib] at hpI; simp [← sum_smul, (by simp [I])] at hpI
    exact hC.convexHull_subset (by intro z hz; obtain ⟨i, hi, rfl⟩ := hz; exact h1 i hi) hpI
  obtain ⟨j, hj⟩ : ∃ j, j ∈ J := by
    obtain ⟨j, hj⟩ : ∃ j, c j < 0 := by
      contrapose! hA; rw [hAB]; exact sum_nonpos (fun j _ => neg_nonpos.2 (hA j))
    exact ⟨j, by simp [J, hj]⟩
  have h3 : j ∉ s := fun h => by
    have := (by simp [J] at hj; exact hj); have := (by simp [I, s] at h; exact h)
    linarith
  exact h3 ((hxy j s).1 (by
    let s' := J; have h4 : ∀ j ∈ J, x j + y s' ∈ C := fun j hj => (hxy j s').2 hj
    have h5 : p + y s' ∈ C := by
      rw [sum_add_distrib] at hpJ; simp [← sum_smul, (by simp [J])] at hpJ
      exact hC.convexHull_subset (by intro z hz; obtain ⟨j, hj, rfl⟩ := hz; exact h4 j hj) hpJ
    exact h2))
