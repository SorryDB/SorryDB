    ⟨y s, λ i => (hxy i s).symm⟩
  let 𝒦 : Fin 4 → Set (Fin 2 → ℝ) := K
  have h_regions : ∀ s, (⋂ i ∈ s, 𝒦 i) ∩ (⋂ i ∉ s, (𝒦 i)ᶜ) ≠ ∅ :=
    λ s => let ⟨y_s, hy_s⟩ := h_shat s; ⟨y_s, ⟨Set.mem_biInter hy_s, Set.mem_biInter (λ i hi => hy_s i |>.not.mpr hi)⟩⟩
