/-- Every convex set in ℝ² has VC dimension at most 3. -/
lemma vc_lt_four_of_convex_r2 {C : Set (Fin 2 → ℝ)} (hC : Convex ℝ C)
    {x : Fin 4 → Fin 2 → ℝ} {y : Set (Fin 4) → Fin 2 → ℝ}
    (hxy : ∀ i s, x i + y s ∈ C ↔ i ∈ s) : False :=
  let C' s := {z | z + y s ∈ C}
  have hC' s : Convex ℝ (C' s) := hC.translate (y s)
  have hshat i s : x i ∈ C' s ↔ i ∈ s := hxy i s
  have h_conv (s : Set (Fin 4)) : convexHull ℝ (x '' s) ⊆ C' s :=
    convexHull_min (fun _ ⟨j, hj, hx⟩ => hx ▸ (hshat j s).2 hj) (hC' s)
  have h_not (s : Set (Fin 4)) (i : Fin 4) (hi : i ∉ s) : x i ∉ convexHull ℝ (x '' s) :=
    fun h => hi ((hshat i s).1 (h_conv s h))
  have h_quad : ∀ i, x i ∉ convexHull ℝ (x '' {j | j ≠ i}) :=
    fun i => h_not {j | j ≠ i} i (fun h => h rfl)
  let z : Fin 2 → ℝ := (x 0 + x 2) / 2
