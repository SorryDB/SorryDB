@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  apply Nat.dvd_of_forall_multiplicity_le
  intro p hp
  rw [multiplicity.mul hp, multiplicity.mul hp, multiplicity.mul hp]
  set N := 2 * m + 2 * n
