  have hk : k > 0 := Nat.pow_pos hp.pos i
  have h1 : 2 * m / k = 2 * (m / k) + 2 * (m % k) / k := by
    rw [← Nat.add_div, ← two_mul, ← Nat.div_add_mod m k, mul_add, ← mul_assoc, Nat.mul_add_div hk]
  have h2 : 2 * n / k = 2 * (n / k) + 2 * (n % k) / k := by
