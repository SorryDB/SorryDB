/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m.factorial * n.factorial * (m + n).factorial ∣ (2 * m).factorial * (2 * n).factorial := by
  induction n generalizing m with
  | zero =>
    simp [Nat.factorial_mul_factorial_dvd_factorial_add]
  | succ n ih =>
    set A := fun m n => (2 * m).factorial * (2 * n).factorial
    set B := fun m n => m.factorial * n.factorial * (m + n).factorial
    have h1 : B (m + 1) n ∣ A (m + 1) n := ih (m + 1)
    have h2 : B (m + 1) (n + 1) ∣ A (m + 1) n * (n + 1) := by
      rw [show B (m + 1) (n + 1) = B (m + 1) n * (n + 1) * (m + n + 2) / (m + n + 1 + 1) by
        simp [Nat.factorial_succ]; ring]
      have hB : B (m + 1) (n + 1) = B (m + 1) n * (n + 1) := by
        simp [Nat.factorial_succ, add_assoc, add_comm n 1]
      rw [hB]
      exact Nat.mul_dvd_mul_right h1 (n + 1)
    have h3 : B m (n + 1) ∣ A m n := ih m
    have h4 : B (m + 1) (n + 1) ∣ 4 * A m n * (m + 1) * (n + 1) * (m + n + 1) := by
      have hB : B (m + 1) (n + 1) = B m n * (m + 1) * (n + 1) * (m + n + 1) := by
        simp [Nat.factorial_succ]; ring
      rw [hB]
      apply Nat.mul_dvd_mul_right
      exact dvd_mul_of_dvd_left h3 4
    have h_sum : A m (n + 1) * (m + 1) + A (m + 1) n * (n + 1) = 4 * A m n * (m + 1) * (n + 1) * (m + n + 1) := by
      simp [Nat.factorial_succ, ← Nat.mul_assoc]
      ring
    have h5 : B (m + 1) (n + 1) ∣ A m (n + 1) * (m + 1) := by
      rw [← h_sum] at h4
      exact Nat.dvd_of_add_dvd_right h4 h2
    exact Nat.dvd_of_mul_dvd_mul_right (Nat.succ_pos m) h5

