/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  apply Nat.dvd_of_factorization_le (by positivity) (by positivity)
  intro p
  by_cases hp : p.Prime; swap
  · rw [Nat.factorization_eq_zero_of_non_prime _ hp]; simp
  rw [Nat.factorization_mul, Nat.factorization_mul, Nat.factorization_mul]
  repeat rw [Nat.factorization_factorial hp]
  · let K := 2 * m + 2 * n + 1
    have h_sum s (hs : s ≤ 2 * m + 2 * n) :
        ∑ i in Finset.Ico 1 (s.log p + 1), s / p ^ i = ∑ i in Finset.Ico 1 K, s / p ^ i := by
      rcases s.eq_zero_or_pos with rfl | hs_pos
      · simp [K, hp.pos]
      apply Finset.sum_subset (Finset.Ico_subset_Ico (by omega) (by
        rw [Nat.log_le_iff hp.one_lt hs_pos]
        apply Nat.lt_of_le_of_lt hs
        apply Nat.le_pow_self hp.two_le))
      intro i _ hni; apply Nat.div_eq_zero
      apply Nat.lt_of_le_of_lt hs
      apply (Nat.le_pow_iff_log_le hp hs_pos).1
      omega
    repeat rw [h_sum _ (by omega)]
    rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
    apply Finset.sum_le_sum
    intro i _; set k := p ^ i
    have hk : k > 0 := Nat.pos_pow_of_pos _ hp.pos
    repeat rw [two_mul]
    rw [Nat.add_div _ _ hk, Nat.add_div _ _ hk, Nat.add_div _ _ hk]
    set rm := m % k; set rn := n % k
    have h1 : (rm + rn) / k ≤ (rm + rm) / k + (rn + rn) / k := by
      by_cases h : rm + rn < k
      · rw [Nat.div_eq_zero h]; exact Nat.zero_le _
      · have : (rm + rn) / k = 1 := by apply Nat.div_eq_of_lt_le <;> omega
        rw [this]; have : rm + rm ≥ k ∨ rn + rn ≥ k := by omega
        rcases this with h2 | h2 <;> { have : 1 ≤ _ / k := Nat.le_div_of_mul_le h2; omega }
    omega
  all_goals positivity

