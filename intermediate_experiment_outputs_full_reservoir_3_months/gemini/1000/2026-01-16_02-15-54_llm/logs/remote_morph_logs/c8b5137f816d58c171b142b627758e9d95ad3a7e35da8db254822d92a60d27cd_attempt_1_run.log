import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  if hmn : m = 0 ∧ n = 0 then
    simp [hmn]
  else
    apply Nat.dvd_of_factorization_le (by positivity)
    intro p hp
    simp [Nat.factorization_mul, Nat.factorial_ne_zero, Nat.factorization_factorial hp]
    let K := 2 * m + 2 * n
    have h_extend {k : ℕ} (hk : k ≤ K) : (k.factorial.factorization p) = ∑ i in Finset.Ico 1 (K + 1), k / p ^ i := by
      rw [Nat.factorization_factorial hp k]
      refine (Finset.sum_subset (Finset.Ico_subset_Ico (le_refl 1) (Nat.add_le_add_right hk 1)) ?_).symm
      intro i hi hni
      rw [Nat.div_eq_zero_of_lt]
      exact (hk.trans_lt (Nat.lt_pow_self hp.two_le i)).trans_le (Nat.pow_le_pow_of_le_left (Nat.Prime.two_le hp) i)
    repeat rw [h_extend (by omega)]
    rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
    apply Finset.sum_le_sum
    intro i hi
    let d := p ^ i
    rw [Nat.add_mod_div m n d, Nat.mul_div_assoc 2 m d, Nat.mul_div_assoc 2 n d]
    have : d > 0 := Nat.pos_pow_of_pos _ (Nat.Prime.pos hp)
    have rm : m % d < d := Nat.mod_lt _ this
    have rn : n % d < d := Nat.mod_lt _ this
    omega

