import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m.factorial * n.factorial * (m + n).factorial ∣ (2 * m).factorial * (2 * n).factorial := by
  have h : ∀ n m, (m.factorial * n.factorial * (m + n).factorial : ℤ) ∣ ((2 * m).factorial * (2 * n).factorial : ℤ) := by
    intro n m
    induction n generalizing m with
    | zero =>
      simp
      norm_cast
      exact Nat.factorial_mul_factorial_dvd_factorial_add m m
    | succ n ih =>
      obtain ⟨s_m, h_m⟩ := Int.dvd_iff_exists_eq_mul_right.mp (ih m)
      obtain ⟨s_m1, h_m1⟩ := Int.dvd_iff_exists_eq_mul_right.mp (ih (m + 1))
      use 4 * s_m - s_m1
      have h1 : (m + 1 : ℤ) ≠ 0 := by norm_cast; simp
      rw [← Int.mul_left_inj' h1]
      have h_m_fact : ((m + 1).factorial : ℤ) = (m + 1) * m.factorial := by
        push_cast; rw [Nat.factorial_succ, Nat.mul_comm]
      have h_n_fact : ((n + 1).factorial : ℤ) = (n + 1) * n.factorial := by
        push_cast; rw [Nat.factorial_succ, Nat.mul_comm]
      have h_mn_fact : ((m + n + 1).factorial : ℤ) = (m + n + 1) * (m + n).factorial := by
        push_cast; rw [Nat.factorial_succ, Nat.mul_comm]
      have h_2m_fact : ((2 * m + 2).factorial : ℤ) = (2 * m + 2) * (2 * m + 1) * (2 * m).factorial := by
        push_cast; rw [Nat.factorial_succ, Nat.factorial_succ, Nat.mul_assoc]
      have h_2n_fact : ((2 * n + 2).factorial : ℤ) = (2 * n + 2) * (2 * n + 1) * (2 * n).factorial := by
        push_cast; rw [Nat.factorial_succ, Nat.factorial_succ, Nat.mul_assoc]
      rw [h_2n_fact, h_m_fact, h_n_fact, h_mn_fact, ← h_m, ← h_m1]
      simp only [Nat.cast_mul, Nat.cast_add, Nat.cast_one]
      ring
  exact Nat.dvd_of_int_dvd (h n m)
