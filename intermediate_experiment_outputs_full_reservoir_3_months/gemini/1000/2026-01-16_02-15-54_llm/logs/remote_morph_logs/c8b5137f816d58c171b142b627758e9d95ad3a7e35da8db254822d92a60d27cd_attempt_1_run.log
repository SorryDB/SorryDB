import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  induction m generalizing n with
  | zero =>
    rw [Nat.zero_factorial, Nat.one_mul, Nat.one_mul, Nat.zero_add]
    exact Nat.factorial_mul_factorial_dvd_factorial_add n n
  | succ m ih =>
    obtain ⟨k1, h1⟩ := ih n
    obtain ⟨k2, h2⟩ := ih (n + 1)
    use 4 * k1 - k2
    have h_ge : 4 * k1 ≥ k2 := by
      apply Nat.le_of_mul_le_mul_left (a := (m + n + 1))
      apply Nat.le_of_mul_le_mul_left (a := (m ! * (n + 1)!))
      rw [Nat.mul_assoc, Nat.mul_left_comm _ (4 * k1), ← h1, Nat.mul_assoc, ← h2]
      simp [Nat.factorial_succ, Nat.mul_succ]
      ring_nf
      omega
    rw [Nat.mul_sub_left_distrib, Nat.mul_assoc (m + 1)! n!, ← Nat.mul_assoc (m + 1)!, Nat.factorial_succ m,
        Nat.mul_assoc (m + 1) m!, ← Nat.mul_assoc (m + 1), Nat.mul_left_comm (m + 1),
        Nat.mul_assoc (m + 1) (m ! * n !), ← Nat.factorial_succ, h1, Nat.mul_assoc,
        Nat.mul_left_comm (4 * (m + n + 1))]
    apply Nat.eq_of_mul_eq_mul_left (Nat.succ_pos n)
    rw [Nat.mul_assoc (n + 1), Nat.mul_assoc (n + 1), Nat.mul_left_comm (n + 1) _ k2, ← h2,
        Nat.mul_left_comm (n + 1), ← Nat.mul_assoc (m + 1)!, Nat.factorial_succ (n),
        Nat.mul_assoc (n + 1), ← Nat.mul_assoc (m + 1)!, ← h2]
    repeat rw [Nat.factorial_succ]
    ring_nf
