import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  rw [Nat.dvd_iff_multiplicity_le]
  intro p hp
  rw [multiplicity.mul hp, multiplicity.mul hp]
  let k := 2 * m + 2 * n + 1
  have h_mul (x : ℕ) (hx : x ≤ 2 * m + 2 * n) : multiplicity p x.factorial = ↑(∑ i in Finset.Ico 1 k, x / p ^ i) :=
    Nat.multiplicity_factorial_eq_sum_quotient hp (Nat.lt_of_le_of_lt hx (Nat.lt_pow_self hp.two_le k))
  rw [h_mul m (Nat.le_trans (Nat.le_add_right m n) (by omega)), h_mul n (Nat.le_trans (Nat.le_add_left n m) (by omega)),
    h_mul (m + n) (by omega), h_mul (2 * m) (by omega), h_mul (2 * n) (by omega), ← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  norm_cast
  apply Finset.sum_le_sum
  intro i _
  let d := p ^ i
  have hd : d > 0 := Nat.pos_pow_of_pos i (Nat.Prime.pos hp)
  have h2 (a : ℕ) : 2 * a / d = 2 * (a / d) + (2 * (a % d)) / d := by
    rw [← Nat.div_add_mod a d, Nat.mul_add, Nat.add_comm, Nat.mul_assoc, Nat.add_mul_div_left _ _ hd, Nat.add_comm]
  rw [h2 m, h2 n, Nat.add_assoc, ← Nat.add_assoc (2 * (m / d)), Nat.add_comm (2 * (n / d)), Nat.add_assoc (2 * (m / d))]
  apply Nat.add_le_add (Nat.refl _)
  have h_add : (m + n) / d = m / d + n / d + (m % d + n % d) / d := by
    rw [← Nat.div_add_mod m d, ← Nat.div_add_mod n d, Nat.add_add_add_comm, Nat.add_assoc (m / d + n / d), Nat.add_mul_div_left _ _ hd]
  rw [h_add, Nat.add_assoc, Nat.add_comm (m / d), Nat.add_assoc, Nat.add_assoc]
  apply Nat.add_le_add (Nat.refl _)
  let r1 := m % d; let r2 := n % d
  have : (r1 + r2) / d ≤ 2 * r1 / d + 2 * r2 / d := by
    if h : r1 + r2 < d then
      rw [Nat.div_eq_of_lt h]; exact Nat.zero_le _
    else
      have h1 : (r1 + r2) / d = 1 := Nat.div_eq_of_lt_le (Nat.not_lt.1 h) (by omega)
      have : d ≤ 2 * r1 ∨ d ≤ 2 * r2 := by omega
      rw [h1]; cases this <;> (have : 1 ≤ _ / d := Nat.le_div_of_mul_le (by omega); omega)
  exact this
