import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  induction n generalizing m with
  | zero =>
    simp [Nat.factorial_mul_factorial_dvd_factorial_add m m]
  | succ n ih =>
    have h : (m + 1) * ((2 * m).factorial * (2 * n + 2).factorial) + (n + 1) * ((2 * m + 2).factorial * (2 * n).factorial) =
             4 * (n + 1) * (m + 1) * (m + n + 1) * ((2 * m).factorial * (2 * n).factorial) := by
      simp [Nat.factorial_succ]
      ring
    have h_dvd1 : (m + 1)! * (n + 1)! * (m + n + 1)! ∣ 4 * (n + 1) * (m + 1) * (m + n + 1) * ((2 * m).factorial * (2 * n).factorial) := by
      rw [show (m + 1)! * (n + 1)! * (m + n + 1)! = (n + 1) * (m + 1) * (m + n + 1) * (m! * n! * (m + n)!) by simp [Nat.factorial_succ]; ring]
      exact Nat.mul_dvd_mul_left _ (ih m)
    have h_dvd2 : (m + 1)! * (n + 1)! * (m + n + 1)! ∣ (n + 1) * ((2 * m + 2).factorial * (2 * n).factorial) := by
      rw [show (m + 1)! * (n + 1)! * (m + n + 1)! = (n + 1) * ((m + 1)! * n! * (m + n + 1)!) by simp [Nat.factorial_succ]; ring]
      exact Nat.mul_dvd_mul_left _ (ih (m + 1))
    have h_dvd : (m + 1)! * (n + 1)! * (m + n + 1)! ∣ (m + 1) * ((2 * m).factorial * (2 * n + 2).factorial) :=
      Nat.dvd_of_add_dvd_add_right (h.symm ▸ h_dvd1) h_dvd2
    rw [Nat.factorial_succ, mul_assoc, mul_assoc, mul_assoc] at h_dvd
    exact (Nat.mul_dvd_mul_iff_left (Nat.succ_pos m)).mp h_dvd
