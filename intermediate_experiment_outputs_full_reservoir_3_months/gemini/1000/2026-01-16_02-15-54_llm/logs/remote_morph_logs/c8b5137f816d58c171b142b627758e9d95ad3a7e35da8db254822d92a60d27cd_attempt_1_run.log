  rw [hN m (by omega), hN n (by omega), hN (m + n) (by omega), hN (2 * m) (by omega), hN (2 * n) (by omega)]
  rw [← Nat.cast_add, ← Nat.cast_add, ← Nat.cast_add, Nat.cast_le, ← Finset.sum_add, ← Finset.sum_add]
  refine Finset.sum_le_sum (fun i _ => ?_)
  set d := p ^ (i + 1)
  have hd : d > 0 := Nat.pos_pow_of_pos _ hp.pos
  rw [Nat.add_div m n hd, Nat.mul_div_assoc 2 (dvd_refl 2), Nat.mul_div_assoc 2 (dvd_refl 2)]
  have : (m % d + n % d) / d ≤ 2 * (m % d) / d + 2 * (n % d) / d := by
    have h4 := Nat.mod_lt m hd
    have h5 := Nat.mod_lt n hd
    omega
  omega

