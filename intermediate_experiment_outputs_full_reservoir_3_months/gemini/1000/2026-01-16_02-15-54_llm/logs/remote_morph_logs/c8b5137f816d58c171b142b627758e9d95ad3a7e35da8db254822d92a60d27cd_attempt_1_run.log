  | 0 => exact Nat.zero_le _
  | _ + 1 =>
    have : p' ≤ 2 * (m % p') ∨ p' ≤ 2 * (n % p') := by
      contrapose! h; exact Nat.div_eq_zero (by linarith)
    cases this <;> exact Nat.le_trans (Nat.le_div_of_mul_le ‹_›) (by simp)

