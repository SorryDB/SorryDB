import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  apply Nat.dvd_of_forall_padicValNat_le (by positivity)
  intro p hp
  simp [padicValNat.mul hp (Nat.factorial_ne_zero _) (by positivity),
        padicValNat.mul hp (Nat.factorial_ne_zero _) (Nat.factorial_ne_zero _)]
  let N := 2 * m + 2 * n
  have h_ext {k : ℕ} (hk : k ≤ N) : k.factorial.padicValNat p = ∑ i in Finset.range N, k / p ^ (i + 1) := by
    rw [padicValNat_factorial hp]
    refine (Finset.sum_subset (Finset.range_mono hk) (fun i hi hni => ?_)).symm
    rw [Finset.mem_range] at hi hni
    exact Nat.div_eq_zero (lt_of_le_of_lt hk (Nat.lt_pow_self hp.one_lt (i + 1) (by omega)))
  rw [h_ext (by omega), h_ext (by omega), h_ext (by omega), h_ext (by omega), h_ext (by omega), ← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  refine Finset.sum_le_sum (fun i _ => ?_)
  set d := p ^ (i + 1)
  have d_pos : 0 < d := Nat.pos_pow _ hp.pos
  rw [Nat.add_div m n d, (by omega : 2 * m = 2 * m), (by omega : 2 * n = 2 * n),
      Nat.mul_div_assoc m (Nat.dvd_refl 2), Nat.mul_div_assoc n (Nat.dvd_refl 2)]
  have h_mod (x : ℕ) : (2 * (x % d)) / d = if d ≤ 2 * (x % d) then 1 else 0 := by
    have : 2 * (x % d) < 2 * d := by linarith [Nat.mod_lt x d_pos]
    rw [Nat.div_eq_of_lt_le (by split_ifs <;> omega) this]; rfl
  have h_add_mod : (m % d + n % d) / d = if d ≤ m % d + n % d then 1 else 0 := by
    have : m % d + n % d < 2 * d := by linarith [Nat.mod_lt m d_pos, Nat.mod_lt n d_pos]
    rw [Nat.div_eq_of_lt_le (by split_ifs <;> omega) this]; rfl
  rw [h_mod m, h_mod n, h_add_mod]; split_ifs <;> omega

