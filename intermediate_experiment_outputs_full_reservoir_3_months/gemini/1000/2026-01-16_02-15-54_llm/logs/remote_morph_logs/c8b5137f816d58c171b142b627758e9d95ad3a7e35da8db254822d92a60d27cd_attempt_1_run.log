open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  apply Nat.dvd_of_forall_prime_multiplicity_le
  intro p hp
  rw [multiplicity.mul hp, multiplicity.mul hp, multiplicity.mul hp, multiplicity.mul hp]
  repeat rw [Nat.multiplicity_factorial_prime_eq_sum_nat_div hp]
  rw [← Nat.cast_add, ← Nat.cast_add, PartENat.coe_le_coe]
  let D := 2 * m + 2 * n + 1
  have hS k (hk : k ≤ 2 * m + 2 * n) : (∑ i in Finset.Ico 1 (k + 1), k / p ^ i) = ∑ i in Finset.Ico 1 D, k / p ^ i := by
    refine Finset.sum_subset (Finset.Ico_subset_Ico (by simp) (by omega)) fun i hi hni => ?_
    exact Nat.div_eq_zero (Nat.lt_of_le_of_lt hk (Nat.one_lt_pow (by omega) (by simp [hp.one_lt])))
  rw [hS m (by omega), hS n (by omega), hS (m + n) (by omega), hS (2 * m) (by omega), hS (2 * n) (by omega)]
  rw [← Finset.sum_add_distrib, ← Finset.sum_add_distrib]
  apply Finset.sum_le_sum
  intro i _
  let k := p ^ i
  have hk : 0 < k := Nat.pos_pow_of_pos i hp.pos
  have h_div k' : (2 * k') / k = 2 * (k' / k) + (2 * (k' % k)) / k := by
    rw [← Nat.div_add_mod k' k, Nat.mul_add, Nat.mul_assoc, Nat.add_comm, Nat.add_mul_div_left _ _ hk]
  rw [Nat.add_div m n hk, h_div m, h_div n]
  have : (m % k + n % k) / k ≤ (2 * (m % k)) / k + (2 * (n % k)) / k := by
    rcases Nat.lt_or_ge (m % k + n % k) k with h | h
    · rw [Nat.div_eq_zero h]; exact Nat.zero_le _
    · rw [Nat.div_eq_one h (by omega)]
      have : k ≤ 2 * (m % k) ∨ k ≤ 2 * (n % k) := by omega
      rcases this with h | h
      · exact Nat.le_add_right 1 ((2 * (n % k)) / k) |>.trans_le (Nat.add_le_add_right (Nat.div_le_div_right h) _)
      · exact Nat.le_add_left 1 ((2 * (m % k)) / k) |>.trans_le (Nat.add_le_add_left (Nat.div_le_div_right h) _)
  omega

