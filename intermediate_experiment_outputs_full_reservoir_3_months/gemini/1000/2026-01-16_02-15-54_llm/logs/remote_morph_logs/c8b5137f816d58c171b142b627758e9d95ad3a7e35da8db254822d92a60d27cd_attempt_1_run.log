theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  apply Nat.dvd_of_multiplicity_le
  intro p hp
  simp [multiplicity.mul hp, ← Nat.cast_add]
  let k := 2 * m + 2 * n + 1
  have hxk (x : ℕ) (hx : x < k) : multiplicity p x.factorial = ↑(∑ i in Finset.Ico 1 k, x / p ^ i) :=
    Nat.multiplicity_factorial_prime_gen hp x k (hx.trans_le (Nat.le_pow_self hp.one_lt k))
  rw [hxk m (by linarith), hxk n (by linarith), hxk (m + n) (by linarith), hxk (2 * m) (by linarith), hxk (2 * n) (by linarith)]
  simp [← Nat.cast_add, Nat.cast_le, ← Finset.sum_add_distrib]
