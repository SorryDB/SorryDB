import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  induction n generalizing m with
  | zero =>
    simp
    apply Nat.factorial_mul_factorial_dvd_factorial_add
  | succ n ih =>
    have h : (↑(m!) * ↑((n + 1)!) * ↑((m + n + 1)!) : ℤ) ∣ ↑((2 * m)!) * ↑((2 * n + 2)!) := by
      obtain ⟨k1, h1⟩ := ih m
      obtain ⟨k2, h2⟩ := ih (m + 1)
      use 4 * (k1 : ℤ) - k2
      replace h1 : (↑(2 * m)! * ↑(2 * n)! : ℤ) = ↑(m!) * ↑(n!) * ↑(m + n)! * k1 := by exact_mod_cast h1
      replace h2 : (↑(2 * m + 2)! * ↑(2 * n)! : ℤ) = ↑(m + 1)! * ↑(n!) * ↑(m + n + 1)! * k2 := by exact_mod_cast h2
      have m_pos : (↑m + 1 : ℤ) ≠ 0 := by exact_mod_cast Nat.succ_ne_zero m
      apply mul_left_cancel₀ m_pos
      rw [Nat.factorial_succ (2 * n + 1), Nat.factorial_succ (2 * n), show 2 * n + 2 = 2 * (n + 1) by ring]
      rw [Nat.factorial_succ n, Nat.factorial_succ (m + n), Nat.factorial_succ (2 * m + 1), Nat.factorial_succ (2 * m), show 2 * m + 2 = 2 * (m + 1) by ring] at h2
      rw [Nat.factorial_succ m] at h2
      push_cast at h1 h2 ⊢
      linear_combination (m + 1) * (n + 1) * (m + n + 1) * 4 * h1 - (n + 1) * h2
    exact_mod_cast h
