import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that $(2m)!(2n)!$ is a multiple of $m!n!(m+n)!$ for any non-negative integers $m$ and $n$. -/
@[imo_problem_subject number_theory]
theorem imo_1972_p3 (m n : ℕ) : m ! * n ! * (m + n)! ∣ (2 * m)! * (2 * n)! := by
  by_cases h : (2 * m).factorial * (2 * n).factorial = 0
  · simp [h]
  · apply Nat.dvd_of_multiplicity_le
    intro p hp
    if hpm : p.Prime then
      rw [multiplicity.mul hpm, multiplicity.mul hpm, multiplicity.mul hpm,
        Nat.Prime.multiplicity_factorial hpm, Nat.Prime.multiplicity_factorial hpm,
        Nat.Prime.multiplicity_factorial hpm, Nat.Prime.multiplicity_factorial hpm,
        Nat.Prime.multiplicity_factorial hpm]
      repeat rw [← Nat.cast_add]
      apply ENat.coe_le_coe.mpr
      let N := m + n + (2 * m) + (2 * n)
      rw [Nat.Factorial.sum_factorial_multiplicity hpm (m + n) (by omega),
          Nat.Factorial.sum_factorial_multiplicity hpm m (by omega),
          Nat.Factorial.sum_factorial_multiplicity hpm n (by omega),
          Nat.Factorial.sum_factorial_multiplicity hpm (2 * m) (by omega),
          Nat.Factorial.sum_factorial_multiplicity hpm (2 * n) (by omega)]
      apply Finset.sum_le_sum
      intro i hi
      if hi0 : i = 0 then
        simp [hi0]
      else
        let d := p ^ i
        have hd : d > 0 := Nat.pos_of_gt (Nat.one_le_pow i p hpm.pos)
        have h1 : (m + n) / d = m / d + n / d + (m % d + n % d) / d := Nat.add_div m n hd
        have h2 : (2 * m) / d = 2 * (m / d) + (2 * (m % d)) / d := Nat.mul_div 2 m hd
        have h3 : (2 * n) / d = 2 * (n / d) + (2 * (n % d)) / d := Nat.mul_div 2 n hd
        rw [h1, h2, h3]
        have : (m % d + n % d) / d ≤ (2 * (m % d)) / d + (2 * (n % d)) / d := by
          let r1 := m % d
          let r2 := n % d
          have r1_lt : r1 < d := Nat.mod_lt m hd
          have r2_lt : r2 < d := Nat.mod_lt n hd
          by_cases h_sum : r1 + r2 < d
          · rw [Nat.div_eq_of_lt h_sum]; exact Nat.zero_le _
          · have : 1 ≤ (2 * r1) / d + (2 * r2) / d := by
              have : d ≤ r1 + r2 := Nat.le_of_not_lt h_sum
              if hr1 : 2 * r1 < d then
                have : d ≤ 2 * r2 := by omega
                have : 1 ≤ (2 * r2) / d := Nat.le_div_iff_mul_le hd |> mpr this
                omega
              else
                have : 1 ≤ (2 * r1) / d := Nat.le_div_iff_mul_le hd |> mpr (Nat.le_of_not_lt hr1)
                omega
            have : (r1 + r2) / d = 1 := by
              apply Nat.div_eq_of_lt_le (by omega) (by omega)
            omega
        omega
    else
      rw [multiplicity.not_prime _ hpm]; simp
