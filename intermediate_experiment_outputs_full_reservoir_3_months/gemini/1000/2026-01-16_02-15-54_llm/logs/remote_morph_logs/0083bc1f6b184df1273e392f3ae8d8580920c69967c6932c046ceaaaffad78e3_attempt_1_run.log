/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf zero_lt_one
  obtain ⟨M, hM⟩ := (hf.uniformContinuous.continuous.continuousOn (Set.Icc 0 l)).exists_forall_norm_le
    isCompact_Icc (nonempty_Icc.mpr hl.pos.le)
  use M + 1
  intro x
  obtain ⟨y, hy, ht⟩ := hl (-x)
  have hxy : x + (-x + y) = y := by ring
  specialize ht x
  rw [hxy] at ht
  calc ‖f x‖ = ‖f y - (f y - f x)‖ := by ring
    _ ≤ ‖f y‖ + ‖f y - f x‖ := norm_sub_le _ _
    _ ≤ M + 1 := add_le_add (hM y ⟨hy.1, hy.2.le⟩) ht
```
