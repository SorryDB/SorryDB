/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf zero_lt_one
  obtain ⟨M, hM⟩ := hf.uniformContinuous.continuous.continuousOn.exists_forall_norm_le (isCompact_Icc (a := 0) (b := l))
  refine ⟨M + 1, fun x ↦ ?_⟩
  obtain ⟨y, hy, ht⟩ := hl (-x)
  calc
    ‖f x‖ = ‖f y - (f y - f x)‖ := by rw [sub_sub_self]
    _ ≤ ‖f y‖ + ‖f y - f x‖ := norm_sub_le _ _
    _ = ‖f y‖ + ‖f (x + (-x + y)) - f x‖ := by rw [add_neg_cancel_left]
    _ ≤ M + 1 := add_le_add (hM y $ Set.mem_Icc_of_Ico hy) (ht x)

