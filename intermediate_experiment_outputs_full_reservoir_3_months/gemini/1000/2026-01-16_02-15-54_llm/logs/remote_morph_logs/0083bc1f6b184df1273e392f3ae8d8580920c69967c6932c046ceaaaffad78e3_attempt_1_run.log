/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf zero_lt_one
  obtain ⟨M, -, hM⟩ := isCompact_Icc.exists_forall_ge (nonempty_Icc.mpr hl.pos.le)
    (hf.uniformContinuous.continuous.norm.continuousOn _)
  refine ⟨‖f M‖ + 1, fun x ↦ ?_⟩
  obtain ⟨y, hy, ht⟩ := hl (-x)
  have h := ht x
  rw [add_neg_cancel_left] at h
  exact (norm_le_insert' (f y) (f x)).trans (add_le_add (hM y <| Set.mem_Icc_of_Ico hy) h)
