/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf zero_lt_one
  obtain ⟨y₀, -, hM⟩ := isCompact_Icc.exists_isMaxOn (Set.nonempty_Icc.mpr hl.pos.le)
    hf.uniformContinuous.continuous.norm.continuousOn
  refine ⟨1 + ‖f y₀‖, fun x ↦ ?_⟩
  obtain ⟨y, hy, hper⟩ := hl (-x)
  calc
    ‖f x‖ ≤ ‖f x - f y‖ + ‖f y‖ := norm_le_sub_add _ _
    _ = ‖f (x + (-x + y)) - f x‖ + ‖f y‖ := by rw [add_neg_cancel_left, norm_sub_rev]
    _ ≤ 1 + ‖f y₀‖ := add_le_add (hper x) (hM <| Set.Ico_subset_Icc_self hy)
