/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf zero_lt_one
  obtain ⟨y₀, _, hM⟩ := (isCompact_Icc (a := 0) (b := l)).exists_isMaxOn
    ⟨0, le_rfl, hl.pos.le⟩ hf.uniformContinuous.continuous.norm.continuousOn
  refine ⟨1 + ‖f y₀‖, fun x ↦ ?_⟩
  obtain ⟨y, hy, ht⟩ := hl (-x)
  have : ‖f x - f y‖ ≤ 1 := by rw [norm_sub_rev, ← add_neg_cancel_left x y]; exact ht x
  calc ‖f x‖ = ‖(f x - f y) + f y‖ := by rw [sub_add_cancel]
    _ ≤ ‖f x - f y‖ + ‖f y‖ := norm_add_le ..
    _ ≤ 1 + ‖f y₀‖ := add_le_add this (hM ⟨hy.1, hy.2.le⟩)
```
