/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf one_pos
  obtain ⟨y₀, -, hy₀⟩ := isCompact_Icc (a := 0) (b := l).exists_isMaxOn
    (Set.nonempty_Icc.mpr hl.pos.le) hf.uniformContinuous.continuous.norm.continuousOn
  refine ⟨‖f y₀‖ + 1, fun x ↦ ?_⟩
  obtain ⟨y, hy, ht⟩ := hl (-x)
  have h : ‖f y - f x‖ ≤ 1 := by simpa [add_neg_cancel_left] using ht x
  calc ‖f x‖ ≤ ‖f x - f y‖ + ‖f y‖ := norm_le_sub_add_norm ..
    _ = ‖f y - f x‖ + ‖f y‖ := by rw [norm_sub_rev]
    _ ≤ 1 + ‖f y₀‖ := add_le_add h (hy₀ y <| Set.mem_Icc_of_Ico hy)
