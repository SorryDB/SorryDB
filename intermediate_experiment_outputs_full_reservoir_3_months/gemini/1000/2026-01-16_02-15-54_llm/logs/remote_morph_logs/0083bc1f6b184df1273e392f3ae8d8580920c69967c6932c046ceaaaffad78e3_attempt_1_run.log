/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C := by
  obtain ⟨l, hl⟩ := hf zero_lt_one
  obtain ⟨C, hC⟩ := (isCompact_Icc : IsCompact (Icc 0 l)).exists_forall_norm_le hf.uniformContinuous.continuous.continuousOn
  refine ⟨C + 1, fun x ↦ ?_⟩
  obtain ⟨y, hy, ht⟩ := hl (-x)
  calc
    ‖f x‖ = ‖f y - (f y - f x)‖ := by rw [sub_sub_self]
    _ ≤ ‖f y‖ + ‖f y - f x‖ := norm_sub_le _ _
    _ ≤ C + 1 := add_le_add (hC y ⟨hy.1, hy.2.le⟩) (by simpa [add_neg_cancel_left] using ht x)
```
