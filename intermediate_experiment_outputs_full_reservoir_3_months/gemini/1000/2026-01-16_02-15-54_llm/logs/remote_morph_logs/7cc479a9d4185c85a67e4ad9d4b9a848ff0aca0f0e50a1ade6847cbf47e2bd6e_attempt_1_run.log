namespace LessEqThan
/-
template LessEqThan(n) {
    signal input in[2];
    signal output out;

    component lt = LessThan(n);

    lt.in[0] <== in[0];
    lt.in[1] <== in[1]+1;
    lt.out ==> out;
}
-/
def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp_all only [circuit_norm, LessThan.circuit, Prod.mk.injEq]
    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith
    rw [ZMod.val_add_of_lt hy, ZMod.val_one] at h_holds
    by_cases hy : y.val + 1 = 2^n
    case neg =>
      specialize h_holds (by omega)
      simp_all [Nat.lt_add_one_iff]
    case pos =>
      have hx : ZMod.val x < 2^n := assumptions.1
      simp only [hy, hx, Nat.le_of_lt_succ, Nat.lt_succ_iff, ite_true]
      have h_holds_main : (LessThan.main n hn).holds i env (x, y + 1) := by
        simp only [LessThan.circuit, circuit_norm] at h_holds
        exact h_holds.2
      simp only [LessThan.main, Num2Bits.circuit, circuit_norm] at h_holds_main
      rcases h_holds_main with ⟨h_bits, h_out⟩
      rw [h_out, hy, sub_eq_add_neg, add_assoc, add_neg_cancel, add_zero]
      have hx_lt : ZMod.val x < 2^n := assumptions.1
      have hx_bit : (ZMod.val x).testBit n = false := Nat.testBit_eq_false_of_lt hx_lt
      unfold fieldToBits toBits at h_bits
      apply congrArg (fun v => v[n]) at h_bits
      simp only [Vector.getElem_map, Vector.getElem_mapRange, Nat.cast_ite, Nat.cast_one,
        Nat.cast_zero, hx_bit, ↓reduceIte] at h_bits
      rw [h_bits, neg_zero, add_zero]

  completeness := by
    circuit_proof_start
    simp only [circuit_norm, LessThan.circuit] at *
    rcases h_assumptions with ⟨hx, hy⟩
    have hx_eval : Expression.eval env input_var.1 = input.1 := by
      simpa using congrArg Prod.fst h_input
    have hy_eval : Expression.eval env input_var.2 = input.2 := by
      simpa using congrArg Prod.snd h_input
    simp [hx_eval, hy_eval] at *
    have h1 : (input.2 + 1).val < 2^(n+1) := by
      have : (input.2 + 1).val ≤ input.2.val + 1 := ZMod.val_add_le _ _
      have : input.2.val + 1 ≤ 2^n := by omega
      have : 2^n < 2^(n+1) := by gcongr; repeat linarith
      omega
    have h2 : input.1.val < 2^(n+1) := by
      have : 2^n < 2^(n+1) := by gcongr; repeat linarith
      omega
    constructor
    · constructor
      · exact hx
      · have : (input.2 + 1).val ≤ input.2.val + 1 := ZMod.val_add_le _ _
        omega
    · have h_lt := (LessThan.circuit n hn).completeness i env (input.1, input.2 + 1) (by simp) (by
        constructor
        · exact hx
        · have : (input.2 + 1).val < 2^n ∨ (input.2 + 1).val = 2^n := by
            have : (input.2 + 1).val ≤ input.2.val + 1 := ZMod.val_add_le _ _
            omega
          cases this with
          | inl h_lt => exact h_lt
          | inr h_eq =>
            -- If Assumptions of LessThan are not met, completeness must be shown manually
            simp only [LessThan.main, Num2Bits.circuit, circuit_norm]
            refine ⟨?_, ?_⟩
            · rw [h_eq, sub_eq_add_neg, add_assoc, add_neg_cancel, add_zero]
              have hx_lt : input.1.val < 2^(n+1) := by
                have : 2^n < 2^(n+1) := by gcongr; repeat linarith
                omega
              simpa [sub_eq_add_neg] using hx_lt
            · rw [h_eq, sub_eq_add_neg, add_assoc, add_neg_cancel, add_zero]
              have hx_bit : (input.1.val).testBit n = false := Nat.testBit_eq_false_of_lt hx
              unfold fieldToBits toBits
              simp [hx_bit] )
      simp only [LessThan.circuit, circuit_norm] at h_lt
      exact h_lt.2

end LessEqThan
