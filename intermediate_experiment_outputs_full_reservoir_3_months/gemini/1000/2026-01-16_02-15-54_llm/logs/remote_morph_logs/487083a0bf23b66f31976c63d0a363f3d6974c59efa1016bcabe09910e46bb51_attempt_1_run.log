--- If an expression can be converted to an affine expression, then their evaluations are the same.
theorem ofExpression_correct (p : ℕ) (e : Expression p) (ae : AffineExpression p) :
  some ae = AffineExpression.ofExpression? e
  → ae.eval = e.eval := by
  intro h
  induction e generalizing ae with
  | const n => injection h with h; subst h; rfl
  | var x => injection h with h; subst h; rfl
  | add e1 e2 ih1 ih2 =>
    simp [AffineExpression.ofExpression?] at h; split at h; next v1 v2 =>
    injection h with h; subst ae; funext env; rw [ih1 v1 rfl, ih2 v2 rfl]
    simp [AffineExpression.eval, Add.add]
  | mul e1 e2 ih1 ih2 =>
    simp [AffineExpression.ofExpression?] at h; split at h; next v1 v2 =>
    simp [mul?] at h; split at h <;> injection h with h <;> subst ae <;> funext env
    all_goals
      rw [ih1 v1 rfl, ih2 v2 rfl]
      simp [AffineExpression.eval, mul_by_number, AffineExpression.toConstant?]
      try (split at *; simp_all [AffineExpression.eval])
```
