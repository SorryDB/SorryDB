/- The Ackermann function, defined using pattern matching notation. -/
def A : ℕ → ℕ → ℕ
| 0,     n     => n + 1
| m + 1, 0     => A m 1
| m + 1, n + 1 => A m (A (m + 1) n)

def myA : ℕ → ℕ → ℕ :=
  Nat.rec (motive := fun _ => ℕ → ℕ) (fun n => n + 1)
    (fun _ f => Nat.rec (motive := fun _ => ℕ) (f 1) (fun _ prev => f prev))

example : A = myA := by
  funext m n
  induction m generalizing n with
  | zero => rfl
  | succ m ih =>
    induction n with
    | zero => rw [A, ih]; rfl
    | succ n ih' => rw [A, ih', ih]; rfl
```
