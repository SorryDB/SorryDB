          cases l with
          | nil =>
            cases r with | nil => contradiction | cons b bs =>
            simp [fromSL, tailSL, nil, headSL] at *
            cases ok.1 (by rfl) with | inl h => simp_all | inr h => simp [h] at *; simp_all
          | cons a as => by_cases h : as = [] <;> simp [tailSL, h, splitInTwoSL, fromSL, headSL] at *
        rw [h_f, dropWhile]; simp
        if hp : p hsl then simp [hp, ih (tailSL sl) (length_tail_lt_length sl (by intro h_n; subst h_n; simp [headSL] at h_h))]
        else simp [hp]
