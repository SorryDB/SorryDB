example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  induction sl using dropWhileSL.induct p with
  | h1 sl h =>
    simp [dropWhileSL, h]; cases sl; simp [isEmpty] at h; simp [fromSL, h.1, h.2, dropWhile]
  | h2 sl h1 hsl h2 h3 ih =>
    unfold dropWhileSL; simp [h1, h2, h3]
    have hh : (fromSL sl).head? = some hsl := by
      cases sl; simp [headSL, fromSL] at *; split at h2 <;> simp_all
    have ht : (fromSL sl).tail = fromSL (tailSL sl) := by
      cases sl; rename_i as bs ok; unfold tailSL fromSL
      split <;> rename_i has
      · cases ok.1 has with | inl h => simp [h] | inr h =>
          cases bs with | nil => simp at h | cons x xs => cases xs with | nil => simp | cons y ys => simp at h
      · split <;> rename_i has2
        · unfold splitInTwoSL fromSL; simp; cases p : List.MergeSort.Internal.splitInTwo ⟨bs.reverse, rfl⟩
          simp [List.MergeSort.Internal.splitInTwo] at p; simp [p, List.take_append_drop]
        · cases as <;> simp_all
    match hfs : fromSL sl with
    | [] => simp [hfs] at hh
    | x :: xs => simp [hfs] at hh ht; subst x; simp [dropWhile, h3, ih, ht]
  | h3 sl h1 hsl h2 h3 =>
    unfold dropWhileSL; simp [h1, h2, h3]
    have hh : (fromSL sl).head? = some hsl := by
      cases sl; simp [headSL, fromSL] at *; split at h2 <;> simp_all
    match hfs : fromSL sl with
    | [] => simp [hfs] at hh
    | x :: xs => simp [hfs] at hh; subst x; simp [dropWhile, h3, hfs]
