def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    intro I B hI hImax hBmax
    classical
    by_contra hno
    have hBI : B ⊆ I := by
      intro x hxB
      by_contra hxI
      exact hno ⟨x, ⟨hxB, hxI⟩, hI⟩
    have hImax' : Maximal (fun S => ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)) I := by
      refine ⟨hI, ?_⟩
      intro J hJ hIJ
      have hJI : J ⊆ I := by
        intro x hxJ
        by_contra hxI
        have : x ∈ J \ I := ⟨hxJ, hxI⟩
        exact hno ⟨x, this, hJ⟩
      exact le_antisymm hIJ (by
        intro x hxI
        exact hJI hxI)
    exact (hBmax.1.2 hImax' (le_trans hBI (by intro x hxI; exact hxI))).elim
