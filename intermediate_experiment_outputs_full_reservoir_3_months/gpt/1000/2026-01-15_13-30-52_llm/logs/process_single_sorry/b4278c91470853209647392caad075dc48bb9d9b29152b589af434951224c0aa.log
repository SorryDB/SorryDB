        (g := (fun _ => (0 : ℂ))) (by
          refine (ae_of_all _)?_; intro z; simp [hf0 z]))
    have hR : ‖x‖ * ‖y‖ * C ≥ 0 := by
      have : ‖x‖ * ‖y‖ ≥ 0 := mul_nonneg (norm_nonneg x) (norm_nonneg y)
      exact mul_nonneg this (le_of_lt hC)
    simpa [hint] using (le_trans (by simpa using (norm_nonneg (0 : ℂ))) hR)
  · have hC' : 0 ≤ C := le_of_not_gt hC
    have habs : ∀ z : spectrum ℂ a, ‖f z‖ ≤ ‖(fun z => (C : ℂ)) z‖ := by
      intro z
      simpa using (le_trans (hf_bounded z) (by simpa using (le_abs_self C)))
    have :=
      (ComplexMeasure.norm_integral_le_integral_norm (μ := cfc_toComplexMeasure ha x y) (f := f))
    have hvar :
        (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := by
      simpa using (cfc_variation_toComplexMeasure_bounded (ha := ha) x y)
    have hI :
        (cfc_toComplexMeasure ha x y).variation.integral (fun z => ‖f z‖) ≤
          (cfc_toComplexMeasure ha x y).variation Set.univ * C := by
      have hmeas : Measurable fun z => ‖f z‖ := (Continuous.measurable (continuous_norm)).comp hX
      have hbound : ∀ z, (fun z => ‖f z‖) z ≤ C := by
        intro z
        exact hf_bounded z
      simpa [MeasureTheory.integral_const] using
        (MeasureTheory.integral_le_const (μ := (cfc_toComplexMeasure ha x y).variation)
          (f := fun z => ‖f z‖) (C := C) hmeas hbound)
    have :
        ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤
          (cfc_toComplexMeasure ha x y).variation Set.univ * C := by
      refine le_trans this ?_
      exact le_trans hI (by
        have hn : 0 ≤ C := hC'
        have := mul_le_mul_of_nonneg_right hvar hn
        simpa [mul_assoc] using this)
    nlinarith [this]
