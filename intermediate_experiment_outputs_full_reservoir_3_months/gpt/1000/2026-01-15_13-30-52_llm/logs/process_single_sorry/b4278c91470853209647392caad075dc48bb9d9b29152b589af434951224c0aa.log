      have : (‖f z‖ : ℝ) < 0 := lt_of_le_of_lt this hC
      exact (not_lt_of_ge (norm_nonneg (f z)) this).elim
    have hint : (cfc_toComplexMeasure ha x y).integral f = 0 := by
      classical
