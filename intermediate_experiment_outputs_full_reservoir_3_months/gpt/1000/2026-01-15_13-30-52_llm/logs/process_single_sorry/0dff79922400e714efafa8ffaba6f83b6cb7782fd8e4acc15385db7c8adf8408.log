import Game.Levels.L22Pset.L02

open Finset Set

World "L22Pset"
Level 3
Title "Differentiability Exercise"
Introduction "
# Level 3: Differentiability Exercise

Show that `x ↦ x ^ 3` is differentiable.

"

/-- Prove this
-/
Statement : ∃ g : ℝ → ℝ,
  FunDeriv (fun x ↦ x ^ 3) g := by
use (fun x ↦ 3 * x ^ 2)
intro x ε hε
let δ : ℝ := min 1 (ε / (3 * |x| + 1))
have δ_le1 : δ ≤ 1 := by bound
have δ_le2 : δ ≤ ε / (3 * |x| + 1) := by bound
have δpos : 0 < δ := by
  have h1 : (0 : ℝ) < (1 : ℝ) := by linarith
  have hden : (0 : ℝ) < 3 * |x| + 1 := by nlinarith [abs_nonneg x]
  have h2 : (0 : ℝ) < ε / (3 * |x| + 1) := by
    exact div_pos hε hden
  simpa [δ] using lt_min h1 h2
```
