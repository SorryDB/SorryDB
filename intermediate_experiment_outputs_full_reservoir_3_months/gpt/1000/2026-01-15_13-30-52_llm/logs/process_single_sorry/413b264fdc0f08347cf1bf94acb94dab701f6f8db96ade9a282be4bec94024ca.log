lemma partials_helper1 {pbar : Pose} {ε : ℝ} {poly : GoodPoly}
    (pc : GlobalTheoremPrecondition poly pbar ε) :
    ‖pc.S‖ * nth_partial 1 pc.fu pbar.innerParams =
    ⟪pbar.rotR (pbar.rotM₁θ pc.S), pc.w⟫ := by
  have := pc.norm_S_ne_zero
  simp only [nth_partial, GlobalTheoremPrecondition.fu, Fin.isValue]
  change ‖pc.S‖ * (fderiv ℝ (rotproj_inner_unit pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 1 1) = _
  have hf : DifferentiableAt ℝ (rotproj_inner pc.S pc.w) pbar.innerParams := by
    fun_prop
  have hnorm : (‖pc.S‖ : ℝ) ≠ 0 := by exact pc.norm_S_ne_zero
  have hnorm' : (‖pc.S‖⁻¹ : ℝ) ≠ 0 := inv_ne_zero hnorm
  have hmul : (‖pc.S‖ : ℝ) * (‖pc.S‖⁻¹ : ℝ) = 1 := by
    field_simp [hnorm]
  unfold rotproj_inner_unit rotprojRM
  convert_to
      ‖pc.S‖ *
        (fderiv ℝ (‖pc.S‖⁻¹ • (rotproj_inner pc.S pc.w)) pbar.innerParams)
            (EuclideanSpace.single 1 1)
        = ⟪pbar.rotR (pbar.rotM₁θ pc.S), pc.w⟫ := by
    conv =>
      lhs; arg 2; arg 1; ext x
      simp only [Pi.smul_apply, smul_eq_mul]
      rw [inv_mul_eq_div]
  rw [(hf.hasFDerivAt.const_smul ‖pc.S‖⁻¹).fderiv]
  simp only [ContinuousLinearMap.coe_smul', Pi.smul_apply, smul_eq_mul]
  have :
      ‖pc.S‖ *
          (‖pc.S‖⁻¹ *
              (fderiv ℝ (rotproj_inner pc.S pc.w) pbar.innerParams)
                (EuclideanSpace.single 1 1))
        =
      (fderiv ℝ (rotproj_inner pc.S pc.w) pbar.innerParams) (EuclideanSpace.single 1 1) := by
    ring_nf
    simp [hmul]
  rw [this]
  rw [HasFDerivAt.rotproj_inner pbar pc.S pc.w |>.fderiv]
  simp [rotproj_inner']
