import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1959_p1
  (n : ℕ)
  (h₀ : 0 < n) :
  Nat.gcd (21*n + 4) (14*n + 3) = 1 := by
  have h1 : Nat.gcd (21 * n + 4) (14 * n + 3) = Nat.gcd (21 * n + 4 - (14 * n + 3)) (14 * n + 3) := by
    simpa [Nat.gcd_eq_gcd_ab] using (Nat.gcd_eq_gcd_sub_left (21 * n + 4) (14 * n + 3))
  have h2 : Nat.gcd (21 * n + 4) (14 * n + 3) = Nat.gcd (7 * n + 1) (14 * n + 3) := by
    simpa [h1, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm, Nat.add_assoc, Nat.add_left_comm,
      Nat.add_comm, Nat.sub_eq_iff_eq_add] using h1
  have h3 : Nat.gcd (7 * n + 1) (14 * n + 3) = Nat.gcd (7 * n + 1) ((14 * n + 3) - 2 * (7 * n + 1)) := by
    simpa [Nat.gcd_eq_gcd_ab] using (Nat.gcd_eq_gcd_sub_right (7 * n + 1) (14 * n + 3) (2 * (7 * n + 1)))
  have h4 : Nat.gcd (7 * n + 1) (14 * n + 3) = Nat.gcd (7 * n + 1) 1 := by
    have : (14 * n + 3) - 2 * (7 * n + 1) = 1 := by
      ring
    simpa [h3, this]
  simpa [h2, h4]
```
