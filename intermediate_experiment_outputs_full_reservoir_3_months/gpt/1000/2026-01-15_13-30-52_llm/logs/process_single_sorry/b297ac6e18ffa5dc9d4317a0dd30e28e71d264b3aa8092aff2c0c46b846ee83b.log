  have h2 : ((7 % 17) * 8) % 17 = 5 := by decide
  have hL :
      ((7 % 17) * (5 % 17) * (n % 17)) % 17 =
        ((7 % 17) * ((5 * (n % 17)) % 17)) % 17 := by
    simp [Nat.mul_mod, Nat.mod_mod, Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]
  have hR :
      ((7 % 17) * (5 % 17) * (n % 17)) % 17 = ((7 % 17) * 8) % 17 := by
    simpa [hL] using hmul
  have : (n % 17) % 17 = 5 := by
    have : ((1 * (n % 17)) % 17) = 5 := by
      simpa [h1, Nat.mul_assoc, Nat.mul_mod, Nat.mod_mod] using (by simpa [h2] using hR)
    simpa [Nat.one_mul] using this
  simpa [Nat.mod_mod] using this
