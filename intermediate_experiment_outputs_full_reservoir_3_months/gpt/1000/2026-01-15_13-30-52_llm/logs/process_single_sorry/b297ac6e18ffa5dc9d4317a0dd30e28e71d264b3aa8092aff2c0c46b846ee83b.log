  have h₀' : (5 * (n % 17)) % 17 = 8 := by
    simpa [Nat.mul_mod, Nat.mod_mod] using h₀
  have hmul : ((7 % 17) * ((5 * (n % 17)) % 17)) % 17 = ((7 % 17) * 8) % 17 := by
