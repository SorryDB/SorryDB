example {α : Type} (t : Tree α) :
  t.height ≤ t.size ∧ t.size < 2 ^ t.height := by
  apply And.intro
  {
   induction t with
   | null  => simp [Tree.height, Tree.size]
   | node t₁ x t₂ ihl ihr =>
     simp [Tree.height, Tree.size]
     sorry
  }
  {
  induction t with
  | null => simp [Tree.height, Tree.size]
  | node t₁ x t₂ ihl ihr =>
    simp [Tree.height, Tree.size]
    have hlt : t₁.size < 2 ^ max t₁.height t₂.height :=
      lt_of_lt_of_le ihl (pow_le_pow_of_le_left (by decide) (le_max_left _ _))
    have hrt : t₂.size < 2 ^ max t₁.height t₂.height :=
      lt_of_lt_of_le ihr (pow_le_pow_of_le_left (by decide) (le_max_right _ _))
    have hsum : t₁.size + t₂.size < 2 ^ max t₁.height t₂.height + 2 ^ max t₁.height t₂.height :=
      add_lt_add hlt hrt
    have hsum' : 1 + t₁.size + t₂.size < 2 ^ max t₁.height t₂.height + (2 ^ max t₁.height t₂.height + 1) := by
      nlinarith
    have hpow : 2 ^ (1 + max t₁.height t₂.height) = 2 ^ max t₁.height t₂.height + 2 ^ max t₁.height t₂.height := by
      simp [pow_succ, two_mul]
    have hone : 2 ^ max t₁.height t₂.height + (2 ^ max t₁.height t₂.height + 1) ≤
        2 ^ max t₁.height t₂.height + (2 ^ max t₁.height t₂.height + 2 ^ max t₁.height t₂.height) := by
      have : 1 ≤ 2 ^ max t₁.height t₂.height := by
        simpa using (Nat.succ_le_iff.mp (Nat.succ_le_succ (Nat.zero_le _)))
      nlinarith
    have : 1 + t₁.size + t₂.size < 2 ^ max t₁.height t₂.height + (2 ^ max t₁.height t₂.height + 2 ^ max t₁.height t₂.height) :=
      lt_of_lt_of_le hsum' hone
    simpa [hpow, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this
