lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  classical
  refine lt_of_le_of_ne (refinement_le (D := D) B hB hB' hB'') ?_
  intro hEq
  rcases H with ⟨N, hN, hne⟩
  have hmemN : N ∈ refinement (D := D) B hB hB' hB'' := by
    have : N ∈ B N hN := by
      by_contra hNnot
      have hle : sSup (B N hN) ≤ N := by
        apply sSup_le
        intro x hx
        have : x = ⊥ := by
          apply (hB' N hN).eq_bot_of_mem_of_not_mem
          · exact hx
          · exact hNnot
        simpa [this] using (bot_le : (⊥ : PersistenceSubmodule M) ≤ N)
      have hbot : N = ⊥ := by
        apply le_antisymm
        · simpa [hB N hN] using hle
        · exact bot_le
      exact D.not_bot_mem (hbot ▸ hN)
    exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨this, rfl⟩⟩⟩⟩
  have hsubset : (B N hN) ⊆ D := by
    intro x hx
    have hx' : x ∈ refinement (D := D) B hB hB' hB'' := by
      exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, Set.mem_iUnion.mpr ⟨x, Set.mem_iUnion.mpr ⟨hx, rfl⟩⟩⟩⟩
    have : x ∈ D := by simpa [hEq] using hx'
    exact this
  have hBsub_singleton : B N hN ⊆ {N} := by
    intro x hx
    have hxD : x ∈ D := hsubset x hx
    have hxle : x ≤ N := by
      have : x ≤ sSup (B N hN) := le_sSup hx
      simpa [hB N hN] using this
    have hdisj : Disjoint x N := (D.sSupIndep.pairwiseDisjoint hxD hN (by
      intro hEqx
      exact hne (hEqx ▸ by ext y; simp)))
    have : x = ⊥ := by
      apply Disjoint.eq_bot_of_le
      · exact hdisj
      · exact hxle
    exfalso
    exact hB'' N hN (this ▸ hx)
  have : B N hN = {N} := by
    apply Set.Subset.antisymm
    · exact hBsub_singleton
    · intro x hx
      simpa [Set.mem_singleton_iff] using hx
  exact hne this
