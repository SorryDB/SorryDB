                | zero =>
                    simpa using hperm
                | succ idx2 =>
                    have hx : x ∈ x :: l₂ := by simp
                    have hx' : x ∈ x :: l₂.eraseIdx idx2 := by
                      have : x ∈ x :: l₂.eraseIdx idx2 := by simp
                      exact this
                    have : x ∈ x :: l₂.eraseIdx idx2 := by simp
                    have : False := by
                      simpa [List.getElem_cons_zero] using heq
                    contradiction
            | succ idx1 =>
                cases idx2 using Fin.cases with
                | zero =>
                    have : False := by
                      simpa [List.getElem_cons_zero] using heq.symm
                    contradiction
                | succ idx2 =>
                    have h' : l₁[idx1] = l₂[idx2] := by
                      simpa using heq
                    have := ih (idx1 := idx1) (idx2 := idx2) h'
                    simpa using this
