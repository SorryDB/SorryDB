/-- Any diffeological manifold is also a diffeological manifold with boundary. -/
instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  classical
  let ⟨u,hu,hxu,i,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  refine ⟨u, hu, hxu, (), (fun y : Eucl n ↦ (⟨y, by simpa using (le_of_eq rfl)⟩ : {x : Eucl n | 0 ≤ x 0})) '' v, ?_, ⟨?_⟩⟩
  ·
    let f : Eucl n → {x : Eucl n | 0 ≤ x 0} := fun y ↦ ⟨y, by simpa using (le_of_eq rfl)⟩
    have hf : Continuous f := by
      refine continuous_subtype_mk ?_ ?_
      · simpa using (continuous_id : Continuous fun y : Eucl n ↦ y)
      · intro y; rfl
    simpa [f] using (hf.isOpenMap _ hv)
  ·
    let f : Eucl n → {x : Eucl n | 0 ≤ x 0} := fun y ↦ ⟨y, by simpa using (le_of_eq rfl)⟩
    let g : {x : Eucl n | 0 ≤ x 0} → Eucl n := fun z ↦ z.1
    have fg : Function.LeftInverse g f := by intro y; rfl
    have gf : Function.RightInverse g f := by intro z; cases z; rfl
    have f_bij : Function.Bijective f := ⟨fun a b h => by
        have : (a : Eucl n) = b := by
          have := congrArg Subtype.val h
          simpa using this
        simpa using this,
      fun z => ⟨z.1, by cases z; rfl⟩⟩
    have f_smooth : DSmooth f := by
      simpa [f] using (dsmooth_subtype_mk (dsmooth_id))
    have g_smooth : DSmooth g := by
      simpa [g] using (dsmooth_subtype_val : DSmooth fun z : {x : Eucl n | 0 ≤ x 0} ↦ z.1)
    let e0 : (Eucl n) ᵈ≃ ({x : Eucl n | 0 ≤ x 0}) :=
      { toEquiv :=
          { toFun := f
            invFun := g
            left_inv := fg
            right_inv := gf }
        dsmooth_toFun := f_smooth
        dsmooth_invFun := g_smooth }
    refine (d.trans ((e0.restrict v).trans (DDiffeomorph.Set.image _ hv))).nonempty⟩
