lemma wignerMatrixEntryFunctionSymmetric (ω : WignerSpace n) {i : Fin n} {j : Fin n} :
  wignerMatrixEntryFunction ω i j = wignerMatrixEntryFunction ω j i := by
  classical
  by_cases h : i = j
  · subst h
    simp [wignerMatrixEntryFunction]
  · have h' : j ≠ i := ne_comm.mp h
    by_cases hij : i < j
    · have hji : ¬ j < i := not_lt_of_gt hij
      simp [wignerMatrixEntryFunction, h, h', hij, hji, dif_neg hij.ne', dif_neg hji]
    · have hji : j < i := lt_of_le_of_ne (le_of_not_gt hij) h.symm
      have hij' : ¬ i < j := hij
      simp [wignerMatrixEntryFunction, h, h', hij', hji, dif_neg hji.ne', dif_neg hij']
```
