    -- `*` For an arbitrary bird `x`, if `K` is fond of `K ◁ x`,
    -- then `K` is fond of `x`.
    theorem kestrel_fondness
        (x : Bird)
        (fond_Kx : K is fond of (K ◁ x)) :
        K is fond of x := by
      have h : (K ◁ (K ◁ x)) = (K ◁ x) := fond_Kx
      have h' : (K ◁ (K ◁ x)) ◁ x = (K ◁ x) ◁ x := congrArg (fun b => b ◁ x) h
      simpa [K.call] using h'
```
