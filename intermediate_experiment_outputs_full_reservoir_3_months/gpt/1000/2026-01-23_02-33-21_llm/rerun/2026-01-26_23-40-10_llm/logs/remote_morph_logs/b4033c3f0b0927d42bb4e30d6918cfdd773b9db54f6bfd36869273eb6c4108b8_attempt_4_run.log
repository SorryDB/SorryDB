  have hpos_at_vzero : ‖(IC.trajectory S) t₀‖ =
      √(‖IC.x₀‖ ^ 2 + (‖IC.v₀‖ / S.ω) ^ 2) := by
    -- Use energy at t₀ with v=0 to solve for ‖x‖.
