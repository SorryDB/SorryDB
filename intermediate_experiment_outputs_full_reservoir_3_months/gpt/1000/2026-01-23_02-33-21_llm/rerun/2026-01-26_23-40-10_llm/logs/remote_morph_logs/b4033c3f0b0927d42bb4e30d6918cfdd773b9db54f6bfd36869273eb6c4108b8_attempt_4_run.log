  have hx0 : IC.x₀ ≠ 0 := by
    by_contra hx0
    have hv0 : IC.v₀ ≠ 0 := by
      have : IC.v₀ ≠ 0 := by
        cases hx with
        | inl h => cases (hx0 h)
        | inr h => exact h
      exact this
    exact False.elim (by exact (by trivial))
  have t₀ : Time := (arctan (IC.v₀ 0 / (S.ω * IC.x₀ 0)) / S.ω)
  have hv0t : (∂ₜ (IC.trajectory S)) t₀ = 0 :=
    trajectory_velocity_eq_zero_at_arctan (S := S) (IC := IC) hx0
  have hE_t₀ : S.energy (IC.trajectory S) t₀ =
      1/2 * (S.m * ‖IC.v₀‖ ^2 + S.k * ‖IC.x₀‖ ^ 2) := by
