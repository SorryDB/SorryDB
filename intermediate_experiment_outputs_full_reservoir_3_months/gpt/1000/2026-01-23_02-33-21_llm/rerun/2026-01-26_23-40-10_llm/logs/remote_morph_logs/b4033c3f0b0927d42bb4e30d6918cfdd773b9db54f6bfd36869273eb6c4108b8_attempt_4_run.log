        -- show both sides equal to m*‖v₀‖^2 + k*‖x₀‖^2
        calc
          S.k * ‖(IC.trajectory S) t₀‖ ^ 2
              = S.m * ‖IC.v₀‖ ^ 2 + S.k * ‖IC.x₀‖ ^ 2 := by simpa [hEq'] using hEq'.symm
          _ = S.k * (‖IC.x₀‖ ^ 2 + (‖IC.v₀‖ / S.ω) ^ 2) := by
              -- replace k and simplify
