lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := by
  ext x
  constructor
  · intro hx
    by_contra hxa
    have hx' : x ∈ A \ {a} := by
      refine And.intro hx ?_
      intro hx_eq
      exact hxa hx_eq.symm
    exact h2 x hx'
  · intro hx
    rcases hx with rfl
    exact h1
```
