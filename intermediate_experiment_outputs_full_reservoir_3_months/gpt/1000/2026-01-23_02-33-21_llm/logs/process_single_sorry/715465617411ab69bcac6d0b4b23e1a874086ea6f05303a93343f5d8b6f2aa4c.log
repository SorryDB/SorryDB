lemma singleton_of_diff_empty {U : Type} {A : Set U} {a : U}
    (h1 : a ∈ A) (h2 : empty (A \ {a})) : A = {a} := by
  apply ext
  intro x
  apply Iff.intro
  · intro hxA
    have : x = a := by
      by_contra hxa
      have hx : x ∈ A \ {a} := by
        refine And.intro hxA ?_
        intro hxIn
        exact hxa hxIn
      exact (h2 x) hx
    exact this ▸ rfl
  · intro hx
    cases hx
