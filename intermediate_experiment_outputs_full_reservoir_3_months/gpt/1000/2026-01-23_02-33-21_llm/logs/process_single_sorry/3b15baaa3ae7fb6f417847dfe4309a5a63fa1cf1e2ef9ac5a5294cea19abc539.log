    have hle : a < a + b + d := this
    have := (div_lt_div_left ha).2 hle
    simpa [div_self (ne_of_gt ha)] using this
  have h1b : b / (a + b + c) < b / b := by
    have : a + b + c > b := by linarith
    have hle : b < a + b + c := this
    have := (div_lt_div_left hb).2 hle
    simpa [div_self (ne_of_gt hb)] using this
