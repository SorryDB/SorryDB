theorem imo_1974_p5 (a b c d s : ℝ) (h₀ : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d)
  (h₁ : s = a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d)) :
  1 < s ∧ s < 2 := by
  have ha : 0 < a := h₀.1
  have hb : 0 < b := h₀.2.1
  have hc : 0 < c := h₀.2.2.1
  have hd : 0 < d := h₀.2.2.2
  have habd : 0 < a + b + d := by linarith
  have habc : 0 < a + b + c := by linarith
  have hbcd : 0 < b + c + d := by linarith
  have hacd : 0 < a + c + d := by linarith
  have hle1 :
      a / (a + b + d) ≤ 1 ∧
      b / (a + b + c) ≤ 1 ∧
      c / (b + c + d) ≤ 1 ∧
      d / (a + c + d) ≤ 1 := by
    constructor
    · have : a ≤ a + b + d := by linarith
      exact (div_le_one habd).2 this
    · constructor
      · have : b ≤ a + b + c := by linarith
        exact (div_le_one habc).2 this
      · constructor
        · have : c ≤ b + c + d := by linarith
          exact (div_le_one hbcd).2 this
        · have : d ≤ a + c + d := by linarith
          exact (div_le_one hacd).2 this
  have hs_lt_4 : s < 4 := by
    have hsumle :
        a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d) ≤ 4 := by
      nlinarith [hle1.1, hle1.2.1, hle1.2.2.1, hle1.2.2.2]
    have : s ≤ 4 := by simpa [h₁] using hsumle
    exact lt_of_le_of_ne this (by
      intro hEq
      have : a / (a + b + d) = 1 := by
        have h1 : a / (a + b + d) ≤ 1 := hle1.1
        have h0 : 0 ≤ a / (a + b + d) := by
          have : 0 ≤ a := le_of_lt ha
          exact div_nonneg this (le_of_lt habd)
        have h2 : b / (a + b + c) + c / (b + c + d) + d / (a + c + d) ≥ 0 := by
          have hb' : 0 ≤ b / (a + b + c) := div_nonneg (le_of_lt hb) (le_of_lt habc)
          have hc' : 0 ≤ c / (b + c + d) := div_nonneg (le_of_lt hc) (le_of_lt hbcd)
          have hd' : 0 ≤ d / (a + c + d) := div_nonneg (le_of_lt hd) (le_of_lt hacd)
          linarith
        have : a / (a + b + d) = 1 := by
          have hs : a / (a + b + d) = 4 - (b / (a + b + c) + c / (b + c + d) + d / (a + c + d)) := by
            have : s = a / (a + b + d) + (b / (a + b + c) + c / (b + c + d) + d / (a + c + d)) := by
              simp [h₁, add_assoc, add_left_comm, add_comm]
            linarith [hEq, this]
          have hrest_le : b / (a + b + c) + c / (b + c + d) + d / (a + c + d) ≤ 3 := by
            nlinarith [hle1.2.1, hle1.2.2.1, hle1.2.2.2]
          have hrest_ge : b / (a + b + c) + c / (b + c + d) + d / (a + c + d) ≥ 0 := h2
          have : a / (a + b + d) ≥ 1 := by linarith [hs, hrest_le]
          exact le_antisymm_iff.mp ⟨h1, this⟩
        exact this
      have habd_eq : a + b + d = a := by
        have := (div_eq_one_iff_eq habd.ne').1 this
        exact this
      linarith)
  have hs_lt_2 : s < 2 := by linarith
  have hs_gt_1 : 1 < s := by
    have h₁' : s = 4 - (b / (a + b + c) + c / (b + c + d) + d / (a + c + d)) +
        (a / (a + b + d)) := by
      ring_nf
      simp [h₁, add_assoc, add_left_comm, add_comm]
    have hrest_le : b / (a + b + c) + c / (b + c + d) + d / (a + c + d) ≤ 3 := by
      nlinarith [hle1.2.1, hle1.2.2.1, hle1.2.2.2]
    have ha_div_pos : 0 < a / (a + b + d) := by
      exact div_pos ha habd
    have : s > 1 := by
      have : s ≥ a / (a + b + d) := by
        have hb' : 0 ≤ b / (a + b + c) := div_nonneg (le_of_lt hb) (le_of_lt habc)
        have hc' : 0 ≤ c / (b + c + d) := div_nonneg (le_of_lt hc) (le_of_lt hbcd)
        have hd' : 0 ≤ d / (a + c + d) := div_nonneg (le_of_lt hd) (le_of_lt hacd)
        have : a / (a + b + d) ≤ s := by
          have := congrArg (fun t => a / (a + b + d) ≤ t) h₁
          have : a / (a + b + d) ≤ a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d) := by
            linarith
          simpa using this
        exact le_of_lt (lt_of_le_of_lt this (lt_of_lt_of_le (by linarith) (le_of_lt hs_lt_2)))
      linarith [ha_div_pos]
    exact this
  exact ⟨hs_gt_1, hs_lt_2⟩
