    have := (div_lt_div_left hc).2 hle
    simpa [div_self (ne_of_gt hc)] using this
  have h1d : d / (a + c + d) < d / d := by
    have : a + c + d > d := by linarith
    have hle : d < a + c + d := this
    have := (div_lt_div_left hd).2 hle
    simpa [div_self (ne_of_gt hd)] using this
  have hs_lt2 :
