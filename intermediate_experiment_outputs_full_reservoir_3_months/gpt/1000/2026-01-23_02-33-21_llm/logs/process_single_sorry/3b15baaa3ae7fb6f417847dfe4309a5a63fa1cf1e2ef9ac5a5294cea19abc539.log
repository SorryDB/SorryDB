import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p5 (a b c d s : ℝ) (h₀ : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d)
  (h₁ : s = a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d)) :
  1 < s ∧ s < 2 := by
  rcases h₀ with ⟨ha, hb, hc, hd⟩
  have habd : 0 < a + b + d := by linarith
  have habc : 0 < a + b + c := by linarith
  have hbcd : 0 < b + c + d := by linarith
  have hacd : 0 < a + c + d := by linarith
  have hsum_pos : 0 < (a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d)) :=
    by
      have ha' : 0 < a / (a + b + d) := by
        exact div_pos ha habd
      have hb' : 0 < b / (a + b + c) := by
        exact div_pos hb habc
      have hc' : 0 < c / (b + c + d) := by
        exact div_pos hc hbcd
      have hd' : 0 < d / (a + c + d) := by
        exact div_pos hd hacd
      linarith
  have hs_pos : 0 < s := by simpa [h₁] using hsum_pos
  have hupper : s < 2 := by
    have h1 : a / (a + b + d) < 1 := by
      have : a < a + b + d := by linarith
      exact (div_lt_one habd).2 this
    have h2 : b / (a + b + c) < 1 := by
      have : b < a + b + c := by linarith
      exact (div_lt_one habc).2 this
