lemma biasedEnergy_fixed_point_iff_no_change :
  biasedEnergyDiff net x i = 0 ↔ biasedUpdateState net x i = x := by
  constructor
  · intro h
    by_contra hx
    have hlf : biasedLocalField net x i ≠ 0 := by
      intro hlf0
      have hlt : biasedEnergyDiff net x i < 0 :=
        biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero
          (net := net) (x := x) (i := i) hx hlf0
      exact (lt_irrefl 0) (hlt.trans_eq h)
    have hlt : biasedEnergyDiff net x i < 0 :=
      biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero
        (net := net) (x := x) (i := i) hx hlf
    exact (lt_irrefl 0) (hlt.trans_eq h)
  · intro h
    simp [biasedEnergyDiff, h]
