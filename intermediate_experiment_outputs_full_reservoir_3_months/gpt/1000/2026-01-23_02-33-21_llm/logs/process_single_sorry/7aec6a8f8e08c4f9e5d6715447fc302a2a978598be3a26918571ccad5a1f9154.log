lemma biasedEnergy_decreasing : biasedEnergyDiff net x i ≤ 0 := by
  classical
  -- Use the standard Hopfield argument: energy change is `-(Δs)*localField`,
  -- and the update rule ensures `Δs` has the same sign as the local field.
  have hEq :=
    biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField (net := net) (x := x) (i := i)
  -- abbreviations
  set lf : ℝ := biasedLocalField net x i
  set Δs : ℝ := (biasedUpdateState net x i i).toReal - (x i).toReal
  have hEq' : biasedEnergyDiff net x i = -(Δs) * lf := by
    simpa [lf, Δs] using hEq
  -- split on the sign of the local field, matching the update rule
  by_cases hpos : 0 < lf
  · -- then the neuron is set to `up`, so Δs ≥ 0 and lf > 0, hence -(Δs*lf) ≤ 0
    have hup : biasedUpdateState net x i i = SpinState.up := by
      simp [biasedUpdateState, biasedLocalField, lf, hpos, Function.update]
    have hΔs_nonneg : 0 ≤ Δs := by
      -- Δs ∈ {0,2} when updating to up from {up,down}
      have : Δs = 1 - (x i).toReal := by
        simp [Δs, hup]
      -- `x i` is a spin, so its real value is ±1
      rcases (x i) <;> simp [this]
    have hmul_nonneg : 0 ≤ Δs * lf := mul_nonneg hΔs_nonneg (le_of_lt hpos)
    have : -(Δs * lf) ≤ 0 := by nlinarith
    simpa [hEq', mul_assoc, mul_left_comm, mul_comm] using this
  · by_cases hneg : lf < 0
    · -- then neuron is set to `down`, so Δs ≤ 0 and lf < 0, hence -(Δs*lf) ≤ 0
      have hdown : biasedUpdateState net x i i = SpinState.down := by
        simp [biasedUpdateState, biasedLocalField, lf, hpos, hneg, Function.update]
      have hΔs_nonpos : Δs ≤ 0 := by
        have : Δs = (-1) - (x i).toReal := by
          simp [Δs, hdown]
        rcases (x i) <;> simp [this]
      have hmul_nonneg : 0 ≤ Δs * lf := by
        -- product of two nonpositive reals is nonnegative
        have : 0 ≤ (-Δs) * (-lf) := mul_nonneg (by nlinarith) (by nlinarith)
        nlinarith
      have : -(Δs * lf) ≤ 0 := by nlinarith
      simpa [hEq', mul_assoc, mul_left_comm, mul_comm] using this
    · -- lf = 0, update leaves the state unchanged, so energy difference is 0
      have hzero : lf = 0 := by
        have : ¬ lf ≠ 0 := by
          intro hne
          have : lf < 0 ∨ 0 < lf := lt_or_gt_of_ne hne
          cases this with
          | inl hlt => exact hneg hlt
          | inr hgt => exact hpos hgt
        exact by simpa using not_ne_iff.mp this
      have hsame : biasedUpdateState net x i i = x i := by
        simp [biasedUpdateState, biasedLocalField, lf, hpos, hneg, hzero, Function.update]
      have hΔs_zero : Δs = 0 := by
        simp [Δs, hsame]
      have : biasedEnergyDiff net x i = 0 := by
        simp [hEq', hΔs_zero, hzero]
      simpa [this]
```
