    by_cases hpos : 0 < biasedLocalField net x i
    · -- update sets spin up, so the spin difference is ≥ 0
      have hup :
          biasedUpdateState net x i i = SpinState.up := by
        simp [biasedUpdateState, biasedLocalField, hpos]
      have hdiff : 0 ≤ (biasedUpdateState net x i i).toReal - (x i).toReal := by
        -- since spins are ±1, setting to +1 can only increase the value
        -- use case split on the old spin
        cases hx0 : x i <;> simp [hup, hx0]
      exact mul_nonneg hdiff (le_of_lt hpos)
    · have hnonpos : biasedLocalField net x i ≤ 0 := le_of_not_gt hpos
      by_cases hneg : biasedLocalField net x i < 0
      · -- update sets spin down, so the spin difference is ≤ 0
        have hdown :
            biasedUpdateState net x i i = SpinState.down := by
          simp [biasedUpdateState, biasedLocalField, hpos, hneg]
        have hdiff : (biasedUpdateState net x i i).toReal - (x i).toReal ≤ 0 := by
          -- setting to -1 can only decrease the value
