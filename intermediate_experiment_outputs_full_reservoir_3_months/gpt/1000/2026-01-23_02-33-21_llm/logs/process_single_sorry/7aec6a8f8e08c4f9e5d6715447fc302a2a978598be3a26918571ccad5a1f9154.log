          simpa [mul_assoc, mul_left_comm, mul_comm, neg_mul, mul_neg] using
            (mul_nonneg hdiff' hlf' : 0 ≤ (-( (biasedUpdateState net x i i).toReal - (x i).toReal)) * (-(biasedLocalField net x i)))
        exact this
