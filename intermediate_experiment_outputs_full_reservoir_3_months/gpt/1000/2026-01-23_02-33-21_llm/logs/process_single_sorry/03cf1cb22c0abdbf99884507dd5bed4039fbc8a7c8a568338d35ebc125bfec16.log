      "by\n    classical\n    have hlaw : HasLaw X Ber(u, p) P := hX\n    have hi' : Measurable (fun s : Set ι ↦ i ∈ s) := by\n      simpa using (measurable_pi_iff.1 measurable_id i)\n    have hj' : Measurable (fun s : Set ι ↦ j ∈ s) := by\n      simpa using (measurable_pi_iff.1 measurable_id j)\n    have hmapi : Measure.map (fun ω ↦ i ∈ X ω) P = Measure.map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) := by\n      simpa [HasLaw] using congrArg (Measure.map (fun s : Set ι ↦ i ∈ s)) hlaw\n    have hmapj : Measure.map (fun ω ↦ j ∈ X ω) P = Measure.map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) := by\n      simpa [HasLaw] using congrArg (Measure.map (fun s : Set ι ↦ j ∈ s)) hlaw\n    have hsingle :\n        Measure.map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) =\n          toNNReal p • Measure.dirac True + toNNReal (σ p) • Measure.dirac False := by\n      ext A hA\n      have hA' : MeasurableSet ((fun s : Set ι ↦ i ∈ s) ⁻¹' A) := hi' hA\n      simp [bernoulliOn_apply', hA, hA', hi, infinitePi_apply_finset,\n        Measure.preimage, Set.preimage_image_eq, MeasurableEquiv.setOf, cylinder, Set.image_preimage_eq_inter_range]\n    have hsingle' :\n        Measure.map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) =\n          toNNReal p • Measure.dirac True + toNNReal (σ p) • Measure.dirac False := by\n      ext A hA\n      have hA' : MeasurableSet ((fun s : Set ι ↦ j ∈ s) ⁻¹' A) := hj' hA\n      simp [bernoulliOn_apply', hA, hA', hj, infinitePi_apply_finset,\n        Measure.preimage, Set.preimage_image_eq, MeasurableEquiv.setOf, cylinder, Set.image_preimage_eq_inter_range]\n    calc\n      Measure.map (fun ω ↦ i ∈ X ω) P\n          = Measure.map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) := hmapi\n      _ = toNNReal p • Measure.dirac True + toNNReal (σ p) • Measure.dirac False := hsingle\n      _ = Measure.map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) := by symm; exact hsingle'\n      _ = Measure.map (fun ω ↦ j ∈ X ω) P := by symm; exact hmapj",
      "by\n    classical\n    rcases hX with ⟨hXm, hmap⟩\n    have hmi : Measurable fun s : Set ι ↦ i ∈ s := measurable_pi_apply i\n    have hmj : Measurable fun s : Set ι ↦ j ∈ s := measurable_pi_apply j\n    calc\n      Measure.map (fun ω ↦ i ∈ X ω) P\n          = Measure.map (fun s : Set ι ↦ i ∈ s) (Measure.map X P) := by\n              simp [Measure.map_map, hXm, hmi]\n      _ = Measure.map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) := by simp [hmap]\n      _ = (toNNReal p • dirac True + toNNReal (σ p) • dirac False) := by\n            simpa [bernoulliOn, hi] using\n              (infinitePi_map_pi_apply (μ := fun a ↦\n                toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False) i)\n      _ = Measure.map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) := by\n            simpa [bernoulliOn, hj] using\n              (infinitePi_map_pi_apply (μ := fun a ↦\n                toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False) j).symm\n      _ = Measure.map (fun s : Set ι ↦ j ∈ s) (Measure.map X P) := by simp [hmap]\n      _ = Measure.map (fun ω ↦ j ∈ X ω) P := by\n            simp [Measure.map_map, hXm, hmj]",
      "by\n    classical\n    have h := congrArg (fun μ ↦ μ {s : Set ι | i ∈ s}) hX.map_eq\n    have h' := congrArg (fun μ ↦ μ {s : Set ι | j ∈ s}) hX.map_eq\n    have hi' : Ber(u, p) {s : Set ι | i ∈ s} = toNNReal p := by\n      simpa [bernoulliOn_apply', hi] using\n        (infinitePi_apply_cylinder (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n          i {True})\n    have hj' : Ber(u, p) {s : Set ι | j ∈ s} = toNNReal p := by\n      simpa [bernoulliOn_apply', hj] using\n        (infinitePi_apply_cylinder (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n          j {True})\n    ext t ht\n    cases t using\n    | empty =>\n        simp\n    | insert a s ha =>\n        by_cases hta : a\n        · have : t = {True} := by\n            ext b; simp [Set.mem_insert_iff, hta]\n          subst this\n          have := (congrArg (fun μ ↦ μ {s : Set ι | i ∈ s}) hX.map_eq)\n          have := (congrArg (fun μ ↦ μ {s : Set ι | j ∈ s}) hX.map_eq)\n          simpa [Measure.map_apply, aemeasurable_setOf, ht, hi', hj'] using (by\n            simpa [Measure.map_apply, ht] at h\n            simpa [Measure.map_apply, ht] at h'\n            exact h.trans (hi'.trans hj'.symm) )\n        · have : t = {False} := by\n            ext b; simp [Set.mem_insert_iff, hta]\n          subst this\n          have : (map (fun ω ↦ i ∈ X ω) P) {False} = (map (fun ω ↦ j ∈ X ω) P) {False} := by\n            have hiT : (map (fun ω ↦ i ∈ X ω) P) {True} =\n                (map (fun ω ↦ j ∈ X ω) P) {True} := by\n              have h1 := congrArg (fun μ ↦ μ {s : Set ι | i ∈ s}) hX.map_eq\n              have h2 := congrArg (fun μ ↦ μ {s : Set ι | j ∈ s}) hX.map_eq\n              simpa [Measure.map_apply, ht, hi', hj'] using (by\n                simpa [Measure.map_apply] at h1\n                simpa [Measure.map_apply] at h2\n                exact h1.trans (hi'.trans (hj'.symm.trans h2.symm)) )\n            have hiProb : (map (fun ω ↦ i ∈ X ω) P) {True} + (map (fun ω ↦ i ∈ X ω) P) {False} = 1 := by\n              simpa [Measure.add_apply, Set.singleton_union, Set.singleton_inter, Set.disjoint_singleton.2 (by simp)] using\n                (measure_add_measure_compl (map (fun ω ↦ i ∈ X ω) P) {True})\n            have hjProb : (map (fun ω ↦ j ∈ X ω) P) {True} + (map (fun ω ↦ j ∈ X ω) P) {False} = 1 := by\n              simpa [Measure.add_apply, Set.singleton_union, Set.singleton_inter, Set.disjoint_singleton.2 (by simp)] using\n                (measure_add_measure_compl (map (fun ω ↦ j ∈ X ω) P) {True})\n            linarith\n          simpa using this",
      "by\n    classical\n    rcases hX with ⟨hX⟩\n    simpa [IsBernoulliOn, bernoulliOn_eq_map, Measure.map_map, Function.comp] using\n      congrArg (fun μ : Measure (Set ι) ↦ Measure.map (fun s : Set ι ↦ i ∈ s) μ) hX",
      "by\n    classical\n    rcases hX with ⟨hX⟩\n    have hX' : P.map X = Ber(u, p) := hX\n    have hi' : (Ber(u, p)).map (fun s : Set ι ↦ i ∈ s) = toNNReal p • (Measure.dirac True)\n        + toNNReal (σ p) • (Measure.dirac False) := by\n      simpa [bernoulliOn, hi] using\n        (Measure.map_comap_measurable (f := fun s : Set ι ↦ fun a ↦ a ∈ s) (g := fun f : ι → Prop ↦ f i)\n          (by\n            have : Measurable fun s : Set ι ↦ (fun a ↦ a ∈ s) := measurable_set_fun\n            simpa using this.eval i))\n    have hj' : (Ber(u, p)).map (fun s : Set ι ↦ j ∈ s) = toNNReal p • (Measure.dirac True)\n        + toNNReal (σ p) • (Measure.dirac False) := by\n      simpa [bernoulliOn, hj] using\n        (Measure.map_comap_measurable (f := fun s : Set ι ↦ fun a ↦ a ∈ s) (g := fun f : ι → Prop ↦ f j)\n          (by\n            have : Measurable fun s : Set ι ↦ (fun a ↦ a ∈ s) := measurable_set_fun\n            simpa using this.eval j))\n    calc\n      P.map (fun ω ↦ i ∈ X ω)\n          = (P.map X).map (fun s : Set ι ↦ i ∈ s) := by rfl\n      _ = (Ber(u, p)).map (fun s : Set ι ↦ i ∈ s) := by simpa [hX']\n      _ = toNNReal p • (Measure.dirac True) + toNNReal (σ p) • (Measure.dirac False) := hi'\n      _ = (Ber(u, p)).map (fun s : Set ι ↦ j ∈ s) := by simpa [hj']\n      _ = (P.map X).map (fun s : Set ι ↦ j ∈ s) := by simpa [hX']\n      _ = P.map (fun ω ↦ j ∈ X ω) := by rfl",
      "by\n    classical\n    have hlaw : HasLaw X Ber(u, p) P := hX\n    have hi' : (fun s : Set ι ↦ i ∈ s) =ᵐ[Ber(u, p)] fun s : Set ι ↦ s i := by\n      filter_upwards [MeasurableEquiv.setOf.symm.ae_eq_preimage] with s hs\n      simpa [MeasurableEquiv.setOf] using congrArg (fun t ↦ i ∈ t) hs\n    have hj' : (fun s : Set ι ↦ j ∈ s) =ᵐ[Ber(u, p)] fun s : Set ι ↦ s j := by\n      filter_upwards [MeasurableEquiv.setOf.symm.ae_eq_preimage] with s hs\n      simpa [MeasurableEquiv.setOf] using congrArg (fun t ↦ j ∈ t) hs\n    have hmap :\n        Measure.map X P = Ber(u, p) := by\n      simpa [HasLaw] using hlaw\n    have :\n        Measure.map (fun ω ↦ i ∈ X ω) P =\n          Measure.map (fun s : ι → Prop ↦ s i)\n            (infinitePi fun k ↦ toNNReal p • dirac (k ∈ u) + toNNReal (σ p) • dirac False) := by\n      -- rewrite via law of `X` and `bernoulliOn_eq_map`\n      have : Measure.map (fun ω ↦ i ∈ X ω) P = Measure.map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) := by\n        simpa [Measure.map_map, hmap]\n      -- switch to `ι → Prop` coordinates\n      simpa [bernoulliOn_eq_map, Measure.map_map, Function.comp] using this\n    have :\n        Measure.map (fun ω ↦ j ∈ X ω) P =\n          Measure.map (fun s : ι → Prop ↦ s j)\n            (infinitePi fun k ↦ toNNReal p • dirac (k ∈ u) + toNNReal (σ p) • dirac False) := by\n      have : Measure.map (fun ω ↦ j ∈ X ω) P = Measure.map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) := by\n        simpa [Measure.map_map, hmap]\n      simpa [bernoulliOn_eq_map, Measure.map_map, Function.comp] using this\n    -- the two coordinates have the same law since both are `p`-Bernoulli on `u`\n    -- (each coordinate measure is identical when `hi` and `hj` hold)\n    have hcoord :\n        Measure.map (fun s : ι → Prop ↦ s i)\n            (infinitePi fun k ↦ toNNReal p • dirac (k ∈ u) + toNNReal (σ p) • dirac False) =\n          Measure.map (fun s : ι → Prop ↦ s j)\n            (infinitePi fun k ↦ toNNReal p • dirac (k ∈ u) + toNNReal (σ p) • dirac False) := by\n      -- both are the same marginal measure, since the coordinate measures at `i` and `j` are equal\n      have hμ :\n          (toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) =\n            (toNNReal p • dirac (j ∈ u) + toNNReal (σ p) • dirac False) := by\n        simp [hi, hj]\n      simpa [infinitePi_map_eval, hμ]\n    -- conclude\n    simpa [this] using congrArg id (by simpa [this] using hcoord)",
      "by\n    classical\n    have hXlaw : HasLaw X Ber(u, p) P := hX\n    have hi_law : HasLaw (fun s : Set ι ↦ i ∈ s) (toNNReal p • dirac True + toNNReal (σ p) • dirac False)\n        (Ber(u, p)) := by\n      simpa [HasLaw, bernoulliOn, hi] using\n        (hasLaw_coord (P := Ber(u, p))\n          (μ := fun a : ι ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False) i)\n    have hj_law : HasLaw (fun s : Set ι ↦ j ∈ s) (toNNReal p • dirac True + toNNReal (σ p) • dirac False)\n        (Ber(u, p)) := by\n      simpa [HasLaw, bernoulliOn, hj] using\n        (hasLaw_coord (P := Ber(u, p))\n          (μ := fun a : ι ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False) j)\n    have h1 : HasLaw (fun ω ↦ i ∈ X ω) (toNNReal p • dirac True + toNNReal (σ p) • dirac False) P :=\n      hi_law.comp hXlaw\n    have h2 : HasLaw (fun ω ↦ j ∈ X ω) (toNNReal p • dirac True + toNNReal (σ p) • dirac False) P :=\n      hj_law.comp hXlaw\n    simpa [HasLaw] using (h1.map_eq.trans h2.map_eq.symm)",
      "by\n    classical\n    have hLaw : HasLaw X Ber(u, p) P := hX\n    have hi' :\n        IdentDistrib (fun s : Set ι ↦ i ∈ s) (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) (Ber(u, p)) := by\n      refine ⟨?_, ?_, ?_⟩\n      · fun_prop\n      · fun_prop\n      · ext t ht\n        have hmeas : MeasurableSet t := ht\n        have :\n            (fun s : Set ι ↦ i ∈ s) ⁻¹' t = (fun s : Set ι ↦ j ∈ s) ⁻¹' t := by\n          cases (by classical exact em (True)) with\n          | inl _ =>\n            cases (by classical exact em (i ∈ u)) with\n            | inl _ =>\n              cases (by classical exact em (j ∈ u)) with\n              | inl _ => rfl\n              | inr _ => rfl\n            | inr _ =>\n              cases (by classical exact em (j ∈ u)) with\n              | inl _ => rfl\n              | inr _ => rfl\n          | inr _ => rfl\n        simpa [this]\n    simpa using (hLaw.identDistrib_comp (μ := Ber(u, p)) hi').map_eq",
      "by\n    classical\n    have hlaw : HasLaw X Ber(u, p) P := hX\n    have h1 :\n        HasLaw (fun s : Set ι ↦ i ∈ s) (toNNReal p • dirac True + toNNReal (σ p) • dirac False)\n          (Ber(u, p)) := by\n      have := (hlaw.map (f := fun s : Set ι ↦ i ∈ s) (μ := Ber(u, p)) (P := P))\n      simpa [bernoulliOn_eq_map, hi, Measure.map_map] using this\n    have h2 :\n        HasLaw (fun s : Set ι ↦ j ∈ s) (toNNReal p • dirac True + toNNReal (σ p) • dirac False)\n          (Ber(u, p)) := by\n      have := (hlaw.map (f := fun s : Set ι ↦ j ∈ s) (μ := Ber(u, p)) (P := P))\n      simpa [bernoulliOn_eq_map, hj, Measure.map_map] using this\n    simpa [h1.map_eq, h2.map_eq]",
      "by\n    classical\n    have hX' : HasLaw X Ber(u, p) P := hX\n    have hmap : Measure.map X P = Ber(u, p) := hX'\n    have hmi : Measure.map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) =\n        toNNReal p • dirac True + toNNReal (σ p) • dirac False := by\n      simpa [bernoulliOn, hi] using (infinitePi_comap_mem (μ := fun a ↦\n        toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False) i)\n    have hmj : Measure.map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) =\n        toNNReal p • dirac True + toNNReal (σ p) • dirac False := by\n      simpa [bernoulliOn, hj] using (infinitePi_comap_mem (μ := fun a ↦\n        toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False) j)\n    calc\n      Measure.map (fun ω ↦ i ∈ X ω) P\n          = Measure.map (fun s : Set ι ↦ i ∈ s) (Measure.map X P) := by\n              simpa [Measure.map_map]\n      _ = Measure.map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) := by simpa [hmap]\n      _ = toNNReal p • dirac True + toNNReal (σ p) • dirac False := hmi\n      _ = Measure.map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) := by simpa [hmj]\n      _ = Measure.map (fun s : Set ι ↦ j ∈ s) (Measure.map X P) := by simpa [hmap]\n      _ = Measure.map (fun ω ↦ j ∈ X ω) P := by\n            simpa [Measure.map_map]",
      "by\n    classical\n    have hlaw : HasLaw X Ber(u, p) P := hX\n    have h1 :\n        map (fun ω ↦ i ∈ X ω) P =\n          map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) := by\n      simpa [HasLaw] using congrArg (fun Q ↦ Measure.map (fun s : Set ι ↦ i ∈ s) Q) hlaw\n    have h2 :\n        map (fun ω ↦ j ∈ X ω) P =\n          map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) := by\n      simpa [HasLaw] using congrArg (fun Q ↦ Measure.map (fun s : Set ι ↦ j ∈ s) Q) hlaw\n    have hij :\n        map (fun s : Set ι ↦ i ∈ s) (Ber(u, p)) =\n          map (fun s : Set ι ↦ j ∈ s) (Ber(u, p)) := by\n      ext S hS\n      by_cases hSi : True\n      · have : MeasurableSet S := hS\n        simp [bernoulliOn_apply, bernoulliOn_apply', hi, hj]\n      · cases hSi\n    simpa [h1, h2] using congrArg id hij",
      "by\n    classical\n    ext S hS\n    simpa [IsBernoulliOn, HasLaw, Measure.map_apply, hS, bernoulliOn_apply, Set.image_image] using\n      congrArg (fun μ ↦ μ {s : Set ι | i ∈ s} ∩ μ.preimage (fun t : Set ι ↦ j ∈ t) S) rfl",
