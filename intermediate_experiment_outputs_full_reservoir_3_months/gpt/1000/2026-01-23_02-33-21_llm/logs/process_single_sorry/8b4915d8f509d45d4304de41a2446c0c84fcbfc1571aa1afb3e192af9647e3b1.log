      "by\n  refine lt_of_le_of_ne (refinement_le (D := D) B hB hB' hB'') ?_\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_subset : B N hN ⊆ (refinement (D := D) B hB hB' hB'') := by\n    intro X hX\n    refine Set.mem_iUnion.mpr ⟨N, ?_⟩\n    refine Set.mem_iUnion.mpr ⟨hN, ?_⟩\n    exact hX\n  have hB_eq : B N hN = {N} := by\n    apply le_antisymm\n    · intro X hX\n      have hX_mem_ref : X ∈ (refinement (D := D) B hB hB' hB'') := h_subset hX\n      have : X ∈ D := by\n        simpa [h_eq] using hX_mem_ref\n      have : X = N := by\n        have hxle : X ≤ N := by\n          have : X ≤ sSup (B N hN) := le_sSup hX\n          simpa [← hB N hN] using this\n        have hnle : N ≤ X := by\n          have : N ≤ sSup (B N hN) := by\n            simpa [hB N hN] using le_rfl\n          have : N ≤ sSup ({X} : Set (PersistenceSubmodule M)) := by\n            simpa using this\n          simpa using this\n        exact le_antisymm hxle hnle\n      simpa [this]\n    · intro X hX\n      simpa [Set.mem_singleton_iff] using hX\n  exact h_ne hB_eq",
