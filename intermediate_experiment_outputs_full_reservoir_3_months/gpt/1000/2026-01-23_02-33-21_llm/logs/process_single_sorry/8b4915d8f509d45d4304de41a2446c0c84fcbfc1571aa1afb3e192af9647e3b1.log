      "by\n  refine lt_of_le_of_ne (refinement_le (D := D) B hB hB' hB'') ?_\n  intro h_eq\n  rcases H with ⟨N, hN, hne⟩\n  have hsubset : B N hN ⊆ (refinement (D := D) B hB hB' hB'') := by\n    intro x hx\n    exact Set.mem_iUnion_of_mem N (Set.mem_iUnion_of_mem hN hx)\n  have hsubset' : B N hN ⊆ D := by\n    simpa [h_eq] using hsubset\n  have h_eq_singleton : B N hN = {N} := by\n    classical\n    apply Set.eq_singleton_iff_unique_mem.mpr\n    constructor\n    · have : N ∈ B N hN := by\n        have : N ≤ sSup (B N hN) := by\n          simpa [hB N hN]\n        simpa [SetLike.le_def] using this\n      exact this\n    · intro x hx\n      have hxD : x ∈ D := hsubset' hx\n      have hxle : x ≤ N := by\n        have : x ≤ sSup (B N hN) := le_sSup hx\n        simpa [hB N hN] using this\n      have hNle : N ≤ x := by\n        have : Disjoint N x := by\n          have hxne : x ≠ N := by\n            intro hxn\n            have : x ∈ ({N} : Set (PersistenceSubmodule M)) := by simpa [hxn]\n            exact (hne (by\n              ext y\n              constructor\n              · intro hy\n                simpa [Set.mem_singleton_iff] using congrArg (fun t => y ∈ t) (by\n                  have : B N hN = {N} := by\n                    apply Set.eq_singleton_iff_unique_mem.mpr\n                    refine ⟨?_, ?_⟩\n                    · exact (by\n                        have : N ≤ sSup (B N hN) := by simpa [hB N hN]\n                        simpa [SetLike.le_def] using this)\n                    · intro z hz\n                      have hzD : z ∈ D := hsubset' hz\n                      have hzle : z ≤ N := by\n                        have : z ≤ sSup (B N hN) := le_sSup hz\n                        simpa [hB N hN] using this\n                      have hNlez : N ≤ z := by\n                        have : Disjoint N z := by\n                          have hzne : z ≠ N := by\n                            intro hzn\n                            exact (hne (by\n                       