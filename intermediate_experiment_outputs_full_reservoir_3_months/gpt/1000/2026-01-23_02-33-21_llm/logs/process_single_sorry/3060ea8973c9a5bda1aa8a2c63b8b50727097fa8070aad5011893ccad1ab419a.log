def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    sorry
  indep_maximal := by
    intro X hX
    classical
    refine Matroid.existsMaximalSubsetProperty_of_finite ?_ X
    intro S hS
