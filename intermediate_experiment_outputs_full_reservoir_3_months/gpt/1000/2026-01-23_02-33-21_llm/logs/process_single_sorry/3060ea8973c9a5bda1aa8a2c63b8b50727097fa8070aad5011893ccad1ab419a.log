def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    sorry
  indep_maximal := by
    intro X hX
    classical
    refine Matroid.existsMaximalSubsetProperty_of_bdd ?_ X
    refine ⟨2 * (ν(G)).toNat, ?_⟩
    rintro S ⟨M, hM, hSV⟩ hS X hSX
    have hfinite : (V(G, M)).Finite := by
      classical
      simpa [V, Graph.vertexSet_edges] using (hM.subset.finite_of_subset ?_)
    have hSfinite : S.Finite := hfinite.subset hSV
    have hcard_le : S.encard ≤ (V(G, M)).encard := by
      classical
      exact encard_le_encard hSV
    have hV_le : (V(G, M)).encard ≤ 2 * M.encard := by
      classical
      simpa using hM.vertex_encard_le_two_mul_encard
    have hMle : M.encard ≤ ν(G) := hM.encard_le
    have hnu : (ν(G)).toNat ≤ (ν(G)).toNat := le_rfl
    have hMle' : M.encard.toNat ≤ (ν(G)).toNat := by
      exact ENat.toNat_le_toNat hMle
    have : S.encard.toNat ≤ 2 * (ν(G)).toNat := by
      have h1 : S.encard.toNat ≤ (V(G, M)).encard.toNat := by
        exact ENat.toNat_le_toNat hcard_le
      have h2 : (V(G, M)).encard.toNat ≤ (2 * M.encard).toNat := by
        exact ENat.toNat_le_toNat hV_le
      have h3 : (2 * M.encard).toNat ≤ 2 * (ν(G)).toNat := by
        simpa [Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm] using Nat.mul_le_mul_left 2 hMle'
      exact le_trans (le_trans h1 h2) h3
    exact this
