      "\n  intro x hx\n  have hx0 : (0 : ℝ) < x := hx\n  have hx2 : (0 : ℝ) < 2 * x := by nlinarith\n  have hAMGM : x + (1 / (2 * x)) ≥ Real.sqrt 2 := by\n    have h :=\n      (two_mul_le_add_sq).2 (by\n        have := (mul_self_sqrt (show (0 : ℝ) ≤ (x * (1 / (2 * x))) by\n          have : (0 : ℝ) ≤ x := le_of_lt hx0\n          have : (0 : ℝ) ≤ (1 / (2 * x)) := by\n            have : (0 : ℝ) < (2 * x) := hx2\n            exact le_of_lt (one_div_pos.2 this)\n          nlinarith))\n        )\n    -- use AM-GM: x + y ≥ 2*sqrt(xy) with y = 1/(2x)\n    have hxy : (0 : ℝ) ≤ x * (1 / (2 * x)) := by\n      have : (0 : ℝ) ≤ x := le_of_lt hx0\n      have : (0 : ℝ) ≤ (1 / (2 * x)) := by\n        exact le_of_lt (one_div_pos.2 hx2)\n      nlinarith\n    have h1 : x + (1 / (2 * x)) ≥ 2 * Real.sqrt (x * (1 / (2 * x))) := by\n      simpa [two_mul] using (two_mul_le_add_sq).1 (by\n        have := (mul_self_sqrt hxy)\n        nlinarith)\n    have hprod : x * (1 / (2 * x)) = (1 / 2 : ℝ) := by\n      field_simp [hx0.ne'] \n    have hsqrt : Real.sqrt (x * (1 / (2 * x))) = (1 / Real.sqrt 2 : ℝ) := by\n      simp [hprod, Real.sqrt_div, Real.sqrt_one, Real.sqrt_two]\n    have : 2 * Real.sqrt (x * (1 / (2 * x))) = Real.sqrt 2 := by\n      have : (0 : ℝ) < Real.sqrt 2 := by\n        simpa using (Real.sqrt_pos.2 (by nlinarith))\n      nlinarith [hsqrt]\n    exact le_trans (by simpa [this] using h1) (le_rfl)\n  linarith",
