      "\n  intro x hx\n  have hx' : (0 : ℝ) < x := hx\n  have h : x + 1 / (2 * x) ≥ Real.sqrt 2 := by\n    have hpos : (0 : ℝ) ≤ 2 * x := by nlinarith\n    have hxne : (x : ℝ) ≠ 0 := by exact ne_of_gt hx'\n    have hxne' : (2 * (x : ℝ)) ≠ 0 := by nlinarith\n    have hsq : (Real.sqrt 2) ^ 2 ≤ (x + 1 / (2 * x)) ^ 2 := by\n      have : (2 : ℝ) ≤ (x + 1 / (2 * x)) ^ 2 := by\n        have := sq_add_sq_le_two_mul_sq_add_sq (a := x) (b := (1 / (2 * x)))\n        -- fallback to direct computation via nlinarith on squares:\n        have : (x + 1 / (2 * x)) ^ 2 - 2 = (x - 1 / (2 * x)) ^ 2 := by\n          field_simp [pow_two, hxne, hxne']\n          ring\n        have hnonneg : (0 : ℝ) ≤ (x - 1 / (2 * x)) ^ 2 := by nlinarith\n        have : (2 : ℝ) ≤ (x + 1 / (2 * x)) ^ 2 := by\n          have := congrArg (fun t => t + 2) this\n          nlinarith\n        exact this\n      simpa [pow_two] using this\n    have hsqrt_nonneg : (0 : ℝ) ≤ Real.sqrt 2 := by exact Real.sqrt_nonneg _\n    have hsum_nonneg : (0 : ℝ) ≤ x + 1 / (2 * x) := by\n      have : (0 : ℝ) ≤ 1 / (2 * x) := by\n        have : (0 : ℝ) < 2 * x := by nlinarith\n        exact le_of_lt (one_div_pos.2 this)\n      nlinarith\n    have hsqrt_le : Real.sqrt 2 ≤ x + 1 / (2 * x) := by\n      have hsq' : (Real.sqrt 2) ^ 2 ≤ (x + 1 / (2 * x)) ^ 2 := hsq\n      exact (sq_le_sq.1 hsq').2 ⟨hsqrt_nonneg, hsum_nonneg⟩\n    exact hsqrt_le\n  linarith",
