      "\n  intro x hx\n  have hx0 : (0 : ℝ) < x := hx\n  have hxne : (x : ℝ) ≠ 0 := ne_of_gt hx0\n  have hpos : (0 : ℝ) < 2 * x := by nlinarith\n  have hpos' : (0 : ℝ) < (2 * x)⁻¹ := by simpa using inv_pos.mpr hpos\n  have hAMGM :\n      Real.sqrt ((x : ℝ) * ((2 * x)⁻¹)) ≤ (x + (2 * x)⁻¹) / 2 := by\n    simpa [mul_comm, mul_left_comm, mul_assoc] using\n      (Real.sqrt_mul_le_add_div_two (x : ℝ) ((2 * x)⁻¹))\n  have hmul : (x : ℝ) * ((2 * x)⁻¹) = (1 : ℝ) / 2 := by\n    field_simp [hxne]\n  have hsqrt : Real.sqrt ((x : ℝ) * ((2 * x)⁻¹)) = (Real.sqrt 2)⁻¹ := by\n    have : (x : ℝ) * ((2 * x)⁻¹) = (2 : ℝ)⁻¹ := by simpa [one_div] using hmul\n    simp [this, one_div, Real.sqrt_inv, Real.sqrt_two]\n  have hineq :\n      (Real.sqrt 2)⁻¹ ≤ (x + (2 * x)⁻¹) / 2 := by\n    simpa [hsqrt] using hAMGM\n  have hineq2 : Real.sqrt 2 ≤ x + (2 * x)⁻¹ := by\n    have hs2pos : (0 : ℝ) < Real.sqrt 2 := by\n      have : (0 : ℝ) < (2 : ℝ) := by norm_num\n      simpa using Real.sqrt_pos.2 this.ne'\n    have hs2ne : (Real.sqrt 2) ≠ 0 := ne_of_gt hs2pos\n    have := (inv_le_inv_of_le hs2pos hineq)\n    have : Real.sqrt 2 ≤ 2 / (x + (2 * x)⁻¹) := by\n      simpa [one_div] using this\n    have hsumpos : (0 : ℝ) < x + (2 * x)⁻¹ := by linarith\n    have hsumne : (x + (2 * x)⁻¹) ≠ 0 := ne_of_gt hsumpos\n    have hcalc : (2 : ℝ) / (x + (2 * x)⁻¹) = (Real.sqrt 2) * (Real.sqrt 2) / (x + (2 * x)⁻¹) := by\n      simp [Real.mul_self_sqrt (by positivity : (0 : ℝ) ≤ (2 : ℝ))]\n    have : (Real.sqrt 2) * (Real.sqrt 2) ≤ (x + (2 * x)⁻¹) * (Real.sqrt 2) := by\n      have := (mul_le_mul_of_nonneg_right hineq2 (le_of_lt hs2pos))\n      simpa [mul_assoc, mul_comm, mul_left_comm, Real.mul_self_sqrt (by positivity : (0 : ℝ) ≤ (2 : ℝ))] using this\n    have : (2 : ℝ) ≤ (x + (2 * x)⁻¹) * (Real.sqrt 2) := by\n      simpa [Real.mul_self_sqrt (by positivity : (0 : ℝ) ≤ (2 : ℝ))] using this\n    have : (2 : ℝ) / (Real.sqrt 2) ≤ x + (2 * x)⁻¹ := by\n      have hs2pos' : (0 : ℝ) < Real.sqrt 2 := by\n        have : (0 : ℝ