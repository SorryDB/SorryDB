      "\n  revert lhs rhs ok\n  induction sl using SymList.rec with\n  | mk lhs rhs ok ih =>\n    -- prove by well-founded recursion on `lengthSL`\n    classical\n    -- generalize to allow rewriting with the definitional equation of `dropWhileSL`\n    revert lhs rhs ok\n    refine (Nat.strongRecOn (lengthSL (SymList.mk lhs rhs ok)) ?_ ) ?_ ?_\n    · intro n hn lhs rhs ok\n      have hsl : lengthSL (SymList.mk lhs rhs ok) = n := rfl\n      -- unfold both sides and follow the definition of `dropWhileSL`\n      by_cases hempty : lhs.isEmpty ∧ rhs.isEmpty\n      · have : SymList.mk lhs rhs ok = nil := by\n          cases lhs <;> cases rhs <;> simp [nil] at hempty ⊢\n        subst this\n        simp [dropWhileSL, fromSL, nil]\n      · simp [dropWhileSL, hempty, fromSL, headSL] at *\n        -- analyze `headSL`\n        cases hhead : headSL (SymList.mk lhs rhs ok) with\n        | none =>\n          -- impossible (nonempty), but simp handles it\n          simp [dropWhileSL, hempty, hhead, fromSL]\n        | some hslh =>\n          by_cases hp : p hslh\n          · -- recursive case\n            have hneq : SymList.mk lhs rhs ok ≠ nil := by\n              intro hnil\n              have : headSL (SymList.mk lhs rhs ok) = none := by\n                simpa [hnil, headSL, nil]\n              simpa [hhead] using this\n            have hlt : lengthSL (tailSL (SymList.mk lhs rhs ok)) < lengthSL (SymList.mk lhs rhs ok) :=\n              Nat.lt_of_lt_of_le (length_tail_lt_length (SymList.mk lhs rhs ok) hneq) (Nat.le_of_lt_succ (Nat.lt_succ_self _))\n            have := hn (lengthSL (tailSL (SymList.mk lhs rhs ok)))\n              (Nat.lt_of_lt_of_eq hlt rfl)\n              (SymList.lhs (tailSL (SymList.mk lhs rhs ok)))\n              (SymList.rhs (tailSL (SymList.mk lhs rhs ok)))\n              (SymList.ok  (tailSL (SymList.mk lhs rhs ok)))\n            -- use the `tailSL` lemma already proved\n            have htail : fromSL (tailSL (SymList.mk lhs rhs ok)) = tail (fromSL (SymList