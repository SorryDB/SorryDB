      "\n  classical\n  revert lhs rhs ok\n  refine Nat.strongRec_on (lengthSL (SymList.mk lhs rhs ok)) ?_ ?_ ?_ ?_\n  · intro n ih lhs rhs ok\n    have ih' :\n        ∀ (sl' : SymList a), lengthSL sl' < n →\n          dropWhile p (fromSL sl') = fromSL (dropWhileSL p sl') := by\n        intro sl' hn\n        exact ih _ hn _ _ _ rfl\n    -- now prove for current sl with length = n\n    have hn : lengthSL (SymList.mk lhs rhs ok) = n := by rfl\n    -- unfold dropWhileSL; split on emptiness and head\n    by_cases hempty : lhs.isEmpty ∧ rhs.isEmpty\n    · simp [dropWhileSL, hempty, fromSL, dropWhile]\n      simp at hempty\n      rcases hempty with ⟨hl, hr⟩\n      simp [List.isEmpty_iff] at hl hr\n      subst hl; subst hr\n      simp [SymList.nil, SymList.fromSL, dropWhile]\n    · have hempty' : ¬ (lhs.isEmpty ∧ rhs.isEmpty) := hempty\n      -- analyze headSL\n      cases hhead : headSL (SymList.mk lhs rhs ok) with\n      | none =>\n          -- headSL none implies nil\n          have : (SymList.mk lhs rhs ok : SymList a) = nil := by\n            have := (headSL_none_iff_nilSL (sl := (SymList.mk lhs rhs ok : SymList a))).1 hhead\n            exact this\n          subst this\n          simp [dropWhileSL, SymList.nil, headSL, fromSL, dropWhile] at hempty'\n      | some hsl =>\n          -- relate headSL to List.head? of fromSL\n          have hheadList : (fromSL (SymList.mk lhs rhs ok : SymList a)).head? = some hsl := by\n            -- use previously proved lemma\n            have := congrArg (fun f => f (SymList.mk lhs rhs ok : SymList a)) (by\n              simpa using (show List.head? ∘ fromSL = @headSL a from\n                (by\n                  funext sl\n                  have ⟨lhs, rhs, ok⟩ := sl\n                  simp [Function.comp, headSL, fromSL]\n                  split <;> (\n                    rename_i h\n                    simp at h\n                    have ⟨ha, hb⟩ := h\n                    subst ha hb\n                    simp\n                  )\n