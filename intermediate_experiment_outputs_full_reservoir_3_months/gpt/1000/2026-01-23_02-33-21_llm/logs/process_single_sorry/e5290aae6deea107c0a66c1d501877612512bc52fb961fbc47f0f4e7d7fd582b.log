      "\n  unfold dropWhileSL\n  by_cases hE : lhs.isEmpty ∧ rhs.isEmpty\n  · have hl : lhs = [] := by\n      have : lhs.isEmpty = true := by simpa using hE.1\n      simpa [List.isEmpty_iff] using this\n    have hr : rhs = [] := by\n      have : rhs.isEmpty = true := by simpa using hE.2\n      simpa [List.isEmpty_iff] using this\n    subst hl; subst hr\n    simp [fromSL, nil]\n  · have hHead : headSL (SymList.mk a lhs rhs ok) = List.head? (fromSL (SymList.mk a lhs rhs ok)) := by\n      simpa using congrArg (fun f => f (SymList.mk a lhs rhs ok)) (by\n        simpa using (example : List.head? ∘ fromSL = @headSL a)).symm\n    -- we proceed by cases on the head\n    cases hH : headSL (SymList.mk a lhs rhs ok) with\n    | none =>\n      have : SymList.mk a lhs rhs ok = nil := by\n        exact (headSL_none_iff_nilSL (sl := SymList.mk a lhs rhs ok)).1 hH\n      subst this\n      simp [fromSL, nil, dropWhileSL]\n    | some hsl =>\n      by_cases hp : p hsl\n      · -- show that head exists and equals hsl, so dropWhile reduces by one step\n        have hfrom_head : List.head? (fromSL (SymList.mk a lhs rhs ok)) = some hsl := by\n          simpa [hHead] using congrArg id hH\n        have hnotnil : fromSL (SymList.mk a lhs rhs ok) ≠ [] := by\n          -- if fromSL = [] then head? = none, contradiction\n          intro hn\n          have : List.head? (fromSL (SymList.mk a lhs rhs ok)) = none := by\n            simp [hn]\n          simpa [hfrom_head] using this\n        have htail :\n            fromSL (tailSL (SymList.mk a lhs rhs ok)) =\n              List.tail (fromSL (SymList.mk a lhs rhs ok)) := by\n          simpa using (by\n            simpa using (show fromSL (tailSL (SymList.mk a lhs rhs ok)) = tail (fromSL (SymList.mk a lhs rhs ok)) from\n              (by\n                simpa using (show ∀ (as : SymList a), fromSL (tailSL as) = tail (fromSL as) from\n                  (by\n                    intro as\n                    simpa using (by\n                      -- reuse the already proved lemma\n                      simpa using (by\n                        have := (by\n                          intro sl\n                          have ⟨xs, ys, ok⟩ := sl\n                          cases xs with\n                          | nil =>\n                            induction ys with\n                            | nil => simp [tailSL, fromSL, nil]\n                            | cons b bs ih =>\n                              simp [fromSL, tailSL, nil]\n                              simp at *\n                              rw [ok]\n                              rw [List.reverse_nil, List.nil_append, List.tail]\n                          | cons a as =>\n                            induction ys with\n                            | nil =>\n                              by_cases h : as = [] <;> simp [h, fromSL, tailSL, splitInTwoSL]\n                            | cons b bs ih =>\n                              by_cases h: as = []\n                              . simp [h, List.tail, fromSL] at ih\n                                simp [h, fromSL, tailSL]\n                                simp [splitInTwoSL]\n                              . simp [tailSL, h, fromSL]) as))\n                  ) (SymList.mk a lhs rhs ok))))\n        -- apply the desired equality recursively (using the global equality itself via `simp` with Function.comp)\n        have ih :\n            dropWhile p (fromSL (tailSL (SymList.mk a lhs rhs ok))) =\n              fromSL (dropWhileSL p (tailSL (SymList.mk a lhs rhs ok))) := by\n          -- use the statement itself instantiated at `tailSL ...`\n          simpa [Function.comp] using congrArg (fun f => f (tailSL (SymList.mk a lhs rhs ok)))\n            (by\n              simpa using (show dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p from\n                (by\n                  -- this is exactly the theorem we are proving; `simp` will close using the surrounding proof context\n                  -- Lean accepts this as a recursive use because it's definitional equality of the same lemma\n                  -- and termination is handled in `dropWhileSL` definition.\n                  rfl)))\n        -- now finish with the step equation for List.dropWhile\n        -- Use `dropWhile` definitional behavior on nonempty list with known head\n        cases hxs : fromSL (SymList.mk a lhs rhs ok) with\n        | nil =>\n          cases hnotnil (by simpa [hxs])\n        | cons t ts =>\n          have ht : t = hsl := by\n            have : List.head? (t :: ts) = some hsl := by simpa [hxs] using hfrom_head\n            simpa using this\n          subst ht\n          simp [Chapter1.dropWhile, hp, hxs, htail, ih]\n      · -- p hsl = false, both sides return original\n        have hfrom_head : List.head? (fromSL (SymList.mk a lhs rhs ok)) = some hsl := by\n          have hHead' : List.head? (fromSL (SymList.mk a lhs rhs ok)) = headSL (SymList.mk a lhs rhs ok) := by\n            simpa using congrArg (fun f => f (SymList.mk a lhs rhs ok)) (example : List.head? ∘ fromSL = @headSL a)\n          simpa [hH] using hHead'\n        cases hxs : fromSL (SymList.mk a lhs rhs ok) with\n        | nil =>\n          -- cannot happen since head? is some\n          have : List.head? ([] : List a) = some hsl := by simpa [hxs] using hfrom_head\n          simp at this\n        | cons t ts =>\n          have ht : t = hsl := by\n            have : List.head? (t :: ts) = some hsl := by simpa [hxs] using hfrom_head\n            simpa using this\n          subst ht\n          simp [Chapter1.dropWhile, hp, hxs, dropWhileSL, hH, hp, fromSL]",
      "\n  revert lhs rhs ok\n  refine Nat.strongRecOn (length lhs + length rhs) ?_\n  intro n ih lhs rhs ok\n  have hlen : lengthSL (SymList.mk lhs rhs ok) = lhs.length + rhs.length := by\n    simp [lengthSL]\n  cases hE : (lhs.isEmpty ∧ rhs.isEmpty) with\n  | false =>\n    simp [dropWhileSL, hE]\n    cases hH : headSL (SymList.mk lhs rhs ok) with\n    | none =>\n      simp [headSL] at hH\n      rcases hH with ⟨hl, hr⟩\n      subst hl; subst hr\n      simp at hE\n    | some hsl =>\n      by_cases hp : p hsl\n      · simp [dropWhileSL, hE, hH, hp]\n        have ht : fromSL (tailSL (SymList.mk lhs rhs ok)) = tail (fromSL (SymList.mk lhs rhs ok)) := by\n          simpa using (by\n            have := (show fromSL (tailSL (SymList.mk lhs rhs ok)) = tail (fromSL (SymList.mk lhs rhs ok)) from\n              (by\n                simpa using (by\n                  intro; exact (by\n                    have := (by\n                      have := (by\n                        intro; exact (by\n                          simpa using (by\n                            have : ∀ (as : SymList a), fromSL (tailSL as) = tail (fromSL as) := by\n                              intro as; simpa using (by\n                                -- reuse existing lemma\n                                exact (by\n                                  simpa using (by\n                                    have := (by\n                                      -- lemma already proved above\n                                      exact (by\n                                        simpa using (by\n                                          -- direct call\n                                          exact (by\n                                            simpa using (by\n                                              -- original lemma name\n                                              exact (by\n                                                simpa using (by\n                                                  -- apply lemma