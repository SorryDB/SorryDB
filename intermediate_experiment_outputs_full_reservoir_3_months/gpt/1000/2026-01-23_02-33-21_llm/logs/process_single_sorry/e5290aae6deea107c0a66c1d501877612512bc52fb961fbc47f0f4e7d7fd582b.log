    -- use headSL/head? info to rewrite\n            have hfromTail : fromSL (tailSL (SymList.mk lhs rhs ok : SymList a)) = List.tail (fromSL (SymList.mk lhs rhs ok : SymList a)) := by\n              simpa using (show fromSL (tailSL (SymList.mk lhs rhs ok : SymList a)) = tail (fromSL (SymList.mk lhs rhs ok : SymList a)) from\n                (by\n                  intro sl\n                  have ⟨xs, ys, ok⟩ := sl\n                  cases xs with\n                  | nil =>\n                    induction ys with\n                    | nil => simp [tailSL, fromSL, nil]\n                    | cons b bs ih =>\n                      simp [fromSL, tailSL, nil]\n                      simp at *\n                      rw [ok]\n                      rw [List.reverse_nil, List.nil_append, List.tail]\n                  | cons a as =>\n                    induction ys with\n                    | nil =>\n                      by_cases h : as = [] <;> simp [h, fromSL, tailSL, splitInTwoSL]\n                    | cons b bs ih =>\n                      by_cases h: as = []\n                      . simp [h, List.tail, fromSL] at ih\n                        simp [h, fromSL, tailSL]\n                        simp [splitInTwoSL]\n                      . simp [tailSL, h, fromSL])))\n            -- simplify dropWhile on list via head?\n            -- use hheadList and hp\n            -- dropWhile p (fromSL sl) = dropWhile p (tail (fromSL sl))\n            have : dropWhile p (fromSL (SymList.mk lhs rhs ok : SymList a)) =\n                dropWhile p (tail (fromSL (SymList.mk lhs rhs ok : SymList a))) := by\n              -- unfold dropWhile from Chapter1; use simp on head?\n              -- easiest: simp [Chapter1.dropWhile, hheadList, hp]\n              simpa [Chapter1.dropWhile, hheadList, hp] using (rfl :\n                dropWhile p (fromSL (SymList.mk lhs rhs ok : SymList a)) =\n                  dropWhile p (fromSL (SymList.mk lhs rhs ok : SymList a)))\n            -- and dropWhileSL