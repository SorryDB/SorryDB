      "\n  revert lhs rhs ok\n  intro lhs rhs ok\n  induction hlen : (lhs.length + rhs.length) generalizing lhs rhs with\n  | zero =>\n      have hl : lhs = [] := by\n        have : lhs.length = 0 := by\n          have : lhs.length ≤ lhs.length + rhs.length := Nat.le.intro (by simp [Nat.add_assoc, Nat.add_comm, Nat.add_left_comm])\n          have h' : lhs.length = 0 := by\n            have := congrArg (fun n => n) hlen\n            omega\n          exact by simpa [List.length_eq_zero_iff] using h'\n        simpa [List.length_eq_zero_iff] using this\n      have hr : rhs = [] := by\n        have : rhs.length = 0 := by\n          have h' : rhs.length = 0 := by\n            have := congrArg (fun n => n) hlen\n            omega\n          exact h'\n        simpa [List.length_eq_zero_iff] using this\n      subst hl; subst hr\n      simp [SymList.dropWhileSL, SymList.fromSL, SymList.nil]\n  | succ n ih =>\n      cases lhs with\n      | nil =>\n          cases rhs with\n          | nil =>\n              simp [SymList.dropWhileSL, SymList.fromSL, SymList.nil]\n          | cons r rs =>\n              simp [SymList.fromSL, SymList.dropWhileSL, SymList.headSL, Chapter1.dropWhile]\n              by_cases hp : p r\n              · simp [hp]\n                have htail : SymList.tailSL a (SymList.mk a [] (r :: rs) ok) = SymList.nil := by\n                  simp [SymList.tailSL, SymList.nil]\n                simp [htail]\n              · simp [hp]\n      | cons l ls =>\n          simp [SymList.fromSL, SymList.dropWhileSL, SymList.headSL, Chapter1.dropWhile]\n          by_cases hp : p l\n          · simp [hp]\n            have hlt : SymList.lengthSL a (SymList.tailSL a (SymList.mk a (l :: ls) rhs ok)) < SymList.lengthSL a (SymList.mk a (l :: ls) rhs ok) := by\n              have := SymList.length_tail_lt_length (a := a) (sl := SymList.mk a (l :: ls) rhs ok) (by\n                intro hnil\n                cases hnil\n                simp [SymList.nil] )\n              simpa using th