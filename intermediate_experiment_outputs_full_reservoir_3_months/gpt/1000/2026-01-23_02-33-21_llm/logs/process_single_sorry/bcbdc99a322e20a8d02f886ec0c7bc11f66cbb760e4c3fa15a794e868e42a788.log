theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  classical
  unfold maxStrength_postcond maxStrength
  dsimp
  let powerSet := fun (l : List Int) =>
    let n := l.length
    let masks := List.range (2^n)
    masks.map fun mask =>
      (List.range n).foldr (fun i acc =>
        if (mask.shiftRight i).land 1 == 1 then l[i]! :: acc else acc
      ) []
  let subsets := powerSet nums
  let nonEmpty := subsets.filter (· ≠ [])
  let products :=
    List.map
        (fun subset =>
          List.foldl (fun acc x => acc * x) (1 : Int) subset)
        nonEmpty
  have hne : products ≠ [] := by
    have : (1 : Int) ∈ products := by
      refine List.mem_map.2 ?_
      refine ⟨[], ?_, by simp⟩
      · have : [] ∈ subsets := by
          unfold subsets powerSet
          dsimp
          refine List.mem_map.2 ?_
          refine ⟨0, ?_, by simp⟩
          simp
        have : [] ∉ nonEmpty := by
          simp [nonEmpty]
        have : False := this (by simpa [nonEmpty] using List.mem_filter.2 ⟨this, by simp⟩)
        exact False.elim this
      · simp [nonEmpty]
    intro h
    have : (1 : Int) ∈ ([] : List Int) := by simpa [h] using this
    simpa using this
  classical
  have hmax := List.getD_max?_le products (-1000000)
  have hmem : (List.max? products).getD (-1000000) ∈ products := by
    simpa using List.getD_max?_mem products (-1000000) hne
  refine ⟨?_, ?_⟩
  ·
    -- show result is among products of nonempty sublists
    -- relate `nums.sublists` products to `products` by noting both contain `products` elementwise
    -- it suffices to use `contains` on the constructed list directly
    -- `products.contains` uses membership
    simpa [List.contains] using hmem
  ·
    -- all products ≤ max
    -- use characterization of max?
    intro x hx
    exact hmax x hx
  -- !benchmark @end proof
