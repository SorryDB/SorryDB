theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  classical
  unfold maxStrength_postcond maxStrength
  simp only
  set powerSet := (fun (l : List Int) =>
    let n := l.length
    let masks := List.range (2^n)
    masks.map fun mask =>
      (List.range n).foldr (fun i acc =>
        if (mask.shiftRight i).land 1 == 1 then l[i]! :: acc else acc
      ) []) with hps
  set subsets := powerSet nums with hsubsets
  set nonEmpty := subsets.filter (· ≠ []) with hnonEmpty
  set products := List.map (fun subset => List.foldl (fun acc x => acc * x) (1 : Int) subset) nonEmpty with hproducts
  have hnne : nonEmpty ≠ [] := by
    intro hne
    have : (subsets.filter (fun s => s ≠ [])) = [] := by simpa [hnonEmpty] using hne
    have hs : ([] : List Int) ∈ subsets := by
      have : 0 ∈ List.range (2 ^ nums.length) := by
        have hpos : 0 < (2 ^ nums.length) := by
          have : (0 : Nat) < 2 ^ nums.length := by
            exact Nat.pow_pos (by decide) _
          simpa using this
        exact List.mem_range.2 hpos
      refine List.mem_map.2 ?_
      refine ⟨0, this, ?_⟩
      simp [powerSet, hps]
    have : ([] : List Int) ∈ nonEmpty := by
      have : ([] : List Int) ∈ subsets.filter (fun s => s ≠ []) := by
        have hmem : ([] : List Int) ∈ subsets := hs
        exact List.mem_filter.2 ⟨hmem, by simp⟩
      simpa [hnonEmpty] using this
    simpa [hne] using this
  have hpn : products ≠ [] := by
    intro hp
    have : nonEmpty = [] := by
      simpa [hproducts] using congrArg List.length hp
    exact hnne this
  have hmemmax : (List.max? products).getD (-1000000) ∈ products := by
    have hmax : List.max? products = some (List.max' products (by
        have : products ≠ [] := hpn
        simpa [List.ne_nil_iff_exists_mem] using this)) := by
      simpa [List.max?_eq_some_max'] using (List.max?_eq_some_max' (l := products) (by
        have : products ≠ [] := hpn
        simpa [List.ne_nil_iff_exists_mem] using this))
    rcases List.max?_eq_some_iff.1 (by
      have : List.max? products ≠ none := by
        simpa [List.max?_eq_none] using hpn
      cases h : List.max? products <;> simp [h] at this) with ⟨m, hm, rfl⟩
    simp [List.getD, hm]
  refine ⟨?_, ?_⟩
  · simpa [products] using hmemmax
  · intro x hx
    have hx' : x ∈ products := by simpa using hx
    have hle : x ≤ (List.max? products).getD (-1000000) := by
      have : ∀ y ∈ products, y ≤ (List.max? products).getD (-1000000) := by
        intro y hy
        cases h : List.max? products with
        | none =>
            exfalso
            have : products = [] := by simpa [List.max?_eq_none] using h
            exact hpn this
        | some m =>
            have hm : m ∈ products ∧ ∀ z ∈ products, z ≤ m := by
              exact List.max?_eq_some_iff.1 (by simp [h])
            have : y ≤ m := hm.2 y hy
            simpa [List.getD, h] using this
      exact this x hx'
    simpa [products] using hle
  -- !benchmark @end proof
