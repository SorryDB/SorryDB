theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  classical
  dsimp [maxStrength_postcond, maxStrength]
  set powerSet : List Int → List (List Int) := fun l =>
    let n := l.length
    let masks := List.range (2^n)
    masks.map fun mask =>
      (List.range n).foldr (fun i acc =>
        if (mask.shiftRight i).land 1 == 1 then l[i]! :: acc else acc
      ) []
  set subsets := powerSet nums
  set nonEmpty := subsets.filter (· ≠ [])
  set products : List Int :=
    List.map (fun subset => List.foldl (fun acc x => acc * x) (1 : Int) subset) nonEmpty
  have hnz : products ≠ [] := by
    have : (nonEmpty : List (List Int)) ≠ [] := by
      by_contra hne
      have : (products : List Int) = [] := by simp [products, hne]
      exact (by simpa [this] using hne)
    by_contra hp
    have : (nonEmpty : List (List Int)) = [] := by
      cases nonEmpty <;> simp [products] at hp
    exact this this
  set r : Int := (List.max? products).getD (-1000000)
  have hr_mem : products.contains r := by
    have hmax : (List.max? products).isSome := by
      simpa [List.max?_eq_some_iff] using List.max?_isSome_iff.2 hnz
    have : List.max? products = some ((List.max? products).getD (-1000000)) := by
      simpa [Option.getD, hmax] using (Option.some_get? (List.max? products))
    rcases List.max?_eq_some_iff.1 this with ⟨hm, hall⟩
    simpa [List.contains] using hm
  have hr_ge : products.all (· ≤ r) := by
    have hmax : (List.max? products).isSome := by
      simpa [List.max?_eq_some_iff] using List.max?_isSome_iff.2 hnz
    have : List.max? products = some ((List.max? products).getD (-1000000)) := by
      simpa [Option.getD, hmax] using (Option.some_get? (List.max? products))
    rcases List.max?_eq_some_iff.1 this with ⟨hm, hall⟩
    simpa using hall
  refine ⟨?_, ?_⟩
  ·
    -- relate `products` to products over `nums.sublists.filter (· ≠ [])`
    have : (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1) = products := by
      rfl
    simpa [r, this] using hr_mem
  ·
    have : (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1) = products := by
      rfl
    simpa [r, this] using hr_ge
  -- !benchmark @end proof
