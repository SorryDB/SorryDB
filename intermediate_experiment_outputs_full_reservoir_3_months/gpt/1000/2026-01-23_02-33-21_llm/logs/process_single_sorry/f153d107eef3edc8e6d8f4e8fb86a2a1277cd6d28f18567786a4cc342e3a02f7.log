theorem well_typed_well_typed' {ε} {e : ExprLow Ident Typ} :
  e.well_formed ε →
  e.well_typed ε →
  e.well_typed' ε := by
  intro hwf hwt
  cases e with
  | base inst typ =>
    -- well_typed for a base is trivial, so just use the build_module_interface' of the well_formed hypothesis
    dsimp [ExprLow.well_typed', ExprLow.build_module_interface', ExprLow.well_typed'', ExprLow.well_formed] at *
    split at hwf <;> try contradiction
    rename_i mod hε
    rw [hε]
    constructor
    simp [Option.map]
  | connect c e =>
    dsimp [ExprLow.well_typed', ExprLow.well_typed] at *
    cases hwt with
    | intro hwt_e hwt_conn =>
      have hwf_e : e.well_formed ε := by
        simpa [ExprLow.well_formed_connect] using hwf
      have ih := well_typed_well_typed' (e := e) (ε := ε) hwf_e hwt_e
      dsimp [ExprLow.well_typed' ] at ih
      exact And.intro ih hwt_conn
  | product e1 e2 =>
    dsimp [ExprLow.well_typed', ExprLow.well_typed] at *
    cases hwt with
    | intro hwt1 hwt2 =>
      have hwf1 : e1.well_formed ε := by
        exact (ExprLow.well_formed_product (ε := ε) (e₁ := e1) (e₂ := e2)).1 hwf |>.1
      have hwf2 : e2.well_formed ε := by
        exact (ExprLow.well_formed_product (ε := ε) (e₁ := e1) (e₂ := e2)).1 hwf |>.2
      refine And.intro ?_ ?_
      · exact well_typed_well_typed' (e := e1) (ε := ε) hwf1 hwt1
      · exact well_typed_well_typed' (e := e2) (ε := ε) hwf2 hwt2
```
