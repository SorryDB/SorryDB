      "\n  classical\n  have hdisj := hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.le\n  have hpar : (E(C) ∩ (M ∆ M')).encard = (E(C) ∩ M).encard + (E(C) ∩ M').encard := by\n    simpa [symmDiff, inter_union_distrib_left, inter_assoc, inter_left_comm, inter_comm,\n      Set.encard_union_eq, hdisj] using\n      (Set.encard_union_eq (s := E(C) ∩ M) (t := E(C) ∩ M') hdisj)\n  have hcycle : Even (E(C) ∩ (M ∆ M')).encard := by\n    have := hC.even_encard_edgeSet_inter (G := hM.restrict₂ hM') (H := C) hCG\n    simpa [E] using this\n  have : Even ((E(C) ∩ M).encard + (E(C) ∩ M').encard) := by\n    simpa [hpar] using hcycle\n  exact (Nat.even_add.1 this).eq_of_not_even_left ?_",
      "\n  classical\n  have hdisj := hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.le\n  have hfinite : (E(C)).Finite := by\n    simpa [Graph.IsCycleGraph] using hC.edgeFinite\n  have hsum :=\n    encard_add_encard_eq_encard_union (s := E(C) ∩ M) (t := E(C) ∩ M') hdisj\n  have hunion :\n      (E(C) ∩ M) ∪ (E(C) ∩ M') = E(C) := by\n    ext e\n    constructor\n    · intro he\n      exact he.elim (fun heM => heM.1) (fun heM' => heM'.1)\n    · intro heC\n      by_cases hmem : e ∈ M\n      · exact Or.inl ⟨heC, hmem⟩\n      · have : e ∈ M' := by\n          have : e ∈ M ∆ M' := by\n            simpa [symmDiff, hmem, heC] using (by\n              have : e ∈ E(C) := heC\n              exact this)\n          simpa [symmDiff, hmem] using this\n        exact Or.inr ⟨heC, this⟩\n  have henc :\n      (E(C) ∩ M).encard + (E(C) ∩ M').encard = (E(C)).encard := by\n    simpa [hunion] using hsum\n  have hpar : (E(C)).encard = 2 * (E(C) ∩ M).encard := by\n    have := hC.encard_edgeSet_eq_two_mul_encard_inter_matching hM\n    simpa using this\n  have hpar' : (E(C)).encard = 2 * (E(C) ∩ M').encard := by\n    have := hC.encard_edgeSet_eq_two_mul_encard_inter_matching hM'\n    simpa using this\n  have : (E(C) ∩ M).encard = (E(C) ∩ M').encard := by\n    have hm : (E(C) ∩ M).encard + (E(C) ∩ M').encard = 2 * (E(C) ∩ M).encard := by\n      simpa [hpar] using henc.trans (by rfl)\n    have hm' : (E(C) ∩ M).encard + (E(C) ∩ M').encard = 2 * (E(C) ∩ M').encard := by\n      simpa [hpar'] using henc.trans (by rfl)\n    have : 2 * (E(C) ∩ M).encard = 2 * (E(C) ∩ M').encard := by\n      simpa [hm, hm'] using congrArg id rfl\n    exact Nat.mul_left_cancel₀ (by decide) this\n  simpa using this",
      "\n  classical\n  have hd : Disjoint (E(C) ∩ M) (E(C) ∩ M') :=\n    hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.le\n  have hsub : E(C) ⊆ M ∆ M' := by\n    intro e he\n    have : e ∈ E(hM.restrict₂ hM') := by\n      have hCE : E(C) ⊆ E(hM.restrict₂ hM') := hCG.subset_edgeSet\n      exact hCE he\n    simpa [IsMatching.restrict₂] using this\n  have hpair : (E(C) ∩ M) ⊆ (E(C) ∩ M')ᶜ := by\n    intro e he\n    exact hd.le_bot ⟨he, ·⟩\n  have hpair' : (E(C) ∩ M') ⊆ (E(C) ∩ M)ᶜ := by\n    intro e he\n    exact hd.symm.le_bot ⟨he, ·⟩\n  have hpart :\n      E(C) = (E(C) ∩ M) ∪ (E(C) ∩ M') := by\n    ext e; constructor\n    · intro he\n      have : e ∈ M ∆ M' := hsub he\n      rcases this with (hm | hm')\n      · exact Or.inl ⟨he, hm⟩\n      · exact Or.inr ⟨he, hm'⟩\n    · rintro (he | he)\n      · exact he.1\n      · exact he.1\n  have hdisj : Disjoint (E(C) ∩ M) (E(C) ∩ M') := hd\n  have henc :\n      (E(C) ∩ M).encard + (E(C) ∩ M').encard = E(C).encard := by\n    simpa [hpart, encard_union_eq, hdisj] using (encard_union_eq (s := E(C) ∩ M) (t := E(C) ∩ M') hdisj).symm\n  have hcycle : Even (E(C).encard) := by\n    simpa using hC.even_encard_edgeSet\n  have : (E(C) ∩ M).encard = (E(C) ∩ M').encard := by\n    have hsum : Even ((E(C) ∩ M).encard + (E(C) ∩ M').encard) := by\n      simpa [henc] using hcycle\n    have hbound :\n        (E(C) ∩ M).encard ≤ (E(C) ∩ M').encard ∧\n        (E(C) ∩ M').encard ≤ (E(C) ∩ M).encard := by\n      constructor <;> exact le_of_lt (Nat.lt_of_lt_of_le (Nat.lt_succ_self _) (Nat.le_add_left _ _))\n    exact le_antisymm hbound.1 hbound.2\n  exact this",
      "\n  classical\n  have hdisj := hM.disjoint_inter_of_isCycleGraph_symmDiff (hM' := hM') (hC := hC) (hCG := hCG.le)\n  have hsub :\n      E(C) ⊆ M ∪ M' := by\n    intro e heC\n    have he' : e ∈ E(hM.restrict₂ hM') := by\n      have : E(C) ⊆ E(hM.restrict₂ hM') := by\n        simpa [Graph.IsCompOf, Graph.Subgraph] using hCG.subset_edgeSet\n      exact this heC\n    have : e ∈ M ∆ M' := by\n      simpa [IsMatching.restrict₂, Graph.loopRemove, Graph.restrict] using he'\n    simpa [symmDiff, Set.mem_union, Set.mem_diff, Set.mem_compl_iff] using this\n  have hpart :\n      (E(C) ∩ (M ∪ M')).encard = (E(C) ∩ M).encard + (E(C) ∩ M').encard := by\n    have : Disjoint (E(C) ∩ M) (E(C) ∩ M') := hdisj\n    simpa [Set.inter_union_distrib_left, Set.union_assoc, Set.union_left_comm, Set.union_comm,\n      Set.inter_assoc, Set.inter_left_comm, Set.inter_comm] using\n      (encard_inter_add_encard_inter_eq_encard_inter_union (s := E(C)) (t := M) (u := M') this)\n  have hEC : (E(C) ∩ (M ∪ M')).encard = E(C).encard := by\n    apply (encard_eq_of_subset_of_card_le (by\n      intro e he\n      exact ⟨he, hsub he⟩) ?_).symm\n    exact encard_mono (by intro e he; exact he.1)\n  have hcycle := hC.edgeSet_encard_even\n  have : Even ((E(C) ∩ M).encard + (E(C) ∩ M').encard) := by\n    simpa [hEC, hpart] using hcycle\n  have hsum :\n      (E(C) ∩ M).encard + (E(C) ∩ M').encard = E(C).encard := by\n    simpa [hEC, hpart] using rfl\n  have hdeg :\n      (hM.restrict₂ hM').MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two (hM' := hM')\n  have hpath :\n      C.IsCycleGraph := hC\n  exact hC.encard_inter_eq_of_disjoint_of_isCompOf_maxDegreeLE_two hdeg hCG hdisj",
      "\n  classical\n  by_contra hne\n  have hdis : Disjoint (E(C) ∩ M) (E(C) ∩ M') :=\n    hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.le\n  have hlt : (E(C) ∩ M).encard < (E(C) ∩ M').encard ∨ (E(C) ∩ M').encard < (E(C) ∩ M).encard := by\n    exact lt_or_gt_of_ne hne\n  cases hlt with\n  | inl hlt =>\n      have : ((E(C) ∩ M) ∪ (E(C) ∩ M')).encard = (E(C) ∩ M).encard + (E(C) ∩ M').encard :=\n        encard_union_eq hdis\n      have hle : (E(C) ∩ M').encard ≤ ((E(C) ∩ M) ∪ (E(C) ∩ M')).encard := by\n        simpa [this] using le_add_of_nonneg_left (by simp)\n      exact (not_lt_of_ge hle) (lt_of_lt_of_le hlt (by\n        simpa [this] using le_add_of_nonneg_left (by simp)))\n  | inr hlt =>\n      have : ((E(C) ∩ M') ∪ (E(C) ∩ M)).encard = (E(C) ∩ M').encard + (E(C) ∩ M).encard := by\n        simpa [union_comm, add_comm] using (encard_union_eq (hdis.symm))\n      have hle : (E(C) ∩ M).encard ≤ ((E(C) ∩ M') ∪ (E(C) ∩ M)).encard := by\n        simpa [this] using le_add_of_nonneg_left (by simp)\n      exact (not_lt_of_ge hle) (lt_of_lt_of_le hlt (by\n        simpa [this] using le_add_of_nonneg_left (by simp)))",
      "\n  classical\n  simpa using hC.encard_inter_eq_of_isMatching_isCompOf_symmDiff hM hM' hCG",
      "\n  classical\n  have hdisj := hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.le\n  have hcycle := hC.even_edgeSet_encard\n  have hsum :\n      (E(C) ∩ M).encard + (E(C) ∩ M').encard = E(C).encard := by\n    simpa [Set.inter_assoc, Set.inter_left_comm, Set.inter_comm] using\n      (encard_inter_add_encard_inter_eq_encard hdisj (by\n        ext e\n        constructor\n        · intro he\n          exact he.1\n        · intro he\n          refine ⟨he, ?_⟩\n          rcases hCG.edge_mem_of_mem he with ⟨hmem, -⟩\n          simpa [IsMatching.restrict₂, Graph.loopRemove, Graph.restrict] using hmem))\n  have :\n      (E(C) ∩ M).encard = (E(C) ∩ M').encard := by\n    have hpar : Even ((E(C) ∩ M).encard + (E(C) ∩ M').encard) := by\n      simpa [hsum] using hcycle\n    exact even_add_eq.1 hpar\n  exact this",
      "\n  classical\n  have hdis : Disjoint (E(C) ∩ M) (E(C) ∩ M') :=\n    hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.le\n  have hfin : (E(C) ∩ M).Finite := by\n    refine (hC.edgeFinite ?_).subset ?_\n    · exact hC.le_edgeSet\n    · intro e he\n      exact he.1\n  have hfin' : (E(C) ∩ M').Finite := by\n    refine (hC.edgeFinite ?_).subset ?_\n    · exact hC.le_edgeSet\n    · intro e he\n      exact he.1\n  have hdeg : ∀ v : α, E(C, v).encard = 2 := by\n    intro v\n    by_cases hv : v ∈ V(C)\n    · simpa [hC.eDegree_eq_two hv, eDegree_eq_encard_inc]\n    · have : E(C, v) = ∅ := by\n        ext e\n        constructor\n        · rintro ⟨w, hw⟩\n          have : v ∈ V(C) := by\n            exact hw.2.1\n          exact (hv this).elim\n        · intro he\n          simpa using he\n      simp [this]\n  have hchain : C.edge.IsChain (fun e f ↦ e ∈ M ∨ f ∈ M) := by\n    simpa [hC.edge] using hC.edge_chain_mem_or_mem hM hM'\n  have hcount :\n      (E(C) ∩ M).encard + (E(C) ∩ M').encard = E(C).encard := by\n    have : (E(C) ∩ M) ⊔ (E(C) ∩ M') = E(C) := by\n      ext e\n      constructor\n      · intro he\n        rcases he with ⟨he | he⟩ <;> exact he.1\n      · intro he\n        have heC : e ∈ E(C) := he\n        have : e ∈ M ∨ e ∈ M' := by\n          have : e ∈ M ∆ M' := by\n            have : e ∈ E(hM.restrict₂ hM') := by\n              have := hCG.subset_edgeSet (by simpa using heC)\n              simpa [IsMatching.restrict₂, Graph.loopRemove, Graph.restrict] at this\n            simpa [symmDiff] using this\n          simpa [symmDiff, and_left_comm, and_assoc, and_comm] using this\n        rcases this with hMmem | hM'mem\n        · exact Or.inl ⟨heC, hMmem⟩\n        · exact Or.inr ⟨heC, hM'mem⟩\n    have hdis' : Disjoint (E(C) ∩ M) (E(C) ∩ M') := hdis\n    have := (encard_sup_eq (hfin) (hfin') hdis').trans ?_\n    · simpa [this] using this\n    · simpa [this] using congrArg Set.encard this\n  have hpar :\n      (E(C) ∩ M).encard = (E(C) ∩ M').encard := by\n    have hEfin : (E(C)).Finite := by\n      exact hC.edgeFinite hC.le_edgeSet\n    have hEven : Even (E(C)).encard := by\n      simpa [hC.edge_encard_even] using hC.edge_encard_even\n    have hsum : (E(C) ∩ M).encard + (E(C) ∩ M').encard = E(C).encard := hcount\n    have hle : (E(C) ∩ M).encard ≤ (E(C) ∩ M').encard := by\n      sorry\n    have hle' : (E(C) ∩ M').encard ≤ (E(C) ∩ M).encard := by\n      sorry\n    exact le_antisymm_iff.mp ⟨hle, hle'⟩\n  simpa using hpar",
      "\n  by_contra hne\n  have hdis : Disjoint (E(C) ∩ M) (E(C) ∩ M') :=\n    hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC (by\n      intro e he\n      exact hCG.subset he)\n  have hss : (E(C) ∩ M).encard = (E(C) ∩ M').encard := by\n    simpa using hC.encard_inter_eq_of_disjoint_matching hM hM' hdis hCG\n  exact hne hss",
      "\n  classical\n  simpa [Set.inter_assoc, Set.inter_left_comm, Set.inter_comm] using\n    (hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG.le).encard_eq",
      "\n  simpa [encard_eq_toFinset_card] using hC.encard_inter_eq_of_isCompOf_symmDiff hM hM' hCG",
      "\n  classical\n  simpa [Nat.cast_one] using hC.encard_inter_eq_of_isMatching_isCompOf_restrict₂ hM hM' hCG",
      "\n  classical\n  have hdis : Disjoint (E(C) ∩ M) (E(C) ∩ M') :=\n    hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC (le_of_eq hCG.eq_subgraph)\n  have hfin : (E(C)).Finite := by\n    simpa [Graph.IsCycleGraph] using hC.edgeFinite\n  have hcard : (E(C) ∩ M).encard + (E(C) ∩ M').encard = (E(C)).encard := by\n    have : (E(C) ∩ M) ∪ (E(C) ∩ M') = E(C) := by\n      ext e\n      constructor\n      · intro he\n        exact he.elim (fun h => h.1) (fun h => h.1)\n      · intro he\n        by_cases hm : e ∈ M\n        · exact Or.inl ⟨he, hm⟩\n        · have hm' : e ∈ M' := by\n            have : e ∈ M ∆ M' := by\n              have hs : E(C) ⊆ E(hM.restrict₂ hM') := by\n                simpa [hCG.eq_subgraph] using hCG.subset_edgeSet\n              have : e ∈ E(hM.restrict₂ hM') := hs he\n              simpa [IsMatching.restrict₂, symmDiff] using this\n            simpa [symmDiff, hm] using this\n          exact Or.inr ⟨he, hm'⟩\n    simpa [encard_union_eq, this, hdis, hfin.subset (by intro e he; exact he.1),\n      hfin.subset (by intro e he; exact he.1)]\n  have hcard' : (E(C) ∩ M').encard + (E(C) ∩ M).encard = (E(C)).encard := by\n    simpa [add_comm] using hcard\n  exact add_left_cancel (by simpa [add_comm] using congrArg (fun n => n + (E(C) ∩ M).encard) (Eq.trans hcard hcard'))",
      "\n  classical\n  simpa [encard_eq_coe_card] using\n    hC.encard_inter_eq_of_isCompOf_symmDiff (G := G) (M := M) (M' := M') hM hM' hCG",
