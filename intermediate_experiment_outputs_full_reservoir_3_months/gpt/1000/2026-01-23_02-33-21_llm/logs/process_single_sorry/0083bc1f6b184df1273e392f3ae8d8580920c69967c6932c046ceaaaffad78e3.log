/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C :=
  by
  classical
  have hUC : UniformContinuous f := hf.uniformContinuous
  obtain ⟨δ, hδpos, hδ⟩ := (uniformContinuous_iff.1 hUC) (1 : ℝ) (by norm_num)
  have hbd_Icc : BddAbove (Set.image (fun x : ℝ ↦ ‖f x‖) (Set.Icc 0 δ)) := by
    refine (bddAbove_image (s := Set.Icc (0 : ℝ) δ) (f := fun x : ℝ ↦ ‖f x‖)).2 ?_
    exact (isCompact_Icc : IsCompact (Set.Icc (0 : ℝ) δ)).bddAbove
  refine ⟨sSup (Set.image (fun x : ℝ ↦ ‖f x‖) (Set.Icc 0 δ)) + (‖f 0‖ + 1), ?_⟩
  intro x
  set n : ℤ := Int.floor (x / δ)
  set y : ℝ := x - n * δ
  have hnle : (n : ℝ) ≤ x / δ := by exact Int.floor_le (x / δ)
  have hlt : x / δ < (n : ℝ) + 1 := by exact Int.lt_floor_add_one (x / δ)
  have hny_nonneg : 0 ≤ y := by
    have : n * δ ≤ x := by
      have := mul_le_mul_of_nonneg_right hnle (le_of_lt hδpos)
      simpa [n] using this
    simpa [y, sub_nonneg] using this
  have hny_lt : y < δ := by
    have : x < (n + 1) * δ := by
      have := mul_lt_mul_of_pos_right hlt hδpos
      simpa [n, add_mul] using this
    have : x - n * δ < δ := by
      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, y, sub_lt_iff_lt_add] using
        (by
          have := this
          simpa [y, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using
            (sub_lt_iff_lt_add.2 (by simpa [add_assoc, add_left_comm, add_comm, add_mul] using this)))
    exact this
  have hdist : dist x y = ‖(n : ℝ) * δ‖ := by
    simp [dist_eq_norm, y, sub_sub, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, norm_mul]
  have hdist_lt : dist x y < δ := by
    have : dist x y = ‖x - y‖ := by simp [dist_eq_norm]
    have : x - y = (n : ℝ) * δ := by
      simp [y, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, sub_sub]
    simp [dist_eq_norm, y, this, hδpos.le] 
  have hxy : ‖f x - f y‖ ≤ 1 := by
    have := hδ x y
    have h' : dist x y < δ := by
      have : |x - y| < δ := by
        have : y ∈ Set.Icc (0 : ℝ) δ := by
          refine ⟨hny_nonneg, le_of_lt ?_⟩
          exact hny_lt.trans_le (le_rfl)
        have : dist x y < δ := by
