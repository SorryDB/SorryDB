    refine le_csSup hbd_Icc ?_
    refine ⟨y, hyIcc, rfl⟩
  have hx_le : ‖f x‖ ≤ ‖f y‖ + (‖f 0‖ + 1) := by
    have : ‖f x‖ ≤ ‖f y‖ + ‖f x - f y‖ := by
      simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using
