    have : ‖f x‖ ≤ ‖f y‖ + (‖f 0‖ + 1) := by
      linarith [norm_nonneg (f 0)]
    exact this
  have : ‖f x‖ ≤ sSup (Set.image (fun x : ℝ ↦ ‖f x‖) (Set.Icc 0 δ)) + (‖f 0‖ + 1) := by
    linarith [hx_le, hy_le_sup]
  simpa using this
