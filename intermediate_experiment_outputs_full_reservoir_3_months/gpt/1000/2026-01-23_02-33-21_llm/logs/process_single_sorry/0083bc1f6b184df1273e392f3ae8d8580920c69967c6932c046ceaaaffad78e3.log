/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C :=
  by
  have huc : UniformContinuous f := hf.uniformContinuous
  have : Bornology.IsBounded (Set.range f) := by
    simpa [Metric.isBounded_iff] using huc.isBounded_range
  rcases this.subset_closedBall 0 with ⟨C, hC⟩
  refine ⟨C, ?_⟩
