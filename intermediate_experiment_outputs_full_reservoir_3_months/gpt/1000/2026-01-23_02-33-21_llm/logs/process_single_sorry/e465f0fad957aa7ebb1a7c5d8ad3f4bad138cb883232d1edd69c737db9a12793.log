section Lp

open MeasureTheory ENNReal Set

/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := by sorry
  empty := by sorry
  mono {S T} hST := by sorry
  iUnion_nat := by
    intro s hs
    by_cases hpi : Real.pi ∈ ⋃ i, s i
    · have : ∃ i, Real.pi ∈ s i := by
        simpa [mem_iUnion] using hpi
      rcases this with ⟨i, hi⟩
      have hsum : (∑' i : ℕ, (if Real.pi ∈ s i then (1 : ℝ≥0∞) else 0)) = 1 := by
        have huniq : ∀ j : ℕ, j ≠ i → Real.pi ∉ s j := by
          intro j hij
          intro hj
          have : Disjoint (s i) (s j) := hs i j hij
          exact this.le_bot ⟨hi, hj⟩
        have :
            (fun j : ℕ => if Real.pi ∈ s j then (1 : ℝ≥0∞) else 0) =
              fun j : ℕ => if j = i then (1 : ℝ≥0∞) else 0 := by
          funext j
          by_cases hji : j = i
          · subst hji; simp [hi]
          · have : Real.pi ∉ s j := huniq j (Ne.symm hji)
            simp [hji, this]
        simp [this]
      simpa [OuterMeasure.iUnion_nat, hpi, hsum]
    · have : ∀ i, Real.pi ∉ s i := by
        intro i hi
        apply hpi
        exact mem_iUnion.2 ⟨i, hi⟩
      have hsum :
          (∑' i : ℕ, (if Real.pi ∈ s i then (1 : ℝ≥0∞) else 0)) = 0 := by
        simp [this]
      simpa [OuterMeasure.iUnion_nat, hpi, hsum]
