      "by\n  refine lt_of_le_of_ne (refinement_le (D := D) B hB hB' hB'') ?_\n  intro h_eq\n  rcases H with ⟨N, hN, h_ne⟩\n  have h_subset : B N hN ⊆ (refinement (D := D) B hB hB' hB'') := by\n    intro x hx\n    refine Set.mem_iUnion.mpr ⟨N, ?_⟩\n    refine Set.mem_iUnion.mpr ⟨hN, ?_⟩\n    exact hx\n  have h_sup : sSup (B N hN) ≤ sSup (SetLike.coe D) := by\n    have : (refinement (D := D) B hB hB' hB'') = D := by\n      simpa using congrArg id h_eq.symm\n    have h_sSup_le : sSup (B N hN) ≤ sSup (refinement (D := D) B hB hB' hB'') :=\n      sSup_le_sSup h_subset\n    simpa [this] using h_sSup_le\n  have h_eqN : N = sSup (B N hN) := hB N hN\n  have h_le : N ≤ sSup (SetLike.coe D) := by\n    simpa [h_eqN] using h_sup\n  have h_top : sSup (SetLike.coe D) = (⊤ : PersistenceSubmodule M) := D.sSup_eq_top\n  have h_le_top : N ≤ ⊤ := by simpa [h_top] using h_le\n  have hN_top : N = ⊤ := top_unique h_le_top\n  have h_single : B N hN = {N} := by\n    have : sSup (B N hN) = N := by simpa [hN_top] using (hB N hN).symm\n    have h_indep := hB' N hN\n    have h_notbot := hB'' N hN\n    classical\n    by_contra hBne\n    have : ∃ x, x ∈ B N hN ∧ x ≠ N := by\n      have : ¬ B N hN ⊆ {N} := by\n        intro hsub\n        have : B N hN = {N} := by\n          apply Set.Subset.antisymm hsub\n          intro y hy\n          have : y = N := by\n            have : y ≤ sSup (B N hN) := le_sSup hy\n            simpa [this] using le_antisymm (show y ≤ N from by\n              simpa [hB N hN] using this) (by\n              have : N ≤ sSup (B N hN) := by simpa [hB N hN] using le_rfl\n              exact le_trans (le_sSup (by simpa using hy)) this)\n          simpa [this]\n        exact hBne this\n      simpa [Set.subset_def, not_forall] using this\n    rcases this with ⟨x, hx, hxne⟩\n    have hx_le : x ≤ N := by\n      have : x ≤ sSup (B N hN) := le_sSup hx\n      simpa [hB N hN] using this\n    have hdisj : Disjoint x (sSup ({N} : Set (PersistenceSubmodule M))) := by\n      have hx_not : x 