/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M ` -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    D < refinement B hB hB' hB'' := by
  classical
  refine lt_of_le_of_ne (refinement_le (D := D) B hB hB' hB'') ?_
  intro hEq
  rcases H with ⟨N, hN, hne⟩
  have hBsubset : B N hN ⊆ refinement (D := D) B hB hB' hB'' := by
    intro x hx
    exact Set.mem_iUnion.2 ⟨N, Set.mem_iUnion.2 ⟨hN, hx⟩⟩
  have hBsubset' : B N hN ⊆ D := by
    simpa [hEq] using hBsubset
  have hTop : sSup (B N hN) = N := by simpa [hB N hN]
  have hNe : sSup (B N hN) ≠ ⊥ := by
    intro h0
    have : N = (⊥ : PersistenceSubmodule M) := by simpa [hTop] using congrArg id h0
    exact D.not_bot_mem (this ▸ hN)
  have hSupSingle : sSup (B N hN) = sSup ({N} : Set (PersistenceSubmodule M)) := by
    simpa [hTop]
  have hEqB : B N hN = ({N} : Set (PersistenceSubmodule M)) := by
    exact (sSupIndep.eq_singleton_of_sSup_eq_sSup_singleton (hB' N hN) hBsubset' hSupSingle hNe)
  exact hne hEqB
```
