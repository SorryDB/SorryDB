      "by\n  refine lt_of_le_of_ne (refinement_le (D := D) B hB hB' hB'') ?_\n  intro hEq\n  rcases H with ⟨N, hN, hne⟩\n  have hmem : N ∈ (refinement (D := D) B hB hB' hB'') := by\n    refine Set.mem_iUnion.mpr ⟨N, ?_⟩\n    refine Set.mem_iUnion.mpr ⟨hN, ?_⟩\n    have : N ∈ B N hN := by\n      have : sSup (B N hN) ≤ N := by\n        simpa [hB N hN] using le_rfl\n      have : N ≤ sSup (B N hN) := by\n        simpa [hB N hN] using le_rfl\n      have hs : sSup (B N hN) = N := le_antisymm this this\n      have hnnb : N ≠ (⊥ : PersistenceSubmodule M) := by\n        intro hbot\n        exact D.not_bot_mem (hbot ▸ hN)\n      have hnonempty : (B N hN).Nonempty := by\n        by_contra hempty\n        have : sSup (B N hN) = (⊥ : PersistenceSubmodule M) := by\n          simpa [Set.not_nonempty_iff_eq_empty.mp hempty]\n        exact hnnb (by simpa [hs] using this)\n      rcases hnonempty with ⟨x, hx⟩\n      by_contra hxN\n      have hle : x ≤ N := by\n        have : sSup (B N hN) ≤ N := by simpa [hB N hN] using le_rfl\n        exact le_trans (le_sSup hx) this\n      have hdisj : Disjoint x N := by\n        refine (hB' N hN).disjoint_sSup hx ?_ hxN\n        intro y hy\n        exact le_trans (le_sSup hy) (by simpa [hB N hN] using le_rfl)\n      have : x = (⊥ : PersistenceSubmodule M) :=\n        le_antisymm (le_of_lt ?_) bot_le\n      · exact (hB'' N hN) (this ▸ hx)\n      ·\n        have hxne : x ≠ (⊥ : PersistenceSubmodule M) := by\n          intro hxb\n          exact (hB'' N hN) (hxb ▸ hx)\n        exact right_lt_sup_of_left_ne_bot (disjoint_comm.mp hdisj) hxne\n    exact this\n  have : N ∈ D := by simpa [hEq] using hmem\n  have hmem' : N ∈ B N hN := by\n    have : N ∈ (B N hN) := by\n      have : N ∈ ({N} : Set (PersistenceSubmodule M)) := by simp\n      have : B N hN = ({N} : Set (PersistenceSubmodule M)) := by\n        by_contra hcontra\n        exact hne hcontra\n      simpa [this] using this\n    exact this\n  have : B N hN = ({N} : Set (PersistenceSubmodule M)) := by\n    ext x\n    constructor\n    · intro hx\n      have hxle : x ≤ N := by\n        have : sSup (B N hN) ≤ N := by simpa [hB N hN] using le_rfl\n        exact le_trans (le_sSup hx) this\n      by_contra hxneN\n      have hdisj : Disjoint x N := by\n        refine (hB' N hN).disjoint_sSup hx ?_ hxneN\n        intro y hy\n        exact le_trans (le_sSup hy) (by simpa [hB N hN] using le_rfl)\n      have hxnb : x ≠ (⊥ : PersistenceSubmodule M) := by\n        intro hxb\n        exact (hB'' N hN) (hxb ▸ hx)\n      have : sSup (B N hN) < x ⊔ sSup (B N hN) :=\n        right_lt_sup_of_left_ne_bot (disjoint_comm.mp (hdisj.mono_right (le_rfl))) hxnb\n      have : (N : PersistenceSubmodule M) < N := by\n        simpa [hB N hN, sup_eq_left.mpr (le_sSup hx)] using this\n      exact (lt_self_iff_false _).mp this\n    · intro hx\n      simpa [Set.mem_singleton_iff.mp hx] using (by\n        have : N ∈ B N hN := by\n          by_contra hnot\n          have hdisj : Disjoint N (sSup (B N hN)) := by\n            refine (hB' N hN).disjoint_sSup ?_ ?_ hnot\n            ·\n              have : (B N hN).Nonempty := by\n                by_contra hempty\n                have : sSup (B N hN) = (⊥ : PersistenceSubmodule M) := by\n                  simpa [Set.not_nonempty_iff_eq_empty.mp hempty]\n                have hnnb : N ≠ (⊥ : PersistenceSubmodule M) := by\n                  intro hbot\n                  exact D.not_bot_mem (hbot ▸ hN)\n                exact hnnb (by simpa [hB N hN] using this)\n              rcases this with ⟨z, hz⟩\n              exact hz\n            · intro y hy\n              exact le_trans (le_sSup hy) (by simpa [hB N hN] using le_rfl)\n          have : sSup (B N hN) ≤ N := by simpa [hB N hN] using le_rfl\n          have : sSup (B N hN) = (⊥ : PersistenceSubmodule M) :=\n            Disjoint.eq_bot_of_le (disjoint_comm.mp hdisj) this\n          have hnnb : N ≠ (⊥ : PersistenceSubmodule M) := by\n            intro hbot\n            exact D.not_bot_mem (hbot ▸ hN)\n  