      · -- otherwise, we do not need more: contradiction to primality via p | 1 from gcd argument
        exact Nat.ModEq.refl 3
    exact hpprime.not_dvd_one (by
      have : p ∣ 1 := by simpa [Nat.ModEq, Nat.ModEq] using this
      simpa using this)
  exact this

end Imo1971P3
