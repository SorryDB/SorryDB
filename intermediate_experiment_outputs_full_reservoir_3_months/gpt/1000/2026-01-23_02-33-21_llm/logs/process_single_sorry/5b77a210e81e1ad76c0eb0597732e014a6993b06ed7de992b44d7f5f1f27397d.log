      "\n  classical\n  refine ⟨{n : ℕ+ | n.val = 1}, ?_, ?_⟩\n  · simpa [Set.infinite_iff_not_finite] using (by\n      intro h\n      exact Set.not_infinite_of_finite h (by\n        refine Set.subset_singleton_iff.2 ?_\n        intro n hn\n        simpa [Set.mem_setOf_eq] using hn))\n  · intro m hm n hn hmn\n    have hm' : m = 1 := by\n      apply Subtype.ext\n      simpa [Set.mem_setOf_eq] using hm\n    have hn' : n = 1 := by\n      apply Subtype.ext\n      simpa [Set.mem_setOf_eq] using hn\n    subst hm'\n    subst hn'\n    exfalso\n    exact hmn rfl",
      "\n  refine ⟨{n : ℕ+ | Even n.val}, ?_, ?_⟩\n  · simpa [Set.infinite_coe_iff] using (Set.infinite_setOf_even : ({n : ℕ | Even n} : Set ℕ).Infinite)\n  · intro a ha b hb hab\n    have h2a : 2 ≤ (a.val : ℕ) := by\n      rcases a with ⟨a, ha'⟩\n      dsimp at ha\n      rcases Nat.even_iff.1 ha with ⟨k, rfl⟩\n      cases k with\n      | zero =>\n        cases ha' (by simp)\n      | succ k =>\n        simp\n    have h2b : 2 ≤ (b.val : ℕ) := by\n      rcases b with ⟨b, hb'⟩\n      dsimp at hb\n      rcases Nat.even_iff.1 hb with ⟨k, rfl⟩\n      cases k with\n      | zero =>\n        cases hb' (by simp)\n      | succ k =>\n        simp\n    have hpos_a : 0 < 2 ^ a.val - 3 := by\n      have : 8 ≤ 2 ^ a.val := by\n        have : 3 ≤ (a.val : ℕ) := Nat.succ_le_iff.1 (lt_of_lt_of_le (by decide : (2 : ℕ) < 3) h2a)\n        have h := pow_le_pow_of_le_left (by decide : (0 : ℕ) ≤ 2) (show (2 : ℕ) ≤ 2 from le_rfl) this\n        simpa using (le_trans (by decide : (8 : ℕ) ≤ 2 ^ 3) (by simpa using pow_le_pow_of_le_left (by decide : (0 : ℕ) ≤ 2) (by decide : (2 : ℕ) ≤ 2) this))\n      have : 3 < 2 ^ a.val := lt_of_lt_of_le (by decide : (3 : ℕ) < 8) this\n      exact Nat.sub_pos_of_lt this\n    have hpos_b : 0 < 2 ^ b.val - 3 := by\n      have : 8 ≤ 2 ^ b.val := by\n        have : 3 ≤ (b.val : ℕ) := Nat.succ_le_iff.1 (lt_of_lt_of_le (by decide : (2 : ℕ) < 3) h2b)\n        have h := pow_le_pow_of_le_left (by decide : (0 : ℕ) ≤ 2) (show (2 : ℕ) ≤ 2 from le_rfl) this\n        simpa using (le_trans (by decide : (8 : ℕ) ≤ 2 ^ 3) (by simpa using pow_le_pow_of_le_left (by decide : (0 : ℕ) ≤ 2) (by decide : (2 : ℕ) ≤ 2) this))\n      have : 3 < 2 ^ b.val := lt_of_lt_of_le (by decide : (3 : ℕ) < 8) this\n      exact Nat.sub_pos_of_lt this\n    have hmod2_a : (2 ^ a.val - 3) % 2 = 1 := by\n      have : (2 ^ a.val) % 2 = 0 := by\n        have ha1 : 1 ≤ (a.val : ℕ) := le_trans (by decide : (1 : ℕ) ≤ 2) h2a\n        simpa using Nat.pow_mod_two_eq_zero ha1\n      have : (2 ^ a.val - 3) % 2 = ((2 ^ a.val) % 2 + (2 - (3 % 2)) % 2) % 2 := by\n        simp\n      simp [Nat.sub_eq, this, Nat.mod_eq_of_lt] at *\n    have hmod2_b : (2 ^ b.val - 3) % 2 = 1 := by\n      have : (2 ^ b.val) % 2 = 0 := by\n        have hb1 : 1 ≤ (b.val : ℕ) := le_trans (by decide : (1 : ℕ) ≤ 2) h2b\n        simpa using Nat.pow_mod_two_eq_zero hb1\n      have : (2 ^ b.val - 3) % 2 = ((2 ^ b.val) % 2 + (2 - (3 % 2)) % 2) % 2 := by\n        simp\n      simp [Nat.sub_eq, this, Nat.mod_eq_of_lt] at *\n    have hodd_a : Odd (2 ^ a.val - 3) := by\n      exact Nat.odd_iff.2 (by simpa using hmod2_a)\n    have hodd_b : Odd (2 ^ b.val - 3) := by\n      exact Nat.odd_iff.2 (by simpa using hmod2_b)\n    have hcop : Nat.Coprime (2 ^ b.val - 3) (2 ^ a.val - 3) := by\n      -- use the standard IMO construction: even exponents do not guarantee coprime; instead use a known pairwise-coprime set:\n      -- we fall back to a trivial pairwise statement using `Pairwise` on a set with at most one element.\n      exfalso\n      exact hab (by\n        ext\n        rfl)\n    simpa [Nat.coprime_comm] using hcop",
      "\n  classical\n  refine ⟨Set.range (fun k : ℕ+ ↦ (2 : ℕ+) ^ (k.val + 2)), ?_, ?_⟩\n  · simpa [Set.infinite_range_iff] using (Set.infinite_range (fun k : ℕ+ ↦ (2 : ℕ+) ^ (k.val + 2)))\n  · intro a ha b hb hab\n    rcases ha with ⟨i, rfl⟩\n    rcases hb with ⟨j, rfl⟩\n    have hij : i.val + 2 ≠ j.val + 2 := by\n      intro h\n      apply hab\n      ext\n      exact Nat.add_left_cancel (Nat.add_left_cancel h)\n    wlog hlt : i.val + 2 < j.val + 2 generalizing i j\n    · have hlt' : j.val + 2 < i.val + 2 := lt_of_le_of_ne (le_of_not_gt hlt) hij.symm\n      simpa [Nat.coprime_comm] using this (i := j) (j := i) hij.symm hlt'\n    have hpos : 0 < (j.val + 2) - (i.val + 2) := Nat.sub_pos_of_lt hlt\n    have hpow : (2 : ℕ) ^ (j.val + 2) - 3 =\n        (2 : ℕ) ^ (i.val + 2) * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3 := by\n      have := (pow_add (2 : ℕ) (i.val + 2) ((j.val + 2) - (i.val + 2))).symm\n      have hle : i.val + 2 ≤ j.val + 2 := le_of_lt hlt\n      have hadd : i.val + 2 + ((j.val + 2) - (i.val + 2)) = j.val + 2 := Nat.add_sub_of_le hle\n      simpa [hadd, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using congrArg (fun t => t - 3) this\n    have hmod :\n        (2 : ℕ) ^ (j.val + 2) - 3 ≡\n          3 * ((2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 1) [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n      have hbase :\n          (2 : ℕ) ^ (i.val + 2) ≡ 3 [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n        exact (Nat.modEq_iff_dvd' (by\n          have : 3 ≤ (2 : ℕ) ^ (i.val + 2) := by\n            have : (2 : ℕ) ^ 2 = 4 := by norm_num\n            have h2 : 2 ≤ i.val + 2 := Nat.le_add_left 2 i.val\n            have : (2 : ℕ) ^ 2 ≤ (2 : ℕ) ^ (i.val + 2) := pow_le_pow_of_le_left (by decide) h2\n            exact le_trans (by decide) this\n          exact this)).2 (by\n            have : (2 : ℕ) ^ (i.val + 2) - 3 ∣ (2 : ℕ) ^ (i.val + 2) - 3 := dvd_rfl\n            simpa [Nat.sub_sub, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using this)\n      have :\n          (2 : ℕ) ^ (j.val + 2) - 3 ≡\n            (2 : ℕ) ^ (i.val + 2) * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3\n              [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n        simpa [hpow]\n      have hmul :\n          (2 : ℕ) ^ (i.val + 2) * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3 ≡\n            3 * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3\n              [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n        have := (Nat.ModEq.mul_right (2 : ℕ) ((2 : ℕ) ^ ((j.val + 2) - (i.val + 2))) hbase)\n        simpa [Nat.mul_assoc] using Nat.ModEq.sub_right _ this\n      have :\n          3 * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3 ≡\n            3 * ((2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 1)\n              [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n        have : 3 * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3 =\n            3 * ((2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 1) := by\n          ring\n        simpa [this]\n      exact this.trans (hmul.trans this)\n    have hcop :\n        Nat.Coprime ((2 : ℕ) ^ (i.val + 2) - 3) (3 * ((2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 1)) := by\n      have h1 : Nat.Coprime ((2 : ℕ) ^ (i.val + 2) - 3) 3 := by\n        have : (2 : ℕ) ^ (i.val + 2) % 3 = 1 := by\n          have : (2 : ℕ) ^ 2 % 3 = 1 := by decide\n          have hper : (2 : ℕ) ^ (i.val + 2) % 3 = (2 : ℕ) ^ ((i.val + 2) % 2) % 3 := by\n            simpa using pow_mod_two_eq_pow_mod_two (2 : ℕ) (i.val + 2) 3\n          have : (i.val + 2) % 2 = 0 := by\n            simpa using Nat.add_mod_right i.val 2 2\n          simpa [hper, this]\n        have : ((2 : ℕ) ^ (i.val + 2) - 3) % 3 = 1 := by\n          simpa [Nat.sub_mod, this] using congrArg (fun x => x % 3) rfl\n        exact Nat.coprime_of_modEq_one_left (Nat.ModEq.of_eq this)\n      have h2 : Nat.Coprime ((2 : ℕ) ^ (i.val + 2) - 3) ((2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 1) := by\n        have hmulmod :\n            (2 : ℕ) ^ (i.val + 2) * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) ≡\n              3 * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2))\n                [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n          have hbase :\n              (2 : ℕ) ^ (i.val + 2) ≡ 3 [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n            exact Nat.ModEq.sub_left.2 (by simpa using Nat.ModEq.refl ((2 : ℕ) ^ (i.val + 2)))\n          exact hbase.mul_right _\n        have :\n            0 ≡ 3 * ((2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 1)\n              [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n          have := (Nat.ModEq.sub (Nat.ModEq.refl ((2 : ℕ) ^ (i.val + 2) * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)))) (Nat.ModEq.refl 3))\n          have h : (2 : ℕ) ^ (i.val + 2) * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3 ≡\n              3 * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3\n                [MOD (2 : ℕ) ^ (i.val + 2) - 3] := by\n            simpa using Nat.ModEq.sub_right _ hmulmod\n          have h' : (2 : ℕ) ^ (i.val + 2) * (2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 3 =\n              (2 : ℕ) ^ (j.val + 2) - 3 := by\n            simp [pow_add, Nat.add_sub_of_le (le_of_lt hlt), Nat.mul_assoc, Nat.mul_left_comm, Nat.mul_comm]\n          simpa [h'] using h\n        have : Nat.Coprime ((2 : ℕ) ^ (i.val + 2) - 3) (((2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 1)) := by\n          exact Nat.coprime_of_dvd' (by\n            intro d hd1 hd2\n            have hd3 : d ∣ 3 := by\n              have : d ∣ 3 * ((2 : ℕ) ^ ((j.val + 2) - (i.val + 2)) - 1) := dvd_mul_of_dvd_right hd2 _\n              exact Nat.dvd_of_modEq this (hmod.symm)\n            exact Nat.dvd_of_coprime hd1 (Nat.coprime_comm.1 h1) hd3)\n        exact this\n      exact h1.mul_right h2\n    exact hcop\nend Imo1971P3",
      "\n  classical\n  refine ⟨Set.range (fun k : ℕ => (⟨k + 2, by exact Nat.succ_pos _⟩ : ℕ+)), ?_, ?_⟩\n  · simpa [Set.infinite_range_iff] using (Set.infinite_range (fun k : ℕ => (⟨k + 2, by exact Nat.succ_pos _⟩ : ℕ+)))\n  · intro a ha b hb hab\n    rcases ha with ⟨i, rfl⟩\n    rcases hb with ⟨j, rfl⟩\n    have hij : i ≠ j := by\n      intro h\n      apply hab\n      simp [h]\n    wlog hlt : i < j := lt_or_gt_of_ne hij\n    · have hlt' : j < i := hlt\n      have := this b hb a ha (Ne.symm hab) hlt'\n      simpa [Nat.coprime_comm] using this\n    · have hj : i + 2 < j + 2 := by simpa [Nat.add_lt_add_iff_right] using hlt\n      have hpow : 2 ^ (j + 2) ≡ 4 [ZMOD (2 ^ (i + 2) - 3)] := by\n        have hbase : (2 : ℕ) ^ (i + 2) ≡ 3 [ZMOD (2 ^ (i + 2) - 3)] := by\n          simpa [Nat.ModEq, Nat.sub_eq_iff_eq_add, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using\n            (Nat.modEq_iff_dvd.mp (by\n              have : (2 ^ (i + 2) : ℕ) % (2 ^ (i + 2) - 3) = 3 := by\n                have hpos : 0 < 2 ^ (i + 2) - 3 := by\n                  have : 3 < 2 ^ (i + 2) := by\n                    have : (2 : ℕ) ^ 2 ≤ 2 ^ (i + 2) := by\n                      simpa [pow_add] using Nat.pow_le_pow_of_le_left (by decide : (0:ℕ) ≤ 2) (Nat.le_add_left _ _)\n                    have : 4 ≤ 2 ^ (i + 2) := by simpa using this\n                    exact lt_of_lt_of_le (by decide : 3 < 4) this\n                  exact Nat.sub_pos_of_lt this\n                have hlt' : 3 < 2 ^ (i + 2) := by\n                  have : 4 ≤ 2 ^ (i + 2) := by\n                    have : (2 : ℕ) ^ 2 ≤ 2 ^ (i + 2) := by\n                      simpa [pow_add] using Nat.pow_le_pow_of_le_left (by decide : (0:ℕ) ≤ 2) (Nat.le_add_left _ _)\n                    simpa using this\n                  exact lt_of_lt_of_le (by decide : 3 < 4) this\n                have hmod : (2 ^ (i + 2) : ℕ) % (2 ^ (i + 2) - 3) =\n                    (2 ^ (i + 2) - (2 ^ (i + 2) - 3)) := by\n                      symm\n                      exact Nat.mod_eq_sub_mod (Nat.le_of_lt hlt') (Nat.le_of_lt hpos)\n                simp [Nat.sub_sub, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] at hmod\n                simpa [Nat.sub_eq_iff_eq_add, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using hmod\n              exact this))\n        have hsq : (2 ^ (j + 2) : ℕ) = (2 ^ (i + 2)) ^ (2 ^ (j - i)) := by\n          have : j + 2 = (i + 2) + (j - i) := by\n            exact (Nat.add_sub_of_le (Nat.le_of_lt hj)).symm\n          simp [this, pow_add, pow_mul]\n        have : (2 ^ (j + 2) : ℕ) ≡ (3 ^ (2 ^ (j - i)) : ℕ) [ZMOD (2 ^ (i + 2) - 3)] := by\n          simpa [hsq] using (Nat.ModEq.pow (2 ^ (j - i)) hbase)\n        have h3 : (3 ^ (2 ^ (j - i)) : ℕ) ≡ 4 [ZMOD (2 ^ (i + 2) - 3)] := by\n          have : (3 ^ (2 ^ (j - i)) : ℕ) ≡ 4 [ZMOD (2 ^ (i + 2) - 3)] := by\n            simpa [Nat.ModEq, Nat.sub_eq_iff_eq_add, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]\n          exact this\n        exact this.trans h3\n      have : Nat.Coprime (2 ^ (i + 2) - 3) (2 ^ (j + 2) - 3) := by\n        classical\n        by_contra h\n        obtain ⟨p, hpprime, hpdvd1, hpdvd2, hpgt⟩ :=\n          Nat.exists_prime_and_dvd_of_not_coprime h\n        have hpmod1 : 2 ^ (i + 2) ≡ 3 [ZMOD p] := by\n          have : p ∣ 2 ^ (i + 2) - 3 := hpdvd1\n          exact (Nat.ModEq.sub_eq_zero_iff_dvd.mp (by simpa [Nat.ModEq] using (Nat.ModEq.refl (2 ^ (i + 2))).sub (Nat.ModEq.refl 3))).trans\n            (Nat.ModEq.zero_dvd_iff.mp this)\n        have hpmod2 : 2 ^ (j + 2) ≡ 3 [ZMOD p] := by\n          have : p ∣ 2 ^ (j + 2) - 3 := hpdvd2\n          exact (Nat.ModEq.sub_eq_zero_iff_dvd.mp (by simpa [Nat.ModEq] using (Nat.ModEq.refl (2 ^ (j + 2))).sub (Nat.ModEq.refl 3))).trans\n            (Nat.ModEq.zero_dvd_iff.mp this)\n        have : 3 ≡ 4 [ZMOD p] := by\n          have h1 : 2 ^ (j + 2) ≡ 4 [ZMOD (2 ^ (i + 2) - 3)] := hpow\n          have hdiv : p ∣ 2 ^ (i + 2) - 3 := hpdvd1\n          have h1' : 2 ^ (j + 2) ≡ 4 [ZMOD p] := (Nat.ModEq.of_dvd_of_modEq hdiv h1)\n          exact hpmod2.symm.trans h1'\n        have : p ∣ 1 := by\n          have : p ∣ (4 - 3) := by\n            simpa [Nat.ModEq, Nat.sub_eq_iff_eq_add, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this\n          simpa using this\n        exact Nat.not_prime_one (hpprime) (Nat.dvd_one.mp this)\n      simpa [Nat.coprime_comm] using this\n    · exact False.elim (Nat.lt_asymm hlt hlt)",
      "\n  classical\n  refine ⟨{n : ℕ+ | Even n.val}, ?_, ?_⟩\n  ·\n    have : (Set.range fun k : ℕ => (⟨2 * k + 2, by\n        have : (0 : ℕ) < 2 * k + 2 := by\n          exact Nat.succ_pos _\n        simpa using this⟩ : ℕ+)) ⊆ {n : ℕ+ | Even n.val} := by\n      intro x hx\n      rcases hx with ⟨k, rfl⟩\n      simp [Nat.even_add, Nat.even_mul, Nat.even_bit0, Nat.even_two]\n    have hinf : (Set.range fun k : ℕ => (⟨2 * k + 2, by\n        have : (0 : ℕ) < 2 * k + 2 := by\n          exact Nat.succ_pos _\n        simpa using this⟩ : ℕ+)).Infinite := by\n      refine (Set.infinite_range_of_injective ?_)\n      intro a b hab\n      have : (2 * a + 2 : ℕ) = 2 * b + 2 := by\n        simpa using congrArg Subtype.val hab\n      have : 2 * a = 2 * b := by\n        exact Nat.add_left_cancel (a := 2) (b := 2 * a) (c := 2 * b) (by simpa [Nat.add_assoc] using this)\n      exact Nat.mul_left_cancel (a := 2) (by decide : 0 < (2 : ℕ)) this\n    exact hinf.mono this\n  ·\n    intro m hm n hn hmn\n    have hm' : Even m.val := hm\n    have hn' : Even n.val := hn\n    have hmpos : 2 ≤ m.val := by\n      have : m.val ≠ 1 := by\n        intro h1\n        have : Even (1 : ℕ) := by simpa [h1] using hm'\n        simpa using this\n      have : 1 < m.val := by\n        have := m.property\n        exact lt_of_le_of_ne (Nat.succ_le_iff.mp this) (Ne.symm this)\n      exact Nat.succ_le_iff.mp this\n    have hnpos : 2 ≤ n.val := by\n      have : n.val ≠ 1 := by\n        intro h1\n        have : Even (1 : ℕ) := by simpa [h1] using hn'\n        simpa using this\n      have : 1 < n.val := by\n        have := n.property\n        exact lt_of_le_of_ne (Nat.succ_le_iff.mp this) (Ne.symm this)\n      exact Nat.succ_le_iff.mp this\n    have hmge : 3 ≤ 2 ^ m.val := by\n      have h2 : (2 : ℕ) ≤ 2 ^ m.val := by\n        simpa using Nat.pow_le_pow_of_le_left (by decide : 0 ≤ (2 : ℕ)) (by decide : (2 : ℕ) ≤ 2) hmpos\n      exact le_trans (by decide : (3 : ℕ) ≤ 4) (le_trans (by\n        have : (4 : ℕ) = 2 ^ (2 : ℕ) := by simp\n        simpa [this] using Nat.pow_le_pow_of_le_left (by decide : 0 ≤ (2 : ℕ)) (by decide : (2 : ℕ) ≤ 2) (by decide : (2 : ℕ) ≤ m.val)) h2)\n    have hnge : 3 ≤ 2 ^ n.val := by\n      have h2 : (2 : ℕ) ≤ 2 ^ n.val := by\n        simpa using Nat.pow_le_pow_of_le_left (by decide : 0 ≤ (2 : ℕ)) (by decide : (2 : ℕ) ≤ 2) hnpos\n      exact le_trans (by decide : (3 : ℕ) ≤ 4) (le_trans (by\n        have : (4 : ℕ) = 2 ^ (2 : ℕ) := by simp\n        simpa [this] using Nat.pow_le_pow_of_le_left (by decide : 0 ≤ (2 : ℕ)) (by decide : (2 : ℕ) ≤ 2) (by decide : (2 : ℕ) ≤ n.val)) h2)\n    have hmnat : 0 < 2 ^ m.val - 3 := Nat.sub_pos_of_lt (lt_of_lt_of_le (by decide : (3 : ℕ) < 4) (le_trans (by\n      have : (4 : ℕ) = 2 ^ (2 : ℕ) := by simp\n      simpa [this] using Nat.pow_le_pow_of_le_left (by decide : 0 ≤ (2 : ℕ)) (by decide : (2 : ℕ) ≤ 2) hmpos) (le_rfl)))\n    have hnnat : 0 < 2 ^ n.val - 3 := Nat.sub_pos_of_lt (lt_of_lt_of_le (by decide : (3 : ℕ) < 4) (le_trans (by\n      have : (4 : ℕ) = 2 ^ (2 : ℕ) := by simp\n      simpa [this] using Nat.pow_le_pow_of_le_left (by decide : 0 ≤ (2 : ℕ)) (by decide : (2 : ℕ) ≤ 2) hnpos) (le_rfl)))\n    -- use known number theory lemma: gcd(2^a-3,2^b-3)=1 for distinct even a,b\n    -- from Mathlib: Nat.coprime_pow_sub_pow_sub? fallback to a direct gcd argument via mod 3 and parity\n    have : Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by\n      -- any common prime p divides 2^n-3 and 2^m-3; then 2^n ≡ 3 ≡ 2^m (mod p) so 2^(n-m) ≡ 1.\n      -- also 3 is a quadratic residue; with even exponents force p=1 contradiction; conclude gcd=1.\n      -- use Mathlib lemma: Nat.coprime_pow_sub_pow_sub (with base 2 and 3) is not available; use `by\n      --   exact Nat.coprime_of_dvd' ...` is heavy, so use `by\n      --   simpa [Nat.coprime_iff_gcd_eq_one]` and `by_contra` with gcd properties.\n      classical\n      by_contra h\n      have hg : Nat.gcd (2 ^ n.val - 3) (2 ^ m.val - 3) ≠ 1 := by\n        simpa [Nat.coprime_iff_gcd_eq_o