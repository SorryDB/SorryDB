      "\n  classical\n  refine ⟨{n : ℕ+ | ∃ k : ℕ, n = ⟨k + 2, Nat.succ_pos _⟩}, ?_, ?_⟩\n  ·\n    have hinj : Function.Injective (fun k : ℕ => (⟨k + 2, Nat.succ_pos _⟩ : ℕ+)) := by\n      intro a b hab\n      apply Nat.succ_inj\n      apply Nat.succ_inj\n      exact congrArg Subtype.val hab\n    have hInf : (Set.range fun k : ℕ => (⟨k + 2, Nat.succ_pos _⟩ : ℕ+)).Infinite :=\n      Set.infinite_range_of_injective _ hinj\n    have hEq :\n        ({n : ℕ+ | ∃ k : ℕ, n = ⟨k + 2, Nat.succ_pos _⟩} : Set ℕ+) =\n          Set.range (fun k : ℕ => (⟨k + 2, Nat.succ_pos _⟩ : ℕ+)) := by\n      ext n\n      constructor\n      · intro hn\n        rcases hn with ⟨k, rfl⟩\n        exact ⟨k, rfl⟩\n      · intro hn\n        rcases hn with ⟨k, rfl⟩\n        exact ⟨k, rfl⟩\n    simpa [hEq] using hInf\n  ·\n    intro m hm n hn hmn\n    rcases hm with ⟨a, rfl⟩\n    rcases hn with ⟨b, rfl⟩\n    have hab : a ≠ b := by\n      intro h\n      apply hmn\n      ext\n      simp [h]\n    wlog hlt : a < b\n    · have hlt' : b < a := Nat.lt_of_le_of_ne (Nat.le_of_not_gt hlt) hab.symm\n      simpa [Nat.coprime_comm] using (this _ _ hlt')\n    let x : ℕ := 2 ^ (a + 2) - 3\n    let y : ℕ := 2 ^ (b + 2) - 3\n    have hx : x + 3 = 2 ^ (a + 2) := by\n      have : 3 ≤ 2 ^ (a + 2) := by\n        have : 4 ≤ 2 ^ (a + 2) := by\n          simpa [pow_succ, pow_succ, mul_assoc] using (Nat.pow_le_pow_of_le_left (by decide : (2:ℕ) ≤ 2) (a + 2))\n        exact le_trans (by decide : (3:ℕ) ≤ 4) this\n      exact Nat.sub_add_cancel this\n    have hy : y + 3 = 2 ^ (b + 2) := by\n      have : 3 ≤ 2 ^ (b + 2) := by\n        have : 4 ≤ 2 ^ (b + 2) := by\n          simpa [pow_succ, pow_succ, mul_assoc] using (Nat.pow_le_pow_of_le_left (by decide : (2:ℕ) ≤ 2) (b + 2))\n        exact le_trans (by decide : (3:ℕ) ≤ 4) this\n      exact Nat.sub_add_cancel this\n    have hxy : Nat.gcd x y = 1 := by\n      have hmodx : 2 ^ (b + 2) % x = 3 := by\n        have hxpos : 0 < x := by\n          have : 4 ≤ 2 ^ (a + 2) := by\n          