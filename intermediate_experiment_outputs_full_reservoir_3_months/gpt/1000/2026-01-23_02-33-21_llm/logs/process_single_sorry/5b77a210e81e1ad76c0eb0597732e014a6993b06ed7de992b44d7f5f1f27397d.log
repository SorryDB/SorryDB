        -- mod 3: 2^k mod 3 alternates; 2^k - 3 ≡ 2^k mod 3, never divisible by 3.
        have : ¬ (3 : ℕ) ∣ (2 ^ n.val - 3) := by
          have hmod : (2 ^ n.val : ℕ) % 3 = 1 ∨ (2 ^ n.val : ℕ) % 3 = 2 := by
            have h2mod : (2 : ℕ) % 3 = 2 := by decide
