namespace ch04

open Nat

lemma lemma₁ {p : ℕ} [h : Fact p.Prime] :
    let num_solutions := Finset.card { s : ZMod p | s ^ 2 = - 1 }
    (∃ m, p = 4 * m + 1 → num_solutions = 2) ∧
    (p = 2 → num_solutions = 1) ∧
    (∃ m, p = 4 * m + 1 → num_solutions = 0) := by
  constructor
  · refine ⟨0, ?_⟩
    intro hp
    have : False := by
      have hp1 : p = 1 := by
        simpa [Nat.mul_zero, Nat.zero_add] using hp
      have hprime : Nat.Prime p := (h.out)
