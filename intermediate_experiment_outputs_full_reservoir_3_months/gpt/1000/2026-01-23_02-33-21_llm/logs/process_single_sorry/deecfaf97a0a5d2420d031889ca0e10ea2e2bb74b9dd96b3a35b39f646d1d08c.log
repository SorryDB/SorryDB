              have : (0:ℝ) < 2 * π := by nlinarith [Real.pi_pos]
              simpa [Ioc, this]
            exact this)))
    have hne : (MeasureTheory.volume.restrict (Ioc 0 (2 * π))) (Ioc 0 (2 * π)) ≠ 0 :=
      ne_of_gt hpos
    have hne' : (MeasureTheory.volume.restrict (Ioc 0 (2 * π))).Univ ≠ 0 := by
      simpa [MeasureTheory.Measure.restrict_apply, Set.inter_univ, Set.measurableSet_Ioc] using hne
    have hex : ∃ θ : ℝ,
        MeasureTheory.Integrable
          (fun θ_1 : ℝ ↦ log ‖f (circleMap 0 r θ_1) - circleMap 0 1 θ‖)
          (MeasureTheory.volume.restrict (Ioc 0 (2 * π))) := by
      by_contra hno
      have : (∀ᵐ θ : ℝ ∂(MeasureTheory.volume.restrict (Ioc 0 (2 * π))),
          ¬ MeasureTheory.Integrable
            (fun θ_1 : ℝ ↦ log ‖f (circleMap 0 r θ_1) - circleMap 0 1 θ‖)
            (MeasureTheory.volume.restrict (Ioc 0 (2 * π)))) := by
        simpa [MeasureTheory.ae_iff] using hno
      have : ¬ (∀ᵐ θ : ℝ ∂(MeasureTheory.volume.restrict (Ioc 0 (2 * π))),
          MeasureTheory.Integrable
            (fun θ_1 : ℝ ↦ log ‖f (circleMap 0 r θ_1) - circleMap 0 1 θ‖)
            (MeasureTheory.volume.restrict (Ioc 0 (2 * π)))) := by
        simpa using this
      exact this (by
        simpa [MeasureTheory.ae_iff] using hIae)
    rcases hex with ⟨θ, hθ⟩
    exact MeasureTheory.Integrable.integral_prod_left hI θ
