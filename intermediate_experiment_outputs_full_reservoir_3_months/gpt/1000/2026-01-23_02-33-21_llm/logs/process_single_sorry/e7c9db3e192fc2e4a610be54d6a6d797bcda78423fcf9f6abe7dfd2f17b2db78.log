      "\n  refine ⟨?f, ?g, ?fg, ?gf⟩\n  · intro x\n    refine ⟨f x.1, ?_⟩\n    have hxA : x.1 ∈ A := x.2.1\n    have hxne : x.1 ≠ a := by\n      intro hx\n      exact x.2.2 (by simpa [hx])\n    have hfxB : f x.1 ∈ B := by\n      have : f x.1 ∈ image f A := ⟨x.1, hxA, rfl⟩\n      simpa [h2] using this\n    refine ⟨hfxB, ?_⟩\n    intro hfb\n    have : f x.1 = b := by simpa using congrArg Subtype.val hfb\n    have : x.1 = a := h1 hxA h3 (by simpa [h4] using this)\n    exact hxne this\n  · intro y\n    have hyB : y.1 ∈ B := y.2.1\n    have : y.1 ∈ image f A := by simpa [h2] using hyB\n    rcases this with ⟨x, hxA, rfl⟩\n    refine ⟨⟨x, ?_⟩, ?_⟩\n    · refine ⟨hxA, ?_⟩\n      intro hxa\n      have : f x = b := by simpa using congrArg Subtype.val hxa\n      have : x = a := h1 hxA h3 (by simpa [h4] using this)\n      exact y.2.2 (by\n        apply Subtype.ext\n        simpa [this, h4])\n    · apply Subtype.ext\n      rfl\n  · funext y\n    apply Subtype.ext\n    rfl\n  · funext x\n    apply Subtype.ext\n    rfl",
      "by\n  classical\n  refine ⟨fun x => ⟨f x.1, ?_⟩, ?_, ?_⟩\n  · have hxA : x.1 ∈ A := x.2.1\n    have hxa : x.1 ≠ a := by\n      intro hxa\n      exact x.2.2 (by simpa [hxa])\n    have hfxB : f x.1 ∈ B := by\n      have : f x.1 ∈ image f A := ⟨x.1, hxA, rfl⟩\n      simpa [h2] using this\n    have hfxb : f x.1 ≠ b := by\n      intro hfxb\n      have : x.1 = a := h1 hxA h3 (by simpa [h4] using hfxb)\n      exact hxa this\n    exact ⟨hfxB, by\n      intro hb\n      have : f x.1 = b := by simpa using congrArg f (by simpa using hb)\n      exact hfxb this⟩\n  · refine fun y => ?_\n    have hyB : y.1 ∈ B := y.2.1\n    have hyne : y.1 ≠ b := by\n      intro hyb\n      exact y.2.2 (by simpa [hyb])\n    have : y.1 ∈ image f A := by simpa [h2] using hyB\n    rcases this with ⟨u, huA, rfl⟩\n    have hune : u ≠ a := by\n      intro hua\n      apply hyne\n      simpa [hua, h4]\n    refine ⟨⟨u, ⟨huA, by\n      intro ha\n      exact hune (by simpa using ha)⟩⟩, ?_⟩\n    apply Subtype.ext\n    rfl\n  · intro x1 x2 h\n    apply Subtype.ext\n    have hx1A : x1.1 ∈ A := x1.2.1\n    have hx2A : x2.1 ∈ A := x2.2.1\n    exact h1 hx1A hx2A (by\n      have := congrArg Subtype.val h\n      simpa using this)",
