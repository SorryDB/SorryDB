      "\n  have h1' : one_one_on f (A \\ {a}) := by\n    intro x hx y hy hxy\n    exact h1 x (And.left hx) y (And.left hy) hxy\n  have him : image f (A \\ {a}) = (B \\ {b}) := by\n    apply subset_antisymm\n    · intro y hy\n      rcases hy with ⟨x, hx, rfl⟩\n      have hxA : x ∈ A := And.left hx\n      have hxa : x ≠ a := by\n        intro h\n        exact (And.right hx) (by simpa [h])\n      have hfb : f x ≠ b := by\n        intro h\n        have : x = a := h1 x hxA a h3 (by simpa [h4] using h)\n        exact hxa this\n      refine ⟨?_, ?_⟩\n      · have : f x ∈ image f A := ⟨x, hxA, rfl⟩\n        simpa [h2] using this\n      · intro hb\n        exact hfb (by simpa [mem_singleton_iff] using hb)\n    · intro y hy\n      have hyB : y ∈ B := And.left hy\n      have hyb : y ∉ {b} := And.right hy\n      have hyimA : y ∈ image f A := by simpa [h2] using hyB\n      rcases hyimA with ⟨x, hxA, rfl⟩\n      have hxa : x ≠ a := by\n        intro h\n        have : f a ∈ {b} := by simpa [h4, mem_singleton_iff]\n        exact hyb (by simpa [h] using this)\n      refine ⟨x, ⟨hxA, ?_⟩, rfl⟩\n      intro hmem\n      exact hxa (by simpa [mem_singleton_iff] using hmem)\n  exact ⟨fun x => ⟨f x.1, by\n      have : f x.1 ∈ image f (A \\ {a}) := ⟨x.1, x.2, rfl⟩\n      have : f x.1 ∈ (B \\ {b}) := by simpa [him] using this\n      exact this⟩,\n    ⟨h1', him⟩⟩",
