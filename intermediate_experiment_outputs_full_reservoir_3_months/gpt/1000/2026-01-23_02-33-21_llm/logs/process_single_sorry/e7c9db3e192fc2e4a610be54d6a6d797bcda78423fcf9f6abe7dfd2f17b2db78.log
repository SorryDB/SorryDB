lemma remove_one_equinum
    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) :=
by
  have hfa : f a ∈ B := by
    rw [← h2]
    exact ⟨a, h3, rfl⟩
  refine ⟨fun x => ⟨f x.1, ?_, rfl⟩, ?_⟩
  · have hxA : x.1 ∈ A := x.2.1
    have hne : x.1 ≠ a := by
      intro hx
      exact x.2.2 (by simpa [hx])
    have hfxne : f x.1 ≠ b := by
      intro hfb
      have : x.1 = a := h1 hxA h3 (by simpa [h4] using hfb)
      exact hne this
    refine ⟨?_, ?_⟩
    · rw [← h2]
      exact ⟨x.1, hxA, rfl⟩
    · intro hbmem
      exact hfxne (by simpa [Set.mem_singleton_iff] using hbmem)
  · refine ⟨fun y => ⟨y.1, ?_, ?_⟩, ?_, ?_⟩
    · have : y.1 ∈ B := y.2.1
      rcases (by
        have : y.1 ∈ image f A := by simpa [h2] using this
        exact this) with ⟨u, huA, rfl⟩
      exact huA
    · intro hamem
      have : y.1 = b := by simpa [Set.mem_singleton_iff] using hamem
      exact y.2.2 (by simpa [this] using hfa)
    · intro x
      apply Subtype.ext
      rfl
    · intro y
      apply Subtype.ext
      rfl
