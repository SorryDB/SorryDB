      "\n  refine ⟨fun x => ⟨f x.1, ?_⟩, ?_, ?_⟩\n  · have hxA : x.1 ∈ A := x.2.1\n    have hxne : x.1 ≠ a := by\n      intro hxa\n      exact x.2.2 (by simpa [hxa])\n    have hfxB : f x.1 ∈ B := by\n      have : f x.1 ∈ image f A := ⟨x.1, hxA, rfl⟩\n      simpa [h2] using this\n    have hfxne : f x.1 ≠ b := by\n      intro hfb\n      have : x.1 = a := h1 hxA h3 (by simpa [h4] using hfb)\n      exact hxne this\n    refine ⟨hfxB, ?_⟩\n    intro hmem\n    exact hfxne (by simpa using hmem)\n  · refine one_to_one.mk ?_\n    intro x y hxy\n    apply Subtype.ext\n    have hxA : x.1 ∈ A := x.2.1\n    have hyA : y.1 ∈ A := y.2.1\n    exact h1 hxA hyA (by simpa using congrArg Subtype.val hxy)\n  · refine onto.mk ?_\n    intro y\n    have hyB : y.1 ∈ B := y.2.1\n    have hyne : y.1 ≠ b := by\n      intro hyb\n      exact y.2.2 (by simpa [hyb])\n    have : y.1 ∈ image f A := by simpa [h2] using hyB\n    rcases this with ⟨x, hxA, rfl⟩\n    have hxne : x ≠ a := by\n      intro hxa\n      apply hyne\n      simpa [hxa, h4]\n    refine ⟨⟨x, ⟨hxA, ?_⟩⟩, ?_⟩\n    · intro hxmem\n      exact hxne (by simpa using hxmem)\n    · apply Subtype.ext\n      rfl",
