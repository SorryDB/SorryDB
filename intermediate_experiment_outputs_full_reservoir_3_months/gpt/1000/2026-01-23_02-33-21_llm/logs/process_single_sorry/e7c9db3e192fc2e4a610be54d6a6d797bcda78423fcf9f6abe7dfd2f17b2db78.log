    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) :=
by
  refine ⟨fun x => ⟨f x.1, ?_⟩, ?_, ?_, ?_⟩
  · have hxA : x.1 ∈ A := x.2.1
    have hxa : x.1 ≠ a := by
      intro h
      exact x.2.2 (by simpa [h])
    have : f x.1 ∈ B := by
      have : f x.1 ∈ image f A := ⟨x.1, hxA, rfl⟩
      simpa [h2] using this
    refine ⟨this, ?_⟩
    intro hb
    have : f x.1 = b := by simpa [Set.mem_singleton_iff] using hb
    have : x.1 = a := h1 hxA h3 this (by simpa [h4])
    exact hxa this
  · intro x y hxy
    apply Subtype.ext
    have hxA : x.1 ∈ A := x.2.1
    have hyA : y.1 ∈ A := y.2.1
    exact h1 hxA hyA (by simpa using congrArg Subtype.val hxy)
  · intro y
    rcases y with ⟨v, hv⟩
    have hvB : v ∈ B := hv.1
    have hnv : v ≠ b := by
      intro h
      exact hv.2 (by simpa [Set.mem_singleton_iff, h])
    have : v ∈ image f A := by simpa [h2] using hvB
    rcases this with ⟨u, huA, rfl⟩
    have huna : u ≠ a := by
      intro hu
      apply hnv
      simpa [hu, h4]
    refine ⟨⟨u, ⟨huA, ?_⟩⟩, ?_⟩
    · intro hu'
      exact huna (by simpa [Set.mem_singleton_iff] using hu')
    · apply Subtype.ext
      rfl
  · intro x
    apply Subtype.ext
    rfl
