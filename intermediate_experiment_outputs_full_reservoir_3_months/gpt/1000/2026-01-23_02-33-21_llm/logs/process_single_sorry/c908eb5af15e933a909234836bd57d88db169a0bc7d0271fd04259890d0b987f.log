      "\n  simpa [one_div, div_eq_mul_inv, add_comm, add_left_comm, add_assoc, sub_eq_add_neg] using\n    (intervalIntegral.integral_add\n        (f := fun x : ℝ => (x : ℝ)⁻¹)\n        (g := fun x : ℝ => (x : ℝ)⁻²)\n        (a := a) (b := b)).trans <|\n      by\n        simp [intervalIntegral.integral_inv, intervalIntegral.integral_inv_sq, this, ha.ne', hb.ne',\n          one_div, div_eq_mul_inv, pow_two, mul_assoc, mul_left_comm, mul_comm, sub_eq_add_neg,\n          add_comm, add_left_comm, add_assoc]",
      "\n  have ha0 : a ≠ 0 := ne_of_gt ha\n  have hb0 : b ≠ 0 := ne_of_gt hb\n  have hderiv :\n      (∀ x ∈ Set.uIcc a b,\n        HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x) := by\n    intro x hx\n    have hx0 : x ≠ 0 := by\n      have hxpos : 0 < x := lt_of_lt_of_le ha hx.1\n      exact ne_of_gt hxpos\n    have hlog : HasDerivAt (fun x : ℝ => log x) (1 / x) x := by\n      simpa [one_div] using Real.hasDerivAt_log (by exact hx0)\n    have hneg : HasDerivAt (fun x : ℝ => - (1 / x)) (1 / x ^ 2) x := by\n      simpa [one_div, pow_two] using (hasDerivAt_inv (x := x)).neg\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, pow_two] using hlog.add hneg\n  have hcont : IntervalIntegrable (fun x : ℝ => 1 / x + 1 / x ^ 2) volume a b := by\n    refine (intervalIntegrable_iff_integrableOn_uIcc_of_le (le_total a b).resolve_left ?_).1 ?_\n    · exact (le_total a b).resolve_left\n    ·\n      have : IntegrableOn (fun x : ℝ => 1 / x + 1 / x ^ 2) (Set.uIcc a b) volume := by\n        have hcont' :\n            ContinuousOn (fun x : ℝ => 1 / x + 1 / x ^ 2) (Set.uIcc a b) := by\n          have h0 : (0 : ℝ) ∉ Set.uIcc a b := this\n          have hne : ∀ x ∈ Set.uIcc a b, x ≠ 0 := by\n            intro x hx; exact fun hx0 => h0 (hx0 ▸ hx)\n          have h1 : ContinuousOn (fun x : ℝ => 1 / x) (Set.uIcc a b) := by\n            intro x hx\n            have : x ≠ 0 := hne x hx\n            simpa [one_div] using (continuousAt_const.div continuousAt_id this).continuousWithinAt\n          have h2 : ContinuousOn (fun x : ℝ => 1 / x ^ 2) (Set.uIcc a b) := by\n            intro x hx\n            have : x ^ 2 ≠ 0 := by\n              have : x ≠ 0 := hne x hx\n              simpa [pow_two] using pow_ne_zero 2 this\n            simpa [one_div] using (continuousAt_const.div (continuousAt_id.pow 2) this).continuousWithinAt\n          exact h1.add h2\n        exact (hcont'.integrableOn_compact (isCompact_uIcc))\n      simpa [intervalIntegrable, IntervalIntegrable] using this\n  have hFTC :\n      ∫ x in a..b, (1 / x + 1 / x ^ 2) =\n        (log b - 1 / b) - (log a - 1 / a) := by\n    have hderiv' :\n        ∀ x ∈ Set.uIcc a b,\n          HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x := hderiv\n    simpa using\n      intervalIntegral.integral_eq_sub_of_hasDerivAt_of_le\n        (a := a) (b := b) (f := fun x : ℝ => 1 / x + 1 / x ^ 2)\n        (F := fun x : ℝ => log x - 1 / x) (by\n          intro x hx; exact (hderiv' x hx).hasDerivWithinAt) (by\n          exact (le_total a b).resolve_left) hcont\n  have : (log b - 1 / b) - (log a - 1 / a) = log b + 1 / a - log a - 1 / b := by\n    ring\n  simpa [hFTC, this]",
      "\n  simpa [one_div, pow_two, add_comm, add_left_comm, add_assoc, sub_eq_add_neg, div_eq_mul_inv] using\n    (intervalIntegral.integral_add\n      (f := fun x : ℝ => (x : ℝ)⁻¹)\n      (g := fun x : ℝ => (x : ℝ)⁻²)\n      (a := a) (b := b)).trans\n      (by\n        simp [intervalIntegral.integral_inv, intervalIntegral.integral_inv_sq, ha.ne', hb.ne',\n          this, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, pow_two])",
      "\n  simpa [one_div, div_eq_mul_inv, add_comm, add_left_comm, add_assoc, sub_eq_add_neg, pow_two]\n    using (intervalIntegral.integral_add\n      (f := fun x : ℝ => (x : ℝ)⁻¹) (g := fun x : ℝ => (x : ℝ)⁻²) (a := a) (b := b)) ▸\n    by\n      have h1 : IntervalIntegrable (fun x : ℝ => (x : ℝ)⁻¹) volume a b := by\n        simpa using (intervalIntegrable_inv (a := a) (b := b) this)\n      have h2 : IntervalIntegrable (fun x : ℝ => (x : ℝ)⁻²) volume a b := by\n        simpa [pow_two] using (intervalIntegrable_inv_sq (a := a) (b := b) this)\n      have I1 :\n          ∫ x in a..b, (x : ℝ)⁻¹ = log b - log a := by\n        simpa using (intervalIntegral.integral_inv (a := a) (b := b) this)\n      have I2 :\n          ∫ x in a..b, (x : ℝ)⁻² = (a : ℝ)⁻¹ - (b : ℝ)⁻¹ := by\n        simpa using (intervalIntegral.integral_inv_sq (a := a) (b := b) this)\n      simpa [I1, I2, sub_eq_add_neg, add_assoc, add_left_comm, add_comm]",
      "\n  simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, div_eq_mul_inv, pow_two] using\n    (integral_inv_add_inv_sq ha hb this)",
      "\n  have hab : a ≠ b := by\n    rintro rfl\n    simpa using ha.ne'\n  have h0a : a ≠ 0 := ne_of_gt ha\n  have h0b : b ≠ 0 := ne_of_gt hb\n  have h0 : ∀ x ∈ [[a, b]], x ≠ 0 := by\n    intro x hx\n    exact fun hx0 => this (by simpa [hx0] using hx)\n  have hderiv1 : ∀ x ∈ [[a, b]], HasDerivAt Real.log (1 / x) x := by\n    intro x hx\n    simpa [one_div] using (Real.hasDerivAt_log (h0 x hx))\n  have hderiv2 : ∀ x ∈ [[a, b]], HasDerivAt (fun x : ℝ => - (1 / x)) (1 / x ^ 2) x := by\n    intro x hx\n    have hx0 : x ≠ 0 := h0 x hx\n    have : HasDerivAt (fun x : ℝ => 1 / x) (-(1 / x ^ 2)) x := by\n      simpa [one_div] using (hasDerivAt_inv hx0)\n    simpa [neg_add, add_comm, add_left_comm, add_assoc] using this.neg\n  have hderiv :\n      ∀ x ∈ [[a, b]],\n        HasDerivAt (fun x : ℝ => Real.log x - 1 / x) (1 / x + 1 / x ^ 2) x := by\n    intro x hx\n    have h1 := (hderiv1 x hx).sub (by\n      simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using hderiv2 x hx)\n    simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using h1\n  have hcont :\n      IntervalIntegrable (fun x : ℝ => 1 / x + 1 / x ^ 2) volume a b := by\n    refine (intervalIntegrable_iff_integrableOn_uIcc_of_le ?_).2 ?_\n    · exact le_of_lt (lt_of_le_of_ne (le_of_lt ha) (by simpa using h0a))\n    · have : ContinuousOn (fun x : ℝ => 1 / x + 1 / x ^ 2) [[a, b]] := by\n        have h1 : ContinuousOn (fun x : ℝ => 1 / x) [[a, b]] :=\n          (continuousOn_const.div (continuousOn_id) (by\n            intro x hx\n            simpa using h0 x hx))\n        have h2 : ContinuousOn (fun x : ℝ => 1 / x ^ 2) [[a, b]] :=\n          (continuousOn_const.div (continuousOn_id.pow _) (by\n            intro x hx\n            have hx0 : x ≠ 0 := h0 x hx\n            simpa [pow_two] using (pow_ne_zero 2 hx0)))\n        simpa [one_div, add_comm, add_left_comm, add_assoc] using h1.add h2\n      exact this.integrableOn_compact\n  have hFTC :\n      ∫ x in a..b, 1 / x + 1 / x ^ 2 =\n        (Real.log b - 1 / b) - (Real.log a - 1 / a) := by\n    have := intervalIntegral.integral_eq_sub_of_hasDerivAt_of_le hab.le hderiv hcont\n    simpa using this\n  calc\n    ∫ x in a..b, 1 / x + 1 / x ^ 2\n        = (Real.log b - 1 / b) - (Real.log a - 1 / a) := hFTC\n    _ = log b + 1 / a - log a - 1 / b := by ring",
      "\n  simpa [one_div, pow_two, add_comm, add_left_comm, add_assoc, sub_eq_add_neg, add_mul,\n    mul_add, div_eq_mul_inv] using\n    (integral_add\n      (f := fun x : ℝ => (1 : ℝ) / x)\n      (g := fun x : ℝ => (1 : ℝ) / x ^ 2)\n      (a := a) (b := b))",
      "\n  have ha0 : a ≠ 0 := ne_of_gt ha\n  have hb0 : b ≠ 0 := ne_of_gt hb\n  have hcont : ContinuousOn (fun x : ℝ => log x - 1 / x) (uIcc a b) := by\n    refine (continuous_log.continuousOn.mono ?_).sub ?_\n    · intro x hx\n      exact ne_of_gt (lt_of_lt_of_le ha (uIcc_subset_uIcc (le_rfl) (le_rfl) hx).1)\n    ·\n      have : ContinuousOn (fun x : ℝ => (1 : ℝ) / x) (uIcc a b) :=\n        (continuous_const.div continuous_id).continuousOn.mono (by\n          intro x hx\n          exact (this hx))\n      simpa [one_div] using this.neg\n  have hderiv :\n      ∀ x ∈ uIcc a b, HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x := by\n    intro x hx\n    have hx0 : x ≠ 0 := by\n      exact (mem_uIcc.mp hx).1.ne' (lt_of_lt_of_le ha (le_of_min_le_left (mem_uIcc.mp hx)))\n    have hlog : HasDerivAt (fun x : ℝ => log x) (1 / x) x := by\n      have hxpos : 0 < x := lt_of_lt_of_le ha (le_of_min_le_left (mem_uIcc.mp hx))\n      simpa [one_div] using (Real.hasDerivAt_log hxpos.ne')\n    have h1 : HasDerivAt (fun x : ℝ => (1 : ℝ) / x) (-(1 / x ^ 2)) x := by\n      simpa [one_div, pow_two] using (hasDerivAt_inv x)\n    have hneg : HasDerivAt (fun x : ℝ => -((1 : ℝ) / x)) (1 / x ^ 2) x := by\n      simpa using h1.neg\n    have : HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x := by\n      simpa [sub_eq_add_neg, add_assoc, add_comm, add_left_comm] using hlog.add hneg\n    exact this\n  have hint :\n      ∫ x in a..b, 1 / x + 1 / x ^ 2 =\n        (log b - 1 / b) - (log a - 1 / a) := by\n    simpa using\n      (intervalIntegral.integral_eq_sub_of_hasDerivAt_of_le (fun x : ℝ => log x - 1 / x)\n        (fun x : ℝ => (1 / x + 1 / x ^ 2)) (by\n          intro x hx\n          exact (hderiv x hx).intervalIntegrable\n        ) (by\n          intro x hx\n          exact hderiv x hx\n        ) (le_of_lt (lt_of_lt_of_le ha (le_of_lt hb))))\n  calc\n    ∫ x in a..b, 1 / x + 1 / x ^ 2\n        = (log b - 1 / b) - (log a - 1 / a) := hint\n    _ = log b + 1 / a - log a - 1 / b := by ring",
      "\n  have ha0 : a ≠ 0 := ne_of_gt ha\n  have hb0 : b ≠ 0 := ne_of_gt hb\n  have hcont : ContinuousOn (fun x : ℝ => 1 / x + 1 / x ^ 2) (uIcc a b) := by\n    have h1 : ContinuousOn (fun x : ℝ => 1 / x) (uIcc a b) := by\n      simpa [one_div] using (continuousOn_const.div continuousOn_id this)\n    have h2 : ContinuousOn (fun x : ℝ => 1 / x ^ 2) (uIcc a b) := by\n      have hx2 : ContinuousOn (fun x : ℝ => x ^ 2) (uIcc a b) :=\n        (continuous_id.pow 2).continuousOn\n      have hne : ∀ x ∈ uIcc a b, (x ^ 2 : ℝ) ≠ 0 := by\n        intro x hx\n        have hx0 : x ≠ 0 := by\n          exact fun h => this (by simpa [h] using hx)\n        exact pow_ne_zero 2 hx0\n      simpa [one_div] using (continuousOn_const.div hx2 hne)\n    simpa [ContinuousOn] using h1.add h2\n  have hder :\n      ∀ x ∈ uIcc a b,\n        HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x := by\n    intro x hx\n    have hx0 : x ≠ 0 := by\n      exact fun h => this (by simpa [h] using hx)\n    have hxpos : 0 < x := by\n      have : x ∈ Icc a b ∨ x ∈ Icc b a := by\n        simpa [uIcc] using hx\n      rcases this with hx' | hx'\n      · exact lt_of_lt_of_le ha hx'.1\n      · exact lt_of_lt_of_le hb hx'.1\n    have hlog : HasDerivAt (fun x : ℝ => log x) (1 / x) x := by\n      simpa [one_div] using Real.hasDerivAt_log hxpos\n    have hneg : HasDerivAt (fun x : ℝ => -(1 / x)) (1 / x ^ 2) x := by\n      have hdiv : HasDerivAt (fun x : ℝ => 1 / x) (-(1 / x ^ 2)) x := by\n        simpa [one_div] using (hasDerivAt_const_div x (1 : ℝ))\n      simpa using hdiv.neg\n    have : HasDerivAt (fun x : ℝ => log x + (-(1 / x))) (1 / x + 1 / x ^ 2) x :=\n      hlog.add hneg\n    simpa [sub_eq_add_neg] using this\n  have hint :\n      ∫ x in a..b, (1 / x + 1 / x ^ 2) =\n        (log b - 1 / b) - (log a - 1 / a) := by\n    have hder' :\n        ∀ x ∈ [[a, b]],\n          HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x := by\n      intro x hx\n      exact hder x (by simpa [uIcc] using hx)\n    have hcont' :\n        ContinuousOn (fun x : ℝ => 1 / x + 1 / x ^ 2) [[a, b]] := by\n      simpa [uIcc] using hcont\n    simpa using intervalIntegral.integral_eq_sub_of_hasDerivAt_of_continuousOn hder' hcont'\n  have : (log b - 1 / b) - (log a - 1 / a) = log b + 1 / a - log a - 1 / b := by\n    ring\n  simpa [this] using hint",
      "\n  have ha0 : a ≠ 0 := ne_of_gt ha\n  have hb0 : b ≠ 0 := ne_of_gt hb\n  have hderiv :\n      ∀ x ∈ uIcc a b,\n        HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x := by\n    intro x hx\n    have hx0 : x ≠ 0 := by\n      have hx' : 0 ∈ uIcc a b → False := by\n        intro h0\n        exact this h0\n      exact fun h => hx' (by simpa [h] using hx)\n    have hlog : HasDerivAt (fun x : ℝ => log x) (1 / x) x := by\n      simpa [one_div] using Real.hasDerivAt_log (by exact hx0)\n    have hinv : HasDerivAt (fun x : ℝ => - (1 / x)) (1 / x ^ 2) x := by\n      have : HasDerivAt (fun x : ℝ => 1 / x) (- (1 / x ^ 2)) x := by\n        simpa [one_div, pow_two, hx0] using (hasDerivAt_inv x)\n      simpa [neg_mul, mul_neg, neg_neg, one_div] using this.neg\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hlog.add hinv\n  have hFTC :=\n    intervalIntegral.integral_eq_sub_of_hasDerivAt_of_le (a := a) (b := b)\n      (f := fun x : ℝ => log x - 1 / x) (f' := fun x : ℝ => 1 / x + 1 / x ^ 2)\n      (by\n        intro x hx\n        exact (hderiv x hx).intervalIntegrable (by\n          simpa using (hderiv x hx).continuousAt))\n      (by\n        intro x hx\n        exact hderiv x hx) (le_total a b).1\n  have hFTC' :\n      ∫ x in a..b, 1 / x + 1 / x ^ 2 =\n        (log b - 1 / b) - (log a - 1 / a) := by\n    simpa [sub_eq_add_neg] using hFTC\n  calc\n    ∫ x in a..b, 1 / x + 1 / x ^ 2\n        = (log b - 1 / b) - (log a - 1 / a) := hFTC'\n    _ = log b + 1 / a - log a - 1 / b := by ring",
      "\n  have hcont : ContinuousOn (fun x : ℝ => log x - 1 / x) [[a, b]] := by\n    have h0 : (0 : ℝ) ∉ [[a, b]] := this\n    exact (continuousOn_log.sub (continuousOn_const.div continuousOn_id)).sub\n      (continuousOn_const.div (continuousOn_pow 2))\n  have hderiv :\n      (∀ x ∈ [[a, b]],\n        HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x) := by\n    intro x hx\n    have hx0 : x ≠ 0 := by\n      have : (0 : ℝ) ∉ [[a, b]] := this\n      exact fun h => this (by simpa [h] using hx)\n    simpa [one_div, hx0, pow_two, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using\n      ( (Real.hasDerivAt_log hx0).sub ((hasDerivAt_const_div _).trans (by\n          simp [hx0, pow_two, one_div])) )\n  have hint :=\n    intervalIntegral.integral_eq_sub_of_hasDerivAt_of_continuousOn\n      (f := fun x : ℝ => log x - 1 / x)\n      (f' := fun x : ℝ => 1 / x + 1 / x ^ 2)\n      (a := a) (b := b) hderiv hcont\n  simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, one_div] using hint",
