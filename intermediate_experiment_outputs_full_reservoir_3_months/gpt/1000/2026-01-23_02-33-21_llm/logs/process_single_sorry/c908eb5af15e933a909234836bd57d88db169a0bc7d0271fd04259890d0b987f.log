      "\n  have ha0 : a ≠ 0 := ne_of_gt ha\n  have hb0 : b ≠ 0 := ne_of_gt hb\n  have hcont : ContinuousOn (fun x : ℝ => 1 / x + 1 / x ^ 2) (uIcc a b) := by\n    have h1 : ContinuousOn (fun x : ℝ => 1 / x) (uIcc a b) := by\n      refine (continuousOn_const.div ?_ ?_).congr ?_\n      · exact continuousOn_id\n      · intro x hx\n        have : x ≠ 0 := by\n          intro hx0\n          exact this (by simpa [hx0] using hx)\n        simpa [one_div, this]\n      · intro x hx; rfl\n    have h2 : ContinuousOn (fun x : ℝ => 1 / x ^ 2) (uIcc a b) := by\n      have : ContinuousOn (fun x : ℝ => x ^ 2) (uIcc a b) := by\n        exact (continuous_id.pow 2).continuousOn\n      refine (continuousOn_const.div this ?_).congr ?_\n      · intro x hx\n        have hx0 : x ≠ 0 := by\n          intro hx0\n          exact this_1 (by simpa [hx0] using hx)\n        have : x ^ 2 ≠ 0 := by simpa [pow_two] using mul_ne_zero hx0 hx0\n        simpa [one_div, this]\n      · intro x hx; rfl\n    exact h1.add h2\n  have hder :\n      ∀ x ∈ uIcc a b,\n        HasDerivAt (fun x : ℝ => log x - 1 / x) (1 / x + 1 / x ^ 2) x := by\n    intro x hx\n    have hx0 : x ≠ 0 := by\n      intro hx0\n      exact this (by simpa [hx0] using hx)\n    have hxpos : 0 < x := by\n      have hx' : x ∈ Set.Icc (min a b) (max a b) := by\n        simpa [uIcc] using hx\n      have hmin : 0 < min a b := lt_min ha hb\n      exact lt_of_lt_of_le hmin hx'.1\n    have hlog : HasDerivAt (fun x : ℝ => log x) (1 / x) x := by\n      simpa [one_div] using Real.hasDerivAt_log hxpos\n    have hneg : HasDerivAt (fun x : ℝ => - (1 / x)) (1 / x ^ 2) x := by\n      have hinv : HasDerivAt (fun x : ℝ => (1 / x)) (-(1 / x ^ 2)) x := by\n        simpa [one_div] using (hasDerivAt_inv hx0)\n      simpa using hinv.neg\n    have : HasDerivAt (fun x : ℝ => log x + (-(1 / x))) (1 / x + 1 / x ^ 2) x := by\n      simpa using hlog.add hneg\n    simpa [sub_eq_add_neg] using this\n  have hFTC :=\n    intervalIntegral.integral_eq_sub_of_hasDerivAt_of_cont