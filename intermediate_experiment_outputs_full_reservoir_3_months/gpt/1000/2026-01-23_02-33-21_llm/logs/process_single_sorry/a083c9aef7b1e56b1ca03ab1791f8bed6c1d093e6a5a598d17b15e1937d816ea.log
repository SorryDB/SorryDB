      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem]\n  | node v left right ihL ihR =>\n      simp [fastCheckMem, LabelledTree.mem] at *\n      rcases h with ⟨hl, hr, hOl, hOr, hv⟩\n      by_cases hEq : v = label\n      · subst hEq\n        simp [fastCheckMem, LabelledTree.mem, hv]\n      · have hne : ¬(v == label) := by simpa [beq_iff_eq] using hEq\n        simp [fastCheckMem, hne, beq_iff_eq] at *\n        by_cases hlt : label < v\n        · have hnotinR : ¬ LabelledTree.mem right label := by\n            intro hm\n            have : v ≤ label := hr label hm\n            exact not_lt_of_ge this hlt\n          have : fastCheckMem label left = true ↔ LabelledTree.mem left label := ihL hOl\n          simpa [hlt, hnotinR, this]\n        · have hge : v ≤ label := by\n            have : ¬ label < v := hlt\n            exact le_of_not_gt this\n          have hnotinL : ¬ LabelledTree.mem left label := by\n            intro hm\n            have : label ≤ v := hl label hm\n            exact not_lt_of_ge this (lt_of_le_of_ne hge (Ne.symm hEq))\n          have : fastCheckMem label right = true ↔ LabelledTree.mem right label := ihR hOr\n          have hlt' : ¬ label < v := hlt\n          simpa [hlt', hnotinL, this]",
      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem]\n  | node v left right ihL ihR =>\n      by_cases hEq : v = label\n      · subst hEq\n        have hv : v ∈ LabelledTree.node v left right := by\n          have : v ∈ left ∨ v ∈ right := (by simpa [IsOrdered] using h).2.2.2.2.2\n          simpa [LabelledTree.mem]\n        constructor\n        · intro _\n          exact hv\n        · intro _\n          simpa [fastCheckMem, BEq.beq, decide_eq_true_eq] using (show (v == v) = true from by simp)\n      · have hbeq : (v == label) = false := by\n          simp [BEq.beq, decide_eq_false_iff, hEq]\n        have hleft_le : ∀ x, x ∈ left → x ≤ v := (by simpa [IsOrdered] using h).1\n        have hright_ge : ∀ x, x ∈ right → v ≤ x := (by simpa [IsOrdered] using h).2.1\n        have hOrdL : IsOrdered left := (by simpa [IsOrdered] using h).2.2.2.1\n        have hOrdR : IsOrdered right := (by simpa [IsOrdered] using h).2.2.2.2.1\n        by_cases hlt : label < v\n        · have hnmemR : label ∈ right ↔ False := by\n            constructor\n            · intro hr\n              have : v ≤ label := hright_ge label hr\n              exact (not_le_of_gt hlt) this\n            · intro hf; cases hf\n          simp [fastCheckMem, hbeq, hlt, LabelledTree.mem, ihL _ hOrdL, hnmemR]\n        · have hge : v ≤ label := le_of_not_gt hlt\n          have hnmemL : label ∈ left ↔ False := by\n            constructor\n            · intro hl\n              have : label ≤ v := hleft_le label hl\n              exact (not_lt_of_ge hge) (lt_of_le_of_ne this (Ne.symm hEq))\n            · intro hf; cases hf\n          have hif : (if label < v then fastCheckMem label left else fastCheckMem label right)\n              = fastCheckMem label right := by\n                simp [hlt]\n          simp [fastCheckMem, hbeq, hlt, LabelledTree.mem, ihR _ hOrdR, hnmemL, hif]",
      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem]\n  | node v left right ihL ihR =>\n      have hLmem : ∀ x, x ∈ left → x ≤ v := h.1\n      have hRmem : ∀ x, x ∈ right → v ≤ x := h.2.1\n      have hLord : IsOrdered left := h.2.2.1\n      have hRord : IsOrdered right := h.2.2.2.1\n      by_cases hv : v = label\n      · subst hv\n        simp [fastCheckMem]\n      · have hv' : ¬ v == label := by simpa [beq_iff_eq, hv]\n        by_cases hlt : label < v\n        · have hnmemR : ¬ label ∈ right := by\n            intro hr\n            have : v ≤ label := hRmem label hr\n            exact (not_lt_of_ge this) hlt\n          have : fastCheckMem label (node v left right) = fastCheckMem label left := by\n            simp [fastCheckMem, hv', hlt]\n          simp [LabelledTree.mem, this, ihL label hLord, hnmemR]\n        · have hge : v ≤ label := le_of_not_gt hlt\n          have hnmemL : ¬ label ∈ left := by\n            intro hl\n            have : label ≤ v := hLmem label hl\n            exact (not_lt_of_ge this) (lt_of_lt_of_le (lt_of_le_of_ne hge (Ne.symm hv)) (le_rfl))\n          have : fastCheckMem label (node v left right) = fastCheckMem label right := by\n            simp [fastCheckMem, hv', hlt]\n          simp [LabelledTree.mem, this, ihR label hRord, hnmemL]",
      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem, LabelledTree.mem]\n  | node v left right ihL ihR =>\n      have hv : v ∈ left ∨ v ∈ right := by\n        simpa [IsOrdered] using h\n      have hL : IsOrdered left := by\n        simpa [IsOrdered] using h\n      have hR : IsOrdered right := by\n        simpa [IsOrdered] using h\n      have hleft : ∀ x, x ∈ left → x ≤ v := by\n        simpa [IsOrdered] using h\n      have hright : ∀ x, x ∈ right → v ≤ x := by\n        simpa [IsOrdered] using h\n      by_cases heq : v = label\n      · have : label ∈ left ∨ label ∈ right := by\n          simpa [heq] using hv\n        simp [fastCheckMem, LabelledTree.mem, heq, this]\n      · have hne' : ¬(v == label) = true := by\n          simpa [beq_iff_eq, heq] using (show ¬ v = label from by simpa [eq_comm] using heq)\n        have hbeq : (v == label) = false := by\n          simpa [Bool.eq_false_iff] using (by\n            intro ht\n            have : v = label := by simpa [beq_iff_eq] using ht\n            exact heq this)\n        have hlt_or_gt : label < v ∨ v < label := lt_or_gt_of_ne (Ne.symm heq)\n        cases hlt_or_gt with\n        | inl hlt =>\n            have hnright : ¬ label ∈ right := by\n              intro hrmem\n              have : v ≤ label := hright label hrmem\n              exact (not_le_of_gt hlt) this\n            have : label ∈ left ↔ label ∈ left ∨ label ∈ right := by\n              constructor\n              · intro hlmem; exact Or.inl hlmem\n              · intro hm; cases hm with\n                | inl hlmem => exact hlmem\n                | inr hrmem => exact False.elim (hnright hrmem)\n            simp [fastCheckMem, LabelledTree.mem, hbeq, hlt, ihL hL, this]\n        | inr hgt =>\n            have hnleft : ¬ label ∈ left := by\n              intro hlmem\n              have : label ≤ v := hleft label hlmem\n              exact (not_le_of_gt hgt) this\n            have : label ∈ right ↔ label ∈ left ∨ label ∈ right := by\n              constructor\n              · intro hrmem; exact Or.inr hrmem\n              · intro hm; cases hm with\n                | inl hlmem => exact False.elim (hnleft hlmem)\n                | inr hrmem => exact hrmem\n            have hnotlt : ¬ label < v := by exact not_lt_of_gt hgt\n            simp [fastCheckMem, LabelledTree.mem, hbeq, hnotlt, ihR hR, this]",
      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem]\n  | node v left right ihL ihR =>\n      rcases h with ⟨hlv, hvr, hleft, hright, hv⟩\n      by_cases hvEq : v = label\n      · subst hvEq\n        have : fastCheckMem α inst✝ v (node v left right) = true := by\n          simp [fastCheckMem]\n        have : v ∈ (node v left right) := by\n          simpa using hv\n        simpa [this] using (Iff.intro (fun _ => this) (fun _ => by simp [fastCheckMem]))\n      · have hvNe : ¬v = label := hvEq\n        have hvNe' : ¬v == label := by\n          simpa [BEq.beq, instBEq] using hvNe\n        by_cases hlt : label < v\n        · have hnotinR : ¬ label ∈ right := by\n            intro hmemR\n            have : v ≤ label := hvr label hmemR\n            exact (not_le_of_gt hlt) this\n          constructor\n          · intro hf\n            have hf' : fastCheckMem α inst✝ label left = true := by\n              simp [fastCheckMem, hvNe, hlt] at hf\n              exact hf\n            have : label ∈ left := (ihL hleft).1 hf'\n            exact Or.inl this\n          · intro hm\n            have : label ∈ left := by\n              cases hm with\n              | inl hL => exact hL\n              | inr hR => exact False.elim (hnotinR hR)\n            have hf' : fastCheckMem α inst✝ label left = true := (ihL hleft).2 this\n            simp [fastCheckMem, hvNe, hlt, hf']\n        · have hge : v < label := lt_of_le_of_ne (le_of_not_gt hlt) (Ne.symm hvNe)\n          have hnotinL : ¬ label ∈ left := by\n            intro hmemL\n            have : label ≤ v := hlv label hmemL\n            exact (not_le_of_gt hge) this\n          constructor\n          · intro hf\n            have hf' : fastCheckMem α inst✝ label right = true := by\n              simp [fastCheckMem, hvNe, hlt] at hf\n              exact hf\n            have : label ∈ right := (ihR hright).1 hf'\n            exact Or.inr this\n          · intro hm\n            have : label ∈ right := by\n              cases 