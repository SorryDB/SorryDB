      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem]\n  | node v left right ihL ihR =>\n      have hvL : ∀ x, x ∈ left → x ≤ v := h.1\n      have hvR : ∀ x, x ∈ right → v ≤ x := h.2.1\n      have hOL : IsOrdered left := h.2.2.1\n      have hOR : IsOrdered right := h.2.2.2.1\n      by_cases hEq : v = label\n      · subst hEq\n        simp [fastCheckMem, ihL, ihR]\n      · have hne : ¬ v == label := by\n          simpa [BEq.beq, hEq] using congrArg (fun t => t) rfl\n        have hne' : (v == label) = false := by\n          simp [BEq.beq, hEq]\n        by_cases hlt : label < v\n        · constructor\n          · intro hf\n            simp [fastCheckMem, hne', hlt, ihL, hOL] at hf\n            have : label ∈ left := hf\n            exact Or.inl this\n          · intro hm\n            have : label ∈ left := by\n              cases hm with\n              | inl hl => exact hl\n              | inr hr =>\n                  have : v ≤ label := hvR label hr\n                  exact False.elim (not_le_of_gt hlt this)\n            simp [fastCheckMem, hne', hlt, ihL, hOL, this]\n        · have hge : v < label := lt_of_le_of_ne (le_of_not_gt hlt) (Ne.symm hEq)\n          constructor\n          · intro hf\n            simp [fastCheckMem, hne', hlt, ihR, hOR] at hf\n            have : label ∈ right := hf\n            exact Or.inr this\n          · intro hm\n            have : label ∈ right := by\n              cases hm with\n              | inr hr => exact hr\n              | inl hl =>\n                  have : label ≤ v := hvL label hl\n                  exact False.elim (not_le_of_gt hge this)\n            simp [fastCheckMem, hne', hlt, ihR, hOR, this]",
      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem, LabelledTree.mem]\n  | node v left right ihl ihr =>\n      simp [fastCheckMem, LabelledTree.mem] at *\n      have hv : (∀ x, x ∈ left → x ≤ v) := h.1\n      have hr : (∀ x, x ∈ right → v ≤ x) := h.2.1\n      have hol : IsOrdered left := h.2.2.1\n      have hor : IsOrdered right := h.2.2.2.1\n      by_cases hEq : v = label\n      · subst hEq\n        simp [fastCheckMem]\n      · have hNe' : ¬v == label := by\n          simpa [beq_iff_eq] using hEq\n        simp [fastCheckMem, hNe']\n        by_cases hlt : label < v\n        · have hnotmemr : ¬ label ∈ right := by\n            intro hm\n            have : v ≤ label := hr label hm\n            exact (not_le_of_gt hlt) this\n          have : (label ∈ left ∨ label ∈ right) ↔ label ∈ left := by\n            constructor\n            · intro hm; exact hm.elim (fun hl => hl) (fun hrm => False.elim (hnotmemr hrm))\n            · intro hm; exact Or.inl hm\n          simp [hlt, ihl _ hol, this]\n        · have hge : v ≤ label := le_of_not_gt hlt\n          have hnotmeml : ¬ label ∈ left := by\n            intro hm\n            have : label ≤ v := hv label hm\n            exact (not_lt_of_ge (le_trans hge this)) (lt_irrefl label)\n          have : (label ∈ left ∨ label ∈ right) ↔ label ∈ right := by\n            constructor\n            · intro hm; exact hm.elim (fun hlm => False.elim (hnotmeml hlm)) (fun hrm => hrm)\n            · intro hm; exact Or.inr hm\n          have hif : (if label < v then fastCheckMem label left else fastCheckMem label right) =\n              fastCheckMem label right := by\n            simp [hlt]\n          simp [hlt, ihr _ hor, this]",
      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem, LabelledTree.mem]\n  | node v left right ihL ihR =>\n      have hL : IsOrdered left := by\n        simpa [IsOrdered] using h.2.2.1\n      have hR : IsOrdered right := by\n        simpa [IsOrdered] using h.2.2.2.1\n      by_cases hv : v = label\n      · subst hv\n        simp [fastCheckMem, LabelledTree.mem]\n      · have : (v == label) = false := by\n          simp [BEq.beq, hv]\n        by_cases hlt : label < v\n        · simp [fastCheckMem, LabelledTree.mem, this, hlt, ihL, hL]\n        · have hge : v ≤ label := le_of_not_gt hlt\n          have hnlt : (label < v) = false := by simp [lt_of_le_of_ne hge (Ne.symm hv)]\n          simp [fastCheckMem, LabelledTree.mem, this, hnlt, ihR, hR]",
      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem]\n  | node v left right ihL ihR =>\n      simp [fastCheckMem] at *\n      by_cases hv : v = label\n      · subst hv\n        have : label ∈ left ∨ label ∈ right := by\n          simpa [IsOrdered] using h.2.2.2.2\n        simp [this]\n      · have hv' : (v == label) = false := by\n          simp [beq_iff_eq, hv]\n        have hleft : IsOrdered left := by\n          simpa [IsOrdered] using h.2.2.2.1\n        have hright : IsOrdered right := by\n          simpa [IsOrdered] using h.2.2.2.2.1\n        have hle : ∀ x ∈ left, x ≤ v := by\n          simpa [IsOrdered] using h.1\n        have hge : ∀ x ∈ right, v ≤ x := by\n          simpa [IsOrdered] using h.2.1\n        by_cases hlt : label < v\n        · have : label ∈ right ↔ False := by\n            constructor\n            · intro hr\n              have : v ≤ label := hge label hr\n              exact (not_le_of_gt hlt) this\n            · intro hf; cases hf\n          simp [hv', hlt, ihL label hleft, this]\n        · have hge' : v ≤ label := le_of_not_gt hlt\n          have : label ∈ left ↔ False := by\n            constructor\n            · intro hl\n              have : label ≤ v := hle label hl\n              exact (not_lt_of_ge hge') (lt_of_le_of_ne this (Ne.symm hv))\n            · intro hf; cases hf\n          have hlt' : (label < v) = false := by\n            exact propext ⟨fun h => (hlt h).elim, fun _ => False.elim⟩\n          simp [hv', hlt', ihR label hright, this]",
      "\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem]\n  | node v left right ihL ihR =>\n      have h₁ : ∀ x, x ∈ left → x ≤ v := h.1\n      have h₂ : ∀ x, x ∈ right → v ≤ x := h.2.1\n      have hL : IsOrdered left := h.2.2.1\n      have hR : IsOrdered right := h.2.2.2.1\n      have hv : v ∈ left ∨ v ∈ right := h.2.2.2.2\n      by_cases hvlabel : v = label\n      · subst hvlabel\n        have : (label ∈ left ∨ label ∈ right) := hv\n        have : label ∈ node v left right := by simpa [LabelledTree.mem] using this\n        constructor\n        · intro _\n          exact this\n        · intro _\n          simp [fastCheckMem]\n      · have hvne : ¬ v = label := hvlabel\n        have hvb : (v == label) = false := by\n          simp [beq_iff_eq, hvne]\n        by_cases hlt : label < v\n        · have hnotinR : label ∈ right → False := by\n            intro hr\n            have : v ≤ label := h₂ label hr\n            exact (not_le_of_gt hlt) this\n          constructor\n          · intro hf\n            have hf' : fastCheckMem label left = true := by\n              simpa [fastCheckMem, hvb, hlt] using hf\n            have hmL : label ∈ left := (ihL hL).1 hf'\n            exact Or.inl hmL\n          · intro hm\n            have hmL : label ∈ left := by\n              cases hm with\n              | inl hmL => exact hmL\n              | inr hmR => exact False.elim (hnotinR hmR)\n            have hf' : fastCheckMem label left = true := (ihL hL).2 hmL\n            simpa [fastCheckMem, hvb, hlt] using hf'\n        · have hge : v ≤ label := le_of_not_gt hlt\n          have hnotinL : label ∈ left → False := by\n            intro hl\n            have : label ≤ v := h₁ label hl\n            exact (not_le_of_gt (lt_of_le_of_ne hge (Ne.symm hvne))) this\n          constructor\n          · intro hf\n            have hf' : fastCheckMem label right = true := by\n              simpa [fastCheckMem, hvb, hlt] using hf\n            have hmR : label ∈ right := (ihR hR).1 hf'\