      "\n  classical\n  induction l with\n  | leaf x =>\n      simp [fastCheckMem]\n  | node v left right ihL ihR =>\n      dsimp [IsOrdered] at h\n      rcases h with ⟨hleft, hright, hOL, hOR, hv⟩\n      by_cases hveq : v = label\n      · subst hveq\n        simp [fastCheckMem, LabelledTree.mem, BEq.beq, hv]\n      · have hvne : ¬ v = label := hveq\n        have hbeq : (v == label) = false := by\n          simp [BEq.beq, hvne]\n        have hmem_ne : label ∈ node v left right ↔ label ∈ left ∨ label ∈ right := by\n          simp [LabelledTree.mem]\n        by_cases hlt : label < v\n        · have hnotRight : ¬ label ∈ right := by\n            intro hr\n            have : v ≤ label := hright label hr\n            exact not_lt_of_ge this hlt\n          have : (fastCheckMem label (node v left right) = true ↔ label ∈ left) := by\n            simp [fastCheckMem, hbeq, hlt, ihL, hOL]\n          constructor\n          · intro hf\n            have hl : label ∈ left := (this.mp hf)\n            exact (by simpa [LabelledTree.mem, hl, hnotRight] using (Or.inl hl : label ∈ left ∨ label ∈ right))\n          · intro hm\n            have : label ∈ left := by\n              simpa [LabelledTree.mem] using hm\n            exact this.mpr this\n        · have hge : v ≤ label := le_of_not_gt hlt\n          have hnotLeft : ¬ label ∈ left := by\n            intro hl\n            have : label ≤ v := hleft label hl\n            have : label = v := le_antisymm this hge\n            exact hvne this.symm\n          have : (fastCheckMem label (node v left right) = true ↔ label ∈ right) := by\n            have : ¬ label < v := hlt\n            simp [fastCheckMem, hbeq, this, ihR, hOR]\n          constructor\n          · intro hf\n            have hr : label ∈ right := (this.mp hf)\n            exact (by simpa [LabelledTree.mem, hnotLeft, hr] using (Or.inr hr : label ∈ left ∨ label ∈ right))\n          · intro hm\n            have : label ∈ right := by\n              have : label ∈ left ∨ label ∈