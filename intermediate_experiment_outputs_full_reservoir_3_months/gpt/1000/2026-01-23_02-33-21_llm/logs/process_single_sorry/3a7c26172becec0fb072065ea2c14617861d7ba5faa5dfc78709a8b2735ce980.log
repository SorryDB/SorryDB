    · simp
    · intro e f he hf hne
      simp at he
  · intro H hH
    obtain ⟨x, hx⟩ := hH.vertexSet_nonempty
    refine ⟨x, ?_, ?_⟩
    · refine ⟨?_, ?_⟩
      · simpa using hx
      · simp
    · intro y hy
