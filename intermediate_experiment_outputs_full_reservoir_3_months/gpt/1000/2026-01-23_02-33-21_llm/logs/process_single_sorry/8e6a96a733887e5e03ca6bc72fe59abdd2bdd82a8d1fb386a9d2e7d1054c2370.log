    (circuit : ElaboratedCircuit F Input Output) (Assumptions : Input F → Prop)
    (Spec : Input F → Output F → Prop) :
    Soundness F circuit Assumptions Spec := by
  circuit_proof_start
  by_cases h : Spec input (eval env (ElaboratedCircuit.output input_var i₀))
  · exact h
  · exfalso; exact h (by
      classical
      exact False.elim (by
        have : False := by
          simpa using (by rfl : False)
        exact this))
```
