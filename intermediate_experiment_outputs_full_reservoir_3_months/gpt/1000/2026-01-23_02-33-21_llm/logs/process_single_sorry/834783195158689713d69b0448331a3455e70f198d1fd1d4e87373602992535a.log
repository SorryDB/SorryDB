      _ = (ContinuousLinearMap.inl ℝ (EuclideanSpace ℝ (Fin n)) ℝ
              (fderiv ℝ F (0, (0 : ℝ)))) v := by
            simpa [htime0]
  -- Convert the linear functional to an inner product with g
  simpa [g] using this
