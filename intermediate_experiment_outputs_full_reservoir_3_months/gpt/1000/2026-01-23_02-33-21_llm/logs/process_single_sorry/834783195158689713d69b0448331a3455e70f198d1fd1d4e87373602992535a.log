@[sorryful]
lemma isTotalTimeDerivativeVelocity {n : ℕ}
    (δL : EuclideanSpace ℝ (Fin n) → ℝ)
    (hδL0 : δL 0 = 0)
    (h : IsTotalTimeDerivative (fun _ v _ => δL v)) :
    ∃ g : EuclideanSpace ℝ (Fin n), ∀ v, δL v = ⟪g, v⟫_ℝ := by
  rcases h with ⟨F, hFdiff, hEq⟩
  have hconst_rt : ∀ (r₁ r₂ : EuclideanSpace ℝ (Fin n)) (t₁ t₂ : ℝ),
      fderiv ℝ F (r₁, t₁) = fderiv ℝ F (r₂, t₂) := by
    intro r₁ r₂ t₁ t₂
    ext w
    have hw : fderiv ℝ F (r₁, t₁) w = δL w.1 := by
      simpa using (hEq r₁ w.1 t₁)
    have hw' : fderiv ℝ F (r₂, t₂) w = δL w.1 := by
      simpa using (hEq r₂ w.1 t₂)
    simpa [hw, hw']
  let g : EuclideanSpace ℝ (Fin n) :=
    (fderiv ℝ F (0 : EuclideanSpace ℝ (Fin n), (0 : ℝ))) (1, 0)
  refine ⟨g, ?_⟩
  intro v
  have hv : δL v = fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 1) := by
    simpa using (hEq (0 : EuclideanSpace ℝ (Fin n)) v (0 : ℝ)).symm
  have h0 : δL 0 = fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (0, 1) := by
    simpa using (hEq (0 : EuclideanSpace ℝ (Fin n)) (0 : EuclideanSpace ℝ (Fin n)) (0 : ℝ))
  have ht : fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (0, 1) = 0 := by
    simpa [hδL0] using h0.symm
  have hv' :
      fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 1) =
        fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 0) +
          fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (0, 1) := by
    simpa [add_comm, add_left_comm, add_assoc] using
      (map_add (fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ))) (v, 0) (0, 1))
  have hv0 :
      fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 1) =
        fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 0) := by
    simpa [hv', ht] using congrArg (fun z => z) rfl
  have hlin :
      fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 0) =
        inner ℝ g v := by
    have : (v, (0 : ℝ)) = v • (1, (0 : ℝ)) := by
      ext <;> simp
    calc
      fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 0)
          = fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v • (1, (0 : ℝ))) := by
              simpa [this]
      _ = v • fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (1, (0 : ℝ)) := by
            simpa using (map_smulₛₗ (fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ))) v (1, (0 : ℝ)))
      _ = inner ℝ g v := by
            -- `g` was defined as the image of `(1,0)`; identify scalar multiplication with inner on Euclidean space
            -- Use `inner_smul_left` + `inner_one_left` via Riesz representation for Euclidean spaces.
            simpa [g, inner_smul_left] 
  calc
    δL v = fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 1) := hv
    _ = fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 0) := by
          -- rewrite using the time-component vanishing
          have hv1 :
              fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) (v, 1) =
                fderiv ℝ F ((0 : EuclideanSpace ℝ (Fin n)), (0 : ℝ)) ((v, 0) + (0, 1)) := by
                  simp
          -- use linearity and `ht`
          simpa [hv1, map_add, ht]
    _ = inner ℝ g v := hlin
