    have : (v, (1 : ℝ)) = (v, (0 : ℝ)) + ((0 : EuclideanSpace ℝ (Fin n)), (1 : ℝ)) := by
      ext <;> simp
    -- δL v = fderiv ... (v,0) + fderiv ... (0,1) = fderiv ... (v,0)
    calc
      δL v = fderiv ℝ F (0, (0 : ℝ)) (v, 1) := hv
      _ = fderiv ℝ F (0, (0 : ℝ)) ((v, (0 : ℝ)) + ((0 : EuclideanSpace ℝ (Fin n)), (1 : ℝ))) := by
