          (ContinuousLinearMap.inr ℝ (EuclideanSpace ℝ (Fin n)) ℝ
            (fderiv ℝ F (0, (0 : ℝ)))) (1 : ℝ) := by
    simpa using (ContinuousLinearMap.prod_apply (fderiv ℝ F (0, (0 : ℝ))) v (1 : ℝ))
  have :
      δL v =
        (ContinuousLinearMap.inl ℝ (EuclideanSpace ℝ (Fin n)) ℝ
            (fderiv ℝ F (0, (0 : ℝ)))) v := by
    calc
      δL v = fderiv ℝ F (0, (0 : ℝ)) (v, (1 : ℝ)) := hEq0
      _ = (ContinuousLinearMap.inl ℝ (EuclideanSpace ℝ (Fin n)) ℝ
              (fderiv ℝ F (0, (0 : ℝ)))) v +
            (ContinuousLinearMap.inr ℝ (EuclideanSpace ℝ (Fin n)) ℝ
