      have hdecomp : (v, (1 : ℝ)) = (v, (0 : ℝ)) + (0, (1 : ℝ)) := by
        ext <;> simp
      have hdecomp' : (v, (0 : ℝ)) + (0, (1 : ℝ)) = (v, (1 : ℝ)) := by
        simpa [hdecomp]
      have hmap := (fderiv ℝ F (r, t)).map_add (v, (0 : ℝ)) (0, (1 : ℝ))
      have : (fderiv ℝ F (r, t)) (v, (1 : ℝ))
            = (fderiv ℝ F (r, t)) (v, (0 : ℝ)) + (fderiv ℝ F (r, t)) (0, (1 : ℝ)) := by
        simpa [hdecomp] using hmap.symm
      simpa [h20] using this
    simpa [h10] using h1
  have hDerivRIndep : ∀ r₁ r₂ v t, fderiv ℝ F (r₁, t) (v, (0 : ℝ))
