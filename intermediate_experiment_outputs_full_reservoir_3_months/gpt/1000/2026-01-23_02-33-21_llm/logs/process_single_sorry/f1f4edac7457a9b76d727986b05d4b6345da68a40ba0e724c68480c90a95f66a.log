-- 7.
-- Don't use ctble_iff_set_nat_equinum to prove this lemma
lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  rcases h1 with ⟨f, g, hfg, hgf⟩
  rcases h2 with ⟨e, he⟩
  refine ⟨fun v => e (g v), ?_⟩
  intro v1 v2 hv
  have : g v1 = g v2 := he hv
  calc
    v1 = f (g v1) := (hfg v1).symm
    _  = f (g v2) := by simpa [this]
    _  = v2 := hfg v2
