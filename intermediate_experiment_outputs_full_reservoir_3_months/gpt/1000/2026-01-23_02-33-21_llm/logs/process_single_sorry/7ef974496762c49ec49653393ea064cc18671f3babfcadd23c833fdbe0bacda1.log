      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  obtain ⟨t, ht, hxt⟩ := hl x\n  have hAP : IsLinftyAP (ε / 3) t f := by\n    simpa using (show t ∈ {t | IsLinftyAP (ε / 3) t f} from hxt)\n  have hAPy : ‖f (y + t) - f y‖ ≤ ε / 3 := hAP y\n  have hAPx : ‖f (x + t) - f x‖ ≤ ε / 3 := hAP x\n  have hyt : y + t ∈ Set.Ioo (x + t - l) (x + t + l) := by\n    have hlt : (t : ℝ) < l := ht.2.2\n    have ht0 : 0 ≤ t := ht.2.1\n    have hyx : |y - x| < l := by simpa [Real.dist_eq, abs_sub_comm] using hxy\n    have hyxl : y - x < l := lt_of_le_of_lt (le_abs_self _) hyx\n    have hneg : -(l : ℝ) < y - x := lt_of_lt_of_le (neg_lt_abs_self _) (le_of_lt hyx)\n    constructor\n    · have : x - y < t := by\n        have : x - y < l := by\n          have : -(l : ℝ) < y - x := hneg\n          simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using (neg_lt_neg_iff.1 this)\n        exact lt_of_lt_of_le this ht0\n      have : x + t - l < y + t := by linarith\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n    · have : y + t < x + t + l := by linarith\n      simpa [add_assoc, add_left_comm, add_comm] using this\n  have hmid : dist (y + t) (x + t) < l := by\n    have : dist y x < l := by simpa [Real.dist_eq, abs_sub_comm] using hxy\n    simpa [dist_eq_norm, Real.norm_eq_abs, abs_sub_comm, sub_eq_add_neg, add_assoc, add_left_comm,\n      add_comm] using this\n  have : ‖f y - f x‖ ≤ ε := by\n    calc\n      ‖f y - f x‖\n          ≤ ‖f y - f (y + t)‖ + ‖f (y + t) - f (x + t)‖ + ‖f (x + t) - f x‖ := by\n            simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using\n              norm_sub_le_three (f y) (f (y + t)) (f (x + t)) (f x)\n      _ ≤ ε / 3 + ‖f (y + t) - f (x + t)‖ + ε / 3 := by\n            gcongr\n            · simpa [norm_sub_rev] using hAPy\n            · exact hAPx\n      _ ≤ ε / 3 + (ε / 3) + ε / 3 := by\n            gcongr\n            have : ‖f ((x + t) + (y - x)) - f (x + t)‖ ≤ ε / 3 := by\n              simpa [add_assoc, add_left_comm, add_comm, sub_eq_add_neg] using hAP (x + t)\n            simpa [add_assoc, add_left_comm, add_comm, sub_eq_add_neg] using this\n      _ = ε := by ring\n  exact this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  rcases hl x with ⟨t, htI, ht⟩\n  have ht' : IsLinftyAP (ε / 3) t f := by simpa [Set.mem_setOf_eq] using ht\n  have hx : ‖f (x + t) - f x‖ ≤ ε / 3 := ht' x\n  have hy : ‖f (y + t) - f y‖ ≤ ε / 3 := ht' y\n  have hmid : ‖f (y + t) - f (x + t)‖ ≤ ε / 3 := by\n    have : ‖f ((x + t) + (y - x)) - f (x + t)‖ ≤ ε / 3 := by\n      simpa [add_assoc, add_comm, add_left_comm, add_sub_cancel] using ht' (x + t)\n    simpa [add_assoc, add_comm, add_left_comm, sub_eq_add_neg] using this\n  have : ‖f x - f y‖ ≤ ε := by\n    have h1 : ‖f x - f (x + t)‖ ≤ ε / 3 := by simpa [norm_sub_rev] using hx\n    have h2 : ‖f (x + t) - f (y + t)‖ ≤ ε / 3 := by simpa [norm_sub_rev] using hmid\n    have h3 : ‖f (y + t) - f y‖ ≤ ε / 3 := hy\n    have := calc\n      ‖f x - f y‖\n          = ‖(f x - f (x + t)) + (f (x + t) - f (y + t)) + (f (y + t) - f y)‖ := by abel\n      _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (y + t)‖ + ‖f (y + t) - f y‖ := by\n            simpa [add_assoc] using (norm_add_le _ _).trans (add_le_add_left (norm_add_le _ _) _)\n      _ ≤ ε / 3 + ε / 3 + ε / 3 := by gcongr\n      _ = ε := by ring\n    exact this\n  exact lt_of_le_of_lt this (by\n    have : ε / 3 + ε / 3 + ε / 3 = ε := by ring\n    simpa [this] using lt_add_of_pos_right _ (by positivity))",
      "by\n  classical\n  rw [Metric.uniformContinuous_iff]\n  intro ε hε\n  rcases hf (ε := ε / 2) (by positivity) with ⟨l, hl⟩\n  refine ⟨l, hl.pos, ?_⟩\n  intro x y hxy\n  rcases hl x with ⟨t, ht, hxt⟩\n  have htAP : IsLinftyAP (ε / 2) t f := hxt\n  have htAP' : IsLinftyAP (ε / 2) (-t) f := by\n    intro z\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using htAP (z - t)\n  have hx : ‖f (x + t) - f x‖ ≤ ε / 2 := htAP x\n  have hy : ‖f y - f (y + t)‖ ≤ ε / 2 := by\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using htAP' (y + t)\n  have hmid : ‖f (x + t) - f (y + t)‖ ≤ ε / 2 := by\n    have : dist (x + t) (y + t) < l := by simpa [Real.dist_eq, abs_sub_comm, sub_add_sub_cancel] using hxy\n    rcases hl (x + t) with ⟨s, hs, hxs⟩\n    rcases hl (y + t) with ⟨u, hu, hyu⟩\n    -- use almost periodicity at shift (s - u) with triangle inequality\n    have hsAP : IsLinftyAP (ε / 2) s f := hxs\n    have huAP : IsLinftyAP (ε / 2) u f := hyu\n    have hsuAP : IsLinftyAP ε (s - u) f := by\n      intro z\n      have hs' : ‖f (z + (s - u)) - f (z - u)‖ ≤ ε / 2 := by\n        simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hsAP (z - u)\n      have hu' : ‖f (z - u) - f z‖ ≤ ε / 2 := by\n        simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using huAP (z - u)\n      have := (norm_sub_le _ _ _).trans (add_le_add hs' hu')\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, add_halves] using this\n    have : ‖f ((x + t) + (s - u)) - f (x + t)‖ ≤ ε := hsuAP (x + t)\n    have : ‖f ((y + t) + (s - u)) - f (y + t)‖ ≤ ε := hsuAP (y + t)\n    exact le_trans (by simpa using (norm_nonneg _)) (by linarith)\n  have : ‖f x - f y‖ ≤ ε := by\n    have := (norm_sub_le _ _ _).trans (add_le_add (le_trans (by simpa [sub_eq_add_neg] using hx) (le_of_lt (by linarith))\n      ) (le_trans (le_trans (by simpa [sub_eq_add_neg] using hmid) (le_of_lt (by linarith))) (le_of_lt (by linarith))))\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n  simpa [dist_eq_norm] using this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 2) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hy : y - x < l := by\n    have : dist y x < l := by simpa [Real.dist_eq] using hxy\n    simpa [Real.dist_eq, abs_sub_comm] using this\n  rcases hl x with ⟨t, ht, hxt⟩\n  have hty : t < y - x := by\n    have ht0 : 0 ≤ t := ht.1\n    have htl : t < l := ht.2\n    exact lt_of_lt_of_le htl (le_of_lt hy)\n  have hx : ‖f (x + t) - f x‖ ≤ ε / 2 := (hxt : IsLinftyAP (ε / 2) t f) x\n  have hy' : ‖f (y + (t - (y - x))) - f y‖ ≤ ε / 2 := by\n    have : IsLinftyAP (ε / 2) (t - (y - x)) f := by\n      intro z\n      simpa [add_assoc, add_left_comm, add_comm, sub_eq_add_neg, add_left_cancel_iff] using\n        (hxt : IsLinftyAP (ε / 2) t f) (z - (y - x))\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this y\n  have hmid : x + t = y + (t - (y - x)) := by\n    ring\n  have : ‖f x - f y‖ ≤ ε := by\n    have := calc\n      ‖f x - f y‖ = ‖(f x - f (x + t)) + (f (x + t) - f y)‖ := by abel\n      _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f y‖ := norm_add_le _ _\n      _ = ‖f (x + t) - f x‖ + ‖f (y + (t - (y - x))) - f y‖ := by\n            simp [norm_sub_rev, hmid]\n      _ ≤ ε / 2 + ε / 2 := by gcongr\n      _ = ε := by ring\n    exact this\n  simpa [dist_eq_norm] using this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 2) (by linarith) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hx : ∃ t ∈ Set.Ico 0 l, x + t ∈ {t | IsLinftyAP (ε / 2) t f} := hl x\n  have hy : ∃ s ∈ Set.Ico 0 l, y + s ∈ {t | IsLinftyAP (ε / 2) t f} := hl y\n  rcases hx with ⟨t, htI, ht⟩\n  rcases hy with ⟨s, hsI, hs⟩\n  have htAP : IsLinftyAP (ε / 2) (x + t) f := ht\n  have hsAP : IsLinftyAP (ε / 2) (y + s) f := hs\n  have hts : |t - s| < l := by\n    have ht0 : 0 ≤ t := htI.1\n    have htl : t < l := htI.2\n    have hs0 : 0 ≤ s := hsI.1\n    have hsl : s < l := hsI.2\n    have h1 : t - s < l := by linarith\n    have h2 : -(t - s) < l := by linarith\n    simpa [abs_lt] using And.intro h2 h1\n  have hmid : |(x + t) - (y + s)| < 2 * l := by\n    have : |(x - y) + (t - s)| < l + l := by\n      have hxy' : |x - y| < l := by simpa [sub_eq_add_neg, abs_sub_comm] using hxy\n      have : |x - y| + |t - s| < l + l := add_lt_add hxy' hts\n      exact (lt_of_le_of_lt (abs_add _ _) this)\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, two_mul] using this\n  have h1 := htAP (y + s)\n  have h2 := hsAP y\n  have h3 : ‖f (y + s) - f y‖ ≤ ε / 2 := by simpa [add_assoc, add_comm, add_left_comm] using h2\n  have h4 : ‖f (y + s + (x + t)) - f (y + s)‖ ≤ ε / 2 := by\n    simpa [add_assoc, add_comm, add_left_comm] using h1\n  have hsum :\n      ‖f (y + s + (x + t)) - f y‖ ≤ ε := by\n    have := norm_sub_le (f (y + s + (x + t))) (f (y + s)) (f y)\n    have : ‖f (y + s + (x + t)) - f y‖ ≤ ‖f (y + s + (x + t)) - f (y + s)‖ + ‖f (y + s) - f y‖ :=\n      by simpa [sub_eq_add_neg, add_assoc] using this\n    exact (this.trans (by linarith [h4, h3]))\n  have hxshift : ‖f (x + (y + s)) - f x‖ ≤ ε / 2 := by\n    have := hsAP x\n    simpa [add_assoc, add_comm, add_left_comm] using this\n  have hfinal :\n      ‖f y - f x‖ ≤ ε := by\n    have := norm_sub_le (f y) (f (x + (y + s))) (f x)\n    have : ‖f y - f x‖ ≤ ‖f y - f (x + (y + s))‖ + ‖f (x + (y + s)) - f x‖ :=\n      by simpa [sub_eq_add_neg, add_assoc] using this\n    have hyshift : ‖f y - f (x + (y + s))‖ ≤ ε / 2 := by\n      have := hsum\n      simpa [add_assoc, add_comm, add_left_comm, sub_eq_add_neg, norm_sub_rev] using this\n    exact (this.trans (by linarith [hyshift, hxshift]))\n  exact lt_of_le_of_lt hfinal (by linarith)",
      "by\n  classical\n  rw [Metric.uniformContinuous_iff]\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  rcases hl x with ⟨t, htI, hxt⟩\n  have htx : IsLinftyAP (ε / 3) t f := hxt\n  have hty : IsLinftyAP (ε / 3) t f := by\n    have : x - (y - t) ∈ Set.Ico 0 l := by\n      simpa [sub_eq_add_neg, add_assoc, add_comm, add_left_comm] using htI\n    have : y - t + (x - (y - t)) ∈ {t | IsLinftyAP (ε / 3) t f} := by\n      simpa [sub_eq_add_neg, add_assoc, add_comm, add_left_comm] using hxt\n    simpa [sub_eq_add_neg, add_assoc, add_comm, add_left_comm] using this\n  have hx : ‖f (x + t) - f x‖ ≤ ε / 3 := htx x\n  have hy : ‖f (y + t) - f y‖ ≤ ε / 3 := hty y\n  have hmid : ‖f (x + t) - f (y + t)‖ ≤ ε / 3 := by\n    simpa [Real.norm_eq_abs, Complex.abs.abs, sub_eq_add_neg, add_assoc, add_comm, add_left_comm] using\n      (hty (x + t))\n  have : ‖f x - f y‖ ≤ ε := by\n    calc\n      ‖f x - f y‖\n          = ‖(f x - f (x + t)) + (f (x + t) - f (y + t)) + (f (y + t) - f y)‖ := by\n              ring_nf\n      _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (y + t)‖ + ‖f (y + t) - f y‖ := by\n              simpa [add_assoc] using\n                (norm_add_le (f x - f (x + t)) ((f (x + t) - f (y + t)) + (f (y + t) - f y)) |>.trans\n                  (by\n                    gcongr\n                    simpa using norm_add_le (f (x + t) - f (y + t)) (f (y + t) - f y)))\n      _ ≤ ε / 3 + ε / 3 + ε / 3 := by\n              gcongr <;>\n                simpa [norm_sub_rev] using (by\n                  first | exact hx | exact hmid | exact hy)\n      _ = ε := by ring\n  exact this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := IsRelDenseWith.pos (E := {t | IsLinftyAP (ε / 3) t f}) (l := l) hl\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hx : ∃ s ∈ Set.Ico 0 l, x + s ∈ {t | IsLinftyAP (ε / 3) t f} := hl (-x)\n  rcases hx with ⟨s, hs, hAPs⟩\n  have hAPs' : IsLinftyAP (ε / 3) (x + s) f := hAPs\n  have hy : ∃ t ∈ Set.Ico 0 l, y + t ∈ {t | IsLinftyAP (ε / 3) t f} := hl (-y)\n  rcases hy with ⟨t, ht, hAPt⟩\n  have hAPt' : IsLinftyAP (ε / 3) (y + t) f := hAPt\n  have hxst : ‖f (x + (x + s)) - f x‖ ≤ ε / 3 := by\n    simpa [IsLinftyAP] using hAPs' x\n  have hyst : ‖f (y + (y + t)) - f y‖ ≤ ε / 3 := by\n    simpa [IsLinftyAP] using hAPt' y\n  have hmid : ‖f (x + (x + s)) - f (y + (y + t))‖ ≤ ε / 3 := by\n    have hΔ : |(x + (x + s)) - (y + (y + t))| < l := by\n      have hxy' : |x - y| < l := by simpa [Real.dist_eq] using hxy\n      have hst : |s - t| < l := by\n        have hs0 : 0 ≤ s := hs.1\n        have hsl : s < l := hs.2\n        have ht0 : 0 ≤ t := ht.1\n        have htl : t < l := ht.2\n        have h1 : s - t < l := sub_lt_iff_lt_add.2 (by simpa [add_comm] using add_lt_add_of_lt_of_le hsl ht0)\n        have h2 : -(s - t) < l := by\n          have : t - s < l := sub_lt_iff_lt_add.2 (by simpa [add_comm] using add_lt_add_of_lt_of_le htl hs0)\n          simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n        exact abs_lt.2 ⟨h2, h1⟩\n      have hsum : |(x - y) + (s - t)| < l + l := abs_add_lt_iff.2 ⟨hxy', hst⟩\n      have : |(x - y) + (s - t)| < l := by\n        have hlpos' : 0 < l := hlpos\n        have : l + l ≤ l + l := le_rfl\n        exact lt_of_lt_of_le hsum (by simpa [two_mul] using (le_add_of_nonneg_right (le_of_lt hlpos')))\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, add_sub, sub_add] using this\n    have : dist (x + (x + s)) (y + (y + t)) < l := by\n      simpa [Real.dist_eq] using hΔ\n    have : dist (x + (x + s)) (y + (y + t)) < l := this\n    have : ‖f (x + (x + s)) - f (y + (y + t))‖ ≤ ε / 3 := by\n      have : IsLinftyAP (ε / 3) ((x + s) - (y + t)) f := by\n        have h1 : IsLinftyAP (ε / 3) (x + s) f := hAPs'\n        have h2 : IsLinftyAP (ε / 3) (y + t) f := hAPt'\n        intro z\n        have hz1 := h1 (z - (y + t))\n        have hz2 := h2 (z - (y + t))\n        simpa [add_assoc, add_left_comm, add_comm, sub_eq_add_neg, add_sub, sub_add] using hz1\n      have hz := this (y + (y + t))\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hz\n    exact this\n  have htri := norm_sub_le (f (x + (x + s))) (f (y + (y + t))) (f x)\n  have htri2 := norm_sub_le (f (y + (y + t))) (f y) (f x)\n  have : ‖f x - f y‖ ≤ ε := by\n    have := calc\n      ‖f x - f y‖\n          ≤ ‖f x - f (x + (x + s))‖ + ‖f (x + (x + s)) - f y‖ := by\n              simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using norm_sub_le (f x) (f (x + (x + s))) (f y)\n      _ ≤ ‖f (x + (x + s)) - f x‖ + (‖f (x + (x + s)) - f (y + (y + t))‖ + ‖f (y + (y + t)) - f y‖) := by\n              nlinarith [norm_sub_rev (f x) (f (x + (x + s)))]\n      _ ≤ ε / 3 + (ε / 3 + ε / 3) := by\n              gcongr <;> try exact hxst <;> try exact hmid <;> try exact hyst\n      _ = ε := by ring\n    simpa [Real.dist_eq] using this\n  simpa [Real.dist_eq] using this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hy : ∃ t ∈ Set.Ico 0 l, y - t ∈ {t | IsLinftyAP (ε / 3) t f} := by\n    simpa [IsRelDenseWith, Set.mem_setOf_eq, sub_add_cancel] using hl (y - l)\n  rcases hy with ⟨t, htI, ht⟩\n  have htAP : IsLinftyAP (ε / 3) t f := ht\n  have htAP' : IsLinftyAP (ε / 3) (-t) f := by\n    intro z\n    simpa [IsLinftyAP, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using htAP (z - t)\n  have h1 : ‖f x - f (x - t)‖ ≤ ε / 3 := by\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using htAP' x\n  have h2 : ‖f (x - t) - f (y - t)‖ ≤ ε / 3 := by\n    have : dist (x - t) (y - t) < l := by\n      simpa [Real.dist_eq, abs_sub_comm, sub_sub_sub_cancel_left] using hxy\n    simpa [Metric.mem_ball, dist_eq_norm] using (le_of_lt this)\n  have h3 : ‖f (y - t) - f y‖ ≤ ε / 3 := by\n    simpa [IsLinftyAP, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, sub_add_cancel] using\n      htAP (y - t)\n  have : ‖f x - f y‖ ≤ ε := by\n    calc\n      ‖f x - f y‖\n          = ‖(f x - f (x - t)) + (f (x - t) - f (y - t)) + (f (y - t) - f y)‖ := by\n              abel\n      _ ≤ ‖f x - f (x - t)‖ + ‖f (x - t) - f (y - t)‖ + ‖f (y - t) - f y‖ := by\n              nlinarith [norm_add_le (f x - f (x - t)) (f (x - t) - f (y - t)),\n                norm_add_le ((f x - f (x - t)) + (f (x - t) - f (y - t))) (f (y - t) - f y)]\n      _ ≤ ε / 3 + ε / 3 + ε / 3 := by gcongr\n      _ = ε := by ring\n  simpa [Metric.dist_eq] using this",
      "by\n  classical\n  -- It suffices to show that `f` is uniformly continuous at scale `ε` using an `ε/3`-almost period.\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  have hε' : 0 < ε / 3 := by positivity\n  rcases hf (ε := ε / 3) hε' with ⟨l, hl⟩\n  refine ⟨l, hl.pos, ?_⟩\n  intro x y hxy\n  -- Find an almost period `t` close to `y - x`.\n  rcases hl (y - x) with ⟨t, htI, htE⟩\n  have ht : ‖t - (y - x)‖ ≤ l := by\n    have : 0 ≤ t ∧ t < l := htI\n    have ht0 : 0 ≤ t := this.1\n    have htl : t < l := this.2\n    have : ‖t‖ ≤ l := by\n      simpa [Real.norm_eq_abs, abs_of_nonneg ht0] using (le_of_lt htl)\n    simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using this\n  have htx : ‖f (x + t) - f x‖ ≤ ε / 3 := htE x\n  have hty : ‖f y - f (x + t)‖ ≤ ε / 3 := by\n    have : ‖f (x + t + (y - (x + t))) - f (x + t)‖ ≤ ε / 3 := htE (x + t)\n    simpa [add_assoc, add_sub_cancel] using this\n  have hclose : ‖(x + t) - y‖ ≤ l := by\n    have : ‖(x + t) - y‖ = ‖t - (y - x)‖ := by\n      ring_nf\n    simpa [this] using ht\n  have : ‖f x - f y‖ ≤ ε := by\n    have := calc\n      ‖f x - f y‖ = ‖(f (x + t) - f x) + (f y - f (x + t))‖ := by ring_nf\n      _ ≤ ‖f (x + t) - f x‖ + ‖f y - f (x + t)‖ := norm_add_le ..\n      _ ≤ ε / 3 + ε / 3 := add_le_add htx hty\n      _ ≤ ε := by\n        nlinarith\n    simpa [norm_sub_rev] using this\n  exact this",
      "by\n  classical\n  by_contra h\n  rw [uniformContinuous_iff] at h\n  push_neg at h\n  rcases h with ⟨ε, hε, h⟩\n  rcases hf hε with ⟨l, hl⟩\n  have hlpos : 0 < l := IsRelDenseWith.pos (E := {t | IsLinftyAP ε t f}) (l := l) hl\n  rcases h (l / 2) (by nlinarith) with ⟨x, y, hxy, hdist⟩\n  have hyx : |y - x| < l := by\n    have : |y - x| ≤ dist x y := by simpa [Real.dist_eq, abs_sub_comm] using (abs_sub_le_dist x y)\n    exact lt_of_le_of_lt this hdist\n  have hx : ∃ s ∈ Set.Ico 0 l, x + s ∈ {t | IsLinftyAP ε t f} := hl x\n  rcases hx with ⟨s, hs, hsx⟩\n  have hsap : IsLinftyAP ε (x + s) f := hsx\n  have hy : ∃ t ∈ Set.Ico 0 l, y + t ∈ {t | IsLinftyAP ε t f} := hl y\n  rcases hy with ⟨t, ht, hty⟩\n  have htap : IsLinftyAP ε (y + t) f := hty\n  have : ‖f (0 + (x + s)) - f 0‖ ≤ ε := hsap 0\n  have : ‖f (0 + (y + t)) - f 0‖ ≤ ε := htap 0\n  have htri : ‖f (x + s) - f (y + t)‖ ≤ ‖f (x + s) - f 0‖ + ‖f (y + t) - f 0‖ := by\n    simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using\n      (norm_sub_le (f (x + s)) (f 0) (f (y + t)))\n  have hle : ‖f (x + s) - f (y + t)‖ ≤ 2 * ε := by\n    have hx0 : ‖f (x + s) - f 0‖ ≤ ε := by simpa [zero_add] using (hsap 0)\n    have hy0 : ‖f (y + t) - f 0‖ ≤ ε := by simpa [zero_add] using (htap 0)\n    have := le_trans htri (add_le_add hx0 hy0)\n    nlinarith\n  have hdist' : dist (x + s) (y + t) < l / 2 := by\n    have hs' : |s - t| < l := by\n      have hslt : s < l := hs.2\n      have htlt : t < l := ht.2\n      have hsge : 0 ≤ s := hs.1\n      have htge : 0 ≤ t := ht.1\n      have : |s - t| ≤ l := by\n        have : s - t ≤ l := by linarith\n        have : -(l) ≤ s - t := by linarith\n        exact abs_le.2 ⟨this, ‹_›⟩\n      exact lt_of_le_of_lt this (by linarith)\n    have : dist (x + s) (y + t) = |(x - y) + (s - t)| := by\n      simp [Real.dist_eq, sub_eq_add_neg, add_assoc, add_left_comm, add_comm, abs_sub_comm]\n    rw [this]\n    have : |(x - y) + (s - t)| ≤ |x - y| + |s - t| := abs_add _ _\n    have hxyl : |x - y| < l / 2 := by\n      have : dist x y = |x - y| := by simpa [Real.dist_eq, abs_sub_comm] using (rfl : dist x y = dist x y)\n      have : |x - y| < l / 2 := by\n        simpa [Real.dist_eq, abs_sub_comm] using hdist\n      exact this\n    have : |(x - y) + (s - t)| < l / 2 + l := lt_of_le_of_lt this (add_lt_add_of_lt_of_le hxyl (le_of_lt hs'))\n    nlinarith\n  have := h (l / 2) (by nlinarith) (x + s) (y + t) hle\n  exact not_lt_of_ge (le_of_eq rfl) this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 2) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := IsRelDenseWith.pos (E := {t | IsLinftyAP (ε / 2) t f}) (l := l) hl\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hx : ∃ t ∈ Set.Ico 0 l, x + t ∈ {t | IsLinftyAP (ε / 2) t f} := hl x\n  rcases hx with ⟨t, htI, htAP⟩\n  have hy : ∃ s ∈ Set.Ico 0 l, y + s ∈ {t | IsLinftyAP (ε / 2) t f} := hl y\n  rcases hy with ⟨s, hsI, hsAP⟩\n  have ht : IsLinftyAP (ε / 2) (x + t) f := htAP\n  have hs : IsLinftyAP (ε / 2) (y + s) f := hsAP\n  have hlt : t < l := htI.2\n  have hls : s < l := hsI.2\n  have hts : |t - s| < l := by\n    have : |t - s| < max t s := by\n      have htmax : t ≤ max t s := le_max_left _ _\n      have hsmax : s ≤ max t s := le_max_right _ _\n      have hmax : max t s < l := max_lt_iff.2 ⟨hlt, hls⟩\n      have : |t - s| ≤ max t s := by\n        have : |t - s| ≤ max t s := by\n          have h1 : |t - s| ≤ |t| + |s| := abs_sub_le_iff.2 ⟨by linarith, by linarith⟩\n          have ht0 : 0 ≤ t := htI.1\n          have hs0 : 0 ≤ s := hsI.1\n          have : |t| = t := abs_of_nonneg ht0\n          have : |s| = s := abs_of_nonneg hs0\n          have : |t - s| ≤ t + s := by\n            simpa [abs_of_nonneg ht0, abs_of_nonneg hs0] using h1\n          have htms : t + s ≤ 2 * max t s := by\n            have htmax : t ≤ max t s := le_max_left _ _\n            have hsmax : s ≤ max t s := le_max_right _ _\n            linarith\n          have : |t - s| ≤ 2 * max t s := this.trans htms\n          have : |t - s| ≤ max t s := by\n            have hmax0 : 0 ≤ max t s := le_trans htI.1 (le_max_left _ _)\n            have : 2 * max t s ≥ max t s := by nlinarith\n            exact le_trans this (le_of_lt (lt_of_lt_of_le (by nlinarith [hmax0]) this))\n          exact this\n        exact this\n      exact lt_of_le_of_lt this (max_lt_iff.2 ⟨hlt, hls⟩)\n    exact lt_of_lt_of_le this (le_of_lt (max_lt_iff.2 ⟨hlt, hls⟩))\n  have : ‖f x - f y‖ ≤ ε := by\n    have h1 : ‖f x - f (x + (x + t))‖ ≤ ε / 2 := by\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using (ht x)\n    have h2 : ‖f y - f (y + (y + s))‖ ≤ ε / 2 := by\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using (hs y)\n    have h3 : ‖f (x + (x + t)) - f (y + (y + s))‖ = ‖f (2 * x + t) - f (2 * y + s)‖ := by\n      simp [two_mul, add_assoc, add_left_comm, add_comm]\n    have : ‖f x - f y‖ ≤ ‖f x - f (x + (x + t))‖ + ‖f (x + (x + t)) - f (y + (y + s))‖ + ‖f (y + (y + s)) - f y‖ := by\n      have := norm_sub_le_three (f x) (f (x + (x + t))) (f (y + (y + s))) (f y)\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n    have hxy' : ‖f (x + (x + t)) - f (y + (y + s))‖ ≤ ε / 2 := by\n      have : IsLinftyAP (ε / 2) ((x + t) - (y + s)) f := by\n        intro z\n        have := ht z\n        have := hs z\n        have : ‖f (z + ((x + t) - (y + s))) - f z‖ ≤ ε / 2 := by\n          simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using (ht (z - (y + s)))\n        exact this\n      have : ‖f (y + (y + s) + ((x + t) - (y + s))) - f (y + (y + s))‖ ≤ ε / 2 := this (y + (y + s))\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, two_mul] using this\n    have h4 : ‖f (y + (y + s)) - f y‖ = ‖f y - f (y + (y + s))‖ := by\n      simpa [norm_sub_rev] using (rfl : ‖f (y + (y + s)) - f y‖ = ‖f (y + (y + s)) - f y‖)\n    have : ‖f x - f y‖ ≤ ε / 2 + ε / 2 := by\n      have := this.trans (by\n        gcongr\n        · exact h1\n        · exact hxy'\n        · simpa [norm_sub_rev] using h2)\n      simpa [add_assoc] using this\n    simpa [add_halves] using this\n  simpa [Complex.dist_eq, dist_eq_norm] using this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 2) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := IsRelDenseWith.pos (E := {t | IsLinftyAP (ε / 2) t f}) (l := l) hl\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hx : ∃ t ∈ Set.Ico 0 l, x + t ∈ {t | IsLinftyAP (ε / 2) t f} := hl x\n  rcases hx with ⟨t, htI, htAP⟩\n  have hxy' : y - x ∈ Set.Ico 0 l := by\n    have : 0 ≤ y - x := sub_nonneg.2 (le_of_lt hxy)\n    have : y - x < l := sub_lt_iff_lt_add.2 hxy\n    exact ⟨this, this_1⟩\n  have hy : ∃ s ∈ Set.Ico 0 l, y + s ∈ {t | IsLinftyAP (ε / 2) t f} := hl y\n  rcases hy with ⟨s, hsI, hsAP⟩\n  have ht : IsLinftyAP (ε / 2) (x + t) f := htAP\n  have hs : IsLinftyAP (ε / 2) (y + s) f := hsAP\n  have ht0 : ‖f (x + (x + t)) - f x‖ ≤ ε / 2 := ht x\n  have hs0 : ‖f (y + (y + s)) - f y‖ ≤ ε / 2 := hs y\n  have hmid :\n      ‖f x - f y‖ ≤ ‖f (x + (x + t)) - f x‖ + ‖f (y + (y + s)) - f y‖ + ‖f (x + (x + t)) - f (y + (y + s))‖ := by\n    calc\n      ‖f x - f y‖ = ‖(f x - f (x + (x + t))) + (f (x + (x + t)) - f (y + (y + s))) + (f (y + (y + s)) - f y)‖ := by\n        ring_nf\n    _ ≤ ‖f x - f (x + (x + t))‖ + ‖f (x + (x + t)) - f (y + (y + s))‖ + ‖f (y + (y + s)) - f y‖ := by\n        simpa [add_assoc] using norm_add₃_le (f x - f (x + (x + t))) (f (x + (x + t)) - f (y + (y + s))) (f (y + (y + s)) - f y)\n    _ = ‖f (x + (x + t)) - f x‖ + ‖f (y + (y + s)) - f y‖ + ‖f (x + (x + t)) - f (y + (y + s))‖ := by\n        simp [norm_sub_rev, add_assoc, add_left_comm, add_comm]\n  have hts : x + (x + t) = y + (y + s) := by\n    have : x + t = y + s := by\n      have ht' : x + t ∈ {t | IsLinftyAP (ε / 2) t f} := htAP\n      have hs' : y + s ∈ {t | IsLinftyAP (ε / 2) t f} := hsAP\n      -- use both belong to the same set, but no further structure; pick equality by rewriting via y - x = s - t from interval bounds\n      -- fallback: choose s = t + (x - y), ensured by relative density? not available\n      -- instead use same almost period not needed: set middle term to 0 by picking same almost period using hl at x and y with same shift\n      -- re-run with s := t + (x - y)\n    sorry\n  have hthird : ‖f (x + (x + t)) - f (y + (y + s))‖ = 0 := by\n    simpa [hts]\n  have : ‖f x - f y‖ ≤ ε := by\n    have := le_trans hmid (by\n      have : ‖f (x + (x + t)) - f x‖ + ‖f (y + (y + s)) - f y‖ + ‖f (x + (x + t)) - f (y + (y + s))‖\n          ≤ ε / 2 + ε / 2 + 0 := by\n            gcongr\n            · exact ht0\n            · exact hs0\n            · simpa [hthird]\n      simpa [add_assoc, add_left_comm, add_comm, add_halves] using this)\n    simpa using this\n  simpa [Complex.dist_eq, dist_eq_norm] using this",
      "by\n  classical\n  rw [Metric.uniformContinuous_iff]\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  rcases hl x with ⟨t, ht, hxt⟩\n  have hclose : ‖f (x + t) - f x‖ ≤ ε / 3 := by simpa [IsLinftyAP] using hxt x\n  have hclose' : ‖f (y + t) - f y‖ ≤ ε / 3 := by simpa [IsLinftyAP] using hxt y\n  have hxt' : x + t = y + t := by linarith\n  have : dist (f x) (f y) ≤ ε := by\n    have :\n        dist (f x) (f y) ≤ dist (f x) (f (x + t)) + dist (f (x + t)) (f (y + t)) + dist (f (y + t)) (f y) :=\n      by\n        calc\n          dist (f x) (f y)\n              ≤ dist (f x) (f (x + t)) + dist (f (x + t)) (f y) := dist_triangle _ _ _\n          _ ≤ dist (f x) (f (x + t)) + (dist (f (x + t)) (f (y + t)) + dist (f (y + t)) (f y)) :=\n              by\n                gcongr\n                exact dist_triangle _ _ _\n          _ = dist (f x) (f (x + t)) + dist (f (x + t)) (f (y + t)) + dist (f (y + t)) (f y) := by ring\n    have hmid : dist (f (x + t)) (f (y + t)) = 0 := by simpa [hxt'] using dist_self (f (x + t))\n    have hx : dist (f x) (f (x + t)) ≤ ε / 3 := by\n      simpa [dist_eq_norm, norm_sub_rev] using hclose\n    have hy : dist (f (y + t)) (f y) ≤ ε / 3 := by\n      simpa [dist_eq_norm] using hclose'\n    have hy' : dist (f (y + t)) (f y) = dist (f y) (f (y + t)) := dist_comm _ _\n    have hy'' : dist (f (y + t)) (f y) ≤ ε / 3 := by simpa [hy'] using hy\n    calc\n      dist (f x) (f y)\n          ≤ dist (f x) (f (x + t)) + dist (f (x + t)) (f (y + t)) + dist (f (y + t)) (f y) := this\n      _ ≤ ε / 3 + 0 + ε / 3 := by gcongr\n      _ = 2 * (ε / 3) := by ring\n      _ ≤ ε := by nlinarith\n  exact lt_of_le_of_lt this (by simpa using hε)",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hx : ∃ t, IsLinftyAP (ε / 3) t f ∧ x ∈ Set.Icc (t - l) t := by\n    rcases hl (x - l) with ⟨u, huI, huE⟩\n    refine ⟨x + u, ?_, ?_⟩\n    · simpa [Set.mem_setOf_eq] using huE\n    · rcases huI with ⟨hu0, hul⟩\n      constructor\n      · have : x ≤ x + u := by linarith\n        simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n      · have : x + u ≤ x + l := by linarith\n        have : x - l ≤ x + u := by linarith\n        have : x + u ≤ x := by linarith\n        simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n  rcases hx with ⟨t, ht, hxt⟩\n  have hyt : y ∈ Set.Icc (t - l) (t + l) := by\n    rcases hxt with ⟨hx₁, hx₂⟩\n    refine ⟨?_, ?_⟩\n    · have : t - l ≤ x := hx₁\n      have : t - l ≤ y := le_trans this (le_of_lt (by linarith))\n      simpa using this\n    · have : x ≤ t := hx₂\n      have : y ≤ t + l := by linarith\n      simpa [add_assoc] using this\n  have hy : ∃ s, IsLinftyAP (ε / 3) s f ∧ y ∈ Set.Icc (s - l) s := by\n    rcases hl (y - l) with ⟨u, huI, huE⟩\n    refine ⟨y + u, ?_, ?_⟩\n    · simpa [Set.mem_setOf_eq] using huE\n    · rcases huI with ⟨hu0, hul⟩\n      constructor\n      · have : y ≤ y + u := by linarith\n        simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n      · have : y + u ≤ y := by linarith\n        simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n  rcases hy with ⟨s, hs, hys⟩\n  have hts : |t - s| ≤ l := by\n    rcases hxt with ⟨hx₁, hx₂⟩\n    rcases hys with ⟨hy₁, hy₂⟩\n    have : t - l ≤ y := by\n      have : t - l ≤ x := hx₁\n      linarith\n    have : y ≤ s := hy₂\n    have : t - l ≤ s := le_trans this this\n    have : s ≤ t + l := by\n      have : y ≤ t + l := by\n        have : x ≤ t := hx₂\n        linarith\n      have : y - l ≤ t := by linarith\n      have : y ≤ s := hy₂\n      linarith\n    have : t - l ≤ s ∧ s ≤ t + l := ⟨this, this⟩\n    have : -l ≤ t - s := by linarith\n    have : t - s ≤ l := by linarith\n    exact abs_le.2 ⟨this, this⟩\n  have htsAP : IsLinftyAP (2 * (ε / 3)) (t - s) f := by\n    intro z\n    have ht' := ht (z - s)\n    have hs' := hs z\n    have : ‖f (z + (t - s)) - f z‖ ≤ ‖f (z + (t - s)) - f (z - s + t)‖ +\n        ‖f (z - s + t) - f (z - s)‖ + ‖f (z - s) - f z‖ := by\n      ring_nf\n      nlinarith [norm_add_le (f (z + (t - s)) - f (z - s + t)) (f (z - s + t) - f (z - s)),\n        norm_add_le (f (z + (t - s)) - f (z - s + t) + (f (z - s + t) - f (z - s)))\n          (f (z - s) - f z)]\n    have : ‖f (z + (t - s)) - f z‖ ≤ ε / 3 + ε / 3 := by\n      have ht'' : ‖f (z - s + t) - f (z - s)‖ ≤ ε / 3 := by simpa [add_assoc, add_comm, add_left_comm] using ht'\n      have hs'' : ‖f (z - s) - f z‖ ≤ ε / 3 := by\n        have := hs (z - s)\n        simpa [sub_eq_add_neg, add_assoc, add_comm, add_left_comm] using this\n      have : ‖f (z + (t - s)) - f (z - s + t)‖ = 0 := by\n        have : z + (t - s) = z - s + t := by ring_nf\n        simp [this]\n      have : ‖f (z + (t - s)) - f z‖ ≤ 0 + (ε / 3) + (ε / 3) := by\n        nlinarith [ht'', hs'']\n      simpa using this\n    simpa [two_mul, add_comm, add_left_comm, add_assoc] using this\n  have hfinal : ‖f x - f y‖ < ε := by\n    have hx' : ‖f (x + (t - x)) - f x‖ ≤ ε / 3 := by\n      simpa [sub_eq_add_neg, add_assoc] using ht x\n    have hy' : ‖f (y + (s - y)) - f y‖ ≤ ε / 3 := by\n      simpa [sub_eq_add_neg, add_assoc] using hs y\n    have hmid : ‖f (x + (t - x)) - f (y + (s - y))‖ ≤ 2 * (ε / 3) := by\n      have := htsAP y\n      simpa [sub_eq_add_neg, add_assoc, add_comm, add_left_comm] using this\n    have : ‖f x - f y‖ ≤ ε / 3 + 2 * (ε / 3) + ε / 3 := by\n      have := norm_sub_le_iff.1 (show ‖f x - f y‖ ≤ ‖f x - f (x + (t - x))‖ +\n          ‖f (x + (t - x)) - f (y + (s - y))‖ + ‖f (y + (s - y)) - f y‖ from by\n          nlinarith [norm_add_le (f x - f (x + (t - x))) (f (x + (t - x)) - f (y + (s - y))),\n            norm_add_le (f x - f (x + (t - x)) + (f (x + (t - x)) - f (y + (s - y))))\n              (f (y + (s - y)) - f y)])\n      have hx'' : ‖f x - f (x + (t - x))‖ = ‖f (x + (t - x)) - f x‖ := by simpa [norm_sub_rev]\n      have hy'' : ‖f (y + (s - y)) - f y‖ ≤ ε / 3 := hy'\n      nlinarith [hx', hmid, hy'', hx'']\n    have : (ε / 3 + 2 * (ε / 3) + ε / 3) = ε := by ring\n    have : ‖f x - f y‖ ≤ ε := by simpa [this] using this\n    exact lt_of_le_of_lt this (lt_of_lt_of_le (by linarith) (le_rfl))\n  simpa [Real.dist_eq, Complex.dist_eq, dist_eq_norm] using hfinal",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := IsRelDenseWith.pos (E := {t | IsLinftyAP (ε / 3) t f}) (l := l) hl\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  rcases hl (-x) with ⟨t, htI, htap⟩\n  have ht0 : 0 ≤ t := htI.1\n  have htl : t < l := htI.2\n  have hxt : x + t ∈ {t | IsLinftyAP (ε / 3) t f} := by\n    simpa [Set.mem_setOf_eq, add_assoc, add_left_comm, add_comm] using htap\n  have hap : IsLinftyAP (ε / 3) (x + t) f := by\n    simpa [Set.mem_setOf_eq] using hxt\n  have hx : ‖f (x + (x + t)) - f x‖ ≤ ε / 3 := hap x\n  have hy : ‖f (y + (x + t)) - f y‖ ≤ ε / 3 := hap y\n  have hmid : ‖f (x + (x + t)) - f (y + (x + t))‖ < ε / 3 := by\n    have : dist (x + (x + t)) (y + (x + t)) < l := by\n      simpa [Real.dist_eq, abs_sub_comm, sub_add_sub_cancel_right] using hxy\n    have : dist (x + (x + t)) (y + (x + t)) < ε / 3 := by\n      have : dist (x + (x + t)) (y + (x + t)) < l := this\n      exact lt_of_lt_of_le this (le_of_lt (by positivity))\n    simpa [dist_eq_norm] using this\n  have htri :\n      ‖f x - f y‖ ≤ ‖f x - f (x + (x + t))‖\n        + ‖f (x + (x + t)) - f (y + (x + t))‖ + ‖f (y + (x + t)) - f y‖ := by\n    have := norm_sub_le_three f x y (x + (x + t))\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n  have hx' : ‖f x - f (x + (x + t))‖ ≤ ε / 3 := by\n    simpa [norm_sub_rev, add_assoc, add_left_comm, add_comm] using hx\n  have hy' : ‖f (y + (x + t)) - f y‖ ≤ ε / 3 := hy\n  have : ‖f x - f y‖ < ε := by\n    have hmid' : ‖f (x + (x + t)) - f (y + (x + t))‖ ≤ ε / 3 := le_of_lt hmid\n    have hsum :\n        ‖f x - f (x + (x + t))‖ + ‖f (x + (x + t)) - f (y + (x + t))‖\n            + ‖f (y + (x + t)) - f y‖ ≤ ε := by\n      nlinarith\n    exact lt_of_le_of_lt (le_trans htri hsum) (by simpa using hε)\n  simpa [dist_eq_norm, sub_eq_add_neg] using this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hEx : ∃ t, t ∈ Set.Ico 0 l ∧ x + t ∈ {t | IsLinftyAP (ε / 3) t f} := hl x\n  rcases hEx with ⟨t, htIco, htAP⟩\n  have htAP' : IsLinftyAP (ε / 3) (x + t) f := htAP\n  have h1 : ‖f (x + (x + t)) - f x‖ ≤ ε / 3 := htAP' x\n  have h2 : ‖f (y + (x + t)) - f y‖ ≤ ε / 3 := htAP' y\n  have h3 : ‖f (x + (x + t)) - f (y + (x + t))‖ ≤ ε / 3 := by\n    simpa [add_assoc, add_left_comm, add_comm, sub_eq_add_neg, add_left_cancel_iff] using\n      (le_of_lt (by\n        have : dist (x + (x + t)) (y + (x + t)) < ε / 3 := by\n          simpa [dist_eq, Real.norm_eq_abs, abs_sub_comm, sub_eq_add_neg, add_assoc, add_left_comm,\n            add_comm] using hxy\n        simpa [dist_eq_norm] using this))\n  have : ‖f x - f y‖ ≤ ε := by\n    have := calc\n          ‖f x - f y‖\n      _ = ‖(f x - f (x + (x + t))) + (f (x + (x + t)) - f (y + (x + t))) +\n            (f (y + (x + t)) - f y)‖ := by abel_nf\n      _ ≤ ‖f x - f (x + (x + t))‖ + ‖f (x + (x + t)) - f (y + (x + t))‖ +\n            ‖f (y + (x + t)) - f y‖ := by\n            simpa [add_assoc] using\n              (norm_add_le (f x - f (x + (x + t))) ((f (x + (x + t)) - f (y + (x + t))) +\n                (f (y + (x + t)) - f y))).trans\n                (by\n                  gcongr\n                  simpa [add_assoc] using\n                    norm_add_le (f (x + (x + t)) - f (y + (x + t))) (f (y + (x + t)) - f y))\n      _ ≤ ε / 3 + ε / 3 + ε / 3 := by\n            gcongr\n            · simpa [norm_sub_rev] using h1\n            · exact h3\n            · exact h2\n      _ = ε := by ring\n    exact this\n  simpa [dist_eq_norm, sub_eq_add_neg] using this",
      "by\n  classical\n  rw [Metric.uniformContinuous_iff]\n  intro ε hε\n  rcases hf (ε := ε / 2) (by positivity) with ⟨l, hl⟩\n  refine ⟨l, ?_⟩\n  intro x y hxy\n  have hlpos : 0 < l := hl.pos\n  have hx : ∃ t, t ∈ Set.Ico 0 l ∧ x - t ∈ {t | IsLinftyAP (ε / 2) t f} := by\n    rcases hl (x - l) with ⟨u, huI, huE⟩\n    refine ⟨l - u, ?_, ?_⟩\n    · have hu0 : 0 ≤ u := huI.1\n      have hul : u < l := huI.2\n      refine ⟨by linarith, ?_⟩\n      have : l - u ≤ l := by linarith\n      exact lt_of_le_of_lt this (lt_of_lt_of_le hlpos.le (le_rfl))\n    · simpa [Set.mem_setOf_eq] using huE\n  rcases hx with ⟨t, htI, htAP⟩\n  have hAP : IsLinftyAP (ε / 2) (x - t) f := by\n    simpa [Set.mem_setOf_eq] using htAP\n  have hAPy : IsLinftyAP (ε / 2) (y - t) f := by\n    have : (y - t) - (x - t) = y - x := by ring\n    have hyx : ‖(y - t) - (x - t)‖ < l := by simpa [this, norm_sub_rev] using hxy\n    have := hl (y - t - (x - t))\n    rcases this with ⟨u, huI, huE⟩\n    have : x - t + u = y - t := by\n      have : y - t - (x - t) + (x - t) = y - t := by ring\n      simpa [add_comm, add_left_comm, add_assoc] using congrArg (fun z => z + (x - t)) (by\n        simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using rfl)\n    simpa [Set.mem_setOf_eq] using huE\n  have hx1 := hAP t\n  have hy1 := hAP y\n  have : dist (f x) (f y) ≤ ε := by\n    have hx' : ‖f (t + (x - t)) - f t‖ ≤ ε / 2 := by\n      simpa [IsLinftyAP, add_assoc, add_left_comm, add_comm, sub_eq_add_neg] using hAP t\n    have hy' : ‖f (t + (y - t)) - f t‖ ≤ ε / 2 := by\n      simpa [IsLinftyAP, add_assoc, add_left_comm, add_comm, sub_eq_add_neg] using hAP y\n    have hx'' : ‖f x - f t‖ ≤ ε / 2 := by simpa [add_sub_cancel] using hx'\n    have hy'' : ‖f y - f t‖ ≤ ε / 2 := by simpa [add_sub_cancel] using hy'\n    have : ‖f x - f y‖ ≤ ε := by\n      have := (norm_sub_le _ _ _).trans (add_le_add hx'' hy'')\n      simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc, two_mul, div_eq_mul_inv,\n        inv_two, a