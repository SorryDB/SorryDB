/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  classical
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  rcases hf (ε := ε / 2) (by linarith) with ⟨l, hl⟩
  have hlpos : 0 < l := IsRelDenseWith.pos (E := {t | IsLinftyAP (ε / 2) t f}) (l := l) hl
  refine ⟨l, hlpos, ?_⟩
  intro x y hxy
  set t := y - x
  rcases hl t with ⟨u, huI, htu⟩
  have hu0 : 0 ≤ u := huI.1
  have hul : u < l := huI.2
  have ht : IsLinftyAP (ε / 2) (t + u) f := htu
  have hx : |u| < ε / 2 := by
    have : u < ε / 2 := lt_of_lt_of_le hul (le_of_lt hxy)
    simpa [abs_of_nonneg hu0] using this
  have hy : ‖f (x + (t + u)) - f x‖ ≤ ε / 2 := ht x
  have hz : ‖f (x + (t + u)) - f y‖ ≤ ε / 2 := by
    have : ‖f (y + u) - f y‖ ≤ ε / 2 := ht y
    simpa [t, add_assoc, add_left_comm, add_comm, sub_eq_add_neg] using this
  have : dist (f x) (f y) < ε := by
    have htri :
        dist (f x) (f y) ≤ dist (f x) (f (x + (t + u))) + dist (f (x + (t + u))) (f y) :=
      dist_triangle (f x) (f (x + (t + u))) (f y)
    have hy' : dist (f x) (f (x + (t + u))) ≤ ε / 2 := by
      simpa [dist_eq_norm, norm_sub_rev] using hy
    have hz' : dist (f (x + (t + u))) (f y) ≤ ε / 2 := by
      simpa [dist_eq_norm] using hz
    have : dist (f x) (f y) ≤ ε := by
      calc
        dist (f x) (f y)
            ≤ dist (f x) (f (x + (t + u))) + dist (f (x + (t + u))) (f y) := htri
        _ ≤ ε / 2 + ε / 2 := add_le_add hy' hz'
        _ = ε := by ring
    exact lt_of_le_of_lt this (by linarith)
  exact this
```
