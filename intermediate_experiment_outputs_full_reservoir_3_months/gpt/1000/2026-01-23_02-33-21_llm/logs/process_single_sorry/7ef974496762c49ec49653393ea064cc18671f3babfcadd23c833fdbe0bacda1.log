      "by\n  classical\n  -- A uniformly almost periodic function is bounded (Bohr almost periodic ⇒ bounded).\n  have h_bdd : ∃ C, ∀ x, ‖f x‖ ≤ C := by\n    -- Use ε = 1 to get relative denseness of 1-almost periods and bound on a compact interval.\n    rcases hf (ε := (1 : ℝ)) (by norm_num) with ⟨l, hl⟩\n    have hl' : 0 < l := IsRelDenseWith.pos (E := {t | IsLinftyAP (1 : ℝ) t f}) (l := l) hl\n    -- Bound on `Set.Icc 0 l` by compactness.\n    have hcont : Continuous f := by\n      -- Uniform almost periodic implies uniform continuity hence continuity; we only need existence\n      -- of a bound, so we use continuity from `continuous_of_uniformContinuous` after proving it\n      -- on a compact interval via `continuousOn` trivially by classical choice.\n      -- Here we can instead use that any function is bounded on a compact set if it's continuous,\n      -- but we don't have continuity yet. So we use a direct bound from almost periods:\n      -- pick a point x0 and use relative denseness to relate any x to x0 by shifts with error ≤ 1.\n      -- Thus it suffices to bound on a compact interval using choice on finitely many points.\n      -- We implement a crude bound by taking `C := ‖f 0‖ + 1 + sup_{y∈Icc 0 l} ‖f y‖` is not available.\n      -- Instead, use: every x = y + n*l + r with r∈Ico 0 l and successive shifts by t in E.\n      -- We'll avoid this complexity by appealing to an existing lemma in Mathlib:\n      -- `IsUnifAlmostPeriodic` already implies boundedness (as in `Mathlib`).\n      -- So we use `by\n      --   simpa [IsUnifAlmostPeriodic] using (hf.bounded ...)` style is unavailable.\n      -- Fallback: use `by classical exact (by\n      --   simpa using (isBounded_range_iff.1 ?_) )` not possible.\n      -- Since the goal is uniform continuity, we can avoid boundedness entirely by a standard lemma\n      -- already in Mathlib: uniformly almost periodic functions are uniformly continuous.\n      -- We directly use the existing theorem.\n      exact (