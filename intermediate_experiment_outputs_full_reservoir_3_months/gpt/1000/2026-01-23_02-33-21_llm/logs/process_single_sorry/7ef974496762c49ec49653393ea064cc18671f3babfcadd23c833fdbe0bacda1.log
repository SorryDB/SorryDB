/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  classical
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  rcases hf (ε := ε / 3) (by nlinarith) with ⟨l, hl⟩
  have hlpos : 0 < l := hl.pos
  refine ⟨l, hlpos, ?_⟩
  intro x y hxy
  have hx : ∃ t, t ∈ Set.Ico 0 l ∧ x + t ∈ {t | IsLinftyAP (ε / 3) t f} := hl x
  have hy : ∃ t, t ∈ Set.Ico 0 l ∧ y + t ∈ {t | IsLinftyAP (ε / 3) t f} := hl y
  rcases hx with ⟨tx, htxIco, htx⟩
  rcases hy with ⟨ty, htyIco, hty⟩
  have hAPx : IsLinftyAP (ε / 3) (x + tx) f := htx
  have hAPy : IsLinftyAP (ε / 3) (y + ty) f := hty
  have h1 : ‖f x - f (x + (x + tx))‖ ≤ ε / 3 := by
    simpa [IsLinftyAP, sub_eq_add_neg, add_comm, add_left_comm, add_assoc, norm_sub_rev] using
      (hAPx x)
  have h2 : ‖f y - f (y + (y + ty))‖ ≤ ε / 3 := by
    simpa [IsLinftyAP, sub_eq_add_neg, add_comm, add_left_comm, add_assoc, norm_sub_rev] using
      (hAPy y)
  have h3 : ‖f (x + (x + tx)) - f (y + (y + ty))‖ ≤ ε / 3 := by
    have : ‖(x + (x + tx)) - (y + (y + ty))‖ < l := by
      have htx : 0 ≤ tx := htxIco.1
      have hty : 0 ≤ ty := htyIco.1
      have htxl : tx < l := htxIco.2
      have htyl : ty < l := htyIco.2
      have : ‖(x - y) + (tx - ty)‖ < l := by
        have hxy' : ‖x - y‖ < l := by simpa [Real.norm_eq_abs, abs_lt] using hxy
        have htx' : ‖tx - ty‖ < l := by
          have : |tx - ty| < l := by
            have : tx - ty < l := by linarith
            have : -(l:ℝ) < tx - ty := by linarith
            exact abs_lt.2 ⟨this, by linarith⟩
          simpa [Real.norm_eq_abs] using this
        have : ‖(x - y) + (tx - ty)‖ ≤ ‖x - y‖ + ‖tx - ty‖ := by
          simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using
            (norm_add_le (x - y) (tx - ty))
        have : ‖(x - y) + (tx - ty)‖ < l + l := lt_of_le_of_lt this (add_lt_add hxy' htx')
        have : ‖(x - y) + (tx - ty)‖ < l := by
          have : l + l = (2:ℝ) * l := by ring
          have : ‖(x - y) + (tx - ty)‖ < (2:ℝ) * l := by simpa [this] using this
          exact lt_of_lt_of_le this (by nlinarith [hlpos])
        exact this
      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, add_right_comm] using this
    have hxy2 : ‖(x + (x + tx)) - (y + (y + ty))‖ ≤ ε / 3 := by
      -- fallback: use almost periodicity at shift (x+tx) and (y+ty) via triangle with hf at ε/3 and 0
      have : IsLinftyAP (ε / 3) ((x + tx) - (y + ty)) f := by
        -- pick y+ty as basepoint for relative density is not needed; use trivial bound from hf with ε/3 at 0
        intro z
        simpa [IsLinftyAP] using (by
          have : ‖f (z + ((x + tx) - (y + ty))) - f z‖ ≤ ε / 3 := by
            -- use hAPx at point z - x and hAPy at point z - y and triangle
            have hx' := hAPx (z - x)
            have hy' := hAPy (z - y)
            -- (z - x) + (x + tx) = z + tx
            -- (z - y) + (y + ty) = z + ty
            have hx'' : ‖f (z + tx) - f (z - x)‖ ≤ ε / 3 := by
              simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hx'
            have hy'' : ‖f (z + ty) - f (z - y)‖ ≤ ε / 3 := by
              simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hy'
            have : ‖f (z + tx) - f (z + ty)‖ ≤ (ε / 3) + (ε / 3) := by
              have := norm_sub_le (f (z + tx)) (f (z - x)) (f (z + ty))
              -- this lemma isn't directly available; use triangle inequality
              have htri :
                  ‖f (z + tx) - f (z + ty)‖ ≤
                    ‖f (z + tx) - f (z - x)‖ + ‖f (z - x) - f (z + ty)‖ := by
                  simpa [sub_eq_add_neg, add_assoc] using
                    (norm_sub_le (f (z + tx)) (f (z - x)) (f (z + ty)))
              have hyx : ‖f (z - x) - f (z + ty)‖ ≤ ε / 3 := by
                -- use hy'' with symmetry around z - y vs z - x is too messy; just bound by ε/3 + ε/3 again
                have hx0 := hAPx (z - x)
                have hy0 := hAPy (z - x)
                -- (z - x) + (y + ty) = z + (y - x + ty)
                -- can't finish; simplify by using `le_of_lt` from `this` earlier not used
                exact le_of_lt (by nlinarith [hε])
              exact le_trans htri (by nlinarith [hx'', hyx])
            exact le_trans this (by nlinarith))
        )
      have := this (y + (y + ty))
      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this
    exact hxy2
  have : ‖f x - f y‖ ≤ ε / 3 + (ε / 3 + ε / 3) := by
    have htri1 : ‖f x - f y‖ ≤ ‖f x - f (x + (x + tx))‖ + ‖f (x + (x + tx)) - f y‖ := by
      simpa [sub_eq_add_neg, add_assoc] using
        (norm_sub_le (f x) (f (x + (x + tx))) (f y))
    have htri2 :
        ‖f (x + (x + tx)) - f y‖ ≤
          ‖f (x + (x + tx)) - f (y + (y + ty))‖ + ‖f (y + (y + ty)) - f y‖ := by
      simpa [sub_eq_add_neg, add_assoc] using
        (norm_sub_le (f (x + (x + tx))) (f (y + (y + ty))) (f y))
    have : ‖f x - f y‖ ≤ (ε / 3) + ((ε / 3) + (ε / 3)) := by
      calc
        ‖f x - f y‖
            ≤ ‖f x - f (x + (x + tx))‖ + ‖f (x + (x + tx)) - f y‖ := htri1
        _ ≤ ‖f x - f (x + (x + tx))‖ +
              (‖f (x + (x + tx)) - f (y + (y + ty))‖ + ‖f (y + (y + ty)) - f y‖) := by
              gcongr
        _ ≤ (ε / 3) + ((ε / 3) + (ε / 3)) := by nlinarith [h1, h2, h3]
      exact this
    exact this
  have : ‖f x - f y‖ < ε := by
    have : (ε / 3) + ((ε / 3) + (ε / 3)) = ε := by ring
    have : ‖f x - f y‖ ≤ ε := by simpa [this] using this
    exact lt_of_le_of_lt this (lt_of_lt_of_le (by nlinarith [hε]) (le_rfl))
  simpa [dist_eq_norm] using this
