/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  classical
  by_contra huc
  have hnot : ¬ UniformContinuous f := huc
  rw [uniformContinuous_iff] at hnot
  rcases hnot with ⟨ε, hε, hbad⟩
  have hRD := hf hε
  rcases hRD with ⟨l, hl⟩
  have hlpos : 0 < l := IsRelDenseWith.pos (E := {t | IsLinftyAP ε t f}) (l := l) hl
  have hpos : 0 < min (l / 2) 1 := lt_min (by nlinarith) (by norm_num)
  rcases hbad (min (l / 2) 1) hpos with ⟨x, y, hxy, hnorm⟩
  have hgap : l / 2 < ‖x - y‖ := by
    have : ‖x - y‖ < l / 2 := lt_of_lt_of_le hxy (min_le_left _ _)
    exact lt_irrefl _ this
  have hx : ∃ t ∈ Set.Ico 0 l, x + t ∈ {t | IsLinftyAP ε t f} := hl x
  rcases hx with ⟨t, htI, htAP⟩
  have ht0 : 0 ≤ t := htI.1
  have htl : t < l := htI.2
  have htAP' : IsLinftyAP ε (x + t) f := htAP
  have := htAP' y
  have : ‖f (y + (x + t)) - f y‖ ≤ ε := this
  have : ‖f (x + t + y) - f y‖ ≤ ε := by simpa [add_assoc, add_left_comm, add_comm] using this
  have h1 : ‖f (x + t + y) - f (x + t)‖ ≤ ε := by
    have := htAP' (x + t)
    simpa [add_assoc, add_left_comm, add_comm, sub_self] using this
  have h2 : ‖f (x + t) - f x‖ ≤ ε := by
    have := htAP' x
    simpa [add_assoc, sub_self] using this
  have h3 : ‖f x - f y‖ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (x + t + y)‖ + ‖f (x + t + y) - f y‖ := by
    calc
      ‖f x - f y‖
          = ‖(f x - f (x + t)) + (f (x + t) - f (x + t + y)) + (f (x + t + y) - f y)‖ := by
              ring_nf
      _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (x + t + y)‖ + ‖f (x + t + y) - f y‖ := by
              simpa [add_assoc] using
                (norm_add_le (f x - f (x + t) + (f (x + t) - f (x + t + y)))
                  (f (x + t + y) - f y) |>.trans
                  (by
                    have := norm_add_le (f x - f (x + t)) (f (x + t) - f (x + t + y))
                    exact add_le_add_right this _))
  have hcontr : ‖f x - f y‖ ≤ 3 * ε := by
    have h1' : ‖f (x + t) - f (x + t + y)‖ ≤ ε := by
      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h1
    have h2' : ‖f x - f (x + t)‖ ≤ ε := by
      simpa [sub_eq_add_neg] using (by
        simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using h2)
    have : ‖f x - f y‖ ≤ ε + ε + ε := by
      refine le_trans h3 ?_
      gcongr
    nlinarith
  have : ¬ ‖f x - f y‖ < ε := by
    exact not_lt_of_ge (le_trans (by nlinarith : ε ≤ 3 * ε) hcontr)
  exact this hnorm
