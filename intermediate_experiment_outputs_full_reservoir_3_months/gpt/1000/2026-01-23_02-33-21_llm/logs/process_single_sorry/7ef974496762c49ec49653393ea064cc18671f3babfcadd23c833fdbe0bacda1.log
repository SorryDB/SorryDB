/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  classical
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩
  have hlpos : 0 < l := hl.pos
  refine ⟨l, hlpos, ?_⟩
  intro x y hxy
  rcases hl (x := x - y) with ⟨t, htI, htE⟩
  have ht : IsLinftyAP (ε / 3) t f := htE
  have hty : y + t ∈ Set.Icc x (x + l) := by
    have ht0 : 0 ≤ t := htI.1
    have htl : t < l := htI.2
    have hyt : y + t = x := by linarith
    have hxyl : x ≤ y + l := by linarith
    have hytle : y + t ≤ x + l := by
      have : y + t = x := by linarith
      linarith [htl, hxyl]
    simpa [hyt] using And.intro (le_of_eq hyt.symm) hytle
  have h1 : ‖f x - f (y + t)‖ ≤ ε / 3 := by
    have := ht (y : ℝ)
    simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc, norm_sub_rev] using this
  have h2 : ‖f (y + t) - f y‖ ≤ ε / 3 := by
    simpa [sub_eq_add_neg, add_assoc] using ht y
  have h3 : ‖f x - f y‖ ≤ ‖f x - f (y + t)‖ + ‖f (y + t) - f y‖ := by
    simpa [sub_eq_add_neg, add_assoc] using
      (norm_sub_le (f x) (f (y + t)) (f y))
  have : ‖f x - f y‖ ≤ ε := by
    have := le_trans h3 (add_le_add h1 h2)
    linarith
  simpa [Complex.dist_eq, dist_eq_norm] using this
