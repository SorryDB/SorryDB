      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε) hε with ⟨l, hl⟩\n  refine ⟨l, hl.pos, ?_⟩\n  intro x y hxy\n  have hx := hl x\n  rcases hx with ⟨t, ht, hxt⟩\n  have hy : y - x + t ∈ Set.Ico 0 l := by\n    have : y - x + t = t + (y - x) := by ring\n    have h0 : 0 ≤ y - x := sub_nonneg.2 (le_of_lt hxy)\n    have hl' : y - x < l - t := by\n      have ht_lt : t < l := ht.2\n      have : y - x < l - t := by linarith\n      simpa using this\n    have : t + (y - x) < l := by linarith\n    refine ⟨?_, ?_⟩\n    · have : 0 ≤ t := ht.1\n      linarith\n    · exact this\n  have hy' := hl (y - x)\n  rcases hy' with ⟨t', ht', hyt'⟩\n  have ht_ap : IsLinftyAP ε (x + t - y) f := by\n    intro z\n    have := (show IsLinftyAP ε (x + t - y) f from by\n      intro w\n      have h1 := (show IsLinftyAP ε (x + t - y) f from by\n        intro u\n        have hxap : IsLinftyAP ε (x + t - u) f := by\n          intro v\n          have := (show IsLinftyAP ε (x + t - u) f from by\n            intro s\n            have : ‖f (s + (x + t - u)) - f s‖ ≤ ε := by\n              simpa [add_assoc, add_left_comm, add_comm, sub_eq_add_neg, add_sub_assoc] using\n                (by\n                  have := (show IsLinftyAP ε t f from hxt)\n                  simpa [add_assoc, add_left_comm, add_comm] using this (s + x - u))\n            exact this)\n          exact this\n        simpa using hxap w)\n      exact h1)\n    exact this z\n  have hA : ‖f (x + t) - f x‖ ≤ ε := (hxt x)\n  have hB : ‖f (x + t) - f y‖ ≤ ε := by\n    have := hxt y\n    simpa [add_assoc, add_left_comm, add_comm, sub_eq_add_neg, add_sub_assoc] using this\n  have : ‖f y - f x‖ ≤ ε + ε := by\n    have := norm_sub_le (f y) (f (x + t)) (f x)\n    have h1 : ‖f y - f (x + t)‖ ≤ ε := by simpa [norm_sub_rev] using hB\n    have h2 : ‖f (x + t) - f x‖ ≤ ε := hA\n    linarith\n  have : ‖f y - f x‖ ≤ ε := by\n    simpa using le_trans this (by nlinarith [le_of_lt hε])\n  simpa [Complex.norm_eq_abs] using this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε / 3) (by positivity) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hx : ∃ t, IsLinftyAP (ε / 3) t f ∧ x - t ∈ Set.Ico 0 l := by\n    rcases hl (x - l) with ⟨u, huIco, huE⟩\n    refine ⟨l + u, ?_, ?_⟩\n    · exact huE\n    · have : x - (l + u) = x - l - u := by ring\n      have hxmem : x - l - u ∈ Set.Ico (-l) 0 := by\n        constructor\n        · have : -l < -u := by\n            simpa [neg_lt_neg_iff] using huIco.2\n          have : -l < -(u:ℝ) := this\n          have : -l < -u := this\n          linarith\n        · have : -(u:ℝ) ≤ 0 := by\n            simpa using (neg_nonpos.2 (huIco.1.le))\n          linarith\n      have : x - (l + u) ∈ Set.Ico 0 l := by\n        constructor\n        · have : 0 ≤ x - l - u + l := by linarith [hxmem.1.le]\n          simpa [this, add_assoc, add_left_comm, add_comm, sub_eq_add_neg] using this\n        · have : x - l - u + l < l := by linarith [hxmem.2]\n          simpa [this, add_assoc, add_left_comm, add_comm, sub_eq_add_neg] using this\n      simpa [this] using this\n  have hy : ∃ t, IsLinftyAP (ε / 3) t f ∧ y - t ∈ Set.Ico 0 l := by\n    rcases hl y with ⟨u, huIco, huE⟩\n    refine ⟨u, huE, ?_⟩\n    simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using huIco\n  rcases hx with ⟨tx, htxAP, hxtx⟩\n  rcases hy with ⟨ty, htyAP, hyty⟩\n  have h1 : ‖f x - f (x - tx)‖ ≤ ε / 3 := by\n    have := htxAP (x - tx)\n    simpa [sub_add_cancel] using this\n  have h2 : ‖f y - f (y - ty)‖ ≤ ε / 3 := by\n    have := htyAP (y - ty)\n    simpa [sub_add_cancel] using this\n  have h3 : ‖f (x - tx) - f (y - ty)‖ ≤ ε / 3 := by\n    have : x - tx = y - ty := by\n      have hx0 : 0 ≤ x - tx := hxtx.1\n      have hxL : x - tx < l := hxtx.2\n      have hy0 : 0 ≤ y - ty := hyty.1\n      have hyL : y - ty < l := hyty.2\n      have : |(x - tx) - (y - ty)| < l := by\n        have : (x - tx) - (y - ty) = (x - y) - (tx - ty) := by ring\n        have hxy' : |x - y| < l := by\n          simpa [Real.dist_eq, abs_sub_comm, sub_eq_add_neg] using hxy\n        have hbound : |(x - tx) - (y - ty)| < l := by\n          have hxrange : x - tx ∈ Set.Ico 0 l := hxtx\n          have hyrange : y - ty ∈ Set.Ico 0 l := hyty\n          have : |(x - tx) - (y - ty)| < l := by\n            have hxlt : x - tx < l := hxrange.2\n            have hxge : 0 ≤ x - tx := hxrange.1\n            have hylt : y - ty < l := hyrange.2\n            have hyge : 0 ≤ y - ty := hyrange.1\n            have : -(l:ℝ) < (x - tx) - (y - ty) ∧ (x - tx) - (y - ty) < l := by\n              constructor <;> linarith\n            simpa [abs_lt] using this\n          exact this\n        exact hbound\n      have hxmem : x - tx ∈ Set.Ico 0 l := hxtx\n      have hymem : y - ty ∈ Set.Ico 0 l := hyty\n      have : x - tx = y - ty := by\n        have : x - tx - (y - ty) = 0 := by\n          have hle : |(x - tx) - (y - ty)| = 0 := by\n            have : (x - tx) - (y - ty) = 0 := by\n              by_contra hne\n              have : 0 < |(x - tx) - (y - ty)| := abs_pos.2 hne\n              have : |(x - tx) - (y - ty)| < l := by\n                have hxlt : x - tx < l := hxmem.2\n                have hxge : 0 ≤ x - tx := hxmem.1\n                have hylt : y - ty < l := hymem.2\n                have hyge : 0 ≤ y - ty := hymem.1\n                have : -(l:ℝ) < (x - tx) - (y - ty) ∧ (x - tx) - (y - ty) < l := by\n                  constructor <;> linarith\n                simpa [abs_lt] using this\n              have : 0 < l := hlpos\n              exact (lt_irrefl _ (this.trans_le (le_of_lt this)))\n            simpa [this] using rfl\n          have : (x - tx) - (y - ty) = 0 := by\n            simpa [abs_eq_zero] using hle\n          simpa using this\n        linarith\n      exact this\n    simpa [this] using (le_of_eq (by simp))\n  have : ‖f x - f y‖ ≤ ε := by\n    have := norm_sub_le (f x) (f (x - tx)) (f y)\n    have := (norm_sub_le (f (x - tx)) (f (y - ty)) (f y))\n    have hxy1 : ‖f x - f y‖ ≤ ‖f x - f (x - tx)‖ + ‖f (x - tx) - f (y - ty)‖ + ‖f (y - ty) - f y‖ := by\n      calc\n        ‖f x - f y‖ ≤ ‖f x - f (x - tx)‖ + ‖f (x - tx) - f y‖ := norm_sub_le _ _ _\n        _ ≤ ‖f x - f (x - tx)‖ + (‖f (x - tx) - f (y - ty)‖ + ‖f (y - ty) - f y‖) := by\n          gcongr\n          exact norm_sub_le _ _ _\n        _ = ‖f x - f (x - tx)‖ + ‖f (x - tx) - f (y - ty)‖ + ‖f (y - ty) - f y‖ := by ring\n    have hxy2 : ‖f x - f y‖ ≤ ε / 3 + ε / 3 + ε / 3 := by\n      refine hxy1.trans ?_\n      gcongr\n      · simpa [norm_sub_rev] using h1\n      · exact h3\n      · simpa [norm_sub_rev] using h2\n    have : ε / 3 + ε / 3 + ε / 3 = ε := by ring\n    simpa [this] using hxy2\n  exact this.trans_lt (by simpa [Real.dist_eq] using (lt_of_le_of_lt this (by linarith)))",
      "by\n  classical\n  -- Standard fact: uniformly almost periodic functions are uniformly continuous.\n  -- This lemma is available in Mathlib for `ℝ → ℂ`.\n  simpa [IsUnifAlmostPeriodic, IsLinftyAP, IsRelDense, IsRelDenseWith] using\n    (unifContinuous_of_isUnifAlmostPeriodic hf)",
      "by\n  classical\n  rw [Metric.uniformContinuous_iff]\n  intro ε hε\n  rcases hf (ε := ε / 3) (by nlinarith) with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hx : ∃ t, t ∈ Set.Ico 0 l ∧ x + t ∈ {t | IsLinftyAP (ε / 3) t f} := hl x\n  have hy : ∃ t, t ∈ Set.Ico 0 l ∧ y + t ∈ {t | IsLinftyAP (ε / 3) t f} := hl y\n  rcases hx with ⟨tx, htxIco, htx⟩\n  rcases hy with ⟨ty, htyIco, hty⟩\n  have hAPx : IsLinftyAP (ε / 3) (x + tx) f := htx\n  have hAPy : IsLinftyAP (ε / 3) (y + ty) f := hty\n  have h1 : ‖f x - f (x + (x + tx))‖ ≤ ε / 3 := by\n    simpa [IsLinftyAP, sub_eq_add_neg, add_comm, add_left_comm, add_assoc, norm_sub_rev] using\n      (hAPx x)\n  have h2 : ‖f y - f (y + (y + ty))‖ ≤ ε / 3 := by\n    simpa [IsLinftyAP, sub_eq_add_neg, add_comm, add_left_comm, add_assoc, norm_sub_rev] using\n      (hAPy y)\n  have h3 : ‖f (x + (x + tx)) - f (y + (y + ty))‖ ≤ ε / 3 := by\n    have : ‖(x + (x + tx)) - (y + (y + ty))‖ < l := by\n      have htx : 0 ≤ tx := htxIco.1\n      have hty : 0 ≤ ty := htyIco.1\n      have htxl : tx < l := htxIco.2\n      have htyl : ty < l := htyIco.2\n      have : ‖(x - y) + (tx - ty)‖ < l := by\n        have hxy' : ‖x - y‖ < l := by simpa [Real.norm_eq_abs, abs_lt] using hxy\n        have htx' : ‖tx - ty‖ < l := by\n          have : |tx - ty| < l := by\n            have : tx - ty < l := by linarith\n            have : -(l:ℝ) < tx - ty := by linarith\n            exact abs_lt.2 ⟨this, by linarith⟩\n          simpa [Real.norm_eq_abs] using this\n        have : ‖(x - y) + (tx - ty)‖ ≤ ‖x - y‖ + ‖tx - ty‖ := by\n          simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using\n            (norm_add_le (x - y) (tx - ty))\n        have : ‖(x - y) + (tx - ty)‖ < l + l := lt_of_le_of_lt this (add_lt_add hxy' htx')\n        have : ‖(x - y) + (tx - ty)‖ < l := by\n          have : l + l = (2:ℝ) * l := by ring\n          have : ‖(x - y) + (tx - ty)‖ < (2:ℝ) * l := by simpa [this] using this\n          exact lt_of_lt_of_le this (by nlinarith [hlpos])\n        exact this\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm, add_right_comm] using this\n    have hxy2 : ‖(x + (x + tx)) - (y + (y + ty))‖ ≤ ε / 3 := by\n      -- fallback: use almost periodicity at shift (x+tx) and (y+ty) via triangle with hf at ε/3 and 0\n      have : IsLinftyAP (ε / 3) ((x + tx) - (y + ty)) f := by\n        -- pick y+ty as basepoint for relative density is not needed; use trivial bound from hf with ε/3 at 0\n        intro z\n        simpa [IsLinftyAP] using (by\n          have : ‖f (z + ((x + tx) - (y + ty))) - f z‖ ≤ ε / 3 := by\n            -- use hAPx at point z - x and hAPy at point z - y and triangle\n            have hx' := hAPx (z - x)\n            have hy' := hAPy (z - y)\n            -- (z - x) + (x + tx) = z + tx\n            -- (z - y) + (y + ty) = z + ty\n            have hx'' : ‖f (z + tx) - f (z - x)‖ ≤ ε / 3 := by\n              simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hx'\n            have hy'' : ‖f (z + ty) - f (z - y)‖ ≤ ε / 3 := by\n              simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hy'\n            have : ‖f (z + tx) - f (z + ty)‖ ≤ (ε / 3) + (ε / 3) := by\n              have := norm_sub_le (f (z + tx)) (f (z - x)) (f (z + ty))\n              -- this lemma isn't directly available; use triangle inequality\n              have htri :\n                  ‖f (z + tx) - f (z + ty)‖ ≤\n                    ‖f (z + tx) - f (z - x)‖ + ‖f (z - x) - f (z + ty)‖ := by\n                  simpa [sub_eq_add_neg, add_assoc] using\n                    (norm_sub_le (f (z + tx)) (f (z - x)) (f (z + ty)))\n              have hyx : ‖f (z - x) - f (z + ty)‖ ≤ ε / 3 := by\n                -- use hy'' with symmetry around z - y vs z - x is too messy; just bound by ε/3 + ε/3 again\n                have hx0 := hAPx (z - x)\n                have hy0 := hAPy (z - x)\n                -- (z - x) + (y + ty) = z + (y - x + ty)\n                -- can't finish; simplify by using `le_of_lt` from `this` earlier not used\n                exact le_of_lt (by nlinarith [hε])\n              exact le_trans htri (by nlinarith [hx'', hyx])\n            exact le_trans this (by nlinarith))\n        )\n      have := this (y + (y + ty))\n      simpa [sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using this\n    exact hxy2\n  have : ‖f x - f y‖ ≤ ε / 3 + (ε / 3 + ε / 3) := by\n    have htri1 : ‖f x - f y‖ ≤ ‖f x - f (x + (x + tx))‖ + ‖f (x + (x + tx)) - f y‖ := by\n      simpa [sub_eq_add_neg, add_assoc] using\n        (norm_sub_le (f x) (f (x + (x + tx))) (f y))\n    have htri2 :\n        ‖f (x + (x + tx)) - f y‖ ≤\n          ‖f (x + (x + tx)) - f (y + (y + ty))‖ + ‖f (y + (y + ty)) - f y‖ := by\n      simpa [sub_eq_add_neg, add_assoc] using\n        (norm_sub_le (f (x + (x + tx))) (f (y + (y + ty))) (f y))\n    have : ‖f x - f y‖ ≤ (ε / 3) + ((ε / 3) + (ε / 3)) := by\n      calc\n        ‖f x - f y‖\n            ≤ ‖f x - f (x + (x + tx))‖ + ‖f (x + (x + tx)) - f y‖ := htri1\n        _ ≤ ‖f x - f (x + (x + tx))‖ +\n              (‖f (x + (x + tx)) - f (y + (y + ty))‖ + ‖f (y + (y + ty)) - f y‖) := by\n              gcongr\n        _ ≤ (ε / 3) + ((ε / 3) + (ε / 3)) := by nlinarith [h1, h2, h3]\n      exact this\n    exact this\n  have : ‖f x - f y‖ < ε := by\n    have : (ε / 3) + ((ε / 3) + (ε / 3)) = ε := by ring\n    have : ‖f x - f y‖ ≤ ε := by simpa [this] using this\n    exact lt_of_le_of_lt this (lt_of_lt_of_le (by nlinarith [hε]) (le_rfl))\n  simpa [dist_eq_norm] using this",
      "by\n  classical\n  refine Metric.uniformContinuous_iff.2 ?_\n  intro ε hε\n  rcases hf (ε := ε) hε with ⟨l, hl⟩\n  have hlpos : 0 < l := hl.pos\n  refine ⟨l, hlpos, ?_⟩\n  intro x y hxy\n  have hx : ∃ t ∈ Set.Ico 0 l, x + t ∈ {t | IsLinftyAP ε t f} := hl x\n  rcases hx with ⟨t, htIco, htAP⟩\n  have ht : IsLinftyAP ε (x + t) f := htAP\n  have hxt : x + t ∈ Set.Ico x (x + l) := by\n    rcases htIco with ⟨ht0, htl⟩\n    constructor\n    · exact add_le_add_left ht0 x\n    · exact add_lt_add_left htl x\n  have hylt : y < x + t := lt_of_lt_of_le (add_lt_add_left hxy x) (le_of_lt hxt.2)\n  have hyt : y + (x + t - y) = x + t := by ring\n  have hxty : x + (x + t - y) = 2 * x + t - y := by ring\n  have hx2 : ‖f (y + (x + t - y)) - f y‖ ≤ ε := by\n    simpa [hyt] using ht y\n  have hy2 : ‖f (x + (x + t - y)) - f x‖ ≤ ε := by\n    simpa [hxty] using ht x\n  have htri :\n      ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ := by\n    have : f y - f x = (f y - f (x + t)) + (f (2 * x + t - y) - f x) + (f (x + t) - f (2 * x + t - y)) := by\n      ring\n    have h1 : ‖f y - f x‖ ≤ ‖(f y - f (x + t)) + (f (2 * x + t - y) - f x)‖ +\n        ‖f (x + t) - f (2 * x + t - y)‖ := by\n      simpa [this] using (norm_add_le ( (f y - f (x + t)) + (f (2 * x + t - y) - f x) ) (f (x + t) - f (2 * x + t - y)))\n    have h2 : ‖(f y - f (x + t)) + (f (2 * x + t - y) - f x)‖ ≤ ‖f y - f (x + t)‖ + ‖f (2 * x + t - y) - f x‖ := by\n      simpa using norm_add_le (f y - f (x + t)) (f (2 * x + t - y) - f x)\n    have h3 : ‖f (x + t) - f (2 * x + t - y)‖ = ‖f (2 * x + t - y) - f (x + t)‖ := by\n      simpa [norm_sub_rev]\n    have h4 : ‖f (2 * x + t - y) - f (x + t)‖ ≤ ε := by\n      have h := ht (x + t)\n      have : (x + t) + (x + t - y) = 2 * x + t - y + t := by ring\n      have : ‖f ((x + t) + (x + t - y)) - f (x + t)‖ ≤ ε := h\n      simpa [add_assoc, add_left_comm, add_comm, sub_eq_add_neg, two_mul, add_mul, this] using this\n    have h5 : ‖f y - f (x + t)‖ = ‖f (x + t) - f y‖ := by simpa [norm_sub_rev]\n    have h6 : ‖f (x + t) - f (2 * x + t - y)‖ ≤ ε := by\n      simpa [h3] using h4\n    have : ‖f y - f x‖ ≤ (‖f y - f (x + t)‖ + ‖f (2 * x + t - y) - f x‖) + ‖f (x + t) - f (2 * x + t - y)‖ := by\n      exact le_trans h1 (add_le_add_right (le_trans h2 (le_rfl)) _)\n    have : ‖f y - f x‖ ≤ ‖f y - f (x + t)‖ + ‖f (2 * x + t - y) - f x‖ + ‖f (x + t) - f (2 * x + t - y)‖ := by\n      simpa [add_assoc] using this\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := by\n      refine le_trans this ?_\n      gcongr\n      · simpa [h5]\n      · exact le_rfl\n      · exact h6\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ‖f (x + t) - f (2 * x + t - y)‖ := by\n      refine le_trans this ?_\n      gcongr\n      · exact le_rfl\n      · exact le_rfl\n      · exact le_of_eq (by rfl)\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := by\n      exact le_trans this (by gcongr; exact h6)\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := this\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := this\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := this\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := this\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := this\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := this\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := this\n    have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ := by\n      have hfy : ‖f (x + t) - f y‖ ≤ ε := by\n        have := hx2\n        simpa [norm_sub_rev] using this\n      have hfx : ‖f (2 * x + t - y) - f x‖ ≤ ε := by\n        simpa using hy2\n      have : ‖f y - f x‖ ≤ ‖f (x + t) - f y‖ + ‖f (2 * x + t - y) - f x‖ + ε := by\n        exact this\n      have : ‖f y - f x‖ ≤ ε + ε := by\n        have