/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  classical
  refine Metric.uniformContinuous_iff.2 ?_
  intro ε hε
  rcases hf (ε := ε / 2) (by positivity) with ⟨l, hl⟩
  refine ⟨l, hl.pos, ?_⟩
  intro x y hxy
  have hx : ∃ t ∈ Set.Ico 0 l, x + t ∈ {t | IsLinftyAP (ε / 2) t f} := hl x
  have hy : ∃ t ∈ Set.Ico 0 l, y + t ∈ {t | IsLinftyAP (ε / 2) t f} := hl y
  rcases hx with ⟨tx, _, htx⟩
  rcases hy with ⟨ty, _, hty⟩
  have htx' : IsLinftyAP (ε / 2) (x + tx) f := htx
  have hty' : IsLinftyAP (ε / 2) (y + ty) f := hty
  have h1 : ‖f (x + (y - x)) - f x‖ ≤ ε / 2 := by
    simpa [IsLinftyAP, add_assoc, add_left_comm, add_comm, add_sub_cancel] using hty' x
  have h2 : ‖f y - f (x + (y - x))‖ ≤ ε / 2 := by
    have := htx' y
    simpa [IsLinftyAP, add_assoc, add_left_comm, add_comm, sub_eq_add_neg, add_sub_cancel] using this
  have : ‖f y - f x‖ ≤ ε := by
    have := norm_sub_le_norm_sub_add_norm_sub (f y) (f (x + (y - x))) (f x)
    have h := le_trans this (add_le_add h2 h1)
    simpa [two_mul, add_comm, add_left_comm, add_assoc, sub_eq_add_neg, add_halves] using h
  simpa [Real.dist_eq, Complex.dist_eq, sub_eq_add_neg, norm_sub_rev] using this
```
