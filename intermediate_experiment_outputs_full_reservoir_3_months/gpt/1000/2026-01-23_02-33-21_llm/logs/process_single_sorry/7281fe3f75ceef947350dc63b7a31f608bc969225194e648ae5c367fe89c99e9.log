      "\n  classical\n  by_cases hxy : x = y\n  · subst hxy\n    simpa [Matroid.Series] using (G.matchingMatroid.series_refl x)\n  ·\n    rcases (h y) with ⟨M, hMmax, hyM⟩\n    have hM : G.IsMatching M := hMmax.toIsMatching\n    have hxV : x ∈ V(G) := h.left_mem\n    have hyV : y ∈ V(G) := h.right_mem\n    have hxM : x ∈ V(G, M) := by\n      by_contra hxM'\n      have : (M ∪ {e | ∃ u v, u = x ∧ v = y ∧ G.IsLink e u v}) ⊆ E(G) := by\n        intro e he\n        rcases he with he | he\n        · exact hM.subset he\n        · rcases he with ⟨u, v, rfl, rfl, hl⟩\n          exact hl.right_mem\n      have hIs : G.IsMatching (M ∪ {e | ∃ u v, u = x ∧ v = y ∧ G.IsLink e u v}) := by\n        refine ⟨this, ?_⟩\n        intro e f he hf hef\n        rcases he with heM | hexy\n        · rcases hf with hfM | hfxy\n          · exact hM.disjoint heM hfM hef\n          · rcases hfxy with ⟨u, v, rfl, rfl, hl⟩\n            have : x ∉ V(G, M) := hxM'\n            exact (hM.disjoint heM (by\n              have : (∃ u v, u = x ∧ v = y ∧ G.IsLink f u v) := by\n                exact ⟨x, y, rfl, rfl, hl⟩\n              exact Or.inr this) (by\n                intro hEq; exact hef (by simpa using hEq))).mono_left ?_\n        · rcases hexy with ⟨u, v, rfl, rfl, hl⟩\n          rcases hf with hfM | hfxy\n          ·\n            have : y ∉ V(G, M) := hyM\n            exact (hM.disjoint (by\n              have : (∃ u v, u = x ∧ v = y ∧ G.IsLink e u v) := by\n                exact ⟨x, y, rfl, rfl, hl⟩\n              exact Or.inr this) hfM (by\n                intro hEq; exact hef (by simpa using hEq))).mono_left ?_\n          ·\n            rcases hfxy with ⟨u', v', rfl, rfl, hl'⟩\n            exfalso\n            exact hef (by\n              have : e = f := by\n                have := hl.uniq hl'\n                simpa using this\n              simpa [this])\n      have hcard : (M.encard : ℕ∞) < (M ∪ {e | ∃ u v, u = x ∧ v = y ∧ G.IsLink e u v}).encard := by\n        have : (∃ e, G.IsLink e x y) := h.exists_isLink\n        rcases this with ⟨e, hl⟩\n        have he : e ∈ {e | ∃ u v, u = x ∧ v = y ∧ G.IsLink e u v} := by\n          exact ⟨x, y, rfl, rfl, hl⟩\n        have hnot : e ∉ M := by\n          intro heM\n          have : y ∈ V(G, M) := by\n            exact ⟨e, heM, y, by simpa using hl.inc_right⟩\n          exact hyM this\n        simpa [encard_union_eq (by\n          refine disjoint_left.2 ?_\n          intro e heM he'\n          rcases he' with ⟨u, v, rfl, rfl, hl'⟩\n          exact hnot heM)] using (encard_lt_encard_insert (s := M) hnot)\n      exact (lt_irrefl _ <| (hMmax.max _ hIs).trans_lt hcard).elim\n    have hyM' : y ∉ V(G, M) := hyM\n    have hxhy : x ≠ y := hxy\n    have hcl : y ∈ G.matchingMatroid.cl ({x} : Set α) := by\n      -- in this matroid, adjacency forces dependence of {x,y}\n      have : ¬ (∃ M', G.IsMatching M' ∧ ({x, y} : Set α) ⊆ V(G, M')) := by\n        intro hI\n        rcases hI with ⟨M', hM', hsub⟩\n        have hxM' : x ∈ V(G, M') := hsub (by simp)\n        have hyM' : y ∈ V(G, M') := hsub (by simp)\n        rcases hxM' with ⟨ex, hex, vx, hvx⟩\n        rcases hyM' with ⟨ey, hey, vy, hvy⟩\n        by_cases hE : ex = ey\n        · subst hE\n          have : x = y := by\n            have hx' : x ∈ V(G, ex) := by simpa using hvx\n            have hy' : y ∈ V(G, ex) := by simpa using hvy\n            exact (by\n              have := by\n                simpa [Graph.V] using And.intro hx' hy'\n              exact this)\n          exact hxhy this\n        · exact (hM'.disjoint hex hey hE).le_bot ⟨by simpa using hvx, by simpa using hvy⟩\n      have hx : x ∈ G.matchingMatroid.E := hxV\n      have hy : y ∈ G.matchingMatroid.E := hyV\n      have hd : ¬ G.matchingMatroid.Indep ({x, y} : Set α) := by\n        intro hI\n        rcases hI with ⟨M', hM', hsub⟩\n        exact this ⟨M', hM', hsub⟩\n      have hcl' : y ∈ G.matchingMatroid.cl ({x} : Set α) := by\n        simpa [Matroid.mem_closure_iff, hx, hy, Set.subset_singleton_iff, hd, hxhy] using\n          (G.matchingMatroid.mem_closure_pair_of_not_indep (x := x) (y := y) hd)\n      exact hcl'\n    exact G.matchingMatroid.seriesPair_iff.2 ⟨hxy, hcl, by\n      have hxcl : x ∈ G.matchingMatroid.cl ({y} : Set α) := by\n        simpa [Set.pair_comm] using hcl\n      exact hxcl⟩",
      "\n  classical\n  rcases h x with ⟨Mx, hMx, hxMx⟩\n  rcases h y with ⟨My, hMy, hyMy⟩\n  have hxV : x ∈ V(G) := by\n    simpa [Graph.Adj] using h.left_mem\n  have hyV : y ∈ V(G) := by\n    simpa [Graph.Adj] using h.right_mem\n  have hxcol : ¬ G.matchingMatroid.IsColoop x := matchingMatroid.noColoop (G := G) h hxV\n  have hycol : ¬ G.matchingMatroid.IsColoop y := matchingMatroid.noColoop (G := G) h hyV\n  have hxpar : G.matchingMatroid.Parallel x y := by\n    simpa [Matroid.parallel_iff, Matroid.series_iff_parallel_dual] using\n      (matchingMatroid.seriesPair_of_adj (G := Gᵈ) (x := x) (y := y) (by\n        intro v\n        rcases h v with ⟨M, hM, hvM⟩\n        refine ⟨M, ?_, hvM⟩\n        exact hM) (by simpa using h))\n  simpa [Matroid.series_iff, hxcol, hycol] using hxpar",
      "\n  classical\n  by_cases hxy : x = y\n  · subst hxy\n    simpa [Matroid.series_iff] using (G.matchingMatroid.loop_or_coloop_or_series x)\n  ·\n    have hxV : x ∈ V(G) := by\n      by_contra hxV\n      have hxcol : ¬ G.matchingMatroid.IsColoop x := matchingMatroid.noColoop (G := G) h (by\n        simpa using hxV)\n      exact hxcol (G.matchingMatroid.isColoop_of_not_mem_ground hxV)\n    have hyV : y ∈ V(G) := by\n      by_contra hyV\n      have hycol : ¬ G.matchingMatroid.IsColoop y := matchingMatroid.noColoop (G := G) h (by\n        simpa using hyV)\n      exact hycol (G.matchingMatroid.isColoop_of_not_mem_ground hyV)\n    have hxcol : ¬ G.matchingMatroid.IsColoop x := matchingMatroid.noColoop (G := G) h hxV\n    have hycol : ¬ G.matchingMatroid.IsColoop y := matchingMatroid.noColoop (G := G) h hyV\n    have hxy' : x ∈ G.matchingMatroid.E ∧ y ∈ G.matchingMatroid.E := by\n      simpa [Graph.matchingMatroid, Graph.matchingIndepMatroid, hxV, hyV]\n    exact (G.matchingMatroid.series_of_adj_of_not_coloop h h hxcol hycol hxy'.1 hxy'.2 h)",
      "\n  classical\n  by_cases hxy : x = y\n  · subst hxy\n    simpa [Matroid.series_self]\n  ·\n    have hx : x ∈ V(G) := by\n      rcases h with ⟨e, he⟩\n      exact he.1\n    have hy : y ∈ V(G) := by\n      rcases h with ⟨e, he⟩\n      exact he.2\n    rcases (h x) with ⟨M, hMmax, hxM⟩\n    have hM : G.IsMatching M := hMmax.toIsMatching\n    have hMe : e ∉ M := by\n      intro heM\n      have hx' : x ∈ V(G, M) := by\n        exact ⟨e, heM, (G.inc_left_mem_of_mem_edge (hM.subset heM) (by simpa using h)).1⟩\n      exact hxM hx'\n    have hMy : y ∈ V(G, M) := by\n      by_contra hyM\n      have : G.IsAugPath hM (.cons x e (.nil y)) :=\n        isAugPath_of_singleEdge (by simpa using h) hxM hyM hxy\n      have hmatch : G.IsMatching (M ∆ E (.cons x e (.nil y))) := this.augment\n      have henc : (M ∆ E (.cons x e (.nil y))).encard = M.encard + 1 := this.augment_encard\n      have hle : (M ∆ E (.cons x e (.nil y))).encard ≤ M.encard := hMmax.max _ hmatch\n      have : M.encard + 1 ≤ M.encard := by simpa [henc] using hle\n      exact Nat.not_succ_le_self _ this\n    have hyM : y ∈ V(G, M) := hMy\n    have hMx : x ∉ V(G, M) := hxM\n    have hxnotcol : ¬ G.matchingMatroid.IsColoop x := matchingMatroid.noColoop (G := G) h hx\n    have hynotcol : ¬ G.matchingMatroid.IsColoop y := matchingMatroid.noColoop (G := G) h hy\n    have : G.matchingMatroid.Cocircuit {x, y} := by\n      refine (G.matchingMatroid.cocircuit_iff_eq_compl_hyperplane).2 ?_\n      refine ⟨V(G) \\ {x, y}, by ext z; simp [Set.mem_diff, Set.mem_insert_iff, Set.mem_singleton_iff,\n        and_left_comm, and_assoc, and_comm], ?_⟩\n      refine (G.matchingMatroid.hyperplane_iff).2 ?_\n      refine ⟨?_, ?_, ?_⟩\n      ·\n        have : (V(G) \\ {x, y}) ⊆ V(G) := by\n          intro z hz\n          exact hz.1\n        exact this\n      ·\n        have : (V(G) \\ {x, y}) ≠ V(G) := by\n          intro hEq\n          have : x ∈ V(G) \\ {x, y} := by simpa [hEq] using hx\n          exact this.2 (by simp)\n        exact this\n      ·\n        intro z hz\n        have hzV : z ∈ V(G) := hz.1\n        have hznxy : z ≠ x ∧ z ≠ y := by\n          have : z ∉ ({x, y} : Set α) := hz.2\n          simpa [Set.mem_insert_iff, Set.mem_singleton_iff] using this\n        have hznotcol : ¬ G.matchingMatroid.IsColoop z := matchingMatroid.noColoop (G := G) h hzV\n        have : ¬ G.matchingMatroid.Hyperplane (V(G) \\ {x, y} ∪ {z}) := by\n          intro hHp\n          have : z ∈ V(G) \\ {x, y} := by\n            refine ⟨hzV, ?_⟩\n            intro hzxy\n            rcases hzxy with rfl | hzY\n            · exact hznxy.1 rfl\n            · cases hzY with\n              | inl hzX => exact hznxy.1 hzX\n              | inr hzY' => exact hznxy.2 hzY'\n          have : V(G) \\ {x, y} ∪ {z} = V(G) \\ {x, y} := by\n            ext w\n            by_cases hwz : w = z\n            · subst hwz; simp [this]\n            · simp [Set.mem_union, Set.mem_singleton_iff, hwz]\n          exact (by simpa [this] using hHp)\n        exact this\n    exact this.seriesPair",
      "\n  classical\n  by_cases hxy : x = y\n  · subst hxy\n    simpa [Matroid.Series] using (G.matchingMatroid.series_refl x)\n  ·\n    rcases h x with ⟨M, hMmax, hxM⟩\n    have hM : G.IsMatching M := hMmax.toIsMatching\n    have hxV : x ∈ V(G) := h.left_mem\n    have hyV : y ∈ V(G) := h.right_mem\n    have hyM : y ∈ V(G, M) := by\n      by_contra hy\n      have : G.IsAugPath hM (.cons x (Classical.choice h) (.nil y)) := by\n        have hl : G.IsLink (Classical.choice h) x y := Classical.choose_spec h\n        exact isAugPath_of_singleEdge (u := x) (v := y) hl hxM hy hxy\n      have hM' : G.IsMatching (M ∆ E (.cons x (Classical.choice h) (.nil y))) := this.augment\n      have hcd : M.encard < (M ∆ E (.cons x (Classical.choice h) (.nil y))).encard := by\n        simpa [this.augment_encard] using (lt_add_of_pos_right _ (Nat.succ_pos 0))\n      exact (hMmax.max _ hM').not_lt hcd\n    exact by\n      simpa [Graph.matchingMatroid, matchingMatroid, matchingIndepMatroid] using\n        (G.matchingMatroid.seriesPair_of_adj h h)",
      "\n  classical\n  rcases h x with ⟨M, hMmax, hxM⟩\n  rcases h y with ⟨M', hM'max, hyM'⟩\n  have hxV : x ∈ V(G) := by\n    rcases h with ⟨e, he⟩\n    exact he.1\n  have hyV : y ∈ V(G) := by\n    rcases h with ⟨e, he⟩\n    exact he.2\n  have hnx : ¬ G.matchingMatroid.IsColoop x := by\n    exact matchingMatroid.noColoop (G := G) h hxV\n  have hny : ¬ G.matchingMatroid.IsColoop y := by\n    exact matchingMatroid.noColoop (G := G) h hyV\n  have hxB : (V(G, M) : Set α) ⊆ G.matchingMatroid.E := by\n    intro v hv\n    exact (Graph.V_sub (G := G) (M := M) hv)\n  have hyB : (V(G, M') : Set α) ⊆ G.matchingMatroid.E := by\n    intro v hv\n    exact (Graph.V_sub (G := G) (M := M') hv)\n  have hbasx : G.matchingMatroid.IsBase (V(G, M)) := by\n    have hI : G.matchingMatroid.Indep (V(G, M)) := by\n      refine ⟨M, hMmax.toIsMatching, ?_⟩\n      intro v hv\n      simpa using hv\n    refine (G.matchingMatroid.isBase_iff_forall_insert_dep ?_).2 ?_\n    · exact hI\n    intro z hz\n    by_contra hdep\n    have hzE : z ∈ G.matchingMatroid.E := by\n      simpa [Graph.matchingMatroid, matchingIndepMatroid, IndepMatroid.matroid] using hz\n    have hzV : z ∈ V(G) := by\n      simpa [Graph.matchingMatroid, matchingIndepMatroid] using hzE\n    have hziness : G.inessential z := h z\n    rcases hziness with ⟨Mz, hMzmax, hzMz⟩\n    have : False := by\n      have hmaxz := hMzmax.encard\n      have hmaxx := hMmax.encard\n      have hsub : V(G, M) ⊆ V(G, Mz) := by\n        intro v hv\n        by_contra hv'\n        have : G.inessential v := ⟨M, hMmax, hv'⟩\n        have : ¬ G.matchingMatroid.IsColoop v := matchingMatroid.noColoop (G := G) h (Graph.V_sub (G := G) (M := M) hv)\n        exact this (by\n          have hb : G.matchingMatroid.IsBase (V(G, M)) := by\n            exact (by\n              have hI : G.matchingMatroid.Indep (V(G, M)) := by\n                refine ⟨M, hMmax.toIsMatching, ?_⟩\n                intro w hw\n                simpa using hw\n              exact (G.matchingMatroid.exists_isBase_superset_of_indep hI hxB).choose_spec.1)\n          exact hb.isColoop_of_mem (by simpa using hv))\n      have hcard : (V(G, M)).encard = (V(G, Mz)).encard := by\n        have := congrArg (fun n ↦ (2 : ℕ∞) * n) (by simpa [hmaxx, hmaxz] : M.encard = Mz.encard)\n        simpa [Graph.V_encard_eq_two_mul_encard_of_isMatching (hMmax.toIsMatching),\n          Graph.V_encard_eq_two_mul_encard_of_isMatching (hMzmax.toIsMatching), mul_assoc] using this\n      have hle : (V(G, M)).encard ≤ (V(G, Mz)).encard := by\n        exact encard_le_encard hsub\n      exact (ne_of_lt (lt_of_le_of_ne hle (by\n        intro hEq\n        have : z ∈ V(G, Mz) := by\n          have : z ∈ V(G, M) := by\n            have : G.matchingMatroid.Indep (insert z (V(G, M))) := by\n              simpa [Graph.matchingMatroid, matchingIndepMatroid] using hdep\n            rcases this with ⟨M'', hM'', hzsub⟩\n            have : z ∈ V(G, M'') := hzsub (by simp)\n            exact this\n          have : z ∈ V(G, Mz) := hsub this\n          exact this\n        exact this\n        ) )).elim\n    exact (this.elim)\n    exact False.elim this\n  have hbasy : G.matchingMatroid.IsBase (V(G, M')) := by\n    have hI : G.matchingMatroid.Indep (V(G, M')) := by\n      refine ⟨M', hM'max.toIsMatching, ?_⟩\n      intro v hv\n      simpa using hv\n    refine (G.matchingMatroid.isBase_iff_forall_insert_dep ?_).2 ?_\n    · exact hI\n    intro z hz\n    by_contra hdep\n    have hzE : z ∈ G.matchingMatroid.E := by\n      simpa [Graph.matchingMatroid, matchingIndepMatroid, IndepMatroid.matroid] using hz\n    have hzV : z ∈ V(G) := by\n      simpa [Graph.matchingMatroid, matchingIndepMatroid] using hzE\n    have hziness : G.inessential z := h z\n    rcases hziness with ⟨Mz, hMzmax, hzMz⟩\n    have : False := by\n      have hmaxz := hMzmax.encard\n      have hmaxy := hM'max.encard\n      have hsub : V(G, M') ⊆ V(G, Mz) := by\n        intro v hv\n        by_contra hv'\n        have : G.inessential v := ⟨M', hM'max