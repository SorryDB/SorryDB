def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  by
    classical
    by_cases h : x = y
    · subst h
      simp [beq]
    · have : x.beq y = false := by
        by_contra hb
        have hb' : x.beq y = true := by
          simpa using hb
        have : x = y := by
          -- show equality by extensionality using the definition of `beq`
          ext i
          -- `beq` checks all bits; from `beq = true` all corresponding bits are equal
          -- We unfold the recursive definition and extract the needed conjunct.
          -- Use a helper lemma by induction on the recursion index.
          have hbits :
              ∀ j : Nat,
                (BitVec.beq.go (w:=w) (x:=x) (y:=y) j = true) →
                  ∀ k : Nat, k ≤ j →
                    x.getLsbD ((w - 1) - k) = y.getLsbD ((w - 1) - k) := by
            intro j
            induction j with
            | zero =>
                intro hj k hk
                have hk' : k = 0 := Nat.le_zero.mp hk
                subst hk'
                simpa [beq] using congrArg (fun b => by
                  -- convert Bool equality to propositional equality of bits
                  exact (of_decide_eq_true (α:=Bool) (p:=x.getLsbD (w - 1) = y.getLsbD (w - 1)) ?_)) hj
            | succ j ih =>
                intro hj k hk
                have hj' : x.getLsbD ((w - 1) - (j + 1)) == y.getLsbD ((w - 1) - (j + 1)) && BitVec.beq.go (w:=w) (x:=x) (y:=y) j = true := by
                  simpa [beq, BitVec.beq.go] using hj
                have hhead : x.getLsbD ((w - 1) - (j + 1)) = y.getLsbD ((w - 1) - (j + 1)) := by
                  have : (x.getLsbD ((w - 1) - (j + 1)) == y.getLsbD ((w - 1) - (j + 1))) = true := by
                    exact (Bool.and_eq_true.mp hj').1
                  simpa using (Bool.eq_true_iff.mp this)
                have htail : BitVec.beq.go (w:=w) (x:=x) (y:=y) j = true := (Bool.and_eq_true.mp hj').2
                cases Nat.eq_or_lt_of_le hk with
                | inl hkEq =>
                    subst hkEq
                    simpa [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using hhead
                | inr hkLt =>
                    have hkLe : k ≤ j := Nat.le_of_lt_succ hkLt
                    have := ih htail k hkLe
                    simpa [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using this
          -- relate index `i` to a `k` in range; use modulo truncation
          have hi : i < w := i.isLt
          let k : Nat := (w - 1) - i
          have hk_le : k ≤ (w - 1) := Nat.sub_le _ _
          have hk : x.getLsbD ((w - 1) - k) = y.getLsbD ((w - 1) - k) :=
            hbits (w - 1) (by simpa [beq] using hb') k hk_le
          simpa [k, Nat.sub_sub_self (Nat.le_of_lt hi)] using hk
        exact this
        exact (h this).elim
      have : (x = y) = False := propext ⟨fun hxy => h hxy, False.elim⟩
      -- convert Bool to proposition via `beq = true`
      have : (x = y) = (x.beq y = true) := by
        apply propext
        constructor
        · intro hxy; exact (h hxy).elim
        · intro hb'
          have : x.beq y = false := this
          exact (by cases hb' ▸ this)
      -- now convert proposition equality to Bool equality
      -- in this file statement expects Bool on RHS, so finish by cases on `x = y`
      -- but we are in `h : x ≠ y`, so RHS is false
      -- and LHS is false
      simp [h, this]
    -- main result by cases
    by_cases hxy : x = y
    · subst hxy; simp [beq]
    · simp [hxy, this]
