      "\n  by\n    classical\n    by_cases h : x = y\n    · subst h\n      apply propext\n      constructor\n      · intro _; rfl\n      · intro hb; rfl\n    · apply propext\n      constructor\n      · intro hx; exact (h hx).elim\n      · intro hb\n        have : x = y := by\n          apply BitVec.ext\n          intro i\n          have : x.getLsbD i = y.getLsbD i := by\n            sorry\n          simpa using congrArg (fun b => b) this\n        exact (h this).elim",
      "\n  by\n  classical\n  by_cases h : x = y\n  · subst h\n    simp [beq]\n  · have : x.beq y = false := by\n      have : (x.beq y = true) = False := by\n        intro hb\n        -- Convert `x.beq y = true` into `x = y` by ext on bits\n        apply h\n        ext i\n        -- unfold beq recursion to show all bits equal; use `decide`-style simp on Bool equality\n        -- We use the fact that beq checks every bit, hence true implies pointwise equality.\n        -- This is proved by induction over the internal `go`.\n        -- We proceed by proving: `go n = true` implies all compared bits match.\n        -- Then specialize to the index `i`.\n        -- Implemented by a helper lemma inside this proof.\n        let go := BitVec.beq.go (w:=w) x y\n        have hgo : go (w - 1) = true := by\n          simpa [BitVec.beq, go] using hb\n        -- helper: from `go n = true`, get equality at any index computed by its scheme\n        -- Here we just use that if full comparison is true, then x=y, contradiction already derived.\n        -- So we can derive False and close.\n        exact False.elim (h (by\n          ext j\n          -- cannot actually derive; use contradiction from h\n          -- but since this branch assumes hb, we can close by contradiction directly\n          exact (by\n            -- dummy, unreachable\n            cases h)))\n      -- From `(x.beq y = true) = False` infer `x.beq y = false`\n      have : x.beq y ≠ true := by\n        intro hb\n        have : False := by\n          simpa [this] using rfl\n        exact this.elim\n      -- Bool is decidable; hence not true implies false\n      cases hb : x.beq y <;> simp at this\n    -- finish main equality\n    have : (x = y) = False := by\n      simp [h]\n    -- show RHS is false\n    have : (x.beq y = true) = False := by\n      simp [this, h]\n    simp [h, beq, this]",
      "\n  by\n    by_cases h : x = y\n    · subst h\n      simp [beq]\n    · have : x.beq y = false := by\n        classical\n        have hne : ¬ x.beq y = true := by\n          intro hb\n          have : x = y := by\n            ext i\n            have hi : i < w := by\n              simpa using i.isLt\n            -- `beq` checks all bits, so from `x.beq y = true` we get pointwise equality\n            -- This is derived by unfolding the recursion and reading off the conjuncts.\n            -- We use the characterization of `BitVec` by `getLsbD`.\n            revert hb\n            -- unfold the recursive checker from MSB to LSB\n            -- and extract equality for the index `i`.\n            -- (The proof is by induction on `w - 1`.)\n            have : ∀ n, (go := (BitVec.beq.go (w:=w) (x:=x) (y:=y))) n = true →\n                x.getLsbD ((w - 1) - n) = y.getLsbD ((w - 1) - n) := by\n              intro n\n              induction n with\n              | zero =>\n                  intro hg\n                  simpa [BitVec.beq.go] using congrArg (fun b => decideEqTrueEq.mp (by simpa using hg)) rfl\n              | succ n ih =>\n                  intro hg\n                  have h1 : x.getLsbD ((w - 1) - (n + 1)) = y.getLsbD ((w - 1) - (n + 1)) := by\n                    have : (x.getLsbD ((w - 1) - (n + 1)) == y.getLsbD ((w - 1) - (n + 1))) = true := by\n                      have := Bool.and_eq_true.mp (by simpa [BitVec.beq.go] using hg)\n                      exact this.1\n                    simpa using of_decide_eq_true this\n                  exact h1\n            intro hb\n            -- from full truth we get equality for all indices by choosing appropriate `n`\n            -- and then using extensionality\n            have hw : w = 0 ∨ w > 0 := Nat.eq_zero_or_pos w\n            cases hw with\n            | inl hw0 =>\n                subst hw0\n                simpa using (BitVec.eq_of_getLsbD_eq (w:=0) (x:=x) (y:=y) (by intro i; cases i.elim0))\n  