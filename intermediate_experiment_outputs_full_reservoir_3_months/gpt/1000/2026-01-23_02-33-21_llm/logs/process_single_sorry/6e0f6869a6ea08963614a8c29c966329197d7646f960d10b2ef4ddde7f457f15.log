def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y :=
  by
    classical
    by_cases h : x = y
    · subst h
      simp [beq]
    · have : x.beq y = false := by
        by_contra hb
        have hb' : x.beq y = true := by
          simpa using hb
        have : x = y := by
          apply BitVec.ext
          intro i
          have hi : i < w := by
            simpa using i.isLt
          -- if beq is true, all bits compared by `go` are equal; in particular at `i`
          -- we reduce to checking the corresponding index used by `go`
          -- use `Nat` arithmetic to rewrite the compared index to `i`
          have : x.getLsbD i = y.getLsbD i := by
            -- we run `go` at position corresponding to `i`
            -- choose j such that (w - 1) - j = i
            let j := (w - 1) - i
            have hj : (w - 1) - j = i := by
              dsimp [j]
              have : i ≤ w - 1 := by
                have hw : w ≠ 0 := by
                  intro hw0
                  subst hw0
                  simpa using hi
                exact Nat.le_pred_of_lt hi
              exact Nat.sub_sub_self this
            -- unfold `beq` and use that `go` returning true implies head comparison true
            -- we proceed by recursion on `j`
            have : x.getLsbD ((w - 1) - j) = y.getLsbD ((w - 1) - j) := by
              revert hb'
              -- prove: go j = true → compared bit at ((w-1)-j) is equal
              induction j with
              | zero =>
                  intro hb'
                  simp [beq] at hb'
                  simpa using congrArg (fun b => by
                    cases b <;> rfl) hb'
              | succ j ih =>
                  intro hb'
                  simp [beq, beq.go] at hb'
                  have hhead : x.getLsbD ((w - 1) - (j + 1)) == y.getLsbD ((w - 1) - (j + 1)) = true := by
                    have := And.left (Bool.and_eq_true.mp hb')
                    simpa using this
                  -- translate Bool equality to Prop equality on bits
                  have : x.getLsbD ((w - 1) - (j + 1)) = y.getLsbD ((w - 1) - (j + 1)) := by
                    simpa using (Bool.eq_true_iff.mp hhead)
                  simpa [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using this
            simpa [hj] using this
          simpa using this
        exact h this
      simp [this, h]
