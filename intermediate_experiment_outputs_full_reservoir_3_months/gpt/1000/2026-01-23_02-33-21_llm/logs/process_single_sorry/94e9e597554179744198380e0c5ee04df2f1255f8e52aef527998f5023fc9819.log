lemma matchingMatroid.noColoop (h : ∀ x, G.inessential x) (hx : x ∈ V(G)) :
    ¬ G.matchingMatroid.IsColoop x := by
  classical
  intro hxcol
  rcases h x with ⟨M, hMmax, hxM⟩
  have hbase : (G.matchingMatroid).IsBase (V(G, M)) := by
    refine (G.matchingIndepMatroid.isBase_iff ?_).2 ?_
    · refine ⟨M, hMmax.toIsMatching, subset_rfl⟩
    intro S hS hSV
    rcases hS with ⟨M', hM', hSV'⟩
    have hcard : S.encard ≤ (V(G, M)).encard := by
      have hle : M'.encard ≤ M.encard := hMmax.max M' hM'
      have hVSle : (V(G, M')).encard ≤ (V(G, M)).encard := by
        simpa [Graph.vSet_eq] using (nsmul_le_nsmul_left 2 hle)
      exact (Set.encard_le_encard_of_subset hSV').trans hVSle
    exact hcard
  have hxnot : x ∉ V(G, M) := hxM
  exact hxnot (hxcol.mem_of_isBase_of_not_mem hbase hxnot)
