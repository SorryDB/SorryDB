      "\n  intro hcol\n  obtain ⟨M, hM, hxM⟩ := h x\n  have hxE : x ∈ G.matchingMatroid.E := by simpa [matchingMatroid, matchingIndepMatroid] using hx\n  have hxcl : x ∈ (G.matchingMatroid.cl (∅ : Set α)) := by\n    simpa [Matroid.IsColoop] using hcol hxE\n  have hxloop : G.matchingMatroid.IsLoop x := by\n    simpa [Matroid.IsLoop] using hxcl\n  have hxindep : (G.matchingMatroid.Indep {x}) := by\n    refine ⟨M, hM, ?_⟩\n    intro y hy\n    have : y = x := by simpa using hy\n    subst this\n    exact hxM\n  exact hxloop.not_indep hxindep",
      "\n  classical\n  obtain ⟨M, hM, hxM⟩ := h x\n  have hbase : (G.matchingMatroid).IsBase (V(G, M)) := by\n    refine ⟨?_, ?_⟩\n    · refine ⟨M, hM.toIsMatching, subset_rfl⟩\n    · intro I hI hVI\n      obtain ⟨M', hM', hIsub⟩ := hI\n      have hle : M'.encard ≤ M.encard := hM.max M' hM'\n      have hVle : (V(G, M')).encard ≤ (V(G, M)).encard := by\n        simpa [hM'.toIsMatching.encard_vertex_eq_two_mul, hM.toIsMatching.encard_vertex_eq_two_mul]\n          using (mul_le_mul_left' hle 2)\n      have hIle : I.encard ≤ (V(G, M)).encard := (encard_le_encard hIsub).trans hVle\n      exact (Matroid.encard_le_encard_of_isBase_of_isIndependent (M := G.matchingMatroid) hbase hVI).trans hIle\n  have hxnot : x ∉ V(G, M) := hxM\n  exact fun hcol ↦ hxnot (hcol.mem_of_isBase hbase)",
      "\n  obtain ⟨M, hMmax, hxM⟩ := h x\n  intro hcol\n  have hxE : x ∈ G.matchingMatroid.E := hx\n  have hxcl : x ∈ G.matchingMatroid.closure (G.matchingMatroid.E \\ {x}) :=\n    hcol.mem_closure_diff_singleton hxE\n  have hxsub : G.matchingMatroid.closure (G.matchingMatroid.E \\ {x}) ⊆ G.matchingMatroid.E :=\n    G.matchingMatroid.closure_subset_ground _\n  have hxmem : x ∈ G.matchingMatroid.E \\ {x} := by\n    refine ⟨?_, ?_⟩\n    · exact hxsub hxcl\n    · simp\n  exact hxmem.2 rfl",
      "\n  intro hcol\n  rcases h x with ⟨M, hMmax, hxM⟩\n  have hxE : x ∈ G.matchingMatroid.E := by simpa [matchingMatroid, matchingIndepMatroid]\n  have hmem : x ∈ M✶.cl (G.matchingMatroid.E \\ {x}) := by\n    simpa [Matroid.IsColoop] using hcol hxE\n  have hsub : V(G, M) ⊆ G.matchingMatroid.E \\ {x} := by\n    intro y hy\n    refine ⟨?_, ?_⟩\n    · have hyV : y ∈ V(G) := by exact (G.vertexSet_inc_of_mem_vertexSet_edges hy)\n      simpa [matchingMatroid, matchingIndepMatroid] using hyV\n    · intro hyx\n      subst hyx\n      exact hxM hy\n  have hbas : G.matchingMatroid.IsBase (V(G, M)) := by\n    refine ⟨?_, ?_, ?_⟩\n    · refine ⟨M, hMmax.toIsMatching, subset_rfl⟩\n    · intro I hI hVI\n      have hI' : ∃ M', G.IsMatching M' ∧ I ⊆ V(G, M') := hI\n      rcases hI' with ⟨M', hM', hIsub⟩\n      have hVsub : V(G, M) ⊆ V(G, M') := by\n        by_contra hnot\n        have hmax' : ¬ G.IsMaxMatching M := by\n          intro hmaxM\n          have := (IsMaxMatching.encard (G := G) (M := M) hmaxM)\n          have := (IsMaxMatching.encard (G := G) (M := M') (by\n            refine (IsMatching.isMaxMatching_of_vertex_subset (G := G) (M := M') hM' ?_)\n            intro v hv\n            exact (G.vertexSet_inc_of_mem_vertexSet_edges (hIsub hv)))).trans ?_\n          · exact hnot (by\n              intro v hv\n              exact (G.vertexSet_inc_of_mem_vertexSet_edges (hIsub hv)))\n          · exact le_rfl\n        exact hmax' hMmax\n      exact hVsub hVI\n    · intro v hv\n      exact (G.vertexSet_inc_of_mem_vertexSet_edges hv)\n  have hcl : x ∈ M✶.cl (V(G, M)) := by\n    exact (M✶.cl_mono hsub) hmem\n  have : x ∈ V(G, M) := by\n    simpa [hbas.cl] using hcl\n  exact hxM this",
      "\n  rcases h x with ⟨M, hMmax, hxM⟩\n  intro hcol\n  have hx' : x ∈ G.matchingMatroid.closure (V(G, M)) := by\n    simpa using hcol.mem_closure_of_mem hx\n  exact hxM (by\n    simpa [Graph.matchingMatroid, matchingMatroid, matchingIndepMatroid, IndepMatroid.matroid] using\n      hx')",
      "\n  classical\n  intro hxC\n  rcases h x with ⟨M, hMmax, hxM⟩\n  have hb : G.matchingMatroid.IsBase (V(G, M)) := by\n    refine ⟨?_, ?_⟩\n    · refine ⟨M, hMmax.toIsMatching, subset_rfl⟩\n    · intro I hI hVI\n      rcases hI with ⟨M', hM', hI'⟩\n      have hM'enc : M'.encard ≤ M.encard := hMmax.max _ hM'\n      have hV' : (I.encard : ℕ∞) ≤ (V(G, M')).encard := by\n        exact (encard_mono hI').trans_eq (by rfl)\n      have hV'' : (V(G, M')).encard ≤ (2 : ℕ∞) * M'.encard := by\n        simpa [two_mul] using (G.encard_vertexSet_le_two_mul_encard_edgeSet (s := M'))\n      have hV : (I.encard : ℕ∞) ≤ (2 : ℕ∞) * M.encard := by\n        exact hV'.trans (hV''.trans (by gcongr))\n      have hVM : (V(G, M)).encard = (2 : ℕ∞) * M.encard := by\n        simpa using (G.encard_vertexSet_eq_two_mul_encard_edgeSet_of_isMatching hMmax.toIsMatching)\n      have hIle : I.encard ≤ (V(G, M)).encard := by\n        simpa [hVM] using hV\n      exact (encard_le_encard hVI).trans hIle\n  have hxnot : x ∉ V(G, M) := hxM\n  have hxmemE : x ∈ G.matchingMatroid.E := hx\n  have hxmemB : x ∈ V(G, M) := hxC.mem_of_isBase_of_mem_ground hb hxmemE\n  exact hxnot hxmemB",
      "\n  intro hxcol\n  obtain ⟨M, hMmax, hxnot⟩ := h x\n  have hxE : x ∈ G.matchingMatroid.E := by\n    simpa [matchingMatroid, matchingIndepMatroid] using hx\n  have hxcl : x ∈ G.matchingMatroid.cl (V(G, M)) := by\n    simpa [Matroid.IsColoop] using hxcol.mem_closure_of_mem hxE\n  have hsubset : V(G, M) ⊆ G.matchingMatroid.E := by\n    intro v hv\n    rcases hv with ⟨e, heM, hv⟩\n    have : v ∈ V(G) := by\n      rcases hv with (hv | hv) <;> exact (hMmax.subset heM) |>.inc_left_mem hv\n    simpa [matchingMatroid, matchingIndepMatroid] using this\n  have hVcl : G.matchingMatroid.cl (V(G, M)) = V(G, M) := by\n    simpa [matchingMatroid, matchingIndepMatroid, Matroid.cl_eq] using\n      (G.matchingMatroid.cl_eq_of_subset_ground hsubset)\n  have : x ∈ V(G, M) := by simpa [hVcl] using hxcl\n  exact hxnot this",
      "\n  classical\n  intro hcol\n  rcases h x with ⟨M, hMmax, hxnot⟩\n  have hxE : x ∈ G.matchingMatroid.E := by simpa [matchingMatroid, matchingIndepMatroid]\n  have hxcl : x ∈ (G.matchingMatroid.closure (G.matchingMatroid.E \\ {x})) := by\n    simpa [Matroid.IsColoop, hxE] using hcol\n  have hxind : ¬ G.matchingMatroid.Indep (G.matchingMatroid.E \\ {x}) := by\n    exact Matroid.not_indep_of_mem_closure_diff hxcl (by simpa using hxE)\n  have hmatch : ∃ M', G.IsMatching M' ∧ (G.matchingMatroid.E \\ {x}) ⊆ V(G, M') := by\n    refine ⟨M, hMmax.toIsMatching, ?_⟩\n    intro y hy\n    by_contra hynV\n    have hmax' : G.IsMaxMatching M := hMmax\n    have henc : M.encard = ν(G) := hmax'.encard\n    have hyV : y ∈ V(G) := by\n      have : y ∈ G.matchingMatroid.E := hy.1\n      simpa [matchingMatroid, matchingIndepMatroid] using this\n    have hyn : y ∉ V(G, M) := hynV\n    have hiness : G.inessential y := h y\n    rcases hiness with ⟨M2, hM2max, hy2not⟩\n    have henc2 : M2.encard = ν(G) := hM2max.encard\n    have : y ∈ V(G, M2) := by\n      have hyE : y ∈ V(G) := hyV\n      have hsub : V(G) ⊆ V(G, M2) := by\n        intro z hz\n        by_contra hzn\n        have : G.IsMaxMatching M2 := hM2max\n        exact (hzn (by\n          have := hz\n          simpa using this))\n      exact hsub hyE\n    exact hy2not this\n  have : G.matchingMatroid.Indep (G.matchingMatroid.E \\ {x}) := by\n    rcases hmatch with ⟨M', hM', hsub⟩\n    refine ⟨M', hM', ?_⟩\n    simpa [matchingMatroid, matchingIndepMatroid] using hsub\n  exact hxind this",
      "\n  classical\n  intro hxcol\n  rcases h x with ⟨M, hMmax, hxM⟩\n  have hxE : x ∈ G.matchingMatroid.E := by\n    simpa [Graph.matchingMatroid, matchingIndepMatroid, hx]\n  have hxcl : x ∈ G.matchingMatroid.closure (G.matchingMatroid.E \\ {x}) := by\n    simpa [Matroid.IsColoop] using hxcol hxE\n  have hbase : G.matchingMatroid.IsBase (V(G, M)) := by\n    have hI : (G.matchingIndepMatroid.Indep (V(G, M))) := by\n      refine ⟨M, hMmax.toIsMatching, ?_⟩\n      intro y hy\n      exact hy\n    have hMmax' : G.matchingIndepMatroid.IsMaximalIndep (V(G, M)) := by\n      intro I hI' hsub\n      have hle : I.encard ≤ (V(G, M)).encard := by\n        rcases hI' with ⟨M', hM', hI'M'⟩\n        have hMM' : M'.encard ≤ M.encard := hMmax.max _ hM'\n        have hVI : I.encard ≤ (V(G, M')).encard := by\n          have : I ⊆ V(G, M') := hI'M'\n          exact encard_le_encard this\n        have hVle : (V(G, M')).encard ≤ (V(G, M)).encard := by\n          simpa [Graph.V] using (mul_le_mul_left' hMM' 2)\n        exact hVI.trans hVle\n      exact (Set.eq_of_subset_of_encard_le hsub hle).symm\n    exact (G.matchingIndepMatroid.isBase_iff.mp ⟨hI, hMmax'⟩)\n  have hxnot : x ∉ V(G, M) := hxM\n  have hxmem : x ∈ V(G, M) := by\n    have hcl' : x ∈ G.matchingMatroid.closure ((V(G, M)) \\ {x}) := by\n      have hsubset : (V(G, M)) \\ {x} ⊆ G.matchingMatroid.E \\ {x} := by\n        intro y hy\n        refine ⟨?_, hy.2⟩\n        have : y ∈ G.matchingMatroid.E := by\n          have : y ∈ V(G) := (G.V_subset_vertexSet M) hy.1\n          simpa [Graph.matchingMatroid, matchingIndepMatroid] using this\n        simpa using this\n      exact G.matchingMatroid.closure_mono hsubset hxcl\n    have : x ∈ G.matchingMatroid.closure (V(G, M)) := by\n      exact G.matchingMatroid.closure_mono (by\n        intro y hy\n        exact hy) hcl'\n    exact hbase.mem_closure_iff.mp this\n  exact hxnot hxmem",
      "\n  intro hcol\n  rcases h x with ⟨M, hMmax, hxM⟩\n  have hbase : G.matchingMatroid.IsBase (V(G, M)) := by\n    refine ⟨?_, ?_⟩\n    · refine ⟨M, hMmax.toIsMatching, le_rfl⟩\n    · intro I hI hVI\n      rcases hI with ⟨M', hM', hsub⟩\n      have hcard : I.encard ≤ (V(G, M')).encard := by\n        exact encard_le_encard hsub\n      have hVM' : (V(G, M')).encard ≤ (V(G, M)).encard := by\n        have : M'.encard ≤ M.encard := hMmax.max _ hM'\n        simpa [Graph.vertexSet_edges_encard_eq_two_mul_encard (G := G) hM'.subset,\n          Graph.vertexSet_edges_encard_eq_two_mul_encard (G := G) hMmax.toIsMatching.subset] using\n          (mul_le_mul_left' this 2)\n      exact (hcard.trans hVM').trans (encard_le_encard hVI)\n  have hxmem : x ∈ V(G, M) := by\n    have := hcol.mem_of_isBase hbase\n    simpa using this\n  exact hxM hxmem",
      "\n  classical\n  rcases h x with ⟨M, hMmax, hxM⟩\n  have hB : G.matchingMatroid.IsBase (V(G, M)) := by\n    refine ⟨?_, ?_⟩\n    · refine ⟨M, hMmax.toIsMatching, ?_⟩\n      rfl\n    · intro I hI hVI\n      rcases hI with ⟨M', hM', hI⟩\n      have hle : I.encard ≤ (V(G, M)).encard := by\n        have hle' : (M'.encard : ℕ∞) ≤ M.encard := hMmax.max M' hM'\n        have hIle : (I.encard : ℕ∞) ≤ (V(G, M')).encard := by\n          exact (encard_le_encard hI).trans_eq (by rfl)\n        have hVM' : (V(G, M')).encard = 2 * M'.encard := by\n          simpa using (hM'.encard_vertex_eq_two_mul_encard (G := G))\n        have hVM : (V(G, M)).encard = 2 * M.encard := by\n          simpa using (hMmax.toIsMatching.encard_vertex_eq_two_mul_encard (G := G))\n        have : (I.encard : ℕ∞) ≤ (2 * M'.encard : ℕ∞) := by\n          simpa [hVM'] using hIle\n        have : (I.encard : ℕ∞) ≤ (2 * M.encard : ℕ∞) := this.trans (mul_le_mul_left' hle')\n        simpa [hVM] using this\n      exact (encard_le_encard_iff.1 hle).2 hVI\n  have hxnot : x ∉ V(G, M) := hxM\n  intro hxcol\n  exact hxnot (hxcol.mem_of_isBase hB hx)",
      "\n  classical\n  intro hcol\n  rcases h x with ⟨M, hMmax, hxM⟩\n  have hbase : (G.matchingMatroid).IsBase (V(G, M)) := by\n    refine ⟨?_, ?_⟩\n    · refine ⟨M, hMmax.toIsMatching, le_rfl⟩\n    · intro I hI hsub\n      rcases hI with ⟨M', hM', hIV⟩\n      have hcard : I.encard ≤ (V(G, M)).encard := by\n        refine (encard_le_encard ?_).trans ?_\n        · exact hsub\n        · exact encard_le_encard hIV\n      have hmax' : M'.encard ≤ M.encard := hMmax.max M' hM'\n      have hVM : (V(G, M)).encard = 2 * M.encard := by\n        simpa using (hMmax.toIsMatching.encard_vertexSet_eq_two_mul_encard (G := G) (M := M))\n      have hVM' : (V(G, M')).encard = 2 * M'.encard := by\n        simpa using (hM'.encard_vertexSet_eq_two_mul_encard (G := G) (M := M'))\n      have : (V(G, M')).encard ≤ (V(G, M)).encard := by\n        simpa [hVM, hVM'] using (mul_le_mul_left' hmax' 2)\n      exact hcard.trans this\n  have hxmem : x ∉ (V(G, M)) := hxM\n  have hxground : x ∈ (G.matchingMatroid).E := by\n    simpa [matchingMatroid, matchingIndepMatroid, IndepMatroid.matroid] using hx\n  have hbase' : (G.matchingMatroid).IsBase ((V(G, M)) ∪ {x}) := by\n    exact hcol.isBase_insert_of_isBase hbase hxmem hxground\n  exact hbase'.not_subset hbase.subset_ground (by\n    intro y hy\n    exact Or.inl hy)",
      "\n  classical\n  intro hco\n  obtain ⟨M, hMmax, hxM⟩ := h x\n  have hxE : x ∈ G.matchingMatroid.E := by simpa [Graph.matchingMatroid, matchingIndepMatroid]\n  have hxcl : x ∈ G.matchingMatroid.cl (G.matchingMatroid.E \\ {x}) := by\n    exact hco.mem_cl_diff_singleton hxE\n  have hsub :\n      V(G, M) ⊆ G.matchingMatroid.cl (G.matchingMatroid.E \\ {x}) := by\n    have hclE : G.matchingMatroid.cl (G.matchingMatroid.E \\ {x}) ⊆ G.matchingMatroid.E :=\n      G.matchingMatroid.cl_subset_ground _\n    intro v hv\n    exact hclE (hxcl)\n  have hxmem : x ∈ V(G, M) := by\n    have : x ∈ G.matchingMatroid.cl (G.matchingMatroid.E \\ {x}) := hxcl\n    exact False.elim (hxM <| by\n      have : x ∈ V(G, M) := by\n        by_contra hx'\n        exact hx' (by\n          simpa using hx')\n      exact this)\n  exact hxM hxmem",
      "\n  classical\n  intro hcol\n  rcases h x with ⟨M, hMmax, hxM⟩\n  have hb : G.matchingMatroid.IsBasis (V(G, M)) := by\n    refine ⟨?_, ?_⟩\n    · refine ⟨M, hMmax.toIsMatching, subset_rfl⟩\n    · intro I hI hVI\n      rcases hI with ⟨M', hM', hIV⟩\n      have hM'cd : M'.encard ≤ M.encard := hMmax.max M' hM'\n      have hVM' : (V(G, M')).encard ≤ (V(G, M)).encard := by\n        simpa [Graph.vertexSet_edges_encard_eq_two_mul_encard (h := hM'.toIsMatching),\n          Graph.vertexSet_edges_encard_eq_two_mul_encard (h := hMmax.toIsMatching)] using\n          (mul_le_mul_left' hM'cd 2)\n      have hIcd : I.encard ≤ (V(G, M)).encard := (encard_le_encard hIV).trans hVM'\n      exact hIcd\n  have hxnot : x ∉ V(G, M) := hxM\n  have hxmem : x ∈ G.matchingMatroid.E := by simpa [matchingMatroid, matchingIndepMatroid] using hx\n  have hcl := hcol.mem_of_isBasis_of_not_mem hb hxnot\n  exact hxnot hcl",
      "\n  classical\n  intro hco\n  obtain ⟨M, hMmax, hxnot⟩ := h x\n  have hxE : x ∈ G.matchingMatroid.E := by simpa [matchingMatroid, matchingIndepMatroid, hx]\n  have hxcl : x ∈ (G.matchingMatroid.closure (G.matchingMatroid.E \\ {x})) := by\n    simpa [Matroid.IsColoop] using hco hxE\n  have hxcl' : x ∈ (G.matchingMatroid.closure (V(G) \\ {x})) := by\n    simpa [matchingMatroid, matchingIndepMatroid] using hxcl\n  have hxmem : x ∈ V(G, M) := by\n    have hbase : G.matchingMatroid.IsBase (V(G, M)) := by\n      have hInd : G.matchingMatroid.Indep (V(G, M)) := by\n        refine ⟨M, hMmax.toIsMatching, ?_⟩\n        intro v hv\n        exact hv\n      refine hInd.isBase_of_forall_insert ?_\n      intro y hyE hynmem\n      exfalso\n      have hyV : y ∈ V(G) := by\n        simpa [matchingMatroid, matchingIndepMatroid] using hyE\n      have hsu : V(G) ⊆ V(G, M) := by\n        intro v hv\n        by_contra hvn\n        have hmax' : G.IsMaxMatching M := hMmax\n        have hMmaxv := (h v).choose_spec.1\n        have hvavoid := (h v).choose_spec.2\n        have henc := IsMaxMatching.encard (M := (h v).choose) hMmaxv\n        have hencM := IsMaxMatching.encard (M := M) hmax'\n        have hle : M.encard ≤ (h v).choose.encard := by\n          have := hmax'.max (h v).choose (h v).choose_spec.1.toIsMatching\n          simpa using this\n        have hge : (h v).choose.encard ≤ M.encard := by\n          have := hMmaxv.max M hmax'.toIsMatching\n          simpa using this\n        have hEq : M.encard = (h v).choose.encard := le_antisymm hle hge\n        have : V(G, M) = V(G, (h v).choose) := by\n          apply subset_antisymm\n          · intro a ha\n            by_contra han\n            have hMaug : ∃ P, G.IsAugPath hmax'.toIsMatching P := by\n              have : ¬ G.IsMaxMatching M := by\n                intro hmax2\n                have hEq2 : M.encard = ν(G) := IsMaxMatching.encard (M := M) hmax2\n                have hEq3 : (h v).choose.encard = ν(G) := by\n              