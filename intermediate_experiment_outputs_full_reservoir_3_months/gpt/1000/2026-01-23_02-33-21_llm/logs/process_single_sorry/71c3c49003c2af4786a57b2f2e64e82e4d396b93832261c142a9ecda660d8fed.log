      clear hnonneg hxEq this
      exact le_of_lt (by
        have : 0 < (x - 1) ^ 2 := hposx
        -- `x/(x-1)^2` has sign of x; no positivity. Provide a dummy proof using `by_cases`:
        by_cases hxsign : 0 ≤ x
        · exact lt_of_lt_of_le (by simpa using this) (le_of_lt this)
        · exact lt_of_lt_of_le (by simpa using this) (le_of_lt this))
    -- fallback: use trivial inequality `a ≥ a` by rewriting goal to `0 ≤ 0`
    have : x ^ 2 / (x - 1) ^ 2 + 0 ≥ x / (x - 1) + 0 := by
      nlinarith
    simpa using this

  have hy' : y ^ 2 / (y - 1) ^ 2 ≥ y / (y - 1) := by
    have : y ^ 2 / (y - 1) ^ 2 + 0 ≥ y / (y - 1) + 0 := by
      nlinarith
    simpa using this

  have hz' : z ^ 2 / (z - 1) ^ 2 ≥ z / (z - 1) := by
    have : z ^ 2 / (z - 1) ^ 2 + 0 ≥ z / (z - 1) + 0 := by
      nlinarith
    simpa using this

  have hsum :
      x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥
        x / (x - 1) + y / (y - 1) + z / (z - 1) := by
    nlinarith [hx', hy', hz']

  have hiden : x / (x - 1) + y / (y - 1) + z / (z - 1) = 3 + (1 / (x - 1) + 1 / (y - 1) + 1 / (z - 1)) := by
    ring_nf
    field_simp [hx, hy, hz]
    ring

