      "\n  have hx : (x - 1) ≠ 0 := sub_ne_zero.mpr h₀.1\n  have hy : (y - 1) ≠ 0 := sub_ne_zero.mpr h₀.2.1\n  have hz : (z - 1) ≠ 0 := sub_ne_zero.mpr h₀.2.2\n  have hxx : (x - 1) ^ 2 ≠ 0 := by\n    simpa [pow_two] using mul_ne_zero hx hx\n  have hyy : (y - 1) ^ 2 ≠ 0 := by\n    simpa [pow_two] using mul_ne_zero hy hy\n  have hzz : (z - 1) ^ 2 ≠ 0 := by\n    simpa [pow_two] using mul_ne_zero hz hz\n  have hxpos : 0 < (x - 1) ^ 2 := sq_pos_of_ne_zero hx\n  have hypos : 0 < (y - 1) ^ 2 := sq_pos_of_ne_zero hy\n  have hzpos : 0 < (z - 1) ^ 2 := sq_pos_of_ne_zero hz\n\n  -- Let a = x/(x-1), etc. Then x^2/(x-1)^2 = a^2.\n  set a : ℝ := x / (x - 1)\n  set b : ℝ := y / (y - 1)\n  set c : ℝ := z / (z - 1)\n\n  have ha : x ^ 2 / (x - 1) ^ 2 = a ^ 2 := by\n    simp [a, div_pow, pow_two, hx, hxx, mul_comm, mul_left_comm, mul_assoc]\n  have hb : y ^ 2 / (y - 1) ^ 2 = b ^ 2 := by\n    simp [b, div_pow, pow_two, hy, hyy, mul_comm, mul_left_comm, mul_assoc]\n  have hc : z ^ 2 / (z - 1) ^ 2 = c ^ 2 := by\n    simp [c, div_pow, pow_two, hz, hzz, mul_comm, mul_left_comm, mul_assoc]\n\n  -- a+b+c = a*b + b*c + c*a (from xyz=1)\n  have habc : a + b + c = a * b + b * c + c * a := by\n    have hx1 : x = a / (a - 1) := by\n      have : a - 1 = (x / (x - 1)) - 1 := by simp [a]\n      have hden : a - 1 = 1 / (x - 1) := by\n        simp [a, sub_eq_add_neg, add_comm, add_left_comm, add_assoc, div_eq_mul_inv, hx, sub_eq_add_neg]\n      calc\n        x = x * 1 := by ring\n        _ = x * ((x - 1) * (1 / (x - 1))) := by\n              field_simp [hx]\n        _ = (x / (x - 1)) / ((x / (x - 1)) - 1) := by\n              field_simp [hx]\n        _ = a / (a - 1) := by simp [a]\n    have hy1 : y = b / (b - 1) := by\n      calc\n        y = y * 1 := by ring\n        _ = y * ((y - 1) * (1 / (y - 1))) := by\n              field_simp [hy]\n        _ = (y / (y - 1)) / ((y / (y - 1)) - 1) := by\n              field_simp [hy]\n        _ = b / (b - 1) := by simp [b]\n    have hz1 : z = c / (c - 1) := by\n 