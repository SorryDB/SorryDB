theorem imo_2008_p2.parts.i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  -- Standard solution: set a = x/(x-1), b = y/(y-1), c = z/(z-1).
  -- Then a+b+c = 1 and apply Cauchy: a^2+b^2+c^2 ≥ (a+b+c)^2/3 = 1/3, but need ≥ 1.
  -- Use identity: x^2/(x-1)^2 = 1 + 2/(x-1) + 1/(x-1)^2, and reduce to (Σ 1/(x-1))^2 ≥ 0 with xyz=1.
