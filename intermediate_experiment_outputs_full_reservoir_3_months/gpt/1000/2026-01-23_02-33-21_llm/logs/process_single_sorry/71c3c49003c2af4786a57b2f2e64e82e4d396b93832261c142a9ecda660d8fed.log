  have hx : (x - 1) ≠ 0 := sub_ne_zero.mpr h₀.1
  have hy : (y - 1) ≠ 0 := sub_ne_zero.mpr h₀.2.1
  have hz : (z - 1) ≠ 0 := sub_ne_zero.mpr h₀.2.2
  have hx2 : (x - 1) ^ 2 ≠ 0 := pow_ne_zero 2 hx
  have hy2 : (y - 1) ^ 2 ≠ 0 := pow_ne_zero 2 hy
  have hz2 : (z - 1) ^ 2 ≠ 0 := pow_ne_zero 2 hz

  have hposx : 0 < (x - 1) ^ 2 := sq_pos_of_ne_zero hx
  have hposy : 0 < (y - 1) ^ 2 := sq_pos_of_ne_zero hy
  have hposz : 0 < (z - 1) ^ 2 := sq_pos_of_ne_zero hz

  have hx' : x ^ 2 / (x - 1) ^ 2 ≥ x / (x - 1) := by
    have : x ^ 2 / (x - 1) ^ 2 - x / (x - 1) = x / (x - 1) ^ 2 := by
      field_simp [hx2]
      ring
    have hnonneg : 0 ≤ x / (x - 1) ^ 2 := by
      have : 0 ≤ x ^ 2 := sq_nonneg x
      have : 0 ≤ x ^ 2 / (x - 1) ^ 2 := by
        exact div_nonneg this (le_of_lt hposx)
      have hxEq : x ^ 2 / (x - 1) ^ 2 = x / (x - 1) := by
        field_simp [hx2]
        ring
      -- use a direct rewrite from the established identity
      -- (note: keep proof simple via `nlinarith` on the identity)
      have : x / (x - 1) ^ 2 = x ^ 2 / (x - 1) ^ 2 - x / (x - 1) := by
        linarith [this]
      -- from `0 ≤ x^2/(...)` and `this` we get `0 ≤ x/(...)^2` is not direct; instead prove directly:
      have : 0 ≤ x ^ 2 / (x - 1) ^ 2 := by
        exact div_nonneg (sq_nonneg x) (le_of_lt hposx)
      -- and note `x/(x-1)^2 = x^2/(x-1)^2 - x/(x-1)` doesn't help; so prove by `mul_self`:
      -- `x/(x-1)^2 = x*(x-1)^0/(x-1)^2` may be negative; so avoid; we'll use another route:
      -- Actually we can show `x^2/(x-1)^2 - x/(x-1) = x/(x-1)^2`, so inequality equivalent to `0 ≤ x/(x-1)^2`,
