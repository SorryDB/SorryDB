      have hy' : (1 - y) ≠ 0 := hy1
      have hz' : (1 - z) ≠ 0 := hz1
      field_simp [a, b, c, hx', hy', hz', h₁]
      ring
    linarith
  -- Reduce to sumsq ≥ 1 using C-S: (a^2+b^2+c^2) ≥ (a+b+c)^2/3 = 1/3; not enough.
  -- But we need (1-a)^2+(1-b)^2+(1-c)^2 ≥ 1 given a+b+c=1, which is true by C-S on (1-a,1-b,1-c):
  -- (1-a)^2+(1-b)^2+(1-c)^2 ≥ (( (1-a)+(1-b)+(1-c) )^2)/3 = (2^2)/3 = 4/3 ≥ 1.
  have hineq : (1 - a) ^ 2 + (1 - b) ^ 2 + (1 - c) ^ 2 ≥ 1 := by
    have hcs :
        (1 - a) ^ 2 + (1 - b) ^ 2 + (1 - c) ^ 2 ≥ (( (1 - a) + (1 - b) + (1 - c) ) ^ 2) / 3 := by
      nlinarith [sq_add_sq_add_sq_ge_div_three_sq (1 - a) (1 - b) (1 - c)]
    have hsum : (1 - a) + (1 - b) + (1 - c) = 2 := by
      linarith [habc]
    have : (( (1 - a) + (1 - b) + (1 - c) ) ^ 2) / 3 = (4 : ℝ) / 3 := by
      simp [hsum]
    have : (1 - a) ^ 2 + (1 - b) ^ 2 + (1 - c) ^ 2 ≥ (4 : ℝ) / 3 := by
      linarith [hcs, this]
    linarith
  -- Finish
  simpa [hxexpr2, hyexpr2, hzexpr2] using hineq
