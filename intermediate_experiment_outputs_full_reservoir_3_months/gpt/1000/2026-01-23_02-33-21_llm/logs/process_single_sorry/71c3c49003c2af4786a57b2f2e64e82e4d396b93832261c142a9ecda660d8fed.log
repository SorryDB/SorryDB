    exact pow_ne_zero 2 this
  have hx' : x ^ 2 / (x - 1) ^ 2 = (x / (x - 1)) ^ 2 := by
    field_simp [pow_two, hx]
    ring
  have hy' : y ^ 2 / (y - 1) ^ 2 = (y / (y - 1)) ^ 2 := by
    field_simp [pow_two, hy]
    ring
  have hz' : z ^ 2 / (z - 1) ^ 2 = (z / (z - 1)) ^ 2 := by
    field_simp [pow_two, hz]
    ring
  have hxnn : 0 ≤ x ^ 2 / (x - 1) ^ 2 := by
    simpa [hx', sq] using sq_nonneg (x / (x - 1))
  have hynn : 0 ≤ y ^ 2 / (y - 1) ^ 2 := by
    simpa [hy', sq] using sq_nonneg (y / (y - 1))
  have hznn : 0 ≤ z ^ 2 / (z - 1) ^ 2 := by
