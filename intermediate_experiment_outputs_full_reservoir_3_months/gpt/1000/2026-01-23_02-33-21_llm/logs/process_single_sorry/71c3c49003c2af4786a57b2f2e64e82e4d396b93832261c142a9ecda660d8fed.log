      field_simp [hx1, hx]
      ring
    have h2 : - x / (1 - x) = 1 - (1 / (1 - x)) := by
      field_simp [hx1]
      ring
    simpa [a] using (h1.trans h2)
  have hyexpr : y / (y - 1) = 1 - b := by
    have h1 : y / (y - 1) = - y / (1 - y) := by
      field_simp [hy1, hy]
      ring
    have h2 : - y / (1 - y) = 1 - (1 / (1 - y)) := by
      field_simp [hy1]
      ring
    simpa [b] using (h1.trans h2)
  have hzexpr : z / (z - 1) = 1 - c := by
    have h1 : z / (z - 1) = - z / (1 - z) := by
      field_simp [hz1, hz]
      ring
    have h2 : - z / (1 - z) = 1 - (1 / (1 - z)) := by
      field_simp [hz1]
      ring
    simpa [c] using (h1.trans h2)
  have hxexpr2 : x ^ 2 / (x - 1) ^ 2 = (1 - a) ^ 2 := by
