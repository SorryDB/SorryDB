  have hy1 : 1 - y ≠ 0 := by simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using (neg_ne_zero.mpr hy)
  have hz1 : 1 - z ≠ 0 := by simpa [sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using (neg_ne_zero.mpr hz)
  -- Use substitution a = 1/(1-x), etc.
  set a : ℝ := 1 / (1 - x)
  set b : ℝ := 1 / (1 - y)
  set c : ℝ := 1 / (1 - z)
  have ha : a = 1 / (1 - x) := rfl
  have hb : b = 1 / (1 - y) := rfl
  have hc : c = 1 / (1 - z) := rfl
  have hax : a ≠ 0 := by
    have : (1 - x) ≠ 0 := hx1
    simp [a, this]
  have hby : b ≠ 0 := by
    have : (1 - y) ≠ 0 := hy1
    simp [b, this]
  have hcz : c ≠ 0 := by
    have : (1 - z) ≠ 0 := hz1
    simp [c, this]
  -- Express target in terms of a,b,c:
  -- x/(x-1) = 1 - 1/(1-x) = 1 - a, hence x^2/(x-1)^2 = (1-a)^2, similarly.
  have hxexpr : x / (x - 1) = 1 - a := by
    have : x - 1 = -(1 - x) := by ring
    have : x / (x - 1) = x / (-(1 - x)) := by simpa [this]
