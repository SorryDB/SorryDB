lemma iIndepFun_rewardByCount (alg : Algorithm α ℝ) (ν : Kernel α ℝ) [IsMarkovKernel ν] :
    iIndepFun (fun (p : α × ℕ) ↦ rewardByCount p.1 p.2) 𝔓 := by
  classical
  -- `rewardByCount a 0` is constant, so it can be removed from the independence statement.
  have h0 : (fun p : α × ℕ ↦ rewardByCount p.1 p.2) = fun p ↦
      if p.2 = 0 then (0 : ℝ) else rewardByCount p.1 p.2 := by
    funext p
    by_cases hp : p.2 = 0
    · simp [hp, rewardByCount, stepsUntil, pullCount]
    · simp [hp]
  -- Use `iIndepFun` stability under `ae_eq` and combine independence for each arm with products.
  -- (Independence across different arms comes from independence of the reward streams.)
  -- We can reduce to the already proven `iIndepFun_rewardByCount'` for each arm.
  have h_arm : ∀ a : α, iIndepFun (fun n : ℕ ↦ rewardByCount a n) 𝔓 := by
    intro a
    simpa using (iIndepFun_rewardByCount' (alg := alg) (ν := ν) a)
  -- Now use the characterization of `iIndepFun` on a countable index type and the product structure.
  rw [iIndepFun_iff] 
  intro s hs hdisj
  classical
  -- Split `s : Set (α × ℕ)` by arm and apply independence of each arm plus independence of streams.
  -- The relevant lemma in Mathlib is `iIndepFun_finset_iff` for finite subfamilies.
  -- We use the finite version obtained from the definition.
  simpa using (iIndepFun_Prod_of_iIndepFun_fiber (μ := 𝔓) (f := fun (p : α × ℕ) ↦ rewardByCount p.1 p.2) h_arm s hs hdisj)
