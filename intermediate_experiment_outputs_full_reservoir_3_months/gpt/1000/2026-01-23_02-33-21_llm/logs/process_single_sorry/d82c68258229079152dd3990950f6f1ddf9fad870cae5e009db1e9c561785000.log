/-- All trivial zeros of the Riemann zeta function (those at s = -2n for positive integers n)
    are simple zeros, meaning that ζ'(-2n) ≠ 0. -/
theorem trivial_zeros_are_simple (n : ℕ) (hn : n > 0) :
  deriv riemannZeta (-2 * ↑n) ≠ 0 :=
by
  have hns : ¬CriticalStrip (-2 * (n : ℂ)) := by
    intro hs
    have : (0 : ℝ) < (-2 * (n : ℂ)).re := hs.1
    have : (0 : ℝ) < (-2 : ℝ) * (n : ℝ) := by simpa using this
    have hn0 : (0 : ℝ) < (n : ℝ) := by exact_mod_cast hn
    have : ¬ (0 : ℝ) < (-2 : ℝ) := by
      have : (-2 : ℝ) < 0 := by norm_num
      exact not_lt_of_ge (le_of_lt this)
    exact (this ((mul_pos_iff_of_pos_right hn0).1 this)).elim
  have hz : riemannZeta (-2 * (n : ℂ)) = 0 := by
    simpa [mul_assoc, two_mul, add_comm, add_left_comm, add_assoc] using
      riemannZeta_neg_two_mul_nat (Nat.pos_iff_ne_zero.mp hn.ne')
  simpa using zeros_outside_critical_strip_are_simple (-2 * (n : ℂ)) hns hz
