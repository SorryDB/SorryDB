      "\n  classical\n  rw [variance, isCentered_stdGaussianMulti (E := E) L]\n  have hmeas :\n      AEStronglyMeasurable (fun x : E ↦ (L x) ^ 2) (stdGaussianMulti E) := by\n    have hcont : Continuous fun x : E ↦ (L x) ^ 2 :=\n      (L.continuous).pow 2\n    exact hcont.aestronglyMeasurable\n  rw [stdGaussianMulti, integral_map _ (by fun_prop)]\n  swap\n  · exact hmeas\n  simp only [map_sum, map_smul, smul_eq_mul]\n  have :\n      (fun x : Fin (Module.finrank ℝ E) → ℝ ↦\n          (L (∑ i, x i • stdOrthonormalBasis ℝ E i)) ^ 2) =\n        fun x ↦\n          (∑ i, (x i) * (L (stdOrthonormalBasis ℝ E i))) ^ 2 := by\n    funext x\n    simp [Finset.mul_sum, Finset.sum_mul, mul_assoc, mul_left_comm, mul_comm]\n  rw [this]\n  have hId : Integrable (fun x : ℝ ↦ x) (gaussianReal 0 1) := by\n    rw [← memLp_one_iff_integrable]\n    exact memLp_id_gaussianReal 1\n  have hmul (i j : Fin (Module.finrank ℝ E)) :\n      Integrable (fun a : Fin (Module.finrank ℝ E) → ℝ ↦ a i * a j)\n        (Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) := by\n    by_cases hij : i = j\n    · subst hij\n      have hsq : Integrable (fun x : ℝ ↦ x ^ 2) (gaussianReal 0 1) := by\n        simpa [pow_two] using (integrable_mul hId hId)\n      simpa [pow_two, mul_assoc, mul_left_comm, mul_comm] using\n        (integrable_eval_pi (i := i) (μ := fun _ ↦ gaussianReal 0 1) (f := fun x ↦ x ^ 2) hsq)\n    ·\n      have hi : Integrable (fun a : Fin (Module.finrank ℝ E) → ℝ ↦ a i)\n          (Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) := by\n        simpa using\n          (integrable_eval_pi (i := i) (μ := fun _ ↦ gaussianReal 0 1) (f := id) hId)\n      have hj : Integrable (fun a : Fin (Module.finrank ℝ E) → ℝ ↦ a j)\n          (Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) := by\n        simpa using\n          (integrable_eval_pi (i := j) (μ := fun _ ↦ gaussianReal 0 1) (f := id) hId)\n      simpa [mul_comm] using (hi.mul hj)\n  have hcov (i j : Fin (Module.finrank ℝ E)) :\n      (∫ a : Fin (Module.finrank ℝ E) → ℝ, a i * a j\n            ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) =\n        (if i = j then 1 else 0) := by\n    by_cases hij : i = j\n    · subst hij\n      have :\n          (∫ a : Fin (Module.finrank ℝ E) → ℝ, (a i) ^ 2\n              ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) =\n            ∫ x, x ^ 2 ∂gaussianReal 0 1 := by\n        convert integral_eval_pi (i := i)\n            (μ := fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)\n            (f := fun x ↦ x ^ 2) ?_\n        · rfl\n        · infer_instance\n        ·\n          have hsq : Integrable (fun x : ℝ ↦ x ^ 2) (gaussianReal 0 1) := by\n            simpa [pow_two] using (integrable_mul hId hId)\n          exact hsq\n      have hvar : (∫ x, x ^ 2 ∂gaussianReal 0 1) = (1 : ℝ) := by\n        simpa [pow_two] using (integral_mul_self_gaussianReal (μ := gaussianReal 0 1))\n      simpa [if_pos rfl, pow_two] using (by simpa [this] using congrArg id hvar)\n    ·\n      have hi : Integrable (fun a : Fin (Module.finrank ℝ E) → ℝ ↦ a i)\n          (Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) := by\n        simpa using\n          (integrable_eval_pi (i := i) (μ := fun _ ↦ gaussianReal 0 1) (f := id) hId)\n      have hj : Integrable (fun a : Fin (Module.finrank ℝ E) → ℝ ↦ a j)\n          (Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) := by\n        simpa using\n          (integrable_eval_pi (i := j) (μ := fun _ ↦ gaussianReal 0 1) (f := id) hId)\n      have hEi :\n          (∫ a : Fin (Module.finrank ℝ E) → ℝ, a i\n              ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) = 0 := by\n        have :\n            (∫ a : Fin (Module.finrank ℝ E) → ℝ, a i\n                ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) =\n              ∫ x, x ∂gaussianReal 0 1 := by\n          convert integral_eval_pi (i := i)\n              (μ := fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) (f := id) hId <;> rfl\n        simpa [this] using (integral_id_gaussianReal (μ := gaussianReal 0 1))\n      have hEj :\n          (∫ a : Fin (Module.finrank ℝ E) → ℝ, a j\n              ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) = 0 := by\n        have :\n            (∫ a : Fin (Module.finrank ℝ E) → ℝ, a j\n                ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) =\n              ∫ x, x ∂gaussianReal 0 1 := by\n          convert integral_eval_pi (i := j)\n              (μ := fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) (f := id) hId <;> rfl\n        simpa [this] using (integral_id_gaussianReal (μ := gaussianReal 0 1))\n      have hprod :\n          (∫ a : Fin (Module.finrank ℝ E) → ℝ, a i * a j\n                ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) =\n            (∫ a, a i ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) *\n              (∫ a, a j ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) := by\n        simpa [mul_comm, mul_left_comm, mul_assoc] using\n          (integral_mul_prod_mk (μ := fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)\n            (i := i) (j := j) hij hi hj)\n      simp [hcov, hij, hprod, hEi, hEj, if_neg hij]\n  classical\n  have :\n      (∫ x : Fin (Module.finrank ℝ E) → ℝ,\n          (∑ i, x i * L (stdOrthonormalBasis ℝ E i)) ^ 2\n            ∂Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1) =\n        ∑ i, (L (stdOrthonormalBasis ℝ E i)) ^ 2 := by\n    classical\n    simp [pow_two, Finset.mul_sum, Finset.sum_mul, hcov, mul_assoc, mul_left_comm, mul_comm]\n  simpa [Var, variance, this]",
      "\n  classical\n  -- unfold variance as second moment since the mean is zero\n  have hcenter : (stdGaussianMulti E)[L] = 0 := isCentered_stdGaussianMulti (E := E) L\n  simp [ProbabilityTheory.variance, hcenter, stdGaussianMulti]",
      "\n  classical\n  -- `stdGaussianMulti` is the image of an i.i.d. standard Gaussian family under a linear map;\n  -- compute variance using orthonormality and independence.\n  have hmean : (stdGaussianMulti E)[L] = 0 := isCentered_stdGaussianMulti (E := E) L\n  rw [ProbabilityTheory.variance, hmean]\n  -- unfold `stdGaussianMulti` and push the integral back to the product space\n  rw [stdGaussianMulti, integral_map _ (by fun_prop)]\n  swap\n  ·\n    -- measurability of the squared function of the finite sum\n    have hm :\n        AEMeasurable\n            (fun x : Fin (Module.finrank ℝ E) → ℝ =>\n              (L (∑ i, x i • stdOrthonormalBasis ℝ E i)) ^ 2)\n            (Measure.pi fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1) := by\n      fun_prop\n    exact hm\n  -- simplify the map\n  simp only [map_sum, map_smul, smul_eq_mul, LinearMap.map_sum, LinearMap.map_smulₛₗ,\n    ContinuousLinearMap.map_sum, ContinuousLinearMap.map_smulₛₗ]\n  -- rewrite the square of a sum as a double sum and use independence / centeredness\n  have hL :\n      (fun x : Fin (Module.finrank ℝ E) → ℝ =>\n          (L (∑ i, x i • stdOrthonormalBasis ℝ E i)) ^ 2) =\n        (fun x =>\n          (∑ i, (x i) * (L (stdOrthonormalBasis ℝ E i))) ^ 2) := by\n    funext x\n    simp [Finset.mul_sum, Finset.sum_mul, mul_assoc, mul_left_comm, mul_comm]\n  simp only [hL]\n  -- expand square into double sum\n  rw [pow_two, Finset.mul_sum, integral_finset_sum]\n  swap\n  · intro i hi\n    refine Integrable.mul_const ?_ _\n    convert integrable_eval_pi (i := i) (μ := fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n        (f := id) ?_\n    · infer_instance\n    · rw [← memLp_one_iff_integrable]\n      exact memLp_id_gaussianReal 1\n  -- inner sum\n  rw [Finset.sum_mul, integral_finset_sum]\n  swap\n  · intro j hj\n    refine Integrable.mul_const ?_ _\n    convert integrable_eval_pi (i := j) (μ := fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n        (f := id) ?_\n    · infer_instance\n    · rw [← memLp_one_iff_integrable]\n      exact memLp_id_gaussianReal 1\n  -- evaluate expectations; cross terms vanish, diagonal terms give variance 1\n  have hdiag :\n      (fun i : Fin (Module.finrank ℝ E) =>\n          ∫ x : Fin (Module.finrank ℝ E) → ℝ, (x i) ^ 2\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)) =\n        fun _ => (1 : ℝ) := by\n    funext i\n    have :\n        ∫ x : Fin (Module.finrank ℝ E) → ℝ, (x i) ^ 2\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n          = ∫ t : ℝ, t ^ 2 ∂gaussianReal 0 1 := by\n      convert integral_eval_pi (i := i)\n          (μ := fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n          (f := fun t => t ^ 2) ?_\n      · rfl\n      · infer_instance\n      ·\n        -- integrable square under standard Gaussian\n        simpa [pow_two] using (memLp_mul_id_gaussianReal (p := (1 : ℝ≥0∞))).integrable\n    -- standard Gaussian second moment is 1\n    simpa [this] using (integral_sq_gaussianReal (m := (0 : ℝ)) (σ := (1 : ℝ)))\n  -- use independence: for i ≠ j, E[x_i x_j] = 0\n  have hcross :\n      ∀ i j : Fin (Module.finrank ℝ E),\n        i ≠ j →\n          (∫ x : Fin (Module.finrank ℝ E) → ℝ, (x i) * (x j)\n              ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)) = 0 := by\n    intro i j hij\n    -- use product structure: factor expectation into product of means\n    have hi :\n        ∫ x : Fin (Module.finrank ℝ E) → ℝ, x i\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n          = (0 : ℝ) := by\n      have :\n          ∫ x : Fin (Module.finrank ℝ E) → ℝ, x i\n              ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n            = ∫ t : ℝ, t ∂gaussianReal 0 1 := by\n        convert integral_eval_pi (i := i)\n            (μ := fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n            (f := id) ?_\n        · rfl\n        · infer_instance\n        · rw [← memLp_one_iff_integrable]\n          exact memLp_id_gaussianReal 1\n      simpa [this] using (integral_id_gaussianReal (m := (0 : ℝ)) (σ := (1 : ℝ)))\n    have hj :\n        ∫ x : Fin (Module.finrank ℝ E) → ℝ, x j\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n          = (0 : ℝ) := by\n      have :\n          ∫ x : Fin (Module.finrank ℝ E) → ℝ, x j\n              ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n            = ∫ t : ℝ, t ∂gaussianReal 0 1 := by\n        convert integral_eval_pi (i := j)\n            (μ := fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)\n            (f := id) ?_\n        · rfl\n        · infer_instance\n        · rw [← memLp_one_iff_integrable]\n          exact memLp_id_gaussianReal 1\n      simpa [this] using (integral_id_gaussianReal (m := (0 : ℝ)) (σ := (1 : ℝ)))\n    -- now compute mixed moment as product (independence) and conclude\n    simpa [hi, hj, mul_assoc, mul_left_comm, mul_comm] using\n      (integral_mul_eval_pi_eq_mul_integral_eval_pi (μ := fun _ : Fin (Module.finrank ℝ E) =>\n        gaussianReal 0 1) hij)\n  -- assemble result\n  -- after expanding: sum over i=j gives (L e_i)^2 * 1, cross terms 0\n  have :\n      (∫ x : Fin (Module.finrank ℝ E) → ℝ,\n          (∑ i : Fin (Module.finrank ℝ E), x i * L (stdOrthonormalBasis ℝ E i)) *\n              (∑ j : Fin (Module.finrank ℝ E), x j * L (stdOrthonormalBasis ℝ E j))\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1))\n        =\n        ∑ i : Fin (Module.finrank ℝ E), (L (stdOrthonormalBasis ℝ E i)) ^ 2 := by\n    -- expand and evaluate integrals termwise\n    simp [Finset.mul_sum, Finset.sum_mul, pow_two, hcross, hdiag, mul_assoc, mul_left_comm, mul_comm]\n  simpa [pow_two] using this",
      "\n  classical\n  rw [stdGaussianMulti]\n  -- reduce to variance of a linear image of an i.i.d. standard Gaussian vector\n  simp only [ProbabilityTheory.variance, ProbabilityTheory.Var, Measure.map_apply (by fun_prop)]\n  -- `simp` knows the variance of a finite sum of independent centered gaussians, and\n  -- the coordinates are independent under `Measure.pi`.\n  simpa using (variance_dual_stdGaussianMulti (E := E) L)",
      "\n  classical\n  have hmean : (stdGaussianMulti E)[L] = 0 := isCentered_stdGaussianMulti (E := E) L\n  rw [variance_def]\n  simp [hmean, stdGaussianMulti]\n  -- reduce to variance of a sum of independent standard Gaussians along an orthonormal basis\n  have hμ :\n      Var[L; stdGaussianMulti E] =\n        Var[(fun x : Fin (Module.finrank ℝ E) → ℝ =>\n            ∑ i, x i * L (stdOrthonormalBasis ℝ E i));\n          Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)] := by\n    simp [stdGaussianMulti, Var, variance, variance_def, integral_map, (by fun_prop : Measurable _)]\n  -- use the standard computation: variance of linear combination of independent N(0,1)\n  -- is sum of squares of coefficients\n  -- Mathlib lemma: `variance_sum_mul_gaussianReal_pi` (in `Mathlib.Probability.Distributions.Gaussian.Basic`)\n  simpa [hμ, mul_comm, mul_left_comm, mul_assoc, pow_two] using\n    variance_sum_mul_gaussianReal_pi (c := fun i => L (stdOrthonormalBasis ℝ E i))",
      "\n  simpa [stdGaussianMulti]",
      "\n  classical\n  -- identify with the standard Gaussian on `Fin (finrank ℝ E) → ℝ` mapped through the ONB\n  simp [stdGaussianMulti, ProbabilityTheory.variance, ProbabilityTheory.Var, isCentered_stdGaussianMulti (E := E) L]",
      "\n  classical\n  rw [variance_eq_integral_sq_sub]\n  simp [isCentered_stdGaussianMulti (E := E) L, stdGaussianMulti, integral_map, map_sum, map_smul,\n    smul_eq_mul, integral_finset_sum, integrable_eval_pi, integral_eval_pi]",
      "\n  classical\n  rw [ProbabilityTheory.variance, isCentered_stdGaussianMulti (E := E) L]\n  simp [stdGaussianMulti, integral_map, map_sum, map_smul, smul_eq_mul, pow_two]",
      "\n  classical\n  -- `Var[L; μ] = ∫ x, (L x) ^ 2 ∂μ` when `μ` is centered for `L`\n  have hcenter : (stdGaussianMulti E)[L] = 0 := isCentered_stdGaussianMulti (E := E) L\n  simp [ProbabilityTheory.variance, hcenter, stdGaussianMulti, integral_map, (by fun_prop),\n    Finset.sum_mul, Finset.mul_sum, mul_assoc, mul_left_comm, mul_comm]",
      "\n  classical\n  rw [stdGaussianMulti, variance_map]\n  swap\n  · exact (Finset.measurable_sum _ (by fun_prop)).aemeasurable\n  simp only [map_sum, map_smul, smul_eq_mul, PiLp.inner_apply, LinearMap.coe_coe]\n  rw [variance_finset_sum]\n  · refine Finset.sum_congr rfl ?_\n    intro i hi\n    simp only [variance_mul_const]\n    have hVar :\n        Var[(fun a : Fin (Module.finrank ℝ E) → ℝ ↦ a i);\n            Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)]\n          = Var[id; gaussianReal 0 1] := by\n      simpa using (variance_eval_pi (i := i)\n        (μ := fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1))\n    simp [hVar]\n  · intro i hi\n    refine (integrable_eval_pi (i := i) (μ := fun _ ↦ gaussianReal 0 1) (f := id) ?_)\n    rw [← memLp_one_iff_integrable]\n    exact memLp_id_gaussianReal 1\n  · intro i hi\n    refine (integrable_eval_pi (i := i) (μ := fun _ ↦ gaussianReal 0 1) (f := fun x ↦ x ^ 2) ?_)\n    rw [← memLp_one_iff_integrable]\n    simpa [pow_two] using (memLp_mul_id_gaussianReal 1)",
      "\n  classical\n  simp [ProbabilityTheory.stdGaussianMulti, variance, isCentered_stdGaussianMulti (E := E) L]",
      "\n  classical\n  -- identify `stdGaussianMulti E` as the pushforward of an i.i.d. standard normal vector\n  simp [ProbabilityTheory.stdGaussianMulti, variance_map, isCentered_stdGaussianMulti (E := E)]",
      "\n  classical\n  rw [variance_eq_integral_sq_sub]\n  have hcenter : (stdGaussianMulti E)[L] = 0 := isCentered_stdGaussianMulti (E := E) L\n  simp [hcenter, stdGaussianMulti, Measure.integral_map (by fun_prop),\n    Finset.mul_sum, Finset.sum_mul, mul_assoc, mul_left_comm, mul_comm,\n    sub_eq_add_neg, add_assoc, add_left_comm, add_comm]",
      "\n  classical\n  simp [stdGaussianMulti, ProbabilityTheory.stdGaussianMulti, variance, isCentered_stdGaussianMulti (E := E) L]",
      "\n  classical\n  -- `stdGaussianMulti E` is the pushforward of an i.i.d. standard Gaussian vector by a linear map.\n  -- The variance of `L` under the pushforward is the variance of the corresponding linear form.\n  rw [stdGaussianMulti, ProbabilityTheory.variance_map (μ := Measure.pi (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1))\n      (f := fun x ↦ ∑ i, x i • stdOrthonormalBasis ℝ E i) (g := fun y ↦ L y)]\n  · simp only [StrongDual.coe_coe, map_sum, map_smul, smul_eq_mul]\n    -- expand the variance of a sum of independent centered Gaussians\n    simpa using\n      variance_sum_mul_eval_stdGaussianReal\n        (L := fun i : Fin (Module.finrank ℝ E) ↦ L (stdOrthonormalBasis ℝ E i))\n  · exact (Finset.measurable_sum _ (by fun_prop)).aemeasurable",
      "\n  rw [stdGaussianMulti, variance_map _ (by fun_prop)]\n  swap\n  · exact (Finset.measurable_sum _ (by fun_prop)).aemeasurable\n  simp only [map_sum, map_smul, smul_eq_mul]\n  have hmean : (stdGaussianMulti E)[L] = 0 := isCentered_stdGaussianMulti (E := E) L\n  rw [variance_eq_integral_sq_sub_mean, hmean, sub_zero]\n  simp only [StrongDual.coe_coe, Finset.sum_apply, LinearMap.map_sum, LinearMap.map_smul,\n    smul_eq_mul]\n  have hL :\n      (fun a : (Fin (Module.finrank ℝ E) → ℝ) =>\n          L (∑ i, a i • stdOrthonormalBasis ℝ E i)) =\n        fun a => ∑ i, a i * L (stdOrthonormalBasis ℝ E i) := by\n    funext a\n    simp [Finset.mul_sum]\n  simp [hL, integral_finset_sum]\n  classical\n  have hIndep :\n      Pairwise fun i j : Fin (Module.finrank ℝ E) =>\n        i ≠ j →\n          (∫ a, (a i * L (stdOrthonormalBasis ℝ E i)) *\n                (a j * L (stdOrthonormalBasis ℝ E j))\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)) = 0 := by\n    intro i j hij\n    have hi :\n        Integrable (fun x : ℝ => x) (gaussianReal 0 1) := by\n      rw [← memLp_one_iff_integrable]\n      exact memLp_id_gaussianReal 1\n    have hj : Integrable (fun x : ℝ => x) (gaussianReal 0 1) := by\n      rw [← memLp_one_iff_integrable]\n      exact memLp_id_gaussianReal 1\n    have hEi :\n        (∫ a : Fin (Module.finrank ℝ E) → ℝ, a i\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)) =\n          (∫ x, x ∂gaussianReal 0 1) := by\n      simpa using (integral_eval_pi (d := Module.finrank ℝ E) (i := i)\n        (μ := fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1) (f := id) hi)\n    have hEj :\n        (∫ a : Fin (Module.finrank ℝ E) → ℝ, a j\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)) =\n          (∫ x, x ∂gaussianReal 0 1) := by\n      simpa using (integral_eval_pi (d := Module.finrank ℝ E) (i := j)\n        (μ := fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1) (f := id) hj)\n    have h0 : (∫ x, x ∂gaussianReal 0 1) = 0 := by\n      simpa using (integral_id_gaussianReal (m := (0 : ℝ)) (σ := (1 : ℝ)))\n    have hprod :\n        (∫ a : Fin (Module.finrank ℝ E) → ℝ, (a i) * (a j)\n            ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)) = 0 := by\n      -- use independence of coordinates in product measure\n      simpa [mul_assoc, mul_left_comm, mul_comm, hEi, hEj, h0] using\n        (integral_mul_eval_pi_eq_mul_integral_eval_pi (μ := fun _ : Fin (Module.finrank ℝ E) =>\n          gaussianReal 0 1) hij (f := id) (g := id) hi hj)\n    simp [mul_assoc, mul_left_comm, mul_comm, hprod]\n  have hsquare :\n      (∫ a : Fin (Module.finrank ℝ E) → ℝ,\n          (∑ i, a i * L (stdOrthonormalBasis ℝ E i)) ^ 2\n        ∂Measure.pi (fun _ : Fin (Module.finrank ℝ E) => gaussianReal 0 1)) =\n        ∑ i, (L (stdOrthonormalBasis ℝ E i)) ^ 2 := by\n    -- expand square and kill cross terms\n    simp [pow_two, mul_add, add_mul, Finset.mul_sum, Finset.sum_mul, Finset.sum_add_distrib,\n      Finset.sum_sigma', Finset.sum_product, Finset.sum_comm, Finset.sum_left_comm,\n      integral_finset_sum, hIndep, integral_mul_const, integral_const_mul, mul_assoc, mul_left_comm,\n      mul_comm, integral_eval_pi, integrable_eval_pi, memLp_id_gaussianReal, memLp_one_iff_integrable,\n      integral_sq_gaussianReal, pow_two]\n  simpa [variance, hsquare]",
      "\n  classical\n  -- `stdGaussianMulti` is the pushforward of an i.i.d. standard Gaussian vector along the linear map\n  -- `x ↦ ∑ i, x i • e i`. Compute the variance by expanding the square and using independence/centering.\n  have hcenter : (stdGaussianMulti E)[L] = 0 := isCentered_stdGaussianMulti (E := E) L\n  rw [Var, hcenter, sub_zero]\n  rw [stdGaussianMulti, integral_map _ (by fun_prop)]\n  swap\n  ·\n    -- aemeasurable of the integrand\n    refine (continuous_finset_sum _ ?_).aemeasurable\n    intro i hi\n    -- continuity of `x ↦ (L (x i • e i))^2`\n    have : Continuous fun x : Fin (Module.finrank ℝ E) → ℝ =>\n        (L (x i • stdOrthonormalBasis ℝ E i)) ^ 2 := by\n      fun_prop\n    simpa using this\n  -- expand the map and simplify\n  simp only [map_sum, map_smul, smul_eq_mul]\n  -- rewrite the integrand\n  have hlin :\n      (fun x : Fin (Module.finrank ℝ E) → ℝ =>\n          (∑ i, (x i) * L (stdOrthonormalBasis ℝ E i)) ^ 2) =\n        fun x =>\n          (∑ i, (L (stdOrthonormalBasis ℝ E i)) * x i) ^ 2 := by\n    funext x\n    refine congrArg (fun t => t ^ 2) ?_\n    refine Finset.sum_congr rfl ?_\n    intro i hi\n    ring\n  -- use bilinearity of square: (∑ a_i)^2 = ∑_{i,j} a_i a_j\n  -- then integrate termwise; cross terms vanish by centering; diagonal terms give variance 1.\n  -- We implement via `Finset.sum_mul_sum` and `integral_finset_sum`.\n  rw [hlin]\n  simp only [pow_two]\n  -- turn the product of sums into double sum\n  have :\n      (fun x : Fin (Module.finrank ℝ E) → ℝ =>\n          (∑ i, L (stdOrthonormalBasis ℝ E i) * x i) *\n            (∑ j, L (stdOrthonormalBasis ℝ E j) * x j)) =\n        fun x =>\n          ∑ i, ∑ j, (L (stdOrthonormalBasis ℝ E i) * x i) *\n            (L (stdOrthonormalBasis ℝ E j) * x j) := by\n    funext x\n    simpa [Finset.sum_mul_sum, Finset.mul_sum, Finset.sum_mul]\n  rw [this]\n  -- integrate the double sum\n  rw [integral_finset_sum]\n  swap\n  · intro i hi\n    refine Integrable.finset_sum ?_\n   