lemma variance_dual_stdGaussianMulti (L : StrongDual ℝ E) :
    Var[L; stdGaussianMulti E] = ∑ i, L (stdOrthonormalBasis ℝ E i) ^ 2 := by
  classical
  -- expand the definition via the map from the product Gaussian
  rw [stdGaussianMulti, ProbabilityTheory.variance_map (μ := Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)
    (f := fun x ↦ ∑ i, x i • stdOrthonormalBasis ℝ E i) (g := fun x ↦ L x)]
  · simp only [map_sum, map_smul, smul_eq_mul]
    have hcenter :
        (∫ x : Fin (Module.finrank ℝ E) → ℝ,
            ∑ i, (x i) * (L (stdOrthonormalBasis ℝ E i)) ∂Measure.pi
              (fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)) = 0 := by
      have : (stdGaussianMulti E)[L] = 0 := isCentered_stdGaussianMulti (E := E) (L := L)
      simpa [stdGaussianMulti, integral_map (by fun_prop),
        Finset.measurable_sum _ (by fun_prop)] using this
    have hvar :
        variance
            (fun x : Fin (Module.finrank ℝ E) → ℝ ↦
              ∑ i, (x i) * (L (stdOrthonormalBasis ℝ E i)))
            (Measure.pi fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)
          = ∑ i, (L (stdOrthonormalBasis ℝ E i)) ^ 2 := by
      -- use independence and known variance of standard Gaussian coordinates
      simpa using
        ProbabilityTheory.variance_sum_mul_gaussianReal_eq
          (c := fun i : Fin (Module.finrank ℝ E) ↦ L (stdOrthonormalBasis ℝ E i))
    simpa [Var, hcenter] using hvar
  · -- integrability side condition
    refine (integrable_finset_sum ?_).2
    intro i hi
    refine Integrable.mul_const ?_ _
    convert integrable_eval_pi (i := i) (μ := fun _ : Fin (Module.finrank ℝ E) ↦ gaussianReal 0 1)
        (f := id) ?_
    · simp
    · infer_instance
    · rw [← memLp_one_iff_integrable]
      exact memLp_id_gaussianReal 1
