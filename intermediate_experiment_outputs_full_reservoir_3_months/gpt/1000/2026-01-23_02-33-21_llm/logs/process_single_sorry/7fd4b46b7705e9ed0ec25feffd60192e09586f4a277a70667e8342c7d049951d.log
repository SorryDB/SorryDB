      "\n  have hx3 : x + 3 ∣ 40 := by\n    simpa [h₁] using (Nat.gcd_dvd_right a 40)\n  have hx3_pos : 0 < x + 3 := by\n    exact Nat.succ_pos _\n  have hx3_le40 : x + 3 ≤ 40 := Nat.le_of_dvd (by decide : 0 < 40) hx3\n  have hx_le37 : x ≤ 37 := by\n    have : x + 3 ≤ 37 + 3 := by\n      simpa using hx3_le40\n    exact Nat.le_of_add_le_add_right this\n  have hgcd_lcm : Nat.gcd a 40 * Nat.lcm a 40 = a * 40 := by\n    simpa [Nat.gcd_mul_lcm] using (Nat.gcd_mul_lcm a 40)\n  have h_eq : (x + 3) * (x * (x + 3)) = a * 40 := by\n    calc\n      (x + 3) * (x * (x + 3)) = (Nat.gcd a 40) * (Nat.lcm a 40) := by simp [h₁, h₂]\n      _ = a * 40 := by simpa using hgcd_lcm\n  have h40div : 40 ∣ (x * (x + 3)) := by\n    have : 40 ∣ (x + 3) * (x * (x + 3)) := by\n      refine ⟨a, ?_⟩\n      simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using h_eq.symm\n    have hx3cop : Nat.Coprime (x + 3) (x * (x + 3)) := by\n      exact Nat.coprime_mul_right_right (Nat.coprime_self (x + 3))\n    exact Nat.dvd_of_dvd_mul_left_of_coprime this (by\n      simpa [Nat.coprime_comm] using (Nat.coprime_mul_left_right (Nat.coprime_self (x + 3))))\n  have hx_mul : x * (x + 3) ≤ Nat.lcm a 40 := by\n    simpa [h₂]\n  have ha40 : a ∣ x * (x + 3) := by\n    have : a ∣ Nat.lcm a 40 := Nat.dvd_lcm_left a 40\n    simpa [h₂] using this.trans (dvd_refl _)\n  have hx3_dvda : x + 3 ∣ a := by\n    simpa [h₁] using (Nat.gcd_dvd_left a 40)\n  have ha_pos : 0 < a := h₀.2\n  have ha_le8 : a ≤ 8 := by\n    have : a ≤ 8 := by\n      have hmin := h₃ 8 (by decide : 0 < (8:ℕ))\n      have hg : Nat.gcd 8 40 = x + 3 := by\n        have : Nat.gcd 8 40 = 8 := by decide\n        have hx3eq : x + 3 = 8 := by\n          have : x + 3 ∣ 8 := by\n            have : x + 3 ∣ Nat.gcd 8 40 := by\n              simpa [h₁] using (Nat.gcd_dvd_left a 40)\n            simpa [this] using this\n          have hx3le8 : x + 3 ≤ 8 := Nat.le_of_dvd (by decide : 0 < (8:ℕ)) this\n          have : x + 3 = 8 := by\n            have : x + 3 = Nat.g