import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_126 (x a : ℕ) (h₀ : 0 < x ∧ 0 < a) (h₁ : Nat.gcd a 40 = x + 3)
  (h₂ : Nat.lcm a 40 = x * (x + 3))
  (h₃ : ∀ b : ℕ, 0 < b → Nat.gcd b 40 = x + 3 ∧ Nat.lcm b 40 = x * (x + 3) → a ≤ b) : a = 8 := by
  have ha : a ∣ 40 := by
    have h := Nat.gcd_mul_lcm a 40
    -- gcd * lcm = a * 40
    -- so lcm divides a*40; but also lcm is multiple of a; use formula to get a ∣ 40
    have h' : a ∣ Nat.gcd a 40 * Nat.lcm a 40 := by
      exact ⟨40, by simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using (h.symm)⟩
    -- since gcd divides a and lcm is multiple of a, their product is multiple of a; thus a ∣ a*40, hence a ∣ 40
    -- use known lemma: gcd_mul_lcm gives (gcd*lcm) = a*b, hence lcm = a*b/gcd so a ∣ lcm; then gcd*lcm divisible by a implies a ∣ a*40, trivial; convert to a ∣ 40 using Nat.dvd_of_mul_dvd_mul_left
    have : Nat.gcd a 40 * Nat.lcm a 40 = a * 40 := h
    -- from this equality, a ∣ gcd*lcm, hence a ∣ a*40, so a ∣ 40 by cancelling a>0
    have : a ∣ a * 40 := by
      exact ⟨1, by simp⟩
    exact Nat.dvd_of_mul_dvd_mul_left (Nat.pos_of_ne_zero (Nat.ne_of_gt h₀.2)) this
  -- enumerate divisors of 40 and find the minimal satisfying the equations is 8
  -- brute force via decidable finiteness of divisors of 40
  have : a = 8 := by
    -- use that a is a positive divisor of 40 and satisfies gcd/lcm constraints; check by dec_trivial over all divisors
    have ha0 : 0 < a := h₀.2
    have ha' : a ∈ (Nat.divisors 40) := by
      simpa [Nat.mem_divisors, Nat.pos_of_ne_zero (by decide : (40:ℕ) ≠ 0), Nat.dvd_refl] using
        And.intro ha (Nat.ne_of_gt ha0)
    -- compute by cases on membership in divisors 40
    have hdiv : a = 1 ∨ a = 2 ∨ a = 4 ∨ a = 5 ∨ a = 8 ∨ a = 10 ∨ a = 20 ∨ a = 40 := by
      -- `Nat.divisors 40` is `[1,2,4,5,8,10,20,40]`
      have : a ∈ ({1, 2, 4, 5, 8, 10, 20, 40} : Finset ℕ) := by
        -- rewrite divisors
        simpa [Nat.divisors, Nat.properDivisors, Nat.divisorsAntidiagonal, Nat.antidiagonal,
          Nat.divisorsList, Nat.divisorsListAux] using ha'
      simpa [Finset.mem_insert, Finset.mem_singleton, Finset.mem_cons] using this
    -- eliminate all but 8 using h₁,h₂ and minimality
    rcases hdiv with rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl <;>
      simp at h₁ h₂
  exact this
