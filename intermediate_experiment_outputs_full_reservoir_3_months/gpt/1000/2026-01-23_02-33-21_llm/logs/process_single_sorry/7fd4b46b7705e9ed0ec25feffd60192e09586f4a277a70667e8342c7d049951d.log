using this\n        exact Nat.mul_right_cancel (by decide : 0 < 40) this\n      have : Nat.gcd a 40 = 1 := by simpa [ha', Nat.gcd_comm] using (by decide : Nat.gcd 17 40 = 1)\n      exact (by\n        have := congrArg (fun t => t) h₁\n        simp [h10] at this\n        exact (by\n          have : (x + 3) = 1 := by simpa [h10] using (Eq.trans (Eq.symm this) this)\n          linarith))\n    · have : x = 17 := by\n        have : x + 3 = 20 := h20\n        linarith\n      have : a * 40 = 6800 := by simpa [h20, this] using hmul\n      have ha' : a = 170 := by\n        have : a * 40 = 170 * 40 := by simpa using this\n        exact Nat.mul_right_cancel (by decide : 0 < 40) this\n      have : Nat.gcd a 40 = 10 := by simpa [ha', Nat.gcd_comm] using (by decide : Nat.gcd 170 40 = 10)\n      have : x + 3 = 10 := by simpa [h₁] using this\n      linarith\n    · have : x = 37 := by\n        have : x + 3 = 40 := h40\n        linarith\n      have : a * 40 = 59200 := by simpa [h40, this] using hmul\n      have ha' : a = 1480 := by\n        have : a * 40 = 1480 * 40 := by simpa using this\n        exact Nat.mul_right_cancel (by decide : 0 < 40) this\n      have : Nat.gcd a 40 = 40 := by simpa [ha', Nat.gcd_comm] using (by decide : Nat.gcd 1480 40 = 40)\n      have : x + 3 = 40 := by simpa [h₁] using this\n      -- then lcm(a,40)=a but h₂ gives 37*40=1480; so a=1480 and minimality fails vs b=40\n      have hb : Nat.gcd 40 40 = x + 3 ∧ Nat.lcm 40 40 = x * (x + 3) := by\n        constructor\n        · simpa [Nat.gcd_self, this] using rfl\n        · simp [Nat.lcm_self, this, h40, this] at *\n      have := h₃ 40 (by decide : 0 < 40) hb\n      have : ¬ (a ≤ 40) := by simpa [ha'] using (by decide : ¬ (1480 ≤ 40))\n      exact (this this).elim\n  have hx : x = 5 := by\n    linarith [hx3_eq8]\n  have ha8 : Nat.gcd a 40 = 8 := by simpa [hx3_eq8] using h₁\n  have hl8 : Nat.lcm a 40 = 40 := by simpa [hx, hx3_eq8] using h₂\n  -- from gcd=8 and lcm=40 with 40, deduce a=8\n  have hmul' : Nat.gcd a 4