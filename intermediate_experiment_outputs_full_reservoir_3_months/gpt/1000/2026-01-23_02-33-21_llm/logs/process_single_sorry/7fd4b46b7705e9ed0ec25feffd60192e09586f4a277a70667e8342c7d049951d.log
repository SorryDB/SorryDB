      "\n  have hxpos : 0 < x := h₀.1\n  have hapos : 0 < a := h₀.2\n  have hgpos : 0 < x + 3 := by exact Nat.succ_pos _\n  have hgl : (Nat.gcd a 40) * (Nat.lcm a 40) = a * 40 := by\n    simpa [Nat.gcd_mul_lcm] using (Nat.gcd_mul_lcm a 40)\n  have h40 : (x + 3) * (x * (x + 3)) = a * 40 := by\n    simpa [h₁, h₂] using hgl\n  have hx3dvd40 : x + 3 ∣ 40 := by\n    have : Nat.gcd a 40 ∣ 40 := Nat.gcd_dvd_right a 40\n    simpa [h₁] using this\n  have hx3dvdx : x + 3 ∣ x := by\n    have : Nat.gcd a 40 ∣ a := Nat.gcd_dvd_left a 40\n    have hax : x + 3 ∣ a := by simpa [h₁] using this\n    have : a ∣ Nat.lcm a 40 := Nat.dvd_lcm_left a 40\n    have : x + 3 ∣ Nat.lcm a 40 := dvd_trans hax this\n    have : x + 3 ∣ x * (x + 3) := by simpa [h₂] using this\n    exact (Nat.dvd_of_dvd_mul_right hgpos this)\n  have hx3_le_x : x + 3 ≤ x := Nat.le_of_dvd hxpos hx3dvdx\n  have hcontra : ¬ (x + 3 ≤ x) := Nat.not_succ_le_self x\n  have : False := hcontra hx3_le_x\n  exact False.elim this",
      "\n  have hxpos : 0 < x := h₀.1\n  have hapos : 0 < a := h₀.2\n  have hprod : a * 40 = (x + 3) * (x * (x + 3)) := by\n    simpa [Nat.gcd_mul_lcm] using congrArg (fun n => n) (by\n      simpa [h₁, h₂] using (Nat.gcd_mul_lcm a 40))\n  have hx3pos : 0 < x + 3 := by exact Nat.succ_pos _\n  have hx3ne : x + 3 ≠ 0 := by exact Nat.ne_of_gt hx3pos\n  have hx3dvd40 : x + 3 ∣ 40 := by\n    have : x + 3 ∣ Nat.gcd a 40 := by\n      exact Nat.gcd_dvd_right a 40 |> (fun h => dvd_trans ?_ h)\n    · simpa [h₁]\n    · exact dvd_rfl\n  have hx3le40 : x + 3 ≤ 40 := Nat.le_of_dvd (by decide : 0 < 40) hx3dvd40\n  have hxle37 : x ≤ 37 := by linarith\n  have hxlt40 : x < 40 := by\n    have : x ≤ 39 := le_trans hxle37 (by decide : 37 ≤ 39)\n    exact lt_of_le_of_lt this (by decide : 39 < 40)\n  have hkey : a = x * (x + 3) := by\n    have h40dvd : 40 ∣ x * (x + 3) := by\n      refine (Nat.dvd_mul_iff_dvd_div ?_).1 ?_\n      · exact hx3dvd40\n      · simpa [h₂] using (Nat.dvd_lcm_right a 40)\n    have : a = (x + 3) * x := by\n      have ha : a = (Nat.gcd a 40) * (Nat.lcm a 40) / 40 := by\n        have := Nat.gcd_mul_lcm a 40\n        have h40pos : 0 < 40 := by decide\n        have h40ne : 40 ≠ 0 := Nat.ne_of_gt h40pos\n        have hdiv : (Nat.gcd a 40) * (Nat.lcm a 40) / 40 = a := by\n          exact Nat.mul_div_cancel_left a h40ne\n        simpa [this] using (Eq.trans (by rfl) (Eq.symm hdiv))\n      have : a = ((x + 3) * (x * (x + 3))) / 40 := by simpa [h₁, h₂] using ha\n      have : a = (x * (x + 3)) := by\n        have h40pos : 0 < 40 := by decide\n        have h40ne : 40 ≠ 0 := Nat.ne_of_gt h40pos\n        have : ((x + 3) * (x * (x + 3))) / 40 = x * (x + 3) := by\n          have h : (x + 3) * (x * (x + 3)) = (x * (x + 3)) * (x + 3) := by\n            ring\n          -- use the equality from gcd*lcm = a*40\n          have hEq : (x + 3) * (x * (x + 3)) = a * 40 := by\n            simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc, h₁, h₂] using (Nat.gcd_mul_lcm a 40).symm\n      