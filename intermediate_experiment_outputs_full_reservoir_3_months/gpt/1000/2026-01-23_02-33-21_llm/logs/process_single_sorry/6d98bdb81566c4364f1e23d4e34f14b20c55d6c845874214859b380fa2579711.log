          E(G ↾ (M ∆ M'), v) ⊆ (M ∆ M') ∩ E(G, v) := by
        rintro e ⟨w, hw⟩
        refine ⟨?_, ?_⟩
        · exact hw.1
        · exact ⟨w, hw.2⟩
      refine (encard_le_encard hsub).trans ?_
      have hsub' :
          (M ∆ M') ∩ E(G, v) ⊆ (M ∩ E(G, v)) ∪ (M' ∩ E(G, v)) := by
        rintro e ⟨he, hev⟩
        rcases he with ⟨he | he, hne⟩
        · exact Or.inl ⟨he, hev⟩
        · exact Or.inr ⟨he, hev⟩
      have henc :
          ((M ∆ M') ∩ E(G, v)).encard ≤ ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard :=
        encard_le_encard hsub'
      refine henc.trans ?_
      have hMle : (M ∩ E(G, v)).encard ≤ 1 := hM.degree_le_one v
      have hM'le : (M' ∩ E(G, v)).encard ≤ 1 := hM'.degree_le_one v
      have hsum :
          ((M ∩ E(G, v)) ∪ (M' ∩ E(G, v))).encard ≤ 2 := by
        simpa [two_mul, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using
          (encard_union_le (M ∩ E(G, v)) (M' ∩ E(G, v))).trans
            (add_le_add hMle hM'le)
      exact hsum
    rw [maxDegreeLE_iff']
    intro v hv
    rw [eDegree_eq_encard_inc]
    simpa using this v
  simpa [IsMatching.restrict₂] using hle.loopRemove
