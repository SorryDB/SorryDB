lemma wignerMatrixEntryFunctionSymmetric (ω : WignerSpace n) {i : Fin n} {j : Fin n} :
  wignerMatrixEntryFunction ω i j = wignerMatrixEntryFunction ω j i := by
  rw[wignerMatrixEntryFunction, wignerMatrixEntryFunction]
  by_cases h : i = j
  · subst h
    simp
  · have h' : j ≠ i := by simpa [eq_comm] using h
    by_cases hij : i < j
    · have hji : ¬ j < i := by exact not_lt_of_lt hij
      simp [h, h', hij, hji]
    · have hji : j < i := by
        have : i ≤ j := le_of_not_gt hij
        have : j < i := lt_of_le_of_ne this (Ne.symm h)
        exact this
      have hij' : ¬ i < j := hij
      simp [h, h', hij', hji]
```
