      "\n  constructor\n  · intro h p hp\n    classical\n    rcases h with ⟨f, hf⟩\n    have hf' : f.IsPseudoIsomorphism := hf\n    have hbij :\n        Function.Bijective\n          (LocalizedModule.map\n            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f := by\n      exact (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N)\n        hMT hNT f).1 hf'\n    let sigma :=\n      (Module.support A M ∪ Module.support A N) ∩ {q : PrimeSpectrum A | q.1.primeHeight = 1}\n    let S := ⨅ q ∈ sigma, q.1.primeCompl\n    have hbijS : Function.Bijective (LocalizedModule.map S f) := by\n      simpa [sigma, S] using hbij\n    haveI : IsLocalization S (Localization S) := by infer_instance\n    have hSp : S ≤ p.1.primeCompl := by\n      intro a haS\n      have : a ∉ ⋃ q ∈ sigma, (q.1 : Set A) := by\n        have : a ∈ (S : Set A) := haS\n        simp [S, Submonoid.mem_iInf, Ideal.primeCompl, Set.mem_iUnion] at this\n      have hps : p ∈ sigma := by\n        refine Set.mem_inter ?_ ?_\n        · by_cases hm : p ∈ Module.support A M ∪ Module.support A N\n          · exact hm\n          · have : p ∉ Module.support A M ∧ p ∉ Module.support A N := by\n              simpa [Set.mem_union] using hm\n            exfalso\n            have htorsM : Subsingleton (LocalizedModule p.1.primeCompl M) := by\n              have := (Module.notMem_support_iff (A := A) (M := M) (p := p)).1 this.1\n              simpa [LocalizedModule.subsingleton_iff] using this\n            have htorsN : Subsingleton (LocalizedModule p.1.primeCompl N) := by\n              have := (Module.notMem_support_iff (A := A) (M := N) (p := p)).1 this.2\n              simpa [LocalizedModule.subsingleton_iff] using this\n            have : M ∼ₚᵢₛ[A] N := ⟨f, hf⟩\n            have : Subsingleton (LocalizedModule p.1.primeCompl M) ∧\n                Subsingleton (LocalizedModule p.1.primeCompl N) := ⟨htorsM, htorsN⟩\n            exact False.elim (by\n              have := this.1\n              trivial)\n        · simpa [Set.mem_setOf_eq] using hp\n    have :\n        IsLocalization p.1.primeCompl (Localization p.1.primeCompl) := by infer_instance\n    let e :=\n      IsLocalization.algEquivOfLe (M := S) (T := p.1.primeCompl) hSp\n    let gM :\n        LocalizedModule p.1.primeCompl M ≃ₗ[Localization p.1.primeCompl]\n          LocalizedModule S M :=\n      (LocalizedModule.congr (S := S) (T := p.1.primeCompl) hSp).symm\n    let gN :\n        LocalizedModule p.1.primeCompl N ≃ₗ[Localization p.1.primeCompl]\n          LocalizedModule S N :=\n      (LocalizedModule.congr (S := S) (T := p.1.primeCompl) hSp).symm\n    have hbijp : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      -- map to p factors through S via localization comparison\n      have :\n          (LocalizedModule.map p.1.primeCompl f) =\n            (gN.symm.toLinearMap.comp\n              ((LocalizedModule.map S f).restrictScalars (Localization p.1.primeCompl))).comp\n                gM.toLinearMap := by\n        ext x\n        simp [gM, gN]\n      -- bijective from bijective in S\n      have hbijS' : Function.Bijective\n          ((LocalizedModule.map S f).restrictScalars (Localization p.1.primeCompl)) := by\n        simpa using hbijS\n      have hgM : Function.Bijective gM.toLinearMap := by\n        refine ⟨gM.injective, gM.surjective⟩\n      have hgN : Function.Bijective gN.toLinearMap := by\n        refine ⟨gN.injective, gN.surjective⟩\n      -- combine\n      have : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n        simpa [this] using (hgN.comp (hbijS'.comp hgM))\n      exact this\n    refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hbijp⟩\n  · intro h\n    classical\n    -- reduce to pseudo-isomorphism via bijectivity after localizing at suitable S\n    rcases Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT with\n      ⟨ιM, _, pM, hpM, eM, heM, hM⟩\n    rcases Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT with\n      ⟨ιN, _, pN, hpN, eN, heN, hN⟩\n    -- use local criteria: isomorphic at all height one primes implies pseudo-isomorphic\n    -- between the two decompositions, hence between M and N\n    refine (PseudoIsomorphic.trans (A := A) hM ?_).trans (PseudoIsomorphic.symm hN)\n    -- show the two products are pseudo-isomorphic by checking localizations at height one primes\n    refine (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule\n      (A := A)\n      (M := (fun i : ιM => A ⧸ (pM i).1 ^ (eM i)))\n      (N := (fun i : ιN => A ⧸ (pN i).1 ^ (eN i)))\n      (hMT := by\n        classical\n        -- torsion for finite product of torsion modules\n        intro x\n        classical\n        refine ⟨⟨1, by simp⟩, by simp⟩\n      )\n      (hNT := by\n        classical\n        intro x\n        classical\n        refine ⟨⟨1, by simp⟩, by simp⟩\n      )).2 ?_\n    intro p hp\n    -- choose the given local equivalence between M and N and transport through pseudo-isos\n    have hMp : Nonempty\n        (LocalizedModule p.1.primeCompl M ≃ₗ[Localization p.1.primeCompl]\n          LocalizedModule p.1.primeCompl N) := h p hp\n    rcases hMp with ⟨e⟩\n    -- transport along pseudo-isomorphisms hM and hN\n    refine ⟨(PseudoIsomorphic.localizedLinearEquiv (A := A) (S := p.1.primeCompl) hM).trans\n      (e.trans (PseudoIsomorphic.localizedLinearEquiv (A := A) (S := p.1.primeCompl) hN).symm)⟩",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have hk : Subsingleton (LocalizedModule p.1.primeCompl (LinearMap.ker f)) := by\n        have : Module.IsPseudoNull A (LinearMap.ker f) := by\n          simpa [LinearMap.IsPseudoIsomorphism] using hf.1\n        exact (Module.isPseudoNull_iff_subsingleton_localizedModule_primeHeight_eq_one\n          (X := LinearMap.ker f) hp).1 this\n      have hc : Subsingleton (LocalizedModule p.1.primeCompl (N ⧸ LinearMap.range f)) := by\n        have : Module.IsPseudoNull A (N ⧸ LinearMap.range f) := by\n          simpa [LinearMap.IsPseudoIsomorphism] using hf.2\n        exact (Module.isPseudoNull_iff_subsingleton_localizedModule_primeHeight_eq_one\n          (X := N ⧸ LinearMap.range f) hp).1 this\n      have hk' : ker (LocalizedModule.map p.1.primeCompl f) = ⊥ := by\n        rwa [← Submodule.subsingleton_iff_eq_bot] at hk\n      have hr' :\n          range (LocalizedModule.map p.1.primeCompl f) = ⊤ := by\n        have : Subsingleton (LocalizedModule p.1.primeCompl N ⧸\n            range (LocalizedModule.map p.1.primeCompl f)) := by\n          simpa [LocalizedModule.quotient_map_eq] using hc\n        rwa [← Submodule.Quotient.subsingleton_iff, range_eq_top] at this\n      refine ⟨?_, ?_⟩\n      · simpa [LinearMap.ker_eq_bot] using congrArg (fun K => (K = ⊥)) hk'\n      · simpa [LinearMap.range_eq_top] using congrArg (fun R => (R = ⊤)) hr'\n    exact ⟨LinearEquiv.ofBijective _ hf'⟩\n  · intro h\n    have :=\n      (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT)\n    have :=\n      (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT)\n    classical\n    rcases this with ⟨ιM, hιM, pM, hpM, eM, heM, hM⟩\n    rcases that with ⟨ιN, hιN, pN, hpN, eN, heN, hN⟩\n    refine (hM.trans ?_).trans hN.symm\n    have hloc :\n        ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →\n          Nonempty\n            (LocalizedModule p.1.primeCompl ((i : ιM) → A ⧸ (pM i).1 ^ (eM i)) ≃ₗ[Localization p.1.primeCompl]\n              LocalizedModule p.1.primeCompl ((i : ιN) → A ⧸ (pN i).1 ^ (eN i))) := by\n      intro p hp\n      have hm := h p hp\n      rcases hm with ⟨eMN⟩\n      have e1 :\n          (LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n            (LocalizedModule p.1.primeCompl ((i : ιM) → A ⧸ (pM i).1 ^ (eM i))) := by\n        rcases (hM.localizedModule_linearEquiv (p := p) hp) with ⟨e⟩\n        exact e.symm\n      have e2 :\n          (LocalizedModule p.1.primeCompl N) ≃ₗ[Localization p.1.primeCompl]\n            (LocalizedModule p.1.primeCompl ((i : ιN) → A ⧸ (pN i).1 ^ (eN i))) := by\n        rcases (hN.localizedModule_linearEquiv (p := p) hp) with ⟨e⟩\n        exact e.symm\n      exact ⟨e1.symm.trans (eMN.trans e2)⟩\n    exact (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule\n      (A := A) (M := ((i : ιM) → A ⧸ (pM i).1 ^ (eM i)))\n      (N := ((i : ιN) → A ⧸ (pN i).1 ^ (eN i)))\n      (by\n        intro x\n        classical\n        rcases (hM.1 x) with ⟨a, ha⟩\n        refine ⟨a, ?_⟩\n        simpa using ha)\n      (by\n        intro x\n        classical\n        rcases (hN.1 x) with ⟨a, ha⟩\n        refine ⟨a, ?_⟩\n        simpa using ha)).2 hloc",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' : f.IsPseudoIsomorphism := hf\n    have hbij := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) hMT (N := N)\n      hNT f).1 hf'\n    have hinjS : Function.Injective (LocalizedModule.map\n        (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n          {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := hbij.1\n    have hsurjS : Function.Surjective (LocalizedModule.map\n        (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n          {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := hbij.2\n    have : Nonempty ((LocalizedModule\n          (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n            {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) M) ≃ₗ[Localization\n          (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n            {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl)]\n          (LocalizedModule\n            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) N)) := by\n      classical\n      exact ⟨LinearEquiv.ofBijective _ ⟨hinjS, hsurjS⟩⟩\n    classical\n    -- localize further at `p`\n    refine (this.map ?_).mono ?_\n    · exact IsLocalization.Away.mapLinearEquiv\n        (S := ⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n          {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl)\n        (T := p.1.primeCompl)\n    · intro e\n      exact ⟨e⟩\n  · intro h\n    classical\n    -- use the characterization via localization away from the union of height one primes in the supports\n    set sigma := (Module.support A M ∪ Module.support A N) ∩\n      {p : PrimeSpectrum A | p.1.primeHeight = 1} with hsigma\n    set S := ⨅ p ∈ sigma, p.1.primeCompl with hS\n    -- build an isomorphism on `S`-localizations by patching the isomorphisms at height one primes;\n    -- here we use the structure theorem on both sides to reduce to the PID case.\n    rcases (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT) with\n      ⟨ι, _inst, pM, hpM, eM, heM, hM⟩\n    rcases (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT) with\n      ⟨κ, _inst', pN, hpN, eN, heN, hN⟩\n    -- conclude by transitivity\n    refine (Module.IsPseudoIsomorphic.trans ?_ ?_)\n    · exact hM\n    · exact (Module.IsPseudoIsomorphic.symm hN)",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hb :\n        Function.Bijective (LocalizedModule.map (p.1.primeCompl) f) := by\n      have := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N)\n        hMT hNT f).1 hf\n      simpa [Function.Bijective] using this.1 p (by simpa [hp]) \n    refine ⟨?_⟩\n    classical\n    refine LinearEquiv.ofBijective (LocalizedModule.map (p.1.primeCompl) f) hb\n  · intro h\n    classical\n    rcases Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT with\n      ⟨ι, instι, pM, hpM, eM, heM, hM⟩\n    rcases Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT with\n      ⟨κ, instκ, pN, hpN, eN, heN, hN⟩\n    refine (hM.trans ?_).trans hN.symm\n    have :\n        ∀ (q : PrimeSpectrum A), q.1.primeHeight = 1 →\n          Nonempty\n            ((LocalizedModule q.1.primeCompl ((i : ι) → A ⧸ (pM i).1 ^ (eM i)))\n              ≃ₗ[Localization q.1.primeCompl]\n              (LocalizedModule q.1.primeCompl ((j : κ) → A ⧸ (pN j).1 ^ (eN j)))) := by\n      intro q hq\n      have hq' := h q hq\n      have hMloc := (Module.IsPseudoIsomorphic.localizedModule (S := q.1.primeCompl) hM).symm\n      have hNloc := Module.IsPseudoIsomorphic.localizedModule (S := q.1.primeCompl) hN\n      rcases hMloc with ⟨fM, hfM⟩\n      rcases hq' with ⟨e⟩\n      rcases hNloc with ⟨fN, hfN⟩\n      refine ⟨(LinearEquiv.ofBijective (LocalizedModule.map (q.1.primeCompl) fM)\n        ((LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A)\n          (M := (i : ι) → A ⧸ (pM i).1 ^ (eM i)) (N := M)\n          (by\n            classical\n            intro x\n            rcases x with ⟨i, x⟩\n            rcases (Module.isTorsion_quotient_of_isTorsion (A := A) (M := A)\n              (I := (pM i).1 ^ (eM i)) (by\n                intro a\n                refine ⟨a, ?_⟩\n                simp)).1 x with ⟨r, hr⟩\n            exact ⟨r, by simpa using hr⟩)\n          hMT (LocalizedModule.map (q.1.primeCompl) fM))).1 hfM)).symm.trans\n        (e.trans (LinearEquiv.ofBijective (LocalizedModule.map (q.1.primeCompl) fN)\n          ((LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A)\n            (M := N) (N := (j : κ) → A ⧸ (pN j).1 ^ (eN j))\n            hNT\n            (by\n              classical\n              intro x\n              rcases x with ⟨j, x⟩\n              rcases (Module.isTorsion_quotient_of_isTorsion (A := A) (M := A)\n                (I := (pN j).1 ^ (eN j)) (by\n                  intro a\n                  refine ⟨a, ?_⟩\n                  simp)).1 x with ⟨r, hr⟩\n              exact ⟨r, by simpa using hr⟩)\n            (LocalizedModule.map (q.1.primeCompl) fN))).1 hfN)))⟩\n    classical\n    refine ⟨0, ?_⟩\n    simpa using (Subsingleton.elim (α := Unit) () ())",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' :\n        Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have hfbij := (LinearMap.isPseudoIsomorphism_iff_bijective_map\n        (A := A) (M := M) (N := N) hMT hNT f).1 hf\n      have hsub :\n          p.1.primeCompl ≤\n            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) := by\n        refine le_iInf_of_le p ?_\n        refine le_iInf_of_le ?_ ?_\n        · exact ⟨by\n            have : p ∈ {q : PrimeSpectrum A | q.1.primeHeight = 1} := by simpa [hp]\n            exact Or.inr this, this⟩\n        · exact le_rfl\n      have hcomp :\n          LocalizedModule.map p.1.primeCompl f =\n            (LocalizedModule.map hsub)\n              (LocalizedModule.map\n                (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n                  {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := by\n        ext m\n        rfl\n      simpa [hcomp] using (Function.Bijective.comp\n        (LocalizedModule.map hsub) (LocalizedModule.map\n          (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n            {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f)\n        (LocalizedModule.map_bijective_of_le _ _ hsub) hfbij)\n    refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hf'⟩\n  · intro h\n    classical\n    rcases (hMT.isPseudoIsomorphic_pi (A := A)) with ⟨ι, _, pM, hpM, eM, heM, hM⟩\n    rcases (hNT.isPseudoIsomorphic_pi (A := A)) with ⟨κ, _, pN, hpN, eN, heN, hN⟩\n    have : ((i : ι) → A ⧸ (pM i).1 ^ (eM i)) ∼ₚᵢₛ[A] ((j : κ) → A ⧸ (pN j).1 ^ (eN j)) := by\n      refine (Module.PseudoIsomorphic.trans (β := M) ?_ (Module.PseudoIsomorphic.trans (β := N) ?_ ?_))\n      · exact hM.symm\n      · exact hN\n      ·\n        classical\n        refine Module.PseudoIsomorphic.of_isomorphism ?_\n        classical\n        have hloc :\n            ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →\n              Nonempty\n                (LocalizedModule p.1.primeCompl ((i : ι) → A ⧸ (pM i).1 ^ (eM i)) ≃ₗ[Localization p.1.primeCompl]\n                  LocalizedModule p.1.primeCompl ((j : κ) → A ⧸ (pN j).1 ^ (eN j))) := by\n          intro p hp\n          have hm : Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n              (LocalizedModule p.1.primeCompl N)) := h p hp\n          rcases hm with ⟨e⟩\n          have eM' : Nonempty ((LocalizedModule p.1.primeCompl ((i : ι) → A ⧸ (pM i).1 ^ (eM i))) ≃ₗ[Localization p.1.primeCompl]\n              (LocalizedModule p.1.primeCompl M)) := by\n            rcases (Module.PseudoIsomorphic.localizedModule_linearEquiv_of_pseudoIsomorphic\n              (S := p.1.primeCompl) hM) with ⟨e'⟩\n            exact ⟨e'⟩\n          have eN' : Nonempty ((LocalizedModule p.1.primeCompl N) ≃ₗ[Localization p.1.primeCompl]\n              (LocalizedModule p.1.primeCompl ((j : κ) → A ⧸ (pN j).1 ^ (eN j)))) := by\n            rcases (Module.PseudoIsomorphic.localizedModule_linearEquiv_of_pseudoIsomorphic\n              (S := p.1.primeCompl) hN.symm) with ⟨e'⟩\n            exact ⟨e'⟩\n          rcases eM' with ⟨eM'⟩\n          rcases eN' with ⟨eN'⟩\n          exact ⟨(eM'.trans e).trans eN'⟩\n        classical\n        choose e' he' using fun p hp => hloc p hp\n        haveI : Subsingleton ((i : ι) → A ⧸ (pM i).1 ^ (eM i)) := by\n          classical\n          exact subsingleton_of_forall_eq (fun x y => by\n            classical\n            have := (he' ⟨⊥, Ideal.bot_prime⟩ (by simpa)).1\n            simpa using congrArg (fun z => z x) (Subsingleton.elim x y))\n        exact ⟨LinearEquiv.refl _⟩\n    exact Module.PseudoIsomorphic.trans hM (Module.PseudoIsomorphic.trans this hN.symm)",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have : f.IsPseudoIsomorphism := hf\n      have hbij := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N)\n        hMT hNT f).1 this\n      refine (hbij.1.comp ?_, hbij.2.comp ?_)\n      all_goals\n        refine LocalizedModule.map_injective ?_ ?_ ?_\n        exact Submonoid.le_compl_iff_disjoint_left.2 (by\n          simpa [Set.disjoint_left] using fun x hx ↦ hx.elim)\n    exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hf'⟩\n  · intro h\n    classical\n    obtain ⟨ι, _, p, hp, e, he, hM⟩ := Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT\n    obtain ⟨κ, _, q, hq, d, hd, hN⟩ := Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT\n    have hMNloc :\n        ∀ r : PrimeSpectrum A, r.1.primeHeight = 1 →\n          Nonempty ((LocalizedModule r.1.primeCompl ((i : ι) → A ⧸ (p i).1 ^ (e i)))\n            ≃ₗ[Localization r.1.primeCompl]\n            LocalizedModule r.1.primeCompl ((j : κ) → A ⧸ (q j).1 ^ (d j))) := by\n      intro r hr\n      rcases (h r hr) with ⟨eMN⟩\n      have eM :\n          Nonempty ((LocalizedModule r.1.primeCompl M) ≃ₗ[Localization r.1.primeCompl]\n            LocalizedModule r.1.primeCompl ((i : ι) → A ⧸ (p i).1 ^ (e i))) := by\n        rcases hM with ⟨f, hf⟩\n        have hfbij : Function.Bijective (LocalizedModule.map r.1.primeCompl f) := by\n          have hbij := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M)\n            (N := ((i : ι) → A ⧸ (p i).1 ^ (e i))) hMT\n            (by\n              have : Module.IsTorsion A ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by\n                classical\n                intro x\n                classical\n                rcases Classical.decEq ι with _ | _\n                · classical\n                  refine ⟨⟨1, by simp⟩, by simp⟩\n                · classical\n                  refine ⟨⟨1, by simp⟩, by simp⟩) f).1 hf\n          exact hbij\n        exact ⟨LinearEquiv.ofBijective (LocalizedModule.map r.1.primeCompl f) hfbij⟩\n      have eN :\n          Nonempty ((LocalizedModule r.1.primeCompl N) ≃ₗ[Localization r.1.primeCompl]\n            LocalizedModule r.1.primeCompl ((j : κ) → A ⧸ (q j).1 ^ (d j))) := by\n        rcases hN with ⟨g, hg⟩\n        have hgbij : Function.Bijective (LocalizedModule.map r.1.primeCompl g) := by\n          have hbij := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := N)\n            (N := ((j : κ) → A ⧸ (q j).1 ^ (d j))) hNT\n            (by\n              have : Module.IsTorsion A ((j : κ) → A ⧸ (q j).1 ^ (d j)) := by\n                classical\n                intro x\n                classical\n                rcases Classical.decEq κ with _ | _\n                · classical\n                  refine ⟨⟨1, by simp⟩, by simp⟩\n                · classical\n                  refine ⟨⟨1, by simp⟩, by simp⟩) g).1 hg\n          exact hbij\n        exact ⟨LinearEquiv.ofBijective (LocalizedModule.map r.1.primeCompl g) hgbij⟩\n      rcases eM with ⟨eM⟩\n      rcases eN with ⟨eN⟩\n      exact ⟨(eM.symm.trans eMN).trans eN⟩\n    have : ((i : ι) → A ⧸ (p i).1 ^ (e i)) ∼ₚᵢₛ[A] ((j : κ) → A ⧸ (q j).1 ^ (d j)) := by\n      classical\n      -- apply the localization criterion with the obvious map given by choices\n      classical\n      choose φ hφ using fun r hr ↦ hMNloc r hr\n      let f :\n          ((i : ι) → A ⧸ (p i).1 ^ (e i)) →ₗ[A] ((j : κ) → A ⧸ (q j).1 ^ (d j)) :=\n        0\n      refine ⟨f, ?_⟩\n      -- zero map is a pseudo-isomorphism since both sides are pseudo-null after inverting height-one primes\n      rw [LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A)\n        (M := ((i : ι) → A ⧸ (p i).1 ^ (e i)))\n        (N := ((j : κ) → A ⧸ (q j).1 ^ (d j)))\n        (by\n          classical\n          intro x\n          refine ⟨⟨1, by simp⟩, by simp⟩)\n        (by\n          classical\n          intro x\n          refine ⟨⟨1, by simp⟩, by simp⟩) f]\n      -- bijectivity follows since each height-one localization is isomorphic, hence the localized modules are subsingleton\n      refine ⟨?_, ?_⟩\n      · intro x y hxy\n        simpa using congrArg (fun z ↦ z) hxy\n      · intro y\n        refine ⟨0, by simp⟩\n    exact (hM.trans (this.trans hN.symm))",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' : f.IsPseudoIsomorphism := by simpa using hf\n    have hbij :\n        Function.Bijective\n          (LocalizedModule.map\n            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f := by\n      (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) hMT (N := N) hNT f).1 hf'\n    have : Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n        (LocalizedModule p.1.primeCompl N)) := by\n      classical\n      haveI : IsLocalization\n          (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n            {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl)\n          (Localization (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n            {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl)) := by\n        infer_instance\n      -- Use the localized bijectivity at the cofinite height-one set, then restrict further to `p`.\n      -- This is standard: localizing further preserves bijectivity, yielding an isomorphism.\n      haveI := (Module.Free.linearEquiv_of_bijective\n        (LocalizedModule.map\n          (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n            {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) hbij).nonempty\n      simpa using (inferInstance : Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n        (LocalizedModule p.1.primeCompl N)))\n    exact this\n  · intro h\n    classical\n    -- pseudo-isomorphism is local at height one primes for torsion modules\n    refine ⟨0, ?_⟩\n    simpa [LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) hMT (N := N) hNT (0 : M →ₗ[A] N)] using\n      (by\n        have : Function.Bijective\n            (LocalizedModule.map\n              (⨅ p ∈ (Module.support A M ∪ Module.support A N) ∩\n                {p : PrimeSpectrum A | p.1.primeHeight = 1}, p.1.primeCompl)\n              (0 : M →ₗ[A] N)) := by\n          constructor <;> intro x <;> simp\n        exact this)",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hb :\n        Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have hiff :=\n        (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) hMT (N := N) hNT f).1 hf\n      refine (LocalizedModule.map_bijective_iff ?_).1 hiff\n      intro x hx\n      simp only [Set.mem_inter_iff, Set.mem_iUnion, exists_prop, Set.mem_setOf_eq,\n        Set.mem_union, Module.mem_support_iff_of_finite, Submodule.mem_annihilator, not_and_or,\n        not_exists, not_or] at hx ⊢\n      have hx' : ¬p ∈ (Module.support A M ∪ Module.support A N) ∩\n          {p : PrimeSpectrum A | p.1.primeHeight = 1} := by\n        intro hmem\n        exact (hx.1 (by\n          refine ⟨?_, ?_⟩\n          · exact hmem.1\n          · simpa using hmem.2)) (by simpa using hp)\n      exact hx'\n    exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hb⟩\n  · intro h\n    classical\n    have : ∃ f : M →ₗ[A] N, Function.Bijective\n        (LocalizedModule.map\n          (⨅ p ∈ (Module.support A M ∪ Module.support A N) ∩\n            {p : PrimeSpectrum A | p.1.primeHeight = 1}, p.1.primeCompl) f := by\n      classical\n      refine ⟨0, ?_⟩\n      -- if all height-one localizations are isomorphic then the localized map is bijective for some f;\n      -- use `f = 0` and the fact that both localized modules are subsingleton outside support union\n      -- and inside height-one primes by assumption (taking any linear equiv yields subsingleton).\n      -- Hence the localized map is bijective.\n      have hs :\n          ∀ p : PrimeSpectrum A,\n            p.1.primeHeight = 1 →\n              Subsingleton (LocalizedModule p.1.primeCompl M) ∧\n                Subsingleton (LocalizedModule p.1.primeCompl N) := by\n        intro p hp\n        rcases h p hp with ⟨e⟩\n        haveI : Subsingleton (LocalizedModule p.1.primeCompl M) :=\n          ⟨fun x y => by\n            have := congrArg e.toLinearMap x\n            have := congrArg e.toLinearMap y\n            exact e.injective (by simpa using (by rfl : e x = e y))⟩\n        haveI : Subsingleton (LocalizedModule p.1.primeCompl N) :=\n          ⟨fun x y => by\n            exact e.surjective x |>.choose_spec.trans (e.surjective y |>.choose_spec).symm ▸ rfl⟩\n        exact ⟨inferInstance, inferInstance⟩\n      -- now show bijective for `f=0` after localizing at S: both source and target are subsingleton\n      -- by `subsingleton_convert` applied to sigma = support union ∩ height-one\n      set sigma :=\n        (Module.support A M ∪ Module.support A N) ∩\n          {p : PrimeSpectrum A | p.1.primeHeight = 1}\n      set S := ⨅ p ∈ sigma, p.1.primeCompl\n      haveI : Subsingleton (LocalizedModule S M) := by\n        have hsigma : ∀ p ∈ sigma, Subsingleton (LocalizedModule p.1.primeCompl M) := by\n          intro p hp'\n          exact (hs p (by\n            have : p ∈ {p : PrimeSpectrum A | p.1.primeHeight = 1} := (Set.mem_inter_iff.1 hp').2\n            simpa [Set.mem_setOf_eq] using this)).1\n        exact (subsingleton_convert (A := A) (M := M) hMT (N := N) hNT M).2 hsigma\n      haveI : Subsingleton (LocalizedModule S N) := by\n        have hsigma : ∀ p ∈ sigma, Subsingleton (LocalizedModule p.1.primeCompl N) := by\n          intro p hp'\n          exact (hs p (by\n            have : p ∈ {p : PrimeSpectrum A | p.1.primeHeight = 1} := (Set.mem_inter_iff.1 hp').2\n            simpa [Set.mem_setOf_eq] using this)).2\n        exact (subsingleton_convert (A := A) (M := M) hMT (N := N) hNT N).2 hsigma\n      have : Function.Bijective (LocalizedModule.map S (0 : M →ₗ[A] N)) := by\n        refine ⟨?_, ?_⟩\n        · intro x y; simp\n        · intro y; refine ⟨0, ?_⟩; simp\n      simpa [S, sigma] using this\n    rcases this with ⟨f, hf⟩\n    refine ⟨f, ?_⟩\n    exact (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) hMT (N := N) hNT f).2 hf",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      refine ⟨?_, ?_⟩\n      · have hk : Subsingleton ↥(LinearMap.ker (LocalizedModule.map p.1.primeCompl f)) := by\n          have : Subsingleton (LocalizedModule p.1.primeCompl (LinearMap.ker f)) := by\n            have := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton).1 hf.1\n            have := this p (by simpa [hp] using (show p.1.primeHeight ≤ 1 by simpa [hp]))\n            exact this\n          have := (LinearMap.subsingleton_ker_convert f p.1.primeCompl).2 this\n          simpa using this\n        have : LinearMap.ker (LocalizedModule.map p.1.primeCompl f) = ⊥ := by\n          simpa [Submodule.subsingleton_iff_eq_bot] using hk\n        simpa [LinearMap.ker_eq_bot] using this\n      · have hc :\n          Subsingleton (LocalizedModule p.1.primeCompl N ⧸\n            LinearMap.range (LocalizedModule.map p.1.primeCompl f)) := by\n          have : Subsingleton (LocalizedModule p.1.primeCompl (N ⧸ LinearMap.range f)) := by\n            have := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton).1 hf.2\n            have := this p (by simpa [hp] using (show p.1.primeHeight ≤ 1 by simpa [hp]))\n            exact this\n          have := (LinearMap.subsingleton_coker_convert f p.1.primeCompl).2 this\n          simpa using this\n        have : LinearMap.range (LocalizedModule.map p.1.primeCompl f) = ⊤ := by\n          simpa [Submodule.Quotient.subsingleton_iff] using hc\n        simpa [LinearMap.range_eq_top] using this\n    refine ⟨?_⟩\n    exact (LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hf')\n  · intro h\n    classical\n    obtain ⟨ι, _, p, hp, e, hepos, hM⟩ := Module.IsTorsion.isPseudoIsomorphic_pi (A := A) hMT\n    obtain ⟨κ, _, q, hq, d, hdpos, hN⟩ := Module.IsTorsion.isPseudoIsomorphic_pi (A := A) hNT\n    refine (Module.IsPseudoIsomorphic.trans hM (Module.IsPseudoIsomorphic.symm hN)) |>.mono_left ?_\n    clear hM hN\n    have hL :\n        ∀ r : PrimeSpectrum A, r.1.primeHeight = 1 →\n          Nonempty ((LocalizedModule r.1.primeCompl ((i : ι) → A ⧸ (p i).1 ^ (e i)))\n            ≃ₗ[Localization r.1.primeCompl]\n            (LocalizedModule r.1.primeCompl ((j : κ) → A ⧸ (q j).1 ^ (d j)))) := by\n      intro r hr\n      have hMr : Nonempty ((LocalizedModule r.1.primeCompl M) ≃ₗ[Localization r.1.primeCompl]\n          (LocalizedModule r.1.primeCompl N)) := h r hr\n      refine hMr.elim ?_\n      intro E\n      refine ⟨?_⟩\n      exact (LocalizedModule.congr (R := A) (S := r.1.primeCompl) E) \n    refine ?_\n    refine (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule\n      (A := A) (M := ((i : ι) → A ⧸ (p i).1 ^ (e i))) (N := ((j : κ) → A ⧸ (q j).1 ^ (d j)))\n      (by\n        intro x\n        classical\n        rcases x with ⟨i, xi⟩\n        refine (Module.isTorsion_quotient (I := (p i).1 ^ (e i)) ?_ ) ⟨_, ?_⟩\n        · exact Ideal.pow_ne_zero _ (by\n            have : (p i).1 ≠ ⊥ := by\n              intro hbot\n              have : (p i).1.primeHeight = 0 := by\n                simpa [hbot] using (Ideal.primeHeight_bot (α := A))\n              simpa [hp i] using this\n            exact Ideal.ne_bot_iff_one_lt_top.1 (by\n              simpa [Ideal.ne_top_iff_one, this] ))\n        · simp)\n      (by\n        intro x\n        classical\n        rcases x with ⟨j, xj⟩\n        refine (Module.isTorsion_quotient (I := (q j).1 ^ (d j)) ?_ ) ⟨_, ?_⟩\n        · exact Ideal.pow_ne_zero _ (by\n            have : (q j).1 ≠ ⊥ := by\n              intro hbot\n              have : (q j).1.primeHeight = 0 := by\n                simpa [hbot] using (Ideal.primeHeight_bot (α := A))\n              simpa [hq j] using this\n            exact Ideal.ne_bot_iff_one_lt_top.1 (by\n              simpa [Ideal.ne_top_iff_one, this] ))\n        · simp)) |>.2 hL",
      "\n  constructor\n  · rintro ⟨f, hf⟩ p hp\n    have hbij :\n        Function.Bijective\n          (LocalizedModule.map\n            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := by\n      simpa using (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N)\n        hMT hNT f).1 hf\n    classical\n    refine ⟨LinearEquiv.ofBijective _ ?_⟩\n    · exact (by\n        simpa using hbij)\n  · intro h\n    classical\n    rcases (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT) with\n      ⟨ι, hι, pM, hpM, eM, heM, hM⟩\n    rcases (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT) with\n      ⟨κ, hκ, pN, hpN, eN, heN, hN⟩\n    have hMN : ((i : ι) → A ⧸ (pM i).1 ^ (eM i)) ∼ₚᵢₛ[A] ((j : κ) → A ⧸ (pN j).1 ^ (eN j)) := by\n      refine (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule\n        (A := A) (M := ((i : ι) → A ⧸ (pM i).1 ^ (eM i)))\n        (N := ((j : κ) → A ⧸ (pN j).1 ^ (eN j))) ?_ ?_).2 ?_\n      · classical\n        infer_instance\n      · classical\n        infer_instance\n      · intro p hp\n        have := h p hp\n        exact this\n    exact (hM.symm.trans (hMN.trans hN))",
      "\n  constructor\n  · rintro ⟨f, hf⟩ p hp\n    have hbij :\n        Function.Bijective\n          (LocalizedModule.map p.1.primeCompl (f : M →ₗ[A] N)) := by\n      have : (f : M →ₗ[A] N).IsPseudoIsomorphism := hf\n      have h :=\n        (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N) hMT hNT\n              (f : M →ₗ[A] N)).1 this\n      refine (h.comp ?_)\n      intro x y hxy\n      exact congrArg (fun g => g x) (congrArg (fun g => g y) rfl) ▸ hxy\n    classical\n    refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl (f : M →ₗ[A] N)) hbij⟩\n  · intro h\n    classical\n    have hker : Module.IsPseudoNull A (LinearMap.ker (0 : M →ₗ[A] N)) := by\n      simpa using (Module.isPseudoNull_bot (A := A) (M := M))\n    refine ⟨(0 : M →ₗ[A] N), ?_⟩\n    simpa [isPseudoIsomorphism_iff, hker] using (and_true (Module.isPseudoNull_bot (A := A) (M := N)))",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have : f.IsPseudoIsomorphism := hf\n      have hbij :\n          Function.Bijective\n            (LocalizedModule.map\n              (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n                {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) :=\n        (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N) hMT hNT f).1 this\n      have : p ∈ (Module.support A M ∪ Module.support A N) ∩\n          {q : PrimeSpectrum A | q.1.primeHeight = 1} := by\n        refine ⟨?_, hp⟩\n        by_contra hp0\n        have hpM : p ∉ Module.support A M := by\n          have : p ∉ Module.support A M ∪ Module.support A N := by\n            simpa [Set.mem_union] using hp0\n          exact fun hpm => this (Or.inl hpm)\n        have hpN : p ∉ Module.support A N := by\n          have : p ∉ Module.support A M ∪ Module.support A N := by\n            simpa [Set.mem_union] using hp0\n          exact fun hpn => this (Or.inr hpn)\n        have hsubM : Subsingleton (LocalizedModule p.1.primeCompl M) := by\n          rw [← Module.notMem_support_iff]\n          exact hpM\n        have hsubN : Subsingleton (LocalizedModule p.1.primeCompl N) := by\n          rw [← Module.notMem_support_iff]\n          exact hpN\n        have : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n          haveI := hsubM\n          haveI := hsubN\n          constructor <;> intro x y hxy <;> simpa using (Subsingleton.elim x y)\n        exact (False.elim (by\n          have := (this.1 (by simpa) (by simpa) (by simpa)))\n          trivial))\n      -- use the already proved characterization specialized to singleton {p} via sigma-trick\n      -- we can directly apply the isPseudoIsomorphism criterion at p:\n      have : Subsingleton (LocalizedModule p.1.primeCompl (LinearMap.ker f)) ∧\n          Subsingleton (LocalizedModule p.1.primeCompl (N ⧸ LinearMap.range f)) := by\n        have hk :\n            Module.IsPseudoNull A (LinearMap.ker f) ∧ Module.IsPseudoNull A (N ⧸ LinearMap.range f) := by\n          simpa [LinearMap.IsPseudoIsomorphism] using (show f.IsPseudoIsomorphism from hf)\n        constructor\n        · have := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton (A := A)\n              (M := LinearMap.ker f)).1 hk.1 p (by\n                simpa [hp, show (1 : ENat) ≤ 1 by exact le_rfl] )\n          exact this (by\n            have : p.1.primeHeight ≤ 1 := by simpa [hp]\n            exact this)\n        · have := (Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton (A := A)\n              (M := (N ⧸ LinearMap.range f))).1 hk.2 p (by\n                simpa [hp, show (1 : ENat) ≤ 1 by exact le_rfl] )\n          exact this (by\n            have : p.1.primeHeight ≤ 1 := by simpa [hp]\n            exact this)\n      have hinj : Function.Injective (LocalizedModule.map p.1.primeCompl f) := by\n        intro x y hxy\n        have hker : (x - y) ∈ LinearMap.ker (LocalizedModule.map p.1.primeCompl f) := by\n          simpa [LinearMap.mem_ker, map_sub] using congrArg (fun z => z - LocalizedModule.map p.1.primeCompl f y) hxy\n        have hsub :\n            Subsingleton ↥(LinearMap.ker (LocalizedModule.map p.1.primeCompl f)) := by\n          have := (LinearMap.subsingleton_ker_convert (f := f) (S := p.1.primeCompl)).2 this.1\n          simpa using this\n        have : x - y = 0 := by\n          haveI := hsub\n          simpa using (Subsingleton.elim ⟨x - y, hker⟩ 0)\n        simpa using sub_eq_zero.mp this\n      have hsurj : Function.Surjective (LocalizedModule.map p.1.primeCompl f) := by\n        intro y\n        have hcoker :\n            Subsingleton (LocalizedModule p.1.primeCompl (N ⧸ LinearMap.range f)) := this.2\n        have hsub :\n            Subsingleton (LocalizedModule p.1.primeCompl N ⧸\n              LinearMap.range (LocalizedModule.map p.1.primeCompl f)) := by\n          have := (LinearMap.subsingleton_coker_convert (f := f) (S := p.1.primeCompl)).2 hcoker\n          simpa [LinearMap.range_eq_map] using this\n        haveI := hsub\n        have : (Submodule.Quotient.mk (LinearMap.range (LocalizedModule.map p.1.primeCompl f)) y) = 0 := by\n          simpa using (Subsingleton.elim (Submodule.Quotient.mk _ y) 0)\n        rcases (Submodule.Quotient.eq_zero_iff_mem).1 this with ⟨x, rfl⟩\n        exact ⟨x, rfl⟩\n      exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) ⟨hinj, hsurj⟩⟩\n    exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) ⟨hf'.1, hf'.2⟩⟩\n  · intro h\n    rcases hMT.isPseudoIsomorphic_pi (A := A) (M := M) with ⟨ι, _, pM, hpM, eM, heM, hM⟩\n    rcases hNT.isPseudoIsomorphic_pi (A := A) (M := N) with ⟨κ, _, pN, hpN, eN, heN, hN⟩\n    -- reduce to comparing localizations at height one primes and use given hypothesis\n    -- pseudo-isomorphism is an equivalence relation\n    have hMN : ((i : ι) → A ⧸ (pM i).1 ^ (eM i)) ∼ₚᵢₛ[A] ((j : κ) → A ⧸ (pN j).1 ^ (eN j)) := by\n      -- by localizing at height one primes, both sides are determined by their local invariants;\n      -- use the hypothesis `h` transported along `hM` and `hN`.\n      classical\n      -- enough to show localizations at height one primes are linearly equivalent\n      refine (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule\n        (A := A) (M := ((i : ι) → A ⧸ (pM i).1 ^ (eM i)))\n        (N := ((j : κ) → A ⧸ (pN j).1 ^ (eN j)))\n        (by\n          -- torsion because each component is torsion\n          intro x\n          classical\n          -- pick any component, annihilate by product of annihilators; use `0` if empty\n          refine ⟨⟨1, one_ne_zero⟩, ?_⟩\n          simpa⟩)\n        (by\n          intro x\n          classical\n          refine ⟨⟨1, one_ne_zero⟩, ?_⟩\n          simpa⟩)).2 (fun q hq => by\n        -- obtain equivalence from M ~ N and hypothesis `h`\n        have hqMN : Nonempty\n            (LocalizedModule q.1.primeCompl M ≃ₗ[Localization q.1.primeCompl]\n              LocalizedModule q.1.primeCompl N) := h q hq\n        -- transport along pseudo-isomorphisms `hM` and `hN` (localizations preserve pseudo-iso to iso at height one)\n        rcases hqMN with ⟨e⟩\n        exact ⟨by\n          -- use `e` and rewrite via `hM` `hN` by choosing representatives\n          exact e⟩)\n    -- conclude by transitivity\n    exact (Module.IsPseudoIsomorphic.trans (Module.IsPseudoIsomorphic.symm hM)\n      (Module.IsPseudoIsomorphic.trans hMN hN))",
      "\n  constructor\n  · rintro ⟨X, Y, f, g, hf, hg, hX, hY⟩ p hp\n    have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have := (LinearMap.isPseudoIsomorphism_iff_bijective_map\n        (A := A) (M := M) (N := N) hMT hNT f).1 hf\n      refine this.2 p ?_\n      simpa [hp] using hp\n    have hg' : Function.Bijective (LocalizedModule.map p.1.primeCompl g) := by\n      have := (LinearMap.isPseudoIsomorphism_iff_bijective_map\n        (A := A) (M := N) (N := M) hNT hMT g).1 hg\n      refine this.2 p ?_\n      simpa [hp] using hp\n    refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hf'⟩\n  · intro h\n    classical\n    let sigma := (Module.support A M ∪ Module.support A N) ∩\n      {p : PrimeSpectrum A | p.1.primeHeight = 1}\n    have hsigma : ∀ p ∈ sigma,\n        Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n          (LocalizedModule p.1.primeCompl N)) := by\n      intro p hp\n      have hp' : p.1.primeHeight = 1 := by\n        have := (Set.mem_inter_iff.mp hp).2\n        simpa using this\n      exact h p hp'\n    rcases (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT) with\n      ⟨ιM, _, pM, hpM, eM, heM, hM⟩\n    rcases (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT) with\n      ⟨ιN, _, pN, hpN, eN, heN, hN⟩\n    have hlocM :\n        ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →\n          Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n            (LocalizedModule p.1.primeCompl ((i : ιM) → A ⧸ (pM i).1 ^ (eM i)))) := by\n      intro p hp\n      rcases hM with ⟨X, Y, f, g, hf, hg, hX, hY⟩\n      have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n        have := (LinearMap.isPseudoIsomorphism_iff_bijective_map\n          (A := A) (M := M) (N := (ιM → A ⧸ (pM ·).1 ^ (eM ·))) hMT\n          (by\n            classical\n            intro x\n            classical\n            by_cases hx : x = 0\n            · use ⟨0, by simpa [hx]⟩\n            ·\n              rcases (Classical.choice (Classical.propComplete (∃ a : A, a ≠ 0 ∧ a • x = 0))) with ⟨a, ha⟩\n              exact ⟨⟨a, ha.1⟩, ha.2⟩) f).1 hf\n        refine this.2 p ?_\n        simpa [hp] using hp\n      exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hf'⟩\n    have hlocN :\n        ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →\n          Nonempty ((LocalizedModule p.1.primeCompl N) ≃ₗ[Localization p.1.primeCompl]\n            (LocalizedModule p.1.primeCompl ((i : ιN) → A ⧸ (pN i).1 ^ (eN i)))) := by\n      intro p hp\n      rcases hN with ⟨X, Y, f, g, hf, hg, hX, hY⟩\n      have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n        have := (LinearMap.isPseudoIsomorphism_iff_bijective_map\n          (A := A) (M := N) (N := (ιN → A ⧸ (pN ·).1 ^ (eN ·))) hNT\n          (by\n            classical\n            intro x\n            classical\n            by_cases hx : x = 0\n            · use ⟨0, by simpa [hx]⟩\n            ·\n              rcases (Classical.choice (Classical.propComplete (∃ a : A, a ≠ 0 ∧ a • x = 0))) with ⟨a, ha⟩\n              exact ⟨⟨a, ha.1⟩, ha.2⟩) f).1 hf\n        refine this.2 p ?_\n        simpa [hp] using hp\n      exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hf'⟩\n    refine (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule\n      (A := A) (M := M) (N := N) hMT hNT).2 ?_\n    intro p hp\n    have := h p hp\n    exact this",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨L, f, g, hf, hg⟩\n    have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have : f.IsPseudoIsomorphism := by\n        refine ⟨?_, ?_⟩\n        · simpa using hf\n        · simpa using (Module.isPseudoNull_congr (LinearEquiv.quotientKerEquivOfInjective\n            (LinearMap.ker_eq_bot.mp (Submodule.eq_bot_of_subsingleton ?_))).symm ?_)\n      -- use the characterization via localization on the sigma attached to M,N at height one primes\n      -- and the fact that localizing further at p preserves bijectivity\n      have hbij := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := L)\n        hMT (by\n          -- torsion for L follows from pseudo-isomorphic to M\n          classical\n          have : Module.IsTorsion A M := hMT\n          -- any element of L maps to torsion in N via g∘f\n          intro x\n          have hx : ∃ a : {a : A // a ≠ 0}, a • (g (f x)) = 0 := by\n            simpa using (hNT (g (f x)))\n          rcases hx with ⟨a, ha⟩\n          refine ⟨a, ?_⟩\n          -- g∘f is a pseudo-isomorphism hence injective up to pseudo-null kernel; for torsion it's enough\n          simpa using ha) f).1 this\n      -- from bijectivity on the big localization we get bijectivity on p-localization\n      -- by mapping along the natural localization morphism\n      classical\n      -- simplify: use that bijective after localizing at sigma implies bijective after localizing at p\n      -- since p is among height-one primes; apply theorem with sigma={p}∪...\n      -- easiest: apply the same characterization directly to f with sigma built from M and L, then restrict\n      simpa using (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := L)\n        hMT (by\n          classical\n          intro x\n          obtain ⟨a, ha⟩ := hMT x\n          exact ⟨a, ha⟩) f).1 this\n    exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hf'⟩\n  · intro h\n    classical\n    -- use structure theorem: reduce to products of cyclic height-one prime power quotients\n    rcases (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT) with\n      ⟨ι, _, pM, hpM, eM, heM, hM⟩\n    rcases (Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT) with\n      ⟨κ, _, pN, hpN, eN, heN, hN⟩\n    -- it suffices to show the standard forms are pseudo-isomorphic using local data\n    have hMN : ((i : ι) → A ⧸ (pM i).1 ^ (eM i)) ∼ₚᵢₛ[A] ((j : κ) → A ⧸ (pN j).1 ^ (eN j)) := by\n      -- use characterization by localizations at height one primes\n      refine (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule\n        (A := A)\n        (M := (i : ι) → A ⧸ (pM i).1 ^ (eM i))\n        (N := (j : κ) → A ⧸ (pN j).1 ^ (eN j))\n        (by\n          classical\n          -- products of torsion modules are torsion\n          intro x\n          classical\n          refine ⟨⟨1, one_ne_zero⟩, ?_⟩\n          simp) (by\n          classical\n          intro x\n          refine ⟨⟨1, one_ne_zero⟩, ?_⟩\n          simp)).2 ?_\n      intro p hp\n      -- get the given equivalence for M,N and transport across the pseudo-isomorphisms hM,hN\n      have hMp : Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n        (LocalizedModule p.1.primeCompl N)) := h p hp\n      rcases hMp with ⟨e⟩\n      -- obtain linear equivalences after localization induced by pseudo-isomorphisms hM,hN\n      rcases hM with ⟨L1, f1, g1, hf1, hg1⟩\n      rcases hN with ⟨L2, f2, g2, hf2, hg2⟩\n      have ef1 : Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n        (LocalizedModule p.1.primeCompl ((i : ι) → A ⧸ (pM i).1 ^ (eM i)))) := by\n        have : Function.Bijective (LocalizedModule.map p.1.primeCompl f1) := by\n          have hf1' : f1.IsPseudoIsomorphism := ⟨hf1, hg1⟩\n          have hb := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := L1)\n            hMT (by\n              classical\n              intro x; obtain ⟨a, ha⟩ := hMT x; exact ⟨a, ha⟩) f1).1 hf1'\n          -- bijective on sigma implies bijective after localizing at p; use the same theorem with sigma\n          simpa using hb\n        exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f1) this⟩\n      have ef2 : Nonempty ((LocalizedModule p.1.primeCompl N) ≃ₗ[Localization p.1.primeCompl]\n        (LocalizedModule p.1.primeCompl ((j : κ) → A ⧸ (pN j).1 ^ (eN j)))) := by\n        have : Function.Bijective (LocalizedModule.map p.1.primeCompl f2) := by\n          have hf2' : f2.IsPseudoIsomorphism := ⟨hf2, hg2⟩\n          have hb := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := N) (N := L2)\n            hNT (by\n              classical\n              intro x; obtain ⟨a, ha⟩ := hNT x; exact ⟨a, ha⟩) f2).1 hf2'\n          simpa using hb\n        exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f2) this⟩\n      rcases ef1 with ⟨e1⟩\n      rcases ef2 with ⟨e2⟩\n      exact ⟨(e1.symm.trans (e.trans e2))⟩\n    -- conclude for M,N by transitivity\n    exact hM.symm.trans (hMN.trans hN)",
      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' :=\n      (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N) hMT hNT f).1 hf\n    have hbij : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have hsub :\n          p ∈ (Module.support A M ∪ Module.support A N) ∩\n              {p : PrimeSpectrum A | p.1.primeHeight = 1} := by\n        refine ⟨?_, ?_⟩\n        · by_cases hpm : p ∈ Module.support A M\n          · exact Or.inl hpm\n          · have : p ∈ Module.support A N := by\n              by_contra hpn\n              have : Subsingleton (LocalizedModule p.1.primeCompl M) := by\n                rw [← Module.notMem_support_iff, Module.mem_support_iff_of_finite] at hpm\n                simpa [LocalizedModule.subsingleton_iff] using hpm\n              have : Subsingleton (LocalizedModule p.1.primeCompl N) := by\n                rw [← Module.notMem_support_iff, Module.mem_support_iff_of_finite] at hpn\n                simpa [LocalizedModule.subsingleton_iff] using hpn\n              have : Subsingleton (LocalizedModule p.1.primeCompl M × LocalizedModule p.1.primeCompl N) := by\n                infer_instance\n              exact False.elim (hpn (by\n                have : p ∈ Module.support A N := by\n                  simpa using (Or.resolve_left (by trivial) hpm)\n                exact this))\n            exact Or.inr this\n        · simpa using hp\n      have hsigma :\n          p.1.primeCompl ≤\n            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n                {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) := by\n        simpa [Submonoid.coe_iInf] using (iInf_le_of_le p (iInf_le_of_le hsub le_rfl))\n      have hcomp :\n          LocalizedModule.map p.1.primeCompl f =\n            (LocalizedModule.map hsigma) (LocalizedModule.map\n              (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n                {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.