/-- Let `A` be a Noetherian ring satisfying `HeightOneLocalizationIsPID`. Then two finitely
generated torsion `A`-modules `M`, `N` are pseudo-isomorphic if and only if their localizations
at all height one primes are isomorphic. -/
theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · intro h p hp
    rcases h with ⟨f, hf⟩
    have hbij : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by
      refine ⟨?_, ?_⟩
      · have : Subsingleton (LocalizedModule p.1.primeCompl (LinearMap.ker f)) := by
          apply hf.1
          intro q hq
          rcases (le_of_eq hp : p.1.primeHeight ≤ 1) with hle
          exact hq hle
        rw [LocalizedModule.subsingleton_iff] at this
        have : ker (LocalizedModule.map p.1.primeCompl f) = ⊥ := by
          ext x
          constructor
          · intro hx
            have hx' : (x : LocalizedModule p.1.primeCompl M) ∈
                LocalizedModule.map p.1.primeCompl (LinearMap.ker f).subtype ⊤ := by
              refine ⟨⟨x, hx⟩, by
                simp⟩
            rcases (this x).1 (by simpa using hx') with ⟨s, hs, hxs⟩
            simpa [Submodule.mem_bot, LocalizedModule.smul_mk, Subtype.ext_iff] using hxs
          · intro hx
            simpa [hx]
        simpa [LinearMap.ker_eq_bot] using this
      · have : Subsingleton (LocalizedModule p.1.primeCompl (N ⧸ LinearMap.range f)) := by
          apply hf.2
          intro q hq
          rcases (le_of_eq hp : p.1.primeHeight ≤ 1) with hle
          exact hq hle
        have : range (LocalizedModule.map p.1.primeCompl f) = ⊤ := by
          classical
          apply top_le_iff.mp
          intro y _
          have : (LocalizedModule p.1.primeCompl N ⧸ range (LocalizedModule.map p.1.primeCompl f)) := by
            exact ⟨y, by simp⟩
          have hs : (⟨y, by simp⟩ :
              LocalizedModule p.1.primeCompl N ⧸ range (LocalizedModule.map p.1.primeCompl f)) = 0 := by
            have := (Submodule.Quotient.subsingleton_iff (range (LocalizedModule.map p.1.primeCompl f))).1 this
            simpa using this
          rcases (Submodule.Quotient.eq_zero_iff_mem).1 hs with hy
          exact ⟨y, hy, rfl⟩
        simpa [LinearMap.range_eq_top] using this
    exact ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hbij⟩
  · intro h
    classical
    rcases (hMT.isPseudoIsomorphic_pi (A := A) (M := M)) with
      ⟨ι, hι, pM, hpM, eM, heM, fM⟩
    rcases (hNT.isPseudoIsomorphic_pi (A := A) (M := N)) with
      ⟨κ, hκ, pN, hpN, eN, heN, fN⟩
    refine (Module.IsPseudoIsomorphic.trans ?_ (Module.IsPseudoIsomorphic.symm ?_))
    · exact fM
    · exact fN
