hq).2) (by\n        classical\n        rcases (Module.IsTorsion.finite_primeHeight_one_support (A := A) (M := M) hMT).union\n            (Module.IsTorsion.finite_primeHeight_one_support (A := A) (M := N) hNT) with hfin\n        have : sigma.Finite := by\n          simpa [sigma, Set.inter_assoc, Set.inter_left_comm, Set.inter_comm, Set.union_inter_distrib_right] using\n            (hfin.inter_of_left _)\n        exact this.to_subtype.nonempty) (by\n        classical\n        rcases (Module.IsTorsion.finite_primeHeight_one_support (A := A) (M := M) hMT).union\n            (Module.IsTorsion.finite_primeHeight_one_support (A := A) (M := N) hNT) with hfin\n        have : sigma.Finite := by\n          simpa [sigma, Set.inter_assoc, Set.inter_left_comm, Set.inter_comm, Set.union_inter_distrib_right] using\n            (hfin.inter_of_left _)\n        exact this)).2\n    have : Nonempty ((LocalizedModule S M) ≃ₗ[Localization S] (LocalizedModule S N)) := by\n      classical\n      refine ⟨LinearEquiv.ofBijective (LocalizedModule.map S f) hb'⟩\n    have hsigma_mem : p ∈ sigma := by\n      simp [sigma, hp]\n    have hloc : IsLocalization p.1.primeCompl (Localization p.1.primeCompl) := by infer_instance\n    have hle : S ≤ p.1.primeCompl := by\n      intro a ha\n      simp [S] at ha\n      have : a ∈ ⋂ q ∈ sigma, (q.1.primeCompl : Set A) := by\n        simpa [Submonoid.mem_iInf] using ha\n      have : a ∈ (p.1.primeCompl : Set A) := by\n        have := Set.mem_iInter₂.1 this p hsigma_mem\n        simpa using this\n      simpa using this\n    haveI : IsLocalization S (Localization S) := by infer_instance\n    let g : Localization S →+* Localization p.1.primeCompl :=\n      IsLocalization.map (T := Localization p.1.primeCompl) (M := S) (N := p.1.primeCompl)\n        (algebraMap A (Localization p.1.primeCompl)) hle\n    haveI : Algebra (Localization S) (Localization p.1.primeCompl) := g.toAlgebra\n    haveI : IsScalarTower A (Localization S) (Localization p.1.primeCompl) := by\n      classical\n      refine IsScalarTower.of_algebraMap_eq ?_\n      ext a\n      rfl\n    haveI :\n        IsLocalization p.1.primeCompl (LocalizedModule S (LocalizedModule p.1.primeCompl M)) := by\n      infer_instance\n    have : Nonempty\n        ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]\n          (LocalizedModule p.1.primeCompl N)) := by\n      classical\n      have hb_p :\n          Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n        have hfbij :\n            Function.Bijective (LocalizedModule.map S f) := hb'\n        have hfbij' :\n            Function.Bijective\n              (LocalizedModule.map p.1.primeCompl (LocalizedModule.map S f)) := by\n          exact ⟨fun x y hxy => by\n            exact (LocalizedModule.map_injective p.1.primeCompl (LocalizedModule.map S f) hfbij.1) hxy,\n            fun y => by\n              rcases hfbij.2 (by\n                classical\n                exact (by\n                  rcases (LocalizedModule.map_surjective p.1.primeCompl (LocalizedModule.map S f) hfbij.2) y with\n                    ⟨x, rfl⟩\n                  exact ⟨x, rfl⟩)) with ⟨x, rfl⟩\n              exact ⟨x, rfl⟩⟩\n        have hcomm :\n            LocalizedModule.map p.1.primeCompl (LocalizedModule.map S f) =\n              (LocalizedModule.map S (LocalizedModule.map p.1.primeCompl f)) := by\n          ext x\n          rfl\n        simpa [hcomm] using hfbij'\n      refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hb_p⟩\n    exact this\n  · intro h\n    classical\n    rcases (hMT.isPseudoIsomorphic_pi (A := A) (M := M) hMT) with\n      ⟨ι, _, pM, hpM, eM, heM, hM⟩\n    rcases (hNT.isPseudoIsomorphic_pi (A := A) (M := N) hNT) with\n      ⟨κ, _, pN, hpN, eN, heN, hN⟩\n    have : M ∼ₚᵢₛ[A] N := by\n      -- use localization criterion plus previous theorem\n      classical\n      refine (Module.isPseudoIsomorphic_iff_forall_heightOne ?_ ?_).2 ?_\n      · exact hMT\n      · exact hNT\n      · i