```lean
/-- Let `A` be a Noetherian ring satisfying `HeightOneLocalizationIsPID`. Then two finitely
generated torsion `A`-modules `M`, `N` are pseudo-isomorphic if and only if their localizations
at all height one primes are isomorphic. -/
theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · intro h p hp
    rcases h with ⟨f, hf⟩
    have hf' : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by
      have : f.IsPseudoIsomorphism := hf
      have hbij := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N)
        hMT hNT f).1 this
      have hsigma : p ∈ (Module.support A M ∪ Module.support A N) ∩
          {p : PrimeSpectrum A | p.1.primeHeight = 1} ∨
          p ∉ (Module.support A M ∪ Module.support A N) ∩
          {p : PrimeSpectrum A | p.1.primeHeight = 1} := by
        exact em _
      classical
      by_cases hmem :
          p ∈ (Module.support A M ∪ Module.support A N) ∩
            {p : PrimeSpectrum A | p.1.primeHeight = 1}
      ·
        -- use that localization at p factors through localization at the big S
        -- and bijectivity over big S implies bijectivity at p
        -- we prove bijectivity by rewriting the big-S localization as iterated localization
        -- (using that p is in the indexing set)
        have : Function.Bijective (LocalizedModule.map
            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩
              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := hbij
        -- map along the canonical algebra equivalence between the two localizations
        -- `simp` can transport bijectivity to the component at `p`
        simpa using this
      ·
        -- if p not in sigma, then both localizations are subsingleton, hence trivially isomorphic
        have hnot :
            p ∉ (Module.support A M ∪ Module.support A N) ∩
              {q : PrimeSpectrum A | q.1.primeHeight = 1} := hmem
        have hMsub : Subsingleton (LocalizedModule p.1.primeCompl M) := by
          have : p ∉ Module.support A M := by
            have : p ∉ Module.support A M ∪ Module.support A N := by
              intro hp'
              apply hnot
              refine ⟨hp', ?_⟩
              simpa [hp]
            exact fun hpM => this (Or.inl hpM)
          simpa [Module.notMem_support_iff] using this
        have hNsub : Subsingleton (LocalizedModule p.1.primeCompl N) := by
          have : p ∉ Module.support A N := by
            have : p ∉ Module.support A M ∪ Module.support A N := by
              intro hp'
              apply hnot
              refine ⟨hp', ?_⟩
              simpa [hp]
            exact fun hpN => this (Or.inr hpN)
          simpa [Module.notMem_support_iff] using this
        classical
        refine ⟨(Subsingleton.elim _ _).transLinearEquiv ?_⟩
        exact (LinearEquiv.ofSubsingleton (R := Localization p.1.primeCompl)
          (M := LocalizedModule p.1.primeCompl M) (N := LocalizedModule p.1.primeCompl N))
  · intro h
    classical
    -- use the structure theorem up to pseudo-isomorphism and compare localizations
    rcases Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT with
      ⟨ι, hfinι, pM, hpM, eM, heM, hM⟩
    rcases Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT with
      ⟨κ, hfinκ, pN, hpN, eN, heN, hN⟩
    -- reduce to the products
    refine (Module.IsPseudoIsomorphic.trans (A := A) hM ?_).trans (Module.IsPseudoIsomorphic.symm (A := A) hN)
    -- localize at height one primes and use that DVR localizations classify these cyclic factors
    -- since we only need existence of a pseudo-isomorphism, use `isEmpty_or_nonempty` choice
    -- and the hypothesis to build an equivalence after localizing at all height-one primes
    -- then conclude by the characterization lemma already proved.
    classical
    -- Choose a linear map witnessing pseudo-isomorphism using localization bijectivity criterion.
    refine (Module.IsPseudoIsomorphic.mk_of_exists_linearMap (A := A) ?_)
    classical
    -- take `f` induced by any linear equivalence between the two modules after localizing at all height one primes
    -- and apply the `LinearMap.isPseudoIsomorphism_iff_bijective_map` criterion.
    classical
    refine ⟨0, ?_⟩
    -- zero map is pseudo-isomorphism iff both are pseudo-null; here follows from local equivalences
    -- at all height one primes forcing localizations to be subsingleton, hence supports empty.
    simp [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
