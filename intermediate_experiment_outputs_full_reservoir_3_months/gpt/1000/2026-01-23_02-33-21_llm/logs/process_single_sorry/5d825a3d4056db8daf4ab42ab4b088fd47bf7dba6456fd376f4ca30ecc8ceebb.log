      "\n  constructor\n  · intro h p hp\n    rcases h with ⟨f, hf⟩\n    have hf' :\n        Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n      have hbij := (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A)\n        (M := M) hMT (N := N) hNT f).1 hf\n      have hsub :\n          p ∈ (Module.support A M ∪ Module.support A N) ∩\n            {p : PrimeSpectrum A | p.1.primeHeight = 1} ∨\n          p ∉ (Module.support A M ∪ Module.support A N) ∩\n            {p : PrimeSpectrum A | p.1.primeHeight = 1} := by\n        exact em _\n      classical\n      rcases hsub with hpσ | hpσ\n      ·\n        -- restriction from the big localization to the localization at `p`\n        have : Function.Bijective (LocalizedModule.map\n            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := hbij\n        -- from bijective at big `S`, we get bijective at each `p ∈ σ`\n        have hmono :\n            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) ≤ p.1.primeCompl := by\n          refine le_trans ?_ (le_rfl)\n          exact iInf_le_of_le p (iInf_le_of_le hpσ le_rfl)\n        -- use `IsLocalization` functoriality: localization at `p` is a localization of the big one\n        haveI :\n            IsLocalization p.1.primeCompl (Localization\n              (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n                {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl)) := by\n          infer_instance\n        -- `LocalizedModule.map` commutes with further localization; bijective remains bijective\n        exact\n          (LocalizedModule.map_bijective_of_bijective_of_le (f := f)\n            (S := (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩\n              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl))\n            (T := p.1.primeCompl) hmono this).1 this\n      ·\n        -- if `p ∉ σ`, then both localized modules are subsingleton, hence any map is bijective\n        have hSM : Subsingleton (LocalizedModule p.1.primeCompl M) := by\n          have : p ∉ Module.support A M := by\n            intro hpm\n            have : p ∈ (Module.support A M ∪ Module.support A N) ∩\n                {p : PrimeSpectrum A | p.1.primeHeight = 1} := by\n              refine ⟨Or.inl hpm, ?_⟩\n              simpa [Set.mem_setOf_eq] using hp\n            exact hpσ this\n          rwa [← Module.notMem_support_iff]\n        have hSN : Subsingleton (LocalizedModule p.1.primeCompl N) := by\n          have : p ∉ Module.support A N := by\n            intro hpn\n            have : p ∈ (Module.support A M ∪ Module.support A N) ∩\n                {p : PrimeSpectrum A | p.1.primeHeight = 1} := by\n              refine ⟨Or.inr hpn, ?_⟩\n              simpa [Set.mem_setOf_eq] using hp\n            exact hpσ this\n          rwa [← Module.notMem_support_iff]\n        have : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by\n          classical\n          haveI := hSM\n          haveI := hSN\n          exact ⟨fun x y _ => Subsingleton.elim _ _, fun y => ⟨0, Subsingleton.elim _ _⟩⟩\n        exact this\n    refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl (Classical.choice h))\n      (by simpa using hf')⟩\n  · intro h\n    classical\n    -- choose local equivalences at every height one prime; then use the characterization\n    -- by bijectivity after inverting all height one primes in `Supp(M) ∪ Supp(N)`.\n    classical\n    have :\n        ∃ f : M →ₗ[A] N, f.IsPseudoIsomorphism := by\n      classical\n      -- use the equivalence: pseudo-iso iff bijective after localizing at the finite set `sigma`\n      -- and construct bijectivity pointwise at each `p ∈ sigma` from `h`.\n      let sigma :=\n        (Module.support A M ∪ Module.support A N) ∩ {p : PrimeSpectrum A | p.1.primeHeight = 1}\n      let S := ⨅ p ∈ sigma, p.1.primeCompl