      have hfbij : Function.Bijective (LocalizedModule.map
          (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩
            {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := by
        (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N) hMT hNT f).1 hf
      -- localizing further at `p` preserves bijectivity; since `p` is in the defining set of primes,
      -- this is equivalent to bijectivity at `p`
      -- use `subsingleton_convert` machinery already developed
      -- we can directly re-run the characterization with `sigma := {p}`.
      simpa using (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N) hMT hNT f).1 hf
    refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hf'⟩
