/-- Let `A` be a Noetherian ring satisfying `HeightOneLocalizationIsPID`. Then two finitely
generated torsion `A`-modules `M`, `N` are pseudo-isomorphic if and only if their localizations
at all height one primes are isomorphic. -/
theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · intro h p hp
    rcases h with ⟨f, hf⟩
    have hf' :=
      (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N) hMT hNT f).1 hf
    have hbij : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by
      have hsub :
          p ∈ (Module.support A M ∪ Module.support A N) ∩
              {p : PrimeSpectrum A | p.1.primeHeight = 1} := by
        refine ⟨?_, ?_⟩
        · by_cases hpm : p ∈ Module.support A M
          · exact Or.inl hpm
          · have : p ∈ Module.support A N := by
              by_contra hpn
              have : Subsingleton (LocalizedModule p.1.primeCompl M) := by
                rw [← Module.notMem_support_iff, Module.mem_support_iff_of_finite] at hpm
                simpa [LocalizedModule.subsingleton_iff] using hpm
              have : Subsingleton (LocalizedModule p.1.primeCompl N) := by
                rw [← Module.notMem_support_iff, Module.mem_support_iff_of_finite] at hpn
                simpa [LocalizedModule.subsingleton_iff] using hpn
              have : Subsingleton (LocalizedModule p.1.primeCompl M × LocalizedModule p.1.primeCompl N) := by
                infer_instance
              exact False.elim (hpn (by
                have : p ∈ Module.support A N := by
                  simpa using (Or.resolve_left (by trivial) hpm)
                exact this))
            exact Or.inr this
        · simpa using hp
      have hsigma :
          p.1.primeCompl ≤
            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩
                {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) := by
        simpa [Submonoid.coe_iInf] using (iInf_le_of_le p (iInf_le_of_le hsub le_rfl))
      have hcomp :
          LocalizedModule.map p.1.primeCompl f =
            (LocalizedModule.map hsigma) (LocalizedModule.map
              (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩
                {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := by
        ext x
        simp
      have := LocalizedModule.map_bijective_of_bijective_of_le (f := f) hsigma hf'
      simpa [hcomp] using this
    refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hbij⟩
  · intro h
    rcases hMT.isPseudoIsomorphic_pi (A := A) (M := M) hMT with
      ⟨ι, hι, pM, hpM, eM, heM, hM⟩
    rcases hNT.isPseudoIsomorphic_pi (A := A) (M := N) hNT with
      ⟨κ, hκ, pN, hpN, eN, heN, hN⟩
    have hMN : ((i : ι) → A ⧸ (pM i).1 ^ (eM i)) ∼ₚᵢₛ[A] ((j : κ) → A ⧸ (pN j).1 ^ (eN j)) := by
      classical
      refine (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
        (A := A)
        (M := ((i : ι) → A ⧸ (pM i).1 ^ (eM i)))
        (N := ((j : κ) → A ⧸ (pN j).1 ^ (eN j)))
        ?_ ?_).2 ?_
      · infer_instance
      · infer_instance
      · intro p hp
        exact h p hp
    exact hM.trans (hMN.trans hN.symm)
