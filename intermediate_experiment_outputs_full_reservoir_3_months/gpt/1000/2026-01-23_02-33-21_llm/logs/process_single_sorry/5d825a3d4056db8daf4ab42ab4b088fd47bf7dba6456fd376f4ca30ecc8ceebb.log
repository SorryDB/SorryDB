        haveI : Subsingleton (LocalizedModule p.1.primeCompl N ⧸ LinearMap.range (LocalizedModule.map p.1.primeCompl f)) := by
          -- convert via previous lemma
          have := (LinearMap.subsingleton_coker_convert (A := A) (M := M) (N := N) f p.1.primeCompl).2 hcoker
          simpa using this
        have : (Submodule.Quotient.mk (LinearMap.range (LocalizedModule.map p.1.primeCompl f)) y) = 0 := by
          haveI := (show Subsingleton (LocalizedModule p.1.primeCompl N ⧸ LinearMap.range (LocalizedModule.map p.1.primeCompl f)) from ‹_›)
          simp
        rcases Submodule.Quotient.eq_zero_iff_mem.1 this with ⟨x, rfl⟩
        exact ⟨x, rfl⟩
      exact ⟨hinj, hsurj⟩
    refine ⟨LinearEquiv.ofBijective (LocalizedModule.map p.1.primeCompl f) hbij⟩
  · intro h
    classical
    rcases (hMT.isPseudoIsomorphic_pi (A := A) (M := M)) with
      ⟨ι, _hι, pM, hpM, eM, heM, hM⟩
    rcases (hNT.isPseudoIsomorphic_pi (A := A) (M := N)) with
      ⟨κ, _hκ, pN, hpN, eN, heN, hN⟩
    -- reduce to comparing the normal forms by localizing at all height-one primes
    -- and use the given hypothesis `h` to identify them
    -- conclude via transitivity
    have : M ∼ₚᵢₛ[A] N := by
      -- use the characterization via localizations at height one primes
      refine (Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
        (A := A) (M := M) (N := N) hMT hNT).2 ?_
