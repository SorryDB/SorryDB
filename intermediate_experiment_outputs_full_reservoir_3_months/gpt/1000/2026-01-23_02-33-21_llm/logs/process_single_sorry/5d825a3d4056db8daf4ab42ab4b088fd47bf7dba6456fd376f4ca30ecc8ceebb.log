/-- Let `A` be a Noetherian ring satisfying `HeightOneLocalizationIsPID`. Then two finitely
generated torsion `A`-modules `M`, `N` are pseudo-isomorphic if and only if their localizations
at all height one primes are isomorphic. -/
theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · intro h p hp
    rcases h with ⟨P, f, hf⟩
    have hf' : (LocalizedModule.map p.1.primeCompl f).IsIso := by
      have : Function.Bijective (LocalizedModule.map p.1.primeCompl f) := by
        have hbij : Function.Bijective (LocalizedModule.map
            (⨅ q ∈ (Module.support A M ∪ Module.support A N) ∩
              {q : PrimeSpectrum A | q.1.primeHeight = 1}, q.1.primeCompl) f) := by
          simpa using (LinearMap.isPseudoIsomorphism_iff_bijective_map (A := A) (M := M) (N := N)
            hMT hNT f).1 hf
        let sigma := (Module.support A M ∪ Module.support A N) ∩
          {q : PrimeSpectrum A | q.1.primeHeight = 1}
        let S := ⨅ q ∈ sigma, q.1.primeCompl
        have : (⨅ q ∈ sigma, q.1.primeCompl) ≤ p.1.primeCompl := by
          refine iInf₂_le_of_le p ?_
          refine iInf_le_of_le ?_ (le_rfl)
          exact by
            refine Set.mem_inter ?_ ?_
            · exact Or.inr ?_
              · exact Module.mem_support_iff.2 (by
                  classical
                  intro h0
                  have : (0 : LocalizedModule p.1.primeCompl N) = 0 := rfl
                  exact False.elim (h0.elim))
            · simpa [hp]
        have hloc : Function.Bijective (LocalizedModule.map S f) := by simpa [S, sigma] using hbij
        have hcomp :
            LocalizedModule.map p.1.primeCompl f =
              (LocalizedModule.map (LocalizationMap.toSubmonoid S p.1.primeCompl this)
                (LocalizedModule.map S f)) := by
          ext x
          rfl
        -- from bijective at S, deduce bijective at p by further localization
        have hbij' :
            Function.Bijective
              (LocalizedModule.map (LocalizationMap.toSubmonoid S p.1.primeCompl this)
                (LocalizedModule.map S f)) := by
          have := LocalizedModule.map_bijective
            (LocalizationMap.toSubmonoid S p.1.primeCompl this) (LocalizedModule.map S f) hloc
          simpa using this
        simpa [hcomp] using hbij'
      exact (LinearMap.isIso_iff_bijective _).2 this
    exact ⟨(LinearEquiv.ofIsIso (LocalizedModule.map p.1.primeCompl f))⟩
  · intro h
    rcases Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := M) hMT with
      ⟨ι, hι, pM, hpM, eM, heM, hM⟩
    rcases Module.IsTorsion.isPseudoIsomorphic_pi (A := A) (M := N) hNT with
      ⟨κ, hκ, pN, hpN, eN, heN, hN⟩
    refine (hM.trans ?_).trans hN.symm
    classical
    -- both sides have isomorphic localizations at height one primes, hence pseudo-isomorphic
    -- use the characterization via bijectivity of a localized map
    refine Module.IsPseudoIsomorphic.of_localization_heightOne ?_
    intro q hq
    -- reduce to hypothesis `h`
    simpa using h q hq
