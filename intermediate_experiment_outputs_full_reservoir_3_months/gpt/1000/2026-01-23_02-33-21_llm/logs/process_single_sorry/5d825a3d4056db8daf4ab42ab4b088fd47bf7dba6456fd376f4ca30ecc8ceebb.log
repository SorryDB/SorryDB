    classical
    -- choose a pseudo-isomorphism using the structure theorem and compare local invariants
    rcases hMT.isPseudoIsomorphic_pi (A := A) with ⟨ι, hfin, pM, hpM, eM, heM, hM⟩
    rcases hNT.isPseudoIsomorphic_pi (A := A) with ⟨κ, hfin', pN, hpN, eN, heN, hN⟩
    -- use transitivity and local criterion
    have : M ∼ₚᵢₛ[A] N := by
      -- it suffices to use the local criterion for pseudo-isomorphism induced by localization at height one primes
      -- obtained from the previous theorem on maps: pseudo-isomorphisms are exactly those inducing iso after
      -- localizing away from all height-one primes in the union of supports.
      -- We use existence of a local linear equiv at every height one prime to build a pseudo-isomorphism
      -- by applying the structure theorem and uniqueness of the localized invariants.
      -- This is available as `Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule`
      -- for the structured modules; here we transport along `hM` and `hN`.
      -- Conclude by rewriting the goal with the already proven equivalence for maps.
      -- We can simply use `hM.trans` etc. and the local criterion for `∼ₚᵢₛ`.
      -- In Mathlib/Iwasawalib, `PseudoIsomorphic` is an equivalence relation.
      simpa using (hM.trans (hN.symm))
