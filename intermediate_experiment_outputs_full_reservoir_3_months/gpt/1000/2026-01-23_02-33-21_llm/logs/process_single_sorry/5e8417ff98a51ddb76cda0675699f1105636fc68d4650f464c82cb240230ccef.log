/--
Taking the first `i` elements of a flattened list
can be expressed as the flattening of the first `j` complete sublists, plus the first
`k` elements of the `j`-th sublist.

The indices are computed as:
- `j` is one less than where the cumulative sum first exceeds `i`
- `k` is `i` minus the total length of the first `j` sublists
-/
theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  classical
  induction L generalizing i with
  | nil =>
    simp [partialSums]
  | cons l L ih =>
    by_cases hli : i ≤ l.length
    · have hfi : findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums = 1 := by
        simp [partialSums_cons, findIdx_cons, hli, Nat.lt_of_lt_of_le (Nat.lt_succ_self _) hli]
      simp [flatten_cons, hli, hfi, Nat.sub_eq_zero_of_le (Nat.succ_le_succ (Nat.zero_le _))]
    · have hlt : l.length < i := Nat.lt_of_not_ge hli
      have hfi :
          findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums =
            findIdx (fun x => decide (x > (i - l.length))) (map length L).partialSums + 1 := by
        simp [partialSums_cons, findIdx_cons, hlt, Function.comp_def]
        congr
        funext x
        grind
      have ht : l.length ≤ i := Nat.le_of_lt hlt
      have : i - l.length + l.length = i := Nat.sub_add_cancel ht
      have htake :
          take i ((l :: L).flatten) =
            l ++ take (i - l.length) (L.flatten) := by
        simp [flatten_cons, take_append, hlt, this]
      have htake' :
          take i ((l :: L).flatten) =
            (take 1 (l :: L)).flatten ++ take (i - l.length) (L.flatten) := by
        simpa [htake, List.flatten] using htake
      simp [flatten_cons, hlt, hfi, htake, ih, Nat.sub_sub, Nat.add_comm, Nat.add_left_comm,
        Nat.add_assoc, Nat.sub_eq_iff_eq_add_of_le ht, Nat.add_sub_cancel_left]
