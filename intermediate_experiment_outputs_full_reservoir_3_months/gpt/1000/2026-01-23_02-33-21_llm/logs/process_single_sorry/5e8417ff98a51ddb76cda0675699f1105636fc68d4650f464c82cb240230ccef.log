/--
Taking the first `i` elements of a flattened list
can be expressed as the flattening of the first `j` complete sublists, plus the first
`k` elements of the `j`-th sublist.

The indices are computed as:
- `j` is one less than where the cumulative sum first exceeds `i`
- `k` is `i` minus the total length of the first `j` sublists
-/
theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil =>
    simp [partialSums]
  | cons l L ih =>
    by_cases hli : i ≤ l.length
    · have hgt : 0 < (l.length + 0) := by omega
      have hfind : (map length (l :: L)).partialSums.findIdx (· > i) = 1 := by
        simp [partialSums_cons, findIdx_cons, Function.comp_def]
        have : decide (0 > i) = false := by
          simp [decide_eq_false_iff_not, Nat.not_lt_zero]
        simp [this, findIdx_eq]
        · simp [decide_eq_true_eq, hli]
      simp [flatten_cons, take_append, hli, hfind, Nat.sub_self, Nat.zero_sub, take_left] at *
      simp [flatten_cons, hli, hfind, Nat.sub_self, Nat.zero_sub]
    · have hli' : l.length < i := by
        have : ¬ i ≤ l.length := hli
        exact Nat.lt_of_not_ge this
      have hfind :
          (map length (l :: L)).partialSums.findIdx (· > i) =
            (map length L).partialSums.findIdx (· > (i - l.length)) + 1 := by
        simp [partialSums_cons, findIdx_cons, Function.comp_def]
        have : decide (0 > i) = false := by
          simp [decide_eq_false_iff_not, Nat.not_lt_zero]
        simp [this]
        congr
        funext x
        have : (x + l.length > i) = (x > i - l.length) := by
          omega
        simp [this]
      have htake : l.take i = l := by
        exact take_of_length_le (Nat.le_of_lt hli')
      have : i - l.length + l.length = i := by omega
      simp [flatten_cons, take_append, Nat.le_of_lt hli', htake, hfind, ih (i := i - l.length),
        Nat.sub_sub, this, Nat.add_sub_cancel_left, Nat.add_sub_cancel] 
