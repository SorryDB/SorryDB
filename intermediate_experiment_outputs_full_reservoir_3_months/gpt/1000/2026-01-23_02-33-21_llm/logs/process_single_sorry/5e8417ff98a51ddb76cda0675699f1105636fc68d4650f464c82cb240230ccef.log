      "\n  induction L generalizing i with\n  | nil =>\n    simp\n  | cons l L ih =>\n    by_cases h : i ≤ l.length\n    · have hj : (l :: L).map length |>.partialSums.findIdx (· > i) = 1 := by\n        simp [List.partialSums_cons, List.findIdx_cons]\n        rw [List.findIdx_eq]\n        · simp [h]\n        · intro k hk\n          cases k <;> simp at hk ⊢\n          omega\n      simp [List.flatten_cons, hj, h, Nat.sub_eq_zero_of_le h]\n    · have hlt : l.length < i := Nat.lt_of_not_ge h\n      have h' : i - l.length ≤ L.flatten.length := by\n        have : i ≤ (l :: L).flatten.length := by\n          have := Nat.le_of_lt_succ (Nat.lt_succ_self i)\n          exact le_trans this (by simp [List.flatten_cons, Nat.succ_le_succ_iff])\n        simpa [List.flatten_cons, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc,\n          Nat.add_sub_cancel_left] using (Nat.le_sub_of_add_le_left (by\n            simpa [List.flatten_cons, Nat.add_assoc] using this))\n      have hj :\n          (l :: L).map length |>.partialSums.findIdx (· > i) =\n            (L.map length).partialSums.findIdx (· > (i - l.length)) + 1 := by\n        simp [List.partialSums_cons, List.findIdx_cons, Function.comp_def]\n        congr\n        funext x\n        grind\n      simp [List.flatten_cons, h, hj, ih (i := i - l.length), Nat.sub_sub, Nat.add_assoc,\n        Nat.add_left_comm, Nat.add_comm, List.take_append, Nat.sub_eq_iff_eq_add_of_le]\n      have : (List.take (i - l.length) L.flatten).length = i - l.length := by\n        simp [List.length_take, Nat.min_eq_left, h']\n      simp [this, Nat.sub_add_cancel (Nat.le_of_lt hlt), List.take_append, List.take_take,\n        Nat.add_sub_cancel_left]",
