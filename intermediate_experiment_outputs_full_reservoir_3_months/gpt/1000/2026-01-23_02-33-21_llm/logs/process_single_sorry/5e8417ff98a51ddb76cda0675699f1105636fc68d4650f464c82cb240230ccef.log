      "\n  classical\n  induction L generalizing i with\n  | nil =>\n    simp\n  | cons l L ih =>\n    by_cases h : i ≤ l.length\n    · have hj : (findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums) = 1 := by\n        simp [partialSums_cons, findIdx_cons, h, Nat.lt_of_lt_of_le (Nat.lt_succ_self _) h]\n      simp [flatten_cons, partialSums_cons, hj, h, Nat.sub_eq_zero_of_le h]\n    · have h' : l.length < i := Nat.lt_of_not_ge h\n      have hi : i - l.length = i - l.length := rfl\n      have hj :\n          (findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums) =\n            findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums + 1 := by\n        simp [partialSums_cons, findIdx_cons, Function.comp_def, h, Nat.not_le_of_gt h']\n        congr\n        funext x\n        grind\n      simp [flatten_cons, partialSums_cons, hj, h, Nat.sub_add_cancel (Nat.le_of_lt h'), ih (i := i - l.length),\n        take_append_of_ge_length, Nat.le_of_lt h', Nat.sub_sub, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]",
