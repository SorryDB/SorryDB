      "\n  induction L generalizing i with\n  | nil =>\n    simp\n  | cons l L ih =>\n    simp only [flatten_cons]\n    by_cases hli : i < l.length\n    · have hj : findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums = 1 := by\n        simp [partialSums_cons, findIdx_cons]\n        rw [findIdx_eq] <;> grind\n      simp [hj, hli, Nat.not_le_of_gt hli]\n    · have hle : l.length ≤ i := Nat.le_of_not_gt hli\n      have hi' : i - l.length ≤ L.flatten.length := by\n        have : i ≤ (l :: L).flatten.length := by\n          simpa [flatten_cons, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using\n            Nat.le_trans hle (Nat.le_add_right l.length L.flatten.length)\n        simpa [flatten_cons, Nat.add_sub_cancel_left] using Nat.sub_le_sub_right this l.length\n      have hj :\n          findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums =\n            findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums + 1 := by\n        simp [partialSums_cons, findIdx_cons, Function.comp_def]\n        congr\n        funext x\n        grind\n      have := ih (i := i - l.length)\n      simp only at this\n      simp [take_append, hle, hj, this, Nat.sub_sub, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm]",
