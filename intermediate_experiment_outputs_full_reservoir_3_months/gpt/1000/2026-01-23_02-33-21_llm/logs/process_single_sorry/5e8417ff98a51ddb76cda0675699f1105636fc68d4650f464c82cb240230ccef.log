      "\n  classical\n  induction L generalizing i with\n  | nil =>\n    simp\n  | cons l L ih =>\n    by_cases h : i < l.length\n    · have hj : findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums = 1 := by\n        simp [partialSums_cons, findIdx_cons, h, Nat.not_lt_of_ge (Nat.le_of_lt_succ\n          (Nat.succ_lt_succ_iff.mp (Nat.lt_of_lt_of_le h (Nat.le_add_right _ _))))]\n      simp [flatten_cons, take_append, h, hj, Nat.not_lt_of_ge (Nat.le_of_lt h), Nat.sub_eq_zero_of_le]\n    · have hi : l.length ≤ i := Nat.le_of_not_gt h\n      have hj :\n          findIdx (fun x => decide (x > i)) (map length (l :: L)).partialSums =\n            findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums + 1 := by\n        simp [partialSums_cons, findIdx_cons, Function.comp_def, hi, Nat.add_comm, Nat.add_left_comm,\n          Nat.add_assoc, Nat.sub_add_cancel hi]\n      have ht : take i (flatten (l :: L)) = l ++ take (i - l.length) (flatten L) := by\n        simp [flatten_cons, take_append, hi, Nat.sub_eq]\n      simp [ht, hj, ih, flatten_cons, take_cons, hi, Nat.sub_sub, Nat.add_assoc, Nat.add_left_comm,\n        Nat.add_comm, Nat.sub_add_cancel hi, Nat.sub_eq, Nat.sub_eq_zero_of_le (Nat.zero_le _)]",
