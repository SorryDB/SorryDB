        simp [partialSums_cons, findIdx_cons, Function.comp_def]
        congr
        funext x
        grind
      have : l.flatten = l := by rfl
      simp only [flatten_cons, take_append, hi, hj]
      simp [ih (i := i - l.length), Nat.add_comm, Nat.add_left_comm, Nat.add_assoc, Nat.sub_sub]
