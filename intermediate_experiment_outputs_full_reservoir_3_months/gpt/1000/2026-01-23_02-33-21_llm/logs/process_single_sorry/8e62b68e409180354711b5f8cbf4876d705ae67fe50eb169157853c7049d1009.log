      "\n  classical\n  by_contra h\n  rcases (not_isBounded_iff.mp h) with ⟨x0, hx0⟩\n  have hx0' : ∀ R : ℝ, ∃ x ∈ s, R ≤ dist (f x) x0 := by\n    intro R\n    rcases hx0 R with ⟨y, hy, hRy⟩\n    rcases hy with ⟨x, hx, rfl⟩\n    exact ⟨x, hx, hRy⟩\n  have : ∀ n : ℕ, ∃ x ∈ s, (n : ℝ) ≤ dist (f x) x0 := by\n    intro n; simpa using hx0' (n : ℝ)\n  choose x hx_mem hx_dist using this\n  have hs' : IsCompact s := hs\n  rcases hs'.isSeqCompact with hseq\n  rcases hseq x hx_mem with ⟨a, ha_mem, φ, hφ_mono, hφ_tendsto, hφ_mem⟩\n  have hdist_unbounded :\n      Tendsto (fun n => dist (f (x (φ n))) x0) atTop atTop := by\n    refine tendsto_atTop.2 ?_\n    intro R\n    rcases exists_nat_ge (max R 0) with ⟨N, hN⟩\n    refine ⟨N, ?_⟩\n    intro n hn\n    have hn' : (φ n : ℝ) ≤ dist (f (x (φ n))) x0 := hx_dist (φ n)\n    have hR : R ≤ (φ n : ℝ) := by\n      have : (max R 0) ≤ (φ n : ℝ) := le_trans hN ?_\n      · exact le_trans (le_max_left _ _) this\n      · exact_mod_cast le_trans (hφ_mono hn) (le_rfl)\n    exact le_trans hR hn'\n  have hdist_bdd :\n      Bornology.IsBounded (Set.range fun n => dist (f (x (φ n))) x0) := by\n    have hcont :\n        Continuous (fun y : E => dist y x0) := by\n      simpa [Metric.continuous_iff] using (continuous_id.dist continuous_const)\n    have hcompact :\n        IsCompact (Set.range fun n => f (x (φ n))) := by\n      have hsub :\n          Set.range (fun n => f (x (φ n))) ⊆ f '' s := by\n        intro y hy\n        rcases hy with ⟨n, rfl⟩\n        refine ⟨x (φ n), hφ_mem n, rfl⟩\n      exact (hs.image_continuous (by\n        intro a\n        simpa [Function.RightContinuous] using hf.right_continuous a)).subset hsub\n    have : IsCompact (Set.range fun n => dist (f (x (φ n))) x0) :=\n      hcompact.image hcont\n    exact this.isBounded\n  have : ¬ Tendsto (fun n => dist (f (x (φ n))) x0) atTop atTop := by\n    intro ht\n    have : ¬ Bornology.IsBounded (Set.range fun n => dist (f (x (φ n))) x0) :=\n      (not_isBounded_iff.mp (by\n        intro hb\n        have := hb\n        exact False.elim (by\n          have := hb\n          exact False.elim (by trivial)))) -- unreachable\n    exact this hdist_bdd\n  exact this hdist_unbounded",
      "\n  classical\n  rcases hs.bddAbove with ⟨r, hr⟩\n  refine (isBounded_iff.2 ?_)\n  refine ⟨dist (f (Classical.choice hs.nonempty)) (f (Classical.choice hs.nonempty)) + 1, ?_⟩\n  intro y hy\n  rcases hy with ⟨x, hx, rfl⟩\n  have : dist (f x) (f (Classical.choice hs.nonempty)) ≤ dist (f x) (f (Classical.choice hs.nonempty)) := le_rfl\n  have hlt : dist (f x) (f (Classical.choice hs.nonempty)) < dist (f (Classical.choice hs.nonempty)) (f (Classical.choice hs.nonempty)) + 1 := by\n    simpa using lt_of_le_of_lt this (lt_add_of_pos_right _ zero_lt_one)\n  simpa [Real.norm_eq_abs, abs_of_nonneg (dist_nonneg)] using hlt.le",
      "\n  classical\n  by_contra h\n  rcases hs with ⟨hs₁, hs₂⟩\n  have hsne : s.Nonempty := by\n    by_contra hsne\n    have : s = ∅ := Set.not_nonempty_iff_eq_empty.mp hsne\n    have : f '' s = ∅ := by simpa [this]\n    exact h (this.symm ▸ bornology_isBounded_empty)\n  rcases hs₂ _ hsne with ⟨a, ha, hmin⟩\n  have hrc : ContinuousWithinAt f (Set.Ioi a) a := hf.right_continuous a\n  have hlim : ∃ l, Tendsto f (𝓝[<] a) (𝓝 l) := hf.left_limit a\n  rcases hlim with ⟨l, hl⟩\n  have hb_right : ∃ r : ℝ, 0 < r ∧ IsBounded (f '' (s ∩ Set.Icc a (a + r))) := by\n    refine ⟨1, by norm_num, ?_⟩\n    have hIcc : IsCompact (s ∩ Set.Icc a (a + (1:ℝ))) :=\n      hs.inter_right isCompact_Icc\n    have : IsBounded (f '' (s ∩ Set.Icc a (a + (1:ℝ)))) := by\n      simpa using (hIcc.image_continuousOn (by\n        intro x hx\n        have hx' : x ∈ Set.Icc a (a + (1:ℝ)) := hx.2\n        have : x = a ∨ x ∈ Set.Ioi a := by\n          by_cases hxa : x = a\n          · exact Or.inl hxa\n          · have : a < x := lt_of_le_of_ne hx'.1 (Ne.symm hxa)\n            exact Or.inr this\n        cases this with\n        | inl hxa =>\n            simpa [hxa] using (hrc.continuousWithinAt)\n        | inr hxa =>\n            have : ContinuousAt f x := by\n              -- from right continuity at points > a, use within at Ioi x to get at\n              have hrcx : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x\n              simpa [ContinuousWithinAt, nhdsWithin_Ioi_eq] using hrcx\n            simpa using this.continuousWithinAt))\n    exact ⟨1, by norm_num, this⟩\n  rcases hb_right with ⟨r, hrpos, hb⟩\n  have hsleft : IsCompact (s ∩ Set.Icc (a - r) a) :=\n    hs.inter_right isCompact_Icc\n  have hb_left : IsBounded (f '' (s ∩ Set.Icc (a - r) a)) := by\n    by_cases hsub : (s ∩ Set.Icc (a - r) a) ⊆ {a}\n    · have : f '' (s ∩ Set.Icc (a - r) a) ⊆ {f a} := by\n        intro y hy\n        rcases hy with ⟨x, hx, rfl⟩\n        have : x = a := by\n          have : x ∈ ({a} : Set ι) := hsub hx\n          simpa using this\n        simpa [this]\n      exact (isBounded_singleton (f a)).mono this\n    · have hne : (s ∩ Set.Icc (a - r) a).Nonempty := by\n        by_contra hne\n        have : s ∩ Set.Icc (a - r) a = ∅ := Set.not_nonempty_iff_eq_empty.mp hne\n        exact hsub (by simpa [this])\n      rcases hsleft.exists_isSeq_tendsto_of_nonempty hne with ⟨u, hu, hut⟩\n      have : Tendsto (f ∘ u) atTop (𝓝 l) := hl.comp hut\n      have hbounded : IsBounded (Set.range (f ∘ u)) := (isBounded_range_of_tendsto_nhds this)\n      have hsubset : f '' (s ∩ Set.Icc (a - r) a) ⊆ closure (Set.range (f ∘ u)) := by\n        intro y hy\n        rcases hy with ⟨x, hx, rfl⟩\n        have : x ∈ closure (Set.range u) := by\n          have : x ∈ closure (Set.range u) := by\n            -- since u ranges in the set and tends to a which is minimal, points are approached\n            exact subset_closure (by\n              rcases hu with ⟨hu1, hu2⟩\n              refine ⟨0, ?_⟩\n              simpa using hu1 0)\n          exact this\n        exact closure_mono (by\n          intro z hz\n          rcases hz with ⟨n, rfl⟩\n          exact ⟨u n, ⟨hu.1 n, by rfl⟩, rfl⟩) (by\n            simpa [Set.image_image] using this)\n      exact hbounded.closure.mono hsubset\n  have : IsBounded (f '' s) := by\n    have hcover : s ⊆ (s ∩ Set.Icc (a - r) a) ∪ (s ∩ Set.Icc a (a + r)) := by\n      intro x hx\n      have hxle : a ≤ x := hmin x hx\n      by_cases hxa : x ≤ a\n      · left\n        refine ⟨hx, ?_⟩\n        exact ⟨by\n          have : a - r ≤ a := sub_le_self _ (le_of_lt hrpos)\n          exact le_trans this (le_of_eq (le_antisymm hxa hxle)),\n          hxa⟩\n      · right\n        refine ⟨hx, ?_⟩\n        refine ⟨hxle, ?_⟩\n        have : x ≤ a + r := by\n          -- otherwise x would be > a+r; but then x in s gives a < x, contradict minimality? impossible; so use trivial le\n          exact le_of_lt (lt_of_not_ge hxa)\n        exact this\n    have : f '' s ⊆ (f '' (s ∩ Set.Icc (a - r) a)) ∪ (f '' (s ∩ Set.Icc a (a + r))) := by\n      intro y hy\n      rcases hy with ⟨x, hx, rfl⟩\n      have : x ∈ (s ∩ Set.Icc (a - r) a) ∪ (s ∩ Set.Icc a (a + r)) := hcover hx\n      cases this with\n      | inl hx' =>\n          exact Or.inl ⟨x, hx', rfl⟩\n      | inr hx' =>\n          exact Or.inr ⟨x, hx', rfl⟩\n    exact (hb_left.union hb).mono this\n  exact h this",
      "\n  classical\n  have hcont : Continuous f := by\n    refine continuous_iff_continuousAt.2 ?_\n    intro x\n    have hr : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x\n    rcases hf.left_limit x with ⟨l, hl⟩\n    have hleft : ContinuousWithinAt f (Set.Iio x) x := by\n      simpa [nhdsWithin_Iio_eq_nhdsWithin_lt] using hl.continuousWithinAt\n    have hx : f x = l := by\n      have : Tendsto f (pure x) (𝓝 (f x)) := tendsto_pure.2 rfl\n      have hxmem : x ∈ Set.Ioi x ∪ Set.Iio x ∪ {x} := by\n        simp\n      have hnhds :\n          (𝓝 x) = 𝓝[Set.Ioi x ∪ Set.Iio x ∪ {x}] x := by\n        symm\n        refine nhdsWithin_eq_of_mem ?_\n        simpa using mem_of_superset (by simpa using mem_of_superset (by\n          simpa using mem_univ x) (by intro y hy; trivial)) (by\n            intro y hy; trivial)\n      have hwithin :\n          Tendsto f (𝓝[Set.Ioi x ∪ Set.Iio x ∪ {x}] x) (𝓝 (f x)) := by\n        have h1 : Tendsto f (𝓝[Set.Ioi x] x) (𝓝 (f x)) := hr.tendsto_nhdsWithin\n        have h2 : Tendsto f (𝓝[Set.Iio x] x) (𝓝 l) := hleft.tendsto_nhdsWithin\n        have h3 : Tendsto f (𝓝[{x}] x) (𝓝 (f x)) := by\n          simpa [nhdsWithin_singleton] using (tendsto_pure.2 rfl)\n        have hsup :\n            Tendsto f (𝓝[Set.Ioi x ∪ Set.Iio x ∪ {x}] x) (𝓝 (f x)) := by\n          have : (𝓝[Set.Ioi x ∪ Set.Iio x ∪ {x}] x) ≤ 𝓝[Set.Ioi x] x := by\n            exact nhdsWithin_mono x (by intro y hy; exact hy.1.1)\n          exact h1.mono_left this\n        exact hsup\n      have hwithin' :\n          Tendsto f (𝓝[Set.Ioi x ∪ Set.Iio x ∪ {x}] x) (𝓝 l) := by\n        have h2 : Tendsto f (𝓝[Set.Iio x] x) (𝓝 l) := hleft.tendsto_nhdsWithin\n        have : (𝓝[Set.Ioi x ∪ Set.Iio x ∪ {x}] x) ≤ 𝓝[Set.Iio x] x := by\n          exact nhdsWithin_mono x (by intro y hy; exact hy.1.2.1)\n        exact h2.mono_left this\n      have : (𝓝 (f x)) = 𝓝 l := by\n        exact tendsto_nhds_unique (by simpa [hnhds] using hwithin)\n          (by simpa [hnhds] using hwithin')\n      exact (nhds_eq_nhds_iff.mp this).1\n    have : ContinuousAt f x := by\n      have hr' : Tendsto f (𝓝[Set.Ioi x] x) (𝓝 (f x)) := by\n        simpa using hr.tendsto_nhdsWithin\n      have hl' : Tendsto f (𝓝[Set.Iio x] x) (𝓝 (f x)) := by\n        simpa [hx] using hleft.tendsto_nhdsWithin\n      have : Tendsto f (𝓝 x) (𝓝 (f x)) := by\n        have hmono1 : (𝓝 x) ≤ 𝓝[Set.Ioi x] x := nhdsWithin_le_nhds\n        exact hr'.mono_left hmono1\n      exact this.continuousAt\n    exact this\n  exact hs.isBounded_image hcont",
      "\n  classical\n  rcases hs.isClosed.exists_compact_superset with ⟨K, hKc, hsK, hK⟩\n  have hcont : ContinuousOn f K := by\n    intro x hx\n    -- cadlag gives right-continuity; together with existence of left limits and first-countability,\n    -- it implies continuity on compact sets in a linear order topology (handled in Mathlib)\n    simpa [Function.RightContinuous] using (hf.right_continuous x)\n  have hKbd : IsBounded (f '' K) := by\n    simpa using hKc.isBounded_image (hcont.continuousOn)\n  exact hKbd.mono <| image_mono hsK",
      "\n  classical\n  by_contra h\n  rcases hs.exists_nhdsWithin_eq_iInf_nhdsWithin_of_isChain (fun x => (𝓝[≤] x)) with ⟨x, hx, hInf⟩\n  have hcont : ContinuousWithinAt f s x := by\n    by_cases hxmax : IsMax x s\n    · have hsx : s ⊆ Set.Ioi x ∪ {x} := by\n        intro y hy\n        by_cases hxy : x < y\n        · exact Or.inl hxy\n        · have : y = x := le_antisymm (not_lt.mp hxy) (hxmax.1 hy)\n          exact Or.inr this\n      have hIoi : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x\n      have hxmem : x ∈ s := hx\n      have : ContinuousWithinAt f (Set.Ioi x ∪ {x}) x := by\n        simpa [ContinuousWithinAt, nhdsWithin_union, nhdsWithin_singleton, hxmem] using\n          (hIoi.union (continuousWithinAt_const))\n      exact this.mono hsx\n    · rcases hf.left_limit x with ⟨l, hl⟩\n      have : ContinuousWithinAt f (Set.Iic x) x := by\n        have hle : Tendsto f (𝓝[<] x) (𝓝 l) := hl\n        have hright : ContinuousWithinAt f (Set.Ioi x) x := hf.right_continuous x\n        have hlim : Tendsto f (𝓝[≤] x) (𝓝 (f x)) := by\n          simpa [nhdsWithin_Iic] using (hle.sup_nhdsWithin_eq (by simpa [nhdsWithin_Ioi] using hright.tendsto_nhdsWithin))\n        simpa [ContinuousWithinAt] using hlim\n      exact this.mono (by intro y hy; exact hy.1)\n  have hbounded : IsBounded (f '' s) := hs.isBounded_image hcont\n  exact h hbounded",
      "\n  classical\n  rcases hs.isBounded_image_of_continuousOn ?_ with hsf\n  · simpa [Bornology.IsBounded] using hsf\n  · intro x hx\n    simpa [ContinuousWithinAt, Set.inter_eq_left.2 (by\n      intro y hy\n      exact hy.1)] using (hf.right_continuous x)",
      "\n  classical\n  rcases hs.isBounded_image ?_ with hbounded\n  · simpa [Bornology.IsBounded] using hbounded\n  · intro x hx\n    rcases hf.left_limit x with ⟨l, hl⟩\n    have hcl : ClusterPt (f x) (map f (𝓝[<] x)) := by\n      refine ⟨l, ?_⟩\n      simpa [ClusterPt, hl] using hl\n    have : ContinuousAt f x := by\n      have hmem : x ∈ closure (Set.Ioi x) := by\n        simpa [Set.closure_Ioi] using (by trivial : x ∈ Set.Icc x x)\n      have hrc := hf.right_continuous x\n      simpa [ContinuousWithinAt, nhdsWithin, Set.inter_assoc, Set.inter_left_comm,\n        Set.inter_comm] using hrc\n    simpa [ContinuousAt] using this.continuousWithinAt",
      "\n  classical\n  by_contra h\n  rcases Metric.not_isBounded_iff.1 h with ⟨x0, hx0⟩\n  have hx0' : ∀ n : ℕ, ∃ x ∈ f '' s, n < dist x x0 := by\n    intro n\n    simpa [not_forall] using hx0 n\n  choose x hxmem hxgt using hx0'\n  rcases hxmem 0 with ⟨t, ht_s, rfl⟩\n  have hts : (fun n : ℕ => t n) ∈ Set.univ := by trivial\n  have hcluster : ∃ a ∈ s, ClusterPt a (map (fun n : ℕ => t n) atTop) := by\n    have : ∃ a ∈ s, Tendsto (fun n : ℕ => t n) atTop (𝓝 a) := by\n      simpa using hs.tendsto_subseq (fun n : ℕ => t n) (by\n        intro n; exact (hxmem n).choose_spec.1)\n    rcases this with ⟨a, ha, hta⟩\n    refine ⟨a, ha, ?_⟩\n    exact hta.clusterPt\n  rcases hcluster with ⟨a, ha_s, ha_cl⟩\n  have hta : ∀ᶠ n in atTop, t n ∈ s := by\n    exact Filter.eventually_of_forall (fun n => (hxmem n).choose_spec.1)\n  have hfa : Tendsto (fun n : ℕ => f (t n)) atTop (𝓝 (f a)) := by\n    have hcont : ContinuousAt f a := by\n      have hright := hf.right_continuous a\n      have hleft := hf.left_limit a\n      rcases hleft with ⟨l, hl⟩\n      have : Tendsto f (𝓝 a) (𝓝 (f a)) := by\n        have hwithin : Tendsto f (𝓝[>] a) (𝓝 (f a)) := by\n          simpa [Function.RightContinuous] using hright\n        have hwithin' : Tendsto f (𝓝[<] a) (𝓝 l) := hl\n        have : l = f a := by\n          have hne : NeBot (𝓝[<] a) := by infer_instance\n          have hlim1 : Tendsto f (𝓝[<] a) (𝓝 (f a)) := by\n            have : ContinuousWithinAt f (Set.Iio a) a := by\n              simpa [ContinuousWithinAt, nhdsWithin_Iio_eq] using (by\n                intro x; exact (hf.right_continuous x))\n            simpa [nhdsWithin_Iio_eq] using this.tendsto_nhdsWithin\n          exact (tendsto_nhds_unique hwithin' hlim1)\n        simpa [this] using (tendsto_nhdsWithin_of_tendsto_nhds_of_eventually_within\n          (by simpa using tendsto_id) (by\n            filter_upwards [Filter.eventually_of_forall (fun x => by\n              by_cases hx : x = a\n              · simp [hx]\n              · exact Or.inl hx)] with x hx\n            simpa using hx))\n      exact (ContinuousAt.mk this)\n    have : Tendsto (fun n : ℕ => t n) atTop (𝓝 a) := by\n      have : ClusterPt a (map (fun n : ℕ => t n) atTop) := ha_cl\n      simpa [ClusterPt, Filter.map_map] using this\n    exact (hcont.tendsto.comp this)\n  have hbounded : IsBounded (Set.range (fun n : ℕ => f (t n))) := by\n    have : IsCompact (Set.range (fun n : ℕ => t n)) := by\n      exact hs.image (by\n        refine continuous_id'.continuousAt.continuousWithinAt)\n    have : IsBounded (f '' Set.range (fun n : ℕ => t n)) := by\n      exact hs.isBounded_image ?_\n    simpa [Set.image_image, Set.range_comp] using this\n  rcases Metric.isBounded_iff.1 hbounded with ⟨R, hR⟩\n  have : ∀ n : ℕ, dist (f (t n)) x0 ≤ R := by\n    intro n\n    have : f (t n) ∈ Set.range (fun n : ℕ => f (t n)) := ⟨n, rfl⟩\n    exact hR this\n  have : ∀ n : ℕ, n < R := by\n    intro n\n    have hn : n < dist (f (t n)) x0 := hxgt n\n    exact lt_of_lt_of_le hn (this n)\n  have : False := by\n    have := this (Nat.ceil R + 1)\n    exact not_lt_of_ge (Nat.le_of_lt_succ (Nat.lt_succ_self _)) this\n  exact this",
      "\n  classical\n  by_contra h\n  have : ∀ x ∈ s, ¬ Tendsto f (𝓝 x ⊓ 𝓟 s) (𝓝 (f x)) := by\n    intro x hx hcont\n    have hbounded : IsBounded (f '' s) :=\n      (hs.isBounded_image_of_continuousOn (by\n        intro y hy\n        exact (continuousWithinAt_univ.1 (by\n          simpa [ContinuousWithinAt] using (hcont.mono_left inf_le_left)))) )\n    exact h hbounded\n  obtain ⟨x, hx, -⟩ := hs.exists_clusterPt_of_forall_not_isClosed (by\n    intro x hx\n    have : x ∈ s := hx\n    exact False.elim (this.elim))\n  exact False.elim (h (hs.isBounded_image_of_continuousOn (by\n    intro x hx\n    have hrc := hf.right_continuous x\n    have hlim := hf.left_limit x\n    have : ContinuousWithinAt f s x := by\n      by_cases hxs : x ∈ s\n      · have : s ⊆ Set.Ioi x ∪ {x} ∪ Set.Iio x := by\n          intro y hy\n          by_cases hxy : x < y\n          · exact Or.inl hxy\n          · by_cases hyx : y < x\n            · exact Or.inr (Or.inr hyx)\n            · have : y = x := le_antisymm (le_of_not_gt hyx) (le_of_not_gt hxy)\n              exact Or.inr (Or.inl this)\n        have h1 : ContinuousWithinAt f (s ∩ Set.Ioi x) x := by\n          simpa [ContinuousWithinAt, nhdsWithin_inter] using (hrc.mono (by intro y hy; exact hy.2))\n        have h2 : ∃ l, Tendsto f (𝓝[<] x) (𝓝 l) := hlim\n        exact (h1.mono (by intro y hy; exact hy.1))\n      · exact (continuousWithinAt_of_not_mem (by simpa) )\n    exact this))",
