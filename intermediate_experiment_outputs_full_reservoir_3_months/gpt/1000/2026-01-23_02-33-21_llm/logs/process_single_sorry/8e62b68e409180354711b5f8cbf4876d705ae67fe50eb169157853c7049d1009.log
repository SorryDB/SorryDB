lemma isBounded_image_of_isCadlag_of_isCompact {E : Type*}
    [FirstCountableTopology ι] [PseudoMetricSpace E] {f : ι → E}
    (hf : IsCadlag f) {s : Set ι} (hs : IsCompact s) :
    IsBounded (f '' s) := by
  classical
  by_contra hbounded
  have h_univ : (s ∩ f ⁻¹' closedBall (f (Classical.choice (hs.nonempty_iff.1 ?_))) 0) = ∅ := by
    · by_cases hsne : s.Nonempty
      · rcases hsne with ⟨x, hx⟩
        have : x ∈ s ∩ f ⁻¹' closedBall (f x) 0 := by
          refine ⟨hx, ?_⟩
          simpa [closedBall, ball, Set.mem_setOf_eq] using (show dist (f x) (f x) ≤ (0 : ℝ) by simp)
        exact Set.nonempty_iff_ne_empty.1 ⟨x, this⟩ |> False.elim
      · have : s = ∅ := by simpa [Set.not_nonempty_iff_eq_empty] using hsne
        simp [this]
  have hsne : s.Nonempty := by
    by_contra hsne
    have : s = ∅ := by simpa [Set.not_nonempty_iff_eq_empty] using hsne
    simp [this] at hbounded
  have h_cont : ContinuousOn f s := by
    refine hs.continuousOn_of_forall_continuousWithinAt ?_
    intro x hx
    have h_right := hf.right_continuous x
    have h_left := hf.left_limit x
    rcases h_left with ⟨l, hl⟩
    have : ContinuousWithinAt f s x := by
      -- On a compact set, cadlag implies continuity at points in the set: use `continuousWithinAt` from right continuity
      -- and existence of left limit gives sequential continuity in first countable spaces.
      -- We use that `hs.continuousWithinAt` can be obtained from `ContinuousWithinAt` on `Set.Ioi x` and `Tendsto` on `𝓝[<] x`.
      -- Combine by `continuousWithinAt_of_tendsto_nhdsWithin` with basis `Ioi`/`Iio`.
      refine (continuousWithinAt_of_tendsto_nhdsWithin ?_).1
      · exact h_right
      · exact hl
    exact this
  have h_comp : IsCompact (f '' s) := hs.image_of_continuousOn h_cont
  exact hbounded (h_comp.isBounded)
