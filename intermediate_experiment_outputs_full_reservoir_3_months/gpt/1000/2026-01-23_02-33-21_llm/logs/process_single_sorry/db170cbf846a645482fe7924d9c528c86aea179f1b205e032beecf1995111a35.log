    have hdis := hM'.disjoint heM' (by
      have : f ∈ M' := by
        have : f ∈ M := hfM
        exact False.elim (heM this)
      exact this) (by
        intro h
        exact heM (h ▸ hfM))
    exact hdis.le_bot ⟨hex, hxf⟩
