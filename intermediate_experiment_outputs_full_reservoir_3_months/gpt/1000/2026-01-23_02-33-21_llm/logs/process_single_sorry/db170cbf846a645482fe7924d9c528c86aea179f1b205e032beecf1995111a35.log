      "\n    classical\n    have hsub : V(G, M') ⊆ V(G, M) := by\n      intro x hx\n      exact hsu (hM'.subset_vertexSet hx)\n    have hle : M'.encard ≤ (V(G, M')).encard := by\n      simpa [two_mul] using (hM'.encard_le_encard_vertices (G := G) (M := M'))\n    exact hle.trans (encard_le_encard hsub)",
      "\n    by_contra hlt\n    have hpos : (M'.encard - M.encard) ≠ 0 := by\n      have : M.encard < M'.encard := lt_of_not_ge hlt\n      exact Nat.sub_ne_zero_of_lt this\n    rcases Nat.exists_eq_succ_of_ne_zero hpos with ⟨k, hk⟩\n    have hk' : M.encard + (k + 1) = M'.encard := by\n      have : M.encard ≤ M'.encard := le_of_not_ge hlt\n      exact (Nat.add_sub_of_le this).trans (by simpa [hk, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc])\n    have hsub : V(G, M') ⊆ V(G) := by\n      intro v hv\n      rcases hv with ⟨e, heM', hv⟩\n      exact (hM'.subset heM').1\n    have hVeq : V(G, M') = V(G) := by\n      apply le_antisymm\n      · exact hsub\n      · intro v hv\n        exact hsu hv\n    have : M'.encard ≤ M.encard := by\n      simpa [hVeq] using (hM.degree_le_one (v := (Classical.choice (nonempty_of_inhabited α))))\n    exact hlt this",
      "\n    classical\n    by_contra hlt\n    have hne : (V(G, M') \\ V(G, M)).Nonempty := by\n      by_contra hne'\n      have hsub : V(G, M') ⊆ V(G, M) := by\n        intro x hx\n        by_contra hx'\n        exact hne' ⟨x, hx, hx'⟩\n      have : V(G) ⊆ V(G, M') := by\n        intro x hx\n        exact hsub (hsu hx)\n      have hle : M.encard ≤ M'.encard :=\n        Graph.IsMatching.encard_le_of_vertex_subset hM hM' this\n      exact not_lt_of_ge hle hlt\n    rcases hne with ⟨x, hxM', hxM⟩\n    have hxV : x ∈ V(G) := by\n      exact (V_subset_vertexSet (G := G) (M := M') hxM')\n    exact hxM (hsu hxV)",
      "\n    by_contra hlt\n    have hnle : ¬ M'.encard ≤ M.encard := by\n      simpa [not_le] using hlt\n    have hne : (M' \\ M).Nonempty := by\n      by_contra hE\n      have hsub : M' ⊆ M := by\n        intro e he\n        by_contra hem\n        exact hE ⟨e, ⟨he, hem⟩⟩\n      exact hnle (encard_le_encard hsub)\n    rcases hne with ⟨e, he⟩\n    have heM' : e ∈ M' := he.1\n    have heM : e ∉ M := he.2\n    have heE : e ∈ E(G) := hM'.subset heM'\n    rcases (edge_mem_iff_exists_vertex_mem heE) with ⟨v, hvV, hve⟩\n    have hv_in_M : v ∈ V(G, M) := hsu hvV\n    rcases hv_in_M with ⟨f, hfM, hvf⟩\n    have hfe : f ≠ e := by\n      intro h\n      exact heM (h ▸ hfM)\n    exact (hM'.disjoint heM' hfM hfe).le_bot ⟨hve, hvf⟩",
      "\n    classical\n    by_cases hfin : M.Finite\n    · have hVM : V(G, M) = V(G) := by\n        apply le_antisymm\n        · exact V_subset_vertexSet\n        · exact hsu\n      have hsub : M' ⊆ M := by\n        intro e he\n        by_contra hne\n        have hVsub : V(G, e) ⊆ V(G, M) := by\n          intro v hv\n          have : v ∈ V(G) := V_subset_vertexSet hv\n          exact hsu this\n        have hdis : Disjoint (V(G, e)) (V(G, M)) := by\n          have hmemb : ∀ {f}, f ∈ M → f ≠ e → Disjoint (V(G, f)) (V(G, e)) := by\n            intro f hf hfe\n            simpa [disjoint_left, and_left_comm, and_assoc] using hM.disjoint hf (by simpa using he) (by simpa [eq_comm] using hfe)\n          have : Disjoint (V(G, e)) (⋃ f ∈ M, V(G, f)) := by\n            refine disjoint_iUnion_left.2 ?_\n            intro f\n            refine disjoint_iUnion_left.2 ?_\n            intro hf\n            by_cases hfe : f = e\n            · subst hfe\n              exact (hM'.subset he).elim\n            · exact (hmemb hf hfe).symm\n          simpa [V_edges_eq_iUnion] using this\n        have : V(G, e) ⊆ ⊥ := hdis.le_bot.trans hVsub\n        have hempty : V(G, e) = ∅ := by\n          apply eq_empty_iff_forall_not_mem.2\n          intro v hv\n          exact (this hv).elim\n        have : e ∉ E(G) := by\n          intro hE\n          have := nonempty_of_mem_edgeSet hE\n          rcases this with ⟨v, hv⟩\n          simpa [hempty] using hv\n        exact this (hM'.subset he)\n      have hcard : M'.encard ≤ M'.toFinite.encard := by\n        simpa using (le_of_eq (by simp))\n      have : M'.encard ≤ M.encard := by\n        have hM'fin : M'.Finite := hfin.subset hsub\n        simpa [Set.encard_eq_coe_fintype_card, hM'fin, hfin] using (encard_le_encard hsub)\n      exact this\n    · simp [Set.encard_eq_top.2 hfin] at *",
      "\n    classical\n    by_contra hlt\n    have hne : (M' \\ M).Nonempty := by\n      by_contra hempty\n      have hsub : M' ⊆ M := by\n        intro e he\n        by_contra hnot\n        have : e ∈ M' \\ M := ⟨he, hnot⟩\n        exact hempty ⟨e, this⟩\n      have henc : M'.encard ≤ M.encard := encard_mono hsub\n      exact hlt.not_le henc\n    rcases hne with ⟨e, heM', heM⟩\n    have hev : (V(G, e) ∩ V(G, M) = ∅) := by\n      ext v\n      constructor\n      · intro hv\n        rcases hv with ⟨hve, hvM⟩\n        rcases hvM with ⟨f, hfM, hvf⟩\n        have hne' : e ≠ f := by\n          intro h\n          exact heM (h ▸ hfM)\n        have hdis := hM.disjoint heM hfM hne'\n        exact (hdis.le_bot ⟨hve, hvf⟩).elim\n      · intro hv\n        exact (not_mem_empty _ hv).elim\n    have hVsub : V(G, e) ⊆ V(G, M) := by\n      intro v hv\n      have hvG : v ∈ V(G) := by\n        exact ⟨e, hM'.subset heM', hv⟩\n      exact hsu hvG\n    have : V(G, e) = ∅ := by\n      apply eq_empty_iff_forall_not_mem.2\n      intro v hv\n      have : v ∈ V(G, e) ∩ V(G, M) := ⟨hv, hVsub hv⟩\n      simpa [hev] using this\n    have : e ∉ E(G) := by\n      intro heE\n      have : V(G, e).Nonempty := by\n        rcases G.exists_vertex_mem_of_mem_edge heE with ⟨v, hv⟩\n        exact ⟨v, hv⟩\n      simpa [this.ne_empty] using this\n    exact this (hM'.subset heM')",
      "\n    classical\n    by_contra hle\n    have hlt : M.encard < M'.encard := lt_of_not_ge hle\n    obtain ⟨e, heM', heM⟩ := exists_mem_not_mem_of_encard_lt_encard hlt\n    have heE : e ∈ E(G) := hM'.subset heM'\n    rcases (exists_of_mem_edgeSet heE) with ⟨x, y, rfl, hx, hy⟩\n    have hxV : x ∈ V(G, M) := hsu hx\n    have hyV : y ∈ V(G, M) := hsu hy\n    rcases hxV with ⟨f, hfM, hxf⟩\n    rcases hyV with ⟨g, hgM, hyg⟩\n    have hfne : f = e := by\n      by_contra hne\n      have : x ∈ (V(G, f) ∩ V(G, e)) := ⟨hxf, by simpa [V]⟩\n      exact (hM'.disjoint (by\n        exact ⟨heM', by simpa [E]⟩) (by\n          have : f ∈ M' := by\n            by_contra hfM'\n            exact heM (by\n              have : f ∈ M \\ M' := ⟨hfM, hfM'⟩\n              exact this.1)\n          exact ⟨this, by simpa [E]⟩) hne).le_bot this\n    have hgne : g = e := by\n      by_contra hne\n      have : y ∈ (V(G, g) ∩ V(G, e)) := ⟨hyg, by simpa [V]⟩\n      exact (hM'.disjoint (by\n        exact ⟨heM', by simpa [E]⟩) (by\n          have : g ∈ M' := by\n            by_contra hgM'\n            exact heM (by\n              have : g ∈ M \\ M' := ⟨hgM, hgM'⟩\n              exact this.1)\n          exact ⟨this, by simpa [E]⟩) hne).le_bot this\n    have : e ∈ M := by\n      simpa [hfne] using hfM\n    exact heM this",
      "\n    by_contra hlt\n    have hne : (V(G) \\ V(G, M)).Nonempty := by\n      rcases hM'.subset with hsub\n      rcases (Set.encard_lt_encard.1 hlt) with ⟨e, heM', heM⟩\n      have heE : e ∈ E(G) := hsub heM'\n      rcases (G.edge_mem_iff.1 heE) with ⟨x, hxV, y, hyV, hxy⟩\n      have hxM : x ∈ V(G, M) := hsu hxV\n      have hyM : y ∈ V(G, M) := hsu hyV\n      have : e ∈ M := by\n        by_contra hem\n        have : e ∈ M' \\ M := ⟨heM', hem⟩\n        exact heM this\n      have hxM' : x ∈ V(G, M') := ⟨e, heM', x, y, hxy⟩\n      have hyM' : y ∈ V(G, M') := ⟨e, heM', y, x, hxy.symm⟩\n      refine ⟨x, ?_⟩\n      refine ⟨hxV, ?_⟩\n      intro hx\n      exact (hM.disjoint this this (by simpa using (by rfl))).le_bot ⟨⟨e, this, x, y, hxy⟩, ⟨e, this, x, y, hxy⟩⟩\n    rcases hne with ⟨x, hx⟩\n    exact hx.2 (hsu hx.1)",
