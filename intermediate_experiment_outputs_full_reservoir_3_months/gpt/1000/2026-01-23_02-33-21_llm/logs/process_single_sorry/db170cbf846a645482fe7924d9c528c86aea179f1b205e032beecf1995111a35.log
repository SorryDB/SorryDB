lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    classical
    by_cases hfin : M'.Finite
    ·
      have hsub : M' ⊆ M := by
        intro e he
        by_contra hne
        have : Disjoint V(G, e) V(G, M) := by
          refine disjoint_iUnion_right.mpr ?_
          intro f
          by_cases hf : f ∈ M
          ·
            have := hM'.disjoint he hf (by
              intro hEq
              exact hne (hEq ▸ hf))
            simpa [V] using this
          ·
            simpa [V, hf] using disjoint_empty_right
        have heV : V(G, e) ⊆ V(G, M) := by
          intro v hv
          refine hsu ?_
          exact ⟨e, hM'.subset he, hv⟩
        have : V(G, e) = ∅ := by
          apply eq_empty_iff_forall_not_mem.mpr
          intro v hv
          exact (this.le_bot ⟨hv, heV hv⟩)
        have : (V(G, e)).Nonempty := by
          rcases edge_vertex_nonempty (G := G) (e := e) (hM'.subset he) with ⟨v, hv⟩
          exact ⟨v, hv⟩
        exact this.ne_empty (by simpa using this)
      exact (encard_le_encard hsub).trans_eq (by rfl)
    ·
      simpa [Set.encard_eq_top.2 hfin] using (le_top : (M'.encard : ℕ∞) ≤ M.encard)
