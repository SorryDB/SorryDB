      by_contra hempty
      have hsub : M' ⊆ M := by
        intro e he
        by_contra hnm
        have : e ∈ M' \ M := ⟨he, hnm⟩
        exact hempty ⟨e, this⟩
      have hle : M'.encard ≤ M.encard := encard_le_encard hsub
      exact hlt (not_le.mpr hlt) hle
