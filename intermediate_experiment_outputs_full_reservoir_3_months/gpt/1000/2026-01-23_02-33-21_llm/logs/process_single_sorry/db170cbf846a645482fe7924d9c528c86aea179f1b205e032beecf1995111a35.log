lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    classical
    by_contra hlt
    have hVle : V(G, M') ⊆ V(G) := by
      intro v hv
      rcases hv with ⟨e, heM', hv⟩
      exact (hM'.subset heM').1
    have hV' : V(G, M') ⊆ V(G, M) := hVle.trans hsu
    have hcardV' : (V(G, M')).encard ≤ (V(G, M)).encard := encard_le_encard hV'
    have hcardM' : 2 * M'.encard = (V(G, M')).encard := by
      simpa [two_mul] using (hM'.encard_vertexSet_eq_two_mul_encard)
    have hcardM : (V(G, M)).encard = 2 * M.encard := by
      simpa [two_mul] using (hM.encard_vertexSet_eq_two_mul_encard).symm
    have hle : 2 * M'.encard ≤ 2 * M.encard := by
      simpa [hcardM', hcardM] using hcardV'
    have hle' : M'.encard ≤ M.encard := by
      exact Nat.le_of_mul_le_mul_left hle (by decide : 0 < (2 : ℕ))
    exact hlt (hle'.trans_le le_rfl)
