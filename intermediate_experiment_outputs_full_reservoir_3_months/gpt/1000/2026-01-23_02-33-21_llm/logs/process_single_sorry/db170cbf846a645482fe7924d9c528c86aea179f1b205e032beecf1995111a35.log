            by_contra hgM'
            exact heM (by
              have : g ∈ M \ M' := ⟨hgM, hgM'⟩
              exact this.1)
          exact ⟨this, by simpa [E]⟩) hne).le_bot this
    have : e ∈ M := by
      simpa [hfne] using hfM
    exact heM this
