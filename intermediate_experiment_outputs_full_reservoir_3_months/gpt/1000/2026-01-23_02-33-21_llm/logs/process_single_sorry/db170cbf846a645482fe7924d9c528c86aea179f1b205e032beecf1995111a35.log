lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
    classical
    by_contra hlt
    have hne : (V(G, M') \ V(G, M)).Nonempty := by
      by_contra hne'
      have hsub : V(G, M') ⊆ V(G, M) := by
        intro x hx
        by_contra hx'
        exact hne' ⟨x, hx, hx'⟩
      have : V(G) ⊆ V(G, M') := by
        intro x hx
        exact hsub (hsu hx)
      have hle : M.encard ≤ M'.encard :=
        Graph.IsMatching.encard_le_of_vertex_subset hM hM' this
      exact not_lt_of_ge hle hlt
    rcases hne with ⟨x, hxM', hxM⟩
    have hxV : x ∈ V(G) := by
      exact (V_subset_vertexSet (G := G) (M := M') hxM')
    exact hxM (hsu hxV)
```
