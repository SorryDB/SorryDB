lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intros w args cs h
  unfold assert_bits at h
  simp only [beq_iff_eq, Bool.decide_or, Vector.all_eq_true, Bool.or_eq_true, decide_eq_true_eq,
    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  clear h' h''
  revert cs
  induction w with
  | zero =>
      intro cs
      cases (Nat.not_lt_zero i h)
  | succ w ih =>
      intro cs
      have hi : i = 0 ∨ ∃ j, i = j.succ := Nat.eq_zero_or_exists_eq_succ i
      rcases hi with rfl | ⟨j, rfl⟩
      · simp [assert_bits_e, assert_bit_e, Cs.eval]
      · have hj : j < w := Nat.lt_of_succ_lt_succ h
        simpa [assert_bits_e, Vector.foldl, assert_bit_e] using (ih (args := args.tail) (i := j) hj cs (by
          simpa using h))
