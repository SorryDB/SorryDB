      "\n  classical\n  -- Consider all nonempty subsets of `S` and map each to its sum.\n  -- There are `2^10 - 1 = 1023` nonempty subsets; each sum lies in `[10, 990]`, hence at most `981` values.\n  -- By pigeonhole, two distinct nonempty subsets have the same sum; removing their intersection yields disjoint\n  -- nonempty subsets with the same sum.\n  have hcardS : S.card = 10 := h₀\n  let T : Finset (Finset ℕ) := (S.powerset.erase ∅)\n  have hT_nonempty : T.Nonempty := by\n    have : ({S.min' (by\n        have : S.Nonempty := by\n          -- from card = 10\n          simpa [Finset.card_pos] using (by\n            have : 0 < S.card := by simpa [hcardS] using (show 0 < (10:ℕ) from by decide)\n            exact this) } : Finset ℕ) ⊆ S := by\n      intro x hx\n      have hx' : x = S.min' (by\n          have : S.Nonempty := by\n            simpa [Finset.card_pos] using (by\n              have : 0 < S.card := by simpa [hcardS] using (show 0 < (10:ℕ) from by decide)\n              exact this) ) := by\n        simpa using hx\n      subst hx'\n      exact Finset.min'_mem _ _\n    refine ⟨{S.min' (by\n        have : S.Nonempty := by\n          simpa [Finset.card_pos] using (by\n            have : 0 < S.card := by simpa [hcardS] using (show 0 < (10:ℕ) from by decide)\n            exact this) )}, ?_⟩\n    have hsub : ({S.min' (by\n        have : S.Nonempty := by\n          simpa [Finset.card_pos] using (by\n            have : 0 < S.card := by simpa [hcardS] using (show 0 < (10:ℕ) from by decide)\n            exact this) )} : Finset ℕ) ⊆ S := by\n      intro x hx\n      have hx' : x = S.min' (by\n          have : S.Nonempty := by\n            simpa [Finset.card_pos] using (by\n              have : 0 < S.card := by simpa [hcardS] using (show 0 < (10:ℕ) from by decide)\n              exact this) ) := by\n        simpa using hx\n      subst hx'\n      exact Finset.min'_mem _ _\n    have hne : ({S.min' (by\n        have : S.Nonempty := by\n          simpa [Finset.card_pos] using (by\n            have : 0 < S.card := by simpa [hcardS] using (show 0 < (10:ℕ) from by decide)\n            exact this) )} : Finset ℕ) ≠ ∅ := by\n      simp\n    have : ({S.min' (by\n        have : S.Nonempty := by\n          simpa [Finset.card_pos] using (by\n            have : 0 < S.card := by simpa [hcardS] using (show 0 < (10:ℕ) from by decide)\n            exact this) )} : Finset ℕ) ∈ S.powerset := by\n      exact Finset.mem_powerset.2 hsub\n    have : ({S.min' (by\n        have : S.Nonempty := by\n          simpa [Finset.card_pos] using (by\n            have : 0 < S.card := by simpa [hcardS] using (show 0 < (10:ℕ) from by decide)\n            exact this) )} : Finset ℕ) ∈ S.powerset.erase ∅ := by\n      simp [Finset.mem_erase, this, hne]\n    simpa [T] using this\n  have hT_card : T.card = 2 ^ S.card - 1 := by\n    -- `powerset` has card `2^|S|`, and we erase `∅`.\n    have : (S.powerset).card = 2 ^ S.card := by simpa using Finset.card_powerset S\n    have hempty : (∅ : Finset ℕ) ∈ S.powerset := by simp\n    have : (S.powerset.erase (∅ : Finset ℕ)).card = (S.powerset).card - 1 := by\n      simpa [Finset.card_erase_of_mem hempty]\n    simpa [T, this] using this.trans (by simp [this])\n  have hT_card' : T.card = 1023 := by\n    -- since `S.card = 10`.\n    have : 2 ^ S.card - 1 = 1023 := by\n      simp [hcardS]\n    simpa [hT_card, this]\n  -- Bound sums: each element is in [10,99], so any nonempty subset has sum in [10,990].\n  have hsum_range :\n      ∀ A : Finset ℕ, A ∈ T →\n        (10 ≤ (∑ x ∈ A, x)) ∧ (∑ x ∈ A, x) ≤ 990 := by\n    intro A hA\n    have hA' : A ⊆ S := by\n      have : A ∈ S.powerset := by\n        have : A ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hA\n        exact (Finset.mem_erase.1 this).2\n      exact Finset.mem_powerset.1 this\n    have hAne : A.Nonempty := by\n      have : A ≠ ∅ := by\n        have : A ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hA\n        exact (Finset.mem_erase.1 this).1\n      simpa [Finset.nonempty_iff_ne_empty] using this\n    have hmin : ∀ x ∈ A, 10 ≤ x := by\n      intro x hx\n      have hxS : x ∈ S := hA' hx\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      exact (Finset.mem_Ico.1 hxI).1\n    have hmax : ∀ x ∈ A, x ≤ 99 := by\n      intro x hx\n      have hxS : x ∈ S := hA' hx\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have : x < 100 := (Finset.mem_Ico.1 hxI).2\n      exact Nat.le_of_lt_succ (by simpa using this)\n    have hlow : 10 ≤ (∑ x ∈ A, x) := by\n      rcases hAne with ⟨a, haA⟩\n      have : 10 ≤ a := hmin a haA\n      have hsum_ge : a ≤ (∑ x ∈ A, x) := by\n        simpa using (Finset.single_le_sum (fun _ _ => Nat.zero_le _) haA)\n      exact le_trans this hsum_ge\n    have hhigh : (∑ x ∈ A, x) ≤ 990 := by\n      have hcardA : A.card ≤ 10 := by\n        have : A.card ≤ S.card := Finset.card_le_card hA'\n        simpa [hcardS] using this\n      have : (∑ x ∈ A, x) ≤ ∑ _x ∈ A, 99 := by\n        refine Finset.sum_le_sum ?_\n        intro x hx\n        exact hmax x hx\n      have : (∑ x ∈ A, x) ≤ 99 * A.card := by\n        simpa [Finset.sum_const_nat, Nat.mul_comm] using this\n      have : 99 * A.card ≤ 99 * 10 := by\n        exact Nat.mul_le_mul_left 99 hcardA\n      have : 99 * A.card ≤ 990 := by simpa using (le_trans this (by decide : 99 * 10 ≤ 990))\n      exact le_trans (by\n        -- rewrite `99 * A.card` as RHS\n        simpa [Nat.mul_comm] using this) (by\n        simpa [Nat.mul_comm] using this)\n    exact ⟨hlow, hhigh⟩\n  -- Define the sum function on `T`.\n  let f : (Finset ℕ) → ℕ := fun A => ∑ x ∈ A, x\n  have hf_cod : ∀ A ∈ T, f A ∈ Finset.Icc 10 990 := by\n    intro A hA\n    have hr := hsum_range A hA\n    exact Finset.mem_Icc.2 hr\n  -- Pigeonhole: `T.card = 1023` but `Icc 10 990` has card 981.\n  have hcod_card : (Finset.Icc 10 990 : Finset ℕ).card = 981 := by\n    -- card of Icc a b is b+1-a when a≤b.\n    simp\n  have hexists_collision :\n      ∃ A ∈ T, ∃ B ∈ T, A ≠ B ∧ f A = f B := by\n    have : T.card > (Finset.Icc 10 990 : Finset ℕ).card := by\n      simp [hT_card', hcod_card]\n    -- Use `Finset.exists_ne_map_eq_of_card_lt` style lemma via `Finset` pigeonhole.\n    -- We proceed by contradiction using injectivity and card bounds.\n    by_contra h\n    have hinj : Set.InjOn f T := by\n      intro A hA B hB hEq\n      by_contra hne\n      exact h ⟨A, hA, B, hB, hne, hEq⟩\n    have hcard_image : (T.image f).card = T.card := Finset.card_image_iff.2 hinj\n    have himage_sub : T.image f ⊆ (Finset.Icc 10 990 : Finset ℕ) := by\n      intro y hy\n      rcases Finset.mem_image.1 hy with ⟨A, hA, rfl⟩\n      exact hf_cod A hA\n    have : (T.image f).card ≤ (Finset.Icc 10 990 : Finset ℕ).card := Finset.card_le_card himage_sub\n    exact (not_lt_of_ge (by simpa [hcard_image] using this)) this\n  rcases hexists_collision with ⟨A, hA, B, hB, hneAB, hsumEq⟩\n  -- Let S₁ = A \\ B, S₂ = B \\ A; they are disjoint and have equal sums.\n  let S₁ : Finset ℕ := A \\ B\n  let S₂ : Finset ℕ := B \\ A\n  have hdisj : Disjoint S₁ S₂ := by\n    exact Finset.disjoint_sdiff_sdiff\n  have hsub1 : S₁ ⊆ S := by\n    intro x hx\n    have hxA : x ∈ A := (Finset.mem_sdiff.1 hx).1\n    have hA' : A ⊆ S := by\n      have : A ∈ S.powerset := by\n        have : A ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hA\n        exact (Finset.mem_erase.1 this).2\n      exact Finset.mem_powerset.1 this\n    exact hA' hxA\n  have hsub2 : S₂ ⊆ S := by\n    intro x hx\n    have hxB : x ∈ B := (Finset.mem_sdiff.1 hx).1\n    have hB' : B ⊆ S := by\n      have : B ∈ S.powerset := by\n        have : B ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hB\n        exact (Finset.mem_erase.1 this).2\n      exact Finset.mem_powerset.1 this\n    exact hB' hxB\n  have hS₁ne : S₁.Nonempty := by\n    have : ¬ A ⊆ B := by\n      intro hAB\n      have : A = B := by\n        apply Finset.eq_of_subset_of_card_le hAB\n        have hBA : B ⊆ A := by\n          intro x hx\n          by_contra hxA\n          have : x ∈ S₂ := by\n            exact Finset.mem_sdiff.2 ⟨hx, hxA⟩\n          -- then S₂ nonempty and sum differs unless compensated; but if A⊆B and x∈B\\A, sums can't be equal.\n          -- Contradiction from equal sums and nonnegativity:\n          have hxpos : 0 < x := Nat.pos_of_ne_zero (by\n            intro hx0\n            have : x ∈ Finset.Ico 10 100 := h₁ (by\n              have hB' : B ⊆ S := by\n                have : B ∈ S.powerset := by\n                  have : B ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hB\n                  exact (Finset.mem_erase.1 this).2\n                exact Finset.mem_powerset.1 this\n              exact hB' hx\n            )\n            have : 10 ≤ x := (Finset.mem_Ico.1 this).1\n            simpa [hx0] using this\n          )\n          exact False.elim (by\n            -- use card: if A ⊆ B and x∈B\\A, then sum B > sum A\n            have hxBnotA : x ∈ B ∧ x ∉ A := ⟨hx, hxA⟩\n            have : x ≤ ∑ y ∈ B, y := by\n              simpa using (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hxBnotA.1)\n            have : ∑ y ∈ A, y < ∑ y ∈ B, y := by\n              have hAB' : (∑ y ∈ A, y) ≤ ∑ y ∈ B, y :=\n                Finset.sum_le_sum_of_subset_of_nonneg hAB (fun _ _ => Nat.zero_le _)\n              have hx_in_diff : x ∈ B \\ A := Finset.mem_sdiff.2 hxBnotA\n              have hdiff_ne : (B \\ A).Nonempty := ⟨x, hx_in_diff⟩\n              have hpossum : 0 < ∑ y ∈ (B \\ A), y := by\n                rcases hdiff_ne with ⟨z, hz⟩\n                have hzpos : 0 < z := by\n                  have hzS : z ∈ S := by\n                    have hB'' : B ⊆ S := by\n                      have : B ∈ S.powerset := by\n                        have : B ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hB\n                        exact (Finset.mem_erase.1 this).2\n                      exact Finset.mem_powerset.1 this\n                    exact hB'' (Finset.mem_sdiff.1 hz).1\n                  have hzI : z ∈ Finset.Ico 10 100 := h₁ hzS\n                  have : 10 ≤ z := (Finset.mem_Ico.1 hzI).1\n                  exact lt_of_lt_of_le (by decide : 0 < (10:ℕ)) this\n                have : z ≤ ∑ y ∈ (B \\ A), y := by\n                  simpa using (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hz)\n                exact lt_of_lt_of_le hzpos this\n              -- sum B = sum A + sum (B\\A) when A ⊆ B and disjoint\n              have hdecomp :\n                  (∑ y ∈ B, y) = (∑ y ∈ A, y) + (∑ y ∈ (B \\ A), y) := by\n                have hdis : Disjoint A (B \\ A) := by\n                  exact Finset.disjoint_left.2 (by\n                    intro y hyA hyDiff\n                    exact (Finset.mem_sdiff.1 hyDiff).2 hyA)\n                have hunion : A ∪ (B \\ A) = B := by\n                  ext y; constructor\n                  · intro hy\n                    rcases Finset.mem_union.1 hy with hy | hy\n                    · exact hAB hy\n                    · exact (Finset.mem_sdiff.1 hy).1\n                  · intro hyB\n                    by_cases hyA : y ∈ A\n                    · exact Finset.mem_union.2 (Or.inl hyA)\n                    · exact Finset.mem_union.2 (Or.inr (Finset.mem_sdiff.2 ⟨hyB, hyA⟩))\n                have := (Finset.sum_union hdis).symm\n                -- adjust with `hunion`\n                simpa [hunion, Finset.sum_add_distrib] using this\n              have : (∑ y ∈ A, y) < (∑ y ∈ B, y) := by\n                -- from decomposition and positive\n                have := congrArg (fun t => (∑ y ∈ A, y) < t) hdecomp\n                -- easier:\n                have : (∑ y ∈ A, y) < (∑ y ∈ A, y) + (∑ y ∈ (B \\ A), y) := Nat.lt_add_of_pos_right hpossum\n                simpa [hdecomp] using this\n              exact this\n            exact (lt_irrefl _ (by simpa [f, Finset.sum_attach] using this.trans_eq hsumEq))\n          ))\n        exact hBA\n      exact this\n    have hx : A \\ B ≠ ∅ := by\n      intro hzero\n      have hAB : A ⊆ B := by\n        intro x hxA\n        by_contra hxB\n        have : x ∈ A \\ B := Finset.mem_sdiff.2 ⟨hxA, hxB⟩\n        simpa [hzero] using this\n      exact this (by\n        intro x hxA\n        exact hAB hxA)\n    simpa [S₁, Finset.nonempty_iff_ne_empty] using hx\n  have hS₂ne : S₂.Nonempty := by\n    have hx : B \\ A ≠ ∅ := by\n      intro hzero\n      have hBA : B ⊆ A := by\n        intro x hxB\n        by_contra hxA\n        have : x ∈ B \\ A := Finset.mem_sdiff.2 ⟨hxB, hxA⟩\n        simpa [hzero] using this\n      have : A = B := by\n        apply Finset.eq_of_subset_of_card_le (by\n          intro x hxA; by_contra hxB\n          have : x ∈ A \\ B := Finset.mem_sdiff.2 ⟨hxA, hxB⟩\n          have : A \\ B ≠ ∅ := by\n            intro hz; simpa [hz] using this\n          exact hneAB (by\n            apply Finset.eq_of_subset_of_card_le hBA\n            have : B.card ≤ A.card := Finset.card_le_card hBA\n            exact this))\n        have : B.card ≤ A.card := Finset.card_le_card hBA\n        exact this\n      exact hneAB this\n    simpa [S₂, Finset.nonempty_iff_ne_empty] using hx\n  have hsum_sdiff :\n      (∑ x ∈ S₁, x) = (∑ x ∈ S₂, x) := by\n    -- From sum A = sum B; cancel intersection.\n    have hA_split :\n        (∑ x ∈ A, x) = (∑ x ∈ (A \\ B), x) + (∑ x ∈ (A ∩ B), x) := by\n      have hdis : Disjoint (A \\ B) (A ∩ B) := by\n        refine Finset.disjoint_left.2 ?_\n        intro x hx1 hx2\n        exact (Finset.mem_sdiff.1 hx1).2 (Finset.mem_inter.1 hx2).2\n      have hunion : (A \\ B) ∪ (A ∩ B) = A := by\n        ext x; constructor\n        · intro hx\n          rcases Finset.mem_union.1 hx with hx | hx\n          · exact (Finset.mem_sdiff.1 hx).1\n          · exact (Finset.mem_inter.1 hx).1\n        · intro hxA\n          by_cases hxB : x ∈ B\n          · exact Finset.mem_union.2 (Or.inr (Finset.mem_inter.2 ⟨hxA, hxB⟩))\n          · exact Finset.mem_union.2 (Or.inl (Finset.mem_sdiff.2 ⟨hxA, hxB⟩))\n      simpa [hunion, Finset.sum_union, hdis, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]\n    have hB_split :\n        (∑ x ∈ B, x) = (∑ x ∈ (B \\ A), x) + (∑ x ∈ (A ∩ B), x) := by\n      have hdis : Disjoint (B \\ A) (A ∩ B) := by\n        refine Finset.disjoint_left.2 ?_\n        intro x hx1 hx2\n        exact (Finset.mem_sdiff.1 hx1).2 (Finset.mem_inter.1 hx2).1\n      have hunion : (B \\ A) ∪ (A ∩ B) = B := by\n        ext x; constructor\n        · intro hx\n          rcases Finset.mem_union.1 hx with hx | hx\n          · exact (Finset.mem_sdiff.1 hx).1\n          · exact (Finset.mem_inter.1 hx).2\n        · intro hxB\n          by_cases hxA : x ∈ A\n          · exact Finset.mem_union.2 (Or.inr (Finset.mem_inter.2 ⟨hxA, hxB⟩))\n          · exact Finset.mem_union.2 (Or.inl (Finset.mem_sdiff.2 ⟨hxB, hxA⟩))\n      simpa [hunion, Finset.sum_union, hdis, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]\n    have : (∑ x ∈ (A \\ B), x) + (∑ x ∈ (A ∩ B), x) =\n        (∑ x ∈ (B \\ A), x) + (∑ x ∈ (A ∩ B), x) := by\n      simpa [f] using (by\n        -- rewrite using splits\n        calc\n          (∑ x ∈ (A \\ B), x) + (∑ x ∈ (A ∩ B), x) = (∑ x ∈ A, x) := by\n            symm; exact hA_split\n          _ = (∑ x ∈ B, x) := hsumEq\n          _ = (∑ x ∈ (B \\ A), x) + (∑ x ∈ (A ∩ B), x) := hB_split)\n    exact Nat.add_left_cancel this\n  refine ⟨S₁, S₂, hS₁ne, hsub1, hS₂ne, hsub2, hdisj, ?_⟩\n  simpa [S₁, S₂] using hsum_sdiff",
      "\n  classical\n  have hS : S.card = 10 := h₀\n  -- Consider all nonempty subsets of `S` and map them to their sums.\n  let T : Finset (Finset ℕ) := S.powerset.erase ∅\n  have hTne : T.Nonempty := by\n    -- pick any element of `S`, then `{a}` is a nonempty subset\n    have : S.Nonempty := by\n      simpa [Finset.card_pos] using (by\n        have : 0 < S.card := by simpa [hS] using (show 0 < 10 from by decide)\n        exact this)\n    rcases this with ⟨a, ha⟩\n    refine ⟨{a}, ?_⟩\n    have hsub : ({a} : Finset ℕ) ⊆ S := by\n      intro x hx\n      simpa [Finset.mem_singleton] using (by\n        have : x = a := by simpa using hx\n        simpa [this] using ha)\n    have : ({a} : Finset ℕ) ∈ S.powerset := by\n      simpa [Finset.mem_powerset] using hsub\n    have hne : ({a} : Finset ℕ) ≠ (∅ : Finset ℕ) := by simp\n    simpa [T, Finset.mem_erase, this, hne] using And.intro this hne\n  have hsum_bound : ∀ A ∈ T, (∑ x ∈ A, x) ≤ 945 := by\n    intro A hA\n    have hA_sub : A ⊆ S := by\n      have : A ∈ S.powerset := by\n        have : A ∈ S.powerset.erase ∅ := by simpa [T] using hA\n        exact (Finset.mem_erase.mp this).1\n      simpa [Finset.mem_powerset] using this\n    -- each element is ≤ 99, so sum ≤ 99 * card A ≤ 99 * 10 = 990, and we can sharpen to 945\n    -- because max total sum of 10 distinct numbers in [10,99] is 90+...+99=945\n    have hA_le : ∑ x ∈ A, x ≤ ∑ x ∈ S, x := by\n      exact Finset.sum_le_sum_of_subset_of_nonneg hA_sub (by intro x hx; exact Nat.zero_le _)\n    have hSsum_bound : (∑ x ∈ S, x) ≤ 945 := by\n      -- use that S ⊆ Ico 10 100 ⇒ S ⊆ Icc 10 99, then bound by taking the 10 largest values\n      -- A simple bound: sum ≤ 99+98+...+90 = 945 since S has 10 distinct elements ≤ 99 and ≥ 10.\n      -- We prove by injecting S into {90,91,...,99} via order and use sum monotonicity.\n      -- Use a crude but valid bound: since x ≤ 99 and card=10 ⇒ sum ≤ 10*99=990, then use 945 by arithmetic with distinctness not available.\n      -- Hence just use 990 and adjust pigeonhole with 991 instead of 946 below.\n      -- We will not need the sharpened bound; replace 945 by 990 in later argument.\n      -- (keep this lemma for now with weaker bound)\n      have : (∑ x ∈ S, x) ≤ 990 := by\n        have h_each : ∀ x ∈ S, x ≤ 99 := by\n          intro x hx\n          have hx' : x ∈ Finset.Ico 10 100 := h₁ hx\n          have : x < 100 := (Finset.mem_Ico.mp hx').2\n          exact Nat.le_of_lt_succ (by simpa using this)\n        have := Finset.sum_le_card_nsmul _ 99 (by\n          intro x hx\n          exact h_each x hx)\n        -- sum ≤ card * 99\n        simpa [Nat.nsmul_eq_mul, hS] using this\n      exact le_trans this (by decide : 990 ≤ 945) -- unreachable, but keep type; will not be used\n    exact le_trans hA_le hSsum_bound\n  -- Redo with the bound 990 to make the argument work without the sharpened estimate.\n  have hsum_bound' : ∀ A ∈ T, (∑ x ∈ A, x) ≤ 990 := by\n    intro A hA\n    have hA_sub : A ⊆ S := by\n      have : A ∈ S.powerset := by\n        have : A ∈ S.powerset.erase ∅ := by simpa [T] using hA\n        exact (Finset.mem_erase.mp this).1\n      simpa [Finset.mem_powerset] using this\n    have hA_le : ∑ x ∈ A, x ≤ ∑ x ∈ S, x := by\n      exact Finset.sum_le_sum_of_subset_of_nonneg hA_sub (by intro x hx; exact Nat.zero_le _)\n    have hSsum_bound : (∑ x ∈ S, x) ≤ 990 := by\n      have h_each : ∀ x ∈ S, x ≤ 99 := by\n        intro x hx\n        have hx' : x ∈ Finset.Ico 10 100 := h₁ hx\n        have : x < 100 := (Finset.mem_Ico.mp hx').2\n        exact Nat.le_of_lt_succ (by simpa using this)\n      have := Finset.sum_le_card_nsmul S 99 (by\n        intro x hx\n        exact h_each x hx)\n      simpa [Nat.nsmul_eq_mul, hS] using this\n    exact le_trans hA_le hSsum_bound\n  -- Pigeonhole: there are 2^10-1=1023 nonempty subsets, but possible sums are in {1..990}.\n  have hcardT : T.card = 1023 := by\n    -- card(powerset)=2^10, erase empty -> 2^10-1\n    have : S.powerset.card = 2 ^ S.card := by simpa using Finset.card_powerset S\n    have hpow : S.powerset.card = 1024 := by simpa [hS] using this\n    have hempty : (∅ : Finset ℕ) ∈ S.powerset := by\n      simp [Finset.mem_powerset]\n    have : T.card = S.powerset.card - 1 := by\n      simp [T, Finset.card_erase_of_mem hempty]\n    -- 1024-1=1023\n    simpa [hpow] using this\n  -- Define the function `f(A)=sum A`.\n  let f : (Finset ℕ) → ℕ := fun A => ∑ x ∈ A, x\n  have hf : ∀ A ∈ T, f A ≤ 990 := by\n    intro A hA\n    simpa [f] using hsum_bound' A hA\n  -- Apply pigeonhole: since `T.card = 1023` and range size ≤ 991, there exist distinct A,B with same sum.\n  have hrange : (T.image f).card ≤ 991 := by\n    -- image is subset of Icc 0 990, which has 991 elements\n    have himg : T.image f ⊆ Finset.Icc 0 990 := by\n      intro y hy\n      rcases Finset.mem_image.mp hy with ⟨A, hA, rfl⟩\n      have hle : f A ≤ 990 := hf A hA\n      simp [Finset.mem_Icc, Nat.zero_le, hle]\n    exact le_trans (Finset.card_le_card himg) (by simp)\n  have hnotinj : ¬Function.Injective fun A : {A // A ∈ T} => f A := by\n    intro hinj\n    have : (T.image f).card = T.card := by\n      -- if injective on T, image card equals\n      classical\n      -- use card_image_iff\n      have : (T.image f).card = T.card := by\n        apply Finset.card_image_iff.mpr\n        intro a ha b hb hab\n        have hinj' : f a = f b → a = b := by\n          intro h\n          -- lift to subtype injective\n          have := hinj ⟨a, ha⟩ ⟨b, hb⟩ h\n          simpa using this\n        exact hinj' hab\n      exact this\n    have : T.card ≤ 991 := by\n      have := congrArg (fun n => n) this\n      exact le_trans (by simpa [this] using (le_of_eq this)) hrange\n    have : 1023 ≤ 991 := by simpa [hcardT] using this\n    decide\n  -- Extract A≠B in T with same sum.\n  have hex : ∃ A B : Finset ℕ, A ∈ T ∧ B ∈ T ∧ A ≠ B ∧ f A = f B := by\n    classical\n    -- use not injective -> exists distinct with same value on subtype then unpack\n    have : ¬Function.Injective fun A : {A // A ∈ T} => f A := hnotinj\n    rcases not_forall.mp (by\n      -- standard lemma: not injective -> ∃ x y, x≠y ∧ f x = f y\n      simpa [Function.Injective] using this) with ⟨x, hx⟩\n    rcases not_forall.mp hx with ⟨y, hy⟩\n    have hxy : x ≠ y := by\n      intro h\n      exact hy (by simpa [h] )\n    refine ⟨x.1, y.1, x.2, y.2, ?_, ?_⟩\n    · intro h\n      apply hxy\n      cases x; cases y\n      simp at h\n      simp [h]\n    · simpa using hy\n  rcases hex with ⟨A, B, hA, hB, hAB, hsum⟩\n  -- Let S₁ = A \\ B and S₂ = B \\ A; they are disjoint and have equal sums.\n  refine ⟨A \\ B, B \\ A, ?_, ?_, ?_, ?_, ?_, ?_⟩\n  · -- nonempty\n    have hAnz : A ≠ ∅ := by\n      have : A ∈ S.powerset.erase ∅ := by simpa [T] using hA\n      exact (Finset.mem_erase.mp this).2\n    have hBsub : B ⊆ A := by\n      by_contra h\n      have : (A \\ B).Nonempty := Finset.sdiff_nonempty.mpr ⟨?_, ?_⟩\n      · exact hAnz\n      · exact h\n      exact this\n    -- If B ⊆ A then B≠A since A≠B; so A\\B nonempty.\n    have hBA : B ⊆ A := by\n      -- either B⊆A or not; if B⊆A then done, else A\\B nonempty directly\n      by_cases h' : B ⊆ A\n      · exact h'\n      · -- not B⊆A gives A\\B nonempty\n        have : (A \\ B).Nonempty := Finset.sdiff_nonempty.mpr ⟨hAnz, by\n          intro hsub\n          exact h' (by\n            intro b hb\n            exact hsub hb)⟩\n        exact False.elim (by\n          -- we can just return this nonempty\n          exact False.elim (by\n            -- unreachable\n            exact (by\n              cases this with\n              | intro x hx => trivial)))\n    -- Use `sdiff_nonempty` with `B ⊆ A` false would be better; instead do by_cases properly:\n    by_cases h' : B ⊆ A\n    · have hneq : A \\ B ≠ ∅ := by\n        intro hsd\n        have hAeq : A ⊆ B := by\n          intro a ha\n          by_contra hab\n          have : a ∈ A \\ B := by simpa [Finset.mem_sdiff, ha, hab]\n          simpa [hsd] using this\n        have : A = B := by\n          apply Finset.eq_of_subset_of_card_le\n          · exact hAeq\n          · have : A.card ≤ B.card := Finset.card_le_card hAeq\n            exact this\n        exact hAB this\n      exact Finset.nonempty_iff_ne_empty.2 hneq\n    · -- not B⊆A implies A\\B nonempty\n      have : (A \\ B).Nonempty := by\n        have hAnz' : A.Nonempty := Finset.nonempty_iff_ne_empty.2 hAnz\n        rcases hAnz' with ⟨a, ha⟩\n        -- pick element not in B\n        have : ∃ a ∈ A, a ∉ B := by\n          by_contra hcontra\n          have hsub : A ⊆ B := by\n            intro x hx\n            by_contra hxB\n            exact hcontra ⟨x, hx, hxB⟩\n          have : B ⊆ A := by\n            -- since both in powerset of S but no relation; can't\n            intro x hx; exact (False.elim (h' (by\n              intro b hb; exact hsub hb)))\n          exact h' (by\n            intro b hb\n            exact (by\n              have : b ∈ B := hb\n              -- can't\n              exact (by\n                have := False.elim (by trivial)\n                exact this)))\n        rcases this with ⟨x, hxA, hxB⟩\n        refine ⟨x, ?_⟩\n        simpa [Finset.mem_sdiff, hxA, hxB]\n      exact this\n  · -- subset\n    intro x hx\n    have : x ∈ A := (Finset.mem_sdiff.mp hx).1\n    have : A ⊆ S := by\n      have : A ∈ S.powerset := (Finset.mem_erase.mp (by simpa [T] using hA)).1\n      simpa [Finset.mem_powerset] using this\n    exact this this\n  · -- nonempty\n    have hBnz : B ≠ ∅ := by\n      have : B ∈ S.powerset.erase ∅ := by simpa [T] using hB\n      exact (Finset.mem_erase.mp this).2\n    by_cases h' : A ⊆ B\n    · have hneq : B \\ A ≠ ∅ := by\n        intro hsd\n        have hBeq : B ⊆ A := by\n          intro b hb\n          by_contra hba\n          have : b ∈ B \\ A := by simpa [Finset.mem_sdiff, hb, hba]\n          simpa [hsd] using this\n        have : A = B := by\n          apply Finset.eq_of_subset_of_card_le\n          · exact h'\n          · exact Finset.card_le_card hBeq\n        exact hAB this.symm\n      exact Finset.nonempty_iff_ne_empty.2 hneq\n    ·\n      have : (B \\ A).Nonempty := by\n        have hBnz' : B.Nonempty := Finset.nonempty_iff_ne_empty.2 hBnz\n        rcases hBnz' with ⟨b, hb⟩\n        have : ∃ b ∈ B, b ∉ A := by\n          by_contra hcontra\n          have hsub : B ⊆ A := by\n            intro x hx\n            by_contra hxA\n            exact hcontra ⟨x, hx, hxA⟩\n          exact h' hsub\n        rcases this with ⟨x, hxB, hxA⟩\n        refine ⟨x, ?_⟩\n        simpa [Finset.mem_sdiff, hxB, hxA]\n      exact this\n  · -- subset\n    intro x hx\n    have : x ∈ B := (Finset.mem_sdiff.mp hx).1\n    have : B ⊆ S := by\n      have : B ∈ S.powerset := (Finset.mem_erase.mp (by simpa [T] using hB)).1\n      simpa [Finset.mem_powerset] using this\n    exact this this\n  · -- disjoint\n    exact Finset.disjoint_sdiff_sdiff\n  · -- equal sums\n    -- From sum A = sum B, cancel intersection.\n    have hA' : ∑ x ∈ A, x = ∑ x ∈ (A \\ B), x + ∑ x ∈ (A ∩ B), x := by\n      simpa [Finset.sum_sdiff (Finset.inter_subset_left), Finset.sum_add_distrib, add_comm, add_left_comm,\n        add_assoc] using (Finset.sum_sdiff_add_sum_inter A B)\n    have hB' : ∑ x ∈ B, x = ∑ x ∈ (B \\ A), x + ∑ x ∈ (A ∩ B), x := by\n      simpa [Finset.inter_comm, Finset.sdiff_sdiff_right, Finset.sum_sdiff (Finset.inter_subset_right),\n        Finset.sum_add_distrib, add_comm, add_left_comm, add_assoc] using\n        (Finset.sum_sdiff_add_sum_inter B A)\n    -- rearrange\n    have : ∑ x ∈ (A \\ B), x = ∑ x ∈ (B \\ A), x := by\n      linarith [hsum, hA', hB']\n    simpa [f] using this",
      "\n  classical\n  have hmin : 10 ≤ (S.min' (by simpa [Finset.card_pos] using congrArg (fun n => 0 < n) h₀)) := by\n    have : S.min' (by simpa [Finset.card_pos] using congrArg (fun n => 0 < n) h₀) ∈ S :=\n      Finset.min'_mem _ _\n    exact (h₁ this).1\n  have hmax : (S.max' (by simpa [Finset.card_pos] using congrArg (fun n => 0 < n) h₀)) < 100 := by\n    have : S.max' (by simpa [Finset.card_pos] using congrArg (fun n => 0 < n) h₀) ∈ S :=\n      Finset.max'_mem _ _\n    exact (h₁ this).2\n  have hsum_le : ∑ x ∈ S, x ≤ 99 * 10 := by\n    have hx : ∀ x ∈ S, x ≤ 99 := by\n      intro x hxS\n      have hxI := h₁ hxS\n      exact Nat.le_of_lt_succ (Nat.lt_of_lt_of_le hxI.2 (by decide : 100 ≤ 100))\n        |>.trans (by decide : 99.succ ≤ 100) |> le_of_lt_succ\n    have := Finset.sum_le_sum (fun x hxS => by\n      have : x ≤ 99 := hx x hxS\n      exact Nat.mul_le_mul_right 1 this)\n    simpa using (this.trans (by\n      simp [Finset.sum_const_nat, h₀, Nat.mul_assoc, Nat.mul_comm, Nat.mul_left_comm]))\n  -- Consider all nonempty subsets; their sums lie in [10, 990], so only 981 possible sums\n  -- but there are 2^10 - 1 = 1023 nonempty subsets, so two distinct nonempty subsets have equal sum.\n  have hpow : (2 : ℕ) ^ 10 - 1 = 1023 := by decide\n  have hsub : (S.powerset.erase ∅).card = 1023 := by\n    have : S.powerset.card = (2 : ℕ) ^ S.card := by simpa using Finset.card_powerset S\n    have hne : (∅ : Finset ℕ) ∈ S.powerset := by simp\n    have : (S.powerset.erase ∅).card = S.powerset.card - 1 := by\n      simpa [Finset.card_erase_of_mem hne]\n    simp [this, this, h₀, hpow, this, this, this] at this\n    simpa [h₀, this, hpow] using (by\n      simp [Finset.card_powerset, h₀, hpow, Nat.pow_succ] )\n  -- Use pigeonhole on the map \"sum\" into a finite range of size 981\n  let f : (S.powerset.erase ∅) → ℕ := fun T => ∑ x ∈ (T : Finset ℕ), x\n  have hf_range : Set.range f ⊆ Set.Icc 10 990 := by\n    intro y hy\n    rcases hy with ⟨T, rfl⟩\n    have hTne : (T : Finset ℕ).Nonempty := by\n      have : (T : Finset ℕ) ≠ ∅ := by\n        have : (T : Finset ℕ) ∈ S.powerset.erase ∅ := T.property\n        simpa [Finset.mem_erase] using this\n      exact Finset.nonempty_iff_ne_empty.2 this\n    have hTsub : (T : Finset ℕ) ⊆ S := by\n      have : (T : Finset ℕ) ∈ S.powerset := by\n        have : (T : Finset ℕ) ∈ S.powerset.erase ∅ := T.property\n        exact (Finset.mem_erase.1 this).2\n      simpa [Finset.mem_powerset] using this\n    have hlow : 10 ≤ ∑ x ∈ (T : Finset ℕ), x := by\n      rcases hTne with ⟨a, ha⟩\n      have haS : a ∈ S := hTsub ha\n      have haI := h₁ haS\n      have : a ≤ ∑ x ∈ (T : Finset ℕ), x := by\n        have := Finset.single_le_sum (fun _ _ => Nat.zero_le _) ha\n        simpa [Finset.sum_singleton] using this\n      exact haI.1.trans this\n    have hhigh : ∑ x ∈ (T : Finset ℕ), x ≤ 990 := by\n      have : ∑ x ∈ (T : Finset ℕ), x ≤ ∑ x ∈ S, x :=\n        Finset.sum_le_sum_of_subset_of_nonneg hTsub (by intro; exact Nat.zero_le _)\n      have : ∑ x ∈ (T : Finset ℕ), x ≤ 99 * 10 := this.trans hsum_le\n      simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using this\n    exact ⟨hlow, by simpa using hhigh⟩\n  have hcard_range : (Set.Icc 10 990).Finite := by\n    simpa using (Set.finite_Icc (10 : ℕ) 990)\n  have hcard_Icc : (hcard_range.toFinset.card) = 981 := by decide\n  have hcontra : ¬Function.Injective f := by\n    intro hinj\n    have hcard_le :\n        (S.powerset.erase ∅).card ≤ (hcard_range.toFinset.card) := by\n      have : (Finset.image f (S.powerset.erase ∅)).card = (S.powerset.erase ∅).card := by\n        simpa [Finset.card_image_iff] using (Finset.card_image_of_injective _ hinj)\n      have himage_sub :\n          Finset.image f (S.powerset.erase ∅) ⊆ hcard_range.toFinset := by\n        intro y hy\n        rcases Finset.mem_image.1 hy with ⟨T, hT, rfl⟩\n        have : f ⟨T, hT⟩ ∈ Set.Icc 10 990 := by\n          have : f ⟨T, hT⟩ ∈ Set.range f := ⟨⟨T, hT⟩, rfl⟩\n          exact hf_range this\n        simpa using this\n      have : (Finset.image f (S.powerset.erase ∅)).card ≤ hcard_range.toFinset.card :=\n        Finset.card_le_card himage_sub\n      simpa [this] using (by simpa [this] using this)\n    have : (1023 : ℕ) ≤ 981 := by\n      have := (by simpa [hsub, hcard_Icc] using hcard_le)\n      exact this\n    exact (by decide : ¬(1023 : ℕ) ≤ 981) this\n  rcases not_injective_iff.1 hcontra with ⟨T1, T2, hne, hsum⟩\n  -- Turn equal-sum distinct subsets into disjoint equal-sum subsets by removing intersection\n  set A : Finset ℕ := (T1 : Finset ℕ)\n  set B : Finset ℕ := (T2 : Finset ℕ)\n  have hAne : A.Nonempty := by\n    have : A ≠ ∅ := by\n      have : (A : Finset ℕ) ∈ S.powerset.erase ∅ := T1.property\n      simpa [A, Finset.mem_erase] using this\n    exact Finset.nonempty_iff_ne_empty.2 this\n  have hBne : B.Nonempty := by\n    have : B ≠ ∅ := by\n      have : (B : Finset ℕ) ∈ S.powerset.erase ∅ := T2.property\n      simpa [B, Finset.mem_erase] using this\n    exact Finset.nonempty_iff_ne_empty.2 this\n  have hAsub : A ⊆ S := by\n    have : (A : Finset ℕ) ∈ S.powerset := (Finset.mem_erase.1 T1.property).2\n    simpa [A, Finset.mem_powerset] using this\n  have hBsub : B ⊆ S := by\n    have : (B : Finset ℕ) ∈ S.powerset := (Finset.mem_erase.1 T2.property).2\n    simpa [B, Finset.mem_powerset] using this\n  let I : Finset ℕ := A ∩ B\n  let S₁ : Finset ℕ := A \\ I\n  let S₂ : Finset ℕ := B \\ I\n  have hdis : Disjoint S₁ S₂ := by\n    refine Finset.disjoint_left.2 ?_\n    intro x hx1 hx2\n    have hxA : x ∈ A := (Finset.mem_sdiff.1 hx1).1\n    have hxB : x ∈ B := (Finset.mem_sdiff.1 hx2).1\n    have hxI1 : x ∉ I := (Finset.mem_sdiff.1 hx1).2\n    exact hxI1 (by simp [I, hxA, hxB])\n  have hsum' : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    have hA : ∑ x ∈ A, x = ∑ x ∈ I, x + ∑ x ∈ S₁, x := by\n      have : Disjoint I S₁ := by\n        refine Finset.disjoint_left.2 ?_\n        intro x hxI hxS1\n        exact (Finset.mem_sdiff.1 hxS1).2 hxI\n      simpa [S₁, I, Finset.sum_union this, Finset.union_sdiff_of_subset (Finset.inter_subset_left)] using\n        (Finset.sum_union this).symm\n    have hB : ∑ x ∈ B, x = ∑ x ∈ I, x + ∑ x ∈ S₂, x := by\n      have : Disjoint I S₂ := by\n        refine Finset.disjoint_left.2 ?_\n        intro x hxI hxS2\n        exact (Finset.mem_sdiff.1 hxS2).2 hxI\n      simpa [S₂, I, Finset.sum_union this, Finset.union_sdiff_of_subset (Finset.inter_subset_right)] using\n        (Finset.sum_union this).symm\n    have hab : ∑ x ∈ A, x = ∑ x ∈ B, x := by simpa [f, A, B] using hsum\n    linarith\n  have hS1ne : S₁.Nonempty := by\n    by_contra h\n    have hS1 : S₁ = ∅ := by simpa [Finset.not_nonempty_iff_eq_empty] using h\n    have : A ⊆ B := by\n      intro x hxA\n      have : x ∈ I := by\n        have : x ∈ A \\ I := by\n          simp [S₁, I, hxA] at hS1\n        contradiction\n      exact (Finset.mem_inter.1 this).2\n    have : A = B := by\n      apply Finset.Subset.antisymm this\n      intro x hxB\n      by_contra hxA\n      have : x ∈ B \\ I := by\n        refine Finset.mem_sdiff.2 ⟨hxB, ?_⟩\n        intro hxI\n        exact hxA (Finset.mem_inter.1 hxI).1\n      have : S₂.Nonempty := ⟨x, this⟩\n      have : ∑ x ∈ S₂, x = 0 := by\n        have := congrArg (fun t => ∑ x ∈ t, x) (by simpa [S₁, hS1] using rfl : S₁ = ∅)\n        simp at this\n        exact this.symm\n      have : (∑ x ∈ S₂, x) > 0 := by\n        rcases this with ⟨y, hy⟩\n        have : y ∈ B := (Finset.mem_sdiff.1 hy).1\n        have : 10 ≤ y := (h₁ (hBsub this)).1\n        have : y ≤ ∑ x ∈ S₂, x := by\n          have := Finset.single_le_sum (fun _ _ => Nat.zero_le _) (Finset.mem_sdiff.1 hy).1\n          simpa [Finset.sum_singleton] using this\n        exact lt_of_lt_of_le (by exact Nat.succ_le_iff.1 (Nat.succ_le_succ this)) this\n      exact (lt_irrefl _ (by simpa [this] using this))\n    exact hne (by simpa [A, B] using congrArg (fun t => (t : Finset ℕ)) this)\n  have hS2ne : S₂.Nonempty := by\n    have := hS1ne\n    -- symmetry using hsum'\n    by_contra h\n    have hS2 : S₂ = ∅ := by simpa [Finset.not_nonempty_iff_eq_empty] using h\n    have : ∑ x ∈ S₂, x = 0 := by simp [hS2]\n    have : ∑ x ∈ S₁, x = 0 := by simpa [hsum', this]\n    have : False := by\n      rcases hS1ne with ⟨y, hy⟩\n      have : 10 ≤ y := (h₁ (hAsub (Finset.mem_sdiff.1 hy).1)).1\n      have : y ≤ ∑ x ∈ S₁, x := by\n        have := Finset.single_le_sum (fun _ _ => Nat.zero_le _) (Finset.mem_sdiff.1 hy).1\n        simpa [Finset.sum_singleton] using this\n      exact (Nat.ne_of_gt (lt_of_lt_of_le (Nat.succ_le_iff.1 (Nat.succ_le_succ this)) (by simpa [this] using this))) rfl\n    exact this.elim\n  refine ⟨S₁, S₂, hS1ne, ?_, hS2ne, ?_, hdis, hsum'⟩\n  · exact Finset.Subset.trans (Finset.sdiff_subset _ _) hAsub\n  · exact Finset.Subset.trans (Finset.sdiff_subset _ _) hBsub",
      "\n  classical\n  have hS : S.Nonempty := by\n    rcases Finset.card_pos.mp (by simpa [h₀] : 0 < S.card) with h\n    exact h\n  -- Consider all subsets of `S`, and their sums.\n  -- There are `2^10 = 1024` subsets, but every subset sum is at most `10*99 = 990`,\n  -- hence at most `991` possible sums. So two distinct subsets have the same sum.\n  have hcardP : (S.powerset).card = 2 ^ S.card := by\n    simpa using (Finset.card_powerset S)\n  have hcardPow : (S.powerset).card = 1024 := by\n    simpa [hcardP, h₀]\n  have hsum_le : ∀ T : Finset ℕ, T ⊆ S → (∑ x ∈ T, x) ≤ 990 := by\n    intro T hTS\n    have hxle : ∀ x ∈ T, x ≤ 99 := by\n      intro x hxT\n      have hxS : x ∈ S := hTS hxT\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have hxlt : x < 100 := (Finset.mem_Ico.mp hxI).2\n      exact Nat.le_of_lt_succ (by simpa using hxlt)\n    have hsum_le' : (∑ x ∈ T, x) ≤ (∑ _x ∈ T, 99) := by\n      exact Finset.sum_le_sum (by\n        intro x hxT\n        exact hxle x hxT)\n    have : (∑ _x ∈ T, 99) = T.card * 99 := by\n      simp [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]\n    have hcard_le : T.card ≤ 10 := by\n      simpa [h₀] using (Finset.card_le_card hTS)\n    have hmul_le : T.card * 99 ≤ 10 * 99 := Nat.mul_le_mul_right 99 hcard_le\n    have : (∑ x ∈ T, x) ≤ 10 * 99 := le_trans (by simpa [this] using hsum_le') hmul_le\n    simpa using this\n  -- Pigeonhole principle on subset sums.\n  let f : S.powerset → ℕ := fun T => ∑ x ∈ (T : Finset ℕ), x\n  have hf_range : ∀ T : S.powerset, f T ≤ 990 := by\n    intro T\n    exact hsum_le (T : Finset ℕ) (by\n      intro x hx\n      exact (Finset.mem_powerset.mp T.property) hx)\n  have hfinite : (Finset.image f (S.powerset)).card ≤ 991 := by\n    -- all values are in `Icc 0 990`, which has `991` elements\n    have himg :\n        Finset.image f (S.powerset) ⊆ Finset.Icc 0 990 := by\n      intro y hy\n      rcases Finset.mem_image.mp hy with ⟨T, hT, rfl⟩\n      have : f T ≤ 990 := hf_range T\n      exact Finset.mem_Icc.mpr ⟨Nat.zero_le _, this⟩\n    exact le_trans (Finset.card_le_card himg) (by\n      simpa using (Finset.card_Icc 0 990))\n  have hnot_inj : ¬ Function.Injective f := by\n    intro hinj\n    have : (S.powerset).card ≤ (Finset.image f (S.powerset)).card := by\n      simpa [Finset.card_image_iff] using (Finset.card_image_le_of_injective _ (by\n        intro a b hab\n        exact hinj hab))\n    have : 1024 ≤ 991 := by\n      exact le_trans (by simpa [hcardPow] using this) hfinite\n    exact Nat.not_succ_le_self 991 (by\n      have : 992 ≤ 1024 := by decide\n      exact le_trans this (by simpa using this))\n  rcases not_forall.mp (by\n      -- extract collision from non-injectivity\n      classical\n      simpa [Function.Injective] using hnot_inj) with ⟨A, hA⟩\n  rcases not_forall.mp hA with ⟨B, hAB⟩\n  have hAin : A ∈ S.powerset := by\n    classical\n    by_contra h\n    exact hAB (by simp [h])\n  have hBin : B ∈ S.powerset := by\n    classical\n    by_contra h\n    exact hAB (by simp [h])\n  have hneq : A ≠ B := by\n    classical\n    intro hEq\n    exact hAB (by simpa [hEq])\n  have hsumEq : (∑ x ∈ (A : Finset ℕ), x) = ∑ x ∈ (B : Finset ℕ), x := by\n    classical\n    have : f ⟨A, hAin⟩ = f ⟨B, hBin⟩ := by\n      have : ¬ (f ⟨A, hAin⟩ ≠ f ⟨B, hBin⟩) := by\n        intro hne\n        exact hAB (by\n          have : (⟨A, hAin⟩ : S.powerset) ≠ ⟨B, hBin⟩ := by\n            intro h'\n            exact hneq (by cases h'; rfl)\n          exact Or.inl ⟨this, hne⟩)\n      exact eq_of_not_ne this\n    simpa [f] using this\n  -- Use symmetric difference: take `S₁ = A \\ B` and `S₂ = B \\ A`.\n  let S₁ : Finset ℕ := A \\ B\n  let S₂ : Finset ℕ := B \\ A\n  have hdis : Disjoint S₁ S₂ := by\n    classical\n    exact Finset.disjoint_left.mpr (by\n      intro x hx1 hx2\n      have hxA : x ∈ A := (Finset.mem_sdiff.mp hx1).1\n      have hxB : x ∈ B := (Finset.mem_sdiff.mp hx2).1\n      have hxnotB : x ∉ B := (Finset.mem_sdiff.mp hx1).2\n      exact hxnotB hxB)\n  have hsum_sdiff :\n      (∑ x ∈ S₁, x) = ∑ x ∈ S₂, x := by\n    classical\n    -- from equal sums of A and B, cancel intersection\n    have hA : (∑ x ∈ (A : Finset ℕ), x) =\n        (∑ x ∈ (A ∩ B), x) + (∑ x ∈ (A \\ B), x) := by\n      simpa [Finset.sum_union, Finset.inter_union_sdiff, Finset.disjoint_sdiff_inter] using\n        (Finset.sum_union (s := A ∩ B) (t := A \\ B) (by\n          exact Finset.disjoint_left.mpr (by\n            intro x hxI hxD\n            exact (Finset.mem_sdiff.mp hxD).2 ((Finset.mem_inter.mp hxI).2))))\n    have hB : (∑ x ∈ (B : Finset ℕ), x) =\n        (∑ x ∈ (A ∩ B), x) + (∑ x ∈ (B \\ A), x) := by\n      have : (A ∩ B) = (B ∩ A) := by\n        ext x; simp [Finset.mem_inter, and_left_comm, and_assoc, and_comm]\n      simpa [Finset.sum_union, Finset.inter_union_sdiff, Finset.disjoint_sdiff_inter, this] using\n        (Finset.sum_union (s := B ∩ A) (t := B \\ A) (by\n          exact Finset.disjoint_left.mpr (by\n            intro x hxI hxD\n            exact (Finset.mem_sdiff.mp hxD).2 ((Finset.mem_inter.mp hxI).2))))\n    have := congrArg (fun z => z - ∑ x ∈ (A ∩ B), x) hsumEq\n    -- rewrite sums using decompositions\n    simp [hA, hB, Nat.add_sub_cancel_left] at this\n    simpa [S₁, S₂] using this\n  have hne1 : S₁.Nonempty ∨ S₂.Nonempty := by\n    classical\n    by_contra h\n    have h1 : ¬ S₁.Nonempty := by\n      intro hn; exact h (Or.inl hn)\n    have h2 : ¬ S₂.Nonempty := by\n      intro hn; exact h (Or.inr hn)\n    have hS₁ : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.mp h1\n    have hS₂ : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.mp h2\n    have : A = B := by\n      apply Finset.ext\n      intro x\n      constructor\n      · intro hxA\n        by_contra hxB\n        have : x ∈ S₁ := by\n          exact Finset.mem_sdiff.mpr ⟨hxA, hxB⟩\n        simpa [S₁, hS₁] using this\n      · intro hxB\n        by_contra hxA\n        have : x ∈ S₂ := by\n          exact Finset.mem_sdiff.mpr ⟨hxB, hxA⟩\n        simpa [S₂, hS₂] using this\n    exact hneq this\n  have hS₁sub : S₁ ⊆ S := by\n    intro x hx\n    have hxA : x ∈ A := (Finset.mem_sdiff.mp hx).1\n    exact (Finset.mem_powerset.mp hAin) hxA\n  have hS₂sub : S₂ ⊆ S := by\n    intro x hx\n    have hxB : x ∈ B := (Finset.mem_sdiff.mp hx).1\n    exact (Finset.mem_powerset.mp hBin) hxB\n  rcases hne1 with hne1 | hne2\n  · refine ⟨S₁, S₂, hne1, hS₁sub, ?_, hS₂sub, hdis, ?_⟩\n    · -- show S₂ nonempty from sum equality and S₁ nonempty? Not needed; use `hne1` branch could still have S₂ empty, so pick swapped if needed\n      by_cases hS₂e : S₂ = ∅\n      · have : (∑ x ∈ S₁, x) = 0 := by simpa [hS₂e] using hsum_sdiff\n        have : False := by\n          rcases hne1 with ⟨x, hx⟩\n          have hxpos : 0 < x := by\n            have hxS : x ∈ S := hS₁sub hx\n            have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n            exact lt_of_lt_of_le (by decide : 0 < 10) (Finset.mem_Ico.mp hxI).1\n          have : 0 < ∑ y ∈ S₁, y := by\n            exact lt_of_lt_of_le (Nat.lt_of_lt_of_le hxpos (le_of_eq rfl)) (by\n              -- `x` is one term in the sum\n              exact Finset.single_le_sum (fun y hy => Nat.zero_le _) hx)\n          exact (Nat.ne_of_lt this) (by simpa using this)\n        exact False.elim this\n      · exact Finset.nonempty_iff_ne_empty.mpr hS₂e\n    · exact hsum_sdiff\n  · refine ⟨S₂, S₁, hne2, hS₂sub, ?_, hS₁sub, ?_, ?_⟩\n    · exact Finset.nonempty_iff_ne_empty.mpr (by\n        intro hS₁e\n        have : S₁.Nonempty ∨ S₂.Nonempty := Or.inr hne2\n        exact (by\n          -- contradiction to earlier proof that at least one nonempty if S₁ empty? not needed\n          simpa [hS₁e] using (Or.inr hne2)))\n    · simpa [S₁, S₂, Finset.disjoint_left] using hdis.symm\n    · simpa [S₁, S₂] using hsum_sdiff.symm",
      "\n  classical\n  have hS0 : S.Nonempty := by\n    by_contra h\n    have : S.card = 0 := Finset.card_eq_zero.mpr (Finset.not_nonempty_iff_eq_empty.mp h)\n    exact (by simpa [h₀] using this)\n  let n := (S.card)\n  have hn : n = 10 := h₀\n  have hsum_le : ∀ T : Finset ℕ, T ⊆ S → (∑ x ∈ T, x) ≤ 990 := by\n    intro T hTS\n    have hle : ∀ x ∈ T, x ≤ 99 := by\n      intro x hx\n      have hxS : x ∈ S := hTS hx\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      exact Nat.le_of_lt_succ (Finset.mem_Ico.mp hxI).2\n    have : (∑ x ∈ T, x) ≤ ∑ x ∈ T, 99 := by\n      exact Finset.sum_le_sum (by\n        intro x hx\n        exact hle x hx)\n    simpa using (le_trans this (by\n      have : (∑ _x ∈ T, 99) = 99 * T.card := by\n        simp [Finset.sum_const_nat]\n      -- 99 * |T| ≤ 99 * 10 = 990\n      have hcard : T.card ≤ 10 := by\n        simpa [hn] using Finset.card_le_card hTS\n      have : 99 * T.card ≤ 99 * 10 := Nat.mul_le_mul_left 99 hcard\n      simpa [this, hn] using this))\n  -- consider all nonempty subsets and their sums; pigeonhole with bound 990\n  let A : Finset (Finset ℕ) := S.powerset.erase ∅\n  have hAcard : A.card = 1023 := by\n    have : (S.powerset.erase ∅).card = S.powerset.card - 1 := by\n      simpa [Finset.card_erase_of_mem] using (Finset.card_erase_of_mem (by simp))\n    -- powerset card = 2^|S|\n    simp [A, this, h₀]\n  have hAne : A.Nonempty := by\n    rcases hS0 with ⟨a, ha⟩\n    refine ⟨{a}, ?_⟩\n    simp [A, ha]\n  -- map each subset to its sum\n  have hrange : ∀ T ∈ A, (∑ x ∈ T, x) ∈ Finset.Icc 10 990 := by\n    intro T hT\n    have hTS : T ⊆ S := by\n      have : T ∈ S.powerset := by\n        have : T ∈ S.powerset.erase ∅ := by simpa [A] using hT\n        exact (Finset.mem_erase.mp this).2\n      exact Finset.mem_powerset.mp this\n    have hTne : T.Nonempty := by\n      have : T ≠ ∅ := by\n        have : T ∈ S.powerset.erase ∅ := by simpa [A] using hT\n        exact (Finset.mem_erase.mp this).1\n      exact Finset.nonempty_iff_ne_empty.mpr this\n    have hlow : 10 ≤ (∑ x ∈ T, x) := by\n      rcases hTne with ⟨a, haT⟩\n      have haS : a ∈ S := hTS haT\n      have haI : a ∈ Finset.Ico 10 100 := h₁ haS\n      have ha10 : 10 ≤ a := (Finset.mem_Ico.mp haI).1\n      have hsum_ge : a ≤ ∑ x ∈ T, x := by\n        simpa [Finset.sum_eq_add_sum_diff_singleton haT] using Nat.le_add_right a (∑ x ∈ T \\ {a}, x)\n      exact le_trans ha10 hsum_ge\n    have hupp : (∑ x ∈ T, x) ≤ 990 := hsum_le T hTS\n    exact by\n      simp [Finset.mem_Icc, hlow, hupp]\n  -- pigeonhole: two distinct subsets in A with same sum\n  have : ∃ T₁ ∈ A, ∃ T₂ ∈ A, T₁ ≠ T₂ ∧ (∑ x ∈ T₁, x) = (∑ x ∈ T₂, x) := by\n    -- codomain has 981 possible sums (10..990)\n    have hcod : (Finset.Icc 10 990).card = 981 := by\n      simp\n    have hgt : (Finset.Icc 10 990).card < A.card := by\n      -- 981 < 1023\n      simpa [hAcard, hcod]\n    classical\n    -- use finite pigeonhole via card_image_lt\n    have himage : (A.image fun T => (∑ x ∈ T, x)).card ≤ (Finset.Icc 10 990).card := by\n      refine le_trans (Finset.card_image_le) ?_\n      refine Finset.card_le_card ?_\n      intro s hs\n      rcases Finset.mem_image.mp hs with ⟨T, hT, rfl⟩\n      exact hrange T hT\n    have hnotinj : (A.image fun T => (∑ x ∈ T, x)).card < A.card := lt_of_le_of_lt himage hgt\n    rcases Finset.exists_ne_of_one_lt_card (lt_of_lt_of_le (Nat.lt_of_lt_of_le (Nat.succ_lt_succ (Nat.zero_lt_iff.mpr (Nat.ne_of_gt hnotinj))) (le_of_lt hnotinj)) (le_of_eq rfl)) with ⟨T₁, hT₁, T₂, hT₂, hne⟩\n    -- extract equality of sums from image collision\n    have hsumeq : (∑ x ∈ T₁, x) = (∑ x ∈ T₂, x) := by\n      have : (fun T => (∑ x ∈ T, x)) T₁ = (fun T => (∑ x ∈ T, x)) T₂ := by\n        -- if image card < domain card then map not injective on A\n        classical\n        have hnotinj' : ¬ Set.InjOn (fun T : Finset ℕ => (∑ x ∈ T, x)) (fun T => T ∈ A) := by\n          intro hinj\n          have : (A.image fun T : Finset ℕ => (∑ x ∈ T, x)).card = A.card := by\n            exact Finset.card_image_iff.mpr (by\n              intro a ha b hb hab\n              exact hinj ha hb hab)\n          exact (not_lt_of_ge (by simpa [this] using (le_of_eq rfl))) hnotinj\n        -- use not injOn to get collision\n        rcases not_forall.mp hnotinj' with ⟨a, ha⟩\n        rcases not_forall.mp ha with ⟨haA, hb⟩\n        rcases not_forall.mp hb with ⟨b, hbA, hneq⟩\n        rcases not_imp.mp hneq with ⟨hneab, heq⟩\n        -- choose our already picked distinct elements to be those\n        -- fallback: just use classical choice with exists from card argument directly\n        -- but we already have T₁,T₂; conclude by contradiction with injectivity on {T₁,T₂}\n        by_contra h\n        have hinj2 : (T₁ ∈ A ∧ T₂ ∈ A ∧ T₁ ≠ T₂) → (∑ x ∈ T₁, x) ≠ (∑ x ∈ T₂, x) := by\n          intro h'; exact h\n        exact (hinj2 ⟨hT₁, hT₂, hne⟩) rfl\n      exact this\n    exact ⟨T₁, hT₁, T₂, hT₂, hne, hsumeq⟩\n  rcases this with ⟨T₁, hT₁, T₂, hT₂, hne, hsumeq⟩\n  -- make them disjoint by taking differences from intersection\n  let I := T₁ ∩ T₂\n  let S₁ := T₁ \\ I\n  let S₂ := T₂ \\ I\n  have hdis : Disjoint S₁ S₂ := by\n    refine Finset.disjoint_left.2 ?_\n    intro x hx1 hx2\n    have hxI1 : x ∉ I := by\n      exact Finset.not_mem_of_mem_diff hx1\n    have hxI2 : x ∉ I := by\n      exact Finset.not_mem_of_mem_diff hx2\n    have hxT1 : x ∈ T₁ := (Finset.mem_diff.mp hx1).1\n    have hxT2 : x ∈ T₂ := (Finset.mem_diff.mp hx2).1\n    have : x ∈ I := by simp [I, hxT1, hxT2]\n    exact hxI1 this\n  have hsumdiff : (∑ x ∈ S₁, x) = (∑ x ∈ S₂, x) := by\n    -- cancel sums over intersection\n    have hsubset1 : I ⊆ T₁ := Finset.inter_subset_left\n    have hsubset2 : I ⊆ T₂ := Finset.inter_subset_right\n    have hdecomp1 : (∑ x ∈ T₁, x) = (∑ x ∈ I, x) + (∑ x ∈ S₁, x) := by\n      simpa [S₁, I, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using\n        (Finset.sum_eq_sum_inter_add_sum_diff (T := T₁) (U := T₂) (f := fun x => x))\n    have hdecomp2 : (∑ x ∈ T₂, x) = (∑ x ∈ I, x) + (∑ x ∈ S₂, x) := by\n      simpa [S₂, I, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using\n        (Finset.sum_eq_sum_inter_add_sum_diff (T := T₂) (U := T₁) (f := fun x => x))\n    -- use hsumeq\n    have := congrArg id hsumeq\n    -- rewrite and cancel\n    have : (∑ x ∈ I, x) + (∑ x ∈ S₁, x) = (∑ x ∈ I, x) + (∑ x ∈ S₂, x) := by\n      simpa [hdecomp1, hdecomp2] using hsumeq\n    exact Nat.add_left_cancel this\n  have hS1sub : S₁ ⊆ S := by\n    intro x hx\n    have hxT : x ∈ T₁ := (Finset.mem_diff.mp hx).1\n    have hT1S : T₁ ⊆ S := by\n      have : T₁ ∈ S.powerset := (Finset.mem_erase.mp (by simpa [A] using hT₁)).2\n      exact Finset.mem_powerset.mp this\n    exact hT1S hxT\n  have hS2sub : S₂ ⊆ S := by\n    intro x hx\n    have hxT : x ∈ T₂ := (Finset.mem_diff.mp hx).1\n    have hT2S : T₂ ⊆ S := by\n      have : T₂ ∈ S.powerset := (Finset.mem_erase.mp (by simpa [A] using hT₂)).2\n      exact Finset.mem_powerset.mp this\n    exact hT2S hxT\n  have hS1ne : S₁.Nonempty := by\n    by_contra h\n    have hS1empty : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.mp h\n    have hsub : T₁ ⊆ T₂ := by\n      intro x hx\n      by_contra hx2\n      have : x ∈ S₁ := by\n        have : x ∉ I := by\n          intro hxI\n          have : x ∈ T₂ := (Finset.mem_inter.mp hxI).2\n          exact hx2 this\n        exact Finset.mem_diff.mpr ⟨hx, this⟩\n      simpa [hS1empty] using this\n    have hsub' : T₂ ⊆ T₁ := by\n      -- symmetric using sums equality and strictness not needed; instead use hne with cardinal?\n      -- use same argument: if S₁ empty then T₁ ⊆ T₂; but if also S₂ empty then equal; else disjoint sets exist already\n      intro x hx\n      by_contra hx1\n      have : x ∈ S₂ := by\n        have : x ∉ I := by\n          intro hxI\n          have : x ∈ T₁ := (Finset.mem_inter.mp hxI).1\n          exact hx1 this\n        exact Finset.mem_diff.mpr ⟨hx, this⟩\n      -- if S₂ nonempty we are done later; contradiction approach: show then sumdiff forces S₂ empty too\n      -- easier: if S₁ empty, then sumdiff gives sum over S₂ = 0, hence S₂ empty, hence T₁=T₂ contradict hne\n      have hsum0 : (∑ x ∈ S₂, x) = 0 := by\n        have : (∑ x ∈ S₁, x) = 0 := by simp [hS1empty]\n        exact by simpa [hsumdiff] using this\n      have hS2empty : S₂ = ∅ := by\n        apply Finset.eq_empty_iff_forall_not_mem.2\n        intro y hy\n        have : 0 < y := Nat.pos_of_ne_zero (by\n          have hyS : y ∈ S := hS2sub (by simpa using hy)\n          have hyI : y ∈ Finset.Ico 10 100 := h₁ hyS\n          exact Nat.ne_of_gt (lt_of_lt_of_le (by exact (Finset.mem_Ico.mp hyI).1) (by decide)))\n        have : 0 < ∑ z ∈ S₂, z := by\n          have : y ≤ ∑ z ∈ S₂, z := by\n            simpa [Finset.sum_eq_add_sum_diff_singleton hy] using\n              Nat.le_add_right y (∑ z ∈ S₂ \\ {y}, z)\n          exact lt_of_lt_of_le this (by exact Nat.zero_lt_of_lt this)\n        exact (by simpa [hsum0] using this).false.elim\n      have : x ∈ T₁ := by\n        have hxT2 : x ∈ T₂ := hx\n        have hxnotI : x ∉ I := by\n          intro hxI; exact hx1 (Finset.mem_inter.mp hxI).1\n        have : x ∈ S₂ := Finset.mem_diff.mpr ⟨hxT2, hxnotI⟩\n        simpa [hS2empty] using this\n      exact hx1 this\n    have : T₁ = T₂ := Finset.Subset.antisymm hsub hsub'\n    exact hne this\n  have hS2ne : S₂.Nonempty := by\n    have : (∑ x ∈ S₂, x) = (∑ x ∈ S₁, x) := by simpa [hsumdiff] using (Eq.symm hsumdiff)\n    -- since S₁ nonempty and all elements ≥ 10, sum>0 hence S₂ nonempty\n    by_contra h\n    have hS2empty : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.mp h\n    have : (∑ x ∈ S₂, x) = 0 := by simp [hS2empty]\n    have : (∑ x ∈ S₁, x) = 0 := by simpa [hsumdiff, this] using rfl\n    rcases hS1ne with ⟨a, ha⟩\n    have haS : a ∈ S := hS1sub ha\n    have haI : a ∈ Finset.Ico 10 100 := h₁ haS\n    have ha10 : 10 ≤ a := (Finset.mem_Ico.mp haI).1\n    have hpos : 0 < (∑ x ∈ S₁, x) := by\n      have : a ≤ ∑ x ∈ S₁, x := by\n        simpa [Finset.sum_eq_add_sum_diff_singleton ha] using\n          Nat.le_add_right a (∑ x ∈ S₁ \\ {a}, x)\n      exact lt_of_lt_of_le (Nat.pos_of_ne_zero (Nat.ne_of_gt (lt_of_lt_of_le (by exact Nat.succ_le_iff.mp (Nat.succ_le_succ ha10)) (le_of_eq rfl)))) this\n    exact (by simpa [this] using hpos).false.elim\n  refine ⟨S₁, S₂, hS1ne, hS1sub, hS2ne, hS2sub, hdis, hsumdiff⟩",
      "\n  classical\n  obtain ⟨T, hTsub, hTcard⟩ : ∃ T : Finset ℕ, T ⊆ S ∧ T.card = 9 := by\n    rcases S.card_pos.2 (by simpa [h₀] : 0 < S.card) with ⟨a, haS⟩\n    refine ⟨S.erase a, Finset.erase_subset _ _, ?_⟩\n    simpa [Finset.card_erase_of_mem haS, h₀]\n  set U : Finset ℕ := T.powerset.erase ∅ with hU\n  have hUsub : U ⊆ T.powerset := by\n    intro A hA\n    exact Finset.mem_powerset.1 (Finset.mem_of_mem_erase hA)\n  have hUnonempty : ∀ {A : Finset ℕ}, A ∈ U → A.Nonempty := by\n    intro A hA\n    have hA' : A ≠ ∅ := by\n      exact Finset.ne_of_mem_erase hA\n    exact Finset.nonempty_iff_ne_empty.2 hA'\n  have hUcard : U.card = 511 := by\n    have : (T.powerset.erase ∅).card = T.powerset.card - 1 := by\n      simpa [Finset.card_erase_of_mem] using (Finset.card_erase_of_mem (by simp))\n    have hpow : T.powerset.card = 2 ^ T.card := by simpa using Finset.card_powerset T\n    have : U.card = T.powerset.card - 1 := by\n      simpa [hU] using (Finset.card_erase_of_mem (by simp : (∅ : Finset ℕ) ∈ T.powerset))\n    simp [this, hpow, hTcard]\n  have hsum_bounds :\n      ∀ {A : Finset ℕ}, A ⊆ S → (∑ x ∈ A, x) ≤ 99 * A.card := by\n    intro A hAsub\n    classical\n    refine Finset.sum_le_sum ?_\n    intro x hx\n    have hxS : x ∈ S := hAsub hx\n    have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n    have hxlt : x < 100 := (Finset.mem_Ico.1 hxI).2\n    have : x ≤ 99 := Nat.le_of_lt_succ (by simpa using hxlt)\n    exact le_trans this (Nat.le_mul_of_pos_right (Nat.succ_pos _))\n  have hsum_upper :\n      ∀ {A : Finset ℕ}, A ∈ U → (∑ x ∈ A, x) ≤ 891 := by\n    intro A hA\n    have hA_T : A ⊆ T := Finset.mem_powerset.1 (hUsub hA)\n    have hA_S : A ⊆ S := fun x hx => hTsub (hA_T hx)\n    have hcard : A.card ≤ 9 := by\n      exact le_trans (Finset.card_le_card hA_T) (by simpa [hTcard])\n    have hsumle : (∑ x ∈ A, x) ≤ 99 * A.card := hsum_bounds (A := A) hA_S\n    have : 99 * A.card ≤ 99 * 9 := Nat.mul_le_mul_left 99 hcard\n    have : 99 * 9 = 891 := by decide\n    exact le_t