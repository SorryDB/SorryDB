)) with ⟨T1, hT1⟩\n  -- use pigeonhole directly to get collision\n  classical\n  have hnotinj : ∃ a b : {T // T ∈ A}, a ≠ b ∧ f a = f b := by\n    classical\n    -- standard finite pigeonhole: if card domain > card codomain then not injective\n    have hgt : (Finset.Icc 10 945).card < A.card := by\n      simpa [hAcard, hcodomain_card] using (by decide : (936 : ℕ) < 1023)\n    simpa [Function.Injective] using (Finset.exists_ne_map_eq_of_card_lt_of_maps_to\n      (s := A) (t := Finset.Icc 10 945)\n      (f := fun T => ∑ x ∈ T, x)\n      (by\n        intro T hT\n        have : (⟨T, hT⟩ : {T // T ∈ A}) |> hf_range = by rfl\n        exact hf_range ⟨T, hT⟩)\n      hgt)\n  rcases hnotinj with ⟨a, b, habne, habeq⟩\n  rcases a with ⟨T, hTA⟩\n  rcases b with ⟨U, hUA⟩\n  have hTsub : T ⊆ S := by\n    have : T ∈ S.powerset := (Finset.mem_erase.mp hTA).1\n    exact Finset.mem_powerset.mp this\n  have hUsub : U ⊆ S := by\n    have : U ∈ S.powerset := (Finset.mem_erase.mp hUA).1\n    exact Finset.mem_powerset.mp this\n  have hTne : T.Nonempty := by\n    have : T ≠ ∅ := (Finset.mem_erase.mp hTA).2\n    exact Finset.nonempty_iff_ne_empty.mpr this\n  have hUne : U.Nonempty := by\n    have : U ≠ ∅ := (Finset.mem_erase.mp hUA).2\n    exact Finset.nonempty_iff_ne_empty.mpr this\n  have hsum : (∑ x ∈ T, x) = ∑ x ∈ U, x := habeq\n  have hneqTU : T ≠ U := by\n    intro hEq\n    apply habne\n    cases habne\n    simp [hEq]\n  let S₁ : Finset ℕ := T \\ U\n  let S₂ : Finset ℕ := U \\ T\n  have hdis : Disjoint S₁ S₂ := by\n    exact Finset.disjoint_sdiff_sdiff\n  have hsum' : (∑ x ∈ S₁, x) = ∑ x ∈ S₂, x := by\n    have : (∑ x ∈ T, x) = (∑ x ∈ (T ∩ U), x) + ∑ x ∈ (T \\ U), x := by\n      simpa [Finset.sum_sdiff, Finset.inter_subset_left] using\n        (Finset.sum_add_sum_compl (s := T) (t := T ∩ U) (f := fun x => x))\n    have : (∑ x ∈ U, x) = (∑ x ∈ (T ∩ U), x) + ∑ x ∈ (U \\ T), x := by\n      simpa [Finset.inter_comm, Finset.sum_sdiff, Finset.inter_subset_left] using\n        (Finset.sum_add_sum_compl (s := U) (t := U ∩ T) (f := fun x => x))\n    have h1 :\n        (∑ x ∈ T, x) = (∑ x ∈ (T ∩ U), x) + ∑ x ∈ (T \\ U), x := by\n      simpa [Finset.sum_sdiff, Finset.inter_subset_left] using\n        (Finset.sum_inter_add_sum_sdiff (s := T) (t := U) (f := fun x => x))\n    have h2 :\n        (∑ x ∈ U, x) = (∑ x ∈ (T ∩ U), x) + ∑ x ∈ (U \\ T), x := by\n      simpa [Finset.sum_sdiff, Finset.inter_subset_left] using\n        (Finset.sum_inter_add_sum_sdiff (s := U) (t := T) (f := fun x => x))\n    have := by\n      -- cancel common term\n      linarith [hsum, h1, h2]\n    simpa [S₁, S₂] using this\n  have hS₁ne : S₁.Nonempty := by\n    by_contra h\n    have h' : T ⊆ U := by\n      intro x hx\n      by_contra hxU\n      have : x ∈ S₁ := by simpa [S₁, hx, hxU]\n      exact (Finset.not_nonempty_iff_eq_empty.mp h) (by\n        refine ⟨x, this⟩)\n    have hTU : T = U := by\n      apply Finset.eq_of_subset_of_card_le h' (by\n        have := Finset.card_le_card hUsub\n        have := Finset.card_le_of_subset h'\n        exact le_antisymm (Finset.card_le_of_subset h') (Finset.card_le_of_subset (by\n          intro x hx; exact hTsub hx)))\n    exact hneqTU hTU\n  have hS₂ne : S₂.Nonempty := by\n    by_contra h\n    have h' : U ⊆ T := by\n      intro x hx\n      by_contra hxT\n      have : x ∈ S₂ := by simpa [S₂, hx, hxT]\n      exact (Finset.not_nonempty_iff_eq_empty.mp h) (by\n        refine ⟨x, this⟩)\n    have hUT : U = T := by\n      apply Finset.eq_of_subset_of_card_le h' (by\n        have := Finset.card_le_card hTsub\n        have := Finset.card_le_of_subset h'\n        exact le_antisymm (Finset.card_le_of_subset h') (Finset.card_le_of_subset (by\n          intro x hx; exact hUsub hx)))\n    exact hneqTU hUT.symm\n  refine ⟨S₁, S₂, hS₁ne, ?_, hS₂ne, ?_, hdis, hsum'⟩\n  · intro x hx\n    have : x ∈ T := (Finset.mem_sdiff.mp hx).1\n    exact hTsub this\n  · intro x hx\n    have : x ∈ U := (Finset.mem_sdiff.mp hx).1\n    exact hUsub this",
      "\n  classical\n  have hcard : S.powerset.card = 2 ^ S.card := by\n    simpa using (Finset.card_powerset S)\n  have hbig : (2 : ℕ) ^ S.card = 1024 := by\n    simp [h₀]\n  have hps : S.powerset.card = 1024 := by\n    simpa [hbig] using congrArg id (by simpa [h₀] using hcard)\n  -- define the sum of a subset\n  let f : {T // T ∈ S.powerset} → ℕ := fun T => ∑ x ∈ (T.1), x\n  -- bound all subset sums by 990\n  have hsum_le : ∀ T : {T // T ∈ S.powerset}, f T ≤ 990 := by\n    intro T\n    have hsub : (T.1 : Finset ℕ) ⊆ S := by\n      exact (Finset.mem_powerset.mp T.2)\n    have hsub' : (T.1 : Finset ℕ) ⊆ Finset.Ico 10 100 := by\n      exact subset_trans hsub h₁\n    have hle99 : ∀ x ∈ (T.1 : Finset ℕ), x ≤ 99 := by\n      intro x hx\n      have hx' : x ∈ Finset.Ico 10 100 := hsub' hx\n      exact Nat.lt_succ_iff.mp (Finset.mem_Ico.mp hx').2\n    have hcard_le : (T.1 : Finset ℕ).card ≤ 10 := by\n      exact Finset.card_le_card hsub\n    have hsum_le' : (∑ x ∈ (T.1 : Finset ℕ), x) ≤ (T.1 : Finset ℕ).card * 99 := by\n      classical\n      simpa [Nat.mul_comm] using\n        (Finset.sum_le_sum fun x hx => by\n          have := hle99 x hx\n          exact Nat.le_trans this (Nat.le_mul_of_pos_left (Nat.succ_pos _)))\n    have : (T.1 : Finset ℕ).card * 99 ≤ 10 * 99 := by\n      exact Nat.mul_le_mul_right 99 hcard_le\n    have : (∑ x ∈ (T.1 : Finset ℕ), x) ≤ 10 * 99 := le_trans hsum_le' this\n    simpa using this\n  -- pigeonhole on subset sums: 1024 subsets but only 991 possible sums (0..990)\n  have hrange : (Set.range f).Finite := by\n    classical\n    exact Set.finite_range f\n  have hcard_range_le : (Set.range f).ncard ≤ 991 := by\n    classical\n    have : Set.range f ⊆ Set.Icc (0 : ℕ) 990 := by\n      intro y hy\n      rcases hy with ⟨T, rfl⟩\n      refine ⟨Nat.zero_le _, ?_⟩\n      exact hsum_le T\n    have hfin : (Set.Icc (0 : ℕ) 990).Finite := by\n      simpa using (Set.finite_Icc (0 : ℕ) 990)\n    have : (Set.range f).Finite := hrange\n    have := Set.Finite.ncard_le_of_subset this this\n    simpa using le_trans this (by\n      simpa using (Set.ncard_Icc (0 : ℕ) 990))\n  have hcollision : ∃ T₁ T₂ : {T // T ∈ S.powerset}, T₁ ≠ T₂ ∧ f T₁ = f T₂ := by\n    classical\n    by_contra h\n    have hinj : Function.Injective f := by\n      intro a b hab\n      by_contra hne\n      exact h ⟨a, b, hne, hab⟩\n    have : (S.powerset.card : ℕ) ≤ (Set.range f).ncard := by\n      simpa [Set.ncard_range_of_injective hinj] using (le_rfl : S.powerset.card ≤ S.powerset.card)\n    have : (1024 : ℕ) ≤ 991 := by\n      have := le_trans (by simpa [hps] using this) hcard_range_le\n      exact this\n    exact Nat.not_succ_le_self 991 (by simpa using this)\n  rcases hcollision with ⟨T₁, T₂, hne, hsum⟩\n  -- from two distinct subsets with equal sum, extract disjoint nonempty subsets with equal sum\n  let A : Finset ℕ := T₁.1 \\ T₂.1\n  let B : Finset ℕ := T₂.1 \\ T₁.1\n  have hA_sub : A ⊆ S := by\n    intro x hx\n    have hx' : x ∈ T₁.1 := (Finset.mem_sdiff.mp hx).1\n    exact (Finset.mem_powerset.mp T₁.2) hx'\n  have hB_sub : B ⊆ S := by\n    intro x hx\n    have hx' : x ∈ T₂.1 := (Finset.mem_sdiff.mp hx).1\n    exact (Finset.mem_powerset.mp T₂.2) hx'\n  have hdisj : Disjoint A B := by\n    exact Finset.disjoint_sdiff_sdiff\n  have hsum' :\n      (∑ x ∈ A, x) = ∑ x ∈ B, x := by\n    classical\n    have hdecomp1 :\n        (∑ x ∈ T₁.1, x) = (∑ x ∈ (T₁.1 ∩ T₂.1), x) + ∑ x ∈ A, x := by\n      have hd : Disjoint (T₁.1 ∩ T₂.1) A := by\n        exact (Finset.disjoint_left.2 (by\n          intro x hx1 hx2\n          have : x ∈ T₂.1 := (Finset.mem_inter.mp hx1).2\n          exact (Finset.mem_sdiff.mp hx2).2 this))\n      have hu : (T₁.1 ∩ T₂.1) ∪ A = T₁.1 := by\n        ext x; constructor\n        · intro hx\n          rcases Finset.mem_union.mp hx with hx | hx\n          · exact (Finset.mem_inter.mp hx).1\n          · exact (Finset.mem_sdiff.mp hx).1\n        · intro hx\n          by_cases hx2 : x ∈ T₂.1\n          · exact Finset.mem_union.mpr (Or.inl (Finset.mem_inter.mpr ⟨hx, hx2⟩))\n          · exact Finset.mem_union.mpr (Or.inr (Finset.mem_sdiff.mpr ⟨hx, hx2⟩))\n      simpa [hu, Finset.sum_union hd] using (rfl : (∑ x ∈ T₁.1, x) = ∑ x ∈ ((T₁.1 ∩ T₂.1) ∪ A), x)\n    have hdecomp2 :\n        (∑ x ∈ T₂.1, x) = (∑ x ∈ (T₁.1 ∩ T₂.1), x) + ∑ x ∈ B, x := by\n      have hd : Disjoint (T₁.1 ∩ T₂.1) B := by\n        exact (Finset.disjoint_left.2 (by\n          intro x hx1 hx2\n          have : x ∈ T₁.1 := (Finset.mem_inter.mp hx1).1\n          exact (Finset.mem_sdiff.mp hx2).2 this))\n      have hu : (T₁.1 ∩ T₂.1) ∪ B = T₂.1 := by\n        ext x; constructor\n        · intro hx\n          rcases Finset.mem_union.mp hx with hx | hx\n          · exact (Finset.mem_inter.mp hx).2\n          · exact (Finset.mem_sdiff.mp hx).1\n        · intro hx\n          by_cases hx1 : x ∈ T₁.1\n          · exact Finset.mem_union.mpr (Or.inl (Finset.mem_inter.mpr ⟨hx1, hx⟩))\n          · exact Finset.mem_union.mpr (Or.inr (Finset.mem_sdiff.mpr ⟨hx, hx1⟩))\n      simpa [hu, Finset.sum_union hd] using (rfl : (∑ x ∈ T₂.1, x) = ∑ x ∈ ((T₁.1 ∩ T₂.1) ∪ B), x)\n    have : (∑ x ∈ (T₁.1 ∩ T₂.1), x) + (∑ x ∈ A, x) =\n        (∑ x ∈ (T₁.1 ∩ T₂.1), x) + (∑ x ∈ B, x) := by\n      simpa [hdecomp1, hdecomp2] using hsum\n    exact Nat.add_left_cancel this\n  have hA_nonempty : A.Nonempty ∨ B.Nonempty := by\n    classical\n    -- if both empty then T₁ = T₂\n    by_contra hne'\n    have hA : A = ∅ := by\n      by_contra hAne\n      exact hne' (Or.inl (Finset.nonempty_iff_ne_empty.2 hAne))\n    have hB : B = ∅ := by\n      by_contra hBne\n      exact hne' (Or.inr (Finset.nonempty_iff_ne_empty.2 hBne))\n    have : T₁.1 = T₂.1 := by\n      ext x\n      constructor\n      · intro hx\n        by_cases hx2 : x ∈ T₂.1\n        · exact hx2\n        · have : x ∈ A := by\n            exact Finset.mem_sdiff.mpr ⟨hx, hx2⟩\n          simpa [hA] using this\n      · intro hx\n        by_cases hx1 : x ∈ T₁.1\n        · exact hx1\n        · have : x ∈ B := by\n            exact Finset.mem_sdiff.mpr ⟨hx, hx1⟩\n          simpa [hB] using this\n    exact hne (by\n      cases T₁ with\n      | mk T₁ hT₁ =>\n        cases T₂ with\n        | mk T₂ hT₂ =>\n          simp at this\n          simpa [Subtype.ext (by simpa using this)])\n  cases hA_nonempty with\n  | inl hAne =>\n      refine ⟨A, B, ?_, hA_sub, ?_, hB_sub, hdisj, hsum'⟩\n      · exact hAne\n      ·\n        have : B.Nonempty := by\n          -- if B empty then A = T₁ and T₂ ⊆ T₁, forcing equality of sums implies T₂ = T₁, contradicting hne\n          by_contra hBe\n          have hB0 : B = ∅ := Finset.not_nonempty_iff_eq_empty.mp hBe\n          have hT2sub : T₂.1 ⊆ T₁.1 := by\n            intro x hx\n            by_contra hx1\n            have : x ∈ B := Finset.mem_sdiff.mpr ⟨hx, hx1⟩\n            simpa [hB0] using this\n          have hsum_le' : (∑ x ∈ T₂.1, x) ≤ ∑ x ∈ T₁.1, x := by\n            exact Finset.sum_le_sum_of_subset_of_nonneg hT2sub (by intro; exact Nat.zero_le _)\n          have hsum_eq : (∑ x ∈ T₂.1, x) = ∑ x ∈ T₁.1, x := by\n            simpa [f] using hsum.symm\n          have hsum_ge' : (∑ x ∈ T₁.1, x) ≤ ∑ x ∈ T₂.1, x := by\n            simpa [hsum_eq] using le_rfl\n          have hsum_eq' : ∑ x ∈ T₁.1, x = ∑ x ∈ T₂.1, x := le_antisymm hsum_ge' (by simpa [hsum_eq] using hsum_le')\n          have hEq : T₁.1 = T₂.1 := by\n            exact Finset.eq_of_subset_of_sum_eq hT2sub (by simpa using hsum_eq'.symm)\n          exact hne (by\n            cases T₁ with\n            | mk T₁ hT₁ =>\n              cases T₂ with\n              | mk T₂ hT₂ =>\n                simp at hEq\n                have : T₁ = T₂ := by simpa using hEq\n                simpa [Subtype.ext (by simpa using this)])\n        exact this\n  | inr hBne =>\n      refine ⟨B, A, ?_, hB_sub, ?_, hA_sub, ?_, ?_⟩\n      · exact hBne\n      ·\n        have : A.Nonempty := by\n          by_contra hAe\n          have hA0 : A = ∅ := Finset.not_nonempty_iff_eq_empty.mp hAe\n          have hT1sub : T₁.1 ⊆ T₂.1 := by\n            intro x hx\n            by_contra hx2\n            have : x ∈ A := Finset.mem_sdiff.mpr ⟨hx, hx2⟩\n            simpa [hA0] using this\n          have hsum_eq : (∑ x ∈ T₁.1, x) = ∑ x ∈ T₂.1, x := by\n            simpa [f] using hsum\n          have hEq : T₁.1 = T₂.1 := by\n            exact Finset.eq_of_subset_of_sum_eq hT1sub (by simpa using hsum_eq)\n          exact hne (by\n            cases T₁ with\n            | mk T₁ hT₁ =>\n              cases T₂ with\n              | mk T₂ hT₂ =>\n                simp at hEq\n                have : T₁ = T₂ := by simpa using hEq\n                simpa [Subtype.ext (by simpa using this)])\n        exact this\n      · simpa [hdisj, Finset.disjoint_comm] using hdisj.symm\n      · simpa [hsum'] using hsum'.symm",
      "\n  classical\n  have hS : S.Nonempty := by\n    rcases Finset.card_pos.2 (by simpa [h₀]) with h\n    exact h\n  obtain ⟨T, hTsub, hTne, hTsum, hTmin⟩ :\n      ∃ T : Finset ℕ,\n        T ⊆ S ∧ T.Nonempty ∧\n        (∑ x ∈ T, x) = Nat.sInf ((Finset.image (fun U : Finset ℕ => ∑ x ∈ U, x)\n            ((S.powerset).erase ∅))).1 ∧ True := by\n    refine ⟨{S.min' hS}, ?_, ?_, ?_, trivial⟩\n    · intro x hx\n      simpa using (Finset.min'_mem S hS)\n    · simp\n    · simp\n  -- Use a standard pigeonhole argument on nonempty subsets and their sums.\n  -- There are 2^10 - 1 = 1023 nonempty subsets, but sums are at most 990, so two distinct subsets have same sum.\n  have hcard_sub :\n      ((S.powerset).erase ∅).card = 1023 := by\n    -- powerset card = 2^|S|\n    have : (S.powerset).card = 2 ^ S.card := by simpa using Finset.card_powerset S\n    -- erase empty reduces by 1\n    have hmem : (∅ : Finset ℕ) ∈ S.powerset := by simpa using (Finset.empty_subset (S := S))\n    have : ((S.powerset).erase (∅ : Finset ℕ)).card = (S.powerset).card - 1 := by\n      simpa [Finset.card_erase_of_mem hmem]\n    -- compute\n    have : ((S.powerset).erase (∅ : Finset ℕ)).card = 2 ^ 10 - 1 := by\n      simpa [this, h₀] using congrArg (fun n => n - 1) this\n    -- 2^10 - 1 = 1023\n    simpa using this\n  have hsum_le : ∀ U : Finset ℕ, U ⊆ S → (∑ x ∈ U, x) ≤ 990 := by\n    intro U hU\n    have hcardU : U.card ≤ 10 := by\n      simpa [h₀] using Finset.card_le_card hU\n    have hle_each : ∀ x ∈ U, x ≤ 99 := by\n      intro x hx\n      have hxS : x ∈ S := hU hx\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      exact Nat.lt_succ_iff.mp (Finset.mem_Ico.mp hxI).2\n    have : (∑ x ∈ U, x) ≤ ∑ _x ∈ U, 99 := by\n      exact Finset.sum_le_sum fun x hx => hle_each x hx\n    have : (∑ x ∈ U, x) ≤ U.card * 99 := by\n      simpa [Finset.sum_const_nat] using this\n    have : (∑ x ∈ U, x) ≤ 10 * 99 := by\n      exact le_trans this (Nat.mul_le_mul_right 99 hcardU)\n    simpa using this\n  let A : 