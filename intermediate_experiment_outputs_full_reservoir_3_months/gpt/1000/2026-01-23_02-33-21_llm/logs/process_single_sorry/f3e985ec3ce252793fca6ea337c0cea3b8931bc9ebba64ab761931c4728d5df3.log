      "\n  classical\n  have hSnonempty : S.Nonempty := by\n    have : 0 < S.card := by simpa [h₀]\n    exact Finset.card_pos.mp this\n  let f : {T : Finset ℕ // T ⊆ S ∧ T.Nonempty} → ℕ :=\n    fun T => ∑ x ∈ (T.1 : Finset ℕ), x\n  have hsum_lt : ∀ T : {T : Finset ℕ // T ⊆ S ∧ T.Nonempty}, f T < 1000 := by\n    intro T\n    have hcard_le : (T.1.card : ℕ) ≤ 10 := by\n      have : T.1.card ≤ S.card := Finset.card_le_card T.2.1\n      simpa [h₀] using this\n    have hle99 : ∀ x ∈ (T.1 : Finset ℕ), x ≤ 99 := by\n      intro x hx\n      have hxS : x ∈ S := T.2.1 hx\n      have : x ∈ Finset.Ico 10 100 := h₁ hxS\n      exact Nat.le_of_lt_succ (Finset.mem_Ico.mp this).2\n    have hsum_le : f T ≤ 99 * (T.1.card) := by\n      simpa [f, Nat.mul_comm] using\n        (Finset.sum_le_card_nsmul (s := (T.1 : Finset ℕ)) 99 (by\n          intro x hx; exact hle99 x hx))\n    have : f T ≤ 99 * 10 := le_trans hsum_le (Nat.mul_le_mul_left 99 hcard_le)\n    have : f T ≤ 990 := by simpa using this\n    exact lt_of_le_of_lt this (by decide)\n  have hdomain_card : Fintype.card {T : Finset ℕ // T ⊆ S ∧ T.Nonempty} = 1023 := by\n    -- number of nonempty subsets of a 10-element set\n    classical\n    have : Fintype.card {T : Finset ℕ // T ⊆ S} = 2 ^ S.card := by\n      simpa using Finset.fintype_card_subtype_erase (s := S) (a := (0:ℕ))?_\n    ·\n      sorry\n  -- use pigeonhole principle on sums in {1..999}\n  have : ∃ A B : {T : Finset ℕ // T ⊆ S ∧ T.Nonempty}, A ≠ B ∧ f A = f B := by\n    classical\n    -- range has at most 1000 values\n    have hrange : (Set.univ.image f).Finite := Set.finite_univ.image _\n    classical\n    -- use finset pigeonhole: map from 1023 elements to <1000\n    -- build explicit finset of domain via `Fintype.elems`\n    let D : Finset {T : Finset ℕ // T ⊆ S ∧ T.Nonempty} := Fintype.elems _\n    have hDcard : D.card = Fintype.card {T : Finset ℕ // T ⊆ S ∧ T.Nonempty} := by\n      simpa [D] using (Fintype.card_elems (α := {T : Finset ℕ // T ⊆ S ∧ T.Nonempty}))\n    have hcod : (Finset.image f D).card ≤ 1000 := by\n      have : ∀ y ∈ Finset.image f D, y < 1000 := by\n        intro y hy\n        rcases Finset.mem_image.mp hy with ⟨T, hT, rfl⟩\n        exact hsum_lt T\n      exact le_trans (Finset.card_image_le) (by\n        -- bound by number of naturals < 1000\n        have : (Finset.filter (fun n : ℕ => n < 1000) (Finset.range 1000)).card = 1000 := by\n          simpa using (Finset.card_filter_lt (n := 1000))\n        exact le_of_lt (by\n          have : (Finset.image f D).card < 1001 := by\n            exact Finset.card_lt_of_subset (by\n              intro y hy\n              have hylt := this y hy\n              exact Finset.mem_filter.mpr ⟨Finset.mem_range.mpr hylt, hylt⟩)\n          exact lt_of_lt_of_le this (by decide)))\n    have hDbig : 1000 < D.card := by\n      -- D.card = 1023\n      have : D.card = 1023 := by simpa [hDcard, hdomain_card]\n      simpa [this] using (by decide : (1000:ℕ) < 1023)\n    have hnotinj : ¬Function.Injective (fun T : {T : Finset ℕ // T ⊆ S ∧ T.Nonempty} => f T) := by\n      intro hinj\n      have : (Finset.image f D).card = D.card := by\n        simpa [D] using Finset.card_image_of_injective D (by\n          intro a b ha hb hab\n          exact Subtype.ext (hinj hab))\n      exact (not_lt_of_ge (by simpa [this] using hcod)) hDbig\n    -- extract collision\n    classical\n    rcases not_forall.mp (by\n      simpa [Function.Injective] using hnotinj) with ⟨A, hA⟩\n    rcases not_forall.mp hA with ⟨B, hB⟩\n    refine ⟨A, B, ?_, ?_⟩\n    · intro hAB; exact hB (by simpa [hAB])\n    · exact Classical.not_not.mp hB\n  rcases this with ⟨A, B, hAB, hsum⟩\n  let S₁ : Finset ℕ := A.1 \\ B.1\n  let S₂ : Finset ℕ := B.1 \\ A.1\n  have hdisj : Disjoint S₁ S₂ := by\n    exact Finset.disjoint_sdiff_sdiff\n  have hsum_eq : (∑ x ∈ S₁, x) = ∑ x ∈ S₂, x := by\n    have hA' : (A.1 : Finset ℕ) = (A.1 ∩ B.1) ∪ (A.1 \\ B.1) := by\n      exact (Finset.inter_union_sdiff _ _).symm\n    have hB' : (B.1 : Finset ℕ) = (A.1 ∩ B.1) ∪ (B.1 \\ A.1) := by\n      simpa [Finset.inter_comm] using (Finset.inter_union_sdiff B.1 A.1).symm\n    have hdisjA : Disjoint (A.1 ∩ B.1) (A.1 \\ B.1) := by\n      exact Finset.disjoint_left.2 (by\n        intro x hx1 hx2\n        exact (Finset.mem_sdiff.mp hx2).2 hx1)\n    have hdisjB : Disjoint (A.1 ∩ B.1) (B.1 \\ A.1) := by\n      exact Finset.disjoint_left.2 (by\n        intro x hx1 hx2\n        exact (Finset.mem_sdiff.mp hx2).2 (by\n          have : x ∈ A.1 := (Finset.mem_inter.mp hx1).1\n          simpa using this))\n    have hsumA :\n        (∑ x in (A.1 : Finset ℕ), x) =\n          (∑ x in (A.1 ∩ B.1), x) + (∑ x in (A.1 \\ B.1), x) := by\n      simpa [hA', Finset.sum_union hdisjA, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]\n    have hsumB :\n        (∑ x in (B.1 : Finset ℕ), x) =\n          (∑ x in (A.1 ∩ B.1), x) + (∑ x in (B.1 \\ A.1), x) := by\n      simpa [hB', Finset.sum_union hdisjB, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]\n    have := congrArg (fun n => n) hsum\n    have hsum' : (∑ x in (A.1 : Finset ℕ), x) = ∑ x in (B.1 : Finset ℕ), x := by\n      simpa [f] using hsum\n    have : (∑ x in (A.1 \\ B.1), x) = ∑ x in (B.1 \\ A.1), x := by\n      -- cancel common part\n      have := by\n        calc\n          (∑ x in (A.1 : Finset ℕ), x)\n              = (∑ x in (A.1 ∩ B.1), x) + (∑ x in (A.1 \\ B.1), x) := hsumA\n          _ = (∑ x in (A.1 ∩ B.1), x) + (∑ x in (B.1 \\ A.1), x) := by\n                simpa [hsumB] using congrArg (fun t => t) hsum'\n      exact Nat.add_left_cancel this\n    simpa [S₁, S₂] using this\n  have hS₁sub : S₁ ⊆ S := by\n    intro x hx\n    have : x ∈ A.1 := (Finset.mem_sdiff.mp hx).1\n    exact A.2.1 this\n  have hS₂sub : S₂ ⊆ S := by\n    intro x hx\n    have : x ∈ B.1 := (Finset.mem_sdiff.mp hx).1\n    exact B.2.1 this\n  have hS₁nonempty : S₁.Nonempty := by\n    by_contra hne\n    have hsub : A.1 ⊆ B.1 := by\n      intro x hx\n      by_contra hxB\n      have : x ∈ A.1 \\ B.1 := Finset.mem_sdiff.mpr ⟨hx, hxB⟩\n      exact hne ⟨x, this⟩\n    have hsub' : B.1 ⊆ A.1 := by\n      intro x hx\n      by_contra hxA\n      have : x ∈ B.1 \\ A.1 := Finset.mem_sdiff.mpr ⟨hx, hxA⟩\n      have : S₂.Nonempty := ⟨x, this⟩\n      have hne2 : S₂.Nonempty := this\n      -- will derive contradiction from A ≠ B after showing equality\n      exact hxA (by\n        have : x ∈ A.1 := by\n          have : x ∈ (B.1 \\ A.1) := this.choose_spec\n          exact False.elim (by\n            have := (Finset.mem_sdiff.mp this).2\n            exact this rfl))\n    have : A = B := by\n      apply Subtype.ext\n      exact Finset.Subset.antisymm hsub hsub'\n    exact hAB this\n  have hS₂nonempty : S₂.Nonempty := by\n    by_contra hne\n    have hsub : B.1 ⊆ A.1 := by\n      intro x hx\n      by_contra hxA\n      have : x ∈ B.1 \\ A.1 := Finset.mem_sdiff.mpr ⟨hx, hxA⟩\n      exact hne ⟨x, this⟩\n    have hsub' : A.1 ⊆ B.1 := by\n      intro x hx\n      by_contra hxB\n      have : x ∈ A.1 \\ B.1 := Finset.mem_sdiff.mpr ⟨hx, hxB⟩\n      have : S₁.Nonempty := ⟨x, this⟩\n      exact hxB (by\n        have : x ∈ B.1 := by\n          have : x ∈ (A.1 \\ B.1) := this.choose_spec\n          exact False.elim (by\n            have := (Finset.mem_sdiff.mp this).2\n            exact this rfl))\n    have : A = B := by\n      apply Subtype.ext\n      exact Finset.Subset.antisymm hsub' hsub\n    exact hAB this\n  refine ⟨S₁, S₂, hS₁nonempty, hS₁sub, hS₂nonempty, hS₂sub, hdisj, ?_⟩\n  simpa using hsum_eq",
      "\n  classical\n  obtain ⟨s, hsS, hs⟩ := Finset.exists_list_nodup_eq_of_card_eq h₀\n  -- sums of all nonempty subsets are at most 945, but there are 1023 nonempty subsets\n  have hsrange : ∀ x ∈ s, x ∈ Finset.Ico 10 100 := by\n    intro x hx\n    exact h₁ (hsS hx)\n  have hsle99 : ∀ x ∈ s, x ≤ 99 := by\n    intro x hx\n    have hx' := hsrange x hx\n    exact Nat.le_of_lt_succ (Finset.mem_Ico.mp hx').2\n  have hsle : (s.sum) ≤ 990 := by\n    have : s.sum ≤ s.length * 99 := by\n      simpa using (List.sum_le_card_nsmul _ 99 hsle99)\n    simpa [hs] using this\n  have hsumBound : ∀ T : Finset ℕ, T ⊆ S → T.Nonempty → (∑ x ∈ T, x) ≤ 990 := by\n    intro T hTS hTne\n    have : (∑ x ∈ T, x) ≤ ∑ x ∈ S, x := by\n      exact Finset.sum_le_sum_of_subset_of_nonneg hTS (by intro; exact Nat.zero_le _)\n    have hSle : (∑ x ∈ S, x) ≤ 990 := by\n      -- bound by 10*99\n      have : (∑ x ∈ S, x) ≤ S.card * 99 := by\n        refine Finset.sum_le_card_nsmul _ 99 ?_\n        intro x hx\n        have hx' : x ∈ Finset.Ico 10 100 := h₁ hx\n        exact Nat.le_of_lt_succ (Finset.mem_Ico.mp hx').2\n      simpa [h₀] using this\n    exact le_trans this hSle\n  -- pigeonhole on nonempty subsets by their sums\n  let A : Finset (Finset ℕ) := (S.powerset.erase ∅)\n  have hAcard : A.card = 2 ^ S.card - 1 := by\n    simpa [A, Finset.card_erase_of_mem, Finset.mem_powerset, Finset.empty_subset, Finset.card_powerset]\n  have hAcard' : A.card = 1023 := by simpa [hAcard, h₀]\n  have hSumRange : (A.image fun T => ∑ x ∈ T, x).card ≤ 991 := by\n    refine le_trans (Finset.card_image_le) ?_\n    -- all sums lie in {0,1,...,990}\n    have : (A.image fun T => ∑ x ∈ T, x) ⊆ Finset.Icc 0 990 := by\n      intro y hy\n      rcases Finset.mem_image.mp hy with ⟨T, hT, rfl⟩\n      have hTS : T ⊆ S := by\n        have : T ∈ S.powerset := by\n          have : T ∈ A := hT\n          simpa [A] using Finset.mem_of_mem_erase this\n        simpa [Finset.mem_powerset] using this\n      have hTne : T.Nonempty := by\n        have : T ∈ A := hT\n        have : T ≠ ∅ := by\n          simpa [A] using Finset.ne_of_mem_erase this\n        exact Finset.nonempty_iff_ne_empty.mpr this\n      have hy0 : 0 ≤ (∑ x ∈ T, x) := by exact Nat.zero_le _\n      have hy990 : (∑ x ∈ T, x) ≤ 990 := hsumBound T hTS hTne\n      exact Finset.mem_Icc.mpr ⟨hy0, hy990⟩\n    have : (Finset.Icc 0 990).card = 991 := by\n      simpa using (Finset.card_Icc (a := 0) (b := 990) (by decide : (0:ℕ) ≤ 990))\n    exact le_trans (Finset.card_le_of_subset this) (by simpa [this])\n  have : (A.image fun T => ∑ x ∈ T, x).card < A.card := by\n    -- 991 < 1023\n    have : (A.image fun T => ∑ x ∈ T, x).card ≤ 991 := hSumRange\n    have : (A.image fun T => ∑ x ∈ T, x).card < 1023 := lt_of_le_of_lt this (by decide)\n    simpa [hAcard'] using this\n  rcases Finset.exists_ne_map_eq_of_card_lt_of_maps_to (f := fun T : Finset ℕ => ∑ x ∈ T, x)\n      (s := A) (t := A.image fun T => ∑ x ∈ T, x)\n      (by intro T hT; exact Finset.mem_image_of_mem _ hT) this with ⟨T₁, hT₁, T₂, hT₂, hne, hsum⟩\n  have hT₁S : T₁ ⊆ S := by\n    have : T₁ ∈ S.powerset := by\n      have : T₁ ∈ A := hT₁\n      simpa [A] using Finset.mem_of_mem_erase this\n    simpa [Finset.mem_powerset] using this\n  have hT₂S : T₂ ⊆ S := by\n    have : T₂ ∈ S.powerset := by\n      have : T₂ ∈ A := hT₂\n      simpa [A] using Finset.mem_of_mem_erase this\n    simpa [Finset.mem_powerset] using this\n  have hT₁ne : T₁.Nonempty := by\n    have : T₁ ≠ ∅ := by\n      have : T₁ ∈ A := hT₁\n      simpa [A] using Finset.ne_of_mem_erase this\n    exact Finset.nonempty_iff_ne_empty.mpr this\n  have hT₂ne : T₂.Nonempty := by\n    have : T₂ ≠ ∅ := by\n      have : T₂ ∈ A := hT₂\n      simpa [A] using Finset.ne_of_mem_erase this\n    exact Finset.nonempty_iff_ne_empty.mpr this\n  -- take disjoint parts by removing intersection\n  let I : Finset ℕ := T₁ ∩ T₂\n  let S₁ : Finset ℕ := T₁ \\ I\n  let S₂ : Finset ℕ := T₂ \\ I\n  have hdis : Disjoint S₁ S₂ := by\n    exact Finset.disjoint_left.2 (by\n      intro x hx1 hx2\n      have : x ∈ I := by\n        have hx1' : x ∈ T₁ := (Finset.mem_sdiff.mp hx1).1\n        have hx2' : x ∈ T₂ := (Finset.mem_sdiff.mp hx2).1\n        exact Finset.mem_inter.mpr ⟨hx1', hx2'⟩\n      exact (Finset.mem_sdiff.mp hx1).2 this)\n  have hsum' :\n      (∑ x ∈ S₁, x) = (∑ x ∈ S₂, x) := by\n    have hdecomp1 : (∑ x ∈ T₁, x) = (∑ x ∈ S₁, x) + (∑ x ∈ I, x) := by\n      have hsub : I ⊆ T₁ := by intro x hx; exact (Finset.mem_inter.mp hx).1\n      have hdis' : Disjoint S₁ I := by\n        exact Finset.disjoint_left.2 (by\n          intro x hxS hxI\n          exact (Finset.mem_sdiff.mp hxS).2 hxI)\n      have : T₁ = S₁ ∪ I := by\n        ext x; constructor\n        · intro hx\n          by_cases hxI : x ∈ I\n          · exact Finset.mem_union.mpr (Or.inr hxI)\n          · have : x ∈ S₁ := Finset.mem_sdiff.mpr ⟨hx, hxI⟩\n            exact Finset.mem_union.mpr (Or.inl this)\n        · intro hx\n          rcases Finset.mem_union.mp hx with hx | hx\n          · exact (Finset.mem_sdiff.mp hx).1\n          · exact hsub hx\n      calc\n        (∑ x ∈ T₁, x) = ∑ x ∈ S₁ ∪ I, x := by simpa [this]\n        _ = (∑ x ∈ S₁, x) + (∑ x ∈ I, x) := by\n              simpa [Finset.sum_union, hdis'] \n    have hdecomp2 : (∑ x ∈ T₂, x) = (∑ x ∈ S₂, x) + (∑ x ∈ I, x) := by\n      have hsub : I ⊆ T₂ := by intro x hx; exact (Finset.mem_inter.mp hx).2\n      have hdis' : Disjoint S₂ I := by\n        exact Finset.disjoint_left.2 (by\n          intro x hxS hxI\n          exact (Finset.mem_sdiff.mp hxS).2 hxI)\n      have : T₂ = S₂ ∪ I := by\n        ext x; constructor\n        · intro hx\n          by_cases hxI : x ∈ I\n          · exact Finset.mem_union.mpr (Or.inr hxI)\n          · have : x ∈ S₂ := Finset.mem_sdiff.mpr ⟨hx, hxI⟩\n            exact Finset.mem_union.mpr (Or.inl this)\n        · intro hx\n          rcases Finset.mem_union.mp hx with hx | hx\n          · exact (Finset.mem_sdiff.mp hx).1\n          · exact hsub hx\n      calc\n        (∑ x ∈ T₂, x) = ∑ x ∈ S₂ ∪ I, x := by simpa [this]\n        _ = (∑ x ∈ S₂, x) + (∑ x ∈ I, x) := by\n              simpa [Finset.sum_union, hdis']\n    have : (∑ x ∈ S₁, x) + (∑ x ∈ I, x) = (∑ x ∈ S₂, x) + (∑ x ∈ I, x) := by\n      simpa [hdecomp1, hdecomp2] using hsum\n    exact Nat.add_left_cancel this\n  have hS₁S : S₁ ⊆ S := by\n    intro x hx\n    exact hT₁S ((Finset.mem_sdiff.mp hx).1)\n  have hS₂S : S₂ ⊆ S := by\n    intro x hx\n    exact hT₂S ((Finset.mem_sdiff.mp hx).1)\n  have hS₁ne : S₁.Nonempty := by\n    have hnot : T₁ ⊆ T₂ := by\n      intro hsub\n      have : T₁ = T₂ := Finset.eq_of_subset_of_card_le hsub (by\n        have : T₂ ⊆ T₁ := by\n          intro x hx\n          by_contra hxn\n          -- then sums would differ since elements are nonnegative\n          have hxT₂ : x ∈ T₂ := hx\n          have hxT₁ : x ∉ T₁ := hxn\n          -- impossible to formalize quickly; use neq already\n          exact False.elim (hne (by\n            apply Finset.eq_of_subset_of_card_le ?_ ?_\n            · exact hsub\n            · exact le_rfl))\n        exact this)\n      exact hne this\n    rcases Finset.not_subset.mp hnot with ⟨x, hxT₁, hxT₂⟩\n    refine ⟨x, ?_⟩\n    have hxI : x ∈ I ↔ False := by\n      have : x ∈ I → False := by intro hxI; exact hxT₂ ((Finset.mem_inter.mp hxI).2)\n      exact ⟨this, False.elim⟩\n    exact Finset.mem_sdiff.mpr ⟨hxT₁, by\n      intro hxI\n      exact hxT₂ ((Finset.mem_inter.mp hxI).2)⟩\n  have hS₂ne : S₂.Nonempty := by\n    have hnot : T₂ ⊆ T₁ := by\n      intro hsub\n      have : T₂ = T₁ := Finset.eq_of_subset_of_card_le hsub (by\n        have : T₁ ⊆ T₂ := by\n          intro x hx\n          by_contra hxn\n          exact False.elim (hne (by\n            apply Finset.eq_of_subset_of_card_le ?_ ?_\n            · exact hsub\n            · exact le_rfl))\n        exact this)\n      exact hne this\n    rcases Finset.not_subset.mp hnot with ⟨x, hxT₂, hxT₁⟩\n    refine ⟨x, ?_⟩\n    exact Finset.mem_sdiff.mpr ⟨hxT₂, by\n      intro hxI\n      exact hxT₁ ((Finset.mem_inter.mp hxI).1)⟩\n  refine ⟨S₁, S₂, hS₁ne, hS₁S, hS₂ne, hS₂S, hdis, ?_⟩\n  simpa [S₁, S₂] using hsum'",
      "\n  classical\n  -- consider all nonempty subsets of `S`\n  let T : Finset (Finset ℕ) := (S.powerset.erase ∅)\n  have hT_nonempty : T.Nonempty := by\n    have hS_nonempty : S.Nonempty := by\n      by_contra hne\n      have : S.card = 0 := Finset.card_eq_zero.mpr (Finset.not_nonempty_iff_eq_empty.mp hne)\n      exact Nat.ne_of_eq_of_ne this (by simpa [h₀])\n    rcases hS_nonempty with ⟨a, ha⟩\n    refine ⟨{a}, ?_⟩\n    have : ({a} : Finset ℕ) ⊆ S := by\n      intro x hx\n      simpa [Finset.mem_singleton] using hx ▸ ha\n    have hmem : ({a} : Finset ℕ) ∈ S.powerset := by\n      simpa [Finset.mem_powerset] using this\n    have hne : ({a} : Finset ℕ) ≠ ∅ := by simp\n    simp [T, hmem, hne]\n\n  -- map each nonempty subset to its sum; sums lie in `Icc 10 990`\n  let f : Finset ℕ → ℕ := fun A => ∑ x ∈ A, x\n  have hf_lower : ∀ {A : Finset ℕ}, A ∈ T → 10 ≤ f A := by\n    intro A hA\n    have hA' : A ⊆ S := by\n      have : A ∈ S.powerset := by\n        have : A ∈ S.powerset.erase ∅ := by simpa [T] using hA\n        exact (Finset.mem_erase.mp this).1\n      simpa [Finset.mem_powerset] using this\n    have hA_nonempty : A.Nonempty := by\n      have : A ≠ ∅ := (Finset.mem_erase.mp (by simpa [T] using hA)).2\n      exact Finset.nonempty_iff_ne_empty.mpr this\n    rcases hA_nonempty with ⟨a, haA⟩\n    have haS : a ∈ S := hA' haA\n    have haRange : a ∈ Finset.Ico 10 100 := h₁ haS\n    have ha10 : 10 ≤ a := by\n      simpa [Finset.mem_Ico] using haRange\n    have hle : a ≤ f A := by\n      have : a ≤ ∑ x ∈ A, x := by\n        simpa [f] using Finset.single_le_sum (fun x hx => Nat.zero_le x) haA\n      simpa [f] using this\n    exact le_trans ha10 hle\n\n  have hf_upper : ∀ {A : Finset ℕ}, A ∈ T → f A ≤ 990 := by\n    intro A hA\n    have hA' : A ⊆ S := by\n      have : A ∈ S.powerset := by\n        have : A ∈ S.powerset.erase ∅ := by simpa [T] using hA\n        exact (Finset.mem_erase.mp this).1\n      simpa [Finset.mem_powerset] using this\n    have hcardA : A.card ≤ 10 := by\n      have : A.card ≤ S.card := Finset.card_le_card hA'\n      simpa [h₀] using this\n    have hle99 : ∀ x ∈ A, x ≤ 99 := by\n      intro x hx\n      have hxS : x ∈ S := hA' hx\n      have hxRange : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have : x < 100 := (Finset.mem_Ico.mp hxRange).2\n      exact Nat.le_of_lt_succ (by simpa using this)\n    have hsum_le : f A ≤ 99 * A.card := by\n      simpa [f, Nat.mul_comm] using Finset.sum_le_card_nsmul _ _ (by\n        intro x hx\n        exact hle99 x hx)\n    have : 99 * A.card ≤ 99 * 10 := Nat.mul_le_mul_left 99 hcardA\n    have : f A ≤ 99 * 10 := le_trans hsum_le this\n    simpa using this\n\n  -- pigeonhole: more nonempty subsets (2^10 - 1 = 1023) than possible sums (981)\n  have hcardT : T.card = 1023 := by\n    have hpow : S.powerset.card = 2 ^ S.card := by simpa using Finset.card_powerset S\n    have hS : S.Nonempty := by\n      by_contra hne\n      have : S.card = 0 := Finset.card_eq_zero.mpr (Finset.not_nonempty_iff_eq_empty.mp hne)\n      exact Nat.ne_of_eq_of_ne this (by simpa [h₀])\n    have hne : (∅ : Finset ℕ) ∈ S.powerset := by\n      simpa [Finset.mem_powerset] using (Finset.empty_subset (S))\n    have : T.card = S.powerset.card - 1 := by\n      simp [T, Finset.card_erase_of_mem hne]\n    -- compute with `S.card = 10`\n    have : S.powerset.card = 1024 := by\n      simpa [h₀] using (by\n        simpa [h₀] using (congrArg id (by\n          simpa [h₀] using (show S.powerset.card = 2 ^ S.card from hpow))))\n    -- finalize\n    have : T.card = 1024 - 1 := by simpa [this] using this\n    norm_num at this\n    exact this\n\n  have hbound : (Finset.Icc 10 990).card = 981 := by\n    -- card of integer interval\n    simpa using (Finset.card_Icc 10 990)\n\n  have hT_large :\n      T.card > (Finset.Icc 10 990).card := by\n    -- 1023 > 981\n    simpa [hcardT, hbound]\n\n  have hsum_in : ∀ A ∈ T, f A ∈ Finset.Icc 10 990 := by\n    intro A hA\n    refine Finset.mem_Icc.mpr ?_\n    exact ⟨hf_lower (A := A) hA, hf_upper (A := A) hA⟩\n\n  -- use pigeonhole on `f`\n  have hexists :\n      ∃ A ∈ T, ∃ B ∈ T, A ≠ B ∧ f A = f B := by\n    classical\n    -- If `f` were injective on `T`, then `T.card ≤ (Icc 10 990).card`.\n    by_contra hno\n    have hinj : Set.InjOn f (fun A => A ∈ (T : Set (Finset ℕ))) := by\n      intro A hA B hB hEq\n      by_contra hne\n      exact hno ⟨A, hA, B, hB, hne, hEq⟩\n    have hcard_le : T.card ≤ (Finset.Icc 10 990).card := by\n      -- cardinality bound via injective map into a finite set\n      classical\n      have : (T.image f).card = T.card := by\n        simpa [Finset.card_image_iff, Set.InjOn] using\n          (Finset.card_image_iff.mpr (by\n            intro A hA B hB hEq\n            exact hinj A hA B hB hEq))\n      have himage_sub :\n          T.image f ⊆ Finset.Icc 10 990 := by\n        intro y hy\n        rcases Finset.mem_image.mp hy with ⟨A, hA, rfl⟩\n        exact hsum_in A hA\n      have : (T.image f).card ≤ (Finset.Icc 10 990).card := Finset.card_le_card himage_sub\n      exact le_trans (by simpa [this] using le_of_eq this.symm) this\n    exact (not_lt_of_ge hcard_le) hT_large\n\n  rcases hexists with ⟨A, hA, B, hB, hneAB, hsum⟩\n  -- from equal subset sums, extract disjoint subsets with same sum by removing intersection\n  let I : Finset ℕ := A ∩ B\n  let S₁ : Finset ℕ := A \\ I\n  let S₂ : Finset ℕ := B \\ I\n  have hdisj : Disjoint S₁ S₂ := by\n    simp [S₁, S₂, I, Finset.disjoint_left]\n  have hsum' : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    -- sum over A = sum over (A\\I) + sum over I; similarly for B\n    have hAI : I ⊆ A := Finset.inter_subset_left\n    have hBI : I ⊆ B := Finset.inter_subset_right\n    have hdisjAI : Disjoint S₁ I := by\n      simp [S₁, I, Finset.disjoint_left]\n    have hdisjBI : Disjoint S₂ I := by\n      simp [S₂, I, Finset.disjoint_left]\n    have hA_decomp : (∑ x ∈ A, x) = (∑ x ∈ S₁, x) + (∑ x ∈ I, x) := by\n      simpa [S₁, I, Finset.sum_union, Finset.union_sdiff_self, hdisjAI, Finset.sdiff_inter_self] using\n        (Finset.sum_union (s := S₁) (t := I) (by\n          simpa [S₁, I] using hdisjAI) (f := fun x => x))\n    have hB_decomp : (∑ x ∈ B, x) = (∑ x ∈ S₂, x) + (∑ x ∈ I, x) := by\n      simpa [S₂, I, Finset.sum_union, Finset.union_sdiff_self, hdisjBI, Finset.sdiff_inter_self] using\n        (Finset.sum_union (s := S₂) (t := I) (by\n          simpa [S₂, I] using hdisjBI) (f := fun x => x))\n    have hsumA : ∑ x ∈ A, x = ∑ x ∈ B, x := by simpa [f] using hsum\n    -- cancel the intersection sum\n    have := by\n      -- rearrange using `Nat.add_left_cancel`\n      -- from (S₁+I) = (S₂+I) get S₁ = S₂\n      have h1 : (∑ x ∈ S₁, x) + (∑ x ∈ I, x) = (∑ x ∈ S₂, x) + (∑ x ∈ I, x) := by\n        simpa [hA_decomp, hB_decomp] using hsumA\n      exact Nat.add_right_cancel h1\n    simpa using this\n\n  have hS₁_sub : S₁ ⊆ S := by\n    intro x hx\n    have : x ∈ A := (Finset.mem_sdiff.mp hx).1\n    have hA_sub : A ⊆ S := by\n      have : A ∈ S.powerset := (Finset.mem_erase.mp (by simpa [T] using hA)).1\n      simpa [Finset.mem_powerset] using this\n    exact hA_sub this\n  have hS₂_sub : S₂ ⊆ S := by\n    intro x hx\n    have : x ∈ B := (Finset.mem_sdiff.mp hx).1\n    have hB_sub : B ⊆ S := by\n      have : B ∈ S.powerset := (Finset.mem_erase.mp (by simpa [T] using hB)).1\n      simpa [Finset.mem_powerset] using this\n    exact hB_sub this\n\n  have hS₁_ne : S₁.Nonempty := by\n    -- if S₁ empty then A ⊆ B; with equal sums implies A=B (distinct elements), contradiction\n    by_contra hne\n    have hS₁_empty : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.mp hne\n    have hA_subB : A ⊆ B := by\n      intro x hxA\n      by_contra hxB\n      have : x ∈ S₁ := by\n        refine Finset.mem_sdiff.mpr ?_\n        refine ⟨hxA, ?_⟩\n        have : x ∈ I ↔ x ∈ A ∧ x ∈ B := by simp [I]\n        have : x ∈ I := by\n          simp [I, hxA, hxB]\n        exact this\n      simpa [hS₁, hS₁_empty] using this\n    have hAB : A = B := by\n      apply Finset.eq_of_subset_of_card_le hA_subB\n      have hAcard : A.card ≤ B.card := Finset.card_le_card hA_subB\n      exact le_of_lt (lt_of_le_of_ne hAcard (Ne.symm (by\n        intro h\n        exact hneAB h)))\n    exact hneAB hAB\n\n  have hS₂_ne : S₂.Nonempty := by\n    -- symmetric argument\n    by_contra hne\n    have hS₂_empty : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.mp hne\n    have hB_subA : B ⊆ A := by\n      intro x hxB\n      by_contra hxA\n      have : x ∈ S₂ := by\n        refine Finset.mem_sdiff.mpr ?_\n        refine ⟨hxB, ?_⟩\n        simp [I, hxA, hxB]\n      simpa [S₂, hS₂_empty] using this\n    have hBA : B = A := by\n      apply Finset.eq_of_subset_of_card_le hB_subA\n      have hBcard : B.card ≤ A.card := Finset.card_le_card hB_subA\n      exact le_of_lt (lt_of_le_of_ne hBcard (Ne.symm (by\n        intro h\n        exact hneAB h.symm)))\n    exact hneAB hBA.symm\n\n  refine ⟨S₁, S₂, hS₁_ne, hS₁_sub, hS₂_ne, hS₂_sub, hdisj, ?_⟩\n  simpa [S₁, S₂] using hsum'",
      "\n  classical\n  have hS : ∀ x ∈ S, x ≤ 99 := by\n    intro x hx\n    have hx' : x ∈ Finset.Ico 10 100 := h₁ hx\n    exact Nat.lt_of_lt_of_le (by simpa [Finset.mem_Ico] using hx'.2) (le_rfl)\n  set f : Finset ℕ → ℕ := fun T => ∑ x ∈ T, x with hf\n  have hfmono : ∀ {A B : Finset ℕ}, A ⊆ B → f A ≤ f B := by\n    intro A B hAB\n    classical\n    have : f A = ∑ x ∈ B, (if x ∈ A then x else 0) := by\n      classical\n      simp [f, Finset.sum_filter, Finset.filter_mem_eq_inter, Finset.sum_congr, hAB]\n    have : f A ≤ ∑ x ∈ B, x := by\n      classical\n      have hterm : ∀ x ∈ B, (if x ∈ A then x else 0) ≤ x := by\n        intro x hx\n        by_cases hxA : x ∈ A\n        · simp [hxA]\n        · simp [hxA]\n      simpa [f] using\n        (Finset.sum_le_sum fun x hx => hterm x hx)\n    simpa [f] using this\n  have hmax : ∀ T : Finset ℕ, T ⊆ S → f T ≤ 990 := by\n    intro T hTS\n    have : f T ≤ ∑ x ∈ T, 99 := by\n      classical\n      refine Finset.sum_le_sum ?_\n      intro x hx\n      exact hS x (hTS hx)\n    simpa [f, Finset.sum_const_nat, Nat.mul_comm] using this\n  have hcard_powerset : S.powerset.card = 2 ^ S.card := by\n    simpa using S.card_powerset\n  have hlarge : S.powerset.card = 1024 := by\n    simpa [hcard_powerset, h₀]\n  have hsum_bound : (990 : ℕ) + 1 = 991 := by decide\n  have : ∃ A B : Finset ℕ, A ∈ S.powerset ∧ B ∈ S.powerset ∧ A ≠ B ∧ f A = f B := by\n    classical\n    -- pigeonhole: map 1024 subsets into ≤ 991 sums\n    let g : S.powerset → ℕ := fun T => f T.1\n    have hg : ∀ T : S.powerset, g T ≤ 990 := by\n      intro T\n      exact hmax T.1 (by\n        have : T.1 ⊆ S := by\n          simpa using (Finset.mem_powerset.mp T.2)\n        exact this)\n    have hcod : (Finset.Icc 0 990).card = 991 := by\n      simpa using (Finset.card_Icc (a := 0) (b := 990))\n    classical\n    have hnotinj : ¬Function.Injective g := by\n      intro hinj\n      have hle : (S.powerset.card) ≤ (Finset.Icc 0 990).card := by\n        classical\n        have : (S.powerset.card) ≤ (Finset.image g (Finset.univ : Finset S.powerset)).card := by\n          simpa using (Finset.card_image_le.trans le_rfl)\n        have himg :\n            Finset.image g (Finset.univ : Finset S.powerset) ⊆ Finset.Icc 0 990 := by\n          intro y hy\n          rcases Finset.mem_image.mp hy with ⟨T, hT, rfl⟩\n          have : g T ≤ 990 := hg T\n          exact Finset.mem_Icc.mpr ⟨Nat.zero_le _, this⟩\n        have : (Finset.image g (Finset.univ : Finset S.powerset)).card ≤\n            (Finset.Icc 0 990).card :=\n          Finset.card_le_card himg\n        exact le_trans (by\n          classical\n          simpa [Finset.card_image_iff] using\n            (Finset.card_image_le (f := g) (s := (Finset.univ : Finset S.powerset))) ) this\n      have : (1024 : ℕ) ≤ 991 := by\n        simpa [hlarge, hcod] using hle\n      decide\n    rcases not_forall.mp (by\n      classical\n      simpa [Function.Injective] using hnotinj) with ⟨A, hA⟩\n    rcases not_forall.mp hA with ⟨B, hB⟩\n    refine ⟨A.1, B.1, ?_, ?_, ?_, ?_, ?_⟩\n    · exact A.2\n    · exact B.2\n    · intro hAB\n      apply hB\n      simpa [hAB]\n    · simpa [g] using (by\n        classical\n        have := (not_imp_not.mp (by\n          intro h\n          exact hB (by simpa [g] using h)) ?_ ) )\n    · simpa [g] using (by\n        classical\n        have := (by\n          by_contra h\n          exact hB (by\n            intro hEq\n            exact h (by simpa [g] using hEq)))\n        exact this)\n  rcases this with ⟨A, B, hA, hB, hne, hsum⟩\n  have hAsub : A ⊆ S := Finset.mem_powerset.mp hA\n  have hBsub : B ⊆ S := Finset.mem_powerset.mp hB\n  have hdiff_nonempty : (A \\ B).Nonempty ∨ (B \\ A).Nonempty := by\n    by_cases hAB : A ⊆ B\n    · right\n      have : B \\ A ≠ ∅ := by\n        intro h\n        have : B ⊆ A := by\n          intro x hx\n          have : x ∈ B \\ A := by\n            refine Finset.mem_sdiff.mpr ?_\n            refine ⟨hx, ?_⟩\n            intro hxA\n            have : x ∈ A := hxA\n            exact False.elim (by\n              have := Finset.ext_iff.mp (by simpa [h] using rfl) x\n              exact (by\n                have := this.mp (by simp [Finset.mem_sdiff, hx, hxA])\n                simp at this))\n          simpa [h] using this\n        have : A = B := Finset.Subset.antisymm hAB this\n        exact hne this\n      exact Finset.nonempty_iff_ne_empty.mpr this\n    · left\n      have : A \\ B ≠ ∅ := by\n        intro h\n        have : A ⊆ B := by\n          intro x hx\n          by_contra hxB\n          have : x ∈ A \\ B := by\n            exact Finset.mem_sdiff.mpr ⟨hx, hxB⟩\n          simpa [h] using this\n        exact hAB this\n      exact Finset.nonempty_iff_ne_empty.mpr this\n  wlog hN : (A \\ B).Nonempty generalizing A B with\n  | _ =>\n    cases hdiff_nonempty with\n    | inl h => exact this h\n    | inr h =>\n      have := this (A := B) (B := A) hB hA (by simpa [and_left_comm, and_assoc] using ⟨hne.symm, hsum.symm⟩) h\n      simpa [Finset.sdiff_sdiff_comm] using this\n  refine ⟨A \\ B, B \\ A, hN, ?_, ?_, ?_, ?_, ?_⟩\n  · exact Finset.sdiff_subset.trans hAsub\n  · have : (B \\ A).Nonempty := by\n      have : A ≠ B := hne\n      by_cases hBA : B ⊆ A\n      · have : A \\ B ≠ ∅ := by\n          intro h\n          have : A ⊆ B := by\n            intro x hx\n            by_contra hxB\n            have : x ∈ A \\ B := Finset.mem_sdiff.mpr ⟨hx, hxB⟩\n            simpa [h] using this\n          have : A = B := Finset.Subset.antisymm this hBA\n          exact this.elim this\n        exact False.elim (by\n          have : A = B := Finset.Subset.antisymm (by\n            intro x hx\n            by_cases hxB : x ∈ B\n            · exact hxB\n            · have : x ∈ A \\ B := Finset.mem_sdiff.mpr ⟨hx, hxB⟩\n              exact False.elim (by\n                have : (A \\ B).Nonempty := hN\n                have := Finset.Nonempty.ne_empty this\n                exact this (by\n                  classical\n                  simpa using this)))\n            hBA\n          exact hne this)\n      · have : B \\ A ≠ ∅ := by\n          intro h\n          have : B ⊆ A := by\n            intro x hx\n            by_contra hxA\n            have : x ∈ B \\ A := Finset.mem_sdiff.mpr ⟨hx, hxA⟩\n            simpa [h] using this\n          exact hBA this\n        exact Finset.nonempty_iff_ne_empty.mpr this\n    exact this\n  · exact Finset.sdiff_subset.trans hBsub\n  · exact Finset.disjoint_sdiff_sdiff\n  ·\n    classical\n    have hsum' : f (A \\ B) = f (B \\ A) := by\n      have hdis : Disjoint (A \\ B) (A ∩ B) := by\n        exact Finset.disjoint_sdiff_inter\n      have hdis2 : Disjoint (B \\ A) (A ∩ B) := by\n        simpa [Finset.inter_comm] using (Finset.disjoint_sdiff_inter (s := B) (t := A))\n      have hAeq : f A = f (A \\ B) + f (A ∩ B) := by\n        simpa [f, Finset.sum_union, Finset.sdiff_union_inter] using\n          (by\n            have := (Finset.sum_union (s := A \\ B) (t := A ∩ B) (by\n              simpa using hdis) (f := fun x => x))\n            simpa [Finset.sdiff_union_inter] using this)\n      have hBeq : f B = f (B \\ A) + f (A ∩ B) := by\n        simpa [f, Finset.sum_union, Finset.sdiff_union_inter, Finset.inter_comm, Finset.union_comm,\n          add_comm, add_left_comm, add_assoc] using\n          (by\n            have := (Finset.sum_union (s := B \\ A) (t := B ∩ A) (by\n              simpa using hdis2) (f := fun x => x))\n            simpa [Finset.sdiff_union_inter, Finset.inter_comm] using this)\n      have : f (A \\ B) + f (A ∩ B) = f (B \\ A) + f (A ∩ B) := by\n        simpa [hAeq, hBeq] using congrArg id hsum\n      exact Nat.add_right_cancel this\n    simpa [f] using hsum'",
      "\n  classical\n  have hpos : (0 : ℕ) < S.card := by\n    simpa [h₀]\n  have hne : S.Nonempty := Finset.card_pos.mp hpos\n  refine ⟨S, S, hne, subset_rfl, hne, subset_rfl, ?_, rfl⟩\n  simpa [Finset.disjoint_self] using (Finset.disjoint_left.2 (by intro a ha ha'; exact (ha'.elim)))",
      "\n  classical\n  have h10 : (S.card : ℕ) = 10 := h₀\n  have hsum_lt : ∑ x ∈ S, x < 1000 := by\n    have hxlt : ∀ x ∈ S, x < 100 := by\n      intro x hxS\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      exact (Finset.mem_Ico.mp hxI).2\n    have hxle : ∀ x ∈ S, x ≤ 99 := by\n      intro x hxS\n      exact Nat.le_of_lt_succ (by simpa using hxlt x hxS)\n    have hle : ∑ x ∈ S, x ≤ 10 * 99 := by\n      have := Finset.sum_le_sum fun x hxS => by\n        exact (hxle x hxS)\n      simpa [Finset.sum_const_nat, h10, Nat.smul_eq_mul] using this\n    have : (10 * 99 : ℕ) < 1000 := by decide\n    exact lt_of_le_of_lt hle this\n  let A : Finset (Finset ℕ) := S.powerset.erase ∅\n  have hAcard : A.card = 1023 := by\n    have : (S.powerset.erase (∅ : Finset ℕ)).card = S.powerset.card - 1 := by\n      simpa using Finset.card_erase_of_mem (by simpa using (Finset.mem_powerset.2 (by intro x hx; cases hx)))\n    have hp : S.powerset.card = 2 ^ S.card := by simpa using Finset.card_powerset S\n    have hs : (2 ^ S.card : ℕ) = 1024 := by\n      simpa [h₀] using (by decide : (2 ^ (10 : ℕ) : ℕ) = 1024)\n    have : (S.powerset.erase (∅ : Finset ℕ)).card = 1024 - 1 := by\n      simpa [hp, hs] using this\n    simpa [A, Nat.succ_eq_add_one] using this\n  classical\n  classical\n  have hex :\n      ∃ T₁ ∈ A, ∃ T₂ ∈ A, T₁ ≠ T₂ ∧ (∑ x ∈ T₁, x) = ∑ x ∈ T₂, x := by\n    classical\n    have hbound :\n        (Finset.image (fun T : Finset ℕ => ∑ x ∈ T, x) A).card ≤ 999 := by\n      have him : ∀ s ∈ Finset.image (fun T : Finset ℕ => ∑ x ∈ T, x) A, s ≤ 999 := by\n        intro s hs\n        rcases Finset.mem_image.mp hs with ⟨T, hT, rfl⟩\n        have hTsub : T ⊆ S := by\n          have hTp : T ∈ S.powerset := by\n            have : T ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [A] using hT\n            exact Finset.mem_of_mem_erase this\n          exact (Finset.mem_powerset.mp hTp)\n        have : ∑ x ∈ T, x ≤ ∑ x ∈ S, x := by\n          classical\n          exact Finset.sum_le_sum_of_subset_of_nonneg hTsub (by intro x hx; exact Nat.zero_le _)\n        have : ∑ x ∈ T, x < 1000 := lt_of_le_of_lt this hsum_lt\n        exact Nat.le_of_lt_succ (by simpa using this)\n      have : (Finset.image (fun T : Finset ℕ => ∑ x ∈ T, x) A).card ≤ 1000 := by\n        classical\n        simpa using Finset.card_le_of_forall_le_nat him\n      exact le_trans this (by decide : (1000 : ℕ) ≤ 999 := by decide)\n    have himg_le : (Finset.image (fun T : Finset ℕ => ∑ x ∈ T, x) A).card < A.card := by\n      have : (Finset.image (fun T : Finset ℕ => ∑ x ∈ T, x) A).card ≤ 999 := hbound\n      have : (Finset.image (fun T : Finset ℕ => ∑ x ∈ T, x) A).card < 1023 := lt_of_le_of_lt this (by decide)\n      simpa [hAcard] using this\n    rcases Finset.exists_ne_of_one_lt_card (by\n        have : 1 < A.card := by simpa [hAcard] using (by decide : 1 < (1023 : ℕ))\n        exact this) with ⟨T₁, hT₁, T₂, hT₂, hne⟩\n    classical\n    have : ∃ T₁ ∈ A, ∃ T₂ ∈ A, T₁ ≠ T₂ ∧ (∑ x ∈ T₁, x) = ∑ x ∈ T₂, x := by\n      classical\n      by_contra hno\n      have hinj :\n          Set.InjOn (fun T : Finset ℕ => ∑ x ∈ T, x) A := by\n        intro a ha b hb hab\n        by_contra hne'\n        exact hno ⟨a, ha, b, hb, hne', hab⟩\n      have hcard := Finset.card_image_iff.mpr hinj\n      have : (Finset.image (fun T : Finset ℕ => ∑ x ∈ T, x) A).card = A.card := hcard\n      exact (Nat.lt_irrefl _ (by simpa [this] using himg_le))\n    exact this\n  rcases hex with ⟨T₁, hT₁A, T₂, hT₂A, hne, hsum⟩\n  have hT₁sub : T₁ ⊆ S := by\n    have hTp : T₁ ∈ S.powerset := by\n      have : T₁ ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [A] using hT₁A\n      exact Finset.mem_of_mem_erase this\n    exact Finset.mem_powerset.mp hTp\n  have hT₂sub : T₂ ⊆ S := by\n    have hTp : T₂ ∈ S.powerset := by\n      have : T₂ ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [A] using hT₂A\n      exact Finset.mem_of_mem_erase this\n    exact Finset.mem_powerset.mp hTp\n  have hT₁ne : T₁.Nonempty := by\n    have : T₁ ≠ ∅ := by\n      have : T₁ ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [A] using hT₁A\n      exact Finset.ne_of_mem_erase this\n    exact Finset.nonempty_iff_ne_empty.mpr this\n  have hT₂ne : T₂.Nonempty := by\n    have : T₂ ≠ ∅ := by\n      have : T₂ ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [A] using hT₂A\n      exact Finset.ne_of_mem_erase this\n    exact Finset.nonempty_iff_ne_empty.mpr this\n  classical\n  let S₁ : Finset ℕ := T₁ \\ T₂\n  let S₂ : Finset ℕ := T₂ \\ T₁\n  have hdis : Disjoint S₁ S₂ := by\n    exact Finset.disjoint_left.2 (by\n      intro x hx1 hx2\n      have hx12 : x ∈ T₂ := (Finset.mem_sdiff.mp hx1).2\n      have hx21 : x ∈ T₁ := (Finset.mem_sdiff.mp hx2).2\n      exact (Finset.mem_sdiff.mp hx1).1 hx21)\n  have hsum' :\n      (∑ x ∈ S₁, x) = ∑ x ∈ S₂, x := by\n    have h1 :\n        (∑ x ∈ T₁, x) = (∑ x ∈ T₁ \\ T₂, x) + (∑ x ∈ T₁ ∩ T₂, x) := by\n      simpa [Finset.sum_union, Finset.disjoint_left, Finset.mem_sdiff, and_left_comm, and_assoc,\n        Finset.union_sdiff_self, Finset.inter_comm, add_comm, add_left_comm, add_assoc] using\n        (Finset.sum_sdiff_add_sum_inter T₁ T₂ (fun x => x))\n    have h2 :\n        (∑ x ∈ T₂, x) = (∑ x ∈ T₂ \\ T₁, x) + (∑ x ∈ T₁ ∩ T₂, x) := by\n      simpa [Finset.inter_comm] using\n        (Finset.sum_sdiff_add_sum_inter T₂ T₁ (fun x => x))\n    have := congrArg (fun n => n) hsum\n    have : (∑ x ∈ T₁ \\ T₂, x) + (∑ x ∈ T₁ ∩ T₂, x) =\n        (∑ x ∈ T₂ \\ T₁, x) + (∑ x ∈ T₁ ∩ T₂, x) := by\n      simpa [h1, h2] using hsum\n    exact Nat.add_left_cancel this\n  have hS₁sub : S₁ ⊆ S := by\n    intro x hx\n    exact hT₁sub ((Finset.mem_sdiff.mp hx).1)\n  have hS₂sub : S₂ ⊆ S := by\n    intro x hx\n    exact hT₂sub ((Finset.mem_sdiff.mp hx).1)\n  have hS₁ne : S₁.Nonempty := by\n    by_contra h\n    have : T₁ ⊆ T₂ := by\n      intro x hxT₁\n      by_contra hxT₂\n      have : x ∈ T₁ \\ T₂ := by exact Finset.mem_sdiff.mpr ⟨hxT₁, hxT₂⟩\n      exact h (Finset.nonempty_iff_ne_empty.mpr (by\n        intro he\n        have := by simpa [S₁, he] using this\n        exact False.elim this))\n    have hle : T₁.card ≤ T₂.card := Finset.card_le_card this\n    have hlt : T₁.card < T₂.card := lt_of_le_of_ne hle (by\n      intro hEq\n      exact hne (Finset.eq_of_subset_of_card_le this (by simpa [hEq])))\n    have : (∑ x ∈ T₂, x) < ∑ x ∈ T₁, x := by\n      have := Finset.sum_lt_sum_of_nonempty hT₂ne (by\n        intro x hxT₂\n        exact Nat.zero_le _) (by\n          intro x hxT₂ hxnot\n          exact Nat.lt_of_le_of_ne (Nat.zero_le _) (by\n            intro h0\n            have : x = 0 := by simpa using h0\n            have hxI := h₁ (hT₂sub hxT₂)\n            have : 10 ≤ x := (Finset.mem_Ico.mp hxI).1\n            exact Nat.ne_of_gt (lt_of_lt_of_le (by decide : 0 < 10) this) this))\n      exact lt_of_lt_of_eq this hsum.symm\n    exact (Nat.lt_irrefl _ (lt_of_lt_of_eq this hsum))\n  have hS₂ne : S₂.Nonempty := by\n    by_contra h\n    have : T₂ ⊆ T₁ := by\n      intro x hxT₂\n      by_contra hxT₁\n      have : x ∈ T₂ \\ T₁ := by exact Finset.mem_sdiff.mpr ⟨hxT₂, hxT₁⟩\n      exact h (Finset.nonempty_iff_ne_empty.mpr (by\n        intro he\n        have := by simpa [S₂, he] using this\n        exact False.elim this))\n    have hle : T₂.card ≤ T₁.card := Finset.card_le_card this\n    have hlt : T₂.card < T₁.card := lt_of_le_of_ne hle (by\n      intro hEq\n      exact hne (Finset.eq_of_subset_of_card_le this (by simpa [hEq])))\n    have : (∑ x ∈ T₁, x) < ∑ x ∈ T₂, x := by\n      have := Finset.sum_lt_sum_of_nonempty hT₁ne (by\n        intro x hxT₁\n        exact Nat.zero_le _) (by\n          intro x hxT₁ hxnot\n          exact Nat.lt_of_le_of_ne (Nat.zero_le _) (by\n            intro h0\n            have : x = 0 := by simpa using h0\n            have hxI := h₁ (hT₁sub hxT₁)\n            have : 10 ≤ x := (Finset.mem_Ico.mp hxI).1\n            exact Nat.ne_of_gt (lt_of_lt_of_le (by decide : 0 < 10) this) this))\n      exact lt_of_lt_of_eq this hsum\n    exact (Nat.lt_irrefl _ (lt_of_lt_of_eq this hsum.symm))\n  refine ⟨S₁, S₂, hS₁ne, hS₁sub, hS₂ne, hS₂sub, hdis, ?_⟩\n  simpa [S₁, S₂] using hsum'",
      "\n  classical\n  -- Consider all subsets of `S` and their sums.\n  let A : Finset (Finset ℕ) := S.powerset\n  have hAcard : A.card = 2 ^ S.card := by\n    simpa [A] using (Finset.card_powerset S)\n  have hS10 : S.card = 10 := h₀\n  -- Every element of `S` lies in `[10,100)`, hence sums of subsets are ≤ 99 * 10 = 990.\n  have hsum_le : ∀ T : Finset ℕ, T ⊆ S → (∑ x ∈ T, x) ≤ 990 := by\n    intro T hTS\n    have hxle : ∀ x ∈ T, x ≤ 99 := by\n      intro x hxT\n      have hxS : x ∈ S := hTS hxT\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have hxlt : x < 100 := by\n        simpa [Finset.mem_Ico] using (And.right hxI)\n      exact Nat.le_of_lt_succ (by simpa using hxlt)\n    have hcardle : T.card ≤ 10 := by\n      have := Finset.card_le_card hTS\n      simpa [h₀] using this\n    calc\n      (∑ x ∈ T, x)\n          ≤ ∑ _x ∈ T, (99 : ℕ) := by\n              exact Finset.sum_le_sum (by\n                intro x hx\n                exact hxle x hx)\n      _ = 99 * T.card := by\n            simpa [Finset.sum_const_nat, Nat.mul_comm]\n      _ ≤ 99 * 10 := by\n            exact Nat.mul_le_mul_left 99 hcardle\n      _ = 990 := by decide\n  -- Pigeonhole: 2^10 = 1024 subsets, but only 991 possible sums (0..990).\n  have hcard_big : A.card > 991 := by\n    have : (2 ^ S.card) > 991 := by\n      -- using S.card = 10\n      simpa [hS10] using (show (2 ^ 10 : ℕ) > 991 by decide)\n    exact lt_of_lt_of_eq this (by symm; exact hAcard)\n  -- Define the map from subsets to sums\n  let f : Finset ℕ → ℕ := fun T => ∑ x ∈ T, x\n  -- The image is contained in `Icc 0 990`, hence has card ≤ 991.\n  have himage_le : (A.image f).card ≤ 991 := by\n    have himage_subset : A.image f ⊆ Finset.Icc 0 990 := by\n      intro y hy\n      rcases Finset.mem_image.mp hy with ⟨T, hT, rfl⟩\n      have hTS : T ⊆ S := by\n        have : T ∈ S.powerset := by simpa [A] using hT\n        exact Finset.mem_powerset.mp this\n      have hle : (∑ x ∈ T, x) ≤ 990 := hsum_le T hTS\n      have hge : 0 ≤ (∑ x ∈ T, x) := Nat.zero_le _\n      simpa [Finset.mem_Icc] using And.intro hge hle\n    have : (A.image f).card ≤ (Finset.Icc 0 990).card :=\n      Finset.card_le_card himage_subset\n    have hIcc : (Finset.Icc 0 990).card = 991 := by\n      simpa using (Finset.card_Icc 0 990)\n    simpa [hIcc] using this\n  -- Hence `f` is not injective on `A`, so there exist distinct subsets with equal sum.\n  have hnot_inj : ¬ Set.InjOn f (fun T : Finset ℕ => T ∈ A) := by\n    intro hinj\n    have hcard_image_eq : (A.image f).card = A.card := by\n      -- `Finset.card_image_iff` with injectivity on `A`\n      have hinjA : Set.InjOn f (fun T : Finset ℕ => T ∈ A) := hinj\n      have : (A.image f).card = A.card := by\n        classical\n        refine Finset.card_image_iff.mpr ?_\n        intro a ha b hb hab\n        exact hinjA ha hb hab\n      exact this\n    have : A.card ≤ (A.image f).card := by simpa [hcard_image_eq]\n    have : A.card ≤ 991 := le_trans (by simpa [hcard_image_eq] using le_rfl) himage_le\n    exact (not_lt_of_ge this) hcard_big\n  rcases not_forall.mp hnot_inj with ⟨T₁, hT₁⟩\n  rcases not_forall.mp hT₁ with ⟨hT₁A, hT₁'⟩\n  rcases not_forall.mp hT₁' with ⟨T₂, hT₂⟩\n  rcases not_forall.mp hT₂ with ⟨hT₂A, hT₂'⟩\n  have hneq_or : ¬ (T₁ = T₂ → f T₁ = f T₂) := hT₂'\n  have hneq : T₁ ≠ T₂ := by\n    intro hEq\n    exact hneq_or (fun _ => by simpa [hEq]) rfl\n  have hEqSum : f T₁ = f T₂ := by\n    by_contra hne\n    exact hneq_or (by intro h; exact (hne (by simpa [h] )))\n  -- Now use disjoint parts: take `S₁ = T₁ \\ T₂`, `S₂ = T₂ \\ T₁`.\n  let S₁ : Finset ℕ := T₁ \\ T₂\n  let S₂ : Finset ℕ := T₂ \\ T₁\n  have hS₁sub : S₁ ⊆ S := by\n    have hT₁sub : T₁ ⊆ S := by\n      have : T₁ ∈ S.powerset := by simpa [A] using hT₁A\n      exact Finset.mem_powerset.mp this\n    exact Finset.Subset.trans (Finset.sdiff_subset _ _) hT₁sub\n  have hS₂sub : S₂ ⊆ S := by\n    have hT₂sub : T₂ ⊆ S := by\n      have : T₂ ∈ S.powerset := by simpa [A] using hT₂A\n      exact Finset.mem_powerset.mp this\n    exact Finset.Subset.trans (Finset.sdiff_subset _ _) hT₂sub\n  have hdisj : Disjoint S₁ S₂ := by\n    exact Finset.disjoint_left.2 (by\n      intro x hx1 hx2\n      have hx1' : x ∈ T₁ := by\n        exact (Finset.mem_sdiff.mp hx1).1\n      have hx1n : x ∉ T₂ := by\n        exact (Finset.mem_sdiff.mp hx1).2\n      have hx2' : x ∈ T₂ := by\n        exact (Finset.mem_sdiff.mp hx2).1\n      exact hx1n hx2')\n  have hsum_eq : (∑ x ∈ S₁, x) = ∑ x ∈ S₂, x := by\n    have hT : (∑ x ∈ T₁, x) + (∑ x ∈ T₂ \\ T₁, x) =\n        (∑ x ∈ T₂, x) + (∑ x ∈ T₁ \\ T₂, x) := by\n      -- rearrange sums via disjoint union decomposition\n      have hdecomp1 :\n          (∑ x ∈ T₁, x) = (∑ x ∈ T₁ ∩ T₂, x) + (∑ x ∈ T₁ \\ T₂, x) := by\n        simpa [Finset.sum_union, Finset.disjoint_left, Finset.inter_union_sdiff, Nat.add_comm,\n          Nat.add_left_comm, Nat.add_assoc] using\n          (Finset.sum_inter_add_sum_sdiff_eq_sum (s := T₂) (t := T₁) (f := fun x => x))\n      have hdecomp2 :\n          (∑ x ∈ T₂, x) = (∑ x ∈ T₁ ∩ T₂, x) + (∑ x ∈ T₂ \\ T₁, x) := by\n        simpa [Finset.inter_comm] using\n          (Finset.sum_inter_add_sum_sdiff_eq_sum (s := T₁) (t := T₂) (f := fun x => x)).symm\n      -- from equal total sums\n      have : (∑ x ∈ T₁, x) = ∑ x ∈ T₂, x := hEqSum\n      -- substitute and cancel\n      have := congrArg (fun z => z + (∑ x ∈ T₂ \\ T₁, x)) this\n      -- use decompositions\n      -- We'll do it by rewriting both sides and commutativity\n      simpa [hdecomp1, hdecomp2, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this\n    -- extract desired equality\n    -- From hT, cancel equal terms\n    -- hT: sum T₁ + sum S₂ = sum T₂ + sum S₁, but sum T₁ = sum T₂\n    have hEq' : (∑ x ∈ T₂ \\ T₁, x) = (∑ x ∈ T₁ \\ T₂, x) := by\n      have h1 : (∑ x ∈ T₁, x) + (∑ x ∈ T₂ \\ T₁, x) =\n          (∑ x ∈ T₁, x) + (∑ x ∈ T₁ \\ T₂, x) := by\n        simpa [hEqSum] using hT\n      exact Nat.add_left_cancel h1\n    simpa [S₁, S₂] using hEq'.symm\n  have hS₁ne : S₁.Nonempty := by\n    by_contra hE\n    have hsub : T₁ ⊆ T₂ := by\n      intro x hx\n      by_contra hxnot\n      have : x ∈ T₁ \\ T₂ := by\n        exact Finset.mem_sdiff.mpr ⟨hx, hxnot⟩\n      exact hE (Finset.nonempty_iff_ne_empty.2 (by\n        intro h\n        have : x ∈ (T₁ \\ T₂) := this\n        simpa [h] using this))\n    have hlt : T₁.card < T₂.card := by\n      have hle : T₁.card ≤ T₂.card := Finset.card_le_card hsub\n      have hne' : T₁ ≠ T₂ := hneq\n      exact lt_of_le_of_ne hle (Ne.symm (by\n        intro hEq; exact hne' (Finset.ext (by\n          intro x; simpa [hEq] ))))\n    have hsub' : T₂ ⊆ T₁ := by\n      -- similarly from S₂ empty would follow, but we don't have that; use sums:\n      -- if T₁ ⊂ T₂ then since all elements ≥ 10, sums strictly increase, contradiction\n      intro x hx\n      by_contra hxnot\n      -- show sum T₂ > sum T₁\n      have hxS : x ∈ S := by\n        have hT₂sub : T₂ ⊆ S := by\n          have : T₂ ∈ S.powerset := by simpa [A] using hT₂A\n          exact Finset.mem_powerset.mp this\n        exact hT₂sub hx\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have hxge : 10 ≤ x := by simpa [Finset.mem_Ico] using (And.left hxI)\n      have hpos : 0 < x := lt_of_lt_of_le (by decide : (0:ℕ) < 10) hxge\n      -- compare sums by splitting off `x`\n      have hxnotin : x ∉ T₁ := hxnot\n      have hxmem : x ∈ T₂ := hx\n      have hsum_lt : (∑ y ∈ T₁, y) < ∑ y ∈ T₂, y := by\n        have : (∑ y ∈ T₂, y) = x + ∑ y ∈ (T₂.erase x), y := by\n          simpa [Finset.sum_erase_add] using (Finset.sum_erase_add (s := T₂) (f := fun y => y) hxmem)\n        have herase_sub : T₂.erase x ⊆ T₂ := Finset.erase_subset _ _\n        have hT₁subT₂ : T₁ ⊆ T₂ := hsub\n        have hT₁subErase : T₁ ⊆ T₂.erase x := by\n          intro y hy\n          have hyT₂ : y ∈ T₂ := hT₁subT₂ hy\n          have hyne : y ≠ x := by\n            intro hEq\n            subst hEq\n            exact hxnotin hy\n          exact Finset.mem_erase.mpr ⟨hyne, hyT₂⟩\n        have hle' : (∑ y ∈ T₁, y) ≤ ∑ y ∈ T₂.erase x, y := by\n          exact Finset.sum_le_sum_of_subset_of_nonneg hT₁subErase (by intro; exact Nat.zero_le _)\n        have : (∑ y ∈ T₁, y) < x + ∑ y ∈ T₂.erase x, y := lt_of_le_of_lt (by\n          exact Nat.le_trans hle' (Nat.le_add_left _ _)) (Nat.lt_add_of_pos_left hpos)\n        simpa [this] using this\n      exact ne_of_lt hsum_lt hEqSum.symm\n    exact False.elim (hsub' (by\n      -- pick an element witnessing strict inclusion from card\n      have := Finset.ssubset_iff_of_subset hsub\n      have hss : T₁ ⊂ T₂ := lt_of_le_of_ne (Finset.card_le_card hsub) (by\n        intro hEq; exact hneq (Finset.ext (by intro x; simpa [hEq])))\n      rcases Finset.ssubset_iff.1 hss with ⟨x, hxT₂, hxT₁⟩\n      exact hxT₂))\n  have hS₂ne : S₂.Nonempty := by\n    by_contra hE\n    have hsub : T₂ ⊆ T₁ := by\n      intro x hx\n      by_contra hxnot\n      have : x ∈ T₂ \\ T₁ := by\n        exact Finset.mem_sdiff.mpr ⟨hx, hxnot⟩\n      exact hE (Finset.nonempty_iff_ne_empty.2 (by\n        intro h\n        have : x ∈ (T₂ \\ T₁) := this\n        simpa [h] using this))\n    have hEq : T₁ = T₂ := by\n      have hsub' : T₁ ⊆ T₂ := by\n        -- from S₁ nonempty already, but just use equality of sums and positivity to force equality:\n        intro x hx\n        by_contra hxnot\n        have hxS : x ∈ S := by\n          have hT₁sub : T₁ ⊆ S := by\n            have : T₁ ∈ S.powerset := by simpa [A] using hT₁A\n            exact Finset.mem_powerset.mp this\n          exact hT₁sub hx\n        have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n        have hxge : 10 ≤ x := by simpa [Finset.mem_Ico] using (And.left hxI)\n        have hpos : 0 < x := lt_of_lt_of_le (by decide : (0:ℕ) < 10) hxge\n        have hxnotin : x ∉ T₂ := hxnot\n        have hxmem : x ∈ T₁ := hx\n        have hsum_lt : (∑ y ∈ T₂, y) < ∑ y ∈ T₁, y := by\n          have : (∑ y ∈ T₁, y) = x + ∑ y ∈ (T₁.erase x), y := by\n            simpa [Finset.sum_erase_add] using (Finset.sum_erase_add (s := T₁) (f := fun y => y) hxmem)\n          have hT₂subT₁ : T₂ ⊆ T₁ := hsub\n          have hT₂subErase : T₂ ⊆ T₁.erase x := by\n            intro y hy\n            have hyT₁ : y ∈ T₁ := hT₂subT₁ hy\n            have hyne : y ≠ x := by\n              intro hEq\n              subst hEq\n              exact hxnotin hy\n            exact Finset.mem_erase.mpr ⟨hyne, hyT₁⟩\n          have hle' : (∑ y ∈ T₂, y) ≤ ∑ y ∈ T₁.erase x, y := by\n            exact Finset.sum_le_sum_of_subset_of_nonneg hT₂subErase (by intro; exact Nat.zero_le _)\n          have : (∑ y ∈ T₂, y) < x + ∑ y ∈ T₁.erase x, y :=\n            lt_of_le_of_lt (by exact Nat.le_trans hle' (Nat.le_add_left _ _)) (Nat.lt_add_of_pos_left hpos)\n          simpa [this] using this\n        exact ne_of_lt hsum_lt hEqSum\n      exact Finset.Subset.antisymm hsub hsub'\n    exact hneq hEq\n  refine ⟨S₁, S₂, hS₁ne, hS₁sub, hS₂ne, hS₂sub, hdisj, ?_⟩\n  simpa [S₁, S₂] using hsum_eq",
      "\n  classical\n  have hcard : (S.powerset.filter Finset.Nonempty).card = 1023 := by\n    -- all nonempty subsets of a 10-element set\n    simpa [Finset.card_filter, h₀] using (Finset.card_powerset_subtype_nonempty (s := S))\n  -- Define the sum of a nonempty subset\n  let f : {T // T ∈ S.powerset.filter Finset.Nonempty} → ℕ :=\n    fun T => ∑ x ∈ (T.1 : Finset ℕ), x\n  have hsum_le : ∀ T : {T // T ∈ S.powerset.filter Finset.Nonempty}, f T ≤ 945 := by\n    intro T\n    have hTs : (T.1 : Finset ℕ) ⊆ S := by\n      have : (T.1 : Finset ℕ) ∈ S.powerset := by\n        have : (T.1 : Finset ℕ) ∈ S.powerset.filter Finset.Nonempty := T.2\n        simpa [Finset.mem_filter] using (And.left (by simpa [Finset.mem_filter] using this))\n      simpa [Finset.mem_powerset] using this\n    have hx : ∀ x ∈ (T.1 : Finset ℕ), x ≤ 99 := by\n      intro x hxT\n      have hxS : x ∈ S := hTs hxT\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      exact Nat.lt_succ_iff.mp (Finset.mem_Ico.mp hxI).2\n    have hcardT : (T.1 : Finset ℕ).card ≤ 10 := by\n      simpa [h₀] using Finset.card_le_card hTs\n    calc\n      f T = ∑ x ∈ (T.1 : Finset ℕ), x := rfl\n      _ ≤ ∑ _x ∈ (T.1 : Finset ℕ), (99 : ℕ) := by\n        exact Finset.sum_le_sum (by intro x hxT; exact hx x hxT)\n      _ = (T.1 : Finset ℕ).card * 99 := by\n        simp [Finset.sum_const_nat]\n      _ ≤ 10 * 99 := by\n        exact Nat.mul_le_mul_right _ hcardT\n      _ = 990 := rfl\n      _ ≤ 945 := by decide\n  -- Pigeonhole: 1023 nonempty subsets, sums in {10..945} at most 936 values\n  have hrange : (Set.range f).Finite := (Set.finite_range f)\n  have hbound : (Set.range f).ncard ≤ 936 := by\n    -- crude bound via max sum\n    have : Set.range f ⊆ Set.Icc (10 : ℕ) 945 := by\n      intro y hy\n      rcases hy with ⟨T, rfl⟩\n      have hTne : (T.1 : Finset ℕ).Nonempty := by\n        have : (T.1 : Finset ℕ) ∈ S.powerset.filter Finset.Nonempty := T.2\n        exact (Finset.mem_filter.mp this).2\n      rcases hTne with ⟨x, hx⟩\n      have hxS : x ∈ S := by\n        have hTs : (T.1 : Finset ℕ) ⊆ S := by\n          have : (T.1 : Finset ℕ) ∈ S.powerset := by\n            have : (T.1 : Finset ℕ) ∈ S.powerset.filter Finset.Nonempty := T.2\n            exact (Finset.mem_filter.mp this).1\n          simpa [Finset.mem_powerset] using this\n        exact hTs hx\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have hx10 : (10 : ℕ) ≤ x := (Finset.mem_Ico.mp hxI).1\n      have hsum_ge : (10 : ℕ) ≤ f ⟨T.1, T.2⟩ := by\n        -- sum ≥ x ≥ 10\n        have : x ≤ ∑ z ∈ (T.1 : Finset ℕ), z := by\n          exact Finset.single_le_sum (by intro a ha; exact Nat.zero_le _) hx\n        exact le_trans hx10 this\n      exact ⟨hsum_ge, hsum_le T⟩\n    have hncard_le := Set.ncard_le_of_subset this\n    have : (Set.Icc (10 : ℕ) 945).ncard = 936 := by\n      simpa using Nat.ncard_Icc 10 945\n    exact le_trans hncard_le (by simpa [this])\n  have hbig : (S.powerset.filter Finset.Nonempty).card > 936 := by\n    -- 2^10 - 1 = 1023\n    have : (S.powerset.filter Finset.Nonempty).card = 1023 := by\n      simpa [Finset.card_filter, h₀] using (Finset.card_powerset_subtype_nonempty (s := S))\n    simpa [this]\n  have : ¬Function.Injective f := by\n    intro hinj\n    have := Set.Finite.ncard_le_of_injective hrange hinj\n    have h1 : (S.powerset.filter Finset.Nonempty).card ≤ 936 := by\n      simpa using this\n    exact (not_le_of_gt hbig) h1\n  rcases not_forall.mp (by\n    classical\n    -- extract collision\n    simpa [Function.Injective, not_forall] using this) with ⟨A, hA⟩\n  rcases not_forall.mp hA with ⟨B, hAB⟩\n  rcases not_imp.mp hAB with ⟨hAne, hB⟩\n  have hBne := (by\n    classical\n    have : B ≠ A := by\n      intro h; exact hAne (by simpa [h] using rfl)\n    exact this)\n  -- unpack A,B as subsets\n  classical\n  let SA : Finset ℕ := (A.1 : Finset ℕ)\n  let SB : Finset ℕ := (B.1 : Finset ℕ)\n  have hSAne : SA.Nonempty := (Finset.mem_filter.mp A.2).2\n  have hSBne : SB.Nonempty := (Finset.mem_filter.mp B.2).2\n  have hSAsub : SA ⊆ S := by\n    have : SA ∈ S.powerset := (Finset.mem_filter.mp A.2).1\n    simpa [Finset.mem_powerset] using this\n  have hSBsub : SB ⊆ S := by\n    have : SB ∈ S.powerset := (Finset.mem_filter.mp B.2).1\n    simpa [Finset.mem_powerset] using this\n  have hsum : ∑ x ∈ SA, x = ∑ x ∈ SB, x := by\n    -- from f A = f B\n    have : f A = f B := by\n      have := (by\n        classical\n        have : ¬ A = B := by\n          intro h; exact hBne (by symm; exact h)\n        -- from not (A=B → fA≠fB)\n        simpa [Function.Injective] using hB.2) \n      exact by\n        by_contra hneq\n        exact hB.2 (by\n          intro hEq\n          exact hneq hEq)\n    simpa [f, SA, SB] using this\n  -- take disjoint parts\n  let S₁ : Finset ℕ := SA \\ SB\n  let S₂ : Finset ℕ := SB \\ SA\n  have hdis : Disjoint S₁ S₂ := by\n    exact Finset.disjoint_sdiff_sdiff\n  have hS₁sub : S₁ ⊆ S := by\n    intro x hx\n    exact hSAsub (Finset.sdiff_subset _ _ hx)\n  have hS₂sub : S₂ ⊆ S := by\n    intro x hx\n    exact hSBsub (Finset.sdiff_subset _ _ hx)\n  have hsum' : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    -- from equal total sums, cancel intersection\n    have :\n        (∑ x ∈ SA, x) = (∑ x ∈ SB, x) := hsum\n    -- SA = (SA\\SB) ∪ (SA∩SB), similarly for SB\n    have h1 :\n        (∑ x ∈ SA, x) =\n          (∑ x ∈ SA \\ SB, x) + (∑ x ∈ SA ∩ SB, x) := by\n        simpa [Finset.sum_union, Finset.disjoint_left, Finset.mem_sdiff, Finset.mem_inter] using\n          (Finset.sum_sdiff_add_sum_inter SA SB)\n    have h2 :\n        (∑ x ∈ SB, x) =\n          (∑ x ∈ SB \\ SA, x) + (∑ x ∈ SA ∩ SB, x) := by\n        simpa [Finset.inter_comm, Finset.sum_union, Finset.disjoint_left, Finset.mem_sdiff, Finset.mem_inter] using\n          (Finset.sum_sdiff_add_sum_inter SB SA)\n    have := by\n      -- substitute and cancel\n      linarith [this, h1, h2]\n    simpa [S₁, S₂] using this\n  have hS₁ne : S₁.Nonempty := by\n    by_contra h\n    have hsub : SA ⊆ SB := by\n      intro x hx\n      by_contra hxSB\n      have : x ∈ SA \\ SB := by\n        exact Finset.mem_sdiff.mpr ⟨hx, hxSB⟩\n      exact h (Finset.nonempty_iff_ne_empty.mpr (by\n        intro hempty; simpa [S₁, hempty] using this))\n    have hsub' : SB ⊆ SA := by\n      intro x hx\n      by_contra hxSA\n      have : x ∈ SB \\ SA := by\n        exact Finset.mem_sdiff.mpr ⟨hx, hxSA⟩\n      have : S₂.Nonempty := by\n        exact ⟨x, this⟩\n      have : (∑ x ∈ S₂, x) > 0 := by\n        rcases this with ⟨y, hy⟩\n        have hypos : (0 : ℕ) < y := Nat.pos_of_ne_zero (by\n          intro hz; have : y ∈ SA := by\n            exact (Finset.mem_sdiff.mp hy).2.elim\n          exact False.elim (by simpa [hz] using this))\n        have : y ≤ ∑ z ∈ S₂, z := Finset.single_le_sum (by intro a ha; exact Nat.zero_le _) hy\n        exact lt_of_lt_of_le hypos this\n      have : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := hsum'\n      have : (∑ x ∈ S₁, x) > 0 := by simpa [S₁, Finset.not_nonempty_iff_eq_empty.mp h] using this ▸ this\n      exact lt_irrefl _ this\n    have : SA = SB := by\n      exact Finset.Subset.antisymm hsub hsub'\n    exact hBne (by\n      -- A and B equal as subtype\n      cases A with\n      | mk a ha =>\n        cases B with\n        | mk b hb =>\n          simp [SA, SB] at this\n          simpa [this] )\n  have hS₂ne : S₂.Nonempty := by\n    -- symmetric\n    have := hS₁ne\n    -- if S₂ empty then SA=SB similarly contradict\n    by_contra h\n    have hsub : SB ⊆ SA := by\n      intro x hx\n      by_contra hxSA\n      have : x ∈ SB \\ SA := Finset.mem_sdiff.mpr ⟨hx, hxSA⟩\n      exact h (Finset.nonempty_iff_ne_empty.mpr (by\n        intro hempty; simpa [S₂, hempty] using this))\n    have hsub' : SA ⊆ SB := by\n      intro x hx\n      by_contra hxSB\n      have : x ∈ SA \\ SB := Finset.mem_sdiff.mpr ⟨hx, hxSB⟩\n      exact (Finset.not_nonempty_iff_eq_empty.mp (by\n        intro; exact False.elim (by\n          have : S₁.Nonempty := ⟨x, this⟩\n          exact (Finset.not_nonempty_iff_eq_empty.mp ?_ ) this))) this\n    have : SA = SB := Finset.Subset.antisymm hsub' hsub\n    exact hBne (by\n      cases A with\n      | mk a ha =>\n        cases B with\n        | mk b hb =>\n          simp [SA, SB] at this\n          simpa [this])\n  refine ⟨S₁, S₂, hS₁ne, hS₁sub, hS₂ne, hS₂sub, hdis, ?_⟩\n  simpa using hsum'",
      "\n  classical\n  have hS : S ⊆ Finset.Icc 10 99 := by\n    intro x hx\n    have hx' := h₁ hx\n    have hx10 : 10 ≤ x := by\n      simpa [Finset.mem_Ico] using (And.left hx')\n    have hx100 : x < 100 := by\n      simpa [Finset.mem_Ico] using (And.right hx')\n    have hx99 : x ≤ 99 := Nat.lt_succ_iff.mp (by simpa using hx100)\n    exact Finset.mem_Icc.mpr ⟨hx10, hx99⟩\n\n  let U : Finset (Finset ℕ) := S.powerset.erase ∅\n  have hUcard : U.card = 1023 := by\n    have : S.powerset.card = 2 ^ S.card := by simpa using (Finset.card_powerset S)\n    have hne : (∅ : Finset ℕ) ∈ S.powerset := by\n      simpa using (Finset.mem_powerset.2 (by intro x hx; cases hx))\n    have : (S.powerset.erase (∅ : Finset ℕ)).card = S.powerset.card - 1 := by\n      simpa using Finset.card_erase_of_mem hne\n    have : U.card = 2 ^ S.card - 1 := by\n      simpa [U] using congrArg id (by simpa [this] : (S.powerset.erase (∅ : Finset ℕ)).card = S.powerset.card - 1)\n    have : U.card = 2 ^ 10 - 1 := by simpa [this, h₀]\n    norm_num at this\n    simpa using this\n\n  have hsum_le : ∀ T : Finset ℕ, T ⊆ S → (∑ x ∈ T, x) ≤ 990 := by\n    intro T hTS\n    have hcardT : T.card ≤ 10 := by\n      simpa [h₀] using (Finset.card_le_card hTS)\n    have hx_le : ∀ x ∈ T, x ≤ 99 := by\n      intro x hxT\n      have hxS : x ∈ S := hTS hxT\n      have hxIcc : x ∈ Finset.Icc 10 99 := hS hxS\n      exact (Finset.mem_Icc.mp hxIcc).2\n    have hsum_le' : (∑ x ∈ T, x) ≤ 99 * T.card := by\n      simpa [Nat.mul_comm] using\n        (Finset.sum_le_card_nsmul (s := T) (f := fun x => x) 99 (by intro x hx; exact hx_le x hx))\n    have : (99 * T.card) ≤ 99 * 10 := by\n      exact Nat.mul_le_mul_left 99 hcardT\n    exact le_trans hsum_le' (by simpa)\n\n  classical\n  by_contra h\n  have hinj :\n      Function.Injective (fun T : Finset ℕ => ∑ x ∈ T, x) := by\n    intro A B hAB\n    by_contra hne\n    have hA : A ⊆ S := by\n      have : A ∈ U := by\n        have : A ∈ S.powerset := by\n          have : A ⊆ S := by\n            by_contra hAS\n            exact hne rfl\n          exact Finset.mem_powerset.2 this\n        have hA0 : A ≠ ∅ := by\n          intro h0\n          subst h0\n          have : (∅ : Finset ℕ) ∈ U := by\n            simp [U]\n          simp [U] at this\n        exact by\n          have : A ∈ S.powerset.erase (∅ : Finset ℕ) := by\n            simp [U, this, hA0]\n          simpa [U] using this\n      have : A ⊆ S := by\n        have : A ∈ S.powerset := by\n          have : A ∈ S.powerset.erase (∅ : Finset ℕ) := by\n            simpa [U] using hinj\n          exact Finset.mem_of_mem_erase this\n        exact Finset.mem_powerset.mp this\n      exact this\n    have hB : B ⊆ S := by\n      have : B ⊆ S := by\n        by_contra hBS\n        exact hne rfl\n      exact this\n    have hAne : A.Nonempty := by\n      by_contra hA0\n      have : A = ∅ := Finset.not_nonempty_iff.mp hA0\n      subst this\n      exact hne rfl\n    have hBne : B.Nonempty := by\n      by_contra hB0\n      have : B = ∅ := Finset.not_nonempty_iff.mp hB0\n      subst this\n      exact hne rfl\n    have hdisj : Disjoint (A \\ B) (B \\ A) := by\n      exact disjoint_sdiff_sdiff\n    have hABsum :\n        (∑ x ∈ A \\ B, x) = ∑ x ∈ B \\ A, x := by\n      have hA' : ∑ x ∈ A, x = (∑ x ∈ A \\ B, x) + ∑ x ∈ A ∩ B, x := by\n        simpa [Finset.sum_add_distrib] using (Finset.sum_sdiff_add_sum_inter (s := A) (t := B) (f := fun x => x))\n      have hB' : ∑ x ∈ B, x = (∑ x ∈ B \\ A, x) + ∑ x ∈ A ∩ B, x := by\n        have := (Finset.sum_sdiff_add_sum_inter (s := B) (t := A) (f := fun x => x))\n        simpa [Finset.inter_comm, Finset.sdiff_sdiff_right] using this\n      have : (∑ x ∈ A \\ B, x) + ∑ x ∈ A ∩ B, x = (∑ x ∈ B \\ A, x) + ∑ x ∈ A ∩ B, x := by\n        simpa [hA', hB', hAB]\n      exact Nat.add_left_cancel this\n    have hAnes : (A \\ B).Nonempty ∨ (B \\ A).Nonempty := by\n      have : A ≠ B := by\n        intro hEq\n        exact hne hEq\n      have : (A \\ B) ≠ ∅ ∨ (B \\ A) ≠ ∅ := by\n        by_contra h0\n        push_neg at h0\n        have hAB' : A ⊆ B := by\n          intro x hxA\n          by_contra hxB\n          have : x ∈ A \\ B := by\n            simp [Finset.mem_sdiff, hxA, hxB]\n          have : x ∈ (∅ : Finset ℕ) := by simpa [h0.1] using this\n          simpa using this\n        have hBA' : B ⊆ A := by\n          intro x hxB\n          by_contra hxA\n          have : x ∈ B \\ A := by\n            simp [Finset.mem_sdiff, hxB, hxA]\n          have : x ∈ (∅ : Finset ℕ) := by simpa [h0.2] using this\n          simpa using this\n        have : A = B := Finset.Subset.antisymm hAB' hBA'\n        exact this.elim this\n      exact by\n        rcases this with hA0 | hB0\n        · left\n          exact Finset.nonempty_iff_ne_empty.2 hA0\n        · right\n          exact Finset.nonempty_iff_ne_empty.2 hB0\n    have hsubA : A \\ B ⊆ S := by\n      intro x hx\n      exact hA (Finset.sdiff_subset _ _ hx)\n    have hsubB : B \\ A ⊆ S := by\n      intro x hx\n      exact hB (Finset.sdiff_subset _ _ hx)\n    have hneA : (A \\ B).Nonempty := by\n      cases hAnes with\n      | inl h => exact h\n      | inr h =>\n          have : ∑ x ∈ B \\ A, x = 0 := by\n            have : B \\ A = ∅ := by\n              by_contra h0\n              have := h\n              exact (Finset.nonempty_iff_ne_empty.1 this) h0\n            simp [this]\n          have : ∑ x ∈ A \\ B, x = 0 := by simpa [hABsum] using this\n          have : A \\ B = ∅ := by\n            by_contra h0\n            have hpos : 0 < ∑ x ∈ A \\ B, x := by\n              have hx10 : ∀ x ∈ A \\ B, 10 ≤ x := by\n                intro x hx\n                have hxS : x ∈ S := hsubA hx\n                have hxIcc : x ∈ Finset.Icc 10 99 := hS hxS\n                exact (Finset.mem_Icc.mp hxIcc).1\n              rcases (Finset.nonempty_iff_ne_empty.2 h0) with ⟨x, hx⟩\n              have : 10 ≤ x := hx10 x hx\n              have : 0 < x := lt_of_lt_of_le (by decide : (0:ℕ) < 10) this\n              have : 0 < ∑ y ∈ A \\ B, y := by\n                exact lt_of_lt_of_le this (Finset.single_le_sum (fun z => z) (by intro; exact Nat.zero_le _) hx)\n              exact this\n            exact (lt_irrefl 0 (by simpa [this] using hpos)).elim\n          exact (Finset.nonempty_iff_ne_empty.2 this).elim\n    have hneB : (B \\ A).Nonempty := by\n      have hneA' : (A \\ B).Nonempty := hneA\n      have : (B \\ A).Nonempty := by\n        by_contra h0\n        have : B \\ A = ∅ := Finset.not_nonempty_iff.mp h0\n        have : ∑ x ∈ B \\ A, x = 0 := by simp [this]\n        have : ∑ x ∈ A \\ B, x = 0 := by simpa [hABsum] using this\n        have : A \\ B = ∅ := by\n          by_contra h0'\n          have hx10 : ∀ x ∈ A \\ B, 10 ≤ x := by\n            intro x hx\n            have hxS : x ∈ S := hsubA hx\n            have hxIcc : x ∈ Finset.Icc 10 99 := hS hxS\n            exact (Finset.mem_Icc.mp hxIcc).1\n          rcases (Finset.nonempty_iff_ne_empty.2 h0') with ⟨x, hx⟩\n          have : 10 ≤ x := hx10 x hx\n          have : 0 < x := lt_of_lt_of_le (by decide : (0:ℕ) < 10) this\n          have : 0 < ∑ y ∈ A \\ B, y := by\n            exact lt_of_lt_of_le this (Finset.single_le_sum (fun z => z) (by intro; exact Nat.zero_le _) hx)\n          exact (lt_irrefl 0 (by simpa [this] using this)).elim\n        exact (Finset.nonempty_iff_ne_empty.2 this).elim\n      exact this\n    have hsubA' : A \\ B ⊆ S := hsubA\n    have hsubB' : B \\ A ⊆ S := hsubB\n    have hdisj' : Disjoint (A \\ B) (B \\ A) := hdisj\n    have : False := h ⟨A \\ B, B \\ A, hneA', hsubA', hneB, hsubB', hdisj', hABsum⟩\n    exact this\n  -- pigeonhole on sums 1..990\n  have hrange :\n      (U.image (fun T : Finset ℕ => ∑ x ∈ T, x)).card ≤ 990 := by\n    have :\n        U.image (fun T : Finset ℕ => ∑ x ∈ T, x) ⊆ Finset.Icc 1 990 := by\n      intro s hs\n      rcases Finset.mem_image.mp hs with ⟨T, hT, rfl⟩\n      have hT0 : T ≠ ∅ := by\n        have : T ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [U] using hT\n        exact Finset.ne