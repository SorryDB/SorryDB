Finset.mem_erase.mp hT\n          exact this.1\n        exact (Finset.mem_erase.mp hT).2\n      exact Finset.nonempty_iff_ne_empty.2 this\n    have hTS : T ⊆ S := by\n      have hTp : T ∈ S.powerset := (Finset.mem_erase.mp hT).1\n      exact (Finset.mem_powerset.mp hTp)\n    have hlow : 10 ≤ f T := by\n      rcases hTne with ⟨x, hxT⟩\n      have hxS : x ∈ S := hTS hxT\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have hx10 : 10 ≤ x := (Finset.mem_Ico.mp hxI).1\n      have hxle : x ≤ f T := by\n        -- x is one of the summands\n        have : x ≤ ∑ y ∈ T, y := by\n          simpa [f] using Finset.single_le_sum (fun y => (Nat.zero_le y)) hxT\n        simpa [f] using this\n      exact le_trans hx10 hxle\n    have hup : f T ≤ 990 := hsum_le T hTS\n    exact Finset.mem_Icc.2 ⟨hlow, hup⟩\n  -- Pigeonhole on values in Icc 10 990 (981 values) vs 1023 subsets\n  have hcod_card : (Finset.Icc 10 990).card = 981 := by\n    simp\n  have : ¬Function.Injective (fun T : {T // T ∈ A} => f T.1) := by\n    intro hinj\n    have hcard_le :=\n      Finset.card_le_of_injective (s := A.attach) (t := Finset.Icc 10 990)\n        (fun T => by\n          have : T.1 ∈ A := T.2\n          exact hf_range T.1 this)\n        (by\n          intro a b hab\n          apply Subtype.ext\n          exact hinj (by simpa using hab))\n    -- card(A) ≤ 981, contradiction with 1023\n    have : A.card ≤ (Finset.Icc 10 990).card := by\n      simpa [Finset.card_attach] using hcard_le\n    have : (1023 : ℕ) ≤ 981 := by simpa [hA_card, hcod_card] using this\n    exact Nat.not_succ_le_self 981 (by simpa using this)\n  -- Extract two distinct subsets with same sum\n  rcases not_forall.mp (by\n    classical\n    simpa [Function.Injective] using this) with ⟨a, ha⟩\n  rcases not_forall.mp ha with ⟨b, hb⟩\n  have hab_ne : a ≠ b := by\n    intro h\n    exact hb (by simpa [h])\n  have hab_sum : f a.1 = f b.1 := by\n    have := not_imp.mp hb\n    exact this.2\n  -- Let S₁ = a \\ b, S₂ = b \\ a. They are disjoint and sums equal.\n  let S₁ : Finset ℕ := a.1 \\ b.1\n  let S₂ : Finset ℕ := b.1 \\ a.1\n  have hS₁sub : S₁ ⊆ S := by\n    intro x hx\n    have : x ∈ a.1 := (Finset.mem_sdiff.mp hx).1\n    have haP : a.1 ⊆ S := by\n      have : a.1 ∈ S.powerset := (Finset.mem_erase.mp a.2).1\n      exact Finset.mem_powerset.mp this\n    exact haP this\n  have hS₂sub : S₂ ⊆ S := by\n    intro x hx\n    have : x ∈ b.1 := (Finset.mem_sdiff.mp hx).1\n    have hbP : b.1 ⊆ S := by\n      have : b.1 ∈ S.powerset := (Finset.mem_erase.mp b.2).1\n      exact Finset.mem_powerset.mp this\n    exact hbP this\n  have hdis : Disjoint S₁ S₂ := by\n    exact Finset.disjoint_left.2 (by\n      intro x hx1 hx2\n      have hx1' : x ∈ a.1 := (Finset.mem_sdiff.mp hx1).1\n      have hx1n : x ∉ b.1 := (Finset.mem_sdiff.mp hx1).2\n      have hx2' : x ∈ b.1 := (Finset.mem_sdiff.mp hx2).1\n      exact hx1n hx2')\n  have hsum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    -- Use sum over sdiff with intersection decomposition.\n    have hdecomp1 :\n        (∑ x ∈ a.1, x) = (∑ x ∈ a.1 \\ b.1, x) + (∑ x ∈ a.1 ∩ b.1, x) := by\n      simpa [Finset.sum_sdiff, Finset.inter_comm, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]\n    have hdecomp2 :\n        (∑ x ∈ b.1, x) = (∑ x ∈ b.1 \\ a.1, x) + (∑ x ∈ a.1 ∩ b.1, x) := by\n      -- symmetric\n      simpa [Finset.sum_sdiff, Finset.inter_comm, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]\n    have : (∑ x ∈ a.1 \\ b.1, x) = (∑ x ∈ b.1 \\ a.1, x) := by\n      -- cancel the common intersection sum\n      have := congrArg (fun n => n) hab_sum\n      -- Rewrite both sides\n      have haS : a.1 ∩ b.1 ⊆ a.1 := Finset.inter_subset_left\n      have hbS : a.1 ∩ b.1 ⊆ b.1 := Finset.inter_subset_right\n      -- Use Nat.add_left_cancel after rewriting\n      apply Nat.add_left_cancel\n      -- Put intersection sum on left\n      have := by\n        -- from hdecomp1 and hdecomp2 and hab_sum\n        calc\n          (∑ x ∈ a.1 ∩ b.1, x) + (∑ x ∈ a.1 \\ b.1, x)\n              = (∑ x ∈ a.1 \\ b.1, x) + (∑ x ∈ a.1 ∩ b.1, x) := by ac_rfl\n          _ = ∑ x ∈ a.1, x := by\n                symm\n                -- from hdecomp1\n                exact by\n                  have := hdecomp1\n                  -- rearrange\n                  simpa [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using this\n          _ = ∑ x ∈ b.1, x := by simpa [f] using hab_sum\n          _ = (∑ x ∈ b.1 \\ a.1, x) + (∑ x ∈ a.1 ∩ b.1, x) := by\n                -- hdecomp2\n                simpa [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using hdecomp2\n          _ = (∑ x ∈ a.1 ∩ b.1, x) + (∑ x ∈ b.1 \\ a.1, x) := by ac_rfl\n      simpa [S₁, S₂] using this\n    simpa [S₁, S₂] using this\n  have hS₁ne : S₁.Nonempty := by\n    by_contra h\n    have hS₁empty : S₁ = ∅ := Finset.not_nonempty_iff_eq_empty.mp h\n    have hsub : a.1 ⊆ b.1 := by\n      intro x hx\n      by_contra hxnb\n      have : x ∈ S₁ := by\n        exact Finset.mem_sdiff.2 ⟨hx, hxnb⟩\n      simpa [hS₁empty] using this\n    have hsumb : f a.1 ≤ f b.1 := by\n      -- monotonicity of sum over subset for Nat\n      have : (∑ x ∈ a.1, x) ≤ ∑ x ∈ b.1, x := by\n        exact Finset.sum_le_sum_of_subset_of_nonneg hsub (by intro x hx; exact Nat.zero_le x)\n      simpa [f] using this\n    have hsub' : b.1 ⊆ a.1 := by\n      -- similarly from S₂ emptiness would follow; but use equal sums and strictness\n      intro x hx\n      -- if x ∉ a.1 then contributes to S₂ making sum strictly larger\n      by_contra hxna\n      have hxS₂ : x ∈ S₂ := by\n        exact Finset.mem_sdiff.2 ⟨hx, hxna⟩\n      have hpos : 0 < x := by\n        have hbS : b.1 ⊆ S := by\n          have : b.1 ∈ S.powerset := (Finset.mem_erase.mp b.2).1\n          exact Finset.mem_powerset.mp this\n        have hxS : x ∈ S := hbS hx\n        have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n        exact lt_of_lt_of_le (by decide : (0:ℕ) < 10) (Finset.mem_Ico.mp hxI).1\n      have : (∑ y ∈ a.1, y) < (∑ y ∈ b.1, y) := by\n        -- add x to a.1 subset inequality becomes strict\n        have hlt : (∑ y ∈ a.1, y) + x ≤ ∑ y ∈ b.1, y := by\n          -- a.1 ∪ {x} ⊆ b.1\n          have hsubu : a.1 ∪ {x} ⊆ b.1 := by\n            intro y hy\n            rcases Finset.mem_union.mp hy with hy | hy\n            · exact hsub hy\n            · simpa [Finset.mem_singleton] using hy\n          have : (∑ y ∈ a.1 ∪ {x}, y) ≤ ∑ y ∈ b.1, y := by\n            exact Finset.sum_le_sum_of_subset_of_nonneg hsubu (by intro y hy; exact Nat.zero_le y)\n          -- lower bound by sum a + x since x ∉ a\n          have hxna' : x ∉ a.1 := hxna\n          have hadd : (∑ y ∈ a.1 ∪ {x}, y) = (∑ y ∈ a.1, y) + x := by\n            simpa [Finset.sum_union, hxna', Finset.disjoint_singleton_right] using rfl\n          simpa [hadd] using this\n        exact lt_of_lt_of_le (Nat.lt_add_of_pos_right hpos) hlt\n      exact (lt_irrefl _ (by simpa [f] using this))\n    have hab_eq : a.1 = b.1 := Finset.Subset.antisymm hsub hsub'\n    exact hab_ne (Subtype.ext (by simpa [hab_eq]))\n  have hS₂ne : S₂.Nonempty := by\n    -- symmetric\n    have : S₁.Nonempty := hS₁ne\n    -- if S₂ empty then disjoint and sum equality forces S₁ empty too\n    by_contra h\n    have hS₂empty : S₂ = ∅ := Finset.not_nonempty_iff_eq_empty.mp h\n    have : ∑ x ∈ S₁, x = 0 := by\n      simpa [hsum_eq, hS₂empty] using (hsum_eq.trans (by simp [hS₂empty]))\n    have : S₁ = ∅ := by\n      -- nat sum of positive elements can't be 0; but elements are ≥10\n      by_contra hne\n      have hne' : S₁.Nonempty := Finset.nonempty_iff_ne_empty.2 hne\n      rcases hne' with ⟨x, hx⟩\n      have hxS : x ∈ S := hS₁sub hx\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have hxpos : 0 < x := lt_of_lt_of_le (by decide : (0:ℕ) < 10) (Finset.mem_Ico.mp hxI).1\n      have : 0 < ∑ y ∈ S₁, y := by\n        exact lt_of_lt_of_le (Nat.lt_add_of_pos_left hxpos) (by\n          have := Finset.single_le_sum (fun y => (Nat.zero_le y)) hx\n          simpa using this)\n      exact lt_irrefl _ (lt_of_lt_of_eq this this)\n    exact this (Finset.not_nonempty_iff_eq_empty.1 hS₁ne)\n  refine ⟨S₁, S₂, hS₁ne, hS₁sub, hS₂ne, hS₂sub, hdis, ?_⟩\n  exact hsum_eq",
      "\n  classical\n  have hS : S.card = 10 := h₀\n  -- consider all nonempty subsets of S and their sums\n  let A : Finset (Finset ℕ) := (S.powerset.erase ∅)\n  have hA_nonempty : A.Nonempty := by\n    have : ({S.min' (by\n        have : S.Nonempty := by\n          simpa [Finset.card_pos] using (by\n            have : 0 < S.card := by simpa [hS] using (show 0 < 10 by decide)\n            exact this)\n        exact this) } : Finset ℕ) ⊆ S := by\n      intro x hx\n      simp at hx\n      subst hx\n      exact Finset.min'_mem _ _\n    have hneS : S.Nonempty := by\n      have : 0 < S.card := by simpa [hS] using (show 0 < 10 by decide)\n      simpa [Finset.card_pos] using this\n    refine ⟨{S.min' hneS}, ?_⟩\n    have : ({S.min' hneS} : Finset ℕ) ∈ S.powerset := by\n      simpa [Finset.mem_powerset] using this\n    have : ({S.min' hneS} : Finset ℕ) ∈ S.powerset.erase ∅ := by\n      refine Finset.mem_erase.2 ?_\n      refine ⟨this, ?_⟩\n      simp\n    simpa [A] using this\n  -- bound sums to apply pigeonhole\n  have hsum_le (T : Finset ℕ) (hT : T ⊆ S) : (∑ x ∈ T, x) ≤ 99 * T.card := by\n    classical\n    have hx : ∀ x ∈ T, x ≤ 99 := by\n      intro x hxT\n      have hxS : x ∈ S := hT hxT\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have : x < 100 := (Finset.mem_Ico.mp hxI).2\n      exact Nat.le_of_lt_succ (by simpa using this)\n    classical\n    -- use `sum_le_sum` with pointwise bound\n    have : (∑ x ∈ T, x) ≤ ∑ x ∈ T, 99 := by\n      refine Finset.sum_le_sum ?_\n      intro x hxT\n      exact hx x hxT\n    simpa [Finset.sum_const_nat, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using this\n  have hsum_lt_1000 (T : Finset ℕ) (hT : T ⊆ S) (hne : T.Nonempty) : (∑ x ∈ T, x) < 1000 := by\n    have hcard : T.card ≤ 10 := by\n      simpa [hS] using Finset.card_le_card hT\n    have hle : (∑ x ∈ T, x) ≤ 99 * T.card := hsum_le T hT\n    have : 99 * T.card ≤ 99 * 10 := Nat.mul_le_mul_left 99 hcard\n    have hle' : (∑ x ∈ T, x) ≤ 990 := le_trans hle (by simpa using this)\n    exact lt_of_le_of_lt hle' (by decide : 990 < 1000)\n  -- define sum function on A\n  let f : (Finset ℕ) → ℕ := fun T => ∑ x ∈ T, x\n  -- pigeonhole: A has 2^10-1 = 1023 elements, sums are in {0..999} hence ≤ 1000 values\n  have hA_card : A.card = 1023 := by\n    classical\n    -- card(powerset S) = 2^(card S)\n    have : S.powerset.card = 2 ^ S.card := by simpa using Finset.card_powerset S\n    have hne : (∅ : Finset ℕ) ∈ S.powerset := by\n      simp [Finset.mem_powerset]\n    have : (S.powerset.erase ∅).card = S.powerset.card - 1 := by\n      simpa [Finset.card_erase_of_mem hne]\n    simp [A, this, hS] at *\n  have hExists_collision :\n      ∃ T₁ ∈ A, ∃ T₂ ∈ A, T₁ ≠ T₂ ∧ f T₁ = f T₂ := by\n    classical\n    -- range of f on A is subset of {1..999}, so at most 999 values; 1023 > 1000 suffices\n    by_contra h\n    have hinj : Set.InjOn f (fun T => T ∈ A) := by\n      intro x hx y hy hxy\n      by_contra hne\n      exact h ⟨x, hx, y, hy, hne, hxy⟩\n    have hcard_image : (A.image f).card = A.card := by\n      classical\n      exact Finset.card_image_iff.2 (by\n        intro x hx y hy hxy\n        have : x = y := hinj hx hy hxy\n        exact this)\n    have hsubset : A.image f ⊆ Finset.Icc 1 999 := by\n      intro s hs\n      rcases Finset.mem_image.1 hs with ⟨T, hT, rfl⟩\n      have hTsub : T ⊆ S := by\n        have : T ⊆ S := by\n          have hmem : T ∈ S.powerset := by\n            have : T ∈ S.powerset.erase ∅ := by simpa [A] using hT\n            exact (Finset.mem_erase.1 this).1\n          simpa [Finset.mem_powerset] using hmem\n        exact this\n      have hTne : T.Nonempty := by\n        have : T ∈ S.powerset.erase ∅ := by simpa [A] using hT\n        exact by\n          have : T ≠ ∅ := (Finset.mem_erase.1 this).2\n          exact Finset.nonempty_iff_ne_empty.2 this\n      have hpos : 1 ≤ f T := by\n        have : 0 < f T := by\n          have hmin : ∀ x ∈ T, 10 ≤ x := by\n            intro x hxT\n            have hxS : x ∈ S := hTsub hxT\n            have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n            exact (Finset.mem_Ico.mp hxI).1\n          rcases hTne with ⟨x, hxT⟩\n          have : 10 ≤ x := hmin x hxT\n          have : 0 < x := lt_of_lt_of_le (by decide : (0:ℕ) < 10) this\n          have hxle : x ≤ f T := by\n            -- term is included in the sum\n            have : x = ∑ y ∈ ({x} : Finset ℕ), y := by simp\n            have hsub : ({x} : Finset ℕ) ⊆ T := by\n              intro y hy\n              simp at hy\n              subst hy\n              exact hxT\n            have : ∑ y ∈ ({x} : Finset ℕ), y ≤ ∑ y ∈ T, y := by\n              exact Finset.sum_le_sum_of_subset_of_nonneg hsub (by intro; simp)\n            simpa [f, Finset.sum_sigma'] using this\n          exact lt_of_lt_of_le this hxle\n        exact Nat.succ_le_iff.2 this\n      have hlt : f T ≤ 999 := by\n        have : f T < 1000 := hsum_lt_1000 T hTsub hTne\n        exact Nat.le_of_lt_succ (by simpa using this)\n      exact Finset.mem_Icc.2 ⟨hpos, hlt⟩\n    have hcard_le : (A.image f).card ≤ (Finset.Icc 1 999).card := Finset.card_le_card hsubset\n    have : A.card ≤ (Finset.Icc 1 999).card := by simpa [hcard_image] using hcard_le\n    have : 1023 ≤ (Finset.Icc 1 999).card := by simpa [hA_card] using this\n    -- but card(Icc 1 999) = 999\n    have : (Finset.Icc 1 999).card = 999 := by\n      simpa using (Finset.card_Icc (a := 1) (b := 999))\n    have : 1023 ≤ 999 := by simpa [this] using ‹1023 ≤ (Finset.Icc 1 999).card›\n    exact (by decide : ¬ (1023 ≤ 999)) this\n  rcases hExists_collision with ⟨T₁, hT₁A, T₂, hT₂A, hne, hsum⟩\n  have hT₁sub : T₁ ⊆ S := by\n    have : T₁ ∈ S.powerset := (Finset.mem_erase.1 (by simpa [A] using hT₁A)).1\n    simpa [Finset.mem_powerset] using this\n  have hT₂sub : T₂ ⊆ S := by\n    have : T₂ ∈ S.powerset := (Finset.mem_erase.1 (by simpa [A] using hT₂A)).1\n    simpa [Finset.mem_powerset] using this\n  have hT₁ne : T₁.Nonempty := by\n    have : T₁ ≠ ∅ := (Finset.mem_erase.1 (by simpa [A] using hT₁A)).2\n    exact Finset.nonempty_iff_ne_empty.2 this\n  have hT₂ne : T₂.Nonempty := by\n    have : T₂ ≠ ∅ := (Finset.mem_erase.1 (by simpa [A] using hT₂A)).2\n    exact Finset.nonempty_iff_ne_empty.2 this\n  -- use symmetric difference decomposition into disjoint equal-sum subsets\n  let S₁ : Finset ℕ := T₁ \\ T₂\n  let S₂ : Finset ℕ := T₂ \\ T₁\n  refine ⟨S₁, S₂, ?_, ?_, ?_, ?_, ?_, ?_⟩\n  · have : S₁ ≠ ∅ := by\n      by_contra hZ\n      have hle : T₁ ⊆ T₂ := by\n        intro x hx\n        by_contra hx'\n        have : x ∈ T₁ \\ T₂ := by\n          simp [Finset.mem_sdiff, hx, hx']\n        simpa [S₁, hZ] using this\n      have hle' : T₂ ⊆ T₁ := by\n        intro x hx\n        by_contra hx'\n        have : x ∈ T₂ \\ T₁ := by\n          simp [Finset.mem_sdiff, hx, hx']\n        -- if T₂\\T₁ nonempty then sums differ? we use hsum with subset and positivity indirectly\n        -- instead, from hsum and hle we deduce equality and then T₁=T₂ contradict hne\n        have : T₂ \\ T₁ = ∅ := by\n          by_contra hNZ\n          -- if strict, then sum T₂ > sum T₁ since all elements positive\n          have hpos : 0 < ∑ x ∈ T₂ \\ T₁, x := by\n            rcases Finset.nonempty_iff_ne_empty.2 hNZ with ⟨x, hx⟩\n            have hxpos : 0 < x := by\n              have hxS : x ∈ S := hT₂sub (by\n                have : x ∈ T₂ := (Finset.mem_sdiff.1 hx).1\n                exact this)\n              have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n              have : 10 ≤ x := (Finset.mem_Ico.mp hxI).1\n              exact lt_of_lt_of_le (by decide : (0:ℕ) < 10) this\n            have hxle : x ≤ ∑ y ∈ T₂ \\ T₁, y := by\n              have : x = ∑ y ∈ ({x} : Finset ℕ), y := by simp\n              have hsub : ({x} : Finset ℕ) ⊆ T₂ \\ T₁ := by\n                intro y hy; simp at hy; subst hy; exact hx\n              have : ∑ y ∈ ({x} : Finset ℕ), y ≤ ∑ y ∈ T₂ \\ T₁, y :=\n                Finset.sum_le_sum_of_subset_of_nonneg hsub (by intro; simp)\n              simpa using this\n            exact lt_of_lt_of_le hxpos hxle\n          -- show sum T₂ > sum T₁ contradict hsum\n          have hdecomp1 : (∑ x ∈ T₂, x) = (∑ x ∈ T₁, x) + (∑ x ∈ T₂ \\ T₁, x) := by\n            -- T₂ = T₁ ∪ (T₂\\T₁) since T₁ ⊆ T₂\n            have hunion : T₁ ∪ (T₂ \\ T₁) = T₂ := by\n              ext x; constructor <;> intro hx\n              · have : x ∈ T₁ ∨ x ∈ T₂ \\ T₁ := by simpa using hx\n                cases this with\n                | inl hx1 => exact hle hx1\n                | inr hx2 => exact (Finset.mem_sdiff.1 hx2).1\n              · by_cases hx1 : x ∈ T₁\n                · exact Or.inl hx1\n                · have hx2 : x ∈ T₂ \\ T₁ := by simp [Finset.mem_sdiff, hx, hx1]\n                  exact Or.inr hx2\n            have hdis : Disjoint T₁ (T₂ \\ T₁) := by\n              exact Finset.disjoint_sdiff\n            -- sums\n            have := (Finset.sum_union hdis (s := T₁) (t := T₂ \\ T₁) (f := fun x : ℕ => x))\n            -- rewrite using hunion\n            simpa [hunion, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using this.symm\n          have : (∑ x ∈ T₂, x) > (∑ x ∈ T₁, x) := by\n            -- from decomposition and positivity\n            have : (∑ x ∈ T₂, x) = (∑ x ∈ T₁, x) + (∑ x ∈ T₂ \\ T₁, x) := hdecomp1\n            have hpos' : 0 < (∑ x ∈ T₂ \\ T₁, x) := hpos\n            have : (∑ x ∈ T₁, x) < (∑ x ∈ T₁, x) + (∑ x ∈ T₂ \\ T₁, x) :=\n              Nat.lt_add_of_pos_right hpos'\n            simpa [this] using this\n          exact lt_irrefl _ (lt_of_lt_of_eq this (by simpa [f] using hsum.symm))\n        -- if T₂\\T₁ empty then T₂ ⊆ T₁\n        intro x hx\n        have hx' : x ∈ T₂ \\ T₁ := by simp [Finset.mem_sdiff, hx, hx']\n        simpa [this] using hx'\n      have : T₁ = T₂ := Finset.eq_of_subset_of_card_le hle (by\n        have := Finset.card_le_card hle'\n        exact le_antisymm (Finset.card_le_card hle) this)\n      exact hne (this)\n    exact Finset.nonempty_iff_ne_empty.2 this\n  · exact Finset.sdiff_subset_trans hT₁sub\n  · have : S₂ ≠ ∅ := by\n      by_contra hZ\n      have hle : T₂ ⊆ T₁ := by\n        intro x hx\n        by_contra hx'\n        have : x ∈ T₂ \\ T₁ := by\n          simp [Finset.mem_sdiff, hx, hx']\n        simpa [S₂, hZ] using this\n      have hle' : T₁ ⊆ T₂ := by\n        -- from sum equality and subset, as above\n        intro x hx\n        by_contra hx'\n        have : x ∈ T₁ \\ T₂ := by\n          simp [Finset.mem_sdiff, hx, hx']\n        -- if strict then sum T₁ > sum T₂, contradiction\n        have hpos : 0 < ∑ x ∈ T₁ \\ T₂, x := by\n          rcases Finset.nonempty_iff_ne_empty.2 (by\n            intro hE\n            exact hx' (by\n              have : x ∈ T₂ := by\n                -- if difference empty then hx implies in T₂\n                have : x ∈ T₁ \\ T₂ := by simp [Finset.mem_sdiff, hx, hx']\n                simpa [S₁, hE] using this\n              exact this)) with ⟨y, hy⟩\n          have hypos : 0 < y := by\n            have hyS : y ∈ S := hT₁sub (Finset.mem_sdiff.1 hy).1\n            have hyI : y ∈ Finset.Ico 10 100 := h₁ hyS\n            have : 10 ≤ y := (Finset.mem_Ico.mp hyI).1\n            exact lt_of_lt_of_le (by decide : (0:ℕ) < 10) this\n          have hyle : y ≤ ∑ z ∈ T₁ \\ T₂, z := by\n            have : y = ∑ z ∈ ({y} : Finset ℕ), z := by simp\n            have hsub : ({y} : Finset ℕ) ⊆ T₁ \\ T₂ := by\n              intro z hz; simp at hz; subst hz; exact hy\n            have : ∑ z ∈ ({y} : Finset ℕ), z ≤ ∑ z ∈ T₁ \\ T₂, z :=\n              Finset.sum_le_sum_of_subset_of_nonneg hsub (by intro; simp)\n            simpa using this\n          exact lt_of_lt_of_le hypos hyle\n        have hdecomp1 : (∑ x ∈ T₁, x) = (∑ x ∈ T₂, x) + (∑ x ∈ T₁ \\ T₂, x) := by\n          have hunion : T₂ ∪ (T₁ \\ T₂) = T₁ := by\n            ext x; constructor <;> intro hx\n            · have : x ∈ T₂ ∨ x ∈ T₁ \\ T₂ := by simpa using hx\n              cases this with\n              | inl hx2 => exact hle hx2\n              | inr hx1 => exact (Finset.mem_sdiff.1