      "\n  classical\n  let A : Finset (Finset ℕ) := S.powerset.erase ∅\n  have hAcard : A.card = 1023 := by\n    have : S.powerset.card = 2 ^ S.card := by simpa using (Finset.card_powerset S)\n    have hempty : (∅ : Finset ℕ) ∈ S.powerset := by\n      simpa using (Finset.empty_mem_powerset : (∅ : Finset ℕ) ∈ S.powerset)\n    have hnot : (∅ : Finset ℕ) ∈ S.powerset := hempty\n    have : (S.powerset.erase (∅ : Finset ℕ)).card = S.powerset.card - 1 := by\n      simpa [Finset.card_erase_of_mem hempty]\n    have hc : (2 ^ S.card : ℕ) = 1024 := by simpa [h₀]\n    have : A.card = (2 ^ S.card) - 1 := by\n      simpa [A, this] using congrArg id (by rfl : (S.powerset.erase (∅ : Finset ℕ)).card = _)\n    simpa [this, hc]\n  have hsum_le : ∀ T : Finset ℕ, T ⊆ S → (∑ x ∈ T, x) ≤ 945 := by\n    intro T hTS\n    have hT1 : ∀ x, x ∈ T → x ≤ 99 := by\n      intro x hx\n      have hxS : x ∈ S := hTS hx\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      exact Nat.le_of_lt_succ (Finset.mem_Ico.mp hxI).2\n    have hcard : T.card ≤ 10 := by\n      simpa [h₀] using (Finset.card_le_card hTS)\n    have hsum1 : (∑ x ∈ T, x) ≤ ∑ _x ∈ T, 99 := by\n      exact Finset.sum_le_sum (fun x hx => by\n        have := hT1 x hx\n        simpa using this)\n    have hsum2 : (∑ _x ∈ T, 99) = 99 * T.card := by\n      simp [Finset.sum_const_nat, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc]\n    have : (∑ x ∈ T, x) ≤ 99 * T.card := by simpa [hsum2] using hsum1\n    have : (99 * T.card : ℕ) ≤ 99 * 10 := by\n      exact Nat.mul_le_mul_left 99 hcard\n    have : (∑ x ∈ T, x) ≤ 99 * 10 := le_trans (by simpa using this) this\n    norm_num at this\n    exact this\n  let f : {T // T ∈ A} → ℕ := fun T => ∑ x ∈ (T : Finset ℕ), x\n  have hf_range : ∀ T : {T // T ∈ A}, f T ∈ Finset.Icc 10 945 := by\n    intro T\n    rcases T with ⟨T, hTA⟩\n    have hTsub : T ⊆ S := by\n      have : T ∈ S.powerset := by\n        have := Finset.mem_erase.mp hTA\n        exact this.1\n      exact Finset.mem_powerset.mp this\n    h