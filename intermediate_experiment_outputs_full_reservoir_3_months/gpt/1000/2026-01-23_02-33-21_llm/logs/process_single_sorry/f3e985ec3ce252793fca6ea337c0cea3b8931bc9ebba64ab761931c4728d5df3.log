         have : A ⊆ B := by\n                  intro y hy\n                  by_contra hyB\n                  have : y ∈ A \\ B := by simpa [Finset.mem_sdiff, hy, hyB]\n                  simpa [this] using this\n                exact Finset.Subset.antisymm (by intro y hy; exact Finset.mem_inter.mpr ⟨hy, this hy⟩) (by intro y hy; exact (Finset.mem_inter.mp hy).1)\n              -- then B has extra nonempty part\n              have hBAne : (B \\ A).Nonempty := ⟨x, by simpa using hx⟩\n              -- sum(B) = sum(A) + sum(B\\A) with positive sum\n              have hsumpos : 0 < ∑ y ∈ (B \\ A), y := by\n                rcases hBAne with ⟨y, hy⟩\n                have : 0 < y := by\n                  have hyS : y ∈ S := by\n                    have hyB : y ∈ B := (Finset.mem_sdiff.mp hy).1\n                    exact hBsub hyB\n                  have hyI : y ∈ Finset.Ico 10 100 := h₁ hyS\n                  have : 10 ≤ y := (by\n                    have : 10 ≤ y ∧ y < 100 := by simpa [Finset.mem_Ico] using hyI\n                    exact this.1)\n                  exact lt_of_lt_of_le (by decide : 0 < 10) this\n                have : y ≤ ∑ z ∈ (B \\ A), z := by\n                  simpa using (Finset.single_le_sum (fun _ _ => Nat.zero_le _) hy)\n                exact lt_of_lt_of_le this\n              have hsumB :\n                  f B = (∑ y ∈ (A ∩ B), y) + (∑ y ∈ (B \\ A), y) := by\n                simp [f, hBdecomp, Finset.sum_union hdisj, Nat.add_comm, Nat.add_left_comm, Nat.add_assoc]\n              have hsumA :\n                  f A = (∑ y ∈ (A ∩ B), y) := by\n                simp [f, hAeq]\n              -- hence fA < fB\n              have : f A + (∑ y ∈ (B \\ A), y) = f B := by\n                simpa [hsumA, hsumB, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm]\n              have : f A < f A + (∑ y ∈ (B \\ A), y) := Nat.lt_add_of_pos_right hsumpos\n              simpa [this] using this\n            exact lt_irrefl _ (lt_of_eq_of_lt hsum.symm hstrict)))\n       