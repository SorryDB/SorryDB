      "\n  classical\n  have hS : S.Nonempty := by\n    rcases Finset.card_pos.mp (by simpa [h₀] : 0 < S.card) with h\n    exact h\n  obtain ⟨a, haS⟩ := hS\n  refine ⟨{a}, {a}, by simp [haS], ?_, by simp [haS], ?_, ?_, ?_⟩\n  · intro x hx\n    simpa using (Finset.mem_singleton.mp hx ▸ haS)\n  · intro x hx\n    simpa using (Finset.mem_singleton.mp hx ▸ haS)\n  · simpa using (Finset.disjoint_singleton_left.2 (by simp))\n  · simp",
