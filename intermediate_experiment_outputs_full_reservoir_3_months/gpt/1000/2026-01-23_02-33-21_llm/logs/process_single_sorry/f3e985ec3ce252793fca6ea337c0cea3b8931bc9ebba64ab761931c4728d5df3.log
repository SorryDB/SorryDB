      "\n  classical\n  have hcard : S.card = 10 := h₀\n  obtain ⟨l, hlnd, hlnodup, hlen, rfl⟩ := S.exists_list_nodup_eq\n  have hlen10 : l.length = 10 := by\n    simpa [hcard] using congrArg List.length hlen\n  have hlmem : ∀ x ∈ l, x ∈ Finset.Ico 10 100 := by\n    intro x hx\n    exact h₁ (by\n      simpa using (Finset.mem_list_toFinset.mpr ⟨hx, by\n        simpa [Finset.mem_list_toFinset, List.mem_toFinset]⟩))\n  let A : Finset (Finset ℕ) := (Finset.powerset (l.toFinset)).erase ∅\n  have hAcard : A.card = 1023 := by\n    have : (Finset.powerset (l.toFinset)).card = 2 ^ (l.toFinset.card) := by\n      simpa using (Finset.card_powerset (l.toFinset))\n    have hlt : l.toFinset.card = 10 := by\n      simpa [Finset.card_list_toFinset hlnodup, hlen10]\n    have hne : (∅ : Finset ℕ) ∈ Finset.powerset (l.toFinset) := by\n      simpa using (Finset.mem_powerset.2 (by intro x hx; cases hx))\n    have herase : A.card = (Finset.powerset (l.toFinset)).card - 1 := by\n      simpa [A, Finset.card_erase_of_mem hne]\n    have : (Finset.powerset (l.toFinset)).card = 1024 := by\n      simp [this, hlt]\n    omega\n  have hsum_le : ∀ T : Finset ℕ, T ⊆ l.toFinset → (∑ x ∈ T, x) ≤ 99 * T.card := by\n    intro T hT\n    classical\n    have hx : ∀ x ∈ T, x ≤ 99 := by\n      intro x hxT\n      have hxS : x ∈ S := by\n        have : x ∈ l.toFinset := hT hxT\n        simpa [Finset.mem_list_toFinset] using this\n      have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n      have hxlt : x < 100 := by\n        exact (Finset.mem_Ico.mp hxI).2\n      exact Nat.le_of_lt_succ (by simpa using hxlt)\n    have := Finset.sum_le_sum fun x hxT => Nat.mul_le_mul_left 1 (hx x hxT)\n    have : (∑ x ∈ T, x) ≤ ∑ x ∈ T, 99 := by\n      exact Finset.sum_le_sum fun x hxT => hx x hxT\n    simpa [Finset.sum_const_nat, Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using this\n  let f : Finset ℕ → ℕ := fun T => ∑ x ∈ T, x\n  have hbound : ∀ T ∈ A, f T ≤ 990 := by\n    intro T hT\n    have hTs : T ⊆ l.toFinset := by\n     