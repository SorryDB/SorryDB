      "\n  classical\n  -- Consider all nonempty subsets of `S` and their sums.\n  let T : Finset (Finset ℕ) := (S.powerset.erase ∅)\n  have hTnonempty : T.Nonempty := by\n    rcases S.card_pos.mp (by simpa [h₀] : 0 < S.card) with ⟨a, ha⟩\n    refine ⟨{a}, ?_⟩\n    have hsub : ({a} : Finset ℕ) ⊆ S := by\n      intro x hx\n      simpa [Finset.mem_singleton] using (by\n        have : x = a := by simpa [Finset.mem_singleton] using hx\n        simpa [this] using ha)\n    have hmem : ({a} : Finset ℕ) ∈ S.powerset := by\n      simpa [Finset.mem_powerset] using hsub\n    have hne : ({a} : Finset ℕ) ≠ ∅ := by simp\n    simpa [T, Finset.mem_erase, hne, hmem]\n  -- Count how many nonempty subsets: 2^10 - 1 = 1023.\n  have hTcard : T.card = 1023 := by\n    have : (S.powerset.erase (∅ : Finset ℕ)).card = (S.powerset.card - 1) := by\n      simpa using (Finset.card_erase_of_mem (by simpa using (Finset.empty_mem_powerset : (∅ : Finset ℕ) ∈ S.powerset)))\n    simp [T, this, Finset.card_powerset, h₀, pow_succ]\n  -- Bound all sums between 10 and 990, hence at most 981 possible sums.\n  have hsumBounds :\n      ∀ A : Finset ℕ, A ∈ T → 10 ≤ (∑ x ∈ A, x) ∧ (∑ x ∈ A, x) ≤ 990 := by\n    intro A hA\n    have hAsub : A ⊆ S := by\n      have : A ∈ S.powerset := by\n        have : A ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hA\n        exact (Finset.mem_erase.mp this).2\n      simpa [Finset.mem_powerset] using this\n    have hAne : A.Nonempty := by\n      have : A ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hA\n      have : A ≠ ∅ := (Finset.mem_erase.mp this).1\n      exact Finset.nonempty_iff_ne_empty.2 this\n    have hApos : 10 ≤ ∑ x ∈ A, x := by\n      rcases hAne with ⟨a, haA⟩\n      have haS : a ∈ S := hAsub haA\n      have haI : a ∈ Finset.Ico 10 100 := h₁ haS\n      have ha10 : 10 ≤ a := by simpa [Finset.mem_Ico] using haI\n      have : a ≤ ∑ x ∈ A, x := by\n        simpa using (Finset.single_le_sum (fun _ _ => Nat.zero_le _) haA)\n      exact le_trans ha10 this\n    have hAupper : (∑ x ∈ A, x) ≤ 990 := by\n      have hcardA : A.card ≤ 10 := by\n        simpa [h₀] using (Finset.card_le_card hAsub)\n      have hle99 : ∀ x ∈ A, x ≤ 99 := by\n        intro x hx\n        have hxS : x ∈ S := hAsub hx\n        have hxI : x ∈ Finset.Ico 10 100 := h₁ hxS\n        have hxlt : x < 100 := (by\n          have : 10 ≤ x ∧ x < 100 := by simpa [Finset.mem_Ico] using hxI\n          exact this.2)\n        exact Nat.le_of_lt_succ (by simpa using hxlt)\n      have : (∑ x ∈ A, x) ≤ A.card * 99 := by\n        simpa [Nat.mul_comm] using (Finset.sum_le_card_nsmul A (fun x hx => hle99 x hx) 99)\n      have : (∑ x ∈ A, x) ≤ 10 * 99 := le_trans this (by\n        gcongr\n        exact hcardA)\n      simpa [Nat.mul_comm, Nat.mul_left_comm, Nat.mul_assoc] using this\n    exact ⟨hApos, hAupper⟩\n  -- Pigeonhole on sums in {10,11,...,990}: 981 values.\n  let f : (Finset ℕ) → ℕ := fun A => ∑ x ∈ A, x\n  have hcod : ∀ A ∈ T, f A ∈ Finset.Icc 10 990 := by\n    intro A hA\n    have hb := hsumBounds A hA\n    simpa [f, Finset.mem_Icc] using hb\n  have hcodcard : (Finset.Icc 10 990 : Finset ℕ).card = 981 := by\n    simp\n  have hDup : ∃ A ∈ T, ∃ B ∈ T, A ≠ B ∧ f A = f B := by\n    classical\n    by_contra h\n    have hinj : Set.InjOn f (fun A => A ∈ T) := by\n      intro A hA B hB hAB\n      by_contra hne\n      exact h ⟨A, hA, B, hB, hne, hAB⟩\n    have hcard_le : T.card ≤ (Finset.Icc 10 990 : Finset ℕ).card := by\n      exact Finset.card_le_of_injOn f (fun A hA => hcod A hA) hinj\n    have : (1023 : ℕ) ≤ 981 := by simpa [hTcard, hcodcard] using hcard_le\n    exact Nat.not_succ_le_self 981 (by simpa using this)\n  rcases hDup with ⟨A, hA, B, hB, hne, hsum⟩\n  -- Make disjoint by taking set differences.\n  refine ⟨A \\ B, B \\ A, ?_, ?_, ?_, ?_, ?_, ?_⟩\n  · have hAne : A.Nonempty := by\n      have : A ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hA\n      have : A ≠ ∅ := (Finset.mem_erase.mp this).1\n      exact Finset.nonempty_iff_ne_empty.2 this\n    have hBne : B.Nonempty := by\n      have : B ∈ S.powerset.erase (∅ : Finset ℕ) := by simpa [T] using hB\n      have : B ≠ ∅ := (Finset.mem_erase.mp this).1\n      exact Finset.nonempty_iff_ne_empty.2 this\n    have : (A \\ B).Nonempty ∨ (B \\ A).Nonempty := by\n      by_contra h'\n      have h1 : (A \\ B) = ∅ := by\n        simpa [Finset.not_nonempty_iff_eq_empty] using (not_or.mp h').1\n      have h2 : (B \\ A) = ∅ := by\n        simpa [Finset.not_nonempty_iff_eq_empty] using (not_or.mp h').2\n      have hAB : A ⊆ B := by\n        intro x hx\n        by_contra hxB\n        have : x ∈ A \\ B := by simpa [Finset.mem_sdiff, hx, hxB]\n        simpa [h1] using this\n      have hBA : B ⊆ A := by\n        intro x hx\n        by_contra hxA\n        have : x ∈ B \\ A := by simpa [Finset.mem_sdiff, hx, hxA]\n        simpa [h2] using this\n      have : A = B := by\n        exact Finset.Subset.antisymm hAB hBA\n      exact hne this\n    cases this with\n    | inl h => exact h\n    | inr h =>\n      -- if A\\B empty, then B\\A nonempty; swap roles using symmetry later\n      exact (by\n        -- show A\\B nonempty by contradiction using hne and symmetry of construction\n        -- We can just use that either side is nonempty and our chosen first is A\\B;\n        -- if not, interchange A and B now.\n        have : (A \\ B).Nonempty := by\n          by_contra h0\n          have h0' : (A \\ B) = ∅ := by simpa [Finset.not_nonempty_iff_eq_empty] using h0\n          -- then B\\A nonempty; swap A,B\n          exact False.elim (by\n            -- contradict: we can redefine; but for goal we need Nonempty of A\\B specifically\n            -- use that if A\\B = ∅ and f A = f B with A ≠ B, impossible since B\\A nonempty and elements are positive\n            rcases h with ⟨x, hx⟩\n            have hxB : x ∈ B := by\n              have : x ∈ B \\ A := by simpa using hx\n              exact (Finset.mem_sdiff.mp this).1\n            have hxA : x ∉ A := (Finset.mem_sdiff.mp (by sim