(((n : ℚ) + 2) + 1) / (((n : ℚ) + 2) * (((n : ℚ) + 2) - 1)))))\n          simpa [Set.setOf_exists, Set.range, and_left_comm, and_assoc, exists_eq_left] using this\n        refine this.mono ?_\n        intro q hq\n        rcases hq with ⟨n, rfl⟩\n        let t : ℚ := (n : ℚ) + 2\n        refine ⟨t, (t - 1) / (t + 1), (t + 1) / (t * (t - 1)), ?_, ?_, ?_, rfl⟩\n        · have ht0 : t ≠ 0 := by\n            have : (0 : ℚ) < t := by\n              have : (0 : ℚ) ≤ (n : ℚ) := by exact_mod_cast (Nat.cast_nonneg n)\n              simpa [t] using (by linarith : (0 : ℚ) < (n : ℚ) + 2)\n            exact ne_of_gt this\n          have ht1 : t ≠ 1 := by\n            have hn : (n : ℚ) ≠ (-1 : ℚ) := by\n              exact_mod_cast (by omega : (n : ℤ) ≠ -1)\n            intro h\n            apply hn\n            have : (n : ℚ) = -1 := by\n              have : (n : ℚ) + 2 = 1 := by simpa [t] using h\n              linarith\n            exact this\n          have htplus1 : t + 1 ≠ 0 := by\n            have : (0 : ℚ) < t + 1 := by\n              have : (0 : ℚ) < t := by\n                have : (0 : ℚ) ≤ (n : ℚ) := by exact_mod_cast (Nat.cast_nonneg n)\n                simpa [t] using (by linarith : (0 : ℚ) < (n : ℚ) + 2)\n              linarith\n            exact ne_of_gt this\n          have htm1 : t - 1 ≠ 0 := sub_ne_zero.mpr ht1\n          refine ⟨ht1, ?_, ?_⟩\n          · intro hy\n            have : t - 1 = t + 1 := by\n              have := congrArg (fun u => u * (t + 1)) hy\n              -- (t-1)/(t+1)=1 ⇒ t-1=t+1\n              have : (t - 1) / (t + 1) * (t + 1) = (1 : ℚ) * (t + 1) := by simpa using this\n              simpa [div_mul_eq_mul_div, htplus1] using this\n            linarith\n          · intro hz\n            have : (t + 1) = t * (t - 1) := by\n              have := congrArg (fun u => u * (t * (t - 1))) hz\n              have hden : t * (t - 1) ≠ 0 := mul_ne_zero ht0 (sub_ne_zero.mpr ht1)\n              -- (t+1)/(t*(t-1)) = 1 ⇒ t+1 = t*(t-1)\n              have :