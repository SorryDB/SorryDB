      "\n  classical\n  have hinj : Function.Injective (fun t : {q : ℚ // q ≠ 0 ∧ q ≠ 1} => ((t.1, t.1, (t.1 ^ 2)⁻¹) : ℚ × ℚ × ℚ)) := by\n    intro a b h\n    have : a.1 = b.1 := by\n      have h1 : (a.1, a.1, (a.1 ^ 2)⁻¹) = (b.1, b.1, (b.1 ^ 2)⁻¹) := by simpa using h\n      simpa using congrArg Prod.fst h1\n    exact Subtype.ext this\n  refine (Set.Infinite.of_injective (α := {q : ℚ // q ≠ 0 ∧ q ≠ 1})\n    (β := {p : ℚ × ℚ × ℚ |\n      ∃ x y z,\n        ∃ (_ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (_ : x * y * z = 1)\n          (_ : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 = 1),\n          (x, y, z) = p})\n    (f := fun t => ⟨(t.1, t.1, (t.1 ^ 2)⁻¹),\n      by\n        refine ⟨t.1, t.1, (t.1 ^ 2)⁻¹, ?_, ?_, ?_, rfl⟩\n        · refine ⟨t.2.2, t.2.2, ?_⟩\n          have hq2 : t.1 ^ 2 ≠ 0 := by\n            have : t.1 ≠ 0 := t.2.1\n            nlinarith\n          intro hz\n          have : (t.1 ^ 2)⁻¹ = 1 := by simpa using hz\n          have : t.1 ^ 2 = 1 := by\n            have := congrArg (fun u : ℚ => u⁻¹) this\n            simpa using this\n          have : t.1 = 1 ∨ t.1 = -1 := by\n            have : t.1 ^ 2 = 1 := this\n            nlinarith\n          cases this with\n          | inl h1 => exact t.2.2 (by simpa [h1])\n          | inr h1 =>\n            have : (t.1 ^ 2)⁻¹ = 1 := by\n              simp [h1]\n            exact t.2.2 (by simpa [h1])\n        · have hq2 : t.1 ^ 2 ≠ 0 := by\n            have : t.1 ≠ 0 := t.2.1\n            nlinarith\n          have : (t.1 * t.1) * (t.1 ^ 2)⁻¹ = 1 := by\n            simpa [pow_two, mul_assoc, mul_left_comm, mul_comm, inv_mul_cancel hq2]\n          simpa [mul_assoc] using this\n        · have hx : t.1 ^ 2 / (t.1 - 1) ^ 2 = 1 / ((t.1 - 1) ^ 2) * (t.1 ^ 2) := by\n            simp [div_eq_mul_inv, mul_assoc, mul_left_comm, mul_comm]\n          have hx' : t.1 ^ 2 / (t.1 - 1) ^ 2 = (t.1 / (t.1 - 1)) ^ 2 := by\n            simp [div_eq_mul_inv, pow_two, mul_assoc, mul_left_comm, mul_comm]\n          have hz' : ((t.1