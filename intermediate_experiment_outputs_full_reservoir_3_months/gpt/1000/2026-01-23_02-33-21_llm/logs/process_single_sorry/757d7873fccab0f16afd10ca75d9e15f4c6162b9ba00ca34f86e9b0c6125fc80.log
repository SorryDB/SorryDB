lemma IsSquareIntegrable.eLpNorm_mono (hX : IsSquareIntegrable X 𝓕 P) {i j : ι} (hij : i ≤ j) :
    eLpNorm (X i) 2 P ≤ eLpNorm (X j) 2 P := by
  classical
  have hsub : Submartingale (fun k ω ↦ ‖X k ω‖ ^ 2) 𝓕 P := hX.submartingale_sq_norm
  have hEi : Integrable (fun ω ↦ ‖X i ω‖ ^ 2) P := hX.integrable_sq i
  have hEj : Integrable (fun ω ↦ ‖X j ω‖ ^ 2) P := hX.integrable_sq j
  have hle :
      ∫ ω, ‖X i ω‖ ^ 2 ∂P ≤ ∫ ω, ‖X j ω‖ ^ 2 ∂P := by
    simpa using hsub.condexp_integral_le hij hEi hEj
  have hi_meas := ((hX.martingale.adapted i).mono (𝓕.le i)).aestronglyMeasurable
  have hj_meas := ((hX.martingale.adapted j).mono (𝓕.le j)).aestronglyMeasurable
  have hi :
      (eLpNorm (X i) 2 P) ^ (2 : ℝ≥0∞) = ENNReal.ofReal (∫ ω, ‖X i ω‖ ^ 2 ∂P) := by
    simpa [eLpNorm, ENNReal.ofReal, Real.rpow_nat_cast] using
      (eLpNorm_rpow_eq_ofReal_integral_norm_rpow hi_meas (p := (2 : ℝ≥0∞)))
  have hj :
      (eLpNorm (X j) 2 P) ^ (2 : ℝ≥0∞) = ENNReal.ofReal (∫ ω, ‖X j ω‖ ^ 2 ∂P) := by
    simpa [eLpNorm, ENNReal.ofReal, Real.rpow_nat_cast] using
      (eLpNorm_rpow_eq_ofReal_integral_norm_rpow hj_meas (p := (2 : ℝ≥0∞)))
  have hpow :
      (eLpNorm (X i) 2 P) ^ (2 : ℝ≥0∞) ≤ (eLpNorm (X j) 2 P) ^ (2 : ℝ≥0∞) := by
    simpa [hi, hj] using ENNReal.ofReal_le_ofReal hle
  exact (ENNReal.rpow_le_rpow_iff (by norm_num : (0 : ℝ≥0∞) < (2 : ℝ≥0∞))).1 hpow
