lemma IsSquareIntegrable.eLpNorm_mono (hX : IsSquareIntegrable X 𝓕 P) {i j : ι} (hij : i ≤ j) :
    eLpNorm (X i) 2 P ≤ eLpNorm (X j) 2 P := by
  classical
  have hsub : Submartingale (fun k ω ↦ ‖X k ω‖ ^ 2) 𝓕 P := hX.submartingale_sq_norm
  have hint : Integrable (fun ω ↦ ‖X j ω‖ ^ 2) P := hX.integrable_sq j
  have hle : ∫ ω, ‖X i ω‖ ^ 2 ∂P ≤ ∫ ω, ‖X j ω‖ ^ 2 ∂P := by
    simpa using hsub.integral_mono hij hint
  have hi_meas : AEStronglyMeasurable (X i) P :=
    ((hX.martingale.adapted i).mono (𝓕.le i)).aestronglyMeasurable
  have hj_meas : AEStronglyMeasurable (X j) P :=
    ((hX.martingale.adapted j).mono (𝓕.le j)).aestronglyMeasurable
  have hi_norm : eLpNorm (X i) 2 P = ENNReal.ofReal ((∫ ω, ‖X i ω‖ ^ 2 ∂P) ^ (1 / (2 : ℝ))) := by
    simpa [eLpNorm, Real.rpow_natCast, one_div] using (eLpNorm_eq_ofReal_rpow_integral_norm hi_meas (p := (2 : ℝ≥0∞)) (P := P))
  have hj_norm : eLpNorm (X j) 2 P = ENNReal.ofReal ((∫ ω, ‖X j ω‖ ^ 2 ∂P) ^ (1 / (2 : ℝ))) := by
    simpa [eLpNorm, Real.rpow_natCast, one_div] using (eLpNorm_eq_ofReal_rpow_integral_norm hj_meas (p := (2 : ℝ≥0∞)) (P := P))
  -- monotonicity of rpow and ofReal
  have : ((∫ ω, ‖X i ω‖ ^ 2 ∂P) ^ (1 / (2 : ℝ))) ≤ ((∫ ω, ‖X j ω‖ ^ 2 ∂P) ^ (1 / (2 : ℝ))) := by
    have h0i : 0 ≤ (∫ ω, ‖X i ω‖ ^ 2 ∂P) := by
      have := integral_nonneg (fun ω ↦ by positivity : 0 ≤ ‖X i ω‖ ^ 2)
      simpa using this
    have h0j : 0 ≤ (∫ ω, ‖X j ω‖ ^ 2 ∂P) := by
      have := integral_nonneg (fun ω ↦ by positivity : 0 ≤ ‖X j ω‖ ^ 2)
      simpa using this
    exact Real.rpow_le_rpow_of_exponent_nonneg (by positivity : 0 ≤ (1 / (2 : ℝ))) hle
  simpa [hi_norm, hj_norm] using ENNReal.ofReal_le_ofReal this
