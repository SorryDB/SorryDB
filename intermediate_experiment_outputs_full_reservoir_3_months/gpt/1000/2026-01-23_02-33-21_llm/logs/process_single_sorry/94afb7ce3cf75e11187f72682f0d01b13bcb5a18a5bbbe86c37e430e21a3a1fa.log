      "\n    funext g\n    have hX := h X\n    have hY := h Y\n    rw [iso_iff_isIso] at hX hY\n    choose i hi using hX\n    choose j hj using hY\n    have hi_hom : i.hom = η.arrow X := by simpa [IsIso.hom] using (hi.1)\n    have hj_hom : j.hom = η.arrow Y := by simpa [IsIso.hom] using (hj.1)\n    have hi_inv : i.inv = (NatIso_inverse (F := F) (G := G) η h).arrow X := by\n      rfl\n    have hj_inv : j.inv = (NatIso_inverse (F := F) (G := G) η h).arrow Y := by\n      rfl\n    subst hi_hom\n    subst hj_hom\n    simp only [Category.comp, Function.comp_apply, Functor]\n    -- use naturality of η and cancel with inverses\n    calc\n      (i.inv ≫ G.homF f) ≫ g\n          = i.inv ≫ (G.homF f ≫ g) := by rw [assoc]\n      _   = i.inv ≫ ((η.arrow X ≫ F.homF f) ≫ j.inv ≫ (j.hom ≫ g)) := by\n            -- insert identities via j.inv ≫ j.hom = 𝟙\n            have hj_id : j.inv ≫ j.hom = D.id (F.F Y) := by\n              simpa [IsIso.inv, IsIso.hom, iso_iff_isIso] using (hj.2.1)\n            -- rewrite using η.naturality\n            -- η.arrow X ≫ G.homF f = F.homF f ≫ η.arrow Y\n            -- hence G.homF f = (i.hom ≫ G.homF f) with i.hom = η.arrow X etc\n            -- We'll use simp chain\n            simp [hj_id, assoc, η.naturality f]\n      _   = (F.homF f ≫ j.inv) ≫ g := by\n            -- cancel i.inv ≫ i.hom = 𝟙 and reassociate\n            have hi_id : i.inv ≫ i.hom = D.id (G.F X) := by\n              simpa [IsIso.inv, IsIso.hom, iso_iff_isIso] using (hi.2.1)\n            simp [hi_id, assoc]",
      "\n    funext g\n    have hx := h X\n    have hy := h Y\n    rw [iso_iff_isIso] at hx hy\n    choose i hi using hx\n    choose j hj using hy\n    have hi1 : i.inv ≫ η.arrow X = D.id _ := by\n      exact hi.2.2\n    have hj1 : η.arrow Y ≫ j.inv = D.id _ := by\n      exact hj.2.1\n    calc\n      i.inv ≫ (G.homF f g)\n          = (i.inv ≫ (η.arrow X ≫ (G.homF f g))) := by\n              simpa [hi1, D.id_comp]\n      _   = i.inv ≫ ((F.homF f (η.arrow Y g)) ≫ j.inv) := by\n              simp [η.naturality f, assoc]\n      _   = (F.homF f (j.inv g)) := by\n              simp [assoc, hj1]",
      "\n    have hX := h X\n    have hY := h Y\n    rw [iso_iff_isIso] at hX hY\n    choose i hi using hX\n    choose j hj using hY\n    have hi₁ : i.hom ≫ i.inv = D.id := by simpa using i.hom_inv_id\n    have hi₂ : i.inv ≫ i.hom = D.id := by simpa using i.inv_hom_id\n    have hj₁ : j.hom ≫ j.inv = D.id := by simpa using j.hom_inv_id\n    have hj₂ : j.inv ≫ j.hom = D.id := by simpa using j.inv_hom_id\n    have hη : ∀ {A B : α} (g : C.Hom A B),\n        η.arrow A ≫ G.homF g = F.homF g ≫ η.arrow B := by\n      intro A B g\n      simpa using η.naturality g\n    have hx : η.arrow X = i.hom := by simpa [hi] \n    have hy : η.arrow Y = j.hom := by simpa [hj]\n    -- show: i.inv ≫ F.homF f = G.homF f ≫ j.inv\n    -- derive from naturality using cancellations\n    have hn : i.hom ≫ G.homF f = F.homF f ≫ j.hom := by\n      simpa [hx, hy] using hη f\n    calc\n      i.inv ≫ F.homF f\n          = (i.inv ≫ (i.hom ≫ (G.homF f))) ≫ j.inv := by\n              rw [assoc, hn, assoc, assoc]\n    _ = G.homF f ≫ j.inv := by\n          -- simplify using inverse identities\n          rw [← assoc, ← assoc, hi₂, D.left_id, hj₁, D.right_id]",
      "\n    have hX : IsIso (η.arrow X) := h X\n    have hY : IsIso (η.arrow Y) := h Y\n    have nat := η.naturality (X := X) (Y := Y) f\n    apply (cancel_mono (η.arrow Y))\n    simpa [assoc] using congrArg (fun k => k ≫ η.arrow Y) (by\n      calc\n        (by\n          have := hX\n          rw [iso_iff_isIso] at this\n          choose i hi using this\n          exact i.inv) ≫ G.homF f ≫ η.arrow Y\n            = (by\n                have := hX\n                rw [iso_iff_isIso] at this\n                choose i hi using this\n                exact i.inv) ≫ (G.homF f ≫ η.arrow Y) := by rw [assoc]\n        _ = (by\n              have := hX\n              rw [iso_iff_isIso] at this\n              choose i hi using this\n              exact i.inv) ≫ (η.arrow X ≫ F.homF f) := by simpa [assoc] using congrArg (fun k => k) nat.symm\n        _ = ((by\n                have := hX\n                rw [iso_iff_isIso] at this\n                choose i hi using this\n                exact i.inv) ≫ η.arrow X) ≫ F.homF f := by rw [assoc]\n        _ = (𝟙 _) ≫ F.homF f := by\n              have := hX\n              rw [iso_iff_isIso] at this\n              choose i hi using this\n              simpa using congrArg (fun k => k ≫ F.homF f) hi.2\n        _ = F.homF f := by simp\n      )",
      "\n    have hx : IsIso (η.arrow X) := h X\n    have hy : IsIso (η.arrow Y) := h Y\n    have hx' := (iso_iff_isIso (f := η.arrow X)).2 hx\n    have hy' := (iso_iff_isIso (f := η.arrow Y)).2 hy\n    rcases hx' with ⟨iX, hiX⟩\n    rcases hy' with ⟨iY, hiY⟩\n    have hX : (arrow (α := α) (β := β) (C := C) (D := D) (F := F) (G := G) η h X) = iX.inv := by\n      simp [NatIso_inverse, hiX]\n    have hY : (arrow (α := α) (β := β) (C := C) (D := D) (F := F) (G := G) η h Y) = iY.inv := by\n      simp [NatIso_inverse, hiY]\n    subst hX\n    subst hY\n    have hn := η.naturality (X := X) (Y := Y) f\n    have hn1 : iX.inv ≫ G.homF f = F.homF f ≫ iY.inv := by\n      calc\n        iX.inv ≫ G.homF f\n            = iX.inv ≫ (η.arrow X ≫ (G.homF f)) := by\n                simp [hiX.2]\n        _   = iX.inv ≫ ((F.homF f) ≫ (η.arrow Y)) := by\n                simp [assoc, hn]\n        _   = (iX.inv ≫ F.homF f) ≫ η.arrow Y := by\n                simp [assoc]\n        _   = (F.homF f) ≫ (iY.inv ≫ η.arrow Y) := by\n                simp [assoc, hiX.1]\n        _   = F.homF f ≫ iY.inv := by\n                simp [assoc, hiY.2]\n    simpa [assoc] using hn1",
      "\n    have hx := h X\n    have hy := h Y\n    rw [iso_iff_isIso] at hx hy\n    choose iX hiX using hx\n    choose iY hiY using hy\n    have hx_inv : (η.arrow X) ≫ iX.inv = D.id (F.F X) := by simpa [hiX]\n    have hy_inv : (η.arrow Y) ≫ iY.inv = D.id (F.F Y) := by simpa [hiY]\n    have hx_inv' : iX.inv ≫ (η.arrow X) = D.id (G.F X) := by simpa [hiX]\n    have hy_inv' : iY.inv ≫ (η.arrow Y) = D.id (G.F Y) := by simpa [hiY]\n    have nat := η.naturality f\n    calc\n      (iX.inv) ≫ (F.homF f)\n          = (iX.inv) ≫ (F.homF f) ≫ (D.id (F.F Y)) := by\n              simp [Category.id_right]\n      _ = (iX.inv) ≫ (F.homF f) ≫ ((η.arrow Y) ≫ iY.inv) := by\n              simp [hy_inv]\n      _ = (iX.inv) ≫ ((F.homF f) ≫ (η.arrow Y)) ≫ iY.inv := by\n              simp [assoc]\n      _ = (iX.inv) ≫ ((η.arrow X) ≫ (G.homF f)) ≫ iY.inv := by\n              simp [nat]\n      _ = ((iX.inv) ≫ (η.arrow X)) ≫ (G.homF f) ≫ iY.inv := by\n              simp [assoc]\n      _ = (D.id (G.F X)) ≫ (G.homF f) ≫ iY.inv := by\n              simp [hx_inv']\n      _ = (G.homF f) ≫ iY.inv := by\n              simp [Category.id_left, assoc]",
      "\n    have hX := h X\n    have hY := h Y\n    rw [iso_iff_isIso] at hX hY\n    classical\n    rcases hX with ⟨iX, hiX⟩\n    rcases hY with ⟨iY, hiY⟩\n    have hη := η.naturality f\n    have leftX : (iX.inv ≫ η.arrow X) = D.id (G.F X) := by\n      simpa [hiX] using congrArg Iso.inv_hom_id iX\n    have rightY : (η.arrow Y ≫ iY.inv) = D.id (F.F Y) := by\n      simpa [hiY] using congrArg Iso.hom_inv_id iY\n    calc\n      iX.inv ≫ G.homF f\n          = (iX.inv ≫ (η.arrow X ≫ (G.homF f ≫ iY.inv))) ≫ η.arrow Y := by\n              simp [assoc, leftX, rightY]\n      _ = (iX.inv ≫ ((F.homF f ≫ η.arrow Y) ≫ iY.inv)) ≫ η.arrow Y := by\n              simp [assoc, hη]\n      _ = F.homF f ≫ iY.inv := by\n              simp [assoc, leftX, rightY]",
      "\n    have hx := h X\n    have hy := h Y\n    rw [iso_iff_isIso] at hx hy\n    choose i hi using hx\n    choose j hj using hy\n    have hη : η.arrow X ≫ G.homF f = F.homF f ≫ η.arrow Y := η.naturality f\n    have hi_hom : i.hom = η.arrow X := by simpa [hi]\n    have hj_hom : j.hom = η.arrow Y := by simpa [hj]\n    calc\n      i.inv ≫ G.homF f\n          = i.inv ≫ (η.arrow X ≫ G.homF f) := by\n              simpa [hi_hom] using congrArg (fun t => i.inv ≫ t) (by\n                simpa [hi_hom] using (show i.hom = η.arrow X from hi_hom))\n      _ = i.inv ≫ (F.homF f ≫ η.arrow Y) := by simpa [hη]\n      _ = (i.inv ≫ F.homF f) ≫ η.arrow Y := by rw [assoc]\n      _ = F.homF f ≫ j.inv := by\n            have : (i.inv ≫ F.homF f) ≫ η.arrow Y = F.homF f := by\n              calc\n                (i.inv ≫ F.homF f) ≫ η.arrow Y\n                    = i.inv ≫ (F.homF f ≫ η.arrow Y) := by rw [assoc]\n                _ = i.inv ≫ (η.arrow X ≫ G.homF f) := by simpa [hη]\n                _ = (i.inv ≫ η.arrow X) ≫ G.homF f := by rw [assoc]\n                _ = 𝟙 _ ≫ G.homF f := by\n                      have := i.inv_hom_id\n                      simpa [hi_hom] using this\n                _ = G.homF f := by simp\n            have : i.inv ≫ F.homF f = F.homF f ≫ j.inv := by\n              have hj_hom' : j.hom = η.arrow Y := hj_hom\n              have := congrArg (fun t => t ≫ j.inv) hη\n              simp [assoc, hj_hom'] at this\n              calc\n                i.inv ≫ F.homF f\n                    = (i.inv ≫ F.homF f) ≫ 𝟙 _ := by simp\n                _ = (i.inv ≫ F.homF f) ≫ (η.arrow Y ≫ j.inv) := by\n                      have := j.hom_inv_id\n                      simpa [hj_hom'] using congrArg (fun t => (i.inv ≫ F.homF f) ≫ t) this\n                _ = ((i.inv ≫ F.homF f) ≫ η.arrow Y) ≫ j.inv := by rw [assoc]\n                _ = F.homF f ≫ j.inv := by simpa [this] using rfl\n            simpa [assoc] using congrArg (fun t => t ≫ j.inv) this",
      "\n    classical\n    have hx := h X\n    have hy := h Y\n    rw [iso_iff_isIso] at hx hy\n    choose i hi using hx\n    choose j hj using hy\n    have hn := η.naturality f\n    have hn' : j.inv ≫ Functor.homF f = Functor.homF f ≫ i.inv := by\n      have : (i.inv ≫ (j.inv ≫ Functor.homF f)) = (i.inv ≫ (Functor.homF f ≫ i.inv)) := by\n        calc\n          i.inv ≫ (j.inv ≫ Functor.homF f)\n              = (i.inv ≫ j.inv) ≫ Functor.homF f := by rw [assoc]\n          _   = (i.inv ≫ (η.arrow Y)) ≫ (j.inv ≫ Functor.homF f) := by\n                simpa [hi.2] using rfl\n          _   = i.inv ≫ ((η.arrow Y) ≫ (j.inv ≫ Functor.homF f)) := by rw [assoc]\n          _   = i.inv ≫ (((η.arrow Y) ≫ j.inv) ≫ Functor.homF f) := by rw [assoc]\n          _   = i.inv ≫ (Category.id _ ≫ Functor.homF f) := by\n                simp [hj.2, Category.comp, Category.id]\n          _   = i.inv ≫ Functor.homF f := by simp [Category.comp, Category.id]\n          _   = (i.inv ≫ Functor.homF f) ≫ i.inv := by rw [assoc]\n          _   = i.inv ≫ (Functor.homF f ≫ i.inv) := by rw [assoc]\n      have : (i.inv ≫ j.inv) ≫ Functor.homF f = (i.inv ≫ Functor.homF f) ≫ i.inv := by\n        simpa [assoc] using this\n      have : j.inv ≫ Functor.homF f = Functor.homF f ≫ i.inv := by\n        -- cancel i.inv on the left using hi.1 : i.inv ≫ η.arrow X = 𝟙\n        calc\n          j.inv ≫ Functor.homF f\n              = (Category.id _) ≫ (j.inv ≫ Functor.homF f) := by simp [Category.comp, Category.id]\n          _   = ((i.inv ≫ η.arrow X) ) ≫ (j.inv ≫ Functor.homF f) := by simpa [hi.1]\n          _   = i.inv ≫ (η.arrow X ≫ (j.inv ≫ Functor.homF f)) := by rw [assoc]\n          _   = i.inv ≫ ((η.arrow X ≫ Functor.homF f) ≫ i.inv) := by\n                -- use naturality then hj.1 : η.arrow Y ≫ j.inv = 𝟙\n                have : η.arrow X ≫ Functor.homF f = Functor.homF f ≫ η.arrow Y := by\n                  simpa [Category.comp] using (hn)\n                -- rewrite\n                -- ηX ≫ Gf = Ff ≫ ηY, but here Functor.homF f is shared; rely on simp/assoc\n                -- Note: hn already is arrow X ≫ G.homF f = F.homF f ≫ arrow Y,\n                -- and here both functors are those in the structure, so Functor.homF is ok.\n                -- We now append ≫ j.inv and use hj.1.\n                calc\n                  η.arrow X ≫ (j.inv ≫ Functor.homF f)\n                      = (η.arrow X ≫ j.inv) ≫ Functor.homF f := by rw [assoc]\n                  _   = (η.arrow X ≫ j.inv) ≫ Functor.homF f := rfl\n                  _   = ((η.arrow X ≫ Functor.homF f) ≫ j.inv) := by rw [assoc]\n                  _   = ((Functor.homF f ≫ η.arrow Y) ≫ j.inv) := by simpa [assoc] using congrArg (fun t => t) this\n                  _   = Functor.homF f ≫ ((η.arrow Y) ≫ j.inv) := by rw [assoc]\n                  _   = Functor.homF f ≫ Category.id _ := by simpa [hj.1]\n                  _   = Functor.homF f := by simp [Category.comp, Category.id]\n          _   = i.inv ≫ (Functor.homF f ≫ i.inv) := by rw [assoc]\n          _   = (i.inv ≫ Functor.homF f) ≫ i.inv := by rw [assoc]\n          _   = Functor.homF f ≫ i.inv := by\n                -- cancel i.inv on the right using hi.2 : η.arrow X ≫ i.inv = 𝟙\n                -- here we use hi.2 indirectly: (i.inv ≫ Functor.homF f) = Functor.homF f ≫ i.inv follows from associativity already in previous line\n                -- simplify\n                simpa [Category.comp, Category.id, assoc] using rfl\n      exact this\n    simpa [NatIso_inverse, NaturalTransformation, Category.comp, assoc] using hn'",
      "\n    have hx := h X\n    have hy := h Y\n    rw [iso_iff_isIso] at hx hy\n    choose i hi using hx\n    choose j hj using hy\n    have hi2 : η.arrow X ≫ i.inv = D.id (F.F X) := by\n      simpa [hi.hom] using i.inv_hom_id\n    have hj2 : η.arrow Y ≫ j.inv = D.id (F.F Y) := by\n      simpa [hj.hom] using j.inv_hom_id\n    have hi3 : i.inv ≫ η.arrow X = D.id (G.F X) := by\n      simpa [hi.hom] using i.hom_inv_id\n    have hj3 : j.inv ≫ η.arrow Y = D.id (G.F Y) := by\n      simpa [hj.hom] using j.hom_inv_id\n    have nat := η.naturality (X := X) (Y := Y) f\n    have : i.inv ≫ G.homF f = F.homF f ≫ j.inv := by\n      calc\n        i.inv ≫ G.homF f\n            = (i.inv ≫ G.homF f) ≫ η.arrow Y ≫ j.inv := by\n                rw [assoc, assoc, hj2]\n                simp [Category.id_comp]\n        _   = i.inv ≫ (G.homF f ≫ η.arrow Y) ≫ j.inv := by\n                simp [assoc]\n        _   = i.inv ≫ (η.arrow X ≫ F.homF f) ≫ j.inv := by\n                simp [nat, assoc]\n        _   = (i.inv ≫ η.arrow X) ≫ F.homF f ≫ j.inv := by\n                simp [assoc]\n        _   = F.homF f ≫ j.inv := by\n                rw [hi3]\n                simp [Category.id_comp, assoc]\n    simpa [arrow, hi, hj, Hom_c_?, Function.comp_apply, assoc] using this",
      "\n    funext g\n    have hx := h X\n    have hy := h Y\n    rw [iso_iff_isIso] at hx\n    rw [iso_iff_isIso] at hy\n    rcases hx with ⟨iX, hiX⟩\n    rcases hy with ⟨iY, hiY⟩\n    have hη := η.naturality (X := X) (Y := Y) f\n    -- cancel using the inverse data coming from `hiX` and `hiY`\n    -- `hiX` and `hiY` give the isomorphism data for `η.arrow _`\n    -- use associativity plus the triangle equalities\n    have leftInvX : (iX.inv ≫ η.arrow X) = D.id := by\n      simpa [iso_iff_isIso] using (And.left hiX)\n    have rightInvY : (η.arrow Y ≫ iY.inv) = D.id := by\n      simpa [iso_iff_isIso] using (And.right hiY)\n    -- now compute\n    calc\n      (iX.inv ≫ G.homF f) g\n          = (iX.inv ≫ (G.homF f ≫ η.arrow Y) ≫ iY.inv) g := by\n              simp [Category.comp, Function.comp_apply, assoc, rightInvY]\n      _ = (iX.inv ≫ (η.arrow X ≫ F.homF f) ≫ iY.inv) g := by\n              simp [Category.comp, Function.comp_apply, assoc, hη]\n      _ = (F.homF f ≫ iY.inv) g := by\n              simp [Category.comp, Function.comp_apply, assoc, leftInvX]",
