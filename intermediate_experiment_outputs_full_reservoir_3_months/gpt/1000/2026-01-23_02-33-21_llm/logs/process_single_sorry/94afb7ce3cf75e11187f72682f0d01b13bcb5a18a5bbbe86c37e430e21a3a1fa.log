-- exercise 1.4.i
noncomputable def NatIso_inverse {α β : Type*} [C : Category α] [D : Category β]
    {F G : Functor α β} (η : NaturalTransformation F G) (h : IsNatIso η) :
    NaturalTransformation G F where
  arrow X := by
    have := h X
    rw [iso_iff_isIso] at this
    choose f hf using this
    exact f.inv

  naturality {X Y} f := by
    funext g
    have hx := h X
    have hy := h Y
    rw [iso_iff_isIso] at hx hy
    choose i hi using hx
    choose j hj using hy
    have hi1 : i.inv ≫ η.arrow X = D.id _ := by
      exact hi.2.2
    have hj1 : η.arrow Y ≫ j.inv = D.id _ := by
      exact hj.2.1
    calc
      i.inv ≫ (G.homF f g)
          = (i.inv ≫ (η.arrow X ≫ (G.homF f g))) := by
              simpa [hi1, D.id_comp]
      _   = i.inv ≫ ((F.homF f (η.arrow Y g)) ≫ j.inv) := by
              simp [η.naturality f, assoc]
      _   = (F.homF f (j.inv g)) := by
              simp [assoc, hj1]
