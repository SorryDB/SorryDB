import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem mathd_numbertheory_13 (u v : ℕ) (S : Set ℕ)
  (h₀ : ∀ n : ℕ, n ∈ S ↔ 0 < n ∧ 14 * n % 100 = 46) (h₁ : IsLeast S u)
  (h₂ : IsLeast (S \ {u}) v) : (u + v : ℚ) / 2 = 64 := by
  have huS : u ∈ S := h₁.1
  have hvS' : v ∈ S \ {u} := h₂.1
  have hvS : v ∈ S := hvS'.1
  have hu_pos : 0 < u := (h₀ u).1 huS |>.1
  have hv_pos : 0 < v := (h₀ v).1 hvS |>.1
  have hu_mod : 14 * u % 100 = 46 := (h₀ u).1 huS |>.2
  have hv_mod : 14 * v % 100 = 46 := (h₀ v).1 hvS |>.2

  have hmod_eq : (14 * (u % 100)) % 100 = 46 := by
    simpa [Nat.mul_mod, Nat.mod_mod] using hu_mod
  have hu_cases : u % 100 = 39 ∨ u % 100 = 89 := by
    have : u % 100 ∈ ({39, 89} : Set ℕ) := by
      decide
    have hfin : (14 * (u % 100)) % 100 = 46 := hmod_eq
    revert hfin
    decide
  have hv_cases : v % 100 = 39 ∨ v % 100 = 89 := by
    have hfin : (14 * (v % 100)) % 100 = 46 := by
      simpa [Nat.mul_mod, Nat.mod_mod] using hv_mod
    revert hfin
    decide

  have hu_eq : u = 39 := by
    have : u ≤ 39 := by
      have h39S : 39 ∈ S := by
        have : 0 < (39 : ℕ) ∧ 14 * 39 % 100 = 46 := by decide
        exact (h₀ 39).2 this
      exact h₁.2 h39S
    have hu39 : 39 ≤ u := by
      have hu0 : u ≠ 0 := Nat.ne_of_gt hu_pos
      exact Nat.succ_le_iff.1 (Nat.pos_of_ne_zero hu0)
    exact le_antisymm this hu39
  have hv_eq : v = 89 := by
    have hv_ne : v ≠ u := by
      exact (by
        intro h
        have : v ∈ ({u} : Set ℕ) := by simpa [Set.mem_singleton_iff, h]
        exact hvS'.2 this)
    have h89S' : 89 ∈ S \ {u} := by
      have h89S : 89 ∈ S := by
        have : 0 < (89 : ℕ) ∧ 14 * 89 % 100 = 46 := by decide
        exact (h₀ 89).2 this
      refine ⟨h89S, ?_⟩
      intro hmem
      have : 89 = u := by simpa [Set.mem_singleton_iff] using hmem
      have : u = 39 := hu_eq
      have : (89 : ℕ) = 39 := by simpa [this] using this
      decide
    have hv_le : v ≤ 89 := h₂.2 h89S'
    have hv_ge : 89 ≤ v := by
      have hv0 : v ≠ 0 := Nat.ne_of_gt hv_pos
      exact Nat.succ_le_iff.1 (Nat.pos_of_ne_zero hv0)
    exact le_antisymm hv_le hv_ge

  subst hu_eq
  subst hv_eq
  norm_num
