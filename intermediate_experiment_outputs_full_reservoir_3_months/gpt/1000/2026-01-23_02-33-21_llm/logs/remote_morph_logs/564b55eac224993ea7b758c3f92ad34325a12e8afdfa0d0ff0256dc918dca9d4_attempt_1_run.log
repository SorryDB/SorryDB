open scoped HermitianMat in
theorem LemmaS2liminf {Оө3 : Prob} {Оө4 : в„қвүҘ0} (hОө4 : 0 < Оө4)
  {d : в„• вҶ’ Type*} [вҲҖ n, Fintype (d n)] [вҲҖ n, DecidableEq (d n)] (ПҒ : (n : в„•) вҶ’ MState (d n)) (Пғ : (n : в„•) вҶ’ MState (d n))
  {Rinf : в„қвүҘ0} (hRinf : Rinf вүҘ Filter.atTop.liminf (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) / n))
  :
  (Filter.atTop.liminf (fun (n : в„•) вҶҰ {(ПҒ n).M вүҘвӮҡ (Real.exp (n * (Rinf + Оө4))) вҖў (Пғ n).M}.inner (ПҒ n)) вүӨ 1 - Оө3)
  := by
  by_contra h
  push_neg at h
  replace h := Filter.eventually_lt_of_lt_liminf h ?_
  В· replace h := Filter.eventually_atTop.mp h
    obtain вҹЁnвӮҖ, hвҹ© := h
    --Can assume that nвӮҖ is positive. Then we don't have to worry about nonzero values down the line
    wlog hnвӮҖ : 0 < nвӮҖ
    В· exact this hОө4 ПҒ Пғ hRinf 1 (fun b hb вҶҰ h _ <| by omega) zero_lt_one
    let T (n : в„•) := {(ПҒ n).M вүҘвӮҡ (Real.exp (n * (Rinf + Оө4))) вҖў (Пғ n).M}
    have hT : вҲҖ n вүҘ nвӮҖ, (ПҒ n).exp_val (1 - (T n)) вүӨ Оө3 := fun n hn вҶҰ by -- Eq (S23)
      unfold MState.exp_val T
      rw [HermitianMat.inner_left_sub, HermitianMat.inner_one, MState.tr,
        HermitianMat.inner_comm, tsub_le_iff_right, add_comm, вҶҗ tsub_le_iff_right]
      apply le_of_lt
      exact h n hn
    have hОІ : вҲҖ n вүҘ nвӮҖ, ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) вүӨ Real.exp (-n * (Rinf + Оө4)) := fun n hn вҶҰ by -- Eq (S25)
      open HermitianMat in
      calc
        ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) вүӨ (Пғ n).exp_val (T n) := by
          have hОІ' := OptimalHypothesisRate.singleton_le_exp_val (Пғ := Пғ n) (T n) (hT n hn) вҹЁproj_le_nonneg _ _, proj_le_le_one _ _вҹ©
          simp only [Subtype.coe_le_coe.mpr hОІ']
        _ <= (T n).inner (Real.exp (-n * (Rinf + Оө4)) вҖў (ПҒ n).M) := by
          rw [вҶҗ mul_le_mul_iff_rightвӮҖ (Real.exp_pos ((n * (Rinf + Оө4)))), HermitianMat.inner_smul, neg_mul, Real.exp_neg]
          simp only [isUnit_iff_ne_zero, ne_eq, Real.exp_ne_zero, not_false_eq_true,
            IsUnit.mul_inv_cancel_left]
          rw [MState.exp_val, HermitianMat.inner_comm, вҶҗ HermitianMat.inner_smul]
          unfold T
          exact proj_le_inner_le (Real.exp (n * (Rinf + Оө4)) вҖў (Пғ n).M) (ПҒ n).M
        _ <= Real.exp (-n * (Rinf + Оө4)) := by
          simp [HermitianMat.inner_smul]
          rw [mul_comm]
          apply (mul_le_iff_le_one_left (Real.exp_pos (-(n * (Rinf + Оө4))))).mpr
          rw [HermitianMat.inner_comm, вҶҗ MState.exp_val]
          exact MState.exp_val_le_one (proj_le_le_one _ _) (ПҒ n)
    have h' : вҲҖ n вүҘ nвӮҖ, Rinf + Оө4 вүӨ вҖ”log ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) / n:= fun n hn вҶҰ by -- Eq (S26)
      have : 0 < n := by order
      have hn1 : (n : в„қвүҘ0вҲһ) вү  0 := by positivity
      have hn2 : (n : в„қвүҘ0вҲһ) вү  вҠӨ := by finiteness
      have hh : n * (Rinf + Оө4) = ENNReal.ofReal (n * (Rinf + Оө4)) := by
        simp only [Nat.cast_nonneg, ENNReal.ofReal_mul, ENNReal.ofReal_natCast, zero_le_coe,
          ENNReal.ofReal_add, ENNReal.ofReal_coe_nnreal]
      apply (ENNReal.mul_le_mul_left (a := n) (b := Rinf + Оө4) (c := вҖ”log ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) / n) hn1 hn2).mp
      rw [ENNReal.mul_div_cancel hn1 hn2, hh]
      apply Prob.le_negLog_of_le_exp
      rw [вҶҗ neg_mul]
      exact hОІ n hn
    have hf : вҲҖб¶  (n : в„•) in Filter.atTop, Rinf + Оө4 вүӨ вҖ”log ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) / n := by
      rw [Filter.eventually_atTop]
      use nвӮҖ
    replace hf := Filter.le_liminf_of_le ?_ hf
    В· replace hf := le_trans hf hRinf
      replace hf := tsub_eq_zero_iff_le.mpr hf
      simp_all
    apply Filter.IsCobounded.of_frequently_le (u := вҠӨ)
    simp [Filter.frequently_atTop]
    intro n; use n
  apply Filter.isBoundedUnder_of
  use 0; intro n
  rw [HermitianMat.inner_comm, вҶҗ MState.exp_val]
  exact MState.exp_val_nonneg (HermitianMat.proj_le_nonneg (Real.exp (n * (Rinf + Оө4)) вҖў (Пғ n).M) (ПҒ n).M) (ПҒ n)

open scoped HermitianMat in
theorem LemmaS2limsup {Оө3 : Prob} {Оө4 : в„қвүҘ0} (hОө4 : 0 < Оө4)
  {d : в„• вҶ’ Type*} [вҲҖ n, Fintype (d n)] [вҲҖ n, DecidableEq (d n)] (ПҒ : (n : в„•) вҶ’ MState (d n)) (Пғ : (n : в„•) вҶ’ MState (d n))
  {Rsup : в„қвүҘ0} (hRsup : Rsup вүҘ Filter.atTop.limsup (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) / n))
  :
  (Filter.atTop.limsup (fun (n : в„•) вҶҰ {(ПҒ n).M вүҘвӮҡ (Real.exp (n * (Rsup + Оө4))) вҖў (Пғ n).M}.inner (ПҒ n)) вүӨ 1 - Оө3)
  := by
  by_contra h
  push_neg at h
  replace h := Filter.frequently_lt_of_lt_limsup ?_ h
  В· replace h := Filter.frequently_atTop.mp h
    let T (n : в„•) := {(ПҒ n).M вүҘвӮҡ (Real.exp (n * (Rsup + Оө4))) вҖў (Пғ n).M}
    have hT (nвӮҖ) : вҲғ n вүҘ nвӮҖ, (ПҒ n).exp_val (1 - (T n)) вүӨ Оө3 := by -- Eq (S30)
      obtain вҹЁn, hn, hвҹ© := h nвӮҖ
      use n, hn
      unfold MState.exp_val T
      rw [HermitianMat.inner_left_sub, HermitianMat.inner_one, MState.tr,
        HermitianMat.inner_comm, tsub_le_iff_right, add_comm, вҶҗ tsub_le_iff_right]
      apply le_of_lt
      exact h
    have hОІ (nвӮҖ) : вҲғ n вүҘ nвӮҖ, ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) вүӨ Real.exp (-n * (Rsup + Оө4)) := by -- Eq (S32)
      obtain вҹЁn, hn, hTвҹ© := hT nвӮҖ
      use n, hn
      open HermitianMat in
      calc
        ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) вүӨ (Пғ n).exp_val (T n) := by
          have hОІ' := OptimalHypothesisRate.singleton_le_exp_val (Пғ := Пғ n) (T n) hT вҹЁproj_le_nonneg _ _, proj_le_le_one _ _вҹ©
          simp only [Subtype.coe_le_coe.mpr hОІ']
        _ <= (T n).inner (Real.exp (-n * (Rsup + Оө4)) вҖў (ПҒ n).M) := by
          rw [вҶҗ mul_le_mul_iff_rightвӮҖ (Real.exp_pos ((n * (Rsup + Оө4)))), HermitianMat.inner_smul, neg_mul, Real.exp_neg]
          simp only [isUnit_iff_ne_zero, ne_eq, Real.exp_ne_zero, not_false_eq_true,
            IsUnit.mul_inv_cancel_left]
          rw [MState.exp_val, HermitianMat.inner_comm, вҶҗ HermitianMat.inner_smul]
          unfold T
          exact proj_le_inner_le (Real.exp (n * (Rsup + Оө4)) вҖў (Пғ n).M) (ПҒ n).M
        _ <= Real.exp (-n * (Rsup + Оө4)) := by
          simp [HermitianMat.inner_smul]
          rw [mul_comm]
          apply (mul_le_iff_le_one_left (Real.exp_pos (-(n * (Rsup + Оө4))))).mpr
          rw [HermitianMat.inner_comm, вҶҗ MState.exp_val]
          exact (ПҒ n).exp_val_le_one (proj_le_le_one _ _)
    have h' (nвӮҖ) : вҲғ n вүҘ nвӮҖ, Rsup + Оө4 вүӨ вҖ”log ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) / n := by -- Eq (S33)
      obtain вҹЁn, hn, hОІвҹ© := hОІ (nвӮҖ + 1)
      use n, by linarith
      have hn0 : 0 < n := by omega
      have hn1 : (n : в„қвүҘ0вҲһ) вү  0 := by positivity
      have hn2 : (n : в„қвүҘ0вҲһ) вү  вҠӨ := by finiteness
      have hh : n * (Rsup + Оө4) = ENNReal.ofReal (n * (Rsup + Оө4)) := by
        simp [ENNReal.ofReal_add]
      apply (ENNReal.mul_le_mul_left (a := n) (b := Rsup + Оө4) (c := вҖ”log ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) / n) hn1 hn2).mp
      rw [ENNReal.mul_div_cancel hn1 hn2, hh]
      apply Prob.le_negLog_of_le_exp
      rwa [вҶҗ neg_mul]
    have hf : вҲғб¶  (n : в„•) in Filter.atTop, Rsup + Оө4 вүӨ вҖ”log ОІ_ Оө3(ПҒ nвҖ–{Пғ n}) / n := by
      rwa [Filter.frequently_atTop]
    replace hf := Filter.le_limsup_of_frequently_le hf (by isBoundedDefault)
    В· replace hf := le_trans hf hRsup
      replace hf := tsub_eq_zero_iff_le.mpr hf
      simp_all
  apply Filter.atTop.isCoboundedUnder_le_of_le (x := 0)
  intro n
  rw [HermitianMat.inner_comm, вҶҗ MState.exp_val]
  exact MState.exp_val_nonneg (HermitianMat.proj_le_nonneg (Real.exp (n * (Rsup + Оө4)) вҖў (Пғ n).M) (ПҒ n).M) (ПҒ n)

private theorem LemmaS3_helper {Оө : Prob} {d : в„• вҶ’ Type*} [вҲҖ n, Fintype (d n)] [вҲҖ n, DecidableEq (d n)]
  (ПҒ ПғвӮҒ ПғвӮӮ : (n : в„•) вҶ’ MState (d n))
  (f : в„• вҶ’ в„қвүҘ0) (hПғ : вҲҖ (i : в„•), Real.exp (-f i) вҖў (ПғвӮӮ i).M вүӨ (ПғвӮҒ i)) (n : в„•) :
    вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮҒ n}) вүӨ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) + f n := by
  have hвӮҒ (T : HermitianMat (d n) в„Ӯ) (hT : 0 вүӨ T) :
          Real.exp (-f n) * T.inner (ПғвӮӮ n).M вүӨ T.inner (ПғвӮҒ n).M := by
    simpa using HermitianMat.inner_mono hT (hПғ n)
  by_cases hПғвӮӮ : ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) = 0
  В· simp [hПғвӮӮ]
  replace hПғвӮӮ := Prob.zero_lt_coe hПғвӮӮ
  have hПғвӮҒ : (0 : в„қ) < ОІ_ Оө(ПҒ nвҖ–{ПғвӮҒ n}) := by
    refine OptimalHypothesisRate.rate_pos_of_smul_pos hПғвӮӮ (Real.exp_pos (-f n)) ?_
    exact hПғ n --For some reason turning these two lines into one `exact` causes timeouts
  rw [вҶҗ ENNReal.toReal_le_toReal (by finiteness) (by finiteness)]
  rw [ENNReal.toReal_add (by finiteness) (by finiteness)]
  simp only [Prob.negLog_pos_Real, ENNReal.coe_toReal, OptimalHypothesisRate,
    Set.mem_singleton_iff, iSup_iSup_eq_left] at hПғвӮҒ hПғвӮӮ вҠў
  rw [вҶҗ neg_le_neg_iff]
  simp only [neg_add_rev, neg_neg]
  rw [вҶҗ Real.log_exp (-f n), вҶҗ Real.log_mul (by positivity) (by positivity)]
  apply Real.log_le_log (by positivity)
  simp only [Prob.coe_iInf]
  rw [Real.mul_iInf_of_nonneg (by positivity)]
  apply ciInf_mono
  В· use 0
    rintro a вҹЁy, rflвҹ©
    have := (ПғвӮӮ n).exp_val_nonneg y.2.2.1
    positivity
  intro вҹЁx, hxвӮҒ, hxвӮӮ, hxвӮғвҹ©
  simp only [MState.exp_val, вҶҗ HermitianMat.smul_inner]
  exact HermitianMat.inner_mono' hxвӮӮ (hПғ n)

/-- Lemma S3 from the paper. What they denote as ПғвӮҷ and ПғвӮҷ', we denote as ПғвӮҒ and ПғвӮӮ. The `exp(-o(n))`
we express as a function `f : в„• вҶ’ в„қ`, together with the fact that `f` is little-o of `n` (i.e. that
`f =o[.atTop] id`), and then writing `exp(-f)`. We also split LemmaS3 into two parts, the `lim inf` part
and the `lim sup` part. The theorem as written is true for any `f`, but we can restrict to nonnegative
`f` (so, `в„• вҶ’ в„қвүҘ0`) which is easier to work with and more natural in the subsequent proofs. -/
private theorem LemmaS3_inf {Оө : Prob}
    {d : в„• вҶ’ Type*} [вҲҖ n, Fintype (d n)] [вҲҖ n, DecidableEq (d n)]
    (ПҒ ПғвӮҒ ПғвӮӮ : (n : в„•) вҶ’ MState (d n))
    (f : в„• вҶ’ в„қвүҘ0) (hf : (f В· : в„• вҶ’ в„қ) =o[.atTop] (В· : в„• вҶ’ в„қ))
    (hПғ : вҲҖ i, Real.exp (-f i) вҖў (ПғвӮӮ i).M вүӨ ПғвӮҒ i)
    :
    Filter.atTop.liminf (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮҒ n}) / n) вүӨ
      Filter.atTop.liminf (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) / n)
    := by
  --Starting with `helper`, divide by n and take the limits. Since f is o(n),
  --the (f n) / n term will go to zero.
  trans Filter.atTop.liminf fun n вҶҰ (вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) + f n) / n
  В· refine Filter.liminf_le_liminf (.of_forall ?_)
    intro
    grw [LemmaS3_helper _ _ _ _ hПғ]
  В· apply le_of_eq
    simp_rw [ENNReal.add_div]
    apply ENNReal.liminf_add_of_right_tendsto_zero
    convert Asymptotics.IsLittleO.tendsto_div_nhds_zero hf
    rw [вҶҗ ENNReal.tendsto_toReal_iff_of_eventually_ne_top ?_ ENNReal.zero_ne_top]
    В· simp
    В· rw [Filter.eventually_atTop]
      use 1
      finiteness

private theorem LemmaS3_sup {Оө : Prob}
    {d : в„• вҶ’ Type*} [вҲҖ n, Fintype (d n)] [вҲҖ n, DecidableEq (d n)]
    (ПҒ ПғвӮҒ ПғвӮӮ : (n : в„•) вҶ’ MState (d n))
    (f : в„• вҶ’ в„қвүҘ0) (hf : (f В· : в„• вҶ’ в„қ) =o[.atTop] (В· : в„• вҶ’ в„қ))
    (hПғ : вҲҖ i, Real.exp (-f i) вҖў (ПғвӮӮ i).M вүӨ ПғвӮҒ i)
    :
    Filter.atTop.limsup (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮҒ n}) / n) вүӨ
      Filter.atTop.limsup (fun (n : в„•) вҶҰ вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) / n)
    := by
  --Starting with `helper`, divide by n and take the limits. Since f is o(n),
  --the (f n) / n term will go to zero.
  trans Filter.atTop.limsup fun n вҶҰ (вҖ”log ОІ_ Оө(ПҒ nвҖ–{ПғвӮӮ n}) + f n) / n
  В· refine Filter.limsup_le_limsup (.of_forall ?_)
    dsimp
    intro x
    grw [LemmaS3_helper _ _ _ _ hПғ]
  В· apply le_of_eq
    simp_rw [ENNReal.add_div]
    apply ENNReal.limsup_add_of_right_tendsto_zero
    convert Asymptotics.IsLittleO.tendsto_div_nhds_zero hf
    rw [вҶҗ ENNReal.tendsto_toReal_iff_of_eventually_ne_top ?_ ENNReal.zero_ne_top]
    В· simp
    В· rw [Filter.eventually_atTop]
      use 1
      finiteness

-- This is not exactly how R_{1, Оө} is defined in Eq. (17), but it should be equal due to
-- the monotonicity of log and Lemma 3.
private noncomputable def R1 (ПҒ : MState (H i)) (Оө : Prob) : в„қвүҘ0вҲһ :=
  Filter.atTop.liminf fun n вҶҰ вҖ”log ОІ_ Оө(ПҒвҠ—^S[n]вҖ–IsFree) / n

private noncomputable def R2 (ПҒ : MState (H i)) : ((n : в„•) вҶ’ IsFree (i := i ^ n)) вҶ’ в„қвүҘ0вҲһ :=
  fun Пғ вҶҰ Filter.atTop.liminf fun n вҶҰ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ n) / n

open MatrixOrder

open scoped HermitianMat

section proj_le

variable {d : Type*} [Fintype d] [DecidableEq d] (A B : HermitianMat d в„Ӯ)

private lemma commute_aux (n : в„•) {x : в„қ}
  {E в„° Пғ : HermitianMat d в„Ӯ} (hв„°Пғ : Commute в„°.toMat Пғ.toMat)
  (hE : E = 1 - {Real.exp (n * x) вҖў Пғ вүӨвӮҡ в„°})
    : Commute ((1 / n : в„қ) вҖў E).toMat (в„°.log - Пғ.log).toMat := by
  rw [HermitianMat.one_sub_proj_le] at hE
  obtain вҹЁC, вҹЁf, rflвҹ©, вҹЁg, rflвҹ©вҹ© := hв„°Пғ.exists_HermitianMat_cfc
  rw [HermitianMat.log, HermitianMat.log]
  rw [вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_sub]
  rw [HermitianMat.proj_lt_def, вҶҗ HermitianMat.cfc_const_mul] at hE
  rw [вҶҗ HermitianMat.cfc_sub, вҶҗ HermitianMat.cfc_comp] at hE
  subst E
  rw [вҶҗ HermitianMat.cfc_const_mul]
  apply HermitianMat.cfc_self_commute

open HermMul in
private lemma rexp_mul_smul_proj_lt_mul_sub_le_mul_sub {n : в„•} {x : в„қ}
  {E в„° Пғ : HermitianMat d в„Ӯ} (hв„°Пғ : Commute в„°.toMat Пғ.toMat) (hx : 0 < x)
  (hв„° : в„°.toMat.PosSemidef) (hПғ : Пғ.toMat.PosDef)
  (hE : E = 1 - {Real.exp (n * x) вҖў Пғ вүӨвӮҡ в„°})
    : в„°.inner (((1 / n : в„қ) вҖў E) * (в„°.log - Пғ.log)) вүӨ в„°.inner (x вҖў E) := by
  rw [HermitianMat.inner_eq_re_trace, HermitianMat.inner_eq_re_trace]
  rcases n.eq_zero_or_pos with rfl | hn
  В· have hE' : 0 вүӨ E.toMat := by
      rw [hE, HermitianMat.one_sub_proj_le]
      apply HermitianMat.proj_lt_nonneg
    have hв„° : 0 вүӨ в„° := by rwa [HermitianMat.zero_le_iff]
    replace hв„° : 0 вүӨ в„°.inner E := HermitianMat.inner_ge_zero hв„° hE'
    rw [HermMul.mul_eq_symmMul, HermitianMat.symmMul_of_commute]
    В· simp only [HermitianMat.val_eq_coe, CharP.cast_eq_zero, div_zero, zero_smul,
        ZeroMemClass.coe_zero, AddSubgroupClass.coe_sub, zero_mul, mul_zero, Matrix.trace_zero,
        map_zero, selfAdjoint.val_smul, Algebra.mul_smul_comm, trace_smul, Complex.real_smul,
        RCLike.mul_re, RCLike.im_to_complex, Complex.ofReal_im, sub_zero, ge_iff_le]
      rw [вҶҗ HermitianMat.inner_eq_re_trace]
      positivity
    В· simp only [CharP.cast_eq_zero, div_zero, zero_smul, HermitianMat.val_eq_coe,
        ZeroMemClass.coe_zero, AddSubgroupClass.coe_sub, Commute.zero_left, Commute.sub_right]
  rw [HermMul.mul_eq_symmMul, HermitianMat.symmMul_of_commute (commute_aux n hв„°Пғ hE)]
  dsimp
  repeat rw [HermitianMat.val_eq_coe]
  gcongr
  apply Matrix.PosSemidef.trace_mono
  rw [one_div, smul_mul_assoc, mul_smul_comm]
  rw [inv_smul_le_iff_of_pos (mod_cast hn)]
  rw [mul_smul_comm]
  obtain вҹЁC, вҹЁf, hfвҹ©, вҹЁg, hgвҹ©вҹ© := hв„°Пғ.exists_HermitianMat_cfc
  rw [hf, hg] at hE вҠў
  rw [HermitianMat.one_sub_proj_le, HermitianMat.proj_lt_def] at hE
  rw [вҶҗ HermitianMat.cfc_const_mul, вҶҗ HermitianMat.cfc_sub] at hE
  rw [вҶҗ HermitianMat.cfc_comp] at hE
  unfold Function.comp at hE
  dsimp at hE
  rw [HermitianMat.log, HermitianMat.log]
  rw [вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_comp, smul_smul]
  change _ * (E.toMat * HermitianMat.toMat (_ - _)) вүӨ _
  rw [вҶҗ HermitianMat.cfc_sub]
  subst E
  rw [вҶҗ HermitianMat.coe_cfc_mul, вҶҗ HermitianMat.coe_cfc_mul]
  rw [вҶҗ HermitianMat.coe_cfc_mul]
  change _ вүӨ HermitianMat.toMat ((n * x) вҖў C.cfc _)
  rw [вҶҗ HermitianMat.cfc_const_mul]
  change (C.cfc _ : HermitianMat _ _) вүӨ C.cfc _
  rw [вҶҗ sub_nonneg, вҶҗ HermitianMat.cfc_sub, HermitianMat.zero_le_cfc]
  intro i
  simp only [mul_ite, Pi.sub_apply, Pi.mul_apply, ite_mul]
  rw [ite_sub_ite]
  simp only [sub_pos, mul_one, Function.comp_apply, one_mul, mul_zero, zero_mul, sub_self]
  split_ifs with h; swap
  В· rfl
  set fi := f (C.H.eigenvalues i) with hfi
  set gi := g (C.H.eigenvalues i) with hgi
  have hfiвӮҖ : 0 вүӨ fi := by
    rw [hf, вҶҗ HermitianMat.zero_le_iff, HermitianMat.zero_le_cfc] at hв„°
    exact hв„° i
  have hgiвӮҖ : 0 < gi := by
    rw [hg, HermitianMat.cfc_PosDef] at hПғ
    exact hПғ i
  rcases hfiвӮҖ.eq_or_lt with hfiвӮӮ | hfiвӮӮ
  В· simp [вҶҗ hfiвӮӮ]
  В· simp [mul_comm fi]
    suffices Real.log fi < n * x + Real.log gi by
      grw [this]
      simp only [add_sub_cancel_right, le_refl]
    rw [вҶҗ Real.log_exp (n * x), вҶҗ Real.log_mul (by positivity) (by positivity)]
    apply Real.strictMonoOn_log hfiвӮӮ ?_ h
    change 0 < Real.exp (n * x) * gi
    positivity

private lemma rexp_mul_smul_proj_lt_mul_sub_le_mul_sub' {n : в„•} {x : в„қ} {y : в„қ}
  {E в„° Пғ : HermitianMat d в„Ӯ} (hв„°Пғ : Commute в„°.toMat Пғ.toMat)
  (hв„° : в„°.toMat.PosSemidef) (hПғ : Пғ.toMat.PosDef)
  (hE : E = {Real.exp (n * y) вҖў Пғ вүӨвӮҡ в„°} - {Real.exp (n * x) вҖў Пғ вүӨвӮҡ в„°})
    : (1 / n : в„қ) вҖў E.toMat * (в„°.log.toMat - Пғ.log.toMat) вүӨ x вҖў E := by
  --Another version of the above. Once we've proved one it's probably very easy to adapt the
  --code for the other. This doesn't suffer from the zero eigenvalue issue as much.
  rcases n.eq_zero_or_pos with rfl | hn
  В· simp_all
  obtain вҹЁC, вҹЁf, hfвҹ©, вҹЁg, hgвҹ©вҹ© := hв„°Пғ.exists_HermitianMat_cfc
  rw [hf, hg] at hE вҠў
  rw [HermitianMat.proj_le_def, HermitianMat.proj_le_def] at hE
  rw [вҶҗ HermitianMat.cfc_const_mul, вҶҗ HermitianMat.cfc_sub] at hE
  rw [вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_const_mul] at hE
  rw [вҶҗ HermitianMat.cfc_sub, вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_sub] at hE
  subst E
  rw [HermitianMat.log, HermitianMat.log]
  rw [вҶҗ HermitianMat.cfc_comp, вҶҗ HermitianMat.cfc_comp]
  conv =>
    enter [1]
    congr
    В· change HermitianMat.toMat ((1 / (n : в„қ)) вҖў _)
    В· change HermitianMat.toMat (_ - _)
  change _ вүӨ HermitianMat.toMat (x вҖў C.cfc _)
  rw [вҶҗ HermitianMat.cfc_sub, вҶҗ HermitianMat.cfc_const_mul, вҶҗ HermitianMat.coe_cfc_mul]
  rw [вҶҗ HermitianMat.cfc_const_mul, вҶҗ sub_nonneg]
  change 0 вүӨ HermitianMat.toMat (_ - _)
  rw [вҶҗ HermitianMat.cfc_sub]
  change (0 : HermitianMat d в„Ӯ) вүӨ _
  rw [HermitianMat.zero_le_cfc]
  intro i
  simp only [Pi.sub_apply, Function.comp_apply, one_div, Pi.mul_apply]
  set fi := f (C.H.eigenvalues i) with hfi
  set gi := g (C.H.eigenvalues i) with hgi
  have hfiвӮҖ : 0 вүӨ fi := by
    rw [hf, вҶҗ HermitianMat.zero_le_iff, HermitianMat.zero_le_cfc] at hв„°
    exact hв„° i
  have hgiвӮҖ : 0 < gi := by
    rw [hg, HermitianMat.cfc_PosDef] at hПғ
    exact hПғ i
  split_ifs with ha hb hb <;> simp only [вҶҗ hfi, вҶҗ hgi] at ha hb вҠў
  В· simp
  В· simp only [sub_nonneg, not_le, sub_zero, mul_one] at ha hb вҠў
    rw [inv_mul_le_iffвӮҖ (by positivity)]
    rw [вҶҗ Real.exp_le_exp, Real.exp_sub]
    rw [Real.exp_log (lt_of_lt_of_le (by positivity) ha), Real.exp_log hgiвӮҖ]
    rw [div_le_iffвӮҖ hgiвӮҖ]
    exact hb.le
  В· simp only [sub_nonneg, not_le, zero_sub, mul_neg, mul_one, neg_mul, sub_neg_eq_add,
      le_neg_add_iff_add_le, add_zero] at ha hb вҠў
    rw [le_inv_mul_iffвӮҖ (by positivity)]
    rw [вҶҗ Real.exp_le_exp, Real.exp_sub]
    rw [Real.exp_log (lt_of_lt_of_le (by positivity) hb), Real.exp_log hgiвӮҖ]
    rw [le_div_iffвӮҖ hgiвӮҖ]
    exact hb
  В· simp

end proj_le

private lemma f_image_bound (mineig : в„қ) (n : в„•) (h : 0 < mineig) (hn : 0 < n) :
  let c : в„• вҶ’ в„қ := fun n вҶҰ Real.log (1 / mineig) + Real.log 3 / (max n 1);
  let f : в„• вҶ’ в„қ вҶ’ в„қ := fun n lam => вҶ‘вҢҲReal.log lam / c nвҢү * c n;
  let S : Set в„қ := (fun x => Real.exp (f n x)) '' Set.Icc ((mineig ^ n) / 3) 1;
  (h_le_f : вҲҖ (n : в„•) (lam : в„қ), Real.log lam вүӨ f n lam) вҶ’
  (h_f_le : вҲҖ (n : в„•) (lam : в„қ), f n lam < Real.log lam + c n) вҶ’
    S.ncard вүӨ n + 1 вҲ§ S.Finite := by
  --Thanks Aristotle. TODO Cleanup
  -- To show that $S$ is finite, we need to show that the function $f$ maps the interval into a finite set.
  have h_finite : Set.Finite (Set.image (fun x => Real.exp (вҢҲReal.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1))вҢү * (Real.log (1 / mineig) + Real.log 3 / (max n 1)))) (Set.Icc (mineig^n / 3) 1)) := by
    -- Since the interval [mineig^n / 3, 1] is bounded and the function Real.log is continuous, the values of Real.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1)) will also be bounded. The ceiling function will then map these values to a finite set of integers.
    have h_bounded : вҲғ m M : в„Ө, вҲҖ x вҲҲ Set.Icc (mineig^n / 3) 1, m вүӨ вҢҲReal.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1))вҢү вҲ§ вҢҲReal.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1))вҢү вүӨ M := by
      have h_bounded : вҲғ m M : в„қ, вҲҖ x вҲҲ Set.Icc (mineig^n / 3) 1, m вүӨ Real.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1)) вҲ§ Real.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1)) вүӨ M := by
        -- Since the interval [mineig^n / 3, 1] is closed and bounded, and the function Real.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1)) is continuous on this interval, it must attain a maximum and minimum value on this interval.
        have h_cont : ContinuousOn (fun x => Real.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1))) (Set.Icc (mineig^n / 3) 1) := by
          -- Since Real.log x is continuous on the interval (0, вҲһ) and the denominator is a non-zero constant, the function Real.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1)) is continuous on the interval [mineig^n / 3, 1].
          have h_cont : ContinuousOn Real.log (Set.Icc (mineig^n / 3) 1) := by
            exact continuousOn_of_forall_continuousAt fun x hx => Real.continuousAt_log ( by linarith [ hx.1, pow_pos h n ] );
          exact h_cont.div_const _;
        exact вҹЁ ( InfSet.sInf <| ( fun x => Real.log x / ( Real.log ( 1 / mineig ) + Real.log 3 / ( max n 1 ) ) ) '' Set.Icc ( mineig ^ n / 3 ) 1 ), ( SupSet.sSup <| ( fun x => Real.log x / ( Real.log ( 1 / mineig ) + Real.log 3 / ( max n 1 ) ) ) '' Set.Icc ( mineig ^ n / 3 ) 1 ), fun x hx => вҹЁ ( csInf_le <| IsCompact.bddBelow <| isCompact_Icc.image_of_continuousOn h_cont ) <| Set.mem_image_of_mem _ hx, ( le_csSup <| IsCompact.bddAbove <| isCompact_Icc.image_of_continuousOn h_cont ) <| Set.mem_image_of_mem _ hx вҹ© вҹ©;
      obtain вҹЁ m, M, hM вҹ© := h_bounded
      exact вҹЁ вҢҲmвҢү, вҢҲMвҢү, fun x hx => вҹЁ Int.ceil_mono <| hM x hx |>.1, Int.ceil_mono <| hM x hx |>.2 вҹ© вҹ© ;
    cases' h_bounded with m h_bounded
    cases' h_bounded with M h_bounded
    refine Set.Finite.subset ( Set.toFinite ( Finset.image ( fun i : в„Ө => Real.exp ( ( i : в„қ ) * ( Real.log ( 1 / mineig ) + Real.log 3 / ( max n 1 : в„қ ) ) ) ) ( Finset.Icc m M ) ) ) ?_
    intro
    intro a_1
    simp_all only [Set.mem_Icc, one_div, Real.log_inv, Nat.cast_max, Nat.cast_one, and_imp, Set.mem_image,
      Finset.coe_image, Finset.coe_Icc]
    obtain вҹЁw, вҹЁleft, rflвҹ©вҹ© := a_1
    simp_all only [Real.exp_eq_exp, mul_eq_mul_right_iff, Int.cast_inj]
    apply Exists.intro
    В· apply And.intro
      on_goal 2 => {
        apply Or.inl
        rfl
      }
      В· simp_all only [and_self]
  intro c f S h_le_f h_f_le
  simp_all only [one_div, Real.log_inv, Nat.cast_max, Nat.cast_one, and_true, f, c, S]
  -- Since the interval [(n * log(mineig) - log(3)) / c(n), 0 / c(n)] has length (log(3) - n * log(mineig)) / c(n), and c(n) is positive, the number of distinct integer values that вҢҲ(log lam) / c(n)вҢү can take is at most n + 1.
  have h_card : Set.ncard (Set.image (fun x => Real.exp (вҢҲReal.log x / (Real.log (1 / mineig) + Real.log 3 / (max n 1))вҢү * (Real.log (1 / mineig) + Real.log 3 / (max n 1)))) (Set.Icc (mineig^n / 3) 1)) вүӨ Set.ncard (Set.image (fun k : в„Ө => Real.exp (k * (Real.log (1 / mineig) + Real.log 3 / (max n 1)))) (Set.Icc (вҢҲ(n * Real.log mineig - Real.log 3) / (Real.log (1 / mineig) + Real.log 3 / (max n 1))вҢү) 0)) := by
    refine Set.ncard_le_ncard ?_;
    intro
    intro a_1
    simp_all only [one_div, Real.log_inv, Nat.cast_max, Nat.cast_one, Set.mem_image, Set.mem_Icc]
    obtain вҹЁw, вҹЁвҹЁleft, right_1вҹ©, rflвҹ©вҹ© := a_1
    simp_all only [Real.exp_eq_exp, mul_eq_mul_right_iff, Int.cast_inj]
    refine' вҹЁ_, вҹЁ_, _ вҹ©, Or.inl rflвҹ©;
    В· gcongr;
      В· have := h_f_le n 1 ; norm_num at this ; linarith [ Real.log_le_sub_one_of_pos h ];
      В· -- Taking the logarithm of both sides of the inequality $mineig^n / 3 \leq w$, we get $n \log(mineig) - \log(3) \leq \log(w)$.
        have h_log : Real.log (mineig^n / 3) вүӨ Real.log w := by
          exact Real.log_le_log ( by positivity ) left;
        rwa [ Real.log_div ( by positivity ) ( by positivity ), Real.log_pow ] at h_log;
    В· refine' Int.ceil_le.mpr _;
      rw [ div_le_iffвӮҖ ]
      В· simp_all only [Int.cast_zero, zero_mul]
        exact Real.log_nonpos ( by linarith [ pow_pos h n ] ) right_1;
      В· have := h_f_le n 1
        simp_all only [Real.log_one, zero_div, Int.ceil_zero, Int.cast_zero, zero_mul, zero_add, lt_neg_add_iff_add_lt, add_zero]
  have h_card_image : Set.ncard (Set.image (fun k : в„Ө => Real.exp (k * (Real.log (1 / mineig) + Real.log 3 / (max n 1)))) (Set.Icc (вҢҲ(n * Real.log mineig - Real.log 3) / (Real.log (1 / mineig) + Real.log 3 / (max n 1))вҢү) 0)) вүӨ Set.ncard (Set.Icc (вҢҲ(n * Real.log mineig - Real.log 3) / (Real.log (1 / mineig) + Real.log 3 / (max n 1))вҢү) 0) := by
    apply Set.ncard_image_le;
    exact Set.finite_Icc _ _;
  simp_all +decide [ Set.ncard_eq_toFinset_card' ];
  refine le_trans h_card <| le_trans h_card_image ?_;
  rcases n with _ | n
  В· simp at hn
  simp_all only [lt_add_iff_pos_left, add_pos_iff, zero_lt_one, or_true, Nat.cast_add, Nat.cast_one,
    le_add_iff_nonneg_left, Nat.cast_nonneg, sup_of_le_left, Int.toNat_le, tsub_le_iff_right]
  specialize h_f_le ( n + 1 ) 1;
  simp_all only [Real.log_one, Nat.cast_add, Nat.cast_one, le_add_iff_nonneg_left, Nat.cast_nonneg, sup_of_le_left,
    zero_div, Int.ceil_zero, Int.cast_zero, zero_mul, zero_add, lt_neg_add_iff_add_lt, add_zero]
  apply Int.le_of_lt_add_one
  rw [ вҶҗ @Int.cast_lt в„қ ]
  push_cast
  nlinarith [ Int.le_ceil ( ( ( n + 1 ) * Real.log mineig - Real.log 3 ) / ( -Real.log mineig + Real.log 3 / ( n + 1 ) ) ),
    mul_div_cancelвӮҖ ( ( n + 1 ) * Real.log mineig - Real.log 3 ) ( show ( -Real.log mineig + Real.log 3 / ( n + 1 ) ) вү  0 by
      nlinarith [ Real.log_pos ( show ( 3 : в„қ ) > 1 by norm_num ), mul_div_cancelвӮҖ ( Real.log 3 ) ( show ( n + 1 : в„қ ) вү  0 by positivity ) ] ),
        Real.log_pos ( show ( 3 : в„қ ) > 1 by norm_num ), mul_div_cancelвӮҖ ( Real.log 3 ) ( show ( n + 1 : в„қ ) вү  0 by positivity ) ]

private lemma c'_bounded {mineig : в„қ} {Оө2 : в„• вҶ’ в„қвүҘ0}
    (hОө2 : вҲҖ (n : в„•), Оө2 n < 1) (o : в„қ) :
  let c : в„• вҶ’ в„қ := fun n => Real.log (1 / mineig) + Real.log 3 / вҶ‘(max n 1);
  let c' : в„қ вҶ’ в„• вҶ’ в„қ := fun  Оө2 n вҶҰ (c n + (c n) / n) вҠ” (o + Оө2);
  (вҲҖ (n : в„•), 0 < c n) вҶ’
    вҲғ (C : NNReal), вҲҖб¶  (n : в„•) in Filter.atTop, c' (вҶ‘(Оө2 n)) n вүӨ вҶ‘C := by
  have h_bound : вҲғ C : в„қ, вҲҖб¶  n in Filter.atTop, Real.log (1 / mineig) + Real.log 3 / (Max.max n 1) + (Real.log (1 / mineig) + Real.log 3 / (Max.max n 1)) / n вүӨ C := by
    have h_bound : Filter.Tendsto (fun n => Real.log (1 / mineig) + Real.log 3 / (Max.max n 1) + (Real.log (1 / mineig) + Real.log 3 / (Max.max n 1)) / n) Filter.atTop (nhds (Real.log (1 / mineig) + Real.log 3 / 0 + (Real.log (1 / mineig) + Real.log 3 / 0) / 0)) := by
      exact le_trans ( Filter.Tendsto.add ( tendsto_const_nhds.add <| Filter.Tendsto.mul tendsto_const_nhds <| Filter.Tendsto.inv_tendsto_atTop <| Filter.tendsto_atTop_atTop.mpr fun x => вҹЁ x + 1, fun y hy => le_max_of_le_left <| by linarith вҹ© ) <| Filter.Tendsto.mul ( tendsto_const_nhds.add <| Filter.Tendsto.mul tendsto_const_nhds <| Filter.Tendsto.inv_tendsto_atTop <| Filter.tendsto_atTop_atTop.mpr fun x => вҹЁ x + 1, fun y hy => le_max_of_le_left <| by linarith вҹ© ) <| tendsto_inv_atTop_zero ) <| by norm_num;
    exact вҹЁ _, h_bound.eventually ( ge_mem_nhds <| lt_add_one _ ) вҹ©;
  intro c c' a
  simp_all only [one_div, Real.log_inv, Filter.eventually_atTop, ge_iff_le, Nat.cast_max, Nat.cast_one,
    lt_neg_add_iff_add_lt, add_zero, sup_le_iff, c, c']
  obtain вҹЁw, вҹЁw_1, hвҹ©вҹ© := h_bound
  use вҢҲwвҢүвӮҠ + вҢҲoвҢүвӮҠ + 1, вҢҲw_1вҢүвӮҠ
  intro n hn
  constructor
  В· norm_num
    linarith [ Nat.le_ceil w, h n ( Nat.le_of_ceil_le hn ) ]
  В· norm_num
    linarith [ Nat.le_ceil o, show ( Оө2 n : в„қ ) вүӨ 1 by exact_mod_cast le_of_lt ( hОө2 n ) ]

noncomputable section sigmas

/- Define the different (sequences of) states needed in the construction and prove their basic
properties. -/

section defs
section ПғвӮҒ_c_and_f --Stuff that has variable (i) explicit because it only depends on that

variable (i)

private def ПғвӮҒ : MState (H i) :=
  Classical.choose (FreeStateTheory.free_fullRank i)

private def ПғвӮҒ_mineig := вЁ… k, (ПғвӮҒ i).M.H.eigenvalues k

/-- The sequence c_n given in (S44). In order to handle when c = 0, we've replaced the
 (Real.log 3) / n term with (Real.log 3) / (max n 1). -/
private def ПғвӮҒ_c (n : в„•) : в„қ :=
  Real.log (1 / ПғвӮҒ_mineig i) + (Real.log 3) / (max n 1)

/-- The function f_n(О») in (S45). -/
private def f_map (n : в„•) (lam : в„қ) : в„қ :=
  вҢҲReal.log lam / ПғвӮҒ_c i nвҢү * ПғвӮҒ_c i n

end ПғвӮҒ_c_and_f
--From here on, sequences generally depend on other parameters + states.

variable (ПҒ : MState (H i)) (Оө : Prob) (m : в„•) (Пғ : (n : в„•) вҶ’ IsFree (i := i ^ n))

private def В«ПғМғВ» :
    (n : в„•) вҶ’ MState (H (i ^ n)) :=
  fun n вҶҰ Lemma6_Пғn m (ПғвӮҒ i) (Пғ m) n

private def В«ПғвӢҶВ» : (n : в„•) вҶ’ MState (H (i ^ n)) :=
  haveI Пғ_max_exists (n : в„•) := IsCompact_IsFree.exists_isMaxOn Set.Nonempty.of_subtype
      (f := fun Пғ вҶҰ ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{Пғ})) (hf := Continuous.continuousOn (by fun_prop))
  fun n вҶҰ Classical.choose (Пғ_max_exists n)

--TODO: would be nice to write a `Mixable` thing for mixing `k` things according to a distribution,
-- in this case `Distribution.uniform (Fin 3)`.
private def Пғ' : (n : в„•) вҶ’ MState (H (i ^ n)) :=
  fun n вҶҰ вҹЁ2/3, by norm_numвҹ© [вҹЁ1/2, by norm_numвҹ© [В«ПғМғВ» m Пғ n вҶ” В«ПғвӢҶВ» ПҒ Оө n] вҶ” (ПғвӮҒ i)вҠ—^S[n]]

private def Пғ''_unnormalized : (n : в„•) вҶ’ HermitianMat (H (i ^ n)) в„Ӯ :=
  fun n вҶҰ (Пғ' ПҒ Оө m Пғ n).M.cfc fun e вҶҰ Real.exp (f_map i n e)

end defs

section proofs
/- Prove relevant properties about their positivity, trace, etc. -/
section ПғвӮҒ_c_and_f

variable (i)

private theorem ПғвӮҒ_pos : (ПғвӮҒ i).m.PosDef :=
  (FreeStateTheory.free_fullRank i).choose_spec.left

private theorem ПғвӮҒ_isFree : IsFree (ПғвӮҒ i) :=
  (FreeStateTheory.free_fullRank i).choose_spec.right

private theorem mineig_pos : 0 < ПғвӮҒ_mineig i := by
  --because ПғвӮҒ is PosDef, all eigenvalues are positive, so their minimum is positive
  obtain вҹЁi_min, hi_minвҹ© := exists_eq_ciInf_of_finite (f := (HermitianMat.H (ПғвӮҒ i).M).eigenvalues)
  unfold ПғвӮҒ_mineig
  rw [вҶҗ hi_min]
  exact (ПғвӮҒ_pos i).eigenvalues_pos i_min

private theorem mineig_le_one : ПғвӮҒ_mineig i вүӨ 1 := by
    --all eigenvalues of a state are at most 1. (We might not actually need this fact.)
    obtain вҹЁi_min, hi_minвҹ© := exists_eq_ciInf_of_finite (f := (HermitianMat.H (ПғвӮҒ i).M).eigenvalues)
    unfold ПғвӮҒ_mineig
    rw [вҶҗ hi_min]
    exact (ПғвӮҒ i).eigenvalue_le_one i_min

private theorem ПғвӮҒ_c_pos (n) : 0 < ПғвӮҒ_c i n := by
  rw [ПғвӮҒ_c]
  have h_min_pos := mineig_pos i
  have h_min_le_one := mineig_le_one i
  have hвӮҒ : 0 вүӨ Real.log (1 / ПғвӮҒ_mineig i) := by bound
  positivity

private theorem ПғвӮҒ_c_div_lim : Filter.atTop.Tendsto (fun n вҶҰ (ПғвӮҒ_c i n) / n) (рқ“қ 0) := by
  unfold ПғвӮҒ_c
  have h_const : Filter.atTop.Tendsto (fun n : в„• вҶҰ Real.log (1 / ПғвӮҒ_mineig i) / n) (рқ“қ 0) :=
      tendsto_const_nhds.div_atTop tendsto_natCast_atTop_atTop;
  -- We can split the limit into two parts: the constant term and the term involving log(3).
  have h_div : Filter.atTop.Tendsto (fun n : в„• вҶҰ Real.log 3 / (max n 1 * n)) (рқ“қ 0) :=
    tendsto_const_nhds.div_atTop <| Filter.tendsto_atTop_mono (fun n вҶҰ by
      norm_cast; nlinarith [le_max_left n 1, le_max_right n 1]) tendsto_natCast_atTop_atTop
  convert h_const.add h_div using 2 <;> ring

private lemma ПғвӮҒ_c_identity {n : в„•} (hn : 0 < n) :
    Real.exp (-ПғвӮҒ_c i n) * (1 / 3) * ПғвӮҒ_mineig i ^ n =
    Real.exp (-n * (ПғвӮҒ_c i n + ПғвӮҒ_c i n / n)) := by
  have h (x : в„қ) : n * (x / n) = x := by field_simp
  simp only [ПғвӮҒ_c]
  simp only [neg_mul, show ((max n 1 : в„•) : в„қ) = n from mod_cast (max_eq_left hn)]
  simp only [Real.exp_add, mul_add, neg_add_rev, mul_assoc, h]
  simp [Real.exp_neg, Real.exp_log, Real.exp_log (mineig_pos i), Real.exp_nat_mul]

theorem ПғвӮҒ_c_littleO : (fun n : в„• вҶҰ ПғвӮҒ_c i n + Real.log 3) =o[Filter.atTop] (fun x вҶҰ (x : в„қ)) := by
  apply Asymptotics.IsLittleO.add
  В· rw [Asymptotics.isLittleO_iff_tendsto']
    В· exact ПғвӮҒ_c_div_lim i
    simp only [Nat.cast_eq_zero, Filter.eventually_atTop]
    use 1
    grind
  В· --This `(fun x => Real.log 3) =o[Filter.atTop] fun x => x` really should be its own fact, TODO
    refine Asymptotics.isLittleO_const_left.2 <| Or.inr ?_
    convert tendsto_natCast_atTop_atTop (R := в„қ)
    ext
    simp

/-- (S46), part 1 -/
private theorem log_le_f (n : в„•) (lam : в„қ) : Real.log lam вүӨ f_map i n lam :=
  calc
  _ вүӨ (вҢҲReal.log lam / (ПғвӮҒ_c i n)вҢү) * ПғвӮҒ_c i n := by
    rw [вҶҗ mul_inv_le_iffвӮҖ (ПғвӮҒ_c_pos i n)]
    apply Int.le_ceil _
  _ = _ := by
    rfl

/-- (S46), part 2 -/
private theorem f_le_log (n : в„•) (lam : в„қ) : f_map i n lam < Real.log lam + ПғвӮҒ_c i n :=
  calc
  _ = вҢҲReal.log lam / ПғвӮҒ_c i nвҢү * ПғвӮҒ_c i n := by
    rfl
  _ < (Real.log lam / ПғвӮҒ_c i n + 1) * ПғвӮҒ_c i n := by
    gcongr
    В· exact ПғвӮҒ_c_pos i n
    В· exact Int.ceil_lt_add_one _
  _ вүӨ _ := by
    have := ПғвӮҒ_c_pos i n
    field_simp
    rfl

private theorem le_exp_f (n : в„•) (x : в„қ) (hx : 0 < x) : x вүӨ Real.exp (f_map i n x) := by
  convert Real.exp_monotone (log_le_f i n x)
  rw [Real.exp_log hx]

private theorem exp_f_le (n : в„•) (x : в„қ) (hx : 0 < x) : Real.exp (f_map i n x) < Real.exp (ПғвӮҒ_c i n) * x := by
  convert Real.exp_strictMono (f_le_log i n x) using 1
  rw [Real.exp_add (Real.log x), Real.exp_log hx, mul_comm]

end ПғвӮҒ_c_and_f

variable (ПҒ : MState (H i)) (Оө : Prob)
variable (m : в„•) (Пғ : (n : в„•) вҶ’ IsFree (i := i ^ n)) (n : в„•)

private theorem В«ПғМғ_isFreeВ» : IsFree (В«ПғМғВ» m Пғ n) :=
  Lemma6_Пғn_IsFree (ПғвӮҒ_isFree i) (fun n вҶҰ (Пғ n).2) m n

private theorem В«ПғвӢҶ_freeВ» : IsFree (В«ПғвӢҶВ» ПҒ Оө n) :=
  haveI Пғ_max_exists (n : в„•) := IsCompact_IsFree.exists_isMaxOn Set.Nonempty.of_subtype
      (f := fun Пғ вҶҰ ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{Пғ})) (hf := Continuous.continuousOn (by fun_prop))
  (Пғ_max_exists n).choose_spec.left

private theorem В«ПғвӢҶ_maxВ» :
    IsMaxOn (fun Пғ вҶҰ ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{Пғ})) IsFree (В«ПғвӢҶВ» ПҒ Оө n) :=
  haveI Пғ_max_exists (n : в„•) := IsCompact_IsFree.exists_isMaxOn Set.Nonempty.of_subtype
      (f := fun Пғ вҶҰ ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{Пғ})) (hf := Continuous.continuousOn (by fun_prop))
  (Пғ_max_exists n).choose_spec.right

private theorem Пғ'_free : IsFree (Пғ' ПҒ Оө m Пғ n) := by
  -- by convexity of `IsFree` and that the three constituents are free
  unfold Пғ'
  apply IsFree.mix
  В· exact (В«ПғМғ_isFreeВ» m Пғ n).mix (В«ПғвӢҶ_freeВ» ПҒ Оө n) _
  В· exact (ПғвӮҒ_isFree i).npow n

private theorem Пғ'_posdef : (Пғ' ПҒ Оө m Пғ n).m.PosDef := by
  --because ПғвӮҒ is PosDef, so is ПғвӮҒвҠ—^[n], and so is any convex mixture.
  unfold Пғ'
  apply MState.PosDef_mix_of_ne_one
  В· apply UnitalPretheory.PosDef.npow (ПғвӮҒ_pos i)
  В· norm_num [вҶҗ Prob.ne_iff]

private theorem hПғ'n_eq_sum_third : (Пғ' ПҒ Оө m Пғ n).M =
    (1 / 3 : в„қ) вҖў (В«ПғМғВ» m Пғ n) + (1 / 3 : в„қ) вҖў (В«ПғвӢҶВ» ПҒ Оө n) + (1 / 3 : в„қ) вҖў ((ПғвӮҒ i)вҠ—^S[n]) := by
  unfold Пғ'
  change _ вҖў _ + _ = _
  conv =>
    enter [1, 1, 2]
    change _ + _
  dsimp [Mixable.to_U]
  norm_num only [one_div, Prob.coe_one_minus, smul_add, smul_smul]

private theorem hПғвӮҒ_le_Пғ' : (1 / 3 : в„қ) вҖў ((ПғвӮҒ i)вҠ—^S[n]).M вүӨ (Пғ' ПҒ Оө m Пғ n).M := by
    rw [hПғ'n_eq_sum_third]
    apply le_add_of_nonneg_left
    have := (В«ПғвӢҶВ» ПҒ Оө n).zero_le
    have := (В«ПғМғВ» m Пғ n).zero_le
    positivity

private theorem Пғ''_unnormalized_PosDef : Matrix.PosDef (Пғ''_unnormalized ПҒ Оө m Пғ n).val := by
  dsimp [Пғ''_unnormalized]
  rw [HermitianMat.cfc_PosDef]
  intro
  positivity

private theorem Пғ''_tr_bounds : 1 вүӨ (Пғ''_unnormalized ПҒ Оө m Пғ n).trace вҲ§
    (Пғ''_unnormalized ПҒ Оө m Пғ n).trace < Real.exp (ПғвӮҒ_c i n) := by
  have hПғ' := (Пғ' ПҒ Оө m Пғ n).tr
  constructor
  В· rw [вҶҗ HermitianMat.sum_eigenvalues_eq_trace] at hПғ' вҠў
    rw [вҶҗ hПғ']
    obtain вҹЁe, heвҹ© := (Пғ' ПҒ Оө m Пғ n).M.cfc_eigenvalues fun e вҶҰ Real.exp (f_map i n e)
    rw [he]
    simp only [HermitianMat.val_eq_coe, MState.toMat_M, Function.comp_apply]
    rw [Equiv.sum_comp e (fun k вҶҰ Real.exp (f_map i n (Matrix.IsHermitian.eigenvalues _ k)))]
    gcongr
    apply le_exp_f i n _
    exact (Пғ'_posdef ПҒ Оө m Пғ n).eigenvalues_pos _
  В· rw [вҶҗ HermitianMat.sum_eigenvalues_eq_trace] at hПғ' вҠў
    rw [вҶҗ mul_one (Real.exp (ПғвӮҒ_c i n)), вҶҗ hПғ', Finset.mul_sum]
    obtain вҹЁe, heвҹ© := (Пғ' ПҒ Оө m Пғ n).M.cfc_eigenvalues fun e вҶҰ Real.exp (f_map i n e)
    rw [he]; clear he
    dsimp
    rw [Equiv.sum_comp e (fun k вҶҰ Real.exp (f_map i n (Matrix.IsHermitian.eigenvalues _ k)))]
    gcongr
    В· exact Finset.univ_nonempty
    В· apply exp_f_le i n _
      exact (Пғ'_posdef ПҒ Оө m Пғ n).eigenvalues_pos _

end proofs

variable (ПҒ : MState (H i)) (Оө : Prob)
variable (m : в„•) (Пғ : (n : в„•) вҶ’ IsFree (i := i ^ n)) (n : в„•)

--We're now finally ready to define the main sequence with the properties we want, Пғ''.
--This is the normalized version of Пғ''_unnormalized, which gives a state because that sequence is
-- already PosDef
private def Пғ'' : (n : в„•) вҶ’ MState (H (i ^ n)) := fun n вҶҰ {
  --TODO make this its own definition: Normalizing a matrix to give a tr-1 op.
  M := (Пғ''_unnormalized ПҒ Оө m Пғ n).traceвҒ»В№ вҖў (Пғ''_unnormalized ПҒ Оө m Пғ n)
  zero_le := by
    have h1 : 0 < (Пғ''_unnormalized ПҒ Оө m Пғ n).trace :=
      zero_lt_one.trans_le (Пғ''_tr_bounds ПҒ Оө m Пғ n).left
    have h2 : 0 < Пғ''_unnormalized ПҒ Оө m Пғ n :=
      (Пғ''_unnormalized_PosDef ПҒ Оө m Пғ n).zero_lt
    positivity
  tr := by
    rw [HermitianMat.trace_smul]
    apply inv_mul_cancelвӮҖ
    exact (zero_lt_one.trans_le (Пғ''_tr_bounds ПҒ Оө m Пғ n).left).ne'
}

private lemma Пғ''_posdef n : (Пғ'' ПҒ Оө m Пғ n).M.toMat.PosDef := by
  apply (Пғ''_unnormalized_PosDef ПҒ Оө m Пғ n).smul
  have := (Пғ''_tr_bounds ПҒ Оө m Пғ n).left
  positivity

private lemma Пғ'_le_Пғ'' (n) : Real.exp (-ПғвӮҒ_c i n) вҖў (Пғ' ПҒ Оө m Пғ n).M вүӨ Пғ'' ПҒ Оө m Пғ n := by
  dsimp [Пғ'']
  set x := (Пғ''_unnormalized ПҒ Оө m Пғ n).trace
  dsimp [Пғ''_unnormalized]
  rw [вҶҗ HermitianMat.cfc_const_mul_id, вҶҗ HermitianMat.cfc_const_mul_id,
    вҶҗ HermitianMat.cfc_comp]
  rw [вҶҗ sub_nonneg, вҶҗ HermitianMat.cfc_sub, HermitianMat.zero_le_cfc]
  intro k
  set y := (Пғ' ПҒ Оө m Пғ n).M.H.eigenvalues k
  have hy : 0 < y := (Пғ'_posdef ПҒ Оө m Пғ n).eigenvalues_pos k
  dsimp only [Pi.sub_apply, Function.comp_apply]
  have : 0 < x := zero_lt_one.trans_le (Пғ''_tr_bounds ПҒ Оө m Пғ n).left
  grw [вҶҗ le_exp_f i n y hy]
  rw [вҶҗ sub_mul]
  suffices 0 вүӨ xвҒ»В№ - Real.exp (-ПғвӮҒ_c i n) by positivity
  rw [sub_nonneg, вҶҗ inv_le_invвӮҖ]
  В· simpa [вҶҗ Real.exp_neg] using (Пғ''_tr_bounds ПҒ Оө m Пғ n).right.le
  В· positivity
  В· positivity

private lemma Пғ''_le_Пғ' (n) : Пғ'' ПҒ Оө m Пғ n вүӨ Real.exp (ПғвӮҒ_c i n) вҖў (Пғ' ПҒ Оө m Пғ n).M := by
    dsimp [Пғ'']
    set x := (Пғ''_unnormalized ПҒ Оө m Пғ n).trace
    dsimp [Пғ''_unnormalized]
    rw [вҶҗ HermitianMat.cfc_const_mul_id, вҶҗ HermitianMat.cfc_const_mul_id,
      вҶҗ HermitianMat.cfc_comp]
    rw [вҶҗ sub_nonneg, вҶҗ HermitianMat.cfc_sub, HermitianMat.zero_le_cfc]
    intro k
    set y := (Пғ' ПҒ Оө m Пғ n).M.H.eigenvalues k
    have hy : 0 < y := (Пғ'_posdef ПҒ Оө m Пғ n).eigenvalues_pos k
    dsimp only [Pi.sub_apply, Function.comp_apply]
    grw [вҶҗ exp_f_le i n y hy]
    rw [вҶҗ one_sub_mul]
    suffices 0 вүӨ 1 - xвҒ»В№ by positivity
    simpa using inv_le_one_of_one_leвӮҖ (Пғ''_tr_bounds ПҒ Оө m Пғ n).left

private theorem В«Пғ''_ge_ПғвӢҶВ» n : Пғ'' ПҒ Оө m Пғ n вүҘ (Real.exp (-ПғвӮҒ_c i n) / 3) вҖў (В«ПғвӢҶВ» ПҒ Оө n).M := by
    grw [ge_iff_le, вҶҗ Пғ'_le_Пғ'', div_eq_mul_inv, вҶҗ smul_smul, вҶҗ one_div]
    rw [smul_le_smul_iff_of_pos_left (by positivity), hПғ'n_eq_sum_third]
    apply le_add_of_le_of_nonneg
    В· apply le_add_of_nonneg_left
      have := (В«ПғМғВ» m Пғ n).zero_le
      positivity
    В· have := ((ПғвӮҒ i)вҠ—^S[n]).zero_le
      positivity

private theorem В«Пғ''_ge_ПғМғВ» n : Пғ'' ПҒ Оө m Пғ n вүҘ (Real.exp (-ПғвӮҒ_c i n) / 3) вҖў (В«ПғМғВ» m Пғ n).M := by
    grw [ge_iff_le, вҶҗ Пғ'_le_Пғ'', div_eq_mul_inv, вҶҗ smul_smul, вҶҗ one_div]
    rw [smul_le_smul_iff_of_pos_left (by positivity), hПғ'n_eq_sum_third]
    apply le_add_of_le_of_nonneg
    В· apply le_add_of_nonneg_right
      have := (В«ПғвӢҶВ» ПҒ Оө n).zero_le
      positivity
    В· have := ((ПғвӮҒ i)вҠ—^S[n]).zero_le
      positivity

private theorem Пғ''_ge_ПғвӮҒ n : Пғ'' ПҒ Оө m Пғ n вүҘ (Real.exp (-ПғвӮҒ_c i n) / 3) вҖў ((ПғвӮҒ i)вҠ—^S[n]).M := by
    grw [ge_iff_le, вҶҗ Пғ'_le_Пғ'', div_eq_mul_inv, вҶҗ smul_smul, вҶҗ one_div]
    rw [smul_le_smul_iff_of_pos_left (by positivity)]
    exact hПғвӮҒ_le_Пғ' ПҒ Оө m Пғ n

private abbrev ОөвӮҖ_func (Оө' : Prob) : в„қ := (R2 ПҒ Пғ - R1 ПҒ Оө).toReal * (Оө - Оө') / (1 - Оө)

end sigmas

set_option maxHeartbeats 600000 in
private theorem EquationS62
    (ПҒ : MState (H i)) (Пғ : (n : в„•) вҶ’ IsFree (i := i ^ n))
    {Оө Оө' : Prob} (hОө'вӮҒ : 0 < Оө') (hОө'вӮӮ : Оө' < Оө) (hОө : Оө < 1)
    (hR1R2 : R1 ПҒ Оө < R2 ПҒ Пғ) (hR1 : R1 ПҒ Оө вү  вҠӨ) (hR2 : R2 ПҒ Пғ вү  вҠӨ)
    (hОөвӮҖ : 0 < ОөвӮҖ_func ПҒ Оө Пғ Оө') (hОөвӮҖ' : (R1 ПҒ Оө).toReal вүӨ (R2 ПҒ Пғ).toReal + ОөвӮҖ_func ПҒ Оө Пғ Оө')
    (m : в„•) (hm : m вүҘ 1 вҲ§ рқҗғ(ПҒвҠ—^S[m]вҖ–вҶ‘(Пғ m)) / вҶ‘m < R2 ПҒ Пғ + (.ofNNReal вҹЁОөвӮҖ_func ПҒ Оө Пғ Оө', hОөвӮҖ.leвҹ©))
    :
  let в„° n := pinching_map (Пғ'' ПҒ Оө m Пғ n);
    Filter.atTop.liminf (fun n вҶҰ рқҗғ(в„° n (ПҒвҠ—^S[n])вҖ–Пғ'' ПҒ Оө m Пғ n) / n) - R1 ПҒ Оө вүӨ
      вҶ‘(1 - Оө') * (R2 ПҒ Пғ - R1 ПҒ Оө) := by
  intro в„°
  set ОөвӮҖ := ОөвӮҖ_func ПҒ Оө Пғ Оө'

  have hliminf_le : Filter.atTop.liminf (fun n вҶҰ
      вҖ”log ОІ_ Оө(в„° n (ПҒвҠ—^S[n])вҖ–{Пғ'' ПҒ Оө m Пғ n}) / n) вүӨ (R1 ПҒ Оө).toNNReal := by --(S66)
    rw [ENNReal.coe_toNNReal hR1R2.ne_top]
    unfold R1
    calc _ = Filter.atTop.liminf (fun n => вҖ”log
      ОІ_ Оө(в„° n (ПҒвҠ—^S[n])вҖ–{(pinching_map (Пғ'' ПҒ Оө m Пғ n)) (Пғ'' ПҒ Оө m Пғ n)}) / вҶ‘n) := by conv =>
        enter [1, 1, n]
        rw [вҶҗ pinching_self (Пғ'' ПҒ Оө m Пғ n)]
    _ вүӨ Filter.atTop.liminf (fun n => вҖ”log ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{(Пғ'' ПҒ Оө m Пғ n)}) / вҶ‘n) := by --(S67)
      refine Filter.liminf_le_liminf ?_
      apply Filter.Eventually.of_forall
      intro
      apply ENNReal.div_le_div_right
      apply Prob.negLog_Antitone
      apply OptimalHypothesisRate.optimalHypothesisRate_antitone
    _ вүӨ Filter.atTop.liminf (fun n => вҖ”log ОІ_ Оө(ПҒвҠ—^S[n]вҖ–{(В«ПғвӢҶВ» ПҒ Оө n)}) / вҶ‘n) := by --(S68)
      apply LemmaS3_inf _ _ _
        (f := fun n вҶҰ вҹЁПғвӮҒ_c i n + Real.log 3, add_nonneg (ПғвӮҒ_c_pos i n).le (Real.log_nonneg (by norm_num))вҹ©)
        (ПғвӮҒ_c_littleO i)
      intro n
      rw [coe_mk, neg_add', Real.exp_sub, Real.exp_log (by positivity)]
      exact В«Пғ''_ge_ПғвӢҶВ» ПҒ Оө m Пғ n
    _ = _ := by --(S69)
      congr! 4 with n
      rw [вҶҗ OptimalHypothesisRate.Lemma3 Оө IsCompact_IsFree free_convex]
      rw [вҶҗ iSup_subtype'']
      exact ((В«ПғвӢҶ_maxВ» ПҒ Оө n).iSup_eq (В«ПғвӢҶ_freeВ» ПҒ Оө n)).symm

  have hlimsup_le (Оө1 : Prob) (hОө1 : 0 < (Оө1 : в„қ) вҲ§ (Оө1 : в„қ) < 1) :
      Filter.atTop.limsup (fun n вҶҰ вҖ”log ОІ_ (1-Оө1)(в„° n (ПҒвҠ—^S[n])вҖ–{Пғ'' ПҒ Оө m Пғ n}) / n) вүӨ
        ((R2 ПҒ Пғ).toNNReal + вҹЁОөвӮҖ, hОөвӮҖ.leвҹ© : NNReal) := by --(S70)
    rw [ENNReal.coe_add, ENNReal.coe_toNNReal hR2]
    unfold R2
    calc _ = Filter.atTop.limsup (fun n => вҖ”log
      ОІ_ (1-Оө1)(в„° n (ПҒвҠ—^S[n])вҖ–{(pinching_map (Пғ'' ПҒ Оө m Пғ n)) (Пғ'' ПҒ Оө m Пғ n)}) / вҶ‘n) := by conv =>
        enter [1, 1, n]
        rw [вҶҗ pinching_self (Пғ'' ПҒ Оө m Пғ n)]
    _ вүӨ Filter.atTop.limsup (fun n => вҖ”log ОІ_ (1-Оө1)(ПҒвҠ—^S[n]вҖ–{(Пғ'' ПҒ Оө m Пғ n)}) / вҶ‘n) := by
      refine Filter.limsup_le_limsup ?_
      apply Filter.Eventually.of_forall
      intro
      apply ENNReal.div_le_div_right
      apply Prob.negLog_Antitone
      apply OptimalHypothesisRate.optimalHypothesisRate_antitone
    _ вүӨ Filter.atTop.limsup (fun n => вҖ”log ОІ_ (1-Оө1)(ПҒвҠ—^S[n]вҖ–{(В«ПғМғВ» m Пғ n)}) / вҶ‘n) := by --(S71)
      apply LemmaS3_sup _ _ _
        (f := fun n вҶҰ вҹЁПғвӮҒ_c i n + Real.log 3, add_nonneg (ПғвӮҒ_c_pos i n).le (Real.log_nonneg (by norm_num))вҹ©)
        (ПғвӮҒ_c_littleO i)
      intro n
      rw [coe_mk, neg_add', Real.exp_sub, Real.exp_log (by positivity)]
      exact В«Пғ''_ge_ПғМғВ» ПҒ Оө m Пғ n
    _ вүӨ _ := by --(S72)
      apply Lemma6
      В· exact hm.left
      В· apply ПғвӮҒ_pos
      В· change (_ : в„қ) < _
        simpa using hОө1.left
    _ вүӨ _ := hm.right.le --(S73)

  let P1 Оө2 n := {(в„° n (ПҒвҠ—^S[n])).M вүҘвӮҡ (Real.exp (вҶ‘n*((R1 ПҒ Оө).toReal + Оө2))) вҖў (Пғ'' ПҒ Оө m Пғ n).M}
  let P2 Оө2 n := {(в„° n (ПҒвҠ—^S[n])).M вүҘвӮҡ (Real.exp (вҶ‘n*((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2))) вҖў (Пғ'' ПҒ Оө m Пғ n).M}

  have hPcomm Оө2 n : Commute (P1 Оө2 n).toMat (P2 Оө2 n).toMat := by
    simp only [HermitianMat.proj_le, HermitianMat.cfc_toMat, P1, P2]
    apply IsSelfAdjoint.commute_cfc
    В· apply HermitianMat.H
    symm
    apply IsSelfAdjoint.commute_cfc
    В· apply HermitianMat.H
    simp only [AddSubgroupClass.coe_sub, MState.toMat_M, selfAdjoint.val_smul]
    suffices h : Commute (в„° n (ПҒвҠ—^S[n])).m (Пғ'' ПҒ Оө m Пғ n).m by
      apply Commute.sub_left
      В· exact (Commute.refl _).sub_right (h.smul_right _)
      В· exact (h.symm.sub_right ((Commute.refl _).smul_right _)).smul_left _
    exact pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)

  let E1 := 1 - P1 -- (S78)
  let E2 := P1 - P2 -- (S79)
  let E3 := P2 -- (S80)

  have Esum : E1 + E2 + E3 = 1 := by
    unfold E1 E2 E3
    abel

  have hE1proj Оө2 n : E1 Оө2 n = {(в„° n (ПҒвҠ—^S[n])).M <вӮҡ (Real.exp (вҶ‘n*((R1 ПҒ Оө).toReal + Оө2))) вҖў (Пғ'' ПҒ Оө m Пғ n).M} := by
    dsimp [E1, P1]
    rw [sub_eq_iff_eq_add]
    simp only [HermitianMat.proj_le_add_lt]

  have hE2leProj Оө2 n : E2 Оө2 n вүӨ {(в„° n (ПҒвҠ—^S[n])).M <вӮҡ (Real.exp (вҶ‘n*((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2))) вҖў (Пғ'' ПҒ Оө m Пғ n).M} := by
    dsimp [E2, P1, P2]
    rw [sub_le_iff_le_add]
    simp only [HermitianMat.proj_le_add_lt]
    exact HermitianMat.proj_le_le_one _ _

  -- (S83)
  let c' Оө2 n := (ПғвӮҒ_c i n + (ПғвӮҒ_c i n) / n) вҠ” ((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2)

  have hc' (Оө2 : в„• вҶ’ в„қвүҘ0) (hОө2 : вҲҖ n, Оө2 n < 1) :
      вҲғ (C : в„қвүҘ0), вҲҖб¶  (n : в„•) in Filter.atTop, c' (Оө2 n) n вүӨ C := by
    apply c'_bounded hОө2 _ (ПғвӮҒ_c_pos i)

  -- (S84)
  have hПғ'' Оө2 n : Real.exp (-n * c' Оө2 n) вҖў 1 вүӨ (Пғ'' ПҒ Оө m Пғ n).M := by
    rcases n.eq_zero_or_pos with rfl | hn
    В· have _ : Unique (H (i ^ 0)) := by
        rw [spacePow_zero]
        infer_instance
      apply le_of_eq
      simp [Unique.eq_default (Пғ'' ПҒ Оө m Пғ 0)]
    calc
      (Пғ'' ПҒ Оө m Пғ n).M вүҘ Real.exp (- ПғвӮҒ_c i n) вҖў (Пғ' ПҒ Оө m Пғ n).M := Пғ'_le_Пғ'' ПҒ Оө m Пғ n
      _ вүҘ (Real.exp (- ПғвӮҒ_c i n) * (1 / 3)) вҖў ((ПғвӮҒ i)вҠ—^S[n]).M := by
        grw [вҶҗ hПғвӮҒ_le_Пғ' ПҒ Оө m Пғ n, smul_smul]
      _ вүҘ (Real.exp (- ПғвӮҒ_c i n) * (1 / 3)) вҖў ((iInf ((ПғвӮҒ i)вҠ—^S[n]).M.H.eigenvalues) вҖў 1) := by
        apply smul_le_smul_of_nonneg_left
        В· exact ((ПғвӮҒ i)вҠ—^S[n]).M.H.iInf_eigenvalues_smul_one_le
        В· positivity
      _ = (Real.exp (- ПғвӮҒ_c i n) * (1 / 3) * (ПғвӮҒ_mineig i)^n) вҖў 1 := by
        dsimp [ПғвӮҒ_mineig, iInf]
        rw [вҶҗ Matrix.IsHermitian.spectrum_real_eq_range_eigenvalues]
        rw [вҶҗ Matrix.IsHermitian.spectrum_real_eq_range_eigenvalues]
        rw [MState.toMat_M, sInf_spectrum_spacePow (ПғвӮҒ i) n, MState.toMat_M, smul_smul]
      _ = Real.exp (- n * (ПғвӮҒ_c i n + (ПғвӮҒ_c i n) / n)) вҖў 1 := by
        rw [ПғвӮҒ_c_identity i hn]
      _ вүҘ Real.exp (-n * c' Оө2 n) вҖў 1 := by
        apply smul_le_smul_of_nonneg_right
        В· apply Real.exp_le_exp_of_le
          simp only [neg_mul, neg_le_neg_iff]
          apply mul_le_mul_of_nonneg_left _ (by positivity)
          dsimp [c']
          exact le_sup_left
        В· exact zero_le_one

  have hE3commв„° Оө2 n : Commute (E3 Оө2 n).toMat ((в„° n (ПҒвҠ—^S[n])).M.log.toMat) := by
    unfold E3 P2
    rw [HermitianMat.proj_le_def]
    apply HermitianMat.cfc_commute
    apply Commute.sub_left
    В· simp only [HermitianMat.val_eq_coe, MState.toMat_M, Commute.refl]
    В· apply Commute.smul_left
      apply Commute.symm
      exact pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)

  -- Leo: I think there's a typo in the third eq. of this step: ПҒ should be ПҒ^n.
  -- The next set of equations also have ПҒ_n instead of ПҒ^n.
  -- (S88)
  have hDleq Оө2 n (hОө2 : 0 < Оө2) (hn : 0 < n) : (рқҗғ(в„° n (ПҒвҠ—^S[n])вҖ–Пғ'' ПҒ Оө m Пғ n) / n : в„қвүҘ0вҲһ) вүӨ  ((R1 ПҒ Оө) + .ofReal Оө2) +
        .ofReal ((P1 Оө2 n).inner (в„° n (ПҒвҠ—^S[n]))) * ((R2 ПҒ Пғ + .ofReal ОөвӮҖ + .ofReal Оө2) - (R1 ПҒ Оө + .ofReal Оө2)) +
        .ofReal ((P2 Оө2 n).inner (в„° n (ПҒвҠ—^S[n]))) * (.ofReal (c' Оө2 n) - (R2 ПҒ Пғ + .ofReal ОөвӮҖ + .ofReal Оө2)) := by
    -- see (S81) for comments on why that statement had to be changed
    -- (S85)
    -- (first inequality should have $\sigma_n''$ instead of
    -- $\tilde{\sigma}_n''$; corrected in v4, where $\tilde{\sigma}_n'$ takes
    -- the place of $\sigma_n''$) in this and other steps
    have hE3leq : (1/n : в„қ) вҖў (E3 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' ПҒ Оө m Пғ n).M.log.toMat) вүӨ (c' Оө2 n) вҖў (E3 Оө2 n).toMat := by
      calc
      (1/n : в„қ) вҖў (E3 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' ПҒ Оө m Пғ n).M.log.toMat) вүӨ (1/n : в„қ) вҖў (E3 Оө2 n).toMat * (- (Пғ'' ПҒ Оө m Пғ n).M.log.toMat) := by
        -- first inequality of (S85)
        have hв„°ПҒlognonpos : 0 вүӨ -(в„° n (ПҒвҠ—^S[n])).M.log.toMat := by
          -- log of state is non-positive
          simp only [HermitianMat.log]
          rw [вҶҗ AddSubgroup.coe_neg _, вҶҗ HermitianMat.cfc_neg (в„° n (ПҒвҠ—^S[n])).M]
          change (HermitianMat.toMat 0) вүӨ _
          rw [Subtype.coe_le_coe, HermitianMat.zero_le_cfc (в„° n (ПҒвҠ—^S[n])).M (-Real.log)]
          intro i
          simp
          apply Real.log_nonpos
          В· apply MState.eigenvalue_nonneg _
          В· apply MState.eigenvalue_le_one
        rw [вҶҗ sub_nonneg, вҶҗ mul_sub_left_distrib]
        conv =>
          rhs
          congr; rfl
          rw [вҶҗ sub_add (-(Пғ'' ПҒ Оө m Пғ n).M.log.toMat) ((в„° n (ПҒвҠ—^S[n])).M.log.toMat) ((Пғ'' ПҒ Оө m Пғ n).M.log.toMat)]
          rw [add_comm_sub]
          rw [вҶҗ add_sub_assoc]
          simp [sub_self (Пғ'' ПҒ Оө m Пғ n).M.log.toMat]
        simp only [Algebra.smul_mul_assoc, one_div]
        have hE3в„°nonneg : 0 вүӨ (E3 Оө2 n).toMat * -(в„° n (ПҒвҠ—^S[n])).M.log.toMat := by
          apply Commute.mul_nonneg _ hв„°ПҒlognonpos (Commute.neg_right (hE3commв„° Оө2 n))
          apply HermitianMat.proj_le_nonneg
        apply smul_nonneg (inv_nonneg_of_nonneg (Nat.cast_nonneg' n)) hE3в„°nonneg
      _ вүӨ (1/n : в„қ) вҖў (E3 Оө2 n).toMat * (- (Real.exp (-n * c' Оө2 n) вҖў (1 : HermitianMat (H (i ^ n)) в„Ӯ)).log.toMat) := by
        -- intermediate step in 2nd ineq of S85
        simp only [mul_neg, neg_mul, neg_le_neg_iff]
        have h1logleq : (Real.exp (-(n * c' Оө2 n)) вҖў 1 : HermitianMat (H (i ^ n)) в„Ӯ).log.toMat вүӨ ((Пғ'' ПҒ Оө m Пғ n).M).log.toMat := by
          -- apply hПғ'' Оө2 n to log by monotonicity
          rw [Subtype.coe_le_coe]
          have h_comm : Commute ((Real.exp _ вҖў 1 : HermitianMat _ в„Ӯ).toMat) _ :=
            Commute.smul_left (Commute.one_left (Пғ'' ПҒ Оө m Пғ n).M.toMat) (Real.exp (-(n * c' Оө2 n)))
          exact HermitianMat.log_le_log_of_commute h_comm (by simpa using hПғ'' Оө2 n)
            (Matrix.PosDef.smul Matrix.PosDef.one (Real.exp_pos (-(n * c' Оө2 n))))
        rw [вҶҗ sub_nonneg] at h1logleq
        rw [вҶҗ sub_nonneg, вҶҗ mul_sub_left_distrib]
        simp only [one_div, Algebra.smul_mul_assoc]
        have hE3commlog : Commute (E3 Оө2 n).toMat ((Пғ'' ПҒ Оө m Пғ n).M.log.toMat - (Real.exp (-(n * c' Оө2 n)) вҖў 1 : HermitianMat _ в„Ӯ).log.toMat) := by
          -- projector commutes with logs
          apply Commute.sub_right
          В· -- prove Commute (E3 _) (Пғ'' _).log
            unfold E3 P2
            rw [HermitianMat.proj_le_def]
            apply HermitianMat.cfc_commute
            apply Commute.sub_left
            В· exact pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)
            В· apply Commute.smul_left
              В· rfl
          В· -- prove `Commute (E3 _) (_ 1).log`
            conv_rhs =>
              simp only [
                HermitianMat.log_smul (1 : HermitianMat _ в„Ӯ) (Real.exp _),
                Real.log_exp, neg_smul, HermitianMat.log_one,
                add_zero, NegMemClass.coe_neg,
                HermitianMat.val_eq_coe, selfAdjoint.val_smul,
                selfAdjoint.val_one
                ]
            simp only [Commute.neg_right_iff, Commute.smul_right (Commute.one_right _) _]
        apply smul_nonneg (inv_nonneg_of_nonneg (Nat.cast_nonneg' n))
        apply Commute.mul_nonneg _ h1logleq hE3commlog
        apply HermitianMat.proj_le_nonneg
      _ = (c' Оө2 n) вҖў (E3 Оө2 n).toMat := by
        simp [HermitianMat.log_smul, smul_smul]
        field_simp
    --Linearly combine S81, S82, S85:
    calc
      рқҗғ(в„° n (ПҒвҠ—^S[n])вҖ–Пғ'' ПҒ Оө m Пғ n) / (n : ENNReal) вүӨ
        ENNReal.ofReal (((в„° n (ПҒвҠ—^S[n])).M.inner (((R1 ПҒ Оө).toReal + Оө2) вҖў (E1 Оө2 n)))
        + ((в„° n (ПҒвҠ—^S[n])).M.inner (((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2) вҖў (E2 Оө2 n)))
        + ((в„° n (ПҒвҠ—^S[n])).M.inner ((c' Оө2 n) вҖў (E3 Оө2 n))))
      := by
        -- (S86) to (S88)
        unfold qRelativeEnt SandwichedRelRentropy
        simp only [вҶ“reduceIte]
        have Пғ''_pd := Пғ''_posdef ПҒ Оө m Пғ
        simp only [MState.toMat_M] at Пғ''_pd
        have hker : (Пғ'' ПҒ Оө m Пғ n).M.ker вүӨ (в„° n (ПҒвҠ—^S[n])).M.ker :=
          ker_le_ker_pinching_of_PosDef (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n) (Пғ''_pd n)
        simp only [hker, if_true]
        have hMulOne : (в„° n (ПҒвҠ—^S[n])).M.toMat * (1 : Matrix (H (i ^ n)) (H (i ^ n)) в„Ӯ) = (в„° n (ПҒвҠ—^S[n])).M.toMat := Matrix.mul_one (в„° n (ПҒвҠ—^S[n])).M.toMat
        have hOneMulCommute : Commute (1 : HermitianMat _ в„Ӯ).toMat (в„° n (ПҒвҠ—^S[n])).M.toMat := Commute.one_left (в„° n (ПҒвҠ—^S[n])).M.toMat
        have hOneIsOne : вҲҖ (Оө : в„қ) (n : в„•), (1 : в„қ вҶ’ в„• вҶ’ HermitianMat (H (i ^ n)) в„Ӯ) Оө n = (1 : HermitianMat (H (i ^ n)) в„Ӯ) := by
          intro Оө n; rfl
        /- convert Esum to the HermitianMat equality at point (Оө2, n) -/
        have Esum' : (E1 Оө2 n).toMat + (E2 Оө2 n).toMat + (E3 Оө2 n).toMat = 1 :=
          congrArg HermitianMat.toMat (congrFun (congrFun Esum Оө2) n)
        conv =>
          enter [1, 1, 1, 1]
          unfold HermitianMat.inner
          rw [вҶҗ hMulOne]
          rw [вҶҗ Esum']
        -- (S87)
        /- Use hE1leq, hE2leq, hE3leq -/

        /-the next two `have`s are duplicates-/
        -- TODO streamline what's below
        /-it should transform a HermitianMat inequality into a reals inequality with HermitianMat.inner_mono,
        the difficulty here is that inner_mono relies on the entries being HermitianMat, but the inequalities are expressed as matrices-/
        have hE2comm : Commute (E2 Оө2 n).toMat (((в„° n (ПҒвҠ—^S[n])).M.log - (Пғ'' ПҒ Оө m Пғ n).M.log).toMat) := by
        -- TODO this needs to be extracted from here, it's badly redundant
          apply Commute.sub_right
          В· unfold E2 P1 P2
            simp
            rw [HermitianMat.proj_le_def, HermitianMat.proj_le_def]
            apply Commute.sub_left
            В· apply HermitianMat.cfc_commute
              apply Commute.sub_left
              В· rfl
              В· simp
                apply Commute.symm
                exact pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)
            В· apply HermitianMat.cfc_commute
              apply Commute.sub_left
              В· rfl
              В· simp
                apply Commute.symm
                exact pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)
          В· unfold E2 P1 P2
            simp
            rw [HermitianMat.proj_le_def, HermitianMat.proj_le_def]
            apply Commute.sub_left
            В· apply HermitianMat.cfc_commute
              apply Commute.sub_left
              В· exact pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)
              В· simp
            В· apply HermitianMat.cfc_commute
              apply Commute.sub_left
              В· exact pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)
              В· simp
        have hE2leqInner : (n : в„қ)вҒ»В№ * ((в„° n (ПҒвҠ—^S[n])).M.toMat * (E2 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' ПҒ Оө m Пғ n).M.log.toMat)).trace.re вүӨ ((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2) * ((в„° n (ПҒвҠ—^S[n])).M).inner (E2 Оө2 n) := by
          open HermMul in
          -- (S82) -- see (S81) for comments
          have hE2leq Оө2 (n : в„•) (hОө2 : 0 < Оө2) : (1/n : в„қ) вҖў (E2 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' ПҒ Оө m Пғ n).M.log.toMat) вүӨ ((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2) вҖў (E2 Оө2 n).toMat := by
            refine rexp_mul_smul_proj_lt_mul_sub_le_mul_sub'
              (pinching_commutes (ПҒвҠ—^S[n]) (Пғ'' ПҒ Оө m Пғ n)) ?_ (Пғ''_posdef ПҒ Оө m Пғ n) rfl
            rw [вҶҗ HermitianMat.zero_le_iff]
            apply MState.zero_le
          simp at hE2leq
          rw [вҶҗ Complex.re_ofReal_mul (вҶ‘n)вҒ»В№, вҶҗ smul_eq_mul, вҶҗ Matrix.trace_smul]
          rw [вҶҗ RCLike.re_to_complex]
          conv =>
            enter [1, 2]
            rw [mul_assoc]
            enter [1, 2, 2]
            norm_cast
            rw [вҶҗ HermitianMat.symmMul_of_commute hE2comm]
          conv at hE2leq =>
            enter [Оө2, n, hОө2, 1, 2, 2]
            norm_cast
          specialize hE2leq Оө2 n hОө2
          rw [вҶҗ HermitianMat.symmMul_of_commute hE2comm] at hE2leq
          conv_lhs at hE2leq =>
            change (Complex.ofReal (_ : в„қ)) вҖў _
            rw [HermitianMat.smul_toMat (HermitianMat.symmMul _ _) (n : в„қ)вҒ»В№]
          conv_rhs at hE2leq =>
            change (Complex.ofReal (_ : в„қ)) вҖў _
            rw [HermitianMat.smul_toMat (E2 Оө2 n) _]
          rw [вҶҗ Matrix.mul_smul (в„° n (ПҒвҠ—^S[n])).M.toMat (Complex.ofReal (n : в„қ)вҒ»В№) (HermitianMat.symmMul _ _).toMat]
          simp only [HermitianMat.smul_toMat]
          rw [вҶҗ HermitianMat.inner_eq_re_trace (в„° n (ПҒвҠ—^S[n])).M ((n : в„қ)вҒ»В№ вҖў (HermitianMat.symmMul _ _))]
          rw [вҶҗ HermitianMat.inner_smul]
          exact ((HermitianMat.inner_mono ((в„° n (ПҒвҠ—^S[n]))).zero_le) hE2leq)
        simp at hE3leq
        /-this and the `have` above are duplicates-/
        have hE3comm : Commute (E3 Оө2 n).toMat (((в„° n (ПҒвҠ—^S[n])).M.log - (Пғ'' ПҒ Оө m Пғ n).M.log).toMat) := by
          apply Commute.sub_right
