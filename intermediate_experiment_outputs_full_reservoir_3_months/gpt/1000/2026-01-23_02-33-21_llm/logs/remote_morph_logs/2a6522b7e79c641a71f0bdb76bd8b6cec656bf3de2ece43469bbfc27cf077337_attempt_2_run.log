/-- Among n agents, to make k an expert, we need at least n-1 calls. -/
lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 < S.length := by
  classical
  by_contra hn
  have hle : S.length ≤ n - 1 := Nat.le_of_not_gt hn
  have hk0 : n = 0 := by
    by_contra hn0
    have hnpos : 0 < n := Nat.pos_of_ne_zero hn0
    have : n ≤ S.length + 1 := by
      simpa [Nat.sub_eq_iff_eq_add_of_le (Nat.succ_le_iff.mp hnpos)] using
