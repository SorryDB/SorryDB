lemma bfc_bounded (x y : H) {C : ℝ} {f : (spectrum ℂ a) → ℂ}  (hf_bounded : ∀ x, ‖f x‖ ≤ C)
    (hX : @Measurable _ _ (borel (spectrum ℂ a)) _ f) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
  classical
  have hC : 0 ≤ C := by
    by_contra hneg
    have : (‖f (Classical.choice (inhabited_of_nonempty (spectrum ℂ a).nonempty))‖ : ℝ) ≤ C :=
      hf_bounded _
    exact not_le_of_gt (lt_of_not_ge hneg) (le_trans (norm_nonneg _) this)
  calc
    ‖(cfc_toComplexMeasure ha x y).integral f‖
        ≤ (cfc_toComplexMeasure ha x y).variation Set.univ * C := by
          simpa [Real.norm_eq_abs, abs_of_nonneg hC, mul_comm, mul_left_comm, mul_assoc] using
            (ComplexMeasure.norm_integral_le_mul_variation (μ := cfc_toComplexMeasure ha x y)
              (f := f) (C := C) hf_bounded hX)
    _ ≤ (‖x‖ * ‖y‖) * C := by
          have := cfc_variation_toComplexMeasure_bounded (ha := ha) x y
          have hx : (‖x‖ₑ : ℝ) = ‖x‖ := by simp
          have hy : (‖y‖ₑ : ℝ) = ‖y‖ := by simp
          have hvar : (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := by
            simpa [hx, hy] using this
          exact mul_le_mul_of_nonneg_right hvar hC
    _ = ‖x‖ * ‖y‖ * C := by ring
```
