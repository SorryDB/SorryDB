lemma bfc_bounded (x y : H) {C : ℝ} {f : (spectrum ℂ a) → ℂ}  (hf_bounded : ∀ x, ‖f x‖ ≤ C)
    (hX : @Measurable _ _ (borel (spectrum ℂ a)) _ f) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * C := by
  classical
  have hC : 0 ≤ C := by
    by_contra hneg
    have : (0 : ℝ) ≤ C := by
      have := hf_bounded (Classical.choice (Set.exists_mem_of_nonempty (spectrum.nonempty ℂ a)))
      exact le_trans (norm_nonneg _) this
    exact hneg this
  have h_ae : ∀ᵐ z ∂(cfc_toComplexMeasure ha x y).variation, ‖f z‖ ≤ C :=
    Filter.eventually_of_forall hf_bounded
  have h_integrable : MeasureTheory.Integrable f (cfc_toComplexMeasure ha x y).variation := by
    refine (MeasureTheory.integrable_iff_norm_integrable ?_).1 ?_
    · exact hX.norm
    · refine MeasureTheory.Integrable.of_norm_bounded ?_ h_ae
      · exact (measurable_const : Measurable fun _ : spectrum ℂ a => (C : ℝ))
      · exact MeasureTheory.integrable_const.2 (by
          simpa using (measure_mono (Set.subset_univ _)))
  have h_abs :
      ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤
        ∫ z, ‖f z‖ ∂(cfc_toComplexMeasure ha x y).variation := by
    simpa using (cfc_toComplexMeasure ha x y).norm_integral_le_integral_norm h_integrable
  have h1 :
      (∫ z, ‖f z‖ ∂(cfc_toComplexMeasure ha x y).variation) ≤
        (∫ z, (C : ℝ) ∂(cfc_toComplexMeasure ha x y).variation) := by
    refine MeasureTheory.integral_mono_ae ?_ ?_
    · exact (MeasureTheory.aestronglyMeasurable_norm hX.aestronglyMeasurable)
    · exact (measurable_const.aestronglyMeasurable)
    · exact h_ae
  have h2 :
      (∫ z, (C : ℝ) ∂(cfc_toComplexMeasure ha x y).variation) =
        C * (cfc_toComplexMeasure ha x y).variation Set.univ := by
    simp [MeasureTheory.integral_const, hC, mul_comm, mul_left_comm, mul_assoc]
  have hv := cfc_variation_toComplexMeasure_bounded (ha := ha) x y
  have hv' :
      (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := by
    simpa using hv
  have : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ C * (‖x‖ * ‖y‖) := by
