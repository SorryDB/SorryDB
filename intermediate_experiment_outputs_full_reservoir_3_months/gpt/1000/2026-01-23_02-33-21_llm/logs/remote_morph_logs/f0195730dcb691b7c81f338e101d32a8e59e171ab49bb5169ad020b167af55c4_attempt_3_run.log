lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  classical
  obtain ⟨s, rfl⟩ := heq
  induction p with
  | mk u pw =>
    clear p
    induction pw with
    | nil =>
      simp [SimpleGraph.LoopWalk.edgeSet, SimpleGraph.LoopWalk.edges]
    | @cons u v w h p ih =>
      have h_edges :
          (SimpleGraph.LoopWalk.permMapWalk n s (SimpleGraph.LoopWalk.cons h p)).edges =
            List.map (fun e => Sym2.map s e) (SimpleGraph.LoopWalk.cons h p).edges := by
          simp [SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.darts, SimpleGraph.LoopWalk.dartEdge]
      -- use the induction hypothesis on the tail walk
      have ih' :
          ((SimpleGraph.LoopWalk.edgeSet (G := K n) p).card) =
            ((SimpleGraph.LoopWalk.edgeSet (G := K n) (SimpleGraph.LoopWalk.permMapWalk n s p)).card) := by
          simpa using (ih)
      -- now finish by converting edges-toFinset under `Sym2.map s`
      have hs : Function.LeftInverse (fun x : Sym2 (Fin n) => Sym2.map s.symm x) (fun x => Sym2.map s x) := by
        intro e
        simpa using (by
          cases e using Sym2.inductionOn with
          | _ a b =>
            simp [Sym2.map_mk, Equiv.apply_symm_apply])
      have hinj : Function.Injective (fun x : Sym2 (Fin n) => Sym2.map s x) :=
        Function.LeftInverse.injective hs
      have h_toFinset :
          (List.map (fun e => Sym2.map s e) (SimpleGraph.LoopWalk.cons h p).edges).toFinset.card =
            (SimpleGraph.LoopWalk.cons h p).edges.toFinset.card := by
        simpa [Finset.card_image_iff] using (Finset.card_image_of_injective _ hinj).symm
      -- reduce both sides to card of toFinset of edges lists
      simp [SimpleGraph.LoopWalk.edgeSet, SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.darts,
        SimpleGraph.LoopWalk.dartEdge] at ih' ⊢
      -- finish with `simp` using `ih'` and `Finset.card_image_of_injective`
      simpa [h_edges, SimpleGraph.LoopWalk.edgeSet] using congrArg id (by
        -- rewrite both cards through mapping on toFinset
        simpa [SimpleGraph.LoopWalk.edgeSet, h_edges] using h_toFinset)
    | @loop u v p ih =>
      -- loop adds a self-edge dart (u,u); mapping preserves it
      simp [SimpleGraph.LoopWalk.edgeSet, SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.darts,
        SimpleGraph.LoopWalk.dartEdge, ih]
