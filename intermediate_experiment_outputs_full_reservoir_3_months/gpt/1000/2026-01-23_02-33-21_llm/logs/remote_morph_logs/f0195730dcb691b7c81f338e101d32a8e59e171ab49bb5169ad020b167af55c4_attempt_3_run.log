  (edgeSet p.2).card = (edgeSet q.2).card := by
  classical
  obtain ⟨s, hs⟩ := heq
  subst hs
  suffices hset :
      (edgeSet (G := K n) (permMapWalk n s p.2)) = (edgeSet (G := K n) p.2).image (Sym2.map s) by
    simpa [hset, Finset.card_image_iff] using congrArg Finset.card hset
  clear s
  classical
  induction p.2 with
  | nil =>
    simp [SimpleGraph.LoopWalk.edgeSet, SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.darts,
      permMapWalk, LoopWalk.map]
  | @cons u v w h p ih =>
    simp [SimpleGraph.LoopWalk.edgeSet, SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.darts,
      permMapWalk, LoopWalk.map, ih, Finset.image_union]
  | @loop u v p ih =>
    simp [SimpleGraph.LoopWalk.edgeSet, SimpleGraph.LoopWalk.edges, SimpleGraph.LoopWalk.darts,
      permMapWalk, LoopWalk.map, ih, Finset.image_union]
