    (hp : ∀ i ∈ s, p i ∈ t) : s.affineCombination k p w ∈ affineSpan k t := by
  classical
  have hnz : ∑ i ∈ s, w i ≠ 0 := h.symm ▸ one_ne_zero
  obtain ⟨i₀, hi₀⟩ : s.Nonempty := Finset.nonempty_of_sum_ne_zero hnz
