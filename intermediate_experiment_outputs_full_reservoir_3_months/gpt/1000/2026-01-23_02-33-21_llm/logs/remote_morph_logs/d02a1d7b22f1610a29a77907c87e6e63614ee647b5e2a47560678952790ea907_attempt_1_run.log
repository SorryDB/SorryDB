lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
  by_cases hf : LocallyIntegrableOn f Ω μ
  · have hf' : LocallyIntegrableOn f' Ω μ := hf.ae_congr h
    ext φ
    simp [ofFunWithOrder_apply (Ω := Ω) (n := n) (μ := μ) hf,
      ofFunWithOrder_apply (Ω := Ω) (n := n) (μ := μ) hf']
    have hsmul : (fun x => (φ x • f x)) =ᵐ[μ.restrict Ω] fun x => (φ x • f' x) :=
      (Filter.EventuallyEq.mul_const (a := φ) (b := 1) ?_ : True) |> by
        simpa [Pi.mul_apply] using h.const_smul (fun x => φ x)
    have hsmul' : (fun x => (φ x • f x)) =ᵐ[μ] fun x => (φ x • f' x) := by
      have : (fun x => (φ x • f x)) =ᵐ[μ.restrict Ω] fun x => (φ x • f' x) := by
        simpa using h.fun_comp (fun y => φ _ • y)
      exact this.filter_mono (by
