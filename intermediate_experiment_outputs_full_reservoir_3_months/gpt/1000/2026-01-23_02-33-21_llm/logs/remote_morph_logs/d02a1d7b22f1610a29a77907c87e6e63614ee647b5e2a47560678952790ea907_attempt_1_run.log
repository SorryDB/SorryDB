lemma ofFunWithOrder_ae_congr {f f' : E → F} {μ : Measure E} (h : f =ᵐ[μ.restrict Ω] f') :
  ofFunWithOrder Ω n f μ = ofFunWithOrder Ω n f' μ := by
  ext φ
  by_cases hf : LocallyIntegrableOn f Ω μ
  · have hf' : LocallyIntegrableOn f' Ω μ := by
      simpa [LocallyIntegrableOn, h] using hf
    simp [ofFunWithOrder_apply (Ω := Ω) (n := n) (μ := μ) hf,
      ofFunWithOrder_apply (Ω := Ω) (n := n) (μ := μ) hf',
      Measure.integral_congr_ae, h]
  · have hf' : ¬ LocallyIntegrableOn f' Ω μ := by
      intro hf'
      apply hf
      simpa [LocallyIntegrableOn, h] using hf'
    simp [ofFunWithOrder_of_not_locallyIntegrable (Ω := Ω) (n := n) (μ := μ) hf,
      ofFunWithOrder_of_not_locallyIntegrable (Ω := Ω) (n := n) (μ := μ) hf']
```
