            rw [HermitianMat.inner_comm, ← MState.exp_val]
            exact MState.exp_val_nonneg (HermitianMat.proj_le_nonneg _ _) ((ℰ n) (statePow ρ n))
          have hε₀nn : 0 ≤ ε₀ := le_of_lt hε₀
          nlinarith
        all_goals sorry --so for now I'm closing everything with sorry
