      simp [Match.btAt]))).toFinset, ?_, ?_⟩
    · refine Finset.mem_coe.2 ?_
      simp [BuildTree.toModel, BuildTree.allPreStates, BuildTree.allPreStatePs]
    · simp [PreState.forms]
