theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id :=
by
  constructor
  · intro h
    rcases h with ⟨f, hf⟩
    classical
    refine ⟨f, fun v => Classical.choose (hf v), ?_, ?_⟩
    · funext v
      have : f (Classical.choose (hf v)) = v := Classical.choose_spec (hf v)
      simpa [Function.comp, id] using this
    · funext u
      have : Classical.choose (hf (f u)) = u := by
        apply (hf.inj)
        simpa using (Classical.choose_spec (hf (f u)))
      simpa [Function.comp, id] using this
  · rintro ⟨f, g, hfg, hgf⟩
    refine ⟨f, ?_⟩
    refine ⟨?_, ?_⟩
    · intro v
      refine ⟨g v, ?_⟩
      have := congrArg (fun h => h v) hfg
      simpa [Function.comp, id] using this
    · intro u1 u2 hu
      have := congrArg g hu
      have hg1 := congrArg (fun h => h u1) hgf
      have hg2 := congrArg (fun h => h u2) hgf
      simpa [Function.comp, id] using (by
        calc
          u1 = g (f u1) := by simpa [Function.comp, id] using hg1.symm
          _ = g (f u2) := by simpa [hu] using rfl
          _ = u2 := by simpa [Function.comp, id] using hg2)
