-- TODO: find a better name!
lemma integrable_smul {f : E → F} {μ : Measure E} (φ : 𝓓(Ω, ℝ)) (hf : LocallyIntegrableOn f Ω μ) :
    Integrable (fun x ↦ φ x • f x) μ := by
  classical
  by_cases hφ : (Function.support fun x ↦ (φ : E → ℝ) x) = ∅
  · have hφ0 : (φ : E → ℝ) = 0 := by
      ext x
      by_contra hx
      have hx' : x ∈ Function.support (fun y ↦ (φ : E → ℝ) y) := by
        simpa [Function.mem_support, hx] using hx
      simpa [hφ] using hx'
    simp [hφ0]
  ·
    have hIsCompact : IsCompact (Function.support fun x ↦ (φ : E → ℝ) x) :=
      (TestFunction.isCompact_support (φ := φ))
    have hsupport : Function.support (fun x ↦ φ x • f x) ⊆ Ω := by
      intro x hx
      have hx' : x ∈ Function.support (fun y ↦ (φ : E → ℝ) y) := by
        have : (φ x : ℝ) ≠ 0 := by
          simpa [Function.mem_support, Pi.mul_apply] using hx
        simpa [Function.mem_support, this]
      exact (TestFunction.support_subset (φ := φ)) hx'
    have hint : IntegrableOn f Ω μ := hf
    have hint' : IntegrableOn f (Function.support fun x ↦ (φ : E → ℝ) x) μ := by
      exact hint.mono_set (by
        intro x hx
        exact (TestFunction.support_subset (φ := φ)) hx)
    have hbounded : BddAbove (Set.range fun x ↦ ‖(φ : E → ℝ) x‖) := by
      simpa using (TestFunction.bddAbove_range_norm (φ := φ))
    rcases (bddAbove_def.1 hbounded) with ⟨C, hC⟩
    have hnorm_le : ∀ x, ‖(φ : E → ℝ) x‖ ≤ C := by
      intro x
      exact hC ⟨x, rfl⟩
    have hmul :
        IntegrableOn (fun x ↦ (φ x : ℝ) • f x) (Function.support fun x ↦ (φ : E → ℝ) x) μ := by
      refine (hint'.smul ?_).mono_set (by intro x hx; exact hx)
      refine (ae_of_all _ ?_)
      intro x
      exact (hnorm_le x)
    have hmul0 :
        IntegrableOn (fun x ↦ (φ x : ℝ) • f x) Ω μ := by
      refine hmul.mono_set ?_
      intro x hx
      exact (TestFunction.support_subset (φ := φ)) hx
    simpa [Integrable, integrableOn_univ] using hmul0.integrable_of_support_subset hsupport
