lemma matchingMatroid.seriesPair_of_adj (h : ∀ x, G.inessential x) (h : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  classical
  by_cases hxy : x = y
  · subst hxy
    simpa [Matroid.series_iff] using (G.matchingMatroid.series_refl x)
  · have hx : x ∈ V(G) := by
      have : x ∈ V(G, ⟨x, y, h⟩ : β) := by
        exact ⟨y, by simpa [Graph.Inc, hxy] using h.inc_left⟩
      exact G.vertex_mem_of_mem_vertexSet_edge this
    have hy : y ∈ V(G) := by
      have : y ∈ V(G, ⟨x, y, h⟩ : β) := by
        exact ⟨x, by simpa [Graph.Inc, hxy] using h.inc_right⟩
      exact G.vertex_mem_of_mem_vertexSet_edge this
    have hncx : ¬ G.matchingMatroid.IsColoop x := G.matchingMatroid.noColoop h hx
    have hncy : ¬ G.matchingMatroid.IsColoop y := G.matchingMatroid.noColoop h hy
    refine (G.matchingMatroid.seriesPair_of_adj_of_not_isColoop h hxy hx hy h hncx hncy)
```
