/--The off-diagonal entries of a Wigner Matrix have law μ -/
lemma offDiagonalHasLaw (n : ℕ) {i j : Fin n} (h : i ≠ j) :
    HasLaw (fun ω ↦ (wignerMatrixMap n ω) i j) μ (WignerMeasure μ ν n) := by
  by_cases hij : i < j
  · exact offDiagonalHasLaw' (μ := μ) (ν := ν) n hij
  · have hji : j < i := lt_of_le_of_ne (le_of_not_gt hij) (Ne.symm h)
    have hs : (fun ω ↦ (wignerMatrixMap n ω) i j) = (fun ω ↦ (wignerMatrixMap n ω) j i) := by
      funext ω
      simpa using (wignerMatrixSymmetric (μ := μ) (ν := ν) n i j (ω := ω)).symm
    simpa [hs] using (offDiagonalHasLaw' (μ := μ) (ν := ν) n hji)
```
