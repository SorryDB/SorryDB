lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable (hX1 : Martingale X 𝓕 P)
    (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  classical
  have h_sub : Submartingale X 𝓕 P := hX1.submartingale
  have h_nonneg : 0 ≤ (fun t ω ↦ ‖X t ω‖) := fun t ω ↦ norm_nonneg _
  have h_sub_norm : Submartingale (fun t ω ↦ ‖X t ω‖) 𝓕 P := hX1.submartingale_convex_comp
    (convexOn_norm convex_univ) continuous_norm (fun t ↦ (hX1.integrable t).norm)
  have h_cont_norm : ∀ ω, RightContinuous (fun t ↦ ‖X t ω‖) := fun ω t ↦ (hX2 ω t).norm
  constructor
  · intro hD
    have hD_norm : ProbabilityTheory.ClassD (fun t ω ↦ ‖X t ω‖) 𝓕 P := by
      refine ⟨?_, ?_⟩
      · exact hX1.adapted.progMeasurable_of_rightContinuous hX2 |>.norm
      · simpa [ProbabilityTheory.ClassD, ProbabilityTheory.ClassDL, uniformIntegrable_iff_norm]
          using hD.uniformIntegrable.norm
    have hUI_norm : UniformIntegrable (fun t ω ↦ ‖X t ω‖) 1 P := by
      simpa using
        (MeasureTheory.Submartingale.classD_iff_uniformIntegrable h_sub_norm h_cont_norm h_nonneg).1
          hD_norm
    simpa [uniformIntegrable_iff_norm] using hUI_norm
  · intro hUI
    have hUI_norm : UniformIntegrable (fun t ω ↦ ‖X t ω‖) 1 P := by
      simpa [uniformIntegrable_iff_norm] using hUI
    have hD_norm : ProbabilityTheory.ClassD (fun t ω ↦ ‖X t ω‖) 𝓕 P := by
      exact
        (MeasureTheory.Submartingale.classD_iff_uniformIntegrable h_sub_norm h_cont_norm h_nonneg).2
          hUI_norm
    refine ProbabilityTheory.classD_of_uniformIntegrable_bounded_stoppingTime ?_
      (hX1.adapted.progMeasurable_of_rightContinuous hX2)
    have hUI_bounded_norm :
        UniformIntegrable
          (fun T :
              {T | IsStoppingTime 𝓕 T ∧ ∃ t : ι, ∀ ω, T ω ≤ t} ↦
              stoppedValue (fun t ω ↦ ‖X t ω‖) T)
          1 P := by
      exact
        (MeasureTheory.Submartingale.uniformIntegrable_bounded_stoppingTime
            (X := fun t ω ↦ ‖X t ω‖) h_sub_norm h_cont_norm h_nonneg hUI_norm)
    simpa [uniformIntegrable_iff_norm] using hUI_bounded_norm
