theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  by_cases hprime : p.Prime
  · have : (P.initial.a.map (·.factorization p)).sum ≤ P.M * (Real.log P.n) + (P.n.factorial.factorization p) := by
      have hnonneg : 0 ≤ (P.n.factorial.factorization p : ℝ) := by positivity
      have hpos : 0 ≤ (P.M : ℝ) * Real.log P.n := by
        by_cases hn : P.n = 0
        · simp [hn]
        · have hn1 : (1 : ℝ) ≤ P.n := by
            exact_mod_cast (Nat.succ_le_iff.mp (Nat.succ_le_of_lt (Nat.pos_of_ne_zero hn)))
          have hlog : 0 ≤ Real.log (P.n : ℝ) := Real.log_nonneg hn1
          have hM : 0 ≤ (P.M : ℝ) := by positivity
          nlinarith
      nlinarith
    have hsum : (P.initial.a.map (·.factorization p)).sum - (P.n.factorial.factorization p : ℤ)
        ≤ (P.M : ℝ) * Real.log P.n := by
      have := this
      push_cast at this
      nlinarith
    simpa [Factorization.balance, Factorization.sum] using hsum
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime]
