lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  classical
  apply le_antisymm
  · refine sSup_le ?_
    intro a ha
    rcases ha with ⟨D, hD, haD⟩
    have hDS : ∀ x ∈ D, x ≤ sSup S := by
      intro x hx
      obtain ⟨b, hbS, hb⟩ := R.carrier_span x (by
        have : x ∈ ⋃ D ∈ R, D := by exact ⟨D, hD, hx⟩
        exact this) |>.exists
      have hb' : x = sSup b := by
        rcases R.carrier_span x (by
          have : x ∈ ⋃ D ∈ R, D := by exact ⟨D, hD, hx⟩
          exact this) with ⟨b', hb'R, hb'eq, hb'unique⟩
        have : b' = b := by
          apply hb'unique b hbS
          simpa [hb] using hb'eq
        simpa [this, hb] using hb'eq
      have : sSup S = sSup S := rfl
      exact le_trans (by simpa [hb'] using le_rfl) le_rfl
    exact le_trans (le_trans (le_csSup (by
      refine ⟨sSup S, ?_⟩
      intro x hx
      exact hDS x hx) haD) (by
        exact le_rfl)) le_rfl
  · refine sSup_le ?_
    intro a haS
    rcases R.carrier_span a haS with ⟨D, hDR, haD, huniq⟩
    have : sSup D ≤ sSup (decomposition_of_refinement R) := by
      refine sSup_le ?_
      intro x hxD
      refine le_csSup ?_ ?_
      · refine ⟨sSup S, ?_⟩
        intro y hy
        exact le_csSup (by
          refine ⟨sSup S, ?_⟩
          intro z hz
          exact le_rfl) hy
      · exact ⟨D, hDR, hxD⟩
    simpa [haD] using this
```
