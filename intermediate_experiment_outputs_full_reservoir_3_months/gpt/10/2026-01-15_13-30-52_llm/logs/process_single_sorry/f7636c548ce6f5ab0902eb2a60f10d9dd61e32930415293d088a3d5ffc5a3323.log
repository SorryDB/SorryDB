namespace SymList

theorem length_lt_length_init {a : Type}
 (sl : SymList a) (h : sl ≠ nil)
 : sl.lengthSL > sl.initSL.lengthSL := by
 have ⟨xs, ys, h₁⟩ := sl
 induction xs with
 | nil =>
   cases ys with
   | nil => contradiction
   | cons b bs =>
     have h₂ := h₁.1 ; simp at h₂
     simp [lengthSL, initSL, h₂, splitInTwoSL]
 | cons b bs ih₁ =>
   induction ys with
   | nil =>
     have h₂ := h₁.2 ; simp at h₂
     simp [lengthSL, initSL, h₂, nil]
   | cons n ns ih₂ =>
     simp at ih₁ ih₂
     by_cases hns : ns = []
     · subst hns
       simp [lengthSL, initSL, splitInTwoSL]
     · simp [lengthSL, initSL, hns, Nat.lt_succ_iff]
```

