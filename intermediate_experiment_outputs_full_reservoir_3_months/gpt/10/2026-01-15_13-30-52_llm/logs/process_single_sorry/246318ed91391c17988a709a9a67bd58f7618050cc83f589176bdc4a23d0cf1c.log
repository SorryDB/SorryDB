    theorem RelIO.liftFinf_in {S} {ident : InternalPort Nat} {n : Nat} {f : Fin n → RelIO S}:
      AssocList.contains ident (RelIO.liftFinf n f) = true
      → ∃ i : Fin n, ident = i := by
          intro h
          classical
          dsimp [RelIO.liftFinf] at h
          have hm :
              (↑ident.name.toNat) ∈ (fin_range n).map (fun i : Fin n => (i.toNat : Nat)) := by
            simpa [AssocList.contains_eq, List.toList_toAssocList, List.any_map, List.any_eq_true, List.mem_map,
              Function.comp_apply, beq_iff_eq] using h
          rcases (List.mem_map.1 hm) with ⟨i, hi, rfl⟩
          refine ⟨i, ?_⟩
          cases ident with
          | mk inst nm =>
            cases nm with
            | mk inst' nm' =>
              simp at *
```
