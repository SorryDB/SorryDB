        simpa using Nat.prime_of_mem_primes (by
          simpa using (Nat.mem_primes.2 ⟨by
            have : 2 * N * N + 1 ≠ 1 := by
              have h : 2 * N * N > 0 := by
                have : (2 : ℕ) > 0 := by decide
                exact Nat.mul_pos this (Nat.mul_pos (Nat.pos_of_ne_zero (by
                  intro hN; simpa [hN] using (Nat.zero_lt_one)) ) (Nat.pos_of_ne_zero (by
                    intro hN; simpa [hN] using (Nat.zero_lt_one))))
              exact Nat.succ_ne_succ_iff.mp (by
                simpa [Nat.succ_eq_add_one] using (ne_of_gt (Nat.succ_lt_succ (Nat.zero_lt_one))))
            exact this
          , by
            intro h
            exact False.elim (by
              have : (2 : ℕ) ∣ 1 := by
                simpa [Nat.add_comm, Nat.add_left_comm, Nat.add_assoc] using h
              exact Nat.not_dvd_one 2 this⟩))
      exact this
    refine ⟨hp, ?_, ?_⟩
    · have : (2 * N * N + 1) ∣ (N ^ 2 + 1) := by
        have h : N ^ 2 + 1 = 1 + N ^ 2 := by omega
        -- trivial divisor: p divides itself; take p = n^2+1 by choosing n = N and p = N^2+1 if prime
        -- but we already fixed p; use that p divides n^2+1 by choosing n so that n^2+1 = p
        sorry
    · sorry
  ⟩
