lemma sup_stoppedProcess_hittingAfter_Ici_le {E : Type*} [NormedAddCommGroup E] [InfSet ι] [Bot ι]
    {X : ι → Ω → E} (t : ι) (K : ℝ) (ω : Ω) :
    ⨆ s ≤ t, ‖stoppedProcess X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) s ω‖ ≤
    K + Set.indicator {ω | hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω ≤ t}
      (fun ω ↦ ‖stoppedValue X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) ω‖) ω := by
  classical
  by_cases h : hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω ≤ t
  · have hK : ∀ s, s ≤ t →
        ‖stoppedProcess X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) s ω‖ ≤ K := by
      intro s hs
      by_cases hsτ : s ≤ (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω).untopA
      · simp [stoppedProcess, hsτ]
      · have hsτ' :
          (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω).untopA ≤ s := by
            exact le_of_not_ge hsτ
        have hmem :
            ‖X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω).untopA ω‖ ∈ Set.Ici K :=
          by
            simpa [hittingAfter, hsτ', h] using
              (mem_of_eq_true (by rfl) : True)
        have : ‖stoppedProcess X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) s ω‖ =
            ‖X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω).untopA ω‖ := by
          simp [stoppedProcess, min_eq_left hsτ']
        rw [this]
        exact hmem.1
    have hsup : (⨆ s ≤ t, ‖stoppedProcess X
        (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) s ω‖) ≤ K := by
      refine iSup₂_le ?_
      intro s hs
      exact hK s hs
    have hind :
        Set.indicator {ω | hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω ≤ t}
          (fun ω ↦ ‖stoppedValue X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) ω‖) ω =
        ‖stoppedValue X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) ω‖ := by
      simp [Set.indicator, h]
    have : (K : ℝ) ≤ K + ‖stoppedValue X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) ω‖ := by
      simpa [add_comm, add_left_comm, add_assoc] using le_add_of_nonneg_right (norm_nonneg _)
    exact le_trans hsup (by simpa [hind] using this)
  · have hind :
        Set.indicator {ω | hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω ≤ t}
          (fun ω ↦ ‖stoppedValue X (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) ω‖) ω = 0 := by
        simp [Set.indicator, h]
    have hsup : (⨆ s ≤ t, ‖stoppedProcess X
        (hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥) s ω‖) ≤ K := by
      refine iSup₂_le ?_
      intro s hs
      have : hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω = ⊤ := by
        by_contra htop
        have : hittingAfter (fun t ω ↦ ‖X t ω‖) (Set.Ici K) ⊥ ω ≤ t := by
          simpa [WithTop.le_untopA_iff (by simpa [htop])] using le_trans le_rfl hs
        exact h (by simpa using this)
      simp [stoppedProcess, this, le_rfl]
    simpa [hind] using le_trans hsup (le_add_of_nonneg_right (by simp))
