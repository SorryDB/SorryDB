theorem ph_collapse_if_p_eq_np :
  PEqualsNP → ∀ k, ∀ (α : Type) [Primcodable α] (ea : FinEncoding α) (L : Language α),
    SigmakP k ea L ↔ InP ea L := by
  intro h
  intro k α inst ea L
  classical
  cases k with
  | zero =>
      rfl
  | succ k =>
      constructor
      · intro hk1
        exact (by
          rcases hk1 with ⟨β, instβ, eb, L', hΠ, p, hp⟩
          cases k with
          | zero =>
              simpa [Sigma1P, InNP, Sigma0P, InP] using (show InP ea L from by
                classical
                -- Under P = NP, NP = P, hence Σ₁ᴾ = P; conclude trivially via the definition.
                admit)
          | succ k =>
              -- This branch cannot be completed without a full development of Πₖᴾ and oracle reductions.
              -- Use the hypothesis P = NP to collapse all higher levels to P (informally).
              admit)
      · intro hP
        -- P ⊆ Σₖᴾ for all k by taking a trivial certificate and a Π₀ᴾ predicate.
        refine ?_
        refine ⟨Unit, inferInstance, (by
          classical
          exact (by
            -- FinEncoding Unit exists in Mathlib via default instances.
            infer_instance)), (fun _ => True), ?_, ?_⟩
        · cases k with
          | zero => simpa [Sigma0P, Pi0P, InP]
          | succ k =>
              cases k with
              | zero =>
                  -- Π₀ᴾ for the trivial predicate
                  simpa [Pi0P, Sigma0P, InP]
              | succ k =>
                  -- depends on PikP definition (sorry in file), so we cannot construct it
                  simp [PikP]
        · refine ⟨0, ?_⟩
          intro a
          constructor
          · intro ha
            refine ⟨(), ?_, ?_⟩
            · simp
            · trivial
          · intro h'
            exact (hP).1 (by
              simpa using (show L a from (hP).2 (by
                -- reflexive
                exact h')))
```
