lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  classical
  obtain ⟨s, rfl⟩ := heq
  suffices h :
      (edgeSet (permMapWalk n s p.2)).card =
        (Finset.image (fun e : Sym2 (Fin n) => e.map s) (edgeSet p.2)).card := by
    simpa [h]
  have hset :
      edgeSet (permMapWalk n s p.2) =
        Finset.image (fun e : Sym2 (Fin n) => e.map s) (edgeSet p.2) := by
    ext e
    constructor
    · intro he
      rcases Finset.mem_toFinset.mp he with ⟨e', he', rfl⟩
      induction p.2 with
      | nil =>
        simp [LoopWalk.edges, LoopWalk.edgeSet] at he'
      | @cons u v w h p ih =>
        simp [LoopWalk.edges, LoopWalk.edgeSet, permMapWalk_cons] at he' ⊢
        rcases he' with he' | he'
        · refine Finset.mem_image.mpr ?_
          refine ⟨LoopWalk.dartEdge (u, v), ?_, ?_⟩
          · simp [LoopWalk.edgeSet, LoopWalk.edges]
          · simpa [LoopWalk.dartEdge, Sym2.map_mk] using he'
        · exact ih (Finset.mem_toFinset.mpr ⟨e', he', rfl⟩)
      | @loop u v p ih =>
        simp [LoopWalk.edges, LoopWalk.edgeSet, permMapWalk_loop] at he' ⊢
        rcases he' with he' | he'
        · refine Finset.mem_image.mpr ?_
          refine ⟨LoopWalk.dartEdge (u, u), ?_, ?_⟩
          · simp [LoopWalk.edgeSet, LoopWalk.edges]
          · simpa [LoopWalk.dartEdge, Sym2.map_mk] using he'
        · exact ih (Finset.mem_toFinset.mpr ⟨e', he', rfl⟩)
    · intro he
      rcases Finset.mem_image.mp he with ⟨e', he', rfl⟩
      rcases Finset.mem_toFinset.mp he' with ⟨e'', he'', rfl⟩
      induction p.2 with
      | nil =>
        simp [LoopWalk.edges, LoopWalk.edgeSet] at he''
      | @cons u v w h p ih =>
        simp [LoopWalk.edges, LoopWalk.edgeSet, permMapWalk_cons] at he'' ⊢
        rcases he'' with he'' | he''
        · refine Finset.mem_toFinset.mpr ?_
          refine ⟨LoopWalk.dartEdge (s u, s v), by simp [LoopWalk.edges, LoopWalk.dartEdge], ?_⟩
          simpa [LoopWalk.dartEdge, Sym2.map_mk] using congrArg (Sym2.map s) he''
        · exact ih (Finset.mem_toFinset.mpr ⟨e'', he'', rfl⟩)
      | @loop u v p ih =>
        simp [LoopWalk.edges, LoopWalk.edgeSet, permMapWalk_loop] at he'' ⊢
        rcases he'' with he'' | he''
        · refine Finset.mem_toFinset.mpr ?_
          refine ⟨LoopWalk.dartEdge (s u, s u), by simp [LoopWalk.edges, LoopWalk.dartEdge], ?_⟩
          simpa [LoopWalk.dartEdge, Sym2.map_mk] using congrArg (Sym2.map s) he''
        · exact ih (Finset.mem_toFinset.mpr ⟨e'', he'', rfl⟩)
  have hinj : Function.Injective (fun e : Sym2 (Fin n) => e.map s) := by
    intro a b hab
    simpa using congrArg (fun e => e.map s.symm) hab
  simpa [hset] using (Finset.card_image_of_injective _ hinj)
