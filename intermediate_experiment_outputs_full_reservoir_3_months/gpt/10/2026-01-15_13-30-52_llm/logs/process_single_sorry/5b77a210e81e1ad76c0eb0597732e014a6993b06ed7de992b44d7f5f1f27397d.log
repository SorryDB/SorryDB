namespace Imo1971P3

problem imo1971_p3 :
   ∃ s : Set ℕ+,
     s.Infinite ∧
     s.Pairwise fun m n ↦ Nat.Coprime (2 ^ n.val - 3) (2 ^ m.val - 3) := by
  classical
  refine ⟨{k : ℕ+ | ∃ t : ℕ, k = ⟨2 * t + 2, by
    have : (0 : ℕ) < 2 * t + 2 := by
      exact Nat.succ_pos _
    simpa using this⟩}, ?_, ?_⟩
  · -- infinite
    refine Set.infinite_iff_exists_not_mem_finite.2 ?_
    intro f
    have hf : ∀ t : ℕ, (⟨2 * t + 2, by
      have : (0 : ℕ) < 2 * t + 2 := by exact Nat.succ_pos _
      simpa using this⟩ : ℕ+) ∈ {k : ℕ+ | ∃ t : ℕ, k = ⟨2 * t + 2, by
        have : (0 : ℕ) < 2 * t + 2 := by exact Nat.succ_pos _
        simpa using this⟩} := by
      intro t
      refine ⟨t, rfl⟩
    obtain ⟨t, ht⟩ : ∃ t : ℕ, (⟨2 * t + 2, by
      have : (0 : ℕ) < 2 * t + 2 := by exact Nat.succ_pos _
      simpa using this⟩ : ℕ+) ∉ f := by
      simpa [Set.infinite_iff_exists_not_mem_finite] using
        (Set.infinite_univ : (Set.univ : Set ℕ).Infinite)
    refine ⟨⟨2 * t + 2, by
      have : (0 : ℕ) < 2 * t + 2 := by exact Nat.succ_pos _
      simpa using this⟩, hf t, ?_⟩
    simpa using ht
  · -- pairwise coprime
    intro a ha b hb hab
    rcases ha with ⟨ta, rfl⟩
    rcases hb with ⟨tb, rfl⟩
    have hne : (ta + 1) ≠ (tb + 1) := by
      intro h
      apply hab
      ext
      have : 2 * ta + 2 = 2 * tb + 2 := by
        have := congrArg (fun x : ℕ => 2 * x) (Nat.succ_inj.1 h)
        simpa [two_mul, Nat.add_assoc, Nat.add_left_comm, Nat.add_comm] using this
      exact this
    -- use the standard identity: gcd(2^m-1,2^n-1)=2^gcd(m,n)-1 and the fact that
    -- if a prime divides both (2^(2k)-3) and (2^(2l)-3) then it divides 3 and hence is 3,
    -- but 3 does not divide 2^(even)-3.
    -- We finish by a direct coprime argument in Nat via `Nat.coprime_of_lt_prime`-style.
    -- A simpler approach: show any common divisor d divides 1.
    refine Nat.coprime_iff_gcd_eq_one.2 ?_
    -- Let g be gcd of the two numbers and show g=1.
    have : Nat.gcd (2 ^ (2 * ta + 2) - 3) (2 ^ (2 * tb + 2) - 3) = 1 := by
      -- Suppose p is a prime dividing the gcd; show contradiction.
      by_contra h
      have hgpos : 0 < Nat.gcd (2 ^ (2 * ta + 2) - 3) (2 ^ (2 * tb + 2) - 3) := by
        exact Nat.pos_of_ne_zero (by
          intro hz
          have := congrArg (fun x => x = 0) hz
          simpa using this)
      have hg : 1 < Nat.gcd (2 ^ (2 * ta + 2) - 3) (2 ^ (2 * tb + 2) - 3) := by
        have : Nat.gcd (2 ^ (2 * ta + 2) - 3) (2 ^ (2 * tb + 2) - 3) ≠ 1 := by
          intro h1
          exact h (by simpa [h1])
        exact lt_of_le_of_ne (Nat.succ_le_iff.2 hgpos) (Ne.symm this)
      obtain ⟨p, pp, hpg⟩ := Nat.exists_prime_and_dvd_of_not_coprime
        (a := 2 ^ (2 * ta + 2) - 3) (b := 2 ^ (2 * tb + 2) - 3) (by
          -- not coprime from gcd > 1
          intro hc
          have := Nat.coprime_iff_gcd_eq_one.1 hc
          exact (ne_of_lt hg) this)
      have hp1 : p ∣ (2 ^ (2 * ta + 2) - 3) := Nat.dvd_trans hpg (Nat.gcd_dvd_left _ _)
      have hp2 : p ∣ (2 ^ (2 * tb + 2) - 3) := Nat.dvd_trans hpg (Nat.gcd_dvd_right _ _)
      have hmoda : (2 ^ (2 * ta + 2) : ZMod p) = 3 := by
        -- from p ∣ 2^n-3
        have : (p : ℕ) ∣ (2 ^ (2 * ta + 2) - 3) := hp1
        have := (ZMod.natCast_zmod_eq_zero_iff_dvd _ _).2 this
        -- rewrite in ZMod
        -- (2^n - 3) = 0 ⇒ 2^n = 3
        simpa [pow_succ, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using
          (eq_add_of_sub_eq (by
            -- in ZMod p
            have : ((2 ^ (2 * ta + 2) - 3 : ℕ) : ZMod p) = 0 := by
              simpa using this
            exact this))
      have hmodb : (2 ^ (2 * tb + 2) : ZMod p) = 3 := by
        have : (p : ℕ) ∣ (2 ^ (2 * tb + 2) - 3) := hp2
        have := (ZMod.natCast_zmod_eq_zero_iff_dvd _ _).2 this
        simpa [pow_succ, sub_eq_add_neg, add_comm, add_left_comm, add_assoc] using
          (eq_add_of_sub_eq (by
            have : ((2 ^ (2 * tb + 2) - 3 : ℕ) : ZMod p) = 0 := by
              simpa using this
            exact this))
      -- Then 2^(2*(ta+1)) = 2^(2*(tb+1)) in ZMod p, so 2^(2*(ta+1 - (tb+1))) = 1,
      -- which implies 3 is a square root of 1, forcing p = 3, contradiction since 3 ∤ 2^(even)-3.
      have hsq : (3 : ZMod p) ^ 2 = 1 := by
        -- since 3 = 2^(2k), it is a square: 3^2 = 2^(4k) = (2^(2k))^2
        -- also equals (2^(2l))^2, hence consistent; now use Fermat little theorem to get ±1, but keep simple:
        -- in a field, (2^(2k))*(2^(2k)) = 2^(4k); not enough. Instead:
        -- from equality of 2^(2k) and 2^(2l), we get 3=3; use that 2^(2k) is a square, so 3 is a square.
        -- A prime p dividing 2^(2k)-3 implies 3 is a quadratic residue; similarly for 2^(2l)-3.
        -- We'll use a direct contradiction mod 3: conclude p=3 via a classical IMO lemma is out of scope.
        -- fallback: use `Nat.coprime_pow_left_iff`? Not available.
        -- As a minimal, accept contradiction by showing p=3 and then 3∤..., using ZMod computation.
        have : (2 ^ (2 * ta + 2) : ZMod p) = (2 ^ (2 * tb + 2) : ZMod p) := by
          simpa [hmoda, hmodb]
        -- square both sides gives 3^2=3^2; trivial; take hsq = 1 by using characteristic p with p=2? impossible.
        -- We instead use that in ZMod p, 2 is invertible (p prime, p≠2); still hard.
        -- Provide hsq as 1 by a simple computation in ZMod p when p=3 later.
        sorry
      exact h (by
        -- derive contradiction from hsq; placeholder
        sorry)
    simpa [this]
  exact this
