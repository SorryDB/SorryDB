```lean
lemma IsBinomialRandom.identDistrib_mem_edgeSet (hG : IsBinomialRandom G p P) :
    IdentDistrib (fun ω ↦ e₁ ∈ (G ω).edgeSet) (fun ω ↦ e₂ ∈ (G ω).edgeSet) P P := by
  classical
  have hlaw : HasLaw G G(V, p) P := hG
  have h₁ : HasLaw (fun ω ↦ e₁ ∈ (G ω).edgeSet) (fun g : SimpleGraph V ↦ e₁ ∈ g.edgeSet) (G(V, p)) P :=
    (hlaw.comp (measurable_mem measurable_edgeSet))
  have h₂ : HasLaw (fun ω ↦ e₂ ∈ (G ω).edgeSet) (fun g : SimpleGraph V ↦ e₂ ∈ g.edgeSet) (G(V, p)) P :=
    (hlaw.comp (measurable_mem measurable_edgeSet))
  have hcod : IdentDistrib (fun g : SimpleGraph V ↦ e₁ ∈ g.edgeSet) (fun g : SimpleGraph V ↦ e₂ ∈ g.edgeSet)
      (G(V, p)) (G(V, p)) := by
    simpa [IdentDistrib, Measure.map_map (by fun_prop) (by fun_prop)] using congrArg (Measure.map · (G(V, p)))
      (by
        ext s hs
        simpa [binomialRandom_apply' (V := V) (p := p), Set.image_image, Function.comp] )
  exact (h₁.identDistrib h₂ hcod)
