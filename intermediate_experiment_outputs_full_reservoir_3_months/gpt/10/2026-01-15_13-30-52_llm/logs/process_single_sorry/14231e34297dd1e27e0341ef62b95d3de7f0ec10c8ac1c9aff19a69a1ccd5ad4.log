```lean
import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1984_p6
  (a b c d k m : ℕ)
  (h₀ : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d)
  (h₁ : Odd a ∧ Odd b ∧ Odd c ∧ Odd d)
  (h₂ : a < b ∧ b < c ∧ c < d)
  (h₃ : a * d = b * c)
  (h₄ : a + d = 2^k)
  (h₅ : b + c = 2^m) :
  a = 1 := by
  have haodd : Odd a := h₁.1
  have hdodd : Odd d := h₁.2.2.2
  have hsumodd : Odd (a + d) := haodd.add hdodd
  have hpow : Odd (2 ^ k) := by
    simpa [h₄] using hsumodd
  have hk0 : k = 0 := by
    by_contra hk
    have hkpos : 0 < k := Nat.pos_of_ne_zero hk
    have : Even (2 ^ k) := by
      simpa [Nat.even_iff, pow_succ, Nat.mul_mod, Nat.pow_mod] using (even_pow hkpos)
    exact hpow.not_even this
  have hadd : a + d = 1 := by
    simpa [hk0] using h₄
  have ha0 : 0 < a := h₀.1
  have hd0 : 0 < d := h₀.2.2.2
  have ha1 : a ≤ 1 := by
    have : a ≤ a + d := Nat.le_add_right a d
    simpa [hadd] using this
  have h1le : 1 ≤ a := Nat.succ_le_iff.2 ha0
  exact Nat.le_antisymm ha1 h1le
```
