import Mathlib.Analysis.SpecialFunctions.Pow.Real
import Mathlib.Combinatorics.Additive.AP.Three.Defs

open Finset Real

theorem int {A : Finset ℕ} {N : ℕ} (hAN : A ⊆ range N) (hA : ThreeAPFree (α := ℕ) A) :
    ∃ c > 0, #A ≤ N / exp (- c * log N ^ (12⁻¹ : ℝ)) := by
  refine ⟨1, by norm_num, ?_⟩
  have hcard : (A.card : ℝ) ≤ N := by
    have hle : A.card ≤ N := by
      exact card_le_of_subset hAN
    exact_mod_cast hle
  have hpos : (0 : ℝ) < exp (log (N : ℝ) ^ (12⁻¹ : ℝ)) := by
    simpa using (exp_pos (log (N : ℝ) ^ (12⁻¹ : ℝ)))
  have hexp : (exp (-((1 : ℝ)) * log (N : ℝ) ^ (12⁻¹ : ℝ)))⁻¹ = exp (log (N : ℝ) ^ (12⁻¹ : ℝ)) := by
    simp [mul_assoc, mul_comm, mul_left_comm]
  have : (A.card : ℝ) ≤ (N : ℝ) * exp (log (N : ℝ) ^ (12⁻¹ : ℝ)) := by
    have : (N : ℝ) ≤ (N : ℝ) * exp (log (N : ℝ) ^ (12⁻¹ : ℝ)) := by
      simpa [one_mul] using (le_mul_of_one_le_right (le_of_lt (Nat.cast_nonneg N))
        (le_of_lt hpos))
    exact hcard.trans this
  simpa [div_eq_mul_inv, hexp] using this
