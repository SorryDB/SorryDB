  filter_upwards [hτtop] with ω hω
  rcases hω with ⟨n, hn⟩
  have hrc :
      Function.RightContinuous
        (stoppedProcess (fun i ↦ {ω | ⊥ < τ n ω}.indicator (X i)) (τ n) · ω) :=
    hτX n ω
  have hst :
