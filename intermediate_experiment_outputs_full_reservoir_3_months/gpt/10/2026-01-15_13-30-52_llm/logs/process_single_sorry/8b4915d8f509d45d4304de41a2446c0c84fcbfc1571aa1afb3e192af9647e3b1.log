    refine Set.mem_iUnion.mpr ⟨N, ?_⟩
    refine Set.mem_iUnion.mpr ⟨hN, ?_⟩
    exact hx
  have hsubset' : B N hN ⊆ D := by
    simpa [h_eq] using hsubset
  have hsSup_le : sSup (B N hN) ≤ N := by
    have : sSup (B N hN) ≤ sSup (SetLike.coe D) :=
      (sSup_le_sSup hsubset').trans (le_of_eq D.sSup_eq_top)
    simpa [hB N hN, le_top] using this
  have hEq : N = sSup (B N hN) := by
    exact (hB N hN).symm
  have hsSup_eq : sSup (B N hN) = N := by
    exact le_antisymm hsSup_le (by simpa [hEq] using le_rfl)
  have hEqSet : B N hN = {N} := by
    apply Set.eq_singleton_iff_unique_mem.mpr
    refine ⟨?_, ?_⟩
    · have : N ∈ B N hN := by
        by_contra hNnot
        have hle : sSup (B N hN) ≤ ⊥ := by
          refine sSup_le ?_
          intro x hx
          have : x = ⊥ := by
            have hxD : x ∈ D := hsubset' hx
            have hdisj :
                Disjoint x N := by
              have hxne : x ≠ N := by
                intro hxn
                exact hNnot (hxn ▸ hx)
              let s : Set (PersistenceSubmodule M) := {x, N}
              have hs : s ≤ D.carrier := by
                intro Y hY
                rcases hY with ⟨hmem⟩
                · exact hmem ▸ hxD
                · subst Y; exact hN
              exact (sSupIndep_pair (by simpa [hxne])).mp
                (sSupIndep.mono D.sSupIndep' hs)
            have : x ≤ x ⊓ N := le_inf le_rfl (by
              have : x ≤ N := by
