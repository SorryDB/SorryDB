            simpa [le_bot_iff] using this
          simpa [this]
        have : sSup (B N hN) = ⊥ := by
          exact le_antisymm hle bot_le
        have : N = (⊥ : PersistenceSubmodule M) := by
          simpa [hsSup_eq] using this
        exact (hB'' N hN) (this ▸ by
          have : (⊥ : PersistenceSubmodule M) = ⊥ := rfl
          simpa [this])
      exact this
    · intro x hx
      have hxle : x ≤ N := by
        have : x ≤ sSup (B N hN) := le_sSup hx
        simpa [hsSup_eq] using this
      have hxD : x ∈ D := hsubset' hx
      by_contra hxne
      have hdisj : Disjoint x N := by
        let s : Set (PersistenceSubmodule M) := {x, N}
        have hs : s ≤ D.carrier := by
          intro Y hY
          rcases hY with ⟨hmem⟩
          · exact hmem ▸ hxD
          · subst Y; exact hN
        exact (sSupIndep_pair (by simpa [hxne])).mp (sSupIndep.mono D.sSupIndep' hs)
      have : x ≤ (⊥ : PersistenceSubmodule M) :=
