lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ :=
by
  classical
  let X' : ι → Ω → ℝ := fun i ω ↦ X i ω - X n ω
  have hX' : Martingale X' 𝓕 μ := hX.martingale_sub hX.submartingale_const
  have hXn_int : Integrable (X n) μ := by
    simpa using (hX.integrable n)
  have hUI : UniformIntegrable (fun i ↦ stoppedValue X' (τ i)) 1 μ :=
    (hX'.uniformIntegrable_stoppedValue τ hτ (n := n) hτ_le)
  have hUI_add :
      UniformIntegrable (fun i ↦ stoppedValue X' (τ i) + X n) 1 μ := by
    have hconst : UniformIntegrable (fun _ : ℕ ↦ X n) 1 μ :=
      uniformIntegrable_const le_rfl (by simp) (memLp_one_iff_integrable.2 hXn_int)
    simpa [Pi.add_def] using (hUI.add (p := 1) le_rfl hconst)
  simpa [X', stoppedValue_sub, sub_eq_add_neg, add_assoc, add_left_comm, add_comm] using hUI_add
```
