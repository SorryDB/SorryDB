lemma biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero :
  biasedUpdateState net x i ≠ x → biasedLocalField net x i ≠ 0 → biasedEnergyDiff net x i < 0 := by
  intro hne hlf
  have h0 : biasedEnergyDiff net x i ≠ 0 := by
    intro hEq
    have h :=
      biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField (net := net) (x := x) (i := i)
    have h' :
        -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i = 0 := by
      simpa [biasedEnergyDiff, hEq] using congrArg id h
    have hmul0 :
        ((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i = 0 := by
      have : -(((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i) = 0 := by
        simpa using h'
      simpa using (neg_eq_zero.mp this)
    have hdiff0 :
        ((biasedUpdateState net x i i).toReal - (x i).toReal) = 0 := by
      have := mul_eq_zero.mp hmul0
      cases this with
      | inl hdiff => exact hdiff
      | inr hlf0 => exact (False.elim (hlf hlf0))
    have hiEq : biasedUpdateState net x i i = x i := by
      apply SpinState.toReal_injective
      have : (biasedUpdateState net x i i).toReal = (x i).toReal := by linarith
      simpa using this
    have hxEq : biasedUpdateState net x i = x := by
      funext j
      by_cases hj : j = i
      · subst hj
        simpa using hiEq
      · simpa [biasedUpdateState, Function.update, hj]
    exact hne hxEq
  have hle : biasedEnergyDiff net x i ≤ 0 := biasedEnergy_decreasing (net := net) (x := x) (i := i)
  exact lt_of_le_of_ne hle (Ne.symm h0)
```
