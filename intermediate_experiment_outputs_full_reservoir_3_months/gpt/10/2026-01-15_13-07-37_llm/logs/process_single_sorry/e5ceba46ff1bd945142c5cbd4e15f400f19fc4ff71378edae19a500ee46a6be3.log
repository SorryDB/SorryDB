@[reducible] def Eq.ndrec.{u1, u2} : {α : Sort u2} →
  {a : α} → {motive : α → Sort u1} → motive a → {b : α} → a = b → motive b :=
fun {α} {a} {motive} m {b} h => h ▸ m
theorem Eq.trans.{u} : ∀ {α : Sort u} {a b c : α}, @Eq.{u} α a b → @Eq.{u} α b c → @Eq.{u} α a c :=
fun {α : Sort u} {a b c : α} (h₁ : @Eq.{u} α a b) (h₂ : @Eq.{u} α b c) =>
  @Eq.rec.{0, u} α b (fun (x : α) (h : @Eq.{u} α b x) => @Eq.{u} α a x) h₁ c h₂
def Eq.mp.{u} : {α β : Sort u} → @Eq.{u + 1} (Sort u) α β → α → β :=
fun {α β : Sort u} (h : @Eq.{u + 1} (Sort u) α β) (a : α) =>
