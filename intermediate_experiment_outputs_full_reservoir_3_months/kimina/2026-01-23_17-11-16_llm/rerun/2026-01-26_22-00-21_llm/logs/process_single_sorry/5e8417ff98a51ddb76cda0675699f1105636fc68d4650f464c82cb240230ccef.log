nd =]\ntheorem length_scanr {f : α → β → β} (b : β) (l : List α) :\n    length (scanr f b l) = l.length + 1 := by\n  induction l <;> simp_all\n\ntheorem head_scanr {f : α → β → β} (h : 0 < l.length) :\n    (scanr f b l).head h = b := by\n  induction l with\n  | nil => simp at h\n  | cons a l ih =>\n    simp [head_cons, ih]\n\ntheorem getLast?_scanr {f : α → β → β} : (scanr f b l).getLast? = some b := by\n  simp [getLast?]\n  split\n  · exact absurd ‹_› (by simp)\n  · simp [←‹_›, head_scanr]\n\ntheorem getLast_scanr {f : α → β → β} (h : 0 < l.length) :\n    (scanr f b l).getLast h = b :=",
