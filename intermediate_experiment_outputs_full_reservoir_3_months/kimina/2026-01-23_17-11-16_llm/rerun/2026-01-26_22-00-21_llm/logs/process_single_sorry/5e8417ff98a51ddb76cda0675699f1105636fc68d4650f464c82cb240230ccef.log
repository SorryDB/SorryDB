    (List.scanl f b l).length = l.length + 1 := by
  induction l <;> simp_all

theorem length_scanr {f : α → β → β} (b : β) (l : List α) :
    (List.scanr f b l).length = l.length + 1 := by
  induction l <;> simp_all

/-! ### List.reverse -/

theorem reverse_scanl {f : α → β → β} (b : β) (l : List α) :
    (List.reverse l).scanl f b = List.reverse (List.scanr f b l) := by
  induction l generalizing b with
  | nil => rfl
  | cons a l ih =>
    simp [List.reverse, List.scanl, List.scanr, ih]
    <;> aesop

theorem reverse_scanr {f : α → β → β} (b : β) (l : List α) :
    (List.reverse l).scanr f b = List.reverse (List.scanl f b l) := by
  induction l generalizing b with
  | nil => rfl
  | cons a l ih =>
    simp [List.reverse, List.scanl, List.scanr, ih]
    <;> aesop

/-! ### partialSums/partialProd -/

@[simp, grind =]
theorem length_partialSums [Add α] [Zero α] {l : List α} :
    l.partialSums.length = l.length + 1 := by
  simp [partialSums]

@[simp, grind =]
theorem length_partialProds [Mul α] [One α] {l : List α} :
    l.partialProds.length = l.length + 1 := by
  simp [partialProds]

