          <;> try { tauto }
          <;> try { aesop }
          <;> try { tauto }
          <;> try { tauto }
          <;> try { tauto }
        }

theorem getElem?_scanl {f : β → γ → β} (h : i < (scanl f b l).length) :
    (scanl f b l)[i]? = b := by
  simp [getElem?_cons, h, getElem_scanl h]

theorem getElem?_scanr {f : α → β → β} (h : i < (scanr f b l).length) :
