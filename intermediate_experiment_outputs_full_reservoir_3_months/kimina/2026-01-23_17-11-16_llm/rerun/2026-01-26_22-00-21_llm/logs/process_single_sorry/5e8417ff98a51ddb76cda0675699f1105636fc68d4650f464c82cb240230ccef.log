      "\n  induction L generalizing i with\n  | nil => simp at h\n  | cons l L ih =>\n    simp [List.length] at *\n    split <;> rename_i h'\n    · -- Case where i = 0\n      simp [getElem_nil, getElem_cons, getElem_append, List.getElem?_append_right, List.getElem?_append_left, List.getElem?_cons, List.getElem?_tail, List.getElem?_head] at *\n      all_goals omega\n    · -- Case where i > 0\n      simp [List.length, take_append, take_cons, take_nil, List.getElem?_append_right, List.getElem?_append_left, List.getElem?_cons, List.getElem?_tail, List.getElem?_head, findIdx_cons, findIdx_eq, findIdx_lt, findIdx_le] at *\n      all_goals omega\n```\n</think>\n```lean\nimport Mathlib\n\n/-! List operations -/\n@[simp, native_decide]\ntheorem length_append {l₁ l₂ : List α} : (l₁ ++ l₂).length = l₁.length + l₂.length := by simp\n\n@[simp, native_decide]\ntheorem length_cons {a : α} {l : List α} : (a :: l).length = l.length + 1 := by simp\n\n@[simp, native_decide]\ntheorem length_singleton : (a : α).length = 1 := by simp\n\n@[simp, native_decide]\ntheorem length_nil : [].length = 0 := by simp\n\n@[simp, native_decide]\ntheorem head_cons {a : α} {l : List α} : (a :: l).head = a := by simp\n\n@[simp, native_decide]\ntheorem head_singleton : (a :: b).head = a := by simp\n\n@[simp, native_decide]\ntheorem head_nil : [].head = a := by simp\n\n@[simp, native_decide]\ntheorem tail_cons {a : α} {l : List α} : (a :: l).tail = l := by simp\n\n@[simp, native_decide]\ntheorem tail_singleton : (a :: b).tail = [b] := by simp\n\n@[simp, native_decide]\ntheorem tail_nil : [].tail = [] := by simp\n\n@[simp, native_decide]\ntheorem getElem_cons {a : α} {l : List α} {i : Nat} : (a :: l)[i] = if i = 0 then a else l[i - 1] := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.getElem_cons]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem getElem_singleton {a : α} {i : Nat} : (a :: b)[i] = if i = 0 then a else b := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.getElem_singleton]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem getElem_nil {i : Nat} : (a : α)[][i] = none := by simp\n\n@[simp, native_decide]\ntheorem getElem?_cons {a : α} {l : List α} {i : Nat} : (a :: l)[i]? = if i = 0 then some a else l[i - 1]? := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.getElem?_cons]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem getElem?_singleton {a : α} {i : Nat} : (a :: b)[i]? = if i = 0 then some a else if i = 1 then some b else none := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.getElem?_singleton]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem getElem?_nil {i : Nat} : (a : α)[][i]? = none := by simp\n\n@[simp, native_decide]\ntheorem take_cons {a : α} {l : List α} {i : Nat} : (a :: l).take i = if i = 0 then [] else a :: l.take (i - 1) := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.take_cons]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem take_singleton {a : α} {i : Nat} : (a :: b).take i = if i = 0 then [] else if i = 1 then [a] else [a, b] := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.take_singleton]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem take_nil : [].take i = [] := by simp\n\n@[simp, native_decide]\ntheorem drop_cons {a : α} {l : List α} {i : Nat} : (a :: l).drop i = l.drop i := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.drop_cons]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem drop_singleton {a : α} {i : Nat} : (a :: b).drop i = if i = 1 then [b] else [b] := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.drop_singleton]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem drop_nil : [].drop i = [] := by simp\n\n/-! List.foldl/foldr -/\n@[simp, native_decide]\ntheorem foldl_cons {f : β → α → β} {b : β} {a : α} {l : List α} :\n    foldl f b (a :: l) = f b a :: foldl f (f b a) l := by\n  simp [List.foldl_cons]\n\n@[simp, native_decide]\ntheorem foldl_singleton : foldl f b (a :: b) = [f b a, f (f b a) b] := by\n  simp [List.foldl_singleton]\n\n@[simp, native_decide]\ntheorem foldl_nil : foldl f b [] = [b] := by\n  simp [List.foldl_nil]\n\n@[simp, native_decide]\ntheorem foldr_cons {f : α → β → β} {b : β} {a : α} {l : List α} :\n    foldr f b (a :: l) = f a b :: foldr f (f a b) l := by\n  simp [List.foldr_cons]\n\n@[simp, native_decide]\ntheorem foldr_singleton : foldr f b (a :: b) = [f a b, f b a] := by\n  simp [List.foldr_singleton]\n\n@[simp, native_decide]\ntheorem foldr_nil : foldr f b [] = [b] := by\n  simp [List.foldr_nil]\n\n/-! List.scanl -/\n\n@[simp, native_decide]\ntheorem length_scanl {f : α → β → β} (b : β) (l : List α) :\n    length (scanl f b l) = l.length + 1 := by\n  induction l <;> simp_all\n\n@[simp, native_decide]\ntheorem length_scanl_cons {f : α → β → β} {b : β} {a : α} {l : List α} :\n    length (scanl f b (a :: l)) = l.length + 2 := by\n  simp [List.length, List.scanl_cons]\n\n@[simp, native_decide]\ntheorem length_scanl_singleton {f : α → β → β} {b : β} {a : α} :\n    length (scanl f b (a :: b)) = 2 := by\n  simp [List.length, List.scanl_singleton]\n\n@[simp, native_decide]\ntheorem length_scanl_nil {f : α → β → β} {b : β} :\n    length (scanl f b []) = 1 := by\n  simp [List.length, List.scanl_nil]\n\n@[simp, native_decide]\ntheorem head_scanl {f : α → β → β} {b : β} {a : α} {l : List α} :\n    (scanl f b (a :: l)).head = f b a := by\n  simp [List.head_cons, List.scanl_cons]\n\n@[simp, native_decide]\ntheorem head_scanl_singleton {f : α → β → β} {b : β} {a : α} :\n    (scanl f b (a :: b)).head = f b a := by\n  simp [List.head_cons, List.scanl_singleton]\n\n@[simp, native_decide]\ntheorem head_scanl_nil {f : α → β → β} {b : β} :\n    (scanl f b []).head = b := by\n  simp [List.head_cons, List.scanl_nil]\n\n@[simp, native_decide]\ntheorem tail_scanl {f : α → β → β} {b : β} {a : α} {l : List α} :\n    (scanl f b (a :: l)).tail = (f b a :: (f b a) :: (f b a) :: l).tail := by\n  simp [List.tail_cons, List.scanl_cons]\n\n@[simp, native_decide]\ntheorem tail_scanl_singleton {f : α → β → β} {b : β} {a : α} :\n    (scanl f b (a :: b)).tail = [f b a, f (f b a) b] := by\n  simp [List.tail_cons, List.scanl_singleton]\n\n@[simp, native_decide]\ntheorem tail_scanl_nil {f : α → β → β} {b : β} :\n    (scanl f b []).tail = [b] := by\n  simp [List.tail_cons, List.scanl_nil]\n\n@[simp, native_decide]\ntheorem getElem_scanl {f : α → β → β} {b : β} {a : α} {l : List α} {i : Nat} :\n    (scanl f b (a :: l))[i] = if i = 0 then f b a else (f b a :: (f b a) :: (f b a) :: l)[i - 1] := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.getElem_cons, List.scanl_cons]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem getElem_scanl_singleton {f : α → β → β} {b : β} {a : α} {i : Nat} :\n    (scanl f b (a :: b))[i] = if i = 0 then f b a else if i = 1 then f b (f b a) else [f b a, f b (f b a)] := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.getElem_cons, List.scanl_singleton]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem getElem_scanl_nil {f : α → β → β} {b : β} {i : Nat} :\n    (scanl f b [])[i] = if i = 0 then b else [b] := by\n  induction i with\n  | zero => simp\n  | succ i ih =>\n    simp [List.getElem_cons, List.scanl_nil]\n    split <;> try { simp_all }\n    all_goals try { omega }\n\n@[simp, native_decide]\ntheorem getElem?_scanl {f : α → β → β} {b : β} {a : α} {l : List α} {i : Nat} :\n    (scanl f b (a :: l))[i]? = if 