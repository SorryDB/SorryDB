import Mathlib

/-! ### List.scanl -/

@[simp, grind =]
theorem scanl_nil {f : α → β → β} (b : β) : scanl f b [] = [b] := by
  simp [scanl]

@[simp]
theorem scanl_ne_nil {f : α → β → β} : ∀ l, ∀ b, (l ≠ []) → (scanl f b l).length > 0 := by
  intro l b hl
  simp [scanl]

@[simp, grind =]
theorem length_scanl {f : α → β → β} (b : β) (l : List α) :
    (scanl f b l).length = l.length + 1 := by
  simp [scanl]

@[simp, grind =]
theorem getElem_scanl {f : α → β → β} (h : i < (scanl f b l).length) :
    (scanl f b l)[i] = f b (l[i]) := by
  induction l generalizing i with
  | nil => simp at h
  | cons a l ih =>
    simp only [getElem_cons, ih]
    cases i <;> simp_all

@[simp, grind =]
theorem getElem?_scanl {f : α → β → β} (h : i < l.length + 1) :
    (scanl f b l)[i]? = some (f b (l[i])) := by
  simp [getElem_scanl]
  split <;> try { tauto }
  <;> try { omega }
  <;> try { tauto }
  <;> try { omega }
  all_goals try { tauto }
  all_goals try { omega }
  all_goals try { tauto }
  all_goals try { omega }
  all_goals try { tauto }
  all_goals try { omega }

@[simp, grind =]
theorem take_scanl {f : α → β → β} (l : List α) (i : Nat) :
    (scanl f b l).take i = (l.take i).scanl f b := by
  induction l generalizing i with
  | nil => simp
  | cons a l ih =>
    simp only [take_cons, ih]
    cases i <;> simp_all

theorem head_scanl {f : α → β → β} (h : (scanl f b l).length > 0) :
    (scanl f b l).head h = b := by
  simp [h]

theorem getLast_scanl {f : α → β → β} (h : (scanl f b l).length > 0) :
    (scanl f b l).getLast h = f b (l.getLast h) := by
  induction l generalizing h with
  | nil => simp at h
  | cons a l ih =>
    simp only [getLast_cons, ih]
    cases h <;> simp_all

theorem getLast?_scanl {f : α → β → β} : (scanl f b l).getLast? = some (f b (l.getLast?)) := by
