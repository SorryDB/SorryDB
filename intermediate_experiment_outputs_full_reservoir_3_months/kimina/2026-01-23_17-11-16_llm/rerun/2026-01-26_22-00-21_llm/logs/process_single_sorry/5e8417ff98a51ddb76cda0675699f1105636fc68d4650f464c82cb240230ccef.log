import Mathlib
import List
import Nat

/-!### List.scanl -/

@[simp, grind =]
theorem scanl_nil {f : β → γ → β} (b : β) : scanl f b [] = [b] := by
  simp [scanl]

@[simp]
theorem scanl_ne_nil {f : β → γ → β} (b : β) : scanl f b [a] ≠ [] := by
  simp [scanl]

@[simp, grind =]
theorem length_scanl {f : β → γ → β} (b : β) (l : List γ) :
    length (scanl f b l) = l.length + 1 := by
  induction l generalizing b
  case nil => simp
  case cons head tail ih => simp [ih]

theorem scanl_cons {f : β → γ → β} :
    ∀ (b : β) (a : γ) (l : List γ), 
    (b :: l).scanl f = [b] ++ (b :: l).tail.scanl f := by
  intro b a l
  simp only [List.cons.scanl, List.cons.append, List.cons.tail, List.head_cons, List.cons.getTail]
  simp

theorem scanl_singleton {f : β → γ → β} (b : β) : [a].scanl f = [f a b, b] := by
  simp [scanl]

@[simp, grind =]
theorem head_scanl {f : β → γ → β} (h : (l : List γ).scanl f ≠ []) :
    (l.scanl f).head h = f (l.getTail 0) (l.head) := by
  simp [head_cons]

@[simp, grind =]
theorem head?_scanl {f : β → γ → β} (h : (l : List γ).scanl f ≠ []) :
    (l.scanl f).head? h = some (f (l.getTail 0) (l.head)) := by
  simp [head_cons]

@[simp, grind =]
theorem getLast?_scanl {f : β → γ → β} (h : (l : List γ).scanl f ≠ []) :
    (l.scanl f).getLast? = some b := by
  simp [getLast_cons]

theorem getLast_scanl {f : β → γ → β} (h : (l : List γ).scanl f ≠ []) :
    (l.scanl f).getLast h = b := by
  simp [getLast_cons]

@[simp, grind =]
theorem tail_scanl {f : β → γ → β} (l : List γ) :
    l.scanl f = l.head :: l.tail.scanl f := by
  simp [List.cons.scanl, List.getTail]

@[simp, grind =]
theorem drop_scanl {f : β → γ → β} (l : List γ) (i : Nat) :
    l.drop i = (List.drop i l).scanl f := by
  induction i generalizing l
  case zero => simp
  case succ =>
    induction l with
    | nil => simp
    | cons head tail ih =>
      simp [List.drop, ih]

theorem getElem_scanl {f : β → γ → β} (l : List γ) (i : Nat) (h : i < (l : List γ).length) :
    l.getElem i = (l.take i).getLast (f (l.getTail i) (l[i]) ) := by
  induction l generalizing i
  case zero => simp
  case succ =>
    induction i generalizing l
    case zero => simp
    case succ =>
      simp only [List.getElem_succ, List.getLast_cons, List.take_succ, List.getTail_cons]
      simp

@[simp, grind =]
theorem getElem?_scanl {f : β → γ → β} (l : List γ) (i : Nat) :
    l.getElem? i = if i < l.length then some (l.getElem i) else none := by
  split <;> simp

theorem getElem?_scanl_zero {f : β → γ → β} (l : List γ) :
    l.getElem? 0 = some (l.getElem 0) := by
  simp

theorem getElem?_scanl_of_lt {f : β → γ → β} (l : List γ) (h : i < l.length) :
    l.getElem? i = some (l.getElem i) := by
  simp [h]

theorem getElem?_scanl_of_ge {f : β → γ → β} (l : List γ) (h : i ≥ l.length) :
    l.getElem? i = none := by
  simp [h]

