import Mathlib

/-! ### List.foldl -/

theorem foldl_nil {f : β → γ → β} (b : β) : foldl f b [] = b := by
  simp

@[simp]
theorem foldl_ne_nil {f : β → γ → β} (b : β) : foldl f b [a] ≠ [] := by
  simp

@[simp, grind =]
theorem foldl_cons {f : β → γ → β} (a : γ) (l : List γ) (b : β) :
    foldl f b (a :: l) = f b a :: foldl f (f b a) l := by
  simp only [foldl, cons.injEq, and_true]
  induction l generalizing a with
  | nil => rfl
  | cons _ _ ih => simp only [ih, cons.injEq, and_true]; rfl

theorem foldl_singleton {f : β → γ → β} : foldl f b [a] = [f b a] := by
  simp

@[simp, grind =]
theorem foldl_reverse {f : γ → β → β} (b : β) (l : List γ) :
    foldl f b l.reverse = reverse (foldr (fun x y => f x y) b l) := by
  induction l generalizing b
  case nil => rfl
  case cons head tail ih => simp [reverse_cons, ih]

/-!### List.foldr -/

theorem foldr_nil {f : α → β → β} (b : β) : foldr f b [] = b := by
  simp

@[simp]
theorem foldr_ne_nil {f : α → β → β} (b : β) : foldr f b [a] ≠ [] := by
  simp

@[simp, grind =]
theorem foldr_cons {f : α → β → β} (a : α) (l : List α) (b : β) :
    foldr f b (a :: l) = f a b :: foldr f (f a b) l := by
  simp only [foldr, cons.injEq, and_true]
  induction l generalizing a with
  | nil => rfl
  | cons _ _ ih => simp only [ih, cons.injEq, and_true]; rfl

theorem foldr_singleton {f : α → β → β} : foldr f b [a] = [f a b] := by
  simp

@[simp, grind =]
theorem foldr_reverse {f : α → β → β} (b : β) (l : List α) :
    foldr f b l.reverse = reverse (foldl (fun x y => f y x) b l) := by
  induction l generalizing b
  case nil => rfl
  case cons head tail ih => simp [reverse_cons, ih]

/-!### List.scanl -/

@[simp, grind =]
theorem scanl_nil {f : β → γ → β} (b : β) : scanl f b [] = [b] := by
  simp

@[simp]
theorem scanl_ne_nil {f : β → γ → β} (b : β) : scanl f b [a] ≠ [] := by
  simp [scanl]

@[simp, grind =]
theorem scanl_cons {f : β → γ → β} :
    scanl f b (a :: l) = [f b a] ++ (scanl f (f b a) l).tail := by
  induction l generalizing b
  case nil => simp
  case cons head tail ih => simp [ih]

theorem scanl_singleton {f : β → γ → β} : scanl f b [a] = [f b a, b] := by
  simp

@[simp, grind =]
theorem length_scanl {f : β → γ → β} (b : β) (l : List γ) :
    length (scanl f b l) = l.length + 1 := by induction l <;> simp_all

theorem scanl_reverse {f : β → γ → β} (b : β) (l : List γ) :
    (scanl f b l).reverse = (foldr (fun x y => f y x) b l).reverse := by
  induction l generalizing b
  case nil => rfl
  case cons head tail ih => simp [ih]

theorem head_scanl {f : β → γ → β} (h : (scanl f b l).length > 0) :
    (scanl f b l).head h = f b (l.get 0 h) := by
  induction l <;> simp_all

theorem tail_scanl {f : β → γ → β} (h : 0 < l.length) :
    (scanl f b l).tail = (f b l.get 0 (by linarith)).tail ++ (scanl f (f b l.get 0 (by linarith)) (l.tail)) := by
  induction l <;> simp_all

@[simp, grind =]
theorem getElem_scanl {f : β → γ → β} (h : i < (scanl f b l).length) :
    (scanl f b l)[i] = f b (l.get i h) := by
  induction l generalizing i with
  | nil => simp at h
  | cons _ _ ih => cases i <;> simp [ih] at h ⊢

@[simp, grind =]
theorem getElem?_scanl {f : β → γ → β} (h : i < l.length + 1) :
    (scanl f b l)[i]? = some (f b (l.get i h)) := by
  simp [h]
  split
  · exact absurd ‹_› (by linarith)
  · simp [h]

theorem getElem_scanl_zero {f : β → γ → β} : (scanl f b l)[0] = f b l.get 0 ‹_› := by
  simp

theorem getElem?_scanl_zero {f : β → γ → β} : (scanl f b l)[0]? = some (f b l.get 0 ‹_›) := by
  simp

theorem getElem?_scanl_of_lt {f : β → γ → β} (h : i < l.length + 1) :
    (scanl f b l)[i]? = some (f b (l.get i h)) := by
  simp [h]

