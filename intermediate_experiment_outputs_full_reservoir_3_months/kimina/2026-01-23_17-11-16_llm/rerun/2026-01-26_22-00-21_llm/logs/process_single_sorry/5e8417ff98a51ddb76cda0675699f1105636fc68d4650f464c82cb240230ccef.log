import Mathlib

/-! ### List.scanl -/

@[simp, grind =]
theorem scanl_nil {f : β → γ → β} (b : β) : scanl f b [] = [b] := by
  simp

@[simp]
theorem scanl_ne_nil {f : β → γ → β} : ∀ (l : List γ), scanl f b l ≠ [] → l ≠ [] := by
  intro l hl
  intro h
  simp [h] at hl

@[simp, grind =]
theorem scanl_cons {f : β → γ → β} :
    ∀ (b : β) (a : γ) (l : List γ), 
    (fun (b : β) => 
      (fun (a : γ) => 
        (fun (l : List γ) => 
          (b :: a :: l).foldl f b
        )
      )
    ) b a l = b :: a :: l.foldl f b := by 
  intro b a l
  rfl

theorem length_scanl {f : β → γ → β} (b : β) (l : List γ) :
    length (scanl f b l) = l.length + 1 := by
  induction l <;> simp_all

theorem head_scanl {f : β → γ → β} (h : (b :: l).foldl f b ≠ []) :
    (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l).head h = b := by
  simp

theorem head?_scanl {f : β → γ → β} (h : (b :: l).foldl f b ≠ []) :
