import Mathlib

/-! List properties -/

theorem length_nil {l : List α} : l = [] → l.length = 0 := by
  intro h
  rw [h]
  rfl

theorem length_cons {a : α} {l : List α} : (a :: l).length = l.length + 1 := by
  simp

theorem length_append {l₁ l₂ : List α} : (l₁ ++ l₂).length = l₁.length + l₂.length := by
  induction l₁ generalizing l₂ with
  | nil => simp
  | cons a l ih => simp [ih]

theorem length_singleton {a : α} : ([a] : List α).length = 1 := by
  simp

theorem length_reverse {l : List α} : (l.reverse).length = l.length := by
  induction l <;> simp_all [List.reverse]

theorem length_map {f : β → γ} {l : List β} : (l.map f).length = l.length := by
  induction l <;> simp_all

theorem length_filter {p : β → Prop} {l : List β} : (l.filter p).length ≤ l.length := by
  induction l <;> simp_all

theorem length_foldr {f : α → β → β} {b : β} {l : List α} : (l.foldr f b).length = 1 := by
  simp

theorem length_foldl {f : β → α → β} {b : β} {l : List α} : (l.foldl f b).length = 1 := by
  simp

/-! List access -/

theorem head_nil {l : List α} : l ≠ [] → l.head = l.getLast := by
  intro h
  simp [h]

theorem head_cons {a : α} {l : List α} : (a :: l).head = a := by
  simp

theorem head_reverse {l : List α} : l.length > 0 → (l.reverse).head = l.getLast := by
  intro h
  simp [h]

theorem head_map {f : β → γ} {l : List β} : (l.map f).head = f l.head := by
  simp

theorem head_filter {p : β → Prop} {l : List β} : (l.filter p).head = (l.filter p).getLast := by
  intro h
  simp [h]

theorem head_foldr {f : α → β → β} {b : β} {l : List α} : (l.foldr f b).head = f (l.head) b := by
  simp

theorem head_foldl {f : β → α → β} {b : β} {l : List α} : (l.foldl f b).head = f b l.head := by
  simp

theorem getLast_nil {l : List α} : l = [] → l.getLast = b := by
  intro h
  rw [h]
  simp

theorem getLast_cons {a : α} {l : List α} : (a :: l).getLast = l.getLast := by
  simp

theorem getLast_reverse {l : List α} : l.length > 0 → (l.reverse).getLast = l.head := by
  intro h
  simp [h]

theorem getLast_map {f : β → γ} {l : List β} : (l.map f).getLast = f l.getLast := by
  simp

theorem getLast_filter {p : β → Prop} {l : List β} : (l.filter p).getLast = (l.filter p).head := by
  intro h
  simp [h]

theorem getLast_foldr {f : α → β → β} {b : β} {l : List α} : (l.foldr f b).getLast = b := by
  simp

theorem getLast_foldl {f : β → α → β} {b : β} {l : List α} : (l.foldl f b).getLast = f b l := by
  simp

/-! List indexing -/

theorem getElem_nil {l : List α} (i : Nat) : i < l.length → l[i] = b := by
  intro h
  simp [h]

theorem getElem_cons {a : α} {l : List α} (i : Nat) : i < (a :: l).length → (a :: l)[i] = if i = 0 then a else l[i - 1] := by
  intro h
  induction i with
  | zero => simp
  | succ i ih =>
    cases i with
    | zero => simp
    | succ i =>
      simp [ih]

theorem getElem_reverse {l : List α} (i : Nat) (h : i < l.length) : l.reverse[i] = l[length - 1 - i] := by
  simp [reverse, getElem]

theorem getElem_map {f : β → γ} {l : List β} (i : Nat) (h : i < l.length) : (l.map f).getElem i = f (l.getElem i) := by
  simp [map, getElem]

theorem getElem_filter {p : β → Prop} {l : List β} (i : Nat) (h : i < l.filter p.length) : (l.filter p).getElem i = l.getElem (filterIndices p l i) := by
  simp [filter, getElem]

theorem getElem_foldr {f : α → β → β} {b : β} {l : List α} (i : Nat) (h : i < l.foldr f b.length) : (l.foldr f b)[i] = b := by
  simp [foldr, getElem]

theorem getElem_foldl {f : β → α → β} {b : β} {l : List α} (i : Nat) (h : i < l.foldl f b.length) : (l.foldl f b)[i] = f b l.getElem i := by
  simp [foldl, getElem]

/-! List operations -/

theorem append_nil {l : List α} : l ++ [] = l := by
  simp

theorem append_cons {a : α} {l₁ : List α} {l₂ : List α} : a :: l₁ ++ l₂ = a :: (l₁ ++ l₂) := by
  simp

theorem reverse_nil : [].reverse = [] := by
  simp

theorem reverse_cons {a : α} {l : List α} : (a :: l).reverse = l.reverse ++ [a] := by
  simp [reverse]

theorem map_nil : [].map = [] := by
  simp

theorem map_cons {a : α} {f : β → γ} {l : List β} : (a :: l).map f = a :: (l.map f) := by
  simp

theorem filter_nil : [].filter = [] := by
  simp

theorem filter_cons {a : α} {p : β → Prop} {l : List β} : (a :: l).filter p = if p a then a :: (l.filter p) else l.filter p := by
  simp

theorem foldr_nil {f : α → β → β} {b : β} : [].foldr f b = b := by
  simp

theorem foldr_cons {a : α} {f : α → β → β} {l : List α} {b : β} : (a :: l).foldr f b = f a (l.foldr f b) := by
  simp

theorem foldl_nil {f : β → α → β} {b : β} : [].foldl f b = b := by
  simp

theorem foldl_cons {a : α} {f : β → α → β} {l : List α} {b : β} : (a :: l).foldl f b = l.foldl f (f b a) := by
  simp

/-! List properties -/

theorem isNil_nil {l : List α} : l = [] → l.isNil := by
  intro h
  rw [h]
  simp

theorem isNil_cons {a : α} {l : List α} : (a :: l).isNil := by
  simp

theorem isNil_reverse {l : List α} : l.isNil → (l.reverse).isNil := by
  intro h
  simp [h]

theorem isNil_map {f : β → γ} {l : List β} : l.isNil → (l.map f).isNil := by
  intro h
  simp [h]

