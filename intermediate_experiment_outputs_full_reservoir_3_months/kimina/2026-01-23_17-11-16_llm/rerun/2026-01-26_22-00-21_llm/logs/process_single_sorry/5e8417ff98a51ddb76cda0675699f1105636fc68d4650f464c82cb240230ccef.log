import Mathlib

/-! ### List.scanl -/

@[simp, grind =]
theorem scanl_nil {f : β → γ → β} (b : β) : scanl f b [] = [b] := by
  simp

@[simp]
theorem scanl_ne_nil {f : β → γ → β} : ∀ (l : List γ), scanl f b l ≠ [] → l ≠ [] := by
  intro l hl
  intro h
  simp [h] at hl

@[simp, grind =]
theorem scanl_cons {f : β → γ → β} :
    ∀ (b : β) (a : γ) (l : List γ), 
    (fun (b : β) => 
      (fun (a : γ) => 
        (fun (l : List γ) => 
          (b :: a :: l).foldl f b
        )
      )
    ) b a l = b :: a :: l.foldl f b := by 
  intro b a l
  rfl

theorem length_scanl {f : β → γ → β} (b : β) (l : List γ) :
    length (scanl f b l) = l.length + 1 := by
  induction l <;> simp_all

theorem head_scanl {f : β → γ → β} (h : (b :: l).foldl f b ≠ []) :
    (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l).head h = b := by
  simp

theorem head?_scanl {f : β → γ → β} (h : (b :: l).foldl f b ≠ []) :
    (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l).head? = some b := by
  simp

theorem tail_scanl {f : β → γ → β} (h : 0 < l.length) :
    (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l).tail = (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b (l.tail)) := by
  intro b l h
  simp

@[simp, grind =]
theorem getElem_scanl {f : β → γ → β} (h : i < l.length + 1) :
    (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l)[i] = l[i].foldl f b := by
  induction l generalizing i with
  | nil => simp at h
  | cons a l ih =>
    cases i <;> simp [ih] at h ⊢

@[simp, grind =]
theorem getElem?_scanl {f : β → γ → β} (h : i < l.length + 1) :
    (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l)[i]? = some (l[i].foldl f b) := by
  simp [h]

theorem getElem_scanl_zero {f : β → γ → β} : (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l)[0] = l.foldl f b := by
  simp

theorem getElem?_scanl_zero {f : β → γ → β} : (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l)[0]? = some (l.foldl f b) := by
  simp

theorem getElem?_scanl_of_lt {f : β → γ → β} (h : i < l.length + 1) :
    (fun (b : β) => (fun (l : List γ) => (b :: l).foldl f b) b l)[i]? = some (l[i].foldl f b) := by
  simp [h]

theorem length_scanl_map {f : β → γ → β} {g : α → γ} (b : β) (l : List α) :
    length (scanl f b (l.map g)) = length (l.map g) + 1 := by
  induction l <;> simp_all

theorem length_scanr {f : α → β → β} (b : β) (l : List α) :
    length (scanr f b l) = l.length + 1 := by
  induction l <;> simp_all

theorem length_scanl_reverse {f : β → α → β} (b : β) (l : List α) :
    length (scanl f b l.reverse) = length (l.reverse) + 1 := by
  simp [length_reverse, length_scanl]

theorem length_scanr_reverse {f : α → β → β} (b : β) (l : List α) :
    length (scanr f b l.reverse) = length (l.reverse) + 1 := by
  simp [length_reverse, length_scanr]

theorem length_partialSums [Add α] [Zero α] {l : List α} :
    l.partialSums.length = l.length + 1 := by
  simp [partialSums]

@[simp, grind =]
theorem length_partialProds [Mul α] [One α] {l : List α} :
    l.partialProds.length = l.length + 1 := by
  simp [partialProds]

