import Mathlib

/-! ### List.scanl -/

@[simp, grind =]
theorem scanl_nil {f : β → γ → β} (b : β) : scanl f b [] = [b] := by
  simp

@[simp]
theorem scanl_ne_nil {f : β → γ → β} : ∀ {b : β} (l : List γ), l ≠ [] →
    (scanl f b l).length > 0 := by
  intro l hl
  simp only [ne_nil_iff_length_pos, length_scanl]
  exact hl

@[simp, grind =]
theorem length_scanl {f : β → γ → β} (b : β) (l : List γ) :
    length (scanl f b l) = l.length + 1 := by
  simp [length_scanl]

@[simp, grind =]
theorem head_scanl {f : β → γ → β} (h : (scanl f b l).length > 0) :
    (scanl f b l).head h = b := by
  simp [head_scanl]

@[simp, grind =]
theorem getLast_scanl {f : β → γ → β} (h : (scanl f b l).length > 0) :
    (scanl f b l).getLast h = f b (l.getLast (by simp)) := by
  simp [getLast_scanl]

@[simp, grind =]
theorem getLast?_scanl {f : β → γ → β} (h : (scanl f b l).length > 0) :
    (scanl f b l).getLast? h = some (f b (l.getLast (by simp))) := by
  simp [getLast?_scanl]

@[simp, grind =]
theorem tail_scanl {f : β → γ → β} (h : 0 < (scanl f b l).length) :
    (scanl f b l).tail = (scanl f b l.tail).reverse ++ [f b l.getLast (by simp)] := by
  induction l generalizing b
  case nil => simp at h
  case cons head tail ih => simp [ih]

@[simp, grind =]
theorem head?_scanl {f : β → γ → β} (h : (scanl f b l).length > 0) :
    (scanl f b l).head? = some (f b (l.getLast (by simp))) := by
  simp [head?_scanl]

@[simp, grind =]
theorem getElem_scanl {f : β → γ → β} (h : i < (scanl f b l).length) :
    (scanl f b l)[i] = f (b) (l[i]) := by
  induction l generalizing b
  case nil => simp at h
  case cons head tail ih => cases i <;> simp [ih]

@[simp, grind =]
theorem getElem?_scanl {f : β → γ → β} (h : i < (scanl f b l).length) :
    (scanl f b l)[i]? = some (f (b) (l[i])) := by
  simp [getElem?_scanl]

@[simp, grind =]
theorem take_scanl {f : β → γ → β} (i : Nat) :
    (scanl f b l).take i = (scanl f b (l.take i)) := by
  induction l generalizing b
  case nil => simp
  case cons head tail ih => simp [ih]

@[simp, grind =]
theorem take?_scanl {f : β → γ → β} (i : Nat) :
    (scanl f b l).take? i = some (scanl f b (l.take i)) := by
  simp [take?_scanl]

@[simp, grind =]
theorem drop_scanl {f : β → γ → β} (h : i ≤ l.length) :
    (scanl f b l).drop i = (scanl f b (l.drop i)) := by
  induction l generalizing b
  case nil => simp at h
  case cons head tail ih => cases i <;> simp [ih]

@[simp, grind =]
theorem drop?_scanl {f : β → γ → β} (h : i ≤ l.length) :
    (scanl f b l).drop? i = some (scanl f b (l.drop i)) := by
  simp [drop?_scanl]

theorem list_sum {f : β → γ → β} {b : β} (l : List α) :
