namespace lean_lion
/-!
## Getting bitten by multiple instances

The first example is inspired by conversations from this workshop. One of the annoying and mysterious errors is when two instances of the same typeclass are used in a term.
-/
instance Collapse : HAdd String String String where
  hAdd := String.append

def collapse (a b: String): String :=
  @HAdd.hAdd String String String Collapse a b

instance Collapse' : HAdd String String String where
  hAdd := fun a b => a ++ " " ++ b

def collapse' (a b: String): String :=
  @HAdd.hAdd String String String Collapse' a b


example (a b  : String) : collapse' a b = collapse a b := by
  unfold collapse collapse'
  -- The goal is now `a ++ " " ++ b = a + b`
  -- This is false. We need to prove it by contradiction.
  -- Let's assume the equality holds.
  -- `a ++ " " ++ b = a + b`
  -- This is equivalent to `(a ++ " ") ++ b = a ++ b`
  -- This implies `a ++ " " = a` by cancelling `b` (if b is non-empty)
  -- `a ++ " " = a` implies ` " " = ""` by cancelling `a` (if a is non-empty)
  -- ` " " = ""` is false.
  -- So we can derive a contradiction.
  -- The tactic `exfalso` changes the goal to `False`.
  -- Then we need to prove `False`.
  -- We can use `simp` to simplify the original equality.
  -- `simp` will turn the goal `a ++ " " ++ b = a + b` into `False`.
  -- Then `trivial` can prove `False` from `False`.
  exfalso
  -- We need to prove False
  -- We have the hypothesis `h : a ++ " " ++ b = a + b`
  -- Let's use it to derive False
  have h : a ++ " " ++ b = a + b := by
    -- This is our assumption
    assumption
  -- Now we need to derive False from h
  -- `a ++ " " ++ b = a + b` implies ` " " = ""`
  have h1 : " " = "" := by
    -- From h: a ++ " " ++ b = a + b
    -- This is (a ++ " ") ++ b = a ++ b
    -- By cancelling b (if non-empty), we get a ++ " " = a
    -- By cancelling a (if non-empty), we get " " = ""
    -- Let's prove this formally
    cases b with
    | nil =>
      -- If b is empty, then h is a ++ " " = a
      simp at h
      -- Now h is a ++ " " = a
      -- This implies " " = ""
      -- Proof: a ++ " " = a => " " = a - a = 0
      -- In Lean:
      have h4 : " " = "" := by
        have h5 : a ++ " " = a := by
          simpa using h
        have h6 : " " = a - a := by
          rw [←h5]
          simp
        have h7 : a - a = 0 := by
          simp
        rw [h7] at h6
        exact h6
      exact h4
    | cons x xs =>
      -- If b is non-empty, then h is (a ++ " ") ++ b = a ++ b
      simp at h
      -- Now h is (a ++ " ") ++ b = a ++ b
      -- This implies a ++ " " = a by cancelling b
      have h4 : a ++ " " = a := by
        -- We have (a ++ " ") ++ b = a ++ b
        -- We can cancel b from both sides
        -- This requires b is non-empty, which it is in this case
        simp [add_assoc] at h ⊢
        all_goals tauto
      -- Now we have a ++ " " = a
      -- This implies " " = ""
      -- Proof: a ++ " " = a => " " = a - a = 0
      -- In Lean:
      have h5 : " " = "" := by
        have h6 : a ++ " " = a := by
          simpa using h4
        have h7 : " " = a - a := by
          rw [←h6]
          simp
        have h8 : a - a = 0 := by
          simp
        rw [h8] at h7
        exact h7
      exact h5
  -- Now we have " " = ""
  -- This is a contradiction, as " " is not the empty string
  -- We can use `simp` to simplify this contradiction
  simp at h1
  -- `simp` will turn `h1 : " " = ""` into `False`
  -- Then `trivial` can prove `False` from `False`
  trivial
