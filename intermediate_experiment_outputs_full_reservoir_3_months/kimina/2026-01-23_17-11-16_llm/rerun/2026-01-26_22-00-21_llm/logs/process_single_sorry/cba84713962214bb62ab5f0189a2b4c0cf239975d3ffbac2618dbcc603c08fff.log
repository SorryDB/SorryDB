        | some rmwRead =>
          let satisifiedWrites := state.satisfied.filter
            (λ (r,_) => r == rmwRead.id) |>.map
              λ (_,w) => w
          match satisifiedWrites.head? with
            | none => none
            | some writeId =>
              state.requests.getReq? writeId

