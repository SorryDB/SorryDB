      "by\n  rcases h with ⟨f, hf⟩\n  have h1 : Function.Injective f := hf.1\n  have h2 : Function.Surjective f := hf.2\n  use (fun A => f '' A)\n  constructor\n  · -- Show that the map is injective\n    intro A1 A2 h_eq\n    ext x\n    simp at h_eq ⊢\n    have h3 : x ∈ A1 ↔ x ∈ A2 := by\n      constructor\n      · -- Assume x ∈ A1, show x ∈ A2\n        intro hx\n        have h4 : f x ∈ f '' A1 := by\n          simp [hx]\n        have h5 : f x ∈ f '' A2 := by\n          rw [show f '' A1 = f '' A2 by exact h_eq] at h4\n          exact h4\n        rcases h5 with ⟨y, hy, hfy⟩\n        have h6 : y = x := by\n          apply h1\n          all_goals\n            simpa using hfy\n        rw [h6] at hy\n        exact hy\n      · -- Assume x ∈ A2, show x ∈ A1\n        intro hx\n        have h4 : f x ∈ f '' A2 := by\n          simp [hx]\n        have h5 : f x ∈ f '' A1 := by\n          rw [show f '' A2 = f '' A1 by rw [h_eq]] at h4\n          exact h4\n        rcases h5 with ⟨y, hy, hfy⟩\n        have h6 : y = x := by\n          apply h1\n          all_goals\n            simpa using hfy\n        rw [h6] at hy\n        exact hy\n    exact h3\n  · -- Show that the map is surjective\n    intro B\n    use {u : U | f u ∈ B}\n    ext y\n    simp\n    constructor\n    · -- Assume y ∈ f '' {u : U | f u ∈ B}, show y ∈ B\n      rintro ⟨x, hx, hfx⟩\n      have h7 : f x ∈ B := by\n        simpa using hx\n      rw [show y = f x by linarith [hfx]] \n      exact h7\n    · -- Assume y ∈ B, show y ∈ f '' {u : U | f u ∈ B}\n      intro hy\n      rcases h2 hy with ⟨x, hx⟩\n      refine ⟨x, by simp [hx, hy], by simp [hx, hy]⟩",
