import Mathlib

/- Definition of a consistent assignment of requests to threads
  A consistent assignment is one where each request is assigned to at most one thread, and each thread can be assigned multiple requests.
  We represent this assignment using an array where the index is the thread ID and the value is an optional request.
  The consistency condition ensures that the assignment is valid.
-/
structure ConsistentAssignment {V : ValidScopes} where
  val : Array (Option (Request))
  consistent : valConsistent val

def valConsistent (vals :  Array (Option (Request))) : Bool :=
  let valOpIds := vals.map (λ r => r.id)
  let valConsistent := λ i opVal => match opVal with
    | none => true
    | some val => val == i
  let consistentVals := valOpIds.mapIdx valConsistent
  consistentVals.foldl (. ∧ .) true

