```lean
import Mathlib


structure RequestArray where
  val : Array (Option (Request))
  coherent : valConsistent val = true

instance : BEq (RequestArray) where beq := λ arr₁ arr₂ => arr₁.val == arr₂.val

def getReq? : RequestArray → RequestId → Option (Request)
  | arr, rId => match arr.val[rId.toNat]? with
    | some (some req) => some req
    | _ => none

def getReq! : RequestArray → RequestId → Request
  | arr, rId => arr.val[rId.toNat]?.get!.get!

def printReq : RequestArray → RequestId → String
  | arr, rId => match arr.getReq? rId with
    | none => ""
    | some r => r.toShortString

def seen : RequestArray → List RequestId
  | arr => List.range arr.val.size

def map {β : Type} : (ra : RequestArray) (f : (r : Request) → β) : Array β :=
  filterNones $ ra.val.map (λ opreq => Option.map f opreq)

def filter : (ra : RequestArray) (f : (r : Request) → Bool) : List (Request) := 
  filterNones (ra.val.filter (λ opreq => match opreq with 
    | none => false
    | some r => f r
  )) |>.toList

def filterAt : (ra : RequestArray) (f : (r : Request) → Bool) : List (Request) := 
  filterNones (ra.val.filter (λ opreq => match opreq with 
    | none => false
    | some r => f r
  )) |>.toArray |>.filter f |>.toList

def qtopSort : (ra : RequestArray) (f : @OrderConstraints V) (numThreads : Nat) : List (Request) := 
  let allreqs := seen ra
  let allreqs' := allreqs.map (λ r => r.id)
  let sorted := allreqs'.qsort (λ r₁ r₂ => f.lookup r₁ r₂)
  let res := filterAt ra (λ r => (r.id ∈ sorted))
  res.reverse

def qtopSort' : (ra : RequestArray) (f : @OrderConstraints V) (numThreads : Nat) : List (Request) := 
  let allreqs := seen ra
  let allreqs' := allreqs.map (λ r => r.id)
  let sorted := allreqs'.qsort (λ r₁ r₂ => f.lookup r₁ r₂)
  let res := filterAt ra (λ r => (r.id ∈ sorted))
  res.reverse

def groupsToString : (l₁ l₂ : List (Request)) → String := 
  let seen₁ := l₁.map (λ r => r.address?)
  let seen₂ := l₂.map (λ r => r.address?)
  let common := seen₁.filter (fun a => seen₂.contains a)
  let colorFun := λ r => if common.contains r.address? then colorString Color.magenta r.toShortString else r.toShortString
  let (s₁ s₂) := (l₁.map colorFun, l₂.map colorFun)
  "{" ++ (String.intercalate ", " $ s₁) ++ 
  "} → {" ++ (String.intercalate ", " $ s₂) ++ "}"

def toString : (ra : RequestArray) (f : @OrderConstraints V) (numThreads : Nat) → String := 
  let allreqs := seen ra
  let allreqs' := allreqs.map (λ r => r.id)
  let sorted := allreqs'.qsort (λ r₁ r₂ => f.lookup r₁ r₂)
  let pairs := filterAt ra (λ r => (r.id ∈ sorted))
  let pairs' := pairs.map (fun r => (r, filterAt ra (λ r' => f.lookup r.id r'.id)))
  let res : List (List (Request) × List (Request)) := pairs'.filter (λ p => p.1.length > 0)
  res.map groupsToString |>.intercalate "\n"

def prettyPrint : (ra : RequestArray) (numThreads : Nat) (f : @OrderConstraints V) → String := 
  let allreqs := seen ra
  let allreqs' := allreqs.map (λ r => r.id)
  let sorted := allreqs'.qsort (λ r₁ r₂ => f.lookup r₁ r₂)
  let pairs := filterAt ra (λ r => (r.id ∈ sorted))
  let pairs' := pairs.map (fun r => (r, filterAt ra (λ r' => f.lookup r.id r'.id)))
  let res : List (List (Request) × List (Request)) := pairs'.filter (λ p => p.1.length > 0)
  let res' := res.map (fun (l₁, l₂) => 
    let seen₁ := l₁.map (λ r => r.address?)
    let seen₂ := l₂.map (λ r => r.address?)
    let common := seen₁.filter (fun a => seen₂.contains a)
    let colorFun := λ r => if common.contains r.address? then colorString Color.magenta r.toShortString else r.toShortString
    let (s₁ s₂) := (l₁.map colorFun, l₂.map colorFun)
    s₁.intercalate ", " ++ " → " ++ s₂.intercalate ", "
  )
  let res'' := res'.intercalate "\n"
  let colWidth := 25
  let res''' := res''.map (fun s => s.rjust colWidth)
  let res'''' := res'''s.intercalate "\n" ++ "|\n" ++ (List.replicate (colWidth * numThreads + 2 * (numThreads - 1)) '-').intercalate "\n" ++ "\n"
  let res''''' := res''''s.intercalate "\n"
  let res'''''' := res'''''s.map (fun s => s.rjust (colWidth * numThreads + 2 * (numThreads - 1)))
  res''''''s.intercalate "\n"

