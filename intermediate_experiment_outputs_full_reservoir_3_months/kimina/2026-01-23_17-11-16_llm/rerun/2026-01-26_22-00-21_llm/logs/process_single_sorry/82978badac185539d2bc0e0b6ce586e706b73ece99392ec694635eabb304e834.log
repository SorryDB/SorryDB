-/

structure Request (inst : Arch) where
  id : Nat
  thread : Nat
  value? : Option Nat
  address? : Option Nat
  isWrite : Bool
  isRead : Bool
  isAnnounce : Bool
  isPropagated : Bool

def opReqId? : Option (Request) → Option Nat := Option.map λ r => r.id

def valConsistent (vals :  Array (Option (Request))) : Bool :=
  let valOpIds := vals.map opReqId?
  let valConsistent := λ (i : Nat) (opVal : Option (Request)) => match opVal with
    | none => true
    | some val => val == i
  let consistentVals := valOpIds.mapIdx valConsistent
  consistentVals.foldl (. && .) true

structure RequestArray where
  val : Array (Option (Request))
  coherent : valConsistent val = true

instance : BEq (RequestArray) where beq := λ arr₁ arr₂ => arr₁.val == arr₂.val

def getReq? : (rarr : RequestArray) (rId : Nat) : Option (Request) :=
  match rarr.val[rId.toNat]? with
    | some (some req) => some req
    | _ => none

def getReq! : (rarr : RequestArray) (rId : Nat) : Request :=
  rarr.val[rId.toNat]?.get!.get!

def seen (rarr : RequestArray) : List Nat := List.range (rarr.val).size

def map {β : Type} (rarr : RequestArray) (f : (Request) → β) : Array (Option β) :=
  filterNones $ rarr.val.map λ opreq => Option.map f opreq

def filter (rarr : RequestArray) (f : (Request) → Bool) : List (Request) :=
  let f' : Option (Request) → Bool := λ opreq => match opreq with
    | none => false
    | some r => f r
  filterNones $ (rarr.val).filter f'

