import Mathlib

import Mathlib

def valConsistent (vals :  Array (Option (Request))) : Bool :=
  let valOpIds := vals.map (Option.map (fun r => r.id))
  let valConsistent := λ (i : Nat) (opVal : Option (Request)) => 
    match opVal with
    | none => true
    | some val => 
      val = i
  let consistentVals := valOpIds.mapIdx valConsistent
  let consistent := consistentVals.foldl (. ∧ .) true
  exact consistent
