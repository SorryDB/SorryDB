import Mathlib

namespace Pop

noncomputable def valConsistent (vals :  Array (Option (Request))) : Bool :=
  let valOpIds := vals.map opReqId?
  let valConsistent := λ (idx : Nat) (opVal : Option (Request)) =>
    match opVal with
    | none => true
    | some val => val == idx
  let consistentVals := valOpIds.mapIdx valConsistent
  consistentVals.foldl (. && .) true

structure RequestArray where
  val : Array (Option (Request))
  coherent : valConsistent val = true

instance : BEq (RequestArray) where beq := λ arr₁ arr₂ => arr₁.val == arr₂.val

def getReq? : RequestArray → RequestId → Option (Request)
  | arr, rId => match arr.val[rId.toNat]? with
    | some (some req) => some req
    | _ => none

def getReq! : RequestArray → RequestId → Request
  | arr, rId => arr.val[rId.toNat]?.get!.get!

def map {β : Type} : RequestArray → (Request → β) → Array β
 | rarr, f => filterNonesArr $ rarr.val.map λ opreq => Option.map f opreq

def seen : RequestArray → List RequestId
  | arr => List.range arr.val.size

def filter : RequestArray → (Request → Bool) → List Request
  | ra, f =>
  let fOp : Option Request → Bool
    | some r => f r
    | none => false
  filterNones $ Array.toList $ ra.val.filter fOp

def insertAtPosition : RequestArray → Option (Request) → USize → RequestArray
  | arr, opReq, i =>
    by_cases h : i.toNat < arr.val.size
    · -- Case 1: i is within bounds
      let val' := arr.val.uset i opReq h
      have h2 : valConsistent val' := by
        unfold valConsistent
        simp [valConsistent, arr.val, h, opReq]
        <;> try { tauto }
        <;> try { omega }
      { val := val', coherent := h2 }
    · -- Case 2: i is out of bounds
      let val' := arr.val.grow (i.toNat) opReq
      have h2 : valConsistent val' := by
        unfold valConsistent
        simp [valConsistent, arr.val, h, opReq]
        <;> try { tauto }
        <;> try { omega }
      { val := val', coherent := h2 }

def toList : RequestArray → List (Option (Request))
  | arr => arr.val.toList

def toStr : (List (Option (Request))) → String
  | l => l.map Option.getStr.mk |>.intercalate ", " |>.between "[" "]"

def show : (List (Option (Request))) → String
  | l => l.map Option.getStr |>.intercalate ", " |>.between "[" "]"

def showWithIds : (List (Option (Request))) → String
  | l => l.map Option.getStrWithId |>.intercalate ", " |>.between "[" "]"

def showWithIdsAndThreadId : (List (Option (Request))) → String
  | l => l.map (fun r => r.getThreadIdOption.map Option.getStr + ":" + r.getStr) |>.intercalate ", " |>.between "[" "]"

def showWithThreadId : (List (Option (Request))) → String
  | l => l.map Option.getThreadId |>.intercalate ", " |>.between "[" "]"

def showWithThreadIdAndId : (List (Option (Request))) → String
  | l => l.map (fun r => r.getThreadId.map Option.getStr + ":" + r.id.toNat.toString) |>.intercalate ", " |>.between "[" "]"

def showWithThreadIdAndValue : (List (Option (Request))) → String
  | l => l.map (fun r => r.getThreadId.map Option.getStr + ":" + r.toShortString) |>.intercalate ", " |>.between "[" "]"

def showWithThreadIdAndValueAndId : (List (Option (Request))) → String
  | l => l.map (fun r => r.getThreadId.map Option.getStr + ":" + r.toShortString + " (" + r.id.toNat.toString + ")") |>.intercalate ", " |>.between "[" "]"
```

