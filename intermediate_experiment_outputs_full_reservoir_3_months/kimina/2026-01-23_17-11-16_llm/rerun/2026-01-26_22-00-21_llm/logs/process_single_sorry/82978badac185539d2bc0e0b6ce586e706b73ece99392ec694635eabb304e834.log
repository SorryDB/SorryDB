  let arr := rarr.val
  String.intercalate ",\n" $ List.map (fun r => r.toShortString) (filterNones (List.range arr.size).map (fun i => arr[i]))

def reqIds (rarr : RequestArray) : List Nat :=
  let opIds :=  (rarr.val).map (fun (opreq : Option (Request)) => opreq.map (fun r => r.id))
