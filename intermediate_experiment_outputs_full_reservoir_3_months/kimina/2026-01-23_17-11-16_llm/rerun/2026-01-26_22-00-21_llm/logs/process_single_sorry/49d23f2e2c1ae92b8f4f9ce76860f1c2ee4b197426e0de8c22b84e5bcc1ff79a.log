}

abbrev BasicRequest := Arch | NoArch | Atomic | Rmw | Fences | Fences2 | Satisfy

abbrev Request := {
  propagated_to : List (ThreadId),
  thread : ThreadId,
  predecessor_at : List (ThreadId),
  pairedRequest? : Option (RequestId),
  basic_type : BasicRequest,
  id : RequestId,
  occurrence : Nat,
  isPredecessorAt (th : ThreadId) : Bool := th ∈ predecessor_at
}

abbrev Request.isPredecessorAt : Request → ThreadId → Bool := fun r th => th ∈ r.predecessor_at

abbrev BasicRequest.isAtomic : BasicRequest → Bool := match b => b.isAtomic
abbrev BasicRequest.isRmw : BasicRequest → Bool := match b => b.isRmw
abbrev BasicRequest.isFence : BasicRequest → Bool := match b => b.isFence

abbrev BasicRequest.isFence2 : BasicRequest → Bool := match b => b.isFence2
abbrev BasicRequest.isSatisfy : BasicRequest → Bool := match b => b.isSatisfy

abbrev BasicRequest.isNoArch : BasicRequest → Bool := match b => b.isNoArch

abbrev BasicRequest.isWrite : BasicRequest → Bool := match b => b.isWrite
abbrev BasicRequest.isRead : BasicRequest → Bool := match b => b.isRead

def Arch.isWrite : Arch → Bool := true
def Arch.isRead : Arch → Bool := true
def NoArch.isWrite : NoArch → Bool := false
def NoArch.isRead : NoArch → Bool := false
def Atomic.isWrite : Atomic → Bool := true
def Atomic.isRead : Atomic → Bool := true
def Rmw.isWrite : Rmw → Bool := true
def Rmw.isRead : Rmw → Bool := true
