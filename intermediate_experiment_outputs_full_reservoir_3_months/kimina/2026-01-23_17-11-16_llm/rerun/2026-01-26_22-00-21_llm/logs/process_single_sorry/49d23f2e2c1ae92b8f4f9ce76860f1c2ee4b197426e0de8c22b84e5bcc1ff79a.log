open Nat

abbrev SystemState := {
  requests : RequestArray,
  scopes : @Scopes,
  threadTypes : ThreadId → Arch,
  orderConstraints : @OrderConstraints,
  removed : List (RequestId),
  satisfied : List (RequestId),
