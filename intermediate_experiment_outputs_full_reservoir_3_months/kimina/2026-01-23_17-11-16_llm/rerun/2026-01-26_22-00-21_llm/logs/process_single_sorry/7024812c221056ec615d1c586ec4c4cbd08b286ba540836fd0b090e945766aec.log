import Mathlib

open List

def SystemState.freshId : SystemState → RequestId
  | state =>
    let removed := state.removed.map Request.id
    let active := reqIds state.requests
    let ids : List Nat := removed ++ active
    let max := ids.max?
    match max with
      | none => 0
      | some id => (Nat.succ id)

def SystemState.cleanupTransactions : SystemState → SystemState
  | state =>
    let removedWrites := state.requests.filter
      λ req => (req.isTransactional || req.isAtomic) ∧ req.isWrite
    let removed' := (List.map (fun r => r.id) removedWrites ++ List.map (fun r => r.id) state.removed).toMultiset
    let h1 : List.map (fun r => r.id) removed' = List.map (fun r => r.id) removed' := rfl
    let h2 : List.map (fun r => r.id) removed' = List.map (fun r => r.id) removed' := rfl
    let h3 : List.map (fun r => r.id) removed' = List.map (fun r => r.id) removed' := rfl
    let h4 : List.map (fun r => r.id) removed' = List.map (fun r => r.id) removed' := rfl
    let h5 : List.map (fun r => r.id) removed' = List.filter (fun r => r.id ∈ List.map (fun r => r.id) removed') state.requests
    ext r
    simp [List.mem_map, List.mem_filter, removed']
    <;> try { tauto }
    <;> try { aesop }
    <;> try { native_decide }
