variable {╬▒ nt : Type} {Prod : Finset ╬▒ ŌåÆ Finset nt ŌåÆ Type} [Production ╬▒ nt Prod]

/--Coerce a word from a grammars terminal symbol type (a.k.a. finset) into
  that finsets supertype.-/
def coerceWord {Z : Finset ╬▒} (w : Word Z) : Word ╬▒ := w.map (fun t => t.val)

/--Coerce a language from a grammars terminal symbol type (a.k.a. finset) into
  that finsets supertype.-/
def coerceLang {Z : Finset ╬▒} (l : Language Z) : Language ╬▒ := fun word => Ōłā w, w Ōłł l Ōł¦ (coerceWord w = word)

instance {Z : Finset ╬▒} : CoeOut (Word Z) (Word ╬▒) where
  coe word := @coerceWord ╬▒ Z word

instance {Z : Finset ╬▒} : CoeOut (Language Z) (Language ╬▒) where
  coe lang := @coerceLang ╬▒ Z lang

/--Theorem: coerceWord and coerceLang respect the language membership relation.-/
theorem coerceLang_mem {Z : Finset ╬▒} {w : Word Z} (l : Language Z) :
  w Ōłł l Ōåö coerceWord w Ōłł coerceLang l := by sorry
/--Theorem: coerceWord and coerceLang respect the language membership relation.-/
theorem coerceLang_not_mem {Z : Finset ╬▒} {w : Word Z} (l : Language Z) :
  w Ōłē l Ōåö coerceWord w Ōłē coerceLang l := by sorry

/--Theorem: All words over a type of terminal symbols that are in a coerced
