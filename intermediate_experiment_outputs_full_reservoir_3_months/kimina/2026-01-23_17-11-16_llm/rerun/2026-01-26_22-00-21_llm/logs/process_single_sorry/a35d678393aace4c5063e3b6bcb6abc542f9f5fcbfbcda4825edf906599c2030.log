  logInfo m!"Syntax: {t} is {repr t}"

elab "#expr" "[" t:term "]" : command =>
  Command.liftTermElabM do
  let t ‚Üê Term.elabTerm t none
  logInfo m!"Expression: {t} is {repr t}"
  let t ‚Üê reduce t
  logInfo m!"Reduced: {t} is {repr t}"

