    <;> try { tauto }
    <;> try { nlinarith }
  have h3 : ((biasedUpdateState net x i i).toReal - (x i).toReal) = if 0 < (biasedLocalField net x i) then (1 - (x i).toReal) else if (biasedLocalField net x i) < 0 then (-1 - (x i).toReal) else 0 := by
    rw [h2]
    <;> simp
    <;> try { aesop }
    <;> try { tauto }
    <;> try { nlinarith }
    <;> try { tauto }
