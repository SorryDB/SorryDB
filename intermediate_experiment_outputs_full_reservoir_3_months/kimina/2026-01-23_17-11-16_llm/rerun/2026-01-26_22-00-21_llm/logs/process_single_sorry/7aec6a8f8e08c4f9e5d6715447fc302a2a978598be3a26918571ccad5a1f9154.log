open Real

lemma biaseEnergy_decreasing : biasedEnergyDiff net x i ≤ 0 := by
  have h1 : ((BiasedUpdateState net x i).i).toReal - (x i).toReal = if 0 < biasedLocalField net x i then 1 - x i else (if biasedLocalField net x i < 0 then -1 - x i else 0) := by
    simp [biasedUpdateState, Fin.sum_univ_succ, Fin.sum_univ_zero, mul_add, add_mul]
