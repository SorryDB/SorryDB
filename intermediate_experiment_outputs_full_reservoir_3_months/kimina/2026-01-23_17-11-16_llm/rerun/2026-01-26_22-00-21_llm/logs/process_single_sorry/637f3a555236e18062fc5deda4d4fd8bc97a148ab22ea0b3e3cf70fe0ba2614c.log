  nt : Type
  initial : nt
  rules : List (KurodaRule T nt)

variable {T : Type}

/-- One step of transformation by a grammar in the Kuroda Normal Form. -/
def KurodaGrammar.Transforms (g : KurodaGrammar T) (w‚ÇÅ w‚ÇÇ : List (Symbol T g.nt)) : Prop :=
  ‚àÉ r : KurodaRule T g.nt,
    r ‚àà g.rules ‚àß
