  ‚àÉ r : KurodaRule T g.nt,
    r ‚àà g.rules ‚àß
    ‚àÉ u v : List (Symbol T g.nt),
      match r with
      | KurodaRule.two_two A B C D =>
          w‚ÇÅ = u ++ [Symbol.nonterminal A, Symbol.nonterminal B] ++ v ‚àß
          w‚ÇÇ = u ++ [Symbol.nonterminal C, Symbol.nonterminal D] ++ v
      | KurodaRule.one_two A B C =>
          w‚ÇÅ = u ++ [Symbol.nonterminal A] ++ v ‚àß
          w‚ÇÇ = u ++ [Symbol.nonterminal B, Symbol.nonterminal C] ++ v
      | KurodaRule.one_one A t =>
          w‚ÇÅ = u ++ [Symbol.nonterminal A] ++ v ‚àß
          w‚ÇÇ = u ++ [Symbol.terminal t] ++ v
      | KurodaRule.one_nil A =>
          w‚ÇÅ = u ++ [Symbol.nonterminal A] ++ v ‚àß
          w‚ÇÇ = u ++ v

