      "\n  have h1 : Tendsto (fun k : ℝ => r / k) atTop (𝓝[≠] 0) := by\n    apply Tendsto.div_const\n    exact atTop_nhds\n  have h2 : Tendsto (fun y : ℝ => Real.sinh y / y) (𝓝[≠] 0) (𝓝 1) := by\n    apply Real.tendsto_sinh_div_at_zero\n  have h3 : Tendsto (fun k : ℝ => k * Real.sinh (r / k)) atTop (𝓝 r) := by\n    have h4 : (fun k : ℝ => k * Real.sinh (r / k)) = (fun k : ℝ => r * (Real.sinh (r / k) / (r / k))) := by\n      funext k\n      by_cases h : r = 0\n      · simp [h]\n      · -- r ≠ 0\n        have hrk : r / k ≠ 0 := by\n          by_contra h'\n          have : r = 0 := by\n            field_simp at h'\n            all_goals linarith\n          contradiction\n        field_simp [hrk]\n        <;> ring_nf <;> field_simp [hrk]\n    rw [h4]\n    have h5 : Tendsto (fun k : ℝ => Real.sinh (r / k) / (r / k)) atTop (𝓝 1) := by\n      apply Tendsto.comp\n      · exact h2\n      · exact h1\n    have h6 : Tendsto (fun k : ℝ => r * (Real.sinh (r / k) / (r / k))) atTop (𝓝 r) := by\n      apply Tendsto.mul_const\n      exact h5\n    exact h6\n  exact h3",
