    (Assumptions : Input F → Prop) (Spec : Fin 8 → Input F → Output F → Prop) :
    Soundness F (circuit offset) Assumptions (Spec offset) := by
  circuit_proof_start
  -- offset is introduced first, then standard parameters
  sorry

-- Test parametrized completeness
