      · -- Show w ≤ unreverse x
        simpa using hwle
    contradiction
  | inr hp_right =>
    have h3 : ∃ w ∈ (unreverse z) ^L, unreverse x ≤ w := by
      rw [show p = right by exact hp_right] at h
