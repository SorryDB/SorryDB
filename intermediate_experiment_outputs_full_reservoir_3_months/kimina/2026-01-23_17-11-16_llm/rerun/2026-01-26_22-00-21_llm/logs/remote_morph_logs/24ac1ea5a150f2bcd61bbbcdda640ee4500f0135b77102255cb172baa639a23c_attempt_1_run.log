```lean
import Mathlib

/- RCLike.I has norm 1 if it is non-zero, and 0 if it is zero. -/
theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · -- If RCLike.I is non-zero, then its norm is 1.
    apply RCLike.norm_I_of_ne_zero h
  · -- If RCLike.I is zero, then its norm is 0.
    push_neg at h
    simpa using h
    -- Goal: eLpNorm (T g) 1 (ν.restrict G) = if RCLike.I ≠ (0 : K) then 1 else 0
    -- where g is such that eLorentzNorm g p 1 μ < ⊤ and RCLike.I = 0
    intro g hg
    calc eLpNorm (T g) 1 (ν.restrict G)
      _ = eLpNorm (enorm ∘ T g) 1 (ν.restrict G) := by
        simp only [eLpNorm_eq, Function.comp_apply]
      _ = (c / p) * eLorentzNorm (enorm ∘ T g) p 1 μ * (ν G) ^ p'⁻¹.toReal := by
        rw [hasLorentzType_iff.mpr]
        exact ⟨hT, T_meas, T_subadd, T_submul, weakly_cont_T, hpp'⟩
      _ = eLorentzNorm g p 1 μ := by
        simp only [eLorentzNorm_eq, Function.comp_apply, norm_eq_norm]
      _ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
        rw [hg]
```

