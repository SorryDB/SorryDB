import Mathlib

open Real

noncomputable abbrev eLpNorm (f : α → 𝕂) (p : ℝ≥0∞) (μ : Measure α) := eLpMeasureTheory.norm f p μ

noncomputable abbrev eLorentzNorm' (f : α → 𝕂) (p : ℝ≥0∞) (μ : Measure α) := eLorentzMeasureTheory.norm' f p μ

noncomputable abbrev eLorentzNorm'' (f : α → 𝕂) (p : ℝ≥0∞) (μ : Measure α) := eLorentzMeasureTheory.norm'' f p μ

noncomputable abbrev eLorentzNorm (f : α → 𝕂) (p : ℝ≥0∞) (μ : Measure α) :=
  if p = ⊤ then
    if IsFiniteMeasure μ then
      eLorentzMeasureTheory.norm f ⊤ μ
    else
      ⊤
  else
    eLorentzMeasureTheory.norm' f p μ

