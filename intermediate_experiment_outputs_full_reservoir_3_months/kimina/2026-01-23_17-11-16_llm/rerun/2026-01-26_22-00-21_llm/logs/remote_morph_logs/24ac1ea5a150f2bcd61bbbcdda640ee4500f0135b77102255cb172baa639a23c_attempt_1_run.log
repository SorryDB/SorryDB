  simp only [Function.comp_apply]
  have hf' : @MeasureTheory.MemLorentz α (ℝ≥0) m0 SeminormedAddGroup.toContinuousENorm.toENorm
        PseudoMetricSpace.toUniformSpace.toTopologicalSpace ((@RCLike.ofReal 𝕂 _) ∘ NNReal.toReal ∘ f) p 1 μ := by
    simpa using hf
  have hg' : @MeasureTheory.MemLorentz α (ℝ≥0) m0 SeminormedAddGroup.toContinuousENorm.toENorm
        PseudoMetricSpace.toUniformSpace.toTopologicalSpace ((@RCLike.ofReal 𝕂 _) ∘ NNReal.toReal ∘ g) p 1 μ := by
