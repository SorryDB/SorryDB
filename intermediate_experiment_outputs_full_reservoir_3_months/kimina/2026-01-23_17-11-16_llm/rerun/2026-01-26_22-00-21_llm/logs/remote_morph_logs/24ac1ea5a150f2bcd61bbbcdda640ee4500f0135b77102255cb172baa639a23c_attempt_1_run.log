  · apply AEStronglyMeasurable.restrict
    apply T_meas hg'
```

Similarly for `T'_submul`:

```tactics
have T'_submul : ∀ (f : α → ℝ≥0) (a : ℝ≥0), eLpNorm (T' (a • f)) 1 (ν.restrict G)
