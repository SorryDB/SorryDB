open Real

/-!
  A map T has restricted weak type (p, p', μ, ν, c) if it satisfies certain
  conditions related to the behavior of norms of T(f) and f under the
  measures μ and ν, and the constant c. This is a technical condition
  used in the analysis of operators on Lorentz spaces.
-/
noncomputable def HasRestrictedWeakType (T : (α → β) → (α' → ε')) (p p' : ℝ≥0∞) (μ : Measure α) (ν : Measure α') (c : ℝ≥0)
    : Prop :=
  ∃ (h : ∀ (f : α → β), (f = 0 ∧ μ.support = ∅) ∨
      (∃ (a : β) (ha : a ≠ 0), f = fun _ => a ∧ μ.support = Set.univ) ∨
      (∃ (s : Set α) (ha : a ∈ s), f = fun _ => a ∧ μ.support = s) ∨
      (∃ (s : Set α) (ha : a ∈ s), f = fun _ => a ∧ μ.support = Set.univ) ∨
      (∃ (s : Set α) (hs : s = Set.univ), f = fun _ => a ∧ μ.support = s) ∨
      (∃ (s : Set α) (hs : s = Set.univ), f = fun _ => a ∧ μ.support = Set.univ)) :
    eLpNorm (T f) 1 ν ≤ c * eLorentzNorm' f p 1 μ ∧
    eLpNorm (T f) 1 ν ≤ c * eLorentzNorm' (fun _ => a) p 1 μ ∧
    eLpNorm (T f) 1 ν ≤ c * eLorentzNorm' (fun _ => a) p 1 μ := sorry

/-!
  A map T is weakly continuous with respect to measures μ and ν if
  it preserves the weak topology in a certain sense. This is a
  technical condition used in the analysis of operators on function
  spaces.
-/
noncomputable def WeaklyContinuous (T : (α → β) → (α' → ε')) (p : ℝ≥0∞) (μ : Measure α) (ν : Measure α') : Prop := sorry

/-!
