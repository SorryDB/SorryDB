    : Prop :=
  ∃ (h : ∀ (f : α → β), (f = 0 ∧ μ.support = ∅) ∨
      (∃ (a : β) (ha : a ≠ 0), f = fun _ => a ∧ μ.support = Set.univ) ∨
      (∃ (s : Set α) (ha : a ∈ s), f = fun _ => a ∧ μ.support = s) ∨
      (∃ (s : Set α) (ha : a ∈ s), f = fun _ => a ∧ μ.support = Set.univ) ∨
      (∃ (s : Set α) (hs : s = Set.univ), f = fun _ => a ∧ μ.support = s) ∨
      (∃ (s : Set α) (hs : s = Set.univ), f = fun _ => a ∧ μ.support = Set.univ)) :
    eLpNorm (T f) 1 ν ≤ c * eLorentzNorm' f p 1 μ ∧
    eLpNorm (T f) 1 ν ≤ c * eLorentzNorm' (fun _ => a) p 1 μ ∧
