  (hμ_moments : ∀ (k : ℕ), Integrable (fun x ↦ x^k) μ)
  (hν_moments : ∀ (k : ℕ), Integrable (fun x ↦ x^k) ν)
  (hμ_mean : integral μ id = 0) (hν_mean : integral ν id = 0)
  (hμ_var : integral μ (fun x ↦ x^2) = 1)
