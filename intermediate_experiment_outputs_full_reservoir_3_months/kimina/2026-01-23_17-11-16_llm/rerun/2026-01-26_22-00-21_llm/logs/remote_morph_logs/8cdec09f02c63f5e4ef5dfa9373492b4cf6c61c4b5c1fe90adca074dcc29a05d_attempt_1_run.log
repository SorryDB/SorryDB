        apply MeasureTheory.Measure.measurableAt_apply
        all_goals
          simp [WignerSpace]
          all_goals
            try { tauto }
  have h2 : Measurable (fun (ω : WignerSpace n) => Matrix.of (wignerMatrixEntryFunction ω)) := by
    apply Matrix.measurable_of
    intro i j
    exact h1 i j
  have h3 : (wignerMatrixMap n) = fun (ω : WignerSpace n) => Matrix.of (wignerMatrixEntryFunction ω) := by
    funext ω
    simp [wignerMatrixMap', wignerMatrixEntryFunction]
