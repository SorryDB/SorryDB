open Filter
open Nat.Prime

/-- The prime counting function `π(x)` for real `x`. -/
noncomputable def primeCountingReal (x : ℝ) : ℕ :=
  if (x ≤ 0) then 0 else primeCounting ⌊x⌋₊

/-- The set of natural numbers whose prime factors are all less than or equal to `x`. -/
def S₁ (x : ℝ) : Set ℕ :=
 { n | ∀ p, Nat.Prime p → p ∣ n → p ≤ x }

theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  -- two parts:
  -- (1) log x ≤ π x + 1
  -- (2) This implies that it is not bounded
  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by sorry
      _ ≤ (∑' m : (S₁ x), (m : ℝ)⁻¹) := by sorry
      _ ≤ (∏ p ∈ primesBelow ⌊x⌋.natAbs, (∑' k : ℕ, (p ^ k : ℝ)⁻¹)) := by sorry
      _ ≤ (∏ k ∈ Icc 1 (primeCountingReal x), (nth Nat.Prime k) / ((nth Nat.Prime k) - 1)) := by sorry
      _ ≤ (∏ k ∈ Icc 1 (primeCountingReal x), (k + 1) / k) := by
        apply Finset.prod_le_prod
        · intro k hk
          simp at hk ⊢
          rcases hk with ⟨hk1, hk2⟩
          have h_k_pos : 0 < k := by linarith
          have h_k_prime : Nat.Prime k := by
            apply nth_prime_pos
            linarith
          have h_k_ge_2 : k ≥ 2 := Nat.Prime.two_le h_k_prime
          have h_p_k_ge_k : (nth Nat.Prime k) ≥ k := by
            apply Nat.le_nth_prime
            linarith
          have h_p_k_gt_1 : (nth Nat.Prime k) > 1 := by
            linarith [h_p_k_ge_k, h_k_ge_2]
          have h_p_k_sub_one_pos : (nth Nat.Prime k) - 1 > 0 := by
            omega
          have h_p_k_sub_one_le_p_k : (nth Nat.Prime k) - 1 ≤ (nth Nat.Prime k) := by
            omega
          have h_k_add_one_pos : k + 1 > 0 := by
            linarith
          have h_k_le_p_k_sub_one : k ≤ (nth Nat.Prime k) - 1 := by
            have h_k_le_p_k : k ≤ (nth Nat.Prime k) := by
              apply Nat.le_nth_prime
              linarith
            omega
          have h_k_add_one_le_p_k : k + 1 ≤ (nth Nat.Prime k) := by
            omega
          have h_k_sub_one_pos : k - 1 ≥ 0 := by
            omega
          have h_k_sub_one_le_p_k_sub_one : k - 1 ≤ (nth Nat.Prime k) - 1 := by
            omega
          have h_k_sub_one_pos : k - 1 > 0 := by
            omega
          have h_k_sub_one_pos : k - 1 > 0 := by
            omega
          have h_k_sub_one_pos : k - 1 > 0 := by
            omega
          -- We need to show: (nth Nat.Prime k) / ((nth Nat.Prime k) - 1) ≤ (k + 1) / k
          -- This is equivalent to: k * (nth Nat.Prime k) ≤ (k + 1) * ((nth Nat.Prime k) - 1)
          -- This is equivalent to: k * (nth Nat.Prime k) ≤ k * (nth Nat.Prime k - 1) + (nth Nat.Prime k - 1)
          -- This is equivalent to: 0 ≤ -k + (nth Nat.Prime k - 1)
          -- This is equivalent to: k ≤ (nth Nat.Prime k - 1)
          -- This is equivalent to: k - 1 ≤ (nth Nat.Prime k)
          -- This is true by Nat.le_nth_prime
          apply (div_le_div_iff (by positivity) (by positivity)).mpr
          nlinarith [Nat.le_nth_prime (show 1 ≤ k by linarith)]
