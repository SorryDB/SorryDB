      tauto
    · -- Assume ρ|G_E is automorphic of level S_E, prove ρ is automorphic of level S
      rintro ⟨D, hD, r, π, h⟩
      refine' ⟨D, hD, r, π, ?_⟩
      intro v hvp hvS
      have h2 := h v hvp hvS
      simp [GaloisRep.map_toLocal, algebraMap] at h2 ⊢
      tauto
