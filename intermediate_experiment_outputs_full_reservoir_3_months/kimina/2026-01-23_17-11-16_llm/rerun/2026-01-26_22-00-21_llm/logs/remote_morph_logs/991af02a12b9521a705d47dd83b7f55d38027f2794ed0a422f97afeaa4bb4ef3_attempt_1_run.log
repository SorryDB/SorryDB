    have hY_bound : ⨆ i, eLpNorm (Y i) 2 P < ⊤ := hY.bounded
    have h1 : ⨆ i, eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P < ⊤ := by
      have h2 : ∀ i : ι, eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P ≤ eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P := by
        intro i
