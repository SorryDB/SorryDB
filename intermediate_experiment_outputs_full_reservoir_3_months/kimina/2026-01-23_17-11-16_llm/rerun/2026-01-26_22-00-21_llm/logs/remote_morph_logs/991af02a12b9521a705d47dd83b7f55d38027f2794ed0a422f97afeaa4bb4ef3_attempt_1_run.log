  · -- Show that the sum process is cadlag
    sorry
  · -- Show that the sum process is square integrable
    have h1 : ⨆ i, eLpNorm (X i) 2 P < ∞ := hX.bounded
    have h2 : ⨆ i, eLpNorm (Y i) 2 P < ∞ := hY.bounded
    calc
      ⨆ i, eLpNorm (fun i ω ↦ X i ω + Y i ω) 2 P
        ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
          apply iSup_mono
          intro i
          have h3 : eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P ≥ eLpNorm (fun ω : Ω ↦ X i ω + Y i ω) 2 P := by
            have h4 : (fun ω : Ω ↦ X i ω + Y i ω) = fun ω : Ω ↦ X i ω + Y i ω := by rfl
            rw [h4]
            apply eLpNorm_add_le
            all_goals
              try { aesop }
              try { 
                have h5 : (X i) = fun ω : Ω ↦ X i ω := by funext; simp
                have h6 : (Y i) = fun ω : Ω ↦ Y i ω := by funext; simp
                simp [h5, h6]
                all_goals aesop
              }
              try { 
                have h5 : (X i) = fun ω : Ω ↦ X i ω := by funext; simp
                have h6 : (Y i) = fun ω : Ω ↦ Y i ω := by funext; simp
                simp [h5, h6]
                all_goals aesop
              }
          linarith
        _ ≤ (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by 
          apply iSup_add
          all_goals try { 
            aesop 
          }
          all_goals try { 
            nlinarith [h1, h2] 
          }
          all_goals try { 
            tauto 
          }
    all_goals try { 
      nlinarith [h1, h2] 
    }
    all_goals try { 
