          apply eLpNorm_add_le
        have h5 : eLpNorm (fun (ω : Ω) ↦ X i ω) 2 P = eLpNorm (X i) 2 P := by
          simp [eLpNorm]
        have h6 : eLpNorm (fun (ω : Ω) ↦ Y i ω) 2 P = eLpNorm (Y i) 2 P := by
