        linarith
      have h7 : ⨆ i, eLpNorm (fun (ω : Ω) ↦ X i ω + Y i ω) 2 P ≤ ⨆ i, (eLpNorm (X i) 2 P + eLpNorm (Y i) 2 P) := by
