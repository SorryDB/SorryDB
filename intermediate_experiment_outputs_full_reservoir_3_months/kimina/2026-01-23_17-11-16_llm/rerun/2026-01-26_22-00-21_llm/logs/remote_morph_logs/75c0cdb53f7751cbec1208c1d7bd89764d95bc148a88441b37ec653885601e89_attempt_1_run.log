    have h5 : ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ∫ (s : Set ℂ) : ℝ, ‖f s‖ * (cfc_toComplexMeasure ha x y).density s := by
      apply ComplexMeasure.norm_integral_le_real_integral
    have h6 : ∫ (s : Set ℂ) : ℝ, ‖f s‖ * (cfc_toComplexMeasure ha x y).density s ≤ ∫ (s : Set ℂ) : ℝ, ‖f s‖ * (cfc_toComplexMeasure ha x y).density s := by
