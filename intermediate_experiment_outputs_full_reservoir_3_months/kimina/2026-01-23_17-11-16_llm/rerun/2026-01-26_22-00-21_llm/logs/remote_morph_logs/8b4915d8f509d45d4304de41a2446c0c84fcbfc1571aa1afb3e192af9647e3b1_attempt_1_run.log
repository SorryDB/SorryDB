variable {C : Type} [Category.Cat.{0, 0} C] {K : Type} [DivisionRing K] {M : C ⥤ ModuleCat K}

variable {M : C ⥤ ModuleCat K} in
/-- A direct sum decomposition of `M` is a set of non-zero submodules that are linearly independent
and whose supremum is the whole of `M`. -/
@[ext]
structure DirectSumDecomposition where
  carrier : Set (PersistenceSubmodule M)
  sSupIndep' : sSupIndep carrier
  sSup_eq_top' : sSup carrier = ⊤
  not_bot_mem' : ⊥ ∉ carrier

