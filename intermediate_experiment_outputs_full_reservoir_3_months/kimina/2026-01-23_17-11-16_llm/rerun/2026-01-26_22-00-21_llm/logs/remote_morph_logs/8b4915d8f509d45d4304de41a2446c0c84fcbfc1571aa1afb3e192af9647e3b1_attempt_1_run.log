    (hB'' : ∀ N hN, ⊥ ∉ B N hN) (D : DirectSumDecomposition M) : DirectSumDecomposition M :=
  {
    carrier := ⋃ N, ⋃ hN, B N hN,
    sSupIndep' := by
      intro x hx y hy hxy
      simp only [Set.mem_iUnion] at hx hy
      rcases hx with ⟨N, hN, P, hP, hxy⟩
      rcases hy with ⟨M, hM, Q, hQ, hxy'⟩
      have hN_in_D : N ∈ D := hN
      have hM_in_D : M ∈ D := hM
      have hP_in_B : P ∈ B N hN := hP
      have hQ_in_B : Q ∈ B M hM := hQ
      have hP_sSup : P ≤ sSup (B N hN) := by
        apply le_sSup
        exact hP_in_B
      have hQ_sSup : Q ≤ sSup (B M hM) := by
        apply le_sSup
        exact hQ_in_B
      have hN_eq_sSup_B : N = sSup (B N hN) := hB N hN
      have hM_eq_sSup_B : M = sSup (B M hM) := hB M hM
      have hP_le_N : P ≤ N := by
        rw [hN_eq_sSup_B] at *
        apply le_sSup_of_le hP_in_B
      have hQ_le_M : Q ≤ M := by
        rw [hM_eq_sSup_B] at *
        apply le_sSup_of_le hQ_in_B
      have hP_le_sSup_Q : P ≤ sSup (B M hM) := by
        apply le_trans hP_le_N
        apply le_trans (le_sSup_of_le (le_refl M))
        apply le_sSup_of_le hQ_in_B
      have hQ_le_sSup_P : Q ≤ sSup (B N hN) := by
        apply le_trans hQ_le_M
        apply le_trans (le_sSup_of_le (le_refl N))
        apply le_sSup_of_le hP_in_B
      have hP_independent_of_Q : Disjoint P Q := by
        apply (sSupIndep (B N hN)).disjoint_of_le hP_in_B
        apply le_sSup_of_le hQ_in_B
      have hQ_independent_of_P : Disjoint Q P := by
        apply (sSupIndep (B M hM)).disjoint_of_le hQ_in_B
        apply le_sSup_of_le hP_in_B
      exact disjoint_iff_inter_eq_empty.mpr (Set.inter_eq_empty_of_disjoint hP_independent_of_Q)
    sSup_eq_top' := by
      have hUnion_le_top : ⋃ N, ⋃ hN, B N hN ≤ ⊤ := by
        intro P hP
        simp only [Set.mem_iUnion] at hP
        rcases hP with ⟨N, hN, P, hP⟩
        exact (le_sSup hP ▸ hB N hN ▸ le_refl (sSup (B N hN)))
      have hTop_le_union : ⊤ ≤ ⋃ N, ⋃ hN, B N hN := by
        intro P hP
        simp only [Set.mem_iUnion]
        use P
        use P
        simp only [Set.mem_setOf_eq]
        exact hB P (by simp)
      exact le_antisymm hUnion_le_top hTop_le_union
    not_bot_mem' := by
      intro hP
      simp only [Set.mem_iUnion] at hP
      rcases hP with ⟨N, hN, P, hP⟩
      have hP_ne_bot : P ≠ ⊥ := by
        intro hP_eq_bot
        have hP_in_B : P ∈ B N hN := hP
        have hB'_N : sSupIndep (B N hN) := hB' N hN
        have hP_in_sSup : P ≤ sSup (B N hN) := by
          apply le_sSup
          exact hP_in_B
        rw [hP_eq_bot] at hP_in_sSup
        have hP_in_sSup_bot : ⊥ ≤ sSup (B N hN) := hP_in_sSup
        have hP_in_B : P ∈ B N hN := hP
        have hB'_N : sSupIndep (B N hN) := hB' N hN
        have hP_ne_in_sSup : P ≠ sSup (B N hN) := by
          intro hP_eq_sSup
          rw [hP_eq_sSup] at hP_in_B
          simp only [Set.mem_singleton_iff] at hP_in_B
          tauto
        have hP_le_sSup : P ≤ sSup (B N hN) := by
          apply le_sSup
          exact hP_in_B
        have hP_eq_sSup : P = sSup (B N hN) := by
          apply le_antisymm hP_le_sSup hP_in_sSup
