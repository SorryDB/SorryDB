    have h2 : (isAgentFinalCall S c.fst c ∧ isAgentFinalCall S c.snd c) ∨ ¬(isAgentFinalCall S c.fst c ∧ isAgentFinalCall S c.snd c) := by
      by_cases h3 : isAgentFinalCall S c.fst c ∧ isAgentFinalCall S c.snd c
