```lean
import Mathlib.Data.List.Basic

def isFinalCall (S : List (Call m)) (c : Call m) : Bool :=
  final S c.fst c = true ∧ final S c.snd c = true

lemma final_both_or_neither (S : List (Call m)) :
    ∀c ∈ S, (isFinalCall S c ∧ isFinalCall S c) ∨ ¬(isFinalCall S c ∧ isFinalCall S c) := by
  intro c hc
  by_cases h : isFinalCall S c
  · -- Assume h : isFinalCall S c is true
    left
    exact ⟨h, h⟩
  · -- Assume h : isFinalCall S c is false
    right
    simp [h]
```

