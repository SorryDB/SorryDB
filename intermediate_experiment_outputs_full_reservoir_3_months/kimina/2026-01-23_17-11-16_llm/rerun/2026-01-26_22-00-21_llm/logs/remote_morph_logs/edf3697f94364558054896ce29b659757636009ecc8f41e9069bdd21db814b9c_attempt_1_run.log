#check Lean.LocalContext.foldlM

example (n: Nat) : n + 2 ≤ n + 4 := by
  induction n
  · -- Base case: n = 0, prove 0 + 2 ≤ 0 + 4
    norm_num
  · -- Inductive step: Assume n + 2 ≤ n + 4, prove n + 1 + 2 ≤ n + 1 + 4
    -- Let's simplify the goal: n + 1 + 2 = n + 3, n + 1 + 4 = n + 5
    -- So the goal is n + 3 ≤ n + 5, which is equivalent to n + 2 ≤ n + 4
