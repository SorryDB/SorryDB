      have RI_sat : satisfiable (Sequent.right (L, R, o) ∪ (interList)) := by
        rcases inter_R_sat with ⟨W, M, w, w_Inter_R⟩
        use W, M, w; simp [conEval] at *; grind
      have := loadedR_sat_down ⟨L,R,o⟩ χ O_is_some lrule YS_def RI_sat
