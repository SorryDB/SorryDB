import Mathlib

/-! A local rule application (LRA) consists of:
-   `L`: the local part of the rule
-   `R`: the right-hand side of the rule
-   `o`: the operator (`L` or `R`)
-   `Lcond`: conditions on the local part
-   `Rcond`: conditions on the right-hand side
-   `Ocond`: overall conditions
-   `ress`: the result of applying the rule
-   `rule`: the specific rule being applied
-   `C`: a list of conditions
-   `hC`: a hypothesis about `C`
-   `precondProof`: proof of preconditions
-/

structure LocalRuleApp :=
  { L : List (Sequent .L)
    R : List (Sequent .R)
    o : Or .L .R
    Lcond : Set (List (Sequent .L))
    Rcond : Set (List (Sequent .R))
    Ocond : Set (List (Sequent .L) × List (Sequent .R) × Or .L .R)
    ress : List (Sequent .L × List (Sequent .R) × Or .L .R)
    rule : PdlRule (List (Sequent .L)) (List (Sequent .R))
    C : List (List (Sequent .L) × List (Sequent .R) × Or .L .R)
    hC : ∀ c ∈ C, (let ⟨L, R, o⟩ := c; L ∈ Lcond ∧ R ∈ Rcond)
    precondProof : PdlRulePreconditions (List (Sequent .L)) (List (Sequent .R)) rule
    }

/-! Maehara's method for single-step *local* rule applications.
This covers easy cases without any loaded path repeats.
We do *not* use `localRuleTruth` to prove this,
but the more specific lemmas `oneSidedL_sat_down` and `oneSidedL_sat_down`. -/
