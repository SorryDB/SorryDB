/-- A local rule application is a rule application that creates a new branch of the
proof state. -/
structure LocalRuleApp (X Y : Sequent) (φ : Formula) (res : RuleResult X Y) (h : X = Y) :
    IsLocal X Y res h := by
  exact ⟨res, h⟩

