      apply localRuleApp_does_not_increase_jvoc _ Y Y_in
      subst def_φ
      exact (subθs Y Y_in).prop.1 n_in_voc_φ
    · rintro nInter_L_sat
      have LI_sat : satisfiable (Sequent.left (L, R, o) ∪ (interList.map Formula.neg)) := by
        rcases nInter_L_sat with ⟨W, M, w, w_nInter_L⟩
        use W, M, w
