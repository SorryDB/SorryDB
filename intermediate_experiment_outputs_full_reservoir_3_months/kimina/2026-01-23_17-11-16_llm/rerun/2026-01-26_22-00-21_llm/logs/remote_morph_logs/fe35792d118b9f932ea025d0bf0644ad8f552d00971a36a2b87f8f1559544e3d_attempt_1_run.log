      have h2 : initPart = S.filter (fun c => isInitialCall S c) := rfl
      have h3 : midPart = S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c)) := rfl
      have h4 : finalPart = S.filter (fun c => isFinalCall S c) := rfl
      rw [h2, h3, h4]
