theorem helper {k n} (h : 4 ≤ n) : k ≤ 2 * n - 5 ↔ k < 2 * n - 4 := by
  rw [Nat.two_mul]
  have := @Nat.add_one_le_iff (k + 4) (n + n)
  rw [add_assoc] at this
  simp at this
  have five_le : 5 ≤ n + n := by linarith
  rw [le_tsub_iff_right five_le]
  rw [this]
  exact Iff.symm Nat.lt_sub_iff_add_lt

/-- For n ≥ 4 agents, any sequence that makes everyone an expert, has length 2n-4 or higher. -/
theorem necessity :
    ∀ n > 4, ∀ σ : List (Call n), allExpert (after σ) → σ.length ≥ 2*n - 4 := by
  by_contra hyp
  simp only [gt_iff_lt, ge_iff_le, not_forall, not_le] at hyp
  -- FIXME later with newer lean: avoid `∃ _` proofs, `simp` does it but `simp only` does not.
  -- let φ n := ∃ (_ : 4 < n), ∃ σ : List (Call n), ∃ (h : allExpert (after σ)), σ.length < 2 * n - 4
  have := exists_to_minimal_exists _ hyp
  rcases this with ⟨m, ⟨le_m, ⟨S, S_allExp, S_len_lt⟩⟩, m_is_minimal⟩
  rw [← helper (by linarith)] at S_len_lt
  -- `m_is_minimal` is not yet exactly the right input for `noHo_of_minimal_expert_sequence`.
  have is_minimal_m : is_minimal m := by
    simp at m_is_minimal
    unfold is_minimal phi is_f_leq
    simp
    constructor
    · exact ⟨le_m, S, ⟨S_allExp, S_len_lt⟩⟩
    · intro k k_lt_m four_lt_k σ σ_AllExp
      have := m_is_minimal k k_lt_m four_lt_k σ σ_AllExp
      simp_rw [@Nat.le_iff_lt_add_one] at this
      omega
  -- Now we can use the lemma.
  have noHo_S : noHo S := noHo_of_minimal_expert_sequence S S_len_lt S_allExp is_minimal_m

  -- 2.3 Graph Building -- TODO

  let initPart : List (Call m) :=
  S.filter (fun c => (isInitialCall S c))

  let midPart : List (Call m) :=
  S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))

  let finalPart : List (Call m) :=
  S.filter (fun c => (isFinalCall S c))

  have : S.length = initPart.length + midPart.length + finalPart.length := by
    -- Proof that the three parts form a partition of S
    have h1 : initPart.length + midPart.length + finalPart.length = S.length := by
      -- Show that the three parts are disjoint and their union is S
      have h2 : Disjoint (initPart ::midPart ::finalPart :: []) := by
        -- Prove disjointness of the three parts
        simp [Disjoint]
        intro x hx y hy
        -- Show that an element cannot be in two different parts
        fin_cases hx <;> fin_cases hy <;> simp [isInitialCall, isFinalCall] at *
        all_goals
          try { tauto }
          try { omega }
      -- Prove that the union of the three parts is S
      have h3 : initPart ++ midPart ++ finalPart = S := by
        -- Show that the union of the three parts covers all elements of S
        ext c
        simp [initPart, midPart, finalPart]
        -- Consider an arbitrary call c in S
        by_cases hc1 : isInitialCall S c
        · -- If c is an initial call, it's in initPart
          simp [hc1]
          -- Check that c is not in midPart or finalPart
          have hc2 : ¬(isFinalCall S c) := by
            -- Use the fact that no call can be both initial and final
            have h1 := initial_both_or_neither S c (by simp)
            cases h1 with
            | inl h => tauto
            | inr h => tauto
          have hc3 : ¬(¬isInitialCall S c ∧ ¬isFinalCall S c) := by
            simp [hc1]
          tauto
        · -- If c is not initial, consider midPart and finalPart
          by_cases hc2 : isFinalCall S c
          · -- If c is a final call, it's in finalPart
            simp [hc2]
            -- Check that c is not in initPart or midPart
            have hc1' : ¬isInitialCall S c := by tauto
            have hc3 : ¬(¬isInitialCall S c ∧ ¬isFinalCall S c) := by
              simp [hc2]
            tauto
          · -- If c is neither initial nor final, it's in midPart
            simp [hc1, hc2]
            -- Check that c is not in initPart or finalPart
            have hc3 : ¬isInitialCall S c := by tauto
            have hc4 : ¬isFinalCall S c := by tauto
            tauto
      -- Use the fact that the length of a list is the sum of the lengths of its parts
      rw [h3]
      -- Apply the list length concatenation lemma
      rw [List.length_append, List.length_append]
      simp
    -- The equality is proven, so we can conclude
    exact h1.symm
