    simpa using E₄.holo'
  have hE6 : Holomorphic (fun z : ℂ => E₆.toFun z) := by
    simpa using E₆.holo'
  have hF_holo : Holomorphic F := by
    rw [hF]
    apply Holomorphic.pow
    · -- Show that `fun z ↦ E₂ z * E₄.toFun z - E₆.toFun z` is holomorphic
      apply Holomorphic.sub
      · -- Show that `fun z ↦ E₂ z * E₄.toFun z` is holomorphic
        apply Holomorphic.mul
        · exact hE2
        · exact hE4
      · -- Show that `fun z ↦ E₆.toFun z` is holomorphic
        exact hE6
    · -- The exponent `2` is a natural number
