      simp at hδ₁ hδ₂ ⊢;
      omega
    cases hδ₁ with
    | inl hδ₁ =>
      simp [hδ₁] at *; tauto
    | inr hδ₁ =>
      simp [hδ₁] at *; tauto
  have : ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) → ξ ∈ T.theory := by
    apply T.imp_closed ?_ $ T.andIR hΓ₂ hΔ₂;
    apply T.mem_of_provable; -- Line of thought: Prove that (Γ.conj ⋏ Δ.conj) → (φ ⋎ ψ) is in T's theory
    apply Classical.propDecidable; -- Line of thought: Use classical logic for decidability
    apply Classical.propDecidable; -- Line of thought: Use classical logic for decidability
    apply Classical.propDecidable; -- Line of thought: Use classical logic for decidability
  have : ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) → ξ ∈ construction_omega T hT := by
    apply T.mem_of_provable; -- Line of thought: Prove that (Γ.conj ⋏ Δ.conj) → (φ ⋎ ψ) is in the omega construction
    apply Classical.propDecidable; -- Line of thought: Use classical logic for decidability
  have : ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) → ξ ∈ construction_omega T hT := by
    apply T.mem_of_provable; -- Line of thought: (Re)state the previous goal using T.mem_of_provable
    apply Classical.propDecidable; -- Line of thought: Use classical logic for decidability
  tauto -- Line of thought: Use tauto to close the goal

