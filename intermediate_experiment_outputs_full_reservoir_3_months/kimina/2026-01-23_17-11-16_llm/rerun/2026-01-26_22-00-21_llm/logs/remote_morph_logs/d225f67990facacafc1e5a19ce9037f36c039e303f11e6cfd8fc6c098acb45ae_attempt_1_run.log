      simp [construction] at *             -- Simplifies goal and uses hΔ_imp to prove goal
      tauto                                -- Tactic to close goal using simplified facts
      contradiction                       -- Finds contradiction between this and the proven fact

lemma of_not_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∉ construction_omega T hT) :
  (χ ➝ φ ∉ T.theory) ∧ (∃ Γ : Finset (Formula _), ↑Γ ⊆ (construction T hT (encode φ)) ∧ Γ.conj ⋏ φ ➝ ξ ∈ T.theory) := by
