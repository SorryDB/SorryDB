import Foundation
import Mathlib

variable {α : Type*}
variable {S} [Entailment S (Formula α)]
variable {𝓈 : S}

structure FTheory (L : Logic ℕ) where
  theory : FormulaSet ℕ
  no_bot : ⊥ ∉ theory
  andIR : ∀ {φ ψ}, φ ∈ theory → ψ ∈ theory → φ ⋏ ψ ∈ theory
  imp_closed : ∀ {φ ψ}, L ⊢ φ → ψ ∈ theory → ψ ∈ theory
  L_subset : L ⊆ theory

namespace FTheory

variable {T : FTheory L} {φ ψ χ : Formula ℕ}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hφ : L ⊢ φ) : φ ∈ T := by
  apply T.imp_closed (φ := ⊤) $ af hφ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (h₁ : φ → ψ ∈ T) (h₂ : ψ → χ ∈ T) : φ → χ ∈ T := by
  apply T.imp_closed (axiomI (ψ := ψ));
  apply T.andIR h₁ h₂;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hφ : φ ∈ T) : φ ∨ ψ ∈ T := by
  apply T.imp_closed (φ := φ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hψ : ψ ∈ T) : φ ∨ ψ ∈ T := by
  apply T.imp_closed (φ := ψ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : φ ∈ T ↔ Deduction Ax T φ := by
  constructor;
  . intro hφ;
    apply Deduction.ctx hφ;
  . intro h; induction h <;> grind

end FTheory


