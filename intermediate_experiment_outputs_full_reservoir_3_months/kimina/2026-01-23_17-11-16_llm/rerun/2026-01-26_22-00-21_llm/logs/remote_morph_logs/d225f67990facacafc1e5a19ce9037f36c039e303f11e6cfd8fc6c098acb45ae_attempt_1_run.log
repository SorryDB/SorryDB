  have : ((Γ.conj ⋏ Δ.conj) ⋏ (φ ⋎ ψ)) → ξ ∈ T.theorem := by
    apply T.imp_closed ?_ $ T.andIR hΓ₂ hΔ₂;
    sorry;
  sorry;

lemma construction_omega_noBot :
  letI U := construction_omega T hT
  ⊥ ∉ U := by
  simp [construction_omega, Set.mem_iUnion, not_exists];
  intro i;
  induction i with
