  (χ → φ ∉ T.lindenbaum.T_theory) ∧ (∃ Γ : Finset (Formula _), ↑Γ ⊆ (construction T hT (encode φ)) ∧ (Γ.conj ⋏ φ) ∈ T.lindenbaum.T_theory) := by
