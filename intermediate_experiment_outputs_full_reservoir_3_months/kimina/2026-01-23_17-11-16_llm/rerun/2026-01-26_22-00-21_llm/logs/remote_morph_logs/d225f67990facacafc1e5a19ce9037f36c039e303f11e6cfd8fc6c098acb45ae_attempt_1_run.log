lemma not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at *
  intro i;
  induction i with
  | zero => simpa [construction] using hφ;
  | succ i ih =>
    dsimp [construction] at ih hφ ⊢;
    split at ih hφ ⊢;
    . split_ifs at ih hφ ⊢ with h;
      . rename_i δ hδ;
        by_contra hC;
        have : δ = φ := by
          have : encode δ = encode φ := by
            simp [hδ] at *; tauto
          have : δ = φ := by
            apply encode_eq_of_eq at this;
            assumption
          assumption
        subst this;
        apply hΓ (by simp) hC; contradiction
      . assumption
    . assumption
    . assumption
    . assumption

lemma of_not_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∉ construction_omega T hT) :
  (χ ➝ φ ∉ T.theory) ∧ (∃ Γ : Finset (Formula _), ↑Γ ⊆ (construction T hT (encode φ)) ∧ Γ.conj ⋏ φ ➝ ξ ∈ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hφ;
  constructor;
  . simpa using hφ 0;
  . have this := hφ (encode φ + 1); -- Line of thought: Extract the second part of the conjunction from hφ
    simp only [construction, encodek] at this; -- Line of thought: Simplify the expression
    split_ifs at this with h; -- Line of thought: Handle the 'if' condition in the definition of construction
