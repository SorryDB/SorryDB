            apply encode_eq_of_eq at this;
            assumption
          have : (i + 1 : ℕ) = (i + 1 : ℕ) := by rfl; tauto
        subst this;
        apply T.mem_of_provable;
        simp;
      . assumption
    . assumption;

lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra! h;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega h;
