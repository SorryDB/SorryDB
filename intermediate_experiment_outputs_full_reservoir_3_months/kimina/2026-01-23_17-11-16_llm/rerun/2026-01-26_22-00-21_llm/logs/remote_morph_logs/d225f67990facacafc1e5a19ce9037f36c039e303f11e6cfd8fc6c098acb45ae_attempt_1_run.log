    intro h
    have h3 := h1 (by simp [h, construction_omega])
    contradiction
  have h3 := h2 0
  have h4 : (φ ∈ construction T hT 0) := by
    simp [h3] at *
    all_goals tauto
  exfalso
  tauto

lemma of_not_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∉ construction_omega T hT) :
  (χ → φ ∉ T.lindenbaum.T_theory) ∧ (∃ Γ : Finset (Formula _), ↑Γ ⊆ (construction T hT (encode φ)) ∧ (Γ.conj ⋏ φ) ∈ T.lindenbaum.T_theory) := by
