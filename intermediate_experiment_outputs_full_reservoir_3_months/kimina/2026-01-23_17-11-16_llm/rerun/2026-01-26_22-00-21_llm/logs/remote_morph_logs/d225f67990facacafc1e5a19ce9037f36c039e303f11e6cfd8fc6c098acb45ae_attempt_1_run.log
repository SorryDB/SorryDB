  have h5 : (({φ, ψ} : Finset (Formula ℕ)).conj ⋏ (φ ⋎ ψ)) ∈ construction_omega T hT := by
    simpa using h4;
  tauto;

lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L ⊢ φ ➝ ψ → φ ∈ U → ψ ∈ U := by
  rintro hφψ hφ;
  simp only [construction_omega, Set.mem_iUnion];
