```lean
import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped EuclideanGeometry

/--
Let $d$ be the sum of the lengths of all the diagonals of a plane convex polygon with $n>3$ vertices. Let $p$ be its perimeter. Prove that: $$n-3<{2d\over p}<\Bigl[{n\over2}\Bigr]\Bigl[{n+1\over 2}\Bigr]-2,$$ where $[x]$ denotes the greatest integer not exceeding $x$. -/
@[imo_problem_subject combinatorics]
theorem imo_1984_p5
    --`n > 3` is the number of vertices of the polygon. The `NeZero` instance is there so we can consider the element `1 : Fin n`
    {n d p : ℕ} [NeZero n] {hn : n > 3}
    --The `P i` are the vertices of the polygon
    (P : Fin n → ℝ²)
    --The polygon is convex
    (hP : ∀ i j, j ≠ i-1 → j ≠ i → (∡ (P (i-1)) (P i) (P j)).sign = 1)
    --`p` is the perimeter of the polygon
    (hp : p = ∑ i, dist (P i) (P (i+1)))
    --`d` is the sum of the lengths of all the diagonals, i.e. the sum of all distances `d(P i, P j)` where `P i` and `P j` are distinct points that do not share an edge.
    (hd : d = 1/2 * ∑ i, ∑ j ∈ (Finset.univ \ {i-1, i, i+1}), dist (P i) (P j))
    : (n-3 : ℝ) < 2*d / p ∧ (2*d / p : ℝ) <  ⌊ (n/2 : ℝ)⌋ * ⌊ (n+1 : ℝ)/2 ⌋ - 2 := by
  have hp' : (p : ℝ) = ∑ i : Fin n, dist (P i) (P (i + 1)) := by
    exact_mod_cast hp
  have hd' : (d : ℝ) = 1 / 2 * ∑ i : Fin n, ∑ j ∈ (Finset.univ \ {i - 1, i, i + 1}), dist (P i) (P j) := by
    exact_mod_cast hd
  have h1 : (n : ℝ) > (3 : ℝ) := by
    exact_mod_cast hn
  have h2 : (p : ℝ) > 0 := by
    have hp1 : p > 0 := by
      have hp1 : p = ∑ i, dist (P i) (P (i + 1)) := hp
      rw [hp1]
      apply Finset.sum_pos
      · -- Show that each term in the sum is non-negative
        intro i hi
        apply dist_nonneg
      · -- Show that at least one term is positive
        use ⟨0, by linarith⟩
        simp
        have hP01 : dist (P 0) (P 1) > 0 := by
          apply dist_pos
          -- Need to show P 0 ≠ P 1
          by_contra h
          have hP01 : P 0 = P 1 := by
            simpa using h
          have hP012 := hP 0 1 (by
            simp [Finset.mem_univ]
            <;> tauto
          ) (by
            simp [Finset.mem_univ]
            <;> tauto
          )
          simp [hP01] at hP012
          all_goals
            try { linarith }
        linarith
    exact_mod_cast hp1
  constructor
  · -- Prove the lower bound: n - 3 < 2 * d / p
    have h3 : (p : ℝ) * ((n : ℝ) - 3) < 2 * (d : ℝ) := by
      simp [hp', hd']
      <;> 
      try { 
        nlinarith [sq_nonneg (∑ i : Fin n, dist (P i) (P (i + 1)) - 2 * (1 / 2 * ∑ i : Fin n, ∑ j ∈ (Finset.univ \ {i - 1, i, i + 1}), dist (P i) (P j))), 
          sq_nonneg (∑ i : Fin n, dist (P i) (P (i + 1))), 
          sq_nonneg (∑ i : Fin n, ∑ j ∈ (Finset.univ \ {i - 1, i, i + 1}), dist (P i) (P j)), 
          Finset.sum_pos (show ∀ i ∈ Finset.univ, dist (P i) (P (i + 1)) > 0 by intro i hi; apply dist_pos; by_contra h; have : P i = P (i + 1) := by simpa using h; have hP1 := hP i (i + 1) (by simp [Finset.mem_univ]; <;> tauto) (by simp [Finset.mem_univ]; <;> tauto); simp [this] at hP1; all_goals try { linarith }) (Finset.univ_nonempty), 
          Finset.sum_nonneg (show ∀ i ∈ Finset.univ, dist (P i) (P (i + 1)) ≥ 0 by intro i hi; apply dist_nonneg), 
          Finset.sum_nonneg (show ∀ i ∈ Finset.univ, ∑ j ∈ (Finset.univ \ {i - 1, i, i + 1}), dist (P i) (P j) ≥ 0 by intro i hi; apply Finset.sum_nonneg; intro j hj; apply dist_nonneg
          ]
      }
    have h4 : (2 * (d : ℝ) / (p : ℝ)) > (n - 3 : ℝ) := by
      apply (lt_div_iff₀ (by positivity)).mpr
      linarith
    linarith
  · -- Prove the upper bound: 2 * d / p < ⌊ n / 2 ⌋ * ⌊ (n + 1) / 2 ⌋ - 2
    have h4 : (2 * (d : ℝ) / (p : ℝ)) < (⌊ (n / 2 : ℝ)⌋ * ⌊ (n + 1 : ℝ) / 2 ⌋ - 2 : ℝ) := by
      simp [hp', hd']
      <;> 
      try { 
        nlinarith [sq_nonneg (∑ i : Fin n, dist (P i) (P (i + 1)) - 2 * (1 / 2 * ∑ i : Fin n, ∑ j ∈ (Finset.univ \ {i - 1, i, i + 1}), dist (P i) (P j))), 
          sq_nonneg (∑ i : Fin n, dist (P i) (P (i + 1))), 
          sq_nonneg (∑ i : Fin n, ∑ j ∈ (Finset.univ \ {i - 1, i, i + 1}), dist (P i) (P j)), 
