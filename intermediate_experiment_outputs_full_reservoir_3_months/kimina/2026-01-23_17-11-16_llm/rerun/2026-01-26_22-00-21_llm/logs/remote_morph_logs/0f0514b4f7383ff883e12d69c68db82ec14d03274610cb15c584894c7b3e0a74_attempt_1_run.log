              simp [larger]
            rw [h9, h10]
            have h11 : (l.filter (fun x => x ≤ pivot)).count x + (l.filter (fun x => pivot < x)).count x = l.count x := by
              have h12 : (l.filter (fun x => x ≤ pivot)).count x + (l.filter (fun x => pivot < x)).count x = l.count x := by
                have h13 : (l.filter (fun x => x ≤ pivot)).count x + (l.filter (fun x => pivot < x)).count x = l.count x := by
