open Real

/-!
The lemma states that the velocity of the trajectory is zero if and only if the norm of the position at time `t` equals `√(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2)`.
-/

lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have h1 : ∂ₜ (IC.trajectory S) t = 0 ↔
      ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by
    constructor
    · -- Forward direction: if velocity is zero, then norm of position equals the given expression
      intro h
      have h2 : ∂ₜ (IC.trajectory S) t = 0 := by
        simpa using h
      have h3 : ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by
        have h4 : (IC.trajectory S) t = cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀ := by
          simp [trajectory_eq]
        rw [h4]
        have h5 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖ =
            Real.sqrt ((cos (S.ω * t.val) * ‖IC.x₀‖)^2 + ( (sin (S.ω * t.val) / S.ω) * ‖IC.v₀‖ )^2 ) := by
          simp [norm_add, norm_smul, norm_mul, Fin.sum_univ_succ, Fin.sum_univ_zero, mul_add, add_mul]
          <;> ring_nf
        rw [h5]
        have h6 : (cos (S.ω * t.val) * ‖IC.x₀‖)^2 + ( (sin (S.ω * t.val) / S.ω) * ‖IC.v₀‖ )^2 =
            ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 := by
          have h7 : cos (S.ω * t.val)^2 + sin (S.ω * t.val)^2 = 1 := by
            exact Real.cos_sq_add_sin_sq (S.ω * t.val)
          field_simp at *
          nlinarith [h7]
        rw [h6]
      exact h3
    · -- Reverse direction: if norm of position equals the given expression, then velocity is zero
      intro h
      have h4 : ∂ₜ (IC.trajectory S) t = 0 := by
        have h5 : (IC.trajectory S) t = cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀ := by
          simp [trajectory_eq]
        have h6 : ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2) := by
          simpa using h
        have h7 : ∂ₜ (IC.trajectory S) t = - S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀ := by
          simp [trajectory_velocity]
        rw [h7]
        have h8 : ‖(IC.trajectory S) t‖^2 = ‖IC.x₀‖^2 + (‖IC.v₀‖ / S.ω)^2 := by
          rw [h6]
          rw [Real.sq_sqrt (by positivity)]
        have h9 : ‖(IC.trajectory S) t‖^2 = ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖^2 := by
          rw [h5]
        rw [h9] at h8
        have h10 : ‖cos (S.ω * t.val) • IC.x₀ + (sin (S.ω * t.val) / S.ω) • IC.v₀‖^2 =
            ‖cos (S.ω * t.val) • IC.x₀‖^2 + ‖(sin (S.ω * t.val) / S.ω) • IC.v₀‖^2 := by
          simp [norm_add, norm_smul, norm_mul, Fin.sum_univ_succ, Fin.sum_univ_zero, mul_add, add_mul]
          <;> ring_nf
        rw [h10] at h8
        have h11 : ‖cos (S.ω * t.val) • IC.x₀‖^2 = cos (S.ω * t.val)^2 * ‖IC.x₀‖^2 := by
          simp [norm_smul, norm_mul, Fin.sum_univ_succ, Fin.sum_univ_zero, mul_add, add_mul]
          <;> ring_nf
        have h12 : ‖(sin (S.ω * t.val) / S.ω) • IC.v₀‖^2 = (sin (S.ω * t.val)^2 / S.ω^2) * ‖IC.v₀‖^2 := by
          simp [norm_smul, norm_mul, Fin.sum_univ_succ, Fin.sum_univ_zero, mul_add, add_mul]
          <;> ring_nf
        rw [h11, h12] at h8
        have h13 : cos (S.ω * t.val)^2 + sin (S.ω * t.val)^2 = 1 := by
          exact Real.cos_sq_add_sin_sq (S.ω * t.val)
        have h14 : (- S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀) • (- S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀) = 0 := by
          nlinarith [sq_nonneg (cos (S.ω * t.val) * ‖IC.v₀‖ - S.ω * sin (S.ω * t.val) * ‖IC.x₀‖), sq_nonneg (sin (S.ω * t.val) * ‖IC.x₀‖ + cos (S.ω * t.val) * ‖IC.v₀‖ / S.ω), sq_nonneg (cos (S.ω * t.val) * ‖IC.v₀‖ - S.ω * sin (S.ω * t.val) * ‖IC.x₀‖), sq_nonneg (sin (S.ω * t.val) * ‖IC.v₀‖ + cos (S.ω * t.val) * ‖IC.x₀‖ / S.ω), h13]
        have h15 : (- S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀) = 0 := by
          nlinarith [h14, sq_nonneg (- S.ω • sin (S.ω * t.val) • IC.x₀ + cos (S.ω * t.val) • IC.v₀)]
        simpa using h15
      simpa using h4
  exact h1
