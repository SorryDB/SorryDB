    intro i j hle
    have h4 : X i = P.conditionalExpectation (fun (ω : Ω) ↦ X j ω) (𝓕 i) := by
      have h5 : ∀ ω, X i ω = P.conditionalExpectation (fun (ω : Ω) ↦ X j ω) (𝓕 i) ω := by
        intro ω
        have h6 : P.conditionalExpectation (fun (ω : Ω) ↦ X j ω) (𝓕 i) ω = X i ω := by
          have h7 : (fun (ω : Ω) ↦ X j ω) = (fun (ω : Ω) ↦ X i ω) := by
            apply P.ae_eq_of_subset_of_ae
