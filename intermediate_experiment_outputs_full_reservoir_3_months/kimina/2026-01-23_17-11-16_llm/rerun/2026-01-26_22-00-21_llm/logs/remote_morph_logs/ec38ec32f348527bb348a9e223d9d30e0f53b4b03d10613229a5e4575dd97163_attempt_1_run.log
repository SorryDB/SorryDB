open ProbabilityTheory
open MeasureTheory

variable (x y : Bool)

have hx : x = true ∨ x = false := by
  cases x with
  | inl h => 
    simp [h]
  | inr h => 
    simp [h]

have hy : y = true ∨ y = false := by
  cases y with
  | inl h => 
    simp [h]
  | inr h => 
    simp [h]

rcases hx with (hx | hx)
· -- x = true
  rcases hy with (hy | hy)
  · -- y = true
    simp [hx, hy]
  · -- y = false
    simp [hx, hy]
    <;> try { 
      simp [evalDist_uniformSelectVector, pmf_apply, Fin.sum_univ_succ, Fin.sum_univ_zero, Fin.sum_univ_one]
      <;> try { native_decide }
    }
    <;> try { 
      native_decide
    }
· -- x = false
  rcases hy with (hy | hy)
  · -- y = true
    simp [hx, hy]
