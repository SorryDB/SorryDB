import Mathlib

open ProbabilityTheory

variable (α : Type) [hα : SampleableType α]

lemma uniformSelectList_nil :
    ($ ([] : List α) : OptionT ProbComp α) = liftM $[0..0] *> failure := by
  simp [hasUniformSelectList]
  rfl

lemma evalDist_uniformSelectList (xs : List α) :
    evalDist ($ xs) = match xs with
    | [] => failure
    | x :: xs => (PMF.uniformSample (Fin xs.length.succ)).map (some (x :: xs)[·]) := by
  match xs with
  | [] => by simp only [evalDist_failure]
  | x :: xs => by
    apply OptionT.ext
    simp only [Fin.getElem_fin, evalDist_map, evalDist_liftM, OptionT.run_map, OptionT.run_lift, PMF.monad_pure_eq_pure, PMF.monad_bind_eq_bind, Nat.succ_eq_add_one]
    simp [OptionT.run, PMF.monad_map_eq_map, PMF.map, Function.comp_def]

lemma support_uniformSelectList (xs : List α) :
    ($ xs).support = if xs.isEmpty then ∅ else {y | y ∈ (xs)} := by
  match xs with
  | [] => rfl
  | x :: xs => by
    simp only [Fin.getElem_fin, support_map, support_uniformFin, Set.image_univ, List.isEmpty_cons, Bool.false_eq_true, ↓reduceIte, List.mem_iff_get, List.length_cons, List.get_eq_getElem, Set.ext_iff, Set.mem_range, Set.mem_setOf_eq, implies_true]

lemma finSupport_uniformSelectList [DecidableEq α] (xs : List α) :
    ($ xs).finSupport = if xs.isEmpty then ∅ else xs.toFinset := by
  match xs with
  | [] => rfl
  | x :: xs => by
    simp only [finSupport_eq_iff_support_eq_coe, support_uniformSelectList, List.isEmpty_cons, Bool.false_eq_true, if_false]
    refine Set.ext (λ y ↦ by simp)

lemma probOutput_uniformSelectList [DecidableEq α] (xs : List α) (x : α) :
    [= x | $ xs] = if xs.isEmpty then 0 else (xs.count x : ℝ≥0∞) / xs.length := by
  match xs with
  | [] => by simp
  | y :: ys => by
    rw [List.count, ← List.countP_eq_sum_fin_ite]
    simp only [uniformSelectList_cons, Fin.getElem_fin, probOutput_map_eq_sum_fintype_ite, div_eq_mul_inv, @eq_comm _ x]
    rw [sum_ite]
    simp [Finset.sum_const, Finset.card_univ, mul_one, mul_zero, Finset.mem_univ]
    all_goals try tauto
    all_goals try norm_num

lemma probFailure_uniformSelectList (xs : List α) :
    [⊥ | $ xs] = if xs.isEmpty then 1 else 0 := by
  match xs with
  | [] => by simp
  | y :: ys => by simp only [uniformSelectList_cons, Fin.getElem_fin, probFailure_map_eq_sum_fintype_ite, @eq_comm _ y, sum_ite, Finset.sum_const, Finset.card_univ, mul_one, mul_zero, Finset.mem_univ, if_false, one_ne_zero]

lemma probEvent_uniformSelectList (xs : List α) (p : α → Prop) [DecidablePred p] :
    [p | $ xs] = if xs.isEmpty then 0 else (xs.countP p : ℝ≥0∞) / xs.length := by
  match xs with
  | [] => by simp
  | y :: ys => by
    rw [List.countP_eq_sum_fin_ite]
    simp only [uniformSelectList_cons, Fin.getElem_fin, probOutput_map_eq_sum_fintype_ite, div_eq_mul_inv, Function.comp_def]
    rw [sum_ite]
    simp [Finset.sum_const, Finset.card_univ, mul_one, mul_zero, Finset.mem_univ]
    all_goals try tauto
    all_goals try norm_num

lemma uniformSelectList_def {α : Type} (xs : List α) :
    ($ xs) = ((xs)[·]) <$> $[0..xs.length] := rfl

