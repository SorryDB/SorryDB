noncomputable def reward (n : ℕ) (ω : ℕ → α × ℝ) : ℝ := ω n.2

noncomputable def arm (n : ℕ) (ω : ℕ → α × ℝ) : α := ω n.1

noncomputable def stepsUntil (a : α) (n : ℕ) (ω : ℕ → α × ℝ) : ℕ∞ :=
  sInf {t : ℕ | ω t.1 = a}

noncomputable def pullCount (a : α) (n : ℕ) (ω : ℕ → α × ℝ) : ℕ :=
  {t | ω t.1 = a}.min' (by use n; simp)

