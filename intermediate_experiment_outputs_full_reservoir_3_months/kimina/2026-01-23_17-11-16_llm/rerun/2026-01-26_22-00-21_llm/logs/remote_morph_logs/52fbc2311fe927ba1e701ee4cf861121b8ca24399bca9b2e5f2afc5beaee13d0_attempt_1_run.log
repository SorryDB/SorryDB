  -- Define the type of a trajectory
  type alias Trajectory α ℝ := ℕ → StepResult α ℝ
  -- Define the type of a decision (arm choice)
  type alias ArmChoice α := ℕ → α
  -- Define the type of a reward function
  type alias RewardFunction α ℝ := ℕ → α → ℝ

  -- Define the pull count function
  def pullCount (a : α) (n : ℕ) (ω : Trajectory α ℝ) : ℕ :=
    (List.length (List.filter (fun x ↦ x.1 = a) (List.map (fun i ↦ ω i) (Finset.range n)))).toNat

  -- Define the reward function
  def reward (n : ℕ) (a : α) (ω : Trajectory α ℝ) : ℝ :=
    ∑ i in range n, ω i.2

  -- Define the steps until function
  def stepsUntil (a : α) (m : ℕ) (ω : Trajectory α ℝ) : ℕ∞ :=
    if m = 0 then
      0
    else
      let s := Nat.find (fun i ↦ ω i.1 = a ∧ i ≥ m)
      if s = Nat.findBounds (fun i ↦ i ≥ m) then
        Nat.findBounds (fun i ↦ i ≥ m)
      else
        s

  -- Define the reward by count function
  def rewardByCount (a : α) (n : ℕ) (ω : Trajectory α ℝ) : ℝ :=
    ∑ i in range n, ω i.2

