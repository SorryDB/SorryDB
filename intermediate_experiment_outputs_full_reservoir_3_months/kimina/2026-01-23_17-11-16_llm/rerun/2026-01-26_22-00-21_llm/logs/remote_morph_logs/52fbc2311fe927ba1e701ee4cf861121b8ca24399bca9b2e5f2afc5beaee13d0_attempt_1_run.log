have h1 : IndepFun (fun ω s ↦ rewardByCount a s ω) (fun ω s ↦ (ω s) a) 𝔓 := by
  have h_eq : (fun ω s ↦ rewardByCount a s ω) = (fun ω s ↦ (ω s) a) := by
    fun_prop
  rw [h_eq]
  apply IndepFun.refl
```

Wait, this is incorrect. `fun ω s ↦ rewardByCount a s ω` and `fun ω s ↦ ω s a` are not equal. `fun ω s ↦ rewardByCount a s ω` is the total reward up to step `s` for arm `a`, while `fun ω s ↦ ω s a` is just the value of the `s`-th step of the trajectory `ω` at arm `a`.

But we know from `identDistrib_rewardByCount_eval` that they have the same distribution.

So, we need to use `IdentDistrib` implies `IndepFun`.

```tactics
have h1 : IndepFun (fun ω s ↦ rewardByCount a s ω) (fun ω s ↦ (ω s) a) 𝔓 := by
  have h_eq : IdentDistrib (fun ω s ↦ rewardByCount a s ω) (fun ω s ↦ (ω s) a) 𝔓 (Bandit.streamMeasure ν) := by
    apply identDistrib_rewardByCount_eval
  have h_indep : IndepFun (fun ω s ↦ rewardByCount a s ω) (fun ω s ↦ (ω s) a) 𝔓 := by
    apply h_eq.induced_indepFun
  exact h_indep
```

Similarly for the second function:

```tactics
have h2 : IndepFun (fun ω s ↦ (ω s) a) (fun ω s ↦ (ω s) b) 𝔓 := by
  apply IndepFun.map_evals_of_ne
  exact hab
```

And for the third function:

```tactics
have h3 : IndepFun (fun ω s ↦ (ω s) b) (fun ω s ↦ rewardByCount b s ω) 𝔓 := by
  have h_eq : IdentDistrib (fun ω s ↦ (ω s) b) (fun ω s ↦ rewardByCount b s ω) 𝔓 (Bandit.streamMeasure ν) := by
    apply identDistrib_eval_streamMeasure_measure
  have h_indep : IndepFun (fun ω s ↦ (ω s) b) (fun ω s ↦ rewardByCount b s ω) 𝔓 := by
    apply h_eq.induced_indepFun
  exact h_indep
```

Now, we can combine these using transitivity of independence.

```tactics
have h4 : IndepFun (fun ω s ↦ rewardByCount a s ω) (fun ω s ↦ rewardByCount b s ω) 𝔓 := by
  have h5 : IndepFun (fun ω s ↦ rewardByCount a s ω) (fun ω s ↦ (ω s) a) 𝔓 := h1
  have h6 : IndepFun (fun ω s ↦ (ω s) a) (fun ω s ↦ (ω s) b) 𝔓 := h2
  have h7 : IndepFun (fun ω s ↦ (ω s) b) (fun ω s ↦ rewardByCount b s ω) 𝔓 := h3
  exact IndepFun.trans (IndepFun.symm h5).trans h6 h7
exact h4
```

This completes the proof.
