import Mathlib

open Filter Measure ProbabilityTheory

namespace bandit

variable {α : Type u_1} {mα : MeasurableSpace α} [DecidableEq α] [MeasurableSingletonClass α] at *
variable {alg : Algorithm α ℝ} {ν : Kernel α ℝ} [IsMarkovKernel ν]

open Measure

lemma rewardByCount_eq_sum (a : α) (s : ℕ) (ω : ℕ → α × ℝ) :
    rewardByCount a s ω = ∑ i in Finset.filter (fun i ↦ arm i ω = a) (Finset.range s), (r i ω) := by
  simp only [rewardByCount, Finset.sum_filter, Finset.sum_range_succ]
  induction s with
  | zero =>
    simp
  | succ s ih =>
    simp only [Nat.succ_eq_add_one, Finset.range_succ, Finset.filter_insert]
    rw [Finset.sum_insert (by simp)]
    simp only [Finset.mem_range, true_and]
    rw [ih]
    simp

lemma disjoint_filter (a b : α) (hab : a ≠ b) (s : ℕ) (ω : ℕ → α × ℝ) :
    Disjoint (Finset.filter (fun i ↦ arm i ω = a) (Finset.range s))
      (Finset.filter (fun i ↦ arm i ω = b) (Finset.range s)) := by
  rw [Finset.disjoint_iff_ne]
  intro i hi hi' j hj hj' h_eq
  have h1 : i < s := by simp at hi; linarith
  have h2 : j < s := by simp at hj; linarith
  have h3 : arm i ω = a := by simp at hi'; tauto
  have h4 : arm j ω = b := by simp at hj'; tauto
  have h5 : i = j := by linarith
  rw [h5] at h3
  tauto

lemma iIndepFun_rewardByCount_of_ne {a b : α} (hab : a ≠ b) :
    iIndepFun (fun (ω s : ℕ → α × ℝ × ℕ) ↦ rewardByCount a s ω) (fun (ω s : ℕ → α × ℝ × ℕ) ↦ rewardByCount b s ω) (Bandit.measure alg ν) := by
  apply iIndepFun_of_indepFun
  intro ω s
  have h3 : IndepFun (fun ω' s' ↦ ∑ i in Finset.filter (fun i ↦ arm i ω' = a) (Finset.range s'), r i ω')
      (fun ω' s' ↦ ∑ i in Finset.filter (fun i ↦ arm i ω' = b) (Finset.range s'), r i ω') (Bandit.measure alg ν) := by
    apply IndepFun.sum
    · -- Show that `fun ω' ↦ ∑ i in Finset.filter (fun i ↦ arm i ω' = a) (Finset.range s), r i ω'` is independent
      apply IndepFun.comp
      · -- Show that `fun ω' ↦ Finset.filter (fun i ↦ arm i ω' = a) (Finset.range s)` is independent
