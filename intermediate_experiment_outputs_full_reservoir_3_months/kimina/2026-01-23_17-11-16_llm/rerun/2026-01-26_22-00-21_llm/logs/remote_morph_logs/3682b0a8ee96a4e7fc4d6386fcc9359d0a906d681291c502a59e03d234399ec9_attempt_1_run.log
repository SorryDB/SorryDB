def MemLorentz (f : α → ε) (p r : ℝ≥0∞) (μ : Measure α) : Prop :=
  let f_abs := fun (x : α) => ‖f x‖₊;
  let f_inv := fun (x : α) => ‖f x‖₊⁻¹;
