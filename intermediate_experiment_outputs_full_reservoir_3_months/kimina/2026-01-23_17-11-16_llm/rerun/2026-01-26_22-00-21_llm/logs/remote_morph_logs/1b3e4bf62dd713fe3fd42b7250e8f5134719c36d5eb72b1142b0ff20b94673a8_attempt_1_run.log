import Mathlib

noncomputable def ε₁ (x T : ℝ) : ℝ := 2 * (log x)^2 / T

noncomputable def riemannZeta.Sigma (T x a b : ℝ) : ℝ := 2 * (riemannZeta.zeroes_sum (Set.Ico a b) (Set.Ioo 0 T) (fun ρ ↦ x^(ρ.re - 1) / ρ.im))

