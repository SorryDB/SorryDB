  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain тЯиx, y, hxy, rfl, hx, hyтЯй := hNotMax
  let B (N) (hN : N тИИ D) : Set (PersistenceSubmodule M) := if N = x тКФ y then {x, y} else {N}
