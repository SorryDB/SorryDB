section Indecomposable
variable {D : DirectSumDecomposition M} in
/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `D` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D`. -/
@[nolint unusedArguments]
def refinement (B : тИА N тИИ D, Set (PersistenceSubmodule M))
    (hB : тИА N hN, N = sSup (B N hN)) (hB' : тИА N hN, sSupIndep (B N hN))
    (hB'' : тИА N hN, тКе тИЙ B N hN) : DirectSumDecomposition M where
  carrier := тЛГ N, тЛГ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    sorry
  sSup_eq_top' := by
    sorry
  not_bot_mem' := by simp [Set.mem_iUnion, hB'']

/-- The direct sum decomposition `refinement B hB hB' hB''` is a refinement of `D`. -/
lemma refinement_le (B : тИА N тИИ D, Set (PersistenceSubmodule M))
    (hB : тИА N hN, N = sSup (B N hN))
    (hB' : тИА N hN, sSupIndep (B N hN))
    (hB'' : тИА N hN, тКе тИЙ B N hN) :
    refinement B hB hB' hB'' тЙд D := sorry

/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : тИА N тИИ D, Set (PersistenceSubmodule M))
    (hB : тИА N hN, N = sSup (B N hN))
    (hB' : тИА N hN, sSupIndep (B N hN))
    (hB'' : тИА N hN, тКе тИЙ B N hN)
    (H : тИГ (N : PersistenceSubmodule M) (hN : N тИИ D), B N hN тЙа {N}) :
    refinement B hB hB' hB'' < D := sorry

/-- If `D` is a direct sum decomposition that is minimal with respect to refinements
then every submodule that appears in `D` is indecomposable. -/
lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N тИИ D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra h
  simp only [not_indecomposable] at h
  rcases h with тЯиx, y, hxy, hx, hy, hN_eqтЯй
  have hN_mem : N тИИ D := hN
  let E : DirectSumDecomposition M := {
    carrier := {x, y},
    sSupIndep' := by
      simp [Set.mem_insert_iff, Set.mem_singleton_iff]
      exact hxy,
    sSup_eq_top' := by
      simp [Set.mem_insert_iff, Set.mem_singleton_iff]
      rw [hN_eq]
      exact D.sSup_eq_top'
    not_bot_mem' := by
      simp [Set.mem_insert_iff, Set.mem_singleton_iff]
      rw [hN_eq]
      exact D.not_bot_mem'
  }
  have hE_le_D : E тЙд D := by
    apply D.le_of_isRefinement
    unfold IsRefinement
    intro N hN
    simp only [E.carrier, Set.mem_insert_iff, Set.mem_singleton_iff] at hN
    rcases hN with (rfl | rfl)
    ┬╖ -- Case A = x
      use N
      constructor
      ┬╖ -- Show x тИИ D
        simp only [Set.mem_insert_iff, Set.mem_singleton_iff]
        exact hN_mem
      ┬╖ -- Show x тЙд N
        rw [hN_eq]
        apply le_sSup
        simp only [Set.mem_insert_iff, Set.mem_singleton_iff]
        all_goals try tauto
    ┬╖ -- Case A = y
      use N
      constructor
      ┬╖ -- Show y тИИ D
        simp only [Set.mem_insert_iff, Set.mem_singleton_iff]
        exact hN_mem
      ┬╖ -- Show y тЙд N
        rw [hN_eq]
        apply le_sSup
        simp only [Set.mem_insert_iff, Set.mem_singleton_iff]
        all_goals try tauto
  have hE_ne_D : E тЙа D := by
    by_contra h_eq
    have hN_in_E : N тИИ E := by
      rw [h_eq]
      exact hN_mem
    simp only [E.carrier, Set.mem_insert_iff, Set.mem_singleton_iff] at hN_in_E
    cases hN_in_E with
    | inl hN_x =>
      have h_contra : y = тКе := by
        rw [hN_eq] at hN_x
        have : y тЙд x := by
