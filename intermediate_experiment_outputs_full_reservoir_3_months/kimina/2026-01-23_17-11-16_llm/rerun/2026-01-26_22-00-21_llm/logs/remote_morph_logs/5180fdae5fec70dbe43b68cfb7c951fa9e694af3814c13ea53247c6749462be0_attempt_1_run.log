import Mathlib

open Set

namespace DirectSumDecomposition

instance : SetLike (DirectSumDecomposition M) (PersistenceSubmodule M) where
  coe := carrier
  coe_injective' DтВБ DтВВ := by cases DтВБ; congr!

attribute [-instance] SetLike.instPartialOrder

protected lemma sSupIndep (D : DirectSumDecomposition M) : sSupIndep (SetLike.coe D) := D.sSupIndep'

lemma sSup_eq_top (D : DirectSumDecomposition M) : sSup (SetLike.coe D) = тКд := D.sSup_eq_top'
lemma not_bot_mem (D : DirectSumDecomposition M) : тКе тИЙ D := D.not_bot_mem'

lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : тиЖ p тИИ D, p x = тКд := sorry

lemma pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : тиЖ p тИИ D, p x = тКд := sorry

open scoped Classical in
lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I тЖж p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor
  ┬╖ sorry
  sorry
  --rw [тЖР iSup_apply, тЖР sSup_eq_iSup', I.sSup_eq_top]
  --rfl

variable {M : C тед ModuleCat K} in
/-- Let `DтВБ, DтВВ` be direct sum decomposition of `M` we say that `DтВБ` is a refinement of `DтВВ` if for
every submodule `N` that appears in `D`, there is a subset `B` of submodules that appear
in `DтВБ` such that `тИС T тИИ B, T = N`. -/
def IsRefinement (DтВБ DтВВ : DirectSumDecomposition M) : Prop :=
  тИА тжГNтжД, N тИИ DтВВ тЖТ тИГ B : Set (PersistenceSubmodule M), B тКЖ DтВБ тИз N = sSup B

variable {M : C тед ModuleCat K} in
/-- Suppose `I, J` are direct sum decompositions of `M ` and `J` is a refinement of `I`.
Then for any submodule `N` appearing in `J`, there is a submodule  `A` appearing in `I`
such that `N тЙд A`. -/
lemma RefinementMapSurj' (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : тИА N : J, тИГ A : I, N.val тЙд A.val := by
  by_contra! h_contra
  rcases h_contra with тЯиNтВА, h_not_leтЯй
  have h_ge : NтВА.val тКФ sSup I тЙд sSup J := by
    rw [тЖР sSup_pair]
    apply sSup_le_iff.mpr
    intro b h_mem
    rcases h_mem with тЯиh_nтЯй
    ┬╖ exact (le_sSup (h_n тЦ╕ NтВА.prop))
    ┬╖ rename b тИИ {sSup (SetLike.coe I)} => h_i
      have h' : sSup (SetLike.coe I) тЙд sSup J := by
        rw [I.sSup_eq_top, J.sSup_eq_top]
      simp only [Set.mem_singleton_iff] at h_i
      exact (h_i тЦ╕ h')
  let B : Set (PersistenceSubmodule M) := {C | тИГ A : I, C тЙд A.val тИз C тИИ J}
  have h_sub : B тКЖ J := by
    intro C h_C_mem
    simp [B] at h_C_mem
    exact h_C_mem.right
  have h_aux : sSup B = sSup I := by
    simp_rw [le_antisymm_iff, sSup_le_iff]
    constructor
    ┬╖ intro b h_mem
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B] at h_mem
      rcases h_mem with тЯиhтВБ, _тЯй
      rcases hтВБ with тЯиa, h_a, h_leтЯй
      exact le_sSup_of_le h_a h_le
    have h_le_subset : тИА A : I, тИГ C тКЖ B, A тЙд sSup C := by
      intro A
      choose f hf hf' using h
      refine тЯиf A.prop, ?_, by rw [тЖР hf' A.prop]тЯй
      intro ╬▒ h_╬▒
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B]
      refine тЯитЯиA, A.prop, ?_тЯй, hf A.prop h_╬▒тЯй
      rw [hf' A.prop]
      exact le_sSup h_╬▒
    intro A h_A_mem
    rcases h_le_subset тЯиA, h_A_memтЯй with тЯиC, h_CтЯй
    simp only at h_C
    exact le_trans h_C.right (sSup_le_sSup h_C.left)
  have h_aux' : NтВА.val тИЙ B := by
    intro h_contra
    simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, SetLike.coe_mem,
      and_true, B] at h_contra
    rcases h_contra with тЯиA, hтВБ, hтВВтЯй
    exact (h_not_le (тЯиA, hтВБтЯй) hтВВ)
  have h_disj : Disjoint NтВА.val (sSup B) := by
    exact (sSupIndep.disjoint_sSup J.sSupIndep' NтВА.prop h_sub h_aux')
  have h_not_bot : NтВА.val тЙа тКе := by
    intro h_contra
    exact J.not_bot_mem (h_contra тЦ╕ NтВА.prop)
  have h_gt : sSup I < NтВА.val тКФ sSup I := by
    rw [тЖР h_aux]
    -- No clue why I couldn't use this theorem from mathlib directly and had to copy paste it here
    -- instead assuming it has to do with needing to bump
    exact (right_lt_sup_of_left_ne_bot h_disj h_not_bot)
  have contra : (тКд : PersistenceSubmodule M) < тКд := by
    rw [I.sSup_eq_top, J.sSup_eq_top] at *
    apply lt_of_lt_of_le h_gt h_ge
  exact (lt_self_iff_false (тКд : PersistenceSubmodule M)).mp contra

/-- Suppose that `I, J` are direct sum decompositions of `M`, `N` is a submodule appearing in `J`
and `A, B` are submodules appearing in `I` such that `N тЙд A, B`. Then `A = B`. -/
lemma UniqueGE (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (N : J) (A : I) (B : I) : N.val тЙд A тИз N.val тЙд B тЖТ A = B := by
  by_contra h'
  push_neg at h'
  rcases h' with тЯиh_le, h_neqтЯй
  have h_neq' : A.val тЙа B.val := by
    simp [h_neq]
  have h_disj : Disjoint A.val B.val := by
    let s : Set (PersistenceSubmodule M) := {A.val, B.val}
    have h_sub : s тЙд I.carrier := by
      intro X hx
      rcases hx with тЯиh_memтЯй
      ┬╖ exact (h_mem тЦ╕ A.prop)
      subst X
      exact B.prop
    exact (sSupIndep_pair h_neq').mp (sSupIndep.mono I.sSupIndep' h_sub)
  have h_le' : N.val тЙд A.val тКУ B.val := le_inf h_le.1 h_le.2
  have h_eq_bot : N тЙд (тКе : PersistenceSubmodule M) := h_le'.trans <| disjoint_iff_inf_le.mp h_disj
  simp only [le_bot_iff] at h_eq_bot
  exact (J.not_bot_mem' (h_eq_bot тЦ╕ N.prop))

/-- Let `I, J` be direct sum decompositions of `M` with `J` a refinement of `I`.
Then `RefinementMap` is the function that sends a submodule `N` appearing in `J` to the unique submodule
in `I` that contains `N`. -/
noncomputable def RefinementMap (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : J тЖТ I :=
  open scoped Classical in
  if h' : I = J then by
    intro N
    use N
    exact (h' тЦ╕ N.prop)
  else by
    intro N
    choose A h using (RefinementMapSurj' I J h N)
    exact A

@[simp]
lemma RefinementMapId (I : DirectSumDecomposition M) (h : IsRefinement I I) (N : I) :
  (RefinementMap I I h) N = N := by
  simp [RefinementMap]

/-- `RefinmentMap N` sends `N` to something it is included in. -/
lemma RefinementMapLE (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : тИА N : J, N.val тЙд (RefinementMap I J h N).val := by
  classical
  obtain rfl | hIJ := eq_or_ne I J
  ┬╖ simp [RefinementMapId]
  ┬╖ intro N
    simpa [RefinementMap, hIJ] using Exists.choose_spec (RefinementMapSurj' I J h N)

/-- Two modules that both decompose the same element are sent to the same submodule by the
`RefinementMap`. -/
lemma RefinementMapSameImage (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
    (h : IsRefinement J I) (NтВБ NтВВ : J) (h_leтВБ : NтВВ.val тЙд RefinementMap I J h NтВБ) :
    RefinementMap I J h NтВВ = RefinementMap I J h NтВБ := by
  have h_leтВВ : NтВВ.val тЙд (RefinementMap I J h NтВВ) := RefinementMapLE I J h NтВВ
  exact (UniqueGE I J NтВВ (RefinementMap I J h NтВБ) (RefinementMap I J h NтВВ) (тЯиh_leтВБ, h_leтВВтЯй)).symm

/-- If `N тЙд A` for some `A : I`, then `RefinementMap N = A`. -/
lemma SendsToUniqueGE (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
    (h : IsRefinement J I) (N : J) (A : I) : N.val тЙд A тЖТ (RefinementMap I J h N) = A := by
  intro h_le
  let B : I := (RefinementMap I J h N)
  rw [UniqueGE I J N A B (тЯиh_le, RefinementMapLE I J h NтЯй)]

lemma RefinmentMapFunctorial (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
    (K : DirectSumDecomposition M) (hij : IsRefinement J I) (hjk : IsRefinement K J)
    (hik : IsRefinement K I) (N : K) :
    RefinementMap I K hik N = RefinementMap I J hij (RefinementMap J K hjk N) := by
  have h_le : N.val тЙд RefinementMap I J hij (RefinementMap J K hjk N) := by
    apply le_trans (RefinementMapLE J K hjk N)
    exact (RefinementMapLE I J hij _)
  exact SendsToUniqueGE I K hik N (RefinementMap I J hij (RefinementMap J K hjk N)) h_le

/-- The refinement relation defines a preorder on direct sum decompositions of `M` via `DтВБ тЙд DтВВ` if
and only if `DтВБ` is a refinement of `DтВВ` i.e. this relation is reflexive and transitive. -/
instance : Preorder (DirectSumDecomposition M) where
  le DтВБ DтВВ := IsRefinement DтВБ DтВВ
  --DтВБ тЙд DтВВ iff DтВБ refines DтВВ.
  le_refl D := by intro N _; use {N}; aesop
  le_trans IтВБ IтВВ IтВГ h12 h23 := by
    intro N h_mem
    rcases (h23 h_mem) with тЯиC, h_sub, h_eqтЯй
    choose f hf hf' using h12
    let A := тиЖ (c : C), (f (h_sub c.prop))
    use A
    constructor
    ┬╖ apply iSup_le_iff.mpr
      intro c
      exact hf (h_sub c.prop)
    ┬╖ have h_aux' : sSup A = sSup C := by
        simp_rw [le_antisymm_iff, sSup_le_iff]
        constructor
        ┬╖ intro a h_a
          have h_aux'' : тИГ (c : C), a тИИ (f (h_sub c.prop)) := by aesop
          rcases h_aux'' with тЯиc_a, h_caтЯй
          have h_le : a тЙд c_a := by rw [hf' (N := c_a) (h_sub c_a.2)]; apply le_sSup h_ca
          apply le_sSup_of_le c_a.prop h_le
        intro c h_mem_c
        let c' : C := тЯиc, h_mem_cтЯй
        have h_le_c : c тЙд sSup (f (h_sub c'.prop)) := by
          rw [тЖР hf' (h_sub c'.prop)]
        apply le_trans h_le_c
        apply sSup_le
        intro a h_mem_a
        have h_a_in_A : a тИИ A := by
          have h_subs : f (h_sub c'.prop) тЙд A := by
            apply le_iSup_of_le c'
            exact le_rfl
          exact h_subs h_mem_a
        exact le_sSup h_a_in_A
      rwa [h_aux']

/-- The refinement relation is antisymmetric. This (combined with the above)
means that it defines a partial order on direct sum decompositions. -/
instance DirectSumDecompLE : PartialOrder (DirectSumDecomposition M) where
  le_antisymm := by
    intro I J h_J_le_I h_I_le_J
    have h_final_left : тИА N тИИ J, N тИИ I := by
      intro N
      by_contra h_neg
      push_neg at h_neg
      rcases h_neg with тЯиh_N_in_J, h_N_not_in_IтЯй
      let N' : J := тЯиN, h_N_in_JтЯй
      have h_A : тИГ A : I, N тЙд A.val := by
        exact (RefinementMapSurj' I J h_I_le_J) N'
      rcases h_A with тЯиA, h_N_le_AтЯй
      choose f hf hf' using h_J_le_I
      let h_BтВБ := hf' N'.prop
      let h_BтВВ := hf N'.prop
      simp only at h_BтВБ
      have h_mem : A.val тИИ f N'.prop := by
        by_contra h_A_not_mem
        have h_aux : Disjoint A.val (sSup (f N'.prop)) := by
          exact (I.sSupIndep.disjoint_sSup A.prop h_BтВВ h_A_not_mem)
        have h_aux' : sSup (f N'.prop) тЙд A.val := h_BтВБ тЦ╕ h_N_le_A
        have h_last : sSup (f N'.prop) = (тКе : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [тЖР h_BтВБ] at h_last
        subst h_last
        exact (J.not_bot_mem h_N_in_J)
      have h_A_le_N : A.val тЙд N := by
        simpa [тЖР h_BтВБ] using le_sSup h_mem
      have h_A_eq_N : A.val = N := by
        exact (le_antisymm h_A_le_N h_N_le_A)
      have h_contra : N тИИ I := by
        exact h_A_eq_N тЦ╕ A.prop
      aesop
    have h_final_right : тИА N тИИ I, N тИИ J := by
      sorry
    aesop

section Indecomposable
variable {D : DirectSumDecomposition M}

/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `S` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D`. -/
@[nolint unusedArguments]
def refinement (B : тИА N тИИ D, Set (PersistenceSubmodule M))
    (hB : тИА N hN, N = sSup (B N hN)) (hB' : тИА N hN, sSupIndep (B N hN))
    (hB'' : тИА N hN, тКе тИЙ B N hN) : DirectSumDecomposition M where
  carrier := тЛГ N, тЛГ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    sorry
  sSup_eq_top' := by
    sorry
  not_bot_mem' := by simp [Set.mem_iUnion, hB'']

/-- The direct sum decomposition `refinement B hB hB' hB''` is a refinement of `D`. -/
lemma refinement_le (B : тИА N тИИ D, Set (PersistenceSubmodule M))
    (hB : тИА N hN, N = sSup (B N hN))
    (hB' : тИА N hN, sSupIndep (B N hN))
    (hB'' : тИА N hN, тКе тИЙ B N hN) :
    refinement B hB hB' hB'' тЙд D := sorry

