          · apply contDiffOn_id
      · apply ContDiffOn.mul
        · apply contDiffOn_exp
        · apply ContDiffOn.mul
          · apply contDiffOn_const
          · apply contDiffOn_id
    · -- Denominator is C∞ and non-zero
