    · -- Show that 1 is differentiable at z
      exact differentiableAt_const 1
    · -- Show that 1 + z.im² is differentiable at z and is non-zero
      apply DifferentiableAt.add
      · -- Show that 1 is differentiable at z
        exact differentiableAt_const 1
      · -- Show that z.im² is differentiable at z
        apply DifferentiableAt.pow
        · -- Show that z.im is differentiable at z
          exact differentiableAt_im
        · -- Show the exponent 2 is differentiable
