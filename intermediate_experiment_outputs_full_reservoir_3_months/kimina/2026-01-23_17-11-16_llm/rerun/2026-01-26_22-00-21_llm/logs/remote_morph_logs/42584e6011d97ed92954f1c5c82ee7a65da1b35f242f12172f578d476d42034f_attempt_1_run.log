import Mathlib

/-!
# Number Theory in Mathlib


In this talk we discuss the implementation of number theory concepts in Mathlib, focusing on
algebraic number theory.

We will cover the following topics:
1. Number fields, their rings of integers and the units group
2. Factorization of ideals, the class group
3. A bit of modular forms and elliptic curves
-/

/- Let's declare a number field `K` -/

variable (K : Type*) [Field K] [NumberField K]

#print NumberField

#synth (Algebra ℚ K)

section

/- Assume `CharZero K` if you want to work with a possible infinite extension of `ℚ`, and *not*
`Algebra ℚ K`.  -/

variable (L : Type*) [Field L] [Algebra ℚ L] [FiniteDimensional ℚ L]

example : NumberField L := by
  sorry -- This is annoying unfortunately (if you are interested we can discuss this later)

end

example (x y : K) : (x + y) ^ 2 = x ^ 2 + 2 * x * y + y ^ 2 := by
  ring

example (x : K) (hx : x ≠ 0) : x/x = 1 := by
  field_simp

example (x y z : K) (hz : z ≠ 0) : (x + y) * z⁻¹ * (z / (z⁻¹)^(-1 : ℤ)) = y/z + x/z := by
  field_simp
  ring

example (x y : K) (hy : y ≠ 0) : x / y * y = x := by
  exact div_mul_cancel₀ x hy

example (x y : K) (h : x ^ 3 + 3 * x ^ 2 * y + 4 * x * y ^ 2 + y ^ 3 ≠ x * y ^ 2) :
    (x ^ 2 - y ^ 2) / (x + y) = x - y := by
  grind

/- The ring of integers is denoted `𝓞 K` (you need `open NumberField`) -/

open NumberField

#check 𝓞 K

#synth (CommRing (𝓞 K))

/- It is defined as the type given by elements `x : K` such that `IsIntegral ℤ x`.

We also have a predicate `IsAlgebraic`, but most of the library uses `IsIntegral`.

Beware that `𝓞 K` is *not* a subset of `K`, but there is a *coercion*. -/

variable (x : 𝓞 K) (y : K)

#check (x + y)

example (a b : 𝓞 K) : (↑(a + b) : K) = (a : K) + (b : K) := by
  norm_cast

example (a : 𝓞 K) (ha : a ≠ 0) : (a : K) * (a : K)⁻¹ = 1 := by
  refine mul_inv_cancel₀ ?_ --found by `apply?`
  exact_mod_cast ha

/- The units of `𝓞 K` (and of any other multiplicative monoid) are denoted `(𝓞 K)ˣ`  -/

#check (𝓞 K)ˣ

#synth (Group (𝓞 K)ˣ)

/- There is also a *predicate* `IsUnit`, saying that `u : 𝓞 K` is a unit.  -/

variable (u : 𝓞 K) (v : (𝓞 K)ˣ) (hu : IsUnit u)

#check IsUnit u

#check hu.unit

#check v.isUnit

/- Again terms of type `(𝓞 K)ˣ` are *not* of type `𝓞 K`.
So there are now *various* coercions `(𝓞 K)ˣ → 𝓞 K → K`.

Can you prove the following without suffering too much?
 -/

example (u v : (𝓞 K)ˣ) : (u / v : 𝓞 K) + 1 = (u : K) / ((v : 𝓞 K) : K) + u / u:= by
  have h1 : (u / v : 𝓞 K) = (u : 𝓞 K) / (v : 𝓞 K) := by
    simp
  have h2 : (↑(u / v) : K) = (↑u : K) / (↑v : K) := by
    rw [h1]
    all_goals simp
  have h4 : (↑u : K) ≠ 0 := by
    have h5 : u ≠ 0 := by
      simpa using u.property
    have h5' : (↑u : K) ≠ 0 := by
      intro h
      have : u = 0 := by
        exact_mod_cast (show (↑u : K) = (0 : K) by simpa using h)
      contradiction
    exact h5'
  have h6 : (↑u : K) / (↑u : K) = 1 := by
    field_simp [h4]
  rw [h2, h6]
  all_goals simp
