def carlesonOperator (f : ℝ≥0 → ℝ≥0∞) (t : ℝ≥0) : ℝ≥0∞ := ⨆ n : ℕ, (integral (fun x : ℝ≥0 ↦ f (t + x) * (x / (x + 1))) x).toReal

