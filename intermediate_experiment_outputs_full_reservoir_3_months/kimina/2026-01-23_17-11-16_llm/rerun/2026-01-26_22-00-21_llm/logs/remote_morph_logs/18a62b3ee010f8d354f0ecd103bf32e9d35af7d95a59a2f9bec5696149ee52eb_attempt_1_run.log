import Mathlib

open Filter Set

/- The `HasLorentzType` predicate means that an operator `T` maps functions from `L^p` to `L^q` in a way that satisfies certain conditions. -/
def HasLorentzType {T : (α → ℝ≥0) → (α' → ε')} {p q : ℝ≥0∞} {μ : Measure α} {ν : Measure α'} {c : ℝ≥0}
    (h : ∀ (f : α → ℝ≥0), (f ∈ L^p μ) → (T f ∈ L^q ν) ∧ ‖T f‖_q ≤ c * ‖f‖_p) : Prop := by
  simpa using h

/- The `HasRestrictedWeakType` predicate is a stronger condition that requires the operator `T` to behave nicely with respect to weak convergence and scaling, often used in the context of operators like the Carleson operator. -/
def HasRestrictedWeakType {T : (α → ℝ≥0) → (α' → ε')} {p p' : ℝ≥0∞} {μ : Measure α} {ν : Measure α'} {c : ℝ≥0}
    (h : ∀ {f : α → ℝ≥0}, (f ∈ L^p μ) → ∀ {g : α → ℝ≥0}, (g ∈ L^p μ) →
      (T (f + g) ∈ L^p' ν) ∧ ‖T (f + g)‖_p' ≤ ‖T f‖_p' + ‖T g‖_p'
      ∧ ∀ {a : ℝ≥0}, (a ≠ ⊤) → (T (a • f) ∈ L^p' ν) ∧ ‖T (a • f)‖_p' ≤ ‖a‖_e * ‖T f‖_p') : Prop := by
  simpa using h

/- The `WeaklyContinuous` predicate means that the operator `T` maps weakly convergent sequences to weakly convergent sequences. -/
def WeaklyContinuous {T : (α → ℝ≥0) → (α' → ε')} {p : ℝ≥0∞} {μ : Measure α} {ν : Measure α'}
    (h : ∀ {f : α → ℝ≥0} {fs : ℕ → α → ℝ≥0}, (LocallyIntegrable f μ) → (∀ (n : ℕ), AEStronglyMeasurable (fs n) μ) →
      (∀ (a : α), Monotone fun n => ‖fs n a‖) → (∀ (a : α), Filter.Tendsto (fun n => fs n a) Filter.atTop (nhds (f a))) →
        ∀ (G : Set α'), eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n => eLpNorm (T (fs n)) 1 (ν.restrict G)) Filter.atTop) : Prop := by
  simpa using h

