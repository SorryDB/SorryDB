/- Definition of the real Carleson operator -/
def carlesonOperatorReal (f : ℝ≥0 → ℝ) (t : ℝ≥0) : ℝ := ⨆ n : ℕ, (integral (fun x : ℝ≥0 ↦ f (t + x) * (x / (x + 1))) x).toReal

/- Definition of the real Carleson operator with explicit bounds -/
def carlesonOperatorExplicitBounds (f : ℝ≥0 → ℝ) (t : ℝ≥0) (C : ℝ) : ℝ := C * ∫ (fun x : ℝ≥0 ↦ f (t + x) * (x / (x + 1))) x

/- Theorem relating the real and complex Carleson operators -/
