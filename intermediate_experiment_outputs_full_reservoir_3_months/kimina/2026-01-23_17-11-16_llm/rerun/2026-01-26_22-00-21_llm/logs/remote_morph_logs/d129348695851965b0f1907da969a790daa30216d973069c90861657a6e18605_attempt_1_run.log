    : PartInterpolant Y := sorry

/-! ## Local Rule Application and Interpolants

The first part of the proof establishes basic facts about local rule applications and their relationship with interpolants. These facts are essential for the later main result.
-/

lemma localRuleApp_interpolant {X Y} (r : PdlRule X Y) (Xfree : X.isFree) (hC : X ∈ C) (Y_in : Y ∈ endNodesOf (r.lt))
    : ∃ θ, (θ : PartInterpolant Y) ∧ (θ : PartInterpolant Y) := by
  sorry

lemma localRuleApp_isFree {X Y} (r : PdlRule X Y) (Xfree : X.isFree) (hC : X ∈ C) (Y_in : Y ∈ endNodesOf (r.lt))
    : Y.isFree := by
  sorry

lemma localRuleApp_interpolant' {X Y} (r : PdlRule X Y) (Xfree : X.isFree) (hC : X ∈ C) (Y_in : Y ∈ endNodesOf (r.lt))
    : ∃ θ, (θ : PartInterpolant Y) := by
  rcases localRuleApp_interpolant r Xfree hC Y_in with ⟨θ, _, _⟩
  exact ⟨θ, sorry⟩

