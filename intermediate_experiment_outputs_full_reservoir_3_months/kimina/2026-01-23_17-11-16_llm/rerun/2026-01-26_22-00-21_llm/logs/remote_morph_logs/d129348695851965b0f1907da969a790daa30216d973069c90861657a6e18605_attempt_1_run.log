import Mathlib

open List

/-! Definition 7.1: Local Tableau Rule -/
noncomputable def localRuleApp (l : LocalRule) (X : Sequent) :
    PartInterpolant X → PartInterpolant (l X) := by
  intro θ
  use (θ.1)
  use (θ.2.1)
  use (θ.2.2)
  apply l

/-! Definition 7.2: Local Tableau -/
noncomputable def LocalTableau (X : Sequent) :=
  match X with
  | (l : List Formula) => List.toFinset l
  | (r : PdlRule) => sorry -- Placeholder for PdlRule definition
  | (s : Sequent) => sorry -- Placeholder for Sequent definition
  | _ => sorry -- Placeholder for other cases

/-! Definition 7.3: End nodes of a local tableau -/
noncomputable def endNodesOf (lt : LocalTableau X) : List (PathIn lt) :=
  sorry

/-! Definition 7.4: Local rule application does not increase jvoc -/
lemma localRuleApp_does_not_increase_jvoc {l : LocalRule} {X Y : Sequent}
    (h : X ∈ endNodesOf l) {θ : PartInterpolant X} : Y ∈ endNodesOf l := by
  sorry

/-! Definition 7.5: Part interpolant step for local tableaux -/
def localInterpolantStep (l : LocalRule) (X : Sequent) (θ : PartInterpolant X) :
    PartInterpolant (l X) := by
  apply localRuleApp l θ

/-! Definition 7.6: Simpler base case for local tableaux -/
def sim (X : Sequent) : PartInterpolant X := by
  use X
  use [X]
  use true
  simp

/-! Definition 7.7: Local Tableau Interpolant -/
def LocalTableau.interpolant (ltX : LocalTableau X)
