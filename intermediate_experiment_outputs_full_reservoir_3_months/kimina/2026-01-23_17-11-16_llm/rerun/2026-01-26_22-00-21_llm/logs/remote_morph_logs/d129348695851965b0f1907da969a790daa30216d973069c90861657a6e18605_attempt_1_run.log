    (next : (Y : _) → Y ∈ endNodesOf lt → Tableau ((L, R, some (Sum.inl nlf)) :: Hist) Y)
    (next' : (Yf : _) → Yf ∈ endNodesOf lt.flip → Tableau (List.map Sequent.flip ((L, R, some (Sum.inl nlf)) :: Hist)) Yf)
    (Y : Sequent)
