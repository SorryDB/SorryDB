import Mathlib
import Lean4

/-! A local rule application preserves the jvoc of a formula. -/
lemma localRuleApp_does_not_increase_jvoc {r : PdlRule X Y} {X Y : Sequent}
    (hr : r = (loadX, loadY))
    (hX : ¬X.isLoaded) (hY : ¬Y.isLoaded)
    (hXvoc : X.voc = ∅) (hYvoc : Y.voc = ∅) :
    Y.voc = X.voc := by
  simp only [hr, loadX, loadY, PdlRule.isLocal, true_and]
  simp only [Sequent.voc, List.map_append, List.map_cons, List.map_nil, List.toFinset_append,
    List.toFinset_cons, List.toFinset_nil, insert_empty_eq, Finset.union_singleton, Finset.sup_insert,
    id_eq, Finset.sup_eq_union', Finset.mem_inter, Finset.mem_union, Finset.mem_sup, List.mem_toFinset,
    List.mem_map, exists_exists_and_eq_and]
  ext n; simp; tauto

