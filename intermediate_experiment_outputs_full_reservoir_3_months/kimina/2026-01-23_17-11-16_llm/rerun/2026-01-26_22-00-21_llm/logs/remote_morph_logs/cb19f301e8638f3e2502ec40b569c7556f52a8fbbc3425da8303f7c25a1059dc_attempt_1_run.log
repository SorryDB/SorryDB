import Mathlib

open Real Complex

noncomputable def eLorentzNorm' {α : Type u_1} [MeasurableSpace α] {p : ℝ≥0∞} {μ : Measure α} {f : α → ℝ≥0}
    (a : ℝ≥0) : ℝ≥0 := if a = 0 then 0 else (μ {x | f x = a}) ^ (1 / p.toReal)

noncomputable def eLorentzNorm {α : Type u_1} [MeasurableSpace α] {p : ℝ≥0∞} {μ : Measure α} {f : α → ℝ}
    (a : ℝ) : ℝ≥0 := if a = 0 then 0 else (μ {x | f x = a}) ^ (1 / p.toReal)

noncomputable def eLpNorm {α : Type u_1} [MeasurableSpace α] [TopologicalSpace E] [ENormedSpace E] {p : ℝ≥0∞} {μ : Measure α} {T : (α → E) → (α' → E)}
    (f : α → E) (a : Set E) (c : ℝ≥0) : ℝ≥0 := c * (μ {x | f x ∈ a}) ^ (1 / p.toReal)

theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

