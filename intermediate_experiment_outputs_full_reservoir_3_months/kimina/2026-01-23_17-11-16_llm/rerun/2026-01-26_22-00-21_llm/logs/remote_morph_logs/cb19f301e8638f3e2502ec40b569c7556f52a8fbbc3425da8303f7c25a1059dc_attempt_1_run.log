import Mathlib

open Real

/- The constant `RCLike.I` is `1` if `RCLike.I ≠ 0` and `0` if `RCLike.I = 0`.
   This is a trivial lemma that might be useful in some contexts. -/
theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

/- A bounded linear operator `T` between two measure spaces `(α, μ)` and `(α', ν)` is said to be of Lorentz type `p, q` if for any measurable set `G ⊆ α'` and any function `f : α → K` that is locally integrable with respect to `μ` and satisfies `‖f‖_p,1,μ ≤ C`, the inequality `‖Tf‖_q,1,ν ≤ C'` holds, where `C'` is a constant depending only on `p, q, C, μ, ν, T`.
   More precisely, `T` is of Lorentz type `p, q` if there exists a constant `C` such that for all measurable sets `G ⊆ α'` with `ν G < ∞`, and all functions `f : α → K` that are locally integrable with respect to `μ` and satisfy `‖f‖_p,1,μ ≤ 1`, we have `‖Tf‖_q,1,ν ≤ C`.
   This definition is equivalent to the existence of a constant `C` such that for all measurable sets `G ⊆ α'` with `ν G < ∞`, and all functions `f : α → K` that are locally integrable with respect to `μ` and satisfy `‖f‖_p,1,μ ≤ 1`, we have `‖Tf‖_q,1,ν ≤ C`. -/
structure HasLorentzType (T : (α → K) → (α' → E)) (p q : ℝ≥0∞) (μ : Measure α) (ν : Measure α') (C : ℝ≥0)
    : Prop :=
