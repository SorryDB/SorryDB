/-! The Dirac (outer) measure at `π ∈ ℝ`. -/
def μD : OuterMeasure ℝ where
  measureOf := by
    intro S
    sorry
  empty := by
    sorry
  mono {S T} hST := by
    sorry
  iUnion_nat := by
    sorry

def μL : Measure ℝ := by volume_tac

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

