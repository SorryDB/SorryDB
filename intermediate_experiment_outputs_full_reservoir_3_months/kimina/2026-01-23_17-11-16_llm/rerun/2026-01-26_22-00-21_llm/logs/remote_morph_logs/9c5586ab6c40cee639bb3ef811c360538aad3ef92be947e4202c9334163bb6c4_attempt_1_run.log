    · -- If i < j, then the left side is ω (⟨(i, j), le_of_lt h_lt⟩)
      -- The right side is ω (⟨(j, i), le_of_lt h_gt⟩) where h_gt is j < i
      have h1 : wignerMatrixEntryFunction ω (i, j) = ω (⟨(i, j), le_of_lt h_lt⟩) := by
        simp [wignerMatrixEntryFunction, h_eq, h_lt]
      have h2 : wignerMatrixEntryFunction ω (j, i) = ω (⟨(i, j), le_of_lt (show i < j by omega)⟩) := by
        simp [wignerMatrixEntryFunction, show i ≠ j by omega, show ¬(i < j) by omega, show j < i by omega]
      rw [h1, h2]
      all_goals simp
    · -- j < i
