      Measurable (fun ω ↦ (wignerMatrixMap n ω) i j):= by
  apply measurable_entry
  apply wignerMatrixMapMeasurable

lemma wignerMatrixSymmetric (n : ℕ) ( i j : Fin n) {ω : WignerSpace n} :
