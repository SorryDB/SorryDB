lemma has_law_off_diag (i j : Fin n) (hij : i ≠ j) : HasLaw (fun ω ↦ X ω i j) μ P

lemma symmetric_entries (i j : Fin n) (ω : Ω): X ω i j = X ω j i

lemma ident_distrib_diag (i j k l: Fin n) (hij : i = j) (hkl : k = l) :
