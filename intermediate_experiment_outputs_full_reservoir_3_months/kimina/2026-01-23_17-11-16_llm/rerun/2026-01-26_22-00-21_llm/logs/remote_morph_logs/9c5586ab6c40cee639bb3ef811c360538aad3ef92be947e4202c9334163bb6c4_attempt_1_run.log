to the corresponding function (Fin n) → (Fin n) → ℝ that respects the symmetric structure of Wigner
matrices.-/
@[grind, simp]
def wignerMatrixEntryFunction (ω : WignerSpace n) : (Fin n) → (Fin n) → ℝ :=
  fun i j =>
    if h_eq : i = j then
      ω (⟨(i, i), le_refl i⟩)
    else if h_lt : i < j then
      ω (⟨(i, j), le_of_lt h_lt⟩)
    else
      have h_gt : j < i := by
         apply lt_of_le_of_ne
         apply le_of_not_gt h_lt
         grind
      ω (⟨(j, i), le_of_lt h_gt⟩)

/-- The function that takes an element of WignerSpace (a map Index n → ℝ)
to the corresponding function (Fin n) → (Fin n) → ℝ that respects the symmetric structure of Wigner
matrices.-/
@[grind, simp]
def wignerMatrixEntryFunctionSymm (ω : WignerSpace n) : (Fin n) → (Fin n) → ℝ :=
  fun i j =>
    if h_eq : i = j then
      ω (⟨(i, i), le_refl i⟩)
    else if h_lt : i < j then
      ω (⟨(j, i), le_of_lt h_lt⟩)
    else
      have h_gt : j < i := by
         apply lt_of_le_of_ne
         apply le_of_not_gt h_lt
         grind
      ω (⟨(i, j), le_of_lt h_gt⟩)

