  -- Let's handle the cases.
  -- We use `by_cases` to handle the different cases.
  by_cases h_eq1 : i = j
  · -- Case 1: i = j
    simp [h_eq1]
  · -- Now we know i ≠ j
    by_cases h_lt1 : i < j
    · -- Case 2: i < j
      simp [h_eq1, h_lt1]
      -- Now we need to show that the `else` branch of the second `if` is the same as the `if` branch of the first `if`.
