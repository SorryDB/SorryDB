/-- The sample space for an `n x n` Wigner matrix. It is the product of ℝ over Index n. -/
abbrev WignerSpace (n : ℕ) := Index n → ℝ

instance (n : ℕ) : MeasurableSpace (WignerSpace n) := by
  infer_instance

/-- The measure distribution for a Wigner matrix. It assigns the measure `ν` to diagonal
entries and `μ` to off-diagonal entries. -/
def wignerMeasureDist (n : ℕ) : Index n → Measure ℝ :=
  fun (p : Index n) =>
    if p.val.1 = p.val.2 then ν
    else μ

/-- The probability measure on the sample space `WignerSpace n`, which makes the
coordinate projections independent random variables with distributions given by
`wignerMeasureDist`. -/
noncomputable
def WignerMeasure (n : ℕ) : Measure (WignerSpace n) :=
  Measure.pi (wignerMeasureDist μ ν n)

instance instIsProbabilityMeasure (n : ℕ) : IsProbabilityMeasure (WignerMeasure μ ν n) := by
  rw[WignerMeasure]
  --apply MeasureTheory.Measure.pi.instIsProbabilityMeasure
  sorry

/-- The function that takes an element of WignerSpace (a map Index n → ℝ)
to the corresponding function (Fin n) → (Fin n) → ℝ that respects the symmetric structure of Wigner
matrices.-/
@[grind, simp]
def wignerMatrixEntryFunction (ω : WignerSpace n) : (Fin n) → (Fin n) → ℝ :=
  fun i j =>
    if h_eq : i = j then
      ω (⟨(i, i), le_refl i⟩)
    else if h_lt : i < j then
      ω (⟨(i, j), le_of_lt h_lt⟩)
    else
      have h_gt : j < i := by
         apply lt_of_le_of_ne
         apply le_of_not_gt h_lt
         grind
      ω (⟨(j, i), le_of_lt h_gt⟩)

lemma wignerMatrixEntryFunctionSymmetric (ω : WignerSpace n) {i : Fin n} {j : Fin n} :
  wignerMatrixEntryFunction ω i j = wignerMatrixEntryFunction ω j i := by
  rw[wignerMatrixEntryFunction, wignerMatrixEntryFunction]
```

Now we need to prove the equality. Let's analyze the structure:
- `wignerMatrixEntryFunction ω i j` is `if i = j then ... else if i < j then ... else ...` (where `else` is `j < i`)
- `wignerMatrixEntryFunction ω j i` is `if j = i then ... else if j < i then ... else ...` (where `else` is `i < j`)

To prove the equality, we need to show that the `if` conditions are equivalent, and the expressions under the `if` are equal.

Let's complete the proof:
```tactics
by_cases h_eq : i = j
· -- If i = j, then j = i, so both expressions take the first branch
  simp [h_eq]
```

Now handle the case where `i ≠ j`:
```tactics
by_cases h_lt : i < j
· -- If i < j, then j > i, so the second expression's `if` condition `j = i` is false, and `j < i` is false, so it takes the else branch. The first expression takes the else branch.
  simp [h_lt, h_eq]
```

Now handle the case where `i ≥ j`:
We know `i ≠ j` from `h_eq`, so `i > j`.
```tactics
by_cases h_eq' : j = i
· -- This case is impossible because of h_eq
  exfalso
  tauto
```

Now we know `i ≠ j` and `¬(i < j)`, so `j ≤ i`.
Since `i ≠ j`, we have `j < i`.
The first expression's `if` condition `i = j` is false. `i < j` is false (as we are in the `else` part of `by_cases h_lt : i < j`), so it takes the `else` branch.
The second expression's `if` condition `j = i` is false. `j < i` is true (as we are in the `else` part of `by_cases h_lt : i < j`), so it takes the `else` branch.

```tactics
have h_gt : j < i := by
  by_contra h
  push_neg at h
  have h_le : j ≥ i := by omega
  have h_eq' : i = j := by omega
  tauto
```

Now we can complete the proof:
```tactics
simp [h_eq', h_lt, h_gt]
```

This completes the proof of the symmetry of the matrix entries.

