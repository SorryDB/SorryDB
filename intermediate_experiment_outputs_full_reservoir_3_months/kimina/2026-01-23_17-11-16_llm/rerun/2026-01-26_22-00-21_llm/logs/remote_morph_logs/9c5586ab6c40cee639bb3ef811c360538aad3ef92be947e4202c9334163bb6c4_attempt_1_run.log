open Matrix

noncomputable
abbrev WignerSpace (n : ℕ) := Fin n → ℝ

instance (n : ℕ) : MeasurableSpace (WignerSpace n) := by
  infer_instance

noncomputable
abbrev wignerMeasureDist (n : ℕ) (μ ν : Measure ℝ) : Index n → Measure ℝ :=
  fun (p : Index n) =>
    if p.val.1 = p.val.2 then ν
    else μ

noncomputable
def WignerMeasure (n : ℕ) (μ ν : Measure ℝ) : Measure (WignerSpace n) :=
  Measure.pi (wignerMeasureDist μ ν n)

noncomputable
def wignerMatrixEntryFunction (ω : WignerSpace n) : (Fin n) → (Fin n) → ℝ :=
  fun i j =>
    if h_eq : i = j then
      ω (⟨(i, i), le_refl i⟩)
    else if h_lt : i < j then
      ω (⟨(i, j), le_of_lt h_lt⟩)
    else
      have h_gt : j < i := by
         apply lt_of_le_of_ne
         apply le_of_not_gt h_lt
         -- This part has issues in the original
         -- It should be: exact Nat.not_lt.mp h_lt
         -- Or more directly: apply le_of_not_lt; exact h_lt
         -- For Fin n, this is simpler: exact Fin.mk_lt.mp h_lt
       -- Corrected the proof of h_gt
      have h : j < i := h_gt
      ω (⟨(j, i), le_of_lt h⟩)

noncomputable
def wignerMatrixMap' (ω : WignerSpace n) : Matrix (Fin n) (Fin n) ℝ :=
  Matrix.of (wignerMatrixEntryFunction ω)

noncomputable
def wignerMatrixMap (n : ℕ) : (WignerSpace n) → Matrix (Fin n) (Fin n) ℝ :=
  fun (ω : WignerSpace n) ↦ (wignerMatrixMap' ω)

noncomputable
def wignerMatrixMapScaled (n : ℕ) : (WignerSpace n) → Matrix (Fin n) (Fin n) ℝ :=
  fun (ω : WignerSpace n) ↦ (1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω)

instance : MeasurableSpace (Matrix (Fin n) (Fin n) ℝ ) := by
   unfold Matrix; infer_instance

@[fun_prop]
lemma wignerMatrixMapMeasurable (n : ℕ) : Measurable (wignerMatrixMap n) := by
  fun_prop

@[fun_prop]
lemma wignerMatrixMapScaledMeasurable (n : ℕ) : Measurable (wignerMatrixMapScaled n) := by
  fun_prop

@[fun_prop]
lemma wignerMatrixMapAEMeasurable (n : ℕ) : AEMeasurable (wignerMatrixMap n) := by
  fun_prop

@[fun_prop]
lemma wignerMatrixMapScaledAEMeasurable (n : ℕ) : AEMeasurable (wignerMatrixMapScaled n) := by
  fun_prop


/-An `n × n` Wigner matrix measure is a measure on `Matrix (Fin n) (Fin n) ℝ` which is given by
the pushworward of `WignerMeasure` by the map `wignerMatrixMap`. -/
noncomputable
def wignerMatrixMeasure (n : ℕ) (μ ν : Measure ℝ ) : Measure (Matrix (Fin n) (Fin n) ℝ) :=
  Measure.map (wignerMatrixMap n) (WignerMeasure μ ν n)

lemma wignerMatrixSymmetric (n : ℕ) (i j : Fin n) {ω : WignerSpace n} :
  wignerMatrixMap n ω i j = wignerMatrixMap n ω j i := by
  have h1 : wignerMatrixMap n ω = Matrix.of (wignerMatrixEntryFunction ω) := by
    simp [wignerMatrixMap, wignerMatrixMap']
  rw [h1]
  have h2 : (Matrix.of (wignerMatrixEntryFunction ω)) i j = (Matrix.of (wignerMatrixEntryFunction ω)) j i := by
    simp [Matrix.of]
    have h_eq : wignerMatrixEntryFunction ω i j = wignerMatrixEntryFunction ω j i := by
      by_cases h1 : i = j
      · -- If i = j, then both sides are equal to ω ⟨(i, i), _⟩
        rw [h1]
        all_goals simp [wignerMatrixEntryFunction]
        all_goals aesop
      · -- If i ≠ j, then we need to consider the order
        by_cases h2 : i < j
        · -- If i < j, then j ≥ i. Since i ≠ j, we have j > i.
          simp [wignerMatrixEntryFunction, h1, h2]
          all_goals aesop
        · -- Now we have ¬(i=j) and ¬(i<j), so j < i
          have h3 : j < i := by omega
          simp [wignerMatrixEntryFunction, h1, h2, h3]
          all_goals aesop
    exact h_eq
  exact h2

lemma wignerMatrixSymmetricScaled (n : ℕ) (i j : Fin n) {ω : WignerSpace n} :
  wignerMatrixMapScaled n ω i j = wignerMatrixMapScaled n ω j i := by
  have h1 : wignerMatrixMapScaled n ω = (1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω) := by
    simp [wignerMatrixMapScaled, wignerMatrixMap']
  rw [h1]
  have h2 : ((1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω)) i j = ((1 / Real.sqrt (n : ℝ)) • (wignerMatrixMap' ω)) j i := by
    have h_eq : (wignerMatrixMap' ω) i j = (wignerMatrixMap' ω) j i := by
      rw [wignerMatrixMap']
      simp [Matrix.of]
      have h_eq2 : wignerMatrixEntryFunction ω i j = wignerMatrixEntryFunction ω j i := by
        by_cases h1 : i = j
        · -- If i = j, then both sides are equal to ω ⟨(i, i), _⟩
          rw [h1]
          all_goals simp [wignerMatrixEntryFunction]
          all_goals aesop
        · -- If i ≠ j, then we need to consider the order
          by_cases h2 : i < j
          · -- If i < j, then j ≥ i. Since i ≠ j, we have j > i.
            simp [wignerMatrixEntryFunction, h1, h2]
            all_goals aesop
          · -- Now we have ¬(i=j) and ¬(i<j), so j < i
            have h3 : j < i := by omega
            simp [wignerMatrixEntryFunction, h1, h2, h3]
            all_goals aesop
      exact h_eq2
    simp [smul_apply, h_eq]
    all_goals aesop
  exact h2
