/-! ### Properties of inner product spaces -/

namespace AdjointSpace

variable {ΏζΧε E F : Type*} [RCLike ΏζΧε]

variable [NormedAddCommGroup E] [AdjointSpace ΏζΧε E]
variable [NormedAddCommGroup F] [AdjointSpace έΕζ F]

local notation "έθς" x ", " y "έθτ" => @inner ΏζΧε E _ x y
local notation "έΑΨ" x "έΑΨέΓΓ┬▓" => @inner ΏζΧε E _ x x

local notation "IK" => @RCLike.I ΏζΧε _

local postfix:90 "έΑι" => starRingEnd _

open RCLike ComplexConjugate InnerProductSpace

section BasicProperties

@[simp mid+1]
theorem inner_conj_symm (x y : E) : έθςy, xέθτέΑι = έθςx, yέθτ := by rw[conj_symm]

theorem real_inner_comm (x y : F) : έθςy, xέθτ_έΕζ = έθςx, yέθτ_έΕζ := by
  rw[έΗΡ conj_symm]; simp only [conj_trivial]

theorem inner_eq_zero_symm {x y : E} : έθςx, yέθτ = 0 έΗΦ έθςy, xέθτ = 0 := by
  rw [έΗΡ inner_conj_symm]
  exact star_eq_zero

@[simp mid+1]
theorem inner_self_im (x : E) : RCLike.im έθςx, xέθτ = 0 := by
  rw [έΗΡ @ofReal_inj ΏζΧε, im_eq_conj_sub]; simp

theorem inner_add_left (x y z : E) : έθςx + y, zέθτ = έθςx, zέθτ + έθςy, zέθτ := by rw[add_left]

theorem inner_add_right (x y z : E) : έθςx, y + zέθτ = έθςx, yέθτ + έθςx, zέθτ := by
  rw [έΗΡ inner_conj_symm, inner_add_left, RingHom.map_add]
