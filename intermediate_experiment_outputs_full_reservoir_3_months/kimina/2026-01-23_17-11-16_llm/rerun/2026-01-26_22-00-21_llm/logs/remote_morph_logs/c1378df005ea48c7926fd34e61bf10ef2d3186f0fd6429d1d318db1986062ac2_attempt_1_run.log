variable
  {X} [NormedAddCommGroup X] [AdjointSpace ΏζΧε X]
  {Y} [NormedAddCommGroup Y] [AdjointSpace ΏζΧε Y]
  {╬╣ : Type*} [Fintype ╬╣]
  {E : ╬╣ έΗΤ Type*} [έΙΑ i, NormedAddCommGroup (E i)] [έΙΑ i, AdjointSpace ΏζΧε (E i)]

instance : AdjointSpace ΏζΧε ΏζΧε where
  inner_top_equiv_norm := by
    apply Exists.intro 1
    apply Exists.intro 1
    simp [norm_sq_eq_def]
  conj_symm := by simp[mul_comm]
  add_left := by simp[add_mul]
  smul_left := by simp[mul_assoc]

instance : Inner ΏζΧε Unit where
  inner _ _ := 0

instance : AdjointSpace ΏζΧε Unit where
  inner_top_equiv_norm := by
    apply Exists.intro 1
    apply Exists.intro 1
    simp[Inner.inner]
  conj_symm := by simp[Inner.inner]
  add_left := by simp[Inner.inner]
