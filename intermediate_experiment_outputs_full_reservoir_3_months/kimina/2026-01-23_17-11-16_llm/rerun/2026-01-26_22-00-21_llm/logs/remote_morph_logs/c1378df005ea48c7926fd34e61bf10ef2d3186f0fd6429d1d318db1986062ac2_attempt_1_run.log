instance : AdjointSpace ΏζΧε ((i : ╬╣) έΗΤ E i) where
  inner := fun x y => έΙΣ i, έθςx i, y iέθτ_ΏζΧε
  inner_top_equiv_norm := by
    use 1, 1
    constructor
    ┬╖ norm_num
    constructor
    ┬╖ norm_num
    intro x
    constructor
    ┬╖ -- Show that 1 έΑλ έΑΨxέΑΨ ^ 2 έΚν re έθςx, xέθτ_έΕζ
