  smul_left := by simp[Inner.inner]

instance : AdjointSpace ΏζΧε (X├ΩY) where
  inner := fun (x,y) (x',y') => έθςx,x'έθτ_ΏζΧε + έθςy,y'έθτ_ΏζΧε
  inner_top_equiv_norm := by
    have έθρcx,dx,hcx,hdx,_hxέθσ := inner_top_equiv_norm (ΏζΧε:=ΏζΧε) (E:=X)
    have έθρcy,dy,hcy,hdy,_hyέθσ := inner_top_equiv_norm (ΏζΧε:=ΏζΧε) (E:=X)
    apply Exists.intro (cx*cx + cy*cy) -- todo: fix this constant
    apply Exists.intro (dx*dx + dy*dy) -- todo: fix this constant
    constructor
    ┬╖ positivity
    constructor
    ┬╖ positivity
    ┬╖ intro (x,y)
      sorry
  conj_symm := by simp
  add_left := by simp[inner_add_left]; intros; ac_rfl
  smul_left := by simp[inner_smul_left,mul_add]

open Classical in
instance : AdjointSpace ΏζΧε ((i : ╬╣) έΗΤ E i) where
  inner := fun x y => έΙΣ i, έθςx i, y iέθτ_ΏζΧε
  inner_top_equiv_norm := by
    have h1 : έΙΑ i : ╬╣, έΙΔ ci di : έΕζ, ci > 0 έΙπ di > 0 έΙπ
        έΙΑ z : E i, ci έΑλ έΑΨzέΑΨ ^ 2 έΚν re (inner z z) έΙπ re (inner z z) έΚν di έΑλ έΑΨzέΑΨ ^ 2 := by
      intro i
      apply inner_top_equiv_norm
    let c := (έΙΣ i : ╬╣, (choose (h1 i).1).1)
    let d := (έΙΣ i : ╬╣, (choose (h1 i).1).2)
    use c
    use d
    constructor
    ┬╖ -- Show c > 0
      sorry
    constructor
    ┬╖ -- Show d > 0
      sorry
    ┬╖ -- Show έΙΑ x : (i : ╬╣) έΗΤ E i, c έΑλ έΑΨxέΑΨ ^ 2 έΚν re έθςx, xέθτ_ΏζΧε έΙπ re έθςx, xέθτ_ΏζΧε έΚν d έΑλ έΑΨxέΑΨ ^ 2
      intro x
      sorry
  conj_symm := by simp
  add_left := by simp[inner_add_left]; intros; ac_rfl
  smul_left := by simp[inner_smul_left,mul_add]
```

We need to prove the existence of `c` and `d` such that `c > 0`, `d > 0`, and for all `x : (i : ╬╣) έΗΤ E i`, the following holds:
- `c έΑλ έΑΨxέΑΨ ^ 2 έΚν re έθςx, xέθτ_ΏζΧε`
- `re έθςx, xέθτ_έΕζ έΚν d έΑλ έΑΨxέΑΨ ^ 2`

Let's analyze what we know:
- `E : ╬╣ έΗΤ Type*` where each `E i` is a `NormedAddCommGroup` and an `AdjointSpace ΏζΧε (E i)`
- For each `i : ╬╣`, we have `inner_top_equiv_norm` which gives us `c_i, d_i` such that `c_i > 0`, `d_i > 0`, and for all `y : E i`:
  - `c_i έΑλ έΑΨyέΑΨ ^ 2 έΚν re έθςy, yέθτ_έΕζ`
  - `re έθςy, yέθτ_έΕζ έΚν d_i έΑλ έΑΨyέΑΨ ^ 2`

To prove the goal for `x : (i : ╬╣) έΗΤ E i`, we need to relate `έΑΨxέΑΨ` (the norm of the function `x`) to `re έθςx, xέθτ_έΕζ`.

The norm `έΑΨxέΑΨ` for `x : (i : ╬╣) έΗΤ E i` is defined as `έΙγ(έΙΣ i, έΑΨx iέΑΨ ^ 2)`.
The inner product `έθςx, xέθτ_έΕζ` for `x : (i : ╬╣) έΗΤ E i` is defined as `έΙΣ i, έθςx i, x iέθτ_έΕζ`.

We need to show that `έΙΣ i, έΑΨx iέΑΨ ^ 2` is bounded by `c έΑλ (έΙΣ i, έΑΨx iέΑΨ ^ 2)` and `d έΑλ (έΙΣ i, έΑΨx iέΑΨ ^ 2)` where `c` and `d` are positive constants.

Let's think about how to construct `c` and `d`:

For each `i`, we have `c_i, d_i` such that:
- `c_i έΑλ έΑΨx iέΑΨ ^ 2 έΚν re έθςx i, x iέθτ_έΕζ`
- `re έθςx i, x iέθτ_έΕζ έΚν d_i έΑλ έΑΨx iέΑΨ ^ 2`

Summing these inequalities over all `i`:
- `έΙΣ i, c_i έΑλ έΑΨx iέΑΨ ^ 2 έΚν έΙΣ i, re έθςx i, x iέθτ_έΕζ`
- `έΙΣ i, re έθςx i, x iέθτ_έΕζ έΚν έΙΣ i, d_i έΑλ έΑΨx iέΑΨ ^ 2`

The left side is `έΙΣ i, c_i έΑλ έΑΨx iέΑΨ ^ 2 = (έΙΣ i, c_i) έΑλ (έΙΣ i, έΑΨx iέΑΨ ^ 2)` if `c_i` are constants w.r.t. `i`. But `c_i` depends on `i`. So this is not directly a constant multiple of `έΙΣ i, έΑΨx iέΑΨ ^ 2`.

Similarly, the right side is `έΙΣ i, d_i έΑλ έΑΨx iέΑΨ ^ 2`.

To make this work, we need `c` and `d` such that:
- `c έΑλ (έΙΣ i, έΑΨx iέΑΨ ^ 2) έΚν έΙΣ i, re έθςx i, x iέθτ_έΕζ`
- `έΙΣ i, re έθςx i, x iέθτ_έΕζ έΚν d έΑλ (έΙΣ i, έΑΨx iέΑΨ ^ 2)`

Let's consider the case where we can choose `c` and `d` to be the maximum values of `c_i` and `d_i` over all `i`. Let `c_max = max_i c_i` and `d_max = max_i d_i`. Then `c_max > 0` and `d_max > 0`.

- `c_max έΑλ (έΙΣ i, έΑΨx iέΑΨ ^ 2) έΚξ έΙΣ i, c_i έΑλ έΑΨx iέΑΨ ^ 2 έΚν έΙΣ i, re έθςx i, x iέθτ_έΕζ`
- `έΙΣ i, re έθςx i, x iέθτ_έΕζ έΚν έΙΣ i, d_i έΑλ έΑΨx iέΑΨ ^ 2 έΚν d_max έΑλ (έΙΣ i, έΑΨx iέΑΨ ^ 2)`

This would give us the desired bounds with `c = c_max` and `d = d_max`.

Now, let's formalize this in Lean:

```tactics
import Problems.NavierStokes.Imports

open ComplexConjugate RCLike
/--
This is almost `InnerProductSpace` but we do not require that norm originates from the inner product.

The reason for this class it to be able to have inner product on spaces line `έΕζ├ΩέΕζ` and `╬╣ έΗΤ έΕζ`
as they are by default equiped by max norm which is not compatible with inner product. -/
class AdjointSpace (ΏζΧε : Type*) (E : Type*) [RCLike ΏζΧε] [NormedAddCommGroup E] extends
  NormedSpace ΏζΧε E, Inner ΏζΧε E where
  /-- Norm induced by inner is topologically equivalent to the given norm -/
  inner_top_equiv_norm : έΙΔ c d : έΕζ,
    c > 0 έΙπ d > 0 έΙπ
    έΙΑ x : E, (c έΑλ έΑΨxέΑΨ^2 έΚν re (inner x x)) έΙπ (re (inner x x) έΚν d έΑλ έΑΨxέΑΨ^2)
  /-- The inner product is *hermitian*, taking the `conj` swaps the arguments. -/
  conj_symm : έΙΑ x y, conj (inner y x) = inner x y
  /-- The inner product is additive in the first coordinate. -/
  add_left : έΙΑ x y z, inner (x + y) z = inner x z + inner y z
  /-- The inner product is conjugate linear in the first coordinate. -/
  smul_left : έΙΑ x y r, inner (r έΑλ x) y = conj r * inner x y

attribute [instance low] AdjointSpace.toNormedSpace AdjointSpace.toInner

/-! ### Properties of inner product spaces -/

namespace AdjointSpace

variable {ΏζΧε E F : Type*} [RCLike ΏζΧε]

variable [NormedAddCommGroup E] [AdjointSpace ΏζΧε E]
variable [NormedAddCommGroup F] [AdjointSpace έΕζ F]

local notation "έθς" x ", " y "έθτ" => @inner ΏζΧε E _ x y
local notation "έΑΨ" x "έΑΨέΓΓ┬▓" => @inner ΏζΧε E _ x x

local notation "IK" => @RCLike.I ΏζΧε _

local postfix:90 "έΑι" => starRingEnd _

export InnerProductSpace (norm_sq_eq_inner)

open RCLike ComplexConjugate InnerProductSpace

section BasicProperties

@[simp mid+1]
theorem inner_conj_symm (x y : E) : έθςy, xέθτέΑι = έθςx, yέθτ := by rw[conj_symm]

theorem real_inner_comm (x y : F) : έθςy, xέθτ_έΕζ = έθςx, yέθτ_έΕζ := by
  rw[έΗΡ conj_symm]; simp only [conj_trivial]

theorem inner_eq_zero_symm {x y : E} : έθςx, yέθτ = 0 έΗΦ έθςy, xέθτ = 0 := by
  rw [έΗΡ inner_conj_symm]
  exact star_eq_zero

@[simp mid+1]
theorem inner_self_im (x : E) : RCLike.im έθςx, xέθτ = 0 := by
  rw [έΗΡ @ofReal_inj ΏζΧε, im_eq_conj_sub]; simp

theorem inner_add_left (x y z : E) : έθςx + y, zέθτ = έθςx, zέθτ + έθςy, zέθτ := by rw[add_left]

theorem inner_add_right (x y z : E) : έθςx, y + zέθτ = έθςx, yέθτ + έθςx, zέθτ := by
  rw [έΗΡ inner_conj_symm, inner_add_left, RingHom.map_add]
  simp only [inner_conj_symm]

theorem inner_re_symm (x y : E) : re έθςx, yέθτ = re έθςy, xέθτ := by rw [έΗΡ inner_conj_symm, conj_re]

theorem inner_im_symm (x y : E) : im έθςx, yέθτ = -im έθςy, xέθτ := by rw [έΗΡ inner_conj_symm, conj_im]

theorem inner_smul_left (x y : E) (r : ΏζΧε) : έθςr έΑλ x, yέθτ = rέΑι * έθςx, yέθτ := by rw [smul_left]

theorem real_inner_smul_left (x y : F) (r : έΕζ) : έθςr έΑλ x, yέθτ_έΕζ = r * έθςx, yέθτ_έΕζ :=
  inner_smul_left _ _ _

theorem inner_smul_real_left (x y : E) (r : έΕζ) : έθς(r : ΏζΧε) έΑλ x, yέθτ = r έΑλ έθςx, yέθτ := by
  rw [inner_smul_left, conj_ofReal, Algebra.smul_def]

theorem inner_smul_right (x y : E) (r : ΏζΧε) : έθςx, r έΑλ yέθτ = r * έθςx, yέθτ := by
  rw [έΗΡ inner_conj_symm, inner_smul_left, RingHom.map_mul, conj_conj, inner_conj_symm]

theorem real_inner_smul_right (x y : F) (r : έΕζ) : έθςx, r έΑλ yέθτ_έΕζ = r * έθςx, yέθτ_έΕζ :=
  inner_smul_right _ _ _

theorem inner_smul_real_right (x y : E) (r : έΕζ) : έθςx, (r : ΏζΧε) έΑλ yέθτ = r έΑλ έθςx, yέθτ := by
  rw [inner_smul_right, Algebra.smul_def]

/-- The inner product as a sesquilinear form.

Note that in the case `ΏζΧε = έΕζ` this is a bilinear form. -/
@[simps!]
def sesqFormOfInner : E έΗΤέΓΩ[ΏζΧε] E έΗΤέΓΩέΜΗ[ΏζΧε] ΏζΧε :=
  LinearMap.mkέΓΓ'έΓδέΓΩ (RingHom.id ΏζΧε) (starRingEnd _) (fun x y => έθςy, xέθτ)
    (fun _x _y _z => inner_add_right _ _ _) (fun _r _x _y => inner_smul_right _ _ _)
    (fun _x _y _z => inner_add_left _ _ _) fun _r _x _y => inner_smul_left _ _ _


/-- An inner product with a sum on the left. -/
theorem sum_inner {╬╣ : Type*} (s : Finset ╬╣) (f : ╬╣ έΗΤ E) (x : E) :
    έθςέΙΣ i έΙΙ s, f i, xέθτ = έΙΣ i έΙΙ s, έθςf i, xέθτ :=
  map_sum (sesqFormOfInner (ΏζΧε := ΏζΧε) (E := E) x) _ _

/-- An inner product with a sum on the right. -/
theorem inner_sum {╬╣ : Type*} (s : Finset ╬╣) (f : ╬╣ έΗΤ E) (x : E) :
    έθςx, έΙΣ i έΙΙ s, f iέθτ = έΙΣ i έΙΙ s, έθςx, f iέθτ :=
  map_sum (LinearMap.flip sesqFormOfInner x) _ _

@[simp mid+1]
theorem inner_zero_left (x : E) : έθς0, xέθτ = 0 := by
  rw [έΗΡ zero_smul ΏζΧε (0 : E), inner_smul_left, RingHom.map_zero, zero_mul]

theorem inner_re_zero_left (x : E) : re έθς0, xέθτ = 0 := by
