lemma g_decomposition (g : α → 𝕂) (g₁ g₂ g₃ g₄ : α → NNReal) : g x = (1 : 𝕂) • (algebraMap ℝ 𝕂 ∘ NNReal.toReal ∘ g₁) x + (-1 : 𝕂) • (algebraMap ℝ 𝕂 ∘ NNReal.toReal ∘ g₂) x + (RCLike.I : 𝕂) • (algebraMap ℝ 𝕂 ∘ NNReal.toReal ∘ g₃) x + (-RCLike.I : 𝕂) • (algebraMap ℝ 𝕂 ∘ NNReal.toReal ∘ g₄) x := by
  simp only [Function.comp_apply, Function.comp_apply, Function.comp_apply, Function.comp_apply]
  simp only [algebraMap, Pi.smul_apply, smul_eq_mul]
  simp only [NNReal.coe_toReal]
