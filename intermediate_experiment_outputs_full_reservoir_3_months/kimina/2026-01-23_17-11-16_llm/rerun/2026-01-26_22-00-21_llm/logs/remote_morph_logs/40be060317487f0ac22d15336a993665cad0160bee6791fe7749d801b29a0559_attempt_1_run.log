noncomputable def eLorentzNorm' {α : Type*} {β : Type*} [TopologicalSpace α] [ENormedSpace β]
    {p : ℝ≥0∞} {f : α → β} : ℝ≥0∞ := if p = ∞ then ‖f‖∞ else (∫⁻ (t : α), ‖f t‖^p⁻¹.toReal).pow p⁻¹.toReal

noncomputable def eLorentzNorm {α : Type*} {β : Type*} [TopologicalSpace α] [ENormedSpace β]
    {p : ℝ≥0∞} {f : α → β} : ℝ≥0∞ := if p = ∞ then ‖f‖∞ else (∫⁻ (t : α), ‖f t‖^p⁻¹.toReal).pow p⁻¹.toReal

noncomputable def eLpNorm {α : Type*} {β : Type*} [TopologicalSpace α] [ENormedSpace β]
    {p : ℝ≥0∞} {f : α → β} {s : Set α} : ℝ≥0∞ := if p = ∞ then ‖f‖∞ on s else (∫⁻ (t : s), ‖f t‖^p⁻¹.toReal).pow p⁻¹.toReal

noncomputable def eLpNorm' {α : Type*} {β : Type*} [TopologicalSpace α] [ENormedSpace β]
    {p : ℝ≥0∞} {f : α → β} {s : Set α} : ℝ≥0∞ := if p = ∞ then ‖f‖∞ on s else (∫⁻ (t : s), ‖f t‖^p⁻¹.toReal).pow p⁻¹.toReal

