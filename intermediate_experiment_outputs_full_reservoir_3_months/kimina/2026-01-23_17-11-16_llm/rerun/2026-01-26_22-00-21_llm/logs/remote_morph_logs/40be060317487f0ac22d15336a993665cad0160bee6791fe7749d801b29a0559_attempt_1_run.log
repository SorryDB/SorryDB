import Mathlib

/- Decompose a complex number `z` into four terms, each involving real and imaginary parts of `z` multiplied by coefficients from the set `{1, -1, I, -I}`. -/
lemma complex_decomposition {z : ℂ} : z = (z.re ≥ 0 ∧ z.im ≥ 0) ∨ (z.re ≥ 0 ∧ z.im < 0) ∨ (z.re < 0 ∧ z.im ≥ 0) ∨ (z.re < 0 ∧ z.im < 0) := by
  by_cases h1 : z.re ≥ 0
  · by_cases h2 : z.im ≥ 0
    · exact Or.inl ⟨h1, h2⟩
    · exact Or.inr (Or.inl ⟨h1, by linarith⟩)
  · by_cases h2 : z.im ≥ 0
    · exact Or.inr (Or.inr (Or.inl ⟨by linarith, h2⟩))
    · exact Or.inr (Or.inr (Or.inr ⟨by linarith, by linarith⟩))

