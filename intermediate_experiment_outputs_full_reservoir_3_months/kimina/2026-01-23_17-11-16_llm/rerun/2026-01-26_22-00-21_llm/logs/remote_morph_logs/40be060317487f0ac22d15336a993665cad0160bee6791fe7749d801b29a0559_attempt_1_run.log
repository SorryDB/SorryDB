        all_goals linarith
      · -- If RCLike.re (f x) < 0, then max (RCLike.re (f x)) 0 = 0 and max (-RCLike.re (f x)) 0 = -RCLike.re (f x).
        rw [max_eq_right (by linarith), max_eq_left (by linarith)]
        all_goals linarith
    linarith
