theorem complex_identity (z : ℂ) : z = (max (re z) 0) - (max (-re z) 0) + I * (max (im z) 0) - I * (max (-im z) 0) := by
  by_cases h1 : re z ≥ 0
  · -- Case re z ≥ 0
    by_cases h2 : im z ≥ 0
    · -- Case re z ≥ 0 and im z ≥ 0
      simp [max_eq_left_of_lt, max_eq_right_of_lt, h1, h2, Complex.ext_iff]
      <;> try { linarith }
    · -- Case re z ≥ 0 and im z < 0
      have h2' : im z < 0 := by linarith
      simp [max_eq_left_of_lt, max_eq_right_of_lt, h1, h2', Complex.ext_iff]
      <;> try { linarith }
  · -- Case re z < 0
    have h1' : re z < 0 := by linarith
    by_cases h2 : im z ≥ 0
    · -- Case re z < 0 and im z ≥ 0
