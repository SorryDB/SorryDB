let T' := Field51_as_Nat c.T
X' % p = (2 * X * Y) % p тИз
Y' % p = (Y^2 + X^2) % p тИз
(Z' + X^2) % p = Y^2 % p тИз
(T' + Z') % p = (2 * Z^2) % p
:= by
  unfold double
  progress*
  ┬╖ -- Goal 1: Precondition for `X`
