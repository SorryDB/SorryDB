@[progress]
theorem double_spec (q : ProjectivePoint)
  (h_qX_bounds : тИА i, i < 5 тЖТ (q.X[i]!).val тЙд 2 ^ 52)
  (h_qY_bounds : тИА i, i < 5 тЖТ (q.Y[i]!).val тЙд 2 ^ 52)
