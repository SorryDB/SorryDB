/-- Helper for Lemma 9, stronger version using a specific `k` and not `Kv`. -/
lemma knowledge_of_secrets_is_preserved' {a b : @Agent n} (k : Bool)
    (hKv : S⌈σ⌉ ⊢ K a ((b,k) @ b))
    (hSub : σ ⊑ τ)
    : S⌈τ⌉ ⊢ K a ((b,k) @ b) := by
  rcases σ with ⟨σ,o⟩
  rcases τ with ⟨τ,o'⟩
  rcases hSub with ⟨ρ, def_τ⟩ -- the `ρ` is called `τ \ σ` in the paper.
