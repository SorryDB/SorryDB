        | ⌜d e^c⌝ => ⌜d e⌝
      have h' : roleOfIn a CnoErr = Other := by unfold CnoErr; cases C <;> simp_all
      apply know_after T ⟨CnoErr :: τ, ?_⟩ (by simp [OSequence.length]; exact same_len)
      · unfold equiv; simp [h, h', equ]
