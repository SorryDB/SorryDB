            · -- ???
              -- Why must `a` already have one of the values b or not-b after σ?
              sorry
            · cases S b <;>  simp_all
            · use S, ⟨σ,⁻o⟩
              simp
              expose_names -- pfoei
              use ⌜a c⌝
              simp
            · intro not_in_callee not_a_knows T τ same_len equ C role_C same_contrib
              cases h_b : S b
              all_goals
                simp_all
              -- ???
              -- How do we know that `S b = T b` here?
              sorry
          all_goals
            sorry
        · sorry
    case Callee =>
      -- second of three outer cases, very similar to `Caller`
      simp [ra] at *
      by_cases h : eval S ⟨σ,⁻o⟩ (Kv a b)
      · -- "Either already ...""
        specialize IH (⁻o) h
        unfold resultSet
