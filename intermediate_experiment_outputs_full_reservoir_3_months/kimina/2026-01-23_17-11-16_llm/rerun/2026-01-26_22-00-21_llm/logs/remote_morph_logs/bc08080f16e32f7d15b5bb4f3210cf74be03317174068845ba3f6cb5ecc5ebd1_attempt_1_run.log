  have h5 : ↑(coerceLang α (cfg_CNF.1).Z (cfg_CNF.1).generatedLanguage) = ↑language := by
    rw [generate_equivalent_CNF_is_eq _ _ _ h4]
    all_goals try tauto
  use (cfg_CNF.1).V.card
  intro z hz
