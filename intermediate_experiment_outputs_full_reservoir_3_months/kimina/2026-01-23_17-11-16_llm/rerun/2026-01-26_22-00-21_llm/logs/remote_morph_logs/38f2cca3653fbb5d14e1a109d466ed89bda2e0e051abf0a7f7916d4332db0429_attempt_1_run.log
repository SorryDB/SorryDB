import Mathlib

/-- A derivation in a context-free grammar. -/
structure ContextFreeDerivation α nt G u v :=
  { step : G.ContextFreeDerivationStep u
    derivation : ContextFreeDerivation α nt G u' v
    sound : step.result = u'
    exhaustiveCondition : ContextFreeDerivation.exhaustiveCondition α nt G u v }

/-- The derivation step in a context-free derivation. -/
structure ContextFreeDerivationStep α nt G u :=
  { prod : G.productions.choose (u.length + 1)
    sound : (u ≠ ∅ → (∀ t ∈ prod.lhs.context, t ∈ G.Z) ∧
      (∀ t ∈ prod.rhs.context, t ∈ G.V ⊕ G.Z) ∧
      (∀ t ∈ prod.lhs.context, t ∈ (G.V ⊕ G.Z)) ∧
      (∀ t ∈ prod.rhs.context, t ∈ (G.V ⊕ G.Z)) ∧
      (∀ t ∈ prod.rhs.context, t ∈ G.Z ∨ t ∈ G.V) ∧
      (∀ t ∈ prod.rhs.context, t ∈ G.V ∨ t ∈ G.Z) ∧
      (∀ t ∈ prod.rhs.context, t ∈ G.V) ∨ (∀ t ∈ prod.rhs.context, t ∈ G.Z)) }

/-- The exhaustive condition for a context-free derivation. This condition is true if
   the derivation is exhaustive, i.e., if all possible derivations from the start word
   have been explored. -/
def ContextFreeDerivation.exhaustiveCondition {α : Sort u} {nt : Sort v} {G : ContextFreeGrammar α nt} {u v : Word (G.V ⊕ G.Z)} :
    (∀ s ∈ u, ∃ t ∈ v, s = t) ∧ (∀ s ∈ v, ∃ t ∈ u, s = t) ∧ (∀ s ∈ u, ∃ t ∈ u, s = t) ∧
    (∀ s ∈ v, ∃ t ∈ v, s = t) ∧ (∀ s ∈ u, ∃ t ∈ v, s = t) ∧ (∀ s ∈ v, ∃ t ∈ u, s = t)

/-- A context-free derivation is sound if its result matches the expected result. -/
def ContextFreeDerivation.sound {α : Sort u} {nt : Sort v} {G : ContextFreeGrammar α nt} {u v : Word (G.V ⊕ G.Z)} :
    ∀ s ∈ u, ∃ t ∈ v, s = t → ∃ t ∈ v, s = t ∧ (∀ t ∈ v, t ∈ u → t = s)

/-- A context-free derivation is exhaustive if all possible derivations from the start
   word have been explored. -/
def ContextFreeDerivation.exhaustive {α : Sort u} {nt : Sort v} {G : ContextFreeGrammar α nt} {u v : Word (G.V ⊕ G.Z)} :
    (∀ s ∈ u, ∃ t ∈ v, s = t) ∧ (∀ s ∈ v, ∃ t ∈ u, s = t) ∧ (∀ s ∈ u, ∃ t ∈ u, s = t) ∧
    (∀ s ∈ v, ∃ t ∈ v, s = t) ∧ (∀ s ∈ u, ∃ t ∈ v, s = t) ∧ (∀ s ∈ v, ∃ t ∈ u, s = t)

