                    simp [afuncDef]
                    by_cases index₁ = head₂.2
                    case pos h_pos_head₂ =>
                      simp [h_pos_head₂]
                      tauto
                    case neg h_neg_head₂ =>
                      simp [h_neg_head₂]
                      tauto
                  case neg h_neg₁ =>
