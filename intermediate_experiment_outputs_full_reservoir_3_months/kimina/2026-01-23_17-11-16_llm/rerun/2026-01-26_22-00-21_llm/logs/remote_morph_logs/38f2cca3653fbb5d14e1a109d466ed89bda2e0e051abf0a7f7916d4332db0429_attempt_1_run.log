import Mathlib

/- A derivation tree for a context-free derivation step.
  It contains the derivation tree for the left side of the rule and the derivation tree for the right side of the rule.
  The root of the tree is the derivation tree for the left side of the rule. -/
noncomputable def DerivationTree (G : ContextFreeGrammar α nt)
  (u : Word (G.V ⊕ G.Z)) :
  G.DerivationTree u :=
  let u' := u
  let tree : G.DerivationTree u' := {
    root : G.DerivationTree u'.val,
    -- This is where the derivation tree for the right side of the rule would go
    -- For now, it's an empty list
    rightDerivations : List (G.DerivationTree (u'.val))
  }
  tree

