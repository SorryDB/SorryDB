import Mathlib

/-- A derivation tree for a context-free derivation.
  The tree structure is such that the root represents the initial
  non-terminal, and the leaves represent the final sequence of
  variables. Each internal node corresponds to a step in the
  derivation.
  This structure is defined in terms of the derivation itself. -/
structure DerivationTree (G : ContextFreeGrammar α nt) : Type where
  root : G.NonTerminal
  children : List (G.NonTerminal × DerivationTree G)

/-- A context-free derivation. This represents a sequence of steps
  starting from an initial non-terminal and deriving a final
  sequence of variables. -/
structure ContextFreeDerivation (G : ContextFreeGrammar α nt) (u : Word (G.V ⊕ G.Z)) (v : Word (G.V ⊕ G.Z)) :
  G.NonTerminal → Prop :=
  @ContextFreeDerivation u v

/-- A context-free derivation step. This represents a single operation
  in the derivation process, such as substituting a non-terminal
  with its right-hand side according to a production rule. -/
structure ContextFreeDerivationStep (G : ContextFreeGrammar α nt) (u : Word (G.V ⊕ G.Z)) (v : Word (G.V ⊕ G.Z)) :
  G.NonTerminal → Prop :=
  @ContextFreeDerivationStep u v

/-- The exhaustive condition for a context-free derivation. This
  condition ensures that the derivation process does not lead to
  non-termination or infinite loops. -/
def exhaustiveCondition (cfd : ContextFreeDerivation G u v) : Prop := by
  match cfd with
  | .same h_same =>
    intro u' step derivation sound
    rw [imp_iff_not_or]
    apply Or.inl
    tauto
  | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound =>
    intro u' step derivation sound h_constructor
    rw [exhaustiveCondition]
    rw [h_constructor, exhaustiveCondition] at h_exhaustive
    exact h_exhaustive

