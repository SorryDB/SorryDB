import Mathlib
open Lean
import Mathlib.Data.Nat

/-- A derivation step within a context-free derivation.
  The structure of the derivation step is given by the context-free
  derivation rule `X → Y` where `X` is a non-terminal symbol and `Y` is
  a sequence of terminal and non-terminal symbols. The derivation step
  transforms the current word `u` into a new word `u'` by replacing the
  left-hand side `X` of the rule with the right-hand side `Y`.

  The derivation step is represented as a pair `(dstep, derivation)`, where:
  - `dstep` is a term of type `ContextFreeDerivationStep α nt G u u'`
  - `derivation` is a term of type `ContextFreeDerivation α nt G u' v`
  - `sound` is a proof that `dstep.result = u'`
  This structure is used recursively to build the full derivation.
  The derivation step is defined by the pair `(dstep, derivation)` and the proof `sound`.
  The derivation step is defined by the pair `(dstep, derivation)` and the proof `sound`.
  The derivation step is defined by the pair `(dstep, derivation)` and the proof `sound`.

  This is a helper structure to define derivations in a recursive manner. -/
abbrev ContextFreeDerivationStep := Nat.succ
abbrev ContextFreeDerivation := Nat.succ
abbrev ContextFreeDerivationSound := Nat.succ

/-- A derivation step within a context-free derivation.
  The structure of the derivation step is given by the context-free
  derivation rule `X → Y` where `X` is a non-terminal symbol and `Y` is
  a sequence of terminal and non-terminal symbols. The derivation step
  transforms the current word `u` into a new word `u'` by replacing the
  left-hand side `X` of the rule with the right-hand side `Y`.

  The derivation step is represented as a pair `(dstep, derivation)`, where:
  - `dstep` is a term of type `ContextFreeDerivationStep α nt G u u'`
  - `derivation` is a term of type `ContextFreeDerivation α nt G u' v`
  - `sound` is a proof that `dstep.result = u'`
  This structure is used recursively to build the full derivation.
  The derivation step is defined by the pair `(dstep, derivation)` and the proof `sound`.

