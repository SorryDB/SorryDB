lemma Locally.rightContinuous
    (hX : Locally (fun X ↦ ∀ (ω : Ω), Function.RightContinuous fun x => X x ω) 𝓕 X P) :
    ∀ᵐ (ω : Ω) ∂P, Function.RightContinuous fun x => X x ω := by
  intro ω h
  rcases hX with ⟨S, hS1, hP1, hS2⟩
  have h1 : ω ∈ S := by
    by_contra h2
    have h3 : P {ω} = 0 := by
