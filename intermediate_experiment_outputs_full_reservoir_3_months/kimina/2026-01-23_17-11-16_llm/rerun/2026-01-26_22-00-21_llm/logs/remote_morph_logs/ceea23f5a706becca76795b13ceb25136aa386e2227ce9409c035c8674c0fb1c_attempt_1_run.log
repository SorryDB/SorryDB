    [NormedAddCommGroup E] [NormedSpace ℝ E] [FiniteDimensional ℝ E] :
    (instIsManifoldModelSpace (I := 𝓘(ℝ,E))).toDiffeology = euclideanDiffeology := by
  ext n p; exact contMDiff_iff_contDiff

