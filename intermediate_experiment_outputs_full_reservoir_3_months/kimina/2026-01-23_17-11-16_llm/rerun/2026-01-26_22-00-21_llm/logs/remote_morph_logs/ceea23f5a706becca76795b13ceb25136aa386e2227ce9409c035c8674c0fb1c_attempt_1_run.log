  -- To prove the forward direction, we need to show that if f is Dsmooth on s, then f is ContMDiffOn I I' ∞ f s
  -- Assume hf : DSmooth (s.restrict f)
  -- We need to show ContMDiffOn I I' ∞ f s
  -- Let x ∈ s and let h be a chart around x
  -- We need to show that f ∘ h is ContMDiff on s ∩ h⁻¹(V) for some open set V
  -- Since s is open, s ∩ h⁻¹(V) is open in h⁻¹(V)
  -- By definition of Dsmooth, f ∘ h is Dsmooth on s ∩ h⁻¹(V)
  -- Since Dsmooth implies ContMDiff, we get the desired result
  have h1 : (s.restrict f).isDiffeological := by
    simpa using hf.isDiffeological
  have h2 : ContMDiffOn I I' (↑⊤) f s := by
    apply isDiffeological.isContMDiffOn h1
  simpa using h2
