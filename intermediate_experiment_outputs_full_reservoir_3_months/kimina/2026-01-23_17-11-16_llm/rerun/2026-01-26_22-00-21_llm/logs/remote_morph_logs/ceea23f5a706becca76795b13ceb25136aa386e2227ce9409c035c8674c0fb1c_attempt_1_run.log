    let _ := m.toDiffeology; let _ := m'.toDiffeology; DSmooth (s.restrict f) := by
  let _ := m.toDiffeology; let _ := m'.toDiffeology
  refine fun n p hp ↦ ?_
  rw [restrict_eq,Function.comp_assoc]
  exact hf.comp_contMDiff hp fun x ↦ (p x).2

