noncomputable def prodLocalComponents (φ : V ≃ₗ[ℚ] V) : (V ⊗[ℚ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
