    omega
  have h3 : ∃ m, 4 < m ∧ ∃ S : List (Call m), allExpert (after S) ∧ S.length < 2*m - 4 := by
    refine' ⟨n, by omega, σ, h_experts, h⟩
  rcases h3 with ⟨m, hm1, S, hS1, hS2⟩
