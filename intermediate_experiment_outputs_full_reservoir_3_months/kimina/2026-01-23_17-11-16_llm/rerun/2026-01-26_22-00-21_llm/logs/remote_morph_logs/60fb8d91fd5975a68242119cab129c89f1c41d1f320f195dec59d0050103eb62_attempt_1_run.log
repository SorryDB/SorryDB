    have h2 : initPart = S.filter (fun c => isInitialCall S c) := rfl
    have h3 : finalPart = S.filter (fun c => isFinalCall S c) := rfl
    rw [h2, h3]
    -- The following is a placeholder for the actual proof of same length
    -- A full proof would involve showing the sets of calls are the same due to noHo
    sorry

