      | none => MordellWeilGroup.mk_point E (xâ‚پ) (-(yâ‚پ + E.val.aâ‚پ*xâ‚پ + E.val.aâ‚ƒ)) sorry
      | some s =>  -- Changed خ» to s (for slope)
        let W := E.val
        let xâ‚ƒ := s^2 + W.aâ‚پ*s - W.aâ‚‚ - xâ‚پ - xâ‚‚
        let yâ‚ƒ := s*(xâ‚پ - xâ‚ƒ) - yâ‚پ - W.aâ‚پ*xâ‚ƒ - W.aâ‚ƒ
        MordellWeilGroup.mk_point E xâ‚ƒ yâ‚ƒ sorry

/-- Negation of a point on the elliptic curve -/
def MordellWeilGroup.neg (E : MordellWeilGroup K) (P : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point with
  | none => P  -- -âˆ‍ = âˆ‍
  | some (x, y) =>
