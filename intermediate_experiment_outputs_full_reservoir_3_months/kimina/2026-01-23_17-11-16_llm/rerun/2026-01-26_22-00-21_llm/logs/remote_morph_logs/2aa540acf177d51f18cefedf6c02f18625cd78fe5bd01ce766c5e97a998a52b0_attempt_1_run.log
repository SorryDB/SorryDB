        let yâ‚ƒ := s*(xâ‚پ - xâ‚ƒ) - yâ‚پ - W.aâ‚پ*xâ‚ƒ - W.aâ‚ƒ
        MordellWeilGroup.mk_point E xâ‚ƒ yâ‚ƒ sorry

/-- Negation of a point on the elliptic curve -/
def MordellWeilGroup.neg (P : MordellWeilGroup E) : MordellWeilGroup E :=
  match P.point with
  | none => P  -- -âˆ‍ = âˆ‍
  | some (x, y) =>
    -- The negative of (x,y) is (x, -y - aâ‚پ*x - aâ‚ƒ)
