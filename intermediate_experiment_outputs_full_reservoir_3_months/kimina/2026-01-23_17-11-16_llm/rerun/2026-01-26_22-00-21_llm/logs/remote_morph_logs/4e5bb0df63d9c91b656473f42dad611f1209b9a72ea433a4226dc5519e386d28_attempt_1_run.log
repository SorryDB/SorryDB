lemma not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ δ ⋝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  intro h
  rcases h with ⟨i, hi⟩
  have h1 : (χ ➝ δ ∈ T.theory) ∨ (∀ (Γ : Finset (Formula ℕ)), ↑Γ ⊆ construction T hT i → (Γ.conj ⋏ δ ⋝ ξ ∉ T.theory)) := by
    simpa [construction] using hi
  rcases h1 with (h1 | h1)
  · -- Case where the first part of the disjunction holds
    exfalso
    have h2 : (δ ∈ T.theory) := by
      simpa using h1
    have h3 : (δ ⋝ ξ ∈ T.theory) := by
      simpa [Finset.conj] using hφ
    have h4 : (δ ⋝ ξ ∉ T.theory) := by
      have h5 : (δ ∈ T.theory) := h2
      have h6 : (δ ⋝ ξ ∉ T.theory) := by
        apply T.imp_closed (φ := δ)
        · exact h5
        · exact orIntroL
      exact h6
    tauto
  · -- Case where the second part of the disjunction holds
    exfalso
    have hC : δ ∈ construction T hT i := by
      simpa using hC
    have h2 : ∀ (Γ : Finset (Formula ℕ)), ↑Γ ⊆ construction T hT i → (Γ.conj ⋏ δ ⋝ ξ ∉ T.theory) := h1
    have h3 := h2 (Finset.mk δ (by simp [hC]))
    tauto
