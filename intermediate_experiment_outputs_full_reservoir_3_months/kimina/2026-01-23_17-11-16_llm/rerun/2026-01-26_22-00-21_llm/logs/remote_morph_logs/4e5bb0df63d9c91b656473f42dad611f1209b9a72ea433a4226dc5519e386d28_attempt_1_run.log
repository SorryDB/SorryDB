            simpa using hC
          have h2 : encode φ = i := by
            simpa using hC
          have h3 : δ = φ := by
            have h4 : encode δ = encode φ := by
              omega
            have h5 : δ = φ := by
              apply encode_inj.mp h4
            exact h5
          exact h3
        subst this;
        apply h Γ ((show ↑Γ ⊆ construction T hT (encode δ) by
          simp [hC] at hΓ ⊢
          <;> tauto
        )) hφ;
      . simp at hC ⊢; tauto;
    . simp at hC ⊢; tauto;
    . simp at hC ⊢; tauto;
    . simp at hC ⊢; tauto;
