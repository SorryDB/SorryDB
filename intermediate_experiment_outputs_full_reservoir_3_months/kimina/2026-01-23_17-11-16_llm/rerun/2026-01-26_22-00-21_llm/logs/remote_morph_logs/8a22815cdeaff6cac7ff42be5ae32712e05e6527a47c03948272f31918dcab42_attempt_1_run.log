    (h2 : ∀ i ∈ Filter.cofinite, IsCompact ((E i).toAddMonoidHom.range))
    (h3 : ∀ i ∈ Filter.cofinite, IsOpen ((E i).toAddMonoidHom.range)) :
    addEquivAddHaarChar (∏ᶠ i in Filter.cofinite, E i) =
      (∏ᶠ i in Filter.cofinite, addEquivAddHaarChar (E i)) * addEquivAddHaarChar (E id) := by
  have h4 : ∀ i ∈ Filter.cofinite, IsBijOn (E i) (Set.range (E i).toAddMonoidHom) (Set.range (E i).toAddMonoidHom) := h
  have h5 : ∀ i ∈ Filter.cofinite, IsCompact ((E i).toAddMonoidHom.range) := h2
  have h6 : ∀ i ∈ Filter.cofinite, IsOpen ((E i).toAddMonoidHom.range) := h3
  -- Apply the main theorem from measure theory about product of measures
