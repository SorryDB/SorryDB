lemma MeasureTheory.addEquivAddHaarChar_prodCongr {G : Type u_1} [CommGroup G] [Fact (Nontrivial G)]
    {X : Type u_2} [AddCommGroup X] {F : Type u_3} [AddCommGroup F]
    {E : X →* F} [AddCommGroupHom E] {μ : Measure F} {s : Set X}
    (h : ∀ x ∈ s, ∀ y ∈ s, (E x).toAddMonoidHom.comp (E y).toAddMonoidHom⁻¹ = id)
    (h2 : ∀ x ∈ s, IsCompact ((E x).toAddMonoidHom.range))
    (h3 : ∀ x ∈ s, IsOpen ((E x).toAddMonoidHom.range)) :
    addEquivAddHaarChar (∏ᶠ i ∈ s, E i) = ∏ᶠ i ∈ s, addEquivAddHaarChar (E i) := by
  have h4 : ∀ i ∈ s, IsBijOn (E i) (Set.range (E i).toAddMonoidHom) (Set.range (E i).toAddMonoidHom) := by
    intro i hi
    constructor
    · -- Show injective on range
      intro x hx y hy h
      simp at h
      exact h
    · -- Show surjective on range
      intro y
      simp
      exact ⟨y, by simp⟩
  have h5 : ∀ i ∈ s, IsCompact ((E i).toAddMonoidHom.range) := h2
  have h6 : ∀ i ∈ s, IsOpen ((E i).toAddMonoidHom.range) := h3
  -- Apply the main theorem from measure theory about product of measures
  rw [MeasureTheory.addEquivAddHaarChar_prod h4 h5 h6]
  all_goals try simp
```

