instance (n : ℕ) : IsProbabilityMeasure (wignerMatrixMeasure n μ ν) := by
  sorry

/--The diagonal entry of a Wigner Matrix is a measurable function from `WignerSpace` to `ℝ`-/
@[fun_prop]
lemma diagonalEntryMeasurable (n : ℕ) (i : Fin n) :
