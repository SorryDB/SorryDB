/--For any `(n : ℕ)` the map `wignerMatrixMap` is `AEMeasurable` from `WignerSpace n` to
  `Matrix (Fin n) (Fin n) ℝ`-/
@[fun_prop]
lemma wignerMatrixMapAEMeasurable (n : ℕ) : AEMeasurable (wignerMatrixMap n) := by
