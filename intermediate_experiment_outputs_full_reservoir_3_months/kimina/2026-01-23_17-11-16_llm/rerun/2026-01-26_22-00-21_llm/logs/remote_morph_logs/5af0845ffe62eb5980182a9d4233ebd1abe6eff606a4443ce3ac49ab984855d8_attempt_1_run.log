noncomputable
def wignerMatrixMeasure (n : ℕ) (μ ν : Measure ℝ ) : Measure (Matrix (Fin n) (Fin n) ℝ) :=
  Measure.map (wignerMatrixMap n) (WignerMeasure μ ν n)


