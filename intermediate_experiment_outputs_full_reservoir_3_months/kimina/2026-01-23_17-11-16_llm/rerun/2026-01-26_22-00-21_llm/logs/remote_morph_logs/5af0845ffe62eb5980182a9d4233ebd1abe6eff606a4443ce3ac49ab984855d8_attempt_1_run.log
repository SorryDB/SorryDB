lemma is_measurable_Wigner (Y : isWignerMatrix n μ ν X P) : Measurable X := by
  exact Y.meas

/-- The index set for the independent random variables of a Wigner matrix. -/
def Index (n : ℕ) := { p : Fin n × Fin n // p.1 ≤ p.2 }

