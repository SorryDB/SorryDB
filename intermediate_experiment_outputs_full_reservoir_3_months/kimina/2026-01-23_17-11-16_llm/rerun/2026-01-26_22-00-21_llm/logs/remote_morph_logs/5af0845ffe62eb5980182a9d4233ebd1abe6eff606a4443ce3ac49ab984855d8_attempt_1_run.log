lemma indep_entries (Y : isWignerMatrix n μ ν X P) (i j k l : Fin n) (hdiff : Sym2.mk (i,j) ≠ Sym2.mk (k,l)) :
    IndepFun (fun ω ↦ X ω i j) (fun ω ↦ X ω k l) P := by
