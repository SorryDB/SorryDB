lemma diagonal_law (Y : isWignerMatrix n μ ν X P) (i : Fin n) : HasLaw (fun ω ↦ X ω i i) ν P:= by
   apply Y.diag_dist i

@[simp]
lemma symmetric (Y : isWignerMatrix n μ ν X P) : ∀ (ω : Ω), (X ω).IsSymm := by
  intro ω
