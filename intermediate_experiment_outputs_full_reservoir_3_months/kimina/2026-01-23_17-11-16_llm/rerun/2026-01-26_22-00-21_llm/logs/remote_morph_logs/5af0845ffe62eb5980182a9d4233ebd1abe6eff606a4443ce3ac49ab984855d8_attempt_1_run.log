@[grind, simp]
def wignerMatrixEntryFunction (ω : WignerSpace n) : (Fin n) → (Fin n) → ℝ :=
  fun i j =>
    if h_eq : i = j then
      ω (⟨(i, i), le_refl i⟩)
    else if h_lt : i < j then
      ω (⟨(i, j), le_of_lt h_lt⟩)
    else
      have h_gt : j < i := by
         apply lt_of_le_of_ne
         apply le_of_not_lt h_lt
         apply ne_of_not_lt h_lt
      ω (⟨(j, i), le_of_lt h_gt⟩)


