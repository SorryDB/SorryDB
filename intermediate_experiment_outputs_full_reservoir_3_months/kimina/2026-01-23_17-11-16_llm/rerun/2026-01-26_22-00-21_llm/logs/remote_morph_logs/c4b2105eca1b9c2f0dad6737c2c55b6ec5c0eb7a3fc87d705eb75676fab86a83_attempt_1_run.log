      have h6 : c * (μ (supp f)).toReal ^ p⁻¹.toReal * (ν G).toReal ^ p'⁻¹.toReal = eLpNorm f p 1 μ / (c⁻¹ * p) * (ν G).toReal ^ p'⁻¹.toReal := by
