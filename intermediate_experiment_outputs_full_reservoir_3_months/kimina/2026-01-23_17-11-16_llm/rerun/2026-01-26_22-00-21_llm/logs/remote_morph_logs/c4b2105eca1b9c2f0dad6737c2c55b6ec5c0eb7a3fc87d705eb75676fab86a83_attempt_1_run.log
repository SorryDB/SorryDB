import Mathlib
open Filter MeasureTheory

variable {α : Type*} {α' : Type*} {β : Type*} {m : MeasurableSpace α} {m' : MeasurableSpace α'}
  {ε : Type*} [Zero ε] [One ε] [AddCommMonoid ε] [TopologicalSpace ε] [ENorm ε]
  {ε' : Type*} [Zero ε'] [One ε'] [AddCommMonoid ε'] [TopologicalSpace ε'] [ENorm ε']
  {f : α → ε} {f' : α → ε'}
  {μ : Measure α} {ν : Measure α'}

lemma setLIntegral_Ici {f : ℝ≥0 → ℝ≥0∞} {a : ℝ≥0} :
    ∫⁻ (t : ℝ≥0) in Set.Ici a, f t = ∫⁻ (t : ℝ≥0), f (t + a) := by
