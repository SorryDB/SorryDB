variable {α : Type*} [MeasureTheory.MeasureSpace α] [TopologicalSpace α] [ENormedSpace α] {f : α → ℝ≥0} {f₁ : α → α}

/-- An operator has Lorentz type `(p, r, q, s)` if it is bounded as a map
