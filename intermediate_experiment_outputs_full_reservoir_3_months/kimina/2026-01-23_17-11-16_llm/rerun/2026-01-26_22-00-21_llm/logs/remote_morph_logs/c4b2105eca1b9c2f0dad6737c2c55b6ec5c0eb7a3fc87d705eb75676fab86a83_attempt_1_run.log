variable {β : Type*} [Zero β] [One β] --[NormedField 𝕂] --[ENormedAddMonoid 𝕂] [Field 𝕂] --[TopologicalSpace 𝕂]
  --[TopologicalSpace 𝕂] [ContinuousENorm 𝕂] [NormedField 𝕂]
