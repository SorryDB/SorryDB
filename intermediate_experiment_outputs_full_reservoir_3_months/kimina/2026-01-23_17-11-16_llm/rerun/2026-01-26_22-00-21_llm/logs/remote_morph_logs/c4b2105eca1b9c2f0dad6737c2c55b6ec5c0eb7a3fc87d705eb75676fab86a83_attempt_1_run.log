variable {α' ε₁ ε₂ : Type*} {m : MeasurableSpace α'} [TopologicalSpace ε₁] [ENorm ε₁]
    [TopologicalSpace ε₂] [ENorm ε₂] {f : α → ε} {f₁ : α → ε₁}

