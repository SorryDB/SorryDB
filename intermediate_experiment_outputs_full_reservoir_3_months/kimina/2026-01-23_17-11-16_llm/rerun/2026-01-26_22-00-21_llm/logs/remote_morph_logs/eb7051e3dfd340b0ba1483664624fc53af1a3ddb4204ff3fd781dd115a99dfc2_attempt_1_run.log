    _ = ‚ąĎ I ‚ąą A √óňĘ A ^ m, ‚ąę ŌČ, ‚ąŹ k, inner ‚ĄĚ (X (I k).1 ŌČ) (X (I k).2 ŌČ) ‚ąāőľ := by
      simp_rw [pow_mul, ‚Üź real_inner_self_eq_norm_sq, sum_inner, inner_sum, ‚Üź sum_product', Finset.sum_pow', integral_finset_sum _ integrable_prod_inner_X]
