open scoped NNReal ENNReal

variable {őĻ ő© E : Type*} {A : Finset őĻ} {m n : ‚Ąē} [MeasurableSpace ő©] {őľ : Measure ő©}
  [IsFiniteMeasure őľ] [mE : MeasurableSpace E] [NormedAddCommGroup E] [InnerProductSpace ‚ĄĚ E]
  {X : őĻ ‚Üí ő© ‚Üí E}

