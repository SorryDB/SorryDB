import Mathlib

lemma wignerMatrixSymmetric (n : ℕ) ( i j : Fin n) {ω : WignerSpace n} :
  wignerMatrixMap n ω i j = wignerMatrixMap n ω j i := by
  rw[wignerMatrixMap]
  rw[wignerMatrixMap']
  simp
  sorry

lemma wignerMatrixTracePowerMeasurable (n : ℕ) (k : ℕ) :
    Measurable (wignerMatrixTracePower n k) := by
  apply measurable_trace
  apply wignerMatrixPowMeasurable

lemma wignerMatrixScaledTracePowerMeasurable (n : ℕ) (k : ℕ) :
    Measurable (wignerMatrixScaledTracePower n k) := by
  apply measurable_trace
  apply wignerMatrixScaledPowMeasurable

noncomputable
def wignerMatrixTracePowerSequence (k : ℕ) : ℕ → ℝ :=
  fun n ↦ (WignerMeasure μ ν n)[wignerMatrixTracePower n k]

noncomputable
def wignerMatrixScaledTracePowerSequence (k : ℕ) : ℕ → ℝ :=
  fun n ↦ (WignerMeasure μ ν n)[(1 / (n : ℝ)) • wignerMatrixScaledTracePower n k]

lemma wignerMatrixMomentOddExpectation (n : ℕ) (k : ℕ) (hk : Odd k) :
  Tendsto (wignerMatrixScaledTracePowerSequence μ ν k) atTop (𝓝 (0 : ℝ)) := by
  have h1 : ∀ n : ℕ, (wignerMatrixScaledTracePowerSequence μ ν k n) = 0 := by
    intro n
    have h2 : (wignerMatrixScaledTracePowerSequence μ ν k n) =
        (WignerMeasure μ ν n) [(1 / (n : ℝ)) • wignerMatrixScaledTracePower n k] := by
      simp [wignerMatrixScaledTracePowerSequence]
    rw [h2]
    have h3 : (WignerMeasure μ ν n) [(1 / (n : ℝ)) • wignerMatrixScaledTracePower n k] = 0 := by
      have h4 : wignerMatrixScaledTracePower n k = fun ω ↦ ((wignerMatrixMap n ω) ^ k).trace := by
        simp [wignerMatrixScaledTracePower]
      rw [h4]
      have h5 : ∀ ω : WignerSpace n, ((wignerMatrixMap n ω) ^ k).trace = 0 := by
        intro ω
        have h6 : ((wignerMatrixMap n ω) ^ k).trace = 0 := by
          have h8 : ∀ i j : Fin n, (wignerMatrixMap n ω) i j = (wignerMatrixMap n ω) j i := by
            intro i j
            apply wignerMatrixSymmetric n i j
          have h9 : ((wignerMatrixMap n ω) ^ k).trace = 0 := by
            have h10 : Odd k := hk
            simp_all [Matrix.trace_pow, Matrix.is_symm_iff, h8]
          linarith
        simp_all
      simp_all [h5]
    simpa using h3
  simp_all [h1]
