theorem h_lamb_gt_q_sub_one (q n : ‚Ñï) (lamb : ‚ÑÇ):
  lamb ‚àà (primitiveRoots n ‚ÑÇ) ‚Üí ‚Äñ(X - (C lamb)).eval (q : ‚ÑÇ)‚Äñ > (q - 1) := by
  let a := lamb.re
