lemma le_abs_of_dvd {i j : ‚Ñ§} (gj: 0 ‚âÝ j) (h: i ‚à£ j) : |i| ‚â§ |j| := by
  rcases h with ‚ü®c, h‚ÇÄ‚ü©
  rcases em (c = 0) with hc | h
  ¬∑ by_contra
    rw [hc, mul_zero] at h‚ÇÄ
    exact gj h‚ÇÄ.symm
  ¬∑ calc
      |i| = |i| * 1 := by simp
      _ ‚â§ |i| * |c| := by gcongr 1; exact Int.one_le_abs h
      _ = |i * c| := (abs_mul i c).symm
      _ = |j| := by rw [h‚ÇÄ.symm]

/-- The `n`-th cyclotomic polynomial over the integers. -/
noncomputable
def phi (n : ‚Ñï) : ‚Ñ§[X] := cyclotomic n ‚Ñ§

lemma phi_dvd (n : ‚Ñï) : phi n ‚à£ X ^ n - 1 := by
  rw [phi]
  exact cyclotomic.dvd_X_pow_sub_one n ‚Ñ§

