example (i j : ‚Ñï) (gj: 0 ‚âÝ j) (h: i ‚à£ j): i ‚â§ j:= by
  rcases h with ‚ü®c, h‚ÇÄ‚ü©
  rcases em (c = 0) with hc | h
  ¬∑ by_contra
    rw [hc] at h‚ÇÄ
    exact gj h‚ÇÄ.symm
  ¬∑ calc
      i ‚â§ i*c := le_mul_of_le_of_one_le rfl.ge (zero_lt_iff.mpr h)
