  induction k using Nat.strong_induction_on
  case h k IH =>
    cases k
    case zero =>
      use 0
      constructor
      · exact h_k
      · simp
    case succ k =>
      by_cases φ k
      case pos h =>
        exact IH k (by simp) h
      case neg h =>
        by_cases ∃ l < k, φ l
