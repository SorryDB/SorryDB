/-- The parent-child relation ⋖_𝕋 in a Builder strategy tree. Similar to `edge` but data. -/
structure Match.edge (m n : Match bt) where
  YS : List GamePos
  next : (newPos : GamePos) → newPos ∈ YS → BuildTree newPos
  mPos : GamePos
