  rcases btAt m with ⟨pos, m_bt⟩
  rcases pos with ⟨Hist, X, _⟩
  intro m_n
  cases m_bt
  case Leaf p rp =>
    exfalso
    simp at rp
    -- lemma that leafs have no edges?
    have := @Match.leaf_no_edge _ _ m
    rw [btAt_m_def]
