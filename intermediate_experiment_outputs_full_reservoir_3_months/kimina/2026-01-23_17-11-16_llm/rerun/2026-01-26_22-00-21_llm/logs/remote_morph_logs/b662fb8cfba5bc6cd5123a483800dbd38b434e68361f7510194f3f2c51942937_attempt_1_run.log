lemma knowledge_of_secrets_is_preserved' {a b : Agent} (k : Bool)
    (hKv : S⌈σ⌉ ⊧ K a ((b,k) @ b))
    (hSub : σ ⊑ τ)
    : S⌈τ⌉ ⊧ K a ((b,k) @ b) := by
