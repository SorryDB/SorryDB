    (hKv : S⌈σ⌉ ⊧ K a ((b,k) @ b))
    (hSub : σ ⊑ τ)
    : S⌈τ⌉ ⊧ K a ((b,k) @ b) := by
  rcases σ with ⟨σ,o⟩
  rcases τ with ⟨τ,o'⟩
  rcases hSub with ⟨ρ, def_τ⟩ -- the `ρ` is called `τ \ σ` in the paper.
  induction ρ generalizing σ τ S o'
  · simp_all
  case cons C ρ IH =>
    subst def_τ
    have ρσ_o : maxOne (ρ ++ σ) := by exact ⁻o'
    simp only at IH hKv
    unfold eval
    simp only [List.cons_append, Subtype.forall]

