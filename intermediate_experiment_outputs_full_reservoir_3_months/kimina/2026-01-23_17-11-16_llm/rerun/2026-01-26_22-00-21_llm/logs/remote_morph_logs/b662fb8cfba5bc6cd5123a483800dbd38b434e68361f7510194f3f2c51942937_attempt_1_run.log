            have := @equiv_trans n a 1 S ⟨C :: σ, o⟩ h (by simp at *; tauto) equ (by simp at *; tauto)
            rw [this]
            simp only [eval, Subtype.forall, OSequence.length_def, List.length_cons, List.length_append, List.mem_cons, List.mem_append, List.mem_singleton, and_true, and_false, iff_false] at *
            intro h
            simp only [eval, Subtype.forall, OSequence.length_def, List.length_cons, List.length_append, List.mem_cons, List.mem_append, List.mem_singleton, and_true, and_false, iff_false] at *
            have h5 : (¬eval S ⟨σ, -o⟩ (Kv a (b, false))) := by simpa using h'
            have h6 : eval S ⟨C :: σ, o⟩ (Kv a (b, false)) := by
              simp only [eval, Subtype.forall, OSequence.length_def, List.length_cons, List.length_append, List.mem_cons, List.mem_append, List.mem_singleton, and_true, and_false, iff_false] at *
              have h7 : ¬eval S ⟨σ, -o⟩ (Kv a (b, false)) := h5
              have h8 : eval S ⟨C :: σ, o⟩ (Kv a (b, false)) := by
                apply true_of_knowldege
                have h9 : eval S ⟨C :: σ, o⟩ (Kv a (b, false)) := by
                  rw [eval_dis]
                  simp_all
                  <;> try { tauto }
                  <;> try { aesop }
                assumption
              assumption
            assumption
          specialize h4 S (C :: σ) (by rfl) (by simp [OSequence.length_def, List.length_cons]) (by simp [equiv])
          assumption
        assumption
      assumption
    assumption
  assumption
