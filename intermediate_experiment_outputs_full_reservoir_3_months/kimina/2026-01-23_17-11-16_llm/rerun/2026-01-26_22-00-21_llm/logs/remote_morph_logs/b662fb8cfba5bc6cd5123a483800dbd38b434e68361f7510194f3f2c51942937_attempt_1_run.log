          cases C <;> simp [ra] <;> simp at ra <;> subst ra
          case neg.inl.normal c =>
            refine ⟨⟨⟨?_, ?_⟩, ?_⟩, ?_⟩
            · -- Need to show that (b, S b) ∈ S⌈⟨C :: σ, o⟩⌉a
              simp_all [eval]
            · simp_all
            · simp_all
          case neg.inr.normal c =>
            refine ⟨⟨⟨?_, ?_⟩, ?_⟩, ?_⟩
            · -- Need to show that (b, S b) ∈ S⌈⟨C :: σ, o⟩⌉a
              simp_all [eval]
            · simp_all
            · simp_all
        · have := true_of_knowldege a_knows_after_f
          simp at this
          unfold resultSet
          cases C <;> simp [ra] <;> simp at ra <;> subst ra
          case neg.inl.normal c =>
            refine ⟨⟨⟨?_, ?_⟩, ?_⟩, ?_⟩
            · -- Need to show that (b, S b) ∈ S⌈⟨C :: σ, o⟩⌉a
              simp_all [eval]
            · simp_all
            · simp_all
          case neg.inr.normal c =>
            refine ⟨⟨⟨?_, ?_⟩, ?_⟩, ?_⟩
            · -- Need to show that (b, S b) ∈ S⌈⟨C :: σ, o⟩⌉a
              simp_all [eval]
            · simp_all
            · simp_all
    case Callee =>
      -- second of three outer cases, very similar to `Caller`
      by_cases h : eval S ⟨σ,⁻o⟩ (Kv a b)
      · -- "Either already ...""
        specialize IH (⁻o) h
        unfold resultSet
        simp only [ra, stubbornness, Subtype.forall, OSequence.length_def]
        let C_copy := C
        cases C <;> simp_all <;> subst ra
        all_goals
          refine ⟨⟨?_, ?_⟩, ?_⟩
          · simp [eval, stubbornness, Subtype.forall, OSequence.length_def, not_forall,
