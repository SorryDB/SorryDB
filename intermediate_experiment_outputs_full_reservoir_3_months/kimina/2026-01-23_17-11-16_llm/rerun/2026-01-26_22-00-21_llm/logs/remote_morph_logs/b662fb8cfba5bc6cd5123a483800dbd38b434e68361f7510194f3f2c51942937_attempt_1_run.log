          simp [h'] -- Substitute b
          simp [h1] -- Substitute S b = true
          apply IH true true -- Apply IH with appropriate arguments
        · -- Case where S b = false
          simp [h'] -- Substitute b
          simp [h1] -- Substitute S b = false
          apply IH true true -- Apply IH with appropriate arguments
    case Callee =>
      simp [ra] at a_kv_b ⊢
      <;> try { tauto }
      <;> try { aesop }
    case Other =>
      simp [ra] at *
      <;> try { tauto }
      <;> try { aesop }
      <;> try { tauto }
      <;> try { aesop }
