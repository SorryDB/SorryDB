abbrev Agent (n : ℕ) : Type (n + 1) := ℕ

/-- A type representing a distribution. -/
abbrev Dist (n : ℕ) : Type (n + 1) := ℕ → Prop

/-- The length of an `OSequence`. -/
noncomputable def OSequence.length {σ : OSequence n} : ℕ := σ.length

/-- The maximum element of an `OSequence`. -/
noncomputable def OSequence.maxOne {σ : OSequence n} : ∀ (c : Call n), c ∈ σ → ∃ (d : Call n), d ∈ σ ∧ ∀ (e : Call n), e ∈ σ → d ≤ e := by
  intro c hc
