lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ, o⟩
  induction σ
  case nil =>
    unfold eval eval eval at a_kv_b
    simp only [not_and_or, not_not] at a_kv_b
    rcases a_kv_b with h | h
    all_goals
      simp_all [eval]
      by_cases b = a
      · aesop
      · exfalso
        have := h S ⟨[], by simp [maxOne]⟩ (by simp)
        have := h (S.switch b) ⟨[], by simp [maxOne]⟩ (by simp) (by simp [Dist.switch]; grind)
        simp_all [Dist.switch]
  case cons C σ IH =>
    cases ra : roleOfIn a C
    case Caller =>
      by_cases h' : b = a
      · -- If b = a, then the result is trivial
        simp [h'] -- Substitute b with a
        apply IH true (by simpa using a_kv_b) -- Apply IH with appropriate arguments
      · -- If b ≠ a, we need to reason about the specific values
        rcases h1 with (h1 | h1) -- h1 is S b = true ∨ S b = false
        · -- Case where S b = true
          simp [h'] -- Substitute b
          simp [h1] -- Substitute S b = true
          apply IH true true -- Apply IH with appropriate arguments
        · -- Case where S b = false
          simp [h'] -- Substitute b
          simp [h1] -- Substitute S b = false
          apply IH true true -- Apply IH with appropriate arguments
    case Callee =>
      simp [ra] at a_kv_b ⊢
      <;> try { tauto }
      <;> try { aesop }
    case Other =>
      simp [ra] at *
      <;> try { tauto }
      <;> try { aesop }
      <;> try { tauto }
      <;> try { aesop }
