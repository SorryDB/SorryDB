-- A distributed system
structure Dist (n : ℕ) : Type 0 where
  values : ℕ → Prop
  -- A call made by an agent
structure Call (n : ℕ) : Type 0 where
  from : Agent
  to : Agent
  -- A boolean value
structure Bool : Type 0 where
  val : ℕ
  -- A proposition
structure Prop : Type 0 where
  val : ℕ
  -- A term in our logic
structure Term : Type 0 where
  val : ℕ
  -- A formula in our logic
