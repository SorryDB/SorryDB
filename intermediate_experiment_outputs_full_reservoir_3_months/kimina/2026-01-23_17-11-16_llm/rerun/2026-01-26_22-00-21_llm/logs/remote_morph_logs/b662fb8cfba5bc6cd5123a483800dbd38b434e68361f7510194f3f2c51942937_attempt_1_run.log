            <;> try { 
              aesop 
            } 
          }
        · -- Similar contradiction for the false case
          have := true_of_knowldege a_knows_after_f
          simp_all [eval, Subtype.forall, not_forall, not_exists, not_and, not_not, iff_false, iff_true] at *
          <;> try { 
            exfalso 
            <;> try { 
              tauto 
            } 
            <;> try { 
              aesop 
            } 
          }
    · -- Case where a is the callee
      simp only [r] at *
      rcases r with ⟨_,_⟩
      -- Similar structure to the caller case
      by_cases h : eval S ⟨σ,⁻o⟩ (Kv a b)
      · -- If knowledge is known, use induction hypothesis
        have := IH (by simp at h; assumption)
        simp_all [eval, Subtype.forall, not_forall, not_exists, not_and, not_not, iff_false, iff_true]
        <;> try { tauto }
        <;> try { 
