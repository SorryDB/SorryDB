  true => f.val = 1
  false => f.val = 0

-- The definition of `Has` (a term satisfies a proposition)
def has_def (t : Term) (p : Prop) : Prop where
  true => t.val = p.val
  false => t.val ≠ p.val

-- The definition of `Eval` (evaluating a term in a context)
def eval_def (s : Dist n) (t : Term) : Prop where
  true => s.tactics t
  false => ¬s.tactics t

-- The definition of `ResultSet`
