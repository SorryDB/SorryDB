  simp
  constructor
  · intro hyp η ρ same_len equ'
    apply hyp η ρ (by simp at h1; aesop)
    have := @equiv_trans n a m S ⟨σ,o⟩ h1 T τ h2 η ρ (by grind) equ (by convert equ'; grind)
    convert this
