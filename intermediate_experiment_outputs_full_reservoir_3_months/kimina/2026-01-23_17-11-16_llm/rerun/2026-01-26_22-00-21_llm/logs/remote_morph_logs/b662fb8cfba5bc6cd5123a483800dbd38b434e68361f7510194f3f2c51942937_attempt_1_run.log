        simp [h'] -- Substitute b with a
        apply IH true (by simpa using a_kv_b) -- Apply IH with appropriate arguments
      · -- If b ≠ a, we need to reason about the specific values
        rcases h1 with (h1 | h1) -- h1 is S b = true ∨ S b = false
