  val : ℕ
-- The result set of an agent
structure ResultSet (n : ℕ) (a : Agent) (s : Dist n) (σ : OSequence n) : Set (Term n) where
  val : ℕ
-- The knowledge of an agent
structure Knowledge (n : ℕ) (a : Agent) (s : Dist n) (σ : OSequence n) : Set (Term n) where
  val : ℕ

-- A sequence of calls is valid if it contains at most one call from a given agent
def valid (n : ℕ) (σ : OSequence n) : Prop where
  valid σ := ∀ (a : Agent), List.count a σ.calls ≤ 1

-- The length of a sequence
def length (σ : OSequence n) : ℕ := σ.calls.length

