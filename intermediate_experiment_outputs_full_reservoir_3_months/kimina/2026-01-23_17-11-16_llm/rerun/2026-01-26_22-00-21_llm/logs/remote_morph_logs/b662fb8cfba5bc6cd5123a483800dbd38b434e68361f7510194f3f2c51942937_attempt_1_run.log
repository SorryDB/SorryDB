lemma equiv_then_know_same {a m S} {σ : @OSequence n} {h1 : σ.length = m} {T τ h2}
    (equ : equiv a (S, ⟨σ, h1⟩) (T, ⟨τ, h2⟩))
    φ
    : eval S σ (K a φ) ↔ eval T τ (K a φ) := by
