  rw [← or_iff_not_and_not] at hKv
  unfold eval eval eval
  rw [← or_iff_not_and_not]
  rcases hKv with (h|h)
  · left
    exact @knowledge_of_secrets_is_preserved' n S σ τ a b true h hSub
  · right
    exact @knowledge_of_secrets_is_preserved' n S σ τ a b false h hSub

