  apply DifferentiableOn.contDiffOn
  apply DifferentiableOn.mul
  · -- Show that `fun z ↦ exp(z * r)` is differentiable on ℂ
    apply DifferentiableOn.comp
    · -- The exponential function is differentiable
      apply differentiableOn_exp
    · -- The function `fun z ↦ z * r` is differentiable
      apply DifferentiableOn.mul
      · -- The function `fun z ↦ z` is differentiable
        exact differentiableOn_id
      · -- The function `fun z ↦ r` (constant) is differentiable
        exact differentiableOn_const r
  · -- Show that `fun z ↦ (z + 1)^2` is differentiable on ℂ
    apply DifferentiableOn.pow
    · -- Show that `fun z ↦ z + 1` is differentiable on ℂ
      apply DifferentiableOn.add
      · -- The function `fun z ↦ z` is differentiable
        exact differentiableOn_id
      · -- The function `fun z ↦ 1` is differentiable
        exact differentiableOn_const 1
    · -- The exponent `2` is a constant, so the power function is differentiable
      exact differentiableOn_const 2

