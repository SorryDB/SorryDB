theorem Φ₁'_contDiffOn : ContDiffOn ℝ ∞ (Φ₁' r) ℍ₀ := by
  apply Differentiable.differentiableOn
  apply Differentiable.mul
  · apply Differentiable.exp
    apply Differentiable.re
    exact differentiable_id'
  · apply Differentiable.mul
    · exact differentiable_const (-1)
    · apply Differentiable.inv
      apply Differentiable.add
      · apply Differentiable.re
        exact differentiable_id'
      · exact differentiable_const 1
      all_goals
        intro x hx
        simp only [mem_setOf_eq, mem_upperHalfPlaneSet] at hx
        have h1 : (x.1 : ℝ) ^ 2 + (x.2 : ℝ) ^ 2 > 0 := by
          have h2 : (x.2 : ℝ) > 0 := hx.2
          nlinarith [sq_pos_of_pos h2]
        positivity

