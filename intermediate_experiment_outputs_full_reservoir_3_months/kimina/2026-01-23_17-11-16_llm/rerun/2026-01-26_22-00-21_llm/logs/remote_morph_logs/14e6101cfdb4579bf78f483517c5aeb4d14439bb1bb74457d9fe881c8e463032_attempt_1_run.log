theorem Φ₅'_contDiffOn : ContDiffOn ℝ ∞ (Φ₅' r) ℍ₀ := by 
  have h1 : DifferentiableOn ℝ (fun z : ℂ ↦ z.re) ℍ₀ := by
    apply DifferentiableOn.re
    exact differentiableOn_id
  have h2 : DifferentiableOn ℝ (fun z : ℂ ↦ z.im) ℍ₀ := by
    apply DifferentiableOn.im
    exact differentiableOn_id
  have h3 : DifferentiableOn ℝ (fun z : ℂ ↦ (1 / z).re) ℍ₀ := by
    intro z hz
    have hz' : z ≠ 0 := by
      intro h
      have : z.im = 0 := by
        simpa using congr_arg Complex.im h
      linarith [hz.2]
    simp [Complex.div_re, hz']
    all_goals
      try { apply DifferentiableAt.mul } <;> try { apply DifferentiableAt.inv } <;> try { apply differentiableAt_id } <;> try { apply differentiableAt_const }
  have h4 : DifferentiableOn ℝ (fun z : ℂ ↦ (1 / z).im) ℍ₀ := by
    intro z hz
    have hz' : z ≠ 0 := by
      intro h
      have : z.im = 0 := by
        simpa using congr_arg Complex.im h
      linarith [hz.2]
    simp [Complex.div_im, hz']
    all_goals
      try { apply DifferentiableAt.mul } <;> try { apply DifferentiableAt.inv } <;> try { apply differentiableAt_id } <;> try { apply differentiableAt_const }
  have h5 : DifferentiableOn ℝ (fun z : ℂ ↦ (z.re + z.im * r)) ℍ₀ := by
    apply DifferentiableOn.add
    · apply DifferentiableOn.mul
      · exact differentiableOn_const r
      · exact differentiableOn_id
    · apply DifferentiableOn.mul
      · exact differentiableOn_id
      · exact differentiableOn_const r
  have h6 : DifferentiableOn ℝ (fun z : ℂ ↦ Complex.exp (-z - 1 / z).re) ℍ₀ := by
    apply DifferentiableOn.exp
    apply DifferentiableOn.sub
    · apply DifferentiableOn.mul
      · exact differentiableOn_const (-1)
      · apply DifferentiableOn.add
        · exact differentiableOn_id
        · apply DifferentiableOn.mul
          · exact differentiableOn_const (-1)
          · exact differentiableOn_id
    · apply DifferentiableOn.div
      · exact differentiableOn_id
      · intro z hz
        have hz' : z ≠ 0 := by
          intro h
          have : z.im = 0 := by
            simpa using congr_arg Complex.im h
          linarith [hz.2]
        exact hz'
  have h7 : DifferentiableOn ℝ (fun z : ℂ ↦ Complex.exp (-z - 1 / z).im) ℍ₀ := by
    apply DifferentiableOn.exp
    apply DifferentiableOn.sub
    · apply DifferentiableOn.mul
      · exact differentiableOn_const (-1)
      · apply DifferentiableOn.add
        · exact differentiableOn_id
        · apply DifferentiableOn.mul
          · exact differentiableOn_const (-1)
          · exact differentiableOn_id
    · apply DifferentiableOn.div
      · exact differentiableOn_id
      · intro z hz
        have hz' : z ≠ 0 := by
          intro h
          have : z.im = 0 := by
            simpa using congr_arg Complex.im h
          linarith [hz.2]
        exact hz'
  have h8 : DifferentiableOn ℝ (fun z : ℂ ↦ (Complex.exp (-z - 1 / z) * (1 / z)).re) ℍ₀ := by
    apply DifferentiableOn.mul
    · exact h6
    · exact h3
  have h9 : DifferentiableOn ℝ (fun z : ℂ ↦ (Complex.exp (-z - 1 / z) * (1 / z)).im) ℍ₀ := by
    apply DifferentiableOn.mul
    · exact h7
    · exact h4
  exact h8.contDiffOn isOpen_upperHalfPlaneSet
