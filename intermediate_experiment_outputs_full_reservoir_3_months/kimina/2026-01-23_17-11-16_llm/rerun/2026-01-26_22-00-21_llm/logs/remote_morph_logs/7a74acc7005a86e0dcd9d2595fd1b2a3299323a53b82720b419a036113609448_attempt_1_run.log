    intro m h hm H
    have hq' := zero_lt_of_lt hq
    by_cases hkeqm : k = m
    · exact Eq.dvd hkeqm

    have hkm : k ≤ m := by
      have : 0 < q ^ m - 1 := by
        have : 1 < q ^ m := by
          calc
            _ < q := hq
            _ = q^1 := (Nat.pow_one q).symm
            _ ≤ q ^ m := (pow_le_pow_iff_right₀ hq).mpr hm
