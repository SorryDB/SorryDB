example : 1 = 1 := by exact?

theorem eg'' (m : ℕ) :  m + 1 ≤ m + 3 :=
  eg _ _

example (n: Nat): n ≤ n + 1 ∧ n + 1 ≤ n + 2 := by
  apply And.intro
  · -- Proof of n ≤ n + 1
    simp
  · -- Proof of n + 1 ≤ n + 2
