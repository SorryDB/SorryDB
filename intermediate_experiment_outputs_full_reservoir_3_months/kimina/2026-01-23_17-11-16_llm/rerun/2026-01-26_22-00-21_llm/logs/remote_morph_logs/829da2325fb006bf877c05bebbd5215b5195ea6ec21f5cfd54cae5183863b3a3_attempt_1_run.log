        simp only [List.mem_map, Sigma.exists, exists_and_right, prMoves] at newPos_in
        rcases newPos_in with ⟨Y, ⟨r, r_in⟩, def_newPos⟩
        simp only [tableauGame]
        apply mem_theMoves_of_move
        subst newPos
