        intro newPos newPos_in
        refine @winning_of_whatever_other_move _ _ s _ (by simp) h ⟨newPos, ?_⟩
        simp only [tableauGame, theMoves, Finset.mem_image, prMoves] at *
        rcases newPos_in with ⟨ltX, ltX_in, def_newPos⟩
