```tactics
  have h1 : (toComplexMeasure (toResolutionOfIdentity ha) x y).integral
    (Function.Embedding.subtype (spectrum ℂ a)) = ⟪x, a y⟫_ℂ := by
    simp [toComplexMeasure, cfc_toLinearFunctional, cfcCLM_apply, toLinearFunctional_apply]
    <;> norm_num [toComplexMeasure, cfc_toLinearFunctional, cfcCLM_apply, toLinearFunctional_apply]
    <;> aesop
