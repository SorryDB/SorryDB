deriving Repr, Inhabited

open LabelledTree

@[grind .]
def LabelledTree.addLabel (t: LabelledTree α) (label: α) : LabelledTree α :=
  match t with
  | leaf x =>
    if label = x then leaf x
    else if label < x then
      node label (leaf label) (leaf x)
    else
      node label (leaf x) (leaf label)
  | node v l r =>
