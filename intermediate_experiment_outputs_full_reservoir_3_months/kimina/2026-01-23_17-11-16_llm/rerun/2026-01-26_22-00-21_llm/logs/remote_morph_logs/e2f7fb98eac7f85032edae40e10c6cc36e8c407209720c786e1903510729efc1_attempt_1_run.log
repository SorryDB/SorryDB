    -- For any bird `x`, the bird `K ‚óÅ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ‚àÄ x, (K ‚óÅ x) is fixated on x := by
      intro x
      unfold fixated_on
      intro y
      have h := K.call x y
      simpa using h

    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      unfold hopelessly_egocentric
      intro x
      have h1 := K.call x x
      have h2 : K ‚óÅ x = x := by 
        simpa using kestrel_egocentric
      rw [h2] at h1
      simpa using h1

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ‚óÅ x = K ‚óÅ y) :
        (x = y) := by 
      have h1 : (K ‚óÅ x) ‚óÅ y = x := K.call x y
      have h2 : (K ‚óÅ y) ‚óÅ x = y := K.call y x
      have h3 : (K ‚óÅ y) ‚óÅ y = y := K.call y y
      have h4 : (K ‚óÅ x) ‚óÅ x = x := K.call x x
      have eq1 : (K ‚óÅ y) ‚óÅ y = x := by 
        rw [show K ‚óÅ x = K ‚óÅ y by exact kestrel_application] at h1 
        exact h1
      have eq2 : (K ‚óÅ x) ‚óÅ x = y := by 
        rw [show K ‚óÅ y = K ‚óÅ x by exact Eq.symm (kestrel_application)] at h2 
        exact h2
      linarith [h3, eq1, h4, eq2]
```

