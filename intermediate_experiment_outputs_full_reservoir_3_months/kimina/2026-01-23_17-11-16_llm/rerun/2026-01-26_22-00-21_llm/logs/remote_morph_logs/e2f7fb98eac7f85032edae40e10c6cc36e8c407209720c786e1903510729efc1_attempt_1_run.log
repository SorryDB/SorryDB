    -/

    -- the definition of a kestrel
    axiom K : Bird
    axiom K_call : ‚àÄ (x y : Bird), (K ‚óÅ x) ‚óÅ y = x

  end Kestrel

  section KestrelTheorems
    open Kestrel

    -- For any bird `x`, the bird `K ‚óÅ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ‚àÄ x, (K ‚óÅ x) is fixated on x := by
      intro x
      unfold is fixated on
      intro z
      have h1 : (K ‚óÅ x) ‚óÅ z = x := by
        apply K_call x z
      simpa using h1

