      have h4 : (K ‚óÅ y) ‚óÅ (K ‚óÅ y) = y := by
        apply h2
      have h5 : (K ‚óÅ y) ‚óÅ (K ‚óÅ y) = x := by
        rw [show K ‚óÅ x = K ‚óÅ y by exact kestrel_application] at h3
        exact h3
      have h6 : y = x := by
        linarith [h4, h5]
      linarith [h6]
