      have h6 : (K ‚óÅ x) ‚óÅ K = (K ‚óÅ y) ‚óÅ K := by
        rw [h5]
      -- Now we have (K ‚óÅ x) ‚óÅ K = (K ‚óÅ y) ‚óÅ K, which means x = y
      -- So we can conclude x = y
