        (K is hopelessly egocentric) := by
      unfold hopelessly_egocentric
      intro x
      have h1 : K ‚óÅ x = K := by
        rw [show K is egocentric by simpa using kestrel_egocentric]
        all_goals simp [response]
      simp [h1]

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ‚óÅ x = K ‚óÅ y) :
        (x = y) := by
      have h1 : (K ‚óÅ x) ‚óÅ K = x := K.call x K
      have h2 : (K ‚óÅ y) ‚óÅ K = y := K.call y K
      have h3 : (K ‚óÅ x) ‚óÅ K = (K ‚óÅ y) ‚óÅ K := by
        rw [show K ‚óÅ x = K ‚óÅ y by simpa using kestrel_application]
      rw [h1] at h3
      rw [h2] at h3
      all_goals try exact h3
      all_goals try tauto
