        (K is hopelessly egocentric) := by
      unfold is hopelessly egocentric
      intro x
      have h1 : K ‚óÅ x = K := by
        apply kestrel_egocentric
      rw [h1]
      all_goals simp [K_call]

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
