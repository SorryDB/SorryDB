open Finset

/-A context-free derivation consists of a sequence of steps, where each step transforms a word
  into another word according to the rules of a context-free grammar.
  This is a derivation tree for a context-free derivation. -/
structure DerivationTree (G : ContextFreeGrammar α nt)
  (v : α)
  (left : DerivationTree G (G.V ⊕ G.Z) (v := v) (left := true))
  (right : DerivationTree G (G.V ⊕ G.Z) (v := v) (left := false))
  (nonterm : α)
  (prod : G.P nonterm)
  (sub : List (DerivationTree G (G.V ⊕ G.Z) (v := v)) )
  (left_right : Finset.range (G.V ⊕ G.Z).val)

