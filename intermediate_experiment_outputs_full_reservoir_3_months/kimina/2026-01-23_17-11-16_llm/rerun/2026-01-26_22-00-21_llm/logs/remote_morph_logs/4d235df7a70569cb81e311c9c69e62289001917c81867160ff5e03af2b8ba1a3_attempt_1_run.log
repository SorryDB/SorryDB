                rw [Nat.add_assoc (dstep.suf.len) (dstep.pre.len) (dstep.prod.val.rhs).len]
                rw [Nat.add_comm (dstep.pre.len) (dstep.suf.len)]
                simp [← Nat.add_assoc] )⟩
