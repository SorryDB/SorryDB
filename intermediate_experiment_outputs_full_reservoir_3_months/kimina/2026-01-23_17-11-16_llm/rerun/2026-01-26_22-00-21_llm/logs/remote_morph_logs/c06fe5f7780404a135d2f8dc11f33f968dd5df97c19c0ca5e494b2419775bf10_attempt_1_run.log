  -/

  set_option quotPrecheck false in
  -- the definition of fixatedness
  notation A " is " " fixated " " on " B => ∀ x, A ◁ x = B


  namespace Kestrel
    /-!
      A bird `K` is a *kestrel* if for any birds `x` and `y`,
      the response of `K` to `x` is a bird that, when called, responds with `y`.
      More formally, `∀ (x y : Bird), (K ◁ x) ◁ y = x`.

      This is the standard definition of a "kestrel" in the context of
      combinator logic, where `K` would typically be the identity combinator `I`.
      However, in our context, `K` is a specific bird.
      https://en.wikipedia.org/wiki/Kestrel
    -/

    -- the definition of a kestrel
    axiom K : Bird
    axiom K_call : ∀ (x y : Bird), (K ◁ x) ◁ y = x

  end Kestrel

  section KestrelTheorems
    open Kestrel

    -- For any bird `x`, the bird `K ◁ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ∀ x, (K ◁ x) is fixated on x := by
      intro x
      unfold fixated_on
      intro y
      have h1 : (K ◁ x) ◁ y = x := K_call x y
      simpa using h1

    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      unfold hopelessly_egocentric
      intro x
      have h1 : K ◁ x = K := by
        -- This follows from K being a kestrel and the definition of being egocentric
        -- Since K is a kestrel, (K ◁ K) ◁ K = K. Since K is egocentric, K ◁ K = K.
        -- So (K) ◁ K = K, which means K is fixated on K.
        -- Wait, let me think more carefully.
        -- K is a kestrel, so ∀ x y, (K ◁ x) ◁ y = x
        -- K is egocentric, so K ◁ K = K
        -- We need to show ∀ x, K ◁ x = K
        -- Let's apply the kestrel property to x and K: (K ◁ x) ◁ K = x
        -- Since K is egocentric, K ◁ K = K. So (K ◁ x) ◁ (K ◁ K) = (K ◁ x) ◁ K = x
        -- But (K ◁ x) ◁ (K ◁ K) = (K ◁ x) ◁ K = x
        -- Wait, this is getting complicated.
        -- Let's try a different approach. We need to show ∀ x, K ◁ x = K
        -- Let's apply the kestrel property to K and x: (K ◁ K) ◁ x = K
        -- Since K is egocentric, K ◁ K = K. So K ◁ x = K
        -- This is exactly what we need!
        have h2 : (K ◁ K) ◁ x = K := K_call K x
        have h3 : K ◁ K = K := by
          simpa using kestrel_egocentric
        rw [h3] at h2
        exact h2
      simpa using h1

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ◁ x = K ◁ y) :
        (x = y) := by
      -- Let's apply the kestrel property to x and K
      have h1 : (K ◁ x) ◁ K = x := K_call x K
      -- Let's apply the kestrel property to y and K
      have h2 : (K ◁ y) ◁ K = y := K_call y K
      -- Since K ◁ x = K ◁ y, we have (K ◁ x) ◁ K = (K ◁ y) ◁ K
      have h3 : (K ◁ x) ◁ K = (K ◁ y) ◁ K := by
        rw [kestrel_application]
      -- So x = y
      linarith [h1, h2, h3]

