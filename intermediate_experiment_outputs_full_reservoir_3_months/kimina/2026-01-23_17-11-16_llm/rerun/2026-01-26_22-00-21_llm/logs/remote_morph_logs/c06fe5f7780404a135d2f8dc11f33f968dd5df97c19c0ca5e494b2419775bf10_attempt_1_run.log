  section KestrelTheorems
    open Kestrel

    -- For any bird `x`, the bird `K ◁ x` is fixated on `x`.
    theorem k_x_fixated_on_x : ∀ x, (K ◁ x) is fixated on x := by
      intro x
      unfold fixated_on
      intro y
      -- We need to show (K x) y = x
      -- This is exactly the property K.call x y
      apply K.call x y

    -- An egocentric kestrel must be hopelessly egocentric.
    theorem kestrel_egocentrism
        (kestrel_egocentric : K is egocentric) :
        (K is hopelessly egocentric) := by
      intro x
      have h1 : (K K) x = K := K.call K x
      rw [kestrel_egocentric] at h1
      exact h1

    -- The left cancellation law for kestrels.
    theorem kestrel_left_cancellation
        (x y : Bird)
        (kestrel_application : K ◁ x = K ◁ y) :
        (x = y) := by
      have h1 : (K x) x = x := K.call x x
      have h2 : (K y) y = y := K.call y y
      have h3 : (K x) x = (K y) x := by
        rw [show K x = K y by exact kestrel_application]
      rw [h1] at h3
      rw [h2] at h3
      exact h3

    -- `*` For an arbitrary bird `x`, if `K` is fond of `K ◁ x`,
    -- then `K` is fond of `x`.
    theorem kestrel_fondness
        (x : Bird)
        (fond_Kx : K is fond of (K ◁ x)) :
        K is fond of x := by
      have h1 : K (K x) = K x := by
        exact fond_Kx
      have h2 : (K x) (K x) = x := K.call x (K x)
      have h3 : (K x) (K x) = K x := by
        rw [show K (K x) = K x by exact h1]
        all_goals try tauto
      have h4 : x = K x := by
        linarith [h2, h3]
