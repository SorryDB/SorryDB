        have eq2 : (K ◁ (K ◁ x)) = (K ◁ x) := by 
          simpa using h1
        rw [eq2] at eq1
        have eq3 : (K ◁ x) ◁ (K ◁ x) = x := h3
        have eq4 : (K ◁ x) = x := by 
          have eq5 : (K ◁ x) ◁ (K ◁ x) = (K ◁ x) := by 
