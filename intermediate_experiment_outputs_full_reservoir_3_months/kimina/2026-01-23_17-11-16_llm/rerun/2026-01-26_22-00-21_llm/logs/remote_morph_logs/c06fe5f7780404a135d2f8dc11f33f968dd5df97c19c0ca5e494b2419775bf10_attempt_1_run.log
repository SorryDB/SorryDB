      have h2 := Kestrel_property (K ◁ x) x
      have h3 := Kestrel_property (K ◁ y) x
      simp [kestrel_application] at h1 h2 h3 ⊢
      all_goals tauto

    -- `*` For an arbitrary bird `x`, if `K` is fond of `K ◁ x`,
    -- then `K` is fond of `x`.
    theorem kestrel_fondness
        (x : Bird)
        (fond_Kx : K is fond of (K ◁ x)) :
        K is fond of x := by
      have h1 : K ◁ (K ◁ x) = K ◁ x := by
        simpa using fond_Kx
      have h2 : (K ◁ x) ◁ (K ◁ x) = x := by
        apply Kestrel_property x (K ◁ x)
      have h3 : (K ◁ (K ◁ x)) ◁ (K ◁ x) = K ◁ x := by
        apply Kestrel_property (K ◁ x) (K ◁ x)
      rw [h1] at h3
      have h4 : (K ◁ x) ◁ (K ◁ x) = K ◁ x := by
        simpa using h3
      rw [h4] at h2
      all_goals tauto
