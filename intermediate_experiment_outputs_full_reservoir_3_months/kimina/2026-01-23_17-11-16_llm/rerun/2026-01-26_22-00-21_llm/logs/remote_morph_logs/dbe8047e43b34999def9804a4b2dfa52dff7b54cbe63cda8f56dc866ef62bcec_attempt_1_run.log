instance : MeasurableSpace (Matrix (Fin n) (Fin n) ã ) := by
   unfold Matrix; infer_instance

@[ext]
structure isWignerMatrix
    (k : ã) (ö¥ ö§ : Measure ã) (X : öˋ ã Matrix (Fin k) (Fin k) ã) (P : Measure öˋ) where
  meas : Measurable X
  diag_dist : ã i : (Fin k), HasLaw (fun ü ãÎ X ü i i) ö§ P
  off_diag_dist : ã i j : (Fin k), i > j ã HasLaw (fun ü ãÎ X ü i j) ö¥ P
  symm : ã i j : (Fin k), ã ü : öˋ, X ü i j = X ü j i
  indep : iIndepFun (fun (x : {p : Fin k û Fin k // p.1 ãÊ p.2}) ãÎ fun ü ãÎ X ü x.val.1 x.val.2) P

#check isWignerMatrix

@[simp]
lemma is_measurable_Wigner (Y : isWignerMatrix n ö¥ ö§ X P) : Measurable X := by
  exact Y.meas

/-- The index set for the independent random variables of a Wigner matrix. -/
def Index (n : ã) := { p : Fin n û Fin n // p.1 ãÊ p.2 }

instance : Fintype (Index n) := by
  rw[Index]
  infer_instance

@[simp]
lemma off_diagonal_law (Y : isWignerMatrix n ö¥ ö§ X P) (i j : Fin n) (hij : i ã  j) :
  HasLaw (fun ü ãÎ X ü i j) ö¥ P:= by
  -- Since $i \neq j$, we have either $i < j$ or $j < i$. We can handle these cases separately using the off_diag_dist and the symmetry of the Wigner matrix.
  by_cases h : j < i;
  ôñ -- Since $j < i$, we can apply the off_diag_dist condition directly.
    apply Y.off_diag_dist i j h
    all_goals unreachable!;
  ôñ -- Since $i < j$, we can apply the off_diag_dist hypothesis with $i$ and $j$ swapped.
    have h_swap : HasLaw (fun ü ãÎ X ü j i) ö¥ P := by
      cases lt_or_gt_of_ne hij <;> aesop
      generalize_proofs at *;
      have := Y.off_diag_dist j i h_1; aesop;
    generalize_proofs at *;
    -- Since $X$ is symmetric, we have $X i j = X j i$.
    have h_symm : ã ü, X ü i j = X ü j i := by
      -- By the symmetry of the Wigner matrix, we have $X i j = X j i$ for all $i$ and $j$.
      intros ü; exact Y.symm i j ü
    generalize_proofs at *;
    aesop;

@[simp]
lemma diagonal_law (Y : isWignerMatrix n ö¥ ö§ X P) (i : Fin n) : HasLaw (fun ü ãÎ X ü i i) ö§ P:= by
   apply Y.diag_dist i

@[simp]
lemma symmetric (Y : isWignerMatrix n ö¥ ö§ X P) : ã (ü : öˋ), (X ü).IsSymm := by
  intro ü
  apply Matrix.IsSymm.ext
  intros i j
  apply Y.symm

@[simp]
lemma indep_entries (Y : isWignerMatrix n ö¥ ö§ X P) (i j k l : Fin n) (hdiff : Sym2.mk (i,j) ã  Sym2.mk (k,l)) :
    IndepFun (fun ü ãÎ X ü i j) (fun ü ãÎ X ü k l) P := by
  -- Define the projections from the Wigner matrix to its entries.
  let proj : {p : Fin n û Fin n // p.1 ãÊ p.2} ã öˋ ã ã := fun p ãÎ (fun ü ãÎ X ü p.val.1 p.val.2);
  -- By definition of Y.indep, the projections proj are independent.
  have h_indep : iIndepFun (fun (p : {p : Fin n û Fin n // p.1 ãÊ p.2}) ãÎ proj p) P := by
    -- Apply the hypothesis that the projections are independent.
    apply Y.indep;
  -- By definition of proj, we have that (fun ü => X ü i j) = proj ã´(i, j), by sorryãˋ and (fun ü => X ü k l) = proj ã´(k, l), by sorryãˋ.
  have h_eq_proj : (fun ü => X ü i j) = proj ã´(min i j, max i j), by
    exact min_le_maxãˋ ãÏ (fun ü => X ü k l) = proj ã´(min k l, max k l), by
    exact min_le_maxãˋ := by
    simp +
