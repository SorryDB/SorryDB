  Sigma1P ea (Complement L)

/--
  Δ₁ᴾ = P

  The first level of the delta hierarchy is still P.
-/
def Delta1P {α : Type} [Primcodable α] (ea : FinEncoding α) : Language α → Prop :=
  InP ea

/--
