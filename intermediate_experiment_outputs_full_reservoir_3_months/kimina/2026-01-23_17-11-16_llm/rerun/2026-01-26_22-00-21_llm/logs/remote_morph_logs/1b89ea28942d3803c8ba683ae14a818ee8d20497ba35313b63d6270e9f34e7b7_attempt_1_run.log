theorem double_spec (q : ProjectivePoint)
  (h_qX_bounds : ‚ąÄ i, i < 5 ‚Üí (q.X[i]!).val ‚Č§ 2 ^ 52)
  (h_qY_bounds : ‚ąÄ i, i < 5 ‚Üí (q.Y[i]!).val ‚Č§ 2 ^ 52)
  (h_qZ_bounds : ‚ąÄ i, i < 5 ‚Üí (q.Z[i]!).val ‚Č§ 2 ^ 52) :
‚ąÉ c,
double q = ok c ‚ąß
let X := Field51_as_Nat q.X
let Y := Field51_as_Nat q.Y
let Z := Field51_as_Nat q.Z
let X' := Field51_as_Nat c.X
let Y' := Field51_as_Nat c.Y
let Z' := Field51_as_Nat c.Z
let T' := Field51_as_Nat c.T
X' % p = (2 * X * Y) % p ‚ąß
Y' % p = (X^2 - Y^2) % p ‚ąß
Z' % p = (Z^2) % p ‚ąß
T' % p = (T^2) % p
:= by
  unfold double
  use add q q
  constructor
  ¬∑ -- Show that `add q q` is a valid point
