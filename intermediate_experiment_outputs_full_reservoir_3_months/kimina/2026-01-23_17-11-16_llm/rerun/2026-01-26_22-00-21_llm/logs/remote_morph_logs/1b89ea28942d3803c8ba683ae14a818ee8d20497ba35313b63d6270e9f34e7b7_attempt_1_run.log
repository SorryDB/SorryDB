      have h6 : (2 ^ 52 : ‚Ąē) < p := by
        norm_num
      omega
    have h5 : (q.Y[i]! : u64).val < p := by
      have h6 : (q.Y[i]! : u64).val ‚Č§ 2 ^ 52 := h2
      have h7 : (2 ^ 52 : ‚Ąē) < p := by
        norm_num
      omega
    have h6 : (q.Z[i]! : u64).val < p := by
      have h7 : (q.Z[i]! : u64).val ‚Č§ 2 ^ 52 := h3
      have h8 : (2 ^ 52 : ‚Ąē) < p := by
        norm_num
      omega
    -- The bounds on the squares are implicitly handled by the
    -- properties of modular arithmetic and the types
    -- (e.g., a^2 mod p is well-defined)
    simp [Nat.add_mod, Nat.mul_mod, pow_two]
    <;> try { native_decide }
    <;> try { tauto }
    <;> try { aesop }
