    let Y := Field51_as_Nat q.Y
    let Z := Field51_as_Nat q.Z
    let X' := Field51_as_Nat (add q q).X
    let Y' := Field51_as_Nat (add q q).Y
    let Z' := Field51_as_Nat (add q q).Z
    let T' := Field51_as_Nat (add q q).T
```

