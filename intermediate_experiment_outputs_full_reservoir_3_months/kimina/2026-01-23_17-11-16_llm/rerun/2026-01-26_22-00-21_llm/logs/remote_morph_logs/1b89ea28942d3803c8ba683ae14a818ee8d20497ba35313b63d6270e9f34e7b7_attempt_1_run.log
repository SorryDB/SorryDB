      apply h_qX_bounds i hi
    have h2 : (q.Y[i]!) ‚Č§ (2 ^ 52 : ‚Ąē) := by
      apply h_qY_bounds i hi
    have h3 : (q.X[i]! : ‚Ąē) ‚Č§ (2 ^ 52 : ‚Ąē) := by
      apply h_qX_bounds i hi
    have h4 : (q.Y[i]! : ‚Ąē) ‚Č§ (2 ^ 52 : ‚Ąē) := by
      apply h_qY_bounds i hi
    have hx2 : (‚ÜĎq.X[i]! : ‚Ą§) ‚Č§ (2 ^ 52 : ‚Ą§) := by
      exact_mod_cast h3
    have hy2 : (‚ÜĎq.Y[i]! : ‚Ą§) ‚Č§ (2 ^ 52 : ‚Ą§) := by
      exact_mod_cast h4
    have h5 : (‚ÜĎ(q.X[i]!) : ‚Ą§) ^ 2 ‚Č§ (2 ^ 104 : ‚Ą§) := by
      nlinarith [hx2]
    have h6 : (‚ÜĎ(q.Y[i]!) : ‚Ą§) ^ 2 ‚Č§ (2 ^ 104 : ‚Ą§) := by
      nlinarith [hy2]
    have h7 : (‚ÜĎ(q.X[i]!) : ‚Ą§) ^ 2 + (‚ÜĎ(q.Y[i]!) : ‚Ą§) ^ 2 ‚Č§ (U64.max : ‚Ą§) := by
      norm_num
      all_goals nlinarith
    norm_num at h7 ‚äĘ
    all_goals nlinarith
