import Mathlib

open Algebra

/-!
A quaternion algebra over a field F is a 4-dimensional vector space over F
with a basis {1, i, j, k} such that:
- i² = a
- j² = b
- k² = -ab
- i * j = k
- j * k = i
- k * i = j
where a, b ∈ F.
-/

structure IsQuaternionAlgebra (F : Type u) (A : Type v) [Field F] [Algebra F A]
    (D : Type w) [Algebra F D] : Prop :=
  ∃ (a b : F) ∃ (i j k : D)
    (_ : i ≠ 0 ∧ j ≠ 0 ∧ k ≠ 0) ∧
    (_ : (i * j) = k) ∧
    (_ : (j * k) = i) ∧
    (_ : (k * i) = j) ∧
    (_ : (i * i) = a) ∧
    (_ : (j * j) = b) ∧
    (_ : (k * k) = - (a * b)) ∧
    (_ : IsAlgebraMap F (fun x : F => x • 1) D) ∧
    (_ : ∀ (x y : F), (x • i) * (y • j) = (x * y) • k) ∧
    (_ : ∀ (x y : F), (x • j) * (y • k) = (x * y) • i) ∧
    (_ : ∀ (x y : F), (x • k) * (y • i) = (x * y) • j)

/-!
If D is a quaternion algebra over F, then E ⊗[F] D is a quaternion algebra over E
for any algebraic extension E of F.
-/

theorem isQuaternionAlgebraTensorProduct (F E D : Type*)
    [Field F] [Field E] [Algebra F E]
    [Ring D] [Algebra F D] [IsQuaternionAlgebra F D] :
    IsQuaternionAlgebra E (E ⊗[F] D) := by
  rcases h with ⟨a, b, i, j, k, h1, h2, h3, h4, h5, h6, h7, h8, h9, h10⟩
  use a, b
