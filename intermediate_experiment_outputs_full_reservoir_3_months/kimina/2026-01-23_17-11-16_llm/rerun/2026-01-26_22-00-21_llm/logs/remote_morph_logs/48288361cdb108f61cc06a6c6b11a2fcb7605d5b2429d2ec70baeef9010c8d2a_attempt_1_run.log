theorem isQuaternionAlgebra_tensorProduct
    {F : Type u_1} [Field F]
    {E : Type u_2} [Field E] [Algebra F E]
    {D : Type u_3} [Ring D] [Algebra F D] [IsQuaternionAlgebra F D]
