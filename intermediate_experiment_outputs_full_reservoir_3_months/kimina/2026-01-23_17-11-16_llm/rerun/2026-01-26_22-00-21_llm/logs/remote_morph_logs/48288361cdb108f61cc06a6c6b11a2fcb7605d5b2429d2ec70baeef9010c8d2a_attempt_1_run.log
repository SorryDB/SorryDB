  constructor
  · -- Show that (1 ⊗ i) * (1 ⊗ j) = 1 ⊗ k
    simp [h2]
  constructor
  · -- Show that (1 ⊗ j) * (1 ⊗ k) = 1 ⊗ i
    simp [h3]
  constructor
  · -- Show that (1 ⊗ k) * (1 ⊗ i) = 1 ⊗ j
