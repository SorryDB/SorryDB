    -- Goal: HasSum (fun i => inner ℂ x ((continuousLinearMapOfBilin (toBoundedBilin H _ _ _ _ _ ha 1 ((w i).indicator 1))) y) ) (inner ℂ x ((continuousLinearMapOfBilin (toBoundedBilin H _ _ _ _ _ ha 1 ((⋃ i, w i).indicator 1))) y))
