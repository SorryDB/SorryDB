    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . sorry;
        . assumption;
      . assumption
    . assumption;
    split at hi;
    -/

lemma not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
