lemma not_of_mem_construction_omega {φ : Formula ℕ}
  {Γ : Finset (Formula ℕ)} (hΓ : ↑Γ ⊆ construction T hT (encode φ))
  (hφ : Γ.conj ⋏ φ ➝ ξ ∈ T.theory) :
  φ ∉ (construction_omega T hT) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hφ;
  intro i;
  induction i with
  | zero =>
    simp only [construction] at hφ;
    exfalso;
    apply hφ; assumption;
  | succ i ih =>
    simp only [construction] at ih hφ;
    split at ih with h;
    . rename_i δ hδ;
      by_contra hC;
      have : δ = φ := by
        have hC' : δ ∈ construction T hT (i + 1) := by
          rw [Set.mem_insert_iff] at hδ; tauto
        have hC'' : δ ∈ construction T hT i := by
          have hC''' : δ ∈ construction T hT (i + 1) := hC'
          simp only [Nat.succ_eq_add_one, Set.mem_insert_iff, Set.mem_singleton_iff, or_false] at hC'''
          tauto
        have hC''' : δ ∈ construction T hT i := hC''
        have hC'''' : δ ∈ (Finset.image (fun (γ : Finset _) => γ.conj ⋏ φ) (Finset.powerset (construction T hT i))) := by
          simp only [Set.mem_image, Set.mem_setOf_eq, Set.mem_powerset] at *
          use δ; assumption
        have hC''''' : δ ∈ (Finset.image (fun (γ : Finset _) => γ.conj ⋏ φ) (Finset.powerset (construction T hT i))) := hC''''
        exfalso; apply hφ; assumption;
      . assumption
    . assumption

lemma of_not_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∉ construction_omega T hT) :
  (χ ➝ φ ∉ T.theory) ∧ (∃ Γ : Finset (Formula _), ↑Γ ⊆ (construction T hT (encode φ)) ∧ Γ.conj ⋏ φ ➝ ξ ∈ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hφ;
  constructor;
  . intro h; have : φ ∈ construction_omega T hT := by simpa using h; contradiction;
  . have this := hφ (encode φ + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this; assumption;
    . simpa using h;

variable [Entailment.F L]

lemma construction_omega_mem_ant : χ ∈ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
  apply impId;

lemma construction_omega_not_mem_csq : ξ ∉ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion, not_exists];
  intro i;
  induction i with
  | zero => simpa [construction];
  | succ i ih =>
    contrapose! ih;
    dsimp [construction] at ih;
    split at ih;
    . split_ifs at ih with h;
      . rename_i δ hδ;
        have := h ∅ (by tauto);
        contrapose! this;
        have : ξ = δ := by
          simp only [Set.mem_empty_iff_false, iff_false] at hδ;
          tauto
        subst this;
        apply T.mem_of_provable;
        simp; assumption;
      . assumption;
    . assumption;

lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra hφψ;
  replace ⟨hφψ, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφψ;
  have h3 := hφψ (Finset.mem_singleton φ) (by simp); contradiction;

lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L ⊢ φ ➝ ψ → φ ∈ U → ψ ∈ U := by
  rintro hφψ hφ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ψ) + 1;
  simp [construction];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain ⟨Γ, hΓ, h₁⟩ := h;
    have h₂ : (Γ.conj ⋏ φ) → (Γ.conj ⋏ ψ) ∈ T.theory := by
      apply T.L_subset;
      apply Logic.iff_provable.mp;
      apply CK_of_C_of_C;
      . exact impId;
      . apply af;
        exact Logic.iff_provable.mpr hφψ;
    have : (Γ.conj ⋏ φ) → ξ ∈ T.theory := T.mem_trans h₂ h₁;
    have h3 := this (Finset.mem_singleton (Γ.conj ⋏ φ)) (by simp); contradiction;

lemma construction_omega_L_subset :
  letI U := construction_omega T hT
  L ⊆ U := by
  intro φ hφ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode φ + 1);
  simp [construction, encodek];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain ⟨Γ, hΓ, h₁⟩ := h;
    have h₂ : (Γ.conj → (Γ.conj ⋏ φ)) ∈ T.theory := by
      apply T.L_subset;
      apply Logic.iff_provable.mp;
      apply I_of_C_of_C;
      . exact impId;
      . apply af;
        exact Logic.iff_provable.mpr hφ;
    have : (Γ.conj → ξ) ∈ T.theory := T.mem_trans h₂ h₁;
    have h3 := this (Finset.mem_singleton (Γ.conj)) (by simp); contradiction;
