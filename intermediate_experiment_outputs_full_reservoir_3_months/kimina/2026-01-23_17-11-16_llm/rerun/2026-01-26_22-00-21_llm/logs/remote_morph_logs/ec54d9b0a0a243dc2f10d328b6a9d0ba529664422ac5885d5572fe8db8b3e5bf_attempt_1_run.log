      assumption
    contradiction
  · -- Show that ∃ Γ, ↑Γ ⊆ construction T hT (encode φ) ∧ Γ.conj ⋏ φ → ξ ∈ T
    use (∅ : Finset (Formula ℕ))
    constructor
    · -- Show that ∅ is a subset of construction T hT (encode φ)
