  cases σ; simp_all

/-- Helper for Lemma 11 "iff (semantics of formulas and observation relation)" -/
lemma not_in_call_then_invariant_kv {a : @Agent n} {C : @Call n}
    (h : roleOfIn a C = Other) b S σ o
