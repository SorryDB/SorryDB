            have know_not_b : eval S ⟨C' :: σ', o⟩ (¬ (Kv a b)) := by
              rw [eval_dis]
              simp only [not_or, not_forall, Subtype.forall, not_exists, not_and, not_not, or_false] at *
              intro T τ same_len equ
              have CnoErr : Call := match C' with -- we remove the error from `C'` if needed.
                | ⌜d e⌝ => ⌜d e⌝
                | ⌜d^c e⌝ => ⌜d e⌝
                | ⌜d e^c⌝ => ⌜d e⌝
