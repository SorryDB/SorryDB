import Mathlib

/-- Definition of a call in the error model. -/
structure Call (n : ℕ) where
  -- The name of the function being called
  name : @Function n → Prop
  -- The arguments to the function
  args : List (@Function n → Prop)

/-- Definition of an agent in the error model. -/
structure Agent (n : ℕ) where
  -- The name of the agent
  name : @Agent n
  -- A list of calls the agent has made
  callHistory : List (Call n)
  -- The current goal the agent is working on
  currentGoal : @Goal n
  -- A list of facts the agent knows
  knownFacts : List (@Fact n)
  -- The current error state of the agent
  errorState : @Error n
  -- The current role of the agent (caller, callee, or other)
  role : @Role

/-- Definition of an observation sequence in the error model. -/
structure OSequence (n : ℕ) where
  -- The sequence of calls
  calls : List (Call n)
  -- The maximum index of a call in the sequence
  maxIndex : ℕ

/-- Definition of a distribution in the error model. -/
structure Dist (n : ℕ) where
  -- The distribution function
  distribution : ℕ → Fin n → Prop
  -- A list of facts associated with the distribution
  facts : List (@Fact n)
  -- The current error state of the distribution
  errorState : @Error n
  -- The maximum number of errors in the distribution
  maxErrors : ℕ

/-- Definition of a goal in the error model. -/
structure Goal (n : ℕ) where
  -- The proposition representing the goal
  proposition : Prop
  -- A list of facts associated with the goal
  facts : List (@Fact n)
  -- The current error state of the goal
  errorState : @Error n
  -- The maximum number of errors in the goal
  maxErrors : ℕ

/-- Definition of a fact in the error model. -/
structure Fact (n : ℕ) where
  -- The proposition representing the fact
  proposition : Prop
  -- The current error state of the fact
  errorState : @Error n
  -- The maximum number of errors in the fact
  maxErrors : ℕ

/-- Definition of an error in the error model. -/
structure Error (n : ℕ) where
  -- The type of error
  errorType : @ErrorType n
  -- The line number where the error occurred
  line : ℕ
  -- The file name where the error occurred
  file : String

/-- Error types. -/
inductive ErrorType (n : ℕ) where
  -- Call stack overflow
  callStackSizeExceeded : ℕ → Prop
  -- Maximum number of errors reached
  maxErrorCountExceeded : ℕ → Prop
  -- Attempt to call a non-existent function
  unknownFunction : @Function n → Prop
  -- Attempt to use a non-existent fact
  unknownFact : @Fact n → Prop
  -- Attempt to use a non-existent goal
  unknownGoal : @Goal n → Prop

/-- Lemma 7 -/
lemma indistinguishable_then_same_values {n} {a : @Agent n} {S T: @Dist n} {σ τ : OSequence} :
    (S, σ) ~_a (T, τ)  →  S⌈σ⌉a = T⌈τ⌉a := by
  rcases σ with ⟨σ,o⟩
  rcases τ with ⟨τ,o'⟩
  intro ⟨same_len, equ⟩
  induction σ generalizing τ o'
  case nil =>
    have := List.length_eq_zero_iff.mp same_len.symm
    aesop
