    case Caller => ...
    case Callee => ...
      have know_better_instantiated : (b, @S b) ∈ Error.resultSet n a S ⟨C :: σ, o⟩ ∧ (b, !@S b) ∉ Error.resultSet n a S ⟨C :: σ, o⟩ := by
