```tactics
lemma know_better {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, @S b) ∈ S⌈σ⌉a ∧ (b, !@S b) ∉ S⌈σ⌉a) := by
  intro a_know
  rcases σ with ⟨σ, o⟩
  induction σ with
  | nil =>
    unfold eval at a_know
    simp only [not_and_or, not_not] at a_know
    rcases a_know with h | h
    all_goals
      simp_all [eval]
      by_cases b = a
      · aesop
      · exfalso
        have := h S ⟨[], by simp [maxOne]⟩ (by simp)
        have := h (S.switch b) ⟨[], by simp [maxOne]⟩ (by simp) (by simp [Dist.switch]; all_goals simp)
        simp_all [Dist.switch]
  | cons C σ IH =>
    cases ra : roleOfIn a C
    · -- Caller case
      by_cases h : eval S ⟨σ, ⁻o⟩ (Kv a b)
      · -- If already know, then it's trivial
        specialize IH (⁻o) h
        unfold resultSet
        simp only [ra, callSemantics, Subtype.forall, OSequence.length_def]
        let C_copy := C
        cases C <;> simp_all <;> subst ra
        all_goals
          refine ⟨⟨?_, ?_⟩, ?_⟩
          · simp [eval, callSemantics, Subtype.forall, OSequence.length_def, not_forall, Bool.not_eq_not]
            use S
            simp only [and_true]
            use ⟨σ, ⁻o⟩
            simp
          · use S, ⟨σ, ⁻o⟩; simp; use C_copy; unfold C_copy; simp [roleOfIn]
          · intro not_in_callee not_a_knows T τ same_len equ C role_C same_contrib
            cases h_b : S b
            all_goals
              exfalso
              simp_all only [Bool.not_false, Bool.not_true, or_false, false_or]
              have := true_of_knowldege h
              simp_all
      · -- If not know before, then derive from after
        rw [eval_dis] at h
        push_neg at h
        rcases h with ⟨a_not_know_before_t, a_not_know_before_f⟩
        rw [eval_dis] at a_know
        rcases a_know with (a_knows_after_t | a_knows_after_f)
        · have := true_of_knowldege a_knows_after_t
          simp at this
          unfold resultSet
          cases C <;> simp [ra] <;> simp at ra <;> subst ra
          all_goals
            refine ⟨⟨?_, ?_⟩, ?_⟩
            · simp [eval, callSemantics, Subtype.forall, OSequence.length_def, not_forall, Bool.not_eq_not]
              use S
              simp only [and_true]
              use ⟨σ, ⁻o⟩
              simp
            · use S, ⟨σ, ⁻o⟩; simp; use C; unfold C; simp [maxOne, roleOfIn]
            · intro not_in_callee not_a_knows T τ same_len equ C role_C same_contrib
              cases h_b : S b
              all_goals
                simp_all
        · -- Contradiction if know after false
          exfalso
          have := true_of_knowldege a_knows_after_f
          simp_all
    · -- Callee case
      by_cases h : eval S ⟨σ, ⁻o⟩ (Kv a b)
      · -- If already know, then it's trivial
        specialize IH (⁻o) h
        unfold resultSet
        simp only [ra, callSemantics, Subtype.forall, OSequence.length_def]
        let C_copy := C
        cases C <;> simp_all <;> subst ra
        all_goals
          refine ⟨⟨?_, ?_⟩, ?_⟩
          · simp [eval, callSemantics, Subtype.forall, OSequence.length_def, not_forall, Bool.not_eq_not]
            use S
            simp only [and_true]
            use ⟨σ, ⁻o⟩
            simp
          · use S, ⟨σ, ⁻o⟩; simp; use C_copy; unfold C_copy; simp [roleOfIn]
          · intro not_in_callee not_a_knows T τ same_len equ C role_C same_contrib
            cases h_b : S b
            all_goals
              exfalso
              simp_all only [Bool.not_false, Bool.not_true, or_false, false_or]
              have := true_of_knowldege h
              simp_all
      · -- If not know before, then derive from after
        rw [eval_dis] at h
        push_neg at h
        rcases h with ⟨a_not_know_before_t, a_not_know_before_f⟩
        rw [eval_dis] at a_know
        rcases a_know with (a_knows_after_t | a_knows_after_f)
        · have := true_of_knowldege a_knows_after_t
          simp at this
          unfold resultSet
          cases C <;> simp [ra] <;> simp at ra <;> subst ra
          all_goals
            refine ⟨⟨?_, ?_⟩, ?_⟩
            · simp [eval, callSemantics, Subtype.forall, OSequence.length_def, not_forall, Bool.not_eq_not]
              use S
              simp only [and_true]
              use ⟨σ, ⁻o⟩
              simp
            · use S, ⟨σ, ⁻o⟩; simp; use C; unfold C; simp [maxOne, roleOfIn]
            · intro not_in_callee not_a_knows T τ same_len equ C role_C same_contrib
              cases h_b : S b
              all_goals
                simp_all
        · -- Contradiction if know after false
