              apply a_knows_after_f T ⟨CnoErr :: τ, ?_⟩ (by simp [OSequence.length]; exact same_len)
              · unfold equiv; simp [h, h', equ]
              · unfold CnoErr; cases C' <;> simp [maxOne]
            -- From know_not_b, prove the goal
            rw [not_in_call_then_invariant_resultSet (by simp_all)]
            have := true_of_knowldege know_not_b
            simp_all [eval]
            intro T τ same_len equ
            apply know_not_b T ⟨CnoErr :: τ, ?_⟩ (by simp [OSequence.length]; exact same_len)
            · unfold equiv; simp [h, h', equ]
            · unfold CnoErr; cases C' <;> simp [maxOne]
        exact h4
