          apply h T ⟨CnoErr :: τ, ?_⟩ (by simp [OSequence.length]; exact same_len)
          · unfold equiv; simp [h, h', equ]
          · unfold CnoErr; cases C' <;> simp [maxOne]
        have h4 : (b, @S b) ∈ Error.resultSet n a S ⟨C' :: σ', o⟩ ∧ (b, !@S b) ∉ Error.resultSet n a S ⟨C' :: σ', o⟩ := by
          rw [eval_dis] at a_kv_b
          rcases a_kv_b with (a_knows_after_t | a_knows_after_f)
          · -- This case is impossible because of h3
