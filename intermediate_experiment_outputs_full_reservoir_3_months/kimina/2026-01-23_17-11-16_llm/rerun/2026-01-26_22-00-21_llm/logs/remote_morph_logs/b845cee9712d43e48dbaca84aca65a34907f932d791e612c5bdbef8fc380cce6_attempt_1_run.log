        simp_all [Dist.switch]
  case cons C σ IH =>
    cases ra : roleOfIn a C
    case Caller =>
      unfold eval at a_kv_b ⊢
      simp_all only [Set.mem_insert_iff, Set.mem_singleton_iff, Set.mem_diff, and_imp]
    case Callee =>
