  rw [← @or_iff_not_and_not]
  cases h : S a
  · right
    unfold eval
    simp_rw [stubbornness]
    intro T ⟨τ, same_len⟩ equ
    rw [know_self _ _ _ _ _ equ] at h
    exact h
  · left
    unfold eval
    simp_rw [stubbornness]
    intro T ⟨τ, same_len⟩ equ
    rw [know_self _ _ _ _ _ equ] at h
    exact h

