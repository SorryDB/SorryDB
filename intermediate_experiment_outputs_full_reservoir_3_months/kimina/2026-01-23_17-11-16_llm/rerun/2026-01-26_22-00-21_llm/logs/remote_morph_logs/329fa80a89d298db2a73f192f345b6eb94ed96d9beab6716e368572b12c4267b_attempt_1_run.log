import Mathlib
import SpectralThm.toMathlib.Variation.Defs
import SpectralThm.toMathlib.Variation.Lemmas
import SpectralThm.ComplexMeasure.Integral

lemma eq_zero_of_integral_eq_zero {μ: ComplexMeasure X} (h : ∀ f : C₀(X, ℂ), μ.integral ⇑f = 0) :
    μ = 0 := by
  have h1 : ∀ f : C₀(X, ℝ), μ.re.integral ⇑f = 0 := by
    intro f
    have h2 := h (fun x => f x + 0 * Complex.I)
    have eq1 : μ.integral (fun x => f x + 0 * Complex.I) = μ.re.integral ⇑f := by
      simp [Complex.integral_add_im]
      <;> ring
    rw [eq1] at h2
    simp [Complex.ext_iff] at h2 ⊢
    linarith
  have h2 : ∀ f : C₀(X, ℝ), μ.im.integral ⇑f = 0 := by
    intro f
    have h3 := h (fun x => 0 + f x * Complex.I)
    have eq1 : μ.integral (fun x => 0 + f x * Complex.I) = μ.im.integral ⇑f := by
      simp [Complex.integral_add_im]
      <;> ring
    rw [eq1] at h3
    simp [Complex.ext_iff] at h3 ⊢
    linarith
  have h3 : μ.re = 0 := by
    apply eq_zero_of_integrals_eq_zero
    intro f
    exact h1 f
  have h4 : μ.im = 0 := by
    apply eq_zero_of_integrals_eq_zero
    intro f
    exact h2 f
  simp [ComplexMeasure.ext_iff, h3, h4]
  all_goals try tauto
```

