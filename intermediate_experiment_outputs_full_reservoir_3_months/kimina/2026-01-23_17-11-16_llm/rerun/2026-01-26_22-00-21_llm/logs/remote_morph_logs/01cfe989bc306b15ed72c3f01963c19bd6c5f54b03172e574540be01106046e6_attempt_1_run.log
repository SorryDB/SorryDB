    -- Need to show T' satisfies HasRestrictedWeakType and other properties
    sorry
    -- Apply weakly_cont_T with the constructed function
    have h1 := weakly_cont_T (LocallyIntegrable.of_ae_stronglyMeasurable (by aesop)) (by aesop) (by aesop) (by aesop) G
    -- This gives eLpNorm (T' g) 1 (ν.restrict G) ≤ Filter.limsup ...
    sorry
