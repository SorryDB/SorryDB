            SimpleFunc.coe_const, SimpleFunc.coe_zero, Set.piecewise_eq_indicator]
          symm
          calc _
            _ = ∫⁻ (t : ℝ≥0), (if t < a then μ s else distribution f (t - a) μ) ^ p.toReal⁻¹ := by
              congr with t
              rw [distribution_indicator_add_of_support_subset_nnreal (μ := μ) hfs]
