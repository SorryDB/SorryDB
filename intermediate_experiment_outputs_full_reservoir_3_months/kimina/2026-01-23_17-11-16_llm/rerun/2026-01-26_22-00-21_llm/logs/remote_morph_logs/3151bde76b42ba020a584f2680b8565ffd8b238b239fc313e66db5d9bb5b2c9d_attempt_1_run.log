import Mathlib

/-- A context-free derivation in a context-free grammar G.
    A derivation consists of a sequence of steps, starting from an initial word u and
    transforming it step-by-step into a final word v.
    Each step is a substitution of a variable from G's alphabet using a rule from G's
    production function. The derivation is represented as a list of derivation steps.
    Each step consists of the rule applied, the pre- and post-state words, and a proof that
    the rule application is valid according to the context-free derivation rules.

    A derivation is exhaustive if it uses all possible rules from G's production
    function at least once during the derivation process. -/
structure ContextFreeDerivation α nt (G : ContextFreeGrammar α nt) (u v : Word (G.V ⊕ G.Z))
  -- This is the list of steps in the derivation.
  -- Each step is represented by the rule applied, the pre-state word, the post-state word,
  -- and a proof that the rule application is valid.
