import Mathlib
open Finset

/--A derivation step in a context-free derivation is represented by a substitution
  applied to a specific location within the current word. This substitution is
  defined by a production rule from the context-free grammar.

  The step is characterized by:
  - The specific location within the current word where the substitution is applied
  - The production rule that defines the substitution
  - A proof that this substitution is valid according to the grammar

  The structure of the step is:
  ```tactics
  structure ContextFreeDerivationStep {G : ContextFreeGrammar α nt}
    (u : Word (G.V ⊕ G.Z)) :
    structure {
      -- The position in the word where the substitution occurs
      -- This is the index of the symbol to be replaced.
      -- This is specified by the `pos` field of the `match` expression
      -- which corresponds to the `pos` in the `match` statement.
      pos : Finset.range (u.length),
      -- The production rule used for the substitution
      prod : G.productions,
      -- A proof that the substitution is valid
      sound : u[pos] ∈ G.Z ∨ u[pos] ∈ G.V
    }
  ```
  The specific fields in the `match` statement define how the substitution is performed.
  The `prod` field is a `G.production` which is a pair `(lhs, rhs)` where `lhs` is the left-hand side
  (a non-terminal symbol) and `rhs` is the right-hand side (a sequence of terminal and non-terminal symbols).

  The `pos` field is a `Finset.range (u.length)` which means it's an index into the current word `u`.
  The `sound` field is a proof that the symbol at `pos` is either a terminal (`∈ G.Z`) or a non-terminal (`∈ G.V`), ensuring
  that the substitution is valid according to the grammar's rules.

  The derivation step transforms the current word by replacing the symbol at `pos` with the sequence `rhs`.
  The new word becomes `u[0..pos] ++ rhs ++ u[pos+1..end]`.
  This operation effectively increases the length of the word by the length of `rhs` minus one.
  The `sound` proof ensures that the substitution is valid at that position.

/--Theorem: Children (i.e. next steps) of exhaustive CFDs are exhaustive.-/
theorem ContextFreeDerivation.exhaustive_imp_child_exhaustive
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition) :
  ∀ u' : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }),
  ∀ step : ContextFreeDerivationStep G u,
  ∀ derivation : ContextFreeDerivation G u' v,
  ∀ sound : _,
  cfd = ContextFreeDerivation.step step derivation sound →
  derivation.exhaustiveCondition := by
    match cfd with
    | .same h_same =>
      intro u' step derivation sound
      rw [imp_iff_not_or]
      apply Or.inl
      tauto
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound =>
      intro u' step derivation sound h_constructor
      rw [exhaustiveCondition]
      rw [h_constructor, exhaustiveCondition] at h_exhaustive
      exact h_exhaustive

/--Collect the DerivationTree Nodes. Each node in the list
  corresponds to exactly one variable in u and each variable in
  u has a returned DerivationTree node. Cannot be called for 0-step
  derivations.

