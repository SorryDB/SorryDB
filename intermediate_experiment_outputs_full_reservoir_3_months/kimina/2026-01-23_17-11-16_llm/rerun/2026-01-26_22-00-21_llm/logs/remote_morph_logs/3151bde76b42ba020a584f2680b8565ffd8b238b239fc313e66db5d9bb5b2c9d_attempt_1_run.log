```lean
import Mathlib

open Finset

/- A derivation step is a pair (A, B), where A is the left-hand side (LHS)
and B is the right-hand side (RHS) of a rewrite rule.
Specifically, LHS is a single non-terminal symbol, and RHS is a word of terminal
and non-terminal symbols. This corresponds to a rule like `X → Y` where Y can be `a b c` or `X Z` etc.
The function `length` computes the length of the RHS. A derivation step is valid
if the LHS is a non-terminal symbol in the context-free grammar. -/
def ContextFreeDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt) (u : Word (G.V ⊕ G.Z))
    (v : Word (G.V ⊕ G.Z)) : Type := @Prod α (α ⊕ α) G u v
abbrev (@ContextFreeDerivationStep α nt G u v).lhs : α := Prod.fst
abbrev (@ContextFreeDerivationStep α nt G u v).rhs : α ⊕ α := Prod.snd

/- A derivation step is sound if the LHS is a non-terminal symbol in the context-free
grammar. This is automatically satisfied in our construction. -/
def isSoundDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  dstep.lhs ∈ G.NT

/- A derivation step is valid if the LHS is a non-terminal symbol in the context-free
grammar. This is automatically satisfied in our construction. -/
abbrev validDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop := isSoundDerivationStep α nt G dstep

/- A derivation step is non-empty if the RHS is non-empty. -/
abbrev nonEmptyDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  dstep.rhs ≠ ε

/- A derivation step is a reduction step if the RHS is shorter than the LHS. -/
abbrev isReductionStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  length dstep < length dstep.lhs

/- A derivation step is an expansion step if the RHS is longer than the LHS. -/
abbrev isExpansionStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  length dstep > length dstep.lhs

/- A derivation step is a same-step if the RHS is equal in length to the LHS. -/
abbrev isSameStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  length dstep = length dstep.lhs

/- The length of a derivation step's RHS. -/
abbrev length (dstep : ContextFreeDerivationStep α nt G u v) : ℕ :=
  (dstep.rhs).length

/- A derivation step is basic if its RHS is a single terminal symbol. -/
abbrev isBasicDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first

/- A derivation step is atomic if its RHS is a single non-terminal symbol. -/
abbrev isAtomicDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first ∧
    (dstep.rhs).first ∈ G.NT

/- A derivation step is a terminal step if its RHS is a single terminal symbol. -/
abbrev isTerminalDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first ∧
    (dstep.rhs).first ∉ G.NT

/- A derivation step is a non-terminal step if its RHS is a single non-terminal symbol. -/
abbrev isNonterminalDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first ∧
    (dstep.rhs).first ∈ G.NT

/- A derivation step is a compound step if its RHS is longer than one symbol. -/
abbrev isCompoundDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs.length > 1

/- A derivation step is a binary step if its RHS consists of two symbols. -/
abbrev isBinaryDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs.length = 2

/- A derivation step is a right-associative step if the RHS starts with a non-terminal
symbol. -/
abbrev isRightAssociativeDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first :: dstep.rhs.tail

/- A derivation step is a left-associative step if the RHS starts with a terminal
symbol. -/
abbrev isLeftAssociativeDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first :: dstep.rhs.tail ∧
    (dstep.rhs).first ∉ G.NT

/- A derivation step is a right-unary step if the RHS is a single non-terminal
symbol. -/
abbrev isRightUnaryDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first

/- A derivation step is a left-unary step if the RHS is a single terminal
symbol. -/
abbrev isLeftUnaryDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first ∧
    (dstep.rhs).first ∉ G.NT

/- A derivation step is a right-binary step if the RHS has two non-terminal
symbols. -/
abbrev isRightBinaryDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs.length = 2 ∧
    (dstep.rhs).first ∈ G.NT ∧ (dstep.rhs).get (1 : Fin 2) ∈ G.NT

/- A derivation step is a left-binary step if the RHS has two terminal
symbols. -/
abbrev isLeftBinaryDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs.length = 2 ∧
    (dstep.rhs).first ∉ G.NT ∧ (dstep.rhs).get (1 : Fin 2) ∉ G.NT

/- A derivation step is a right-nary step if the RHS has more than two symbols. -/
abbrev isRightNaryDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs.length > 2

/- A derivation step is a left-nary step if the RHS has more than two symbols. -/
abbrev isLeftNaryDerivationStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs.length > 2 ∧
    (dstep.rhs).first ∉ G.NT ∧ (dstep.rhs).get (1 : Fin 2) ∉ G.NT

/- A derivation step is a root step if the LHS is the start variable of the
context-free grammar. -/
abbrev isRootStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  dstep.lhs = G.S

/- A derivation step is a final step if the RHS is the empty word. -/
abbrev isFinalStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  dstep.rhs = ε

/- A derivation step is a terminal step if the RHS is a single terminal symbol. -/
abbrev isTerminalStep (α : Type) (nt : Type) (G : ContextFreeGrammar α nt)
    (dstep : ContextFreeDerivationStep α nt G u v) : Prop :=
  isSoundDerivationStep α nt G dstep ∧ dstep.rhs = (dstep.rhs).first ∧
    (dstep.rhs).first ∉ G.NT

