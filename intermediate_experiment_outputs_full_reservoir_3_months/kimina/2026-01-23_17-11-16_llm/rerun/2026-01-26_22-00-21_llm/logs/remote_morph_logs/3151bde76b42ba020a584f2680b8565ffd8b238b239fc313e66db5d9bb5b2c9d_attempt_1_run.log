import Mathlib

/- A context-free derivation (CFD) is a sequence of rewriting steps
  starting from a given word u and transforming it into a word v.
  Each step is performed by a context-free derivation rule.
  The derivation proceeds by building a derivation tree, where each node
  represents a step in the derivation. The exhaustive condition ensures
  that the derivation process is complete, i.e., no further derivations
  are possible from the current state.
  This theorem states that if a derivation step is exhaustive, then
  any further derivations from that step are also exhaustive. -/
theorem ContextFreeDerivation.exhaustive_imp_child_exhaustive
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition) :
  ∀ u' : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }),
  ∀ step : ContextFreeDerivationStep G u,
  ∀ derivation : ContextFreeDerivation G u' v,
  ∀ sound : _,
  cfd = ContextFreeDerivation.step step derivation sound →
  derivation.exhaustiveCondition := by
    match cfd with
    | .same h_same =>
      intro u' step derivation sound
      rw [imp_iff_not_or]
      apply Or.inl
      tauto
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound =>
      intro u' step derivation sound h_constructor
      rw [exhaustiveCondition]
      rw [h_constructor, exhaustiveCondition] at h_exhaustive
      exact h_exhaustive

