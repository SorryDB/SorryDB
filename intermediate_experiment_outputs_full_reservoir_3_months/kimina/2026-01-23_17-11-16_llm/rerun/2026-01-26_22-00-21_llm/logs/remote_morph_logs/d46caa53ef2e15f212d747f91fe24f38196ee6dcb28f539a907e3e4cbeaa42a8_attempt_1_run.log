theorem φ₀''_holo : Holo(φ₀'') := by
  apply Holo.div
  · -- Show that 1 is holomorphic
    exact differentiableOn_const 1
  · -- Show that z + 1 is holomorphic
    apply DifferentiableOn.add
    · exact differentiableOn_id
    · exact differentiableOn_const 1
  · -- Show that z + 1 ≠ 0 on ℍ₀
    intro z hz
    by_contra h
    have h1 : z.im > 0 := by
      simpa using hz
    have h2 : z.im = 0 := by
      have h_eq : z + 1 = 0 := h
      have him := congr_arg Complex.im h_eq
      simp [Complex.add_im, Complex.ofReal_im] at him
      linarith
    linarith

