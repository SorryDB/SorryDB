  have h1 : DifferentiableOn ℝ (fun z : ℂ ↦ z.re) ℍ₀ := by
    apply differentiableOn_id.re
  have h2 : DifferentiableOn ℝ (fun z : ℂ ↦ z.im) ℍ₀ := by
    apply differentiableOn_id.im
  have h3 : DifferentiableOn ℝ (fun z : ℂ ↦ z.re + z.im) ℍ₀ := by
    apply DifferentiableOn.add h1 h2
  have h4 : DifferentiableOn ℝ (fun z : ℂ ↦ z.re * z.im) ℍ₀ := by
    apply DifferentiableOn.mul h1 h2
  have h5 : DifferentiableOn ℝ (fun z : ℂ ↦ z.re ^ 2 - z.im ^ 2) ℍ₀ := by
    apply DifferentiableOn.sub (DifferentiableOn.pow h1 2) (DifferentiableOn.pow h2 2)
  have h6 : DifferentiableOn ℝ (fun z : ℂ ↦ 2 * z.re * z.im) ℍ₀ := by
    apply DifferentiableOn.const_mul (2 : ℝ) (DifferentiableOn.mul h1 h2)
  have h7 : DifferentiableOn ℝ (fun z : ℂ ↦ z.re ^ 2 + z.im ^ 2) ℍ₀ := by
    apply DifferentiableOn.add (DifferentiableOn.pow h1 2) (DifferentiableOn.pow h2 2)
  have h8 : DifferentiableOn ℝ (fun z : ℂ ↦ z.re / (z.re ^ 2 + z.im ^ 2)) ℍ₀ := by
    apply DifferentiableOn.div h1 h7
    · -- Show that the denominator is non-zero
      intro z hz hcontra
      have hdenom : z.re ^ 2 + z.im ^ 2 = 0 := by
        rw [hcontra]
        norm_num
      have hzre : z.re = 0 := by nlinarith [sq_nonneg z.re, sq_nonneg z.im]
      have hzim : z.im = 0 := by nlinarith [sq_nonneg z.re, sq_nonneg z.im]
      have hz' : z = (0 : ℂ) := by
        simp [Complex.ext_iff, hzre, hzim]
      rw [mem_setOf_eq] at hz
      rw [hz'] at hz
      contradiction
  have h9 : DifferentiableOn ℝ (fun z : ℂ ↦ z.im / (z.re ^ 2 + z.im ^ 2)) ℍ₀ := by
    apply DifferentiableOn.div h2 h7
    · -- Show that the denominator is non-zero
      intro z hz hcontra
      have hdenom : z.re ^ 2 + z.im ^ 2 = 0 := by
        rw [hcontra]
        norm_num
      have hzre : z.re = 0 := by nlinarith [sq_nonneg z.re, sq_nonneg z.im]
      have hzim : z.im = 0 := by nlinarith [sq_nonneg z.re, sq_nonneg z.im]
      have hz' : z = (0 : ℂ) := by
        simp [Complex.ext_iff, hzre, hzim]
      rw [mem_setOf_eq] at hz
      rw [hz'] at hz
      contradiction
  -- Now construct Φ₄' using these components
  apply DifferentiableOn.mul h3 h4 -- This is Φ₄' r = (z.re + z.im) * (z.re * z.im)
