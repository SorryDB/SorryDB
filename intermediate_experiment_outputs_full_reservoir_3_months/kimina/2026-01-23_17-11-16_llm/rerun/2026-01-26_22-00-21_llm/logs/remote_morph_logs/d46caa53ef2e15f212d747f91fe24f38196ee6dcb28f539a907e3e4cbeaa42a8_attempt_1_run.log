/-! # Real Differentiability -/

theorem Φ₁'_contDiffOn : ContDiffOn ℝ ∞ (Φ₁' r) ℍ₀ := by
  have h1 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z + 1 : ℂ)) ℍ₀ := by
    apply DifferentiableOn.add
    · apply DifferentiableOn.div
      · exact differentiableOn_const (-1 : ℂ)
      · exact differentiableOn_id
      · intro z hz
        simp only [mem_upperHalfPlaneSet] at hz
        have hz' : z ≠ 0 := by
          by_contra h
          rw [h] at hz
          norm_num at hz
        exact hz'
    · exact differentiableOn_const 1
  have h2 : DifferentiableOn ℝ (fun z : ℂ => z) ℍ₀ := by
    exact differentiableOn_id
  have h3 : DifferentiableOn ℝ (fun z : ℂ => (z : ℂ) ^ 2) ℍ₀ := by
    apply DifferentiableOn.pow
    exact differentiableOn_id
  have h4 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z + 1 : ℂ) ^ 2) ℍ₀ := by
    apply DifferentiableOn.pow
    exact h1
  have h5 : DifferentiableOn ℝ (fun z : ℂ => (z : ℂ) * ((-1 / z + 1 : ℂ) ^ 2 : ℂ)) ℍ₀ := by
    apply DifferentiableOn.mul
    · exact h2
    · exact h4
  exact h5.contDiffOn

theorem Φ₂'_contDiffOn : ContDiffOn ℝ ∞ (Φ₂' r) ℍ₀ := by
  have h1 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z - 1 : ℂ)) ℍ₀ := by
    apply DifferentiableOn.sub
    · apply DifferentiableOn.div
      · exact differentiableOn_const (-1 : ℂ)
      · exact differentiableOn_id
      · intro z hz
        simp only [mem_upperHalfPlaneSet] at hz
        have hz' : z ≠ 0 := by
          by_contra h
          rw [h] at hz
          norm_num at hz
        exact hz'
    · exact differentiableOn_const 1
  have h2 : DifferentiableOn ℝ (fun z : ℂ => z) ℍ₀ := by
    exact differentiableOn_id
  have h3 : DifferentiableOn ℝ (fun z : ℂ => (z : ℂ) ^ 2) ℍ₀ := by
    apply DifferentiableOn.pow
    exact differentiableOn_id
  have h4 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z - 1 : ℂ) ^ 2) ℍ₀ := by
    apply DifferentiableOn.pow
    exact h1
  have h5 : DifferentiableOn ℝ (fun z : ℂ => (z : ℂ) * ((-1 / z - 1 : ℂ) ^ 2 : ℂ)) ℍ₀ := by
