theorem Φ₄'_contDiffOn : ContDiffOn ℝ ∞ (Φ₄' r) ℍ₀ := by
  have h1 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z)) ℍ₀ := by
    apply DifferentiableOn.div
    · exact differentiableOn_const (-1 : ℂ)
    · exact differentiableOn_id
    · intro z hz
      simp only [mem_upperHalfPlaneSet] at hz
      have hz' : z ≠ 0 := by
        by_contra h
        rw [h] at hz
        norm_num at hz
      exact hz'
  have h2 : DifferentiableOn ℝ (fun z : ℂ => r * z + 1) ℍ₀ := by
    apply DifferentiableOn.add
    · apply DifferentiableOn.const_mul
      exact differentiableOn_id
    · exact differentiableOn_const 1
  have h3 : DifferentiableOn ℝ (fun z : ℂ => z) ℍ₀ := by
    exact differentiableOn_id
  have h4 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z)) ℍ₀ := h1
  have h5 : DifferentiableOn ℝ (fun z : ℂ => r * z + 1) ℍ₀ := h2
  have h6 : DifferentiableOn ℝ (fun z : ℂ => z) ℍ₀ := h3
  have h7 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z) * (r * z + 1) ^ 2) ℍ₀ := by
    apply DifferentiableOn.mul
    · exact h4
    · apply DifferentiableOn.pow
      exact h5
  exact h7.contDiffOn
