  have h4 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z)) ℍ₀ := h1
  have h5 : DifferentiableOn ℝ (fun z : ℂ => r * z + 1) ℍ₀ := h2
  have h6 : DifferentiableOn ℝ (fun z : ℂ => z) ℍ₀ := h3
  have h7 : DifferentiableOn ℝ (fun z : ℂ => (-1 / z) * (r * z + 1) ^ 2) ℍ₀ := by
    apply DifferentiableOn.mul
    · exact h4
    · apply DifferentiableOn.pow
      exact h5
  exact h7.contDiffOn
