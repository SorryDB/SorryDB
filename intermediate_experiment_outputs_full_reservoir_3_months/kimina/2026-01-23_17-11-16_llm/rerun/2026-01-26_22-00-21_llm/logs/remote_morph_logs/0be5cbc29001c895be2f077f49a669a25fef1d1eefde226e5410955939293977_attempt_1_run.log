        all_goals
          refine ⟨⟨?_, ?_⟩, ?_⟩ -- Prove the conjunction
          · simp only [eval, stubbornness, Subtype.forall, OSequence.length_def, not_forall, not_and, not_not, iff_false] at * -- Simplify goal and hypotheses
            use S -- Provide S as witness for the existential quantifier
            simp only [and_true] at * -- Simplify conjunction with true
            use ⟨σ,⁻o⟩ -- Provide ⟨σ,⁻o⟩ as witness for the existential quantifier
