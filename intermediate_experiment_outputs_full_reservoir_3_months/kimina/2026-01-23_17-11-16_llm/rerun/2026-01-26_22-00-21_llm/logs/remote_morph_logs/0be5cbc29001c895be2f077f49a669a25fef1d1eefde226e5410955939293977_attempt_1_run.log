      have h' : roleOfIn a CnoErr = Other := by unfold CnoErr; cases C <;> simp_all -- Prove role is 'Other'
      apply h T ⟨CnoErr :: τ, ?_⟩ (by simp [OSequence.length]; exact same_len) -- Apply hypothesis h
      · unfold equiv; simp [h', h, equ] -- Simplify equivalence
      · unfold CnoErr; cases C <;> simp [maxOne] -- Simplify call construction
