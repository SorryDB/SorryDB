namespace Error
open Error

-- Error type for calls, sequences, and agents.
structure Call (n : ℕ) where
  d e : ℕ
  _ : d < n ∧ e < n

structure OSequence (n : ℕ) where
  l : List (Call n)
  _ : ∀ x ∈ l, x.1 < n ∧ x.2 < n

structure Agent (n : ℕ) where
  id : ℕ
  _ : id < n

structure Dist (n : ℕ) where
  map : ℕ → Prop
  _ : ∀ x < n, ∃ y < n, map x y

structure ResultSet (n : ℕ) where
  set : Set (ℕ × ℕ)
  _ : ∀ p ∈ set, p.1 < n ∧ p.2 < n

structure Form (n : ℕ) where
  k : ℕ
  _ : k < n

structure Has (n : ℕ) where
  b : ℕ
  _ : b < n

structure K (n : ℕ) where
  a : ℕ
  _ : a < n
  form : Form n
  _ : form < n

structure Eq (n : ℕ) where
  a b : ℕ
  _ : a < n ∧ b < n

