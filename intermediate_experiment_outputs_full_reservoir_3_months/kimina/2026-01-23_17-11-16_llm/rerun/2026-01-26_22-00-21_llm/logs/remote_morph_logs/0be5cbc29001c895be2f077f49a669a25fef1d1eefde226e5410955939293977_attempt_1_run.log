        simp at this
        simp_all only [eval, Subtype.coe, and_true, and_false, or_true, or_false, 
          iff_true, iff_false, true_and, true_or, iff_self, iff_false]
        <;> try { aesop }
  case Callee =>
    by_cases h : eval S ⟨σ, ⁻o⟩ (Kv a b)
    · specialize IH (⁻o) h
