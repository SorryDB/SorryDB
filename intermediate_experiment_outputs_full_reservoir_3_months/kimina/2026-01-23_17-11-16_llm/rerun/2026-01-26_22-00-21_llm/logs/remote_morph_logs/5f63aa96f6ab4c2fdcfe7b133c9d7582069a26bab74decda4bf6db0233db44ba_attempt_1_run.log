  apply_fun (· % 4) at h
  simp [mul_assoc, Int.add_emod] at h

/-- The subset of `S k` where `z` is positive. -/
def T : Set (S k) := {⟨(_, _, z), _⟩ : S k |  z > 0}

noncomputable instance : Fintype <| T k := by
