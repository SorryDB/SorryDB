    simp [stoppedValue]
  have h6 : X (τ i) ≤ X n := by
    apply hX.sub (by 
      have h7 : (τ i) ≤ n := h4
      exact h7
    ) (by 
      have h7 : (τ i) ≤ n := h4
      exact h7
    )
  linarith [h5, h6]
```

