open scoped NNReal ENNReal
open Filter

variable {ι κ Ω E F : Type*} {mΩ : MeasurableSpace Ω} {μ : Measure Ω}

lemma Submartingale.ae_le_of_le {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ} {n : ι} {τ : Ω → WithTop ι}
    (hτ : IsStoppingTime 𝓕 τ) (hτ_le : τ ≤ n) :
    X τ ≤ X n := by
  have hτ' : IsStoppingTime 𝓕 τ := hτ
  have hτ_le' : τ ≤ n := hτ_le
  have h : ∀ ω, X (τ ω) ≤ X n := by
    intro ω
    have h1 : τ ω ≤ n := hτ_le' ω
    have h2 : (τ ω : ι) ≤ n := by exact_mod_cast h1
    have h3 : X (τ ω) ≤ X n := by
      apply hτ'.submartingale_ae_le_of_le 
      exact_mod_cast h2
    simpa using h3
  simpa using h

lemma Submartingale.uniformIntegrable_stoppedValue {X : ι → Ω → ℝ} {𝓕 : Filtration ι mΩ}
    [SigmaFiniteFiltration μ 𝓕]
    (hX : Submartingale X 𝓕 μ) (τ : ℕ → Ω → WithTop ι) (hτ : ∀ i, IsStoppingTime 𝓕 (τ i))
    {n : ι} (hτ_le : ∀ i ω, τ i ω ≤ n) :
    UniformIntegrable (fun i ↦ stoppedValue X (τ i)) 1 μ := by
  have h1 : ∀ i, IsMeasurable (fun ω ↦ stoppedValue X (τ i) ω) := by
    intro i
    apply stoppedValue_isMeasurable
  have h2 : ∀ i, Integrable (fun ω ↦ stoppedValue X (τ i) ω) 1 μ := by
    intro i
    have h3 : ∀ ω, stoppedValue X (τ i) ω ≤ X n := by
      intro ω
      have h4 : τ i ω ≤ n := hτ_le i ω
      have h5 : (τ i ω : ι) ≤ n := by exact_mod_cast h4
      have h6 : X (τ i ω) ≤ X n := by
        apply hX.submartingale_ae_le_of_le 
        exact_mod_cast h5
      simpa using h6
    have h7 : Integrable (fun ω ↦ X n) 1 μ := by
      apply hX.integrable
    have h8 : Integrable (fun ω ↦ stoppedValue X (τ i) ω) 1 μ := by
      apply Integrable.of_nonneg_of_le 
      · -- Show that stoppedValue X (τ i) is non-negative
        intro ω
        have h9 : stoppedValue X (τ i) ω ≥ 0 := by
          have h10 : X (τ i ω) ≥ 0 := by
            apply hX.nonneg
          simpa using h10
        simpa using h9
      · -- Show that stoppedValue X (τ i) is integrable
        apply h7.le_integrable
        fun_prop
    exact h8
  exact ⟨fun _ ↦ h1 _, fun _ ↦ h2 _⟩
