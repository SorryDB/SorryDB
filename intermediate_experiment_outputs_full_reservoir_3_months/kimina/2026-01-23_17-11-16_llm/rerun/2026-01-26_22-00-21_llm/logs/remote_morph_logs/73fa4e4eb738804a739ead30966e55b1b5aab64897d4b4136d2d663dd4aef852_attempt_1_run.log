  have eq52 : ∂ₜ x 0 = (deriv (fun (t : Time) => cos (S.ω * t) • IC.x₀ + (sin (S.ω * t) / S.ω) • IC.v₀) t) 0 := by
    have eq53 : ∂ₜ x 0 = IC.v₀ := h_ic_vel
    have eq54 : deriv (fun (t : Time) => cos (S.ω * t) • IC.x₀ + (sin (S.ω * t) / S.ω) • IC.v₀) 0 = IC.v₀ := by
      simp [deriv_add, deriv_mul, deriv_id'', mul_comm]
      <;> field_simp [S.ω_neq_zero]
      <;> ring_nf
      <;> simp [sin_zero, cos_zero]
      <;> ring
    linarith
```

Now, we can use the uniqueness of the solution to the ODE. Since $x(t)$ and the given function both satisfy the ODE $\ddot{y} + \omega^2 y = 0$, and they have the same initial conditions $y(0) = 0$ and $\dot{y}(0) = 0$, so they must be equal.

