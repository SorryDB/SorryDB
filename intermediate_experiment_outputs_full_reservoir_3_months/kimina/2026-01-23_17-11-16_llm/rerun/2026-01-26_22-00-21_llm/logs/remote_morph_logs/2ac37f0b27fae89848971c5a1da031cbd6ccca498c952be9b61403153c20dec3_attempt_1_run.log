import Mathlib

/-- A `Factorization` of a natural number `n` is a function `ℕ → ℕ` such that the sum of
the factorization `f` is `n`. -/
structure Factorization (n : ℕ) where
  a : Multiset ℕ
  ha : ∀ m ∈ a, m ≥ 2
  hpos : ∀ m ∈ a, m > 0
  sum : a.sum = n

/-- The `p`-adic valuation of a `Factorization` `f` is the sum of the factorization of
`f`'s elements with respect to `p`. -/
noncomputable def balance (f : Factorization n) (p : ℕ) :=
  (f.a.map (fun m ↦ (m.factorization p : ℤ))).sum

/-- The `p`-adic valuation of `n!` is the number of factors of `p` in `n!`. -/
noncomputable def factorial_factorization (n p : ℕ) :=
  (Nat.factorial n).factorization p

/-- The `score` of a `Factorization` `f` with respect to a bound `L` is defined as the
total waste of `f` if `f` has a prime in surplus, and the total waste of the `L`-truncated
version of `f` if all primes in `f` are in balance or in deficit up to `L`. -/
noncomputable def score (f : Factorization n) (L : ℕ) :=
  if f.total_imbalance > 0 then f.waste else f.wasteL L

/-- The `total_imbalance` of a `Factorization` `f` is the difference between the sum of
`p`-adic valuations for primes `p > n / L` and the number of such primes, weighted by their
logarithms. -/
noncomputable def total_imbalance (f : Factorization n) (L : ℕ) :=
  ∑ p ∈ (n + 1).primesBelow, if p ≤ L then 0 else (f.balance p : ℝ) * Real.log p

/-- The `waste` of a `Factorization` `f` is the sum of the `p`-adic valuations for primes `p`
that divide `n!` but not `f`'s elements, weighted by their logarithms. -/
noncomputable def waste (f : Factorization n) :=
  ∑ p ∈ (n.factorization.support : Multiset ℕ), if p ∣ n.factorization.support.sum then
    (n.factorization p - f.balance p : ℝ) * Real.log p else 0

/-- The `wasteL` of a `Factorization` `f` with respect to a bound `L` is similar to `waste`, but
only considers primes up to `L`. -/
noncomputable def wasteL (f : Factorization n) (L : ℕ) :=
  ∑ p ∈ (L + 1).primesBelow, if p ∣ n.factorization.support.sum then
    (n.factorization p - f.balance p : ℝ) * Real.log p else 0

/-- The `a` field of a `Factorization` `f` is the set of prime factors of `n` whose power in
`n`'s prime factorization is greater than their power in `f`'s prime factorization. -/
noncomputable def Factorization.a (f : Factorization n) :=
  (n.factorization.support.filter (fun p ↦ n.factorization p > f.factorization p))

/-- The `ha` condition ensures that elements in `a` are at least 2, which is true for prime
factors. -/
noncomputable def Factorization.ha (f : Factorization n) := fun p hp ↦ by
  have h1 : p ∈ n.factorization.support := by simp_all [Multiset.mem_filter]
  have h2 : p.Prime := by exact Nat.prime_of_mem_support h1
  exact h2.two_le

/-- The `hpos` condition ensures that elements in `a` are positive, which is true for prime
factors. -/
noncomputable def Factorization.hpos (f : Factorization n) := fun p hp ↦ by
  have h1 : p ∈ n.factorization.support := by simp_all [Multiset.mem_filter]
  have h2 : p.Prime := by exact Nat.prime_of_mem_support h1
  exact h2.pos

/-- The `total_imbalance` of a `Factorization` `f` is the difference between the sum of
`p`-adic valuations for primes `p > n / L` and the number of such primes, weighted by their
logarithms. -/
noncomputable def total_imbalance (f : Factorization n) (L : ℕ) :=
  ∑ p ∈ (n + 1).primesBelow, if p ≤ L then 0 else (f.balance p : ℝ) * Real.log p

/-- The `waste` of a `Factorization` `f` is the sum of the `p`-adic valuations for primes `p`
that divide `n!` but not `f`'s elements, weighted by their logarithms. -/
noncomputable def waste (f : Factorization n) :=
  ∑ p ∈ (n.factorization.support : Multiset ℕ), if p ∣ n.factorization.support.sum then
    (n.factorization p - f.balance p : ℝ) * Real.log p else 0

/-- The `wasteL` of a `Factorization` `f` with respect to a bound `L` is similar to `waste`, but
only considers primes up to `L`. -/
noncomputable def wasteL (f : Factorization n) (L : ℕ) :=
