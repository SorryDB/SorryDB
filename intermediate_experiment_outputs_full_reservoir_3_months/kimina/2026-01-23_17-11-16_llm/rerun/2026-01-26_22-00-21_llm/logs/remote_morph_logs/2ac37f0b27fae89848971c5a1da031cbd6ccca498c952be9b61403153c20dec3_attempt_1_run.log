  have h5 : (Real.sqrt P.n : ℝ) < (p : ℝ) := by exact_mod_cast hp'
  have h6 : (Real.sqrt P.n : ℝ) ^ 2 < (p : ℝ) ^ 2 := by nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sqrt_nonneg (P.n : ℝ)]
  have h7 : (Real.sqrt P.n : ℝ) ^ 2 = (P.n : ℝ) := by
