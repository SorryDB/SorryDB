import Mathlib
open Real
open scoped BigOperators

/- Type class for real numbers with a rounding operation.
  This is used in the definition of RCLike.
  The rounding operation maps real numbers to real numbers.
  It must satisfy the following properties:
  1. round x = ⌊x + 1/2⌋
  2. round (x + n) = round x + n for n an integer
  3. round (round x) = round x
  4. round x is an integer
  5. round x ≥ x
  6. round x - x ≤ 1/2
  7. round x - round y ≤ |x - y|  -/
class Rounding (R : Type u_1) extends AddGroupWithOne R where
  round : R → R
  properties :
    round_eq_floor_add_half : ∀ x : R, round x = ⌊x + (1 : R) / 2⌋
    round_add_int : ∀ x : R ∀ (n : ℤ), round (x + n) = round x + n
    round_idempotent : ∀ x : R, round (round x) = round x
    round_is_int : ∀ x : R, ∃ n : ℤ, round x = n
    round_ge : ∀ x : R, round x ≥ x
    round_sub : ∀ x y : R, round x - round y ≤ |x - y|


/- Type class for real numbers with a rounding operation that satisfies the properties
  of the standard rounding function on real numbers.
 
