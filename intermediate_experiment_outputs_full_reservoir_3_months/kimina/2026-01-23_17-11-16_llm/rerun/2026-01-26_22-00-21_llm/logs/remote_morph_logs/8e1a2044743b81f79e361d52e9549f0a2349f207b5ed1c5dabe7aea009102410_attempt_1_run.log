  :
  ∀ (f : α → 𝕂), (f : α → 𝕂) → ∀ (G : Set α'), (MeasurableSet G) → (ν G < ∞) →
    eLpNorm (T f) 1 (ν.restrict G) ≤ (4 * c / p) * eLorentzNorm f p 1 μ * ν G ^ p'⁻¹.toReal := by
  intro f hf
  have claim : ∀ (G : Set α'), (MeasurableSet G) → (ν G < ∞) →
    eLpNorm (T f) 1 (ν.restrict G) ≤ (4 * c / p) * eLorentzNorm f p 1 μ * ν G ^ p'⁻¹.toReal := by
    intro G measurable_G G_finite
    rcases hf with ⟨aemeasurable_f, hf⟩
    have hf' : aemeasurable_f := by
      simpa using aemeasurable_f
    have h1 := hT.hasLorentzType_helper c_pos hT hpp' T_meas T_subadd T_submul weakly_cont_T
    have h2 : eLpNorm (T f) 1 (ν.restrict G) ≤ 4 * eLpNorm (T f) 1 (ν.restrict G) := by
      linarith
