        _ = (c / p) * (eLorentzNorm g₁ p 1 μ + eLorentzNorm g₂ p 1 μ + eLorentzNorm g₃ p 1 μ + eLorentzNorm g₄ p 1 μ) * ν G ^ p'⁻¹.toReal := by
