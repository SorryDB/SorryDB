import Mathlib

open Filter Real Measure Topology

/- An auxiliary lemma that will be used later.
   It shows that the norm of the indicator function `1_A` is the volume of the set A, `μ A`.
   This is a standard result, but we include it for completeness.
   Note: this is not directly used in the main proof, but is part of the context. -/
lemma norm_ind (A : Set ℝ) (μ : Measure ℝ) (hA : A ∈ Set.l1) (hA' : Set.Finite A) :
    ‖(1 : ℝ → ℝ)‖[μ A] = μ A := by
  simp

/- An auxiliary lemma that will be used later.
   It shows that the norm of the constant function `c` is the absolute value of c.
