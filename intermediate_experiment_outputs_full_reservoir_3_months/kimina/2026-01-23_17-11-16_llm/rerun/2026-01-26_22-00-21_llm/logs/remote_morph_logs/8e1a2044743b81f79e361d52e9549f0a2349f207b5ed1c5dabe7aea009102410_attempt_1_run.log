            · apply memLorentz_ofReal.comp
              apply SimpleFunc.memLorentz
          · apply helper
            · apply measurable_ofReal.comp
              apply SimpleFunc.measurable
            · apply memLorentz_ofReal.comp
              apply SimpleFunc.memLorentz
          · apply helper
            · apply measurable_ofReal.comp
              apply SimpleFunc.measurable
            · apply memLorentz_ofReal.comp
              apply SimpleFunc.memLorentz
          · apply helper
            · apply measurable_ofReal.comp
              apply SimpleFunc.measurable
            · apply memLorentz_ofReal.comp
