import Mathlib

open Filter

/- A vector space norm satisfies the triangle inequality.
-/
noncomputable def normedAddCommGroup (𝕜 : Type u_1) [DivisionRing 𝕜] [AddCommGroupWithOne 𝕜] [OrderedAddCommGroup 𝕜] [OrderedAddCommMonoid (1 : 𝕜)] [OrderedAddCommGroup (1 : 𝕜)] (V : Type u_2) [AddCommGroup V] [Module 𝕜 V] [OrderedAddCommMonoid V] [OrderedAddCommGroup V] (N : V → ℝ≥0∞) : Prop := ∀ (x y : V), N (x + y) ≤ N x + N y

/- A vector space norm satisfies the scaling property.
-/
noncomputable def normedScalarMultiplication (𝕜 : Type u_1) [DivisionRing 𝕜] [AddCommGroupWithOne 𝕜] [OrderedAddCommGroup 𝕜] [OrderedAddCommMonoid (1 : 𝕜)] [OrderedAddCommGroup (1 : 𝕜)] (V : Type u_2) [AddCommGroup V] [Module 𝕜 V] [OrderedAddCommMonoid V] [OrderedAddCommGroup V] (N : V → ℝ≥0∞) : Prop := ∀ (c : 𝕜) (x : V), N (c • x) ≤ N c * N x

/- A vector space norm satisfies the triangle inequality.
-/
noncomputable def normedAddCommMonoid (V : Type u_2) [AddCommMonoid V] [OrderedAddCommMonoid V] (N : V → ℝ≥0∞) : Prop := ∀ (x y : V), N (x + y) ≤ N x + N y

/- A vector space norm satisfies the triangle inequality.
-/
noncomputable def normedAddCommGroupWithOne (V : Type u_2) [AddCommGroupWithOne V] [OrderedAddCommGroup V] [OrderedAddCommMonoid (1 : V)] (N : V → ℝ≥0∞) : Prop := ∀ (x y : V), N (x + y) ≤ N x + N y

/- A vector space norm satisfies the triangle inequality.
-/
noncomputable def normedAddCommGroupWithOneAndOrdered (V : Type u_2) [AddCommGroupWithOne V] [OrderedAddCommGroup V] [OrderedAddCommMonoid (1 : V)] [OrderedAddCommGroup (1 : V)] (N : V → ℝ≥0∞) : Prop := ∀ (x y : V), N (x + y) ≤ N x + N y

/- A vector space norm satisfies the triangle inequality.
-/
noncomputable def normedAddCommMonoidWithOne (V : Type u_2) [AddCommMonoidWithOne V] [OrderedAddCommMonoid V] (N : V → ℝ≥0∞) : Prop := ∀ (x y : V), N (x + y) ≤ N x + N y

/- A vector space norm satisfies the triangle inequality.
