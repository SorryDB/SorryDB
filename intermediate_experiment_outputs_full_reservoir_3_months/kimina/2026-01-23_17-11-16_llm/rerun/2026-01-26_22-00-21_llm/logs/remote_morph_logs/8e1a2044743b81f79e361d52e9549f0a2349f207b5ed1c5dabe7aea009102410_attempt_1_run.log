noncomputable def normedAddCommGroupWithOneAndOrdered (V : Type u_2) [AddCommGroupWithOne V] [OrderedAddCommGroup V] [OrderedAddCommMonoid (1 : V)] [OrderedAddCommGroup (1 : V)] (N : V → ℝ≥0∞) : Prop := ∀ (x y : V), N (x + y) ≤ N x + N y

