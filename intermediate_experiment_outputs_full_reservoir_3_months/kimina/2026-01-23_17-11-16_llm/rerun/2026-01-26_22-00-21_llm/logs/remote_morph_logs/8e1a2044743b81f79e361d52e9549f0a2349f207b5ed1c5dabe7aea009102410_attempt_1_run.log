import Mathlib
open Real
open scoped BigOperators

/-!
A theorem stating that a certain type of functional T preserves the structure of Lorentz norms.
-/

theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

/-!
