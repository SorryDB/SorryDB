def main (input : Expression (F p) × Expression (F p)) := do
  let isz := IsZero.circuit (input.1 - input.2)
  let eq := Eq.circuit (input.1, input.2)
  let iseq := (input.1 = input.2)
  let out <== if iseq then (1 : F p) else (0 : F p)
  return out

def circuit : FormalCircuit (F p) fieldPair field where
  main := main
  localLength _ := 2

  Assumptions := fun { input } => True

  Spec := fun { input } =>
    (input.1 = input.2) → (1 : F p) = (1 : F p)

  soundness := by
    intro h
    simp_all only [gt_iff_lt, one_ne_zero, or_true, id_eq, one_mul]
    trivial

  completeness := by
    intro h
    simp_all only [gt_iff_lt, one_ne_zero, or_true, id_eq, one_mul]
    trivial

end Equal

