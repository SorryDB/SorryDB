  rw [show Φ₂' r = fun z ↦ exp (↑(z - 1)⁻¹ * r * 2 * Real.pi * 1) by funext z; simp [Φ₂', mul_comm]]
  apply ContDiffOn.exp
  apply DifferentiableOn.div
  · exact differentiableOn_const 1
  · exact differentiableOn_id.sub differentiableOn_const 1
  · intro z hz hz'
    simp only [Complex.ext_iff, mem_upperHalfPlaneSet] at hz
    obtain ⟨hre, him⟩ := hz'
    have hzim : z.im > 0 := hz
    have : z - 1 = 0 → z = 1 := by
      intro h
      simp [Complex.ext_iff] at h ⊢
      constructor <;> linarith
    rw [this] at hz'
    simp only [sub_im, one_im, sub_zero, zero_im] at hz'
    linarith

theorem Φ₃'_contDiffOn : ContDiffOn ℝ ∞ (Φ₃' r) ℍ₀ := by
  rw [show Φ₃' r = fun z ↦ exp (↑z⁻¹ * r * 2 * Real.pi * 1) by funext z; simp [Φ₃', mul_comm]]
  apply ContDiffOn.exp
  apply DifferentiableOn.div
  · exact differentiableOn_const 1
  · exact differentiableOn_id
  · intro z hz hz'
    simp only [Complex.ext_iff, mem_upperHalfPlaneSet] at hz
    obtain ⟨hre, him⟩ := hz'
    have hzim : z.im > 0 := hz
    have : z = 0 := by
      have hzre : z.re = 0 := by linarith
      have hzim' : z.im = 0 := by linarith
      exact Complex.ext_iff.mpr ⟨hzre, hzim'⟩
    rw [this] at hz'
    simp only [inv_im, zero_im] at hz'
    linarith

