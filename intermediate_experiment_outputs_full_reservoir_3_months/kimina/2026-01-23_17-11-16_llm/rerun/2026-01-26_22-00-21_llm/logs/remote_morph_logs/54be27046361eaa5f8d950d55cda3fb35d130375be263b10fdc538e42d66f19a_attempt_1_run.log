        exact h7.1
      have h10 : v = unreverse (Reversible.choose h1) := by
        simpa using h9
      exact h10
    · exfalso
      tauto
  have h3 : Reversible.choose h1 = z := by
    have h4 : Reversible.choose h1 ∈ reverseSet (unreverse z) y p := by
      have h5 : Reversible.choose h1 ∈ (unreverse z).moves p := by
        simpa using h1.choose_mem_moves
      have h6 : (unreverse z).moves p = unreverse '' reverseSet (unreverse z) y p := by
        rw [moves_unreverse]
      rw [h6] at h5
      simpa using h5
    simp [reverseSet] at h4
    split_ifs at h4 with h5
    · exfalso
      tauto
    · exact h4
  have h4 : Reversible (unreverse x) z p := by
    rw [h3] at h1
    simpa using h1
  have h5 : ¬ Reversible x z p := by
    have h6 : ¬ Reversible x z p := h
    simpa using h6
