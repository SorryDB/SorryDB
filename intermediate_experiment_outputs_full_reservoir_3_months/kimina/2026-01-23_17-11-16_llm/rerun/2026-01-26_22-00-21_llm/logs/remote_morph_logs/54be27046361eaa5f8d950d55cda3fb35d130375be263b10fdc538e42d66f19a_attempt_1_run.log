  cases p <;> exact h.choose_spec.1

theorem Reversible.choose_le (h : Reversible x y left) : h.choose ≤ x := h.choose_spec.2
theorem Reversible.le_choose (h : Reversible x y right) : x ≤ h.choose := h.choose_spec.2

