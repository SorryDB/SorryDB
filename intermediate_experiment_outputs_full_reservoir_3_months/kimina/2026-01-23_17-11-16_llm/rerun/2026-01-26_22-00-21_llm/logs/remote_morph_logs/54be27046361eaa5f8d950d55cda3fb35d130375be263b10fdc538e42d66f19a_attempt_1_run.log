def Reversible (x y : IGame) (p : Player) : Prop :=
  p.cases (∃ z ∈ yᴿ, z ≤ x) (∃ z ∈ yᴸ, x ≤ z)

theorem reversible_left : Reversible x y left ↔ ∃ z ∈ yᴿ, z ≤ x := .rfl
theorem reversible_right : Reversible x y right ↔ ∃ z ∈ yᴸ, x ≤ z := .rfl

