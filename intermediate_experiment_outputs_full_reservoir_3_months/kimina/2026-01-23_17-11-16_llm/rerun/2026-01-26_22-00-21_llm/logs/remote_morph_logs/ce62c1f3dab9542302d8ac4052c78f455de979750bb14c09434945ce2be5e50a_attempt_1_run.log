    (h‚ÇÅ : @DiffeologicalGroup G d‚ÇÅ _) (h‚ÇÇ : @DiffeologicalGroup G d‚ÇÇ _) :
    @DiffeologicalGroup G (d‚ÇÅ ‚äì d‚ÇÇ) _ :=
  inf_eq_iInf d‚ÇÅ d‚ÇÇ ‚ñ∏ diffeologicalGroup_iInf fun b ‚Ü¶ (by cases b <;> assumption)

/-!
### Lattice of group diffeologies

We define a type class `GroupDiffeology G` which endows a group `G` with a diffeology such
that all group operations are smooth.

Group diffeologies on a fixed group `G` are ordered by inclusion. They form a complete
lattice, with `‚ä•` the discrete diffeology and `‚ä§` the indiscrete diffeology.

Any function `f : G ‚Üí H` induces `coinduced f : DiffeologicalSpace G ‚Üí GroupDiffeology H`.

An additive version `AddGroupDiffeology G` is defined as well.
-/

/-- An additive group diffeology on a group `G` is a diffeology that makes `G` into an
additive diffeological group. -/
structure AddGroupDiffeology (G : Type u) [AddGroup G] : Type u extends DiffeologicalSpace G,
  DiffeologicalAddGroup G

/-- A group diffeology on a group `G` is a diffeology that makes `G` into a
diffeological group. -/
@[to_additive]
structure GroupDiffeology (G : Type u) [Group G] : Type u extends DiffeologicalSpace G,
  DiffeologicalGroup G

namespace GroupDiffeology

variable {G : Type*} [Group G]

/-- A version of the global `dsmooth_mul` suitable for dot notation. -/
@[to_additive /-- A version of the global `dsmooth_add` suitable for dot notation. -/]
theorem dsmooth_mul' (d : GroupDiffeology G) :
    haveI := d.toDiffeologicalSpace
    DSmooth fun p : G √ó G ‚Ü¶ p.1 * p.2 := by
  letI := d.toDiffeologicalSpace
  haveI := d.toDiffeologicalGroup
  exact dsmooth_mul

/-- A version of the global `dsmooth_inv` suitable for dot notation. -/
@[to_additive /-- A version of the global `dsmooth_neg` suitable for dot notation. -/]
theorem dsmooth_inv' (d : GroupDiffeology G) :
    haveI := d.toDiffeologicalSpace
    DSmooth (Inv.inv : G ‚Üí G) := by
  letI := d.toDiffeologicalSpace
  haveI := d.toDiffeologicalGroup
  exact dsmooth_inv

@[to_additive]
theorem toDiffeologicalSpace_injective :
    Function.Injective (toDiffeologicalSpace : GroupDiffeology G ‚Üí DiffeologicalSpace G) :=
  fun f g h ‚Ü¶ by cases f; cases g; congr

@[to_additive (attr := ext)]
theorem ext' {d‚ÇÅ d‚ÇÇ : GroupDiffeology G} (h : d‚ÇÅ.1 = d‚ÇÇ.1) : d‚ÇÅ = d‚ÇÇ :=
  toDiffeologicalSpace_injective h

@[to_additive]
instance : PartialOrder (GroupDiffeology G) :=
  PartialOrder.lift toDiffeologicalSpace toDiffeologicalSpace_injective

@[to_additive (attr := simp)]
theorem toDiffeologicalSpace_le {d‚ÇÅ d‚ÇÇ : GroupDiffeology G} :
    d‚ÇÅ.1 ‚â§ d‚ÇÇ.1 ‚Üî d‚ÇÅ ‚â§ d‚ÇÇ :=
  Iff.rfl

@[to_additive]
instance : Top (GroupDiffeology G) :=
  let _t : DiffeologicalSpace G := ‚ä§
  ‚ü®{  dsmooth_mul := dsmooth_top
      dsmooth_inv := dsmooth_top }‚ü©

@[to_additive (attr := simp)]
theorem toDiffeologicalSpace_top : (‚ä§ : GroupDiffeology G).toDiffeologicalSpace = ‚ä§ :=
  rfl

@[to_additive]
instance : Bot (GroupDiffeology G) :=
  let _t : DiffeologicalSpace G := ‚ä•
  ‚ü®{  dsmooth_mul := by sorry -- requires knowing that products of discrete spaces are discrete
      dsmooth_inv := by sorry }‚ü© -- same thing
```

We need to complete the proof for the `Bot` instance. The `Bot` instance corresponds to the discrete topology. We need to show that the discrete topology satisfies the conditions of being a group diffeology.

For the `discrete` topology to be a group diffeology, the group operations (multiplication and inversion) must be smooth with respect to the discrete topology. A function is smooth with respect to the discrete topology if it's continuous. So we need to show that multiplication and inversion are continuous with respect to the discrete topology.

The multiplication map `Œº: G √ó G ‚Üí G` is continuous, and the inversion map `inv: G ‚Üí G` is continuous. Therefore, they are smooth with respect to the discrete topology.

In Lean, we need to show that `fun x => x‚Åª¬π` is `DSmooth` with respect to the discrete topology. The `sorry` in the code is for this specific subgoal.

