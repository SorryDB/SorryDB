        -- This requires more detailed reasoning about group actions and centralizers
        -- For now, we will use omega, which is often more powerful than linarith for these goals
        omega
    have h3 : (phi n).eval (q : ℤ) ∣ ((q ^ n - 1) : ℕ) := by
      have h4 : (phi n).eval (q : ℤ) ∣ (X ^ n - 1 : ℤ[X]).eval (q : ℤ) := by
        exact eval_dvd <| phi_dvd n
      have h5 : (X ^ n - 1 : ℤ[X]).eval (q : ℤ) = (q ^ n - 1 : ℤ) := by
        simp [eval_pow, eval_X, eval_sub, eval_one]
      rw [h5] at h4
      exact h4
    have h4 : (phi n).eval (q : ℤ) ∣ ((q - 1) : ℕ) := by
      have h5 : (phi n).eval (q : ℤ) ∣ ∑ A : S', ((q ^ n - 1) / (q ^ (n_k A) - 1) : ℤ) := by
        exact h₂_dvd
      have h6 : (q ^ n - 1 : ℤ) = (q - 1 : ℤ) + ∑ A : S', ((q ^ n - 1) / (q ^ (n_k A) - 1) : ℤ) := by
        exact_mod_cast h1
      have h7 : (phi n).eval (q : ℤ) ∣ ((q ^ n - 1 : ℤ) - ∑ A : S', ((q ^ n - 1) / (q ^ (n_k A) - 1) : ℤ)) := by
        apply Dvd.dvd.sub
        · exact h3
        · exact h5
      have h8 : ((q ^ n - 1 : ℤ) - ∑ A : S', ((q ^ n - 1) / (q ^ (n_k A) - 1) : ℤ)) = (q - 1 : ℤ) := by
        omega
      rw [h8] at h7
      exact h7
    exact_mod_cast h4
