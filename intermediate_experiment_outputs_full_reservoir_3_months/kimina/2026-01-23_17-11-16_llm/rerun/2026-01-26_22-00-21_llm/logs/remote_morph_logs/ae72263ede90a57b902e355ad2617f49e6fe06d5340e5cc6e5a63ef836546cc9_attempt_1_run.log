    have e' := (e.trans (d.restrict _)).trans (DDiffeomorph.Set.nested _)
    refine ⟨_,hv'.isOpenMap_subtype_val _ ?_,⟨e'⟩⟩
    exact ((dTop_eq X ▸ hu).preimage continuous_subtype_val).preimage d.symm.dsmooth.continuous'⟩

