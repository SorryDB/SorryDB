    ext a b; dsimp; rw [MulAction.orbitRel_apply,MulAction.mem_orbit_iff]
    refine ⟨fun ⟨g,hg⟩ ↦ hg ▸ ?_,fun h ↦ ⟨1,by rw [h,one_smul]⟩⟩
    rw [Unique.eq_default g,unique_one,one_smul]
  dsimp [MulAction.orbitRel.Quotient]; rw [h]
