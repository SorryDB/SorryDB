    (mem_nhds_subtype u ⟨x, hxu⟩ _).mpr ⟨s, hs, subset_rfl⟩
  refine ⟨(↑) '' t, ?_, by simp [hts], ht'.image continuous_subtype_val⟩
  exact hu.isOpenMap_subtype_val.image_mem_nhds ht

