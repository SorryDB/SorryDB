spaces. -/
protected theorem IsOpen.locallyModelled {X ι : Type*} [DiffeologicalSpace X] {M : ι → Type*}
    [(i : ι) → DiffeologicalSpace (M i)] (h : LocallyModelled M X) {u : Set X}
