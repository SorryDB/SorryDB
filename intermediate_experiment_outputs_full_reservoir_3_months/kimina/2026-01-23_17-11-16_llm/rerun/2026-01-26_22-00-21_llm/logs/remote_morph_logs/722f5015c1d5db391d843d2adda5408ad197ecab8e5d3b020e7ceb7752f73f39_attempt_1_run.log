          have lhs_len : (Word.mk [Sum.inl (↑dstep.prod).lhs]).length = 1 := by
            simp [Word.mk, Word.length]
          have rhs_comp : (dstep.prod.val.rhs).length = 1 + (dstep.prod.val.rhs.length - 1) := by
            rw [dstep.prod.val.rhs.length]
            simp [add_comm, Nat.sub_add_cancel]
            exact h_rhs_non_empty
          rw [rhs_comp]
          rw [lhs_len]
          rw [add_assoc (dstep.pre.length + 1) (dstep.suf.length) (dstep.prod.val.rhs.length - 1)]
