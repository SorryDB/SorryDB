        have result_comp := (dstep.len_result_composition)
        simp [← u'_eq_result, u_comp, result_comp]
        have lhs_len : (Word.mk [Sum.inl (↑dstep.prod).lhs]).len = 1 := by
          simp [Word.mk, Word.len]
        have rhs_comp : (↑dstep.prod).rhs.len = n + 1 := by
          rw [h_num_vars_rhs]
          simp
        have rhs_len : (↑dstep.prod).rhs.len = n + 1 := by
          rw [h_num_vars_rhs]
          simp
        rw [lhs_len, rhs_len]
        rw [add_assoc (dstep.pre.len + 1) (dstep.suf.len) (n + 1)]
        rw [add_comm (dstep.suf.len) (n + 1)]
        repeat rw [add_assoc]
