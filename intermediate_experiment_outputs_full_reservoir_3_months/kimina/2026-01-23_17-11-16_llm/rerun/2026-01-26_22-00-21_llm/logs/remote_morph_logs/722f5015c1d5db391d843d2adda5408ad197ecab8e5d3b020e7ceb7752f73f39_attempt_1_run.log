      -- this exact derivation step
      have h_u_vs_u'_len₂ : u'.len ≥ u.len := by
        rw [h_u_vs_u'_len]
        simp
      have u_range_subset_u'_range : (Finset.range u.len) ⊆ (Finset.range u'.len) := by
        apply Finset.range_subset_range.mpr
        exact h_u_vs_u'_len₂
      let leftOfVarCount₂ : Finset.range u'.len := ⟨ dstep.pre.len, (by
        simp [u'_eq_result.symm, dstep.len_result_composition, add_assoc, add_comm]
      )⟩
      let fun_find_allChildren_with_index (index₁ : Finset.range (u'.len)) (h_index_valid : ∃ location  ∈ allChildren, location.2 = index₁) : (DerivationTree G) :=
        let afunc : List (DerivationTree G × { x // x ∈ Finset.range u'.len }) →
                      (DerivationTree G × { x // x ∈ Finset.range u'.len }) →
                      List (DerivationTree G × { x // x ∈ Finset.range u'.len }) :=
              (fun prev (DT , index₂) =>
              dite (index₁ = index₂)
              (fun h_is : index₁ = index₂ =>
                prev ++ [(DT, index₂)])
              (fun h_is_not : index₁ ≠ index₂ =>
                prev) )
        have afuncDef : afunc =
            (fun prev (DT , index₂) =>
            dite (index₁ = index₂)
            (fun h_is : index₁ = index₂ =>
              prev ++ [(DT, index₂)])
            (fun h_is_not : index₁ ≠ index₂ =>
              prev) ) := by tauto
        let a : List (DerivationTree G × { x // x ∈ Finset.range u'.len }) := List.foldl afunc [] allChildren
        have aDef : a = List.foldl afunc [] allChildren := by simp [a]
        have afunc_monotone : ∀ list₁ list₂ : List (DerivationTree G × { x // x ∈ Finset.range u'.len }), list₁ ≠ [] → List.foldl afunc list₁ list₂ ≠ [] := by
          intro list₁ list₂
          induction list₁
          case nil =>
            tauto
          case cons head₁ tail₁ ind_hyp₁ =>
            induction list₂
            case nil =>
              tauto
            case cons head₂ tail₂ ind_hyp₂ =>
              intro h_head_tail_neq_nil
              by_cases tail₂ ≠ []
              case pos h_pos₂ =>
                by_cases tail₁ ≠ []
                case pos h_pos₁ =>
                  simp [h_pos₁] at ind_hyp₂
                  simp [h_pos₁] at ind_hyp₁

                  rw [List.foldl_cons]

                  simp [afuncDef]
                  by_cases index₁ = head₂.2
                  case pos h_is =>
                    simp [h_is]
                    simp [List.foldl]
                    <;> tauto
                  case neg h_is =>
