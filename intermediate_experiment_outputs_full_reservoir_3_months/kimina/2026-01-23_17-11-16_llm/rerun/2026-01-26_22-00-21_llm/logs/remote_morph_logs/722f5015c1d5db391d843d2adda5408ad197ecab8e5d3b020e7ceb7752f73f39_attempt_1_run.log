                simp [h_neg₂] at ind_hyp₂
                simp [h_neg₂] at ind_hyp₁
                simp [List.foldl]
                <;> tauto
        have h_nonempty : ∃ element ∈ allChildren, element.2 = index₁ := h_index_valid
        have h_nonempty_a : a ≠ [] := by
          have h_nonempty_a' : a = List.foldl afunc [] allChildren := by
            exact aDef
          rw [h_nonempty_a']
          exact List.ne_nil_iff_ne_empty.mpr (by
