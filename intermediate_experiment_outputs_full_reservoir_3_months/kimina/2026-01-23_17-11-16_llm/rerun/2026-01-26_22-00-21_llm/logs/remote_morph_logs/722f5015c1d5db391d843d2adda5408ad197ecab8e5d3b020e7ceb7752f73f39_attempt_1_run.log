            rw [exhaustiveCondition] at h_exhaustive
            apply not_exists_of_forall_not
            intro symbol
            have h_s_e : _ := h_exhaustive symbol
            rw [Decidable.not_and_iff_not_or_not']
            by_cases symbol ∈ v
            case pos h_pos =>
              apply h_s_e at h_pos
              apply Or.inr
              simp [h_pos]
            case neg h_neg =>
              apply Or.inl
              exact h_neg
          by_contra h_contra
          rw [h_contra] at h_u'_has_var
          contradiction
        ))

    have u_comp := (ContextFreeDerivationStep.len_u_composition dstep).symm
    have var_len_1 : (Word.mk [Sum.inl (↑dstep.prod).lhs]).length = 1 := by
      simp [Word.mk, Word.length]
    have pre_len_less_u_len : dstep.pre.length < u.length := by
      rw [eq_iff_le_not_lt] at u_comp
      apply And.left at u_comp
      have var_len_1 : (Word.mk [Sum.inl (↑dstep.prod).lhs]).length = 1 := by
        simp [Word.mk, Word.length]
      rw [var_len_1, add_comm] at u_comp
      rw [← add_assoc] at u_comp
      apply Nat.lt_succ_of_le at u_comp
      apply Nat.lt_of_succ_lt_succ at u_comp
      rw [add_comm] at u_comp
      apply Nat.lt_sub_of_add_lt at u_comp
      exact @Nat.lt_of_lt_of_le (dstep.pre.length) (u.length - dstep.suf.length) (u.length) u_comp (by
        exact @Nat.sub_le (u.length) (dstep.suf.length))
    have u_comp := (ContextFreeDerivationStep.len_u_composition dstep).symm
    have suf_len_less_u_len : dstep.suf.length < u.length := by
      rw [eq_iff_le_not_lt] at u_comp
      apply And.left at u_comp
      rw [var_len_1, add_comm] at u_comp
      rw [← add_assoc] at u_comp
      apply Nat.lt_succ_of_le at u_comp
      apply Nat.lt_of_succ_lt_succ at u_comp
      apply Nat.lt_sub_of_add_lt at u_comp
      exact @Nat.lt_of_lt_of_le (dstep.suf.length) (u.length - dstep.pre.length) (u.length) u_comp (by
        exact @Nat.sub_le (u.length) (dstep.pre.length))

    let leftOfVarCount : Finset.range u.length := ⟨dstep.pre.length, (by
      simp [pre_len_less_u_len])⟩
    let rightOfVarCount : Finset.range u.length := ⟨dstep.suf.length, (by
      simp [suf_len_less_u_len])⟩
    let rhs_symbol_count : ℕ := dstep.prod.val.rhs.length
    have u'_eq : dstep.result = u' := by exact sound

    cases h_constructor with
    | .same h_same => contradiction
    | @ContextFreeDerivation.step α nt G _ u'' _ dstep' derivation' sound' =>
      have u'_comp := (ContextFreeDerivationStep.len_u_composition dstep').symm
      have derivation_exhaustive : derivation'.exhaustiveCondition := by
        apply @ContextFreeDerivation.exhaustive_imp_child_exhaustive α nt G u v cfd h_exhaustive u' dstep' derivation' sound'
        all_goals try { tauto }
        all_goals try { contradiction }
      have a := (derivation'.collectDerivationTreeNodes derivation_exhaustive (by
        have h_u'_has_var : ∃ symbol ∈ u', Sum.isLeft symbol := by
          have dstep'_var_in_u' : Sum.inl dstep'.prod.val.lhs ∈ u' := by
            have h_dstep'_sound : _ := dstep'.sound
            simp at h_dstep'_sound
            simp [h_dstep'_sound, Word.mem_mul_iff_or]
            apply Or.inl; apply Or.inr; tauto
          exists (Sum.inl dstep'.prod.val.lhs)
        have h_v_has_no_var : ¬ ∃ symbol ∈ v, Sum.isLeft symbol := by
          rw [exhaustiveCondition] at h_exhaustive
          apply not_exists_of_forall_not
          intro symbol
          have h_s_e : _ := h_exhaustive symbol
          rw [Decidable.not_and_iff_not_or_not']
          by_cases symbol ∈ v
          case pos h_pos =>
            apply h_s_e at h_pos
            apply Or.inr
            simp [h_pos]
          case neg h_neg =>
            apply Or.inl
            exact h_neg
        by_contra h_contra
        rw [h_contra] at h_u'_has_var
        contradiction
      ))
      simp [a, allChildren]
      <;> try { tauto }
      all_goals try { contradiction }
```

The key change is replacing the complex proof of `List.foldl ... = List.foldl ...` with a `cases` block that proves `List (DerivationTree G × { x // x ∈ Finset.range u'.len }) = List.foldl afunc [] allChildren` by showing that the `match` expression equals `List.foldl afunc [] allChildren`. This is done by `simp [a, allChildren]` after `cases` and then `tauto` or `contradiction`.
