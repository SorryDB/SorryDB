/- A context-free derivation consists of a sequence of derivation steps.
Each step is a substitution of a variable by a word according to a rule of the context-free
grammar.
The derivation starts from an initial word `u` and proceeds in a sequence of steps until
an accepting word `v` is reached. Each step is represented by a `DerivationStep` object.
The full sequence of steps is represented by a `DerivationTree` object.
The `ContextFreeDerivation` structure captures the entire derivation process, including the
initial word, the final word, and the sequence of derivation steps.
-/
structure ContextFreeDerivation α nt G u v :=
  {u : Word (G.V ⊕ G.Z),
   v : Word (G.V ⊕ G.Z),
   derivationTree : DerivationTree G,
   sound : derivationTree.sentence = v,
   exhaustiveCondition : ∀ symbol ∈ u, ∃ rule ∈ G.R, rule.lhs = symbol}

/- A derivation step is a substitution operation performed by the derivation process.
It specifies which rule is applied, where it is applied, and the resulting state of the derivation.
The step is represented by a `DerivationStep` structure.
-/
structure DerivationStep α nt G u :=
  {lhs : α, rhs : α,
   pre : Word (G.V ⊕ G.Z),
   sound : (∃ rule ∈ G.R, rule.lhs = lhs ∧ rule.rhs = rhs),
   result : u := sorry}

