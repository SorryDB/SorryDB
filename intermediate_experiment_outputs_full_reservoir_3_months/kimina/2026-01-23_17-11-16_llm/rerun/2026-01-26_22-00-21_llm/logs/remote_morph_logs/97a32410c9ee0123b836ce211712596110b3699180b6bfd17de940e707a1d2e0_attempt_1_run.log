    (cfc_toComplexMeasure ha x y).variation Set.univ ≤ ‖x‖ * ‖y‖ := by
  have h1 : (cfc_toComplexMeasure ha x y).totalVariation = ‖cfc_toLinearFunctional ha x y‖ := by
