  have h2 : (cfc_toComplexMeasure ha x y).variation Set.univ = ‖(cfc_toComplexMeasure ha x y).toLinearFunctional‖ := by
    simp only [cfc_toComplexMeasure]
    rw [ComplexRMK.variation_rieszMeasure]
