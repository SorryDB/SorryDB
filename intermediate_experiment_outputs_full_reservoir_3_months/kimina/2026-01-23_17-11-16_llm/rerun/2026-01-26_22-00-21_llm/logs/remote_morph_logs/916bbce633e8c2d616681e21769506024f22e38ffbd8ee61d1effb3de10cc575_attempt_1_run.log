        · -- Proof of T₁_subadd
          sorry
        · -- Proof of T₁_submul
          sorry
      have h8 : AESTronglyMeasurable (T₁ g₁) ν := sorry
      have h9 : AESTronglyMeasurable (T₁ g₂) ν := sorry
      have h10 : AESTronglyMeasurable (T₁ g₃) ν := sorry
      have h11 : AESTronglyMeasurable (T₁ g₄) ν := sorry
