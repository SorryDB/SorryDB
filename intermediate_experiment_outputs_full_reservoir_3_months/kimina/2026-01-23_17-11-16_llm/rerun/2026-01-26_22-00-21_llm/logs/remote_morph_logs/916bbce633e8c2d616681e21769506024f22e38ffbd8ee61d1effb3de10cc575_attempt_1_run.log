      set g₄ := fun x ↦ Real.toNNReal (- RCLike.im (g x))
      have h1 : g = (1 : 𝕂) • (algebraMap ℝ 𝕂 ∘ g₁) + (-1 : 𝕂) • (algebraMap ℝ 𝕂 ∘ g₂) +
          (RCLike.I : 𝕂) • (algebraMap ℝ 𝕂 ∘ g₃) + (-RCLike.I : 𝕂) • (algebraMap ℝ 𝕂 ∘ g₄) := by
        unfold g₁ g₂ g₃ g₄
        ext x
        simp only [one_smul, neg_smul, Pi.add_apply, Function.comp_apply, Real.coe_toNNReal',
