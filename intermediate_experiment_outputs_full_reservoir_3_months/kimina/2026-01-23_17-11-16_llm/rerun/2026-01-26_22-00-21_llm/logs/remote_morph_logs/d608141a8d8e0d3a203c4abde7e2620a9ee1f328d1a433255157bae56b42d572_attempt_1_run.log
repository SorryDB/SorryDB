    ∫ ω, ‖∑ i ∈ A, X i ω‖ ^ (2 * m) ∂μ
    _ ≤ ∫ ω, ‖∑ i ∈ A, X' i ω‖ ^ (2 * m) ∂μ.prod μ := by
      simp [X', X₁, X₂]
      all_goals
        congr
        <;> simp
        <;> aesop
    _ ≤ marcinkiewiczZygmundSymmConst (2 * m) * ∫ ω, (∑ i ∈ A, ‖X' i ω‖ ^ 2) ^ m ∂μ.prod μ := by
      apply marcinkiewicz_zygmund_symmetric
      · -- Show that X' is independent
