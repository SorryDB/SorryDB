        · -- Show that X₂ i is identically distributed with -X₂ i
          apply IdentDistrib.comp
          · exact identDistrib_neg_X i
          · simp
      · -- Show that X' is in L^(2*m)
        intro i hi
        apply memLp.sub
        · -- Show that X₁ i is in L^(2*m)
