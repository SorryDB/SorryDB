      simp [X₁]
      apply iIndepFun.comp_left
      exact iIndepFun_X i j h
    have h2 : iIndepFun X₂ (μ.prod μ) := by
      intro i j h
      simp [X₂]
      apply iIndepFun.comp_left
      exact iIndepFun_X i j h
    simp [X']
    apply iIndepFun.sub
    exact h1
    exact h2
