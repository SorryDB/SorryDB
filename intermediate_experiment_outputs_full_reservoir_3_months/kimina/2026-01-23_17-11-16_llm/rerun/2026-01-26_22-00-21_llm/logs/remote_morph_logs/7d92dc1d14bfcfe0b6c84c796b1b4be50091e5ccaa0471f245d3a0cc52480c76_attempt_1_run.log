    <;> try { norm_num }
    <;> try { simp [cfc_toLinearFunctional_apply] }
    <;> try { tauto }
    <;> try { norm_num }
  rw [h1]
  calc
    ‖⟪x, (cfcHom ha.isStarNormal f y)⟫_ℂ‖
      ≤ ‖x‖ * ‖(cfcHom ha.isStarNormal f y)‖ := norm_inner_le_norm x ((cfcHom ha.isStarNormal f) y)
    _ ≤ ‖x‖ * (‖cfcHom ha.isStarNormal f‖ * ‖y‖) := by
      apply mul_le_mul_of_nonneg_left
      exact le_of_eq (norm_eq_norm cfcHom ha.isStarNormal f y) -- This is incorrect, need to use le_opNorm
