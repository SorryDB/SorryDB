variable {C : Type*} [inst : AddCommGroup C] [inst : AddCommMonoid C] [inst : AddCommGroupWithZero C] [inst : NoZeroDivisors C] [inst : AddLeftMono C] [inst : AddRightMono C] [inst : AddLeftCancel C] [inst : AddRightCancel C] [inst : LinearOrderedAddCommGroup C] [inst : LinearOrderedAddCommMonoid C] [inst : LinearOrderedAddCommGroupWithZero C] [inst : LinearOrderedNoZeroDivisors C] [inst : LinearOrderedAddLeftMono C] [inst : LinearOrderedAddRightMono C] [inst : LinearOrderedAddLeftCancel C] [inst : LinearOrderedAddRightCancel C]

variable {K : Type*} [inst : DivisionRing K] [inst : AddLeftMono K] [inst : AddRightMono K] [inst : AddLeftCancel K] [inst : AddRightCancel K] [inst : AddLeftMono K] [inst : AddRightMono K] [inst : AddLeftCancel K] [inst : AddRightCancel K] [inst : LinearOrderedAddCommGroup K] [inst : LinearOrderedAddCommMonoid K] [inst : LinearOrderedAddCommGroupWithZero K] [inst : LinearOrderedNoZeroDivisors K] [inst : LinearOrderedAddLeftMono K] [inst : LinearOrderedAddRightMono K] [inst : LinearOrderedAddLeftCancel K] [inst : LinearOrderedAddRightCancel K]

variable {M : C ⥤ ModuleCat K} in

namespace DirectSumDecomposition

noncomputable def refinement (D : DirectSumDecomposition M) (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' := sorry
  sSup_eq_top' := sorry
  not_bot_mem' := sorry

lemma refinement_le (D : DirectSumDecomposition M) (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    refinement D B hB hB' hB'' ≤ D := sorry

lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  by_contra hNotMax
  simp only [Indecomposable, not_forall, not_or] at hNotMax
  rcases hNotMax with ⟨x, y, hxy, hN_eq, hx, hy⟩
  let B (N : PersistenceSubmodule M) (hN' : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  have h1 : ∀ (N : PersistenceSubmodule M) (hN' : N ∈ D), N = sSup (B N hN') := by
    intro N hN'
    by_cases h_eq : N = x ⊔ y
    · -- Case 1: N = x ⊔ y
      rw [h_eq]
      have h2 : B (x ⊔ y) hN' = {x, y} := by
        simp [B, h_eq]
      rw [h2]
      have h3 : sSup ({x, y} : Set (PersistenceSubmodule M)) = x ⊔ y := by
        rw [sSup_pair hxy]
      rw [h3]
    · -- Case 2: N ≠ x ⊔ y
      have h4 : B N hN' = {N} := by
        simp [B, h_eq]
      rw [h4]
      simp
  have h2 : ∀ (N : PersistenceSubmodule M) (hN' : N ∈ D), sSupIndep (B N hN') := by
    intro N hN'
    by_cases h_eq : N = x ⊔ y
    · -- Case 1: N = x ⊔ y
      rw [h_eq]
      have h3 : B (x ⊔ y) hN' = {x, y} := by
        simp [B, h_eq]
      rw [h3]
      simp [sSupIndep_pair, hxy]
    · -- Case 2: N ≠ x ⊔ y
      have h4 : B N hN' = {N} := by
        simp [B, h_eq]
      rw [h4]
      simp
  have h3 : ∀ (N : PersistenceSubmodule M) (hN' : N ∈ D), ⊥ ∉ B N hN' := by
    intro N hN'
    by_cases h_eq : N = x ⊔ y
    · -- Case 1: N = x ⊔ y
      rw [h_eq]
      have h4 : B (x ⊔ y) hN' = {x, y} := by
        simp [B, h_eq]
      rw [h4]
      simp [hx, hy]
    · -- Case 2: N ≠ x ⊔ y
      have h5 : B N hN' = {N} := by
        simp [B, h_eq]
      rw [h5]
      have hN_ne_zero : N ≠ ⊥ := by
        rw [show N = x ⊔ y by tauto]
        by_contra h_eq_zero
        have hx_zero : x = ⊥ := by
          have : x ≤ x ⊔ y := by simp
          rw [h_eq_zero] at this
          have : x = ⊥ := by
            simpa using this
          assumption
        contradiction
      simp [hN_ne_zero]
  let newD := refinement D B h1 h2 h3
  have h4 : newD ≤ D := by
    apply refinement_le
    all_goals
      try { tauto }
      try { aesop }
  have h5 : newD = D := by
    apply hmax.1 h4
  have h6 : x ∈ newD := by
    simp [newD, B, hN_eq]
  have h7 : y ∈ newD := by
    simp [newD, B, hN_eq]
  have h8 : x ⊔ y ∈ newD := by
    simp [newD, B, hN_eq]
