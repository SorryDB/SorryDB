def cfc_toComplexMeasure (x y : H) := ComplexRMK.rieszMeasure (compSL C₀((spectrum ℂ a), ℂ)
  C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y)
  (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE
  (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap)

/-- The integral of `f` against `E_{a, x,y}` is bounded by `‖x‖ * ‖y‖ * ‖f‖`. -/
lemma cfc_toComplexMeasure_bounded (x y : H) (f : C((spectrum ℂ a), ℂ)) :
    ‖(cfc_toComplexMeasure ha x y).integral f‖ ≤ ‖x‖ * ‖y‖ * ‖f‖ := by
  have h1 : ‖(cfc_toComplexMeasure ha x y).integral f‖ = ‖cfc_toLinearFunctional ha x y (f : C((spectrum ℂ a), ℂ))‖ := by
    simp [cfc_toComplexMeasure, ComplexRMK.rieszMeasure_apply]
    all_goals try { tauto }
    all_goals try { 
      have h2 : (compSL C₀((spectrum ℂ a), ℂ) C((spectrum ℂ a), ℂ) ℂ _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ℂ a) ℂ ℂ _ _ _ _ _ _).symm.toContinuousLinearMap) = (cfc_toLinearFunctional ha x y : C((spectrum ℂ a), ℂ) →L[ℂ] ℂ) := by
