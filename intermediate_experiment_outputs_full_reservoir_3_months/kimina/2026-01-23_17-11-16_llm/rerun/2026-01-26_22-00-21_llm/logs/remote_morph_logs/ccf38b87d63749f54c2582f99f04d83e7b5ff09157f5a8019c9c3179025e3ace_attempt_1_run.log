  (hѕЖ : ќУ.conj вЛП ѕЖ вЮЭ ќЊ вИИ T.theory) :
  ѕЖ вИЙ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    exfalso;
    apply hѕЖ вИЕ (by tauto) (by tauto)
  | succ i ih =>
    simp [construction] at ih вКҐ;
    split_ifs at ih with h;
    . rename_i ќі hќі;
      by_contra hC;
      have : ќі = ѕЖ := by
        have h1 : encode ќі = i := by
          simpa using hќі
        have h2 : encode ѕЖ = i := by
          simpa using hC
        omega
      subst this;
      apply hќУ ((show encode ќі = i by
        simpa using hќі
      ) вЦЄ h) hѕЖ;
    . assumption

lemma construction_omega_mem_ant : ѕЗ вИИ construction_omega T hT := by
  apply mem_omega_of_mem;
  simp [construction_omega, Set.mem_iUnion, Set.mem_insert_iff, construction]
  use 0; simp

