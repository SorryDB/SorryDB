import Foundation.Propositional.Hilbert.F.Deduction
import Foundation.Propositional.Kripke2.Basic

namespace LO.Propositional

open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {ќ± : Type*}
variable {S} [Entailment S (Formula ќ±)]
variable {рЭУҐ : S}

structure FTheory (L : Logic вДХ) where
  protected theory : FormulaSet вДХ
  protected no_bot : вК• вИЙ theory
  protected andIR : вИА {ѕЖ ѕИ}, ѕЖ вИИ theory вЖТ ѕИ вИИ theory вЖТ ѕЖ вЛП ѕИ вИИ theory
  protected imp_closed : вИА {ѕЖ ѕИ}, L вКҐ ѕЖ вЮЭ ѕИ вЖТ ѕЖ вИИ theory вЖТ ѕИ вИИ theory
  protected L_subset : L вКЖ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {ѕЖ ѕИ ѕЗ : Formula вДХ}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hѕЖ : L вКҐ ѕЖ) : ѕЖ вИИ T.theorem := by
  apply T.imp_closed (ѕЖ := вК§) $ af hѕЖ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (hвВБ : ѕЖ вЮЭ ѕИ вИИ T.theorem) (hвВВ : ѕИ вЮЭ ѕЗ вИИ T.theorem) : ѕЖ вЮЭ ѕЗ вИИ T.theorem := by
  apply T.imp_closed (axiomI (ѕИ := ѕИ));
  apply T.andIR hвВБ hвВВ;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hѕЖ : ѕЖ вИИ T.theorem) : ѕЖ вЛО ѕИ вИИ T.theorem := by
  apply T.imp_closed (ѕЖ := ѕЖ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hѕИ : ѕИ вИИ T.theorem) : ѕЖ вЛО ѕИ вИИ T.theorem := by
  apply T.imp_closed (ѕЖ := ѕИ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ѕЖ вИИ T.theorem вЖФ Deduction Ax T.theorem ѕЖ := by
  constructor;
  . intro hѕЖ;
    apply Deduction.ctx hѕЖ;
  . intro h; induction h <;> grind

end FTheory


variable {L : Logic вДХ}

structure PrimeFTheory (L : Logic вДХ) extends FTheory L where
  protected prime : вИА {ѕЖ ѕИ}, ѕЖ вЛО ѕИ вИИ theory вЖТ ѕЖ вИИ theory вИ® ѕИ вИИ theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {ѕЖ ѕИ ѕЗ ќЊ : Formula вДХ} {T : FTheory L} {hT : ѕЗ вЮЭ ќЊ вИЙ T.theorem}

def construction (T : FTheory L) (hT : ѕЗ вЮЭ ќЊ вИЙ T.theorem) : вДХ вЖТ Set (Formula вДХ)
  | 0 => { ќі | ѕЗ вЮЭ ќі вИИ T.theorem }
  | i + 1 =>
    match (decode i) with
    | some ќі =>
      letI T' := construction T hT i
      if вИА ќУ : Finset (Formula _), вЖСќУ вКЖ T' вЖТ ќУ.conj вЛП ќі вЮЭ ќЊ вИЙ T.theorem then insert ќі T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : ѕЗ вЮЭ ќЊ вИЙ T.theorem) : Set (Formula вДХ) := вЛГ i, construction T hT i

lemma subset_construction_succ : construction T hT i вКЖ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i вКЖ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i вЙ§ j) : construction T hT i вКЖ construction T hT j := by
  obtain вЯ®k, rflвЯ© := le_iff_exists_add.mp hij;
  apply subset_construction_add;

lemma mem_omega_of_mem (h : ѕЗ вЮЭ ќі вИИ T.theorem) : ќі вИИ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion];
  use 0;
  simpa [construction];

lemma of_mem_construction_omega {ѕЖ : Formula вДХ} (hѕЖ : ѕЖ вИИ construction_omega T hT) :
  (ѕЗ вЮЭ ѕЖ вИИ T.theorem) вИ® (вИА ќУ : Finset _, вЖСќУ вКЖ construction T hT (encode ѕЖ) вЖТ ќУ.conj вЛП ѕЖ вЮЭ ќЊ вИЙ T.theorem) := by
  obtain вЯ®i, hiвЯ© := by simpa [construction_omega] using hѕЖ;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
    dsimp [construction] at hi;
    sorry;
    /-
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . grind;
      . assumption
    . assumption
    .dsimp [construction] at hi;
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . sorry;
        . assumption
      . assumption
    . assumption
    split at hi;
    -/

lemma not_of_mem_construction_omega {ѕЖ : Formula вДХ}
  {ќУ : Finset (Formula вДХ)} (hќУ : вЖСќУ вКЖ construction T hT (encode ѕЖ))
  (hѕЖ : ќУ.conj вЛП ѕЖ вЮЭ ќЊ вИИ T.theorem) :
  ѕЖ вИЙ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    sorry;
  | succ i ih =>
    simp [construction];
    split_ifs at ih with h;
    . rename_i ќі hќі;
      by_contra hC;
      have : ќі = ѕЖ := by grind;
      subst this;
      apply h ќУ ((show encode ќі = i by sorry) вЦЄ hќУ) hѕЖ;
    . assumption

lemma of_not_mem_construction_omega {ѕЖ : Formula вДХ} (hѕЖ : ѕЖ вИЙ construction_omega T hT) :
  (ѕЗ вЮЭ ѕЖ вИЙ T.theorem) вИІ (вИГ ќУ : Finset (Formula _), вЖСќУ вКЖ (construction T hT (encode ѕЖ)) вИІ ќУ.conj вЛП ѕЖ вЮЭ ќЊ вИИ T.theorem) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hѕЖ;
  constructor;
  . simpa using hѕЖ 0;
  . have this := hѕЖ (encode ѕЖ + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this;
    . simpa using h;


variable [Entailment.F L]

lemma construction_omega_mem_ant : ѕЗ вИИ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
  apply impId;

lemma construction_omega_not_mem_csq : ќЊ вИЙ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion, not_exists];
  intro i;
  induction i with
  | zero => simpa [construction];
  | succ i ih =>
    contrapose! ih;
    dsimp [construction] at ih;
    split at ih;
    . split_ifs at ih with h;
      . rename_i ќі hќі;
        have := h вИЕ (by tauto);
        contrapose! this;
        have : ќЊ = ќі := by grind;
        subst this;
        apply T.mem_of_provable;
        simp;
      . assumption;
    . assumption;

lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  ѕЖ вИИ U вЖТ ѕИ вИИ U вЖТ ѕЖ вЛП ѕИ вИИ U := by
  rintro hѕЖ hѕИ;
  by_contra hѕЖѕИ;
  replace вЯ®hѕЖѕИ, вЯ®ќУ, hќУвВБ, hќУвВВвЯ©вЯ© := of_not_mem_construction_omega hѕЖѕИ;

  sorry;

lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L вКҐ ѕЖ вЮЭ ѕИ вЖТ ѕЖ вИИ U вЖТ ѕИ вИИ U := by
  rintro hѕЖѕИ hѕЖ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ѕИ) + 1;
  simp [construction];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain вЯ®ќУ, hќУ, hќУвВВвЯ© := h;
