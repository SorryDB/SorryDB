      . assumption;
    . assumption;

lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  ѕЖ вИИ U вЖТ ѕИ вИИ U вЖТ ѕЖ вЛП ѕИ вИИ U := by
  rintro hѕЖ hѕИ;
  by_contra hѕЖѕИ;
  replace вЯ®hѕЖѕИ, вЯ®ќУ, hќУвВБ, hќУвВВвЯ©вЯ© := of_not_mem_construction_omega hѕЖѕИ;

