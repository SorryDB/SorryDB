open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {ќ± : Type*}
variable {S} [Entailment S (Formula ќ±)]
variable {рЭУҐ : S}

structure FTheory (L : Logic вДХ) where
  protected theory : FormulaSet вДХ
  protected no_bot : вК• вИЙ theory
  protected andIR : вИА {ѕЖ ѕИ}, ѕЖ вИИ theory вЖТ ѕИ вИИ theory вЖТ ѕЖ вЛП ѕИ вИИ theory
  protected imp_closed : вИА {ѕЖ ѕИ}, L вКҐ ѕЖ вЮЭ ѕИ вЖТ ѕЖ вИИ theory вЖТ ѕИ вИИ theory
  protected L_subset : L вКЖ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {ѕЖ ѕИ ѕЗ : Formula вДХ}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hѕЖ : L вКҐ ѕЖ) : ѕЖ вИИ T.theory := by
  apply T.imp_closed (ѕЖ := вК§) $ af hѕЖ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (hвВБ : ѕЖ вЮЭ ѕИ вИИ T.theory) (hвВВ : ѕИ вЮЭ ѕЗ вИИ T.theory) : ѕЖ вЮЭ ѕЗ вИИ T.theory := by
  apply T.imp_closed (axiomI (ѕИ := ѕИ));
  apply T.andIR hвВБ hвВВ;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hѕЖ : ѕЖ вИИ T.theory) : ѕЖ вЛО ѕИ вИИ T.theory := by
  apply T.imp_closed (ѕЖ := ѕЖ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hѕИ : ѕИ вИИ T.theory) : ѕЖ вЛО ѕИ вИИ T.theory := by
  apply T.imp_closed (ѕЖ := ѕИ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ѕЖ вИИ T.theory вЖФ Deduction Ax T.theory ѕЖ := by
  constructor;
  . intro hѕЖ;
    apply Deduction.ctx hѕЖ;
  . intro h; induction h <;> grind

end FTheory


