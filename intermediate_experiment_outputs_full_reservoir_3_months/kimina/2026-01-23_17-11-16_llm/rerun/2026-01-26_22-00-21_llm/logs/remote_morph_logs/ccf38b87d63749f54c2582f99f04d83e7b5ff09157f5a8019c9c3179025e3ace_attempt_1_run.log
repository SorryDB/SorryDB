    . assumption;

lemma of_not_mem_construction_omega {ѕЖ : Formula вДХ} (hѕЖ : ѕЖ вИЙ construction_omega T hT) :
  (ѕЗ вЮЭ ѕЖ вИЙ T.theory) вИІ (вИГ ќУ : Finset (Formula _), вЖСќУ вКЖ (construction T hT (encode ѕЖ)) вИІ ќУ.conj вЛП ѕЖ вЮЭ ќЊ вИИ T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hѕЖ;
  constructor;
  . simpa using hѕЖ 0;
  . have this := hѕЖ (encode ѕЖ + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this;
    . simpa using h;


variable [Entailment.F L]

lemma construction_omega_mem_ant : ѕЗ вИИ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
