    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . grind;
      . grind;
    . grind;
    split at hi;
    -/

lemma not_of_mem_construction_omega {ѕЖ : Formula вДХ}
  {ќУ : Finset (Formula вДХ)} (hќУ : вЖСќУ вКЖ construction T hT (encode ѕЖ))
  (hѕЖ : ќУ.conj вЛП ѕЖ вЮЭ ќЊ вИИ T.theory) :
  ѕЖ вИЙ (construction_omega T hT) := by
