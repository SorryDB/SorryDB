import Foundation.Propositional.Hilbert.F.Deduction
import Foundation.Propositional.Kripke2.Basic

namespace LO.Propositional

open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {ќ± : Type*}
variable {S} [Entailment S (Formula ќ±)]
variable {рЭУҐ : S}

structure FTheory (L : Logic вДХ) where
  protected theory : FormulaSet вДХ
  protected no_bot : вК• вИЙ theory
  protected andIR : вИА {ѕЖ ѕИ}, ѕЖ вИИ theory вЖТ ѕИ вИИ theory вЖТ ѕЖ вЛП ѕИ вИИ theory
  protected imp_closed : вИА {ѕЖ ѕИ}, L вКҐ ѕЖ вЮЭ ѕИ вЖТ ѕЖ вИИ theory вЖТ ѕИ вИИ theory
  protected L_subset : L вКЖ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {ѕЖ ѕИ ѕЗ : Formula вДХ}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hѕЖ : L вКҐ ѕЖ) : ѕЖ вИИ T.theory := by
  apply T.imp_closed (ѕЖ := вК§) $ af hѕЖ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (hвВБ : ѕЖ вЮЭ ѕИ вИИ T.theory) (hвВВ : ѕИ вЮЭ ѕЗ вИИ T.theory) : ѕЖ вЮЭ ѕЗ вИИ T.theory := by
  apply T.imp_closed (axiomI (ѕИ := ѕИ));
  apply T.andIR hвВБ hвВВ;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hѕЖ : ѕЖ вИИ T.theory) : ѕЖ вЛО ѕИ вИИ T.theory := by
  apply T.imp_closed (ѕЖ := ѕЖ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hѕИ : ѕИ вИИ T.theory) : ѕЖ вЛО ѕИ вИИ T.theory := by
  apply T.imp_closed (ѕЖ := ѕИ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ѕЖ вИИ T.theory вЖФ Deduction Ax T.theory ѕЖ := by
  constructor;
  . intro hѕЖ;
    apply Deduction.ctx hѕЖ;
  . intro h; induction h <;> grind

end FTheory


variable {L : Logic вДХ}

structure PrimeFTheory (L : Logic вДХ) extends FTheory L where
  protected prime : вИА {ѕЖ ѕИ}, ѕЖ вЛО ѕИ вИИ theory вЖТ ѕЖ вИИ theory вИ® ѕИ вИИ theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {ѕЖ ѕИ ѕЗ ќЊ : Formula вДХ} {T : FTheory L} {hT : ѕЗ вЮЭ ќЊ вИЙ T.theory}

def construction (T : FTheory L) (hT : ѕЗ вЮЭ ќЊ вИЙ T.theory) : вДХ вЖТ Set (Formula вДХ)
  | 0 => { ќі | ѕЗ вЮЭ ќі вИИ T.theory }
  | i + 1 =>
    match (decode i) with
    | some ќі =>
      letI T' := construction T hT i
      if вИА ќУ : Finset (Formula _), вЖСќУ вКЖ T' вЖТ ќУ.conj вЛП ќі вЮЭ ќЊ вИЙ T.theory then insert ќі T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : ѕЗ вЮЭ ќЊ вИЙ T.theory) : Set (Formula вДХ) := вЛГ i, construction T hT i

lemma subset_construction_succ : construction T hT i вКЖ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i вКЖ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i вЙ§ j) : construction T hT i вКЖ construction T hT j := by
  obtain вЯ®k, rflвЯ© := le_iff_exists_add.mp hij;
  apply subset_construction_add;

lemma mem_omega_of_mem (h : ѕЗ вЮЭ ќі вИИ T.theory) : ќі вИИ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion];
  use 0;
  simpa [construction];

lemma of_mem_construction_omega {ѕЖ : Formula вДХ} (hѕЖ : ѕЖ вИИ construction_omega T hT) :
  (ѕЗ вЮЭ ѕЖ вИИ T.theory) вИ® (вИА ќУ : Finset _, вЖСќУ вКЖ construction T hT (encode ѕЖ) вЖТ ќУ.conj вЛП ѕЖ вЮЭ ќЊ вИЙ T.theory) := by
  obtain вЯ®i, hiвЯ© := by simpa [construction_omega] using hѕЖ;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
