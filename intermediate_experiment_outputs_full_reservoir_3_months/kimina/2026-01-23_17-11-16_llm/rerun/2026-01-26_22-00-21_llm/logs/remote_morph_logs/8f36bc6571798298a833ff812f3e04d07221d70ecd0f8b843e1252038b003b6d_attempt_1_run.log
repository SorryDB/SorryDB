omit [DecidableEq őĪ] [MeasurableSingletonClass őĪ] in
lemma condDistrib_reward'' [StandardBorelSpace őĪ] [Nonempty őĪ] (n : ‚Ąē) :
    ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ arm n ŌČ.1; ūĚĒď]
      =ŠĶź[(ūĚĒďt).map (fun ŌČ ‚Ü¶ arm n ŌČ.1)] őĹ := by
  have h_ra' : ūĚďõ[reward n | arm n; ūĚĒďt] =ŠĶź[(ūĚĒďt).map (fun ŌČ ‚Ü¶ arm n ŌČ.1)] őĹ := condDistrib_reward alg őĹ n
  have h_law : (ūĚĒď).map (fun ŌČ ‚Ü¶ arm n ŌČ.1) = (ūĚĒďt).map (fun ŌČ ‚Ü¶ arm n ŌČ.1) := by
    rw [‚Üź Bandit.fst_measure, Measure.fst, Measure.map_map (by fun_prop) (by fun_prop)]
    rfl
  rw [h_law]
  have h_prod : ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ arm n ŌČ.1; ūĚĒď]
      =ŠĶź[(ūĚĒďt).map (fun ŌČ ‚Ü¶ arm n ŌČ.1)] ūĚďõ[reward n | arm n; ūĚĒďt] :=
    condDistrib_fst_prod _ (by fun_prop) _
  filter_upwards [h_ra', h_prod] with ŌČ h_eq h_prod
  rw [h_prod, h_eq]

