lemma hasLaw_Z (a : őĪ) (m : ‚Ąē) :
  HasLaw (fun ŌČ ‚Ü¶ ŌČ.2 m a) (őĹ a) (Bandit.measure alg őĹ) where
  map_eq := by
    calc (Bandit.measure alg őĹ).map (fun ŌČ ‚Ü¶ ŌČ.2 m a)
    _ = ((Bandit.measure alg őĹ).snd).map (fun ŌČ ‚Ü¶ ŌČ m a) := by
      rw [Measure.snd, Measure.map_map (by fun_prop) (by fun_prop)]
      rfl
    _ = (Bandit.streamMeasure őĹ).map (fun ŌČ ‚Ü¶ ŌČ m a) := by simp
    _ = ((Measure.infinitePi fun _ ‚Ü¶ Measure.infinitePi őĹ).map (fun ŌČ ‚Ü¶ ŌČ m)).map
        (fun ŌČ ‚Ü¶ ŌČ a) := by
      rw [Bandit.streamMeasure, Measure.map_map (by fun_prop) (by fun_prop)]
      rfl
    _ = őĹ a := by simp_rw [(measurePreserving_eval_infinitePi _ _).map_eq]

/-- Law of `Y` conditioned on the event `s`.-/
notation "ūĚďõ[" Y " | " s "; " őľ "]" => Measure.map Y (őľ[|s])
/-- Law of `Y` conditioned on the event that `X` is in `s`. -/
notation "ūĚďõ[" Y " | " X " in " s "; " őľ "]" => Measure.map Y (őľ[|X ‚ĀĽ¬Ļ' s])
/-- Law of `Y` conditioned on the event that `X` equals `x`. -/
notation "ūĚďõ[" Y " | " X " ‚Üź " x "; " őľ "]" => Measure.map Y (őľ[|X ‚ĀĽ¬Ļ' {x}])

local notation "ūĚĒďt" => Bandit.trajMeasure alg őĹ
local notation "ūĚĒď" => Bandit.measure alg őĹ

omit [DecidableEq őĪ] [MeasurableSingletonClass őĪ] in
lemma condDistrib_reward'' [StandardBorelSpace őĪ] [Nonempty őĪ] (n : ‚Ąē) :
    ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ arm n ŌČ.1; ūĚĒď]
      =ŠĶź[(ūĚĒď).map (fun ŌČ ‚Ü¶ arm n ŌČ.1)] őĹ := by
  have h_ra' : ūĚďõ[reward n | arm n; ūĚĒďt] =ŠĶź[(ūĚĒďt).map (arm n)] őĹ := condDistrib_reward alg őĹ n
  have h_law : (ūĚĒď).map (fun ŌČ ‚Ü¶ arm n ŌČ.1) = (ūĚĒďt).map (arm n) := by
    rw [‚Üź Bandit.fst_measure, Measure.fst, Measure.map_map (by fun_prop) (by fun_prop)]
    rfl
  rw [h_law]
  have h_prod : ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ arm n ŌČ.1; ūĚĒď]
      =ŠĶź[(ūĚĒďt).map (arm n)] ūĚďõ[reward n | arm n; ūĚĒďt] :=
    condDistrib_fst_prod _ (by fun_prop) _
  filter_upwards [h_ra', h_prod] with ŌČ h_eq h_prod
  rw [h_prod, h_eq]

omit [DecidableEq őĪ] in
lemma reward_cond_arm [StandardBorelSpace őĪ] [Nonempty őĪ] [Countable őĪ] (a : őĪ) (n : ‚Ąē)
    (hőľa : (ūĚĒď).map (fun ŌČ ‚Ü¶ arm n ŌČ.1) {a} ‚Č† 0) :
    ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ arm n ŌČ.1 ‚Üź a; ūĚĒď] = őĹ a := by
  have h_ra : ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ arm n ŌČ.1; ūĚĒď] =ŠĶź[(ūĚĒď).map (fun ŌČ ‚Ü¶ arm n ŌČ.1)] őĹ :=
    condDistrib_reward''
  have h_eq := condDistrib_ae_eq_cond (őľ := ūĚĒď)
    (X := fun ŌČ ‚Ü¶ arm n ŌČ.1) (Y := fun ŌČ ‚Ü¶ reward n ŌČ.1) (by fun_prop) (by fun_prop)
  rw [Filter.EventuallyEq, ae_iff_of_countable] at h_ra h_eq
  specialize h_ra a hőľa
  specialize h_eq a hőľa
  rw [h_ra] at h_eq
  exact h_eq.symm

-- after the Mathlib stopping time refactor, we will be able to prove that stepsUntil is a
-- stopping time
lemma measurable_comap_indicator_stepsUntil_eq (a : őĪ) (m n : ‚Ąē) :
    Measurable[MeasurableSpace.comap (fun ŌČ : ‚Ąē ‚Üí őĪ √ó ‚ĄĚ ‚Ü¶ (hist (n-1) ŌČ, arm n ŌČ)) inferInstance]
      ({ŌČ | stepsUntil a m ŌČ = ‚ÜĎn}.indicator fun _ ‚Ü¶ 1) := by
  let k : ((Iic (n - 1) ‚Üí őĪ √ó ‚ĄĚ) √ó őĪ) ‚Üí (‚Ąē ‚Üí őĪ √ó ‚ĄĚ) := fun x i ‚Ü¶
    if hi : i ‚ąą Iic (n - 1) then (x.1 ‚ü®i, hi‚ü©) else if i = n then (x.2, 0) else (a, 0)
  have hk : Measurable k := by
    unfold k
    rw [measurable_pi_iff]
    intro i
    split_ifs <;> fun_prop
  let ŌÜ : ((Iic (n - 1) ‚Üí őĪ √ó ‚ĄĚ) √ó őĪ) ‚Üí ‚Ąē := fun x ‚Ü¶ if stepsUntil a m (k x) = ‚ÜĎn then 1 else 0
  have hŌÜ : Measurable ŌÜ :=
    Measurable.ite ((measurableSet_singleton _).preimage (by fun_prop)) (by fun_prop) (by fun_prop)
  suffices {ŌČ | stepsUntil a m ŌČ = ‚ÜĎn}.indicator (fun x ‚Ü¶ 1)
      = ŌÜ ‚ąė fun ŌČ ‚Ü¶ (hist (n - 1) ŌČ, arm n ŌČ) from this ‚Ėł measurable_comp_comap _ hŌÜ
  ext ŌČ
  classical
  simp only [Set.indicator_apply, Set.mem_setOf_eq, Function.comp_apply, ŌÜ]
  congr 1
  rw [stepsUntil_eq_congr]
  intro i hin
  simp only [arm, mem_Iic, hist, dite_eq_ite, k, action]
  grind

lemma measurable_indicator_stepsUntil_eq (a : őĪ) (m n : ‚Ąē) :
    Measurable ({ŌČ : ‚Ąē ‚Üí őĪ √ó ‚ĄĚ | stepsUntil a m ŌČ = ‚ÜĎn}.indicator fun _ ‚Ü¶ 1) := by
  refine (measurable_comap_indicator_stepsUntil_eq a m n).mono ?_ le_rfl
  refine Measurable.comap_le ?_
  fun_prop

lemma measurableSet_stepsUntil_eq (a : őĪ) (m n : ‚Ąē) :
    MeasurableSet[MeasurableSpace.comap (fun ŌČ : ‚Ąē ‚Üí őĪ √ó ‚ĄĚ ‚Ü¶ (hist (n-1) ŌČ, arm n ŌČ)) inferInstance]
      {ŌČ : ‚Ąē ‚Üí őĪ √ó ‚ĄĚ | stepsUntil a m ŌČ = ‚ÜĎn} := by
  let mProd := MeasurableSpace.comap (fun ŌČ : ‚Ąē ‚Üí őĪ √ó ‚ĄĚ ‚Ü¶ (hist (n-1) ŌČ, arm n ŌČ)) inferInstance
  suffices Measurable[mProd] ({ŌČ | stepsUntil a m ŌČ = ‚ÜĎn}.indicator (fun x ‚Ü¶ 1)) by
    rwa [measurable_indicator_const_iff] at this
  exact measurable_comap_indicator_stepsUntil_eq a m n

lemma condIndepFun_reward_stepsUntil_arm' [StandardBorelSpace őĪ] [Countable őĪ] [Nonempty őĪ]
    (a : őĪ) (m n : ‚Ąē) (hm : m ‚Č† 0) :
    reward n ‚üāŠĶĘ[arm n, measurable_arm n; ūĚĒďt] {ŌČ | stepsUntil a m ŌČ = ‚ÜĎn}.indicator (fun _ ‚Ü¶ 1) := by
  -- the indicator of `stepsUntil ... = n` is a function of
  -- `hist (n-1)` and `arm n`.
  -- It thus suffices to prove the independence of `reward n` and `hist (n-1)` conditionally
  -- on `arm n`.
  by_cases hn : n = 0
  ¬∑ simp only [hn, CharP.cast_eq_zero]
    simp only [stepsUntil_eq_zero_iff, hm, ne_eq, false_and, false_or]
    by_cases hm1 : m = 1
    ¬∑ simp only [hm1, true_and]
      have h_indep := condIndepFun_self_right (X := reward 0) (Z := arm 0)
        (mő≤ := inferInstance) (mő≤' := inferInstance) (őľ := ūĚĒďt)
        (by fun_prop) (by fun_prop)
      have : {ŌČ : ‚Ąē ‚Üí őĪ √ó ‚ĄĚ | action 0 ŌČ = a}.indicator (fun _ ‚Ü¶ 1)
          = {b | b = a}.indicator (fun _ ‚Ü¶ 1) ‚ąė action 0 := by ext; simp [Set.indicator]
      rw [this]
      exact h_indep.comp measurable_id (by fun_prop)
    ¬∑ simp only [hm1, false_and, Set.setOf_false, Set.indicator_empty]
      exact condIndepFun_const_right (reward 0) 0
  have h_indep : reward n ‚üāŠĶĘ[arm n, measurable_arm n; ūĚĒďt] hist (n - 1) := by
    convert condIndepFun_reward_hist_arm (alg := alg) (őĹ := őĹ) (n - 1)
      <;> rw [Nat.sub_add_cancel (by grind)]
  have h_indep' : reward n ‚üāŠĶĘ[arm n, measurable_arm n; ūĚĒďt] fun ŌČ ‚Ü¶ (hist (n - 1) ŌČ, arm n ŌČ) :=
    h_indep.prod_right (by fun_prop) (by fun_prop) (by fun_prop)
  obtain ‚ü®ŌÜ, hŌÜ_meas, h_eq‚ü© : ‚ąÉ ŌÜ : ((Iic (n - 1) ‚Üí őĪ √ó ‚ĄĚ) √ó őĪ) ‚Üí ‚Ąē, Measurable ŌÜ ‚ąß
      {ŌČ | stepsUntil a m ŌČ = ‚ÜĎn}.indicator (fun _ ‚Ü¶ 1) = ŌÜ ‚ąė (fun ŌČ ‚Ü¶ (hist (n - 1) ŌČ, arm n ŌČ)) :=
    (measurable_comap_indicator_stepsUntil_eq a m n).exists_eq_measurable_comp
  rw [h_eq]
  exact h_indep'.comp measurable_id hŌÜ_meas

lemma condIndepFun_reward_stepsUntil_arm [StandardBorelSpace őĪ] [Countable őĪ] [Nonempty őĪ]
    (a : őĪ) (m n : ‚Ąē) (hm : m ‚Č† 0) :
    CondIndepFun (mőĪ.comap (fun ŌČ ‚Ü¶ arm n ŌČ.1)) ((measurable_arm n).comp measurable_fst).comap_le
      (fun ŌČ ‚Ü¶ reward n ŌČ.1) ({ŌČ | stepsUntil a m ŌČ.1 = ‚ÜĎn}.indicator (fun _ ‚Ü¶ 1)) ūĚĒď :=
  condIndepFun_fst_prod (őĹ := Bandit.streamMeasure őĹ)
    (measurable_indicator_stepsUntil_eq a m n) (by fun_prop) (by fun_prop)
    (condIndepFun_reward_stepsUntil_arm' a m n hm)

lemma reward_cond_stepsUntil [StandardBorelSpace őĪ] [Countable őĪ] [Nonempty őĪ] (a : őĪ) (m n : ‚Ąē)
    (hm : m ‚Č† 0) (hőľn : ūĚĒď ((fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1) ‚ĀĽ¬Ļ' {‚ÜĎn}) ‚Č† 0) :
    ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1 ‚Üź (n : ‚Ąē‚ąě); ūĚĒď] = őĹ a := by
  have hőľna :
      ūĚĒď ((fun ŌČ : (‚Ąē ‚Üí őĪ √ó ‚ĄĚ) √ó (‚Ąē ‚Üí őĪ ‚Üí ‚ĄĚ) ‚Ü¶
          stepsUntil a m ŌČ.1) ‚ĀĽ¬Ļ' {‚ÜĎn} ‚ą© (fun ŌČ ‚Ü¶ arm n ŌČ.1) ‚ĀĽ¬Ļ' {a}) ‚Č† 0 := by
    suffices ((fun ŌČ : (‚Ąē ‚Üí őĪ √ó ‚ĄĚ) √ó (‚Ąē ‚Üí őĪ ‚Üí ‚ĄĚ) ‚Ü¶
          stepsUntil a m ŌČ.1) ‚ĀĽ¬Ļ' {‚ÜĎn} ‚ą© (fun ŌČ ‚Ü¶ arm n ŌČ.1) ‚ĀĽ¬Ļ' {a})
        = (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1) ‚ĀĽ¬Ļ' {‚ÜĎn} by simpa [this] using hőľn
    ext ŌČ
    simp only [Set.mem_inter_iff, Set.mem_preimage, Set.mem_singleton_iff, and_iff_left_iff_imp]
    exact arm_eq_of_stepsUntil_eq_coe hm
  have hőľa : (ūĚĒď).map (fun ŌČ ‚Ü¶ arm n ŌČ.1) {a} ‚Č† 0 := by
    rw [Measure.map_apply (by fun_prop) (measurableSet_singleton _)]
    refine fun h_zero ‚Ü¶ hőľn (measure_mono_null (fun ŌČ ‚Ü¶ ?_) h_zero)
    simp only [Set.mem_preimage, Set.mem_singleton_iff]
    exact arm_eq_of_stepsUntil_eq_coe hm
  calc ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1 ‚Üź (n : ‚Ąē‚ąě); ūĚĒď]
  _ = (ūĚĒď[|(fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1) ‚ĀĽ¬Ļ' {‚ÜĎn} ‚ą© (fun ŌČ ‚Ü¶ arm n ŌČ.1) ‚ĀĽ¬Ļ' {a}]).map
      (fun ŌČ ‚Ü¶ reward n ŌČ.1) := by
    congr with ŌČ
    simp only [Set.mem_preimage, Set.mem_singleton_iff, Set.mem_inter_iff, iff_self_and]
    exact arm_eq_of_stepsUntil_eq_coe hm
  _ = (ūĚĒď[|(fun ŌČ ‚Ü¶ arm n ŌČ.1) ‚ĀĽ¬Ļ' {a}
      ‚ą© {ŌČ : (‚Ąē ‚Üí őĪ √ó ‚ĄĚ) √ó (‚Ąē ‚Üí őĪ ‚Üí ‚ĄĚ) | stepsUntil a m ŌČ.1 = ‚ÜĎn}.indicator 1 ‚ĀĽ¬Ļ' {1} ]).map
      (fun ŌČ ‚Ü¶ reward n ŌČ.1) := by
    congr 2 with ŌČ
    simp only [Set.mem_inter_iff, Set.mem_preimage, Set.mem_singleton_iff, Set.indicator_apply,
      Set.mem_setOf_eq, Pi.one_apply, ite_eq_left_iff, zero_ne_one, imp_false, Decidable.not_not]
    rw [and_comm]
  _ = ūĚďõ[fun ŌČ ‚Ü¶ reward n ŌČ.1 | fun ŌČ ‚Ü¶ arm n ŌČ.1 ‚Üź a; ūĚĒď] := by
    rw [cond_of_indepFun (by fun_prop)]
    ¬∑ exact condIndepFun_reward_stepsUntil_arm a m n hm
    ¬∑ refine measurable_one.indicator ?_
      exact measurableSet_eq_fun (by fun_prop) (by fun_prop)
    ¬∑ fun_prop
    ¬∑ convert hőľna using 2
      rw [Set.inter_comm]
      congr 1 with ŌČ
      simp [Set.indicator_apply]
  _ = őĹ a := reward_cond_arm a n hőľa

lemma condDistrib_rewardByCount_stepsUntil [Countable őĪ] [StandardBorelSpace őĪ] [Nonempty őĪ]
    (a : őĪ) (m : ‚Ąē) (hm : m ‚Č† 0) :
    condDistrib (rewardByCount a m) (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1) ūĚĒď
      =ŠĶź[(ūĚĒď).map (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1)] Kernel.const _ (őĹ a) := by
  refine (condDistrib_ae_eq_cond (őľ := ūĚĒď)
    (X := fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1) (by fun_prop) (by fun_prop)).trans ?_
  rw [Filter.EventuallyEq, ae_iff_of_countable]
  intro n hn
  simp only [Kernel.const_apply]
  cases n with
  | top =>
    rw [Measure.map_congr (g := fun ŌČ ‚Ü¶ ŌČ.2 m a)]
    swap
    ¬∑ refine ae_cond_of_forall_mem ((measurableSet_singleton _).preimage (by fun_prop)) ?_
      simp only [Set.mem_preimage, Set.mem_singleton_iff]
      exact fun ŌČ ‚Ü¶ rewardByCount_of_stepsUntil_eq_top
    rw [cond_of_indepFun _ (by fun_prop) (by fun_prop) (measurableSet_singleton _)]
    ¬∑ exact (hasLaw_Z a m).map_eq
    ¬∑ rwa [Measure.map_apply (by fun_prop) (measurableSet_singleton _)] at hn
    ¬∑ exact indepFun_prod (X := fun ŌČ : ‚Ąē ‚Üí őĪ √ó ‚ĄĚ ‚Ü¶ stepsUntil a m ŌČ)
        (Y := fun ŌČ : ‚Ąē ‚Üí őĪ ‚Üí ‚ĄĚ ‚Ü¶ ŌČ m a) (by fun_prop) (by fun_prop)
  | coe n =>
    rw [Measure.map_congr (g := fun ŌČ ‚Ü¶ reward n ŌČ.1)]
    swap
    ¬∑ refine ae_cond_of_forall_mem ((measurableSet_singleton _).preimage (by fun_prop)) ?_
      simp only [Set.mem_preimage, Set.mem_singleton_iff]
      exact fun ŌČ ‚Ü¶ rewardByCount_of_stepsUntil_eq_coe
    refine reward_cond_stepsUntil a m n hm ?_
    rwa [Measure.map_apply (by fun_prop) (measurableSet_singleton _)] at hn

/-- The reward received at the `m`-th pull of arm `a` has law `őĹ a`. -/
lemma hasLaw_rewardByCount [Countable őĪ] [StandardBorelSpace őĪ] [Nonempty őĪ]
    (a : őĪ) (m : ‚Ąē) (hm : m ‚Č† 0) :
    HasLaw (rewardByCount a m) (őĹ a) ūĚĒď where
  map_eq := by
    have h_condDistrib :
        condDistrib (rewardByCount a m) (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1) ūĚĒď
        =ŠĶź[(ūĚĒď).map (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1)]
          Kernel.const _ (őĹ a) := condDistrib_rewardByCount_stepsUntil a m hm
    calc (ūĚĒď).map (rewardByCount a m)
    _ = (condDistrib (rewardByCount a m) (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1) ūĚĒď)
        ‚ąė‚āė ((ūĚĒď).map (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1)) := by
      rw [condDistrib_comp_map (by fun_prop) (by fun_prop)]
    _ = (Kernel.const _ (őĹ a)) ‚ąė‚āė ((ūĚĒď).map (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1)) :=
      Measure.comp_congr h_condDistrib
    _ = őĹ a := by
      have : IsProbabilityMeasure ((ūĚĒď).map (fun ŌČ ‚Ü¶ stepsUntil a m ŌČ.1)) :=
        Measure.isProbabilityMeasure_map (by fun_prop)
      simp

lemma identDistrib_rewardByCount [Countable őĪ] [StandardBorelSpace őĪ] [Nonempty őĪ] (a : őĪ) (n m : ‚Ąē)
    (hn : n ‚Č† 0) (hm : m ‚Č† 0) :
    IdentDistrib (rewardByCount a n) (rewardByCount a m) ūĚĒď ūĚĒď where
  aemeasurable_fst := by fun_prop
  aemeasurable_snd := by fun_prop
  map_eq := by rw [(hasLaw_rewardByCount a n hn).map_eq, (hasLaw_rewardByCount a m hm).map_eq]

lemma identDistrib_rewardByCount_id [Countable őĪ] [StandardBorelSpace őĪ] [Nonempty őĪ]
    (a : őĪ) (n : ‚Ąē) (hn : n ‚Č† 0) :
    IdentDistrib (rewardByCount a n) id ūĚĒď (őĹ a) where
  aemeasurable_fst := by fun_prop
  aemeasurable_snd := Measurable.aemeasurable <| by fun_prop
  map_eq := by rw [(hasLaw_rewardByCount a n hn).map_eq, Measure.map_id]

lemma identDistrib_rewardByCount_eval [Countable őĪ] [StandardBorelSpace őĪ] [Nonempty őĪ]
    (a : őĪ) (n m : ‚Ąē) (hn : n ‚Č† 0) :
    IdentDistrib (rewardByCount a n) (fun ŌČ ‚Ü¶ ŌČ m a) ūĚĒď (Bandit.streamMeasure őĹ) :=
  (identDistrib_rewardByCount_id a n hn).trans (identDistrib_eval_eval_id_streamMeasure őĹ m a).symm

lemma iIndepFun_rewardByCount' (alg : Algorithm őĪ ‚ĄĚ) (őĹ : Kernel őĪ ‚ĄĚ) [IsMarkovKernel őĹ] (a : őĪ) :
    iIndepFun (rewardByCount a) (Bandit.measure alg őĹ) := by
  rw [iIndepFun_nat_iff_forall_indepFun (by fun_prop)]
  exact fun n hn ‚Ü¶ indepFun_rewardByCount_Iic alg őĹ a n

lemma iIndepFun_rewardByCount (alg : Algorithm őĪ ‚ĄĚ) (őĹ : Kernel őĪ ‚ĄĚ) [IsMarkovKernel őĹ] :
    iIndepFun (fun (p : őĪ √ó ‚Ąē) ‚Ü¶ rewardByCount p.1 p.2) ūĚĒď := by
  sorry
```

We need to prove `iIndepFun (fun p => rewardByCount p.1 p.2) (Bandit.measure alg őĹ)`.
The definition of `iIndepFun` for a function `f : ‚Ąē ‚Üí ő© ‚Üí X` and a measure `őľ` is `‚ąÄ n, f n` is independent of `f k` for `k ‚Č† n`.

Looking at the code, we have a lemma `iIndepFun_rewardByCount'` which proves `iIndepFun (rewardByCount a) (Bandit.measure alg őĹ)` for a fixed `a`. We need to prove `iIndepFun (fun p => rewardByCount p.1 p.2) (Bandit.measure alg őĹ)`.

Let's see if we can derive the required `iIndepFun` property from `iIndepFun_rewardByCount'`.

```tactics
import LeanBandits.Bandit.Regret
import LeanBandits.ForMathlib.IndepFun
import Mathlib.Probability.IdentDistribIndep

/-! # Laws of `stepsUntil` and `rewardByCount`
-/

open MeasureTheory ProbabilityTheory Finset Learning
open scoped ENNReal NNReal

