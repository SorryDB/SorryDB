lemma integrable_pullCount {alg : Algorithm őĪ ‚ĄĚ} {őĹ : Kernel őĪ ‚ĄĚ} [IsMarkovKernel őĹ]
    (a : őĪ) (n : ‚Ąē) :
    Integrable (fun ŌČ ‚Ü¶ (pullCount a n ŌČ : ‚ĄĚ)) (Bandit.trajMeasure alg őĹ) := by
  refine integrable_of_le_of_le (g‚āĀ := 0) (g‚āā := fun _ ‚Ü¶ n) (by fun_prop)
    (ae_of_all _ fun ŌČ ‚Ü¶ by simp) (ae_of_all _ fun ŌČ ‚Ü¶ ?_) (integrable_const _) (integrable_const _)
  simp only [Nat.cast_le]
