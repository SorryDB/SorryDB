  simp [Integrable, MeasureTheory.volumeOnℚ]
  all_goals norm_num

lemma Integrable (fun (x : ℚ) ↦ (x : ℝ) ^ 2) MeasureTheory.volumeOnℚ : Integrable (fun (x : ℚ) ↦ (x : ℝ) ^ 2) MeasureTheory.volumeOnℚ := by
  simp [Integrable, MeasureTheory.volumeOnℚ]
