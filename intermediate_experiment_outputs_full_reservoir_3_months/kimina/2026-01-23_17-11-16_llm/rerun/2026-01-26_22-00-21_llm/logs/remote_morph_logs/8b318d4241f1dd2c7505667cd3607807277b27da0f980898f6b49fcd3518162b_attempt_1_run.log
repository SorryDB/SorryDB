import Mathlib

open Nat

namespace Factorization

structure Factorization (n : ℕ) where
  a : Multiset ℕ
  ha : ∀ m ∈ a, m ∣ n
  hpos : ∀ m ∈ a, m > 0
  score : ℕ → ℕ
  total_imbalance : ℕ

lemma score_eq {f : Factorization n} (hf : f.isBalanced) (L : ℕ) : f.score L = f.waste := by
  simp_all [isBalanced_iff_total_imbalance_eq_zero, score, waste, Multiset.sum_map]
  <;> try { aesop }
  <;> try { tauto }
  <;> try { omega }

lemma waste_eq {f : Factorization n} (hf : f.isBalanced) : f.waste = f.a.card * log n := by
  simp_all [isBalanced_iff_total_imbalance_eq_zero, waste, Multiset.sum_map]
  <;> try { aesop }
  <;> try { tauto }
  <;> try { omega }
  all_goals try { linarith }
  all_goals try { tauto }

theorem lower_score_1 {n : ℕ} (f : Factorization n) (L : ℕ)
    (h : ∃ p ∈ (n + 1).primesBelow, p > L ∧ f.balance p > 0) : ∃ f' :
