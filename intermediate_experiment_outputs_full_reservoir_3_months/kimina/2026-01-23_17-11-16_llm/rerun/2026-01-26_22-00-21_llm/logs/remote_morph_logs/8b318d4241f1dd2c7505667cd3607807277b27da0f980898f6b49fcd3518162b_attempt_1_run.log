/- The `score` of a factorization with respect to a bound `L` is the sum of the exponents
of primes `p ≤ L` in the factorization. -/
noncomputable def Factorization.score (f : Factorization n) (L : ℕ) :=
  f.support.filter (fun p => p ≤ L).sum (fun p hp => f p)

/- A `Factorization` of a natural number `n` is a function from prime numbers to
natural numbers representing the exponent of each prime in the factorization of
`n`. The function is required to be zero for primes greater than `n`. -/
structure Factorization (n : ℕ) : Type (u + 1) where
  a : ℕ → ℕ
  ha : ∀ m, m.Prime → m > n → a m = 0
