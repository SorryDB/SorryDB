  have h1 : ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ = ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ := rfl
  have h2 : ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ := by
    have h3 : ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ = ‚ÄĖcfc_toLinearFunctional ha x y‚ÄĖ := by
