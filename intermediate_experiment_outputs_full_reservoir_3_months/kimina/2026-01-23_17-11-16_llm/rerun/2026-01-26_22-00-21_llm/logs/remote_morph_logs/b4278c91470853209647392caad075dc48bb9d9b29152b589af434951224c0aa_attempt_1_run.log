      apply norm_le_iff.mpr
      constructor
      ¬∑ -- Show - (‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * ‚ÄĖf‚ÄĖ) ‚Č§ ‚ü®x, (cfcHom ha.isStarNormal f)y‚ü©_‚Ąā
        simp [inner_le_norm, norm_nonneg]
        all_goals try { nlinarith [cfc_toLinearFunctional_bound x y, norm_nonneg (f : C((spectrum ‚Ąā a), ‚Ąā) ‚ÜíL[‚Ąā] H), norm_nonneg x, norm_nonneg y] }
