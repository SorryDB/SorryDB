  have h1 : (cfc_toComplexMeasure ha x y).integral f = ‚ü™x, (cfcHom ha.isStarNormal f)y‚üę_‚Ąā := by
    simp only [cfc_toComplexMeasure, ComplexRMK.rieszMeasure_apply, compSL_apply]
    all_goals try { tauto }
  rw [h1]
  have h2 : ‚ÄĖ‚ü™x, (cfcHom ha.isStarNormal f)y‚üę_‚Ąā‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * C := by
