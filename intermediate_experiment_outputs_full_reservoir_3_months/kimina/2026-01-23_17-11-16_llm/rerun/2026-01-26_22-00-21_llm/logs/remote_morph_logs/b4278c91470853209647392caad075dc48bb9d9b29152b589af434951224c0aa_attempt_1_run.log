    have h4 : ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ = ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ := rfl
    have h5 : ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ = ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ := rfl
    have h6 : ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ := h2
    have h7 : (cfc_toComplexMeasure ha x y).variation Set.univ ‚Č§ ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ := by
