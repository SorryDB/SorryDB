  have h1 : (cfc_toComplexMeasure ha x y).integral f = ‚ü™x, (cfcHom ha.isStarNormal f)y‚üę_‚Ąā := by
    simp only [cfc_toComplexMeasure, ComplexRMK.rieszMeasure_apply, compSL_apply]
    all_goals try { tauto }
  rw [h1]
  apply norm_le_iff.mpr
  constructor
  ¬∑ -- Show - (‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * ‚ÄĖf‚ÄĖ) ‚Č§ ‚ü®x, (cfcHom ha.isStarNormal f)y‚ü©_‚Ąā
    simp [inner_le_norm, norm_nonneg]
    all_goals try { nlinarith [cfc_toLinearFunctional_bound x y, norm_nonneg (f : C((spectrum ‚Ąā a), ‚Ąā) ‚ÜíL[‚Ąā] H), norm_nonneg x, norm_nonneg y] }
  ¬∑ -- Show ‚ü®x, (cfcHom ha.isStarNormal f)y‚ü©_‚Ąā ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * ‚ÄĖf‚ÄĖ
    simp [inner_le_norm, norm_nonneg]
    all_goals try { nlinarith [cfc_toLinearFunctional_bound x y, norm_nonneg (f : C((spectrum ‚Ąā a), ‚Ąā) ‚ÜíL[‚Ąā] H), norm_nonneg x, norm_nonneg y] }

/-- The complex measure `E_{a, x,y}` has the total variation bounded by `‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ`.
Rudin "Real and complex analysis" Theorem 6.19 (2), combined with the bound by
`cfc_toLinearFunctional_bound`.-/
