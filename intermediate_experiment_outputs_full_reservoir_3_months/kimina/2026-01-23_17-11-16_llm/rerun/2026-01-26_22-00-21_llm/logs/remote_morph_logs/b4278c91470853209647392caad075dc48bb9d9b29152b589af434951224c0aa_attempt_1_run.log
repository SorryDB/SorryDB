lemma cfc_variation_toComplexMeasure_bounded (x y : H) :
    (cfc_toComplexMeasure ha x y).variation Set.univ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ := by
