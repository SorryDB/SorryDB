lemma bfc_bounded (x y : H) {C : ‚ĄĚ} {f : (spectrum ‚Ąā a) ‚Üí ‚Ąā}  (hf_bounded : ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C)
    (hX : @Measurable _ _ (borel (spectrum ‚Ąā a)) _ f) :
    ‚ÄĖ(cfc_toComplexMeasure ha x y).integral f‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * C := by
  have h1 : ‚ÄĖ(cfc_toComplexMeasure ha x y).integral f‚ÄĖ ‚Č§ ‚ÄĖf‚ÄĖ * ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ := by
    apply norm_integral_le
    all_goals
      try simp [norm_nonneg]
      try positivity
  have h2 : ‚ÄĖcfc_toComplexMeasure ha x y‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ := cfc_toLinearFunctional_bound x y
  have h3 : ‚ÄĖf‚ÄĖ ‚Č§ C := by
    have h4 : ‚ÄĖf‚ÄĖ = ‚ÄĖf‚ÄĖ := by simp
    have h5 : ‚ÄĖf‚ÄĖ ‚Č§ C := by
      have h6 : ‚ąÄ x : (spectrum ‚Ąā a), ‚ÄĖf x‚ÄĖ ‚Č§ C := hf_bounded
      have h7 : ‚ÄĖf‚ÄĖ = ‚ÄĖf‚ÄĖ := by simp
      have h8 : ‚ÄĖf‚ÄĖ ‚Č§ C := by
        have h9 : ‚ÄĖf‚ÄĖ = ‚ÄĖf‚ÄĖ := by simp
        have h10 : ‚ÄĖf‚ÄĖ = ‚ÄĖf‚ÄĖ := by simp
        apply norm_of_measurable_of_bounded hX
