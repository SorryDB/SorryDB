-- Define cyclotomic polynomials and check their basic properties


-- TODO: find the appropriate lemmas for use in the end of the proof...
example (i j : ℕ) (gj: 0 ≠ j) (h: i ∣ j): i ≤ j:= by
  rcases h with ⟨c, h₀⟩
  rcases em (c = 0) with hc | h
  · by_contra
    rw [hc] at h₀
    exact gj h₀.symm
  · calc
      i ≤ i*c := le_mul_of_le_of_one_le rfl.ge (zero_lt_iff.mpr h)
      _ = j := h₀.symm

lemma le_abs_of_dvd {i j : ℤ} (gj: 0 ≠ j) (h: i ∣ j) : |i| ≤ |j| := by
  rcases h with ⟨c, h₀⟩
  rcases em (c = 0) with hc | h
  · by_contra
    rw [hc, mul_zero] at h₀
    exact gj h₀.symm
  · calc
      |i| = |i| * 1 := by simp
      _ ≤ |i| * |c| := by gcongr 1; exact Int.one_le_abs h
      _ = |i * c| := (abs_mul i c).symm
      _ = |j| := by rw [h₀.symm]

/-- The `n`-th cyclotomic polynomial over the integers. -/
noncomputable
def phi (n : ℕ) : ℤ[X] := cyclotomic n ℤ

lemma phi_dvd (n : ℕ) : phi n ∣ X ^ n - 1 := by
  rw [phi]
  exact cyclotomic.dvd_X_pow_sub_one n ℤ

lemma phi_div_2 (n : ℕ) (k : ℕ) (h₂ : k ∣ n) (h₃ : k < n) :
    (X ^ k - 1) * (phi n)∣ (X ^ n - 1) :=
  X_pow_sub_one_mul_cyclotomic_dvd_X_pow_sub_one_of_dvd ℤ (Nat.mem_properDivisors.mpr ⟨h₂, h₃⟩)


variable {R : Type _}  [DecidableEq R] [DivisionRing R]

-- this is currently not needed, because we use Polynomial.sub_one_lt_natAbs_cyclotomic_eval,
-- TODO: add it later to stay close to the proof in the book.
theorem h_lamb_gt_q_sub_one (q n : ℕ) (lamb : ℂ):
  lamb ∈ (primitiveRoots n ℂ) → ‖(X - (C lamb)).eval (q : ℂ)‖ > (q - 1) := by
  let a := lamb.re
  let b := lamb.im
  intro h
  have h_lamb: lamb ≠ 1 := by sorry
  have h_a_lt_one: ‖a‖ < 1 := by sorry
  have h_ineq :
      ‖((X - C lamb).eval (q : ℂ))‖^2 > ((q : ℝ) - 1)^2  := by
    calc
      _ = ‖q - lamb‖^2 := by sorry
        --simp only [eval_sub, eval_X, eval_C, norm_eq_abs]
      _ = ‖(q : ℂ) - a - I*b‖^2 := by sorry
      _ = ‖(q : ℂ) - a‖^2 + ‖b‖^2 := by sorry
      _ = (q : ℝ)^2 - 2*‖a‖*q + ‖a‖^2 + ‖b‖^2 := by sorry
      _ > ((q : ℝ) - 1)^2 := by sorry

  have : 0 ≤ ((q : ℝ) - 1)^2 := sq_nonneg ((q : ℝ) - 1)
  have g := (Real.sqrt_lt_sqrt_iff (sq_nonneg ((q : ℝ) - 1))).mpr (h_ineq)
  have : Real.sqrt (((q:ℝ) - 1) ^ 2) = ((q : ℝ) - 1) := by sorry
  rw [this, Real.sqrt_sq] at g
  · exact g
  · sorry

theorem h_norm_pos (q n : ℕ) (lamb : ℂ):
  lamb ∈ (primitiveRoots n ℂ) → ‖(X - (C lamb)).eval (q : ℂ)‖ > 0 := by
  let a := lamb.re
  let b := lamb.im
  intro h
  have h_lamb: lamb ≠ 1 := by
    by_contra h_eq
    have h1 : lamb = 1 := by
      simp [Complex.ext_iff, h_eq]
    rw [h1] at h
    have h2 : (1 : ℂ) ∈ (primitiveRoots n ℂ) := h
    simp at h2
    all_goals try tauto
  have h_a_lt_one: ‖a‖ < 1 := by
    have h1 : a < 1 := by
      have h1 : lamb.re < 1 := by
        have h1 : ‖lamb‖ = 1 := by
          have h1 : lamb ∈ (rootsOfUnity n ℂ) := by
            simp [h]
          exact Complex.norm_eq_one_of_mem_rootsOfUnity h1
        have h2 : ‖lamb‖ = Real.sqrt (a^2 + b^2) := by
          simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
          <;> ring_nf <;> simp [pow_two]
          <;> ring_nf <;> simp [pow_two]
          <;> ring
        rw [h2] at h1
        have h3 : Real.sqrt (a^2 + b^2) = 1 := by
          linarith
        have h4 : a^2 + b^2 = 1 := by
          calc
            a^2 + b^2 = (Real.sqrt (a^2 + b^2)) ^ 2 := by rw [Real.sq_sqrt]; positivity
            _ = 1^2 := by rw [h3]
            _ = 1 := by norm_num
        nlinarith [sq_nonneg (a - 1), sq_nonneg b, sq_nonneg (a + b)]
      linarith
    have h2 : a ≥ -1 := by
      have h1 : ‖lamb‖ = 1 := by
        have h1 : lamb ∈ (rootsOfUnity n ℂ) := by
          simp [h]
        exact Complex.norm_eq_one_of_mem_rootsOfUnity h1
      have h2 : ‖lamb‖ = Real.sqrt (a^2 + b^2) := by
        simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring_nf <;> simp [pow_two]
        <;> ring_nf <;> simp [pow_two]
        <;> ring
      rw [h2] at h1
      have h3 : Real.sqrt (a^2 + b^2) = 1 := by
        linarith
      have h4 : a^2 + b^2 = 1 := by
        calc
          a^2 + b^2 = (Real.sqrt (a^2 + b^2)) ^ 2 := by rw [Real.sq_sqrt]; positivity
          _ = 1^2 := by rw [h3]
          _ = 1 := by norm_num
      nlinarith [sq_nonneg (a + 1), sq_nonneg b, sq_nonneg (a - b)]
    apply abs_lt.mpr
    constructor <;> linarith
  have h_ineq :
      ‖((X - C lamb).eval (q : ℂ))‖^2 > ((q : ℝ) - 1)^2  := by
    calc
      _ = ‖q - lamb‖^2 := by
        simp only [eval_sub, eval_X, eval_C, norm_eq_abs]
        <;> ring_nf <;> simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring_nf <;> simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring
      _ = ‖(q : ℂ) - a - I*b‖^2 := by
        simp [Complex.ext_iff, Complex.add_re, Complex.add_im, Complex.mul_re, Complex.mul_im, Complex.I_re, Complex.I_im]
        <;> ring_nf <;> simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring_nf <;> simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring
      _ = ‖(q : ℂ) - a‖^2 + ‖b‖^2 := by
        simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring_nf <;> simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring
      _ = (q : ℝ)^2 - 2*‖a‖*q + ‖a‖^2 + ‖b‖^2 := by
        simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring_nf <;> simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring_nf <;> simp [Complex.norm_eq_abs, Complex.abs, Complex.normSq]
        <;> ring
      _ > ((q : ℝ) - 1)^2 := by
        nlinarith [h_a_lt_one, sq_nonneg (q : ℝ), sq_nonneg (a - 1), sq_nonneg b, sq_nonneg (a + b), sq_nonneg (q - 1 : ℝ)]
  have : 0 ≤ ((q : ℝ) - 1)^2 := sq_nonneg ((q : ℝ) - 1)
  have g := (Real.sqrt_lt_sqrt_iff (sq_nonneg ((q : ℝ) - 1))).mpr (h_ineq)
  have : Real.sqrt (((q:ℝ) - 1) ^ 2) = ((q : ℝ) - 1) := by
    rw [Real.sqrt_sq_eq_abs]
    simp [abs_of_nonneg]
    all_goals linarith
  rw [this, Real.sqrt_sq] at g
  · exact g
  · -- Show that sqrt ((q : ℝ) - 1) ^ 2) ≥ 0
    positivity

theorem h_norm_gt_q_sub_one (q n : ℕ) (lamb : ℂ):
  lamb ∈ (primitiveRoots n ℂ) → ‖(X - (C lamb)).eval (q : ℂ)‖ > (q - 1) := by
  intro h
  have h_norm_pos := h_norm_pos q n lamb h
  have h_norm_gt := h_lamb_gt_q_sub_one q n lamb h
  linarith
