      apply Logic.iff_provable.mp;
      apply iff_of_true_left
      apply T.mem_of_provable
      apply Iff.mpr (iff_of_true_left (by tauto))
      apply hφψ
    have : (Γ.conj ⋏ φ) ➝ ξ ∈ T.theory := T.imp_closed axiomI $ T.andIR h₂ h₁;
    have : (Γ.conj ⋏ φ) ➝ ξ ∈ construction_omega T hT := by
      simpa [construction_omega, Set.mem_iUnion]
      using ⟨(encode ψ + 1), this⟩;
    assumption;

lemma construction_omega_L_subset :
  letI U := construction_omega T hT
  L ⊆ U := by
  intro φ hφ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode φ + 1);
  simp only [construction, encodek];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain ⟨Γ, hΓ, h₁⟩ := h;
    have h₂ : (Γ.conj ⋏ φ) ∈ T.theory := T.mem_of_provable $ by
      apply Iff.mpr (iff_of_true_left (by tauto))
      apply hφ
    have : (Γ.conj ⋏ φ) ∈ construction_omega T hT := by
      simpa [construction_omega, Set.mem_iUnion]
      using ⟨(encode φ + 1), h₂⟩;
    assumption;

lemma construction_omega_prime :
  letI U := construction_omega T hT
  φ ⋎ ψ ∈ U → φ ∈ U ∨ ψ ∈ U := by
  rintro hφψ;
  by_contra! hC;
  obtain ⟨hφ, hψ⟩ := hC;
  obtain ⟨_, ⟨Γ, hΓ₁, hΓ₂⟩⟩ := of_not_mem_construction_omega hφ;
  obtain ⟨_, ⟨Δ, hΔ₁, hΔ₂⟩⟩ := of_not_mem_construction_omega hψ;

