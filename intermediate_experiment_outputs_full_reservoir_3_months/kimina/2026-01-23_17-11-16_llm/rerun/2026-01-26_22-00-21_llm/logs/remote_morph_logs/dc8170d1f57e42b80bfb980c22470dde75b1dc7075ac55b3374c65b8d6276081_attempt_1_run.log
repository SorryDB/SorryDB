structure FTheory (L : Logic ℕ) extends Set (Formula ℕ) where
  andIR : ∀ {φ ψ}, φ ∈ theory → ψ ∈ theory → φ ⋏ ψ ∈ theory
  imp_closed : ∀ {φ ψ}, L ⊢ φ ➝ ψ → φ ∈ theory → ψ ∈ theory
  L_subset : L ⊆ theory


