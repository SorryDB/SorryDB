  (∀ φ ψ, φ ➝ ψ ∈ T.theory → φ ∈ U → ψ ∈ U) := by
  sorry;

end FTheory.lindenbaum

open FTheory.lindenbaum in
lemma FTheory.lindenbaum {χ ξ : Formula _} [Entailment.F L] (T : FTheory L) (hT : χ ➝ ξ ∉ T.theory) : ∃ U : PrimeFTheory L,
