lemma construction_omega_mem_ant : χ ∈ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
  apply impId;

lemma construction_omega_not_mem_csq : ξ ∉ construction_omega T hT := by
