      . assumption; -- Close the goal if it's `True` (e.g. from `simp`)
    . assumption; -- Close the goal if it's `True` (e.g. from `simp`)
  -- After the induction, we have `h4 : False ∈ construction_omega T hT` and `h5 : False ∉ construction_omega T hT`.
  -- This is a contradiction.
  tauto; -- Use tauto to close the goal from the contradiction

