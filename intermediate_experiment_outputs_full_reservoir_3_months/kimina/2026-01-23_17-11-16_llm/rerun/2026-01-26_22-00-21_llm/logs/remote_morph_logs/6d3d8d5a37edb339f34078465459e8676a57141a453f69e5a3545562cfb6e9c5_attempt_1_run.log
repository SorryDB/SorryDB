  intro h
  have h1 : m + 1 ≤ n := h
  have h2 : m ≤ n := by
    have h3 : 1 ≤ n := hmn
    have h4 : m + 1 ≤ n := h
    have h5 : m ≤ m + 1 := by simp
    have h6 : m + 1 ≤ n := h4
    exact Nat.add_le_add_left 1 h6
  exact h2
```

