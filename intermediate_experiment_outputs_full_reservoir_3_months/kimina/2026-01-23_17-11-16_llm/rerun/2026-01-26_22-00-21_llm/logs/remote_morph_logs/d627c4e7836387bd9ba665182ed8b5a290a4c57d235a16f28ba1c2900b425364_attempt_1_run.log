/-! Definition 10. The set of values an agent knows are true. -/
noncomputable def knowTrue (S : @Dist n) (σ : @OSequence n) (a : @Agent n) : Set (@Value n) :=
  {v | v ∈ know S σ a true}
```

```tactics
/-! Definition 11. The set of values an agent knows are false. -/
noncomputable def knowFalse (S : @Dist n) (σ : @OSequence n) (a : @Agent n) : Set (@Value n) :=
  {v | v ∈ know S σ a false}
```

