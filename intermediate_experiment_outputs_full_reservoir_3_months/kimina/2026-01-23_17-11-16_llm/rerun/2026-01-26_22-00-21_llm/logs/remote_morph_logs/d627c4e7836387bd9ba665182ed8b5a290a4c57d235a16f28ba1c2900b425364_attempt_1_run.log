    case Callee =>
      -- Similar to Caller
      by_cases h : eval S ⟨σ,⁻o⟩ (Kv a b)
      · specialize IH (⁻o) h
        unfold resultSet
        simp only [r, stubbornness, Subtype.forall, OSequence.length_def]
        let C_copy := C
