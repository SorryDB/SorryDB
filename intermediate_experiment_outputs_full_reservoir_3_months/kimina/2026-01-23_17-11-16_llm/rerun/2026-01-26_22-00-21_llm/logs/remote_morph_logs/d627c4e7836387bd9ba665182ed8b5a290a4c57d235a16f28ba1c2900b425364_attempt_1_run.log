import Mathlib

set_option maxHeartbeats 2000000 in

/-- Definition of distinguishability. -/
noncomputable def distinguishable (S T : @Dist n) (σ τ : @OSequence n) :
    (∃ (T' : @OSequence n) : T' = τ ∧ (∀ (a : @Agent n), S⌈σ⌉a = T'⌈T'⌉a)) ∨
    (∃ (S' : @OSequence n) : S' = σ ∧ (∀ (a : @Agent n), S'⌈S'⌉a = T⌈τ⌉a)) := by
  use τ, rfl, fun a => rfl
  use σ, rfl, fun a => rfl
  simp

/-- Definition of equivalence. -/
noncomputable def equivalent (S T : @Dist n) (σ τ : @OSequence n) : Prop :=
    (∃ (T' : @OSequence n) : T' = τ ∧ (∀ (a : @Agent n), S⌈σ⌉a = T'⌈T'⌉a ∧ S⌈σ⌉a = T⌈τ⌉a)) ∨
    (∃ (S' : @OSequence n) : S' = σ ∧ (∀ (a : @Agent n), S'⌈S'⌉a = T⌈τ⌉a ∧ S'⌈S'⌉a = T⌈τ⌉a)) := by
  use τ, rfl, fun a => rfl
  use σ, rfl, fun a => rfl
  simp

/-- Definition of indistinguishability. -/
noncomputable def indistinguishable (S T : @Dist n) (σ τ : @OSequence n) : Prop :=
    ¬ distinguishable S T σ τ

