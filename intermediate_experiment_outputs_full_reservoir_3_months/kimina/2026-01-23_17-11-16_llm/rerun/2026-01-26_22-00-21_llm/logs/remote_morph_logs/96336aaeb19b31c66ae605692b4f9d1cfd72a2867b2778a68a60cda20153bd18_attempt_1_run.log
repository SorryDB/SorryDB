open Filter
open Nat.Prime

/-- The prime counting function `π(x)` for real `x`. -/
noncomputable def primeCountingReal (x : ℝ) : ℕ :=
  if (x ≤ 0) then 0 else primeCounting ⌊x⌋₊

/-- The set of natural numbers whose prime factors are all less than or equal to `x`. -/
def S₁ (x : ℝ) : Set ℕ :=
 { n | ∀ p, Nat.Prime p → p ∣ n → p ≤ x }

theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  apply tendsto_atTop_atTop_of_forall_mem_atTop
  intro n
  simp only [mem_atTop, mem_univ]
  use n + 1
  simp only [mem_atTop]
  apply Real.tendsto_atTop_atTop_of_unbounded_of_forall_mem
  · -- Show that the function is unbounded
    intro B
    use B + 1
    simp
    all_goals linarith
  · -- Show that for all x > n, π(x) > n
    intro x hx
    have h1 : x ≥ n + 1 := by linarith
    have h2 : π x ≥ n + 1 := by
      have h3 : (n + 1 : ℕ) ∈ S₁ (x : ℝ) := by
        simp [S₁]
        intro p hp hpdvd
        have : p ≤ (n + 1 : ℕ) := by
          have h4 : p ≤ x := by
            exact Nat.le_of_dvd (by linarith) hpdvd
          have h5 : x < (n + 1 : ℝ) + 1 := by
            linarith [show (n + 1 : ℝ) + 1 = x + 1 by linarith]
          have h6 : p ≤ (n + 1 : ℕ) := by
            by_contra h
            push_neg at h
            have h7 : p ≥ (n + 2 : ℕ) := by omega
            have h8 : (p : ℝ) ≥ (n + 2 : ℝ) := by exact_mod_cast h7
            linarith
          exact_mod_cast h6
        omega
      have h4 : (n + 1 : ℕ) ≤ π x := by
        have h5 : (n + 1 : ℕ) ∈ S₁ (x : ℝ) := h3
        have h6 : (n + 1 : ℕ) ≤ π x := by
          have h7 : (n + 1 : ℕ) ∈ S₁ (x : ℝ) := h5
          have h8 : (n + 1 : ℕ) ≤ π x := by
            apply Nat.le_primeCounting_of_mem
            exact_mod_cast h7
          linarith
        linarith
      linarith
    linarith

