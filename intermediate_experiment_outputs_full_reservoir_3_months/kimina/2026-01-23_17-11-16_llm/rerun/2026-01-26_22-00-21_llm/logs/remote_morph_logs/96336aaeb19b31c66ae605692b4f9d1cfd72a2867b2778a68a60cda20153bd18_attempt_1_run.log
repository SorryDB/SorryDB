    have h1 : Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
      have h2 : ∀ (k : ℕ), k ∈ Icc 1 n → (k : ℝ)⁻¹ ≤ (k : ℝ)⁻¹ := by
        intro k hk
        simp at hk ⊢
        all_goals linarith
      have h3 : ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ ≥ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
        apply Finset.sum_le_sum
