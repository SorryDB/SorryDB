import Mathlib
import Mathlib.Data.SSupIndep
import Mathlib.Data.SSup
import Mathlib.Order.Basic
import Mathlib.Tactic.Linarith

/-!
In this file we sketch what we'll need to prove to
get Step 2 done. Most of the work is setting the stage so
we can apply Zorn's lemma.

For now we work with types in the 1-th universe. To make the code universe polymorphic we'll need
to make a few edits below
-/

open Set

variable {C : Type} [Category.Cat] {K : Type} [DivisionRing K] {M : C Ōźż ModuleCat K}

/-!
This is the definition of direct sum decomposition.
-/
noncomputable def DirectSumDecomposition (M : C Ōźż ModuleCat K) : Type where
  carrier := {D | D ŌŖå univ Ōł¦ sSup D = ŌŖż Ōł¦ sSupIndep D}
  sSup_eq_top' : sSup D = ŌŖż := by simpa using D.2.1
  sSupIndep' : sSupIndep D := by simpa using D.2.2
  nonempty' : Ōłā x, x Ōłł D := by
    -- If D is empty, then sSup D = ŌŖź, which contradicts sSup D = ŌŖż
    by_contra h
    rw [Set.eq_empty_iff_forall_not_mem] at h
    have h1 : ŌłĆ x, x Ōłē D := h
    -- Choose an element from the sSup D = ŌŖż
    have h2 : D.Nonempty := by
      by_contra h
      push_neg at h
      have h3 : D = Ōłģ := by
        ext x
        simp [h]
      rw [h3] at sSup_eq_top'
      simp at sSup_eq_top'
      all_goals linarith
    -- Choose an element from D
    obtain Ō¤©a, haŌ¤® := h2
    -- Show that a Ōłł D
    have ha' : a Ōłł D := ha
    -- Contradiction with h1
    specialize h1 a
    contradiction

/-!
Here we write some code to go from chains in directSumDecompositions to diagrams in the category
of types. -/
noncomputable def ToTypeCat : DirectSumDecomposition M Ōźż Type where
  obj D := D
  -- Define the maps f_{IJ} induced by "J refines I"
  map {J I} f := RefinementMap I J (leOfHom f)
  map_comp {I J L} f g := by
    have hŌéü := leOfHom f
    have hŌéé := leOfHom g
    ext N : 2
    simpa using RefinmentMapFunctorial .. --THANK YOU FOR .. YAEL!!

/-- This is possibly useful to make things a bit cleaner so let's keep it for now but possibly
remove it later -/
noncomputable def Pone (T : Set (DirectSumDecomposition M)) : T Ōźż Type where
  obj D := ToTypeCat.obj D.val
  map {J I} f := ToTypeCat.map f
  map_id I := by rw [ŌåÉ ToTypeCat.map_id]; rfl
  map_comp {I J K} f g := by rw [ŌåÉ ToTypeCat.map_comp]; rfl


variable (N : PersistenceSubmodule M) {T : Set (DirectSumDecomposition M)}

local notation "L" T:arg => limit (Pone T)

noncomputable abbrev ╬ø (I : T) := limit.ŽĆ (Pone T) I

variable (l : L T) (I : T) (D : DirectSumDecomposition M)

/-- Construct `M[╬╗]` in the notation of our doc -/
noncomputable def chainBound (l : L T) : PersistenceSubmodule M := Ō©ģ I, (╬ø I l).val

notation3:max "M["l"]" => chainBound l
notation3:max "M["l"]_[" c "]" => chainBound l c

lemma chainBound_le : M[l] Ōēż (╬ø I l).val := iInf_le ..

@[nolint unusedArguments]
noncomputable def limit_elt_mk (hT : IsChain LE.le T) (f : T ŌåÆ PersistenceSubmodule M)
  (h_le : ŌłĆ (I J : T), I Ōēż J ŌåÆ f J Ōēż f I) (h_mem : ŌłĆ I : T, (f I) Ōłł I.val) : (L T) := by
  let f' : (I : T) ŌåÆ (Pone T).obj I := by
    intro I
    simpa [Pone, ToTypeCat] using Ō¤©(f I), h_mem IŌ¤®
  have h_compatible : (ŌłĆ (j j' : ŌåæT) (f : j Ō¤Č j'), (Pone T).map f (f' j) = f' j') := by
    intro I J g
    have h_ij := leOfHom g
    sorry
  let l := CategoryTheory.Limits.Types.Limit.mk (Pone T) f' h_compatible
  exact l

open scoped Classical in
/-- `M` is the direct sum of all the `M[╬╗]`. -/
lemma isInternal_chainBound (hT : IsChain LE.le T) (c : C) : IsInternal fun l : L T Ōå” M[l]_[c] := by
  rw [isInternal_iff]
  constructor
  ┬Ę intro m hm
    obtain Ō¤©J, hJŌ¤® : Ōłā J : T, (m.support : Set (L T)).InjOn (╬ø J) := by
      sorry
    have : IsInternal fun j : J.val Ōå” j.val c := J.1.isInternal _
    refine DFinsupp.ext fun l Ōå” ?_
    ext : 1
    by_cases hl : l Ōłł m.support
    ┬Ę exact this.eq_zero_of_subsingleton_preimage (╬ø J) (fun l Ōå” m l) m.support hJ
        (fun l Ōå” chainBound_le _ _ _ (m l).2) hm hl
    ┬Ę simpa using hl
  ┬Ę sorry

/-- The `M[╬╗]` are linearly independent -/
lemma lambdas_indep (hT : IsChain LE.le T) :
    sSupIndep {M[l] | (l : L T) (_ : ┬¼ IsBot M[l])} := by
  intro a b ha hb hab
  sorry

/-- The `M[╬╗]` span `M` -/
lemma sSup_lambdas_eq_top (hT : IsChain LE.le T) :
    sSup {M[l] | (l : L T) (_ : ┬¼ IsBot M[l])} = ŌŖż := by
  sorry

/-- Get a direct sum out of a chain (this should be the index set ­Øōż in out doc). -/
def DirectSumDecomposition_of_chain (hT : IsChain LE.le T) : DirectSumDecomposition M where
  carrier := {M[l] | (l : L T) (_ : ┬¼ IsBot M[l])}
  sSup_eq_top' := sSup_lambdas_eq_top hT
  sSupIndep' := lambdas_indep hT
  not_bot_mem' := sorry

/-- The set `­Øōż` is an upper bound for the chain `T` -/
lemma every_chain_has_an_upper_bound (N : PersistenceSubmodule M) (hT : IsChain LE.le T) :
    ŌłĆ D Ōłł T, D Ōēż DirectSumDecomposition_of_chain hT := by
  intro D hD
  sorry

/-- Every chain has an upper bound, hence there is a maximal direct sum decomposition `D`. -/
lemma zorny_lemma (N : PersistenceSubmodule M) : Ōłā (D : DirectSumDecomposition M), IsMax D := by
  apply zorn_le
  rintro T hT
  rw [bddAbove_def]
  use (DirectSumDecomposition_of_chain hT)
  exact (every_chain_has_an_upper_bound N hT)

end Chains

/-!
In this section we define the refinement structure on which our argument will be based.
-/

/-!
The structure of a refinement
-/
structure refinement (S : Set ╬▒) where
  carrier : Set (Set ╬▒)
  -- The set of sets in the refinement
  carrier_span : ŌłĆ a Ōłł S, Ōłā! D Ōłł carrier, a = sSup D
  -- For every element in the original set, there is a unique set in the refinement that contains it
  carrier_indep : ŌłĆ D Ōłł carrier, sSupIndep D
  -- Every set in the refinement is linearly independent
  bot_not_mem : ŌłĆ D Ōłł carrier, ŌŖź Ōłē D
  -- The empty set is not in the refinement

/-!
The set of all sets in the refinement
-/
noncomputable def decomposition_of_refinement {S ╬▒ : Type u} [CompleteLattice ╬▒] [DistribLattice ╬▒] [BoundedOrder ╬▒]
    (R : refinement S) : Set ╬▒ := Ōŗā D Ōłł R.carrier, D

/-!
