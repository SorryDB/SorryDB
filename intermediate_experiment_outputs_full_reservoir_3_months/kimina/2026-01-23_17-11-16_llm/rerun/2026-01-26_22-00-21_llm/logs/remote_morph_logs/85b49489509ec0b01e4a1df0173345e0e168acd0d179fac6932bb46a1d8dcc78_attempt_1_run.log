        have h4 : (n.factorial : ℚ) / ((k.factorial : ℚ) * ((n - k).factorial : ℚ)) ≤ (n ^ k / (k.factorial : ℚ)) := by
          have h5 : (n.factorial : ℚ) ≤ (n ^ k * (n - k).factorial : ℚ) := by
