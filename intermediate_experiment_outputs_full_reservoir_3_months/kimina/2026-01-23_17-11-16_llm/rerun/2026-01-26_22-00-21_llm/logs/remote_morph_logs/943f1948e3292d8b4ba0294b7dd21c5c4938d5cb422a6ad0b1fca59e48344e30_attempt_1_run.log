```lean
import Mathlib
open Lean4

namespace Lean4

/-- Definition of PdlRule from the paper, using `Sequent` and `LocalTableau` from Lean4.
The rule `r : PdlRule X Y` means:
- `X` is the current state, a `Sequent`
- `Y` is the next state, a `Sequent`
- `r` is constructed by `cases r with | loadL in_L notBox Y_def => ... | loadR in_R notBox Y_def => ...`
- `in_L` (or `in_R`) is a proof that the current `Sequent` is `L` (or `R`)
- `notBox` is a proof that the current `Sequent` is not a `Box`
- `Y_def` defines the next `Sequent` (e.g., `Y_def := (L', R', none)` for a local rule, or `Y_def := (L', R', some nlf)` for a PDL rule)
- The rule `r` is a `PdlRule` if `X` is free, `Y` is not free, and it's constructed from `PdlRule` constructors.
- The rule `r` is a local rule if `X` is free, `Y` is not free, and it's constructed from `LocalRule` constructors. This is a subset of PDL rules.
- The rule `r` is a PDL rule if `X` is free, `Y` is not free, and it's constructed using the `PdlRule` constructors defined here.
- The rule `r` is a free rule if `X` is free and `Y` is free.

/-- PartInterpolant from the paper. -/
def PartInterpolant (X : Sequent) := (X : Set (List Formula)) × (X ⊢ ?M) × ?P_satisfiable

/-- PdlRule is a rule that transforms a `Sequent` X into a `Sequent` Y.
It's defined using constructors for different types of rules.
- `loadL`: loads a formula `f` (from `X`'s left side) into `Y`'s left side.
- `loadR`: loads a formula `f` (from `X`'s right side) into `Y`'s right side.
- `notBox`: ensures the current rule is not a box rule.
- `Y_def`: defines the structure of the resulting `Sequent` Y.
- `PdlRule` is the type of these rules.

/-- A PdlRule is a rule that transforms a `Sequent` X into a `Sequent` Y.
It's defined using constructors for different types of rules.
- `loadL`: loads a formula `f` (from `X`'s left side) into `Y`'s left side.
- `loadR`: loads a formula `f` (from `X`'s right side) into `Y`'s right side.
- `notBox`: ensures the current rule is not a box rule.
- `Y_def`: defines the structure of the resulting `Sequent` Y.
- `PdlRule` is the type of these rules. -/
noncomputable inductive PdlRule (X Y : Sequent) : Prop :=
  | loadL in_L notBox Y_def =>
    X.isFree ∧ Y.isNotFree ∧ in_L : X = (Sequent.left (L, R, none)) ∧
    Y = (Sequent.left (L', R', none)) ∧
    (∀ x, x ∈ X → x ∈ Y) ∧ X ⊢ Y ∧ X.satisfiable
  | loadR in_R notBox Y_def =>
    X.isFree ∧ Y.isNotFree ∧ in_R : X = (Sequent.right (L, R, none)) ∧
    Y = (Sequent.right (L', R', none)) ∧
    (∀ x, x ∈ X → x ∈ Y) ∧ X ⊢ Y ∧ X.satisfiable

/-- Local rule is a rule that transforms a `Sequent` X into a `Sequent` Y.
It's defined using constructors for different types of local rules.
- `local`: applies a local rule `lra` to a local context `lt` to produce a new local context `lt'` and a new `Sequent` Y, then uses `next` to create a new `Sequent`.
- `sim`: simplifies the current `Sequent`.
- `PdlRule` is the type of rules.
- `LocalRule` is the type of local rules.

/-- A local rule is a rule that transforms a `Sequent` X into a `Sequent` Y.
It's defined using constructors for different types of local rules.
- `local`: applies a local rule `lra` to a local context `lt` to produce a new local context `lt'` and a new `Sequent` Y, then uses `next` to create a new `Sequent`.
- `sim`: simplifies the current `Sequent`.
- `PdlRule` is the type of rules.
- `LocalRule` is the type of local rules. -/
noncomputable inductive LocalRule (X Y : Sequent) : Prop :=
  | local lra lt next Y =>
    X = (Sequent.left (L, R, none)) ∧ Y = (Sequent.right (L', R', none)) ∧
    lra : LocalRuleApp X Y ∧ lt : LocalTableau X ∧ next : (Y : Sequent) → Y ∈ endNodesOf lt → Tableau ((L, R, none) :: List (Sequent)) Y
  | sim X =>
    X = (Sequent.left (L, R, none)) ∧ X = (Sequent.right (L', R', none))

/-- A local rule is a rule that transforms a `Sequent` X into a `Sequent` Y.
It's defined using constructors for different types of local rules.
- `local`: applies a local rule `lra` to a local context `lt` to produce a new local context `lt'` and a new `Sequent` Y, then uses `next` to create a new `Sequent`.
- `sim`: simplifies the current `Sequent`.
- `PdlRule` is the type of rules.
- `LocalRule` is the type of local rules. -/
noncomputable inductive LocalRule (X Y : Sequent) : Prop :=
  | local lra lt next Y =>
    X = (Sequent.left (L, R, none)) ∧ Y = (Sequent.right (L', R', none)) ∧
    lra : LocalRuleApp X Y ∧ lt : LocalTableau X ∧ next : (Y : Sequent) → Y ∈ endNodesOf lt → Tableau ((L, R, none) :: List (Sequent)) Y
  | sim X =>
    X = (Sequent.left (L, R, none)) ∧ X = (Sequent.right (L', R', none))

/-! ## Interpolants for PdlRules applied to free nodes

The only rule treated here is (L+), i.e. `loadL` and `loadR`.
-/

def freePdlRuleInterpolant {X Y} (r : PdlRule X Y) (Xfree : X.isFree) (θY : PartInterpolant Y)
    : PartInterpolant X := by
  rcases θY with ⟨θ, θ_ip_Y⟩
  cases r
  case loadL in_L notBox Y_def =>
    use θ
    subst Y_def
    rcases θ_ip_Y with ⟨hYvoc, hYL, hYR⟩
    refine ⟨?_, ?_, ?_⟩
    · -- First goal: ∀ x, x ∈ X → x ∈ Y
      intro x hx
      have h1 : x ∈ (Sequent.left (L, R, some (Sum.inl nlf)) : Set (List Formula)) := by
        simpa using hx
      have h2 : x ∈ (Sequent.left (LY, RY, none) : Set (List Formula)) := by
        apply hYvoc h1
      simpa using h2
    · -- Second goal: X ⊢ Y
      apply hYL
    · -- Third goal: X is satisfiable
      apply hYR
  case loadR in_R notBox Y_def =>
    use θ
    subst Y_def
    rcases θ_ip_Y with ⟨hYvoc, hYL, hYR⟩
    refine ⟨?_, ?_, ?_⟩
    · -- First goal: ∀ x, x ∈ X → x ∈ Y
      intro x hx
      have h1 : x ∈ (Sequent.right (L, R, some (Sum.inl nlf)) : Set (List Formula)) := by
        simpa using hx
      have h2 : x ∈ (Sequent.right (LY, RY, none) : Set (List Formula)) := by
        apply hYvoc h1
      simpa using h2
    · -- Second goal: X ⊢ Y
      apply hYL
    · -- Third goal: X is satisfiable
      apply hYR
  all_goals
    exfalso
    subst_eqs

/-! ## Interpolants for local tableaux -/

def LocalTableau.interpolant (ltX : LocalTableau X)
    (endθs : ∀ Y ∈ endNodesOf ltX, PartInterpolant Y)
    : PartInterpolant X := by
  cases ltX
  case byLocalRule lra nexts X_def =>
    subst X_def
    apply localInterpolantStep lra
    intro Y Y_in
    have IH := LocalTableau.interpolant (nexts Y Y_in)
    exact IH (fun Z Z_in_end => endθs _ (endNodeOfChild_to_endNode lra nexts rfl Y Y_in Z_in_end))
  case sim Xbas =>
    apply endθs X
    simp [endNodesOf]

/-! ## Interpolants for PdlRules applied to free nodes

The only rule treated here is (L+), i.e. `loadL` and `loadR`.
-/

