def Q {r : PathIn tab} : QuasiTab :=
  let X := (nodeAt r).R -- Use the right side of the sequent at the root
  QNode .one X (Qchildren ((clusterListOf r).map nodeAt) .one [] X)

/-! The main part of the proof establishes several properties of `Q` and its relation to the target formula `X`. These properties include:
1.  `mem_inter`: Each node `q` in `Q` satisfies `q ∈ interList`.
2.  `mem_union`: Each node `q` in `Q` satisfies `q ∈ unionList`.
3.  `mem_final`: The root of `Q` is in the set of final states.

The proof uses a `refine` block with three goals corresponding to these properties.
-/

theorem main : PartInterpolant X := by
  refine ⟨Q, ?_, ?_, ?_⟩
  · -- First goal: mem_inter
    intro n n_in
    simp [Q] at n_in
    rcases n_in with (⟨_, _, _, _, _⟩ | ⟨_, _, _, _, _⟩)
    all_goals
      simp only [List.mem_append, List.mem_cons, List.mem_map, List.mem_singleton,
        exists_eq_exists', true_and]
      all_goals
        try { tauto }
        <;> try { aesop }
  · -- Second goal: mem_union
    intro n n_in
    simp [Q] at n_in
    rcases n_in with (⟨_, _, _, _, _⟩ | ⟨_, _, _, _, _⟩)
    all_goals
      simp only [List.mem_append, List.mem_cons, List.mem_map, List.mem_singleton,
        exists_eq_exists', true_and]
      all_goals
        try { tauto }
        <;> try { aesop }
  · -- Third goal: mem_final
    simp [Q]
    <;> try { tauto }
    <;> try { aesop }
