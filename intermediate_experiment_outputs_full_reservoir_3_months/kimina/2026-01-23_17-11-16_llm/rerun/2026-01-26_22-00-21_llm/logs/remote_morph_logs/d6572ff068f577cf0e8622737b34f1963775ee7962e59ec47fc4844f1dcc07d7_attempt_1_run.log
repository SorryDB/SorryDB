    (compIsofibration f g).1 = f.1 ≫ g.1 := rfl

/-- The object defined by pulling back an isofibration. -/
noncomputable def pullbackIsofibrationObj {E B A : K} (p : E ↠ B) (f : A ⟶ B) : K :=
  pullback p.1 f

/-- The object defined by pulling back an isofibration. -/
