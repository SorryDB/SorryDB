lemma HasLocallyIntegrableSup.locally_classDL [OrderBot ι] [TopologicalSpace ι] [OrderTopology ι]
    [MeasurableSpace ι]
    (hX1 : HasLocallyIntegrableSup X 𝓕 P) (hX2 : Adapted 𝓕 X) (h𝓕 : 𝓕.IsRightContinuous) :
    Locally
    (fun x =>
      @ProbabilityTheory.ClassDL ι Ω E instNormedAddCommGroup E mΩ instDistribLatticeOfLinearOrder.toSemilatticeInf.toPreorder ⋯ instLinearOrder ι x P)
    X P := by 
