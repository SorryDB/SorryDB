/--
Definition of $F$ and $G$ and auxiliary functions for the inequality between them
on the imaginary axis.
-/
noncomputable def F := (Eâ‚‚ * Eâ‚„.toFun - Eâ‚†.toFun) ^ 2

noncomputable def G := Hâ‚‚ ^ 3 * (2 * Hâ‚‚ ^ 2 + 5 * Hâ‚‚ * Hâ‚„ + 5 * Hâ‚„ ^ 2)

noncomputable def negDEâ‚‚ := - (D Eâ‚‚)

noncomputable def خ”_fun := 1728âپ»آ¹ * (Eâ‚„.toFun ^ 3 - Eâ‚†.toFun ^ 2)

noncomputable def Lâ‚پâ‚€ := (D F) * G - F * (D G)

noncomputable def SerreDer_22_Lâ‚پâ‚€ := serre_D 22 Lâ‚پâ‚€

noncomputable def FReal (t : â„‌) : â„‌ := (F.resToImagAxis t).re

noncomputable def GReal (t : â„‌) : â„‌ := (G.resToImagAxis t).re

noncomputable def FmodGReal (t : â„‌) : â„‌ := (FReal t) / (GReal t)

theorem F_eq_FReal {t : â„‌} (ht : 0 < t) : F.resToImagAxis t = FReal t := by sorry

theorem G_eq_GReal {t : â„‌} (ht : 0 < t) : G.resToImagAxis t = GReal t := by sorry

theorem FmodG_eq_FmodGReal {t : â„‌} (ht : 0 < t) :
    FmodGReal t = (F.resToImagAxis t) / (G.resToImagAxis t) := by sorry

