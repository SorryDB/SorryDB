  ⟨fun x ↦ ⟨_,isOpen_univ,Set.mem_univ x,(),Set.univ,isOpen_univ,⟨DDiffeomorph.refl _⟩⟩⟩

/-- Any diffeological manifold is also a diffeological manifold with boundary. -/
