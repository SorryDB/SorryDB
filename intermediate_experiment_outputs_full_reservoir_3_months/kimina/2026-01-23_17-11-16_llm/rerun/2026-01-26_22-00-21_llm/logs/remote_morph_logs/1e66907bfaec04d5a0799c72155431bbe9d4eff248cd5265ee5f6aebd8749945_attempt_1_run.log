    [Zero (Fin n)] (h : IsManifoldWithBoundary n X) {u : Set X} (hu : IsOpen[DTop] u) :
    IsManifoldWithBoundary n u := hu.locallyModelled h

/-- Any D-open subset of a diffeological orbifold is a diffeological orbifold. -/
