    t ∈ all_cEdge s ↔ ((s ⋖_ t) ∨ s ♥ t) := by
  sorry

def all_cEdge_rev {X} {tab : Tableau .nil X} (t : PathIn tab) : List (PathIn tab) :=
  sorry

