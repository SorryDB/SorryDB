      have h6 : ¬Sequent.basic X := by
        simpa using h1
      -- Proof that endNodesOf is non-empty for non-basic X
      sorry -- This would be filled in with actual proof from context
    rcases h4 with ⟨Y₀, hY₀⟩
    have h6 : ((.loc Y₀ .nil) : (PathIn tab)) ∈ (List.map (fun x => .loc x .nil) (endNodesOf tab) : List (PathIn tab)) := by
      simp [List.mem_map, hY₀]
    have h7 : (.loc Y₀ .nil : (PathIn tab)) ≠ .nil := h3 ((.loc Y₀ .nil : (PathIn tab))) h6
    have h8 : ( (.loc Y₀ .nil : (PathIn tab)) ) = .nil := by 
      simp [List.mem_map, List.mem_attach] 
    rw [h8] at h7
    contradiction

