import Mathlib

/-- A path in a finite, acyclic, binary tableaux structure used to represent
traces of a PDL system. -/
noncomputable inductive PathIn (tab : Tableau .nil X) : Type
| nil : PathIn tab
| loc  (Y_in : Y ∈ endNodesOf (localTableauAt tab)) (p : PathIn (next Y Y_in)) :
    PathIn (next Y Y_in)
| pdl  (Y_in : Y ∈ endNodesOf (localTableauAt tab)) (p : PathIn (pdl Y Y_in)) :
    PathIn (pdl Y Y_in)

/-- A sequence of formulas representing the state of a PDL system at a certain point in time.
A `Sequent` `Δ` consists of a list of formulas `L` assumed true (`Δ.L`) and a list of formulas `R` assumed false (`Δ.R`), along with an `Option` indicating if the context is "open" or "closed" (`Δ.O`). -/
noncomputable inductive Sequent (O : Option (List Formula)) : Type
| L (L : List Formula) (O : Option (List Formula)) (R : List Formula)
| R (L : List Formula) (O : Option (List Formula)) (R : List Formula)

/-- The root of a local tableaux, representing the initial state of the PDL system. -/
noncomputable inductive LocalTableau (X : Sequent) : Type
| lrep (X : Sequent) (nrep : ¬ rep (X :: [])) : LocalTableau X
| loc  (X : Sequent) (nbas : ¬ basic X) (lt : LocalTableau X) (next : (Y : Sequent) → Y ∈ endNodesOf lt → Tableau (X :: []) Y) : LocalTableau X
| pdl  (X : Sequent) (nbas : ¬ basic X) (lt : LocalTableau X) (pdl : (Y : Sequent) → Y ∈ endNodesOf lt → Tableau (X :: []) Y) : LocalTableau X

/-- A `Tableau` is a sequence of local tableaux, representing the evolution of the PDL system.
The `History` parameter represents the list of formulas that are "in the context" of the PDL system at the root of the tableaux. -/
noncomputable inductive Tableau (Hist : List Formula) (X : Sequent) : Type
| nil : Tableau [] X
| cons (lt : LocalTableau X) (next : (Y : Sequent) → Y ∈ endNodesOf lt → Tableau (Y :: Hist) Y) : Tableau (X :: Hist)

/-- The set of all paths in a tableaux `tab`. -/
noncomputable def allPaths (tab : Tableau .nil X) : List (PathIn tab) :=
  match tab with
  | nil => [ .nil ]
  | cons lt next =>
    (lt.endNodesOf.map (fun Y_in => (PathIn.loc Y_in .nil))).append
    (lt.endNodesOf.map (fun Y_in => (next Y_in .map (fun x => x.map (fun p => p))))).append
    (lt.endNodesOf.map (fun Y_in => (lt.pdl Y_in).map (fun x => x.map (fun p => p)))) -- this is wrong, need to fix the structure

/-- The set of all "exits" from a tableaux `tab`, i.e., all paths that end at a terminal node.
A terminal node is one where the corresponding `Sequent` is "loaded" (its context is `some`), or it's a base case (its context is `none`). -/
noncomputable def exitsOf (tab : Tableau .nil X) : List (PathIn tab) :=
  match tab with
  | nil => [ .nil ] -- root is a free node
  | cons lt next =>
    let X := lt.X
    if X.isLoaded
    then
      (lt.endNodesOf.map (fun Y_in => (PathIn.loc Y_in .nil))).append
      (lt.endNodesOf.map (fun Y_in => (next Y_in .map (fun x => x.map (fun p => p)) ))).append
      (lt.endNodesOf.map (fun Y_in => (lt.pdl Y_in).map (fun x => x.map (fun p => p)) )) -- this is wrong, need to fix the structure
    else
      (lt.endNodesOf.map (fun Y_in => (PathIn.loc Y_in .map (fun x => x.map (fun p => p)) ))).append
      (lt.endNodesOf.map (fun Y_in => (next Y_in .map (fun x => x.map (fun p => p)) ))).append
      (lt.endNodesOf.map (fun Y_in => (lt.pdl Y_in).map (fun x => x.map (fun p => p)) )) -- this is wrong, need to fix the structure

/-- A `Vocabulary` is a list of formulas that are "in context" of the PDL system.
The `jvoc` function computes the set of all formulas that appear in a `Vocabulary`. -/
noncomputable def jvoc (V : List Formula) : Finset Formula := sorry

/-- A `PartInterpolant` `θ` for a `Sequent` `Δ` is a pair `(L, R)` of lists of formulas such that
`L` is a subset of `Δ.L` and `R` is a subset of `Δ.R`, and `L ∪ R` contains all formulas in `Δ.O`.
This corresponds to an interpolant for the "open" part of the `Sequent` if `Δ.O` is `some`, or for the "closed" part if `Δ.O` is `none`. -/
noncomputable inductive PartInterpolant (Δ : Sequent) : Type
| exists (L : List Formula) (R : List Formula) (hL : L ⊆ Δ.L) (hR : R ⊆ Δ.R) (hO : Δ.O.map (fun x => x ∈ L ∪ R)) : PartInterpolant Δ
| none : PartInterpolant Δ := sorry -- this is wrong, need to fix the structure

/-- The `isInterpolant` predicate checks if a given `PartInterpolant` `θ` is indeed an interpolant for a `Sequent` `Δ`.
This involves checking subset conditions and set equality for the "open" part. -/
noncomputable def isInterpolant (θ : PartInterpolant Δ) (Δ : Sequent) : Prop := sorry

/-- The set of all "exits" from a tableaux `tab` that satisfy a given `Property P`.
An exit `e` satisfies `P` if `P (evaluating the property at the end of the path e)`. -/
noncomputable def satisfyingExits (P : (Sequent) → Prop) (tab : Tableau .nil X) : List (PathIn tab) :=
  (exitsOf tab).filter (fun e => P (nodeAt e))

/-- A `Property` `P` is `satisfiable` if there exists a `Sequent` `Δ` such that `P Δ` is true.
This corresponds to the existence of a "world" in the PDL system where the property holds. -/
noncomputable def satisfiable (P : (Sequent) → Prop) : Prop := ∃ Δ, P Δ

/-- A `Property` `P` is `realizable` if there exists a `Sequent` `Δ` such that `P Δ` is true AND `Δ` is "realizable" (its context is `none`).
This corresponds to the existence of a "world" in the PDL system where the property holds and the context is open. -/
noncomputable def realizable (P : (Sequent) → Prop) : Prop := ∃ Δ, P Δ ∧ Δ.isRealizable

/-- A `Property` `P` is `closed` if for every `Sequent` `Δ` where `P Δ` is true, `Δ` must be "realizable" (its context is `none`).
This corresponds to the property being satisfied only in "closed" worlds. -/
noncomputable def closed (P : (Sequent) → Prop) : Prop := ∀ Δ, P Δ → Δ.isRealizable

/-- A `Property` `P` is `decidable` if the set of all `Sequent`s satisfying `P` is finite.
This is a strong assumption, typically only satisfied by very simple properties. -/
noncomputable def decidable (P : (Sequent) → Prop) : Prop := sorry

/-- A `Property` `P` is `closed` and `decidable` if the set of all `Sequent`s satisfying `P` is finite and non-empty.
This is a strong assumption, typically only satisfied by very simple properties. -/
noncomputable def closed_decidable (P : (Sequent) → Prop) : Prop := sorry

/-! ## Interpolants for Local Tableau -/

def localInterpolantStep (lra : LocalRuleApp X Y) (θY : PartInterpolant Y)
    : PartInterpolant X := by
  subst X
  apply lra.interpolant
  intro Y Y_in
  apply localInterpolantStep lra
  intro Y Y_in
  have IH := localInterpolantStep (lra) (θY)
  exact IH (fun Z Z_in_end => endθs _ (endNodeOfChild_to_endNode lra nexts rfl Y_in Z_in_end))

/-! ## Interpolants for PdlRules applied to free nodes

The only rule treated here is (L+), i.e. `loadL` and `loadR`.
