    (s : PathIn tab.flip) (s_in : s ∈ (exitsOf tab.flip : List (PathIn tab.flip)))
    : (PathIn_type_flip_flip ▸ s.flip) ∈ exitsOf tab := by
  unfold exitsOf at s_in ⊢
  simp only [List.mem_cons, List.mem_singleton, List.mem_nil, iff_false, not_false_iff] at s_in ⊢
  rcases s_in with (⟨Yf, Yf_in, e, e_in, def_s⟩ | ⟨Yf, Yf_in, e, e_in, def_s⟩)
  · -- Case where s is the first exit
    simp only [List.mem_cons, true_and, def_s, iff_true] at *
    rcases Yf_in with ⟨Y, Y_in, rfl⟩
    simp only [Sequent.flip, Olf.flip, Option.map_some, Sum.swap_inl, List.mem_cons, true_and, iff_true] at *
    subst Y
    cases tab <;> simp at Y_in e_in <;> try { tauto }
    <;> try { aesop }
  · -- Case where s is an exit from the rest of the list
    simp only [List.mem_cons, true_and, def_s, iff_true] at *
    rcases Yf_in with ⟨Y, Y_in, rfl⟩
    simp only [Sequent.flip, Olf.flip, Option.map_some, Sum.swap_inl, List.mem_cons, true_and, iff_true] at *
    subst Y
    cases tab <;> simp at Y_in e_in <;> try { tauto }
    <;> try { aesop }
