      Sequent.isLoaded, decide_false, ↓reduceIte, List.mem_map, List.mem_cons, List.mem_singleton,
      true_and, exists_eq_left, exists_eq_right, and_imp, List.mem_append, List.mem_singleton,
      List.mem_map, true_and, Subtype.exists, Sum.swap_inl] at *
