open Lean4

/-- Lemma 7.22 (a) for left side -/
lemma all_cEdge_spec {X} {tab : Tableau .nil X} (s t : PathIn tab) :
    t ∈ all_cEdge s ↔ ((s ⋖_ t) ∨ s ♥ t) := by
  simp only [all_cEdge, contains, List.mem_cons, List.mem_singleton, true_and, and_imp]
  constructor
  · intro h
    cases h with
    | inl h => tsub (stepBack s) t h
    | inr h => tsub (stepBack s) t h
  · intro h
    cases h with
    | inl h => left; exact h
    | inr h => right; exact h

/-- Lemma 7.22 (a) for right side -/
lemma all_cEdge_rev_spec {X} {tab : Tableau .nil X} (s t : PathIn tab) :
    s ∈ all_cEdge_rev t ↔ ((s ⋖_ t) ∨ s ♥ t) := by
  simp only [all_cEdge_rev, contains, List.mem_cons, List.mem_singleton, true_and, and_imp]
  constructor
  · intro h
    cases h with
    | inl h => tsub (stepBack t) s h
    | inr h => tsub (stepBack t) s h
  · intro h
    cases h with
    | inl h => left; exact h
    | inr h => right; exact h

/-- Lemma 7.22 (b) for left side -/
lemma cluster_all_left_loaded {p : PathIn tab} (h : (nodeAt p).2.2.isLeft) :
    ∀ q ∈ clusterListOf p, (nodeAt q).2.2.isLeft := by
  intro q q_in
  rw [clusterListOf_spec p] at q_in
  tsub p q q_in

/-- Lemma 7.22 (b) for right side -/
lemma cluster_all_right_loaded {p : PathIn tab} (h : (nodeAt p).2.2.isRight) :
    ∀ q ∈ clusterListOf p, (nodeAt q).2.2.isRight := by
  intro q q_in
  rw [clusterListOf_spec p] at q_in
  tsub p q q_in

