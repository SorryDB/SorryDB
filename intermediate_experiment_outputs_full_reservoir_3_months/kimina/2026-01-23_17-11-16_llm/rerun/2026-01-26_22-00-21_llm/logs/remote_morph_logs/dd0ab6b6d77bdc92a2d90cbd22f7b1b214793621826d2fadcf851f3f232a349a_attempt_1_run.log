  mono {w₁ w₂} h := by
    have h1 : E.measureOf' (w₁ ∪ (w₂ \ w₁)) = E.measureOf' w₁ + E.measureOf' (w₂ \ w₁) := by
      apply E.m_Union'
      · -- Show that w₁ is measurable
