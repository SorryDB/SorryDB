      simp
    have h3 : E.measureOf' w₂ = E.measureOf' w₁ + E.measureOf' (w₂ \ w₁) := by
      rw [h2] at *
      linarith [h1]
    rw [h3]
    apply norm_add_le
    all_goals
      try { 
        apply norm_nonneg
      }
