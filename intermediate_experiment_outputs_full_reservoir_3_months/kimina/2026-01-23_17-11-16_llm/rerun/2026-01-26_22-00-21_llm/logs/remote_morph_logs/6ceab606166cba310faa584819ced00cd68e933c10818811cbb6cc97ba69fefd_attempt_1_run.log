  | leaf x, y => x = y
  | node _ l r, y => mem l y ‚ą® mem r y

@[grind .]
instance {őĪ : Type} : Membership őĪ (LabelledTree őĪ) where
  mem := mem

@[grind .]
def IsOrdered : LabelledTree őĪ ‚Üí Prop
  | leaf _ => True
  | node v l r =>
    (‚ąÄ x ‚ąą l, x ‚Č§ v) ‚ąß (‚ąÄ x ‚ąą r, v ‚Č§ x) ‚ąß IsOrdered l ‚ąß IsOrdered r ‚ąß (v ‚ąą l ‚ą® v ‚ąą r)

@[grind .]
def fastCheckMem (label : őĪ)(l: LabelledTree őĪ) : Bool := match l with
  | leaf l => l == label
  | node l left right =>
