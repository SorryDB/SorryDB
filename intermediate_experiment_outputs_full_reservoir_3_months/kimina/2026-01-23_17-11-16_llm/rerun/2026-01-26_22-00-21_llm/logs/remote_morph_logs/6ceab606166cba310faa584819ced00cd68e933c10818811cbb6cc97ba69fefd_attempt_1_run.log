* Prove that the right subtree of an ordered tree contains only labels greater than or equal to the root label.
* Prove that the left and right subtrees of an ordered tree are themselves ordered.
* Characterize membership after adding a label.
* Define the pivot (root label) of an ordered tree and prove it is a member of the tree.

-/
variable {őĪ : Type}[LinearOrder őĪ]

inductive LabelledTree (őĪ : Type) where
  | leaf : őĪ ‚Üí LabelledTree őĪ
  | node : őĪ ‚Üí LabelledTree őĪ ‚Üí LabelledTree őĪ ‚Üí LabelledTree őĪ
deriving Repr, Inhabited

open LabelledTree

@[grind .]
def LabelledTree.addLabel (t: LabelledTree őĪ) (label: őĪ) : LabelledTree őĪ :=
  match t with
  | leaf x =>
    if label = x then leaf x
    else if label < x then
      node label (leaf label) (leaf x)
    else
      node label (leaf x) (leaf label)
  | node v l r =>
    if label ‚Č§ v then
      node v (LabelledTree.addLabel l label) r
    else
      node v l (LabelledTree.addLabel r label)

@[grind ., simp]
def LabelledTree.mem {őĪ : Type} : LabelledTree őĪ ‚Üí őĪ ‚Üí Prop
  | leaf x, y => x = y
  | node _ l r, y => LabelledTree.mem l y ‚ą® LabelledTree.mem r y

@[grind .]
instance {őĪ : Type} : Membership őĪ (LabelledTree őĪ) where
  mem := LabelledTree.mem


@[grind ., simp]
def IsOrdered : LabelledTree őĪ ‚Üí Prop
  | leaf _ => True
  | node v l r =>
    (‚ąÄ x ‚ąą l, x ‚Č§ v) ‚ąß (‚ąÄ x ‚ąą r, v ‚Č§ x) ‚ąß IsOrdered l ‚ąß IsOrdered r ‚ąß (v ‚ąą l ‚ą® v ‚ąą r)

@[grind .]
def fastCheckMem (label : őĪ)(l: LabelledTree őĪ) : Bool := match l with
  | leaf l => l == label
  | node l left right =>
    if l == label then true
    else if label < l then fastCheckMem label left
    else fastCheckMem label right


