import Mathlib

open Finset

noncomputable abbrev Rep : Nat → Nat → Nat :=
  fun h x ↦ (Nat.add h x) * 2

def decide (h : List Nat) (x : Nat) : Prop :=
  x ∈ h

noncomputable def rep (h : List Nat) (x : Nat) : Nat :=
  match h.findIdx? (fun y => y = x) with
  | none => by
      exfalso
      have : ∃ y ∈ h, y = x := by aesop
      have := @List.findIdx?_eq_some_of_exists Sequent h (fun y => y = x) this
      simp_all
  | some k => k

noncomputable def theRep {H X} (rp : rep H X) : Nat :=
  match h : List.findIdx? (fun Y => decide (Y.setEqTo X)) H with
  | none => by
      exfalso
      have : ∃ Y ∈ H, decide (Y.setEqTo X) = true := by aesop
      have := @List.findIdx?_eq_some_of_exists Sequent H (fun Y => Y.setEqTo X) this
      simp_all
  | some k => k

/-- The tree generated from a winning Builder strategy -/
noncomputable -- :-(
def buildTree (s : Strategy tableauGame Builder) {H X p} (h : winning s ⟨H, X, p⟩) :
