noncomputable abbrev game := (⟨fun (x : Nat) => (x : Nat) = 0, fun x => x = 0⟩ : Game ℕ)

noncomputable abbrev strategy : Strategy game :=
  fun pos => 
    if pos.1 = 0 then
      Move.mk (List.mem_cons_self (List.mem_singleton_self 0))
    else
      Move.mk (List.mem_cons_self (List.mem_singleton_self (pos.1 - 1)))

noncomputable abbrev winning : winning strategy game := by
  intro pos
  induction pos with
  | zero => simp [winning]
  | succ n ih =>
    simp [winning]
    by_cases h : n = 0
    · subst h
      simp
      tauto
    · have : n > 0 := by omega
      have h3 : n - 1 > 0 := by omega
      simp [h3] at ih ⊢
      tauto

