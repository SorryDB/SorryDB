    have h3 : ∀ n : ℕ, (1 / (n : ℝ) ) ^ 2 = 1 / ((n : ℝ) ^ 2) := by 
      intro n
      field_simp
    rw [h3]
    apply summable_inv_pow
    all_goals norm_num
  simp_all [h2]
