#check PreLp (α := ι) E
#check Memℓp v p
#check lp E p

def ONE : PreLp (fun n : ℕ ↦ ℝ) := (fun _ : ℕ ↦ 1)

def GEO : PreLp (fun n : ℕ ↦ ℝ) := (fun n : ℕ ↦ (1 / n : ℝ))

example : Memℓp ONE ∞ := by sorry

