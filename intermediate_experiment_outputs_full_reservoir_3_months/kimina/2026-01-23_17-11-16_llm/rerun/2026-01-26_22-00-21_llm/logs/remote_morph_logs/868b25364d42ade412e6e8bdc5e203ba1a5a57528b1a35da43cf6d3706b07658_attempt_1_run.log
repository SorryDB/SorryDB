import Mathlib

/-! A pre-state is a maximal path in the build tree that does not contain an M step.
It consists of a sequence of non-modal edges starting from the root or just after a repeat.

-/
inductive PreState {pos} (bt : BuildTree pos) : Type
  | fromRoot : PreStateP bt .stop → PreState bt
  | fromMod {o m} : (e : Match.edge o m) → e.isModal → PreStateP bt m → PreState bt

/-! Collect all pre-states for a given build tree.
-/
def BuildTree.allPreStates {pos} (bt : BuildTree pos) : List (PreState bt) :=
  (bt.allPreStatePs .stop).map .fromRoot

/-! The forms of a pre-state π are the formulas accumulated along the path.
-/
def PreState.forms : PreState bt → List Formula := sorry

/-! The last formula in a pre-state.
-/
def PreState.last : PreState bt → Formula := sorry

/-! The loaded forms of a pre-state π are the negated load formulas accumulated along the path.
-/
def PreState.lforms : PreState bt → List NegLoadFormula := sorry

