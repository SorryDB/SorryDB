    simp only [List.mem_map] at Y_in
    rcases Y_in with ⟨ltX, _, def_pos⟩
    subst def_pos
    exact ⟨@Move.prLocTab H X nrep nbas _⟩
  · simp_wf
    simp only [tableauGame, Game.wf, WellFoundedRelation.rel]
    -- show that it's a move
    exact forTermination

