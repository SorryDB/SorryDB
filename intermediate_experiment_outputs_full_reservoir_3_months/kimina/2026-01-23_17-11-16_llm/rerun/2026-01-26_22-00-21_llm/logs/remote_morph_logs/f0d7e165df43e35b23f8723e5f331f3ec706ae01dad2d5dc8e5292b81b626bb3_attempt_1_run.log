      tauto
    · -- Show that the sum of the submodules equals the entire module
      intro x
      simp
      <;> simp_all [pointwise_sSup_eq_top I c]
  · -- Show that the internal direct sum equals the entire module
    intro x
    simp
    <;> simp_all [pointwise_sSup_eq_top I c]
