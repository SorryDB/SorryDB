        apply Finset.prod_ident
        intro k
        have h_j_ident : IdentDistrib (X (I k).1) (Y (I k).1) μ μ := by
          apply identDistrib_X_Y
        have h_j_ident' : IdentDistrib (X (I k).2) (Y (I k).2) μ μ := by
          apply identDistrib_X_Y
        exact ⟨h_j_ident, h_j_ident'⟩
      rw [h_prod_ident]
      rw [neg_eq_neg_one_mul, integral_neg, mul_neg, neg_mul, neg_neg]
      simp
