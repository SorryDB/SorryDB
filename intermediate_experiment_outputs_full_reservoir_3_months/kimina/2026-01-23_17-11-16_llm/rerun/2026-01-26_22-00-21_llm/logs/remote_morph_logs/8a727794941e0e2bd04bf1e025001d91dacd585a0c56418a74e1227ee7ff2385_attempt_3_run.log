    <;> try { tauto }
    <;> try { norm_num }
    <;> try { tauto }
    <;> try { tauto }
    <;> try { tauto }
    <;> try { tauto }
    <;> try { tauto }
    <;> try { tauto }
    <;> try { tauto }
    <;> try { tauto }
  | apply rule A B C hA hB hC =>
    -- The current node is applying a rule to its children
    -- The result is the concatenation of the results of the children
    -- The number of leaves is the sum of the number of leaves of the children
    -- We use the induction hypothesis for the children
