theorem eps_not_in_CNF_Grammar {α nt : Type} :
  ∀ grammar : @ContextFreeGrammarCNF α nt,
  ε ∉ grammar.val.GeneratedLanguage := by
    intro grammar h_contra
    unfold ContextFreeGrammar.generatedLanguage at h_contra
    cases h_contra with | intro default_CFGCNF =>
      have monotone := deriv_length_monotone_CNF grammar _ _ (Exists.intro default_CFGCNF (by tauto))
      nth_rewrite 2 [Word.eps_len_0.mpr] at monotone
      have start_len_1 : Word.length [@Sum.inl grammar.1.V grammar.1.Z grammar.1.start] = 1 := by tauto
      rw [start_len_1] at monotone
      rw [Nat.le_zero_eq 1] at monotone
      tauto
      rfl
```

This proves that the empty string is not in the language generated by a context-free grammar in Chomsky normal form.

