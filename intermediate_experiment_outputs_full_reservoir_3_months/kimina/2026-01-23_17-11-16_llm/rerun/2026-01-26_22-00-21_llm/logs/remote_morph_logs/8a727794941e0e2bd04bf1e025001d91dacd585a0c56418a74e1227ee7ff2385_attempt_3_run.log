  (cfg : {cfg : ContextFreeGrammar α nt // ε ∉ cfg.GeneratedLanguage})
  : { cfg₂ : ContextFreeGrammar α nt₂ // isInChomskyNormalForm cfg₂} := sorry

/--The grammar returned by`generate_equivalent_CNF`has the same generated language
