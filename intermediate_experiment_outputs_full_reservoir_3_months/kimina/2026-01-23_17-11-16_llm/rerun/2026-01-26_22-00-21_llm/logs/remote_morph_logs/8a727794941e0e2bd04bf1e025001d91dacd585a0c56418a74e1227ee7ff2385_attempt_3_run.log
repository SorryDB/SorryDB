/--The length of a context-free derivation in chomsky normal
  form is two times the length of the result word minus 1.-/
theorem CNF_derivation_lengths {α nt : Type} :
  ∀ cfgCNF : @ContextFreeGrammarCNF α nt, ∀ word : Word cfgCNF.val.Z,
