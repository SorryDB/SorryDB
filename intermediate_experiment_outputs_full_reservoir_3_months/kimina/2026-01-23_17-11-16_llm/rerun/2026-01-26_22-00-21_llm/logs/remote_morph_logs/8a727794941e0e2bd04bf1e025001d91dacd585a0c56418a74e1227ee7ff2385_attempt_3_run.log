theorem derivation_result_is_leaf_count :
  ∀ dt : ContextFreeGrammar.DerivationTree G,
  Word.len dt.result = List.length dt.collectLeaves' := by
  -- Base case: The root of the tree.
  -- If the root is a terminal, then the tree has one leaf (the root itself) and the result is that terminal, so length 1.
  -- Inductive step: If a node has children, then the result of that node is the concatenation of the results of its children.
