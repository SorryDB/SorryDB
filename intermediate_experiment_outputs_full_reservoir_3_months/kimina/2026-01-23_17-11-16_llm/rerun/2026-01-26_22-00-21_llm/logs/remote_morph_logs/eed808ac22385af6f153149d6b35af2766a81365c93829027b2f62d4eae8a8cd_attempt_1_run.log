[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  rcases h₀ with ⟨hx, hy, hz⟩
  have hx1 : x - 1 ≠ 0 := by
    intro h
    apply hx
    linarith
  have hy1 : y - 1 ≠ 0 := by
    intro h
    apply hy
    linarith
  have hz1 : z - 1 ≠ 0 := by
    intro h
    apply hz
    linarith
  have h2 : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 - 1 ≥ 0 := by
    have pos1 : (x - 1) ^ 2 > 0 := by
      apply pow_two_pos_of_ne_zero
      exact hx1
    have pos2 : (y - 1) ^ 2 > 0 := by
      apply pow_two_pos_of_ne_zero
      exact hy1
    have pos3 : (z - 1) ^ 2 > 0 := by
      apply pow_two_pos_of_ne_zero
      exact hz1
    have pos4 : (x - 1) ^ 2 * (y - 1) ^ 2 * (z - 1) ^ 2 > 0 := by
      positivity
    have h3 : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 - 1 =
        (x^2 * (y - 1)^2 * (z - 1)^2 + y^2 * (x - 1)^2 * (z - 1)^2 + z^2 * (x - 1)^2 * (y - 1)^2 - (x - 1)^2 * (y - 1)^2 * (z - 1)^2) / ((x - 1) ^ 2 * (y - 1) ^ 2 * (z - 1) ^ 2) := by
      field_simp
      <;> ring
    rw [h3]
    have h4 : x^2 * (y - 1)^2 * (z - 1)^2 + y^2 * (x - 1)^2 * (z - 1)^2 + z^2 * (x - 1)^2 * (y - 1)^2 - (x - 1)^2 * (y - 1)^2 * (z - 1)^2 ≥ 0 := by
      nlinarith [sq_nonneg (x * y - 1), sq_nonneg (y * z - 1), sq_nonneg (z * x - 1),
        sq_nonneg (x - 1), sq_nonneg (y - 1), sq_nonneg (z - 1),
        sq_nonneg (x * y * z - 1), h₁,
        sq_nonneg (x * y * z - 1), sq_nonneg (x * y - 1), sq_nonneg (y * z - 1), sq_nonneg (z * x - 1)]
    have h5 : (x^2 * (y - 1)^2 * (z - 1)^2 + y^2 * (x - 1)^2 * (z - 1)^2 + z^2 * (x - 1)^2 * (y - 1)^2 - (x - 1)^2 * (y - 1)^2 * (z - 1)^2) / ((x - 1) ^ 2 * (y - 1) ^ 2 * (z - 1) ^ 2) ≥ 0 := by
      apply div_nonneg
      linarith
      positivity
    linarith
  linarith
