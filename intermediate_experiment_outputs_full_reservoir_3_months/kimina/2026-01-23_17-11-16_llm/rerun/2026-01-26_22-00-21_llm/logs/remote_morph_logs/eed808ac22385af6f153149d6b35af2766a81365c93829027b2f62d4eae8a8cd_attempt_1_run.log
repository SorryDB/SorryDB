[i]Author: Walther Janous, Austria[/i] -/
theorem imo_2008_p2.parts.i (x y z : ℝ) (h₀ : x ≠ 1 ∧ y ≠ 1 ∧ z ≠ 1) (h₁ : x * y * z = 1) :
    x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 ≥ 1 := by
  have hx1 : x - 1 ≠ 0 := by
    intro h
    apply h₀.1
    linarith
  have hy1 : y - 1 ≠ 0 := by
    intro h
    apply h₀.2.1
    linarith
  have hz1 : z - 1 ≠ 0 := by
    intro h
    apply h₀.2.2
    linarith
  have h2 : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 - 1 ≥ 0 := by
    have h3 : x ^ 2 / (x - 1) ^ 2 + y ^ 2 / (y - 1) ^ 2 + z ^ 2 / (z - 1) ^ 2 - 1 =
        (x^2 * (y - 1)^2 * (z - 1)^2 + y^2 * (x - 1)^2 * (z - 1)^2 + z^2 * (x - 1)^2 * (y - 1)^2 - (x - 1)^2 * (y - 1)^2 * (z - 1)^2) / ((x - 1)^2 * (y - 1)^2 * (z - 1)^2) := by
      field_simp [hx1, hy1, hz1]
      ring
    rw [h3]
    have h4 : (x^2 * (y - 1)^2 * (z - 1)^2 + y^2 * (x - 1)^2 * (z - 1)^2 + z^2 * (x - 1)^2 * (y - 1)^2 - (x - 1)^2 * (y - 1)^2 * (z - 1)^2) ≥ 0 := by
      nlinarith [sq_nonneg (x * y - 1), sq_nonneg (y * z - 1), sq_nonneg (z * x - 1),
        sq_nonneg (x - 1), sq_nonneg (y - 1), sq_nonneg (z - 1),
        sq_nonneg (x * y * z - 1), h₁,
        sq_nonneg (x * z - 1), sq_nonneg (y * x - 1), sq_nonneg (z * y - 1)]
    apply div_nonneg
    linarith
    positivity
  linarith
