import Mathlib
set_option linter.unusedVariables false

noncomputable section

namespace ItaLean



/-!
# Filters
-/



section Filter

open Filter Topology
variable {őĪ ő≤ ő≥ : Type*}

lemma mono (f : őĪ ‚Üí ő≤) {F G : Filter őĪ} (h : F ‚Č§ G) : F.map f ‚Č§ G.map f := by
  intro s hs
  rcases hs with ‚ü®t, ht, hts‚ü©
  have h1 : t ‚ąą G := ht
  have h2 : t ‚ą© F.Nonempty := by
    apply h
    exact h1
  rcases h2 with ‚ü®x, hx‚ü©
  have hx1 : x ‚ąą t := by
    simpa using hx.1
  have hx2 : x ‚ąą F := by
    simpa using hx.2
  have hfx : f x ‚ąą s := by
    have h3 : f x ‚ąą f t := by
      apply hts
      exact hx1
    have h4 : f t ‚äÜ s := by
      simpa using hts
    have h5 : f x ‚ąą s := by
      apply h4
      exact h3
    exact h5
  have hfx2 : f x ‚ąą F.map f := by
    use x
    all_goals
      simp [hx2]
  have h6 : f x ‚ąą s ‚ą© F.map f := by
    exact ‚ü®hfx, hfx2‚ü©
  simp at h6 ‚äĘ
  all_goals
    tauto

/-- The function `f` tends to `G` along `F`. -/
def Tendsto (f : őĪ ‚Üí ő≤) (F : Filter őĪ) (G : Filter ő≤) := F.map f ‚Č§ G

lemma Tendsto_comp {s : őĪ ‚Üí ő≤} {t : ő≤ ‚Üí ő≥} {F : Filter őĪ} {G : Filter ő≤} {H : Filter ő≥}
    (hs : Tendsto s F G) (ht : Tendsto t G H) : Tendsto (t ‚ąė s) F H := by
  unfold Tendsto
  exact mono (t ‚ąė s) ht hs

example (f g : ‚ĄĚ ‚Üí ‚ĄĚ) (hf : Tendsto f (ūĚďĚ 0) (ūĚďĚ Real.pi))
    (hg : Tendsto g (ūĚďĚ Real.pi) atTop) : Tendsto (g ‚ąė f) (ūĚďĚ 0) atTop := by
  apply Tendsto_comp
  exact hg
  exact hf

example (a : ‚Ąē ‚Üí ‚ĄĚ) (ŌÜ : ‚ĄĚ ‚Üí ‚Ąā) (ha : Tendsto a atTop (ūĚďĚ (-1)))
    (hŌÜ : Tendsto ŌÜ (ūĚďĚ (-1)) (ūĚďĚ (Complex.I))) : Tendsto (ŌÜ ‚ąė a) atTop (ūĚďĚ (Complex.I)) := by
  apply Tendsto_comp
  exact hŌÜ
  exact ha


end Filter

