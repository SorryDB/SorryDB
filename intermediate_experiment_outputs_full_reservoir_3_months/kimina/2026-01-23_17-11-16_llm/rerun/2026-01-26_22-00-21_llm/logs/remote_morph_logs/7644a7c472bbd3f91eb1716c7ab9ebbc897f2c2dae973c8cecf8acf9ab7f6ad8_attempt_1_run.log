    simpa [Pone, ToTypeCat] using ⟨(f I), h_mem I⟩
  have h_compatible : (∀ (j j' : ↑T) (f : j ⟶ j'), (Pone T).map f (f' j) = f' j') := by
    intro I J g
    have h_ij := leOfHom g
    sorry
  let l := CategoryTheory.Limits.Types.Limit.mk (Pone T) f' h_compatible
  exact l

