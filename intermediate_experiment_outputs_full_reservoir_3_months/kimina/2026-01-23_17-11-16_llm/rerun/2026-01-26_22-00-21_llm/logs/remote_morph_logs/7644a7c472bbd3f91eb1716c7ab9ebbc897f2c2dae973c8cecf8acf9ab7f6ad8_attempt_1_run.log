/-- `M` is the direct sum of all the `M[λ]`. -/
lemma isInternal_chainBound (hT : IsChain LE.le T) (c : C) : IsInternal fun l : L T ↦ M[l]_[c] := by
  rw [isInternal_iff]
  constructor
  · intro m hm
    obtain ⟨J, hJ⟩ : ∃ J : T, (m.support : Set (L T)).InjOn (Λ J) := by
