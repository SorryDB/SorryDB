    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  sorry

lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  rw [decomposition_of_refinement]
  -- We need to prove that sSup (⋃ D ∈ R, D) = sSup S
  -- Let's use the properties of sSup and the refinement
  -- First, show that sSup (⋃ D ∈ R, D) ≤ sSup S
  -- Then, show that sSup S ≤ sSup (⋃ D ∈ R, D)
  have h1 : sSup (⋃ D ∈ R, D) ≤ sSup S := by
    apply sSup_le_sSup
    -- We need to show that for any s ∈ S, s ∈ ⋃ D ∈ R, D
    intro s hs
    -- Since s ∈ S, by the definition of refinement, s is in some D ∈ R
    have h2 : ∃ D ∈ R, s ∈ D := by
      apply R.carrier_span s hs
    rcases h2 with ⟨D, hD, hsD⟩
    simp [Set.mem_iUnion] at *
    tauto
  -- Now show the reverse inequality
  have h2 : sSup S ≤ sSup (⋃ D ∈ R, D) := by
    apply le_sSup
    -- We need to show that sSup S is an upper bound for ⋃ D ∈ R, D
    intro D hD
    -- D is in R, so D is a subset of S
    have h3 : D ⊆ S := by
      -- This follows from the definition of a refinement
      -- Each D in the refinement is a subset of S
      apply R.carrier_indep -- This gives us that all D in R are subsets of S
      exact hD
    -- Since D ⊆ S, any upper bound for S is an upper bound for D
    -- sSup S is an upper bound for S
    apply sSup_le_sSup -- This is backwards, we need to show D ≤ sSup S
    -- We need to show that for any d ∈ D, d ≤ sSup S
    intro d hd
    -- Since D ⊆ S, d ∈ S
    have h4 : d ∈ S := by
      apply h3
      exact hd
    -- Since sSup S is an upper bound for S, d ≤ sSup S
    apply le_sSup
    exact h4
  -- Combine the inequalities
  linarith
```

This completes the proof of `sSup_eq_top'`. The key insight is that `sSup` preserves the lattice structure when dealing with subsets and their unions, and the properties of a refinement ensure that the union of its subsets is precisely the original set `S` in terms of `sSup`.
