    (hT : {x | p x} ‚ąą ūĚďĚ x)
    (hT' : {x | p' x} ‚ąą ūĚďĚ x)
    (hS : {x | q x} ‚ąą ūĚďĚ x)
    (hS' : {x | q' x} ‚ąą ūĚďĚ x) :
    {x | p x ‚ąß q x ‚ą® p' x ‚ąß q' x} ‚ąą ūĚďĚ x := by sorry


end Filter

