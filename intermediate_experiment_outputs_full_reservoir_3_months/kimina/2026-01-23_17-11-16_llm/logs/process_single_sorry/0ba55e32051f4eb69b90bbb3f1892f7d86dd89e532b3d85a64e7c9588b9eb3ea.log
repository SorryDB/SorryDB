  ∀ ⦃x i⦄, x ∈ S.vertices → x i = 0 → c x ≠ i

def IsPanchromatic (c : (Fin n → ℝ) → Fin (m + 1)) (X : Finset (Fin n → ℝ)) : Prop :=
