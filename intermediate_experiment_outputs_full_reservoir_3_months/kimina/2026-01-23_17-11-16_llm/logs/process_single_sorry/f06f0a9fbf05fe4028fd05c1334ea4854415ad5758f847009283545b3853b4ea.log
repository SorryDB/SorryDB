      "by\n  have h1 : (unifDistN n).toOuterMeasure good_seqs = (Finset.filter (fun s => 10 ∣ ∏a, (s a) + 1) (Finset.univ : Finset (Fin n → Fin 9))).card / (9 ^ n : ℝ) := by\n    simp [Finset.filter, unifDistN, good_seqs]\n    <;> aesop\n  rw [h1]\n  have h2 : (Finset.filter (fun s => 10 ∣ ∏a, (s a) + 1) (Finset.univ : Finset (Fin n → Fin 9))).card = 9 ^ n - 5 ^ n - 8 ^ n + 4 ^ n := by\n    have h3 : (Finset.filter (fun s => 10 ∣ ∏a, (s a) + 1) (Finset.univ : Finset (Fin n → Fin 9))) = Finset.filter (fun s => 10 ∣ ∏a, (s a) + 1) (Finset.univ : Finset (Fin n → Fin 9)) := by rfl\n    rw [h3]\n    rw [Finset.card_filter]\n    simp\n    <;> native_decide\n  rw [h2]\n  field_simp\n  <;> ring_nf",
