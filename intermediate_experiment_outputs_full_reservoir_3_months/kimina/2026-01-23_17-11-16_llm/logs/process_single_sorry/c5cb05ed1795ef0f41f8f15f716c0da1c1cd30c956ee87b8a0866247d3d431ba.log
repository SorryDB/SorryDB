-- example 1.4.3iii
def NatTrans_Id_PowerSet : NaturalTransformation IdFunctor PowerSetFunctor where
  arrow X := fun x => ({x} : Set X)
  naturality {X Y} f := by
    funext x
    simp only [Category.comp, Function.comp_apply, IdFunctor, PowerSetFunctor]
    rw [Set.image]
    simp
```

