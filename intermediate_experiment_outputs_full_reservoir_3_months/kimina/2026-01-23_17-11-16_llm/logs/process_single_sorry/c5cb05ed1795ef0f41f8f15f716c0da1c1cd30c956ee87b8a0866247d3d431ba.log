    NaturalTransformation (Hom_c_? d) (Hom_c_? c) where
  arrow X := fun f => h ‚Čę f
  naturality {X Y} f := by
    funext g
    simp only [Category.comp, Function.comp_apply, Hom_c_?]
    rw [assoc]

