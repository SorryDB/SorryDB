  /-- The actual solution, represented as a vector of rational coefficients. -/
  val : د‡.toACCSystemCharges.Charges
  /-- The condition that this vector satisfies all linear equations. -/
  linearSol : âˆ€ i : Fin د‡.numberLinear, (د‡.linearACCs i) val = 0

/-!

