  add_assoc S T L := LinSols.ext (د‡.chargesAddCommMonoid.add_assoc _ _ _)
  zero := âں¨د‡.chargesAddCommMonoid.zero, fun _ â†¦ (د‡.linearACCs _).map_zeroâں©
  zero_add S := LinSols.ext (د‡.chargesAddCommMonoid.zero_add _)
  add_zero S := LinSols.ext (د‡.chargesAddCommMonoid.add_zero _)
