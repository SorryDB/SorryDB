ndef solsIncl (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.Charges :=\n  MulActionHom.comp د‡.quadSolsIncl د‡.solsInclQuadSols\n\n/-!\nThe inclusion of `Sols` into `Charges`.\n-/\n\n/-- The inclusion of `Sols` into `Charges`. -/\ndef solsIncl (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.Charges :=\n  MulActionHom.comp د‡.quadSolsIncl د‡.solsInclQuadSols\n\n/-!\nThe inclusion of `Sols` into `Charges`.\n-/\n\n/-- The inclusion of `Sols` into `Charges`. -/\ndef solsIncl (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.Charges :=\n  MulActionHom.comp د‡.quadSolsIncl د‡.solsInclQuadSols\n\n/-!\nThe inclusion of `Sols` into `Charges`.\n-/\n\n/-- The inclusion of `Sols` into `Charges`. -/\ndef solsIncl (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.Charges :=\n  MulActionHom.comp د‡.quadSolsIncl د‡.solsInclQuadSols\n\n/-!\nThe inclusion of `Sols` into `Charges`.\n-/\n\n/-- The inclusion of `Sols` into `Charges`. -/\ndef solsIncl (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.Charges :=\n  Mul",
      "\n  âˆƒ (sol : د‡.Sols), sol.val = S",
      "\n    apply s.quadSolsIncl.injective\n    simpa using h1\n  have h3 : S = T := by\n    apply s.solsInclQuadSols.injective\n    simpa using h2\n  exact h3",
      "\n  intro Sâ‚پ Sâ‚‚ h\n  have h3 : (solsIncl د‡) Sâ‚پ = (solsIncl د‡) Sâ‚‚ := h\n  have h4 : (solsIncl د‡) = (fun S => (quadSolsIncl د‡) ((solsInclQuadSols د‡) S)) := by\n    simp [solsIncl, solsInclQuadSols, quadSolsIncl]\n  rw [h4] at h3\n  have h5 : (quadSolsIncl د‡) ((solsInclQuadSols د‡) Sâ‚پ) = (quadSolsIncl د‡) ((solsInclQuadSols د‡) Sâ‚‚) := by\n    simpa using h3\n  have h6 : (solsInclQuadSols د‡) Sâ‚پ = (solsInclQuadSols د‡) Sâ‚‚ := by\n    apply quadSolsIncl_injective\n    exact h5\n  have h7 : Sâ‚پ = Sâ‚‚ := by\n    apply solsInclQuadSols_injective\n    exact h6\n  exact h7",
      "\n  intro S T h\n  simp [ACCSystem.solsIncl] at h âٹ¢\n  have h1 : (solsInclQuadraticSols S) = (solsInclQuadraticSols T) := by\n    apply quadraticSolsIncl_injective\n    simpa using h\n  have h2 : S = T := by\n    apply solsInclQuadraticSols_injective\n    simpa using h1\n  exact h2",
      "Charges`. -/\ndef solsIncl (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.Charges :=\n  MulActionHom.comp د‡.quadSolsIncl د‡.solsInclQuadSols\n\n@[sorryful]\nlemma solsIncl_injective (د‡ : ACCSystem) :\n    Function.Injective د‡.solsIncl := by\n  sorry\n```\n\nWe need to prove that the function `â†‘(solsIncl د‡)` is injective. Let's write the proof:\n\n```tactics\nimport Mathlib\n\nopen Function\n\n/-!\n\n### D.2. Module structure on the solutions to the linear ACCs\n\nwe now give a module structure to `LinSols`.\n\n-/\n\n/-- An instance providing the operations and properties for `LinSols` to form an\n  additive commutative monoid. -/\n@[simps!]\ninstance linSolsAddCommMonoid (د‡ : ACCSystemLinear) :\n    AddCommMonoid د‡.LinSols where\n  add S T := âں¨S.val + T.val, fun _ â†¦ by simp [(د‡.linearACCs _).map_add, S.linearSol _, T.linearSol _]âں©\n  add_comm S T := LinSols.ext (د‡.chargesAddCommMonoid.add_comm _ _)\n  add_assoc S T L := LinSols.ext (د‡.chargesAddCommMonoid.add_assoc _ _ _)\n  zero := âں¨د‡.chargesAddCommMonoid.zero, fun _ â†¦ (د‡.linearACCs _).map_zeroâں©\n  zero_add S := LinSols.ext (د‡.chargesAddCommMonoid.zero_add _)\n  add_zero S := LinSols.ext (د‡.chargesAddCommMonoid.add_zero _)\n  nsmul n S := âں¨n â€¢ S.val, fun _ â†¦ by simp [S.linearSol _]âں©\n  nsmul_zero n := by ext; simp only [zero_nsmul]; rfl\n  nsmul_succ n S := LinSols.ext (د‡.chargesAddCommMonoid.nsmul_succ _ _)\n\n/-- An instance providing the operations and properties for `LinSols` to form a\n  module over `â„ڑ`. -/\n@[simps!]\ninstance linSolsModule (د‡ : ACCSystemLinear) : Module â„ڑ د‡.LinSols where\n  smul a S := âں¨a â€¢ S.val, fun _ â†¦ by simp [(د‡.linearACCs _).map_smul, S.linearSol _]âں©\n  one_smul one_smul := LinSols.ext (د‡.chargesModule.one_smul _)\n  mul_smul a b S := LinSols.ext (د‡.chargesModule.mul_smul _ _ _)\n  smul_zero a := LinSols.ext (د‡.chargesModule.smul_zero _)\n  zero_smul S := LinSols.ext (د‡.chargesModule.zero_smul _)\n  smul_add a S T := LinSols.ext (د‡.chargesModule.smul_add _ _ _)\n  add_smul a b T:= LinSols.ext (د‡.chargesModule.add_smul _ _ _)\n\ninstance linSolsAddCommGroup (د‡ : ACCSystemLinear) : AddCommGroup د‡.LinSols :=\n  Module.addCommMonoidToAddCommGroup â„ڑ\n\n/-!\n\n### D.3. Embedding of the solutions to the linear ACCs into the module of charges\n\nWe give the linear embedding of solutions to the linear ACCs `LinSols` into\nthe module of all `charges`.\n\n-/\n\n/-- The inclusion of `LinSols` into `charges`. -/\ndef linSolsIncl (د‡ : ACCSystemLinear) : د‡.LinSols â†’â‚—[â„ڑ] د‡.Charges where\n  toFun S := S.val\n  map_add' _ _ := rfl\n  map_smul' _ _ := rfl\n\n@[sorryful]\nlemma linSolsIncl_injective (د‡ : ACCSystemLinear) :\n    Function.Injective د‡.linSolsIncl := by\n  sorry\n\nend ACCSystemLinear\n\n/-!\n\n## E. The quadratic anomaly cancellation conditions\n\nWe extend `ACCSystemLinear` to `ACCSystemQuad` by adding a finite number\n(determined by `numberQuadratic`) of quadratic equations in the rational charges.\n\nThese quadratic anomaly cancellation conditions correspond to the interaction\nof the `u(1)` part of the gauge group of interest with another abelian part.\n\n-/\n\n/-- The type of charges plus the linear ACCs plus the quadratic ACCs. -/\nstructure ACCSystemQuad extends ACCSystemLinear where\n  /-- The number of quadratic ACCs. -/\n  numberQuadratic : â„•\n  /-- The quadratic ACCs. -/\n  quadraticACCs : Fin numberQuadratic â†’ HomogeneousQuadratic toACCSystemCharges.Charges\n\nnamespace ACCSystemQuad\n\n/-!\n\n## F. The solutions to the quadratic and linear anomaly cancellation conditions\n\nWe define the type `QuadSols` of solutions to the linear and quadratic ACCs.\n\n-/\n\n/-- The type of solutions to the linear and quadratic ACCs. -/\nstructure QuadSols (د‡ : ACCSystemQuad) extends د‡.LinSols where\n  /-- The condition that the charge satisfies the quadratic ACCs. -/\n  quadSol : âˆ€ i : Fin د‡.numberQuadratic, (د‡.quadraticACCs i) val = 0\n\n/-!\n\n### F.1. Extensionality of solutions to the quadratic and linear ACCs\n\nWe prove a lemma relating to the equality of two elements of `QuadSols`.\n\n-/\n\n/-- Two `QuadSols` are equal if the underlying charges are equal. -/\n@[ext]\nlemma QuadSols.ext {د‡ : ACCSystemQuad} {S T : د‡.QuadSols} (h : S.val = T.val) :\n    S = T := by\n  have h := ACCSystemLinear.LinSols.ext h\n  cases' S\n  simp_all only\n\n/-!\n\n### F.2. MulAction of rationals on the solutions to the quadratic and linear ACCs\n\nThe type `QuadSols` does not carry the structure of a module over `â„ڑ` as\nthe quadratic ACCs are not linear. However it does carry the structure of\na `MulAction` of `â„ڑ`.\n\n-/\n/-- An instance giving the properties and structures to define an action of `â„ڑ` on `QuadSols`. -/\ninstance quadSolsMulAction (د‡ : ACCSystemQuad) : MulAction â„ڑ د‡.QuadSols where\n  smul a S := âں¨a â€¢ S.toLinSols, fun _ â†¦ by erw [(د‡.quadraticACCs _).map_smul, S.quadSol _,\n    mul_zero]âں©\n  mul_smul a b S := QuadSols.ext (mul_smul _ _ _)\n  one_smul S := QuadSols.ext (one_smul _ _)\n\n/-!\n\n### F.3. Embeddings of quadratic solutions into linear solutions\n\nWe give the equivariant of solutions to the quadratic and linear ACCs `QuadSols` into\nthe solutions to the linear ACCs `LinSols`.\n\n-/\n\n/-- The inclusion of quadratic solutions into linear solutions. -/\ndef quadSolsInclLinSols (د‡ : ACCSystemQuad) : د‡.QuadSols â†’[â„ڑ] د‡.LinSols where\n  toFun := QuadSols.toLinSols\n  map_smul' _ _ := rfl\n\n@[sorryful]\nlemma quadSolsInclLinSols_injective (د‡ : ACCSystemQuad) :\n    Function.Injective د‡.quadSolsInclLinSols := by\n  sorry\n\n/-!\n\n### F.4. Embeddings of solutions to linear ACCs into quadratic solutions when no quadratics\n\nWhen there are no quadratic ACCs, the solutions to the linear ACCs embed into the solutions\nto the linear and quadratic ACCs.\n\n-/\n\n/-- The inclusion of the linear solutions into the quadratic solutions, where there is\n  no quadratic equations (i.e. no U(1)'s in the underlying gauge group). -/\ndef linSolsInclQuadSolsZero (د‡ : ACCSystemQuad) (h : د‡.numberQuadratic = 0) :\n    د‡.LinSols â†’[â„ڑ] د‡.QuadSols where\n  toFun S := âں¨S, by intro i; rw [h] at i; exact Fin.elim0 iâں©\n  map_smul' _ _ := rfl\n\n/-!\n\n### F.5. Embeddings of quadratic solutions into all charges\n\nWe give the equivariant embedding of solutions to the quadratic and linear ACCs `QuadSols` into\nthe module of all charges `Charges`.\n\n-/\n\n/-- The inclusion of quadratic solutions into all charges. -/\ndef quadSolsIncl (د‡ : ACCSystemQuad) : د‡.QuadSols â†’[â„ڑ] د‡.Charges :=\n  MulActionHom.comp د‡.linSolsIncl.toMulActionHom د‡.quadSolsInclLinSols\n\n@[sorryful]\nlemma quadSolsIncl_injective (د‡ : ACCSystemQuad) :\n    Function.Injective د‡.quadSolsIncl := by\n  sorry\n\nend ACCSystemQuad\n\n/-!\n\n## G. The full anomaly cancellation conditions\n\nWe extend `ACCSystemQuad` to `ACCSystem` by adding the single cubic equation\nin the rational charges. This corresponds to the `u(1)^3` anomaly.\n\n-/\n\n/-- The type of charges plus the anomaly cancellation conditions. -/\nstructure ACCSystem extends ACCSystemQuad where\n  /-- The cubic ACC. -/\n  cubicACC : HomogeneousCubic toACCSystemCharges.Charges\n\nnamespace ACCSystem\n\n/-!\n\n## H. The solutions to the full anomaly cancellation conditions\n\nWe define the type `Sols` of solutions to the full ACCs.\n\n-/\n\n/-- The type of solutions to the anomaly cancellation conditions. -/\nstructure Sols (د‡ : ACCSystem) extends د‡.QuadSols where\n  /-- The condition that the charge satisfies the cubic ACC. -/\n  cubicSol : د‡.cubicACC val = 0\n\n/-!\n\n### H.1. Extensionality of solutions to the ACCs\n\nWe prove a lemma relating to the equality of two elements of `Sols`.\n\n-/\n\n/-- Two solutions are equal if the underlying charges are equal. -/\nlemma Sols.ext {د‡ : ACCSystem} {S T : د‡.Sols} (h : S.val = T.val) :\n    S = T := by\n  have h := ACCSystemQuad.QuadSols.ext h\n  cases' S\n  simp_all only\n\n/-!\n\n### H.2. The `IsSolution` predicate\n\nwe define a predicate on charges which is true if they correspond to a solution.\n\n-/\n\n/-- A charge `S` is a solution if it extends to a solution. -/\ndef IsSolution (د‡ : ACCSystem) (S : د‡.Charges) : Prop :=\n  âˆƒ (sol : د‡.Sols), sol.val = S\n\n/-!\n\n### H.3. MulAction of `â„ڑ` on the solutions to the ACCs\n\nLike with `QuadSols`, the type `Sols` does not carry the structure of a module over `â„ڑ`\nas the cubic nor quadratic ACC is not linear. However it does carry the structure of\na `MulAction` of `â„ڑ`.\n\n-/\n\n/-- An instance giving the properties and structures to define an action of `â„ڑ` on `Sols`. -/\ninstance solsMulAction (د‡ : ACCSystem) : MulAction â„ڑ د‡.Sols where\n  smul a S := âں¨a â€¢ S.toQuadSols, by\n    erw [(د‡.cubicACC).map_smul, S.cubicSol]\n    exact Rat.mul_zero (a ^ 3)âں©\n  mul_smul a b S := Sols.ext (mul_smul _ _ _)\n  one_smul S := Sols.ext (one_smul _ _)\n\n/-!\n\n### H.4. Embeddings of solutions to the ACCs into quadratic solutions\n\n-/\n\n/-- The inclusion of `Sols` into `QuadSols`. -/\ndef solsInclQuadSols (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.QuadSols where\n  toFun := Sols.toQuadSols\n  map_smul' _ _ := rfl\n\n@[sorryful]\nlemma solsInclQuadSols_injective (د‡ : ACCSystem) :\n    Function.Injective د‡.solsInclQuadSols := by\n  sorry\n\n/-!\n\n### H.5. Embeddings of solutions to the ACCs into linear solutions\n\n-/\n/-- The inclusion of `Sols` into `LinSols`. -/\ndef solsInclLinSols (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.LinSols :=\n  MulActionHom.comp د‡.quadSolsInclLinSols د‡.solsInclQuadSols\n\n@[sorryful]\nlemma solsInclLinSols_injective (د‡ : ACCSystem) :\n    Function.Injective د‡.solsInclLinSols := by\n  sorry\n\n/-!\n\n### H.6. Embeddings of solutions to the ACCs into charges\n\n-/\n\n/-- The inclusion of `Sols` into `Charges`. -/\ndef solsIncl (د‡ : ACCSystem) : د‡.Sols â†’[â„ڑ] د‡.Charges :=\n  MulActionHom.comp د‡.quadSolsIncl د‡.solsInclQuadSols\n\n@[sorryful]\nlemma solsIncl_injective (د‡ : ACCSystem) :\n    Function.Injective د‡.solsIncl := by\n  sorry\n```\n\nNow, we'll complete the proof for `solsIncl_injective`:\n\n```tactics\nimport Mathlib\n\nopen Function\n\n/-!\n\n### D.2. Module structure on the solutions to the linear ACCs\n\nwe now give a module structure to `LinSols`.\n\n-/\n\n/-- An instance providing the operations and properties for `LinSols` to form an\n  additive commutative monoid. -/\n@[simps!]\ninstance linSolsAddCommMonoid (د‡ : ACCSystemLinear) :\n    AddCommMonoid د‡.LinSols where\n  add S T := âں¨S.val + T.val, fun _ â†¦ by simp [(د‡.linearACCs _).map_add, S.linearSol _, T.linearSol _]âں©\n  add_comm S T := LinSols.ext (د‡.chargesAddCommMonoid.add_comm _ _)\n  add_assoc S T L := LinSols.ext (د‡.chargesAddCommMonoid.add_assoc _ _ _)\n  zero := âں¨د‡.chargesAddCommMonoid.zero, fun _ â†¦ (د‡.linearACCs _).map_zeroâں©\n  zero_add S := LinSols.ext (د‡.chargesAddCommMonoid.zero_add _)\n  add_zero S := LinSols.ext (د‡.chargesAddCommMonoid.add_zero _)\n  nsmul n S := âں¨n â€¢ S.val, fun _ â†¦ by simp [S.linearSol _]âں©\n  nsmul_zero n := by ext; simp only [zero_nsmul]; rfl\n  nsmul_succ n S := LinSols.ext (د‡.chargesAddCommMonoid.nsmul_succ _ _)\n\n/-- An instance providing the operations and properties for `LinSols` to form a\n  module over `â„ڑ`. -/\n@[simps!]\ninstance linSolsModule (د‡ : ACCSystemLinear) : Module â„ڑ د‡.LinSols where\n  smul a S := âں¨a â€¢ S.val, fun _ â†¦ by simp [(د‡.linearACCs _).map_smul, S.linearSol _]âں©\n  one_smul one_smul := LinSols.ext (د‡.chargesModule.one_smul _)\n  mul_smul a b S := LinSols.ext (د‡.chargesModule.mul_smul _ _ _)\n  smul_zero a := LinSols.ext (د‡.chargesModule.smul_zero _)\n  zero_smul S := LinSols.ext (د‡.chargesModule.zero_smul _)\n  smul_add a S T := LinSols.ext (د‡.chargesModule.smul_add _ _ _)\n  add_smul a b T:= LinSols.ext (د‡.chargesModule.add_smul _ _ _)\n\ninstance linSolsAddCommGroup (د‡ : ACCSystemLinear) : AddCommGroup د‡.LinSols :=\n  Module.addCommMonoidToAddCommGroup â„ڑ\n\n/-!\n\n### D.3. Embedding of the solutions to the linear ACCs into the module of charges\n\nWe give the linear embedding of solutions to the linear ACCs `LinSols` into\nthe module of all `charges`.\n\n-/\n\n/-- The inclusion of `LinSols` into `charges`. -/\ndef linSolsIncl (د‡ : ACCSystemLinear) : د‡.LinSols â†’â‚—[â„ڑ] د‡.Charges where\n  toFun S := S.val\n  map_add' _ _ := rfl\n  map_smul' _ _ := rfl\n\n@[sorryful]\nlemma linSolsIncl_injective (د‡ : ACCSystemLinear) :\n    Function.Injective د‡.linSolsIncl := by\n  sorry\n\nend ACCSystemLinear\n\n/-!\n\n## E. The quadratic anomaly cancellation conditions\n\nWe extend `ACCSystemLinear` to `ACCSystemQuad` by adding a finite number\n(determined by `numberQuadratic`) of quadratic equations in the rational charges.\n\nThese quadratic anomaly cancellation conditions correspond to the interaction\nof the `u(1)` part of the gauge group of interest with another abelian part.\n\n-/\n\n/-- The type of charges plus the linear ACCs plus the quadratic ACCs. -/\nstructure ACCSystemQuad extends ACCSystemLinear where\n  /-- The number of quadratic ACCs. -/\n  numberQuadratic : â„•\n  /-- The quadratic ACCs. -/\n  quadraticACCs : Fin numberQuadratic â†’ HomogeneousQuadratic toACCSystemCharges.Charges\n\nnamespace ACCSystemQuad\n\n/-!\n\n## F. The solutions to the quadratic and linear anomaly cancellation conditions\n\nWe define the type `QuadSols` of solutions to the linear and quadratic ACCs.\n\n-/\n\n/-- The type of solutions to the linear and quadratic ACCs. -/\nstructure QuadSols (د‡ : ACCSystemQuad) extends د‡.LinSols where\n  /-- The condition that the charge satisfies the quadratic ACCs. -/\n  quadSol : âˆ€ i : Fin د‡.numberQuadratic, (د‡.quadraticACCs i) val = 0\n\n/-!\n\n### F.1. Extensionality of solutions to the quadratic and linear ACCs\n\nWe prove a lemma relating to the equality of two elements of `QuadSols`.\n\n-/\n\n/-- Two `QuadSols` are equal if the underlying charges are equal. -/\n@[ext]\nlemma QuadSols.ext {د‡ : ACCSystemQuad} {S T : د‡.QuadSols} (h : S.val = T.val) :\n    S = T := by\n  have h := ACCSystemLinear.LinSols.ext h\n  cases' S\n  simp_all only\n\n/-!\n\n### F.2. MulAction of rationals on the solutions to the quadratic and linear ACCs\n\nThe type `QuadSols` does not carry the structure of a module over `â„ڑ` as\nthe quadratic ACCs are not linear. However it does carry the structure of\na `MulAction` of `â„ڑ`.\n\n-/\n/-- An instance giving the properties and structures to define an action of `â„ڑ` on `QuadSols`. -/\ninstance quadSolsMulAction (د‡ : ACCSystemQuad) : MulAction â„ڑ د‡.QuadSols where\n  smul a S := âں¨a â€¢ S.toLinSols, fun _ â†¦ by erw [(د‡.quadraticACCs _).map_smul, S.quadSol _,\n    mul_zero]âں©\n  mul_smul a b S := QuadSols.ext (mul_smul _ _ _)\n  one_smul S := QuadSols.ext (one_smul _ _)\n\n/-!\n\n### F.3. Embeddings of quadratic solutions into linear solutions\n\nWe give the equivariant of solutions to the quadratic and linear ACCs `QuadSols` into\nthe solutions to the linear ACCs `LinSols`.\n\n-/\n\n/-- The inclusion of quadratic solutions into linear solutions. -/\ndef quadSolsInclLinSols (د‡ : ACCSystemQuad) : د‡.QuadSols â†’[â„ڑ] د‡.LinSols where\n  toFun := QuadSols.toLinSols\n  map_smul' _ _ := rfl\n\n@[sorryful]\nlemma quadSolsInclLinSols_injective (د‡ : ACCSystemQuad) :\n    Function.Injective د‡.quadSolsInclLinSols := by\n  sorry\n\n/-!\n\n### F.4. Embeddings of solutions to linear ACCs into quadratic solutions when no quadratics\n\nWhen there are no quadratic ACCs, the solutions to the linear ACCs embed into the solutions\nto the linear and quadratic ACCs.\n\n-/\n\n/-- The inclusion of the linear solutions into the quadratic solutions, where there is\n  no quadratic equations (i.e. no U(1)'s in the underlying gauge group). -/\ndef linSolsInclQuadSolsZero (د‡ : ACCSystemQuad) (h : د‡.numberQuadratic = 0) :\n    د‡.LinSols â†’[â„ڑ] د‡.QuadSols where\n  toFun S := âں¨S, by intro i; rw [h] at i; exact Fin.elim0 iâں©\n  map_smul'