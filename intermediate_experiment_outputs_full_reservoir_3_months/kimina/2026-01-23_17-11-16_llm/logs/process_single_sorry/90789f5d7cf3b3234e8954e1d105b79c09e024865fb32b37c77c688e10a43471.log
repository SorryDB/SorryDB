    NaturalTransformation (Hom_c_? d) (Hom_c_? c) where
  arrow X := fun f => h ≫ f
  naturality {X Y} f := by
    funext x
    simp only [Category.comp, Function.comp_apply, IdFunctor, PowerSetFunctor]
