  carrier := I ∩ J
  add_mem' := by
    sorry
  zero_mem' := by
    sorry
  smul_mem' := by
    sorry

/-
Finally, let's look at ideal quotients. If `I` is an ideal of the ring `R`,
then we write the quotient of `R` modulo `I` as `R ⧸ I`.
-/
example (I : Ideal R) (x y z : R ⧸ I) :
    x * (y + z) + y * (z + x) + z * (x + y) = 2 * x * y + 2 * y * z + 2 * x * z := by
  ring

