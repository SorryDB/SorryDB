  intro ε hε
  use 1, zero_lt_one, 1, default
  constructor
  · -- First goal: (CPTPMap.piProd (fun (_ : Fin 1) ↦ A)).Emulates B
    have h1 : (CPTPMap.piProd (fun (_ : Fin 1) ↦ Λ)).Emulates (CPTPMap.id (Fin 1) (Fin 1)) := by
