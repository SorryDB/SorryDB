  intro ε hε
  use 1
  constructor
  · exact Nat.one_pos
  refine ⟨CPTPMap.id, ?_⟩
  · -- Show Λ.emulates id
    have h : Λ.emulates CPTPMap.id := by
      use CPTPMap.id, CPTPMap.id
      simp
    exact h
  · -- Show id.εApproximates id
    exact εApproximates_self

