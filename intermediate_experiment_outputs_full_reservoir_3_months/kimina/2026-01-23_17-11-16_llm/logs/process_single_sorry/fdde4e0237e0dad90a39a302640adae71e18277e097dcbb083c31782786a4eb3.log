     apply Nat.pow_le_pow_of_le_right\n                 all_goals\n                   omega\n                 ]\n             have h6' : 1 + 2 ^ t₁.height + 2 ^ t₁.height ≤ 2 ^ (1 + t₁.height) := by\n               ring_nf\n               all_goals\n                 omega\n             nlinarith\n           rw [show 1 + max t₁.height t₂.height = 1 + t₁.height by\n             simp [h_max]\n           ]\n           all_goals\n             omega\n       all_goals\n         omega\n  }",
      "\n     cases max_cases t₁.height t₂.height with\n     | inl h =>\n       omega\n     | inr h =>\n       omega\n  }\n  {\n   induction t with\n   | null  => simp [Tree.height, Tree.size]\n   | node t₁ x t₂ ihl ihr =>\n     simp [Tree.height, Tree.size] at ihl ihr ⊢\n     all_goals\n       try { \n         have h1 : t₁.size < 2 ^ t₁.height := by omega\n         have h2 : t₂.size < 2 ^ t₂.height := by omega\n         have h3 : t₁.size + t₂.size < 2 ^ t₁.height + 2 ^ t₂.height := by omega\n         have h4 : 2 ^ t₁.height + 2 ^ t₂.height ≤ 2 ^ (1 + max t₁.height t₂.height) := by\n           cases max_cases t₁.height t₂.height with\n           | inl h => \n             have : t₁.height = max t₁.height t₂.height := by omega\n             have : 2 ^ t₁.height + 2 ^ t₂.height ≤ 2 ^ (t₁.height + 1) := by\n               have h5 : t₂.height < t₁.height := by omega\n               have h6 : 2 ^ t₂.height ≤ 2 ^ t₁.height := by\n                 exact (pow_le_pow_iff_right (by norm_num)).mpr (by omega)\n               omega\n             omega\n           | inr h => \n             have : t₂.height = max t₁.height t₂.height := by omega\n             have : 2 ^ t₁.height + 2 ^ t₂.height ≤ 2 ^ (t₂.height + 1) := by\n               have h5 : t₁.height < t₂.height := by omega\n               have h6 : 2 ^ t₁.height ≤ 2 ^ t₂.height := by\n                 exact (pow_le_pow_iff_right (by norm_num)).mpr (by omega)\n               omega\n             omega\n         have h5 : t₁.size + t₂.size < 2 ^ (1 + max t₁.height t₂.height) := by\n           omega\n         have h6 : t₁.size + t₂.size < 2 ^ (1 + max t₁.height t₂.height) := by\n           omega\n         omega\n       }\n       try { \n         all_goals omega \n       }\n  }",
