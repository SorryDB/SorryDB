    intro t
    induction t using Nat.strongRecOn with
    | ind t ih =>
      cases t with
      | null =>
        simp
      | node l x r =>
        have h2 := ih l (by simp)
        have h3 := ih r (by simp)
        simp [Tree.size, Tree.height] at h2 h3 ⊢
        omega
  have h2 : ∀ (t : Tree α), t.height ≤ t.size := by
    intro t
    induction t using Nat.strongRecOn with
    | ind t ih =>
      cases t with
      | null =>
        simp [Tree.height, Tree.size]
      | node l x r ihl ihr =>
        simp [Tree.height, Tree.size]
        omega
  have h3 : ∀ (t : Tree α), t.size < 2 ^ t.height := by
    intro t
    have h4 : t.size ≤ 2 ^ t.height - 1 := h1 t
    have h5 : t.size + 1 ≤ 2 ^ t.height := by
      omega
    omega
  exact ⟨h2 t, h3 t⟩
