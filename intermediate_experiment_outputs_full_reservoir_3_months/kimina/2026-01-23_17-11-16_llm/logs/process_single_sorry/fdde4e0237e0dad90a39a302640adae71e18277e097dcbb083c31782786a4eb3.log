   induction t with
   | null  => simp [Tree.height, Tree.size]
   | node t₁ x t₂ ihl ihr =>
     simp [Tree.height, Tree.size]
     sorry
  }
  {
   induction t with
   | null  => simp [Tree.height, Tree.size]
   | node t₁ x t₂ ihl ihr =>
     simp [Tree.height, Tree.size]
     sorry
  }
```

