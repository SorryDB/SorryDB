-- # Exercicio 4.6

-- #eval D2.search₁ (λ (x, y) => x ^ 3 + y ^ 3) 1729


-- # Exercicio 4.7

namespace BST1

def flatcat : (t : Tree a) → (xs: List a) → List a
| .null, xs => xs
| .node l x r, xs => flatcat l (x :: flatcat r xs)

def Tree.flatten₁ (t : Tree a) : List a :=
 flatcat t []

theorem flatten_eq_helper_accum (t : Tree a) (xs: List a)
  : t.flatten ++ xs = flatcat t xs := by
  induction t generalizing xs with
  | null => rfl
  | node l x r ihl ihr =>
    rw [flatcat, ←ihr]
    rw [←ihl (x :: (r.flatten ++ xs))]
    rw [List.append_cons]
    rw [← List.append_assoc]
    rw [Tree.flatten]

example (t: Tree a) : t.flatten = t.flatten₁ := by
  induction t with
  | null => exact rfl
  | node l x r ihl ihr =>
    rw [Tree.flatten₁]
    simp [← flatten_eq_helper_accum]

end BST1

-- # Exercicio 4.8


namespace BST1

example {α : Type} (t : Tree α) :
  t.height ≤ t.size ∧ t.size < 2 ^ t.height := by
  constructor
  · -- First goal: t.height ≤ t.size
    intro t
    induction t using Nat.strongRecOn with
    | ind h =>
      cases h with
      | isDef t =>
        simp [Tree.height, Tree.size] at *
        all_goals
          try { 
            cases max_cases t.1.1 t.1.2 with
            | inl h1 =>
              omega
            | inr h2 =>
              omega
          }
        all_goals
          try { nlinarith }
      | intro t ih =>
        simp [Tree.height, Tree.size] at ih ⊢
        all_goals
          try { 
            cases max_cases t.1.1 t.1.2 with
            | inl h1 =>
              omega
            | inr h2 =>
              omega
          }
        all_goals
          try { nlinarith }
  · -- Second goal: t.size < 2 ^ t.height
    intro t
    induction t using Nat.strongRecOn with
    | ind h =>
      cases h with
      | isDef t =>
        simp [Tree.height, Tree.size] at *
        all_goals
          try { 
            have h1 : (1 : ℕ) < (2 : ℕ) ^ (1 : ℕ) := by norm_num
            omega
          }
        all_goals
          try { nlinarith }
      | intro t ih =>
        simp [Tree.height, Tree.size] at ih ⊢
        all_goals
          try { 
            have h1 : (1 : ℕ) < (2 : ℕ) ^ (1 : ℕ) := by norm_num
            have h2 : (1 + t.1.1 + t.1.2 : ℕ) < (2 : ℕ) ^ (1 + max t.1.1 t.1.2 : ℕ) := by
              have h3 : (t.1.1 : ℕ) < (2 : ℕ) ^ (t.1.1 : ℕ) := ih.1
              have h4 : (t.1.2 : ℕ) < (2 : ℕ) ^ (t.1.2 : ℕ) := ih.2
              have h5 : (t.1.1 : ℕ) ≤ (max t.1.1 t.1.2 : ℕ) := by 
                cases max_cases t.1.1 t.1.2 with
                | inl h11 => 
                  omega
                | inr h22 => 
                  omega
              have h6 : (t.1.2 : ℕ) ≤ (max t.1.1 t.1.2 : ℕ) := by 
                cases max_cases t.1.1 t.1.2 with
                | inl h11 => 
                  omega
                | inr h22 => 
                  omega
              have h7 : (2 : ℕ) ^ (t.1.1 : ℕ) ≤ (2 : ℕ) ^ (max t.1.1 t.1.2 : ℕ) := by 
                apply pow_le_pow_right 
                all_goals 
                  try { norm_num }
                all_goals 
                  try { omega }
              have h8 : (2 : ℕ) ^ (t.1.2 : ℕ) ≤ (2 : ℕ) ^ (max t.1.1 t.1.2 : ℕ) := by 
                apply pow_le_pow_right 
                all_goals 
                  try { norm_num }
                all_goals 
                  try { omega }
              have h9 : (t.1.1 : ℕ) + (t.1.2 : ℕ) < (2 : ℕ) ^ (max t.1.1 t.1.2 : ℕ) + (2 : ℕ) ^ (max t.1.1 t.1.2 : ℕ) := by 
                linarith 
              have h10 : (1 + t.1.1 + t.1.2 : ℕ) < (2 : ℕ) ^ (1 + max t.1.1 t.1.2 : ℕ) := by 
                have h11 : (2 : ℕ) ^ (1 + max t.1.1 t.1.2 : ℕ) = (2 : ℕ) * (2 : ℕ) ^ (max t.1.1 t.1.2 : ℕ) := by 
                  ring_nf 
                rw [h11] 
                nlinarith 
              linarith 
            omega 
          }
        all_goals
          try { nlinarith }
