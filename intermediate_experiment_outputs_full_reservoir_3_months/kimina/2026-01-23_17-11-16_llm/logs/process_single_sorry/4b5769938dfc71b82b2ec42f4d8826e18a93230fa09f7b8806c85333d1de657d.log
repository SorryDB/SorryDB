import Game.Levels.L22Pset.L01

open Finset Set

World "L22Pset"
Level 2
Title "Continuity Exercise"
Introduction "
# Level 2: Continuity Exercise

Prove that `x ↦ x ^ 3` is continuous.

"

/-- Prove this
-/
Statement : FunCont (fun x ↦ x ^ 3) := by
  intro x ε hε
  let δ : ℝ := min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1))
  have δle1 : δ ≤ 1 := by
    cases min_cases 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) with
    | inl h =>
      linarith
    | inr h =>
      linarith
  have δle2 : δ ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by
    cases min_cases 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) with
    | inl h =>
      linarith
    | inr h =>
      linarith
  have δpos : 0 < δ := by
    apply min_pos
    · norm_num
    · -- Show the second argument of min is positive
      have h1 : ε / (3 * |x| ^ 2 + 3 * |x| + 1) > 0 := by
        apply div_pos
        · linarith
        · -- Show the denominator is positive
          have h2 : 3 * |x| ^ 2 + 3 * |x| + 1 > 0 := by
            nlinarith [sq_nonneg (|x|), sq_nonneg (|x| + 1)]
          linarith
      linarith
  use δ, δpos
  intro y hy
  have h1 : |y - x| < 1 := by
    linarith [hy, δle1]
  have hy1 : |y| ≤ |x| + 1 := by
    have h2 : |y - x| < 1 := h1
    have h3 : |y| ≤ |y - x| + |x| := by
      apply abs_sub
    have h4 : |y - x| < 1 := h2
    have h5 : |y| < |x| + 1 := by
      linarith [h3, h4]
    linarith
  have h2 : x ^ 2 + x * y + y ^ 2 ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by
    have h3 : y ^ 2 ≤ (|x| + 1) ^ 2 := by
      have h4 : |y| ≤ |x| + 1 := hy1
      have h5 : y ^ 2 ≤ (|x| + 1) ^ 2 := by
        have h6 : |y| ≤ |x| + 1 := h4
        have h7 : y ^ 2 ≤ (|x| + 1) ^ 2 := by
          apply sq_le_sq.mpr
          linarith [abs_nonneg y, abs_nonneg (|x| + 1)]
        linarith
      linarith
    nlinarith [sq_nonneg (x - y), sq_nonneg (x + y), sq_nonneg (x - (|x|)), sq_nonneg (y - (|x|)), abs_nonneg x, abs_nonneg y, abs_nonneg (x - y), abs_nonneg (x + y)]
  have h3 : |x ^ 2 + x * y + y ^ 2| ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by
    have h4 : x ^ 2 + x * y + y ^ 2 ≥ 0 := by
      nlinarith [sq_nonneg (x + y / 2), sq_nonneg (y), sq_nonneg (x - y)]
    have h5 : |x ^ 2 + x * y + y ^ 2| = x ^ 2 + x * y + y ^ 2 := by
      rw [abs_of_nonneg h4]
    rw [h5]
    linarith [h2]
