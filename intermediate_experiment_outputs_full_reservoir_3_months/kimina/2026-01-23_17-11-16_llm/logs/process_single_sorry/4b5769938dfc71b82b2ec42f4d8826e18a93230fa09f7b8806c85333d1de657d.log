Statement : FunCont (fun x ↦ x ^ 3) := by
intro x ε hε
let δ : ℝ := min 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1))
have δle1 : δ ≤ 1 := by bound
have δle2 : δ ≤ ε / (3 * |x| ^ 2 + 3 * |x| + 1) := by bound
have δpos : 0 < δ := by
  cases min_cases 1 (ε / (3 * |x| ^ 2 + 3 * |x| + 1)) with
  | inl h =>
    have h1 : ε / (3 * |x| ^ 2 + 3 * |x| + 1) > 0 := by
      apply div_pos
      linarith
      positivity
    nlinarith [h1]
  | inr h =>
    have h2 : (1 : ℝ) > 0 := by norm_num
    nlinarith [h2]
use δ, δpos
intro y hy
rewrite [show y^3 - x^3 = (y - x) * (x ^ 2 + x * y + y ^ 2) by ring_nf]
rewrite [show |(y - x) * (x ^ 2 + x * y + y ^ 2)| = |y - x| * |x ^ 2 + x * y + y ^ 2| by apply abs_mul]
have hy1 : |y - x| < δ := by simpa using hy
have hy2 : |y| ≤ |x| + 1 := by
  have h1 : |y - x| < 1 := by linarith [hy1, δle1]
  have h2 : |y| ≤ |x| + 1 := by
    have h3 : |y| = |(y - x) + x| := by ring_nf
    rw [h3]
    have h4 : |(y - x) + x| ≤ |y - x| + |x| := by
      apply abs_add
    linarith
  exact h2
have h1 : |x ^ 2 + x * y + y ^ 2| ≤ 3 * |x| ^ 2 + 3 * |x| + 1 := by
  have h2 : |x ^ 2 + x * y + y ^ 2| ≤ |x| ^ 2 + |x| * |y| + |y| ^ 2 := by
    have h3 : x ^ 2 + x * y + y ^ 2 = x ^ 2 + x * y + y ^ 2 := by rfl
    have h4 : |x ^ 2 + x * y + y ^ 2| = |x ^ 2 + x * y + y ^ 2| := by rfl
    have h5 : |x ^ 2 + x * y + y ^ 2| ≤ |x ^ 2| + |x * y| + |y ^ 2| := by
      apply abs_add
      all_goals
        apply abs_add
    have h6 : |x ^ 2| = |x| ^ 2 := by
      simp [abs_pow]
    have h7 : |x * y| = |x| * |y| := by
      simp [abs_mul]
    have h8 : |y ^ 2| = |y| ^ 2 := by
      simp [abs_pow]
    rw [h6, h7, h8] at h5
    linarith
  have h3 : |x| * |y| ≤ |x| * (|x| + 1) := by
    have h4 : |y| ≤ |x| + 1 := hy2
    nlinarith [abs_nonneg x, abs_nonneg y, h4]
  have h4 : |y| ^ 2 ≤ (|x| + 1) ^ 2 := by
    have h5 : |y| ≤ |x| + 1 := hy2
    nlinarith [abs_nonneg y, h5, sq_nonneg (|x| + 1)]
  nlinarith [abs_nonneg x, abs_nonneg y, h2, h3, h4, sq_nonneg (|x| - 1), sq_nonneg (|y| - 1)]
linarith
```

The key insight is that when `|y - x| < 1`, we have `|y| ≤ |x| + 1`. Then, we can bound `|x^2 + xy + y^2|` by `|x|^2 + |x|*|y| + |y|^2 ≤ |x|^2 + |x|(|x| + 1) + (|x| + 1)^2 = 3|x|^2 + 3|x| + 1`.

This completes the proof of the continuity of `x ↦ x^3`.
