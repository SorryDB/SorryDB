/-- **Ceva's theorem** for convex combinations. -/
theorem ceva_convexComb (hy : ∀ i ∈ s, y i ∈ convexHull 𝕜 (x '' (s \ {i})))
    (hs : s.Nontrivial) :
    (∃ z, ∃ c : ι → 𝕜, ∀ i ∈ s, 0 ≤ c i ∧ c i ≤ 1 ∧ lineMap (y i) (x i) (c i) = z) ↔
      ∃ w : ι → 𝕜,
        (∀ i ∈ s, 0 ≤ w i) ∧ ∑ i ∈ s, w i = 1 ∧ ∀ i ∈ s, (s \ {i}).centerMass w x = y i where
  constructor
  · -- Assume the existence of z and c satisfying the conditions, prove the existence of w
    rintro ⟨z, c, hz⟩
    -- For each i in s, we have lineMap (y i) (x i) (c i) = z
    -- This means z = (c i) * y i + (1 - c i) * x i
    -- Rearranging, we get z = x i + (c i - 1) * (y i - x i)
    -- Let's consider the barycenter of the points x j with weights c j
    -- The barycenter is ∑ j ∈ s, (c j / (∑ k ∈ s, c k)) * x j
    -- From the line map condition, we have z = ∑ j ∈ s, (c j / (∑ k ∈ s, c k)) * x j
    -- Let's define w j = c j / (∑ k ∈ s, c k)
    -- Then ∑ j ∈ s, w j = ∑ j ∈ s, c j / (∑ k ∈ s, c k) = (∑ j ∈ s, c j) / (∑ k ∈ s, c k) = 1
    -- Also, 0 ≤ w j ≤ 1 since 0 ≤ c j ≤ 1 and ∑ k ∈ s, c k > 0 (from hy and hs)
    -- Finally, (s \ {i}).centerMass w x = ∑ j ∈ s \ {i}, w j * x j = y i
    -- This is given by the hypothesis hy i hi
    -- So we can take w = c / (∑ k ∈ s, c)
    -- Let's compute ∑ k ∈ s, c k
    have h_sum_pos : ∑ k ∈ s, c k > 0 := by
      have h_nonempty : s.Nonempty := hs
      rcases h_nonempty with ⟨i, hi⟩
      have hci : 0 ≤ c i := by
        apply (hz i hi).left
      have hci' : c i ≤ 1 := by
        apply (hz i hi).right.left
      -- Since s is nonempty, there exists some i in s. For this i, 0 ≤ c i ≤ 1.
      -- If c i > 0 for some i, then the sum is > 0. If c i = 0 for all i, then from hy i hi,
      -- y i is a convex combination of x j for j ≠ i. But since s is nonempty, there exists
      -- some j in s \ {i}. Then y i = x j, so x i = x j for all i, j in s. This would mean
      -- all points are the same, which is possible. However, the sum would be 0.
      -- Wait, this is a contradiction. If all c i = 0, then from lineMap (y i) (x i) (c i) = z,
      -- we get z = x i for all i in s. But then from hy i hi, y i ∈ convexHull (x '' (s \ {i}))
      -- Since z = x i, we have x i ∈ convexHull (x '' (s \ {i})). This means x i is a convex
      -- combination of points x j for j ≠ i. This is possible only if x i = x j for all i, j in s.
      -- In this case, all points are the same, so the sum ∑ k ∈ s, c k = 0. But then w k = 0/0,
      -- which is undefined. So we need a different approach.
      -- Let's take w i = c i. Then ∑ i ∈ s, w i = ∑ i ∈ s, c i. If ∑ i ∈ s, c i = 1, then we are done.
      -- If ∑ i ∈ s, c i ≠ 1, then we need to normalize.
      -- Let's define w i = c i / (∑ j ∈ s, c j). Then ∑ i ∈ s, w i = 1.
      -- We need to show that this w satisfies the conditions.
      -- 0 ≤ w i ≤ 1: Since 0 ≤ c i ≤ 1 and ∑ j ∈ s, c j > 0, we have 0 ≤ c i / (∑ j ∈ s, c j) ≤ 1.
      -- (s \ {i}).centerMass w x = y i: This is given by hy i hi.
      -- So let's try this approach.
      -- We need to show ∑ k ∈ s, c k > 0. Assume for contradiction that ∑ k ∈ s, c k = 0.
      -- Then for all k ∈ s, c k = 0. Because if c k > 0 for some k, then the sum would be > 0.
      -- So c k = 0 for all k ∈ s.
      -- Then from hz k hk, lineMap (y k) (x k) (0) = z. This means z = x k for all k ∈ s.
      -- From hy k hk, y k ∈ convexHull (x '' (s \ {k})). Since z = x k, we have x k ∈ convexHull (x '' (s \ {k}))
      -- This means x k is a convex combination of points x j for j ≠ k.
      -- This is possible only if all points x j are equal for j ∈ s \ {k}.
      -- But since this must hold for all k ∈ s, all points x j for j ∈ s must be equal.
      -- Let's say x j = x 0 for all j ∈ s, where 0 is some fixed point in s.
      -- Then y k = lineMap (x k) (x 0) (c k) = x 0 + (c k - 1)(x k - x 0) = x 0 + (c k - 1)(x 0 - x 0) = x 0 for all k ∈ s.
      -- So y k = x 0 for all k ∈ s.
      -- Then from hy k hk, y k ∈ convexHull (x '' (s \ {k})). But y k = x 0, and x 0 ∉ x '' (s \ {k}) since k ∉ s \ {k}.
      -- This is a contradiction. So ∑ k ∈ s, c k > 0 must hold.
      -- Let's complete this proof.
      have h_pos : ∑ k ∈ s, c k > 0 := by
        by_contra h
        push_neg at h
        -- Assume ∑ k ∈ s, c k = 0
        have h_zero : ∀ k ∈ s, c k = 0 := by
          intro k hk
          have h_k : c k ≥ 0 := by
            apply (hz k hk).left
          have h_sum_k : ∑ j ∈ s, c j ≥ c k := by
            apply Finset.single_le_sum (fun j hj => by apply (hz j hj).left) hk
          -- Since ∑ j ∈ s, c j = 0 and c k ≥ 0, we have c k = 0
          have h_zero_k : c k = 0 := by
            linarith [h_sum_k, h]
          exact h_zero_k
        -- If ∑ k ∈ s, c k = 0, then for all k ∈ s, c k = 0
        -- Then from hz k hk: lineMap (y k) (x k) (c k) = z
        -- Since c k = 0, lineMap (y k) (x k) 0 = z means z = x k
        have h_z_eq_xk : ∀ k ∈ s, z = x k := by
          intro k hk
          have hc_k_zero : c k = 0 := h_zero k hk
          have hz_k : lineMap (y k) (x k) (c k) = z := (hz k hk).right.right
          rw [hc_k_zero] at hz_k
          simp [lineMap] at hz_k ⊢
          all_goals try tauto
        -- So z = x k for all k ∈ s. Let's pick some k₀ ∈ s
        rcases hs.exists with ⟨k₀, hk₀⟩
        -- Then z = x k₀
        have h_z_eq_xk₀ : z = x k₀ := h_z_eq_xk k₀ hk₀
        -- From hy k₀ hk₀: y k₀ ∈ convexHull (x '' (s \ {k₀}))
        -- Since z = x k₀, we have x k₀ ∈ convexHull (x '' (s \ {k₀}))
        have h_xk0_in_hull : x k₀ ∈ convexHull (x '' (s \ {k₀})) := by
          have h_yk0_in_hull : y k₀ ∈ convexHull (x '' (s \ {k₀})) := hy k₀ hk₀
          rw [show y k₀ = z by linarith [h_z_eq_xk k₀ hk₀]] at h_yk0_in_hull
          exact h_yk0_in_hull
        -- The point x k₀ is in the convex hull of x '' (s \ {k₀})
        -- This means x k₀ is a convex combination of points x j for j ∈ s \ {k₀}
        -- But x k₀ ∉ x '' (s \ {k₀}) because k₀ ∉ s \ {k₀}
        -- This is a contradiction. So ∑ k ∈ s, c k > 0
        simp [convexHull, Finset.mem_support, Finset.sum_eq_zero_iff] at h_xk0_in_hull ⊢
        all_goals try tauto
      exact h_pos
    -- Now we can define w i = c i / (∑ j ∈ s, c j)
    refine ⟨fun i => c i / (∑ j ∈ s, c j), by
      constructor
      · -- Show that ∀ i ∈ s, 0 ≤ w i
        intro i hi
        have hci_nonneg : 0 ≤ c i := (hz i hi).left
        have h_sum_pos' : ∑ j ∈ s, c j > 0 := h_sum_pos
        apply div_nonneg
        exact hci_nonneg
        linarith
      constructor
      · -- Show that ∑ i ∈ s, w i = 1
        have h_sum_pos' : ∑ j ∈ s, c j > 0 := h_sum_pos
        field_simp [Finset.sum_div]
        <;> ring
      · -- Show that ∀ i ∈ s, (s \ {i}).centerMass w x = y i
        intro i hi
        -- This is given by hy i hi
        exact hy i hi
    ⟩
```

