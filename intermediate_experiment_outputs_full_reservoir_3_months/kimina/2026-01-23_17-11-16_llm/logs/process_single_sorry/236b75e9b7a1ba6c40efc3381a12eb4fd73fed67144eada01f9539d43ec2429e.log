  carrier := I ‚ą© J
  add_mem' := by
    intro a b ha hb
    have ha1 : a ‚ąą I := ha.1
    have ha2 : a ‚ąą J := ha.2
    have hb1 : b ‚ąą I := hb.1
    have hb2 : b ‚ąą J := hb.2
