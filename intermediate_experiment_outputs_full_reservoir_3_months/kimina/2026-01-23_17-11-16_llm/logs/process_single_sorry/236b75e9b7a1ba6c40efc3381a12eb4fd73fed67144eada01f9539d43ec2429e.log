    ¬∑ -- Show that a + b ‚ąą I
      exact I.add_mem ha1 hb1
    ¬∑ -- Show that a + b ‚ąą J
      exact J.add_mem ha2 hb2
  zero_mem' := by
    constructor
    ¬∑ -- Show that 0 ‚ąą I
      exact I.zero_mem
    ¬∑ -- Show that 0 ‚ąą J
      exact J.zero_mem
  smul_mem' := by
    intro c a ha
    have ha1 : a ‚ąą I := ha.1
    have ha2 : a ‚ąą J := ha.2
    constructor
    ¬∑ -- Show that c ‚ÄĘ a ‚ąą I
      exact I.mul_mem c ha1
    ¬∑ -- Show that c ‚ÄĘ a ‚ąą J
      exact J.mul_mem c ha2
