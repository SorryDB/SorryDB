def RingEquiv.comp (g : S ‚ČÉ+* T) (f : R ‚ČÉ+* S) : R ‚ČÉ+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    sorry
  right_inv := by
    sorry
  map_add' := by
    sorry
  map_mul' := by
    sorry

