  dsimp [coloring_of_eight] at *
  interval_cases i <;> interval_cases j <;> sorry --aesop (simp_config := {decide := true})

theorem theorem1 : all_colorings_are_good 8 := by
  intro color
  have h1 := lemma1 (by norm_num) (by
    unfold all_colorings_are_good
    constructor
    · norm_num
    · intro c
      have h2 := lemma2
      obtain ⟨f, hf⟩ := h2
      have hf' := hf
      have h3 := hf' (by aesop)
      contradiction
  )
  exact h1 color
