import Mathlib

open Finset

-- Define the Vector type
structure Vector (α : Sort u) (n : ℕ) : Type u_1 where
  toList : List α
  size : n = List.length (toList)

-- Basic operations on Vector
def Vector.get (v : Vector α n) (i : Fin n) : α := v.toList[i.toNat]

-- Define the Vector operations
def Vector.map (f : α → β) (v : Vector α n) : Vector β n :=
  ⟨v.toList.map f, v.size⟩

def Vector.mapIdx (f : (i : Fin n) → α → β) (v : Vector α n) : Vector β n :=
  ⟨(v.toList).mapIdx f, v.size⟩

def Vector.set (v : Vector α n) (i : Fin n) (l : List α) : Vector α n :=
  ⟨(v.toList).set i.toNat l, v.size⟩

-- Theorem relating vector equality to element-wise equality
theorem vector_eq_iff (v1 v2 : Vector α n) :
  v1 = v2 ↔ ∀ i : Fin n, v1.get i = v2.get i := by
  simp [Vector.ext_iff, Finset.mem_univ]

-- Theorem about map and set operations preserving element-wise equality
theorem map_set_equiv (f : α → β) {v : Vector α n} {w : Vector β n}
    (h : v = w) : (Vector.map f v).get = (Vector.map f w).get := by
  intro i
  simp [h, Function.comp_apply]

-- Theorem about mapIdx and set operations preserving element-wise equality
theorem mapIdx_set_equiv {f : (i : Fin n) → α → β} {v : Vector α n} {w : Vector β n}
    (h : v = w) : (Vector.mapIdx f v).get = (Vector.mapIdx f w).get := by
