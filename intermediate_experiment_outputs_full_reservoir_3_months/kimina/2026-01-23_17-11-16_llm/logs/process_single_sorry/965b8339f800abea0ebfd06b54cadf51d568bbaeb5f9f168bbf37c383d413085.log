noncomputable def eraseIdx {α} {n : Nat} {i : Fin n} {v : Vector α n} : Vector α n := 
  v.toList.erase i |>.toVector

noncomputable def set {α} {n : Nat} {i : Fin n} {a} {v : Vector α n} : Vector α n := 
  v.toList.set i a |>.toVector

noncomputable def liftFinf {α : Type} (n : Nat) (f : Fin n → α) : Vector α n :=
  (List.range n).map (λ i => ⟨↑i.toNat, f i⟩) |>.toAssocList.toVector

