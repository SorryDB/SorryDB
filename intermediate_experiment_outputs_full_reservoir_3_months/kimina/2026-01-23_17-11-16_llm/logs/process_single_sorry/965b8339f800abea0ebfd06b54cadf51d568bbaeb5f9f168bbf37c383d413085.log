    elt ∈ (Vector.set v idx (elt :: v[↑idx])).toList.flatten := by
  simp only [Fin.getElem_fin, List.mem_flatten, Vector.mem_toList_iff]
  exists (elt :: v[↑idx])
  and_intros <;> simpa [Vector.mem_set]

