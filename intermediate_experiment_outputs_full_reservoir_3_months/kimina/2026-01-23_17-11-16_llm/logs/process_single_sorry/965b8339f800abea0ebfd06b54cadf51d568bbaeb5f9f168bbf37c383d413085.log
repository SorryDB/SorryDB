import Mathlib

variable {α : Type u_1} {n : Nat}

theorem vec_point_eq {v1 v2 : Vector α n} :
  (∀ (idx : Fin n), v1[↑idx] = v2[↑idx]) → v1 = v2 := by
  intro h
  have h1 : v1.toList = v2.toList := by
    have h2 : ∀ (i : Nat), i < n → v1.toList[i] = v2.toList[i] := by
      intro i hi
      have h3 : v1[↑(⟨i, hi⟩ : Fin n)] = v2[↑(⟨i, hi⟩ : Fin n)] := h ⟨i, hi⟩
      simpa using h3
    have h3 : v1.toList = v2.toList := by
      apply List.ext
      intro i
      by_cases hi : i < n
      · exact h2 i hi
      · -- i >= n
        have h4 : i ≥ n := by omega
        have h5 : v1.toList[i] = v2.toList[i] := by
          simp at *
          all_goals try { tauto }
        exact h5
    exact h3
  have h2 : v1 = v2 := by
    have h3 : v1.toList = v2.toList := h1
    have h4 : v1.n = v2.n := by simp
    exact Vector.ext h3
  exact h2
