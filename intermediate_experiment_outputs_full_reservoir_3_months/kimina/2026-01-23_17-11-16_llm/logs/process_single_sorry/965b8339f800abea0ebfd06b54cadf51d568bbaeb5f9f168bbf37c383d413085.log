  simp only [Fin.getElem_fin, List.mem_flatten, Vector.mem_toList_iff] at Hx
  obtain ⟨l', Hl1, Hl2⟩ := Hx
  sorry

theorem vec_set_subset_in {v : Vector (List α) n} {idx : Fin n} {l : List α} {elt : α} :
    (v.set idx (elt :: v[↑idx])).toList.flatten ⊆ l →
