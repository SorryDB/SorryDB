      "\n    have h1 : M.IsCographic := hM\n    have h2 : M.IsRegular := by\n      have h3 : M.IsCographic := h1\n      have h5 : ∃ N : Matroid α, M = N* ∧ N.IsGraphic := by\n        simpa using h3\n      rcases h5 with ⟨N, hN1, hN2⟩\n      have h6 : N.IsRegular := by\n        have h7 : N.IsGraphic := hN2\n        exact h7.isRegular\n      have h7 : M.IsRegular := by\n        rw [hN1]\n        exact (star_isRegular_iff N).mpr h6\n      exact h7\n    exact h2\n  | isomorphicR10 hM => \n    have h1 : M.IsIsomorphicR10 := hM\n    have h2 : M.IsRegular := by\n      have h3 : M.IsIsomorphicR10 := h1\n      have h4 : M.IsRegular := by\n        rw [isIsomorphicR10] at h3\n        exact h3\n      exact h4\n    exact h2\n  | is1sum hMMM hM hMₗ hMᵣ => \n    have h1 : M.Is1Sum := hMMM\n    have h2 : M.RankFinite := hM\n    have h3 : Mₗ.IsGood := hMₗ\n    have h4 : Mᵣ.IsGood := hMᵣ\n    have h5 : Mₗ.IsRegular := by\n      apply Matroid.IsGood.isRegular\n      exact h3\n    have h6 : Mᵣ.IsRegular := by\n      apply Matroid.IsGood.isRegular\n      exact h4\n    have h7 : M.IsRegular := by\n      rw [is1Sum] at h1\n      apply (one_sum_isRegular_iff h2 h5 h6).mp h1\n    exact h7\n  | is2sum hMMM hM hMₗ hMᵣ => \n    have h1 : M.Is2Sum := hMMM\n    have h2 : M.RankFinite := hM\n    have h3 : Mₗ.IsGood := hMₗ\n    have h4 : Mᵣ.IsGood := hMᵣ\n    have h5 : Mₗ.IsRegular := by\n      apply Matroid.IsGood.isRegular\n      exact h3\n    have h6 : Mᵣ.IsRegular := by\n      apply Matroid.IsGood.isRegular\n      exact h4\n    have h7 : M.IsRegular := by\n      rw [is2Sum] at h1\n      apply (two_sum_isRegular_iff h2 h5 h6).mp h1\n    exact h7\n  | is3sum hMMM hM hMₗ hMᵣ => \n    have h1 : M.Is3Sum := hMMM\n    have h2 : M.RankFinite := hM\n    have h3 : Mₗ.IsGood := hMₗ\n    have h4 : Mᵣ.IsGood := hMᵣ\n    have h5 : Mₗ.IsRegular := by\n      apply Matroid.IsGood.isRegular\n      exact h3\n    have h6 : Mᵣ.IsRegular := by\n      apply Matroid.IsGood.isRegular\n      exact h4\n    have h7 : M.