lemma lemma1 {m n : ℕ} (hmn : m ≤ n) (hm : all_colorings_are_good m) :
    all_colorings_are_good n := by
  constructor
  · exact hm.1.trans hmn
  · intro c
    let c' : Set.Icc 1 m → Fin 2 :=
      fun x ↦ c ⟨x.val, by rw [Set.mem_Icc]; exact ⟨x.prop.1, x.prop.2.trans hmn⟩⟩
    obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := hm.2 c'
    use ⟨i, hi1, hi2.trans hmn⟩
    use ⟨j, hj1, hj2.trans hmn⟩
    simp only [Subtype.mk_lt_mk, Set.mem_Icc, tsub_le_iff_right, exists_and_left]
    simp only [Subtype.mk_lt_mk] at hij1
    refine ⟨hij1, ?_⟩
    simp only [Set.mem_Icc, tsub_le_iff_right] at hij2
    simp only [c'] at hc1
    refine ⟨hc1, ?_⟩
    have hij2' : 1 ≤ 2 * j - i ∧ 2 * j ≤ n + i :=
       ⟨hij2.1, le_add_of_le_add_right hij2.2 hmn⟩
    use hij2'

def coloring_of_eight {n : ℕ} : Set.Icc 1 n → Fin 2
| ⟨1, _⟩ => 0
| ⟨2, _⟩ => 1
| ⟨3, _⟩ => 0
| ⟨4, _⟩ => 1
| ⟨5, _⟩ => 1
| ⟨6, _⟩ => 0
| ⟨7, _⟩ => 1
| ⟨8, _⟩ => 0
| _ => 0 -- unreachable

lemma lemma2 :
    ∃ f : Set.Icc 1 8 → Fin 2, ¬coloring_is_good f := by
  use coloring_of_eight
  intro h
  obtain ⟨⟨i, hi1, hi2⟩, ⟨j, hj1, hj2⟩, hij1, hij2, hc1, hc2⟩ := h
  dsimp [coloring_of_eight] at *
  interval_cases i <;> interval_cases j <;> sorry --aesop (simp_config := {decide := true})

theorem theorem1 : 3 ≤ 3 ∧ ∀ color : Set.Icc 1 3 → Fin 2, coloring_is_good color := by
  constructor
  · norm_num
  · intro color
    have h1 : color ⟨1, by norm_num⟩ = color ⟨2, by norm_num⟩ ∨ color ⟨1, by norm_num⟩ = color ⟨3, by norm_num⟩ ∨ color ⟨2, by norm_num⟩ = color ⟨3, by norm_num⟩ := by
      have h1 : color ⟨1, by norm_num⟩ = 0 ∨ color ⟨1, by norm_num⟩ = 1 := by
        have h1 : color ⟨1, by norm_num⟩ = 0 ∨ color ⟨1, by norm_num⟩ = 1 := by
          fin_cases (color ⟨1, by norm_num⟩) <;> tauto
        tauto
      have h2 : color ⟨2, by norm_num⟩ = 0 ∨ color ⟨2, by norm_num⟩ = 1 := by
        fin_cases (color ⟨2, by norm_num⟩) <;> tauto
      have h3 : color ⟨3, by norm_num⟩ = 0 ∨ color ⟨3, by norm_num⟩ = 1 := by
        fin_cases (color ⟨3, by norm_num⟩) <;> tauto
      rcases h1 with h1 | h1 <;> rcases h2 with h2 | h2 <;> rcases h3 with h3 | h3 <;> 
        simp [h1, h2, h3] <;> tauto
    rcases h1 with h1 | h1 | h1
    · -- case where color 1 = color 2
      use ⟨1, by norm_num⟩, ⟨2, by norm_num⟩
      constructor
      · norm_num
      · -- need to show that 2 * 2 - 1 = 3 is in the interval and has the same color
        use ⟨3, by norm_num⟩
        constructor
        · norm_num
        constructor
        · simp [h1]
        · simp [h1]
    · -- case where color 1 = color 3
      use ⟨1, by norm_num⟩, ⟨3, by norm_num⟩
      constructor
      · norm_num
      · -- need to show that 2 * 3 - 1 = 5 is in the interval and has the same color
        use ⟨5, by norm_num⟩
        constructor
        · norm_num
        constructor
        · simp [h1]
        · simp [h1]
    · -- case where color 2 = color 3
      use ⟨2, by norm_num⟩, ⟨3, by norm_num⟩
      constructor
      · norm_num
      · -- need to show that 2 * 3 - 2 = 4 is in the interval and has the same color
        use ⟨4, by norm_num⟩
        constructor
        · norm_num
        constructor
        · simp [h1]
        · simp [h1]

