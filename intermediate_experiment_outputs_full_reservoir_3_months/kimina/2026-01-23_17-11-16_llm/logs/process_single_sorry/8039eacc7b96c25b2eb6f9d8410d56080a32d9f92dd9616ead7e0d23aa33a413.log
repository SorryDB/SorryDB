    simp at h1 ⊢
    omega
  have h4 : j.val ≤ 8 := by
    have h1 : j ∈ Set.Icc (1 : ℕ) 8 := by
      exact hj2
    simp at h1 ⊢
    omega
  interval_cases i.val <;> interval_cases j.val
