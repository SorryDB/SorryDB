    simp at h1 ⊢
    omega
  have h2 : i.val ≤ 8 := by
    have h1 : i ∈ Set.Icc (1 : ℕ) 8 := by
      exact hi1
    simp at h1 ⊢
    omega
  have h3 : j.val ≥ 1 := by
    have h1 : j ∈ Set.Icc (1 : ℕ) 8 := by
