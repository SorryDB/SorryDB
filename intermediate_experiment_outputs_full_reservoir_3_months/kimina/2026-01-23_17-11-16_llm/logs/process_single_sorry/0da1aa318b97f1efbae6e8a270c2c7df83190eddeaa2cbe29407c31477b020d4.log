def RingEquiv.comp (g : S Ôëâ+* T) (f : R Ôëâ+* S) : R Ôëâ+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    sorry
  right_inv := by
    sorry
  map_add' := by
    sorry
  map_mul' := by
    sorry

end homomorphisms

