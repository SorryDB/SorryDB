      "\n  simp only [wInner_cWeight_eq_smul_wInner_one, cLpNorm_eq_sum_rpow, cLqNorm_eq_sum_rpow, \n    ← NNReal.coe_mul, ← NNReal.coe_pow, ← NNReal.coe_rpow, \n    smul_eq_mul, ← NNReal.mul_rpow]\n  have h1 : ∀ a : α, 0 ≤ (f a) ^ p * (g a) ^ q := by\n    intro a\n    have hp1 : 0 ≤ (f a) ^ p := by positivity\n    have hq1 : 0 ≤ (g a) ^ q := by positivity\n    positivity\n  have h2 : ∑ i : α, (f i) * (g i) ≤ (∑ i : α, (f i) ^ p) ^ (1 / p : ℝ) * (∑ i : α, (g i) ^ q) ^ (1 / q : ℝ) := by\n    apply Finset.sum_mul_le_mul_sum_of_nonneg\n    · -- Show that 0 ≤ (f i) * (g i)\n      intro i hi\n      have hf1 : 0 ≤ f i := by apply le_of_not_neg; positivity\n      have hg1 : 0 ≤ g i := by apply le_of_not_neg; positivity\n      positivity\n    · -- Show that 0 ≤ (f i) ^ p * (g i) ^ q\n      intro i hi\n      have hf1 : 0 ≤ f i := by apply le_of_not_neg; positivity\n      have hg1 : 0 ≤ g i := by apply le_of_not_neg; positivity\n      positivity\n  simpa using h2",
