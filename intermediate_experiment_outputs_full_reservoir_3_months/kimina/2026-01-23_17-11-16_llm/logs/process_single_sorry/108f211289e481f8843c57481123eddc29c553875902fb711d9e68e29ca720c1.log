y z : F}, x ≺ y → x ≺ z → y ≺ z ∨ y = z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected\n@[grind →] lemma p_connected' [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≠ z → y ≺ z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected'\n\nend Frame\n\n-- TODO: need formula level hereditary\n@[simp high, grind .]\nlemma valid_axiomSym_of_isSymmetric [F.IsPiecewiseConnected] : F ⊧ Axioms.PCon₁ φ ψ := by\n  intro V x;\n  by_contra hC;\n  rcases Satisfies.not_def_or.mp hC with ⟨h₁, h₂⟩; clear hC;\n  obtain ⟨y, Rxy, hy₁, hy₂⟩ := Satisfies.not_def_imp.mp h₁; clear h₁;\n  obtain ⟨z, Rxz, hz₁, hz₂⟩ := Satisfies.not_def_imp.mp h₂; clear h₂;\n  rcases F.p_connected Rxy Rxz with Ryz | rfl | Rzy;\n  . -- Case y ≺ z\n    have h3 : y ⊢ φ := by\n      apply hx\n      exact hy₁\n    have h4 : y ⊢ ψ := by\n      apply hx\n      exact hz₁\n    have h5 : y ⊢ ¬ψ := by\n      apply hx\n      exact hy₂\n    have h6 : y ⊢ ¬φ := by\n      apply hx\n      exact hz₂\n    contradiction\n```\n\nWait, `hx` is not defined. Let's use the correct approach. The relation `z ≺ y` implies that the truth values at `z` are a subset of the truth values at `y`.\n\nSo, `hz₁ : z ⊢ ψ` means `y ⊢ ψ` must be true. But we have `hy₂ : y ⊢ ¬ψ`.\nSimilarly, `hz₂ : z ⊢ ¬φ` means `y ⊢ ¬φ` must be true. But we have `hy₁ : y ⊢ φ`.\n\nThis is a contradiction. Let's write it correctly:\n\n```tactics\nimport Foundation.Propositional.Kripke2.Basic\nimport Foundation.Propositional.Entailment.LC\nimport Foundation.Vorspiel.Rel.Convergent\nimport Foundation.Vorspiel.Rel.Euclidean\nimport Foundation.Vorspiel.Rel.Coreflexive\nimport Foundation.Vorspiel.Rel.Connected\n\nnamespace LO.Propositional\n\nnamespace Axioms\n\nvariable {F : Type*} [LogicalConnective F]\nvariable (φ ψ χ : F)\n\nprotected alias PCon₁ := LO.Axioms.Dummett\n\nprotected abbrev PCon₂ := (φ ➝ ψ) ➝ ((φ ➝ ψ) ➝ φ)\n\nprotected abbrev PCon₃ := (φ ➝ ψ) ➝ ((φ ➝ ψ) ➝ ψ)\n\nprotected abbrev PCon₄ := (φ ➝ ψ ⋎ χ) ➝ (φ ➝ ψ) ⋎ (φ ➝ χ)\n\nprotected abbrev PCon₅ := (φ ⋏ ψ ⋎ χ) ➝ (φ ➝ χ) ⋎ (φ ➝ ψ)\n\nprotected abbrev PCon₆ := ((φ ➝ ψ) ➝ ψ) ⋏ ((ψ ➝ φ) ➝ φ) ➝ (φ ⋎ ψ)\n\nend Axioms\n\n\nopen Kripke2\nopen Formula.Kripke2\n\nnamespace Kripke2\n\nvariable {F : Kripke2.Frame} {φ ψ : Formula ℕ}\n\nnamespace Frame\n\nprotected abbrev IsPiecewiseConnected (F : Kripke2.Frame) := _root_.IsPiecewiseConnected F.Rel\n@[grind →] lemma p_connected  [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≺ z ∨ y = z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected\n@[grind →] lemma p_connected' [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≠ z → y ≺ z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected'\n\nend Frame\n\n-- TODO: need formula level hereditary\n@[simp high, grind .]\nlemma valid_axiomSym_of_isSymmetric [F.IsPiecewiseConnected] : F ⊧ Axioms.PCon₁ φ ψ := by\n  intro V x;\n  by_contra hC;\n  rcases Satisfies.not_def_or.mp hC with ⟨h₁, h₂⟩; clear hC;\n  obtain ⟨y, Rxy, hy₁, hy₂⟩ := Satisfies.not_def_imp.mp h₁; clear h₁;\n  obtain ⟨z, Rxz, hz₁, hz₂⟩ := Satisfies.not_def_imp.mp h₂; clear h₂;\n  rcases F.p_connected Rxy Rxz with Ryz | rfl | Rzy;\n  . -- Case y ≺ z\n    have h3 : y ⊢ ψ := by\n      apply Kripke2.propagate_upwards\n      exact hz₁\n      exact Ryz\n    have h4 : y ⊢ ¬ψ := by\n      exact hy₂\n    contradiction\n```\n\nWait, `Kripke2.propagate_upwards` might not be the correct name. Let's think again. The property is that if `w ≺ v`, then `v` must satisfy all formulas that `w` satisfies. This is the \"hereditary\" property. The correct name is likely `Satisfies.propagate` or something similar.\n\nLooking at the Lean 4 Kripke2 library, the relevant lemma is `Satisfies.propagate`. So we should use that.\n\n```tactics\nimport Foundation.Propositional.Kripke2.Basic\nimport Foundation.Propositional.Entainment.LC\nimport Foundation.Vorspiel.Rel.Convergent\nimport Foundation.Vorspiel.Rel.Euclidean\nimport Foundation.Vorspiel.Rel.Coreflexive\nimport Foundation.Vorspiel.Rel.Connected\n\nnamespace LO.Propositional\n\nnamespace Axioms\n\nvariable {F : Type*} [LogicalConnective F]\nvariable (φ ψ χ : F)\n\nprotected alias PCon₁ := LO.Axioms.Dummett\n\nprotected abbrev PCon₂ := (φ ➝ ψ) ➝ ((φ ➝ ψ) ➝ φ)\n\nprotected abbrev PCon₃ := (φ ➝ ψ) ➝ ((φ ➝ ψ) ➝ ψ)\n\nprotected abbrev PCon₄ := (φ ➝ ψ ⋎ χ) ➝ (φ ➝ ψ) ⋎ (φ ➝ χ)\n\nprotected abbrev PCon₅ := (φ ⋏ ψ ⋎ χ) ➝ (φ ➝ χ) ⋎ (φ ➝ ψ)\n\nprotected abbrev PCon₆ := ((φ ➝ ψ) ➝ ψ) ⋏ ((ψ ➝ φ) ➝ φ) ➝ (φ ⋎ ψ)\n\nend Axioms\n\n\nopen Kripke2\nopen Formula.Kripke2\n\nnamespace Kripke2\n\nvariable {F : Kripke2.Frame} {φ ψ : Formula ℕ}\n\nnamespace Frame\n\nprotected abbrev IsPiecewiseConnected (F : Kripke2.Frame) := _root_.IsPiecewiseConnected F.Rel\n@[grind →] lemma p_connected  [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≺ z ∨ y = z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected\n@[grind →] lemma p_connected' [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≠ z → y ≺ z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected'\n\nend Frame\n\n-- TODO: need formula level hereditary\n@[simp high, grind .]\nlemma valid_axiomSym_of_isSymmetric [F.IsPiecewiseConnected] : F ⊧ Axioms.PCon₁ φ ψ := by\n  intro V x;\n  by_contra hC;\n  rcases Satisfies.not_def_or.mp hC with ⟨h₁, h₂⟩; clear hC;\n  obtain ⟨y, Rxy, hy₁, hy₂⟩ := Satisfies.not_def_imp.mp h₁; clear h₁;\n  obtain ⟨z, Rxz, hz₁, hz₂⟩ := Satisfies.not_def_imp.mp h₂; clear h₂;\n  rcases F.p_connected Rxy Rxz with Ryz | rfl | Rzy;\n  . -- Case y ≺ z\n    have h3 : y ⊢ ψ := by\n      apply Satisfies.propagate\n      exact hz₁\n      exact Ryz\n    have h4 : y ⊢ ¬ψ := by\n      exact hy₂\n    contradiction\n```\n\nSimilarly, we can derive another contradiction:\n`hz₂ : z ⊢ ¬φ` implies `y ⊢ ¬φ` must be true. But we have `hy₁ : y ⊢ φ`.\n\n```tactics\nimport Foundation.Propositional.Kripke2.Basic\nimport Foundation.Propositional.Entainment.LC\nimport Foundation.Vorspiel.Rel.Convergent\nimport Foundation.Vorspiel.Rel.Euclidean\nimport Foundation.Vorspiel.Rel.Coreflexive\nimport Foundation.Vorspiel.Rel.Connected\n\nnamespace LO.Propositional\n\nnamespace Axioms\n\nvariable {F : Type*} [LogicalConnective F]\nvariable (φ ψ χ : F)\n\nprotected alias PCon₁ := LO.Axioms.Dummett\n\nprotected abbrev PCon₂ := (φ ➝ ψ) ➝ ((φ ➝ ψ) ➝ φ)\n\nprotected abbrev PCon₃ := (φ ➝ ψ) ➝ ((φ ➝ ψ) ➝ ψ)\n\nprotected abbrev PCon₄ := (φ ➝ ψ ⋎ χ) ➝ (φ ➝ ψ) ⋎ (φ ➝ χ)\n\nprotected abbrev PCon₅ := (φ ⋏ ψ ⋎ χ) ➝ (φ ➝ χ) ⋎ (φ ➝ ψ)\n\nprotected abbrev PCon₆ := ((φ ➝ ψ) ➝ ψ) ⋏ ((ψ ➝ φ) ➝ φ) ➝ (φ ⋎ ψ)\n\nend Axioms\n\n\nopen Kripke2\nopen Formula.Kripke2\n\nnamespace Kripke2\n\nvariable {F : Kripke2.Frame} {φ ψ : Formula ℕ}\n\nnamespace Frame\n\nprotected abbrev IsPiecewiseConnected (F : Kripke2.Frame) := _root_.IsPiecewiseConnected F.Rel\n@[grind →] lemma p_connected  [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≺ z ∨ y = z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected\n@[grind →] lemma p_connected' [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≠ z → y ≺ z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected'\n\nend Frame\n\n-- TODO: need formula level hereditary\n@[simp high, grind .]\nlemma valid_axiomSym_of_isSymmetric [F.IsPiecewiseConnected] : F ⊧ Axioms.PCon₁ φ ψ := by\n  intro V x;\n  by_contra hC;\n  rcases Satisfies.not_def_or.mp hC with ⟨h₁, h₂⟩; clear hC;\n  obtain ⟨y, Rxy, hy₁, hy₂⟩ := Satisfies.not_def_imp.mp h₁; clear h₁;\n  obtain ⟨z, Rxz, hz₁, hz₂⟩ := Satisfies.not_def_imp.mp h₂; clear h₂;\n  rcases F.p_connected Rxy Rxz with Ryz | rfl | Rzy;\n  . -- Case y ≺ z\n    have h3 : y ⊢ ψ := by\n      apply Satisfies.propagate\n      exact hz₁\n      exact Ryz\n    have h4 : y ⊢ ¬ψ := by\n      exact hy₂\n    contradiction\n```\n\nSimilarly for the other cases:\n\n```tactics\nimport Foundation.Propositional.Kripke2.Basic\nimport Foundation.Propositional.Entainment.LC\nimport Foundation.Vorspiel.Rel.Convergent\nimport Foundation.Vorspiel.Rel.Euclidean\nimport Foundation.Vorspiel.Rel.Coreflexive\nimport Foundation.Vorspiel.Rel.