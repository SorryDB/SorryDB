  rcases Satisfies.not_def_or.mp hC with ⟨h₁, h₂⟩; clear hC;
  obtain ⟨y, Rxy, hy₁, hy₂⟩ := Satisfies.not_def_imp.mp h₁; clear h₁;
  obtain ⟨z, Rxz, hz₁, hz₂⟩ := Satisfies.not_def_imp.mp h₂; clear h₂;
  rcases F.p_connected Rxy Rxz with Ryz | rfl | Rzy;
  . -- Case where y ≺ z
    exfalso
    have h3 : y ⊢ φ := by 
      simpa using hy₁
    have h4 : z ⊢ φ := by
      apply Satisfies.of_trans (show z ⊢ y by simpa using Ryz)
      simpa using h3
    have h5 : z ⊢ ¬φ := by 
      simpa using hz₂
    contradiction
  . -- Case where y = z
    exfalso
    have h3 : y = z := by 
      simpa using rfl
    rw [h3] at hy₂
    tauto
  . -- Case where z ≺ y
    exfalso
    have h3 : z ⊢ φ := by 
      apply Satisfies.of_trans (show y ⊢ z by simpa using Rzy)
      simpa using hz₁
    have h4 : y ⊢ ¬φ := by 
      simpa using hy₂
    contradiction
```

