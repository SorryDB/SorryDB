      "\n  have h1 : ∫ x in a..b, 2 * x * exp (x ^ 2) = exp (b ^ 2) - exp (a ^ 2) := by\n    have h3 : ∀ x, HasDerivAt (fun x => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := by\n      intro x\n      apply HasDerivAt.exp\n      · -- Show that x^2 has derivative 2x\n        apply HasDerivAt.pow\n        all_goals simp\n      all_goals simp\n    simp [intervalIntegral.integral_eq_sub_of_hasDerivAt, h3]\n    <;> ring_nf <;> norm_num\n  exact h1",
      "\n  have h1 : ∀ x : ℝ, HasDerivAt (fun x => exp (x ^ 2)) (2 * x) x := by\n    intro x\n    have h2 : HasDerivAt (fun x => exp (x ^ 2)) (2 * x) x := by\n      simp [hasDerivAt_exp, hasDerivAt_pow]\n      <;> try field_simp\n      <;> try ring\n    exact h2\n  have h3 : ∫ x in a..b, 2 * x * exp (x ^ 2) = exp (b ^ 2) - exp (a ^ 2) := by\n    have h4 : ∫ x in a..b, 2 * x * exp (x ^ 2) = ∫ x in a..b, (deriv (fun x => exp (x ^ 2)) x) := by\n      congr\n      funext x\n      have h5 : HasDerivAt (fun x => exp (x ^ 2)) (2 * x) x := h1 x\n      have h6 : deriv (fun x => exp (x ^ 2)) x = 2 * x := by\n        simpa using h5.deriv\n      simpa using h6\n    rw [h4]\n    simp [intervalIntegral.integral_deriv_eq_sub]\n    all_goals try { tauto }\n  exact h3",
      "\n  have h1 : ∀ x, HasDerivAt (fun x => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := by\n    intro x\n    have h2 : HasDerivAt (fun x => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := by\n      have h3 : HasDerivAt (fun x => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := by\n        simp [hasDerivAt_exp, hasDerivAt_pow]\n        <;> ring\n      exact h3\n    exact h2\n  have h2 : ∫ x in a..b, 2 * x * exp (x ^ 2) = exp (b ^ 2) - exp (a ^ 2) := by\n    have h3 : ∫ x in a..b, 2 * x * exp (x ^ 2) = ∫ x in a..b, (deriv (fun x => exp (x ^ 2)) x) := by\n      congr\n      funext x\n      have h4 : HasDerivAt (fun x => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := h1 x\n      simpa using h4.hasDerivAt\n    rw [h3]\n    have h4 : ∫ x in a..b, deriv (fun x => exp (x ^ 2)) x = exp (b ^ 2) - exp (a ^ 2) := by\n      apply intervalIntegral.integral_eq_sub_of_hasDerivOn\n      · -- Show that the derivative exists on the interval\n        intro x hx\n        have h5 : HasDerivAt (fun x => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := h1 x\n        simpa using h5\n      all_goals\n        -- Show that the interval is connected\n        norm_num\n    exact h4\n  exact h2",
      "\n  have h1 : ∫ x in a..b, 2 * x * exp (x ^ 2) = exp (b ^ 2) - exp (a ^ 2) := by\n    have h2 : ∀ x : ℝ, HasDerivAt (fun x => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := by\n      intro x\n      have h3 : HasDerivAt (fun x => exp (x ^ 2)) (2 * x * exp (x ^ 2)) x := by\n        simp [hasDerivAt_exp, hasDerivAt_pow, mul_comm]\n        <;> try { norm_num }\n        <;> try { ring }\n      exact h3\n    have h4 : ∫ x in a..b, 2 * x * exp (x ^ 2) = exp (b ^ 2) - exp (a ^ 2) := by\n      simp [intervalIntegral.integral_eq_sub_of_hasDerivAt h2]\n      all_goals norm_num\n      <;> try { ring }\n      <;> try { norm_num }\n    exact h4\n  exact h1",
