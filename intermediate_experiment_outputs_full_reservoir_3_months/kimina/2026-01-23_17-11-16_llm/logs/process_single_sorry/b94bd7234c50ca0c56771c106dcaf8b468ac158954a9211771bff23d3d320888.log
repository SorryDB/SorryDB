      "\n  have h1 : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by\n    have h2 : ∀ x : ℝ, ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by\n      intro x\n      have h3 : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by\n        simp [intervalIntegral.integral_const, mul_comm]\n        <;> ring_nf <;> simp [exp_add, mul_add, add_mul]\n        <;> ring\n      exact h3\n    specialize h2 x\n    simpa using h2\n  exact h1",
      "\n  have h1 : ∀ t : ℝ, HasDerivAt (fun t : ℝ => t * exp t) (fun t : ℝ => exp t + t * exp t) t := by\n    intro t\n    have h2 : HasDerivAt (fun t : ℝ => t * exp t) (fun t : ℝ => exp t + t * exp t) t := by\n      apply HasDerivAt.mul\n      · -- Show that t has derivative 1 at t\n        apply hasDerivAt_id\n      · -- Show that exp t has derivative exp t at t\n        apply hasDerivAt_exp\n    exact h2\n  have h2 : ∫ t in 0..x, t * exp t = (x - 1) * exp x + 1 := by\n    have h3 : ∀ t : ℝ, HasDerivAt (fun t : ℝ => (t - 1) * exp t) (fun t : ℝ => exp t + (t - 1) * exp t) t := by\n      intro t\n      have h4 : HasDerivAt (fun t : ℝ => (t - 1) * exp t) (fun t : ℝ => exp t + (t - 1) * exp t) t := by\n        apply HasDerivAt.mul\n        · -- Show that t - 1 has derivative 1 at t\n          apply hasDerivAt_id\n        · -- Show that exp t has derivative exp t at t\n          apply hasDerivAt_exp\n      exact h4\n    have h5 : ∫ t in 0..x, t * exp t = ((x - 1) * exp x) - ((0 - 1) * exp (0 : ℝ)) := by\n      apply intervalIntegral.integral_eq_sub_of_hasDerivAt\n      intro t ht\n      have h4 : HasDerivAt (fun t : ℝ => (t - 1) * exp t) (fun t : ℝ => exp t + (t - 1) * exp t) t := h3 t\n      simpa using h4\n    rw [h5]\n    all_goals\n      simp [exp_zero]\n      <;> ring\n  exact h2",
