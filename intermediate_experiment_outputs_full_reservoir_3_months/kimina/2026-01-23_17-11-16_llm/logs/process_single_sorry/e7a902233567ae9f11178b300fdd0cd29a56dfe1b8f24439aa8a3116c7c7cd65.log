theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.c entry.r.2).eval) G ->
      cl ≈ (dedup cr) := by
  intro cl cr G h1 h2
  simp [Dedup.dedup, Function.eval, Circuit.eval, Nat.succ_pos', Nat.succ_ne_self]
  <;> try { tauto }
  all_goals try { aesop }
```

