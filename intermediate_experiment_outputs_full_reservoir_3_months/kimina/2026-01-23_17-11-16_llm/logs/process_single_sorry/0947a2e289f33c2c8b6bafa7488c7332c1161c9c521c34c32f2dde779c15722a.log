/- Prove the following using the change of variables theorem. -/
lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h1 : ∫ x in 0..Real.pi, sin x * f (cos x) = ∫ y in -1..1, f y := by
    have h5 : ∫ x in (0 : ℝ)..Real.pi, sin x * f (cos x) = ∫ y in -1..1, f y := by
      have h6 : ∫ x in (0 : ℝ)..Real.pi, sin x * f (cos x) = ∫ y in (cos (0 : ℝ) : ℝ)..(cos (Real.pi : ℝ) : ℝ), - f y * (deriv (fun x => cos x) y) := by
        apply intervalIntegral.integral_comp_of_deriv
        all_goals
          simp [Real.cos_pi, Real.sin_pi]
          all_goals
            try { 
              intro x
              simp [hasDerivAt_cos]
              all_goals try { norm_num }
            }
            all_goals try { 
              intro x
              simp [hasDerivAt_cos]
              all_goals try { norm_num }
            }
      have h7 : ∫ y in (cos (0 : ℝ) : ℝ)..(cos (Real.pi : ℝ) : ℝ), - f y * (deriv (fun x => cos x) y) = ∫ y in -1..1, f y := by
        have h8 : cos (0 : ℝ) = 1 := by simp
        have h9 : cos (Real.pi : ℝ) = -1 := by simp [Real.cos_pi]
        rw [h8, h9]
        have h10 : deriv (fun x => cos x) (-1 : ℝ) = - (sin (-1 : ℝ)) := by
          simp [hasDerivAt_cos]
        have h11 : deriv (fun x => cos x) (1 : ℝ) = - (sin (1 : ℝ)) := by
          simp [hasDerivAt_cos]
        simp [h10, h11]
        all_goals
          ring_nf
      linarith [h6, h7]
    exact h5
  exact h1
