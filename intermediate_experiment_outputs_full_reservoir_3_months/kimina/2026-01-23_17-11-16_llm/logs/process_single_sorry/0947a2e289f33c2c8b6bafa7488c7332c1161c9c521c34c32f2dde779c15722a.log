/- Prove the following using the change of variables theorem. -/
lemma change_of_variables_exercise (f : ℝ → ℝ) :
    ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
  have h1 : ∀ x : ℝ, cos x = cos x := by
    intro x
    rfl
  have h2 : ∀ x : ℝ, sin x = sin x := by
    intro x
    rfl
  -- Use change of variables theorem
  -- Let y = cos x, then dy = -sin x dx
  -- When x = 0, y = 1; when x = π, y = -1
  -- Integral becomes ∫_{1}^{-1} f(y) (-1) dy = ∫_{-1}^{1} f(y) dy
  -- We need to use intervalIntegral.integral_comp' or similar
  -- theorem for change of variables.
  -- Let's try intervalIntegral.integral_comp
  -- We need a function g such that g(x) = f(cos(x))
  -- Then we need to compute ∫ x in 0..π, sin x * g(x) dx
  -- We want to transform it to ∫ y in -1..1, (something) dy
  -- Let's use intervalIntegral.integral_comp
  -- We need to define the transformation
  -- Let's try to compute the integral directly using the theorem
  -- Let's define the transformation from x to y = cos x
  -- The inverse transformation is x = arccos y
  -- The derivative is dx/dy = 1 / (-sin y) = -1 / sin y
  -- But sin y is not always positive. So the transformation is not monotone.
  -- We need to split the integral at points where the derivative changes sign.
  -- The derivative of cos is -sin, which is negative in (0, π).
  -- So the transformation is monotone decreasing from 1 to -1.
  -- So we can use intervalIntegral.integral_comp
  -- We need to reverse the limits
  -- Let's try:
  have h3 : ∫ x in 0..π, sin x * f (cos x) = ∫ y in -1..1, f y := by
    -- Use change of variables theorem
