    let r := repr x.dest
    use r.fst
    use ((TypeVec.id ::: Cofix.corec Cofix.dest) ⊚ r.snd)
    use r.snd
    simp only [r]
    and_intros
    · change _ = abs (_ <$$> repr _)
      simp [abs_repr, abs_map]
    · simp [abs_repr]
    · intro i j
      cases i
      <;> rfl
  · rfl

theorem ofCofix_toCofix (self : Coalg F α) : ofCofix (toCofix self) = self := by
  simp only [ofCofix, toCofix, CShrink.toLarge, CShrink.ofLarge, StateCofixFinal.toCofix, StateCofixFinal.ofCofix, MvQPF.Cofix.bisim]
```

