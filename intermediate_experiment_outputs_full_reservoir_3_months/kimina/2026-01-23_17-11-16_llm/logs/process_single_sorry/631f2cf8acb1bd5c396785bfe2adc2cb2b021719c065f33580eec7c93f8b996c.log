  have nB : B := by
    by_contra hB
    have nAnC := stBn.mp hB
    push_neg at nAnC
    have hA := stA.mpr (And.intro hB nAnC.right)
    contradiction

  have hC : C := by
    have h1 : B ∨ C := by
      simpa using BC
    cases h1 with
    | inl hB =>
      have hC : C := by
        have h1 : A ∨ C := by
          tauto
        cases h1 with
        | inl hA =>
