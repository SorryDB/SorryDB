    by_contra h
    have h4 : ¬B ∧ ¬C := h1.mp h
    have h5 : ¬B := h4.1
    have h6 : ¬C := h4.2
    have h7 : B ↔ (A ∨ C) := h2
    have h8 : ¬B := h5
    have h9 : ¬(A ∨ C) := by
      rw [show B ↔ (A ∨ C) by exact h7] at h8
      tauto
    have h10 : ¬A := by
      intro hA
      tauto
    have h11 : ¬C := h6
    tauto
  have h4 : B ∨ C := by
    have h7 : ¬(¬B ∧ ¬C) := by
      tauto
    by_contra h
    push_neg at h
    have h9 : ¬B := h.1
    have h10 : ¬C := h.2
    have h11 : ¬B ∧ ¬C := ⟨h9, h10⟩
    contradiction
  cases h4 with
