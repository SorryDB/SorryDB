section
open List (filter all head!)

def ok (xs : List Nat) : Bool :=  xs.all (· > 0)

def okextendl (x : Nat) : Partition Nat → List (Partition Nat) :=
 filter (ok ∘ head!) ∘ extendl x

variable (h : ∀ x ps, filter (flip all ok) (concatMap (extendl x) ps) =
              concatMap (okextendl x) (filter (flip all ok) ps))

example
  : List.filter (flip List.all ok) ∘ parts₁ = List.foldr (concatMap ∘ okextendl) [[]] := by
  funext xs
  unfold parts₁
  simp [Function.comp]
  induction xs with
  | nil =>
    simp [List.foldr, flip]
  | cons a as ih =>
    have h1 := h a
    sorry

end

/- # Exercicio 12.5 -/

section
open List (range head! tail zipWith and)

def leftmin  (xs : List Nat) := xs.all (head! xs ≤ ·)
def rightmax (xs : List Nat) := xs.all (· ≤ last xs)
def ordered  (xs : List Nat) := and $ zipWith (· ≤ ·) xs (tail xs)
def nmatch   (xs : List Nat) := and $ zipWith (· ≠ ·) xs (range xs.length)

def suffixClosed (p : List Nat → Bool) : Prop :=
    ∀ xs ys, p (xs ++ ys) → p ys

def prefixClosed (p : List Nat → Bool) : Prop :=
    ∀ xs ys, p (xs ++ ys) → p xs

example : suffixClosed leftmin := by
   unfold suffixClosed
   intro xs ys
   unfold leftmin; simp
   intro h
   sorry
```

We need to prove that `leftmin` is suffix-closed. The definition of `leftmin` is `∀ xs, xs.all (head! xs ≤ ·)`. The definition of `suffixClosed p` is `∀ xs ys, p (xs ++ ys) → p ys`.

So we need to show that for any lists `xs` and `ys`, if `leftmin (xs ++ ys)` holds, then `leftmin ys` holds.

Let's think about this. The property `leftmin L` holds if:
- If `L` is non-empty, then `head! L ≤ x` for all `x ∈ L`.

So if `L = xs ++ ys` and `leftmin (xs ++ ys)` holds, then:
- If `xs ++ ys` is non-empty, `head! (xs ++ ys) ≤ x` for all `x ∈ xs ++ ys`.

We need to show that `leftmin ys` holds, which means:
- If `ys` is non-empty, then `head! ys ≤ x` for all `x ∈ ys`.

So the implication is: if `leftmin (xs ++ ys)` is true, then `leftmin ys` is true.

Let's try to prove this implication. If `leftmin (xs ++ ys)` is true, then in particular, if `xs ++ ys` is non-empty, `head! (xs ++ ys) ≤ x` for all `x ∈ xs ++ ys`.

Now, if `ys` is non-empty, then `head! ys` is defined. We need to show `head! ys ≤ x` for all `x ∈ ys`.

If `xs ++ ys` is non-empty, then either `xs` is non-empty or `ys` is non-empty. If `xs` is non-empty, then `head! (xs ++ ys) = head! xs`. If `xs` is empty, then `head! (xs ++ ys) = head! ys`.

So, if `leftmin (xs ++ ys)` holds, then:
- If `xs ++ ys` is non-empty, `head! (xs ++ ys) ≤ x` for all `x ∈ xs ++ ys`.

Therefore, if `ys` is non-empty, then `head! ys ≤ x` for all `x ∈ ys`. So `leftmin ys` holds.

