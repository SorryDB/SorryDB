    have h1 : ∀ (w : ℕ) (e : Exp (ZMod p) (ZMod p)) (c : Exp (ZMod p) (ZMod p)), 
      (Circuit.assert_range w e c).eval = 
        Clap.Cs.eval p inst✝ (Clap.wrap p inst✝ (Clap.to_wg p inst✝ (Circuit.assert_range w e c)) (Clap.to_cs p inst✝ (ZMod p) (Circuit.assert_range w e c))) := by
      intro w
      induction w with
      | zero =>
        simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap,assert_range]
        <;> try { tauto }
        <;> try { aesop }
      | succ w ih =>
        simp [Circuit.eval,Cs.eval,to_cs,to_wg,wrap,assert_range] at ih ⊢
        <;> try { tauto }
        <;> try { aesop }
        <;> try { 
          simp_all [Exp.eval, Exp.eval, Exp.eval, Exp.eval, Exp.eval, Exp.eval, Exp.eval, Exp.eval]
          <;> try { tauto }
          <;> try { aesop }
        }
    specialize h1 w e c
    simpa using h1

