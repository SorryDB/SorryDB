      apply h
      sorry
      -- apply bits_good
      -- assumption
    case _ lt w =>
      rw [fail]
      constructor
      sorry
      -- apply bits_bad
      -- assumption

theorem soundness' : ∀ (c:Circuit' p),
  rw_bisim (Circuit.eval' c) (Cs.eval' (to_cs' c)) := by
  intro c
  apply soundness

