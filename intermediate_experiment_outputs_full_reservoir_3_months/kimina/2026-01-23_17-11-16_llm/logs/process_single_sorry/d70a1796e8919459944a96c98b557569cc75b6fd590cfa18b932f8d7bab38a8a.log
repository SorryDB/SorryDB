import Mathlib
open Nat

noncomputable def to_wg (c : Circuit p (ZMod p)) : Wg (ZMod p) :=
  match c with
  | .nil => Wg.nil
  | .eq0 _ c => to_wg c
  | .lam k => Wg.input (fun i => to_wg (k i))
  | .share e k =>
    let e := Exp.eval e
    .cons e (to_wg (k e))
  | .is_zero e k =>
    let e := Exp.eval e
    let inv : (ZMod p) := e⁻¹
    let o : (ZMod p) := if e = 0 then 1 else 0
    .cons inv (.cons o (to_wg (k o)))
  | .assert_range w e c =>
    let e := Exp.eval e
    .cons e (to_wg (c e))

