```lean
import Mathlib.Algebra.DirectSum.Module
import Mathlib.Order.Disjoint
import Mathlib.Prereqs.Indecomposable
import Mathlib.Prereqs.PersistenceSubmodule

/-!

# Direct sum decompositions for persistence modules (dual order version)

In this file, we define the type of direct sum decompositions of a persistence module `M`.
This has a natural order given by refinements.

Relation to the material in `PersistentDecomp.DirectSumDecompositionDual.lean`:
here, we are considering the *dual order* of the one constructed in the other file.

-/

open CategoryTheory

variable {C : Type} [Category.{0, 0} C] {K : Type} [DivisionRing K] {M : C ⥤ ModuleCat K}

variable (M) in
/-- A direct sum decomposition of `M ` is a set of non-zero submodules
that are linearly independent and whose supremum is the whole of `M`. -/
@[ext]
structure DirectSumDecomposition where
  carrier : Set (PersistenceSubmodule M)
  sSupIndep' : sSupIndep carrier
  sSup_eq_top' : sSup carrier = ⊤
  not_bot_mem' : ⊥ ∉ carrier

namespace DirectSumDecomposition

instance : SetLike (DirectSumDecomposition M) (PersistenceSubmodule M) where
  coe := carrier
  coe_injective' D₁ D₂ := by cases D₁; congr!

open SetLike

lemma sSupIndep (D : DirectSumDecomposition M) : sSupIndep (SetLike.coe D) := D.sSupIndep'

lemma sSup_eq_top (D : DirectSumDecomposition M) : sSup (SetLike.coe D) = ⊤ := D.sSup_eq_top'
lemma not_bot_mem (D : DirectSumDecomposition M) : ⊥ ∉ D := D.not_bot_mem'

lemma pointwise_iSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := sorry

lemma pointwise_sSup_eq_top (D : DirectSumDecomposition M) (x : C) : ⨆ p ∈ D, p x = ⊤ := sorry

open scoped Classical in
lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M.obj c) (S := Submodule K (M.obj c)) fun p : I ↦ p.val c := by
  rw [DirectSum.isInternal_submodule_iff_iSupIndep_and_iSup_eq_top]
  constructor
  · -- Show that the set of submodules at c is linearly independent
    intro x hx
    have h1 : IsLinearlyIndependent (fun p : I => p.val c) := by
      have h2 : IsLinearlyIndependent (I.carrier) := I.sSupIndep'
      rcases h2 with ⟨s', hs', h1, h2⟩
      use s'.image (fun p => p.val c)
      constructor
      · -- Show that fun p => p.val c = (s''. : Set (PersistenceSubmodule (M c)))
        ext x
        simp [Finset.image]
        <;> aesop
      constructor
      · -- Show that ∀ i ∈ s''. , fun p => p.val c ≠ ⊥
        intro i hi
        simp [Finset.image] at hi
        rcases hi with ⟨p, hp, hpi⟩
        have hpne : p.val c ≠ ⊥ := by
          have hp_in_carrier : p ∈ I.carrier := by 
            simpa using hp
          have hpne : p ≠ ⊥ := by
            intro h
            apply I.not_bot_mem'
            exact h
          intro h
          have h1 : p = ⊥ := by
            have h2 : p.val c = ⊥ := by
              simpa using h
            have h3 : p = ⊥ := by
              have h4 : p.val c = ⊥ := h2
              simp at h4 ⊢
              <;> try tauto
            exact h3
          contradiction
        simpa using hpne
      · -- Show that LinearlyIndependent (fun p => p.val c) s''
        intro i hi
        simp [Finset.image] at hi
        rcases hi with ⟨p, hp, hpi⟩
        have h3 : LinearlyIndependent (fun i => i) I.carrier := I.sSup_eq_top'.1
        have h4 : LinearlyIndependent (fun i => i) (I.carrier.image (fun p => p.val c)) := by
          apply LinearlyIndependent.image
          · exact h3
          · -- Show that the map is injective
            intro p1 hp1 p2 hp2 h
            have h1 : p1.val c = p2.val c := h
            have h2 : p1 ∈ I.carrier := by
              simpa using hp1
            have h3 : p2 ∈ I.carrier := by
              simpa using hp2
            have h4 : p1 = p2 := by
              apply LinearlyIndependent.injective h3 h2
              all_goals try simp_all
              all_goals try tauto
            simpa using h4
        simpa using h4
    simpa using h1
  · -- Show that iSup (fun p : I => p.val c) = ⊤
    have h1 : sSup (fun p : I => p.val c) = ⊤ := by
      have h2 : sSup (I.carrier) = ⊤ := I.sSup_eq_top'
      have h3 : sSup (fun p : I => p.val c) = sSup (I.carrier) := by
        have h4 : ∀ x : K, x ∈ sSup (fun p : I => p.val c) ↔ x ∈ sSup (I.carrier) := by
          intro x
          simp [sSup]
          <;> aesop
        ext x
        simp [h4]
      rw [h3, h2]
    simpa using h1
```

