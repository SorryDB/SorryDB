```tactics
theorem (n : ℕ) : all_colorings_are_good n ↔ n ≥ 9 := by
  constructor
  · -- Forward: if all colorings are good, then n ≥ 9
    intro h
    by_contra h'
    push_neg at h'
    have h8 : n ≤ 8 := by omega
    have h8' : all_colorings_are_good 8 := by
      apply lemma1 (by omega) h
    obtain ⟨f, hf⟩ := lemma2
    specialize h8' f
    contradiction
```

