      " a xs) := by\n  intro xs\n  induction xs with\n  | nil => rfl\n  | cons x xs ih =>\n    simp [toRA, fromRA, consRA]\n    rw [ih]\n    match toRA xs with\n    | [] => rfl\n    | (Digit.zero :: ds) =>\n      simp [fromRA]\n      rw [concatMap]\n      sorry\n    | (Digit.one t :: ds) =>\n      simp [fromRA]\n      rw [concatMap]\n      sorry\n```\n\nThe goal is to prove the equality:\n`x :: (concat1 ∘ List.map fromRA.frm) (Digit.one t :: ds) = (concat1 ∘ List.map fromRA.frm) (consRA.consT (Tree.leaf x) (List.foldr consRA nilRA ((concat1 ∘ List.map fromRA.frm) (Digit.one t :: ds))))`\n\nLet's analyze the structure:\n- Left side: `x :: (concat1 ∘ List.map fromRA.frm) (Digit.one t :: ds)`\n- Right side: `(concat1 ∘ List.map fromRA.frm) (consRA.consT (Tree.leaf x) (List.foldr consRA nilRA ((concat1 ∘ List.map fromRA.frm) (Digit.one t :: ds))))`\n\nLet `L = (concat1 ∘ List.map fromRA.frm) (Digit.one t :: ds)`.\nLeft side is `x :: L`.\nRight side is `(concat1 ∘ List.map fromRA.frm) Y` where `Y = consRA.consT (Tree.leaf x) (List.foldr consRA nilRA L)`.\n`Y = (Tree.leaf x).consT (List.foldr consRA nilRA L)`.\n`List.foldr consRA nilRA L = toRA L`.\nSo `Y = (Tree.leaf x).consT (toRA L)`.\n`fromRA Y = fromRA ((Tree.leaf x).consT (toRA L))`.\n`fromRA ((Tree.leaf x).consT (toRA L)) = fromRA (toRA (x :: L))` (by definition of `consT` and `toRA`)\n`fromRA (toRA (x :: L)) = x :: L` (by the property `fromRA (toRA X) = X`)\n\nSo the right side `(concat1 ∘ List.map fromRA.frm) Y` should be `x :: L`.\nThe left side is `x :: L`.\nSo the equality holds.\n\nLet's complete the proof.\n\n```tactics\nimport Fad.Chapter3\nimport Fad.Chapter1\nimport Fad.«Chapter1-Ex»\n```\n\n```tactics\nnamespace Chapter3\n```\n\n```tactics\n/- # Exercicio 3.1 -/\n\nsection\nopen SL1\n\n/-\n(['a', 'b', 'c'], ['d'])\n(['a'], ['d', 'c', 'b'])\n(['a', 'b'], ['d', 'c'])\n\n#eval toSL \"abcd\".toList\n#eval List.foldr consSL nilSL \"abcd\".toList\n#eval List.foldl (flip snocSL) nilSL \"abcd\".toList\n#eval consSL 'a' (snocSL 'd' (List.foldr consSL nilSL \"bc\".toList))\n-/\n\nend\n```\n\n```tactics\n/- # Exercicio 3.2 -/\n\nnamespace SL1\n\ndef nullSL {α : Type} : SymList α → Bool\n| (xs, ys) => xs.isEmpty ∧ ys.isEmpty\n\ndef singleSL {α : Type} : SymList α → Prop\n| (xs, ys) => (xs.isEmpty ∧ ys.single) ∨ (ys.isEmpty ∧ xs.single)\n\ndef lengthSL {α : Type} : SymList α → Nat\n| (xs, ys) => xs.length + ys.length\n\nend SL1\n```\n\n```tactics\n/- # Exercicio 3.3 -/\n\nnamespace SL1\n\ndef headSL? {α : Type} : SymList α → Option α\n | ([],[])  => none    -- why not nilSL?\n | ([], ys) => List.head? ys\n | (xs, _)  => List.head? xs\n\nend SL1\n```\n\n```tactics\n-- # Exercicio 3.4\n\nnamespace SymList\n\ndef initSL {a : Type} : (sl : SymList a) → SymList a\n| ⟨xs, ys, ok⟩ =>\n  if h : ys.isEmpty then\n    match xs with\n    | [] => nil\n    | _  => nil\n  else\n    if h2 : ys.length = 1 then\n     splitInTwoSL xs\n    else SymList.mk xs ys.tail (by\n      simp [← not_congr List.length_eq_zero_iff] at h\n      apply And.intro\n      all_goals\n       intro h3\n       simp [h3] at ok\n       cases ys with\n       | nil => contradiction\n       | cons b bs => simp_all)\n\nend SymList\n```\n\n```tactics\n/- # Exercicio 3.5 -/\n\nnamespace SL1\nopen Chapter1 (dropWhile)\n\n/-\ndef dropWhileSL₁ (p : α → Bool) (sl : SymList α) : SymList α :=\n let us := sl.1.dropWhile p\n if us.isEmpty then toSL (sl.2.reverse.dropWhile p) else (us, sl.2)\n\npartial def dropWhileSL (p : α → Bool) (sl : SymList α) : SymList α :=\n if nullSL sl then\n   nilSL\n else\n  match headSL? sl with\n  | none   => nilSL\n  | some x =>\n    if p x then\n      match (tailSL sl) with\n      | none    => nilSL\n      | some us => dropWhileSL p us\n    else\n      sl\n\nexample (p : α → Bool)\n  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL₁ p := by\n  funext xs\n  simp [Function.comp]\n  simp [fromSL]\n  sorry -- it should not be proved\n-/\n```\n\n```tactics\nend SL1\n```\n\n```tactics\n/- # Exercicio 3.6 -/\n\nnamespace SymList\n\ntheorem length_lt_length_init {a : Type}\n (sl : SymList a) (h : sl ≠ nil)\n : sl.lengthSL > sl.initSL.lengthSL := by\n have ⟨xs, ys, h₁⟩ := sl\n induction xs with\n | nil =>\n   cases ys with\n   | nil => contradiction\n   | cons b bs =>\n     have h₂ := h₁.1 ; simp at h₂\n     simp [lengthSL, initSL, h₂, splitInTwoSL]\n | cons b bs ih₁ =>\n   induction ys with\n   | nil =>\n     have h₂ := h₁.2 ; simp at h₂\n     simp [lengthSL, initSL, h₂, nil]\n   | cons n ns ih₂ =>\n     simp at ih₁ ih₂\n     simp [lengthSL, initSL]; sorry\n\n\ndef initsSL {a : Type} (sl : SymList a) : SymList (SymList a) :=\n  if h : sl.isEmpty then\n   nil.snocSL sl\n  else\n    have : (initSL sl).lengthSL <  sl.lengthSL :=\n      length_lt_length_init sl (by\n       have ⟨lsl, rsl, _⟩ := sl\n       simp [isEmpty] at h\n       simp [nil]\n       exact h)\n    snocSL sl (initsSL (initSL sl))\n termination_by sl.lengthSL\n\n\nend SymList\n```\n\n```tactics\n/- # Exercicio 3.7 -/\n\ndef inits {α : Type} : List α → List (List α) :=\n (List.map List.reverse ∘ (Chapter1.scanl (flip List.cons) []))\n\n\n/- # Exercicio 3.8  -/\n\ndef measure (ts : List (Tree a)) : Nat :=\n  ts.foldr (λ t acc => size t + acc) 0\n where\n  size : Tree a → Nat\n  | Tree.leaf _       => 1\n  | Tree.node _ t1 t2 => 1 + size t1 + size t2\n\ndef fromTs : List (Tree a) → List a\n| [] => []\n| (Tree.leaf x) :: ts =>\n  have : measure ts < measure (Tree.leaf x :: ts) := by\n   simp [measure,measure.size]\n  x :: fromTs ts\n| (Tree.node n t1 t2) :: ts =>\n  have : measure (t1 :: t2 :: ts) < measure (Tree.node n t1 t2 :: ts) := by\n   simp [measure, measure.size]\n   rw [Nat.add_assoc]; simp\n  fromTs (t1 :: t2 :: ts)\ntermination_by x1 => measure x1\n```\n\n```tactics\n-- 3.10\n\ndef toRA {a : Type} : List a → RAList a :=\n  List.foldr consRA nilRA\n\nexample : ∀ (xs : List a), xs = fromRA (toRA a xs) := by\n  intro xs\n  induction xs with\n  | nil => rfl\n  | cons x xs ih =>\n    simp [toRA, fromRA, consRA]\