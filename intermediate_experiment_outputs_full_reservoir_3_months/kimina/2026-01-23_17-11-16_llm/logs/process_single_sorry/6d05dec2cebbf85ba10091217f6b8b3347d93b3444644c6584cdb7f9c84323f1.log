import Fad.Chapter3
import Fad.Chapter1
import Fad.«Chapter1-Ex»
open Fad

namespace Fad

def toSL {α : Type} (l : List α) : SymList α :=
  (List.foldr consSL nilSL l, List.reverse l)

def consSL (x : α) (s : SymList α) : SymList α :=
  match s with
  | (xs, ys) => (List.cons x xs, List.reverse xs ++ List.reverse ys)

def snocSL (x : α) (s : SymList α) : SymList α :=
  match s with
  | (xs, ys) => (List.reverse ys ++ List.reverse (List.cons x xs))

end Fad

open Fad

/- # Exercicio 3.1 -/

namespace Fad

def consSL (x : α) (s : SymList α) : SymList α :=
  match s with
  | (xs, ys) => (List.cons x xs, List.reverse xs ++ List.reverse ys)

def snocSL (x : α) (s : SymList α) : SymList α :=
  match s with
  | (xs, ys) => (List.reverse ys ++ List.reverse (List.cons x xs))

end Fad

/- # Exercicio 3.2 -/

namespace Fad

def nullSL {α : Type} : SymList α → Bool
| (xs, ys) => xs.isEmpty ∧ ys.isEmpty

def singleSL {α : Type} : SymList α → Prop
| (xs, ys) => (xs.isEmpty ∧ ys.single) ∨ (ys.isEmpty ∧ xs.single)

def lengthSL {α : Type} : SymList α → Nat
| (xs, ys) => xs.length + ys.length

end Fad

/- # Exercicio 3.3 -/

namespace Fad

def headSL? {α : Type} : SymList α → Option α
 | ([],[])  => none
 | ([], ys) => List.head? ys
 | (xs, _)  => List.head? xs

end Fad

/- # Exercicio 3.4 -/

namespace Fad

def initSL {a : Type} : (sl : SymList a) → SymList a
| ⟨xs, ys, ok⟩ =>
  if h : ys.isEmpty then
    match xs with
    | [] => nil
    | _  => nil
  else
    if h2 : ys.length = 1 then
     splitInTwoSL xs
    else SymList.mk xs ys.tail (by
      simp [← not_congr List.length_eq_zero_iff] at h
      apply And.intro
      all_goals
       intro h3
       simp [h3] at ok
       cases ys with
       | nil => contradiction
       | cons b bs => simp_all)

end Fad

/- # Exercicio 3.5 -/

namespace Fad

def fromSL {α : Type} (l : List α) : SymList α :=
  (List.foldr consSL nilSL l, List.reverse l)

def toSL {α : Type} (s : SymList α) : List α :=
  s.1 ++ List.reverse s.2

end Fad

/- # Exercicio 3.6 -/

namespace Fad

def initsSL {a : Type} (sl : SymList a) : SymList (SymList a) :=
  if h : sl.isEmpty then
   nil.snocSL sl
  else
    have : (initSL sl).lengthSL <  sl.lengthSL :=
      length_lt_length_init sl (by
       have ⟨lsl, rsl, _⟩ := sl
       simp [isEmpty] at h
       simp [h]
       exact h)
    snocSL sl (initsSL (initSL sl))
 termination_by sl.lengthSL

end Fad

/- # Exercicio 3.7 -/

def inits {α : Type} : List α → List (List α) :=
 (List.map List.reverse ∘ (List.scanl (flip List.cons) []))

end Fad

/- # Exercicio 3.8  -/

def measure (ts : List (Tree a)) : Nat :=
  ts.foldr (λ t acc => size t + acc) 0
 where
  size : Tree a → Nat
  | Tree.leaf _       => 1
  | Tree.node _ t1 t2 => 1 + size t1 + size t2

def fromTs : List (Tree a) → List a
| [] => []
| (Tree.leaf x) :: ts =>
  have : measure ts < measure (Tree.leaf x :: ts) := by
   simp [measure, measure.size]
  x :: fromTs ts
| (Tree.node n t1 t2) :: ts =>
  have : measure (t1 :: t2 :: ts) < measure (Tree.node n t1 t2 :: ts) := by
   simp [measure, measure.size]
   rw [Nat.add_assoc]; simp
  fromTs (t1 :: t2 :: ts)
termination_by x1 => measure x1

end Fad

/- # Exercicio 3.9  -/

namespace Fad

def toRA {a : Type} : List a → RAList a :=
  List.foldr consRA nilRA

def fromRA {a : Type} : RAList a → List a :=
  List.foldr (fun x xs => x :: xs) [] 

end Fad

