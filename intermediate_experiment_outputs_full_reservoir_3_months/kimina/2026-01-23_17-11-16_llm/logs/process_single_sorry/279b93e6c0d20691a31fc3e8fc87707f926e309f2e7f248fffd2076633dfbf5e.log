```lean
import Clean.Circuit
import Clean.Utils.Field
import Clean.Utils.Tactics

namespace Circomlib
variable {p : ℕ} [Fact p.Prime] [Fact (p > 2)]

/-
Original source code:
https://github.com/iden3/circomlib/blob/master/circuits/sha256/rotate.circom
-/

namespace RotR

/-
template RotR(n, r) {
    signal input inp[n];
    signal output out[n];

    for (var i = 0; i < n; i++) {
        out[i] <== inp[ (i+r)%n ];
    }
}
-/
def main (n r : ℕ) [NeZero n] (inp : Vector (Expression (F p)) n) := do
  let out <== Vector.mapFinrange n fun i => inp.get (i + Fin.ofNat n r)
  return out

def circuit (n r : ℕ) [NeZero n] : FormalCircuit (F p) (fields n) (fields n) where
  main := main n r

  localLength _ := n

  Spec input output := output = input.rotate r

  soundness := by
    circuit_proof_start
    -- Assuming i₀ = r for the sake of argument
    have eq1 : ∀ i : Fin n, (var { index := r + i }) = input[(i + r) % n] := by
      intro i
      simp [var, Vector.get]
      <;> try { tauto }
      <;> try { native_decide }
    
    have eq2 : Vector.map (fun i => var { index := r + i }) n = Vector.map (fun i => input[(i + r) % n]) n := by 
      apply Vector.map_congr
      intro i hi
      exact eq1 i

    rw [eq2]
    simp [Vector.rotate]
    <;> try { tauto }
