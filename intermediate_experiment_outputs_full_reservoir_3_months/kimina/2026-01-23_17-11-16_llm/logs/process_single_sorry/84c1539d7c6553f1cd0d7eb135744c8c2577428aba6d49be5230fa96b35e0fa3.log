      "\n    | node tâ‚پ x tâ‚‚ ihl ih =>\n      simp [Tree.height, Tree.size] at ih âٹ¢\n      all_goals\n        try { \n          have h1 : (tâ‚پ : â„•).height â‰¤ tâ‚پ.size := by \n            omega \n          have h2 : (tâ‚‚ : â„•).height â‰¤ tâ‚‚.size := by \n            omega \n          have h3 : tâ‚پ.size < 2 ^ tâ‚پ.height := by \n            omega \n          have h4 : tâ‚‚.size < 2 ^ tâ‚‚.height := by \n            omega \n          have h5 : tâ‚پ.height â‰¤ tâ‚‚.height âˆ¨ tâ‚‚.height â‰¤ tâ‚پ.height := by \n            omega \n          rcases h5 with (h5 | h5)\n          آ· -- Case tâ‚پ.height â‰¤ tâ‚‚.height\n            have h6 : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + tâ‚‚.height) := by\n              have h7 : tâ‚‚.size < 2 ^ tâ‚‚.height := by \n                omega \n              have h8 : tâ‚پ.size < 2 ^ tâ‚پ.height := by \n                omega \n              have h9 : tâ‚پ.height â‰¤ tâ‚‚.height := by \n                omega \n              have h10 : 2 ^ tâ‚پ.height â‰¤ 2 ^ tâ‚‚.height := by \n                apply Nat.pow_le_pow_of_le_right \n                all_goals \n                  omega \n              nlinarith [show 2 ^ tâ‚‚.height â‰¥ 1 from by \n                have h11 : 2 ^ tâ‚‚.height â‰¥ 2 ^ 0 := by \n                  apply Nat.pow_le_pow_of_le_right \n                  all_goals \n                    omega \n                have h12 : 2 ^ 0 = 1 := by \n                  norm_num \n                linarith \n              ]\n            have h7 : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) := by \n              have h8 : max tâ‚پ.height tâ‚‚.height = tâ‚‚.height := by \n                simp [max_eq_right, h5] \n              rw [h8] \n              linarith \n            linarith \n          آ· -- Case tâ‚‚.height â‰¤ tâ‚پ.height \n            have h6 : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + tâ‚پ.height) := by \n              have h7 : tâ‚پ.size < 2 ^ tâ‚پ.height := by \n                omega \n              have h8 : tâ‚‚.size < 2 ^ tâ‚‚.height := by \n                omega \n              have h9 : tâ‚‚.height â‰¤ tâ‚پ.height := by \n                omega \n              have h10 : 2 ^ tâ‚‚.height â‰¤ 2 ^ tâ‚پ.height := by \n                apply Nat.pow_le_pow_of_le_right \n                all_goals \n                  omega \n              nlinarith [show 2 ^ tâ‚پ.height â‰¥ 1 from by \n                have h11 : 2 ^ tâ‚پ.height â‰¥ 2 ^ 0 := by \n                  apply Nat.pow_le_pow_of_le_right \n                  all_goals \n                    omega \n                have h12 : 2 ^ 0 = 1 := by \n                  norm_num \n                linarith \n              ]\n            have h7 : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) := by \n              have h8 : max tâ‚پ.height tâ‚‚.height = tâ‚پ.height := by \n                simp [max_eq_left, h5] \n              rw [h8] \n              linarith \n            linarith \n        }\n        try { \n          linarith \n        }",
      "\n    all_goals\n      have h1 : tâ‚پ.size < 2 ^ tâ‚پ.height := ihl\n      have h2 : tâ‚‚.size < 2 ^ tâ‚‚.height := ihr\n      have h3 : tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) := by\n        have h4 : max tâ‚پ.height tâ‚‚.height â‰¥ tâ‚پ.height := by apply le_max_left\n        have h5 : max tâ‚پ.height tâ‚‚.height â‰¥ tâ‚‚.height := by apply le_max_right\n        have h6 : (2 : â„•) ^ (1 + max tâ‚پ.height tâ‚‚.height) = 2 * (2 ^ (max tâ‚پ.height tâ‚‚.height)) := by ring\n        rw [h6]\n        have h7 : tâ‚پ.size < 2 ^ tâ‚پ.height := h1\n        have h8 : tâ‚‚.size < 2 ^ tâ‚‚.height := h2\n        have h9 : tâ‚پ.size â‰¤ 2 ^ tâ‚پ.height := by omega\n        have h10 : tâ‚‚.size â‰¤ 2 ^ tâ‚‚.height := by omega\n        have h11 : 2 ^ tâ‚پ.height â‰¤ 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n          apply pow_le_pow_right\n          all_goals omega\n        have h12 : 2 ^ tâ‚‚.height â‰¤ 2 ^ (max tâ‚پ.height tâ‚‚.height) := by\n          apply pow_le_pow_right\n          all_goals omega\n        have h13 : tâ‚پ.size + tâ‚‚.size < 2 ^ tâ‚پ.height + 2 ^ tâ‚‚.height := by linarith\n        have h14 : 2 ^ tâ‚پ.height + 2 ^ tâ‚‚.height â‰¤ 2 * (2 ^ (max tâ‚پ.height tâ‚‚.height)) := by\n          nlinarith [show (2 : â„•) ^ tâ‚پ.height â‰¤ (2 : â„•) ^ (max tâ‚پ.height tâ‚‚.height) from h11, \n          show (2 : â„•) ^ tâ‚‚.height â‰¤ (2 : â„•) ^ (max tâ‚پ.height tâ‚‚.height) from h12]\n        linarith\n      omega\n  }",
      "\n    | node tâ‚پ x tâ‚‚ ihl =>\n      simp [Tree.height, Tree.size] at ihl âٹ¢\n      cases max_cases tâ‚پ.height tâ‚‚.height with\n      | inl h =>\n        have h1 : 1 + tâ‚پ.size + tâ‚‚.size < 2 * (2 ^ tâ‚پ.height) := by\n          omega\n        have h2 : 2 * (2 ^ tâ‚پ.height) â‰¤ 2 * (2 ^ (tâ‚پ.height + tâ‚‚.height)) := by\n          have h3 : tâ‚‚.height â‰¤ tâ‚پ.height := by linarith\n          have h4 : 2 ^ tâ‚‚.height â‰¤ 2 ^ tâ‚پ.height := by\n            apply Nat.pow_le_pow_of_le_right\n            all_goals linarith\n          omega\n        have h3 : 2 * (2 ^ (tâ‚پ.height + tâ‚‚.height)) = 2 ^ (1 + tâ‚پ.height + tâ‚‚.height) := by\n          ring_nf\n        have h4 : 2 * (2 ^ tâ‚پ.height) â‰¤ 2 ^ (1 + tâ‚پ.height + tâ‚‚.height) := by\n          linarith [h2, h3]\n        have h5 : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + tâ‚پ.height + tâ‚‚.height) := by\n          linarith [h1, h4]\n        have h6 : 1 + tâ‚پ.height + tâ‚‚.height = 1 + tâ‚پ.height := by\n          omega\n        rw [h6] at h5\n        linarith\n      | inr h =>\n        have h1 : 1 + tâ‚پ.size + tâ‚‚.size < 2 * (2 ^ tâ‚‚.height) := by\n          omega\n        have h2 : 2 * (2 ^ tâ‚‚.height) â‰¤ 2 * (2 ^ (tâ‚پ.height + tâ‚‚.height)) := by\n          have h3 : tâ‚پ.height â‰¤ tâ‚‚.height := by linarith\n          have h4 : 2 ^ tâ‚پ.height â‰¤ 2 ^ tâ‚‚.height := by\n            apply Nat.pow_le_pow_of_le_right\n            all_goals linarith\n          omega\n        have h3 : 2 * (2 ^ (tâ‚پ.height + tâ‚‚.height)) = 2 ^ (1 + tâ‚پ.height + tâ‚‚.height) := by\n          ring_nf\n        have h4 : 2 * (2 ^ tâ‚‚.height) â‰¤ 2 ^ (1 + tâ‚پ.height + tâ‚‚.height) := by\n          linarith [h2, h3]\n        have h5 : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + tâ‚پ.height + tâ‚‚.height) := by\n          linarith [h1, h4]\n        have h6 : 1 + tâ‚پ.height + tâ‚‚.height = 1 + tâ‚‚.height := by\n          omega\n        rw [h6] at h5\n        linarith",
      "\n```\n\nThe `end BST1` is closing the namespace.\n\nNow, the main theorem statement:\n\n```tactics\n-- # Exercicio 4.8\n\n\nnamespace BST1\n\nexample {خ± : Type} (t : Tree خ±) :\n  t.height â‰¤ t.size âˆ§ t.size < 2 ^ t.height := by\n  apply And.intro\n  {\n   induction t with\n   | null  => simp [Tree.height, Tree.size]\n   | node tâ‚پ x tâ‚‚ ihl ihr =>\n     simp [Tree.height, Tree.size]\n     sorry\n  }\n  {\n  induction t with\n  | null => simp [Tree.height, Tree.size]\n  | node tâ‚پ x tâ‚‚ ihl ihr =>\n    simp [Tree.height, Tree.size]\n    sorry\n```\n\nWe're proving that for a binary tree `t`, its height is less than or equal to its size, and its size is less than `2^height`. This is a standard property of binary trees.\n\nThe first part `t.height â‰¤ t.size` is being proved by induction. The base case is trivial. The inductive step needs to show that if the property holds for the left and right subtrees, it holds for the whole tree.\n\nThe second part `t.size < 2 ^ t.height` is also being proved by induction. The base case is trivial. The inductive step needs to show that if the property holds for the left and right subtrees, it holds for the whole tree.\n\nThe `sorry` is in the inductive step for the second part. Let's replace it:\n\n```tactics\nimport Fad.Chapter4\nimport Fad.Chapter3\n\nnamespace Chapter4\n```\n\nWe have the necessary imports.\n\nLet's define the theorem:\n\n```tactics\n/- 4.3\n\nVamos provar por induأ§أ£o que\n\nT(x) = âŒˆlog(n-1)âŒ‰.\n\nPara o caso base (n=2)\n\nT(2) = âŒˆlog(2-1)âŒ‰ = âŒˆlog(1)âŒ‰ = âŒˆ0âŒ‰ = 0.\n\nSupondo valido para k < n, vamos provar para n. Como âŒˆ(n+1)/2âŒ‰ < n,\nvale a hipotese de induأ§أ£o, entأ£o temos que provar que:\n\nT(n) = âŒˆlog(âŒˆ(n+1)/2âŒ‰ -1)âŒ‰ + 1 = âŒˆlog(n-1)âŒ‰.\n\nPodemos mostrar por desigualdade indireta, mostrando que o lado\nesquerdo أ© menor que k se e somente o lado direito أ© menor que k, para\nqualquer k natural.  Pelo lado direito temos que âŒˆlog(n-1)âŒ‰ <= k <=>\nn-1 <= 2^k.  Pelo lado esquerdo:\n\n    âŒˆlog(âŒˆ(n+1)/2âŒ‰ -1)âŒ‰ + 1 <= k <=> âŒˆlog(âŒˆ(n+1)/2âŒ‰ -1)âŒ‰ <= k-1,\n                                 <=> log(âŒˆ(n+1)/2âŒ‰ -1) <= k-1,\n                                 <=> âŒˆ(n+1)/2âŒ‰ -1 <= 2^(k-1),\n                                 <=> âŒˆ(n+1)/2âŒ‰ <= 2^(k-1) + 1,\n                                 <=> (n+1)/2 <= 2^(k-1) + 1,\n                                 <=> n+1 <= 2^k + 2,\n                                 <=> n-1 <= 2^k.\n\nO que completa a prova, uma vez que ambos os lados chegam na mesma\nproposiأ§أ£o.\n\n-/\n\n\n/- 4.4 : see the book -/\n\n/-!\n# Exercicio 4.5\n\nIndexing the coordinates from zero, the positions are\n(0, 9), (5, 6), (7, 5), (9, 0)\n-/\n\n-- # Exercicio 4.6\n\n-- #eval D2.searchâ‚پ (خ» (x, y) => x ^ 3 + y ^ 3) 1729\n\n\n-- # Exercicio 4.7\n\nnamespace BST1\n\ndef flatcat : (t : Tree a) â†’ (xs: List a) â†’ List a\n| .null, xs => xs\n| .node l x r, xs => flatcat l (x :: flatcat r xs)\n\ndef Tree.flattenâ‚پ (t : Tree a) : List a :=\n flatcat t []\n```\n\nWe're defining `flatcat` and `Tree.flattenâ‚پ` here. `flatcat` is a recursive function that flattens a tree into a list. `Tree.flattenâ‚پ` is a specific call to `flatcat` with an empty list as the second argument.\n\nLet's continue with the proof:\n\n```tactics\ntheorem flatten_eq_helper_accum (t : Tree a) (xs: List a)\n  : t.flatten ++ xs = flatcat t xs := by\n  induction t generalizing xs with\n  | null => rfl\n  | node l x r ihl ihr =>\n    rw [flatcat, â†گihr]\n    rw [â†گihl (x :: (r.flatten ++ xs))]\n    rw [List.append_cons]\n    rw [â†گ List.append_assoc]\n    rw [Tree.flatten]\n```\n\nThis theorem `flatten_eq_helper_accum` is being proved. It's showing that the standard `t.flatten ++ xs` is equal to `flatcat t xs`. The proof is by induction on `t`.\n\nNow, let's look at the example:\n\n```tactics\nexample (t: Tree a) : t.flatten = t.flattenâ‚پ := by\n  induction t with\n  | null => exact rfl\n  | node l x r ihl ihr =>\n    rw [Tree.flattenâ‚پ]