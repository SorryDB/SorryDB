    rw [List.append_cons]
    rw [â†گ List.append_assoc]
    rw [Tree.flatten]

example (t: Tree a) : t.flatten = t.flattenâ‚پ := by
  induction t with
  | null => exact rfl
  | node l x r ihl ihr =>
    rw [Tree.flattenâ‚پ]
    simp [â†گ flatten_eq_helper_accum]

