      "\n    have h1 : tâ‚پ.size < 2 ^ tâ‚پ.height := ihl\n    have h2 : tâ‚‚.size < 2 ^ tâ‚‚.height := ihr\n    have h3 : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (1 + max tâ‚پ.height tâ‚‚.height) := by\n      have h4 : tâ‚پ.height â‰¤ max tâ‚پ.height tâ‚‚.height := by\n        cases max_cases tâ‚پ.height tâ‚‚.height with\n        | inl h => omega\n        | inr h => omega\n      have h5 : tâ‚‚.height â‰¤ max tâ‚پ.height tâ‚‚.height := by\n        cases max_cases tâ‚پ.height tâ‚‚.height with\n        | inl h => omega\n        | inr h => omega\n      have h6 : 2 ^ tâ‚پ.height â‰¤ 2 ^ max tâ‚پ.height tâ‚‚.height := by\n        apply pow_le_pow_right\n        all_goals omega\n      have h7 : 2 ^ tâ‚‚.height â‰¤ 2 ^ max tâ‚پ.height tâ‚‚.height := by\n        apply pow_le_pow_right\n        all_goals omega\n      have h8 : tâ‚پ.size < 2 ^ tâ‚پ.height := ihl\n      have h9 : tâ‚‚.size < 2 ^ tâ‚‚.height := ihr\n      have h10 : tâ‚پ.size + tâ‚‚.size < 2 ^ tâ‚پ.height + 2 ^ tâ‚‚.height := by linarith\n      have h11 : 2 ^ tâ‚پ.height + 2 ^ tâ‚‚.height â‰¤ 2 * (2 ^ max tâ‚پ.height tâ‚‚.height) := by\n        have h12 : 2 ^ tâ‚پ.height â‰¤ 2 ^ max tâ‚پ.height tâ‚‚.height := h6\n        have h13 : 2 ^ tâ‚‚.height â‰¤ 2 ^ max tâ‚پ.height tâ‚‚.height := h7\n        omega\n      have h14 : 2 * (2 ^ max tâ‚پ.height tâ‚‚.height) = 2 ^ (max tâ‚پ.height tâ‚‚.height + 1) := by ring\n      have h15 : 1 + tâ‚پ.size + tâ‚‚.size < 2 ^ (max tâ‚پ.height tâ‚‚.height + 1) := by\n        omega\n      simpa using h15\n    omega\n  }",
