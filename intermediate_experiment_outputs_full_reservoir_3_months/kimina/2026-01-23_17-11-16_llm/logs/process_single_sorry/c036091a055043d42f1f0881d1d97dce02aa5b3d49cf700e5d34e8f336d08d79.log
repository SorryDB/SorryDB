# Bulgarian Mathematical Olympiad 1998, Problem 1

We will be considering colorings in 2 colors of n (distinct) points
AРѓЂ, AРѓѓ, ..., AРѓЎ. Call such a coloring "good" if there exist three points
Aрхб, AР▒╝, AРѓѓР▒╝РѓІрхб, 1 РЅц i < 2j - i РЅц n, which are colored the same color.

Find the least natural number n (n РЅЦ 3) such that all colorings
of n points are good.
-/

namespace Bulgaria1998P1

abbrev coloring_is_good {m : РёЋ} (color : Set.Icc 1 m Рєњ Fin 2) : Prop :=
  РѕЃ i j : Set.Icc 1 m,
    i < j РѕД
    РѕЃ h3 : 2 * j.val - i Рѕѕ Set.Icc 1 m,
    color i = color j РѕД color i = color РЪе2 * j - i, h3РЪЕ

abbrev all_colorings_are_good (m : РёЋ) : Prop :=
  3 РЅц m РѕД Рѕђ color : Set.Icc 1 m Рєњ Fin 2, coloring_is_good color

lemma lemma1 {m n : РёЋ} (hmn : m РЅц n) (hm : all_colorings_are_good m) :
    all_colorings_are_good n := by
  constructor
  ┬и exact hm.1.trans hmn
  ┬и intro c
    let c' : Set.Icc 1 m Рєњ Fin 2 :=
      fun x Рєд c РЪеx.val, by rw [Set.mem_Icc]; exact РЪеx.prop.1, x.prop.2.trans hmnРЪЕРЪЕ
    obtain РЪеРЪеi, hi1, hi2РЪЕ, РЪеj, hj1, hj2РЪЕ, hij1, hij2, hc1, hc2РЪЕ := hm.2 c'
    use РЪеi, hi1, hi2.trans hmnРЪЕ
    use РЪеj, hj1, hj2.trans hmnРЪЕ
    simp only [Subtype.mk_lt_mk, Set.mem_Icc, tsub_le_iff_right, exists_and_left]
    simp only [Subtype.mk_lt_mk] at hij1
    refine РЪеhij1, ?_РЪЕ
    simp only [Set.mem_Icc, tsub_le_iff_right] at hij2
    simp only [c'] at hc1
    refine РЪеhc1, ?_РЪЕ
    have hij2' : 1 РЅц 2 * j - i РѕД 2 * j РЅц n + i :=
       РЪеhij2.1, le_add_of_le_add_right hij2.2 hmnРЪЕ
    use hij2'

def coloring_of_eight {n : РёЋ} : Set.Icc 1 n Рєњ Fin 2
| РЪе1, _РЪЕ => 0
| РЪе2, _РЪЕ => 1
| РЪе3, _РЪЕ => 0
| РЪе4, _РЪЕ => 1
| РЪе5, _РЪЕ => 1
| РЪе6, _РЪЕ => 0
| РЪе7, _РЪЕ => 1
| РЪе8, _РЪЕ => 0
| _ => 0 -- unreachable

lemma lemma2 :
    РѕЃ f : Set.Icc 1 8 Рєњ Fin 2, ┬гcoloring_is_good f := by
  use coloring_of_eight
  intro h
  obtain РЪеРЪеi, hi1, hi2РЪЕ, РЪеj, hj1, hj2РЪЕ, hij1, hij2, hc1, hc2РЪЕ := h
  dsimp [coloring_of_eight] at *
  interval_cases i <;> interval_cases j <;> try { contradiction }
  <;> omega

