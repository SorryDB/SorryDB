| РЪе2, _РЪЕ => 1
| РЪе3, _РЪЕ => 0
| РЪе4, _РЪЕ => 1
| РЪе5, _РЪЕ => 1
| РЪе6, _РЪЕ => 0
| РЪе7, _РЪЕ => 1
| РЪе8, _РЪЕ => 0
| _ => 0 -- unreachable

lemma lemma2 :
