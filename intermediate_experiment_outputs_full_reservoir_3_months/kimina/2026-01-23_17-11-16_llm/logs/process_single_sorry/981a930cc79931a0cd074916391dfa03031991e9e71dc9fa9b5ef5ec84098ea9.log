/- An alternating path P with respect to a matching M is a path where the edges in P are alternately in and not in M. -/
@[mk_iff]
structure IsAltPath (G : Graph α β) (hM : G.IsMatching M) (P : WList α β) : Prop
  extends G.IsPath P where
  mem_matching : P.edge.IsChain (fun e f ↦ e ∈ M ∨ f ∈ M)

/- An augmenting path P with respect to a matching M is an alternating path that starts and ends at vertices not covered by M. -/
@[mk_iff]
structure IsAugPath (G : Graph α β) (hM : G.IsMatching M) (P : WList α β) : P : Prop
  extends G.IsAltPath hM P where
  nonempty : P.Nonempty
  first_not_in : P.first ∉ V(G, M)
  last_not_in : P.last ∉ V(G, M)

/- A vertex x is inessential if it is not covered by some maximum matching M. -/
def inessential (G : Graph α β) (x : α) : Prop :=
  ∃ M, G.IsMaxMatching M ∧ x ∉ V(G, M)

/- An odd component of a graph G is a connected subgraph H such that the number of vertices in H is odd. -/
structure IsOddCompOf (H G : Graph α β) extends H.IsCompOf G where
  finite : V(H).Finite
  odd : Odd V(H).encard

/- The set of all odd components of a graph G. -/
def OddComponents (G : Graph α β) : Set (Graph α β) :=
  {H | H.IsOddCompOf G}

/- Lemma: For any matching M in G, the set of vertices covered by M is a subset of the set of vertices of G. -/
lemma IsMatching.subset_of_vertices (hM : G.IsMatching M) : V(G, M) ⊆ V(G) := by
  intro v hv
  rw [mem_mk] at hv
  rcases hv with ⟨e, he, hw⟩
  simp at he hw ⊢
  tauto

/- Lemma: For any matching M in G, the degree of any vertex v in G restricted to M is at most 1. -/
lemma IsMatching.degree_le_one (hM : G.IsMatching M) (v : α) : (M ∩ E(G, v)).encard ≤ 1 := by
  rw [encard_le_one_iff_subsingleton]
  intro e he f hf
  by_contra hne
  have hdisj : Disjoint V(G, e) V(G, f) := hM.disjoint he hf hne
  simp [he, hf] at hdisj
  all_goals try { tauto }
  all_goals try { aesop }

/- Lemma: For any matching M in G, the maximum degree of any vertex in G restricted to M is at most 1. This assumes G is loopless. -/
lemma IsMatching.maxDegreeLE_one [G.Loopless] (hM : G.IsMatching M) : (G ↾ M).maxDegree ≤ 1 := by
  have : ∀ v : α, E(G ↾ M, v).encard ≤ ↑1 := by
    intro v
    have hle : (M ∩ E(G, v)).encard ≤ 1 := hM.degree_le_one v
    have hsub : (M ∩ E(G, v)) = E(G ↾ M, v) := by
      ext e
      simp
    rw [hsub] at hle
    exact hle
  apply maxDegreeLE_of_degree_le_one
  intro v hv
  have hle : (M ∩ E(G, v)).encard ≤ 1 := hM.degree_le_one v
  have hsub : (M ∩ E(G, v)) = E(G ↾ M, v) := by
    ext e
    simp
  rw [hsub] at hle
  exact_mod_cast hle

/- Lemma: If M is a matching in G, and S is a subset of V(G), then the set of edges in M whose endpoints are in S forms a matching in the induced subgraph G[S]. -/
lemma IsMatching.submatching_of_vertex_subset (hM : G.IsMatching M) (S : Set α) :
    (G[S]).IsMatching (M ∩ E(G, S)) := by
