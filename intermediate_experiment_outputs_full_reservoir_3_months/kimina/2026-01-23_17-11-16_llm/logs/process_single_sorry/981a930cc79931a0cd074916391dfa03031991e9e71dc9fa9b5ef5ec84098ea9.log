    simp [he1, he2, Set.mem_inter_iff] at hdisj ⊢
    tauto

/- Lemma: If M is a maximum matching in G, and S is a subset of V(G), then M ∩ E(G, S) is a maximum matching in G[S]. -/
lemma IsMatching.isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
