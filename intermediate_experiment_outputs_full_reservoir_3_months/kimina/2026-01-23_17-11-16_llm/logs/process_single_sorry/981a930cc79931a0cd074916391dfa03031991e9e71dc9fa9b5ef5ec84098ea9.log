      "\n  have h1 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by \n    refine' ⟨M, hM, rfl⟩\n  have h2 : M.encard ≤ (sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} : ℕ∞) := by \n    apply sSup_le\n    exact h1\n  rw [show (sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} : ℕ∞) = ν(G) by \n      simp [MatchingNumber]\n  ] at h2\n  exact h2",
