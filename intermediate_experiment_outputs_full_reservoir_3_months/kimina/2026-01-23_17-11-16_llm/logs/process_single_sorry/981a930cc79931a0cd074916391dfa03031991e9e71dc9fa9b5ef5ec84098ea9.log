/- An alternating path with respect to a matching M is a path where edges in the path are alternately in and not in M. -/
@[mk_iff]
structure IsAltPath (G : Graph α β) (hM : G.IsMatching M) (P : WList α β) : Prop
  extends G.IsPath P where
  mem_matching : P.edge.IsChain (fun e f ↦ e ∈ M ∨ f ∈ M)

/- An augmenting path with respect to a matching M is an alternating path that starts and ends with vertices not covered by M. -/
@[mk_iff]
structure IsAugPath (G : Graph α β) (hM : G.IsMatching M) (P : WList α β) : Prop
  extends G.IsAltPath hM P where
  nonempty : P.Nonempty
  first_not_in : P.first ∉ V(G, M)
  last_not_in : P.last ∉ V(G, M)

/- A vertex is inessential if it is not covered by some maximum matching. -/
def inessential (G : Graph α β) (x : α) : Prop :=
  ∃ M, G.IsMaxMatching M ∧ x ∉ V(G, M)

/- An odd component of a graph G is a connected subgraph H such that the number of vertices in H is odd and H has no even vertices. -/
structure IsOddCompOf (H G : Graph α β) extends H.IsCompOf G where
  finite : V(H).Finite
  odd : Odd V(H).encard

/- The set of all odd components of a graph G. -/
def OddComponents (G : Graph α β) : Set (Graph α β) :=
  {H | H.IsOddCompOf G}

