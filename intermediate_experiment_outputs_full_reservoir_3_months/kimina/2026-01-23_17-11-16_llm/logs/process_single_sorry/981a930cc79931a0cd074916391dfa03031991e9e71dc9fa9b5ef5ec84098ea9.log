def IsMatchable (G : Graph α β) (S : Set α) : Prop := ∃ M, G.IsMatching M ∧ V(G, M) = S

/- An alternating path P with respect to a matching M is a path such that the edges of P are alternately in M and not in M. -/
@[mk_iff]
structure IsAltPath (G : Graph α β) (hM : G.IsMatching M) (P : WList α β) : Prop
  extends G.IsPath P where
  mem_matching : P.edge.IsChain (fun e f ↦ e ∈ M ∨ f ∈ M)

/- An augmenting path P with respect to a matching M is an alternating path P such that the first and last vertices of P are not covered by M. -/
@[mk_iff]
structure IsAugPath (G : Graph α β) (hM : G.IsMatching M) (P : WList α β) : P : Prop
  extends G.IsAltPath hM P where
  nonempty : P.Nonempty
  first_not_in : P.first ∉ V(G, M)
  last_not_in : P.last ∉ V(G, M)

