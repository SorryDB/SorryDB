import Mathlib

/-!
A system of linear and quadratic and cubic equations in rational charges.
-/

structure ACCSystemLinear where
  /-- The number of linear equations. -/
  numberLinear : ℕ
  /-- The linear equations. -/
  linearACCs : Fin numberLinear → HomogeneousLinear toACCSystemCharges.Charges

structure ACCSystemQuad extends ACCSystemLinear where
  /-- The number of quadratic equations. -/
  numberQuadratic : ℕ
  /-- The quadratic equations. -/
  quadraticACCs : Fin numberQuadratic → HomogeneousQuadratic toACCSystemCharges.Charges

structure ACCSystem extends ACCSystemQuad where
  /-- The cubic equations. -/
  cubicACCs : Fin (numberQuadratic + 1) → HomogeneousCubic toACCSystemCharges.Charges

/-!
The type of all possible solutions to the linear and quadratic and cubic equations.
-/

structure Sols (χ : ACCSystem) extends χ.QuadSols where
  /-- The condition that the charge satisfies the cubic equations. -/
  cubicSol : ∀ i : Fin (χ.numberQuadratic + 1), (χ.cubicACCs i) val = 0

/-!
The type of solutions to the linear and quadratic equations.
-/

structure QuadSols (χ : ACCSystemQuad) extends χ.LinSols where
  /-- The condition that the charge satisfies the quadratic equations. -/
  quadSol : ∀ i : Fin χ.numberQuadratic, (χ.quadraticACCs i) val = 0

/-!
The type of solutions to the linear equations.
-/

structure LinSols (χ : ACCSystemLinear) where
  /-- The underlying charge. -/
  val : toACCSystemCharges.Charges
  /-- The condition that the charge satisfies the linear equations. -/
  linearSol : ∀ i : Fin χ.numberLinear, (χ.linearACCs i) val = 0

/-!

### A.1. Extensionality of solutions to the linear equations

We prove a lemma relating to the equality of two elements of `LinSols`.

-/

/-- Two solutions are equal if the underlying charges are equal. -/
@[ext]
lemma LinSols.ext {χ : ACCSystemLinear} {S T : χ.LinSols} (h : S.val = T.val) : S = T := by
  cases' S
  simp_all only

/-!

### A.2. Module structure on the solutions to the linear equations

we now give a module structure to `LinSols`.

-/

/-- An instance providing the operations and properties for `LinSols` to form an
  additive commutative monoid. -/
@[simps!]
instance linSolsAddCommMonoid (χ : ACCSystemLinear) :
    AddCommMonoid χ.LinSols where
  add S T := ⟨S.val + T.val, fun _ ↦ by simp [(χ.linearACCs _).map_add, S.linearSol _,
    T.linearSol _]⟩
  add_comm S T := LinSols.ext (χ.chargesAddCommMonoid.add_comm _ _)
  add_assoc S T L := LinSols.ext (χ.chargesAddCommMonoid.add_assoc _ _ _)
  zero := ⟨χ.chargesAddCommMonoid.zero, fun _ ↦ (χ.linearACCs _).map_zero⟩
  zero_add S := LinSols.ext (χ.chargesAddCommMonoid.zero_add _)
  add_zero S := LinSols.ext (χ.chargesAddCommMonoid.add_zero _)
  nsmul n S := ⟨n • S.val, fun _ ↦ by simp [S.linearSol _]⟩
  nsmul_zero n := by ext; simp only [zero_nsmul]; rfl
  nsmul_succ n S := LinSols.ext (χ.chargesAddCommMonoid.nsmul_succ _ _)

/-- An instance providing the operations and properties for `LinSols` to form a
  module over `ℚ`. -/
@[simps!]
instance linSolsModule (χ : ACCSystemLinear) : Module ℚ χ.LinSols where
  smul a S := ⟨a • S.val, fun _ ↦ by simp [(χ.linearACCs _).map_smul, S.linearSol _]⟩
  one_smul one_smul := LinSols.ext (χ.chargesModule.one_smul _)
  mul_smul a b S := LinSols.ext (χ.chargesModule.mul_smul _ _ _)
  smul_zero a := LinSols.ext (χ.chargesModule.smul_zero _)
  zero_smul S := LinSols.ext (χ.chargesModule.zero_smul _)
  smul_add a S T := LinSols.ext (χ.chargesModule.smul_add _ _ _)
  add_smul a b T:= LinSols.ext (χ.chargesModule.add_smul _ _ _)

instance linSolsAddCommGroup (χ : ACCSystemLinear) : AddCommGroup χ.LinSols :=
  Module.addCommMonoidToAddCommGroup ℚ

/-!

### A.3. Embedding of the solutions to the linear equations into the module of charges

We give the linear embedding of solutions to the linear ACCs `LinSols` into
the module of all `charges`.

-/

/-- The inclusion of `LinSols` into `charges`. -/
def linSolsIncl (χ : ACCSystemLinear) : χ.LinSols →ₗ[ℚ] χ.Charges where
  toFun S := S.val
  map_add' _ _ := rfl
  map_smul' _ _ := rfl

@[sorryful]
lemma linSolsIncl_injective (χ : ACCSystemLinear) :
    Function.Injective χ.linSolsIncl := by
  sorry

/-!

### B.1. Extensionality of solutions to the linear and quadratic equations

We prove a lemma relating to the equality of two elements of `QuadSols`.

-/

/-- Two `QuadSols` are equal if the underlying charges are equal. -/
@[ext]
lemma quadSols.ext {χ : ACCSystemQuad} {S T : χ.QuadSols} (h : S.val = T.val) :
    S = T := by
  have h := ACCSystemLinear.LinSols.ext h
  cases' S
  simp_all only

/-!

### B.2. The solutions to the linear and quadratic equations form a module over ℚ

The solutions to the linear and quadratic equations form a `AddCommMonoid` and a `Module` over `ℚ`.

-/

/-- An instance providing the operations and properties for `QuadSols` to form an
  additive commutative monoid. -/
@[simps!]
instance quadSolsAddCommMonoid (χ : ACCSystemQuad) :
    AddCommMonoid χ.QuadSols where
  add S T := ⟨S.val + T.val, fun _ ↦ by simp [(χ.quadraticACCs _).map_add, S.quadSol _,
    T.quadSol _]⟩
  add_comm S T := quadSols.ext (χ.chargesAddCommMonoid.add_comm _ _)
  add_assoc S T L := quadSols.ext (χ.chargesAddCommMonoid.add_assoc _ _ _)
  zero := ⟨χ.chargesAddCommMonoid.zero, fun _ ↦ (χ.quadraticACCs _).map_zero⟩
  zero_add S := quadSols.ext (χ.chargesAddCommMonoid.zero_add _)
  add_zero S := quadSols.ext (χ.chargesAddCommMonoid.add_zero _)
  nsmul n S := ⟨n • S.val, fun _ ↦ by simp [S.quadSol _]⟩
  nsmul_zero n := by ext; simp only [zero_nsmul]; rfl
  nsmul_succ n S := quadSols.ext (χ.chargesAddCommMonoid.nsmul_succ _ _)

/-- An instance providing the operations and properties for `QuadSols` to form a
  module over `ℚ`. -/
@[simps!]
instance quadSolsModule (χ : ACCSystemQuad) : Module ℚ χ.QuadSols where
  smul a S := ⟨a • S.val, fun _ ↦ by simp [(χ.quadraticACCs _).map_smul, S.quadSol _]⟩
  one_smul one_smul := quadSols.ext (χ.chargesModule.one_smul _)
  mul_smul a b S := quadSols.ext (χ.chargesModule.mul_smul _ _ _)
  smul_zero a := quadSols.ext (χ.chargesModule.smul_zero _)
  zero_smul S := quadSols.ext (χ.chargesModule.zero_smul _)
  smul_add a S T := quadSols.ext (χ.chargesModule.smul_add _ _ _)
  add_smul a b T:= quadSols.ext (χ.chargesModule.add_smul _ _ _)

/-!

### B.3. The solutions to the linear and quadratic equations form an AddCommGroup

The solutions to the linear and quadratic equations form an `AddCommGroup`.

-/

instance quadSolsAddCommGroup (χ : ACCSystemQuad) : AddCommGroup χ.QuadSols :=
  Module.addCommMonoidToAddCommGroup ℚ

/-!

### B.4. The inclusion of solutions to the linear equations into the solutions to the linear and quadratic equations

We give the inclusion of solutions to the linear equations into the solutions to the linear and quadratic equations.

-/

/-- The inclusion of linear solutions into quadratic solutions. -/
def linSolsInclQuadSols (χ : ACCSystemQuad) : χ.LinSols →[ℚ] χ.QuadSols where
  toFun S := ⟨S, by intro i; simp [S.val]⟩
  map_smul' _ _ := rfl

@[sorryful]
lemma linSolsInclQuadSols_injective (χ : ACCSystemQuad) :
    Function.Injective χ.linSolsInclQuadSols := by
  sorry

/-!

### B.5. The inclusion of solutions to the linear and quadratic equations into the module of all charges

We give the linear embedding of solutions to the linear and quadratic equations `quadSols` into the module of all `charges`.

-/

