import Mathlib

open Finset

/-!

### A. The system of equations

We consider the system of equations for the charges in the system.

-/

/-- The type of the system of equations. -/
structure ACCSystemBase {
  /-- The number of linear equations. -/
  numberLinear : ℕ
  /-- The linear equations. -/
  linearEquations : Fin numberLinear → LinearHomogeneousEquation toACCSystemCharges.Charges
  /-- The number of quadratic equations. -/
  numberQuadratic : ℕ
  /-- The quadratic equations. -/
  quadraticEquations : Fin numberQuadratic → QuadraticHomogeneousEquation toACCSystemCharges.Charges
  /-- The number of cubic equations. -/
  numberCubic : ℕ
  /-- The cubic equations. -/
  cubicEquations : Fin numberCubic → CubicHomogeneousEquation toACCSystemCharges.Charges
}

/-!

### B. The system of linear equations

We consider the system of linear equations for the charges in the system.

-/

/-- The type of the system of linear equations. -/
structure ACCSystemLinear extends ACCSystemBase {
  /-- The number of linear equations. -/
  numberLinear : ℕ
  /-- The linear equations. -/
  linearEquations : Fin numberLinear → LinearHomogeneousEquation toACCSystemCharges.Charges
}

/-!

### C. The system of linear and quadratic equations

We consider the system of linear and quadratic equations for the charges in the system.

-/

/-- The type of the system of linear and quadratic equations. -/
structure ACCSystemQuad extends ACCSystemLinear {
  /-- The number of quadratic equations. -/
  numberQuadratic : ℕ
  /-- The quadratic equations. -/
  quadraticEquations : Fin numberQuadratic → QuadraticHomogeneousEquation toACCSystemCharges.Charges
}

/-!

### D. The system of linear, quadratic and cubic equations

We consider the system of linear, quadratic and cubic equations for the charges in the system.

-/

/-- The type of the system of linear, quadratic and cubic equations. -/
structure ACCSystem extends ACCSystemQuad {
  /-- The number of cubic equations. -/
  numberCubic : ℕ
  /-- The cubic equations. -/
  cubicEquations : Fin numberCubic → CubicHomogeneousEquation toACCSystemCharges.Charges
}

/-!

## E. The solutions to the linear equations

We define the type `Sols` of solutions to the linear equations.

-/

/-- The type of solutions to the linear equations. -/
structure Sols (χ : ACCSystemBase) extends χ.Charges where
  /-- The condition that the charge satisfies the linear equations. -/
  linearSol : ∀ i : Fin χ.numberLinear, (χ.linearEquations i) val = 0

/-!

### E.1. The `IsSolution` predicate

we define a predicate on charges which is true if they correspond to a solution.

-/

/-- A charge `S` is a solution if it satisfies all linear equations. -/
def IsSolution (χ : ACCSystemBase) (S : χ.Charges) : Prop :=
  ∀ i : Fin χ.numberLinear, (χ.linearEquations i) val = 0

/-!

### E.2. The solutions to the linear equations form an additive commutative group

We prove that the solutions to the linear equations form an additive commutative group.

-/

/-- The solutions to the linear equations form an additive commutative group. -/
instance solsAddCommGroup (χ : ACCSystemBase) : AddCommGroup (χ.Sols) :=
  Subtype.valAddCommGroup (fun S => S.linearSol) (by
    intro S T hST
    simp_all only [Set.mem_setOf_eq]
    intro i
    rw [hST]
    exact (χ.linearEquations i).map_zero
  ) (by
    intro S hS T hT hST
    simp_all only [Set.mem_setOf_eq]
    intro i
    rw [hST]
    exact (χ.linearEquations i).map_add (S.val) (T.val)
  ) (by
    intro S hS
    simp_all only [Set.mem_setOf_eq]
    intro i
    exact (χ.linearEquations i).map_neg (S.val)
  ) (by
    intro S hS
    simp_all only [Set.mem_setOf_eq]
    exact ⟨S.val, fun i => by simp [hS]⟩
  ) (by
    intro S hS
    simp_all only [Set.mem_setOf_eq]
    intro i
    exact (χ.linearEquations i).map_smul (S.val) i
  )

/-!

### E.3. The solutions to the linear equations form a module over `ℚ`

We prove that the solutions to the linear equations form a module over `ℚ`.

-/

/-- The solutions to the linear equations form a module over `ℚ`. -/
instance solsModule (χ : ACCSystemBase) : Module ℚ (χ.Sols) :=
  Subtype.valModule (fun S => S.linearSol) (by
    intro S hS a
    simp_all only [Set.mem_setOf_eq]
    intro i
    rw [hS]
    simp [(χ.linearEquations i).map_smul]
  ) (by
    intro S hS a b
    simp_all only [Set.mem_setOf_eq]
    intro i
    rw [hS]
    simp [(χ.linearEquations i).map_add]
  ) (by
    intro S hS
    simp_all only [Set.mem_setOf_eq]
    intro i
    rw [hS]
    simp [(χ.linearEquations i).map_neg]
  ) (by
    intro S hS
    simp_all only [Set.mem_setOf_eq]
    exact ⟨S.val, fun i => by simp [hS]⟩
  ) (by
    intro S hS
    simp_all only [Set.mem_setOf_eq]
    intro i
    rw [hS]
    simp [(χ.linearEquations i).map_smul]
  )

/-!

### E.4. Extensionality of solutions to the linear equations

We prove a lemma relating to the equality of two elements of `Sols`.

-/

/-- Two solutions are equal if the underlying charges are equal. -/
@[ext]
lemma Sols.ext {χ : ACCSystemBase} {S T : χ.Sols} (h : S.val = T.val) : S = T := by
  cases' S
  simp_all only

