import Fad.Data.SymList

namespace SymList

def lengthSL {α : Type} : SymList α → Nat
| (xs, ys) => xs.length + ys.length

def initSL {a : Type} : (sl : SymList a) → SymList a
| ⟨xs, ys, ok⟩ =>
  if h : ys.isEmpty then
    match xs with
    | [] => nil
    | _  => nil
  else
    if h2 : ys.length = 1 then
     splitInTwoSL xs
    else SymList.mk xs ys.tail (by
      simp [← not_congr List.length_eq_zero_iff] at h
      apply And.intro
      all_goals
       intro h3
       simp [h3] at ok
       cases ys with
       | nil => contradiction
       | cons b bs => simp_all)

theorem length_lt_length_init {a : Type}
 (sl : SymList a) (h : sl ≠ nil)
 : sl.lengthSL > sl.initSL.lengthSL := by
  have ⟨xs, ys, h₁⟩ := sl
  induction xs with
  | nil =>
    cases ys with
    | nil => contradiction
    | cons b bs =>
      have h₂ := h₁.1 ; simp at h₂
      simp [lengthSL, initSL, h₂, splitInTwoSL]
      all_goals omega
  | cons b bs ih₁ =>
    induction ys with
    | nil =>
      have h₂ := h₁.2 ; simp at h₂
      simp [lengthSL, initSL, h₂, nil]
      all_goals omega
    | cons n ns ih₂ =>
      by_cases h2 : (n :: ns).isEmpty
      · -- Case where the right side is empty
        simp [h2] at *
        all_goals omega
      · -- Case where the right side is not empty
