import Mathlib


/-!
# Category Theory in Context - Section 1.1

We introduce the basic concepts of category theory.
A category consists of a collection of objects and a collection of arrows (also called morphisms) between these objects.
Each arrow has a source object and a target object.
There is a special arrow called the identity arrow for each object.
For each pair of objects, there is a composition operation for arrows.
The following definition formalizes these concepts.
-/

namespace CategoryInContext

open Category

-- definition 1.1.1
def Category (α : Type*) := {
  objects : α → Prop
  hom : ∀ (a b : α), (a → b → Prop)
  id : ∀ (a : α), hom a a (id a)
  comp : ∀ (a b c : α), hom b c (comp a b c)
  -- the following are axioms, not definitions
  -- composition is associative
  comp_assoc : ∀ (a b c d : α) (f : hom a b) (g : hom b c) (h : hom c d),
    comp (comp f g) h = comp f (comp g h)
  -- identity arrows are units for composition
  id_comp : ∀ (a b : α), comp (id a) b = id b ∧ comp a (id b) = a
}

-- example 1.1.2
example {α : Type*} (C : Category α) : (C.comp (C.id 1) 2).1 = (C.comp (C.comp (C.id 1) 2) 3).1 := by
  have h1 : C.comp (C.id 1) 2 = C.comp (C.id 1) 2 := by rfl
  have h2 : C.comp (C.comp (C.id 1) 2) 3 = C.comp (C.comp (C.id 1) 2) 3 := by rfl
  -- the goal is trivial by the associativity axiom comp_assoc
  exact C.comp_assoc 1 2 3 (id (C.comp (C.id 1) 2)) (id (C.comp (C.id 1) 2)) (id (C.comp (C.id 1) 2))

-- example 1.1.3
example {α : Type*} (C : Category α) : ∀ (a b : α), (C.comp (C.id a) b).1 = C.comp (C.id a) b := by
  intro a b
  -- the goal is true by the unit axiom id_comp
  exact (C.id_comp a b).1

-- example 1.1.4
example {α : Type*} (C : Category α) : ∀ (a b c : α), (C.comp (C.comp (C.comp a b) c) d).1 = C.comp (C.comp (C.comp a b) c) d := by
  intro a b c d
  -- the goal is true by the associativity axiom comp_assoc
  exact C.comp_assoc a b c d (C.comp a b) (C.comp b c) (C.comp c d)

-- example 1.1.5
example {α : Type*} (C : Category α) (f : C.hom a b) (g : C.hom b c) (h : C.hom c d) : C.comp (C.comp f g) h = C.comp f (C.comp g h) := by
  -- the goal is true by the associativity axiom comp_assoc
  exact C.comp_assoc a b c d f g h

-- example 1.1.6
example {α : Type*} (C : Category α) (a b : α) : C.comp (C.id a) b = C.comp (C.id a) b := by
  -- the goal is trivially true
  rfl

/-!
