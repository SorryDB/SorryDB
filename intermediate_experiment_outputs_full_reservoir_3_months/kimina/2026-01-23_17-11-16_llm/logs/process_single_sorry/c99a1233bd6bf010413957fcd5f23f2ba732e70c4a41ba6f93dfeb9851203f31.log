  comp f g := C.comp f g
  id_comp := by simp [C.id_comp]
  comp_id := by simp [C.comp_id]
  assoc := by simp [C.assoc]

theorem slice_over_equiv_slice_over' (c : α) : slice_over c = @CategoryInContext.Category.slice_over' α C c := by 
  ext x y
  simp [slice_over, slice_over']
