but nothing about its values. -/
example : f 3 = f 3 := rfl
-- unprovable, since `f` is opaque
example : f 0 = 1 := by sorry

def h (n : ℕ) : ℕ := f n + f n

/- An `unsafe` function is not sent to the kernel altogether,
and cannot be used in other definitions. -/
unsafe def g : ℕ → Empty
| n => g (n + 1)

