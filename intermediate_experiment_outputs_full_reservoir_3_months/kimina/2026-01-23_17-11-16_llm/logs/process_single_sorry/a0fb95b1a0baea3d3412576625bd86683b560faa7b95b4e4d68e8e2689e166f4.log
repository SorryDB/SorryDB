#check ∀ (f : nAry 3 ℕ ℕ), f 1 2 3 = (0 : ℕ)
#check ∀ (f : nAry 5 ℕ ℕ), f 1 2 3 4 5 = (0 : ℕ)
#check ∀ (F : (n : ℕ) → nAry n ℕ ℕ), F 3 0 0 0 = (0 : ℕ)
#check ∀ (F : (n : ℕ) → nAry n ℕ ℕ), F 5 0 0 0 0 0 = (0 : ℕ)


