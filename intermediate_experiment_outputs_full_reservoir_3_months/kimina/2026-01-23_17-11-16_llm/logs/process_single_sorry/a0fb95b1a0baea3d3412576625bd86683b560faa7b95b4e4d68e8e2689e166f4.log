def nAry : ℕ → Type → Type → Type
| 0, A, B => B
| n + 1, A, B => A → nAry n A B
-- or using a recursor:
-- fun n A B ↦ Nat.rec B (fun k nAry_k ↦ A → nAry_k) n

variable (f : nAry 1 ℕ ℕ) in
#check (f 0 : ℕ)
