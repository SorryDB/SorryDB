-/
def firstIsomorphismTheorem (f : R →+* S) (hf : Function.Surjective f) :
    R ⧸ (ker f) ≃+* S :=
  { toFun := ↑(kerLift f)
    invFun := fun x => (Ideal.Quotient.mk (ker f)) (surjInv hf x)
    right_inv := rightInverse_surjInv hf
    map_mul' := by
      intro x y
      simp [GlimpseOfLean.mem_ker, GlimpseOfLean.mem_ideal, Function.comp_apply]
      <;> try { tauto }
      <;> try { aesop }
      <;> try { native_decide }
      <;> try { tauto }
    map_add' := by
      intro x y
      simp [GlimpseOfLean.mem_ker, GlimpseOfLean.mem_ideal, Function.comp_apply]
      <;> try { tauto }
      <;> try { aesop }
      <;> try { native_decide }
      <;> try { tauto }
    left_inv := by
      intro y
      simp [GlimpseOfLean.mem_ker, GlimpseOfLean.mem_ideal, hf, Function.comp_apply]
