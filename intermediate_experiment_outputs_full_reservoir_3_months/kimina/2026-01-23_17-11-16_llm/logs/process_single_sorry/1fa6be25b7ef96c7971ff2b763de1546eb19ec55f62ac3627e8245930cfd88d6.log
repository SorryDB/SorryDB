  { toFun := (fun x => (Ideal.Quotient.mk (ker f)) (surjInv hf x))
    invFun := (fun x => (Ideal.Quotient.mk (ker f) (f x)))
    right_inv := rightInverse_surjInv hf
    map_mul' := by
      sorry
    map_add' := by
      sorry
    left_inv := by
