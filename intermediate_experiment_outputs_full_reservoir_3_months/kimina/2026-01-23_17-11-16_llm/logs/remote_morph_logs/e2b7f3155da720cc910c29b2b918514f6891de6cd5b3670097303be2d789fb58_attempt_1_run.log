  | neg m' ih => apply neg_congruence! ih;

lemma C_subst_attachmodality_mp : L Ріб ((m ¤є)РЪдsРЪД) РъЮ (m (¤єРЪдsРЪД)) := by
  apply C_of_E_mp! E_subst_attachmodality;

lemma C_subst_attachmodality_mpr : L Ріб (m (¤єРЪдsРЪД)) РъЮ ((m ¤є)РЪдsРЪД) := by
  apply C_of_E_mpr! E_subst_attachmodality;

lemma attachmodality_subst_of_subst_attachmodality : L Ріб (m ¤є)РЪдsРЪД Рєњ L Ріб m (¤єРЪдsРЪД) := mdp! $ C_subst_attachmodality_mp

lemma subst_attachmodality_of_attachmodality_subst : L Ріб m (¤єРЪдsРЪД) Рєњ L Ріб (m ¤є)РЪдsРЪД := mdp! $ C_subst_attachmodality_mpr

end Logic


namespace Modality

open Formula

variable {L : Logic РёЋ} [L.IsNormal] {mРѓЂ mРѓѓ : Modality}

class Translation (L : Logic _) (mРѓЂ mРѓѓ : Modality) where
  translate : Рѕђ a,  L Ріб (mРѓЂ (.atom a)) РъЮ (mРѓѓ (.atom a))

notation:90 MРѓЂ " Рц│[" L "] " MРѓѓ => Translation L MРѓЂ MРѓѓ

instance : IsRefl _ (┬и Рц│[L] ┬и) := РЪеby
  intro M;
  constructor;
  simp;
РЪЕ

instance : IsTrans _ (┬и Рц│[L] ┬и) where
  trans MРѓЂ MРѓѓ MРѓЃ := by
    intro TРѓЂРѓѓ TРѓѓРѓЃ;
    constructor;
    intro a;
    exact C!_trans (TРѓЂРѓѓ.translate a) (TРѓѓРѓЃ.translate a);

class Equivalence (L : Logic РёЋ) (MРѓЂ MРѓѓ : Modality) where
  equivalent : Рѕђ a, L Ріб (MРѓЂ (.atom a)) РГц (MРѓѓ (.atom a))

notation MРѓЂ " РЅЁ[" L "] " MРѓѓ => Equivalence L MРѓЂ MРѓѓ

instance [mРѓЂ РЅЁ[L] mРѓѓ] : mРѓЂ Рц│[L] mРѓѓ := РЪеfun a Рєд C_of_E_mp! $ Equivalence.equivalent aРЪЕ
instance [mРѓЂ РЅЁ[L] mРѓѓ] : mРѓѓ Рц│[L] mРѓЂ := РЪеfun a Рєд C_of_E_mpr! $ Equivalence.equivalent aРЪЕ

lemma iff_equivalence_bi_translate : (mРѓЂ РЅЁ[L] mРѓѓ) Рєћ (mРѓЂ Рц│[L] mРѓѓ) РѕД (mРѓѓ Рц│[L] mРѓЂ) := by
  constructor;
  . intro eq;
    constructor <;> infer_instance;
  . intro РЪеTРѓЂРѓѓ, TРѓѓРѓЂРЪЕ;
    constructor;
    intro a;
    apply E!_intro;
    . exact TРѓЂРѓѓ.translate a;
    . exact TРѓѓРѓЂ.translate a;

instance [mРѓЂ Рц│[L] mРѓѓ] [mРѓѓ Рц│[L] mРѓЂ] : mРѓЂ РЅЁ[L] mРѓѓ := by
  apply iff_equivalence_bi_translate.mpr;
  constructor <;> infer_instance;

instance : Std.Symm (┬и РЅЁ[L] ┬и) := РЪеby
  intro _ _ eq;
  apply iff_equivalence_bi_translate.mpr;
  constructor <;> infer_instance;
РЪЕ

instance : IsRefl _ (┬и РЅЁ[L] ┬и) := РЪеby
  intro _;
  apply iff_equivalence_bi_translate.mpr;
  constructor <;> apply _root_.refl;
РЪЕ

instance : IsTrans _ (┬и РЅЁ[L] ┬и) := РЪеby
  intro a b c;
  intro EРѓЂРѓѓ EРѓѓРѓЃ;
  have РЪеTРѓЂРѓѓ, TРѓѓРѓЂРЪЕ := iff_equivalence_bi_translate.mp EРѓЂРѓѓ;
  have РЪеTРѓѓРѓЃ, TРѓЃРѓѓРЪЕ := iff_equivalence_bi_translate.mp EРѓѓРѓЃ;
  apply iff_equivalence_bi_translate.mpr;
  constructor;
  . exact _root_.trans TРѓЂРѓѓ TРѓѓРѓЃ;
  . exact _root_.trans TРѓЃРѓѓ TРѓѓРѓЂ;
РЪЕ

instance : IsEquiv _ (┬и РЅЁ[L] ┬и) where

lemma Translation.translate_fml [mРѓЂ Рц│[L] mРѓѓ] (¤є : Formula _) : L Ріб mРѓЂ ¤є РъЮ mРѓѓ ¤є := by
  let s : Substitution РёЋ := ╬╗ a => if a = 0 then ¤є else (.atom a);
  apply C!_replace ?_ ?_ $ L.subst (Translation.translate (L := L) (mРѓЂ := mРѓЂ) (mРѓѓ := mРѓѓ) 0) (s := s);
  . simpa [s] using L.C_subst_attachmodality_mpr (s := s) (¤є := (.atom 0));
  . simpa [s] using L.C_subst_attachmodality_mp (s := s) (¤є := (.atom 0));

def translation_of_axiomInstance {a : РёЋ} (h : L Ріб (mРѓЂ a) РъЮ (mРѓѓ a)) : mРѓЂ Рц│[L] mРѓѓ := РЪеby
  intro b;
  let s : Substitution РёЋ := ╬╗ c => if c = a then b else c;
  apply C!_replace ?_ ?_ $ L.subst (s := s) h;
  . simpa [s] using L.C_subst_attachmodality_mpr (s := s) (¤є := (.atom a));
  . simpa [s] using L.C_subst_attachmodality_mp (s := s) (¤є := (.atom a));
РЪЕ

lemma translation_expand_right {L : Logic _} [L.IsNormal] (mРѓЂ mРѓѓ m) [mРѓЂ Рц│[L] mРѓѓ] : (mРѓЂ + m) Рц│[L] (mРѓѓ + m) := by
  constructor;
  intro a;
  simpa using Translation.translate_fml (L := L) (mРѓЂ := mРѓЂ) (mРѓѓ := mРѓѓ) $ m (.atom a);

lemma translation_expand_left {L : Logic _} [L.IsNormal] (mРѓЂ mРѓѓ m) [mРѓЂ Рц│[L] mРѓѓ] [m Рц│[L] (-)] : (m + mРѓЂ) Рц│[L] (mРѓѓ) := by
  constructor;
  intro a;
  have HРѓЂ : L Ріб (m + mРѓЂ) (atom a) РъЮ mРѓЂ (atom a) := by simpa using Translation.translate_fml (mРѓЂ := m) (mРѓѓ := (-)) (mРѓЂ (.atom a));
  have HРѓѓ : L Ріб mРѓЂ (atom a) РъЮ mРѓѓ (atom a) := Translation.translate_fml (.atom a);
  exact C!_trans HРѓЂ HРѓѓ;

lemma Equivalence.equivalent_fml [mРѓЂ РЅЁ[L] mРѓѓ] (¤є : Formula _) : L Ріб mРѓЂ ¤є РГц mРѓѓ ¤є := by
  apply E!_intro <;> apply Translation.translate_fml;

def equivalence_of_axiomInstance {a : РёЋ} (h : L Ріб (mРѓЂ a) РГц (mРѓѓ a)) : mРѓЂ РЅЁ[L] mРѓѓ := by
  apply iff_equivalence_bi_translate.mpr;
  constructor;
  . apply translation_of_axiomInstance (a := a);
    apply C_of_E_mp! h;
  . apply translation_of_axiomInstance (a := a);
    apply C_of_E_mpr! h;

lemma equivalence_expand_right {L : Logic _} [L.IsNormal] (mРѓЂ mРѓѓ m) [mРѓЂ РЅЁ[L] mРѓѓ] : (mРѓЂ + m) РЅЁ[L] (mРѓѓ + m) := by
  apply iff_equivalence_bi_translate.mpr;
  constructor <;> apply translation_expand_right;

lemma equivalence_expand_left {L : Logic _} [L.IsNormal] (mРѓЂ mРѓѓ m) [mРѓЂ РЅЁ[L] mРѓѓ] : (m + mРѓЂ) РЅЁ[L] (m + mРѓѓ) := by
  constructor;
  intro a;
  induction m with
  | empty    => apply Equivalence.equivalent_fml (mРѓЂ := mРѓЂ) (mРѓѓ := mРѓѓ);
  | box m ih => apply box_congruence! ih;
  | dia m ih => apply dia_congruence! ih;
  | neg m ih => apply neg_congruence! ih;

end Modality


