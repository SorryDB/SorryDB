instance : CoeFun (Modality) (╬╗ _ => Formula РёЋ Рєњ Formula РёЋ) := РЪеFormula.attachmodalityРЪЕ

#eval (РќА-) (.atom 1)

@[simp]
lemma eq_attachModality_add : mРѓЂ (mРѓѓ ¤є) = (mРѓЂ + mРѓѓ) ¤є := by
  induction mРѓЂ with
