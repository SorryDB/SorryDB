    obtain РЪеmРѓЂ, mРѓѓ, hmРѓЂ, hmРѓѓ, rflРЪЕ  := split_right_leРѓЂ hm;
    obtain РЪеmРѓЃ, mРѓё, hmРѓЃ, hmРѓё, rflРЪЕ := @ih mРѓЂ hmРѓЂ;
    use mРѓЃ, (mРѓё + mРѓѓ);
    refine РЪеby omega, ?_, ?_РЪЕ;
    . simp; omega;
    . simp [add_assoc]

