import Mathlib

open Finset

lemma split (hm : m.size = nРѓЂ + nРѓѓ) : РѕЃ mРѓЂ mРѓѓ, mРѓЂ.size = nРѓЂ РѕД mРѓѓ.size = nРѓѓ РѕД m = mРѓЂ + mРѓѓ := by
  induction nРѓѓ generalizing m with
  | zero =>
    subst hm;
    use m, -;
    refine РЪе?_, ?_, ?_РЪЕ <;> simp;
  | succ nРѓѓ ih =>
    replace hm : m.size = (nРѓЂ + nРѓѓ) + 1 := hm;
    obtain РЪеmРѓЂ, mРѓѓ, hmРѓЂ, hmРѓѓ, rflРЪЕ  := split_rightРѓЂ hm;
    obtain РЪеmРѓЃ, mРѓё, hmРѓЃ, hmРѓё, rflРЪЕ := @ih mРѓЂ hmРѓЂ;
    use mРѓЃ, (mРѓё + mРѓѓ);
    refine РЪеby omega, ?_, ?_РЪЕ;
    . simp_all;
    . simp [add_assoc]

lemma split_leftРѓѓ' (hm : m.size = n + 2) : РѕЃ m', m'.size = n РѕД
                                                    (m = РќАРќАm' Рѕе m = РќАРЌЄm' Рѕе m = РќАРѕ╝m' Рѕе
                                                     m = РЌЄРќАm' Рѕе m = РЌЄРЌЄm' Рѕе m = РЌЄРѕ╝m' Рѕе
                                                     m = Рѕ╝РќАm' Рѕе m = Рѕ╝РЌЄm' Рѕе m = Рѕ╝Рѕ╝m') := by
  obtain РЪеmРѓЂ, mРѓѓ, hmРѓЂ, hmРѓѓ, rflРЪЕ := split $ show m.size = 2 + n by omega;
  use mРѓѓ;
  constructor;
  . assumption;
  . rcases iff_size_2.mp hmРѓЂ with (rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl | rfl) <;> simp;

lemma split_left_leРѓЂ (hm : m.size РЅц nРѓѓ + 1) : РѕЃ mРѓЂ mРѓѓ, mРѓЂ.size РЅц 1 РѕД mРѓѓ.size РЅц nРѓѓ РѕД m = mРѓЂ + mРѓѓ := by
  induction nРѓѓ generalizing m with
  | zero => simp_all;
  | succ n ih =>
    rcases Nat.le_or_eq_of_le_succ hm with (h | hm);
    . obtain РЪеmРѓЂ, mРѓѓ, hmРѓЂ, hmРѓѓ, rflРЪЕ := @ih m h;
      use mРѓЂ, mРѓѓ;
      refine РЪеby omega, by omega, rflРЪЕ;
    . obtain РЪеmРѓЂ, mРѓѓ, hmРѓЂ, hmРѓѓ, rflРЪЕ := split_leftРѓЂ hm;
      use mРѓЂ, mРѓѓ;
      refine РЪеby omega, by omega, rflРЪЕ;

lemma split_right_leРѓЂ (hm : m.size РЅц n + 1) : РѕЃ mРѓЂ mРѓѓ, mРѓЂ.size РЅц n РѕД mРѓѓ.size РЅц 1 РѕД m = mРѓЂ + mРѓѓ := by
  induction n generalizing m with
