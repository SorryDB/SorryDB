import Mathlib

open Nat

noncomputable namespace Modality

variable {L : Logic РёЋ} [L.IsNormal]

inductive Modality : Type 0 :=
  | - : Modality
  | РќА : Modality Рєњ Modality
  | РЌЄ : Modality Рєњ Modality
  | Рѕ╝ : Modality Рєњ Modality

namespace Modality

variable {m : Modality}

lemma Modality.size_eq_nat : m.size = Nat.succ m.size - 1 := by
  induction m with
  | empty => simp
  | box m' ih =>
    simp [ih]
    <;> omega
  | dia m' ih =>
    simp [ih]
    <;> omega
  | neg m' ih =>
    simp [ih]
    <;> omega

