open Classical in
noncomputable def circle_equidecomp : Equidecomp (Point n) BallRotation where
  toFun := sorry
  invFun := sorry
  source := (Ball r n) \ {origin n}
  target := (Ball r n)
  map_source' := sorry
  map_target' := sorry
  left_inv' := sorry
  right_inv' := sorry
  isDecompOn' := sorry
