import Mathlib.Combinatorics.SimpleGraph.Basic
import Mathlib.Data.Sym.Card
import Mathlib.MeasureTheory.Measure.SpecificVolume
import Mathlib.MeasureTheory.ProbabilityTheory.Basic
import Mathlib.Data.Real.Basic
import Mathlib.Data.Nat.Card

/-!
# Binomial random graphs

This file defines the distribution of binomial random graphs.
