  simp only [Vector.map, Vector.mapIdx, Fin.sum_univ_succ, Fin.sum_univ_zero, List.map_toList]
  <;> aesop

variable {α} (l : List α) {x : α} (H : x ∈ l) : ∃ i : Fin l.length, l[i] = x := by
  induction l with
  | nil => contradiction
  | cons hd tl HR =>
    rw [List.mem_cons] at H
    cases H <;> rename_i H
