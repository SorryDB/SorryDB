  -- Indep_subset : ∀ s ∈ Indep, ∀ t ⊆ s, t ∈ Indep
  -- Indep_aug : ∀ s ∈ Indep, ∀ t ∈ Indep, s ∪ t ∈ Indep
  -- Indep_maximal : ∀ s ∈ Indep, ∀ t ∈ Indep, s ⊆ t → s = t
  -- Subset_ground : ∀ s ∈ Indep, s ⊆ ground
  -- ground := V(G)
  -- mem_indep_iff : ∀ v, v ∈ ground → (∃ M, G.IsMatching M ∧ v ∈ V(G, M))

def matchingMatroid (G : Graph α β) : Matroid α := G.matchingIndepMatroid.matroid

