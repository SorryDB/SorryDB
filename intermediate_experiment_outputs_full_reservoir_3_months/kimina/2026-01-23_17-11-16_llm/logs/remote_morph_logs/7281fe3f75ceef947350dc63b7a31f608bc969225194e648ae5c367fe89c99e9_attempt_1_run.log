    simp [IsAugmenting, hM, hM']
    have h1 : P.Nonempty := by
      have hM'cd : M.encard < M'.encard := hM'cd
      have hne : (M Δ M').toWList.Nonempty := by
        apply WList.nonempty_of_nonempty
        apply Set.toWList_nonempty.mpr
        apply Set.nonempty_iff_ne_empty.mpr
        intro h
        rw [h] at hM'cd
        simp at hM'cd
      exact hne
    have h2 : P.EdgeSet ∩ M = ∅ := by
      simp [P]
      ext e
      simp
      intro heM hM
      have hdisj := hM.disjoint heM hM
      have hdisj' := hM.disjoint hM heM
