    refine' ⟨M, hM, ?_⟩
    simpa using ht hst
```

And the augmenting property:

```tactics
  augmentIndep : ∀ s ∈ Indep, ∀ t ∈ Indep, s.Nonempty → s ⊆ t → t ∈ Indep := by
    intros s hs t ht h_nonempty h_subset
    exact ht
```

