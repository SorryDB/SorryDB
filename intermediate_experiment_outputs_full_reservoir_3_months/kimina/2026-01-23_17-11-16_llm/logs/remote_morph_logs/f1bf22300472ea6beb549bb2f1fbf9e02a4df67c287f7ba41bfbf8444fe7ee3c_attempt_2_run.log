import Mathlib.Data.ZMod.Basic

import Clap.Circuit
import Clap.Simulation

namespace Clap

namespace Spec

--variable (F var:Type) [Field F] [DecidableEq F]
variable {p : ŌäĢ} [Fact (Nat.Prime p)] [NeZero p]

def eq0 (e : ZMod p) : Option Unit :=
  if e = 0 then some () else none

def share (e : ZMod p) : ZMod p := e

def is_zero (e : ZMod p) : ZMod p := if e = 0 then 1 else 0

def assert_range (w : ŌäĢ) (e : ZMod p) : Option Unit := if e.val < 2^w then some () else none

--def assert_range (w:ŌäĢ) (e:ZMod p) : Option { x:ZMod p // (x.val < 2^w) } := if h:e.val < 2^w then some Ō¤©e, hŌ¤® else none

-- def assert_range (w:ŌäĢ) (e:ZMod p) : Option (ZMod p') := if e.val < 2^w then some e else none

def accept : Unit -> Unit := fun () => ()

--lemma lemma_range : ŌłĆ w (e:ZMod p), assert_range w e = some () -> e.val < 2^w

------------------

-- def to_u4 (e:ZMod p) : Option (Fin 4) :=
--   let := assert_range 2 e -- outside the do we keep the assert_range
--   do
--   let x <- assert_range 2 e
--   let res : Fin 4 := Ō¤©e.val, b

-- def to_u4 (e:ZMod p) : Option (Fin 4) := do
--   let x <- assert_range 2 e
--   let res : Fin 4 := Ō¤©x.1, by  sorry Ō¤®
--   some res

def to_u4 (e : ZMod p) : Option (ZMod p) := do
  assert_range 2 e
  some e

instance : LT (ZMod p) where
  lt := fun x y Ōå” x.val < y.val

@[simp]
def zmod_lt_def {a b : ZMod p} : a < b Ōåö a.val < b.val := by
  rfl

-- lemma to_u4_ok (h : 4 < p) : ŌłĆ e, to_u4 e < some (4 : ZMod p) := by
--   aesop (add simp [to_u4, assert_range, Fin.lt_def, Nat.mod_eq_of_lt, ZMod, ZMod.val]) (add safe cases Fin)

omit [NeZero p] in
lemma to_u4_ok (h : 4 < p) : ŌłĆ e, to_u4 e < some (4 : ZMod p) := by
  have : ZMod.val (4 : ZMod p) = 4 := by
      exact ZMod.val_natCast_of_lt h
  aesop (add simp [to_u4, assert_range])



