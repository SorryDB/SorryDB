  if e = 0 then some () else none

def share (e : ZMod p) : ZMod p := e

def is_zero (e : ZMod p) : ZMod p := if e = 0 then 1 else 0

def assert_range (w : ŌäĢ) (e : ZMod p) : Option Unit := if e.val < 2^w then some () else none

