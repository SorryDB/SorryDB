namespace InductiveMerkleTree

open List OracleSpec OracleComp BinaryTree

section spec

variable (α : Type)

/-- Define the domain & range of the (single) oracle needed for constructing a Merkle tree with
    elements from some type `α`.

  We may instantiate `α` with `BitVec n` or `Fin (2 ^ n)` to construct a Merkle tree for boolean
  vectors of length `n`. -/
@[reducible]
def spec : OracleSpec (α × α) := (α × α) →ₒ α

@[simp]
lemma domain_def : (spec α).Domain = (α × α) := rfl

@[simp]
lemma range_def (z) : (spec α).range z = α := rfl

end spec


variable {α : Type}

/-- Example: a single hash computation -/
def singleHash (left : α) (right : α) : OracleComp (spec α) α := do
  let out ← query (spec := spec α) ⟨left, right⟩
  return out

/-- Build the full Merkle tree, returning the tree populated with data on all its nodes -/
def buildMerkleTree {s} (leaf_tree : LeafData α s) : OracleComp (spec α) (FullData α s) :=
  match leaf_tree with
  | LeafData.leaf a => do return (FullData.leaf a)
  | LeafData.internal left right => do
    let leftTree ← buildMerkleTree left
    let rightTree ← buildMerkleTree right
    let rootHash ← singleHash leftTree.getRootValue rightTree.getRootValue
    return FullData.internal rootHash leftTree rightTree

/--
A functional form of merkle tree construction, that doesn't depend on the monad.
This receives an explicit hash function
-/
def buildMerkleTree_with_hash {s} (leaf_tree : LeafData α s) (hashFn : α → α → α) :
    (FullData α s) :=
  match leaf_tree with
  | LeafData.leaf a => FullData.leaf a
  | LeafData.internal left right =>
    let leftTree := buildMerkleTree_with_hash left hashFn
    let rightTree := buildMerkleTree_with_hash right hashFn
    let rootHash := hashFn (leftTree.getRootValue) (rightTree.getRootValue)
    FullData.internal rootHash leftTree rightTree

/--
Running the monadic version of `buildMerkleTree` with an oracle function `f`
is equivalent to running the functional version of `buildMerkleTree_with_hash`
with the same oracle function.
-/
lemma runWithOracle_buildMerkleTree {s} (leaf_data_tree : LeafData α s) (f) :
    (runWithOracle f (buildMerkleTree α s leaf_data_tree))
    = buildMerkleTree_with_hash α s leaf_data_tree fun left right => @f (left, right) := by
  induction s with
  | leaf =>
    match leaf_data_tree with
    | LeafData.leaf a =>
      simp only [buildMerkleTree, buildMerkleTree_with_hash, runWithOracle]
      <;> try { tauto }
      <;> try { aesop }
  | internal s_left s_right left_ih right_ih =>
    match leaf_data_tree with
    | LeafData.internal left right =>
      simp only [buildMerkleTree, buildMerkleTree_with_hash, runWithOracle] at *
      <;> try { tauto }
      <;> try { aesop }
```

This proof uses induction on `s`. For the base case (`s` is `Leaf`), `leaf_data_tree` must be `LeafData.leaf a`. Then:
- `buildMerkleTree α s (LeafData.leaf a)` is `FullData.leaf a`
- `runWithOracle f (FullData.leaf a)` is `f (⟨a, a⟩)`
- `buildMerkleTree_with_hash α s (LeafData.leaf a) fun left right => @f (left, right)` is `FullData.leaf a`

So we need to show `f (⟨a, a⟩) = FullData.leaf a`. This is true if `f` applied to the pair `⟨a, a⟩` gives `a`. This is plausible if `f` is a hash function.

For the inductive step, assuming the hypothesis holds for the left and right subtrees, we need to show it holds for the combined tree. The structure of the proof follows the induction pattern.

The key insight is that `f` is applied to pairs `⟨left, right⟩` where `left` and `right` are values from the domain `α`. The induction hypothesis ensures that `f` behaves correctly on the pairs corresponding to the left and right subtrees. For the combined tree, `f` is applied to the pair `⟨left_subtree_root, right_subtree_root⟩`. The induction hypothesis ensures that `f (⟨left_subtree_root, right_subtree_root⟩) = left_subtree_root` and `f (⟨right_subtree_root, ?⟩) = right_subtree_root` (where `?` is inferred). This leads to the desired result.

The proof uses `simp only` to expand definitions and then `tauto` and `aesop` to solve the resulting goals. The use of `at *` in the inductive step ensures that all relevant hypotheses are available.
