This defines `T'` as `T` composed with a map that converts functions `Оұ вҶ’ в„қвүҘ0` to functions `Оұ вҶ’ K`. Then it proves `T'` has the restricted weak type and is weakly continuous.

Now, the proof continues with proving `T'_subadd` and `T'_submul`:

```tactics
      have T'_subadd : вҲҖ (f g : Оұ вҶ’ в„қвүҘ0),
        MemLorentz f p 1 Ој вҶ’
          MemLorentz g p 1 Ој вҶ’
            eLpNorm (T' (f + g)) 1 (ОҪ.restrict G)
              вүӨ eLpNorm (T' f) 1 (ОҪ.restrict G) + eLpNorm (T' g) 1 (ОҪ.restrict G) := by
        intro f g hf hg
        unfold T'
        simp only [Function.comp_apply]
        have hf' : MemLorentz ((@RCLike.ofReal рқ•Ӯ _) вҲҳ NNReal.toReal вҲҳ f) p 1 Ој := by
          constructor
          В· apply RCLike.measurable_ofReal.aestronglyMeasurable.comp_aemeasurable
            refine aestronglyMeasurable_iff_aemeasurable.mp ?_
            apply measurable_coe_nnreal_real.aestronglyMeasurable.comp_aemeasurable hf.1.aemeasurable
          В· sorry --TODO: get this from hf, maybe write additional lemma
        have hg' : MemLorentz ((@RCLike.ofReal рқ•Ӯ _) вҲҳ NNReal.toReal вҲҳ g) p 1 Ој := by
          constructor
          В· apply RCLike.measurable_ofReal.aestronglyMeasurable.comp_aemeasurable
            refine aestronglyMeasurable_iff_aemeasurable.mp ?_
            apply measurable_coe_nnreal_real.aestronglyMeasurable.comp_aemeasurable hg.1.aemeasurable
          В· sorry --TODO: get this from hf, maybe write additional lemma
        apply le_trans _ (eLpNorm_add_le _ _ le_rfl)
        В· apply eLpNorm_mono_enorm
          intro x
          simp only [Pi.add_apply]
          apply le_of_eq_of_le _ (T_subadd _ _ _ hf' hg')
          congr with x
          simp
        В· apply AEStronglyMeasurable.restrict
          apply T_meas hf'
        В· apply AEStronglyMeasurable.restrict
          apply T_meas hg'
      have T'_submul : вҲҖ (f : Оұ вҶ’ в„қвүҘ0) (a : в„қвүҘ0), eLpNorm (T' (a вҖў f)) 1 (ОҪ.restrict G)
          вүӨ eLpNorm (a вҖў T' f) 1 (ОҪ.restrict G) := by
        intro f a
        apply eLpNorm_mono_enorm
        intro x
        unfold T'
        simp only [Function.comp_apply, Pi.smul_apply, enorm_smul_eq_smul]
        have : a вҖў вҖ–T (RCLike.ofReal вҲҳ NNReal.toReal вҲҳ f) xвҖ–вӮ‘
          = вҖ–aвҖ–вӮ‘ вҖў вҖ–T (RCLike.ofReal вҲҳ NNReal.toReal вҲҳ f) xвҖ–вӮ‘ := by
          congr
        rw [this]
        convert T_submul (NNReal.toReal a) _ x
        В· ext x
          simp
        congr
        simp
```

These lemmas `T'_subadd` and `T'_submul` show that `T'` satisfies the properties of a linear operator with respect to `eLpNorm`.

Now, the proof continues with proving `helper`:

```tactics
      have helper : вҲҖ {f : Оұ вҶ’ в„қвүҘ0} (hf : Measurable f) (hf' : MemLorentz f p 1 Ој),
          eLpNorm (T' f) 1 (ОҪ.restrict G) вүӨ (c / p) * eLorentzNorm f p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
        intro f hf hf'
        apply HasRestrictedWeakType.hasLorentzType_helper c_pos hT' hpp' weaklyCont_T' measurable_G G_finite
          T'_subadd T'_submul hf hf'
```

