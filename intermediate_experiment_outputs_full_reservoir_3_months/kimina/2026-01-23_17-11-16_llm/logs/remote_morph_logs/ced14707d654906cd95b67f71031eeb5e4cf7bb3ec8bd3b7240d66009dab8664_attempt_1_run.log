      set gвӮғ := fun x вҶҰ Real.toNNReal (RCLike.im (g x))
      set gвӮ„ := fun x вҶҰ Real.toNNReal (- RCLike.im (g x))
      have g_decomposition : g = (1 : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮҒ)
                                + (-1 : рқ•Ӯ) вҖў (algebraMap в„қ рқ•Ӯ вҲҳ NNReal.toReal вҲҳ gвӮӮ)
