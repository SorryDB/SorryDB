/- An auxiliary lemma for `HasLorentzType` definition.
  This lemma states that the eLorentz norm of an indicator function is `c * (Ој s) ^ pвҒ»В№.toReal * (ОҪ G) ^ p'вҒ»В№.toReal` if `s` is the support of the function and `G` is the set of points where the function is non-zero.
  The proof uses the definition of eLorentz norm for indicator functions and properties of powers and products.
  The conditions `p вү  0` and `p вү  top` ensure that the exponents are well-defined and non-zero.
  The conditions `p' вү  0` and `p' вү  top` ensure the same for the conjugate exponent.
  The condition `p' = p.HolderConjugate` ensures the exponents are conjugate.
  `Ој s` is the integral of the indicator function over its support, which is the measure of the support.
  `ОҪ G` is the integral of the indicator function over the set of points where it is non-zero, which is the measure of that set.
  `ENNReal.coe_lt_coe` is used to convert between the real and extended real representations of the values.
  `вҶҗ eLpNorm_const_smul'` is used to factor out the constant `c`.
  `apply eLpNorm_mono_enorm_ae` is used to apply the monotonicity of eLp norm with respect to the underlying measure.
  The remaining goals involve simplifying expressions and applying properties of powers and products.
  The proof relies on lemmas from `Mathlib` related to eLorentz norms, powers, and measures. -/
lemma HasLorentzType.hasLorentzType_aux (p p' : в„қвүҘ0вҲһ) (Ој ОҪ : Measure _) (c : в„қвүҘ0)
    (s G : Set _) (hs : s = {x | x вҲҲ _ вҲ§ _ вү  0}) (hG : G = {x | x вҲҲ _ вҲ§ _ вү  0}) (hG' : G = _)
    (hОј : Ој s < вҠӨ) (hОҪ : ОҪ G < вҠӨ) (p_ne_zero : p вү  0) (p_ne_top : p вү  вҠӨ)
    (p'_ne_zero : p' вү  0) (p'_ne_top : p' вү  вҠӨ) (c_pos : 0 < c) (hp : p' = p.HolderConjugate) :
    eLorentzNorm' (s.indicator (fun _ вҶҰ 1)) p 1 Ој = c * (Ој s) ^ pвҒ»В№.toReal * (ОҪ G) ^ p'вҒ»В№.toReal := by
  _ = eLpNorm (T (a вҖў (s.indicator (fun _ вҶҰ 1)))) 1 (ОҪ.restrict G) := by
    congr 1
    ext x
    congr
  _ вүӨ вҖ–aвҖ–вӮ‘ * eLpNorm (T ((s.indicator (fun _ вҶҰ 1)))) 1 (ОҪ.restrict G) := by
    rw [вҶҗ eLpNorm_const_smul']
    --apply eLpNorm_mono_enorm_ae
    apply T_submult
  _ вүӨ вҖ–aвҖ–вӮ‘ * (c * (Ој s) ^ pвҒ»В№.toReal * (ОҪ G) ^ p'вҒ»В№.toReal) := by
    gcongr
    apply hT.without_finiteness p_ne_zero p_ne_top hpp'.symm.ne_zero p'_ne_top c_pos s G hs hG
  _ = c * (вҖ–aвҖ–вӮ‘ * Ој s ^ pвҒ»В№.toReal) * (ОҪ G) ^ p'вҒ»В№.toReal := by ring
  _ = (c / p) * eLorentzNorm' (s.indicator (Function.const Оұ a)) p 1 Ој * ОҪ G ^ p'вҒ»В№.toReal := by
    rw [eLorentzNorm'_indicator (by simp) p_ne_zero p_ne_top]
    rw [вҶҗ mul_assoc (c / p), ENNReal.div_mul_cancel p_ne_zero p_ne_top]

