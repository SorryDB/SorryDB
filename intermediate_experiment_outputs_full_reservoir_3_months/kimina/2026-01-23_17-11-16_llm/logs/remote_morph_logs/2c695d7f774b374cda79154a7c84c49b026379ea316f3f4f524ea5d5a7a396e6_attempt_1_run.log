```lean
import Mathlib

open MeasureTheory ProbabilityTheory
open Real Set

noncomputable
def semicirclePDF (μ : ℝ) (v : ℝ≥0) : ℝ → ENNReal := if v = 0 then fun _ => 0 else fun x => 1 / (2 * π * v) * Real.sqrt (4 * v - (x - μ) ^ 2)

lemma semicirclePDF_zero_var (μ : ℝ) : semicirclePDF μ 0 = fun _ => 0 := by simp

lemma semicirclePDF_real (μ : ℝ) {v : ℝ≥0} (hv : v ≠ 0) : semicirclePDF μ v = fun x => 1 / (2 * π * v) * Real.sqrt (4 * v - (x - μ) ^ 2) := by simp [hv]

lemma semicirclePDF_nonneg (μ : ℝ) {v : ℝ≥0} (hv : v ≠ 0) (x : ℝ) : 0 ≤ semicirclePDF μ v x := by
