/- The probability density function of the real semicircle distribution. -/
noncomputable
def semicirclePDF μ v : ℝ → ℝ≥0 :=
  if v = 0 then
    fun _ => 0
  else
    fun x =>
      if |x - μ| < 2 * √v then
        1 / (2 * π * v) * √(4 * v - (x - μ) ^ 2)
      else
        0

lemma semicirclePDFReal_def {μ : ℝ} {v : ℝ≥0} (hv : v ≠ 0) :
    semicirclePDF μ v = fun x =>
      1 / (2 * π * v) * √(4 * v - (x - μ) ^ 2) := by
  simp [semicirclePDF, hv]

lemma semicirclePDFReal_nonneg {μ : ℝ} {v : ℝ≥0} (x : ℝ) (hv : v ≠ 0) :
    0 ≤ semicirclePDF μ v x := by
  simp [semicirclePDF, hv]

lemma semicirclePDF_zero_var {μ : ℝ} {x : ℝ} :
    semicirclePDF μ (0 : ℝ≥0) x = 0 := by
  simp [semicirclePDF]

lemma semicirclePDF_real_def {μ : ℝ} {v : ℝ≥0} (hv : v ≠ 0) :
    semicirclePDF μ v = fun x =>
