        rcases hx1 with ⟨hx11, hx12⟩
        have h2 : |x - μ| < 2 * √v := by
          have h3 : μ - 2 * √v < x := by linarith [hx11]
          have h4 : x < μ + 2 * √v := by linarith [hx12]
          have h5 : x - μ < 2 * √v := by linarith
          have h6 : - (2 * √v) < x - μ := by linarith
          apply abs_lt.mpr
          constructor <;> linarith
        have h3 : |x - μ| ≤ 2 * √v := by linarith [abs_nonneg (x - μ), h2]
        have h4 : |t * x| ≤ |t| * (|μ| + 2 * √v) := by
          have h5 : |t * x| = |t| * |x| := by
            rw [abs_mul]
          have h6 : |x| ≤ |μ| + 2 * √v := by
            have h7 : |x - μ| ≤ 2 * √v := h3
            have h8 : |x| = |(x - μ) + μ| := by ring_nf
            rw [h8]
            have h9 : |(x - μ) + μ| ≤ |x - μ| + |μ| := by
