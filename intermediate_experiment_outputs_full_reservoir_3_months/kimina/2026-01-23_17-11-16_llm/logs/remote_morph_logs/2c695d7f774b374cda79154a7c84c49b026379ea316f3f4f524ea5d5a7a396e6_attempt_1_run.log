/- Real semicircle distribution. -/
noncomputable def semicirclePDFReal (μ : ℝ) (v : ℝ≥0) (x : ℝ) : ℝ :=
  if v = 0 then
    if x = μ then 1 / (2 * π) else 0
  else
    1 / (2 * π * v) * Real.sqrt (4 * v - (x - μ) ^ 2)

