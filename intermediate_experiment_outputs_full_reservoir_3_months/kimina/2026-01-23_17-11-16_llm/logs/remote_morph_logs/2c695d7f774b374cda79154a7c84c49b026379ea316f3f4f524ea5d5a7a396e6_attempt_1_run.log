lemma memLp_id_semicircleReal (p : ℝ≥0) : MemLp id p (semicircleReal μ v) := by
  have h1 : (fun x : ℝ => |x| ^ p) IntegrableOn (semicircleReal μ v) (Set.univ : Set ℝ) := by
    have h3 : (fun x : ℝ => |x| ^ p) Continuous := by
      apply Continuous.pow
      exact continuous_abs
    have h4 : (semicircleReal μ v).support = Icc (μ - 2 * √v) (μ + 2 * √v) := by
      rw [semicircleReal]
      by_cases h' : v = 0
      · simp [h']
      · simp [v.ne_zero]
        rw [lemma_support_semicirclePDF {μ : ℝ} {v : ℝ≥0} (hv : v ≠ 0) : Function.support (semicirclePDF μ v) = Ioo (μ - 2 * √v) (μ + 2 * √v)]
        all_goals
