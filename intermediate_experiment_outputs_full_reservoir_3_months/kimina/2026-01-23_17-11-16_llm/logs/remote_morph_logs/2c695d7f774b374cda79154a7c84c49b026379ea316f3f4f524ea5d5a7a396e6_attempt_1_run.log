            linarith [h9, h7]
          rw [h5]
          linarith [h6]
        have h5 : Real.exp (t * x) ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by
          have h6 : t * x ≤ |t| * (|μ| + 2 * √v) := by
            have h7 : |t * x| ≤ |t| * (|μ| + 2 * √v) := h4
            cases' abs_cases (t * x) with h1 h1 <;> cases' abs_cases (|t| * (|μ| + 2 * √v)) with h2 h2 <;> try { nlinarith }
            all_goals try { linarith }
          have h7 : Real.exp (t * x) ≤ Real.exp (|t| * (|μ| + 2 * √v)) := by
