/-- The mean of a real semicircle distribution `semicircleReal μ v` is its mean parameter `μ`. -/
@[simp]
lemma integral_id_semicircleReal : ∫ x, x ∂semicircleReal μ v = μ := by
  by_cases h : v = 0
  · simp only [h, semicircleReal_zero_var, Measure.integral_dirac]
  · -- case v ≠ 0
    rw [semicircleReal_of_var_ne_zero μ h]
    -- convert to integral of real part
    simp [integral_semicircleReal_eq_integral_smul]
    -- integral of x * semicirclePDFReal x
    have integral_x_semicirclePDFReal : ∫ x : ℝ, x * semicirclePDFReal μ v x := by
      sorry
    exact integral_x_semicirclePDFReal

/-- The variance of a real semicircle distribution `semicircleReal μ v` is
its variance parameter `v`. -/
@[simp]
lemma variance_fun_id_semicircleReal : Var[fun x ↦ x; semicircleReal μ v] = v := by
  sorry

