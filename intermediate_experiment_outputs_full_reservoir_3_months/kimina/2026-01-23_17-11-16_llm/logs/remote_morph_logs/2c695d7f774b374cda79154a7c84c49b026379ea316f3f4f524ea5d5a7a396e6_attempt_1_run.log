    ∫ y in Set.Icc (-2 * Real.sqrt v) (2 * Real.sqrt v), (μ + y) * Real.sqrt ((2 * Real.sqrt v) ^ 2 - y ^ 2) := by
  have h11 : Set.Ioo (μ - 2 * Real.sqrt v) (μ + 2 * Real.sqrt v) = (Set.Icc (-2 * Real.sqrt v) (2 * Real.sqrt v)) + μ := by
    ext x
    simp [add_assoc]
    constructor
    · -- Assume x ∈ Ioo (μ - 2 * Real.sqrt v) (μ + 2 * Real.sqrt v)
      rintro ⟨h1, h2⟩
      have h3 : -2 * Real.sqrt v ≤ x - μ := by linarith
      have h4 : x - μ ≤ 2 * Real.sqrt v := by linarith
      have h5 : -2 * Real.sqrt v ≤ x - μ ∧ x - μ ≤ 2 * Real.sqrt v := ⟨h3, h4⟩
      simp at h5 ⊢
      <;> linarith
    · -- Assume x ∈ (Icc (-2 * Real.sqrt v) (2 * Real.sqrt v)) + μ
      rintro ⟨h1, h2⟩
      simp at h1 h2 ⊢
      constructor <;> linarith
```

So we have that `Ioo (μ - 2 * Real.sqrt v) (μ + 2 * Real.sqrt v) = (Icc (-2 * Real.sqrt v) (2 * Real.sqrt v)) + μ`. This is a translation of the interval.

