        have h1 : μ - 2 * √v < x := by
          have h1 : x ∈ (semicircleReal μ v).support := by
            simpa using (mem_support_iff_pos (semicircleReal μ v)).mpr (show 0 < (semicircleReal μ v) (show (x : ℝ) ∈ (semicircleReal μ v).support from sorry) by sorry)
          rw [support_semicirclePDF (by sorry)] at h1
          simp at h1
          linarith
        have h2 : x < μ + 2 * √v := by
          have h1 : x ∈ (semicircleReal μ v).support := by
