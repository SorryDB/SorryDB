--   input, and lifts the output -/
-- def Extractor.RoundByRound.liftContext
--     {WitMid : Fin (n + 1) → Type}
--     (lens : Extractor.Lens OuterStmtIn OuterStmtOut InnerStmtIn InnerStmtOut
--                           OuterWitIn OuterWitOut InnerWitIn InnerWitOut)
