      Prover oSpec OuterStmtIn OuterWitIn OuterStmtOut OuterWitOut pSpec := by
  unfold Prover
  refine' ⟨fun i => P.PrvState i × OuterStmtIn × OuterWitIn, fun ctxIn => ⟨P.input <| lens.proj ctxIn, ctxIn⟩, fun i ⟨prvState, stmtIn, witIn⟩ => do
    let ⟨msg, prvState'⟩ ← P.sendMessage i prvState
