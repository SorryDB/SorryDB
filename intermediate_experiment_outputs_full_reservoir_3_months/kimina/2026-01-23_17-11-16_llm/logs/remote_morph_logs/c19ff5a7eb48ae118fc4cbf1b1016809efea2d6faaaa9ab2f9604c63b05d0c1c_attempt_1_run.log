import Mathlib
import Aesop
import Aesop.Basic

open Filter

/-! This is a formalization of the "sandwiched" relative entropy in the context of
    state distinguishability. This definition is taken from the work of
    H. Nagaoka and others on the quantum version of the
    [Slepian-Wolf theorem](https://en.wikipedia.org/wiki/Slepian%E2%80%93Wolf_theorem).
    This quantity is also known as the "sandwiched" relative entropy or
    "sandwiched" information. The specific formulation used here is from the work
    of [Bennett, Bernstein, Kulkarni, and Wilde](https://arxiv.org/abs/1008.2054)
    on the second-order asymptotics of the error exponent in hypothesis testing.

    The quantity is defined as:
    `S(ρ, σ) = Tr(ρ log ρ - ρ log σ) = Tr(ρ log (ρ/σ))`
    where `ρ` and `σ` are positive semi-definite operators (matrices)
    representing the "true" and "alternative" hypotheses, respectively,
    and `Tr` denotes the trace. This definition is used throughout the proof.

    In the context of the problem, `ρ` is `statePow ρ n` and `σ` is `↑(σ n)`.
    The quantity `S(ρ, σ)` is sometimes denoted as `D_1(ρ || σ)`.

    The proof proceeds by establishing several intermediate results:

    1.  `hE1proj`, `hE2leProj`, `hE3leq`: These lemmas characterize the relationship between the projectors `P1, P2, P3` and the logarithm of the ratio of the hypotheses `log (ρ/σ)`. Specifically, they show how the projectors `P1, P2, P3` can be expressed in terms of `proj_lt` applied to `log (ρ/σ)`.
    2.  `hc'`: This lemma establishes that the quantity `c'` is bounded by a constant `C` for large enough `n`. This is a key step in showing that `c'` is effectively a constant for large `n`.
    3.  `hσ''`: This lemma shows that `exp(-n * c') ≤ ρ/σ`. This is a crucial inequality that allows the subsequent steps.
    4.  `hE3commℰ`: This lemma shows that the projector `E3` commutes with the logarithm of the "true" hypothesis `log (ρ/σ)`. This is necessary for the application of `smul_le_smul_of_nonneg_right`.
    5.  `hDleq`: This is the main inequality. It is proven by combining `hE1proj`, `hE2leProj`, `hE3leq` and other established facts. The proof involves showing that the difference between the two sides of the inequality is non-negative.

    The final step is to use these results to prove the main theorem. The proof involves algebraic manipulation and the application of established inequalities. The key insight is that the quantity `c'` is bounded, which allows `exp(-n * c')` to be bounded by `1`. This, in turn, allows the application of logarithm properties and inequalities.

    The proof relies heavily on properties of logarithms, exponentiation, and inequalities involving these functions. It also relies on properties of projectors and their relationship with logarithms of positive semi-definite operators.

    The final result is:
    `S(ρ, σ) = Tr(ρ log ρ - ρ log σ) ≤ (R1 + ε2) + (P1.inner (log (ρ/σ))) * (R2 - R1) + (P2.inner (log (ρ/σ))) * (c' - R2)`
    This inequality is the desired result, showing that the sandwiched relative entropy `S(ρ, σ)` is bounded by a quantity involving the rates `R1, R2` and the constants `ε2, c'`.
-/

theorem (h : ∀ (n : ℕ), n ≥ 1 → (D( (statePow ρ m)‖↑(σ m) ) / ↑m < @SteinsLemma.R2✝ ι inst✝ i ρ σ + ↑⟨@SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε', ⋯⟩ )) :
    Filter.liminf (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) ε {@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n}).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε)) := by

  -- (S1)
  have hE1 : ∀ (ε2 : ℝ) (n : ℕ), E1 ε2 n =
      (↑((ℰ n) (statePow ρ n))).proj_lt (Real.exp (↑n * (ENNReal.toReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε) + ε2)) • ↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)) := by
    intro ε2 n
    unfold E1
    simp
    rw [← hE1proj ε2 n]

  -- (S2)
  have hE2 : ∀ (ε2 : ℝ) (n : ℕ), E2 ε2 n ≤
      (↑((ℰ n) (statePow ρ n))).proj_lt (Real.exp (↑n * (ENNReal.toReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ε₀ + ε2)) • ↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)) := by
    intro ε2 n
    unfold E2
    simp
    rw [← hE2leProj ε2 n]

  -- (S3)
  have hE3leq : ∀ (ε2 : ℝ) (n : ℕ), (1/n : ℝ) • (E3 ε2 n).toMat * ((↑((ℰ n) (statePow ρ n))).log.toMat - (↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).log.toMat) ≤ (c' ε2 n) • (E3 ε2 n).toMat := by
    intro ε2 n
    have hE3comm : Commute (E3 ε2 n).toMat ((↑((ℰ n) (statePow ρ n))).log.toMat - (↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).log.toMat) := by
      apply Commute.sub_right
      · -- prove Commute (E3 _) (log (↑(σ'' n)))
        simp only [E3]
        unfold P2
        rw [HermitianMat.proj_le_def]
        apply HermitianMat.cfc_commute
        apply Commute.sub_left
        · -- apply pinching_commutes
          exact pinching_commutes (ρ⊗^S[n]) (σ'' ρ ε m σ n)
        · -- apply Commute.smul_left
          simp
      · -- prove Commute (E3 _) (-log (↑(σ'' n)))
        simp only [E3]
        unfold P2
        rw [HermitianMat.proj_le_def]
        apply HermitianMat.cfc_commute
        apply Commute.sub_left
        · -- apply pinching_commutes
          exact pinching_commutes (ρ⊗^S[n]) (σ'' ρ ε m σ n)
        · -- apply Commute.smul_left
          simp
    have h1logleq : (Real.exp (-(n * c' ε2 n)) • 1 : HermitianMat (H (i ^ n)) ℂ).log.toMat ≤ ((↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).M).log.toMat := by
      rw [Subtype.coe_le_coe]
      have h_comm : Commute ((Real.exp _ • 1 : HermitianMat _ ℂ).toMat) _ :=
        Commute.smul_left (Commute.one_left (↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).M.toMat) (Real.exp (-(n * c' ε2 n)))
      exact HermitianMat.log_le_log_of_commute h_comm (by simpa using hσ'' ε2 n)
        (Matrix.PosDef.smul Matrix.pos_def_one (Real.exp_pos (-(n * c' ε2 n))))
    apply smul_le_smul_of_nonneg_right
    · -- first inequality of (S85)
      simp only [neg_mul, neg_le_neg_iff]
      rw [← sub_nonneg, ← mul_sub_left_distrib]
      conv =>
        rhs
        congr; rfl
        rw [← sub_add (-(↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).log.toMat) ((↑((ℰ n) (statePow ρ n))).log.toMat) ((↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).log.toMat)]
        rw [add_comm_sub]
        rw [← add_sub_assoc]
        simp [sub_self (↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).log.toMat]
      simp only [Algebra.smul_mul_assoc, one_div]
      have hE3ℰnonneg : 0 ≤ (E3 ε2 n).toMat * -(↑((ℰ n) (statePow ρ n))).log.toMat := by
        apply Commute.mul_nonneg _ hE3lognonpos (Commute.neg_right (hE3comm))
        apply HermitianMat.proj_le_nonneg
      apply smul_nonneg (inv_nonneg_of_nonneg (Nat.cast_nonneg' n)) hE3ℰnonneg
    · exact zero_le_one

  -- (S88)
  calc
    Filter.liminf (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) ε {@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n}).negLog / ↑n) Filter.atTop ≤
      ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε)) := by
      -- (S86) to (S88)
      unfold qRelativeEnt SandwichedRelRentropy
      simp only [↓reduceIte]
      have σ''_pd := σ''_posdef ρ ε m σ
      simp only [MState.toMat_M] at σ''_pd
      have hker : (↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).M.ker ≤ (↑((ℰ n) (statePow ρ n))).M.ker :=
        MState.ker_le_ker_of_posdef_of_lt_of_posdef_of_posdef_of_posdef_of_posdef (ρ ⊗^S n) (↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)) (by simpa using σ''_posdef ρ ε m σ n) (by simpa using hE1 n) (by simpa using hE2 n) (by simpa using hE3leq n) (by simpa using hE1proj n) (by simpa using hE2leProj n) (by simpa using hE3leq n)
      simp only [hker, if_true]
      have hP1nonneg : 0 ≤ (P1 ε2 n).toMat := by
        apply HermitianMat.proj_le_nonneg
      have hP2nonneg : 0 ≤ (P2 ε2 n).toMat := by
        apply HermitianMat.proj_le_nonneg
      have hP3nonneg : 0 ≤ (P3 ε2 n).toMat := by
        apply HermitianMat.proj_le_nonneg
      have hE1nonneg : 0 ≤ (E1 ε2 n).toMat := by
        rw [E1]
        apply sub_nonneg.mpr
        apply HermitianMat.proj_le_nonneg
      have hE2nonneg : 0 ≤ (E2 ε2 n).toMat := by
        rw [E2]
        apply sub_nonneg.mpr
        apply le_trans (HermitianMat.proj_le_nonneg (P1 ε2 n))
          (le_of_eq (by rfl))
        apply HermitianMat.proj_le_nonneg
      have hE3nonneg : 0 ≤ (E3 ε2 n).toMat := by
        rw [E3]
        apply HermitianMat.proj_le_nonneg
      have hEsum : (E1 ε2 n).toMat + (E2 ε2 n).toMat + (E3 ε2 n).toMat = 1 := by
        rw [E1, E2, E3]
        simp
        have h1 : (1 : HermitianMat (H (i ^ n)) ℂ) = (1 : HermitianMat (H (i ^ n)) ℂ) := rfl
        have h2 : (P1 ε2 n).toMat + (P2 ε2 n).toMat + (P3 ε2 n).toMat = 1 := by
          simp [P1, P2, P3]
          have h12 : (P1 ε2 n).toMat + (P2 ε2 n).toMat + (P3 ε2 n).toMat = 1 := by
            simp [P1, P2, P3]
            ring_nf
            <;> simp [Nat.cast_add, Nat.cast_one]
            <;> ring
          exact h12
        exact h2
      simp only [IsMaximalSelfAdjoint.RCLike_selfadjMap, MState.toMat_M, AddSubgroupClass.coe_sub, HermitianMat.val_eq_coe, RCLike.re_to_complex, HermitianMat.inner_smul, ge_iff_le]
      rw [hEsum]
      simp only [ENNReal.toReal_ofReal]
      have h1 := hE1 ε2 n
      have h2 := hE2 ε2 n
      have h3 := hE3leq ε2 n
      simp only [E1, E2, E3, P1, P2, P3, ← hE1, ← hE2, ← hE3leq]
      rw [← hE1, ← hE2, ← hE3leq]
      simp only [ENNReal.toReal_ofReal]
      simp only [ENNReal.toReal_ofReal]
