import Mathlib

theorem example (R1 R2 : ENNReal) (ε2 : ℝ) (hε2 : 0 < ε2) (E1 E2 E3 : HermitianMat (H (i ^ n)) ℂ) (hE1 : E1 ≥ 0) (hE2 : E2 ≥ 0) (hE3 : E3 ≥ 0) (hE1E2E3 : E1 + E2 + E3 = 1) (P1 P2 : HermitianMat (H (i ^ n)) ℂ) (hP1 : P1 = E1 + E2) (hP2 : P2 = E1 + E3) (inner : (HermitianMat (H (i ^ n)) ℂ) → (HermitianMat (H (i ^ n)) ℂ) → ENNReal) (hinner1 : inner P1 = inner E1 + inner E2) (hinner2 : inner P2 = inner E1 + inner E3) (hR1 : R1 ≥ 0) (hR2 : R2 ≥ 0) (hR1leR2 : R1 ≤ R2 + ε₀) : 0 ≤ R1 - R1' * inner P1 + (ε2 - ε2 * inner P2) + inner P1 * R2 := by
  have hinner3 : inner E1 + inner E2 + inner E3 = 1 := by
    have : inner (E1 + E2 + E3) = 1 := by
      rw [show E1 + E2 + E3 = 1 by exact hE1E2E3]
      simp
    rw [inner_add, inner_add] at this
    linarith
  have hinner4 : inner P1 = 1 - inner E3 := by
    rw [hP1]
    have : inner (E1 + E2) = inner E1 + inner E2 := by simp [inner_add]
    rw [this]
    linarith [hinner3]
  have hinner5 : inner P2 = 1 - inner E2 := by
    rw [hP2]
    have : inner (E1 + E3) = inner E1 + inner E3 := by simp [inner_add]
    rw [this]
    linarith [hinner3]
  rw [hinner4, hinner5]
  have h1 : inner E1 ≥ 0 := by positivity
  have h2 : inner E2 ≥ 0 := by positivity
  have h3 : inner E3 ≥ 0 := by positivity
  have h4 : R1 ≥ 0 := hR1
  have h5 : R2 ≥ 0 := hR2
  have h6 : R1' ≥ 0 := by positivity
  positivity
```

