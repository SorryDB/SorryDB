    ↑(statePow ρ n)).proj_lt ↑(↑(σ n))

noncomputable abbrev E3 (ε2 : ℝ) (n : ℕ) :=
  (Real.exp (↑n * (ENNReal.toReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ε₀ + ε2)) •
    ↑(statePow ρ n)).proj_le ↑(↑(σ n))

noncomputable abbrev Esum (ε2 : ℝ) (n : ℕ) : HermitianMat (H (i ^ n)) ℂ :=
  E1 ε2 n + E2 ε2 n + E3 ε2 n

noncomputable abbrev P1 (ε2 : ℝ) (n : ℕ) :=
