            rw [show ((1 / n : ℝ) • (E3 ε2 n).toMat * ((ℰ n (ρ ⊗^S[n])).M.log.toMat - (σ'' ρ ε m σ n).M.log.toMat) : ℝ) = ((1 / n : ℝ) • (E3 ε2 n).toMat * ((ℰ n (ρ ⊗^S[n])).M.log.toMat : ℝ) - (1 / n : ℝ) • (E3 ε2 n).toMat * ((σ'' ρ ε m σ n).M.log.toMat : ℝ)) by ring]
            rw [show ((1 / n : ℝ) • (E3 ε2 n).toMat * (- (σ'' ρ ε m σ n).M.log.toMat) : ℝ) = - ((1 / n : ℝ) • (E3 ε2 n).toMat * ((σ'' ρ ε m σ n).M.log.toMat : ℝ)) by ring]
            have h13 : (Real.exp (-n * c' ε2 n) • 1 : HermitianMat (H (i ^ n)) ℂ).log.toMat ≤ ((σ'' ρ ε m σ n).M).log.toMat := h11
            have h14 : ((1 / n : ℝ) • (E3 ε2 n).toMat * ((ℰ n (ρ ⊗^S[n])).M.log.toMat : ℝ) : ℝ) ≤ ((1 / n : ℝ) • (E3 ε2 n).toMat * ((σ'' ρ ε m σ n).M.log.toMat : ℝ) : ℝ) := by
              have h15 : (Real.exp (-n * c' ε2 n) • 1 : HermitianMat (H (i ^ n)) ℂ).log.toMat ≤ ((σ'' ρ ε m σ n).M).log.toMat := h11
              have h16 : ((1 / n : ℝ) • (E3 ε2 n).toMat * ((Real.exp (-n * c' ε2 n) • 1 : HermitianMat (H (i ^ n)) ℂ).log.toMat : ℝ) : ℝ) ≤ ((1 / n : ℝ) • (E3 ε2 n).toMat * ((σ'' ρ ε m σ n).M.log.toMat : ℝ) : ℝ) := by
                apply mul_le_mul_of_nonneg_left h15
                positivity
              simpa using h16
            linarith
          linarith
        _ ≤ (1 / n : ℝ) • (E3 ε2 n).toMat * (- (Real.exp (-n * c' ε2 n) • (1 : HermitianMat (H (i ^ n)) ℂ)).log.toMat) := by
          simp only [mul_neg, neg_mul, neg_le_neg_iff]
          have h1logleq : (Real.exp (-(n * c' ε2 n)) • 1 : HermitianMat (H (i ^ n)) ℂ).log.toMat ≤ ((σ'' ρ ε m σ n).M).log.toMat := by
            rw [Subtype.coe_le_coe]
            have h_comm : Commute ((Real.exp (-(n * c' ε2 n)) • 1 : HermitianMat (H (i ^ n)) ℂ).toMat) ((σ'' ρ ε m σ n).M.toMat) := by
              apply Commute.smul_left (Real.exp (-(n * c' ε2 n))) (Commute.one_left (σ'' ρ ε m σ n).M.toMat)
            exact HermitianMat.log_le_log_of_commute h_comm (by simpa using hσ'' ε2 n) (Matrix.pos_def_of_smul_of_pos (Real.exp_pos (-(n * c' ε2 n))) (Matrix.pos_def_one))
          rw [← sub_nonneg] at h1logleq
          rw [← sub_nonneg, ← mul_sub_left_distrib]
          simp only [one_div, Algebra.smul_mul_assoc]
          have hE3commlog : Commute (E3 ε2 n).toMat ((σ'' ρ ε m σ n).M.log.toMat - (Real.exp (-(n * c' ε2 n)) • 1 : HermitianMat (H (i ^ n)) ℂ).log.toMat) := by
            apply Commute.sub_right
            · -- prove Commute (E3 _) (σ'' _).log
              unfold E3 P2
              rw [HermitianMat.proj_le_def]
              apply HermitianMat.cfc_commute
              apply Commute.sub_left
              · exact pinching_commutes (ρ⊗^S[n]) (σ'' ρ ε m σ n)
              · apply Commute.smul_left
                · rfl
            · -- prove `Commute (E3 _) (_ 1).log`
              conv_rhs =>
                simp only [
                  HermitianMat.log_smul (1 : HermitianMat (H (i ^ n)) ℂ) (Real.exp _),
                  Real.log_exp, neg_smul, HermitianMat.log_one,
                  add_zero, NegMemClass.coe_neg,
                  HermitianMat.val_eq_coe, selfAdjoint.val_smul,
                  selfAdjoint.val_one
                  ]
              simp only [Commute.neg_right_iff, Commute.smul_right (Commute.one_right _) _]
          apply smul_nonneg (inv_nonneg_of_nonneg (Nat.cast_nonneg' n))
          apply Commute.mul_nonneg _ h1logleq hE3commlog
          apply HermitianMat.proj_le_nonneg
        _ = (c' ε2 n) • (E3 ε2 n).toMat := by
          simp [HermitianMat.log_smul, smul_smul]
          field_simp
  -- Now, we establish h2 and h3 which are simpler inequalities.
  have h2 : (1 / n : ℝ) • (E1 ε2 n).toMat * ((ℰ n (ρ ⊗^S[n])).M.log.toMat - (σ'' ρ ε m σ n).M.log.toMat) ≤ ((R1 ρ ε).toReal + ε2) • (E1 ε2 n).toMat := by
    refine rexp_mul_smul_proj_lt_mul_sub_le_mul_sub'
      (pinching_commutes (ρ⊗^S[n]) (σ'' ρ ε m σ n)) (by positivity) ?_ (σ''_posdef ρ ε m σ n) rfl
    rw [← HermitianMat.zero_le_iff]
    apply MState.zero_le
  have h3 : (1 / n : ℝ) • (E2 ε2 n).toMat * ((ℰ n (ρ ⊗^S[n])).M.log.toMat - (σ'' ρ ε m σ n).M.log.toMat) ≤ ((R2 ρ σ).toReal + ε₀ + ε2) • (E2 ε2 n).toMat := by
    refine rexp_mul_smul_proj_lt_mul_sub_le_mul_sub'
      (pinching_commutes (ρ⊗^S[n]) (σ'' ρ ε m σ n)) (by positivity) ?_ (σ''_posdef ρ ε m σ n) rfl
    rw [← HermitianMat.zero_le_iff]
    apply MState.zero_le
  
  -- Now combine h1, h2, h3.
  calc
    (D(ℰ n (ρ ⊗^S[n])‖σ'' ρ ε m σ n) / n : ℝ≥0∞) = ENNReal.ofReal (((ℰ n (ρ ⊗^S[n])).M.inner (((R1 ρ ε).toReal + ε2) • (E1 ε2 n)))
      + ((ℰ n (ρ ⊗^S[n])).M.inner (((R2 ρ σ).toReal + ε₀ + ε2) • (E2 ε2 n)))
      + ((ℰ n (ρ ⊗^S[n])).M.inner ((c' ε2 n) • (E3 ε2 n))))
    := by
      unfold qRelativeEnt SandwichedRelRentropy
      simp only [↓reduceIte]
      have σ''_pd := σ''_posdef ρ ε m σ
      simp only [MState.toMat_M] at σ''_pd
      have hker : (σ'' ρ ε m σ n).M.ker ≤ (ℰ n (ρ ⊗^S[n])).M.ker :=
        ker_le_ker_pinching_of_posDef (ρ ⊗^S[n]) (σ'' ρ ε m σ n) (σ''_pd n)
      simp only [hker, if_true]
      have hEsum : (E1 ε2 n).toMat + (E2 ε2 n).toMat + (E3 ε2 n).toMat = 1 := by
        congrArg HermitianMat.toMat (congrFun (congrFun Esum ε2) n)
      conv =>
        enter [1, 1, 1, 1]
        rw [hEsum]
        simp only [Matrix.mul_one]
      all_goals simp only [Matrix.mul_one]
