import Mathlib

open Real Filter Topology

/- The fundamental lemma of information theory, often called the
Steins lemma or the optimal hypothesis testing lemma, was first
proven by Stein in 1956. It states that for a given significance
level α, the logarithm of the ratio of the probability of
incorrectly rejecting the null hypothesis to the probability
of correctly rejecting it (the logarithm of the false positive
rate to the true positive rate) converges to a specific value
determined by the statistical properties of the hypotheses.
This value is known as the optimal hypothesis testing rate or
the information-theoretic lower bound for the rate of
convergence in hypothesis testing. The lemma is crucial for
understanding the limits of statistical inference and has
applications in various fields including machine learning,
communication systems, and quantum information theory.
-/
theorem SteinsLemma
    (inst : UnitalFreeStateTheory ι)
    (i : ι)
    (ρ : MState (H i))
    (σ : (n : ℕ) → ↑IsFree)
    (ε : Prob)
    (hε₁ : 0 < ε)
    (hε₂ : ε < 1)
    (hR1 : @SteinsLemma.R1✝ ι inst✝ i ρ ε ≠ ⊤)
    (hR2 : @SteinsLemma.R2✝ ι inst✝ i ρ σ ≠ ⊤)
    (hε₀ : 0 < @SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε)
    (m : ℕ)
    (hm : m ≥ 1 ∧ 𝐃(statePow ρ m‖↑(σ m)) / ↑m < @SteinsLemma.R2✝ ι inst✝ i ρ σ + ↑⟨@SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε, ⋯⟩)
    (hliminf_le : Filter.liminf
        (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) ε {@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n}).negLog / ↑n)
        Filter.atTop ≤
      ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε))
    (hlimsup_le :
      ∀ (ε1 : Prob),
        0 < ↑ε1 ∧ ↑ε1 < 1 →
          Filter.limsup
              (fun n =>
                (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) (1 - ε1) {@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n}).negLog / ↑n)
              Filter.atTop ≤
            ↑(ENNReal.toNNReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ⟨@SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε, ⋯⟩))
    (hE1leq : ∀ (ε2 : ℝ) (n : ℕ), (1/n : ℝ) • (E1 ε2 n).toMat * ((ℰ n (ρ⊗^S[n])).M.log.toMat - (σ'' ρ ε m σ n).M.log.toMat) ≤ ((R1 ρ ε).toReal + ε2) • (E1 ε2 n).toMat)
    (hE2leq : ∀ (ε2 : ℝ) (n : ℕ), (1/n : ℝ) • (E2 ε2 n).toMat * ((ℰ n (ρ⊗^S[n])).M.log.toMat - (σ'' ρ ε m σ n).M.log.toMat) ≤ ((R2 ρ σ).toReal + ε₀ + ε2) • (E2 ε2 n).toMat)
    (hE3leq : ∀ (ε2 : ℝ) (n : ℕ), (1/n : ℝ) • (E3 ε2 n).toMat * ((ℰ n (ρ⊗^S[n])).M.log.toMat - (σ'' ρ ε m σ n).M.log.toMat) ≤ (c' ε2 n) • (E3 ε2 n).toMat)
    (E1 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ)
    (E2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ)
    (E3 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ)
    (Esum : E1 + E2 + E3 = 1)
    (P1 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε) + ε2)) • ↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).proj_le ↑((ℰ n) (statePow ρ n)))
    (P2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ε₀ + ε2)) • ↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).proj_le ↑((ℰ n) (statePow ρ n)))
    (hPcomm : ∀ (ε2 : ℝ) (n : ℕ), Commute ↑(P1 ε2 n) ↑(P2 ε2 n))
