noncomputable abbrev qRelativeEnt (ρ : MState (H i)) (σ : (n : ℕ) → ↑IsFree) (n : ℕ) :=
  (statePow ρ n).relativeEnt ((↑(σ n) : CPTPMap (H (i ^ n)) (H (i ^ n)) ℂ))

noncomputable abbrev SandwichedRelRentropy (ρ : MState (H i)) (σ : (n : ℕ) → ↑IsFree) (n : ℕ) :=
  (statePow ρ n).sandwichedRelativeR entropy ((↑(σ n) : CPTPMap (H (i ^ n)) (H (i ^ n)) ℂ))

noncomputable abbrev optimalHypothesisRate (ρ : MState (H i)) (σ : (n : ℕ) → ↑IsFree) (n : ℕ) :=
  (statePow ρ n).optimalHypothesisRate ((↑(σ n) : CPTPMap (H (i ^ n)) (H (i ^ n)) ℂ))

