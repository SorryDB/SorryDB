      rw [Set.mem_inter_iff] at hp
      simp [show p.asIdeal.primeHeight = 1 by simpa using hp.2]
    . rintro hp hp₁
      rw [Decidable.le_iff_eq_or_lt, ENat.lt_one_iff_eq_zero] at hp₁
      rcases hp₁ with hp₁ | hp₁
