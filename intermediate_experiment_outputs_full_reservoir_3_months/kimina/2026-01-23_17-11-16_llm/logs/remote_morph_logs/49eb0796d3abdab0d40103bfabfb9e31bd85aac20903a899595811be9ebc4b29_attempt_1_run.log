          intro h
          rw [Set.subsingleton_iff_singleton hp] at h
          simp only [h, Set.mem_singleton_iff, Set.iUnion_iUnion_eq_left, SetLike.coe_subset_coe,
            forall_eq] at h_sub h_not_le
          contradiction
