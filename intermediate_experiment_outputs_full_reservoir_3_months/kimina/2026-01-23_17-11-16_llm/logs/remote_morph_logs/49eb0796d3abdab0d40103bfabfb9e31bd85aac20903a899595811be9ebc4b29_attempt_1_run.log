        use s, ?_, by simpa using hs
        have := Ideal.disjoint_nonZeroDivisors_of_mem_minimalPrimes hp₁
        rw [Set.disjoint_right] at this
        apply this
        simpa
  . refine forall_congr' fun p => ?_
    constructor
    . rintro hp₁ hp
