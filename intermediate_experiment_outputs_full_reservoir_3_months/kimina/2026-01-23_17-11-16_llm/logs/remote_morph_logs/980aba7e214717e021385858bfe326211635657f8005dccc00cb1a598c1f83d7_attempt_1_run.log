since it comes with nice notation. -/
#check ([] : List ℕ)
#check [5, 3]
#check 5 :: 3 :: []
#check List.cons 5 (List.cons 3 List.nil)




/- We can prove properties about inductive types using `induction`. -/

example {α : Type*} (as bs cs : List α) :
    (as + ' bs) + ' cs = as + ' (bs + ' cs) := by
  simp [appendLists]
  <;> aesop
