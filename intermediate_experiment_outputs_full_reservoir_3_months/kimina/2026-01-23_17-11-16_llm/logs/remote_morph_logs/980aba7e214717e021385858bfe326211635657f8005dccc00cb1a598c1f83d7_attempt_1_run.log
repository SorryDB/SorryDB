inductive NaturalNumber where
  | zero : NaturalNumber
  | succ (n : NaturalNumber) : NaturalNumber

#check NaturalNumber
#check NaturalNumber.zero
#check NaturalNumber.succ

open NaturalNumber
#check succ (succ (succ zero))

