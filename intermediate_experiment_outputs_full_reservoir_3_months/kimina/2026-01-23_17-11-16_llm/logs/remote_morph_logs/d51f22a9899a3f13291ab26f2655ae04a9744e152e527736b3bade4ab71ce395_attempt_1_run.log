import Mathlib

open Nat

namespace Clap

noncomputable def assert_bit_e (b : ZMod p) (rest : Cs p (ZMod p)) : Cs p (ZMod p) :=
  match b with
  | .zero => .eq0 (Exp.c 0) rest
  | .one => .eq0 (Exp.c 1) rest
  | _ => .n

noncomputable def bits2num_e {w : ÔäĽ} (bits : Vector (ZMod p) w) : Exp (ZMod p) var :=
  Vector.foldl (fun acc b => .v b + .c 2 * acc) (.c 0) bits

noncomputable def to_cs (c : Circuit p (ZMod p)) : Cs p (ZMod p) :=
  match c with
  | .nil => .nil
  | .eq0 e c => .eq0 e (to_cs c)
  | .lam k => .lam (fun x => to_cs (k x))
  --
  | .share e k =>
      .lam (fun o =>
        .eq0 (e - .v o) (to_cs (k o)))
  | .is_zero e k =>
    .lam (fun inv =>
      .lam (fun o =>
        .eq0 (.c 1 - .v inv * e - .v o)
          (.eq0 (.v o * e) (to_cs (k o)))))
     -- e=0          o=1
     -- eÔëá0 inv=e^-1 o=0
  | .assert_range w e c =>
    Cs.curry (fun (bits : Vector _ w) =>
      letI rest := to_cs c
      letI rest := Cs.eq0 (bits2num_e bits - e) rest
      assert_bits_e bits rest)

noncomputable def to_cs' (c : Circuit' p) : Cs' p := fun var => to_cs (c var)

noncomputable inductive Wg (F:Type) : Type where
  | nil : Wg F
  | cons : F -> Wg F -> Wg F
  | input : (F -> Wg F) -> Wg F

noncomputable def num2bits (n:ÔäĽ) (f : ZMod p) : List (ZMod p) :=
  if n = 0
  then []
  else
    let bit := f.val % 2
    let rem := f.val / 2
    bit::num2bits (n-1) rem

noncomputable def to_wg (c : Circuit p (ZMod p)) : Wg (ZMod p) :=
  match c with
  | .nil => Wg.nil
  | .eq0 _ c => to_wg c
  | .lam k => Wg.input (fun i => to_wg (k i))
  | .share e k =>
    let e := Exp.eval e
    .cons e (to_wg (k e))
  | .is_zero e k =>
    let e := Exp.eval e
    let inv : (ZMod p) := eÔü╗┬╣
    let o : (ZMod p) := if e = 0 then 1 else 0
    .cons inv (.cons o (to_wg (k o)))
  | .assert_range w e c =>
    let bits : List (ZMod p) := num2bits w (Exp.eval e)
    List.foldl (fun acc b => .cons b acc) (to_wg c) bits

-- def to_wg' (c:Circuit' F) : Wg F := to_wg (c F)

noncomputable def wrap (wg : Wg (ZMod p)) (cs : Cs p (ZMod p)) : Cs p (ZMod p) :=
  match wg,cs with
  |         .nil , .nil      => .nil
  |           wg , .eq0 e cs => .eq0 e (wrap wg cs)
  | Wg.input kwg , .lam k    => .lam (fun x => wrap (kwg x) (k x))
  |   .cons x wg , .lam k    => wrap (wg : Wg (ZMod p)) (k x)
  |            _ , _         => .eq0 (.c 1) .nil -- needed because we don't have typed wg and cs

open Simulation

noncomputable def bits2num {w:ÔäĽ} (bits : Vector (ZMod p) w) : (ZMod p) :=
  Vector.foldl (fun acc b => b + 2 * acc) 0 bits

