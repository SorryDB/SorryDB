lemma rw_bisim_uncurry : ÔłÇ (w : ÔäĽ) (d : denotation (ZMod p)) (k : Vector (ZMod p) w -> Cs p (ZMod p)),
 (ÔłÇ args : Vector (ZMod p) w, rw_bisim d (k args).eval) ->
 rw_bisim d (Cs.curry k).eval := by
  intro w
  induction w
  case _ =>
    intros d k h
    simp [Cs.curry]
    apply h
  case _ ih =>
    intros d k h
    simp [Cs.curry]
    constructor
    intro x
    apply ih
    intro args
    apply h

