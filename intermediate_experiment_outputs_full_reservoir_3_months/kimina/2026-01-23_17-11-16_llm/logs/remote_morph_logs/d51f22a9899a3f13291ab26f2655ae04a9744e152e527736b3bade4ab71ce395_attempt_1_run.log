import Mathlib
import Mathlib.Tactic.SimpRw

open Nat

lemma bits2num (w : ÔäĽ) (f : ZMod p) : List (ZMod p) :=
  if f.val = 0 then
    []
  else
    let bit := f.val % 2
    let rem := f.val / 2
    bit :: bits2num (w - 1) rem

lemma to_cs (c : Circuit p (ZMod p)) : Cs p (ZMod p) :=
  match c with
  | .nil => .nil
  | .eq0 e c => .eq0 e (to_cs c)
