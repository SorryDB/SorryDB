import Mathlib
import Clap

open Clap

theorem soundness : ÔłÇ (c : Circuit p (ZMod p)),
  rw_bisim (Circuit.eval c) (Cs.eval (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval, to_cs]
    constructor
  | lam k h =>
    simp [Circuit.eval, to_cs]
    constructor
    exact h
  | eq0 e c h =>
    simp [Circuit.eval, Cs.eval, to_cs]
    split
    apply h
    constructor
