theorem soundness : ÔłÇ (c : Circuit p (ZMod p)),
  rw_bisim (Circuit.eval c) (Cs.eval (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval, to_cs]
    <;> try { tauto }
  | lam k h =>
    simp [Circuit.eval, to_cs, Function.comp]
    <;> try { tauto }
  | eq0 e c h =>
    simp [Circuit.eval, to_cs, Function.comp]
    <;> try { tauto }
  | share e c h =>
    simp [Circuit.eval, to_cs, Function.comp]
    <;> try { tauto }
  | is_zero e c h =>
    simp [Circuit.eval, to_cs, Function.comp]
    <;> try { tauto }
  | assert_range w e c h =>
    simp [Circuit.eval, to_cs]
