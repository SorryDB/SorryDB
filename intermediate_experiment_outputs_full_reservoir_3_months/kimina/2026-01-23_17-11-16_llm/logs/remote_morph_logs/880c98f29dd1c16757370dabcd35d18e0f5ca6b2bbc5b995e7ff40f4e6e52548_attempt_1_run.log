      have h6 : |(↑j + 1) * (b - a)| = (↑j + 1) * (b - a) := by
        apply abs_of_nonneg
        nlinarith
      rw [h6]
      have h7 : (↑j + 1) * (b - a) / (↑n * ↑n) < δ := by
        have h8 : 2 * (b - a) / ↑n < δ := hfine
        have h9 : (↑j + 1) ≤ (↑n : ℝ) := by
          have : j < n := by
            simp at *
            all_goals linarith
          have : (↑j : ℝ) < (↑n : ℝ) := by
            exact_mod_cast this
