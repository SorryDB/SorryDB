      (b - a) / ↑(n * k) * ∑ j ∈ Finset.range n, ∑ k_1 ∈ Finset.range k, f (a + (↑(j + k_1 * n) + 1) * (b - a) / ↑(n * k)) -
      (b - a) / ↑n * ∑ i ∈ Finset.range n, f (a + (↑i + 1) * (b - a) / ↑n) := by
    simp [RiemannSum, Finset.sum_range_succ]
    <;> ring_nf <;> simp [mul_add, add_mul]
    <;> ring
