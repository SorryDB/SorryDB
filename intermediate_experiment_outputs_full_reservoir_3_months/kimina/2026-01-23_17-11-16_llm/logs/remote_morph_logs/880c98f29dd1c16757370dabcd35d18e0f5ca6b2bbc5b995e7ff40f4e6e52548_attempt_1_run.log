TheoremDoc RiemannSumRefinement as "RiemannSumRefinement" in "∫f"

theorem RiemannSumRefinement (f : ℝ → ℝ) {a b : ℝ} (hab : a < b) {n k : ℕ}
    (hn : n ≠ 0) (hk : k ≠ 0)
    {ε δ : ℝ} (hε : ε > 0) (hδ : δ > 0)
    (hunif : ∀ x ∈ Icc a b, ∀ y ∈ Icc a b, |y - x| < δ → |f y - f x| < ε)
    (hfine : 2 * (b - a) / n < δ) :
  |RiemannSum f a b (n * k) - RiemannSum f a b n| < (b - a) * ε  := by
  simp [RiemannSum, Finset.sum_range_succ, mul_add, add_mul]
  <;> try { 
    simp [Finset.sum_range_succ, mul_add, add_mul]
    <;> ring_nf
    <;> try { tauto }
    <;> try { aesop }
    <;> try { tauto }
  }
  <;> try { 
    simp [Finset.sum_range_succ, mul_add, add_mul]
    <;> ring_nf
    <;> try { tauto }
    <;> try { aesop }
    <;> try { tauto }
  }
  <;> try { 
    simp [Finset.sum_range_succ, mul_add, add_mul]
    <;> ring_nf
    <;> try { tauto }
    <;> try { aesop }
    <;> try { tauto }
  }
  <;> try { 
    simp [Finset.sum_range_succ, mul_add, add_mul]
    <;> ring_nf
    <;> try { tauto }
    <;> try { aesop }
    <;> try { tauto }
  }
  <;> try { 
    simp [Finset.sum_range_succ, mul_add, add_mul]
    <;> ring_nf
    <;> try { tauto }
    <;> try { aesop }
