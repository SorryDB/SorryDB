  -- Now we need to bound this difference.
  -- The key insight is that the terms in the sum are close.
  -- Let's use the uniform continuity.
  have h2 : ∀ j : ℕ, |(↑(j + k * n) + 1) * (b - a) / ↑(n * k) - (↑j + 1) * (b - a) / ↑n| < δ := by
    intro j
    -- Let's compute the difference.
    have h3 : (↑(j + k * n) + 1) * (b - a) / ↑(n * k) - (↑j + 1) * (b - a) / ↑n =
        (↑k * (↑j + 1) * (b - a) / (↑n * ↑k * ↑n)) := by
      -- This is a calculation.
