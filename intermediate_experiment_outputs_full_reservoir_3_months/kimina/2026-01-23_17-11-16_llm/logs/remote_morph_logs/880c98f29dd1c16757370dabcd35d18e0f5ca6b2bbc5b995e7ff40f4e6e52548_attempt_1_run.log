        have h10 : (↑j + 1) * (b - a) / (↑n * ↑n) ≤ (↑n : ℝ) * (b - a) / (↑n * ↑n) := by
          apply (div_le_div_right (by positivity)).mpr
          nlinarith
        have h11 : (↑n : ℝ) * (b - a) / (↑n * ↑n) = (b - a) / ↑n := by
          field_simp
          <;> ring
        have h12 : (b - a) / ↑n < δ := by linarith
        linarith
      linarith
    exact h4
  have h3 : |(b - a) / ↑(n * k) * ∑ j ∈ Finset.range n, ∑ k_1 ∈ Finset.range k, f (a + (↑(j + k_1 * n) + 1) * (b - a) / ↑(n * k)) - (b - a) / ↑n * ∑ i ∈ Finset.range n, f (a + (↑i + 1) * (b - a) / ↑n)| < (b - a) * ε := by
    have h4 : (b - a) / ↑(n * k) * ∑ j ∈ Finset.range n, ∑ k_1 ∈ Finset.range k, f (a + (↑(j + k_1 * n) + 1) * (b - a) / ↑(n * k)) - (b - a) / ↑n * ∑ i ∈ Finset.range n, f (a + (↑i + 1) * (b - a) / ↑n) =
        (b - a) / ↑n * ∑ j ∈ Finset.range n, (f (a + (↑(j + k * n) + 1) * (b - a) / ↑(n * k)) - f (a + (↑j + 1) * (b - a) / ↑n)) := by
      simp [Finset.sum_range_succ, mul_add, add_mul]
      <;> ring_nf <;> simp [mul_add, add_mul]
