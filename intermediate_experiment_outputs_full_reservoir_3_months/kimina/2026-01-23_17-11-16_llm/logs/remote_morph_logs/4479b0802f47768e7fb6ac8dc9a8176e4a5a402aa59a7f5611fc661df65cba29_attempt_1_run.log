section mapCLM

def mapCLM [IsTopologicalAddGroup F] [ContinuousSMul РёЮ F] [IsTopologicalAddGroup F']
    [ContinuousSMul РёЮ F'] (A : F РєњL[РёЮ] F') : ­ЮЊЊ'^{n}(╬Е, F) РєњL[РёЮ] ­ЮЊЊ'^{n}(╬Е, F') :=
  A.postcomp_uniformConvergenceCLM _

@[simp]
lemma mapCLM_apply [IsTopologicalAddGroup F] [ContinuousSMul РёЮ F] [IsTopologicalAddGroup F']
    [ContinuousSMul РёЮ F'] {A : F РєњL[РёЮ] F'} {T : ­ЮЊЊ'^{n}(╬Е, F)} {f : ­ЮЊЊ^{n}(╬Е, РёЮ)} :
    mapCLM A T f = A (T f) := rfl

