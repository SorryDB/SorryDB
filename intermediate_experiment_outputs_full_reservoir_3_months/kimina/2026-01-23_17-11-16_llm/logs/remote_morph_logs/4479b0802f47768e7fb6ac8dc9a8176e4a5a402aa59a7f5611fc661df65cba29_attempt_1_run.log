/-!
# Distributions

Let `E` be a real **finite-dimensional normed space**, `╬Е` an open subset of `E`,
and `F` a real **locally convex topological vector space**.

An **`F`-valued distribution on `╬Е`** is a continuous `РёЮ`-linear map `T : ­ЮЊЊ(╬Е, РёЮ) РєњL[РёЮ] F`.
-/

abbrev Distribution := ­ЮЊЊ^{n}(╬Е, РёЮ) РєњL_c[РёЮ] F

@[simp]
lemma apply_ofFunWithOrder {f : E Рєњ F} {╬╝ : Measure E} (hf : LocallyIntegrableOn f ╬Е ╬╝)
    {¤є : TestFunction ╬Е РёЮ Ріц} :
    (ofFunWithOrder ╬Е n f ╬╝) ¤є = РѕФ x, ¤є x Рђб f x Рѕѓ╬╝ := by
  simp [ofFunWithOrder, TestFunction.integralAgainstBilinCLM_apply hf]

@[simp]
lemma apply_ofFun {f : E Рєњ F} {╬╝ : Measure E} (hf : LocallyIntegrableOn f ╬Е ╬╝)
    {¤є : TestFunction ╬Е РёЮ} :
    (ofFun ╬Е f ╬╝) ¤є = РѕФ x, ¤є x Рђб f x Рѕѓ╬╝ := by
  simp [ofFun, apply_ofFunWithOrder hf]

lemma ofFunWithOrder_of_not_locallyIntegrable {f : E Рєњ F} {╬╝ : Measure E}
    (hf : ┬гLocallyIntegrableOn f ╬Е ╬╝) : ofFunWithOrder ╬Е n f ╬╝ = 0 := by
  ext ¤є
  simp_rw [ofFunWithOrder, TestFunction.integralAgainstBilinCLM,
    TestFunction.integralAgainstBilinLM, hf]
  dsimp
  congr

lemma ofFun_of_not_locallyIntegrable {f : E Рєњ F} {╬╝ : Measure E} (hf : ┬гLocallyIntegrableOn f ╬Е ╬╝) :
    ofFun ╬Е f ╬╝ = 0 := by
  ext ¤є
  simp [ofFun, ofFunWithOrder_of_not_locallyIntegrable hf]

lemma ofFunWithOrder_ae_congr {f f' : E Рєњ F} {╬╝ : Measure E} (h : f =рхљ[╬╝.restrict ╬Е] f') :
  ofFunWithOrder ╬Е n f ╬╝ = ofFunWithOrder ╬Е n f' ╬╝ := sorry

lemma ofFun_ae_congr {f f' : E Рєњ F} {╬╝ : Measure E} (h : f =рхљ[╬╝.restrict ╬Е] f') :
    ofFun ╬Е f ╬╝ = ofFun ╬Е f' ╬╝ := ofFunWithOrder_ae_congr h

@[simp]
lemma ofFunWithOrder_zero {╬╝ : Measure E} : ofFunWithOrder ╬Е n (0 : E Рєњ F) ╬╝ = 0 := by
  ext ¤є
  simp [ofFunWithOrder, TestFunction.integralAgainstBilinCLM, TestFunction.integralAgainstBilinLM]

@[simp]
lemma ofFun_zero {╬╝ : Measure E} : ofFun ╬Е (0 : E Рєњ F) ╬╝ = 0 := by
  ext ¤є
  simp [ofFun]

lemma mapCLM [IsTopologicalAddGroup F] [ContinuousSMul РёЮ F] [IsTopologicalAddGroup F']
    [ContinuousSMul РёЮ F'] (A : F РєњL[РёЮ] F') : ­ЮЊЊ'^{n}(╬Е, F) РєњL[РёЮ] ­ЮЊЊ'^{n}(╬Е, F') :=
  A.postcomp_uniformConvergenceCLM _

@[simp]
lemma mapCLM_apply [IsTopologicalAddGroup F] [ContinuousSMul РёЮ F] [IsTopologicalAddGroup F']
    [ContinuousSMul РёЮ F'] {A : F РєњL[РёЮ] F'} {T : ­ЮЊЊ'^{n}(╬Е, F)} {f : ­ЮЊЊ^{n}(╬Е, РёЮ)} :
    mapCLM A T f = A (T f) := rfl

end Distributions

