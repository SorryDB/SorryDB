-- TODO: find a better name!
lemma integrable_smul {f : E Рєњ F} {╬╝ : Measure E} (¤є : TestFunction ╬Е РёЮ Ріц) (hf : LocallyIntegrableOn f (РєЉ╬Е) ╬╝) :
