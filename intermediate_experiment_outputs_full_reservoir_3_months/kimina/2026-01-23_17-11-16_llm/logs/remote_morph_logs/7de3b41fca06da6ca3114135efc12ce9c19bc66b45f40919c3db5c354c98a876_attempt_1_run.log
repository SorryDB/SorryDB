  rw [h2] at h1
  have h3 : ((Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat).symm).toAlgHom (Algebra.TensorProduct.includeRight q₁) = ((Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat).symm).toAlgHom (Algebra.TensorProduct.includeRight q₂) := by
