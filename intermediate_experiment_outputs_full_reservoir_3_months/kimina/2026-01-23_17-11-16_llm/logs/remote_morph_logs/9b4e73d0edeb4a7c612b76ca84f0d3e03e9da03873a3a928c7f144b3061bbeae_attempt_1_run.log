        _ ≤ 2 ^ 12 * 𝓛 α * (2 * 𝓛 α) * (2 ^ 3 * 𝓛 (ε * α)) ^ 2 / ε ^ 2 := by
          gcongr
          · exact le_add_of_nonneg_left zero_le_one
          · exact Int.ceil_le_two_mul <| two_inv_lt_one.le.trans <| one_le_curlog (by positivity)
