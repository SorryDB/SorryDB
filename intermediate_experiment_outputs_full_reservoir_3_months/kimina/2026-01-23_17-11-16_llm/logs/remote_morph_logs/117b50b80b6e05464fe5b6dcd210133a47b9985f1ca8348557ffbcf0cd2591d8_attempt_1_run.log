partial def f : ℕ → ℕ
| 0 => 1
| n => f (n + 1)

#check f
#eval f 0
-- #eval f 1 -- infinite loop

/- The kernel only "knows" that `f` has type `ℕ → ℕ`,
but nothing about its values. -/
example : f 3 = f 3 := rfl
-- unprovable, since `f` is opaque
example : f 0 = 1 := by 
  -- The goal is f 0 = 1
  -- From the definition of f, when n = 0, f 0 is defined as 1
  -- Therefore, f 0 = 1 is true by definition
  -- In Lean, this can be proven using the simp tactic
  -- simp will unfold the definition of f at 0
  simp [f]
```
