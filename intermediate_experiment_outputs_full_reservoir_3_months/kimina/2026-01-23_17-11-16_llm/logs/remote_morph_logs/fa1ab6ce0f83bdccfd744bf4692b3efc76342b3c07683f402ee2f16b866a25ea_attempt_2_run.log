-- using exercise notation, instead of mathlib style
instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where

  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := sorry
  comp_id := sorry
  assoc := sorry

-- Define the domain category for the comma category functors
noncomputable instance Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (D × E × (D →* E) // (fun ⟨d, e, h⟩ => ⟨id d, id e, h⟩)) where
  Hom := fun ⟨d₁, e₁, h₁⟩ ⟨d₂, e₂, h₂⟩ =>
    {hk : (D →* E) // h₁ ≫ hk = h₂}
  id := fun ⟨d, e, h⟩ => ⟨id d, id e, id h⟩
  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨f.1, f.2, f.3 ≫ f'.3⟩
  id_comp := sorry
  comp_id := sorry
  assoc := sorry

-- Define the first projection functor from the comma category to D
def Comma_category_proj1 {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    @Functor (D × E × (D →* E) // (fun ⟨d, e, h⟩ => ⟨id d, id e, h⟩)) D where
  F := fun ⟨d, e, h⟩ => d
  homF := fun ⟨⟨d₁, e₁, h₁⟩, ⟨d₂, e₂, h₂⟩⟩ => ⟨id d₁, id d₂⟩
  map_id X := by simp
  map_comp {X Y Z} f g := by simp

-- Define the second projection functor from the comma category to E
def Comma_category_proj2 {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    @Functor (D × E × (D →* E) // (fun ⟨d, e, h⟩ => ⟨id d, id e, h⟩)) E where
  F := fun ⟨d, e, h⟩ => e
  homF := fun ⟨⟨d₁, e₁, h₁⟩, ⟨d₂, e₂, h₂⟩⟩ => ⟨id e₁, id e₂⟩
  map_id X := by simp
  map_comp {X Y Z} f g := by simp

-- Define the third projection functor from the comma category to (D →* E)
def Comma_category_proj3 {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    @Functor (D × E × (D →* E) // (fun ⟨d, e, h⟩ => ⟨id d, id e, h⟩)) (D →* E) where
  F := fun ⟨d, e, h⟩ => h
  homF := fun ⟨⟨d₁, e₁, h₁⟩, ⟨d₂, e₂, h₂⟩⟩ => id h₁
  map_id X := by simp
  map_comp {X Y Z} f g := by simp

-- Define the first projection functor from the comma category to C via F
def Comma_category_proj1F {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    @Functor (D × E × (D →* E) // (fun ⟨d, e, h⟩ => ⟨id d, id e, h⟩)) C where
  F := fun ⟨d, e, h⟩ => F.F d
  homF := fun ⟨⟨d₁, e₁, h₁⟩, ⟨d₂, e₂, h₂⟩⟩ => F.homF id
