-- exercise 1.3.vi
-- using exercise notation, instead of mathlib style
instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where

  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := sorry
  comp_id := sorry
  assoc := sorry

def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) D where
  F := fun ⟨X, _, _⟩ => X
  homF := fun ⟨hk, _⟩ => hk.1
  map_id X := by
    simp
```
The proof is straightforward. We need to show that for any `x` in the domain of `Comma_category`, `id x` is the same as `id (Comma_category x)`. Since `Comma_category x` is defined as `⟨x.1, x.2.1⟩`, applying `id` to `x` gives `⟨id x.1, id x.2.1⟩`. Applying `id` to `Comma_category x` gives `id ⟨x.1, x.2.1⟩` which is `⟨id x.1, id x.2.1⟩`. These are the same.

So we can complete the proof with:
```tactics
import Mathlib

open Set

noncomputable instance CategoryInContext : Category (Set (Set * × Set * × Set *))
  where
    Hom := fun (X Y : Set (Set * × Set * × Set *)) => Set.Ico X Y
    id := fun X => Set.Ico X X
    comp := fun f g => Set.Ico (Set.Ico f.1 g.1) (Set.Ico f.2 g.2)
    id_comp := by intro a b; apply Set.Ico_subset_Ico; simp
    comp_id := by intro a b; apply Set.Ico_subset_Ico; simp
    assoc := by intro a b c; apply Set.Ico_subset_Ico; simp

