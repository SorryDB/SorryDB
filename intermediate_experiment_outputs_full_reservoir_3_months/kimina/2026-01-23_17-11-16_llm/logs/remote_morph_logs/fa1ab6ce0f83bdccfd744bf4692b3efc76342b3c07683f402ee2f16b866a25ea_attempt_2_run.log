-- definition 1.3.12
def Comma_category (D C E : Type*)
    [CD : Category D] [CE : Category E] [CC : Category C]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Hom (F.F d) (G.F e)) where
  Hom := fun ⟨d, e, h⟩ ⟨d', e', h'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ h' = h ≫ (G.homF hk.2)}
  id := fun ⟨d, e, h⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩
  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [CD.assoc, CE.assoc]
    rw [hf']
    rw [← CD.assoc]
    rw [hf]
    rw [← CE.assoc]
  ⟩
  id_comp := by
    simp only [id, Set.mem_setOf_eq]
    all_goals try { simp_all [CD.id_comp, CE.id_comp] }
    all_goals try { tauto }
  comp_id := by
    simp only [comp, Set.mem_setOf_eq]
    all_goals try { simp_all [CD.comp_id, CE.comp_id] }
    all_goals try { tauto }
  assoc := by
    simp only [comp, Set.mem_setOf_eq]
    all_goals try { simp_all [CD.assoc, CE.assoc] }
    all_goals try { tauto }
