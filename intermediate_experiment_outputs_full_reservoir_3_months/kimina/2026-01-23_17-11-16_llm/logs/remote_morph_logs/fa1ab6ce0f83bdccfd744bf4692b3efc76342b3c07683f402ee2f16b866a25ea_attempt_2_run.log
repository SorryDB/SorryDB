  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := sorry
  comp_id := sorry
  assoc := sorry

