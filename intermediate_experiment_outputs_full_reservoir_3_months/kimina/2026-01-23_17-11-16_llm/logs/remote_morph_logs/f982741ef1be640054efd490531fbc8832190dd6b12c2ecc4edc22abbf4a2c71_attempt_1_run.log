import Mathlib
open Real

/- The following lemma establishes that for any sequence of states `ρ_n` that converges to a state `ρ` and any sequence of positive real numbers `ε_n` that converges to a positive real number `ε`, the following inequality holds asymptotically:
   `D(ρ_n, σ_n'') / n ≤ R_1(ρ, ε) + ε_0 + ε_n + o(1)` as `n → ∞`, where `σ_n''` is a specific sequence of states defined in terms of `ρ`, `σ`, `ε`, and `n`, and `R_1`, `R_2`, `ε_0` are constants from the Steins Lemma context. -/
lemma hlimsup_le : ∀ (ε1 : Prob),
    0 < ↑ε1 ∧ ↑ε1 < 1 →
      Filter.limsup
          (fun n =>
            (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) (1 - ε1) {@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n}).negLog / ↑n)
          Filter.atTop ≤
        ↑(ENNReal.toNNReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ⟨ε₀, ⋯⟩)

