import Mathlib

open Real

/- Steins Lemma -/

-- Define the hypotheses for the lemma
noncomputable def H (i : Type u) [UnitalFreeStateTheory i] (ρ : MState (H i)) (ε : Prob) (m : ℕ) (σ : (n : ℕ) → ↑IsFree) (ε' : Prob) : Prop :=
  m ≥ 1 ∧ 𝐃(statePow ρ m‖↑(σ m)) / ↑m < @R2 i (H i) ℂ ρ σ + ↑⟨@ε₀ i (H i) ℂ ρ ε σ ε', ⋯⟩

-- Define the ε₀ term for the lemma
noncomputable def ε₀ (i : Type u) [UnitalFreeStateTheory i] (ρ : MState (H i)) (ε : Prob) (m : ℕ) (σ : (n : ℕ) → ↑IsFree) (ε' : Prob) : ℝ :=
  @ε₀ i (H i) ℂ ρ ε σ ε'

-- Define the R1 term for the lemma
noncomputable def R1 (i : Type u) [UnitalFreeStateTheory i] (ρ : MState (H i)) (ε : Prob) : ℝ :=
  @R1 i (H i) ℂ ρ ε

-- Define the R2 term for the lemma
noncomputable def R2 (i : Type u) [UnitalFreeStateTheory i] (ρ : MState (H i)) (σ : (n : ℕ) → ↑IsFree) : ℝ :=
  @R2 i (H i) ℂ ρ σ

-- Define the σ'' term for the lemma
noncomputable def σ'' (i : Type u) [UnitalFreeStateTheory i] (ρ : MState (H i)) (ε : Prob) (m : ℕ) (σ : (n : ℕ) → ↑IsFree) : (n : ℕ) → CPTPMap (H (i ^ n)) (H (i ^ n)) ℂ :=
  fun n => @σ'' i (H i) ℂ ρ ε m σ n

-- Define the E1, E2, E3 terms for the lemma
noncomputable def E1 (i : Type u) [UnitalFreeStateTheory i] (ε2 : ℝ) (n : ℕ) : HermitianMat (H (i ^ n)) ℂ :=
  (Real.exp (↑n * (R1 ρ ε + ε2)) • ↑(σ'' ρ ε m σ n)).proj_le ↑((ℰ n) (statePow ρ n))

noncomputable def E2 (i : Type u) [UnitalFreeStateTheory i] (ε2 : ℝ) (n : ℕ) : HermitianMat (H (i ^ n)) ℂ :=
  (Real.exp (↑n * (R2 ρ σ + ε₀ ρ ε m σ ε')) • ↑(σ'' ρ ε m σ n)).proj_le ↑((ℰ n) (statePow ρ n))

noncomputable def E3 (i : Type u) [UnitalFreeStateTheory i] (ε2 : ℝ) (n : ℕ) : HermitianMat (H (i ^ n)) ℂ :=
  (Real.exp (↑n * (R2 ρ σ + ε₀ ρ ε m σ ε' + ε2)) • ↑(σ'' ρ ε m σ n)).proj_le ↑((ℰ n) (statePow ρ n))

-- Define the c' term for the lemma
noncomputable def c' (i : Type u) [UnitalFreeStateTheory i] (ε2 : ℝ) (n : ℕ) : ℝ :=
  max (σ₁_c i (H i) ρ n + σ₁_c' i (H i) ρ n / ↑n) (R2 ρ σ + ε₀ ρ ε m σ ε' + ε2)

-- Define the overall hypothesis for the lemma
noncomputable def Hyp (i : Type u) [UnitalFreeStateTheory i] (ρ : MState (H i)) (ε : Prob) (m : ℕ) (σ : (n : ℕ) → ↑IsFree) (ε' : Prob) : Prop :=
  H ρ ε m σ ε' ∧ ∃ C, ∀ᶠ (n : ℕ) in Filter.atTop, c' (↑(ε' : ℝ)) n ≤ ↑C ∧ ∃ C, ∀ᶠ (n : ℕ) in Filter.atTop, c' (↑(ε' : ℝ)) n ≤ ↑C

/- The main theorem of the lemma -/
theorem SteinsLemma (i : Type u) [UnitalFreeStateTheory i] (ρ : MState (H i)) (ε : Prob) (m : ℕ) (σ : (n : ℕ) → ↑IsFree) (ε' : Prob) (h : Hyp ρ ε m σ ε') : Prop := by
  -- Extract the main hypothesis part from `h`
  rcases h with ⟨hH, hC⟩
  -- Extract the specific constant `C` from `hC`
  rcases hC with ⟨C, hC⟩
