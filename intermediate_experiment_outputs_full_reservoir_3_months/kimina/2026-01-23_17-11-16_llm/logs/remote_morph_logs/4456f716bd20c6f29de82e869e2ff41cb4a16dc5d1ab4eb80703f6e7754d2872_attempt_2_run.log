instance : solidToCondensed'.IsRightAdjoint := by
  apply isRightAdjoint_of_preservesLimits_of_solutionSetCondition
  · -- Show that solidToCondensed' preserves limits
    sorry
  · -- Show that solidToCondensed' satisfies the solution set condition
    intro A
    sorry
