    ctble U ↔ ∃ (f : U → Nat), one_to_one f := by
  constructor
  · -- Assume U is countable, prove ∃ f, one_to_one f
    intro h
    have h1 : ∃ g : ℕ → U, Function.Surjective g := h
    rcases h1 with ⟨g, hg⟩
    use λ u => Nat.find (show u ∈ Set.range g by
      simpa using hg u
    )
    constructor
    · -- Show that the function is injective
      intro u1 u2 h
      have h1 : u1 = u2 := by
        have h2 : (Nat.find (show u1 ∈ Set.range g by simpa using hg u1)) = (Nat.find (show u2 ∈ Set.range g by simpa using hg u2)) := h
        have h3 : g (Nat.find (show u1 ∈ Set.range g by simpa using hg u1)) = u1 := by
          simpa using hg u1
        have h4 : g (Nat.find (show u2 ∈ Set.range g by simpa using hg u2)) = u2 := by
          simpa using hg u2
        have h5 : Nat.find (show u1 ∈ Set.range g by simpa using hg u1) = Nat.find (show u2 ∈ Set.range g by simpa using hg u2) := h2
        have h6 : g (Nat.find (show u1 ∈ Set.range g by simpa using hg u1)) = g (Nat.find (show u2 ∈ Set.range g by simpa using hg u2)) := by
          rw [show Nat.find (show u1 ∈ Set.range g by simpa using hg u1) = Nat.find (show u2 ∈ Set.range g by simpa using hg u2) by linarith [h5]]
        linarith [h3, h4, h6]
      exact h1
    · -- Show that the function is well-defined
      intro u
      have h1 : u ∈ Set.range g := by
        simpa using hg u
      simpa using h1
  · -- Assume ∃ f, one_to_one f, prove U is countable
    intro h
    rcases h with ⟨f, hf⟩
    have h2 : ∃ g : ℕ → U, Function.Surjective g := by
      use λ n => (f ⁻¹' {n}).choose
      constructor
      · -- Show g is surjective
        intro u
        use f u
        simp [Set.mem_preimage, hf]
        <;> aesop
      · -- Show g is well-defined
        intro n
        have h1 : (f ⁻¹' {n}).Nonempty := by
          use u
          simp [hf]
          <;> aesop
        simpa using h1
    exact h2
