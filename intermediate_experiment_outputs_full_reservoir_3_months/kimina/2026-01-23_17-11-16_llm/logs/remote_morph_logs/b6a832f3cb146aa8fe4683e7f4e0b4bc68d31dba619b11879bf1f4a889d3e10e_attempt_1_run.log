import Mathlib

open ProbabilityTheory
open Real

variable (α : Type) [hα : SampleableType α]

noncomputable def uniformSample (β : Type) [h : SampleableType β] : ProbComp β := h.selectElem

noncomputable def uniformSelectList (xs : List α) : ProbComp α := OptionT.lift (PMF.map (fun (i : Fin (List.length xs)) => xs[i]) (PMF.uniform (List.length xs)))

noncomputable def uniformSelectVector (xs : Vector α (n + 1)) : ProbComp α := OptionT.lift (PMF.map (fun (i : Fin (List.length xs)) => xs[i]) (PMF.uniform (List.length xs)))

noncomputable def uniformSelectFinset (s : Finset α) : ProbComp α := OptionT.lift (PMF.map (fun (i : Fin s.card) => List.get s.toList i) (PMF.uniform s.card))

noncomputable def uniformSelect (x : α) : ProbComp α := return x

noncomputable def uniformSelectList' (xs : List α) : ProbComp α := uniformSelectList xs

noncomputable def uniformSelectVector' (xs : Vector α (n + 1)) : ProbComp α := uniformSelectVector xs

noncomputable def uniformSelectFinset' (s : Finset α) : ProbComp α := uniformSelectFinset s

noncomputable def uniformSelect' (x : α) : ProbComp α := return x

