open SProbComp

variable (α : Type)

/- A `HasUniformSelect! β α` instance means that `β` is a structure for selecting an element of type `α` uniformly at random.
It requires a function `run` that computes the result of the selection, a function `evalDist` that computes the distribution of the result, and a function `finSupport` that computes the finite support of the distribution.
The structure is `Mk <;> (run : M → Option α) <;> (evalDist : M → SProb α) <;> (finSupport : M → Finset α)`.

variable (M : Type)

/-- A computation that may fail, represented as `Option α`. -/
structure Option α := Option α

/-- A computation that may fail, represented as `Option α`, but with a probability distribution over the successful outcomes. -/
structure OptionT (α : Type) (M : Type) [Fintype M] [DecidableEq α] [DecidableEq M] (P : SProb α) (f : M → Option α) : SProbComp α :=
  SProbComp.mk P f

