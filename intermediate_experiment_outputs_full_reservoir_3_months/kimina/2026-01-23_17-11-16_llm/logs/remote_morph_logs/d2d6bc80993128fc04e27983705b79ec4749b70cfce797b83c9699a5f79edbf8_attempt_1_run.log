  simpa [Sym2.diagSet_eq_setOf_isDiag, ÔćÉ Set.disjoint_compl_right_iff_subset, ÔćÉ Set.compl_setOf]
    using hs

variable (V) in
@[simp] lemma binomialRandom_zero : G(V, 0) = dirac ÔŐą := by simp [binomialRandom_eq_map]

variable (V) in
@[simp] lemma binomialRandom_one : G(V, 1) = dirac ÔŐĄ := by simp [binomialRandom_eq_map]

end Countable

variable (V) in
@[simp] lemma binomialRandom_singleton [Finite V] (G : SimpleGraph V) :
    G(V, p) {G} = toNNReal p ^ G.edgeSet.ncard *
      toNNReal (¤â p) ^ ((Nat.card V).choose 2 - G.edgeSet.ncard) := by
  classical
  cases nonempty_fintype V
  simp only [binomialRandom, measurableEmbedding_edgeSet.comap_apply, Set.image_singleton,
    edgeSet_subset_setOf_not_isDiag, bernoulliOn_singleton]
  rw [Set.ncard_diff (edgeSet_subset_setOf_not_isDiag _)]
  congr!
  rw [Nat.card_eq_fintype_card, ÔćÉ Sym2.card_subtype_not_diag, Fintype.card_eq_nat_card,
    ÔćÉ Nat.card_coe_set_eq]
  simp [diagSet_compl_eq_setOf_not_isDiag]

