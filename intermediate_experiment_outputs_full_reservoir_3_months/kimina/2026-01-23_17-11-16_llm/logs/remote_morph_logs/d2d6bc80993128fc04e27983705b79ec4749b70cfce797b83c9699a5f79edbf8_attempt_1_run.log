variable (V p) in
lemma binomialRandom_eq_map : G(V, p) = map fromEdgeSet Ber(diagSetßÂť, p) := by
  refine (map_eq_comap measurable_fromEdgeSet measurableEmbedding_edgeSet ?_
    fromEdgeSet_edgeSet).symm
  filter_upwards [bernoulliOn_ae_subset] with S hS
  refine ÔčĘfromEdgeSet S, ?_Ôčę
  simpa [Sym2.diagSet_eq_setOf_isDiag, ÔćÉ Set.compl_setOf, Set.subset_compl_iff_disjoint_right]
    using hS

lemma isBernoulliOn_edgeSet_binomialRandom : IsBernoulliOn edgeSet diagSetßÂť p G(V, p) where
  map_eq := by
    rw [binomialRandom_eq_map, map_map (by fun_prop) (by fun_prop), Measure.map_congr,
      Measure.map_id]
    filter_upwards [bernoulliOn_ae_subset] with S hS
    simpa [Set.subset_compl_iff_disjoint_right] using hS

variable (p) in
lemma binomialRandom_apply' (S : Set (SimpleGraph V)) :
