instance : MeasurableSpace (SimpleGraph V) := .comap Adj inferInstance

/-- A simple graph-valued map is measurable iff all induced adjacency maps are measurable. -/
lemma measurable_iff_adj {╬ę : Type*} {m : MeasurableSpace ╬ę} {G : ╬ę Ôćĺ SimpleGraph V} :
    Measurable G Ôćö ÔłÇ u v, Measurable fun ¤ë ÔćŽ (G ¤ë).Adj u v := by
  simp [measurable_comap_iff, measurable_pi_iff]

@[fun_prop]
lemma measurable_adj : Measurable (Adj : SimpleGraph V Ôćĺ V Ôćĺ V Ôćĺ Prop) := comap_measurable _

@[fun_prop]
lemma measurable_edgeSet : Measurable (edgeSet : SimpleGraph V Ôćĺ Set (Sym2 V)) :=
  measurable_set_iff.2 <| by rintro ÔčĘu, vÔčę; simp only [mem_edgeSet]; fun_prop

set_option linter.flexible false in
@[simp, fun_prop]
lemma measurable_fromEdgeSet : Measurable (fromEdgeSet : Set (Sym2 V) Ôćĺ SimpleGraph V) := by
  simp [measurable_iff_adj]; fun_prop

lemma measurableEmbedding_edgeSet [Countable V] :
    MeasurableEmbedding (edgeSet : SimpleGraph V Ôćĺ Set (Sym2 V)) where
  injective := edgeSet_injective
  measurable := measurable_edgeSet
  measurableSet_image' s hs := by
    simp only [ÔćÉ measurable_mem, Set.mem_image, edgeSet_eq_iff, ÔćôexistsAndEq, true_and,
      Set.disjoint_right]
    refine .and (hs.mem.comp measurable_fromEdgeSet) <| .forall fun e ÔćŽ .imp ?_ ?_ <;> fun_prop

/-!
### Distribution of binomial random graphs

In this section, we construct the binomial distribution with parameter `p` on simple graphs with
vertices `V`. This is the law `G(V, p)` of binomial random graphs with probability `p`.
-/

variable (V p) in
/-- The binomial distribution with parameter `p` on simple graphs with vertices `V`. -/
@[expose]
noncomputable def binomialRandom : Measure (SimpleGraph V) := Ber(diagSetßÂť, p).comap edgeSet

@[inherit_doc] scoped notation "G(" V ", " p ")" => binomialRandom V p

section Countable
variable [Countable V]

variable (V p) in
lemma binomialRandom_eq_map : G(V, p) = map fromEdgeSet Ber(diagSetßÂť, p) := by
  refine (map_eq_comap measurable_fromEdgeSet measurableEmbedding_edgeSet ?_
    fromEdgeSet_edgeSet).symm
  filter_upwards [bernoulliOn_ae_subset] with S hS
  refine ÔčĘfromEdgeSet S, ?_Ôčę
  simpa [Sym2.diagSet_eq_setOf_isDiag, ÔćÉ Set.compl_setOf, Set.subset_compl_iff_disjoint_right]
    using hS

lemma isBernoulliOn_edgeSet_binomialRandom : IsBernoulliOn edgeSet diagSetßÂť p G(V, p) where
  map_eq := by
    rw [binomialRandom_eq_map, map_map (by fun_prop) (by fun_prop), Measure.map_congr,
      Measure.map_id]
    filter_upwards [bernoulliOn_ae_subset] with S hS
    simpa [Set.subset_compl_iff_disjoint_right] using hS

variable (p) in
lemma binomialRandom_apply' (S : Set (SimpleGraph V)) :
    G(V, p) S = Ber(diagSetßÂť, p) (edgeSet '' S) := by
  rw [binomialRandom, measurableEmbedding_edgeSet.comap_apply]

variable (p) in
lemma binomialRandom_apply (S : Set (SimpleGraph V)) :
    G(V, p) S = (infinitePi fun e : Sym2 V ÔćŽ
          toNNReal p ÔÇó .dirac (┬Č e.IsDiag) + toNNReal (¤â p) ÔÇó .dirac False)
        ((fun G e ÔćŽ e Ôłł G.edgeSet) '' S) := by
  simp [binomialRandom_apply', bernoulliOn_apply, ÔćÉ Set.image_comp]

instance : IsProbabilityMeasure G(V, p) := by
  refine measurableEmbedding_edgeSet.isProbabilityMeasure_comap ?_
  filter_upwards [bernoulliOn_ae_subset] with s hs
  refine ÔčĘ.fromEdgeSet s, ?_Ôčę
  simpa [Sym2.diagSet_eq_setOf_isDiag, ÔćÉ Set.disjoint_compl_right_iff_subset, ÔćÉ Set.compl_setOf]
    using hs

variable (V) in
@[simp] lemma binomialRandom_zero : G(V, 0) = dirac ÔŐą := by simp [binomialRandom_eq_map]

variable (V) in
@[simp] lemma binomialRandom_one : G(V, 1) = dirac ÔŐĄ := by simp [binomialRandom_eq_map]

end Countable

