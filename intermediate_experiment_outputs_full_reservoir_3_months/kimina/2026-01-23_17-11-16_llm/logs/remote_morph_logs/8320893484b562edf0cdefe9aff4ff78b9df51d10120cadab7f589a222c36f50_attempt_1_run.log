import Mathlib

open Filter Real Finset Complex

/-! The main theorem is a version of the classical Stein's lemma from hypothesis testing, adapted for use with positive definite operators on complex Hilbert spaces. The theorem provides an upper bound for the logarithmic term in the definition of relative entropy, which is crucial for establishing optimal rates of convergence in hypothesis testing problems. -/
theorem steins_lemma (inst : UnitalFreeStateTheory ι) [inst : UnitalFreeStateTheory ι] (i : ι) (ρ : MState (H i)) (σ : (n : ℕ) → ↑IsFree) (ε : Prob) (hε : ε < 1) (hε₁ : 0 < ε) (m : ℕ) (hm : m ≥ 1) (hm' : ∀ n ≥ m, (n : ℝ)⁻¹ * log (tr ((statePow ρ n) (↑(σ n))))) < R2 ρ σ + ε₀ + ε) (hm'' : m ≥ 1) (hm''' : ∀ n ≥ m, (n : ℝ)⁻¹ * log (tr ((statePow ρ n) (↑(σ n))))) < R2 ρ σ + ε₀ + ε) (ε' : Prob) (hε' : ε' < ε) (hε₁' : 0 < ε') (R1 : ℝ → (n : ℕ) → Hermitian (H (i ^ n)) (H (i ^ n)) ℂ) (R2 : ℝ → (n : ℕ) → Hermitian (H (i ^ n)) (H (i ^ n)) ℂ) (ε₀ : ℝ) (hε₀ : 0 < ε₀) (hε₀' : ENNReal.toReal (R1 ρ ε) ≤ ENNReal.toReal (R2 ρ σ) + ε₀) (hliminf_le : Filter.liminf (fun n => (OptimalHypothesisRate ((statePow ρ n) (↑(σ n))) ε (↑(σ n))).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (R1 ρ ε))) (hlimsup_le : ∀ (ε1 : Prob), 0 < ↑ε1 ∧ ↑ε1 < 1 → Filter.limsup (fun n => (OptimalHypothesisRate ((statePow ρ n) (↑(σ n))) (1 - ε1) (↑(σ n))).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (R2 ρ σ) + ⟨ε₀, ⋯⟩)) :
  ∀ (ε2 : ℝ), 0 < ε2 → ∀ (n : ℕ), 0 < n → (n : ℝ)⁻¹ * log (tr ((statePow ρ n) (↑(σ n))))) ≤ R1 ρ ε + ε2 + ENNReal.toReal ((P1 ε2 n).inner (↑(statePow ρ n))) * (R2 ρ σ - R1 ρ ε) + ENNReal.toReal ((P2 ε2 n).inner (↑(statePow ρ n))) * (c' ε2 n - R2 ρ σ) := by
  intro ε2 hε2 n hn
  -- Define the projectors P1 and P2 as in the standard proof of Stein's lemma
  have P1 : ℝ → (n : ℕ) → Hermitian (H (i ^ n)) (H (i ^ n)) ℂ :=
    fun ε2 n =>
      (Real.exp (↑n * (ENNReal.toReal (R1 ρ ε) + ε2)) • ↑(↑(σ n)))
      .proj_le ↑((statePow ρ n))
  have P2 : ℝ → (n : ℕ) → Hermitian (H (i ^ n)) (H (i ^ n)) ℂ :=
    fun ε2 n =>
      (Real.exp (↑n * (ENNReal.toReal (R2 ρ σ) + ε₀ + ε2)) • ↑(↑(σ n)))
      .proj_le ↑((statePow ρ n))
  have hPcomm : ∀ (ε2 : ℝ) (n : ℕ), Commute ↑(P1 ε2 n) ↑(P2 ε2 n) := by
    intro ε2 n
    -- Show that P1 and P2 commute by showing they are both projections onto subspaces of a commuting pair
