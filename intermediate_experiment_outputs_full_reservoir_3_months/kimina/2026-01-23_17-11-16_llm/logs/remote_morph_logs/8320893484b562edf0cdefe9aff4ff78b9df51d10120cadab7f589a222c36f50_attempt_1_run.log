-- Define P1, P2 projectors
noncomputable abbrev P1 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε) + ε2)) • ↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).proj_le ↑((ℰ n) (statePow ρ n))
noncomputable abbrev P2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ε₀ + ε2)) • ↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).proj_le ↑((ℰ n) (statePow ρ n))
