noncomputable abbrev E2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := P1 - P2
noncomputable abbrev E3 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := P2
-- Prove that E1 + E2 + E3 = 1
noncomputable abbrev Esum : E1 + E2 + E3 = 1 := by
  funext ε2 n
  simp [E1, E2, E3, P1, P2]
  all_goals try ring_nf
  all_goals try simp [hPcomm]
  all_goals try ring
