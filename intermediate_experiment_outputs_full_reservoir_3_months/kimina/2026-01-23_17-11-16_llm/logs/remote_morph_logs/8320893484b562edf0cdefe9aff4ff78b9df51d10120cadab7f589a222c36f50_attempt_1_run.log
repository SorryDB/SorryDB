  intro ε2 n
  simp [E1, P1, P2, hEsum]
  positivity
noncomputable abbrev hE2_nonneg : ∀ (ε2 : ℝ) (n : ℕ), E2 ε2 n ≥ 0 := by
  intro ε2 n
  simp [E2, P1, P2, hEsum]
  positivity
noncomputable abbrev hE3_nonneg : ∀ (ε2 : ℝ) (n : ℕ), E3 ε2 n ≥ 0 := by
  intro ε2 n
  simp [E3, P1, P2, hEsum]
