noncomputable abbrev hE2comm : Commute ↑(E2 ε2 n) ↑(↑((ℰ n) (statePow ρ n))).log := by
  apply Commute.sub_right
  · simp [E1, E2, E3, hEsum]
    apply Commute.symm
    apply Commute.one_right
  · apply Commute.smul_left
    apply Commute.symm
    apply pinching_commutes (ρ⊗^S[n]) (σ'' ρ ε m σ)
noncomputable abbrev hE3comm : Commute ↑(E3 ε2 n) ↑(↑((ℰ n) (statePow ρ n))).log := by
  simp [E3, P2, hEsum]
  apply Commute.smul_left
  apply Commute.symm
  apply pinching_commutes (ρ⊗^S[n]) (σ'' ρ ε m σ)
