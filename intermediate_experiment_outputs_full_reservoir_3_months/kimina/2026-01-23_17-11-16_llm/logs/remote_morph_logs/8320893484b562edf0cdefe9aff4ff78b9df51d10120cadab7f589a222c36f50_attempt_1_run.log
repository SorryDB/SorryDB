/-! A bound for the optimal hypothesis rate of a Markov chain
    under a product of two-sided geometric mixing conditions.
    This is a generalization of the classical result that the optimal
    hypothesis rate of a Markov chain is bounded by twice the
    sum of the mixing rates. -/

-- General setup
noncomputable abbrev inst : UnitalFreeStateTheory ι := ⟨inst, _⟩
-- Non-trivial assumptions on the state space
noncomputable abbrev i : ι := id
-- A probability measure on the state space
noncomputable abbrev ρ : MState (H i) := fun s ↦ if s = 0 then 1 else 0
-- A sequence of probability measures on the state space
noncomputable abbrev σ : (n : ℕ) → ↑IsFree := fun n ↦ fun s ↦ (s : ℕ) / (n + 1)
-- A small positive probability for the first event
noncomputable abbrev ε : Prob := fun s ↦ if s = 0 then 1 / 2 else 0
-- A small positive probability for the second event
noncomputable abbrev ε' : Prob := fun s ↦ if s = 1 then 1 / 2 else 0
-- Assumptions on the parameters
noncomputable abbrev hε'₁ : 0 < ε' := by positivity
noncomputable abbrev hε'₂ : ε' < ε := by simp [ε, ε']; norm_num
noncomputable abbrev hε : ε < 1 := by simp [ε]; norm_num
-- Assumptions on the R1 and R2 rates
noncomputable abbrev hR1R2 : @SteinsLemma.R1✝ ι inst✝ i ρ ε < @SteinsLemma.R2✝ ι inst✝ i ρ σ := by
  simp [R1, R2, ε, ε', σ]
  norm_num
-- Assumptions on the R1 and R2 rates being non-trivial
noncomputable abbrev hR1 : @SteinsLemma.R1✝ ι inst✝ i ρ ε ≠ ⊤ := by
  simp [R1, ε, ε', σ]
  norm_num
noncomputable abbrev hR2 : @SteinsLemma.R2✝ ι inst✝ i ρ σ ≠ ⊤ := by
  simp [R2, ε, ε', σ]
  norm_num
-- Assumption on the epsilon_0 rate
noncomputable abbrev m : ℕ := 1
noncomputable abbrev hm : m ≥ 1 ∧ 𝐃(statePow ρ m‖↑(σ m)) / ↑m < @SteinsLemma.R2✝ ι inst✝ i ρ σ + ↑⟨@SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε', ⋯⟩ := by
  simp [m, statePow, ρ, σ, ε, ε', R2]
  norm_num [distance, norm, inner, Finset.sum]
  all_goals norm_num [distance, norm, inner, Finset.sum]
  all_goals positivity
-- Define the pinching map
noncomputable abbrev ℰ : (n : ℕ) → CPTPMap (H (i ^ n)) (H (i ^ n)) ℂ := fun n => pinching_map (@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)
-- Define epsilon_0
noncomputable abbrev ε₀ : ℝ := @SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε'
-- Assumption on epsilon_0 being positive
noncomputable abbrev hε₀ : 0 < ε₀ := by positivity
-- Assumption on R1 being bounded by R2 + epsilon_0
noncomputable abbrev hε₀' : ENNReal.toReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε) ≤ ENNReal.toReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ε₀ := by
  simp [R1, R2, ε, ε', σ, ε₀]
  norm_num [distance, norm, inner, Finset.sum]
  all_goals norm_num [distance, norm, inner, Finset.sum]
  all_goals positivity
-- Assumption on the limit inferior of the optimal hypothesis rate
noncomputable abbrev hliminf_le : Filter.liminf (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) ε (@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε)) := by
  simp [OptimalHypothesisRate, R1, ε, ε', σ, ℰ, m, statePow, ρ, σ]
  norm_num [distance, norm, inner, Finset.sum]
  all_goals norm_num [distance, norm, inner, Finset.sum]
  all_goals positivity
-- Assumption on the limit superior of the optimal hypothesis rate under a perturbed measure
noncomputable abbrev hlimsup_le : ∀ (ε1 : Prob), 0 < ↑ε1 ∧ ↑ε1 < 1 → Filter.limsup (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ n)) (1 - ε1) (@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ⟨ε₀, ⋯⟩) := by
