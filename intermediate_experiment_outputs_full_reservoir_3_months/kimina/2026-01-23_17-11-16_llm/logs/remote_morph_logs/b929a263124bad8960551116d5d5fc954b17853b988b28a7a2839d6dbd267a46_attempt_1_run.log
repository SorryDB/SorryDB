    _ = ‖f‖_[p] * ‖g‖_[q] := by simp_rw [dLpNorm_norm]

/-- **Hölder's inequality**, binary case. -/
lemma dLpNorm_mul_le (p q r : ℝ≥0∞) (hr₀ : r ≠ 0) [hpqr : ENNReal.HolderTriple p q r] :
