noncomputable abbrev removedIds (state : SystemState) : Set (RequestId) := state.removed.map Request.id

noncomputable abbrev pendingIds (state : SystemState) : Set (RequestId) :=
  (satisfiedIds state).compl ∩ (removedIds state).compl ∩ (requestIds state).toSet

