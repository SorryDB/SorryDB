def SystemState.updateOrderConstraintsPropagate (state : SystemState) : @Scope state.scopes →
RequestId → ThreadId → @OrderConstraints state.scopes
  | scope, reqId, thId =>
  match state.requests.getReq? reqId with
    | none => state.orderConstraints
    | some req =>
