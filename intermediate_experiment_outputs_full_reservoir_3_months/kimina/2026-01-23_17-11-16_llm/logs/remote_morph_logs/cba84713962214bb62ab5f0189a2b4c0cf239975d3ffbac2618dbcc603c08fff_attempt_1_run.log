import Mathlib

open Arch

def SystemState := {
  requests : Array (Array (Request)),
  removed : Set (RequestId),
  orderConstraints : @OrderConstraints Arch,
  threadTypes : Thread → Arch,
  scopes : @Scopes Arch,
  satisfied : Set (RequestId),
  removedCoherent : sorry
}

def SystemState.freshId : SystemState → RequestId
  | state =>
    let removed := state.removed.map Request.id
    let active := reqIds state.requests
    let ids : List Nat := removed ++ active
    let max := ids.max?
    match max with
      | none => 0
      | some id => (Nat.succ id)

def SystemState.isSatisfied : SystemState → RequestId → Bool
  | state, rId =>
    rId ∈ state.satisfied

