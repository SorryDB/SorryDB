    | none => state.orderConstraints
    | some req =>
      let newobs := λ req' : Request =>
        req.id != req'.id ∧
        -- TODO: this seems to be too weak?
        (req.isWrite ∧ req'.isMem ∨ req.isMem ∧ req'.isWrite) ∧
        --req.isMem ∧ req'.isMem ∧
