import Mathlib

abbrev Arch : Type := Arch

abbrev SystemState : Type := {
  requests : Array (Array (Request)), -- Each inner array is a thread's local requests
  removed : Set (RequestId),         -- Set of request IDs that are removed from the system
  orderConstraints : @OrderConstraints Arch, -- Constraints on the order of requests
  scopes : @Scopes Arch,               -- Scoping information for requests
  threadTypes : @ThreadId → Option Nat, -- Maps thread IDs to their types (e.g., core, I/O)
  satisfied : Set (RequestId),        -- Set of request IDs that have been satisfied
  removedCoherent : Bool,             -- A flag indicating if the removed set is coherent
}

abbrev BasicRequest : Type := { type : Nat, address : Nat, size : Nat, isAtomic : Bool }

abbrev Request : Type := {
  id : Nat,                          -- Unique identifier for the request
  thread : Option Nat,               -- Thread in which the request was created
  basic_type : BasicRequest,         -- Basic type of the request (e.g., read, write, atomic)
  occurrence : Nat,                 -- Occurrence count for the same logical operation
  address : Option Nat,              -- Address of the memory location
  isMem : Bool,                      -- Is the request a memory operation?
  isSatisfied : Bool,                -- Is the request satisfied?
  isPredecessorAt : Nat → Bool,       -- Checks if a request is a predecessor at a given thread
  isAtomic : Bool,                   -- Is the request atomic (e.g., compare-and-swap)
  isTransactional : Bool,            -- Is the request transactional?
  pairedRequest? : Option Nat,        -- Optional paired request (for read-modify-write)
  propagated_to : List Nat,          -- List of thread IDs where the request has been propagated
  blockingSemantics : Set (Nat),      -- Set of natural numbers representing the request's blocking behavior
  -- Fields from BasicRequest
  type : Nat,
  size : Nat
}

abbrev ReadWrite : Type := { read : BasicRequest, write : BasicRequest }
abbrev Request.isRead : Prop := sorry
abbrev Request.isWrite : Prop := sorry
abbrev BasicRequest.isRead : Prop := sorry
abbrev BasicRequest.isWrite : Prop := sorry

abbrev OrderConstraint : Type := {
  scope : Set (ThreadId),           -- The scope of the order constraint (e.g., all threads, specific pair)
