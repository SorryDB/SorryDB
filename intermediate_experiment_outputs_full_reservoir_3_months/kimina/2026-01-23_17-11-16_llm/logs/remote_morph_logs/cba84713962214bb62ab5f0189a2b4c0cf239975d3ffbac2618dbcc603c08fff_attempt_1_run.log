    isAtomic : Bool,
    isTransactional : Bool,
    isMem : Bool,
    isPredecessorAt : λ (t : ThreadId) => this ∈ t.propagated_from,
    isSatisfiedAt : λ (t : ThreadId) => this ∈ t.satisfied,
    isFenceAt : λ (t : ThreadId) => this ∈ t.fences,
    isRmwAt : λ (t : ThreadId) => this ∈ t.rmw,
    isAtomicAt : λ (t : ThreadId) => this ∈ t.atomics,
