import Mathlib
import Arch

abbrev SystemState := {
  requests : List (Request),
  removed : List (RequestId),
  orderConstraints : @OrderConstraints (List (ThreadId)) (List (RequestId)) (List (RequestId)),
  threadTypes : Finset (ThreadId),
  scopes : @Scopes (List (ThreadId)) (List (RequestId)) (List (ThreadId)) (List (RequestId)) (List (ThreadId)) (List (RequestId)),
  satisfied : List (RequestId),
  removedCoherent : trivial
}

def SystemState.freshId : SystemState → RequestId
  | state =>
    let removed := state.removed.map Request.id
    let active := reqIds state.requests
    let ids : List Nat := removed ++ active
    let max := ids.max?
    match max with
      | none => 0
      | some id => (Nat.succ id)

abbrev Transition :=
  (acceptRequest : (ThreadId → List (RequestId)) → Option (ThreadId))
  (propagateToThread : (ThreadId → List (RequestId)) → Option (ThreadId))
  (read : (ThreadId → List (RequestId)) → Option (ThreadId))
  (write : (ThreadId → List (RequestId)) → Option (ThreadId))
  (fence : (ThreadId → List (RequestId)) → Option (ThreadId))
  (satisfyRead : (ThreadId → List (RequestId)) → Option (ThreadId))
  (satisfyWrite : (ThreadId → List (RequestId)) → Option (ThreadId))
  (satisfyFence : (ThreadId → List (RequestId)) → Option (ThreadId))
