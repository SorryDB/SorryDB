import Foundation.Propositional.Hilbert.F.Deduction
import Foundation.Propositional.Kripke2.Basic

namespace LO.Propositional

open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {őĪ : Type*}
variable {S} [Entailment S (Formula őĪ)]
variable {ūĚďĘ : S}

structure FTheory (L : Logic ‚Ąē) where
  protected theory : FormulaSet ‚Ąē
  protected no_bot : ‚ä• ‚ąČ theory
  protected andIR : ‚ąÄ {ŌÜ Ōą}, ŌÜ ‚ąą theory ‚Üí Ōą ‚ąą theory ‚Üí ŌÜ ‚čŹ Ōą ‚ąą theory
  protected imp_closed : ‚ąÄ {ŌÜ Ōą}, L ‚äĘ ŌÜ ‚ěĚ Ōą ‚Üí ŌÜ ‚ąą theory ‚Üí Ōą ‚ąą theory
  protected L_subset : L ‚äÜ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {ŌÜ Ōą Ōá : Formula ‚Ąē}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hŌÜ : L ‚äĘ ŌÜ) : ŌÜ ‚ąą T.theory := by
  apply T.imp_closed (ŌÜ := ‚ä§) $ af hŌÜ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (h‚āĀ : ŌÜ ‚ěĚ Ōą ‚ąą T.theory) (h‚āā : Ōą ‚ěĚ Ōá ‚ąą T.theory) : ŌÜ ‚ěĚ Ōá ‚ąą T.theory := by
  apply T.imp_closed (axiomI (Ōą := Ōą));
  apply T.andIR h‚āĀ h‚āā;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hŌÜ : ŌÜ ‚ąą T.theory) : ŌÜ ‚čé Ōą ‚ąą T.theory := by
  apply T.imp_closed (ŌÜ := ŌÜ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hŌą : Ōą ‚ąą T.theory) : ŌÜ ‚čé Ōą ‚ąą T.theory := by
  apply T.imp_closed (ŌÜ := Ōą);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ŌÜ ‚ąą T.theory ‚ÜĒ Deduction Ax T.theory ŌÜ := by
  constructor;
  . intro hŌÜ;
    apply Deduction.ctx hŌÜ;
  . intro h; induction h <;> grind

end FTheory


variable {L : Logic ‚Ąē}

structure PrimeFTheory (L : Logic ‚Ąē) extends FTheory L where
  protected prime : ‚ąÄ {ŌÜ Ōą}, ŌÜ ‚čé Ōą ‚ąą theory ‚Üí ŌÜ ‚ąą theory ‚ą® Ōą ‚ąą theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {ŌÜ Ōą Ōá őĺ : Formula ‚Ąē} {T : FTheory L} {hT : Ōá ‚ěĚ őĺ ‚ąČ T.theory}

def construction (T : FTheory L) (hT : Ōá ‚ěĚ őĺ ‚ąČ T.theory) : ‚Ąē ‚Üí Set (Formula ‚Ąē)
  | 0 => { őī | Ōá ‚ěĚ őī ‚ąą T.theory }
  | i + 1 =>
