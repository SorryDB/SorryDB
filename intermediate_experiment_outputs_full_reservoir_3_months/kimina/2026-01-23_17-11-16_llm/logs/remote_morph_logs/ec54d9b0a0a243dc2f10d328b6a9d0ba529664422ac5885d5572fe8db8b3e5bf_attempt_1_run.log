lemma not_of_mem_construction_omega {ŌÜ : Formula ‚Ąē}
  {őď : Finset (Formula _)} (hőď : ‚ÜĎőď ‚äÜ construction T hT (encode ŌÜ))
  (hŌÜ : őď.conj ‚čŹ ŌÜ ‚ěĚ őĺ ‚ąą T.theory) :
  ŌÜ ‚ąČ (construction_omega T hT) := by
  by_contra h
  simp [construction_omega, Set.mem_iUnion] at h
  rcases h with ‚ü®i, hi‚ü©
  induction i with
  | zero =>
    simp [construction] at hi
    exfalso
    have h2 : ŌÜ ‚ąą construction_omega T hT := by
      apply mem_omega_of_mem
      tauto
    contradiction
  | succ i ih =>
    simp [construction] at hi
    exfalso
    have h2 : ŌÜ ‚ąą construction_omega T hT := by
      apply mem_omega_of_mem
      tauto
    contradiction
    all_goals
      try { tauto }
      <;> try { 
