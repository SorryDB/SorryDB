lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hŌą : Ōą ‚ąą T.theory) : ŌÜ ‚čé Ōą ‚ąą T.theory := by
  apply T.imp_closed (ŌÜ := Ōą);
