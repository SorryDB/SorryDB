      . exact impId;
      . apply af;
        exact Logic.iff_provable.mpr hŌÜ;
    have : (őď.conj ‚čŹ ŌÜ) ‚ěĚ őĺ ‚ąą T.theory := T.mem_trans h‚āā h‚āĀ;
    have : (őď.conj ‚čŹ ŌÜ) ‚ěĚ őĺ ‚ąą construction_omega T hT := by
