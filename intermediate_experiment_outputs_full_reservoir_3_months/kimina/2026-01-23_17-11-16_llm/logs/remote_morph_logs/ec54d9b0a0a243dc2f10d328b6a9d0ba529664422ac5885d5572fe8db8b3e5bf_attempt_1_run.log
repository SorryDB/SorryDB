  {őď : Finset (Formula ‚Ąē)} (hőď : ‚ÜĎőď ‚äÜ construction T hT (encode ŌÜ))
  (hŌÜ : őď.conj ‚čŹ ŌÜ ‚ěĚ őĺ ‚ąą T.theory) :
  ŌÜ ‚ąČ (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
