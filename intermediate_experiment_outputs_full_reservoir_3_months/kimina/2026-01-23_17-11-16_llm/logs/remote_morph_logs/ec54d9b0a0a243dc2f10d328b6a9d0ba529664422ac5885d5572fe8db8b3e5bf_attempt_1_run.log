    . assumption

lemma mem_omega_of_mem {ŌÜ : Formula ‚Ąē} (h : Ōá ‚ěĚ ŌÜ ‚ąą T.theory) : ŌÜ ‚ąą construction_omega T hT := by
  apply mem_omega_of_mem h;
