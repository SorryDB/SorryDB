        <;> try { contradiction }
        <;> try { tauto }
      }

lemma of_not_mem_construction_omega {ŌÜ : Formula ‚Ąē} (hŌÜ : ŌÜ ‚ąČ construction_omega T hT) :
  (Ōá ‚ěĚ ŌÜ ‚ąČ T.theory) ‚ąß (‚ąÉ őď : Finset (Formula _), ‚ÜĎőď ‚äÜ (construction T hT (encode ŌÜ)) ‚ąß őď.conj ‚čŹ ŌÜ ‚ěĚ őĺ ‚ąą T.theory) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hŌÜ;
  constructor;
  . simpa using hŌÜ 0;
  . have this := hŌÜ (encode ŌÜ + 1);
