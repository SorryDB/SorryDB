        rcases hi with (rfl | hi);
        . sorry;
        . assumption;
      . assumption
    . assumption
    split at hi;
    -/

lemma not_of_mem_construction_omega {ŌÜ : Formula ‚Ąē} (hŌÜ : ŌÜ ‚ąČ construction_omega T hT) :
  (Ōá ‚ěĚ ŌÜ ‚ąČ T) ‚ąß (‚ąÉ őď : Finset (Formula _), ‚ÜĎőď ‚äÜ (construction T hT (encod ŌÜ)) ‚ąß őď.conj ‚čŹ ŌÜ ‚ěĚ őĺ ‚ąą T) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hŌÜ;
  constructor;
  . simpa using hŌÜ 0;
  . have this := hŌÜ (encod ŌÜ + 1);
