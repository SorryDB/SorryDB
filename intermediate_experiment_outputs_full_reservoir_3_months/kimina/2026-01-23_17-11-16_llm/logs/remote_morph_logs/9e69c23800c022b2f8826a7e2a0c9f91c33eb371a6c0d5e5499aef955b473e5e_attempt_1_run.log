import Mathlib

open Complex

/- The main theorem of information theory for hypothesis testing
  in the limit of large numbers of observations. -/
theorem optimalHypothesisRateAsymptotics
    {ι : Type u_1} [inst : UnitalFreeStateTheory ι]
    {i : ι} {ρ : MState (H i)} {σ : (n : ℕ) → ↑IsFree}
    {ε : Prob} {m : ℕ} (hm : m ≥ 1) :
    Filter.liminf
        (fun n => (OptimalHypothesisRate ((pinching_map (σ m)) (statePow ρ n)) ε (statePow ρ n)).negLog / ↑n)
        Filter.atTop ≤
      ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε)) ∧
    Filter.limsup
        (fun n =>
            (OptimalHypothesisRate ((pinching_map (σ m)) (statePow ρ n)) (1 - ε) (statePow ρ n)).negLog / ↑n)
        Filter.atTop ≤
      ↑(ENNReal.toNNReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ⟨@SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε', ⋯⟩) := by
  sorry

/- The following is a generalization of the main result in the paper
  "A Generalized Stein's Lemma for Hypothesis Testing" by
  Anand G. Bharath, N. Srivastava, and Y. S. Pilla. -/
