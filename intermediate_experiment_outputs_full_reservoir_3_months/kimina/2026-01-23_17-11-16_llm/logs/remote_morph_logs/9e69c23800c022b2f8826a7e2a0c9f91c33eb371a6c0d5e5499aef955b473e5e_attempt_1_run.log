import Mathlib

/- The main goal is to prove the following inequality for the relative entropy of a state with respect to a reference state, where the state is pinched by a sequence of projections that approach the identity:
  `hS88: (n : ℝ)⁻¹ * ((↑((ℰ n (statePow ρ n))).log - ↑(↑(@SteinsLemma.σ'' ...))).log).inner (↑(E1 ε2 n) + ↑(E2 ε2 n) + ↑(E3 ε2 n))) ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R1 ...)) + ↑(ENNReal.toNNReal (@SteinsLemma.R2 ...)) * ↑(ENNReal.toNNReal ε₀) + ↑(ENNReal.toNNReal ε₀) * ↑(ENNReal.toNNReal ε₀) -/
theorem hS88 ε2 n (hε2 : 0 < ε2) (hn : 0 < n) : (n : ℝ)⁻¹ * ((↑((ℰ n (statePow ρ n))).log - ↑(↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n))).log).inner (↑(E1 ε2 n) + ↑(E2 ε2 n) + ↑(E3 ε2 n))) ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε)) + ↑(ENNReal.toNNReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ)) * ↑(ENNReal.toNNReal ε₀) + ↑(ENNReal.toNNReal ε₀) * ↑(ENNReal.toNNReal ε₀) := by
  -- h1, h2, h3 are the three inequalities from the previous steps (S81, S82, S85)
  have h1 := hE1leq ε2 n hε2
  have h2 := hE2leq ε2 n hε2
  have h3 := hE3leq ε2 n hε2
  -- h4 is the equality for the left-hand side of the sum
  have h4 : (n : ℝ)⁻¹ * ((↑((ℰ n (statePow ρ n))).log - ↑(↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n))).log).inner (↑(E1 ε2 n) + ↑(E2 ε2 n) + ↑(E3 ε2 n))) =
      (n : ℝ)⁻¹ * ((↑((ℰ n (statePow ρ n))).log - ↑(↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n))).log).inner (↑(E1 ε2 n)) +
      (n : ℝ)⁻¹ * ((↑((ℰ n (statePow ρ n))).log - ↑(↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n))).log).inner (↑(E2 ε2 n)) +
      (n : ℝ)⁻¹ * ((↑((ℰ n (statePow ρ n))).log - ↑(↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n))).log).inner (↑(E3 ε2 n)) := by
    simp [add_mul]
    <;> ring_nf <;> simp [ENNReal.ofReal_add]
    <;> ring_nf <;> simp [ENNReal.ofReal_add]
    <;> ring_nf <;> simp [ENNReal.ofReal_add]
    <;> ring_nf
  -- h5 is the equality for the right-hand side of the sum
  have h5 : ((R1 ρ ε).toReal + ε2) * ((↑((ℰ n (statePow ρ n))).log).inner (↑(E1 ε2 n))) +
      ((R2 ρ σ).toReal + ε₀ + ε2) * ((↑((ℰ n (statePow ρ n))).log).inner (↑(E2 ε2 n))) +
      (c' ε2 n) * ((↑((ℰ n (statePow ρ n))).log).inner (↑(E3 ε2 n))) =
      ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε)) + ↑(ENNReal.toNNReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ)) * ↑(ENNReal.toNNReal ε₀) + ↑(ENNReal.toNNReal ε₀) * ↑(ENNReal.toNNReal ε₀) := by
    simp [ENNReal.ofReal_add, ENNReal.ofReal_mul]
    <;> ring_nf <;> simp [ENNReal.ofReal_add, ENNReal.ofReal_mul]
    <;> ring_nf <;> simp [ENNReal.ofReal_add, ENNReal.ofReal_mul]
    <;> ring_nf
  rw [h4]
  rw [h5] at *
  apply add_le_add_three
  · linarith
  · linarith
  · linarith
