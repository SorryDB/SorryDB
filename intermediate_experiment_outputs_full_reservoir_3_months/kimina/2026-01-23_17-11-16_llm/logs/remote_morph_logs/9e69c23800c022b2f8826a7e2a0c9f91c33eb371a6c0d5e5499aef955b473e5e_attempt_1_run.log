import Mathlib

/- Given a free probability space, a state ρ, a sequence of states σ, and parameters ε, ε', δ, this theorem provides a bound on the relative entropy of pinched states. The bound is expressed in terms of R1, R2, and ε₀, which are quantities related to the free probability theory. The theorem is useful in the study of large deviations for random matrices and quantum states. -/
theorem SteinsLemma {ι : Type u_1} [inst : UnitalFreeStateTheory ι] [i : ι] [ρ : MState (H i)] [σ : (n : ℕ) → ↑IsFree]
    (ε ε' : Prob) (hε'₁ : 0 < ε') (hε'₂ : ε' < ε) (hε : ε < 1)
    (hR1R2 : @SteinsLemma.R1✝ ι inst✝ i ρ ε < @SteinsLemma.R2✝ ι inst✝ i ρ σ)
    (hR1 : @SteinsLemma.R1✝ ι inst✝ i ρ ε ≠ ⊤)
    (hR2 : @SteinsLemma.R2✝ ι inst✝ i ρ σ ≠ ⊤)
    (hε₀✝ : 0 < @SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε')
    (m : ℕ) (hm : m ≥ 1) (hliminf_le : Filter.liminf (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ m)) ε (@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ m)).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R1✝ ι inst✝ i ρ ε)))
    (hlimsup_le : ∀ (ε1 : Prob), 0 < ↑ε1 ∧ ↑ε1 < 1 → Filter.limsup (fun n => (OptimalHypothesisRate ((ℰ n) (statePow ρ m)) (1 - ε1) (@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ m)).negLog / ↑n) Filter.atTop ≤ ↑(ENNReal.toNNReal (@SteinsLemma.R2✝ ι inst✝ i ρ σ) + ⟨@SteinsLemma.ε₀_func✝ ι inst✝ i ρ ε σ ε', ⋯⟩))
    (hc' : ∀ (ε2 : ℕ → NNReal), (∀ (n : ℕ), ε2 n < 1) → ∃ C, ∀ᶠ (n : ℕ) in Filter.atTop, c' (↑(ε2 n)) n ≤ ↑C) (hσ'' : ∀ (ε2 : ℝ) (n : ℕ), Real.exp (-↑n * c' ε2 n) • 1 ≤ ↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n))
    (hE3comm : ∀ (ε2 : ℝ) (n : ℕ), Commute ↑(E3 ε2 n) ↑(↑((ℰ n) (statePow ρ n)).log)) :
    ∀ (ε2 : ℝ) (n : ℕ), (n : ℝ)⁻¹ • ↑(E3 ε2 n) * (↑(↑((ℰ n) (statePow ρ n))).log - ↑(↑(@SteinsLemma.σ''✝ ι inst✝ i ρ ε m σ n)).log) ≤ c' ε2 n • ↑(E3 ε2 n) := by
  intro ε2 n
  simp [ENNReal.ofReal_nonneg, MState.toMat_nonneg, P1, inner_nonneg]
  <;> positivity
