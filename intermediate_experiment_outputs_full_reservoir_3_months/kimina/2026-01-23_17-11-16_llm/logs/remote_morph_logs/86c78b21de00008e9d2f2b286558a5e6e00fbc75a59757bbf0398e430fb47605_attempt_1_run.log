def median (xs : List a) : a :=
  let k := (xs.length + 1) / 2
  selectвӮҖ k xs


def group (n : Nat) (xs : List a) : List (List a) :=
  if      hвӮҒ : n = 0   then []
  else if hвӮӮ : xs = [] then []
  else
   let p := xs.splitAt n
   have : xs.length - n < xs.length := by
    induction xs with
    | nil => simp at *
    | cons b bs ih =>
      simp ; omega
   p.1 :: (group n p.2)
 termination_by xs.length

