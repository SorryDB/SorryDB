namespace Chapter6

open Chapter1 (unwrap until' single)
open Chapter5.Mergesort (pairWith halve length_halve_fst length_halve_snd)
open Chapter5.Quicksort (qsortвӮҒ)
open Chapter4.BST2 (partition3)


-- # Section 6.1: minimum and maximum

variable {a : Type}
  [Inhabited a] [DecidableRel (Оұ := a) (В· = В·)]
  [Max a] [Min a]
  [LT a] [DecidableRel (Оұ := a) (В· < В·)]
  [LE a] [DecidableRel (Оұ := a) (В· вүӨ В·)]


def foldr1вӮҖ (f : a вҶ’ a вҶ’ a) (xs : List a) (h : xs вү  []) : a
  :=
  if hвӮҒ : xs.length = 1 then
    xs.head (by simp [h])
  else
    let b :: bs := xs
    f b (foldr1вӮҖ f bs (by
      intro hвӮӮ; apply hвӮҒ ; rw [hвӮӮ]; simp))

def foldr1 (f : a вҶ’ a вҶ’ a) : List a вҶ’ a
  | []    => default
  | [x]   => x
  | x::xs => f x (foldr1 f xs)

def foldl1 (f : a вҶ’ a вҶ’ a) : List a вҶ’ a
  | []    => default
  | x::xs => xs.foldl f x

def minimum : List a вҶ’ a :=
  foldr1 min

def maximum : List a вҶ’ a :=
  foldr1 max

def minmaxвӮҖ : List a вҶ’ (a Г— a)
  | []      => default
  | x :: xs =>
    let op x q := (min x q.1, max x q.2)
    xs.foldr op (x,x)

def minmaxвӮҒ : List a вҶ’ (a Г— a)
  | []      => default
  | x :: xs =>
    let op x q :=
      if      x < q.1 then (x, q.2)
      else if x > q.2 then (q.1, x)
      else (q.1, q.2)
    xs.foldr op (x,x)

def minmaxвӮӮ : List a вҶ’ (a Г— a)
  | []      => default
  | x :: xs =>
    if      hвӮҒ : xs.length = 0 then (x, x)
    else if hвӮӮ : xs.length = 1 then
     have hвӮғ : xs вү  [] := by
      intro h; apply hвӮҒ
      apply List.length_eq_zero_iff.mpr; assumption
     if x вүӨ xs.head hвӮғ then (x, xs.head hвӮғ) else (xs.head hвӮғ, x)
    else
     let p := halve xs
     have : (halve xs).fst.length < xs.length := by
      simp [length_halve_fst]; omega
     have : (halve xs).snd.length < xs.length := by
      simp [length_halve_snd]; omega
     let q := minmaxвӮӮ p.1
     let r := minmaxвӮӮ p.2
     (min q.1 r.1, max q.2 r.2)
termination_by xs => xs.length


def mkPairs : List a вҶ’ List (a Г— a)
  | []           => []
  | [x]          => [(x, x)]
  | x :: y :: xs =>
    if x вүӨ y then
     (x, y) :: mkPairs xs
    else
     (y, x) :: mkPairs xs


def minmax (xs : List a) : (a Г— a) :=
  let op p q := (min p.1 q.1, max p.2 q.2)
  (unwrap вҲҳ until' single (pairWith op) вҲҳ mkPairs) xs
    |>.getD default


-- # Section 6.2: selection from one set

/-
#check let xs := [1,2,3];
 xs.get (Fin.mk 2 (by simp [List.length]) : Fin xs.length)
-/

def selectвӮҖ (k : Nat) (xs : List a) : a :=
 (qsortвӮҒ xs)[k - 1]!

def median (xs : List a) : a :=
  let k := (xs.length + 1) / 2
  selectвӮҖ k xs


def group (n : Nat) (xs : List a) : List (List a) :=
  if      hвӮҒ : n = 0   then []
  else if hвӮӮ : xs = [] then []
  else
   let p := xs.splitAt n
   have : xs.length - n < xs.length := by
    induction xs with
    | nil => simp at *
    | cons b bs ih =>
      simp ; omega
   p.1 :: (group n p.2)
 termination_by xs.length

-- #eval group 5 (List.range' 1 12)

/- `qsortвӮҒ` or `qsort` ? -/
def medians : List a вҶ’ List a :=
  let middle (xs : List a) := xs[((xs.length + 1) / 2) - 1]!
  List.map (middle вҲҳ qsortвӮҒ) вҲҳ group 5


/- `selectвӮҖ` or `select` ? -/
def pivot : List a вҶ’ a
  | [x] => x
  | xs  =>
    let median xs := selectвӮҖ ((xs.length + 1) / 2) xs
    median (medians xs)


partial def qsort : List a вҶ’ List a
  | [] => []
  | xs =>
    let p := partition3 (pivot xs) xs
    qsort p.1 ++ p.2.1 ++ qsort p.2.2


/- this function breaks with k > xs.length -/
partial def select
  (k : Nat) (xs : List a) (ok : k вүӨ xs.length) : a :=
  match partition3 (pivot xs) xs with
  | (us, vs, ws) =>
    let m := us.length
    let n := vs.length
    if         hвӮҒ : k вүӨ m then select k us (by sorry)
    else if hвӮӮ : k вүӨ m + n then vs[k - m - 1]'(by sorry)
```

