lemma isInternal (I : DirectSumDecomposition M) (c : C) :
    IsInternal (M := M c) (S := Submodule K (M c)) fun p : I ↦ p.val c := by
  have h1 : sSup (fun (p : I) => p.val c) = ⊤ := by
