import HTPILib.Chap8Part2
namespace HTPI.Exercises

open Classical

/- Section 8.1 -/
-- 1.
--Hint:  Use Exercise_6_1_16a2 from the exercises of Section 6.1
lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := sorry

-- 2.
lemma fnz_fzn : fnz ∘ fzn = id  := sorry

-- 3.
lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := sorry

-- 4.
lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := sorry

-- 5.
example {U V : Type} (f : U → V) : range f = Ran (graph f) := sorry

-- 6.
lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := by
  constructor
  · -- Assume f is onto, prove range f = V
    intro h
    ext v
    simp at *
    <;> try { 
      constructor 
      · -- Assume v ∈ range f, prove v ∈ V
        rintro ⟨u, hu⟩
        tauto
      · -- Assume v ∈ V, prove v ∈ range f
        intro h
        have h2 : v ∈ range f := by
          have h3 : ∃ u : U, f u = v := h v
          simpa using h3
        tauto
    }
  · -- Assume range f = V, prove f is onto
    intro h
    intro v hv
    have h1 : v ∈ range f := by
      rw [show range f = Univ V by exact_mod_cast h]
      simp at *
    rcases h1 with ⟨u, hu⟩
    exact ⟨u, hu⟩
```

This proof seems correct now. The first direction shows that if `f` is onto, then `range f = V`. The second direction shows that if `range f = V`, then `f` is onto.
