    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  obtain ⟨M', hM', hM'cd⟩ := by
    simpa only [isMaxMatching_iff, hM, true_and, not_forall, not_le] using hnotmax
  have hM'_diff : (M' ∆ M).IsSubgraph (M' ∪ M) := by
    simp [symmDiff_subset]
  have hM'_diff_nonempty : (M' ∆ M).Nonempty := by
    simp [symmDiff_nonempty_iff, hM'cd]
  obtain ⟨e, he⟩ := hM'_diff_nonempty
  have he_mem : e ∈ M' ∆ M := by
    simpa using he
  have hM'_diff_eq : M' ∆ M = (M' \ M) ∪ (M \ M') := by
    ext e
    simp [symmDiff_eq]
