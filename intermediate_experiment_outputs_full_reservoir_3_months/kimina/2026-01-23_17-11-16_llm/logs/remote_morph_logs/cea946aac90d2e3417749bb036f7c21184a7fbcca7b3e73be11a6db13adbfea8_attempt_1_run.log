structure IsMatching (G : Graph α β) (M : Set β) : Prop where
  subset : M ⊆ E(G)
  disjoint : ∀ ⦃e f⦄, e ∈ M → f ∈ M → e ≠ f → Disjoint V(G, e) V(G, f)

/- A maximum matching is a matching with maximum cardinality. -/
@[mk_iff]
structure IsMaxMatching (G : Graph α β) (M : Set β) : Prop extends G.IsMatching M where
  max : ∀ M', G.IsMatching M' → M'.encard ≤ M.encard

noncomputable def MatchingNumber (G : Graph α β) : ℕ∞ :=
  sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard}

/- The number of vertices in the matching `M` is equal to the matching number of `G`. -/
theorem IsMaxMatching.encard (h : G.IsMaxMatching M) : M.encard = ν(G) := by
  have h1 : M.encard = ν(G) := by
    have h3 : M.encard = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by
      rw [show sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} = M.encard by
        rw [←h]
        apply le_antisymm
        · -- Show M.encard ≤ sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard}
          apply sSup_le
          use M
          all_goals tauto
        · -- Show sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} ≤ M.encard
          apply le_sSup
          intro n hn
          rcases hn with ⟨M', hM', hn⟩
          have h4 : M'.encard ≤ M.encard := by
            have h5 : G.IsMaxMatching M := h
            have h6 : G.IsMatching M' := hM'
            have h7 : M'.encard ≤ M.encard := by
              apply h5.le_max
              exact h6
            exact h7
          linarith
      ]
    rw [h3]
    all_goals try { simp [MatchingNumber] }
    all_goals try { tauto }
  exact h1
