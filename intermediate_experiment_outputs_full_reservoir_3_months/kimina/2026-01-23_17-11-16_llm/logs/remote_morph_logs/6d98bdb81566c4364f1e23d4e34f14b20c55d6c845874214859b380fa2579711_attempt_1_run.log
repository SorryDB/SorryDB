      apply sSup_le
      intro x hx
      simp at hx
      rcases hx with ⟨v, hv⟩
      have h7 : (hM.restrict₂ hM').degree v ≤ 2 := h5 v
      have h8 : x = (hM.restrict₂ hM').degree v := by
        simp at *
        try { tauto }
      linarith
    linarith
  exact_mod_cast h2
