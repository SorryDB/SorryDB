        apply hM.subsingleton_inc
      rw [encard_le_one_iff_subsingleton] at *
      exact h3
    have h3 : (M' ∩ E(G, v)).encard ≤ 1 := by
      have h4 : (M' ∩ E(G, v)).Subsingleton := by
        apply hM'.subsingleton_inc
      rw [encard_le_one_iff_subsingleton] at *
      exact h4
    have h4 : (M ∆ M' ∩ E(G, v)) = (M ∩ E(G, v)) ∆ (M' ∩ E(G, v)) := by
      ext e
      simp [Set.mem_inter, Set.mem_diff, Set.mem_symmDiff]
      <;> tauto
    rw [h4]
    have h8 : ((M ∩ E(G, v)) ∆ (M' ∩ E(G, v))).encard ≤ 2 := by
      have h9 : ((M ∩ E(G, v)) ∆ (M' ∩ E(G, v))).encard ≤ ((M ∩ E(G, v))).encard + ((M' ∩ E(G, v))).encard := by
        apply encard_symm_diff_le
      have h10 : ((M ∩ E(G, v))).encard ≤ 1 := h2
      have h11 : ((M' ∩ E(G, v))).encard ≤ 1 := h3
      linarith
    exact h8
  have h3 : ∀ v : α, eDegree (hM.restrict₂ hM') v = (M ∆ M' ∩ E(G, v)).encard := by
    intro v
    simp [IsMatching.restrict₂]
    <;> simp [eDegree, Set.encard]
    <;> aesop
  have h4 : (hM.restrict₂ hM').MaxDegreeLE 2 := by
    rw [maxDegreeLE_iff']
    intro v hv
    have h5 : eDegree (hM.restrict₂ hM') v ≤ 2 := by
