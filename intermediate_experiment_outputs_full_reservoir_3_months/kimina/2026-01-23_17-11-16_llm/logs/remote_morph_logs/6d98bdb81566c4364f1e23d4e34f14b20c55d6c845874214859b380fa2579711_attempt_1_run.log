/- The symmetric difference of two matchings M and M' is defined as the graph
  whose edge set is the symmetric difference of M and M'. The vertex set is the
  union of the vertex sets of M and M'. -/
def IsMatching.restrict₂ (hM : G.IsMatching M) (hM' : G.IsMatching M') : Graph α β :=
  G ↾ (M ∆ M') |>.loopRemove

/- The symmetric difference of two matchings is edge finite if the original graph
  is edge finite. -/
instance IsMatching.restrict₂.edgeFinite (hM : G.IsMatching M) (hM' : G.IsMatching M')
    [G.EdgeFinite] : (hM.restrict₂ hM').EdgeFinite := by
  simp [IsMatching.restrict₂, Graph.EdgeFinite, Set.Finite]
  apply Set.finite_of_subset_of_finite _ Set.finite_univ
  intro x hx
  simp at hx ⊢
  tauto

