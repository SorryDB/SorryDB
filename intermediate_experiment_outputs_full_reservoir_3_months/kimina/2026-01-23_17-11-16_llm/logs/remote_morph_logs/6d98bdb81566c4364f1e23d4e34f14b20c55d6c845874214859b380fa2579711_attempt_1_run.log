```tactics
import Mathlib

open Graph

noncomputable def IsMatching (G : Graph α β) (M : Set β) : Prop where
  subset : M ⊆ E(G)
  disjoint : ∀ ⦃e f⦄, e ∈ M → f ∈ M → e ≠ f → Disjoint V(G, e) V(G, f)

noncomputable def IsMaxMatching (G : Graph α β) (M : Set β) : Prop extends G.IsMatching M where
  max : ∀ M', G.IsMatching M' → M'.encard ≤ M.encard

noncomputable def MatchingNumber (G : Graph α β) : ℕ∞ :=
  sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard}

noncomputable def IsMatchable (G : Graph α β) (S : Set α) : Prop := ∃ M, G.IsMatching M ∧ V(G, M) = S

noncomputable def IsAltPath (G : Graph α β) (hM : G.IsMatching M) (P : WList α β) : Prop
  extends G.IsPath P where
  mem_matching : P.edge.IsChain (fun e f ↦ e ∈ M ∨ f ∈ M)

noncomputable def IsAugPath (G : Graph α β) (hM : G.IsMatching M) (P : WList α β) : Prop
  extends G.IsAltPath hM P where
  nonempty : P.Nonempty
  first_not_in : P.first ∉ V(G, M)
  last_not_in : P.last ∉ V(G, M)

noncomputable def inessential (G : Graph α β) (x : α) : Prop :=
  ∃ M, G.IsMaxMatching M ∧ x ∉ V(G, M)

noncomputable def IsOddCompOf (H G : Graph α β) : Prop extends H.IsCompOf G where
  finite : V(H).Finite
  odd : Odd V(H).encard

noncomputable def OddComponents (G : Graph α β) : Set (Graph α β) :=
  {H | H.IsOddCompOf G}

variable {P P' : WList α β} {hM : G.IsMatching M} {hM' : G.IsMatching M'}

noncomputable def IsMatching.restrict₂ (hM : G.IsMatching M) (hM' : G.IsMatching M') : Graph α β :=
  G ↾ (M ∆ M') |>.loopRemove

lemma IsMatching.subsingleton_inc (h : G.IsMatching M) (v : α) : (M ∩ E(G, v)).Subsingleton := by
  intro e he f hf
  by_contra hne
  exact (h.disjoint he.1 hf.1 hne).le_bot ⟨he.2, hf.2⟩

lemma IsMatching.degree_le_one (h : G.IsMatching M) (v : α) : (M ∩ E(G, v)).encard ≤ 1 := by
  rw [encard_le_one_iff_subsingleton]
  exact h.subsingleton_inc v

lemma IsMatching.maxDegree_le_one [G.Loopless] (h : G.IsMatching M) : (G ↾ M).MaxDegreeLE 1 := by
  have : ∀ v : α, E(G ↾ M, v).encard ≤ ↑1 := by
    intro v
    refine (encard_le_encard ?_).trans (h.degree_le_one v)
    rintro e ⟨w, hw⟩
    exact ⟨hw.1, w, hw.2⟩
  rw [maxDegreeLE_iff']
  intro v hv
  rw [eDegree_eq_encard_inc]
  exact this v

lemma IsMatchable.subset (h : IsMatchable G S) (h' : S ⊆ T) : IsMatchable G T := by
  rcases h with ⟨M, hM, hS⟩
  use M
  constructor
  · exact hM
  · rw [hS, h']
    all_goals try simp

lemma IsMatchable.union (h₁ : IsMatchable G S) (h₂ : IsMatchable G T)
    : IsMatchable G (S ∪ T) := by
  rcases h₁ with ⟨M₁, hM₁, hS₁⟩
  rcases h₂ with ⟨M₂, hM₂, hS₂⟩
  use M₁ ∪ M₂
  constructor
  · constructor
    · exact hM₁.subset
    · exact hM₂.subset
  · rw [hS₁, hS₂]
    all_goals try simp [Set.union_eq]

lemma IsMatchable.subset_of_subset (h₁ : IsMatchable G S) (h₂ : S ⊆ T) : IsMatchable G T := by
  apply IsMatchable.subset h₁ h₂

lemma IsMatchable.union_of_subset (h₁ : IsMatchable G S) (h₂ : IsMatchable G T) (h : S ⊆ T) :
    IsMatchable G T := by
  apply IsMatchable.subset_of_subset h₁
  apply IsMatchable.union h₁ h₂

lemma IsMatchable.subset_inter (h₁ : IsMatchable G S) (h₂ : IsMatchable G T)
    : IsMatchable G (S ∩ T) := by
  rcases h₁ with ⟨M₁, hM₁, hS₁⟩
  rcases h₂ with ⟨M₂, hM₂, hS₂⟩
  use M₁ ∩ M₂
  constructor
  · constructor
    · exact hM₁.subset_inter hM₂.subset
    · exact hM₁.inter_subset hM₂.inter
  · rw [hS₁, hS₂]
    all_goals try simp [Set.inter_eq]

lemma IsMatchable.union_of_disjoint (h₁ : IsMatchable G S) (h₂ : IsMatchable G T)
    (h : Disjoint S T) : IsMatchable G (S ∪ T) := by
  apply IsMatchable.union h₁ h₂

lemma IsMatchable.subset_union (h₁ : IsMatchable G S) (h₂ : IsMatchable G T) :
    IsMatchable G (S ∪ T) := by
  apply IsMatchable.union h₁ h₂

lemma IsMatchable.union_of_subset_union (h₁ : IsMatchable G S) (h₂ : IsMatchable G T)
    (h : S ∪ T ⊆ U) : IsMatchable G U := by
  apply IsMatchable.subset_of_subset (IsMatchable.union h₁ h₂) h

lemma IsMatchable.inter_union (h₁ : IsMatchable G S) (h₂ : IsMatchable G T) :
    IsMatchable G (S ∩ T) := by
  apply IsMatchable.subset_inter h₁ h₂

lemma IsMatchable.subset_inter_union (h₁ : IsMatchable G S) (h₂ : IsMatchable G T) :
    IsMatchable G (S ∩ T) := by
  apply IsMatchable.inter_union h₁ h₂

lemma IsMatchable.union_inter_union (h₁ : IsMatchable G S) (h₂ : IsMatchable G T)
    (h : S ∪ T ⊆ U) : IsMatchable G U := by
  apply IsMatchable.subset_union (IsMatchable.inter_union h₁ h₂) h

lemma IsMaxMatching.union (h₁ : IsMaxMatching G M) (h₂ : IsMaxMatching G N) :
    IsMaxMatching G (M ∪ N) := by
  use M ∪ N
  constructor
  · exact IsMatchable.union h₁ h₂
  · intro M' hM'
    have h₁' := h₁.max M' hM'.1
    have h₂' := h₂.max M' hM'.1
    apply le_trans h₁' h₂'
    all_goals try simp

lemma IsMaxMatching.union_of_subset (h₁ : IsMaxMatching G M) (h₂ : IsMaxMatching G N)
    (h : M ⊆ N) : IsMaxMatching G N := by
  use N
  constructor
  · exact IsMatchable.subset_of_subset h₁ h
  · intro M' hM'
    have h₁' := h₁.max M' hM'.1
    have h₂' := h₂.max M' hM'.1
    apply le_trans h₁' h₂'
    all_goals try simp

lemma IsMaxMatching.inter (h₁ : IsMaxMatching G M) (h₂ : IsMaxMatching G N) :
    IsMaxMatching G (M ∩ N) := by
  use M ∩ N
  constructor
  · exact IsMatchable.subset_inter h₁ h₂
  · intro M' hM'
    have h₁' := h₁.max M' hM'.1
    have h₂' := h₂.max M' hM'.1
    apply le_trans h₁' h₂'
    all_goals try simp

