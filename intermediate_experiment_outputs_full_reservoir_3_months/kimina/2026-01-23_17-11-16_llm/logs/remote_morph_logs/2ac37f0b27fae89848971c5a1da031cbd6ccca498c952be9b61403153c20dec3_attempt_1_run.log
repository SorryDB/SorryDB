        have h13 : p ^ 2 > P.n := h5
        have h14 : (p : ℝ) ^ 2 > (P.n : ℝ) := by exact_mod_cast h13
        have h15 : (p : ℝ) ≤ Real.sqrt (P.n : ℝ) := by
          nlinarith [Real.sqrt_nonneg (P.n : ℝ), Real.sq_sqrt (show 0 ≤ (P.n : ℝ) by positivity)]
        exact_mod_cast h15
      exact_mod_cast h12
