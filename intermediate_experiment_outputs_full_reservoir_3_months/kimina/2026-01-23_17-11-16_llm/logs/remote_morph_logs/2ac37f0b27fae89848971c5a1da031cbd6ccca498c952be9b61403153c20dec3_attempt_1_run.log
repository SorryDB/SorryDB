  have h7 : p.Prime := by
    by_contra h
    push_neg at h
    have h8 : ¬p.Prime := by
      exact_mod_cast h
    have h9 : p ≤ P.n / P.L := hp
    have h10 : p > Real.sqrt (P.n : ℝ) := h3
    have h11 : p ≤ Real.sqrt (P.n : ℝ) := by
