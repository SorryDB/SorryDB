theorem Factorization.lower_score_1 {n : ℕ} (f : Factorization n) (L : ℕ)
    (hf : ∃ p ∈ (n + 1).primesBelow, p ≤ L ∧ f.balance p > 0) : ∃ f' :
    Factorization n, f'.total_imbalance < f.total_imbalance ∧ f'.score L ≤ f.score L := by
  obtain ⟨p, hp, hpL, hf⟩ := hf
  let f' := f - (p ^ (f.balance p)).factorization
  use f'
  constructor
  · -- Show that the total imbalance of f' is less than that of f
    have h_total_imbalance : f'.total_imbalance < f.total_imbalance := by
      rw [total_imbalance_eq f']
      rw [Nat.add_sub_cancel_left, ← add_zero (p ^ (f.balance p).factorization.card)]
      rw [Nat.add_lt_add_iff_left]
