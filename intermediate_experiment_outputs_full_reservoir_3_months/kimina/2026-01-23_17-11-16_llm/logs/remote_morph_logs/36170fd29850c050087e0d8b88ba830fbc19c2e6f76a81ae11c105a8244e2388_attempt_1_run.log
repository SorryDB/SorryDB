import LeanAPAP.Prereqs.Inner.Hoelder.Discrete
import LeanAPAP.Prereqs.LpNorm.Compact

/-! # Inner product -/

open Finset hiding card
open Fintype (card)
open Function MeasureTheory RCLike Real
open scoped BigOperators ComplexConjugate ENNReal NNReal NNRat

variable {őĻ őļ : Type*} [Fintype őĻ]

namespace RCLike
variable [RCLike ūĚēú] {mőĻ : MeasurableSpace őĻ} [DiscreteMeasurableSpace őĻ] {f : őĻ ‚Üí ūĚēú}

@[simp] lemma wInner_cWeight_self (f : őĻ ‚Üí ūĚēú) :
    ‚ü™f, f‚üę‚āô_[ūĚēú] = ((‚ÄĖf‚ÄĖ‚āô_[2] : ‚ĄĚ) : ūĚēú) ^ 2 := by
  simp_rw [‚Üź algebraMap.coe_pow, ‚Üź NNReal.coe_pow]
  simp [cL2Norm_sq_eq_expect_nnnorm, wInner_cWeight_eq_expect]

lemma cL1Norm_mul (f g : őĻ ‚Üí ūĚēú) : ‚ÄĖf * g‚ÄĖ‚āô_[1] = ‚ü™fun i ‚Ü¶ ‚ÄĖf i‚ÄĖ, fun i ‚Ü¶ ‚ÄĖg i‚ÄĖ‚üę‚āô_[‚ĄĚ] := by
  simp [wInner_cWeight_eq_expect, cL1Norm_eq_expect_nnnorm, mul_comm]

/-- **Cauchy-Schwarz inequality** -/
lemma wInner_cWeight_le_cL2Norm_mul_cL2Norm (f g : őĻ ‚Üí ‚ĄĚ) : ‚ü™f, g‚üę‚āô_[‚ĄĚ] ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[2] * ‚ÄĖg‚ÄĖ‚āô_[2] := by
  simp only [wInner_cWeight_eq_smul_wInner_one, cL2Norm_eq_expect_nnnorm, ‚Üź NNReal.coe_mul, expect,
    ‚Üź NNRat.cast_smul_eq_nnqsmul ‚ĄĚ‚Č•0, smul_eq_mul, ‚Üź NNReal.mul_rpow, mul_mul_mul_comm, ‚Üź sq]
  simp only [NNReal.mul_rpow, ‚Üź dL2Norm_eq_sum_nnnorm, card_univ]
  rw [‚Üź NNReal.rpow_two, NNReal.rpow_rpow_inv two_ne_zero, NNReal.smul_def, smul_eq_mul]
  push_cast
  gcongr
  exact wInner_one_le_dL2Norm_mul_dL2Norm _ _

end RCLike

/-! ### H√∂lder inequality -/

namespace MeasureTheory
section Real
variable {őĪ : Type*} {mőĪ : MeasurableSpace őĪ} [DiscreteMeasurableSpace őĪ] [Fintype őĪ] {p q : ‚ĄĚ‚Č•0}
  {f g : őĪ ‚Üí ‚ĄĚ}

lemma cL1Norm_mul_of_nonneg (hf : 0 ‚Č§ f) (hg : 0 ‚Č§ g) : ‚ÄĖf * g‚ÄĖ‚āô_[1] = ‚ü™f, g‚üę‚āô_[‚ĄĚ] := by
  convert cL1Norm_mul f g using 2 <;> ext a <;> refine (norm_of_nonneg ?_).symm; exacts [hf _, hg _]

/-- **H√∂lder's inequality**, binary case. -/
lemma wInner_cWeight_le_cLpNorm_mul_cLpNorm (p q : ‚ĄĚ‚Č•0‚ąě) [p.HolderConjugate q] :
    ‚ü™f, g‚üę‚āô_[‚ĄĚ] ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] := by
  sorry
  -- have hp := hpq.ne_zero
  -- have hq := hpq.symm.ne_zero
  -- norm_cast at hp hq
  -- rw [wInner_cWeight_eq_expect, expect_eq_sum_div_card, cLpNorm_eq_expect_nnnorm hp,
  --   cLpNorm_eq_expect_nnnorm hq, expect_eq_sum_div_card, expect_eq_sum_div_card,
  --   NNReal.div_rpow, NNReal.div_rpow, ‚Üź NNReal.coe_mul, div_mul_div_comm, ‚Üź NNReal.rpow_add,
  --   hpq.coe.inv_add_inv_conj, NNReal.rpow_one]
  -- swap
  -- ¬∑ simp [hpq.coe.inv_add_inv_conj]
  -- push_cast
  -- gcongr
  -- rw [‚Üź dLpNorm_eq_sum_norm hp, ‚Üź dLpNorm_eq_sum_norm hq, ‚Üź wInner_one_eq_sum]
  -- exact wInner_one_le_dLpNorm_mul_dLpNorm hpq.coe_ennreal _ _

/-- **H√∂lder's inequality**, binary case. -/
lemma abs_wInner_cWeight_le_dLpNorm_mul_dLpNorm (p q : ‚ĄĚ‚Č•0‚ąě) [p.HolderConjugate q] :
    |‚ü™f, g‚üę‚āô_[‚ĄĚ]| ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] :=
  (abs_wInner_le fun _ ‚Ü¶ by dsimp; positivity).trans <|
    (wInner_cWeight_le_cLpNorm_mul_cLpNorm p q).trans_eq <| by simp_rw [cLpNorm_abs]

end Real

