  rw [maxDegreeLE_iff']
  intro v hv
  rw [eDegree_eq_encard_inc]
  exact this v

lemma isMaxMatching_of_vertex_subset (hM : G.IsMatching M) (hsu : V(G) ⊆ V(G, M)) :
    G.IsMaxMatching M where
  toIsMatching := hM
  max M' hM' := by
