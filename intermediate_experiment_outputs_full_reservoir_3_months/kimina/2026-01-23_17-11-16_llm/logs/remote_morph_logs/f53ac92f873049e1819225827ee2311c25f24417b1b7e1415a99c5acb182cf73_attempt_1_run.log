def Category.IsRetract (X Y : α) := ∃ (f : Hom X Y), ∃ (g : Hom Y X), f ≫ g = id X

alias Category.IsRightInverse := Category.IsSection
alias Category.IsLeftInverse := Category.IsRetraction

