theorem Category.Mono_injection {X Y : α} (f : Hom X Y) (hf : Mono f) :
    ∀ c : α, Function.Injective (fun g : Hom c X => g ≫ f) := by
  intros g1 g2 h
  apply hf

theorem Category.Epi_surjection {X Y : α} (f : Hom X Y) (hf : Epi f) :
    ∀ c : α, Function.Injective (fun g : Hom Y c => f ≫ g) := by
  intros g1 g2 h
  apply hf

