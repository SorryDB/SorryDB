    (hf : Epi f) (hg : Epi g) : Epi (f ≫ g) := by
  sorry
lemma category.epi_of_comp_epi {X Y Z : α} (f : hom X Y) (g : hom Y Z)
    (hfg : Epi (f ≫ g)) : Epi g := by
  sorry

