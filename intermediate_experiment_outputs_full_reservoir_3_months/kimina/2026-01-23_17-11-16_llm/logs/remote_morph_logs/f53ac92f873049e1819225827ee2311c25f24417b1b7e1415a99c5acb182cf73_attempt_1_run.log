  Hom X Y := PLift (Y ≤ X) -- some universe gymnastics to move between Prop and Type
  id X := ⟨le_refl X⟩
  comp f g := ⟨le_trans g.down f.down⟩
  id_comp _ := rfl
  comp_id _ := rfl
  assoc _ _ _ := rfl

theorem Category.Poset_opp_eq_poset' [PartialOrder α] : (Poset α).opp = Poset' α := by sorry

-- lemma 1.2.3
lemma Category.iso_equiv {X Y : α} (f : Hom X Y) :
  [ IsIso f,
    ∀ c : α, Function.Bijective (fun g : Hom c X => g ≫ f),
    ∀ c : α, Function.Bijective (fun g : Hom Y c => f ≫ g)
  ].TFAE := by sorry

-- definition 1.2.7
def Category.Mono {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k
def Category.Epi {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k

lemma Category.mono_iff_injective {X Y : α} (f : Hom X Y) :
    Function.Injective f ↔ Mono f := by
  constructor
  · -- Assume f is injective, prove f is a mono
    intro hf
    intro h1 h2 h
    apply hf
    simpa using h
  · -- Assume f is a mono, prove f is injective
    intro hf
    intro x1 x2 h
    have h' : (id X) x1 = (id X) x2 := by simpa using h
    have h1 : (id X) x1 = x1 := rfl
    have h2 : (id X) x2 = x2 := rfl
    simp [h1, h2] at h'
    exact h'

lemma Category.epi_iff_surjective {X Y : α} (f : Hom X Y) :
    Function.Surjective f ↔ Epi f := by
  constructor
  · -- Assume f is surjective, prove f is an epi
    intro hf
    intro h1 h2 h
    have h3 : ∃ x, f x = h1 := hf h1
    have h4 : ∃ x, f x = h2 := hf h2
    obtain ⟨x1, hx1⟩ := h3
    obtain ⟨x2, hx2⟩ := h4
    simp [hx1, hx2] at h
    exact h
  · -- Assume f is an epi, prove f is surjective
    intro hf
    intro y
    have h1 : y = f (id Y) := by simp [hf]
    have h2 : ∃ x, f x = y := by
      use id Y
      all_goals simp [h1]
    exact h2

-- example 1.2.8
-- note we need to use Category.Hom and not just Hom,
-- because we are not in the namespace Category.
example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Mono f) :
    Function.Injective f := by
  apply Category.mono_iff_injective.mp hf

example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Epi f) :
    Function.Surjective f := by
  apply Category.epi_iff_surjective.mp hf

-- example 1.2.9
def Category.IsSection {X Y : α} (f : Hom Y X) (g : Hom X Y) := g ≫ f = id X
def Category.IsRetraction {X Y : α} (f : Hom X Y) (g : Hom Y X) := f ≫ g = id X
def Category.IsRetract (X Y : α) := ∃ (f : Hom X Y), ∃ (g : Hom Y X), f ≫ g = id X

