-- IsLeftInverse := IsRetraction

-- lemma 1.2.11 / exercise 1.2.iii
lemma Category.comp_mono_of_mono_mono {X Y Z : α} (f : Hom X Y) (g : Hom Y Z)
    (hf :Mono f) (hg :Mono g) :Mono (f ≫ g) := by
  apply mono_of_comp_mono
  intro c h1 h2 h
  have h3 := hf h1 h2 h
  exact h3

lemma Category.mono_of_comp_mono {X Y Z : α} (f : Hom X Y) (g : Hom Y Z)
    (hfg :Mono (f ≫ g)) :Mono f := by
  apply epi_of_comp_epi
  intro c h1 h2 h
