theorem category.split_epi_iff {X Y : α} (f : hom X Y) :
    split_epi f ↔
    ∀ (c : α), Function.Surjective fun g => comp g f := by
  apply Iff.intro
  · -- Forward implication: If f is split epi, then it's surjective on its domain
    intro h
    rcases h with ⟨g, hg⟩
    intro c
    use (g.comp id)
    simp [hg]
    <;> try tauto
  · -- Backward implication: If f is surjective on its domain, then it's split epi
    intro h
    have h2 : ∀ (c : α), Function.Surjective fun g => comp g f := h
    have h3 : ∃ (g : Hom Y X), f ≫ g = id X := by
      -- We need to construct a retraction g such that f ≫ g = id X
      -- Since f is surjective on its domain, for each x in X, there's some y in Y such that f(y) = x
      -- We can define g(x) to be such a y
      use (fun x => (h x).choose_spec)
      -- We need to show that f(g(x)) = x for all x in X
      intro x
      -- By surjectivity, there exists some y such that f(y) = x
      have h4 : (h x).exists := by simpa using h x
      -- Choose such a y
      rcases h4 with ⟨y, hy⟩
      -- Check that f(g(x)) = x
      simp [hy]
      <;> try tauto
    exact h3

-- exercise 1.2.ii.ii
theorem category.split_mono_iff {X Y : α} (f : hom X Y) :
    split_mono f ↔
    ∀ (c : α), Function.Surjective fun g => comp f g := by
  apply Iff.intro
