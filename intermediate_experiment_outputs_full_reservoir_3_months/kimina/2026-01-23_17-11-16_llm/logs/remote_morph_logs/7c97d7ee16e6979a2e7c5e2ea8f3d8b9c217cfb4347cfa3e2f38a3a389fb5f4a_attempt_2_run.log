    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := sorry

-- 10.
lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := by 
  have h1 : ∀ s, (image g) ∘ (image f) s = s := by 
    intro s 
    ext x 
    simp [Function.comp_apply]
    constructor 
