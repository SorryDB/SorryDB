  -- exact wInner_one_le_dLpNorm_mul_dLpNorm hpq.coe_ennreal _ _

/-- **H√∂lder's inequality**, binary case. -/
lemma abs_wInner_cWeight_le_dLpNorm_mul_dLpNorm (p q : ‚ĄĚ‚Č•0‚ąě) [p.HolderConjugate q] :
    |‚ü™f, g‚üę‚āô_[‚ĄĚ]| ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] :=
  (abs_wInner_le fun _ ‚Ü¶ by dsimp; positivity).trans <|
