section Hoelder
variable {őĪ : Type*} {mőĪ : MeasurableSpace őĪ} [DiscreteMeasurableSpace őĪ] [Fintype őĪ] [RCLike ūĚēú]
  {p q r : ‚ĄĚ‚Č•0‚ąě} {f g : őĪ ‚Üí ūĚēú}

lemma norm_wInner_cWeight_le (f g : őĪ ‚Üí ūĚēú) :
    ‚ÄĖ‚ü™f, g‚üę‚āô_[ūĚēú]‚ÄĖ‚āä ‚Č§ ‚ü™fun a ‚Ü¶ ‚ÄĖf a‚ÄĖ, fun a ‚Ü¶ ‚ÄĖg a‚ÄĖ‚üę‚āô_[‚ĄĚ] := by
  simpa [wInner_cWeight_eq_expect, norm_mul, mul_comm]
    using norm_expect_le (K := ‚ĄĚ) (f := fun i ‚Ü¶ conj (f i) * g i)

/-- **H√∂lder's inequality**, binary case. -/
lemma nnnorm_wInner_cWeight_le_dLpNorm_mul_dLpNorm (p q : ‚ĄĚ‚Č•0‚ąě) [p.HolderConjugate q] :
    ‚ÄĖ‚ü™f, g‚üę‚āô_[ūĚēú]‚ÄĖ‚āä ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] :=
  calc
    _ ‚Č§ ‚ü™fun a ‚Ü¶ ‚ÄĖf a‚ÄĖ, fun a ‚Ü¶ ‚ÄĖg a‚ÄĖ‚üę‚āô_[‚ĄĚ] := norm_wInner_cWeight_le _ _
    _ ‚Č§ ‚ÄĖfun a ‚Ü¶ ‚ÄĖf a‚ÄĖ‚ÄĖ‚āô_[p] * ‚ÄĖfun a ‚Ü¶ ‚ÄĖg a‚ÄĖ‚ÄĖ‚āô_[q] := wInner_cWeight_le_cLpNorm_mul_cLpNorm _ _
    _ = ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] := by simp_rw [cLpNorm_norm]

/-- **H√∂lder's inequality**, binary case. -/
lemma cLpNorm_mul_le (p q : ‚ĄĚ‚Č•0‚ąě) (hr‚āÄ : r ‚Č† 0) [hpqr : ENNReal.HolderTriple p q r] :
    ‚ÄĖf * g‚ÄĖ‚āô_[r] ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] := by
  obtain rfl | p := p
  ¬∑ sorry
  obtain rfl | q := q
  ¬∑ sorry
  obtain rfl | r := r
  ¬∑ sorry
  -- The following two come from `HolderTriple p q r`
  have hp‚āÄ : p ‚Č† 0 := sorry
  have hq‚āÄ : q ‚Č† 0 := sorry
  simp only [ENNReal.some_eq_coe] at *
  norm_cast at hr‚āÄ
  have : (‚ÄĖ(f * g) ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) = (‚ÄĖf ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) * (‚ÄĖg ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) := by ext; simp [mul_rpow]
  rw [cLpNorm_eq_cL1Norm_rpow, NNReal.rpow_inv_le_iff_of_pos, this, ‚Üź NNReal.coe_le_coe]
  any_goals positivity
  push_cast
  rw [cL1Norm_mul_of_nonneg, mul_rpow, ‚Üź NNReal.coe_rpow, ‚Üź NNReal.coe_rpow, cLpNorm_rpow',
    cLpNorm_rpow']
  any_goals intro a; dsimp
  any_goals positivity
  have := hpqr.holderConjugate_div_div _ _ _ (mod_cast hr‚āÄ) ENNReal.coe_ne_top
  exact wInner_cWeight_le_cLpNorm_mul_cLpNorm _ _

/-- **H√∂lder's inequality**, binary case. -/
lemma cL1Norm_mul_le (p q : ‚ĄĚ‚Č•0‚ąě) [hpq : ENNReal.HolderConjugate p q] :
    ‚ÄĖf * g‚ÄĖ‚āô_[1] ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] := cLpNorm_mul_le _ _ one_ne_zero

/-- **H√∂lder's inequality**, finitary case. -/
lemma cLpNorm_prod_le {őĻ : Type*} {s : Finset őĻ} (hs : s.Nonempty) {p : őĻ ‚Üí ‚ĄĚ‚Č•0} (hp : ‚ąÄ i, p i ‚Č† 0)
    (q : ‚ĄĚ‚Č•0) (hpq : ‚ąĎ i ‚ąą s, ((p i)‚ĀĽ¬Ļ : ‚ĄĚ‚Č•0‚ąě) = (q : ‚ĄĚ‚Č•0‚ąě)‚ĀĽ¬Ļ) (f : őĻ ‚Üí őĪ ‚Üí ūĚēú) :
    ‚ÄĖ‚ąŹ i ‚ąą s, f i‚ÄĖ‚āô_[q] ‚Č§ ‚ąŹ i ‚ąą s, ‚ÄĖf i‚ÄĖ‚āô_[p i] := by
  induction hs using Finset.Nonempty.cons_induction generalizing q with
  | singleton => simp_all
  | cons i s hi hs ih =>
  simp_rw [prod_cons]
  rw [sum_cons, ‚Üź inv_inv (‚ąĎ _ ‚ąą _, _)] at hpq
  have : ENNReal.HolderTriple (p i) ‚ÜĎ(‚ąĎ i ‚ąą s, (p i)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ q := ‚ü®sorry‚ü©
```

The key issue is that we need to connect `q` in `hpq` with the inductive hypothesis. Let's look at the specific goal state again:

The goal is:
`‚äĘ (‚ÜĎ(p i))‚ĀĽ¬Ļ + (‚ÜĎ(‚ąĎ i ‚ąą s, (p i)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ = (‚ÜĎq)‚ĀĽ¬Ļ`

This is exactly what `hpq` states. So we can use `hpq` to rewrite the left side.

