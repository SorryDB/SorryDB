  obtain rfl | p := p
  ¬∑ sorry
  obtain rfl | q := q
  ¬∑ sorry
  obtain rfl | r := r
  ¬∑ sorry
  -- The following two come from `HolderTriple p q r`
  have hp‚āÄ : p ‚Č† 0 := sorry
  have hq‚āÄ : q ‚Č† 0 := sorry
  simp only [ENNReal.some_eq_coe] at *
  norm_cast at hr‚āÄ
  have : (‚ÄĖ(f * g) ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) = (‚ÄĖf ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) * (‚ÄĖg ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) := by ext; simp [mul_rpow]
  rw [cLpNorm_eq_cL1Norm_rpow, NNReal.rpow_inv_le_iff_of_pos, this, ‚Üź NNReal.coe_le_coe]
  any_goals positivity
