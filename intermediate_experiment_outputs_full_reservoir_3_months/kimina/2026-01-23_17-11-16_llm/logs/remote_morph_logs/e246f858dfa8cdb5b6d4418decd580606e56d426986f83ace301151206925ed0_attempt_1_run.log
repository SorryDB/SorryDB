    _ ‚Č§ ‚ÄĖfun a ‚Ü¶ ‚ÄĖf a‚ÄĖ‚ÄĖ‚āô_[p] * ‚ÄĖfun a ‚Ü¶ ‚ÄĖg a‚ÄĖ‚ÄĖ‚āô_[q] := wInner_cWeight_le_cLpNorm_mul_cLpNorm _ _
    _ = ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] := by simp_rw [cLpNorm_norm]

/-- **H√∂lder's inequality**, binary case. -/
lemma cLpNorm_mul_le (p q : ‚ĄĚ‚Č•0‚ąě) (hr‚āÄ : r ‚Č† 0) [hpqr : ENNReal.HolderTriple p q r] :
    ‚ÄĖf * g‚ÄĖ‚āô_[r] ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] := by
  obtain rfl | p := p
  ¬∑ sorry
  obtain rfl | q := q
  ¬∑ sorry
  obtain rfl | r := r
  ¬∑ sorry
  -- The following two come from `HolderTriple p q r`
  have hp‚āÄ : p ‚Č† 0 := sorry
  have hq‚āÄ : q ‚Č† 0 := sorry
  simp only [ENNReal.some_eq_coe] at *
  norm_cast at hr‚āÄ
  have : (‚ÄĖ(f * g) ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) = (‚ÄĖf ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) * (‚ÄĖg ¬∑‚ÄĖ ^ (r : ‚ĄĚ)) := by ext; simp [mul_rpow]
  rw [cLpNorm_eq_cL1Norm_rpow, NNReal.rpow_inv_le_iff_of_pos, this, ‚Üź NNReal.coe_le_coe]
  any_goals positivity
  push_cast
  rw [cL1Norm_mul_of_nonneg, mul_rpow, ‚Üź NNReal.coe_rpow, ‚Üź NNReal.coe_rpow, cLpNorm_rpow',
    cLpNorm_rpow']
  any_goals intro a; dsimp
  any_goals positivity
  have := hpqr.holderConjugate_div_div _ _ _ (mod_cast hr‚āÄ) ENNReal.coe_ne_top
  exact wInner_cWeight_le_cLpNorm_mul_cLpNorm _ _

/-- **H√∂lder's inequality**, binary case. -/
lemma cL1Norm_mul_le (p q : ‚ĄĚ‚Č•0‚ąě) [hpq : ENNReal.HolderConjugate p q] :
    ‚ÄĖf * g‚ÄĖ‚āô_[1] ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] := cLpNorm_mul_le _ _ one_ne_zero

/-- **H√∂lder's inequality**, finitary case. -/
lemma cLpNorm_prod_le {őĻ : Type*} {s : Finset őĻ} (hs : s.Nonempty) {p : őĻ ‚Üí ‚ĄĚ‚Č•0} (hp : ‚ąÄ i, p i ‚Č† 0)
    (q : ‚ĄĚ‚Č•0) (hpq : ‚ąĎ i ‚ąą s, ((p i)‚ĀĽ¬Ļ : ‚ĄĚ‚Č•0‚ąě) = (q : ‚ĄĚ‚Č•0‚ąě)‚ĀĽ¬Ļ) (f : őĻ ‚Üí őĪ ‚Üí ūĚēú) :
    ‚ÄĖ‚ąŹ i ‚ąą s, f i‚ÄĖ‚āô_[q] ‚Č§ ‚ąŹ i ‚ąą s, ‚ÄĖf i‚ÄĖ‚āô_[p i] := by
  induction hs using Finset.Nonempty.cons_induction generalizing q with
  | singleton => simp_all
  | cons i s hi hs ih =>
  simp_rw [prod_cons]
  rw [sum_cons, ‚Üź inv_inv (‚ąĎ _ ‚ąą _, _)] at hpq
  have : ENNReal.HolderTriple (p i) ‚ÜĎ(‚ąĎ i ‚ąą s, (p i)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ q := ‚ü®sorry‚ü©
```

The goal is to prove `(‚ÜĎ(p i))‚ĀĽ¬Ļ + (‚ÜĎ(‚ąĎ i ‚ąą s, (p i)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ = (‚ÜĎq)‚ĀĽ¬Ļ` given `hpq : (‚ÜĎ(p i))‚ĀĽ¬Ļ + (‚ąĎ x ‚ąą s, (‚ÜĎ(p x))‚ĀĽ¬Ļ)‚ĀĽ¬Ļ‚ĀĽ¬Ļ = (‚ÜĎq)‚ĀĽ¬Ļ`.

This is a simple algebraic manipulation. The expression `(‚ÜĎ(p i))‚ĀĽ¬Ļ + (‚ąĎ x ‚ąą s, (‚ÜĎ(p x))‚ĀĽ¬Ļ)‚ĀĽ¬Ļ‚ĀĽ¬Ļ` is equal to `(‚ÜĎ(p i))‚ĀĽ¬Ļ + (‚ÜĎ(‚ąĎ i ‚ąą s, (p i)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ)‚ĀĽ¬Ļ`.

Let's complete the proof:

```tactics
import LeanAPAP.Prereqs.Inner.Hoelder.Discrete
import LeanAPAP.Prereqs.LpNorm.Compact

/-! # Inner product -/

open Finset hiding card
open Fintype (card)
open Function MeasureTheory RCLike Real
open scoped BigOperators ComplexConjugate ENNReal NNReal NNRat

variable {őĻ őļ : Type*} [Fintype őĻ]

namespace RCLike
variable [RCLike ūĚēú] {mőĻ : MeasurableSpace őĻ} [DiscreteMeasurableSpace őĻ] {f : őĻ ‚Üí ūĚēú}

@[simp] lemma wInner_cWeight_self (f : őĻ ‚Üí ūĚēú) :
    ‚ü™f, f‚üę‚āô_[ūĚēú] = ((‚ÄĖf‚ÄĖ‚āô_[2] : ‚ĄĚ) : ūĚēú) ^ 2 := by
  simp_rw [‚Üź algebraMap.coe_pow, ‚Üź NNReal.coe_pow]
  simp [cL2Norm_sq_eq_expect_nnnorm, wInner_cWeight_eq_expect]

lemma cL1Norm_mul (f g : őĻ ‚Üí ūĚēú) : ‚ÄĖf * g‚ÄĖ‚āô_[1] = ‚ü™fun i ‚Ü¶ ‚ÄĖf i‚ÄĖ, fun i ‚Ü¶ ‚ÄĖg i‚ÄĖ‚üę‚āô_[‚ĄĚ] := by
  simp [wInner_cWeight_eq_expect, cL1Norm_eq_expect_nnnorm, mul_comm]

/-- **Cauchy-Schwarz inequality** -/
lemma wInner_cWeight_le_cL2Norm_mul_cL2Norm (f g : őĻ ‚Üí ‚ĄĚ) : ‚ü™f, g‚üę‚āô_[‚ĄĚ] ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[2] * ‚ÄĖg‚ÄĖ‚āô_[2] := by
  simp only [wInner_cWeight_eq_smul_wInner_one, cL2Norm_eq_expect_nnnorm, ‚Üź NNReal.coe_mul, expect,
    ‚Üź NNRat.cast_smul_eq_nnqsmul ‚ĄĚ‚Č•0, smul_eq_mul, ‚Üź NNReal.mul_rpow, mul_mul_mul_comm, ‚Üź sq]
  simp only [NNReal.mul_rpow, ‚Üź dL2Norm_eq_sum_nnnorm, card_univ]
  rw [‚Üź NNReal.rpow_two, NNReal.rpow_rpow_inv two_ne_zero, NNReal.smul_def, smul_eq_mul]
  push_cast
  gcongr
  exact wInner_one_le_dL2Norm_mul_dL2Norm _ _

end RCLike

