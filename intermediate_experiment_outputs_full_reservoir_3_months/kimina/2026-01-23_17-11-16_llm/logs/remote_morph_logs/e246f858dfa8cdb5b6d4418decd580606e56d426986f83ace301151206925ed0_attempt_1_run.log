variable {őĪ : Type*} {mőĪ : MeasurableSpace őĪ} [DiscreteMeasurableSpace őĪ] [Fintype őĪ] {p q : ‚ĄĚ‚Č•0}
  {f g : őĪ ‚Üí ‚ĄĚ}

lemma cL1Norm_mul_of_nonneg (hf : 0 ‚Č§ f) (hg : 0 ‚Č§ g) : ‚ÄĖf * g‚ÄĖ‚āô_[1] = ‚ü™f, g‚üę‚āô_[‚ĄĚ] := by
  convert cL1Norm_mul f g using 2 <;> ext a <;> refine (norm_of_nonneg ?_).symm; exacts [hf _, hg _]

/-- **H√∂lder's inequality**, binary case. -/
lemma wInner_cWeight_le_cLpNorm_mul_cLpNorm (p q : ‚ĄĚ‚Č•0‚ąě) [p.HolderConjugate q] :
    ‚ü™f, g‚üę‚āô_[‚ĄĚ] ‚Č§ ‚ÄĖf‚ÄĖ‚āô_[p] * ‚ÄĖg‚ÄĖ‚āô_[q] := by
  sorry
