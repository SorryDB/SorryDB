/-- Any uniformly almost periodic function is bounded. -/
lemma IsUnifAlmostPeriodic.exists_forall_le (hf : IsUnifAlmostPeriodic f) : ∃ C, ∀ x, ‖f x‖ ≤ C :=
  sorry
