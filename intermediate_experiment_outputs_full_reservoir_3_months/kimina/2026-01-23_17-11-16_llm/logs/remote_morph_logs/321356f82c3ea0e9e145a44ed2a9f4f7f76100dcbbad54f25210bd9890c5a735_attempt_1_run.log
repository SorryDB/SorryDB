  (S : @Scope V) (req₁ req₂ : RequestId) : Bool :=
  let sc_ordc := ordc.val.get? S.threads
  match sc_ordc with
    | none => ordc.default
    | some hashmap =>
      hashmap.getD (req₁, req₂) ordc.default

