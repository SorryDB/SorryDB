-- This is the definition of the valid scopes for our system.
-- It's a structure that represents the set of valid scopes in our system.
-- Each scope is a set of thread IDs. The structure also contains information
-- about how these scopes relate to each other and the system's default scope.
structure ValidScopes {
  -- A map from scope names to sets of thread IDs.
  scopes : Map (List ThreadId) (List ThreadId) := sorry
  -- A map from scope names to their validity.
  valid : Map (List ThreadId) Bool := sorry
  -- The system's default scope.
  systemScope : List ThreadId := sorry
  -- A function to get the joint scope of two scopes.
  -- This is the intersection of the two scopes.
  jointScope : (List ThreadId) → (List ThreadId) → List ThreadId := sorry
  -- A function to check if a scope is valid.
  validate : (List ThreadId) → Bool := sorry
  -- A function to get the subscopes of a scope.
  subscopes : (List ThreadId) → List (List ThreadId) := sorry
  -- A function to check if one scope is a subset of another.
  isSubset : (List ThreadId) → (List ThreadId) → Bool := sorry
  -- A function to check if a scope is equal to the system scope.
  isSystem : (List ThreadId) → Bool := sorry
}

-- This is the definition of our request structure.
-- It contains information about the request's thread, predecessor,
-- and whether it's propagated to other threads.
structure Request {
  -- The thread ID that this request is associated with.
  thread : ThreadId := sorry
  -- A list of predecessor thread IDs.
  predecessor_at : List ThreadId := sorry
  -- A list of all threads that this request is propagated to.
  propagated_to : List ThreadId := sorry
  -- The request's ID.
  id : RequestId := sorry
}

-- This is the definition of our order constraints.
-- It's a map from scope names to maps of request pairs to boolean values.
-- The boolean value indicates whether there's an order constraint
-- between the two requests in that scope.
structure OrderConstraints {
  -- The actual map of constraints.
  val : Std.HashMap (List ThreadId) (Std.HashMap (RequestId × RequestId) Bool) := sorry
  -- A default value for constraints not explicitly defined.
  default : Bool := sorry
}

-- This is the definition of our request array structure.
-- It contains the actual array of requests and a proof that it's consistent.
structure RequestArray {
  -- The actual array of requests. Each entry is an option, as some entries
