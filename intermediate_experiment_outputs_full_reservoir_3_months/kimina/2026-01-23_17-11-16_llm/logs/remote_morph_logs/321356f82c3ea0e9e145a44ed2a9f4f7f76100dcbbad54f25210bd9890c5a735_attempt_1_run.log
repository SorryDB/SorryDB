import Mathlib

/- A request in our system is identified by a unique integer, called its "id".
  It also has a "thread" it belongs to, and a "valid" field that is true iff the
  request is valid for the current scope. -/
structure Request (id : RequestId) (thread : ThreadId) (valid : Bool) := by
  field id thread valid

/- A valid scope is a set of thread ids that are valid for a given system state.
  We have a set of valid scopes, and we need to determine if a given set of
  constraints is consistent with these scopes. -/
structure ValidScopes (scopes : Set (List ThreadId)) (valid : Set (List ThreadId)) := by
  field scopes valid

/- A request can be propagated to other threads. The "propagated_to" field is a set
  of thread ids to which the request has been propagated. -/
structure Request (id : RequestId) (thread : ThreadId) (valid : Bool) (propagated_to : Set ThreadId) := by
  field id thread valid propagated_to

/- The predecessor of a request is the request that came before it in the
  execution sequence. The "predecessor_at" field is a list of thread ids where
  the predecessor was located. -/
structure Request (id : RequestId) (thread : ThreadId) (valid : Bool) (propagated_to : Set ThreadId) (predecessor_at : List ThreadId) := by
  field id thread valid propagated_to predecessor_at

/- The "value" of a request is the data it carries. The "value?" field is an option
  type representing this value. -/
structure Request (id : RequestId) (thread : ThreadId) (valid : Bool) (propagated_to : Set ThreadId) (predecessor_at : List ThreadId) (value? : Option Int) := by
  field id thread valid propagated_to predecessor_at value?

/- The "isWrite" property indicates whether a request is a write operation. The
  "value?" field is an option type representing the value written. -/
structure WriteRequest (id : RequestId) (thread : ThreadId) (valid : Bool) (propagated_to : Set ThreadId) (predecessor_at : List ThreadId) (value : Int) :=
  { isWrite := true, value? := some value }

/- The "isWrite" property indicates whether a request is a write operation. The
  "value?" field is an option type representing the value written. -/
structure ReadRequest (id : RequestId) (thread : ThreadId) (valid : Bool) (propagated_to : Set ThreadId) (predecessor_at : List ThreadId) (value : Int) :=
  { isWrite := false, value? := some value }

/- A request can be a read or write operation. The "isWrite" property distinguishes
  them. The "value?" field is an option type representing the value involved. -/
structure GeneralRequest (id : RequestId) (thread : ThreadId) (valid : Bool) (propagated_to : Set ThreadId) (predecessor_at : List ThreadId) (value? : Option Int) (address? : Option Int) := by
  field id thread valid propagated_to predecessor_at value? address?

/- The "address?" field is the location of the memory address accessed by the
  request. For writes, it's the address being written to; for reads, it's the
  address being read from. The type is Option because the request might not access
  a specific address (e.g. for control flow instructions). -/
structure GeneralRequest (id : RequestId) (thread : ThreadId) (valid : Bool) (propagated_to : Set ThreadId) (predecessor_at : List ThreadId) (value? : Option Int) (address? : Option Int) := by
  field id thread valid propagated_to predecessor_at value? address?

/- The "toShortString" method provides a concise string representation of the
  request, useful for debugging and display. -/
def GeneralRequest.toShortString (r : GeneralRequest) : String := r.id.toNat.toNat.repr ++ r.isWrite ? " (write)" : " (read)" ++ " to " ++ r.address? ? : "unknown address"

/- The "toFullString" method provides a more detailed string representation of the
  request. -/
def GeneralRequest.toFullString (r : GeneralRequest) : String := r.isWrite ? "Write request" : "Read request" ++ " at address " ++ r.address?

/- A request can be a simple operation or a compound operation. A simple operation
  is one that does not depend on other requests. A compound operation is one that
  depends on other requests (e.g. via predecessor links). -/
structure SimpleRequest (id : RequestId) (thread : ThreadId) (valid : Bool) (propagated_to : Set ThreadId) (predecessor_at : List ThreadId) (value? : Option Int) (address? : Option Int) := by
  field id thread valid propagated_to predecessor_at value? address?

/- A system state consists of a list of requests, along with information about
  which requests are valid in which scopes. The "valid" field is a map from
  scope identifiers to lists of valid request identifiers. The "scopes"
  field is a list of scope identifiers. The "requests" field is a list of
  requests. The "orderConstraints" field is a list of order constraints. -/
structure SystemState (valid : FinMap (List ThreadId) (List RequestId)) (scopes : List (List ThreadId)) (requests : List (GeneralRequest)) (orderConstraints : List (List (RequestId × RequestId))) := by
  field valid scopes requests orderConstraints

/- The "idToReq" map provides a way to look up a request by its id. -/
def SystemState.idToReq (s : SystemState) (rId : RequestId) : Option (GeneralRequest) := s.requests.find (fun r => r.id == rId)

/- The "reqsInScope" function returns a list of request identifiers that are valid
  in a given scope. -/
def SystemState.reqsInScope (s : SystemState) (S : List ThreadId) : List (RequestId) := s.valid S.toList

/- The "reqsInSystemScope" function returns a list of request identifiers that are
  valid in the system scope. -/
def SystemState.reqsInSystemScope (s : SystemState) : List (RequestId) := s.reqsInScope s.systemScope

/- A request is considered "simple" if it is not a predecessor to any other
  request. The "isSimple" property is defined based on the "predecessor_at" list. -/
def GeneralRequest.isSimple (r : GeneralRequest) : Bool :=
  r.predecessor_at.length == 0

/- The "qtopSort" algorithm is a topological sort that respects precedence
  constraints. It is used to determine the correct order of execution for
  requests. -/
def GeneralRequest.qtopSort (s : SystemState) (reqs : List (GeneralRequest)) : List (GeneralRequest) :=
  let validRequests := reqs.filter (fun r => r.isSimple)
  let constraints := s.orderConstraints
  let dependencies := constraints.map (fun c => (c.1, c.2))
  let graph := validRequests.map (fun r => (r, dependencies.filter (fun d => d.1 == r.id)))
  let sorted := Graph.topSort graph
  let result := sorted.map (fun r => r.1)
  result

/- The "groupsToString" function converts a list of request groups into a string
  representation, showing dependencies between groups. -/
def GeneralRequest.groupsToString (groups : List (List (GeneralRequest))) : String :=
  groups.map (fun group => group.map GeneralRequest.toShortString).map (fun row => row.join ", ").join " → " 

/- The "toString" function converts a list of request groups into a string
  representation, showing the full details of each request. -/
def GeneralRequest.toString (groups : List (List (GeneralRequest))) : String :=
  groups.map (fun group => group.map GeneralRequest.toFullString).map (fun row => row.join ",\n  ").join "\n  " 

/- The "prettyPrint" function provides a more visually structured output of the
  request groups, using colors to differentiate types of requests and their
  relationships. -/
def GeneralRequest.prettyPrint (groups : List (List (GeneralRequest))) (numThreads : Nat) (order : @OrderConstraints V) (colWidth : Nat := 25) (highlight : Option (ThreadId × GeneralRequest) := none) : String := sorry

/- A request array is a collection of requests, represented as an array of
  options. This allows for a more direct representation of the system state. -/
structure RequestArray (val : Array (Option (GeneralRequest))) (coherent : valConsistent val = true) := by
  field val coherent

/- The "valConsistent" predicate checks if the mapping from request IDs to
  request objects is consistent with the structure of the system. This is
  crucial for the correctness of the "prettyPrint" and other functions. -/
def valConsistent (vals :  Array (Option (GeneralRequest))) : Bool :=
  let valOpIds := vals.map opReqId?
  let valConsistent := λ (idx : Nat) (opVal : Option (GeneralRequest)) => match opVal with
    | none => true
    | some val => val == idx
  let consistentVals := valOpIds.mapIdx valConsistent
  consistentVals.foldl (. ∧ .) true

/- The "empty" constructor creates an empty request array. -/
def RequestArray.empty : RequestArray := { val := Array.mk [], coherent := sorry }

/- The "toString" method for a request array converts it into a string
  representation. -/
def RequestArray.toString : RequestArray → String := sorry

/- The "filter" method filters the request array based on a predicate. -/
def RequestArray.filter : RequestArray → (GeneralRequest → Bool) → List (GeneralRequest) := sorry

/- The "prettyPrint" method provides a structured output of the request array. -/
def RequestArray.prettyPrint : RequestArray → Nat → @OrderConstraints V → Nat → Option (ThreadId × GeneralRequest) → String := sorry

/- The "insert" method adds a new request to the array at the correct index. -/
def RequestArray._insert : (r : GeneralRequest) (arr : RequestArray) : RequestArray := sorry

/- The "insertConsistent" lemma establishes that inserting a request into the
  array preserves consistency. -/
lemma insertConsistent (r : GeneralRequest) (arr : RequestArray) : valConsistent (arr._insert r).val := sorry

/- The main theorem establishes the consistency of the request array construction. -/
theorem main : valConsistent (RequestArray.mk (sorry : List (Option (GeneralRequest))) sorry) = true := sorry
