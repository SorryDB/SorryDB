  unfold IsEquiv
  constructor
  · -- Show reflexivity: any closed loop is equivalent to itself
    intro x
    let s := Equiv.refl (Fin n)
    use s
    use (fun y ↦ rfl) -- This proves s x.1 = x.1
    simp [permMapWalk, Equiv.refl, Function.comp_apply, Equiv.Perm.map_refl]
    <;> try { tauto }
    <;> try { aesop }
    <;> try { exact rfl }
