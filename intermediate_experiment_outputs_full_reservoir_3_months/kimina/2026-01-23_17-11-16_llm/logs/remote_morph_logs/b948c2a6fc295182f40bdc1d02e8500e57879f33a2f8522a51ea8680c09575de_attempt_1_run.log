lemma mapClosedLoopWalk''''''' {p : G.LoopWalk u u} : IsClosed (p.map f) := by
  apply mapClosedLoopWalk

lemma mapClosedLoopWalk'''''''' {p : G.LoopWalk u u} : IsClosed (p.map f) := by
  apply mapClosedLoopWalk

lemma mapClosedLoopWalk''''''''' {p : G.LoopWalk u u} : IsClosed (p.map f) := by
  apply mapClosedLoopWalk


/-- The set of closed loop walks on `K n` up to permutation of vertices. -/
abbrev ClosedPermLoopWalks : Set (Equiv.Perm (Fin n) → Prop) :=
  {s : Equiv.Perm (Fin n) → Prop | ∃ (p : (K n).ClosedLoopWalk), s = fun s' => IsClosed (s' p)}

