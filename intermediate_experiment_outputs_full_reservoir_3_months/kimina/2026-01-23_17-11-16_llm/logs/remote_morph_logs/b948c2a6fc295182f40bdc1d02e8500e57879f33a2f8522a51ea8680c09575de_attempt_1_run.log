```lean
import Mathlib


open SimpleGraph


/- Complete graph on n vertices.-/
def K (n : ℕ) : SimpleGraph (Fin n) :=
  completeGraph (Fin n)


/- A closed loop walk on a graph is a sequence of vertices starting and ending at the same vertex, such that consecutive vertices are adjacent.-/
abbrev ClosedLoopWalk (G : SimpleGraph V) := Σ u : V, G.LoopWalk u u


/- A walk is closed if its start and end vertices are the same. -/
@[simp]
def IsClosed {u v : V} (_ : G.LoopWalk u v) : Prop := u = v


/- Two closed loop walks are equivalent if one can be obtained from the other by a graph automorphism.-/
def LoopWalkEquiv (p q : ClosedLoopWalk (K n)) : Prop :=
  ∃ (s : Equiv.Perm (Fin n)), s p.1 = q.1 ∧ s.map p.2 = q.2


/- The set of closed loop walks on K_n up to automorphism forms a setoid. -/
setoid : Setoid (ClosedLoopWalk (K n)) where
  r := fun p q => ∃ (s : Equiv.Perm (Fin n)), s p = q ∧ s.map p = q
  isEquiv := by
    intro p q
    exact ⟨Equiv.refl (Fin n), rfl, rfl⟩
```

