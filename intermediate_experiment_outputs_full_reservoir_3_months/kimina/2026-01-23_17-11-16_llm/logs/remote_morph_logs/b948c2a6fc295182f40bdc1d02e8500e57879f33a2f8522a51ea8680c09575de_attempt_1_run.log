-- The set of all closed loop walks in a complete graph
abbrev ClosedLoopWalks (G : SimpleGraph V) := Set.range (fun (u : V) ↦ G.LoopWalk u u)

-- A closed loop walk is equivalent to a permutation of the vertices
noncomputable abbrev ClosedLoopWalksEquiv (n : ℕ) : Equiv.Perm (Fin n) ≃ Set.range (fun (u : Fin n) ↦ (completeGraph n).LoopWalk u u) := sorry

-- The set of all closed loop walks in a complete graph up to permutation
noncomputable abbrev ClosedLoopWalksSetoid : Setoid (Equiv.Perm (Fin n)) := sorry

