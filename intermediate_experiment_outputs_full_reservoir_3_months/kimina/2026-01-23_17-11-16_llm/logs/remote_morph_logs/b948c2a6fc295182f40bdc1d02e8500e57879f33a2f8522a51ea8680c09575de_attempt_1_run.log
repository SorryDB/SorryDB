where `h_eq : s x.1 = x.1` and `p : @SimpleGraph.LoopWalk.ClosedLoopWalk (Fin n) (SimpleGraph.LoopWalk.K n) := x` (so `p.1 = x.1`, `p.2 = x.2`), and `q : @SimpleGraph.LoopWalk.ClosedLoopWalk (Fin n) (SimpleGraph.LoopWalk.K n) := x` (so `q.1 = x.1`, `q.2 = x.2`).

