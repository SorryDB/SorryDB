    use s.symm
    use (fun y ↦ s.symm.injective y ▸ h_eq y) -- This proves s.symm q.1 = p.1
    rw [h_eq']
    simp [s.symm, permMapWalk, Equiv.symm, Equiv.Perm.map_symm, Function.comp_apply]
    <;> try { tauto }
    <;> try { aesop }
    <;> try { exact rfl }
  · -- Show transitivity: if p is equivalent to q and q is equivalent to r, then p is equivalent to r
