-- The equivalence relation between closed loop walks
def LoopWalkEquiv (p q : ClosedLoopWalk (K n)) : Prop :=
  ∃ (s : Equiv.Perm (Fin n)), ∃ (h_eq : s p.1 = q.1),
    h_eq ▸ (permMapWalk n s p.2) = q.2


-- The setoid structure on the closed loop walks
instance Setoid (ClosedLoopwalk (K n)) where
  r := LoopWalkEquiv
  iseqv := by
    constructor
    · -- Show that the relation is reflexive
      intro x
      use Equiv.refl (Fin n)
      use rfl
      simp
    · -- Show that the relation is symmetric
      rintro ⟨s, h_eq, heq⟩
      use s.symm
      use h_eq.symm
      rw [heq]
      simp [Equiv.Perm.symm]
    · -- Show that the relation is transitive
      rintro ⟨s₁, h_eq₁, heq₁⟩ ⟨s₂, h_eq₂, heq₂⟩
      use s₁.comp s₂
      use h_eq₁.trans h_eq₂
      rw [heq₁, heq₂]
      simp [Equiv.Perm.comp]
      all_goals try { tauto }
      all_goals try { simp }
