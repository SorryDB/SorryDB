import Mathlib


namespace SimpleGraph

variable {V}

/-- A walk `p : G.LoopWalk u v` consists of a sequence of vertices `u = v₀, v₁, ..., vₙ = v`
such that each consecutive pair `(vᵢ, vᵢ₊₁)` is connected by an edge in `G`.
The walk can be represented as `⟨v₀, v₁, ..., vₙ, [e₁, ..., eₙ]⟩`, where `eᵢ` is the edge from `vᵢ` to `vᵢ₊₁`.
The empty walk `⟨⟩` goes from `u` to `u` with length 0 and no edges.
A walk `cons e p` goes from the start of `e` to the end of `p`, with length `p.length + 1`.
A loop `loop p` goes from the start of `p` to itself, with length `p.length + 1`. -/
inductive LoopWalk (G : SimpleGraph V) (u v : V) : Prop :=
  | nil =>
    -- The empty walk goes from u to u with length 0.
    -- This corresponds to the trivial path in the graph.
    -- The definition of an empty loop is a trivial path.
    sorry
  | cons h p =>
    -- A non-empty walk starts with an edge `h` from `u` to `v'`, then continues with a walk `p` from `v'` to `v`.
    -- This corresponds to `h : G.Adj u v'` and `p : G.LoopWalk v' v`.
    sorry
  | loop p =>
    -- A loop walk starts with a walk `p` from `u` to `v`, then loops back to `u`.
    -- This corresponds to `p : G.LoopWalk u v`.
    sorry


namespace SimpleGraph.LoopWalk

variable {G}

/-- The empty walk. -/
abbrev nil : G.LoopWalk u v := sorry

/-- Construct a walk by adding an edge at the start. -/
abbrev cons (h : G.Adj u v) (p : G.LoopWalk v w) : G.LoopWalk u w := sorry

/-- Construct a loop by repeating a walk. -/
abbrev loop (p : G.LoopWalk u v) : G.LoopWalk u v := sorry


/-- The length of a walk is the number of edges along it. -/
def length {u v : V} : G.LoopWalk u v → ℕ := sorry

/-- The support of a walk is the list of vertices it visits in order. -/
def support {u v : V} : G.LoopWalk u v → List V := sorry

/-- The support set of a walk is the set of vertices it visits. -/
def supportSet {u v : V} [DecidableEq V] (p : G.LoopWalk u v) : Finset V := sorry

/-- The darts of a walk is the list of edges it uses. -/
def darts {u v : V} : G.LoopWalk u v → List (V × V) := sorry

/-- The darts set of a walk is the set of edges it uses. -/
def dartsSet {u v : V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (V × V) := sorry


/-- The connecting darts are the edges between distinct vertices. -/
def connectingDarts {u v : V} : G.LoopWalk u v → List (V × V) := sorry

/-- The connecting darts set is the set of edges between distinct vertices. -/
def connectingDartsSet {u v : V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (V × V) := sorry

/-- The self darts are the loops in the walk. -/
def selfDarts {u v : V} : G.LoopWalk u v → List (V × V) := sorry

/-- The self darts set is the set of loops in the walk. -/
def selfDartsSet {u v : V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (V × V) := sorry


/-- The edges of a walk is the list of edges it uses. -/
def edges {u v : V} (p : G.LoopWalk u v) : List (Sym2 V) := p.darts.map dartEdge

/-- The connecting edges are the edges between distinct vertices. -/
def connectingEdges {u v : V} (p : G.LoopWalk u v) : List (Sym2 V) := p.connectingDarts.map dartEdge

/-- The self edges are the loops in the walk. -/
def selfEdges {u v : V} (p : G.LoopWalk u v) : List (Sym2 V) := p.selfDarts.map dartEdge

/-- The edge set of a walk is the set of edges it uses. -/
def edgeSet {u v: V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (Sym2 V) := (p.edges).toFinset

/-- The connecting edge set is the set of edges between distinct vertices. -/
def connectingEdgeSet {u v: V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (Sym2 V) := (p.connectingEdges).toFinset

/-- The self edge set is the set of loops in the walk. -/
def selfEdgeSet {u v: V} [DecidableEq V] (p : G.LoopWalk u v) : Finset (Sym2 V) := (p.selfEdges).toFinset


/-- The number of times an edge `e` is used in a walk `p`. -/
def edgeCount {u v : V} (p : G.LoopWalk u v) (e : Sym2 V) : ℕ := countP (· = e) p.edges

/-- The number of loops in a walk. -/
def loop_count {u v : V} : G.LoopWalk u v → ℕ := sorry


/-- A walk is closed if its start and end vertices are the same. -/
def IsClosed {u v : V} (p : G.LoopWalk u v) : Prop := u = v

/-- A closed loop walk is a closed walk that is also a loop. -/
def ClosedLoopWalk (G : SimpleGraph V) := Σ u : V, G.LoopWalk u u

