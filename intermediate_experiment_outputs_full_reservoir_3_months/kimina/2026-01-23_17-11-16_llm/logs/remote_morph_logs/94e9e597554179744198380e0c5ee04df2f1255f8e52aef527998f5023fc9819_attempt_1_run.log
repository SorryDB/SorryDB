  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    sorry
  indep_maximal := by
    sorry
  subset_ground := by
    sorry

def matchingMatroid (G : Graph α β) : Matroid α := G.matchingIndepMatroid.matroid

