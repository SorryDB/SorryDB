lemma matchingMatroid.noColoop (h : ∀ x, G.inessential x) (hx : x ∈ V(G)) :
    ¬ G.matchingMatroid.IsColoop x := by
  -- Assume x is a coloop in the matching matroid
  intro h_isColoop
  -- By definition of coloop, x is in every basis
  -- But since x is inessential, there is a maximum matching not containing x
  obtain ⟨M, hM⟩ := h x
  -- Since M is a maximum matching, its vertex set is a basis of the matching matroid
  have hM_indep : M ∈ (G.matchingMatroid).bases := by
    simp [indep_iff_exists_isMaxMatching, matchingIndepMatroid]
    exact ⟨M, hM⟩
  -- Since x is a coloop, x must be in M
  have h_x_in_M : x ∈ M := by
    -- The definition of coloop in Mathlib is that it is in every basis
    -- We can use the property that a coloop is in every basis
    apply h_isColoop hM_indep
  -- But x is not in M by the inessentiality of x
  contradiction
