This will be replaced by a more direct approach using `rcases`.

```tactics
rcases h_mem with ⟨b, hb_mem, hN_eq⟩
have hN_eq' : N = sSup b := hN_eq
have ha' : a ≤ sSup b := by
  have ha_eq : a ≤ sSup b := by
    rw [hN_eq'] at ha
    exact ha
  exact ha_eq
have ha'' : a ≤ sSup b := by
  have ha_eq : a ≤ sSup b := by
    rw [hN_eq'] at ha'
    exact ha'
  exact ha_eq
```
