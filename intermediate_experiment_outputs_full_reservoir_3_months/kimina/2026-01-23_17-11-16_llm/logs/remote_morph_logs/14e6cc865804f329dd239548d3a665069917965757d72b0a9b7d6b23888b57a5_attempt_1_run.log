        rcases hx with ⟨N, hN, Bx, hBx⟩
        rw [hBx] at *
        exact hN
      have h_sSup_eq : sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \ {x}) = sSup ((⋃ N, ⋃ (hN : N ∈ D), B N hN) \ {x}) := rfl
