```lean
import Mathlib
open Mathlib

lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra hNotMax
  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement D B sorry sorry sorry
  have contra : ¬ IsMin D := by
    simp only [not_isMin_iff]
    use newD
    apply refinement_lt_of_exists_ne_singleton
    use x ⊔ y, hN
    simp only [B, if_true]
    intro h
    --This should be easy
    have h3 : x ≠ x ⊔ y := by
      intro h_eq
      have h4 : y ≤ x := by
        rw [show x ⊔ y = x by
          exact h_eq
        ] at *
        have h5 : Disjoint x y := hxy
        have h6 : y ≤ x := by
          exact (disjoint_iff_inter_eq_bot.mp h5).1 h_eq
        exact h6
      have h6 : y = ⊥ := by
        have h7 : Disjoint x y := hxy
        have h8 : y ≤ x := by
          rw [show x ⊔ y = x by
            exact h_eq
          ] at *
          have h9 : Disjoint x y := hxy
          have h10 : y ≤ x := by
            exact (disjoint_iff_inter_eq_bot.mp h9).1 h_eq
          exact h10
        have h9 : y = ⊥ := by
          exact (disjoint_iff_inter_eq_bot.mp h7).1 h8
        exact h9
      contradiction
    have h4 : y ≠ x ⊔ y := by
      intro h_eq
      have h5 : x ≤ y := by
        rw [show x ⊔ y = y by
          exact h_eq
        ] at *
        have h6 : Disjoint x y := hxy
        have h7 : x ≤ y := by
          exact (disjoint_iff_inter_eq_bot.mp h6).1 h_eq
        exact h7
      have h6 : x = ⊥ := by
        have h7 : Disjoint x y := hxy
        have h8 : x ≤ y := by
          rw [show x ⊔ y = y by
            exact h_eq
          ] at *
          have h9 : Disjoint x y := hxy
          have h10 : x ≤ y := by
            exact (disjoint_iff_inter_eq_bot.mp h9).1 h_eq
          exact h10
        have h9 : x = ⊥ := by
          exact (disjoint_iff_inter_eq_bot.mp h7).1 h8
        exact h9
      contradiction
    have h5 : (x : Set (PersistenceSubmodule M)) ≠ (x ⊔ y : Set (PersistenceSubmodule M)) := by
      intro h_eq
      have h6 : x = x ⊔ y := by
        have h7 : x ∈ ({x, y} : Set (PersistenceSubmodule M)) := by simp
        have h8 : x ∈ ({x ⊔ y} : Set (PersistenceSubmodule M)) := by
          rw [h_eq] at *
          exact h7
        simp only [Set.mem_singleton_iff] at h8
        exact h8
      contradiction
    simp [h5]
  exact hmax.not_lt contra
