  intro i; -- This line
  induction i with
  | zero =>
    simp [construction]; -- This line
    -- The goal is now `⊢ False`, which is trivially true
    -- The hypotheses are:
    -- h : ∀ (x : Option (Formula ℕ)), x = some δ → False
    -- hφ : δ ∈ construction T hT 0
