example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Mono f) :
    Function.Injective f := by sorry
example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Epi f) :
    Function.Surjective f := by sorry

