def Category.Subcategory.mono : Subcategory α where
  obj := fun X => True
  hom := fun f => Mono f
  id_mem X := by sorry
  comp_mem hX hY hZ hf hg := by sorry

def Category.Subcategory.epi : Subcategory α where
  obj := fun X => True
  hom := fun f => Epi f
  id_mem X := by sorry
  comp_mem hX hY hZ hf hg := by sorry

