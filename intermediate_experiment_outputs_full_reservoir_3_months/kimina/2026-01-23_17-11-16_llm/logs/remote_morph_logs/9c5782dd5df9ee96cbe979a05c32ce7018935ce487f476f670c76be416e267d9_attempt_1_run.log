  id := 1
  comp f g := f * g
  id_comp := by simp
  comp_id := by simp
  assoc _ _ _ := by rw [Matrix.mul_assoc]

variable {α : Type*} [C : Category α]

theorem Category.MatR_opp_eq_MatR' [Ring α] : (MatR α).opp = MatR' α := by sorry

-- exmaple 1.2.2.ii
