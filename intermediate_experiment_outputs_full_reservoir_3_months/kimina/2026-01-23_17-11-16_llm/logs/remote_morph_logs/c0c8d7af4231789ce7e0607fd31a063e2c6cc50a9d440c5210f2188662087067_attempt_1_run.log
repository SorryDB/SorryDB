import Mathlib

lemma mem_support_rec (m : ℕ) :
    ∀ (x : Vector α (m + 1)), x ∈ support (Nat.recAux (pure #v[]) (fun m ih => Vector.push <$> ih <*> ($ᵗ α)) (m + 1)) := by
  intro x
  induction m with
  | zero =>
    simp
```

