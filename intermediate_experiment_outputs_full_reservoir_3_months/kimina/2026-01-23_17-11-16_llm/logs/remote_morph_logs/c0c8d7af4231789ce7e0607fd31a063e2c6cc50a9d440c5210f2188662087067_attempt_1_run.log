noncomputable abbrev uniformSelectList (xs : List α) : ProbComp α :=
  match xs with
  | [] => failure
  | x :: xs => (PMF.uniformSample (Fin xs.length.succ)).map (some (x :: xs)[·])

variable {α : Type}

@[simp] lemma evalDist_uniformSelectList (xs : List α) :
    evalDist ($ xs) = match xs with
    | [] => failure
    | x :: xs => (PMF.uniformSample (Fin xs.length.succ)).map (some (x :: xs)[·]) := by
  match xs with
  | [] => simp [uniformSelectList]
  | x :: xs => simp [uniformSelectList]

@[simp] lemma support_uniformSelectList (xs : List α) :
    ($ xs).support = if xs.isEmpty then ∅ else {y | y ∈ (xs)} := by
  match xs with
  | [] => simp [uniformSelectList]
  | x :: xs => simp [uniformSelectList, support_map, support_uniformFin, Set.image_univ]

