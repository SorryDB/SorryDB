import Data.List

-- This is a simple example of how to define a list of thread IDs.
abbrev ListThreadIds : List ThreadId := [0, 1, 2]

-- This defines a structure for valid scopes in the system.
structure ValidScopes where
  system_scope : List ThreadId
  scopes : ListTree ThreadId
  --scopes_consistent : ∀ s, scopes.elem s → s.sublist system_scope
  --system_scope_is_scope : system_scope ∈ scopes

def ValidScopes.default : ValidScopes :=
    { system_scope := ListThreadIds, scopes := ListTree.leaf [ListThreadIds],
     -- scopes_consistent :=
     --     (by
     --      intros s h
     --      simp [ListTree.elem] at h
     --      rw [h]
     --      simp),
     -- system_scope_is_scope :=
     --     (by simp [ (· ∈ ·) ])
    }

-- This is a helper function to decide if a list of thread IDs is in the scopes.
instance {threads : List ThreadId} {V : ValidScopes} : Decidable (threads ∈ V.scopes) := decideThreadsValid threads V

-- This defines a structure for a scope, which is a list of thread IDs that form a scope.
structure @Scope {V : ValidScopes} where
  -- The list of thread IDs in this scope.
  threads : List ThreadId
  -- A proof that this list of thread IDs is in the valid scopes.
  valid : threads ∈ V.scopes

-- This defines a function to check if a list of thread IDs is a valid scope.
