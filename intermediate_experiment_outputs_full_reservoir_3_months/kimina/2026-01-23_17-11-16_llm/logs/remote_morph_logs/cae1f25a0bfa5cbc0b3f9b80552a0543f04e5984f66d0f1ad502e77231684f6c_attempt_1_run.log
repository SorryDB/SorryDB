local notation:90 f:90 " вЦЈ " X:90 => LinearMap.rTensor X f
local notation "ќ±" => TensorProduct.assoc R
local notation "ќ≤" => TensorProduct.comm R
local notation "рЭСЇ" => antipode R (A := C)
local notation "рЭС≠" => ќівВБ вИШвВЧ рЭСЇ
local notation "рЭСЃ" => (рЭСЇ вКЧвВШ рЭСЇ) вИШвВЧ (ќ≤ C C) вИШвВЧ ќівВБ

lemma comul_right_inv : ќівВБ * рЭС≠ = 1 := calc
    ќЉвВВ вИШвВЧ (ќівВБ вКЧвВШ (ќівВБ вИШвВЧ рЭСЇ)) вИШвВЧ ќівВБ
  _ = ќЉвВВ вИШвВЧ ((ќівВБ вИШвВЧ id) вКЧвВШ (ќівВБ вИШвВЧ рЭСЇ)) вИШвВЧ ќівВБ := rfl
  _ = ќЉвВВ вИШвВЧ (ќівВБ вКЧвВШ ќівВБ) вИШвВЧ (id вКЧвВШ рЭСЇ) вИШвВЧ ќівВБ := by
    simp only [_root_.TensorProduct.map_comp, comp_assoc]
  _ = ќівВБ вИШвВЧ ќЉвВБ вИШвВЧ (id вКЧвВШ рЭСЇ) вИШвВЧ ќівВБ := by
      have : ќЉвВВ вИШвВЧ (ќівВБ вКЧвВШ ќівВБ) = ќівВБ вИШвВЧ ќЉвВБ := by ext; simp
      simp [this, вЖР comp_assoc]
  _ = ќівВБ вИШвВЧ (id * рЭСЇ) := rfl
  _ = ќівВБ вИШвВЧ ќЈвВБ вИШвВЧ ќµвВБ := by simp [convOne_def]
  _ = ќЈвВВ вИШвВЧ ќµвВБ := by
      have : ќівВБ вИШвВЧ ќЈвВБ = ќЈвВВ := by ext; simp; rfl
      simp [this, вЖР comp_assoc]

end LinearMap

namespace AlgHom
variable [CommSemiring A] [Semiring C] [Bialgebra R C] [HopfAlgebra R A]

lemma antipode_id_cancel : HopfAlgebra.antipodeAlgHom R A * AlgHom.id R A = 1 := by
  apply AlgHom.toLinearMap_injective
  rw [toLinearMap_convMul]
  ext
  simp [LinearMap.antipode_mul_id, AlgHom.convOne_apply]

lemma counitAlgHom_comp_antipodeAlgHom :
    (counitAlgHom R A).comp (HopfAlgebra.antipodeAlgHom R A) = counitAlgHom R A :=
  AlgHom.toLinearMap_injective <| by simp

private lemma inv_convMul_cancel (f : C вЖТвВРc[R] A) :
    (.comp (HopfAlgebra.antipodeAlgHom R A) f : C вЖТвВР[R] A) * f = 1 := calc
  _ = (.comp (HopfAlgebra.antipodeAlgHom R A) f : C вЖТвВР[R] A) * (.comp (.id R A) f) := by simp
  _ = .comp (lmul' R) (.comp (Algebra.TensorProduct.map (HopfAlgebra.antipodeAlgHom R A)
       (.id R A)) <| .comp (Algebra.TensorProduct.map f f) (comulAlgHom R C)) := by
    rw [convMul_def, Algebra.TensorProduct.map_comp]
    simp only [comp_assoc]
  _ = (HopfAlgebra.antipodeAlgHom R A * AlgHom.id R A).comp f := by
    simp only [convMul_def, BialgHomClass.map_comp_comulAlgHom]
    simp only [comp_assoc]
  _ = _ := by simp [antipode_id_cancel, convOne_def, comp_assoc]

end AlgHom

namespace BialgHom
variable [CommSemiring A] [CommSemiring C]

section HopfAlgebra
variable [HopfAlgebra R A] [HopfAlgebra R C] [IsCocomm R C]

/-- The antipode of a commutative cocommutative Hopf algebra as a coalgebra hom. -/
def antipodeBialgHom : C вЖТвВРc[R] C where
  map_smul' := by
    intro c d
    simp [antipode_mul]
    <;> try simp
    <;> try tauto
  counit_comp := by
    simp [antipode_mul, mul_comm]
    <;> try simp
    <;> try tauto
  map_comp_comul := by
    apply left_inv_eq_right_inv (a := comul)
    all_goals simp
