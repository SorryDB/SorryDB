variable {R A C : Type*} [CommSemiring R]

namespace HopfAlgebra
variable [CommSemiring A] [HopfAlgebra R A]

lemma antipode_mul_antidistrib (a b : A) : antipode R (a * b) = antipode R b * antipode R a := by
  let ќ± := antipode R вИШвВЧ .mul' R A
  let ќ≤ : A вКЧ[R] A вЖТвВЧ[R] A := .mul' R A вИШвВЧ map (antipode R) (antipode R) вИШвВЧ TensorProduct.comm R A A
  suffices ќ± = ќ≤ from congr($this (a вКЧвВЬ b))
  apply left_inv_eq_right_inv (a := LinearMap.mul' R A) <;> ext a b
  ¬Ј simp [ќ±, ((вДЫ R a).tmul (вДЫ R b)).convMul_apply, вЖР Bialgebra.counit_mul, mul_comm b a,
      вЖР sum_antipode_mul_eq_algebraMap_counit ((вДЫ R a).mul (вДЫ R b))]
  ¬Ј simp [((вДЫ R a).tmul (вДЫ R b)).convMul_apply, mul_comm, mul_mul_mul_comm, Finset.sum_mul_sum,
      вЖР Finset.sum_product', ќ≤, вЖР sum_mul_antipode_eq_algebraMap_counit (вДЫ R a),
      вЖР sum_mul_antipode_eq_algebraMap_counit (вДЫ R b)]

lemma antipode_mul_distrib (a b : A) : antipode R (a * b) = antipode R a * antipode R b := by
  rw [antipode_mul_antidistrib, mul_comm]

alias antipode_mul := antipode_mul_distrib

