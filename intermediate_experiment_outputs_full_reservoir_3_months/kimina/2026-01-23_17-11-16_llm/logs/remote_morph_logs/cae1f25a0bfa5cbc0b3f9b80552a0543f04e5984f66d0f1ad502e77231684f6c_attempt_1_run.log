import Mathlib.RingTheory.HopfAlgebra.Basic
import Toric.Mathlib.RingTheory.Bialgebra.Convolution

/-!
# Convolution product on Hopf algebra maps

This file constructs the ring structure on bialgebra homs `C вЖТ A` where `C` and `A` are Hopf
algebras and multiplication is given by
```
         .
        / \
f * g = f g
        \ /
         .
```
-/

suppress_compilation

open Algebra Coalgebra Bialgebra HopfAlgebra TensorProduct
open scoped ConvolutionProduct RingTheory.LinearMap

variable {R A C : Type*} [CommSemiring R]

namespace HopfAlgebra
variable [CommSemiring A] [HopfAlgebra R A]

lemma antipode_mul_antidistrib (a b : A) : antipode R (a * b) = antipode R b * antipode R a := by
  let ќ± := antipode R вИШвВЧ .mul' R A
  let ќ≤ : A вКЧ[R] A вЖТвВЧ[R] A := .mul' R A вИШвВЧ map (antipode R) (antipode R) вИШвВЧ TensorProduct.comm R A A
  suffices ќ± = ќ≤ from congr($this (a вКЧвВЬ b))
  apply left_inv_eq_right_inv (a := LinearMap.mul' R A) <;> ext a b
  ¬Ј simp [ќ±, ((вДЫ R a).tmul (вДЫ R b)).convMul_apply, вЖР Bialgebra.counit_mul, mul_comm b a,
      вЖР sum_antipode_mul_eq_algebraMap_counit ((вДЫ R a).mul (вДЫ R b))]
  ¬Ј simp [((вДЫ R a).tmul (вДЫ R b)).convMul_apply, mul_comm, mul_mul_mul_comm, Finset.sum_mul_sum,
      вЖР Finset.sum_product', ќ≤, вЖР sum_mul_antipode_eq_algebraMap_counit (вДЫ R a),
      вЖР sum_mul_antipode_eq_algebraMap_counit (вДЫ R b)]

lemma antipode_mul_distrib (a b : A) : antipode R (a * b) = antipode R a * antipode R b := by
  rw [antipode_mul_antidistrib, mul_comm]

alias antipode_mul := antipode_mul_distrib

variable (R A) in
/-- The antipode of a commutative Hopf algebra as an algebra hom. -/
@[simps!]
def antipodeAlgHom : A вЖТвВР[R] A := .ofLinearMap (antipode R) antipode_one antipode_mul

@[simp] lemma toLinearMap_antipodeAlgHom : (antipodeAlgHom R A).toLinearMap = antipode R := rfl

end HopfAlgebra

namespace LinearMap

local notation "ќЈ" => Algebra.linearMap R A
local notation "ќµ" => counit (R := R) (A := C)
local notation "ќЉ" => mul' R A
local notation "ќі" => comul
local infix:70 " вКЧвВШ " => TensorProduct.map
-- local notation "ќ±" => TensorProduct.assoc _ _ _

variable [Semiring C] [HopfAlgebra R C]

@[simp] lemma antipode_mul_id : antipode R (A := C) * id = 1 := by
  ext; simp [convMul_def, вЖР LinearMap.rTensor_def]

@[simp] lemma id_mul_antipode : id * antipode R (A := C) = 1 := by
  ext; simp [convMul_def, вЖР LinearMap.lTensor_def]

end LinearMap

namespace LinearMap
variable [Semiring C] [HopfAlgebra R C]

local notation "ќµвВБ" => counit (R := R) (A := C)
local notation "ќµвВВ" => counit (R := R) (A := C вКЧ[R] C)
local notation "ќЉвВБ" => LinearMap.mul' R C
local notation "ќЉвВВ" => LinearMap.mul' R (C вКЧ[R] C)
local notation "ќівВБ" => comul (R := R) (A := C)
local notation "ќівВВ" => comul (R := R) (A := C вКЧ[R] C)
local notation "ќЈвВБ" => Algebra.linearMap R C
local notation "ќЈвВВ" => Algebra.linearMap R (C вКЧ[R] C)
local infix:90 " вЧБ " => LinearMap.lTensor
local notation:90 f:90 " вЦЈ " X:90 => LinearMap.rTensor X f
local notation "ќ±" => TensorProduct.assoc R
local notation "ќ≤" => TensorProduct.comm R
local notation "рЭСЇ" => antipode R (A := C)
local notation "рЭС≠" => ќівВБ вИШвВЧ рЭСЇ
local notation "рЭСЃ" => (рЭСЇ вКЧвВШ рЭСЇ) вИШвВЧ (ќ≤ C C) вИШвВЧ ќівВБ

lemma comul_right_inv : ќівВБ * рЭС≠ = 1 := calc
    ќЉвВВ вИШвВЧ (ќівВБ вКЧвВШ (ќівВБ вИШвВЧ рЭСЇ)) вИШвВЧ ќівВБ
  _ = ќЉвВВ вИШвВЧ ((ќівВБ вИШвВЧ id) вКЧвВШ (ќівВБ вИШвВЧ рЭСЇ)) вИШвВЧ ќівВБ := rfl
  _ = ќЉвВВ вИШвВЧ (ќівВБ вКЧвВШ ќівВБ) вИШвВЧ (id вКЧвВШ рЭСЇ) вИШвВЧ ќівВБ := by
    simp only [_root_.TensorProduct.map_comp, comp_assoc]
  _ = ќівВБ вИШвВЧ ќЉвВБ вИШвВЧ (id вКЧвВШ рЭСЇ) вИШвВЧ ќівВБ := by
      have : ќЉвВВ вИШвВЧ (ќівВБ вКЧвВШ ќівВБ) = ќівВБ вИШвВЧ ќЉвВБ := by ext; simp
      simp [this, вЖР comp_assoc]
  _ = ќівВБ вИШвВЧ (id * рЭСЇ) := rfl
  _ = ќівВБ вИШвВЧ ќЈвВБ вИШвВЧ ќµвВБ := by simp [convOne_def]
  _ = ќЈвВВ вИШвВЧ ќµвВБ := by
      have : ќівВБ вИШвВЧ ќЈвВБ = ќЈвВВ := by ext; simp; rfl
      simp [this, вЖР comp_assoc]

end LinearMap

namespace AlgHom
variable [CommSemiring A] [Semiring C] [Bialgebra R C] [HopfAlgebra R A]

lemma antipode_id_cancel : HopfAlgebra.antipodeAlgHom R A * AlgHom.id R A = 1 := by
  apply AlgHom.toLinearMap_injective
  rw [toLinearMap_convMul]
  ext
  simp [LinearMap.antipode_mul_id, AlgHom.convOne_apply]

lemma counitAlgHom_comp_antipodeAlgHom :
    (counitAlgHom R A).comp (HopfAlgebra.antipodeAlgHom R A) = counitAlgHom R A :=
  AlgHom.toLinearMap_injective <| by simp

private lemma inv_convMul_cancel (f : C вЖТвВРc[R] A) :
    (.comp (HopfAlgebra.antipodeAlgHom R A) f : C вЖТвВР[R] A) * f = 1 := calc
  _ = (.comp (HopfAlgebra.antipodeAlgHom R A) f : C вЖТвВР[R] A) * (.comp (.id R A) f) := by simp
  _ = .comp (lmul' R) (.comp (Algebra.TensorProduct.map (HopfAlgebra.antipodeAlgHom R A)
       (.id R A)) <| .comp (Algebra.TensorProduct.map f f) (comulAlgHom R C)) := by
    rw [convMul_def, Algebra.TensorProduct.map_comp]
    simp only [comp_assoc]
  _ = (HopfAlgebra.antipodeAlgHom R A * AlgHom.id R A).comp f := by
    simp only [convMul_def, BialgHomClass.map_comp_comulAlgHom]
    simp only [comp_assoc]
  _ = _ := by simp [antipode_id_cancel, convOne_def, comp_assoc]

end AlgHom

