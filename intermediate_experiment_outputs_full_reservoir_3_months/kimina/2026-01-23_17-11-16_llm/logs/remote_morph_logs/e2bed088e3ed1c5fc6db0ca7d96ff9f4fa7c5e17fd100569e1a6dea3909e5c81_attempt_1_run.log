import Mathlib
import Mathlib.Analysis.SpecificLimits.Normed
import Mathlib.Analysis.SpecificLimits.Normed.Real
import Mathlib.Data.Nat.Prime
import Mathlib.Data.Nat.Sieve
import Mathlib.Data.Nat.SpecificLimits.Normed
import Mathlib.Data.Nat.SpecificLimits.Normed.Real
import Mathlib.Tactic.IntervalCases
import Mathlib.Tactic.SpecificLimits.Normed
import Mathlib.Tactic.SpecificLimits.Normed.Real

/- @Erdos392 Factorization Lower Bounds -/
namespace Erdos392

/- @Erdos392 Factorization Lower Bounds -/
namespace Factorization

/- @Erdos392 Factorization Lower Bounds -/
open Nat

/- @Erdos392 Factorization Lower Bounds -/
noncomputable abbrev score (f : Factorization n) (L : ℕ) : ℝ :=
  (f.a.card : ℝ) * Real.log (n / f.a.card) + ∑ q ∈ (n + 1).primesBelow,
    (if f.balance q > 0 then (f.balance q : ℝ) * Real.log q
     else if q ≤ L then (-f.balance q) * Real.log L else (-f.balance q) * Real.log (n / q))

/- @Erdos392 Factorization Lower Bounds -/
noncomputable abbrev waste (f : Factorization n) (L : ℕ) : ℝ :=
  (f.a.card : ℝ) * Real.log (n / f.a.card) + ∑ q ∈ (n + 1).primesBelow,
    (if f.balance q > 0 then (f.balance q : ℝ) * Real.log q
     else if q ≤ L then (-f.balance q) * Real.log L else (-f.balance q) * Real.log (n / q)) - score f L

/- @Erdos392 Factorization Lower Bounds -/
structure Params where
  n : ℕ
  M : ℕ
  L : ℕ
  hL_pos : L > 0
  hL : n > L * L

/- @Erdos392 Factorization Lower Bounds -/
def Params.initial (P : Params) : Factorization P.n := {
  a := (replicate P.M (.Ico (P.n - P.n/P.M) P.n)).join.filter
    (fun m ↦ m ∈ (P.n/P.L).smoothNumbers)
  ha := fun m hm ↦ by
    simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
    obtain ⟨⟨_, ⟨_, rfl⟩, hs⟩, _⟩ := hm
    rw [Multiset.mem_Ico, tsub_le_iff_right] at hs
    exact ⟨hs.1, by positivity⟩
  hpos := fun m hm ↦ by
    simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
    obtain ⟨_, hsmooth⟩ := hm
    exact pos_of_ne_zero (mem_smoothNumbers.mp hsmooth).1
}

/- @Erdos392 Factorization Lower Bounds -/
theorem Factorization.lower_score_1 {n : ℕ} (f : Factorization n) (L : ℕ)
    (hf : ∃ p ∈ (n + 1).primesBelow, f.balance p > 0) : ∃ f' :
    Factorization n, f'.total_imbalance < f.total_imbalance ∧ f'.score L ≤ f.score L := by
  rcases hf with ⟨p, hp, h⟩
  use f
  constructor
  · -- Show that the total imbalance is not less than f's total imbalance
    simp only [Nat.succ_pos', Nat.add_pos_left, Set.mem_setOf_eq, and_imp]
    intro h'
    exfalso
    have h_pos : f.balance p > 0 := h
    have h_nonneg : f.balance p ≥ 0 := by omega
    have h_zero : f.balance p = 0 := by linarith
    linarith
  · -- Show that the score is less than or equal
    simp only [Nat.succ_pos', Nat.add_pos_left, Set.mem_setOf_eq, and_imp]
    intro h'
    exfalso
    have h_pos : f.balance p > 0 := h
    have h_nonneg : f.balance p ≥ 0 := by omega
    have h_zero : f.balance p = 0 := by linarith
