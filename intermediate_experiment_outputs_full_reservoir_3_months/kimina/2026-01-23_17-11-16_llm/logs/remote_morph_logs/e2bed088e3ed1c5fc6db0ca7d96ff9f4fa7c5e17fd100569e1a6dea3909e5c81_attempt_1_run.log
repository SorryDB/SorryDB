import Mathlib

open Nat

/-- A factorization of a natural number `n` consists of a set of prime factors `a` and a
  function `ha` that gives the exponent of each prime in the factorization, and a function
  `hpos` that verifies the prime is indeed positive. -/
structure Factorization (n : ℕ) where
  a : Multiset ℕ
  ha : ℕ → ℕ
  hpos : ℕ → Prop

/-- The total imbalance of a factorization `f` is the sum of the absolute values of the
  difference between the exponent of each prime in `f` and its exponent in `n!`. -/
def Factorization.imbalance (f : Factorization n) := ∑ p ∈ f.a, |f ha p - n.factorization p|

/-- The score of a factorization `f` with parameter `L` is defined as the sum of terms
  involving the balance of each prime `p` in `f`. The balance is defined as `ha p - n.factorization p`. -/
def Factorization.score (f : Factorization n) (L : ℕ) := ∑ q ∈ (n + 1).primesBelow,
    (if f.balance q > 0 then (f.balance q : ℝ) * Real.log q
     else if q ≤ L then (-f.balance q) * Real.log L else (-f.balance q) * Real.log (n / q))

/-- The balance of a prime `q` in a factorization `f` is the difference between its exponent
  in `f` and its exponent in `n!`. -/
def Factorization.balance (f : Factorization n) (q : ℕ) := f ha q - n.factorization q

/-- A factorization `f` is in balance if its total imbalance is zero, meaning it perfectly
  matches the factorization of `n!`. -/
def Factorization.isBalanced (f : Factorization n) := f.imbalance = 0

/-- The waste of a factorization `f` is a measure of how much "extra" prime factorization
  is present, defined as the sum of the absolute values of the balance for primes greater than
  `L`. -/
def Factorization.waste (f : Factorization n) (L : ℕ) := ∑ p ∈ (n + 1).primesBelow,
    (if f.balance p > 0 then p else if p ≤ L then L else n / p)

/-- A factorization `f` of `n` is called "good" if it is in balance and its score is less than
  or equal to the score of the original factorization `f₀`. -/
structure FactorizationSolution (f₀ : Factorization n) where
  f : Factorization n
  hf : f.isBalanced
  hle : f.score L ≤ f₀.score L

/-- A factorization `f` is called "balanced" if its total imbalance is zero. -/
theorem Factorization.isBalanced_iff (f : Factorization n) : f.isBalanced ↔ ∑ p ∈ f.a, |f ha p - n.factorization p| = 0 := by
  simp [Factorization.isBalanced, Factorization.imbalance]

/-- The total waste of a factorization `f` is at most `n * log (1 - 1/M)⁻¹`. -/
