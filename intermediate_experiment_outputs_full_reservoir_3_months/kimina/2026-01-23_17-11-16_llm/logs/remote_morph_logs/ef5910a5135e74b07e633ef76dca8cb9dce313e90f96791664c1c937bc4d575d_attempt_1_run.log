import Mathlib

open Filter Measure ProbabilityTheory

noncomputable
def algFunction [DecidableEq Оұ] [Countable Оұ] [DecidableEq R] [Nonempty R] (a : Оұ) (r : R) (x : в„• вҶ’ Оұ Г— R) (n : в„•) : Оұ :=
  if n = 0 then a else
  let x_prev := x (n - 1)
  let a_prev := x_prev.1
  let r_prev := x_prev.2
  if x n.1 = a_prev then x n.2 else
    let r'_n := r (n + 1) (x n.1)
    let r'_n_prev := r n a_prev
    let r'_n_prev_prev := r (n - 1) (x (n - 1).1)
    let x_prev_prev := x (n - 1)
    let a_prev_prev := x_prev_prev.1
    let r_prev_prev := x_prev_prev.2
    if r'_n < r'_n_prev then x n.1 else a_prev

noncomputable
def action [DecidableEq Оұ] [Countable Оұ] [DecidableEq R] [Nonempty R] (a : Оұ) (r : R) (x : в„• вҶ’ Оұ Г— R) (n : в„•) : Оұ :=
  if n = 0 then a else
  let x_prev := x (n - 1)
  let a_prev := x_prev.1
  let r_prev := x_prev.2
  if x n.1 = a_prev then x n.1 else
