def reward [DecidableEq Оұ] [Countable Оұ] [DecidableEq R] [Nonempty R] (a : Оұ) (r : R) (x : в„• вҶ’ Оұ Г— R) (n : в„•) : R :=
  if n = 0 then r else
  let x_prev := x (n - 1)
  let a_prev := x_prev.1
  let r_prev := x_prev.2
  if x n.1 = a_prev then r n a_prev else
