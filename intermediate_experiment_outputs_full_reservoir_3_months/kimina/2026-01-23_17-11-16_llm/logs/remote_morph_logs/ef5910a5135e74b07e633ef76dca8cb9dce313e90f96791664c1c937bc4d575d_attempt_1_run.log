    hist alg Пү 0 = fun _ вҶҰ (initAlgFunction alg (Пү.1 0), Пү.2 0 (initAlgFunction alg (Пү.1 0))) :=
  rfl

lemma hist_add_one [DecidableEq Оұ] (alg : Algorithm Оұ R) (Пү : probSpace Оұ R) (n : в„•) :
    let a : Оұ := algFunction alg n (hist alg Пү n) (Пү.1 (n + 1))
    hist alg Пү (n + 1) =
      fun (i : Iic (n + 1)) вҶҰ if hin : i вүӨ n then hist alg Пү n вҹЁi, by simp [hin]вҹ©
        else (a, Пү.2 (pullCount' n (hist alg Пү n) a) a) := by
  intro a
  rw [hist_add_one]
  ext i : 1
  simp only [Kernel.symm_IicSuccProd, MeasurableEquiv.prodCongr, MeasurableEquiv.refl_toEquiv,
    MeasurableEquiv.piSingleton, eq_rec_constant, MeasurableEquiv.IicProdIoc,
    MeasurableEquiv.trans_apply, MeasurableEquiv.coe_mk, Equiv.prodCongr_apply, Equiv.coe_refl,
    Equiv.coe_fn_mk, Prod.map_apply, id_eq]
  rfl

lemma hist_eq [DecidableEq Оұ] (alg : Algorithm Оұ R) (Пү : probSpace Оұ R) (n : в„•) :
    hist alg Пү n = fun i : Iic n вҶҰ hist alg Пү i вҹЁi.1, by simpвҹ© := by
  induction n with
  | zero =>
    ext i : 1
    simp only [hist]
    rw [Unique.eq_default i]
    simp [coe_default_Iic_zero]
  | succ n hn =>
    ext i : 1
    by_cases hin : i вүӨ n
    В· rw [hist_add_one]
      simp only [hin, вҶ“reduceDIte]
      rw [funext_iff] at hn
      simp_rw [hn]
    В· grind

lemma hist_add_one_eq_IicSuccProd' [DecidableEq Оұ] (alg : Algorithm Оұ R) (Пү : probSpace Оұ R)
    (n : в„•) :
    let a : Оұ := algFunction alg n (hist alg Пү n) (Пү.1 (n + 1))
    hist alg Пү (n + 1) =
      (MeasurableEquiv.IicSuccProd (fun _ вҶҰ Оұ Г— R) n).symm
        (hist alg Пү n, (a, Пү.2 (pullCount' n (hist alg Пү n) a) a)) := by
  intro a
  rw [hist_add_one]
  ext i : 1
  simp only [Kernel.symm_IicSuccProd, MeasurableEquiv.prodCongr, MeasurableEquiv.refl_toEquiv,
    MeasurableEquiv.piSingleton, eq_rec_constant, MeasurableEquiv.IicProdIoc,
    MeasurableEquiv.trans_apply, MeasurableEquiv.coe_mk, Equiv.prodCongr_apply, Equiv.coe_refl,
    Equiv.coe_fn_mk, Prod.map_apply, id_eq]
  rfl

lemma measurable_action_add_one' [DecidableEq Оұ] {alg : Algorithm Оұ R}
    (n : в„•) (h : Measurable (hist alg В· n)) :
    Measurable (fun x вҶҰ algFunction alg n (hist alg x n) (x.1 (n + 1))) := by fun_prop

instance : MeasurableEq Оұ := by
  letI := upgradeStandardBorel Оұ
  infer_instance

lemma measurable_pullCount'_action_add_one [DecidableEq Оұ] {alg : Algorithm Оұ R}
    (n : в„•) (h_hist : Measurable (hist alg В· n)) :
    Measurable (fun x вҶҰ
      pullCount' n (hist alg x n) (algFunction alg n (hist alg x n) (x.1 (n + 1)))) := by
  have h_alg_meas : Measurable (fun x вҶҰ algFunction alg n (hist alg x n) (x.1 (n + 1))) :=
    measurable_action_add_one' n h_hist
  exact (measurable_uncurry_pullCount' (Оұ := Оұ) n).comp (h_hist.prodMk h_alg_meas)

@[fun_prop]
lemma measurable_hist [DecidableEq Оұ] [Countable Оұ] (alg : Algorithm Оұ R) (n : в„•) :
    Measurable (fun Пү вҶҰ hist alg Пү n) := by
  induction n with
  | zero =>
    simp_rw [hist_zero, measurable_pi_iff]
    refine fun _ вҶҰ Measurable.prodMk (by fun_prop) ?_
    change Measurable ((fun x : Оұ Г— ((в„• вҶ’ I) Г— (в„• вҶ’ Оұ вҶ’ R)) вҶҰ x.2.2 0 x.1) вҲҳ
        (fun x : (в„• вҶ’ I) Г— (в„• вҶ’ Оұ вҶ’ R) вҶҰ (initAlgFunction alg (x.1 0), x)))
    have : Measurable (fun x : Оұ Г— ((в„• вҶ’ I) Г— (в„• вҶ’ Оұ вҶ’ R)) вҶҰ x.2.2 0 x.1) :=
      measurable_from_prod_countable_right fun p вҶҰ by simp only; fun_prop
    exact Measurable.comp (by fun_prop) (Measurable.prodMk (by fun_prop) (by fun_prop))
  | succ n hn =>
    refine measurable_pi_iff.mpr fun i вҶҰ ?_
    by_cases hin : i вүӨ n
    В· simp only [hist, hin, вҶ“reduceDIte]
      rw [measurable_pi_iff] at hn
      exact hn вҹЁi.1, by simp [hin]вҹ©
    В· simp only [hist, hin, вҶ“reduceDIte]
      refine Measurable.prodMk (by fun_prop) ?_
      change Measurable ((fun (x : (в„• вҶ’ Оұ вҶ’ R) Г— в„• Г— Оұ) вҶҰ x.1 x.2.1 x.2.2) вҲҳ
        (fun x вҶҰ (x.2, pullCount' n (hist alg x n) (algFunction alg n (hist alg x n) (x.1 (n + 1))),
          (algFunction alg n (hist alg x n) (x.1 (n + 1))))))
      have h1 : Measurable (fun (x : (в„• вҶ’ Оұ вҶ’ R) Г— в„• Г— Оұ) вҶҰ x.1 x.2.1 x.2.2) :=
        measurable_from_prod_countable_left fun p : в„• Г— Оұ вҶҰ (by simp only; fun_prop)
      refine Measurable.comp (by fun_prop) (Measurable.prodMk (by fun_prop) ?_)
      refine Measurable.prodMk ?_ (by fun_prop)
      exact measurable_pullCount'_action_add_one n hn

noncomputable
def action [DecidableEq Оұ] (alg : Algorithm Оұ R) (n : в„•) (Пү : probSpace Оұ R) : Оұ :=
  (hist alg Пү n вҹЁn, by simpвҹ©).1

lemma action_zero [DecidableEq Оұ] (alg : Algorithm Оұ R) :
    action alg 0 = fun Пү вҶҰ initAlgFunction alg (Пү.1 0) := by
  ext
  simp [action, hist_zero]

lemma action_add_one_eq [DecidableEq Оұ] (alg : Algorithm Оұ R) (n : в„•) :
    action alg (n + 1) = fun Пү вҶҰ algFunction alg n (hist alg Пү n) (Пү.1 (n + 1)) := by
  ext Пү
  rw [action, hist_add_one]
  simp only [add_le_iff_nonpos_right, nonpos_iff_eq_zero, one_ne_zero, вҶ“reduceDIte]

@[fun_prop]
lemma measurable_action [DecidableEq Оұ] [Countable Оұ] (alg : Algorithm Оұ R) (n : в„•) :
    Measurable (action alg n) := by unfold action; fun_prop

noncomputable
def reward [DecidableEq Оұ] (alg : Algorithm Оұ R) (n : в„•) (Пү : probSpace Оұ R) : R :=
  (hist alg Пү n вҹЁn, by simpвҹ©).2

lemma reward_zero [DecidableEq Оұ] (alg : Algorithm Оұ R) :
    reward alg 0 = fun Пү вҶҰ Пү.2 0 (action alg 0 Пү) := by
  ext
  simp [reward, hist_zero, action_zero]

lemma reward_add_one [DecidableEq Оұ] (alg : Algorithm Оұ R) (n : в„•) :
    reward alg (n + 1) =
      fun Пү вҶҰ Пү.2 (pullCount' n (hist alg Пү n) (action alg (n + 1) Пү)) (action alg (n + 1) Пү) := by
  ext Пү
  simp [reward, hist_add_one, action_add_one_eq]

lemma reward_eq [DecidableEq Оұ] (alg : Algorithm Оұ R) (n : в„•) :
    reward alg n = fun Пү вҶҰ Пү.2 (pullCount (action alg) (action alg n Пү) n Пү) (action alg n Пү) := by
  cases n with
  | zero => ext; simp [reward_zero, action_zero]
  | succ n =>
    ext Пү
    rw [reward, hist_add_one]
    simp only [add_le_iff_nonpos_right, nonpos_iff_eq_zero, one_ne_zero, вҶ“reduceDIte]
    rw [action_add_one_eq, pullCount_eq_pullCount' (R' := reward alg) (by simp)]
    simp only [Nat.add_one_sub_one]
    rw [hist_eq]
    rfl

@[fun_prop]
lemma measurable_reward [DecidableEq Оұ] [Countable Оұ] (alg : Algorithm Оұ R) (n : в„•) :
    Measurable (reward alg n) := by unfold reward; fun_prop

lemma hist_add_one_eq_IicSuccProd [DecidableEq Оұ] (alg : Algorithm Оұ R) (Пү : probSpace Оұ R)
    (n : в„•) :
    hist alg Пү (n + 1) =
      (MeasurableEquiv.IicSuccProd (fun _ вҶҰ Оұ Г— R) n).symm
        (hist alg Пү n, (action alg (n + 1) Пү, reward alg (n + 1) Пү)) := by
  rw [hist_add_one_eq_IicSuccProd', reward_add_one, action_add_one_eq]

variable [DecidableEq Оұ] [Countable Оұ]

lemma hasLaw_action_zero (alg : Algorithm Оұ R) (ОҪ : Kernel Оұ R) [IsMarkovKernel ОҪ] :
    HasLaw (action alg 0) alg.p0 (arrayMeasure ОҪ) where
  map_eq := by
    calc (arrayMeasure ОҪ).map (fun Пү вҶҰ initAlgFunction alg (Пү.1 0))
    _ = ((arrayMeasure ОҪ).fst.map (Function.eval 0)).map (initAlgFunction alg) := by
      rw [Measure.fst, Measure.map_map (by fun_prop) (by fun_prop),
        Measure.map_map (by fun_prop) (by fun_prop)]
      rfl
    _ = (volume : Measure I).map (initAlgFunction alg) := by
      simp only [arrayMeasure, Measure.fst_prod]
      rw [(measurePreserving_eval_infinitePi (fun _ вҶҰ volume) 0).map_eq]
    _ = alg.p0 := initAlgFunction_map alg

variable [StandardBorelSpace R] [Nonempty R]

omit [Nonempty Оұ] [StandardBorelSpace Оұ] [DecidableEq Оұ] [Countable Оұ]
  [StandardBorelSpace R] [Nonempty R] in
lemma indepFun_fst_snd (ОҪ : Kernel Оұ R) [IsMarkovKernel ОҪ] :
    IndepFun Prod.fst Prod.snd (arrayMeasure ОҪ) :=
  indepFun_prod measurable_id measurable_id

omit [Nonempty Оұ] [StandardBorelSpace Оұ] [DecidableEq Оұ] [Countable Оұ]
  [StandardBorelSpace R] [Nonempty R] in
lemma indepFun_fst_zero_snd_zero_action (ОҪ : Kernel Оұ R) [IsMarkovKernel ОҪ] (a : Оұ) :
    IndepFun (fun Пү вҶҰ Пү.1 0) (fun Пү вҶҰ Пү.2 0 a) (arrayMeasure ОҪ) :=
  indepFun_prod (X := fun Пү : в„• вҶ’ I вҶҰ Пү 0) (Y := fun Пү : в„• вҶ’ Оұ вҶ’ R вҶҰ Пү 0 a)
    (by fun_prop) (by fun_prop)

omit [Nonempty Оұ] [StandardBorelSpace Оұ] [DecidableEq Оұ] [Countable Оұ]
  [StandardBorelSpace R] [Nonempty R] in
lemma map_snd_apply_arrayMeasure {ОҪ : Kernel Оұ R} [IsMarkovKernel ОҪ] (n : в„•) (a : Оұ) :
    (arrayMeasure ОҪ).map (fun Пү вҶҰ Пү.2 n a) = ОҪ a := by
  calc (arrayMeasure ОҪ).map (fun Пү вҶҰ Пү.2 n a)
  _ = (arrayMeasure ОҪ).snd.map (fun Пү вҶҰ Пү n a) := by
    rw [Measure.snd, Measure.map_map (by fun_prop) (by fun_prop)]
    rfl
  _ = ОҪ a := by
    rw [arrayMeasure, Measure.snd_prod, Bandit.streamMeasure]
    have : (fun Пү вҶҰ Пү.2 n a) = (fun h : Оұ вҶ’ R вҶҰ h a) вҲҳ (fun Пү : в„• вҶ’ Оұ вҶ’ R вҶҰ Пү n) := rfl
    rw [this, вҶҗ Measure.map_map (by fun_prop) (by fun_prop), Measure.infinitePi_map_eval,
      Measure.infinitePi_map_eval]

lemma hasCondDistrib_reward_zero (alg : Algorithm Оұ R) (ОҪ : Kernel Оұ R) [IsMarkovKernel ОҪ] :
    HasCondDistrib (reward alg 0) (action alg 0) (stationaryEnv ОҪ).ОҪ0 (arrayMeasure ОҪ) where
  condDistrib_eq := by
    refine (condDistrib_ae_eq_cond (by fun_prop) (by fun_prop)).trans ?_
    rw [Filter.EventuallyEq, ae_iff_of_countable]
    intro a ha
    simp only [stationaryEnv_ОҪ0, reward_zero]
    calc ((arrayMeasure ОҪ)[|action alg 0 вҒ»В№' {a}]).map (fun Пү вҶҰ Пү.2 0 (action alg 0 Пү))
    _ = ((arrayMeasure ОҪ)[|action alg 0 вҒ»В№' {a}]).map (fun Пү вҶҰ Пү.2 0 a) := by
      refine Measure.map_congr
        (ae_cond_of_forall_mem ((measurableSet_singleton _).preimage (by fun_prop)) ?_)
      intro x hx
      simp only [Set.mem_preimage, Set.mem_singleton_iff] at hx
      simp [hx]
    _ = ОҪ a := by
      rw [cond_of_indepFun]
      В· exact map_snd_apply_arrayMeasure 0 a
      В· have : (fun Пү вҶҰ Пү.1 0) вҹӮбөў[arrayMeasure ОҪ] fun Пү вҶҰ Пү.2 0 a :=
          indepFun_fst_zero_snd_zero_action ОҪ a
        rw [action_zero]
        exact this.comp (ПҶ := initAlgFunction alg) (by fun_prop) measurable_id
      В· fun_prop
      В· fun_prop
      В· simp
      В· rwa [Measure.map_apply (by fun_prop) (by simp)] at ha

lemma hasCondDistrib_reward' (alg : Algorithm Оұ R) (ОҪ : Kernel Оұ R) [IsMarkovKernel ОҪ]
    (n : в„•) :
    HasCondDistrib (reward alg (n + 1)) (fun Пү вҶҰ (hist alg Пү n, action alg (n + 1) Пү))
      (ОҪ.prodMkLeft _) (arrayMeasure ОҪ) := by
  rw [hasCondDistrib_def]
  refine вҹЁ?_, by fun_prop, ?_вҹ©
  В· -- We need to show that the measures are equal
    -- This involves showing that the mapping of `arrayMeasure` is equal to the `compProd` expression
    -- We compute the map of `arrayMeasure` directly
    have h1 : (arrayMeasure ОҪ).map (fun Пү вҶҰ (reward alg (n + 1) Пү, action alg (n + 1) Пү)) =
        (Measure.map (fun Пү вҶҰ (action alg (n + 1) Пү, reward alg (n + 1) Пү)) (arrayMeasure ОҪ)).comp (Measure.map (fun x : Оұ Г— R вҶҰ x.1) (Measure.infinitePi fun x вҶҰ в„ҷ)) := by
      simp only [arrayMeasure, Measure.map_map]
      rw [вҶҗ Measure.map_comp, вҶҗ Measure.prod_comp]
      simp only [Prod.swap, Measure.prod_comp]
      rw [вҶҗ Measure.prod_comp]
      simp only [Prod.swap, Measure.prod_comp, Measure.comp_apply, Measure.prod_apply, Measure.comp_apply]
