import Mathlib

open MeasureTheory

noncomputable
def algFunction [DecidableEq Оұ] (alg : Algorithm Оұ R) (n : в„•) (h : Iic n вҶ’ Оұ Г— R) (i : в„•) : Оұ :=
  letI x := alg.get i h
  x.1

@[fun_prop]
lemma measurable_algFunction (alg : Algorithm Оұ R) (n : в„•) :
    Measurable (Function.uncurry (algFunction alg n)) :=
  (representation (alg.policy n)).choose_spec.1

noncomputable
def hist [DecidableEq Оұ] (alg : Algorithm Оұ R) (Пү : probSpace Оұ R) : (n : в„•) вҶ’ Iic n вҶ’ Оұ Г— R
| 0 => fun _ вҶҰ (initAlgFunction alg (Пү.1 0), Пү.2 0 (initAlgFunction alg (Пү.1 0)))
| n + 1 =>
  let hn : Iic n вҶ’ Оұ Г— R := hist alg Пү n
  let a : Оұ := algFunction alg n hn (Пү.1 (n + 1))
  fun i вҶҰ if hin : i вүӨ n then hn вҹЁi, by simp [hin]вҹ© else (a, Пү.2 (pullCount' n hn a) a)

@[simp]
lemma hist_zero [DecidableEq Оұ] (alg : Algorithm Оұ R) (Пү : probSpace Оұ R) :
    hist alg Пү 0 = fun _ вҶҰ (initAlgFunction alg (Пү.1 0), Пү.2 0 (initAlgFunction alg (Пү.1 0))) :=
  rfl

