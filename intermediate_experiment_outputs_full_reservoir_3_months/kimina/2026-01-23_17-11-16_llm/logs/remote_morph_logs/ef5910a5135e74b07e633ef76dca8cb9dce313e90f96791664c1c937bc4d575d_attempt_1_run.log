noncomputable
def pullCount [DecidableEq Оұ] [Countable Оұ] [DecidableEq R] [Nonempty R] (a : Оұ) (r : R) (x : в„• вҶ’ Оұ Г— R) (n : в„•) : в„• :=
  if n = 0 then 0 else
  let x_prev := x (n - 1)
  let a_prev := x_prev.1
  let r_prev := x_prev.2
  if x n.1 = a_prev then pullCount a r x (n - 1) + 1 else pullCount a r x (n - 1)

