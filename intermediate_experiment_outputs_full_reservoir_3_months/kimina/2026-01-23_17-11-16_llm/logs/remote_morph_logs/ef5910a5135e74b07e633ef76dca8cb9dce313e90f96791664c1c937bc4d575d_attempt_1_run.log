noncomputable
def history [DecidableEq Оұ] [Countable Оұ] [DecidableEq R] [Nonempty R] (a : Оұ) (r : R) (x : в„• вҶ’ Оұ Г— R) (n : в„•) : Iic n вҶ’ Оұ Г— R :=
  if n = 0 then fun _ вҶҰ (a, r) else
  let x_prev := x (n - 1)
  let a_prev := x_prev.1
  let r_prev := x_prev.2
  if x n.1 = a_prev then
    fun i вҶҰ if i = вҹЁn, _вҹ© then (x n.1, r n x n.1) else (x i, r i (x i).1)
  else
    fun i вҶҰ if i = вҹЁn, _вҹ© then (x n.1, r n x n.1) else
      if i вҲҲ (fun (j : в„•) вҶҰ (j, a_prev)).preimage (Finset.Icc 0 n) then (x i, r i (x i).1) else
        (x_prev, r_prev)

