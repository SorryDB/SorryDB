def banditProcess [DecidableEq Оұ] [Countable Оұ] [DecidableEq R] [Nonempty R] (a : Оұ) (r : R вҶ’ Оұ вҶ’ R) (x : в„• вҶ’ Оұ Г— R) (Пү : в„• вҶ’ I) (t : в„•) : Оұ Г— R :=
  let Пү_prev := Пү (t - 1)
  let a_prev := Пү_prev.1
  let r_prev := Пү_prev.2
  if t = 0 then (a, r a)
  else if Пү t = a_prev then (a, r a) else
    let r'_t := r (t + 1) (Пү t)
    let r'_t_prev := r t a_prev
    if r'_t < r'_t_prev then (a, r a) else (a_prev, r_prev)

