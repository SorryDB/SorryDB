def Category.IsRetraction {X Y : α} (f : Hom X Y) (g : Hom Y X) := f ≫ g = id X
def Category.IsRetract (X Y : α) := ∃ (f : Hom X Y), ∃ (g : Hom Y X), f ≫ g = id X

