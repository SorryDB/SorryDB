    ∀ c : α, Function.Injective (fun g : Hom c X => g ≫ f) := by
  intros g1 g2 h
  apply hf

theorem mono_inj {X Y : α} (f : Hom X Y) (hf : Mono f) :
    ∀ c : α, Function.Injective (fun g : Hom c X => g ≫ f) := by
  intros g1 g2 h
