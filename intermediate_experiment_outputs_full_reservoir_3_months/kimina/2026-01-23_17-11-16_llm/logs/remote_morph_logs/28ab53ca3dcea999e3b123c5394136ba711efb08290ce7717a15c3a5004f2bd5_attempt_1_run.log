theorem retraction_epi {X Y : α} (f : Hom X Y) (g : Hom Y X)
    (h : IsRetraction f g) : Epi f := by
  sorry

def split_epi {X Y : α} (f : Hom X Y) := ∃ (g : Hom Y X), IsRetraction f g
def split_mono {X Y : α} (f : Hom Y X) := ∃ (g : Hom X Y), IsSection f g

