import Mathlib

open Set

namespace CategoryInContext

open Category

-- need a type synomym the types in the opposite category
-- so that typeclass resolution doesn't get confused
-- by having two instances of Category on the same type.
def Opposite (α : Type*) := α

-- definition 1.2.1
instance Category.opp {α : Type*} [C : Category α] : Category (Opposite α) where
  Hom X Y := C.Hom Y X
  id X := C.id X
  comp f g := C.comp g f
  id_comp := by simp [comp_id]
  comp_id := by simp [id_comp]
  assoc := by simp [← assoc]

-- exmaple 1.2.2.i
def Matrix (m n : ℕ) (α : Type*) [AddCommMonoid α] [Ring α] : Type* := Matrix (Fin m) (Fin n) α

noncomputable instance Matrix.ring (m n : ℕ) (α : Type*) [AddCommMonoid α] [Ring α] : Ring (Matrix m n α) := by
  sorry

noncomputable instance Matrix.add_comm_monoid (m n : ℕ) (α : Type*) [AddCommMonoid α] : AddCommMonoid (Matrix m n α) := by
  sorry

noncomputable instance Matrix.category (m n : ℕ) (α : Type*) [Ring α] : Category (Matrix m n α) := by
  sorry

variable {α : Type*} [C : Category α]

theorem Matrix_opp_eq_MatR' [Ring α] : (Matrix α).opp = Matrix' α := by sorry

-- exmaple 1.2.2.ii
noncomputable instance Poset' (α : Type*) [PartialOrder α] : Category α where
  Hom X Y := PLift (Y ≤ X) -- some universe gymnastics to move between Prop and Type
  id X := ⟨le_refl X⟩
  comp f g := ⟨le_trans g.down f.down⟩
  id_comp _ := rfl
  comp_id _ := rfl
  assoc _ _ _ := rfl

theorem Poset_opp_eq_poset' [PartialOrder α] : (Poset α).opp = Poset' α := by sorry

-- lemma 1.2.3
lemma iso_equiv {X Y : α} (f : Hom X Y) :
  [ IsIso f,
    ∀ c : α, Function.Bijective (fun g : Hom c X => g ≫ f),
    ∀ c : α, Function.Bijective (fun g : Hom Y c => f ≫ g)
  ].TFAE := by sorry

-- definition 1.2.7
def Category.Mono {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k
def Category.Epi {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k

lemma mono_op_epi {X Y : α} (f : Hom X Y) :
    Mono f ↔ @Epi (Opposite α) _ Y X f := by
  sorry

lemma epi_op_mono {X Y : α} (f : Hom X Y) :
    Epi f ↔ @Mono (Opposite α) _ Y X f := by
  sorry

