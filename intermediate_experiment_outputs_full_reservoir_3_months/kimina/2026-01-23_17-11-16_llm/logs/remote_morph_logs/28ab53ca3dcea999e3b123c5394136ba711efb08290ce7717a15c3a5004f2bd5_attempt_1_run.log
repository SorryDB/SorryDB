      all_goals try { tauto }
  · -- Assume ∀ (c : α), Function.Surjective (fun g => f ≫ g), prove split_epi f
    intro h
    have h1 : Function.Surjective (fun g => f ≫ g) := h
    have h2 : ∃ w : Hom Y X, f ≫ w = id X := by
      apply h1
      all_goals
        try { simp }
        all_goals try { tauto }
    rcases h2 with ⟨g, hg⟩
    exact ⟨g, hg⟩
```

