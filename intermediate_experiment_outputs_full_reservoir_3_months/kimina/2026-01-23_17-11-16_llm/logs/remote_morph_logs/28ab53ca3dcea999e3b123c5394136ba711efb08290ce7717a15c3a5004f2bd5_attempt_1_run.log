-- example 1.2.8
-- note we need to use Category.Hom and not just Hom,
-- because we are not in the namespace Category.
example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Mono f) :
    Function.Injective f := by sorry
example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Epi f) :
    Function.Surjective f := by sorry

-- example 1.2.9
def IsSection {X Y : α} (f : Hom Y X) (g : Hom X Y) := g ≫ f = id X
def IsRetraction {X Y : α} (f : Hom X Y) (g : Hom Y X) := f ≫ g = id X
def IsRetract (X Y : α) := ∃ (f : Hom X Y), ∃ (g : Hom Y X), f ≫ g = id X

-- alias IsRightInverse := IsSection
-- alias IsLeftInverse := IsRetraction

theorem section_mono {X Y : α} (f : Hom Y X) (g : Hom X Y) (h : IsSection f g) :
    Mono f := by
