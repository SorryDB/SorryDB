open Set

noncomputable instance CategoryInContext : Category (Set α) where
  Hom X Y := Set (X → Y)
  id X := fun x => x
  comp f g := fun x => f (g x)
  id_comp := by simp [comp]
  comp_id := by simp [comp]
  assoc := by simp [comp, Function.comp_apply]

variable {α : Type*} [C : Category α]

theorem split_epi_iff (f : C.Hom X Y) :
    split_epi f ↔ ∀ c : α, Function.Surjective fun g => comp f g := by
