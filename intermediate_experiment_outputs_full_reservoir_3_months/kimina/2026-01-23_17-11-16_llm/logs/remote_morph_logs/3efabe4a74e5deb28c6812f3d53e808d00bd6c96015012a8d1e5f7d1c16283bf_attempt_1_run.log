            field_simp at ⊢ hp' hs
            rewrite [show (2 : ℝ) ^ (n + 1) = 2 * 2 ^ n by ring_nf]
            have f : (p.1 + p.2) * 2 ^ n ≤ 2 * s * 2 ^ n := by bound
            linarith [hp', hs, hp.2.2.1, f]
        · use (p.1, mid)
          split_ands
