lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  have h1 : ∀ D ∈ R.carrier, D = ∅ := by
    intro D hD
    have h2 : sSupIndep D := R.carrier_indep D hD
    by_cases h : D = ∅
    · exact h
    · -- Assume D ≠ ∅
      have h3 : ∃ c, c ∈ D := by
        by_contra h
        push_neg at h
        have : D = ∅ := by
          ext x
          simp [h]
        contradiction
      rcases h3 with ⟨c, hc⟩
      have h4 : c ⊓ c = ⊥ := by
        apply h2
        all_goals simp [hc]
      have h5 : c ⊓ c = c := by
        simp
      have h6 : c = ⊥ := by
        linarith [h4, h5]
      have h7 : ⊥ ∈ D := by
        rw [h6] at hc
        exact hc
      have h8 : ⊥ ∉ D := R.bot_not_mem D hD
      contradiction
  have h2 : decomposition_of_refinement R = ∅ := by
    ext x
    simp [decomposition_of_refinement, h1]
  have h3 : ∀ a ∈ S, a = ⊥ := by
    intro a ha
    have h5 : ∃! D ∈ R.carrier, a = sSup D := R.carrier_span a ha
    rcases h5 with ⟨D, hD1, hD2⟩
    have h6 : D ∈ R.carrier := hD1
    have h7 : D = ∅ := h1 D h6
    have h8 : sSup D = ⊥ := by
      rw [h7]
      simp
    have h9 : a = ⊥ := by
      linarith [hD2.1, h8]
    exact h9
