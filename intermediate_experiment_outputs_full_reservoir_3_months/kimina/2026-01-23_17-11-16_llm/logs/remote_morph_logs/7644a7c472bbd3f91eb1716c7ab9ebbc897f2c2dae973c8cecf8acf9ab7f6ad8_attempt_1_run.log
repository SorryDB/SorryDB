    cases Set.eq_empty_or_nonempty S with
    | inl hS_empty =>
      rw [hS_empty]
      simp
    | inr hS_nonempty =>
      have h5 : ∃ a, a ∈ S := hS_nonempty
      rcases h5 with ⟨a, ha⟩
      have ha_eq : a = ⊥ := h3 a ha
      have h6 : ∀ s ∈ S, s ≤ ⊥ := by
