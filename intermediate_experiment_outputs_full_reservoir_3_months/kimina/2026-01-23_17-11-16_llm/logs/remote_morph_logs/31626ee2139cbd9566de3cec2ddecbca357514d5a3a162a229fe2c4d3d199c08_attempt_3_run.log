```lean
import Data.List

variable {α} {n : Nat}

theorem list_insertIdx_length {l1 l2 : List α} {idx : Nat} {hidx : idx <= l1.length}
    {l1 : List α} {elt : α} :
    (l1 ++ l2).insertIdx idx elt = (l1.insertIdx idx elt) ++ l2 := by 
  induction l1 with
  | nil =>
    simp at hidx ⊢
    <;> omega
  | cons hd tl h1 =>
    rw [List.length_cons] at h1
    have h2 : ∀ {j : Nat} {hj : j ≤ 1 + tl.length}, (tl ++ l2).insertIdx j elt = (tl).insertIdx j elt ++ l2 := by
      intro j hj
      apply h1
      all_goals
        omega
    by_cases h3 : idx = 0
    · 
      rw [h3]
      simp [List.insertIdx]
      <;> tauto
    · 
      have h4 : 1 ≤ idx := by
        by_contra h
        push_neg at h
        have : idx = 0 := by linarith
        tauto
      have h5 : idx - 1 ≤ 1 + tl.length := by
        omega
      have h6 : (tl ++ l2).insertIdx (idx - 1) elt = (tl).insertIdx (idx - 1) elt ++ l2 := by
        apply h2 (idx - 1)
        all_goals
          omega
      have h7 : (hd :: (tl ++ l2)).insertIdx idx elt = hd :: (tl ++ l2).insertIdx (idx - 1) elt := by
        rw [show idx = (idx - 1) + 1 by omega]
        simp [List.insertIdx]
        <;> tauto
      have h8 : (hd :: tl).insertIdx idx elt = (hd :: (tl).insertIdx (idx - 1) elt) := by
        rw [show idx = (idx - 1) + 1 by omega]
        simp [List.insertIdx]
        <;> tauto
      rw [h7, h8]
      rw [h6]
      <;> simp [List.append]
      <;> tauto
```

