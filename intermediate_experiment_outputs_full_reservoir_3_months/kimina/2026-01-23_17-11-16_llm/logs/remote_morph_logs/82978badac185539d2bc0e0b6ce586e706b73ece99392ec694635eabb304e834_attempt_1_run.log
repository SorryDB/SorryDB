import Mathlib

-- This imports all the necessary libraries for our work.

/-
This defines the structure that holds all the information about our system.
-/
structure SystemState {
  id : Nat,
  request : Option (Request),
  time : Nat,
  predecessor : Option (ThreadId),
  predecessor_at : List (ThreadId),
  successors : List (ThreadId),
  propagators : List (ThreadId),
  value? : Option (Int),
  isWrite : Bool,
  isInitial : Bool,
  isFinal : Bool,
  isStuck : Bool,
  isSolved : Bool,
  isAborted : Bool,
  isParked : Bool,
  isPropagated : Bool,
  isSolvedAt : Option (ThreadId),
  isParkedAt : Option (ThreadId)
}

-- This defines the structure that holds all the information about our system.
-- For simplicity, we'll use the same structure for both versions.
-- In a more realistic scenario, this would be different.
structure SystemState where
  id : Nat,
  request : Option (Request),
  time : Nat,
  predecessor : Option (ThreadId),
  predecessor_at : List (ThreadId),
  successors : List (ThreadId),
  propagators : List (ThreadId),
  value? : Option (Int),
  isWrite : Bool,
  isInitial : Bool,
  isFinal : Bool,
  isStuck : Bool,
  isSolved : Bool,
  isAborted : Bool,
  isParked : Bool,
  isPropagated : Bool,
  isSolvedAt : Option (ThreadId),
  isParkedAt : Option (ThreadId)

-- This defines a thread in our system.
structure Thread {
  id : Nat,
  state : SystemState,
  time : Nat,
  predecessor : Option (ThreadId),
  predecessor_at : List (ThreadId),
  successors : List (ThreadId),
  propagators : List (ThreadId),
  value? : Option (Int),
  isWrite : Bool,
  isInitial : Bool,
  isFinal : Bool,
  isStuck : Bool,
  isSolved : Bool,
  isAborted : Bool,
  isParked : Bool,
  isPropagated : Bool,
  isSolvedAt : Option (ThreadId),
  isParkedAt : Option (ThreadId)
}

-- This defines a request in our system.
structure Request {
  id : Nat,
  state : SystemState,
  time : Nat,
  predecessor : Option (ThreadId),
  predecessor_at : List (ThreadId),
  successors : List (ThreadId),
  propagators : List (ThreadId),
  value? : Option (Int),
  isWrite : Bool,
  isInitial : Bool,
  isFinal : Bool,
  isStuck : Bool,
  isSolved : Bool,
  isAborted : Bool,
  isParked : Bool,
  isPropagated : Bool,
  isSolvedAt : Option (ThreadId),
  isParkedAt : Option (ThreadId)
}

-- This defines a valid set of scopes.
structure ValidScopes {
  scopes : List (ThreadId),
  subscopes : List (ThreadId) → List (ThreadId),
  jointScopes : List (ThreadId) → List (ThreadId),
  validate : (ThreadId) → Bool
}

-- This defines the order constraints for our system.
structure OrderConstraints {V : ValidScopes} where
  val : Std.HashMap (List ThreadId) (Std.HashMap (RequestId × RequestId) Bool)
  default : Bool

-- This defines the request array for our system.
structure RequestArray where
  val : Array (Option (Request))
  coherent : valConsistent val = true

-- This defines the initial state of the system.
def initialState : SystemState := {
  id := 0,
  request := none,
  time := 0,
  predecessor := none,
  predecessor_at := [],
