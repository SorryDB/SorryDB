   let opIds :=  Array.toList $ arr.val.map (Option.map Request.id)
   filterNones opIds

def growArray {α : Type} (a : Array (Option α)) (n : Nat) : Array (Option α) :=
  --dbg_trace s!"growing array of size {a.size} by {n}"
  a.append (Array.replicate (n - a.size) none)

-- This is the definition of _insert that contains the error
def RequestArray._insert : RequestArray → Request → Array (Option (Request))
  | arr, req =>
    --dbg_trace "growing [{arr}] of size {arr.val.size} to {req.id.toNat + 1} for Request {req}"
    let vals' := growArray arr.val (req.id.toNat + 1)
    let i := req.id.toNat.toUSize
    if h : i.toNat < vals'.size
    then vals'.uset i (some req) h
    else if h: (Nat.beq i.toNat vals'.size) then
      let hless : i.toNat < vals'.size + 1 := by
        {apply Nat.lt_of_succ_le
         apply Nat.le_of_eq
         rw [Nat.succ_eq_add_one]
         rw [Nat.beq_eq] at h
         rw [h]
         }
      let idfin := Fin.mk i.toNat hless
      vals'.insertIdx idfin (some req)
    else unreachable! -- because of growArray before

-- This is the definition of insertAtPosition that contains the error
def RequestArray.insertAtPosition : RequestArray → Option (Request) → USize → RequestArray
  | arr, opReq, i =>
    let val' := if h1 : i.toNat < arr.val.size
      then arr.val.uset i opReq h1
      else if h2 : i.toNat = arr.val.size then
        let idfin := Fin.mk i.toNat (by
          {apply Nat.lt_of_succ_le
           apply Nat.le_of_eq
           rw [Nat.succ_eq_add_one]
           rw [Nat.beq_eq] at h2
           rw [h2]
           }
        )
        (arr.val).insertIdx idfin opReq
      else -- this is the case where i >= arr.val.size + 1
        -- which is impossible due to the type of i : USize
        sorry -- This branch should not be reachable for USize i
    { val := val', coherent := sorry } -- The main error is in this 'sorry'
```

