import Mathlib

/-!
  A `ValidScopes` is a finite set of `Scope`s, where each `Scope` is a list of `ThreadId`s.
  This is used to represent the set of valid scopes in a system.
  -/
structure ValidScopes : Type where
  scopes : List (List ThreadId)
  -- A scope is valid if it's in the list
  valid : ∀ (s : List ThreadId), s ∈ scopes → True
  -- A scope is valid if it's in the list
  -- We also assume that the scopes are non-empty
  nonempty : ∀ s ∈ scopes, s.Nonempty
  -- We also assume that the scopes are non-empty
  -- We also assume that the scopes are nested, i.e. if s' is in s, then s' is a prefix of s
  nested : ∀ s₁ s₂, s₁ ∈ scopes → s₂ ∈ scopes → (s₁.∀ t, t ∈ s₂ → t ∈ s₁) ∨ (s₂.∀ t, t ∈ s₁ → t ∈ s₂)
  -- We also assume that the scopes are nested, i.e. if s' is in s, then s' is a prefix of s
  -- We also assume that there is a unique "joint scope" that contains all others
  -- This is a simplification for now, in reality the joint scope is not unique.
  jointScope : List ThreadId

/-!
  A `Request` is an operation that a thread can perform.
  It has an identifier, a thread it was created on, a list of threads it propagates to,
  and a boolean flag indicating if it's a write operation.
  -/
structure Request : Type where
  id : Nat
  thread : ThreadId
  propagatedTo : List ThreadId
  isWrite : Bool

