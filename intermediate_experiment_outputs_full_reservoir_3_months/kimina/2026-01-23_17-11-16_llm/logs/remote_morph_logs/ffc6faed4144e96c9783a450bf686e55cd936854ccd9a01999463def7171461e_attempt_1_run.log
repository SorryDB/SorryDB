```tactics
import Mathlib

open ProbabilityTheory
open MeasureTheory

noncomputable abbrev uniformSelectList (xs : List α) :
    SPMF α := fun x ↦
      if List.isEmpty xs then
        if x = ⊥ then 1 else 0
      else
        (List.count x xs : ℝ≥0∞) / List.length xs

noncomputable abbrev uniformSelectVector (xs : Vector α (n + 1)) :
    SPMF α := fun x ↦
      if List.isEmpty xs.toList then
        if x = ⊥ then 1 else 0
      else
        (xs.toList.count x : ℝ≥0∞) / xs.toList.length

noncomputable abbrev uniformSelectFinset (s : Finset α) :
    SPMF α := fun x ↦
      if x ∈ s then (s.card : ℝ≥0∞)⁻¹ else 0

noncomputable abbrev uniformSelect (β : Type) [Fintype β] [Inhabited β] :
    SPMF β := fun x ↦ (Fintype.card β : ℝ≥0∞)⁻¹

variable (α : Type) [hα : Fintype α] [Inhabited α] [DecidableEq α]

theorem theorem1 :
    ∑ x : α, Pr[= x | uniformSelect α] = 1 := by
  simp only [Finset.sum_const, Finset.card_univ, nsmul_eq_mul, mul_one, mul_inv_cancel]
  exact Fintype.card_pos.mpr (Fintype.card_pos.mpr (Fintype.card_pos.mpr hα))

variable (α : Type) [hα : Fintype α] [Inhabited α] [DecidableEq α]

theorem theorem2 :
    ∀ x : α, Pr[= x | uniformSelect α] = (Fintype.card α : ℝ≥0∞)⁻¹ := by
  intro x
  simp only [Finset.mem_univ, Finset.sum_const, Finset.card_univ, nsmul_eq_mul, mul_one,
    mul_inv_cancel]
```

