variable (α : Type) [DecidableEq α]

noncomputable def evalSPMF (f : SPMF α) (x : α) : ℝ≥0∞ := f.eval x

noncomputable def evalSPMF' (f : SPMF α) : SPMF (ℝ≥0∞) := fun x ↦ evalSPMF f x

noncomputable def evalDist (f : SPMF α) : SPMF (ℝ≥0∞) := fun x ↦ (f.eval x).toReal

noncomputable def support (f : SPMF α) : Set α := {x | f.eval x > 0}

noncomputable def finSupport (f : SPMF α) [DecidableEq α] : Finset α := f.support.toFinset

noncomputable def evalSPMFOnFinset (f : SPMF α) (s : Finset α) : SPMF (ℝ≥0∞) := fun x ↦ (f.eval x).toReal

noncomputable def evalSPMFOnFinset' (f : SPMF α) (s : Finset α) : SPMF α := fun x ↦ if x ∈ s then f.eval x else 0

noncomputable def evalSPMFOnFinset'' (f : SPMF α) (s : Finset α) : SPMF (Finset α) := fun x ↦ if x ∈ s then f.eval x else 0

