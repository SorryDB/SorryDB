import Mathlib

open Finset

namespace uniformSelect

variable {α : Type} [DecidableEq α] {β : Type} [DecidableEq β]

/-- A computation that selects a value of type `α` uniformly at random from a list of values of type `α`.
The result is a value of type `α` wrapped in a `Some` constructor if the list is non-empty, or `None` if the list is empty.
This is a noncomputable operation due to the use of `List.get`. -/
noncomputable def uniformSelectList (xs : List α) : ProbComp (Option α) :=
  if List.isEmpty xs then
    return none
  else
    let n := List.length xs
    let w : Fin n → α := fun i => List.get i
    let s : Fin n → Prop := fun _ => True
    return (@OptionT.some (Fin n → α) (fun i ↦ return (w i)) (fun i ↦ return s i) (fun i j ↦ return Eq.refl _))

-- lemma uniformSelectList_def {α : Type} [DecidableEq α] (xs : List α) :
--     ($ uniformSelectList xs) = (@OptionT.some (List α) (fun x ↦ return x) (fun x ↦ return True) (fun x y ↦ return Eq.refl _)) := by rfl

-- /- A computation that selects a value of type `α` uniformly at random from a vector of values of type `α`.
The result is a value of type `α` wrapped in a `Some` constructor if the vector is non-empty, or `None` if the vector is empty.
This is a noncomputable operation due to the use of `List.get`. -/
