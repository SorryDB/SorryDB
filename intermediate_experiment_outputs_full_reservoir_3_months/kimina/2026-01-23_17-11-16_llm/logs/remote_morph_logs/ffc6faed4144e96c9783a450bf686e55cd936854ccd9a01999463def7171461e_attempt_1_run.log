/-- A computation that selects a value of type `α` uniformly at random from a finite set of values of type `α`.
The result is a value of type `α` wrapped in a `Some` constructor if the set is non-empty, or `None` if the set is empty.
This is a noncomputable operation due to the use of `List.get`. -/
noncomputable def uniformSelectFinset (s : Finset α) : ProbComp (Option α) :=
  if s.Nonempty then
    let x : α := s.choose
    return some x
  else
    return none

/-- A computation that selects a value of type `α` uniformly at random from a type `α` that has a `Fintype` instance.
The result is a value of type `α` wrapped in a `Some` constructor if the type is non-empty, or `None` if the type is empty.
This is a noncomputable operation due to the use of `List.get`. -/
noncomputable def uniformSelectFintype (α : Type) [h : Fintype α] [Inhabited α] :
    ProbComp (Option α) := $! (List.get ⟨List.range (Fintype.card α), fun i j ↦ rfl⟩)

/-- A computation that selects a value of type `α` uniformly at random from a type `α` that has a `Fintype` instance and a `DecidableEq` instance.
The result is a value of type `α` wrapped in a `Some` constructor if the type is non-empty, or `None` if the type is empty.
This is a noncomputable operation due to the use of `List.get`. -/
noncomputable def uniformSelect (α : Type) [h : Fintype α] [Inhabited α] [DecidableEq α] :
    ProbComp α := $! (List.get ⟨List.range (Fintype.card α), fun i j ↦ rfl⟩)

/- A computation that selects a value of type `α` uniformly at random from a type `α` that has a `Fintype` instance and a `DecidableEq` instance and a `HasUniformSelect` instance.
