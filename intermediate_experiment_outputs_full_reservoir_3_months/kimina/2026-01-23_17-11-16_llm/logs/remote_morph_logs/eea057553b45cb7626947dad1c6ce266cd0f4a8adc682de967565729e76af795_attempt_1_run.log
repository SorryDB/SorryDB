  -- Let's establish the inequality for E1
  have hE1leq : (1 / ↑n : ℝ) • ↑(E1 ε2 n) * (↑(↑((ρ : MState (H i)).state.pow n)).log - ↑(↑(pinching_map (@SteinsLemma.σ'' ι inst i ρ ε m σ n)).log) ≤ ((R1 ρ ε).toReal + ε2) • ↑(E1 ε2 n) := by
