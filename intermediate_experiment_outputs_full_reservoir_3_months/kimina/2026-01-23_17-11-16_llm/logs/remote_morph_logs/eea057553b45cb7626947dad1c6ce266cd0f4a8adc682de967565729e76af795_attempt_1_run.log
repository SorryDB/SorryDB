    (E1 P1 E2 P2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ)
    (c' : ℝ → ℕ → ℝ)
    (hE1 : E1 = 1 - P1)
    (hE2 : E2 = P1 - P2)
    (hE3 : E3 = P2)
    (hEsum : E1 + E2 + E3 = 1)
