/- This lemma shows that for any state ρ, any positive ε, any positive n, any positive δ,
the following holds: the relative entropy between ρ and a certain state related to σ'' (which depends on ε, δ, n) is bounded above by a specific expression involving ε, δ, n, and the eigenvalues of ρ.
This is a key result in the theory of information, with applications in statistical mechanics and probability.
-/
lemma SandwichedRelRentropy (i : ι) (inst : UnitalFreeStateTheory ι) (ρ : MState (H i))
    (ε : Prob) (δ : Prob) (n : ℕ) (hn : 0 < n) (hδn : δ < 1 / ↑n) :
    Real.log ((↑((ρ : MState (H i)).state).norm)⁻¹) + Real.log (n : ℝ) + Real.log (δ : ℝ) +
    Real.log ((1 - δ : ℝ)) ≤
    ((R1 ρ ε).toReal + ε) + ((R2 ρ σ + δ + ε) - (R1 ρ ε + ε)) +
    ((R2 ρ σ + δ + ε) - (R1 ρ ε + ε)) := by
  -- First, let's define some objects we'll need
  -- Let's define σ'' as a state that is a convex combination of the maximally mixed state and a state related to R2
  let σ'' : (n : ℕ) → ↑IsFree → MState (H (i ^ n)) := fun n => pinching_map (@SteinsLemma.σ'' ι inst i ρ ε m σ n)
  -- Let's define E1, E2, E3 as projectors onto different subspaces of the Hilbert space
  let E1 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (R1 ρ ε) + ε2)) • ↑(pinching_map (@SteinsLemma.σ'' ι inst i ρ ε m σ n))).proj_lt ↑((ρ : MState (H i)).state.pow n)
  let E2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (R2 ρ σ) + ε₀ + ε2)) • ↑(pinching_map (@SteinsLemma.σ'' ι inst i ρ ε m σ n))).proj_le ↑((ρ : MState (H i)).state.pow n)
  let E3 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (R2 ρ σ) + ε₀ + ε2)) • ↑(pinching_map (@SteinsLemma.σ'' ι inst i ρ ε m σ n))).proj_lt ↑((ρ : MState (H i)).state.pow n)
  let Esum : E1 + E2 + E3 = 1 := sorry
  -- Let's define P1, P2 as intermediate projectors
  let P1 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (R1 ρ ε) + ε2)) • ↑(pinching_map (@SteinsLemma.σ'' ι inst i ρ ε m σ n))).proj_le ↑((ρ : MState (H i)).state.pow n)
  let P2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := fun ε2 n => (Real.exp (↑n * (ENNReal.toReal (R2 ρ σ) + ε₀ + ε2)) • ↑(pinching_map (@SteinsLemma.σ'' ι inst i ρ ε m σ n))).proj_le ↑((ρ : MState (H i)).state.pow n)
  have hPcomm : ∀ (ε2 : ℝ) (n : ℕ), Commute ↑(P1 ε2 n) ↑(P2 ε2 n) := sorry
  -- Let's define c' as a threshold value
  let c' : ℝ → ℕ → ℝ := fun ε2 n => max (σ₁_c + σ₁_c' / ↑n) (R2 + ε₀ + ε2)
  have hc' : ∀ (ε2 : ℕ → NNReal), (∀ (n : ℕ), ε2 n < 1) → ∃ C, ∀ᶠ (n : ℕ) in Filter.atTop, c' (↑(ε2 n)) n ≤ ↑C := sorry
  -- Let's show that the exponential of -n*c' is less than or equal to σ''
  have hσ'' : ∀ (ε2 : ℝ) (n : ℕ), Real.exp (-↑n * c' ε2 n) • 1 ≤ ↑(pinching_map (@SteinsLemma.σ'' ι inst i ρ ε m σ n)) := sorry
