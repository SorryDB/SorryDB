    have hB1 : N = sSup (B N hN1) := hB N hN1
    have hN2 : N ∈ D := hN1
    have hN3 : N ∈ D := hN1
    have hN4 : N = sSup (B N hN1) := hB N hN1
    have hN5 : sSupIndep (B N hN1) := hB' N hN1
    have hN6 : ⊥ ∉ B N hN1 := hB'' N hN1
    have hN7 : N ∈ D := hN1
    have hN8 : N ∈ D := hN1
    have hN9 : N ∈ D := hN1
    have hN10 : N ∈ D := hN1
    have hN11 : N = sSup (B N hN1) := hB N hN1
    have hN12 : sSupIndep (B N hN1) := hB' N hN1
    have hN13 : ⊥ ∉ B N hN1 := hB'' N hN1
