        exact hN
      exact D.not_bot_mem hN_mem
    intro p_eq_bot
    have hN_eq_bot : N = ⊥ := by
      exact p_eq_bot ▸ (sSup_eq_bot (by simp)).1 (by simp [p_eq_bot])
