    have h_le : x ≤ y := by
      have h_aux1 : p ≤ sSup (B N hN) := by
        apply le_sSup
        exact p ∈ B N hN
      have h_aux2 : p' ≤ sSup (B N' hN') := by
        apply le_sSup
        exact p' ∈ B N' hN'
      have h_aux3 : sSup (B N hN) = N := by
        exact hB N hN
      have h_aux4 : sSup (B N' hN') = N' := by
        exact hB N' hN'
      have h_aux5 : N ≤ N' := by
        apply le_trans (le_sSup h_aux1) h_aux3
      apply le_trans h_aux4 (le_sSup h_aux2)
    have h_le' : y ≤ x := by
      have h_aux1 : p' ≤ sSup (B N' hN') := by
        apply le_sSup
        exact p' ∈ B N' hN'
      have h_aux2 : p ≤ sSup (B N hN) := by
        apply le_sSup
        exact p ∈ B N hN
      have h_aux3 : sSup (B N hN) = N := by
        exact hB N hN
      have h_aux4 : sSup (B N' hN') = N' := by
        exact hB N' hN'
      have h_aux5 : N' ≤ N := by
        apply le_trans (le_sSup h_aux2) h_aux3
      apply le_trans h_aux4 (le_sSup h_aux1)
    have h_eq : x = y := by
      exact le_antisymm h_le h_le'
    rw [h_eq] at hxy
    exact hxy (by simp)
