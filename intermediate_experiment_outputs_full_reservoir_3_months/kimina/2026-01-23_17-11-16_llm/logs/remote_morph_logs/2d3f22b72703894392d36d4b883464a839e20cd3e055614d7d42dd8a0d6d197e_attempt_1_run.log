    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' := by
    intro s h_s N h_N
    simp only [Set.mem_iUnion, Set.mem_iUnion, Set.mem_setOf_eq] at h_s h_N
    rcases h_s with ⟨N, hN, B⟩
    rcases h_N with ⟨hN', hN''⟩
    simp only [Set.mem_setOf_eq] at hN''
    have hN1 : N ∈ D := by
