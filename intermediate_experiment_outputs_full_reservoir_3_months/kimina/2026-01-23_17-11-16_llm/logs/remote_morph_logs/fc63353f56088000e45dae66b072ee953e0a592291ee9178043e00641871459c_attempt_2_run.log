-- definition 1.3.14
def Comma_category (D C E : Type*) [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) : Type (max (max u_1 u_2) u_3) :=
  Σ (d : D) (e : E), (C.Hom (F.F d) (G.F e))

-- instance of category structure on the comma category
instance : Category (Comma_category D C E F G) where
  Hom X Y := {
    val := (X.1.1 ↦ Y.1.1) × (X.1.2 ↦ Y.1.2)
    property := by
      intro h
      simp only [Prod.mk.injEq]
      tauto
  }
  id X := {
    val := (id X.1.1, id X.1.2)
    property := by
      simp only [Prod.mk.injEq]
      tauto
  }
  comp f g := {
    val := ((f.val.1 ≫ g.val.1), (f.val.2 ≫ g.val.2))
    property := by
      intro h
      simp only [Prod.mk.injEq]
      tauto
  }
  id_comp := by
    intro X
    simp only [comp, id, Prod.mk.injEq]
    all_goals tauto
  comp_id := by
    intro X
    simp only [comp, id, Prod.mk.injEq]
    all_goals tauto
  associativity := by
    intro X Y Z h
    simp only [comp, Prod.mk.injEq]
    all_goals tauto

-- instance of functors on the comma category
def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    @Functor (Comma_category D C E F G) D := sorry

def Comma_category_cod {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    @Functor (Comma_category D C E F G) E := sorry

-- definition 1.3.15
def prod_functor_bifunctorial {α β γ : Type*} [C : Category α] [D : Category β] [E : Category γ]
    (F : @Functor (α × β) γ) : @Functor α β := sorry

