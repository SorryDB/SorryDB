  F := fun X => F.F (X, default)
  homF := fun {X Y} f => F.homF (f, id default)
  map_id X := by
    rw [← F.map_id]
    congr
  map_comp f g := by
    rw [← F.map_comp]
    congr
    rw [id_comp]

