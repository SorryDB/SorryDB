import Mathlib

namespace CategoryInContext

open Category

-- ... (previous definitions) ...

def Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Type (max (CD.u) (CE.u) ⊔ max (D.u) (E.u) ⊔ max (C.u) (C.v))
    := Σ (d : D) (e : E), Hom (F d) (G e)

-- ... (other definitions) ...

instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) : Category (Σ (d : D) (e : E), Hom (F d) (G e)) where
  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [functor_comp, functor_comp]
    rw [hf']
    rw [← hf]
    rw [functor_comp]
    rw [functor_comp]
  ⟩

  id_comp := sorry
  comp_id := sorry
  assoc := sorry
