-- exercise 1.3.vi
-- using exercise notation, instead of mathlib style
instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where

  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := sorry
  comp_id := sorry
  assoc := sorry

--todo: how to refactor the comma category type to avoid spelling it out.
def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) D where
  F := fun ⟨X, _, _⟩ => X
  homF := fun ⟨X, _, _⟩ Y hk => hk.1
  map_id X := by sorry
  map_comp f g := by sorry

def Comma_category_cod {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) E where
  F := fun ⟨_, Y, _⟩ => Y
  homF := fun ⟨_, Y, _⟩ Z hk => hk.2
  map_id X := by sorry
  map_comp f g := by sorry

theorem Comma_functor_comp {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    @Comma_category D C E CC CD CE F G.comp = @Comma_category D C E CC CD CE (F.comp G) := by
  ext ⟨d, e, h⟩
  simp [Comma_category.comp]
  <;> aesop
```

The key insight is that in the `Comma` category, the composition of two functors `f'` and `g'` is defined component-wise as `(f'1 ∘ g'1, f'2 ∘ g'2)`. This is straightforward because the `comp` operation in the `Comma` category is defined as `(f.1 ≫ f'.1, f.2 ≫ f'.2)`. When we apply this to `f'` and `g'`, we get `(f'1 ∘ g'1, f'2 ∘ g'2)`, which is precisely the composition of the two functors in the `Comma` category.

The proof is remarkably concise because the definition of `comp` in the `Comma` category directly gives us the desired result. We just need to unfold the definition of `comp` and simplify. The `aesop` tactic is powerful enough to handle the resulting goals, which are primarily about the associativity of composition and the interaction of `comp` with the structure of the `Comma` category.
