noncomputable instance Comma_category (D C E : Type*) [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), (D.Hom (F.F d) (G.F e)) ) where
  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    { hk : (D.Hom d d' × E.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2) }
  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩
  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    simp [hf, hf', F.map_comp, G.map_comp, Category.assoc]
  ⟩
  id_comp := by
    simp [id, comp]
    <;> try { tauto }
  comp_id := by
    simp [comp, id]
    <;> try { tauto }
  assoc := by
    simp [comp]
