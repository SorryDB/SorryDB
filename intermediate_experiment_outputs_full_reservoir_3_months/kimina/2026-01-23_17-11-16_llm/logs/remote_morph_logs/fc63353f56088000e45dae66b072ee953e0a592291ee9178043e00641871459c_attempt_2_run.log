    intro a b c
    simp only
    rw [id_comp, id_comp, id_comp, id_comp]
    simp only

  comp_id := by
    intro a b c
    simp only
    rw [comp_id, comp_id, comp_id, comp_id]
    simp only

  assoc := by
    intro a b c
    simp only
    rw [assoc, assoc, assoc, ← assoc]
    simp only
