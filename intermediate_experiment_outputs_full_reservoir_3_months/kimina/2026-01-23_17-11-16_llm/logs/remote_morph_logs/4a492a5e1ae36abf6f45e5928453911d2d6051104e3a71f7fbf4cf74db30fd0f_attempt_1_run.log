```tactics
  have integrable_prod_norm_X : ∀ I ∈ A ×ˢ A ^ m, Integrable (fun ω ↦ ∏ k, ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by
    intro I hI
    have h1 : ∀ k : Fin m, Integrable (fun ω ↦ ‖X (I k).1 ω‖ * ‖X (I k).2 ω‖) μ := by
      intro k
      have h2 : Integrable (fun ω ↦ ‖X (I k).1 ω‖ ^ 2) μ := by
        have hX1 : X (I k).1 ∈ L^(2 * m) μ := by
          apply memLp_X
          simp at *
          <;> try { tauto }
          <;> try { aesop }
        exact hX1.integrable_pow 2
      have h3 : Integrable (fun ω ↦ ‖X (I k).2 ω‖ ^ 2) μ := by
        have hX2 : X (I k).2 ∈ L^(2 * m) μ := by
          apply memLp_X
          simp at *
          <;> try { tauto }
          <;> try { aesop }
