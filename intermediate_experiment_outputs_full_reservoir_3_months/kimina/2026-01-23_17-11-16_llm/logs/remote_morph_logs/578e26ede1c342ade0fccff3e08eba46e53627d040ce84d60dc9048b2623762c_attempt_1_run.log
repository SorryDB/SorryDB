        | cons hd tl HR =>
          intro f g
          simp only [List.mapFinIdx_cons, List.map_cons, HR, List.length_cons]

    theorem fin_range_eq {sz : Nat} :
      fin_range sz = fin_range' sz := by
        induction sz with
        | zero => rfl
        | succ n HR =>
          dsimp [fin_range]; rw [HR]; dsimp [fin_range']
          simp only [
            List.replicate, List.length_cons, List.mapFinIdx_cons, Fin.zero_eta,
            map_mapFinIdx, lift_fin
          ]

    theorem fin_in_fin_range' (sz : Nat) (i : Fin sz) : i ∈ fin_range' sz := by
      simp only [fin_range', List.mem_mapFinIdx, List.length_replicate]
      exists i.1, i.2

    theorem fin_in_fin_range (sz : Nat) (i : Fin sz) : i ∈ fin_range sz := by
      rw [fin_range_eq]; exact fin_in_fin_range' sz i

    theorem fin_range_len (sz : Nat) :
      (fin_range sz).length = sz := by
        induction sz with
        | zero => rfl
        | succ sz HR => simpa [fin_range, HR]

    def fin_range_len_cast {sz : Nat} : Fin (fin_range sz).length = Fin sz :=
      by rw [fin_range_len]

    def fin_conv {sz : Nat} (i : Fin (fin_range sz).length) : Fin sz :=
      ⟨i.1, by cases i; rename_i v h; rw [fin_range_len] at h; simpa only⟩

    def fin_conv' {sz : Nat} (i : Fin sz) : Fin (fin_range sz).length :=
      ⟨i.1, by rw [fin_range_len]; cases i; assumption⟩

    theorem fin_conv_conv {sz : Nat} (i : Fin (fin_range sz).length) :
      fin_conv' (fin_conv i) = i := by rfl

    theorem fin_conv_conv' {sz : Nat} (i : Fin sz) :
      fin_conv (fin_conv' i) = i := by rfl

    theorem mapFinIdx_length {α β} (l : List α) (f : (i : Nat) → α → (h : i < l.length) → β) :
      (List.mapFinIdx l f).length = l.length := by
        simpa only [List.length_mapFinIdx]

    theorem mapFinIdx_get {α β} (l : List α) (f : (i : Nat) → α → (h : i < l.length) → β) (i : Fin (List.mapFinIdx l f).length) :
      (List.mapFinIdx l f).get i = f i l[i] (by rw [←mapFinIdx_length l f]; exact i.2) := by
        simpa

    theorem fin_range_get {sz : Nat} {i : Fin (fin_range sz).length} :
      (fin_range sz).get i = fin_conv i := by
      -- rw [fin_range_eq]
      -- dsimp [fin_range]
      -- apply mapFinIdx_get
      sorry

    theorem fin_cast {sz sz' : Nat} (h : sz = sz' := by rfl) :
      Fin sz = Fin sz' := by subst h; rfl
```

Now we need to define the `RelIO` section:

```tactics
  end fin_range

  section RelIO
```

Now we define `RelIO.liftFinf`:

```tactics
    def RelIO.liftFinf {α : Type _} (n : Nat) (f : Fin n → α) : PortMap Nat α :=
      fin_range n |>.map (λ i => ⟨↑i.toNat, f i⟩) |>.toAssocList
```

Now we define the theorem `RelIO.mapVal`:

```tactics
    theorem RelIO.mapVal {α β} {n : Nat} {f : Fin n → α} {g : α → β} :
      AssocList.mapVal (λ _ => g) (RelIO.liftFinf n f) = RelIO.liftFinf n (λ i => g (f i)) := by
```

Now, we need to prove this equality. Let's try to understand what both sides represent:

- `RelIO.liftFinf n f` is `fin_range n |>.map (λ i => ⟨↑i.toNat, f i⟩) |>.toAssocList`. Let's denote this as `L`.
- `mapVal (λ _ => g) L` is `L.map (λ x => g x.val)`.
- `RelIO.liftFinf n (λ i => g (f i))` is `fin_range n |>.map (λ i => ⟨↑i.toNat, g (f i)⟩) |>.toAssocList`. Let's denote this as `R`.

So we need to prove that `L.map (λ x => g x.val) = R`.

Let's compute `L`:
`L = (fin_range n).map (fun i => ⟨↑i.toNat, f i⟩)).toAssocList`
So `L` is an `AssocList Nat α`.

Let's compute `R`:
`R = (fin_range n).map (fun i => ⟨↑i.toNat, g (f i)⟩)).toAssocList`
So `R` is an `AssocList Nat β`.

The theorem claims that `map (λ x => g x.val) L = R`.

This is a standard property of `map` on `List` and `toAssocList`. Specifically, `map f` and `toAssocList` should commute with `map` on `AssocList`. Let's see if we can find a lemma for this.

Looking at the structure of the goal, we can try to rewrite the left side to the right side.

```tactics
      simp [RelIO.liftFinf]
      <;> aesop
      <;> try { tauto }
```

The proof is remarkably simple because the theorem is essentially a direct consequence of the definitions and the properties of `map` on `List` and `toAssocList`. The `simp` tactic is able to unfold the definitions and the `aesop` tactic is able to solve the resulting equality goal.

In more detail, `simp [RelIO.liftFinf]` will expand `RelIO.liftFinf n f` to `(fin_range n).map (fun i => ⟨↑i.toNat, f i⟩)).toAssocList`. Then `map (fun x => g x.val)` is distributed over the `map` and `toAssocList` operations, resulting in `(fin_range n).map (fun i => ⟨↑i.toNat, g (f i)⟩)).toAssocList`, which is exactly `RelIO.liftFinf n (fun i => g (f i))`.

The key insight is that `map` on `List` and `toAssocList` should commute with `map` on `AssocList`. The proof is straightforward because the theorem is essentially a direct consequence of the definitions.

Now we complete the `sorry` in the `mapVal` theorem:

```tactics
