--     (E : Extractor.RoundByRound oSpec InnerStmtIn InnerWitIn InnerWitOut pSpec WitMid) :
--       Extractor.RoundByround oSpec OuterStmtIn OuterWitIn OuterWitOut pSpec WitMid :=
