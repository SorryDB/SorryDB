      have h19 : (Real.exp (-n * c' Оө2 n) вҖў 1 : HermitianMat (H (i ^ n)) в„Ӯ).toMat вүӨ ((Пғ'' ПҒ Оө m Пғ n).M).toMat := h12
      have h20 : (Real.exp (-n * c' Оө2 n) вҖў 1 : HermitianMat (H (i ^ n)) в„Ӯ).log.toMat вүӨ ((Пғ'' ПҒ Оө m Пғ n).M).log.toMat := by
        apply Real.log_le_log
        В· -- Show positivity of left side
          have h14 : (Real.exp (-n * c' Оө2 n) : в„қ) вүҘ 0 := by positivity
          have h15 : (1 : HermitianMat (H (i ^ n)) в„Ӯ).toMat вүҘ 0 := by
            simp [one_div, HermitianMat.one_toMat]
          have h16 : (Real.exp (-n * c' Оө2 n) вҖў 1 : HermitianMat (H (i ^ n)) в„Ӯ).toMat вүҘ 0 := by
