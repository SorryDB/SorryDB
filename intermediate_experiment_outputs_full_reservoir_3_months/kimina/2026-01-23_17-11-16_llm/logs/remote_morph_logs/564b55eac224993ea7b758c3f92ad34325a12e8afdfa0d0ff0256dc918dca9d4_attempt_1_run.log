open Real

noncomputable def qRelativeEnt (ПҒ : MState (H (i ^ n))) (Пғ : MState (H (i ^ n))) :
    (ПҒ : CPTPMap (H (i ^ n)) (H (i ^ n)) в„Ӯ).relativeEnt Пғ := by
  rw [qRelativeEnt]
  simp

noncomputable def sandwichedRelRentropy (ПҒ : MState (H (i ^ n))) (Пғ : MState (H (i ^ n))) :
    (ПҒ : CPTPMap (H (i ^ n)) (H (i ^ n)) в„Ӯ).sandwichedRelRentropy Пғ := by
  rw [sandwichedRelRentropy]
  simp

noncomputable def E1 (Оө2 : в„қ) (n : в„•) : HermitianMat (H (i ^ n)) в„Ӯ :=
  (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө m Пғ n) + Оө2)) вҖў
      вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)).proj_le
    вҶ‘((в„° n) (statePow ПҒ n))

noncomputable def E2 (Оө2 : в„қ) (n : в„•) : HermitianMat (H (i ^ n)) в„Ӯ :=
  (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө m Пғ n) + Оө2)) вҖў
      вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)).proj_le
    вҶ‘((в„° n) (statePow ПҒ n)) - (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + ОөвӮҖ + Оө2)) вҖў
      вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)).proj_le
    вҶ‘((в„° n) (statePow ПҒ n))

noncomputable def E3 (Оө2 : в„қ) (n : в„•) : HermitianMat (H (i ^ n)) в„Ӯ :=
  (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + ОөвӮҖ + Оө2)) вҖў
      вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)).proj_le
    вҶ‘((в„° n) (statePow ПҒ n))

noncomputable def P1 (Оө2 : в„қ) (n : в„•) : HermitianMat (H (i ^ n)) в„Ӯ :=
  (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө m Пғ n) + Оө2)) вҖў
      вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)).proj_le
    вҶ‘((в„° n) (statePow ПҒ n))

noncomputable def P2 (Оө2 : в„қ) (n : в„•) : HermitianMat (H (i ^ n)) в„Ӯ :=
  (Real.exp (вҶ‘n * (ENNReal.toReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + ОөвӮҖ + Оө2)) вҖў
      вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)).proj_le
    вҶ‘((в„° n) (statePow ПҒ n))

noncomputable def c' (Оө2 : в„қ) (n : в„•) : в„қ :=
  max (@SteinsLemma.ПғвӮҒ_cвңқ О№ instвңқ i n + @SteinsLemma.ПғвӮҒ_cвңқВ№ О№ instвңқ i n / вҶ‘n)
    (ENNReal.toReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + ОөвӮҖ + Оө2)

noncomputable def R1 (ПҒ : MState (H (i ^ n))) (Оө : Prob) : в„қ :=
  @SteinsLemma.R1вңқ О№ instвңқ i ПҒ Оө

noncomputable def R2 (ПҒ : MState (H (i ^ n))) (Пғ : MState (H (i ^ n))) : в„қ :=
  @SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ

noncomputable def Пғ'' (ПҒ : MState (H (i ^ n))) (Оө : Prob) (m : в„•) (Пғ : MState (H (i ^ n))) (n : в„•) : MState (H (i ^ n)) :=
  @SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n

noncomputable def E3 (Оө2 : в„қ) (n : в„•) : HermitianMat (H (i ^ n)) в„Ӯ :=
