      fun Оө2 n =>
        max (@SteinsLemma.ПғвӮҒ_cвңқ О№ instвңқ i n + @SteinsLemma.ПғвӮҒ_cвңқВ№ О№ instвңқ i n / вҶ‘n)
          (ENNReal.toReal (@SteinsLemma.R2вңқ О№ instвңқ i ПҒ Пғ) + @SteinsLemma.ОөвӮҖ_funcвңқ О№ instвңқ i ПҒ Оө Пғ Оө' + Оө2))
