import Mathlib

open Commute

lemma lemma_1 (A : Type u) [Commute A] (a b c d : A) : a * b = c * d → a * c = b * d := by
  intro h
  have h1 : a * b = c * d := h
  have h2 : a * c = b * d := by
    calc
      a * c = a * c := by rfl
      _ = b * d := by
        have h3 : a * b = c * d := h1
        have h4 : a * c = b * d := by
          apply (mul_left_inj' (show b ≠ 0 by
            intro hb
