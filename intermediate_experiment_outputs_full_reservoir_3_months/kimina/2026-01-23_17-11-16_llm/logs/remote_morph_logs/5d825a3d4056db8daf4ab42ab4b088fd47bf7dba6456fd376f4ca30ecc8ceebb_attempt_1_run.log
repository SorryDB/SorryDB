import Mathlib

open Mathlib

theorem Module.IsTorsion.isPseudoIsomorphic_iff_nonempty_linearEquiv_localizedModule
    {A : Type*} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M)
    {N : Type*} [AddCommGroup N] [Module A N] [Module.Finite A N] (hNT : Module.IsTorsion A N) :
    M ∼ₚᵢₛ[A] N ↔ ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
      Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
        (LocalizedModule p.1.primeCompl N)) := by
  constructor
  · -- Assume M ∼ₚᵢₛ[A] N, prove ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 → Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl] (LocalizedModule p.1.primeCompl N))
    intro h
    intro p hp
    have h1 : IsPseudoIsomorphism A M N h := by
      exact h
    have h2 := h1.isIsomorphism_of_isDomain_of_primeHeight_eq_one
      (show IsDomain (Localization p.1.primeCompl) by infer_instance)
      (show p.1.primeHeight = 1 by simpa using hp)
    refine ⟨?_, h2⟩
    exact Nonempty.intro (f := h2.symm)
  · -- Assume ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 → Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl] (LocalizedModule p.1.primeCompl N)), prove M ∼ₚᵢₛ[A] N
    intro h
    have h1 : IsPseudoIsomorphism A M N := by
      apply IsPseudoIsomorphism.mk
      let S := ⨅ p ∈ (Module.support A M ∪ Module.support A N) ∩
        {p : PrimeSpectrum A | p.1.primeHeight = 1}, p.1.primeCompl
      have hS : S = {a : A | ∀ p ∈ (Module.support A M ∪ Module.support A N) ∩
        {p : PrimeSpectrum A | p.1.primeHeight = 1}, a ∉ p.1.primeCompl} := by
        ext a
        simp [S]
      have h5 : IsDomain (A / S) := by
        apply IsDomain.of_isDomain_localization
        intro p hp
        simp only [S, Set.mem_iInter] at hp
        have hp1 : p ∈ (Module.support A M ∪ Module.support A N) ∩
          {q : PrimeSpectrum A | q.1.primeHeight = 1} := by
            simpa using hp
        have hp2 : p.1.primeHeight = 1 := by
          simpa using hp1.2
        have hp3 : p ∈ (Module.support A M ∪ Module.support A N) := hp1.1
        have hp4 : p ∈ Module.support A M ∨ p ∈ Module.support A N := by
          simpa using hp3
        have hp5 : ∀ x, x ∈ p.1.primeCompl → x ≠ 0 := by
          intro x hx
          have hx1 : x ∈ p.1.primeCompl := hx
          have hx2 : x ≠ 0 := by
            by_contra h
            rw [h] at hx1
            simp at hx1
          exact hx2
        exact IsDomain.localization_isDomain (p.1.primeCompl) (by simpa using hp2) (by simpa using hp3)
      have h6 : ∃ f : M → N, Function.IsPseudoIsomorphism f S := by
        let f : M → N := fun m => m
        use f
        simp [S, hS, h5]
        all_goals
          intro p hp
          have h7 : ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
            Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
              (LocalizedModule p.1.primeCompl N)) := h
          rcases h7 p hp with ⟨f_p, hf_p⟩
          have h8 : (f : M → N) = fun m => m := by rfl
          simp [h8] at *
          all_goals
            try { tauto }
            try { 
              have := hf_p
              tauto 
            }
      rcases h6 with ⟨f, hf⟩
      exact ⟨f, hf⟩
    exact h1
