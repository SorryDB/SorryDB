        have hp4 : p ∈ Module.support A M ∨ p ∈ Module.support A N := by
          simpa using hp3
        have hp5 : ∀ x, x ∈ p.1.primeCompl → x ≠ 0 := by
          intro x hx
          have hx1 : x ∈ p.1.primeCompl := hx
          have hx2 : x ≠ 0 := by
            by_contra h
            rw [h] at hx1
            simp at hx1
          exact hx2
        exact IsDomain.localization_isDomain (p.1.primeCompl) (by simpa using hp2) (by simpa using hp3)
      have h6 : ∃ f : M → N, Function.IsPseudoIsomorphism f S := by
        let f : M → N := fun m => m
        use f
        simp [S, hS, h5]
        all_goals
          intro p hp
          have h7 : ∀ p : PrimeSpectrum A, p.1.primeHeight = 1 →
            Nonempty ((LocalizedModule p.1.primeCompl M) ≃ₗ[Localization p.1.primeCompl]
              (LocalizedModule p.1.primeCompl N)) := h
          rcases h7 p hp with ⟨f_p, hf_p⟩
          have h8 : (f : M → N) = fun m => m := by rfl
          simp [h8] at *
          all_goals
            try { tauto }
            try { 
              have := hf_p
              tauto 
            }
      rcases h6 with ⟨f, hf⟩
      exact ⟨f, hf⟩
    exact h1
