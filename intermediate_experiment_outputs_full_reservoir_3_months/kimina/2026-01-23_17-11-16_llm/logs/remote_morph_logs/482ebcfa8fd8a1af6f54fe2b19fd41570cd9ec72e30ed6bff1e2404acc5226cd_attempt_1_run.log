/- This is a helper lemma that shows the existence of a sequence `a_n` such that `a_n` converges to `a` if `a` is an accumulation point of the set `s`.
The proof uses the `IsPreconnected` property of `ℝ` to show that if `a` is an accumulation point, then it is a limit point, and thus `a` is in the closure of `s`.
-/
lemma lemma1 (s : Set ℝ) (a : ℝ) (hs : IsAcc a s) : ∃ x : ℕ → ℝ, x → a ∧ ∀ i, x i ∈ s := by
  have h1 : IsPreconnected ℝ := by
    exact isPreconnected_univ
  have h2 : IsLimitPt a s := by
    simpa using hs
  have h3 : ∃ x : ℕ → ℝ, x → a ∧ ∀ i, x i ∈ s := by
    have h4 : IsClosed (closure s) := by
      exact isClosed_closure
    have h5 : a ∈ closure s := by
      simpa using h2
    have h6 : ∀ x ∈ closure s, ∀ y ∈ closure s, x ≤ y → x = y := by
      intro x hx y hy hxy
      have h7 : IsPreconnected closure s := by
        apply isPreconnected_of_isClosed
        exact isClosed_closure
      have h8 : x = y := by
        apply h7
        all_goals
          try { tauto }
          try { linarith }
          try { tauto }
      exact h8
    have h7 : ∃ x : ℕ → ℝ, x → a ∧ ∀ i, x i ∈ s := by
      have h8 : IsCompact closure s := by
        apply isCompact_closure
        exact isCompact_univ
      have h9 : IsPreconnected closure s := by
        apply isPreconnected_of_isClosed
        exact isClosed_closure
      have h10 : IsPreconnected closure s := by
        apply isPreconnected_of_isClosed
        exact isClosed_closure
      have h11 : ∃ x : ℕ → ℝ, x → a ∧ ∀ i, x i ∈ s := by
        have h12 : IsCompact closure s := by
          apply isCompact_closure
          exact isCompact_univ
        have h13 : IsPreconnected closure s := by
          apply isPreconnected_of_isClosed
          exact isClosed_closure
        have h14 : IsPreconnected closure s := by
          apply isPreconnected_of_isClosed
          exact isClosed_closure
        have h15 : ∃ x : ℕ → ℝ, x → a ∧ ∀ i, x i ∈ s := by
          have h16 : IsPreconnected closure s := by
            apply isPreconnected_of_isClosed
            exact isClosed_closure
          have h17 : IsPreconnected closure s := by
            apply isPreconnected_of_isClosed
            exact isClosed_closure
          have h18 : IsPreconnected closure s := by
            apply isPreconnected_of_isClosed
            exact isClosed_closure
          have h19 : ∃ x : ℕ → ℝ, x → a ∧ ∀ i, x i ∈ s := by
            apply isPreconnected_closure_iff.1
            exact h2
          exact h19
        exact h15
      exact h11
    exact h7
  exact h3

