Let's complete the proof:

```tactics
have dy : ∀ j ∈ range n, ∀ ℓ ∈ range k,
  |f (a + (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k)) -  f (a + (↑j + 1) * (b - a) / ↑n)| < ε := by
  intro j hj ℓ hℓ
  have hx1 : a + (↑j + 1) * (b - a) / ↑n ∈ Icc a b := by
    constructor
    · -- Show a ≤ a + (j + 1) * (b - a) / n
      have h1 : (↑j + 1) * (b - a) / ↑n ≥ 0 := by
        apply div_nonneg
        · -- Show (j + 1) * (b - a) ≥ 0
          nlinarith [show 0 ≤ (j : ℝ) by exact_mod_cast (show j ≥ 0 by omega), hab]
        · -- Show n ≥ 0
          positivity
      linarith
    · -- Show a + (j + 1) * (b - a) / n ≤ b
      have h2 : (↑j + 1) * (b - a) / ↑n ≤ b - a := by
        have h3 : (↑j + 1) ≤ (n : ℝ) := by
          have h4 : j ≤ n - 1 := by
            simp at *
            omega
          have h5 : (j : ℝ) ≤ (n - 1 : ℝ) := by exact_mod_cast h4
          nlinarith
        have h6 : (↑j + 1) * (b - a) ≤ n * (b - a) := by
          nlinarith [h3, hab]
        have h7 : (↑j + 1) * (b - a) / ↑n ≤ (n * (b - a)) / ↑n := by
          apply (div_le_div_right (by positivity)).mpr
          nlinarith
        have h8 : (n * (b - a)) / ↑n = b - a := by
          field_simp
          <;> nlinarith
        linarith [h7, h8]
      linarith
```

This proves that the original point `a + (j + 1) * (b - a) / n` is in the interval `[a, b]`.

Now, we need to prove the same for the refined point:

```tactics
have hx2 : a + (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k) ∈ Icc a b := by
  constructor
  · -- Show a ≤ a + (ℓ + j * k + 1) * (b - a) / (n * k)
    have h1 : (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k) ≥ 0 := by
      apply div_nonneg
      · -- Show (ℓ + j * k + 1) * (b - a) ≥ 0
        nlinarith [show 0 ≤ (ℓ : ℝ) by exact_mod_cast (show ℓ ≥ 0 by omega), show 0 ≤ (j : ℝ) by exact_mod_cast (show j ≥ 0 by omega), hab]
      · -- Show n * k ≥ 0
        positivity
    linarith
  · -- Show a + (ℓ + j * k + 1) * (b - a) / (n * k) ≤ b
    have h2 : (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k) ≤ b - a := by
      have h3 : (↑ℓ + ↑j * ↑k + 1) ≤ (↑n * ↑k : ℝ) := by
        have h4 : ℓ ≤ k - 1 := by
          simp at *
          omega
        have h5 : j ≤ n - 1 := by
          simp at *
          omega
        have h6 : (ℓ : ℝ) ≤ (k - 1 : ℝ) := by exact_mod_cast h4
        have h7 : (j : ℝ) ≤ (n - 1 : ℝ) := by exact_mod_cast h5
        nlinarith
      have h8 : (↑ℓ + ↑j * ↑k + 1) * (b - a) ≤ (↑n * ↑k) * (b - a) := by
        nlinarith [h3, hab]
      have h9 : (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k) ≤ ((↑n * ↑k) * (b - a)) / (↑n * ↑k) := by
        apply (div_le_div_right (by positivity)).mpr
        nlinarith
      have h10 : ((↑n * ↑k) * (b - a)) / (↑n * ↑k) = b - a := by
        field_simp
        <;> nlinarith
      linarith [h9, h10]
    linarith
```

This proves that the refined point is also in the interval `[a, b]`.

Now, we can apply the uniform continuity:

