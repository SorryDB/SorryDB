              have h14 : (b - a) / ↑n * |∑ k_1 ∈ Finset.range k, (f (a + (↑(j + k_1 * n) + 1) * (b - a) / ↑(n * k)) - f (a + (↑j + 1) * (b - a) / ↑n))| ≤ (b - a) / ↑n * (k * ε) := by
