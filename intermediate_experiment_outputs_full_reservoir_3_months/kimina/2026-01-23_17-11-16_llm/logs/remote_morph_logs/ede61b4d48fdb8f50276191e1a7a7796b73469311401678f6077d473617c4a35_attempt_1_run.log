have h3 : |(b - a) / (↑n * ↑k) * ∑ j ∈ range n, ∑ ℓ ∈ range k, (f (a + (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k)) - f (a + (↑j + 1) * (b - a) / ↑n))| ≤ (b - a) * ε := by
  have h4 : |(b - a) / (↑n * ↑k) * ∑ j ∈ range n, ∑ ℓ ∈ range k, (f (a + (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k)) - f (a + (↑j + 1) * (b - a) / ↑n))| ≤ (b - a) * ε := by
```

We need to bound the sum. Let's apply the triangle inequality:

```tactics
have h5 : |(b - a) / (↑n * ↑k) * ∑ j ∈ range n, ∑ ℓ ∈ range k, (f (a + (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k)) - f (a + (↑j + 1) * (b - a) / ↑n))| ≤ (b - a) / (↑n * ↑k) * ∑ j ∈ range n, ∑ ℓ ∈ range k, |f (a + (↑ℓ + ↑j * ↑k + 1) * (b - a) / (↑n * ↑k)) - f (a + (↑j + 1) * (b - a) / ↑n)| := by
