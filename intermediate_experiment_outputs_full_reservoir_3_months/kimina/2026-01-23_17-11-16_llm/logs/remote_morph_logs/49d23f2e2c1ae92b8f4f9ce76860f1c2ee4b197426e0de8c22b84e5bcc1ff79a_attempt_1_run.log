    let ocLookup := state.orderConstraints.lookup (state.scopes.jointScope tId tId)
    let paired := threadReads.filter
      λ r => threadReads.all
       λ r' => r.id == r'.id || ocLookup r'.id r.id
    paired.head?
    else none
  --dbg_trace s!"accepting {req}, requests.val : {state.requests.val}"
  let requests' :=
