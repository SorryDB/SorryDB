import Mathlib

abbrev SystemState := ...
abbrev ProgramState := ...

def SystemState.isSatisfied (state : SystemState) (req : Request) : Bool := ...
def SystemState.satisfied (state : SystemState) : List (RequestId × BasicRequest) := ...
def SystemState.requests (state : SystemState) : RequestArray := ...
def SystemState.removed (state : SystemState) : List (RequestId × BasicRequest) := ...
def SystemState.orderConstraints (state : SystemState) : @OrderConstraints state.scopes := ...
def SystemState.scopes (state : SystemState) : Arch.Scopes := ...
def SystemState.threadTypes (state : SystemState) : List (ThreadId × Arch.ThreadType) := ...

def SystemState.applyAcceptRequest : SystemState → BasicRequest → ThreadId → SystemState × RequestId
  | state, reqType, tId => 
    let prelimReq : Request :=
      {propagated_to := [tId], thread := tId, predecessor_at := [], pairedRequest? := none,
       basic_type := reqType, id := state.freshId, occurrence := 0} 
    let previous : List Request := state.requests.filter (fun r => r.id == prelimReq.id)
    let removed : List (RequestId × BasicRequest) := state.removed.filter (fun r => r.1 == prelimReq.id)
    let occurrences : List Nat := previous.map (fun r => r.occurrence) ++ removed.map (fun r => r.2.occurrence)
    let req : Request := {prelimReq with occurrence := (occurrences.maximum + 1)}
    let pairedRequest? : Option (RequestId × BasicRequest) := if reqType.isWrite ∧ (reqType.isTransactional ∨ reqType.isAtomic) then
      let threadReads := state.requests.filter (fun r => r.thread == tId ∧ r.isRead ∧ r.address? == req.address? ∧ (r.isAtomic ∨ r.isTransactional))
      let ocLookup := state.orderConstraints.lookup (state.scopes.jointScope tId tId)
      let paired := threadReads.filter (fun r => threadReads.all (fun r' => r'.id == r.id ∨ ocLookup r'.id r.id))
      paired.head?
    let requests' := state.requests.insert req |>.insert (if pairedRequest? isSome then { pairedRequest? with basic_type := reqType, occurrence := 0 } else none)
    let orderConstraints' := state.updateOrderConstraintsAccept req
    let st := { 
      requests := requests', 
      scopes := state.scopes, 
      threadTypes := state.threadTypes, 
      orderConstraints := orderConstraints', 
      removed := sorry, 
      satisfied := sorry 
    }
