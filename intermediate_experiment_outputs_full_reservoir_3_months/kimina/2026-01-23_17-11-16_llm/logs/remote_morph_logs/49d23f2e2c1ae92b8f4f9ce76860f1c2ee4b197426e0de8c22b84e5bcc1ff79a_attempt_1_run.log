import Mathlib
import Arch

abbrev SystemState := Arch.SystemState

abbrev BasicRequest := Arch.BasicRequest

abbrev Request := Arch.Request

abbrev Coherent := Arch.Coherent

abbrev ThreadId := Arch.ThreadId

abbrev Arch := Arch

abbrev RequestId := Arch.RequestId

def Arch.acceptConstraints (state : Arch.SystemState) (br : Arch.BasicRequest) (tId : Arch.ThreadId) : Arch.Request → Prop
  | state, br, tId, r => r.isSatisfied

def Arch.orderCondition (scopes : Arch.Scopes) (r : Arch.Request) (r' : Arch.Request) : Prop
  | scopes, r, r' => r' < r

def Arch.orderConstraints (state : Arch.SystemState) : Arch.OrderConstraints :=
  state.orderConstraints

def Arch.isSatisfied (state : Arch.SystemState) (r : Arch.Request) : Prop :=
  state.isSatisfied r

def Arch.isPredecessorAt (state : Arch.SystemState) (r : Arch.Request) (t : Arch.ThreadId) : Prop :=
  state.isPredecessorAt r t

def Arch.isAtomic (r : Arch.Request) : Prop := r.isAtomic

