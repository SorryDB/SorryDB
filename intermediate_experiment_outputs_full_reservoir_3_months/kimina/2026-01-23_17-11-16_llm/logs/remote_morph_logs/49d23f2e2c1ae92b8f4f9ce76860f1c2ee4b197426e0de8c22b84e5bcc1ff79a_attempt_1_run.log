  have h10 : q = r := by
    have h11 : q ∈ requests' := hq
    have h12 : q.id = r.id := by
      rw [h9, h2]
    have h13 : q = r := by
      apply Eq.symm
      apply Eq.of_subst
      exact h12
    exact h13
  rw [h10] at hq
  contradiction
