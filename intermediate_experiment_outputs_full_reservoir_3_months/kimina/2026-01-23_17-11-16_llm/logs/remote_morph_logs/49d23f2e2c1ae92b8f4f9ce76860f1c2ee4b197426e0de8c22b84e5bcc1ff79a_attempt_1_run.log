import Mathlib

abbrev SystemState := ...
abbrev ProgramState := ...

def SystemState.isSatisfied (state : SystemState) (req : Request) : Bool := ...
def SystemState.satisfied (state : SystemState) : List (RequestId × BasicRequest) := ...
def SystemState.requests (state : SystemState) : RequestArray := ...
def SystemState.removed (state : SystemState) : List (RequestId × BasicRequest) := ...
def SystemState.orderConstraints (state : SystemState) : @OrderConstraints state.scopes := ...
def SystemState.scopes (state : SystemState) : Arch.Scopes := ...
def SystemState.threadTypes (state : SystemState) : List (ThreadId × Arch.ThreadType) := ...

