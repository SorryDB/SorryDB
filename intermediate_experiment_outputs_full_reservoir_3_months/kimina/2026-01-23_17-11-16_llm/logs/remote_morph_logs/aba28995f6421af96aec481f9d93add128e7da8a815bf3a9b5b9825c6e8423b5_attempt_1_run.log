namespace NumberField.AdeleRing.DivisionAlgebra

set_option quotPrecheck false in
/-- `D_ً‌”¸` is notation for `D âٹ—[K] ً‌”¸_K`. -/
notation "D_ً‌”¸" => (D âٹ—[K] AdeleRing (ً‌“‍ K) K)

open scoped TensorProduct.RightActions

/-- The inclusion Dث£ â†’ D_ً‌”¸ث£ as a group homomorphism. -/
noncomputable abbrev incl : Dث£ â†’* D_ً‌”¸ث£ :=
  Units.map Algebra.TensorProduct.includeLeftRingHom.toMonoidHom

namespace Aux

/-- The inclusion of K^n into ً‌”¸^n. -/
abbrev incl_Kn_ً‌”¸Kn : (Fin (Module.finrank K D) â†’ K) â†’
    (Fin (Module.finrank K D) â†’ AdeleRing (ً‌“‍ K) K) :=
  fun x i â†¦ algebraMap K (AdeleRing (ً‌“‍ K) K) (x i)

theorem Kn_discrete : âˆ€ x : (Fin (Module.finrank K D) â†’ K),
    âˆƒ U : Set (Fin (Module.finrank K D) â†’ AdeleRing (ً‌“‍ K) K),
    IsOpen U âˆ§ (incl_Kn_ً‌”¸Kn K D)âپ»آ¹' U = {x} := by
  exact (DiscretePi (algebraMap K (AdeleRing (ً‌“‍ K) K)) (Module.finrank K D))
    (NumberField.AdeleRing.discrete K)

variable [FiniteDimensional K D]

/-- The K-algebra equivalence of D and K^n. -/
