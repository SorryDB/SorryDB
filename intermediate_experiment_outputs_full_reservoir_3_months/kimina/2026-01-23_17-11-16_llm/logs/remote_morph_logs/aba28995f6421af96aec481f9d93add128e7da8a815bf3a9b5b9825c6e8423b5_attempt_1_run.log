    simpa [â†گ Algebra.algebraMap_eq_smul_one] using hx
  آ· intro âں¨y, hy1, hy2âں©
    have : (Dً‌”¸_iso_top K D) âˆک (Algebra.TensorProduct.includeLeft : D â†’â‚گ[K] D_ً‌”¸) =
        (incl_Kn_ً‌”¸Kn K D) âˆک (D_iso K D) := by
      ext d n
