theorem D_discrete : âˆ€ x : D, âˆƒ U : Set D_ً‌”¸,
    IsOpen U âˆ§ (Algebra.TensorProduct.includeLeft : D â†’â‚گ[K] D_ً‌”¸) âپ»آ¹' U = {x} := by
  apply Discrete_of_HomeoDiscrete (Y' := ((Fin (Module.finrank K D) â†’ AdeleRing (ً‌“‍ K) K)))
    (Algebra.TensorProduct.includeLeft : D â†’â‚گ[K] D_ً‌”¸) (Dً‌”¸_iso_top K D)
  apply Discrete_of_HomDiscrete (X' := Fin (Module.finrank K D) â†’ K)
    ((Dً‌”¸_iso_top K D) âˆک (Algebra.TensorProduct.includeLeft : D â†’â‚گ[K] D_ً‌”¸)) (D_iso K D)
  simpa [D_discrete_extracted] using Kn_discrete K D

