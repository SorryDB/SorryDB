  exact HasFDerivAt.comp h2 z1

theorem f_pose_eq_inner' {pbar : Pose} {S : ℝ³} {w : ℝ²} :
    deriv (fun x : ℝ³ ↦ inner (rotprojRM (x 1) (x 2) (x 0)) S) x = S := by
