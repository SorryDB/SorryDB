lemma Differentiable.fu (pbar : Pose) {ε : ℝ} {poly : GoodPoly}
    (pc : GlobalTheoremPrecondition poly pbar ε) : Differentiable ℝ (pc.fu) := by
  apply Differentiable.comp
  · apply Differentiable.div
    · apply Differentiable.inner ℝ
      apply Differentiable.rotprojRM
    · apply Differentiable.const
  · apply Differentiable.rotprojRM

lemma Differentiable.fu_outer (pbar : Pose) {ε : ℝ} {poly : GoodPoly} (P : ℝ³)
