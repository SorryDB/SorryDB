import Mathlib

open Set

namespace RealAnalysisGame

/--
The Intermediate Value Theorem (IVT) states that if a function is continuous on a closed interval `[a, b]` and takes values `f(a) < 0` and `0 < f(b)`, then there exists some `c ∈ (a, b)` so that `f(c)=0`.
-/
theorem IVT {f : ℝ → ℝ} (hf : FunCont f) {a b : ℝ} (hab : a < b)
    (hfa : f a < 0) (hfb : 0 < f b): ∃ c ∈ Ioo a b, f c = 0 := by
  let S := { x ∈ Icc a b | f x < 0 }
  have a_in_S : a ∈ S := by
    split_ands
    · -- Show that a ∈ Icc a b
      exact ⟨by linarith, by linarith⟩
    · -- Show that f a < 0
      exact hfa
  have Snonempty : S.Nonempty := by
    use a
    all_goals
      tauto
  have Sbounded : IsUB S b := by
    intro x hx
    apply hx.1.2
  choose c hc using HasLUB_of_BddNonempty Snonempty Sbounded
  have a_le_c : a ≤ c := by
    apply hc.1 a a_in_S
  have c_le_b : c ≤ b := by
    apply hc.2
    intro s hs
    apply hs.1.2
  have fc_lt : ¬ f c < 0 := by
    intro h
    specialize hf c (-f c / 2) (by bound)
    choose δ hδpos hδ using hf
    have cpd : c + δ / 2 ≤ b := by
      by_contra hb
      push_neg at hb
      have hbc : |b - c| < δ := by
        rw [abs_lt]
        split_ands
        linarith [c_le_b, hδpos]
        linarith [hb, hδpos]
      specialize hδ b hbc
      rw [abs_lt] at hδ
      linarith [hδ, h, hfb]
    specialize hδ (c + δ / 2) (by ring_nf; rewrite [abs_of_nonneg (by bound)]; linarith [hδpos])
    rw [abs_lt] at hδ
    have hfc1 : f (c + δ / 2) < 0 := by
      linarith [hδ]
    have hc_in_S : c + δ / 2 ∈ S := by
      split_ands
      · -- Show that c + δ / 2 ∈ Icc a b
        constructor
        · -- Show that a ≤ c + δ / 2
          linarith
        · -- Show that c + δ / 2 ≤ b
          linarith
      · -- Show that f (c + δ / 2) < 0
        exact hfc1
    have hc_ineq := hc.1 (c + δ / 2) hc_in_S
    linarith [hc_ineq, hδpos]
  have fc_gt : ¬ 0 < f c := by
    intro h
    specialize hf c (f c / 2) (by bound)
    choose δ hδpos hδ using hf
    have cpd : a ≤ c - δ / 2 := by
      by_contra ha
      push_neg at ha
      have hac : |a - c| < δ := by
        rw [abs_lt]
        split_ands
        bound
        bound
      specialize hδ a hac
      rw [abs_lt] at hδ
      linarith [hδ, hfa, h]
    have cUB : IsUB S (c - δ / 2) := by
      intro s hs
      by_contra hsc
      push_neg at hsc
      have s_le : s ≤ c := by
        apply hc.1 s hs
      have hcs : |s - c| < δ := by
        rw [abs_lt]
        split_ands
        bound
        bound
      specialize hδ s hcs
      have hfs : f s < 0 := by
        apply hs.2
      rw [abs_lt] at hδ
      linarith [hδ, hfs, h]
    linarith [hc.2 (c - δ / 2) cUB, hδpos]
  have fc : f c = 0 := by
    linarith
  have hc' : c ∈ Ioo a b := by
    constructor
    · -- Show that a < c
      by_contra h
      push_neg at h
      have h_eq : a = c := by linarith
      contradiction
    · -- Show that c < b
      by_contra h
      push_neg at h
      have h_eq : b = c := by linarith
      contradiction
  exact ⟨c, hc', fc⟩
