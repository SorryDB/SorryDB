import Mathlib

open Set

/--
The Intermediate Value Theorem (IVT) states that if a function is continuous on a closed interval `[a, b]` and takes values `f(a) < 0` and `0 < f(b)`, then there exists some `c ∈ (a, b)` such that `f(c)=0`.
-/
theorem RealAnalysisGame.IVT {f : ℝ → ℝ} (hf : fun x => ContinuousAt f x) {a b : ℝ} (hab : a < b)
    (hfa : f a < 0) (hfb : 0 < f b): ∃ c ∈ Ioo a b, f c = 0 := by
  let S := { x ∈ Icc a b | f x < 0 }
  have a_in_S : a ∈ S := by
    split_ands
    · -- Show that a ∈ Icc a b
      exact ⟨by linarith, by linarith⟩
    · -- Show that f a < 0
      simpa using hfa
  have Snonempty : S.Nonempty := by
    use a
    all_goals tauto
  have Sbounded : IsUB S b := by
    intro x hx
    apply hx.1.2
  have h1 : ∃ c, IsLUB S c := by
    apply hasLUB_of_nonempty_bounded
    · exact Snonempty
    · exact Sbounded
  rcases h1 with ⟨c, hc⟩
  have a_le_c : a ≤ c := by
    have h2 : a ∈ S := a_in_S
    have h3 : a ≤ c := hc.1 h2
    linarith
  have c_le_b : c ≤ b := by
    have h4 : c ∈ upperBounds S := hc.2
    have h5 : b ∈ upperBounds S := by
      intro s hs
      have h6 : s ∈ Icc a b := hs.1
      have h7 : s ≤ b := h6.2
      linarith
    have h8 : c ≤ b := h4 b h5
    linarith
  have fc_lt : ¬ f c < 0 := by
    by_contra h
    have h2 : c ∈ S := by
      constructor
      · -- Show c ∈ Icc a b
        constructor
        · linarith
        · linarith
      · -- Show f c < 0
        linarith
    have h4 : c ∈ upperBounds S := hc.2
    have h5 : ContinuousAt f c := hf c
    have h6 : ∀ ε > 0, ∃ δ > 0, ∀ x, |x - c| < δ → |f x - f c| < ε := by
      apply h5
    have h7 := h6 (|f c|) (by linarith [abs_nonneg (f c)])
    rcases h7 with ⟨δ, hδ, h8⟩
    have h9 : a ≤ c := by linarith
    have h10 : c ≤ b := by linarith
    have h11 : a ≤ c + δ / 2 := by
      linarith
    have h12 : c + δ / 2 ≤ b := by
      by_contra h
      push_neg at h
      have h13 : |b - c| < δ := by
        rw [abs_lt]
        constructor
        · -- Show - (c + δ / 2) < b - c
          nlinarith
        · -- Show b - c < δ
          nlinarith
      have h14 : b ∉ S := by
        simp [S]
        all_goals
        -- Show that b ∈ Icc a b
        constructor <;> linarith
        -- Show that f b < 0
        linarith [hfb]
      have h15 : c + δ / 2 ∈ S := by
        constructor
        · -- Show c + δ / 2 ∈ Icc a b
          constructor
          · -- Show a ≤ c + δ / 2
            linarith
          · -- Show c + δ / 2 ≤ b
            nlinarith
        · -- Show f (c + δ / 2) < 0
          have h16 : |f (c + δ / 2) - f c| < |f c| := by
            apply h8 (c + δ / 2)
            rw [abs_lt]
            all_goals
            nlinarith
          have h17 : f (c + δ / 2) < 0 := by
            linarith [abs_lt.mp h16, h]
          linarith
      have h18 : c ≤ c + δ / 2 := h4 h15
      nlinarith
    have h13 : c + δ / 2 ∈ S := by
      constructor
      · -- Show c + δ / 2 ∈ Icc a b
        constructor
        · -- Show a ≤ c + δ / 2
          linarith
        · -- Show c + δ / 2 ≤ b
          nlinarith
      · -- Show f (c + δ / 2) < 0
        have h16 : |f (c + δ / 2) - f c| < |f c| := by
          apply h8 (c + δ / 2)
          rw [abs_lt]
          all_goals
          nlinarith
        have h17 : f (c + δ / 2) < 0 := by
          linarith [abs_lt.mp h16, h]
        linarith
    have h14 : c ≤ c + δ / 2 := h4 h13
    nlinarith
  have fc_gt : ¬ 0 < f c := by
    by_contra h
    have h2 : f c < 0 := by
      linarith [h]
    linarith
  have fc : f c = 0 := by
    linarith
  have h1 : c ∈ Ioo a b := by
    constructor
    · -- Show a < c
      by_contra h
      push_neg at h
      have h2 : a ∈ S := a_in_S
      have h3 : c ≤ a := hc.1 h2
      nlinarith
    · -- Show c < b
      by_contra h
      push_neg at h
      have h4 : c ∈ upperBounds S := hc.2
      have h5 : b ∈ upperBounds S := by
        intro s hs
        have h6 : s ∈ Icc a b := hs.1
        have h7 : s ≤ b := h6.2
        linarith
      have h6 : c ≤ b := h4 b h5
      have h7 : c = b := by linarith
      rw [show c = b by linarith] at fc
      linarith [hfb, fc]
  exact ⟨c, h1, fc⟩
```

