have fc : f c = 0 := by bound
have hc' : c ∈ Icc a b := by
  split_ands
  bound
  bound
have hca : a ≠ c := by
  intro c_eq_a
  rw [← c_eq_a] at fc
  linarith [hfa, fc]
have hcb : b ≠ c := by
  intro c_eq_b
  rw [← c_eq_b] at fc
  linarith [fc, hfb]
have ha1 : a < c := by
  by_contra h
  push_neg at h
  have h2 : a = c := by
    linarith [a_le_c, h]
  rw [show c = a by linarith [h2]] at fc
