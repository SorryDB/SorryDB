import Mathlib

open Filter Set

noncomputable def eLorentzNorm (f : α → ℝ≥0) (p : ℝ≥0∞) (r : ℕ) (μ : Measure α) :=
  if p = ∞ then
    sSup (fun x ∈ support μ => f x * (μ {x})⁻¹) ∞ else
    (μ {x | f x > 0}).toReal⁻¹ * (∫ x : α, (f x) ^ p.toReal⁻¹ * (μ {x})⁻¹ ^ (p.toReal - 1) over μ).toReal

