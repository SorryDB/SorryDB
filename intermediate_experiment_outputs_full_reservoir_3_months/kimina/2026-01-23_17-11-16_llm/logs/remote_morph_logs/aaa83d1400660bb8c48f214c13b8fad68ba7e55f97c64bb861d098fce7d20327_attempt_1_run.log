have hg' : @MeasureTheory.MemLorentz α (NNReal) m0 instENormedSpaceNNReal.toENorm NNReal.instTopologicalSpace (RCLike.ofReal ∘ NNReal.toReal ∘ g) p 1 μ := by
  apply @MeasureTheory.memLorentz_of_ae_stronglyMeasurable
  · -- Show that g is locally integrable
    apply aemeasurable_g.locallyIntegrable
