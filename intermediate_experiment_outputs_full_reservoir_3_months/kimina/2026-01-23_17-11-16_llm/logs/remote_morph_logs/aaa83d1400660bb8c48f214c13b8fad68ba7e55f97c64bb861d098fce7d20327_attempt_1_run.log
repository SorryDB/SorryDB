    have T'_submul : ∀ (a : 𝕂) (f : α → 𝕂) (x : α'), ‖T' (a • f) x‖ₑ ≤ ‖a‖ₑ • ‖T' f x‖ₑ := by
      intro a f x
      simp only [Function.comp_apply]
