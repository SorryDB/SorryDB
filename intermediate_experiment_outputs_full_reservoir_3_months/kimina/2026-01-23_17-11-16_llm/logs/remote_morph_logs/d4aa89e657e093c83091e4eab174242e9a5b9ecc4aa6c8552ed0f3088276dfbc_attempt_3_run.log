    | do
      (simulateQ (rbrSoundness_queryImpl)
        (do
          let ⟨⟨transcript, _⟩, proveQueryLog⟩ ← prover.runWithLogToRound i.1.castSucc stmtIn witIn
          let challenge ← (pSpec.getChallenge i)
          return (transcript, challenge, proveQueryLog))).run' (← init)] ≤
      rbrKnowledgeError i
