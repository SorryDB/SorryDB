  {WitIn : Type}
  {WitOut : Type}

variable
  {prover : Prover oSpec Statement WitIn Statement WitOut pSpec}

namespace Verifier

@[reducible, simp]
def StateFunction
    (langIn : Set (Statement × WitIn))
    (langOut : Set (Statement × WitOut))
    (verifier : Verifier oSpec Statement WitIn Statement WitOut pSpec) :=
  verifier.toVerifier.StateFunction init impl langIn langOut

@[reducible, simp]
def KnowledgeStateFunction
    (relIn : Set ((Statement × WitIn) × WitIn))
    (relOut : Set ((Statement × WitOut) × WitOut))
    (verifier : Verifier oSpec Statement WitIn Statement WitOut pSpec)
