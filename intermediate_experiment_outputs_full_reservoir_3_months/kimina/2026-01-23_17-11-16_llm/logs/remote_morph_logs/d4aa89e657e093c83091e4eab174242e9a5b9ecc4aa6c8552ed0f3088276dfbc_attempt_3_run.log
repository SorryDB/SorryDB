import Mathlib
import Mathlib.Tactic.Simpa

variable
  {oSpec : OracleSpec ι}
  {init : ProbComp σ}
  {impl : QueryImpl oSpec (StateT σ ProbComp)}
  {Statement : Type}
  {Witness : Type}
  {pSpec : ProverSpec}
  {p : pSpec}

namespace Verifier

@[reducible, simp]
def StateFunction
    (langIn : Set Statement)
    (verifier : Verifier oSpec Statement Bool pSpec)
    := verifier.toVerifier.StateFunction init impl langIn acceptRejectRel.language

@[reducible, simp]
def KnowledgeStateFunction
    (relation : Set (Statement × Witness))
    (verifier : Verifier oSpec Statement Witness Bool pSpec)
    := verifier.toVerifier.KnowledgeStateFunction init impl relation acceptRejectRel

/-- Round-by-round soundness of an oracle reduction is the same as for non-oracle reductions. -/
def rbrSoundness
    (langIn : Set Statement)
    (verifier : Verifier oSpec Statement Bool pSpec)
    (rbrSoundnessError : pSpec.ChallengeIdx → ℝ≥0) : Prop :=
  verifier.toVerifier.rbrSoundness init impl langIn acceptRejectRel.language rbrSoundnessError

/-- Round-by-round knowledge soundness of an oracle reduction is the same as for non-oracle
reductions. -/
def rbrKnowledgeSoundness
    (relation : Set (Statement × Witness))
    (verifier : Verifier oSpec Statement Witness Bool pSpec)
    (rbrKnowledgeError : pSpec.ChallengeIdx → ℝ≥0) : Prop :=
  verifier.toVerifier.rbrKnowledgeSoundness init impl relation acceptRejectRel rbrKnowledgeError

end Verifier

