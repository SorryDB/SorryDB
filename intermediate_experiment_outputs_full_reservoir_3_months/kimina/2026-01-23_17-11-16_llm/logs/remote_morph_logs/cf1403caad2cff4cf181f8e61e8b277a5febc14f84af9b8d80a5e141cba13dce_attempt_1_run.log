@[reducible]
def typ (a r : Type) : ‚Ąē -> Type
  | 0   => r
  | n+1 => a -> typ a r n

@[reducible]
def curry {a r : Type} (n : ‚Ąē) (k : Vector a n -> r) : typ a r n :=
  match n with
  | 0 => k ‚ü®#[], by rfl‚ü©
  | n+1 => fun (x : a) => curry n (fun l => k (Vector.push l x))

