import Mathlib.Data.ZMod.Basic

import Clap.Circuit
import Clap.Simulation

namespace Clap

namespace Spec

--variable (F var:Type) [Field F] [DecidableEq F]
variable {p : ‚Ąē} [Fact (Nat.Prime p)] [NeZero p]

def eq0 (e : ZMod p) : Option Unit :=
  if e = 0 then some () else none

def share (e : ZMod p) : ZMod p := e

def is_zero (e : ZMod p) : ZMod p := if e = 0 then 1 else 0

def assert_range (w : ‚Ąē) (e : ZMod p) : Option Unit := if e.val < 2^w then some () else none

--def assert_range (w:‚Ąē) (e:ZMod p) : Option { x:ZMod p // (x.val < 2^w) } := if h:e.val < 2^w then some ‚ü®e, h‚ü© else none

-- def assert_range (w:‚Ąē) (e:ZMod p) : Option (ZMod p') := if e.val < 2^w then some e else none

def accept : Unit -> Unit := fun () => ()

