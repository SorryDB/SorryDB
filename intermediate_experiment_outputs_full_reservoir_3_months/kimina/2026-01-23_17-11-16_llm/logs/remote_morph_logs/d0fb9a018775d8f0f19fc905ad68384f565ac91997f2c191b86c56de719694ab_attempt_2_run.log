    have h4 : x ⊢ ψ := by
      apply Satisfies.satisfies_trans x z Rxz
      exact hz₁
    have h5 : x ⊢ ¬ψ := by
      apply Satisfies.not_def_trans x y Rxy
      exact hy₂
    contradiction
  · -- Case where y = z
    rw [show z = y by exact rfl] at hz₁ hz₂
    have h5 : x ⊢ ¬ψ := by
      apply Satisfies.not_def_trans x y Rxy
      exact hy₂
    have h6 : x ⊢ ψ := by
      apply Satisfies.satisfies_trans x y Rxy
      exact hz₁
    contradiction
  · -- Case where z ≺ y
    have h3 : x ⊢ φ := by
      apply Satisfies.satisfies_trans x y Rxy
      exact hy₁
    have h4 : x ⊢ ¬ψ := by
      apply Satisfies.not_def_trans x y Rxy
      exact hy₂
    have h5 : x ⊢ ψ := by
      apply Satisfies.satisfies_trans x z (Rzy.symm)
      exact hz₁
    have h6 : x ⊢ ¬φ := by
      apply Satisfies.not_def_trans x z (Rzy.symm)
      exact hz₂
    contradiction
