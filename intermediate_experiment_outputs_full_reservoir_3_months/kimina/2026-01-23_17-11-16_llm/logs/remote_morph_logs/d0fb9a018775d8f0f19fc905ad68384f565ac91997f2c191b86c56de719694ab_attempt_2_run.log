@[simp high, grind .]
lemma valid_axiomSym_of_isSymmetric [F.IsPiecewiseConnected] : F ⊧ Axioms.PCon₁ φ ψ := by
  intro V x;
  by_contra hC;
  rcases Satisfies.not_def_or.mp hC with ⟨h₁, h₂⟩; clear hC;
  obtain ⟨y, Rxy, hy₁, hy₂⟩ := Satisfies.not_def_imp.mp h₁; clear h₁;
  obtain ⟨z, Rxz, hz₁, hz₂⟩ := Satisfies.not_def_imp.mp h₂; clear h₂;
  rcases F.p_connected Rxy Rxz with Ryz | rfl | Rzy;
  . 
    exfalso;
    have h1 : y ⊧ φ := hy₁;
    have h2 : y ⊭ ψ := hy₂;
    have h3 : z ⊧ ψ := hz₁;
    have h4 : z ⊭ φ := hz₂;
    have h5 : x ≺ y := Rxy;
    have h6 : x ≺ z := by
      have h7 : y ≺ z := Ryz;
      have h8 : x ≺ y := Rxy;
      -- Apply Euclidean property: if x ≺ y and y ≺ z, then x ≺ z
      apply F.eucledian; all_goals try tauto
    have h7 : y ⊧ φ ↔ z ⊧ φ := by
      -- Apply convergent property: if x ≺ y and x ≺ z, then y ≺ z ∨ y = z ∨ z ≺ y
      apply F.convergent; all_goals try tauto
    have h8 : y ⊧ φ := hy₁;
    have h11 : z ⊧ φ := by
      tauto
    contradiction
