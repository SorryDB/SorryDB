import Mathlib

open Filter Real Complex Topology

namespace SteinsLemma

noncomputable def R1 (ρ : MState (H i)) (ε : Prob) (i : ι) := 
  (1 / 2) * (log (1 - ε) + log (2 * (ρ.m / (1 - ε)))) 

noncomputable def R2 (ρ : MState (H i)) (σ : (n : ℕ) → ↑IsFree) (i : ι) := 
  log (1 / (ρ.m)) + log (2 * (↑(σ 0).m / ρ.m)) + ∑' k : ℕ, log (1 / (1 - (↑(σ (k + 1)).m / ↑(σ k).m))) 

noncomputable def optimalHypothesisRate (n : ℕ) (ρ : MState (H i)) (ε : Prob) (S : (n : ℕ) → ↑IsFree) (σ : (n : ℕ) → ↑IsFree) := 
  log (det (S n) / det (σ n)) + log (det (S (n - 1)) / det (σ (n - 1))) + ... 

noncomputable def negLog (A : CPTPMap (H i) (H i) ℂ) (M : MState (H i)) := -log (det (A M))

noncomputable def pinching_map (M : MState (H i)) : CPTPMap (H i) (H i) ℂ := 
  fun x ↦ (M.cfc x) • x 

noncomputable def pinching_self (M : MState (H i)) : CPTPMap (H i) (H i) ℂ := 
  fun x ↦ (M.cfc x) • x 

noncomputable def pinching_commutes (ρ : MState (H i)) (σ : MState (H i)) : Commute (pinching_map ρ) (pinching_map σ) := by
  simp only [CPTPMap.comp, CPTPMap.mul, CPTPMap.id, CPTPMap.log, CPTPMap.log, CPTPMap.log]
  apply Commute.mul
  · apply Commute.cptp
    apply Commute.refl
  · apply Commute.cptp
    apply Commute.refl

noncomputable def qRel (S : (n : ℕ) → ↑IsFree) (σ : (n : ℕ) → ↑IsFree) (n : ℕ) := 
  log (det (S n) / det (σ n))

