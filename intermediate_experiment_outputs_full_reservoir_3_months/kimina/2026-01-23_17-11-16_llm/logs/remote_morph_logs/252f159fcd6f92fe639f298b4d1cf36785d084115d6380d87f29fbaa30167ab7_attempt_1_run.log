/-! A lemma from the paper that is used multiple times. -/
lemma lemmaS1 (c : ℕ → ℝ) (h : ∀ n : ℕ, 0 < c n) (hc : Filter.Tendsto (fun n => c n / ↑n) Filter.atTop (nhds 0)) :
    ∀ (n : ℕ) (ε : ℝ), 0 < ε → ∃ (N : ℕ), ∀ (n : ℕ), n ≥ N → |c n - n| < ε := by
  intro n ε
  have hc' : Filter.Tendsto (fun n => c n / ↑n) Filter.atTop (nhds 0) := hc
  have h1 : ∀ (n : ℕ), 0 < c n := h
  have h2 : ∀ (n : ℕ), n ≥ 1 → c n / ↑n < c n := by
    intro n hn
    have hn' : (n : ℝ) > 0 := by exact_mod_cast (show (0 : ℕ) < n by linarith)
    have h3 : c n / ↑n < c n := by
      have h4 : c n / ↑n < c n := by
        apply (div_lt_iff₀ (by positivity)).mpr
        nlinarith
      linarith
    linarith
  have h3 : ∀ (n : ℕ), n ≥ 1 → |c n - n| < |c n| := by
    intro n hn
    have h4 : c n - n < 0 := by
      nlinarith [h2 n hn]
    have h5 : |c n - n| = n - c n := by
      rw [abs_of_neg h4]
      ring
    have h6 : |c n| = c n := by
      apply abs_of_pos
      exact h n
    nlinarith [h5, h6, h n]
  have h4 : ∃ (N : ℕ), ∀ (n : ℕ), n ≥ N → |c n| < ε := by
    apply hc'.eventually_mem_of_isClosed (s := {x | |x| < ε}) (by simp; exact ε)
    intro n hn
    simp at hn ⊢
    exact hn
  rcases h4 with ⟨N, hN⟩
  use N
  intro n hn
  have h5 : n ≥ N := hn
  have h6 : |c n| < ε := hN n h5
  have h7 : |c n - n| < |c n| := h3 n (by linarith)
  linarith [abs_nonneg (c n - n), abs_nonneg (c n), h6]

