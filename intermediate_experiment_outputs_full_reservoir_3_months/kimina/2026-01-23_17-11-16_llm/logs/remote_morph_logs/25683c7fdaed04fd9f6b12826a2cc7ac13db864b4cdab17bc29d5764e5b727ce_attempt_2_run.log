    marcinkiewiczZygmundSymmConst (2 * m) * ∫ ω, (∑ i ∈ A, ‖X i ω‖ ^ 2) ^ m ∂μ := by
  apply marcinkiewicz_zygmund_symmetric
  · simpa using iIndepFun_X
  · intro i
