    use x Ôèö y, hN
    simp only [B, Set.mem_setOf_eq, if_true, Set.mem_singleton_iff]
    intro h
    --This should be easy
    --But we need to show {x, y} = {x Ôèö y} is false
    simp only [Set.mem_singleton_iff] at h
    have h1 := h x (by tauto)
    have h2 := h y (by tauto)
    --h1: x = x Ôèö y
    --h2: y = x Ôèö y
    --From h1: x Ôëñ x Ôèö y, which is true
    --From h1: y Ôëñ x Ôèö y, which is true
    --From h2: x = x Ôèö y, which implies x = y
    --From h2: y = x Ôèö y, which implies y = x
    --So x = y
    --But then x Ôèö y = x = y
    --But hxy says Disjoint x y
    --Disjoint x x is false
    exfalso
    have h_eq : x = y := by
