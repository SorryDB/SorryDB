```lean
import Mathlib
open scoped Classical

namespace Algebra

variable {C : Type u_1} [inst : Category C] {K : Type u_0} [inst : DivisionRing K] {M : C ÔÑñ (ModuleCat K)}

/- A direct sum decomposition of a module M is a set D of submodules such that:
1. D is a partition of M (every vector is in exactly one submodule of D)
2. D is minimal in the sense that if D' is a direct sum decomposition of M and D' is a subset of D, then D' = D
3. Each submodule in D is non-zero -/
structure DirectSumDecomposition (M : C ÔÑñ (ModuleCat K)) :=
  { carrier : Set (PersistenceSubmodule M)
    sSupIndep' : SetLike.sSupIndep (SetLike.coe carrier)
    sSup_eq_top' : SetLike.sSup (SetLike.coe carrier) = Ôèñ
    not_bot_mem' : ÔêÇ N Ôêê carrier, N Ôëá ÔèÑ
    -- Pointwise versions of these properties
    pointwise_iSup_eq_top : ÔêÇ c : C, Ô¿å p Ôêê carrier, p.val c = Ôèñ
    pointwise_sSup_eq_top : ÔêÇ c : C, Ô¿å p Ôêê carrier, p.val c = Ôèñ
  }

/- A direct sum decomposition D is minimal if any other direct sum decomposition D' that is a subset of D must be equal to D. -/
structure IsMin (D : DirectSumDecomposition M) :=
  ÔêÇ D' : DirectSumDecomposition M, D' Ôèå D ÔåÆ D' = D

/- If `DÔéü, DÔéé` are direct sum decompositions of `M` we say that `DÔéü` is a refinement of `DÔéé` if for
every submodule `N` that appears in `DÔéé`, there is a subset `B` of submodules that appear
in `DÔéü` such that `Ôêæ T Ôêê B, T = N`. -/
def IsRefinement (DÔéü DÔéé : DirectSumDecomposition M) : Prop :=
  ÔêÇ ÔªâNÔªä, N Ôêê DÔéé ÔåÆ Ôêâ B : Set (PersistenceSubmodule M), B Ôèå DÔéü Ôêº N = sSup B

/- Suppose `I, J` are direct sum decompositions of `M ` and `J` is a refinement of `I`.
Then for any submodule `N` appearing in `J`, there is a submodule  `A` appearing in `I`
such that `N Ôëñ A`. -/
lemma RefinementMapSurj' (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : ÔêÇ N : J, Ôêâ A : I, N.val Ôëñ A.val := by
  by_contra! h_contra
  rcases h_contra with Ôƒ¿NÔéÇ, h_not_leÔƒ®
  have h_ge : NÔéÇ.val Ôèö sSup I Ôëñ sSup J := by
    rw [ÔåÉ sSup_pair]
    apply sSup_le_iff.mpr
    intro b h_mem
    rcases h_mem with Ôƒ¿h_nÔƒ®
    ┬À exact (le_sSup (h_n Ôû© NÔéÇ.prop))
    ┬À rename b Ôêê {sSup (SetLike.coe I)} => h_i
      have h' : sSup (SetLike.coe I) Ôëñ sSup J := by
        rw [I.sSup_eq_top, J.sSup_eq_top]
      simp only [Set.mem_singleton_iff] at h_i
      exact (h_i Ôû© h')
  let B : Set (PersistenceSubmodule M) := {C | Ôêâ A : I, C Ôëñ A.val Ôêº C Ôêê J}
  have h_sub : B Ôèå J := by
    intro C h_C_mem
    simp [B] at h_C_mem
    exact h_C_mem.right
  have h_aux : sSup B = sSup I := by
    simp_rw [le_antisymm_iff, sSup_le_iff]
    constructor
    ┬À intro b h_mem
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B] at h_mem
      rcases h_mem with Ôƒ¿hÔéü, _Ôƒ®
      rcases hÔéü with Ôƒ¿a, h_a, h_leÔƒ®
      exact le_sSup_of_le h_a h_le
    have h_le_subset : ÔêÇ A : I, Ôêâ C Ôèå B, A Ôëñ sSup C := by
      intro A
      choose f hf hf' using h
      refine Ôƒ¿f A.prop, ?_, by rw [ÔåÉ hf' A.prop]Ôƒ®
      intro ╬▒ h_╬▒
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B]
      refine Ôƒ¿Ôƒ¿A, A.prop, ?_Ôƒ®, hf A.prop h_╬▒Ôƒ®
      rw [hf' A.prop]
      exact le_sSup h_╬▒
    intro A h_A_mem
    rcases h_le_subset Ôƒ¿A, h_A_memÔƒ® with Ôƒ¿C, h_CÔƒ®
    simp only at h_C
    exact le_trans h_C.right (sSup_le_sSup h_C.left)
  have h_aux' : NÔéÇ.val Ôêë B := by
    intro h_contra
    simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, SetLike.coe_mem,
      and_true, B] at h_contra
    rcases h_contra with Ôƒ¿A, hÔéü, hÔééÔƒ®
    exact (h_not_le (Ôƒ¿A, hÔéüÔƒ®) hÔéé)
  have h_disj : Disjoint NÔéÇ.val (sSup B) := by
    exact (sSupIndep.disjoint_sSup J.sSupIndep' NÔéÇ.prop h_sub h_aux')
  have h_not_bot : NÔéÇ.val Ôëá ÔèÑ := by
    intro h_contra
    exact J.not_bot_mem (h_contra Ôû© NÔéÇ.prop)
  have h_gt : sSup I < NÔéÇ.val Ôèö sSup I := by
    rw [ÔåÉ h_aux]
    -- No clue why I couldn't use this theorem from mathlib directly and had to copy paste it here
    -- instead assuming it has to do with needing to bump
    exact (right_lt_sup_of_left_ne_bot h_disj h_not_bot)
  have contra : (Ôèñ : PersistenceSubmodule M) < Ôèñ := by
    rw [I.sSup_eq_top, J.sSup_eq_top] at *
    apply lt_of_lt_of_le h_gt h_ge
  exact (lt_self_iff_false (Ôèñ : PersistenceSubmodule M)).mp contra

/- Suppose that `I, J` are direct sum decompositions of `M`, `N` is a submodule appearing in `J`
and `A, B` are submodules appearing in `I` such that `N Ôëñ A, B`. Then `A = B`. -/
lemma UniqueGE (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (N : J) (A : I) (B : I) : N.val Ôëñ A Ôêº N.val Ôëñ B ÔåÆ A = B := by
  by_contra h'
  push_neg at h'
  rcases h' with Ôƒ¿h_le, h_neqÔƒ®
  have h_neq' : A.val Ôëá B.val := by
    simp [h_neq]
  have h_disj : Disjoint A.val B.val := by
    let s : Set (PersistenceSubmodule M) := {A.val, B.val}
    have h_sub : s Ôëñ I.carrier := by
      intro X hx
      rcases hx with Ôƒ¿h_memÔƒ®
      ┬À exact (h_mem Ôû© A.prop)
      subst X
      exact B.prop
    exact (sSupIndep_pair h_neq').mp (sSupIndep.mono I.sSupIndep' h_sub)
  have h_le' : N.val Ôëñ A.val Ôèô B.val := le_inf h_le.1 h_le.2
  have h_eq_bot : N Ôëñ (ÔèÑ : PersistenceSubmodule M) := h_le'.trans <| disjoint_iff_inf_le.mp h_disj
  simp only [le_bot_iff] at h_eq_bot
  exact (J.not_bot_mem' (h_eq_bot Ôû© N.prop))

/- Let `I, J` be direct sum decompositions of `M` with `J` a refinement of `I`. Then
`RefinementMap` is the function that sends a submodule `N` appearing in `J` to the unique submodule
in `I` that contains `N`. -/
noncomputable def RefinementMap (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : J ÔåÆ I :=
  open scoped Classical in
  if h' : I = J then by
    intro N
    use N
    exact (h' Ôû© N.prop)
  else by
    intro N
    choose A h using (RefinementMapSurj' I J h N)
    exact A

@[simp]
lemma RefinementMapId (I : DirectSumDecomposition M) (h : IsRefinement I I) (N : I) :
  (RefinementMap I I h) N = N := by
  simp [RefinementMap]

/- `RefinmentMap N` sends `N` to something it is included in. -/
lemma RefinementMapLE (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : ÔêÇ N : J, N.val Ôëñ (RefinementMap I J h N).val := by
  classical
  obtain rfl | hIJ := eq_or_ne I J
  ┬À simp [RefinementMapId]
  ┬À intro N
    simpa [RefinementMap, hIJ] using Exists.choose_spec (RefinementMapSurj' I J h N)

/- Two modules that both decompose the same element are sent to the same submodule by the
`RefinementMap`. -/
lemma RefinementMapSameImage (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
    (h : IsRefinement J I) (NÔéü NÔéé : J) (h_leÔéü : NÔéé.val Ôëñ RefinementMap I J h NÔéü) :
    RefinementMap I J h NÔéé = RefinementMap I J h NÔéü := by
  have h_leÔéé : NÔéé.val Ôëñ (RefinementMap I J h NÔéé) := RefinementMapLE I J h NÔéé
  exact (UniqueGE I J NÔéé (RefinementMap I J h NÔéü) (RefinementMap I J h NÔéé) (Ôƒ¿h_leÔéü, h_leÔééÔƒ®)).symm

/- If `N Ôëñ A` for some `A : I`, then `RefinementMap N = A`. -/
lemma SendsToUniqueGE (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
    (h : IsRefinement J I) (N : J) (A : I) : N.val Ôëñ A ÔåÆ (RefinementMap I J h N) = A := by
  intro h_le
  let B : I := (RefinementMap I J h N)
  rw [UniqueGE I J N A B (Ôƒ¿h_le, RefinementMapLE I J h NÔƒ®)]

lemma RefinmentMapFunctorial (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
    (K : DirectSumDecomposition M) (hij : IsRefinement J I) (hjk : IsRefinement K J)
    (hik : IsRefinement K I) (N : K) :
    RefinementMap I K hik N = RefinementMap I J hij (RefinementMap J K hjk N) := by
  have h_le : N.val Ôëñ RefinementMap I J hij (RefinementMap J K hjk N) := by
    apply le_trans (RefinementMapLE J K hjk N)
    exact (RefinementMapLE I J hij _)
  exact SendsToUniqueGE I K hik N (RefinementMap I J hij (RefinementMap J K hjk N)) h_le

/-- The refinement relation defines a preorder on direct sum decompositions of `M` via `DÔéü Ôëñ DÔéé` if
and only if `DÔéü` is a refinement of `DÔéé` i.e. this relation is reflexive and transitive. -/
instance : Preorder (DirectSumDecomposition M) where
  le DÔéü DÔéé := IsRefinement DÔéü DÔéé
  --DÔéü Ôëñ DÔéé iff DÔéü refines DÔéé.
  le_refl D := by intro N _; use {N}; aesop
  le_trans IÔéü IÔéé IÔéâ h12 h23 := by
    intro N h_mem
    rcases (h23 h_mem) with Ôƒ¿C, h_sub, h_eqÔƒ®
    choose f hf hf' using h12
    let A := Ô¿å (c : C), (f (h_sub c.prop))
    use A
    constructor
    ┬À apply iSup_le_iff.mpr
      intro c
      exact hf (h_sub c.prop)
    ┬À have h_aux' : sSup A = sSup C := by
        simp_rw [le_antisymm_iff, sSup_le_iff]
        constructor
        ┬À intro a h_a
          have h_aux'' : Ôêâ (c : C), a Ôêê (f (h_sub c.prop)) := by aesop
          rcases h_aux'' with Ôƒ¿c_a, h_caÔƒ®
          have h_le : a Ôëñ c_a := by rw [hf' (N := c_a) (h_sub c_a.2)]; apply le_sSup h_ca
          apply le_sSup_of_le c_a.prop h_le
        intro c h_mem_c
        let c' : C := Ôƒ¿c, h_mem_cÔƒ®
        have h_le_c : c Ôëñ sSup (f (h_sub c'.prop)) := by
          rw [ÔåÉ hf' (h_sub c'.prop)]
        apply le_trans h_le_c
        apply sSup_le
        intro a h_mem_a
        have h_a_in_A : a Ôêê A := by
          have h_subs : f (h_sub c'.prop) Ôëñ A := by
            apply le_iSup_of_le c'
            exact le_rfl
          exact h_subs h_mem_a
        exact le_sSup h_a_in_A
      rwa [h_aux']

/-- The refinement relation is antisymmetric. This (combined with the above)
means that it defines a partial order on direct sum decompositions. -/
instance DirectSumDecompLE : PartialOrder (DirectSumDecomposition M) where
  le_antisymm := by
    intro I J h_J_le_I h_I_le_J
    have h_final_left : ÔêÇ N Ôêê J, N Ôêê I := by
      intro N
      by_contra h_neg
      push_neg at h_neg
      rcases h_neg with Ôƒ¿h_N_in_J, h_N_not_in_IÔƒ®
      let N' : J := Ôƒ¿N, h_N_in_JÔƒ®
      have h_A : Ôêâ A : I, N Ôëñ A.val := by
        exact (RefinementMapSurj' I J h_I_le_J) N'
      rcases h_A with Ôƒ¿A, h_N_le_AÔƒ®
      choose f hf hf' using h_J_le_I
      let h_BÔéü := hf' N'.prop
      let h_BÔéé := hf N'.prop
      simp only at h_BÔéü
      have h_mem : A.val Ôêê f N'.prop := by
        by_contra h_A_not_mem
        have h_aux : Disjoint A.val (sSup (f N'.prop)) := by
          exact (I.sSupIndep.disjoint_sSup A.prop h_BÔéé h_A_not_mem)
        have h_aux' : sSup (f N'.prop) Ôëñ A.val := h_BÔéü Ôû© h_N_le_A
        have h_last : sSup (f N'.prop) = (ÔèÑ : PersistenceSubmodule M) := by
          rw [disjoint_comm] at h_aux
          exact (Disjoint.eq_bot_of_le h_aux h_aux')
        rw [ÔåÉ h_BÔéü] at h_last
        subst h_last
        exact (J.not_bot_mem h_N_in_J)
      have h_A_le_N : A.val Ôëñ N := by
        simpa [ÔåÉ h_BÔéü] using le_sSup h_mem
      have h_A_eq_N : A.val = N := by
        exact (le_antisymm h_A_le_N h_N_le_A)
      have h_contra : N Ôêê I := by
        exact h_A_eq_N Ôû© A.prop
      aesop
    have h_final_right : ÔêÇ N Ôêê I, N Ôêê J := by
      sorry
    aesop

variable {M : C ÔÑñ ModuleCat K} in
/-- Let `DÔéü, DÔéé` be direct sum decomposition of `M` we say that `DÔéü` is a refinement of `DÔéé` if for
every submodule `N` that appears in `DÔéé`, there is a subset `B` of submodules that appear
in `DÔéü` such that `Ôêæ T Ôêê B, T = N`. -/
def IsRefinement (DÔéü DÔéé : DirectSumDecomposition M) : Prop :=
  ÔêÇ ÔªâNÔªä, N Ôêê DÔéé ÔåÆ Ôêâ B : Set (PersistenceSubmodule M), B Ôèå DÔéü Ôêº N = sSup B

variable {M : C ÔÑñ ModuleCat K} in
/-- Suppose `I, J` are direct sum decompositions of `M ` and `J` is a refinement of `I`.
Then for any submodule `N` appearing in `J`, there is a submodule  `A` appearing in `I`
such that `N Ôëñ A`. -/
lemma RefinementMapSurj' (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : ÔêÇ N : J, Ôêâ A : I, N.val Ôëñ A.val := by
  by_contra! h_contra
  rcases h_contra with Ôƒ¿NÔéÇ, h_not_leÔƒ®
  have h_ge : NÔéÇ.val Ôèö sSup I Ôëñ sSup J := by
    rw [ÔåÉ sSup_pair]
    apply sSup_le_iff.mpr
    intro b h_mem
    rcases h_mem with Ôƒ¿h_nÔƒ®
    ┬À exact (le_sSup (h_n Ôû© NÔéÇ.prop))
    ┬À rename b Ôêê {sSup (SetLike.coe I)} => h_i
      have h' : sSup (SetLike.coe I) Ôëñ sSup J := by
        rw [I.sSup_eq_top, J.sSup_eq_top]
      simp only [Set.mem_singleton_iff] at h_i
      exact (h_i Ôû© h')
  let B : Set (PersistenceSubmodule M) := {C | Ôêâ A : I, C Ôëñ A.val Ôêº C Ôêê J}
  have h_sub : B Ôèå J := by
    intro C h_C_mem
    simp [B] at h_C_mem
    exact h_C_mem.right
  have h_aux : sSup B = sSup I := by
    simp_rw [le_antisymm_iff, sSup_le_iff]
    constructor
    ┬À intro b h_mem
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B] at h_mem
      rcases h_mem with Ôƒ¿hÔéü, _Ôƒ®
      rcases hÔéü with Ôƒ¿a, h_a, h_leÔƒ®
      exact le_sSup_of_le h_a h_le
    have h_le_subset : ÔêÇ A : I, Ôêâ C Ôèå B, A Ôëñ sSup C := by
      intro A
      choose f hf hf' using h
      refine Ôƒ¿f A.prop, ?_, by rw [ÔåÉ hf' A.prop]Ôƒ®
      intro ╬▒ h_╬▒
      simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, B]
      refine Ôƒ¿Ôƒ¿A, A.prop, ?_Ôƒ®, hf A.prop h_╬▒Ôƒ®
      rw [hf' A.prop]
      exact le_sSup h_╬▒
    intro A h_A_mem
    rcases h_le_subset Ôƒ¿A, h_A_memÔƒ® with Ôƒ¿C, h_CÔƒ®
    simp only at h_C
    exact le_trans h_C.right (sSup_le_sSup h_C.left)
  have h_aux' : NÔéÇ.val Ôêë B := by
    intro h_contra
    simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, SetLike.coe_mem,
      and_true, B] at h_contra
    rcases h_contra with Ôƒ¿A, hÔéü, hÔééÔƒ®
    exact (h_not_le (Ôƒ¿A, hÔéüÔƒ®) hÔéé)
  have h_disj : Disjoint NÔéÇ.val (sSup B) := by
    exact (sSupIndep.disjoint_sSup J.sSupIndep' NÔéÇ.prop h_sub h_aux')
  have h_not_bot : NÔéÇ.val Ôëá ÔèÑ := by
    intro h_contra
    exact J.not_bot_mem (h_contra Ôû© NÔéÇ.prop)
  have h_gt : sSup I < NÔéÇ.val Ôèö sSup I := by
    rw [ÔåÉ h_aux]
    -- No clue why I couldn't use this theorem from mathlib directly and had to copy paste it here
    -- instead assuming it has to do with needing to bump
    exact (right_lt_sup_of_left_ne_bot h_disj h_not_bot)
  have contra : (Ôèñ : PersistenceSubmodule M) < Ôèñ := by
    rw [I.sSup_eq_top, J.sSup_eq_top] at *
    apply lt_of_lt_of_le h_gt h_ge
  exact (lt_self_iff_false (Ôèñ : PersistenceSubmodule M)).mp contra

/-- Suppose that `I, J` are direct sum decompositions of `M`, `N` is a submodule appearing in `J`
and `A, B` are submodules appearing in `I` such that `N Ôëñ A, B`. Then `A = B`. -/
lemma UniqueGE (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (N : J) (A : I) (B : I) : N.val Ôëñ A Ôêº N.val Ôëñ B ÔåÆ A = B := by
  by_contra h'
  push_neg at h'
  rcases h' with Ôƒ¿h_le, h_neqÔƒ®
  have h_neq' : A.val Ôëá B.val := by
    simp [h_neq]
  have h_disj : Disjoint A.val B.val := by
    let s : Set (PersistenceSubmodule M) := {A.val, B.val}
    have h_sub : s Ôëñ I.carrier := by
      intro X hx
      rcases hx with Ôƒ¿h_memÔƒ®
      ┬À exact (h_mem Ôû© A.prop)
      subst X
      exact B.prop
    exact (sSupIndep_pair h_neq').mp (sSupIndep.mono I.sSupIndep' h_sub)
  have h_le' : N.val Ôëñ A.val Ôèô B.val := le_inf h_le.1 h_le.2
  have h_eq_bot : N Ôëñ (ÔèÑ : PersistenceSubmodule M) := h_le'.trans <| disjoint_iff_inf_le.mp h_disj
  simp only [le_bot_iff] at h_eq_bot
  exact (J.not_bot_mem' (h_eq_bot Ôû© N.prop))

/- Let `I, J` be direct sum decompositions of `M` with `J` a refinement of `I`. Then
`RefinementMap` is the function that sends a submodule `N` appearing in `J` to the unique submodule
in `I` that contains `N`. -/
noncomputable def RefinementMap (I : DirectSumDecomposition M) (J : DirectSumDecomposition M)
  (h : IsRefinement J I) : J ÔåÆ I :=
  open scoped Classical in
  if h' : I = J then by
    intro N
    use N
    exact (h' Ôû© N.prop)
  else by
    intro N
    choose A h using (RefinementMapSurj' I J h N)
