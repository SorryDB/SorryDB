import Data.Nat

noncomputable def Arch (state : SystemState) (r : Request) (t : ThreadId) : Prop :=
  Arch.acceptConstraints state r t

noncomputable def SystemState.rmwPairsBlocking : SystemState → List (RequestId × RequestId)
  | _ => []
  /-
    let atomics := state.requests.filter Request.isAtomic
    -- quadratic, but shouldn't often by many pairs anyway
