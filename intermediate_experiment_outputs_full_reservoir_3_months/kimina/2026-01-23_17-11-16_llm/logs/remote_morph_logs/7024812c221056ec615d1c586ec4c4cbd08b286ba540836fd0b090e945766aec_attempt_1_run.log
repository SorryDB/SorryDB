rmwWrites : List Request := state✝.requests.filter fun req => req.isWrite && (req.isTransactional || req.isAtomic)
state : SystemState
rmwWrite previousWrite : Request
otherWrites : List Request :=
  state.requests.filter fun r =>
    r.isWrite && r.address? == rmwWrite.address? && r.id != rmwWrite.id && r.id != previousWrite.id
failedWriteBetween : Bool :=
  otherWrites.any fun write' =>
    let scope1 := state.scopes.jointScope previousWrite.thread write'.thread;
    state.orderConstraints.lookup scope1 previousWrite.id write'.id &&
