```tactics
def SystemState.cleanupTransactions : SystemState → SystemState
   | state =>
     let rmwWrites := state.requests.filter
       λ req => req.isWrite ∧ (req.isTransactional ∨ req.isAtomic)
     let result := rmwWrites.foldl (init := state) (fun state' rmwWrite =>
       match state'.rmwGetPreviousWrite? rmwWrite.id with
         | none => state'
         | some previousWrite =>
             let otherWrites := state'.requests.filter (fun r => r.isWrite ∧ r.address? == rmwWrite.address? ∧ r.id ≠ previousWrite.id ∧ r.id ≠ rmwWrite.id)
             let failedWriteBetween : Bool := otherWrites.any
               λ write' =>
                 let scope1 := state'.scopes.jointScope previousWrite.thread write'.thread
                 state'.orderConstraints.lookup scope1 previousWrite.id write'.id ∧
                 let scope2 := state'.scopes.jointScope rmwWrite.thread write'.thread
                 state'.orderConstraints.lookup scope2 write'.id rmwWrite.id
             let failedOtherRMW : Bool := otherWrites.filter
               (λ req => Option.map Request.id (state'.rmwGetPreviousWrite? req.id) == some previousWrite.id)
               |>.any (λ r => r.conditionalSucceeded)
             let failed : Prop := 
               failedWriteBetween 
                 (by { 
                   apply exists_eq; assumption
                 }) 
                 (by { 
                   apply exists_eq; assumption
                 }) 
               or failedOtherRMW
             let removedWrites := state'.requests.filter (fun r => r.conditionalFailed ∨ r == rmwWrite)
             let removed' : Multiset RequestId := 
               List.toMultiset removedWrites
                 |>.filter (fun id => id ∈ List.toMultiset (state'.removed))
             let requestsRemoved := removedWrites.foldl (λ arr req => arr.remove req.id) state'.requests
             let requests' : RequestArray := if failed then
               requestsRemoved
             else
               requestsRemoved.insert rmwWrite
             {state' with requests := requests', removed := removed', removedCoherent := sorry}
     ) 
     result
```
