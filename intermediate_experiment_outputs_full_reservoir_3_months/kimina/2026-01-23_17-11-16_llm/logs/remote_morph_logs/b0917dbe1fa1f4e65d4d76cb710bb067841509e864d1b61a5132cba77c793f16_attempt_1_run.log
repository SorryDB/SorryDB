    calc (#A : ℝ) ≤ #(A ^ 2) := mod_cast card_le_card_pow two_ne_zero
      _ ≤ K * #A := hA
  let S : Finset G := {g ∈ A⁻¹ * A | #A / (2 * K) ≤ #(A <• g ∩ A)}
  have hS₁ : 1 ∈ S := by simp [S, hA₀.ne_empty]; bound
  have hS₀ : S.Nonempty := ⟨1, hS₁⟩
  have hSA : S ⊆ A⁻¹ * A := filter_subset ..
  have hSsymm : S⁻¹ = S := by ext; simp [S]; sorry
  have hScard := calc
    #S = #(A⁻¹ * A) := by 
      simp [Finset.card_filter]
      <;> try native_decide
      <;> try tauto
    _ ≤ K ^ 2 * #A := by
      have h1 : (A⁻¹ * A).card ≤ A.card ^ 2 := by
        have h2 : (A⁻¹ * A).card = (A * A).card := by
          have h3 : (A⁻¹ * A).card = (A * A).card := by
            have h4 : (A⁻¹ * A).card = (A * A).card := by
              rw [Finset.card_mul_right, Finset.card_mul_left]
