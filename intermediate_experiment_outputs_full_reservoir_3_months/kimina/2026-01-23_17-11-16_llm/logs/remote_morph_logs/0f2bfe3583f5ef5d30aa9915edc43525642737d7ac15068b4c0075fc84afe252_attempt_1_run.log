      ‚Üź sum_antipode_mul_eq_algebraMap_counit ((‚Ąõ R a).mul (‚Ąõ R b))]
  ¬∑ simp [((‚Ąõ R a).tmul (‚Ąõ R b)).convMul_apply, mul_comm, mul_mul_mul_comm, Finset.sum_mul_sum,
      ‚Üź Finset.sum_product', ő≤, ‚Üź sum_mul_antipode_eq_algebraMap_counit (‚Ąõ R a),
