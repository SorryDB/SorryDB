local infix:90 " ‚óĀ " => LinearMap.lTensor
local notation:90 f:90 " ‚Ė∑ " X:90 => LinearMap.rTensor X f
local notation "őĪ" => TensorProduct.assoc R
local notation "ő≤" => TensorProduct.comm R
local notation "ūĚĎļ" => antipode R (A := C)
local notation "ūĚĎ≠" => őī‚āĀ ‚ąė‚āó ūĚĎļ
local notation "ūĚĎģ" => (ūĚĎļ ‚äó‚āė ūĚĎļ) ‚ąė‚āó (ő≤ C C) ‚ąė‚āó őī‚āĀ

lemma comul_right_inv : őī‚āĀ * ūĚĎ≠ = 1 := calc
    őľ‚āā ‚ąė‚āó (őī‚āĀ ‚äó‚āė (őī‚āĀ ‚ąė‚āó ūĚĎļ)) ‚ąė‚āó őī‚āĀ
  _ = őľ‚āā ‚ąė‚āó ((őī‚āĀ ‚ąė‚āó id) ‚äó‚āė (őī‚āĀ ‚ąė‚āó ūĚĎļ)) ‚ąė‚āó őī‚āĀ := rfl
  _ = őľ‚āā ‚ąė‚āó (őī‚āĀ ‚äó‚āė őī‚āĀ) ‚ąė‚āó (id ‚äó‚āė ūĚĎļ) ‚ąė‚āó őī‚āĀ := by
    simp only [_root_.TensorProduct.map_comp, comp_assoc]
  _ = őī‚āĀ ‚ąė‚āó őľ‚āĀ ‚ąė‚āó (id ‚äó‚āė ūĚĎļ) ‚ąė‚āó őī‚āĀ := by
      have : őľ‚āā ‚ąė‚āó (őī‚āĀ ‚äó‚āė őī‚āĀ) = őī‚āĀ ‚ąė‚āó őľ‚āĀ := by ext; simp
      simp [this, ‚Üź comp_assoc]
  _ = őī‚āĀ ‚ąė‚āó (id * ūĚĎļ) := rfl
  _ = őī‚āĀ ‚ąė‚āó ő∑‚āĀ ‚ąė‚āó őĶ‚āĀ := by simp [convOne_def]
  _ = ő∑‚āā ‚ąė‚āó őĶ‚āĀ := by
      have : őī‚āĀ ‚ąė‚āó ő∑‚āĀ = ő∑‚āā := by ext; simp; rfl
      simp [this, ‚Üź comp_assoc]

end LinearMap

namespace AlgHom
variable [CommSemiring A] [Semiring C] [Bialgebra R C] [HopfAlgebra R A]

lemma antipode_id_cancel : HopfAlgebra.antipodeAlgHom R A * AlgHom.id R A = 1 := by
  apply AlgHom.toLinearMap_injective
  rw [toLinearMap_convMul]
  ext
  simp [LinearMap.antipode_mul_id, AlgHom.convOne_apply]

lemma counitAlgHom_comp_antipodeAlgHom :
    (counitAlgHom R A).comp (HopfAlgebra.antipodeAlgHom R A) = counitAlgHom R A :=
  AlgHom.toLinearMap_injective <| by simp

private lemma inv_convCancel (f : C ‚Üí‚āźc[R] A) :
    (.comp (HopfAlgebra.antipodeAlgHom R A) f : C ‚Üí‚āźc[R] A) * f = 1 := calc
  _ = (.comp (HopfAlgebra.antipodeAlgHom R A) f : C ‚Üí‚āźc[R] A) * (.comp (.id R A) f) := by simp
  _ = .comp (lmul' R) (.comp (Algebra.TensorProduct.map (HopfAlgebra.antipodeAlgHom R A)
       (.id R A)) <| .comp (Algebra.TensorProduct.map f f) (comulAlgHom R C)) := by
    rw [convMul_def, Algebra.TensorProduct.map_comp]
    simp only [comp_assoc]
  _ = (HopfAlgebra.antipodeAlgHom R A * id).comp f := by
    simp only [convMul_def, BialgHomClass.map_comp_comulAlgHom]
    simp only [comp_assoc]
  _ = _ := by simp [antipode_id_cancel, convOne_def, comp_assoc]

end AlgHom

namespace BialgHom
variable [CommSemiring A] [CommSemiring C]

section HopfAlgebra
variable [HopfAlgebra R A] [HopfAlgebra R C] [IsCocomm R C]

/-- The antipode of a commutative cocommutative Hopf algebra as a coalgebra hom. -/
def antipodeBialgHom : C ‚Üí‚āźc[R] C where
  __ := antipodeAlgHom R (A := C)
  map_smul' := _
  counit_comp := counit_comp_antipode
  map_comp_comul := by
    apply left_inv_eq_right_inv (a := comul)
    ¬∑ sorry
    ¬∑ sorry

instance : Inv (C ‚Üí‚āźc[R] A) where inv := antipodeBialgHom.comp

set_option linter.unusedSectionVars false in
lemma inv_def (f : C ‚Üí‚āźc[R] A) : f‚ĀĽ¬Ļ = antipodeBialgHom.comp f := rfl

set_option linter.unusedSectionVars false in
@[simp] lemma inv_apply (f : C ‚Üí‚āźc[R] A) (c : C) : f‚ĀĽ¬Ļ c = antipode R (f c) := rfl

private lemma inv_convCancel (f : C ‚Üí‚āźc[R] A) : f‚ĀĽ¬Ļ * f = 1 := sorry
