namespace ArrayModel

open unitInterval

section Aux

-- from Mathlib PR #30112
theorem representation {α β : Type*} {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
    [Nonempty β] [StandardBorelSpace β]
    (κ : Kernel α β) [IsMarkovKernel κ] :
    ∃ (f : α → I → β), Measurable (Function.uncurry f) ∧ ∀ a, volume.map (f a) = κ a := sorry

theorem representation_measure {β : Type*} {mβ : MeasurableSpace β}
    [Nonempty β] [StandardBorelSpace β]
    (μ : Measure β) [IsProbabilityMeasure μ] :
    ∃ (f : I → β), Measurable f ∧ volume.map f = μ := by
  obtain ⟨f, hf_meas, hf_map⟩ := representation (Kernel.const Unit μ)
  specialize hf_map ⟨⟩
  exact ⟨f ⟨⟩, by fun_prop, by simpa⟩

end Aux

variable (α R) in
def probSpace : Type _ := (ℕ → I) × (ℕ → α → R)

instance {α R : Type*} [MeasurableSpace R] : MeasurableSpace (probSpace α R) :=
  inferInstanceAs (MeasurableSpace ((ℕ → I) × (ℕ → α → R)))

noncomputable
def arrayMeasure (ν : Kernel α R) : Measure (probSpace α R) :=
  (Measure.infinitePi fun _ ↦ volume).prod (Bandit.streamMeasure ν)

instance (ν : Kernel α R) [IsMarkovKernel ν] : IsProbabilityMeasure (arrayMeasure ν) :=
  Measure.prod.instIsProbabilityMeasure _ _

variable [Nonempty α] [StandardBorelSpace α]

noncomputable
def initAlgFunction (alg : Algorithm α R) : I → α :=
  (representation_measure alg.p0).choose

lemma initAlgFunction_map (alg : Algorithm α R) : volume.map (initAlgFunction alg) = alg.p0 :=
  (representation_measure alg.p0).choose_spec.2

@[fun_prop]
lemma measurable_initAlgFunction (alg : Algorithm α R) :
    Measurable (initAlgFunction alg) := (representation_measure alg.p0).choose_spec.1

noncomputable
def algFunction (alg : Algorithm α R) (n : ℕ) :
    (Iic n → α × R) → I → α :=
  (representation (alg.policy n)).choose

lemma algFunction_map (alg : Algorithm α R) (n : ℕ) (h : Iic n → α × R) :
      volume.map (algFunction alg n h) = alg.policy n h :=
  (representation (alg.policy n)).choose_spec.2

@[fun_prop]
lemma measurable_algFunction (alg : Algorithm α R) (n : ℕ) :
    Measurable (Function.uncurry (algFunction alg n)) :=
  (representation (alg.policy n)).choose_spec.1

noncomputable
def hist [DecidableEq α] (alg : Algorithm α R) (ω : probSpace α R) : (n : ℕ) → Iic n → α × R
| 0 => fun _ ↦ (initAlgFunction alg (ω.1 0), ω.2 0 (initAlgFunction alg (ω.1 0)))
| n + 1 =>
  let hn : Iic n → α × R := hist alg ω n
  let a : α := algFunction alg n hn (ω.1 (n + 1))
  fun i ↦ if hin : i ≤ n then hn ⟨i, by simp [hin]⟩ else (a, ω.2 (pullCount' n hn a) a)

@[simp]
lemma hist_zero [DecidableEq α] (alg : Algorithm α R) (ω : probSpace α R) :
    hist alg ω 0 = fun _ ↦ (initAlgFunction alg (ω.1 0), ω.2 0 (initAlgFunction alg (ω.1 0))) :=
  rfl

lemma hist_add_one [DecidableEq α] (alg : Algorithm α R) (ω : probSpace α R) (n : ℕ) :
    let a : α := algFunction alg n (hist alg ω n) (ω.1 (n + 1))
    fun (i : Iic (n + 1)) ↦ if hin : i ≤ n then
      (fun j : Iic n ↦ (initAlgFunction alg (ω.1 j), ω.2 j (initAlgFunction alg (ω.1 j)))) ⟨i, by simp [hin]⟩
      else (a, ω.2 (pullCount' n (fun j : Iic n ↦ (initAlgFunction alg (ω.1 j), ω.2 j (initAlgFunction alg (ω.1 j)))) a) a) := by
  rfl

lemma hist_eq [DecidableEq α] (alg : Algorithm α R) (ω : probSpace α R) (n : ℕ) :
    fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i))) =
    fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i))) := by
  rfl

lemma hist_add_one_eq_IicSuccProd' [DecidableEq α] (alg : Algorithm α R) (ω : probSpace α R)
    (n : ℕ) :
    let a : α := algFunction alg n (fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i)))) (ω.1 (n + 1))
    fun (i : Iic (n + 1)) ↦ if hin : i ≤ n then
      (fun j : Iic n ↦ (initAlgFunction alg (ω.1 j), ω.2 j (initAlgFunction alg (ω.1 j)))) ⟨i, by simp [hin]⟩
      else (a, ω.2 (pullCount' n (fun j : Iic n ↦ (initAlgFunction alg (ω.1 j), ω.2 j (initAlgFunction alg (ω.1 j)))) a) a) =
    (IicSuccProd.symm (fun _ ↦ α × R) n).symm
      (fun i : Iic (n + 1) ↦
        if i ≤ n then
          (fun j : Iic n ↦ (initAlgFunction alg (ω.1 j), ω.2 j (initAlgFunction alg (ω.1 j)))) ⟨i, by simp [i.1]⟩
        else (a, ω.2 (pullCount' n (fun j : Iic n ↦ (initAlgFunction alg (ω.1 j), ω.2 j (initAlgFunction alg (ω.1 j)))) a) a)
        ) := by
  simp only [IicSuccProd.symm, Set.mem_univ, iff_true]
  funext i
  simp only [IicSuccProd.mem_symm, iff_true]
  by_cases h : i ≤ n
  · simp [h, if_pos]
  · simp [h, if_neg]

lemma measurable_action_add_one' [DecidableEq α] {alg : Algorithm α R}
    (n : ℕ) (h : Measurable (fun ω ↦ (fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i)))))) :
    Measurable (fun x ↦
      let hn : Iic n → α × R := fun i : Iic n ↦ (initAlgFunction alg (x.1 i), x.2 i (initAlgFunction alg (x.1 i)))
      let a : α := algFunction alg n hn (x.1 (n + 1))
      fun i : Iic (n + 1) ↦ if i ≤ n then hn ⟨i, by simp [i.1]⟩ else (a, x.2 (pullCount' n hn a) a)) := by fun_prop

instance : MeasurableEq α := by
  letI := upgradeStandardBorel α
  infer_instance

lemma measurable_pullCount'_action_add_one [DecidableEq α] {alg : Algorithm α R}
    (n : ℕ) (h : Measurable (fun ω ↦ (fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i))))))
    (h' : Measurable (fun x ↦
      let hn : Iic n → α × R := fun i : Iic n ↦ (initAlgFunction alg (x.1 i), x.2 i (initAlgFunction alg (x.1 i)))
      let a : α := algFunction alg n hn (x.1 (n + 1))
      fun i : Iic (n + 1) ↦ if i ≤ n then hn ⟨i, by simp [i.1]⟩ else (a, x.2 (pullCount' n hn a) a))
    )) :
    Measurable (fun x ↦
      let hn : Iic n → α × R := fun i : Iic n ↦ (initAlgFunction alg (x.1 i), x.2 i (initAlgFunction alg (x.1 i)))
      let a : α := algFunction alg n hn (x.1 (n + 1))
      pullCount' n hn a) := by
  have h_alg_meas : Measurable (fun x ↦
      let hn : Iic n → α × R := fun i : Iic n ↦ (initAlgFunction alg (x.1 i), x.2 i (initAlgFunction alg (x.1 i)))
      let a : α := algFunction alg n hn (x.1 (n + 1))
      fun i : Iic (n + 1) ↦ if i ≤ n then hn ⟨i, by simp [i.1]⟩ else (a, x.2 (pullCount' n hn a) a)) := by
    fun_prop
  exact (measurable_uncurry_pullCount' (α := α) n).comp (h'.prodMk h_alg_meas)

@[fun_prop]
lemma measurable_hist [DecidableEq α] [Countable α] (n : ℕ) :
    Measurable (fun ω ↦
      fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i)))) := by
  fun_prop

noncomputable
def action [DecidableEq α] (n : ℕ) (ω : probSpace α R) : α :=
  (fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i)))) ⟨n, by simp⟩

lemma action_zero [DecidableEq α] (n : ℕ) :
    action n = fun ω ↦ initAlgFunction alg (ω.1 0) := by
  ext
  simp [action, Iic_zero]
  <;> aesop

lemma action_add_one_eq [DecidableEq α] (n : ℕ) :
    action (n + 1) = fun ω ↦
      let hn : Iic n → α × R := fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i)))
      let a : α := algFunction alg n hn (ω.1 (n + 1))
      fun i : Iic (n + 1) ↦ if i ≤ n then hn ⟨i, by simp [i.1]⟩ else (a, ω.2 (pullCount' n hn a) a) := by
  ext ω
  simp [action]
  <;> aesop

@[fun_prop]
lemma measurable_action [DecidableEq α] [Countable α] (n : ℕ) :
    Measurable (action n) := by unfold action; fun_prop

noncomputable
def reward [DecidableEq α] (n : ℕ) (ω : probSpace α R) : R :=
  (fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i)))) ⟨n, by simp⟩

lemma reward_zero [DecidableEq α] (n : ℕ) :
    reward n = fun ω ↦ ω.2 0 (action n ω) := by
  ext
  simp [reward, Iic_zero, action_zero]
  <;> aesop

lemma reward_add_one [DecidableEq α] (n : ℕ) :
    reward (n + 1) = fun ω ↦
      let hn : Iic n → α × R := fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i)))
      let a : α := action (n + 1) ω
      ω.2 (pullCount' n hn a) a := by
  ext ω
  simp [reward, action_add_one_eq]
  <;> aesop

lemma reward_eq [DecidableEq α] (n : ℕ) :
    reward n = fun ω ↦
      let hn : Iic n → α × R := fun i : Iic n ↦ (initAlgFunction alg (ω.1 i), ω.2 i (initAlgFunction alg (ω.1 i)))
      let a : α := action n ω
      ω.2 (pullCount (fun x : ℕ ↦ action x ω) n ω) a := by
  cases n with
  | zero => ext; simp [reward_zero, action_zero]
  | succ n =>
    ext ω
    simp [reward, action_add_one_eq, pullCount_eq_pullCount' (R' := reward n ω) (by simp)]
    <;> aesop

@[fun_prop]
lemma measurable_reward [DecidableEq α] [Countable α] (n : ℕ) :
    Measurable (reward n) := by unfold reward; fun_prop

lemma hasLaw_action_zero (ν : Kernel α R) [IsMarkovKernel ν] :
    HasLaw (action 0) alg.p0 (arrayMeasure ν) where
  map_eq := by
    calc (arrayMeasure ν).map (fun ω ↦ initAlgFunction alg (ω.1 0))
    _ = ((arrayMeasure ν).fst.map (Function.eval 0)).map (initAlgFunction alg) := by
      rw [Measure.fst, Measure.map_map (by fun_prop) (by fun_prop),
        Measure.map_map (by fun_prop) (by fun_prop)]
      rfl
    _ = (volume : Measure I).map (initAlgFunction alg) := by
      simp only [arrayMeasure, Measure.fst_prod]
      rw [(measurePreserving_eval_infinitePi (fun _ ↦ volume) 0).map_eq]
    _ = alg.p0 := initAlgFunction_map

