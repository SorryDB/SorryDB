      simp [hx]
    _ = ν a := by
      rw [cond_of_indepFun]
      · exact map_snd_apply_arrayMeasure 0 a
      · have : (fun ω ↦ ω.1 0) ⟂ᵢ[arrayMeasure ν] fun ω ↦ ω.2 0 a :=
          indepFun_fst_zero_snd_zero_action ν a
