import Mathlib

open Filter Set Measure ProbabilityTheory

namespace Bandit

variable (α R : Type*)

variable [Nonempty α] [StandardBorelSpace α]

variable [StandardBorelSpace R] [Nonempty R]

variable [StandardBorelSpace α] [Nonempty α]
variable [StandardBorelSpace R] [Nonempty R]

noncomputable
def arrayMeasure (ν : Kernel α R) : Measure (ℕ → (I × (α × R))) :=
  (Measure.infinitePi fun _ ↦ volume).prod (fun s ↦ ν s)

noncomputable
def algFunction (alg : Algorithm α R) (n : ℕ) :
    (Iic n → α × R) → I → α :=
  (representation (alg.policy n)).choose

lemma algFunction_map (alg : Algorithm α R) (n : ℕ) (h : Iic n → α × R) :
      volume.map (algFunction alg n h) = alg.policy n h := by
  (representation (alg.policy n)).choose_spec.2

@[fun_prop]
lemma measurable_algFunction (alg : Algorithm α R) (n : ℕ) :
    Measurable (Function.uncurry (algFunction alg n)) :=
  (representation (alg.policy n)).choose_spec.1

noncomputable
def hist [DecidableEq α] (alg : Algorithm α R) (ω : ℕ → (I × (α × R))) (n : ℕ) : Iic n → α × R
| 0 => fun _ ↦ (initAlgFunction alg (ω 0).1, (ω 0).2)
| n + 1 =>
  let hn : Iic n → α × R := fun i ↦ (ω i).1
  let a : α := algFunction alg n hn (ω (n + 1)).1
  fun i ↦ if hin : i ≤ n then hn ⟨i, by simp [hin]⟩ else (a, (ω (n + 1)).2)

lemma hasLaw_action_zero (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] :
    HasLaw (action alg 0) alg.p0 (arrayMeasure ν) where
  map_eq := by
    calc (arrayMeasure ν).map (fun ω ↦ initAlgFunction alg (ω 0).1)
    _ = ((arrayMeasure ν).fst.map (Function.eval 0)).map (initAlgFunction alg) := by
      rw [Measure.fst, Measure.map_map (by fun_prop) (by fun_prop),
        Measure.map_map (by fun_prop) (by fun_prop)]
      rfl
    _ = (volume : Measure I).map (initAlgFunction alg) := by
      simp only [arrayMeasure, Measure.fst_prod]
      rw [(measurePreserving_eval_infinitePi (fun _ ↦ volume) 0).map_eq]
    _ = alg.p0 := by
      rw [initAlgFunction_map]

lemma hasLaw_action (alg : Algorithm α R) (n : ℕ) (ν : Kernel α R) [IsMarkovKernel ν] :
    HasLaw (action alg n) (fun i ↦ ν ((fun x ↦ x.1) (fun _ ↦ (initAlgFunction alg i, (ν i) (initAlgFunction alg i)))) := by
  sorry

lemma hasLaw_reward (alg : Algorithm α R) (n : ℕ) (ν : Kernel α R) [IsMarkovKernel ν] :
    HasLaw (reward alg n) (fun i ↦ (ν ((fun x ↦ x.1) (fun _ ↦ (initAlgFunction alg i, (ν i) (initAlgFunction alg i)))) 0) := by
  sorry

lemma hasCondDistrib_reward_zero (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] :
    HasCondDistrib (reward alg 0) (action alg 0) (fun i ↦ ν ((fun x ↦ x.1) (fun _ ↦ (initAlgFunction alg i, (ν i) (initAlgFunction alg i)))) (arrayMeasure ν) where
  condDistrib_eq := by
    refine (condDistrib_ae_eq_cond (by fun_prop) (by fun_prop)).trans ?_
    rw [Filter.EventuallyEq, ae_iff_of_countable]
    intro a ha
