    apply Measureable.mem
    simp
  have hg : Measureable (fun (x : ℕ → α × R) ↦ @Bandits.ArrayModel.hist α R mα mR inst✝⁶ inst✝⁵ inst✝⁴ alg x n) := by
    apply Measureable.mem
    intro x
    apply measurable_hist
    all_goals simp
  have h3 : ∀ x y, x ∈ Set.range (fun (ω : ℕ → I) ↦ ω (n + 1)) → y ∈ Set.range (fun (x : ℕ → α × R) ↦ @Bandits.ArrayModel.hist α R mα mR inst✝⁶ inst✝⁵ inst✝⁴ alg x n) →
    (arrayMeasure ν) ((fun (ω : ℕ → I) ↦ ω (n + 1)) ⁻¹' {x}) ∩ (@Bandits.ArrayModel.hist α R mα mR inst✝⁶ inst✝⁵ inst✝⁴ alg · n) ⁻¹' {y}
      = (arrayMeasure ν) ((fun (ω : ℕ → I) ↦ ω (n + 1)) ⁻¹' {x}) * (arrayMeasure ν) (@Bandits.ArrayModel.hist α R mα mR inst✝⁶ inst✝⁵ inst✝⁴ alg · n) ⁻¹' {y}) := by
    intro x hx y hy
    simp at hx hy
    simp
    <;> try { 
      simp_all [Set.mem_preimage, Set.mem_singleton_iff, Set.mem_setOf_eq]
      <;> try { 
        rw [← Measure.map_apply (by fun_prop)]
        simp
      }
      <;> try { 
        rw [← Measure.map_apply (by fun_prop)]
        simp
      }
    }
    <;> try { 
      simp_all [Set.mem_preimage, Set.mem_singleton_iff, Set.mem_setOf_eq]
      <;> try { 
        rw [← Measure.map_apply (by fun_prop)]
        simp
      }
      <;> try { 
        rw [← Measure.map_apply (by fun_prop)]
