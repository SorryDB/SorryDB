    calc ((arrayMeasure ν)[|action alg 0 ⁻¹' {a}]).map (fun ω ↦ ω 0 2)
    _ = ((arrayMeasure ν)[|action alg 0 ⁻¹' {a}]).map (fun ω ↦ ω 0 2) := by rfl
    _ = (volume : Measure I).map (fun x ↦ (ν a) 0) := by
      rw [Measure.snd, Measure.map_map (by fun_prop) (by fun_prop)]
      simp only [arrayMeasure, Measure.fst_prod]
