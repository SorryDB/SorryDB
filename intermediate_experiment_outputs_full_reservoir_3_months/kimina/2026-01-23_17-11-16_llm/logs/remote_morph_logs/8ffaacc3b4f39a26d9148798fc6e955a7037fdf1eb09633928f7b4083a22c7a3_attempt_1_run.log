lemma independent_of_finite_past {α R : Type*} [MeasurableSpace α] [MeasurableSpace R]
    [Nonempty α] [StandardBorelSpace α] [Nonempty R] [StandardBorelSpace R] (ν : Kernel α R)
    [IsMarkovKernel ν] {n : ℕ} {f : α × R → S} {g : (Iic n → α × R) → T} [Measurable f] [Measurable g]
