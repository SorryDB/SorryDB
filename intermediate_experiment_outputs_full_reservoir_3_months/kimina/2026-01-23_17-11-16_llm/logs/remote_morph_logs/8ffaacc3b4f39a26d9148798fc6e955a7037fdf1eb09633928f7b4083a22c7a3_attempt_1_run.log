open Real

noncomputable
def banditMeasure (ν : Kernel α R) : Measure (ℕ → I) :=
  (Measure.infinitePi fun _ ↦ volume)

noncomputable
def arrayMeasure (ν : Kernel α R) : Measure (ℕ → α × R) :=
  (Measure.infinitePi fun _ ↦ volume).prod (fun _ ↦ ν)

noncomputable
def banditEnv (ν : Kernel α R) : Measure (ℕ → I × (α × R)) :=
  (Measure.infinitePi fun _ ↦ volume).prod (fun _ ↦ ν.map (fun x ↦ (x, 0)) )

noncomputable
def stationaryEnv (ν : Kernel α R) : Measure (ℕ → α × R) :=
  (Measure.infinitePi fun _ ↦ volume).prod (fun _ ↦ ν)

noncomputable
def action (n : ℕ) (ω : ℕ → α × R) : α :=
  (fun i : ℕ ↦ ω i).choose n

noncomputable
def reward (n : ℕ) (ω : ℕ → α × R) : R :=
  (fun i : ℕ ↦ ω i).choose (n + 1) |>.2

noncomputable
def state (n : ℕ) (ω : ℕ → α × R) : α × R :=
  (fun i : ℕ ↦ ω i).choose (n)

lemma action_zero (n : ℕ) : action 0 = fun ω ↦ (ω 0).1 := by rfl

lemma reward_zero (n : ℕ) : reward 0 = fun ω ↦ (ω 0).2 := by rfl

lemma state_zero (n : ℕ) : state 0 = fun ω ↦ (ω 0) := by rfl

lemma action_succ (n : ℕ) : action (n + 1) = fun (ω : ℕ → α × R) ↦ (ω n).1 := by
  rfl

lemma reward_succ (n : ℕ) : reward (n + 1) = fun (ω : ℕ → α × R) ↦ (ω n).2 := by
  rfl

lemma state_succ (n : ℕ) : state (n + 1) = fun (ω : ℕ → α × R) ↦ (ω n) := by
  rfl

lemma action_eq (n : ℕ) : action n = fun (ω : ℕ → α × R) ↦ (ω n).1 := by
  cases n with
  | zero => exact action_zero
  | succ n => exact action_succ n

lemma reward_eq (n : ℕ) : reward n = fun (ω : ℕ → α × R) ↦ (ω n).2 := by
  cases n with
  | zero => exact reward_zero
  | succ n => exact reward_succ n

lemma state_eq (n : ℕ) : state n = fun (ω : ℕ → α × R) ↦ (ω n) := by
  cases n with
  | zero => exact state_zero
  | succ n => exact state_succ n

