lemma sum_of_prod {X : Type*} [CommSemiring X] (f : ℕ → X) (m n : ℕ) :
  ∑ i ∈ range (m * n), f i =
    ∑ j ∈ range m, ∑ k ∈ range n, f (j + k * m) := by
  induction' m with m hm
  simp
  sorry
