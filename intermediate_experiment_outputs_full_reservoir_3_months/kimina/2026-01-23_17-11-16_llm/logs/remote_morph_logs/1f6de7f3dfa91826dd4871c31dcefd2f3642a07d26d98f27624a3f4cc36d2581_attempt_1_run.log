/-- The condition on functions in the problem. -/
def Bonza (f : ℕ+ → ℕ+) : Prop := ∀ a b : ℕ+, (f a : ℤ) ∣ (b ^ (a : ℕ) : ℤ) - (f b ^ (f a : ℕ) : ℤ)

/-- The answer to be determined. -/
def answer : ℝ := 1

theorem result : IsLeast {c : ℝ | ∀ f : ℕ+ → ℕ+, Bonza f → ∀ n, f n ≤ c * n}
    answer := by
  constructor
  · -- Show that 1 is in the set
    intro f hf
    intro n
    have h1 : f 1 = 1 := by
      have h1 := hf 1 1
      simp at h1
      have h2 : f 1 ≥ 1 := by
        apply Nat.one_le_of_lt
        exact Nat.succ_pos 0
      have h3 : f 1 ≤ 1 := by
        by_contra h
        push_neg at h
        have h4 : f 1 ^ f 1 > 1 := by
          have h5 : f 1 ≥ 2 := by omega
          have h6 : f 1 ^ f 1 ≥ 2 ^ 1 := by
            apply Nat.pow_le_pow_of_le_left
            all_goals omega
          have h7 : 2 ^ 1 = 2 := by norm_num
          have h8 : f 1 ^ f 1 ≥ 2 := by linarith [h6, h7]
          omega
        have h4' : (1 : ℤ) - (f 1 : ℤ) ^ (f 1 : ℤ) < 0 := by
          omega
        have h5 : (f 1 : ℤ) ∣ (1 : ℤ) - (f 1 : ℤ) ^ (f 1 : ℤ) := by
          exact h1
        have h6 : (f 1 : ℤ) ≤ (1 : ℤ) - (f 1 : ℤ) ^ (f 1 : ℤ) := by
          apply Int.le_of_dvd (by omega) h5
        omega
      omega
    have h5 : f n ≤ n := by
      have h6 := hf n 1
      simp [h1] at h6
      all_goals
        try { 
          have h7 : (f n : ℝ) ≤ (n : ℝ) := by
            exact_mod_cast (show f n ≤ n by
              have h8 : f n ≤ n := by
                have h9 := h6
                norm_num at h9 ⊢
                all_goals omega
              exact h8
            )
          exact_mod_cast h7
        }
        try { tauto }
    norm_num at h5 ⊢
    all_goals
      try { exact_mod_cast h5 }
      try { tauto }
  · -- Show that 1 is the least element
    intro c hc
    have h2 := hc (fun n => n) (by
      intro a b
      simp
      <;> ring_nf <;> omega
    )
    have h3 := h2 1
    norm_num at h3 ⊢
    all_goals
      try { linarith }
      try { tauto }
