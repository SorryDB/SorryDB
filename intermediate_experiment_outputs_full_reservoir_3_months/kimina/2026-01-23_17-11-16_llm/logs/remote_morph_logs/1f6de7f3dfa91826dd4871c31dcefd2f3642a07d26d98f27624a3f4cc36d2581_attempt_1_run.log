    have h1 : ∀ a b : ℕ+, (f a : ℤ) ∣ (b ^ (a : ℕ) : ℤ) - (f b ^ (f a : ℕ) : ℤ) := hf
    have h2 := h1 n n
    have h3 : (f n : ℤ) ∣ (n ^ (n : ℕ) : ℤ) - (f n ^ (f n : ℕ) : ℤ) := by
      simpa using h2
    by_contra h
    push_neg at h
    have h4 : (f n : ℤ) > (n : ℤ) := by
      exact_mod_cast h
    have h5 : (f n : ℤ) ^ (f n : ℕ) > (n : ℤ) ^ (f n : ℕ) := by
      have h6 : (f n : ℤ) > (n : ℤ) := h4
      have h7 : (f n : ℤ) ≥ 1 := by
        have h8 : (f n : ℤ) ≥ 1 := by
          have h9 : f n ≥ 1 := by
            apply Nat.succ_le_of_lt
            exact Nat.one_lt_of_lt h
          exact_mod_cast h9
        linarith
      have h8 : (n : ℤ) ≥ 1 := by
        have h9 : n ≥ 1 := by
          exact Nat.one_le_of_lt h
        exact_mod_cast h9
      have h9 : (f n : ℤ) ^ (f n : ℕ) > (n : ℤ) ^ (f n : ℕ) := by
        apply pow_lt_pow_left
        all_goals linarith
      linarith
    have h6 : (n : ℤ) ^ (f n : ℕ) - (f n : ℤ) ^ (f n : ℕ) < 0 := by
      linarith
    have h7 : (f n : ℤ) > 0 := by
      have h8 : f n ≥ 1 := by
        apply Nat.succ_le_of_lt
        exact Nat.one_lt_of_lt h
      exact_mod_cast h8
    have h8 : (f n : ℤ) ∣ (n ^ (f n : ℕ) : ℤ) - (f n ^ (f n : ℕ) : ℤ) := h3
    have h9 : (n ^ (f n : ℕ) : ℤ) - (f n ^ (f n : ℕ) : ℤ) ≥ 0 := by
      apply Int.le_of_dvd (by linarith) h8
    linarith
  · -- Show that 1 is the least such value.
