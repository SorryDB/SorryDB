  theorem idx_in_vec {v : Vector α n} {x : α} (hidx : ∃ i : Fin n, v[i] = x) :
     x ∈ v := by sorry

  theorem vec_set_concat_perm {v : Vector (List α) n} {idx : Fin n} {l : List α} {elt : α} :
    v.toList.flatten.Perm l →
    (v.set idx (v[idx] ++ [elt])).toList.flatten.Perm (l ++ [elt]) := by
      sorry

  theorem vec_set_map {α β} {v : Vector α n} {idx : Fin n} {elt : α}
    {f : (idx : Nat) → α → (idx < n) → β} :
    (v.set idx elt).mapFinIdx f = (v.mapFinIdx f).set idx (f idx.1 elt idx.2) := by
      sorry

  theorem vec_set_toList {v : Vector α n} {idx : Fin n} {elt : α} :
    (v.set idx elt).toList = v.toList.set idx elt := by
      sorry

  theorem list_insertIdx_length {l1 l2 : List α} {idx : Nat} {hidx : idx <= l1.length}
    {l1 : List α} {elt : α} :
    (l1 ++ l2).insertIdx idx elt = (l1.insertIdx idx elt) ++ l2
    := by
      induction l1 generalizing idx hidx with
      | nil =>
        -- from the fact idx <= l1.length = [].length
        have : idx = 0 := by sorry
        subst idx
        simp
      | cons hd tl HR =>
        simp
        sorry

  theorem list_set_sum {l : List Nat} {idx : Nat} {e : Nat} (hidx : idx < l.length := by simpa) :
    (l.set idx e).sum = l.sum - l[idx] + e := by
      induction l with
      | nil => contradiction
      | cons hd tl HR =>
        simp at hidx ⊢
        rw [Nat.add_sub_cancel_left]
        apply HR
        simpa using hidx
