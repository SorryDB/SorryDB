      have eq1 : ((hd :: tl).set (Nat.succ (idx - 1)) e).sum = ((hd :: tl).set (Nat.succ (idx - 1)) e).sum := by rfl
      have eq2 : ((hd :: tl).set (Nat.succ (idx - 1)) e).sum = (hd + (tl).sum - (tl).get (Nat.succ (idx - 1)) + e) := by 
