theorem list_set_sum {l : List Nat} {idx : Nat} {e : Nat} (hidx : idx < l.length := by simpa) :
    (l.set idx e).sum = l.sum - l[idx] + e := by 
  induction l with 
  | nil => 
    cases idx with 
    | zero => 
      simp at hidx
    | succ n => 
      simp at hidx
  | cons hd tl HR =>
    cases Nat.eq_or_lt_of_le hidx with
    | inl h => 
      rw [h]
      simp [List.sum_cons, List.get_cons]
      <;> omega
    | inr h => 
      have h1 : (Nat.succ (idx - 1) : Nat) < (hd :: tl).length := by 
