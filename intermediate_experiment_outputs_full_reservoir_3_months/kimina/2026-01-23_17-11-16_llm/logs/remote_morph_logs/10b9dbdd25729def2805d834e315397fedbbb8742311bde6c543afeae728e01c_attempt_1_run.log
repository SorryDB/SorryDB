        have eq3 : ((hd :: tl).set (Nat.succ (idx - 1)) e).get (Nat.succ (idx - 1)) = (tl).get (Nat.succ (idx - 1)) := by 
          simp [List.get_cons]
          <;> omega
        simp [eq3]
        <;> omega
      have eq3 : (hd + (tl).sum - (tl).get (Nat.succ (idx - 1)) + e) = (hd + (tl).sum - (tl).get (Nat.succ (idx - 1)) + e) := by rfl
      have eq4 : ((hd :: tl).sum - (hd :: tl).get (Nat.succ (idx - 1)) + e) = (hd + (tl).sum - (tl).get (Nat.succ (idx - 1)) + e) := by 
        simp [List.sum_cons, List.get_cons]
        <;> omega
      rw [eq4]
      <;> omega
