      -- The right side is (hd + tl).sum - (hd + tl)[idx] + e = (hd + tl).sum - hd + e = (tl.sum + hd) - hd + e = tl.sum + e
      -- From h1: (tl.set (idx - 1) e).sum = tl.sum - tl[idx - 1] + e
      -- So we need to prove: hd + (tl.sum - tl[idx - 1] + e) = tl.sum + e
