      -- We need to prove: (hd :: tl).set 0 e).sum = (hd :: tl).sum - (hd :: tl)[0] + e
      -- The left side is (e :: tl).sum = e + tl.sum
      -- The right side is (hd + tl).sum - hd + e = (tl.sum + hd) - hd + e = tl.sum + e
      -- So we need e + tl.sum = tl.sum + e, which is true by commutativity of addition
      rw [h_eq0]
      simp [List.sum_cons, List.get_cons]
      all_goals omega
    | inr h_gt0 =>
      -- Case where `1 ≤ idx` (for the new `l = hd :: tl`)
      -- We need to apply the induction hypothesis to `tl` with index `idx - 1`
