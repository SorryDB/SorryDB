```lean
import Mathlib

theorem list_set_sum {l : List Nat} {idx : Nat} {e : Nat} (hidx : idx < l.length := by simpa) :
    (l.set idx e).sum = l.sum - l[idx] + e := by
  induction l with
  | nil =>
    exfalso
    simpa using hidx
  | cons hd tl HR =>
    simp at hidx ⊢
    by_cases h : idx = 0
    · -- Case where the index is 0
      rw [h]
      simp [List.set_zero, List.sum_cons, List.get?_cons]
      all_goals omega
    · -- Case where the index is greater than 0
      have h'' : idx > 0 := by
        omega
      have h''' : idx - 1 < tl.length := by
        omega
      have eq1 : (tl.set (idx - 1) e).sum = tl.sum - tl[(idx - 1)] + e := by
        apply HR
        all_goals omega
      have eq2 : (hd :: tl).set idx e = hd :: (tl.set (idx - 1) e) := by
        rw [List.set]
        all_goals
          simp [h'', h''', Nat.add_sub_cancel]
          all_goals omega
      rw [eq2]
      simp [List.sum_cons, eq1]
      all_goals
        simp [List.get?_cons, h'', h''', Nat.add_sub_cancel]
        all_goals omega
