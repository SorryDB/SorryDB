  map_id Y := by
    rw [← F.map_id]
    congr
  map_comp f g := by
    rw [← F.map_comp]
    congr
    rw [comp_id]

-- definition 1.3.13
def Hom_bifunctor (α : Type*) [C : Category α] : Functor (Opposite α × α) Type where
  -- without the C. qualification Lean picks up C.opp.Hom and hilarity ensues
  F X := C.Hom X.1 X.2
  homF {X Y} f g := f.1 ≫ g ≫ f.2
  map_id X := by
    funext g
    simp [Category.id]
    rw [id_comp]
    rw [comp_id]
  map_comp f g := by
    funext h
    simp [comp]
    repeat rw [assoc]

-- definition 1.3.14
def CompFunctor (C D E : Category) (F : C → D) (G : D → E) : C → E where
  F := fun X => G F X
  homF {X Y} f := G (F f)
  map_id X := by
    simp [F.map_id, G.map_id]
  map_comp f g := by
    simp [F.map_comp, G.map_comp]

-- the goal is to show that comp F G is a functor from Opposite (C × D) to E
-- but comp F G is a functor from C to E
-- this is a contradiction
