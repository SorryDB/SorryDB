  map_comp {X Y Z : α} (f : C.Hom X Y) (g : C.Hom Y Z) :
    homF (f ≫ g) = homF g ≫ homF f

-- Composition of contravariant functors
def comp {α β γ : Type*} [C : Category α] [D : Category β] [E : Category γ]
    (F : ContravariantFunctor α β) (G : ContravariantFunctor β γ) :
    ContravariantFunctor α γ where
  -- The map on objects is the composition of the maps on objects
  F := fun x => F.F (G.F x)
  -- The map on morphisms needs to be defined carefully
  homF {X Y : α} f := F.homF (G.homF f)
  -- Verify the map_id property
  map_id X := by
    rw [F.map_id, G.map_id]
    all_goals simp
  -- Verify the map_comp property
  map_comp f g := by
    -- We need to show that `comp.map_comp (f ≫ g) = comp.map_comp g ∘ comp.map_comp f`
