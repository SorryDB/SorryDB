    (F : Functor α β) (G : Functor β γ) : Functor α γ where
  F x := G.F (F.F x)
  homF f := G.homF (F.homF f)
  map_id X := by simp only [comp]; rfl -- Assuming comp is defined as a structure
  map_comp f g := by
    rw [← F.map_comp]
    apply G.map_comp

