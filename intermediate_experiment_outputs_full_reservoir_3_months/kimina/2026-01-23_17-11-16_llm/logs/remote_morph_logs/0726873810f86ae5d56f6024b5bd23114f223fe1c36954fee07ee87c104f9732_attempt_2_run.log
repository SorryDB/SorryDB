import Mathlib

/-!
# Composition of Contravariant Functors

We need to prove that the composition of two contravariant functors is also contravariant.
-/

namespace ContravariantFunctor

-- Contravariant functors definition
class ContravariantFunctor (α β : Type*) [C : Category α] [D : Category β] where
  -- map on objects
  F : α → β
  -- map on morphisms
  homF {X Y : α} : C.Hom X Y → D.Hom (F Y) (F X)
  -- properties / laws
  -- need to qualify id to avoid clash with id in root namespace.
  map_id (X : α) : homF (id X) = Category.id (F X)
  map_comp {X Y Z : α} (f : C.Hom X Y) (g : C.Hom Y Z) :
    homF (f ≫ g) = homF g ≫ homF f

-- Composition of two contravariant functors
def CompContravariantFunctor {α β γ : Type*} [C : Category α] [D : Category β] [E : Category γ]
    (F : ContravariantFunctor α β) (G : ContravariantFunctor β γ) :
    ContravariantFunctor α γ :=
  {
    F := fun x => G.F (F.F x)
    homF => fun {X Y} f => G.homF (F.homF f)
    map_id => fun X => G.map_id (F.map_id X)
    map_comp => fun f g => G.map_comp (F.map_comp f g)
  }
```

Now we need to prove that this is indeed a contravariant functor. The definition is given, so we need to verify all the properties.

