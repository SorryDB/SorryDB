    -- RHS: `comp.map_comp g ∘ comp.map_comp f = F.comp.mapF (G.comp.mapF g) ∘ F.comp.mapF (G.comp.mapF f)`
    -- These are equal.
    rw [F.map_comp, G.map_comp]
