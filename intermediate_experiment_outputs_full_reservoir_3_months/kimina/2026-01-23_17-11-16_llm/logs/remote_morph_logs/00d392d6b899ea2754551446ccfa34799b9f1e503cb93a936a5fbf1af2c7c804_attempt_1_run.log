import Mathlib

open TopologicalSpace Filter Finset

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

noncomputable abbrev Distribution := 𝓓^{n}(Ω, ℝ) →L_c[ℝ] F

