theorem fderivCLM_linearity : ∀ (T : 𝓓'(Ω, F)), ∀ (v₁ v₂ : E),
    lineDerivCLM (v₁ + v₂) T = lineDerivCLM v₁ T + lineDerivCLM v₂ T := by
  intro T v₁ v₂
  have h1 : ∀ (f : TestFunction Ω ℝ), lineDerivCLM (v₁ + v₂) T f =
      (lineDerivCLM v₁ T + lineDerivCLM v₂ T) f := by
    intro f
    have h2 : lineDerivCLM (v₁ + v₂) T f = T (- TestFunction.lineDerivCLM (v₁ + v₂) f) := by
      apply lineDerivCLM_apply
    have h3 : (lineDerivCLM v₁ T + lineDerivCLM v₂ T) f =
        T (- TestFunction.lineDerivCLM v₁ f) + T (- TestFunction.lineDerivCLM v₂ f) := by
      simp [add_apply]
      <;> try { tauto }
      <;> try { aesop }
    rw [h2, h3]
    have h4 : TestFunction.lineDerivCLM (v₁ + v₂) f = TestFunction.lineDerivCLM v₁ f + TestFunction.lineDerivCLM v₂ f := by
      simp [TestFunction.lineDerivCLM]
      <;> try { tauto }
      <;> try { aesop }
    have h5 : T (- (TestFunction.lineDerivCLM v₁ f + TestFunction.lineDerivCLM v₂ f)) =
        T (- TestFunction.lineDerivCLM v₁ f) + T (- TestFunction.lineDerivCLM v₂ f) := by
      simp [T.neg_apply]
      <;> try { tauto }
      <;> try { aesop }
    have h6 : T (- TestFunction.lineDerivCLM (v₁ + v₂) f) =
