lemma mem_trans [Entailment.HasAxiomI L] (hÔéü : ¤ć Ô×Ł ¤ł Ôłł T.theory) (hÔéé : ¤ł Ô×Ł ¤ç Ôłł T.theory) : ¤ć Ô×Ł ¤ç Ôłł T.theory := by
  apply T.imp_closed (axiomI (¤ł := ¤ł));
