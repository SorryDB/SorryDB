@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (h¤ć : ¤ć Ôłł T.theory) : ¤ć ÔőÄ ¤ł Ôłł T.theory := by
  apply T.imp_closed (¤ć := ¤ć);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (h¤ł : ¤ł Ôłł T.theory) : ¤ć ÔőÄ ¤ł Ôłł T.theory := by
  apply T.imp_closed (¤ć := ¤ł);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ¤ć Ôłł T.theory Ôćö Deduction Ax T.theory ¤ć := by
  constructor;
  . intro h¤ć;
    apply Deduction.ctx h¤ć;
  . intro h; induction h <;> grind

end FTheory


