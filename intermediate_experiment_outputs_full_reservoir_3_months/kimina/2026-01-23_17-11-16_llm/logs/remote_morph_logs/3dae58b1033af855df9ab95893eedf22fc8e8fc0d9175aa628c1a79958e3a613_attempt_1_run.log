lemma finSupport_uniformSelectMatrix [DecidableEq α] {α : Type} [Fintype α] (n m : ℕ) (s : Matrix (Fin n) (Fin m) α) :
    ($ s).finSupport = (s.toList.map (fun l ↦ l.head!) |>.map (fun x ↦ x)).toFinset := by
