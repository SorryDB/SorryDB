    HasUniformSelect (Mathlib.Vector α (n + 1)) α where
  uniformSelect xs := $ xs.toList

lemma uniformSelectVector_def {α : Type} {n : ℕ} (xs : Vector α (n + 1)) :
    ($ xs) = ($ xs.toList) := rfl

