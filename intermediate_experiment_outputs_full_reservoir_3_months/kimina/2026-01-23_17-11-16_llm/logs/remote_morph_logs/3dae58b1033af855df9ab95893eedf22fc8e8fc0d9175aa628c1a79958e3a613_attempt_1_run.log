    exact congrFun (congrArg HMul.hMul (ih x.pop y.pop)) Pr[= y.back | SampleableType.selectElem]
  probFailure_selectElem := by
    stop
    induction n with
    | zero => simp
    | succ m ih => simp [ih, probFailure_seq, probFailure_pure, probFailure_ite]
    sorry

