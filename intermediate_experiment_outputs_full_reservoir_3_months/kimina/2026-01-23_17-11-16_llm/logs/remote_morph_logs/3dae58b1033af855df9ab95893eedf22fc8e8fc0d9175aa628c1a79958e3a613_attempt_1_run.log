/-- Select uniformly from `α × β` using a type-class provided definition.
NOTE: naming is somewhat strange now that `Fintype` isn't explicitly required. -/
def uniformSampleProduct (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] :
    ProbComp (α × β) := (·, ·) <$> (uniformSample α) <*> (uniformSample β)

@[simp] lemma selectElem_eq_uniformSampleProduct {α β : Type} [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] : (α × β).selectElem = uniformSampleProduct α β := rfl

@[simp] lemma mem_support_uniformSampleProduct {α β : Type} [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] (x : α × β) : x ∈ support uniformSampleProduct α β := by
  simp only [selectElem_eq_uniformSampleProduct, SampleableType.mem_support_selectElem]

@[simp] lemma probOutput_uniformSampleProduct {α β : Type} [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] (x : α × β) :
    Pr[= x | uniformSampleProduct α β] = (1 / Fintype.card α) * (1 / Fintype.card β) := by
  simp only [selectElem_eq_uniformSampleProduct, SampleableType.probOutput_selectElem_eq]

@[simp] lemma probFailure_uniformSampleProduct {α β : Type} [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] :
    Pr[⊥ | uniformSampleProduct α β] = 0 := by
  simp only [selectElem_eq_uniformSampleProduct, SampleableType.probFailure_selectElem]

@[simp] lemma evalDist_uniformSampleProduct {α β : Type} [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β] :
