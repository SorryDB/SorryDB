    ($ s) = ($ s.toList.map (fun l ↦ l.head!) |>.map (fun x ↦ x) : ProbComp α) := by
  simp [uniformSelectMatrix_def]

lemma evalDist_uniformSelectMatrix {α : Type} [Fintype α] (n m : ℕ) (s : Matrix (Fin n) (Fin m) α) :
    evalDist ($ s) = (PMF.uniformSample (Fin (n * m))).map (s.getElem) := by
  simp [uniformSelectMatrix_def]

lemma support_uniformSelectMatrix {α : Type} [Fintype α] (n m : ℕ) (s : Matrix (Fin n) (Fin m) α) :
    ($ s).support = {x | x ∈ s.toList.map (fun l ↦ l.head!) |>.map (fun x ↦ x)} := by
