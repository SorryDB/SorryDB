    intro x hx y hy h_eq
    have hx1 : x ∈ A := by
      simpa using hx.1
    have hy1 : y ∈ A := by
      simpa using hy.1
    have h_inj : x = y := by
      apply h1
      all_goals
        try { tauto }
        try { aesop }
    exact h_inj
