lemma remove_one_equinum
    {U V : Type} {A : Set U} {B : Set V} {a : U} {b : V} {f : U → V}
    (h1 : one_one_on f A) (h2 : image f A = B)
    (h3 : a ∈ A) (h4 : f a = b) : ↑(A \ {a}) ∼ ↑(B \ {b}) := by
  have h5 : ∀ x ∈ A \ {a}, f x ∈ B \ {b} := by
    intro x hx
    have hx1 : x ∈ A := by
      simp at hx ⊢
      tauto
    have hx2 : x ≠ a := by
      simp at hx ⊢
      tauto
    have hfx1 : f x ∈ B := by
      rw [show B = image f A by rw [h2]]
      exact ⟨x, hx1⟩
    have hfx2 : f x ≠ b := by
      have hne : f a = b := by
        exact h4
      have h11 : ∀ x1 x2 : U, x1 ∈ A → x2 ∈ A → (f x1 = f x2) → x1 = x2 := by
        intro x1 x2 hx1 hx2 heq
        apply h1
        all_goals
          try { tauto }
          try { aesop }
      by_contra h
      have h12 : f x = f a := by
        rw [h]
        all_goals
          try { tauto }
          try { rw [h4] }
          try { tauto }
      have h13 : x = a := by
        apply h11 x a hx1 (show a ∈ A by tauto) h12
      contradiction
    exact ⟨hfx1, hfx2⟩
  have h6 : Set.Equij (A \ {a}) (B \ {b}) := by
    apply Set.equiv_of_bijective
    constructor
    · -- injective
      intro x hx y hy heq
      simp at hx hy
      have hx1 : x ∈ A := by tauto
      have hy1 : y ∈ A := by tauto
      have h11 : ∀ x1 x2 : U, x1 ∈ A → x2 ∈ A → (f x1 = f x2) → x1 = x2 := by
        intro x1 x2 hx1 hx2 heq
        apply h1
        all_goals
          try { tauto }
          try { aesop }
      have h12 : x = y := by
        apply h11 x y hx1 hy1 heq
      tauto
    · -- surjective
      intro y hy
      simp at hy
      have hy1 : y ∈ B := by tauto
      have hy2 : y ≠ b := by tauto
      rw [show B = image f A by rw [h2]] at hy1
      rcases hy1 with ⟨x, hx⟩
      have hx1 : x ∈ A := by
        simpa using hx
      have hx2 : x ≠ a := by
        by_contra h
        have h1 : f x = b := by
          rw [h]
          all_goals
            try { tauto }
            try { rw [h4] }
            try { tauto }
        have h2 : f x = y := by
          simpa using hx
        have h3 : y = b := by
          linarith
        tauto
      simp
      all_goals
        try { tauto }
        try { tauto }
  exact h6
