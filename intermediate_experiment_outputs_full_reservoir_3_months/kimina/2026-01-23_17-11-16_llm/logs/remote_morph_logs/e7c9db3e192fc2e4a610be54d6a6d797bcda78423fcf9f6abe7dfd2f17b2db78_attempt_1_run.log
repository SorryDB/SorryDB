    have hfx_ne_b : f x ≠ b := by
      intro h_eq
      have h_eq2 : f x = f a := by
        rw [h_eq, h4]
      have h_inj : x = a := by
        apply h1
        all_goals
          try { tauto }
          try { aesop }
      contradiction
    exact ⟨hfx, hfx_ne_b⟩
