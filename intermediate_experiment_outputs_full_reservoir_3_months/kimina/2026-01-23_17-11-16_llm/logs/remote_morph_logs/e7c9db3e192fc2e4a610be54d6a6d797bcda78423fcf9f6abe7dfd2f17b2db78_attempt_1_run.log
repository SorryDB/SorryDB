/- Definition of image of a set under a function -/
def image (f : α → β) (s : Set α) : Set β := {y | ∃ x ∈ s, f x = y}

/- Theorem: If f is a bijection from A to B, then the image of A under f is equal to B -/
theorem image_eq_set_of_bijection {U V : Type} {A : Set U} {B : Set V} {f : U → V}
    (h : Set.BijOn f A B) : image f A = B := by
```

