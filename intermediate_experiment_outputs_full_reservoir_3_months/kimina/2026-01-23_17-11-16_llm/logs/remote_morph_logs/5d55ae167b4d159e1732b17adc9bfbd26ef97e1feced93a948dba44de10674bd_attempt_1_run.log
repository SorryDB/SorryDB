    rw [show f' (f b) = g' y by rw [hk2.2]; all_goals try { simp_all }]
    rw [hxy]
  have h5 : x = y := by
    have h6 : f' x = f' y := by
      rw [show f' x = f' (f a) by rw [ha]; all_goals try { simp_all }]
