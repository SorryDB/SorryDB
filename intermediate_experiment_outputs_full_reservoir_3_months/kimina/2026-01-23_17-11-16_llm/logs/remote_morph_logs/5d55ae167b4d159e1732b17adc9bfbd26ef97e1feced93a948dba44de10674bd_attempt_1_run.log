      dsimp [Cone.extend]
      congr
      ext n
      simp [show k_cone.π.app n = (k_seq n.unop).1 from rfl, (k_seq n).property]
    rw [← hlim]
    apply S.asLimit.uniq (k_cone.extend f)
    intro n
    simp
