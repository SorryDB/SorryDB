  have h3 : y ∈ preimage f {f y} := by
    rw [mem_preimage]
    use y
    all_goals try { simp_all }
    all_goals try { tauto }
  rcases mem_image_of_mem_preimage h2 with ⟨a, ha⟩
  rcases mem_image_of_mem_preimage h3 with ⟨b, hb⟩
  have h4 : f' (f a) = f' (f b) := by
