lemma profinite_key_extension_lemma (X Y S T : Profinite.{u}) [Finite S]
    (f : X ⟶ Y) [Mono f] (f' : S ⟶ T) [Epi f']
    (g : X ⟶ S) (g' : Y ⟶ T) (h_comm : f ≫ g' = g ≫ f') :
    ∃ k : Y ⟶ S, (k ≫ f' = g') ∧ (f ≫ k = g)  := by
  obtain ⟨k_fun, k_cont, h2, h3⟩ := key_extension_lemma X Y S T
