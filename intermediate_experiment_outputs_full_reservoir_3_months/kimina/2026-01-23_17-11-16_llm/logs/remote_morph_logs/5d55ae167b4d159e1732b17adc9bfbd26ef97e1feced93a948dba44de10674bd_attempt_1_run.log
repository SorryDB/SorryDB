import Mathlib

open Topology Filter Set
open scoped BigOperators

/- A light profinite space is a compact, totally disconnected, and nonempty topological space.
  It is equivalent to the inverse limit of a sequence of finite topological spaces. -/
structure LightProfinite (X : Type u) extends Profinite X where
  nonempty : Nonempty X

