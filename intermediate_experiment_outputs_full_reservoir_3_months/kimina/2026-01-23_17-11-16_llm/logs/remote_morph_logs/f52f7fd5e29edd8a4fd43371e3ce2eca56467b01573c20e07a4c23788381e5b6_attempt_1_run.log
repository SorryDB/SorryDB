lemma fderivCLM_apply {T : 𝓓'(Ω, F)} {f : 𝓓(Ω, ℝ)} {v : E} :
    fderivCLM T f v = T (- TestFunction.lineDerivCLM v f) := rfl

-- fderivCLM_zero proves that the map part of fderivCLM is zero for the zero distribution.
lemma fderivCLM_zero {f : 𝓓(Ω, ℝ)} {v : E} :
    fderivCLM (0 : 𝓓'(Ω, F)) f v = 0 := by
  simp [fderivCLM_apply, ofFun, ofFunWithOrder]

-- fderivCLM_add proves additivity of the map part of fderivCLM.
lemma fderivCLM_add {T S : 𝓓'(Ω, F)} {f g : 𝓓(Ω, ℝ)} {v : E} :
    fderivCLM (T + S) f v = fderivCLM T f v + fderivCLM S f v := by
  simp [fderivCLM_apply, lineDerivCLM_apply, TestFunction.lineDerivCLM_add]

-- fderivCLM_smul proves linearity with scalar multiplication for the map part of fderivCLM.
lemma fderivCLM_smul {T : 𝓓'(Ω, F)} {f : 𝓓(Ω, ℝ)} {v : E} {c : ℝ} :
    fderivCLM (c • T) f v = c • fderivCLM T f v := by
  simp [fderivCLM_apply, lineDerivCLM_apply, TestFunction.lineDerivCLM_smul]

