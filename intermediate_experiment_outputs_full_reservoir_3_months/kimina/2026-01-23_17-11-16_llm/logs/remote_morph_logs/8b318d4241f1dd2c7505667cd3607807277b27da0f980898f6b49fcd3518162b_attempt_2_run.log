/-!
This defines the initial factorization used in the proof.
-/

def Erdos392.Factorization (P : Erdos392.Params) : Factorization P.n :=
  { a := (replicate P.M (.Ico (P.n - P.n/P.M) P.n)).join.filter
      (fun m ↦ m ∈ (P.n/P.L).smoothNumbers)
    ha := fun m hm ↦ by
      simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
      obtain ⟨⟨_, ⟨_, rfl⟩, hs⟩, _⟩ := hm
      rw [Multiset.mem_Ico, tsub_le_iff_right] at hs
      have h1 : m ≤ P.n := by linarith
      have h2 : m ≥ P.n - P.n / P.M := by linarith
      have h3 : m ∈ (P.n / P.L).smoothNumbers := by
        simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
        obtain ⟨_, hsm⟩ := hm; tauto
      exact h3
    hpos := fun m hm ↦ by
      simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
      obtain ⟨_, hsm⟩ := hm
      have h1 : m ∈ (P.n / P.L).smoothNumbers := hsm
      have h2 := (mem_smoothNumbers' h1).1
      exact pos_of_ne_zero h2
  }

/-!
This theorem states that the cardinality of the initial factorization is at most n.
-/

theorem Erdos392.card_bound (P : Erdos392.Params) : (Erdos392.Factorization P).a.card ≤ P.n := by
  calc
    (Erdos392.Factorization P).a.card = Multiset.card (filter (fun m ↦ m ∈ (P.n/P.L).smoothNumbers)
        (replicate P.M (Multiset.Ico (P.n - P.n/P.M) P.n)).join) := by rfl
    _ ≤ Multiset.card (replicate P.M (Multiset.Ico (P.n - P.n/P.M) P.n)).join := by
      apply card_le_card
      apply filter_le
    _ = P.M * Multiset.card (Multiset.Ico (P.n - P.n / P.M) P.n) := by
      rw [card_join, map_replicate, sum_replicate, smul_eq_mul]
    _ = P.M * (P.n - (P.n - P.n / P.M)) := by
      congr 1
      simp [Multiset.Ico]
      <;> linarith
    _ = P.M * (P.n / P.M) := by
      congr 1
      exact Nat.sub_sub_self (div_le_self P.n P.M)
    _ ≤ P.n := by
      have h1 : P.M * (P.n / P.M) ≤ P.n := by
        have h2 : P.n / P.M * P.M ≤ P.n := by
          exact Nat.div_mul_le_self P.n P.M
        linarith
