  have hle : (Multiset.map (fun m ↦ m.factorization p) (Multiset.Ico (n - n / M) n)) ≤
      Multiset.map (fun m ↦ if p ∣ m then 1 else 0) (Multiset.Ico (n - n / M) n) := by
