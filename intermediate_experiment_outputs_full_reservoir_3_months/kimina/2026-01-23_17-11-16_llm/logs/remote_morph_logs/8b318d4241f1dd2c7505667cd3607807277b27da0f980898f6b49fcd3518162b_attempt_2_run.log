lemma sum_valuation_le_M_mul_interval_count {n M p : ℕ} (hp' : (p : ℝ) > Real.sqrt n) :
    (Multiset.map (fun m ↦ m.factorization p) (Multiset.Ico (n - n / M) n)).sum ≤
