    exact Multiset.sum_le_sum hle
  calc (Multiset.map (fun m ↦ m.factorization p) (Multiset.Ico (n - n / M) n)).sum
      _ ≤ (Multiset.map (fun m ↦ if p ∣ m then 1 else 0) (Multiset.Ico (n - n / M) n)).sum := hsub
