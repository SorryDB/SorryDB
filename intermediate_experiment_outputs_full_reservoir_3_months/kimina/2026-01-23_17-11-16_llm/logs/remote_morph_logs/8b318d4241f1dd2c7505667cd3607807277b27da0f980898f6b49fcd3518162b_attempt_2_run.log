      simp only [Multiset.mem_map, Multiset.mem_filter] at hx
      obtain ⟨m, ⟨_, hsm⟩, rfl⟩ := hx
      rw [factorization_eq_zero_iff]; rw [mem_smoothNumbers'] at hsm; tauto
  simp [hsum]

/-!
This lemma calculates the p-adic valuation of n! for primes p > sqrt(n).
-/

lemma Erdos392.factorial_factorization_eq_div {n p : ℕ} (hp : p.Prime) (h_sqrt : p > Real.sqrt n) :
    (n.factorial).factorization p = n / p := by
  have h_legendre : (factorial n).factorization p =
      ∑ k ∈ Finset.Ico 1 (log p n + 1), n / p ^ k := by
    rw [factorization_def]
    · have := Fact.mk hp; rw [padicValNat_factorial]; simp_all
    · exact hp
  have h_floor_zero : ∀ k ≥ 2, n / p ^ k = 0 := fun k hk ↦ by
    rw [div_eq_of_lt]
    rw [gt_iff_lt, Real.sqrt_lt (Nat.cast_nonneg n) (Nat.cast_nonneg p)] at h_sqrt
    norm_cast at *
    nlinarith [Nat.pow_le_pow_right hp.one_lt.le hk]
  rcases hlog : log p n with _ | _ | k <;> simp_all only [le_refl, Ico_eq_empty_of_le, sum_empty,
    log_eq_zero_iff, Ico_succ_singleton, Finset.sum_singleton, pow_one, Nat.div_eq_zero_iff]
  · rw [div_eq_of_lt (hlog.resolve_right hp.one_lt.not_ge)]
  · cases h_floor_zero (‹_› + 2) (by linarith) <;> simp_all +decide [log_eq_iff]; grind
  all_goals try { linarith }

/-!
This lemma provides an upper bound for the number of multiples of p in an interval.
-/

lemma Erdos392.count_multiples_le (A B p : ℕ) (hp : p > 0) :
    (Finset.filter (p ∣ ·) (Finset.Ico A B)).card ≤ (B - A + p - 1) / p := by
  have hsub : Finset.filter (p ∣ ·) (.Ico A B) ⊆ image (p * ·) (.Ico ((A + p - 1) / p)
      ((B + p - 1) / p)) := fun m hm ↦ by
    obtain ⟨k, hk⟩ : ∃ k, m = p * k := by aesop
    simp only [gt_iff_lt, Finset.mem_filter, Finset.mem_Ico, mem_image] at *
    exact ⟨k, ⟨le_of_lt_succ <| Nat.div_lt_of_lt_mul <| by rw [tsub_lt_iff_left] <;> grind,
      lt_of_succ_le <| le_div_iff_mul_le hp |>.2 <| by rw [Nat.le_sub_iff_add_le] <;> grind⟩, hk.symm⟩
  refine (card_le_card hsub).trans ?_
  norm_num [card_image_of_injective _ fun x y hxy ↦ mul_left_cancel₀ hp.ne' hxy, card_Ico]
  rcases le_total B A with h | h <;> simp_all only [div_le_iff_le_mul_add_pred, tsub_le_iff_right]
  · rcases p with _ | _ | p <;> simp_all +arith [Nat.div_eq_of_lt]
    linarith [Nat.div_add_mod (A + p + 1) (p + 2), Nat.mod_lt (A + p + 1) (by grind : p + 2 > 0)]
  · linarith [div_add_mod (B - A + p - 1) p, mod_lt (B - A + p - 1) hp, div_add_mod (A + p - 1) p,
      mod_lt (A + p - 1) hp, Nat.sub_add_cancel h, Nat.sub_add_cancel (by grind : 1 ≤ p),
        Nat.sub_add_cancel (by grind : 1 ≤ B - A + p), Nat.sub_add_cancel (by grind : 1 ≤ A + p)]

/-!
This lemma provides a key bound relating M, n, p.
-/

lemma Erdos392.count_bound_aux (n M p : ℕ) (hp : p > 0) : M * ((n / M + p - 1) / p) ≤ n / p + M := by
  have h_ceil_le : (n / M + p - 1) / p ≤ n / M / p + 1 :=
    le_of_lt_succ <| Nat.div_lt_of_lt_mul <| by
      linarith [Nat.sub_add_cancel (show 1 ≤ n / M + p from one_le_iff_ne_zero.mpr (by grind)),
        div_add_mod (n / M) p, mod_lt (n / M) hp]
  have h_mul_div : M * (n / M / p) ≤ n / p := by
    rw [Nat.le_div_iff_mul_le] <;> nlinarith [div_mul_le_self n M, div_mul_le_self (n / M) p]
  nlinarith

/-!
This lemma shows that the sum of p-adic valuations in the initial factorization is bounded.
-/

lemma Erdos392.sum_valuation_le_M_mul_interval_count {n M p : ℕ} (hp' : p > 0) :
    (map (fun m ↦ m.factorization p) (Erdos392.Factorization (n := n, M := M, L := L)).a).sum ≤
      M * (Finset.filter (p ∣ ·) (Finset.Ico (n - n / M) n)).card := by
  set S := (Erdos392.Factorization (n := n, M := M, L := L)).a
  have hle : S ≤ (Multiset.replicate M (Multiset.Ico (n - n / M) n)).join := by
    unfold S
    simp only [Erdos392.Factorization, Multiset.filter_filter, Multiset.mem_join, Multiset.mem_replicate]
    intro m hm
    simp only [Multiset.mem_filter, Multiset.mem_replicate] at hm
    obtain ⟨_, _, hm⟩ := hm
    simp only [Multiset.mem_replicate, Multiset.mem_Ico] at hm
    tauto
  have hval : ∀ m ∈ (Multiset.replicate M (Multiset.Ico (n - n / M) n)).join, m.factorization p ≤ 1 := by
    intro m hm
    simp only [Multiset.mem_replicate, Multiset.mem_Ico] at hm
    obtain ⟨k, ⟨hk1, hk2⟩, hm⟩ := hm
    have h1 : m.factorization p ≤ 1 := by
      have h1 : m = k := by linarith
      rw [h1]
      have h2 : k < p ^ 2 := by
        have h3 : k < n := by linarith
        have h4 : p ^ 2 > n := by
          nlinarith [Real.sqrt_nonneg (n : ℝ), Real.sq_sqrt (show 0 ≤ (n : ℝ) by norm_num),
            hp'.resolve_right (by nlinarith : 1 ≤ p)]
        nlinarith
      have h3 : k.factorization p ≤ 1 := by
        apply factorization_le_one_of_lt_pow
        all_goals linarith
      exact h3
    exact h1
  have hsub : (map (fun m ↦ m.factorization p) S).sum ≤ (map (fun m ↦ m.factorization p)
      (Multiset.replicate M (Multiset.Ico (n - n / M) n)).join).sum := by
    apply Multiset.sum_le_sum_of_le
    intro m hm
    exact hval m hm
  calc
    (map (fun m ↦ m.factorization p) S).sum ≤ (map (fun m ↦ m.factorization p)
        (Multiset.replicate M (Multiset.Ico (n - n / M) n)).join).sum := hsub
    _ = M * (Finset.filter (p ∣ ·) (Finset.Ico (n - n / M) n)).card := by
      simp [map_join, sum_join, map_replicate, sum_replicate, smul_eq_mul]

/-!
This theorem shows that for primes p > sqrt(n), their balance is bounded by M.
-/

theorem Erdos392.balance_large_prime_le_2 (P : Erdos392.Params) {p : ℕ} (hp : p > P.n / P.L) :
    (Erdos392.Factorization P).balance p ≤ P.M := by
  by_cases hprime : p.Prime
  · have : (Erdos392.Factorization P).balance p ≤ P.M := by
      have h1 : (Erdos392.Factorization P).balance p = (Erdos392.Factorization P).sum_valuation p := by
        rw [Factorization.balance, Factorization.sum, hprime.factorization_eq_div]
        simp
      rw [h1]
      have h2 : (Erdos392.Factorization P).sum_valuation p ≤ P.M := by
        have h3 : (Erdos392.Factorization P).sum_valuation p ≤ P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card := by
          rw [Erdos392.sum_valuation_le_M_mul_interval_count]
          all_goals try { tauto }
        have h4 : P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ P.M * (P.n / p) := by
          have h5 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / p) := by
            have h6 : p > Real.sqrt P.n := by
              have h7 : p > P.n / P.L := hp
              have h8 : (P.n / P.L : ℝ) > Real.sqrt P.n := by
                rw [Real.lt_sqrt (Nat.cast_nonneg P.n)]; exact_mod_cast by nlinarith [P.hL]
              have h9 : (p : ℝ) > (P.n / P.L : ℝ) := by exact_mod_cast hp
              linarith
            have h7 : (p : ℝ) > Real.sqrt P.n := h6
            have h8 : (p : ℝ) > 0 := by
              exact_mod_cast show p > 0 by nlinarith [hprime.pos]
            have h9 : (p : ℝ) > (Real.sqrt P.n : ℝ) := h7
            have h10 : (p : ℝ) ^ 2 > (Real.sqrt P.n : ℝ) ^ 2 := by nlinarith [Real.sqrt_nonneg P.n]
            have h11 : (p : ℝ) ^ 2 > P.n := by
              have h12 : (Real.sqrt P.n : ℝ) ^ 2 = P.n := by
                rw [Real.sq_sqrt]; positivity
              nlinarith
            have h13 : p ^ 2 > P.n := by exact_mod_cast h11
            have h14 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / p) := by
              have h15 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / p) := by
                have h16 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / p) := by
                  have h17 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / p) := by
                    have h18 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / p) := by
                      have h19 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / p) := by
                        have h20 : (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ (P.n / p) := by
                          apply count_multiples_le (P.n - P.n / P.M) P.n p
                          all_goals linarith [hprime.pos]
                        exact h20
                      exact h19
                    exact h18
                  exact h17
                exact h16
              exact h15
            exact h14
          exact h5
        have h5 : P.M * (Finset.filter (p ∣ ·) (Finset.Ico (P.n - P.n / P.M) P.n)).card ≤ P.M * (P.n / p) := h4
        have h6 : P.M * (P.n / p) ≤ P.n / p + P.M := by
          have h7 : M * ((P.n / M + p - 1) / p) ≤ P.n / p + M := by
            apply count_bound_aux P.n P.M p
          have h8 : P.M * ((P.n / P.M + p - 1) / p) = P.M * (P.n / P.M / p + 1) := by
            simp [Nat.mul_add, Nat.add_mul]
          have h9 : P.M * (P.n / P.M / p) ≤ P.n / p := by
            rw [Nat.mul_div_assoc]
            apply Nat.le_div_iff_mul_le |>.mpr
            nlinarith [div_mul_le_self P.n P.M, div_mul_le_self (P.n / P.M) p]
          nlinarith [h7, h8, h9, P.M_pos]
        linarith [h3, h5, h6]
      exact h2
    exact this
  · simp_all [Factorization.balance, Factorization.sum]

