class ArchReq where
  (type : Type 0)
  (instBEq : BEq type)
  (instInhabited : Inhabited type)
  (instToString : ToString type)
  (prettyPrint : type → String := instToString.toString)
  (isPermanentRead : type → Bool := λ _ => false)

