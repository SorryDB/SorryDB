  let X₁ i : Ω × Ω → E := X i ∘ Prod.fst
  let X₂ i : Ω × Ω → E := X i ∘ Prod.snd
  let X' i : Ω × Ω → E := X₁ i - X₂ i
  have : DecidableEq ι := Classical.decEq _
  have identDistrib_X'_neg_X' : IdentDistrib (X' i) (-X' i) (μ.prod μ) (μ.prod μ) := by
    rw [show X' i = X i ∘ Prod.fst - X i ∘ Prod.snd by rfl]
    apply identDistrib_neg
  calc
