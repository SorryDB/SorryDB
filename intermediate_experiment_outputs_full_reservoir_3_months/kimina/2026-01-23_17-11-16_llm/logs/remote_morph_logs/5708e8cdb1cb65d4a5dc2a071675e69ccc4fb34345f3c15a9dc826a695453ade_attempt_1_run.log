```lean
import Mathlib.Analysis.Convex.Combination

open AffineMap Finset

section oldVars
variable {ι R E : Type*} [Field R] [LinearOrder R] [IsStrictOrderedRing R] [AddCommGroup E]
  [Module R E] {s : Finset ι} {f : ι → E} {x : E}

lemma mem_convexHull_image :
    x ∈ convexHull R (f '' s) ↔
      ∃ w : ι → R, (∀ i ∈ s, 0 ≤ w i) ∧ ∑ i ∈ s, w i = 1 ∧ s.centerMass w f = x where
  mp hp := by
    classical
    rw [← Subtype.range_val (α := ι) (s := s), ← Set.range_comp,
      convexHull_range_eq_exists_affineCombination] at hp
    obtain ⟨t, w, hw₀, hw₁, rfl⟩ := hp
    refine ⟨w, ?_⟩
    constructor
    · -- Show that ∀ i ∈ s, 0 ≤ w i
      intro i hi
      by_cases h : i ∈ t
      · -- If i ∈ t, then 0 ≤ w i by hw₀
        have h' : i ∈ t := h
        exact hw₀ i h'
      · -- If i ∉ t, we need 0 ≤ w i
        simp at hw₀ ⊢
        <;> try { tauto }
        <;> try { aesop }
    constructor
    · -- Show that ∑ i ∈ s, w i = 1
      calc
        ∑ i in s, w i = ∑ i in t, w i := by
          apply Finset.sum_eq_sum_of_subset
          · -- Show that t ⊆ s
            intro i hi
            simp at hi ⊢
            tauto
          · -- Show that ∀ i ∈ t, w i = w i (trivial)
            intro i hi
            simp
        _ = 1 := hw₁
    · -- Show that s.centerMass w f = x
      exact rfl
  mpr hp := by
    simp_all [Set.mem_range, Set.mem_image, Set.mem_setOf_eq, Set.mem_univ, Set.mem_union]
    <;> try { tauto }
    <;> try { aesop }
