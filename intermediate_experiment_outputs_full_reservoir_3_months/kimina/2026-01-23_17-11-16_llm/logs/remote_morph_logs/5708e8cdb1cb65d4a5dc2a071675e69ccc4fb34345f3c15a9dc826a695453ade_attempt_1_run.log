import Mathlib.Analysis.Convex.Combination

open AffineMap Finset

section oldVars
variable {ι R E : Type*} [Field R] [LinearOrder R] [IsStrictOrderedRing R] [AddCommGroup E]
  [Module R E] {s : Finset ι} {f : ι → E} {x : E}

lemma mem_convexHull_image :
    x ∈ convexHull R (f '' s) ↔
      ∃ w : ι → R, (∀ i ∈ s, 0 ≤ w i) ∧ ∑ i ∈ s, w i = 1 ∧ s.centerMass w f = x where
  constructor
  · -- Assume x ∈ convexHull R (f '' s), prove ∃ w : ι → R, (∀ i ∈ s, 0 ≤ w i) ∧ ∑ i ∈ s, w i = 1 ∧ s.centerMass w f = x
    rintro hx
    rcases hx with ⟨w, hw₀, hw₁, hw₂⟩
    refine ⟨fun i => if h : i ∈ f '' s then w i else 0, ?_, ?_, ?_⟩
    · -- Show that ∀ i ∈ s, 0 ≤ w' i
      intro i hi
      simp at hw₀ ⊢
      by_cases h : i ∈ f '' s
      · -- If i ∈ f '' s, then 0 ≤ w i by hw₀
        have h' : 0 ≤ w i := hw₀ i h
        simp [h, h']
      · -- If i ∉ f '' s, then w' i = 0 ≥ 0
        simp [h]
    · -- Show that ∑ i ∈ s, w' i = 1
      have h1 : ∑ i in s, (if h : i ∈ f '' s then w i else 0) = ∑ i in f '' s, w i := by
        apply Finset.sum_bijective (fun i hi => ⟨i, by simp at hi ⊢; tauto⟩) (by
          intro i hi j hj h
          simp at h ⊢
          all_goals try { tauto }
        ) (by
          intro i hi
          simp at hi ⊢
          all_goals try { tauto }
        )
      rw [h1]
      exact hw₁
    · -- Show that s.centerMass w' f = x
      simp [hw₂, Finset.sum_dite]
      <;> try { aesop }
  · -- Assume ∃ w : ι → R, (∀ i ∈ s, 0 ≤ w i) ∧ ∑ i ∈ s, w i = 1 ∧ s.centerMass w f = x, prove x ∈ convexHull R (f '' s)
    rintro ⟨w, hw₀, hw₁, hw₂⟩
    refine' ⟨fun j => if h : j ∈ f '' s then w ⟨(f ⁻¹' {j}).min' (by simp at h ⊢; tauto), by simp at h ⊢; tauto⟩ else 0, ?_, ?_, ?_⟩
    · -- Show that ∀ j ∈ f '' s, 0 ≤ w' j
