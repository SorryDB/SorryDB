            have h4 : p.2 - p.1 ≤ (M - s₀) / 2 ^ n := by
              exact hp.2.2.2
            have h5 : s - p.1 ≤ p.2 - p.1 := by linarith [hs.1]
            have h6 : p.2 - s ≤ p.2 - p.1 := by linarith
