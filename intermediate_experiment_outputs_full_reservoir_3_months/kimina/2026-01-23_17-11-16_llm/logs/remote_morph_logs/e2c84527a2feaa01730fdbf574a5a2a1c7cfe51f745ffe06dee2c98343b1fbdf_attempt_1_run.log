          rw [show (2 : ℝ) ^ (n + 1) = 2 * 2 ^ n by ring_nf]
          linarith [hp']

let a : ℕ → ℝ := fun n ↦ (ab n).val.1
let b : ℕ → ℝ := fun n ↦ (ab n).val.2

have a_prop : ∀ n, a n ∈ S := by
  intro n
  have h := (ab n).property.1
  apply h

have b_prop : ∀ n, IsUB S (b n) := by
  intro n
  have h := (ab n).property.2.1
  apply h

