    have h := (ab n).property.1
    apply h

  have b_prop : ∀ n, IsUB S (b n) := by
    intro n
    have h := (ab n).property.2.1
    apply h

  have aMono : Monotone a := by
    apply Monotone_of_succ
    intro n
    have h := (ab n).property.2.2.1
    by_cases midS : ∃ s ∈ S, (a n + b n) / 2 ≤ s
    · choose s sInS hs using midS
      have ha' : a (n + 1) = (ab (n + 1)).val.1 := by rfl
      have ha'' : (ab (n + 1)).val.1 = s := by
        have h1 : (ab (n + 1)).val.1 = s := by
          have h2 : (ab (n + 1)).val.1 = s := by
            -- The proof of ab (n + 1) is by induction, in the then branch, we choose (s, p.2)
            -- where s is chosen from S. So (ab (n + 1)).val.1 = s.
            -- This should be provable by rfl if we have the right structure.
            -- Let's assume we can prove this with rfl
            rfl
          exact h2
        exact h1
      have f1 : a n ≤ b n := by bound
      linarith [f1, ha', ha'', hs]
    · -- We need to prove a (n + 1) = a n
      have ha' : a (n + 1) = a n := by
        have h1 : (ab (n + 1)).val.1 = a n := by
          -- We are in the else branch, so we used (p.1, mid) where p = (a n, b n)
          -- So (ab (n + 1)).val.1 = a n.
          -- We need to make this explicit in the proof.
          -- Looking at the definition of ab (n + 1), we know that
