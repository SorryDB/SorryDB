      have ha1 : a (n + 1) = s := by
        simp [Set.mem_setOf_eq] at *
        <;> try { tauto }
      have ha2 : a n ≤ b n := by
        have h1 := (ab n).property.2.1
        linarith
      have ha3 : s ≤ b n := by linarith [h2, ha2]
      have ha4 : a (n + 1) ≥ a n := by linarith [ha1, hs]
      linarith
    · -- Case where the midpoint is an upper bound
      have h1 : ¬∃ s ∈ S, (a n + b n) / 2 ≤ s := by simpa using midS
      have ha1 : a (n + 1) = a n := by
