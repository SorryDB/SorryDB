          have hp' := hp.2.2.2
          change (p.1 + p.2) / 2 ≤ s at hs
          field_simp at ⊢ hp' hs
          rw [show (2 : ℝ) ^ (n + 1) = 2 * 2 ^ n by ring_nf]
          have f : (p.1 + p.2) * 2 ^ n ≤ 2 * s * 2 ^ n := by bound
          linarith [hp', hs, hp.2.2.1, f]
