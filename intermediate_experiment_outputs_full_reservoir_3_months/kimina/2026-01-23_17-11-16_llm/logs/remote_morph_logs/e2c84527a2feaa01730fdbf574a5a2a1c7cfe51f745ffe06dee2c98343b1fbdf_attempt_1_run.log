      by_cases midS : ∃ s ∈ S, mid ≤ s
      · -- Case where the midpoint is an upper bound
        choose s hs using midS
        use (s, p.2)
        constructor
        · -- Show s ∈ S
          exact hs.1
        constructor
        · -- Show IsUB S p.2
          exact hp.2.1
        constructor
        · -- Show s ≤ p.2
          linarith
        constructor
        · -- Show p.2 - s ≤ (M - s₀) / 2 ^ (n + 1)
