                    linarith
                  linarith
                linarith
              have h6 : a n ≤ x := ha
              have h7 : x ≤ b n := hb
              have h8 : a n ≤ x := by linarith
              have h9 : x ≤ b n := by linarith
              have h10 : a n ≤ b n := by linarith
