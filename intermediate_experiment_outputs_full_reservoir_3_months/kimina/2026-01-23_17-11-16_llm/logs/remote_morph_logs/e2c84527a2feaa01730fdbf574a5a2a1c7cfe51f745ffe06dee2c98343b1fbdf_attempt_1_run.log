                  have h16 : sSup S ≥ b n := by
                    have h17 : b n ∈ lowerBounds S := by
                      intro s hs
                        -- apply le_csSup S (show ∀ s ∈ S, s ≤ b n by intro s hs; apply h13 s hs)
                      have h18 : b n ∈ lowerBounds S := by
                        intro s hs
                        have h19 : s ≤ b n := by
                          apply h13 s hs
                        linarith
                      exact h18
                    have h19 : b n ≤ sSup S := by
                      apply csSup_le
                      exact h17
                    linarith
                  linarith
                have h13 : sSup S = b n := by
                  linarith [h15, h16]
                linarith
                linarith
                linarith
              linarith
            · -- Assume x ∈ S
              intro hx
              have h10 : x ∈ S := hx
              have h11 : x ≤ b 0 := by
                apply b_prop 0
                exact h10
              have h12 : a 0 ≤ x := by
                have h13 : a 0 ∈ S := a_prop 0
                have h14 : a 0 ≤ x := by
                  have h15 : a 0 ≤ b 0 := by
                    have h16 : IsUB S (b 0) := b_prop 0
                    have h17 : a 0 ∈ S := a_prop 0
                    have h18 : a 0 ≤ b 0 := by
                      have h19 := (ab 0).property.2.2.1
                      linarith
                    linarith
                  linarith
                linarith
              have h13 : ∃ n, a n ≤ x ∧ x ≤ b n := by
                use 0
                constructor
                · exact h12
                · exact h11
              exact h13
            linarith
          have h5 : sSup S = lim a := by
            have h6 : sSup S = lim a := by
