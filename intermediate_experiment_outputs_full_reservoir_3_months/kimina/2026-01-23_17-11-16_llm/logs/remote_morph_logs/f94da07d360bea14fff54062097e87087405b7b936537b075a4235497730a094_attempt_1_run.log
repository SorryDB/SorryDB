          have h6 : - (‚ÄĖX (I k).1 ŌČ‚ÄĖ * ‚ÄĖX (I k).2 ŌČ‚ÄĖ) ‚Č§ inner ‚ĄĚ (X (I k).1 ŌČ) (X (I k).2 ŌČ) := by linarith [show ‚ÄĖX (I k).1 ŌČ‚ÄĖ * ‚ÄĖX (I k).2 ŌČ‚ÄĖ ‚Č• 0 by positivity]
