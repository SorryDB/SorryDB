    apply Finset.prod_integrable
    intro k hk
    have h1k : Integrable (fun ŌČ => inner ‚ĄĚ (X (I k).1 ŌČ) (X (I k).2 ŌČ)) őľ := by
      have h2k : (fun ŌČ => inner ‚ĄĚ (X (I k).1 ŌČ) (X (I k).2 ŌČ)) ‚Č§
          (fun ŌČ => ‚ÄĖX (I k).1 ŌČ‚ÄĖ * ‚ÄĖX (I k).2 ŌČ‚ÄĖ) := by
        intro ŌČ
        have h3 : inner ‚ĄĚ (X (I k).1 ŌČ) (X (I k).2 ŌČ) ‚Č§ ‚ÄĖX (I k).1 ŌČ‚ÄĖ * ‚ÄĖX (I k).2 ŌČ‚ÄĖ := by
          apply inner_le_norm_mul_norm
        simpa using h3
      have h3k : Integrable (fun ŌČ => ‚ÄĖX (I k).1 ŌČ‚ÄĖ * ‚ÄĖX (I k).2 ŌČ‚ÄĖ) őľ := by
        have h4k1 : Integrable (fun ŌČ => ‚ÄĖX (I k).1 ŌČ‚ÄĖ) őľ := by
          apply memLp_X
          simp at hI ‚äĘ
          tauto
        have h4k2 : Integrable (fun ŌČ => ‚ÄĖX (I k).2 ŌČ‚ÄĖ) őľ := by
          apply memLp_X
          simp at hI ‚äĘ
          tauto
        apply Integrable.mul
        all_goals try assumption
