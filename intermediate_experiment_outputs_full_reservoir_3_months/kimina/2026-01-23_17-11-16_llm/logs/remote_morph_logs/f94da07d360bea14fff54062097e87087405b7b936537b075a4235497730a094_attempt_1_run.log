  -- Turn the `L^p` assumption on the `X i` into various integrability conditions.
  have integrable_prod_norm_X I (hI : I ‚ąą A √óňĘ A ^^ m) :
    Integrable (fun ŌČ ‚Ü¶ ‚ąŹ k, ‚ÄĖX (I k).1 ŌČ‚ÄĖ * ‚ÄĖX (I k).2 ŌČ‚ÄĖ) őľ := by
    sorry
```

