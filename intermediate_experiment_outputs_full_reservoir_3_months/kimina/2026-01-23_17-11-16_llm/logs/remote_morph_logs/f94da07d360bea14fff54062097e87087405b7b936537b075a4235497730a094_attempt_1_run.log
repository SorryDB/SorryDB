      ¬∑ -- Show non-negativity
        intro ŌČ
        have h4 : inner ‚ĄĚ (X (I k).1 ŌČ) (X (I k).2 ŌČ) ‚Č• - (‚ÄĖX (I k).1 ŌČ‚ÄĖ * ‚ÄĖX (I k).2 ŌČ‚ÄĖ) := by
          have h5 : inner ‚ĄĚ (X (I k).1 ŌČ) (X (I k).2 ŌČ) ‚Č§ ‚ÄĖX (I k).1 ŌČ‚ÄĖ * ‚ÄĖX (I k).2 ŌČ‚ÄĖ := by
