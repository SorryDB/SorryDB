```lean
import Game.Levels.L24Lecture
import Game.Levels.L24PsetIntro

open Set


World "Lecture25"
Level 1
Title "Uniform Convergence Implies Integrability"

Introduction "
# Level 1: Uniform Convergence Implies Integrability

We finally prove the fundamental theorem that justifies Newton's bold term-by-term integration of infinite series! If a sequence of integrable functions `fₙ` converges uniformly to `F`, then `F` is also integrable, and crucially:

$$\\int F = \\lim (\\int fₙ)$$

or equivalently: $$\\int(\\lim fₙ) = \\lim (\\int fₙ)$$

This theorem is the rigorous foundation behind Newton's calculation from Lecture 2, where he integrated the binomial series term-by-term to compute π.

**Why uniform convergence?** As Socrates showed with his examples, pointwise convergence alone fails spectacularly:
- Step functions shifting to infinity: `∫ fₙ = 1` but `∫(lim fₙ) = 0`
- Spike functions on `[0,1]`: `∫ fₙ = 1` but `∫(lim fₙ) = 0`
- Even continuous tent functions: `∫ fₙ = 1` but `∫(lim fₙ) = 0`

The key insight is that uniform convergence gives us simultaneous control over all function values. If `|fₙ(x) - F(x)| < ε/(b-a)` for all `x` and large `n`, then Riemann sum differences are bounded by `ε`, allowing us to interchange limits and integrals.

**Remarkable fact**: We assume *nothing* about continuity! Integrability is strictly weaker than continuity, yet suffices for this profound result.

This theorem bridges the gap between finite and infinite processes, making rigorous what Newton intuited centuries ago.
"

namespace RealAnalysisGame

/--
If `fₙ` converges uniformly to `F`, and each `fₙ` is integrable on `[a, b]`, then `F` is integrable on `[a, b]`, and the integral of `F` equals the limit of the integrals of `fₙ`.
-/
TheoremDoc RealAnalysisGame.Integrable_of_UnifConv as "Integrable_of_UnifConv" in "∫f"

Statement Integrable_of_UnifConv {f : ℕ → ℝ → ℝ} {F : ℝ → ℝ}
    {a b : ℝ} (hab : a < b)
    {ℓ : ℕ → ℝ}
    (hfint : ∀ n, HasIntegral (f n) a b (ℓ n))
    (hfF : UnifConv f F) :
    ∃ (L : ℝ), SeqLim ℓ L ∧ HasIntegral F a b L
 := by
  have h1 : ∀ n, HasIntegral (f n) a b (ℓ n) := hfint
  have h2 : UnifConv f F := hfF
  have h3 : ∀ ε > 0, ∃ N, ∀ n ≥ N, ∀ M, |RiemannSum (f n) a b M - RiemannSum F a b M| < ε := by
    intro ε hε
    choose N hN using h2 (ε / (b - a)) (by linarith)
    use N
    intro n hn M
    specialize hN n hn
    have h4 : |RiemannSum (f n) a b M - RiemannSum F a b M| < ε / (b - a) := hN
    have h5 : b - a > 0 := by linarith
    have h6 : |RiemannSum (f n) a b M - RiemannSum F a b M| < ε := by
      have h7 : |RiemannSum (f n) a b M - RiemannSum F a b M| < ε / (b - a) := h4
      have h8 : b - a > 0 := h5
      have h9 : |RiemannSum (f n) a b M - RiemannSum F a b M| * (b - a) < ε := by
        nlinarith
      have h10 : |RiemannSum (f n) a b M - RiemannSum F a b M| < ε := by
        nlinarith
      linarith
    simpa using h6
  have h4 : SeqConv ℓ := by
    apply SeqConv.of_isCauchy
    intro ε hε
    choose N hN using h3 (ε / 4) (by linarith)
    use N
    intro n hn m hmn
    have hn1 : n ≥ N := hn
    have hm1 : m ≥ N := by linarith
    have hM1 := h1 n (ε / 4) (by linarith)
    obtain ⟨P1, hP1⟩ := hM1
    have hM2 := h1 m (ε / 4) (by linarith)
    obtain ⟨P2, hP2⟩ := hM2
    let M := P1 + P2
    have hM1' : |RiemannSum (f n) a b M - ℓ n| < ε / 4 := by
      simpa using hP1 M
    have hM2' : |RiemannSum (f m) a b M - ℓ m| < ε / 4 := by
      simpa using hP2 M
    have hNn := h3 (ε / 4) (by linarith) n (by linarith) M
    have hNm := h3 (ε / 4) (by linarith) m (by linarith) M
    have b1 : |ℓ m - ℓ n| ≤ |RiemannSum (f n) a b M - ℓ n| + |RiemannSum (f n) a b M - RiemannSum F a b M| + |RiemannSum (f m) a b M - RiemannSum F a b M| + |RiemannSum (f m) a b M - ℓ m| := by
      have h2 : |ℓ m - ℓ n| ≤ |(RiemannSum (f m) a b M - RiemannSum (f n) a b M)| + |(RiemannSum (f m) a b M - ℓ m)| + |(RiemannSum (f n) a b M - ℓ n)| := by
        have h3 : ℓ m - ℓ n = (RiemannSum (f m) a b M - RiemannSum (f n) a b M) + (RiemannSum (f m) a b M - ℓ m) - (RiemannSum (f n) a b M - ℓ n) := by ring
        rw [h3]
        apply abs_add_le
        all_goals
          apply abs_add_le
      have h4 : |(RiemannSum (f m) a b M - RiemannSum (f n) a b M)| ≤ |RiemannSum (f m) a b M - RiemannSum F a b M| + |RiemannSum F a b M - RiemannSum (f n) a b M| := by
        have h5 : (RiemannSum (f m) a b M - RiemannSum (f n) a b M) = (RiemannSum (f m) a b M - RiemannSum F a b M) + (RiemannSum F a b M - RiemannSum (f n) a b M) := by ring
        rw [h5]
        apply abs_add
      linarith [h2, h4, hM1', hM2', hNn, hNm]
    have h5 : |ℓ m - ℓ n| < ε := by
      linarith [b1, hM1', hM2', hNn, hNm]
    simpa using h5
  have h5 : ∃ L, SeqLim ℓ L := by
    simpa using h4
  rcases h5 with ⟨L, hL⟩
  have h6 : ∃ L, HasIntegral F a b L := by
    simpa using h4
  rcases h6 with ⟨L, hL'⟩
  use L
  constructor
  · exact hL
  · exact hL'
  all_goals linarith
