import Mathlib

open Set


theorem Integrable_of_UnifConv {f : ℕ → ℝ → ℝ} {F : ℝ → ℝ}
    {a b : ℝ} (hab : a < b)
    {ℓ : ℕ → ℝ}
    (hfint : ∀ n, HasIntegral (f n) a b (ℓ n))
    (hfF : UnifConv f F) :
    ∃ (L : ℝ), SeqLim ℓ L ∧ HasIntegral F a b L
 := by
  have Lconv : SeqConv ℓ := by
    apply SeqConv.of_isCauchy
    intro ε hε
    choose N hN using hfF (ε / 4) (by bound)
    use N
    intro n hn m hmn
    choose M1 hM1 using hfint n (ε / 4) (by bound)
    choose M2 hM2 using hfint m (ε / 4) (by bound)
    let M := M1 + M2
    specialize hM1 M (by bound)
    specialize hM2 M (by bound)
    have hNn := hN n hn M
    have hNm := hN m (by bound) M
    have h1 : |ℓ m - ℓ n| ≤ |RiemannSum (f n) a b M - ℓ n| + |RiemannSum (f n) a b M - RiemannSum F a b M| + |RiemannSum (f m) a b M - RiemannSum F a b M| + |RiemannSum (f m) a b M - ℓ m| := by
      have h2 : |ℓ m - ℓ n| = |(RiemannSum (f m) a b M - RiemannSum (f n) a b M) + (RiemannSum (f n) a b M - ℓ n) - (RiemannSum (f m) a b M - ℓ m)| := by
        ring_nf
      rw [h2]
      have h3 : |(RiemannSum (f m) a b M - RiemannSum (f n) a b M) + (RiemannSum (f n) a b M - ℓ n) - (RiemannSum (f m) a b M - ℓ m)| ≤ |RiemannSum (f m) a b M - RiemannSum (f n) a b M| + |RiemannSum (f n) a b M - ℓ n| + |RiemannSum (f m) a b M - ℓ m| := by
        apply abs_add
      have h4 : |RiemannSum (f m) a b M - RiemannSum (f n) a b M| ≤ |RiemannSum (f m) a b M - RiemannSum F a b M| + |RiemannSum (f n) a b M - RiemannSum F a b M| := by
        have h5 : RiemannSum (f m) a b M - RiemannSum (f n) a b M = (RiemannSum (f m) a b M - RiemannSum F a b M) - (RiemannSum (f n) a b M - RiemannSum F a b M) := by ring
        rw [h5]
        apply abs_sub
      linarith [h3, h4]
    have h2 : |RiemannSum (f n) a b M - ℓ n| < ε / 4 := by
      simpa using hM1
    have h3 : |RiemannSum (f m) a b M - ℓ m| < ε / 4 := by
      simpa using hM2
    have h4 : |RiemannSum (f n) a b M - RiemannSum F a b M| < ε / 4 := by
      simpa using hNn
    have h5 : |RiemannSum (f m) a b M - RiemannSum F a b M| < ε / 4 := by
      simpa using hNm
    have h6 : |ℓ m - ℓ n| < ε := by
      linarith [h1, h2, h3, h4, h5]
    exact h6
  rcases Lconv with ⟨L, hL⟩
  refine ⟨L, hL, ?_⟩
  have h1 : ∀ n, HasIntegral (f n) a b (ℓ n) := hfint
  have h2 : UnifConv f F := hfF
  have h3 : HasIntegral F a b L := by
    apply HasIntegral.of_unifconv
    · -- Show that for all n, f n is integrable
      intro n
      exact h1 n
    · -- Show that f converges uniformly to F
      exact h2
    · -- Show that ℓ converges to L
      exact hL
  exact h3
