      have h2 : ℓ m - ℓ n = (RiemannSum (f n) a b M - RiemannSum (f m) a b M) + (RiemannSum (f m) a b M - RiemannSum F a b M) + (RiemannSum F a b M - RiemannSum (f n) a b M) := by
