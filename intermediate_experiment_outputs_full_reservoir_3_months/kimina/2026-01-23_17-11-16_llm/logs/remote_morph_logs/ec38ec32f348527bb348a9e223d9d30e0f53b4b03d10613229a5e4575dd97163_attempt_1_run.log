import Mathlib

open ProbabilityTheory

variable (α : Type) [Inhabited α]

noncomputable instance hasUniformSelect (List α) where
  uniformSelect = OptionT.mk (some <$> ($[0..List.length] ?))

noncomputable instance hasUniformSelect! (List α) where
  uniformSelect! = OptionT.mk (some <$> ($[0..List.length] ?))

noncomputable instance hasUniformSelect (Finset α) where
  uniformSelect = OptionT.mk (some <$> (Finset.toList.choose ($[0..Finset.card] ?)))

noncomputable instance hasUniformSelect! (Finset α) where
  uniformSelect! = OptionT.mk (some <$> (Finset.toList.choose ($[0..Finset.card] ?)))

noncomputable instance hasUniformSelect (Fin α) where
  uniformSelect = OptionT.mk (some <$> ($[0..Fin.isLt] ?))

noncomputable instance hasUniformSelect! (Fin α) where
  uniformSelect! = OptionT.mk (some <$> ($[0..Fin.isLt] ?))

noncomputable instance hasUniformSelect (Vector α (n + 1)) where
  uniformSelect = OptionT.mk (some <$> (Vector.get! ($[0..n] ?)))

noncomputable instance hasUniformSelect! (Vector α (n + 1)) where
  uniformSelect! = OptionT.mk (some <$> (Vector.get! ($[0..n] ?)))

noncomputable instance hasUniformSelect (List.Vector α (n + 1)) where
  uniformSelect = OptionT.mk (some <$> (List.get! ($[0..n] ?)))

noncomputable instance hasUniformSelect! (List.Vector α (n + 1)) where
  uniformSelect! = OptionT.mk (some <$> (List.get! ($[0..n] ?)))

noncomputable instance hasUniformSelect (α × β) where
  uniformSelect = OptionT.mk (some <$> (Prod.mk ($[0..1] ?) ($[0..1] ?)))

noncomputable instance hasUniformSelect! (α × β) where
  uniformSelect! = OptionT.mk (some <$> (Prod.mk ($[0..1] ?) ($[0..1] ?)))

noncomputable instance hasUniformSelect (α + β) where
  uniformSelect = OptionT.mk (some <$> (Sum.inl ($[0..1] ?)) + some <$> (Sum.inr ($[0..1] ?)))

noncomputable instance hasUniformSelect! (α + β) where
  uniformSelect! = OptionT.mk (some <$> (Sum.inl ($[0..1] ?)) + some <$> (Sum.inr ($[0..1] ?)))

