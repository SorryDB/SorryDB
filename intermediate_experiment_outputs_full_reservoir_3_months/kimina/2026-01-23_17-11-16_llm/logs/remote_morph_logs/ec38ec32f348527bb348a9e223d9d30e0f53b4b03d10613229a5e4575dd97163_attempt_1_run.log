import Mathlib

open ProbabilityTheory

variable (α : Type) [Inhabited α]

noncomputable def uniformSelect (β : Type) [HasUniformSelect β] : ProbComp β := fun _ ↦ @HasUniformSelect.uniformSelect β

noncomputable def uniformSelect! (β : Type) [HasUniformSelect! β] : ProbComp β := fun _ ↦ @HasUniformSelect!.uniformSelect! β

-- This is the same as `evalDist`, but we need this name for the paper.
noncomputable def evalSPMF (p : SProbComp) : SProb := p.eval

variable {α : Type} [Inhabited α]

noncomputable def uniformSample (β : Type) [h : SampleableType β] : ProbComp β := h.selectElem

-- This is the same as `evalSPMF`, but we need this name for the paper.
noncomputable def evalDist (p : ProbComp) : Dist := p.eval

-- This is the same as `evalSPMF`, but we need this name for the paper.
noncomputable def evalSProb (p : SProbComp) : SProb := p.eval

variable (α : Type) [Inhabited α]

noncomputable def uniformSelect (β : Type) [HasUniformSelect β] : ProbComp β := fun _ ↦ @HasUniformSelect.uniformSelect β

noncomputable def uniformSelect! (β : Type) [HasUniformSelect! β] : ProbComp β := fun _ ↦ @HasUniformSelect!.uniformSelect! β

-- This is the same as `evalDist`, but we need this name for the paper.
noncomputable def evalSPMF (p : SProbComp) : SProb := p.eval

variable {α : Type} [Inhabited α]

noncomputable def uniformSample (β : Type) [h : SampleableType β] : ProbComp β := h.selectElem

-- This is the same as `evalSPMF`, but we need this name for the paper.
noncomputable def evalDist (p : ProbComp) : Dist := p.eval

-- This is the same as `evalSPMF`, but we need this name for the paper.
noncomputable def evalSProb (p : SProbComp) : SProb := p.eval

-- This is the same as `evalSPMF`, but we need this name for the paper.
noncomputable def evalSProb (p : SProbComp) : SProb := p.eval

