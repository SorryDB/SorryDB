    Pr[=x | @HasUniformSelect!.uniformSelect! (Vector Bool 2) Bool (hasUniformSelectVector Bool 1) #v[true, false]] =
    Pr[=y | @HasUniformSelect!.uniformSelect! (Vector Bool 2) Bool (hasUniformSelectVector Bool 1) #v[true, false]] := by
