import Mathlib

open Mathlib

/- Types for representing probability distributions and related concepts. -/
namespace SPMF

variable (α : Type) [hα : HasUniformSelect α]

/- A probability distribution over a type `β` is a function from `β` to `ℝ≥0∞` such that the sum of the distribution over all elements in the type is 1. -/
structure ProbComp (β : Type) : Type* where
  val : β → ℝ≥0∞
  val_prop : (∑ x : β, val x) = 1

/- The empty probability distribution, which assigns 0 to all outcomes. -/
noncomputable def failure : ProbComp (β : Type) := ⟨fun _ => 0, by simp⟩

/- A computation that results in a probability distribution. -/
noncomputable def OptionT (P : Type → Type) (β : Type) [DecidableEq β] (α : Type) [DecidableEq α]
    (h : α → P β) : P β :=
    match h with
    | ⟨p, hp⟩ => OptionT.mk ⟨fun x => p x, fun x => hp x⟩
    | ⟨p, hp⟩ => OptionT.mk ⟨fun x => p x, fun x => hp x⟩

/- A computation that results in a probability distribution, but requires a non-empty input. -/
noncomputable def OptionT! (P : Type → Type) (β : Type) [DecidableEq β] (α : Type) [DecidableEq α]
    (h : α → P β) : P β :=
    match h with
    | ⟨p, hp⟩ => OptionT!.mk ⟨fun x => p x, fun x => hp x⟩
    | ⟨p, hp⟩ => OptionT!.mk ⟨fun x => p x, fun x => hp x⟩

/- A computation that results in a probability distribution. -/
noncomputable def SPMF (β : Type) : Type* where
  val : β → ℝ≥0∞
  val_prop : (∑ x : β, val x) = 1

/- A computation that results in a probability distribution, but requires a non-empty input. -/
noncomputable def SPMF! (β : Type) : Type* where
  val : β → ℝ≥0∞
  val_prop : (∑ x : β, val x) = 1
  nonempty : ¬ IsEmpty (Set.univ : Set β)

