noncomputable def assert_bit_e (rest : Cs p var) (b : var) : Cs p var :=
  .eq0 (.v b * (.c 1 - .v b)) rest

noncomputable def assert_bits_e {w : ℕ} (bs : Vector var w) (rest : Cs p var) : Cs p var :=
  Vector.foldl assert_bit_e rest bs

noncomputable def bits2num_e {w : ℕ} (bits : Vector var w) : Exp (ZMod p) var :=
  Vector.foldl (fun acc b => .v b + .c 2 * acc) (.c 0) bits

noncomputable def to_cs (c : Circuit p var) : Cs p var :=
  match c with
  | .nil => .nil
  | .eq0 e c => .eq0 e (to_cs c)
  | .lam k => .lam (fun x => to_cs (k x))
