  let b : ℕ → ℝ := fun n ↦ (ab n).val.2
```

Now we need to prove that these sequences have the required properties.

```tactics
  have a_prop : ∀ n, a n ∈ S := by
    intro n
    have h := (ab n).property.1
    apply h
```

Similarly for `b_prop`.

```tactics
  have b_prop : ∀ n, IsUB S (b n) := by
    intro n
    have h := (ab n).property.2.1
    apply h
```

Now we prove that `a` is monotone increasing and `b` is monotone decreasing.

```tactics
  have aMono : Monotone a := by
    apply Monotone_of_succ
    intro n
    have h := (ab n).property.2.2.1
    by_cases midS : ∃ s ∈ S, (a n + b n) / 2 ≤ s
    · choose s sInS hs using midS
      have ha' : a (n + 1) = (ab (n + 1)).val.1 := by rfl
      have ha'' : (ab (n + 1)).val.1 = s := by
        simp [ab]
        <;> aesop
      have f1 : a n ≤ b n := by
        have h := (ab n).property.2.1
        apply h
      linarith [f1, ha', ha'', hs]
    · have ha' : a (n + 1) = a n := by
        simp [ab]
        <;> aesop
      linarith [ha']
```

Now we prove `b` is antitone.

```tactics
  have bAnti : Antitone b := by
    apply Antitone.of_succ
    intro n
    have h := (ab n).property.2.2.1
    by_cases midS : ∃ s ∈ S, (a n + b n) / 2 ≤ s
    · choose s sInS hs using midS
      have hb' : b (n + 1) = (ab (n + 1)).val.2 := by rfl
      have hb'' : (ab (n + 1)).val.2 = b n := by
        simp [ab]
        <;> aesop
      have f1 : a n ≤ b n := by
        have h := (ab n).property.2.1
        apply h
      linarith [f1, hb', hb'', hs]
    · have hb' : b (n + 1) = b n := by
        simp [ab]
        <;> aesop
      linarith [hb']
```

Now we prove that `a` and `b` are bounded, so they converge.

```tactics
  have aBnded : ∀ n, a n ≤ b 0 := by
    intro n
    have hb : (b n) ≤ b 0 := by
      have h1 := (ab n).property.2.2.2
      have h2 := (ab 0).property.2.2.2
      linarith [h1, h2]
    specialize b_prop n (a n) (a_prop n)
    linarith [b_prop, hb]
```

Similarly for `bBnded`.

```tactics
