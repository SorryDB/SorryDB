```lean
import Mathlib

open ProbabilityTheory

/- Define a function that selects an element uniformly at random from a finite type `α`.
This is a generalization of `selectElem` in `Mathlib/Data/Finset/Select.lean` to arbitrary finite types.
The definition is noncomputable because we generally need a way to choose an element from a finite set,
but the specific computational method depends on the type. -/
noncomputable def uniformSample (α : Type) [h : Fintype α] [Inhabited α] :
    ProbComp α := sSupp (Finset.univ : Finset α) fun x ↦ (Finset.card (Finset.univ : Finset α) : ℝ≥0∞)⁻¹

/- Define a function that selects a pair `(x, y)` such that `x` is selected uniformly at random from `Fin n` and `y` is selected uniformly at random from `Fin n`.
This is a generalization of `selectElem` in `Mathlib/Data/Finset/Select.lean` to the type `Fin n × Fin n`.
The definition is noncomputable for the same reasons as `uniformSample`. -/
noncomputable def uniformSamplePair (n : ℕ) :
    ProbComp (Fin n × Fin n) := sSupp (Finset.univ : Finset (Fin n × Fin n)) fun p ↦ (Finset.card (Finset.univ : Finset (Fin n × Fin n)) : ℝ≥0∞)⁻¹

/- Define a function that selects a pair `(x, y)` such that `x` is selected uniformly at random from `Fin n` and `y` is selected uniformly at random from `Fin n`.
This is a generalization of `selectElem` in `Mathlib/Data/Finset/Select.lean` to the type `Fin n × Fin n`.
The definition is noncomputable for the same reasons as `uniformSample`. -/
noncomputable def uniformSamplePair' (n : ℕ) :
    ProbComp (Fin n × Fin n) := sSupp (Finset.univ : Finset (Fin n × Fin n)) fun p ↦ (Finset.card (Finset.univ : Finset (Fin n × Fin n)) : ℝ≥0∞)⁻¹

/- A lemma stating that the probability of an impossible event is zero.
This is a generalization of `selectElem` in `Mathlib/Data/Finset/Select.lean` to arbitrary finite types.
The definition is noncomputable because we generally need a way to choose an element from a finite set,
but the specific computational method depends on the type. -/
lemma impossibleProbabilityIsZero (α : Type) [h : Fintype α] [Inhabited α] :
    Pr[False | uniformSample α] = 0 := by
  simp only [uniformSample, Fintype.card_univ, sSupp_eq_zero, zero_smul, zero_eq_zero, not_false_eq_true, true_and, true_iff]
  simp only [zero_smul, zero_eq_zero]
