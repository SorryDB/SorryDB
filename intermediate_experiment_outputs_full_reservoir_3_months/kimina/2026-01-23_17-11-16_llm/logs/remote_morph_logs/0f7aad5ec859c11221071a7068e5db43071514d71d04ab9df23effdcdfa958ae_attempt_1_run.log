  probOutput_selectElem_eq x y := by 
    simp [Finset.mem_univ, support_eq_support_iff, Finset.mem_univ]
  probFailure_selectElem := by 
    simp [Finset.mem_univ, support_eq_support_iff, Finset.mem_univ]
