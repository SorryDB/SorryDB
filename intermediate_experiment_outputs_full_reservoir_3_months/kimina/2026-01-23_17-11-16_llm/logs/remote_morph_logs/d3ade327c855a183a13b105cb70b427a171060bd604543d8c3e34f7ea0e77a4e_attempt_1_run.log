# Solving the Factorization Problem in Lean 4

We need to complete a Lean 4 proof for a theorem about factorization. The specific goal is to prove that for any factorization `f` of a natural number `n` and any natural number `L`, there exists another factorization `f'` of `n` such that `f'` is in balance (i.e., `f'.total_imbalance = 0`) and `f'.score L ≤ f.score L`.

The proof strategy is to use strong induction on the total imbalance of the factorization. The induction hypothesis is that for any factorization `g` of `n` with total imbalance less than `k`, there exists a factorization `f'` of `n` such that `f'` is in balance and `f'.score L ≤ g.score L`.

The proof proceeds by cases:
1. If the total imbalance `k` is 0, then the factorization is already in balance, so we can take `f' = f`.
2. If `k > 0`, then we need to find a prime `p` such that the balance of `f` at `p` is non-zero. We then consider three cases:
   - If there exists a prime `p` dividing `n` such that `f.balance p > 0`, we use a theorem `lower_score_1` to find a factorization `f₁` with lower score, then apply the induction hypothesis to `f₁`.
   - If there exists a prime `p` dividing `n` such that `p > L` and `f.balance p < 0`, we use a theorem `lower_score_2` to find a factorization `f₁` with lower score, then apply the induction hypothesis to `f₁`.
   - If all primes `p` dividing `n` satisfy `p ≤ L` and `f.balance p < 0`, we use a theorem `lower_score_3` to find a factorization `f₁` with lower score, then apply the induction hypothesis to `f₁`.

The key insight is that if a prime `p` has a positive balance, we can remove factors of `p` to decrease the score, and if a prime `p` has a negative balance and `p > L`, we can add factors of `p` to decrease the score. The induction hypothesis then allows us to find a factorization with score less than or equal to the original.

Now, let's complete the Lean proof:

```tactics
import Mathlib

open Nat

namespace Factorization

noncomputable def total_imbalance (f : Factorization n) := f.sum (fun p hp ↦ abs f.balance p)

noncomputable def score (f : Factorization n) (L : ℕ) := f.sum (fun p hp ↦ if p ≤ L then 0 else -f.balance p)

theorem lowest_score {n : ℕ} (f : Factorization n) (L : ℕ) :
    ∃ f' : Factorization n, f'.total_imbalance = 0 ∧ f'.score L ≤ f.score L := by
  induction h : f.total_imbalance using Nat.strong_induction_on generalizing f with
  | _ k ih =>
    obtain rfl | hk := k.eq_zero_or_pos
    · exact ⟨f, h, le_refl _⟩
    · have step : ∀ g : Factorization n, g.total_imbalance < k →
          ∃ f' : Factorization n, f'.total_imbalance = 0 ∧ f'.score L ≤ g.score L := fun g hg =>
        ih g.total_imbalance (h ▸ hg) g rfl
      by_cases h1 : ∃ p ∈ (n + 1).primesBelow, f.balance p > 0
      · obtain ⟨f₁, hlt, hle⟩ := lower_score_1 f L h1
        obtain ⟨f', hbal, hle'⟩ := step f₁ (h ▸ hlt)
        exact ⟨f', hbal, hle'.trans hle⟩
      · by_cases h2 : ∃ p ∈ (n + 1).primesBelow, p > L ∧ f.balance p < 0
        · obtain ⟨f₁, hlt, hle⟩ := lower_score_2 f L h2
          obtain ⟨f', hbal, hle'⟩ := step f₁ (h ▸ hlt)
          exact ⟨f', hbal, hle'.trans hle⟩
        · have h3 : ∃ p ∈ (n + 1).primesBelow, p ≤ L ∧ f.balance p < 0 := by
            simp only [not_exists, not_and, not_lt] at h1 h2; by_contra hc; push_neg at hc
            exact hk.ne' <| h ▸ sum_eq_zero fun p hp ↦ by
              have := h1 p hp; have := if hpL : p ≤ L then hc p hp hpL
                else h2 p hp (lt_of_not_ge hpL); omega
          obtain ⟨f₁, hlt, hle⟩ := lower_score_3 f L h3
          obtain ⟨f', hbal, hle'⟩ := step f₁ (h ▸ hlt)
          exact ⟨f', hbal, hle'.trans hle⟩

theorem card_bound {n : ℕ} (f : Factorization n) (L : ℕ) : ∃ f' :
    Factorization n, f'.total_imbalance = 0 ∧ (f'.a.card : ℝ) * (Real.log n)
      ≤ Real.log n.factorial + (f.score L) := by
  obtain ⟨f', hf'_bal, hf'_score⟩ := lowest_score f L
  exact ⟨f', hf'_bal, by rw [waste_eq f' hf'_bal]; linarith [score_eq hf'_bal L]⟩

structure Params where
  n : ℕ
  M : ℕ
  L : ℕ
  hL_pos : L > 0
  hL : n > L * L

def initial (P : Params) : Factorization P.n := {
  a := (replicate P.M (.Ico (P.n - P.n/P.M) P.n)).join.filter
    (fun m ↦ m ∈ (P.n/P.L).smoothNumbers)
  ha := fun m hm ↦ by
    simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
    obtain ⟨⟨_, ⟨_, rfl⟩, hs⟩, _⟩ := hm
    rw [Multiset.mem_Ico, tsub_le_iff_right] at hs
    grind
  hpos := fun m hm ↦ by
    simp only [Multiset.mem_filter, mem_join, mem_replicate] at hm
    obtain ⟨_, hsmooth⟩ := hm
    exact pos_of_ne_zero (mem_smoothNumbers.mp hsmooth).1
}

theorem initial.card (P : Params) : P.initial.a.card ≤ P.n := by
  calc Multiset.card (filter (fun m ↦ m ∈ (P.n / P.L).smoothNumbers)
      (replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)).join)
    _ ≤ Multiset.card (replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)).join :=
        card_le_card (filter_le _ _)
    _ = P.M * Multiset.card (Multiset.Ico (P.n - P.n / P.M) P.n) := by
        rw [card_join, map_replicate, sum_replicate, smul_eq_mul]
    _ = P.M * (P.n - (P.n - P.n / P.M)) := by congr 1; simp [Multiset.Ico]
    _ = P.M * (P.n / P.M) := by congr 1; exact Nat.sub_sub_self (div_le_self P.n P.M)
    _ ≤ P.n := mul_div_le P.n P.M

theorem initial.waste (P : Params) : P.initial.waste ≤ P.n * log (1 - 1/P.M)⁻¹ := by
  sorry

theorem initial.balance_large_prime_le (P : Params) {p : ℕ} (hp : p > P.n / P.L) :
