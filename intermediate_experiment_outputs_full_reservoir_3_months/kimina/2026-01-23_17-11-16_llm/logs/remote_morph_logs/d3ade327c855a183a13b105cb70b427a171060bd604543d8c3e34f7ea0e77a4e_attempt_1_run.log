import Mathlib

open Nat

/-- A factorization of $n$ is a function from primes to natural numbers such that the sum of $p^{k}$ for all primes $p$ is $n$.
   We denote the set of prime factors of $n$ as $\mathcal{P}_n$. The factorization function is $f$. The $p$-adic valuation of $n$ is $f(p)$.
   The waste of a factorization is the sum of $f(p)$ for all primes $p$.
   The score of a factorization $f$ with respect to a bound $L$ is the sum of $f(p)$ for all primes $p \leq L$. -/
structure Factorization (n : ℕ) where
  a : Multiset ℕ
  balance : ℕ → ℤ
  total_imbalance : ℕ → ℤ
  score : ℕ → ℕ
  ha : ∀ m ∈ a, ∀ p ∈ m.primeFactors, balance p = m.factorization p
  hpos : ∀ m ∈ a, m > 0

/-- The set of primes $p$ dividing $n$ is finite. -/
lemma (n : ℕ) (hn : n > 0) : (Nat.divisors n).Finite := by exact Nat.finite_divisors hn

/-- The set of prime factors of $n$ is finite. -/
lemma (n : ℕ) (hn : n > 0) : (Nat.primeFactors n).Finite := by
  exact Nat.finite_primeFactors hn

/-- The set of prime factors of $n$ is a subset of the set of divisors of $n$. -/
lemma (n : ℕ) (hn : n > 0) : (Nat.primeFactors n) ⊆ (Nat.divisors n) := by
  intro p hp; exact Nat.prime_factor_dvd hp

/-- The set of prime factors of $n$ is non-empty if $n > 1$. -/
lemma (n : ℕ) (hn : n > 1) : (Nat.primeFactors n).Nonempty := by
  use Nat.minFac n; simp [Nat.minFac_prime]; omega

/-- The set of prime factors of $n$ is non-empty if $n$ is not a power of a single prime. -/
lemma (n p : ℕ) (h : n ≠ p ^ k) (hp : Nat.Prime p) : (Nat.primeFactors n).Nonempty := by
  intro hempty; rcases hempty with ⟨p', hp'⟩; simp at hp'; tauto

/-- The set of prime factors of $n$ is non-empty if $n$ is not a power of a single prime. -/
lemma (n p : ℕ) (h : n ≠ p ^ k) (hp : Nat.Prime p) : (Nat.primeFactors n).Nonempty := by
  intro hempty; rcases hempty with ⟨p', hp'⟩; simp at hp'; tauto

/-- The set of primes $p$ dividing $n$ and less than or equal to $L$ is finite. -/
lemma (n L : ℕ) (hn : n > 0) : {p ∈ Nat.primeFactors n | p ≤ L}.Finite := by
  have h1 : {p ∈ Nat.primeFactors n | p ≤ L} ⊆ Nat.primeFactors n := by
    intro p hp; simp at hp; tauto
  exact Finite.subset (Nat.finite_primeFactors hn) h1

/-- The set of primes $p$ dividing $n$ and less than or equal to $L$ is non-empty if $n$ has prime factors. -/
lemma (n L : ℕ) (hn : n > 0) (hL : L > 0) : {p ∈ Nat.primeFactors n | p ≤ L}.Nonempty := by
  have h1 : (Nat.primeFactors n).Nonempty := by
    use Nat.minFac n; simp [Nat.minFac_prime]; omega
  have h2 : {p ∈ Nat.primeFactors n | p ≤ L} ⊆ (Nat.primeFactors n) := by
    intro p hp; simp at hp; tauto
  have h3 : (Nat.primeFactors n).Nonempty := h1
  have h4 : {p ∈ Nat.primeFactors n | p ≤ L}.Nonempty := by
    apply Nonempty.subset h3 h2
  exact h4

/-- The set of primes $p$ dividing $n$ and less than $L$ is finite. -/
lemma (n L : ℕ) (hn : n > 0) : {p ∈ Nat.primeFactors n | p < L}.Finite := by
  have h1 : {p ∈ Nat.primeFactors n | p < L} ⊆ Nat.primeFactors n := by
    intro p hp; simp at hp; tauto
  exact Finite.subset (Nat.finite_primeFactors hn) h1

/-- The set of primes $p$ dividing $n$ and less than $L$ is non-empty if $n$ has prime factors and $L > 1$. -/
lemma (n L : ℕ) (hn : n > 0) (hL : L > 1) : {p ∈ Nat.primeFactors n | p < L}.Nonempty := by
