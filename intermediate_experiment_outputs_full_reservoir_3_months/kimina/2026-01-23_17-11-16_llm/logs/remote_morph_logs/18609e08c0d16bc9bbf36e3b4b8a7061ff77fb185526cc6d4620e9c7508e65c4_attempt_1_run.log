theorem cartan {r : ℝ} {f : ℂ → ℂ} (hr : r ≠ 0) (h : Meromorphic f) (h₂ : 0 < meromorphicOrderAt f 0) :
    characteristic f ⊤ r = circleAverage (logCounting f · r) 0 1 := by
  have f1 {a : ℂ} :
      logCounting f a r + log ‖meromorphicTrailingCoeffAt (f · - a) 0‖
        = circleAverage (log ‖f · - a‖) 0 r + logCounting f ⊤ r := by
    have : logCounting f a r = logCounting (fun z ↦ f z - a) 0 r := by
      rw [logCounting_coe_eq_logCounting_sub_const_zero]
      rfl
    rw [this]
    have h₁ : Meromorphic (fun z ↦ f z - a) := h.sub (by fun_prop)
    have h₂ : meromorphicOrderAt (fun z ↦ f z - a) 0 = 0 := by
      have : (fun z ↦ f z - a) = f + (fun _ ↦ -a) := by
        fun_prop
      rw [this]
      have h₃ : meromorphicOrderAt (fun _ ↦ -a : ℂ → ℂ) 0 = 0 := by
        refine (MeromorphicNFAt.meromorphicOrderAt_eq_zero_iff ?_).mpr ?_
        refine IsAnalyticAt.meromorphicNFAt ?_
        exact isAnalyticAt_const
        simp
      rw [h₃]
      have h₄ : 0 < meromorphicOrderAt f 0 := h₂
      rw [h₄]
      simp
    have h₃ : logCounting (fun z ↦ f z - a) 0 r = 0 := by
      rw [logCounting_eq_zero_of_meromorphicOrderAt_lt (show -1 < (0 : ℝ) by norm_num)]
      exact h₂
    simp [h₃]
  have f2 : logCounting f ⊤ r = circleAverage (log ‖f‖) 0 r := by
    have h₁ : logCounting f ⊤ r = circleAverage (log ‖f‖) 0 r := by
      rw [logCounting_eq_circleAverage_log_norm]
      all_goals
        try { tauto }
        try { aesop }
    exact h₁
  rw [f2]
  have := intervalIntegrable_log_norm_meromorphicOn (a := 0) (b := 2 * π)
      (f := fun x ↦ f x - (0 : ℂ)) (by
        have : (fun x ↦ f x - (0 : ℂ)) = fun x ↦ f x := by
          fun_prop
        rw [this]
        exact h.meromorphicOn_univ
      )
  unfold IntervalIntegrable at this
  simp at this
  rw [this]
  all_goals
    try { tauto }
    try { aesop }
