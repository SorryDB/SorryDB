          MemLorentz g p 1 μ →
            eLpNorm (T' (f + g)) 1 (ν.restrict G)
              ≤ eLpNorm (T' f) 1 (ν.restrict G) + eLpNorm (T' g) 1 (ν.restrict G) := by
