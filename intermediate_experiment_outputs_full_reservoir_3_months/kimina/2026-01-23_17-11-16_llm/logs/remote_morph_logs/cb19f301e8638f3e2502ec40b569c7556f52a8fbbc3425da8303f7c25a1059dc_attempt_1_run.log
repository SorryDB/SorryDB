```lean
import Mathlib

open Filter Set

noncomputable def eLorentzNorm' (f : α → K) (p : ℝ≥0∞) (s : Set α) (μ : Measure α) (a : K) (ha : a ≠ 0) : ℝ≥0 :=
  if p = ∞ then
    if μ s = 0 then 0 else
      if IsFinite (μ s) then
        (sup (f '' s) fun ⦃x y⦄ x_1 ↦ |x - y|) / μ s
      else
        ‖f‖₊∞ s μ
  else
    (μ s) ^ (1 / p.toReal) * ‖f‖₊p s μ / (p.toReal / (p.toReal + 1))

noncomputable def eLorentzNorm (f : α → K) (p : ℝ≥0∞) (s : Set α) (μ : Measure α) : ℝ≥0 :=
  if p = ∞ then
    if μ s = 0 then 0 else
      if IsFinite (μ s) then
        (sup (f '' s) fun ⦃x y⦄ x_1 ↦ |x - y|) / μ s
      else
        ‖f‖₊∞ s μ
  else
    (μ s) ^ (1 / p.toReal) * ‖f‖₊p s μ

noncomputable def eLpNorm (T : (α → K) → (α' → E)) (f : α → K) (p : ℝ≥0∞) (s : Set α') (μ : Measure α) : ℝ≥0 :=
  if p = ∞ then
    if μ '' s = 0 then 0 else
      if IsFinite (μ '' s) then
        (sup (T '' s) fun ⦃x y⦄ x_1 ↦ ‖x - y‖) / μ '' s
      else
        ‖T‖₊∞ s μ
  else
    (μ '' s) ^ (1 / p.toReal) * ‖T‖₊p s μ

theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

lemma HasRestrictedWeakType.hasLorentzType [TopologicalSpace α] {𝕂 : Type*} /- [MeasurableSpace ε'] [BorelSpace ε'] -/
