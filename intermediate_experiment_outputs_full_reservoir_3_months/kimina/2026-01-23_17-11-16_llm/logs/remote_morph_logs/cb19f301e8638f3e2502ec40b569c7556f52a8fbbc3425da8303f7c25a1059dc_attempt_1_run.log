import Mathlib

open Real Complex

/- The norm of the imaginary unit I in a RCLike field is 1 if I is not zero, and 0 if I is zero. -/
theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

/- A linear operator T between two measure spaces has a bounded norm if it satisfies certain conditions. -/
lemma HasLorentzType (T : (α → 𝕂) → (α' → ε')) {p p' : ℝ≥0∞} {μ : Measure α} {ν : Measure α'}
    (c : ℝ≥0) (c_pos : 0 < c) (hT : HasRestrictedWeakType T p p' μ ν c) (hpp' : p.HolderConjugate p')
