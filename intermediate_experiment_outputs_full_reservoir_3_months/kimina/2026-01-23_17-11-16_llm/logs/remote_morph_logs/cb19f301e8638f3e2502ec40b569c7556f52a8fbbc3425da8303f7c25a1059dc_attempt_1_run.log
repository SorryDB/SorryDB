      AEStronglyMeasurable (T f) ν)
    (T_subadd : ∀ (f g : α → 𝕂) (x : α'), (@MeasureTheory.MemLorentz α 𝕂 μ p 1 f) →
      (@MeasureTheory.MemLorentz α 𝕂 μ p 1 g) → ‖T (f + g) x‖ ≤ ‖T f x + T g x‖)
