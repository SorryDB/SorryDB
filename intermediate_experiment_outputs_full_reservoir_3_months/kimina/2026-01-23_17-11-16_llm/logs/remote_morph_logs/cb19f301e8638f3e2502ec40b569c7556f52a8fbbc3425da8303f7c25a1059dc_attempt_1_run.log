import Mathlib

open Real

/- A normed space is a vector space over a field k, together with a norm function from the vector space to the non-negative reals. -/
class NormedSpace (𝕜 : Type u_1) extends AddZeroClass (𝕜) with
  field : Field 𝕜
  add_norm : ∀ (x y : 𝕜), ‖x + y‖ ≤ ‖x‖ + ‖y‖
  norm_zero : ‖0‖ = 0
  norm_pos : ∀ (x : 𝕜), x ≠ 0 → 0 < ‖x‖

/- A vector space over a field k is a set of vectors with addition and scalar multiplication operations that satisfy the vector space axioms. -/
class AddZeroClass (𝕜 : Type u_1) extends Type u_1 with
  zero : 𝕜
  add : 𝕜 → 𝕜 → 𝕜
  add_assoc : ∀ (x y z : 𝕜), x + y + z = x + (y + z)
  add_left_inv : ∀ (x : 𝕜), x + (-x) = 0
  add_right_inv : ∀ (x : 𝕜), (-x) + x = 0
  add_left_inv' : ∀ (x : 𝕜), x + 0 = x
  add_right_inv' : ∀ (x : 𝕜), 0 + x = x

/- A field k is a division ring that is also a vector space over itself. -/
class Field (𝕜 : Type u_1) extends AddZeroClass (𝕜) with
  mul : 𝕜 → 𝕜 → 𝕜
  mul_assoc : ∀ (x y z : 𝕜), x * y * z = x * (y * z)
  mul_left_inv : ∀ (x : 𝕜), x ≠ 0 → ∃ y : 𝕜, x * y = 1 ∧ y * x = 1
  mul_right_inv : ∀ (x : 𝕜), x ≠ 0 → ∃ y : 𝕜, y * x = 1 ∧ x * y = 1
  mul_one : ∀ (x : 𝕜), x * 1 = x
  one_mul : ∀ (x : 𝕜), 1 * x = x
  add_left_comm : ∀ (x y z : 𝕜), x + (y + z) = (x + y) + z
  mul_add : ∀ (x y z : 𝕜), x * (y + z) = x * y + x * z
  add_mul : ∀ (x y z : 𝕜), (x + y) * z = x * z + y * z
  mul_neg : ∀ (x y : 𝕜), x * (-y) = -(x * y)
  neg_mul : ∀ (x y : 𝕜), (-x) * y = -(x * y)
  neg_neg : ∀ (x : 𝕜), -(-x) = x

/- An add comm group with one is an add comm group with a multiplicative identity 1. -/
class AddCommGroupWithOne (𝕜 : Type u_1) extends AddZeroClass (𝕜) with
  mul : 𝕜 → 𝕜 → 𝕜
  one : 𝕜
  mul_one : ∀ (x : 𝕜), x * 1 = x
  one_mul : ∀ (x : 𝕜), 1 * x = x
  add_left_comm : ∀ (x y z : 𝕜), x + (y + z) = (x + y) + z
  mul_add : ∀ (x y z : 𝕜), x * (y + z) = x * y + x * z
  add_mul : ∀ (x y z : 𝕜), (x + y) * z = x * z + y * z
  mul_neg : ∀ (x y : 𝕜), x * (-y) = -(x * y)
  neg_mul : ∀ (x y : 𝕜), (-x) * y = -(x * y)
  neg_neg : ∀ (x : 𝕜), -(-x) = x

/- A normed comm ring is a comm ring with a norm function to the non-negative reals. -/
class NormedCommRing (𝕜 : Type u_1) extends CommRing (𝕜) with
  norm : 𝕜 → ℝ≥0
  norm_zero : ‖0‖ = 0
  norm_pos : ∀ (x : 𝕜), x ≠ 0 → 0 < ‖x‖
  norm_add : ∀ (x y : 𝕜), ‖x + y‖ ≤ ‖x‖ + ‖y‖
  norm_mul : ∀ (x y : 𝕜), ‖x * y‖ = ‖x‖ * ‖y‖

/- A normed field is a field with a norm function to the non-negative reals. -/
class NormedField (𝕜 : Type u_1) extends Field (𝕜) with
  norm : 𝕜 → ℝ≥0
  norm_zero : ‖0‖ = 0
  norm_pos : ∀ (x : 𝕜), x ≠ 0 → 0 < ‖x‖
  norm_add : ∀ (x y : 𝕜), ‖x + y‖ ≤ ‖x‖ + ‖y‖
  norm_mul : ∀ (x y : 𝕜), ‖x * y‖ = ‖x‖ * ‖y‖

/- An ordered field is a field with a total order that is compatible with the field operations. -/
class OrderedField (𝕜 : Type u_1) extends Field (𝕜) with
  lt : 𝕜 → 𝕜 → Prop
  le : 𝕜 → 𝕜 → Prop
