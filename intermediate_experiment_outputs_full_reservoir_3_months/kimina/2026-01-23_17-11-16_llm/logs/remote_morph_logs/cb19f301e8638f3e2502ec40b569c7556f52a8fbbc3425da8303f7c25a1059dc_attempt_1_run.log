import Mathlib

open Real Complex

/- The norm of the imaginary unit I in a RCLike field is 1 if I is not zero, and 0 if I is zero. -/
theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

/- A linear operator T between two measure spaces has a bounded norm if it satisfies certain conditions. -/
lemma HasLorentzType (T : (α → 𝕂) → (α' → ε')) {p p' : ℝ≥0∞} {μ : Measure α} {ν : Measure α'}
    (c : ℝ≥0) (c_pos : 0 < c) (hT : HasRestrictedWeakType T p p' μ ν c) (hpp' : p.HolderConjugate p')
    (T_meas : ∀ {f : α → 𝕂}, (hf : @MeasureTheory.MemLorentz α 𝕂 μ p 1) →
      AEStronglyMeasurable (T f) ν)
    (T_subadd : ∀ (f g : α → 𝕂) (x : α'), (@MeasureTheory.MemLorentz α 𝕂 μ p 1 f) →
      (@MeasureTheory.MemLorentz α 𝕂 μ p 1 g) → ‖T (f + g) x‖ ≤ ‖T f x + T g x‖)
    (T_submul : ∀ (a : 𝕂) (f : α → 𝕂) (x : α'), ‖T (a • f) x‖ ≤ ‖a‖ • ‖T f x‖)
    (weakly_cont_T : ∀ {f : α → 𝕂} {fs : ℕ → α → 𝕂}
                     (f_locInt : LocallyIntegrable f μ)
                     (hF_meas : ∀ (n : ℕ), AEStronglyMeasurable (fs n) μ)
                     (h_norm_monotone : ∀ (a : α), Monotone (fun n ↦ ‖fs n a‖))
                     (h_lim : ∀ (a : α), Filter.Tendsto (fun (n : ℕ) => fs n a) Filter.atTop (nhds (f a)))
                     (G : Set α'),
    eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n ↦ eLpNorm (T (fs n)) 1 (ν.restrict G)) Filter.atTop)
    : HasLorentzType T p 1 p ∞ μ ν (4 * c / p) := by
  intro f hf
  have claim : ∀ (G : Set α'), (MeasurableSet G) → (ν G < ∞) → eLpNorm (T f) 1 (ν.restrict G)
    ≤ (4 * c / p) * eLorentzNorm f p 1 μ * (ν G) ^ p'⁻¹.toReal := by
    intro G measurable_G G_finite
    apply HasLorentzType.hasLorentzType_bound
