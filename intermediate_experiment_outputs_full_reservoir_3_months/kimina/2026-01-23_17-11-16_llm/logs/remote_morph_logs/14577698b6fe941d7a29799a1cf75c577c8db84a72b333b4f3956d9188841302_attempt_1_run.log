    exact hM'_finite
  -- The restriction G ↾ (M ∆ M') is edge finite because G is edge finite and the set is finite
  have h2 : (G ↾ (M ∆ M')).EdgeFinite := by
    apply Graph.restrictEdgeFinite
    exact G.EdgeFinite
  -- The loopRemove operation preserves edge finiteness
  exact Graph.loopRemoveEdgeFinite h2
