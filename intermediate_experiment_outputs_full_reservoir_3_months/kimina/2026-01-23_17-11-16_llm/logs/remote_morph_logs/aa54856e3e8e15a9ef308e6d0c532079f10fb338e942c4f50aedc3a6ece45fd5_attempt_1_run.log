```tactics
def Opposite (α : Type*) := α

-- definition 1.2.1
instance Category.opp {α : Type*} [C : Category α] : Category (Opposite α) where
  Hom X Y := C.Hom Y X
  id X := C.id X
  comp f g := C.comp g f
  id_comp := by simp [comp_id]
  comp_id := by simp [id_comp]
  assoc := by simp [← assoc]

-- exmaple 1.2.2.i
def MatrixRings (α : Type*) [Ring α] : Category ℕ where
  Hom m n := Matrix (Fin m) (Fin n) α
  id := 1
  comp f g := f * g
  id_comp := by simp
  comp_id := by simp
  assoc _ _ _ := by rw [Matrix.mul_assoc]

variable {α : Type*} [C : Category α]

theorem MatrixRings_opp_eq_MatR' [Ring α] : (MatrixRings α).opp = MatrixRings' α := by sorry

-- exmaple 1.2.2.ii
noncomputable instance Category.Poset' (α : Type*) [PartialOrder α] : Category α where
  Hom X Y := PLift (Y ≤ X) -- some universe gymnastics to move between Prop and Type
  id X := ⟨le_refl X⟩
  comp f g := ⟨le_trans g.down f.down⟩
  id_comp _ := rfl
  comp_id _ := rfl
  assoc _ _ _ := rfl

theorem Poset_opp_eq_Poset' [PartialOrder α] : (Poset α).opp = Poset' α := by sorry

-- todo add 1.2.2.iii

-- lemma 1.2.3
lemma isIso_iff_isMonoAndIsEpi {X Y : α} (f : Hom X Y) :
  IsIso f ↔ (Mono f ∧ Epi f) := by
  rw [isIso_iff_isMonoAndIsEpi]
```

So Lean's library already has the equivalence we need. We can use it directly.

```tactics
theorem isIso_implies_mono_and_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    f.isMono ∧ f.isEpi := by
  rw [isIso_iff_isMonoAndIsEpi] at hf
  exact hf
```

So the proof is immediate from Lean's library.

```tactics
example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Mono f) :
    Function.Injective f := by
  simpa using hf
```

