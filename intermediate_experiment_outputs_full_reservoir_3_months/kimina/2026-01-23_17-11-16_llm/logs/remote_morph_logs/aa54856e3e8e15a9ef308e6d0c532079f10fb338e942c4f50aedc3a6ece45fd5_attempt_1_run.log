theorem category_is_isomorphism_implies_split_mono {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_split_mono f := by
  unfold category_is_split_mono
  use (f⁻¹)
  rw [comp_eq_right_inv_comp (show f ≫ f⁻¹ = id Y by tauto)]
  all_goals simp [comp_id]

theorem category_is_isomorphism_implies_split_epi {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_split_epi f := by
  unfold category_is_split_epi
  use (f⁻¹)
  rw [comp_eq_right_inv_comp (show f⁻¹ ≫ f = id X by tauto)]
  all_goals simp [comp_id]

theorem category_is_isomorphism_implies_is_retract {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_retract := by
  unfold category_is_retract
  use f
  use f⁻¹
  rw [comp_eq_right_inv_comp (show f ≫ f⁻¹ = id Y by tauto)]
  all_goals simp [comp_id]

theorem category_is_isomorphism_implies_is_composite {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : ∃ g : Hom Y X, IsIsomorphism g := by
  use f⁻¹
  exact hf.symm

theorem category_is_isomorphism_implies_is_isomorphism {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : IsIsomorphism f := by
  exact hf

theorem category_is_isomorphism_implies_mono_and_epi {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_mono f ∧ category_is_epi f := by
  constructor
  · exact category_is_isomorphism_implies_mono f hf
  · exact category_is_isomorphism_implies_epi f hf
