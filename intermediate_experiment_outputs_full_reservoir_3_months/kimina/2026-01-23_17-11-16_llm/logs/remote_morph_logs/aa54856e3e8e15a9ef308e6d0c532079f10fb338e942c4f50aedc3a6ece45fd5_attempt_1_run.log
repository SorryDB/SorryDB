          have h_eq9 : b = g ≫ (g ≫ b) := by
            rw [comp_self_eq_id]
            exact h2
          rw [h_eq8, h_eq9, h_eq6]
        exact h_eq7
      exact h_inj h_eq4
    exact h_eq5
  · -- Show f is an epimorphism
    intro h k h_eq
    have h_eq2 : g ≫ (f ≫ h) = g ≫ (f ≫ k) := by
      rw [h_eq]
    have h_eq3 : (g ≫ f) ≫ h = (g ≫ f) ≫ k := by
      rw [comp_assoc, comp_assoc] at h_eq2
      all_goals try exact h_eq2
    have h_eq4 : h = k := by
