        rw [h_eq]
      have h5 : g ≫ (h1 ≫ f) = (g ≫ h1) ≫ f := by
        simp [comp_eq_assoc]
      have h6 : g ≫ (h2 ≫ f) = (g ≫ h2) ≫ f := by
