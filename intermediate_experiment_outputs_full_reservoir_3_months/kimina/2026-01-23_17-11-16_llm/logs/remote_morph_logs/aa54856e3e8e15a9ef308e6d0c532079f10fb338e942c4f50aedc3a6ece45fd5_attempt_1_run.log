import Mathlib

open Set

noncomputable def Opposite (α : Type*) := α

-- definition 1.2.1
instance Category.opp {α : Type*} [C : Category α] : Category (Opposite α) where
  Hom X Y := C.Hom Y X
  id X := C.id X
  comp f g := C.comp g f
  id_comp := by simp [comp_id]
  comp_id := by simp [id_comp]
  assoc := by simp [← assoc]

-- exmaple 1.2.2.i
def Matrix (m n : ℕ) (α : Type*) := Fin m → Fin n → α

noncomputable instance MatrixR (α : Type*) [Ring α] : Matrix (ℕ × ℕ) α where
  Hom m n := Matrix m n α
  id m := Matrix.map (fun i => 1) (fun i => i)
  comp f g := Matrix.mul f g
  id_comp := by simp
  comp_id := by simp
  assoc _ _ _ := by rw [Matrix.mul_assoc]

variable {α : Type*} [C : Category α]

theorem MatrixR_opp_eq_MatR' [Ring α] : (MatrixR α).opp = MatrixR' α := by sorry

-- exmaple 1.2.2.ii
noncomputable instance Poset' (α : Type*) [PartialOrder α] : Category α where
  Hom X Y := PLift (Y ≤ X) -- some universe gymnastics to move between Prop and Type
  id X := ⟨le_refl X⟩
  comp f g := ⟨le_trans g.down f.down⟩
  id_comp _ := rfl
  comp_id _ := rfl
  assoc _ _ _ := rfl

theorem Poset_opp_eq_Poset' [PartialOrder α] : (Poset α).opp = Poset' α := by sorry

-- lemma 1.2.3
lemma iso_equiv {X Y : α} (f : Hom X Y) :
  [ IsIso f,
    ∀ c : α, Function.Bijective (fun g : Hom c X => g ≫ f),
    ∀ c : α, Function.Bijective (fun g : Hom Y c => f ≫ g)
  ].TFAE := by sorry

-- definition 1.2.7
def Mono {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k
def Epi {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k

lemma mono_op_epi {X Y : α} (f : Hom X Y) :
    Mono f ↔ @Epi (Opposite α) _ Y X f := by
  sorry

lemma epi_op_mono {X Y : α} (f : Hom X Y) :
    Epi f ↔ @Mono (Opposite α) _ Y X f := by
  sorry

-- example 1.2.8
-- note we need to use Category.Hom and not just Hom,
-- because we are not in the namespace Category.
example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Mono f) :
    Function.Injective f := by sorry
example {X Y : Set α} (f : Category.Hom X Y) (hf : Category.Epi f) :
    Function.Surjective f := by sorry

-- example 1.2.9
def IsSection {X Y : α} (f : Hom Y X) (g : Hom X Y) := g ≫ f = id X
def IsRetraction {X Y : α} (f : Hom X Y) (g : Hom Y X) := f ≫ g = id X
def IsRetract (X Y : α) := ∃ (f : Hom X Y), ∃ (g : Hom Y X), f ≫ g = id X

alias IsRightInverse := IsSection
alias IsLeftInverse := IsRetraction

theorem section_mono {X Y : α} (f : Hom Y X) (g : Hom X Y) (h : IsSection f g) :
    Mono f := by sorry

theorem retraction_epi {X Y : α} (f : Hom X Y) (g : Hom Y X)
    (h : IsRetraction f g) : Epi f := by sorry

def split_epi {X Y : α} (f : Hom X Y) := ∃ (g : Hom Y X), IsRetraction f g
def split_mono {X Y : α} (f : Hom Y X) := ∃ (g : Hom X Y), IsSection f g

-- example 1.2.10
theorem iso_mono {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Mono f := by
  rcases hf with ⟨g, hg1, hg2⟩
  intro h k h_eq
  have eq1 : h ≫ f ≫ g = h := by
    rw [← hg1]
    simp
  have eq2 : k ≫ f ≫ g = k := by
    rw [← hg1]
    simp
  have eq3 : h ≫ f ≫ g = k ≫ f ≫ g := by
    rw [h_eq]
  rw [eq1] at eq3
  rw [eq2] at eq3
  exact eq3

theorem iso_epi {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    Epi f := by
  rcases hf with ⟨g, hg1, hg2⟩
  intro h k h_eq
  have eq1 : g ≫ f ≫ h = g ≫ f ≫ k := by
    rw [h_eq]
  have eq2 : g ≫ f ≫ h = h := by
    rw [hg2]
    simp
  have eq3 : g ≫ f ≫ k = k := by
    rw [hg2]
    simp
  rw [eq2] at eq1
  rw [eq3] at eq1
  exact eq1
