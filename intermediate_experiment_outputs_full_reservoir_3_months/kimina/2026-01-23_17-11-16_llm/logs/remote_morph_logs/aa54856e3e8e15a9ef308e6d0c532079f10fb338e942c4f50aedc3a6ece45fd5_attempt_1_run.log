      have h_inj : Function.Injective (g) := by
        intro a b h_eq
        have h_eq6 : g ≫ a = g ≫ b := by simpa using h_eq
        have h_eq7 : a = b := by
          have h_eq8 : a = g ≫ (g ≫ a) := by
