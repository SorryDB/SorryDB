  `f ≫ (h ≫ g) = f ≫ (k ≫ g)`
  `f ≫ (h ≫ g) = f ≫ (k ≫ g)`
  `h ≫ (f ≫ g) = k ≫ (f ≫ g)`
  `h ≫ id Y = k ≫ id Y` (by `f ≫ g = id Y`)
  `h = k` (by `id Y`)

