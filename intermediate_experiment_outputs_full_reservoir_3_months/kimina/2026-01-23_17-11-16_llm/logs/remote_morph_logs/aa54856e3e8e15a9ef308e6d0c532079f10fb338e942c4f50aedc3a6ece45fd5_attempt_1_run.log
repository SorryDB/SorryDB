    Mono f ↔ @Epi (Opposite α) _ Y X f := by
  sorry

lemma Category.epi_op_mono {X Y : α} (f : Hom X Y) :
    Epi f ↔ @Mono (Opposite α) _ Y X f := by
  sorry

