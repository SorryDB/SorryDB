import Mathlib

open Set

noncomputable def IsIso {α : Type*} [C : Category α] {X Y : α} (f : Hom X Y) : Prop :=
  ∃ (g : Hom Y X), f ≫ g = id Y ∧ g ≫ f = id X

noncomputable def IsMono {α : Type*} [C : Category α] {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {W}, Function.Injective (fun (g : Hom W X) => g ≫ f)

noncomputable def IsEpi {α : Type*} [C : Category α] {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {Z}, Function.Surjective (fun (g : Hom Y Z) => f ≫ g)

theorem iso_mono {X Y : α} (f : Hom X Y) (hf : IsIso f) :
    IsMono f ∧ IsEpi f := by
  rcases hf with ⟨g, hg1, hg2⟩
  constructor
  · -- Show that f is a monomorphism
    intro W
    intro h1 h2 h_eq
    have h1_eq : h1 = h2 := by
      have eq1 : h1 ≫ f = h2 ≫ f := h_eq
      have eq2 : h1 ≫ f ≫ g = h2 ≫ f ≫ g := by
        rw [eq1]
      have eq3 : h1 ≫ f ≫ g = h1 := by 
        rw [hg2]
        all_goals simp
      have eq4 : h2 ≫ f ≫ g = h2 := by 
        rw [hg2]
        all_goals simp
      rw [eq3] at eq2
      rw [eq4] at eq2
      all_goals tauto
    exact h1_eq
  · -- Show that f is an epimorphism
    intro Z
    intro h1 h2 h_eq
    have h1_eq : h1 = h2 := by
      have eq1 : f ≫ h1 = f ≫ h2 := h_eq
      have eq2 : g ≫ f ≫ h1 = g ≫ f ≫ h2 := by 
        rw [eq1]
      have eq3 : g ≫ f ≫ h1 = h1 := by 
        rw [show g ≫ f = id X by tauto]
        all_goals simp
      have eq4 : g ≫ f ≫ h2 = h2 := by 
        rw [show g ≫ f = id X by tauto]
        all_goals simp
      rw [eq3] at eq2
      rw [eq4] at eq2
      all_goals tauto
    exact h1_eq
