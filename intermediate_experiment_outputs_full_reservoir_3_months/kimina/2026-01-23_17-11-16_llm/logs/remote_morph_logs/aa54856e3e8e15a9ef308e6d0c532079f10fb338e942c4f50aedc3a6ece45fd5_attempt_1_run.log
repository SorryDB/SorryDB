            exact eq1
          exact eq4
        have eq5 : g ≫ h1 = g ≫ h2 := by
          apply h5
          exact eq4
        exact eq5
      exact eq3
    have h5 : Function.Injective g := by
      intro a b hab
      have eq1 : f (g a) = f (g b) := by
        rw [hab]
      have eq2 : f (g a) = a := by
        simpa using hg2.symm ▸ id (f ≫ g a)
      have eq3 : f (g b) = b := by
        simpa using hg2.symm ▸ id (f ≫ g b)
      have eq4 : a = b := by
        linarith [eq1, eq2, eq3]
      exact eq4
    have h6 : h1 = h2 := by
      apply h5
      exact h4
    exact h6
  · -- Show that f is an epimorphism
    intro h1 h2 h
    have h3 : IsIso f := hf
    rcases h3 with ⟨g, hg1, hg2⟩
    have h4 : g ≫ f ≫ h1 = g ≫ f ≫ h2 := by
