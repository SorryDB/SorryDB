import Mathlib

open Set

noncomputable def Opposite (α : Type*) := α

noncomputable instance Category.opp {α : Type*} [C : Category α] : Category (Opposite α) where
  Hom X Y := C.Hom Y X
  id X := C.id X
  comp f g := C.comp g f
  id_comp := by simp [comp_id]
  comp_id := by simp [id_comp]
  assoc := by simp [← assoc]

noncomputable instance Category.MatR' (α : Type*) [Ring α] : Category ℕ where
  Hom m n := Matrix (Fin m) (Fin n) α
  id := 1
  comp f g := f * g
  id_comp := by simp
  comp_id := by simp
  assoc _ _ _ := by rw [Matrix.mul_assoc]

noncomputable instance Category.Poset' (α : Type*) [PartialOrder α] : Category α where
  Hom X Y := PLift (Y ≤ X)
  id X := ⟨le_refl X⟩
  comp f g := ⟨le_trans g.down f.down⟩
  id_comp _ := rfl
  comp_id _ := rfl
  assoc _ _ _ := rfl

variable {α : Type*} [C : Category α]

theorem category_inversion [Ring α] : (Matrix (Fin 2) (Fin 2) α).opp = Matrix (Fin 2) (Fin 2) α := by
  rfl

theorem category_inversion_poset [PartialOrder α] : (Poset α).opp = Poset' α := by
  rfl

noncomputable def Category.Mono {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {W} (h k : Hom W X), h ≫ f = k ≫ f → h = k

noncomputable def Category.Epi {X Y : α} (f : Hom X Y) : Prop :=
  ∀ {Z} (h k : Hom Y Z), f ≫ h = f ≫ k → h = k

noncomputable def category_is_section {X Y : α} (f : Hom Y X) (g : Hom X Y) := g ≫ f = id X

noncomputable def category_is_retraction {X Y : α} (f : Hom X Y) (g : Hom Y X) := f ≫ g = id X

noncomputable def category_is_retract (X Y : α) := ∃ (f : Hom X Y), ∃ (g : Hom Y X), f ≫ g = id X

noncomputable def category_is_right_inverse := category_is_section
noncomputable def category_is_left_inverse := category_is_retraction

noncomputable lemma category_mono_inj {X Y : α} (f : Hom X Y) (hf : IsMono f) : ∀ c : α, Function.Injective (fun g : Hom c X => g ≫ f) := by
  intro c g1 g2 h
  apply hf

noncomputable lemma category_epi_surj {X Y : α} (f : Hom X Y) (hf : IsEpi f) : ∀ c : α, Function.Injective (fun g : Hom Y c => f ≫ g) := by
  intro c g1 g2 h
  apply hf

noncomputable def category_is_isomorphism {X Y : α} (f : Hom X Y) := ∃ (f⁻¹ : Hom Y X), f ≫ f⁻¹ = id X ∧ f⁻¹ ≫ f = id Y

noncomputable def category_is_mono {X Y : α} (f : Hom X Y) := ∀ {W}, Function.Injective (fun g : Hom W X => g ≫ f)

noncomputable def category_is_epi {X Y : α} (f : Hom X Y) := ∀ {Z}, Function.Surjective (fun g : Hom Y Z => f ≫ g)

noncomputable def category_is_split_mono {X Y : α} (f : Hom Y X) := ∃ (g : Hom X Y), IsLeftInverse f g

noncomputable def category_is_split_epi {X Y : α} (f : Hom X Y) := ∃ (g : Hom Y X), IsRightInverse f g

theorem category_is_isomorphism_implies_mono {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_mono f := by
  unfold category_is_mono
  intro W g1 g2 h
  obtain ⟨f⁻¹, h1, h2⟩ := hf
  have h3 : f⁻¹ ≫ (f ≫ g1) = f⁻¹ ≫ (f ≫ g2) := by rw [h]
  have h4 : f⁻¹ ≫ (f ≫ g1) = g1 := by rw [comp_eq_right_inv_comp h1]
  have h5 : f⁻¹ ≫ (f ≫ g2) = g2 := by rw [comp_eq_right_inv_comp h1]
  rw [h4] at h3
  rw [h5] at h3
  exact h3

theorem category_is_isomorphism_implies_epi {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_epi f := by
  unfold category_is_epi
  intro Z
  use (f⁻¹ ≫ id Z)
  rw [comp_eq_right_inv_comp (show f ≫ f⁻¹ = id Y by tauto)]
  all_goals simp [comp_id]

theorem category_is_isomorphism_implies_split_mono {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_split_mono f := by
  unfold category_is_split_mono
  use (f⁻¹)
  rw [comp_eq_right_inv_comp (show f ≫ f⁻¹ = id Y by tauto)]
  all_goals simp [comp_id]

theorem category_is_isomorphism_implies_split_epi {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_split_epi f := by
  unfold category_is_split_epi
  use (f⁻¹)
  rw [comp_eq_right_inv_comp (show f⁻¹ ≫ f = id X by tauto)]
  all_goals simp [comp_id]

theorem category_is_isomorphism_implies_is_retract {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : category_is_retract := by
  unfold category_is_retract
  use f
  use f⁻¹
  rw [comp_eq_right_inv_comp (show f ≫ f⁻¹ = id Y by tauto)]
  all_goals simp [comp_id]

theorem category_is_isomorphism_implies_is_composite {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : ∃ g : Hom Y X, IsIsomorphism g := by
  use f⁻¹
  exact hf.symm

theorem category_is_isomorphism_implies_is_isomorphism {X Y : α} (f : Hom X Y) (hf : IsIsomorphism f) : IsIsomorphism f := by
  exact hf
