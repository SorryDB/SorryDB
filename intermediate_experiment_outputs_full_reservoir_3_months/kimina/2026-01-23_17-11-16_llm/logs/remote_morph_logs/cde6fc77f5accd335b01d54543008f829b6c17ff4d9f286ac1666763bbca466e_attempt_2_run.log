/--
Verify a proof by checking if the computed root matches the given putative root.
-/
def verifyProof {s} (idx : BinaryTree.SkeletonLeafIndex s) (actualRoot : α)
    (leafValue : α) (proof : List α) : Bool :=
  match proof with
  | [] => return actualRoot = leafValue
  | siblingBelowRootHash :: restProof =>
    match idx with
    | BinaryTree.SkeletonLeafIndex.ofLeaf =>
      return false
    | BinaryTree.SkeletonLeafIndex.ofLeft idxLeft =>
      let ancestorBelowRootHash ← getPutativeRoot idxLeft leafValue restProof
      return actualRoot = singleHash ancestorBelowRootHash siblingBelowRootHash
    | BinaryTree.SkeletonLeafIndex.ofRight idxRight =>
      let ancestorBelowRootHash ← getPutativeRoot idxRight leafValue restProof
      return actualRoot = singleHash siblingBelowRootHash ancestorBelowRootHash

/--
A functional version of `verifyProof`
-/
def verifyProof_with_hash {s} (idx : BinaryTree.SkeletonLeafIndex s)
    (actualRoot : α) (leafValue : α) (proof : List α) (hashFn : α → α → α) : Bool :=
  match proof with
  | [] => return actualRoot = leafValue
  | siblingBelowRootHash :: restProof =>
    match idx with
    | BinaryTree.SkeletonLeafIndex.ofLeaf =>
      return false
    | BinaryTree.SkeletonLeafIndex.ofLeft idxLeft =>
      let ancestorBelowRootHash := getPutativeRoot_with_hash idxLeft leafValue restProof hashFn
      return actualRoot = hashFn ancestorBelowRootHash siblingBelowRootHash
    | BinaryTree.SkeletonLeafIndex.ofRight idxRight =>
      let ancestorBelowRootHash := getPutativeRoot_with_hash idxRight leafValue restProof hashFn
      return actualRoot = hashFn siblingBelowRootHash ancestorBelowRootHash

/--
Running the monadic version of `verifyProof` with an oracle function `f`,
it is equivalent to running the functional version of `verifyProof_with_hash`
-/
lemma runWithOracle_verifyProof {s} (idx : BinaryTree.SkeletonLeafIndex s)
    (actualRoot : α) (leafValue : α) (proof : List α) (f) :
    (runWithOracle f (verifyProof idx actualRoot leafValue proof)) =
    verifyProof_with_hash idx actualRoot leafValue proof fun (left right : α) => (f ⟨left, right⟩) := by
  induction proof generalizing s' with
  | nil =>
    unfold verifyProof
    simp only [runWithOracle_pure, verifyProof, verifyProof_with_hash]
  | cons siblingBelowRootHash restProof ih =>
    unfold verifyProof
    cases s' with
    | leaf =>
      cases idx with
      | ofLeaf =>
        simp only [runWithOracle_pure]
        rfl
      | ofLeft => 
        simp only [runWithOracle_pure]
        rfl
      | ofRight => 
        simp only [runWithOracle_pure]
        rfl
    | internal s_left s_right =>
      cases idx with
      | ofLeft idxLeft =>
        simp only [verifyProof, verifyProof_with_hash, runWithOracle, runWithOracle_bind, ih]
        rfl
      | ofRight idxRight =>
        simp only [verifyProof, verifyProof_with_hash, runWithOracle, runWithOracle_comm, runWithOracle_assoc, ih]
        rfl

end InductiveMerkleTree
