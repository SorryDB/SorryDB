/--
Verify the proof by checking that the computed root matches the expected root.
-/
def verifyProof {s} (expected_root : α) (idx : BinaryTree.SkeletonLeafIndex s)
    (leafValue : α) (proof : List α) : Boolean :=
  match proof with
  | [] => return (expected_root = leafValue)
  | _ :: restProof => do
    match idx with
    | BinaryTree.SkeletonLeafIndex.ofLeaf =>
      return (expected_root = leafValue)
    | BinaryTree.SkeletonLeafIndex.ofLeft idxLeft =>
      let computed_root := getPutativeRootWithHash idxLeft leafValue restProof (fun (left right : α) => (expected_root))
      return (computed_root = expected_root)
    | BinaryTree.SkeletonLeafIndex.ofRight idxRight =>
      let computed_root := getPutativeRootWithHash idxRight leafValue restProof (fun (left right : α) => (expected_root))
      return (computed_root = expected_root)

/--
The completeness theorem: given any possible set of leaves, the probability that
the computed root matches the true root is 1.
-/
theorem completeness : ∀ (s : List (α × α)) (h : ∀ (leaves : List α), ∃ (t : Tree α), t.leaves = leaves ∧ t.isMerkleTree),
    ∀ (target : α), ∃ (leaves : List α), ∃ (t : Tree α), t.leaves = leaves ∧ t.isMerkleTree ∧
      t.getRootValue = target := by
  intro s h
  intro target
  let leaves := List.replicate s.length (target) -- Just fill the list with the target value
  let t := buildMerkleTree leaves -- Construct the tree
  use leaves
  use t
  simp [leaves, t]
  <;> try { tauto } <;> try { native_decide }
