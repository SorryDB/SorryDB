/-- **Hölder's inequality**, binary case. -/
lemma dLpNorm_mul_le (p q : ℝ≥0∞) (hr₀ : r ≠ 0) [hpqr : ENNReal.HolderTriple p q r] :
    ‖f * g‖_[r] ≤ ‖f‖_[p] * ‖g‖_[q] := by
  obtain rfl | p | q | r := hpqr
  · -- p = r
    simp [show r = p by rfl] at *
    all_goals try { tauto }
  · -- q = r
    simp [show r = q by rfl] at *
    all_goals try { tauto }
  · -- none = r
    exfalso
    tauto
  · -- r = none
    have h1 : ‖f * g‖_[none] ≤ ‖f‖_[∞] * ‖g‖_[∞] := by
      have h2 : ‖f * g‖_[none] = ‖fun x => ‖f x * g x‖₊‖₊ := by
        simp [dLpNorm_eq_sum, wInner_one_eq_sum, PiLp.norm_eq_of_Lp]
        <;> try { simp }
      have h3 : ‖fun x => ‖f x * g x‖₊‖₊ ≤ ‖fun x => ‖f x‖₊‖₊ * ‖fun x => ‖g x‖₊‖₊ := by
        have h4 : ‖fun x => ‖f x * g x‖₊‖₊ = ‖fun x => ‖f x‖₊ * ‖g x‖₊‖₊ := by
          congr
          funext i
          simp [norm_mul]
        rw [h4]
        simp [norm_mul_le]
      have h4 : ‖fun x => ‖f x‖₊ * ‖g x‖₊‖₊ = ‖fun x => ‖f x‖₊‖₊ * ‖fun x => ‖g x‖₊‖₊ := by
        simp [norm_mul]
      linarith [h2, h3, h4]
    simp [show r = none by rfl] at *
    all_goals try { tauto }
```

