import Mathlib

open Graph

def inessential (G : Graph α β) (x : α) : Prop :=
  ∃ M, G.IsMaxMatching M ∧ x ∉ V(G, M)

def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  -- Axiom 1: The empty set is independent.
  axiom_empty : ∅ ∈ Indep := by
    use ∅
    simp
  -- Axiom 2: Any subset of an independent set is independent.
  axiom_subset : ∀ s ∈ Indep, ∀ t ⊆ s, t ∈ Indep := by
    intros s hs t ht
    rcases hs with ⟨M, hM, hMs⟩
    use M
    exact ⟨hM, ht ▸ hMs⟩
  -- Axiom 3: The augmenting property
  axiom_augment : ∀ s ∈ Indep, ∀ t ∈ Indep, s ⊆ t → s ∈ t → s ≠ t → ∃ v ∈ t \ s, s ∪ {v} ∈ Indep := by
    intros s hs t ht hsub hne
    rcases hs with ⟨M, hM, hMs⟩
    rcases ht with ⟨M', hM', hMt⟩
    have hne' : s ≠ t := hne
    have h1 : s ⊆ t := hsub
    have h2 : s ≠ t := hne
    have h5 : t \ s ≠ ∅ := by
      by_contra h
      have h6 : t \ s = ∅ := by
        simpa using h
      have h7 : t = s := by
        have h8 : t \ s = ∅ := h6
        have h9 : t = s ∪ (t \ s) := by
          ext x
          simp [Set.mem_union, Set.mem_sdiff, Set.mem_singleton_iff]
          <;> tauto
        rw [h8] at h9
        have h10 : t = s ∪ ∅ := h9
        simp at h10
        tauto
      contradiction
    rcases h5 with ⟨v, hv⟩
    use v
    constructor
    · -- Show that v ∈ t \ s
      exact hv
    · -- Show that s ∪ {v} ∈ Indep
      have h7 : v ∈ t := by
        simpa using hv.1
      have h8 : v ∉ s := by
        simpa using hv.2
      have h9 : ∃ M, G.IsMatching M ∧ s ∪ {v} ⊆ V(G, M) := by
        have h10 : v ∈ t := h7
        have h11 : v ∉ s := h8
        have h12 : v ∈ V(G, M') := by
          have h13 : v ∈ t := h10
          have h14 : t ⊆ V(G, M') := by
            simpa using hMt
          have h15 : v ∈ V(G, M') := by
            apply h14
            exact h13
          exact h15
        have h13 : v ∉ V(G, M) := by
          by_contra h
          have h14 : v ∈ s := by
            have h15 : v ∈ V(G, M) := by
              simpa using h
            have h16 : v ∈ s := by
              have h17 : s ⊆ V(G, M) := by
                simpa using hMs
              have h18 : v ∈ V(G, M) := h15
              have h19 : v ∈ s := by
                apply h17
                exact h18
              exact h19
            exact h16
          contradiction
        have h14 : ∃ P, P.IsAlternatingPath M M' ∧ P.isChain ∧ P.mem v := by
          have h15 : v ∈ V(G, M') \ V(G, M) := by
            simp [Set.mem_sdiff, h12, h13]
          have h16 : ∃ P, P.IsAlternatingPath M M' ∧ P.isChain ∧ P.mem v := by
            apply G.exists_isAlternatingPath_from_diff
            all_goals
              try { tauto }
              try { 
                have h17 : v ∈ V(G, M') \ V(G, M) := h15
                simp [Set.mem_sdiff] at h17
                tauto
              }
          assumption
        rcases h14 with ⟨P, hP, hPchain, hPv⟩
        have h18 : ∃ M, G.IsMatching M ∧ s ∪ {v} ⊆ V(G, M) := by
          have h19 : ∃ M, G.IsMatching M ∧ s ∪ {v} ⊆ V(G, M) := by
            have h20 : P.IsAlternatingPath M M' := hP
            have h21 : P.isChain := hPchain
            have h22 : P.mem v := hPv
            have h23 : v ∈ V(G, M') \ V(G, M) := by
              simp [Set.mem_sdiff, h12, h13]
            have h24 : ∃ M, G.IsMatching M ∧ s ∪ {v} ⊆ V(G, M) := by
              have h25 : M' ∆ M = (M' ∆ M).subgraph := by
                simp
              have h26 : P.IsAlternatingPath M M' := hP
              have h27 : P.isChain := hPchain
              have h28 : P.mem v := hPv
              have h29 : ∃ M, G.IsMatching M ∧ s ∪ {v} ⊆ V(G, M) := by
                apply (G.exists_isAlternatingPath_from_diff (by tauto) (by tauto)).resolve_left
                all_goals
                  try { tauto }
                  try { 
                    have h31 : v ∈ V(G, M') \ V(G, M) := by
                      simp [Set.mem_sdiff, h12, h13]
                    simp [Set.mem_sdiff] at h31
                    tauto
                  }
              assumption
            assumption
          assumption
        assumption
      assumption
    assumption

def matchingMatroid (G : Graph α β) : Matroid α := (matchingIndepMatroid G).matroid

lemma matchingMatroid.noColoop (h : ∀ x, G.inessential x) (hx : x ∈ V(G)) :
    ¬ G.matchingMatroid.IsColoop x := by
  simp [matchingIndepMatroid, hx]
  intro h
  have h1 : ∀ M, G.IsMatching M → x ∈ V(G, M) := by
    intro M hM
    have h2 := h M hM
    simpa using h2
  have h2 := h1 (∅) (by simp)
  simp at h2
