import Mathlib
open Real
open scoped BigOperators

noncomputable namespace SteinsLemma

-- Define the problem context and constants
-- ι is the type of indices
-- inst is the instance of the UnitalFreeStateTheory
-- i is an index
-- ρ is a state
-- σ is a function from ℕ to IsFree (representing a sequence of states or operations)
-- ε, ε' are probabilities
-- hε'₁, hε'₂, hε are bounds on ε and ε'
-- hR1R2 are bounds on R1 and R2
-- hR1, hR2 are non-triviality conditions on R1 and R2
-- hε₀ is a constant ε₀
-- m is a natural number
-- hm is a hypothesis about the limit of a sequence involving hypothesis rates
-- ℰ is a sequence of pinching maps
-- ε₀ is the constant ε₀ from the problem statement
-- hε₀' relates ε₀ to R1 and R2
-- hliminf_le and hlimsup_le are limit inequalities
-- P1, P2 are projection operators
-- E1, E2, E3 are projection operators
-- Esum is E1+E2+E3=1
-- hE1proj, hE2leProj relate E1, E2 to hypothesis rates
-- c' is a function from ℝ to ℕ → ℝ
-- hc' is a property of c'
-- hσ'' is a property of σ''
-- hE3commℰ is a commutation property
-- ε2, n are variables for the theorem
-- hε2, hn are positivity conditions

-- The main theorem statement
theorem main (ε2 : ℝ) (n : ℕ) (hε2 : 0 < ε2) (hn : 0 < n) : (D(ℰ n (ρ⊗^S[n])‖σ'' ρ ε m σ n) / n : ℝ≥0∞) ≤  ((R1 ρ ε) + ε2) +
    ((P1 ε2 n).inner (ℰ n (ρ⊗^S[n]))) * ((R2 ρ σ + ε₀ + ε2) - (R1 ρ ε + ε2)) +
    ((P2 ε2 n).inner (ℰ n (ρ⊗^S[n]))) * (c' ε2 n - (R2 ρ σ + ε₀ + ε2)) := by
  have h1 : (E1 ε2 n + E2 ε2 n + E3 ε2 n : HermitianMat (H (i ^ n)) ℂ) = 1 := by
    simp [E1, E2, E3, P1, P2, reduceIte, if_true, if_false]
    <;> ring
  simp [D, reduceIte, if_true, if_false, h1] at *
  <;> linarith [hE1leq, hE2leq, hE3leq, h1]
