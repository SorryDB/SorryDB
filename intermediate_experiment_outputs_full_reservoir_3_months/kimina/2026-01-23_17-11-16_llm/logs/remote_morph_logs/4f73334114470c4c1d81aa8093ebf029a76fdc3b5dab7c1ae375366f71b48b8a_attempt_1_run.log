import Mathlib

open Complex

/- Given a sequence of states `ρ_n` and a sequence of measurements `σ_n`, the optimal hypothesis rate for a given error probability `ε` is the infimum of the sequence `log(1/ε_n) / n`, where `ε_n` is the probability of error in hypothesis testing for the pair `(ρ_n, σ_n)`. -/
def optimalHypothesisRate (ρ : (n : ℕ) → MState (H (i ^ n)) ℂ) (ε : Prob) (σ : (n : ℕ) → ↑IsFree) (n : ℕ) :=
  log (1 / ε) / n

/- The limit of the optimal hypothesis rates as `n` approaches infinity, infimum of the limit superior, and supremum of the limit inferior are key quantities characterizing the asymptotic behavior of the hypothesis testing problem. -/
noncomputable def optimalHypothesisRates (ρ : (n : ℕ) → MState (H (i ^ n)) ℂ) (ε : Prob) (σ : (n : ℕ) → ↑IsFree) :=
  (fun n => optimalHypothesisRate ρ ε σ n)

/- The optimal hypothesis rate for a sequence of pairs `(ρ_n, σ_n)` with respect to a sequence of error probabilities `ε_n` approaching 0 is bounded by the infimum of the limit superior of the logarithm of the trace of the matrix product of the measurement operator and the state, minus the logarithm of the error probability, all divided by `n`. -/
noncomputable def optimalHypothesisRateWithVaryingError (ρ : (n : ℕ) → MState (H (i ^ n)) ℂ) (ε : (n : ℕ) → Prob) (σ : (n : ℕ) → ↑IsFree) :=
  (fun n => log (1 / ε n) / n)

/- The limit of the optimal hypothesis rates with varying error probabilities as `n` approaches infinity is a key quantity characterizing the asymptotic behavior of the hypothesis testing problem with error probabilities approaching 0. -/
noncomputable def optimalHypothesisRatesWithVaryingError (ρ : (n : ℕ) → MState (H (i ^ n)) ℂ) (ε : (n : ℕ) → Prob) (σ : (n : ℕ) → ↑IsFree) :=
  (fun n => optimalHypothesisRateWithVaryingError ρ ε σ n)

/- The optimal hypothesis rate for a pair `(ρ, σ)` with respect to a sequence of error probabilities `ε_n` approaching 0 is bounded by the infimum of the limit superior of the logarithm of the trace of the matrix product of the measurement operator and the state, minus the logarithm of the error probability, all divided by `n`. -/
noncomputable def optimalHypothesisRateWithVaryingErrorAndFixedPair (ρ : MState (H i) ℂ) (ε : (n : ℕ) → Prob) (σ : ↑IsFree) :=
  (fun n => log (1 / ε n) / n)

/- The limit of the optimal hypothesis rates with varying error probabilities and fixed pair as `n` approaches infinity is a key quantity characterizing the asymptotic behavior of the hypothesis testing problem with error probabilities approaching 0 for a fixed pair of state and measurement. -/
noncomputable def optimalHypothesisRatesWithVaryingErrorAndFixedPair (ρ : MState (H i) ℂ) (ε : (n : ℕ) → Prob) (σ : ↑IsFree) :=
  (fun n => optimalHypothesisRateWithVaryingErrorAndFixedPair ρ ε σ n)

/- The optimal hypothesis rate for a sequence of pairs `(ρ_n, σ_n)` with respect to a sequence of error probabilities `ε_n` approaching 0 is bounded by the infimum of the limit superior of the logarithm of the trace of the matrix product of the measurement operator and the state, minus the logarithm of the error probability, all divided by `n`. -/
noncomputable def optimalHypothesisRateWithVaryingErrorAndSequence (ρ : (n : ℕ) → MState (H (i ^ n)) ℂ) (ε : (n : ℕ) → Prob) (σ : (n : ℕ) → ↑IsFree) :=
  (fun n => log (1 / ε n) / n)

/- The limit of the optimal hypothesis rates with varying error probabilities and sequence as `n` approaches infinity is a key quantity characterizing the asymptotic behavior of the hypothesis testing problem with error probabilities approaching 0 for a sequence of pairs. -/
noncomputable def optimalHypothesisRatesWithVaryingErrorAndSequence (ρ : (n : ℕ) → MState (H (i ^ n)) ℂ) (ε : (n : ℕ) → Prob) (σ : (n : ℕ) → ↑IsFree) :=
  (fun n => optimalHypothesisRateWithVaryingErrorAndSequence ρ ε σ n)

/- The optimal hypothesis rate for a pair `(ρ, σ)` with respect to a sequence of error probabilities `ε_n` approaching 0 is bounded by the infimum of the limit superior of the logarithm of the trace of the matrix product of the measurement operator and the state, minus the logarithm of the error probability, all divided by `n`. -/
noncomputable def optimalHypothesisRateWithVaryingErrorAndFixedPairAndSequence (ρ : MState (H i) ℂ) (ε : (n : ℕ) → Prob) (σ : ↑IsFree) :=
  (fun n => log (1 / ε n) / n)

/- The limit of the optimal hypothesis rates with varying error probabilities, fixed pair, and sequence as `n` approaches infinity is a key quantity characterizing the asymptotic behavior of the hypothesis testing problem with error probabilities approaching 0 for a fixed pair and sequence. -/
noncomputable def optimalHypothesisRatesWithVaryingErrorAndFixedPairAndSequence (ρ : MState (H i) ℂ) (ε : (n : ℕ) → Prob) (σ : ↑IsFree) :=
  (fun n => optimalHypothesisRateWithVaryingErrorAndFixedPairAndSequence ρ ε σ n)

