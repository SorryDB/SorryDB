/- A measure is finite if its total value is finite. -/
abbrev IsFiniteMeasure (μ : Measure α) : Prop :=
  IsFinite (μ univ)

/- A measure is locally finite if every point has a finite neighborhood. -/
abbrev IsLocallyFiniteMeasure (μ : Measure α) : Prop :=
