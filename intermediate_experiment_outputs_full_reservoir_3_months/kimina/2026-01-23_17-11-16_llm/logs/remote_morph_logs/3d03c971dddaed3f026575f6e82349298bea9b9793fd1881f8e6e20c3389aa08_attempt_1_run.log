import Mathlib
open Filter Set

/- The norm of the identity map on complex numbers is 1 if the identity map is not zero, and 0 if it is zero. -/
lemma RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

