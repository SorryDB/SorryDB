import HTPILib.Chap8Part2
namespace HTPI.Exercises

open Classical

/- Section 8.1 -/
-- 1.
--Hint:  Use Exercise_6_1_16a2 from the exercises of Section 6.1
lemma fnz_odd (k : Nat) : fnz (2 * k + 1) = -↑(k + 1) := sorry

-- 2.
lemma fnz_fzn : fnz ∘ fzn = id  := sorry

-- 3.
lemma tri_step (k : Nat) : tri (k + 1) = tri k + k + 1 := sorry

-- 4.
lemma tri_incr {j k : Nat} (h1 : j ≤ k) : tri j ≤ tri k := sorry

-- 5.
example {U V : Type} (f : U → V) : range f = Ran (graph f) := sorry

-- 6.
lemma onto_iff_range_eq_univ {U V : Type} (f : U → V) :
    onto f ↔ range f = Univ V := sorry

-- 7.
-- Don't use ctble_iff_set_nat_equinum to prove this lemma
lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := sorry

-- 8.
theorem Exercise_8_1_1_b : denum {n : Int | even n} := sorry

-- 9.
theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := sorry

-- 10.
lemma image_comp_id {U V : Type} {f : U → V} {g : V → U}
    (h : g ∘ f = id) : (image g) ∘ (image f) = id := sorry

-- 11.
theorem Exercise_8_1_5_1 {U V : Type}
    (h : U ∼ V) : Set U ∼ Set V := by
  rcases h with ⟨f, g, hf, hg⟩
  use fun s => f '' s
  constructor
  · -- Show F is injective
    intro s1 s2 h1
    ext x
    simp [Set.mem_image, Set.mem_setOf_eq] at h1 ⊢
    constructor
    · -- Assume x ∈ s1
      rintro ⟨y, hy, hxy⟩
      have h2 : x ∈ f '' s2 := by
        simpa using h1 (show x ∈ f '' s1 by simpa using ⟨y, hy, hxy⟩)
      rcases h2 with ⟨z, hz, hfx⟩
      have h_eq : z = y := by
        have h1 : f z = f y := by
          rw [hfx, hxy]
        have h2 : z = y := by
          have h3 : g (f z) = z := by
            simpa using congr_fun hg z
          have h4 : g (f y) = y := by
            simpa using congr_fun hg y
          have h5 : g (f z) = g (f y) := by
            rw [h1]
          have h6 : z = y := by
            simpa using h5
          exact h6
        exact h2
      tauto
    · -- Assume x ∈ s2
      rintro ⟨y, hy, hxy⟩
      have h1 : x ∈ f '' s1 := by
        simpa using h1 (show x ∈ f '' s2 by simpa using ⟨y, hy, hxy⟩)
      rcases h1 with ⟨z, hz, hfx⟩
      have h_eq : z = y := by
        have h1 : f z = f y := by
          rw [hfx, hxy]
        have h2 : z = y := by
          have h3 : g (f z) = z := by
            simpa using congr_fun hg z
          have h4 : g (f y) = y := by
            simpa using congr_fun hg y
          have h5 : g (f z) = g (f y) := by
            rw [h1]
          have h6 : z = y := by
            simpa using h5
          exact h6
        exact h2
      tauto
  · -- Show F is surjective
    intro s
    use g '' s
    ext x
    simp [Set.mem_image, Set.mem_setOf_eq]
    constructor
    · -- Assume x ∈ f '' (g '' s)
      rintro ⟨y, hy, hxy⟩
      have h1 : y ∈ g '' s := hy
      rcases h1 with ⟨z, hz, hgy⟩
      have h2 : f z = x := by
        have h3 : f (g z) = z := by
          simpa using congr_fun hf z
        have h4 : g z = y := by
          tauto
        have h5 : f y = x := by
          tauto
        have h6 : f (g z) = f y := by
          rw [h4]
        have h7 : f (g z) = z := by
          simpa using congr_fun hf z
        linarith
      have h3 : z ∈ s := hz
      have h4 : x = z := by
        have h5 : f z = x := by
          tauto
        have h6 : f z = z := by
          have h7 : f (g z) = z := by
            simpa using congr_fun hf z
          have h8 : g z = y := by
            tauto
          have h9 : f y = x := by
            tauto
          have h10 : f (g z) = f y := by
            rw [h8]
          have h11 : f (g z) = z := by
            simpa using congr_fun hf z
          linarith
        linarith
      rw [show x = z by tauto]
      exact hz
    · -- Assume x ∈ s
      intro hx
      have h1 : x ∈ s := hx
      have h3 : f (g x) = x := by
        simpa using congr_fun hf x
      have h4 : g x ∈ g '' s := by
        simpa using h1
      refine ⟨g x, h4, h3⟩
