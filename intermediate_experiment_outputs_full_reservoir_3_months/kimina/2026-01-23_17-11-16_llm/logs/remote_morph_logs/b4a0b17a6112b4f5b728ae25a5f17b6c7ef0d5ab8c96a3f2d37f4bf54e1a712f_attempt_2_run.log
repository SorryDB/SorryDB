        exact h1
      rcases h2 with ⟨y, hy, h3⟩
      have h4 : y = x := by
        apply hf.1
        exact h3
      rw [h4] at hy
      exact hy
  · -- Show that the function is surjective
    intro t
    use {x : U | f x ∈ t}
    ext y
    simp [Set.mem_image, Set.mem_setOf_eq]
