import Mathlib

noncomputable def Matrix.sharedEigenvalueA {A B : Matrix d d 𝕜} (hA : A.IsHermitian) (hB : B.IsHermitian) (hAB : Commute A B) (j : d) : ℝ :=
  RCLike.re (dotProduct (Matrix.sharedEigenbasis hA hB hAB j) (A *ᵥ WithLp.ofLp (Matrix.sharedEigenbasis hA hB hAB j)))

noncomputable def Matrix.sharedEigenvectorUnitary {A B : Matrix d d 𝕜} (hA : A.IsHermitian) (hB : B.IsHermitian) (hAB : Commute A B) : Matrix.unitaryGroup d 𝕜 :=
  ⟨(EuclideanSpace.basisFun d 𝕜).toBasis.toMatrix (Matrix.sharedEigenbasis hA hB hAB).toBasis,
    (EuclideanSpace.basisFun d 𝕖).toMatrix_orthonormalBasis_mem_unitary (Matrix.sharedEigenbasis hA hB hAB)⟩

noncomputable def Matrix.sharedEigenvectorUnitary' {A B : Matrix d d 𝕜} (hA : A.IsHermitian) (hB : B.IsHermitian) (hAB : Commute A B) : Matrix.unitaryGroup d 𝕜 :=
  LinearMap.sharedEigenvectorUnitary (isHermitian_iff_isSymmetric.mp hA)
    (isHermitian_iff_isSymmetric.mp hB) (commute_euclideanLin hAB)

theorem Matrix.mulVec_sharedEigenbasis (j : d) :
    A *ᵥ (Matrix.sharedEigenbasis hA hB hAB j) =
    (Matrix.sharedEigenvalueA hA hB hAB) j • WithLp.ofLp (Matrix.sharedEigenbasis hA hB hAB j) := by
  have h1 : IsDiagonalizable (A) := by
    exact hA.isDiagonalizable
  have h2 : (A *ᵥ (Matrix.sharedEigenbasis hA hB hAB j)) =
      (RCLike.re (dotProduct (Matrix.sharedEigenbasis hA hB hAB j) (A *ᵥ WithLp.ofLp (Matrix.sharedEigenbasis hA hB hAB j)))) • (WithLp.ofLp (Matrix.sharedEigenbasis hA hB hAB j)) := by
    have h_eq : (RCLike.re (dotProduct (Matrix.sharedEigenbasis hA hB hAB j) (A *ᵥ WithLp.ofLp (Matrix.sharedEigenbasis hA hB hAB j)))) = (A *ᵥ (Matrix.sharedEigenbasis hA hB hAB j)).re := by
      have h_eq3 : (dotProduct (Matrix.sharedEigenbasis hA hB hAB j) (A *ᵥ WithLp.ofLp (Matrix.sharedEigenbasis hA hB hAB j))) = (A *ᵥ (Matrix.sharedEigenbasis hA hB hAB j)).re := by
