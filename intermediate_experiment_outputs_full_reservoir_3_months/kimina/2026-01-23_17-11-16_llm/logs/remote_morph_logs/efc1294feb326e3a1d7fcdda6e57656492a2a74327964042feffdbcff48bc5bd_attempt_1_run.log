import Mathlib

/- Definition of a Hermitian matrix. -/
structure Matrix.IsHermitian (A : Matrix d d 𝕜) : Prop :=
  ∃ U : Matrix d d 𝕜, U.IsUnitary ∧ A = U * (diagonal (RCLike.ofReal ∘ fun i => (RCLike.ofReal ∘ A.diag i))) * Uᴴ

/- Definition of a unitary matrix. -/
structure Matrix.IsUnitary (U : Matrix d d 𝕜) : Prop :=
  U * Uᴴ = 1 ∧ Uᴴ * U = 1

/- Definition of a diagonal matrix. -/
structure Matrix.IsDiagonal (A : Matrix d d 𝕜) : Prop :=
  ∃ D : d → 𝕜, ∀ i j, i ≠ j → A i j = 0

/- Definition of a projection matrix. -/
structure Matrix.IsProjection (P : Matrix d d 𝕜) : Prop :=
  P * P = P

/- Definition of a positive semi-definite matrix. -/
structure Matrix.IsPositiveSemiDefinite (A : Matrix d d 𝕜) : Prop :=
  A.IsHermitian ∧ ∀ v : EuclideanSpace 𝕜 d, v.restrictToSubspace (EuclideanSpace.subspace_univ) = v.restrictToSubspace (EuclideanSpace.subspace_univ) → 0 ≤ inner 𝕜 v (A *ᵥ v)

