import Mathlib

variable (hA : A.IsHermitian) (hB : B.IsHermitian) (hAB : Commute A B)

noncomputable def sharedEigenvectorUnitary (hA : A.IsHermitian) (hB : B.IsHermitian)
    (hAB : Commute A B) : Matrix.unitaryGroup d 𝕜 := sorry

noncomputable def sharedEigenvalueA (j : d) : ℝ :=
  RCLike.re (dotProduct (sharedEigenbasis hA hB hAB j) (A *ᵥ WithLp.ofLp (sharedEigenbasis hA hB hAB j)))

noncomputable def sharedEigenvalueB (j : d) : ℝ :=
  RCLike.re (dotProduct (sharedEigenbasis hA hB hAB j) (B *ᵥ WithLp.ofLp (sharedEigenbasis hA hB hAB j)))

theorem sharedEigenvectorUnitary_mulVec (j : d) : (sharedEigenvectorUnitary hA hB hAB) *ᵥ
    Pi.single j 1 = WithLp.ofLp (sharedEigenbasis hA hB hAB j) := by
  simp_all only [mulVec_single, MulOpposite.op_one, one_smul]
  rfl

theorem mulVec_sharedEigenbasis (j : d) :
    A *ᵥ (sharedEigenbasis hA hB hAB j) =
    (sharedEigenvalueA hA hB hAB) j • WithLp.ofLp (sharedEigenbasis hA hB hAB j) := by
  have h1 : A *ᵥ (sharedEigenbasis hA hB hAB j) = (hA.eigenvalues j) • WithLp.ofLp (sharedEigenbasis hA hB hAB j) := by
    simpa using hA.mulVec_eigenvectorBasis j
  have h2 : (hA.eigenvalues j : ℝ) = (sharedEigenvalueA hA hB hAB) j := by
    have h_eq : (dotProduct (sharedEigenbasis hA hB hAB j) (A *ᵥ WithLp.ofLp (sharedEigenbasis hA hB hAB j)) : 𝕜) = (hA.eigenvalues j : ℝ) := by
