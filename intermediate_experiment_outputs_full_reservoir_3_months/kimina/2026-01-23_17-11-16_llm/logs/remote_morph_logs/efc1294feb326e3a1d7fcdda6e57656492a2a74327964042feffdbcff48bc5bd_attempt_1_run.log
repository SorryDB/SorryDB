/- Matrix properties -/
namespace Matrix

variable (d : ℕ)

/- The definition of a Hermitian matrix. -/
structure IsHermitian (A : Matrix d d 𝕜) : Prop where
  hA : ∀ v : d → 𝕜, (A *ᵥ v) = (A* v) := by
    intro v
    apply Matrix.mulVec_eq_conjMulVec

/- The definition of a symmetric matrix. -/
structure IsSymmetric (A : Matrix d d 𝕜) : Prop where
  hA : ∀ v : d → 𝕜, (A *ᵥ v) = (A* v) := by
    intro v
    apply Matrix.mulVec_eq_transposeVec

/- The definition of a unitary matrix. -/
structure IsUnitary (A : Matrix d d 𝕜) : Prop where
  hA : A * A* = 1 := by
    intro v
    apply Matrix.mulVec_eq_oneVec

/- The definition of a diagonal matrix. -/
structure IsDiagonal (A : Matrix d d 𝕜) : Prop where
  hA : ∀ i j : d, i ≠ j → A i j = 0 := by
    intro i j ne
    apply Matrix.zeroOffDiagonal

/- The definition of a projection matrix. -/
structure IsProjection (A : Matrix d d 𝕜) : Prop where
  hA : A * A = A := by
    intro v
    apply Matrix.mulVec_eq_self

/- The definition of a positive definite matrix. -/
structure IsPositiveDefinite (A : Matrix d d 𝕜) : Prop where
  hA : ∀ v : d → 𝕜, v ≠ 0 → 0 < v * (A *ᵥ v) := by
    intro v hv
    apply Matrix.posDefinite_innerProduct

/- The definition of a positive semidefinite matrix. -/
structure IsPositiveSemidefinite (A : Matrix d d 𝕜) : Prop where
  hA : ∀ v : d → 𝕜, v ≠ 0 → 0 ≤ v * (A *ᵥ v) := by
    intro v hv
    apply Matrix.posSemiDefinite_innerProduct

/- The definition of a negative definite matrix. -/
structure IsNegativeDefinite (A : Matrix d d 𝕜) : Prop where
  hA : ∀ v : d → 𝕜, v ≠ 0 → v * (A *ᵥ v) < 0 := by
    intro v hv
    apply Matrix.negDefinite_innerProduct

/- The definition of a negative semidefinite matrix. -/
structure IsNegativeSemidefinite (A : Matrix d d 𝕜) : Prop where
  hA : ∀ v : d → 𝕜, v ≠ 0 → v * (A *ᵥ v) ≤ 0 := by
    intro v hv
    apply Matrix.negSemiDefinite_innerProduct

/- The definition of a matrix with a zero determinant. -/
structure IsSingular (A : Matrix d d 𝕜) : Prop where
  hA : det A = 0 := by
    intro v
    apply Matrix.singular_determinant

/- The definition of a non-singular matrix. -/
structure IsNonSingular (A : Matrix d d 𝕜) : Prop where
  hA : det A ≠ 0 := by
    intro v
    apply Matrix.nonSingular_determinant

/- The definition of a diagonalizable matrix. -/
structure IsDiagonalizable (A : Matrix d d 𝕜) : Prop where
  hA : ∃ P D, A = P * D * P⁻¹ := by
    intro v
    apply Matrix.diagonalizable

/- The definition of a normal matrix. -/
structure IsNormal (A : Matrix d d 𝕜) : Prop where
  hA : A * A* = A* * A := by
    intro v
    apply Matrix.normal_innerProduct

/- The definition of a triangular matrix. -/
structure IsTriangular (A : Matrix d d 𝕜) : Prop where
  hA : ∀ i j : d, i > j → A i j = 0 := by
