    intro x
    rw [Submodule.eq_top_iff'] at h_sum
    specialize h_sum x
    rw [Submodule.mem_iSup_iff_exists_finsupp] at h_sum
    rcases h_sum with ⟨f, hf₁, hf₂⟩
