```lean
import Foundation.Propositional.Hilbert.F.Deduction
import Foundation.Propositional.Kripke2.Basic

namespace LO.Propositional

open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {Оұ : Type*}
variable {S} [Entailment S (Formula Оұ)]
variable {рқ“ў : S}

structure FTheory (L : Logic в„•) where
  protected theory : FormulaSet в„•
  protected no_bot : вҠҘ вҲү theory
  protected andIR : вҲҖ {ПҶ ПҲ}, ПҶ вҲҲ theory вҶ’ ПҲ вҲҲ theory вҶ’ ПҶ вӢҸ ПҲ вҲҲ theory
  protected imp_closed : вҲҖ {ПҶ ПҲ}, L вҠў ПҶ вһқ ПҲ вҶ’ ПҶ вҲҲ theory вҶ’ ПҲ вҲҲ theory
  protected L_subset : L вҠҶ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {ПҶ ПҲ ПҮ : Formula в„•}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hПҶ : L вҠў ПҶ) : ПҶ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := вҠӨ) $ af hПҶ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (hвӮҒ : ПҶ вһқ ПҲ вҲҲ T.theory) (hвӮӮ : ПҲ вһқ ПҮ вҲҲ T.theory) : ПҶ вһқ ПҮ вҲҲ T.theory := by
  apply T.imp_closed (axiomI (ПҲ := ПҲ));
  apply T.andIR hвӮҒ hвӮӮ;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hПҶ : ПҶ вҲҲ T.theory) : ПҶ вӢҺ ПҲ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := ПҶ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hПҲ : ПҲ вҲҲ T.theory) : ПҶ вӢҺ ПҲ вҲҲ T.theory := by
  apply T.imp_closed (ПҶ := ПҲ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ПҶ вҲҲ T.theory вҶ” Deduction Ax T.theory ПҶ := by
  constructor;
  . intro hПҶ;
    apply Deduction.ctx hПҶ;
  . intro h; induction h <;> grind

end FTheory


variable {L : Logic в„•}

structure PrimeFTheory (L : Logic в„•) extends FTheory L where
  protected prime : вҲҖ {ПҶ ПҲ}, ПҶ вӢҺ ПҲ вҲҲ theory вҶ’ ПҶ вҲҲ theory вҲЁ ПҲ вҲҲ theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {ПҶ ПҲ ПҮ Оҫ : Formula в„•} {T : FTheory L} {hT : ПҮ вһқ Оҫ вҲү T.theory}

def construction (T : FTheory L) (hT : ПҮ вһқ Оҫ вҲү T.theory) : в„• вҶ’ Set (Formula в„•)
  | 0 => { Оҙ | ПҮ вһқ Оҙ вҲҲ T.theory }
  | i + 1 =>
    match (decode i) with
    | some Оҙ =>
      letI T' := construction T hT i
      if вҲҖ (Оі : Formula в„•), вҶ‘{Оі} вҠҶ T' вҶ’ (Оі вҶ’ Оҫ) вҲү T.then insert Оҙ T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : ПҮ вһқ Оҫ вҲү T.theory) : Set (Formula в„•) := вӢғ i, construction T hT i

lemma subset_construction_succ : construction T hT i вҠҶ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i вҠҶ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i вүӨ j) : construction T hT i вҠҶ construction T hT j := by
  obtain вҹЁk, rflвҹ© := le_iff_exists_add.mp hij;
  apply subset_construction_add k;

lemma mem_omega_of_mem (h : ПҮ вһқ Оҙ вҲҲ T.theory) : Оҙ вҲҲ construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion];
  use 0;
  simpa [construction];

lemma of_mem_construction_omega {ПҶ : Formula в„•} (hПҶ : ПҶ вҲҲ construction_omega T hT) :
  (ПҮ вһқ ПҶ вҲҲ T.theory) вҲЁ (вҲҖ (О“ : Finset (Formula _)), вҶ‘О“ вҠҶ construction T hT (encode ПҶ) вҶ’ О“.conj вӢҸ ПҶ вһқ Оҫ вҲү T) := by
  obtain вҹЁi, hiвҹ© := by simpa [construction_omega] using hПҶ;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
    dsimp [construction] at hi;
    split at hi;
    . split_ifs at hi with h;
      . rename_i Оҙ hОҙ;
        by_contra hC;
        have : Оҙ = ПҶ := by grind;
        subst this;
        apply h вҲ… (by tauto);
        all_goals tauto;
      . assumption
    . assumption
    . assumption

lemma not_of_mem_construction_omega {ПҶ : Formula в„•}
  {О“ : Finset (Formula в„•)} (hО“ : вҶ‘О“ вҠҶ construction T hT (encode ПҶ))
  (hПҶ : О“.conj вӢҸ ПҶ вһқ Оҫ вҲҲ T.theory) :
  ПҶ вҲү (construction_omega T hT) := by
  simp [construction_omega, Set.mem_iUnion];
  intro i;
  induction i with
  | zero =>
    simp [construction];
    intro hC; apply hПҶ; assumption;
  | succ i ih =>
    contrapose! ih;
    dsimp [construction] at ih;
    split at ih;
    . split_ifs at ih with h;
      . rename_i Оҙ hОҙ;
        by_contra hC;
        have : Оҙ = ПҶ := by grind;
        subst this;
        apply h вҲ… (by tauto); assumption;
      . assumption
    . assumption;
    . assumption

lemma of_not_mem_construction_omega {ПҶ : Formula в„•} (hПҶ : ПҶ вҲү construction_omega T hT) :
  (ПҮ вһқ ПҶ вҲү T.theory) вҲ§ (вҲғ (О“ : Finset (Formula _)), вҶ‘О“ вҠҶ (construction T hT (encode ПҶ)) вҲ§ (О“.conj вӢҸ ПҶ) вһқ Оҫ вҲҲ T) := by
  simp only [construction_omega, Set.mem_iUnion, not_exists] at hПҶ;
  constructor;
  . simpa using hПҶ 0;
  . have this := hПҶ (encode ПҶ + 1);
    simp only [construction, encodek] at this;
    split_ifs at this with h;
    . simp at this;
      tauto
    . simpa using h

variable [Entailment.F L]

lemma construction_omega_mem_ant : ПҮ вҲҲ construction_omega T hT := by
  apply mem_omega_of_mem;
  apply T.mem_of_provable;
  apply impId;

lemma construction_omega_not_mem_csq : Оҫ вҲү construction_omega T hT := by
  simp only [construction_omega, Set.mem_iUnion, not_exists];
  intro i;
  induction i with
  | zero => simpa [construction];
  | succ i ih =>
    contrapose! ih;
    dsimp [construction] at ih;
    split at ih;
    . split_ifs at ih with h;
      . rename_i Оҙ hОҙ;
        by_contra hC;
        have : Оҙ = Оҫ := by
          have : encode Оҙ = i + 1 := by
            simp at hОҙ вҠў; tauto
          have : Оҙ = Оҫ := by
            have : encode Оҙ = encode Оҫ := by
              simp at this вҠў; tauto
            tauto
          assumption
        subst this;
        apply T.mem_of_provable; simp; assumption;
      . assumption
    . assumption

lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  ПҶ вҲҲ U вҶ’ ПҲ вҲҲ U вҶ’ ПҶ вӢҸ ПҲ вҲҲ U := by
  rintro hПҶ hПҲ;
  by_contra hПҶПҲ;
  replace вҹЁhПҶПҲ, вҹЁО“, hО“вӮҒ, hО“вӮӮвҹ©вҹ© := of_not_mem_construction_omega hПҶПҲ;
  have h3 : (вҶ‘О“ : Set (Formula в„•)) вҠҶ (U : Set (Formula в„•)) := by
    intro Оҙ hОҙ;
    simp [U, construction_omega, Set.mem_iUnion] at hОҙ вҠў;
    rcases hОҙ with вҹЁi, hiвҹ©;
    have : Оҙ вҲҲ construction T hT i := by
      simpa using hi;
    have : Оҙ вҲҲ construction_omega T hT := by
      simp [construction_omega, Set.mem_iUnion]
      use i; assumption
    assumption
  have h4 : (О“.conj вӢҸ ПҶ) вҲҲ U := by
    simp [U, construction_omega, Set.mem_iUnion]
    use 0; simp [construction]; assumption
  have h5 : (О“.conj вӢҸ ПҲ) вҲҲ U := by
    simp [U, construction_omega, Set.mem_iUnion]
    use 0; simp [construction]; assumption
  have h6 : (О“.conj вӢҸ ПҶ) вҲҲ construction T hT 0 := by
    simp [construction]; assumption
  have h7 : (О“.conj вӢҸ ПҲ) вҲҲ construction T hT 0 := by
    simp [construction]; assumption
  have h8 : (вҶ‘{ПҶ} : Set (Formula в„•)) вҠҶ (construction T hT 0 : Set (Formula в„•)) := by
    intro Оҙ hОҙ; simp at hОҙ вҠў; tauto
  have h9 : (вҶ‘{ПҲ} : Set (Formula в„•)) вҠҶ (construction T hT 0 : Set (Formula в„•)) := by
    intro Оҙ hОҙ; simp at hОҙ вҠў; tauto
  have h10 : (ПҶ : Formula в„•) вҲҲ (construction T hT 0 : Set (Formula в„•)) := by
    simp [construction]; assumption
  have h11 : (ПҲ : Formula в„•) вҲҲ (construction T hT 0 : Set (Formula в„•)) := by
    simp [construction]; assumption
  have h12 : (ПҶ вӢҸ ПҲ : Formula в„•) вҲҲ (construction T hT 0 : Set (Formula в„•)) := by
    simp [construction]; apply T.andIR; all_goals assumption
  have h13 : (ПҶ вӢҸ ПҲ : Formula в„•) вҲҲ (U : Set (Formula в„•)) := by
    simp [U, construction_omega, Set.mem_iUnion]
    use 0; simp [construction]; assumption
  tauto

lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L вҠў ПҶ вһқ ПҲ вҶ’ ПҶ вҲҲ U вҶ’ ПҲ вҲҲ U := by
  rintro hПҶПҲ hПҶ;
