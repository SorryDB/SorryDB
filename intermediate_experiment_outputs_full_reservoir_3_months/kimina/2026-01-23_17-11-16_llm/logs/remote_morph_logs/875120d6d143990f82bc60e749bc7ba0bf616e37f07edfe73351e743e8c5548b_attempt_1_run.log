```lean
import Foundation.Propositional.Hilbert.F.Deduction
import Foundation.Propositional.Kripke2.Basic

namespace LO.Propositional

open LO.Entailment (disjunctive)
open LO.Propositional.Entailment.Corsi
open Formula

variable {Оұ : Type*}
variable {S} [Entailment S (Formula Оұ)]
variable {рқ“ў : S}

structure FTheory (L : Logic в„•) where
  protected theory : FormulaSet в„•
  protected no_bot : вҠҘ вҲү theory
  protected andIR : вҲҖ {ПҶ ПҲ}, ПҶ вҲҲ theory вҶ’ ПҲ вҲҲ theory вҶ’ ПҶ вӢҸ ПҲ вҲҲ theory
  protected imp_closed : вҲҖ {ПҶ ПҲ}, L вҠў ПҶ вһқ ПҲ вҶ’ ПҶ вҲҲ theory вҶ’ ПҲ вҲҲ theory
  protected L_subset : L вҠҶ theory


namespace FTheory

attribute [simp] FTheory.no_bot
attribute [grind <=] FTheory.andIR FTheory.imp_closed

variable {T : FTheory L} {ПҶ ПҲ ПҮ : Formula в„•}

@[simp, grind <=]
lemma mem_of_provable [Entailment.HasAxiomVerum L] [Entailment.AFortiori L] (hПҶ : L вҠў ПҶ) : ПҶ вҲҲ T.theorem := by
  apply T.imp_closed (ПҶ := вҠӨ) $ af hПҶ;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma mem_trans [Entailment.HasAxiomI L] (hвӮҒ : ПҶ вһқ ПҲ вҲҲ T.theorem) (hвӮӮ : ПҲ вһқ ПҮ вҲҲ T.theorem) : ПҶ вһқ ПҮ вҲҲ T.theorem := by
  apply T.imp_closed (axiomI (ПҲ := ПҲ));
  apply T.andIR hвӮҒ hвӮӮ;

@[grind <=]
lemma mem_orIntroL [Entailment.HasAxiomOrInst L] (hПҶ : ПҶ вҲҲ T.theorem) : ПҶ вӢҺ ПҲ вҲҲ T.theorem := by
  apply T.imp_closed (ПҶ := ПҶ);
  . exact orIntroL;
  . assumption;

@[grind <=]
lemma mem_orIntroR [Entailment.HasAxiomOrInst L] (hПҲ : ПҲ вҲҲ T.theorem) : ПҶ вӢҺ ПҲ вҲҲ T.theorem := by
  apply T.imp_closed (ПҶ := ПҲ);
  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : ПҶ вҲҲ T.theorem вҶ” Deduction Ax T.theorem ПҶ := by
  constructor;
  . intro hПҶ;
    apply Deduction.ctx hПҶ;
  . intro h; induction h <;> grind

end FTheory


variable {L : Logic в„•}

structure PrimeFTheory (L : Logic в„•) extends FTheory L where
  protected prime : вҲҖ {ПҶ ПҲ}, ПҶ вӢҺ ПҲ вҲҲ theory вҶ’ ПҶ вҲҲ theory вҲЁ ПҲ вҲҲ theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {ПҶ ПҲ ПҮ Оҫ : Formula в„•} {T : FTheory L} {hT : ПҮ вҶ’ Оҫ вҲү T.theorem}

def construction (T : FTheory L) (hT : ПҮ вҶ’ Оҫ вҲү T.theorem) : в„• вҶ’ Set (Formula в„•)
  | 0 => { Оҙ | ПҮ вҶ’ Оҙ вҲҲ T.theorem }
  | i + 1 =>
    match (decode i) with
    | some Оҙ =>
      letI T' := construction T hT i
      if вҲҖ (О“ : Finset (Formula _)), вҶ‘О“ вҠҶ T' вҶ’ (О“.conj вӢҸ Оҙ) вҶ’ Оҫ вҲү T.theorem then insert Оҙ T'
      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : ПҮ вҶ’ Оҫ вҲү T.theorem) : Set (Formula в„•) := вӢғ i, construction T hT i

lemma subset_construction_succ : construction T hT i вҠҶ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i вҠҶ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
    trans construction T hT (i + j);
    . apply ih;
    . apply subset_construction_succ;

lemma monotone_construction (hij : i вүӨ j) : construction T hT i вҠҶ construction T hT j := by
  obtain вҹЁk, rflвҹ© := le_iff_exists_add.mp hij;
  apply subset_construction_add;

lemma mem_omega_of_mem (h : L вҠў ПҶ) : ПҶ вҲҲ construction_omega T hT := by
  apply T.imp_closed (ПҶ := вҠӨ) $ af h;
  apply T.L_subset;
  apply Logic.iff_provable.mp;
  simp;

lemma of_mem_construction_omega {ПҶ : Formula в„•} (hПҶ : ПҶ вҲҲ construction_omega T hT) :
  (ПҮ вҶ’ ПҶ вҲҲ T.theorem) вҲЁ (вҲҖ (О“ : Finset (Formula _)), вҶ‘О“ вҠҶ construction T hT (encode ПҶ) вҶ’ (О“.conj вӢҸ ПҶ) вҶ’ Оҫ вҲү T.theorem) := by
  obtain вҹЁi, hiвҹ© := by simpa [construction_omega] using hПҶ;
  induction i with
  | zero => left; simpa [construction] using hi;
  | succ i ih =>
    dsimp [construction] at hi;
    split at hi;
    . split_ifs at hi with h;
      . replace hi := Set.mem_insert_iff.mp hi;
        rcases hi with (rfl | hi);
        . right;
          assumption;
        . simp at hi вҠў; tauto;
      . assumption
    . assumption
    . dsimp [construction] at hi;
      split at hi;
      . split_ifs at hi with h;
        . replace hi := Set.mem_insert_iff.mp hi;
          rcases hi with (rfl | hi);
          . right;
            assumption;
          . simp at hi вҠў; tauto;
        . assumption
      . assumption
      . dsimp [construction] at hi;
        split at hi;
        . split_ifs at hi with h;
          . replace hi := Set.mem_insert_iff.mp hi;
            rcases hi with (rfl | hi);
            . right;
              assumption;
            . simp at hi вҠў; tauto;
          . assumption
        . assumption

lemma not_of_mem_construction_omega {ПҶ : Formula в„•}
  {О“ : Finset (Formula в„•)} (hО“ : вҶ‘О“ вҠҶ construction T hT (encode ПҶ))
  (hПҶ : (О“.conj вӢҸ ПҶ) вҶ’ Оҫ вҲҲ T.theorem) :
  ПҶ вҲү (construction_omega T hT) := by
