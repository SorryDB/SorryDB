def construction_omega (T : FTheory L) (hT : ПҮ вһқ Оҫ вҲү T.1) : Set (Formula в„•) := вӢғ i, construction T hT i

lemma subset_construction_succ : construction T hT i вҠҶ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i вҠҶ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
