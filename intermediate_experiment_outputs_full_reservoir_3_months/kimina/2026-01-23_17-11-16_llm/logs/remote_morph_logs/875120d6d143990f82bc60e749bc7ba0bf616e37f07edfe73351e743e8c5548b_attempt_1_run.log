    have : (О“.conj вӢҸ ПҶ) вһқ Оҫ вҲҲ T.theory := T.mem_trans hвӮӮ hвӮҒ;
    have : (О“.conj вӢҸ ПҶ) вһқ Оҫ вҲҲ construction_omega T hT := by sorry;
    assumption;

lemma construction_omega_L_subset :
  letI U := construction_omega T hT
  L вҠҶ U := by
  intro ПҶ hПҶ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ПҶ + 1);
