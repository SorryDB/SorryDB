    {p : ℕ} [Fact (Nat.Prime p)] [Fact (p > 512)]
    {programSize : ℕ} [NeZero programSize] (program : Fin programSize → (F p))
    {memorySize : ℕ} [NeZero memorySize] (memory : Fin memorySize → (F p))
