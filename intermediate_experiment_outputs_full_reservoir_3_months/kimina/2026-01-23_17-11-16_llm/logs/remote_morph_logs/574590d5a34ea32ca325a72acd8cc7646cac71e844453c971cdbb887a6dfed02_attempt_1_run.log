  letI U := construction_omega T hT
  L ⊢ φ ➝ ψ → φ ∈ U → ψ ∈ U := by
  rintro hφψ hφ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode ψ + 1);
  simp [construction];
  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain ⟨(Δ : Finset (Formula _)), hΔ, h₁⟩ := h;
