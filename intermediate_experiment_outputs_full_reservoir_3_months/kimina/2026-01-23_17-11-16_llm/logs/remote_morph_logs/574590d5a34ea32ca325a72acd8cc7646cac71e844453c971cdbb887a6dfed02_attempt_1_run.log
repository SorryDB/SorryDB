lemma construction_omega_impClosed :
  letI U := construction_omega T hT
  L ⊢ φ ➝ ψ → φ ∈ U → ψ ∈ U := by
  intro h1 h2;
  simp only [construction_omega, Set.mem_iUnion] at h2 ⊢;
  rcases h2 with ⟨k, hk⟩;
  use k + 1;
  simp [construction] at hk ⊢;
  split_ifs with h;
  . -- Case where ψ is added because of the first condition
