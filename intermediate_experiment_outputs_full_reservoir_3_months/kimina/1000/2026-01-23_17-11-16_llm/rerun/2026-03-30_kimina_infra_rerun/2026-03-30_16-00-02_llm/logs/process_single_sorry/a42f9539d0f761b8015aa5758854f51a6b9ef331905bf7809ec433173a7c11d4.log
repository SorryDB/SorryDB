```lean
import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  have h1 : ∀ n : ℕ, 4 ≤ n → n ^ 2 ≤ n ! := by
    intro n hn
    have base4 : 4 ^ 2 ≤ 4 ! := by 
      norm_num [Nat.factorial]
    have step : ∀ (k : ℕ), 4 ≤ k → k ^ 2 ≤ k ! → (k + 1) ^ 2 ≤ (k + 1) ! := by
      intro k hk h
      have h2 : (k + 1) ^ 2 ≤ (k + 1) * (k ^ 2) := by
        nlinarith [sq_nonneg ((k : ℤ)), sq_nonneg ((k + 1 : ℤ)), sq_nonneg ((k - 1 : ℤ)), sq_nonneg ((k - 2 : ℤ)), show k ≥ 2 by omega]
      have h3 : (k + 1) * (k ^ 2) ≤ (k + 1) * (k !) := by 
        have h4 : k ^ 2 ≤ k ! := h
        have h5 : (k + 1) * (k ^ 2) ≤ (k + 1) * (k !) := by 
          apply mul_le_mul_of_nonneg_left 
          linarith 
          all_goals omega 
        linarith 
      have h6 : (k + 1) * (k !) = (k + 1) ! := by 
        simp [Nat.factorial]
        <;> ring 
      have h7 : (k + 1) ^ 2 ≤ (k + 1) ! := by 
        linarith [h2, h3, h6] 
      exact h7 
    exact Nat.le_induction base4 step n hn 
  exact h1 n h₀
```
