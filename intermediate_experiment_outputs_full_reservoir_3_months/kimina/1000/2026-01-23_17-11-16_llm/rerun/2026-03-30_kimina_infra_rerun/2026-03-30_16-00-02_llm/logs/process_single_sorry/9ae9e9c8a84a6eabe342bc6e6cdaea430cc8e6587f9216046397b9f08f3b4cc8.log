  simp only [rotproj_inner, inner, Matrix.vecHead, Matrix.vecTail, Matrix.cons_val_zero, Matrix.cons_val, AffineMap.coe_comp, LinearMap.coe_toAffineMap, ContinuousLinearMap.coe_coe, Function.comp_apply]
  change _ = inner (proj_xyL ∘L rotRM p.θ₁ p.φ₁ p.α) S w
  rw [← projxy_rotRM_eq_rotprojRM]
  rfl

