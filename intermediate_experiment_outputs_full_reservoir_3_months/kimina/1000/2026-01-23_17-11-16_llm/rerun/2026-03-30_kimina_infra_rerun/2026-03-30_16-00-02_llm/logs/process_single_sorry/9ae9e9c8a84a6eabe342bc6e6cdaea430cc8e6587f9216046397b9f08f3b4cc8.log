  have h1 : HasFDerivAt (pc.fu) (rotproj_inner' pbar pc.S pc.w) pbar.innerParams := by
    apply HasFDerivAt.rotproj_inner
  have h2 : (fderiv ℝ (pc.fu) pbar.innerParams) (EuclideanSpace.single 2 1) =
      (rotproj_inner' pbar pc.S pc.w) 2 := by
    simpa using congrArg (λ f => f (EuclideanSpace.single 2 1)) h1.fderiv
  rw [show nth_partial 2 (pc.fu) pbar.innerParams = (fderiv ℝ (pc.fu) pbar.innerParams) (EuclideanSpace.single 2 1) by simp]
  rw [h2]
  simp only [Fin.isValue, EuclideanSpace.single, Pi.smul_apply, smul_eq_mul]
  have h3 : ‖pc.S‖ * ((rotproj_inner' pbar pc.S pc.w) 2) = inner ℝ (pbar.rotR (pbar.rotM₁φ pc.S)) (pc.w) := by
    have h4 : (rotproj_inner' pbar pc.S pc.w) 2 = ‖pc.S‖⁻¹ * inner ℝ (pbar.rotR (pbar.rotM₁φ pc.S)) (pc.w) := by
