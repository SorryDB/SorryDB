lemma rotation_partials_exist {S : ℝ³} (S_nonzero : ‖S‖ > 0) {w : ℝ²} :
    ContDiff ℝ 2 (fun (x : ℝ³) => inner w (rotprojRM (x 1) (x 2) (x 0) S)) := by
