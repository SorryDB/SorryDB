    (pc : GlobalTheoremPrecondition poly pbar ε) :
    ‖pc.S‖ * nth_partial 2 pc.fu pbar.innerParams =
    inner ℝ (pbar.rotR (pbar.rotM₁φ pc.S), pc.w) := by
  have hf : HasFDerivAt (pc.fu) (fun x => (fun y => inner ℝ (x y) (pc.w)) ∘ (fun x => (fun y => y) x)) pbar.innerParams := by
    unfold pc.fu
    apply HasFDerivAt.comp
    · -- Show differentiability of rotproj_inner_unit
      apply HasFDerivAt.continuous.continuous.differentiableAt
      apply DifferentiableAt.continuous.differentiableAt
      apply HasFDerivAt.differentiableAt
      apply HasFDerivAt.comp
      · -- Show differentiability of rotproj_inner
        apply HasFDerivAt.differentiableAt
        apply HasFDerivAt.comp
        · -- Show differentiability of pbar.inner
          apply HasFDerivAt.differentiableAt
          apply HasFDerivAt.comp
          · -- Show differentiability of pbar.innerParams
            apply hasFDerivAt_id
          · -- Show differentiability of pbar.rotM₁
            apply hasFDerivAt_id
        · -- Show differentiability of pbar.rotM₁θ
          apply hasFDerivAt_id
      · -- Show differentiability of pbar.rotM₁φ
        apply hasFDerivAt_id
    · -- Show differentiability of w
      apply hasFDerivAt_const
  -- Compute the second partial derivative
  have h2 : nth_partial 2 pc.fu pbar.innerParams = (fderiv ℝ (fderiv ℝ (fun x => (fun y => inner ℝ (x y) (pc.w)) ∘ (fun x => (fun y => y) x)) pbar.innerParams) (EuclideanSpace.single 2 1) := by
    simp [Fin.isValue]
