open BigOperators Real Nat Topology Rat

theorem imo_1974_p5 (a b c d s : ℝ) (h₀ : 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d)
  (h₁ : s = a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d)) :
  1 < s ∧ s < 2 := by
  rcases h₀ with ⟨ha, hb, hc, hd⟩
  have h2 : 0 < a + b + c + d := by
    linarith
  have h3 : 1 < s := by
    rw [h₁]
    have h4 : 0 < a + b + d := by
      linarith
    have h5 : 0 < a + b + c := by
      linarith
    have h6 : 0 < b + c + d := by
      linarith
    have h7 : 0 < a + c + d := by
      linarith
    have h8 : a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d) - 1 > 0 := by
      have pos1 : 0 < (a + b + d) * (a + b + c) * (b + c + d) * (a + c + d) := by positivity
      have h9 : a / (a + b + d) + b / (a + b + c) + c / (b + c + d) + d / (a + c + d) - 1 =
          ( (a * (a + b + c) * (b + c + d) * (a + c + d) ) +
            (b * (a + b + d) * (b + c + d) * (a + c + d) ) +
            (c * (a + b + d) * (a + b + c) * (a + c + d) ) +
            (d * (a + b + d) * (a + b + c) * (b + c + d) ) - 
            (a + b + d) * (a + b + c) * (b + c + d) * (a + c + d) ) / ( (a + b + d) * (a + b + c) * (b + c + d) * (a + c + d) ) := by 
        field_simp
        ring
      rw [h9]
      apply div_pos
      nlinarith [sq_nonneg (a * b - b * c), sq_nonneg (b * c - c * d), sq_nonneg (c * d - d * a), sq_nonneg (d * a - a * b),
                  sq_nonneg (a - b), sq_nonneg (a - c), sq_nonneg (a - d), sq_nonneg (b - c), sq_nonneg (b - d), sq_nonneg (c - d),
                  mul_pos ha hb, mul_pos ha hc, mul_pos ha hd, mul_pos hb hc, mul_pos hb hd, mul_pos hc hd
                ]
      all_goals positivity
    linarith
  have h4 : s < 2 := by
    rw [h₁]
    have h4 : 0 < a + b + d := by
