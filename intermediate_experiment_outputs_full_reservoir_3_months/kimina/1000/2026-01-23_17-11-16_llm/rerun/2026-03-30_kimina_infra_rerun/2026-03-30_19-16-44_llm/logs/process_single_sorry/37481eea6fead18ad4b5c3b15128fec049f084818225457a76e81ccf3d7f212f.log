      "\n  have eq1 : deriv (interpolated_deriv x y f) = fun t => ∑ i, (y i - x i) * deriv (fun (t : ℝ) => nth_partial i f ((1 - t) • x + t • y)) t := by\n    funext t\n    simp [deriv_sum, deriv_const_mul, deriv_id'', mul_comm]\n    <;> ring_nf\n    <;> simp [Finset.sum, mul_add, add_mul]\n    <;> ring\n  have eq2 : ∀ i, deriv (fun (t : ℝ) => nth_partial i f ((1 - t) • x + t • y)) = fun t => nth_partial i f ((1 - t) • x + t • y) * (y - x) := by\n    intro i\n    have eq3 : deriv (fun (t : ℝ) => nth_partial i f ((1 - t) • x + t • y)) = fun t => (deriv (fun (t : ℝ) => (1 - t) • x + t • y) t) • nth_partial i f ((1 - t) • x + t • y) := by\n      funext t\n      simp [deriv_mul, deriv_id'', mul_comm]\n      <;> ring_nf\n      <;> simp [Finset.sum, mul_add, add_mul]\n      <;> ring\n    have eq4 : deriv (fun (t : ℝ) => (1 - t) • x + t • y) = fun t => y - x := by\n      funext t\n      simp [deriv_add, deriv_sub, deriv_const, deriv_id'', mul_comm]\n      all_goals ring\n    rw [eq4] at eq3\n    simpa using eq3\n  rw [eq1]\n  funext t\n  simp [eq2]\n  <;> ring_nf\n  <;> simp [Finset.sum, mul_add, add_mul]\n  <;> ring\n  all_goals try { tauto }\n  all_goals try { norm_num }\n  all_goals try { ring }\n  all_goals try { tauto }\n  all_goals try { norm_num }\n  all_goals try { ring }",
