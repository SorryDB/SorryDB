  have g_diff : Differentiable ℝ g := Differentiable.interpolated x y f fc
  have g'_diff : Differentiable ℝ g' := by sorry
  have g'_cont : Continuous g' := by fun_prop
  have g''_cont : Continuous g'' := by
    fun_prop
