        · -- Show that `fun t => nth_partial i <| nth_partial j f ((1 - t) • x + t • y)` is continuous
          apply Continuous.continuousOn
          apply Continuous.comp
          exact h3
      exact h2
    simpa using h1
  exact g''_cont
