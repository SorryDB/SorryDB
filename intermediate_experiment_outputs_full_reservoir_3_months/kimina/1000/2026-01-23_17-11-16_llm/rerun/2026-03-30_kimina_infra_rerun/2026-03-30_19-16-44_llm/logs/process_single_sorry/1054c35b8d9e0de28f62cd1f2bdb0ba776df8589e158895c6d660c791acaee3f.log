import Mathlib.Analysis.InnerProductSpace.Dual
import Mathlib.MeasureTheory.Integral.IntervalIntegral.FundThmCalculus
import Mathlib.Analysis.InnerProductSpace.Calculus
import Noperthedron.Nopert
import Noperthedron.PoseInterval
import Noperthedron.Global.Basic

open scoped RealInnerProductSpace

namespace GlobalTheorem

noncomputable abbrev E (n : ℕ) := EuclideanSpace ℝ (Fin n)

noncomputable
def interpolator {n : ℕ} (x y : E n) (t : ℝ) : E n :=
  (1 - t) • x + t • y

noncomputable
def interpolated {n : ℕ} (x y : E n) (f : E n → ℝ) : ℝ → ℝ  :=
  f ∘ interpolator x y

noncomputable
def Differentiable.interpolator {n : ℕ} (x y : E n) :
    Differentiable ℝ (interpolator x y)  := by
  unfold GlobalTheorem.interpolator
  fun_prop

noncomputable
def Differentiable.interpolated {n : ℕ} (x y : E n) (f : E n → ℝ) (fc : ContDiff ℝ 2 f) :
    Differentiable ℝ (interpolated x y f)  := by
  have := Differentiable.interpolator x y
  have := fc.differentiable (by norm_num)
  unfold GlobalTheorem.interpolated
  fun_prop

noncomputable
def interpolated_deriv {n : ℕ} (x y : E n) (f : E n → ℝ) (t : ℝ) : ℝ :=
  ∑ i, (y i - x i) * nth_partial i f ((1 - t) • x + t • y)

noncomputable
def interpolated_deriv2 {n : ℕ} (x y : E n) (f : E n → ℝ) (t : ℝ) : ℝ :=
  ∑ i, ∑ j, (y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - t) • x + t • y)

theorem bounded_partials_control_difference {n : ℕ} (f : E n → ℝ)
    (fc : ContDiff ℝ 2 f) (x y : E n)
    (ε : ℝ) (hε : ε > 0) (hdiff : (i : Fin n) → |x i - y i| ≤ ε)
    (mpb : mixed_partials_bounded f x) :
    |f x - f y| ≤ ε * ∑ i, |nth_partial i f x| + (n^2 / 2) * ε^2 := by
  let g₀ := interpolator x y
  let g := interpolated x y f

  let g' := interpolated_deriv x y f
  let g'' := interpolated_deriv2 x y f

  have f_diff : Differentiable ℝ f := fc.differentiable (by norm_num)
  have g₀_diff : Differentiable ℝ g₀ := Differentiable.interpolator x y
  have g_diff : Differentiable ℝ g := Differentiable.interpolated x y f fc
  have g'_diff : Differentiable ℝ g' := by
    apply Differentiable.sum
    intro i hi
    apply Differentiable.mul
    · -- Show `y i - x i` is differentiable
      apply Differentiable.sub
      · -- Show `y i` is differentiable
        apply Differentiable.const
      · -- Show `x i` is differentiable
        apply Differentiable.const
    · -- Show `nth_partial i f ((1 - t) • x + t • y)` is differentiable
      apply Differentiable.nthPartial
      apply Differentiable.comp
      · -- Show `f` is differentiable
        exact f_diff
      · -- Show `interpolant` is differentiable
        apply Differentiable.add
        · -- Show `(1 - t) • x` is differentiable
          apply Differentiable.smul
          apply Differentiable.const
        · -- Show `t • y` is differentiable
          apply Differentiable.smul
          apply Differentiable.const
  have g'_cont : Continuous g' := by
    apply Continuous.continuousOn
    apply ContinuousOn.sum
    intro i hi
    have h1 : Continuous (fun t => (y i - x i) * nth_partial i f ((1 - t) • x + t • y)) := by
      apply Continuous.mul
      · -- Show `fun t => y i - x i` is continuous
        apply Continuous.sub
        · -- Show `fun t => y i` is continuous
          apply Continuous.const
        · -- Show `fun t => x i` is continuous
          apply Continuous.const
      · -- Show `fun t => nth_partial i f ((1 - t) • x + t • y)` is continuous
        apply Continuous.nthPartial
        apply Continuous.comp
        · -- Show `f` is continuous
          exact f_diff.continuous
        · -- Show `fun t => (1 - t) • x + t • y` is continuous
          apply Continuous.add
          · -- Show `fun t => (1 - t) • x` is continuous
            apply Continuous.smul
            apply Continuous.sub
            · -- Show `fun t => 1` is continuous
              apply Continuous.const
            · -- Show `fun t => t` is continuous
              apply Continuous.id
          · -- Show `fun t => t • y` is continuous
            apply Continuous.smul
            apply Continuous.id
    exact h1.continuousOn
  have g''_cont : Continuous g'' := by
    apply Continuous.continuousOn
    apply ContinuousOn.sum
    intro i hi
    have h1 : Continuous (fun t => (y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - t) • x + t • y)) := by
      apply Continuous.mul
      apply Continuous.mul
      · -- Show `fun t => y i - x i` is continuous
        apply Continuous.sub
        · -- Show `fun t => y i` is continuous
          apply Continuous.const
        · -- Show `fun t => x i` is continuous
          apply Continuous.const
      · -- Show `fun t => y j - x j` is continuous
        apply Continuous.sub
        · -- Show `fun t => y j` is continuous
          apply Continuous.const
        · -- Show `fun t => x j` is continuous
          apply Continuous.const
      · -- Show `fun t => (nth_partial i <| nth_partial j f) ((1 - t) • x + t • y)` is continuous
        apply Continuous.nthPartial
        apply Continuous.comp
        · -- Show `f` is continuous
          exact f_diff.continuous
        · -- Show `fun t => (1 - t) • x + t • y` is continuous
          apply Continuous.add
          · -- Show `fun t => (1 - t) • x` is continuous
            apply Continuous.smul
            apply Continuous.sub
            · -- Show `fun t => 1` is continuous
              apply Continuous.const
            · -- Show `fun t => t` is continuous
              apply Continuous.id
          · -- Show `fun t => t • y` is continuous
            apply Continuous.smul
            apply Continuous.id
    exact h1.continuousOn
  exact g''_cont
