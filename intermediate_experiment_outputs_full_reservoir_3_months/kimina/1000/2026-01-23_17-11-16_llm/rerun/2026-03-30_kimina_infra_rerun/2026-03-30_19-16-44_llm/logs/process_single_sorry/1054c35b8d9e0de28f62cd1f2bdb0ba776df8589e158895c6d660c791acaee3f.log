    <;> ring_nf <;> simp [norm_smul, one_smul]
    <;> ring_nf <;> simp [norm_smul, one_smul]
    <;> ring_nf <;> simp [norm_smul, one_smul]
    <;> ring_nf <;> simp [norm_smul, one_smul]
    <;> ring_nf <;> simp [norm_smul, one_smul]
