      have h2 : (fun (t : ℝ) => ∑ i : Fin n, ∑ j : Fin n, (y i - x i) * (y j - x j) * (nth_partial i <| nth_partial j f) ((1 - t) • x + t • y)) =
          ∑ i : Fin n, ∑ j : Fin n, (y i - x i) * (y j - x j) * (fun (t : ℝ) => (nth_partial i <| nth_partial j f) ((1 - t) • x + t • y)) := by
        funext t
