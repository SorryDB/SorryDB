      _ ≤ ε * ∑ i, |nth_partial i f x| + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, |g'' s| := by
        apply add_le_add
        · exact bound1
        · exact int_abs_int_le_int_int_abs
