    apply intervalIntegral.integral_mono
    intro t ht
    have ht1 : 0 ≤ t := ht.1
    have h1 : |∫ (s : ℝ) in 0..t, g'' s| ≤ ∫ (s : ℝ) in 0..t, |g'' s| := by
      apply abs_int_le_int_abs
      exact ht1
    simpa using h1

  -- Now combine everything
  calc |f x - f y| = |g 1 - g 0| := by simp [g, g₀]
      _ = |g' 0 + ∫ (t : ℝ) in 0..1, ∫ (s : ℝ) in 0..t, g'' s| := by rw [hobs]
