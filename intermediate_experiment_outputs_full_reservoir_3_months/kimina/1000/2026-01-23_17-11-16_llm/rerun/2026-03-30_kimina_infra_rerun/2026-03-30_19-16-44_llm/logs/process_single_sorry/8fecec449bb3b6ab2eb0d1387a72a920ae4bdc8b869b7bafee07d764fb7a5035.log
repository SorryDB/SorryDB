    have h7 : ∑ i : Fin n, |(y i - x i) * nth_partial i f (g₀ t)| = ∑ i : Fin n, |y i - x i| * |nth_partial i f (g₀ t)| := by
      apply Finset.sum_congr rfl
      intro i hi
