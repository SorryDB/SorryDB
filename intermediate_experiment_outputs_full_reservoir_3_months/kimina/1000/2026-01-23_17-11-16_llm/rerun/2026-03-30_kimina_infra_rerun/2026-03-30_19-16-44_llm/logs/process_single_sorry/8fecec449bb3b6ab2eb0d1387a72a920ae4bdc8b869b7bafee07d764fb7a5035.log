      rw [h5]
      have h6 : |(nth_partial j <| nth_partial i f) x| ≤ 2 * |nth_partial j f x| * |nth_partial i f x| := by
        have h7 : (nth_partial j <| nth_partial i f) x = (nth_partial i f) ((nth_partial j f) x) := by
          simp [Function.comp_apply]
        rw [h7]
        have h8 : |(nth_partial i f) ((nth_partial j f) x)| ≤ 2 * |nth_partial i f x| * |(nth_partial j f) x| := by
          have h9 : |(nth_partial i f) ((nth_partial j f) x)| ≤ 2 * |(nth_partial i f) x| * |(nth_partial j f) x| := by
