noncomputable
def interpolator {n : ℕ} (x y : E n) (t : ℝ) : E n :=
  (1 - t) • x + t • y

noncomputable
def interpolated {n : ℕ} (x y : E n) (f : E n → ℝ) : ℝ → ℝ  :=
  f ∘ interpolator x y

noncomputable
def Differentiable.interpolator {n : ℕ} (x y : E n) :
    Differentiable ℝ (interpolator x y)  := by
  unfold GlobalTheorem.interpolator
