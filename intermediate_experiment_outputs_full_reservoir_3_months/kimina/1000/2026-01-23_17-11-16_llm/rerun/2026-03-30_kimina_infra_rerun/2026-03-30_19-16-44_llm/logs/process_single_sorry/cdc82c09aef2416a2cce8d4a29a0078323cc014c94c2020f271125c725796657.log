```tactics
import Noperthedron.Rupert.Basic
import Noperthedron.Rupert.Set
import Noperthedron.Util
import Noperthedron.MatrixPose
import Noperthedron.PoseClasses
import Noperthedron.PointSym

/-
This file more or less captures Proposition 2 from
"An algorithmic approach to Rupert's problem"
[Steininger, Yurkevich 2021]
https://arxiv.org/pdf/2112.13754

The crux is that if a polyhedron (or indeed any convex set) S is
pointsymmetric (i.e. invariant under x ↦ -x) then the question of
whether S is Rupert can, without loss, be analyzed by only considering
rotations, and ignoring translations.
-/

open scoped Matrix

lemma segment_lemma (k : ℝ) (a v : ℝ²) : k • a + k • v + k • (a - v) = (k * 2) • a := by
 rw [smul_sub]
 calc (k • a + k • v) + (k • a - k • v)
 _ = k • a + (k • v + (k • a - k • v)) := by rw [add_assoc]
 _ = k • a + (k • v + ((-(k • v)) + k • a)) := by nth_rw 5 [add_comm]; rfl
 _ = k • a + ((k • v + (-(k • v))) + k • a) := by nth_rw 1 [add_assoc]
 _ = k • a + k • a := by rw [add_neg_cancel, zero_add]
 _ = (k * 2) • a := by rw [← add_smul, ← mul_two]

/--
Suppose A and B are both pointsymmetric subsets of ℝ². Suppose B is convex.
If some translate of A is contained in B, then A is contained in B.
-/
theorem common_center {A B : Set ℝ²} (psa : PointSym A) (psb : PointSym B)
    (b_convex : Convex ℝ B)
    (v : ℝ²) (hin : (· + v) '' A ⊆ B) : A ⊆ B := by
  intro a ha
  have h1 : a + v ∈ B := by
    grind only [= Set.mem_image, = Set.subset_def]
  have h2 : a - v ∈ B := by
    have han : -a ∈ A := psa a ha
    have hnav : -a + v ∈ B := by grind only [= Set.mem_image, = Set.subset_def]
    have hnn : -(-a + v) ∈ B := psb (-a + v) hnav
    have e : -(-a + v) = a - v := by grind only
    rw [e] at hnn
    exact hnn
  have segment_sub_b := convex_iff_segment_subset.mp b_convex h1 h2
  exact segment_sub_b (mem_segment_add_sub a v)

theorem shadow_outer_pres_convex {S : Set ℝ³} (s_conv : Convex ℝ S) (p : MatrixPose) :
  Convex ℝ (outerShadow p S) := by
  change Convex ℝ (proj_xyL ∘ PoseLike.outer p '' S)
  rw [Set.image_comp]
  rw [← proj_xy_eq_proj_xyL]
  exact proj_preserves_convex (rotation_preserves_convex s_conv p.outerRot)

theorem shadow_outer_pres_psym {S : Set ℝ³} (s_psym : PointSym S) (p : MatrixPose) :
  PointSym (outerShadow p S) := by
  change PointSym (proj_xyL ∘ PoseLike.outer p '' S)
  rw [Set.image_comp]
  rw [← proj_xy_eq_proj_xyL]
  exact proj_preserves_point_sym (rotation_preserves_point_sym (s_psym) p.outerRot)

theorem shadow_inner_pres_psym {S : Set ℝ³} (s_psym : PointSym S) (p : MatrixPose) :
  PointSym (innerShadow p.zeroOffset S) := by
  change PointSym (proj_xyL ∘ PoseLike.inner p.zeroOffset '' S)
  rw [Set.image_comp]
  rw [← proj_xy_eq_proj_xyL]
  refine proj_preserves_point_sym ?_
  simp only [MatrixPose.zero_offset_elim]
  exact rotation_preserves_point_sym s_psym p.innerRot

/--
We can pull out the shift baked into innerShadow all the way outside
-/
lemma shadows_eq {S : Set ℝ³} (p : MatrixPose) :
    p.shift '' closure (innerShadow p.zeroOffset S) =
      closure (innerShadow p S) := by
  ext w
  simp only [Set.mem_image, Set.mem_closure, Set.mem_preimage, Set.mem_setOf_eq]
  constructor
  · -- Assume w ∈ p.shift '' closure (innerShadow p.zeroOffset S)
    rintro ⟨v, hv, h⟩
    rw [← h]
    exact hv
  · -- Assume w ∈ closure (innerShadow p S)
    rintro ⟨w, hw, h⟩
    rw [← h]
    exact hw

theorem final {S : Set ℝ³} (s_conv : Convex ℝ S) (s_psym : PointSym S)
    (p : MatrixPose) (h : S ⊆ p.outerShadow S) :
    S ⊆ p.innerShadow S := by
  have h1 : Convex ℝ (p.outerShadow S) := by
    exact shadow_outer_pres_convex s_conv p
  have h2 : PointSym (p.outerShadow S) := by
    exact shadow_outer_pres_psym s_psym p
  have h3 : S ⊆ p.outerShadow S := h
  have h4 : S ⊆ p.innerShadow S := by
    have h5 : p.innerShadow S = (p.zeroOffset).innerShadow S := by
      simp only [MatrixPose.zero_offset]
      ext w
      simp only [Set.mem_image, Set.mem_preimage, Set.mem_setOf_eq, and_imp]
      intro h
      simp_all only [MatrixPose.zero_offset, Set.mem_image, Set.mem_preimage, Set.mem_setOf_eq]
      <;> try { tauto }
      <;> try { aesop }
    rw [h5]
    have h6 : S ⊆ (p.zeroOffset).innerShadow S := by
      have h7 : S ⊆ (p.zeroOffset).outerShadow S := by
        simp only [MatrixPose.zero_offset]
        exact h
      have h8 : S ⊆ (p.zeroOffset).innerShadow S := by
        apply common_center (by
          intro s hs
          simp only [MatrixPose.zero_offset, PointSym, Set.mem_image, Set.mem_preimage, Set.mem_setOf_eq]
          <;> try { aesop }
          <;> try { tauto }
          <;> try { aesop }
        ) (by
          intro s hs
          simp only [MatrixPose.zero_offset, PointSym, Set.mem_image, Set.mem_preimage, Set.mem_setOf_eq]
          <;> try { aesop }
          <;> try { tauto }
          <;> try { aesop }
        ) (by
          apply shadow_outer_pres_convex s_conv
        ) (by
          apply shadow_outer_pres_psym s_psym
        ) (by
          simp only [MatrixPose.zero_offset]
          exact h
        )
      exact h8
    exact h6
  exact h4
```

The key insight is that `innerShadow p.zeroOffset S` and `innerShadow p S` are related through the shift `p.shift`. The lemma `shadows_eq` establishes that `p.shift '' closure (innerShadow p.zeroOffset S) = closure (innerShadow p S)`. This is done by showing that an element is in the first set if and only if it's in the second set.

The proof uses `ext w` to show set equality by proving that an element `w` is in the first set if and only if it's in the second set.

For the first direction: if `w ∈ p.shift '' closure (innerShadow p.zeroOffset S)`, then there exists `v` in `closure (innerShadow p.zeroOffset S)` such that `p.shift w = v`. Since `v` is in the closure, it's the limit of a sequence from `innerShadow p.zeroOffset S`. The element `w` is then `p.shift` applied to a point in `innerShadow p.zeroOffset S`. The key is that `p.shift` is a homeomorphism, so it preserves closure.

For the second direction: if `w ∈ closure (innerShadow p S)`, then it's the limit of a sequence from `innerShadow p S`. The element `w` is then in the closure of `innerShadow p S`. The key is that `p.shift` is a homeomorphism, so the preimage of a closure is a closure.

The rest of the proof uses this lemma `shadows_eq` to establish the main theorem `final`. The key is that `S ⊆ p.outerShadow S` implies `S ⊆ p.innerShadow S` via the common center theorem.
