    simp only [Set.mem_image, Set.mem_setOf_eq] at hyc
    rcases hyc with ⟨s, hs1, hs2⟩
    rw [hy]
    refine ⟨s, by simp [hs1, hs2, MatrixPose.shift]⟩

theorem rupert_characterization {S : Set ℝ³} (s_conv : Convex ℝ S) (s_psym : PointSym S) :
  (∃ p : MatrixPose, (p.zeroOffset ∧ p.isProper ∧ p.isRigid ∧ p.isRightHanded ∧ p.isRealizable) ∧
