  rw [Homeomorph.image_closure p.shift]
  refine congrArg closure ?_
  change p.shift '' ((proj_xyL ∘ p.innerOffsetPart) '' S) = (proj_xyL ∘ p.innerOffsetPart) '' S
  ext w
  simp only [Set.mem_image, Set.mem_setOf_eq, Set.mem_closure]
  constructor
  · -- Assume w ∈ p.shift '' ((proj_xyL ∘ p.innerOffsetPart) '' S)
    rintro ⟨v, hv, h⟩
    refine ⟨v, by simpa using h⟩
  · -- Assume w ∈ (proj_xyL ∘ p.innerOffsetPart) '' S
    rintro ⟨v, hv, h⟩
    refine ⟨v, by simpa using h⟩

theorem rupert {S : Set ℝ³} (s_conv : Convex ℝ S) (s_psym : PointSym S) (p : MatrixPose) :
  (∃ v, (innerShadow p S) ⊆ translate v (outerShadow p (closure S))) →
  (innerShadow p S) ⊆ translate (p.shift) (outerShadow p (closure S)) := by
