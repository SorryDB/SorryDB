import Noperthedron.Rupert.Set
import Noperthedron.Util
import Noperthedron.MatrixPose
import Noperthedron.PoseClasses
import Noperthedron.PointSym

lemma shadows_eq {S : Set ℝ³} (p : MatrixPose) :
    p.shift '' closure (innerShadow p.zeroOffset S) =
      closure (innerShadow p S) := by
  have h1 : p.shift '' closure (innerShadow p.zeroOffset S) =
      p.shift '' closure (p.zeroOffset '' S) := by
    congr 1
    all_goals
      ext x
      simp [innerShadow]
  have h2 : p.zeroOffset = p.inner := by
    funext v
    simp [MatrixPose.inner, MatrixPose.zeroOffset]
  have h3 : p.shift '' closure (p.zeroOffset '' S) =
      p.shift '' closure (p.inner '' S) := by
    rw [h2]
  have h4 : p.shift '' closure (p.inner '' S) = closure (innerShadow p S) := by
    have h5 : innerShadow p S = closure (p.inner '' S) := by
      simp [innerShadow]
    rw [h5]
    have h6 : p.shift '' closure (p.inner '' S) = closure (p.inner '' S) := by
      have h7 : Continuous (p.shift : ℝ³ → ℝ³) := by
        continuity
      have h8 : p.shift '' closure (p.inner '' S) = closure (p.inner '' S) := by
        rw [←h7.map_closure]
      exact h8
    exact h6
  rw [h1]
  rw [h3]
  rw [h4]
