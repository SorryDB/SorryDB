    <;> ring_nf <;> simp [Matrix.cons_val_zero, Matrix.cons_val, Matrix.head_cons]
    <;> ring
  have h2 : nth_partial 1 (fun x => ‖P‖⁻¹ * inner ℝ (pbar.rotM₂ x) (pc.w)) pbar.outerParams =
      ‖P‖⁻¹ * (deriv (fun x => inner ℝ (pbar.rotM₂ x) (pc.w)) pbar.outerParams) 1 := by
