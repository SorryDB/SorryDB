    all_goals
      try { ring_nf <;> simp [Matrix.cons_val_zero, Matrix.cons_val, Matrix.head_cons] }
      <;> try { tauto }
  have h4 : pbar.rotM₂' pbar.outerParams = pbar.rotM₂φ P := by
    simp [pbar.rotM₂', pbar.rotM₂]
    <;> ring_nf <;> simp [Matrix.cons_val_zero, Matrix.cons_val, Matrix.head_cons]
    <;> ring
