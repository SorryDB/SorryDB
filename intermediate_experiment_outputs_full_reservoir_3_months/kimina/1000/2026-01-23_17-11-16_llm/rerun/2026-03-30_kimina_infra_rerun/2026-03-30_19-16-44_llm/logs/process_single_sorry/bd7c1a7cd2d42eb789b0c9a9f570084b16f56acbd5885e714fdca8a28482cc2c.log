def G (p : Pose) (ε : ℝ) (S : ℝ³) (w : ℝ²) : ℝ :=
  inner w (p.inner S) - (ε * (|inner ℝ (p.rotR' (p.rotM₁ S)) w| + |inner ℝ (p.rotR (p.rotM₁θ S)) w| + |inner ℝ (p.rotR (p.rotM₁φ S)) w|) + 9 * ε^2 / 2)

noncomputable
def H (p : Pose) (ε : ℝ) (w : ℝ²) (P : ℝ³) : ℝ :=
  inner w (p.outer P) + ε * (|inner ℝ (p.rotM₂θ P) w| + |inner ℝ (p.rotM₂φ P) w|) + 2 * ε^2

noncomputable
def maxH (p : Pose) (poly : GoodPoly) (ε : ℝ) (w : ℝ²) : ℝ :=
  (poly.vertices.image (fun P => H p ε w P)).max' (by
    simp only [Finset.image_nonempty]
    exact poly.nonempty)

noncomputable
def maxInner (p : Pose) (poly: GoodPoly) (w : ℝ²) : ℝ :=
  (p.imageInner poly w).max' (by
    simp only [Finset.image_nonempty]
    exact poly.nonempty)

noncomputable
def imageInner (p : Pose) (V : Finset ℝ³) (w : ℝ²) : Finset ℝ :=
  V.image (fun P => inner w (p.inner P))

noncomputable
def imageOuter (p : Pose) (V : Finset ℝ³) (w : ℝ²) : Finset ℝ :=
  V.image (fun P => inner w (p.outer P))

