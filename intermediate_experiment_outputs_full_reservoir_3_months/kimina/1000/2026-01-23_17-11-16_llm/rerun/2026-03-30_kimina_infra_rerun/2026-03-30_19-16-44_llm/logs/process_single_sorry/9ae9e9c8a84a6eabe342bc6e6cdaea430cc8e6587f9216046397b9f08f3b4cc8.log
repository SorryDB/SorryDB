  have h1 : p.inner v ∈ convexHull ℝ poly.vertices := by
    simp only [convexHull, Set.mem_coe, Set.mem_insert_iff, Set.mem_singleton_iff, and_imp]
    use p.inner v
    use v
    use (by simp [InnerProductSpace.inner_prod, Matrix.vecHead, Matrix.vecTail])
    use (by simp [InnerProductSpace.inner_prod, Matrix.vecHead, Matrix.vecTail])
    use (by simp [InnerProductSpace.inner_prod, Matrix.vecHead, Matrix.vecTail])
