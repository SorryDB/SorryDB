lemma Differentiable.rotproj_inner (S : ℝ³) (w : ℝ²) : Differentiable ℝ (fun x => inner (rotprojRM x S) w) :=
  Differentiable.inner ℝ (Differentiable.rotprojRM S) (by fun_prop)

