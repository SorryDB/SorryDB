       · -- Show that p.inner is differentiable\n                                                                                                apply HasFDerivAt.comp\n                                                                                                · -- Show that p.inner is differentiable\n                                                                                                      apply HasFDerivAt.comp\n                                                                                                      · -- Show that p.inner is differentiable\n                                                                                                        apply HasFDerivAt.comp\n                                                                                                        · -- Show that p.inner is differentiable\n                                                                                                          apply HasFDerivAt.comp\n                                                                                                          · -- Show that p.inner is differentiable\n                                                                                                            apply HasFDerivAt.comp\n                                                                                                            · -- Show that p.inner is differentiable\n                                                                                                              apply HasFDerivAt.comp\n                                                                                                              · -- Show that p.inner is differentiable\n                                                                                                                apply HasFDerivAt.comp\n                                                                                                                · -- Show that p.inner is differentiable\n             