import Mathlib

noncomputable
def rotproj_inner (S : ℝ³) (w : ℝ²) (x : ℝ³) : ℝ :=
  inner w (proj_z (rot_x (S.θ₁) (rot_y (S.φ₁) x)))

noncomputable
def proj_z (v : ℝ³) : ℝ³ :=
  (v.1, v.2, 0)

noncomputable
def rot_x (θ : ℝ) (v : ℝ³) : ℝ³ :=
  (v.1, v.2 * cos θ - v.3 * sin θ, v.2 * sin θ + v.3 * cos θ)

noncomputable
def rot_y (φ : ℝ) (v : ℝ³) : ℝ³ :=
  (v.1 * cos φ - v.2 * sin φ, v.1 * sin φ + v.2 * cos φ, v.3)

lemma rotation_partials_bounded (S : ℝ³) {w : ℝ²} (w_unit : ‖w‖ = 1) (x : ℝ³) :
    mixed_partials_bounded (rotproj_inner S w) x := by
  have h1 : (rotproj_inner S w) = fun x => inner w (proj_z (rot_x S.θ₁ (rot_y S.φ₁ x))) := by
    simp [rotproj_inner]
  rw [h1]
  apply mixed_partials_bounded_of_inner
  apply bounded_linear_transformations
  · -- Show that the function is linear in w
    apply linear_in_w
    -- The rest of the proof would involve showing that the partial derivatives with respect to x are bounded
    apply bounded_quadratic
