  simp [pc.fu_outer, rotproj_outer_unit]
  <;> field_simp [show ‖P‖ ≠ 0 by
    by_contra h
    have : ‖P‖ = 0 := by linarith
    have h_zero : P = 0 := by
      rw [EuclideanSpace.norm_eq_zero] at this
      simpa using this
    simp [h_zero]
    <;> ring_nf <;> norm_num
  ]
  <;> ring_nf <;> simp [Matrix.vecHead, Matrix.vecTail, Matrix.cons_val_zero, Matrix.cons_val, Matrix.head_cons, Matrix.tail_cons]
  <;> ring_nf <;> norm_num
  <;> ring
```

