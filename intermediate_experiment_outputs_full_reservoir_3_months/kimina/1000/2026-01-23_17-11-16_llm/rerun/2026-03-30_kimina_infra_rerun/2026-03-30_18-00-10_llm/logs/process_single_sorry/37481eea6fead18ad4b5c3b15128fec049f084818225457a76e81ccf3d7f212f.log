      "\n  have eq1 : deriv (interpolated_deriv x y f) = fun t => ∑ i, (y i - x i) * (deriv (fun (t : ℝ) => nth_partial i f ((1 - t) • x + t • y)) t) := by\n    funext t\n    simp [deriv_sum, deriv_mul, deriv_id'', mul_comm]\n    <;> try ring\n  have eq2 : ∀ i, deriv (fun (t : ℝ) => nth_partial i f ((1 - t) • x + t • y)) = fun t => ∑ j, (nth_partial i (fun (p : E n) => nth_partial j f p) ((1 - t) • x + t • y) ) * (y j - x i) := by\n    intro i\n    funext t\n    have h1 : Differentiable ℝ (fun (t : ℝ) => (1 - t) • x + t • y) := by\n      apply Differentiable.add\n      · apply Differentiable.const_mul\n        exact differentiable_id\n      · apply Differentiable.mul\n        · exact differentiable_const\n        · exact differentiable_id\n    have h2 : Differentiable ℝ (fun (p : E n) => nth_partial i f p) := by\n      apply Differentiable.nthPartial\n      apply (by infer_instance : ContDiff ℝ 2 f).differentiableOn\n    have h3 : Differentiable ℝ (fun (t : ℝ) => nth_partial i f ((1 - t) • x + t • y)) := by\n      apply Differentiable.comp\n      exact h2\n      exact h1\n    simp [deriv.comp, h1.differentiableAt, h2.differentiableAt]\n    <;> try simp [Fin.sum_univ_succ, Fin.sum_univ_zero]\n    <;> try ring\n  rw [eq1]\n  funext t\n  simp [eq2]\n  <;> try ring\n  <;> try simp [Fin.sum_univ_succ, Fin.sum_univ_zero]\n  <;> try ring",
