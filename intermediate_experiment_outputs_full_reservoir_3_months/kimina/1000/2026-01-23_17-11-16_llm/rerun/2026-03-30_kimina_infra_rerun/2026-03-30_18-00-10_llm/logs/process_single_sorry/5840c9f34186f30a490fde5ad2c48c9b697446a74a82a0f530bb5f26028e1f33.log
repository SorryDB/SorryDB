    {poly : GoodPoly} {p : Pose} {Œµ : ‚Ñù}
    (hp : GlobalTheoremPrecondition poly p Œµ) : ‚Äñhp.S‚Äñ ‚â§ 1 :=
  poly.vertex_radius_le_one hp.S hp.S_in_poly

