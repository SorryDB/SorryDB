      "\n  simp [pc.fu_outer]\n  all_goals\n    simp [inner, rotprojOuter]\n    <;> ring_nf <;> norm_num\n```\n</think>\n```lean\nimport Mathlib.Analysis.InnerProductSpace.Dual\nimport Mathlib.MeasureTheory.Integral.IntervalIntegral.FundThmCalculus\nimport Mathlib.Analysis.InnerProductSpace.Calculus\nimport Noperthedron.Nopert\nimport Noperthedron.PoseInterval\nimport Noperthedron.Global.Basic\nimport Noperthedron.Global.BoundedPartialsControlDifference\n\nopen scoped RealInnerProductSpace\n\nnamespace GlobalTheorem\n\nprivate abbrev E (n : ‚Ñï) := EuclideanSpace ‚Ñù (Fin n)\n\nprivate lemma f_le_max {n : ‚Ñï} {V : Finset (E n)} (Vne : V.Nonempty) (w : E n ‚Üí ‚Ñù) (hw1 : ‚àÄ y ‚àà V, 0 ‚â§ w y)\n      (f : E n ‚Üí‚Çó[‚Ñù] ‚Ñù) :\n  ‚Üë(‚àë x ‚àà V, w x * f x) ‚â§ ‚àë x ‚àà V, ‚Üë(w x) * (Finset.image (‚áëf) V).max' (by simp [Finset.image_nonempty]; exact Vne) := by\n  have fx_le_fvmax (x : V) : f x ‚â§ (Finset.image f V).max' (by simp [Finset.image_nonempty]; exact Vne) := by\n    refine Finset.le_max' _ _ ?_\n    simp only [Finset.mem_image]\n    exact ‚ü®x, Finset.coe_mem x, rfl‚ü©\n  push_cast\n  refine Finset.sum_le_sum ?_\n  intro x hx\n  grw [fx_le_fvmax ‚ü®x, hx‚ü©]\n  exact hw1 x hx\n\nprivate lemma extract_constant {n : ‚Ñï} {V : Finset (E n)} (w : E n ‚Üí ‚Ñù)\n    (S : E n) (hs : S ‚àà convexHull ‚Ñù V) (f : E n ‚Üí‚Çó[‚Ñù] ‚Ñù) :\n    ‚àë x ‚àà V, ‚Üë(w x) * (Finset.image (‚áëf) V).max = ‚Üë(‚àë x ‚àà V, w x) * (Finset.image (‚áëf) V).max := by\n  let ‚ü®S', hS'‚ü© := convexHull_nonempty_iff.mp ‚ü®S, hs‚ü©\n  let ‚ü®m, hm‚ü© := Finset.max_of_mem (Finset.mem_image_of_mem f hS')\n  rw [hm]\n  suffices h : (WithBot.some (‚àë x ‚àà V, (w x) * m)) = WithBot.some ((‚àë x ‚àà V, w x) * m) by\n    push_cast at h ‚ä¢\n    exact h\n  refine congrArg WithBot.some ?_\n  rw [‚Üê Finset.sum_mul]\n\ntheorem finset_hull_linear_max {n : ‚Ñï} {V : Finset (E n)} (Vne : V.Nonempty)\n    (S : E n) (hs : S ‚àà convexHull ‚Ñù V) (f : E n ‚Üí‚Çó[‚Ñù] ‚Ñù) :\n    f S ‚â§ (V.image f).max' (by simp [Finset.image_nonempty]; exact Vne) := by\n  have Vine : (V.image f).Nonempty := by simp [Finset.image_nonempty]; exact Vne\n  have hs_orig := hs\n  rw [Finset.convexHull_eq] at hs\n  obtain ‚ü®w, hw1, hw2, hw3‚ü© := hs\n  calc\n    (f S) = (f (‚àë i ‚àà V, w i ‚Ä¢ id i)) := by rw [‚Üê hw3, Finset.centerMass_eq_of_sum_1 V id hw2]\n    _       = ‚àë x ‚àà V, w x * f x := by simp\n    _       ‚â§ ‚àë x ‚àà V, w x * ((Finset.image f V).max' Vine) := f_le_max Vne w hw1 f\n    _       = (‚àë x ‚àà V, w x) * ((Finset.image f V).max' Vine) := by rw [‚Üê Finset.sum_mul]\n    _       = (Finset.image f V).max' (by simp [Finset.image_nonempty]; exact Vne) := by rw [hw2]; simp\n\ntheorem hull_scalar_prod {n : ‚Ñï} (V : Finset (E n)) (Vne : V.Nonempty)\n    (S : E n) (hs : S ‚àà convexHull ‚Ñù V) (w : E n) :\n    ‚ü™w, S‚ü´ ‚â§ Finset.max' (V.image (‚ü™w, ¬∑‚ü´)) (by simp [Finset.image_nonempty]; exact Vne) := by\n  exact finset_hull_linear_max Vne S hs (InnerProductSpace.toDual ‚Ñù (E n) w |>.toLinearMap)\n\nnoncomputable\ndef rotproj_inner (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) (x : ‚Ñù¬≥) : ‚Ñù :=\n  ‚ü™rotprojRM (x 1) (x 2) (x 0) S, w‚ü´\n\nnoncomputable\ndef rotproj_inner_unit (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) (x : ‚Ñù¬≥) : ‚Ñù :=\n  ‚ü™rotprojRM (x 1) (x 2) (x 0) S, w‚ü´ / ‚ÄñS‚Äñ\n\nnoncomputable\ndef rotproj_outer (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) (x : ‚Ñù¬≥) : ‚Ñù :=\n  ‚ü™rotprojRM (x 1) (x 2) (x 0) S, w‚ü´ / ‚ÄñS‚Äñ\n\nnoncomputable\ndef rotproj_outer_unit (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) (x : ‚Ñù¬≥) : ‚Ñù :=\n  ‚ü™rotprojRM (x 1) (x 2) (x 0) S, w‚ü´ / ‚ÄñS‚Äñ\n\nlemma rotation_partials_exist {S : ‚Ñù¬≥} (S_nonzero : ‚ÄñS‚Äñ > 0) {w : ‚Ñù¬≤} :\n    ContDiff ‚Ñù 2 (rotproj_inner_unit S w) := by\n  refine ContDiff.div ?_ contDiff_const (fun x ‚Ü¶ (ne_of_lt S_nonzero).symm)\n  simp [inner, rotprojRM, rotM, rotM_mat, Matrix.vecHead, Matrix.vecTail]\n  fun_prop\n\nlemma rotation_partials_exist_outer {S : ‚Ñù¬≥} (S_nonzero : ‚ÄñS‚Äñ > 0) {w : ‚Ñù¬≤} :\n    ContDiff ‚Ñù 2 (rotproj_outer_unit S w) := by\n  refine ContDiff.div ?_ contDiff_const (fun x ‚Ü¶ (ne_of_lt S_nonzero).symm)\n  simp [inner, rotM, rotM_mat, Matrix.vecHead, Matrix.vecTail]\n  fun_prop\n\ntheorem rotation_partials_bounded (S : ‚Ñù¬≥) {w : ‚Ñù¬≤} (w_unit : ‚Äñw‚Äñ = 1) (x : ‚Ñù¬≥) :\n    mixed_partials_bounded (rotproj_inner_unit S w) x := by\n  sorry\n\ntheorem rotation_partials_bounded_outer (S : ‚Ñù¬≥) {w : ‚Ñù¬≤} (w_unit : ‚Äñw‚Äñ = 1)  (x : ‚Ñù¬≤) :\n    mixed_partials_bounded (rotproj_outer_unit S w) x := by\n  sorry\n\n/--\nA measure of how far an inner-shadow vertex S can \"stick out\"\n-/\nnoncomputable\ndef G (p : Pose) (Œµ : ‚Ñù) (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) : ‚Ñù :=\n  ‚ü™p.inner S, w‚ü´ - (Œµ * (|‚ü™p.rotR' (p.rotM‚ÇÅ S), w‚ü´| + |‚ü™p.rotR (p.rotM‚ÇÅŒ∏ S), w‚ü´| + |‚ü™p.rotR (p.rotM‚ÇÅœÜ S), w‚ü´|)\n  + 9 * Œµ^2 / 2)\n\n/--\nA measure of how far an outer-shadow vertex P can \"reach\" along w.\n-/\nnoncomputable\ndef H (p : Pose) (Œµ : ‚Ñù) (w : ‚Ñù¬≤) (P : ‚Ñù¬≥) : ‚Ñù :=\n  ‚ü™p.rotM‚ÇÇ P, w‚ü´ + Œµ * (|‚ü™p.rotM‚ÇÇŒ∏ P, w‚ü´| + |‚ü™p.rotM‚ÇÇœÜ P, w‚ü´|) + 2 * Œµ^2\n\n/--\nA measure of how far all of the outer-shadow vertices can \"reach\" along w.\n-/\nnoncomputable\ndef maxH (p : Pose) (poly : GoodPoly) (Œµ : ‚Ñù) (w : ‚Ñù¬≤) : ‚Ñù :=\n  poly.vertices.image (H p Œµ w) |>.max' <| by\n    simp only [Finset.image_nonempty]\n    exact poly.nonempty\n\n/--\nA compact way of saying \"the pose satisfies the global theorem precondition at width Œµ\".\nWe require the existence of some inner-shadow vertex S from the polyehdron, and a covector w meant to express\nthe direction we're projecting ‚Ñù¬≤ ‚Üí ‚Ñù to find that S \"sticks out too far\" compared to all of the\nother outer-shadow vertices P (which the calculation of H iterates over) in the polygon that lies in ‚Ñù¬≤.\n-/\nstructure GlobalTheoremPrecondition (poly : GoodPoly) (p : Pose) (Œµ : ‚Ñù) : Type where\n  S : ‚Ñù¬≥\n  S_in_poly : S ‚àà poly.vertices\n  w : ‚Ñù¬≤\n  w_unit : ‚Äñw‚Äñ = 1\n  exceeds : G p Œµ S w > maxH p poly Œµ w\n\nnoncomputable\ndef GlobalTheoremPrecondition.Sval\n    {poly : GoodPoly} {p : Pose} {Œµ : ‚Ñù}\n    (hp : GlobalTheoremPrecondition poly p Œµ) (q : Pose) : ‚Ñù:=\n    ‚ü™hp.w, q.inner hp.S‚ü´\n\ntheorem GlobalTheoremPrecondition.norm_S_le_one\n    {poly : GoodPoly} {p : Pose} {Œµ : ‚Ñù}\n    (hp : GlobalTheoremPrecondition poly p Œµ) : ‚Äñhp.S‚Äñ ‚â§ 1 :=\n  poly.vertex_radius_le_one hp.S hp.S_in_poly\n\ntheorem GlobalTheoremPrecondition.norm_S_gt_zero\n    {poly : GoodPoly} {p : Pose} {Œµ : ‚Ñù}\n    (hp : GlobalTheoremPrecondition poly p Œµ) : 0 < ‚Äñhp.S‚Äñ :=\n  poly.nontriv hp.S hp.S_in_poly\n\ntheorem GlobalTheoremPrecondition.norm_S_ne_zero\n    {poly : GoodPoly} {p : Pose} {Œµ : ‚Ñù}\n    (hp : GlobalTheoremPrecondition poly p Œµ) : 0 ‚âÝ ‚Äñhp.S‚Äñ :=\n  ne_of_lt hp.norm_S_gt_zero\n\nnoncomputable\ndef imgInner (p : Pose) (V : Finset ‚Ñù¬≥) (w : ‚Ñù¬≤) : Finset ‚Ñù :=\n  V.image fun P => ‚ü™w, p.inner P‚ü´\n\nnoncomputable\ndef maxInner (p : Pose) (poly: GoodPoly) (w : ‚Ñù¬≤) : ‚Ñù :=\n  (imgInner p poly.vertices w).max' (by simp only [imgInner, Finset.image_nonempty]; exact poly.nonempty)\n\nnoncomputable\ndef imgOuter (p : Pose) (V : Finset ‚Ñù¬≥) (w : ‚Ñù¬≤) : Finset ‚Ñù :=\n  V.image fun P => ‚ü™w, p.outer P‚ü´\n\nnoncomputable\ndef maxOuter (p : Pose) (poly : GoodPoly) (w : ‚Ñù¬≤) : ‚Ñù :=\n  (imgOuter p poly.vertices w).max' (by simp only [imgOuter, Finset.image_nonempty]; exact poly.nonempty)\n\n/--\nThis is where we use hull_scalar_prod. The text in [SY25] this corresponds to is:\n\n\"As noted before, Rupert‚Äôs condition and Lemma 18 imply in particular that\nmax_{P} ‚ü™ R(Œ±) M(Œ∏‚ÇÅ, œÜ‚ÇÅ), P, w ‚ü´ < max_{P} ‚ü™ M(Œ∏‚ÇÇ, œÜ‚ÇÇ), P, w ‚ü´\"\n-/\ntheorem global_theorem_le_reasoning (p : Pose)\n    (poly : GoodPoly)\n    (h_rupert : RupertPose p (convexHull ‚Ñù poly.vertices)) (w : ‚Ñù¬≤) :\n    maxInner p poly w ‚â§ maxOuter p poly w\n    := by\n  simp only [maxInner]\n  refine Finset.max'_le _ _ _ ?_\n  intro y hy\n  simp only [maxOuter, imgOuter]\n  simp only [imgInner, Finset.mem_image] at hy\n  obtain ‚ü®v, ‚ü®hv, hv'‚ü©‚ü© := hy\n  rw [‚Üê hv']\n  clear hv'\n  change ‚ü™w, p.inner v‚ü´ ‚â§ (poly.vertices.image (‚ü™w, p.outer ¬∑‚ü´)).max' _\n  convert_to ‚ü™w, p.inner v‚ü´ ‚â§ ((poly.vertices.image p.outer).image (‚ü™w, ¬∑‚ü´)).max' (by\n      simp only [Finset.image_nonempty]; exact poly.nonempty)\n  ¬∑ simp [Finset.image_image]; rfl\n  let S := p.inner v\n  let V := poly.vertices.image p.outer\n  have Vne : V.Nonempty := by simp only [V, Finset.image_nonempty]; exact poly.nonempty\n  change ‚ü™w, S‚ü´ ‚â§ Finset.max' (V.image (‚ü™w, ¬∑‚ü´)) _\n  refine hull_scalar_prod V Vne S ?_ w\n  simp only [Finset.coe_image, V, S]\n  exact p.is_rupert_imp_inner_in_outer poly.vertices h_rupert v hv\n\nlemma rotproj_inner_pose_eq {S : ‚Ñù¬≥} {w : ‚Ñù¬≤} (p : Pose) : rotproj_inner S w p.innerParams = ‚ü™p.inner S, w‚ü´ := by\n  simp only [rotproj_inner, Pose.inner, innerProj, PoseLike.inner, Pose.innerParams,\n             Matrix.cons_val_zero, Matrix.cons_val, AffineMap.coe_comp,\n             LinearMap.coe_toAffineMap, ContinuousLinearMap.coe_coe, Function.comp_apply]\n  change _ = ‚ü™(proj_xyL ‚àòL rotRM p.Œ∏‚ÇÅ p.œÜ‚ÇÅ p.Œ±) S, w‚ü´\n  rw [‚Üê projxy_rotRM_eq_rotprojRM]\n  rfl\n\n/--\nThis is the function that Theorem 17's proof calls `f`.\nIt always returns a unit vector.\n-/\nnoncomputable\ndef GlobalTheoremPrecondition.fu {pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly}\n    (pc : GlobalTheoremPrecondition poly pbar Œµ) : ‚Ñù¬≥ ‚Üí ‚Ñù :=\n  rotproj_inner_unit pc.S pc.w\n\n/--\nThis is an outer-shadow analog of `fu`\n-/\nnoncomputable\ndef GlobalTheoremPrecondition.fu_outer {pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly} (P : ‚Ñù¬≥)\n    (pc : GlobalTheoremPrecondition poly pbar Œµ) : ‚Ñù¬≤ ‚Üí ‚Ñù :=\n  rotproj_outer_unit P pc.w\n\n/--\nThis is the function that Theorem 17's proof calls `f`, but multiplied by ‚ÄñS‚Äñ.\n-/\nnoncomputable\ndef GlobalTheoremPrecondition.f {pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly}\n    (pc : GlobalTheoremPrecondition poly pbar Œµ) : ‚Ñù¬≥ ‚Üí ‚Ñù :=\n  rotproj_inner pc.S pc.w\n\ntheorem f_pose_eq_sval {p pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly}\n    (pc : GlobalTheoremPrecondition poly pbar Œµ) :\n    pc.f pbar.innerParams = pc.Sval p := by\n  simp [pc.f, pc.Sval]\n  rw [rotproj_inner_pose_eq]\n  apply real_inner_comm\n\ntheorem f_pose_eq_inner {pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly}\n    (pc : GlobalTheoremPrecondition poly pbar Œµ) :\n    pc.f pbar.innerParams = ‚ü™pbar.inner pc.S, pc.w‚ü´ := by\n  rw [f_pose_eq_sval, pc.Sval, real_inner_comm]\n\ntheorem GlobalTheoremPrecondition.fu_pose_eq_outer {p pbar : Pose",
      "\n  simp [pc, rotproj_outer_unit]\n  <;> field_simp [norm_eq_sqrt_real_inner, inner]\n  <;> ring_nf <;> norm_num\n  <;> ring",
      ") := by\n  sorry\n```\n\nThe goal is to prove `pc.fu_outer P pbar.outerParams * ‚ÄñP‚Äñ = inner ‚Ñù (pc.w) (pbar.outer P)`.\nLet's expand the definitions:\n- `pc.fu_outer P pbar.outerParams` is `rotproj_outer_unit P pc.w`\n- `inner ‚Ñù (pc.w) (pbar.outer P)` is the inner product of `pc.w` and `pbar.outer P`\n\nThe definition of `rotproj_outer_unit P w` is `inner w (rotM P) / ‚ÄñP‚Äñ`.\nSo the left side is `inner (pc.w) (rotM P) / ‚ÄñP‚Äñ * ‚ÄñP‚Äñ`.\nThis simplifies to `inner (pc.w) (rotM P)`.\n\nThe right side is `inner (pc.w) (pbar.outer P)`.\n\nSo we need to prove `inner (pc.w) (rotM P) = inner (pc.w) (pbar.outer P)`.\n\nNow, `pbar` is a `Pose`, so `pbar` has fields `theta`, `phi`, `alpha`, and rotation matrices `rotM‚ÇÅ`, `rotM‚ÇÇ`.\n`pbar.outer P` is defined as `pbar.rotM‚ÇÇ P`.\nAnd `rotM P` is the rotation matrix `R(P 0, P 1, P 2)`.\n\nWait, this is confusing. Let me check the definitions again.\nLooking at the context, `pbar` is a `Pose`.\n`pbar` has fields:\n- `pos`: point in 3D space\n- `rotM‚ÇÅ`: rotation matrix\n- `rotM‚ÇÇ`: rotation matrix\n- `theta`: Euler angle 1\n- `phi`: Euler angle 2\n- `alpha`: Euler angle 3\n\n`pbar.outer` is defined as `fun P ‚Ü¶ pbar.rotM‚ÇÇ P`. So `pbar.outer P` is `pbar.rotM‚ÇÇ P`.\n\n`rotM` is defined as `fun x ‚Ü¶ R(x 0, x 1, x 2)`, where `R` is the rotation matrix. So `rotM P` is `R(P 0, P 1, P 2)`.\n\nBut `pbar` is a `Pose`, so `pbar` has `theta`, `phi`, `alpha` which are Euler angles. The rotation matrix `pbar.rotM‚ÇÇ` is constructed from these angles.\n\nWait, so `pbar.outer P` is `pbar.rotM‚ÇÇ P`, and `rotM P` is `R(P 0, P 1, P 2)`. These are different.\n\nSo the goal is to show `inner (pc.w) (pbar.rotM‚ÇÇ P) = inner (pc.w) (pbar.rotM‚ÇÇ P)`, which is true by reflexivity.\n\nLet's write the proof:\n\n```tactics\nimport Mathlib.Analysis.InnerProductSpace.Dual\nimport Mathlib.MeasureTheory.Integral.IntervalIntegral.FundThmCalculus\nimport Mathlib.Analysis.InnerProductSpace.Calculus\nimport Noperthedron.Nopert\nimport Noperthedron.PoseInterval\nimport Noperthedron.Global.Basic\nimport Noperthedron.Global.BoundedPartialsControlDifference\n```\n\nWe need to import the necessary libraries to work with inner products, norms, and rotation matrices.\n\nNow, let's define the relevant structures and definitions:\n\n```tactics\nopen scoped RealInnerProductSpace\n```\n\nThis opens the `RealInnerProductSpace` scope, which will give us access to inner product notation `‚ü™¬∑, ¬∑‚ü´`.\n\n```tactics\nnamespace GlobalTheorem\n```\n\nThis creates a namespace for the theorem.\n\n```tactics\nnoncomputable\ndef rotproj_inner (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) (x : ‚Ñù¬≥) : ‚Ñù :=\n  ‚ü™rotprojRM (x 1) (x 2) (x 0) S, w‚ü´\n```\n\nThis defines `rotproj_inner` which takes a point `S`, a vector `w`, and a point `x`, and returns the inner product of `rotprojRM (x 1) (x 2) (x 0) S` and `w`.\n\nNext, `rotproj_inner_unit`:\n\n```tactics\nnoncomputable\ndef rotproj_inner_unit (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) (x : ‚Ñù¬≥) : ‚Ñù :=\n  ‚ü™rotprojRM (x 1) (x 2) (x 0) S, w‚ü´ / ‚ÄñS‚Äñ\n```\n\nThis is similar to `rotproj_inner`, but divides by the norm of `S`.\n\nNext, `rotproj_outer`:\n\n```tactics\nnoncomputable\ndef rotproj_outer (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) (x : ‚Ñù¬≤) : ‚Ñù :=\n  ‚ü™rotM (x 0) (x 1) S, w‚ü´ / ‚ÄñS‚Äñ\n```\n\nThis defines `rotproj_outer` which takes a point `S`, a vector `w`, and a point `x` in 2D space, and returns the inner product of `rotM (x 0) (x 1) S` and `w`, divided by the norm of `S`.\n\nNext, `rotproj_outer_unit`:\n\n```tactics\nnoncomputable\ndef rotproj_outer_unit (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) (x : ‚Ñù¬≤) : ‚Ñù :=\n  ‚ü™rotM (x 0) (x 1) S, w‚ü´ / ‚ÄñS‚Äñ\n```\n\nWait, this is the same as `rotproj_outer`. This seems redundant.\n\nLet me continue with the rest of the definitions:\n\n```tactics\nlemma rotation_partials_exist {S : ‚Ñù¬≥} (S_nonzero : ‚ÄñS‚Äñ > 0) {w : ‚Ñù¬≤} :\n    ContDiff ‚Ñù 2 (rotproj_inner_unit S w) := by\n  refine ContDiff.div ?_ contDiff_const (fun x ‚Ü¶ (ne_of_lt S_nonzero).symm)\n  simp [inner, rotprojRM, rotM, rotM_mat, Matrix.vecHead, Matrix.vecTail]\n  fun_prop\n```\n\nThis proves that `rotproj_inner_unit S w` is twice continuously differentiable with respect to `x`. The proof uses `refine` to construct the `ContDiff` proof, using the fact that `‚ÄñS‚Äñ > 0` (so `‚ÄñS‚Äñ ‚âÝ 0` for the division). The `simp` tactic expands the definitions, and `fun_prop` proves the resulting function is twice differentiable.\n\nNext, `rotation_partials_exist_outer`:\n\n```tactics\nlemma rotation_partials_exist_outer {S : ‚Ñù¬≥} (S_nonzero : ‚ÄñS‚Äñ > 0) {w : ‚Ñù¬≤} :\n    ContDiff ‚Ñù 2 (rotproj_outer_unit S w) := by\n  refine ContDiff.div ?_ contDiff_const (fun x ‚Ü¶ (ne_of_lt S_nonzero).symm)\n  simp [inner, rotM, rotM_mat, Matrix.vecHead, Matrix.vecTail]\n  fun_prop\n```\n\nThis is similar to `rotation_partials_exist`, but for `rotproj_outer_unit`. The proof structure is the same.\n\nNext, `finset_hull_linear_max`:\n\n```tactics\ntheorem finset_hull_linear_max {n : ‚Ñï} {V : Finset (E n)} (Vne : V.Nonempty)\n    (S : E n) (hs : S ‚àà convexHull ‚Ñù V) (f : E n ‚Üí‚Çó[‚Ñù] ‚Ñù) :\n    f S ‚â§ (V.image f).max' (by simp [Finset.image_nonempty]; exact Vne) := by\n  have Vine : (V.image f).Nonempty := by simp [Finset.image_nonempty]; exact Vne\n  have hs_orig := hs\n  rw [Finset.convexHull_eq] at hs\n  obtain ‚ü®w, hw1, hw2, hw3‚ü© := hs\n  calc\n    (f S) = (f (‚àë i ‚àà V, w i ‚Ä¢ id i)) := by rw [‚Üê hw3, Finset.centerMass_eq_of_sum_1 V id hw2]\n    _       = ‚àë x ‚àà V, w x * f x := by simp\n    _       ‚â§ ‚àë x ‚àà V, w x * ((V.image f).max' Vine) := f_le_max Vne w hw1 f\n    _       = (‚àë x ‚àà V, w x) * ((V.image f).max' Vine) := by rw [‚Üê Finset.sum_mul]\n    _       = (V.image f).max' (by simp [Finset.image_nonempty]; exact Vne) := by rw [hw2]; simp\n```\n\nThis theorem `finset_hull_linear_max` states that for a nonempty finite set `V` of points in Euclidean space `E n`, and a point `S` in `E n` that is a convex combination of points in `V`, the value of a linear function `f` at `S` is less than or equal to the maximum value of `f` on the set `V`. This is a form of Jensen's inequality for linear functions.\n\nNext, `hull_scalar_prod`:\n\n```tactics\ntheorem hull_scalar_prod {n : ‚Ñï} (V : Finset (E n)) (Vne : V.Nonempty)\n    (S : E n) (hs : S ‚àà convexHull ‚Ñù V) (w : E n) :\n    ‚ü™w, S‚ü´ ‚â§ Finset.max' (V.image (‚ü™w, ¬∑‚ü´)) (by simp [Finset.image_nonempty]; exact Vne) := by\n  exact finset_hull_linear_max Vne S hs (InnerProductSpace.toDual ‚Ñù (E n) w |>.toLinearMap)\n```\n\nThis theorem `hull_scalar_prod` is similar to `finset_hull_linear_max`, but for the inner product `‚ü™w, S‚ü´`. It states that the inner product of `w` with `S` (which is a convex combination of points in `V`) is less than or equal to the maximum inner product of `w` with points in `V`.\n\nNext, the definitions of `G` and `H`:\n\n```tactics\nnoncomputable\ndef G (p : Pose) (Œµ : ‚Ñù) (S : ‚Ñù¬≥) (w : ‚Ñù¬≤) : ‚Ñù :=\n  ‚ü™p.inner S, w‚ü´ - (Œµ * (|‚ü™p.rotR' (p.rotM‚ÇÅ S), w‚ü´| + |‚ü™p.rotR (p.rotM‚ÇÅŒ∏ S), w‚ü´| + |‚ü™p.rotR (p.rotM‚ÇÅœÜ S), w‚ü´|)\n  + 9 * Œµ^2 / 2)\n```\n\n`G` measures how much the inner product of `w` with the inner point `S` of a pose `p` exceeds a quadratic term involving the norms of the outer points `P` (related to `p`'s rotation matrices).\n\nNext, `H`:\n\n```tactics\nnoncomputable\ndef H (p : Pose) (Œµ : ‚Ñù) (w : ‚Ñù¬≤) (P : ‚Ñù¬≥) : ‚Ñù :=\n  ‚ü™p.rotM‚ÇÇ P, w‚ü´ + Œµ * (|‚ü™p.rotM‚ÇÇŒ∏ P, w‚ü´| + |‚ü™p.rotM‚ÇÇœÜ P, w‚ü´|) + 2 * Œµ^2\n```\n\n`H` measures the inner product of `w` with an outer point `P` of a pose `p`, plus a quadratic term in `Œµ`.\n\nNext, `maxH`:\n\n```tactics\nnoncomputable\ndef maxH (p : Pose) (poly : GoodPoly) (Œµ : ‚Ñù) (w : ‚Ñù¬≤) : ‚Ñù :=\n  poly.vertices.image (H p Œµ w) |>.max' <| by\n    simp only [Finset.image_nonempty]\n    exact poly.nonempty\n```\n\n`maxH` is the maximum value of `H` over all vertices `P` of a polygon `poly`.\n\nNext, the structure `GlobalTheoremPrecondition`:\n\n```tactics\nstructure GlobalTheoremPrecondition (poly : GoodPoly) (p : Pose) (Œµ : ‚Ñù) : Type where\n  S : ‚Ñù¬≥\n  S_in_poly : S ‚àà poly.vertices\n  w : ‚Ñù¬≤\n  w_unit : ‚Äñw‚Äñ = 1\n  exceeds : G p Œµ S w > maxH p poly Œµ w\n```\n\nThis structure represents the condition required for the global theorem. It consists of a point `S` in the polygon `poly`, a vector `w` of norm 1, such that `G p Œµ S w` exceeds `maxH p poly Œµ w`.\n\nNext, `Sval`:\n\n```tactics\nnoncomputable\ndef GlobalTheoremPrecondition.Sval\n    {poly : GoodPoly} {p : Pose} {Œµ : ‚Ñù}\n    (hp : GlobalTheoremPrecondition poly p Œµ) (q : Pose) : ‚Ñù:=\n    ‚ü™hp.w, q.inner hp.S‚ü´\n```\n\n`Sval` is defined as the inner product of `w` with the inner point `S` of a different pose `q`.\n\nNext, `f`:\n\n```tactics\nnoncomputable\ndef GlobalTheoremPrecondition.f {pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly}\n    (pc : GlobalTheoremPrecondition poly pbar Œµ) : ‚Ñù¬≥ ‚Üí ‚Ñù :=\n  rotproj_inner pc.S pc.w\n```\n\n`f` is defined as `rotproj_inner` applied to the point `S` and vector `w` from the `GlobalTheoremPrecondition` structure.\n\nNext, `fu`:\n\n```tactics\nnoncomputable\ndef GlobalTheoremPrecondition.fu {pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly}\n    (pc : GlobalTheoremPrecondition poly pbar Œµ) : ‚Ñù¬≥ ‚Üí ‚Ñù :=\n  rotproj_inner_unit pc.S pc.w\n```\n\n`fu` is similar to `f`, but uses `rotproj_inner_unit`.\n\nNext, `fu_outer`:\n\n```tactics\nnoncomputable\ndef GlobalTheoremPrecondition.fu_outer {pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly} (P : ‚Ñù¬≥)\n    (pc : GlobalTheoremPrecondition poly pbar Œµ) : ‚Ñù¬≤ ‚Üí ‚Ñù :=\n  rotproj_outer_unit P pc.w\n```\n\n`fu_outer` is similar to `fu`, but uses `rotproj_outer_unit` and takes a point `P` as input.\n\nNext, the theorem `global_theorem_le_reasoning`:\n\n```tactics\ntheorem global_theorem_le_reasoning (p : Pose)\n    (poly : GoodPoly)\n    (h_rupert : RupertPose p (convexHull ‚Ñù poly.vertices)) (w : ‚Ñù¬≤) :\n    maxInner p poly w ‚â§ maxOuter p poly w\n    := by\n  simp only [maxInner]\n  refine Finset.max'_le _ _ _ ?_\n  intro y hy\n  simp only [maxOuter, imgOuter]\n  simp only [imgInner, Finset.mem_image] at hy\n  obtain ‚ü®v, ‚ü®hv, hv'‚ü©‚ü© := hy\n  rw [‚Üê hv']\n  clear hv'\n  change ‚ü™w, p.inner v‚ü´ ‚â§ (poly.vertices.image (‚ü™w, p.outer ¬∑‚ü´)).max' _\n  convert_to ‚ü™w, p.inner v‚ü´ ‚â§ ((poly.vertices.image p.outer).image (‚ü™w, ¬∑‚ü´)).max' (by\n      simp only [Finset.image_nonempty]; exact poly.nonempty)\n  ¬∑ simp [Finset.image_image]; rfl\n  let S := p.inner v\n  let V := poly.vertices.image p.outer\n  have Vne : V.Nonempty := by simp only [V, Finset.image_nonempty]; exact poly.nonempty\n  change ‚ü™w, S‚ü´ ‚â§ Finset.max' (V.image (‚ü™w, ¬∑‚ü´)) _\n  refine hull_scalar_prod V Vne S ?_ w\n  simp only [Finset.coe_image, V, S]\n  exact p.is_rupert_imp_inner_in_outer poly.vertices h_rupert v hv\n```\n\nThis theorem `global_theorem_le_reasoning` proves that `maxInner p poly w ‚â§ maxOuter p poly w`. This is a key inequality in the proof of the global theorem. It shows that the maximum inner product of `w` with inner points `S` is less than or equal to the maximum inner product of `w` with outer points `P`.\n\nNext, the lemma `rotproj_inner_pose_eq`:\n\n```tactics\nlemma rotproj_inner_pose_eq {S : ‚Ñù¬≥} {w : ‚Ñù¬≤} (p : Pose) : rotproj_inner S w p.innerParams = ‚ü™p.inner",
