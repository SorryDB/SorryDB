def GlobalTheoremPrecondition.fu {pbar : Pose} {Œµ : ‚Ñù} {poly : GoodPoly}
    (pc : GlobalTheoremPrecondition poly pbar Œµ) : ‚Ñù¬≥ ‚Üí ‚Ñù :=
  fun P => rotproj_inner_unit pc.S pc.w P

