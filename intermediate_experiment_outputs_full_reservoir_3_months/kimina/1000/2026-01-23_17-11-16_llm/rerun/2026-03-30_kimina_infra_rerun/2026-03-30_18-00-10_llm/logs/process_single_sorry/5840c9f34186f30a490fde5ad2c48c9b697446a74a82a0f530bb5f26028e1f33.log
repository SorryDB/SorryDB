    (S : E n) (hs : S ‚àà convexHull ‚Ñù V) (w : E n) :
    ‚ü™w, S‚ü´ ‚â§ Finset.max' (V.image (‚ü™w, ¬∑‚ü´)) (by simp [Finset.image_nonempty]; exact Vne) := by
  exact finset_hull_linear_max Vne S hs (InnerProductSpace.toDual ‚Ñù (E n) w |>.toLinearMap)

