  S : ‚Ñù¬≥
  S_in_poly : S ‚àà poly.vertices
  w : ‚Ñù¬≤
  w_unit : ‚Äñw‚Äñ = 1
  exceeds : G p Œµ S w > maxH p poly Œµ w

