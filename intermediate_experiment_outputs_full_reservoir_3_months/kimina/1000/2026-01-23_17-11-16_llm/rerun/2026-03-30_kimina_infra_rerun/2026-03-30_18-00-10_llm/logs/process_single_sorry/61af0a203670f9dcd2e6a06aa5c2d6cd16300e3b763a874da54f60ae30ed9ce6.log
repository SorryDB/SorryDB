      "\n  have h1 : deriv (interpolated x y f) = fun t => deriv (f ∘ (interpolator x y)) t := by\n    simp [interpolated]\n  rw [h1]\n  funext t\n  simp [deriv.comp, Differentiable.interpolator x y]\n  all_goals\n    simp [interpolated_deriv]\n    <;> field_simp\n    <;> ring",
      "\n  have h5 : deriv (interpolated x y f) = deriv f ∘ (interpolator x y) * deriv (interpolator x y) := by\n    funext t\n    simp [deriv.comp]\n    <;> ring\n  have h6 : deriv (interpolator x y) = fun _ => y - x := by\n    funext t\n    simp [deriv_add, deriv_sub, deriv_const, deriv_id', mul_comm]\n    <;> ring\n  rw [h5, h6]\n  funext t\n  simp [interpolated_deriv]\n  <;> ring",
      "\n  have h2 : Differentiable ℝ (interpolator x y) := by\n    apply Differentiable.interpolator x y\n  have h3 : deriv (interpolated x y f) = deriv f (interpolator x y) • deriv (interpolator x y) := by\n    simp [interpolated]\n    all_goals\n      try { \n        apply deriv.comp\n        all_goals\n          try { \n            try { tauto }\n            try { aesop }\n            try { tauto }\n          }\n      }\n      try { \n        try { tauto }\n        try { aesop }\n        try { tauto }\n      }\n  have h4 : deriv (interpolator x y) = (y - x) := by\n    simp [interpolator]\n    all_goals\n      try { \n        funext i\n        simp [deriv_add, deriv_sub, deriv_mul, deriv_id'', mul_comm]\n        all_goals\n          try { \n            try { tauto }\n            try { aesop }\n            try { tauto }\n          }\n      }\n      try { \n        try { tauto }\n        try { aesop }\n        try { tauto }\n      }\n  rw [h3, h4]\n  funext t\n  simp [deriv_add, deriv_sub, deriv_mul, deriv_id'', mul_comm]\n  all_goals\n    try { \n      try { tauto }\n      try { aesop }\n      try { tauto }\n    }\n    try { \n      try { tauto }\n      try { aesop }\n      try { tauto }\n    }",
