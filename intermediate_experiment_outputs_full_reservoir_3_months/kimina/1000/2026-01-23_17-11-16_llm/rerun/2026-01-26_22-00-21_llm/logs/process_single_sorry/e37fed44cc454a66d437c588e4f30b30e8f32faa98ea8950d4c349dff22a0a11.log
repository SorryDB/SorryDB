open Filter

namespace Cosmology

open Filter
open scoped Topology

namespace Cosmology

/-- The inductive type with three constructors:
- `Spherical (k : ‚ĄĚ)`
- `Flat`
- `Saddle (k : ‚ĄĚ)`
-/
inductive SpatialGeometry : Type where
  | Spherical (k : ‚ĄĚ) (h : k < 0)
  | Flat
  | Saddle (k : ‚ĄĚ) (h : k > 0)

namespace SpatialGeometry

/-- For `s` corresponding to
- `Spherical k`, `S s r = k * sin (r / k)`
- `Flat`, `S s r = r`,
- `Saddle k`, `S s r = k * sinh (r / k)`.
-/
noncomputable def S (s : SpatialGeometry) : ‚ĄĚ ‚Üí ‚ĄĚ :=
  fun r =>
    match s with
    | SpatialGeometry.Spherical k _ => k * Real.sin (r / k)
    | SpatialGeometry.Flat => r
    | SpatialGeometry.Saddle k _ => k * Real.sinh (r / k)

/-- The limit of `S (Saddle k) r` as `k ‚Üí ‚ąě` is equal to `S (Flat) r`.
First show that `k * sinh(r / k) = sinh(r / k) / (1 / k)` pointwise. -/
lemma mul_sinh_as_div (r k : ‚ĄĚ) :
    k * Real.sinh (r / k) = Real.sinh (r / k) / (1 / k) := by field_simp

/-- First, show that limit of `sinh(r * x) / x` is r at the limit x goes to zero.
Then the next theorem will address the rewrite using Filter.Tendsto.comp -/
@[sorryful]
lemma tendsto_sinh_rx_over_x (r : ‚ĄĚ) :
    Tendsto (fun x : ‚ĄĚ => Real.sinh (r * x) / x) (ūĚďĚ[‚Č†] 0) (ūĚďĚ r) := by
  have h1 : Tendsto (fun x : ‚ĄĚ => Real.sinh (r * x) / x) (ūĚďĚ[‚Č†] 0) (ūĚďĚ r) := by
    have h21 : Tendsto (fun x : ‚ĄĚ => Real.sinh (r * x)) (ūĚďĚ 0) (ūĚďĚ 0) := by
      have h22 : Tendsto (fun x : ‚ĄĚ => r * x) (ūĚďĚ 0) (ūĚďĚ 0) := by
        have h23 : Tendsto (fun x : ‚ĄĚ => r * x) (ūĚďĚ 0) (ūĚďĚ 0) := by
          apply Tendsto.const_mul
          simp
        exact h23
      have h24 : Tendsto (Real.sinh ‚ąė (fun x : ‚ĄĚ => r * x)) (ūĚďĚ 0) (ūĚďĚ (Real.sinh 0)) := by
        apply Real.tendsto_sinhasinh
        exact h22
      have h25 : Real.sinh 0 = 0 := Real.sinh_zero
      rw [h25] at h24
      simpa using h24
    have h30 : Tendsto (fun x : ‚ĄĚ => (x : ‚ĄĚ)) (ūĚďĚ 0) (ūĚďĚ (0 : ‚ĄĚ)) := by
      simp
    have h36 : Tendsto (fun x : ‚ĄĚ => Real.sinh (r * x) / x) (ūĚďĚ[‚Č†] 0) (ūĚďĚ r) := by
      have h37 : Tendsto (fun x : ‚ĄĚ => Real.sinh (r * x) / x) (ūĚďĚ[‚Č†] 0) (ūĚďĚ r) := by
        have h38 : Tendsto (fun x : ‚ĄĚ => Real.sinh (r * x) / x) (ūĚďĚ[‚Č†] 0) (ūĚďĚ r) := by
