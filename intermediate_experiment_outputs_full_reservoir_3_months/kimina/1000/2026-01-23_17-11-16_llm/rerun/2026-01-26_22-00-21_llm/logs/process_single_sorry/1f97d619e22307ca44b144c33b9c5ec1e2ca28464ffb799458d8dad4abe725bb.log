      "by\n  constructor\n  · -- Assume SemiconjBy (unop a) (unop y) (unop x), prove SemiconjBy a x y\n    intro h_eq\n    simp [SemiconjBy] at h_eq ⊢\n    have h_inj2 : ∀ {x y : α}, op x = op y → x = y := by\n      intro h_eq\n      have h1 : unop (op x) = x := by\n        simp\n      have h2 : unop (op y) = y := by\n        simp\n      have h3 : unop (op x) = unop (op y) := by\n        rw [h_eq]\n      rw [h1, h2] at h3\n      exact h3\n    have h_mul1 : (unop a) * (unop y) = op (y * a) := by\n      simp [mul_add, add_mul, mul_comm]\n    have h_mul2 : (unop x) * (unop a) = op (a * x) := by\n      simp [mul_add, add_mul, mul_comm]\n    rw [h_mul1, h_mul2] at h_eq\n    have h_eq2 : y * a = a * x := by\n      apply h_inj2\n      exact h_eq\n    linarith [h_eq2]\n  · -- Assume SemiconjBy a x y, prove SemiconjBy (unop a) (unop y) (unop x)\n    intro h_eq\n    simp [SemiconjBy] at h_eq ⊢\n    have h_inj2 : ∀ {x y : α}, op x = op y → x = y := by\n      intro h_eq\n      have h1 : unop (op x) = x := by\n        simp\n      have h2 : unop (op y) = y := by\n        simp\n      have h3 : unop (op x) = unop (op y) := by\n        rw [h_eq]\n      rw [h1, h2] at h3\n      exact h3\n    have h_mul1 : (unop a) * (unop y) = op (y * a) := by\n      simp [mul_add, add_mul, mul_comm]\n    have h_mul2 : (unop x) * (unop a) = op (a * x) := by\n      simp [mul_add, add_mul, mul_comm]\n    rw [h_mul1, h_mul2]\n    have h_eq2 : y * a = a * x := by\n      linarith [h_eq]\n    have h_eq3 : op (y * a) = op (a * x) := by\n      rw [show y * a = a * x by linarith [h_eq]]\n    exact h_eq3",
      "by\n  simp [SemiconjBy, mul_add, add_mul]\n  <;> try { \n    have h1 : unop (unop y) = y := by \n      apply unop_inj.1 \n      simp \n    have h2 : unop (unop a) = a := by \n      apply unop_inj.1 \n      simp \n    have h3 : unop (unop x) = x := by \n      apply unop_inj.1 \n      simp \n    simp [h1, h2, h3] \n    <;> try { \n      constructor \n      · -- Assume op (y * a) = op (a * x), prove a * x = y * a \n        intro h \n        have h4 : y * a = a * x := by \n          have h5 : unop (op (y * a)) = unop (op (a * x)) := by \n            rw [h] \n          have h6 : unop (op (y * a)) = y * a := by \n            simp \n          have h7 : unop (op (a * x)) = a * x := by \n            simp \n          linarith \n        have h5 : a * x = y * a := by \n          linarith [h4, mul_comm y a] \n        assumption \n      · -- Assume a * x = y * a, prove op (y * a) = op (a * x) \n        intro h \n        have h4 : y * a = a * x := by \n          linarith [h, mul_comm y a] \n        have h5 : op (y * a) = op (a * x) := by \n          rw [h4] \n        assumption \n    }\n  }\n  <;> try { tauto }\n  <;> try { aesop }",
      "by\n  simp [SemiconjBy]\n  constructor\n  · -- Assume unop a * unop y = unop x * unop a, prove a * x = y * a\n    intro h\n    have h1 : a * y = x * a := by\n      have h5 : unop (unop a * unop y) = unop (unop x * unop a) := by\n        rw [h]\n      have h6 : unop (unop a * unop y) = unop (unop y) * unop (unop a) := by\n        simp [unop, mul_comm]\n      have h7 : unop (unop x * unop a) = unop (unop a) * unop (unop x) := by\n        simp [unop, mul_comm]\n      rw [h6, h7] at h5\n      have h8 : unop (unop y) = y := by\n        simp [unop]\n      have h9 : unop (unop a) = a := by\n        simp [unop]\n      have h10 : unop (unop x) = x := by\n        simp [unop]\n      rw [h8, h9, h10] at h5\n      linarith\n    linarith\n  · -- Assume a * x = y * a, prove unop a * unop y = unop x * unop a\n    intro h\n    have h1 : unop x * unop a = unop a * unop y := by\n      have h2 : unop (a * x) = unop (y * a) := by\n        rw [h]\n      have h3 : unop (a * x) = unop x * unop a := by\n        simp [unop, mul_comm]\n      have h4 : unop (y * a) = unop a * unop y := by\n        simp [unop, mul_comm]\n      rw [h3, h4] at h2\n      linarith\n    linarith [h1]",
