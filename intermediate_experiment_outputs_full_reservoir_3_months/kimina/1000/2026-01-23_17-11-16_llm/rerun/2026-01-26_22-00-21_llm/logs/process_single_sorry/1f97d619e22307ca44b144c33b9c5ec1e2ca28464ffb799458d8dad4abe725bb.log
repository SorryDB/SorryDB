      "by\n  have h1 : SemiconjBy (unop a) (unop y) (unop x) ↔ (unop a) * (unop x) = (unop y) * (unop a) := by\n    simp [SemiconjBy]\n  have h2 : SemiconjBy a x y ↔ a * x = y * a := by\n    simp [SemiconjBy]\n  rw [h1, h2]\n  have h3 : (unop a) * (unop x) = op (unop (unop x) * unop (unop a)) := by\n    rw [mul]\n  have h4 : (unop y) * (unop a) = op (unop (unop a) * unop (unop y)) := by\n    rw [mul]\n  rw [h3, h4]\n  have h5 : unop (unop x) * unop (unop a) = unop (unop a) * unop (unop y) := by\n    have h_eq : op (unop (unop x) * unop (unop a)) = op (unop (unop a) * unop (unop y)) := by\n      rfl\n    have h_inj : ∀ {x y : αᵐᵒᵖ}, op x = op y → x = y := by\n      intro x y h_eq\n      have h1 : unop (op x) = unop (op y) := by\n        rw [h_eq]\n      simp at h1 ⊢\n      exact h1\n    apply h_inj\n    exact h_eq\n  have h6 : unop (unop x) = x := by\n    simp [unop]\n  have h7 : unop (unop a) = a := by\n    simp [unop]\n  have h8 : unop (unop y) = y := by\n    simp [unop]\n  rw [h6, h7, h8] at h5\n  have h9 : x * a = a * y ↔ a * x = y * a := by\n    constructor\n    · -- Assume x * a = a * y, prove a * x = y * a\n      intro h_eq\n      have h_comm1 : x * a = a * x := by\n        ring\n      have h_comm2 : y * a = a * y := by\n        ring\n      rw [h_comm1] at h_eq\n      rw [h_comm2] at h_eq\n      have h_comm3 : a * y = y * a := by\n        ring\n      rw [h_comm3] at h_eq\n      exact h_eq\n    · -- Assume a * x = y * a, prove x * a = a * y\n      intro h_eq\n      have h_comm1 : a * x = x * a := by\n        ring\n      have h_comm2 : y * a = a * y := by\n        ring\n      rw [h_comm1] at h_eq\n      rw [h_comm2] at h_eq\n      exact h_eq\n  rw [h9] at h5\n  exact h5",
