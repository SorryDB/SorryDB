import Mathlib

/-!
 * A SystemState represents the state of the system at a particular moment in time.
 * It contains information about the current requests, the order constraints between them,
 * the state of the threads, and other relevant information.
 * This is a simplified version of the SystemState used in the example.
-/

namespace SystemState

-- A simple structure for a system state
structure SystemState where
  -- A list of all current requests
  requests : RequestArray
  -- The current set of order constraints between requests
  orderConstraints : OrderConstraints
  -- The current set of removed requests (for cleanup)
  removal : List (RequestId)
  -- The current set of satisfied requests (for cleanup)
  satisfied : List (RequestId)
