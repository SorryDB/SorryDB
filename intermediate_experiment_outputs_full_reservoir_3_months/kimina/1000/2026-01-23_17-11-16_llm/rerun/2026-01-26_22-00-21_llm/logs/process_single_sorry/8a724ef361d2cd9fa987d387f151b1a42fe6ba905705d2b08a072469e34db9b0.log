import Mathlib

namespace Arch
  def orderCondition : Arch → @OrderConstraints Arch → @OrderConstraints Arch → Bool
    | arch, oc1, oc2 =>
      let eq1 := Arch.eqOrderConstraints arch
      let eq2 := Arch.eqOrderConstraints arch
      let eq3 := Arch.eqOrderConstraints arch
      let eq4 := Arch.eqOrderConstraints arch
      let eq5 := Arch.eqOrderConstraints arch
      let eq6 := Arch.eqOrderConstraints arch
      let eq7 := Arch.eqOrderConstraints arch
      let eq8 := Arch.eqOrderConstraints arch
      let eq9 := Arch.eqOrderConstraints arch
      let eq10 := Arch.eqOrderConstraints arch
      eq1 (oc1 ⊢ oc2)

  def eqOrderConstraints : Arch → @OrderConstraints Arch → @OrderConstraints Arch → Bool
    | arch, oc1, oc2 => Arch.eqOrderConstraints arch oc1 oc2

  def acceptConstraints : Arch → @OrderConstraints Arch → @OrderConstraints Arch → @OrderConstraints Arch
    | arch, oc1, oc2 => Arch.acceptOrderConstraints arch (oc1 ∪ oc2)

  def propagateConstraints : Arch → @OrderConstraints Arch → @OrderConstraints Arch → @OrderConstraints Arch
    | arch, oc1, oc2 => Arch.propagateOrderConstraints arch (oc1 ∪ oc2)

end Arch

