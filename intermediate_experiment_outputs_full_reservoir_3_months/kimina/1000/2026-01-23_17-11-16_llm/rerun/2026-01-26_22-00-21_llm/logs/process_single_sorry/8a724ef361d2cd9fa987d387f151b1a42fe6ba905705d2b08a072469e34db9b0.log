      let res := { state with
        requests := requests', orderConstraints := orderConstraints', removedCoherent := List.map (fun r => r.id) (List.filter (fun r => r.thread == thId) state.removed)}
      sorry
      <;> tauto <;> aesop <;> omega <;> norm_num
