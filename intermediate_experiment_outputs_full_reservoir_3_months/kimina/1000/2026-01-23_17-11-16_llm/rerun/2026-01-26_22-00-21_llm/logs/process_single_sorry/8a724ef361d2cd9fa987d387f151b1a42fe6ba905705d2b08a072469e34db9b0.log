      let rmw_pairs_done := state.rmwPairsBlocking.all λ (read, write) => write.id == reqId ∧ read.propagatedTo thId
      arch ∧ unpropagated ∧ blockingReqs.isEmpty ∧ fenceLikes ∧ rmw_pairs_done

