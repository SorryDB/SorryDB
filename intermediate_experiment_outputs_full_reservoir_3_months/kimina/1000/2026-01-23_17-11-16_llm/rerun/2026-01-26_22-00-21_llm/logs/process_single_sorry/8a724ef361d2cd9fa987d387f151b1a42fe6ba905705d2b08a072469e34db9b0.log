namespace Arch

def Arch : ArchType := {
  name : "My Arch",
  isBigEndian : false,
  addressSize : 64,
  nativeEndian : true,
  canRearrange : true,
  canSatisfy : true,
  canPropagate : true
}

end Arch

namespace SystemState

def SystemState := {
  name : "My System State",
  requests : RequestArray,
  orderConstraints : OrderConstraints,
  removed : List (RequestId),
  satisfied : Set (RequestId),
  removedCoherent : Set (RequestId),
  threadTypes : Thread → Arch,
  scopes : @Scopes Arch,
  canSatisfy : Arch → Bool,
  canPropagate : Arch → Bool,
  canRearrange : Arch → Bool
}

end SystemState

namespace Arch

def ArchType : Type :=
  { name : String,
    isBigEndian : Bool,
    addressSize : Nat,
    nativeEndian : Bool,
    canRearrange : Bool,
    canSatisfy : Bool,
    canPropagate : Bool }

end Arch

namespace SystemState

def SystemState := {
  name : "My System State",
  requests : RequestArray,
  orderConstraints : OrderConstraints,
  removed : List (RequestId),
  satisfied : Set (RequestId),
  removedCoherent : Set (RequestId),
  threadTypes : Thread → Arch,
  scopes : @Scopes Arch,
  canSatisfy : Arch → Bool,
  canPropagate : Arch → Bool,
  canRearrange : Arch → Bool
}

end SystemState

