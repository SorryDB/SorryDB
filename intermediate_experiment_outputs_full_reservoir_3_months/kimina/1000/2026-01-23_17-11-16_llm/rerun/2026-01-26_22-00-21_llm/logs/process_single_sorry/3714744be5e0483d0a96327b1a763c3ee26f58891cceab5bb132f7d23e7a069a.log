@[simp, grind =]
theorem foldl_cons {f : β → α → β} :
    foldl f b (a :: l) = foldl f (f b a) l := by
  simp only [foldl, cons.injEq, and_true]
  induction l generalizing a with
  | nil => rfl
  | cons _ _ ih => simp only [foldl, ih]

theorem foldl_singleton {f : β → α → β} : foldl f b [a] = f b a := by
  simp

@[simp]
theorem foldl_iff_nil {f : β → α → β} (c : β) : foldl f b l = [c] ↔ c = b ∧ l = [] := by
  constructor <;> cases l <;> simp_all

