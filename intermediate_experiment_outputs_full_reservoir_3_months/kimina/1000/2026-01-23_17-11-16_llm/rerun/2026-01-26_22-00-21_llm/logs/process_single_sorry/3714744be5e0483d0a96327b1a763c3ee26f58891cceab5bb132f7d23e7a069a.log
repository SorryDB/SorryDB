  split <;> simp [h]

theorem getElem_foldl_zero {f : β → α → β} : (foldl f b l)[0] = foldl f b l := by
  simp

theorem getElem?_foldl_zero {f : β → α → β} : (foldl f b l)[0]? = some (foldl f b l) := by
  simp

@[simp]
theorem head_foldl {f : β → α → β} (h : foldl f b l ≠ []) :
    (foldl f b l).head h = foldl f b l := by
  simp [head]

theorem getLast_foldl {f : β → α → β} (h : foldl f b l ≠ []) :
    (foldl f b l).getLast h = b := by
  induction l
  case nil => simp
  case cons head tail ih => simp [getLast_cons, foldl_ne_nil, ih]

