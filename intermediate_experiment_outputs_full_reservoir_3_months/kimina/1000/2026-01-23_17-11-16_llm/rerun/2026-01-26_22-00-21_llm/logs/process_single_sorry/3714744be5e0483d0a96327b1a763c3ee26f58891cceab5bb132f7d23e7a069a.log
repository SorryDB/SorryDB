_mem_partialSums_map_length (L : List (List α)) :\n    L.flatten.length ∈ (L.map length).partialSums := by\n  induction L with\n  | nil => simp\n  | cons l L ih =>\n    simp [flatten_cons, partialSums_cons]\n    right\n    simpa using ih\n\ntheorem getElem_flatten_aux₁ (L : List (List α)) (i : Nat) (h : i < L.flatten.length) :\n    (L.map length).partialSums.findIdx (fun x => decide (x > i)) - 1 < L.length := by\n  have := findIdx_lt_length_of_exists (xs := (L.map length).partialSums) (p := fun x => decide (x > i))\n  specialize this ⟨L.flatten.length,\n    length_flatten_mem_partialSums_map_length L, by grind⟩\n  simp at this\n  simp\n  have : 0 < findIdx (fun x => decide (i < x)) (map length L).partialSums := by\n    by_contra w\n    simp at w\n  omega\n\ntheorem getElem_flatten_aux₂ (L : List (List α)) (i : Nat) (h : i < L.flatten.length) :\n    let j := (L.map length).partialSums.findIdx (· > i) - 1;\n    have hj : j < L.length := getElem_flatten_aux₁ L i h;\n    let k := i - (take j L).flatten.length;\n    k < L[j].length := by\n```\n\nNow we need to prove `k < L[j].length`. Let's expand the definitions and use reasoning.\n\n```tactics\n  have h1 : (L.map length).partialSums[j] > i := by\n    have h2 : findIdx (fun x => decide (x > i)) (map length L).partialSums ≤ (L.map length).partialSums.length := by\n      apply findIdx_le\n    have h3 : (L.map length).partialSums[j] > i := by\n      have h4 : (L.map length).partialSums[findIdx (fun x => decide (x > i)) (map length L).partialSums - 1] > i := by\n        have h5 : findIdx (fun x => decide (x > i)) (map length L).partialSums > 0 := by\n          by_contra h6\n          push_neg at h6\n          have h7 : findIdx (fun x => decide (x > i)) (map length L).partialSums = 0 := by\n            omega\n          rw [h7] at h2\n          simp at h2\n          all_goals\n            try { tauto }\n          all_goals\n            try { nlinarith }\n        have h8 : (L.map length).partialSums[findIdx (fun x => decide (x