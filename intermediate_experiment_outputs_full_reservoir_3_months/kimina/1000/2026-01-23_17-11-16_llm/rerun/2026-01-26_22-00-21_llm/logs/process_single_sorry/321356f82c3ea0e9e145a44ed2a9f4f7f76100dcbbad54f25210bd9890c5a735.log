      "\n  let vals' := growArray rarr.val (req.id.toNat + 1)\n  let i := req.id.toNat.toUSize\n  let inserted := if h : i.toNat < vals'.size\n    then vals'.uset i (some req) h\n    else if h: (Nat.beq i.toNat vals'.size) then\n      let hless : i.toNat < vals'.size + 1 := by\n        {apply Nat.lt_of_succ_le\n         apply Nat.le_of_eq\n         rw [Nat.succ_eq_add_one]\n         rw [Nat.beq_eq] at h\n         rw [h]\n         }\n      let idfin := Fin.mk i.toNat hless\n      vals'.insertIdx idfin (some req)\n    else unreachable!\n  have h1 : valConsistent inserted = true := by\n    have h2 : valConsistent inserted := by\n      have h3 : ∀ j, (inserted[j] : Option (Request)) = if j = i then some req else if j < rarr.val.length then rarr.val[j] else none := by\n        intro j\n        simp [inserted, vals', growArray]\n        <;> try { \n          cases j with\n          | zero => simp_all [i]\n          | succ j =>\n            simp_all [i]\n            <;> try { \n              cases j with\n              | zero => simp_all [i]\n              | succ j => \n                simp_all [i]\n            }\n        }\n        <;> try { omega }\n      have h4 : ∀ j, (inserted[j] : Option (Request)) = if j = i then some req else if j < rarr.val.length then rarr.val[j] else none := h3\n      let valOpIds := inserted.map opReqId?\n      let valConsistent := λ (i : Nat) (opVal : Option (Request)) => match opVal with\n        | none => true\n        | some val => val == i\n      let consistentVals := valOpIds.mapIdx valConsistent\n      have h6 : consistentVals.foldl (. ∧ .) true = true := by\n        have h7 : ∀ j, consistentVals[j] = true := by\n          intro j\n          have h8 : j < consistentVals.length := by\n            have h9 : consistentVals.length = inserted.length := by\n              simp [valOpIds]\n            rw [h9]\n            have h10 : inserted.length = rarr.val.length + (req.id.toNat + 1 - rarr.val.length) := by\n              simp [vals', growArr