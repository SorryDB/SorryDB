`grow 4 = fun x => (fun y => x) (fun y => y) x = x` (identity function)
`grow 5 = fun x => (fun y => x) (fun y => x) x = x` (identity function)
`grow 6 = fun x => (fun y => x) (fun y => x) x = x` (identity function)

