noncomputable def marcinkiewiczZygmundConst (p : ‚ĄĚ‚Č•0) : ‚ĄĚ :=
  2 ^ (p / 2 : ‚ĄĚ) * marcinkiewiczZygmundSymmConst p

/-- The **Marcinkiewicz-Zygmund inequality** for random variables with zero mean.

