import Mathlib

/-!
A *sagebird* or *oracle bird* `θ` is a bird with the following property:
for any other bird `x`, if the name of `x` is called out to `θ`, it responds with
the name of a bird that `x` is fond of.
-/

-- the definition of a sagebird
noncomputable abbrev θ : Bird :=
  sorry

-- the defining property of a sagebird
noncomputable abbrev sage_bird_property (θ : Bird) : Prop :=
  ∀ x, x ◁ (θ ◁ x) = θ ◁ x

-- the existence of a sagebird
theorem sage_bird_exists : ∃ θ, ∀ x, x ◁ (θ ◁ x) = θ ◁ x := by
  use I
  intro x
```

