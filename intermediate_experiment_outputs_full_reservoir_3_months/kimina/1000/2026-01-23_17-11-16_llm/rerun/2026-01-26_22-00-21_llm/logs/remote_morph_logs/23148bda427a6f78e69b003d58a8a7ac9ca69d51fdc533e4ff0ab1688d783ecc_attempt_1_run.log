open Filter
open Nat.Prime

/-- The prime counting function `π(x)` for real `x`. -/
noncomputable def primeCountingReal (x : ℝ) : ℕ :=
  if (x ≤ 0) then 0 else primeCounting ⌊x⌋₊

/-- The set of natural numbers whose prime factors are all less than or equal to `x`. -/
def S₁ (x : ℝ) : Set ℕ :=
 { n | ∀ p, Nat.Prime p → p ∣ n → p ≤ x }

theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  -- two parts:
  -- (1) log x ≤ π x + 1
  -- (2) This implies that it is not bounded
  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by sorry
      _ ≤ (∑' m : (S₁ x), (m : ℝ)⁻¹) := by sorry
      _ ≤ (∏ p ∈ ⌊x⌋.natAbs.primesBelow, (∑' k : ℕ, (p ^ k : ℝ)⁻¹)) := by sorry

  -- (2) This implies that it is not bounded
  have H_not_bounded : ¬ BoundedOn π (Set.univ : Set ℕ) := by
    intro h
    -- use the fact that π(x) is unbounded
    have h2 : ∀ x : ℝ, x ≥ (0 : ℝ) → π x ≤ (π 1 : ℕ) := by
      intro x hx
      apply h
      simp
    -- This implies that π(x) is bounded for x ≥ 0
    have h3 : BoundedOn π (Set.Ici (0 : ℝ)) := by
      apply BoundedOn.mono h2
      intro x hx
      simp at hx ⊢
      exact hx
    -- But we know that π(x) is not bounded
    -- This is a contradiction
    exfalso
    -- We know that π(x) is unbounded
    -- So there exists some x such that π(x) > π(1)
    -- Let's pick x = 2 * π(1) + 1
    let x := 2 * π 1 + 1
    have hxge0 : x ≥ (0 : ℝ) := by
      simp [x]
      all_goals linarith [show π 1 ≥ 0 by apply Nat.zero_le]
    -- π(x) > π(1)
    have h4 : π x > π 1 := by
      -- We know that π(x) is unbounded
      -- So for any N, there exists x such that π(x) > N
      -- Let's pick N = π(1)
      have h5 : ∃ x : ℝ, π x > π 1 := by
        -- Since π is unbounded, there exists some x such that π(x) > π(1)
        -- We can use the fact that π(x) tends to infinity
        -- So for any N, there exists x such that π(x) > N
        -- Let's pick N = π(1)
        -- Then there exists x such that π(x) > π(1)
        sorry
      rcases h5 with ⟨x, hx⟩
      exact ⟨x, hx⟩
    -- But h3 says that π(x) ≤ π(1) for all x ≥ 0
    have h5 : π x ≤ π 1 := h3 x hxge0
    -- This contradicts h4
    linarith [h4, h5]

  -- Now we can prove that π tends to infinity
  apply tendsto_atTop_atTop_of_unbounded
  exact H_not_bounded

