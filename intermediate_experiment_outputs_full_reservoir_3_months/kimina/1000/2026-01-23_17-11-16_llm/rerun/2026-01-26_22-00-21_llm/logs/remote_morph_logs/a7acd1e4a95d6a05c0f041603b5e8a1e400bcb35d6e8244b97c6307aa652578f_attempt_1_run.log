  fun_prop

/--For any `(n : ℕ)` the map `wignerMatrixMap` is `AEMeasurable` from `WignerSpace n` to
  `Matrix (Fin n) (Fin n) ℝ`-/
@[fun_prop]
lemma wignerMatrixMapScaledAEMeasurable (n : ℕ) : AEMeasurable (wignerMatrixMapScaled n) := by
  fun_prop


