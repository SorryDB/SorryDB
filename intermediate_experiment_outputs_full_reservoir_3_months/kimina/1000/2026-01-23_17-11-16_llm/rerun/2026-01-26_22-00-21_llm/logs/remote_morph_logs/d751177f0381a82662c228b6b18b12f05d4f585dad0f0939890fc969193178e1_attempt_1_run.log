import Mathlib

open Filter MeasureTheory ProbabilityTheory

noncomputable
def stoppedProcess (f : ℕ → Ω → WithTop ι) (t : ℕ) ω :=
  ⨅ i ∈ {i | i ≥ t}, f i ω

lemma stoppedProcess_eq_of_le {f : ℕ → Ω → WithTop ι} (f_mono : ∀ i j, i ≤ j → f i ≤ f j)
    (t : ℕ) ω : stoppedProcess f t ω = f t ω := by
  simp only [stoppedProcess, Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and]
  exact iInter_eq_of_eventually_le f_mono t

lemma stoppedProcess_eq_of_ge {f : ℕ → Ω → WithTop ι} (f_mono : ∀ i j, i ≤ j → f i ≤ f j)
    (t : ℕ) ω : stoppedProcess f t ω = ⊤ := by
  simp only [stoppedProcess, Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and]
  simp only [Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and]
  exact iInter_eq_top_of_subset_of_mono (fun i _ ↦ le_rfl) f_mono

lemma stoppedProcess_mono {f : ℕ → Ω → WithTop ι} (f_mono : ∀ i j, i ≤ j → f i ≤ f j)
    (t₁ : ℕ) t₂ : t₁ ≤ t₂ : stoppedProcess f t₁ ω ≤ stoppedProcess f t₂ ω := by
  simp only [stoppedProcess, Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and]
  exact iInter_mono_of_mono f_mono (by omega)

lemma stoppedProcess_tendsto_top {f : ℕ → Ω → WithTop ι} (f_mono : ∀ i j, i ≤ j → f i ≤ f j)
    (t : ℕ) : Tendsto (fun n => stoppedProcess f n ω) atTop (𝓝[<] ⊤) := by
  simp only [Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and]
  refine tendsto_atTop_iSup ?_
  intro n m hnm
  simp only [Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and]
  exact iInter_subset_iInter_of_subset_of_mono (fun i hi ↦ hnm.trans hi) f_mono

lemma stoppedProcess_indicator_comm' {f : ℕ → Ω → WithTop ι} {p : (ℕ → Ω → E) → Prop} (t : ℕ) ω :
    (stoppedProcess f t ω).indicator (p (f t)) = (p (f t)).indicator (stoppedProcess f t ω) := by
  simp only [Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and, iff_self]

lemma stoppedProcess_indicator_comm {f : ℕ → Ω → WithTop ι} {p : (ℕ → Ω → E) → Prop} (t : ℕ) :
    ∀ ω, (stoppedProcess f t ω).indicator (p (f t)) = (p (f t)).indicator (stoppedProcess f t ω) := by
  intro ω
  exact stoppedProcess_indicator_comm' t ω

lemma stoppedProcess_stoppedProcess {f : ℕ → Ω → WithTop ι} {t₁ t₂ : ℕ} (f_mono : ∀ i j, i ≤ j → f i ≤ f j) (t₁ : ℕ) t₂ : t₁ ≤ t₂ :
    stoppedProcess f t₁ (stoppedProcess f t₂ ω) = ⊤ := by
  simp only [stoppedProcess, Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and]
  exact iInter_eq_top_of_subset_of_mono (fun i hi ↦ (le_trans hi (le_rfl)).trans (le_rfl)) f_mono

lemma stoppedProcess_isStoppingTime {f : ℕ → Ω → WithTop ι} (f_mono : ∀ i j, i ≤ j → f i ≤ f j) (t : ℕ) :
    IsStoppingTime 𝓕 (fun ω ↦ stoppedProcess f t ω) := by
  have h1 := f_mono t (max t (f_mono t (max t (f_mono t (max t (f_mono t (max t (f_mono t (max t 0) 0) 0) 0) 0) 0) 0) 0) 0)
  simp only [Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and, iff_true]
  refine ⟨fun i hi ↦ ?_, fun i hi ↦ ?_⟩
  · exact fun _ ↦ h1
  · exact fun _ ↦ h1

lemma stoppedProcess_isStoppingTime' {f : ℕ → Ω → WithTop ι} (f_mono : ∀ i j, i ≤ j → f i ≤ f j) (t : ℕ) :
    IsStoppingTime 𝓕 (fun ω ↦ stoppedProcess f t ω) := by
  have h1 := f_mono t (max t (f_mono t (max t (f_mono t (max t (f_mono t (max t (f_mono t (max t 0) 0) 0) 0) 0) 0) 0) 0) 0)
  simp only [Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and, iff_true]
  refine ⟨fun i hi ↦ ?_, fun i hi ↦ ?_⟩
  · exact fun _ ↦ h1
  · exact fun _ ↦ h1

lemma stoppedProcess_isStoppingTime_of_le_right {f : ℕ → Ω → WithTop ι} {t₁ t₂ : ℕ} (f_mono : ∀ i j, i ≤ j → f i ≤ f j) (h : t₁ ≤ t₂) :
    IsStoppingTime 𝓕 (fun ω ↦ stoppedProcess f t₁ ω) := by
  have h1 := f_mono t₁ (max t₁ (f_mono t₁ (max t₁ (f_mono t₁ (max t₁ (f_mono t₁ (max t₁ (f_mono t₁ (max t₁ 0) 0) 0) 0) 0) 0) 0) 0) 0)
  simp only [Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le, true_and, iff_true]
  refine ⟨fun i hi ↦ ?_, fun i hi ↦ ?_⟩
  · exact fun _ ↦ h1
  · exact fun _ ↦ h1

lemma isLocalizingSequence {f : ℕ → Ω → WithTop ι} {P : Measure Ω} (f_mono : ∀ i j, i ≤ j → f i ≤ f j)
    (hfin : ∃ (i : ℕ), P (f i) ≠ ⊤) : IsLocalizingSequence 𝓕 (fun i ω ↦ stoppedProcess f i ω) P := by
  set t : ℕ → Set Ω := fun i ↦ {ω | ⊥ < f i ω}
  have hst (i : ℕ) : (fun i ω ↦ stoppedProcess f i ω) i =ᵐ[P] t i := by
    filter_upwards [f_mono] with ω hω
    suffices ω ∈ (fun i ω ↦ stoppedProcess f i ω) i ↔ ω ∈ t i by
      exact propext this
    simp only [t, Set.mem_iInter, Set.mem_setOf_eq, ge_iff_le]
    refine ⟨fun (h : ∀ j ≥ i, f j ω ≤ ⊤) ↦ ?_, fun h ↦ h i le_rfl⟩
    change f i ω ≤ ⊤
    specialize hω i le_rfl
    simp only [le_Prop_eq] at hω
    exact hω h
  rw [measure_congr <| EventuallyEq.countable_iInter hst, Antitone.measure_iInter]
  · exact iInf_congr <| fun i ↦ measure_congr <| (hst i).symm
  · intros i j hij
    simp only [t]
    rw [(_ : {ω | ⊥ < f i ω} = {ω | ⊥ < f i ω})]
    · exact Set.inter_subset_left
    · ext ω
      simp only [Set.mem_iInter, Set.mem_setOf_eq, Set.mem_inter_iff, and_imp]
      exact fun h i' hi'j ↦ h i' (le_trans hi'j (le_rfl))
  · exact fun i ↦ NullMeasurableSet.iInter <| fun j ↦ NullMeasurableSet.iInter <| fun _ ↦ IsNullMeasurableSet (f j ω) P
  · obtain ⟨i, hi⟩ := hfin
    refine ⟨i, (lt_of_le_of_lt ?_ <| lt_top_iff_ne_top.2 hi).ne⟩
    rw [measure_congr (hst i)]

lemma isLocalizingSequence_of_isPreLocalizingSequence {f : ℕ → Ω → WithTop ι} (h : IsPreLocalizingSequence 𝓕 f P)
    : IsLocalizingSequence 𝓕 (fun i ω ↦ stoppedProcess f i ω) P := by
  exact isLocalizingSequence f (h.isPreLocalizingSequence.1) (h.isPreLocalizingSequence.2.1) (h.isPreLocalizingSequence.2.2)

lemma measure_iInter_of_ae_antitone {ι : Type*}
    [Countable ι] [Preorder ι] [IsDirected ι fun (x1 x2 : ι) ↦ x1 ≤ x2]
    {s : ι → Set Ω} (hs : ∀ᵐ ω ∂P, Antitone (s · ω))
    (hsm : ∀ (i : ι), MeasureTheory.NullMeasurableSet (s i) P) (hfin : ∃ (i : ι), P (s i) ≠ ⊤) :
    P (⋂ (i : ι), s i) = ⨅ (i : ι), P (s i) := by
  set t : ι → Set Ω := fun i ↦ ⋂ j ≤ i, s j with ht
  have hst (i : ι) : s i =ᵐ[P] t i := by
    filter_upwards [hs] with ω hω
    suffices ω ∈ s i ↔ ω ∈ t i by
      exact propext this
    simp only [ht, Set.mem_iInter]
    refine ⟨fun (h : s i ω) j hj ↦ ?_, fun h ↦ h i le_rfl⟩
    change s j ω
    specialize hω hj
    simp only [le_Prop_eq] at hω
    exact hω h
  rw [measure_congr <| EventuallyEq.countable_iInter hst, Antitone.measure_iInter]
  · exact iInf_congr <| fun i ↦ measure_congr <| (hst i).symm
  · intros i j hij
    simp only [ht]
    rw [(_ : ⋂ k ≤ j, s k = (⋂ k ≤ i, s k) ∩ (⋂ k ∈ {k | k ≤ j ∧ ¬ k ≤ i}, s k))]
    · exact Set.inter_subset_left
    · ext ω
      simp only [Set.mem_iInter, Set.mem_setOf_eq, Set.mem_inter_iff, and_imp]
      grind
  · exact fun _ ↦ NullMeasurableSet.iInter <| fun j ↦ NullMeasurableSet.iInter <| fun _ ↦ hsm j
  · obtain ⟨i, hi⟩ := hfin
    refine ⟨i, (lt_of_le_of_lt ?_ <| lt_top_iff_ne_top.2 hi).ne⟩
    rw [measure_congr (hst i)]

lemma isLocalizingSequence_of_isPreLocalizingSequence
    {τ : ℕ → Ω → WithTop ι} (h : IsPreLocalizingSequence 𝓕 τ P) :
    IsLocalizingSequence 𝓕 (fun i ω ↦ stoppedProcess τ i ω) P := by
  apply isLocalizingSequence_of_isPreLocalizingSequence h

