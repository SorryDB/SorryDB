import Mathlib

/- The norm of the constant function 1 is 1. -/
lemma RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

/- The set of values attained by a simple function is finite. -/
lemma SimpleFunc.finite_support {f : α → β} [AddCommMonoid β] [Fintype α] (s : SimpleFunc α β) : Finite {f x | x ∈ s.support} := by
  rw [Set.finite_def]
  use s.support
  simp

/- The set of values attained by a simple function is finite. -/
lemma SimpleFunc.finite_support' {f : α → β} [AddCommMonoid β] [Fintype α] (s : SimpleFunc α β) : Finite {f x | x ∈ s.support} := by
  rw [Set.finite_def]
  use s.support
  simp

/- The set of values attained by a simple function is finite. -/
lemma SimpleFunc.finite_support'' {f : α → β} [AddCommMonoid β] [Fintype α] (s : SimpleFunc α β) : Finite {f x | x ∈ s.support} := by
  rw [Set.finite_def]
  use s.support
  simp

/- The set of values attained by a simple function is finite. -/
lemma SimpleFunc.finite_support''' {f : α → β} [AddCommMonoid β] [Fintype α] (s : SimpleFunc α β) : Finite {f x | x ∈ s.support} := by
  rw [Set.finite_def]
  use s.support
  simp

/- An integral over a set that is the complement of the support of a simple function is zero. -/
lemma integral_compl_support {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) {μ : Measure α} (hμ : IsLocallyFiniteMeasure μ) {G : Set α} (hG : G = Set.compl (s.support) ) : ∫ (x : α) in G, f x = 0 := by
  rw [hG]
  rw [MeasureTheory.integral_compl_support]
  simp

/- An integral over a set that is the complement of the support of a simple function is zero. -/
lemma integral_compl_support' {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) {μ : Measure α} (hμ : IsLocallyFiniteMeasure μ) {G : Set α} (hG : G = Set.compl (s.support) ) : ∫ (x : α) in G, f x = 0 := by
  rw [hG]
  rw [MeasureTheory.integral_compl_support]
  simp

/- An integral over a set that is the complement of the support of a simple function is zero. -/
lemma integral_compl_support'' {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) {μ : Measure α} (hμ : IsLocallyFiniteMeasure μ) {G : Set α} (hG : G = Set.compl (s.support) ) : ∫ (x : α) in G, f x = 0 := by
  rw [hG]
  rw [MeasureTheory.integral_compl_support]
  simp

/- An integral over a set that is the complement of the support of a simple function is zero. -/
lemma integral_compl_support''' {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) {μ : Measure α} (hμ : IsLocallyFiniteMeasure μ) {G : Set α} (hG : G = Set.compl (s.support) ) : ∫ (x : α) in G, f x = 0 := by
  rw [hG]
  rw [MeasureTheory.integral_compl_support]
  simp

/- The integral of the sum of two simple functions is the sum of their integrals. -/
lemma integral_add {f g : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s₁ s₂ : SimpleFunc α β) : ∫ (x : α) in Set.univ, (s₁ + s₂) x = ∫ (x : α) in Set.univ, s₁ x + ∫ (x : α) in Set.univ, s₂ x := by
  simp [integral_add]

/- The integral of a constant times a simple function is the constant times the integral of the simple function. -/
lemma integral_const_mul {c : β} {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) : ∫ (x : α) in Set.univ, c • s x = c • ∫ (x : α) in Set.univ, s x := by
  simp [integral_const_mul]

/- The integral of the product of a constant and a simple function is the product of the constant and the integral of the simple function. -/
lemma integral_smul {c : β} {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) : ∫ (x : α) in Set.univ, c • s x = c • ∫ (x : α) in Set.univ, s x := by
  simp [integral_const_mul]

/- The integral of a simple function over a set that is a subset of its support is the integral of the function over that set. -/
lemma integral_subset_support {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) {G : Set α} (hG : G ⊆ s.support) : ∫ (x : α) in G, f x = ∫ (x : α) in G, s x := by
  have h1 : ∀ x : α, x ∈ G → f x = s x := by
    intro x hx
    have hx' : x ∈ s.support := hG hx
    simp at hx' ⊢
    all_goals tauto
  simp_rw [h1]
  all_goals simp

/- The integral of a simple function over a set that is disjoint from its support is zero. -/
lemma integral_disj_support {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) {G : Set α} (hG : Disjoint G (s.support)) : ∫ (x : α) in G, f x = 0 := by
  have h1 : ∀ x : α, x ∈ G → f x = 0 := by
    intro x hx
    have hx' : Disjoint G (s.support) := hG
    have hx'' : x ∉ s.support := by
      apply hx' hx
    simp at hx'' ⊢
    all_goals tauto
  simp_rw [h1]
  all_goals simp

/- The integral of a simple function is the sum of its values on the support, weighted by the measure of each point. -/
lemma integral_simple {f : α → β} [AddCommMonoid β] [Fintype α] [MeasureTheory.Measure α] [MeasureTheory.IsLocallyFiniteMeasure α] (s : SimpleFunc α β) : ∫ (x : α) in Set.univ, s x = ∑ x in s.support, s x x := by
  simp [integral_simple]

