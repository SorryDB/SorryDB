open Equiv
namespace Matrix

variable {n : ℕ}

theorem permanent_conjecture (M : Matrix (Fin n) (Fin n) ℝ) :
    M ∈ doublyStochastic ℝ (Fin n) → permanent M ≥ (n.factorial)/(n ^ n) := sorry
