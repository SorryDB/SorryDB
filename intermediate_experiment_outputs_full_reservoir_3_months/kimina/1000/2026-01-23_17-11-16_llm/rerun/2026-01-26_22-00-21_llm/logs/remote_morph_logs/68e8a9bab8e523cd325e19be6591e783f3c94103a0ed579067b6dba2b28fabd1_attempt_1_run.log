    have h1 := h_qX_bounds i hi
    have h2 := h_qY_bounds i hi
    have h3 := h_qZ_bounds i hi
    simp at *
    <;> try { 
      have h4 : (q.X[i]!) ^ 2 ≤ 2 ^ 104 := by 
