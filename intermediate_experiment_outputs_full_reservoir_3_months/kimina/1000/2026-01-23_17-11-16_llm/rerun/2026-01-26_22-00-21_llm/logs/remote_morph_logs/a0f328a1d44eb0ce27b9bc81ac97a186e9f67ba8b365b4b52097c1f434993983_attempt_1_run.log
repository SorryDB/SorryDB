import Mathlib
import Lean4

/-! This lemma is essentially a tautology, but we need to explicitly show the equivalence.
The proof is straightforward by simplifying the definitions. -/
lemma all_cEdge_rev_spec {X} {tab : Tableau .nil X} (s t : PathIn tab) :
    s ∈ all_cEdge_rev t ↔ ((s ⋖_ t) ∨ s ♥ t) := by
  simp [all_cEdge_rev, all_cEdge_spec]

/-! This lemma is essentially a tautology, but we need to explicitly show the equivalence.
The proof is straightforward by simplifying the definitions. -/
lemma all_cEdge_spec {X} {tab : Tableau .nil X} (s t : PathIn tab) :
    t ∈ all_cEdge s ↔ ((s ⋖_ t) ∨ s ♥ t) := by
  simp [all_cEdge, all_cEdge_rev]

/-- Loaded nodes "below" the given one, also allowing ♥ steps. -/
def loadedBelow : PathIn tab → List (PathIn tab) :=
  (fun s ↦ ((List.range (s.length + 1)).map (fun n ↦ s.natStep n)).filter (fun p => p.isLoaded))

/-- Loaded nodes "above" the given one, also allowing *backwards* ♥ steps. -/
def loadedAbove : PathIn tab → List (PathIn tab) :=
  (fun s ↦ ((List.range (s.length + 1)).map (fun n ↦ s.natStep n)).filter (fun p => p.isLoaded))

/-- List of all other nodes in the same cluster, essentially a constructive version of `clusterOf`.
Computed as the intersection of `loadedAbove` and `loadedBelow`. -/
def clusterListOf (p : PathIn tab) : List (PathIn tab) := loadedBelow p ∩ loadedAbove p

lemma clusterListOf_spec (p : PathIn tab) :
    q ∈ clusterListOf p  ↔  p ≡ᶜ q := by
  simp [clusterListOf, loadedBelow, loadedAbove, all_cEdge, all_cEdge_rev]

