import Mathlib

/-! A simple idea for a data type representing a path in a tree. -/
inductive PathIn (α : Type) [DecidableEq α] (X : List α) : List α → Type
| nil => List α
| cons x xs => α × List α
open PathIn

/-! A simple idea for a data type representing a tree. -/
inductive Tableau (H : List Formula) (X : List Formula) : Type
| lrep H' => -- repeat a hypothesis
  H' : List Formula
  rep : H' ∈ H
  next : List (Tableau H' X)
| loc nrep nbas lt next => -- local rule application
  lt : LocalTableau X
  next : ∀ Y ∈ endNodesOf lt, Tableau ((X ++ Y).map Sequent.flip) Y
| pdl r nrep next => -- PDL rule application
  r : PdlRule X Y
  next : Tableau ((X ++ Y).map Sequent.flip) Y

