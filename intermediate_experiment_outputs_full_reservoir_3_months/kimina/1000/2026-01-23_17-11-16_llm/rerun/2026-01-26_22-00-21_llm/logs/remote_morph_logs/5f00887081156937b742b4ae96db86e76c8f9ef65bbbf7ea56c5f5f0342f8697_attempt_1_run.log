  ¬∑ intro h f hf
    unfold MemLp MemLorentz at *
    rw [‚Üź eLorentzNorm_eq_eLpNorm hf.1] at *
    have := h f hf
    rwa [‚Üź eLorentzNorm_eq_eLpNorm this.1]

