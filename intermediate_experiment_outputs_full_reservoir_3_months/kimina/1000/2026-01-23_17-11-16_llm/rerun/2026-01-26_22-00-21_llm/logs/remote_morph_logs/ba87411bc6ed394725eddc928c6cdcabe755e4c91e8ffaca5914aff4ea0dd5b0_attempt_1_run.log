    contradiction
  use u * R % L
  constructor
  · -- Show that as_montgomery u = ok m
    simp [as_montgomery]
  constructor
  · -- Show that m ≡ (u * R) [MOD L]
    simp [Nat.ModEq]
    <;> omega
  · -- Show that m ≠ 0
    omega
