lemma coprime_pow_left {a b : ℕ} :
    ∀ n, Nat.Coprime a b → Nat.Coprime (a ^ n) b
  | 0, _ => by simp
  | n + 1, h => by
    simp [pow_succ]
    exact Nat.Coprime.mul_left (coprime_pow_left n h) h

theorem coprimeRL : Nat.Coprime R L:= by
  unfold R L Nat.Coprime
  simp

theorem cancelRR {a b : ℕ}
    (h : a * R ^ 2 ≡ b * R ^ 2 [MOD L])
