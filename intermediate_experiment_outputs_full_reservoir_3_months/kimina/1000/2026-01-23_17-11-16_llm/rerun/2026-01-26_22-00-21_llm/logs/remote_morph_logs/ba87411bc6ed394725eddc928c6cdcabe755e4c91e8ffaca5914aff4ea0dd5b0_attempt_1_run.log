lemma coprime_pow_left {a b : ℕ} :
    ∀ n, Nat.Coprime a b → Nat.Coprime (a ^ n) b
  | 0, _ => by simp
  | n + 1, h => by
    simp [pow_succ]
    exact Nat.Coprime.mul_left (coprime_pow_left n h) h

