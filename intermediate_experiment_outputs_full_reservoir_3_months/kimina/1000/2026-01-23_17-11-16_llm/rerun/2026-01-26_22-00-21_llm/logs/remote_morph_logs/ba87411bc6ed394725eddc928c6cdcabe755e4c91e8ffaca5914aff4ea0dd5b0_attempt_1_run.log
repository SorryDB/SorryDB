  have hcoprime : Nat.Coprime R L := by
    unfold R L Nat.Coprime
    simp
  have h1 := Nat.Coprime.symm hcoprime

  -- use the standard lemma for cancelling a factor modulo L
  exact Nat.ModEq.cancel_right_of_coprime h1 h

