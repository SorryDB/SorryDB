      classical
      rcases x with ⟨ux, px⟩
      rcases y with ⟨uy, py⟩
      rcases hxy with ⟨s, h1, h2⟩
      use s.symm * s
      constructor
      · -- Show that (s.symm * s) applied to uy gives ux
        have h3 : (s.symm * s) uy = ux := by
