import Mathlib


open SimpleGraph


/-- A walk in a graph is a sequence of vertices connected by edges.
This is represented as a list of vertices, where each consecutive pair is connected by an edge.
A `nil` walk is a trivial walk of length 0.
A `cons h p` walk starts with a vertex `u` (implicit from context), takes an edge `h` to `v`, and then continues with a walk `p` from `v` to `w`. The full walk is from `u` to `w`.
A `loop p` walk starts with a vertex `u` (implicit from context), takes a walk `p` from `u` to `u`, and then takes a loop edge (implicit from context). The full walk is from `u` to `u`. -/
inductive LoopWalk (G : SimpleGraph V) : V → V → List (V × V) → Prop :=
  | nil =>
    sorry
  | cons h p =>
    sorry
  | loop p =>
    sorry

/-- The concatenation of two walks `p` and `q` is a new walk formed by performing `p` and then `q`.
For `cons h p` and `q`, the new walk is `cons h (p ++ q)`.
For `loop p` and `q`, the new walk is `loop (p ++ q)`. -/
def append {p q : G.LoopWalk u v} : G.LoopWalk u v := sorry

/-- The reversed version of `SimpleGraph.LoopWalk.cons`, concatenating an edge to
the end of a walk. -/
def concat {u v w : V} (p : G.LoopWalk u v) (h : G.Adj v w) : G.LoopWalk u w :=
  p.append (cons h nil)

theorem concat_eq_append {u v w : V} (p : G.LoopWalk u v) (h : G.Adj v w) :
    p.concat h = p.append (cons h nil) := rfl


/-- The concatenation of the reverse of the first walk with the second walk. -/
protected def reverseAux {u v w : V} : G.LoopWalk u v → G.LoopWalk u w → G.LoopWalk v w
  | nil, q => q
  | cons h p, q => LoopWalk.reverseAux p (cons (G.symm h) q)
  | loop p, q => LoopWalk.reverseAux p (loop q)

/-- The walk in reverse. -/
@[symm]
def reverse {u v : V} (w : G.LoopWalk u v) : G.LoopWalk v u := w.reverseAux nil


