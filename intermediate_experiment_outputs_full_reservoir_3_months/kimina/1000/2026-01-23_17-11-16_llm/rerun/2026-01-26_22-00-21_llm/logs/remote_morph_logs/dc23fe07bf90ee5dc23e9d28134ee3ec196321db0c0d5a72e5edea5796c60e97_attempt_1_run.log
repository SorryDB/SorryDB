def PreState.forms : PreState bt → List Formula := 
  fun π => match π with
  | fromRoot p => p.forms
  | fromMod e p => p.forms

/-- Collect formulas in a pre-state. The loaded part of Λ(π) in paper. -/
def PreState.lforms : PreState bt → List NegLoadFormula := 
  fun π => match π with
  | fromRoot p => p.lforms
  | fromMod e p => p.lforms

def PreState.last : PreState bt → Sequent := 
  fun π => match π with
  | fromRoot p => p.last
  | fromMod e p => p.last

