have h6 : (ComplexRMK.rieszMeasure (compSL C‚āÄ((spectrum ‚Ąā a), ‚Ąā) C((spectrum ‚Ąā a), ‚Ąā) ‚Ąā _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ‚Ąā a) ‚Ąā ‚Ąā _ _ _ _ _ _).symm.toContinuousLinearMap)).integral f = (compSL C‚āÄ((spectrum ‚Ąā a), ‚Ąā) C((spectrum ‚Ąā a), ‚Ąā) ‚Ąā _ _ (cfc_toLinearFunctional ha x y) (@ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE (spectrum ‚Ąā a) ‚Ąā ‚Ąā _ _ _ _ _ _).symm.toContinuousLinearMap) f := by
