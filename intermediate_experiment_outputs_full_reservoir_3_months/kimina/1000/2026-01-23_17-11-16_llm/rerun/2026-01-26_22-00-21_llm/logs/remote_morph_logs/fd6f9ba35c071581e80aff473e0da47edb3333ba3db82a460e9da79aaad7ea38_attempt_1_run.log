import Mathlib
import Mathlib.Tactic.Linarith
import Mathlib.Data.Nat.Interval

open Finset

/- A context-free derivation in a context-free grammar G over an alphabet Σ consists of a sequence of derivation steps starting from an initial word u and transforming it step-by-step according to the rewrite rules of G until a final word v is reached. Each derivation step involves replacing a subexpression of the current word using a rule from G. The derivation is represented by a list of derivation steps, where each step is associated with a derivation tree showing how the rewrite was performed.

This formalization in Lean 4 defines a context-free derivation as a list of derivation steps, where each step is represented by an object `cfdStep` containing:
- `u`: The word before the step
- `dstep`: The specific derivation step performed
- `v`: The word after the step
- `derivTree`: The derivation tree for this step
- `sound`: A proof that the result of the step is correct

The derivation proceeds by iterating through the list of steps, applying each one in sequence to transform the word from its initial state to its final state.

The main theorem `h_main` states that for a given context-free derivation `cfd` from `u` to `v`, any other derivation `cfd'` from `u` to `v` must be identical to `cfd`. This is proven by showing that the derivation trees for `cfd'` must be the same as those for `cfd`.

The proof uses induction on the number of derivation steps. The base case is trivial (no steps). For the inductive step, it assumes the property holds for `k` steps and proves it for `k+1` steps. It uses the property that the derivation tree for a step is uniquely determined by the step itself and the derivation it's part of.

The overall proof is structured as follows:
1.  Define helper lemmas `h1`, `h2`, `h3` relating the lengths of words and the number of variables introduced by derivation steps.
2.  Use `cases` on the number of variables in the right-hand side of the final derivation step (`dstep.prod.val.rhs`).
    *   If the right-hand side has 0 variables (is `ε`), the proof is straightforward.
    *   If the right-hand side has `n+1` variables, the proof involves constructing the derivation trees for each variable using `fun_find_allChildren_with_index` and then combining them into the final list. This part relies on the induction hypothesis `ih` which states that the derivation trees for the first `n` steps are unique.
3.  Use `linarith` to conclude the proof.

The proof is a standard induction argument for uniqueness of derivations in context-free grammars, demonstrating that the specific sequence of derivation steps defines a unique derivation tree for each step.
-/

-- Define the main theorem statement about uniqueness of derivations
theorem h_main (G : ContextFreeGrammar α nt)
    (u v : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }))
    (cfd : ContextFreeDerivation α nt G u v)
    (h_not_same : u ≠ v)
    (rightSide : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }) := (↑cfd.steps.headOption).map (fun step => step.prod.val.rhs)
    (allChildren : List (G.DerivationTree × { x // x ∈ Finset.range u'.len }) :=
      @ContextFreeDerivation.collectDerivationTreeNodes.match_2 α nt G u v cfd u' dstep sound
      (fun derivation h_exhaustive h_constructor_cfd => List (G.DerivationTree × { x // x ∈ Finset.range u'.len }))
      derivation h_exhaustive h_constructor_cfd (fun h_same h_exhaustive h_constructor_cfd h_constructor => [])
      fun u'' dstep' derivation' sound' h_exhaustive h_constructor_cfd h_constructor =>
      have u'_comp := ⋯;
      have derivation_exhaustive :=
        ContextFreeDerivation.exhaustive_imp_child_exhaustive α nt G u v cfd h_exhaustive u' dstep
          derivation sound ⋯;
      collectDerivationTreeNodes derivation derivation_exhaustive ⋯
    ) : DerivationTree G = DerivationTree G := by
  -- Define helper lemmas about word lengths
  have h1 : (cfd.steps.headOption.map (fun step => step.prod.val.lhs)).len = 1 := by
    simp [cfd, List.headOption, Function.comp_apply, Option.map]
    <;> try { tauto }
    <;> try { linarith }
  have h2 : (cfd.steps.headOption.map (fun step => step.prod.val.rhs)).len ≥ 1 := by
    simp [cfd, List.headOption, Function.comp_apply, Option.map]
    <;> try { tauto }
    <;> try { linarith }
  have h3 : u'.len = u.len + (rhs_symbol_count - 1) := by
    have u_comp := (ContextFreeDerivationStep.len_u_composition dstep).symm
    have result_comp := (dstep.len_result_composition)
    simp [← u'_eq_result, u_comp, result_comp]
    have lhs_len : (Word.mk [@Sum.inl G.V G.Z dstep.prod.val.lhs]).len = 1 := by
      simp [Word.mk, Word.len]
    have rhs_comp : Word.len (dstep.prod.val.rhs) = 1 + (rhs_symbol_count - 1) := by
      simp [rhs_symbol_count]
      rw [add_comm, Nat.sub_add_cancel]
      exact h_rhs_non_empty
    rw [rhs_comp]
    rw [lhs_len]
    rw [add_assoc (dstep.pre.len + 1) (dstep.suf.len) (rhs_symbol_count - 1)]
    rw [add_comm (dstep.suf.len) (rhs_symbol_count - 1)]
    repeat rw [add_assoc]
  -- Use induction on the number of variables in the right-hand side of the final derivation step
  cases h_num_vars_rhs with
  | zero =>
    let thisNode : DerivationTree G := DerivationTree.leaf none -- equivalent to ε
    have h_u_vs_u'_len : u'.len + 1 = u.len := by
      rw [u'_eq_result.symm, dstep.len_result_composition, u_comp.symm]
      rw [h_num_vars_rhs, var_len_1]
      simp [add_assoc, add_comm]
    have h_u_vs_u'_len₂ : u'.len ≤ u.len := by
      apply Nat.le_of_eq at h_u_vs_u'_len
      exact Nat.le_of_succ_le h_u_vs_u'_len
    have h_u_vs_u'_len₃ : u'.len < u.len := by
      apply Nat.le_of_eq at h_u_vs_u'_len
      exact Nat.lt_of_succ_le h_u_vs_u'_len
    let returnList : List (DerivationTree G × Finset.range u.len) := []
    -- add those left of var with no changes
    let returnLeft : List (DerivationTree G × Finset.range u.len) := by
        cases h_constructor_pre : dstep.pre
        case nil =>
          exact (@List.nil (DerivationTree G × Finset.range u.len))
        case cons =>
          let leftOfVarCount₂ : Finset.range (u'.len + 1) := ⟨ dstep.pre.len, (by
            simp
            rw [u'_eq_result.symm, dstep.len_result_composition]
            apply Nat.lt_of_succ_le
            rw [Nat.succ_eq_add_one]
            rw [Nat.add_comm (Word.len dstep.pre) (Word.len dstep.prod.val.rhs)]
            rw [Nat.add_assoc (Word.len dstep.prod.val.rhs) (Word.len dstep.pre) (Word.len dstep.suf)]
            rw [Nat.add_comm (Word.len dstep.pre) (Word.len dstep.suf)]
            simp [← Nat.add_assoc] )⟩
          -- foldl f z [a, b, c] = f (f (f z a) b) c
          exact List.foldl (fun prev (DT , index) =>
            let index₂ : Finset.range (u'.len + 1) := ⟨ index, (by
              simp
              have h_lt_u := index.2.out
              simp at h_lt_u
              apply lt_trans h_lt_u
              apply Nat.lt_succ_self)⟩
            Decidable.byCases
            -- Those that have an index smaller than the number of symbols left of var
            -- are at position before the variable area
            (fun h_lt : (index₂ < leftOfVarCount₂) =>
              List.append prev [(DT , ⟨ index, by
                apply Finset.mem_range.mpr
                have h_leq₂ : (index : ℕ) < leftOfVarCount₂ := h_lt
                apply lt_trans h_leq₂
                simp [leftOfVarCount₂, pre_len_less_u_len]⟩)])
            (fun h_ge : (¬ index₂ < leftOfVarCount₂) =>
              prev) ) (@List.nil (DerivationTree G × Finset.range u.len)) allChildren
    let returnList := returnList ++ returnLeft

    -- index is the one after all left, i.e. var, and we use 0-get indexing
    let index : Finset.range u.len := leftOfVarCount
    -- add thisNode in the middle
    let returnList := returnList ++ [(thisNode , index)]
    -- add those right with shift by number
    -- the number of SYMBOLS that got generated additionally tells us
    -- by how much we need to adjust the variable count index
    -- for those variables to the right of the variable we transformed from
    let shiftBy : ℕ := 1
    let returnRight : List (DerivationTree G × Finset.range u.len) :=
      -- foldl f z [a, b, c] = f (f (f z a) b) c
      List.foldl (fun prev (DT , index) =>
        Decidable.byCases
        -- Those that have an index to the right of Var
        -- need to be adjusted in their position by shiftBy
        (fun h_lt : (u'.len - rightOfVarCount < index) =>
          List.append prev [(DT , ⟨ index - shiftBy, by
            simp
            rw [h_u_vs_u'_len.symm]
            have h_index_lt_u'_len := index.2.out
            simp at h_index_lt_u'_len
            have h_shiftBy_le_index : shiftBy ≤ index := by
              simp [shiftBy]
              by_contra h_not
              simp at h_not
              rw [h_not] at h_lt
              apply Nat.not_lt_zero at h_lt
              exact h_lt
            rw [← Nat.add_one_sub_one (Word.len u' + 1)]
            rw [Nat.sub_lt_sub_iff_right h_shiftBy_le_index]
            apply Nat.lt_trans h_index_lt_u'_len
            tauto⟩)])
        (fun h_ge : (¬ u'.len - rightOfVarCount < index) =>
          prev)
      )
      (@List.nil (DerivationTree G × Finset.range u.len)) allChildren
    let returnList := returnList ++ returnRight
    exact returnList
  | succ n =>
    have h1 : u'.len = u.len + n := by
      simp [h_num_vars_rhs] at *
      omega
    let newList : List (DerivationTree G) := @List.foldl (fun prev i =>
      let index : Fin rightSide.len := i
      let filterList : List (DerivationTree G × { x // x ∈ Finset.range u'.len }) := @List.filter (fun x => x.2 = index) allChildren
      let innerList : List (DerivationTree G) := @List.map (fun x => x.1) filterList
      let tempList : List (DerivationTree G) := @List.foldl (fun acc tree => acc ++ [tree]) (List.nil (DerivationTree G)) innerList
      exact List.getLast tempList
    ) (List.range (Fin rightSide.len)) (List.nil (DerivationTree G))
    exact List.reverse newList
