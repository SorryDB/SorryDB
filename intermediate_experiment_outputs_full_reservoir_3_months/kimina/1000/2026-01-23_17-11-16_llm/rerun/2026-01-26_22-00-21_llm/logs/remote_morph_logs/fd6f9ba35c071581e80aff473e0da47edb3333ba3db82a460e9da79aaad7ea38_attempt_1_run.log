import Mathlib

/-
This theorem is about the structure of the set of derivations in a context-free
grammar. Specifically, it shows that if a derivation step introduces a new variable,
then the derivations can be broken down into three parts: the part before the variable,
the variable itself, and the part after the variable.
-/

theorem ContextFreeDerivationStep.collectDerivationTreeNodes (α : Sort u_1) [DecidableEq α] [DecidableEq (α ⊕ α)] [DecidableEq (Finset α)] (nt : Sort u_2) [DecidableEq nt] [DecidableEq (Finset nt)] (G : ContextFreeGrammar α nt) (u v : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }))
    (h_not_same : u ≠ v)
    (u' : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }))
    (dstep : G.ContextFreeDerivationStep u)
    (derivation : ContextFreeDerivation α nt G u' v)
    (sound : dstep.result = u')
    (h_exhaustive : ContextFreeDerivationStep.exhaustiveCondition α nt G u v
        (ContextFreeDerivation.step α nt G u u' v dstep derivation sound))
    (h_constructor : cfd = ContextFreeDerivation.step α nt G u u' v dstep derivation sound) :
    (let allChildren : List (G.DerivationTree × { x // x ∈ Finset.range u'.len }) :=
     @ContextFreeDerivationStep.collectDerivationTreeNodes match_2 α nt G u v cfd u' dstep sound
     (fun derivation h_exhaustive h_constructor_cfd => List (G.DerivationTree × { x // x ∈ Finset.range u'.len }))
     derivation h_exhaustive h_constructor_cfd (fun h_same h_exhaustive h_constructor_cfd h_constructor =>
       have u'' : u' = u := by tauto
       have : u = v := by
         exact h_not_same u'' 
       tauto
     )
     fun u'' dstep' derivation' sound' h_exhaustive h_constructor_cfd h_constructor =>
     have u'_comp := (ContextFreeDerivationStep.len_u_composition dstep').symm
     have derivation_exhaustive := ContextFreeDerivationStep.derivation_exhaustive α nt G u v cfd h_exhaustive u'' dstep' derivation' sound' h_exhaustive h_constructor_cfd h_constructor
     collectDerivationTreeNodes derivation' derivation_exhaustive
    )
    (fun index₁ h_index_valid => 
      let afunc : List (G.DerivationTree × { x // x ∈ Finset.range u'.len }) →
                      (G.DerivationTree × { x // x ∈ Finset.range u'.len }) →
