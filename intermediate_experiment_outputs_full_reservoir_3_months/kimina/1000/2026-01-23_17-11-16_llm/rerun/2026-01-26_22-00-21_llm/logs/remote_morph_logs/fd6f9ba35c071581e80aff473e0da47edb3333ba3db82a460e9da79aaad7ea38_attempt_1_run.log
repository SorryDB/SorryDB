import Mathlib

/- A context-free derivation is a sequence of derivation steps. A derivation step consists of a
   preface, a variable, and a suffix. The variable is replaced by its definition in the
   preface and suffix. This forms a new word. This new word is the result of the derivation
   step. -/

namespace ContextFreeDerivation

variable {α : Sort u_1} {nt : Sort u_2} {G : ContextFreeGrammar α nt}

/- A derivation step is a function from a derivation context to a derivation result. -/
noncomputable def DerivationStep (G : ContextFreeGrammar α nt) (u : Word (G.V ⊕ G.Z)) :
  G.V ⊕ G.Z → Option (DerivationResult G u) :=
  fun v ↦ DerivationResult.mk (G.derivations u v)

/- A derivation step is sound if it leads to a valid derivation result. -/
noncomputable def sound (dstep : DerivationStep G u) : Prop :=
  ∃ result : DerivationResult G u, dstep result

/- A derivation step is exhaustive if any valid derivation result leads to a contradiction
   when used in further derivations. -/
noncomputable def exhaustiveCondition (G : ContextFreeGrammar α nt) (u v : Word (G.V ⊕ G.Z)) :
  (derivations u v).Nonempty → Prop :=
  fun (nonempty : (derivations u v).Nonempty) =>
    ∀ (d : DerivationStep G u), ∀ (derivation : Derivation G u v), ∀ (h : sound d),
      ∀ (h' : d.derivates (derivations u v)), False

/- A derivation step is valid if it is sound and exhaustive. -/
noncomputable def valid (dstep : DerivationStep G u) : Prop :=
  sound dstep ∧ (∀ (derivation : Derivation G u v) (h : sound dstep),
    exhaustiveCondition G u v (derivations u v).Nonempty → False)

