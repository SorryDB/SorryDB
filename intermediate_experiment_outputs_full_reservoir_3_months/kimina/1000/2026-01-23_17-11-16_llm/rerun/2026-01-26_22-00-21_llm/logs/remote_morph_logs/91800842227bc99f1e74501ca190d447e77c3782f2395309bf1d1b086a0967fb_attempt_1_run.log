  match e with
  | .v (v,_) => .v v
  | .c f => .c f
  | .add l r => to_nat l + to_nat r
  | .mul l r => to_nat l * to_nat r
  | .sub l r => to_nat l - to_nat r

def to_var {var} (e:Exp F (Nat × var)) : Exp F var :=
  match e with
  | .v (_,v) => .v v
  | .c f => .c f
  | .add l r => to_var l + to_var r
  | .mul l r => to_mul l r
  | .sub l r => to_sub l r

def beq : (e1 e2 : Exp F Nat) -> Bool
