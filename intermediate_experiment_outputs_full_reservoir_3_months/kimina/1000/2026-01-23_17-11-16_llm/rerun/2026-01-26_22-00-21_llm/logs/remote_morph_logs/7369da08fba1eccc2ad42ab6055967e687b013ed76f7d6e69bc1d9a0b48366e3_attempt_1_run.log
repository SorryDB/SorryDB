            nlinarith [sq_nonneg (x₁ - x₂), sq_nonneg (y₁ - y₂), sq_nonneg (s * (x₁ - x₂) - (y₁ - y₂)), sq_nonneg (x₁ + x₂ - 2 * s), sq_nonneg (y₁ + y₂ + E.val.a₁ * x₁ + E.val.a₃), sq_nonneg (y₁ - y₂ - s * (x₁ - x₂))]
          )
