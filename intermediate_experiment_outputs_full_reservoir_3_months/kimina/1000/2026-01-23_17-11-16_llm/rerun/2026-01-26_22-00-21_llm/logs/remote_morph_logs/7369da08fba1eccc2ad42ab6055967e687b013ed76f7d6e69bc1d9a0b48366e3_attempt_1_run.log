            <;> field_simp [show (2 : K) ≠ 0 by norm_num]
            <;> ring_nf
            <;> nlinarith [sq_nonneg (s + W.a₁/2), sq_nonneg (x₁ - x₃), sq_nonneg (y₁ - y₃)]
          )
