import ClassFieldTheory.IsNonarchimedeanLocalField.Valuation
import ClassFieldTheory.IsNonarchimedeanLocalField.Instances
/-

# 1 → 𝒪[L]ˣ → Lˣ → ℤ → 0 as G-module

