      ext (u : Additive Lˣ)
      obtain ⟨u, rfl⟩ := Additive.ofMul.surjective u
      -- should follow from `valuation_ringEquiv`
      sorry
  }
  zero := sorry -- v(𝒪[L]ˣ) = 0, follows from (easy direction of) ker_v_ker in
                -- IsNonarchimedeanLocalField.Valuation

