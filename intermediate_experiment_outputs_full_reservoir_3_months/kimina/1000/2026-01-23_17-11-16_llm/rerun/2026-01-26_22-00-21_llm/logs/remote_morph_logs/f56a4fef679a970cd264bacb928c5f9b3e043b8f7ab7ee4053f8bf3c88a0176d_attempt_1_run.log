noncomputable abbrev stoppingTime (t : WithTop ℝ) : Ω → WithTop ℝ := fun _ ↦ t

noncomputable abbrev hittingAfter (P : ι → Ω → Prop) (A : Set ι) (T : WithTop ι) :
    Ω → WithTop ι := fun ω => inf {t ∈ A | P t ω ∧ t ≥ T}

