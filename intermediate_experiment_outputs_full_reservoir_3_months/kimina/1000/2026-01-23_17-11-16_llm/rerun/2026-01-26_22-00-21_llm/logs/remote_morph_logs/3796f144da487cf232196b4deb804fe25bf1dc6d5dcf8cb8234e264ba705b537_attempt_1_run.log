import Mathlib

/-- A derivation for a context-free grammar -/
noncomputable def ContextFreeDerivation
  (α : Sort u_1) (nt : Sort u_2) (G : ContextFreeGrammar α nt)
  (u : Word (G.V ⊕ G.Z)) (v : Word (G.V ⊕ G.Z))
  : Prop :=
  match u with
  | [] => v = []
  | a :: u =>
    match v with
    | [] => False
    | b :: v =>
      match a with
      | Inl s => match s with
        | Apply p => match p with
          | Base n => n = b
          | Rewrite r => match r with
            | Replace w h => False
            | Substitute x h => False
          | Reduce h => False
        | Variable n => False
      | Inr s => match s with
        | Apply p => match p with
          | Base n => n = b
          | Rewrite r => match r with
            | Replace w h => False
            | Substitute x h => False
          | Reduce h => False
        | Variable n => False

/-- Return a derivation tree version of this CFD-/
def ContextFreeDerivation.toDerivationTree
  {G : ContextFreeGrammar α nt} {u : Word (G.V ⊕ G.Z) } {v : Word (G.V ⊕ G.Z)}
  (cfd : @ContextFreeDerivation α nt G u v)
  (h_exhaustive : cfd.exhaustiveCondition)
  (h_starts_in_1 : cfd.startsIn1Condition) :
  DerivationTree G :=
    match h_constructor : cfd with
    | .same h_same => sorry
    | @ContextFreeDerivation.step _ _ _ _ u' _ dstep derivation sound => by
      exact ((ContextFreeDerivation.collectDerivationTreeNodes cfd h_exhaustive ⋯)[0]'sorry).fst

