  intro x
  simp [smaller, larger]
  <;> tauto
```

We've established that for any element `x`, it is in `l` if and only if it is in either `smaller pivot l` or `larger pivot l`. This is true because any element is either less than or equal to the pivot or strictly greater than the pivot.

Now we need to show that `List.count x l = (smaller pivot l).count x + (larger pivot l).count x`. The key is that these are disjoint lists, so their counts add up.

```tactics
have h2 : (l.count x) = (smaller pivot l).count x + (larger pivot l).count x := by
  have h3 : ∀ x : α, x ∈ l ↔ x ∈ smaller pivot l ∨ x ∈ larger pivot l := h1
  have h4 : (smaller pivot l).count x + (larger pivot l).count x = l.count x := by
    have h5 : (smaller pivot l).count x + (larger pivot l).count x = l.count x := by
      have h6 : (smaller pivot l).count x + (larger pivot l).count x = (l.filter (fun x => x ≤ pivot)).count x + (l.filter (fun x => pivot < x)).count x := by
        simp [smaller, larger]
      rw [h6]
      have h7 : (l.filter (fun x => x ≤ pivot)).count x + (l.filter (fun x => pivot < x)).count x = l.count x := by
        have h8 : (l.filter (fun x => x ≤ pivot)).count x + (l.filter (fun x => pivot < x)).count x = l.count x := by
          have h9 : Disjoint (l.filter (fun x => x ≤ pivot)) (l.filter (fun x => pivot < x)) := by
            apply List.disjoint_filter_filter
            intro x hx1 hx2
            simp at hx1 hx2
            all_goals omega
          rw [←List.count_union_eq h9]
          have h10 : l.filter (fun x => x ≤ pivot) ∪ l.filter (fun x => pivot < x) = l := by
            ext y
            simp
            <;> omega
          rw [h10]
          all_goals simp
        linarith
      linarith
    linarith
