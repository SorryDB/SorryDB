    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [V ⊗[ℚ] v.adicCompletion ℚ,
        (((continuousBaseChange _ φ).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
          v).subtype.toIntLinearMap).toAddMonoidHom).range)]) ≃ₜ+
    (V ⊗[ℚ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [V ⊗[ℚ] v.adicCompletion ℚ,
        (((continuousBaseChange _ φ).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
          v).subtype.toIntLinearMap).toAddMonoidHom).range)]) := 
  .sumCongr (continuousBaseChange _ φ).toContinuousAddEquiv
