theorem is_open_range_of_composition_of_isomorphism_and_linear_map {L : Type*} [AddCommGroup L]
    {V : Type*} [AddCommGroup V] [Module ℤ L] [Module ℚ V]
    {f : L → V} [Continuous f]
    {g : V → L} [IsEquiv g]
    {h : L → V} [IsLinearMap h]
    {k : V → L} [IsLinearMap k] (hk : k = g)
    {m : L} (hm : m = f)
    : IsOpen (Set.range (g.comp f)) := by
  have h1 : IsContinuousOn g.comp f (Set.univ : Set L) := by
    apply ContinuousOn.comp
    · exact continuousOn_of_isEquiv g
    · exact continuousOn_of_isLinearMap f
  have h2 : IsOpen (Set.range (g.comp f)) := by
    apply isOpen_range_of_isEquiv
    exact ⟨fun x => ⟨g.comp f x, by simp [hk, hm]⟩, by simp⟩
  exact h2

