    IntegralLattice ℤ ℚ V ⊗[ℤ] (InfiniteAdeleRing ℚ) ≃L[InfiniteAdeleRing ℚ]
    V ⊗[ℚ] (InfiniteAdeleRing ℚ) := {
  __ := c_infty_alg
