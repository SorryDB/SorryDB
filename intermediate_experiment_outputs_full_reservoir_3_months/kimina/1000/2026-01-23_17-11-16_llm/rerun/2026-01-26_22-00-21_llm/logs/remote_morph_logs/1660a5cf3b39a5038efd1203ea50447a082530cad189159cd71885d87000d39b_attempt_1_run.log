      -- Let's compute A ◁ ((A ∘ M) ◁ (A ∘ M))
      -- By definition of composition (A ∘ M) applied to (A ∘ M)
      -- (A ∘ M) ◁ (A ∘ M) = A ◁ (M ◁ (A ∘ M))
      -- Now compute M ◁ (A ∘ M)
      -- M is the mockingbird, so M ◁ x = x ◁ x
      -- Therefore M ◁ (A ∘ M) = (A ∘ M) ◁ (A ∘ M)
      -- Therefore, (A ∘ M) ◁ (A ∘ M) = A ◁ ((A ∘ M) ◁ (A ∘ M))
      -- This is exactly what we need to show
      have h1 : (A ∘ M) ◁ (A ∘ M) = A ◁ ((A ∘ M) ◁ (A ∘ M)) := by
        have h2 : (A ∘ M) ◁ (A ∘ M) = A ◁ (M ◁ (A ∘ M)) := by
          rw [composition]
        have h3 : M ◁ (A ∘ M) = (A ∘ M) ◁ (A ∘ M) := by
          rw [M.call]
          all_goals simp
        rw [h2, h3]
