        evaluate (collection R).snd.snd.fst oldWorld œÜ)
    -- Program IH 1: relations within models are preserved
    (fun œÄ => (‚àÄ (R : Œ≤) (oldWorld‚ÇÅ oldWorld‚ÇÇ : (collection R).fst),
        relate (combinedModel collection newVal).fst œÄ
          (Sum.inr ‚ü®R, oldWorld‚ÇÅ‚ü©) (Sum.inr ‚ü®R, oldWorld‚ÇÇ‚ü©)
        ‚Üî relate (collection R).snd.snd.fst œÄ oldWorld‚ÇÅ oldWorld‚ÇÇ)
        -- Program IH 2: if old worlds are from different models they are not related
