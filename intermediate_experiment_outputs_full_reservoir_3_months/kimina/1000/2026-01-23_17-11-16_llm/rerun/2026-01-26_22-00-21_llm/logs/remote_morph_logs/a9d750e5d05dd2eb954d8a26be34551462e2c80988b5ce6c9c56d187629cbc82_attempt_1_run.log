  sorry

lemma Sheaf.discToCodisc_app {X : (Type max u v)} :
    (discToCodisc (Sheaf J (Type max u v)) (Type max u v)).app X =
      ⟨inv (toSheafify J ((Functor.const _).obj X)) ≫ { app Y x y := ⟨x⟩ }⟩ := by
