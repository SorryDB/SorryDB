    sorry
  · -- Property 3: ∀ w ∈ W, ∀ α, ∀ φ ∈ w, φ ∈ proj α w
    intro w w_in α φ in_w
    unfold M at in_w
    simp at in_w
    rcases in_w with ⟨π, in_all, def_w
