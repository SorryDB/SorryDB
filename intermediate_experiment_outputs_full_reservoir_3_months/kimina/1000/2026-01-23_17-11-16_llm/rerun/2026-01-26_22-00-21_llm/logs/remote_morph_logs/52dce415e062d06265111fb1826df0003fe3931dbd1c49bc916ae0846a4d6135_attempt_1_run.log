import Mathlib

/-! ## Builder strategy tree

/-- A position in the strategy tree. -/
inductive GamePos (s : Set (Finset Formula)) : Type
| start : GamePos s
| next (Y : Finset Formula) (Y_in : Y ∈ s) : GamePos s

/-- The game state at a position `pos`. -/
structure GameState (pos : GamePos s) : Type
| pos : GamePos s
| s : Set (Finset Formula)
| H : Finset Formula
| X : Finset Formula
| moves : List (Finset Formula)

/-- The type of the strategy tree. -/
inductive BuildTree (pos : GamePos s) : Type
| leaf : pos ∈ s → BuildTree pos := sorry
| step : (YS : List (Finset Formula)) → (next : (newPos : Finset Formula) → newPos ∈ YS → BuildTree newPos) →
    (mvs : (newPos : Finset Formula) → newPos ∈ YS → Move pos newPos) →
    (h : YS ∈ s) →
    (pos_in : pos = YS.head) →
    (s_in : s = YS.tail ++ [YS.head]) →
    (nonempty : YS.Nonempty) →
    BuildTree pos := sorry

/-- A path in the strategy tree, ending at a specific position. -/
inductive Match : ∀ {pos : GamePos s}, BuildTree pos → Type
| stop {bt} : Match bt
| mov {YS Y mvs next} Y_in (tail : Match (next Y Y_in)) : Match (BuildTree.Step YS mvs next)

