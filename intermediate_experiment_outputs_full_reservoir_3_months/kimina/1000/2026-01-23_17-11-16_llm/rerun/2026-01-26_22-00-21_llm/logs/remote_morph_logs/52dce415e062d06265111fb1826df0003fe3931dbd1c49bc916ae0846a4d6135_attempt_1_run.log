/-- Theorem 6.21: If Builder has a winning strategy then there is a model graph. -/
theorem strmg (X : Sequent) (s : Strategy tableauGame Builder) (h : winning s (startPos X)) :
    ∃ (WS : Finset (Finset Formula)) (mg : ModelGraph WS), ∃ Z ∈ WS, X.toFinset ⊆ Z := by
  let bt := buildTree s h
  let WS := bt.toModel.1
  let M := bt.toModel.2
  refine ⟨WS, ⟨M, ?_, ?_⟩⟩
  -- show the model graph properties
  · -- Property 1: ∀ X, X ∈ W → S X ⊆ X
    intro X X_in
    unfold WS at X_in
    simp at X_in
    rcases X_in with ⟨π, in_all, def_X⟩
    have := PreState.locConsSatBas π
    simp_all
  · -- Property 2: ∀ X Y, X ∈ W → Y ∈ W → R X Y → X ⊆ Y
    intro X Y X_in Y_in rel
    unfold M at rel
    simp at rel
    rcases rel with ⟨φ, in_X, sub_Y⟩
    simp at sub_Y
    unfold WS at X_in Y_in
    simp at X_in Y_in
    rcases X_in with ⟨πX, in_allX, def_XX⟩
    rcases Y_in with ⟨πY, in_allY, def_YY⟩
    -- Need to show X ⊆ Y, i.e., πX.forms ⊆ πY.forms
    -- This is not generally true. We need to reason about the structure.
    -- This is a complex part, need to use properties of build tree.
    sorry
  · -- Property 3: ∀ w ∈ W, ∀ α, ∀ φ ∈ w, φ ∈ proj α w
    intro w w_in α φ w_in
    unfold M at w_in
    simp at w_in
    rcases w_in with ⟨π, in_all, def_w⟩
    unfold WS at w_in
    simp at w_in
    rcases w_in with ⟨π, in_all, def_w⟩
    -- Need to show that if φ ∈ w, then φ ∈ projection α w
    -- This means φ ∈ PreState.forms π ++ (if α.isAtomic then [Formula.neg (Formula.boxes α φ)] else [])
    -- Since φ ∈ w, which is ((bt.allPreStates).map (List.toFinset ∘ PreState.forms)).toFinset
    -- This means there exists some π' in bt.allPreStates such that φ ∈ PreState.forms π'
    -- So we need to show that if φ ∈ PreState.forms π', then φ ∈ PreState.forms π ++ ...
    -- This is true because PreState.forms π' is a subset of PreState.forms π ++ ...
    -- This reasoning needs to be formalized.
    sorry
  · -- Property 4: ∀ w ∈ W, ∀ α, ∀ φ ∈ proj α w, φ ∈ w
    intro w w_in α φ w_in
    unfold M at w_in
    simp at w_in
    rcases w_in with ⟨π, in_all, def_w⟩
