import Mathlib

/-! ## Builder strategy tree (Def 6.8)

/-- A strategy tree for the `Builder` in `tableauGame`.
It consists of a root position `pos` and a map `next` from positions to lists of successor positions.
The root is the starting position of the game.
A position `pos` is represented as `⟨H, X, p⟩`, where `H` is the list of moves made to reach `pos` (e.g. `[]` for the root, `[prPdl r]` for one step), `X` is the current state of the goal (a `Sequent`), and `p` is the current game state (e.g. `0` for `PDL`, `1` for `LocTab`, `2` for `Repeat`).
A `PDL` move takes a `r : PDL` and a proof that `r` is valid.
A `LocTab` move takes a `lt : LocalTableau` and a proof that it's valid.
A `Repeat` move takes a proof that there's at least one move available.
-/

inductive Move (pos : GamePos) : Type
| prPdl r hr => ⟨r, hr⟩
| prLocTab lt hl => ⟨lt, hl⟩
| prRepeat => ⟨⟩ -- A repeat move is simply an empty constructor

/-- A strategy tree for the `Builder` in `tableauGame`.
It is a tree structure where each node is a position `pos` and its children are the possible next positions `next pos`.
-/
inductive BuildTree (pos : GamePos) : Type
| leaf pos_in : {pos_in : GamePos}
| step pos_in YS nextMoves : {pos_in : GamePos} → (YS : List GamePos) → (nextMoves : ∀ (newPos : GamePos), newPos ∈ YS → Move pos_in newPos) → {pos_in : GamePos} → {pos_in : GamePos}

/-- A build tree is well formed if its root is a valid starting position and its internal structure respects the game rules. -/
structure BuildTree.wf : ∀ {pos}, Prop :=
  (pos : GamePos) → ∀ (bt : BuildTree pos), { root : pos = (posOf [] X) -- root is start
    , moves : ∀ (pos_in : GamePos), pos_in ∈ YS → Move pos_in new_pos
    , nonempty : YS.Nonempty } → True -- internal structure rules

/-! ## Strategy tree construction (Sec 6.3)

/-- Given a `winning` strategy `s` for `Builder` on a goal `X`, construct the corresponding strategy tree.
-/
def buildTree (s : Strategy tableauGame Builder) (pos : GamePos) (h : winning s pos) : BuildTree pos :=
