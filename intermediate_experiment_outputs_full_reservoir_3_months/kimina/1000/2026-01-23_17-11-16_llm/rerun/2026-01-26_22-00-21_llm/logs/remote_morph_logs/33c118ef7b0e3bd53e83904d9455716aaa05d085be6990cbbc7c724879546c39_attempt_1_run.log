  rw [h1]
  apply ContMDiffAt.prod
  · -- Show that `f` is m-differentiable at x₀
    simpa using hf.of_le (by linarith)
  · -- Show that `fderiv I I' f` is m-differentiable at x₀
    apply contMDiffAt_fderiv hf
