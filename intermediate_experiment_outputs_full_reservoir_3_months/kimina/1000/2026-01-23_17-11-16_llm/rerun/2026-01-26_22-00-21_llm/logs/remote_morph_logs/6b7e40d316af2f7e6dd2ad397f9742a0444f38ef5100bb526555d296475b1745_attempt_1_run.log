import Mathlib.Algebra.IsPrimePow

/-!
# Conjecture relating two characterizations of a set of integers.

Informal Statement:
For an integer $k ≥ 2$, the following are equivalent:

1. The greatest common divisor of the binomial coefficients
    $\binom{2k}{k}, \binom{3k}{k}, \dots, \binom{(k+1)k}{k} = 1$.

2. Writing prime factorization of k as
    $k = \prod p_i^{e_i}$, and let
    $P = \max_i p_i^{e_i}$,
    one has $k / P > P$.

This conjecture asserts that the integers satisfying (1)
are exactly those satisfying (2).

*Reference:*
- [A080170](https://oeis.org/A080170)
- [A051283](https://oeis.org/A051283)
-/

namespace OeisA080170

/--
The gcd of the binomial coefficients
$\binom{2k}{k}, \binom{3k}{k}, \dots, \binom{(k+1)k}{k} = 1$.
-/
def GCDCondition (k : ℕ) : Prop :=
  (Finset.range k).gcd (fun i => Nat.choose ((i + 2) * k) k) = 1

/--
Let P be the largest prime power dividing `k`.
Then $k / P > P$.
-/
def PrimePowerCondition (k : ℕ) : Prop :=
  let P := ((Nat.divisors k).filter IsPrimePow).max.getD 0
  k / P > P

/--
Conjecture: The gcd condition is equivalent to the prime power condition.
-/
@[category research open, AMS 11]
theorem gcdCondition_iff_primePowerCondition (k : ℕ) (hk : 2 ≤ k) :
    GCDCondition k ↔ PrimePowerCondition k := by
  constructor
  · -- Assume GCDCondition k, prove PrimePowerCondition k
    intro h
    have h1 : ¬ (k).IsPrimePow := by
      have h2 : (Finset.range k).gcd (fun i => Nat.choose ((i + 2) * k) k) = 1 := h
      by_contra h
      have h3 : (Finset.range k).gcd (fun i => Nat.choose ((i + 2) * k) k) = k := by
        rw [Nat.gcd_range_choose]
        all_goals
          try { tauto }
          try { 
            have h5 : k ≥ 2 := by linarith
            have h6 : k ≠ 0 := by linarith
            tauto
          }
      omega
    have h2 : let P := ((Nat.divisors k).filter IsPrimePow).max.getD 0
      k / P > P := by
      have h3 : ¬ k.IsPrimePow := h1
      by_contra h
      push_neg at h
      have h4 : k ≤ ((Nat.divisors k).filter IsPrimePow).max.getD 0 ^ 2 := by
        have h7 : k / ((Nat.divisors k).filter IsPrimePow).max.getD 0 ≤ ((Nat.divisors k).filter IsPrimePow).max.getD 0 := by
          have h8 : ((Nat.divisors k).filter IsPrimePow).max.getD 0 ∣ k := by
            simp [Nat.dvd_divisors]
          have h9 : k / ((Nat.divisors k).filter IsPrimePow).max.getD 0 ≤ ((Nat.divisors k).filter IsPrimePow).max.getD 0 := by
            apply Nat.div_le_of_le_mul
            nlinarith
          linarith
        have h10 : k = ((Nat.divisors k).filter IsPrimePow).max.getD 0 * (k / ((Nat.divisors k).filter IsPrimePow).max.getD 0) := by
          rw [Nat.mul_div_cancel']
          exact (by simp [Nat.dvd_divisors])
        nlinarith
      have h5 : k.IsPrimePow := by
        apply Nat.isPrimePow_of_dvd_of_prime_pow
        · -- Show that k is a prime power
          have h9 : ((Nat.divisors k).filter IsPrimePow).max.getD 0 ≤ k := by
            simp [Nat.le_divisors]
          have h10 : ((Nat.divisors k).filter IsPrimePow).max.getD 0 ^ 2 ≥ k := by
            nlinarith
          have h11 : ((Nat.divisors k).filter IsPrimePow).max.getD 0 ∣ k := by
            simp [Nat.dvd_divisors]
          have h12 : ((Nat.divisors k).filter IsPrimePow).max.getD 0 ^ 2 ∣ k ^ 2 := by
            apply Dvd.dvd.pow
            exact h11
          have h13 : ((Nat.divisors k).filter IsPrimePow).max.getD 0 ^ 2 ≤ k ^ 2 := by
            apply Nat.le_of_dvd (by nlinarith) h12
          nlinarith
        · -- Show that k is a prime power
          simp [Nat.PrimePow]
          all_goals
            try { tauto }
            try { 
              have h5 : k ≥ 2 := by linarith
              have h6 : k ≠ 0 := by linarith
              tauto
            }
      contradiction
    exact h2
  · -- Assume PrimePowerCondition k, prove GCDCondition k
    intro h
    have h1 : ¬ (k).IsPrimePow := by
      by_contra h2
      have h3 : (Finset.range k).gcd (fun i => Nat.choose ((i + 2) * k) k) = k := by
        rw [Nat.gcd_range_choose]
        all_goals
          try { tauto }
