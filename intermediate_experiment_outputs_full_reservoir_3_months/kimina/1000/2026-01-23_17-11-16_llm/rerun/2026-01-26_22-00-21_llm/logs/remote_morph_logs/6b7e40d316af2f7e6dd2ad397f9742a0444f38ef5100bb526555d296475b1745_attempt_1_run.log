            tauto
          }
      have h4 : (Finset.range k).gcd (fun i => Nat.choose ((i + 2) * k) k) = 1 := by
        have h5 : let P := ((Nat.divisors k).filter IsPrimePow).max.getD 0
          k / P > P := h
        have h6 : (Finset.range k).gcd (fun i => Nat.choose ((i + 2) * k) k) = k := h3
        omega
      omega
    have h2 : (Finset.range k).gcd (fun i => Nat.choose ((i + 2) * k) k) = 1 := by
      have h3 : ¬ k.IsPrimePow := h1
