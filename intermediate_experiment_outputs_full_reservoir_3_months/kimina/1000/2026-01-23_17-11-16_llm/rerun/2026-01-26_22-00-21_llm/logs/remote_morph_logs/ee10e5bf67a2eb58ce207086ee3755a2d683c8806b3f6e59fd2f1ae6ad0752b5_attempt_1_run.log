import Mathlib
open Finset

noncomputable abbrev PartInterpolant (X : Sequent) : Type :=
  ∃ θ : Subtype (Vocab X) → Prop, (∀ v ∈ X.voc, θ (v.toSubtype X)) ∧
    (∀ (v₁ v₂ : Subtype (Vocab X)), v₁ ≠ v₂ → v₁ ∈ X.voc → v₂ ∈ X.voc →
      (θ v₁ → θ v₂) ∧ (θ v₂ → θ v₁))

noncomputable abbrev IsPartInterpolant (X : Sequent) : Prop :=
  ∃ θ : Subtype (Vocab X) → Prop, (∀ v ∈ X.voc, θ v) ∧
    (∀ (v₁ v₂ : Subtype (Vocab X)), v₁ ≠ v₂ → v₁ ∈ X.voc → v₂ ∈ X.voc →
      (θ v₁ → θ v₂) ∧ (θ v₂ → θ v₁))

noncomputable abbrev Interpolant (X : Sequent) : Type :=
  (IsPartInterpolant X) → PartInterpolant X

/-! The following lemma about `PartInterpolant` is here because it is used by `freePdlRuleInterpolant`. -/
lemma partInterpolant_of_isPartInterpolant {X} {θ : Subtype (Vocab X) → Prop} (h : IsPartInterpolant X) : PartInterpolant X :=
  ⟨θ, h.1, fun v₁ v₂ hv₁ hv₂ h₁₂ h₂₁ => ⟨h₁₂, h₂₁⟩⟩

