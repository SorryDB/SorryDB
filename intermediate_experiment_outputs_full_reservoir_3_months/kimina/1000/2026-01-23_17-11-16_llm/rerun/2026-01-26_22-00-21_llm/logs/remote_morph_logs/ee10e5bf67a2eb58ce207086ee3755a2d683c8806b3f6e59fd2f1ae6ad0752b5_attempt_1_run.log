/-! Definition 7.25: Exits of a Tableau

The function `exitsOf` determines the set of paths that can be taken from a given state in a game-theoretic interpretation of a logical formula. In the context of a proof, it defines the set of paths from a given state that lead to a contradiction.

Given a history `H`, a pair of formula lists `(L, R)`, and a negation of a load formula `nlf`, this function determines the set of paths in a tableaux structure that lead to a contradiction when trying to prove `False` from the given context.

The definition of `exitsOf` is recursive and depends on the structure of the tableaux:
- If the current state is a repeat (`lrep`), there are no exits.
- If the current state is a local tableaux (`loc`), exits are computed based on the local structure and the exits of the remaining tableaux.
- If the current state is a PDL rule application (`pdl`), exits are computed based on the rules and the exits of the remaining tableaux.

Specifically:
- For a state `lrep`, the list of exits is `[ ]`.
- For a state `loc nrep nbas lt next`, the list of exits is computed using `match` statements on the structure of the local formula `Y` (which is `⟨LY, RY, nlf⟩`):
    - If `Y` is not basic (i.e., `nlf = some _`), then exits are computed based on `endNodesOf lt`.
    - If `Y` is basic (i.e., `nlf = none`), then exits are computed based on `endNodesOf lt`.
- For a state `pdl Y bas r nrep next`, the list of exits is computed based on the PDL rules and the exits of the remaining tableaux.

The full definition is quite complex, involving many `match` statements and conditional logic based on the structure of the formulas and tableaux.

```tactics
import Mathlib
open Lean4

/-! Definition 7.25: Exits of a Tableau

Given a history `H`, a pair of formula lists `(L, R)`, and a negation of a load formula `nlf`, this function determines the set of paths in a tableaux structure that lead to a contradiction when trying to prove `False` from the given context. The definition is recursive and depends on the structure of the tableaux.

Specifically:
- If the current state is a repeat (`lrep`), there are no exits.
- If the current state is a local tableaux (`loc`), exits are computed based on the local structure and the exits of the remaining tableaux.
- If the current state is a PDL rule application (`pdl`), exits are computed based on the PDL rules and the exits of the remaining tableaux.

The full definition is quite complex, involving many `match` statements and conditional logic based on the structure of the formulas and tableaux.
-/
def exitsOf (H : List (Sequent × Subtype Prop)) (L R : List Formula) (nlf : NegLoadFormula ⊕ NegLoadFormula)
    (tab : Tableau H (L, R, some nlf)) : List (PathIn tab) :=
  match tab with
  | .lrep _ => [] -- A repeat has no exit!
  | .loc nrep nbas lt next =>
    let Y := lt.1
    let Y_in := Y ∈ endNodesOf lt
    match Y with
    | ⟨LY, RY, nlfY⟩ =>
      match nlfY with
      | none => -- Y is basic
        let Y_in' : Y ∈ endNodesOf lt := by
          simpa using Y_in
        let e := (PathIn.loc Y_in' .nil)
        let e_in : e ∈
          if (Y).isLoaded = true then
            @exitsOf.match_2 (List.map Sequent.flip H) (Sequent.flip (L, R, some (Sum.inl nlf)))
              (fun tab => List (PathIn tab)) (Tableau.loc nrep nbas lt next) (fun lpr => [])
              (fun nrep nbas lt next =>
                List.flatMap
                  (fun x =>
                    @exitsOf.match_1 (Sequent.flip (L, R, some (Sum.inl nlf))) lt
                      (fun x => List (PathIn (Tableau.loc nrep nbas lt next))) x fun Y Y_in =>
                    List.map (PathIn.loc Y_in)
                      (exitsOf (Sequent.flip (L, R, some (Sum.inl nlf)) :: List.map Sequent.flip H) Y (next Y Y_in)))
                  (endNodesOf lt).attach)
              fun Y nrep bas r next =>
              List.map PathIn.pdl (exitsOf (Sequent.flip (L, R, some (Sum.inl nlf)) :: List.map Sequent.flip H) Y next)
            else [PathIn.nil] := by
          simp [Y]
          tauto
        simp [e, e_in]
      | some nlfY' => -- Y is not basic
        let Y_in' : Y ∈ endNodesOf lt := by
          simpa using Y_in
        let e := (PathIn.loc Y_in' .nil)
        let e_in : e ∈
          if (Y).isLoaded = true then
            @exitsOf.match_2 (List.map Sequent.flip H) (Sequent.flip (L, R, some (Sum.inl nlf)))
              (fun tab => List (PathIn tab)) (Tableau.loc nrep nbas lt next) (fun lpr => [])
              (fun nrep nbas lt next =>
                List.flatMap
                  (fun x =>
                    @exitsOf.match_1 (Sequent.flip (L, R, some (Sum.inl nlf))) lt
                      (fun x => List (PathIn (Tableau.loc nrep nbas lt next))) x fun Y Y_in =>
                    List.map (PathIn.loc Y_in)
                      (exitsOf (Sequent.flip (L, R, some (Sum.inl nlf)) :: List.map Sequent.flip H) Y (next Y Y_in)))
                  (endNodesOf lt).attach)
              fun Y nrep bas r next =>
              List.map PathIn.pdl (exitsOf (Sequent.flip (L, R, some (Sum.inl nlf)) :: List.map Sequent.flip H) Y next)
            else [PathIn.nil] := by
          simp [Y]
          tauto
        simp [e, e_in]
  | .pdl Y bas r nrep next =>
    let e := (PathIn.pdl Y (next Y Y_in))
    let e_in : e ∈
      if (Y).isLoaded = true then
        @exitsOf.match_2 (List.map Sequent.flip H) (Sequent.flip (L, R, some (Sum.inr nlf)))
          (fun tab => List (PathIn tab)) (Tableau.pdl Y bas r nrep next) (fun lpr => [])
          (fun nrep nbas lt next =>
            List.map
              (fun x => List (PathIn (Tableau.pdl Y bas r nrep next))) x fun Y Y_in =>
            List.map (PathIn.loc Y_in) (exitsOf (Sequent.flip (L, R, some (Sum.inr nlf)) :: List.map Sequent.flip H) Y (next Y Y_in)))
          fun Y nrep bas r next =>
          List.map (fun x => List (PathIn (Tableau.pdl Y bas r nrep next))) x fun Y Y_in =>
          List.map (PathIn.loc Y_in) (exitsOf (Sequent.flip (L, R, some (Sum.inr nlf)) :: List.map Sequent.flip H) Y (next Y Y_in)))
        else [PathIn.nil] := by
      simp [Y]
      tauto
    simp [e, e_in]

