    simp only [Xload, ↓reduceIte] at q_in
    cases tab <;> simp at q_in <;> grind
  · intro no_nil
    unfold exitsOf at no_nil
    simp only [Xload, ↓reduceIte, List.mem_filter, List.mem_nil, iff_false] at no_nil
    simp only [Xload, ↓reduceIte, List.mem_filter, List.mem_nil, iff_false]
    simp only [Xload, ↓reduceIte, List.mem_filter, List.mem_nil, iff_false]
    simp at no_nil
    cases tab <;> simp at no_nil <;> try { tauto } <;> try { simp_all } <;> try { tauto }
    <;> try { exfalso <;> tauto }

