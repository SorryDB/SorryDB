import Mathlib
open Finset

/-! This file contains lemmas about the relationship between a tableaux and its flipped version, specifically concerning the `exitsOf` function.

/-! The lemma `mem_existsOf_of_flip` states that if a path `s` is an exit of a tableaux `tab.flip`, then the path `s'` obtained by flipping `s` (where `s'` is the path from `s_in` in the `exitsOf` definition for `tab.flip`) is an exit of `tab`.

lemma mem_existsOf_of_flip {Hist L R lr_nlf} {tab : Tableau Hist (L, R, some lr_nlf)}
    (s : PathIn tab.flip) (s_in : s ∈ (exitsOf tab.flip : List (PathIn tab.flip)))
    : (PathIn_type_flip_flip ▸ s.flip) ∈ exitsOf tab := by
  rcases s_in with (s_in | s_in)
  · -- Case where s_in is a root path
    simp only [List.mem_singleton] at s_in
    rcases s_in with ⟨Yf, Yf_in, e, e_in, def_s⟩
    rcases exists_flip_of_endNodesOf Yf_in with ⟨Y, def_Yf, Y_in⟩
    subst def_Yf def_s
    rcases Y with ⟨LY, RY, (_|lr_nlf_Y)⟩
    · simp [Sequent.flip] at e e_in
      simp_all [Sequent.isLoaded, decide_eq_false, Olf.isNone, Olf.isSome, endNodesOf]
      <;> try { aesop }
      <;> try { native_decide }
    · simp [Sequent.flip] at e e_in
      simp_all [Sequent.isLoaded, decide_eq_false, Olf.isNone, Olf.isSome, endNodesOf]
      <;> try { aesop }
      <;> try { native_decide }
  · -- Case where s_in is a path
    simp only [List.mem_attach, List.mem_map, true_and] at s_in
    rcases s_in with ⟨Yf, Yf_in, e, e_in, def_s⟩
    rcases exists_flip_of_endNodesOf Yf_in with ⟨Y, def_Yf, Y_in⟩
    subst def_Yf def_s
    rcases Y with ⟨LY, RY, (_|lr_nlf_Y)⟩
    · simp [Sequent.flip] at e e_in
      simp_all [Sequent.isLoaded, decide_eq_false, Olf.isNone, Olf.isSome, endNodesOf]
      <;> try { aesop }
      <;> try { native_decide }
    · simp [Sequent.flip] at e e_in
      simp_all [Sequent.isLoaded, decide_eq_false, Olf.isNone, Olf.isSome, endNodesOf]
      <;> try { aesop }
      <;> try { native_decide }
