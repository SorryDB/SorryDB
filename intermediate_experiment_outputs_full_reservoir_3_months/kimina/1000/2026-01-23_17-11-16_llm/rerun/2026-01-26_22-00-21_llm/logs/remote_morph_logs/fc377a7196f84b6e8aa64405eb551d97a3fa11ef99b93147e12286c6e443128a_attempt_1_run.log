    Algebra 𝒪[K] 𝒪[L] where
  algebraMap := {
    toFun r := ⟨(algebraMap K L) ↑r, sorry⟩ -- there is probably a better approach to this instance
    map_add' := sorry
    map_one' := sorry
    map_mul' := sorry
    map_zero' := sorry
