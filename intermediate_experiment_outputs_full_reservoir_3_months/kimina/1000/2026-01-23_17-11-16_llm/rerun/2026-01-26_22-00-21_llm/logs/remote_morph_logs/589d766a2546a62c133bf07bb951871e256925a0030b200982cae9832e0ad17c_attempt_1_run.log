import Mathlib

open Finset

namespace ContextFreeDerivation

structure CollectDerivationTreeNodesState α nt G u v
  {u' : Word (G.V ⊕ G.Z)}
  {dstep : G.ContextFreeDerivationStep u}
  {derivation : ContextFreeDerivation α nt G u' v}
  {sound : dstep.result = u'}
  {h_exhaustive : derivation.exhaustiveCondition}
  {h_not_same : u ≠ v}
  {h_constructor_cfd : derivation = ContextFreeDerivation.step α nt G u u' v dstep derivation sound}
  {rightSide : dstep.prod.val.rhs}
  {allChildren : List (DerivationTree G × { x // x ∈ Finset.range (u'.len) })}
  {u_comp : dstep.pre.len + (Word.mk [Sum.inl (↑dstep.prod).lhs]).len + dstep.suf.len = u.len}
  {var_len_1 : (Word.mk [Sum.inl (↑dstep.prod).lhs]).len = 1}
  {pre_len_less_u_len : dstep.pre.len < u.len}
  {suf_len_less_u_len : dstep.suf.len < u.len}
  {leftOfVarCount : Finset.range u.len}
  {rightOfVarCount : Finset.range u.len}
  {rhs_symbol_count : ℕ}
  {u'_eq_result : dstep.result = u'}
  {h_num_vars_rhs : (↑dstep.prod).rhs.len = n + 1}
  {h_rhs_non_empty : 1 ≤ (↑dstep.prod).rhs.len}
  {h_u_vs_u'_len : u'.len = u.len + (rhs_symbol_count - 1)}
  {h_u_vs_u'_len₂ : u.len ≤ u'.len}
  {u_range_subset_u'_range : Finset.range u.len ⊆ Finset.range u'.len}
  {leftOfVarCount₂ : Finset.range u'.len}
  {index₁ : Finset.range u'.len}
  {h_index_valid : ∃ location ∈ allChildren, location.2 = index₁}
  {afunc : List (DerivationTree G × { x // x ∈ Finset.range u'.len }) → (DerivationTree G × { x // x ∈ Finset.range u'.len }) → List (DerivationTree G × { x // x ∈ Finset.range u'.len }) := fun prev (DT , index₂) => if index₁ = index₂ then prev ++ [(DT, index₂)] else prev}
  {afuncDef : afunc = fun prev (DT , index₂) => if index₁ = index₂ then prev ++ [(DT, index₂)] else prev}
  {a : List (DerivationTree G × { x // x ∈ Finset.range u'.len }) := List.foldl afunc [] allChildren}
  {aDef : a = List.foldl afunc [] allChildren}
  {afunc_monotone : ∀ list₁ list₂ : List (DerivationTree G × { x // x ∈ Finset.range u'.len }), list₁ ≠ [] → List.foldl afunc list₁ list₂ ≠ [] := by
    intro list₁ list₂
    induction list₁ with
    | nil =>
      simp
      <;> tauto
    | cons head tail ih =>
      induction list₂ with
      | nil =>
        simp at ih ⊢
        <;> tauto
      | cons head₂ tail₂ ih₂ =>
        intro h_neq
        by_cases h_pos₁ : tail₁ ≠ []
        case pos =>
          by_cases h_pos₂ : tail₂ ≠ []
          case pos =>
