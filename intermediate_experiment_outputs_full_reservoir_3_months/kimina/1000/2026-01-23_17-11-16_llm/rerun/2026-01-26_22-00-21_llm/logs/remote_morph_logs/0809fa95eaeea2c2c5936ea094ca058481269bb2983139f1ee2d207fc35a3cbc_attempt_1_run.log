  -- We just need to apply it
  apply isFilterComplete_cohomology_eq_zero_of_all_quotients_zero
  -- Use the hypothesis that all the quotient cohomologies are zero
  intro i
  -- Apply the hypothesis
  exact (M_ i).toSubmodule.cohomology_eq_zero
