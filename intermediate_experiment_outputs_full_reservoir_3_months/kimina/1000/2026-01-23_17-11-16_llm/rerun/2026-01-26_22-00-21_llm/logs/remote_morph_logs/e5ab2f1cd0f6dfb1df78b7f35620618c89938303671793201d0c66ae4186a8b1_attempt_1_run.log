    have h6 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₂ * H₄) := by
      apply MDifferentiable.mul
      · exact differentiable_const 5
      · apply MDifferentiable.mul
        · exact h1
        · exact h2
    have h7 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (5 * H₄ ^ 2) := by
      apply MDifferentiable.mul
      · exact differentiable_const 5
      · apply MDifferentiable.pow
        exact h2
    apply MDifferentiable.add
    · apply MDifferentiable.add
      · exact h5
      · exact h6
    · exact h7
  have h8 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) G := by
