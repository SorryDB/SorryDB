    exact h1
  have h4 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2 + 5 * H₂ * H₄ + 5 * H₄ ^ 2) := by
    have h5 : MDifferentiable 𝓘(ℂ) 𝓘(ℂ) (2 * H₂ ^ 2) := by
