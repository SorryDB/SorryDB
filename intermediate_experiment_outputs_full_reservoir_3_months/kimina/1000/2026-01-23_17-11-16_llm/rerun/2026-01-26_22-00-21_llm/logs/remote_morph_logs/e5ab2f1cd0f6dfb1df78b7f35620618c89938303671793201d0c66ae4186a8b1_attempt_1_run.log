      apply Differentiable.mul
      · -- Show that 2 is differentiable
        apply differentiable_const
      · -- Show that H₂ ^ 2 is differentiable
        apply Differentiable.pow
        exact h7
    have h10 : MDifferentiable 𝚜(ℂ) 𝚜(ℂ) (5 * H₂ * H₄) := by
