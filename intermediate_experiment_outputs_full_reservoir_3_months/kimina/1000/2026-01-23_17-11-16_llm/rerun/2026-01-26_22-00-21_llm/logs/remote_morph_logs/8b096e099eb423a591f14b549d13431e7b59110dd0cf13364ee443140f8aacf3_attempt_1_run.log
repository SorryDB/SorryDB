theorem MeasureTheory.ringHaarChar_adeles_units_eq_one (x : (V ⊗[ℚ] (𝔸 ℚ))ˣ) :
  ringHaarChar x = 1 := by
  have h1 : x = ((x).1, (x).2) := by
    have h2 : (V ⊗[ℚ] (InfiniteAdeleRing ℚ)) = V ⊗[ℚ] (InfiniteAdeleRing ℚ) := rfl
    have h5 : ((V ⊗[ℚ] (InfiniteAdeleRing ℚ))ˣ) ×
        (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
          [(V ⊗[ℚ] (v.adicCompletion ℚ))ˣ,
