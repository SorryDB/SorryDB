noncomputable def c_infty_alg :
    IntegralLattice ℤ ℚ V ⊗[ℤ] (InfiniteAdeleRing ℚ) ≃ₗ[InfiniteAdeleRing ℚ]
    V ⊗[ℚ] (InfiniteAdeleRing ℚ) :=
