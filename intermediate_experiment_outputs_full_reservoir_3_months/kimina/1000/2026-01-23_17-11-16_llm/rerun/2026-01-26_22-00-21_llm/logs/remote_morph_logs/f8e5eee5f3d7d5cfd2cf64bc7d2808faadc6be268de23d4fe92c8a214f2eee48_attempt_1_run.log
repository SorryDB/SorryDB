/-!
The sheaf of differential k-forms on a general topological space, using the standard
atlas of Euclidean charts.
-/
noncomputable def ΩStandardSheaf {k : ℕ} : StandardSheaf (fun (X : TopologicalSpace) ↦ (X.univ [⋀^k] →ₗ[ℝ] ℝ)) :=
  { val := fun {n} s ↦ {
      map := fun {n m} f => {
        map := fun (ω : DSmoothMap (Eucl n) ((Eucl n) [⋀^k] →ₗ[ℝ] ℝ)) =>
          fun x => (ω (f x)).compLinearMap ((f.differentiableAt x).deriv.toLinearMap)
      }
    }
  }
  map_id := by
    ext n
    simp
  map_comp := by
    ext n m p
    simp
    all_goals try { aesop }
    all_goals try { tauto }
    all_goals try { aesop }
    all_goals try { tauto }
}

