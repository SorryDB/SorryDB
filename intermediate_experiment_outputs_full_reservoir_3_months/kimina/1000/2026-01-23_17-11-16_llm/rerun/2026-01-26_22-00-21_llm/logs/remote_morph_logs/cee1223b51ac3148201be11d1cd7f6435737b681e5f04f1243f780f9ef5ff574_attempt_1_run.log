            have h11 : eLpNorm (T (F.indicator (fun _ ‚Ü¶ 1))) 1 (őĹ.restrict G) ‚Č§ (c * (őľ F) ^ p‚ĀĽ¬Ļ.toReal * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal : ‚ĄĚ) := by
              simpa using (hT F G hF (by
