    (p_ne_zero : p ‚Č† 0) (p_ne_top : p ‚Č† ‚ä§) (p'_ne_zero : p' ‚Č† 0) (p'_ne_top : p' ‚Č† ‚ä§)
    {őľ : Measure őĪ} {őĹ : Measure őĪ'} {c : ‚ĄĚ‚Č•0} (c_pos : 0 < c) (hT : HasRestrictedWeakType T p p' őľ őĹ c)
    : --(h_zero : ‚ąÄ {f : őĪ ‚Üí ő≤}, ) :
  ‚ąÄ (F : Set őĪ) (G : Set őĪ'), (MeasurableSet F) ‚Üí (MeasurableSet G) ‚Üí
    eLpNorm (T (F.indicator (fun _ ‚Ü¶ 1))) 1 (őĹ.restrict G)
      ‚Č§ c * (őľ F) ^ p‚ĀĽ¬Ļ.toReal * (őĹ G) ^ p'‚ĀĽ¬Ļ.toReal := by
  intro F G hF hG
