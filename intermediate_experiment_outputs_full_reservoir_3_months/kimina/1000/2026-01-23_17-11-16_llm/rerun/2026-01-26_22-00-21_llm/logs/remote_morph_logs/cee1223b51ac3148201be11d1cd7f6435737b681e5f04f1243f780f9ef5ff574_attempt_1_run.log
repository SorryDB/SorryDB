variable [TopologicalSpace őĶ] [ENormedAddMonoid őĶ]
/-- A function is in the Lorentz space L_{pr} if it is (strongly a.e.)-measurable and has finite Lorentz norm. -/
def MemLorentz (f : őĪ ‚Üí őĶ) (p r : ‚ĄĚ‚Č•0‚ąě) (őľ : Measure őĪ) : Prop :=
  AEStronglyMeasurable f őľ ‚ąß eLorentzNorm f p r őľ < ‚ąě

lemma MemLorentz_iff_MemLp {f : őĪ ‚Üí őĶ'} :
    MemLorentz f p p őľ ‚ÜĒ MemLp f p őľ := by
  unfold MemLorentz MemLp
  constructor
  ¬∑ intro h
    rwa [‚Üź eLorentzNorm_eq_eLpNorm h.1]
  ¬∑ intro h
    rwa [eLorentzNorm_eq_eLpNorm h.1]


