  unfold HasStrongType HasLorentzType
  constructor
  ¬∑ intro h f hf
    unfold MemLp MemLorentz at *
    rw [eLorentzNorm_eq_eLpNorm hf.1] at *
    have := h f hf
    rwa [eLorentzNorm_eq_eLpNorm this.1]
  ¬∑ intro h f hf
    unfold MemLp MemLorentz at *
    rw [‚Üź eLorentzNorm_eq_eLpNorm hf.1] at *
