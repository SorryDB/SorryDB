def exitsOf (tab : Tableau .nil X) : List (PathIn tab) :=
  if X.isLoaded
  then
    match tab with
    | .lrep _ => [] -- A repeat has no exit! (To ensure termination we do not rewrite here.)
    | .loc nrep nbas lt next => (endNodesOf lt).attach.flatMap (fun ⟨Y,Y_in⟩ =>
                                  (exitsOf (next Y Y_in)).map (fun ⟨Z,Z_in⟩ => PathIn.loc Y_in Z))
    | .pdl Y bas r nrep next => (exitsOf next).map (fun ⟨Z,Z_in⟩ => PathIn.pdl Y Z)
  else
    [ .nil ] -- Free nodes are their own (and the only kind of exits.

