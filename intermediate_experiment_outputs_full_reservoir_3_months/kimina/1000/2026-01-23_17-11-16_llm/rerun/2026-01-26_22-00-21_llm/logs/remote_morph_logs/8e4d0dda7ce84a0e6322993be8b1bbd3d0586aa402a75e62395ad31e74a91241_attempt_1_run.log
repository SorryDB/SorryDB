      simp_all [Sequent.isLoaded, decide_true, Option.map_some, Sum.swap_inl, Tableau.flip, List.mem_map, List.mem_attach, List.mem_singleton, List.mem_map]
      <;> try { tauto }
      <;> try { aesop }
      <;> try { native_decide }
    simp [Sequent.flip] at *
    unfold Olf.flip at *
    simp_all [Sequent.isLoaded, decide_true, Option.map_some, Sum.swap_inl, Tableau.flip, List.mem_map, List.mem_attach, List.mem_singleton, List.mem_map]
    <;> try { tauto }
    <;> try { aesop }
    <;> try { native_decide }

    case lrep =>
      simp [Sequent.isLoaded, Sequent.flip, Olf.flip] at *
      simp_all [Tableau.flip]

  · -- other `nlf` side, should be analogous.
    sorry
