    | cons x xs ih =>
      simp only [List.mem_cons, List.mem_singleton]
      intro p hp
      rcases hp with (hp | hp)
      · simp only [List.mem_singleton] at hp
        rw [hp]
        exact ih rfl
      · simp only [List.mem_cons] at hp
        rcases hp with (hp | hp)
        · exact ih hp
        · exact ih hp
