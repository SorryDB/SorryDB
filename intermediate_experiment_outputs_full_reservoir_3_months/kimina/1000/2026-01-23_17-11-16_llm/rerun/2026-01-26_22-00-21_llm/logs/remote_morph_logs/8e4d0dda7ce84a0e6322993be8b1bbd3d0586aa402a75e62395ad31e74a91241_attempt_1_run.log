  unfold exitsOf at s_in ⊢
  simp only [isLoaded, endNodesOf, List.mem_cons, List.mem_singleton, List.mem_nil, true_and, 
    and_true, iff_true] at s_in ⊢
  rcases s_in with (⟨Yf, Yf_in, e, e_in, def_s⟩ | ⟨e, e_in, def_s⟩)
  · -- Case 1: s is a path in a local tableaux of tab.flip
    simp only [def_s] at *
    rcases e_in with (⟨Y, Y_in, e', e'_in, def_e⟩ | ⟨e', e'_in, def_e⟩)
    · -- Case 1.1: e is a path in a local tableaux of next Y Y_in
      simp only [def_e] at *
      rcases e'_in with (⟨Y', Y'_in, e'', e''_in, def_e'⟩ | ⟨e'', e''_in, def_e'⟩)
