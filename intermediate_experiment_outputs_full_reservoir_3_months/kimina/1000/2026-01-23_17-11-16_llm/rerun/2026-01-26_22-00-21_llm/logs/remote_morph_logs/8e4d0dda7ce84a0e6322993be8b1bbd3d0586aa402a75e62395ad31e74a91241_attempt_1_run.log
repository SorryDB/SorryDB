    (∃ (φ : Formula), (x : Vocab) = (φ : Vocab) ∧
    (∃ (Δ : Sequent), Δ = (x : Vocab) ∧
    (∃ (I : Finset Vocab), I = {x} ∧
    (∃ (J : Finset Vocab), J = (∅ : Finset Vocab) ∧
    (∃ (K : Finset Vocab), K = (∅ : Finset Vocab) ∧
    (x : Vocab) ∈ Δ ∧
    (x : Vocab) ∉ I ∧
    (x : Vocab) ∉ J ∧
    (x : Vocab) ∉ K ∧
    (∀ (y : Vocab), y ∈ formulaVocab →
    ((y ∈ I ↔ y ∈ K) ∧ (y ∈ J ↔ y ∈ K)) ∧
    (y ∈ formulaVocab → y ∈ K ↔ y ∈ I)) ∧
    (∀ (y : Vocab), y ∈ formulaVocab →
    (y ∈ I ↔ y ∈ K) ∧ (y ∈ J ↔ y ∈ K)) ∧
    (y ∈ formulaVocab → y ∈ K ↔ y ∈ I)) ∧
    (∀ (y : Vocab), y ∈ formulaVocab →
