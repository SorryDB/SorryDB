  rcases s_in with ⟨Yf, Yf_in, e, e_in, def_s⟩
  rcases exists_flip_of_endNodesOf Yf_in with ⟨Y, def_Yf, Y_in⟩
  subst def_Yf def_s
  rcases Y with ⟨LY, RY, (_|lr_nlf_Y)⟩
  · simp [Sequent.flip] at e
    simp_all [Sequent.isLoaded, decide_true, Olf.flip, Option.map_some, Sum.swap_inl, Tableau.flip, List.mem_map, List.mem_attach, List.mem_singleton, List.mem_map]
