    have h5 : x ⊢ ¬(φ → ψ) := by
      simpa using h₁
    have h6 : x ⊢ ¬((φ → ψ) → φ) := by
      simpa using h₂
    have h7 : x ⊢ ¬φ := by
      have h8 : x ⊢ ¬(φ → ψ) := h5
      have h9 : x ⊢ ¬((φ → ψ) → φ) := h6
      have h10 : x ⊢ (φ → ψ) := by
        have h11 : x ⊢ ¬((φ → ψ) → φ) := h6
        have h12 : x ⊢ (φ → ψ) ∨ x ⊢ ¬φ := by 
