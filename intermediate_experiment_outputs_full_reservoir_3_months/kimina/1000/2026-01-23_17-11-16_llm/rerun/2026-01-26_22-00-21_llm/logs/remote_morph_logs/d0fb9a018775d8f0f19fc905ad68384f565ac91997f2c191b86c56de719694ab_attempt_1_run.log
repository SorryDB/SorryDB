@[grind →] lemma p_connected' [F.IsPiecewiseConnected] : ∀ {x y z : F}, x ≺ y → x ≺ z → y ≠ z → y ≺ z ∨ z ≺ y := by apply IsPiecewiseConnected.p_connected'

