          have h16 : x ⊢ ¬φ := h14
          tauto
      have h11 : x ⊢ ¬(φ → ψ) := h8
      have h12 : x ⊢ ¬(φ → ψ) := h8
      tauto
    tauto
  exfalso; tauto
