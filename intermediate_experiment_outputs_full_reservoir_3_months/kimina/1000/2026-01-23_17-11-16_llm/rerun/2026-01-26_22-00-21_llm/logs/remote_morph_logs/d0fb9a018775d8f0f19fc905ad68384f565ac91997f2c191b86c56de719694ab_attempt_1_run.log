            have h18 : x ⊢ ¬(φ → ψ) := h4
            have h19 : x ⊢ ¬(φ → ψ) := h4
            have h20 : x ⊢ ¬(φ → ψ) := h4
            have h21 : x ⊢ ¬(φ → ψ) := h4
            have h22 : x ⊢ ¬(φ → ψ) := h4
            have h23 : x ⊢ ¬(φ → ψ) := h4
            have h24 : x ⊢ ¬(φ → ψ) := h4
