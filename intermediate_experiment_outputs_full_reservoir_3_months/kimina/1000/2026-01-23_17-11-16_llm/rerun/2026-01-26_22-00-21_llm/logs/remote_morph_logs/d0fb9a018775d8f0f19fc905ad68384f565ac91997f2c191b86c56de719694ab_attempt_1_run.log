            have h26 : x ⊢ ¬(φ → ψ) := h4
            have h27 : x ⊢ ¬(φ → ψ) := h4
            have h28 : x ⊢ ¬(φ → ψ) := h4
            have h29 : x ⊢ ¬(φ → ψ) := h4
