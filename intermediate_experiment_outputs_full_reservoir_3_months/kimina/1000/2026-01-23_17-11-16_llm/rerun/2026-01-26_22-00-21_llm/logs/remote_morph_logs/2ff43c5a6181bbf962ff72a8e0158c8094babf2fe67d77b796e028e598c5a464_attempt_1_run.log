    intro i hi
    have hy := h_qY_bounds i hi
    scalar_tac
  · -- Goal 3: Precondition for `Z`
    intro i hi
    have hz := h_qZ_bounds i hi
    scalar_tac
  · -- Goal 4: Precondition for `q.X+q.Y`
    intro i hi
    have hx := h_qX_bounds i hi
    have hy := h_qY_bounds i hi
    scalar_tac
  · -- Goal 5: Precondition for `X_plus_Y`
