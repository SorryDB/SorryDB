  let Xc := (2 * q.X * q.Y).mod p
  let Yc := (q.Y ^ 2 + q.X ^ 2).mod p
  let Zc := (q.Y ^ 2 - q.X ^ 2).mod p
  let Tc := (2 * q.Z ^ 2 - q.Y ^ 2 + q.X ^ 2).mod p

  have hc : some ⟨Xc, Yc, Zc, Tc, hc⟩ = ok (some ⟨Xc, Yc, Zc, Tc, hc⟩) := by
    simp [Xc, Yc, Zc, Tc]
