noncomputable inductive ContextFreeDerivation (α : Sort u) {nt : Sort v} [DecidableEq α] [DecidableEq nt] {G : ContextFreeGrammar α nt} (u : Word (G.V ⊕ G.Z)) (v : Word (G.V ⊕ G.Z)) :
