import Mathlib

/- A derivation in a context-free grammar consists of a sequence of derivation steps, starting from an initial word and transforming it step-by-step until a final word is reached. Each step involves applying a production rule from the grammar. This data structure represents such a sequence of steps.-/
noncomputable inductive ContextFreeDerivationStep (α : Sort u) {nt : Sort v} [DecidableEq α] [DecidableEq nt] {G : ContextFreeGrammar α nt} (u : Word (G.V ⊕ G.Z)) :
  G.ContextFreeDerivationStep u :=
  | applyRule (r : G.productions) (h : u = r.lhs) (h' : r.rhs ≠ []) =>
    -- Apply a production rule `r` to the current word `u`.
    -- This requires `u` to be equal to the left-hand side of the rule `r`.
    -- It also requires the right-hand side of the rule `r` to be non-empty.
    -- The result of this step is the word obtained by substituting `r.rhs` for `r.lhs` in `u`.
    let u' := u.subst r
    {
      stepType := "applyRule"
      rule := r
      result := u'
      -- We need to prove that u' is indeed the result of applying the rule r to u
      -- This follows directly from the definition of substitution.
      proof : u' = u.subst r := rfl
      -- We need to prove that the substitution is valid, i.e., u = r.lhs
      substitutionValid : u = r.lhs := h
      -- We need to prove that the right-hand side is non-empty
      rhsNonEmpty : r.rhs ≠ [] := h'
    }
  | reduceStep (h : u = []) =>
    -- Reduce the current word `u` to the empty word `[]`.
    -- This step is valid if `u` is already the empty word.
    {
      stepType := "reduceStep"
      result := []
      proof : u = [] := h
    }
