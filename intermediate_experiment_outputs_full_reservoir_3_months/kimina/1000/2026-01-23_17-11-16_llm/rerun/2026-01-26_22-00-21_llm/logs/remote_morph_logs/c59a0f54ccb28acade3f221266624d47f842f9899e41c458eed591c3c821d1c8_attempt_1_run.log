    ∃ deriv₁ : ContextFreeDerivation cfg_CNF.1 u u',
    ∃ deriv₂ : ContextFreeDerivation cfg_CNF.1 u' u'',
    ∃ deriv₃ : ContextFreeDerivation cfg_CNF.1 u'' v,
    Sum.inl var ∈ u' ∧ Sum.inl var ∈ u'' := by
  sorry

