import Mathlib

open ContextFree

/- The pumping lemma for context-free languages states that for any context-free
  language L, there exists a natural number n such that for any z in L with
  z.length ≥ n, there exist u, v, w, x, y such that z = uvwxy, v*x.length ≥ 1,
  v*w*x.length ≤ n, and uv^kwx^ky is in L for all k. -/
theorem PumpingLemma :
  ∀ language : ContextFreeLanguage, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧
  Word.len (v * w * x) ≤ n ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
  intro language
```

