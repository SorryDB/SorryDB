theorem equivalent_CNF_Grammar :
  ∀ α nt nt₂,
  ∀ cfg : {cfg : ContextFreeGrammar α nt | ε ∉ cfg.GeneratedLanguage},
  ∃ cfg₂ : { cfg₂ : ContextFreeGrammar α nt₂ // isInChomskyNormalForm cfg₂},
