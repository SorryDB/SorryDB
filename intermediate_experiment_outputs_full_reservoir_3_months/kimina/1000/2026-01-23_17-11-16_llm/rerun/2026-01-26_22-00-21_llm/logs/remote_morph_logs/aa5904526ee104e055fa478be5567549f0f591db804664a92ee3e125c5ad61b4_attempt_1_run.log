lemma ENNReal.rpow_eq_zero_iff {p : ℝ≥0∞} {a : ℝ≥0∞} (hp_pos : 0 < p) :
    a ^ p = 0 ↔ a = 0 := by
  simp [ENNReal.rpow_eq_zero_iff, hp_pos]

lemma ENNReal.rpow_add_rpow_le_add {p : ℝ≥0∞} (a b : ℝ≥0∞) (hp1 : 1 ≤ p) :
    a ^ p + b ^ p ≤ (a + b) ^ p := by
  calc
    _ = ((a ^ p + b ^ p) ^ (1 / p)) ^ p := by
      rw [one_div, ENNReal.rpow_inv_rpow]
      linarith
    _ ≤ (a + b) ^ p := by
