import Mathlib

open Filter MeasureTheory

namespace HasLorentzType

noncomputable def eLorentzNorm (f : α → ℝ≥0) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) :=
  (∫⁻ (t : α), (f t) ^ q.toReal) ^ (1 / q.toReal) * (μ {t | f t ≠ 0}).toReal⁻¹

noncomputable def eLpNorm (f : α → ℝ≥0) (p : ℝ≥0∞) (μ : Measure α) :=
  (∫⁻ (t : α), f t ^ p.toReal) ^ (1 / p.toReal)

noncomputable def eLqNorm (f : α → ℝ≥0) (q : ℝ≥0∞) (μ : Measure α) :=
  (∫⁻ (t : α), f t ^ q.toReal) ^ (1 / q.toReal)

noncomputable def eLpNormRestrict (f : α → ℝ≥0) (p : ℝ≥0∞) (μ : Measure α) (G : Set α) :=
  (∫⁻ (t : α) in G, f t ^ p.toReal) ^ (1 / p.toReal)

noncomputable def eLqNormRestrict (f : α → ℝ≥0) (q : ℝ≥0∞) (μ : Measure α) (G : Set α) :=
  (∫⁻ (t : α) in G, f t ^ q.toReal) ^ (1 / q.toReal)

noncomputable def eLorentzNormRestrict (f : α → ℝ≥0) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (G : Set α) :=
  (∫⁻ (t : α) in G, (f t) ^ q.toReal) ^ (1 / q.toReal) * (μ {t | f t ≠ 0} ∩ G).toReal⁻¹

-- This is the definition of the eL^p norm for functions with codomain ℝ≥0∞
noncomputable def eLpNorm' (f : α → ℝ≥0∞) (p : ℝ≥0∞) (μ : Measure α) :=
  (∫⁻ (t : α), f t ^ p.toReal) ^ (1 / p.toReal)

-- This is the definition of the eL^q norm for functions with codomain ℝ≥0∞
noncomputable def eLqNorm' (f : α → ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) :=
  (∫⁻ (t : α), f t ^ q.toReal) ^ (1 / q.toReal)

-- This is the definition of the eL^p norm for functions with codomain ℝ≥0∞
noncomputable def eLpNormRestrict' (f : α → ℝ≥0∞) (p : ℝ≥0∞) (μ : Measure α) (G : Set α) :=
  (∫⁻ (t : α) in G, f t ^ p.toReal) ^ (1 / p.toReal)

-- This is the definition of the eL^q norm for functions with codomain ℝ≥0∞
noncomputable def eLqNormRestrict' (f : α → ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (G : Set α) :=
  (∫⁻ (t : α) in G, f t ^ q.toReal) ^ (1 / q.toReal)

-- This is the definition of the eL^p norm for functions with codomain ℝ≥0∞
noncomputable def eLorentzNormRestrict' (f : α → ℝ≥0∞) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (G : Set α) :=
  (∫⁻ (t : α) in G, (f t) ^ q.toReal) ^ (1 / q.toReal) * (μ {t | f t ≠ 0} ∩ G).toReal⁻¹

lemma eLpNorm_const_smul' {f : α → ℝ≥0} {a : ℝ≥0} {p : ℝ≥0∞} (ha : a ≠ ⊤) :
    eLpNorm (fun x ↦ a • f x) p μ = ‖a‖ * eLpNorm f p μ := by
