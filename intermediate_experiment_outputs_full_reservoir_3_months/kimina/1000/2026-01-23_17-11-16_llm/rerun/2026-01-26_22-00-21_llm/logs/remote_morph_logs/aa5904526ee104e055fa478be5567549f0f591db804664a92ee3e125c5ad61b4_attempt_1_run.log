/-
def HasLorentzType (T : (α → 𝕂) → (α' → ε')) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (ν : Measure α') (C : ℝ≥0) : Prop :=
  ∀ (f : α → 𝕂), (LocallyIntegrable f μ) → (AESTronglyMeasurable f μ) →
    eLpNorm (T f) 1 (ν.restrict G) ≤ C * (eLorentzNorm f p 1 μ) * (ν G) ^ q⁻¹.toReal
-/

def HasLorentzType (T : (α → 𝕂) → (α' → ε')) (p q : ℝ≥0∞) (μ : Measure α) (ν : Measure α') (C : ℝ≥0) : Prop :=
  ∀ (f : α → 𝕂) (G : Set α'), (LocallyIntegrable f μ) → (AESTronglyMeasurable f μ) →
    (MeasurableSet G) → (ν G < ⊤) →
    eLpNorm (T f) 1 (ν.restrict G) ≤ C * (eLorentzNorm f p 1 μ) * (ν G) ^ q⁻¹.toReal

/-
