theorem erdos_1064.variants.general_function (f : ℕ → ℕ)
    (hf : (fun n ↦ (f n : ℝ)) =o[atTop] (fun n ↦ (n : ℝ))) :
    {n : ℕ | φ (n - φ n) + f n < φ n}.HasDensity 1 := by
  have h1 : ∀ᶠ n in Filter.atTop, f n < n := by
    have h2 : (fun n : ℕ ↦ (f n : ℝ)) =o[atTop] (fun n : ℕ ↦ (n : ℝ)) := hf
    have h3 : ∀ᶠ n in Filter.atTop, (f n : ℝ) < (n : ℝ) := by
      apply Filter.eventually_lt_of_eventually_eq
      simpa using h2
    have h4 : ∀ᶠ n in Filter.atTop, f n < n := by
      simpa using h3
    simpa using h4
  have h4 : ∀ᶠ n in Filter.atTop, φ (n - φ n) + f n < φ n := by
    have h5 : ∀ᶠ n in Filter.atTop, f n < n := h1
    have h6 : ∀ᶠ n in Filter.atTop, φ (n - φ n) < n := by
      have h4 : ∀ n : ℕ, φ (n - φ n) ≤ n := by
        intro n
        have h5 : n - φ n ≤ n := by
          omega
        have h6 : φ (n - φ n) ≤ n - φ n := by
          apply Nat.totient_le
        have h7 : n - φ n ≤ n := by
          omega
        omega
      have h8 : ∀ᶠ n in Filter.atTop, φ (n - φ n) < n := by
        have h9 : ∀ n : ℕ, φ (n - φ n) ≤ n := h4
        apply Filter.eventually_lt_of_eventually_eq
        simpa using h9
      simpa using h8
    apply Filter.eventually_of_forall
    intro n hn
    have h8 : f n < n := by
      have h9 : ∀ᶠ n in Filter.atTop, f n < n := h1
      have h10 : f n < n := by
        simpa using h9
      linarith
    have h9 : φ (n - φ n) < n := by
      have h10 : ∀ᶠ n in Filter.atTop, φ (n - φ n) < n := h6
      have h11 : φ (n - φ n) < n := by
        simpa using h10
      linarith
    have h10 : φ n > φ (n - φ n) := by
      have h14 : n > n - φ n := by
        omega
      have h17 : φ n > φ (n - φ n) := by
        apply Nat.totient_lt_totient
        all_goals omega
      linarith
    omega
  simpa using h4
