    simp [hlt]

    have hdiff_lt : ZMod.val (input.1 + 2^n - input.2) < 2^n := by
      rw[ZMod.val_sub]
      · rw[ZMod.val_add_of_lt]
        · simp only [heq] at *
          calc
            ZMod.val input.1 + 2^n - ZMod.val input.2 <  ZMod.val input.2 + 2^n - ZMod.val input.2 := by omega
            _ = 2^n := by omega
        · have easy_lemma: 2 * 2^n = 2^(n+1) := by
            rw[pow_succ, two_mul]
            omega
