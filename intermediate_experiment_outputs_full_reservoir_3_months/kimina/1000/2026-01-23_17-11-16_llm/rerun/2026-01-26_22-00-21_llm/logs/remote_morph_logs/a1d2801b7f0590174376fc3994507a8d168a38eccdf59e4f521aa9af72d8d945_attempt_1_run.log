    simp only [← sub_eq_add_neg, Nat.testBit_eq_false_of_lt hdiff_lt, Bool.false_eq_true,
      ↓reduceIte] at h2
    rw[h2]
    simp only [neg_zero, add_zero]

    -- CASE input.1 >= input.2
    simp [hlt]
    have hdiff_ge : ZMod.val (input.1 + 2^n - input.2) >= 2^n := by
