import Mathlib

/-! ## Interpolants for proper clusters -/

/-- Helper for `exitsOf`. Or replace it fully with this? -/
def exitsOf (tab : Tableau Hist X) : List (PathIn tab) :=
  if X.isLoaded
  then
    match tab with
    | .lrep _ => [] -- A repeat has no exit! (To ensure termination we do not rewind here.)
    | .loc _ _ lt next => (endNodesOf lt).attach.flatMap (fun ⟨Y,Y_in⟩ =>
                                  (exitsOf (next Y Y_in)).map (PathIn.loc Y_in))
    | .pdl _ _ _ next => (exitsOf next).map PathIn.pdl
  else
    [ .nil ] -- Free nodes are their own (and the only kind of exits.

lemma mem_existsOf_of_flip {Hist L R lr_nlf} {tab : Tableau Hist (L, R, some lr_nlf)}
    (s : PathIn tab.flip) (s_in : s ∈ (exitsOf tab.flip : List (PathIn tab.flip)))
    : (PathIn_type_flip_flip ▸ s.flip) ∈ exitsOf tab := by
  rcases s_in with ⟨Y, Y_in, e, e_in, def_s⟩
  unfold exitsOf at * -- Simplify all exitsOf definitions
  rcases e_in with (hY | hY)
  · -- Case where e is a nil path
    simp only [List.mem_singleton, isNil, ↓reduceIte, not_true_eq_false, false_and,
      and_false] at hY
    simp [Y_in, def_s] at * -- Use Y_in and def_s
    rfl -- Goal is now trivial
  · -- Case where e is a non-nil path
    rcases hY with ⟨e_def, e_in'⟩
    -- Now prove that e.flip is an exit of tab
    -- This requires careful case analysis based on the structure of tab
    -- and the structure of s_in
    -- Example: if tab is loc, need to show e.flip is in endNodesOf lt
    -- and that (next ...).flip has e.flip as an exit
    -- The proof would involve pattern matching on the structure of `e_def`
