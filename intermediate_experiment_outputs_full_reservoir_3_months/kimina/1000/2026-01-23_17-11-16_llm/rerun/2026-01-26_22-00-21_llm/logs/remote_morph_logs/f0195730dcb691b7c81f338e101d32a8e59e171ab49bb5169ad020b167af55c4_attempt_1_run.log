import Mathlib


/-/
-- A closed loop walk is a walk that starts and ends at the same vertex.
abbrev ClosedLoopWalk (G : SimpleGraph V) := Σ u : V, G.LoopWalk u u

/-- A walk is closed if its start and end vertices are the same. -/
@[simp]
def IsClosed {u v : V} (_ : G.LoopWalk u v) : Prop := u = v


/-/
-- The length of a closed loop walk is the number of edges in the walk.
def length {p : ClosedLoopWalk G} : ℕ := (p.2).length


/-/
-- The number of vertices in a closed loop walk is the cardinality of its support set.
def vertexCount {p : ClosedLoopWalk G} : ℕ := (p.2).supportSet.card


/-/
-- The number of edges in a closed loop walk is the cardinality of its edge set.
def edgeCount {p : ClosedLoopWalk G} : ℕ := (p.2).edgeSet.card


/-/
-- The Euler characteristic of a closed loop walk is vertices - edges.
def eulerChar {p : ClosedLoopWalk G} : ℤ := vertexCount p - edgeCount p


