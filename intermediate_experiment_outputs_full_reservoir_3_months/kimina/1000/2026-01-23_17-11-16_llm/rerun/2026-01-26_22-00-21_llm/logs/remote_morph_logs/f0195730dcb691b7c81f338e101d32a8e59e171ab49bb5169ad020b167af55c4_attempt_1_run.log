-- Two closed loop walks are equivalent if one can be obtained from the other by applying a permutation of vertices.
def LoopWalkEquiv (p q : ClosedLoopWalk (K n)) : Prop :=
  ∃ (s : Equiv.Perm (Fin n)), q = ⟨s p.1, SimpleGraph.LoopWalk.permMapWalk n s p.2⟩


