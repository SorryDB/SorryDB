import Mathlib

open SimpleGraph

/- A simple graph is a graph without multiple edges or self-loops. -/
variable (G : SimpleGraph V)

/- A complete graph on n vertices is a simple graph where each pair of vertices is connected by an edge. -/
abbrev K (n : ℕ) : SimpleGraph (Fin n) where
  adj u v := u ≠ v

/- A walk in a graph is a sequence of vertices where each consecutive pair is connected by an edge. -/
inductive Walk (u : V) : V → Type where
  | nil => u
  | cons v p => v :: p
  | edges p => edges p

/-- A loop walk is a walk where the start and end vertices are the same. -/
inductive LoopWalk (u : V) : V → Type where
  | nil => u
  | cons v p => v :: p
  | edges p => edges p

/-- The length of a walk is the number of edges in it. -/
def walk_length {p : Walk u} : ℕ := match p with
  | nil => 0
  | cons v p => p.length + 1
  | edges p => p.length + 1

/-- The length of a loop walk is the number of edges in it. -/
def loop_walk_length {p : LoopWalk u} : ℕ := match p with
  | nil => 0
  | cons v p => p.length + 1
  | edges p => p.length + 1

/-- The support of a walk is the set of vertices it visits. -/
def support {p : Walk u} : Finset V := List.toFinset p

/-- The support of a loop walk is the set of vertices it visits. -/
def support {p : LoopWalk u} : Finset V := List.toFinset p

/-- The edge set of a walk is the set of edges it uses. -/
def edges {p : Walk u} : Finset (V × V) := List.toFinset p.edges

/-- The edge set of a loop walk is the set of edges it uses. -/
def edges {p : LoopWalk u} : Finset (V × V) := List.toFinset p.edges

