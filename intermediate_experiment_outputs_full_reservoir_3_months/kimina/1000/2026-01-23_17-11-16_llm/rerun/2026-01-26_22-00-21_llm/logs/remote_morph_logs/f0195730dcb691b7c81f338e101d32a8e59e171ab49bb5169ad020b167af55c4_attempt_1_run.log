      rcases x with ⟨ux, px⟩
      rcases y with ⟨uy, py⟩
      rcases z with ⟨uz, pz⟩
      rcases hxy with ⟨s1, hy⟩
      rcases hyz with ⟨s2, hz⟩
      refine ⟨s2 * s1, ?_⟩
      cases hy
      cases hz
      ext
      · simp [Equiv.Perm.mul_def]
      · simp [permMapWalk_comp]


