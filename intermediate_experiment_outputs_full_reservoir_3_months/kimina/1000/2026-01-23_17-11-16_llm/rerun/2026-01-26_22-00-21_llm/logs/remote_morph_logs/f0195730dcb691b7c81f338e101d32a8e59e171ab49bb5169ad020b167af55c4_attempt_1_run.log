import Mathlib

open SimpleGraph

/- A walk is closed if its start and end vertices are the same. -/
@[simp]
def IsClosed {u v : V} (_ : G.LoopWalk u v) : Prop := u = v

/- The number of edges in a loop walk is the number of edges along it. -/
def edge_count {u v : V} (p : G.LoopWalk u v) : ℕ :=
  p.toFinset.card

/- The number of vertices in a loop walk is the number of vertices along it. -/
def vertex_count {u v : V} (p : G.LoopWalk u v) : ℕ :=
  (p.support.toFinset).card

/- The length of a loop walk is the number of edges in it. -/
def length (p : G.LoopWalk u v) : ℕ :=
  edge_count p

/- The number of loops in a loop walk is the number of times the walk returns to the starting vertex. -/
def loop_count {u v : V} (p : G.LoopWalk u v) : ℕ := sorry

/- The number of edges in a closed loop walk is the number of edges along it. -/
abbrev ClosedLoopWalk (G : SimpleGraph V) := Σ u : V, G.LoopWalk u u

/-- A walk is closed if its start and end vertices are the same. -/
@[simp]
def IsClosed {u v : V} (_ : G.LoopWalk u v) : Prop := u = v

