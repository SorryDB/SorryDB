import Mathlib

open Finset

/- A walk is a sequence of vertices where each consecutive pair is connected by an edge. -/
abbrev Walk (G : SimpleGraph V) (u v : V) := G.Path u v

/-- The length of a walk is the number of edges in it. -/
noncomputable def walk_length {u v : V} (p : G.Walk u v) : ℕ := (p.toEdges.toFinset.card)

/-- The number of vertices in a walk is the length of the walk plus one. -/
noncomputable def walk_vertex_count {u v : V} (p : G.Walk u v) : ℕ := walk_length p + 1

/-- The number of edges in a walk is its length. -/
noncomputable def walk_edge_count {u v : V} (p : G.Walk u v) : ℕ := walk_length p

/-- The support of a walk is the set of vertices it visits. -/
noncomputable def walk_support {u v : V} (p : G.Walk u v) : Finset V :=
  (p.toEdges.toFinset.map (fun e => e.1)).toFinset

/-- The edge set of a walk is the set of edges it uses. -/
