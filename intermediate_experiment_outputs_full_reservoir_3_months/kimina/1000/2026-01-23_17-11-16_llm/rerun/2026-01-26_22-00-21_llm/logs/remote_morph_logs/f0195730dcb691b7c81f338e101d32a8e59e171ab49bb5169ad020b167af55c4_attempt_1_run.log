  | nil => nil
  | cons h p => cons (f.map_adj h) (p.map f)
  | loop p => loop (p.map f)

variable (n : ℕ)
variable (s : Equiv.Perm (Fin n))
variable {u v w x: Fin n}

def permMap (s : Equiv.Perm (Fin n)) : K n →g K n where
  toFun:= s
  map_rel':= by
    intro u v h_adj
    unfold K
    rw [top_adj] at h_adj ⊢
    rw[Function.Injective.ne_iff]
    · apply h_adj
    apply s.injective


