-- The set of all closed loop walks up to equivalence.
def LoopWalkSetoid : Setoid (ClosedLoopWalk (K n)) where
  r := fun p q ↦ ∃ (s : Equiv.Perm (Fin n)), q = ⟨s p.1, SimpleGraph.LoopWalk.permMapWalk n s p.2⟩
