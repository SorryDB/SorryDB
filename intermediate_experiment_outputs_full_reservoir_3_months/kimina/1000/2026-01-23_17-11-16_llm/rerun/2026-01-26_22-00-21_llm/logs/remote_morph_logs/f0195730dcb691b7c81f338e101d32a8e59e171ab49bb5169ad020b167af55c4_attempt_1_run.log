import Mathlib


open SimpleGraph


/-/


/-- A walk is closed if its start and end vertices are the same. -/
@[simp]
def IsClosed {u v : V} (_ : G.LoopWalk u v) : Prop := u = v


/-- The number of edges in a walk is its length. -/
noncomputable def walk_length {p : G.LoopWalk u v} : ℕ := p.edges.toFinset.card


/-- The number of loops along a walk is the number of times the walk returns to the starting vertex. -/
noncomputable def loop_count {u v : V} (p : G.LoopWalk u v) : ℕ := (p.support.toFinset.filter (fun w => w = p.start)).card


abbrev ClosedLoopWalk (G : SimpleGraph V) := Σ u : V, G.LoopWalk u u


