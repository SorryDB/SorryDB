            simp [norm_eq_sqrt_real_sq_add_imag_sq]
          have h8 : - RCLike.re (g x) ≤ Real.sqrt ((RCLike.re (g x)) ^ 2 + (RCLike.im (g x)) ^ 2) := by
            nlinarith [Real.sqrt_nonneg ((RCLike.re (g x)) ^ 2 + (RCLike.im (g x)) ^ 2), sq_nonneg (RCLike.re (g x)), sq_nonneg (RCLike.im (g x))]
          linarith
        have h7 : Real.toNNReal (- RCLike.re (g x)) ≤ Real.toNNReal |g x| := by
          apply Real.toNNReal_le_toNNReal
          linarith
        have h8 : Real.toNNReal |g x| = |g x| := by
          simp [Real.toNNReal_eq_iff]
        nlinarith [h7, h8]
      have h5 : ∀ x, (g₂ x) ^ p.toReal⁻¹ ≤ |g x| ^ p.toReal⁻¹ := by
