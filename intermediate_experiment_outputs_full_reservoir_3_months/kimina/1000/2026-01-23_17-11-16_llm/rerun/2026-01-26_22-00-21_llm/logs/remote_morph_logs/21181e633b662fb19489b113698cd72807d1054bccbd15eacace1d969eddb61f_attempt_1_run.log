```lean
import Mathlib
open Real
open MeasureTheory
open Filter
open Topology
open RCLike

/- A map T between function spaces is called restricted weakly type preserving if for any
  functions f and g, the norm of T(f+g) is bounded by the sum of norms of Tf and Tg.
  More formally, for any set G in the codomain space, the eLp norm of T(f) restricted to G
  is bounded by the limsup of eLp norms of T(f_n) restricted to G, where f_n converges
  weakly to f.
  This implies that T maps functions of finite eLorentz norm to functions of finite eLorentz norm,
  and the eLorentz norm of T(f) is bounded by a multiple of the eLorentz norm of f. -/
structure HasRestrictedWeakType (T : (α → 𝕂) → (α' → ε')) (p p' : ℝ≥0∞) (μ : Measure α) (ν : Measure α') (c : ℝ≥0)
  : Prop :=
  (∀ {f g : α → 𝕂}, (LocallyIntegrable f μ) → (LocallyIntegrable g μ) →
    (AESTronglyMeasurable (T f) ν) → (AESTronglyMeasurable (T g) ν) →
    (AESTronglyMeasurable (T (f + g)) ν) →
    eLpNorm (T (f + g)) 1 (ν.restrict {x | T (f + g) x ≠ 0}) ≤
      eLpNorm (T f) 1 (ν.restrict {x | T f x ≠ 0}) + eLpNorm (T g) 1 (ν.restrict {x | T g x ≠ 0}))
  ∧ (∀ {a : 𝕂} (ha : ‖a‖ ≠ ⊤) {f : α → 𝕂}, (AESTronglyMeasurable (T f) ν) →
    eLpNorm (T (a • f)) 1 (ν.restrict {x | T (a • f) x ≠ 0}) ≤ ‖a‖ • eLpNorm (T f) 1 (ν.restrict {x | T f x ≠ 0}))
  ∧ (∀ {fs : ℕ → (α → 𝕂)}, (LocallyIntegrable f μ) → (∀ (n : ℕ), LocallyIntegrable (fs n) μ) →
