          have h₃ := T'_subadd (g₁ + g₃) (g₂ + g₄) (by sorry) (by sorry) x
          sorry --use: iterate T_subadd
        _ ≤ (c / p) * eLorentzNorm g₁ p 1 μ * ν G ^ p'⁻¹.toReal + (c / p) * eLorentzNorm g₂ p 1 μ * ν G ^ p'⁻¹.toReal + (c / p) * eLorentzNorm g₃ p 1 μ * ν G ^ p'⁻¹.toReal + (c / p) * eLorentzNorm g₄ p 1 μ * ν G ^ p'⁻¹.toReal := by
          gcongr
          · exact helper_g₁
          · exact helper_g₂
          · exact helper_g₃
          · exact helper_g₄
