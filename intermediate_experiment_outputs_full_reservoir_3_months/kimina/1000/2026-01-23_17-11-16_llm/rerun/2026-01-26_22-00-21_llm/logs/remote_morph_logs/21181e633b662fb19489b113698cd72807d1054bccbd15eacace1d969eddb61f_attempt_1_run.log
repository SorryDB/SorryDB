            try { nlinarith [show 0 ≤ p.toReal⁻¹ by positivity] }
        linarith
      have h8 : eLorentzNorm g₂ p 1 μ = ∫ (x : α), (g₂ x) ^ p.toReal⁻¹ dμ := by
        simp [eLorentzNorm]
      have h9 : eLorentzNorm g p 1 μ = ∫ (x : α), |g x| ^ p.toReal⁻¹ dμ := by
