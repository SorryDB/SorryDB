        have hf := hf this
        sorry --use: hf
      intro g stronglyMeasurable_g hg

      have g₁_is_measurable : Measurable g₁ := by
        have : Measurable (fun x : α => RCLike.re (g x)) := by
          apply Measurable.re
          exact stronglyMeasurable_g
        have : Measurable (fun x : α => Real.toNNReal (RCLike.re (g x))) := by
          apply Measurable.comp
          · exact this
          · exact continuous_toNNReal
        simpa using this

      have g₂_is_measurable : Measurable g₂ := by
        have : Measurable (fun x : α => RCLike.re (g x)) := by
          apply Measurable.re
          exact stronglyMeasurable_g
        have : Measurable (fun x : α => -RCLike.re (g x)) := by
