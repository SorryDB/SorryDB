Now we need to add the proofs for the measurability of `g₁, g₂, g₃, g₄` and then apply the helper lemma.

```tactics
      have g₁_is_measurable : Measurable g₁ := by
        have : Measurable (fun x : α => RCLike.re (g x)) := by
          apply Measurable.re
          exact stronglyMeasurable_g
        have : Measurable (fun x : α => Real.toNNReal (RCLike.re (g x))) := by
          apply Measurable.comp
          · exact this
          · exact continuous_toNNReal
        simpa using this

      have g₂_is_measurable : Measurable g₂ := by
        have : Measurable (fun x : α => RCLike.re (g x)) := by
          apply Measurable.re
          exact stronglyMeasurable_g
        have : Measurable (fun x : α => -RCLike.re (g x)) := by
          apply Measurable.neg
          exact this
        have : Measurable (fun x : α => Real.toNNReal (-RCLike.re (g x))) := by
          apply Measurable.comp
          · exact this
          · exact continuous_toNNReal
        simpa using this

      have g₃_is_measurable : Measurable g₃ := by
        have : Measurable (fun x : α => RCLike.im (g x)) := by
          apply Measurable.im
          exact stronglyMeasurable_g
        have : Measurable (fun x : α => Real.toNNReal (RCLike.im (g x))) := by
          apply Measurable.comp
          · exact this
          · exact continuous_toNNReal
        simpa using this

      have g₄_is_measurable : Measurable g₄ := by
        have : Measurable (fun x : α => RCLike.im (g x)) := by
          apply Measurable.im
          exact stronglyMeasurable_g
        have : Measurable (fun x : α => -RCLike.im (g x)) := by
          apply Measurable.neg
          exact this
        have : Measurable (fun x : α => Real.toNNReal (-RCLike.im (g x))) := by
          apply Measurable.comp
          · exact this
          · exact continuous_toNNReal
        simpa using this
```

Now we can apply the helper lemma to `g₁, g₂, g₃, g₄`.

```tactics
      have helper_g₁ : eLpNorm (T' g₁) 1 (ν.restrict G) ≤ (c / p) * eLorentzNorm g₁ p 1 μ * ν G ^ p'⁻¹.toReal := by
        apply helper
        · exact g₁_is_measurable
        · sorry --use: hg₁
