  intro s1 s2 hS
  simp [embed_S] at hS
  ext
  · exact hS.1
  · exact hS.2.1
  · have := hS.2.2
    have ⟨⟨x1, y1, z1⟩, ⟨h1, _, _⟩⟩ := s1
    have ⟨⟨x2, y2, z2⟩, ⟨h2, _, _⟩⟩ := s2
