    simp at hS1 hS2
    have h1 : x - y + z = x := by linarith [h_eq.1]
    have h2 : y = y := by linarith [h_eq.2.1]
    have h3 : 2 * y - z = z := by linarith [h_eq.2.2]
    have h4 : z = y := by linarith
    have h5 : 2 * z = 2 * y := by linarith [h3, h4]
    have h6 : y = z := by linarith
    have eq1 : x = y + z := by linarith
    have eq2 : x = 2 * y := by linarith [h6, eq1]
    have h7 : 4 * x * y + z ^ 2 = 4 * k + 1 := by
      nlinarith [hS1, hS2]
    rw [show z = y by linarith [h4]] at h7
    have eq3 : 4 * x * y + y ^ 2 = 4 * k + 1 := by linarith
    rw [show x = 2 * y by linarith [eq2]] at eq3
    have eq4 : 4 * (2 * y) * y + y ^ 2 = 4 * k + 1 := by linarith [eq3]
    have eq5 : 8 * y ^ 2 + y ^ 2 = 4 * k + 1 := by linarith [eq4]
