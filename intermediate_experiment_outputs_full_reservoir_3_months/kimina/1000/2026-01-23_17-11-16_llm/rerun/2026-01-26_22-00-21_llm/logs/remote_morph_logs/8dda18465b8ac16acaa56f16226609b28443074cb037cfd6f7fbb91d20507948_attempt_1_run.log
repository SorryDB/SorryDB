variable (IB)
variable [IsManifold IB ∞ B] [ContMDiffVectorBundle ∞ F E IB]

-- TODO: rename to contMDiffAt
theorem Trivialization.smoothAt (e : Trivialization F (π F E)) [MemTrivializationAtlas e]
