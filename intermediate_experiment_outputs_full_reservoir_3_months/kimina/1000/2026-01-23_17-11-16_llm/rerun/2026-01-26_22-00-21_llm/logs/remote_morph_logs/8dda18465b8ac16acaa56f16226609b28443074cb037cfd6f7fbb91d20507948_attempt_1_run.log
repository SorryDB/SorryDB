variable {α β γ : Type*} [TopologicalSpace α] [TopologicalSpace β]

theorem map_fst_nhdsWithin_eq {x : α × β} {s : Set α} :
    map Prod.fst (𝓝[Prod.fst ⁻¹' s] x) = 𝓝[s] x.1 := by
