    (∀ᶠ x in 𝓝[s] a, t ∈ 𝓝[s] x) ↔ t ∈ 𝓝[s] a :=
  eventually_eventually_nhdsWithin

theorem eventually_mem_nhds_within'' {α} [TopologicalSpace α] {s t : Set α} {a : α} :
    (∀ᶠ x in 𝓝 a, t ∈ 𝓝[s] x) ↔ t ∈ 𝓝[s] a :=
  eventually_nhds_nhdsWithin

