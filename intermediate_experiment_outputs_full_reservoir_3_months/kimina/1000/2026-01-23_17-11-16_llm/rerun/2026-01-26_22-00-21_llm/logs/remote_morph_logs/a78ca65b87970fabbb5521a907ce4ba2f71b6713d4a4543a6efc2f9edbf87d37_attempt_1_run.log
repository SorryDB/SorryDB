          all_goals linarith
        have h3 : Real.log (n + 1 : ℝ) ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
          have h4 : ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ ≥ Real.log (n + 1 : ℝ) := by
            have h5 : ∀ m : ℕ, ∑ k ∈ Icc 1 m, (k : ℝ)⁻¹ ≥ Real.log (m + 1 : ℝ) := by
