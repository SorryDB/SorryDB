open Filter
open Nat.Prime

/-- The prime counting function `π(x)` for real `x`. -/
noncomputable def primeCountingReal (x : ℝ) : ℕ :=
  if (x ≤ 0) then 0 else primeCounting ⌊x⌋₊

/-- The set of natural numbers whose prime factors are all less than or equal to `x`. -/
def S₁ (x : ℝ) : Set ℕ :=
 { n | ∀ p, Nat.Prime p → p ∣ n → p ≤ x }

theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  -- two parts:
  -- (1) log x ≤ π x + 1
  -- (2) This implies that it is not bounded
  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
        -- We need to show that ln(x) ≤ ∑_{k=1}^n (1/k)
        -- Since x ≥ n, and n ≥ 1, we have x ≥ 1
        -- Since ln is strictly increasing, ln(n) ≤ ln(x)
        -- So we need to show ln(n) ≤ ∑_{k=1}^n (1/k)
        -- From the integral test, we know that ∑_{k=1}^n (1/k) ≥ ln(n+1)
        -- Since ln is strictly increasing, ln(n) ≤ ln(n+1)
        -- Therefore, ln(n) ≤ ∑_{k=1}^n (1/k)
        have h1 : (n : ℝ) ≥ 1 := by exact_mod_cast show (1 : ℕ) ≤ n by linarith
        have h2 : x ≥ (1 : ℝ) := by linarith [hxge, h1]
        have h3 : Real.log x ≥ Real.log (n : ℝ) := by
          apply Real.log_le_log
          all_goals nlinarith
        have h4 : Real.log (n : ℝ) ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by
          -- We need to show that ln(n) ≤ ∑_{k=1}^n (1/k)
          -- This is a known inequality: ∑_{k=1}^n (1/k) ≥ ln(n+1) ≥ ln(n)
          have h5 : ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ ≥ Real.log (n + 1 : ℝ) := by
            have h6 : ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ ≥ ∫ (x : ℝ) in (1 : ℝ)..(n + 1 : ℝ), (1 / x : ℝ) := by
              apply Finset.sum_le_sum
              intro i hi
              have h7 : i ≥ 1 := by
                have h8 : i ∈ Icc (1 : ℕ) n := by
                  simpa using hi
                simp at h8 ⊢
                omega
              have h8 : (i : ℝ) ≥ (1 : ℝ) := by exact_mod_cast h7
              have h9 : (i : ℝ) ≤ (n + 1 : ℝ) := by
                have h10 : i ≤ n := by
                  have h11 : i ∈ Icc (1 : ℕ) n := by
                    simpa using hi
                  simp at h11 ⊢
                  omega
                have h11 : (i : ℝ) ≤ (n : ℝ) := by exact_mod_cast h10
                nlinarith
              have h10 : (1 / (i : ℝ)) ≥ (1 / (n + 1 : ℝ)) := by
                apply (div_le_div_iff (by positivity) (by positivity)).mpr
                nlinarith
              simp
              all_goals
                try { linarith }
                try { positivity }
              all_goals
                try { tauto }
            have h7 : ∫ (x : ℝ) in (1 : ℝ)..(n + 1 : ℝ), (1 / x : ℝ) = Real.log (n + 1 : ℝ) - Real.log (1 : ℝ) := by
              simp [Real.log_mul]
            have h8 : Real.log (1 : ℝ) = 0 := by
              simp [Real.log_one]
            have h9 : ∫ (x : ℝ) in (1 : ℝ)..(n + 1 : ℝ), (1 / x : ℝ) = Real.log (n + 1 : ℝ) := by
              rw [h7, h8]
