            have h6 : Real.log x ≤ ∑ k in Icc 1 n, (k : ℝ)⁻¹ := by
              apply Real.log_le_sum
              all_goals
                try { tauto }
                try { linarith }
                try { tauto }
                try { tauto }
            linarith
          linarith
        linarith
      _ = primeCountingReal x + 1 := by sorry
