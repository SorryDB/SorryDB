theorem infinity_of_primes₆ (n : ℕ) : ∃ (p : ℕ), p > n ∧ Nat.Prime p := by
  let p := Nat.succ (Nat.primeAfter n)
  use p
  have hp : Nat.Prime p := Nat.primeAfter_prime n
  have hp_gt : p > n := by
    have h1 : Nat.primeAfter n > n := Nat.primeAfter_gt n
    have h2 : Nat.succ (Nat.primeAfter n) > n := by
      omega
    exact_mod_cast h2
  exact ⟨hp_gt, hp⟩
