                  linarith [ih]
                linarith
            specialize h5 n
            simpa using h5
          linarith
        linarith
      _ = primeCountingReal x + 1 := by
        simp [primeCountingReal]
        <;> try { tauto }
        <;> try { norm_num }
        <;> try { linarith }
