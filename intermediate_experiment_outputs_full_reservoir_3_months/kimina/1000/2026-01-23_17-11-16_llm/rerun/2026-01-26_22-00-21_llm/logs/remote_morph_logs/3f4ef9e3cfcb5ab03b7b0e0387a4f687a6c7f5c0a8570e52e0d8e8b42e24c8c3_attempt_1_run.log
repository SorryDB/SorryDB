lemma embed_S_injective : Function.Injective (embed_S k):= by
  intro s1 s2 hS
  simp [embed_S] at hS
  ext
  · exact hS.1
  · exact hS.2.1
  · have := hS.2.2
    have ⟨⟨x1, y1, z1⟩, ⟨h1, _, _⟩⟩ := s1
    have ⟨⟨x2, y2, z2⟩, ⟨h2, _, _⟩⟩ := s2
    have hz_eq_z: z1 ^ 2 = z2 ^ 2 := by
      nlinarith
    simp at this
    by_cases hz1 : 0 ≤ z1
    · simp [hz1] at this
      by_cases hz2 : 0 ≤ z2
      · nlinarith
      · simp [hz2] at this
    · by_cases hz2 : 0 ≤ z2
      · simp [hz2] at this
        tauto
      · nlinarith

