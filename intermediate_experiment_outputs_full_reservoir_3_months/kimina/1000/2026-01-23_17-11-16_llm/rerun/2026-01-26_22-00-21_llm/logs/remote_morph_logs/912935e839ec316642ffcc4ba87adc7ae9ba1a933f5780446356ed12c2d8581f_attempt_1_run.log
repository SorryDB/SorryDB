def Match.edge.isModal {pos} {bt : BuildTree pos} {m n : Match bt} : Match.edge m n → Prop := by
  rcases btAt_m_def : btAt m with ⟨pos, m_bt⟩
  rcases pos with ⟨Hist, X, _⟩
