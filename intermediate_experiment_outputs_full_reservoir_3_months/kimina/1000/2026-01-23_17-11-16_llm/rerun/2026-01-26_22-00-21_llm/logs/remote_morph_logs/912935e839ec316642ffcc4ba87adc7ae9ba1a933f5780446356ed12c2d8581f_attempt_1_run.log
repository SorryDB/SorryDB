    specialize mvs nPos nPos_in
    -- Here we use that we have a `Move` that is data (and we not just have `move`).
    cases mvs
    case prPdl r => exact r.isModal
    case prLocTab => exact False
    case buEnd => exact False

def PreState.forms (π : PreState bt) : List Formula := π.last.1

def PreState.lforms (π : PreState bt) : List NegLoadFormula := π.last.2

def PreState.last (π : PreState bt) : Sequent := π.last

lemma PreState.formsCases {π : PreState bt} : ∀ (φ : Formula), φ ∈ PreState.forms π →
      (φ ∈ PreState.last π ∧ φ.basic = true) ∨ sorry := by
  intro φ h
  simp [PreState.forms] at h
  simp [PreState.last] at *
