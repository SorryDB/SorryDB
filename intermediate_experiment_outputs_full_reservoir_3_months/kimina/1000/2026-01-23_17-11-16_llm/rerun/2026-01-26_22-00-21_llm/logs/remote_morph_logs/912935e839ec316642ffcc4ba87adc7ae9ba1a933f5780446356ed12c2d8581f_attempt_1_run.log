inductive PreState {pos} (bt : BuildTree pos) : Type
| fromRoot : PreStateP bt .stop → PreState bt
| fromMod {o m} : (e : Match.edge o m) → e.isModal → PreStateP bt m → PreState bt

/-- Collect all `PreState`s for a given `BuildTree`. -/
