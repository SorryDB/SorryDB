            rw [<- def_nP]; exact Move.prLocTab)
        <| fun Y Y_in => buildTree s (stillWin _ Y_in)
  -- Builder positions:
  | Sum.inr (.lpr _) => by exfalso; simp [winning] at h -- prover wins, cannot happen
  | Sum.inr (.ltab nrep nbas ltX) =>
