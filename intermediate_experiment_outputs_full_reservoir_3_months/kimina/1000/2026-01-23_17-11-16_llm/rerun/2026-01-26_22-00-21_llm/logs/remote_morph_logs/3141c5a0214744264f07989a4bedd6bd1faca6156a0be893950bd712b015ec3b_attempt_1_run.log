  : H →L⋆[ℂ] H →L[ℂ] ℂ where
  toFun x := {  toFun y := (cfc_toComplexMeasure ha x y).integral f
                map_add' := sorry
                map_smul' := sorry
                cont := sorry }
  map_add' := sorry
  map_smul' := sorry
  cont := sorry

/-- For each indicator function
