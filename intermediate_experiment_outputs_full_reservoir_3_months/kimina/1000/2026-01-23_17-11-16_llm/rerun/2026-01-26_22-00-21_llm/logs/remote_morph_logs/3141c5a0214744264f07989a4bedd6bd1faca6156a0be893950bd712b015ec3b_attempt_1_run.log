    -- from a continuous linear functional
    -- The functional is zero if the function is zero
    -- The function is the indicator function of a non-measurable set
    -- The integral of a non-measurable function is zero
    -- Therefore the measure is zero
    simp [continuousLinearMapOfBilin, toBoundedBilin, cfc_toComplexMeasure, ComplexMeasure.integral]
