  simp [marcinkiewiczZygmundSymmConst]
  have h4 : ∀ ω, (∑ i ∈ A, ‖X i ω‖ ^ 2) ^ m ≥ 0 := by
    intro ω
    positivity

  have h5 : ∫ ω, (∑ i ∈ A, ‖X i ω‖ ^ 2) ^ m ∂μ ≥ 0 := by
    apply integral_nonneg
    intro ω
    apply h4

  have h6 : (m : ℝ) ^ (m : ℝ) ≥ 1 := by
    have h7 : (m : ℝ) ≥ (1 : ℝ) := by
      exact_mod_cast show (1 : ℕ) ≤ m by linarith
    have h8 : (m : ℝ) ^ (m : ℝ) ≥ (1 : ℝ) := by
      have h9 : (m : ℝ) ^ (m : ℝ) ≥ (1 : ℝ) ^ (m : ℝ) := by
        apply Real.rpow_le_rpow
        all_goals nlinarith
      have h10 : (1 : ℝ) ^ (m : ℝ) = 1 := by
        simp
