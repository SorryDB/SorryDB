      · simpa [abs_prod] using (integrable_prod_inner_X I <| filter_subset _ _ hI).abs
      · exact integrable_prod_norm_X I <| filter_subset _ _ hI
      rintro ω
      dsimp
      gcongr with k
      exact abs_real_inner_le_norm ..
    -- Rewrite the sum of `𝔼 ∏ k, ‖X iₖ ω‖ * ‖X jₖ ω‖` over even families of indices
    -- `i₁, ..., iₙ, j₁, ..., jₙ` into the sum over `w₁ + ... + wₐ = m` of
    -- `(2m choose 2w₁, ..., 2wₖ) * 𝔼 ∏ i, ‖X i‖ ^ wᵢ`.
    _ = ∑ I ∈ A ×ˢ A ^ m with EvenIndex I,
          ∫ ω, ∏ i ∈ A, ‖X i ω‖ ^ ({k | (I k).1 = i}.card + {k | (I k).2 = i}.card) ∂μ := by
      congr! with I hI ω
      simp only [mem_filter, mem_piFinset, mem_product, forall_and] at hI
      simp_rw [pow_add, prod_mul_distrib, ← prod_const]
      rw [prod_fiberwise_of_maps_to', prod_fiberwise_of_maps_to']
      · simpa using hI.1.2
      · simpa using hI.1.1
    _ = ∑ w ∈ A.piAntidiag (2 * m) with ∀ i ∈ A, 2 ∣ w i,
          multinomial A w * ∫ (ω : Ω), ∏ i ∈ A, ‖X i ω‖ ^ w i ∂μ := by
      apply Finset.sum_bijective
      · -- Show that the map from index families to weight vectors is injective
        intro I1 I2 h
        simp [EvenIndex] at h
        sorry
      · -- Show that the map from index families to weight vectors is surjective
        intro w hw
        sorry
      · -- Show that the map preserves the sum structure
        sorry
