import Mathlib

open Filter Set

noncomputable def eLpNorm (f : α → β) (p : ℝ≥0∞) (μ : Measure α) (s : Set α) :=
  (sSup (fun x => ‖f x‖ ^ p) μ).pow (1 / p)

noncomputable def eLorentzNorm (f : α → ℝ≥0) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) :=
  (‖(fun x => f x * (1 : ℝ≥0))‖_{Lp q} μ).toReal

noncomputable def Filter.limsup (f : α → β) [TopologicalSpace β] (f : Filter α) :=
  sSup (fun x => f x) f

noncomputable def Filter.limsup (f : α → β) [TopologicalSpace β] :=
  Filter.limsup f Filter.atTop

noncomputable def eLpSpace (α : Sort*) [TopologicalSpace α] (p : ℝ≥0∞) (X : Set α) :=
  {x : α | ‖x‖ ^ p < ⊤} --this is not correct, need to use measure

noncomputable def eLorentzSpace (α : Sort*) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) :=
  {f : α → ℝ≥0 | ‖f‖_{Lp q} μ < ⊤}

noncomputable def HasLorentzType (T : (α → ℝ≥0) → β → γ) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (ν : Measure β) (C : ℝ≥0∞) :=
  ∀ (f : α → ℝ≥0), (f ∈ eLorentzSpace p q μ) → (T f ∈ eLorentzSpace q p ν) → ‖T f‖_{Lp p} ν ≤ C * ‖f‖_{Lp q} μ

noncomputable def HasRestrictedWeakType (T : (α → ℝ≥0) → β → γ) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (ν : Measure β) (c : ℝ≥0) :=
  ∀ {f : α → ℝ≥0} (h : ∀ x, ‖f x‖ ≤ ‖x‖ ^ p), HasLorentzType T p q μ ν c

