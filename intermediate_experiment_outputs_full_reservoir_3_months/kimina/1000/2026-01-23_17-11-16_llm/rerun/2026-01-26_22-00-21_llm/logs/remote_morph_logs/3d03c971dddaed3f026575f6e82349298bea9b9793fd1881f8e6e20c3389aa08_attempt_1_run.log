    (C : ℝ≥0) : Prop :=
  ∀ {f : α → ℝ}, (f ∈ L^p(μ)) → ∀ {G : Set α'}, (MeasurableSet G) → (ν G < ⊤) →
    ‖T f‖_{L^q(ν)} ≤ C * ‖f‖_{L^p(μ)} * (ν G)^(1/q : ℝ) ∧
    (∀ {f : α → ℝ}, (f ∈ L^p(μ)) → ∀ {a : α}, IsMinOn f (· ∈ ·) (upperBoundsOn f (· ∈ ·)) →
      IsMinOn (T f) (· ∈ ·) (upperBoundsOn (T f) (· ∈ ·)))

