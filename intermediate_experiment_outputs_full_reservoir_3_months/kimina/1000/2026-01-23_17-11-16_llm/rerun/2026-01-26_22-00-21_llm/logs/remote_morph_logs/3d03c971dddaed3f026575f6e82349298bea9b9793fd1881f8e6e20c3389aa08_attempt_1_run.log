/- Definition of HasLorentzType from Mathlib -/
structure HasLorentzType (T : (α → ℝ) → (α' → ε)) (p : ℝ≥0∞) (q : ℝ≥0∞) (μ : Measure α) (ν : Measure α')
    (C : ℝ≥0) : Prop :=
