import Mathlib

open Filter Real Set

/- The Carleson operator is defined as:
  C(f)(x) = ∫_{t ∈ ℝ} (f(t) / (x - t)^2) * (x - t) dt
  = ∫_{t ∈ ℝ} (f(t) / (x - t)) dt
  where the integral is taken in the principal value sense. -/
def carlesonOperator (f : ℝ → ℝ) : ℝ → ℝ := fun x => ∫' (t : ℝ), f t / (x - t)

/- The weak continuity assumption neede for `HasRestrictedWeakType.hasLorentzType_helper`. -/
def WeaklyContinuous [TopologicalSpace ε] [ENorm ε] [ENorm ε'] [SupSet ε] [Preorder ε] (T : (α → ε) → (α' → ε')) (p : ℝ≥0∞) (μ : Measure α) (ν : Measure α') : Prop :=
  ∀ {fs : ℕ → SimpleFunc α ε} (_ : Monotone fs),
  let f := fun x ↦ ⨆ n, (fs n) x;
  ∀ (_ : MemLorentz f p 1 μ) (G : Set α'),
    eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n ↦ eLpNorm (T ⇑(fs n)) 1 (ν.restrict G)) Filter.atTop

/- The condition on the constant `c` in the `HasRestrictedWeakType` definition.
  It ensures that the operator `T` maps bounded sets in `L^{p,1}` to bounded sets in `L^{p',1}`. -/
def HasRestrictedWeakType {T : (α → ε) → (α' → ε')} {p p' : ℝ≥0∞} {μ : Measure α} {ν : Measure α'} {c : ℝ≥0}
    (hT : ∀ (f : α → ε), (f ∈ L^p(μ) ∧ f ∈ L^1(μ)) → (T f ∈ L^{p'}(ν) ∧ T f ∈ L^1(ν)))
    (weakly_cont_T : WeaklyContinuous T p μ ν) (T_subadd : ∀ (f g : α → ε), (f ∈ L^p(μ) ∧ f ∈ L^1(μ)) → (g ∈ L^p(μ) ∧ g ∈ L^1(μ)) →
      ‖T (f + g)‖_{L^{p'}} ≤ ‖T f + T g‖_{L^{p'}}) (T_submul : ∀ (a : ε) (f : α → ε), ‖T (a • f)‖_{L^{p'}} ≤ ‖a‖_{L^p} • ‖T f‖_{L^{p'}}) :
    ∃ (c' : ℝ≥0), (∀ (f : α → ε), (f ∈ L^p(μ) ∧ f ∈ L^1(μ)) → ‖T f‖_{L^{p'}} ≤ c' * ‖f‖_{L^{p,1}}) ∧
