example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by 
  have h3 : f =ᵐ[μL] h := by
    have h4 : {x : ℝ | f x ≠ h x} = {x : ℝ | f x ≠ g x ∨ g x ≠ h x} := by
      ext x
      simp
    rw [h4]
    have h5 : {x : ℝ | f x ≠ g x ∨ g x ≠ h x} = {x : ℝ | f x ≠ g x} ∪ {x : ℝ | g x ≠ h x} := by
      ext x
      simp [or_assoc]
    rw [h5]
    have h7 : μL {x : ℝ | f x ≠ g x} = 0 := by
      simpa using h1
    have h8 : μL {x : ℝ | g x ≠ h x} = 0 := by
      simpa using h2
    have h9 : μL ({x : ℝ | f x ≠ g x} ∪ {x : ℝ | g x ≠ h x}) = 0 := by
      have h10 : μL ({x : ℝ | f x ≠ g x} ∪ {x : ℝ | g x ≠ h x}) ≤ μL {x : ℝ | f x ≠ g x} + μL {x : ℝ | g x ≠ h x} := by
        apply MeasureTheory.Measure.add_le_add
        apply MeasureTheory.measure_subset
        · -- Show that {x | f x ≠ g x} is a subset of the union
          intro x hx
          simp at hx ⊢
          tauto
        · -- Show that {x | g x ≠ h x} is a subset of the union
          intro x hx
          simp at hx ⊢
          tauto
      have h11 : μL {x : ℝ | f x ≠ g x} = 0 := h7
      have h12 : μL {x : ℝ | g x ≠ h x} = 0 := h8
      have h13 : μL {x : ℝ | f x ≠ g x} + μL {x : ℝ | g x ≠ h x} = 0 := by
        rw [h11, h12]
        all_goals norm_num
      have h14 : μL ({x : ℝ | f x ≠ g x} ∪ {x : ℝ | g x ≠ h x}) ≥ 0 := by
        apply MeasureTheory.measure_nonneg
      linarith
    simpa using h9
  exact h3
