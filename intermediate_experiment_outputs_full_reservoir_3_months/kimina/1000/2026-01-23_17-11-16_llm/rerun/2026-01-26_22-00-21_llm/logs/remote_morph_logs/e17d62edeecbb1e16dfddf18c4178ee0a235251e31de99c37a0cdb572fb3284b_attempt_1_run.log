def μL : Measure ℝ := by volume_tac

def LebesgueFilter := ae μL
def DiracFilter := ae μD
#check DiracFilter

example : {x : ℝ | x < 0} =ᵐ[μD] (∅ : Set ℝ) := by sorry

example (f g h : ℝ → ℝ) (h1 : f =ᵐ[μL] g) (h2 : g =ᵐ[μL] h) : f =ᵐ[μL] h := by 
  have h3 : f =ᶠ[ae μL] h := by
    have h4 : {x | f x ≠ h x} = {x | f x ≠ g x} ∪ {x | g x ≠ h x} := by 
      ext x
      simp only [Set.mem_union, Set.mem_setOf_eq, Set.mem_setOf_eq]
      constructor
      · -- Assume f x ≠ h x
        intro h
        by_cases h1' : f x ≠ g x
        · -- If f x ≠ g x, then f x ≠ h x
          tauto
        · -- If f x = g x, then g x ≠ h x must hold
          have h2' : g x ≠ h x := by
            by_contra h_eq
            have h3 : f x = h x := by 
              have h4 : f x = g x := by 
                simpa using h1'
              have h5 : g x = h x := by 
                simpa using h_eq
              rw [h4, h5]
            contradiction
          tauto
      · -- Assume x ∈ {x | f x ≠ g x} ∪ {x | g x ≠ h x}
        rintro (h | h)
        · -- If x ∈ {x | f x ≠ g x}, then f x ≠ h x
          intro h
          by_contra h_eq
          have h3 : f x = h x := by
            simpa using h_eq
          have h4 : f x = g x := by 
            simpa using h
          have h5 : g x = h x := by 
            linarith
          contradiction
        · -- If x ∈ {x | g x ≠ h x}, then f x ≠ h x
          intro h
          by_contra h_eq
          have h3 : f x = h x := by 
            simpa using h_eq
          have h4 : g x = h x := by 
            simpa using h
          have h5 : f x = g x := by 
            linarith
          contradiction
    have h5 : μL {x | f x ≠ g x} = 0 := by 
