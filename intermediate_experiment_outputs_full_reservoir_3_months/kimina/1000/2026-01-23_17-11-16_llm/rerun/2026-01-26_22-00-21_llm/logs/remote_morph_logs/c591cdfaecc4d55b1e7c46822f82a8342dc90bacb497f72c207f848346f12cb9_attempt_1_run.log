import Mathlib.Data.List.Indexes
import Mathlib.Data.List.Basic

import Gossip.Sufficient

variable {n : Nat}

abbrev after (¤â : List (Call n)) := makeCalls (initialState n) ¤â

/-! ## Helper functions about properties of `Nat`s. -/

/-- Suppose there exists a natural number satisfying ¤ć.
Then there exists a *minimal* natural number that satisfies ¤ć. -/
lemma exists_to_minimal_exists (¤ć : Nat Ôćĺ Prop):
    (Ôłâ k, ¤ć k) Ôćĺ (Ôłâ m, ¤ć m Ôłž ÔłÇ n < m, ┬Č ¤ć n) := by
  intro ÔčĘk, h_kÔčę
  induction k using Nat.strong_induction_on
  case h k IH =>
    cases k
    case zero =>
      use 0
      constructor
      ┬Ě exact h_k
      ┬Ě simp
    case succ k =>
      by_cases ¤ć k
      case pos h =>
        exact IH k (by simp) h
      case neg h =>
        by_cases Ôłâ l < k, ¤ć l
        case pos hl =>
          rcases hl with ÔčĘl, l_lt_, phi_lÔčę
          exact IH l (by linarith) phi_l
        case neg hl =>
          use k + 1
          constructor
          ┬Ě exact h_k
          ┬Ě intro j j_lt_k_succ
            rw [@Nat.lt_add_one_iff_lt_or_eq] at j_lt_k_succ
            cases j_lt_k_succ
            ┬Ě simp at hl
              apply hl
              assumption
            ┬Ě convert h

/-- Nobody hears their own secret in the given sequence, i.e. before each call
in the sequence, the agents in that call do not know each other's secrets. -/
def noHo (¤â : List (Call n)) : Prop :=
  ÔłÇ i : Fin ¤â.length,
      ┬Č (after (¤â.take (i - 1))) ¤â[i].fst ¤â[i].snd
    Ôłž ┬Č (after (¤â.take (i - 1))) ¤â[i].snd ¤â[i].fst

/-- Number of calls that k directly participates in. -/
def v (S : List (Call m)) (k : Fin m) : Nat := -- easy?
  --S.foldl (╬╗ (counter c) => ite (c.fst = k ÔłĘ c.snd = k) (counter + 1) counter) 0
  S.countP (╬╗ (c : Call m) => c.fst = k ÔłĘ c.snd = k)

/-- Among n agents, to make k an expert, we need at least n-1 calls. -/
lemma exp_needs_n_min_one_calls (S : List (Call n))
    (h : isExpert (after S) k)
    : n - 1 < S.length := by
  sorry

/-- Among n agents, to make everyone know k's secret, we need at least n-1 calls. -/
lemma known_needs_n_min_one_calls (S : List (Call n))
    (h : allKnow (after S) k)
    : n - 1 < S.length := by
  sorry

/-- Given a noHo sequence, to make k an expert and make everyone know k, we need this many calls. -/
lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ÔëĄ S.length := by
  -- use Lemma 6 "calls needed for both spreading and informing are those in v S k"
  sorry

/-- f(n) = k -/
def is_f n k :=
  Ôłâ ¤â : List (Call n), allExpert (after ¤â)
  Ôłž ¤â.length = k
  Ôłž ┬Č Ôłâ ¤â' : List (Call n), allExpert (after ¤â') Ôłž ¤â'.length < k

def is_f_leq n k :=
  Ôłâ ¤â : List (Call n), allExpert (after ¤â)
  Ôłž ¤â.length ÔëĄ  k

def phi (n : Nat) : Prop :=
  n > 4 Ôłž is_f_leq n (2*n - 5)

def is_minimal (m : Nat) :=
  phi m
  Ôłž ÔłÇ n < m, ┬Č phi n -- note: corrected > to be < here.

def initial (S : List (Call m)) (k : Fin m) : Option (Call m) :=
  S.find? (╬╗ c => c.fst = k ÔłĘ c.snd = k)

example : initial [(4, 3), (0, 2), (0, 3)] (0 : Fin 5) = some (0,2) := by rfl

def final (S : List (Call m)) (k : Fin m) : Option (Call m) :=
  S.reverse.find? (╬╗ c => c.fst = k ÔłĘ c.snd = k)

example : final [(4, 3), (0, 2), (0, 3), (2, 4)] (0 : Fin 5) = some (0,3) := by rfl

def isAgentInitialCall (S : List (Call m)) (k : Fin m) (c : Call m) : Bool :=
  initial S k = c

example : ┬Č isAgentInitialCall [(4, 3), (0, 2), (0, 3)] (0 : Fin 5) (0, 3) := by decide

def isAgentFinalCall (S : List (Call m)) (k : Fin m) (c : Call m) : Bool :=
  final S k = c

example : isAgentFinalCall [(4, 3), (0, 2), (0, 3)] (0 : Fin 5) (0, 3) := by decide

def isInitialCall (S : List (Call m)) (c : Call m) : Bool :=
  isAgentInitialCall S c.fst c ÔłĘ isAgentInitialCall S c.snd c

example : ┬Č isInitialCall ([(4, 3), (0, 2), (0, 3), (2, 3)] : List (Call 5)) (2, 3) := by decide

example : ┬Č isAgentInitialCall [(4, 3), (0, 2), (0, 3)] (0 : Fin 5) (0, 3) := by decide
example : ┬Č isAgentInitialCall ([(4, 3), (0, 2), (0, 3)] : List (Call 4)) 0 (0, 2) := by decide

def isFinalCall (S : List (Call m)) (c : Call m) : Bool :=
  isAgentFinalCall S c.fst c ÔłĘ isAgentFinalCall S c.snd c

example : isAgentFinalCall [(4, 3), (0, 2), (0, 3)] (0 : Fin 5) (0, 3) := by decide
example : ┬Č isAgentFinalCall ([(4, 3), (0, 2), (0, 3)] : List (Call 4)) 0 (0, 2) := by decide

/-- Given a sequence `¤â` of length `2m-5` or less that makes all `m` agents experts,
if `m` is minimal, then nobody hears their own secret in ¤â. -/
lemma noHo_of_minimal_expert_sequence (¤â : List (Call m))
    (¤â_short : ¤â.length ÔëĄ 2 * m - 5)
    (hExp : allExpert (after ¤â))
    (h_min : is_minimal m)
    : noHo ¤â := by
    obtain ÔčĘh_phi, h_minimalÔčę := h_min
  -- rearranging argument
    sorry

/--All calls in S are initial for both agents or for neither-/
  lemma initial_both_or_neither (S : List (Call m)) :
    ÔłÇc Ôłł S, (isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c)
    ÔłĘ ┬Č(isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c) := by
  by_contra hyp
  have h1 : Ôłâ c Ôłł S, ┬Č ((isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c) ÔłĘ ┬Č (isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c)) := by
    simpa using hyp
  rcases h1 with ÔčĘc, hc_mem, h_notÔčę
  have h3 : False := by
    have h4 : (isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c) ÔłĘ ┬Č (isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c) := by
      by_cases h : isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c
      ┬Ě left
        exact h
      ┬Ě right
        exact h
    have h5 : ┬Č ((isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c) ÔłĘ ┬Č (isAgentInitialCall S c.1 c Ôłž isAgentInitialCall S c.2 c)) := h_not
