Next, we define `is_f n k` and `is_f_leq n k`:

```tactics
/-- f(n) = k -/
def is_f n k :=
  Ôłâ ¤â : List (Call n), allExpert (after ¤â)
  Ôłž ¤â.length = k
  Ôłž ┬Č Ôłâ ¤â' : List (Call n), allExpert (after ¤â') Ôłž ¤â'.length < k

def is_f_leq n k :=
  Ôłâ ¤â : List (Call n), allExpert (after ¤â)
  Ôłž ¤â.length ÔëĄ  k
