    exact h11
  have h8 : Set.SurjOn (fun x => f x) (A \ {a}) (B \ {b}) := by
    intro y hy
    have hy1 : y ∈ B \ {b} := hy
    have hy2 : y ∈ B := hy1.1
    have hy3 : y ≠ b := hy1.2
    have hy4 : ∃ x ∈ A, f x = y := by
