        rw [h4] at *
        all_goals
          try tauto
      have h8 : x = a := by
        apply h1
        all_goals
          try { tauto }
      tauto
    exact ⟨hfx1, hfx2⟩
  have h7 : ∀ y ∈ (B \ {b}), ∃! x ∈ (A \ {a}), f x = y := by
    intro y hy
    have hy1 : y ∈ B := hy.1
    have hy2 : y ≠ b := hy.2
    have h8 : ∃ x ∈ A, f x = y := by
      rw [← h2]
      exact ⟨y, hy1⟩
    rcases h8 with ⟨x, hx1, hx2⟩
    use x
    constructor
    · -- Show x ∈ A \ {a}
