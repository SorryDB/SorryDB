      have h9' : f x = f y := h9
      have h11 : x = y := by
        apply h1
        all_goals
          try { tauto }
          try { 
            simp_all 
          }
      exact h11
    exact h10
  have h7 : Set.InjOn (fun x => f x) (A \ {a}) := by
    intro x hx y hy hxy
    have h8 : x ∈ A \ {a} := hx
    have h9 : y ∈ A \ {a} := hy
    have h10 : f x = f y := hxy
    have h11 : x = y := by
      have h7 : x ∈ A := by 
