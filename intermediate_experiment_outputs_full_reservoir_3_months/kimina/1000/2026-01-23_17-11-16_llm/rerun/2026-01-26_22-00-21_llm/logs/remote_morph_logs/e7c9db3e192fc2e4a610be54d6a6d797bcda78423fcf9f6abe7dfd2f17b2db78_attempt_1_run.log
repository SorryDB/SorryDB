        by_contra h
        have h8 : f a = y := by
          rw [h] at hx2
          exact hx2
        have h9 : f a = b := h4
        have h10 : y = b := by
          linarith [h8, h9]
        tauto
      ⟩
    · -- Show ∀ x' ∈ A \ {a}, f x' = y → x' = x
      intro x' hx' hfx'
      have hx1' : x' ∈ A := hx'.1
      have hx2' : x' ≠ a := hx'.2
      have hfx_eq : f x' = f x := by
        linarith [hfx', hx2]
      have h9 : x' = x := by
        apply h1
        all_goals
          try { tauto }
      exact h9
  use (fun x => f x)
  use (fun y => (choose (h7 y)).1)
  all_goals
    intro x hx
    simp_all [Set.mem_diff, Set.mem_singleton_iff, h5, h7]
    <;> try { tauto }
    <;> try { aesop }
