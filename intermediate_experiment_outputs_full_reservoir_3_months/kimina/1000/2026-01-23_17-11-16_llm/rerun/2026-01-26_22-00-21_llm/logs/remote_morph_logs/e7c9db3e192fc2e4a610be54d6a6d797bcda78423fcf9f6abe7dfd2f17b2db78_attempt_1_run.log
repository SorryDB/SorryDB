    by_contra h
    have hfx_eq_b : f x = b := by
      rw [h, h4]
    have hy_eq_b : y = b := by
      linarith [hx, hfx_eq_b]
    contradiction
  exact ⟨⟨hx_in_A, hx_ne_a⟩, hx⟩
