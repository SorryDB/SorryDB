        (x = y) := by
      intro x y h
      have h1 := Introductions.K_call x y
      have h2 := Introductions.K_call x y
      simp [Introductions.K, Introductions.K_call] at h1 h2 h ⊢
      all_goals try tauto

    -- `*` For an arbitrary bird `x`, if `K` is fond of `K ◁ x`,
