        <;> try { 
          tauto
        }
      }
    · -- If N ≠ x ⊔ y, then B N hN = {N} and sSup {N} = N
      simp [B, h_eq]
      <;> try { 
        simp [sSup]
        <;> try { 
          tauto
        }
      }
  ) (by
    intro N hN
    by_cases h_eq : N = x ⊔ y
    · -- If N = x ⊔ y, then B N hN = {x, y} and sSupIndep {x, y} is true because x and y are disjoint
      simp [B, h_eq]
      <;> try { 
