variable {M : C ⥤ ModuleCat K} in
/-- A submodule `N` of `M` is called *indecomposable* if it is non-zero and cannot be written as a direct sum of two non-zero submodules. -/
structure Indecomposable (N : PersistenceSubmodule M) : Prop :=
  ¬ (N = ⊥ ∧ (∃ x y, x ≠ ⊥ ∧ y ≠ ⊥ ∧ Disjoint x y ∧ N = x ⊔ y))

