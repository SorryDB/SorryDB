lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by 
  by_contra h
  simp only [Decomposable, not_forall, not_and] at h
  rcases h with ⟨x, y, hxy, rfl, hx, hy⟩
  let B (N : PersistenceSubmodule M) (hN : N ∈ D) : Set (PersistenceSubmodule M) := 
    if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement B (by
    intro N hN
    by_cases h_eq : N = x ⊔ y
    · -- If N = x ⊔ y, then B N hN = {x, y} and sSup {x, y} = x ⊔ y
      simp [B, h_eq]
      <;> try { 
        rw [show x ⊔ y = sSup {x, y} by 
          simp [sSup, hxy]
        ]
      }
      <;> try { 
