noncomputable def B (N : PersistenceSubmodule M) (hN : N ∈ D) : Set (PersistenceSubmodule M) := 
  if N = x ⊔ y then {x, y} else {N}

lemma : ∀ (N : PersistenceSubmodule M) (hN : N ∈ D), ⊥ ∉ B N hN := by
  intro N hN
  simp [B]
