    · simp [h_eq, sSup_singleton, sSupIndep_singleton]
  have hB'' : ∀ N hN, ⊥ ∉ B N hN := by
    intro N hN
    by_cases h_eq : N = x ⊔ y
    · simp [h_eq]
      intro h_contra
      rcases h_contra with (rfl | rfl)
      · contradiction
      · contradiction
    · simp [h_eq]
      intro h_contra
      have hN0 : N = ⊥ := by
