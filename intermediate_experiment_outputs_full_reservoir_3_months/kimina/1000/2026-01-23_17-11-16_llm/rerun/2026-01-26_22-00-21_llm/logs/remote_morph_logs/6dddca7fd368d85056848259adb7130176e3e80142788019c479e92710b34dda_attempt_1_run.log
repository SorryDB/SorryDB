    apply refinement_le B
    · -- Show that for any N in D, N = sSup (B N hN)
      intro N hN
      by_cases h_eq : N = x ⊔ y
      · -- If N = x ⊔ y, then B N hN = {x, y} and sSup {x, y} = x ⊔ y
        simp [B, h_eq]
        <;> try { 
