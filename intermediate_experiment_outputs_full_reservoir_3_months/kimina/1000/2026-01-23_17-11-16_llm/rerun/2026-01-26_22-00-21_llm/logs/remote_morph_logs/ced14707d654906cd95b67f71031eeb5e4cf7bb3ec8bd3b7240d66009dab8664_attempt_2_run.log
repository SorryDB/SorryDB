import Mathlib
open Filter Real Measure Topology ENNReal RCLike

/- Definition of eLorentz space norm -/
noncomputable def eLorentzNorm (f : α → K) (p : ℝ≥0∞) (s : Set α) (μ : Measure α) :=
  (∫ x in s, (f x) ^ p.toReal⁻¹) ^ p.toReal⁻¹.toReal

/- Definition of eLorentz space norm for indicator functions -/
noncomputable def eLorentzNorm' (f : α → K) (p : ℝ≥0∞) (s : Set α) (μ : Measure α) :=
  (∫ x in s, if x ∈ s then (μ s) ^ p.toReal⁻¹ else 0) ^ p.toReal⁻¹.toReal

/- Definition of eLorentz space norm for simple functions -/
noncomputable def eLorentzNorm'' (f : α → K) (p : ℝ≥0∞) (s : Set α) (μ : Measure α) :=
  (∫ x in s, (f x) ^ p.toReal⁻¹) ^ p.toReal⁻¹.toReal

/- Definition of eLorentz space norm for general functions -/
noncomputable def eLorentzNorm''' (f : α → K) (p : ℝ≥0∞) (μ : Measure α) :=
  (∫ x in Set.univ, (f x) ^ p.toReal⁻¹) ^ p.toReal⁻¹.toReal

