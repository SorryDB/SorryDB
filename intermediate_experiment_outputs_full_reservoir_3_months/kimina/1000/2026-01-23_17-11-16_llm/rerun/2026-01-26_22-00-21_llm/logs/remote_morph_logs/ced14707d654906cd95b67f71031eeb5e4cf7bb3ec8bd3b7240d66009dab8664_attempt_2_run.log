import Mathlib
open Filter Real Measure Topology

/- An element `a` of an ordered add comm group with zero `V` is said to be
locally finite if its support is finite. More precisely, there exists a finite set
`S` such that `a x = 0` for all `x` not in `S`. This is equivalent to being finite
when the group is non-unital.-/
def LocallyFinite (a : α → β) [OrderedAddCommGroupWithZero β] : Prop :=
  ∃ s : Finset α, ∀ x, x ∉ s → a x = 0

/- A measure `μ` on a measurable space `α` is locally finite if every
measurable set is locally finite. -/
def IsLocallyFiniteMeasure (μ : Measure α) : Prop :=
  ∀ s : Set α, MeasurableSet s → LocallyFinite s

/- A normed add comm group is a pair `(V, ‖·‖)` where `V` is an add comm group with
zero, and `‖·‖` is a norm on `V`. -/
structure NormedAddCommGroup (V : Type u) [AddCommGroupWithZero V] : Type u → Type u :=
  { norm : V → ℝ≥0 }
  -- (Note: The `norm` field is actually a function `V → ℝ≥0`)

