import Mathlib

open MeasureTheory

/- A transformation T from functions f: α → K to functions g: α' → E is said to have restricted weak type (p, p') if:
1. There exists a constant c ≥ 0 such that for all locally integrable functions f: α → K with eLp-norm bounded by 1 (relative to measure μ), the eLp-norm of T(f) relative to ν is bounded by c * (μ s)^{p⁻¹} * (ν G)^{p'⁻¹} for any measurable set G in α' and s ⊆ α with μ s < ∞.
2. T is weakly continuous with respect to μ and ν. -/
structure HasRestrictedWeakType {T : (α → K) → (α' → E)} {p p' : ℝ≥0∞} {μ : Measure α} {ν : Measure α'} {c : ℝ≥0}
    (c_pos : 0 < c) (hT : ∀ {f : α → K}, (LocallyIntegrable f μ) → (eLpNorm f p 1 μ ≤ 1) → (eLpNorm (T f) p' 1 ν ≤ c * (μ {x | f x ≠ 0}).volume ^ p'⁻¹.toReal * ν {x | f x ≠ 0} ^ p'⁻¹.toReal)) (weakly_cont_T : ∀ {f : α → K} {fs : ℕ → α → K}, LocallyIntegrable f μ → (∀ (n : ℕ), AEStronglyMeasurable (fs n) μ) → (∀ (a : α), Monotone (fun n ↦ ‖fs n a‖)) → (∀ (a : α), Filter.Tendsto (fun (n : ℕ) => fs n a) Filter.atTop (nhds (f a))) → ∀ (G : Set α'), eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n ↦ eLpNorm (T (fs n)) 1 (ν.restrict G)) Filter.atTop)
    : Prop := by
  infer_instance

/- A transformation T from functions f: α → K to functions g: α' → E is said to have Lorentz type (p, q) if there exists a constant c ≥ 0 such that for all functions f: α → K with eLp-norm bounded by 1 (relative to measure μ), the eLq-norm of T(f) relative to ν is bounded by c * (μ s)^{1/q} * (ν G)^{1/p} for any measurable set G in α' and s ⊆ α with μ s < ∞. -/
structure HasLorentzType {T : (α → K) → (α' → E)} {p q : ℝ≥0∞} {μ : Measure α} {ν : Measure α'} {c : ℝ≥0} (c_pos : 0 < c) (hT : ∀ {f : α → K}, (LocallyIntegrable f μ) → (eLpNorm f p 1 μ ≤ 1) → (eLqNorm (T f) q 1 ν ≤ c * (μ {x | f x ≠ 0}).volume ^ (1 / q : ℝ) * ν {x | f x ≠ 0} ^ (1 / p : ℝ)))
    : Prop := by
  infer_instance

/- A transformation T from functions f: α → K to functions g: α' → E is said to be weakly continuous if for any sequence of functions f_n converging to f (in a suitable topology), T(f_n) converges weakly to T(f). -/
structure WeaklyContinuous {T : (α → K) → (α' → E)} {μ : Measure α} {ν : Measure α'}
    (hT : ∀ {f : α → K} {fs : ℕ → α → K}, LocallyIntegrable f μ → (∀ (n : ℕ), AEStronglyMeasurable (fs n) μ) → (∀ (a : α), Monotone (fun n ↦ ‖fs n a‖)) → (∀ (a : α), Filter.Tendsto (fun (n : ℕ) => fs n a) Filter.atTop (nhds (f a))) → ∀ (G : Set α'), eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n ↦ eLpNorm (T (fs n)) 1 (ν.restrict G)) Filter.atTop)
    : Prop := by
  infer_instance

/- A transformation T from functions f: α → K to functions g: α' → E is said to be locally bounded if for every point x in α, the set {T(f)(x) | f is locally integrable and eLp-norm bounded by 1} is bounded. -/
structure LocallyBounded {T : (α → K) → (α' → E)} {p : ℝ≥0∞} {μ : Measure α} {c : ℝ≥0}
    (hT : ∀ {f : α → K}, (LocallyIntegrable f μ) → (eLpNorm f p 1 μ ≤ 1) → IsCompact {y | ∃ (g : α → K), (LocallyIntegrable g μ ∧ eLpNorm g p 1 μ ≤ 1) ∧ y = T g x})
    : Prop := by
  infer_instance

/- A transformation T from functions f: α → K to functions g: α' → E is said to be locally bounded if for every point x in α, the set {T(f)(x) | f is locally integrable and eLp-norm bounded by 1} is bounded. -/
structure LocallyBounded {T : (α → K) → (α' → E)} {p : ℝ≥0∞} {μ : Measure α} {c : ℝ≥0}
    (hT : ∀ {f : α → K}, (LocallyIntegrable f μ) → (eLpNorm f p 1 μ ≤ 1) → IsCompact {y | ∃ (g : α → K), (LocallyIntegrable g μ ∧ eLpNorm g p 1 μ ≤ 1) ∧ y = T g x})
    : Prop := by
