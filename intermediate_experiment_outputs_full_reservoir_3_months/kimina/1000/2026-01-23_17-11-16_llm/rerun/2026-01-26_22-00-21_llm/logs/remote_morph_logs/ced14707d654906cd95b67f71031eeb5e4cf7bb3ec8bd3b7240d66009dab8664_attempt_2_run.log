import Mathlib

open Real Set Measure Finset

/- The type of a function from a measure space (α, μ) to a measure space (α', ν) that is
locally bounded by a constant c, satisfies a certain Holder inequality condition,
and is approximately continuous in a weak sense.
-/
structure HasRestrictedWeakType (T : (α → ℝ) → (α' → ℝ)) (p p' : ℝ≥0∞) (μ : Measure α) (ν : Measure α') (c : ℝ≥0)
    : Prop where
  -- The function T is locally bounded by c
  local_bound : ∀ (x : α'), ‖T (fun _ ↦ 0) x‖ ≤ c
  -- Holder inequality condition
  holder : ∀ (f : α → ℝ), (LocallyIntegrable f μ) →
    eLpNorm (T f) p' (ν.restrict (spt f)) ≤ c * (μ (spt f)) ^ p'⁻¹.toReal * (ν (spt f)) ^ p'⁻¹.toReal
  -- Approximate continuity in a weak sense
  weakly_cont : ∀ {f : α → ℝ} {fs : ℕ → α → ℝ},
    (LocallyIntegrable f μ) →
      (∀ (n : ℕ), MeasureTheory.IsLocallyFiniteMeasureOn μ (Set.Iic (n : ℝ))) →
        (∀ (n : ℕ), AEStronglyMeasurable (fs n) μ) →
          (∀ (a : α), Monotone fun n => ‖fs n a‖) →
            (∀ (a : α), Filter.Tendsto (fun n => fs n a) Filter.atTop (nhds (f a))) →
              ∀ (G : Set α'), eLpNorm (T f) p' (ν.restrict G) ≤
                Filter.limsup (fun n => eLpNorm (T (fs n)) p' (ν.restrict G)) Filter.atTop

/- A function T has Lorentz type if it satisfies a certain Holder inequality condition
and its associated operator satisfies a bound related to the Lorentz norm.
-/
structure HasLorentzType (T : (α → ℝ) → (α' → ℝ)) (p : ℝ≥0∞) (p' : ℝ≥0∞) (μ : Measure α) (ν : Measure α')
    : Prop where
  -- Holder conjugate condition
  p_conjugate : p' = p.HolderConjugate
  -- Holder inequality condition
  holder : ∀ (f : α → ℝ), (LocallyIntegrable f μ) →
    eLpNorm (T f) p' (ν.restrict (spt f)) ≤ (μ (spt f)) ^ p'⁻¹.toReal * (ν (spt f)) ^ p'⁻¹.toReal
  -- Approximate continuity in a weak sense
  weakly_cont : ∀ {f : α → ℝ} {fs : ℕ → α → ℝ},
    (LocallyIntegrable f μ) →
      (∀ (n : ℕ), MeasureTheory.IsLocallyFiniteMeasureOn μ (Set.Iic (n : ℝ))) →
        (∀ (n : ℕ), AEStronglyMeasurable (fs n) μ) →
          (∀ (a : α), Monotone fun n => ‖fs n a‖) →
            (∀ (a : α), Filter.Tendsto (fun n => fs n a) Filter.atTop (nhds (f a))) →
              ∀ (G : Set α'), eLpNorm (T f) p' (ν.restrict G) ≤
                Filter.limsup (fun n => eLpNorm (T (fs n)) p' (ν.restrict G)) Filter.atTop

/- The norm of the identity function on ℝ is 1 if it's non-zero, 0 if it's zero.
-/
theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ‖(RCLike.I : K)‖ = if RCLike.I ≠ (0 : K) then 1 else 0 := by
  split_ifs with h
  · apply RCLike.norm_I_of_ne_zero h
  · push_neg at h
    simpa

/- A function f : α → K is said to be locally p-integrable if its real part is
locally p-integrable with respect to the measure μ.
-/
def LocallyIntegrable (f : α → K) (μ : Measure α) : Prop :=
  IsLocallyFiniteMeasureOn μ (spt (fun x ↦ RCLike.re (f x)))

/- A function f : α → K is said to be memLorentz if it satisfies certain conditions
related to local integrability and the p-norm.
-/
def @MeasureTheory.MemLorentz (α : Type u_1) (K : Type u_8) [RCLike K] [TopologicalSpace α] [ENormedSpace K]
    (f : α → K) (p : ℝ≥0∞) (μ : Measure α) : Prop :=
    (LocallyIntegrable f μ) ∧ (∃ s : Finset α, s = spt f ∧ μ s < ⊤)

/- The eLorentz norm of a function f : α → K with respect to a measure μ and a
real number p ≥ 0 is defined as the integral of ‖f(x)‖^p dμ(x) raised to the
power 1/p.
-/
def @MeasureTheory.eLorentzNorm (α : Type u_1) (K : Type u_8) [RCLike K] [TopologicalSpace α] [ENormedSpace K]
    (f : α → K) (p : ℝ≥0∞) (μ : Measure α) : ℝ≥0 :=
    (Real.rpow (∫ (x : α) : ℝ, ‖f x‖ ^ p dμ x) (1 / p.toReal)).toReal

/- A function f : α → K is said to be memLorentz' if it satisfies certain conditions
related to local integrability and the p-norm.
-/
def @MeasureTheory.MemLorentz' (α : Type u_1) (K : Type u_8) [RCLike K] [TopologicalSpace α] [ENormedSpace K]
    (f : α → K) (p : ℝ≥0∞) (μ : Measure α) : Prop :=
    (LocallyIntegrable f μ) ∧ (∃ s : Finset α, s = spt f ∧ μ s < ⊤ ∧
      ∫ (x : α) : ℝ, ‖f x‖ ^ p dμ x < ⊤)

/- A function T : (α → K) → (α' → E) is said to be eLp-Lipschitz if for every x in
α', the norm of T(f)(x) is bounded by the eLp norm of f.
-/
def eLpLipschitz (T : (α → K) → (α' → E)) (p : ℝ≥0∞) (μ : Measure α) (E : Type u_9)
    [ENormedAddCommGroup E] [TopologicalSpace E] : Prop :=
  ∀ (f : α → K), ‖T f‖_eLp μ ≤ eLpNorm f p μ

/- A function T : (α → K) → (α' → E) is said to be eLp-subadditive if for any
functions f, g : α → K, and any x in α', the norm of T(f+g)(x) is bounded by the
sum of the norms of T(f)(x) and T(g)(x).
-/
def eLpSubadditive (T : (α → K) → (α' → E)) (p : ℝ≥0∞) (μ : Measure α) (E : Type u_9)
    [ENormedAddCommGroup E] [TopologicalSpace E] : Prop :=
  ∀ (f g : α → K) (x : α'), ‖T (f + g) x‖ ≤ ‖T f x‖ + ‖T g x‖

/- A function T : (α → K) → (α' → E) is said to be eLp-submultiplicative if for any
scalar a and function f : α → K, and any x in α', the norm of T(a•f)(x) is
bounded by the product of the norm of a and the norm of T(f)(x).
-/
def eLpSubmultiplicative (T : (α → K) → (α' → E)) (p : ℝ≥0∞) (μ : Measure α) (E : Type u_9)
    [ENormedAddCommGroup E] [TopologicalSpace E] : Prop :=
  ∀ (a : K) (f : α → K) (x : α'), ‖T (a • f) x‖ ≤ ‖a‖ • ‖T f x‖

/- A function T : (α → K) → (α' → E) is said to be weakly continuous with respect
to the eLp norm if for any sequence of functions converging to f in the eLp norm,
the sequence of compositions T(f_n) converges to T(f) in the eLp norm.
-/
def weaklyContinuous (T : (α → K) → (α' → E)) (p : ℝ≥0∞) (μ : Measure α) (E : Type u_9)
    [ENormedAddCommGroup E] [TopologicalSpace E] : Prop :=
  ∀ {f : α → K} {fs : ℕ → α → K}, (LocallyIntegrable f μ) →
    (∀ (n : ℕ), IsLocallyFiniteMeasureOn μ (Iic (n : ℝ))) →
      (∀ (n : ℕ), AEStronglyMeasurable (fs n) μ) →
        (∀ (a : α), Monotone fun n => ‖fs n a‖) →
          (∀ (a : α), Filter.Tendsto (fun n => fs n a) Filter.atTop (nhds (f a))) →
            ∀ (G : Set α'), eLpNorm (T f) p (ν.restrict G) ≤
              Filter.limsup (fun n => eLpNorm (T (fs n)) p (ν.restrict G)) Filter.atTop

/- A function T : (α → K) → (α' → E) is said to have restricted weak type if it
satisfies certain conditions related to local boundedness, Holder inequality, and
approximate continuity.
-/
structure HasRestrictedWeakType (T : (α → K) → (α' → E)) (p p' : ℝ≥0∞) (μ : Measure α) (ν : Measure α') (c : ℝ≥0)
