import Mathlib
open Real

lemma eLpNorm_mono (s₁ s₂ : Set α) (hs₁ : MeasureTheory.MeasurableSet s₁) (hs₂ : MeasureTheory.MeasurableSet s₂)
    (h : s₁ ⊆ s₂) (h' : ν s₂ < ∞) : eLpNorm (T s₁) 1 ν ≤ eLpNorm (T s₂) 1 ν := by
  congr 1
  ext x
  simp only [Set.mem_setOf_eq, Set.mem_setOf_eq, Set.mem_inter_iff, and_imp]
  intro hx hx₂
  have hx₁ : x ∈ s₁ := by simpa using hx
  have hx₂ : x ∈ s₂ := by simpa using hx₂
  have hx₁ : x ∈ s₁ := hx₁
  have hx₂ : x ∈ s₂ := hx₂
  simp only [Set.mem_inter_iff, true_and]
  tauto

lemma eLpNorm_mul (a : K) (s : Set α) (hs : MeasureTheory.MeasurableSet s) (h : ν s < ∞) :
    eLpNorm (T (a • s.indicator (fun _ ↦ 1))) 1 ν = ‖a‖ₑ * eLpNorm (T (s.indicator (fun _ ↦ 1))) 1 ν := by
  congr 1
  ext x
  simp only [Set.mem_setOf_eq, Set.mem_setOf_eq, Set.mem_inter_iff, and_imp]
  intro hx hx₂
  have hx₁ : x ∈ s := by simpa using hx
  have hx₂ : x ∈ s := by simpa using hx₂
  simp only [Set.mem_inter_iff, true_and]
  simp [ENNReal.mul_apply]

lemma eLpNorm_add (s₁ s₂ : Set α) (hs₁ : MeasureTheory.MeasurableSet s₁) (hs₂ : MeasureTheory.MeasurableSet s₂)
    (h : s₁ ∪ s₂ ∈ Set.Finite) (h' : ν (s₁ ∪ s₂) < ∞) : eLpNorm (T (s₁ ∪ s₂)) 1 ν =
    eLpNorm (T s₁) 1 ν + eLpNorm (T s₂) 1 ν := by
  have h1 : Disjoint s₁ s₂ := by
    apply Set.disjoint_iff_inter_eq_empty.mpr
    ext x
    simp
    tauto
  rw [eLpNorm_union_eq h1]
  all_goals
    try { tauto }
    try { simp }
    try { tauto }

lemma eLpNorm_const_smul' (a : K) (s : Set α) (hs : MeasureTheory.MeasurableSet s) (h : ν s < ∞) :
