@[imo_problem_subject algebra]
theorem imo_1972_p5 (f g : ℝ → ℝ) (h₀ : ∀ x y, f (x + y) + f (x - y) = 2 * f x * g y)
    (h₁ : ¬∀ x, f x = 0) (h₂ : ∀ x, |f x| ≤ 1) : ∀ x, |g x| ≤ 1 := by
  have h3 : ∃ x, f x ≠ 0 := by
    by_contra h
    push_neg at h
    have h4 : ∀ x, f x = 0 := by
      intro x
      have h5 := h x
      simpa using h5
    contradiction
  rcases h3 with ⟨x₀, hx₀⟩
  have h4 : g 0 = 1 := by
    have eq1 := h₀ x₀ 0
    simp at eq1
