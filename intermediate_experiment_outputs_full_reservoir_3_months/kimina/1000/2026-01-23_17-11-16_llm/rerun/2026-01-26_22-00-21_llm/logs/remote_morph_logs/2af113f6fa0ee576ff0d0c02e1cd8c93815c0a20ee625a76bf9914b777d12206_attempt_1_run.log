      have h5 : x - x = (0 : ℝ) := by ring
      rw [h5]
      linarith [h4]
    rw [h5'] at eq2
    nlinarith [abs_le.mp h5, abs_le.mp h6, h4]
  apply abs_le.mpr
  constructor <;> linarith
