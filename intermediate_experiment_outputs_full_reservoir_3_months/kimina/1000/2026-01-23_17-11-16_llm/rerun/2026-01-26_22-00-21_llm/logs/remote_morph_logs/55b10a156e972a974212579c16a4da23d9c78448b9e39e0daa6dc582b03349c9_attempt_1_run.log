@[ext]
structure isWignerMatrix
    (k : ÔäĽ) (╬╝ ╬Ż : Measure ÔäŁ) (X : ╬ę Ôćĺ Matrix (Fin k) (Fin k) ÔäŁ) (P : Measure ╬ę) where
