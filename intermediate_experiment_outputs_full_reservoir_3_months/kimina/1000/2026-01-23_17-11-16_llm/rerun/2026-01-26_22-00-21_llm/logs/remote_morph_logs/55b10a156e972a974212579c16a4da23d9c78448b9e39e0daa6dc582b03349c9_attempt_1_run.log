         apply lt_of_le_of_ne
         apply le_of_not_gt h_lt
         exact h_eq
      ¤ë (ÔčĘ(j, i), le_of_lt h_gtÔčę)

lemma wignerMatrixEntryFunctionSymmetric (¤ë : WignerSpace n) {i j : Fin n} :
