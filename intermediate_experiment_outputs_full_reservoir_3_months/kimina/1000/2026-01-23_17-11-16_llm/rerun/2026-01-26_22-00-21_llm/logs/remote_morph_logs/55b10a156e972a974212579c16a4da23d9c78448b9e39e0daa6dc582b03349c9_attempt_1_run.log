/-- The sample space for an `n x n` Wigner matrix. It is the product of ÔäŁ over Index n. -/
abbrev WignerSpace (n : ÔäĽ) := Index n Ôćĺ ÔäŁ

instance (n : ÔäĽ) : MeasurableSpace (WignerSpace n) := by
  infer_instance

/-- The measure distribution for a Wigner matrix. It assigns the measure `╬Ż` to diagonal
entries and `╬╝` to off-diagonal entries. -/
def wignerMeasureDist (n : ÔäĽ) : Index n Ôćĺ Measure ÔäŁ :=
  fun (p : Index n) =>
    if p.val.1 = p.val.2 then ╬Ż
    else ╬╝


/-- The probability measure on the sample space `WignerSpace n`, which makes the
coordinate projections independent random variables with distributions given by
`wignerMeasureDist`. -/
noncomputable
def WignerMeasure (n : ÔäĽ) : Measure (WignerSpace n) :=
  Measure.pi (wignerMeasureDist ╬╝ ╬Ż n)

instance instIsProbabilityMeasure (n : ÔäĽ) : IsProbabilityMeasure (WignerMeasure ╬╝ ╬Ż n) := by
  rw[WignerMeasure]
  --apply MeasureTheory.Measure.pi.instIsProbabilityMeasure
  sorry

/-- The function that takes an element of WignerSpace (a map Index n Ôćĺ ÔäŁ)
to the corresponding function (Fin n) Ôćĺ (Fin n) Ôćĺ ÔäŁ that respects the symmetric structure of Wigner
matrices.-/
@[grind, simp]
def wignerMatrixEntryFunction (¤ë : WignerSpace n) : (Fin n) Ôćĺ (Fin n) Ôćĺ ÔäŁ :=
  fun i j =>
    if h_eq : i = j then
      ¤ë (ÔčĘ(i, i), le_refl iÔčę)
    else if h_lt : i < j then
      ¤ë (ÔčĘ(i, j), le_of_lt h_ltÔčę)
    else
      have h_gt : j < i := by
         apply lt_of_le_of_ne
         apply le_of_not_gt h_lt
         grind
      ¤ë (ÔčĘ(j, i), le_of_lt h_gtÔčę)

lemma wignerMatrixEntryFunctionSymmetric (¤ë : WignerSpace n) {i : Fin n} {j : Fin n} :
  wignerMatrixEntryFunction ¤ë i j = wignerMatrixEntryFunction ¤ë j i := by
  rw[wignerMatrixEntryFunction, wignerMatrixEntryFunction]
  by_cases h1 : i = j
  ┬Ě -- Case i = j
