open scoped ENNReal NNReal Real Complex

open MeasureTheory ProbabilityTheory Filter Topology

variable {n : ÔäĽ}
variable (╬╝ ╬Ż : Measure ÔäŁ) [IsProbabilityMeasure ╬╝] [IsProbabilityMeasure ╬Ż]
  (h╬╝_moments : ÔłÇ (k : ÔäĽ), Integrable (fun x ÔćŽ x^k) ╬╝)
  (h╬Ż_moments : ÔłÇ (k : ÔäĽ), Integrable (fun x ÔćŽ x^k) ╬Ż)
  (h╬╝_mean : integral ╬╝ id = 0) (h╬Ż_mean : integral ╬Ż id = 0)
  (h╬╝_var : integral ╬╝ (fun x ÔćŽ x^2) = 1)
variable {╬ę : Type*} [MeasurableSpace ╬ę] {P : Measure ╬ę} (X : ╬ę Ôćĺ Matrix (Fin n) (Fin n) ÔäŁ)


instance : MeasurableSpace (Matrix (Fin n) (Fin n) ÔäŁ ) := by
   unfold Matrix; infer_instance

@[ext]
structure isWignerMatrix
    (k : ÔäĽ) (╬╝ ╬Ż : Measure ÔäŁ) (X : ╬ę Ôćĺ Matrix (Fin k) (Fin k) ÔäŁ) (P : Measure ╬ę) where
  meas : Measurable X
  diag_dist : ÔłÇ i : (Fin k), HasLaw (fun ¤ë ÔćŽ X ¤ë i i) ╬Ż P
  off_diag_dist : ÔłÇ i j : (Fin k), i > j Ôćĺ HasLaw (fun ¤ë ÔćŽ X ¤ë i j) ╬╝ P
  symm : ÔłÇ i j : (Fin k), ÔłÇ ¤ë : ╬ę, X ¤ë i j = X ¤ë j i
  indep : iIndepFun (fun (x : {p : Fin k ├Ś Fin k // p.1 ÔëĄ p.2}) ÔćŽ fun ¤ë ÔćŽ X ¤ë x.val.1 x.val.2) P

#check isWignerMatrix

@[simp]
lemma is_measurable_Wigner (Y : isWignerMatrix n ╬╝ ╬Ż X P) : Measurable X := by
  exact Y.meas

/-- The index set for the independent random variables of a Wigner matrix. -/
def Index (n : ÔäĽ) := { p : Fin n ├Ś Fin n // p.1 ÔëĄ p.2 }

instance : Fintype (Index n) := by
  rw[Index]
  infer_instance

@[simp]
lemma off_diagonal_law (Y : isWignerMatrix n ╬╝ ╬Ż X P) (i j : Fin n) (hij : i Ôëá j) :
  HasLaw (fun ¤ë ÔćŽ X ¤ë i j) ╬╝ P:= by
  -- Since $i \neq j$, we have either $i < j$ or $j < i$. We can handle these cases separately using the off_diag_dist and the symmetry of the Wigner matrix.
  by_cases h : j < i;
  ┬Ě -- Since $j < i$, we can apply the off_diag_dist condition directly.
    apply Y.off_diag_dist i j h
    all_goals unreachable!;
  ┬Ě -- Since $i < j$, we can apply the off_diag_dist hypothesis with $i$ and $j$ swapped.
    have h_swap : HasLaw (fun ¤ë ÔćŽ X ¤ë j i) ╬╝ P := by
