open scoped ENNReal NNReal Real Complex

open MeasureTheory ProbabilityTheory Filter Topology

variable {n : ÔäĽ}
variable (╬╝ ╬Ż : Measure ÔäŁ) [IsProbabilityMeasure ╬╝] [IsProbabilityMeasure ╬Ż]
  (h╬╝_moments : ÔłÇ (k : ÔäĽ), Integrable (fun x ÔćŽ x^k) ╬╝)
  (h╬Ż_moments : ÔłÇ (k : ÔäĽ), Integrable (fun x ÔćŽ x^k) ╬Ż)
  (h╬╝_mean : integral ╬╝ id = 0) (h╬Ż_mean : integral ╬Ż id = 0)
  (h╬╝_var : integral ╬╝ (fun x ÔćŽ x^2) = 1)
variable {╬ę : Type*} [MeasurableSpace ╬ę] {P : Measure ╬ę} (X : ╬ę Ôćĺ Matrix (Fin n) (Fin n) ÔäŁ)


instance : MeasurableSpace (Matrix (Fin n) (Fin n) ÔäŁ ) := by
   unfold Matrix; infer_instance

@[ext]
structure isWignerMatrix
    (k : ÔäĽ) (╬╝ ╬Ż : Measure ÔäŁ) (X : ╬ę Ôćĺ Matrix (Fin k) (Fin k) ÔäŁ) (P : Measure ╬ę) where
  meas : Measurable X
  diag_dist : ÔłÇ i : (Fin k), HasLaw (fun ¤ë ÔćŽ X ¤ë i i) ╬Ż P
  off_diag_dist : ÔłÇ i j : (Fin k), i > j Ôćĺ HasLaw (fun ¤ë ÔćŽ X ¤ë i j) ╬╝ P
  symm : ÔłÇ i j : (Fin k), ÔłÇ ¤ë : ╬ę, X ¤ë i j = X ¤ë j i
  indep : iIndepFun (fun (x : {p : Fin k ├Ś Fin k // p.1 ÔëĄ p.2}) ÔćŽ fun ¤ë ÔćŽ X ¤ë x.val.1 x.val.2) P

#check isWignerMatrix

@[simp]
lemma is_measurable_Wigner (Y : isWignerMatrix n ╬╝ ╬Ż X P) : Measurable X := by
  exact Y.meas

/-- The index set for the independent random variables of a Wigner matrix. -/
def Index (n : ÔäĽ) := { p : Fin n ├Ś Fin n // p.1 ÔëĄ p.2 }

instance : Fintype (Index n) := by
  rw[Index]
  infer_instance

@[simp]
lemma off_diagonal_law (Y : isWignerMatrix n ╬╝ ╬Ż X P) (i j : Fin n) (hij : i Ôëá j) :
  HasLaw (fun ¤ë ÔćŽ X ¤ë i j) ╬╝ P:= by
  -- Since $i \neq j$, we have either $i < j$ or $j < i$. We can handle these cases separately using the off_diag_dist and the symmetry of the Wigner matrix.
  by_cases h : j < i;
  ┬Ě -- Since $j < i$, we can apply the off_diag_dist condition directly.
    apply Y.off_diag_dist i j h
    all_goals unreachable!;
  ┬Ě -- Since $i < j$, we can apply the off_diag_dist hypothesis with $i$ and $j$ swapped.
    have h_swap : HasLaw (fun ¤ë ÔćŽ X ¤ë j i) ╬╝ P := by
      cases lt_or_gt_of_ne hij <;> aesop
      generalize_proofs at *;
      have := Y.off_diag_dist j i h_1; aesop;
    generalize_proofs at *;
    -- Since $X$ is symmetric, we have $X i j = X j i$.
    have h_symm : ÔłÇ ¤ë, X ¤ë i j = X ¤ë j i := by
      -- By the symmetry of the Wigner matrix, we have $X i j = X j i$ for all $i$ and $j$.
      intros ¤ë; exact Y.symm i j ¤ë
    generalize_proofs at *;
    aesop;

@[simp]
lemma diagonal_law (Y : isWignerMatrix n ╬╝ ╬Ż X P) (i : Fin n) : HasLaw (fun ¤ë ÔćŽ X ¤ë i i) ╬Ż P:= by
   apply Y.diag_dist i

@[simp]
lemma symmetric (Y : isWignerMatrix n ╬╝ ╬Ż X P) : ÔłÇ (¤ë : ╬ę), (X ¤ë).IsSymm := by
  intro ¤ë
  apply Matrix.IsSymm.ext
  intros i j
  apply Y.symm

@[simp]
lemma indep_entries (Y : isWignerMatrix n ╬╝ ╬Ż X P) (i j k l : Fin n) (hdiff : Sym2.mk (i,j) Ôëá Sym2.mk (k,l)) :
    IndepFun (fun ¤ë ÔćŽ X ¤ë i j) (fun ¤ë ÔćŽ X ¤ë k l) P := by
  -- Define the projections from the Wigner matrix to its entries.
  let proj : {p : Fin n ├Ś Fin n // p.1 ÔëĄ p.2} Ôćĺ ╬ę Ôćĺ ÔäŁ := fun p ÔćŽ (fun ¤ë ÔćŽ X ¤ë p.val.1 p.val.2);
  -- By definition of Y.indep, the projections proj are independent.
  have h_indep : iIndepFun (fun (p : {p : Fin n ├Ś Fin n // p.1 ÔëĄ p.2}) ÔćŽ proj p) P := by
    -- Apply the hypothesis that the projections are independent.
    apply Y.indep;
  -- By definition of proj, we have that (fun ¤ë => X ¤ë i j) = proj ÔčĘ(i, j), by sorryÔčę and (fun ¤ë => X ¤ë k l) = proj ÔčĘ(k, l), by sorryÔčę.
  have h_eq_proj : (fun ¤ë => X ¤ë i j) = proj ÔčĘ(min i j, max i j), by
    exact min_le_maxÔčę Ôłž (fun ¤ë => X ¤ë k l) = proj ÔčĘ(min k l, max k l), by
    exact min_le_maxÔčę := by
    simp +zetaDelta at *;
    generalize_proofs at *;
    cases le_total i j <;> cases le_total k l <;> simp +decide [ * ];
    ┬Ě exact funext fun ¤ë => Y.symm k l ¤ë ÔľŞ rfl;
    ┬Ě exact funext fun ¤ë => by simpa [ eq_comm ] using Y.symm j i ¤ë;
    ┬Ě exact ÔčĘ funext fun ¤ë => Y.symm _ _ _, funext fun ¤ë => Y.symm _ _ _ Ôčę
  generalize_proofs at *;
  rw [ h_eq_proj.1, h_eq_proj.2 ];
  apply_rules [ ProbabilityTheory.iIndepFun.indepFun ];
  cases le_total i j <;> cases le_total k l <;> aesop


