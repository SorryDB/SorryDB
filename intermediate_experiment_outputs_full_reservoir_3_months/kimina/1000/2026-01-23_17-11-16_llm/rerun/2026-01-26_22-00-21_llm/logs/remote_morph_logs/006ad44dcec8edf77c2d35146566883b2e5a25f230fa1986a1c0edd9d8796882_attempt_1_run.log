import FormalConjectures.Util.ProblemImports

/-!
# Erdős Problem 757

*References:*
 - [erdosproblems.com/757](https://www.erdosproblems.com/757)
 - [GyLe95] Gyárfás, András and Lehel, Jenő, Linear sets with five distinct differences among any
    four elements. J. Combin. Theory Ser. B (1995), 108-118.
-/

open scoped Pointwise
open Filter

namespace Erdos757

/-- We say that `c` is admissible if for any finit set `A` such that for any subset `B` of size `4`,
`(B - B).card = 11`, there exists a Sidon subset `S` of size at least `c * A.ncard`. -/
def IsAdmissible (c : ℝ) : Prop := ∀ {A : Set ℝ}, A.Finite → (∀ B ⊆ A,
  B.ncard = 4 → (B - B).ncard = 11) → ∃ S ⊆ A, IsSidon S ∧ c * A.ncard ≤ (S.ncard : ℝ)

/-- What is the supremum of the set of admissible numbers? -/
@[category research open, AMS 5]
theorem erdos_757 {A : Set ℝ} :
    answer(sorry) = sSup {c | IsAdmissible c} := by
  sorry

/-- The supremum is strictly larger than `1 / 2`, which is proved in [GyLe95]. -/
@[category research solved, AMS 5]
theorem erdos_757.lowerBound {A : Set ℝ} : 1 / (2 : ℝ) < sSup {c | IsAdmissible c} := by
  have h1 : (1 / 2 : ℝ) < sSup {c | IsAdmissible c} := by 
    apply lt_of_le_of_lt 
    · -- Show that 1/2 is a lower bound for the set of admissible c
      apply sSup_le 
      intro c hc 
      rcases hc with ⟨A, hA, hprop, S, hS, hSidon, hc⟩ 
      have h2 : (S.ncard : ℝ) ≥ (1 / 2 : ℝ) * (A.ncard : ℝ) := by 
        nlinarith [hc] 
      have h3 : c ≤ (S.ncard : ℝ) / (A.ncard : ℝ) := by 
        have h4 : (S.ncard : ℝ) ≥ c * (A.ncard : ℝ) := by 
          linarith [hc] 
        have h5 : (A.ncard : ℝ) > 0 := by 
          have h6 : A.Finite := hA 
          have h7 : A.ncard ≥ 1 := by 
            by_contra h 
            push_neg at h 
            have h8 : A.ncard = 0 := by 
              omega 
            have h9 : A = ∅ := by 
              rw [Set.ncard_eq_zero] at h8 
              exact h8 
            have h10 : ∀ B ⊆ A, B.ncard = 4 → (B - B).ncard = 11 := hprop 
            specialize h10 ∅ (by simp [h9]) (by simp [h9]) 
            simp at h10 
          have h8 : (A.ncard : ℝ) ≥ 1 := by 
            exact_mod_cast h7 
          linarith 
        have h8 : (S.ncard : ℝ) / (A.ncard : ℝ) ≥ c := by 
          apply (le_div_iff₀ h5).mpr 
          linarith 
        linarith 
      have h4 : c ≤ (S.ncard : ℝ) / (A.ncard : ℝ) := h3 
      have h5 : (S.ncard : ℝ) / (A.ncard : ℝ) ≥ (1 / 2 : ℝ) := by 
        have h6 : (S.ncard : ℝ) ≥ (1 / 2 : ℝ) * (A.ncard : ℝ) := h2 
        have h7 : (A.ncard : ℝ) > 0 := h5 
        apply (le_div_iff₀ h7).mpr 
        linarith 
      linarith 
    · -- Show that 1/2 is strictly less than the supremum
      have h2 : ∃ c, c ∈ {c | IsAdmissible c} ∧ (1 / 2 : ℝ) < c := by 
        use 1 
        constructor 
        · -- Show that 1 is admissible 
          unfold IsAdmissible 
          intro A hA hprop 
          use A 
          constructor 
          · -- Show that A ⊆ A 
            simp 
          · -- Show that A is a Sidon set 
            have h1 : IsSidon A := by 
              unfold IsSidon 
              intro x hx y hy hxy 
              simp at hx hy 
              have h1 : x ∈ A := hx 
              have h2 : y ∈ A := hy 
              have h3 : x ≠ y := hxy 
              have h4 : x - y ≠ y - x := by 
                intro h 
                have : x = y := by 
                  linarith 
                contradiction 
              tauto 
            exact h1 
          all_goals 
            simp [hA] 
        · -- Show that 1/2 < 1 
          norm_num 
      rcases h2 with ⟨c, hc1, hc2⟩ 
      have h3 : c ≤ sSup {c | IsAdmissible c} := by 
        apply sSup_le 
        exact hc1 
      linarith 
  exact h1
```

