  {n m k : ℕ} [hX : IsOrbifold n X] [hY : IsOrbifold m Y] [hZ : IsOrbifold k Z]

instance : IsOrbifold (n + m) (X × Y) where
  locally_modelled := fun ⟨x,y⟩ ↦ by
    let _ := @DTop X _; let _ := @DTop Y _
    let ⟨u, hu, hxu, Γ, u', hu', ⟨du⟩⟩ := hX.locally_modelled x
