dule R β] [Module R γ] {f : β → γ",
      "\n  intro s₁ s₂ h\n  have h1 : (s₁ : χ.QuadSols).val = (s₂ : χ.QuadSols).val := by\n    simpa using h\n  have h_eq1 : (s₁ : χ.QuadSols).val = (s₂ : χ.QuadSols).val := h1\n  have h_eq2 : s₁.linearSol = s₂.linearSol := by\n    intro i\n    simp_all [Function.comp_apply]\n    <;> try { tauto }\n    <;> try { \n      simp_all [Fin.sum_univ_succ, Fin.sum_univ_zero] \n      <;> try { tauto } \n    }\n  have h_eq3 : s₁.quadSol = s₂.quadSol := by\n    intro i\n    simp_all [Function.comp_apply]\n    <;> try { tauto }\n    <;> try { \n      simp_all [Fin.sum_univ_succ, Fin.sum_univ_zero] \n      <;> try { tauto } \n    }\n  ext\n  simp_all [h_eq1, h_eq2, h_eq3]\n  <;> try { tauto }\n  <;> try { aesop }\n  <;> try { tauto }",
      "\n  intro S₁ S₂ h\n  simp [quadSolsIncl, mulActionHom_comp_apply] at h\n  have h1 : quadSolsInclLinSols S₁ = quadSolsInclLinSols S₂ := by\n    apply linSolsIncl_injective\n    simpa using h\n  have h2 : S₁ = S₂ := by\n    apply quadSolsInclLinSols_injective\n    simpa using h1\n  exact h2",
