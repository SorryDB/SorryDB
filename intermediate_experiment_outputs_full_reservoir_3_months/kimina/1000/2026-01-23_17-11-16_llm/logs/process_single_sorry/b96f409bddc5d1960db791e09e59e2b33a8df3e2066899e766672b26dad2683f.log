tching.Tutte.Lift.Card\n\nimport Mathlib.Data.Graph.Matching.Tutte.Lift.Lemmas\nimport Mathlib.Data.Graph.Matching.Tutte.Lift.Card\n\nimport Mathlib.Data.Graph.Matching.Tutte.Lift.Lemmas\nimport Mathlib.Data.Graph.Matching.Tutte.Lift.Card\n\nimport Mathlib.Data.Graph.Matching.Tutte.Lift.Lemmas\nimport",
      "\n  have h1 : M.encard = ν(G) := by\n    rw [MatchingNumber]\n    have h2 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      refine' ⟨M, h.1, rfl⟩\n    have h3 : ∀ n, n ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → n ≤ M.encard := by\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h4 : M'.encard ≤ M.encard := by\n        apply h.2 M' hM'\n      linarith [hn, h4]\n    have h4 : M.encard = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      rw [sSup_eq_iff]\n      constructor\n      · -- Show that M.encard is in the set\n        exact h2\n      · -- Show that M.encard is the least upper bound\n        intro n hn\n        have h5 : n ≤ M.encard := h3 n hn\n        linarith\n    exact h4\n  exact h1",
      "\n  have h1 : M.encard ∈ {n | ∃ M, G.IsMatching M ∧ n = M.encard} := by\n    refine' ⟨M, h.toIsMatching, rfl⟩\n  have h2 : ∀ n, n ∈ {n | ∃ M, G.IsMatching M ∧ n = M.encard} → n ≤ M.encard := by\n    intro n hn\n    rcases hn with ⟨M', hM', hn⟩\n    have h3 : M'.encard ≤ M.encard := by\n      apply h.max\n      exact hM'\n    linarith\n  rw [show ν(G) = sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} by rfl]\n  rw [sSup_eq_iff]\n  constructor\n  · exact h1\n  · intro n hn\n    apply h2 n hn",
      "\n  have h1 : ∀ M', G.IsMatching M' → M'.encard ≤ M.encard := by\n    intro M' hM'\n    exact h.max hM'\n  have h2 : M.encard = ν(G) := by\n    rw [show ν(G) = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} by rfl]\n    rw [sSup_eq_iff]\n    constructor\n    · -- Show that M.encard is in the set\n      use M\n      all_goals\n        simp [h]\n    · -- Show that M.encard is the maximum element in the set\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h3 : M'.encard ≤ M.encard := h1 M' hM'\n      linarith [hn, h3]\n  exact h2",
      "\n  have h1 : M.encard = ν(G) := by\n    rw [MatchingNumber]\n    have h2 : M.encard = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      have h3 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n        refine' ⟨M, h.1, rfl⟩\n      have h4 : ∀ n, n ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → n ≤ M.encard := by\n        intro n hn\n        rcases hn with ⟨M', hM', hn⟩\n        have h5 : M'.encard ≤ M.encard := by\n          apply h.2\n          exact hM'\n        linarith\n      have h6 : sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} = M.encard := by\n        rw [sSup_eq_iff]\n        constructor\n        · -- Show that M.encard is in the set\n          exact h3\n        · -- Show that M.encard is the least upper bound\n          intro n hn\n          have h7 : n ≤ M.encard := h4 n hn\n          exact h7\n      exact h6\n    exact h2\n  exact h1",
      "\n  have h1 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by \n    refine' ⟨M, h.1, rfl⟩\n  have h2 : ∀ n, n ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → n ≤ M.encard := by \n    intro n hn\n    rcases hn with ⟨M', hM', hn⟩\n    have h3 : M'.encard ≤ M.encard := by \n      apply h.2 M' hM'\n    rw [hn]\n    exact h3\n  have h3 : M.encard = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by \n    rw [sSup_eq_iff]\n    constructor\n    · -- Show that M.encard is in the set\n      exact h1\n    · -- Show that M.encard is the least upper bound\n      intro n hn\n      have h4 : ∀ m, m ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → m ≤ n := by \n        intro m hm\n        have h5 : m ≤ M.encard := h2 m hm\n        linarith\n      have h5 : M.encard ≤ n := by \n        have h6 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := h1\n        specialize hn M.encard h6\n        linarith\n      linarith\n  rw [show ν(G) = sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard} by rfl]\n  exact h3",
      "\n  have h1 : M.encard = ν(G) := by\n    have h2 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      refine' ⟨M, hM, rfl⟩\n    have h3 : ∀ n, n ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → n ≤ M.encard := by\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h4 : M'.encard ≤ M.encard := by\n        apply h.2\n        exact hM'\n      linarith\n    have h5 : sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} = M.encard := by\n      apply sSup_eq_of_mem_of_upperBounds\n      · exact h2\n      · exact h3\n    rw [show ν(G) = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} by rfl]\n    rw [h5]\n  exact h1",
      "\n  have h1 : IsMatching G M := h.1\n  have h2 : ∀ M', IsMatching G M' → M'.encard ≤ M.encard := by\n    intro M' hM'\n    exact h.2 hM'\n  have h5 : ν(G) = M.encard := by\n    rw [MatchingNumber]\n    rw [sSup_eq_iff]\n    constructor\n    · -- Show that M.encard is indeed an upper bound\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h5 : M'.encard ≤ M.encard := h2 M' hM'\n      linarith\n    · -- Show that M.encard is the least upper bound\n      intro b hb\n      have h6 : M.encard ≤ b := by\n        have h7 : M.encard ∈ {n | ∃ M, IsMatching G M ∧ n = M.encard} := by\n          refine' ⟨M, h1, rfl⟩\n        have h8 : M.encard ≤ b := by\n          apply hb\n          exact h7\n        exact h8\n      linarith\n  exact h5.symm",
      "\n  rcases h with ⟨hM, hmax⟩\n  have h1 : M.encard ≤ ν(G) := by\n    have h3 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      refine ⟨M, hM, rfl⟩\n    have h4 : M.encard ≤ sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      apply sSup_le\n      exact h3\n    rw [show ν(G) = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} by rfl] at *\n    exact h4\n  have h2 : ν(G) ≤ M.encard := by\n    have h3 : ν(G) = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by rfl\n    rw [h3]\n    apply le_sSup\n    intro n hn\n    rcases hn with ⟨M', hM', hn⟩\n    have h4 : M'.encard ≤ M.encard := hmax M' hM'\n    linarith [hn, h4]\n  linarith [h1, h2]",
