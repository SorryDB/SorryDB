      "\n  have h1 : M.encard ≤ ν(G) := by\n    apply IsMatching.encard_le\n    exact h.1\n  have h2 : ν(G) ≤ M.encard := by\n    have h3 : ν(G) = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      rfl\n    rw [h3]\n    apply sSup_le\n    intro n hn\n    rcases hn with ⟨M', hM', hn⟩\n    have h4 : M'.encard ≤ M.encard := by\n      apply h.2 M' hM'\n    linarith [hn, h4]\n  linarith [h1, h2]",
      "\n  have h1 : M.encard ≤ ν(G) := by\n    apply h.1.encard_le\n  have h2 : ν(G) ≤ M.encard := by\n    have h3 : ∀ n, (∃ M', G.IsMatching M' ∧ n = M'.encard) → n ≤ M.encard := by\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h4 : M'.encard ≤ M.encard := h.2 M' hM'\n      linarith [hn, h4]\n    have h4 : ν(G) = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      simp [MatchingNumber]\n    rw [h4]\n    apply sSup_le\n    intro n hn\n    apply h3 n hn\n  linarith",
      "\n  have h1 : M.encard = ν(G) := by\n    rw [MatchingNumber]\n    have h2 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      refine' ⟨M, h.1, rfl⟩\n    have h3 : ∀ n, n ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → n ≤ M.encard := by\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h4 : M'.encard ≤ M.encard := by\n        apply h.2\n        exact hM'\n      linarith [hn, h4]\n    have h4 : sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} = M.encard := by\n      rw [sSup_eq_iff]\n      constructor\n      · exact h2\n      · exact h3\n    exact h4.symm\n  exact h1",
      "\n  have h1 : M.encard ≤ ν(G) := by\n    have h2 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      refine' ⟨M, h.1, rfl⟩\n    have h3 : M.encard ≤ (sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} : ℕ∞) := by\n      apply sSup_le\n      exact h2\n    rw [show ν(G) = (sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} : ℕ∞) by rfl] at *\n    exact_mod_cast h3\n  have h4 : ν(G) ≤ M.encard := by\n    have h5 : ∀ n, n ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → n ≤ M.encard := by\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h6 : M'.encard ≤ M.encard := by\n        apply h.2 M'\n        exact hM'\n      have h7 : (n : ℕ∞) = M'.encard := by\n        rw [hn]\n      have h8 : (n : ℕ∞) ≤ M.encard := by\n        rw [h7]\n        exact_mod_cast h6\n      exact_mod_cast h8\n    have h9 : ν(G) ≤ M.encard := by\n      have h10 : ν(G) = (sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} : ℕ∞) := by\n        rfl\n      have h11 : (sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} : ℕ∞) ≤ M.encard := by\n        apply le_csSup\n        intro n hn\n        have h12 : n ≤ M.encard := h5 n hn\n        exact_mod_cast h12\n      rw [h10]\n      exact_mod_cast h11\n    exact_mod_cast h9\n  have h5 : M.encard = ν(G) := by\n    have h6 : M.encard ≤ ν(G) := h1\n    have h7 : ν(G) ≤ M.encard := h4\n    exact_mod_cast (NatInf.le_antisymm h6 h7)\n  exact_mod_cast h5",
      "\n  have h1 : M.encard = ν(G) := by\n    rw [MatchingNumber]\n    have h2 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      refine' ⟨M, h.1, rfl⟩\n    have h3 : ∀ n, n ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → n ≤ M.encard := by\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h4 : M'.encard ≤ M.encard := by\n        apply h.2 M' hM'\n      linarith [hn, h4]\n    have h4 : ∀ n, (∀ m ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard}, m ≤ n) → M.encard ≤ n := by\n      intro n hn\n      have h5 : M.encard ≤ n := by\n        have h6 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n          refine' ⟨M, h.1, rfl⟩\n        have h7 : M.encard ≤ n := by\n          apply hn (M.encard) h6\n        linarith\n      linarith\n    have h5 : M.encard = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      rw [sSup_eq_iff]\n      constructor\n      · -- Show that M.encard is in the set\n        exact h2\n      · -- Show that M.encard is the least upper bound\n        constructor\n        · -- Show that M.encard is an upper bound\n          exact h3\n        · -- Show that M.encard is the least element of the upper bounds\n          exact h4\n    exact h5\n  exact h1",
      "\n  have h1 : M.encard = ν(G) := by\n    have h2 : ∀ n, (∃ M', G.IsMatching M' ∧ n = M'.encard) → n ≤ M.encard := by\n      intro n hn\n      rcases hn with ⟨M', hM', hn⟩\n      have h3 : M'.encard ≤ M.encard := by\n        apply h.2\n        exact hM'\n      linarith\n    have h3 : M.encard = sSup {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n      have h4 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n        refine' ⟨M, h.1, rfl⟩\n      have h5 : ∀ k, (∀ n, (∃ M', G.IsMatching M' ∧ n = M'.encard) → n ≤ k) → M.encard ≤ k := by\n        intro k hk\n        have h6 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := h4\n        specialize hk (M.encard) h6\n        linarith\n      rw [sSup_eq]\n      constructor\n      · -- Show that M.encard is an upper bound\n        intro n hn\n        apply h2 n hn\n      · -- Show that M.encard is the least upper bound\n        intro k hk\n        apply h5 k hk\n    rw [h3]\n    simp [MatchingNumber]\n  exact h1",
      "\n  have h1 : M.encard ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} := by\n    refine' ⟨M, h.1, rfl⟩\n  have h2 : ∀ n, n ∈ {n | ∃ M', G.IsMatching M' ∧ n = M'.encard} → n ≤ M.encard := by\n    intro n hn\n    rcases hn with ⟨M', hM', hn⟩\n    have h3 : M'.encard ≤ M.encard := by\n      apply h.2\n      exact hM'\n    linarith\n  rw [MatchingNumber]\n  simp [h1, h2]\n  <;> try { aesop }\n  all_goals try { tauto }",
