import Mathlib

open List

noncomputable def SymList (a : Sort u) : Type (u + 1) :=
  (List a × List a) // (fun p => (p.1.isEmpty → p.2.isEmpty) ∧ (p.2.isEmpty → p.1.isEmpty ∧ p.1.length = 1))

noncomputable def fromSL (sl : SymList a) : List a :=
  sl.1.1 ++ sl.1.2.reverse

noncomputable def dropWhileSL (p : a → Bool) (sl : SymList a) : SymList a :=
  if sl.1.1.isEmpty ∧ sl.1.2.isEmpty then
    ⟨[], [], by simp⟩
  else
    match h: headSL sl with
    | none => ⟨[], [], by simp⟩
    | some hsl =>
      if p hsl then
        let tl := tailSL sl
        have : lengthSL (tailSL sl) < lengthSL sl :=
         length_tail_lt_length sl (by
          if h2: sl = ⟨[], [], _⟩ then
            rw [h2] at h
            simp at h
          else
            exact h2)
        dropWhileSL p tl
      else
        sl

def headSL : SymList a → Option a
 | ⟨[], [], _⟩     => none
 | ⟨[], y :: _, _⟩ => some y
 | ⟨x::_, _, _⟩    => some x

def tailSL {a : Type} (as : SymList a) : SymList a
 | ⟨xs, ys, ok⟩ =>
   if h : xs.isEmpty then
     ⟨[], ys, by simp_all [List.length_eq_zero_iff]; tauto⟩
   else
     if h2 : xs.length = 1 then
       ⟨[], ys.reverse, by simp_all [List.length_eq_zero_iff]; tauto⟩
     else
       ⟨xs.tail, ys, by simp_all [List.length_eq_zero_iff]; tauto⟩

example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL := by
  funext sl
  have ⟨lhs, rhs, ok⟩ := sl
  simp [Function.comp, fromSL, dropWhileSL]
