open List

noncomputable def SymList (a : Type) : Type :=
  { lhs rhs : List a // (lhs.isEmpty → rhs.isEmpty) ∧ (rhs.isEmpty → lhs.isEmpty)}

def fromSL (sl : SymList a) : List a :=
  sl.lhs ++ sl.rhs.reverse

def headSL : SymList a → Option a
 | ⟨[], [], _⟩     => none
 | ⟨[], y :: _, _⟩ => some y
 | ⟨x::_, _, _⟩    => some x

def headSL! [Inhabited a] : SymList a → a
 | ⟨[], [], _⟩     => panic!"empty list"
 | ⟨[], y :: _, _⟩ => y
 | ⟨x::_, _, _⟩    => x

