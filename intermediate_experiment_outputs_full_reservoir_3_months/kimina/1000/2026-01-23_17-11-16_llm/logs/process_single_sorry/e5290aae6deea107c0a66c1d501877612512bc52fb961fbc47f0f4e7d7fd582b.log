import Mathlib

open List

noncomputable def SymList (a : Type) :=
  { mk : (List a) → (List a) → (List a → Prop) → SymList a
    | SymList.mk =>
      fun lhs rhs h => {
        lhs : lhs,
        rhs : rhs,
        ok : h
      }
    | SymList.ofList =>
      fun (l : List a) => SymList.mk l [] (by simp)
    | SymList.cons =>
      fun (h : a) (t : SymList a) => SymList.mk [] (t.lhs ++ [h]) (by
        intro h'
        simp at h'
        tauto
      )
    | SymList.reverse =>
      fun (t : SymList a) => SymList.mk t.rhs.reverse t.lhs.reverse (by
        intro h'
        simp at h'
        tauto
      )
    | SymList.nil =>
      { lhs := [], rhs := [], ok := by simp }
    | SymList.singleton =>
      fun (a : a) => SymList.mk [a] [] (by simp)
  }

noncomputable def fromSL (sl : SymList a) : List a :=
  match sl with
  | { lhs, rhs, ok } => lhs ++ rhs.reverse

noncomputable def headSL (sl : SymList a) : Option a :=
  match sl with
  | { lhs, rhs, ok } =>
    if h₁ : lhs.isEmpty then
      if h₂ : rhs.length = 1 then
        some rhs.head (by simp at h₂; exact h₂)
      else none
    else
      some lhs.head (by
        intro h₂
        apply ok
        exact h₂
      )

noncomputable def lengthSL (sl : SymList a) : Nat :=
  (List.length sl.lhs) + (List.length sl.rhs)

noncomputable def singleSL (sl : SymList a) : Bool :=
  (List.single sl.lhs ∧ sl.rhs.isEmpty) ∨
  (List.single sl.rhs ∧ sl.lhs.isEmpty)

noncomputable def lastSL (sl : SymList a) (ne : ¬ isEmpty sl) : a :=
 match sl with
 | ⟨as, bs, ok⟩ =>
   if h₁ : bs.isEmpty then
     as.head (by
      intro h₂
      apply ok
      exact h₂
      simp at h₁
      exact h₁
      simp at h₁
      exact h₁
     )
   else
     bs.head (by simp at h₁; exact h₁)

noncomputable def headSL! [Inhabited a] (sl : SymList a) : a :=
  match sl with
  | ⟨[], [], _⟩ => panic!"empty list"
  | ⟨_, y :: _, _⟩ => y
  | ⟨x :: _, _, _⟩ => x

noncomputable def singleSL (sl : SymList a) : Bool :=
  (List.single sl.lhs ∧ sl.rhs.isEmpty) ∨
  (List.single sl.rhs ∧ sl.lhs.isEmpty)

noncomputable def lengthSL (sl : SymList a) : Nat :=
  sl.lhs.length + sl.rhs.length


/- subtipos -/

noncomputable def splitInTwoSL (xs : List a) : SymList a :=
  let p := List.MergeSort.Internal.splitInTwo (Subtype.mk xs (by rfl))
  SymList.mk p.1.val p.2.val.reverse (by
    have ⟨⟨as, aok⟩, ⟨bs, bok⟩⟩ := p
    simp [aok, bok]
    apply And.intro <;>
     (intro h; simp [h] at bok aok)
    if h2: bs.length = 0 then simp at h2; simp [h2] else omega
    if h2: as.length = 0 then simp at h2; simp [h2] else omega)

noncomputable def tailSL {a : Type} (as : SymList a) : SymList a :=
  match as with
  | ⟨xs, ys, ok⟩ =>
    if h : xs.isEmpty then
      { lhs := [], rhs := ys.reverse, ok := by
