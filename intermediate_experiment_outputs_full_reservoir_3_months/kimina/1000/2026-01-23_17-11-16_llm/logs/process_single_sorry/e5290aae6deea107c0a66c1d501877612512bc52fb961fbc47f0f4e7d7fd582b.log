import Mathlib

open List

def SymList (a : Type) := ⟨List a, List a, Prop⟩

def fromSL (sl : SymList a) : List a :=
  sl.1 ++ (sl.2).reverse

def headSL (sl : SymList a) : Option a :=
  if sl.1 = [] then
    if sl.2 = [] then none
    else some (sl.2.head (by
      intro h
      apply sl.2.is_empty_iff.mp at h
      contradiction
    )
    )
  else
    some (sl.1.head (by
      intro h
      apply sl.1.is_empty_iff.mp at h
      contradiction
    )
    )

def dropWhileSL (p : a → Bool) (sl : SymList a) : SymList a :=
  if sl = ⟨_, _, _⟩ then
    if sl.1 = [] ∧ sl.2 = [] then ⟨[], [], by simp⟩
    else
      match h: headSL sl with
      | none => ⟨[], [], by simp⟩
      | some hsl =>
        if p hsl then
          let tl := tailSL sl
          have : lengthSL (tailSL sl) < lengthSL sl := by
            have h : sl ≠ ⟨_, _, _⟩ := by
              simp [sl]
            exact length_tail_lt_length sl h
          dropWhileSL p tl
        else sl
  else sl

example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  have h1 : (List.dropWhile p ∘ fromSL) sl = (List.dropWhile p (fromSL sl)) := by
    simp
  have h2 : (fromSL ∘ SymList.dropWhileSL p) sl = (fromSL (SymList.dropWhileSL p sl)) := by
    simp
  rw [h1, h2]
  by_cases h : sl.1 = [] ∧ sl.2 = []
  · -- Case where sl is empty
    have h2 : fromSL sl = [] := by
      simp [fromSL, h]
    have h3 : SymList.dropWhileSL p sl = ⟨_, _, _⟩ := by
      simp [h]
    rw [h2, h3]
    all_goals simp [fromSL]
  · -- Case where sl is non-empty
    have h3 : ¬ (sl.1 = [] ∧ sl.2 = []) := by
      intro h4
      contradiction
    have h4 : List.dropWhile p (fromSL sl) = fromSL (SymList.dropWhileSL p sl) := by
      by_cases h5 : p (headSL sl)
      · -- Case where p (headSL sl) is true
        have h6 : SymList.dropWhileSL p sl = SymList.dropWhileSL p (tailSL sl) := by
          simp [h5, headSL, tailSL, h3]
          <;> try { tauto }
          <;> try { omega }
        rw [h6]
        have h7 : List.dropWhile p (fromSL sl) = List.dropWhile p (fromSL (tailSL sl)) := by
          simp [fromSL, h5, headSL, tailSL, h3]
          <;> try { tauto }
          <;> try { omega }
        rw [h7]
        all_goals try { simp }
      · -- Case where ¬ p (headSL sl) is true
        have h6 : SymList.dropWhileSL p sl = sl := by
