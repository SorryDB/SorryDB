```tactics
import Mathlib

example
  {inst : DecidableEq Inhabitant}
  {inst2 : Fintype Inhabitant}
  {all : ∀(x : Inhabitant), x = A ∨ x = B ∨ x = C}
{stA : A ∈ Knight  ↔ (Knave={A,B,C}) }
{stAn : A ∈ Knave ↔ ¬ (Knave={A,B,C}) }
{stB: B ∈ Knight ↔ (Knight = {A} ∨ Knight = {B} ∨ Knight = {C}) }
{stBn: B ∈ Knave ↔ ¬ (Knight = {A} ∨ Knight = {B} ∨ Knight = {C}) }
  :

  A ∈ Knave ∧ B ∈ Knight ∧ C ∈ Knave
  := by
  -- also similar to I am a Knave
  have AKnave : A ∈ Knave := by
    set_knave_to_knight
    intro AKnight
    have everyoneknave := stA.mp AKnight  
    have AKnave: A ∈ Knave := by rw [everyoneknave] ; mem_finset
    contradiction
  have notallknave := stAn.mp AKnave
  have AnKnight: Knight ≠ {A} := by 
    intro KnighteqA 
    have := mem_of_eq_singleton KnighteqA 
    contradiction
  simp [AnKnight] at stB
  have BKnight2 : B ∈ Knight := by 
    set_knight_to_knave
    intro BKnave
    have CnKnave : C ∉ Knave := by 
      intro CKnave
      have : Knave = {A,B,C} := by 
        exact (everyone_in_set_eq all).mp ⟨AKnave,BKnave ,CKnave⟩
      contradiction 
    -- so Knight = {C} so B knight, contradiction 
    have : Knight = {C} := by
      apply Finset.Subset.antisymm
      · have : Finset.univ = {A,B,C} := by exact univ_iff_all.mpr all
        have : Knight ⊆ {A,B,C} := by  
          by_universe
          exact inst2
        set_knave_to_knight at AKnave
        set_knave_to_knight at BKnave
        remove_top at this
        remove_top at this
      · intro a h
        mem_finset at h
        rw [h]
        set_knight_to_knave
        assumption
    simp [this] at stB
    contradiction
  have BKnight : B ∈ Knight := by 
    set_knight_to_knave
    intro BKnave
    have notoneknight := stBn.mp BKnave
    push_neg at notoneknight
    -- by stAn, C is a knight because otherwise Knave={A,B,C}. then knight={C} contradiction
    -- since ¬Knave={A,B,C} then Knight is not empty. If C knave, then knight empty or then Knave={A,B,C} contradition. So C not knave, i.e C Knight but if C Knight then Knight ={C} contradiction
    --#check all3_in_one_other_empty
    --#check all3_in_one_other_eq_all
    --#check two_in_one_other_nonemp 
    have Or := KorKn
    simp [or_comm] at Or
    -- instead of other nonemp , instead have other is singleton
    have S'nonemp := two_in_one_other_nonemp all  AKnave BKnave (Or) notallknave
    have : Knight ={C} := by 
      rw [Finset.eq_singleton_iff_nonempty_unique_mem] 
      constructor
      · exact Finset.nonempty_iff_ne_empty.mpr S'nonemp
      · intro x
        intro xKnight
        have xs := all x
        -- repeated pattern of reasoning
        rcases xs with h_1|h_2
        · rw [h_1] at xKnight
          exfalso
          contradiction
        · rcases h_2 with h_3|h_4
          · rw [h_3] at xKnight
            contradiction
          · assumption
    have := notoneknight.right.right 
    contradiction
    --exact notoneknight.right.right this
  -- solution is A ∈ Knave ∧ B ∈ Knight ∧ C ∈ Knave
  have Knightsingle := stB.mp BKnight
  -- repeated pattern of reasoning
  -- A ∉ Knight so Knight ≠ {A}
  have KneA := not_eq_singleton_of_not_mem AKnave 

  -- need to prove C ∈ Knave
  have Cknave : C ∈ Knave := by
    by_contra h
    push_neg at h
    -- Assume C ∉ Knave, so C ∈ Knight
    have Cknight : C ∈ Knight := by
      simp [h] -- or directly use h
    -- We have A ∈ Knave, B ∈ Knight, C ∈ Knight
    -- This means Knight = {B, C}
    have K_eq_BC : Knight = {B, C} := by
      ext x
      simp [BKnight, Cknight, stB, stAn, all] -- Need to show this correctly
      -- Correct way to show equality:
      -- Show {B, C} ⊆ Knight and Knight ⊆ {B, C}
      apply Finset.Subset.antisymm
      · -- Show {B, C} ⊆ Knight
        intro x hx
        simp at hx -- hx is x = B ∨ x = C
        rcases hx with (rfl | rfl)
        · exact BKnight
        · exact Cknight
      · -- Show Knight ⊆ {B, C}
        intro x hx
        -- hx is x ∈ Knight
        have x_eq_or : x = A ∨ x = B ∨ x = C := by
          apply all x
        rcases x_eq_or with (hA' | hB' | hC')
        · -- x = A
          -- We know A ∈ Knave, so A ∉ Knight
          have A_knave : A ∈ Knave := AKnave
          simp [A_knave] at hx -- This should lead to contradiction
          -- Correct way: use the fact that A ∉ Knight
          have A_not_knight : A ∉ Knight := by
            intro hA_knight
            have : A ∈ Knave := by assumption -- or use AKnave
            simp [this] at hA_knight -- or contradiction
          -- Correct way to handle this case:
          rw [hA'] at hx
          have : A ∉ Knight := by
            intro h
            have : A ∈ Knave := by assumption
            contradiction
          contradiction
        · -- x = B
          simp [hB']
        · -- x = C
          simp [hC']
    -- Now we have Knight = {B, C}
    -- But from stB: B ∈ Knight ↔ Knight = {B} ∨ Knight = {C}
    -- We have B ∈ Knight (from BKnight)
    -- So Knight = {B} ∨ Knight = {C} must be true
    -- But we derived Knight = {B, C}
    -- This contradicts both options
    have h1 : Knight = {B, C} := K_eq_BC
    have h2 : B ∈ Knight := BKnight
    have h3 : (Knight = {B} ∨ Knight = {C}) := by
      rw [show B ∈ Knight by assumption] at stB -- Use stB directly
      tauto -- or apply stB.mp h2
    -- Now we have a contradiction
    rw [h1] at h3
    -- h3 is now ({B, C} = {B} ∨ {B, C} = {C})
    -- Both are false
    norm_num at h3 -- or use tauto
    -- Or more explicitly:
    cases h3 with
    | inl h_eq_B => 
      rw [Finset.ext_iff] at h_eq_B
      specialize h_eq_B C
      simp at h_eq_B -- leads to False
    | inr h_eq_C => 
      rw [Finset.ext_iff] at h_eq_C
      specialize h_eq_C B
      simp at h_eq_C -- leads to False

  -- Now we can prove the conjunction
  exact ⟨AKnave, BKnight, Cknave⟩
