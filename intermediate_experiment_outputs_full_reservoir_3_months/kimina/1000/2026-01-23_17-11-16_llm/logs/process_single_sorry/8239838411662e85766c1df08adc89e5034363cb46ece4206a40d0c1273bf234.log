  carrier := I ‚ą© J
  add_mem' := by
    intro a b ha hb
    exact ‚ü®I.add_mem ha hb, I.add_mem ha hb‚ü©
  zero_mem' := by
    exact ‚ü®I.zero_mem, I.zero_mem‚ü©
  smul_mem' := by
    intro c ha
    exact ‚ü®I.smul_mem c ha, I.smul_mem c ha‚ü©

