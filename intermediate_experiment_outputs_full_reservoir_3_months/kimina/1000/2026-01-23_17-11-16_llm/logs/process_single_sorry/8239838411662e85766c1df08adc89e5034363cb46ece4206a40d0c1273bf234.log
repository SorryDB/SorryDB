-/

section universal_property
variable {S} [CommRing S]

def kerLift (f : R ‚Üí+* S) : R ‚ßł (ker f) ‚Üí+* S :=
  (Ideal.Quotient.lift (ker f) f) -- Replacing the `fun x ‚Ü¶ by sorry` with the direct proof term.
