    (h0 : P m) (h1 : ∀ n, m ≤ n → P n → P (n + 1)) : ∀ n, m ≤ n → P n := by
  apply Nat.le.rec
  · exact h0
  · exact h1 _

-- Soft rule: when you have to break a theorem statement, breaking between hypotheses and
-- conclusion is better than in the middle of hypotheses
