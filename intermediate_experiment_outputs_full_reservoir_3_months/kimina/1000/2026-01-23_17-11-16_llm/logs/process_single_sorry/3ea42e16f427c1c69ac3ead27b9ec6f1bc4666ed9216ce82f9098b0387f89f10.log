  exact add_pow x y n

-- better
example {R : Type*} [CommRing R] (x y : R) (n : ℕ) : (x + y) ^ n =
    ∑ m ∈ Finset.range (n + 1), x ^ m * y ^ (n - m) * Nat.choose n m := by
  exact add_pow x y n

/- Put a colon at the end of the line, not at the beginning of the next one -/
