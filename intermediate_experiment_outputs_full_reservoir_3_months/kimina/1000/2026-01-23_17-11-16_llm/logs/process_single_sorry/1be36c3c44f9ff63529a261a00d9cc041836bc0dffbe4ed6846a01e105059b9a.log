import Mathlib

open ProbabilityTheory
open SProbabilityTheory

-- Define a way to select a uniform element from a type β, given it is finite.
-- This involves a computation `selectElem` that returns a `ProbComp β`.
-- We also require that each element in the support has the same probability of being chosen.
-- This is a generalization of `Fintype` types where each element has probability `1 / Fintype.card β`.
-- For types without `Fintype` but with `Inhabited` and `SampleableType`, this is defined via a computation.
class SampleableType (β : Type) where
  selectElem : ProbComp β
  mem_support_selectElem (x : β) : x ∈ support selectElem
  probOutput_selectElem_eq (x y : β) : Pr[= x | selectElem] = Pr[= y | selectElem]
  probFailure_selectElem : Pr[⊥ | selectElem] = 0

