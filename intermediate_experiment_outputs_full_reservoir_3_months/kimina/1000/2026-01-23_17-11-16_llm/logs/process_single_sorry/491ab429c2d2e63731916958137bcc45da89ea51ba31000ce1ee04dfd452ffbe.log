import GlimpseOfLean.Library.Ring

import Mathlib

open GlimpseOfLean

variable {R} [CommRing R]

example (I J : Ideal R) : (I ∩ J : Set R) = {a | a ∈ I ∧ a ∈ J} := by
  ext a
  simp [Set.mem_inter_iff]

def Ideal.inter (I J : Ideal R) : Ideal R where
  carrier := I ∩ J
  add_mem' := by
    intro a b ha hb
    have ha1 : a ∈ I := by
      simpa using ha.1
    have ha2 : a ∈ J := by
      simpa using ha.2
    have hb1 : b ∈ I := by
      simpa using hb.1
    have hb2 : b ∈ J := by
      simpa using hb.2
    have h1 : a + b ∈ I := by
      exact I.add_mem ha1 hb1
    have h2 : a + b ∈ J := by
      exact J.add_mem ha2 hb2
    exact ⟨h1, h2⟩
  zero_mem' := by
    simp [I.zero_mem, J.zero_mem]
  mul_mem' := by
    intro c a ha
    have ha1 : a ∈ I := by
      simpa using ha.1
    have ha2 : a ∈ J := by
      simpa using ha.2
    have h1 : c * a ∈ I := by
      exact I.mul_mem c ha1
    have h2 : c * a ∈ J := by
      exact J.mul_mem c ha2
    exact ⟨h1, h2⟩
