    -- Show the contradiction.
    have h3 : A.isKnave := hA_knave
    -- From h2: ¬(A.isKnave ∨ B.isKnave), we can derive ¬A.isKnave.
    have h4 : ¬A.isKnave := by
      intro h
      have h5 : A.isKnave ∨ B.isKnave := by
        tauto
      contradiction
    -- Now we have A.isKnave and ¬A.isKnave. Contradiction.
