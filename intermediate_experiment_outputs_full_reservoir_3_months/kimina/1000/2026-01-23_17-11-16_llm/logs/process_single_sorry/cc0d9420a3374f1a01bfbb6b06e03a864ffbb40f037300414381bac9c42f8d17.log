def firstIsomorphismTheorem (f : R →+* S) (hf : Function.Surjective f) :
    R ⧸ ker f ≃+* S :=
  { toFun := kerLift f
    invFun x := Ideal.Quotient.mk (ker f) (surjInv hf x)
    right_inv := rightInverse_surjInv hf
    map_mul' := by
      intro x y
      simp [mul_comm]
      <;> try ring
      <;> try simp [hf]
      <;> try tauto
    map_add' := by
      intro x y
      simp [mul_comm]
      <;> try ring
      <;> try simp [hf]
      <;> try tauto
  }

end universal_property
