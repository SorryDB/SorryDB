      "\n      simp [mul_add, add_mul, mul_assoc, mul_comm, mul_left_comm]\n      <;> ring_nf\n      <;> simp [mul_add, add_mul, mul_assoc, mul_comm, mul_left_comm]\n      <;> ring_nf\n      <;> tauto\n  }",
