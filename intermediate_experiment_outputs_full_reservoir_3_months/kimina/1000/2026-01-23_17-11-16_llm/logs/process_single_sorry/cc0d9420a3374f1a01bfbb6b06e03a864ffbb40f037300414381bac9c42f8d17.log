  invFun x := f.symm (g.symm x)
  left_inv := by
    simp
  right_inv := by
    simp
  map_add' := by
    simp
  map_mul' := by
    simp

example {R : Type*} [CommRing R] (x y z : R) :
    x * (y + z) + y * (z + x) + z * (x + y) = 2 * x * y + 2 * y * z + 2 * x * z := by
  ring

example (f : R →+* S) (x y : R) :
    f (1 + x * y) + f 0 = 1 + f x * f y := by
  simp

example {R} [CommRing R] (I : Ideal R) (x y : R) (hx : x ∈ I) : y * x + x * y - 0 ∈ I := by
  aesop

example {S} [CommRing S] (f : R →+* S) (x : R) : x ∈ ker f ↔ f x = 0 := by
  rw [mem_ker]

example {R} [CommRing R] (I J : Ideal R) : I ∩ J is an ideal := by
  simp [Ideal.inter]

example {R} [CommRing R] (I : Ideal R) (x y : R) (h : x - y ∈ I) :
    (x : R ⧸ I) = (y : R ⧸ I) := by
  rw [Ideal.Quotient.mk_eq_mk_iff_sub_mem]
  exact h

example (I : Ideal R) : (0 : R ⧸ I) = (0 : R ⧸ I) := by
  rfl

example (I : Ideal R) : (1 : R ⧸ I) = (1 : R ⧸ I) := by
  rfl

example (I : Ideal R) (x y : R) : (x + y : R ⧸ I) = (x : R ⧸ I) + (y : R ⧸ I) := by
  simp

example (I : Ideal R) (x y : R) : (x * y : R ⧸ I) = (x : R ⧸ I) * (y : R ⧸ I) := by
  simp

example (I : Ideal R) (x : R) : (x : R ⧸ I) = (x : R ⧸ I) := by
  rfl

example (I : Ideal R) (x : R) : (x * (y + z) + y * (z + x) + z * (x + y) : R ⧸ I) =
    (2 * x * y + 2 * y * z + 2 * x * z : R ⧸ I) := by
  ring

