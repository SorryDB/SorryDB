    right_inv := rightInverse_surjInv hf
    map_mul' := by
      intro x y
      have hx : (x : R) ∈ (ker f) := by 
        simpa using x.1
      have hy : (y : R) ∈ (ker f) := by 
        simpa using y.1
      have hfx : f x = 0 := by 
        simpa using hx
      have hfy : f y = 0 := by 
        simpa using hy
      have hfxy : f (x * y) = 0 := by 
        calc
          f (x * y) = f x * f y := by rw [f.map_mul]
          _ = 0 * 0 := by rw [hfx, hfy]
          _ = 0 := by ring
      simp [hfxy, hfx, hfy, RingHom.map_mul]
      <;> try tauto
      <;> try nlinarith
    map_add' := by
      intro x y
      simp [RingHom.map_add]
      <;> try tauto
      <;> try nlinarith
    map_one' := by
      simp [RingHom.map_one]
      <;> try tauto
      <;> try nlinarith
    map_zero' := by
      simp [RingHom.map_zero]
      <;> try tauto
      <;> try nlinarith
