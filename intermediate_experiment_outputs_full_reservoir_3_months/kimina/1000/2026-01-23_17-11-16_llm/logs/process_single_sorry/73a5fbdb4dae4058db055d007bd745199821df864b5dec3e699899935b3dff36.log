  · norm_num
  · intro color
    use 1, by norm_num
    use 2, by norm_num
    simp only [Subtype.mk_lt_mk, Set.mem_Icc] at *
    interval_cases i <;> interval_cases j <;> norm_num at hc1 hc2 hij1 hij2 <;> omega

lemma lemma5 : all_colorings_are_good 5 := by
  constructor
  · norm_num
  · intro color
    use 1, by norm_num
    use 2, by norm_num
    simp only [Subtype.mk_lt_mk, Set.mem_Icc] at *
    interval_cases i <;> interval_cases j <;> norm_num at hc1 hc2 hij1 hij2 <;> omega

lemma lemma6 : all_colorings_are_good 6 := by
  constructor
  · norm_num
  · intro color
    use 1, by norm_num
    use 2, by norm_num
    simp only [Subtype.mk_lt_mk, Set.mem_Icc] at *
    interval_cases i <;> interval_cases j <;> norm_num at hc1 hc2 hij1 hij2 <;> omega

lemma lemma7 : all_colorings_are_good 7 := by
