  simp [Measure.map_comap, Set.compl_setOf, Set.not_subset_iff_exists_mem_notMem, Set.setOf_exists, Set.setOf_and,
    infinitePi_cylinder, Set.mem_compl_iff, Set.mem_setOf_eq, Set.mem_inter_iff, Set.mem_singleton_iff]
  <;> aesop

