iv (by\n        simpa +contextual [ite_add_ite, ← ENNReal.coe_add] using fun _ ↦ mt (@hsu _))]\n      simp +contextual [ite_add_ite]\n    _ = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (↑u \\ s).ncard := by\n      simp [Finset.prod_ite, ← Set.ncard_coe_finset, Set.setOf_and,\n        Set.inter_eq_right.2 hsu, ← Set.compl_setOf, Set.diff_eq_compl_inter, Set.inter_comm]\n\n/-! ### Bernoulli random variables -/\n\nvariable (X u p P) in\n/-- A random variable `X : Ω → Set ι` is `p`-bernoulli on a set `u : Set ι` if its distribution is\nthe product over `u` of `p`-bernoulli random variables. -/\nabbrev IsBernoulliOn : Prop := HasLaw X Ber(u, p) P\n\nlemma isBernoulliOn_congr (hXY : X =ᵐ[P] Y) : IsBernoulliOn X u p P ↔ IsBernoulliOn Y u p P :=\n  hasLaw_congr hXY\n\nlemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :\n    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P where\n  aemeasurable_fst := by fun_prop\n  aemeasurable_snd := by fun_prop\n  map_eq := sorry\n```\n\nThe goal is to prove `map (fun ω ↦ i ∈ X ω) P = map (fun ω ↦ j ∈ X ω) P`.\nThis is equivalent to showing that for any measurable set `A`, the probabilities `P(i ∈ X⁻¹(A))` and `P(j ∈ X⁻¹(A))` are equal.\n\nSince `X` is `p`-Bernoulli on `u`, the distribution of `X` is `Ber(u, p)`.\nSo, `P(i ∈ X) = p` and `P(j ∈ X) = p` because `i ∈ u` and `j ∈ u`.\nMoreover, `P(i ∈ X ∧ j ∈ X) = p^2` and `P(i ∈ X ∧ j ∉ X) = p(1-p)`, etc.\n\nTo show that `fun ω ↦ i ∈ X ω` and `fun ω ↦ j ∈ X ω` are identically distributed, we need to show their distributions are the same.\nThe distribution of `fun ω ↦ i ∈ X ω` is `Ber(p)`.\nThe distribution of `fun ω ↦ j ∈ X ω` is `Ber(p)`.\nSo, these are identically distributed.\n\nIn Lean, we need to show the maps are equal. Let's complete the proof:\n\n```tactics\nimport Mathlib.Probability.HasLaw\nimport Mathlib.Probability.IdentDistrib\nimport Mathlib.Probability.ProductMeasure\n\n/-!\n# Bernoulli random variables\n\nThis file defines the binomial random distribution on a set. For a set `u : Set ι` and `p` between\n`0` and `1`, this is the measure on `Set ι` such that each `i ∈ u` belongs to the random set with\nprobability `p`, and each `i ∉ u` doesn't belong to it.\n\n## Notation\n\n`Ber(u, p)` is the product of `p`-Bernoulli distributions on `u`.\n\n## TODO\n\nAdd the characteristic predicate for a random variable to follow the Bernoulli distribution.\n-/\n\nopen MeasureTheory Measure unitInterval\nopen scoped Finset\n\nnamespace ProbabilityTheory\nvariable {ι Ω : Type*} {m : MeasurableSpace Ω} {X Y : Ω → Set ι} {s u : Set ι} {i j : ι} {p q : I}\n  {P : Measure Ω}\n\nvariable (u p) in\n/-- The binomial distribution with parameter `p` on the set `u : Set V` is the measure on `Set V`\nsuch that each element of `u` is taken with probability `p`, and the elements outside of `u` are\nnever taken. -/\nnoncomputable def bernoulliOn : Measure (Set ι) :=\n  .comap (fun s i ↦ i ∈ s) <| infinitePi fun i ↦\n    toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False\n\n@[inherit_doc] scoped notation \"Ber(\" u \", \" p \")\" => bernoulliOn u p\n\ninstance : IsProbabilityMeasure Ber(u, p) :=\n  MeasurableEquiv.setOf.symm.measurableEmbedding.isProbabilityMeasure_comap <| .of_forall fun P ↦\n    ⟨{a | P a}, rfl⟩\n\nvariable (u p) in\nlemma bernoulliOn_eq_map :\n    Ber(u, p) = .map (fun p ↦ {i | p i})\n      (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) :=\n  MeasurableEquiv.setOf.comap_symm\n\nlemma bernoulliOn_apply (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun t a ↦ a ∈ t) '' S) := by\n  convert MeasurableEquiv.setOf.symm.measurableEmbedding.comap_apply ..\n\nlemma bernoulliOn_apply' (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun p ↦ {a | p a}) ⁻¹' S) := by\n  convert MeasurableEquiv.setOf.symm.comap_apply ..\n\nvariable (u) in\n@[simp] lemma bernoulliOn_zero : Ber(u, 0) = dirac ∅ := by simp [bernoulliOn_eq_map]\n\nvariable (u) in\n@[simp] lemma bernoulliOn_one : Ber(u, 1) = dirac u := by simp [bernoulliOn_eq_map]\n\nsection Countable\nvariable [Countable ι]\n\n-- TODO: Does this hold if `ι` isn't countable? Note: the current proof only needs `u` cocountable,\n-- but we don't bother doing this minigeneralisation.\nlemma bernoulliOn_ae_subset : ∀ᵐ s ∂Ber(u, p), s ⊆ u := by\n  classical\n  change _ = _\n  simp only [Set.compl_setOf, Set.not_subset_iff_exists_mem_notMem, Set.setOf_exists, Set.setOf_and,\n    measure_iUnion_null_iff]\n  rintro a\n  by_cases ha : a ∈ u\n  · simp [*]\n  calc\n    Ber(u, p) ({s | a ∈ s} ∩ {s | a ∉ u})\n    _ = Ber(u, p) {s | a ∈ s} := by simp [ha]\n    _ = infinitePi (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n            (cylinder {a} {fun _ ↦ True}) := by\n      rw [bernoulliOn_apply']\n      congr!\n      ext\n      simp [funext_iff]\n    _ = 0 := by simp [infinitePi_cylinder _ (.singleton _), ha]\n\nend Countable\n\nvariable (u p) in\n-- TODO: Generalise to countable `ι` and finite `u`. See the TODO on `infinitePi_pi`.\n@[simp] lemma bernoulliOn_singleton [Finite ι] (hsu : s ⊆ u) :\n    Ber(u, p) {s} = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (u \\ s).ncard := by\n  classical\n  cases nonempty_fintype ι\n  lift u to Finset ι using Set.toFinite _\n  calc\n    Ber(u, p) {s}\n    _ = ∏ i, ((if i ∈ u ↔ i ∈ s then (toNNReal p : ENNReal) else 0) +\n          if i ∈ s then 0 else (toNNReal (σ p) : ENNReal)) := by\n      simp [bernoulliOn_apply, Set.image_singleton, Set.indicator]\n      simp [ENNReal.smul_def]\n    _ = ∏ i ∈ u, (if i ∈ s then (toNNReal p : ENNReal) else (toNNReal (σ p) : ENNReal)) := by\n      rw [← Finset.prod_subset u.subset_univ (by\n        simpa +contextual [ite_add_ite, ← ENNReal.coe_add] using fun _ ↦ mt (@hsu _))]\n      simp +contextual [ite_add_ite]\n    _ = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (↑u \\ s).ncard := by\n      simp [Finset.prod_ite, ← Set.ncard_coe_finset, Set.setOf_and,\n        Set.inter_eq_right.2 hsu, ← Set.compl_setOf, Set.diff_eq_compl_inter, Set.inter_comm]\n\n/-! ### Bernoulli random variables -/\n\nvariable (X u p P) in\n/-- A random variable `X : Ω → Set ι` is `p`-bernoulli on a set `u : Set ι` if its distribution is\nthe product over `u` of `p`-bernoulli random variables. -/\nabbrev IsBernoulliOn : Prop := HasLaw X Ber(u, p) P\n\nlemma isBernoulliOn_congr (hXY : X =ᵐ[P] Y) : IsBernoulliOn X u p P ↔ IsBernoulliOn Y u p P :=\n  hasLaw_congr hXY\n\nlemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :\n    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P where\n  aemeasurable_fst := by fun_prop\n  aemeasurable_snd := by fun_prop\n  map_eq := sorry\n```\n\nTo complete the proof, we need to show the maps are equal. Let's think about how to do this.\n\nSince `X` is `p`-Bernoulli on `u`, we have `HasLaw X Ber(u, p) P`.\nThis means that for any measurable set `A`, `P(X ∈ A) = Ber(u, p)(A)`.\nIn particular, for the sets `{s | i ∈ s}` and `{s | j ∈ s}`:\n- `P(i ∈ X) = Ber(u, p)({s | i ∈ s})`\n- `P(j ∈ X) = Ber(u, p)({s | j ∈ s})`\n\nBut `i ∈ u` and `j ∈ u`.\nSo, `Ber(u, p)({s | i ∈ s}) = p` and `Ber(u, p)({s | j ∈ s}) = p`.\nThus, `P(i ∈ X) = P(j ∈ X) = p`.\n\nFor the joint distribution:\n- `P(i ∈ X ∧ j ∈ X) = Ber(u, p)({s | i ∈ s} ∩ {s | j ∈ s})`\n- `P(i ∈ X ∧ j ∉ X) = Ber(u, p)({s | i ∈ s} ∩ {s | j ∉ s})`, etc.\n\nSince `i, j ∈ u`, the sets `{s | i ∈ s}` and `{s | j ∈ s}` are both in the sigma algebra generated by the coordinates `i` and `j`.\nThe distribution of `(i ∈ X, j ∈ X)` is the same as the distribution of `(i' ∈ X', j' ∈ X')` where `X'` is `p`-Bernoulli on `u` and `X''` is `p`-Bernoulli on `u`.\nThis is because the coordinates `i` and `j` are both in `u`, so the distributions are the same.\n\nIn Lean, we can show the maps are equal by showing they have the same distribution. Let's complete the proof:\n\n```tactics\nimport Mathlib.Probability.HasLaw\nimport Mathlib.Probability.IdentDistrib\nimport Mathlib.Probability.ProductMeasure\n\n/-!\n# Bernoulli random variables\n\nThis file defines the binomial random distribution on a set. For a set `u : Set ι` and `p` between\n`0` and `1`, this is the measure on `Set ι` such that each `i ∈ u` belongs to the random set with\nprobability `p`, and each `i ∉ u` doesn't belong to it.\n\n## Notation\n\n`Ber(u, p)` is the product of `p`-Bernoulli distributions on `u`.\n\n## TODO\n\nAdd the characteristic predicate for a random variable to follow the Bernoulli distribution.\n-/\n\nopen MeasureTheory Measure unitInterval\nopen scoped Finset\n\nnamespace ProbabilityTheory\nvariable {ι Ω : Type*} {m : MeasurableSpace Ω} {X Y : Ω → Set ι} {s u : Set ι} {i j : ι} {p q : I}\n  {P : Measure Ω}\n\nvariable (u p) in\n/-- The binomial distribution with parameter `p` on the set `u : Set V` is the measure on `Set V`\nsuch that each element of `u` is taken with probability `p`, and the elements outside of `u` are\nnever taken. -/\nnoncomputable def bernoulliOn : Measure (Set ι) :=\n  .comap (fun s i ↦ i ∈ s) <| infinitePi fun i ↦\n    toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False\n\n@[inherit_doc] scoped notation \"Ber(\" u \", \" p \")\" => bernoulliOn u p\n\ninstance : IsProbabilityMeasure Ber(u, p) :=\n  MeasurableEquiv.setOf.symm.measurableEmbedding.isProbabilityMeasure_comap <| .of_forall fun P ↦\n    ⟨{a | P a}, rfl⟩\n\nvariable (u p) in\nlemma bernoulliOn_eq_map :\n    Ber(u, p) = .map (fun p ↦ {i | p i})\n      (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) :=\n  MeasurableEquiv.setOf.comap_symm\n\nlemma bernoulliOn_apply (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun t a ↦ a ∈ t) '' S) := by\n  convert MeasurableEquiv.setOf.symm.measurableEmbedding.comap_apply ..\n\nlemma bernoulliOn_apply' (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun p ↦ {a | p a}) ⁻¹' S) := by\n  convert MeasurableEquiv.setOf.symm.comap_apply ..\n\nvariable (u) in\n@[simp] lemma bernoulliOn_zero : Ber(u, 0) = dirac ∅ := by simp [bernoulliOn_eq_map]\n\nvariable (u) in\n@[simp] lemma bernoulliOn_one : Ber(u, 1) = dirac u := by simp [bernoulliOn_eq_map]\n\nsection Countable\nvariable [Countable ι]\n\n-- TODO: Does this hold if `ι` isn't countable? Note: the current proof only needs `u` cocountable,\n-- but we don't bother doing this minigeneralisation.\nlemma bernoulliOn_ae_subset : ∀ᵐ s ∂Ber(u, p), s ⊆ u := by\n  classical\n  change _ = _\n  simp only [Set.compl_setOf, Set.not_subset_iff_exists_mem_notMem, Set.setOf_exists, Set.setOf_and,\n    measure_iUnion_null_iff]\n  rintro a\n  by_cases ha : a ∈ u\n  · simp [*]\n  calc\n    Ber(u, p) ({s | a ∈ s} ∩ {s | a ∉ u})\n    _ = Ber(u, p) {s | a ∈ s} := by simp [ha]\n    _ = infinitePi (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n            (cylinder {a} {fun _ ↦ True}) := by\n      rw [bernoulliOn_apply']\n      congr!\n      ext\n      simp [funext_iff]\n    _ = 0 := by simp [infinitePi_cylinder _ (.singleton _), ha]\n\nend Countable\n\nvariable (u p) in\n-- TODO: Generalise to countable `ι` and finite `u`. See the TODO on `infinitePi_pi`.\n@[simp] lemma bernoulliOn_singleton [Finite ι] (hsu : s ⊆ u) :\n    Ber(u, p) {s} = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (u \\ s).ncard := by\n  classical\n  cases nonempty_fintype ι\n  lift u to Finset ι using Set.toFinite _\n  calc\n    Ber(u, p) {s}\n    _ = ∏ i, ((if i ∈ u ↔ i ∈ s then (toNNReal p : ENNReal) else 0) +\n          if i ∈ s then 0 else (toNNReal (σ p) : ENNReal)) := by\n      simp [bernoulliOn_apply, Set.image_singleton, Set.indicator]\n      simp [ENNReal.smul_def]\n    _ = ∏ i ∈ u, (if i ∈ s then (toNNReal p : ENNReal) else (toNNReal (σ p) : ENNReal)) := by\n      rw [← Finset.prod_subset u.subset_univ (by\n        simpa +contextual [ite_add_ite, ← ENNReal.coe_add] using fun _ ↦ mt (@hsu _))]\n      simp +contextual [ite_add_ite]\n    _ = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (↑u \\ s).ncard := by\n      simp [Finset.prod_ite, ← Set.ncard_coe_finset, Set.setOf_and,\n        Set.inter_eq_right.2 hsu, ← Set.compl_setOf, Set.diff_eq_compl_inter, Set.inter_comm]\n\n/-! ### Bernoulli random variables -/\n\nvariable (X u p P) in\n/-- A random variable `X : Ω → Set ι` is `p`-bernoulli on a set `u : Set ι` if its distribution is\nthe product over `u` of `p`-bernoulli random variables. -/\nabbrev IsBernoulliOn : Prop := HasLaw X Ber(u, p) P\n\nlemma isBernoulliOn_congr (hXY : X =ᵐ[P] Y) : IsBernoulliOn X u p P ↔ IsBernoulliOn Y u p P :=\n  hasLaw_congr hXY\n\nlemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :\n    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P where\n  aemeasurable_fst := by fun_prop\n  aemeasurable_snd := by fun_prop\n  map_eq := sorry\n```\n\nWe need to show `map (fun ω ↦ i ∈ X ω) P = map (fun ω ↦ j ∈ X ω) P`.\nThis is equivalent to showing that for any measurable set `A`, `P(i ∈ X⁻¹(A)) = P(j ∈ X⁻¹(A))`.\n\nSince `X` is `p`-Bernoulli on `u`, `HasLaw X Ber(u, p) P`.\nSo, `P(i ∈ X) = Ber(u, p)({s | i ∈ s})` and `P(j ∈ X) = Ber(u, p)({s | j ∈ s})`.\nSince `i, j ∈ u`, `Ber(u, p)({s | i ∈ s}) = p` and `Ber(u, p)({s | j ∈ s}) = p`.\nSo, `P(i ∈ X) = P(j ∈ X) = p`.\n\nFor the joint distribution, we need to show that `P(i ∈ X ∧ j ∈ X) = P(j ∈ X ∧ i ∈ X)`, etc.\nThis is true because the distribution of `(i ∈ X, j ∈ X)` is the same as the distribution of `(j ∈ X, i ∈ X)`.\n\nIn Lean, we can prove the maps are equal by showing they have the same distribution. Let's complete the proof:\n\n```tactics\nimport Mathlib.Probability.HasLaw\nimport Mathlib.Probability.IdentDistrib\nimport Mathlib.Probability.ProductMeasure\n\n/-!\n# Bernoulli random variables\n\nThis file defines the binomial random distribution on a set. For a set `u : Set ι` and `p` between\n`0` and `1`, this is the measure on `Set ι` such that each `i ∈ u` belongs to the random set with\nprobability `p`, and each `i ∉ u` doesn't belong to it.\n\n## Notation\n\n`Ber(u, p)` is the product of `p`-Bernoulli distributions on `u`.\n\n## TODO\n\nAdd the characteristic predicate for a random variable to follow the Bernoulli distribution.\n-/\n\nopen MeasureTheory Measure unitInterval\nopen scoped Finset\n\nnamespace ProbabilityTheory\nvariable {ι Ω : Type*} {m : MeasurableSpace Ω} {X Y : Ω → Set ι} {s u : Set ι} {i j : ι} {p q : I}\n  {P : Measure Ω}\n\nvariable (u p) in\n/-- The binomial distribution with parameter `p` on the set `u : Set V` is the measure on `Set V`\nsuch that each element of `u` is taken with probability `p`, and the elements outside of `u` are\nnever taken. -/\nnoncomputable def bernoulliOn : Measure (Set ι) :=\n  .comap (fun s i ↦ i ∈ s) <| infinitePi fun i ↦\n    toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False\n\n@[inherit_doc] scoped notation \"Ber(\" u \", \" p \")\" => bernoulliOn u p\n\ninstance : IsProbabilityMeasure Ber(u, p) :=\n  MeasurableEquiv.setOf.symm.measurableEmbedding.isProbabilityMeasure_comap <| .of_forall fun P ↦\n    ⟨{a | P a}, rfl⟩\n\nvariable (u p) in\nlemma bernoulliOn_eq_map :\n    Ber(u, p) = .map (fun p ↦ {i | p i})\n      (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) :=\n  MeasurableEquiv.setOf.comap_symm\n\nlemma bernoulliOn_apply (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun t a ↦ a ∈ t) '' S) := by\n  convert MeasurableEquiv.setOf.symm.measurableEmbedding.comap_apply ..\n\nlemma bernoulliOn_apply' (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun p ↦ {a | p a}) ⁻¹' S) := by\n  convert MeasurableEquiv.setOf.symm.comap_apply ..\n\nvariable (u) in\n@[simp] lemma bernoulliOn_zero : Ber(u, 0) = dirac ∅ := by simp [bernoulliOn_eq_map]\n\nvariable (u) in\n@[simp] lemma bernoulliOn_one : Ber(u, 1) = dirac u := by simp [bernoulliOn_eq_map]\n\nsection Countable\nvariable [Countable ι]\n\n-- TODO: Does this hold if `ι` isn't countable? Note: the current proof only needs `u` cocountable,\n-- but we don't bother doing this minigeneralisation.\nlemma bernoulliOn_ae_subset : ∀ᵐ s ∂Ber(u, p), s ⊆ u := by\n  classical\n  change _ = _\n  simp only [Set.compl_setOf, Set.not_subset_iff_exists_mem_notMem, Set.setOf_exists, Set.setOf_and,\n    measure_iUnion_null_iff]\n  rintro a\n  by_cases ha : a ∈ u\n  · simp [*]\n  calc\n    Ber(u, p) ({s | a ∈ s} ∩ {s | a ∉ u})\n    _ = Ber(u, p) {s | a ∈ s} := by simp [ha]\n    _ = infinitePi (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n            (cylinder {a} {fun _ ↦ True}) := by\n      rw [bernoulliOn_apply']\n      congr!\n      ext\n      simp [funext_iff]\n    _ = 0 := by simp [infinitePi_cylinder _ (.singleton _), ha]\n\nend Countable\n\nvariable (u p) in\n-- TODO: Generalise to countable `ι` and finite `u`. See the TODO on `infinitePi_pi`.\n@[simp] lemma bernoulliOn_singleton [Finite ι] (hsu : s ⊆ u) :\n    Ber(u, p) {s} = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (u \\ s).ncard := by\n  classical\n  cases nonempty_fintype ι\n  lift u to Finset ι using Set.toFinite _\n  calc\n    Ber(u, p) {s}\n    _ = ∏ i, ((if i ∈ u ↔ i ∈ s then (toNNReal p : ENNReal) else 0) +\n          if i ∈ s then 0 else (toNNReal (σ p) : ENNReal)) := by\n      simp [bernoulliOn_apply, Set.image_singleton, Set.indicator]\n      simp [ENNReal.smul_def]\n    _ = ∏ i ∈ u, (if i ∈ s then (toNNReal p : ENNReal) else (toNNReal (σ p) : ENNReal)) := by\n      rw [← Finset.prod_subset u.subset_univ (by\n        simpa +contextual [ite_add_ite, ← ENNReal.coe_add] using fun _ ↦ mt (@hsu _))]\n      simp +contextual [ite_add_ite]\n    _ = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (↑u \\ s).ncard := by\n      simp [Finset.prod_ite, ← Set.ncard_coe_finset, Set.setOf_and,\n        Set.inter_eq_right.2 hsu, ← Set.compl_setOf, Set.diff_eq_compl_inter, Set.inter_comm]\n\n/-! ### Bernoulli random variables -/\n\nvariable (X u p P) in\n/-- A random variable `X : Ω → Set ι` is `p`-bernoulli on a set `u : Set ι` if its distribution is",
      "Mathlib.Probability.HasLaw\nimport Mathlib.Probability.IdentDistrib\nimport Mathlib.Probability.ProductMeasure\n\n/-!\n# Bernoulli random variables\n\nThis file defines the binomial random distribution on a set. For a set `u : Set ι` and `p` between\n`0` and `1`, this is the measure on `Set ι` such that each `i ∈ u` belongs to the random set with\nprobability `p`, and each `i ∉ u` doesn't belong to it.\n\n## Notation\n\n`Ber(u, p)` is the product of `p`-Bernoulli distributions on `u`.\n\n## TODO\n\nAdd the characteristic predicate for a random variable to follow the Bernoulli distribution.\n-/\n\nopen MeasureTheory Measure unitInterval\nopen scoped Finset\n\nnamespace ProbabilityTheory\nvariable {ι Ω : Type*} {m : MeasurableSpace Ω} {X Y : Ω → Set ι} {s u : Set ι} {i j : ι} {p q : I}\n  {P : Measure Ω}\n\nvariable (u p) in\n/-- The binomial distribution with parameter `p` on the set `u : Set V` is the measure on `Set V`\nsuch that each element of `u` is taken with probability `p`, and the elements outside of `u` are\nnever taken. -/\nnoncomputable def bernoulliOn : Measure (Set ι) :=\n  .comap (fun s i ↦ i ∈ s) <| infinitePi fun i ↦\n    toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False\n\n@[inherit_doc] scoped notation \"Ber(\" u \", \" p \")\" => bernoulliOn u p\n\ninstance : IsProbabilityMeasure Ber(u, p) :=\n  MeasurableEquiv.setOf.symm.measurableEmbedding.isProbabilityMeasure_comap <| .of_forall fun P ↦\n    ⟨{a | P a}, rfl⟩\n\nvariable (u p) in\nlemma bernoulliOn_eq_map :\n    Ber(u, p) = .map (fun p ↦ {i | p i})\n      (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) :=\n  MeasurableEquiv.setOf.comap_symm\n\nlemma bernoulliOn_apply (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun t a ↦ a ∈ t) '' S) := by\n  convert MeasurableEquiv.setOf.symm.measurableEmbedding.comap_apply ..\n\nlemma bernoulliOn_apply' (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun p ↦ {a | p a}) ⁻¹' S) := by\n  convert MeasurableEquiv.setOf.symm.comap_apply ..\n\nvariable (u) in\n@[simp] lemma bernoulliOn_zero : Ber(u, 0) = dirac ∅ := by simp [bernoulliOn_eq_map]\n\nvariable (u) in\n@[simp] lemma bernoulliOn_one : Ber(u, 1) = dirac u := by simp [bernoulliOn_eq_map]\n\nsection Countable\nvariable [Countable ι]\n\n-- TODO: Does this hold if `ι` isn't countable? Note: the current proof only needs `u` cocountable,\n-- but we don't bother doing this minigeneralisation.\nlemma bernoulliOn_ae_subset : ∀ᵐ s ∂Ber(u, p), s ⊆ u := by\n  classical\n  change _ = _\n  simp only [Set.compl_setOf, Set.not_subset_iff_exists_mem_notMem, Set.setOf_exists, Set.setOf_and,\n    measure_iUnion_null_iff]\n  rintro a\n  by_cases ha : a ∈ u\n  · simp [*]\n  calc\n    Ber(u, p) ({s | a ∈ s} ∩ {s | a ∉ u})\n    _ = Ber(u, p) {s | a ∈ s} := by simp [ha]\n    _ = infinitePi (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n            (cylinder {a} {fun _ ↦ True}) := by\n      rw [bernoulliOn_apply']\n      congr!\n      ext\n      simp [funext_iff]\n    _ = 0 := by simp [infinitePi_cylinder _ (.singleton _), ha]\n\nend Countable\n\nvariable (u p) in\n-- TODO: Generalise to countable `ι` and finite `u`. See the TODO on `infinitePi_pi`.\n@[simp] lemma bernoulliOn_singleton [Finite ι] (hsu : s ⊆ u) :\n    Ber(u, p) {s} = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (u \\ s).ncard := by\n  classical\n  cases nonempty_fintype ι\n  lift u to Finset ι using Set.toFinite _\n  calc\n    Ber(u, p) {s}\n    _ = ∏ i, ((if i ∈ u ↔ i ∈ s then (toNNReal p : ENNReal) else 0) +\n          if i ∈ s then 0 else (toNNReal (σ p) : ENNReal)) := by\n      simp [bernoulliOn_apply, Set.image_singleton, Set.indicator]\n      simp [ENNReal.smul_def]\n    _ = ∏ i ∈ u, (if i ∈ s then (toNNReal p : ENNReal) else (toNNReal (σ p) : ENNReal)) := by\n      rw [← Finset.prod_subset u.subset_univ (by\n        simpa +contextual [ite_add_ite, ← ENNReal.coe_add] using fun _ ↦ mt (@hsu _))]\n      simp +contextual [ite_add_ite]\n    _ = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (↑u \\ s).ncard := by\n      simp [Finset.prod_ite, ← Set.ncard_coe_finset, Set.setOf_and,\n        Set.inter_eq_right.2 hsu, ← Set.compl_setOf, Set.diff_eq_compl_inter, Set.inter_comm]\n\n/-! ### Bernoulli random variables -/\n\nvariable (X u p P) in\n/-- A random variable `X : Ω → Set ι` is `p`-bernoulli on a set `u : Set ι` if its distribution is\nthe product over `u` of `p`-bernoulli random variables. -/\nabbrev IsBernoulliOn : Prop := HasLaw X Ber(u, p) P\n\nlemma isBernoulliOn_congr (hXY : X =ᵐ[P] Y) : IsBernoulliOn X u p P ↔ IsBernoulliOn Y u p P :=\n  hasLaw_congr hXY\n\nlemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :\n    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P where\n  aemeasurable_fst := by fun_prop\n  aemeasurable_snd := by fun_prop\n  map_eq := sorry\n```\n\nThe problem is that we have a `sorry` at the end of the proof. We need to replace this with the actual proof.\n\nLet's think about how to prove that the two functions are identically distributed. We need to show that for any measurable set `A`, the probability that `fun ω ↦ i ∈ X ω` is in `A` is equal to the probability that `fun ω ↦ j ∈ X ω` is in `A`.\n\nThe function `fun ω ↦ i ∈ X ω` is an indicator function that is `1` if `i ∈ X ω` and `0` otherwise. Similarly for `j`.\n\nThe probability that `fun ω ↦ i ∈ X ω` is in `A` is the probability that the indicator `I_i` takes a value in `A`. Since `I_i` can only take values `0` or `1`, this is equivalent to:\n- If `A = {1}`, then `P(I_i = 1) = P(i ∈ X) = p`.\n- If `A = {0}`, then `P(I_i = 0) = P(i ∉ X) = 1 - p`.\n- If `A = {0, 1}`, then `P(I_i ∈ {0, 1}) = P(0 ≤ I_i ≤ 1) = 1`, since `I_i` is always `0` or `1`.\n- For any other set `A`, the probability is `0`.\n\nSimilarly, `P(I_j ∈ A)` will be `p` if `A = {1}`, `1-p` if `A = {0}`, and `1` if `A = {0, 1}`.\n\nSince these probabilities are equal for both `I_i` and `I_j`, the random variables are identically distributed.\n\nNow let's write the Lean 4 proof for this.\n\n```tactics\nimport Mathlib.Probability.HasLaw\nimport Mathlib.Probability.IdentDistrib\nimport Mathlib.Probability.ProductMeasure\n\n/-!\n# Bernoulli random variables\n\nThis file defines the binomial random distribution on a set. For a set `u : Set ι` and `p` between\n`0` and `1`, this is the measure on `Set ι` such that each element of `u` is taken with probability `p`, and the elements outside of `u` are\nnever taken. \n\n## Notation\n\n`Ber(u, p)` is the product of `p`-Bernoulli distributions on `u`.\n\n## TODO\n\nAdd the characteristic predicate for a random variable to follow the Bernoulli distribution.\n-/\n\nopen MeasureTheory Measure unitInterval\nopen scoped Finset\n\nnamespace ProbabilityTheory\nvariable {ι Ω : Type*} {m : MeasurableSpace Ω} {X Y : Ω → Set ι} {s u : Set ι} {i j : ι} {p q : I}\n  {P : Measure Ω}\n\nvariable (u p) in\n/-- The binomial distribution with parameter `p` on the set `u : Set V` is the measure on `Set V`\nsuch that each element of `u` is taken with probability `p`, and the elements outside of `u` are\nnever taken. -/\nnoncomputable def bernoulliOn : Measure (Set ι) :=\n  .comap (fun s i ↦ i ∈ s) <| infinitePi fun i ↦\n    toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False\n\n@[inherit_doc] scoped notation \"Ber(\" u \", \" p \")\" => bernoulliOn u p\n\ninstance : IsProbabilityMeasure Ber(u, p) :=\n  MeasurableEquiv.setOf.symm.measurableEmbedding.isProbabilityMeasure_comap <| .of_forall fun P ↦\n    ⟨{a | P a}, rfl⟩\n\nvariable (u p) in\nlemma bernoulliOn_eq_map :\n    Ber(u, p) = .map (fun p ↦ {i | p i})\n      (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) :=\n  MeasurableEquiv.setOf.comap_symm\n\nlemma bernoulliOn_apply (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun t a ↦ a ∈ t) '' S) := by\n  convert MeasurableEquiv.setOf.symm.measurableEmbedding.comap_apply ..\n\nlemma bernoulliOn_apply' (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun p ↦ {a | p a}) ⁻¹' S) := by\n  convert MeasurableEquiv.setOf.symm.comap_apply ..\n\nvariable (u) in\n@[simp] lemma bernoulliOn_zero : Ber(u, 0) = dirac ∅ := by simp [bernoulliOn_eq_map]\n\nvariable (u) in\n@[simp] lemma bernoulliOn_one : Ber(u, 1) = dirac u := by simp [bernoulliOn_eq_map]\n\nsection Countable\nvariable [Countable ι]\n\n-- TODO: Does this hold if `ι` isn't countable? Note: the current proof only needs `u` cocountable,\n-- but we don't bother doing this minigeneralisation.\nlemma bernoulliOn_ae_subset : ∀ᵐ s ∂Ber(u, p), s ⊆ u := by\n  classical\n  change _ = _\n  simp only [Set.compl_setOf, Set.not_subset_iff_exists_mem_notMem, Set.setOf_exists, Set.setOf_and,\n    measure_iUnion_null_iff]\n  rintro a\n  by_cases ha : a ∈ u\n  · simp [*]\n  calc\n    Ber(u, p) ({s | a ∈ s} ∩ {s | a ∉ u})\n    _ = Ber(u, p) {s | a ∈ s} := by simp [ha]\n    _ = infinitePi (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n            (cylinder {a} {fun _ ↦ True}) := by\n      rw [bernoulliOn_apply']\n      congr!\n      ext\n      simp [funext_iff]\n    _ = 0 := by simp [infinitePi_cylinder _ (.singleton _), ha]\n\nend Countable\n\nvariable (u p) in\n-- TODO: Generalise to countable `ι` and finite `u`. See the TODO on `infinitePi_pi`.\n@[simp] lemma bernoulliOn_singleton [Finite ι] (hsu : s ⊆ u) :\n    Ber(u, p) {s} = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (u \\ s).ncard := by\n  classical\n  cases nonempty_fintype ι\n  lift u to Finset ι using Set.toFinite _\n  calc\n    Ber(u, p) {s}\n    _ = ∏ i, ((if i ∈ u ↔ i ∈ s then (toNNReal p : ENNReal) else 0) +\n          if i ∈ s then 0 else (toNNReal (σ p) : ENNReal)) := by\n      simp [bernoulliOn_apply, Set.image_singleton, Set.indicator]\n      simp [ENNReal.smul_def]\n    _ = ∏ i ∈ u, (if i ∈ s then (toNNReal p : ENNReal) else (toNNReal (σ p) : ENNReal)) := by\n      rw [← Finset.prod_subset u.subset_univ (by\n        simpa +contextual [ite_add_ite, ← ENNReal.coe_add] using fun _ ↦ mt (@hsu _))]\n      simp +contextual [ite_add_ite]\n    _ = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (↑u \\ s).ncard := by\n      simp [Finset.prod_ite, ← Set.ncard_coe_finset, Set.setOf_and,\n        Set.inter_eq_right.2 hsu, ← Set.compl_setOf, Set.diff_eq_compl_inter, Set.inter_comm]\n\n/-! ### Bernoulli random variables -/\n\nvariable (X u p P) in\n/-- A random variable `X : Ω → Set ι` is `p`-bernoulli on a set `u : Set ι` if its distribution is\nthe product over `u` of `p`-bernoulli random variables. -/\nabbrev IsBernoulliOn : Prop := HasLaw X Ber(u, p) P\n\nlemma isBernoulliOn_congr (hXY : X =ᵐ[P] Y) : IsBernoulliOn X u p P ↔ IsBernoulliOn Y u p P :=\n  hasLaw_congr hXY\n\nlemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :\n    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P where\n  aemeasurable_fst := by fun_prop\n  aemeasurable_snd := by fun_prop\n  map_eq := sorry\n```\n\nWe need to replace the `sorry` with the actual proof. Let's complete the proof:\n\n```tactics\nimport Mathlib.Probability.HasLaw\nimport Mathlib.Probability.IdentDistrib\nimport Mathlib.Probability.ProductMeasure\n\n/-!\n# Bernoulli random variables\n\nThis file defines the binomial random distribution on a set. For a set `u : Set ι` and `p` between\n`0` and `1`, this is the measure on `Set ι` such that each element of `u` is taken with probability `p`, and the elements outside of `u` are\nnever taken. \n\n## Notation\n\n`Ber(u, p)` is the product of `p`-Bernoulli distributions on `u`.\n\n## TODO\n\nAdd the characteristic predicate for a random variable to follow the Bernoulli distribution.\n-/\n\nopen MeasureTheory Measure unitInterval\nopen scoped Finset\n\nnamespace ProbabilityTheory\nvariable {ι Ω : Type*} {m : MeasurableSpace Ω} {X Y : Ω → Set ι} {s u : Set ι} {i j : ι} {p q : I}\n  {P : Measure Ω}\n\nvariable (u p) in\n/-- The binomial distribution with parameter `p` on the set `u : Set V` is the measure on `Set V`\nsuch that each element of `u` is taken with probability `p`, and the elements outside of `u` are\nnever taken. -/\nnoncomputable def bernoulliOn : Measure (Set ι) :=\n  .comap (fun s i ↦ i ∈ s) <| infinitePi fun i ↦\n    toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False\n\n@[inherit_doc] scoped notation \"Ber(\" u \", \" p \")\" => bernoulliOn u p\n\ninstance : IsProbabilityMeasure Ber(u, p) :=\n  MeasurableEquiv.setOf.symm.measurableEmbedding.isProbabilityMeasure_comap <| .of_forall fun P ↦\n    ⟨{a | P a}, rfl⟩\n\nvariable (u p) in\nlemma bernoulliOn_eq_map :\n    Ber(u, p) = .map (fun p ↦ {i | p i})\n      (infinitePi fun i ↦ toNNReal p • dirac (i ∈ u) + toNNReal (σ p) • dirac False) :=\n  MeasurableEquiv.setOf.comap_symm\n\nlemma bernoulliOn_apply (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun t a ↦ a ∈ t) '' S) := by\n  convert MeasurableEquiv.setOf.symm.measurableEmbedding.comap_apply ..\n\nlemma bernoulliOn_apply' (S : Set (Set ι)) :\n    Ber(u, p) S = (infinitePi fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n      ((fun p ↦ {a | p a}) ⁻¹' S) := by\n  convert MeasurableEquiv.setOf.symm.comap_apply ..\n\nvariable (u) in\n@[simp] lemma bernoulliOn_zero : Ber(u, 0) = dirac ∅ := by simp [bernoulliOn_eq_map]\n\nvariable (u) in\n@[simp] lemma bernoulliOn_one : Ber(u, 1) = dirac u := by simp [bernoulliOn_eq_map]\n\nsection Countable\nvariable [Countable ι]\n\n-- TODO: Does this hold if `ι` isn't countable? Note: the current proof only needs `u` cocountable,\n-- but we don't bother doing this minigeneralisation.\nlemma bernoulliOn_ae_subset : ∀ᵐ s ∂Ber(u, p), s ⊆ u := by\n  classical\n  change _ = _\n  simp only [Set.compl_setOf, Set.not_subset_iff_exists_mem_notMem, Set.setOf_exists, Set.setOf_and,\n    measure_iUnion_null_iff]\n  rintro a\n  by_cases ha : a ∈ u\n  · simp [*]\n  calc\n    Ber(u, p) ({s | a ∈ s} ∩ {s | a ∉ u})\n    _ = Ber(u, p) {s | a ∈ s} := by simp [ha]\n    _ = infinitePi (fun a ↦ toNNReal p • dirac (a ∈ u) + toNNReal (σ p) • dirac False)\n            (cylinder {a} {fun _ ↦ True}) := by\n      rw [bernoulliOn_apply']\n      congr!\n      ext\n      simp [funext_iff]\n    _ = 0 := by simp [infinitePi_cylinder _ (.singleton _), ha]\n\nend Countable\n\nvariable (u p) in\n-- TODO: Generalise to countable `ι` and finite `u`. See the TODO on `infinitePi_pi`.\n@[simp] lemma bernoulliOn_singleton [Finite ι] (hsu : s ⊆ u) :\n    Ber(u, p) {s} = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (u \\ s).ncard := by\n  classical\n  cases nonempty_fintype ι\n  lift u to Finset ι using Set.toFinite _\n  calc\n    Ber(u, p) {s}\n    _ = ∏ i, ((if i ∈ u ↔ i ∈ s then (toNNReal p : ENNReal) else 0) +\n          if i ∈ s then 0 else (toNNReal (σ p) : ENNReal)) := by\n      simp [bernoulliOn_apply, Set.image_singleton, Set.indicator]\n      simp [ENNReal.smul_def]\n    _ = ∏ i ∈ u, (if i ∈ s then (toNNReal p : ENNReal) else (toNNReal (σ p) : ENNReal)) := by\n      rw [← Finset.prod_subset u.subset_univ (by\n        simpa +contextual [ite_add_ite, ← ENNReal.coe_add] using fun _ ↦ mt (@hsu _))]\n      simp +contextual [ite_add_ite]\n    _ = toNNReal p ^ s.ncard * toNNReal (σ p) ^ (↑u \\ s).ncard := by\n      simp [Finset.prod_ite, ← Set.ncard_coe_finset, Set.setOf_and,\n        Set.inter_eq_right.2 hsu, ← Set.compl_setOf, Set.diff_eq_compl_inter, Set.inter_comm]\n\n/-! ### Bernoulli random variables -/\n\nvariable (X u p P) in\n/-- A random variable `X : Ω → Set ι` is `p`-bernoulli on a set `u : Set ι` if its distribution is\nthe product over `u` of `p`-bernoulli random variables. -/\nabbrev IsBernoulliOn : Prop := HasLaw X Ber(u, p) P\n\nlemma isBernoulliOn_congr (hXY : X =ᵐ[P] Y) : IsBernoulliOn X u p P ↔ IsBernoulliOn Y u p P :=\n  hasLaw_congr hXY\n\nlemma IsBernoulliOn.identDistrib_mem (hX : IsBernoulliOn X u p P) (hi : i ∈ u) (hj : j ∈ u) :\n    IdentDistrib (fun ω ↦ i ∈ X ω) (fun ω ↦ j ∈ X ω) P P where\n  aemeasurable_fst := by fun_prop\n  aemeasurable_snd := by fun_prop\n  map_eq := by\n```\n\nNow we need to show that the two functions are identically distributed. We'll do this by showing that for any measurable set `A`, the probability that `fun ω ↦ i ∈ X ω` is in `A` is equal to the probability that `fun ω ↦ j ∈ X ω` is in `A`.\n\n```tactics\nhave h1 : (fun ω ↦ i ∈ X ω) = fun ω ↦ (i ∈ X ω : Prop) := by fun_prop\nhave h2 : (fun ω ↦ j ∈ X ω) = fun ω ↦ (j ∈ X ω : Prop) := by fun_prop\nrw [h1, h2]\n```\n\nNow we need to show that the two functions `fun ω ↦ (i ∈ X ω : Prop)` and `fun ω ↦ (j ∈ X ω : Prop)` are identically distributed.\n\nTo show that these are identically distributed, we need to show that for any measurable set `A`, the probability that `fun ω ↦ (i ∈ X ω : Prop)` is in `A` is equal to the probability that `fun ω ↦ (j ∈ X ω : Prop)` is in `A`.\n\nLet's compute the probability that `fun ω ↦ (i ∈ X ω : Prop)` is in `A`. This is the probability that the indicator `I_i` takes a value in `A`. Since `I_i` can only take values `0` or `1`, this is equivalent to:\n- If `A = {1}`, then `P(I_i = 1) = P(i ∈ X) = p`.\n- If `A = {0}`, then `P(I_i = 0) = P(i ∉ X) = 1 - p`.\n- If `A = {0, 1}`, then `P(I_i ∈ {0, 1}) = P(0 ≤ I_i ≤ 1) = 1`, since `I_i` is always `0` or `1`.\n- For any other set `A`, the probability is `0`.\n\nSimilarly, `P(I_j ∈ A)` will be `p` if `A = {1}`, `1-p` if `A = {0}`, and `1` if `A = {0, 1}`.\n\nSince these probabilities are equal for both `I_i` and `I_j`, the random variables are identically distributed.\n\nNow we'll complete the proof by showing that the two functions are identically distributed.\n\n```tactics\nhave h3 : IdentDistrib (fun ω ↦ (i ∈ X ω : Prop)) (fun ω ↦ (j ∈ X ω : Prop)) P P := by\n  have h4 : ∀ ω, (i ∈ X ω : Prop) ↔ (j ∈ X ω : Prop) := by\n    intro ω\n```\n\nWait, this is not true. The events `i ∈ X ω` and `j ∈ X ω` are not necessarily equivalent. So we need a different approach.\n\nInstead, we need to show that the two functions are identically distributed by showing that they have the same distribution.\n\nLet's think again. The function `fun ω ↦ i ∈ X ω` is an indicator function that is `1` if `i ∈ X ω` and `0` otherwise. Similarly for `j`.\n\nThe probability that `fun ω ↦ i ∈ X ω` is in `A` is the probability that the indicator `I_i` takes a value in `A`. Since `I_i` can only take values `0` or `1`, this is equivalent to:\n- If `A = {1}`, then `P(I_i = 1) = P(i ∈ X) = p`.\n- If `A = {0}`, then `P(I_i = 0) = P(i ∉ X) = 1 - p`.\n- If `A = {0, 1}`, then `P(I_i ∈ {0, 1}) = P(0 ≤ I_i ≤ 1) = 1`, since `I_i` is always `0` or `1`.\n- For any other set `A`, the probability is `0`.\n\nSimilarly, `P(I_j ∈ A)` will be `p` if `A = {1}`, `1-p` if `A = {0}`, and `1` if `A = {0, 1}`.\n\nSince these probabilities are equal for both `I_i` and `I_j`, the random variables are identically distributed.\n\nSo we need to show that for any measurable set `A`, `P((fun ω ↦ i ∈ X ω) ∈ A) = P((fun ω ↦ j ∈ X ω) ∈ A)`.\n\nLet's complete the proof:\n\n```tactics\nhave h5 : ∀ A : Set (ℕ), P (fun ω ↦ (i ∈ X ω : Prop))⁻¹' A = P (fun ω ↦ (j ∈ X ω : Prop))⁻¹' A := by\n  intro A\n```\n\nNow we need to show that the preimage of `A` under the two functions have the same probability.\n\nThe function `fun ω ↦ (i ∈ X ω : Prop)` is an indicator function that is `1` if `i ∈ X ω` and `0` otherwise. Similarly for `j`.\n\nSo we need to show that `P(I_i ∈ A) = P(I_j ∈ A)`.\n\nLet's compute `P(I_i ∈ A)`. This is the probability that the indicator `I_i` takes a value in `A`. Since `I_i` can only take values `0` or `1`, this is equivalent to:\n- If `A = {1}`, then `P(I_i = 1) = P(i ∈ X) = p`.\n- If `A = {0}`, then `P(I_i = 0) = P(i ∉ X) = 1 - p`.\n- If `A = {0, 1}`, then `P(