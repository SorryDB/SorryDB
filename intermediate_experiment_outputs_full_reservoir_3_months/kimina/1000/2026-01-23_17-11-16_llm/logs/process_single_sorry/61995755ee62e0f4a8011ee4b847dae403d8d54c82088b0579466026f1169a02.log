def Hom_c_? {α : Type*} [Category α] (c : α) : Functor α Type where
  F Y := Hom c Y
  homF {Y Z : α} (f : Hom Y Z) (g : Hom c Y) := g ≫ f
  map_id Y := by 
    simp [comp_eq_left, id_eq]
  map_comp {Y Z W : α} (f : Hom Y Z) (g : Hom Z W) :
    (fun g_1 => g_1 ≫ f) ≫ (fun h => h ≫ g) = fun h => h ≫ (f ≫ g) := by
    funext h
