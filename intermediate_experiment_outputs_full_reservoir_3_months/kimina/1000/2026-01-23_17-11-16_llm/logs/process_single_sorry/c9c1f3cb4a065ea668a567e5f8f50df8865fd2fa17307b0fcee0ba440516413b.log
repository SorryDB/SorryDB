      Real.logb 2 (k : ℕ) ≥ R*n ∧
      B.εApproximates CPTPMap.id ε

noncomputable def quantumCapacity (A : CPTPMap d₁ d₂) : ℝ :=
  sSup { R : ℝ | AchievesRate A R }

