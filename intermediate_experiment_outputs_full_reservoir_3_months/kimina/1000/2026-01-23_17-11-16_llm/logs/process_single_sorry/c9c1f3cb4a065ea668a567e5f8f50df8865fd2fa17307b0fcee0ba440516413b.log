  use 1, zero_lt_one, 1, ⟨x, hx⟩ -- assuming d₂ is Fin 1 and x is its element
  constructor
  · -- need to show Nonempty d₁
    infer_instance
  constructor
  · -- need to show Nonempty d₂
    infer_instance
  constructor
  · -- need to show (CPTPMap.piProd (fun (_ : Fin 1) ↦ Λ)).Emulates (id : CPTPMap (Fin 1) (Fin 1))
