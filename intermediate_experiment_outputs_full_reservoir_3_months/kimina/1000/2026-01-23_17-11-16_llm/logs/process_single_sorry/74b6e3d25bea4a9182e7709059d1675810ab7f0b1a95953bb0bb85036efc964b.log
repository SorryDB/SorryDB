  F Y := Hom c Y
  homF {Y Z : α} (f : Hom Y Z) (g : Hom c Y) := g ≫ f
  map_id Y := by
    simp [map_id]
    all_goals aesop
  map_comp f g := by
    simp [map_comp]
    all_goals aesop
