def StateCofixFinal (F : TypeVec.{u} (n + 1) → Type u) [MvQPF F] (α : TypeVec.{u} n) : Type u :=
  Quot (Cofix F α) (fun c d => ∃ R, IsBisim (Cofix.mk' F α R) ∧ R c d)

