  map_mul' := by
    simp [g.map_mul', f.map_mul']
  map_zero' := by
    have h1 : f 0 = 0 := by 
      simpa using f.map_zero'
    have h2 : g 0 = 0 := by 
      simpa using g.map_zero'
    rw [h1]
    exact h2
