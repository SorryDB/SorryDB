  F X := C.Hom X.1 X.2
  homF {X Y} f g := f.1 ≫ g ≫ f.2
  map_id X := by
    funext g
    simp [Category.id]
    rw [id_comp]
    rw [comp_id]
  map_comp f g := by
    funext h
    simp [comp]
    repeat rw [assoc]

