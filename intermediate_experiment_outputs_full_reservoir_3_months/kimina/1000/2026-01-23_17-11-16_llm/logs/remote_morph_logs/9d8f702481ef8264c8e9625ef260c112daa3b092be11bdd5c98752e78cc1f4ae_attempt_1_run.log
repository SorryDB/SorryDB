noncomputable instance Category.Preorder (α : Type*) [Preorder α] : Category α where
  Hom X Y := PLift (X ≤ Y) -- some universe gymnastics to move between Prop and Type
  id X := ⟨le_refl X⟩
  comp f g := ⟨le_trans f.down g.down⟩
  id_comp _ := rfl
  comp_id _ := rfl
  assoc _ _ _ := rfl

theorem preorder_cat_functor {α β : Type*} [Preorder α] [Preorder β]
    (F : @CategoryInContext.Functor α β (@CategoryInContext.Category.Preorder α inst) (@CategoryInContext.Category.Preorder β inst)) :
    ∃ f,
    Monotone f ∧
      ∀ (x : α),
        @CategoryInContext.Functor.F α β (@CategoryInContext.Category.Preorder α inst) (@CategoryInContext.Category.Preorder β inst) F x =
          f x := by
  use λ x => F x
  constructor
  · -- Show f is monotone
    intro x y hxy
    have h1 : @CategoryInContext.Functor.F α β (@CategoryInContext.Category.Preorder α inst) (@CategoryInContext.Category.Preorder β inst) F x ≤
        @CategoryInContext.Functor.F α β (@CategoryInContext.Category.Preorder α inst) (@CategoryInContext.Category.Preorder β inst) F y := by
      have h2 : (x : α) ≤ (y : α) := hxy
