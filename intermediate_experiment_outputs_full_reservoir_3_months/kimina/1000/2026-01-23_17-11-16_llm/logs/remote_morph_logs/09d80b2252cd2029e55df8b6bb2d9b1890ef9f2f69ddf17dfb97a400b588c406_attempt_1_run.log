        simp;
      . assumption;
    . assumption;

lemma construction_omega_andClosed :
  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
    intro hφ hψ
    have h3 : φ ⋏ ψ ∈ U := by
