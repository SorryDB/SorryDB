        have : δ = φ := by grind;
        subst this;
        apply h Γ ((show encode δ = i by sorry) ▸ hΓ) hφ;
      . assumption
    . assumption;

lemma of_not_mem_construction_omega {φ : Formula ℕ} (hφ : φ ∉ construction_omega T hT) :
  (χ → φ ∉ T) ∧ (∃ Γ : Finset (Formula _), ↑Γ ⊆ (construction T hT (encode φ)) ∧ (↑(φ) ∈ T)) := by
  simp [construction_omega, Set.mem_iUnion, not_exists] at hφ;
