    have h10 : False := by
      simp at h9 ⊢
      exact h9
    exfalso
    exact h10

lemma construction_omega_prime : PrimeFTheory L T := by
  simp [PrimeFTheory, FTheory.lindenbaum, FTheory.prime, construction_omega, Set.mem_iUnion]
  intro hφ hψ hφψ; simp at hφψ
  rcases hφψ with (h | h)
  . tauto
  . exfalso; tauto

lemma lindenbaum_lemma : ∃ P : PrimeFTheory L, P ⊢ φ := by
  use T; apply construction_omega_prime

lemma main : L ⊢ φ := by
  obtain ⟨P, hP⟩ := lindenbaum_lemma
  have := P.prime (φ := φ) (hφ := by tauto)
  tauto

theorem lindenbaum_theorem : L ⊢ φ := by
  apply main
