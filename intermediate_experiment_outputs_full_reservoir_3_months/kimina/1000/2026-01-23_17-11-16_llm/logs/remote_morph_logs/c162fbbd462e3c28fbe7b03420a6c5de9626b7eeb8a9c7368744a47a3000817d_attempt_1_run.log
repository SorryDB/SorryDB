open SProbComp

lemma product_support {α β : Type} [Fintype α] [Fintype β]
    [Inhabited α] [Inhabited β] [SampleableType α] [SampleableType β]
    (sα : ProbComp α) (sβ : ProbComp β) (x : α × β) :
