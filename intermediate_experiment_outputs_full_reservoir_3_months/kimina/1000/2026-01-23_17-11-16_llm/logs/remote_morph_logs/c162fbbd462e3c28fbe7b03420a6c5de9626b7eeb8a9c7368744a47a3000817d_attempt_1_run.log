noncomputable abbrev selectElem (β : Type) [h : SampleableType β] : ProbComp β := h.selectElem

noncomputable abbrev uniformSample (β : Type) [h : SampleableType β] : ProbComp β := h.selectElem


variable {α : Type} [hα : SampleableType α]
variable {β : Type} [hβ : SampleableType β]

@[simp] lemma mem_support (x : α) : x ∈ support (α : Type) := by
  apply hα.mem_support x

@[simp] lemma mem_support' (x : β) : x ∈ support (β : Type) := by
  apply hβ.mem_support x

@[simp] lemma support_prod : support (α × β : Type) = Set.univ := by
  simp [Set.ext_iff, Set.mem_univ]
  intro x
  simp only [Set.mem_prod_iff, mem_support, mem_support']
  tauto

