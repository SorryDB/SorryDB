    · exact hβ.mem_support_selectElem x.2
  probOutput_selectElem_eq x y := by
    simp only [Prod.forall, probOutput_seq_map_prod_mk_eq_mul,
      hα.probOutput_selectElem_eq, hβ.probOutput_selectElem_eq]
    all_goals
