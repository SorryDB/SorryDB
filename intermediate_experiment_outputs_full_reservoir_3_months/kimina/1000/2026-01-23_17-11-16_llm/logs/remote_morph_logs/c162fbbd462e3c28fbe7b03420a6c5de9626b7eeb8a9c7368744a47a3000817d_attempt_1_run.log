lemma product_eq {α β : Type} [Fintype α] [Fintype β]
    [Inhabited α] [Inhabited β] [SampleableType α] [SampleableType β]
    (sα : ProbComp α) (sβ : ProbComp β) :
    (sα ×ˢ sβ) = sα ×ˢ sβ := by rfl

theorem product_sampleable {α β : Type} [Fintype α] [Fintype β]
    [Inhabited α] [Inhabited β] [SampleableType α] [SampleableType β]
    (sα : ProbComp α) (sβ : ProbComp β) :
