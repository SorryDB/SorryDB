import Mathlib

namespace SPMF

variable (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [SampleableType α] [SampleableType β]

-- Define the selectElem operation for the product type
def selectElem_prod : ProbComp (α × β) := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)

-- Prove that selectElem_prod is a valid SampleableType instance
instance : SampleableType (α × β) where
  selectElem := selectElem_prod
  mem_support_selectElem (p : α × β) := by
    simp only [mem_support, mem_support_iff, mem_support_iff]
    simp [p.1, p.2]
    apply And.intro
    exact (SampleableType.mem_support_selectElem p.1)
    exact (SampleableType.mem_support_selectElem p.2)
  -- Prove that the probability of selecting any two elements is the same
  probOutput_selectElem_eq (p₁ p₂ : α × β) : Pr[= p₁ | selectElem_prod] = Pr[= p₂ | selectElem_prod] := by
    simp [selectElem_prod]
    rw [prod_eq_prod_iff]
    -- The probability of selecting p₁ is the product of the probabilities of selecting each component
    have h1 : Pr[= p₁ | (fun x y => (x, y)) <$> ($ᵗ α) <*> ($ᵗ β)] = 
      Pr[= p₁.1 | $ᵗ α] * Pr[= p₁.2 | $ᵗ β] := by
      simp [prod_eq_prod_iff, ← and_assoc]
      rw [← Prod.mk.injEq]
      simp [prod_eq_prod_iff]
    -- Similarly for p₂
    have h2 : Pr[= p₂ | (fun x y => (x, y)) <$> ($ᵗ α) <*> ($ᵗ β)] = 
      Pr[= p₂.1 | $ᵗ α] * Pr[= p₂.2 | $ᵗ β] := by
      simp [prod_eq_prod_iff, ← and_assoc]
      rw [← Prod.mk.injEq]
      simp [prod_eq_prod_iff]
    rw [h1, h2]
    -- Use the fact that the probability of selecting each component is the same
    rw [SampleableType.probOutput_selectElem_eq p₁.1 p₂.1, 
        SampleableType.probOutput_selectElem_eq p₁.2 p₂.2]
    simp
  -- Prove that the probability of failure is 0
  probFailure_selectElem : Pr[⊥ | selectElem_prod] = 0 := by
    simp [selectElem_prod]
    rw [prod_eq_prod_iff]
    simp
    -- The failure probability of the product is 0 because neither component fails
    rw [SampleableType.probFailure_selectElem, 
        SampleableType.probFailure_selectElem]
    simp
