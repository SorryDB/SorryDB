    [Inhabited α] [Inhabited β] [SampleableType α] [SampleableType β]
    (sα : ProbComp α) (sβ : ProbComp β) (x : α × β) :
    Pr[= x | sα ×ˢ sβ] = Pr[= x.1 | sα] * Pr[= x.2 | sβ] := by
  simp [prod_eq, eq_prod]

lemma product_failure {α β : Type} [Fintype α] [Fintype β]
    [Inhabited α] [Inhabited β] [SampleableType α] [SampleableType β]
    (sα : ProbComp α) (sβ : ProbComp β) :
    Pr[⊥ | sα ×ˢ sβ] = Pr[⊥ | sα] * Pr[⊥ | sβ] := by
