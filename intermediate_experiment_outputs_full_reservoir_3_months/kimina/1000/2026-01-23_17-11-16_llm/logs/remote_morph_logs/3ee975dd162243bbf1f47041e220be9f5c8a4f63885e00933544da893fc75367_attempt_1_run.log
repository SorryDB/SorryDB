import Mathlib

open Finset Set

/- Riemann sum of a function `f` over an interval `[a, b]` with `n` subintervals -/
noncomputable def RiemannSum (f : ℝ → ℝ) (a b : ℝ) (n : ℕ) : ℝ :=
  (∑ i in Finset.range n, f (a + (i : ℝ) / n * (b - a))) * (b - a) / n

/- A function `f` is uniformly continuous on a set `S` if for every `ε > 0`, there exists a `δ > 0` such that for all `x, y ∈ S`, if `|x - y| < δ`, then `|f x - f y| < ε`. -/
def UnifContOn (f : ℝ → ℝ) (S : Set ℝ) : Prop :=
  ∀ ε > 0, ∃ δ > 0, ∀ x ∈ S, ∀ y ∈ S, |y - x| < δ → |f y - f x| < ε

/- If a function `f` is uniformly continuous on `[a,b]`, then the Riemann sums of `f` converge to a limit as `N → ∞`. -/
theorem HasIntegral_of_UnifContOn (f : ℝ → ℝ) (a b : ℝ) (hab : a < b) (hf : UnifContOn f (Icc a b)) :
    IntegrableOn f a b := by
  apply HasIntegral.of.IsCauchy
  intro ε hε
