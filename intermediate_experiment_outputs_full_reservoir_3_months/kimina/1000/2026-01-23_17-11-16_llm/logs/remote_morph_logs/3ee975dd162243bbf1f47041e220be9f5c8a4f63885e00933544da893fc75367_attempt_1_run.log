import Mathlib.Analysis.Calculus.Integration.Riemann

open Finset Set

/- Riemann sum for a function f : ℝ → ℝ over the interval [a, b] with n intervals -/
noncomputable def RiemannSum (f : ℝ → ℝ) (a b : ℝ) (n : ℕ) : ℝ :=
  (∑ i in range n, f (a + (b - a) * (↑i / ↑n))) * ((b - a) / ↑n)

/- Definition of a Riemann integrable function -/
noncomputable def IntegrableOn (f : ℝ → ℝ) (a b : ℝ) : Prop :=
  HasIntegral (fun x ↦ if x ∈ Set.Icc a b then f x else 0) MeasureTheory.volume MeasureTheory.volume
