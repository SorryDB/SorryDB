  choose δ hδ₁ hδ₂ using hf (ε / (2 * (b - a))) (by positivity)
  choose N hN using ArchProp (show 0 < δ / (2 * (b - a)) by positivity)
  use N
  intro n hn m hnm
  have pos1 : 0 < 1 / (δ / (2 * (b - a))) := by positivity
  have NposR : (0 : ℝ) < N := by linarith [hN, pos1]
  have Npos : 0 < N := by exact_mod_cast NposR
  have npos : 0 < n := by linarith [hn, Npos]
  have mpos : 0 < m := by linarith [hnm, npos]
  change |RiemannSum f a b m - RiemannSum f a b n| < ε
```

