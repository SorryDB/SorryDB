If we choose the common multiple of n and m as N = m * n, then each interval in the Riemann sum with N intervals has width (b - a) / N. If (b - a) / N < δ, then |f x - f y| < ε / (2 * (b - a)) for any x, y in the same interval. The difference between the Riemann sums with n and m intervals can be bounded by the sum over the intervals where the function values change significantly.

```tactics
have h4 : ∀ i : ℕ, i ∈ Finset.Icc (0 : ℕ) (m * n - 1) → |f ((a + ((i : ℕ) : ℝ) * (b - a) / (m * n)) ) - f ((a + ((i + 1 : ℕ)) * (b - a) / (m * n)) )| < ε / (2 * (b - a)) := by
  intro i hi
  have h5 : ((a + ((i : ℕ) : ℝ) * (b - a) / (m * n)) ) ∈ Icc a b := by
    simp at *
    constructor
    · -- Show a ≤ a + (i * (b - a) / (m * n))
      have h1 : (i : ℝ) ≥ 0 := by exact_mod_cast (show (i : ℕ) ≥ 0 by omega)
      nlinarith
    · -- Show a + (i * (b - a) / (m * n)) ≤ b
      have h2 : (i : ℝ) ≤ (m * n - 1 : ℝ) := by
        simp at hi ⊢
        exact_mod_cast hi.2
      have h3 : (i : ℝ) * (b - a) / (m * n) ≤ (b - a) := by
        have h4 : (i : ℝ) ≤ (m * n - 1 : ℝ) := by exact_mod_cast hi.2
        have h5 : (m * n : ℝ) > 0 := by positivity
        have h6 : (i : ℝ) * (b - a) ≤ (m * n - 1 : ℝ) * (b - a) := by
          nlinarith [show (b - a : ℝ) ≥ 0 by nlinarith]
        have h7 : (i : ℝ) * (b - a) / (m * n) ≤ (m * n - 1 : ℝ) * (b - a) / (m * n) := by
          apply (div_le_div_right (by positivity)).mpr
          nlinarith
        have h8 : (m * n - 1 : ℝ) * (b - a) / (m * n) < (b - a) := by
          have h9 : (m * n : ℝ) > 0 := by positivity
          have h10 : (m * n - 1 : ℝ) < (m * n : ℝ) := by linarith
          have h11 : (m * n - 1 : ℝ) * (b - a) < (m * n : ℝ) * (b - a) := by
            nlinarith [show (b - a : ℝ) ≥ 0 by nlinarith]
          have h12 : (m * n - 1 : ℝ) * (b - a) / (m * n) < (m * n : ℝ) * (b - a) / (m * n) := by
            apply (div_lt_div_right (by positivity)).mpr
            nlinarith
          have h13 : (m * n : ℝ) * (b - a) / (m * n) = (b - a) := by
            field_simp
          linarith
        linarith
      nlinarith
```

