  toFun_next := fun i => Fin.elim0 i
  toFun_full := fun _ _ _ => by simp

/-- Round-by-round soundness of the identity verifier. -/
def rbrSoundness (lang : Set Statement)
    (verifier : Verifier oSpec Statement _ _)
    (rbrSoundnessError : pSpec.ChallengeIdx → ℝ≥0) : Prop :=
  ∃ stateFunction : verifier.StateFunction init impl (acceptRejectRel.language) (acceptRejectRel.language),
  ∀ s1 ∉ acceptRejectRel.language,
  ∀ W1 W2 : Type,
  ∀ w1 : W1,
  ∀ p : Prover oSpec Statement W1 Statement W2 pSpec,
  ∀ i : pSpec.ChallengeIdx,
    Pr[fun ⟨transcript, challenge⟩ =>
      ¬ stateFunction i.1.castSucc s1 transcript ∧
        stateFunction i.1.succ s1 (transcript.concat challenge)
    | do
      (simulateQ (rbrSoundness_queryImpl)
        (do
          let ⟨transcript, _⟩ ← p.runToRound i.1.castSucc s1 w1
          let challenge ← (pSpec.getChallenge i)
          return (transcript, challenge))).run' (← init)] ≤
      rbrSoundnessError i

end Trivial

