  letI U := construction_omega T hT
  φ ∈ U → ψ ∈ U → φ ⋏ ψ ∈ U := by
  rintro hφ hψ;
  by_contra! hC;
  obtain ⟨hφ', hψ'⟩ := hC;
  obtain ⟨_, ⟨Γ, h1, h2⟩⟩ := of_not_mem_construction_omega hφ;
