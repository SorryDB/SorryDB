    have h3 : (Γ.conj ⋏ φ) ∈ T.theorem := T.mem_of_provable $ by
      apply T.iff_mem.mp
      exact h₂;
    have : (Γ.conj ⋏ φ) ∈ construction T hT (encode (ξ)) := sorry;
    sorry;

lemma construction_omega_L_subset :
  letI U := construction_omega T hT
  L ⊆ U := by
  intro φ hφ;
  simp only [construction_omega, Set.mem_iUnion];
  use (encode φ + 1);
