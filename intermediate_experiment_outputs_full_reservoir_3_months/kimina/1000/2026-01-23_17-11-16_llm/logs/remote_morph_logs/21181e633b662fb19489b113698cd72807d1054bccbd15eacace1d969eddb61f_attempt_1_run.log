import Mathlib

open Filter Real Set

/- A locally finite measure space is one where each set has finite measure
and the measure of the entire space is finite. -/
structure IsLocallyFiniteMeasure (μ : Measure α) : Prop :=
  ∀ s, IsCompact s → μ s < ⊤

/- A measure space is finite if the entire space has finite measure.
-/
structure IsFiniteMeasure (μ : Measure α) : Prop :=
  μ α < ⊤

/- A measure space is finite if the entire space has finite measure.
-/
abbrev IsFiniteMeasure' (μ : Measure α) : Prop := IsFiniteMeasure μ

/- A measure space is finite if the entire space has finite measure.
-/
abbrev IsLocallyFiniteMeasure' (μ : Measure α) : Prop := IsLocallyFiniteMeasure μ

/- An eLorentz space is a generalization of L^p and L^∞ spaces.
Given a measure space (α, μ), a real number p ≥ 1, and a real number q ≥ 1,
the eLorentz space (α, μ, p, q) consists of all measurable functions f : α → ℝ such that
the integral of |f| over any set s with μ(s) < ∞ is finite, and
(1/μ(s)) ∫_{t ∈ s} |f(t)|^p dμ(t) ≤ q^p for all s with μ(s) < ∞.
-/
abbrev eLorentzSpace (α : Type u_1) [MeasurableSpace α] (μ : Measure α) [IsLocallyFiniteMeasure μ] (p q : ℝ≥0∞) : Type u_2 :=
  {f : α → ℝ | IsMeasurable f μ ∧ ∀ s, μ s < ⊤ → (∫ t in s, |f t| ^ p dμ) ≤ q ^ p * μ s}

/- An eLorentz norm is a generalization of the L^p norm.
Given a measure space (α, μ), a real number p ≥ 1, and a real number q ≥ 1,
the eLorentz norm on a function f ∈ eLorentzSpace (α, μ, p, q) is defined as
‖f‖_{eL^p,q} = ∫_{t ≥ 0} (if t < a then μ s ^ p⁻¹ else distribution f (t - a) μ ^ p⁻¹) dt,
where a = ∫_{t ≥ 0} μ s ^ p⁻¹ dt, and distribution f x μ = ∫_{t ≥ x} |f(t)| dμ(t).
-/
noncomputable def eLorentzNorm (f : α → ℝ) (p q : ℝ≥0∞) (μ : Measure α) (s : Set α) :
  ∫ (t : ℝ≥0), (if t < ∫ (y : α) in s, |f y| ^ p⁻¹ dμ y then μ s ^ p⁻¹ else (∫ (y : α) in {y | y ≥ t}, |f y| dμ y) ^ p⁻¹) dt

/- A function f is in the eLorentz space (α, μ, p, q) if and only if it is measurable
and its eLorentz norm is finite.
-/
lemma eLorentzNorm_isFinite_iff_memLorentz {f : α → ℝ} {p q : ℝ≥0∞} {μ : Measure α} {s : Set α} (hs : μ s < ⊤) :
  IsFinite (eLorentzNorm f p q μ s) ↔ f ∈ eLorentzSpace α μ p q := by
  -- sorry
  sorry

/- The eLorentz space (α, μ, p, q) is non-empty if p ≥ 1 and q ≥ 1.
-/
lemma eLorentzSpace_nonempty {α : Type u_1} [MeasurableSpace α] {μ : Measure α} [IsLocallyFiniteMeasure μ] {p q : ℝ≥0∞} (hp : 1 ≤ p) (hq : 1 ≤ q) : Nonempty (eLorentzSpace α μ p q) := by
