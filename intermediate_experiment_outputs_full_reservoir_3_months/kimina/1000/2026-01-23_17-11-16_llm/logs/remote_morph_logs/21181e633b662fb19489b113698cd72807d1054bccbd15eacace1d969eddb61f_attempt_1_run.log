/- An operator T : (α → ℝ) → (α' → ℝ) is said to be of restricted weak type (p, p') if there exists a constant c such that for all measurable sets s with μ(s) < ∞ and ν(s') < ∞, we have ‖T f‖_{L^{p'}(s')} ≤ c * ‖f‖_{L^p(s)}.
-/
noncomputable def HasRestrictedWeakType (T : (α → ℝ) → (α' → ℝ)) (p p' : ℝ≥0∞) (μ : Measure α) (ν : Measure α') (c : ℝ≥0) : Prop :=
  ∃ c, ∀ s, IsCompact s → μ s < ⊤ → ∃ s', IsCompact s' → ν s' < ⊤ → ‖T f‖_{L^{p'}(s')} ≤ c * ‖f‖_{L^p(s)}

/- An operator T : (α → ℝ) → (α' → ℝ) is said to be of Lorentz type (p, p') if it is of restricted weak type (p, p') and satisfies the Hölder conjugate condition p' = p^H.
-/
noncomputable def HasLorentzType (T : (α → ℝ) → (α' → ℝ)) (p p' : ℝ≥0∞) (μ : Measure α) (ν : Measure α') : Prop :=
  HasRestrictedWeakType T p p' μ ν (p := 1) ∧ p'.holderConjugate = p

/- An operator T : (α → ℝ) → (α' → ℝ) is said to be weakly continuous if for every sequence of functions f_n converging to f in the weak* topology, the sequence T f_n converges to T f in the weak* topology.
-/
noncomputable def WeaklyContinuous (T : (α → ℝ) → (α' → ℝ)) (p : ℝ≥0∞) (μ : Measure α) (ν : Measure α') : Prop :=
