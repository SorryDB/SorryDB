/- The eLorentz norm satisfies the triangle inequality.
-/
lemma eLorentzNorm_subadd {f g : α → ℝ} {p q : ℝ≥0∞} {μ : Measure α} {s : Set α} (hs : μ s < ⊤) :
  eLorentzNorm (f + g) p q μ s ≤ eLorentzNorm f p q μ s + eLorentzNorm g p q μ s := by
