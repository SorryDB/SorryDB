import Mathlib.Algebra.Central.Basic
/-!

# Haar character of the finite adele ring of a number field

We prove the crucial result that left and right multiplication by an element of `D ÔŐŚ[K] ­ŁöŞ_K^f`
scale Haar measure by the same factor, if D is a finite-dimensional central simple `K`-alegbra.

-/

open NumberField

open scoped TensorProduct

variable (K : Type*) [Field K] [NumberField K]

variable (B : Type*) [Ring B] [Algebra K B] [FiniteDimensional K B]

open scoped TensorProduct

open NumberField MeasureTheory

-- in FLT#823
instance (k A B : Type*) [Field k] [CommRing A] [Ring B]
    [Algebra k A] [Algebra k B]
    [Algebra.IsCentral k B] :
    Algebra.IsCentral A (A ÔŐŚ[k] B) := by
  have h1 : IsCentral k B := by simpa using h
  have h2 : IsCentral A (A ÔŐŚ[k] B) := by
    rw [isCentral_iff_center_eq_field]
    ext z
    simp [center]
    constructor
    ┬Ě -- Assume z is in the center of A ÔŐŚ[k] B
      intro hz
      have h13 : z Ôłł center (B : Type*) := by
        simp [center]
        intro b
        have h14 : z * b = b * z := by
          have h15 : z Ôłł center (A ÔŐŚ[k] B) := hz
          specialize h15 b
          simpa using h15
        simpa using h14
      have h14 : (z : B) Ôłł (k : B) := by
        have h15 : center (B : Type*) = (k : B) := by
          rw [isCentral_iff_center_eq_field] at h
          simpa using h
        rw [h15] at h13
        exact h13
      exact h14
    ┬Ě -- Assume z Ôłł k
      intro hz
      simp [center]
      intro x
      have h2 : z Ôłł (k : A ÔŐŚ[k] B) := hz
      simp [mem_center] at *
      all_goals try { 
        have h3 : z * x = x * z := by
          simp [h2]
        exact h3
      }
  exact h2
```

