import Mathlib

open SPMF

noncomputable namespace OracleComp

variable (α : Type) [h : SampleableType α]

variable (α β : Type) [Fintype α] [Fintype β] [Inhabited α] [Inhabited β]
    [hα : SampleableType α] [hβ : SampleableType β] : SampleableType (α × β) where
  selectElem := (·, ·) <$> ($ᵗ α) <*> ($ᵗ β)
  mem_support_selectElem x := by
    simp [hα.mem_support_selectElem, hβ.mem_support_selectElem]
    <;> aesop
  probOutput_selectElem_eq x y := by
    simp [hα.probOutput_selectElem_eq, hβ.probOutput_selectElem_eq]
    <;> aesop
  probFailure_selectElem := by
    simp [hα.probFailure_selectElem, hβ.probFailure_selectElem]
    <;> aesop

@[simp] lemma evalDist_uniformSample [Fintype α] [Inhabited α] :
    evalDist ($ᵗ α) = liftM (PMF.uniformOfFintype α) := by
  simp only [evalDist]
  have h1 : OptionT.run (fun (x : α) => (x : OptionT ProbComp α) = liftM (fun (x : α) => return x) ($! (α : Fin (Fintype.card α)).val)) = 1 := by
    simp
  simp [h1]
  <;> simp [OptionT.run_eq, OptionT.mk, OptionT.pure, OptionT.run_map]
