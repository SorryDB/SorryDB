import Mathlib

open Classical

variable {C : Type} in
variable {inst : AddCommGroupWithDivisors C} in
variable {K : Type} in
variable {inst : DivisionRing K} in
variable {M : C ⥤ ModuleCat K} in

namespace DirectSumDecomposition

noncomputable def IsMin (D : DirectSumDecomposition M) : Prop :=
  ∀ D' : DirectSumDecomposition M, D' ≤ D → D' = D

/- Suppose `D` is a direct sum decomposition that is minimal with respect to refinements.
Then every submodule that appears in `D` is an atom. -/
lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra hNotMax
  simp only [Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement B
    (fun N hN => by simp [B, hN] at *) (fun N hN => by simp [B, hN]; apply sSupIndep_pair; exact hxy) (fun N hN => by simp [B, hN]; simp)
  have h1 : newD ≤ D := by
    intro N hN
    simp only [refinement, Set.mem_iUnion, Set.mem_iInter]
    intro hN
    by_cases h_eq : N = x ⊔ y
    · -- Case where N = x ⊔ y
      rw [h_eq]
      have h1 : B (x ⊔ y) (by simp [h_eq] at *; tauto) = {x, y} := by
        simp [B, h_eq]
      rw [h1]
      rw [sSup_pair hxy]
      all_goals tauto
    · -- Case where N ≠ x ⊔ y
      have h1 : B N hN = {N} := by
        simp [B, h_eq]
      rw [h1]
      simp
  have h2 := hmax h1
  simp [refinement, Set.mem_iUnion, Set.mem_iInter, B] at h2 ⊢
