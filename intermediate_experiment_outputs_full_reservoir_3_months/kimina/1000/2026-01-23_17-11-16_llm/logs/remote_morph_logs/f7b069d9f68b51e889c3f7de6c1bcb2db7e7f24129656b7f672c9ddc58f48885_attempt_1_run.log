    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  obtain ⟨N₀, hN₀, h_neq⟩ := H
  have h_lt : (refinement B hB hB' hB'') < D := by
    apply lt_of_le_of_lt (refinement_le B hB hB' hB'')
    apply lt_of_lt_of_le (refinement_lt_of_exists_ne_singleton B hB hB' hB'' H)
  exact h_lt

/-- If `D` is a direct sum decomposition that is minimal with respect to refinements
then every submodule that appears in `D` is indecomposable. -/
