  by_contra hNotMax
  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement B
    (by intro N hN; rfl)
    (by intro N hN; by_cases h_eq : N = x ⊔ y; · simp [h_eq, sSup_pair hxy]; · simp [h_eq]; all_goals try { tauto }) 
    (by intro N hN; by_cases h_eq : N = x ⊔ y; · simp [h_eq, sSup_pair hxy, hx, hy]; · simp [h_eq]; all_goals try { tauto })
    (by intro N hN; by_cases h_eq : N = x ⊔ y; · simp [h_eq, sSup_pair hxy, hx, hy]; · simp [h_eq]; all_goals try { tauto })

  have h1 : newD ≤ D := by
    apply refinement_le B
    all_goals
      intro N hN
      by_cases h_eq : N = x ⊔ y
      · simp [h_eq, sSup_pair hxy]
      · simp [h_eq]
  have h2 : IsMin newD := by
    apply IsMin.of_le_of_min h1 hmax
  have h3 : x ∈ newD := by
