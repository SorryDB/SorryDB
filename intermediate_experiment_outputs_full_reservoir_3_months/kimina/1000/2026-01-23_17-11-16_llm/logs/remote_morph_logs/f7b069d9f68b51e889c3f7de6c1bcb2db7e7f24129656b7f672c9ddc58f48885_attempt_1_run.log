/-- The direct sum decomposition `refinement B hB hB' hB''` is a refinement of `D`. -/
lemma refinement_le (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) :
    refinement B hB hB' hB'' ≤ D := by
  intro N hN
  apply le_trans (sSup_le (D := D) N hN) 
  apply le_sSup
  intro A hA
  simp only [exists_and_right, Subtype.exists, exists_prop, Set.mem_setOf_eq, Set.mem_iUnion, Set.mem_iInter] at *
  simp only [Set.mem_setOf_eq, Set.mem_iUnion, Set.mem_iInter]
