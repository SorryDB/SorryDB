open scoped Classical

namespace DirectSumDecomposition

variable {M : C ⥤ ModuleCat K} in
variable {D : DirectSumDecomposition M} in
variable {N : PersistenceSubmodule M} in
variable {hN : N ∈ D} in
variable {hmax : IsMin D} in
variable {x y : PersistenceSubmodule M} in
variable {hxy : Disjoint x y} in
variable {hN_decomp : x ⊔ y = N} in
variable {hx : ¬x = ⊥} in
variable {hy : ¬y = ⊥} in

lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  unfold Indecomposable
  intro x y hxy
  by_contra h
  push_neg at h
  have hN_in_D : N ∈ D := hN
  have hx_in_D : x ∈ D := by
    apply D.mem_of_mem_submodule
    exact hN
  have hy_in_D : y ∈ D := by
    apply D.mem_of_mem_submodule
    exact hN
  let D' : DirectSumDecomposition M := {
    carrier := D.carrier \ {N} ∪ {x, y},
    sSupIndep' := sorry,
    sSup_eq_top' := sorry,
    not_bot_mem' := sorry
  }
  have hD'_is_refinement : IsRefinement D' D := by
    intro N hN
    simp at hN ⊢
    rcases hN with (hN | hN)
    · exfalso
      have hN_eq : N = N := by rfl
      simp [hN_eq] at hN
    · rcases hN with (hN | hN)
      · rw [hN]
        exact hx_in_D
      · rw [hN]
        exact hy_in_D
  have hD'_ne_D : D' ≠ D := by
    intro h
    have hN_in_D' : N ∈ D' := by
      rw [h]
      exact hN
    have hN_not_in_D' : N ∉ D' := by
      simp at *
      all_goals
        try { tauto }
    contradiction
  have hD'_is_min : IsMin D' := hmax D hD'_is_refinement
  exfalso
  have hD'_ne_D : D' ≠ D := hD'_ne_D
  exact hD'_ne_D hD'_is_min
