variable {C : Type} {inst : Category.Functor C (ModuleCat K)} {K : Type} {instK : DivisionRing K} {M : C ⥤ ModuleCat K} {D : DirectSumDecomposition M} {hmax : IsMin D} {x y : PersistenceSubmodule M} {hxy : Disjoint x y} {hN : x ⊔ y ∈ D} {hx : ¬x = ⊥} {hy : ¬y = ⊥}

def B (N : PersistenceSubmodule M) (hN : N ∈ D) : Set (PersistenceSubmodule M) := 
  if N = x ⊔ y then {x, y} else {N}

lemma h1 : ∀ (N : PersistenceSubmodule M) (hN : N ∈ D), N = sSup (B N hN) := by
  intro N hN
```

Now we have to prove `N = sSup (B N hN)` given `N ∈ D`.

