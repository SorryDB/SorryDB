noncomputable def decomposition_of_refinement {S : Set α} (R : refinement S) : Set α := ⋃ D ∈ R, D

/-!
The lemma `forall_indep` states that the union of the sets in the decomposition is independent
-/
lemma forall_indep {S D : Set α} (R : refinement S) :
