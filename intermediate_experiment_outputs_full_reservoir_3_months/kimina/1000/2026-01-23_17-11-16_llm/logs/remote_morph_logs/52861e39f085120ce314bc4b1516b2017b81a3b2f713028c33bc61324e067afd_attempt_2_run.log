open Set
open scoped Classical in

/-!
A set of subsets of `α` that forms a decomposition
-/
noncomputable structure refinement (S : Set α) where
  carrier : Set (Set α)
  carrier_span : ∀ a ∈ S, ∃! D ∈ carrier, a = sSup D
  carrier_indep : ∀ D ∈ carrier, sSupIndep D
  bot_not_mem : ∀ D ∈ carrier, ⊥ ∉ D

/-!
The union of the sets in the decomposition
-/
noncomputable def decomposition_of_refinement {S : Set α} (R : refinement S) : Set α := ⋃ D ∈ R, D

/-!
The lemma `forall_indep` states that the union of the sets in the decomposition is independent
-/
lemma forall_indep {S D : Set α} (R : refinement S) :
    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  simp_rw [Set.mem_iUnion] at hb'
  have h1 := R.carrier_indep I hI
  have h2 := R.carrier_indep D hD
  sorry

/-!
The lemma `sSup_eq_top'` states that the sSup of the decomposition equals the sSup of the original set
-/
lemma sSup_eq_top' {S : Set α} (R : refinement S) :
    sSup (decomposition_of_refinement R) = sSup S := by
  sorry

/-!
The lemma `bot_not_mem` states that `⊥` is not in the decomposition
-/
lemma bot_not_mem {S : Set α} (R : refinement S) :
    ⊥ ∉ decomposition_of_refinement R := by
  simp_rw [decomposition_of_refinement]
  intro h
  have h1 : ∃ D ∈ R, ⊥ ∈ D := by
    simpa using h
  rcases h1 with ⟨D, hD, h1⟩
  have h2 := R.bot_not_mem D hD
  contradiction

/-!
The lemma `isInternal` states that the decomposition is internal
-/
lemma isInternal {S : Set α} (R : refinement S) :
    IsInternal decomposition_of_refinement R := by
  rw [isInternal_iff]
  constructor
  · intro m hm
    obtain ⟨D, hD⟩ := R.carrier_span m (Set.mem_of_mem_of_subset (hm ▸ (by simp)) (by simp))
    refine DFinsupp.ext fun x ↦ ?_
    intro hx
    have hx' : x ∈ D := by
      simpa using hx
    exact R.carrier_indep D hD hx'
  · intro m hm
    obtain ⟨D, hD⟩ := R.carrier_span m (Set.mem_of_mem_of_subset (hm ▸ (by simp)) (by simp))
    refine DFinsupp.ext fun x ↦ ?_
    intro hx
    have hx' : x ∈ D := by
      simpa using hx
    exact R.carrier_indep D hD hx'

/-!
The lemma `zorn` states that the decomposition satisfies the Zorn's lemma condition
-/
lemma zorn (R : refinement (Top : Set α)) :
    BddAbove (R : Set (Set α)) := by
  apply bddAbove_of_subset
  · use { ⊥ }
    intro x hx
    simp at hx ⊢
    tauto
  · sorry

/-!
The lemma `zorn_lemma` states that there exists a maximal element in the lattice
-/
lemma zorn_lemma : ∃ (D : Set α), IsMax D := by
  apply zorn
  use (refinementTop : refinement (Top : Set α))
  simp [refinementTop]
  apply zorn

