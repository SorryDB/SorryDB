    ⊥ ∉ decomposition_of_refinement R := by
  rw [decomposition_of_refinement]
  simp only [Set.mem_iUnion]
  intro h
  rcases h with ⟨D, hD, hD'⟩
  have h1 := R.bot_not_mem D hD
  contradiction
