      <;> norm_num
      <;> simp [Fin.sum_univ_succ]
      <;> norm_num
    have h13 : g 1 - g 0 = f y - f x := by linarith [h11, h12]
    have h14 : ∫ (t : ℝ) in 0..1, g' t = g 1 - g 0 := by
      rw [int_g'_eq_sub]
      all_goals norm_num
    linarith [h13, h14]

  have h11 : |f y - f x| = |∫ (t : ℝ) in 0..1, g' t| := by
    rw [h10]
  have h12 : |∫ (t : ℝ) in 0..1, g' t| ≤ ∫ (t : ℝ) in 0..1, |g' t| := by
    apply abs_le_of_nonneg
    · -- Show that the integral is non-negative
      apply intervalIntegral.integral_nonneg
