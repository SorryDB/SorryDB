    have h2 : ∑ i : Fin n, |(y i - x i) * nth_partial i f x| = ∑ i : Fin n, |y i - x i| * |nth_partial i f x| := by
      congr
      funext i
      have h3 : |(y i - x i) * nth_partial i f x| = |y i - x i| * |nth_partial i f x| := by
        rw [abs_mul]
        <;> ring
      simp [h3]
    rw [h2]
    have h3 : ∀ i : Fin n, |y i - x i| ≤ ε := by
      intro i
      have h4 : |x i - y i| ≤ ε := hdiff i
      have h5 : |y i - x i| = |x i - y i| := by
        rw [show y i - x i = -(x i - y i) by ring]
        rw [abs_neg]
      linarith [h4, h5]
    have h4 : ∑ i : Fin n, |y i - x i| * |nth_partial i f x| ≤ ∑ i : Fin n, (ε * |nth_partial i f x|) := by
      apply Finset.sum_le_sum
      intro i hi
      have h5 : |y i - x i| ≤ ε := h3 i
      have h6 : |y i - x i| * |nth_partial i f x| ≤ ε * |nth_partial i f x| := by
        apply mul_le_mul_of_nonneg_right
        linarith
        positivity
      linarith
    have h5 : ∑ i : Fin n, (ε * |nth_partial i f x|) = ε * ∑ i : Fin n, |nth_partial i f x| := by
      rw [Finset.mul_sum]
      <;> ring
    linarith [h4, h5]

  have bound2 : |g'' 0| ≤ (n ^ 2 / 2) * ε ^ 2 := by
    sorry

  have main_ineq : |f x - f y| ≤ ε * ∑ i, |nth_partial i f x| + (n ^ 2 / 2) * ε ^ 2 := by
