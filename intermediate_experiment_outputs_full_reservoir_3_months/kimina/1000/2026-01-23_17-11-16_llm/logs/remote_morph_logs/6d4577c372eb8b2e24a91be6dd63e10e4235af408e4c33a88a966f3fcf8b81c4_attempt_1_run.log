    have h1 : g' 0 = (y - x) := by
      simp [g', interpolator]
      <;> ring_nf <;> simp [Fin.sum_univ_succ, mul_add, add_mul]
      <;> ring
    rw [h1]
    have h2 : |y - x| ≤ ε := by
      have h3 : ∀ i : Fin n, |x i - y i| ≤ ε := hdiff
      have h4 : |y - x| = |(y - x : E n)| := by simp
      rw [h4]
      have h5 : ‖y - x‖ = √(∑ i : Fin n, (y i - x i) ^ 2) := by
        simp [E.norm_eq, Fin.sum_univ_succ]
        <;> ring_nf <;> simp [Fin.sum_univ_succ]
        <;> ring
      rw [h5]
      have h6 : ∑ i : Fin n, (y i - x i) ^ 2 ≤ ∑ i : Fin n, ε ^ 2 := by
        apply Finset.sum_le_sum
        intro i hi
        have h7 : |x i - y i| ≤ ε := hdiff i
        have h8 : (x i - y i) ^ 2 ≤ ε ^ 2 := by
          nlinarith [abs_le.mp h7]
        nlinarith
      have h7 : ∑ i : Fin n, ε ^ 2 = n * ε ^ 2 := by
        simp [Finset.sum_const, Finset.card_univ, mul_comm]
      rw [h7] at h6
      have h8 : ∑ i : Fin n, (y i - x i) ^ 2 ≥ 0 := by
        apply Finset.sum_nonneg
        intro i hi
        positivity
      have h9 : n * ε ^ 2 ≥ 0 := by
        nlinarith [sq_nonneg ε, show (n : ℝ) ≥ 0 by positivity]
      have h10 : √(∑ i : Fin n, (y i - x i) ^ 2) ≤ √(n * ε ^ 2) := Real.sqrt_le_sqrt (by linarith)
      have h11 : √(n * ε ^ 2) = ε * √n := by
        have h12 : n * ε ^ 2 = ε ^ 2 * (n : ℝ) := by ring
        rw [h12]
        have h13 : √(ε ^ 2 * (n : ℝ)) = √(ε ^ 2) * √(n : ℝ) := by
          rw [Real.sqrt_mul (by nlinarith [sq_nonneg ε, show (n : ℝ) ≥ 0 by positivity])]
        rw [h13]
        have h14 : √(ε ^ 2) = ε := by
          rw [Real.sqrt_sq (by linarith)]
        rw [h14]
        <;> ring_nf <;> simp [Real.sqrt_nonneg]
        <;> ring
      linarith [h10, h11, Real.sqrt_nonneg (n * ε ^ 2), Real.sqrt_nonneg (∑ i : Fin n, (y i - x i) ^ 2)]
    have h3 : |y - x| = |y - x| := rfl
    have h4 : |y - x| ≤ ε := h2
    have h5 : |y - x| ≥ 0 := by apply abs_nonneg
    have h6 : |y - x| ≤ ε := h4
    have h7 : |y - x| ≥ 0 := by apply abs_nonneg
    have h8 : ∑ i, |nth_partial i f x| ≥ 0 := by
