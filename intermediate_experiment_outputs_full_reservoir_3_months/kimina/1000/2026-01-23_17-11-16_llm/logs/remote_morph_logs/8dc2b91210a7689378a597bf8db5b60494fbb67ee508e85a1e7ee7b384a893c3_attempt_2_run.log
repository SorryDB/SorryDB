-- end loggingsComps

-- section Execution

variable
  {ι} {oComps : OracleComps ι} {StmtIn StmtOut WitIn WitOut OStmtIn OStmtOut Qᵢ Qₘ Qᵢ₀ : Type}
  {n : ℕ} {pComps : ProvenComps n}
  {OCompsᵢ : OraclesComps Qᵢ (ReaderM OStmtIn)}
  {OCompsₘ : OraclesComps Qₘ (ReaderM pComps.Messages)}
  {OCompsᵢ₀ : OraclesComps Qᵢ₀}

namespace Prover

/--
Prover's function for processing the next round, given the current result of the previous round, and
a function for getting the challenge.
-/
@[inline, specialize]
def processRound (j : Fin n)
    (prover : Prover oComps StmtIn WitIn StmtOut WitOut pComps)
    (currentResult : OraclesComps (oComps + (challengesComps pComps).comps) (pComps.transcripts j.castSucc × prover.prvState j.castSucc)) :
      OraclesComps (oComps + (challengesComps pComps).comps)
        (pComps.transcripts j.succ × prover.prvState j.succ) := do
  let ⟨transcript, state⟩ ← currentResult
  match hDir : pComps.dir j with
  | .V_to_P => do
    let challenge := pComps.getChallenge ⟨j, hDir⟩
    letI newState := (prover.receiveChallenge ⟨j, hDir⟩ state) challenge
    return ⟨transcript ++ challenge, newState⟩
  | .P_to_V => do
    let ⟨msg, newState⟩ := prover.sendMessage ⟨j, hDir⟩ state
    return ⟨transcript ++ msg, newState⟩

/-- Run the prover in an interactive reduction up to round index `i`, via first inputting the
  statement and witness, and then processing each round up to round `i`. Returns the transcript up
  to round `i`, and the prover's state after round `i`.
-/
@[inline, specialize]
def runToRound (i : Fin (n + 1))
    (prover : Prover oComps StmtIn WitIn StmtOut WitOut pComps)
    (stmt : StmtIn) (wit : WitIn) :
      OraclesComps (oComps + (challengesComps pComps).comps) (pComps.transcripts i × prover.prvState i) := by
