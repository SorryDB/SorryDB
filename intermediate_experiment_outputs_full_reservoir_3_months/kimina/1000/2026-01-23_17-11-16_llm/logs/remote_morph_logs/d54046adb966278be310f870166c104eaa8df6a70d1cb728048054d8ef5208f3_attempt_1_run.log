    have h : x = y := by
      apply Vector.ext
      intro i hi
      simp at hi ⊢
      linarith
    simp [h]
  | succ m ih =>
    rw [probOutput_eqRec]
    simp only [Finset.sum_singleton, Finset.sum_insert, Finset.mem_singleton, Finset.mem_insert,
      Finset.mem_univ, ne_eq, OfNat.ofNat_ne_zero, OfNat.ofNat_ne_zero, iff_false, not_false_eq_true,
