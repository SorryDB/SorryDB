import Mathlib

open ProbabilityTheory

/- An element is selected uniformly at random from a finite type.
The probability of each element is 1 / Fintype.card α.
The probability of failure is 0.
This is a trivial instance, as we can just pick the default element.
-/
noncomputable instance sampleableType_trivial (α : Type) [Fintype α] [Inhabited α] :
    SampleableType α where
  selectElem := return default
  mem_support_selectElem x := Unique.eq_default x ▸ (by simp)
  probOutput_selectElem_eq x y := by rw [Unique.eq_default x, Unique.eq_default y]
  probFailure_selectElem := by simp

/- An element is selected uniformly at random from a finite type.
The probability of each element is 1 / Fintype.card α.
The probability of failure is 0.
This is the standard instance for types with a Fintype instance. -/
noncomputable instance sampleableType_fintype (α : Type) [Fintype α] [Inhabited α] :
    SampleableType α where
  selectElem := $! #v[α]
  mem_support_selectElem x := Fintype.mem_univ x
  probOutput_selectElem_eq x y := by simp only [Fintype.card_univ, Fintype.mem_univ, true_and]
    rw [Finset.sum_const, Finset.card_univ, nsmul_eq_mul, mul_one, mul_one]
    simp
  probFailure_selectElem := by simp

/- An element is selected uniformly at random from a finite type.
The probability of each element is 1 / Fintype.card α.
The probability of failure is 0.
This is the standard instance for types with a Fintype instance. -/
noncomputable instance sampleableType_fintype' (α : Type) [Fintype α] [Inhabited α] :
