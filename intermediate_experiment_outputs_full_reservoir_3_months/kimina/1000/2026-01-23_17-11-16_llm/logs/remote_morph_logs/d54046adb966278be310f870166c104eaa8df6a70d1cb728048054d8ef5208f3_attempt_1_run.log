import Mathlib

open ProbabilityTheory
open scoped BigOperators

/- A computation that produces a value of type α, where each possible output has equal probability.
This is defined in terms of a base computation that produces a value of type α, and a computation that produces a value of type α × α.
The structure is similar to a binary tree, where each node represents a computation, and the leaves represent the base computations.
The computation is defined as follows:
- If the input is a base computation `x`, then the computation `x` itself produces `x` with probability 1.
- If the input is a pair `(x, y)`, then the computation `x` produces `x` with probability 1/2 and `y` with probability 1/2.
- The computation `x` produces a value `v` with probability `Pr[=v | x]`.
- The computation `x` fails with probability `Pr[⊥ | x]`.
- The computation `x` is never failing. -/
noncomputable def uniformSample (β : Type) [h : SampleableType β] :
    ProbComp β := h.selectElem

/- A typeclass instance that provides a way to select an element uniformly at random from a type β.
This requires β to be a finite type with a computationally defined structure.
The typeclass provides:
- `selectElem`: A computation that selects an element from β.
- `mem_support`: A proof that any element x is in the support of `selectElem`.
- `probOutput`: A proof that the probability of selecting any two elements x, y is the same.
- `probFailure`: A proof that the probability of failure is zero.
- `evalDist`: A proof that the evaluation distribution is the uniform distribution.
- `finSupport`: A proof that the finite support is the entire type.
- `isFinite`: A proof that the type is finite.
- `nonempty`: A proof that the type is nonempty.
- `card`: The cardinality of the type. -/
class SampleableType (β : Type) where
  selectElem : ProbComp β
  mem_support : ∀ x : β, x ∈ support selectElem
  probOutput : ∀ x y : β, Pr[= x | selectElem] = Pr[= y | selectElem]
  probFailure : Pr[⊥ | selectElem] = 0
  evalDist : evalDist selectElem = liftM (PMF.uniformOfFintype β) -- requires Fintype β
  finSupport : finSupport selectElem = Set.univ -- requires DecidableEq β
  isFinite : IsFinite β -- requires Fintype β
  nonempty : Nonempty β -- requires Fintype β and β ≠ ∅
  card : Fintype.card β -- requires Fintype β

/- A typeclass instance that provides a way to select an element uniformly at random from a type β.
This is a weaker version of `SampleableType` that does not require the type to be finite or have a `Fintype` instance.
It only requires that there exists some computation that selects an element from β with equal probability for all elements.
The typeclass provides:
- `selectElem`: A computation that selects an element from β.
- `mem_support`: A proof that any element x is in the support of `selectElem`.
- `probOutput`: A proof that the probability of selecting any two elements x, y is the same.
- `probFailure`: A proof that the probability of failure is zero.
- `evalDist`: A proof that the evaluation distribution is the uniform distribution (this is trivial as the computation is never failing).
- `finSupport`: A proof that the finite support is the entire type (this is trivial as the computation is never failing).
- `isFinite`: A proof that the type is finite (this is trivial as the computation is never failing).
- `nonempty`: A proof that the type is nonempty (this is trivial as the computation is never failing).
- `card`: The cardinality of the type (this is trivial as the computation is never failing).
- `isFinite`: A proof that the type is finite (this is trivial as the computation is never failing).
- `nonempty`: A proof that the type is nonempty (this is trivial as the computation is never failing).
- `card`: The cardinality of the type (this is trivial as the computation is never failing). -/
class SampleableType' (β : Type) where
  selectElem : ProbComp β
  mem_support : ∀ x : β, x ∈ support selectElem
  probOutput : ∀ x y : β, Pr[= x | selectElem] = Pr[= y | selectElem]
  probFailure : Pr[⊥ | selectElem] = 0
  evalDist : evalDist selectElem = liftM (fun x ↦ 1) -- trivial
  finSupport : finSupport selectElem = Set.univ -- trivial
  isFinite : IsFinite β -- trivial
  nonempty : Nonempty β -- trivial
  card : Fintype.card β -- trivial

/- A typeclass instance that provides a way to select an element uniformly at random from a type β.
This is the strongest version of `SampleableType`, requiring β to be a finite type with a `Fintype` instance.
The typeclass provides:
- `selectElem`: A computation that selects an element from β.
- `mem_support`: A proof that any element x is in the support of `selectElem`.
- `probOutput`: A proof that the probability of selecting any two elements x, y is the same.
- `probFailure`: A proof that the probability of failure is zero.
- `evalDist`: A proof that the evaluation distribution is the uniform distribution.
- `finSupport`: A proof that the finite support is the entire type.
- `isFinite`: A proof that the type is finite.
- `nonempty`: A proof that the type is nonempty.
- `card`: The cardinality of the type. -/
class SampleableType'' (β : Type) extends SampleableType β where
  selectElem : ProbComp β
  mem_support : ∀ x : β, x ∈ support selectElem
  probOutput : ∀ x y : β, Pr[= x | selectElem] = Pr[= y | selectElem]
  probFailure : Pr[⊥ | selectElem] = 0
  evalDist : evalDist selectElem = liftM (PMF.uniformOfFintype β)
  finSupport : finSupport selectElem = Set.univ
  isFinite : IsFinite β
  nonempty : Nonempty β
  card : Fintype.card β

