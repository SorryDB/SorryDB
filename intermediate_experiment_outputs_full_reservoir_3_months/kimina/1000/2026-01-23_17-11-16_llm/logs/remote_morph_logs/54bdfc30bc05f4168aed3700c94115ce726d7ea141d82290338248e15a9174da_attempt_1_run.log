/-- **Spec and proof concerning `backend.serial.curve_models.CompletedPoint.as_projective`**:
- No panic (always returns successfully)
- Given input CompletedPoint with coordinates (X, Y, Z, T), the output ProjectivePoint (X', Y', Z')
satisfies the conversion formulas modulo p:
- X' ≡ X·T (mod p)
- Y' ≡ Y·Z (mod p)
- Z' ≡ Z·T (mod p)
where p = 2^255 - 19
These formulas implement the conversion from completed ℙ¹ × ℙ¹ coordinates to projective
ℙ² coordinates.
-/
@[progress]
theorem as_projective_spec (q : CompletedPoint)
  (h_qX_bounds : ∀ i, i < 5 → (q.X[i]!).val < 2 ^ 54)
  (h_qY_bounds : ∀ i, i < 5 → (q.Y[i]!).val < 2 ^ 54)
  (h_qZ_bounds : ∀ i, i < 5 → (q.Z[i]!).val < 2 ^ 54)
  (h_qT_bounds : ∀ i, i < 5 → (q.T[i]!).val < 2 ^ 54) :
∃ proj,
as_projective q = ok proj ∧
let X := Field51_as_Nat q.X
let Y := Field51_as_Nat q.Y
let Z := Field51_as_Nat q.Z
let T := Field51_as_Nat q.T
let X' := Field51_as_Nat proj.X
let Y' := Field51_as_Nat proj.Y
let Z' := Field51_as_Nat proj.Z
X' % p = (X * T) % p ∧
Y' % p = (Y * Z) % p ∧
Z' % p = (Z * T) % p
:= by
