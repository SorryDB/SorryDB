            exact hP.augmenting.tail_mem_J
          have hv_in_VMJ : P.last ∈ V(G, M_J) := by
            exact hJ_M hv_in_J
          have hv_in_symm_diff : P.last ∈ V(G, M_I ∆ E(P)) := by
            simp [hv_in_VMJ]
          exact hv_in_symm_diff
    simp [hx_in_J_diff_I, hIcupx_indep]
