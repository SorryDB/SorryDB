import Mathlib.Data.Set.Cardinal
import Mathlib.Data.Set.Finite
import Mathlib.Data.WList
import Mathlib.Data.Graph.Basic
import Mathlib.Data.Graph.Matching
import Mathlib.Data.Graph.Matroid

open Set
open WList
open Graph

variable {G : Graph α β}

structure MatchableIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := G.vertexSet
  Indep := fun S ↦ ∃ M, IsMatching M ∧ S ⊆ V(G, M)
  empty_mem : ∅ ∈ Indep := by
    use ∅
    simp
  subset_mem : ∀ I, I ∈ Indep → ∀ J, J ⊆ I → J ∈ Indep := by
    intro I hI J hJ
    rcases hI with ⟨M, hM, hJI⟩
    use M
    simp [hJI, hJ]
  augment_mem : ∀ I, I ∈ Indep → ∀ J, J ∈ Indep → I ⊆ J → I < J → ∃ x ∈ J \ I, I ∪ {x} ∈ Indep := by
    intro I hI J hJ hI_J hI_lt_J
    rcases hI with ⟨M_I, hM_I, hI_M⟩
    rcases hJ with ⟨M_J, hM_J, hJ_M⟩
    have hJset : J ⊆ V(G, M_J) := hJ_M
    have hIsset : I ⊆ V(G, M_I) := hI_M
    have h_exists_augmenting_path : ∃ P, P.IsAugmentingPath M_I M_J I J := by
      apply graphTheory.exists_augmenting_path_of_nonmaximal
      · -- Show that I is not maximal in J
        intro M' hM' hM'_sup
        have hM'_sup_I : I ⊆ V(G, M') := by
          have hJ_sub_M' : J ⊆ V(G, M') := hM'_sup
          have hI_sub_J : I ⊆ J := hI_J
          exact subset_trans hI_sub_J hJ_sub_M'
        have h_card : (M').encard > M_I.encard := by
          have h_card_J : J.encard ≤ (M').encard := by
            apply M'.degree_le_one.encard_le
            intro v hv
            simp [hM'_sup]
          have h_card_I : I.encard ≤ M_I.encard := by
            apply M_I.degree_le_one.encard_le
            intro v hv
            simp [hI_M]
          have h_card_lt : I.encard < J.encard := by
            exact (Set.encard_lt_encard hI_lt_J).symm
          linarith
        have hM_I_encard : M_I.encard = M_I.encard := rfl
        linarith [h_card, hM_I.encard_eq, hM'_sup.encard_eq]
      · -- Show that M_I is a matching
        exact hM_I
      · -- Show that M_J is a matching
        exact hM_J
    rcases h_exists_augmenting_path with ⟨P, hP⟩
    use P.last
    have hx_in_J_diff_I : P.last ∈ J \ I := by
      have hx_in_J : P.last ∈ J := by
        exact hP.augmenting.tail_mem_J
      have hx_not_in_I : P.last ∉ I := by
        intro h
        have hP_mem_I : P.last ∈ I := by
          simpa using h
        have hP_not_mem_I : P.last ∉ I := by
          exact hP.augmenting.not_mem_I hP_mem_I
        contradiction
      simp [hx_in_J, hx_not_in_I]
    have hIcupx_indep : I ∪ {P.last} ∈ Indep := by
      use M_I ∆ E(P)
      constructor
      · -- Show that M_I ∆ E(P) is a matching
        apply isMatching_of_symm_diff
        · exact hM_I
        · -- Show that P is an alternating path
          exact hP.augmenting.is_alt
      · -- Show that I ∪ {P.last} ⊆ V(G, M_I ∆ E(P))
        intro v hv
        simp at hv
        rcases hv with (hv | hv)
        · -- v ∈ I
          have hv_in_M_I : v ∈ V(G, M_I) := by
            exact hI_M hv
          have hv_in_symm_diff : v ∈ V(G, M_I ∆ E(P)) := by
            simp [hv_in_M_I]
          exact hv_in_symm_diff
        · -- v = P.last
