--     (hM' : G.IsMatching M')
--     (hcd : M.encard < M'.encard) [G.EdgeFinite] :
--     ∃ G' : Graph α β, G'.IsCompOf (hM.restrict₂ hM') ∧ G'.IsPathGraph := by
