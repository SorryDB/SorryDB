  obtain ⟨w, hw⟩ := he
  simp only [mem_singleton, iff_true] at hw
  obtain ⟨w, hw⟩ := hw
  simp only [mem_singleton, iff_true] at hw
  obtain ⟨w, hw⟩ := hw
  simp only [mem_singleton, iff_true] at hw
  obtain ⟨w, hw⟩ := hw
  apply hM.subset hw.1
  tauto

