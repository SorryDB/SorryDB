import Mathlib.Analysis.SpecificLimits.Normed.Carleson

open Filter Real

theorem HasLorentzType.hasLorentzType {α : Type*} {β : Type*} [CompleteLattice α] {f : Filter β}
    {u : β → α} {a : α} (h : ∀ (x : β), u x ≤ a) :
  Filter.limsup u f ≤ a := by
  refine Filter.limsup_le_limsup ?_
  apply Filter.Eventually.of_forall h

