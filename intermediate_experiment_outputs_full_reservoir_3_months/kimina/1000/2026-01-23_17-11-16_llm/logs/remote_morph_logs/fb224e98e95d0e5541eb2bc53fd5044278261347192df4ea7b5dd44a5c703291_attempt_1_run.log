import Mathlib

open Filter Real Measure Set

/- The weak continuity assumption neede for `HasRestrictedWeakType.hasLorentzType_helper`. -/
def WeaklyContinuous [TopologicalSpace ε] [ENorm ε] [ENorm ε'] [SupSet ε] [Preorder ε] (T : (α → ε) → (α' → ε')) (p : ℝ≥0∞) (μ : Measure α) (ν : Measure α') : Prop :=
  ∀ {fs : ℕ → SimpleFunc α ε} (_ : Monotone fs),
  let f := fun x ↦ ⨆ n, (fs n) x;
  ∀ (_ : MemLorentz f p 1 μ) (G : Set α'),
    eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n ↦ eLpNorm (T ⇑(fs n)) 1 (ν.restrict G)) Filter.atTop

/-- The weak continuity assumption neede for `HasLorentzType`. -/
def WeaklyContinuous' [TopologicalSpace ε] [ENorm ε] [ENorm ε'] [SupSet ε] [Preorder ε] (T : (α → ε) → (α' → ε')) (p : ℝ≥0∞) (μ : Measure α) (ν : Measure α') : Prop :=
  ∀ {f : α → ε}, (AESTronglyMeasurable f μ) → (LocallyIntegrable f μ) →
  ∀ {fs : ℕ → α → ε} (hF : ∀ (a : α), Monotone (fun (n : ℕ) => (fs n) a)) (hF' : ∀ (n : ℕ), AEStronglyMeasurable (fs n) μ) (hF'' : ∀ (a : α), Filter.Tendsto (fun (n : ℕ) => (fs n) a) Filter.atTop (nhds (f a))) (G : Set α'),
    eLpNorm (T f) 1 (ν.restrict G) ≤ Filter.limsup (fun n ↦ eLpNorm (T (fs n)) 1 (ν.restrict G)) Filter.atTop

/- The weak continuity assumption neede for `HasLorentzType`. -/
def HasLorentzType {T : (α → ε) → (α' → ε')} {p : ℝ≥0∞} {μ : Measure α} {ν : Measure α'} {c : ℝ≥0} (hT : HasRestrictedWeakType T p μ ν c) (h : ∀ {f : α → ε}, (AESTronglyMeasurable f μ) → (LocallyIntegrable f μ) → HasLorentzType' T p μ ν c f) : HasLorentzType T p μ ν c := by
  intro f hf
  apply h f hf (LocallyIntegrable.memLorentz hf)

