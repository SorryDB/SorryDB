import Mathlib

open Finset

noncomputable def well_formed (ε : Env Ident Typ) (e : ExprLow Ident Typ) : Prop :=
  match e with
  | base inst typ => True
  | connect c e => e.ports.c.isSome ∧ e.ports.in.isSome ∧ e.ports.out.isSome ∧ e.well_formed ∧ e.ports.c.get_some.ports.isSome ∧ e.ports.c.get_some.ports.in.isSome ∧ e.ports.c.get_some.ports.out.isSome
  | product e1 e2 => e1.well_formed ∧ e2.well_formed

noncomputable def well_typed (ε : Env Ident Typ) (e : ExprLow Ident Typ) : Prop :=
  match e with
  | base inst typ => True
  | connect c e => e.ports.c.isSome ∧ e.ports.in.isSome ∧ e.ports.out.isSome ∧ e.well_formed ∧ e.ports.c.get_some.ports.isSome ∧ e.ports.c.get_some.ports.in.isSome ∧ e.ports.c.get_some.ports.out.isSome
  | product e1 e2 => e1.well_typed ∧ e2.well_typed

noncomputable def well_typed' (ε : Env Ident Typ) (e : ExprLow Ident Typ) : Prop :=
  match e with
  | base inst typ => True
  | connect c e => e.ports.c.isSome ∧ e.ports.in.isSome ∧ e.ports.out.isSome ∧ e.well_formed ∧ e.ports.c.get_some.ports.isSome ∧ e.ports.c.get_some.ports.in.isSome ∧ e.ports.c.get_some.ports.out.isSome
  | product e1 e2 => e1.well_typed ∧ e2.well_typed

noncomputable def build_module' (ε : Env Ident Typ) (e : ExprLow Ident Typ) : Option (Module (Ident × Ident)) :=
  match e with
  | base inst typ => some (Module.mk inst (by simp))
  | connect c e => 
    let mod := e.ports.c.get_some
    let mod' := e.ports.c.get_some
    some (Module.mk (mod'.id) (by simp [mod'.ports]))
  | product e1 e2 => 
    let mod1 := e1.build_module' ε
    let mod2 := e2.build_module' ε
    if h : mod1.isSome ∧ mod2.isSome then
      let ⟨mod1', m1⟩ := h.1; let ⟨mod2', m2⟩ := h.2
      some (Module.mk (mod1'.id × mod2'.id) (by simp [mod1'.ports, mod2'.ports]))
    else none

noncomputable def build_module (ε : Env Ident Typ) (e : ExprLow Ident Typ) : Option (Module (Ident × Ident)) :=
  match e with
  | base inst typ => some (Module.mk inst (by simp))
  | connect c e => 
    let mod := e.ports.c.get_some
    let mod' := e.ports.c.get_some
    some (Module.mk (mod'.id) (by simp [mod'.ports]))
  | product e1 e2 => 
    let mod1 := e1.build_module' ε
    let mod2 := e2.build_module' ε
    if h : mod1.isSome ∧ mod2.isSome then
      let ⟨mod1', m1⟩ := h.1; let ⟨mod2', m2⟩ := h.2
      some (Module.mk (mod1'.id × mod2'.id) (by simp [mod1'.ports, mod2'.ports]))
    else none

noncomputable def build_module_interface (ε : Env Ident Typ) (e : ExprLow Ident Typ) : Option (AssocList (Ident × Ident) (Ident × Ident)) :=
  match e with
  | base inst typ => some (AssocList.singleton (inst, (inst)))
  | connect c e => 
    let mod := e.ports.c.get_some
    some (mod.ports)
  | product e1 e2 => 
    let mod1 := e1.build_module' ε
    let mod2 := e2.build_module' ε
    if h : mod1.isSome ∧ mod2.isSome then
      let ⟨mod1', m1⟩ := h.1; let ⟨mod2', m2⟩ := h.2
      some (mod1'.ports ++ mod2'.ports)
    else none

noncomputable def build_module_interface' (ε : Env Ident Typ) (e : ExprLow Ident Typ) : Option (AssocList (Ident × Ident) (Ident × Ident)) :=
  match e with
  | base inst typ => some (AssocList.singleton (inst, (inst)))
  | connect c e => 
    let mod := e.ports.c.get_some
    some (mod.ports)
  | product e1 e2 => 
    let mod1 := e1.build_module' ε
    let mod2 := e2.build_module' ε
    if h : mod1.isSome ∧ mod2.isSome then
      let ⟨mod1', m1⟩ := h.1; let ⟨mod2', m2⟩ := h.2
      some (mod1'.ports ++ mod2'.ports)
    else none

noncomputable def renamePorts (l : List (Ident × Ident)) (e : ExprLow Ident Typ) : Option (ExprLow Ident Typ) :=
  match e with
  | base inst typ => 
    if l = [] then some (base inst typ) else none
  | connect c e => 
    let mod := e.ports.c.get_some
    let mod' := e.ports.c.get_some
    let in' := e.ports.in.get_some
    let out' := e.ports.out.get_some
    if l = [] then some (connect c e) else none
  | product e1 e2 => 
