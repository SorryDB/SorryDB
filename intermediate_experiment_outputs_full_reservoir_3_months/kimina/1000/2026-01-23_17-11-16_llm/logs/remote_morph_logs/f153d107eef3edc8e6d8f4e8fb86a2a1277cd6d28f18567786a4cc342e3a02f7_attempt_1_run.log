theorem renamePorts_well_typed2 [DecidableEq Typ] {ε : Env Ident Typ} {iexpr e : ExprLow Ident Typ} {l} :
  iexpr.well_formed ε →
  e.well_formed ε →
  iexpr.renamePorts l = some e →
  iexpr.well_typed ε →
  e.well_typed ε := by
