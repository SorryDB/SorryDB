  i.invertible → i.bijectivePortRenaming x ∈ i.keysList → x ∈ i.valsList

theorem build_module_interface'_unique {ε : Env Ident Typ} {e mi x y} :
  e.well_formed ε →
  build_module_interface' ε e = some mi →
  mi.inputs.find? x = some y →
  x ∈ e.valsList.1 := by
