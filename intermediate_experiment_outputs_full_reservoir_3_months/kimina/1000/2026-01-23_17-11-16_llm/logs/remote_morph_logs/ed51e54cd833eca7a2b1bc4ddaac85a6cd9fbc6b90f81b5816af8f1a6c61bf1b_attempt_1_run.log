TheoremDoc RealAnalysisGame.HasLUB_of_BddNonempty as "HasLUB_of_BddNonempty" in "x∈U"

Statement HasLUB_of_BddNonempty {S : Set ℝ} (hS : S.Nonempty) {M : ℝ} (hM : IsUB S M) : ∃ L, IsLUB S L := by
