          simp
        rw [show a (n + 1) = (ab (n + 1)).val.1 by rfl] at *
        linarith [h1]
      have h1 : a n ≤ a (n + 1) := by
        linarith [ha']
      exact h1

  have bMono : Monotone b := by
    apply Monotone_of_succ
    intro n
    have h := (ab n).property.2.2.1
    by_cases midS : ∃ s ∈ S, (a n + b n) / 2 ≤ s
    · -- Case 1: Midpoint is not an upper bound
      rcases midS with ⟨s, hs, hmid⟩
      have hb' : b (n + 1) = p.2 := by
        have h1 : (ab (n + 1)).val.2 = p.2 := by
