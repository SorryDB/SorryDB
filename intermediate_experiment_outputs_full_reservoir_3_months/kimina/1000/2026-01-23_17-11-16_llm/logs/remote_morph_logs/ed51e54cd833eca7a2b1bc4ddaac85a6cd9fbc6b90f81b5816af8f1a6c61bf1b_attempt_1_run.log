      p.1 ≤ p.2 ∧
      p.2 - p.1 ≤ (M - s₀) / 2^n} := by
      intro n
      induction' n with n hn
      · use (s₀, M)
        split_ands
        · apply hs₀
        · apply hM
        · bound
