        rw [show b (n + 1) = (ab (n + 1)).val.2 by rfl] at *
        linarith [h1]
      have h1 : b n ≤ b (n + 1) := by
        linarith [hb']
      exact h1
    · -- Case 2: Midpoint is an upper bound
      have hb' : b (n + 1) = mid := by
        have h1 : (ab (n + 1)).val.2 = mid := by
          rw [show (ab (n + 1)).val = (p.1, mid) by
