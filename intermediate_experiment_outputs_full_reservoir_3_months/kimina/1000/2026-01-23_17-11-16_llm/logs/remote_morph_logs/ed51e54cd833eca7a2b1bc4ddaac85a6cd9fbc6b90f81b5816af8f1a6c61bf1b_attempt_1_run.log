    · -- Case where not exists s ∈ S, s > (a n + b n) / 2
      use (p.1, mid)
      split_ands
      · apply hp.1
      · push_neg at midS
        intro s hs
        linarith [midS s hs]
      · change p.1 ≤ (p.1 + p.2) / 2
