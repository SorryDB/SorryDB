        rw [show b (n + 1) = (ab (n + 1)).val.2 by rfl] at *
        linarith [h1]
      have h1 : b n ≤ b (n + 1) := by
        linarith [hb']
      exact h1

  have h1 : ∀ n, a n ≤ b n := by
    intro n
    have h := (ab n).property.2.2.1
    linarith

  have h2 : ∀ n, b n - a n ≤ (M - s₀) / 2^n := by
