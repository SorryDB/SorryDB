structure PrimeFTheory (L : Logic ‚Ñï) extends FTheory L where
  protected prime : ‚àÄ {œÜ œà}, œÜ ‚ãé œà ‚àà theory ‚Üí œÜ ‚àà theory ‚à® œà ‚àà theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {œÜ œà œá Œæ : Formula ‚Ñï} {T : FTheory L} {hT : œá ‚Üí Œæ ‚àâ T.theory}

def construction (T : FTheory L) (hT : œá ‚Üí Œæ ‚àâ T.theory) : ‚Ñï ‚Üí Set (Formula ‚Ñï)
  | 0 => { Œ¥ | œá ‚Üí Œ¥ ‚àà T.theory }
