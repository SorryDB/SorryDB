  . exact orIntroR;
  . assumption;

open Hilbert.F in
lemma iff_mem_CorsiDeducible {T : FTheory (Hilbert.F Ax)} : œÜ ‚àà T.theory ‚Üî Deduction Ax T.theory œÜ := by
  constructor;
  . intro hœÜ;
    apply Deduction.ctx hœÜ;
  . intro h; induction h <;> grind

end FTheory


