def construction_omega (T : FTheory L) (hT : œá ‚ûù Œæ ‚àâ T.theory) : Set (Formula ‚Ñï) := ‚ãÉ i, construction T hT i

lemma subset_construction_succ : construction T hT i ‚äÜ construction T hT (i + 1) := by
