def construction (T : FTheory L) (hT : œá ‚ûù Œæ ‚àâ T.theory) : ‚Ñï ‚Üí Set (Formula ‚Ñï)
  | 0 => { Œ¥ | œá ‚ûù Œ¥ ‚àà T.theory }
