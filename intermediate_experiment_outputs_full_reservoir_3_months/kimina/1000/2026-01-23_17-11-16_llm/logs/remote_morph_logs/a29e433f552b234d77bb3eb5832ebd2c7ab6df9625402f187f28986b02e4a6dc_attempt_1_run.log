  protected prime : ‚àÄ {œÜ œà}, œÜ ‚ãé œà ‚àà theory ‚Üí œÜ ‚àà theory ‚à® œà ‚àà theory

namespace FTheory.lindenbaum

open Classical
open Encodable

variable {œÜ œà œá Œæ : Formula ‚Ñï} {T : FTheory L} {hT : œá ‚ûù Œæ ‚àâ T.theory}

def construction (T : FTheory L) (hT : œá ‚ûù Œæ ‚àâ T.theory) : ‚Ñï ‚Üí Set (Formula ‚Ñï)
  | 0 => { Œ¥ | œá ‚ûù Œ¥ ‚àà T.theory }
