      else T'
    | none => construction T hT i

def construction_omega (T : FTheory L) (hT : œá ‚ûù Œæ ‚àâ T.theory) : Set (Formula ‚Ñï) := ‚ãÉ i, construction T hT i

lemma subset_construction_succ : construction T hT i ‚äÜ construction T hT (i + 1) := by
  dsimp [construction];
  split;
  . split <;> tauto;
  . tauto;

lemma subset_construction_add : construction T hT i ‚äÜ construction T hT (i + j) := by
  induction j with
  | zero => simp;
  | succ j ih =>
