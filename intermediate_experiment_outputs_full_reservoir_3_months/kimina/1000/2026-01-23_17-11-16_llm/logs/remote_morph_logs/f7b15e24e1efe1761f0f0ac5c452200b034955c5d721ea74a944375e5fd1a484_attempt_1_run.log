noncomputable def F (p : ℕ) := Fin p

/- The state of the system, represented as a triple (program counter, accumulator, stack pointer). -/
noncomputable def State (p : ℕ) := (F p) × (F p) × (F p)

/- The program is a function from the program counter to an instruction. -/
noncomputable def program (p : ℕ) : Fin p → F p := fun _ => 0

/- The data memory is a function from the stack pointer to a value. -/
noncomputable def memory (p : ℕ) : Fin p → F p := fun _ => 0

/- The initial state of the system. -/
noncomputable def initialState (p : ℕ) : State p := (0 : F p) × (0 : F p) × (0 : F p)

