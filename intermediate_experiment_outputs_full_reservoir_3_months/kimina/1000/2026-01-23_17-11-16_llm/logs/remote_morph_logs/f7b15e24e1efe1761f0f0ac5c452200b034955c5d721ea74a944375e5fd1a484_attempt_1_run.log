    rw [h_eq, ←c_fetch]
    simp [circuit_norm, explicit_provable_type]

    split at c_decode
    case h_2 =>
      -- impossible, decodeInstructionCircuit ensures that
      -- instruction decode is always successful
      contradiction
    case h_1 instr_type mode1 mode2 mode3 h_eq_decode =>
