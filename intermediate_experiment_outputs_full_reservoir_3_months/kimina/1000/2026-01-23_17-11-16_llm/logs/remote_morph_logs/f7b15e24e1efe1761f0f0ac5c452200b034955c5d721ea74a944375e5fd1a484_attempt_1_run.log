      assumptions := femtoCairoAssumptions,
      spec := fun state nextstate => 
        match Spec.femtoCairoMachineTransition program memory state with
          | some s => s = nextstate
          | none => False -- impossible, constraints ensure that the transition is valid
      soundness := by
        exact_mod_cast (femtoCairoStepCircuitSoundness program h_programSize memory h_memorySize)
      completeness := by
        exact_mod_cast (femtoCairoStepCircuitCompleteness program h_programSize memory h_memorySize)
