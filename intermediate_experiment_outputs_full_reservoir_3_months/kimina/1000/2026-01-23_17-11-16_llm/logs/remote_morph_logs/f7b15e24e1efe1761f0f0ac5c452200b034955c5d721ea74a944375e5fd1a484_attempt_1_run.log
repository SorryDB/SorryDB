import Mathlib

open Nat

/-/
def F (p : ℕ) : Type := ZMod p

/-/
noncomputable def State (p : ℕ) : Type := (Fin p) × (Fin p) × (Fin p)

/-/
noncomputable def Program (p : ℕ) : Type := Fin p → (F p)

/-/
noncomputable def Memory (p : ℕ) : Type := Fin p → (F p)

/-/
noncomputable def femtoCairoStepCircuit (p : ℕ) (h : p > 512) (program : Fin p → (F p)) (h_program : (Finset.range p).card < p) (memory : Fin p → (F p)) (h_memory : (Finset.range p).card < p) :
    GeneralFormalCircuit (F p) (State p) (State p) := {
  elaboratedCircuit := fun state => do
    let { rawInstrType, op1, op2, op3 } := subcircuitWithAssertion (fetchInstructionCircuit program h) state.1
    let { decoded } := subcircuitWithAssertion (decodeInstructionCircuit rawInstrType)
    let { v1 } := subcircuitWithAssertion (readFromMemoryCircuit memory h) { state := state, offset := op1, mode := decoded.mode1 }
    let { v2 } := subcircuitWithAssertion (readFromMemoryCircuit memory h) { state := state, offset := op2, mode := decoded.mode2 }
    let { v3 } := subcircuitWithAssertion (readFromMemoryCircuit memory h) { state := state, offset := op3, mode := decoded.mode3 }
    let { next } := subcircuitWithAssertion (nextStateCircuit state decoded v1 v2 v3)
    next
  assumptions := fun _ => True
  spec := fun state next => match
      Spec.femtoCairoMachineTransition program memory state with
    | some s => s = next
    | none => False
  soundness := by
    intros initial_state i env state_var input_var state input h1 h2 h_inputs h_hold
    simp [circuit_norm, explicit_provable_type] at h_hold h_inputs
    obtain ⟨pc, ap, fp⟩ := state
    obtain ⟨pc'⟩ := input
    simp [circuit_norm, explicit_provable_type] at h_hold
    obtain ⟨ c_fetch, c_decode, c_read1, c_read2, c_read3, c_next ⟩ := h_hold
    split at c_fetch
    case h_2 =>
      contradiction
    case h_1 raw_instruction h_eq =>
      rw [h_eq, ←c_fetch]
      simp [circuit_norm, explicit_provable_type]

      split at c_decode
      case h_2 =>
        contradiction
      case h_1 instr_type mode1 mode2 mode3 h_eq_decode =>
        rw [h_eq_decode]
        obtain ⟨ h_instr_type_val, h_instr_type_encoded_correctly, h_mode1_val,
          h_mode1_encoded_correctly, h_mode2_val, h_mode2_encoded_correctly,
          h_mode3_val, h_mode3_encoded_correctly ⟩ := c_decode
        simp [circuit_norm, explicit_provable_type]

        -- satisfy assumptions of read1
        specialize c_read1 h_mode1_encoded_correctly
        rw [h_mode1_val] at c_read1

        -- satisfy assumptions of read2
        specialize c_read2 h_mode2_encoded_correctly
        rw [h_mode2_val] at c_read2

        -- satisfy assumptions of read3
        specialize c_read3 h_mode3_encoded_correctly
        rw [h_mode3_val] at c_read3

        -- satisfy assumptions of next
        specialize c_next h_instr_type_encoded_correctly
        rw [h_instr_type_val] at c_next

        split at c_read1
        case h_2 =>
          contradiction
        case h_1 v1 h_eq_v1 =>
          rw [h_eq_v1, ←c_read1]
          split at c_read2
          case h_2 =>
            contradiction
          case h_1 v2 h_eq_v2 =>
            rw [h_eq_v2, ←c_read2]
            split at c_read3
            case h_2 =>
              contradiction
            case h_1 v3 h_eq_v3 =>
              rw [h_eq_v3, ←c_read3]
              simp [circuit_norm, explicit_provable_type]

              split at c_next
              case h_2 =>
                contradiction
              case h_1 next_state h_eq_next =>
                rw [←c_next]
                simp [explicit_provable_type, circuit_norm]
  completeness := by
    intros initial_state i env state_var input_var state input h1 h2 h_inputs h_hold
    simp [circuit_norm, explicit_provable_type] at h_hold h_inputs
    obtain ⟨pc, ap, fp⟩ := state
    obtain ⟨pc'⟩ := input
    simp [circuit_norm, explicit_provable_type] at h_hold
    obtain ⟨ c_fetch, c_decode, c_read1, c_read2, c_read3, c_next ⟩ := h_hold
    split at c_fetch
    case h_2 =>
      contradiction
    case h_1 raw_instruction h_eq =>
      rw [h_eq, ←c_fetch]
      simp [circuit_norm, explicit_provable_type]

      split at c_decode
      case h_2 =>
        contradiction
      case h_1 instr_type mode1 mode2 mode3 h_eq_decode =>
        rw [h_eq_decode]
        obtain ⟨ h_instr_type_val, h_instr_type_encoded_correctly, h_mode1_val,
          h_mode1_encoded_correctly, h_mode2_val, h_mode2_encoded_correctly,
          h_mode3_val, h_mode3_encoded_correctly ⟩ := c_decode
        simp [circuit_norm, explicit_provable_type]

        -- satisfy assumptions of read1
        specialize c_read1 h_mode1_encoded_correctly
        rw [h_mode1_val] at c_read1

        -- satisfy assumptions of read2
        specialize c_read2 h_mode2_encoded_correctly
        rw [h_mode2_val] at c_read2

        -- satisfy assumptions of read3
        specialize c_read3 h_mode3_encoded_correctly
        rw [h_mode3_val] at c_read3

        -- satisfy assumptions of next
        specialize c_next h_instr_type_encoded_correctly
        rw [h_instr_type_val] at c_next

        split at c_read1
        case h_2 =>
          contradiction
        case h_1 v1 h_eq_v1 =>
          rw [h_eq_v1, ←c_read1]
          split at c_read2
          case h_2 =>
            contradiction
          case h_1 v2 h_eq_v2 =>
            rw [h_eq_v2, ←c_read2]
            split at c_read3
            case h_2 =>
