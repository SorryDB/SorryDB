    | neg : F p → F p
    -- Memory instructions
    | load : Fin 16 → F p
    | store : Fin 16 → F p
    | get : F p → Fin 16 → F p
    | set : F p → Fin 16 → F p
    -- Control instructions
    | branch : F p → rawInstrType
    | jump : Fin 16 → rawInstrType
