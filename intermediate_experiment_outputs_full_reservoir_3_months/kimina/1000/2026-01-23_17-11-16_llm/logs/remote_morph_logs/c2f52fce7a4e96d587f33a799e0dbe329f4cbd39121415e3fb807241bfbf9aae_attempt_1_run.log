    intro n m hnm
    have h : n < m := hnm
    have h1 : ∀ k : ℕ, b (k + 1) ≤ b k := by
      intro k
      have h2 := (ab k).property.2.2.2
      have h3 := (ab (k + 1)).property.1
      have h4 := (ab (k + 1)).property.2.1
      have h5 := (ab k).property.2.1
      have h6 : b (k + 1) ≤ b k := by
        have h7 : b (k + 1) = (ab (k + 1)).val.2 := by rfl
        have h8 : (ab (k + 1)).val.2 ≤ b k := by
