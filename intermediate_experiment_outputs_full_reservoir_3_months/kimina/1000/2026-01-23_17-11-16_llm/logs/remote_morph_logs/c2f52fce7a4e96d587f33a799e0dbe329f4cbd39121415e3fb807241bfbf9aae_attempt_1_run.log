    intro n
    have h1 : (ab n).property.2.1 := b_prop n
    have h2 : (ab (n + 1)).property.1 := by
      apply (ab (n + 1)).property.1
    sorry

  exact ⟨b, ⟨b_prop n, sorry⟩⟩
