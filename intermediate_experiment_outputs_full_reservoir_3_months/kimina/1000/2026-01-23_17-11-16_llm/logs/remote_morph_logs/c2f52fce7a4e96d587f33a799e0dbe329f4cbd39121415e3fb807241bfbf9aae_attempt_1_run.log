        have h7 : n < m := h4
        have h8 : b n ≥ b m := by
          have h9 : ∀ k : ℕ, b (k + 1) ≤ b k := h6
          have h10 : n < m := h7
          have h11 : b n ≥ b m := by
            have h12 : ∀ k : ℕ, b (k + 1) ≤ b k := h9
            have h13 : n < m := h10
            exact antitone_of_succ_le (show ∀ k : ℕ, b (k + 1) ≤ b k by assumption) (show n < m by assumption)
