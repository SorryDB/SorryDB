      · choose s sInS hs using midS
        use (s, p.2)
        split_ands
        · apply sInS
        · apply hp.2.1
        · bound
        · change p.2 - s ≤ (M - s₀) / 2^(n + 1)
          have hp' := hp.2.2.2
