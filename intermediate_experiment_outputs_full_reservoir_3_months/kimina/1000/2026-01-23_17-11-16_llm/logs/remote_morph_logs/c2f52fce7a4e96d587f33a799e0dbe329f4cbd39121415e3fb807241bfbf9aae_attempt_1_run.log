      sorry
    have f1 : a n ≤ b n := by bound
    linarith [f1, ha', ha'', hs]
  · have ha' : a (n + 1) = a n := by sorry
    linarith [ha']

have bAnti : Antitone b := by
  intro n
  have h1 := (ab n).property.2.2.1
  have h2 := (ab (n + 1)).property.2.2.1
  have h3 : b (n + 1) ≤ b n := by
