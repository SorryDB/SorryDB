          <;> tauto
        simp [h5]
        <;> tauto
      have f1 : a n ≤ b n := by
        have h6 : (ab n).val.1 ≤ (ab n).val.2 := by
          have h7 : (ab n).property.1 := by
            apply (ab n).property.1
          simp at h7 ⊢
          <;> try { tauto } <;> try { linarith }
        simp [h6]
        <;> try { tauto } <;> try { linarith }
      linarith [f1, ha', ha'', hs]
    · have ha' : a (n + 1) = a n := by
        have h5 : (ab (n + 1)).val = (a n, (a n + b n) / 2) := by
          simp [midS]
          <;> tauto
        simp [h5]
        <;> tauto
      linarith [ha']

