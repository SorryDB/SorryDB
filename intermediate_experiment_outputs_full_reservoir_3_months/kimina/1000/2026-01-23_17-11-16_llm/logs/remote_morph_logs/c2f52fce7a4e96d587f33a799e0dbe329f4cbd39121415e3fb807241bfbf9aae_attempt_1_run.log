      have f1 : a n ≤ b n := by bound
      linarith [f1, ha', ha'', hs]
    · have ha' : a (n + 1) = a n := by sorry
      linarith [ha']

  have bAnti : Antitone b := by
    intro n
    induction n with
    | zero =>
      simp
      <;> try { tauto }
    | succ n ih =>
      have h1 : b (n + 2) ≤ b (n + 1) := by
        have h2 := (ab (n + 2)).property.1
        have h3 := (ab (n + 1)).property.1
        have h4 := (ab (n + 2)).property.2.1
        have h5 := (ab (n + 1)).property.2.1
        have h6 := (ab (n + 2)).property.2.2.1
        have h7 := (ab (n + 1)).property.2.2.1
        have h8 := (ab (n + 2)).property.2.2.2
        have h9 := (ab (n + 1)).property.2.2.2
        by_cases h : ∃ s ∈ S, ( (ab (n + 1)).val.1 + (ab (n + 1)).val.2 ) / 2 ≤ s
        · -- If there exists an element s in S such that mid ≤ s, then b (n + 2) = b (n + 1)
