          have f : (p.1 + p.2) * 2 ^ n ≤ 2 * s * 2 ^ n := by bound
          linarith [hp', hs, hp.2.2.1, f]
      · use (p.1, mid)
        split_ands
        · apply hp.1
        · push_neg at midS
          intro s hs
          linarith [midS s hs]
        · change p.1 ≤ (p.1 + p.2) / 2
          linarith [hp]
        · change (p.1 + p.2) / 2 - p.1 ≤ (M - s₀) / 2^(n + 1)
          have hp' := hp.2.2.2
          field_simp at ⊢ hp'
          rewrite [show (2 : ℝ) ^ (n + 1) = 2 * 2 ^ n by ring_nf]
          linarith [hp']

  let a : ℕ → ℝ := fun n ↦ (ab n).val.1
  let b : ℕ → ℝ := fun n ↦ (ab n).val.2

