/- lemma HasEnoughRootsOfUnity.of_mulEquiv {M M' : Type*} [CommMonoid M] [CommMonoid M'] {n : ℕ}
    [NeZero n] [HasEnoughRootsOfUnity M n] (equiv : rootsOfUnity n M ≃* rootsOfUnity n M') :
    HasEnoughRootsOfUnity M' n where
