import Mathlib.Analysis.Complex.Circle
import Mathlib.Analysis.Complex.Polynomial.Basic
import Mathlib.Analysis.Normed.Field.UnitBall
import Mathlib.RingTheory.RootsOfUnity.AlgebraicallyClosed

/-!
### Auxiliary lemmas
