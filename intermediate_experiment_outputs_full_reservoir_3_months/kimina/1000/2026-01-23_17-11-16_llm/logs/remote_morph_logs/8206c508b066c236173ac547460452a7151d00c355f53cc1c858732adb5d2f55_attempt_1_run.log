          (List.replicate (n + 1) (⟨0, Nat.zero_lt_succ _⟩ : Fin (n + 1))).map (λ (i : Nat) => i) := by
          simp [List.mapFinIdx_replicate, Fin.mk.injEq]
        have eq1 : (0, Nat.zero_lt_succ _) :: (fin_range n).map lift_fin =
          (List.replicate (n + 1) (⟨0, Nat.zero_lt_succ _⟩ : Fin (n + 1))).map (λ (i : Nat) => i) := by
          simp [List.map_cons, List.map_map, Fin.mk.injEq, HR]
        rw [eq1, eq2]

