```tactics
    theorem map_mapFinIdx {α β δ} (l : List α) (f : (i : Nat) → α → (h : i < l.length) → β) (g : β → δ) :
      (l.mapFinIdx f).map g = l.mapFinIdx (λ i v h => g (f i v h)) := by
        revert f g
        induction l with
        | nil => intros _ _; rfl
        | cons hd tl HR =>
          intro f g
          simp only [List.mapFinIdx_cons, List.map_cons, HR, List.length_cons]
```

