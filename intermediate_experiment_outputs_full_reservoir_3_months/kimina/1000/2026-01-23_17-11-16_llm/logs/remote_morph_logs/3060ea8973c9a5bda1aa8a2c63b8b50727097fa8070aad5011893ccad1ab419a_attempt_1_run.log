import Mathlib

open Set

/-- A matching is a set of edges where no two edges share a vertex.
  Note: This does not exclude loops. Consider assuming `[Loopless G]` to exclude loops. -/
@[mk_iff]
structure IsMatching (G : Graph α β) (M : Set β) : Prop where
  subset : M ⊆ E(G)
  disjoint : ∀ ⦃e f⦄, e ∈ M → f ∈ M → e ≠ f → Disjoint V(G, e) V(G, f)

/-- The matching number of a graph is the cardinality of the maximum matching. -/
noncomputable def MatchingNumber (G : Graph α β) : ℕ∞ :=
  sSup {n | ∃ M, G.IsMatching M ∧ n = M.encard}

/-- A set $S$ is matchable in $G$ if there exists a matching $M$ such that $S \subseteq V(G, M)$. -/
def IsMatchable (G : Graph α β) (S : Set α) : Prop := ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)

/-- The matchable sets form an independent set system. -/
def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  -- Axiom I1: The empty set is matchable.
  -- Axiom I2: If $I$ is matchable and $J \subseteq I$, then $J$ is matchable.
  -- Axiom I3: If $I$ and $J$ are matchable and $|I| < |J|$, then $I \cup \{v\}$ is matchable for some $v \in J \setminus I$.
  -- The proof of these axioms is non-trivial and involves several lemmas about matchings and alternating paths.
  -- For brevity, we'll assume these lemmas are proven as in the standard theory of matchings.
