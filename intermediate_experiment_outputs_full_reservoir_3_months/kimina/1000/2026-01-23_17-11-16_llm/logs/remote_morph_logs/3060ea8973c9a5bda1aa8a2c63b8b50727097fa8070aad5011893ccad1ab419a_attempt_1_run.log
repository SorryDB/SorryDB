import Mathlib

open Graph

namespace MatroidGraph

variable {α β : Type*} {G : Graph α β}

noncomputable def Matchable (G : Graph α β) : Set (Set α) :=
  {S | ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)}

lemma matchable_empty (G : Graph α β) : ∅ ∈ Matchable G := by
  use ∅
  simp [isMatching_empty, Set.subset_empty]
```

