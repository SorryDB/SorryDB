    have h11 : (2 : ℝ) ^ (S.card - 1 : ℝ) ≥ (0 : ℝ) := by positivity
    have h12 : (2 : ℝ) ^ (S.card : ℝ) ≥ (0 : ℝ) := by positivity
    have h13 : (3 / 2 : ℝ) = (2 : ℝ) ^ (S.card - 1 : ℝ) ∨ (3 / 2 : ℝ) = (2 : ℝ) ^ (S.card : ℝ) := by
