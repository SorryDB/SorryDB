      ∃ S : Finset (Fin n), S.Nonempty ∧
        (deck j + deck k : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ))) →
      ∀ i j, deck i = deck j} = answer := by
  ext n
  simp only [Set.mem_setOf_eq, Set.mem_insert_iff, Set.mem_singleton_iff, and_imp]
  constructor
  · -- First, we show that if $n$ satisfies the property, then $n \in \{2, 3\}$.
    intro h
    rcases h with ⟨h1, h⟩
    have h2 := h (fun i => if i = 0 then 1 else 2) (by
      intro i
      fin_cases i
      all_goals simp
    )
    have h3 := h2 0 1
    rcases h3 with ⟨S, hS, heq⟩
    have h4 : S.Nonempty := hS
    have h5 : (deck 0 + deck 1 : ℝ) / 2 = (∏ i ∈ S, (deck i : ℝ)) ^ (1 / (#S : ℝ)) := heq
    have h6 : (∏ i ∈ S, (deck i : ℝ)) = (∏ i ∈ S, if i = 0 then (1 : ℝ) else (2 : ℝ)) := by
      apply Finset.prod_congr
      · rfl
      · intro i hi
        simp [show i = 0 ∨ i ≠ 0 by omega]
        <;> fin_cases i <;> simp
    rw [h6] at h5
    have h7 : (∏ i ∈ S, (if i = 0 then (1 : ℝ) else (2 : ℝ))) = (2 : ℝ) ^ (S.card - 1 : ℝ) := by
      have h14 : 0 ∈ S ∨ 0 ∉ S := by omega
      rcases h14 with (h14 | h14)
      · -- 0 ∈ S
        have h15 : (∏ i ∈ S, if i = 0 then (1 : ℝ) else (2 : ℝ)) = (1 : ℝ) * (∏ i ∈ S \ {0}, (if i = 0 then (1 : ℝ) else (2 : ℝ))) := by
          rw [Finset.prod_eq_mul_prod_diff_singleton h14]
          <;> simp
        rw [h15]
        have h16 : (∏ i ∈ S \ {0}, (if i = 0 then (1 : ℝ) else (2 : ℝ))) = (2 : ℝ) ^ ((S \ {0}).card : ℝ) := by
          apply Finset.prod_eq_pow_card
          intro i hi
          simp at hi ⊢
          omega
        rw [h16]
        have h17 : (S \ {0}).card = S.card - 1 := by
          simp [Finset.card_sdiff, h14]
          all_goals omega
        rw [h17]
        all_goals norm_num
      · -- 0 ∉ S
        have h16 : (∏ i ∈ S, if i = 0 then (1 : ℝ) else (2 : ℝ)) = (2 : ℝ) ^ (S.card : ℝ) := by
          apply Finset.prod_eq_pow_card
          intro i hi
          simp at hi ⊢
          omega
        rw [h16]
        all_goals norm_num
    rw [h7] at h5
    have h8 : S.card ≥ 1 := by
      have h13 : S.Nonempty := hS
      simp at h13 ⊢
      omega
    have h9 : (S.card : ℝ) ≥ (1 : ℝ) := by
      exact_mod_cast h8
    have h10 : (S.card - 1 : ℝ) ≥ (0 : ℝ) := by
      have h11 : (S.card : ℝ) ≥ (1 : ℝ) := by
