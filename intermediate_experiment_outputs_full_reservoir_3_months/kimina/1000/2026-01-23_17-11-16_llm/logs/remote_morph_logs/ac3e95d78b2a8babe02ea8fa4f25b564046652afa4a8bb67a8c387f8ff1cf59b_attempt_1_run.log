        simp [coerceWord] at h3 ⊢
        exact h3
      have h3 : w' = w := by
        apply word_eq_of_val_eq
        intro i
        exact h2 i
      exact h3
    have hw1 : w ∈ l := by
      rw [show w' = w by exact h_eq] at hw'1
      exact hw'1
    exact hw1
