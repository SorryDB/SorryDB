import Mathlib
open Real

/- Central moments of the semicircle distribution
  The semicircle distribution with parameter v > 0 has probability density function
  f(x) = 1/(π√(4v - x²)) for -2√v ≤ x ≤ 2√v and 0 otherwise.
  The central moments are given by
  μₖ = ∫_{-2√v}^{2√v} x^k f(x) dx.
  For k even, μₖ = v^{k/2} * Catalan(k/2).
  For k odd, μₖ = 0.

  We prove the odd case here. -/
lemma centralMoment_fun_odd_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment (fun x ↦ x) ((2 * n) + 1) (semicircleReal μ v)
    = 0 := by
  dsimp [centralMoment]; simp
