/- The k-th central moment of the semicircle distribution with location μ and
scale v > 0 is given by v^k * Catalan(k / 2). -/
lemma centralMoment_two_mul_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment id (2 * n) (semicircleReal μ v)
    = v ^ n * catalan n := by
  unfold id; apply centralMoment_semicircleReal

/- The k-th central moment of the semicircle distribution with location μ and
scale v > 0 is zero if k is odd. -/
