lemma centralMoment_odd_semicircleReal (μ : ℝ) (v : ℝ≥0) (k : ℕ) (hk : Odd k) : centralMoment (fun x ↦ x) k (semicircleReal μ v) = 0 := by
  have hk1 : k % 2 = 1 := by
    obtain ⟨m, hm⟩ := hk
    omega
  have hk2 : Even (k - 1) := by
    use (k - 1) / 2
    omega
  have hk3 : k = (k - 1) + 1 := by omega
  rw [hk3]
  have hk4 : k - 1 = 2 * ((k - 1) / 2) := by
    omega
  rw [hk4]
  apply centralMoment_fun_odd_semicircleReal

/- The k-th central moment of the semicircle distribution with location μ and
scale v > 0 is given by v^k * Catalan(k / 2). -/
lemma centralMoment_two_mul_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment id (2 * n) (semicircleReal μ v)
    = v ^ n * catalan n := by
  unfold id; apply centralMoment_semicircleReal

