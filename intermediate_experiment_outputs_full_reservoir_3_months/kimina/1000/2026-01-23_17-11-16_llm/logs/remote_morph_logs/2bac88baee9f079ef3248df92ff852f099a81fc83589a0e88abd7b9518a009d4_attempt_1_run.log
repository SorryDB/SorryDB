import Mathlib


open ProbabilityTheory


/- The semicircle distribution with location μ and scale v > 0 is defined as
the distribution of the random variable X such that X = Y / √(2v) + μ, where Y
is a standard normal distribution. -/
def semicircleReal (μ : ℝ) (v : ℝ≥0) (x : ℝ) : ℝ := (x - μ) ^ 2 / (2 * v) - 1

/- The k-th central moment of a distribution is given by
E[(X - E[X])^k] where E denotes expectation. -/
def centralMoment (f : ℝ → ℝ) (k : ℕ) (p : ProbabilityMeasure ℝ) : ℝ :=
  integral (fun x ↦ (x - (∫ (y : ℝ) in p.support, y) ^ k) d p) f

/- The k-th moment of a distribution is given by E[X^k]. -/
def moment (f : ℝ → ℝ) (k : ℕ) (p : ProbabilityMeasure ℝ) : ℝ :=
  integral (fun x ↦ x ^ k) d p

/- The k-th central moment of a semicircle distribution is given by
E[(X - μ)^k] where X is a semicircle distributed random variable. -/
lemma centralMoment_semicircleReal (μ : ℝ) (v : ℝ≥0) (k : ℕ) : centralMoment (fun x ↦ x) k (semicircleReal μ v) = if Even k then 2 * v ^ (k / 2) else 0 := by
  unfold centralMoment; dsimp [fun, semicircleReal]
  simp

/- The k-th central moment of the semicircle distribution with location μ and
scale v > 0 is given by v^k * Catalan(k / 2). -/
lemma centralMoment_two_mul_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment id (2 * n) (semicircleReal μ v)
    = v ^ n * catalan n := by
  unfold id; apply centralMoment_semicircleReal

/- The k-th central moment of the semicircle distribution with location μ and
scale v > 0 is zero if k is odd. -/
lemma centralMoment_fun_odd_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment (fun x ↦ x) ((2 * n) + 1) (semicircleReal μ v)
    = 0 := by
  dsimp [centralMoment]; simp

lemma centralMoment_two_mul_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment id (2 * n) (semicircleReal μ v)
    = v ^ n * catalan n := by
  unfold id; apply centralMoment_semicircleReal

lemma centralMoment_fun_odd_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment (fun x ↦ x) ((2 * n) + 1) (semicircleReal μ v)
    = 0 := by
  dsimp [centralMoment]; simp

/- The k-th moment of a semicircle distribution is given by
E[X^k] where X is a semicircle distributed random variable. -/
lemma moment_semicircleReal (μ : ℝ) (v : ℝ≥0) (k : ℕ) : moment (fun x ↦ x) k (semicircleReal μ v) = 2 * v ^ (k / 2 + 1) := by
  unfold moment; dsimp [fun, semicircleReal]
  simp

/- The k-th moment of the semicircle distribution with location μ and
