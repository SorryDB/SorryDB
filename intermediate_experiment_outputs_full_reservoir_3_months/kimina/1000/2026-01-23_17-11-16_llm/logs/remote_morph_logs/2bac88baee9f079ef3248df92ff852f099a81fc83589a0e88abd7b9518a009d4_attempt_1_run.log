import Mathlib

open MeasureTheory

/- The nth central moment of a real-valued random variable X is defined as E[(X - E[X])^n]. -/
def centralMoment (f : ℝ → ℝ) (n : ℕ) (P : Measure ℝ) :=
  ∫ (x : ℝ) in Set.univ, f x * (x - ∫ (y : ℝ) in Set.univ, id y * P) ^ n dP

/- The semicircle distribution with mean μ and variance v (where v ≥ 0) is defined as
  f(x) = (1 / (2 * π * √v)) * √(4v - x^2) for x ∈ [-2√v, 2√v] and 0 otherwise. -/
