have h3 : (-1 : ℝ) * x = -x := by ring
```

Next, we'll compute `f(-x)` and show it equals `-f(x)`.

```tactics
have h4 : (-x) ^ (2 * n + 1) = - (x ^ (2 * n + 1)) := by
  have h5 : ∀ k : ℕ, (-x) ^ (2 * k + 1) = - (x ^ (2 * k + 1)) := by
    intro k
    induction k with
    | zero =>
      simp
    | succ k ih =>
      simp [pow_succ, pow_mul] at ih ⊢
      all_goals try linarith [ih]
      all_goals try ring_nf at ih ⊢
