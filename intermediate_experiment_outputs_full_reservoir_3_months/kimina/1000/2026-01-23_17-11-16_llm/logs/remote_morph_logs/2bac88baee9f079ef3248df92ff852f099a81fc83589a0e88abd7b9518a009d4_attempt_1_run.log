import Mathlib

open MeasureTheory ProbabilityTheory

/- Define the semicircle real distribution. -/
def semicircleReal (μ : ℝ) (v : ℝ≥0) : Measure ℝ :=
  (if v = 0 then
    (Dirac δ μ).push (by simp)
  else
    ((fun x : ℝ ↦ (1 / π) * Real.sqrt (4 * v - x ^ 2)) |>.toMeasure (by
      intro x
      simp
      <;> try { positivity }
      <;> try { norm_num }
      <;> try { linarith [Real.pi_pos] }
    )).push (by
      simp [v]
      <;> try { positivity }
      <;> try { norm_num }
      <;> try { linarith [Real.pi_pos] }
    )
    |>.toProbabilityMeasure
    |>.toMeasure
  )
  |>.toMeasure

/- Define the central moment of order k of a distribution. -/
def centralMoment (f : ℝ → ℝ) (k : ℕ) (m : Measure ℝ) :=
  ∫ x in m.support, f x * m.density x ^ k

/- Define the central moment of order k of a distribution. -/
def centralMoment' (f : ℝ → ℝ) (k : ℕ) (m : Measure ℝ) :=
  ∫ x in m.support, f x * m.density x ^ k

/- The central moment of order k of the semicircle real distribution. -/
