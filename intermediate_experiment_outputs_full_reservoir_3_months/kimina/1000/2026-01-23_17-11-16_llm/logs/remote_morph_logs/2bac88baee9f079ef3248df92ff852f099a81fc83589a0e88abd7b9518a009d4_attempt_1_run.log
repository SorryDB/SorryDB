import Mathlib

open Real

/- The k-th central moment of a distribution is given by E[(X - μ)^k], where μ is the mean of the distribution. -/
def centralMoment (f : ℝ → ℝ) (k : ℕ) (P : Measure ℝ) := ∫ (x : ℝ) in univ, f (x - P.mean) * P.density x dP

/- The semicircle real distribution is defined as the distribution of X = √(4v - Y^2) where Y is a standard normal variable. It is a symmetric distribution about the mean `μ = 2√v`. For a symmetric distribution, all the odd central moments are zero. -/
def semicircleReal (μ : ℝ) (v : ℝ≥0) : Measure ℝ :=
  (MeasureTheory.Measure.comp (fun x : ℝ => √(4 * v - x ^ 2)) (Real.volume)) push ({x | x ∈ Set.Icc (-2 * √v) (2 * √v)}) (fun x ↦ 1 / (2 * π * √(4 * v - x ^ 2)) * √(4 * v - x ^ 2)) (fun x ↦ 1 / (2 * π))

lemma centralMoment_two_mul_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment id (2 * n) (semicircleReal μ v)
    = v ^ n * catalan n := by
  unfold id; apply centralMoment_fun_two_mul_semicircleReal

lemma centralMoment_fun_odd_semicircleReal (μ : ℝ) (v : ℝ≥0) (n : ℕ) :
    centralMoment (fun x ↦ x) ((2 * n) + 1) (semicircleReal μ v)
    = 0 := by
