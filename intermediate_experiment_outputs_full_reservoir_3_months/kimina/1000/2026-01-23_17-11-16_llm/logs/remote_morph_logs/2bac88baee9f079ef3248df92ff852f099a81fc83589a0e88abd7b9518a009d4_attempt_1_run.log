import Mathlib
open Real

/- The semicircle real distribution on [-2 * sqrt v, 2 * sqrt v] -/
def semicircleReal (μ : ℝ) (v : ℝ≥0) : MeasureTheory.Measure ℝ :=
  if h : v = 0 then
    if μ = 0 then
      Dirac 0
    else
      MeasureTheory.zeroMeasure
  else
    -- The semicircle real distribution is defined as
    -- (1/(2π√v)) * √(4v - x²) on [-2√v, 2√v]
    -- and 0 otherwise.
    -- We use `v₀` as the variable inside the sqrt.
    -- This is a common parametrization where v₀ = √v
    -- and the distribution is (1/(2πv₀)) * √(4v₀² - x²)
    -- on [-2v₀, 2v₀].
    let v₀ : ℝ := √v
    -- The interval where the distribution is non-zero
    let interval : Set ℝ := Icc (-2 * v₀) (2 * v₀)
    -- The probability density function (PDF)
    let pdf (x : ℝ) := if x ∈ interval then (1 / (2 * π * v₀)) * √(4 * v₀² - x²) else 0
    -- Construct the measure using the PDF
    MeasureTheory.Measure.ofPDF pdf
