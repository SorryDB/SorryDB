  simp [h1]
  set f := fun (x : ℝ) ↦ x ^ (2 * n + 1) * √(4 * ↑v - x ^ 2)
  have c0 : ∀ (x : ℝ), f (-1 * x) = - f x := by
    intro x
    simp [f]
    <;> ring_nf
    <;> simp [pow_succ, pow_mul, mul_pow]
    <;> ring_nf
  have h3 : ∫ (x : ℝ) in -2 * Real.sqrt v ..2 * Real.sqrt v, f x = 0 := by
    have h4 : ∀ (x : ℝ), f (-x) = -f x := by
