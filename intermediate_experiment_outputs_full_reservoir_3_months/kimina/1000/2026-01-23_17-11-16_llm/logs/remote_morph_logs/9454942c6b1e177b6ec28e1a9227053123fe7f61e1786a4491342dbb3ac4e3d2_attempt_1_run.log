  intro N hN
  simp only [Set.mem_iUnion, Set.mem_iUnion] at hN
  rcases hN with ⟨N', hN', hN''⟩
  have hN_in_D : N' ∈ D := hN'
  have hN_eq_N' : N = N' := by
    have hN'_eq_sSup : N' = sSup (B N' hN') := by
      apply hB N' hN'
    have hN_in_sSup : N ∈ sSup (B N' hN') := by
      simpa using hN''
    rw [hN'_eq_sSup] at *
    exact hN_in_sSup
  rw [hN_eq_N']
  exact hN_in_D
