  intro N hN
  use B N hN
  constructor
  · -- Show that B N hN ⊆ refinement B hB hB' hB''
    simp [refinement, Set.subset_def]
    intro p hp
    simp only at hp
    rcases hp with ⟨N', hN', p⟩
    simp [Set.mem_iUnion]
    tauto
  · -- Show that N = sSup (B N hN)
