import Mathlib

open Set TopologicalSpace
open scoped Distributions CompactConvergenceCLM

variable
  {E : Type*} [NormedAddCommGroup E] [NormedSpace ℝ E] {Ω : Opens E}
  {F : Type*} [AddCommGroup F] [Module ℝ F] [TopologicalSpace F]
  {F' : Type*} [AddCommGroup F'] [Module ℝ F'] [TopologicalSpace F']
  {n k : ℕ∞}

-- We define `Distribution` as an abbreviation for `𝓓'^{n}(Ω, F)` where `n` is top infinity
variable (Ω F n) in
abbrev Distribution := 𝓓'^{n}(Ω, F)

-- Notation for the space of distributions of order less than `n`.
@[Notation] notation "𝓓'^{" n "}(" Ω ", " F ")" => Distribution Ω F n

-- Notation for the space of distributions `𝓓'(Ω, F)`.
@[Notation] notation "𝓓'(" Ω ", " F ")" => Distribution Ω F ⊤

namespace Distribution

-- This lemma proves that the derivative of a sum of distributions is the sum of their derivatives.
lemma mapCLM [IsTopologicalAddGroup F] [ContinuousSMul ℝ F] [IsTopologicalAddGroup F']
    [ContinuousSMul ℝ F'] (A : F →L[ℝ] F') : 𝓓'^{n}(Ω, F) →L[ℝ] 𝓓'^{n}(Ω, F') :=
  A.postcomp_uniformConvergenceCLM _

@[simp]
lemma mapCLM_apply [IsTopologicalAddGroup F] [ContinuousSMul ℝ F] [IsTopologicalAddGroup F']
    [ContinuousSMul ℝ F'] {A : F →L[ℝ] F'} {T : 𝓓'^{n}(Ω, F)} {f : 𝓓^{n}(Ω, ℝ)} :
    mapCLM A T f = A (T f) := rfl

