def RingEquiv.comp (g : S ≃+* T) (f : R ≃+* S) : R ≃+* T where
  toFun x := g (f x)
  invFun x := f.symm (g.symm x)
  left_inv := by
    sorry
  right_inv := by
    sorry
  map_add' := by
    sorry
  map_mul' := by
    sorry

example {R S T : Type*} [CommRing R] [CommRing S] [CommRing T] (f : R ≃+* S) (g : S ≃+* T) : R ≃+* T :=
  RingEquiv.comp g f
