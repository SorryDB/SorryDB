 (∀ args : Vector (ZMod p) w, rw_bisim d (k args).eval) ->
 rw_bisim d (Cs.curry k).eval := by
  intro w
  induction w
  case _ =>
    intros d k h
    simp [Cs.curry]
    apply h
  case _ ih =>
    intros d k h
    simp [Cs.curry]
    constructor
    intro x
    apply ih
    intro args
    apply h

def assert_bits {w : ℕ} (args : Vector (ZMod p) w) : Bool :=
  Vector.all args (fun (x : ZMod p) => x == 0 ∨ x == 1)

