  intros args
  have : args = #v[] := by simp
  simp [this, assert_bits_e]
| succ w ih =>
  intros args cs h
  have : args = Vector.insertIdx args.tail 0 args.head := by
    simp only [Vector.insertIdx_zero]
    ext i h
