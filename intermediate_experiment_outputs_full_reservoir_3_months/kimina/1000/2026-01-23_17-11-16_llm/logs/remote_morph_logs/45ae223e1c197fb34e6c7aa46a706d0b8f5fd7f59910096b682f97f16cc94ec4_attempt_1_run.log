/- A semicircle distribution on `ℝ` with mean `μ` and variance `v`. -/
noncomputable
def semicirclePDF (μ : ℝ) (v : ℝ≥0) (x : ℝ) : ℝ≥0 :=
  if v = 0 then
    if x = μ then 1 / 2 else 0
  else
    ENNReal.ofReal (1 / (2 * π * (v : ℝ)) * Real.sqrt (4 * (v : ℝ) - (x - μ) ^ 2))

/- The support of a semicircle distribution is the interval `(μ - 2√v, μ + 2√v)`. -/
lemma support_semicirclePDF (μ : ℝ) (v : ℝ≥0) : Function.support (semicirclePDF μ v) = Ioo (μ - 2 * √v) (μ + 2 * √v) := by
