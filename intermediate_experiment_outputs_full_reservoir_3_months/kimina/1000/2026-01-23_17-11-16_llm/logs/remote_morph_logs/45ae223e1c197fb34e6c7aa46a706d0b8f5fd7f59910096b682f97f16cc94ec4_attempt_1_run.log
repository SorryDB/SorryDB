    all_goals
      norm_num

lemma variance_fun_id_semicircleReal : Var[fun x ↦ x; semicircleReal μ v] = v := by
  by_cases hv : v = 0
  · -- If v = 0, the measure is Dirac measure at μ, so the variance is 0.
