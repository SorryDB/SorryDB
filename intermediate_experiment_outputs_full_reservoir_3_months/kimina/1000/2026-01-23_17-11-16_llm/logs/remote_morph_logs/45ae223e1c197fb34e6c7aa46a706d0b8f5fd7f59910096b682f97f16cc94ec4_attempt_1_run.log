noncomputable def semicirclePDF (μ : ℝ) (v : ℝ≥0) (x : ℝ) : ENNReal :=
  if v = 0 then
    if x = μ then 1 else 0
  else
    if abs (x - μ) < 2 * √v then
      (1 / (2 * π * v)) * √(4 * v - (x - μ) ^ 2)
    else
      0
