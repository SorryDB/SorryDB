import Mathlib

open Real MeasureTheory ProbabilityTheory

noncomputable def semicirclePDFReal (μ : ℝ) (v : ℝ≥0) (x : ℝ) : ENNReal :=
  if |x - μ| < 2 * √v then
    1 / (2 * π * v) * √(4 * v - (x - μ) ^ 2)
  else
    0

lemma semicirclePDFReal_nonneg {μ : ℝ} {v : ℝ≥0} {x : ℝ} : 0 ≤ semicirclePDFReal μ v x := by
  simp [semicirclePDFReal, if_pos]
  positivity

noncomputable def semicircleReal (μ : ℝ) (v : ℝ≥0) : Measure ℝ :=
  if v = 0 then Measure.dirac μ else volume.withDensity (semicirclePDFReal μ v)

lemma semicircleReal_of_var_ne_zero (μ : ℝ) {v : ℝ≥0} (hv : v ≠ 0) :
    semicircleReal μ v = volume.withDensity (semicirclePDFReal μ v) := if_neg hv

@[simp]
lemma semicircleReal_zero_var (μ : ℝ) : semicircleReal μ 0 = Measure.dirac μ := if_pos rfl

instance instIsProbabilityMeasuresemicircleReal (μ : ℝ) (v : ℝ≥0) :
    IsProbabilityMeasure (semicircleReal μ v) where
  measure_univ := by by_cases h : v = 0 <;> simp [semicircleReal_of_var_ne_zero, h]

lemma integral_id_semicircleReal : ∫ x, x ∂semicircleReal μ v = μ := by
  sorry

lemma variance_id_semicircleReal : Var[id; semicircleReal μ v] = v := by
  sorry

lemma memLp_id_semicircleReal (p : ℝ≥0) : MemLp id p (semicircleReal μ v) := by
  have h1 : (id : ℝ → ℝ) ∈ Lp (p) (semicircleReal μ v) := by
    apply memLp_of_mem_interior_integrableExpSet
    · -- Show that the support is contained in the set
      intro x hx
      simp at hx ⊢
      tauto
    · -- Show that the function is integrable over the support
      apply MeasureTheory.integrable_of_mem_interior_expSet
      · -- Show that the support is contained in the set
        intro x hx
        simp at hx ⊢
