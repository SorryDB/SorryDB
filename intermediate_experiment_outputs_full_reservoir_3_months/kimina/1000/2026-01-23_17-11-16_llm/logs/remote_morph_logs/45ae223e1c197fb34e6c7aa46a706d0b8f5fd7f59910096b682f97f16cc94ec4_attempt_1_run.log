  rw [semicircleReal_of_var_ne_zero _ hv, withDensity_apply' _ s]

lemma semicircleReal_absolutelyContinuous (μ : ℝ) {v : ℝ≥0} (hv : v ≠ 0) :
    semicircleReal μ v ≪ volume := by
