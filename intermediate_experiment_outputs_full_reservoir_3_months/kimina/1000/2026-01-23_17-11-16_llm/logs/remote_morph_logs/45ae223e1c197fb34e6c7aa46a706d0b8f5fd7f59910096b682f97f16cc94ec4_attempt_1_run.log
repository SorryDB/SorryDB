```lean
import Mathlib

open ProbabilityTheory MeasureTheory

/- A semicircle distribution on `ℝ` with mean `μ` and variance `v`. -/
noncomputable
def semicircleReal (μ : ℝ) (v : ℝ≥0) : Measure ℝ :=
  if v = 0 then Measure.dirac μ else volume.withDensity (semicirclePDF μ v)

lemma semicircleReal_of_var_ne_zero (μ : ℝ) {v : ℝ≥0} (hv : v ≠ 0) :
    semicircleReal μ v = volume.withDensity (semicirclePDF μ v) := if_neg hv

@[simp]
lemma semicircleReal_zero_var (μ : ℝ) : semicircleReal μ 0 = Measure.dirac μ := if_pos rfl

lemma memLp_id_semicircleReal (p : ℝ≥0) : MemLp id p (semicircleReal μ v) := by
  have h3 : Integrable (fun x : ℝ => |x| ^ p) (semicircleReal μ v) := by
    have h4 : (semicircleReal μ v).isProbabilityMeasure := by 
      infer_instance
    have h7 : ∀ x : ℝ, |x| ^ p ≥ 0 := by 
      intro x 
      positivity
    have h8 : (semicircleReal μ v).IsLocallyFiniteMeasure := by 
      infer_instance
    have h9 : ∀ x ∈ (semicircleReal μ v).support, |x| ^ p ≤ (|μ| + 2 * √(v : ℝ)) ^ p := by 
      intro x hx
      have h10 : x ∈ (semicircleReal μ v).support := hx
      have h11 : v ≠ 0 ∨ v = 0 := by by_cases h; tauto; tauto
      rcases h11 with (hv | hv)
      · -- Case v ≠ 0
        have h12 : (semicircleReal μ v).support = Ioo (μ - 2 * √(v : ℝ)) (μ + 2 * √(v : ℝ)) := by
          rw [semicircleReal_of_var_ne_zero _ hv]
          simp [volume.support, Function.support, semicirclePDF]
          <;> aesop
        rw [h12] at h10
        rcases h10 with ⟨h13, h14⟩
        have h15 : |x - μ| < 2 * √(v : ℝ) := by
          have h16 : - (2 * √(v : ℝ)) < x - μ := by linarith
          have h17 : x - μ < 2 * √(v : ℝ) := by linarith
          apply abs_lt.mpr
          constructor <;> linarith
        have h18 : |x| ≤ |μ| + 2 * √(v : ℝ) := by
          have h19 : |x| = |(x - μ) + μ| := by ring_nf
          rw [h19]
          have h20 : |(x - μ) + μ| ≤ |x - μ| + |μ| := by 
            apply abs_add
          have h21 : |x - μ| < 2 * √(v : ℝ) := h15
          have h22 : |x - μ| + |μ| < 2 * √(v : ℝ) + |μ| := by linarith
          linarith
        have h23 : |x| ^ p ≤ (|μ| + 2 * √(v : ℝ)) ^ p := by
          have h24 : |x| ≤ |μ| + 2 * √(v : ℝ) := h18
          have h25 : |x| ^ p ≤ (|μ| + 2 * √(v : ℝ)) ^ p := by
            apply pow_le_pow_left
            all_goals
              try { linarith [abs_nonneg x, abs_nonneg μ, Real.sqrt_nonneg (v : ℝ)] }
              try { positivity }
          linarith
        linarith
      · -- Case v = 0
        have h12 : (semicircleReal μ v).support = {μ} := by
          rw [hv, semicircleReal_zero_var]
          simp
        rw [h12] at h10
        have h13 : x = μ := by
          simp at h10 ⊢
          tauto
        rw [h13]
        all_goals
          simp
    have h14 : (fun x : ℝ => |x| ^ p) Integrable (semicircleReal μ v) := by 
      apply Measure.integrable_of_isLocallyFinite
      all_goals
        try { 
          simp_all [h9]
        }
        try { 
          positivity
        }
    exact h14
  exact h3
