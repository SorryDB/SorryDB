        exact h244
      have h25 : 4 * v - (x - μ) ^ 2 ≤ 0 := by exact sub_nonpos.mpr h24
      have h26 : √(4 * v - (x - μ) ^ 2) = 0 := by exact Real.sqrt_eq_zero'.mpr h25
      have h27 : 1 / (2 * π * v) *  √(4 * v - (x - μ) ^ 2) = 0 := by
        exact mul_eq_zero_of_right (1 / (2 * π * ↑v)) h26
