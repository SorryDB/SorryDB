```lean
import Mathlib

open MeasureTheory ProbabilityTheory

namespace SemicirclePDF

noncomputable def semicirclePDFReal (μ : ℝ) {v : ℝ≥0} (x : ℝ) := 
  if v = 0 then
    if x = μ then 1 / (2 * π) else 0
  else
    1 / (2 * π * v) * √(4 * v - (x - μ) ^ 2)

lemma semicirclePDFReal_def : ∀ (μ : ℝ) {v : ℝ≥0} (x : ℝ), semicirclePDFReal μ x =
  if v = 0 then
    if x = μ then 1 / (2 * π) else 0
  else
    1 / (2 * π * v) * √(4 * v - (x - μ) ^ 2) := by
  intro μ x
  rfl

lemma semicirclePDFReal_sub (x y : ℝ) (v : ℝ≥0) : semicirclePDFReal x v (x - y) = semicirclePDFReal (x - y) v x := by
  simp [semicirclePDFReal_def]
  <;> ring_nf <;> simp [Real.sq_sqrt, mul_add, mul_sub]
  <;> ring_nf
  <;> norm_num
  <;> ring

lemma semicirclePDFReal_nonneg (x : ℝ) {v : ℝ≥0} : 0 ≤ semicirclePDFReal x v := by
  simp [semicirclePDFReal_def]
