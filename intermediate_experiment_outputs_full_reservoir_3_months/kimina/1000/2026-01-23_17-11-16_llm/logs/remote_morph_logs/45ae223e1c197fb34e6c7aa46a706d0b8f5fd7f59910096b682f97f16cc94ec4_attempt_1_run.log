        rw [h241]; refine sq_le_sq.mpr ?_
        have h242 : 0 ≤ B := by positivity
        have h243 : 0 ≤ - (x - μ) := by exact Preorder.le_trans 0 B (-(x - μ)) h242 h23
        /- Apply? helped complete this part.-/
        calc
