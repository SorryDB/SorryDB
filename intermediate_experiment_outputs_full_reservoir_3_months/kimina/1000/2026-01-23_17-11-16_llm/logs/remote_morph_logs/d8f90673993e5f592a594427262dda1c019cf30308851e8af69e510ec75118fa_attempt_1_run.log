lemma dL1Norm_mul_of_nonneg (hf : 0 ≤ f) (hg : 0 ≤ g) : ‖f * g‖_[1] = ⟪f, g⟫_[ℝ] := by
  have h1 : ‖f * g‖_[1] = ∑ i : α, ‖f i‖ * ‖g i‖ := by
    simp [dL1Norm_eq_sum_nnnorm, wInner_one_eq_sum]
    <;> try { aesop }
    <;> try { tauto }
    all_goals try { aesop }
    all_goals try { tauto }
  have h2 : ∑ i : α, ‖f i‖ * ‖g i‖ = ⟪f, g⟫_[ℝ] := by
    simp [wInner_one_eq_sum]
    <;> try { aesop }
    <;> try { tauto }
    all_goals try { aesop }
    all_goals try { tauto }
  rw [h1, h2]
