  have h1 : (R1' + Оө2) * ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (E1 Оө2 n).toMat).trace.re вүӨ
      (R1' + Оө2) * ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (E1 Оө2 n).toMat).trace.re := by rfl
  have h2 : (R2' + ОөвӮҖ + Оө2) * ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (E2 Оө2 n).toMat).trace.re вүӨ
      (R2' + ОөвӮҖ + Оө2) * ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (E2 Оө2 n).toMat).trace.re := by rfl
  have h3 : c' Оө2 n * ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (E3 Оө2 n).toMat).trace.re вүӨ
      c' Оө2 n * ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (E3 Оө2 n).toMat).trace.re := by rfl
