    have h4 : ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (E3 Оө2 n).toMat).trace.re = ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (E3 Оө2 n).toMat).trace.re := rfl
