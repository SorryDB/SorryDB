  have hComb : (R2' + ОөвӮҖ) * ((вҶ‘((в„° n) (statePow ПҒ n))).toMat * (P2 Оө2 n).toMat).trace.re вүӨ 0 := by
    have h1 : (1 / вҶ‘n : в„қ) вҖў вҶ‘(E2 Оө2 n) * (вҶ‘(вҶ‘((в„° n) (statePow ПҒ n))).log - вҶ‘(вҶ‘(@SteinsLemma.Пғ''вңқ О№ instвңқ i ПҒ Оө m Пғ n)).log) вүӨ (R2' + ОөвӮҖ + Оө2) вҖў вҶ‘(E2 Оө2 n) := hE2leq
