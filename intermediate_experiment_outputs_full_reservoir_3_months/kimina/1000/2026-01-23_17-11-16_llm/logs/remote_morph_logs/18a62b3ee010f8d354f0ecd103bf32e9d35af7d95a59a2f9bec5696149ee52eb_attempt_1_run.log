        apply T_subadd ((@RCLike.ofReal 𝕂 _) ∘ NNReal.toReal ∘ f) ((@RCLike.ofReal 𝕂 _) ∘ NNReal.toReal ∘ g) hf' hg'

      have T'_submul : ∀ (a : 𝕂) (f : α → ℝ≥0), eLpNorm (T' (a • f)) 1 (ν.restrict G)
