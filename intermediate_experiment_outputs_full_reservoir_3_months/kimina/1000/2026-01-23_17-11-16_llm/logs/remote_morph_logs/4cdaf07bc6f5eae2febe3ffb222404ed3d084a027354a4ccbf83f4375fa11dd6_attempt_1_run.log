      intro x hx
      have h1 : x ∈ ⨅ γ ∈ Δ', γ.toAddMonoidHom.ker := by simpa using hx
      have h2 : x ∈ ⨅ γ ∈ Δ, γ.toAddMonoidHom.ker := by
