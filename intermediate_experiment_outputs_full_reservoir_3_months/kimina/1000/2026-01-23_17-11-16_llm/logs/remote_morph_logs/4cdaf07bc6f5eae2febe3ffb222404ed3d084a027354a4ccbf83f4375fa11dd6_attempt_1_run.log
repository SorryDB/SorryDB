    have hWV : W ≤ V := by
      apply AddSubgroup.submodule_le_iff
      intro γ hγ
      have hγ' : γ ∈ Δ' := hγ
      have hγ'' : γ ∈ Δ := hΔ'Δ hγ'
      simp [W, V] at *
      tauto
    exact hWV
