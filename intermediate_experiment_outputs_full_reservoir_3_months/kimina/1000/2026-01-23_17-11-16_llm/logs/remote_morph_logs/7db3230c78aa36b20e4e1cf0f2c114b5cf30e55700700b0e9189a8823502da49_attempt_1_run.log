      set gÔéä := fun x ÔćŽ Real.toNNReal (- RCLike.im (g x))
      have g_decomposition : g = (1 : ­ŁĽé) ÔÇó (algebraMap ÔäŁ ­ŁĽé Ôłś NNReal.toReal Ôłś gÔéü)
