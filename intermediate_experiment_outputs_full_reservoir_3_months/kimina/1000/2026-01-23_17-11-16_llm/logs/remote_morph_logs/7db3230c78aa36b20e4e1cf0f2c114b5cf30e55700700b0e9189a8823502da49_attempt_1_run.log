    have h8 : Continuous (fun x : ╬▒ => norm (T' gÔéü x)) := by
      apply Continuous.norm
      -- T' gÔéü is strongly measurable, hence continuous
      exact h5.continuous
    exact h8.continuous.measurable
  -- To show AEStronglyMeasurable, we need to show it's measurable
