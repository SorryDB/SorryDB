    have h2 : eLpNorm (T' gÔéü) 1 (╬Ż.restrict G) ÔëĄ (c / p) * eLorentzNorm gÔéü p 1 ╬╝ * (╬Ż G) ^ p'Ôü╗┬╣.toReal := by
      apply helper (gÔéü := gÔéü) (by simp) (by
