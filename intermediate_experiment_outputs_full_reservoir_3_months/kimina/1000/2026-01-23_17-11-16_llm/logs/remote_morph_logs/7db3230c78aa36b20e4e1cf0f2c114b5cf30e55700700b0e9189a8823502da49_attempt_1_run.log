  have h2 : eLpNorm (T' gÔéé) 1 (╬Ż.restrict G) ÔëĄ (c / p) * eLorentzNorm gÔéé p 1 ╬╝ * (╬Ż G) ^ p'Ôü╗┬╣.toReal := by
    have h3 : eLpNorm (T' gÔéé) 1 (╬Ż.restrict G) ÔëĄ (c / p) * eLorentzNorm gÔéé p 1 ╬╝ * (╬Ż G) ^ p'Ôü╗┬╣.toReal := by
      apply helper (gÔéü := gÔéé) (by simp) (by
