theorem RCLike.norm_I {K : Type u_1} [RCLike K] : ÔÇľ(RCLike.I : K)ÔÇľ = if RCLike.I Ôëá (0 : K) then 1 else 0 := by
  split_ifs with h
  ┬Ě apply RCLike.norm_I_of_ne_zero h
  ┬Ě push_neg at h
    simpa

