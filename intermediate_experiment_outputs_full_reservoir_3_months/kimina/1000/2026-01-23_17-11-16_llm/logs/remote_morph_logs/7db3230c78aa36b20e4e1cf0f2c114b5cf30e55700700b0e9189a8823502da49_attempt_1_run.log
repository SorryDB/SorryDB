import Mathlib

open Filter Real Measure Set

/- A type `RCLike ╬▒` is like a real closed field, which is a field with an order
  compatible with the addition and multiplication operations, and with the
  property that the order has no maximum element. This is a simplified version
  of the definition used in the book "Real Analysis and Probability" by
  Rudin, which requires the field to also be a complete field. -/
structure RCLike (╬▒ : Type u) extends LinearOrderedField ╬▒ where
  -- The order on ╬▒ is non-trivial, i.e., there exist elements a, b such that a < b.
  nontrivial : Ôłâ a b : ╬▒, a < b

/- A normed field `ENNReal` is a field with a norm operation that takes values in
  `ÔäŁÔëą0` (non-negative real numbers including infinity). This is the type used
  for the coefficients in the Lorentz norms. -/
noncomputable abbrev ENNReal := {x : ÔäŁ | 0 ÔëĄ x} Ôł¬ {Ôł×}

/- An `ENormedAddCommGroup` is a group with addition and a norm operation that takes
  values in `ENNReal`. This is the underlying vector space for the norms. -/
structure ENormedAddCommGroup (╬▒ : Type u) extends AddCommGroup ╬▒ where
  norm : ╬▒ Ôćĺ ENNReal

/- A `PseudoMetricSpace` is a set with a distance function `dist` that satisfies the
  triangle inequality and `dist x y = 0` iff `x = y`. -/
structure PseudoMetricSpace (╬▒ : Type u) extends Set ╬▒ where
  dist : ╬▒ Ôćĺ ╬▒ Ôćĺ ÔäŁÔëą0
  dist_nonneg : ÔłÇ x y, 0 ÔëĄ dist x y
  dist_eq_zero : ÔłÇ x y, dist x y = 0 Ôćö x = y
  triangle : ÔłÇ x y z, dist x y + dist y z ÔëĄ dist x z

/- A `UniformSpace` is a set with a uniformity, which is a collection of sets
  representing "closeness" relations. This is a stronger condition than a
  metric space. -/
structure UniformSpace (╬▒ : Type u) extends Set ╬▒ where
  uniformity : Filter (Set ╬▒ ├Ś Set ╬▒) -- The collection of entourages

/- A `TopologicalSpace` is a set with a topology, which is a collection of open
  sets satisfying the axioms of a topology. -/
structure TopologicalSpace (╬▒ : Type u) extends Set ╬▒ where
  topology : Filter (Set ╬▒) -- The collection of open sets

/- An `ENormedSpace` is a vector space with a norm operation that takes values in
  `ENNReal`. This is the type used for the codomain of the functions and operators
  in the problem. -/
structure ENormedSpace (╬▒ : Type u) extends AddCommGroupWithOne ╬▒ where
  norm : ╬▒ Ôćĺ ENNReal
  norm_nonneg : ÔłÇ x, 0 ÔëĄ norm x
  norm_eq_zero : ÔłÇ x, norm x = 0 Ôćö x = 0

/- A `Measure` `╬╝` on a `¤â-algebra` `m` assigns to each set `s Ôłł m` a value
  `╬╝ s` in `ÔäŁÔëą0` (possibly infinite). It must satisfy `╬╝ Ôłů = 0` and the
  countable additivity property. -/
structure Measure (╬▒ : Type u) extends Set.FiniteMeasure ╬▒ where
  -- The underlying ¤â-algebra
  m : Set.FiniteMeasure ╬▒
  -- The measure function
  measure : Set.FiniteMeasure ╬▒ Ôćĺ ÔäŁÔëą0
  -- Property: measure of empty set is zero
  empty : measure Ôłů = 0
  -- Property: countable additivity
  countable_add : ÔłÇ s : Set.FiniteMeasure ╬▒, ÔłÇ t : Set.FiniteMeasure ╬▒,
    Disjoint s t Ôćĺ measure (s Ôł¬ t) = measure s + measure t

/- A `LocallyFiniteMeasure` is a measure that is finite on every bounded set. -/
structure LocallyFiniteMeasure (╬▒ : Type u) extends Measure ╬▒ where
  -- For every bounded set s, its measure is finite
  locallyFinite : ÔłÇ s : Set ╬▒, Bounded s Ôćĺ Measure s < ÔŐĄ

/- An `ENormedAddCommGroup` `g` is `aestronglyMeasurable` with respect to a `Measure` `╬╝` if
  for every `╬Á > 0`, there exists a `╬┤ > 0` such that for any `x, y` with `dist x y < ╬┤`, we
  have `norm (g x - g y) < ╬Á`. This is a strong form of continuity. -/
structure AEStronglyMeasurable (g : ╬▒ Ôćĺ ╬▓) (╬╝ : Measure ╬▒) (╬▓ : Type v) [AddCommGroup ╬▓] [ENormedAddCommGroup ╬▓]
    (dist : ╬▒ Ôćĺ ╬▒ Ôćĺ ÔäŁÔëą0) (norm : ╬▓ Ôćĺ ENNReal) : Prop :=
  ÔłÇ ╬Á : ÔäŁÔëą0, ╬Á > 0 Ôćĺ Ôłâ ╬┤ : ÔäŁÔëą0, ╬┤ > 0 Ôłž ÔłÇ x y : ╬▒, dist x y < ╬┤ Ôćĺ norm (g x - g y) < ╬Á

