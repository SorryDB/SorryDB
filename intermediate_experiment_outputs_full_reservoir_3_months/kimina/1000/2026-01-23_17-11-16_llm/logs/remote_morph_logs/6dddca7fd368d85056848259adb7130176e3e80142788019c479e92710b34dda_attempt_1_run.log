import Mathlib

open Set

noncomputable def SetLike (D : Set (PersistenceSubmodule M)) : Set (PersistenceSubmodule M) := D

noncomputable instance : SetLike (DirectSumDecomposition M) (PersistenceSubmodule M) where
  coe := carrier
  coe_injective' DÔéü DÔéé := by cases DÔéü; congr!

variable {C : Type} {inst : Category C} {K : Type} {instK : DivisionRing K} {M : C ÔąĄ ModuleCat K}
variable {D : DirectSumDecomposition M}

lemma sSupIndep (D : DirectSumDecomposition M) : sSupIndep (SetLike.coe D) := D.sSupIndep'

