# Affine monoids give rise to toric varieties
-/

suppress_compilation

open Algebra AlgebraicGeometry Scheme CategoryTheory Limits AddMonoidAlgebra AddLocalization
  AffineAddMonoid
open scoped SpecOfNotation

universe u
variable {𝕜 M : Type u} [Field 𝕜] [AddCancelCommMonoid M] [AddMonoid.FG M] [IsAddTorsionFree M]

namespace AffineToricVarietyFromMonoid

noncomputable instance instToricVariety : ToricVariety 𝕜 (Diag Spec(𝕜) M) where
  torus := Diag Spec(𝕜) (GrothendieckAddGroup M)
  modObjTorus := sorry
  torusEmb := sorry
  isOver_torusEmb := sorry
  isOpenImmersion_torusEmb := by
    stop
    obtain ⟨s, hsgen⟩ := AddMonoid.FG.fg_top (N := M)
    let x : AddMonoidAlgebra R M := ∏ z ∈ s, single z 1
    let alg : Algebra R[M] R[FreeAbelianGroup <| Fin <| dim M] :=
      (AddMonoidAlgebra.mapDomainAlgHom R _ <| embedding M).toAlgebra
    have _ : IsLocalization.Away x (AddMonoidAlgebra R <| FreeAbelianGroup <| Fin <| dim M) := by
      sorry
    exact .of_isLocalization x (M := R[FreeAbelianGroup <| Fin <| dim M])
  isDominant_torusEmb := by -- integral + open nonempty
    stop
    let img := RingHom.range (AddMonoidAlgebra.mapDomainRingHom R <| embedding M)
    have img_domain := Subring.instIsDomainSubtypeMem img
    have := (AlgebraicGeometry.affine_isIntegral_iff (CommRingCat.of (AddMonoidAlgebra R M)))
    sorry
  torusMul_comp_torusEmb := by
    stop
    simp [← Spec.map_comp, ← CommRingCat.ofHom_comp, pullback.condition]
    sorry
```

Now, let's look at the specific goal we need to prove:

```tactics
theorem : 
  (MonoidalCategoryStruct.comp
    (MonoidalCategoryStruct.tensorHom
      (CategoryStruct.id
        (((Spec { carrier := 𝕜, commRing := Field.toEuclideanDomain.toCommring }).Diag
              (GrothendieckAddGroup M)).asOver
            (Spec { carrier := 𝕜, commRing := Field.toEuclideanDomain.toCommring })))
      (Hom.asOver sorry (Spec { carrier := 𝕜, commRing := Field.toEuclideanDomain.toCommring })))
    ModObj.smul) =
  (MonoidalCategoryStruct.comp
    MonObj.mul
    (Hom.asOver sorry (Spec { carrier := 𝕜, commRing := Field.toEuclideanDomain.toCommring })))
```

This is a complex equality. Let's break it down:

- `MonoidalCategoryStruct.comp`: This represents the composition operation in the monoidal category.
- `MonoidalCategoryStruct.tensorHom`: This represents the tensor product operation.
- `CategoryStruct.id`: The identity object in the category.
- `Hom.asOver sorry`: A homomorphism represented as `sorry`.
- `ModObj.smul`: Scalar multiplication.
- `MonObj.mul`: Multiplication in the monoid.

The equality is of the form:
`((I ⊗ H₁) • m) = ((m • H₂))`
where `H₁` and `H₂` are homomorphisms, `m` is an element of the monoid, and `•` represents the action of the homomorphism on `m`.

Let's think about how to approach this proof. The key insight is that the left side is a composition of `I ⊗ H₁` followed by scalar multiplication, while the right side is a composition of `m • H₂`. We need to show these are equal.

