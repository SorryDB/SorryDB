  F X := Set X
  homF f := Set.preimage f
  map_id X := by
    simp [Category.id]
    funext x
    simp only [Set.preimage_id']
  map_comp f g := by
    simp [Category.comp]
    funext x
    simp only [Function.comp_apply]
    rfl

