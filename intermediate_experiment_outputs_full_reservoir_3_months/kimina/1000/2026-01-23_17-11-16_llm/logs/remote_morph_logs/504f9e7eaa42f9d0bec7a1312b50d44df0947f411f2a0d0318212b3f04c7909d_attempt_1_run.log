  F X := Set X
  homF f := Set.image f
  map_id X := by
    simp [Category.id]
    funext x
    simp only [Set.image_id']
  map_comp f g := by
    simp [Category.comp]
    funext x
    simp only [Function.comp_apply]
    exact Eq.symm (Set.image_image g f x)

