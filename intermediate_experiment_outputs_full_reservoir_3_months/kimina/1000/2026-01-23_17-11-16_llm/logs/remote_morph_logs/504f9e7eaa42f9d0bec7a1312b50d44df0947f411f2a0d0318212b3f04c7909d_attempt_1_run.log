-- using exercise notation, instead of mathlib style
instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : @Functor D C CD CC) (G : @Functor E C CE CC) :
    @Category (D × E) (C) where
  Hom := fun ⟨d, e⟩ ⟨c, d', e', h⟩ => { hk : (CD.Hom d d') × (CE.Hom e e') // F.homF hk.1 ≫ G.homF hk.2 = h }
  id := fun ⟨d, e, c, d', e', h⟩ => ⟨(id d, id e), by simp [h]⟩
  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by simp [hf', hf, comp]⟩
  id_comp := by simp
  comp_id := by simp
  assoc := by simp

