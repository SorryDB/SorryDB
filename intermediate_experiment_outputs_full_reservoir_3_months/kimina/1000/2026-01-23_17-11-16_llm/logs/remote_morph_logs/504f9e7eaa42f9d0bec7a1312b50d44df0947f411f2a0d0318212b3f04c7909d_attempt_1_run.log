  -- Let m be (f, hf) and m' be (f', hf')
  -- Then m' ∘ m is (f' ∘ f, hf' ∘ hf)
  -- Applying F to this composition gives f' ∘ f
  -- Applying F to m' gives f'
  -- Applying F to m gives f
  -- So we need to show that f' ∘ f = f' ∘ f, which is true by definition
  simp only
