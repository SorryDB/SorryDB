-- exercise 1.3.vi
-- using exercise notation, instead of mathlib style
instance Comma_category {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Category (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) where

  Hom := fun ⟨d, e, f⟩ ⟨d', e', f'⟩ =>
    {hk : (CD.Hom d d' × CE.Hom e e') // (F.homF hk.1) ≫ f' = f ≫ (G.homF hk.2)}

  id := fun ⟨d, e, f⟩ => ⟨(id d, id e), by
    simp only
    rw [F.map_id, G.map_id]
    rw [id_comp, comp_id]
  ⟩

  comp := fun ⟨f, hf⟩ ⟨f', hf'⟩ => ⟨(f.1 ≫ f'.1, f.2 ≫ f'.2), by
    rw [Functor.map_comp, Functor.map_comp]
    rw [Category.assoc]
    rw [hf']
    rw [← Category.assoc]
    rw [hf]
    rw [Category.assoc]
  ⟩

  id_comp := sorry
  comp_id := sorry
  assoc := sorry

-- example 1.3.14.i
def Comma_category_dom {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) D where
  F := fun ⟨X, _, _⟩ => X.1
  homF := fun ⟨X, Y, h⟩ ⟨f, _⟩ => f.1
  map_id ⟨X, Y, h⟩ := by
    simp [functor]
    simp only
    rw [id_comp]
  map_comp f g := by
    simp [functor]
    simp only
    rw [comp]

-- example 1.3.14.ii
def Comma_category_1st_proj {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) E where
  F := fun ⟨X, _, _⟩ => X.2.1
  homF := fun ⟨X, Y, h⟩ ⟨_, g⟩ => g.1
  map_id ⟨X, Y, h⟩ := by
    simp [functor]
    simp only
    rw [id_comp]
  map_comp f g := by
    simp [functor]
    simp only
    rw [comp]

-- example 1.3.14.iii
def Comma_category_2nd_proj {D C E : Type*} [CC : Category C] [CD : Category D] [CE : Category E]
    (F : Functor D C) (G : Functor E C) :
    Functor (Σ (d : D) (e : E), Category.Hom (F.F d) (G.F e)) C where
  F := fun ⟨X, _, _⟩ => X.2.2
  homF := fun ⟨X, Y, h⟩ ⟨_, _⟩ => h
  map_id ⟨X, Y, h⟩ := by
    simp [functor]
    simp only
    rw [id_comp]
  map_comp f g := by
    simp [functor]
    simp only
    rw [comp]

