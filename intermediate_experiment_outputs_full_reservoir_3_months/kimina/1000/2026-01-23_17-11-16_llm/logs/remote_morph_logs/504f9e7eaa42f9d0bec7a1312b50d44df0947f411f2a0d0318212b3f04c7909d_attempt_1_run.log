  F C := ⟨Opposite C.1, @Category.opp (Opposite C.1) C.2⟩
  homF {C D} F := letI := C.2; letI := D.2; {
    F := F.F
    homF := F.homF
    map_id X := F.map_id X
    map_comp f g := by
      rw [Functor.homF]
      repeat rw [comp]
      simp only
      apply F.map_comp
  }
  map_id C := by sorry
  map_comp {C D E} F G := by sorry

