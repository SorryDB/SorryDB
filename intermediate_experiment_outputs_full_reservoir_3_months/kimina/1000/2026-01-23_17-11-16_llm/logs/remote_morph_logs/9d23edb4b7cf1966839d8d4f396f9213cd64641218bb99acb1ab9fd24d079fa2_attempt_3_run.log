            do
            let __do_lift ← init
            ((fun {α} x => (simulateQ impl).toFun α x)
                (run sIn wIn
                  (R.liftContext lens)))
                .run' __do_lift
            )] ≥ 1 - ↑completenessError := by
    intro sIn wIn hIn
    have h2 : (lens.stmt.proj sIn, lens.wit.proj (sIn, wIn)) ∈ innerRelIn := by
      apply lensComplete.mem_iff.mp
      exact hIn
    have h3 : Pr[fun z => (z.2, z.1.2.2) ∈ innerRelOut ∧ z.1.2.1 = z.1.2.1 |
        OptionT.mk
          (have impl := impl.addLift challengeQueryImpl;
          do
          let __do_lift ← init
          ((fun {α} x => (simulateQ impl).toFun α x)
              (run (lens.stmt.proj sIn) (lens.wit.proj (sIn, wIn)) R)
              ).run' __do_lift
          )] ≥ 1 - ↑completenessError := by
      apply h
