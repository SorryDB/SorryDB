import Mathlib
open Lean4

/-
A context is a quadruple of sets representing the input and output statements and witnesses for a computational task. It's often useful to transform these sets using a "lens" function, which preserves certain structural properties. We define a general way to apply such transformations to proofs, verifiers, and related objects.
-/

namespace Context

/-- A context consists of four sets: input and output statements and witnesses, both for the outer and inner computational layers. -/
structure Context :=
  {stmtIn : Set (OuterStmtIn)
   , witIn : Set (OuterWitIn)
   , stmtOut : Set (OuterStmtOut)
   , witOut : Set (OuterWitOut)}

/-- A context transformation (lens) maps the sets of a context according to specified functions. -/
structure Lens :=
  {proj : OuterStmtIn → InnerStmtIn}
  {lift : (InnerStmtIn × InnerWitIn) → (OuterStmtIn × OuterWitIn)}

/-- A context is sound if the lens maps input/output pairs appropriately. -/
structure IsSound :=
  {sound : ∀ (c : Context), c ∈ support this → ...}

/-- A context is complete if the lens maps input/output pairs appropriately. -/
structure IsComplete :=
  {complete : ∀ (c : Context), c ∈ support this → ...}

/-- A context is valid if it's both sound and complete. -/
structure IsValid :=
  {valid : this.IsSound ∧ this.IsComplete}

/-- A context is non-empty if its support is non-empty. -/
structure IsNonempty :=
  {nonempty : support this ≠ ∅}

/-- A context is finite if its support is finite. -/
