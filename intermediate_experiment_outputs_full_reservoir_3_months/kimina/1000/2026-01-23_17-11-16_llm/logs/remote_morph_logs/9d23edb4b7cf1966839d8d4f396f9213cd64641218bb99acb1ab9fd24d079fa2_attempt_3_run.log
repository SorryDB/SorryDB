    have h5 : Pr[fun z => (z.2, z.1.2.2) ∈ outerRelOut ∧ z.1.2.1 = z.1.2.1 |
        OptionT.mk
          (have impl := impl.addLift challengeQueryImpl;
          do
          let __do_lift ← init
          ((fun {α} x => (simulateQ impl).toFun α x)
              (run sIn wIn
                (R.liftContext lens)))
              .run' __do_lift
          )] ≥ 1 - ↑completenessError := by
      have h6 : {val | (val.2, val.1.2.2) ∈ innerRelOut ∧ val.1.2.1 = val.1.2.1} ⊆
        {val | (val.2, val.1.2.2) ∈ outerRelOut ∧ val.1.2.1 = val.1.2.1} := h4
      have h7 : Pr[fun z => (z.2, z.1.2.2) ∈ outerRelOut ∧ z.1.2.1 = z.1.2.1 |
          OptionT.mk
            (have impl := impl.addLift challengeQueryImpl;
