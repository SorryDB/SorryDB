/-- The fintype instance of `WickContraction n`, for `n.succ` this is defined
  through the equivalence `extractEquiv`. -/
instance fintype_succ : (n : ℕ) → Fintype (WickContraction n)
  | 0 => fintype_zero
  | Nat.succ n => by
    letI := fintype_succ n
    exact Fintype.ofEquiv _ (extractEquiv 0).symm
```

This defines `fintype_succ` which gives a `Fintype` instance for `WickContraction n` for any `n`. The base case `n=0` is `fintype_zero`. For `n+1`, it uses `Fintype.ofEquiv` with the equivalence `extractEquiv`. This is a key result establishing that `WickContraction n` is finite for all `n`.

