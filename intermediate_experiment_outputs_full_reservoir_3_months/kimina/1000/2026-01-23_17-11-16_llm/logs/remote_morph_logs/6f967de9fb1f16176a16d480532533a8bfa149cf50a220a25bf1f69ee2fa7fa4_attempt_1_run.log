/-- The fintype instance of `WickContraction 0` defined through its single
  element `empty`. -/
instance fintype_zero : Fintype (WickContraction 0) where
 elems := {empty}
  complete := by
    intro c
    simp only [Finset.mem_singleton]
    apply Subtype.ext
    simp only [empty]
    ext a
    apply Iff.intro
    · intro h
      have hc := c.2.1 a h
      rw [Finset.card_eq_two] at hc
      obtain ⟨x, y, hxy, ha⟩ := hc
      exact Fin.elim0 x
    · simp
```

This establishes that `WickContraction 0` is a finite type with exactly one element, `empty`. This is the base case for the induction that will define `WickContraction n` for all `n`.

