lemma cLpNorm_mul_le (p q : ℝ≥0∞) (hr₀ : r ≠ 0) [hpqr : ENNReal.HolderTriple p q r] :
    ‖f * g‖ₙ_[r] ≤ ‖f‖ₙ_[p] * ‖g‖ₙ_[q] := by
  by_cases hp0 : p = 0
  · simp [hp0] at hpqr ⊢
    all_goals try { tauto }
    all_goals try { norm_num at hpqr ⊢ <;> tauto }
  · by_cases hq0 : q = 0
    · simp [hq0] at hpqr ⊢
      all_goals try { tauto }
      all_goals try { norm_num at hpqr ⊢ <;> tauto }
    · -- Now p ≠ 0 and q ≠ 0
      have hp : p ≠ 0 := by
        by_contra h
        simp [h] at hp0
      have hq : q ≠ 0 := by
        by_contra h
        simp [h] at hq0
      by_cases hrinf : r = ∞
      · -- Case r = ∞
        rw [hrinf]
        simp [hp, hq] at hpqr ⊢
        all_goals try { tauto }
        all_goals try { norm_num at hpqr ⊢ <;> tauto }
      · -- Now p, q, r are finite
        have hp' : p ≠ 0 := hp
        have hq' : q ≠ 0 := hq
        have hr' : r ≠ ∞ := by
          intro h
          apply hrinf
          exact h
        have h1 := hpqr.1
        have h2 := hpqr.2
        have h3 := hpqr.3
        have h4 : p + q = r := by
          exact h1
        have h5 : p⁻¹ + q⁻¹ = r⁻¹ := by
          exact h2
        have h6 : p * q = r * (p * q / r) := by
          field_simp [hr']
          <;> nlinarith
        have h7 : ‖f * g‖ₙ_[r] ≤ ‖f‖ₙ_[p] * ‖g‖ₙ_[q] := by
          have h8 : ‖f * g‖ₙ_[r] = ‖f‖ₙ_[p] * ‖g‖ₙ_[q] := by
            have h9 : ‖f * g‖ₙ_[r] = ‖fun i ↦ ‖f i * g i‖₊‖ₙ_[ℝ] := by
              simp [cLpNorm_eq_norm]
            have h10 : ‖fun i ↦ ‖f i * g i‖₊‖ₙ_[ℝ] = ‖fun i ↦ ‖f i‖₊‖ₙ_[p] * ‖fun i ↦ ‖g i‖₊‖ₙ_[q] := by
              have h11 : ‖fun i ↦ ‖f i * g i‖₊‖ₙ_[ℝ] = ‖fun i ↦ ‖f i‖₊ * ‖g i‖₊‖ₙ_[ℝ] := by
