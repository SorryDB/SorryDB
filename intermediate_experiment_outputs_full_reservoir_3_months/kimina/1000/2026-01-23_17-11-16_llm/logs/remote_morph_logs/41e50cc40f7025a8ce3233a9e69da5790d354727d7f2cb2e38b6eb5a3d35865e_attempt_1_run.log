  have eq3 : ∂ₜ (∂ₜ d) = - S.ω^2 • d - S.ω • ∂ₜ d := by
    have eq4 : ∂ₜ (∂ₜ d) = ∂ₜ (∂ₜ x) - ∂ₜ (∂ₜ (IC.trajectory S)) := by
