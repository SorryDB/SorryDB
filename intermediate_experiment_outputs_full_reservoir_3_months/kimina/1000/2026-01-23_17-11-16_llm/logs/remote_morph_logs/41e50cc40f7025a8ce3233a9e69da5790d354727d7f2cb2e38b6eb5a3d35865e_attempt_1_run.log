  have h1 : x 0 = IC.x₀ := pos_ic
  have h2 : ∂ₜ x 0 = IC.v₀ := vel_ic

  -- Let's compute the values for the proposed solution
  have h3 : (IC.trajectory S) 0 = IC.x₀ := by simp [trajectory]
  have h4 : ∂ₜ (IC.trajectory S) 0 = IC.v₀ := by simp [trajectory_velocity]

