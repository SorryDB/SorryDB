import Mathlib

namespace Pop
  -- Basic structures
  structure ArchReq where
    type : Type
    atomicity : Option (Atomicity)
    value? : Option (Value)
    address? : Option (Address)
    propagatedRoute : List (ThreadId)
    predecessorAt : List (ThreadId)
    isFence : Bool
    isAtomic : Bool
    isTransactional : Bool
    isMem : Bool
    isPermanentRead : Bool
    deriving Eq, Show, Inhabited

  structure BasicRequest where
    type : Type
    basic_type : ArchReq
    deriving Eq, Show, Inhabited

  structure Request where
    basic_type : ArchReq
    propagatedRoute : List (ThreadId)
    predecessorAt : List (ThreadId)
    deriving Eq, Show, Inhabited

  structure SystemState where
    time : Int
    validScopes : List (ValidScopes)
    orderConstraints : List (OrderConstraints)
    requestArray : RequestArray
    deriving Eq, Show, Inhabited

  structure ValidScopes where
    scopes : ListTree (List (ThreadId))
    system_scope : List (ThreadId)
    deriving Eq, Show, Inhabited

  structure OrderConstraints where
    val : Std.HashMap (List ThreadId) (Std.HashMap (RequestId × RequestId) Bool)
    default : Bool
    deriving Eq, Show, Inhabited

  structure RequestArray where
    val : Array (Option (Request))
    coherent : valConsistent val = true
    deriving Eq, Show, Inhabited

  def valConsistent (vals :  Array (Option (Request))) : Bool :=
    let valOpIds := vals.map opReqId?
    let valConsistent := λ (idx : Nat) (opVal : Option (Request)) => match opVal with
      | none => true
      | some val => val == (idx : RequestId)
    let consistentVals := valOpIds.mapIdx valConsistent
    consistentVals.foldl (. ∧ .) true

  def emptyArrayCoherent : valConsistent (Array.mk ([] : List (Option (Request)))) := by
    unfold valConsistent
    native_decide

  -- Basic operations
  def opReqId? : Option (Request) → Option (RequestId) := Option.map (λ r => r.id)

  -- Basic accessors
  def Request.address? (r : Request) : Option Address := r.basic_type.address?
  def Request.isFence (r : Request) : Bool := r.basic_type.isFence
  def Request.isAtomic (r : Request) : Bool := r.basic_type.isAtomic
  def Request.isTransactional (r : Request) : Bool := r.basic_type.isTransactional
  def BasicRequest.isFence (r : BasicRequest) : Bool := r.basic_type.isFence
  def BasicRequest.isAtomic (r : BasicRequest) : Bool := r.basic_type.isAtomic
  def BasicRequest.isTransactional (r : BasicRequest) : Bool := r.basic_type.isTransactional
  def BasicRequest.isRead    (r : BasicRequest) : Bool := match r with | read  _ _ => true | _ => false
  def BasicRequest.isWrite   (r : BasicRequest) : Bool := match r with | write _ _ => true | _ => false
  def BasicRequest.isFence (r : BasicRequest) : Bool := match r with | fence _ => true | _ => false

  -- Basic operations
  def Request.toShortString : Request → String
    | req => s!"{req.id}[{req.basic_type.toString}]"
  instance : ToString (Request) where toString := Request.toShortString

  def BasicRequest.toString : BasicRequest → String
    | req => s!"{req.basic_type} {req.id}"
  instance : ToString (BasicRequest) where toString := BasicRequest.toString

  -- Basic relations
  def BasicRequest.isAtomic (r : BasicRequest) : Bool := match r with | .read rr _ => rr.atomicity == .atomic | .write wr _ => wr.atomicity == .atomic | .fence _ => false
  def BasicRequest.isTransactional (r : BasicRequest) : Bool := match r with | .read rr _ => rr.atomicity == .transactional | .write wr _ => wr.atomicity == .transactional | .fence _ => false

  -- Basic relations
  def BasicRequest.address? (r : BasicRequest) : Option Address := match r with
    | read  req _ => some req.addr
    | write req _ => some req.addr
    | _ => none

  -- Basic relations
  def BasicRequest.equivalent (r₁ r₂ : BasicRequest) : Bool :=
    if r₁.isFence then r₁.basic_type == r₂.basic_type
    else r₁.address? == r₂.address? ∧ r₁.value? == r₂.value? ∧ r₁.thread == r₂.thread ∧
       ((r₁.isWrite ∧ r₂.isWrite) ∨ (r₁.isRead ∧ r₂.isRead))

  -- Basic relations
  def BasicRequest.isSatisfied (r : BasicRequest) : Bool := match r with
    | .read rr _ => rr.val.isSome
    | _ => false

  -- Basic relations
  def BasicRequest.isAtomic (r : BasicRequest) : Bool := match r with | .read rr _ => rr.atomicity == .atomic | .write wr _ => wr.atomicity == .atomic | .fence _ => false
  def BasicRequest.isTransactional (r : BasicRequest) : Bool := match r with | .read rr _ => rr.atomicity == .transactional | .write wr _ => wr.atomicity == .transactional | .fence _ => false

