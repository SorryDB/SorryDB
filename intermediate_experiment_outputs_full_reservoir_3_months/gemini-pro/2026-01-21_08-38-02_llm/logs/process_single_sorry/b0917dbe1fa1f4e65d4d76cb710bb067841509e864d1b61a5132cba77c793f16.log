  let S : Finset G := {g ∈ A⁻¹ * A | #A / (2 * K) ≤ #(A <• g ∩ A)}
  have hS₁ : 1 ∈ S := by simp [S, hA₀.ne_empty]; bound
  have hS₀ : S.Nonempty := ⟨1, hS₁⟩
  have hSA : S ⊆ A⁻¹ * A := filter_subset ..
  have hSsymm : S⁻¹ = S := by ext; simp [S]; sorry
  have hScard := calc
    (#S : ℝ) ≤ #(A⁻¹ * A) := by gcongr
    _ ≤ K ^ 2 * #A := by
      refine le_of_mul_le_mul_right ?_ (by positivity)
      calc
        (#(A⁻¹ * A) : ℝ) * #A = #A⁻¹ * #(A⁻¹ / A⁻¹) := by simp [div_eq_mul_inv]; ring
        _ ≤ (#(A⁻¹ * A⁻¹) : ℝ) ^ 2 := by
          norm_cast
          simpa [sq] using mul_card_div_le A⁻¹ A⁻¹ A⁻¹
        _ ≤ (K * #A) ^ 2 := by simp [← mul_inv_rev, card_inv]; gcongr
        _ = (K ^ 2 * #A) * #A := by ring
