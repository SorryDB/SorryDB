lemma IsAugPath.augment_vertex_subset (h : G.IsAugPath hM P) : V(G, M) ⊆ V(G, M ∆ E(P)) := by
  intro v hv
  obtain ⟨e, heM, hve⟩ := hv
  by_cases heP : e ∈ P.edge
  · have hv_int : v ∉ {P.first, P.last} := by
