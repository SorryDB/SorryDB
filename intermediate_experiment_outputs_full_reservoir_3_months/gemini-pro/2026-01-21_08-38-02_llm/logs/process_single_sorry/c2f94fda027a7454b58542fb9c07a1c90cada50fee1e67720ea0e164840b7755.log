      "\n      rw [Ne, ← CharP.cast_eq_zero_iff K (ringChar K), CharP.cast_card_eq_zero K]\n      exact Nat.not_dvd_of_pos_of_lt (Nat.sub_pos_of_lt (Nat.one_lt_pow n q (Fintype.card_pos_iff.2 ‹_›)\n        (natDegree_pos_iff_degree_pos.2 (degree_pos_of_irreducible hf)))) (Nat.sub_lt (Nat.pow_pos (Fintype.card_pos_iff.2 ‹_›) _) one_pos)\n    refine ⟨_, (exists_root_of_splits _ (splits_of_splits_of_dvd _\n      (splits_mul _ (splits_X _) (IsCyclotomicExtension.splits_X_pow_sub_one L hn))\n      (Polynomial.dvd_X_pow_card_pow_sub_X f hf.ne_zero rfl))\n      (degree_pos_of_irreducible hf)).choose_spec⟩\n  · have : Algebra.IsAlgebraic K L := IsAlgClosure.isAlgebraic K L\n    rw [IsCyclotomicExtension.iff_isSplittingField]\n    refine ⟨fun n hn ↦ IsAlgClosed.splits_codomain _, eq_top_iff.2 fun x ↦ ?_⟩\n    by_cases hx : x = 0; · subst x; exact zero_mem _\n    let Kx := IntermediateField.adjoin K {x}\n    have : Fintype Kx := IntermediateField.fintypeOfIsAlgebraic (this x)\n    let n := Fintype.card Kx - 1\n    have hn : n ∈ S := by\n      rw [mem_setOf, Ne, ← CharP.cast_eq_zero_iff K (ringChar K), CharP.cast_card_eq_zero K]\n      exact Nat.not_dvd_of_pos_of_lt (Nat.sub_pos_of_lt (Fintype.one_lt_card_iff_nontrivial.2 inferInstance))\n        (Nat.sub_lt (Fintype.card_pos_iff.2 ‹_›) one_pos)\n    have hroot : x ^ n = 1 := by\n      rw [← Subtype.coe_inj, Subgroup.coe_pow, Subgroup.coe_one,\n        ← FiniteField.pow_card_sub_one_eq_one (⟨x, IntermediateField.mem_adjoin_simple_self _ _⟩ : Kx)\n        (mt Subtype.coe_eq_zero.1 hx)]\n    exact Algebra.subset_adjoin ⟨X ^ n - 1, ⟨n, hn, rfl⟩, by rw [mem_rootSet_of_ne (X_pow_sub_C_ne_zero (by simp [hn]) _), IsRoot.def, eval_sub, eval_pow, eval_X, eval_one, sub_eq_zero, hroot]⟩",
      "\n    refine IsAlgClosure.of_finite_extension K _ fun E _ _ _ ↦ ?_\n    obtain ⟨n, hn, rfl⟩ := FiniteField.exists_extension_eq_adjoin_root_of_unity K E\n    exact IsCyclotomicExtension.splits_X_pow_sub_one L hn\n  · refine ⟨fun n _ ↦ IsAlgClosed.splits_codomain _, eq_top_iff.2 fun x _ ↦ ?_⟩\n    obtain ⟨E, hE, hx⟩ := IsAlgClosure.exists_finite_subextension K x\n    have : Finite E := Module.Finite.of_restrictScalars_finite K E hE\n    obtain ⟨n, hn, rfl⟩ := FiniteField.exists_extension_eq_adjoin_root_of_unity K E\n    exact Algebra.adjoin_mono (fun y hy ↦ by\n      obtain ⟨m, hm, hprim⟩ := IsRootOfUnity.exists_primitive_root (IsRootOfUnity.mk_of_pow_eq hy (Nat.cast_ne_zero.mp hn))\n      exact ⟨m, fun h ↦ hn (dvd_trans (RingChar.dvd h) hm), hprim⟩) hx",
      "\n      rw [Ne, CharP.cast_eq_zero_iff K (ringChar K)]\n      have : Nat.Coprime (Fintype.card K ^ d) (Fintype.card K ^ d - 1) :=\n        Nat.coprime_sub_self_right.mpr (Nat.coprime_one_left _)\n      exact (Nat.Coprime.coprime_dvd_left (dvd_pow (CharP.cast_card_eq_zero K)\n        hf.natDegree_pos.ne.bot_lt) this).symm\n    obtain ⟨\\zeta, h\\zeta⟩ := IsCyclotomicExtension.exists_roots (L := L) _ hd\n    exact Polynomial.exists_root_of_splits _ (Polynomial.splits_of_splits_of_dvd _\n      (Polynomial.splits_mul _ _ h\\zeta.splits_X_pow_sub_one)\n      (FiniteField.irreducible_dvd_X_pow_sub_X f hf)) (by simpa using hf.natDegree_pos)\n  · constructor\n    · intro n hn\n      have hsep : (Polynomial.X ^ n - 1 : L[X]).Separable := Polynomial.separable_X_pow_sub_C _\n        (IsUnit.mk0 _ (by exact_mod_cast hn)) one_ne_zero\n      obtain ⟨\\zeta, h\\zeta⟩ := IsCyclic.exists_generator (rootsOfUnity n L)\n      refine ⟨\\zeta, IsPrimitiveRoot.iff_def.mpr ⟨\\zeta.2, fun m hm ↦ ?_⟩⟩\n      rw [← orderOf_eq_card_of_forall_mem_zpowers h\\zeta]\n      convert hm\n      rw [Fintype.card_coe, Multiset.toFinset_card_of_nodup (Polynomial.nodup_roots hsep.map),\n        Polynomial.card_roots (IsAlgClosed.splits_codomain _), Polynomial.natDegree_X_pow_sub_C]\n    · rw [Algebra.eq_top_iff]\n      intro x\n      let E := Algebra.adjoin K {x}\n      haveI : Finite E := Module.Finite.of_surjective (Algebra.adjoin.surjective K {x})\n      obtain ⟨\\zeta, h\\zeta⟩ := FiniteField.exists_primitive_root E\n      have horder : Fintype.card E - 1 ∈ S := by\n        rw [mem_setOf_eq, Ne, CharP.cast_eq_zero_iff K (ringChar K)]\n        have : Nat.Coprime (Fintype.card E) (Fintype.card E - 1) :=\n          Nat.coprime_sub_self_right.mpr (Nat.coprime_one_left _)\n        exact (Nat.Coprime.coprime_dvd_left (dvd_trans (CharP.cast_card_eq_zero K)\n          (FiniteField.card_dvd_card_of_tower K E)) this).symm\n      rw [← Algebra.adjoin_simple_eq_gen_iff.mpr h\\zeta.isUnit_unit]\n      apply Algebra.adjoin_mono\n      simp only [Set.singleton_subset_iff, Set.mem_setOf_eq]\n      use Fintype.card E - 1, horder\n      exact h\\zeta.pow_eq_one",
      "\n      simpa using congr_arg (algebraMap E L) (FiniteField.pow_card_sub_one_eq_one ⟨x, this⟩ (mt (Subtype.ext_iff.1) hx))",
      "\n    refine IsAlgClosure.of_isAlgebraic_of_isSplitting this fun f _ ↦ ?_\n    rcases IsSplittingField.exists_finite_subfield K f this with ⟨E, _, _, hsp⟩\n    have : Finite E := Finite.of_fintype E\n    let n := Fintype.card E - 1\n    have hn : n ∈ S := by\n      rw [mem_setOf_eq, Ne, Nat.cast_pred (Fintype.card_pos_iff.mpr inferInstance),\n        CharP.cast_card_eq_zero K, sub_eq_zero, neg_eq_zero, one_ne_zero]\n    have : E ≤ Algebra.adjoin K {x : L | ∃ n ∈ S, x ^ n = 1} := by\n      rw [Algebra.adjoin_le_iff]; intro x hx\n      by_cases h0 : x = 0; · rw [h0]; exact zero_mem _\n      exact subset_adjoin ⟨n, hn, by rw [← map_pow, FiniteField.pow_card_sub_one_eq_one ⟨x, hx⟩ h0, map_one]⟩\n    rw [← IsCyclotomicExtension.adjoin_roots S (K := K) (L := L)] at this\n    exact Splits.map (Algebra.inclusion this) hsp\n  · apply IsCyclotomicExtension.iff_isSplittingField.mpr ⟨fun n _ ↦ IsAlgClosed.splits_codomain _, ?_⟩\n    rw [eq_top_iff]; intro x _\n    have : Algebra.IsAlgebraic K L := h.1\n    let E := Algebra.adjoin K {x}\n    have : Finite E := Finite.of_fintype E\n    let n := Fintype.card E - 1\n    have hn : n ∈ S := by\n      rw [mem_setOf_eq, Ne, Nat.cast_pred (Fintype.card_pos_iff.mpr inferInstance),\n        CharP.cast_card_eq_zero K, sub_eq_zero, neg_eq_zero, one_ne_zero]\n    by_cases h0 : x = 0; · rw [h0]; exact zero_mem _\n    have hx : x ∈ E := Algebra.subset_adjoin (Set.mem_singleton x)\n    have : (⟨x, hx⟩ : E) ^ n = 1 := FiniteField.pow_card_sub_one_eq_one ⟨x, hx⟩ (by simpa using h0)\n    refine subset_adjoin ⟨n, hn, ?_⟩\n    simpa using congr_arg (algebraMap E L) this",
      "\n    have h1 : (Fintype.card K ^ f.natDegree - 1 : K) ≠ 0 :=\n      (FiniteField.isUnit_card_pow_sub_one K f.natDegree).ne_zero\n    refine Polynomial.exists_root_of_splits _ (Polynomial.Splits.of_mul _ (Polynomial.Splits.of_mul _ \n      (Polynomial.splits_X _) ?_) hn) (Polynomial.degree_le_of_dvd hn (by simp))\n    exact IsCyclotomicExtension.splits_X_pow_sub_one K L (Set.mem_setOf.2 h1)\n  · rw [isCyclotomicExtension_iff_isSplittingField_set]\n    refine IsSplittingField.mk _ (fun _ ⟨n, _, rfl⟩ ↦ IsAlgClosed.splits_codomain _) ?_\n    rw [eq_top_iff]; intro x _; have := IsAlgClosure.isIntegral K x\n    obtain ⟨n, hn, hx⟩ := FiniteField.exists_pow_card_eq_self_of_isIntegral K x this\n    by_cases hx0 : x = 0; · simp [hx0, Subalgebra.zero_mem]\n    have h : x ^ (Fintype.card K ^ n - 1) = 1 := by\n      rw [← mul_left_inj' hx0, ← pow_succ', Nat.sub_add_cancel (Nat.one_le_pow _ _ (Fintype.card_pos_iff.2 ‹_›)), hx, mul_one]\n    refine Algebra.adjoin_mono (s := {Polynomial.X ^ (Fintype.card K ^ n - 1) - 1}) ?_ \n      (Polynomial.mem_adjoin_of_eq_zero (Polynomial.X ^ (Fintype.card K ^ n - 1) - 1) \n      (by simp [Polynomial.eval_sub, Polynomial.eval_pow, h]))\n    simp only [Set.image_subset_iff, Set.singleton_subset_iff, Set.mem_setOf_eq]\n    exact ⟨_, (FiniteField.isUnit_card_pow_sub_one K n).ne_zero, rfl⟩",
      "L⟩",
      "\n    exact Splits.of_dvd ((isCyclotomicExtension_iff_isSplittingField_X_pow_sub_one _ _ _).mp h).splits ⟨n, hn, rfl⟩ (FiniteField.irreducible_dvd_X_pow_sub_one f hf)\n  · rw [isCyclotomicExtension_iff_isSplittingField_X_pow_sub_one]; refine ⟨h.splits_set _, (eq_top_iff _).mpr fun x _ ↦ ?_⟩\n    by_cases hx : x = 0; · rw [hx]; exact zero_mem _\n    have := Module.Finite.iff_fg.mpr (IsAlgClosure.algebraic K L x).fg_adjoin\n    let n := Fintype.card (Algebra.adjoin K {x}) - 1\n    have hn : (n : K) ≠ 0 := by rw [Nat.cast_sub_one, CharP.cast_card_eq_zero, zero_sub]; exact neg_ne_zero.mpr one_ne_zero\n    refine subset_adjoin_roots _ ⟨n, hn, rfl⟩ (by rw [mem_rootSet_of_ne (X_pow_sub_one_ne_zero hn.ne_zero_of_map) (h.splits _), aeval_X_pow_sub_one]; exact FiniteField.pow_card_sub_one_eq_one ⟨x, Algebra.subset_adjoin (Set.mem_singleton x)⟩ (mt Subtype.ext_iff.mp hx))",
      "\n    let n := Fintype.card E - 1\n    have hn : (n : K) ≠ 0 := by\n      rw [Nat.cast_pred (Fintype.card_pos_iff.mpr ‹_›), CharP.cast_card_eq_zero K, zero_sub]\n      exact neg_ne_zero.mpr one_ne_zero\n    obtain ⟨ζ, hζ⟩ := IsCyclotomicExtension.exists_prim_root (S := {n | (n : K) ≠ 0}) (K := K) (L := L) n hn\n    obtain ⟨φ⟩ := Polynomial.IsSplittingField.exists_algebra_of_splits K E (X ^ n - 1)\n      hζ.splits_X_pow_sub_one\n      (by rw [Polynomial.splits_id_iff_splits, Polynomial.map_sub, Polynomial.map_pow, Polynomial.map_one, Polynomial.map_X]; exact FiniteField.splits_X_pow_card_sub_one_sub_one E)\n    exact ⟨_, φ.toRingHom.comp (Polynomial.IsSplittingField.adjoin_root E hf)⟩\n  · refine ⟨fun n hn ↦ IsAlgClosed.exists_isPrimitiveRoot n hn, fun x ↦ ?_⟩\n    obtain ⟨E, hE, hxE⟩ := IntermediateField.exists_finite_type_of_isAlgebraic (IsAlgClosure.isAlgebraic K L x)\n    have : Finite E := FiniteDimensional.finite_of_finite K E\n    let n := Fintype.card E - 1\n    have hn : (n : K) ≠ 0 := by\n      rw [Nat.cast_pred (Fintype.card_pos_iff.mpr ‹_›), CharP.cast_card_eq_zero K, zero_sub]\n      exact neg_ne_zero.mpr one_ne_zero\n    obtain ⟨ζ, hζ⟩ := FiniteField.exists_primitive_element E\n    have h_prim : IsPrimitiveRoot (algebraMap E L ζ) n := by\n      rw [IsPrimitiveRoot.map_iff_of_injective (algebraMap E L).injective]\n      exact FiniteField.isPrimitiveRoot_card_sub_one ζ\n    have : algebraMap E L ζ ∈ Algebra.adjoin K {r | ∃ n, (n : K) ≠ 0 ∧ IsPrimitiveRoot r n} :=\n      Algebra.subset_adjoin ⟨n, hn, h_prim⟩\n    rw [← hE, ← Subalgebra.mem_map (Algebra.ofId E L), hζ, Algebra.adjoin_map_args] at hxE\n    refine Subalgebra.adjoin_le (Set.singleton_subset_iff.mpr this) hxE",
      "\n  refine ⟨fun h ↦ ?_, fun h ↦ ?_⟩\n  · have : IsSplittingField K L {X ^ n - 1 | n ∈ S} := IsCyclotomicExtension.iff_isSplittingField.mp h\n    apply IsAlgClosure.of_splits_of_all_roots_mem\n    · exact IsSplittingField.algebraic (S := {X ^ n - 1 | n ∈ S})\n    · intro f hf\n      let q := Fintype.card K\n      have hq : (q : K) = 0 := CharP.cast_card_eq_zero K\n      let k := f.natDegree\n      have h_div : f ∣ X ^ (q ^ k) - X := Polynomial.dvd_X_pow_card_pow_sub_X k f (by simp)\n      apply Splits.of_dvd _ h_div (splits_mul _ (splits_X _) _)\n      apply IsSplittingField.splits (S := {X ^ n - 1 | n ∈ S})\n      use q ^ k - 1\n      refine ⟨?_, rfl⟩\n      rw [Set.mem_setOf_eq, Ne, Nat.cast_sub (one_le_pow_of_one_le (Fintype.card_pos) _),\n          Nat.cast_one, Nat.cast_pow, hq, zero_pow (by simp [k, Nat.pos_of_ne_zero (Polynomial.natDegree_ne_zero_of_degree_ne_bot (Polynomial.degree_eq_natDegree hf.ne_zero ▸ hf.ne_bot))]), zero_sub]\n      exact neg_ne_zero.mpr one_ne_zero\n  · rw [IsCyclotomicExtension.iff_isSplittingField]\n    refine IsSplittingField.mk_of_splits_of_generate_roots \n      (fun p ⟨n, _, hp⟩ ↦ hp ▸ IsAlgClosure.splits_codomain p) ?_\n    rw [eq_top_iff]\n    intro x\n    by_cases hx : x = 0; · simp [hx]\n    let q := Fintype.card K\n    let E := Algebra.adjoin K {x}\n    have : Finite E := Finite.of_isAlgebraic_of_finite (IsAlgClosure.isAlgebraic K x)\n    have : Fintype E := Fintype.ofFinite E\n    let k := FiniteDimensional.finrank K E\n    have hk : 0 < k := FiniteDimensional.finrank_pos\n    have hpow : x ^ (q ^ k) = x := by\n      have hcard : Fintype.card E = q ^ k := Fintype.card_eq_pow_finrank\n      have := FiniteField.pow_card_eq (⟨x, Algebra.subset_adjoin (Set.mem_singleton x)⟩ : E)\n      simp only [hcard] at this\n      exact this\n    refine Algebra.subset_adjoin ⟨q ^ k - 1, ?_, ?_⟩\n    · rw [Set.mem_setOf_eq, Ne, Nat.cast_sub (one_le_pow_of_one_le (Fintype.card_pos) _), \n          Nat.cast_one, Nat.cast_pow, CharP.cast_card_eq_zero K, zero_pow (by simp [hk]), zero_sub]\n      exact neg_ne_zero.mpr one_ne_zero\n    · rw [Polynomial.mem_roots (by simp [X_pow_sub_one_ne_zero]), Polynomial.eval_sub, \n          Polynomial.eval_pow, Polynomial.eval_X, Polynomial.eval_one, sub_eq_zero]\n      apply (mul_eq_zero.mp (a := x) _).resolve_left hx\n      rw [mul_sub, mul_one, ← pow_succ', Nat.sub_add_cancel (one_le_pow_of_one_le (Fintype.card_pos) _), hpow, sub_self]",
      "nce",
