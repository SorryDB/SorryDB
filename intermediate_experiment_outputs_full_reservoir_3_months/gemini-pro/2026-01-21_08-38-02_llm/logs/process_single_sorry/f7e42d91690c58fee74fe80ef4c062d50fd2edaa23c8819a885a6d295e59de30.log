      marcinkiewiczZygmundConst (2 * m) * ∫ ω, (∑ i ∈ A, ‖X i ω‖ ^ 2) ^ m ∂μ := by
  let X₁ i : Ω × Ω → E := X i ∘ Prod.fst
  let X₂ i : Ω × Ω → E := X i ∘ Prod.snd
  let X' i : Ω × Ω → E := X₁ i - X₂ i
  have : DecidableEq ι := Classical.decEq _
  calc
    ∫ ω, ‖∑ i ∈ A, X i ω‖ ^ (2 * m) ∂μ
    _ ≤ ∫ ω, ‖∑ i ∈ A, X' i ω‖ ^ (2 * m) ∂μ.prod μ := by
      let S := ∑ i ∈ A, X i
      have hS : Integrable S μ := Integrable.sum fun i hi ↦ (memLp_X i hi).integrable one_le_two_mul_m
      have hS0 : ∫ ω, S ω ∂μ = 0 := by simp [S, integral_sum _ hS, integral_X]
      simp only [X', X₁, X₂, sum_sub_distrib]
      convert integral_norm_pow_le_integral_norm_sub_pow hS hS0 (2 * m : ℝ) (by norm_cast; exact one_le_two_mul_m) using 1
      · funext; rw [Real.rpow_nat_cast]
      · congr with x; simp [S]; rfl
