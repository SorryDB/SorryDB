/--
Taking the first `i` elements of a flattened list
can be expressed as the flattening of the first `j` complete sublists, plus the first
`k` elements of the `j`-th sublist.

The indices are computed as:
- `j` is one less than where the cumulative sum first exceeds `i`
- `k` is `i` minus the total length of the first `j` sublists
-/
theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil => simp
  | cons l L ih =>
    simp only [flatten_cons, partialSums_cons, take_append]
    have : findIdx (fun x => decide (x > i)) (0 :: map (l.length + ·) (map length L).partialSums) =
        1 + findIdx (fun x => decide (x > i)) (map (l.length + ·) (map length L).partialSums) := rfl
    rw [this]; simp only [Nat.add_sub_cancel_right]
    split
    · rename_i h
      have : findIdx (fun x => decide (x > i)) (map (l.length + ·) (map length L).partialSums) = 0 := by
        cases (map length L).partialSums <;> simp_all; omega
      simp [this]
      have : i - l.length = 0 := by omega
      simp [this]
    · rename_i h
      simp only [not_lt] at h
      have h_idx : findIdx (fun x => decide (x > i)) (map (l.length + ·) (map length L).partialSums) =
          findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums := by
        rw [findIdx_map]; congr; funext x; simp; omega
      rw [h_idx]
      let idx := findIdx (fun x => decide (x > i - l.length)) (map length L).partialSums
      have : idx ≠ 0 := by
        cases (map length L).partialSums <;> simp_all; omega
      cases idx with
      | zero => contradiction
      | succ idx' =>
        simp only [take_succ_cons, flatten_cons, append_assoc, getElem?_cons_succ]
        rw [ih (i - l.length)]
        congr 1
        rw [take_of_length_le h]
