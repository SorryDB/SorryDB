theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil => simp
  | cons l L ih =>
    simp only [flatten_cons]
    by_cases h : i < l.length
    · have : (map length (l :: L)).partialSums.findIdx (· > i) = 1 := by
        simp [partialSums_cons, findIdx_cons]
        rw [findIdx_eq] <;> grind
      simp [this, take_append_of_le_length (by simpa using h.le)]
    · rw [not_lt] at h
      rw [take_append, take_of_length_le h, ih (i - l.length)]
      have : (map length (l :: L)).partialSums.findIdx (· > i) =
          (map length L).partialSums.findIdx (· > i - l.length) + 1 := by
        simp [partialSums_cons, findIdx_cons, Function.comp_def]
        congr; funext x; grind
      simp only [this]
      simp
      congr 1
      simp; omega
