instance (priority := 100) IsKrullDomain.isIntegrallyClosed
    (A : Type*) [CommRing A] [IsDomain A] [IsKrullDomain A] : IsIntegrallyClosed A := by
  refine ⟨fun {x} hx ↦ ?_⟩
  rw [← IsKrullDomain.biInf_eq_bot (A := A), Subalgebra.mem_iInf]
  intro p
  rw [Subalgebra.mem_iInf]
  intro hp
  let M := p.1.primeCompl
  haveI : IsDiscreteValuationRing (Localization M) :=
    IsKrullDomain.isDiscreteValuationRing_localization p hp
  haveI : IsFractionRing (Localization M) (FractionRing A) :=
    IsLocalization.isFractionRing_of_isDomain_of_isLocalization M _
  haveI : IsScalarTower A (Localization M) (FractionRing A) :=
    IsScalarTower.of_algebraMap_eq (fun x ↦ (IsLocalization.lift_eq M _ x).symm)
  obtain ⟨y, hy⟩ := IsIntegrallyClosed.isIntegral_iff.mp (isIntegral_of_isScalarTower hx)
  rw [Localization.mem_subalgebra_iff]
  obtain ⟨a, s, rfl⟩ := IsLocalization.mk_surjective M y
  exact ⟨a, s, by simpa using hy.symm⟩
