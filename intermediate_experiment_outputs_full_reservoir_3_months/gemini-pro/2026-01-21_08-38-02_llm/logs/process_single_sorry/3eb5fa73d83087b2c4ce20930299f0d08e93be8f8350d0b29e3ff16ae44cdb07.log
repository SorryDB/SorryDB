      "\n  induction a with\n  | nil =>\n    exists []\n    simp\n  | cons h t ih =>\n    obtain ⟨bt, hlen, hfresh, hnodup⟩ := ih\n    let blocked := (ε.toList.filterMap (fun x => if x.1.1 == h then some x.1.2 else none)) ++\n                   ((t.zip bt).filterMap (fun x => if x.1 == h then some x.2 else none))\n    let max_len := blocked.foldr (fun s n => max s.length n) 0\n    let s := String.mk (List.replicate (max_len + 1) 'x')\n    have hs : s ∉ blocked := by\n      intro hin\n      have hlen : ∀ x ∈ blocked, x.length ≤ max_len := by\n        intro x hx; induction blocked <;> simp_all [List.foldr]\n        cases hx <;> simp_all; apply Nat.le_trans _ (Nat.le_max_right _ _); assumption\n      specialize hlen s hin\n      have : s.length = max_len + 1 := by simp [s]\n      rw [this] at hlen; have := Nat.lt_succ_self max_len; apply Nat.not_le_of_gt this hlen\n    exists s :: bt\n    constructor\n    · simp [hlen]\n    constructor\n    · intro a' b' hin\n      simp at hin\n      cases hin with\n      | inl heq =>\n        cases heq; intro hcon\n        apply hs; apply List.mem_append_of_mem_left\n        rw [List.mem_filterMap]\n        rw [Batteries.AssocList.contains_eq_isSome_find?] at hcon\n        cases hf : ε.find? (h, s) with\n        | none => simp [hf] at hcon\n        | some v =>\n          exists ⟨(h, s), v⟩\n          simp [beq_self_eq_true]\n          constructor\n          · apply Batteries.AssocList.find?_some_iff_get_eq.mp hf\n          · rfl\n      | inr hin =>\n        apply hfresh _ _ hin\n    · rw [List.nodup_cons]\n      constructor\n      · intro hin\n        apply hs; apply List.mem_append_of_mem_right\n        rw [List.mem_filterMap]; exists (h, s); simp [hin]\n      · exact hnodup",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons h t ih =>\n    obtain ⟨b, hl, hf, hn⟩ := ih\n    let used := ε.toList.map (Prod.snd ∘ Prod.fst) ++ b\n    let m := used.foldr (λ str acc => max str.length acc) 0\n    let s := String.mk (List.replicate (m + 1) 'a')\n    have hnot : s ∉ used := by\n      intro hin\n      have : s.length ≤ m := by\n        induction used with\n        | nil => contradiction\n        | cons x xs ih =>\n          simp [List.foldr] at *\n          rcases hin with rfl | hin\n          · exact Nat.le_max_left _ _\n          · exact Nat.le_trans (ih hin) (Nat.le_max_right _ _)\n      simp [s] at this; contradiction\n    refine ⟨s :: b, by simp [hl], ?_, ?_⟩\n    · intros a' b' mem\n      simp at mem\n      rcases mem with ⟨rfl, rfl⟩ | mem\n      · intro hc; apply hnot; apply List.mem_append_of_mem_left\n        revert hc; grind\n      · exact hf _ _ mem\n    · rw [List.nodup_cons]\n      refine ⟨λ mem => hnot (List.mem_append_of_mem_right _ ?_), hn⟩\n      induction t generalizing b with\n      | nil => contradiction\n      | cons _ _ iht => cases b; contradiction; simp at mem; cases mem; apply List.mem_cons_self; apply List.mem_cons_of_mem; apply iht; assumption",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, by simp⟩\n  | cons x xs ih =>\n    obtain ⟨bs, hl, hfresh, hnodup⟩ := ih\n    let bad := (ε.toList.map Prod.fst ++ xs.zip bs).filterMap (λ p => if p.1 = x then some p.2 else none)\n    let total_len := bad.foldr (λ str n => str.length + n) 0\n    let s := String.mk (List.replicate (total_len + 1) 'x')\n    have s_fresh : s ∉ bad := by\n      intro h\n      have : s.length ≤ total_len := by\n        let rec lemma_len : ∀ {l} {str}, str ∈ l → str.length ≤ l.foldr (λ x n => x.length + n) 0 := by\n          intro l str hin\n          induction l with\n          | nil => contradiction\n          | cons y ys ihy =>\n            simp [List.foldr]\n            cases hin with\n            | inl e => rw [e]; apply Nat.le_add_right\n            | inr i => apply Nat.le_trans (ihy i); apply Nat.le_add_left\n        apply lemma_len h\n      have slen : s.length = total_len + 1 := by simp [s]\n      rw [slen] at this\n      apply Nat.not_succ_le_self _ this\n    refine ⟨s :: bs, by simp [hl], ?_, ?_⟩\n    · intros a' b' h\n      simp at h\n      cases h with\n      | inl heq =>\n        rw [heq.1, heq.2]; intro hc; apply s_fresh\n        simp [bad, List.mem_filterMap]; exists (x, s)\n        constructor\n        · simp; left\n          revert hc; induction ε with\n          | nil => simp [Batteries.AssocList.contains, Batteries.AssocList.find?]\n          | cons k v t ih' =>\n            simp [Batteries.AssocList.contains, Batteries.AssocList.find?]\n            split <;> intro h\n            · simp; assumption\n            · right; exact ih' h\n        · simp\n      | inr hin => exact hfresh _ _ hin\n    · simp; constructor\n      · intro h_in; apply s_fresh\n        simp [bad, List.mem_filterMap]; exists (x, s)\n        constructor; simp; right; exact h_in; simp\n      · exact hnodup",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons h t ih =>\n    obtain ⟨tb, hlen, hfresh, hnodup⟩ := ih\n    let bad_in_ε : List String := ε.toList.filterMap (λ k => if k.1.1 = h then some k.1.2 else none)\n    let bad_in_tail : List String := (t.zip tb).filterMap (λ p => if p.1 = h then some p.2 else none)\n    let bad := bad_in_ε ++ bad_in_tail\n    let len := bad.foldr (λ s n => max s.length n) 0\n    let hb := String.mk (List.replicate (len + 1) 'x')\n    have hbad : hb ∉ bad := by\n      intro m\n      have : hb.length ≤ len := by\n        induction bad with\n        | nil => contradiction\n        | cons s ss ih' =>\n          cases m with\n          | head => simp [List.foldr]; apply Nat.le_max_left\n          | tail _ m' =>\n            simp [List.foldr]; trans; apply ih' m'; apply Nat.le_max_right\n      simp [hb] at this\n      rw [List.length_replicate] at this\n      apply Nat.not_succ_le_self _ this\n    exists hb :: tb\n    refine ⟨by simp [hlen], ?_, ?_⟩\n    · intros a' b' hin\n      simp at hin\n      cases hin with\n      | inl heq =>\n        cases heq; subst h hb\n        intro hc\n        apply hbad\n        apply List.mem_append_of_mem_left\n        rw [List.mem_filterMap]\n        have : ∃ v, ((h, hb), v) ∈ ε.toList := by\n          induction ε with\n          | nil => simp [Batteries.AssocList.contains, Batteries.AssocList.find?] at hc\n          | cons k v tail ih =>\n            simp [Batteries.AssocList.contains, Batteries.AssocList.find?] at hc\n            split at hc\n            next heq =>\n              exists v\n              simp\n              have : k = (h, hb) := eq_of_beq heq\n              rw [this]\n            next =>\n              obtain ⟨v', hv'⟩ := ih hc\n              exists v'\n              simp [hv']\n        obtain ⟨v, hmem⟩ := this\n        exists ((h, hb), v)\n        simp [hmem]\n      | inr hin => exact hfresh _ _ hin\n    · simp\n      rw [List.nodup_cons]\n      refine ⟨?_, hnodup⟩\n      intro hin\n      apply hbad\n      apply List.mem_append_of_mem_right\n      rw [List.mem_filterMap]\n      exists (h, hb)\n      simp [hin]",
      "\n  induction a generalizing ε with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons h t ih =>\n    obtain ⟨bt, hlen, hfresh, hnodup⟩ := ih\n    let used := bt ++ ε.toList.map (Prod.snd ∘ Prod.fst)\n    let max_len := used.foldr (λ s n => max s.length n) 0\n    let s := String.mk (List.replicate (max_len + 1) 'x')\n    have hs : s ∉ used := by\n      intro h\n      have : s.length ≤ max_len := by\n        induction used with\n        | nil => contradiction\n        | cons u us ih =>\n          simp only [max_len, List.foldr]\n          cases h with\n          | head => apply Nat.le_max_left\n          | tail h => apply Nat.le_trans (ih h) (Nat.le_max_right _ _)\n      have : s.length = max_len + 1 := by simp [s]\n      have : max_len + 1 ≤ max_len := by rwa [← this]\n      exact Nat.not_succ_le_self _ this\n    refine ⟨s :: bt, by simp [hlen], ?_, ?_⟩\n    · intro a' b' H\n      simp only [List.zip_cons_cons, List.mem_cons] at H\n      cases H with\n      | inl H =>\n        obtain ⟨rfl, rfl⟩ := H\n        simp only [Bool.not_eq_true]\n        intro hc\n        apply hs; apply List.mem_append_of_mem_right\n        induction ε with\n        | nil => simp [Batteries.AssocList.contains] at hc\n        | cons k v l ih =>\n          simp [Batteries.AssocList.contains, Batteries.AssocList.toList] at hc ⊢\n          by_cases heq : (h, s) == k\n          · rw [if_pos heq] at hc\n            simp; left; apply beq_iff_eq.mp heq\n          · rw [if_neg heq] at hc\n            right; exact ih hc\n      | inr H => exact hfresh _ _ H\n    · simp only [List.zip_cons_cons, List.nodup_cons, hnodup, true_and]\n      intro H\n      apply hs; apply List.mem_append_of_mem_left\n      exact List.mem_map_of_mem Prod.snd H",
      "\n  induction a with\n  | nil =>\n    exists []\n    simp\n  | cons h t ih =>\n    obtain ⟨bt, hlen, hfresh, hnodup⟩ := ih\n    let forbidden := ε.foldl (λ acc k _ => k.2 :: acc) bt\n    let max_len := forbidden.foldr (λ s n => max s.length n) 0\n    let s := String.mk (List.replicate (max_len + 1) 'a')\n    have s_len : s.length = max_len + 1 := by simp [s, max_len]\n    have s_not_mem : s ∉ forbidden := by\n      intro h\n      have : s.length ≤ max_len := by\n        rw [←s_len]\n        clear s_len s hlen hfresh hnodup\n        induction forbidden with\n        | nil => contradiction\n        | cons x xs ih =>\n          simp [max_len] at *\n          cases h with\n          | inl heq => subst heq; apply Nat.le_max_left\n          | inr hin => apply Nat.le_trans (ih hin); apply Nat.le_max_right\n      rw [s_len] at this\n      exact Nat.not_succ_le_self _ this\n    have mem_foldl_of_mem_acc : ∀ (l : FinEnv Ident (String × String)) (acc : List String) (x), x ∈ acc → x ∈ l.foldl (λ a k _ => k.2 :: a) acc := by\n      intro l; induction l with\n      | nil => intros; assumption\n      | cons k v t ih => intros acc x hin; simp [Batteries.AssocList.foldl]; apply ih; simp [hin]\n    have mem_foldl_of_contains : ∀ (l : FinEnv Ident (String × String)) (acc : List String), l.contains (h, s) → s ∈ l.foldl (λ a k _ => k.2 :: a) acc := by\n      intro l; induction l with\n      | nil => intros; simp [Batteries.AssocList.contains] at *\n      | cons k v t ih =>\n        intro acc hcon; simp [Batteries.AssocList.foldl]\n        simp [Batteries.AssocList.contains] at hcon\n        split at hcon\n        · have : k = (h, s) := LawfulBEq.eq_of_beq ‹_›\n          subst this; apply mem_foldl_of_mem_acc; simp\n        · apply ih _ hcon\n    exists s :: bt\n    refine ⟨by simp [hlen], ?_, ?_⟩\n    · intros a' b' hin\n      simp at hin\n      cases hin with\n      | inl heq =>\n        obtain ⟨rfl, rfl⟩ := heq\n        intro hcon\n        have : s ∈ forbidden := mem_foldl_of_contains ε bt hcon\n        contradiction\n      | inr hin => exact hfresh _ _ hin\n    · rw [List.zip_cons_cons, List.nodup_cons]\n      constructor\n      · intro hin\n        rw [←hlen] at hin\n        have : s ∈ bt := by\n          clear hfresh hnodup s_not_mem\n          induction t generalizing bt with\n          | nil => cases bt; contradiction; cases hlen; contradiction\n          | cons _ _ ih =>\n            cases bt with | nil => contradiction | cons _ _ =>\n            simp at hin hlen\n            cases hin with\n            | inl h => inject h; assumption\n            | inr h => right; exact ih _ hlen h\n        have : s ∈ forbidden := mem_foldl_of_mem_acc ε bt s this\n        contradiction\n      · exact hnodup",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons x xs ih =>\n    obtain ⟨bs, hlen, hfresh, hnodup⟩ := ih\n    let keys := ε.toList.map Prod.fst\n    let bad := (keys.filter (λ k => k.1 == x)).map Prod.snd\n    let forbidden := bs ++ bad\n    let max_len := (forbidden.map String.length).foldr Nat.max 0\n    let s := String.mk (List.replicate (max_len + 1) 'a')\n    have s_fresh : s ∉ forbidden := by\n      intro h\n      have : s.length ≤ max_len := by\n        induction forbidden with\n        | nil => contradiction\n        | cons f fs ih =>\n          simp [List.foldr] at *\n          cases h with | inl heq => rw [heq]; apply Nat.le_max_left | inr hin => trans; apply ih hin; apply Nat.le_max_right\n      have : s.length = max_len + 1 := by simp [s]\n      have : s.length > max_len := by rw [this]; apply Nat.lt_succ_self\n      apply Nat.lt_irrefl _ (Nat.lt_of_le_of_lt this ‹s.length > max_len›)\n    refine ⟨s :: bs, by simp [hlen], ?_, ?_⟩\n    · intro u v huv\n      simp at huv\n      rcases huv with ⟨rfl, rfl⟩ | hin\n      · simp only [Bool.not_eq_true]\n        intro hc\n        have : (x, s) ∈ keys := by\n          rw [Batteries.AssocList.contains] at hc\n          rcases List.any_iff_exists.mp hc with ⟨p, hp, heq⟩\n          simp at heq; rw [heq]; apply List.mem_map_of_mem Prod.fst hp\n        have : s ∈ bad := by\n          rw [List.mem_map]; exists (x, s)\n          simp [keys, bad]; constructor\n          · rw [List.mem_filter]; exact ⟨this, by simp⟩\n          · rfl\n        exact s_fresh (List.mem_append_right _ this)\n      · apply hfresh _ _ hin\n    · rw [List.nodup_cons]\n      refine ⟨?_, hnodup⟩\n      intro h\n      have : s ∈ bs := by\n        clear hfresh hnodup s_fresh bad keys ih\n        induction xs generalizing bs with\n        | nil => cases bs; contradiction; contradiction\n        | cons _ _ ih =>\n          cases bs with\n          | nil => contradiction\n          | cons b bs =>\n            simp at hlen h\n            cases h with | inl heq => rw [heq.2]; exact List.mem_cons_self _ _ | inr hin => right; apply ih (by simp at hlen; exact hlen) hin\n      exact s_fresh (List.mem_append_left _ this)",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons h t ih =>\n    obtain ⟨b, hl, hf, hn⟩ := ih\n    let keys := ε.toList.map Prod.fst\n    let forbidden := (keys ++ t.zip b).filterMap (fun (k, v) => if k = h then some v else none)\n    let max_len := forbidden.foldr (fun s n => max s.length n) 0\n    let y := String.mk (List.replicate (max_len + 1) 'a')\n    have hy : y ∉ forbidden := by\n      intro h_in\n      have : y.length ≤ max_len := by\n        induction forbidden with\n        | nil => contradiction\n        | cons f fs ih_f =>\n          dsimp [max_len]\n          rw [List.mem_cons] at h_in\n          cases h_in\n          · subst f; exact Nat.le_max_left _ _\n          · exact Nat.le_trans (ih_f (by assumption)) (Nat.le_max_right _ _)\n      have : y.length = max_len + 1 := by simp [y]\n      rw [this] at this_1\n      exact Nat.not_succ_le_self _ this_1\n    refine ⟨y :: b, by simp [hl], ?_, ?_⟩\n    · intros a' b' hmem\n      simp at hmem\n      cases hmem with\n      | inl heq =>\n        injection heq with h1 h2; subst h1 h2\n        intro hc\n        have : y ∈ forbidden := by\n          refine List.mem_filterMap.mpr ⟨(h, y), ?_, ?_⟩\n          · left\n            have : (h, y) ∈ keys := by\n               cases ε\n               dsimp [Batteries.AssocList.contains, Batteries.AssocList.find?, Batteries.AssocList.toList] at *\n               rename_i l\n               induction l with\n               | nil => contradiction\n               | cons hd tl ih_l =>\n                 dsimp [List.find?] at hc\n                 split at hc\n                 · simp_all; exact List.mem_cons_self _ _\n                 · simp; right; exact ih_l hc\n            exact this\n          · simp\n        contradiction\n      | inr hmem => exact hf _ _ hmem\n    · rw [List.nodup_cons]\n      constructor\n      · intro h_in\n        have : y ∈ forbidden := by\n          refine List.mem_filterMap.mpr ⟨(h, y), ?_, ?_⟩\n          · right; exact h_in\n          · simp\n        contradiction\n      · exact hn",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons h t ih =>\n    obtain ⟨b, hl, hf, hn⟩ := ih\n    let forbidden := (ε.toList.map Prod.fst ++ t.zip b).filterMap (λ (x, y) => if x = h then some y else none)\n    let fresh := String.mk (List.replicate (forbidden.foldr (max ·.length) 0 + 1) 'x')\n    have h_not_mem : fresh ∉ forbidden := λ h_mem => by\n      have h_len : ∀ s ∈ forbidden, s.length ≤ forbidden.foldr (max ·.length) 0 := by\n        intro s hs\n        induction forbidden with\n        | nil => contradiction\n        | cons x xs ih =>\n          simp at hs; simp\n          cases hs with\n          | inl h => subst h; apply Nat.le_max_left\n          | inr h => apply Nat.le_trans (ih h); apply Nat.le_max_right\n      have := h_len fresh h_mem\n      simp [fresh] at this\n      exact Nat.not_succ_le_self _ this\n    refine ⟨fresh :: b, by simp [hl], ?_, ?_⟩\n    · intro a' b' h_in\n      simp at h_in\n      cases h_in with\n      | inl h_eq =>\n        rcases h_eq with ⟨rfl, rfl⟩\n        simp only [Bool.not_eq_true]\n        apply Bool.eq_false_iff.2\n        by_contra hc\n        apply h_not_mem\n        simp [forbidden]\n        apply List.mem_filterMap.2\n        refine ⟨(h, fresh), ?_, rfl⟩\n        simp only [and_true, beq_self_eq_true, ite_true]\n        rw [Batteries.AssocList.contains_eq_isSome_find?] at hc\n        have ⟨v, hv⟩ := Option.isSome_iff_exists.mp hc\n        exact List.mem_map_of_mem Prod.fst (Batteries.AssocList.mem_of_find? hv)\n      | inr h_in => exact hf _ _ h_in\n    · simp [List.nodup_cons, hn]\n      intro h_mem\n      apply h_not_mem\n      simp [forbidden]\n      apply List.mem_filterMap.2\n      exact ⟨(h, fresh), by simp [h_mem], rfl⟩",
      "\n  induction a generalizing ε with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons h t ih =>\n    obtain ⟨bt, hlen, hfresh, hnodup⟩ := ih\n    let bad := bt ++ ε.toList.map (Prod.snd ∘ Prod.fst)\n    let len := bad.foldr (λ s n => max s.length n) 0\n    let s := String.mk (List.replicate (len + 1) 'a')\n    have s_not_bad : s ∉ bad := by\n      intro h\n      have l1 : s.length = len + 1 := by simp [s]\n      have l2 : s.length ≤ len := by\n        induction bad with\n        | nil => contradiction\n        | cons x xs ih =>\n          cases h\n          · exact Nat.le_max_left _ _\n          · exact Nat.le_trans (ih ‹_›) (Nat.le_max_right _ _)\n      rw [l1] at l2\n      exact Nat.not_succ_le_self _ l2\n    refine ⟨s :: bt, by simp [hlen], ?_, ?_⟩\n    · intro a' b' hin\n      simp at hin\n      cases hin with\n      | inl heq =>\n        obtain ⟨rfl, rfl⟩ := heq\n        intro hcon\n        apply s_not_bad; right\n        induction ε with\n        | nil => simp [Batteries.AssocList.contains] at hcon\n        | cons k v tl ih =>\n          simp [Batteries.AssocList.contains] at hcon\n          split at hcon\n          · next heq => rw [beq_iff_eq] at heq; subst heq; exact List.mem_cons_self _ _\n          · exact List.mem_cons_of_mem _ (ih hcon)\n      | inr hin => exact hfresh _ _ hin\n    · rw [List.nodup_cons]\n      exact ⟨λ h => s_not_bad (List.mem_append_of_mem_left _ (by rwa [←hlen, List.map_snd_zip] at h; exact hlen)), hnodup⟩",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons a' as ih =>\n    obtain ⟨bs, hlen, hfresh, hnodup⟩ := ih\n    let keys := ε.toList.map Prod.fst ++ as.zip bs\n    let forbidden := keys.filterMap (λ (k, v) => if k = a' then some v else none)\n    let n := (forbidden.map String.length).foldr Nat.max 0\n    let b' := String.mk (List.replicate (n + 1) 'a')\n    have hb' : b' ∉ forbidden := by\n      intro h\n      let lens := forbidden.map String.length\n      have : b'.length ∈ lens := List.mem_map_of_mem String.length h\n      have le_max : ∀ x, x ∈ lens → x ≤ lens.foldr Nat.max 0 := by\n        intro x hx\n        induction lens with\n        | nil => contradiction\n        | cons l ls ih_l =>\n          simp at hx ⊢\n          cases hx with\n          | head hx => rw [hx]; apply Nat.le_max_left\n          | tail hx => exact Nat.le_trans (ih_l hx) (Nat.le_max_right _ _)\n      have : b'.length ≤ n := le_max b'.length this\n      simp [b', String.length, List.length_replicate] at this\n      exact Nat.not_succ_le_self n this\n    exists b' :: bs\n    refine ⟨by simp [hlen], ?_, ?_⟩\n    · intro u v huv\n      simp at huv\n      cases huv with\n      | head h =>\n        obtain ⟨rfl, rfl⟩ := h\n        intro hc\n        apply hb'\n        simp [forbidden, keys, List.mem_filterMap]\n        exists (a', b')\n        constructor\n        · apply List.mem_append_left\n          rw [Batteries.AssocList.contains] at hc\n          rw [List.any_eq_true] at hc\n          obtain ⟨⟨k, val⟩, hmem, heq⟩ := hc\n          simp at heq\n          rw [heq] at hmem\n          exact List.mem_map_of_mem Prod.fst hmem\n        · rfl\n      | tail h => exact hfresh _ _ h\n    · simp [List.nodup_cons, hnodup]\n      intro h\n      apply hb'\n      simp [forbidden, keys, List.mem_filterMap]\n      exists (a', b')\n      constructor\n      · apply List.mem_append_right; exact h\n      · rfl",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, by simp⟩\n  | cons x xs ih =>\n    obtain ⟨bs, hlen, hfresh, hnodup⟩ := ih\n    let bad := (ε.toList.map Prod.fst ++ xs.zip bs).filterMap (λ (u, v) => if u == x then some v else none)\n    let n := bad.foldr (λ s acc => max s.length acc) 0\n    let y := String.mk (List.replicate (n + 1) 'x')\n    have hy : y ∉ bad := by\n      intro h\n      have : y.length ≤ n := by\n        induction bad with\n        | nil => contradiction\n        | cons b bad' ih =>\n          simp only [List.foldr, List.mem_cons] at h ⊢\n          cases h <;> simp_all only [Nat.le_max_left, Nat.le_max_right]\n          apply Nat.le_trans (ih ‹_›) (Nat.le_max_right _ _)\n      simp [y] at this\n      exact Nat.not_succ_le_self _ this\n    refine ⟨y :: bs, by simp [hlen], ?_, ?_⟩\n    · intros a' b' h\n      simp only [List.mem_cons, List.zip_cons] at h\n      cases h with\n      | inl h =>\n        cases h\n        rw [Bool.eq_false_iff, Batteries.AssocList.contains_eq_isSome, Option.not_isSome, Option.eq_none_iff_forall_not_mem]\n        intro v hv\n        apply hy\n        simp only [bad, List.mem_filterMap, List.mem_append, List.mem_map, List.mem_zip]\n        exists (x, y)\n        refine ⟨?_, by simp⟩\n        apply Or.inl\n        rw [Batteries.AssocList.find?_eq_find?_toList] at hv\n        exact List.mem_map_of_mem Prod.fst (List.mem_of_find?_eq_some hv)\n      | inr h => exact hfresh _ _ h\n    · simp only [List.zip_cons, List.nodup_cons]\n      refine ⟨?_, hnodup⟩\n      intro h\n      apply hy\n      simp only [bad, List.mem_filterMap, List.mem_append]\n      exists (x, y)\n      simp only [h, ite_true, Option.some.injEq, true_and]\n      exact Or.inr rfl",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩\n  | cons h t ih =>\n    obtain ⟨bt, hlen, hfree, hnodup⟩ := ih\n    let used := bt ++ ε.toList.map (Prod.snd ∘ Prod.fst)\n    let max_len := used.foldr (λ s n => max s.length n) 0\n    let s := String.mk (List.replicate (max_len + 1) 'x')\n    have s_fresh : s ∉ used := by\n      intro h\n      have : s.length ≤ max_len := by\n        induction used with\n        | nil => contradiction\n        | cons x xs ih_u =>\n          cases h with\n          | head => apply Nat.le_max_left\n          | tail _ h => exact Nat.le_trans (ih_u h) (Nat.le_max_right _ _)\n      have : s.length = max_len + 1 := by simp [s, List.length_replicate]\n      rw [this] at *\n      exact Nat.not_succ_le_self _ (by assumption)\n    refine ⟨s :: bt, by simp [hlen], ?_, ?_⟩\n    · intro a' b' h\n      cases h with\n      | head =>\n        simp only\n        intro hcon\n        apply s_fresh\n        apply List.mem_append_of_mem_right\n        have : (h, s).2 ∈ ε.toList.map (Prod.snd ∘ Prod.fst) := by\n          induction ε generalizing h s with\n          | nil => simp [Batteries.AssocList.contains] at hcon\n          | cons k v tail ih_ε =>\n            simp [Batteries.AssocList.contains] at hcon\n            split at hcon\n            · simp_all; exact List.mem_cons_self _ _\n            · exact List.mem_cons_of_mem _ (ih_ε hcon)\n        exact this\n      | tail _ h => exact hfree _ _ h\n    · rw [List.zip_cons_cons, List.nodup_cons]\n      refine ⟨?_, hnodup⟩\n      intro hin\n      apply s_fresh\n      apply List.mem_append_of_mem_left\n      let rec mem_snd {α β} {x : α × β} {l1 : List α} {l2 : List β} (h : x ∈ l1.zip l2) : x.2 ∈ l2 := by\n         match l1, l2, h with\n         | _ :: _, _ :: _, List.Mem.head .. => exact List.mem_cons_self _ _\n         | _ :: _, _ :: _, List.Mem.tail _ h' => exact List.mem_cons_of_mem _ (mem_snd h')\n      exact mem_snd hin",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, by simp⟩\n  | cons h t ih =>\n    obtain ⟨bt, hlen, hfresh, hnodup⟩ := ih\n    let keys := ε.toList.map Prod.fst\n    let bad := (keys ++ (t.zip bt)).filterMap (λ p => if p.1 == h then some p.2 else none)\n    let bh := String.mk (List.replicate (bad.foldr (λ s n => max s.length n) 0 + 1) 'a')\n    have hbad : bh ∉ bad := by\n      intro h\n      let len := bad.foldr (λ s n => max s.length n) 0\n      have : bh.length ≤ len := by\n        induction bad with\n        | nil => contradiction\n        | cons x xs ih =>\n          simp_all [len]\n          cases h with\n          | inl e => rw [←e]; apply Nat.le_max_left\n          | inr e => trans (xs.foldr (λ s n => max s.length n) 0); apply ih e; apply Nat.le_max_right\n      have : bh.length = len + 1 := rfl\n      rw [this] at this_1; apply Nat.not_succ_le_self _ this_1\n    refine ⟨bh :: bt, by simp [hlen], ?_, ?_⟩\n    · intro u v hin\n      simp at hin; cases hin with\n      | inl e =>\n        rcases e with ⟨rfl, rfl⟩\n        intro hc\n        have : (h, bh) ∈ keys := by\n          induction ε with\n          | nil => simp [Batteries.AssocList.contains] at hc\n          | cons k v l ih =>\n            simp [Batteries.AssocList.contains, Batteries.AssocList.find?] at hc\n            split at hc\n            · simp [keys, Batteries.AssocList.toList]; left; apply eq_of_beq; assumption\n            · simp [keys, Batteries.AssocList.toList]; right; exact ih hc\n        have : bh ∈ bad := by simp [bad]; exists (h, bh); simp [this]\n        contradiction\n      | inr e => exact hfresh u v e\n    · rw [List.nodup_cons]; constructor\n      · intro hin\n        have : bh ∈ bad := by simp [bad]; exists (h, bh); simp [hin]; right; assumption\n        contradiction\n      · exact hnodup",
      "\n  let bad := ε.toList.map (Prod.snd ∘ Prod.fst)\n  let gen_fresh (l : List String) : String := (l.foldr String.append \"\") ++ \"a\"\n  have fresh_prop : ∀ l, gen_fresh l ∉ l := by\n    intro l h\n    let sum_len := (l.map String.length).sum\n    have le_sum : ∀ s ∈ l, s.length ≤ sum_len := by\n      intro s hs; induction l with\n      | nil => contradiction\n      | cons x xs ih =>\n        cases hs with\n        | head h => subst h; apply Nat.le_add_right\n        | tail _ h => apply Nat.le_trans (ih h); apply Nat.le_add_left\n    have : (gen_fresh l).length = sum_len + 1 := by\n      dsimp [gen_fresh]; rw [String.length_append]\n      have : (l.foldr String.append \"\").length = sum_len := by\n        induction l <;> simp [*, String.length_append]\n      rw [this]; rfl\n    have : (gen_fresh l).length ≤ sum_len := le_sum _ h\n    omega\n  have exists_b : ∃ b : List String, b.length = a.length ∧ b.Nodup ∧ ∀ x ∈ b, x ∉ bad := by\n    induction a.length with\n    | zero => exists []; simp\n    | succ n ih =>\n      obtain ⟨b', hl, hn, hd⟩ := ih\n      let s := gen_fresh (bad ++ b')\n      exists s :: b'; simp [hl, hn]\n      constructor\n      · intro h; apply fresh_prop (bad ++ b'); rw [List.mem_append]; right; assumption\n      · intro x hx; cases hx with\n        | head => intro h; apply fresh_prop (bad ++ b'); rw [List.mem_append]; left; assumption\n        | tail _ h => apply hd _ h\n  obtain ⟨b, hlen, hnodup, hdisj⟩ := exists_b\n  refine ⟨b, hlen, ?_, ?_⟩\n  · intro a' b' h\n    have : b' ∈ b := by\n      have : b' ∈ (a.zip b).map Prod.snd := List.mem_map_of_mem _ h\n      have map_snd : ∀ {l r : List String}, l.length = r.length → (l.zip r).map Prod.snd = r := by\n        intro l; induction l with\n        | nil => intro r h; cases r; rfl; contradiction\n        | cons x xs ih => intro r h; cases r; contradiction; simp; apply ih; injections at h; assumption\n      rwa [map_snd hlen] at this\n    have : b' ∉ bad := hdisj _ this\n    intro hc\n    dsimp [Batteries.AssocList.contains] at hc\n    let ⟨_, hv⟩ := Option.isSome_iff_exists.mp hc\n    rw [Batteries.AssocList.find?_eq_some_iff_mem_toList] at hv\n    apply this; apply List.mem_map_of_mem (Prod.snd ∘ Prod.fst)\n    apply List.mem_map_of_mem _ hv\n  · rw [← hlen] at hnodup\n    apply List.Nodup.of_map (f := Prod.snd)\n    have map_snd : (a.zip b).map Prod.snd = b := by\n      clear hdisj fresh_prop hnodup\n      revert b; induction a <;> intro b h\n      · cases b; rfl; contradiction\n      · cases b; contradiction; simp; apply ih; injections at h; assumption\n    rwa [map_snd]",
      "\n  induction a with\n  | nil => exact ⟨[], rfl, by simp, by simp⟩\n  | cons h t ih =>\n    obtain ⟨b, hl, hf, hn⟩ := ih\n    let used := b ++ ε.toList.map (λ p => p.1.2)\n    let max_len := used.foldr (λ s n => max s.length n) 0\n    let s := \"\".pushn 'a' (max_len + 1)\n    have s_fresh : s ∉ used := by\n      intro m\n      have : s.length ≤ max_len := by\n        induction used with\n        | nil => contradiction\n        | cons x xs ih =>\n          simp [List.foldr] at *; cases m with\n          | head => exact Nat.le_max_left _ _\n          | tail m => exact Nat.le_trans (ih m) (Nat.le_max_right _ _)\n      simp [s] at this; exact Nat.not_succ_le_self _ this\n    refine ⟨s :: b, by simp [hl], ?_, ?_⟩\n    · intro a' b' H; simp at H; cases H with\n      | inl e =>\n        cases e; simp only [Bool.not_eq_true]\n        intro hc\n        have : ∃ v, ((h, s), v) ∈ ε.toList := by\n          suffices ∀ {l : FinEnv Ident (String × String)}, l.contains (h, s) → ∃ v, ((h, s), v) ∈ l.toList from this hc\n          intro l hl; induction l with\n          | nil => simp [Batteries.AssocList.contains] at hl\n          | cons k v tl ihl =>\n            simp [Batteries.AssocList.contains, Batteries.AssocList.toList] at *\n            cases heq : (k == (h, s))\n            · rw [heq] at hl; simp [false_or] at hl; obtain ⟨v', hv'⟩ := ihl hl\n              exact ⟨v', List.mem_cons_of_mem _ hv'⟩\n            · rw [beq_iff_eq] at heq; subst heq; exact ⟨v, List.mem_cons_self _ _⟩\n        obtain ⟨v, hv⟩ := this\n        exact s_fresh (List.mem_append_of_mem_right _ (List.mem_map_of_mem _ hv))\n      | inr m => exact hf _ _ m\n    · simp; constructor\n      · intro m; exact s_fresh (List.mem_append_of_mem_left _ (List.mem_map_of_mem _ m))\n      · exact hn",
      "\n  let bad := ε.toList.map (λ x => x.1.2)\n  have exists_b : ∃ b : List String, b.length = a.length ∧ b.Nodup ∧ ∀ x ∈ b, x ∉ bad := by\n    generalize hn : a.length = n\n    induction n with\n    | zero => exists []\n    | succ n ih =>\n      obtain ⟨b, hlen, hnodup, hbad⟩ := ih\n      let used := b ++ bad\n      let max_len := used.foldr (λ s n => Nat.max s.length n) 0\n      let fresh := String.mk (List.replicate (max_len + 1) 'a')\n      have h_fresh : fresh ∉ used := by\n        intro h\n        have : fresh.length ≤ max_len := by\n          induction used with\n          | nil => contradiction\n          | cons s ss ih' =>\n            cases h with\n            | head => exact Nat.le_max_left _ _\n            | tail _ h => exact Nat.le_trans (ih' h) (Nat.le_max_right _ _)\n        have : fresh.length = max_len + 1 := rfl\n        rw [this] at *\n        have c : max_len + 1 > max_len := Nat.lt_succ_self _\n        exact Nat.not_le_of_gt c this\n      refine ⟨fresh :: b, by simp [hlen], ?_, ?_⟩\n      · rw [List.nodup_cons]\n        exact ⟨fun h => h_fresh (List.mem_append_of_mem_left _ h), hnodup⟩\n      · intro x hx\n        cases hx with\n        | head => exact fun h => h_fresh (List.mem_append_of_mem_right _ h)\n        | tail _ h => exact hbad x h\n\n  obtain ⟨b, hlen, hnodup, hbad⟩ := exists_b\n  exists b\n  refine ⟨hlen, ?_, ?_⟩\n  · intro u v hin\n    have vinb : v ∈ b := by\n      have : length a = length b := hlen\n      induction a generalizing b with\n      | nil => cases b; contradiction; contradiction\n      | cons x xs ih =>\n        cases b with\n        | nil => contradiction\n        | cons y ys =>\n          simp at hin\n          cases hin with\n          | inl e => rw [e]; apply List.Mem.head\n          | inr e => apply List.Mem.tail; apply ih; simp at this; exact this; exact e\n    intro h\n    replace h : (ε.find? (u, v)).isSome := by\n      try rw [Batteries.AssocList.contains_eq_isSome] at h\n      exact h\n    match heq : ε.find? (u, v) with\n    | some val =>\n      have : (u, v) ∈ ε.toList.map Prod.fst := by\n        -- Assuming minimal API; find? finds => in toList\n        induction ε.toList with\n        | nil => simp [Batteries.AssocList.find?] at heq; contradiction\n        | cons k t ih' =>\n          simp [Batteries.AssocList.find?] at heq\n          split at heq\n          · simp; left; assumption\n          · simp; right; exact ih' heq\n      have : v ∈ bad := by\n        rw [List.mem_map] at this\n        obtain ⟨key, hk1, hk2⟩ := this\n        exists (key, val)\n        exact ⟨hk1, by simp [hk2]⟩\n      exact hbad v vinb this\n    | none => simp at h\n  · clear hbad\n    induction a generalizing b with\n    | nil => cases b; simp; contradiction\n    | cons x xs ih =>\n      cases b with\n      | nil => contradiction\n      | cons y ys =>\n        simp\n        simp at hlen\n        obtain ⟨ny, nys⟩ := List.nodup_cons.mp hnodup\n        constructor\n        · intro h\n          have : y ∈ ys := by\n            -- prove y ∈ ys if (x,y) ∈ zip xs ys\n            clear ih\n            induction xs generalizing ys with\n            | nil => cases ys; contradiction; contradiction\n            | cons a as ih2 =>\n              cases ys with\n              | nil => contradiction\n              | cons b bs =>\n                simp at h\n                cases h with\n                | inl e => rw [e]; apply List.Mem.head\n                | inr e => apply List.Mem.tail; apply ih2; simp at hlen; exact hlen; exact e\n          exact ny this\n        · exact ih ys hlen nys",
      "\n  induction a with\n  | nil =>\n    exists []\n    simp\n  | cons h t ih =>\n    obtain ⟨bt, hlen, hfresh, hnodup⟩ := ih\n    let forbidden := bt ++ (ε.toList.filterMap (λ ⟨(k1, k2), _⟩ => if k1 == h then some k2 else none))\n    let max_len := forbidden.foldr (λ s n => max s.length n) 0\n    let b_new := String.mk (List.replicate (max_len + 1) 'a')\n    have b_len : b_new.length = max_len + 1 := by simp\n    have b_not_mem : b_new ∉ forbidden := by\n      intro h\n      have : b_new.length ≤ max_len := by\n        clear hfresh hnodup b_len b_new hlen ih\n        induction forbidden with\n        | nil => contradiction\n        | cons x xs ih =>\n          simp [max_len] at *\n          cases h with\n          | head => apply Nat.le_max_left\n          | tail _ h => apply Nat.le_trans (ih h) (Nat.le_max_right _ _)\n      rw [b_len] at this\n      simp at this\n    exists (b_new :: bt)\n    refine ⟨?_, ?_, ?_⟩\n    · simp [hlen]\n    · intro a' b' hin\n      simp at hin\n      cases hin with\n      | inl heq =>\n        obtain ⟨rfl, rfl⟩ := heq\n        dsimp [Batteries.AssocList.contains]\n        rw [Option.isSome_iff_exists]\n        intro ⟨v, hv⟩\n        have : b_new ∈ forbidden := by\n           apply List.mem_append_of_mem_right\n           rw [List.mem_filterMap]\n           exists ⟨(h, b_new), v⟩\n           constructor\n           · apply Batteries.AssocList.find?_some_iff_mem_toList.mp hv\n           · simp\n        contradiction\n      | inr hin => exact hfresh a' b' hin\n    · rw [List.zip_cons_cons, List.nodup_cons]\n      constructor\n      · intro hmem\n        rw [List.mem_zip] at hmem\n        rcases hmem with ⟨i, hi, h_get_a, h_get_b⟩\n        have : b_new ∈ bt := List.mem_of_get? h_get_b\n        exact b_not_mem (List.mem_append_of_mem_left _ this)\n      · exact hnodup",
