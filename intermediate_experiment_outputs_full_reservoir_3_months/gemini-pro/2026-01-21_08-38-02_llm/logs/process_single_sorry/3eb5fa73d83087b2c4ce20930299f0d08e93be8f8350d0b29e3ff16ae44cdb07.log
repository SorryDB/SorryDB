theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  induction a with
  | nil => exact ⟨[], rfl, by simp, by simp⟩
  | cons h t ih =>
    obtain ⟨bt, hlen, hfresh, hnodup⟩ := ih
    let used := bt ++ ε.toList.map (Prod.snd ∘ Prod.fst)
    let n := used.foldr (λ s m => Nat.max s.length m) 0 + 1
    let s := String.mk (List.replicate n 'a')
    have hlen_s : s.length = n := List.length_replicate n 'a'
    have hnot : s ∉ used := by
      intro h
      have : s.length ≤ used.foldr (λ s m => Nat.max s.length m) 0 := by
        induction used with
        | nil => contradiction
