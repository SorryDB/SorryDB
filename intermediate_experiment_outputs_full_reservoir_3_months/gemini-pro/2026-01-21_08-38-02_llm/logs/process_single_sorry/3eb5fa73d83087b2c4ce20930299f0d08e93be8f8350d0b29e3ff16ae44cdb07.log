namespace FinEnv

@[simp]
def toEnv {Ident Typ} [DecidableEq Typ] (ε : FinEnv Ident Typ) : Env Ident Typ := ε.find?

theorem exists_fresh {Ident} {ε : FinEnv Ident (String × String)} {a : List String}
  : ∃ (b : List String), a.length = b.length ∧ (∀ a' b', (a', b') ∈ a.zip b → ¬ ε.contains (a', b')) ∧ (a.zip b).Nodup := by
  induction a with
  | nil => exact ⟨[], rfl, by simp, List.nodup_nil⟩
  | cons h t ih =>
    obtain ⟨bt, hlen, hfree, hnodup⟩ := ih
    let used := bt ++ ε.toList.map (Prod.snd ∘ Prod.fst)
    let max_len := used.foldr (λ s n => max s.length n) 0
    let s := String.mk (List.replicate (max_len + 1) 'x')
    have s_fresh : s ∉ used := by
      intro h
      have : s.length ≤ max_len := by
        induction used with
        | nil => contradiction
        | cons x xs ih_u =>
          cases h with
          | head => apply Nat.le_max_left
          | tail _ h => exact Nat.le_trans (ih_u h) (Nat.le_max_right _ _)
      have : s.length = max_len + 1 := by simp [s, List.length_replicate]
      rw [this] at *
      exact Nat.not_succ_le_self _ (by assumption)
    refine ⟨s :: bt, by simp [hlen], ?_, ?_⟩
    · intro a' b' h
      cases h with
      | head =>
        simp only
        intro hcon
        apply s_fresh
        apply List.mem_append_of_mem_right
        have : (h, s).2 ∈ ε.toList.map (Prod.snd ∘ Prod.fst) := by
          induction ε generalizing h s with
          | nil => simp [Batteries.AssocList.contains] at hcon
          | cons k v tail ih_ε =>
            simp [Batteries.AssocList.contains] at hcon
            split at hcon
            · simp_all; exact List.mem_cons_self _ _
            · exact List.mem_cons_of_mem _ (ih_ε hcon)
        exact this
      | tail _ h => exact hfree _ _ h
    · rw [List.zip_cons_cons, List.nodup_cons]
      refine ⟨?_, hnodup⟩
      intro hin
      apply s_fresh
      apply List.mem_append_of_mem_left
      let rec mem_snd {α β} {x : α × β} {l1 : List α} {l2 : List β} (h : x ∈ l1.zip l2) : x.2 ∈ l2 := by
         match l1, l2, h with
         | _ :: _, _ :: _, List.Mem.head .. => exact List.mem_cons_self _ _
         | _ :: _, _ :: _, List.Mem.tail _ h' => exact List.mem_cons_of_mem _ (mem_snd h')
      exact mem_snd hin
