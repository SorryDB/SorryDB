  mem_support_selectElem x := by sorry --rw [mem_support_eqRec_iff]; simp
  probOutput_selectElem_eq x y := by
    cases n
    · have := NeZero.ne 0; contradiction
    · simp
      apply SampleableType.probOutput_selectElem_eq
