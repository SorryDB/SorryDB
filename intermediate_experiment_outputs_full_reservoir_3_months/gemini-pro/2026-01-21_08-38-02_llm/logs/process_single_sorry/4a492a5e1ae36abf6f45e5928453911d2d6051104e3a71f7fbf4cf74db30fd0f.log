      "\n      let counts (I : Fin m ‚Üí őĻ √ó őĻ) (i : őĻ) := #{k | (I k).1 = i} + #{k | (I k).2 = i}\n      rw [‚Üź Finset.sum_fiberwise_of_maps_to (fun I ‚Ü¶ counts I) (piAntidiag A (2 * m))]\n      ¬∑ refine Finset.sum_congr rfl fun w hw ‚Ü¶ ?_\n        rw [Finset.sum_const, nsmul_eq_mul]\n        congr 1\n        let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (Fin (2 * m) ‚Üí őĻ) :=\n          (Equiv.piProdEquivProdPi (fun _ ‚Ü¶ őĻ) (fun _ ‚Ü¶ őĻ)).trans\n            ((Equiv.sumArrowEquivProdArrow _ _ _).symm.trans\n              (Equiv.piCongrLeft _ Equiv.finSumFinEquiv))\n        rw [‚Üź card_piFinset_const_of_count_eq_multinomial A _ w hw, ‚Üź Finset.card_map e]\n        refine Finset.card_congr (fun I _ ‚Ü¶ e I) (fun I hI ‚Ü¶ ?_) (fun I _ ‚Ü¶ e I) (fun I _ ‚Ü¶ e I)\n        ¬∑ simp only [mem_filter, mem_piFinset] at hI ‚äĘ\n          simp only [counts, count, e, Equiv.trans_apply, Equiv.piProdEquivProdPi_apply,\n            Equiv.sumArrowEquivProdArrow_symm_apply_inl,\n            Equiv.sumArrowEquivProdArrow_symm_apply_inr, Equiv.piCongrLeft_apply,\n            Equiv.finSumFinEquiv_apply_left, Equiv.finSumFinEquiv_apply_right,\n            ‚Üź card_sum_eq_card_inl_add_card_inr] at hI ‚äĘ\n          exact hI\n        ¬∑ intro; simp\n        ¬∑ intro; simp\n        ¬∑ intro f hf\n          simp only [mem_filter, mem_piFinset, mem_map, exists_exists_and_eq_and] at hf ‚äĘ\n          use e.symm f\n          simp only [counts, count, e, Equiv.symm_apply_apply, Equiv.trans_apply,\n            Equiv.piProdEquivProdPi_apply, Equiv.sumArrowEquivProdArrow_symm_apply_inl,\n            Equiv.sumArrowEquivProdArrow_symm_apply_inr, Equiv.piCongrLeft_apply,\n            Equiv.finSumFinEquiv_apply_left, Equiv.finSumFinEquiv_apply_right,\n            ‚Üź card_sum_eq_card_inl_add_card_inr] at hf ‚äĘ\n          exact hf\n      ¬∑ intro I hI\n        simp only [mem_piFinset, mem_product] at hI\n        rw [mem_piAntidiag]\n        refine ‚ü®fun i hi ‚Ü¶ ?_, ?_‚ü©\n        ¬∑ simp only [coun