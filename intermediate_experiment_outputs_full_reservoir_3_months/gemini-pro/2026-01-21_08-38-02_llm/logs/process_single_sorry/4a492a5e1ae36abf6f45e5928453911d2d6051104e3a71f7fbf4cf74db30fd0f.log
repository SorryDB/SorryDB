      "\n      let Ōą (I : Fin m ‚Üí őĻ √ó őĻ) (i : őĻ) := #{k | (I k).1 = i} + #{k | (I k).2 = i}\n      rw [‚Üź sum_fiberwise_of_maps_to (fun I ‚Ü¶ Ōą I) (A √óňĘ A ^^ m)]\n      ¬∑ refine sum_congr rfl fun w hw ‚Ü¶ ?_\n        rw [sum_filter, sum_filter]\n        split_ifs with h_even\n        ¬∑ rw [sum_const, nsmul_eq_mul]\n          congr 1\n          -- We show that the number of I with counts w is multinomial A w.\n          -- We construct a bijection to functions Fin (2*m) ‚Üí A.\n          let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (Fin (2 * m) ‚Üí őĻ) :=\n            Equiv.trans (Equiv.piCurry (fun _ ‚Ü¶ őĻ) (Fin m) (Fin 2))\n              (Equiv.piCongrLeft (fun _ ‚Ü¶ őĻ) (finProdFinEquiv (Fin m) (Fin 2)))\n          rw [‚Üź card_filter_piFinset_sum_eq_multinomial A _ _ (mem_piAntidiag.1 hw)]\n          rw [‚Üź card_map e, map_filter]\n          congr 1\n          ext f\n          simp only [mem_map, mem_piFinset, mem_filter, and_congr_right_iff]\n          intro hf\n          -- The bijection e preserves the counts.\n          simp only [Ōą, e, Equiv.trans_apply, Equiv.piCurry_apply, Equiv.piCongrLeft_apply,\n            Fintype.card, Fintype.sum_prod_type]\n          rfl\n        ¬∑ rw [sum_empty, sum_empty]\n      ¬∑ intro I hI\n        rw [mem_piAntidiag]\n        simp_rw [Ōą, sum_add_distrib]\n        rw [‚Üź card_eq_sum_ones, ‚Üź card_eq_sum_ones]\n        simp only [mem_piFinset, mem_product] at hI\n        trans (Finset.univ.filter (fun k ‚Ü¶ (I k).1 ‚ąą A)).card + (Finset.univ.filter (fun k ‚Ü¶ (I k).2 ‚ąą A)).card\n        ¬∑ congr 1 <;> rw [card_eq_sum_ones, sum_filter] <;> apply sum_congr rfl <;> intro x _ <;>\n          rw [sum_comm] <;> simp\n        ¬∑ rw [filter_true_of_mem (fun k ‚Ü¶ (hI k).1), filter_true_of_mem (fun k ‚Ü¶ (hI k).2), card_fin, card_fin]\n          rfl",
      "\n      let count (I : Fin m ‚Üí őĻ √ó őĻ) (i : őĻ) := #{k | (I k).1 = i} + #{k | (I k).2 = i}\n      rw [‚Üź Finset.sum_fiberwise_of_maps_to (fun I ‚Ü¶ count I)]\n      ¬∑ congr 1\n        refine Finset.sum_congr rfl fun w hw ‚Ü¶ ?_\n        rw [Finset.sum_const, nsmul_eq_mul]\n        congr 1\n        let K := Fin m √ó Fin 2\n        let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (K ‚Üí őĻ) :=\n        { toFun := fun I x ‚Ü¶ if x.2 = 0 then (I x.1).1 else (I x.1).2\n          invFun := fun f k ‚Ü¶ (f (k, 0), f (k, 1))\n          left_inv := fun I ‚Ü¶ by ext k; simp\n          right_inv := fun f ‚Ü¶ by ext ‚ü®k, i‚ü©; cases i using Fin.cases <;> simp }\n        have h_bij : (A √óňĘ A ^^ m).map e.toEmbedding = Fintype.piFinset fun _ : K ‚Ü¶ A := by\n          ext f\n          simp only [mem_map_equiv, mem_piFinset, mem_product, K]\n          constructor\n          ¬∑ rintro ‚ü®I, hI, rfl‚ü© x\n            specialize hI x.1\n            simp only [mem_product] at hI\n            split_ifs <;> tauto\n          ¬∑ intro hf\n            refine ‚ü®e.symm f, ?_, e.apply_symm_apply f‚ü©\n            intro k\n            simp only [e, mem_product]\n            exact ‚ü®hf (k, 0), hf (k, 1)‚ü©\n        rw [‚Üź Finset.card_map e.toEmbedding, h_bij]\n        convert card_filter_piFinset_const_eq_multinomial A w _ using 2\n        ¬∑ refine Finset.card_congr (Equiv.refl _) ?_\n          intro f hf\n          simp only [mem_piFinset, mem_filter, Equiv.refl_apply] at hf ‚äĘ\n          congr! 1\n          ext i\n          simp only [count, e, K]\n          rw [‚Üź Finset.sum_boole, ‚Üź Finset.sum_boole, ‚Üź Finset.sum_boole]\n          simp only [Fintype.sum_prod_type, Fin.sum_univ_two, if_true, if_false]\n        ¬∑ simp [K, mul_comm]; exact (mem_piAntidiag.1 hw).1\n      ¬∑ intro I hI\n        simp only [mem_piAntidiag]\n        refine ‚ü®?_, ?_‚ü©\n        ¬∑ simp only [count, sum_add_distrib]\n          rw [sum_card_fiberwise, sum_card_fiberwise]\n          simp [mul_comm]\n        ¬∑ simpa [EvenIndex, count] using (mem_filter.1 hI).2",
      "\n      rw [‚Üź (Equiv.piProdEquiv (fun _ ‚Ü¶ őĻ) (fun _ ‚Ü¶ őĻ)).sum_comp,\n          ‚Üź (Equiv.sumArrowEquivProdArrow _ _ _).symm.sum_comp,\n          ‚Üź (finSumFinEquiv (m := m) (n := m)).sum_comp,\n          ‚Üź (finCongr (two_mul m).symm).sum_comp]\n      let count (f : Fin (2 * m) ‚Üí őĻ) (i : őĻ) := #{k | f k = i}\n      have h_maps : ‚ąÄ f ‚ąą A ^^ (2 * m), count f ‚ąą piAntidiag A (2 * m) := fun f hf ‚Ü¶ by\n        rw [mem_piAntidiag]\n        exact ‚ü®by simp [count, sum_card_fiberwise], fun i hi ‚Ü¶\n          by rw [count, card_eq_zero, filter_eq_empty_iff]; intro x hx; exact hi (mem_piFinset.1 hf x)‚ü©\n      rw [‚Üź Finset.sum_fiberwise_of_maps_to (fun f _ ‚Ü¶ h_maps f) _]\n      refine Finset.sum_bij_ne_zero (fun w _ _ ‚Ü¶ w) (fun _ _ _ ‚Ü¶ rfl)\n        (fun _ _ _ _ _ ‚Ü¶ rfl) (fun _ _ _ ‚Ü¶ rfl) (fun w hw hnz ‚Ü¶ ?_)\n      ¬∑ rw [mem_filter] at hw\n        have heven : ‚ąÄ i ‚ąą A, 2 ‚ą£ w i := by\n          contrapose! hnz\n          exact Finset.sum_eq_zero fun f hf ‚Ü¶ (hnz (hf.2 _ (hw.2 _))).elim\n        simp only [heven, and_true, Finset.sum_const, nsmul_eq_mul]\n        congr 1\n        rw [‚Üź card_piFinset_sum_eq_multinomial A w, Finset.filter_congr]\n        ¬∑ intro f hf; simp only [mem_filter] at hf; rw [hf.2]\n          simp only [heven, true_and]; rfl\n        ¬∑ exact (mem_piAntidiag.1 hw.1).1.symm",
      "\n      let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (Fin (2 * m) ‚Üí őĻ) :=\n        (Equiv.piCongrRight (fun _ ‚Ü¶ (finTwoArrowEquiv (fun _ ‚Ü¶ őĻ)).symm)).trans <|\n        (Equiv.piCurry _ _ _).trans <|\n        (finProdFinEquiv m 2).arrowCongr (Equiv.refl őĻ)\n      rw [Finset.sum_equiv e]\n      ¬∑ let counts (f : Fin (2 * m) ‚Üí őĻ) i := (A ^^ (2 * m)).count f i\n        rw [‚Üź Finset.sum_fiberwise_of_maps_to (fun f ‚Ü¶ counts f) (piAntidiag A (2 * m))]\n        ¬∑ refine Finset.sum_congr rfl fun w hw ‚Ü¶ ?_\n          by_cases h_even : ‚ąÄ i ‚ąą A, 2 ‚ą£ w i\n          ¬∑ rw [Finset.sum_filter_of_true, Finset.sum_const, nsmul_eq_mul]\n            ¬∑ rw [card_filter_piFinset_eq_multinomial _ _ _ (mem_piAntidiag.1 hw)]\n            ¬∑ intro f hf i hi; rw [mem_filter] at hf; rw [‚Üź hf.2]; exact h_even i hi\n          ¬∑ rw [Finset.sum_filter_of_false]; simp; intro f hf; contrapose! h_even\n            obtain ‚ü®i, hi, h‚ü© := h_even; use i, hi; rw [‚Üź hf.2] at h; exact h\n        ¬∑ intro f hf; rw [mem_piAntidiag]; simp only [mem_piFinset] at hf\n          exact Finset.card_eq_sum_ones _\n      ¬∑ intro I; simp [e, mem_piFinset, mem_product, forall_and]\n        constructor\n        ¬∑ rintro ‚ü®h1, h2‚ü© x; have := finProdFinEquiv m 2 x; revert this\n          match x with | ‚ü®k, 0‚ü© => exact h1 k | ‚ü®k, 1‚ü© => exact h2 k\n        ¬∑ intro h; constructor <;> intro k <;> apply h\n      ¬∑ intro I; simp [e, EvenIndex]; congr! 2 with i\n        simp [Pi.count, ‚Üź Finset.card_sum]\n        rw [Finset.sum_equiv (finProdFinEquiv m 2).symm]\n        simp [Finset.filter_eq', ‚Üź Finset.sum_filter, Finset.sum_add_distrib]",
      "\n      let e : (Fin (2 * m) ‚Üí őĻ) ‚ČÉ (Fin m ‚Üí őĻ √ó őĻ) :=\n        (Equiv.piCongrLeft (fun _ ‚Ü¶ őĻ) Fin.finSumFinEquiv).trans\n          ((Equiv.sumArrowEquivProdArrow _ _ _).trans (Equiv.arrowProdEquivProdArrow _ _ _ _))\n      have h_count : ‚ąÄ f i, #{k | (e f k).1 = i} + #{k | (e f k).2 = i} = count f i := by\n        intro f i\n        simp only [count, e, Equiv.trans_apply, Equiv.arrowProdEquivProdArrow_apply,\n          Equiv.sumArrowEquivProdArrow_apply, Equiv.piCongrLeft_apply, Sum.elim_apply]\n        rw [‚Üź Fintype.card_sum, ‚Üź Fintype.card_congr Fin.finSumFinEquiv]\n        simp only [Equiv.apply_symm_apply]\n      rw [‚Üź Finset.sum_equiv e]\n      ¬∑ simp only [mem_piAntidiag]\n        rw [Finset.sum_fiberwise_of_maps_to (fun f i ‚Ü¶ count f i) (piAntidiag A (2 * m))]\n        ¬∑ refine Finset.sum_congr rfl fun w hw ‚Ü¶ ?_\n          simp only [mem_filter, mem_piAntidiag] at hw\n          rw [Finset.sum_const, ‚Üź card_filter_count_eq_multinomial A _ w hw.1, Nat.cast_natCast]\n          congr 1\n          refine Finset.filter_congr fun f hf ‚Ü¶ ?_\n          simp only [h_count]\n          exact ‚ü®fun h ‚Ü¶ h.2, fun h ‚Ü¶ ‚ü®fun i ‚Ü¶ by rw [h]; exact (mem_filter.mp hw).1 i, h‚ü©‚ü©\n        ¬∑ intro f hf\n          rw [mem_piAntidiag]\n          exact ‚ü®sum_count_eq_card f, fun i h ‚Ü¶ (mem_piFinset.mp hf _ (mem_filter.mp h).1)‚ü©\n      ¬∑ intro f hf\n        simp only [mem_piFinset, mem_product] at hf ‚äĘ\n        intro k\n        simp only [e, Equiv.trans_apply, Equiv.arrowProdEquivProdArrow_apply,\n          Equiv.sumArrowEquivProdArrow_apply, Equiv.piCongrLeft_apply, Sum.elim_apply]\n        constructor <;> apply hf\n      ¬∑ intro f hf; simp only [h_count]\n      ¬∑ intro f hf; congr; ext i; rw [h_count]",
      "\n      let n := 2 * m\n      let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (Fin n ‚Üí őĻ) :=\n        (Equiv.piCongrRight (fun _ ‚Ü¶ Equiv.finTwoArrowEquiv őĻ)).trans <|\n        (Equiv.piCurry _ _ _).trans <|\n        Equiv.piCongrLeft _ (finProdFinEquiv m).symm\n      rw [‚Üź Finset.sum_equiv e]\n      ¬∑ rw [Finset.sum_fiberwise_of_maps_to (fun f i ‚Ü¶ #{k | f k = i}) (piAntidiag A n)]\n        ¬∑ apply Finset.sum_congr rfl\n          intro w hw\n          simp only [mem_piAntidiag] at hw\n          rw [Finset.sum_filter]\n          split_ifs with h_even\n          ¬∑ rw [Finset.sum_congr rfl (fun _ _ ‚Ü¶ rfl), Finset.filter_true_of_mem]\n            ¬∑ rw [Finset.sum_const, nsmul_eq_mul, multinomial_filter_piFinset_eq w]\n            ¬∑ intro f hf\n              simp only [mem_filter] at hf\n              intro i _\n              rw [‚Üź hf.2]\n              exact h_even i\n          ¬∑ rw [Finset.filter_false_of_mem, Finset.sum_empty, zero_mul]\n            intro f hf\n            simp only [mem_filter] at hf\n            intro h\n            refine h_even (fun i _ ‚Ü¶ ?_)\n            rw [‚Üź hf.2]\n            exact h i\n        ¬∑ intro f hf\n          rw [mem_piAntidiag]\n          refine ‚ü®fun i hi ‚Ü¶ ?_, ?_‚ü©\n          ¬∑ rw [‚Üź card_pos] at hi\n            exact (mem_piFinset.1 hf) _ (exists_mem_of_nonempty (nonempty_of_pos_multiset_card hi)).2\n          ¬∑ simp only [n, card_eq_sum_ones, sum_boole, Finset.sum_const, card_fin]\n      ¬∑ intro I\n        simp only [mem_piFinset, mem_product]\n        refine ‚ü®fun h k ‚Ü¶ ?_, fun h k ‚Ü¶ ?_‚ü©\n        ¬∑ let p := finProdFinEquiv m k\n          specialize h p.1\n          simp only [e, Equiv.trans_apply, Equiv.piCongrLeft_apply, Equiv.symm_apply_apply,\n            Equiv.piCurry_apply, Equiv.piCongrRight_apply, Equiv.finTwoArrowEquiv_apply]\n          rcases p with ‚ü®k, a | a‚ü© <;> simpa using h\n        ¬∑ simp only [e, Equiv.trans_apply, Equiv.piCongrLeft_apply, Equiv.piCurry_apply,\n            Equiv.piCongrRight_apply, Equiv.finTwoArrowEquiv_apply] at h \n          exact ‚ü®h _, h _‚ü©\n      ¬∑ intro I hI\n        dsimp\n        congr 1\n        ¬∑ simp only [EvenIndex]\n          congr! 2 with i\n          simp only [e, Equiv.trans_apply, Equiv.piCongrLeft_apply, Equiv.piCurry_apply,\n            Equiv.piCongrRight_apply, Equiv.finTwoArrowEquiv_apply]\n          rw [‚Üź card_sum, ‚Üź Finset.univ_product_univ, ‚Üź Fin.univ_pi_univ_eq_univ]\n          exact card_congr (finProdFinEquiv m).symm\n        ¬∑ congr! 2 with i\n          simp only [e, Equiv.trans_apply, Equiv.piCongrLeft_apply, Equiv.piCurry_apply,\n            Equiv.piCongrRight_apply, Equiv.finTwoArrowEquiv_apply]\n          rw [‚Üź card_sum, ‚Üź Finset.univ_product_univ, ‚Üź Fin.univ_pi_univ_eq_univ]\n          exact card_congr (finProdFinEquiv m).symm",
      "\n      have : DecidableEq (őĻ ‚Üí ‚Ąē) := Classical.decEq _\n      let key (I : Fin m ‚Üí őĻ √ó őĻ) (i : őĻ) := #{k | (I k).1 = i} + #{k | (I k).2 = i}\n      rw [‚Üź sum_fiberwise_of_maps_to key ((piAntidiag A (2 * m)).filter fun w ‚Ü¶ ‚ąÄ i ‚ąą A, 2 ‚ą£ w i)]\n      ¬∑ refine Finset.sum_congr rfl fun w H ‚Ü¶ ?_\n        rw [sum_const, nsmul_eq_mul]\n        congr 1\n        let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (Fin (2 * m) ‚Üí őĻ) :=\n          (Equiv.piProd _ _ _).trans <| (Equiv.sumArrowEquivProdArrow _ _ _).symm.trans <|\n          Equiv.piCongrLeft' _ finSumFinEquiv\n        have h_count (I : Fin m ‚Üí őĻ √ó őĻ) (i : őĻ) : #{k | e I k = i} = key I i := by\n          simp only [key, e, Equiv.trans_apply, Equiv.piProd_apply,\n            Equiv.sumArrowEquivProdArrow_symm_apply, Equiv.piCongrLeft'_apply]\n          rw [‚Üź Fintype.card_congr finSumFinEquiv, Fintype.card_sum]\n          congr 1 <;> { apply Fintype.card_congr; refine Equiv.Set.ofEq ?_; ext; simp }\n        have h_mem (I : Fin m ‚Üí őĻ √ó őĻ) : (‚ąÄ k, e I k ‚ąą A) ‚ÜĒ I ‚ąą A √óňĘ A ^^ m := by\n          simp_rw [mem_piFinset, mem_product, Equiv.forall_congr_left, Sum.forall, forall_and]\n        rw [‚Üź card_piFinset_card_eq_multinomial A _ w (mem_piAntidiag.1 (mem_filter.1 H).1).1]\n        apply Fintype.card_congr\n        refine (e.subtypeEquiv ?_).trans ?_\n        ¬∑ exact fun I ‚Ü¶ by rw [h_mem, ‚Üź h_count]; rfl\n        ¬∑ exact Equiv.Set.ofEq (by ext; simp)\n      ¬∑ intro I hI\n        simp only [mem_filter, mem_piFinset, mem_product, forall_and] at hI \n        rw [mem_filter, mem_piAntidiag]\n        refine ‚ü®‚ü®?_, fun i ‚Ü¶ ?_‚ü©, hI.2‚ü©\n        ¬∑ rw [‚Üź Fintype.card_eq_sum_card_fiberwise (fun k ‚Ü¶ (I k).1) _ (fun k ‚Ü¶ (hI.1 k).1),\n              ‚Üź Fintype.card_eq_sum_card_fiberwise (fun k ‚Ü¶ (I k).2) _ (fun k ‚Ü¶ (hI.1 k).2)]\n          simp [key, sum_add_distrib, two_mul]\n        ¬∑ rw [Function.mem_support, ne_eq, ‚Üź pos_iff_ne_zero]\n          intro h_pos\n          simp [key] at h_pos\n          obtain ‚ü®k, rfl‚ü© | ‚ü®k, rfl‚ü© := by simpa [pos_iff_ne_zero] using h_pos\n          ¬∑ exact (hI.1 k).1\n          ¬∑ exact (hI.1 k).2",
      "\n      let n := 2 * m\n      let signs := Fintype.piFinset fun _ : A ‚Ü¶ ({-1, 1} : Finset ‚ĄĚ)\n      have sum_signs (f : A ‚Üí ‚ĄĚ) :\n          ‚ąĎ őĶ ‚ąą signs, (‚ąĎ i ‚ąą A, őĶ i * f i) ^ n =\n            signs.card * ‚ąĎ w ‚ąą piAntidiag A n with ‚ąÄ i ‚ąą A, Even (w i),\n              multinomial A w * ‚ąŹ i ‚ąą A, f i ^ w i := by\n        simp_rw [sum_pow, mul_pow, sum_comm (s := signs), mul_sum]\n        refine sum_congr rfl fun w hw ‚Ü¶ ?_\n        rw [‚Üź mul_assoc, mul_right_comm, mul_right_inj' (by positivity)]\n        simp_rw [prod_mul_distrib, prod_pow, sum_product, univ_eq_attach, ‚Üź prod_sum]\n        convert_to (‚ąŹ i ‚ąą A, if Even (w i) then 2 else 0) * _ = _\n        ¬∑ congr with i; simp [mem_attach, sum_pair, neg_pow, one_pow]; split_ifs <;> simp_all [even_iff_not_odd]\n        ¬∑ rw [prod_ite, prod_const, prod_const, prod_eq_zero_iff]\n          simp only [mem_filter, not_and, not_forall, exists_prop]\n          by_cases h : ‚ąÄ i ‚ąą A, Even (w i)\n          ¬∑ simp [h, card_attach, filter_eq_self.2 h, signs, card_piFinset]\n          ¬∑ simp [h]\n      have LHS_eq :\n          ‚ąĎ őĶ ‚ąą signs, ‚ąę ŌČ, (‚ąĎ i ‚ąą A, őĶ i * ‚ÄĖX i ŌČ‚ÄĖ) ^ n ‚ąāőľ =\n            signs.card * ‚ąĎ I ‚ąą A √óňĘ A ^^ m with EvenIndex I,\n              ‚ąę ŌČ, ‚ąŹ i ‚ąą A, ‚ÄĖX i ŌČ‚ÄĖ ^ (#{k | (I k).1 = i} + #{k | (I k).2 = i}) ‚ąāőľ := by\n        simp_rw [integral_sum signs, ‚Üź Finset.sum_pow', integral_finset_sum _ integrable_prod_norm_X,\n          sum_comm (s := signs), ‚Üź mul_sum]\n        refine sum_congr rfl fun I hI ‚Ü¶ ?_\n        congr 1\n        simp_rw [prod_mul_distrib, prod_pow, sum_product, univ_eq_attach, ‚Üź prod_sum]\n        convert_to (‚ąŹ i ‚ąą A, if Even (#{k | (I k).1 = i} + #{k | (I k).2 = i}) then 2 else 0) = _\n        ¬∑ congr with i; simp [mem_attach, sum_pair, neg_pow, one_pow]; split_ifs <;> simp_all [even_iff_not_odd]\n        ¬∑ rw [prod_ite, prod_const, prod_const]; by_cases h : EvenIndex I\n          ¬∑ simp [h, car