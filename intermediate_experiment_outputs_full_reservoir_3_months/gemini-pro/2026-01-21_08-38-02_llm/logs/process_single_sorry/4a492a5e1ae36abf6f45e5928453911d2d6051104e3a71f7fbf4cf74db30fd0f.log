      "\n      let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (Fin (2 * m) ‚Üí őĻ) :=\n        (Equiv.piProd _ _ _).trans <| Equiv.piSumProd.symm.trans <|\n        Equiv.piCongrLeft' _ (finSumFinEquiv.trans (finCongr (two_mul m).symm))\n      rw [Finset.sum_equiv e]\n      ¬∑ rw [‚Üź Finset.sum_fiberwise_of_maps_to (fun f ‚Ü¶ count f) (piAntidiag A (2 * m))]\n        ¬∑ refine Finset.sum_congr rfl fun w hw ‚Ü¶ ?_\n          rw [mem_piAntidiag] at hw\n          split_ifs with h_even\n          ¬∑ simp_rw [sum_const, nsmul_eq_mul]\n            rw [card_filter_piFinset_eq_multinomial _ _ hw.1]\n          ¬∑ refine sum_empty fun f hf ‚Ü¶ ?_\n            simp only [mem_filter] at hf\n            apply h_even\n            rw [‚Üź hf.1]\n            exact hf.2\n        ¬∑ intro f hf\n          rw [mem_piAntidiag]\n          refine ‚ü®?_, fun i hi ‚Ü¶ ?_‚ü©\n          ¬∑ rw [sum_count, ‚Üź Finset.card_piFinset_const, Fintype.card_fin]\n          ¬∑ simp only [mem_piFinset] at hf\n            contrapose! hi\n            rw [count_eq_zero]\n            intro x\n            exact fun h => hi (h ‚Ėł hf x)\n      ¬∑ intro I\n        simp only [mem_piFinset, mem_product, e, Equiv.trans_apply, Equiv.piProd_apply,\n          Equiv.piSumProd_symm_apply, Equiv.piCongrLeft'_apply, finSumFinEquiv_apply,\n          finCongr_apply, Sum.elim_comp_cast]\n        simp only [Sum.elim_lam_const_lam_const, comp_apply]\n        simp only [forall_and]\n        refine ‚ü®fun h x ‚Ü¶ ?_, fun h ‚Ü¶ ‚ü®fun k ‚Ü¶ ?_, fun k ‚Ü¶ ?_‚ü©‚ü©\n        ¬∑ obtain ‚ü®k, rfl‚ü© | ‚ü®k, rfl‚ü© := finSumFinEquiv.symm.surjective (finCongr (two_mul m) x) <;>\n            simp [h]\n        ¬∑ simpa using h (finCongr (two_mul m).symm (finSumFinEquiv (Sum.inl k)))\n        ¬∑ simpa using h (finCongr (two_mul m).symm (finSumFinEquiv (Sum.inr k)))\n      ¬∑ intro I hI\n        dsimp [EvenIndex]\n        congr! with i\n        simp only [count, e, Equiv.trans_apply, Equiv.piProd_apply,\n          Equiv.piSumProd_symm_apply, Equiv.piCongrLeft'_apply, finSumFinEquiv_apply,\n          finCongr_apply, Sum.elim_comp_cast, Sum.elim_lam_const_lam_const, comp_apply]\n        -- key I i = count (e I) i\n        rw [‚Üź card_sum_fiberwise_eq_card_univ, univ_sum_type, card_sum,\n          filter_sum, card_map, card_map]\n        rfl\n      ¬∑ rfl",
      "\n      let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (Fin (2 * m) ‚Üí őĻ) :=\n        (Equiv.finProdFinEquiv m).symm.trans (Equiv.piCurry _ _ _).symm\n      rw [‚Üź (e.piCongrLeft (fun _ ‚Ü¶ A)).sum_comp]\n      simp_rw [‚Üź Finset.sum_fiberwise_of_maps_to (fun f ‚Ü¶ count f) (fun f hf ‚Ü¶ mem_piAntidiag.2 ‚ü®hf, rfl‚ü©)]\n      refine Finset.sum_congr rfl fun w hw ‚Ü¶ ?_\n      rw [mem_piAntidiag] at hw\n      split_ifs with h\n      ¬∑ rw [Finset.sum_filter, Finset.sum_const, Finset.card_piFinset_const_of_count _ _ _ hw.1]\n        ¬∑ congr 1 with ŌČ\n          rw [prod_fiberwise_of_maps_to (fun _ _ ‚Ü¶ _) (by simpa using hw.1)]\n        ¬∑ intro f hf\n          simp only [mem_filter] at hf\n          simp only [EvenIndex, e, Equiv.trans_symm, Equiv.symm_symm, Equiv.piCurry_apply,\n            Equiv.finProdFinEquiv_symm_apply, count]\n          convert h using 2 with i\n          rw [‚Üź hf.2]\n          simp only [Fintype.card_ofFinset, mem_filter, Finset.mem_univ, true_and]\n          apply Fintype.card_congr\n          exact (Equiv.finProdFinEquiv m).trans (Equiv.piCurry _ _ _)\n      ¬∑ apply Finset.sum_empty\n        intro f hf\n        simp only [mem_filter, EvenIndex, e, Equiv.trans_symm, Equiv.symm_symm,\n            Equiv.piCurry_apply, Equiv.finProdFinEquiv_symm_apply, count] at hf\n        apply h\n        intro i hi\n        rw [‚Üź hf.1.2]\n        convert hf.2 i hi\n        simp only [Fintype.card_ofFinset, mem_filter, Finset.mem_univ, true_and]\n        apply Fintype.card_congr\n        exact (Equiv.finProdFinEquiv m).trans (Equiv.piCurry _ _ _)",
      "\n      rw [Finset.sum_integral]\n      congr with ŌČ\n      let e : (Fin m ‚Üí őĻ √ó őĻ) ‚ČÉ (Fin m ‚äē Fin m ‚Üí őĻ) :=\n        { toFun := fun I x ‚Ü¶ Sum.recOn x (fun k ‚Ü¶ (I k).1) (fun k ‚Ü¶ (I k).2)\n          invFun := fun f k ‚Ü¶ (f (Sum.inl k), f (Sum.inr k))\n          left_inv := fun I ‚Ü¶ by ext k; simp\n          right_inv := fun f ‚Ü¶ by ext x; cases x <;> simp }\n      rw [‚Üź Finset.sum_equiv e (fun f i ‚Ü¶ #{x | f x = i}) (fun I ‚Ü¶ by simp) (fun I ‚Ü¶ by simp)]\n      ¬∑ rw [‚Üź Finset.sum_fiberwise_of_maps_to (fun f i ‚Ü¶ #{x | f x = i}) (piAntidiag A (2 * m))]\n        ¬∑ congr with w\n          rw [Finset.sum_const, nsmul_eq_mul]\n          congr 1\n          convert Finset.card_filter_piFinset_const_eq_multinomial A w (mem_piAntidiag.mp w.2) using 1\n          rw [Fintype.card_sum, Fintype.card_fin]\n        ¬∑ intro f hf\n          rw [mem_piAntidiag, Fintype.card_sum, Fintype.card_fin]\n          exact sum_card_fiber_eq _ _\n      ¬∑ intro I\n        congr! with i\n        simp only [e, Finset.univ_sum_type, Finset.filter_sum, Finset.card_disjoint_union,\n          Finset.card_map, Function.Embedding.coeFn_mk]",
      "\n      rw [Finset.sum_equiv Equiv.piProdEquiv]\n      ¬∑ let e : (Fin (2 * m) ‚Üí őĻ) ‚ČÉ (Fin m ‚Üí őĻ) √ó (Fin m ‚Üí őĻ) :=\n          (Equiv.arrowCongr Fin.finSumFinEquiv (Equiv.refl őĻ)).trans (Equiv.sumArrowEquivProdArrow _ _ _)\n        rw [Finset.sum_equiv e.symm]\n        ¬∑ rw [Finset.sum_fiberwise_of_maps_to (fun f ‚Ü¶ fun i ‚Ü¶ #{k | f k = i}) _]\n          ¬∑ refine Finset.sum_congr rfl fun w hw ‚Ü¶ ?_\n            simp only [mem_piAntidiag] at hw\n            rw [Finset.sum_filter]\n            split_ifs with h_even\n            ¬∑ rw [Finset.sum_const, nsmul_eq_mul, Finset.card_piFinset_filter_count_eq_multinomial]\n              ¬∑ intro i hi; exact hw.1 _ hi\n              ¬∑ rw [‚Üź hw.2, two_mul]\n            ¬∑ refine (Finset.sum_eq_zero fun f hf ‚Ü¶ ?_).symm\n              simp only [mem_filter, mem_piFinset] at hf\n              obtain ‚ü®i, hi, h_odd‚ü© : ‚ąÉ i ‚ąą A, Odd (w i) := by\n                simpa [EvenIndex, -not_forall] using h_even\n              have := hf.2 i hi\n              rw [hf.1] at this\n              exact (Nat.odd_iff_not_even.mp h_odd this).elim\n          ¬∑ intro f hf\n            simp only [mem_filter, mem_piFinset] at hf\n            simp only [mem_piAntidiag]\n            refine ‚ü®fun i hi ‚Ü¶ (count_eq_zero_of_not_mem (mt (hf.1 ¬∑) (not_mem_of_mem_not_mem ¬∑ hi))).symm, ?_‚ü©\n            rw [sum_card_filter_eq_card_pi, Fintype.card_fin]\n        ¬∑ intro f\n          simp only [mem_piFinset, Equiv.symm_apply_apply, Sum.forall, Equiv.sumArrowEquivProdArrow_apply,\n            Equiv.arrowCongr_apply, Fin.finSumFinEquiv_symm_apply]\n        ¬∑ intro x hx\n          simp only [EvenIndex, Equiv.symm_apply_apply]\n          congr! with i\n          rw [‚Üź Fintype.card_sum, ‚Üź Fintype.card_congr (Equiv.filterPreimage Fin.finSumFinEquiv _)]\n          simp only [Equiv.sumArrowEquivProdArrow_symm_apply, Equiv.arrowCongr_symm_apply,\n            Equiv.refl_symm, Equiv.refl_apply, Sum.elim_comp_inl, Sum.elim_comp