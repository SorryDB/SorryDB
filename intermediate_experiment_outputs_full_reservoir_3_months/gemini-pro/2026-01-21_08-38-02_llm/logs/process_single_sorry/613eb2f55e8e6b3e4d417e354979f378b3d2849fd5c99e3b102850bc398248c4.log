theorem longestIncreasingSubseqLength_spec_satisfied (xs: List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) :
    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  dsimp [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond]
  let subs := subsequences xs
  let allSub := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse
  
  have h_equiv_subs : ∀ s, s ∈ subs ↔ s ∈ allSub := by
    intro s
    have h_sub_iff : ∀ l s, s ∈ subsequences l ↔ s <+ l := fun l s => by
      have : subsequences l = List.subsequences l := rfl
      rw [this, List.mem_subsequences]
    rw [h_sub_iff]
    rw [List.mem_map]
    constructor
    · intro h
      refine ⟨s.reverse, ?_, s.reverse_reverse⟩
      -- Prove membership of foldl corresponds to sublist of reverse
      let f := fun acc x => acc ++ acc.map (fun sub => x :: sub)
      have h_fold : ∀ l, l.foldl f [[]] = List.subsequences l.reverse := by
        intro l; induction l with
        | nil => simp [f, List.subsequences]
        | cons x xs ih =>
          simp [f, List.reverse_cons, List.subsequences_concat, ih]
          rfl
      rw [h_fold, List.mem_subsequences, List.reverse_sublist_iff]
      exact h
    · rintro ⟨a, h, rfl⟩
      let f := fun acc x => acc ++ acc.map (fun sub => x :: sub)
      have h_fold : ∀ l, l.foldl f [[]] = List.subsequences l.reverse := by
        intro l; induction l with
        | nil => simp [f, List.subsequences]
        | cons x xs ih => simp [f, List.reverse_cons, List.subsequences_concat, ih]; rfl
      rw [h_fold, List.mem_subsequences, List.reverse_sublist_iff] at h
      exact h

  have h_equiv_pred : ∀ s, isStrictlyIncreasing s ↔ s.Pairwise (· < ·) := by
    intro s
    induction s with
    | nil => simp [isStrictlyIncreasing]
    | cons x xs ih =>
      cases xs with
      | nil => simp [isStrictlyIncreasing]
      | cons y ys =>
        simp only [isStrictlyIncreasing, Bool.if_true_eq_true, Bool.if_false_eq_false,
          List.pairwise_cons, beq_iff_eq]
        split
        next hlt =>
          rw [ih]
          constructor
          · intro h; exact ⟨fun z hz => lt_of_lt_of_le hlt (List.le_of_sorted_cons h z hz), h⟩
          · intro h; exact h.2
        next hge =>
          simp; intro h; exact (hge (h.1 y (List.mem_cons_self _ _))).elim

  let lens1 := subs.filter isStrictlyIncreasing |>.map List.length
  let lens2 := allSub.filter (fun l => l.Pairwise (· < ·)) |>.map List.length
  
  have h_lens_eq : ∀ n, n ∈ lens1 ↔ n ∈ lens2 := by
    intro n
    simp only [List.mem_map, List.mem_filter]
    constructor
    · rintro ⟨s, ⟨hs1, hs2⟩, rfl⟩
      refine ⟨s, ⟨h_equiv_subs s |>.1 hs1, (h_equiv_pred s).1 hs2⟩, rfl⟩
    · rintro ⟨s, ⟨hs1, hs2⟩, rfl⟩
      refine ⟨s, ⟨h_equiv_subs s |>.2 hs1, (h_equiv_pred s).2 hs2⟩, rfl⟩

  -- Result is foldl max 0 lens1
  -- We need result ∈ lens2 ∧ ∀ y ∈ lens2, y ≤ result
  -- This is equivalent to result being the maximum of lens2 (which is essentially lens1)
  let result := lens1.foldl max 0
  
  have h_nonempty : 0 ∈ lens1 := by
    rw [List.mem_map]
    exists []
    simp [subsequences, isStrictlyIncreasing]

  have h_res_max : result ∈ lens1 ∧ ∀ x ∈ lens1, x ≤ result := by
    have : result = (0 :: lens1).foldl max 0 := rfl -- 0 is neutral, effectively
    -- Actually foldl max 0 lens1 is max of (0 :: lens1)
    rw [List.foldl_max]
    constructor
    · apply List.max_mem_of_mem; simp [h_nonempty]
    · intro x hx; apply List.le_max_of_mem; simp [hx]

  constructor
  · rw [←h_lens_eq]; exact h_res_max.1
  · rw [List.all_iff_forall]; intro x hx
    rw [←h_lens_eq] at hx
    exact h_res_max.2 x hx
