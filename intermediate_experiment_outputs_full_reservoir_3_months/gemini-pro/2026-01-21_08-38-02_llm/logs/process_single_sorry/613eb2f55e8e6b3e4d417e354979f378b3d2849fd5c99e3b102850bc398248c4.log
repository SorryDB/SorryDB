        | cons _ h => left; exact h
        | cons2 _ h => right; use l.tail; simp; exact h

  have h_fold (acc) (l) : l ∈ xs.foldl step acc ↔ ∃ s ∈ acc, ∃ t <+ xs, l = t.reverse ++ s := by
