        · intro h; exact (List.pairwise_cons.mp h).2
      · simp; intro h; have := List.rel_of_pairwise_cons h _ (List.mem_cons_self _ _); contradiction

  -- Permutation equivalence between subsequences implementations
  have h_perm : subs ~ allSubseq := by
    let op (acc : List (List Int)) (x : Int) := acc ++ acc.map (fun s => x :: s)
    let F (l : List Int) := l.foldl op [[]]
    have F_append : ∀ l x, F (l ++ [x]) = F l ++ (F l).map (fun s => x :: s) := by
      intros; simp [F, List.foldl_append]; rfl
    have subseq_append : ∀ l x, subsequences (l ++ [x]) ~ subsequences l ++ (subsequences l).map (· ++ [x]) := by
      intro l x; induction l with
      | nil => simp [subsequences]; rfl
      | cons y ys ih =>
        simp [subsequences]
        refine List.Perm.trans (List.Perm.append_left _ ih) ?_
        simp [List.map_append]
        exact List.Perm.trans (List.perm_append_comm _ _) (List.Perm.refl _)
    induction xs using List.reverseRecOn with
    | nil => simp [subsequences, F]; rfl
    | append_singleton x xs ih =>
      rw [F_append]; simp [List.map_append]
      apply List.Perm.trans (subseq_append xs x)
      apply List.Perm.trans (List.Perm.append _ (List.Perm.map _ ih))
      apply List.Perm.append_left
      rw [← List.map_map, ← List.map_map]
      apply List.Perm.map; exact ih

  -- L1 is a permutation of increasingSubseqLens
  have h_L_perm : L1 ~ increasingSubseqLens := by
    apply List.Perm.map; apply List.Perm.filter _ h_perm; exact h_equiv

  let res := L1.foldl (fun acc s => max acc s) 0

  -- 0 is in L1 (from empty subsequence)
  have h0 : 0 ∈ L1 := by
