    rcases gen lens 0 with ⟨h_in, h_le⟩
    simp at h_in h_le; constructor
    · cases h_in <;> [exact h_lens_nonempty; assumption]
    · intro x hx; apply h_le; right; assumption

  -- 4. Combine results to prove postcondition
  constructor
  · rw [List.mem_map]; rcases h_max.1 with ⟨len, hlen, rfl⟩
    rw [List.mem_map] at hlen; rcases hlen with ⟨s, hs, rfl⟩
    rw [List.mem_filter] at hs
    refine ⟨s, ?_, rfl⟩
    rw [List.mem_filter, h_spec_mem, h_pred]; simp [h_impl_mem] at hs; exact hs
  · intro x hx; rw [List.mem_map] at hx; rcases hx with ⟨s, hs, rfl⟩
    rw [List.mem_filter] at hs
    apply h_max.2; rw [List.mem_map]; use s; rw [List.mem_filter, h_impl_mem, h_pred]; simp [h_spec_mem] at hs; exact hs
  -- !benchmark @end proof
