    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  dsimp [longestIncreasingSubseqLength_postcond, longestIncreasingSubseqLength]
  
  -- Equivalence of subsequences definitions
  let S1 := subsequences xs
  let S2_aux (ys : List Int) := ys.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]
  let S2 := (S2_aux xs).map List.reverse

  have h_sub_iff : ∀ l, l ∈ S1 ↔ l <+ xs := by
    intro l
    induction xs generalizing l with
    | nil => 
      simp [subsequences]
      constructor <;> { intro h; try cases h; apply List.Sublist.nil }
    | cons x xs ih =>
      simp [subsequences]
      constructor
      . rintro (h | ⟨k, hk, rfl⟩)
        . apply List.Sublist.sublist_cons; exact ih _ |>.mp h
        . apply List.Sublist.cons_cons; exact ih _ |>.mp hk
      . intro h
        cases h with
        | cons _ _ h_sub => left; exact ih _ |>.mpr h_sub
        | cons_cons _ _ h_sub => right; use l.tail; exact ⟨ih _ |>.mpr h_sub, rfl⟩

  have h_s2_iff : ∀ l, l ∈ S2_aux xs ↔ l.reverse <+ xs := by
    have fold_step : ∀ ys z, S2_aux (ys ++ [z]) = S2_aux ys ++ (S2_aux ys).map (z :: ·) := by
      intros; simp [S2_aux, List.foldl_append]
    induction xs using List.reverseRecOn with
    | nil => simp [S2_aux]; intro l; constructor <;> { rintro rfl; exact List.Sublist.nil }
    | snoc xs x ih =>
      rw [fold_step]
      intro l
      simp
      constructor
      . rintro (h | ⟨k, hk, rfl⟩)
        . apply List.Sublist.sublist_append_of_sublist_left; exact ih _ |>.mp h
        . rw [List.reverse_cons]; apply List.Sublist.append_left; exact ih _ |>.mp hk
      . intro h
