  have h_mem_eq : ∀ s, s ∈ subs ↔ s ∈ allSubseq := by
    intro s
    have h1 : s ∈ subs ↔ s <+ xs := by
      induction xs generalizing s <;> simp [subsequences, List.sublist_cons_iff, *]
    have h2 : s ∈ allSubseq ↔ s <+ xs := by
      suffices ∀ l r, r ∈ l.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]] ↔ r <+ l.reverse by
        simp [allSubseq]; constructor
        · rintro ⟨a, ha, rfl⟩; rw [this] at ha; simpa using List.reverse_sublist_iff.2 ha
        · intro h; refine ⟨s.reverse, ?_, List.reverse_reverse s⟩; rw [this]; simpa using List.reverse_sublist_iff.1 h
      intro l; induction l using List.reverseRecOn with
      | nil => simp
      | append_singleton l x ih =>
        intro r; simp [List.foldl_append, ih, List.sublist_cons_iff]
        constructor <;> rintro (h|⟨t,ht,rfl⟩) <;> try (exact Or.inl h) <;> exact Or.inr ⟨t, ht, rfl⟩
    rw [h1, h2]

  -- Prove isStrictlyIncreasing is equivalent to Pairwise (<)
  have h_strict : ∀ l, isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by
    intro l; induction l with
    | nil => simp [isStrictlyIncreasing]
    | cons x xs ih =>
      cases xs with
      | nil => simp [isStrictlyIncreasing]
      | cons y ys =>
