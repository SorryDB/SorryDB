theorem longestIncreasingSubseqLength_spec_satisfied (xs: List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) :
    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  dsimp [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond]
  
  -- Equivalence of isStrictlyIncreasing and Pairwise <
  have h_strict (l : List Int) : isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by
    induction l with
    | nil => simp [isStrictlyIncreasing]
    | cons x xs ih =>
      cases xs with
      | nil => simp [isStrictlyIncreasing]
      | cons y ys =>
        simp [isStrictlyIncreasing]
        split
        · next hlt =>
          simp [ih, List.pairwise_cons]
          constructor
          · rintro ⟨h1, h2⟩; constructor
            · intro z hz; trans y; exact hlt; exact h1 z hz
            · exact h2
          · rintro ⟨h1, h2⟩; exact ⟨fun z hz => by trans y <;> assumption, h2⟩
        · next hnlt =>
          simp [List.pairwise_cons]
          intro h; apply hnlt; exact h.1 y (Or.inl rfl)

  -- Equivalence of subsequences generation
  let subs := subsequences xs
  let step := fun (acc : List (List Int)) x => acc ++ acc.map (fun sub => x :: sub)
  let allS := (xs.foldl step [[]]).map List.reverse

  have h_subs_iff (l) : l ∈ subs ↔ l <+ xs := by
    induction xs generalizing l with
