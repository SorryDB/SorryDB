             rw [Nat.add_comm] at this; contradiction
          | nil =>
             have : y = x := by cases h2; assumption; contradiction
             subst y; right; use l1.reverse
             constructor; apply ih; rw [List.reverse_reverse]; exact h1; simp

  have h_perm : ∀ l, l ∈ S1 ↔ l ∈ S2 := by
    intro l
    rw [h_sub_iff, List.mem_map]
    constructor
    . intro h; use l.reverse; rw [h_s2_iff, List.reverse_reverse]; exact ⟨h, rfl⟩
    . rintro ⟨k, hk, rfl⟩; rw [h_s2_iff] at hk; rw [List.reverse_reverse] at hk; exact hk

