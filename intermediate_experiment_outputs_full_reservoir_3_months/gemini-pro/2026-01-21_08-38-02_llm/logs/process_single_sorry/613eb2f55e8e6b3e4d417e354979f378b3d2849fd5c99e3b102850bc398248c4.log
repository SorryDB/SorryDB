theorem longestIncreasingSubseqLength_spec_satisfied (xs: List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) :
    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  simp only [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond, longestIncreasingSubseqLength_precond]
  
  -- 1. Equivalence of strictly increasing and pairwise less than
  have strict_iff_pairwise (l : List Int) : isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by
    induction l with
    | nil => simp [isStrictlyIncreasing]
    | cons x xs ih =>
      simp [isStrictlyIncreasing]
      split_ifs with h
      · rw [ih]; constructor
        · rintro ⟨h1, h2⟩; exact ⟨fun z hz => lt_trans h (List.rel_of_pairwise_cons h2 hz), h2⟩
        · rintro ⟨_, h2⟩; exact ⟨h2⟩
      · simp; intro p; exact h (List.rel_of_pairwise_cons p (List.mem_cons_self _ _))

  -- 2. Equivalence of subsequences implementation and Sublist
  have mem_subsequences (s : List Int) : s ∈ subsequences xs ↔ s <+ xs := by
    induction xs generalizing s <;> simp [subsequences, List.sublist_cons_iff, *]
    constructor
    · rintro (h | ⟨t, h, rfl⟩); { left; exact h }; { right; exact ⟨t, h, rfl⟩ }
    · rintro (h | ⟨t, h, rfl⟩); { left; exact h }; { right; exact ⟨t, h, rfl⟩ }

  -- 3. Equivalence of spec generation and Sublist
  let spec_gen := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse
  have mem_spec_gen (s : List Int) : s ∈ spec_gen ↔ s <+ xs := by
    let f := fun acc (x : Int) => acc ++ acc.map (fun sub => x :: sub)
    have inv (l acc pre) (h : ∀ t, t ∈ acc ↔ t.reverse <+ pre) :
        ∀ t, t ∈ l.foldl f acc ↔ t.reverse <+ pre ++ l := by
      induction l generalizing acc pre with
      | nil => simp; exact h
      | cons x l ih =>
        simp [f]; apply ih; intro u
        simp [List.mem_append, List.mem_map, h, List.sublist_append_iff]
        constructor
        · rintro (h1 | ⟨v, h2, rfl⟩)
          · exact ⟨u.reverse, [], h1, List.Sublist.nil, by simp⟩
          · exact ⟨v.reverse, [x], h2, List.Sublist.refl _, by simp⟩
        · rintro ⟨l1, l2, h1, h2, heq⟩
          cases l2 with 
          | nil => left; simp at *; rw [heq] at h1; exact h1
          | cons z zs => 
            have : z = x ∧ zs = [] := by simpa using h2
            rcases this with ⟨rfl, rfl⟩
            right; use l1.reverse; simp; rw [heq]; simp; exact h1
    simp [spec_gen]; rw [inv xs [[]] []]; simp; simp

  -- 4. Proving properties of the result (max length)
  let lens := (subsequences xs).filter isStrictlyIncreasing |>.map List.length
  let lens_spec := spec_gen.filter (fun l => l.Pairwise (· < ·)) |>.map List.length
  
  have h_set_eq : ∀ n, n ∈ lens ↔ n ∈ lens_spec := by
    intro n; simp [lens, lens_spec, strict_iff_pairwise, mem_subsequences, mem_spec_gen]
    
  have h_res : longestIncreasingSubseqLength xs h_precond = lens.foldl max 0 := rfl
  rw [h_res]
  
  have h_assoc : lens.foldl max 0 = lens.foldr max 0 := List.foldl_assoc
  rw [h_assoc]

  let res := lens.foldr max 0
  have h0 : 0 ∈ lens := by simp [lens, subsequences]; use []; simp [isStrictlyIncreasing]
  
  have h_mem : res ∈ lens := by
    induction lens with
    | nil => contradiction
    | cons y ys ih =>
      simp [List.foldr]; split_ifs
      · exact List.mem_cons_self _ _
      · cases ys
        · simp at h0; subst y; simp
        · right; apply ih; cases h0; subst y; contradiction; assumption

  have h_ge : ∀ n ∈ lens, n ≤ res := by
    intro n hn; rw [←h_assoc]; exact List.le_foldl_max _ _ hn

  constructor
  · rw [←h_set_eq]; exact h_mem
  · rw [List.all_iff_forall]; intro x hx; rw [←h_set_eq] at hx; apply h_ge _ hx
