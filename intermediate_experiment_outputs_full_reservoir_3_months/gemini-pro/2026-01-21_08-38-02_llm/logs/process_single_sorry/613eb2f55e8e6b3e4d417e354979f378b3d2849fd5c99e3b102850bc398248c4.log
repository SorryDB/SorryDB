    · rintro (h | ⟨s, h, rfl⟩); exact Or.inl h; exact Or.inr ⟨s, h, rfl⟩

  have h_spec_mem : ∀ l, l ∈ spec_subs ↔ l <+ xs := by
    have fold_inv : ∀ l, l ∈ xs.foldl (fun acc x => acc ++ acc.map (fun s => x :: s)) [[]] ↔ l.reverse <+ xs := by
      induction xs using List.reverseRecOn with
      | nil => simp
      | append_singleton xs x ih =>
        simp [List.foldl_append, ih, List.sublist_append_iff]
        intro l; constructor
        · rintro (h | ⟨s, hs, rfl⟩)
          · left; exact h
          · right; exact ⟨s.reverse, by simp [hs], by simp⟩
        · rintro (h | ⟨s, hs, rfl⟩)
          · left; exact h
          · right; refine ⟨s.reverse, ?_, ?_⟩ <;> simp [hs]
    intro l; rw [List.mem_map]; constructor
    · rintro ⟨s, hs, rfl⟩; rw [fold_inv] at hs; simp [hs]
    · intro h; use l.reverse; rw [fold_inv]; simp [h]

  -- 2. Prove isStrictlyIncreasing is equivalent to Pairwise (<)
  have h_pred : ∀ l, isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by
    intro l; induction l with
    | nil => simp [isStrictlyIncreasing]
    | cons x tl ih =>
      cases tl <;> simp [isStrictlyIncreasing, ih, List.pairwise_cons]
      intro y tl; constructor
      · rintro ⟨hxy, hrest⟩
        refine ⟨fun z hz => ?_, hrest⟩
        cases hz with
        | head => exact hxy
        | tail _ h' => rw [List.pairwise_cons] at hrest; exact Int.lt_trans hxy (hrest.1 _ h')
      · rintro ⟨hxy, hrest⟩; exact ⟨hxy _ (List.mem_cons_self _ _), hrest⟩

  -- 3. Show that foldl max computes the maximum of lengths
  let valid_subs := impl_subs.filter isStrictlyIncreasing
  let lens := valid_subs.map List.length
  
  -- Transform implementation logic to lens.foldl max 0
  have h_fold_eq : valid_subs.foldl (fun acc s => max acc s.length) 0 = lens.foldl max 0 := List.foldl_map _ _ _
  rw [h_fold_eq]

  -- Zero is always in the list of lengths (from empty subsequence)
  have h_lens_nonempty : 0 ∈ lens := by
    simp [List.mem_filter, h_impl_mem, h_pred]; use []; simp [isStrictlyIncreasing]

  -- The result of foldl max is an element and an upper bound
  have h_max : lens.foldl max 0 ∈ lens ∧ ∀ x ∈ lens, x ≤ lens.foldl max 0 := by
    have gen : ∀ (L : List Nat) a, (L.foldl max a ∈ a :: L) ∧ (∀ x ∈ a :: L, x ≤ L.foldl max a) := by
      intro L; induction L with
