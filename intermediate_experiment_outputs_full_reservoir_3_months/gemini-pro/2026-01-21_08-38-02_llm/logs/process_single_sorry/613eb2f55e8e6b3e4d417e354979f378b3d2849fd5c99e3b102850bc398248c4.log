theorem longestIncreasingSubseqLength_spec_satisfied (xs: List Int) (h_precond : longestIncreasingSubseqLength_precond (xs)) :
    longestIncreasingSubseqLength_postcond (xs) (longestIncreasingSubseqLength (xs) h_precond) h_precond := by
  -- !benchmark @start proof
  unfold longestIncreasingSubseqLength longestIncreasingSubseqLength_postcond
  let subs := subsequences xs
  let lens := (subs.filter isStrictlyIncreasing).map List.length
  let allSubseq := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse
  let increasingSubseqLens := (allSubseq.filter (fun l => List.Pairwise (· < ·) l)).map List.length

  have h_sub_iff : ∀ s, s ∈ subs ↔ s <+ xs := by
    intro s; induction xs <;> simp [subsequences, List.sublist_cons_iff, *]
    intro; constructor
    · rintro (h | ⟨t, h, rfl⟩); exact Or.inl h; exact Or.inr ⟨t, h, rfl⟩
    · rintro (h | ⟨t, h, rfl⟩); exact Or.inl h; exact Or.inr ⟨t, h, rfl⟩

  have h_aux_eq : xs.foldl (fun acc x => acc ++ acc.map (x :: ·)) [[]] = subsequences xs.reverse := by
    induction xs using List.reverseRecOn with
    | nil => rfl
    | append_cons ys y ih =>
      simp only [List.foldl_append, List.foldl_cons, List.foldl_nil, subsequences, 
        List.map_append, List.map_map, List.reverse_append, List.reverse_cons, List.singleton_append]
      rw [ih]; rfl

  have h_all_iff : ∀ s, s ∈ allSubseq ↔ s <+ xs := by
    intro s
    simp only [allSubseq, List.mem_map, List.mem_reverse, h_aux_eq]
    constructor
    · rintro ⟨l, hl, rfl⟩
      rw [h_sub_iff, List.reverse_sublist_iff] at hl; exact hl
    · intro h
      refine ⟨s.reverse, ?_, List.reverse_reverse _⟩
      rw [h_sub_iff, List.reverse_sublist_iff]; exact h

  have h_incr_iff : ∀ s, isStrictlyIncreasing s ↔ List.Pairwise (· < ·) s := by
    intro s; induction s with
    | nil => simp [isStrictlyIncreasing]
    | cons x tail ih =>
      cases tail with
      | nil => simp [isStrictlyIncreasing]
      | cons y rest =>
        simp only [isStrictlyIncreasing, Bool.if_prop]
        split <;> rename_i h_cond
        · simp [ih]; rw [List.pairwise_cons]
          constructor
          · intro h; exact ⟨fun z hz => lt_trans h_cond (List.rel_of_pairwise_cons h hz), h⟩
          · rintro ⟨_, h⟩; exact h
        · simp [ih, List.pairwise_cons]; intro h; exact h_cond (h.1 _ (List.mem_cons_self _ _))

  have h_lens_set : ∀ n, n ∈ lens ↔ n ∈ increasingSubseqLens := by
    intro n; simp [lens, increasingSubseqLens, List.mem_map, List.mem_filter]
    constructor
    · rintro ⟨s, ⟨hs1, hs2⟩, rfl⟩; refine ⟨s, ⟨(h_all_iff s).2 ((h_sub_iff s).1 hs1), (h_incr_iff s).1 hs2⟩, rfl⟩
    · rintro ⟨s, ⟨hs1, hs2⟩, rfl⟩; refine ⟨s, ⟨(h_sub_iff s).2 ((h_all_iff s).1 hs1), (h_incr_iff s).2 hs2⟩, rfl⟩

  have h_fold_prop : ∀ l acc, let res := l.foldl max acc; res ≥ acc ∧ ∀ x ∈ l, x ≤ res := by
    intro l acc; induction l generalizing acc <;> simp [List.foldl_cons]
    · exact le_refl _
    · next y ys ih => 
      specialize ih (max acc y)
      exact ⟨le_trans (le_max_left _ _) ih.1, fun x hx => (ih.2 x hx)⟩
      
  have h_fold_mem : ∀ l acc, l.foldl max acc ∈ acc :: l := by
    intro l acc; induction l generalizing acc with
    | nil => simp
    | cons y ys ih =>
      simp; specialize ih (max acc y)
      cases ih with
      | head => 
         simp [max_def]; split
         · right; left; rfl
         · left; rfl
      | tail _ h => right; right; exact h

  let m := lens.foldl max 0
  have h0 : 0 ∈ lens := by
    apply List.mem_map_of_mem; rw [List.mem_filter]
    refine ⟨(h_sub_iff _).2 (List.nil_sublist _), by simp [isStrictlyIncreasing]⟩

  constructor
  · rw [h_lens_set]
    have := h_fold_mem lens 0
    cases this with
    | head h => rw [h]; exact h0
    | tail _ h => exact h
  · rw [List.all_eq_true]; intro x hx
    rw [h_lens_set] at hx; exact (h_fold_prop lens 0).2 x hx
  -- !benchmark @end proof
