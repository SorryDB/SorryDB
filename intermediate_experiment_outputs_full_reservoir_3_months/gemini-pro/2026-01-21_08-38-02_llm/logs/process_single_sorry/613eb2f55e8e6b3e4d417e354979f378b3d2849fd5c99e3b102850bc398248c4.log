  simp only [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond, longestIncreasingSubseqLength_precond]
  
  -- Define the list of subsequences from implementation and specification
  let impl_subs := subsequences xs
  let spec_subs := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse

  -- 1. Prove both subsequence generation methods produce the set of all subsequences (l <+ xs)
  have h_impl_mem : ∀ l, l ∈ impl_subs ↔ l <+ xs := by
