        · rw [Nat.max_def] at h; split at h <;> simp [h]
        · right; right; assumption

  rw [h_res_eq]
  rcases h_max lens1 0 with ⟨_, h_le, h_mem⟩
  
  constructor
  · rw [List.contains_iff_mem]
    cases h_mem
    · rw [h_lens_eq]; simp [lens1]; use []
      simp [isStrictlyIncreasing]; apply List.Sublist.slnil
    · rw [h_lens_eq] at h_mem; exact h_mem
  · rw [List.all_iff_forall]
    intro x hx
    rw [← h_lens_eq] at hx
    exact h_le x hx
