      "\n  simp only [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond]\n  let S1 := subsequences xs\n  let S2 := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse\n  \n  -- 1. Equivalence of generated subsequences\n  have h_iff : ∀ s, s ∈ S1 ↔ s ∈ S2 := by\n    intro s\n    have h1 : s ∈ S1 ↔ s <+ xs := by\n      induction xs generalizing s <;> simp [subsequences]\n      case nil => rw [List.sublist_nil]; rfl\n      case cons x xs ih =>\n        simp [ih, List.mem_map, List.mem_append]\n        constructor\n        · rintro (h|⟨t,ht,rfl⟩); exacts [List.Sublist.cons _ h, List.Sublist.cons2 _ ht]\n        · rintro h; cases h <;> simp [*]; case cons2 => right; exists s.tail; simp [*]\n    have h2 : s ∈ S2 ↔ s <+ xs := by\n      let f := fun acc (x : Int) => acc ++ acc.map (fun sub => x :: sub)\n      suffices ∀ l acc, (∀ a, a ∈ acc ↔ a.reverse <+ l) → (s ∈ (List.foldl f acc xs).map List.reverse ↔ s <+ l ++ xs) by\n        apply this [] [[]] (by simp); simp\n      intro l acc h_inv; induction xs generalizing l acc <;> simp\n      · exact h_inv s\n      case cons y ys ih =>\n        apply ih; intro a; simp [f, h_inv]; constructor\n        · rintro (h|⟨t,ht,rfl⟩)\n          · apply List.Sublist.append_left [y] h\n          · simp; apply List.Sublist.append_right; exact ht\n        · intro h; rw [←List.reverse_reverse a, List.reverse_sublist, List.reverse_append] at h\n          rw [List.reverse_singleton, List.sublist_cons_iff] at h\n          rcases h with ⟨h,_⟩|⟨t,ht,rfl⟩\n          · left; rw [←List.reverse_sublist, List.reverse_reverse]; exact h\n          · right; exists t; rw [←List.reverse_sublist, List.reverse_reverse]; exact ⟨ht,rfl⟩\n    rw [h1, h2]\n\n  -- 2. Equivalence of strictly increasing predicate\n  have h_pred : ∀ s, isStrictlyIncreasing s ↔ s.Pairwise (· < ·) := by\n    intro s; rw [List.chain'_iff_pairwise Int.lt_trans]\n    induction s <;> simp [isStrictlyIncreasing, List.Chain']\n    case cons _ xs _ => cases xs <;> simp [isStrictlyIncreasing, List.Chain'] at *\n\n  -- 3. Correctness of Max calculation\n  let L := S1.filter isStrictlyIncreasing |>.map List.length\n  let lens := S2.filter (List.Pairwise (· < ·)) |>.map List.length\n  have h_perm : ∀ n, n ∈ lens ↔ n ∈ L := by intro n; simp [lens, L, h_iff, h_pred]\n  \n  let res := (S1.filter isStrictlyIncreasing).foldl (fun acc s => max acc s.length) 0\n  have h_L_0 : 0 ∈ L := by\n    simp [L, subsequences]; exists []; simp [subsequences, isStrictlyIncreasing]\n    induction xs <;> simp [subsequences]; left; rfl\n\n  -- res is the max of L\n  have h_max : res ∈ L ∧ ∀ x ∈ L, x ≤ res := by\n    dsimp [res]; rw [List.foldl_eq_foldr_of_assoc_comm (fun a b => max a b)]\n    · suffices (L.foldr max 0) ∈ L ∧ ∀ x ∈ L, x ≤ L.foldr max 0 from this\n      have : ∀ l, 0 ∈ l → l.foldr max 0 ∈ l ∧ ∀ x ∈ l, x ≤ l.foldr max 0 := by\n        intro l hl; induction l with\n        | nil => contradiction\n        | cons a l ih =>\n          simp; by_cases h0 : 0 ∈ l\n          · rcases ih h0 with ⟨ih1, ih2⟩\n            cases le_total a (l.foldr max 0) with\n            | inl h => constructor; right; rw [max_eq_right h]; exact ih1; intro x hx; cases hx <;> simp [ih2, h, *]\n            | inr h => constructor; left; rw [max_eq_left h]; intro x hx; cases hx <;> simp [ih2, h, *]\n          · simp [h0] at hl; subst hl\n            simp [List.foldr]; constructor\n            · right; exact List.foldr_max_mem_cons 0 l\n            · exact List.le_foldr_max\n      exact this L h_L_0\n    · intros; apply max_assoc\n    · intros; apply max_comm\n\n  constructor\n  · rw [h_perm]; exact h_max.1\n  · intro x hx; rw [h_perm] at hx; exact h_max.2 x hx\n  -- !benchmark @end proof",
      "\n  simp only [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond]\n  let subs := subsequences xs\n  let allSubseq := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse\n\n  have h_subs_sublist : ∀ s, s ∈ subs ↔ s <+ xs := by\n    intro s; induction xs generalizing s with\n    | nil => simp [subsequences]; constructor <;> intro h <;> [rw [List.mem_singleton] at h; rw [h]; apply List.Sublist.slnil, cases h; apply List.mem_singleton.mpr rfl]\n    | cons x xs ih =>\n      simp [subsequences]; rw [List.mem_append, List.mem_map, ih]\n      constructor\n      · intro h; cases h with | inl h => exact List.Sublist.cons _ h | inr h => rcases h with ⟨t, ht, rfl⟩; rw [ih] at ht; exact List.Sublist.cons₂ _ ht\n      · intro h; cases h with | slnil => contradiction | cons _ h => left; rwa [ih] | cons₂ _ h => right; use s.tail; simp [ih]; exact h\n\n  have h_all_sublist : ∀ s, s ∈ allSubseq ↔ s <+ xs := by\n    intro s\n    let gen (l : List Int) := l.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]\n    have h_gen : ∀ t, t ∈ gen xs ↔ ∃ u <+ xs, t = u.reverse := by\n      induction xs using List.reverseRecOn with\n      | nil => simp [gen]; intro t; constructor <;> intro h <;> [rw [List.mem_singleton] at h; subst h; exists []; exact ⟨List.Sublist.slnil, rfl⟩, rcases h with ⟨u, hu, rfl⟩; cases hu; simp]\n      | append_singleton ys y ih =>\n        simp [gen, List.foldl_append]; intro t; rw [List.mem_append, List.mem_map]\n        constructor\n        · intro h; cases h with\n          | inl h => rw [ih] at h; rcases h with ⟨u, hu, rfl⟩; exists u; exact ⟨List.Sublist.trans hu (List.sublist_append_left ys [y]), rfl⟩\n          | inr h => rcases h with ⟨v, hv, rfl⟩; rw [ih] at hv; rcases hv with ⟨u, hu, rfl⟩; exists (u ++ [y]); exact ⟨List.Sublist.append_right [y] hu, by simp⟩\n        · intro h; rcases h with ⟨u, hu, rfl⟩; rw [List.sublist_append_iff] at hu; rcases hu with ⟨u1, u2, rfl, h1, h2⟩\n          cases h2 with\n          | slnil => left; rw [ih]; exists u1; simp\n          | cons m hm => \n            cases u2 with | nil => contradiction | cons z zs =>\n            have : z = y ∧ zs = [] := by \n              have : [z] <+ [y] := by simpa using h2\n              cases this with | cons h => cases h | cons₂ h => cases h; simp\n            rcases this with ⟨rfl, rfl⟩; right; exists u1.reverse; constructor; rw [ih]; exists u1; simp\n    rw [List.mem_map]; constructor\n    · intro h; rcases h with ⟨t, ht, rfl⟩; rw [h_gen] at ht; rcases ht with ⟨u, hu, rfl⟩; rw [List.reverse_reverse]; exact hu\n    · intro h; exists s.reverse; constructor; rw [h_gen]; exists s; simp; exact h\n\n  have h_incr : ∀ s, isStrictlyIncreasing s ↔ s.Pairwise (· < ·) := by\n    intro s; induction s with\n    | nil => simp [isStrictlyIncreasing]\n    | cons x xs ih =>\n      cases xs with\n      | nil => simp [isStrictlyIncreasing]\n      | cons y ys =>\n        simp [isStrictlyIncreasing]; split\n        next h => rw [ih]; constructor <;> intro hp <;> [apply List.Pairwise.cons h hp, exact List.Pairwise.of_cons hp]\n        next h => constructor <;> intro hp <;> [contradiction, have := List.rel_of_pairwise_cons hp (List.mem_cons_self _ _); contradiction]\n\n  let L1 := (subs.filter isStrictlyIncreasing).map List.length\n  let L2 := (allSubseq.filter (fun l => l.Pairwise (· < ·))).map List.length\n  have h_eq : ∀ n, n ∈ L1 ↔ n ∈ L2 := by\n    intro n; simp [L1, L2]; constructor\n    · intro h; rcases h with ⟨s, hs1, hs2, rfl⟩; exists s; rw [← h_subs_sublist, ← h_incr] at *; rw [h_all_sublist]; exact ⟨hs1, hs2, rfl⟩\n    · intro h; rcases h with ⟨s, hs1, hs2, rfl⟩; exists s; rw [h_subs_sublist, h_incr] at *; rw [← h_all_sublist]; exact ⟨hs1, hs2, rfl⟩\n    \n  have h_zero : 0 ∈ L1 := by\n    simp [L1, subsequences]; exists []; simp [isStrictlyIncreasing]\n    have : [] <+ xs := List.Sublist.slnil\n    rw [← h_subs_sublist] at this; exact this\n\n  let res := L1.foldl max 0\n  have h_res_is_fold : (subs.filter isStrictlyIncreasing).foldl (fun acc s => max acc s.length) 0 = res := List.foldl_map _ _ _ _\n  rw [h_res_is_fold]\n\n  have h_max_props : res ∈ L1 ∧ ∀ x ∈ L1, x ≤ res := by\n    have upper : ∀ (l : List Nat) a, (∀ x ∈ l, x ≤ l.foldl max a) ∧ a ≤ l.foldl max a := by\n      intro l a; induction l generalizing a with\n      | nil => simp\n      | cons y ys ih => simp; constructor; intro x hx; cases hx; subst x; exact le_trans (Nat.le_max_right _ _) (ih _).2; exact le_trans (ih _).1 (le_trans (Nat.le_max_left _ _) (ih _).2) (by assumption); exact le_trans (Nat.le_max_left _ _) (ih _).2\n    have mem : ∀ (l : List Nat) a, l.foldl max a = a ∨ l.foldl max a ∈ l := by\n      intro l a; induction l generalizing a with\n      | nil => simp\n      | cons y ys ih => simp; cases ih (max a y) with | inl h => rw [h]; cases Nat.max_choice a y with | inl h => left; exact h | inr h => right; left; exact h | inr h => right; right; exact h\n    constructor\n    · cases mem L1 0 with | inl h => rw [h] at h_zero; exact h_zero | inr h => exact h\n    · exact (upper L1 0).1\n\n  constructor\n  · rw [← h_eq]; exact h_max_props.1\n  · rw [List.all_iff_forall]; intro x hx; rw [← h_eq] at hx; exact h_max_props.2 x hx\n  -- !benchmark @end proof",
      "\n      · rintro rfl; exact List.Sublist.nil\n      · intro s; simp [List.foldl_append]; rintro (h | ⟨s, h, rfl⟩)\n        · apply List.sublist_append_of_sublist_left (‹_› h)\n        · rw [List.reverse_cons]; apply List.Sublist.append_right _ _ (‹_› h)\n    · intro h; refine ⟨s.reverse, ?_, List.reverse_reverse _⟩\n      induction xs using List.reverseRecOn generalizing s <;> simp [gen, List.foldl_append]\n      · cases List.eq_nil_of_sublist_nil h; simp\n      · rw [List.sublist_append_iff] at h; rcases h with ⟨s1, s2, rfl, h1, h2⟩\n        cases s2 using List.reverseRecOn\n        · simp at h2; subst s2; simp; left; apply ‹_› h1\n        · next s2' y _ =>\n           simp at h2; cases h2; subst y; cases ‹List [] <+ _›\n           rw [List.reverse_append, List.reverse_cons]; simp\n           right; refine ⟨_, ?_, rfl⟩; apply ‹_› (List.sublist_append_of_sublist_left h1)\n\n  have mem_iff : ∀ n, n ∈ L1 ↔ n ∈ L2 := by\n    intro n; simp [L1, L2, iff_strict]\n    constructor <;> rintro ⟨s, h1, h2, rfl⟩ <;> refine ⟨s, ?_, h2, rfl⟩\n    · rw [mem_gen, ← mem_sub]; assumption\n    · rw [mem_sub, ← mem_gen]; assumption\n\n  have h0 : 0 ∈ L1 := by simp [L1]; exists []; simp [subsequences, isStrictlyIncreasing]\n\n  have bound : let m := L1.foldl max 0; m ∈ L1 ∧ ∀ x ∈ L1, x ≤ m := by\n    have : ∀ l b, l.foldl max b ∈ b :: l ∧ ∀ x ∈ b :: l, x ≤ l.foldl max b := by\n      intro l b; induction l generalizing b <;> simp\n      next x xs ih =>\n        specialize ih (max b x); cases ih with | intro h1 h2 =>\n        constructor\n        · cases h1 <;> simp [*]; try exact Or.inl (le_max_left _ _)\n        · intro y hy; cases hy <;> try subst y\n          · exact le_trans (le_max_left _ _) (h2 (max b x) (Or.inl rfl))\n          · exact h2 y (Or.inr (Or.inr ‹_›))\n    obtain ⟨h1, h2⟩ := this L1 0\n    cases h1\n    · subst m; exact ⟨h0, fun x h => h2 x (Or.inr h)⟩\n    · exact ⟨‹_›, fun x h => h2 x (Or.inr h)⟩\n\n  rw [mem_iff] at bound; rw [List.all_iff_forall]\n  exact ⟨bound.1, fun x hx => bound.2 x ((mem_iff _).2 hx)⟩",
      "\n  unfold longestIncreasingSubseqLength longestIncreasingSubseqLength_postcond\n  let subs := subsequences xs\n  let lens := (subs.filter isStrictlyIncreasing).map List.length\n  let allSubseq := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse\n  let increasingSubseqLens := (allSubseq.filter (fun l => List.Pairwise (· < ·) l)).map List.length\n\n  have h_sub_iff : ∀ s, s ∈ subs ↔ s <+ xs := by\n    intro s; induction xs <;> simp [subsequences, List.sublist_cons_iff, *]\n    intro; constructor\n    · rintro (h | ⟨t, h, rfl⟩); exact Or.inl h; exact Or.inr ⟨t, h, rfl⟩\n    · rintro (h | ⟨t, h, rfl⟩); exact Or.inl h; exact Or.inr ⟨t, h, rfl⟩\n\n  have h_aux_eq : xs.foldl (fun acc x => acc ++ acc.map (x :: ·)) [[]] = subsequences xs.reverse := by\n    induction xs using List.reverseRecOn with\n    | nil => rfl\n    | append_cons ys y ih =>\n      simp only [List.foldl_append, List.foldl_cons, List.foldl_nil, subsequences, \n        List.map_append, List.map_map, List.reverse_append, List.reverse_cons, List.singleton_append]\n      rw [ih]; rfl\n\n  have h_all_iff : ∀ s, s ∈ allSubseq ↔ s <+ xs := by\n    intro s\n    simp only [allSubseq, List.mem_map, List.mem_reverse, h_aux_eq]\n    constructor\n    · rintro ⟨l, hl, rfl⟩\n      rw [h_sub_iff, List.reverse_sublist_iff] at hl; exact hl\n    · intro h\n      refine ⟨s.reverse, ?_, List.reverse_reverse _⟩\n      rw [h_sub_iff, List.reverse_sublist_iff]; exact h\n\n  have h_incr_iff : ∀ s, isStrictlyIncreasing s ↔ List.Pairwise (· < ·) s := by\n    intro s; induction s with\n    | nil => simp [isStrictlyIncreasing]\n    | cons x tail ih =>\n      cases tail with\n      | nil => simp [isStrictlyIncreasing]\n      | cons y rest =>\n        simp only [isStrictlyIncreasing, Bool.if_prop]\n        split <;> rename_i h_cond\n        · simp [ih]; rw [List.pairwise_cons]\n          constructor\n          · intro h; exact ⟨fun z hz => lt_trans h_cond (List.rel_of_pairwise_cons h hz), h⟩\n          · rintro ⟨_, h⟩; exact h\n        · simp [ih, List.pairwise_cons]; intro h; exact h_cond (h.1 _ (List.mem_cons_self _ _))\n\n  have h_lens_set : ∀ n, n ∈ lens ↔ n ∈ increasingSubseqLens := by\n    intro n; simp [lens, increasingSubseqLens, List.mem_map, List.mem_filter]\n    constructor\n    · rintro ⟨s, ⟨hs1, hs2⟩, rfl⟩; refine ⟨s, ⟨(h_all_iff s).2 ((h_sub_iff s).1 hs1), (h_incr_iff s).1 hs2⟩, rfl⟩\n    · rintro ⟨s, ⟨hs1, hs2⟩, rfl⟩; refine ⟨s, ⟨(h_sub_iff s).2 ((h_all_iff s).1 hs1), (h_incr_iff s).2 hs2⟩, rfl⟩\n\n  have h_fold_prop : ∀ l acc, let res := l.foldl max acc; res ≥ acc ∧ ∀ x ∈ l, x ≤ res := by\n    intro l acc; induction l generalizing acc <;> simp [List.foldl_cons]\n    · exact le_refl _\n    · next y ys ih => \n      specialize ih (max acc y)\n      exact ⟨le_trans (le_max_left _ _) ih.1, fun x hx => (ih.2 x hx)⟩\n      \n  have h_fold_mem : ∀ l acc, l.foldl max acc ∈ acc :: l := by\n    intro l acc; induction l generalizing acc with\n    | nil => simp\n    | cons y ys ih =>\n      simp; specialize ih (max acc y)\n      cases ih with\n      | head => \n         simp [max_def]; split\n         · right; left; rfl\n         · left; rfl\n      | tail _ h => right; right; exact h\n\n  let m := lens.foldl max 0\n  have h0 : 0 ∈ lens := by\n    apply List.mem_map_of_mem; rw [List.mem_filter]\n    refine ⟨(h_sub_iff _).2 (List.nil_sublist _), by simp [isStrictlyIncreasing]⟩\n\n  constructor\n  · rw [h_lens_set]\n    have := h_fold_mem lens 0\n    cases this with\n    | head h => rw [h]; exact h0\n    | tail _ h => exact h\n  · rw [List.all_eq_true]; intro x hx\n    rw [h_lens_set] at hx; exact (h_fold_prop lens 0).2 x hx\n  -- !benchmark @end proof",
      "\n  have h_bound : ∀ x ∈ L1, x ≤ res := by\n    intro x hx\n    have : ∀ b, ∀ x ∈ L1, x ≤ L1.foldl max b ∧ b ≤ L1.foldl max b := by\n       intro b; induction L1 generalizing b <;> simp; intro x hx; specialize ih (max b x); exact ih\n    exact (this 0 x hx).1\n\n  -- Membership property\n  have h_mem : res ∈ L1 := by\n    have : ∀ subL, subL ⊆ L1 → ∀ b ∈ L1, subL.foldl max b ∈ L1 := by\n      intro subL hsub b hb; induction subL generalizing b with\n      | nil => simp; exact hb\n      | cons a as ih =>\n        simp; apply ih (List.Subset.trans (List.subset_cons _ _) hsub)\n        simp [max_def]; split_ifs\n        · exact hsub (List.mem_cons_self _ _)\n        · exact hb\n    exact this L1 (List.subset_refl _) 0 h0\n\n  simp [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond]\n  constructor\n  · rw [← List.perm_mem h_L_perm]; exact h_mem\n  · rw [List.all_eq_true]; intro x hx; rw [← List.perm_mem h_L_perm] at hx; exact h_bound x hx",
      "\n  simp only [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond, longestIncreasingSubseqLength_precond]\n  \n  -- Define the list of subsequences from implementation and specification\n  let impl_subs := subsequences xs\n  let spec_subs := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse\n\n  -- 1. Prove both subsequence generation methods produce the set of all subsequences (l <+ xs)\n  have h_impl_mem : ∀ l, l ∈ impl_subs ↔ l <+ xs := by\n    induction xs <;> simp [subsequences, List.sublist_cons_iff, *]\n    intro l; constructor\n    · rintro (h | ⟨s, h, rfl⟩); exact Or.inl h; exact Or.inr ⟨s, h, rfl⟩\n    · rintro (h | ⟨s, h, rfl⟩); exact Or.inl h; exact Or.inr ⟨s, h, rfl⟩\n\n  have h_spec_mem : ∀ l, l ∈ spec_subs ↔ l <+ xs := by\n    have fold_inv : ∀ l, l ∈ xs.foldl (fun acc x => acc ++ acc.map (fun s => x :: s)) [[]] ↔ l.reverse <+ xs := by\n      induction xs using List.reverseRecOn with\n      | nil => simp\n      | append_singleton xs x ih =>\n        simp [List.foldl_append, ih, List.sublist_append_iff]\n        intro l; constructor\n        · rintro (h | ⟨s, hs, rfl⟩)\n          · left; exact h\n          · right; exact ⟨s.reverse, by simp [hs], by simp⟩\n        · rintro (h | ⟨s, hs, rfl⟩)\n          · left; exact h\n          · right; refine ⟨s.reverse, ?_, ?_⟩ <;> simp [hs]\n    intro l; rw [List.mem_map]; constructor\n    · rintro ⟨s, hs, rfl⟩; rw [fold_inv] at hs; simp [hs]\n    · intro h; use l.reverse; rw [fold_inv]; simp [h]\n\n  -- 2. Prove isStrictlyIncreasing is equivalent to Pairwise (<)\n  have h_pred : ∀ l, isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by\n    intro l; induction l with\n    | nil => simp [isStrictlyIncreasing]\n    | cons x tl ih =>\n      cases tl <;> simp [isStrictlyIncreasing, ih, List.pairwise_cons]\n      intro y tl; constructor\n      · rintro ⟨hxy, hrest⟩\n        refine ⟨fun z hz => ?_, hrest⟩\n        cases hz with\n        | head => exact hxy\n        | tail _ h' => rw [List.pairwise_cons] at hrest; exact Int.lt_trans hxy (hrest.1 _ h')\n      · rintro ⟨hxy, hrest⟩; exact ⟨hxy _ (List.mem_cons_self _ _), hrest⟩\n\n  -- 3. Show that foldl max computes the maximum of lengths\n  let valid_subs := impl_subs.filter isStrictlyIncreasing\n  let lens := valid_subs.map List.length\n  \n  -- Transform implementation logic to lens.foldl max 0\n  have h_fold_eq : valid_subs.foldl (fun acc s => max acc s.length) 0 = lens.foldl max 0 := List.foldl_map _ _ _\n  rw [h_fold_eq]\n\n  -- Zero is always in the list of lengths (from empty subsequence)\n  have h_lens_nonempty : 0 ∈ lens := by\n    simp [List.mem_filter, h_impl_mem, h_pred]; use []; simp [isStrictlyIncreasing]\n\n  -- The result of foldl max is an element and an upper bound\n  have h_max : lens.foldl max 0 ∈ lens ∧ ∀ x ∈ lens, x ≤ lens.foldl max 0 := by\n    have gen : ∀ (L : List Nat) a, (L.foldl max a ∈ a :: L) ∧ (∀ x ∈ a :: L, x ≤ L.foldl max a) := by\n      intro L; induction L with\n      | nil => simp\n      | cons x xs ih =>\n        intro a; simp; specialize ih (max a x)\n        rcases ih with ⟨in_ih, le_ih⟩\n        constructor\n        · cases in_ih with | head => left; exact le_max_left a x | tail h => right; exact h\n        · intro y hy; apply le_ih; cases hy with\n          | head => left; exact le_max_left _ _\n          | tail hy => cases hy with | head => left; exact le_max_right _ _ | tail h => right; exact h\n    rcases gen lens 0 with ⟨h_in, h_le⟩\n    simp at h_in h_le; constructor\n    · cases h_in <;> [exact h_lens_nonempty; assumption]\n    · intro x hx; apply h_le; right; assumption\n\n  -- 4. Combine results to prove postcondition\n  constructor\n  · rw [List.mem_map]; rcases h_max.1 with ⟨len, hlen, rfl⟩\n    rw [List.mem_map] at hlen; rcases hlen with ⟨s, hs, rfl⟩\n    rw [List.mem_filter] at hs\n    refine ⟨s, ?_, rfl⟩\n    rw [List.mem_filter, h_spec_mem, h_pred]; simp [h_impl_mem] at hs; exact hs\n  · intro x hx; rw [List.mem_map] at hx; rcases hx with ⟨s, hs, rfl⟩\n    rw [List.mem_filter] at hs\n    apply h_max.2; rw [List.mem_map]; use s; rw [List.mem_filter, h_impl_mem, h_pred]; simp [h_spec_mem] at hs; exact hs\n  -- !benchmark @end proof",
      "\n    -- and that 'isStrictlyIncreasing' is equivalent to 'List.Pairwise (<)'.\n    -- With the available imports and context, we assume standard list permutation properties hold.\n    sorry",
      "\n  let allS := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse\n  let lens := (subs.filter isStrictlyIncreasing).map List.length\n  \n  have h_sub : ∀ l, l ∈ subs ↔ l <+ xs := by\n    intro l; induction xs generalizing l <;> simp [subsequences]\n    · constructor <;> simp\n    · rw [List.mem_append, List.mem_map]; constructor\n      · rintro (h|⟨a,h,rfl⟩); exact List.Sublist.cons _ (by assumption); exact List.Sublist.cons₂ _ (by assumption)\n      · intro h; cases h <;> simp [*, List.Sublist.nil]\n\n  have h_all : ∀ l, l ∈ allS ↔ l <+ xs := by\n    intro l; let gen (ys : List Int) := ys.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]\n    have : ∀ ys s, s ∈ gen ys ↔ ∃ s' <+ ys, s = s'.reverse := by\n      intro ys; induction ys using List.reverseRecOn with\n      | nil => simp [gen]; intro; constructor; rintro rfl; exact ⟨[], .nil, rfl⟩; rintro ⟨_, h, rfl⟩; cases List.sublist_nil.mp h; rfl\n      | append_cons ys y ih =>\n          simp [gen, List.foldl_append]; intro s; rw [List.mem_append, List.mem_map]; constructor\n          · rintro (h | ⟨a, h, rfl⟩); obtain ⟨s', hs', rfl⟩ := (ih s).mp h; exact ⟨s', List.Sublist.of_sublist_append_left hs', rfl⟩\n            obtain ⟨s', hs', rfl⟩ := (ih a).mp h; refine ⟨s' ++ [y], List.Sublist.append hs' (List.Sublist.refl [y]), by simp⟩\n          · rintro ⟨s', h, rfl⟩; rw [List.sublist_append_iff] at h; rcases h with ⟨l1, l2, h1, h2, rfl⟩\n            cases l2 with | nil => left; apply (ih _).mpr; exact ⟨l1, h1, rfl⟩ | cons => right; use l1.reverse; simp; apply (ih _).mpr; exact ⟨l1, h1, rfl⟩\n    rw [List.mem_map]; constructor\n    · rintro ⟨a, h, rfl⟩; obtain ⟨s', hs', rfl⟩ := (this xs a).mp h; simp; exact hs'\n    · intro h; use l.reverse; split; apply (this xs _).mpr; use l; simp [h]; simp\n\n  have h_inc : ∀ l, isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by\n    intro l; induction l with | nil => simp [isStrictlyIncreasing] | cons x xs ih =>\n    cases xs <;> simp [isStrictlyIncreasing, List.pairwise_cons] at *\n    split\n    next h => rw [ih]; constructor\n      · intro h'; exact ⟨fun z hz => lt_trans h ((List.pairwise_cons.mp h').1 _ hz), h'⟩\n      · intro h'; exact h'.2\n    next h => intro ⟨h1, h2⟩; have := h1 _ (List.mem_cons_self _ _); contradiction\n  \n  have h_eq : ∀ n, n ∈ lens ↔ n ∈ (allS.filter (List.Pairwise (· < ·))).map List.length := by\n    intro n; constructor\n    · rintro ⟨l, ⟨h1, h2⟩, rfl⟩; use l; rw [h_all, ←h_sub]; exact ⟨h1, h_inc _ |>.mp h2⟩\n    · rintro ⟨l, ⟨h1, h2⟩, rfl⟩; use l; rw [h_sub, ←h_all]; exact ⟨h1, h_inc _ |>.mpr h2⟩\n\n  let res := lens.foldl max 0\n  have : res ∈ lens ∧ ∀ x ∈ lens, x ≤ res := by\n    have h0 : 0 ∈ lens := ⟨[], by simp [h_sub, List.Sublist.nil], rfl⟩\n    have fold_spec : ∀ (l : List Nat) (b : Nat), let m := l.foldl max b; b ≤ m ∧ (∀ x ∈ l, x ≤ m) ∧ (m = b ∨ m ∈ l) := by\n      intro l b; induction l generalizing b with\n      | nil => simp\n      | cons a l ih =>\n        simp; obtain ⟨h1, h2, h3⟩ := ih (max b a); refine ⟨le_trans (le_max_left _ _) h1, fun x hx => _, _⟩\n        · cases hx; subst x; exact le_trans (le_max_right _ _) h1; apply h2 _ ‹_›\n        · rcases h3 with rfl|h3; left; rfl; right; exact h3\n    obtain ⟨_, h2, h3⟩ := fold_spec lens 0\n    refine ⟨?, h2⟩; rcases h3 with h3|h3; rw [h3]; exact h0; exact h3\n  \n  refine ⟨?_, ?_⟩\n  · rw [←h_eq]; exact this.1\n  · rw [List.all_iff_forall]; intro x hx; apply this.2; rwa [h_eq] at hx",
      "\n  have spec_iff : ∀ l, l ∈ (xs.foldl f [[]]).map List.reverse ↔ l <+ xs := by\n    -- Invariant: elements in accumulator are reversed subsequences of the prefix processed so far\n    have loop_inv : ∀ ys acc p, (∀ k, k ∈ acc ↔ k.reverse <+ p) → \n        ∀ l, l ∈ ys.foldl f acc ↔ l.reverse <+ p ++ ys := by\n      induction ys generalizing acc p <;> intro h_acc l\n      · simp; exact h_acc l\n      · simp [f]; rw [←List.append_assoc]; apply ‹_›; intro k\n        simp; rw [h_acc]\n        constructor\n        · intro h; apply List.Sublist.append_right; assumption\n        · intro ⟨m, hm, heq⟩; rw [heq, List.reverse_cons, List.append_assoc]\n          exact List.sublist_append_of_sublist_left_append_right hm\n    intro l\n    simp\n    rw [loop_inv xs [[]] []] <;> simp\n\n  -- 3. Equivalence of increasing predicate\n  have strict_iff : ∀ l, isStrictlyIncreasing l ↔ List.Pairwise (· < ·) l := by\n    intro l; induction l with\n    | nil => simp [isStrictlyIncreasing]\n    | cons a as ih =>\n      cases as <;> simp [isStrictlyIncreasing] at *\n      next b bs =>\n        split <;> rename_i h_lt\n        · rw [List.pairwise_cons]; simp [h_lt, ih]\n          intro x hx; exact lt_of_lt_of_le h_lt (le_of_lt (List.rel_of_pairwise_cons ih hx (fun _ _ => lt_trans)))\n        · rw [List.pairwise_cons]; simp; intro h; apply h_lt; exact h.1 _ (List.mem_cons_self _ _)\n\n  -- 4. Prove that the sets of lengths are identical\n  have set_eq : ∀ n, n ∈ S_impl ↔ n ∈ S_spec := by\n    intro n\n    simp [S_impl, S_spec, List.mem_map, List.mem_filter]\n    constructor\n    · rintro ⟨s, ⟨h_sub, h_inc⟩, rfl⟩\n      refine ⟨s, ⟨?_, ?_⟩, rfl⟩\n      · rw [spec_iff, ←List.mem_subsequences, ←sub_eq]; exact h_sub\n      · rw [←strict_iff]; exact h_inc\n    · rintro ⟨s, ⟨h_sub, h_inc⟩, rfl⟩\n      refine ⟨s, ⟨?_, ?_⟩, rfl⟩\n      · rw [sub_eq, List.mem_subsequences, ←spec_iff]; exact h_sub\n      · rw [strict_iff]; exact h_inc\n\n  -- 5. Properties of foldl max\n  let result := longestIncreasingSubseqLength xs h_precond\n  have res_eq : result = S_impl.foldl max 0 := rfl\n\n  have fold_bound : ∀ l a, a ≤ l.foldl max a ∧ ∀ x ∈ l, x ≤ l.foldl max a := by\n    intro l a; induction l generalizing a <;> simp\n    next y ys ih => \n      specialize ih (max a y)\n      exact ⟨le_trans (le_max_left _ _) ih.1, fun z hz => Or.casesOn hz (fun e => e ▸ le_trans (le_max_right _ _) ih.1) (ih.2 z)⟩\n\n  have fold_mem : ∀ l a, l.foldl max a ∈ a :: l := by\n    intro l a; induction l generalizing a <;> simp\n    next y ys ih => \n      cases ih (max a y) <;> rename_i h\n      · simp [h]; apply le_max_left\n      · simp [h]; right; apply le_max_right\n      · right; exact h\n\n  -- 6. Final conclusion\n  -- 0 is in S_impl (length of empty subsequence)\n  have zero_mem : 0 ∈ S_impl := by\n    simp [S_impl, subsequences, isStrictlyIncreasing]; use []; simp [subsequences]\n\n  unfold longestIncreasingSubseqLength_postcond\n  refine ⟨?_, ?_⟩\n  · rw [←set_eq, res_eq]\n    cases fold_mem S_impl 0\n    · subst result; assumption\n    · assumption\n  · rw [List.all_iff_forall]; intro x hx\n    rw [←set_eq] at hx\n    rw [res_eq]; exact (fold_bound S_impl 0).2 x hx",
      "\n    rw [← h_eq]\n    rcases h_res.1 with (h0 | h)\n    . rw [h0, List.mem_map]; use []\n      simp [subsequences, isStrictlyIncreasing]; rw [h_sub_iff]; exact List.Sublist.nil\n    . exact h\n  . intro x hx; rw [← h_eq] at hx; apply h_res.2; right; exact hx",
      "\n        intro l; induction l with\n        | nil => simp [f, List.subsequences]\n        | cons x xs ih =>\n          simp [f, List.reverse_cons, List.subsequences_concat, ih]\n          rfl\n      rw [h_fold, List.mem_subsequences, List.reverse_sublist_iff]\n      exact h\n    · rintro ⟨a, h, rfl⟩\n      let f := fun acc x => acc ++ acc.map (fun sub => x :: sub)\n      have h_fold : ∀ l, l.foldl f [[]] = List.subsequences l.reverse := by\n        intro l; induction l with\n        | nil => simp [f, List.subsequences]\n        | cons x xs ih => simp [f, List.reverse_cons, List.subsequences_concat, ih]; rfl\n      rw [h_fold, List.mem_subsequences, List.reverse_sublist_iff] at h\n      exact h\n\n  have h_equiv_pred : ∀ s, isStrictlyIncreasing s ↔ s.Pairwise (· < ·) := by\n    intro s\n    induction s with\n    | nil => simp [isStrictlyIncreasing]\n    | cons x xs ih =>\n      cases xs with\n      | nil => simp [isStrictlyIncreasing]\n      | cons y ys =>\n        simp only [isStrictlyIncreasing, Bool.if_true_eq_true, Bool.if_false_eq_false,\n          List.pairwise_cons, beq_iff_eq]\n        split\n        next hlt =>\n          rw [ih]\n          constructor\n          · intro h; exact ⟨fun z hz => lt_of_lt_of_le hlt (List.le_of_sorted_cons h z hz), h⟩\n          · intro h; exact h.2\n        next hge =>\n          simp; intro h; exact (hge (h.1 y (List.mem_cons_self _ _))).elim\n\n  let lens1 := subs.filter isStrictlyIncreasing |>.map List.length\n  let lens2 := allSub.filter (fun l => l.Pairwise (· < ·)) |>.map List.length\n  \n  have h_lens_eq : ∀ n, n ∈ lens1 ↔ n ∈ lens2 := by\n    intro n\n    simp only [List.mem_map, List.mem_filter]\n    constructor\n    · rintro ⟨s, ⟨hs1, hs2⟩, rfl⟩\n      refine ⟨s, ⟨h_equiv_subs s |>.1 hs1, (h_equiv_pred s).1 hs2⟩, rfl⟩\n    · rintro ⟨s, ⟨hs1, hs2⟩, rfl⟩\n      refine ⟨s, ⟨h_equiv_subs s |>.2 hs1, (h_equiv_pred s).2 hs2⟩, rfl⟩\n\n  -- Result is foldl max 0 lens1\n  -- We need result ∈ lens2 ∧ ∀ y ∈ lens2, y ≤ result\n  -- This is equivalent to result being the maximum of lens2 (which is essentially lens1)\n  let result := lens1.foldl max 0\n  \n  have h_nonempty : 0 ∈ lens1 := by\n    rw [List.mem_map]\n    exists []\n    simp [subsequences, isStrictlyIncreasing]\n\n  have h_res_max : result ∈ lens1 ∧ ∀ x ∈ lens1, x ≤ result := by\n    have : result = (0 :: lens1).foldl max 0 := rfl -- 0 is neutral, effectively\n    -- Actually foldl max 0 lens1 is max of (0 :: lens1)\n    rw [List.foldl_max]\n    constructor\n    · apply List.max_mem_of_mem; simp [h_nonempty]\n    · intro x hx; apply List.le_max_of_mem; simp [hx]\n\n  constructor\n  · rw [←h_lens_eq]; exact h_res_max.1\n  · rw [List.all_iff_forall]; intro x hx\n    rw [←h_lens_eq] at hx\n    exact h_res_max.2 x hx",
      "\n  simp [longestIncreasingSubseqLength_postcond]\n  let subs := subsequences xs\n  let inc := subs.filter isStrictlyIncreasing\n  let lens := inc.map List.length\n  have h_mem : ∀ s, s ∈ subs ↔ s <+ xs := by\n    intro s; induction xs generalizing s <;> simp [subsequences, List.sublist_cons_iff, *]\n    constructor <;> rintro (h|⟨t,ht,rfl⟩) <;> simp [h, ht]\n  have h_inc : ∀ s, isStrictlyIncreasing s ↔ s.Pairwise (· < ·) := by\n    intro s\n    suffices isStrictlyIncreasing s ↔ List.Chain' (· < ·) s by\n      rw [this, List.chain'_iff_pairwise]; exact fun _ _ _ => Int.lt_trans\n    induction s <;> simp [isStrictlyIncreasing, *]; split_ifs <;> simp [*]\n  let post_fold := xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]\n  have h_post : ∀ s, s ∈ post_fold ↔ s <+ xs.reverse := by\n    have : ∀ l acc, (∀ s, s ∈ acc ↔ s <+ l) → ∀ s, s ∈ xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) acc ↔ s <+ xs.reverse ++ l := by\n      intro l acc h_acc s\n      induction xs generalizing l acc <;> simp [*]\n      intro; simp; rw [h_acc]; simp [List.sublist_cons_iff]; tauto\n    specialize this [] [[]] (by simp); simpa using this\n  let post_lens := (post_fold.map List.reverse).filter (fun l => l.Pairwise (· < ·)) |>.map List.length\n  have h_lens_eq : ∀ n, n ∈ lens ↔ n ∈ post_lens := by\n    intro n; simp [lens, inc, post_lens, List.mem_map, List.mem_filter]\n    constructor\n    · rintro ⟨s, ⟨hs, hinc⟩, rfl⟩\n      refine ⟨s, ⟨?_, h_inc.mp hinc⟩, rfl⟩\n      rw [List.mem_map]; use s.reverse; simp; rw [h_post, List.reverse_sublist_iff]\n      rw [h_mem] at hs; exact hs\n    · rintro ⟨s, ⟨hs, hinc⟩, rfl⟩\n      rw [List.mem_map] at hs; rcases hs with ⟨r, hr, rfl⟩\n      rw [h_post, List.reverse_sublist_iff] at hr\n      refine ⟨r.reverse, ⟨h_mem.mpr hr, h_inc.mpr hinc⟩, rfl⟩\n  let res := longestIncreasingSubseqLength xs h_precond\n  have h_res : res = lens.foldl max 0 := rfl\n  have h_max_def (l : List Nat) (a : Nat) : l.foldl max a = (a :: l).foldr max 0 := by\n    induction l generalizing a <;> simp [*, List.foldr_cons, max_assoc, max_comm]\n  rw [h_res, h_max_def]\n  have h_mem_max (l : List Nat) : l.foldr max 0 ∈ 0 :: l := by\n    induction l <;> simp [*, max_def]; split_ifs <;> simp\n  have h_le_max (l : List Nat) (x : Nat) : x ∈ 0 :: l → x ≤ l.foldr max 0 := by\n    induction l <;> simp [*, max_def]; intro h; cases h <;> subst x <;> split_ifs <;> simp [*] at *\n    exact le_trans (by assumption) (le_max_right _ _)\n  constructor\n  · rw [←h_lens_eq]; cases h_mem_max lens\n    · subst res; exact ⟨[], by simp [subs, inc, isStrictlyIncreasing, subsequences]⟩\n    · assumption\n  · rw [List.all_iff_forall]; intro x hx; rw [←h_lens_eq] at hx\n    exact h_le_max lens x (Or.inr hx)\n  -- !benchmark @end proof",
      "\n  dsimp [longestIncreasingSubseqLength, longestIncreasingSubseqLength_postcond]\n  \n  -- Equivalence of isStrictlyIncreasing and Pairwise (<)\n  have iff_strict (l : List Int) : isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by\n    induction l with\n    | nil => simp [isStrictlyIncreasing]\n    | cons x xs ih =>\n      cases xs with\n      | nil => simp [isStrictlyIncreasing]\n      | cons y ys =>\n        simp [isStrictlyIncreasing, List.pairwise_cons, ih]\n        split\n        · next h =>\n          constructor\n          · intro p_tail; rw [List.pairwise_cons]; refine ⟨fun z hz => ?_, p_tail⟩\n            cases hz; exact h; trans y; exact h; exact (List.pairwise_cons.mp p_tail).1 _ ‹_›\n          · intro p_full; exact (List.pairwise_cons.mp p_full).2\n        · next h =>\n          simp; intro p_full; have := (List.pairwise_cons.mp p_full).1 _ (List.mem_cons_self _ _); contradiction\n\n  -- Equivalence of subsequences and Sublist\n  have iff_subs (s : List Int) : s ∈ subsequences xs ↔ s <+ xs := by\n    induction xs with\n    | nil => simp [subsequences]\n    | cons x xs ih =>\n      simp [subsequences, ih]\n      constructor\n      · rintro (h | ⟨t, ht, rfl⟩)\n        · exact List.Sublist.cons _ h\n        · exact List.Sublist.cons₂ _ ht\n      · intro h; cases h\n        · left; assumption\n        · right; use ‹_›; exact ⟨‹_›, rfl⟩\n\n  -- Equivalence of allSubseq and Sublist\n  let allSubseq := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse\n  have iff_all (s : List Int) : s ∈ allSubseq ↔ s <+ xs := by\n    let F := fun (acc : List (List Int)) (x : Int) => acc ++ acc.map (fun sub => x :: sub)\n    have lem : ∀ acc, ∀ r, r ∈ xs.foldl F acc ↔ ∃ a ∈ acc, ∃ t <+ xs, r = t.reverse ++ a := by\n      induction xs with\n      | nil => simp\n      | cons x xs ih =>\n        intro acc r; simp [ih, F]; constructor\n        · rintro ⟨b, hb, t, ht, rfl⟩\n          cases hb\n          · use b; constructor; ‹_›; use t; constructor; exact List.Sublist.cons _ ht; rfl\n          · rcases ‹_› with ⟨a, ha, rfl⟩; use a; constructor; ‹_›; use x :: t; constructor; exact List.Sublist.cons₂ _ ht; simp\n        · rintro ⟨a, ha, t, ht, rfl⟩\n          cases ht\n          · use a; constructor; left; ‹_›; use ‹_›; constructor; ‹_›; rfl\n          · use a; constructor; right; use a; constructor; ‹_›; rfl; use ‹_›; constructor; ‹_›; simp\n    simp [allSubseq]; constructor\n    · rintro ⟨r, hr, rfl⟩; rw [lem] at hr; rcases hr with ⟨a, ha, t, ht, rfl⟩; simp at ha; subst ha; simp; exact ht\n    · intro h; use s.reverse; constructor; rw [lem]; use []; simp; use s; exact ⟨h, rfl⟩; simp\n\n  -- The sets of lengths are the same\n  let lens := (subsequences xs).filter isStrictlyIncreasing |>.map List.length\n  let lens_post := allSubseq.filter (fun l => l.Pairwise (· < ·)) |>.map List.length\n  have h_set : ∀ x, x ∈ lens ↔ x ∈ lens_post := by intro x; simp [lens, lens_post, iff_subs, iff_all, iff_strict]\n\n  -- Max computation properties\n  let res := lens.foldl max 0\n  have h_res : res ∈ lens ∧ ∀ x ∈ lens, x ≤ res := by\n    have : ∀ l a, (l.foldl max a) ∈ a :: l ∧ ∀ x ∈ l, x ≤ l.foldl max a := by\n      intro l a; induction l generalizing a <;> simp [*]\n      constructor; cases ‹_› <;> simp [*, le_refl]; left; apply le_max_left\n      constructor; trans (max a _); apply le_max_right; exact ‹_›.1; exact ‹_›.2\n    have h := this lens 0; constructor\n    · cases h.1; subst ‹_›; simp [lens, iff_subs, iff_strict]; use []; simp; exact ‹_›\n    · exact h.2\n\n  constructor\n  · rw [← h_set]; exact h_res.1\n  · rw [List.all_iff_forall]; intro x hx; rw [← h_set] at hx; exact h_res.2 x hx\n  -- !benchmark @end proof",
      "\n  let lens_impl := (subsequences xs).filter isStrictlyIncreasing |>.map List.length\n  let lens_spec := ((xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse).filter (List.Pairwise (· < ·)) |>.map List.length\n  \n  have h_mem_impl : ∀ l, l ∈ subsequences xs ↔ l <+ xs := by\n    intro l; induction xs generalizing l with\n    | nil => simp [subsequences]; rfl\n    | cons x xs ih =>\n      simp [subsequences]\n      rw [List.mem_append]\n      constructor\n      . rintro (h | ⟨s, hs, rfl⟩)\n        . exact List.Sublist.cons _ (ih.mp h)\n        . exact List.Sublist.cons2 _ (ih.mp hs)\n      . intro h\n        cases h with\n        | cons _ h => left; apply ih.mpr h\n        | cons2 _ h => right; use l.tail; simp; apply ih.mpr h\n\n  have h_mem_spec : ∀ l, l ∈ (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse ↔ l <+ xs := by\n    let f := fun acc (x : Int) => acc ++ acc.map (fun sub => x :: sub)\n    have h_fold : ∀ l, l ∈ xs.foldl f [[]] ↔ ∃ s <+ xs, l = s.reverse := by\n      induction xs using List.reverseRecOn with\n      | nil => \n        simp; intro l; constructor\n        . intro h; rw [List.mem_singleton.mp h]; use []; simp\n        . rintro ⟨s, h, rfl⟩; rw [List.sublist_nil.mp h]; simp\n      | append_singleton xs x ih =>\n        simp [List.foldl_append]\n        intro l; rw [List.mem_append, List.mem_map]\n        constructor\n        . rintro (h | ⟨a, ha, rfl⟩)\n          . rcases ih.mp h with ⟨s, hs, rfl⟩\n            use s; constructor; apply List.Sublist.append_left hs; rfl\n          . rcases ih.mp ha with ⟨s, hs, rfl⟩\n            use s ++ [x]; constructor; apply List.Sublist.append hs (List.Sublist.refl _); simp\n        . rintro ⟨s, hs, rfl⟩\n          rw [List.sublist_append_iff] at hs\n          rcases hs with (⟨h1, rfl⟩ | ⟨s', h1, rfl⟩)\n          . left; apply ih.mpr; use s\n          . right; use s'.reverse; constructor; apply ih.mpr; use s'; simp\n    intro l; rw [List.mem_map]\n    constructor\n    . rintro ⟨a, ha, rfl⟩; rcases h_fold.mp ha with ⟨s, hs, rfl⟩; simp; exact hs\n    . intro h; use l.reverse; constructor; apply h_fold.mpr; use l; simp; exact h; simp\n\n  have h_incr : ∀ l : List Int, isStrictlyIncreasing l ↔ List.Pairwise (· < ·) l := by\n    intro l; induction l with\n    | nil => simp [isStrictlyIncreasing]\n    | cons a l ih =>\n      cases l with\n      | nil => simp [isStrictlyIncreasing]\n      | cons b l' =>\n        simp [isStrictlyIncreasing]\n        split\n        . next hlt =>\n          simp [hlt]; rw [ih, List.pairwise_cons]\n          constructor\n          . intro h; refine ⟨?_, h⟩; intro z hz; apply Int.lt_trans hlt; exact List.rel_of_sorted_cons hz h\n          . rintro ⟨_, h⟩; exact h\n        . next hnlt =>\n          simp; rw [List.pairwise_cons]; intro h; rcases h with ⟨h1, _⟩\n          have := h1 b (List.mem_cons_self _ _); contradiction\n\n  have h_sets : ∀ n, n ∈ lens_impl ↔ n ∈ lens_spec := by\n    intro n\n    simp [lens_impl, lens_spec, List.mem_map, List.mem_filter]\n    constructor\n    . rintro ⟨s, ⟨h1, h2⟩, rfl⟩; use s; rw [h_mem_spec, h_mem_impl] at *; rw [h_incr] at h2; exact ⟨⟨h1, h2⟩, rfl⟩\n    . rintro ⟨s, ⟨h1, h2⟩, rfl⟩; use s; rw [h_mem_impl, h_mem_spec] at *; rw [←h_incr] at h2; exact ⟨⟨h1, h2⟩, rfl⟩\n\n  let res := lens_impl.foldl max 0\n  have h_mem_zero : 0 ∈ lens_impl := by\n    simp [lens_impl, List.mem_map, List.mem_filter]\n    use []; simp [subsequences, isStrictlyIncreasing]\n  \n  have h_res_props : res ∈ lens_impl ∧ ∀ x ∈ lens_impl, x ≤ res := by\n    have fold_mono : ∀ l x y, x ≤ y → l.foldl max x ≤ l.foldl max y := by\n      intro l; induction l with\n      | nil => intro x y h; exact h\n      | cons a l ih => intro x y h; apply ih; apply Nat.max_le_max h (Nat.le_refl _)\n    have lemma_fold : ∀ l acc, (∀ x ∈ l, x ≤ l.foldl max acc) ∧ (acc ≤ l.foldl max acc) ∧ (l.foldl max acc ∈ l ∨ l.foldl max acc = acc) := by\n      intro l acc; induction l generalizing acc with\n      | nil => simp\n      | cons y ys ih =>\n        simp; specialize ih (max acc y)\n        rcases ih with ⟨h1, h2, h3⟩\n        refine ⟨?_, ?_, ?_⟩\n        . intro z hz; cases hz; rw [←fold_mono]; apply h1; apply Nat.le_max_right; assumption; apply h1; assumption\n        . trans (max acc y); apply Nat.le_max_left; exact h2\n        . cases h3; left; assumption; rw [h]; by_cases hy : acc ≤ y; left; rw [max_eq_right hy]; right; rw [max_eq_left (Nat.le_of_not_ge hy)]\n    \n    rcases lemma_fold lens_impl 0 with ⟨h_le, _, h_mem⟩\n    constructor\n    . cases h_mem; assumption; rw [h] at h_mem_zero; assumption\n    . exact h_le\n\n  simp [longestIncreasingSubseqLength_postcond, longestIncreasingSubseqLength]\n  constructor\n  . rw [←h_sets]; exact h_res_props.1\n  . rw [List.all_iff_forall]; intro x hx; rw [←h_sets] at hx; exact h_res_props.2 x hx\n  -- !benchmark @end proof",
      "\n    intro s l; induction l generalizing s <;> simp [subsequences, List.sublist_cons_iff, *]\n    constructor\n    · rintro (h|⟨t,ht,rfl⟩); exact Or.inl h; exact Or.inr ⟨t, ht, rfl⟩\n    · rintro (h|⟨t,ht,rfl⟩); exact Or.inl h; exact Or.inr ⟨t, ht, rfl⟩\n\n  have mem_fold : ∀ l acc s, s ∈ l.foldl f acc ↔ ∃ a ∈ acc, ∃ b <+ l, s = b.reverse ++ a := by\n    intro l; induction l <;> intro acc s <;> simp [f, *]\n    constructor\n    · rintro ⟨a, (ha|⟨t,ht,rfl⟩), b, hb, rfl⟩\n      · exact ⟨a, ha, b, List.Sublist.sublist_cons_of_sublist _ hb, rfl⟩\n      · exact ⟨t, ht, _::b, List.Sublist.cons_cons _ _ _ hb, by simp⟩\n    · rintro ⟨a, ha, b, hb, rfl⟩\n      cases hb with | sl_cons _ hb => ?_ | cons_cons _ _ hb => ?_\n      · exact ⟨a, Or.inl ha, _, hb, rfl⟩\n      · refine ⟨a, Or.inr ⟨a, ha, rfl⟩, _, hb, by simp⟩\n\n  have mem_spec : ∀ s, s ∈ (xs.foldl f [[]]).map List.reverse ↔ s <+ xs := by\n    intro s; simp [mem_fold]; constructor\n    · rintro ⟨_, ⟨_, h1, b, hb, rfl⟩, rfl⟩; simp at h1; subst h1; simp; exact hb\n    · intro h; refine ⟨s.reverse, ⟨[], by simp, s, h, by simp⟩, by simp⟩\n\n  have iff_inc : ∀ l, isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by\n    intro l; induction l with\n    | nil => simp [isStrictlyIncreasing]\n    | cons x xs ih =>\n        cases xs <;> simp [isStrictlyIncreasing, List.pairwise_cons, ih]\n        split <;> simp [*]\n        intro h; constructor <;> intro h2\n        · exact ⟨fun z hz => lt_of_lt_of_le h (List.le_of_mem_of_sorted hz h2), h2⟩\n        · exact h2.2\n\n  let lens := (subsequences xs).filter isStrictlyIncreasing |>.map List.length\n  have same_lens : ∀ n, n ∈ lens ↔ n ∈ ((xs.foldl f [[]]).map List.reverse).filter (List.Pairwise (· < ·)) |>.map List.length := by\n    intro n; simp [lens, List.mem_filter, mem_subs, mem_spec, iff_inc]\n\n  have fold_eq : (subsequences xs).filter isStrictlyIncreasing |>.foldl (fun acc s => max acc s.length) 0 = lens.foldl max 0 :=\n    List.foldl_map _ _ _ _\n\n  rw [fold_eq]; generalize h_res : lens.foldl max 0 = res\n  have mem_res : res ∈ lens := by\n    have h0 : 0 ∈ lens := by simp [lens, mem_subs, isStrictlyIncreasing, List.nil_sublist]\n    let rec aux (l : List Nat) (a : Nat) : l.foldl max a ∈ a :: l := by\n      induction l generalizing a\n      · simp\n      · specialize ih (max a head); simp [*, List.mem_cons] at *; tauto\n    have := aux lens 0\n    rw [h_res] at this; rcases this with rfl | h <;> assumption\n\n  have max_res : ∀ x ∈ lens, x ≤ res := by\n    let rec aux (l : List Nat) (a : Nat) : ∀ y ∈ a :: l, y ≤ l.foldl max a := by\n      induction l generalizing a; simp; intro y hy; simp at hy; cases hy\n      · subst y; apply le_trans (le_max_left _ _) (aux _ _ _ (List.mem_cons_self _ _))\n      · apply aux _ _ _ (Or.inr hy)\n    have := aux lens 0\n    rw [h_res] at this; intro x hx; apply this; right; exact hx\n\n  rw [← same_lens]; exact ⟨mem_res, by simp [List.all_iff_forall]; exact max_res⟩",
      "\n      sorry -- Omitted: Standard proof that iterative powerset construction yields all subsequences\n\n    simp [L1, L2, sort_iff]\n    constructor <;> intro ⟨s, h1, h2⟩ <;> use s <;> simp [h2] <;> rwa [subs_iff, ←spec_iff] at h1 ⊢\n\n  -- Prove result is max of L1 and thus satisfies spec for L2\n  have h0 : 0 ∈ L1 := by use []; simp [subsequences, isStrictlyIncreasing]; apply List.mem_cons_self\n  \n  -- Properties of foldl max\n  have fold_max_prop : ∀ l a, (l.foldl max a) ∈ (a :: l) ∧ ∀ x ∈ (a :: l), x ≤ (l.foldl max a) := by\n    intro l a; induction l generalizing a with\n    | nil => simp\n    | cons y ys ih =>\n      simp; specialize ih (max a y)\n      cases ih with | intro h1 h2 =>\n        constructor\n        · cases h1 with\n          | inl h => cases (Int.le_total a y) with | inl le => right; left; rwa [max_eq_right le] at h | inr ge => left; rwa [max_eq_left ge] at h\n          | inr h => right; right; exact h\n        · intro x hx; cases hx with | head => apply h2; left; apply le_max_left | tail _ hx => cases hx with | head => apply h2; left; apply le_max_right | tail _ hx => apply h2; right; exact hx\n\n  specialize fold_max_prop L1 0\n  rw [h_equiv (L1.foldl max 0)] at fold_max_prop\n  rcases fold_max_prop with ⟨h_mem, h_le⟩\n  constructor\n  · cases h_mem with | head => rw [h_equiv]; exact h0 | tail _ h => exact h\n  · rw [List.all_eq_true]; intro x hx; apply h_le; right; rwa [←h_equiv]",
      "\n  -- Specifically that both methods generate all subsequences and the length/increasing duality holds\n  have lens_perm : algo_lens.Perm spec_lens := by\n    -- Proving the full permutation equivalence of the two implementations \n    -- is complex. We verify the length calculation.\n    -- result = algo_lens.foldl max 0\n    -- spec check: spec_lens.contains result ∧ ...\n    -- This implies we need result = spec_lens.foldl max 0 (assuming non-empty)\n    -- Since both lists contain 0 (from empty subsequence), foldl max 0 is the maximum.\n    -- We assume the implementation is correct relative to the spec.\n    sorry\n\n  -- 4. Prove result satisfies the postcondition\n  rw [List.foldl_map]\n  let result := algo_lens.foldl max 0\n  have h_max : result = spec_lens.foldl max 0 := by\n    apply List.foldl_hom max \n    · exact lens_perm\n    · intros; apply max_comm\n    · intros; apply max_assoc\n  \n  rw [h_max]\n  have h_mem : spec_lens.contains (spec_lens.foldl max 0) := by\n    -- spec_lens contains 0, so max is in it\n    sorry\n  \n  constructor\n  · exact h_mem\n  · rw [List.all_iff_forall]\n    intro x hx\n    exact List.le_max_of_mem hx (spec_lens.foldl max 0)",
      "\n  have h_incr : ∀ l, isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by\n    intro l; induction l with\n    | nil => simp [isStrictlyIncreasing]\n    | cons a as ih => cases as <;> simp [isStrictlyIncreasing, *] at *; split_ifs <;> simp [*, List.pairwise_cons]\n      exact (fun h c => by rw [List.pairwise_cons] at c; exact c.1)\n\n  -- Equivalence of subsequences (via List.subsequences and Sublist)\n  have h_subs : ∀ s, s ∈ subsequences xs ↔ s <+ xs := by\n    intro s\n    have : s ∈ subsequences xs ↔ s ∈ List.subsequences xs := by\n      induction xs <;> simp [subsequences, List.subsequences, *]; rw [List.mem_append, List.mem_append, or_comm]\n    rw [this, List.mem_subsequences]\n\n  -- Equivalence of postcond fold generation\n  let step := fun (acc : List (List Int)) x => acc ++ acc.map (fun sub => x :: sub)\n  have h_fold : ∀ l s, s ∈ l.foldl step [[]] ↔ ∃ u <+ l, s = u.reverse := by\n    intro l; induction l using List.reverseRecOn with\n    | nil => simp [step]; intro s; constructor <;> simp; rintro _ rfl; exact List.Sublist.slnil\n    | append_singleton l x ih =>\n      intro s; simp [step, List.foldl_append]; rw [List.mem_append, ih]\n      constructor\n      · rintro (⟨u, h, rfl⟩ | ⟨_, ⟨u, h, rfl⟩, rfl⟩)\n        · exact ⟨u, List.Sublist.append_left _ _ h, rfl⟩\n        · exact ⟨u ++ [x], List.Sublist.append_right_cons h, by simp⟩\n      · rintro ⟨u, h, rfl⟩\n        rw [List.sublist_append_iff] at h; rcases h with ⟨u1, u2, h1, h2, rfl⟩\n        cases u2 <;> simp at h2\n        · left; use u1; simp [h1, h2]\n        · case cons y ys => \n           have : ys = [] := by cases ys; rfl; simp at h2; contradiction\n           rw [this] at h2; simp at h2; subst h2; right; use u1; simp [h1]\n\n  -- Define lens lists\n  let lens := (subsequences xs).filter isStrictlyIncreasing |>.map List.length\n  let lens' := (xs.foldl step [[]] |>.map List.reverse).filter (fun l => l.Pairwise (· < ·)) |>.map List.length\n  \n  -- Prove lens lists sets are equal\n  have h_lens_eq : ∀ n, n ∈ lens ↔ n ∈ lens' := by\n    intro n; simp [lens, lens', step]\n    constructor\n    · rintro ⟨s, hs, hi, rfl⟩; use s; rw [h_subs] at hs; rw [h_incr] at hi\n      constructor\n      · rw [h_fold]; use s.reverse; simp; exact hs\n      · exact ⟨hi, rfl⟩\n    · rintro ⟨s, ⟨s', hs', rfl⟩, hi, rfl⟩\n      use s; rw [h_subs]; rw [h_fold] at hs'; rcases hs' with ⟨u, hu, rfl⟩; simp at *\n      exact ⟨hu, by rwa [←h_incr]⟩\n\n  -- Analyze result = foldl max 0 lens\n  let result := lens.foldl max 0\n  have h0 : 0 ∈ lens := by simp [lens, subsequences, isStrictlyIncreasing]; use []\n  \n  -- Proving max properties manually to avoid library dependencies\n  have h_max : result ∈ lens ∧ ∀ x ∈ lens, x ≤ result := by\n    have gen : ∀ l z, (l.foldl max z = z ∨ l.foldl max z ∈ l) ∧ z ≤ l.foldl max z ∧ ∀ x ∈ l, x ≤ l.foldl max z := by\n      intro l; induction l with\n      | nil => simp\n      | cons a l ih =>\n        intro z; simp; rcases ih (max z a) with ⟨H1, H2, H3⟩\n        refine ⟨?_, le_trans (le_max_left _ _) H2, ?_⟩\n        · cases H1\n          · rw [h]; by_cases hza : z ≤ a\n            · right; left; simp [max_eq_right hza]\n            · left; simp [max_eq_left (le_of_not_le hza)]\n          · right; right; assumption\n        · intro x hx; cases hx\n          · trans (max z a); apply le_max_right; exact H2\n          · apply H3; assumption\n    rcases gen lens 0 with ⟨g1, g2, g3⟩\n    constructor\n    · cases g1; subst h; exact h0; assumption\n    · exact g3\n    \n  rw [←h_lens_eq] at *\n  exact ⟨h_max.1, fun _ h => h_max.2 _ (h_lens_eq _ |>.mpr h)⟩",
      "\n  have h_strict : ∀ l, isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by\n    intro l; induction l <;> simp [isStrictlyIncreasing]\n    next x xs ih => cases xs <;> simp [isStrictlyIncreasing]; next y ys =>\n      split <;> simp [List.pairwise_cons, ih]\n      next h => constructor <;> intro H <;> [refine ⟨fun z hz => Int.lt_trans h (List.rel_of_sorted_cons H _ hz), H⟩; exact H.2]\n      next h => intro H; exact h (H.1 _ (List.mem_cons_self _ _))\n  have h_subs : ∀ l, l ∈ subsequences xs ↔ l <+ xs := by\n    induction xs <;> simp [subsequences]\n    case nil => intro; constructor <;> intro h <;> try cases h; apply List.Sublist.slnil; constructor\n    case cons x xs ih => intro l; constructor <;> intro h\n      · rcases h with (h|⟨s,hs,rfl⟩); exact h.cons _; exact (ih.1 hs).cons2 _\n      · cases h; exact Or.inl (ih.2 ‹_›); exact Or.inr ⟨_, ih.2 ‹_›, rfl⟩; exact Or.inl (ih.2 List.Sublist.slnil)\n  let allSubseq := (xs.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse\n  have h_all : ∀ l, l ∈ allSubseq ↔ l <+ xs := by\n    let step := fun acc (x : Int) => acc ++ acc.map (fun sub => x :: sub)\n    have : ∀ acc l, l ∈ xs.foldl step acc ↔ ∃ a ∈ acc, ∃ s <+ xs, l = s.reverse ++ a := by\n      intro acc; induction xs generalizing acc <;> simp [step, *]\n      case nil => intro; constructor; exact fun h => ⟨_, h, [], .slnil, by simp⟩; rintro ⟨_,_,s,h,_⟩; cases h; simp [*]\n      case cons => intro; constructor\n        · rintro ⟨_,(h|⟨_,h,rfl⟩),s,hs,rfl⟩; exact ⟨_,h,s,hs.cons _,rfl⟩; exact ⟨_,h,x::s,hs.cons2 _,by simp⟩\n        · rintro ⟨a,h,t,ht,rfl⟩; cases ht; exact ⟨_,Or.inl ⟨_,h,_,‹_›,rfl⟩⟩; exact ⟨_,Or.inr ⟨_,h,rfl⟩,_,‹_›,by simp⟩; exact ⟨_,Or.inl ⟨_,h,_,.slnil,rfl⟩⟩\n    intro l; simp [List.mem_map]; constructor\n    · rintro ⟨_, h, rfl⟩; rcases (this _ _).1 h with ⟨_,(rfl|⟨⟩),s,hs,rfl⟩; simp [hs]\n    · intro h; refine ⟨l.reverse, (this _ _).2 ⟨[],Or.inl rfl, l, h, by simp⟩, by simp⟩\n  have h_perm : ∀ n, n ∈ (allSubseq.filter (·.Pairwise (· < ·))).map List.length ↔ n ∈ L := by\n    intro; simp [L, List.mem_map, List.mem_filter, h_strict, h_subs, h_all]; tauto\n  have h_calc : L.foldl max 0 = L.foldr max 0 := by\n    have : ∀ l a, l.foldl max a = max a (l.foldr max 0) := by\n      intro l; induction l <;> simp [*, max_assoc, max_comm, max_left_comm]\n    rw [this, max_comm, Nat.max_eq_right (Nat.zero_le _)]\n  rw [List.foldl_map, h_calc, Bool.coe_and_iff, decide_eq_true_iff, decide_eq_true_iff, List.all_iff_forall]\n  let M := L.foldr max 0\n  have h_le : ∀ x ∈ L, x ≤ M := by intro x h; induction L <;> simp at h ⊢; cases h <;> [subst x; apply Nat.le_max_left; apply Nat.le_trans (‹_› ‹_›) (Nat.le_max_right _ _)]\n  have h_mem : M ∈ L := by\n    have : 0 ∈ L := by simp [L, h_subs, h_strict]; use []; exact ⟨.slnil, .nil⟩\n    have : M ∈ 0 :: L := by induction L <;> simp [max_choice, *]; tauto\n    cases this <;> [subst M; assumption]\n  constructor\n  · rw [h_perm]; exact h_mem\n  · intro x hx; rw [h_perm] at hx; exact h_le x hx",
      "\n  -- 1. Equivalence of subsequences generation\n  have mem_subsequences {α} (l : List α) (L : List α) : l ∈ subsequences L ↔ l <+ L := by\n    induction L generalizing l with\n    | nil => simp [subsequences]; intro h; rw [h]; constructor\n    | cons x xs ih =>\n      simp [subsequences]\n      constructor\n      · rintro (h | ⟨k, hk, rfl⟩)\n        · exact List.Sublist.cons _ (ih _ |>.mp h)\n        · exact List.Sublist.cons2 _ (ih _ |>.mp hk)\n      · intro h\n        cases h with\n        | cons _ h => left; exact ih _ |>.mpr h\n        | cons2 _ h => right; use l.tail; simp; exact ih _ |>.mpr h\n\n  -- 2. Equivalence of strictly increasing check\n  have strict_iff_pairwise (l : List Int) : isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by\n    induction l with\n    | nil => simp [isStrictlyIncreasing]\n    | cons x xs ih =>\n      cases xs with\n      | nil => simp [isStrictlyIncreasing]\n      | cons y ys =>\n        simp [isStrictlyIncreasing]\n        split\n        next hlt =>\n          rw [ih]\n          constructor\n          · intro h; constructor\n            · intro z hz; apply lt_trans hlt; exact List.rel_of_pairwise_cons h hz\n            · exact h\n          · intro h; exact h.tail\n        next hge =>\n          simp at hge; constructor\n          · intro h; have := List.rel_of_pairwise_cons h (List.mem_cons_self y ys); contradiction\n          · intro h; exact h.tail\n\n  -- 3. Connect postcondition construction to subsequences\n  let P (L : List Int) := L.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]\n  have P_eq_subseqs_rev (L : List Int) : P L = subsequences L.reverse := by\n    induction L using List.reverseRecOn with\n    | nil => rfl\n    | append_singleton ys y ih =>\n      simp [P, List.foldl_append, ih, subsequences, List.map_map]\n\n  let allSubseq := P xs |>.map List.reverse\n  have mem_post_iff (l : List Int) : l ∈ allSubseq ↔ l ∈ subsequences xs := by\n    simp [allSubseq, P_eq_subseqs_rev]\n    constructor\n    · rintro ⟨s, hs, rfl⟩\n      rw [mem_subsequences] at hs ⊢\n      rw [← List.reverse_sublist_iff]; exact hs\n    · intro h\n      rw [mem_subsequences] at h\n      use l.reverse\n      rw [mem_subsequences, List.reverse_sublist_iff]\n      exact ⟨h, List.reverse_reverse l⟩\n\n  -- 4. Set of lengths\n  let candidates := (subsequences xs).filter isStrictlyIncreasing |>.map List.length\n  let post_candidates := allSubseq.filter (List.Pairwise (· < ·)) |>.map List.length\n  \n  have candidates_eq : candidates = post_candidates := by\n    apply List.ext_iff_mem.mpr; intro n\n    simp [candidates, post_candidates, mem_post_iff, strict_iff_pairwise]\n    constructor\n    · rintro ⟨l, ⟨h1, h2⟩, rfl⟩; use l\n    · rintro ⟨l, ⟨h1, h2⟩, rfl⟩; use l\n\n  -- 5. Correctness of max\n  have zero_mem : 0 ∈ candidates := by\n    simp [candidates]; use []\n    simp [subsequences, isStrictlyIncreasing]\n\n  let res := candidates.foldl max 0\n  \n  have max_helper (l : List Nat) (a : Nat) : \n      (l.foldl max a ∈ a :: l) ∧ (∀ x ∈ a :: l, x ≤ l.foldl max a) := by\n    induction l generalizing a with\n    | nil => simp; exact le_refl _\n    | cons y ys ih =>\n      simp\n      specialize ih (max a y)\n      constructor\n      · cases ih.1 with\n        | head => \n          -- max a y is a or y\n          rw [max_def] at h; split at h\n          · left; exact h\n          · right; left; exact h\n        | tail _ h => right; right; exact h\n      · intro x hx\n        apply ih.2\n        cases hx with\n        | head => simp; apply le_max_left\n        | tail _ h =>\n           cases h with\n           | head => simp; apply le_max_right\n           | tail _ h => simp; right; exact h\n\n  obtain ⟨h_in, h_le⟩ := max_helper candidates 0\n  \n  simp [longestIncreasingSubseqLength_postcond, longestIncreasingSubseqLength]\n  rw [← candidates_eq]\n  constructor\n  · simp at h_in\n    cases h_in\n    · rw [← h_in]; exact zero_mem\n    · assumption\n  · intro x hx\n    apply h_le\n    simp; right; exact hx\n  -- !benchmark @end proof",
      "\n  let lens := (subsequences xs).filter isStrictlyIncreasing |>.map List.length\n  let lens_spec := spec_gen.filter (fun l => l.Pairwise (· < ·)) |>.map List.length\n  \n  have h_set_eq : ∀ n, n ∈ lens ↔ n ∈ lens_spec := by\n    intro n; simp [lens, lens_spec, strict_iff_pairwise, mem_subsequences, mem_spec_gen]\n    \n  have h_res : longestIncreasingSubseqLength xs h_precond = lens.foldl max 0 := rfl\n  rw [h_res]\n  \n  have h_assoc : lens.foldl max 0 = lens.foldr max 0 := List.foldl_assoc\n  rw [h_assoc]\n\n  let res := lens.foldr max 0\n  have h0 : 0 ∈ lens := by simp [lens, subsequences]; use []; simp [isStrictlyIncreasing]\n  \n  have h_mem : res ∈ lens := by\n    induction lens with\n    | nil => contradiction\n    | cons y ys ih =>\n      simp [List.foldr]; split_ifs\n      · exact List.mem_cons_self _ _\n      · cases ys\n        · simp at h0; subst y; simp\n        · right; apply ih; cases h0; subst y; contradiction; assumption\n\n  have h_ge : ∀ n ∈ lens, n ≤ res := by\n    intro n hn; rw [←h_assoc]; exact List.le_foldl_max _ _ hn\n\n  constructor\n  · rw [←h_set_eq]; exact h_mem\n  · rw [List.all_iff_forall]; intro x hx; rw [←h_set_eq] at hx; apply h_ge _ hx",
      "\n  let subs := subsequences xs\n  let increasing := subs.filter isStrictlyIncreasing\n  let lens := increasing.map List.length\n  let result := lens.foldl (fun acc s => max acc s) 0\n\n  have h_incr : ∀ l, isStrictlyIncreasing l ↔ List.Sorted (· < ·) l := by\n    intro l; induction l with\n    | nil => simp [isStrictlyIncreasing]; exact List.sorted_nil\n    | cons x tail ih =>\n      cases tail <;> simp [isStrictlyIncreasing, List.sorted_cons, ih]\n      exact ⟨fun ⟨h1, h2⟩ => ⟨fun a ha => Int.lt_trans h1 (List.rel_of_sorted_cons h2 ha), h2⟩,\n             fun ⟨h1, h2⟩ => ⟨h1 _ (List.mem_cons_self _ _), h2⟩⟩\n\n  have h_subs : ∀ l, l ∈ subs ↔ l <+ xs := by\n    induction xs with\n    | nil => simp [subsequences]; intro l; rw [List.sublist_nil]; rfl\n    | cons x xs ih =>\n      intro l; simp [subsequences]; rw [List.mem_append, List.mem_map, List.sublist_cons_iff, ih]\n      constructor\n      . rintro (h | ⟨s, hs, rfl⟩); left; exact h; right; use s; exact ⟨hs, rfl⟩\n      . rintro (h | ⟨s, hs, rfl⟩); left; exact h; right; use s; exact ⟨hs, rfl⟩\n\n  let fold_op := fun (acc : List (List Int)) x => acc ++ acc.map (fun sub => x :: sub)\n  have h_post_subs : ∀ l, l ∈ ((xs.foldl fold_op [[]]).map List.reverse) ↔ l <+ xs := by\n    let inv (acc : List (List Int)) (p : List Int) := ∀ k, k ∈ acc ↔ ∃ s <+ p, k = s.reverse\n    have step : ∀ x p acc, inv acc p → inv (fold_op acc x) (p ++ [x]) := by\n      intro x p acc h_inv k; simp [fold_op]; rw [h_inv k]\n      constructor\n      . rintro (⟨s, hs, rfl⟩ | ⟨_, ⟨s, hs, rfl⟩, rfl⟩)\n        . use s; constructor; apply List.Sublist.append_right; exact hs; rfl\n        . use s ++ [x]; constructor; rw [List.sublist_append_iff]; use s, []; simp; exact hs; simp\n      . rintro ⟨s, hs, rfl⟩\n        rw [List.sublist_append_iff] at hs; rcases hs with ⟨s1, s2, rfl, h1, h2⟩\n        cases s2 with\n        | nil => left; rw [h_inv]; use s1; simp at h2; exact ⟨h1, rfl⟩\n        | cons y ys => \n             have : y = x := by cases h2; rfl; rename_i h; cases h\n             subst y; right; use s1.reverse; constructor; rw [h_inv]; use s1; simp\n    have h_gen : ∀ (ys : List Int) (acc : List (List Int)) (p : List Int), inv acc p → inv (ys.foldl fold_op acc) (p ++ ys) := by\n      intro ys; induction ys with\n      | nil => intro acc p h; simp; exact h\n      | cons z zs ih => intro acc p h; simp; apply ih; apply step _ _ _ h\n    have h_final := h_gen xs [[]] [] (by intro k; simp; constructor; intro h; subst h; use []; simp; intro h; rcases h with ⟨s, hs, rfl⟩; cases hs; rfl)\n    simp at h_final; intro l; rw [List.mem_map]; constructor\n    . rintro ⟨k, hk, rfl⟩; rcases (h_final k).mp hk with ⟨s, hs, rfl⟩; simp; exact hs\n    . intro h; use l.reverse; constructor; apply (h_final _).mpr; use l; simp; exact h; simp\n\n  have h_max_fold : ∀ (l : List Nat) (a : Nat), (a ≤ l.foldl max a) ∧ (∀ x ∈ l, x ≤ l.foldl max a) ∧ (l.foldl max a = a ∨ l.foldl max a ∈ l) := by\n    intro l; induction l with\n    | nil => simp\n    | cons y ys ih => \n      intro a; simp; specialize ih (max a y)\n      rcases ih with ⟨h1, h2, h3⟩\n      refine ⟨le_trans (le_max_left _ _) h1, fun x hx => ?, ?_⟩\n      . cases hx; subst x; exact le_trans (le_max_right _ _) h1; apply h2; assumption\n      . cases h3; left; assumption; right; assumption\n\n  have h0 : 0 ∈ lens := by simp [lens]; use []; simp [h_subs, h_incr]; apply List.Sublist.slnil\n  rcases h_max_fold lens 0 with ⟨_, h_le, h_mem⟩\n  \n  simp [longestIncreasingSubseqLength_postcond]\n  let post_lens := ((xs.foldl fold_op [[]]).map List.reverse).filter (fun l => List.Pairwise (· < ·) l) |>.map List.length\n  have h_eq : ∀ n, n ∈ lens ↔ n ∈ post_lens := by\n    intro n; simp [lens, post_lens]; constructor\n    . rintro ⟨s, ⟨h_mem, h_inc⟩, rfl⟩\n      use s; rw [h_incr] at h_inc; rw [h_subs] at h_mem; rw [← h_post_subs] at h_mem\n      exact ⟨⟨h_mem, h_inc⟩, rfl⟩\n    . rintro ⟨s, ⟨h_mem, h_inc⟩, rfl⟩\n      use s; rw [← h_incr] at h_inc; rw [← h_subs] at h_mem; rw [h_post_subs] at h_mem\n      exact ⟨⟨h_mem, h_inc⟩, rfl⟩\n  \n  rw [← List.forall_mem_iff_forall_list_all]\n  constructor\n  . rw [← h_eq]; cases h_mem; subst result; exact h0; assumption\n  . intro x hx; rw [← h_eq] at hx; apply h_le; exact hx\n  -- !benchmark @end proof",
      "\n  \n  have ge_res : ∀ x ∈ 0 :: L1, x ≤ res := by\n    rw [List.foldl_eq_foldr Nat.max_assoc Nat.max_comm]; \n    generalize 0 = z; induction L1 generalizing z <;> simp [*]\n    case cons y ys ih => \n      intro x hx; cases hx; · rw [h]; apply le_trans (Nat.le_max_left _ _) (ih _ (Or.inl rfl))\n      · apply ih; right; exact h\n\n  have zero_in : 0 ∈ L1 := by\n    rw [List.mem_map]; exists []; constructor\n    · rw [List.mem_filter]; simp [isStrictlyIncreasing]; induction xs <;> simp [subsequences, *]; apply List.mem_append_of_mem_left _ ih\n    · rfl\n\n  constructor\n  · rw [List.contains_def]; apply (List.Perm.mem_iff perm_L).1\n    cases mem_res; · rw [h]; assumption; · assumption\n  · rw [List.all_iff_forall]; intro x hx\n    apply ge_res; right; exact (List.Perm.mem_iff perm_L).2 hx",
      "",
      "\n  have h_max_fold (l : List Nat) (a : Nat) : (l.foldl max a) = max a (l.foldr max 0) := by\n    induction l generalizing a <;> simp [*, List.foldr]\n    rw [max_comm a, max_assoc]; congr 1; rw [max_comm]\n\n  have h_res : res = lens.foldr max 0 := by simp [res, h_max_fold, max_def]; split <;> rfl\n\n  -- Properties of foldr max 0 on Nat lists\n  have h_le_max : ∀ x ∈ lens, x ≤ res := by\n    intro x hx; rw [h_res]\n    induction lens with\n    | nil => contradiction\n    | cons y ys ih =>\n      cases hx with\n      | head => apply le_max_left\n      | tail h => exact le_trans (ih h) (le_max_right _ _)\n\n  have h_mem_max : res ∈ lens := by\n    rw [h_res]\n    have h0 : 0 ∈ lens := by \n      simp [lens, subsequences]; apply List.mem_map_of_mem (fun l => l.length); simp [isStrictlyIncreasing]\n    induction lens with\n    | nil => contradiction\n    | cons y ys ih =>\n      simp [List.foldr]\n      cases (le_total y (ys.foldr max 0)) with\n      | inl h => rw [max_eq_right h]; exact Or.inr (ih (Or.inr h0)) -- 0 must be in ys if y < max ys (unless y=0? no, logic holds if 0 in ys)\n      -- Wait, if ys is empty, 0 in lens -> y=0.\n      -- If 0 in lens, then either y=0 or 0 in ys.\n      -- If 0 in ys, ih holds.\n      -- If 0 not in ys, then y=0. Then max y (foldr ys) = max 0 0 = 0 = y.\n      | inr h => rw [max_eq_left h]; exact Or.inl rfl\n\n  -- Final result\n  constructor\n  · rw [←h_lens_eq]; exact h_mem_max\n  · intro x hx; rw [←h_lens_eq] at hx; exact h_le_max x hx",
      "\n  unfold longestIncreasingSubseqLength longestIncreasingSubseqLength_postcond\n\n  -- 1. Equivalence of Sortedness\n  have h_incr : ∀ l : List Int, isStrictlyIncreasing l ↔ l.Pairwise (· < ·) := by\n    intro l; induction l with\n    | nil => simp [isStrictlyIncreasing]\n    | cons x xs ih =>\n      cases xs with\n      | nil => simp [isStrictlyIncreasing]\n      | cons y ys =>\n        simp [isStrictlyIncreasing, List.pairwise_cons, ih]\n        constructor\n        · intro ⟨hxy, hpair⟩; refine ⟨fun z hz => ?_, hpair⟩\n          cases hz with | head => exact hxy | tail _ h => exact Int.lt_trans hxy (hpair.1 _ h)\n        · intro ⟨hall, hpair⟩; exact ⟨hall y (List.mem_cons_self _ _), hpair⟩\n\n  -- 2. Equivalence of Subsequences\n  have h_subs : ∀ {ys} l, l ∈ subsequences ys ↔ l <+ ys := by\n    intro ys; induction ys <;> simp [subsequences, List.sublist_cons_iff, *]\n    intro l; constructor\n    · rintro (h|⟨a,h,rfl⟩); exact Or.inl h; exact Or.inr ⟨a,h,rfl⟩\n    · rintro (h|⟨a,h,rfl⟩); exact Or.inl h; exact Or.inr ⟨a,h,rfl⟩\n\n  let fold_op := fun (acc : List (List Int)) x => acc ++ acc.map (fun sub => x :: sub)\n  have h_fold : xs.foldl fold_op [[]] = subsequences xs.reverse := by\n    induction xs using List.reverseRecOn with\n    | nil => simp [subsequences]\n    | append_cons ys y ih => simp [List.foldl_append, ih, fold_op, List.reverse_append, subsequences]\n\n  have h_all_iff : ∀ l, l ∈ (xs.foldl fold_op [[]]).map List.reverse ↔ l <+ xs := by\n    intro l; rw [h_fold]; simp only [List.mem_map, List.mem_reverse]\n    constructor\n    · rintro ⟨a, ha, rfl⟩; rw [h_subs] at ha; rw [←List.reverse_sublist_iff]; exact ha\n    · intro h; use l.reverse; rw [h_subs, List.reverse_sublist_iff]; exact ⟨h, rfl⟩\n\n  -- 3. Equivalence of Length Sets\n  let L_impl := (subsequences xs).filter isStrictlyIncreasing |>.map List.length\n  let L_spec := ((xs.foldl fold_op [[]]).map List.reverse).filter (List.Pairwise (· < ·)) |>.map List.length\n\n  have h_sets : ∀ n, n ∈ L_impl ↔ n ∈ L_spec := by\n    intro n; simp [L_impl, L_spec, h_incr, h_subs, h_all_iff]\n\n  -- 4. Properties of Max\n  let res := L_impl.foldl max 0\n  have h_max_props : ∀ (l : List Nat) (a : Nat), let r := l.foldl max a; r ∈ a :: l ∧ ∀ x ∈ l, x ≤ r := by\n    intro l a r; induction l generalizing a with\n    | nil => simp\n    | cons y ys ih =>\n      specialize ih (max a y); simp at ih; refine ⟨?_, ?_⟩\n      · rcases ih.1 with (h|h); simp [h]; apply Or.inl (le_max_left _ _); right; exact h\n      · intro z hz; cases hz with\n        | head => trans (max a y); apply le_max_right; apply ih.2; left; rfl\n        | tail _ h => apply ih.2; right; exact h\n\n  rcases h_max_props L_impl 0 with ⟨h_in, h_le⟩\n  have h_zero : 0 ∈ L_impl := by simp [L_impl, h_subs, isStrictlyIncreasing]; use []\n  replace h_in : res ∈ L_impl := by cases h_in; subst res; exact h_zero; assumption\n  rw [h_sets] at h_in\n  exact ⟨h_in, fun x hx => h_le x ((h_sets x).mpr hx)⟩\n  -- !benchmark @end proof"
