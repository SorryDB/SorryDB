def circuit (c : ℕ) : FormalCircuit (F p) (fields 254) field where
  main := main c
  localLength _ := 127 + 1 + 135 + 1
  localLength_eq := by simp only [circuit_norm, main, Num2Bits.circuit]
  subcircuitsConsistent input n := by
    simp only [circuit_norm, main, Num2Bits.circuit]
    and_intros <;> ac_rfl

  Assumptions input :=
    ∀ i (_ : i < 254), input[i] = 0 ∨ input[i] = 1

  Spec bits output :=
    output = if fromBits (bits.map ZMod.val) > c then 1 else 0

  soundness := by
    intros offset env input_var input h_map h_bits h_logic
    rcases h_logic with ⟨h_parts, h_sum, h_n2b, h_out⟩
    simp only [h_map] at h_parts
    rw [h_out]
    
    -- The circuit performs a radix-4 lexicographical comparison.
    -- We define the accumulated difference E and the carry K.
    let s_val (i : ℕ) : ℤ := (input[2*i+1].val : ℤ) * 2 + input[2*i].val
    let k_val (i : ℕ) : ℤ := ((c >>> (2*i+1)) &&& 1 : ℤ) * 2 + ((c >>> (2*i)) &&& 1)
    
    -- The term for each chunk: -2^i if input > c, +2^i if input < c, 0 otherwise
    let term (i : ℕ) : ℤ := 
      if s_val i > k_val i then -(2^i) 
      else if s_val i < k_val i then 2^i 
      else 0

    let E : ℤ := ∑ i in Finset.range 127, term i
    let K : ℤ := ∑ i in Finset.range 127, if s_val i > k_val i then 1 else 0

    -- Lemma 1: The sum computed by the circuit corresponds to K*2^128 + E modulo p
    -- derived from h_parts and h_sum
    have h_compute : (env.get (offset + 127)).val = (K * (2:ℤ)^128 + E) % p := by sorry

    -- Lemma 2: E < 0 iff Input > c
    -- derived from the lexicographic properties of the signed digit sum
    have h_cmp : E < 0 ↔ c < fromBits (Vector.map ZMod.val input) := by sorry

    -- Lemma 3: Bit 127 of the sum is 1 iff E < 0
    -- derived from h_n2b and the bounds |E| < 2^127
    have h_bit : (env.get (offset + 127 + 1 + ElaboratedCircuit.localLength (fields 135) (var { index := offset + 127 }))) = (if E < 0 then 1 else 0 : F p) := by sorry
    
    rw [h_bit, h_cmp]
    simp
