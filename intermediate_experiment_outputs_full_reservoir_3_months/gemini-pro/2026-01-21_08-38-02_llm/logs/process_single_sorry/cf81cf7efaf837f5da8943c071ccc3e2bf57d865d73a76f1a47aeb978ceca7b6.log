def toCofix (self : StateCofixFinal F α) : Cofix F α :=
  have h : ∀ (a b : Coalg F α), a ~ b → a.toCofix = b.toCofix := by
    -- to show: two bisimilar coalgebras generate the same cofix
    -- This is true, and proving it shouldn't be too hard
    rintro a b ⟨R, h_bisim, h_R⟩
    let k : a.σ ⊕ b.σ → Cofix F α := Sum.elim (fun s => Coalg.toCofix { a with s }) (fun s => Coalg.toCofix { b with s })
    let R' : Cofix F α → Cofix F α → Prop := fun x y =>
      ∃ u v, R u v ∧ x = k u ∧ y = k v
    apply MvQPF.Cofix.bisim R'
    · rintro x y ⟨u, v, hR, rfl, rfl⟩
      rw [Cofix.dest_corec, Cofix.dest_corec]
      have H := h_bisim u v hR
      rw [union_dest_eq_left, union_dest_eq_right] at H
      rw [MvQPF.liftR_map] at H ⊢
      refine MvQPF.LiftR_mono ?_ H
      intro i x y hxy
      cases i using Fin2.cases
      · simp only [RelLast, TypeVec.append1, Fin2.cases_zero, TypeVec.id, TypeVec.appendFun, TypeVec.splitFun, TypeVec.comp,
          Sum.elim_inl, Sum.elim_inr] at hxy ⊢
        exact hxy
      · simp only [RelLast, TypeVec.append1, Fin2.cases_succ, TypeVec.id, TypeVec.appendFun, TypeVec.splitFun, TypeVec.comp,
          Sum.elim_inl, Sum.elim_inr] at hxy ⊢
        exact ⟨x, y, hxy, rfl, rfl⟩
    · exact ⟨.inl a.s, .inr b.s, h_R, rfl, rfl⟩
  Quot.lift Coalg.toCofix h self
