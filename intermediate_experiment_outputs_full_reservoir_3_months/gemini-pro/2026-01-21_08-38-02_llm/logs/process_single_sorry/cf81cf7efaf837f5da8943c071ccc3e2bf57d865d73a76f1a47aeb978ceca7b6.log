      let g : a.σ ⊕ b.σ → Cofix F α := fun
        | .inl s => Coalg.toCofix { a with s := s }
        | .inr t => Coalg.toCofix { b with s := t }
      have hg1 : (TypeVec.id ::: g) ∘ (TypeVec.id ::: Sum.inl) = (TypeVec.id ::: Cofix.corec a.dest') := by
        ext x; cases x <;> rfl
      have hg2 : (TypeVec.id ::: g) ∘ (TypeVec.id ::: Sum.inr) = (TypeVec.id ::: Cofix.corec b.dest') := by
        ext x; cases x <;> rfl
      rw [← hg1, ← hg2, ← MvFunctor.map_map, ← MvFunctor.map_map]
      specialize h_bisim s t hR
      rw [MvQPF.LiftR_iff] at h_bisim ⊢
      rcases h_bisim with ⟨z, hz1, hz2, hz3⟩
      refine ⟨(TypeVec.id ::: Prod.map g g) <$$> z, ?_, ?_, ?_⟩
      · simp only [MvFunctor.map_map, ←TypeVec.comp_assoc, ←TypeVec.map_comp_snd, ←TypeVec.map_comp_fst, hz1]
