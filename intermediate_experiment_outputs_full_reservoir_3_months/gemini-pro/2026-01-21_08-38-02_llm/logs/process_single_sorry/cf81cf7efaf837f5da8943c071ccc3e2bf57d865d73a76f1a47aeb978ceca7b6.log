      · simp only [MvFunctor.map_map, ←TypeVec.comp_assoc, ←TypeVec.map_comp_snd, ←TypeVec.map_comp_fst, hz2]
        congr; ext x; cases x <;> rfl
      · intro i p
        cases i using Fin.lastCases
        · rfl
        · simp only [RelLast, TypeVec.last_def]
          dsimp
