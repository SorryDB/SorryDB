    -- We need to choose a subset of these occurrences to be i+n such that size is Even.
    -- Number of such subsets is 2^(counts_v i - 1).
    -- Total count is Product 2^(counts_v i - 1) = 2^(Sum counts_v i - n) = 2^(k - n).
    sorry -- Combinatorial calculation

  have h_proj_img : ∀ u ∈ UN, proj u ∈ UM := by
    intro u hu
    simp [UN] at hu
    simp [UM]
    constructor
    · intro i hi
