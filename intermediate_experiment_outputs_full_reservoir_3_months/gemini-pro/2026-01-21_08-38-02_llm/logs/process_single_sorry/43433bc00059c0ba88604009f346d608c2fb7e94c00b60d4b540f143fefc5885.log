  -- We define the type of switch sequences as functions Fin k -> Fin (2 * n)
  -- and use the provided hypotheses to relate N and M to cardinalities of sets of such functions.
  
  -- Define counts
  let counts (s : Fin k → Fin (2 * n)) (i : Fin (2 * n)) : ℕ :=
    (Finset.univ.filter (λ t => s t = i)).card

  -- Define the predicates corresponding to SN and SM
  -- For SN: lamps 0..n-1 are odd, lamps n..2n-1 are even
  let PredN (s : Fin k → Fin (2 * n)) : Prop :=
    (∀ i : Fin n, Odd (counts s (i.castAdd n))) ∧
    (∀ i : Fin n, Even (counts s (i.natAdd n)))

  -- For SM: lamps 0..n-1 are odd, lamps n..2n-1 are 0 (never switched)
  -- The problem says "none of lamps n+1..2n is ever switched on".
  -- Since they start OFF, this means they are never switched.
  let PredM (s : Fin k → Fin (2 * n)) : Prop :=
    PredN s ∧ ∀ t, s t < n

  let SetN := Finset.univ.filter PredN
  let SetM := Finset.univ.filter PredM

