      · simp [s_of_u]
        constructor
        · intro i hi; specialize hu.1 i; simp at hi; simp [hi] at hu; exact hu
        · intro i hi t; specialize hu.2 i; simp at hi; simp [hi] at hu
          rw [hu]; simp
    · exact h_inj
    · intro s hs
      simp [h₂] at hs
      sorry -- Standard surjectivity

  -- Combinatorial argument UN -> UM
  let proj (u : U) : U := λ t => if (u t : ℕ) < n then u t else ⟨u t - n, by 
    have := (u t).2; have : (u t : ℕ) < 2 * n := this; omega⟩
  
  have h_fiber : ∀ v ∈ UM, (UN.filter (λ u => proj u = v)).card = 2 ^ (k - n) := by
    intro v hv
    simp [UM] at hv
