  let U := Fin k → Fin (2 * n)
  let V := Fin k → Fin n

  -- Define the "count" of lamp flips for index i in sequence u
  let count {α} [DecidableEq α] (u : Fin k → α) (i : α) := (Finset.univ.filter (λ t ↦ u t = i)).card

