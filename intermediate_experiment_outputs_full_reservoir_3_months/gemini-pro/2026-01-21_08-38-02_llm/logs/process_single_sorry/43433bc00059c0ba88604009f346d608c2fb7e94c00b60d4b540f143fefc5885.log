    (switch_seq : (Fin (k + 1) → Fin (2 * n) → Bool) → Prop)
    (SN SM : Finset (Fin (k + 1) → Fin (2 * n) → Bool))
    (h₀ : ∀ s, switch_seq s ↔
      s 0 = Function.const _ false ∧
      ∀ t : Fin k, ∃ i, s t.succ = Function.update (s t.castSucc) i (!s t.castSucc i))
    (h₁ : ∀ s, s ∈ SN ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), s (Fin.last _) ↑i = false)
    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = 2 ^ (k - n) := by
  -- We map switching sequences to sequences of indices
  let U := Fin k → Fin (2 * n)
  let count (u : U) (i : Fin (2 * n)) := (Finset.univ.filter (λ t => u t = i)).card
  
  -- SN counts sequences where parities of counts match the target pattern
  have hN : (N : ℚ) = (1 / 2^(2*n)) * ∑ A in Finset.univ.powerset, 
      ((-1 : ℚ) ^ (A ∩ Finset.Iio (2*n) n).card) * ((2 * n : ℚ) - 2 * A.card) ^ k := by
    rw [h₃.1]
    let filter (u : U) := ∀ i, (if i < n then Odd (count u i) else Even (count u i))
    have : SN.card = (Finset.univ.filter filter).card := sorry -- Standard bijection
    rw [this]
    let f (u : U) := ∏ i : Fin (2*n), if i < n then (1 - (-1 : ℚ)^(count u i))/2 else (1 + (-1 : ℚ)^(count u i))/2
    have sum_eq : ∑ u, f u = (Finset.univ.filter filter).card := sorry -- Sum of indicators
    rw [← sum_eq]
    -- Expansion of the product and sum swap
    sorry 

  -- SM is similar but restricted to first n lamps
  have hM : (M : ℚ) = (1 / 2^n) * ∑ B in (Finset.Iio (2*n) n).powerset, 
      ((-1 : ℚ) ^ B.card) * ((n : ℚ) - 2 * B.card) ^ k := by
    rw [h₃.2]
    -- "Never switched" means indices are in 0..n-1
    let U' := Fin k → Fin n
    let count' (u : U') (i : Fin n) := (Finset.univ.filter (λ t => u t = i)).card
    let filter' (u : U') := ∀ i, Odd (count' u i)
    have : SM.card = (Finset.univ.filter filter').card := sorry
    rw [this]
    -- Expansion: sum_{u} prod_{i<n} (1 - (-1)^c_i)/2
    sorry

  -- We need to prove N = 2^(k-n) * M.
  -- Rearranging: 2^(2n) * N = 2^k * (2^n * M)
  -- Let S_N = sum_{A} ... and S_M = sum_{B} ...
  -- We show S_N = 2^k * S_M
  
  let P := (Polynomial.X - 1)^n * (Polynomial.X + 1)^n
  let Q := (Polynomial.X^2 - 1)^n
  have hPQ : P = Q := by 
    rw [← mul_pow, squared_diff_one_eq_mul_sub_add]
  
  let moment (p : Polynomial ℚ) := ∑ i in p.support, p.coeff i * ((i : ℚ) - n)^k
  
  -- The sums S_N and S_M are related to moments of P and Q
  -- Specifically, S_M corresponds to Q
  -- coeff of X^r in Q is non-zero only for r even?
  -- Q = sum_j binom(n, j) (-1)^j X^{2(n-j)}
  -- moment Q = sum_j binom(n, j) (-1)^j (2n - 2j - n)^k = sum_j binom(n, j) (-1)^j (n - 2j)^k
  -- This matches the sum in hM (up to index renaming).
  
  -- S_N corresponds to P
  -- P = (X-1)^n (X+1)^n
  -- Expansion leads to S_N formula = moment P
  
  have h_moments : moment P = moment Q := by rw [hPQ]
  
  -- Connecting hN and hM to moments
  have hN_eq : (2^(2*n) : ℚ) * N = 2^k * moment P := sorry
  have hM_eq : (2^n : ℚ) * M = moment Q := sorry
  
  rw [hN_eq, h_moments, ← hM_eq]
  field_simp
  rw [pow_sub _ _ (le_of_lt h.2.2)]
  ring
  norm_num
  sorry -- M != 0 check
