      sorry 
    · intro i hi
      -- i >= n are mapped to i-n < n, so count is 0
      sorry

  rw [hN, hM]
  rw [Finset.card_eq_sum_card_fiberwise (λ u => proj u) UM]
  · simp [h_fiber]
    rw [Finset.sum_const, Nat.smul_eq_mul, mul_comm]
