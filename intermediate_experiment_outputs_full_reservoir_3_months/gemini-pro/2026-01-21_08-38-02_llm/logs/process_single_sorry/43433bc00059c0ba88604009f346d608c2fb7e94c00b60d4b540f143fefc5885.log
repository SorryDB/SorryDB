import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped Classical
open scoped Fin.CommRing

/--
Let $ n$ and $ k$ be positive integers with $ k \geq n$ and $ k - n$ an even number. Let $ 2n$ lamps labelled $ 1$, $ 2$, ..., $ 2n$ be given, each of which can be either [i]on[/i] or [i]off[/i]. Initially all the lamps are off. We consider sequences of steps: at each step one of the lamps is switched (from on to off or from off to on).

Let $ N$ be the number of such sequences consisting of $ k$ steps and resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off.

Let $ M$ be number of such sequences consisting of $ k$ steps, resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off, but where none of the lamps $ n + 1$ through $ 2n$ is ever switched on.

Determine $ \frac {N}{M}$.


[i]Author: Bruno Le Floch and Ilia Smilga, France[/i]

Solution: $2^{k-n}$
-/
@[imo_problem_subject combinatorics]
theorem imo_2008_p5 (n k N M : ℕ) (h : 0 < n ∧ 0 < k ∧ k ≥ n) [NeZero n] (heven : Even (k - n))
    -- whether the mapping of type (t → (lamp_id → on/off)) is a correct switching
    -- sequence.
    (switch_seq : (Fin (k + 1) → Fin (2 * n) → Bool) → Prop)
    (SN SM : Finset (Fin (k + 1) → Fin (2 * n) → Bool))
    (h₀ : ∀ s, switch_seq s ↔
      s 0 = Function.const _ false ∧
      ∀ t : Fin k, ∃ i, s t.succ = Function.update (s t.castSucc) i (!s t.castSucc i))
    (h₁ : ∀ s, s ∈ SN ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), s (Fin.last _) ↑i = false)
    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = answer(2 ^ (k - n)) := by
  let Steps := Fin k → Fin (2 * n)
  let to_states (x : Steps) : Fin (k + 1) → Fin (2 * n) → Bool :=
    fun t i => ((Finset.range t).filter (x · = i)).card % 2 = 1

  let SN_x := Finset.univ.filter (fun x : Steps =>
    (∀ i : Fin n, Odd ((Finset.univ.filter (x · = i)).card)) ∧
    (∀ i : Fin n, Even ((Finset.univ.filter (x · = i.val + n)).card)))
  
  let SM_x := Finset.univ.filter (fun x : Steps =>
    (∀ i : Fin n, Odd ((Finset.univ.filter (x · = i)).card)) ∧
    (∀ i : Fin n, (Finset.univ.filter (x · = i.val + n)).card = 0))

  have h_bij : ∀ s ∈ SN, ∃! x : Steps, to_states x = s := by
    intro s hs
    have h_seq := (h₁ s).mp hs |>.1
    rw [h₀] at h_seq
    let x : Steps := fun t => Classical.choose (h_seq.2 t)
    use x
    have h_eq : to_states x = s := by
      ext t i
      induction' t using Fin.induction with t ih
      · simp [to_states, h_seq.1]
      · simp [to_states]
        rw [Finset.range_succ, Finset.filter_insert]
        have h_step := Classical.choose_spec (h_seq.2 t)
        rw [ih, h_step]
        simp only [Function.update, cast_eq, eq_iff_iff]
        split_ifs with h_eq
        · rw [h_eq, Nat.card_insert_of_not_mem (Finset.not_mem_range_self)]
          simp; cases ((Finset.range t.castSucc).filter (x · = i)).card % 2 <;> simp
        · rw [Nat.card_insert_of_not_mem (Finset.not_mem_range_self)] at h_eq -- Contradiction if we assume equality
          -- Actually split_ifs logic:
          -- If x t = i, card increments. Parity flips. s flips.
          -- If x t != i, card same. s same.
          simp [Finset.mem_filter] at h_eq
          rw [h_eq]
    constructor
    · exact h_eq
    · intro y hy
      ext t
      have : to_states x t.succ (x t) ≠ to_states x t.castSucc (x t) := by
         simp [to_states]; rw [Nat.add_mod]; simp
      rw [hy, h_eq] at this
      have : to_states y t.succ (x t) ≠ to_states y t.castSucc (x t) := this
      simp [to_states] at this
      by_contra h_neq
      rw [if_neg h_neq] at this
      simp at this

  have hN_card : N = SN_x.card := by
    rw [h₃.1]
    apply Finset.card_congr (fun x _ => to_states x)
    · intro x hx
      rw [h₁]
      constructor
      · -- switch_seq
        rw [h₀]; constructor; · ext; simp [to_states]; · intro t; use x t; ext i
        simp [to_states, Function.update]; split_ifs <;> simp [Nat.add_mod]
      · -- conditions
        simp only [Finset.mem_filter] at hx
        constructor
        · intro i hi; simp; rw [←Finset.card_univ]; exact hx.1 ⟨i, (Finset.mem_Ico.mp hi).2⟩
        · intro i hi; simp; rw [←Finset.card_univ]; exact hx.2 ⟨i - n, by
            rw [Finset.mem_Ico] at hi; simp; apply Nat.sub_lt_left_of_lt_add (by linarith) hi.2⟩
    · intro x y _ _ h; ext t; 
      have h1 := congr_fun (congr_fun h t.succ) (x t)
      have h2 := congr_fun (congr_fun h t.castSucc) (x t)
      simp [to_states] at h1 h2
      by_contra hne
      rw [if_neg hne] at h1
      rw [h2] at h1
      simp [Nat.add_mod] at h1
    · intro s hs; obtain ⟨x, hx⟩ := h_bij s hs; use x; constructor
      · simp only [Finset.mem_filter]; rw [←hx.1] at hs; rw [h₁] at hs
        constructor
        · intro i; specialize hs.2.1 i (Finset.mem_Ico.mpr ⟨i.2, by linarith⟩)
          simp [to_states] at hs; rw [←Finset.card_univ]; exact hs
        · intro i; specialize hs.2.2 (i + n) (Finset.mem_Ico.mpr ⟨by linarith, by linarith [i.2]⟩)
          simp [to_states] at hs; rw [←Finset.card_univ]; exact hs
      · exact hx.1

  have hM_card : M = SM_x.card := by
    rw [h₃.2]
    apply Finset.card_congr (fun x _ => to_states x)
    · intro x hx
      rw [h₂]
      constructor
      · rw [h₀]; constructor; · ext; simp [to_states]; · intro t; use x t; ext i
        simp [to_states, Function.update]; split_ifs <;> simp [Nat.add_mod]
      · simp only [Finset.mem_filter] at hx
        constructor
        · intro i hi; simp; rw [←Finset.card_univ]; exact hx.1 ⟨i, (Finset.mem_Ico.mp hi).2⟩
        · intro i hi t; simp [to_states]; rw [←Finset.card_univ]
          have hc := hx.2 ⟨i - n, by rw [Finset.mem_Ico] at hi; exact Nat.sub_lt_left_of_lt_add (by linarith) hi.2⟩
          rw [hc]; apply Nat.mod_eq_of_lt; apply Nat.lt_of_le_of_lt (Finset.card_le_univ _) (by norm_num [hc])
    · intro x y _ _ h; ext t; 
      have h1 := congr_fun (congr_fun h t.succ) (x t); have h2 := congr_fun (congr_fun h t.castSucc) (x t)
      simp [to_states] at h1 h2; by_contra hne; rw [if_neg hne] at h1; rw [h2] at h1; simp [Nat.add_mod] at h1
    · intro s hs; obtain ⟨x, hx⟩ := h_bij s (by rw [h₂, h₁] at hs ⊢; exact ⟨hs.1, hs.2.1, fun i hi => (hs.2.2 i hi (Fin.last k))⟩)
      use x; constructor
      · simp only [Finset.mem_filter]; rw [←hx.1] at hs; rw [h₂] at hs
        constructor
        · intro i; specialize hs.2.1 i (Finset.mem_Ico.mpr ⟨i.2, by linarith⟩)
          simp [to_states] at hs; rw [←Finset.card_univ]; exact hs
        · intro i; rw [←Finset.card_univ, Finset.card_eq_zero]
          rw [Finset.eq_empty_iff_forall_not_mem]
          intro t ht; simp at ht
          specialize hs.2.2 (i + n) (Finset.mem_Ico.mpr ⟨by linarith, by linarith [i.2]⟩) t.succ
          simp [to_states] at hs
          rw [Finset.range_succ, Finset.filter_insert, if_pos ht, Nat.card_insert_of_not_mem (Finset.not_mem_range_self)] at hs
          rw [Nat.succ_eq_add_one, Nat.add_mod] at hs
          simp at hs
      · exact hx.1

  let U := Finset.univ.filter (fun u : Fin k → Fin n => ∀ i, Odd ((Finset.univ.filter (u · = i)).card))
  
  have hSM_iso : SM_x.card = U.card := by
    apply Finset.card_congr (fun x _ t => ⟨x t, by
      have := (Finset.mem_filter.mp ‹_›).2.2
      by_contra h; push_neg at h; specialize this ⟨x t - n, Nat.sub_lt_left_of_lt_add (by linarith) h⟩
      rw [Finset.card_eq_zero, Finset.filter_eq_empty_iff] at this; specialize this t (Finset.mem_univ _); simp at this⟩)
    · intro x hx; simp; intro i; convert (Finset.mem_filter.mp hx).2.1 i; ext t; simp
    · intro x y _ _ h; ext t; apply Fin.eq_of_veq; exact congr_arg Subtype.val (congr_fun h t)
    · intro u hu; use (fun t => (u t).val); constructor
      · simp; constructor
        · intro i; convert (Finset.mem_filter.mp hu).2 i; ext t; simp
        · intro i; rw [Finset.card_eq_zero, Finset.filter_eq_empty_iff]; intro t _; simp; linarith [i.2, (u t).2]
      · ext t; simp

  have hSN_fiber : SN_x.card = U.card * 2^(k - n) := by
    let π (x : Steps) : Fin k → Fin n := fun t => ⟨x t % n, Nat.mod_lt _ h.1⟩
    rw [Finset.card_eq_sum_card_fiberwise (fun x => π x)]
    rw [←Finset.sum_const]
    · apply Finset.sum_congr rfl
      intro u hu
      let fiber := SN_x.filter (fun x => π x = u)
      -- Fiber count
      have : fiber.card = 2^(k - n) := by
        -- Identify fiber with choices of x t = u t or u t + n
        -- Parity constraints imply we choose even number of +n for each i
        -- Number of ways is product of 2^(k_i - 1)
        sorry -- Standard combinatorial counting
      exact this
    · intro x hx; simp [U]; intro i
      let u := π x
      have : (Finset.univ.filter (u · = i)).card = (Finset.univ.filter (x · = i.val)).card + (Finset.univ.filter (x · = i.val + n)).card := by
        rw [←Finset.card_union_of_disjoint (by rw [Finset.disjoint_filter]; intro _ h1 h2; linarith [i.2])]; apply Finset.card_congr (fun t _ => t) (by intro _ _; simp) (by intro _ _ _; rfl)
        intro t ht; simp [π] at ht; simp; rcases ht with h1 | h1; left; simpa using h1; right; simpa using h1
      rw [this]
      have ho := (Finset.mem_filter.mp hx).2.1 i
      have he := (Finset.mem_filter.mp hx).2.2 i
      exact Odd.add_even ho he

  rw [hN_card, hM_card, hSM_iso, hSN_fiber]
  push_cast
  rw [mul_div_cancel_left]
  -- U is nonempty
  rw [Finset.card_pos]
  use (fun t => ⟨if t < n then t else 0, by split_ifs <;> linarith [h.1]⟩)
  sorry -- Existence of partition
