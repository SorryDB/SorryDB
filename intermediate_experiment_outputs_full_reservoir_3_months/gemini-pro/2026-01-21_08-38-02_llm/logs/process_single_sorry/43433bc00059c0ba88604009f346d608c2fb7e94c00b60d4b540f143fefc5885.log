    · intro s hs; simp only [Finset.mem_filter, Finset.mem_univ, true_and]
      rw [h₁] at hs
      constructor
      · intro i; specialize hs.2 (i.castAdd n) (by simp); simpa using hs
      · intro i; specialize hs.2.2 (i.natAdd n) (by simp); simpa using hs
    · intro s₁ s₂ hs₁ hs₂ h; ext t i
      -- Injectivity follows from h₀ uniqueness of updates
      sorry 
    · -- Surjectivity follows from constructing s from u
      sorry 

  have hM : M = SM'.card := by
    rw [h₃.2]
    -- Similar bijection to V for M, using h₂ to show u t < n
    apply Finset.card_congr (λ s _ t ↦ (Classical.choose (h₀ s |>.1 (switch_seq_of_mem s) |>.2 t)).castPred (by
       have := (h₂ s).1 (switch_seq_of_mem s) |>.2.2 (Classical.choose (h₀ s |>.1 (switch_seq_of_mem s) |>.2 t)) t
       -- Proof that index < n
       sorry))
    · sorry
    · sorry
    · sorry

  -- Define projection π: U → V by taking indices modulo n
  let π (u : U) : V := λ t ↦ if h : (u t : ℕ) < n then ⟨u t, h⟩ else ⟨u t - n, by
    have := (u t).isLt; omega⟩

  -- Main combinatorial argument: fiber counting
  have h_fiber : ∀ v ∈ SM', (SN'.filter (λ u ↦ π u = v)).card = 2^(k-n) := by
