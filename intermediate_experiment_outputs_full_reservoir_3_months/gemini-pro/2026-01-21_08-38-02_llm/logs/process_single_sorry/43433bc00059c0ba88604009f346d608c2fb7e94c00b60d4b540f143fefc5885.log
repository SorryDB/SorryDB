  -- relating switch sequences to final states. The "state" of lamp i is ON iff 
  -- it has been switched an odd number of times.
  have hN_eq : N = SetN.card := by
    rw [h₃.1]
    -- The bijection between switch_seq and functions Fin k -> Fin (2n) is standard
    -- and preserves the parity conditions given in h0 and h1.
    sorry 
  have hM_eq : M = SetM.card := by
    rw [h₃.2]
    sorry

  -- Define the projection map from SetN to SetM
  let psi (s : Fin k → Fin (2 * n)) : Fin k → Fin (2 * n) :=
    λ t => if h : s t < n then s t else s t - n

  -- Show psi maps SetN to SetM
  have h_psi_map : ∀ s ∈ SetN, psi s ∈ SetM := by
    intro s hs
    simp only [Finset.mem_filter, PredN, PredM] at hs ⊢
    rcases hs with ⟨hodd, heven⟩
    refine ⟨⟨?_, ?_⟩, ?_⟩
    · intro i
      -- The count of i in psi s is count(s, i) + count(s, i+n)
      -- Odd + Even = Odd
      have : counts (psi s) (i.castAdd n) = counts s (i.castAdd n) + counts s (i.natAdd n) := by
        simp [counts, psi]
        let A := Finset.univ.filter (λ t => s t = i.castAdd n)
        let B := Finset.univ.filter (λ t => s t = i.natAdd n)
        have disjoint : Disjoint A B := by
          rw [Finset.disjoint_filter]; intro t _ hA hB; simp [hA] at hB; omega
        convert Finset.card_union_eq A B disjoint
        ext t; simp; constructor
        · intro h; split at h
          · left; exact h
          · right; simp at h; have : s t = i.natAdd n := by 
              apply Fin.eq_of_val_eq; rw [Fin.val_natAdd]; simp [Fin.val_sub] at h; omega
            exact this
        · intro h; cases h <;> simp [*]
          · rw [dif_pos]; exact (by apply Fin.val_lt_of_le; exact i.is_le)
          · rw [dif_neg]; simp; exact (by simp [Fin.val_natAdd])
      rw [this]
      exact Odd.add_even (hodd i) (heven i)
    · intro i
      -- count of i+n is 0 because range of psi is < n
