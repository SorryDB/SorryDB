        simp [counts, psi]; apply Finset.card_eq_zero; apply Finset.eq_empty_of_forall_not_mem
        intro t ht; simp at ht; split at ht <;> simp at ht; omega
      rw [this]; exact even_zero
    · intro t; simp [psi]; split <;> simp; omega

  -- Calculate fiber sizes
  have h_fibers : ∀ y ∈ SetM, (SetN.filter (λ x => psi x = y)).card = 2 ^ (k - n) := by
    intro y hy
    simp only [Finset.mem_filter, PredM, PredN] at hy
    -- For each i < n, let T_i be indices where y t = i.
    -- We must choose for each t in T_i whether x t = i or i+n.
    -- Constraint: count(x, i+n) is even.
    -- count(y, i) is odd implies |T_i| is odd.
    -- Number of even subsets of T_i is 2^(|T_i|-1).
    let T (i : Fin n) := Finset.univ.filter (λ t => y t = i.castAdd n)
    have h_part : Finset.univ = Finset.biUnion Finset.univ T := by
      ext t; simp; use (y t).cast_lo (by have := hy.2 t; omega)
      simp [T]; exact (by ext; simp; have := hy.2 t; omega)
    have h_disj : PairwiseDisjoint Finset.univ T := by
      intro i _ j _ neq; rw [Finset.disjoint_filter]; intro t _ h1 h2
      apply neq; apply Fin.eq_of_val_eq; simp at h1 h2; rw [←h1, ←h2]
    
    rw [Finset.card_congr (λ x _ => λ i => (Finset.univ.filter (λ t => x t = i.natAdd n)).map ⟨λ t => t, by simp⟩) ?_ ?_ ?_]
    · -- The size of the product space
      rw [Finset.card_pi]
