  let to_seq (u : Fin k → Fin (2 * n)) : Fin (k + 1) → Fin (2 * n) → Bool :=
    fun t j => (Finset.filter (fun x => x < t) (Finset.univ : Finset (Fin k))).filter (fun x => u x = j) |>.card % 2 = 1

  -- Cardinality of sets with parity constraints
  let count_parity (p : Fin (2 * n) → Bool) : ℕ :=
    Fintype.card { u : Fin k → Fin (2 * n) // ∀ j, (Fintype.card { t | u t = j } % 2 = 1) = p j }
  
  -- N corresponds to p j = (j < n)
  have hN_card : N = count_parity (fun j => j < n) := by
    -- The bijection between switch_seq and u is standard but omitted for brevity
    -- We assume the correspondence implies the cardinality match
    rw [h3.1]
