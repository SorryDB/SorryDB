import Imo.ProblemImports

open scoped Real
open scoped Nat
open scoped Classical
open scoped Fin.CommRing

/--
Let $ n$ and $ k$ be positive integers with $ k \geq n$ and $ k - n$ an even number. Let $ 2n$ lamps labelled $ 1$, $ 2$, ..., $ 2n$ be given, each of which can be either [i]on[/i] or [i]off[/i]. Initially all the lamps are off. We consider sequences of steps: at each step one of the lamps is switched (from on to off or from off to on).

Let $ N$ be the number of such sequences consisting of $ k$ steps and resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off.

Let $ M$ be number of such sequences consisting of $ k$ steps, resulting in the state where lamps $ 1$ through $ n$ are all on, and lamps $ n + 1$ through $ 2n$ are all off, but where none of the lamps $ n + 1$ through $ 2n$ is ever switched on.

Determine $ \frac {N}{M}$.


[i]Author: Bruno Le Floch and Ilia Smilga, France[/i]

Solution: $2^{k-n}$
-/
@[imo_problem_subject combinatorics]
theorem imo_2008_p5 (n k N M : ℕ) (h : 0 < n ∧ 0 < k ∧ k ≥ n) [NeZero n] (heven : Even (k - n))
    -- whether the mapping of type (t → (lamp_id → on/off)) is a correct switching
    -- sequence.
    (switch_seq : (Fin (k + 1) → Fin (2 * n) → Bool) → Prop)
    (SN SM : Finset (Fin (k + 1) → Fin (2 * n) → Bool))
    (h₀ : ∀ s, switch_seq s ↔
      s 0 = Function.const _ false ∧
      ∀ t : Fin k, ∃ i, s t.succ = Function.update (s t.castSucc) i (!s t.castSucc i))
    (h₁ : ∀ s, s ∈ SN ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), s (Fin.last _) ↑i = false)
    (h₂ : ∀ s, s ∈ SM ↔
      switch_seq s ∧
      ∀ i ∈ Finset.Ico 0 n,
      s (Fin.last _) ↑i = true ∧ ∀ i ∈ Finset.Ico n (2 * n), ∀ t, s t ↑i = false)
    (h₃ : N = SN.card ∧ M = SM.card) :
    (N / M : ℚ) = answer(2 ^ (k - n)) := by
  let U := Fin k → Fin (2 * n)
  let V := Fin k → Fin n
  -- Bijection between switch sequences and sequences of moves
  let count (u : U) (i : Fin (2 * n)) : ℕ := (Finset.univ.filter (λ t => u t = i)).card
  let final_state (u : U) (i : Fin (2 * n)) : Bool := (count u i) % 2 = 1
  have : ∃ f : SN → { u : U // ∀ i < n, final_state u i = true ∧ ∀ i ≥ n, final_state u i = false }, Function.Bijective f := by sorry
  have card_N : N = (Finset.univ.filter (λ u : U => (∀ i : Fin n, final_state u i) ∧ (∀ i : Fin n, ¬final_state u (Fin.castAdd n i + n)))).card := by sorry
  -- For M, only lamps 0..n-1 are used.
  have card_M : M = (Finset.univ.filter (λ v : V => ∀ i : Fin n, (Finset.univ.filter (λ t => v t = i)).card % 2 = 1)).card := by sorry

  -- We calculate the sums using inclusion-exclusion / characters
  let S_M : ℚ := ∑ A in (Finset.univ : Finset (Finset (Fin n))), (-1:ℚ)^A.card * (n - 2 * (A.card : ℚ))^k
  have form_M : (M : ℚ) = S_M / 2^n := by
    rw [card_M, Rat.div_eq_mul_inv]
    trans (2:ℚ)^(-n : ℤ) * ∑ v : V, ∏ i : Fin n, (1 - (-1:ℚ)^(Finset.univ.filter (λ t => v t = i)).card)
    · sorry -- standard character sum argument
    rw [Finset.sum_comm]
    sorry -- reduce to S_M form

  let S_N : ℚ := ∑ A in (Finset.univ : Finset (Finset (Fin n))), ∑ B in (Finset.univ : Finset (Finset (Fin n))), 
    (-1:ℚ)^A.card * (2 * n - 2 * (A.card : ℚ) - 2 * (B.card : ℚ))^k
  have form_N : (N : ℚ) = S_N / 2^(2*n) := by
    rw [card_N, Rat.div_eq_mul_inv]
    trans (2:ℚ)^(-(2*n : ℤ)) * ∑ u : U, (∏ i : Fin n, (1 - (-1:ℚ)^(count u i))) * (∏ i : Fin n, (1 + (-1:ℚ)^(count u (Fin.castAdd n i + n))))
    · sorry -- character sum
    rw [Finset.sum_comm]
    sorry -- reduce to S_N form

  have poly_identity : S_N = 2^k * S_M := by
    simp only [S_N, S_M]
    rw [← Finset.sum_product']
    have : ∑ x in (Finset.univ : Finset (Finset (Fin n) × Finset (Fin n))), (-1:ℚ)^x.1.card * (2 * n - 2 * (x.1.card : ℚ) - 2 * (x.2.card : ℚ))^k
         = 2^k * ∑ A in Finset.univ, (-1:ℚ)^A.card * (n - 2 * (A.card : ℚ))^k := by
      -- This reduces to sum_{A, B} (-1)^|A| (n - (|A|+|B|))^k = sum_C (-1)^|C| (n - 2|C|)^k
      -- which follows from (1-x)^n (1+x)^n = (1-x^2)^n
      sorry
    exact this

  rw [form_N, form_M, poly_identity]
  field_simp
  rw [pow_sub₀ (by norm_num) h.2.2]
  ring
