      exact not_le_of_lt hM'cd (Set.encard_le_encard this)
    
    obtain ⟨e, he⟩ := h_nonempty
    let C := G'.component e
    have hC : C.IsCompOf G' := G'.isCompOf_component (by simp [G', IsMatching.restrict₂, he])
    
