    -- Thus in every component C, |E(C) ∩ M'| ≤ |E(C) ∩ M|.
    -- Summing over all components (valid by EdgeFinite), we get |M' \ M| ≤ |M \ M'|.
    -- Adding |M ∩ M'| to both sides gives |M'| ≤ |M|.
    sorry
  exact not_le_of_lt hM'cd h_le
