      let M'_sub := M' \ C.E
      
      have hM_sub : G.IsMatching M_sub := hM.subset (Set.diff_subset _ _)
      have hM'_sub : G.IsMatching M'_sub := hM'.subset (Set.diff_subset _ _)
      
