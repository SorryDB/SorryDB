  have hG'fin : G'.EdgeFinite := inferInstance
  have hG'deg : G'.MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'
  
  -- We proceed by strong induction on the size of the symmetric difference.
  let n := G'.E.encard
  have hn : n < ⊤ := G'.E.encard_lt_top
