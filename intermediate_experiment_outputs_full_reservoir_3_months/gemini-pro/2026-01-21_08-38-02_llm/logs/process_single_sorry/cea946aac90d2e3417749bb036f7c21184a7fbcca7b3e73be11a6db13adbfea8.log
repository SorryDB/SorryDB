    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  obtain ⟨M', hM', hM'cd⟩ := by
    simpa only [isMaxMatching_iff, hM, true_and, not_forall, not_le] using hnotmax
  let H := hM.restrict₂ hM'
  have hH : H.MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'
  have h_cnt : (E(H) ∩ M).encard < (E(H) ∩ M').encard := by
    simp only [restrict₂, EdgeSub_edge, mem_inter_iff, mem_diff, mem_symmDiff_iff]
    rw [encard_diff_add_encard_inter M M', encard_diff_add_encard_inter M' M, inter_comm M' M] at hM'cd
    exact Encard.lt_of_add_lt_add_right hM.edgeFinite.encard_lt_top hM'cd

  let S := E(H)
  have hS : S.Finite := H.edgeFinite
  -- We prove that if S has more M' edges, it contains an augmenting path
  suffices ∀ (S : Set β) (hSsub : S ⊆ E(H)), (S ∩ M).encard < (S ∩ M').encard →
      ∃ P, G.IsAugPath hM P by exact this S rfl h_cnt

  intro S₀ hSsub₀
  refine Set.Finite.induction_on (hS.subset hSsub₀) (fun _ h ↦ (h.not_lt (by simp)).elim) ?_ S₀ hSsub₀
  rintro e S' he ih hS'sub h_lt
  
  -- Consider the component of e in the graph restricted to insert e S'
  -- To simplify, we just check if e starts a "good" path in H.
  -- Since we cannot easily iterate components, we use the fact that if no augmenting path exists,
  -- we can remove a neutral or M-heavy structure and recurse.
  
  -- If we can find an augmenting path in S', done.
  by_cases h_ex : ∃ P, G.IsAugPath hM P
  · exact h_ex
  
  -- If not, then the component containing e must be "bad" or "neutral".
  -- However, constructing the component formally is verbose.
  -- We rely on the fact that if there is no augmenting path, we can derive a contradiction.
  -- This is a placeholder for the component decomposition argument.
  -- Given the constraints, we construct a path P starting at e.
  
  -- If e ∈ M, then count(M) decreases by 1, count(M') stays same.
  -- Then S' has even larger gap.
  by_cases heM : e ∈ M
  · refine ih (S'.subset_insert e ▸ hS'sub) ?_
    rw [insert_inter_of_mem heM, insert_inter_of_not_mem (hM.disjoint heM (by simpa [H, restrict₂] using hS'sub e) (by simp)).ne_of_mem] at h_lt
    simp only [encard_insert_of_not_mem (by simp [he]), encard_insert_of_not_mem (by simp [he])] at h_lt
    exact Nat.lt_of_succ_lt h_lt

  -- If e ∈ M', then count(M') decreases by 1.
  -- We need to remove a structure that balances this.
  -- Since e ∈ M' \ M, e is an endpoint of a path in H (or cycle?).
  -- Since hH.MaxDegreeLE 2, we can follow the path from e.
  -- If the path is augmenting, we found P.
  -- If not, it ends in M, so we remove the whole path (neutral balance).
  -- This requires constructing the path.
