        ← encard_diff_add_inter (subset_union_right (s:=M) (t:=M'))] at hM'cd
    exact (WithTop.add_lt_add_iff_left (encard_ne_top_iff.2 inferInstance)).1 hM'cd
  
  have ∃ C, C.IsCompOf G' ∧ (E(C) ∩ M).encard < (E(C) ∩ M').encard
  · by_contra! h
    have h_sum : (E(G') ∩ M').encard ≤ (E(G') ∩ M).encard := by
