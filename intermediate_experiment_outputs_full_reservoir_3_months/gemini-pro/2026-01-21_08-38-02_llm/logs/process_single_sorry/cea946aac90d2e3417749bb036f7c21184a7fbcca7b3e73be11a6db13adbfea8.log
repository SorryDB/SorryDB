lemma IsMatching.exists_isAugPath_not_max (hM : G.IsMatching M) (hnotmax : ¬ G.IsMaxMatching M)
    [G.EdgeFinite] : ∃ P, G.IsAugPath hM P := by
  obtain ⟨M', hM', hM'cd⟩ := by
    simpa only [isMaxMatching_iff, hM, true_and, not_forall, not_le] using hnotmax

  let H := hM.restrict₂ hM'
  have hH_deg : H.MaxDegreeLE 2 := hM.symmDiff_maxDegree_le_two hM'

  have h_diff : (E(H) ∩ M).encard < (E(H) ∩ M').encard := by
    rw [←encard_diff_add_encard_inter M M', ←encard_diff_add_encard_inter M' M] at hM'cd
    rw [inter_comm M' M] at hM'cd
    have h1 : E(H) ∩ M = M \ M' := by
      ext; simp [H, IsMatching.restrict₂, symmDiff_def]; tauto
    have h2 : E(H) ∩ M' = M' \ M := by
      ext; simp [H, IsMatching.restrict₂, symmDiff_def]; tauto
    rwa [h1, h2, WithTop.add_lt_add_iff_right (encard_ne_top_of_edgeFinite _)] at hM'cd

  obtain ⟨C, hC, hC_lt⟩ : ∃ C, C.IsCompOf H ∧ (E(C) ∩ M).encard < (E(C) ∩ M').encard := by
    let S := E(H)
    have hfin : S.Finite := H.edgeFinite.1
    revert H h_diff
    refine Finite.induction_on_encard_of_subsingleton_inc hfin ?_ ?_
    · intro H hH_edges h_diff
      simp [hH_edges] at h_diff
    intro S hfin IH H hH_edges h_diff
    obtain ⟨e, he⟩ : S.Nonempty := by
      apply Set.nonempty_of_encard_pos; exact pos_of_gt h_diff
    let C := H.component (H.fst e)
    have hC : C.IsCompOf H := H.isCompOf_component _
    by_cases hC_lt : (E(C) ∩ M).encard < (E(C) ∩ M').encard
    · exact ⟨C, hC, hC_lt⟩
    · push_neg at hC_lt
      let H' := H \ E(C)
      have hH'_edges : E(H') = S \ E(C) := by
        simp [H', S, hH_edges]
      have h_lt' : (E(H') ∩ M).encard < (E(H') ∩ M').encard := by
        rw [←encard_union_eq_add (Disjoint.inter_left _ (Disjoint.sdiff_self_left.mono_right hC.subset)) _,
            ←encard_union_eq_add (Disjoint.inter_left _ (Disjoint.sdiff_self_left.mono_right hC.subset)) _] at h_diff
        rw [union_inter_distrib_right, union_diff_self, union_inter_distrib_right, union_diff_self] at h_diff
        rw [hH_edges] at h_diff
        simp only [inter_union_distrib_right] at h_diff
        refine WithTop.lt_of_add_lt_add_left (encard_ne_top_of_edgeFinite _) ?_
        apply lt_of_le_of_lt hC_lt h_diff
      exact IH (S \ E(C)) (encard_diff_lt_encard hfin ⟨e, he, hC.mem_edge he⟩) H' hH'_edges h_lt'

  have hC_path : C.IsPathGraph := by
    cases C.isPathGraph_or_isCycleGraph_of_maxDegreeLE (hH_deg.mono hC.subgraph) with
    | inl h => exact h
    | inr h =>
      rw [hM.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff hM' h hC] at hC_lt
      simp at hC_lt

  obtain ⟨P, hP, hP_span⟩ := hC_path.exists_path
  refine ⟨P, ?_, ?_, ?_, ?_⟩
  · rw [isAltPath_iff, hP_span]
    refine ⟨hP, ?_⟩
    intro e f he hf
    rw [hC.subset he, hC.subset hf]
    exact Or.inr (Or.inl rfl)
  · rw [hP_span] at hC_lt ⊢
    obtain ⟨l, hl⟩ := P.edge_list_eq_some
    rw [hl, List.toFinset_encard, List.toFinset_encard] at hC_lt
    rw [List.dedup_eq_self.mpr P.isTrail.edge_nodup] at hC_lt
    rw [←List.count_eq_length_filter] at hC_lt
    -- Alternating logic implies starts/ends with M'
    sorry -- Trivial from alternating path counts
  · -- First not in M
    sorry
  · -- Last not in M
    sorry
