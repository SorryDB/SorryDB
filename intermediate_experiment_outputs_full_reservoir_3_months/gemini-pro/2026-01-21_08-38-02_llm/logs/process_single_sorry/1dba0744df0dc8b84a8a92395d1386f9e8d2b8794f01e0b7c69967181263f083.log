theorem imo_1988_p4 (S : Set ℝ)
    -- Exclude the points in [1, 70] to avoid division by 0.
    (h₁ :
      S =
        {x : ℝ |
          (¬∃ n : ℕ, n ∈ Finset.Icc (1 : ℕ) 70 ∧ x = n) ∧
            5 / 4 ≤ ∑ k ∈ Finset.Icc (1 : ℕ) 70, (k : ℝ) / (x - k)}) :
    -- n intervals [l_i, r_i]
    ∃ l r : ℕ → ℝ, ∃ n : ℕ,
      -- Disjoint intervals.
      (∀ k, k < n → l k < r k) ∧
      (∀ k, k < n - 1 → r k < l (k + 1)) ∧
      -- Lengths summing to 1988.
      ∑ k ∈ Finset.range n, (r k - l k) = 1988 ∧
      -- S is the union of them. The question does not specify whether the intervals are open or closed.
      -- In fact, the intervals are (k, k+r] for integers k. We give the openness away here.
      S = ⋃ k ∈ Finset.range n, Set.Ioc (l k) (r k) := by
  let n := 70
  let I := Finset.Icc 1 n
  let Q : Polynomial ℝ := ∏ k in I, (Polynomial.X - Polynomial.C (k : ℝ))
  let T : Polynomial ℝ := ∑ k in I, Polynomial.C (k : ℝ) * ∏ j in I.erase k, (Polynomial.X - Polynomial.C (j : ℝ))
  let P := Polynomial.C (5/4 : ℝ) * Q - T
  -- P has exactly n real roots, one in each interval (k, k+1) for k < 70 and (70, ∞)
  -- This follows from the behavior of f(x) = Σ k/(x-k)
  have h_roots : P.roots.card = n ∧ P.Splits (RingHom.id ℝ) := sorry
  let roots := P.roots.sort (· ≤ ·)
  let l (k : ℕ) : ℝ := k + 1
  let r (k : ℕ) : ℝ := roots.get ⟨k, by rw [h_roots.1, List.length_sort]; exact k.2⟩
  refine ⟨l, r, n, ?_, ?_, ?_, ?_⟩
  · -- l k < r k
    intro k hk; sorry
  · -- r k < l (k+1)
    intro k hk; sorry
  · -- Sum of lengths
    have h_sum_k : ∑ k in I, (k : ℝ) = 2485 := by
      rw [Finset.sum_Icc_nat_cast]; norm_num
    have h_roots_sum : P.roots.sum = 9/5 * 2485 := by
