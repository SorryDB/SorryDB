    have h_sum_r : ∑ k in Finset.range n, r k = 4473 := by
      -- Sum of sorted roots equals sum of roots
      rw [← h_roots_sum]; norm_num; sorry 
    have h_sum_l : ∑ k in Finset.range n, l k = 2485 := by
      simp [l]; rw [Finset.sum_range_add, Finset.sum_range_id]; norm_num
    rw [← Finset.sum_sub_distrib, h_sum_r, h_sum_l]; norm_num
  · -- S is union
