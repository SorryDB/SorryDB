  have hB_sub : B ⊆ S := Finset.mem_powerset.mp (Finset.mem_sdiff.mp hB).1
  have h_pos : ∀ x ∈ S, 0 < x := fun x hx => lt_of_lt_of_le (by norm_num) (Finset.mem_Ico.mp (h₁ hx)).1
  
  refine ⟨?_, Finset.sdiff_subset.trans hA_sub, ?_, Finset.sdiff_subset.trans hB_sub, Finset.disjoint_sdiff_sdiff, ?_⟩
  
