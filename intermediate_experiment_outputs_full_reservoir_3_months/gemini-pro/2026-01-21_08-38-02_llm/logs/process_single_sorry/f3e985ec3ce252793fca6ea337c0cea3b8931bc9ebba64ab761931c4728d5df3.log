    exact h_ne₁.ne_empty (h_pos S₁ (Finset.sdiff_subset.trans hA) (by rw [h_eq, h, Finset.sum_empty]))

  exact ⟨S₁, S₂, h_ne₁, Finset.sdiff_subset.trans hA, h_ne₂, Finset.sdiff_subset.trans hB, disjoint_sdiff_sdiff, h_eq⟩
