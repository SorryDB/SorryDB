      "\n  let P := S.powerset\n  have hP : P.card = 1024 := by rw [Finset.card_powerset, h₀]; norm_num\n  have h_map : ∀ s ∈ P, ∑ x ∈ s, x ∈ Finset.Icc 0 990 := by\n    intro s hs\n    rw [Finset.mem_powerset] at hs\n    rw [Finset.mem_Icc]\n    constructor\n    · exact Nat.zero_le _\n    · calc\n        ∑ x ∈ s, x ≤ s.card * 99 := by\n           rw [← nsmul_eq_mul]\n           apply Finset.sum_le_card_nsmul\n           intro x hx\n           exact Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (hs hx))).2\n        _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (Finset.card_le_card hs).trans_eq h₀\n        _ = 990 := rfl\n  have h_card : (Finset.Icc 0 990).card < P.card := by\n    rw [hP, Nat.card_Icc]\n    norm_num\n  obtain ⟨A, hA, B, hB, hAB, hSum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_card h_map\n  rw [Finset.mem_powerset] at hA hB\n  let S₁ := A \\ B\n  let S₂ := B \\ A\n  have h_sum : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    apply Nat.add_right_cancel (b := ∑ x ∈ A ∩ B, x)\n    rw [← Finset.sum_union disjoint_sdiff_inter, Finset.sdiff_union_inter, hSum]\n    rw [← Finset.sum_union disjoint_sdiff_inter, Finset.sdiff_union_inter, Finset.inter_comm]\n  have h_pos : ∀ {X}, X ⊆ S → X.Nonempty → 0 < ∑ x ∈ X, x := by\n    intro X hXS hne\n    obtain ⟨x, hx⟩ := hne\n    apply Nat.lt_of_lt_of_le (by norm_num : 0 < 10)\n    trans x\n    · exact (Finset.mem_Ico.1 (h₁ (hXS hx))).1\n    · exact Finset.single_le_sum (fun _ _ => Nat.zero_le _) hx\n  have hS1 : S₁.Nonempty := by\n    intro h\n    have : ∑ x ∈ S₁, x = 0 := by rw [h, Finset.sum_empty]\n    rw [this] at h_sum\n    have hS2_empty : S₂ = ∅ := by\n      rw [Finset.eq_empty_iff_forall_not_mem]\n      intro x hx\n      have : 0 < ∑ y ∈ S₂, y := h_pos (Finset.sdiff_subset.trans hB) ⟨x, hx⟩\n      rw [← h_sum] at this\n      exact lt_irrefl 0 this\n    rw [Finset.sdiff_eq_empty_iff_subset] at h hS2_empty\n    exact hAB (Finset.Subset.antisymm h hS2_empty)\n  have hS2 : S₂.Nonempty := by\n    intro h\n    have : ∑ x ∈ S₂, x = 0 := by rw [h, Finset.sum_empty]\n    rw [← this] at h_sum\n    have hS1_empty : S₁ = ∅ := by\n      rw [Finset.eq_empty_iff_forall_not_mem]\n      intro x hx\n      have : 0 < ∑ y ∈ S₁, y := h_pos (Finset.sdiff_subset.trans hA) ⟨x, hx⟩\n      rw [h_sum] at this\n      exact lt_irrefl 0 this\n    rw [Finset.sdiff_eq_empty_iff_subset] at h hS1_empty\n    exact hAB (Finset.Subset.antisymm hS1_empty h)\n  exact ⟨S₁, S₂, hS1, Finset.sdiff_subset.trans hA, hS2, Finset.sdiff_subset.trans hB, disjoint_sdiff_sdiff, h_sum⟩",
      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset_self _), Finset.card_powerset, h₀]\n    norm_num\n  have h_sum : ∀ s ∈ P, ∑ x ∈ s, x ∈ Finset.range 1000 := by\n    intro s hs\n    rw [Finset.mem_range]\n    have : s ⊆ S := Finset.mem_powerset.1 (Finset.mem_of_mem_erase hs)\n    refine (Finset.sum_le_sum_of_subset_of_nonneg this (by simp)).trans_lt ?_\n    calc ∑ x ∈ S, x ≤ S.card * 99 := Finset.sum_le_card_nsmul S _ 99 (fun x hx ↦ Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ hx)).2)\n      _ < 1000 := by rw [h₀]; norm_num\n  obtain ⟨A, hA, B, hB, hAB, hSum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to (by rw [hP, Finset.card_range]; norm_num) h_sum\n  have hAS : A ⊆ S := Finset.mem_powerset.1 (Finset.mem_of_mem_erase hA)\n  have hBS : B ⊆ S := Finset.mem_powerset.1 (Finset.mem_of_mem_erase hB)\n  have h_pos : ∀ x ∈ S, 0 < x := fun x hx ↦ (Finset.mem_Ico.1 (h₁ hx)).1.trans_le (by norm_num)\n  refine ⟨A \\ B, B \\ A, ?_, (Finset.sdiff_subset A B).trans hAS, ?_, (Finset.sdiff_subset B A).trans hBS, disjoint_sdiff_sdiff, ?_⟩\n  · rw [Finset.sdiff_nonempty]; by_contra h\n    exact (Finset.sum_lt_sum_of_subset h hAB.symm (fun x hx _ ↦ h_pos x (hAS hx))).ne hSum.symm\n  · rw [Finset.sdiff_nonempty]; by_contra h\n    exact (Finset.sum_lt_sum_of_subset h hAB (fun x hx _ ↦ h_pos x (hBS hx))).ne hSum\n  · rw [Finset.sum_sdiff_eq_sub (Finset.inter_subset_left A B), Finset.sum_sdiff_eq_sub (Finset.inter_subset_right A B), hSum]",
      "\n  let P := S.powerset.filter (·.Nonempty)\n  have hP : P.card = 1023 := by\n    rw [Finset.filter_nonempty_eq_erase_empty_powerset, Finset.card_erase_of_mem (Finset.empty_mem_powerset _), Finset.card_powerset, h₀]\n    rfl\n  let f (s : Finset ℕ) := ∑ x ∈ s, x\n  have h_map : ∀ s ∈ P, f s ∈ Finset.Icc 0 990 := by\n    intro s hs\n    rw [Finset.mem_filter, Finset.mem_powerset] at hs\n    rw [Finset.mem_Icc]\n    refine ⟨zero_le _, (Finset.sum_le_sum_of_subset_of_nonneg hs.1 (λ _ _ ↦ zero_le _)).trans ?_⟩\n    exact (Finset.sum_le_card_nsmul S 99 (λ x hx ↦ (Finset.mem_Ico.mp (h₁ hx)).2.le)).trans_eq (by rw [h₀]; rfl)\n  \n  have h_card : (Finset.Icc 0 990).card < P.card := by rw [Finset.card_Icc, hP]; norm_num\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_map h_card\n  rw [Finset.mem_filter] at hA hB\n\n  let S₁ := A \\ B\n  let S₂ := B \\ A\n  have h_sum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    apply Nat.add_right_cancel (k := ∑ x ∈ A ∩ B, x)\n    rw [Finset.sum_sdiff (Finset.inter_subset_left A B), Finset.sum_sdiff (Finset.inter_subset_right A B), hsum]\n\n  have h_not_empty : ∀ X, X ⊆ S → ∑ x ∈ X, x = 0 → X = ∅ := by\n    intro X hX hSum\n    rw [Finset.eq_empty_iff_forall_not_mem]\n    intro x hx\n    apply (ne_of_gt (lt_of_lt_of_le (by norm_num) (Finset.mem_Ico.mp (h₁ (hX hx))).1)).symm\n    exact Finset.sum_eq_zero_iff.mp hSum x hx\n\n  refine ⟨S₁, S₂, ?_, Finset.sdiff_subset _ _, ?_, Finset.sdiff_subset _ _, Finset.disjoint_sdiff_sdiff, h_sum_eq⟩\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    have : S₂ = ∅ := h_not_empty S₂ (Finset.sdiff_subset _ _) (by rw [← h_sum_eq, h, Finset.sum_empty])\n    rw [Finset.sdiff_eq_empty] at h this\n    exact hne (Subset.antisymm h this)\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    have : S₁ = ∅ := h_not_empty S₁ (Finset.sdiff_subset _ _) (by rw [h_sum_eq, h, Finset.sum_empty])\n    rw [Finset.sdiff_eq_empty] at h this\n    exact hne (Subset.antisymm this h)",
      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.2 S.empty_subset), Finset.card_powerset, h₀]\n    norm_num\n  let f (s : Finset ℕ) := ∑ x ∈ s, x\n  let T := Finset.Icc 1 990\n  have hT : T.card = 990 := by rw [Finset.card_Icc]; rfl\n  have h_map : ∀ s ∈ P, f s ∈ T := by\n    intro s hs\n    rw [Finset.mem_erase, Finset.mem_powerset] at hs\n    have hne : s.Nonempty := Finset.nonempty_iff_ne_empty.2 hs.1\n    have hsub : s ⊆ S := hs.2\n    rw [Finset.mem_Icc]\n    constructor\n    · rcases hne with ⟨x, hx⟩\n      exact le_trans (by norm_num) (le_trans (Finset.mem_Ico.1 (h₁ (hsub hx))).1 (Finset.le_sum_of_mem hx))\n    · apply le_trans (Finset.sum_le_card_nsmul s 99 (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (hsub hx))).2))\n      exact le_trans (Nat.mul_le_mul_right 99 (Finset.card_le_card hsub)) (by rw [h₀]; norm_num)\n  have : T.card < P.card := by rw [hP, hT]; norm_num\n  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to this h_map\n  use A \\ B, B \\ A\n  rw [Finset.mem_erase, Finset.mem_powerset] at hA hB\n  have hpos : ∀ x ∈ S, 0 < x := fun x hx => lt_of_lt_of_le (by norm_num) (Finset.mem_Ico.1 (h₁ hx)).1\n  have hsum : ∑ x ∈ A \\ B, x = ∑ x ∈ B \\ A, x := by\n    refine Nat.add_right_cancel (k := ∑ x ∈ A ∩ B, x) ?_\n    rw [← Finset.sum_union (Finset.disjoint_sdiff_inter A B), Finset.sdiff_union_inter, heq,\n        ← Finset.sum_union (Finset.disjoint_sdiff_inter B A), Finset.sdiff_union_inter, Finset.inter_comm]\n  refine ⟨?_, (Finset.sdiff_subset A B).trans hA.2, ?_, (Finset.sdiff_subset B A).trans hB.2,\n    Finset.disjoint_of_subset_right (Finset.sdiff_subset B A) Finset.disjoint_sdiff_left, hsum⟩\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    exact ne_of_lt (Finset.sum_lt_sum_of_ssubset (Finset.ssubset_iff_subset_ne.2 ⟨hsub, hne⟩)\n      (fun x hx _ => hpos x (hB.2 hx))) heq\n  · rw [Fin