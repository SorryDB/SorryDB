theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let P := S.powerset
  have hP : P.card = 1024 := by rw [Finset.card_powerset, h₀]; norm_num
  let f (s : Finset ℕ) := ∑ x in s, x
  have h_img : ∀ s ∈ P, f s ∈ Finset.range 1000 := by
    intro s hs
    rw [Finset.mem_powerset] at hs
    rw [Finset.mem_range]
    calc ∑ x in s, x ≤ ∑ x in s, 99 := Finset.sum_le_sum (λ x hx ↦ Nat.le_of_lt_succ <| (Finset.mem_Ico.mp <| h₁ (hs hx)).2)
      _ = s.card * 99 := by rw [Finset.sum_const, Nat.nsmul_eq_mul]
      _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (hs.card_le.trans h₀.le)
      _ < 1000 := by norm_num
  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to (by rw [Finset.card_range, hP]; norm_num) h_img
  rw [Finset.mem_powerset] at hA hB
  use A \ B, B \ A
  have hsum : ∑ x in A \ B, x = ∑ x in B \ A, x := by
    apply Nat.add_right_cancel (k := ∑ x in A ∩ B, x)
    rw [← Finset.sum_sdiff_add_sum_inter A B, ← Finset.sum_sdiff_add_sum_inter B A, heq, Finset.inter_comm]
  have hpos : ∀ X : Finset ℕ, X ⊆ S → ∑ x in X, x = 0 → X = ∅ := by
    intro X hX hsum
    refine Finset.eq_empty_of_sum_eq_zero hsum (λ x hx ↦ ?_)
    exact ((Finset.mem_Ico.mp (h₁ (hX hx))).1).trans_le (by norm_num)
  refine ⟨?_, Finset.sdiff_subset _ _ |>.trans hA, ?_, Finset.sdiff_subset _ _ |>.trans hB, Finset.sdiff_disjoint.mono_right (Finset.sdiff_subset _ _), hsum⟩
  · rw [Finset.nonempty_iff_ne_empty]; intro h
    have hsub : A ⊆ B := Finset.sdiff_eq_empty_iff_subset.mp h
    have : B \ A = ∅ := hpos _ (Finset.sdiff_subset _ _ |>.trans hB) (by rw [← hsum, h, Finset.sum_empty])
    exact hne (Finset.Subset.antisymm hsub (Finset.sdiff_eq_empty_iff_subset.mp this))
  · rw [Finset.nonempty_iff_ne_empty]; intro h
    have hsub : B ⊆ A := Finset.sdiff_eq_empty_iff_subset.mp h
    have : A \ B = ∅ := hpos _ (Finset.sdiff_subset _ _ |>.trans hA) (by rw [hsum, h, Finset.sum_empty])
    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.mp this) hsub)
