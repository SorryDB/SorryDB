      "\n  let f (s : Finset ℕ) := ∑ x ∈ s, x\n  have h_bound : ∀ s ∈ S.powerset, f s ∈ Finset.range 1000 := by\n    intros s hs\n    rw [Finset.mem_range]\n    calc ∑ x ∈ s, x ≤ ∑ x ∈ S, x := Finset.sum_le_sum_of_subset_of_nonneg (Finset.mem_powerset.1 hs) (fun _ _ ↦ Nat.zero_le _)\n      _ < S.card * 100 := Finset.sum_lt_card_mul_of_top (fun x hx ↦ (Finset.mem_Ico.1 (h₁ hx)).2) (by rw [h₀]; norm_num)\n      _ = 1000 := by rw [h₀]; norm_num\n\n  have h_card : (Finset.range 1000).card < S.powerset.card := by\n    rw [Finset.card_range, Finset.card_powerset, h₀]; norm_num\n  \n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_card h_bound\n  rw [Finset.mem_powerset] at hA hB\n\n  let S₁ := A \\ B; let S₂ := B \\ A\n  have h_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    apply Nat.add_right_cancel (k := ∑ x ∈ A ∩ B, x)\n    rw [← Finset.sum_sdiff_add_inter A B, ← Finset.sum_sdiff_add_inter B A, Finset.inter_comm, hsum]\n\n  have h_pos : ∀ X ⊆ S, ∑ x ∈ X, x = 0 → X = ∅ := by\n    intros X hX h_sum\n    rw [Finset.sum_eq_zero_iff] at h_sum\n    rw [Finset.eq_empty_iff_forall_not_mem]\n    intros x hx\n    have : x ≥ 10 := (Finset.mem_Ico.1 (h₁ (hX hx))).1\n    rw [h_sum x hx] at this\n    contradiction\n\n  have h_ne₁ : S₁.Nonempty := by\n    intro h\n    rw [Finset.not_nonempty_iff_eq_empty] at h\n    have : S₂ = ∅ := h_pos S₂ (Finset.sdiff_subset.trans hB) (by rw [← h_eq, h, Finset.sum_empty])\n    rw [Finset.sdiff_eq_empty_iff_subset] at h this\n    exact hne (Finset.Subset.antisymm h this)\n\n  have h_ne₂ : S₂.Nonempty := by\n    intro h\n    rw [Finset.not_nonempty_iff_eq_empty] at h\n    exact h_ne₁.ne_empty (h_pos S₁ (Finset.sdiff_subset.trans hA) (by rw [h_eq, h, Finset.sum_empty]))\n\n  exact ⟨S₁, S₂, h_ne₁, Finset.sdiff_subset.trans hA, h_ne₂, Finset.sdiff_subset.trans hB, disjoint_sdiff_sdiff, h_eq⟩",
      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.2 S.empty_subset), Finset.card_powerset, h₀]\n    norm_num\n  have h_sum : ∀ s ∈ P, ∑ x ∈ s, x ∈ Finset.range 1000 := by\n    intro s hs\n    rw [Finset.mem_range]\n    have hsub : s ⊆ S := Finset.mem_powerset.1 (Finset.mem_of_mem_erase hs)\n    refine (Finset.sum_le_card_nsmul s 99 (fun x hx => ?_)).trans_lt ?_\n    · exact Nat.le_pred_of_lt (Finset.mem_Ico.1 (h₁ (hsub hx))).2\n    · calc s.card * 99 ≤ 10 * 99 := Nat.mul_le_mul_right 99 (hsub.card_le.trans h₀.le)\n             _ < 1000 := by norm_num\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to \n    (by rw [hP, Finset.card_range]; norm_num) h_sum\n  have hA_sub : A ⊆ S := Finset.mem_powerset.1 (Finset.mem_of_mem_erase hA)\n  have hB_sub : B ⊆ S := Finset.mem_powerset.1 (Finset.mem_of_mem_erase hB)\n  refine ⟨A \\ B, B \\ A, ?_, Finset.sdiff_subset _ _ |>.trans hA_sub, ?_, \n    Finset.sdiff_subset _ _ |>.trans hB_sub, Finset.disjoint_sdiff_sdiff, ?_⟩\n  · intro h\n    rw [Finset.sdiff_eq_empty_iff_subset] at h\n    apply hne\n    apply Finset.Subset.antisymm h\n    rw [← Finset.sdiff_eq_empty_iff_subset]\n    apply Finset.eq_empty_of_forall_not_mem\n    intro x hx\n    have : ∑ x in B \\ A, x = 0 := by rw [Finset.sum_sdiff h, hsum, Nat.sub_self]\n    have x0 : x = 0 := Finset.sum_eq_zero_iff.mp this x hx\n    have : 10 ≤ x := (Finset.mem_Ico.mp (h₁ (hB_sub (Finset.sdiff_subset B A hx)))).1\n    rw [x0] at this; contradiction\n  · intro h\n    rw [Finset.sdiff_eq_empty_iff_subset] at h\n    apply hne\n    apply (Finset.Subset.antisymm h _).symm\n    rw [← Finset.sdiff_eq_empty_iff_subset]\n    apply Finset.eq_empty_of_forall_not_mem\n    intro x hx\n    have : ∑ x in A \\ B, x = 0 := by rw [Finset.sum_sdiff h, hsum, Nat.sub_self]\n    have x0 : x = 0 := Finset.sum_eq_zero_iff.mp this x hx\n    have : 10 ≤ x := (Finset.mem_Ico.mp (h₁ (hA_sub (Finset.sd