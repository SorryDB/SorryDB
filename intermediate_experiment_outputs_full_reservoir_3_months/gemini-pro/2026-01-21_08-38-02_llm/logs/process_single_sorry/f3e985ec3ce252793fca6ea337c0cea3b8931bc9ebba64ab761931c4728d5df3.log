      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 2 ^ 10 - 1 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.mpr (Finset.empty_subset S)), Finset.card_powerset, h₀]\n    rfl\n  have h_sum : ∀ s ∈ P, ∑ x ∈ s, x ∈ Finset.Icc 1 1000 := by\n    intro s hs\n    have hs_sub : s ⊆ S := Finset.mem_powerset.mp (Finset.mem_of_mem_erase hs)\n    have hs_ne : s.Nonempty := Finset.nonempty_of_ne_empty (Finset.ne_of_mem_erase hs)\n    constructor\n    · apply Nat.one_le_of_lt\n      refine Finset.sum_pos (fun x hx => ?_) hs_ne\n      exact lt_of_lt_of_le (by norm_num) (Nat.mem_Ico.mp (h₁ (hs_sub hx))).1\n    · apply le_trans (Finset.sum_le_sum_of_subset_of_nonneg hs_sub (fun _ _ _ => zero_le _))\n      apply le_of_lt\n      calc ∑ x ∈ S, x < S.card * 100 := Finset.sum_lt_card_mul_of_forall (by rw [← Finset.card_pos, h₀]; norm_num) (fun x hx => (Nat.mem_Ico.mp (h₁ hx)).2)\n        _ = 1000 := by rw [h₀]; rfl\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_sum (by rw [hP, Finset.card_Icc]; norm_num)\n  refine ⟨A \\ B, B \\ A, ?_, ?_, ?_, ?_, ?_, ?_⟩\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    apply hne\n    apply Finset.eq_of_subset_of_sum_eq hsub hsum\n    intro x hx\n    exact ne_of_gt (lt_of_lt_of_le (by norm_num) (Nat.mem_Ico.mp (h₁ (Finset.mem_powerset.mp (Finset.mem_of_mem_erase hB) hx))).1)\n  · exact (Finset.sdiff_subset A B).trans (Finset.mem_powerset.mp (Finset.mem_of_mem_erase hA))\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    apply hne\n    symm\n    apply Finset.eq_of_subset_of_sum_eq hsub hsum.symm\n    intro x hx\n    exact ne_of_gt (lt_of_lt_of_le (by norm_num) (Nat.mem_Ico.mp (h₁ (Finset.mem_powerset.mp (Finset.mem_of_mem_erase hA) hx))).1)\n  · exact (Finset.sdiff_subset B A).trans (Finset.mem_powerset.mp (Finset.mem_of_mem_erase hB))\n  · exact Finset.disjoint_sdiff_sdiff\n  · have h1 : ∑ x ∈ A, x