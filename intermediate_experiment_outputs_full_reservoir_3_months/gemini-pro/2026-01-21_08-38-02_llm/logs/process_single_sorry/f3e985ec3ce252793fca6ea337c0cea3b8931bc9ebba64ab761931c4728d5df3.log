      "\n  let P := S.powerset.erase ∅\n  let f : Finset ℕ → ℕ := fun s ↦ ∑ x ∈ s, x\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.mpr (Finset.empty_subset _)), Finset.card_powerset, h₀]\n    norm_num\n  have h_im : ∀ s ∈ P, f s ∈ Finset.Icc 1 990 := by\n    intro s hs\n    rw [Finset.mem_erase, Finset.mem_powerset] at hs\n    obtain ⟨hne, hss⟩ := hs\n    rw [Finset.mem_Icc]\n    constructor\n    · obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.mp hne\n      exact le_trans (by norm_num) (le_trans (by have := h₁ (hss hx); simp at this; exact this.1) \n        (Finset.single_le_sum (fun _ _ => zero_le _) hx))\n    · apply le_trans (Finset.sum_le_card_nsmul s 99 (fun x ↦ x) (fun x hx ↦ le_of_lt (Finset.mem_Ico.mp (h₁ (hss hx))).2))\n      apply mul_le_mul' (Finset.card_le_card hss) (le_refl _) <;> rw [h₀] <;> norm_num\n  have : (Finset.Icc 1 990).card < P.card := by rw [Finset.card_Icc, hP]; norm_num\n  obtain ⟨A, hA, B, hB, hAB, hSum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to this h_im\n  rw [Finset.mem_erase, Finset.mem_powerset] at hA hB\n  refine ⟨A \\ B, B \\ A, ?_, Finset.sdiff_subset.trans hA.2, ?_, Finset.sdiff_subset.trans hB.2, disjoint_sdiff_sdiff, ?_⟩\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    rw [Finset.sdiff_eq_empty_iff_subset] at h\n    have : ∑ x ∈ A, x < ∑ x ∈ B, x := by\n      rw [←Finset.sum_sdiff h, lt_add_iff_pos_left]\n      refine Finset.sum_pos (fun x hx ↦ lt_of_lt_of_le (by norm_num) (Finset.mem_Ico.mp (h₁ (hB.2 (Finset.sdiff_subset _ _ hx)))).1) ?_\n      rw [Finset.nonempty_iff_ne_empty]; intro h'; apply hAB; rw [Finset.sdiff_eq_empty_iff_subset] at h'\n      exact h.antisymm h'\n    linarith\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    rw [Finset.sdiff_eq_empty_iff_subset] at h\n    have : ∑ x ∈ B, x < ∑ x ∈ A, x := by\n      rw [←Finset.sum_sdiff h, lt_add_iff_pos_left]\n      refine Finset.sum_pos (fun x hx ↦ lt_of_lt_of_le (by norm_num) (Finset.mem_Ico.mp (h₁ (hA.2 (Finse