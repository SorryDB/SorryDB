      "\n  let f := fun s ↦ ∑ x ∈ s, x\n  have h_bound : ∀ x ∈ S.powerset, f x ∈ Finset.range 1000 := fun x hx ↦ by\n    rw [Finset.mem_range, Finset.mem_powerset] at hx ⊢\n    calc ∑ y ∈ x, y ≤ x.card * 99 := Finset.sum_le_card_nsmul x _ 99 \n        (fun y hy ↦ Nat.le_of_lt_succ (Finset.mem_Ico.mp (h₁ (hx hy))).2)\n      _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 ((Finset.card_le_of_subset hx).trans_eq h₀)\n      _ < 1000 := by norm_num\n  have h_card : (Finset.range 1000).card < S.powerset.card := by\n    rw [Finset.card_range, Finset.card_powerset, h₀]; norm_num\n  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_card h_bound\n  refine ⟨A \\ B, B \\ A, ?_, (Finset.sdiff_subset A B).trans (Finset.mem_powerset.mp hA),\n         ?_, (Finset.sdiff_subset B A).trans (Finset.mem_powerset.mp hB), disjoint_sdiff_sdiff, ?_⟩\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    rw [Finset.sdiff_eq_empty_iff_subset] at h\n    apply hne; apply Subset.antisymm h\n    rw [← Finset.sdiff_eq_empty_iff_subset, Finset.eq_empty_iff_forall_not_mem]\n    intro x hx\n    have : ∑ y ∈ B \\ A, y = 0 := by rw [Finset.sum_sdiff h] at heq; exact (self_eq_add_right.mp heq.symm)\n    exact ((Finset.mem_Ico.mp (h₁ (Finset.mem_powerset.mp hB (Finset.mem_sdiff.mp hx).1))).1.trans_le \n      (by norm_num)).ne' (Finset.sum_eq_zero_iff.mp this x hx)\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    rw [Finset.sdiff_eq_empty_iff_subset] at h\n    apply hne; apply Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.mp ?_) h\n    rw [Finset.eq_empty_iff_forall_not_mem]\n    intro x hx\n    have : ∑ y ∈ A \\ B, y = 0 := by rw [Finset.sum_sdiff h] at heq; exact (self_eq_add_right.mp heq)\n    exact ((Finset.mem_Ico.mp (h₁ (Finset.mem_powerset.mp hA (Finset.mem_sdiff.mp hx).1))).1.trans_le \n      (by norm_num)).ne' (Finset.sum_eq_zero_iff.mp this x hx)\n  · rw [← Finset.sdiff_inter_self_right A B, Finset.sum_sdiff (Finset.inter_subset_left A B),\n        heq, ← Finset.sdiff_inter_self_right B A, Finset.sum_sdiff (Finset.inter_subset_left B A),\n        Finset.inter_comm]",
      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.mpr S.empty_subset), Finset.card_powerset, h₀]\n    norm_num\n  let f (X : Finset ℕ) := ∑ x ∈ X, x\n  let T := Finset.Icc 10 990\n  have hT : T.card = 981 := by rw [Finset.card_Icc]; norm_num\n  have h_maps : ∀ X ∈ P, f X ∈ T := by\n    intro X hX\n    rw [Finset.mem_erase, Finset.mem_powerset, Finset.nonempty_iff_ne_empty] at hX\n    rw [Finset.mem_Icc]\n    constructor\n    · obtain ⟨x, hx⟩ := hX.1\n      exact (le_of_mem_Ico (h₁ (hX.2 hx))).1.trans (Finset.single_le_sum (λ _ _ ↦ zero_le _) hx)\n    · calc ∑ x ∈ X, x ≤ ∑ x ∈ X, 99 := Finset.sum_le_sum (λ x hx ↦ le_of_lt (mem_Ico.mp (h₁ (hX.2 hx))).2)\n        _ = X.card * 99 := by simp [Finset.sum_const, nsmul_eq_mul]\n        _ ≤ S.card * 99 := Nat.mul_le_mul_right 99 (Finset.card_le_card hX.2)\n        _ = 990 := by rw [h₀]; norm_num\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to (by rw [hP, hT]; norm_num) h_maps\n  rw [Finset.mem_erase, Finset.mem_powerset] at hA hB\n  refine ⟨A \\ B, B \\ A, ?_, ?_, ?_, ?_, disjoint_sdiff_sdiff, ?_⟩\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    have : ∑ x ∈ B \\ A, x = 0 := by\n      rw [← Finset.sum_sdiff hsub] at hsum\n      exact Nat.add_left_cancel hsum\n    have : B \\ A = ∅ := Finset.eq_empty_of_forall_not_mem (λ x hx ↦ \n      ne_of_gt ((le_of_mem_Ico (h₁ (hB.2 (Finset.sdiff_subset _ _ hx)))).1.trans_lt (by norm_num)) \n      (Finset.sum_eq_zero_iff.mp this x hx))\n    exact hne (hsub.antisymm (Finset.sdiff_eq_empty_iff_subset.mp this))\n  · exact (Finset.sdiff_subset _ _).trans hA.2\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    have : ∑ x ∈ A \\ B, x = 0 := by\n      rw [← Finset.sum_sdiff hsub] at hsum\n      exact Nat.add_right_cancel hsum\n    have : A \\ B = ∅ := Finset.eq_empty_of_forall_not_mem (λ x