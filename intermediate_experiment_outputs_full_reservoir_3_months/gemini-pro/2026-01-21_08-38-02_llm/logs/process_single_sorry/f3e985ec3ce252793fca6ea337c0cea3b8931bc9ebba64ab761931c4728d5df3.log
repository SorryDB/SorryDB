      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 2 ^ 10 - 1 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.mpr (Finset.empty_subset _)), Finset.card_powerset, h₀]\n  let max_sum := 10 * 99\n  let f := fun s => ∑ x ∈ s, x\n  have h_im : ∀ s ∈ P, f s ∈ Finset.Icc 10 max_sum := by\n    intro s hs\n    rw [Finset.mem_erase, Finset.mem_powerset] at hs\n    obtain ⟨hne, hsub⟩ := hs\n    have hne' : s.Nonempty := Finset.nonempty_iff_ne_empty.mpr hne\n    constructor\n    · obtain ⟨x, hx⟩ := hne'\n      apply le_trans _ (Finset.single_le_sum (fun _ _ => zero_le _) hx)\n      exact (Finset.mem_Ico.mp (h₁ (hsub hx))).1\n    · apply le_trans (Finset.sum_le_card_nsmul s 99 (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.mp (h₁ (hsub hx))).2))\n      apply Nat.mul_le_mul_right 99 (trans (Finset.card_le_of_subset hsub) (le_of_eq h₀))\n  have h_card : P.card > (Finset.Icc 10 max_sum).card := by\n    rw [hP, Nat.card_Icc]\n    norm_num\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_card h_im\n  rw [Finset.mem_erase, Finset.mem_powerset] at hA hB\n  refine ⟨A \\ B, B \\ A, ?_, ?_, ?_, ?_, ?_, ?_⟩\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    apply hne\n    have : ∑ x ∈ B \\ A, x = 0 := by\n      rw [← Nat.add_right_eq_self (∑ x ∈ A, x), ← hsum, ← Finset.sum_sdiff hsub]\n    rw [Finset.sum_eq_zero_iff] at this\n    have hBA : B \\ A = ∅ := Finset.eq_empty_of_forall_not_mem (fun x hx => by\n      specialize this x hx\n      have x_ge_10 : 10 ≤ x := (Finset.mem_Ico.mp (h₁ (hB.2 (Finset.sdiff_subset B A hx)))).1\n      linarith)\n    rw [Finset.sdiff_eq_empty_iff_subset] at hBA\n    exact Finset.subset_antisymm hsub hBA\n  · exact (Finset.sdiff_subset _ _).trans hA.2\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    apply hne\n    symm\n    have : ∑ x ∈ A \\ B, x = 0 := by\n      rw [← Nat.add_right_eq_self (∑ x ∈ B, x), hsum, ← Finset.sum_sdiff hsub]\n    rw [Finset.sum_eq_zero_iff] at this\n    have hAB : A \\ B = ∅ := Finset.eq_empty_of_forall_not_mem (fun x hx => by\n      specialize this x hx\n      have x_ge_10 : 10 ≤ x := (Finset.mem_Ico.mp (h₁ (hA.2 (Finset.sdiff_subset A B hx)))).1\n      linarith)\n    rw [Finset.sdiff_eq_empty_iff_subset] at hAB\n    exact Finset.subset_antisymm hAB hsub\n  · exact (Finset.sdiff_subset _ _).trans hB.2\n  · exact Finset.disjoint_sdiff_sdiff\n  · rw [Finset.sum_sdiff_eq_sub (Finset.inter_subset_left _ _), Finset.sum_sdiff_eq_sub (Finset.inter_subset_right _ _), hsum, Finset.inter_comm]",
      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.mpr S.empty_subset), Finset.card_powerset, h₀]\n    norm_num\n\n  let f (A : Finset ℕ) := ∑ x ∈ A, x\n  let T := Finset.Icc 1 990\n  have h_map : ∀ A ∈ P, f A ∈ T := by\n    intro A hA\n    rw [Finset.mem_erase, Finset.mem_powerset] at hA\n    rw [Finset.mem_Icc]\n    constructor\n    · obtain ⟨x, hx⟩ := hA.1\n      exact le_trans (by norm_num) (Finset.single_le_sum (fun _ _ => zero_le _) hx)\n    · apply le_trans (Finset.sum_le_sum_of_subset_of_nonneg hA.2 (fun _ _ => zero_le _))\n      apply le_trans (Finset.sum_le_card_nsmul S 99 (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.mp (h₁ hx)).2))\n      rw [h₀]; norm_num\n\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to \n    (by rw [hP, Finset.card_Icc]; norm_num : T.card < P.card) h_map\n  rw [Finset.mem_erase, Finset.mem_powerset] at hA hB\n\n  let S₁ := A \\ B\n  let S₂ := B \\ A\n  have h_sum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    dsimp [f] at hsum\n    rw [← Finset.sum_sdiff_eq_sub (Finset.inter_subset_left A B), \n        ← Finset.sum_sdiff_eq_sub (Finset.inter_subset_right A B), hsum, Finset.inter_comm]\n\n  have h_empty_imp (X Y : Finset ℕ) (hY : Y ⊆ S) (heq : ∑ x ∈ X \\ Y, x = ∑ x ∈ Y \\ X, x) (h : X \\ Y = ∅) : Y \\ X = ∅ := by\n    rw [h, Finset.sum_empty] at heq\n    exact Finset.eq_empty_of_forall_not_mem fun x hx => (lt_of_lt_of_le (by norm_num) \n      (Finset.mem_Ico.mp (h₁ (hY (Finset.sdiff_subset _ _ hx)))).1).ne' \n      (Finset.sum_eq_zero_iff_of_nonneg (fun _ _ => zero_le _) |> (·.mp heq.symm) _ hx)\n\n  refine ⟨S₁, S₂, ?, (Finset.sdiff_subset _ _).trans hA.2, ?, (Finset.sdiff_subset _ _).trans hB.2, Finset.disjoint_sdiff_sdiff, h_sum_eq⟩\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    have h' := h_empty_imp A B hB.2 h_sum_eq h\n    rw [Finset.sdiff_eq_empty_iff_subset] at h h'\n    exact hne (Finset.Subset.antisymm h h')\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    have h' := h_empty_imp B A hA.2 h_sum_eq.symm h\n    rw [Finset.sdiff_eq_empty_iff_subset] at h h'\n    exact hne (Finset.Subset.antisymm h' h)",
      "\n  let P := S.powerset.filter Finset.Nonempty\n  have hP : P.card = 1023 := by\n    rw [← Finset.erase_eq_filter_ne_self_of_mem _ (Finset.mem_powerset.2 S.empty_subset),\n      Finset.card_erase_of_mem (Finset.mem_powerset.2 S.empty_subset),\n      Finset.card_powerset, h₀]; norm_num\n  have h_map : ∀ s ∈ P, ∑ x in s, x ∈ Finset.Icc 10 990 := by\n    intro s hs\n    rw [Finset.mem_filter] at hs\n    obtain ⟨hsub, ⟨x, hx⟩⟩ := hs\n    rw [Finset.mem_powerset] at hsub\n    rw [Finset.mem_Icc]; constructor\n    · exact (le_of_lt (h₁ (hsub hx)).1).trans (Finset.single_le_sum (fun _ _ ↦ zero_le _) hx)\n    · exact (Finset.sum_le_card_nsmul s 99 (fun x hx ↦ le_of_lt (h₁ (hsub hx)).2)).trans\n        (mul_le_mul_left _ (Finset.card_le_card hsub) |>.trans_eq (by rw [h₀]; rfl))\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to\n    (by rw [hP, Finset.card_Icc]; norm_num) h_map\n  rw [Finset.mem_filter] at hA hB; obtain ⟨hA, -⟩ := hA; obtain ⟨hB, -⟩ := hB\n  let S₁ := A \\ B; let S₂ := B \\ A\n  have h_eq : ∑ x in S₁, x = ∑ x in S₂, x := by\n    rw [Finset.sum_sdiff_eq_sub (Finset.inter_subset_left ..),\n      Finset.sum_sdiff_eq_sub (Finset.inter_subset_right ..), hsum, Finset.inter_comm]\n  have h_nempty : ∀ {X}, X ⊆ S → ∑ x in X, x = 0 → X = ∅ := fun hX h ↦\n    Finset.eq_empty_of_forall_not_mem fun x hx ↦ (h₁ (hX hx)).1.ne' <|\n      Finset.sum_eq_zero_iff_of_nonneg (fun _ _ ↦ zero_le _) |>.1 h x hx\n  refine ⟨S₁, S₂, ?_, Finset.sdiff_subset.trans (Finset.mem_powerset.1 hA),\n    ?_, Finset.sdiff_subset.trans (Finset.mem_powerset.1 hB), Finset.disjoint_sdiff_sdiff, h_eq⟩\n  · intro h; apply hne; apply Finset.subset_antisymm\n    · exact Finset.sdiff_eq_empty_iff_subset.1 h\n    · exact Finset.sdiff_eq_empty_iff_subset.1 <| h_nempty (Finset.sdiff_subset.trans (Finset.mem_powerset.1 hB)) (by rw [←h_eq, h, Finset.sum_empty])\n  · intro h; apply hne; apply Finset.subset_antisymm\n    · exact Finset.sdiff_eq_empty_iff_subset.1 <| h_nem