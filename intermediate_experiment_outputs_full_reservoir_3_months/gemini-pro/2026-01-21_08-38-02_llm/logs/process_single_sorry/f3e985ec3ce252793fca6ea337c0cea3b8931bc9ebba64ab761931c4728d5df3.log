      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.mpr (Finset.empty_subset _))]\n    rw [Finset.card_powerset, h₀]\n    norm_num\n  let f (A : Finset ℕ) := ∑ x ∈ A, x\n  let max_sum := 1000\n  have h_im : ∀ A ∈ P, f A ∈ Finset.range max_sum := by\n    intro A hA\n    rw [Finset.mem_range]\n    have hA_sub : A ⊆ S := Finset.mem_powerset.mp (Finset.mem_of_mem_erase hA)\n    calc ∑ x ∈ A, x ≤ ∑ x ∈ S, x := Finset.sum_le_sum_of_subset_of_nonneg hA_sub (by simp)\n      _ ≤ S.card * 99 := by\n        apply Finset.sum_le_card_nsmul\n        intro x hx\n        have := h₁ hx\n        rw [Finset.mem_Ico] at this\n        linarith\n      _ < max_sum := by rw [h₀]; norm_num\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to (by rw [hP, Finset.card_range]; norm_num) h_im\n  let S₁ := A \\ B\n  let S₂ := B \\ A\n  refine ⟨S₁, S₂, ?_, ?_, ?_, ?_, ?_, ?_⟩\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    refine hne (Finset.eq_of_subset_of_sum_eq hsub hsum (λ x hxB hxnA ↦ ?_))\n    have : x ∈ S := Finset.mem_powerset.mp (Finset.mem_of_mem_erase hB) hxB\n    have := h₁ this\n    rw [Finset.mem_Ico] at this; linarith\n  · exact (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.mp (Finset.mem_of_mem_erase hA))\n  · rw [Finset.nonempty_iff_ne_empty, Ne, Finset.sdiff_eq_empty_iff_subset]\n    intro hsub\n    refine hne (Finset.eq_of_subset_of_sum_eq hsub hsum.symm (λ x hxA hxnB ↦ ?_)).symm\n    have : x ∈ S := Finset.mem_powerset.mp (Finset.mem_of_mem_erase hA) hxA\n    have := h₁ this\n    rw [Finset.mem_Ico] at this; linarith\n  · exact (Finset.sdiff_subset _ _).trans (Finset.mem_powerset.mp (Finset.mem_of_mem_erase hB))\n  · exact Finset.disjoint_sdiff_sdiff\n  · rw [← Finset.sum_sdiff_add_sum_inter A B, ← Finset.sum_sdiff_add_sum_inter B A, Finset.inter_comm] at hsum\n    exact add_right_cancel hsum",
      "\n  let f : Finset ℕ → ℕ := fun s => ∑ x ∈ s, x\n  have h_bound : ∀ s ∈ S.powerset, f s ∈ Finset.range 1000 := by\n    intro s hs\n    rw [Finset.mem_powerset] at hs\n    rw [Finset.mem_range]\n    calc ∑ x ∈ s, x\n      _ ≤ s.card * 99 := Finset.sum_le_card_nsmul s _ 99 (fun x hx => Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (hs hx))).2)\n      _ ≤ 10 * 99 := Nat.mul_le_mul_right 99 (hs.card_le.trans_eq h₀)\n      _ < 1000 := by norm_num\n  have h_card : S.powerset.card > (Finset.range 1000).card := by\n    rw [Finset.card_powerset, h₀, Finset.card_range]\n    norm_num\n  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to _ _ f h_card h_bound\n  rw [Finset.mem_powerset] at hA hB\n  refine ⟨A \\ B, B \\ A, ?_, (Finset.sdiff_subset _ _).trans hA, ?_, (Finset.sdiff_subset _ _).trans hB, disjoint_sdiff_sdiff, ?_⟩\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    have hsub : A ⊆ B := Finset.sdiff_eq_empty_iff_subset.1 h\n    have : ∑ x ∈ B \\ A, x = 0 := by\n      apply Nat.add_left_cancel (n := ∑ x ∈ A, x)\n      rw [add_zero, heq, ← Finset.sum_sdiff hsub, add_comm]\n    have : B \\ A = ∅ := Finset.eq_empty_of_sum_eq_zero this fun x hx =>\n       (Finset.mem_Ico.1 (h₁ (hB (Finset.sdiff_subset _ _ hx)))).1.ne'\n    exact hne (Finset.Subset.antisymm hsub (Finset.sdiff_eq_empty_iff_subset.1 this))\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    have hsub : B ⊆ A := Finset.sdiff_eq_empty_iff_subset.1 h\n    have : ∑ x ∈ A \\ B, x = 0 := by\n      apply Nat.add_left_cancel (n := ∑ x ∈ B, x)\n      rw [add_zero, ← heq, ← Finset.sum_sdiff hsub, add_comm]\n    have : A \\ B = ∅ := Finset.eq_empty_of_sum_eq_zero this fun x hx =>\n       (Finset.mem_Ico.1 (h₁ (hA (Finset.sdiff_subset _ _ hx)))).1.ne'\n    exact hne (Finset.Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 this) hsub)\n  · apply Nat.add_right_cancel (m := ∑ x ∈ A ∩ B, x)\n    rw [Finset.sum_sdiff (Finset.inter_subset_left A B), heq, Finset.inter_comm,\n        Finset.su