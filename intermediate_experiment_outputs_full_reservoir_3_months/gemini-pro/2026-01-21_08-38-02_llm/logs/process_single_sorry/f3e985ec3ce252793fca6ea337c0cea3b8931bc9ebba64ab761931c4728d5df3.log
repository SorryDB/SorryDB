  have hA_sub : A ⊆ S := Finset.mem_powerset.mp hA
  have hB_sub : B ⊆ S := Finset.mem_powerset.mp hB
  have aux : ∀ {X Y : Finset ℕ}, X ⊆ S → Y ⊆ S → X ⊆ Y → ∑ x ∈ Y, x = ∑ x ∈ X, x → X = Y := by
