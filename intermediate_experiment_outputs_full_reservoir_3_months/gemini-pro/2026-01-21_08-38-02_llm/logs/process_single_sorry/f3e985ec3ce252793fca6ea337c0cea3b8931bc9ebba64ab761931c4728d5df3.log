@[imo_problem_subject combinatorics]
theorem imo_1972_p1 (S : Finset ℕ) (h₀ : S.card = 10) (h₁ : S ⊆ Finset.Ico 10 100) :
    ∃ S₁ S₂ : Finset ℕ,
      -- while the text says "subset", it appears to mean "nonempty subset"
      S₁.Nonempty ∧ S₁ ⊆ S ∧
      S₂.Nonempty ∧ S₂ ⊆ S ∧
      Disjoint S₁ S₂ ∧ ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by
  let f (s : Finset ℕ) := ∑ x ∈ s, x
  have h_bound : ∀ s ∈ S.powerset, f s ∈ Finset.Icc 0 990 := fun s hs ↦ by
    rw [Finset.mem_powerset] at hs
    rw [Finset.mem_Icc]; constructor
    · exact zero_le _
    · apply le_trans (Finset.sum_le_card_nsmul s _ 99 (λ x hx ↦ le_of_lt (Finset.mem_Ico.1 (h₁ (hs hx))).2))
      exact le_trans (Nat.mul_le_mul_right 99 (Finset.card_le_card hs)) (by rw [h₀]; norm_num)
  have h_card : (Finset.Icc 0 990).card < S.powerset.card := by
    rw [Finset.card_Icc, Finset.card_powerset, h₀]; norm_num
  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_card h_bound
  rw [Finset.mem_powerset] at hA hB
  have h_sum : ∑ x ∈ A \ B, x = ∑ x ∈ B \ A, x := by
    rw [Finset.sum_sdiff_eq_sub (Finset.inter_subset_left A B), Finset.sum_sdiff_eq_sub (Finset.inter_subset_right A B), heq, Finset.inter_comm]
  have h_pos : ∀ X ⊆ S, ∑ x ∈ X, x = 0 → X = ∅ := fun X hX h0 ↦ 
    Finset.eq_empty_of_forall_not_mem fun x hx ↦ by
      have := Finset.sum_eq_zero_iff.1 h0 x hx
      have := (Finset.mem_Ico.1 (h₁ (hX hx))).1
      linarith
  refine ⟨A \ B, B \ A, ?_, Finset.sdiff_subset_self.trans hA, ?_, Finset.sdiff_subset_self.trans hB, disjoint_sdiff_sdiff, h_sum⟩
  · rw [Finset.nonempty_iff_ne_empty]; intro h; apply hne
    have h1 : A \ B = ∅ := h
    have h2 : B \ A = ∅ := h_pos _ (Finset.sdiff_subset_self.trans hB) (by rw [← h_sum, h1, Finset.sum_empty])
    rw [Finset.sdiff_eq_empty_iff_subset] at h1 h2
    exact Subset.antisymm h1 h2
  · rw [Finset.nonempty_iff_ne_empty]; intro h; apply hne
    have h1 : B \ A = ∅ := h
    have h2 : A \ B = ∅ := h_pos _ (Finset.sdiff_subset_self.trans hA) (by rw [h_sum, h1, Finset.sum_empty])
    rw [Finset.sdiff_eq_empty_iff_subset] at h1 h2
    exact Subset.antisymm h2 h1
