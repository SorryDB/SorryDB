      "\n  let f (X : Finset ℕ) := ∑ x ∈ X, x\n  have h_bound : ∀ X ∈ S.powerset, f X ≤ 990 := fun X hX ↦ by\n    rw [Finset.mem_powerset] at hX\n    apply le_trans (Finset.sum_le_card_nsmul X 99 (fun x hx ↦ Nat.le_of_lt_succ (Finset.mem_Ico.1 (h₁ (hX hx))).2))\n    exact Nat.mul_le_mul_right 99 (h₀ ▸ Finset.card_le_card hX)\n  have h_card : (Finset.Icc 0 990).card < S.powerset.card := by\n    rw [Finset.card_Icc, Finset.card_powerset, h₀]; norm_num\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_card\n    (fun X hX ↦ Finset.mem_Icc.2 ⟨Finset.sum_nonneg (fun _ _ ↦ zero_le _), h_bound X hX⟩)\n  rw [Finset.mem_powerset] at hA hB\n  let S₁ := A \\ B; let S₂ := B \\ A\n  have h_pos : ∀ x ∈ S, 0 < x := fun x hx ↦ lt_of_lt_of_le (by norm_num) (Finset.mem_Ico.1 (h₁ hx)).1\n  have h_sum_zero : ∀ X, X ⊆ S → ∑ x ∈ X, x = 0 → X = ∅ := fun X hXS hX ↦\n    Finset.eq_empty_of_forall_not_mem fun x hx ↦ \n      ne_of_gt (h_pos x (hXS hx)) ((Finset.sum_eq_zero_iff_of_nonneg fun _ _ ↦ zero_le _).1 hX x hx)\n  have sum_eq : ∑ x ∈ S₁, x = ∑ x ∈ S₂, x := by\n    rw [Finset.sum_sdiff_eq_sub (Finset.inter_subset_left _ _),\n      Finset.sum_sdiff_eq_sub (Finset.inter_subset_right _ _), hsum, Finset.inter_comm]\n  refine ⟨S₁, S₂, ?_, Finset.sdiff_subset_of_subset hA, ?_, Finset.sdiff_subset_of_subset hB,\n    Finset.disjoint_sdiff_sdiff, sum_eq⟩\n  · intro h; apply hne; apply Subset.antisymm (Finset.sdiff_eq_empty_iff_subset.1 h)\n    apply Finset.sdiff_eq_empty_iff_subset.1; apply h_sum_zero S₂ (Finset.sdiff_subset_of_subset hB)\n    rw [← sum_eq, h, Finset.sum_empty]\n  · intro h; apply hne; apply Subset.antisymm _ (Finset.sdiff_eq_empty_iff_subset.1 h)\n    apply Finset.sdiff_eq_empty_iff_subset.1; apply h_sum_zero S₁ (Finset.sdiff_subset_of_subset hA)\n    rw [sum_eq, h, Finset.sum_empty]",
      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset_self _), Finset.card_powerset, h₀]\n    norm_num\n  let f (s : Finset ℕ) := ∑ x ∈ s, x\n  have h_map : ∀ s ∈ P, f s ∈ Finset.Icc 1 990 := by\n    intros s hs\n    rw [Finset.mem_erase, Finset.mem_powerset] at hs\n    refine Finset.mem_Icc.mpr ⟨?_, ?_⟩\n    · obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.mp hs.1\n      exact le_trans (by norm_num) (le_trans (Finset.mem_Ico.mp (h₁ (hs.2 hx))).1 \n        (Finset.single_le_sum (fun _ _ ↦ zero_le _) hx))\n    · apply le_trans (Finset.sum_le_sum_of_subset_of_nonneg hs.2 (fun _ _ ↦ zero_le _))\n      exact le_trans (Finset.sum_le_card_nsmul S 99 (fun x hx ↦ Nat.le_of_lt_succ (Finset.mem_Ico.mp (h₁ hx)).2)) (by rw [h₀]; norm_num)\n  obtain ⟨A, hA, B, hB, hne, hsum⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to (by rw [Finset.card_Icc, hP]; norm_num) h_map\n  have hA_sub : A ⊆ S := (Finset.mem_powerset.mp (Finset.mem_of_mem_erase hA))\n  have hB_sub : B ⊆ S := (Finset.mem_powerset.mp (Finset.mem_of_mem_erase hB))\n  use A \\ B, B \\ A\n  have h_sum_eq : ∑ x ∈ A \\ B, x = ∑ x ∈ B \\ A, x := by\n    have h1 : ∑ x ∈ A, x = ∑ x ∈ A \\ B, x + ∑ x ∈ A ∩ B, x := by\n      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter _ _), Finset.sdiff_union_inter]\n    have h2 : ∑ x ∈ B, x = ∑ x ∈ B \\ A, x + ∑ x ∈ A ∩ B, x := by\n      rw [← Finset.sum_union (Finset.disjoint_sdiff_inter _ _), Finset.sdiff_union_inter, Finset.inter_comm]\n    rw [hsum] at h1\n    exact Nat.add_right_cancel (h1.trans h2.symm)\n  have h_pos : ∀ X ⊆ S, X ≠ ∅ → ∑ x ∈ X, x ≠ 0 := fun X hX hne h0 ↦ by\n    obtain ⟨x, hx⟩ := Finset.nonempty_iff_ne_empty.mpr hne\n    have : 10 ≤ x := (Finset.mem_Ico.mp (h₁ (hX hx))).1\n    have : x ≤ 0 := h0 ▸ Finset.single_le_sum (fun _ _ ↦ zero_le _) hx\n    linarith\n  refine ⟨?_, (Finset.sdiff_subset _ _).trans hA_sub, ?_, (Finset.sdiff_subset _ _).trans hB_sub, disjoint_sdiff_sdiff, h_sum_eq⟩\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    refine hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.mp h) (Finset.sdiff_eq_empty_iff_subset.mp ?_))\n    by_contra h'; apply h_pos (B \\ A) ((Finset.sdiff_subset _ _).trans hB_sub) h'\n    rw [← h_sum_eq, h, Finset.sum_empty]\n  · rw [Finset.nonempty_iff_ne_empty]; intro h\n    refine hne (Finset.subset_antisymm (Finset.sdiff_eq_empty_iff_subset.mp ?_) (Finset.sdiff_eq_empty_iff_subset.mp h))\n    by_contra h'; apply h_pos (A \\ B) ((Finset.sdiff_subset _ _).trans hA_sub) h'\n    rw [h_sum_eq, h, Finset.sum_empty]",
      "\n  let P := S.powerset.erase ∅\n  have hP : P.card = 1023 := by\n    rw [Finset.card_erase_of_mem (Finset.mem_powerset.mpr S.empty_subset), Finset.card_powerset, h₀]\n    norm_num\n  have h_sum : ∀ s ∈ P, ∑ x ∈ s, x ∈ Finset.range 1000 := by\n    intro s hs\n    rw [Finset.mem_range]\n    have : s ⊆ S := Finset.mem_powerset.mp (Finset.mem_of_mem_erase hs)\n    refine (Finset.sum_le_sum_of_subset_of_nonneg this (fun _ _ _ => zero_le _)).trans_lt ?_\n    calc ∑ x ∈ S, x < S.card * 100 := Finset.sum_lt_card_mul_of_top (fun x hx => (Finset.mem_Ico.mp (h₁ hx)).2)\n      _ = 1000 := by rw [h₀]; rfl\n  obtain ⟨A, hA, B, hB, hne, heq⟩ := Finset.exists_ne_map_eq_of_card_lt_of_maps_to h_sum (by rw [hP, Finset.card_range]; norm_num)\n  have hA_sub : A ⊆ S := Finset.mem_powerset.mp (Finset.mem_of_mem_erase hA)\n  have hB_sub : B ⊆ S := Finset.mem_powerset.mp (Finset.mem_of_mem_erase hB)\n  let S₁ := A \\ B\n  let S₂ := B \\ A\n  refine ⟨S₁, S₂, ?_, Finset.sdiff_subset.trans hA_sub,\n                 ?_, Finset.sdiff_subset.trans hB_sub,\n                 disjoint_sdiff_sdiff, ?_⟩\n  · by_contra h\n    rw [Finset.not_nonempty_iff_eq_empty, Finset.sdiff_eq_empty_iff_subset] at h\n    have : ∑ x ∈ S₂, x = 0 := by\n      have : ∑ x ∈ B, x = ∑ x ∈ S₂, x + ∑ x ∈ B ∩ A, x := (Finset.sum_sdiff (Finset.inter_subset_left B A)).symm\n      rw [Finset.inter_eq_right.mpr h, ← heq] at this\n      exact Nat.eq_zero_of_add_eq_self_right this.symm\n    refine hne (Finset.subset.antisymm h (Finset.sdiff_eq_empty_iff_subset.mp (Finset.eq_empty_of_forall_not_mem fun x hx => ?_)))\n    linarith [Finset.single_le_sum (fun _ _ => zero_le _) hx, (Finset.mem_Ico.mp (h₁ (Finset.sdiff_subset.trans hB_sub hx))).1]\n  · by_contra h\n    rw [Finset.not_nonempty_iff_eq_empty, Finset.sdiff_eq_empty_iff_subset] at h\n    have : ∑ x ∈ S₁, x = 0 := by\n      have : ∑ x ∈ A, x = ∑ x ∈ S₁, x + ∑ x ∈ A ∩ B, x := (Finset.sum_sdiff (Finset.inter_subset_left A B)).symm\n      rw [Finset.inter_eq_left.mpr h, he