  let net' := net.toHopfieldNetwork
  let x' := biasedUpdateState net x i
  have h_energy : ∀ y, biasedEnergy net y = HopfieldNetwork.energy net' y - ∑ j, net.bias j * (y j).toReal := by
    intro y
    simp [biasedEnergy, HopfieldNetwork.energy, Finset.sum_add_distrib, Finset.sum_mul, sub_eq_add_neg]
    ring
