lemma biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField :
    biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
  let net' : HopfieldNetwork n := { net.toHopfieldNetwork with thresholds := net.thresholds + net.bias }
  have hE : ∀ y, biasedEnergy net y = net'.energy y := by
    intro y
    simp [biasedEnergy, HopfieldNetwork.energy, net', Finset.sum_add_distrib, add_mul]
  have hLF : biasedLocalField net x i = net'.localField x i := by
    simp [biasedLocalField, HopfieldNetwork.localField, net']
  have hUpd : biasedUpdateState net x i = net'.updateState x i := by
    simp [biasedUpdateState, HopfieldNetwork.updateState, hLF]
  rw [biasedEnergyDiff, hE, hE, hUpd, hLF]
  exact net'.energyDiff_eq_neg_spinDiff_localField x i
