  trans HopfieldNetwork.energyDiff net' x i - net.bias i * ((x' i).toReal - (x i).toReal)
  · rfl
  rw [HopfieldNetwork.energyDiff_eq_neg_spinDiff_localField]
  unfold biasedLocalField
  ring
