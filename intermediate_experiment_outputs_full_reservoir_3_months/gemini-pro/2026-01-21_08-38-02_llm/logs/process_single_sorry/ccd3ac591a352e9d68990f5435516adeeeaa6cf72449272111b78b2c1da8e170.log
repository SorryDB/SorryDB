lemma biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField :
    biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
  let h := net.toHopfieldNetwork
  let x' := biasedUpdateState net x i
  let Δs := (x' i).toReal - (x i).toReal
  have h_energy_eq (y) : biasedEnergy net y = h.energy y - Finset.sum Finset.univ (fun j => net.bias j * (y j).toReal) := by
    simp [biasedEnergy, HopfieldNetwork.energy, sub_eq_add_neg, Finset.sum_add_distrib, mul_add]
    ring
  rw [biasedEnergyDiff, h_energy_eq x', h_energy_eq x]
  have h_diff : h.energy x' - h.energy x = -Δs * localField h x i :=
    HopfieldNetwork.energyDiff_of_update h x i (x' i)
  have b_diff : (Finset.sum Finset.univ fun j => net.bias j * (x' j).toReal) - 
                (Finset.sum Finset.univ fun j => net.bias j * (x j).toReal) = 
                net.bias i * Δs := by
    simp [x', biasedUpdateState, Δs, toRealVector]
    rw [Finset.sum_update] <;> simp; ring
  rw [h_diff, b_diff, biasedLocalField]
  ring
