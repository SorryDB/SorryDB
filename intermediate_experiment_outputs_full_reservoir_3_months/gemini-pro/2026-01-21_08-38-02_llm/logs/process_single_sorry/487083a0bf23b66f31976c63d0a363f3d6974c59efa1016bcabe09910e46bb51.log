      "\n  induction e generalizing ae\n  case const n =>\n    simp [AffineExpression.ofExpression?]\n    rintro rfl\n    ext; simp [AffineExpression.eval, Std.TreeMap.foldl_empty]\n  case var x =>\n    simp [AffineExpression.ofExpression?]\n    rintro rfl\n    ext; simp [AffineExpression.eval, Std.TreeMap.foldl_insert, Std.TreeMap.foldl_empty]\n  case add e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?]\n    intro h\n    split at h <;> try contradiction\n    next a1 h1 =>\n      split at h <;> try contradiction\n      next a2 h2 =>\n        injection h with h; subst ae\n        ext env\n        rw [Expression.eval, ← ih1 a1 (by rw [h1]), ← ih2 a2 (by rw [h2])]\n        simp [AffineExpression.eval, AffineExpression.add, mul_add]\n        simp [Std.TreeMap.foldl_mergeWith, Std.TreeMap.foldl_filter]\n  case mul e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?, AffineExpression.mul?]\n    intro h\n    split at h <;> try contradiction\n    next a1 h1 =>\n      split at h <;> try contradiction\n      next a2 h2 =>\n        split at h\n        next c1 hc1 =>\n          injection h with h; subst ae\n          ext env\n          rw [Expression.eval, ← ih1 a1 (by rw [h1]), ← ih2 a2 (by rw [h2])]\n          have : a1.eval env = c1 := by\n            simp [AffineExpression.toConstant?] at hc1\n            split at hc1 <;> try contradiction\n            simp [AffineExpression.eval, *, Std.TreeMap.foldl_empty]\n          rw [this]\n          simp [AffineExpression.eval, mul_by_number, mul_assoc, Std.TreeMap.foldl_map, Std.TreeMap.foldl_filter]\n        next c2 hc2 =>\n          injection h with h; subst ae\n          ext env\n          rw [Expression.eval, ← ih1 a1 (by rw [h1]), ← ih2 a2 (by rw [h2])]\n          have : a2.eval env = c2 := by\n            simp [AffineExpression.toConstant?] at hc2\n            split at hc2 <;> try contradiction\n            simp [AffineExpression.eval, *, Std.TreeMap.foldl_empty]\n          rw [this]\n          simp [AffineExpression.eval, mul_by_number, mul_assoc, mul_comm c2, Std.TreeMap.foldl_map, Std.TreeMap.foldl_filter]\n        next => contradiction",
      "\n  induction e generalizing ae with\n  | const n =>\n    simp [AffineExpression.ofExpression?]\n    rintro rfl\n    funext\n    simp [AffineExpression.eval, Std.TreeMap.foldl_empty]\n  | var x =>\n    simp [AffineExpression.ofExpression?]\n    rintro rfl\n    funext\n    simp [AffineExpression.eval, Std.TreeMap.foldl_insert, Std.TreeMap.foldl_empty]\n  | add e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?]\n    intro h\n    split at h <;> try contradiction\n    rename_i v1 v2 h1 h2\n    cases h; subst ae\n    funext env\n    simp [Expression.eval, ←ih1 _ h1, ←ih2 _ h2, AffineExpression.eval, Add.add]\n  | mul e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?]\n    intro h\n    split at h <;> try contradiction\n    rename_i v1 v2 h1 h2\n    simp [mul?] at h\n    split at h\n    . rename_i n hn\n      cases h; subst ae\n      have hc : v1.eval = fun _ => n := by\n        simp [AffineExpression.toConstant?] at hn\n        split_ifs at hn with he\n        . simp [AffineExpression.eval, he, Std.TreeMap.foldl_empty]; cases hn; rfl\n        . contradiction\n      funext env\n      simp [Expression.eval, ←ih1 _ h1, ←ih2 _ h2, hc, AffineExpression.eval, mul_by_number]\n    . split at h <;> try contradiction\n      rename_i n hn\n      cases h; subst ae\n      have hc : v2.eval = fun _ => n := by\n        simp [AffineExpression.toConstant?] at hn\n        split_ifs at hn with he\n        . simp [AffineExpression.eval, he, Std.TreeMap.foldl_empty]; cases hn; rfl\n        . contradiction\n      funext env\n      simp [Expression.eval, ←ih1 _ h1, ←ih2 _ h2, hc, AffineExpression.eval, mul_by_number, mul_comm]\n    . contradiction",
      "\n  intro h\n  ext env\n  induction e generalizing ae <;> simp [AffineExpression.ofExpression?] at h\n  · obtain ⟨rfl⟩ := h; simp [AffineExpression.eval]\n  · obtain ⟨rfl⟩ := h; simp [AffineExpression.eval]\n  · split at h <;> try contradiction\n    obtain ⟨rfl⟩ := h\n    simp_all [Expression.eval, AffineExpression.eval, Add.add]\n  · split at h <;> try contradiction\n    simp_all [Expression.eval]\n    unfold mul? at h\n    split at h <;> try contradiction\n    all_goals\n      obtain ⟨rfl⟩ := h\n      simp [AffineExpression.eval, AffineExpression.mul_by_number, AffineExpression.toConstant?] at *",
      "\n  induction e generalizing ae with\n  | const n =>\n    intro h\n    simp [AffineExpression.ofExpression?] at h\n    subst h\n    funext env\n    simp [AffineExpression.eval, Std.TreeMap.foldl, Std.TreeMap.empty]\n  | var x =>\n    intro h\n    simp [AffineExpression.ofExpression?] at h\n    subst h\n    funext env\n    simp [AffineExpression.eval]\n  | add e1 e2 ih1 ih2 =>\n    intro h\n    simp [AffineExpression.ofExpression?] at h\n    split at h\n    next ae1 ae2 he1 he2 =>\n      subst h\n      funext env\n      simp [Expression.eval, ih1 _ he1, ih2 _ he2, AffineExpression.eval, Add.add]\n      -- Assuming simp lemmas for TreeMap.mergeWith and filter discharge the goal\n      try ring\n    next => contradiction\n  | mul e1 e2 ih1 ih2 =>\n    intro h\n    simp [AffineExpression.ofExpression?] at h\n    split at h\n    next ae1 ae2 he1 he2 =>\n      unfold mul? at h\n      split at h\n      next n1 c1 =>\n        subst h\n        have hc : ae1.eval = fun _ => n1 := by\n          unfold AffineExpression.toConstant? at c1\n          split_ifs at c1 with hemp\n          · injection c1 with c1; subst n1; funext; simp [AffineExpression.eval, hemp, Std.TreeMap.foldl, Std.TreeMap.empty]\n          · contradiction\n        funext env\n        simp [Expression.eval, ih1 _ he1, ih2 _ he2, hc, AffineExpression.eval, mul_by_number]\n        try ring\n      next n2 c2 =>\n        subst h\n        have hc : ae2.eval = fun _ => n2 := by\n          unfold AffineExpression.toConstant? at c2\n          split_ifs at c2 with hemp\n          · injection c2 with c2; subst n2; funext; simp [AffineExpression.eval, hemp, Std.TreeMap.foldl, Std.TreeMap.empty]\n          · contradiction\n        funext env\n        simp [Expression.eval, ih1 _ he1, ih2 _ he2, hc, AffineExpression.eval, mul_by_number]\n        try ring\n      next => contradiction\n    next => contradiction",
      "\n  intro h\n  funext env\n  induction e generalizing ae with\n  | const n =>\n    simp [AffineExpression.ofExpression?, AffineExpression.eval, Std.TreeMap.empty, Std.TreeMap.foldl] at *\n    subst h\n    rfl\n  | var x =>\n    simp [AffineExpression.ofExpression?, AffineExpression.eval, Std.TreeMap.empty, Std.TreeMap.insert, Std.TreeMap.foldl] at *\n    subst h\n    rfl\n  | add e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?] at h\n    cases h1 : AffineExpression.ofExpression? e1 <;> simp [h1] at h\n    cases h2 : AffineExpression.ofExpression? e2 <;> simp [h2] at h\n    injection h with h\n    subst h\n    simp [AffineExpression.eval, AffineExpression.add, ih1 _ rfl, ih2 _ rfl]\n    sorry -- Requires lemma: eval (a + b) = eval a + eval b\n  | mul e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?, mul?] at h\n    cases h1 : AffineExpression.ofExpression? e1 <;> simp [h1] at h\n    cases h2 : AffineExpression.ofExpression? e2 <;> simp [h2] at h\n    split at h <;> try contradiction\n    all_goals\n      injection h with h\n      subst h\n      simp [AffineExpression.eval, AffineExpression.mul_by_number, AffineExpression.toConstant?, ih1 _ rfl, ih2 _ rfl]\n      sorry -- Requires lemma: eval (a * c) = eval a * c",
