     simp\n      next => contradiction",
      "\n  induction e generalizing ae\n  case const n =>\n    simp [AffineExpression.ofExpression?, AffineExpression.eval, Std.TreeMap.foldl_empty]\n    rintro rfl; rfl\n  case var x =>\n    simp [AffineExpression.ofExpression?, AffineExpression.eval, Std.TreeMap.foldl_insert, Std.TreeMap.foldl_empty]\n    rintro rfl; rfl\n  case add e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?]\n    split <;> try contradiction\n    rintro rfl; funext env\n    simp [AffineExpression.eval, Add.add]\n    rw [ih1 _ rfl, ih2 _ rfl]\n    -- Assuming simp handles distribution of foldl over mergeWith with appropriate lemmas in scope\n    simp [add_assoc, add_left_comm, add_comm]\n  case mul e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?, mul?]\n    split <;> try contradiction\n    split\n    · next n1 h =>\n      rintro rfl; funext env\n      simp [AffineExpression.eval, mul_by_number]\n      rw [ih2 _ rfl]\n      simp [AffineExpression.toConstant?] at h\n      split at h <;> try contradiction\n      cases h\n      simp [AffineExpression.eval, Std.TreeMap.foldl_empty] at ih1\n      rw [ih1 _ rfl]; ring\n    · split\n      · next h1 n2 h =>\n        rintro rfl; funext env\n        simp [AffineExpression.eval, mul_by_number]\n        rw [ih1 _ rfl]\n        simp [AffineExpression.toConstant?] at h\n        split at h <;> try contradiction\n        cases h\n        simp [AffineExpression.eval, Std.TreeMap.foldl_empty] at ih2\n        rw [ih2 _ rfl]; ring\n      · contradiction",
      "\n  induction e generalizing ae\n  case const n =>\n    simp [AffineExpression.ofExpression?, AffineExpression.eval, Expression.eval, Std.TreeMap.foldl_empty]\n    rintro rfl; rfl\n  case var x =>\n    simp [AffineExpression.ofExpression?, AffineExpression.eval, Expression.eval, Std.TreeMap.foldl_insert, Std.TreeMap.foldl_empty]\n    rintro rfl; simp\n  case add e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?]\n    split; rename_i v1 v2 he1 he2; swap; intro; contradiction\n    intro h; injection h; subst ae\n    simp [Expression.eval, ih1 _ he1.symm, ih2 _ he2.symm, AffineExpression.eval, Add.add]\n    funext env\n    simp [add_assoc, add_left_comm, add_comm, mul_add, add_mul]\n    -- Assuming standard simp lemmas for Std.TreeMap merge/foldl distribution are available or handled\n  case mul e1 e2 ih1 ih2 =>\n    simp [AffineExpression.ofExpression?]\n    split; rename_i v1 v2 he1 he2; swap; intro; contradiction\n    specialize ih1 v1 he1.symm\n    specialize ih2 v2 he2.symm\n    intro h\n    simp [AffineExpression.mul?] at h\n    split at h\n    · rename_i c1 hc1\n      injection h with h; subst ae\n      simp [AffineExpression.toConstant?] at hc1\n      split at hc1; swap; contradiction\n      simp at hc1; subst c1\n      simp [Expression.eval, ih1, ih2, AffineExpression.mul_by_number, AffineExpression.eval]\n      simp [Std.TreeMap.isEmpty_eq_true_iff] at *\n      rw [‹v1.affine = Std.TreeMap.empty›]\n      simp [Std.TreeMap.foldl_empty, mul_add]\n      funext env\n      simp [mul_assoc]\n    · rename_i c2 hc2\n      injection h with h; subst ae\n      simp [AffineExpression.toConstant?] at hc2\n      split at hc2; swap; contradiction\n      simp at hc2; subst c2\n      simp [Expression.eval, ih1, ih2, AffineExpression.mul_by_number, AffineExpression.eval]\n      simp [Std.TreeMap.isEmpty_eq_true_iff] at *\n      rw [‹v2.affine = Std.TreeMap.empty›]\n      simp [Std.TreeMap.foldl_empty, mul_add]\n      funext env\n      simp [mul_assoc, mul_comm]