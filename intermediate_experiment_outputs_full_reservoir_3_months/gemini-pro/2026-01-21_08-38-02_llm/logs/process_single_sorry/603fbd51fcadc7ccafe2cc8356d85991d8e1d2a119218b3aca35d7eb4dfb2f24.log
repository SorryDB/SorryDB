    -- a sage bird exists in the forest
    theorem sagebird_existence :
        ∃ θ, ∀ x, x ◁ (θ ◁ x) = θ ◁ x := by
      use B ◁ M ◁ L
      intro x
      simp only [B.call, M.call]
      rw [← L.call]
