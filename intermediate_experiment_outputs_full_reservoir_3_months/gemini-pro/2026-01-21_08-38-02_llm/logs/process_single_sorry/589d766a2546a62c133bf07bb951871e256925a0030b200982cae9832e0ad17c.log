              dite (index₁ = index₂)
              (fun h_is : index₁ = index₂ =>
                prev ++ [(DT, index₂)])
              (fun h_is_not : index₁ ≠ index₂ =>
                prev) )
          have afuncDef : afunc =
              (fun prev (DT , index₂) =>
              dite (index₁ = index₂)
              (fun h_is : index₁ = index₂ =>
                prev ++ [(DT, index₂)])
