    exact le_sSup h_mem_B
  have h_eq_N : N = N' := by
    by_contra h_diff
    have h_disj := sSupIndep.pairwise_disjoint D.sSupIndep' hN hN' h_diff
    exact D.not_bot_mem (disjoint_self.mp (Disjoint.mono_right h_le h_disj) ▸ hN)
