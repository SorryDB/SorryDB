/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_
  intro h_eq
  obtain ⟨N, hN, h_ne⟩ := H
  have h_mem : N ∈ (refinement B hB hB' hB'').carrier := h_eq.symm ▸ hN
  simp only [refinement, Set.mem_iUnion] at h_mem
  obtain ⟨M, hM, h_N_in_B⟩ := h_mem
  have h_le : N ≤ M := by
    rw [hB M hM]
    exact le_sSup h_N_in_B
  have h_eq_NM : N = M := by
    by_contra h_diff
    have h_disj : Disjoint N M := D.sSupIndep.disjoint_sSup hN (Set.singleton_subset_iff.mpr hM) (by simpa)
    have h_bot : N = ⊥ := disjoint_self.mp (Disjoint.mono_right h_le h_disj)
    exact D.not_bot_mem (h_bot ▸ hN)
  subst h_eq_NM
  have h_sing : B N hN = {N} := by
    apply eq_singleton_iff_unique_mem.mpr ⟨h_N_in_B, ?_⟩
    intro P hP
    by_contra h_P_ne_N
    have h_disj : Disjoint P N := by
      apply sSupIndep.disjoint_sSup (hB' N hN) hP (Set.singleton_subset_iff.mpr h_N_in_B)
      simpa using h_P_ne_N
    rw [hB N hN] at h_disj
    have h_le_N : P ≤ sSup (B N hN) := le_sSup hP
    rw [← hB N hN] at h_le_N
    have h_bot : P = ⊥ := disjoint_self.mp (Disjoint.mono_right h_le_N h_disj)
    exact hB'' N hN P hP h_bot
  exact h_ne h_sing
