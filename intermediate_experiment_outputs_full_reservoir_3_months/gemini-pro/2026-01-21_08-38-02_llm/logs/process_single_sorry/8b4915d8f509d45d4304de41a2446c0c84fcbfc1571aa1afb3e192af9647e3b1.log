/-- If one of the decompositions of the `N`'s is non-trivial then `refinement B hB hB' hB''`
is a strict refinement of `M`. -/
lemma refinement_lt_of_exists_ne_singleton (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN))
    (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN)
    (H : ∃ (N : PersistenceSubmodule M) (hN : N ∈ D), B N hN ≠ {N}) :
    refinement B hB hB' hB'' < D := by
  apply lt_of_le_of_ne (refinement_le B hB hB' hB'')
  intro h_eq
  obtain ⟨N₀, hN₀, h_ne⟩ := H
  have h_mem : N₀ ∈ (refinement B hB hB' hB'').carrier := h_eq.symm ▸ hN₀
  simp only [refinement, Set.mem_iUnion] at h_mem
  obtain ⟨N₁, hN₁, h_N₀_in_B₁⟩ := h_mem
  have h_le : N₀ ≤ N₁ := (le_sSup h_N₀_in_B₁).trans_eq (hB N₁ hN₁).symm
  have h_eq_N : N₀ = N₁ := by
    by_contra h_diff
    have h_disj : Disjoint N₀ N₁ := by
      apply Disjoint.mono_right _ (D.sSupIndep N₀ hN₀)
      exact le_sSup ⟨hN₁, h_diff.symm⟩
    have h_bot : N₀ = ⊥ := le_bot_iff.mp (le_trans (le_inf le_rfl h_le) (disjoint_iff_inf_le.mp h_disj))
    subst h_bot
    exact D.not_bot_mem hN₀
  subst h_eq_N
  have h_sing : B N₀ hN₀ = {N₀} := by
    apply Set.eq_singleton_iff_unique_mem.mpr ⟨h_N₀_in_B₁, _⟩
    intro x hx
    by_contra h_diff
    have h_disj : Disjoint x N₀ := by
      apply Disjoint.mono_right _ (hB' N₀ hN₀ x hx)
      exact le_sSup ⟨h_N₀_in_B₁, h_diff.symm⟩
    have h_x_le : x ≤ N₀ := (le_sSup hx).trans_eq (hB N₀ hN₀).symm
    have h_bot : x = ⊥ := le_bot_iff.mp (le_trans (le_inf le_rfl h_x_le) (disjoint_iff_inf_le.mp h_disj))
    subst h_bot
    exact hB'' N₀ hN₀ hx
  exact h_ne h_sing
