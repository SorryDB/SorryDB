      "by\n  refine lt_of_le_not_le (refinement_le B hB hB' hB'') fun h_le ↦ ?_\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_eq : ∀ x ∈ B N hN, x = N := by\n    intro x hx\n    have hx_mem : x ∈ refinement B hB hB' hB'' := by\n      simp only [refinement, SetLike.mem_coe, Set.mem_iUnion]\n      exact ⟨N, hN, hx⟩\n    obtain ⟨S, hS_sub, rfl⟩ := h_le hx_mem\n    have h_le_N : sSup S ≤ N := (le_sSup hx).trans (hB N hN).ge\n    have hS_eq : S = {N} := by\n      apply Set.eq_singleton_iff_unique_mem.mpr\n      constructor\n      · by_contra h_empty\n        rw [Set.eq_empty_iff_forall_not_mem] at h_empty\n        have : sSup S = ⊥ := by simp [h_empty]\n        exact hB'' N hN (sSup S) hx this\n      · intro s hs\n        have hs_in : s ∈ D := hS_sub hs\n        have hs_le : s ≤ N := le_trans (le_sSup hs) h_le_N\n        by_contra h_diff\n        exact D.not_bot_mem' hs_in <| (D.sSupIndep' hs_in hN h_diff).eq_bot_of_le hs_le\n    rw [hS_eq, sSup_singleton]\n  apply h_ne\n  apply Set.eq_singleton_iff_unique_mem.mpr\n  constructor\n  · by_contra h_empty\n    rw [Set.eq_empty_iff_forall_not_mem] at h_empty\n    have : N = ⊥ := by rw [hB N hN, sSup_empty] at h_empty; exact h_empty\n    exact D.not_bot_mem' hN this\n  · exact h_eq",
      "by\n  rw [lt_iff_le_not_le]\n  refine ⟨refinement_le B hB hB' hB'', ?_⟩\n  intro h_le\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_sub : B N hN ⊆ {N} := by\n    intro x hx\n    have h_x_mem : x ∈ refinement B hB hB' hB'' := by\n      simp [refinement]\n      exact ⟨N, hN, hx⟩\n    obtain ⟨S, hS_sub, hS_eq⟩ := h_le h_x_mem\n    have h_x_le_N : x ≤ N := by rw [hB N hN]; exact le_sSup hx\n    have h_S_eq : S = {N} := by\n      have h_S_sub_N : S ⊆ {N} := by\n        intro M hM\n        have hM_D : M ∈ D := hS_sub hM\n        by_contra h_neq\n        have h_neq_N : M ≠ N := by simpa using h_neq\n        have h_disj : Disjoint M N := D.sSupIndep' hM_D hN h_neq_N\n        have h_le_M_x : M ≤ x := hS_eq ▸ le_sSup hM\n        have h_le_M_N : M ≤ N := h_le_M_x.trans h_x_le_N\n        have h_bot : M = ⊥ := Disjoint.eq_bot_of_le h_disj h_le_M_N\n        exact D.not_bot_mem' hM_D h_bot\n      rcases Set.subset_singleton_iff.mp h_S_sub_N with rfl | rfl\n      · rw [sSup_empty] at hS_eq\n        exfalso; exact hB'' N hN (hS_eq ▸ hx)\n      · rfl\n    rw [h_S_eq, sSup_singleton] at hS_eq\n    rw [hS_eq]\n    rfl\n  have h_nonempty_B : (B N hN).Nonempty := by\n    by_contra h_emp\n    rw [Set.not_nonempty_iff_eq_empty] at h_emp\n    have h_bot : N = ⊥ := by rw [hB N hN, h_emp, sSup_empty]\n    exact D.not_bot_mem' hN h_bot\n  rcases Set.subset_singleton_iff.mp h_sub with h_emp | h_eq\n  · exfalso; exact h_nonempty_B.ne_empty h_emp\n  · exact h_ne h_eq",
      "by\n  apply lt_of_le_of_ne (refinement_le B hB hB' hB'')\n  intro h_eq\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_subset : B N hN ⊆ D.carrier := by\n    rw [← h_eq]\n    intro x hx\n    exact Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hx⟩⟩\n  have h_mem : N ∈ B N hN := by\n    by_contra h_abs\n    have h_disj := D.sSupIndep.disjoint_sSup hN h_subset h_abs\n    rw [← hB N hN] at h_disj\n    exact D.not_bot_mem hN (disjoint_self.mp h_disj)\n  have h_unique : ∀ x ∈ B N hN, x = N := by\n    intro x hx\n    by_contra h_neq\n    have h_disj : Disjoint x N := by\n      refine disjoint_mono_right (le_sSup ?_) (D.sSupIndep (h_subset hx))\n      exact (Set.mem_diff _).mpr ⟨hN, Ne.symm h_neq⟩\n    have h_le : x ≤ N := (hB N hN) ▸ le_sSup hx\n    have h_bot : x = ⊥ := disjoint_iff_inf_le.mp h_disj h_le\n    exact D.not_bot_mem (h_subset hx) h_bot\n  exact h_ne (Set.eq_singleton_iff_unique_mem.mpr ⟨h_mem, h_unique⟩)",
      "by\n  rw [lt_iff_le_not_le]\n  refine ⟨refinement_le B hB hB' hB'', ?_⟩\n  intro h_le\n  rcases H with ⟨N, hN, h_ne⟩\n  apply h_ne\n  have h_nonempty : (B N hN).Nonempty := by\n    by_contra h_empty\n    rw [Set.not_nonempty_iff_eq_empty] at h_empty\n    have : N = ⊥ := by rw [hB N hN, h_empty, sSup_empty]\n    exact D.not_bot_mem (this ▸ hN)\n  have h_eq : ∀ x ∈ B N hN, x = N := by\n    intro x hx\n    have hx_in_R : x ∈ refinement B hB hB' hB'' := by\n      simp only [refinement, SetLike.mem_coe, Set.mem_iUnion]\n      use N, hN\n    obtain ⟨S, hS_sub, hS_eq⟩ := h_le hx_in_R\n    have h_le_N : x ≤ N := (hB N hN) ▸ le_sSup hx\n    have hS_sub_N : S ⊆ {N} := by\n      intro M hM\n      have hM_in_D : M ∈ D := hS_sub hM\n      have hM_le_x : M ≤ x := hS_eq ▸ le_sSup hM\n      have hM_le_N : M ≤ N := le_trans hM_le_x h_le_N\n      by_contra h_ne_N\n      rw [Set.mem_singleton_iff] at h_ne_N\n      push_neg at h_ne_N\n      have : Disjoint M N := sSupIndep.pairwise_disjoint D.sSupIndep' hM_in_D hN h_ne_N\n      have : M = ⊥ := Disjoint.eq_bot_of_le this hM_le_N\n      exact D.not_bot_mem (this ▸ hM_in_D)\n    have hS_eq_N : S = {N} := by\n      rcases Set.subset_singleton_iff_eq.mp hS_sub_N with rfl | rfl\n      · rw [sSup_empty] at hS_eq\n        exact (hB'' N hN (hS_eq ▸ hx)).elim\n      · rfl\n    rw [hS_eq_N, sSup_singleton] at hS_eq\n    exact hS_eq\n  ext x\n  constructor\n  · intro hx; rw [h_eq x hx, Set.mem_singleton_iff]\n  · intro hx; rw [Set.mem_singleton_iff] at hx; subst hx; obtain ⟨y, hy⟩ := h_nonempty; rw [← h_eq y hy]; exact hy",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_\n  intro h_eq\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_N_mem : N ∈ refinement B hB hB' hB'' := h_eq.symm ▸ hN\n  obtain ⟨M, hM, h_mem_M⟩ : ∃ M hM, N ∈ B M hM := by\n    simpa [refinement] using h_N_mem\n  have h_le : N ≤ M := (le_sSup h_mem_M).trans_eq (hB M hM).symm\n  have h_eq_NM : N = M := by\n    by_contra h_diff\n    have h_disj : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep.disjoint_sSup hN\n    have h_le_sSup : M ≤ sSup (D.carrier \\ {N}) := le_sSup ⟨hM, h_diff.symm⟩\n    have h_bot : N = ⊥ := disjoint_self.mp (Disjoint.mono_right (h_le.trans h_le_sSup) h_disj)\n    exact D.not_bot_mem (h_bot ▸ hN)\n  subst h_eq_NM\n  have h_singleton : B N hN = {N} := by\n    rw [Set.eq_singleton_iff_unique_mem]\n    refine ⟨h_mem_M, fun x hx ↦ ?_⟩\n    have h_x_mem : x ∈ D := h_eq ▸ (by simp [refinement]; exact ⟨N, hN, hx⟩)\n    have h_x_le : x ≤ N := (le_sSup hx).trans_eq (hB N hN).symm\n    by_contra h_diff\n    have h_disj : Disjoint x (sSup (D.carrier \\ {x})) := D.sSupIndep.disjoint_sSup h_x_mem\n    have h_le_sSup : N ≤ sSup (D.carrier \\ {x}) := le_sSup ⟨hN, h_diff.symm⟩\n    have h_bot : x = ⊥ := disjoint_self.mp (Disjoint.mono_right (h_x_le.trans h_le_sSup) h_disj)\n    exact hB'' N hN (h_bot ▸ hx)\n  exact h_ne h_singleton",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_\n  intro h_eq\n  obtain ⟨N, hN, h_ne⟩ := H\n  let R := refinement B hB hB' hB''\n  have h_ref : D ≤ R := h_eq.symm ▸ le_refl D\n  have h_not_mem : N ∉ B N hN := fun h ↦ h_ne <| eq_singleton_iff_unique_mem.mpr\n    ⟨h, fun x hx ↦ by_contra fun hne ↦ hB'' N hN x hx <|\n      ((hB' N hN).disjoint_pair hx h hne).eq_bot_of_le ((le_sSup hx).trans (hB N hN).symm.le)⟩\n  have h_nonempty : (B N hN).Nonempty := by\n    by_contra h; rw [Set.not_nonempty_iff_eq_empty] at h\n    exact D.not_bot_mem hN ((hB N hN).trans (h ▸ sSup_empty))\n  obtain ⟨b, hb⟩ := h_nonempty\n  obtain ⟨S, hS_sub, hS_eq⟩ := h_ref (Set.mem_iUnion.mpr ⟨N, Set.mem_iUnion.mpr ⟨hN, hb⟩⟩)\n  have hS_sub_N : S ⊆ {N} := fun x hx ↦ by\n    have : x ≤ N := ((le_sSup hx).trans_eq hS_eq.symm).trans ((le_sSup hb).trans (hB N hN).symm.le)\n    by_contra hne; exact D.not_bot_mem (hS_sub hx) <|\n      (D.sSupIndep.disjoint_pair (hS_sub hx) hN hne).eq_bot_of_le this\n  have hS_eq_N : S = {N} := by\n    refine Set.eq_singleton_iff_nonempty_unique_mem.mpr ⟨?_, fun x hx ↦ hS_sub_N hx ▸ rfl⟩\n    by_contra h; rw [Set.not_nonempty_iff_eq_empty] at h\n    exact hB'' N hN b hb (hS_eq.trans (h ▸ sSup_empty))\n  have h_b_eq_N : b = N := by rw [hS_eq, hS_eq_N, sSup_singleton]\n  exact h_not_mem (h_b_eq_N ▸ hb)",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_\n  intro h_eq\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_mem : N ∈ refinement B hB hB' hB'' := h_eq.symm ▸ hN\n  simp only [refinement, Set.mem_iUnion] at h_mem\n  obtain ⟨M, hM, hNM⟩ := h_mem\n  have h_le : N ≤ M := (hB M hM).symm ▸ le_sSup hNM\n  have h_eq_NM : N = M := by\n    by_contra h_diff\n    have h_disj := sSupIndep.pairwise_disjoint D.sSupIndep' hN hM h_diff\n    exact D.not_bot_mem' hN <| le_bot_iff.mp <| h_le.trans <|\n      disjoint_self.mp <| disjoint_of_disjoint_of_le h_disj le_rfl h_le\n  subst h_eq_NM\n  have h_disj : Disjoint N (sSup (B N hN \\ {N})) := (hB' N hN).disjoint_sSup hNM\n  have h_K_le_N : sSup (B N hN \\ {N}) ≤ N := by\n    have h_decomp := hB N hN\n    rw [← Set.insert_diff_singleton hNM, sSup_insert] at h_decomp\n    exact h_decomp.symm ▸ le_sup_right\n  have h_bot : sSup (B N hN \\ {N}) = ⊥ :=\n    disjoint_self.mp (disjoint_of_disjoint_of_le h_disj.symm le_rfl h_K_le_N)\n  have h_empty : B N hN \\ {N} = ∅ := by\n    by_contra h_nonempty\n    obtain ⟨x, hx⟩ := Set.nonempty_iff_ne_empty.mpr h_nonempty\n    exact hB'' N hN x hx.1 (le_bot_iff.mp (h_bot ▸ le_sSup hx))\n  rw [← Set.insert_diff_singleton hNM, h_empty, Set.insert_emptyc_eq] at h_ne\n  contradiction",
      "by\n  rw [lt_iff_le_and_ne]\n  constructor\n  · exact refinement_le B hB hB' hB''\n  · intro h_eq\n    obtain ⟨N, hN, h_ne⟩ := H\n    have h_N_in_ref : N ∈ refinement B hB hB' hB'' := h_eq ▸ hN\n    simp only [SetLike.mem_coe, refinement, Set.mem_iUnion] at h_N_in_ref\n    obtain ⟨K, hK, h_N_in_BK⟩ := h_N_in_ref\n    have h_N_le_K : N ≤ K := by\n      rw [hB K hK]\n      exact le_sSup h_N_in_BK\n    have h_NK : N = K := by\n      by_contra h_diff\n      have h_disj : Disjoint N K := sSupIndep.pairwiseDisjoint D.sSupIndep hN hK h_diff\n      have h_bot : N = ⊥ := disjoint_self.mp (Disjoint.mono_right h_N_le_K h_disj)\n      exact D.not_bot_mem (h_bot ▸ hN)\n    subst h_NK\n    have h_B_eq : B N hN = {N} := by\n      apply Set.eq_singleton_iff_unique_mem.mpr\n      constructor\n      · exact h_N_in_BK\n      · intro x hx\n        by_contra h_x_ne_N\n        have h_disj : Disjoint x N := sSupIndep.pairwiseDisjoint (hB' N hN) hx h_N_in_BK h_x_ne_N\n        have h_x_le_N : x ≤ N := (hB N hN).symm ▸ le_sSup hx\n        have h_bot : x = ⊥ := disjoint_self.mp (Disjoint.mono_right h_x_le_N h_disj)\n        exact hB'' N hN (h_bot ▸ hx)\n    exact h_ne h_B_eq",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_\n  intro h_eq\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_in : N ∈ refinement B hB hB' hB'' := h_eq ▸ hN\n  simp only [refinement, SetLike.mem_coe, Set.mem_iUnion] at h_in\n  obtain ⟨M, hM, h_mem⟩ := h_in\n  have h_le : N ≤ M := (le_sSup h_mem).trans (hB M hM).symm.le\n  have h_eq_NM : N = M := by\n    by_contra h_diff\n    have h_sub : {N, M} ⊆ D := by\n      intro x hx\n      simp only [Set.mem_insert_iff, Set.mem_singleton_iff] at hx\n      rcases hx with rfl | rfl <;> assumption\n    have h_ind : sSupIndep ({N, M} : Set (PersistenceSubmodule M)) := D.sSupIndep.mono h_sub\n    rw [sSupIndep_pair h_diff] at h_ind\n    have h_bot : N = ⊥ := disjoint_self.mp (disjoint_of_subset_left h_le h_ind.symm)\n    exact D.not_bot_mem hN h_bot\n  subst h_eq_NM\n  have h_sing : B N hN = {N} := by\n    refine Set.eq_singleton_iff_unique_mem.2 ⟨h_mem, fun x hx ↦ ?_⟩\n    by_contra h_x_ne\n    have h_le_sup : x ≤ sSup (B N hN \\ {N}) := le_sSup ⟨hx, h_x_ne⟩\n    have h_disj : Disjoint N (sSup (B N hN \\ {N})) := hB' N hN N h_mem\n    have h_le_N : x ≤ N := (le_sSup hx).trans (hB N hN).symm.le\n    have h_disj_x : Disjoint x N := disjoint_of_subset_left h_le_sup h_disj.symm\n    have h_bot : x = ⊥ := disjoint_self.mp (disjoint_of_subset_right h_le_N h_disj_x)\n    subst h_bot\n    exact hB'' N hN hx\n  exact h_ne h_sing",
      "by\n  rw [lt_iff_le_not_le]\n  refine ⟨refinement_le B hB hB' hB'', ?_⟩\n  intro h_le\n  obtain ⟨N, hN, h_ne⟩ := H\n  apply h_ne\n  have h_sub : B N hN ⊆ {N} := by\n    intro x hx\n    have hx_in : x ∈ refinement B hB hB' hB'' := by\n      simp only [refinement, SetLike.mem_coe, Set.mem_iUnion]\n      use N, hN\n    obtain ⟨S, hS_sub, hx_eq⟩ := h_le hx_in\n    have x_le_N : x ≤ N := by\n      rw [hB N hN]\n      exact le_sSup hx\n    have S_le_N : sSup S ≤ N := hx_eq.trans_le x_le_N\n    have h_eq : ∀ s ∈ S, s = N := by\n      intro s hs\n      by_contra h_neq\n      have h_disj : Disjoint s N := by\n        apply Disjoint.mono_right _ (D.sSupIndep (hS_sub hs))\n        apply le_sSup\n        exact ⟨hN, h_neq⟩\n      have h_bot : s = ⊥ := h_disj.eq_bot_of_le ((le_sSup hs).trans S_le_N)\n      exact D.not_bot_mem (hS_sub hs) h_bot\n    have S_eq : S = {N} := by\n      have h_nonempty : S.Nonempty := by\n        by_contra h_empty\n        simp [Set.not_nonempty_iff_eq_empty] at h_empty\n        rw [h_empty, sSup_empty] at hx_eq\n        rw [hx_eq] at hx\n        exact hB'' N hN hx\n      ext s\n      constructor\n      · intro hs; rw [h_eq s hs]; exact Set.mem_singleton _\n      · intro hs; rw [Set.mem_singleton_iff] at hs; rw [hs]\n        exact h_nonempty.some_mem ▸ h_eq _ h_nonempty.some_mem ▸ hs\n    rw [S_eq, sSup_singleton] at hx_eq\n    rw [hx_eq]\n    exact Set.mem_singleton _\n  rcases Set.eq_empty_or_nonempty (B N hN) with h_empty | h_nonempty\n  · rw [h_empty, sSup_empty] at hB\n    exact (D.not_bot_mem hN (hB N hN).symm).elim\n  · exact Set.eq_singleton_iff_nonempty_unique_mem.mpr ⟨h_nonempty, fun x hx ↦ Set.mem_singleton_iff.mp (h_sub hx)⟩",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_\n  intro h_eq\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_S_sub : B N hN ⊆ {N} := by\n    intro x hx\n    have h_x_mem : x ∈ refinement B hB hB' hB'' := by\n      simp only [refinement, SetLike.mem_coe, Set.mem_iUnion]\n      use N, hN\n    rw [h_eq] at h_x_mem\n    have h_le : x ≤ N := (hB N hN) ▸ le_sSup hx\n    by_contra h_diff\n    have h_disj : Disjoint x N := by\n      apply disjoint_of_subset_right _ (D.sSupIndep' x h_x_mem)\n      apply le_sSup\n      exact ⟨hN, h_diff.symm⟩\n    have h_x_bot : x = ⊥ := h_disj.eq_bot_of_le h_le\n    exact (hB'' N hN) (h_x_bot ▸ hx)\n  have h_S_eq : B N hN = {N} := by\n    rcases Set.subset_singleton_iff_eq.mp h_S_sub with h_empty | h_eq\n    · have h_N_bot : N = ⊥ := by rw [hB N hN, h_empty, sSup_empty]\n      exact False.elim (D.not_bot_mem (h_N_bot ▸ hN))\n    · exact h_eq\n  exact h_ne h_S_eq",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') ?_\n  intro h_eq\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_mem : N ∈ refinement B hB hB' hB'' := h_eq.symm ▸ hN\n  simp only [refinement, SetLike.mem_coe, Set.mem_iUnion] at h_mem\n  obtain ⟨M, hM, h_mem_M⟩ := h_mem\n  have h_le : N ≤ M := (le_sSup h_mem_M).trans_eq (hB M hM).symm\n  have h_eq_NM : N = M := by\n    by_contra h_neq\n    have h_disj := sSupIndep.pairwiseDisjoint D.sSupIndep' hN hM h_neq\n    exact D.not_bot_mem' (hN ▸ Disjoint.eq_bot_of_le h_disj h_le)\n  subst h_eq_NM\n  apply h_ne\n  refine (Set.eq_singleton_iff_unique_mem.mpr ⟨h_mem_M, fun x hx ↦ ?_⟩).symm\n  by_contra h_x_ne\n  have h_disj := (hB' N hN) hx\n  rw [disjoint_iff_inf_le] at h_disj\n  have h_x_le_N : x ≤ N := (le_sSup hx).trans_eq (hB N hN).symm\n  have h_N_le : N ≤ sSup (B N hN \\ {x}) :=\n    le_sSup ⟨h_mem_M, fun h => h_x_ne (Set.mem_singleton_iff.mp h).symm⟩\n  have h_x_bot : x = ⊥ := by\n    apply le_bot_iff.mp\n    trans x ⊓ sSup (B N hN \\ {x})\n    · apply le_inf le_rfl (h_x_le_N.trans h_N_le)\n    · exact h_disj\n  exact hB'' N hN (h_x_bot ▸ hx)",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') (fun h_eq ↦ ?_)\n  obtain ⟨N, hN, h_ne⟩ := H\n  have : N ∈ refinement B hB hB' hB'' := h_eq ▸ hN\n  simp only [refinement, SetLike.mem_coe, Set.mem_iUnion] at this\n  obtain ⟨K, hK, h_mem⟩ := this\n  have h_le : N ≤ K := (hB K hK).symm ▸ le_sSup h_mem\n  have h_eq_NK : N = K := by\n    by_contra h_diff\n    exact D.not_bot_mem <| (disjoint_self.mp <| disjoint_of_le_right h_le <|\n      D.sSupIndep.pairwiseDisjoint hN hK h_diff) ▸ hN\n  subst h_eq_NK\n  apply h_ne\n  refine Set.eq_singleton_of_forall_mem_eq h_mem (fun P hP ↦ ?_)\n  by_contra h_diff\n  have : P ≤ ⊥ := le_trans (le_inf ((hB N hN).symm ▸ le_sSup hP) (le_sSup ⟨hP, h_diff⟩))\n    (disjoint_iff_inf_le.mp <| hB' N hN h_mem)\n  exact hB'' N hN P hP (le_bot_iff.mp this)",
      "by\n  rcases H with ⟨N, hN, h_ne⟩\n  rw [lt_iff_le_not_le]\n  refine ⟨refinement_le B hB hB' hB'', ?_⟩\n  intro h_le\n  apply h_ne\n  have h_subset : B N hN ⊆ {N} := by\n    intro x hx\n    have h_in_ref : x ∈ (refinement B hB hB' hB'') := by\n      simp [refinement]\n      exact ⟨N, ⟨hN, hx⟩⟩\n    obtain ⟨S, hS_sub, hS_eq⟩ := h_le h_in_ref\n    have hS_sub_N : S ⊆ {N} := by\n      intro y hy\n      have hy_le_N : y ≤ N := by\n        rw [← hS_eq] at hx\n        have : x ≤ N := by rw [hB N hN]; exact le_sSup hx\n        exact le_trans (le_sSup hy) (hS_eq.symm ▸ this)\n      have hy_in_D : y ∈ D := hS_sub hy\n      by_contra h_diff\n      rw [Set.mem_singleton_iff] at h_diff\n      have h_disj : Disjoint y N := D.sSupIndep'.pairwise_disjoint hy_in_D hN h_diff\n      have : y = ⊥ := disjoint_self.mp (disjoint_of_subset_right hy_le_N h_disj)\n      exact D.not_bot_mem hy_in_D this\n    have hS_eq_N : S = {N} := by\n      refine Set.eq_singleton_of_forall_mem_eq (fun y hy => Set.mem_singleton_iff.mp (hS_sub_N hy)) ?_\n      by_contra h_empty\n      rw [Set.not_nonempty_iff_eq_empty] at h_empty\n      rw [h_empty, sSup_empty] at hS_eq\n      exact hB'' N hN x hx hS_eq\n    rw [hS_eq_N, sSup_singleton] at hS_eq\n    rw [hS_eq]\n    exact Set.mem_singleton N\n  have h_nonempty : (B N hN).Nonempty := by\n    by_contra h_empty\n    rw [Set.not_nonempty_iff_eq_empty, h_empty, sSup_empty] at hB\n    exact D.not_bot_mem hN (hB N hN).symm\n  exact Set.eq_singleton_of_forall_mem_eq (fun x hx => Set.mem_singleton_iff.mp (h_subset hx)) h_nonempty",
      "by\n  rw [lt_iff_le_and_ne]\n  refine ⟨refinement_le B hB hB' hB'', ?_⟩\n  intro h_eq\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_mem : N ∈ refinement B hB hB' hB'' := h_eq ▸ hN\n  simp only [refinement, SetLike.mem_coe, Set.mem_iUnion] at h_mem\n  obtain ⟨N', hN', h_mem_B⟩ := h_mem\n  have h_le : N ≤ N' := (hB N' hN').symm ▸ le_sSup h_mem_B\n  have h_eq_N : N = N' := by\n    by_contra h_diff\n    have h_le_sup : N' ≤ sSup (SetLike.coe D \\ {N}) := le_sSup ⟨hN', h_diff.symm⟩\n    have h_disj : Disjoint N N' := Disjoint.mono_right h_le_sup (D.sSupIndep' hN)\n    exact D.not_bot_mem (Disjoint.eq_bot_of_le h_disj h_le ▸ hN)\n  subst h_eq_N\n  have h_singleton : B N hN = {N} := by\n    refine Set.eq_singleton_iff_unique_mem.mpr ⟨h_mem_B, fun M hM ↦ ?_⟩\n    by_contra h_diff\n    have h_le_sup : M ≤ sSup (B N hN \\ {N}) := le_sSup ⟨hM, h_diff⟩\n    have h_disj : Disjoint N M := Disjoint.mono_right h_le_sup (hB' N hN h_mem_B)\n    have h_le_N : M ≤ N := (hB N hN).symm ▸ le_sSup hM\n    exact hB'' N hN (Disjoint.eq_bot_of_le h_disj.symm h_le_N ▸ hM)\n  exact h_ne h_singleton",
      "by\n  refine lt_of_le_of_not_le (refinement_le B hB hB' hB'') ?_\n  intro h_le\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_subset : B N hN ⊆ {N} := by\n    intro b hb\n    have hb_in : b ∈ refinement B hB hB' hB'' := by\n      simp [refinement]\n      exact ⟨N, ⟨hN, hb⟩⟩\n    obtain ⟨K, hK_subset, hK_sup⟩ := h_le hb_in\n    have h_k_eq_N : ∀ k ∈ K, k = N := by\n      intro k hk\n      have k_le_N : k ≤ N := by\n        have : b ≤ N := by rw [hB N hN]; exact le_sSup hb\n        rw [← hK_sup] at this\n        exact (le_sSup hk).trans this\n      have k_in_D : k ∈ D := hK_subset hk\n      by_contra k_ne_N\n      have : Disjoint k N := disjoint_of_subset_right\n        (le_sSup (Set.mem_diff_singleton.mpr ⟨hN, k_ne_N.symm⟩))\n        (D.sSupIndep k k_in_D)\n      have : k = ⊥ := this.eq_bot_of_le k_le_N\n      exact D.not_bot_mem (this ▸ k_in_D)\n    have h_K_eq_N : K = {N} := by\n      refine Set.eq_singleton_iff_unique_mem.mpr ⟨?_, h_k_eq_N⟩\n      have : b ≠ ⊥ := hB'' N hN b hb\n      rw [← hK_sup] at this\n      rcases Set.eq_empty_or_nonempty K with rfl | ⟨k, hk⟩\n      · rw [sSup_empty] at this; contradiction\n      · rw [h_k_eq_N k hk]; exact hk\n    rw [h_K_eq_N, sSup_singleton] at hK_sup\n    rwa [hK_sup]\n  have h_eq : B N hN = {N} := by\n    refine Set.eq_singleton_iff_unique_mem.mpr ⟨?_, fun x hx ↦ Set.mem_singleton_iff.mp (h_subset hx)⟩\n    have : N ≠ ⊥ := D.not_bot_mem hN\n    rw [hB N hN] at this\n    rcases Set.eq_empty_or_nonempty (B N hN) with rfl | ⟨b, hb⟩\n    · rw [sSup_empty] at this; contradiction\n    · rw [Set.mem_singleton_iff.mp (h_subset hb)]; exact hb\n  exact h_ne h_eq",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') fun h_eq ↦ ?_\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_mem : N ∈ (refinement B hB hB' hB'').carrier := h_eq.symm ▸ hN\n  simp only [refinement, Set.mem_iUnion] at h_mem\n  obtain ⟨N', hN', h_mem_B⟩ := h_mem\n  have h_le : N ≤ N' := (le_sSup h_mem_B).trans (hB N' hN').le\n  have h_eq_NN' : N = N' := by\n    by_contra h_diff\n    apply D.not_bot_mem hN\n    have h_disj : Disjoint N (sSup (D.carrier \\ {N})) := D.sSupIndep' hN\n    refine Disjoint.eq_bot_of_le (Disjoint.mono_right ?_ h_disj) h_le\n    exact le_sSup (Set.mem_diff_of_mem hN' h_diff)\n  subst h_eq_NN'\n  apply h_ne\n  refine Set.eq_singleton_iff_unique_mem.mpr ⟨h_mem_B, fun x hx ↦ ?_⟩\n  by_contra h_diff\n  have h_bot : x = ⊥ := by\n    have h_disj : Disjoint x (sSup (B N hN \\ {x})) := hB' N hN x hx\n    refine Disjoint.eq_bot_of_le (Disjoint.mono_right ?_ h_disj) ((le_sSup hx).trans (hB N hN).le)\n    exact le_sSup (Set.mem_diff_of_mem h_mem_B h_diff)\n  subst h_bot\n  exact hB'' N hN hx",
      "by\n  apply lt_of_le_not_le (refinement_le B hB hB' hB'')\n  intro h_le\n  rcases H with ⟨N, hN, h_ne⟩\n  apply h_ne\n  have h_nonempty : (B N hN).Nonempty := by\n    by_contra h_emp\n    rw [Set.not_nonempty_iff_eq_empty] at h_emp\n    have h_bot : N = ⊥ := by rw [hB N hN, h_emp, sSup_empty]\n    exact D.not_bot_mem (h_bot ▸ hN)\n  have h_forall_eq : ∀ x ∈ B N hN, x = N := by\n    intro x hx\n    let D' := refinement B hB hB' hB''\n    have h_x_in_D' : x ∈ D' := by\n      simp only [refinement, SetLike.mem_coe, Set.mem_iUnion]\n      exact ⟨N, ⟨hN, hx⟩⟩\n    obtain ⟨S, hS_sub, h_sup⟩ := h_le h_x_in_D'\n    have h_le_N : x ≤ N := by\n      rw [hB N hN]\n      exact le_sSup hx\n    have h_S_le_N : sSup S ≤ N := h_sup ▸ h_le_N\n    have h_S_sub_N : S ⊆ {N} := by\n      intro y hy\n      have hy_le : y ≤ N := le_trans (le_sSup hy) h_S_le_N\n      have hy_in_D : y ∈ D := hS_sub hy\n      by_contra h_neq\n      have h_disj : Disjoint y N := D.sSupIndep.pairwiseDisjoint hy_in_D hN h_neq\n      have h_y_bot : y = ⊥ := h_disj.eq_bot_of_le_left hy_le\n      exact D.not_bot_mem (h_y_bot ▸ hy_in_D)\n    have h_S_eq : S = {N} := by\n      refine Set.eq_singleton_iff_unique_mem.mpr ⟨N, ⟨?_, ?_⟩⟩\n      · by_contra h_not_mem\n        have h_empty : S = ∅ := by\n          ext z\n          rw [Set.mem_empty_iff_false, iff_false]\n          intro hz\n          exact h_not_mem (Set.mem_singleton_iff.mp (h_S_sub_N hz) ▸ hz)\n        have h_x_bot : x = ⊥ := by rw [h_sup, h_empty, sSup_empty]\n        exact hB'' N hN (h_x_bot ▸ hx)\n      · intro y hy\n        exact Set.mem_singleton_iff.mp (h_S_sub_N hy)\n    rw [h_sup, h_S_eq, sSup_singleton]\n  have h_mem : N ∈ B N hN := by\n    obtain ⟨z, hz⟩ := h_nonempty\n    rw [← h_forall_eq z hz]\n    exact hz\n  ext y\n  constructor\n  · exact fun hy ↦ Set.mem_singleton_iff.mpr (h_forall_eq y hy)\n  · exact fun hy ↦ (Set.mem_singleton_iff.mp hy) ▸ h_mem",
      "by\n  rw [lt_iff_le_not_le]\n  refine ⟨refinement_le B hB hB' hB'', ?_⟩\n  intro h_le\n  obtain ⟨N, hN, h_ne⟩ := H\n  apply h_ne\n  have h_ne_bot : N ≠ ⊥ := D.not_bot_mem hN\n  have h_nonempty : (B N hN).Nonempty := by\n    by_contra h\n    simp [Set.not_nonempty_iff_eq_empty] at h\n    rw [hB N hN, h, sSup_empty] at h_ne_bot\n    exact h_ne_bot rfl\n  apply Set.eq_singleton_of_forall_mem_eq h_nonempty.some_mem\n  intro b hb\n  have hb_in : b ∈ (refinement B hB hB' hB'').carrier := by\n    simp only [refinement, Set.mem_iUnion]\n    exact ⟨N, hN, hb⟩\n  obtain ⟨S, hS_sub, hS_eq⟩ := h_le hb_in\n  have h_le_N : sSup S ≤ N := hS_eq ▸ (le_sSup hb).trans_eq (hB N hN).symm\n  have hS_eq_N : S = {N} := by\n    have h_sub : S ⊆ {N} := by\n      intro s hs\n      by_contra h_diff\n      have : Disjoint s N := D.sSupIndep.disjoint_discrete (hS_sub hs) hN h_diff\n      have : s = ⊥ := Disjoint.eq_bot_of_le this ((le_sSup hs).trans h_le_N)\n      exact D.not_bot_mem (this ▸ hS_sub hs)\n    have hS_ne_bot : sSup S ≠ ⊥ := hS_eq ▸ hB'' N hN b hb\n    have hS_nonempty : S.Nonempty :=\n      Set.nonempty_iff_ne_empty.mpr fun h => hS_ne_bot (h.symm ▸ sSup_empty)\n    rw [Set.eq_singleton_iff_unique_mem]\n    exact ⟨N, h_sub hS_nonempty.some_mem, fun x hx => h_sub hx⟩\n  rw [hS_eq, hS_eq_N, sSup_singleton]\n\nend Indecomposable",
      "by\n  refine lt_of_le_of_ne (refinement_le B hB hB' hB'') (fun h_eq ↦ ?_)\n  obtain ⟨N, hN, h_ne⟩ := H\n  have hN' : N ∈ refinement B hB hB' hB'' := h_eq ▸ hN\n  simp only [refinement, Set.mem_iUnion] at hN'\n  obtain ⟨M, hM, hN_in_B⟩ := hN'\n  have hNM : N = M := by\n    by_contra h_diff\n    have h_le : N ≤ M := le_trans (le_sSup hN_in_B) (hB M hM).ge\n    have h_disj : Disjoint N M := Disjoint.mono_right (le_sSup ⟨hM, h_diff.symm⟩) (D.sSupIndep N hN)\n    exact D.not_bot_mem hN <| disjoint_self.1 <| Disjoint.mono_left h_le h_disj\n  subst hNM\n  apply h_ne\n  refine Set.eq_singleton_iff_unique_mem.2 ⟨hN_in_B, fun P hP ↦ ?_⟩\n  by_contra hPN\n  have h_le : P ≤ N := le_trans (le_sSup hP) (hB N hN).ge\n  have h_disj : Disjoint P N := Disjoint.mono_right (le_sSup ⟨hN_in_B, hPN⟩) (hB' N hN P hP)\n  exact hB'' N hN P hP <| disjoint_self.1 <| Disjoint.mono_left h_le h_disj",
      "by\n  refine lt_of_le_of_not_le (refinement_le B hB hB' hB'') (fun h_le => ?_)\n  obtain ⟨N, hN, h_ne⟩ := H\n  have h_sub : B N hN ⊆ {N} := by\n    intro b hb\n    have hb_in_R : b ∈ refinement B hB hB' hB'' := by\n      simp only [refinement, SetLike.mem_coe, Set.mem_iUnion]\n      exact ⟨N, ⟨hN, hb⟩⟩\n    obtain ⟨S, hS_sub, hS_eq⟩ := h_le hb_in_R\n    have h_b_le_N : b ≤ N := (le_sSup hb).trans_eq (hB N hN).symm\n    have h_S_sub_N : S ⊆ {N} := by\n      intro s hs\n      have hs_in_D : s ∈ D := hS_sub hs\n      have hs_le_N : s ≤ N := (le_sSup hs).trans (hS_eq.trans_le h_b_le_N)\n      by_cases h_eq : s = N\n      · rwa [h_eq]\n      · have h_disj : Disjoint s N := D.sSupIndep.pairwise_disjoint hs_in_D hN h_eq\n        have h_bot : s = ⊥ := Disjoint.eq_bot_of_le h_disj hs_le_N\n        exfalso; exact D.not_bot_mem (h_bot ▸ hs_in_D)\n    have h_S_eq_N : S = {N} := by\n      rw [Set.subset_singleton_iff_eq] at h_S_sub_N\n      refine h_S_sub_N.resolve_left (fun h_empty => ?_)\n      rw [h_empty, sSup_empty] at hS_eq\n      exact hB'' N hN hb (hS_eq ▸ rfl)\n    rw [h_S_eq_N, sSup_singleton] at hS_eq\n    exact hS_eq\n  have h_nonempty : (B N hN).Nonempty := by\n    rw [Set.nonempty_iff_ne_empty]\n    intro h_emp\n    rw [h_emp, sSup_empty] at hB\n    exact D.not_bot_mem (hB N hN ▸ hN)\n  rw [Set.subset_singleton_iff_eq] at h_sub\n  exact h_ne (h_sub.resolve_left (Set.nonempty_iff_ne_empty.mp h_nonempty))",
