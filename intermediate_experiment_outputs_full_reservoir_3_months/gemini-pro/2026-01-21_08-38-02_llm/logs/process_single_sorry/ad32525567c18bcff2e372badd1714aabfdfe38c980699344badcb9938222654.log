      "\n  ext n\n  simp only [Set.mem_setOf_eq, answer, Set.mem_sep_eq]\n  constructor\n  · rintro ⟨h0, A, B, hAB, hAcard, hAinter, hBcov, f, hfB, hfA⟩\n    let m := 2 * n + 1\n    let r (x : ℕ) := (Finset.univ.filter (λ i : Fin m, x ∈ A i)).card\n    have h_sum : ∑ x in B, r x = m * (2 * n) := by\n      rw [← Finset.sum_comm]; simp [hAcard, m]\n    have h_sq : ∑ x in B, r x * (r x - 1) = m * (2 * n) := by\n      let P := (Finset.univ : Finset (Fin m)).offDiag\n      have : ∑ p in P, (A p.1 ∩ A p.2).card = m * (2 * n) := by\n        simp [Finset.offDiag_card, hAinter, m, mul_comm]\n      rw [← this, Finset.sum_comm]; apply Finset.sum_congr rfl (fun x _ => ?)\n      rw [← Finset.card_offDiag, Finset.filter_filter]; congr; ext; simp [r, and_comm]\n    have : ∀ x ∈ B, r x = 2 := by\n      intro x hx\n      have r_ge_2 : 2 ≤ r x := by\n        rcases hBcov x hx with ⟨i, j, hij, hi, hj⟩\n        rw [← Nat.card_doubleton hij.symm]\n        exact Finset.card_le_card_of_subset_iff.2 (λ k hk => by simp at hk; cases hk <;> subst k <;> simp [hi, hj])\n      have : ∑ x in B, r x * (r x - 2) = 0 := by\n        rw [← Nat.sub_eq_zero_iff_le.2 (le_of_eq (h_sq.trans h_sum.symm))]\n        apply Finset.sum_congr rfl (fun y _ => by \n          rw [Nat.mul_sub_right_distrib, Nat.mul_sub_one, Nat.sub_sub, Nat.add_comm, ← Nat.sub_sub])\n      exact (Nat.eq_zero_of_add_eq_zero_right (Finset.sum_eq_zero_iff_of_nonneg (λ _ _ => Nat.zero_le _)).1 this x hx).1 \n        |>.resolve_right (Nat.sub_ne_zero_of_lt r_ge_2)\n    have : Even (m * n) := by\n      rw [← Finset.card_univ, ← Finset.sum_const, Finset.sum_congr rfl (fun i _ => (hfA i).symm), Finset.sum_comm, ← nsmul_eq_mul]\n      convert even_two_mul _\n      rw [Finset.sum_filter, Finset.sum_congr rfl (fun x hx => by rw [this x hx])]; simp\n    simpa [m, parity_simps] using this\n  · rintro ⟨h0, ⟨k, rfl⟩⟩\n    let m := 4 * k + 1\n    let V := ZMod m\n    let E := (Finset.univ : Finset (Finset V)).filter (λ s => s.card = 2)\n    have : ∃