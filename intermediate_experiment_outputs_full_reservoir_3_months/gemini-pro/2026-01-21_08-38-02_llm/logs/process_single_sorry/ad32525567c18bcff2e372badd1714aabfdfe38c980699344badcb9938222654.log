      "\n  simp only [answer, Set.ext_iff, Set.mem_setOf_eq]\n  intro n\n  constructor\n  · rintro ⟨h_pos, A, B, hAB, hA_card, hA_inter, hB_cover, f, hf_range, hf_deg⟩\n    refine ⟨h_pos, ?_⟩\n    let m := 2 * n + 1\n    let r (x : ℕ) := (Finset.univ.filter (λ i : Fin m ↦ x ∈ A i)).card\n    \n    -- We count pairs (x, i) such that x ∈ A_i in two ways to find ∑ r(x)\n    have sum_r : ∑ x in B, r x = m * (2 * n) := by\n      rw [mul_comm, ← hA_card 0, Fintype.card_fin]\n      simp_rw [r, card_eq_sum_ones, sum_filter, sum_comm]\n      apply sum_congr rfl (λ i _ ↦ by\n        rw [sum_filter, sum_const, Nat.smul_one_eq_coe]\n        congr; ext x; simp only [mem_filter, true_and]; exact hAB i)\n\n    -- We count triples (x, i, j) with i ≠ j and x ∈ A_i ∩ A_j to find ∑ r(x)(r(x)-1)\n    have sum_r_comb : ∑ x in B, r x * (r x - 1) = m * (2 * n) := by\n      rw [← mul_one (m * (2 * n))]\n      trans ∑ p in (Finset.univ : Finset (Fin m)).offDiag, (A p.1 ∩ A p.2).card\n      · simp_rw [card_eq_sum_ones, sum_filter, sum_comm]\n        apply sum_congr rfl (λ x hx ↦ ?_)\n        rw [sum_filter, r, ←Nat.mul_pred_eq_succ_mul_pred, mul_comm, Nat.mul_sub_one]\n        simp_rw [←card_offDiag, filter_offDiag, card_eq_sum_ones, sum_filter, mem_offDiag,\n                 mem_filter, mem_univ, true_and, and_assoc]\n        rfl\n      · simp only [hA_inter, mul_comm 2 n, card_offDiag, card_univ, Fintype.card_fin, sum_const, Nat.smul_one_eq_coe, Nat.mul_sub_one]\n\n    -- This implies r(x) = 2 for all x\n    have h_r_eq_2 : ∀ x ∈ B, r x = 2 := by\n      have h_sum : ∑ x in B, (r x * (r x - 1) - r x) = 0 := by \n        rw [sum_sub_distrib, sum_r_comb, sum_r, sub_self]\n      intro x hx\n      -- Since x is in at least 2 sets, r x ≥ 2\n      obtain ⟨i, j, hij, hi, hj⟩ := hB_cover x hx\n      have h_ge : 2 ≤ r x := by\n        rw [r]\n        refine le_trans (show 2 ≤ ({i, j} : Finset (Fin m)).card by simp [hij]) (card_le_of_subset ?_)\n        intro k hk; simp at hk; cases hk <;> subst k <;