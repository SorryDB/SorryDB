      "\n  ext n\n  simp only [Set.mem_setOf_eq]\n  constructor\n  · rintro ⟨hn, A, B, hAB, hAcard, hAinter, hBcov, f, hfB, hfA⟩\n    let m := 2 * n + 1\n    let r (x : ℕ) := (Finset.univ.filter (fun i : Fin m ↦ x ∈ A i)).card\n    have h1 : ∑ x in B, r x = m * (2 * n) := by\n      rw [Finset.sum_comm]; simp [r, hAcard, mul_comm]\n    have h2 : ∑ x in B, r x * (r x - 1) = m * (2 * n) := by\n      rw [Finset.sum_comm]\n      trans ∑ i : Fin m, ∑ j in Finset.univ.erase i, (A i ∩ A j).card\n      · apply Finset.sum_congr rfl; intro i _; apply Finset.sum_congr rfl; intro j hj\n        rw [Finset.mem_erase] at hj; simp [hAinter i j hj.2, r]\n      · simp [mul_comm, Finset.card_univ, mul_assoc]\n        rw [← Nat.mul_succ, Nat.succ_eq_add_one, Nat.sub_add_cancel (by simp [m]; linarith)]\n        simp [m, mul_comm]\n    have h3 : ∑ x in B, r x * (r x - 2) = 0 := by\n      rw [← Nat.sub_eq_of_eq (h2.trans h1.symm)]\n      apply Finset.sum_congr rfl; intro x hx\n      obtain ⟨i, j, hij, hi, hj⟩ := hBcov x hx\n      have : r x ≥ 2 := by rw [r, Finset.card_ge_two]; exact ⟨i, by simp [hi], j, by simp [hj], hij⟩\n      zify [this]; ring\n    have hr : ∀ x ∈ B, r x = 2 := by\n      intro x hx\n      have : r x * (r x - 2) = 0 := Finset.sum_eq_zero h3 hx\n      obtain ⟨i, j, hij, hi, hj⟩ := hBcov x hx\n      have hge : r x ≥ 2 := by rw [r, Finset.card_ge_two]; exact ⟨i, by simp [hi], j, by simp [hj], hij⟩\n      exact Nat.eq_of_mul_eq_zero_left (by linarith) this |> (Nat.sub_eq_zero_iff_le.mp · |> (le_antisymm · hge))\n    let B0 := B.filter (f · = 0)\n    have : 2 * B0.card = m * n := by\n      trans ∑ x in B0, r x\n      · rw [Finset.sum_const]; simp [hr]; rfl\n      · rw [Finset.sum_comm]; simp only [Finset.sum_boole, Finset.mem_filter]\n        trans ∑ i : Fin m, n\n        · apply Finset.sum_congr rfl; intro i _; rw [←hfA i]; apply Finset.card_congr; intro x _; simp; tauto\n        · simp\n    rw [mul_comm] at this\n    use hn\n    have : Coprime 2 m := by simp [m, Nat.coprim