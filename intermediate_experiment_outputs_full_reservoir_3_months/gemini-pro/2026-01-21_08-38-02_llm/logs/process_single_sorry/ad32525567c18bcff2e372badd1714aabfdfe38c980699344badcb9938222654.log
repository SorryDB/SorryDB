of_bij (fun s _ => (s.erase u).min' (by \n           intro h; rw [card_eq_zero] at h; have := (mem_filter.1 ‹_›).1; rw [mem_filter] at this; linarith [this.2]))\n         · intro s hs; apply (mem_erase.mp ((s.erase u).min'_mem _)).1;\n           intro h; rw [card_eq_zero] at h; have := (mem_filter.1 hs).1; rw [mem_filter] at this; linarith [this.2]\n         · intros s1 s2 h1 h2 eq\n           rw [mem_filter] at h1 h2; \n           have c1 : s1.card = 2 := h1.1.2; have u1 : u ∈ s1 := h1.2\n           have c2 : s2.card = 2 := h2.1.2; have u2 : u ∈ s2 := h2.2\n           let v1 := (s1.erase u).min' _\n           let v2 := (s2.erase u).min' _\n           have : s1 = {u, v1} := by ext z; simp; constructor; \n             intro hz; by_cases z = u; left; exact h; right; have : z ∈ s1.erase u := mem_erase.mpr ⟨h, hz⟩;\n             rw [eq_singleton_of_card_one (by rw [card_erase_of_mem u1, c1]; rfl) (mem_erase.mpr ⟨(mem_erase.mp ((s1.erase u).min'_mem _)).1, (mem_erase.mp ((s1.erase u).min'_mem _)).2⟩)] at this; exact mem_singleton.mp this\n             rintro (rfl|rfl); exact u1; exact (mem_erase.mp ((s1.erase u).min'_mem _)).2\n           have : s2 = {u, v2} := by ext z; simp; constructor;\n             intro hz; by_cases z = u; left; exact h; right; have : z ∈ s2.erase u := mem_erase.mpr ⟨h, hz⟩;\n             rw [eq_singleton_of_card_one (by rw [card_erase_of_mem u2, c2]; rfl) (mem_erase.mpr ⟨(mem_erase.mp ((s2.erase u).min'_mem _)).1, (mem_erase.mp ((s2.erase u).min'_mem _)).2⟩)] at this; exact mem_singleton.mp this\n             rintro (rfl|rfl); exact u2; exact (mem_erase.mp ((s2.erase u).min'_mem _)).2\n           rw [‹s1 = {u, v1}›, ‹s2 = {u, v2}›, eq]\n         · intro v hv; rw [mem_erase] at hv\n           refine ⟨{u, v}, ?_, ?_⟩\n           · rw [mem_filter]; refine ⟨⟨univ, rfl, card_pair hv.1⟩, mem_insert_self _ _⟩\n           · simp; apply min'_eq_of_eq_singleton; rw [erase_insert (not_mem_singleton.mpr hv.1)]; rfl\n       · rw [card_erase_of_mem (mem_univ u)