      "\n  rw [answer]\n  ext n\n  simp only [Set.mem_setOf_eq, Set.mem_sep_eq]\n  constructor\n  · rintro ⟨h0, A, B, hAB, hA, hInt, hB, f, hfB, hfA⟩\n    refine ⟨h0, ?_⟩\n    let m := 2 * n + 1\n    let r (x : ℕ) := (Finset.univ.filter (fun i : Fin m ↦ x ∈ A i)).card\n    have hr : ∀ x ∈ B, r x = 2 := by\n      have h_sum : ∑ x in B, r x = m * (2 * n) := by\n        rw [Finset.sum_comm]; simp [hA, mul_comm]\n      have h_sum_sq : ∑ x in B, r x * (r x - 1) = m * (2 * n) := by\n        rw [Finset.sum_comm]\n        trans ∑ i : Fin m, ∑ j : Fin m, if i = j then 0 else (A i ∩ A j).card\n        · apply Finset.sum_congr rfl; intro x hx; simp only [Finset.sum_boole];\n          rw [← sq, r, Finset.card_eq_sum_ones]\n          have : (∑ i : Fin m, if x ∈ A i then 1 else 0) ^ 2 = ∑ i : Fin m, ∑ j : Fin m, (if x ∈ A i then 1 else 0) * (if x ∈ A j then 1 else 0) := sum_mul_sum ..\n          rw [this, Nat.mul_sub_one, Finset.sum_sub_distrib]\n          congr\n          · apply Finset.sum_congr rfl; intro i _; apply Finset.sum_congr rfl; intro j _; split_ifs; all_goals simp\n          · simp\n        · simp [hInt, Finset.filter_ne, Finset.card_erase_of_mem, mul_comm]\n      have : ∑ x in B, r x * (r x - 2) = 0 := by\n        rw [Finset.sum_mul, h_sum_sq, Finset.sum_mul, h_sum, mul_comm, mul_assoc, mul_comm (2*n)]\n        exact Nat.sub_self _\n      intro x hx\n      apply Finset.sum_eq_zero_iff_of_nonneg at this\n      · specialize this x hx\n        have : 2 ≤ r x := by\n          obtain ⟨i, j, hij, hi, hj⟩ := hB x hx\n          rw [r, Finset.card_ge_iff_exists_sublist]\n          exact ⟨[i, j], by simp [hij], by simp [hi, hj]⟩\n        zify at this ⊢; rw [mul_eq_zero, sub_eq_zero] at this; rcases this with h|h; linarith; exact h\n      · intro y hy; obtain ⟨i, j, hij, hi, hj⟩ := hB y hy\n        have : 2 ≤ r y := by\n           rw [r, Finset.card_ge_iff_exists_sublist]; exact ⟨[i, j], by simp [hij], by simp [hi, hj]⟩\n        exact Nat.mul_self_sub_mul_two_nonneg _\n    let B0 := B.filter (fun x ↦ f x = 0)\n    have : 2 * B0.card = m * n := by\n      rw [mul_comm, ← Finset.sum_const]\n      trans ∑ i : Fin m, ((A i).filter (f · = 0)).card\n      · simp [hfA]\n      · rw [Finset.sum_comm]; apply Finset.sum_congr rfl; intro x hx\n        simp only [Finset.mem_filter] at hx\n        rw [Finset.card_eq_sum_ones, Finset.sum_filter, r, ← Finset.card_eq_sum_ones]\n        exact hr x hx.1\n    rw [← this]\n    exact dvd_mul_right 2 _\n  · rintro ⟨h0, ⟨k, rfl⟩⟩\n    let n := 2 * k\n    let m := 4 * k + 1\n    let encode (p : Fin m × Fin m) : ℕ := p.1.val * m + p.2.val\n    let B : Finset ℕ := (Finset.univ.filter (fun p : Fin m × Fin m ↦ p.1 < p.2)).image encode\n    let A (i : Fin m) : Finset ℕ := B.filter (fun x ↦ ∃ j, (j ≠ i ∧ (encode (if i < j then (i, j) else (j, i)) = x)))\n    refine ⟨h0, A, B, ?_, ?_, ?_, ?_, ?_⟩\n    · intro i x hx; simp [A] at hx; exact hx.1\n    · intro i; sorry\n    · intro i j hij; sorry\n    · intro x hx; sorry\n    · let f (x : ℕ) : ℕ := if ∃ u v : Fin m, u < v ∧ encode (u, v) = x ∧\n        ((v - u).val ≤ k ∨ (v - u).val ≥ m - k) then 0 else 1\n      use f; refine ⟨fun _ _ ↦ by apply Classical.em, ?_⟩\n      intro i; sorry",
      "\n  dsimp [answer]; ext n\n  constructor\n  · rintro ⟨h0, A, B, hAB, hA, hA_int, hB, f, hf_range, hf_count⟩\n    let m := 2 * n + 1\n    let k (x : ℕ) := (Finset.univ.filter (λ i : Fin m ↦ x ∈ A i)).card\n    have sum_k : ∑ x in B, k x = m * (2 * n) := by\n      rw [← Finset.sum_const (s := Finset.univ) (2 * n), ← hA, Finset.sum_comm]\n      exact Finset.sum_congr rfl (λ x _ ↦ by rw [Finset.card_eq_sum_ones, Finset.sum_filter]; rfl)\n    have sum_k_sq : ∑ x in B, k x * (k x - 1) = m * (2 * n) := by\n      rw [← Finset.sum_const (s := Finset.univ.offDiag) 1, ← hA_int, Finset.sum_offDiag]\n      simp_rw [Finset.card_eq_sum_ones, Finset.sum_filter, Finset.sum_comm (s := B),\n        ← Finset.sum_product', Finset.filter_product, Finset.card_product]\n      refine Finset.sum_congr rfl (λ x _ ↦ ?_)\n      simp_rw [mul_comm, boole_mul, Finset.sum_boole, Finset.filter_filter]; congr\n    have k_eq_2 : ∀ x ∈ B, k x = 2 := λ x hx ↦ by\n      have : ∑ x in B, (k x * (k x - 2)) = 0 := by\n        rw [← sub_eq_zero] at sum_k sum_k_sq ⊢; simp_rw [mul_sub, mul_two, ← sum_k, ← sum_k_sq, ← Finset.sum_sub_distrib]\n        rw [sum_k_sq, sum_k, sub_self]\n      have h_nonneg : ∀ y ∈ B, 0 ≤ k y * (k y - 2) := λ y hy ↦ Nat.mul_self_sub_mul_two_nonneg _\n      have h_term_zero : k x * (k x - 2) = 0 := (Finset.sum_eq_zero_iff_of_nonneg h_nonneg).mp this x hx\n      obtain ⟨i, j, hij, hi, hj⟩ := hB x hx\n      have : 2 ≤ k x := by\n        rw [Finset.card_ge_iff_exists_sublist]; use [i, j]; simp [hij, hi, hj]\n        rw [List.Sublist]; simp [List.IsSuffix]; use []; simp\n      exact Nat.eq_of_mul_eq_zero_of_le h_term_zero this\n    let B0 := B.filter (f · = 0)\n    have : 2 * B0.card = m * n := by\n      rw [← Finset.sum_const (s := B0) 2, ← Finset.sum_congr rfl (fun x hx => k_eq_2 x (Finset.mem_of_mem_filter hx)), Finset.sum_comm]\n      simp_rw [Finset.card_eq_sum_ones, Finset.sum_filter]\n      rw [← Finset.sum_comm]; simp_rw [hf_count, Finset.sum_const, Fintype.card_fin, nsmul_