@[imo_problem_subject combinatorics]
theorem imo_1988_p2 :
    {(n) | (n : ℕ) (h₀ : 0 < n)
      -- "$ A_1, A_2, \ldots, A_{2n+1}$ be subsets of a set B"
      (A : Fin (2 * n + 1) → Finset ℕ)
      (B : Finset ℕ)
      (h₀ : ∀ i, A i ⊆ B)
      -- "(i) Each $A_i$ has exactly $2n$ elements,"
      (h₁ : ∀ i, (A i).card = 2 * n)
      -- "(ii) The intersection of every two distinct $A_i$ contains exactly one element, and"
      (h₂ : ∀ i j, i ≠ j → (A i ∩ A j).card = 1)
      -- "(iii) Every element of $B$ belongs to at least two of the $A_i$."
      (h₃ : ∀ x ∈ B, ∃ i j, i ≠ j ∧ x ∈ A i ∧ x ∈ A j)
      -- Assignment from every member of the union to {0, 1}
      (h₅ : ∃ f : ℕ → ℕ, (∀ x : ℕ, x ∈ B → f x = 0 ∨ f x = 1) ∧
        ∀ i, ((A i).filter (f · = 0)).card = n)} =
    answer({n : ℕ | 0 < n ∧ 2 ∣ n}) := by
  ext n
  constructor
  · rintro ⟨h0, A, B, hsub, hcard, hinter, hcover, f, _, hf_count⟩
    use h0
    have hr : ∀ x ∈ B, (univ.filter (fun i => x ∈ A i)).card = 2 := by
      intro x hx
      obtain ⟨i, _, _, hi, _⟩ := hcover x hx
      have h_sum : ∑ y in A i, ((univ.filter (fun k => y ∈ A k)).card - 1) = 2 * n := by
        trans ∑ k in univ.erase i, (A i ∩ A k).card
        · rw [sum_erase_eq_sub, ← sum_comm]
          simp only [card_inter_eq_sum_ones, sum_boole]
          congr 1; refine sum_congr rfl fun y hy => ?_
          have : 1 ≤ (univ.filter (fun k => y ∈ A k)).card :=
             card_pos.2 ⟨i, mem_filter.2 ⟨mem_univ _, hy⟩⟩
          rw [tsub_eq_sum_filter_nat_of_le this]; rfl
        · simp only [hinter _ _ (ne_of_mem_erase ·).2, sum_const, card_erase_of_mem (mem_univ i),
            card_univ, cast_sub, cast_add, cast_one, cast_mul, Nat.cast_two]
          ring
