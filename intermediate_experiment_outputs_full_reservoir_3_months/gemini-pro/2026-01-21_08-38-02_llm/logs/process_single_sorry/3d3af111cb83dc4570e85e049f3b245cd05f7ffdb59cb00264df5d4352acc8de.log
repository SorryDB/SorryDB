lemma IsMatching.inter_encard_eq_of_isCycleGraph_isCompOf_symmDiff (hM : G.IsMatching M)
    (hM' : G.IsMatching M') (hC : C.IsCycleGraph) (hCG : C.IsCompOf (hM.restrict₂ hM')) :
    (E(C) ∩ M).encard = (E(C) ∩ M').encard := by
  let E₁ := E(C) ∩ M
  let E₂ := E(C) ∩ M'
  have h_disj : Disjoint E₁ E₂ := hM.disjoint_inter_of_isCycleGraph_symmDiff hM' hC hCG

  have h_union : E(C) = E₁ ∪ E₂ := by
    refine Subset.antisymm (λ e he ↦ ?_) (union_subset (inter_subset_left _ _) (inter_subset_left _ _))
