def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep S := ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := ⟨∅, by simp [isMatching_iff], empty_subset _⟩
  indep_subset := fun ⟨M, hM, hS⟩ hT ↦ ⟨M, hM, hT.trans hS⟩
  indep_aug := by
    rintro I B ⟨MI, hMI, hI⟩ hInotmax hBmax
    obtain ⟨MB, hMB, hBsub⟩ := hBmax.exists
    have hB : B = V(G, MB) := hBmax.eq_of_le ⟨MB, hMB, Subset.rfl⟩ hBsub
    subst hB
    -- Extend MI to a max matching MI' covering I
    have ⟨MI', hMI', hI_sub⟩ : ∃ MI', G.IsMaxMatching MI' ∧ I ⊆ V(G, MI') := sorry
    -- I is a proper subset of V(MI')
    have ⟨y, hyMI', hyI⟩ : ∃ y ∈ V(G, MI'), y ∉ I := sorry
    by_cases hyB : y ∈ V(G, MB)
    · exact ⟨y, ⟨hyB, hyI⟩, MI', hMI'.toIsMatching, insert_subset hyMI' hI_sub⟩
    -- Exchange y with x ∈ B using symmetric difference path
    · have : ∃ x ∈ V(G, MB) \ V(G, MI'), ∃ M', G.IsMatching M' ∧ V(G, M') = (V(G, MI') \ {y}) ∪ {x} := sorry
      obtain ⟨x, ⟨hxB, hxMI'⟩, M', hM', hV⟩ := this
      refine ⟨x, ⟨hxB, fun hxI ↦ hxMI' (hI_sub hxI)⟩, M', hM', ?_⟩
      rw [hV, insert_subset_iff]
      exact ⟨Or.inr rfl, subset_union_left _ _ |>.trans_supererset (subset_diff.mpr ⟨hI_sub, disjoint_singleton_right.mpr hyI⟩)⟩
```
