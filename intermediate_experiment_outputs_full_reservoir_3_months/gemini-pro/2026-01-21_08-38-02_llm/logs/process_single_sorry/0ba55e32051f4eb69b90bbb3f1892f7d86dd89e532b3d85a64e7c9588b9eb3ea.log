      -- Sperner condition implies c(up x) ≠ last since (up x) last = 0
      exact fun h => hc (by sorry) (by simp [up]) h
    )

    -- 3. Apply induction hypothesis to S'
    have h_odd : Odd {s ∈ S'.faces | IsPanchromatic c' s}.ncard :=
