def bits2num {w:ℕ} (bits : Vector (ZMod p) w) : (ZMod p) :=
  Vector.foldl (fun acc b => b + 2 * acc) 0 bits

lemma bits_good {w : ℕ} {args : Vector (ZMod p) w} :
    assert_bits args → (bits2num args).val < 2 ^ w := by
  rcases args with ⟨l, rfl⟩
  unfold bits2num assert_bits
  simp only [Vector.foldl, Vector.all, Vector.toArray_mk, Vector.toArray_val, List.foldl_toArray, List.all_eq_true]
  intro h
  let v_nat := l.foldl (fun acc b => b.val + 2 * acc) 0
  have h_eq : (l.foldl (fun acc b => b + 2 * acc) 0).val = v_nat % p := by
    have : ∀ acc : ℕ, (l.foldl (fun acc b => b + 2 * acc) acc).val = (l.foldl (fun acc b => b.val + 2 * acc) acc) % p := by
      intro acc
      induction l generalizing acc with
      | nil => simp [ZMod.val_nat_cast]
      | cons b l ih =>
        simp only [List.foldl_cons, ZMod.val_nat_cast]
        rw [ih]
        congr
        simp [Nat.cast_add, Nat.cast_mul, Nat.cast_two]
    apply this
  have h_bound : v_nat < 2 ^ w := by
    have : ∀ acc, l.foldl (fun acc b => b.val + 2 * acc) acc < 2 ^ l.length * (acc + 1) := by
      intro acc
      induction l generalizing acc with
      | nil => simp
      | cons b l ih =>
        simp only [List.all_cons, Bool.and_eq_true, beq_iff_eq, Bool.or_eq_true, decide_eq_true_eq] at h
        obtain ⟨hb, h'⟩ := h
        simp only [List.length_cons, List.foldl_cons]
        rw [pow_succ, mul_assoc]
        apply lt_of_lt_of_le (ih h' (b.val + 2 * acc))
        apply Nat.mul_le_mul_left
        cases hb <;> simp [*, add_assoc]
    specialize this 0
    simpa using this
  rw [h_eq]
  exact lt_of_le_of_lt (Nat.mod_le _ _) h_bound
