lemma bits_good (w : ℕ) (e : Exp (ZMod p) (ZMod p)) :
  e.eval.val < 2 ^ w → ∃ args : Vector (ZMod p) w, assert_bits args ∧ e.eval = bits2num args := by
  intro h
  induction w generalizing e with
  | zero =>
    exists #[]
    simp [assert_bits, bits2num]
    apply ZMod.val_eq_zero
    linarith [e.eval.val_lt, h]
  | succ w ih =>
    let val := e.eval.val
    let bit := val / 2^w
    let rem := val % 2^w
    have h_bit : bit < 2 := by
      rw [pow_succ', mul_comm] at h
      exact Nat.div_lt_of_lt_mul h
    have h_rem : rem < 2^w := Nat.mod_lt _ (pow_pos (by linarith) _)
    specialize ih (.c rem) h_rem
    rcases ih with ⟨args, h_bits, h_val⟩
    exists Vector.cons bit args
    constructor
    · simp [assert_bits, Vector.all_cons, h_bits]
      match bit, h_bit with
      | 0, _ => simp
      | 1, _ => simp; right; rfl
      | n+2, h_lt => contradiction
    · rw [bits2num, Vector.foldl_cons]
      have fold_shift : ∀ (v : ZMod p) (xs : Vector (ZMod p) w),
        Vector.foldl (fun acc b => b + 2 * acc) v xs =
        Vector.foldl (fun acc b => b + 2 * acc) 0 xs + v * (2^w : ℕ) := by
          intro v xs
          induction xs using Vector.inductionOn generalizing v
          · simp [Vector.foldl_nil]
          · rename_i x xs ih
            simp [Vector.foldl_cons, ih]
            simp [pow_succ, mul_assoc, add_mul]
