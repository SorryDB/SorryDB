  e.eval.val < 2 ^ w -> ∃ args : Vector (ZMod p) w, assert_bits args ∧ e.eval = bits2num args := by
  intro w e h
  induction w generalizing e with
  | zero =>
    exists Vector.nil
    simp [assert_bits, bits2num, Vector.foldl]
    apply ZMod.val_injective
    simp only [ZMod.val_zero]
    exact Nat.eq_zero_of_le_zero (Nat.le_of_lt_succ h)
  | succ w ih =>
    let v := e.eval.val
    let b_nat := v / 2^w
    let rem_nat := v % 2^w
    let b : ZMod p := b_nat
    let rem : ZMod p := rem_nat
    have h_v_lt : v < 2 * 2^w := by rw [pow_succ'] at h; exact h
    have h_b_lt : b_nat < 2 := Nat.div_lt_of_lt_mul h_v_lt
    have h_rem_lt : rem_nat < 2^w := Nat.mod_lt _ (pow_pos (by decide) _)
    have h_rem_val : rem.val = rem_nat := by
      apply ZMod.val_cast_of_lt
      apply Nat.lt_trans h_rem_lt
      apply Nat.lt_trans h (ZMod.val_lt e.eval)
    obtain ⟨tl, h_bits, h_val⟩ := ih (.c rem) (by rw [Exp.eval, Exp.eval, h_rem_val]; exact h_rem_lt)
    exists Vector.cons b tl
    constructor
    · simp [assert_bits, Vector.all_cons, h_bits]
      match b_nat, h_b_lt with
      | 0, _ => left; simp
      | 1, _ => right; simp
    · rw [h_val]
      let f := fun (acc : ZMod p) (b : ZMod p) => b + 2 * acc
      have prop : ∀ (acc : ZMod p) (xs : Vector (ZMod p) w),
        Vector.foldl f acc xs = Vector.foldl f 0 xs + acc * (2^w : ℕ) := by
        intro acc xs
        induction xs using Vector.inductionOn generalizing acc
        · simp [Vector.foldl]
        · rename_i x xs ih
          simp [Vector.foldl, ih]
          ring
      simp [bits2num, Vector.foldl, prop b tl, Exp.eval]
      have : (v : ZMod p) = rem + b * (2^w : ℕ) := by
        have : v = rem_nat + b_nat * 2^w := (Nat.mod_add_div v (2^w)).symm
        rw [this, Nat.cast_add, Nat.cast_mul]
        rfl
      rw [←this]
