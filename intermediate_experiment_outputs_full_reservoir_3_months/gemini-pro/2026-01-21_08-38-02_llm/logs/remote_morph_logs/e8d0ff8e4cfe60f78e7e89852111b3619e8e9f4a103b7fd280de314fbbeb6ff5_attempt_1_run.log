    have h_all : args.toList.all (fun x => x == 0 ∨ x == 1) := by
      rw [assert_bits, Vector.all_iff_forall, List.all_iff_forall] at h_bits
      intros x hx
      specialize h_bits x (Vector.mem_iff_mem_toList.mpr hx)
