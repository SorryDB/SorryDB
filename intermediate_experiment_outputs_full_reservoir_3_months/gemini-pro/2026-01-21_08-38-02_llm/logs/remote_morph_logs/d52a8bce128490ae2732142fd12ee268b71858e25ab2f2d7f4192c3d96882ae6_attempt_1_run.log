/-- Theorem 6.21: If Builder has a winning strategy then there is a model graph. -/
theorem strmg (X : Sequent) (s : Strategy tableauGame Builder) (h : winning s (startPos X)) :
    ∃ (WS : Finset (Finset Formula)) (mg : ModelGraph WS), ∃ Z ∈ WS, X.toFinset ⊆ Z := by
  let bt := buildTree s h
  let WS := bt.toModel.1
  let M := bt.toModel.2
  refine ⟨WS, ⟨M, ⟨?a, ?b, ?c, ?d⟩⟩, ?X_in⟩
  -- show the model graph properties
  case a =>
    rintro ⟨X, X_in⟩
    unfold WS at X_in
    simp at X_in
    rcases X_in with ⟨π, in_all, def_X⟩
    have := PreState.locConsSatBas π-- using Lemma 6.16 for (i)
    simp_all
  -- "(b, c) will follow immediately from the definition"
  case b =>
    simp_all [M]
  case c =>
    intro X Y a φ X_a_Y aφ_in_X -- pick any ⌈a⌉φ
    simp only [M] at X_a_Y
    rcases X_a_Y with ⟨ψ, in_X, sub_Y⟩ -- relation was witnessed by ⌈a⌉ψ
    apply sub_Y -- show that φ is in projection
    simp_all
  case d =>
    intro w w_in α φ in_w
    unfold WS at w_in
    simp at w_in
    rcases w_in with ⟨π, _, rfl⟩
    -- Lemma 6.20: diamond existence for pre-states
    have exists_diam : ∃ (τ : PreState bt),
        Modelgraphs.Q M.Rel α
          ⟨π.forms.toFinset, by unfold WS; simp; use π, bt.allPreStates_spec π⟩
          ⟨τ.forms.toFinset, by unfold WS; simp; use τ, bt.allPreStates_spec τ⟩
        ∧ (~φ) ∈ τ.forms := sorry
    rcases exists_diam with ⟨τ, hQ, in_τ⟩
    use τ.forms.toFinset
    constructor
    · unfold WS; simp; use τ, bt.allPreStates_spec τ
    · exact ⟨hQ, in_τ⟩
  case X_in =>
    unfold WS
    simp
    -- Existence of a root pre-state containing X
    sorry
