    -- Right side: length final + length mid
    -- final = filter F S. mid = filter (¬I ∧ ¬F) S.
    -- filter ¬I S is partitioned by F into (¬I ∧ F) and (¬I ∧ ¬F).
    let notI := S.filter (fun c => ¬isInitialCall m S c)
