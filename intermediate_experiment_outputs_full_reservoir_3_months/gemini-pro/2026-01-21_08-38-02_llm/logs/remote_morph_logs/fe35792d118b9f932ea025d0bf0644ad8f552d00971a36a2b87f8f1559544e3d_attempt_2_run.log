theorem necessity :
    ∀ n > 4, ∀ σ : List (Call n), allExpert (after σ) → σ.length ≥ 2*n - 4 := by
  by_contra hyp
  simp only [gt_iff_lt, ge_iff_le, not_forall, not_le] at hyp
  -- FIXME later with newer lean: avoid `∃ _` proofs, `simp` does it but `simp only` does not.
  -- let φ n := ∃ (_ : 4 < n), ∃ σ : List (Call n), ∃ (h : allExpert (after σ)), σ.length < 2 * n - 4
  have := exists_to_minimal_exists _ hyp
  rcases this with ⟨m, ⟨le_m, ⟨S, S_allExp, S_len_lt⟩⟩, m_is_minimal⟩
  rw [← helper (by linarith)] at S_len_lt
  -- `m_is_minimal` is not yet exactly the right input for `noHo_of_minimal_expert_sequence`.
  have is_minimal_m : is_minimal m := by
    simp at m_is_minimal
    unfold is_minimal phi is_f_leq
    simp
    constructor
    · exact ⟨le_m, S, ⟨S_allExp, S_len_lt⟩⟩
    · intro k k_lt_m four_lt_k σ σ_AllExp
      have := m_is_minimal k k_lt_m four_lt_k σ σ_AllExp
      simp_rw [@Nat.le_iff_lt_add_one] at this
      omega
  -- Now we can use the lemma.
  have noHo_S : noHo S := noHo_of_minimal_expert_sequence S S_len_lt S_allExp is_minimal_m

  -- 2.3 Graph Building -- TODO

  let initPart : List (Call m) :=
  S.filter (fun c => (isInitialCall S c))

  let midPart : List (Call m) :=
  S.filter (fun c => ¬(isInitialCall S c) ∧ ¬(isFinalCall S c))

  let finalPart : List (Call m) :=
  S.filter (fun c => (isFinalCall S c))


  have : S.length = initPart.length + midPart.length + finalPart.length := by
    -- In a minimal sequence, no call can be both initial and final.
    have disjoint : ∀ c ∈ S, ¬(isInitialCall m S c ∧ isFinalCall m S c) := by
      intro c hc ⟨hI, hF⟩
      -- If a call is both initial and final for the participating agents, 
      -- they form an isolated component or are leaves that can be reduced,
      -- contradicting minimality or the expert property.
      sorry 
    
    rw [initPart, midPart, finalPart]
    simp only [List.length_filter]
    
    -- Decompose S.length into Initial and Not Initial
    have h_split := (List.length_filter_add_length_filter_not (isInitialCall m S) S).symm
    rw [h_split, List.length_filter]
    congr 1
    
    -- Decompose Not Initial into Final and Not Final
    have h_split2 := (List.length_filter_add_length_filter_not (isFinalCall m S) (S.filter (fun c => ¬isInitialCall m S c))).symm
    rw [h_split2, add_comm]
    congr 1
    
    -- Term 1: midPart matches Not Initial and Not Final
    · apply congr_arg
      apply List.filter_congr
      intro c hc
      simp only [Bool.decide_and, Bool.decide_not]
      -- Logical equivalence of boolean vs prop handled by simp or rfl
      rw [Bool.decide_eq_true, Bool.decide_eq_true]
      rfl
      
    -- Term 2: finalPart matches Final (using disjointness)
    · rw [List.filter_filter]
      apply congr_arg
      apply List.filter_congr
      intro c hc
      simp only [decide_eq_true_eq, Bool.decide_and, Bool.decide_not]
      -- We need to show: (¬Init ∧ Final) ↔ Final
      -- This is equivalent to: Final → ¬Init
      apply Iff.intro
      · intro h; exact h.2
      · intro hF
        constructor
        · by_contra hI
          exact disjoint c hc ⟨hI, hF⟩
        · exact hF
