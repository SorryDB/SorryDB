theorem bound_binomial_coeff {k n : ℕ} :
  Nat.choose n k ≤ n ^ k / (k.factorial : ℚ)∧
  n ^ k / (k.factorial : ℚ) ≤ n ^ k / 2 ^ (k - 1) := by
  constructor
  · rw [le_div_iff (by exact_mod_cast k.factorial_pos), ← Nat.cast_mul, mul_comm,
      ← Nat.descFactorial_eq_factorial_mul_choose]
    exact_mod_cast n.descFactorial_le_pow k
  · by_cases h : n = 0
    · simp [h]; cases k <;> simp
