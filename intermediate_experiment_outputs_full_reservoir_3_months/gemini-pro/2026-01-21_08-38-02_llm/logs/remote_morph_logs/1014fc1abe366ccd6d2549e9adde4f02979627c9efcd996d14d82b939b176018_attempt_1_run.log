instance [Fintype ι] [(i : ι) → TopologicalSpace (Y i)] [(i : ι) → LocallyCompactSpace (Y i)]
    [(i : ι) → DTopCompatible (Y i)] : DTopCompatible ((i : ι) → Y i) := ⟨by
  let n := Fintype.card ι
  let e : ι ≃ Fin n := Fintype.equivFin ι
  let Y' : Fin n → Type _ := fun k ↦ Y (e.symm k)
  have : DTopCompatible ((k : Fin n) → Y' k) := by
    induction n with
    | zero =>
      constructor
      have : Subsingleton ((k : Fin 0) → Y' k) := ⟨fun f g ↦ funext (finZeroElim)⟩
      exact Subsingleton.elim _ _
    | succ n IH =>
      let Y'' : Fin n → Type _ := fun k ↦ Y' k.cast_succ
      let e' : ((k : Fin (n + 1)) → Y' k) ≃ Y' 0 × ((k : Fin n) → Y'' k) :=
        Equiv.piFinSuccAbove 0 Y'
      have h_ind : IsDInducing e' := ⟨rfl⟩
      have h_top_eq : DTop = e'.induced (@instTopologicalSpaceProd _ _ DTop DTop) := by
        let _ : DTopCompatible ((k : Fin n) → Y'' k) := IH
        rw [dTop_prod_eq_prod_dTop_of_locallyCompact_left]
