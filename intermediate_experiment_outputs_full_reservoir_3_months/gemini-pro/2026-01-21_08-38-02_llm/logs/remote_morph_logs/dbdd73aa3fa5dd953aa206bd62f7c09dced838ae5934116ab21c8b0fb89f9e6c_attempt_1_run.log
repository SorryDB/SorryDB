def toResolutionOfIdentity : ResolutionOfIdentity (spectrum ℂ a) H where
  measureOf' s := InnerProductSpace.continuousLinearMapOfBilin
    (@toBoundedBilin _ _ _ _ _ ha 1 (Set.indicator s (1 : (spectrum ℂ a) → ℂ)))
  isOrthogonalProjection' := sorry
  empty' := by
    ext
    simp [continuousLinearMapOfBilin, toBoundedBilin, cfc_toComplexMeasure, ComplexMeasure.integral]
    rfl
  not_measurable' := sorry
  m_Union' := sorry
  m_Inter' := sorry
  m_iUnion' := fun x y w hw_meas hw_disj ↦ by
    simp only [InnerProductSpace.continuousLinearMapOfBilin_apply, toBoundedBilin]
    convert (cfc_toComplexMeasure ha x y).hasSum_measure hw_disj hw_meas using 1
    · ext i; rw [ComplexMeasure.integral_indicator (hw_meas i)]
    · rw [ComplexMeasure.integral_indicator (MeasurableSet.iUnion hw_meas)]
```
