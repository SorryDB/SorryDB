    · exact p₂.bijective
    · intro i; use (hp₂ i).2.1; exact (hp₂ i).2.2
  -- Uniqueness of Hamiltonian cycles in a cycle graph
  obtain ⟨i, h | h⟩ := SimpleGraph.IsCycle.exists_unique_hamiltonian h_is_cycle h_ham1 h_ham2
  · left; use i; exact h
  · right; use i; exact h
