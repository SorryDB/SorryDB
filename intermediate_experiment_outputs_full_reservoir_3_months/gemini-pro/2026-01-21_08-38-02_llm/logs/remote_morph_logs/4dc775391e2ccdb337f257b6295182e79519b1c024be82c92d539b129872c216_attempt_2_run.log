    refine le_trans (Finset.card_le_card this) (le_trans (Finset.card_image_le.trans (le_of_eq rfl)) ?_)
    exact (Polynomial.card_roots' (Polynomial.X^2 + Polynomial.X + Polynomial.C (k : ZMod q))).trans (by norm_num)
