    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  let n := #S
  have hn : n = S.card := rfl
  -- Define adjacency
  let Adj (a b : ℕ) : Prop := ∃ x : ℕ, 0 < x ∧ a * b = x ^ 2 + x + k
  have adj_comm : ∀ a b, Adj a b → Adj b a := by
    intros a b h; rcases h with ⟨x, hx, heq⟩; exact ⟨x, hx, by rw [mul_comm, heq]⟩

  -- Key Lemma: At most 2 smaller neighbors
  have smaller_neighbors_le_two : ∀ p ∈ S, ({q ∈ S | q < p ∧ Adj p q}).card ≤ 2 := by
    intro p hp
    let roots := (Polynomial.X ^ 2 + Polynomial.X + (k : ZMod p)).roots
    have roots_card : roots.card ≤ 2 := Polynomial.card_roots_le_degree (by
      have : Nat.Prime p := (hS p hp).2
      simp [Polynomial.degree_X_pow_add_X_add_C, this.ne_zero])
    let f (q : ℕ) : ℕ := ((p * q - k).sqrt)
    let T := {q ∈ S | q < p ∧ Adj p q}
    have inj : T.injOn f roots.toFinset := by
      intros q1 h1 q2 h2 heq
      simp only [T, Finset.mem_filter] at h1 h2
      rcases h1.2.2 with ⟨x1, hx1, heq1⟩
      rcases h2.2.2 with ⟨x2, hx2, heq2⟩
      dsimp [f] at heq
      have eq_x : x1 = x2 := by
        have s1 : x1 * (x1 + 1) = p * q1 - k := by rw [←heq1]; exact Nat.add_sub_cancel _ _
        have s2 : x2 * (x2 + 1) = p * q2 - k := by rw [←heq2]; exact Nat.add_sub_cancel _ _
        -- x^2 ≈ p*q. q < p => x < p.
        have ub1 : x1 < p := by
          by_contra! contra
          have : p * p ≤ x1 * x1 := Nat.mul_le_mul contra contra
          have : x1 * x1 < x1 * x1 + x1 + k := by linarith
          rw [←heq1] at this
          have : p * q1 < p * p := Nat.mul_lt_mul_of_pos_left h1.2.1 (hS p hp).2.pos
          linarith
        have ub2 : x2 < p := by -- Symmetric argument
          by_contra! contra
          have : p * p ≤ x2 * x2 := Nat.mul_le_mul contra contra
          have : x2 * x2 < x2 * x2 + x2 + k := by linarith
          rw [←heq2] at this
          have : p * q2 < p * p := Nat.mul_lt_mul_of_pos_left h2.2.1 (hS p hp).2.pos
          linarith
        -- x = floor(sqrt(pq-k)).
        rw [←s1, ←s2] at heq
        have sq1 : (x1 * (x1+1)).sqrt = x1 := by
           apply Nat.sqrt_eq
           constructor
           · exact Nat.le_add_right _ _
           · rw [mul_add, mul_one, add_assoc]; nlinarith
        have sq2 : (x2 * (x2+1)).sqrt = x2 := by
           apply Nat.sqrt_eq; constructor; exact Nat.le_add_right _ _; rw [mul_add, mul_one, add_assoc]; nlinarith
        rw [sq1, sq2] at heq
        exact heq
      rw [←(mul_left_cancel_iff_of_pos (hS p hp).2.pos), eq_x] at heq1 heq2
      linarith [heq1, heq2]
    
    have map_mem : ∀ q ∈ T, f q ∈ roots.toFinset := by
      intro q hq
      simp only [T, Finset.mem_filter] at hq
      rcases hq.2.2 with ⟨x, hx, heq_adj⟩
      dsimp [f]
      have eq_x : (p * q - k).sqrt = x := by
         have : p * q - k = x * (x + 1) := by rw [←heq_adj]; exact Nat.add_sub_cancel _ _
         rw [this]
         apply Nat.sqrt_eq; constructor; exact Nat.le_add_right _ _; rw [mul_add, mul_one, add_assoc]; nlinarith
      rw [eq_x]
