import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  -- We define the simple graph of valid adjacencies on S.
  let G : SimpleGraph S := {
    adj := fun u v ↦ u ≠ v ∧ ∃ x > 0, (u : ℕ) * v = x ^ 2 + x + k,
    symm := fun u v ⟨huv, x, hx, h⟩ ↦ ⟨huv.symm, x, hx, by rwa [mul_comm]⟩,
    loopless := fun u ⟨hu, _⟩ ↦ hu rfl
  }
  -- The conditions imply p₁ and p₂ form Hamiltonian cycles in G.
  have h_ham (p : Fin #S ≃ S) (hp : Condition k S p) : G.IsHamiltonianCycle (fun i ↦ p i) := by
    rw [SimpleGraph.isHamiltonianCycle_iff]
    constructor
    · intro i
      have : NeZero #S := ⟨i.pos.ne'⟩
      obtain ⟨x, hx, h⟩ := hp i
      use ⟨p.injective.ne (Fin.ne_of_val_ne (ne_of_eq_of_ne (Fin.val_add_one i) (Fin.ne_of_lt (Fin.val_lt_last i)).symm)), x, hx, h⟩
    · exact p.surjective
  -- The graph G on a set of odd primes with this condition has a unique Hamiltonian cycle.
  -- This follows from the fact that for the largest prime m in S, its neighbors are uniquely determined 
  -- by the roots of t^2 + t + k = 0 mod m, and this rigidity propagates (the "descent" argument).
  have h_unique : ∃! c : Cycle S, c ∈ G.hamiltonianCycles := by
    sorry -- The uniqueness proof involves detailed number theory and graph theory.
  
  -- Since the cycle is unique, p₁ and p₂ must define the same cycle (up to direction).
  obtain ⟨c, hc_mem, hc_unique⟩ := h_unique
  have hp₁_c : (Cycle.form (fun i ↦ p₁ i) (by simp)) ∈ G.hamiltonianCycles := by
    rw [SimpleGraph.mem_hamiltonianCycles_iff]; exact h_ham p₁ hp₁
  have hp₂_c : (Cycle.form (fun i ↦ p₂ i) (by simp)) ∈ G.hamiltonianCycles := by
    rw [SimpleGraph.mem_hamiltonianCycles_iff]; exact h_ham p₂ hp₂
  
  have h_eq : Cycle.form (fun i ↦ p₁ i) (by simp) = Cycle.form (fun i ↦ p₂ i) (by simp) := by
    rw [hc_unique _ hp₁_c, hc_unique _ hp₂_c]
  
  -- Cycle equality implies p₂ is a rotation or reflection of p₁.
  rw [Cycle.form_eq_form] at h_eq
  rcases h_eq with ⟨i, h⟩ | ⟨i, h⟩
  · left; use i; intro j; exact h j
  · right; use i; intro j; exact h j
