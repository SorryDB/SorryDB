        have : ∃ x, S = {x} := card_eq_one.mp hn
        rcases this with ⟨x, rfl⟩
        use 0; intro j; simp; apply Subsingleton.elim
      · have : n = 2 := by linarith
        have : Fintype.card (Fin 2) = 2 := by simp
        -- For size 2, only 2 permutations: identity and swap. Swap is reversal.
