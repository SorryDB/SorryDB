    cases v_eq with
    | inl h => right; apply p₁.injective; rw [h]; simp
    | inr h => left; apply p₁.injective; rw [h]; simp

  -- r is an automorphism of C_n, i.e., in D_n
  -- This implies r is a rotation or reflection
  sorry
