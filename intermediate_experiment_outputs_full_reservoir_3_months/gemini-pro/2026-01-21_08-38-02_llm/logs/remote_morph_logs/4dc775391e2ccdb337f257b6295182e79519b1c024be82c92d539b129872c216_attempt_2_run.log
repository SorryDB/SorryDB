  -- If the set of edges is the same for two cycles on the same vertices,
  -- they are the same up to rotation and reflection.
  have h_cycle_eq : (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
    -- Graph isomorphism for cycles determined by edge sets
    sorry

