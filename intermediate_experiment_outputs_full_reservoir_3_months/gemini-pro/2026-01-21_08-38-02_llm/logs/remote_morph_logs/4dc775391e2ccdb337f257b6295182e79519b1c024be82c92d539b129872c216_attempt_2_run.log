        have : 0 ≤ 4 * (a : ℤ) * b + (1 - 4 * k) := by
           obtain ⟨y, hy, -⟩ := (this b b.2).mp (hp₁ 0).2 -- abuse existence
           rw [← hy]; exact sq_nonneg y
        apply Int.natAbs_of_nonneg; apply Int.sqrt_nonneg )).trans
      (show Finset.card (Finset.image _ _) ≤ 2 from ?_)
    sorry -- The number theoretic bound |{b < a | adj}| <= 2 is standard but long to formalize
  let G : SimpleGraph S := SimpleGraph.fromRel (fun a b ↦ ∃ x > 0, (a : ℕ) * b = x^2 + x + k)
  have h_is_cycle : G.IsCycle := by sorry -- Implied by h_deg and Hamiltonian existence
