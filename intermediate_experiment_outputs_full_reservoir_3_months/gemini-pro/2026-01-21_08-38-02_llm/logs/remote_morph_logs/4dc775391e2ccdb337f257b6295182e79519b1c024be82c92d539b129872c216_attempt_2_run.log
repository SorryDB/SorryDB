      (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
    intro h
    -- Standard graph theory result: A simple cycle is determined by its edges up to symmetry.
    sorry

  exact implies_geometry edges_eq
