  have h_deg : ∀ q ∈ S, ({p ∈ S | p < q ∧ adj p q}).card ≤ 2 := fun q hq => by
    let s := {p ∈ S | p < q ∧ adj p q}
    have : s ⊆ (Finset.range q).filter (fun p => ∃ x < q, (x^2 + x + k) % q = 0 ∧ p = (x^2 + x + k) / q) := by
      intro p hp; rw [Finset.mem_filter] at hp; rcases hp with ⟨_, hpq, x, _, heq⟩
