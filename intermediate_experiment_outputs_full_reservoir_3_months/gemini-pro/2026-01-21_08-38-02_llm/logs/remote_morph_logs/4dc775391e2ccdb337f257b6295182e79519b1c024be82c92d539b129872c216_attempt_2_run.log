  -- Lemma: For any p ∈ S, there are at most 2 neighbors q ∈ S with q < p.
  have neighbors_bound : ∀ p ∈ S, ({q ∈ S | q < p ∧ IsEdge p q}).card ≤ 2 := by
    intro p hp
