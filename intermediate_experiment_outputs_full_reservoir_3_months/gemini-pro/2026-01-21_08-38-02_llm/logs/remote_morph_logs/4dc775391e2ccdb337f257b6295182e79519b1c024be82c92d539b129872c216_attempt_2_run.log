      use u; simp; refine ⟨(h_edges p₁ hp₁ ⟨u, v⟩ (by aesop)).1, ⟨u, v⟩, h, by simp⟩
    
    let m := Affected.max' h_aff_ne
    have hm : m ∈ Affected := Finset.max'_mem _ _

    -- Neighbors of m in E1 and E2
    let N (E : Finset (ℕ × ℕ)) (v : ℕ) := {u ∈ S | (if u < v then (u, v) else (v, u)) ∈ E}
    have degree_is_two (p : Fin #S ≃ S) (v : ℕ) (hv : v ∈ S) : (N (edges p) v).card = 2 := by
      -- p forms a cycle, so degree is 2
      sorry
    
    have neighbors_diff : N E₁ m ≠ N E₂ m := by
      -- If neighbors are same, edges incident to m are same, m not in Affected
      sorry

    have common_large : ∀ u ∈ S, m < u → u ∈ N E₁ m ↔ u ∈ N E₂ m := by
      intro u hu hmu
      have : u ∉ Affected := by
        by_contra h
        exact (Finset.le_max' _ _ h).not_lt hmu
      -- Logic: if u not affected, edges incident to u are same
      sorry
    
    -- Count neighbors
    let L := {u ∈ S | m < u}
    let Sm := {u ∈ S | u < m} -- candidates
    let C := {b ∈ Sm | ∃ x > 0, b * m = x^2 + x + k}
    have hC : C.card ≤ 2 := max_le_2 m (by aesop)

    let N1 := N E₁ m
    let N2 := N E₂ m
    let k := (N1 ∩ L).card
    have h_k_eq : (N2 ∩ L).card = k := by sorry -- from common_large

    have h_small1 : (N1 ∩ Sm).card = 2 - k := by sorry -- total degree 2
    have h_small2 : (N2 ∩ Sm).card = 2 - k := by sorry
    
    have h_sub1 : N1 ∩ Sm ⊆ C := by sorry
    have h_sub2 : N2 ∩ Sm ⊆ C := by sorry

    have contra : False := by
