  have h_adj : p₂ (k + 1) = p₁ 1 ∨ p₂ (k + 1) = p₁ (Fin.last _) := by
    have : {p₂ k, p₂ (k + 1)} ∈ E₁ := h_edges ▸ (by simp; use k)
