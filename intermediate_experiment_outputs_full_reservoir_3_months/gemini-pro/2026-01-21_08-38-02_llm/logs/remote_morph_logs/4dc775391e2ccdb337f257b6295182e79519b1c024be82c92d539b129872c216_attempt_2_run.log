import Mathlib


open scoped Finset

namespace IMO2022P3

/-- The condition of the problem on a placement of numbers round a circle. -/
def Condition (k : ℕ) (S : Finset ℕ) (p : Fin #S ≃ S) : Prop :=
  ∀ i, have : NeZero #S := ⟨i.pos.ne'⟩
  ∃ x : ℕ, 0 < x ∧ ((p i : ℕ) * (p (i + 1) : ℕ)) = x ^ 2 + x + k

theorem result {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  rcases Nat.even_or_odd k with hk_even | hk_odd
  · exfalso
    cases' (Finset.card_eq_zero.or_nonempty S) with hS0 hSne
    · have : IsEmpty (Fin #S) := by simp [hS0]
      exact (this.false 0).elim
    · let i : Fin #S := ⟨0, (Finset.card_pos.mpr hSne)⟩
      have h1 := hp₁ i
      rcases h1 with ⟨x, _, heq⟩
      have h_odd : Odd ((p₁ i : ℕ) * (p₁ (i + 1) : ℕ)) :=
        Nat.odd_mul.mpr ⟨(hS _ (p₁ i).2).1, (hS _ (p₁ (i + 1)).2).1⟩
      rw [heq, ← Nat.mul_succ x] at h_odd
      exact Nat.odd_iff_not_even.mp h_odd (Nat.Even.add (Nat.even_mul_self_pred x).symm hk_even)
  · sorry
