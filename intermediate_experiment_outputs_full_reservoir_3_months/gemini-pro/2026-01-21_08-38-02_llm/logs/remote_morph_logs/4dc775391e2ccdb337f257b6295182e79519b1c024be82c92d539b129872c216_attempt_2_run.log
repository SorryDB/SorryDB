    have : ∀ b ∈ S, ∃ x > 0, (a : ℕ) * b = x^2 + x + k ↔ ∃ y : ℤ, y^2 = 4 * (a : ℤ) * b + D ∧ y ≡ 1 [ZMOD 2] := by
      intro b hb; constructor
