    rw [SimpleGraph.isHamiltonianCycle_iff]; constructor
    · exact p₁.bijective
    · intro i; use (hp₁ i).2.1; exact (hp₁ i).2.2
  have h_ham2 : G.IsHamiltonianCycle (fun i ↦ p₂ i) := by
