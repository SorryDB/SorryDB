      intro i j h
      simp at h
      exact h⟩

  -- The edges of p1 and p2 must be the same subset of valid edges
  have h_edges_eq : edges p₁ = edges p₂ := by
    -- We prove by induction on the elements of S (ordered by size) that the incident edges are fixed.
