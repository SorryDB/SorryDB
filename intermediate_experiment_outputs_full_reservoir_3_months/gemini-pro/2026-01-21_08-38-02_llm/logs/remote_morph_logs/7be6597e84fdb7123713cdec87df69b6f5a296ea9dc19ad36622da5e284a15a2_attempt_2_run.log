lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  induction v using Submodule.Quotient.inductionOn
  rename_i v
  induction v using DirectSum.induction_on
  case zero => exact ⟨0, map_zero _⟩
  case atom p w =>
    -- Since X has the fine diffeology, the plot p locally factors through a linear map
    obtain ⟨n, L, f, hf, hf₀, rfl⟩ := IsFineDiffeology.fine x p
    use L (fderiv ℝ f 0 w)
    -- We show that lof p w equals the tangent vector of the line in direction L (Df 0 w)
    rw [vectorSpaceToInternalTangentSpace, InternalTangentSpace.lof_comp p hf hf₀]
    let pL : pointedPlots x := ⟨⟨n, fun u ↦ x + L u⟩, ((dsmooth_add_left x).comp L.dsmooth).isPlot, by simp⟩
    let l : Eucl 1 → Eucl n := fun t ↦ t 0 • fderiv ℝ f 0 w
    have hl : ContDiff ℝ ∞ l := (LinearMap.toSpanSingleton _ _ _).continuousLinearMap.contDiff
    have hl₀ : l 0 = 0 := by simp [l]
    refine Eq.trans ?_ (InternalTangentSpace.lof_comp pL hl hl₀).symm
    congr 1
    · ext t; simp [pL, l]
    · simp only [l, LinearMap.toSpanSingleton_apply, ContinuousLinearMap.coe_coe]
      rw [ContinuousLinearMap.fderiv, LinearMap.toSpanSingleton_apply]
      simp
  case plus v₁ v₂ h₁ h₂ =>
    obtain ⟨x₁, rfl⟩ := h₁
    obtain ⟨x₂, rfl⟩ := h₂
    use x₁ + x₂
    simp
