  induction v using DirectSum.induction_on
  · exact ⟨0, map_zero _⟩
  · intro p v
    obtain ⟨k, L, g, hg, rfl⟩ := IsFineDiffeology.exists_linear_factor p.2.1
    let q : pointedPlots x := ⟨⟨k, fun y ↦ L (y + g 0)⟩,
      (LinearMap.dsmooth L).comp (dsmooth_id.add dsmooth_const) |>.isPlot, by simp [p.2.2]⟩
    let h : Eucl p.1.1 → Eucl k := fun u ↦ g u - g 0
    have hh : ContDiff ℝ ∞ h := hg.contDiff.sub contDiff_const
    rw [InternalTangentSpace.lof_comp q hh (sub_self _)]
    refine ⟨L (fderiv ℝ g 0 v), ?_⟩
    let l : Eucl 1 →L[ℝ] Eucl k := LinearMap.toContinuousLinearMap (LinearMap.lsmul ℝ _ (fderiv ℝ g 0 v))
    rw [vectorSpaceToInternalTangentSpace, ← InternalTangentSpace.lof_comp_apply q l.contDiff (map_zero _) (.single 0 1)]
    congr 2; ext t
    simp only [q, h, l, Function.comp_apply, LinearMap.lsmul_apply,
      LinearMap.coe_toContinuousLinearMap, smul_eq_mul, mul_comm, map_add, map_smul]
