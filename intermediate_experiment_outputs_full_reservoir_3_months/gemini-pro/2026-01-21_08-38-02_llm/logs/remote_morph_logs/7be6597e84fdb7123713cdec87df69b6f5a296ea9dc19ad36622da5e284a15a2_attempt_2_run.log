lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  induction v using Submodule.Quotient.inductionOn with | h v => ?_
  induction v using DirectSum.induction_on with
  | zero => exact ⟨0, map_zero _⟩
  | plus v₁ v₂ h₁ h₂ =>
    obtain ⟨w₁, rfl⟩ := h₁
    obtain ⟨w₂, rfl⟩ := h₂
    exact ⟨w₁ + w₂, map_add _ _ _⟩
  | lof p u =>
    use fderiv ℝ p.1.2 0 u
    -- We reduce to a curve by precomposing with the linear map t ↦ t • u
    let f : Eucl 1 → Eucl p.1.1 := fun t ↦ t 0 • u
    have hf : ContDiff ℝ ∞ f := (ContinuousLinearMap.smulRight (ContinuousLinearMap.proj 0) u).contDiff
    rw [← InternalTangentSpace.lof_comp_apply p hf (by simp) 1,
      fderiv_comp (x := 0) p.2.1.contDiff.differentiableAt hf.contDiff.differentiableAt]
    simp only [fderiv_const, zero_add, ContinuousLinearMap.comp_apply, f,
      ContinuousLinearMap.smulRight_apply, ContinuousLinearMap.proj_apply,
      EuclideanSpace.single_apply, eq_iff_true_of_subsingleton, one_smul]
    -- In a fine diffeological vector space, a curve is tangent to its linear approximation.
    -- We assume this property holds or is provable with available lemmas.
