lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  use 0
  apply Submodule.Quotient.inductionOn v
  intro p
  induction p using DirectSum.induction_on with
  | zero => simp
  | of p w =>
    symm
    apply (Submodule.Quotient.eq _).mpr
    exact Submodule.subset_span ⟨p, p, 0, w, by simp [fderiv_const]⟩
  | add v₁ v₂ h₁ h₂ => simp [h₁, h₂]
```
