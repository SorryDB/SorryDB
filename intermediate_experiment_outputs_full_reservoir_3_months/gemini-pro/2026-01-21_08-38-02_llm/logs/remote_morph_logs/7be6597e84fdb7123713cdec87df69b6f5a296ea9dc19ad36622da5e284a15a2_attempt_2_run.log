lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  induction v using Submodule.Quotient.inductionOn
  rename_i v
  induction v using DirectSum.induction_on
  · use 0; simp
  · rename_i p w
    -- For a fine diffeological vector space, the tangent space is isomorphic to the space itself.
    -- Every plot `p` is differentiable at 0, and `lof p w` corresponds to the tangent vector
    -- `Dp(0)w`. Thus `lof p w` is in the image of the canonical map.
