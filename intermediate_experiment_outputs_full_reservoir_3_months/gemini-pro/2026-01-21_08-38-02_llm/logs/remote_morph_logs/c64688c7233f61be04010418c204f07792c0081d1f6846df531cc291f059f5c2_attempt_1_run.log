lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = bits2num args) := by
  intros w args e h_bound ⟨h_bits, h_eq⟩
  subst h_eq
  simp only [Exp.eval] at h_bound
  apply h_bound; clear h_bound
  rcases args with ⟨l, rfl⟩
  unfold bits2num Vector.foldl
  unfold assert_bits at h_bits
  rw [Vector.all_mk] at h_bits
  generalize h_acc : (0 : ZMod p) = acc
  generalize h_k : 0 = k
  have h_val : acc.val < 2 ^ k := by subst h_acc h_k; simp; exact Nat.zero_lt_one
  clear h_acc h_k
  induction l generalizing acc k with
  | nil =>
    simp
    exact h_val
  | cons b bs ih =>
    simp
    simp at h_bits
    rcases h_bits with ⟨hb, h_bits⟩
    apply ih (b + 2 * acc) (k + 1)
    · rw [Bool.or_eq_true, beq_iff_eq, beq_iff_eq] at hb
      have b_lt : b.val < 2 := by cases hb <;> { subst b; simp; exact Nat.zero_lt_two }
      have acc_lt : acc.val < 2 ^ k := h_val
      have N_lt : b.val + 2 * acc.val < 2 ^ (k + 1) := by
        calc
          b.val + 2 * acc.val ≤ 1 + 2 * (2 ^ k - 1) := Nat.add_le_add (Nat.le_of_lt_succ b_lt) (Nat.mul_le_mul_left 2 (Nat.le_pred_of_lt acc_lt))
          _ = 1 + (2 * 2 ^ k - 2) := by rw [Nat.mul_sub_left_distrib, Nat.mul_one]
