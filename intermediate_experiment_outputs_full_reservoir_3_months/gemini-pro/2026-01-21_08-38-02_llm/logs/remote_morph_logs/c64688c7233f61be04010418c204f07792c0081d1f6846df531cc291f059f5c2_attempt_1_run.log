lemma bits_bad : ∀ (w : ℕ) (args : Vector (ZMod p) w) (e : Exp (ZMod p) (ZMod p)),
  (¬ e.eval.val < 2 ^ w) -> ¬ (assert_bits args /\ e = bits2num args) := by
  intros w args e h_not h_conj
  obtain ⟨h_assert, rfl⟩ := h_conj
  apply h_not
  clear h_not
  induction w generalizing args with
  | zero =>
    have : args = Vector.nil := Vector.zero_subsingleton.allEq _ _
    subst this
    simp [bits2num, Vector.foldl]
  | succ n ih =>
    let h := args.head
    let t := args.tail
    have h_split : args = h ::ᵥ t := (Vector.cons_head_tail args).symm
    rw [h_split] at h_assert ⊢
    simp only [assert_bits, Vector.all_cons, beq_iff_eq, Bool.decide_or, Bool.or_eq_true, decide_eq_true_eq] at h_assert
    obtain ⟨h_head_bit, h_tail_bits⟩ := h_assert
    specialize ih t h_tail_bits

    have decomp : bits2num (h ::ᵥ t) = h * 2^n + bits2num t := by
      simp only [bits2num]
      let f (acc b : ZMod p) := b + 2 * acc
      trans List.foldl f 0 (h :: t.toList)
      · rfl
      rw [List.foldl_cons]
      have aux : ∀ l acc, List.foldl f acc l = acc * 2^(List.length l) + List.foldl f 0 l := by
        intro l
        induction l with
        | nil => intro; simp
        | cons x xs ih =>
          intro acc
          simp only [List.foldl_cons, List.length_cons, pow_succ]
          rw [ih (x + 2 * acc), ih x]
          generalize 2 ^ xs.length = P
          ring
      rw [aux t.toList h]
      simp

    rw [decomp]
    let S := h.val * 2^n + (bits2num t).val
    have S_bound : S < 2^(n+1) := by
      cases h_head_bit with
      | inl hz =>
        rw [hz]; simp [S]
        apply Nat.lt_trans ih
        apply Nat.pow_lt_pow_of_lt_right (by decide) (by simp)
      | inr ho =>
        rw [ho]; simp [S]
        calc 1 * 2^n + (bits2num t).val
           = 2^n + (bits2num t).val := by simp
         _ < 2^n + 2^n := Nat.add_lt_add_left ih _
         _ = 2 * 2^n := by ring
         _ = 2^(n+1) := by ring

    have val_eq : (h * 2^n + bits2num t : ZMod p).val = (S : ZMod p).val := by
      congr; simp [S]; norm_cast

    rw [val_eq]
    cases lt_or_ge S p with
    | inl hp => rw [ZMod.val_cast_of_lt hp]; exact S_bound
    | inr hp =>
      calc (S : ZMod p).val
         < p := ZMod.val_lt _
       _ ≤ S := hp
       _ < 2^(n+1) := S_bound
