    have val_eq : (h * 2^n + bits2num t : ZMod p).val = (S : ZMod p).val := by
      congr; simp [S]; norm_cast

    rw [val_eq]
    cases lt_or_ge S p with
    | inl hp => rw [ZMod.val_cast_of_lt hp]; exact S_bound
    | inr hp =>
      calc (S : ZMod p).val
         < p := ZMod.val_lt _
       _ ≤ S := hp
       _ < 2^(n+1) := S_bound
