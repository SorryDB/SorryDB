  try simp only [Exp.eval] at h_bound
  have h_bound_val : 2 ^ w ≤ (bits2num args).val := le_of_not_lt h_bound
  have h_p : 2 ^ w < p := lt_of_le_of_lt h_bound_val (ZMod.val_lt _)
  have h_lt : (bits2num args).val < 2 ^ w := by
    unfold bits2num
    let l := args.toList
    have h_len : l.length = w := by simp
    have h_bits_l : ∀ x ∈ l, x.val ≤ 1 := by
      unfold assert_bits at h_bits
      rw [Vector.all_iff_forall] at h_bits
      intro x hx; specialize h_bits x hx
      cases h_bits <;> simp_all [beq_iff_eq]
      · exact Nat.zero_le _
      · rfl
    have h_fold : (l.foldl (fun acc b => b + 2 * acc) (0:ZMod p)).val < 2^l.length := by
      let f_n (acc : ℕ) (b : ZMod p) := b.val + 2 * acc
      let f_z (acc : ZMod p) (b : ZMod p) := b + 2 * acc
      have H : ∀ (xs : List (ZMod p)) (k : ℕ) (acc : ℕ),
        (∀ x ∈ xs, x.val ≤ 1) → acc < 2^k → 2^(k + xs.length) ≤ p →
        (xs.foldl f_z acc).val = xs.foldl f_n acc ∧ xs.foldl f_n acc < 2^(k + xs.length) := by
        intro xs
        induction xs with
        | nil => intros; simp; exact ⟨ZMod.val_cast_of_lt (lt_of_lt_of_le (by assumption) (by assumption)), by assumption⟩
        | cons x xs ih =>
          intros k acc h_all h_acc h_pow
          simp at h_all
          have h_next : x.val + 2 * acc < 2^(k+1) := by
            calc x.val + 2 * acc
              _ ≤ 1 + 2 * (2^k - 1) := Nat.add_le_add h_all.1 (Nat.mul_le_mul_left 2 (Nat.le_sub_one_of_lt h_acc))
              _ < 2^(k+1) := by rw [pow_add, mul_comm, Nat.mul_sub_left_distrib]; simp; exact Nat.sub_lt (by decide) (by decide)
          have h_pow' : 2^(k+1+xs.length) ≤ p := by rw [add_assoc, add_comm 1] at h_pow; exact h_pow
          have h_eq : f_z acc x = (x.val + 2 * acc : ℕ) := by
            simp [f_z]
            apply ZMod.val_cast_of_lt
            exact lt_of_lt_of_le (lt_of_lt_of_le h_next (Nat.pow_le_pow_of_le_right (by decide) (Nat.le_add_right _ _))) h_pow'
          specialize ih (k+1) (x.val + 2 * acc) h_all.2 h_next h_pow'
          rw [h_eq]
          exact ih
      obtain ⟨h_eq, h_lt⟩ := H l 0 0 h_bits_l Nat.zero_lt_one (by simp [h_len]; exact le_of_lt h_p)
      rw [h_eq]
      exact h_lt
    
    -- Assuming Vector.foldl is definitionally equal to List.foldl on toList/val
    try simp only [Vector.foldl_eq_foldl_toList]
    try simp only [Vector.foldl_val]
    change (l.foldl _ _).val < 2^w
    rw [h_len] at h_fold
    exact h_fold
    
  linarith
