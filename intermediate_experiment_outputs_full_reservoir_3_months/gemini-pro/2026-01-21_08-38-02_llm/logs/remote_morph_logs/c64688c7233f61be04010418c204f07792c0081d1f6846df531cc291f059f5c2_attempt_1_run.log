  -- We prove that if assert_bits holds and 2^n <= p, then val < 2^n
  let rec bound_lemma {n} (v : Vector (ZMod p) n) (h_bits : assert_bits v) (h_p_n : 2^n ≤ p) : (bits2num v).val < 2^n := by
