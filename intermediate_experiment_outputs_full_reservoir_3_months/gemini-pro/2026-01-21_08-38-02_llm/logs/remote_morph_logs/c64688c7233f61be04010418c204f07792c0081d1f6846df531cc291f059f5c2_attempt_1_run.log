  let f_zmod (acc : ZMod p) (b : ZMod p) := b + 2 * acc
  
  have h_comb : ∀ (L : List (ZMod p)) (k : ℕ) (acc_z : ZMod p) (acc_n : ℕ),
    (∀ b ∈ L, b.val ≤ 1) →
    acc_z.val = acc_n % p → acc_n < 2 ^ k →
    (List.foldl f_zmod acc_z L).val ≤ (List.foldl f_nat acc_n L) ∧
    (List.foldl f_nat acc_n L) < 2 ^ (k + L.length) := by
    intro L
    induction L with
    | nil =>
      intros k acc_z acc_n h_L h_eq h_lt
      simp
      exact ⟨le_of_eq h_eq.symm ▸ Nat.mod_le _ _, h_lt⟩
    | cons b bs ih =>
