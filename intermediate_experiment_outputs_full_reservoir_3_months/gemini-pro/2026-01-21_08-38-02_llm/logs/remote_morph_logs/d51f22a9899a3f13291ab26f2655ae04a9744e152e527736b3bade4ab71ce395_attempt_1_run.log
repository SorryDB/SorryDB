theorem soundness : ∀ (c : Circuit p (ZMod p)),
  rw_bisim (Circuit.eval c) (Cs.eval (to_cs c)) := by
  intro c
  induction c with
  | nil =>
    simp [Circuit.eval,to_cs]
    constructor
  | lam k h =>
    simp [Circuit.eval,to_cs]
    constructor
    exact h
  | eq0 e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    split
    apply h
    constructor
  | share e c h =>
    simp [Circuit.eval,Cs.eval,to_cs]
    apply rw_bisim.right
    intro x
    simp [Exp.eval]
    split
    have hmy : x = Exp.eval e := by grind
    rw [<-hmy]
    apply h
    constructor
  | is_zero e c h =>
    apply rw_bisim.right
    intro inv
    apply rw_bisim.right
    intro o
    simp [Exp.eval,Circuit.eval,Cs.eval]
    split
    case is_zero.h.h.isTrue he0 =>
      split
      case isTrue hsub =>
        split
        case isTrue hmul =>
          simp [*] at *
          have hmy : o=1 := by grind
          rw [hmy]
          apply h
        case isFalse hmul => constructor
      case isFalse hsub => constructor
    case is_zero.h.h.isFalse he0 =>
      split
      case isTrue hsub =>
        split
        case isTrue hmul =>
          simp [*] at *
          rw [hmul]
          apply h
        case isFalse hmul => constructor
      case isFalse hsub => constructor
  | assert_range w e c h =>
    simp [Circuit.eval,to_cs]
    apply rw_bisim_uncurry
    intros args
    split
    case _ ew =>
      rw [reduce]
      apply h
      sorry
      -- apply bits_good
      -- assumption
    case _ lt w_bound =>
      rw [fail]
      constructor
      rintro ⟨h_bits, h_eq⟩
      rw [h_eq] at w_bound
      apply w_bound
      suffices (bits2num args).val < 2 ^ w by assumption
      clear h_eq w_bound
      induction w with
      | zero => simp [bits2num, Vector.foldl]; exact Nat.zero_lt_one
      | succ w ih =>
        let h := args.head; let t := args.tail
        have eq : args = h ::ᵥ t := by simp
        rw [eq, assert_bits, Vector.all_cons] at h_bits
        rw [eq, bits2num, Vector.foldl, Vector.toList_cons, List.foldl_cons, add_zero, mul_zero]
        let f := fun (acc : ZMod p) (b : ZMod p) => b + 2 * acc
        have prop : ∀ (a : ZMod p) (l : List (ZMod p)), (List.foldl f a l) = List.foldl f 0 l + a * (2^l.length) := by
          intros a l; induction l generalizing a with
          | nil => simp
          | cons x xs inner_ih => simp [f, inner_ih]; ring
        rw [prop, bits2num, Vector.foldl] at *
        specialize ih t h_bits.2
        rw [Vector.toList_length] at *
        if hp : p ≤ 2^(w+1) then
          apply lt_of_lt_of_le (ZMod.val_lt _) hp
        else
          push_neg at hp
          have h_val : (List.foldl f 0 t.toList + h * 2 ^ w).val = (List.foldl f 0 t.toList).val + h.val * 2 ^ w := by
            apply ZMod.val_add_of_lt
            rw [ZMod.val_mul_of_lt]
            · rcases h_bits.1 with rfl | rfl <;> simp; linarith
            · rcases h_bits.1 with rfl | rfl <;> simp <;> linarith [Nat.pos_pow_of_pos w (by decide)]
            · apply Nat.lt_trans _ hp; rcases h_bits.1 with rfl | rfl <;> simp <;> linarith [Nat.pos_pow_of_pos w (by decide)]
          rw [h_val]
          rcases h_bits.1 with rfl | rfl <;> simp <;> linarith
