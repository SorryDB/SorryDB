    obtain ⟨ny, zy, rfl⟩ := hy
    use nx * ny, ny • zx + nx • zy
    simp only [map_add, map_zsmul]
    trans j₁ (((nx * ny : ℕ+) : ℚ)⁻¹ ⊗ₜ[ℤ] 1) * (j₂ (ny • zx) + j₂ (nx • zy))
    · congr
      · simp only [map_zsmul, zsmul_eq_mul, ← map_mul]
        congr 2
        push_cast
        field_simp
      · simp only [map_zsmul, zsmul_eq_mul, ← map_mul]
        congr 2
        push_cast
        field_simp
    · rw [mul_add]
      congr 1 <;>
      { rw [map_zsmul, zsmul_eq_mul, ← mul_assoc, ← map_intCast j₁, ← map_mul]
        congr 2
        push_cast
        field_simp }

end HurwitzRatHat
