namespace HurwitzRatHat

/-- The "profinite Hurwitz quaternions" over the finite adeles of ℚ; a free rank 4 module
generated by 1, i, j, and (1+i+j+k)/2. -/
scoped notation "D^" => HurwitzRatHat

noncomputable instance : Ring D^ := Algebra.TensorProduct.instRing

/-- The inclusion from D=ℚ+ℚi+ℚj+ℚk to D ⊗ 𝔸, with 𝔸 the finite adeles of ℚ. -/
noncomputable abbrev j₁ : D →ₐ[ℤ] D^ := Algebra.TensorProduct.includeLeft
-- (Algebra.TensorProduct.assoc ℤ ℚ 𝓞 ZHat).symm.trans Algebra.TensorProduct.includeLeft

lemma injective_hRat :
    Function.Injective j₁ := sorry -- flatness

/-- The inclusion from the profinite Hurwitz quaternions to to 𝔸+𝔸i+𝔸j+𝔸k,
with 𝔸 the finite adeles of ℚ. -/
noncomputable abbrev j₂ : 𝓞^ →ₐ[ℤ] D^ :=
  ((Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat).symm : ℚ ⊗ 𝓞^ ≃ₐ[ℤ] D ⊗ ZHat).toAlgHom.comp
  (Algebra.TensorProduct.includeRight : 𝓞^ →ₐ[ℤ] ℚ ⊗ 𝓞^)

lemma injective_zHat :
    Function.Injective j₂ := sorry -- flatness

-- should I rearrange tensors? Not sure if D^ should be (ℚ ⊗ 𝓞) ⊗ ℤhat or ℚ ⊗ (𝓞 ⊗ Zhat)
lemma canonicalForm (z : D^) : ∃ (N : ℕ+) (z' : 𝓞^), z = j₁ ((N⁻¹ : ℚ) ⊗ₜ 1 : D) * j₂ z' := by
  let e : D^ ≃ₐ[ℤ] ℚ ⊗[ℤ] 𝓞^ := Algebra.TensorProduct.assoc ℤ ℤ ℚ 𝓞 ZHat
  suffices ∃ (N : ℕ+) (z' : 𝓞^), e z = (N : ℚ)⁻¹ ⊗ₜ z' by
    obtain ⟨N, z', h⟩ := this
    refine ⟨N, z', e.injective ?_⟩
    simp only [map_mul, h, j₁, j₂, AlgEquiv.toAlgHom_eq_coe, AlgEquiv.coe_algHom,
      AlgEquiv.comp_apply, AlgEquiv.apply_symm_apply,
      Algebra.TensorProduct.includeRight_apply, Algebra.TensorProduct.includeLeft_apply]
    rw [TensorProduct.tmul_mul_tmul, mul_one, one_mul]
    rfl
  induction e z using TensorProduct.induction_on with
  | zero => use 1, 0; simp
  | tmul q x =>
    use ⟨q.den, q.den_pos⟩, q.num • x
    rw [← TensorProduct.smul_tmul', ← smul_eq_mul, ← zsmul_eq_mul, ← Rat.num_div_den q,
      div_eq_mul_inv, mul_comm]
    congr
  | add x y hx hy =>
    obtain ⟨Nx, x', rfl⟩ := hx
    obtain ⟨Ny, y', rfl⟩ := hy
    use Nx * Ny, (Ny : ℤ) • x' + (Nx : ℤ) • y'
    simp only [TensorProduct.tmul_add, ← TensorProduct.smul_tmul']
    rw [← mul_smul, ← mul_smul]
    congr 1
    · rw [PNat.mul_coe, Nat.cast_mul, mul_inv, mul_comm, smul_eq_mul, mul_assoc,
        mul_comm (Nx : ℚ)⁻¹, ← mul_assoc, inv_mul_cancel (Nat.cast_ne_zero.2 (PNat.ne_zero Ny)),
        one_mul]
    · rw [PNat.mul_coe, Nat.cast_mul, mul_inv, smul_eq_mul, mul_assoc,
        inv_mul_cancel (Nat.cast_ne_zero.2 (PNat.ne_zero Nx)), mul_one]

end HurwitzRatHat
