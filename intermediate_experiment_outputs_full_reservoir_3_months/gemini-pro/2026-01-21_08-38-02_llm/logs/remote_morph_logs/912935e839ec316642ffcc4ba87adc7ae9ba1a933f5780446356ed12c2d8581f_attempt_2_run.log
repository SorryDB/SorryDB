def PreStateP.last {pos} {bt : BuildTree pos} {m : Match bt} : PreStateP bt m → Sequent
  | .edge _ _ next => next.last
  | .stopLeaf _ => m.btAt.1.2.1
  | .stopAtM _ _ => m.btAt.1.2.1

def PreStateP.forms {pos} {bt : BuildTree pos} {m : Match bt} (p : PreStateP bt m) : List Formula :=
  let ⟨L, R, _⟩ := p.last; L ++ R

def PreStateP.lforms {pos} {bt : BuildTree pos} {m : Match bt} (p : PreStateP bt m) : List NegLoadFormula :=
  match p.last with | ⟨_, _, some (Sum.inl f)⟩ => [f] | ⟨_, _, some (Sum.inr f)⟩ => [f] | _ => []

/-- Collect formulas in a pre-state. The non-loaded part of Λ(π) in paper. -/
def PreState.forms : PreState bt → List Formula
  | .fromRoot p => p.forms
  | .fromMod _ _ p => p.forms

/-- Collect formulas in a pre-state. The loaded part of Λ(π) in paper. -/
def PreState.lforms : PreState bt → List NegLoadFormula
  | .fromRoot p => p.lforms
  | .fromMod _ _ p => p.lforms

def PreState.last : PreState bt → Sequent
  | .fromRoot p => p.last
  | .fromMod _ _ p => p.last

/-- TODO Lemma 6.14 -/
