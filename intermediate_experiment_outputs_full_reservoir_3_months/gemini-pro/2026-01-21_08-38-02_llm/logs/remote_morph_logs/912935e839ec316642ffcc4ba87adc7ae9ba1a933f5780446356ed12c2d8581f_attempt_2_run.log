def PreState.last {pos} {bt : BuildTree pos} : PreState bt → Sequent
  | .fromRoot p => pLast p
  | .fromMod _ _ p => pLast p
where pLast {m} : PreStateP bt m → Sequent
  | .stopLeaf h => (Match.btAt h).1.2.1
  | .stopAtM e _ => e.mPos.2.1
  | .edge _ _ tail => pLast tail

/-- Collect formulas in a pre-state. The non-loaded part of Λ(π) in paper. -/
def PreState.forms {pos} {bt : BuildTree pos} (π : PreState bt) : List Formula :=
  let ⟨L, R, _⟩ := π.last; L ++ R

/-- Collect formulas in a pre-state. The loaded part of Λ(π) in paper. -/
def PreState.lforms {pos} {bt : BuildTree pos} (π : PreState bt) : List NegLoadFormula :=
  match π.last.2.2 with
  | some (.inl f) => [f]
  | some (.inr f) => [f]
  | none => []

/-- TODO Lemma 6.14 -/
lemma PreState.formsCases {π : PreState bt} : φ ∈ π.forms →
      (φ.basic ∧ φ ∈ π.last) -- NOTE: the `∈` is not dealing with loaded formulas here!
    ∨ (¬ φ.basic) := by
  intro h
  unfold PreState.forms at h
  rcases def_last : π.last with ⟨L, R, _⟩
  rw [def_last] at h
  simp only [List.mem_append] at h
  if hbas : φ.basic then
    left
    constructor
    · exact hbas
    · -- Assuming Sequent membership includes L and R parts
      rw [def_last]
      simp only [Sequent.mem_def] -- This lemma likely exists to define membership
      tauto
  else
    right
    exact hbas
