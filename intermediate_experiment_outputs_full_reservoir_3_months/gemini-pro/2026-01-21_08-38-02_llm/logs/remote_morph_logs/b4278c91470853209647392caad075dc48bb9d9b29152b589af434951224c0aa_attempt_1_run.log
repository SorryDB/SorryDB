lemma bfc_bounded (x y : H) {C : ‚ĄĚ} {f : (spectrum ‚Ąā a) ‚Üí ‚Ąā}  (hf_bounded : ‚ąÄ x, ‚ÄĖf x‚ÄĖ ‚Č§ C)
    (hX : @Measurable _ _ (borel (spectrum ‚Ąā a)) _ f) :
    ‚ÄĖ(cfc_toComplexMeasure ha x y).integral f‚ÄĖ ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ * C := by
  let őľ := cfc_toComplexMeasure ha x y
  have h_bound : (őľ.variation Set.univ).toReal ‚Č§ ‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ := by
    have h := cfc_variation_toComplexMeasure_bounded ha x y
    rw [‚Üź ENNReal.ofReal_le_iff_toReal_le (ComplexMeasure.finite_variation őľ).ne_top (by positivity)]
    simp only [ENNReal.ofReal_mul (norm_nonneg _)]
    exact h
  by_cases hx : x = 0
  ¬∑ simp [hx, cfc_toLinearFunctional_apply]
    have : őľ = 0 := by
      apply ComplexRMK.rieszMeasure_eq_zero_of_forall_integral_eq_zero
      intro g
      simp [őľ, cfc_toComplexMeasure, cfc_toLinearFunctional_apply, hx]
    simp [this]
  ¬∑ haveI : Nontrivial H := nontrivial_of_ne _ _ hx
    haveI : Nontrivial (H ‚ÜíL[‚Ąā] H) := ContinuousLinearMap.nontrivial
    have : Nonempty (spectrum ‚Ąā a) := spectrum.nonempty a
    have hC : 0 ‚Č§ C := le_trans (norm_nonneg _) (hf_bounded (Classical.choice this))
    calc ‚ÄĖőľ.integral f‚ÄĖ
      ‚Č§ ‚ąę z, ‚ÄĖf z‚ÄĖ ‚ąāőľ.variation := ComplexMeasure.norm_integral_le_integral_norm f
    _ ‚Č§ ‚ąę z, C ‚ąāőľ.variation := MeasureTheory.integral_mono_of_nonneg
          (MeasureTheory.Integrable.of_bound (MeasureTheory.integrable_const _) hX.norm (fun z => hf_bounded z))
          (MeasureTheory.integrable_const C)
          (fun z => norm_nonneg _) (fun z => hf_bounded z)
    _ = (őľ.variation Set.univ).toReal * C := MeasureTheory.integral_const C
    _ ‚Č§ (‚ÄĖx‚ÄĖ * ‚ÄĖy‚ÄĖ) * C := mul_le_mul_of_nonneg_right h_bound hC
