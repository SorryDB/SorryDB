    -- (S83)
    let c' Оө2 n := (c n + (c n) / n) вҠ” ((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2)

    have hc' (Оө2 : в„• вҶ’ в„қвүҘ0) (hОө2 : вҲҖ n, Оө2 n < 1) :
        вҲғ (C : в„қвүҘ0), вҲҖб¶  (n : в„•) in Filter.atTop, c' (Оө2 n) n вүӨ C := by
      apply c'_bounded hОө2 _ hc

    -- (S84)
    have hПғ'' Оө2 n : Real.exp (-n * c' Оө2 n) вҖў 1 вүӨ (Пғ'' n).M := by
      rcases n.eq_zero_or_pos with rfl | hn
      В· have _ : Unique (H (i ^ 0)) := by
          rw [spacePow_zero]
          infer_instance
        apply le_of_eq
        simp [Unique.eq_default (Пғ'' 0)]
