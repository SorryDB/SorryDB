    -- (S82) -- see (S81) for comments
    have hE2leq Оө2 (n : в„•) (hОө2 : 0 < Оө2) : (1/n : в„қ) вҖў (E2 Оө2 n).toMat * ((в„° n (ПҒвҠ—^S[n])).M.log.toMat - (Пғ'' n).M.log.toMat) вүӨ ((R2 ПҒ Пғ).toReal + ОөвӮҖ + Оө2) вҖў (E2 Оө2 n).toMat := by
