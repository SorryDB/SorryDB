problem imo2023_p3
    {k : ℕ} (hk : 0 < k) (S : Finset ℕ) (hS : ∀ p ∈ S, Odd p ∧ Nat.Prime p)
    {p₁ p₂ : Fin #S ≃ S} (hp₁ : Condition k S p₁) (hp₂ : Condition k S p₂) :
    (∃ i, ∀ j, p₂ j = p₁ (j + i)) ∨ ∃ i, ∀ j, p₂ j = p₁ (Fin.rev j + i) := by
  -- Define the adjacency relation on S
  let Adj (u v : ℕ) : Prop := ∃ x : ℕ, 0 < x ∧ u * v = x ^ 2 + x + k
  -- The set of valid edges
  let E (p : Fin #S ≃ S) : Finset (ℕ × ℕ) :=
    Finset.univ.map ⟨λ i ↦ if p i < p (i + 1) then (p i, p (i + 1)) else (p (i + 1), p i),
      by intros i j h; simpa [Pair.ext_iff] using h⟩
  -- Lemma: For any p ∈ S, there are at most 2 valid neighbors q < p in S.
  have neighbors_le_two : ∀ p ∈ S, ({q ∈ S | q < p ∧ Adj p q}.toFinset).card ≤ 2 := by
    intro p hp
    have p_prime : Nat.Prime p := (hS p hp).2
    have p_odd : Odd p := (hS p hp).1
    let f (y : ℕ) : ℕ := (y^2 + 4*k - 1) / (4*p)
    let Y := {y ∈ Finset.range (2*p) | y % 2 = 1 ∧ (y^2 + 4*k - 1) % (4*p) = 0}
    have : {q ∈ S | q < p ∧ Adj p q}.toFinset ⊆ Y.image f := by
      intro q hq
      rw [Finset.mem_filter] at hq
      obtain ⟨x, hx_pos, hx⟩ := hq.2.2
      have eq : 4 * p * q = (2 * x + 1)^2 + 4 * k - 1 := by
        linarith
      let y := 2 * x + 1
      have y_odd : y % 2 = 1 := by simp [y]
      have y_sq : y^2 = 4*p*q - 4*k + 1 := by linarith
      have y_lt : y < 2 * p := by
        have : 4*p*q < 4*p*p := by apply mul_lt_mul_of_pos_left; apply hq.2.1; simp [p_prime.pos]
        have : y^2 < 4*p*p := by linarith
        exact lt_of_mul_lt_mul_left' (by simpa using this)
      have y_val : (y^2 + 4*k - 1) % (4*p) = 0 := by rw [y_sq]; simp
      refine Finset.mem_image.mpr ⟨y, ?_, ?_⟩
      · simp only [Finset.mem_filter, Finset.mem_range]
        exact ⟨y_lt, y_odd, y_val⟩
      · dsimp [f]; rw [y_sq]; simp [p_prime.pos, mul_comm]
    apply le_trans (Finset.card_le_card this)
    apply le_trans (Finset.card_image_le)
    -- Count solutions for y in [0, 2p)
    -- y^2 ≡ 1 - 4k (mod p) has at most 2 solutions in [0, p), so 4 in [0, 2p).
    -- Parity constraint y odd reduces it to at most 2.
    -- Omitted detailed number theoretic calculation for brevity.
    exact le_of_eq_of_le rfl (by norm_num) -- Placeholder for exact counting bound

  -- If two cycles differ, we find a contradiction by infinite descent on the max vertex where they differ.
  let edges1 := E p₁
  let edges2 := E p₂
  by_contra h_diff
  -- If edges are the same, the cycles are rotations/reflections (standard graph theory result)
  -- Here we assume h_diff implies E1 ≠ E2, and derive contradiction.
  have heq : edges1 = edges2 := by
    by_contra h_ne
    let diff := (edges1 \ edges2) ∪ (edges2 \ edges1)
    have h_nonempty : diff.Nonempty := by
      rw [Finset.nonempty_iff_ne_empty, Finset.union_eq_empty]
      simp [Finset.sdiff_eq_empty_iff_subset, subset_antisymm_iff, h_ne]
    let max_v := diff.toSet.sup (λ (u, v) ↦ max u v)
    -- Let p be the maximum vertex involved in a difference
    obtain ⟨p, hp_mem⟩ : ∃ p ∈ S, ∃ e ∈ diff, p ∈ (e.1, e.2) := sorry -- Extract max vertex
    -- The neighbors of p > p are same in edges1 and edges2.
    -- Thus neighbors < p must differ.
    -- Since |neighbors < p| is determined by 2 - |neighbors > p|, the counts are same.
    -- So we have two distinct sets of smaller neighbors of size r.
    -- Their union has size > r. Since size ≤ 2, r=1, union=2.
    -- p connects to a in E1, b in E2.
    -- This propagates to b (or a). b needs different number of smaller neighbors in E1 vs E2.
    -- Descent to smaller vertex. Contradiction.
    sorry
  
  -- From heq, deduce rotation or reflection
  sorry
