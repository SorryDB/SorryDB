  have h_dual (H : Graph α β) (hH : H.IsCompOf G) (x y : α) (hx : x ∈ V(H)) (hy : y ∈ V(H)) :
      Mmat.dual.Parallel x y := by
    obtain ⟨P, hP⟩ := hH.connected.exists_path hx hy
    induction P using WList.induction_trail with
    | base => exact Mmat.dual.parallel_refl _
    | cons_edge _ _ _ P' ha _ ih =>
      exact (Mmat.series_iff_dual_parallel _ _).mp (matchingMatroid.seriesPair_of_adj h ha) |>.trans
        (ih (hH.subset_vertexSet P'.subset_vertices_left))
  have h_comp (H : Graph α β) (hH : H.IsCompOf G) : ∃ MH, H.IsMatching MH ∧ ∃! x, x ∈ V(H) ∧ x ∉ V(H, MH) := by
