lemma foo_of_forall_inessential (h : ∀ x, G.inessential x) :
    ∃ M, G.IsMatching M ∧ ∀ H : Graph α β, H.IsCompOf G → ∃! x, x ∈ V(H) ∧ x ∉ V(G, M) := by
  -- Obtain a global maximum matching M.
  obtain ⟨M, hM⟩ : ∃ M, G.IsMaxMatching M := by
    obtain rfl | ⟨x, -⟩ := V(G).eq_empty_or_nonempty
    · exact ⟨∅, by simp [IsMaxMatching_iff]⟩
    · obtain ⟨M, hM, -⟩ := h x; exact ⟨M, hM⟩
  
  -- The matching M works for all components.
  refine ⟨M, hM.toIsMatching, fun H hH ↦ ?_⟩
  
  -- We claim |V(H)| = r(V(H)) + 1 = 2|M_H| + 1, so M leaves exactly one vertex in H exposed.
  let S := V(H)
  have hS_sub : S ⊆ G.matchingMatroid.E := hH.subset_vertexSet
  
  -- Establish rank properties and size of V(H).
  have h_card : S.encard = G.matchingMatroid.eRk S + 1 := by
    obtain h_sing | h_nontriv := S.subsingleton_or_nontrivial
    · obtain ⟨x, hx⟩ := h_sing.exists_eq_singleton
      subst hx; simp
    · -- V(H) is a set of series pairs in the matching matroid.
      have h_ser : ∀ u ∈ S, ∀ v ∈ S, u ≠ v → G.matchingMatroid.Series u v := by
        intro u hu v hv huv
        -- Series relation is transitive on non-coloops (which all vertices are).
        have hnc (x) (hx : x ∈ S) : ¬ G.matchingMatroid.IsColoop x := 
          matchingMatroid.noColoop h (hS_sub hx)
        induction H.connected.pairwise_path hu hv huv using WList.IsPath.induction with
        | single e a b hab => exact matchingMatroid.seriesPair_of_adj h (hH.adj_subset hab)
        | step e a b c hab _ IH => 
          exact (matchingMatroid.seriesPair_of_adj h (hH.adj_subset hab)).trans (IH (hnc b (by sorry))) -- b ∈ S
      
      -- Apply Part (a) and rank additivity.
      have h_rk := Matroid.fooA hS_sub h_nontriv h_ser
      -- Use rank additivity: r(E) = r(E \ S) + r(S). (Assumed standard for matching matroid / components).
      sorry -- Rank algebra

  -- Relate rank to matching size in H.
  have h_rk_S : G.matchingMatroid.eRk S = (M ∩ E(H)).encard * 2 := by
    -- M ∩ H is a max matching in H (since M is global max), so covers r(S) vertices.
    sorry

  -- Conclusion: |V(H) \ V(M)| = |V(H)| - |V(M) ∩ V(H)| = (r(S) + 1) - r(S) = 1.
  have h_diff : (S \ V(G, M)).encard = 1 := by
    rw [encard_diff_eq_sub_of_subset, h_card, h_rk_S]
    · rw [hM.toIsMatching.inter_right E(H) |>.encard_V_graph_eq, add_tsub_cancel_left]
    · -- Subset proof: V(M) ∩ V(H) ⊆ V(H)
      sorry
    · -- Finiteness proof
      sorry

  exact exists_unique_iff_card_eq_one.mpr h_diff
