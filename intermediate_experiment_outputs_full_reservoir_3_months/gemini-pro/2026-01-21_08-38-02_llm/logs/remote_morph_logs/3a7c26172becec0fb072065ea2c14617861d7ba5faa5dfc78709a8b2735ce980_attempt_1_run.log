lemma foo_of_forall_inessential (h : ∀ x, G.inessential x) :
    ∃ M, G.IsMatching M ∧ ∀ H : Graph α β, H.IsCompOf G → ∃! x, x ∈ V(H) ∧ x ∉ V(G, M) := by
  obtain ⟨M, hM⟩ : ∃ M, G.IsMaxMatching M := by
    obtain ⟨x, hx⟩ | hempty := eq_empty_or_nonempty V(G)
    · obtain ⟨M, hM, -⟩ := h x hx; exact ⟨M, hM⟩
    · use ∅; simp [isMaxMatching_iff, isMatching_iff, hempty]
  refine ⟨M, hM.1, fun H hH ↦ ?_⟩
  let S := V(H)
  have hS : S ⊆ V(G) := hH.subset
  by_cases htriv : S.Subsingleton
  · obtain ⟨v, rfl⟩ := htriv.exists_eq_singleton_or_empty
    · refine ⟨v, ?_, fun y hy _ ↦ hy⟩
      simp only [mem_singleton_iff, and_true, true_and]
      intro hv
      obtain ⟨e, heM, he⟩ := hv
      have : e ∈ E(H) := hH.subset_edges_of_subset_vertices_incident hM.1.subset heM he
      have : E(H) = ∅ := by
        rw [eq_empty_iff_forall_not_mem]
        intro f hf
        obtain ⟨x, hx, y, hy, hne⟩ := H.exists_ne_of_mem_edges hf
        simp [H.inc_subset_vertices hf hx, H.inc_subset_vertices hf hy] at hx hy
        subst x; subst y; contradiction
      rw [this] at *; contradiction
    · exact (hH.nonempty).ne_empty rfl
  have hnt : S.Nontrivial := htriv.not_subsingleton_iff_nontrivial.mp htriv
  
  have h_series (x y : α) (hx : x ∈ S) (hy : y ∈ S) (hne : x ≠ y) :
      G.matchingMatroid.Series x y := by
    have h_conn : H.Connected := hH.connected
    have h_path := h_conn hx hy
    induction h_path using Relation.ReflTransGen.head_induction_on with
    | refl => contradiction
    | head huz hzy IH =>
      by_cases heq : z = y
      · subst heq
        apply matchingMatroid.seriesPair_of_adj h (hH.adj_subset_adj huz)
      · apply G.matchingMatroid.Series.trans _ (IH (by contradiction) heq)
        · exact matchingMatroid.noColoop h (hS (h_conn.left_mem huz))
        · exact matchingMatroid.noColoop h (hS (h_conn.right_mem huz))
        · exact matchingMatroid.noColoop h (hS hy)
        · exact matchingMatroid.seriesPair_of_adj h (hH.adj_subset_adj huz)

  have h_rank := Matroid.fooA (M := G.matchingMatroid) hS hnt h_series
  
  -- Using rank additivity for components (matchings are independent across components)
  -- r(G) = r(S) + r(G \ S)
  -- M is max matching, so |M| = r(G)/2 (if we count vertices) -> M covers r(S) in S and r(G\S) in rest.
  -- |M ∩ S| = r(S) (in terms of matching count, |V(M ∩ S)| = r(S))
  -- fooA: r(G \ S) + |S| = r(G) + 1 = r(S) + r(G \ S) + 1
  -- |S| = r(S) + 1
  -- |S| - |V(M) ∩ S| = 1
  
  -- Assuming finite ranks/sets for subtraction:
  have h_eq : S.encard = (V(G, M) ∩ S).encard + 1 := by
    -- Rank additivity and fooA application
    -- We assume standard matroid/graph finiteness properties implicit in the context
    sorry 

  exact encard_diff_eq_one_of_encard_eq_add_one hS (by simp) h_eq
