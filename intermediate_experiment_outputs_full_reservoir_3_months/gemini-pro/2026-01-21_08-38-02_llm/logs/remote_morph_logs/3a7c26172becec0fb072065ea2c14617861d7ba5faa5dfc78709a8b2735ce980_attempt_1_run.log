      refine Mmat.dual.basis_iff_indep_closure.mpr ⟨?_, ?_⟩
      · rw [Mmat.dual.indep_singleton, ← Mmat.isColoop_iff_dual_isNonloop]
        exact matchingMatroid.noColoop h x (hH.subset_vertexSet hx)
      · refine (subset_diff.mp hH.subset_vertexSet).1.trans (Mmat.dual.closure_subset_closure_of_subset_closure (singleton_subset_iff.mpr ?_))
        exact Mmat.dual.mem_closure_of_parallel (h_dual H hH x _ hx (by simp)) (by simpa using (matchingMatroid.noColoop h x (hH.subset_vertexSet hx)))
    obtain ⟨M, hM, hsub⟩ := hb.indep
    have heH : M ∩ E(H) ⊆ E(H) := inter_subset_right
    have hMH : H.IsMatching (M ∩ E(H)) := G.isMatching_subgraph_of_isMatching hM hH.le heH
    have hV : V(H, M ∩ E(H)) = V(H) \ {x} := by
      refine subset_antisymm ?_ (fun v hv ↦ ?_)
