        exact ⟨e, ⟨heM, hH.isInduced.edge_mem (hM.subset heM) (hb.subset_ground hv).1
          (hsub.subset_ground ⟨_, heM, (hM.disjoint_vertexSet_of_mem heM).symm.subset_right⟩)⟩, hev⟩
    use M ∩ E(H), hMH
    rw [hV]; exact ⟨x, ⟨hx, by simp⟩, fun y ⟨hy, hyn⟩ ↦ by simp_all⟩
  choose f hf using h_comp
  use ⋃ (H : {H | H.IsCompOf G}), f H H.2
  refine ⟨⟨?_, ?_⟩, ?_⟩
  · simp; rintro _ H hH e he; exact hH.subgraph.edge_subset (hf H hH).1.subset he
  · simp; intro e H hH he f K hK hf hne
