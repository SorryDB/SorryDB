lemma foo_of_forall_inessential (h : ∀ x, G.inessential x) :
    ∃ M, G.IsMatching M ∧ ∀ H : Graph α β, H.IsCompOf G → ∃! x, x ∈ V(H) ∧ x ∉ V(G, M) := by
  obtain ⟨M, hM⟩ : ∃ M, G.IsMaxMatching M := by
    by_cases hne : V(G).Nonempty
    · exact (h hne.some).imp fun _ ↦ And.left
    · exact ⟨∅, by simp [not_nonempty_iff_eq_empty.mp hne, isMaxMatching_iff]⟩
  refine ⟨M, hM.1, fun H hH ↦ ?_⟩
  let S := V(H)
  have hS_card : S.encard = G.matchingMatroid.eRk S + 1 := by
    cases S.subsingleton_or_nontrivial with
    | inl hs =>
      obtain ⟨x, rfl⟩ := hs.eq_empty_or_singleton; · exact (hH.nonempty.ne_empty rfl).elim
      rw [encard_singleton, add_left_eq_self, G.matchingMatroid.eRk_eq_zero_iff,
        matchingMatroid, matchingIndepMatroid, IndepMatroid.loop_iff_not_indep]
      rintro ⟨M', hM', hx⟩; obtain ⟨e, he⟩ := hx
      exact ((M' ∩ E(H)).eq_empty_of_subset_not_mem (by simp [hs.1]) (fun _ ↦ id)).subset ⟨he, sorry⟩
    | inr hnt =>
      have h_ser : ∀ u ∈ S, ∀ v ∈ S, u ≠ v → G.matchingMatroid.Series u v :=
        fun u hu v hv _ ↦ sorry -- connectivity + local series
      have h_sep : G.matchingMatroid.IsSeparator S := sorry
      have := Matroid.fooA hH.subset_vertexSet hnt h_ser
