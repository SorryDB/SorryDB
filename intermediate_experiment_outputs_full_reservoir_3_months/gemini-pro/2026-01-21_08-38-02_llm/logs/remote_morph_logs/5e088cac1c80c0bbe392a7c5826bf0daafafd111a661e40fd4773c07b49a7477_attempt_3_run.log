```lean
import Mathlib

set_option maxHeartbeats 0

open BigOperators Real Nat Topology Rat

theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  let S := ∑ k in Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (3 : ZMod 5)^k
  have hS_eq : (∑ k in Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) : ZMod 5) = S := by
    congr; ext k; norm_cast; rw [pow_mul]; rfl
  rw [← ZMod.int_cast_zmod_eq_zero_iff_dvd, hS_eq] at h

  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  have hM2 : M ^ 2 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    ext i j; fin_cases i <;> fin_cases j <;> simp [M, Matrix.mul_apply] <;> rfl
  
  let X := (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) + M
  let V (m : ℕ) := X ^ (2 * m + 1)

  have hV_val : V n 1 0 = S := by
    rw [V, add_pow]
    simp only [Matrix.sum_apply, Commute.add_pow (Commute.one_left M), one_pow, Matrix.one_mul]
    rw [Finset.sum_ite]
    simp only [Finset.mem_range, one_mul]
    trans ∑ x in Finset.filter (fun x => x % 2 = 1) (Finset.range (2 * n + 2)), (Nat.choose (2 * n + 1) x) * (M ^ x) 1 0
    · apply Finset.sum_congr rfl
      intro x hx
      -- If x is even, (M^x) 1 0 = 0
      have he : x % 2 = 0 := by
        by_contra h_odd
        rw [Nat.mod_two_ne_zero] at h_odd
        rw [h_odd] at hx
        simp at hx
      let j := x / 2
      have hx_eq : x = 2 * j := (Nat.div_mod_unique x).2 he
      rw [hx_eq, pow_mul, hM2]
      simp [Matrix.one_apply]
    · -- Map k -> 2k+1
      let f : ℕ ↪ ℕ := ⟨fun k => 2 * k + 1, fun a b hab => by linarith⟩
      rw [← Finset.sum_map]
      apply Finset.sum_congr
      · ext x; simp [Finset.mem_filter, Finset.mem_map, Finset.mem_range]; constructor
        · rintro ⟨h1, h2⟩
          use (x - 1) / 2
          constructor
          · apply Nat.lt_succ_of_le; rw [← Nat.succ_le_iff, ← Nat.lt_succ_iff] at h1 ⊢
            linarith
          · rw [← Nat.odd_iff] at h2; exact (Nat.odd_iff_eq_two_mul_add_one.mp h2).symm
        · rintro ⟨k, hk, rfl⟩
          simp; linarith
      · intro k hk
        simp only
        let j := k
        have h_odd : (2 * k + 1) % 2 = 1 := by simp
        have h_pow : M ^ (2 * k + 1) = (3 : ZMod 5) ^ k • M := by
          rw [pow_add, pow_mul, hM2, pow_one, Matrix.smul_mul, Matrix.one_mul]
        rw [h_pow]
        simp [M]

  rw [← hV_val] at h
  let Y := X ^ 2
  have hY : Y = !![4, 1; 2, 4] := by
    rw [pow_two, add_mul, mul_add, mul_add, mul_one, one_mul, hM2]
    ext i j; fin_cases i <;> fin_cases j <;> simp [M, Matrix.add_apply, Matrix.smul_apply] <;> rfl
    
  have hY3 : Y ^ 3 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    rw [pow_three, hY]; ext i j; fin_cases i <;> fin_cases j <;> simp [Matrix.mul_apply, Matrix.smul_apply] <;> rfl

  have h_rec : ∀ m, V (m + 3) = (3 : ZMod 5) • V m := by
    intro m
    simp only [V]
    have : 2 * (m + 3) + 1 = (2 * m + 1) + 6 := by ring
    rw [this, pow_add, show 6 = 2 * 3 by rfl, pow_mul, ←hY, hY3]
    simp [Matrix.smul_mul]

  have h_nz : ∀ m, V m 1 0 ≠ 0 := by
    intro m
    induction m using Nat.strong_induction_on with
    | h k ih =>
      if hk : k < 3 then
        fin_cases k
        · simp [V, X, M]
        · simp [V, X, M, hY]; rw [pow_add, pow_one, ←hY]; native_decide
        · simp [V, X, M, hY]; rw [pow_add, show 5 = 2*2+1 by rfl, pow_add, pow_mul, ←hY]; native_decide
      else
        let k' := k - 3
        have : k = k' + 3 := (Nat.sub_eq_iff_eq_add (le_of_not_lt hk)).mp rfl
        rw [this, h_rec]
        intro hz
        apply ih k' (Nat.sub_lt (le_of_not_lt hk) (by decide))
        simpa using hz
        
  exact h_nz n h
