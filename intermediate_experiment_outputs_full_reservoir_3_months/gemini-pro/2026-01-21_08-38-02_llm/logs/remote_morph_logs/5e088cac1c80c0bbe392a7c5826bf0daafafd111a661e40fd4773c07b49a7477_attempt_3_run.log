  let C (p : ℕ) : ZMod 5 := ∑ k ∈ Finset.range (p + 1), (p.choose (2 * k)) * 3 ^ k
  have h_rec (p : ℕ) : S (p + 1) = S p + C p ∧ C (p + 1) = C p + 3 * S p := by
    constructor
    · simp only [S, C]
