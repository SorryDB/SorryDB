theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  -- We work in ZMod 5
  intro h_div
  rw [← ZMod.int_cast_zmod_eq_zero_iff_dvd] at h_div
  push_cast at h_div
  -- 2^3 = 8 ≡ 3 (mod 5)
  have h_pow : (2 : ZMod 5) ^ 3 = 3 := by norm_num
  simp_rw [h_pow] at h_div
  
  -- Define the matrix M = [[1, 3], [1, 1]] corresponds to 1 + √3
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let m := 2 * n + 1
  
  -- The sum is exactly the (1,0) entry of M^m
  -- M = I + J where J^2 = 3I. Binomial expansion gives the sum.
  have h_sum : ∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k = (M ^ m) 1 0 := by
    let J : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
    have hM : M = 1 + J := by ext i j; fin_cases i <;> fin_cases j <;> rfl
    have hJ2 : J ^ 2 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
      ext i j; fin_cases i <;> fin_cases j <;> simp [J, Matrix.mul_apply] <;> norm_num
    
    rw [hM, add_pow]
    simp only [Matrix.one_pow, Matrix.smul_one_mul, mul_one]
    rw [Finset.sum_apply]
    
    -- Filter terms: (J^k) 1 0 is non-zero only for odd k
    let f : ℕ → ZMod 5 := fun k => (m.choose k) * (J ^ k) 1 0
    trans ∑ k ∈ Finset.range (m + 1), f k
    · rfl
    
    rw [← Finset.sum_filter_add_sum_filter_not (Finset.range (m + 1)) (Odd)]
    have h_even : ∀ k ∈ Finset.range (m + 1), ¬Odd k → f k = 0 := by
      intros k _ h_even
      simp only [f]
      rw [Nat.odd_iff_not_even] at h_even; simp at h_even
      rcases h_even with ⟨j, rfl⟩
      rw [pow_mul, hJ2, one_smul, Matrix.smul_pow, Matrix.one_pow, Matrix.smul_apply, Matrix.one_apply]
      simp
    
    rw [Finset.sum_eq_zero h_even, zero_add]
    
    -- Map odd indices 2k+1 to k
    let g : ℕ ↪ ℕ := ⟨fun k => 2 * k + 1, fun a b h => by linarith⟩
    rw [Finset.sum_map (Finset.range (n + 1)) g f]
    · apply Finset.sum_congr
      · ext x; simp only [Finset.mem_map, Finset.mem_range, Finset.mem_filter]
        constructor
        · rintro ⟨a, ⟨ha, rfl⟩⟩; constructor
          · linarith
          · use a; ring
        · rintro ⟨hx, ⟨k, hk⟩⟩; use k; constructor
          · linarith
          · assumption
      · intros k hk
        simp only [f, g]
        rw [pow_add, pow_mul, hJ2, one_smul, pow_one]
        simp [Matrix.smul_pow, Matrix.smul_apply]
    · intros x _; simp
  
  rw [h_sum] at h_div
  
  -- Analyze the period of M^m
  -- M^6 = 3 * I
  have h_period : M ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    decide
  
  -- m is odd, so m = 6q + r with r ∈ {1, 3, 5}
  let r := m % 6
  have hm : m = 6 * (m / 6) + r := by apply Nat.div_add_mod
  rw [hm, pow_add, pow_mul, h_period] at h_div
  simp only [Matrix.smul_pow, Matrix.one_pow, Matrix.smul_mul, Matrix.one_mul, Matrix.smul_apply] at h_div
  
  -- 3^q is a unit, so (M^r) 1 0 must be 0
  have h_nonzero : (3 : ZMod 5) ^ (m / 6) ≠ 0 := pow_ne_zero _ (by norm_num)
  field_simp at h_div
  
  -- Check r ∈ {1, 3, 5}
  have h_r : r ∈ ({1, 3, 5} : Finset ℕ) := by
    have h_odd : m % 2 = 1 := by
      rw [Nat.add_mod, Nat.mul_mod]; norm_num
    rw [Nat.mod_def] at h_odd
    -- r % 2 = 1 and r < 6
    have hr6 : r < 6 := Nat.mod_lt _ (by norm_num)
    interval_cases r <;> try { contradiction } <;> simp
  
  fin_cases h_r
  · -- r = 1
    rw [pow_one] at h_div; simp at h_div; contradiction
  · -- r = 3
    have : M ^ 3 = !![0, 3; 1, 0] := by decide
    rw [this] at h_div; simp at h_div; contradiction
  · -- r = 5
    have : M ^ 5 = !![1, 2; 4, 1] := by decide
    rw [this] at h_div; simp at h_div; contradiction
