The IMO 1974 Problem 3 asks to prove that $5$ does not divide $\sum_{k=0}^n \binom{2n+1}{2k+1} 2^{3k}$.
This sum can be identified with the $(1,0)$ entry of the matrix power $M^{2n+1}$ where $M = \begin{pmatrix} 1 & 8 \\ 1 & 1 \end{pmatrix}$.
Working modulo 5, we have $M \equiv \begin{pmatrix} 1 & 3 \\ 1 & 1 \end{pmatrix} \pmod 5$.
We calculate the powers of this matrix modulo 5 and show that the $(1,0)$ entry is non-zero for all odd exponents. Specifically, the entry is zero if and only if the exponent is a multiple of 6, but $2n+1$ is never a multiple of 6.

```lean
theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let m := 2 * n + 1
  let M : Matrix (Fin 2) (Fin 2) ℤ := !![1, 8; 1, 1]
  
  -- The sum S is equal to the (1,0) entry of M^m
  let S := ∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1)) * 2 ^ (3 * k)
  have h_eq : (S : ℤ) = (M ^ m) 1 0 := by
    let B : Matrix (Fin 2) (Fin 2) ℤ := !![0, 8; 1, 0]
    have hM : M = 1 + B := by ext i j; fin_cases i <;> fin_cases j <;> rfl
    rw [hM, add_pow_of_commute (Commute.one_left B) m, Matrix.sum_apply]
    
    -- Identify the terms in the binomial expansion
    have term_eq (k : ℕ) : (m.choose k : ℤ) * (B ^ k) 1 0 = 
        if Odd k then (m.choose k : ℤ) * 8 ^ (k / 2) else 0 := by
      rcases Nat.odd_or_even k with ⟨j, rfl⟩ | ⟨j, rfl⟩
      · simp only [Odd, true_and]
        have hB_odd : (B ^ (2 * j + 1)) 1 0 = 8 ^ j := by
          rw [pow_succ', pow_mul]
          have hB2 : B ^ 2 = 8 • (1 : Matrix (Fin 2) (Fin 2) ℤ) := by
            ext i j; fin_cases i <;> fin_cases j <;> simp [B, Matrix.mul_apply] <;> rfl
          simp [hB2, Matrix.smul_mul, B]
        rw [hB_odd, Nat.add_div_two, Nat.mul_div_right _ (by decide), Nat.zero_add]
      · simp only [Odd, false_and, if_false]
        have hB_even : (B ^ (2 * j)) 1 0 = 0 := by
          rw [pow_mul]
          have hB2 : B ^ 2 = 8 • (1 : Matrix (Fin 2) (Fin 2) ℤ) := by
            ext i j; fin_cases i <;> fin_cases j <;> simp [B, Matrix.mul_apply] <;> rfl
          simp [hB2]
        rw [hB_even, mul_zero]

    rw [Finset.sum_congr rfl (fun k _ => term_eq k), ← Finset.sum_filter_ne_zero]
    apply Finset.sum_bij (fun k _ => 2 * k + 1)
    · intro k hk; simp at hk ⊢; constructor <;> omega
    · intro k hk; simp; rw [pow_mul]; rfl
    · intro x y _ _ h; omega
    · intro b hb
      simp at hb; by_contra h; rw [Finset.mem_filter] at hb; simp [Odd] at hb
      rcases hb.2.1 with ⟨j, rfl⟩
      apply h; use j; simp at hb ⊢; omega

  -- Proof by contradiction modulo 5
  rw [← Int.mod_eq_zero_of_dvd, ← Int.cast_zero (R := ZMod 5)]
  intro h_zero
  have h_mod : ((M ^ m) 1 0 : ZMod 5) = 0 := by rw [← h_eq, Int.cast_natCast]; exact h_zero

  let M5 : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  have hM_mod : (M ^ m).map (Int.cast : ℤ → ZMod 5) = M5 ^ m := by
    rw [Matrix.map_pow]; congr; ext i j; fin_cases i <;> fin_cases j <;> simp [M, M5]; rfl
  rw [← Matrix.map_apply, hM_mod] at h_mod
  
  -- Periodicity of the sequence (M5^k)_{1,0}
  let u (k : ℕ) := (M5 ^ k) 1 0
  have h_period (k) : u (k + 6) = 3 * u k := by
    have h6 : M5 ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by native_decide
    simp [u, pow_add, h6, Matrix.scalar_apply]
    
  have h_u_zero (k) : u k = 0 ↔ k % 6 = 0 := by
    induction k using Nat.strong_induction_on with | h k ih =>
    if hk : k < 6 then interval_cases k <;> native_decide else
    rw [← Nat.sub_add_cancel (le_of_not_lt hk : 6 ≤ k)] at *
    rw [h_period, mul_eq_zero]
    simp; rw [ih (k-6) (Nat.sub_lt (by omega) (by decide))]; omega

  -- m = 2n + 1 is odd, so m % 6 != 0
  have h_contra : m % 6 = 0 := (h_u_zero m).mp h_mod
  omega
