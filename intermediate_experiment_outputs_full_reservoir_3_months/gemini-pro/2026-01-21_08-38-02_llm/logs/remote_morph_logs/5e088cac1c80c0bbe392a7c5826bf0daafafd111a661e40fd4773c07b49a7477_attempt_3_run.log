theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  let R := ZMod 5
  -- Map the sum to ZMod 5
  let S_nat := ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * 2 ^ (3 * k)
  have h_mod : (S_nat : R) = 0 := by
    rw [← ZMod.int_cast_zmod_eq_zero_iff_dvd] at h
    exact h
  
  let S : R := ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * 3 ^ k
  have h_eq : (S_nat : R) = S := by
    simp only [S, S_nat, Nat.cast_sum, Nat.cast_mul, Nat.cast_pow, Nat.cast_ofNat]
    refine Finset.sum_congr rfl fun k _ => ?_
    congr 1
    norm_num [pow_mul]
  rw [h_eq] at h_mod

  let M : Matrix (Fin 2) (Fin 2) R := !![1, 3; 1, 1]
  let A : Matrix (Fin 2) (Fin 2) R := !![0, 3; 1, 0]
  have hM : M = 1 + A := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  have hA2 : A ^ 2 = 3 • (1 : Matrix (Fin 2) (Fin 2) R) := by ext i j; fin_cases i <;> fin_cases j <;> rfl

  have h_sum : (M ^ (2 * n + 1)) 1 0 = S := by
    rw [hM, add_pow]
    simp only [Matrix.sum_apply, Matrix.smul_apply, Matrix.one_apply, Matrix.pow_apply]
    
    let range_even := (Finset.range (2 * n + 2)).filter (λ x => x % 2 = 0)
    let range_odd := (Finset.range (2 * n + 2)).filter (λ x => x % 2 = 1)
    
    have h_split : Finset.range (2 * n + 2) = range_even ∪ range_odd := by
      ext x
      simp only [Finset.mem_union, Finset.mem_filter, Finset.mem_range]
      constructor <;> intro h <;> simp_all
      omega

    have h_disj : Disjoint range_even range_odd := by
      rw [Finset.disjoint_filter]
      intro x _ h1 h2
      omega

    rw [Finset.sum_union h_disj]
    
    have h_zeros : ∑ x ∈ range_even, (Nat.choose (2 * n + 1) x) * (A ^ x) 1 0 = 0 := by
      apply Finset.sum_eq_zero
      intros x hx
      simp only [Finset.mem_filter] at hx
      obtain ⟨k, rfl⟩ := Nat.exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero hx.2)
      rw [pow_mul, hA2]
      simp
      
    rw [h_zeros, zero_add]
    
    rw [← Finset.sum_image]
    · refine Finset.sum_congr ?_ (λ k _ => ?_)
      · ext x
        simp only [Finset.mem_image, Finset.mem_filter, Finset.mem_range]
        constructor
        · rintro ⟨k, hk, rfl⟩; simp at hk; constructor; linarith; simp
        · rintro ⟨hx1, hx2⟩
          use (x - 1) / 2
          constructor
          · linarith
          · omega
      · rw [pow_succ', pow_mul, hA2]
        simp [A]
    · intros x _ y _ h; linarith

  have h_nz : (M ^ (2 * n + 1)) 1 0 ≠ 0 := by
    let m := 2 * n + 1
    have hm : m % 2 = 1 := by omega
    have h_per : M ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) R) := by revert n; decide
    
    let q := m / 6
    let r := m % 6
    have : m = 6 * q + r := (Nat.div_add_mod m 6).symm
    rw [this, pow_add, pow_mul, h_per]
    simp only [Matrix.smul_pow, Matrix.one_pow, Matrix.smul_mul, Matrix.one_mul, Matrix.smul_apply, smul_eq_mul]
    
    apply mul_ne_zero (by apply pow_ne_zero; decide)
    
    interval_cases r
    · decide
    · omega
    · decide
    · omega
    · decide
    · omega

  rw [h_sum] at h_nz
  contradiction
