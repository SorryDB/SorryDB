      rw [Finset.sum_range_succ']
      simp only [Nat.choose_zero_succ, Nat.cast_zero, zero_mul, add_zero, pow_zero]
      have : ∀ k ∈ Finset.range (p + 1), ((p + 1).choose (2 * k + 1) : ZMod 5) * 3 ^ k = 
