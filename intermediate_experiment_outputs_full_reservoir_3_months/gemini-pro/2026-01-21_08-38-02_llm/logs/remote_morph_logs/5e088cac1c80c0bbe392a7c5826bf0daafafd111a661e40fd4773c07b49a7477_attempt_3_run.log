theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  let R := ZMod 5
  -- Translate the divisibility hypothesis to an equation in ZMod 5
  have h_eq : ∑ k in Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) : R) * 3 ^ k = 0 := by
    rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h
    convert h using 2
    rw [Nat.cast_mul, Nat.cast_pow]
    congr
    norm_num
  
  -- Define the transition matrix M
  let M : Matrix (Fin 2) (Fin 2) R := !![1, 3; 1, 1]
  let m := 2 * n + 1
  
  -- Prove that the (1,0) entry of M^m corresponds to the sum
  have h_pow : (M ^ m) 1 0 = ∑ k in Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) : R) * 3 ^ k := by
    let N : Matrix (Fin 2) (Fin 2) R := !![0, 3; 1, 0]
    have hM : M = 1 + N := by ext i j; fin_cases i <;> fin_cases j <;> rfl
    have hN2 : N ^ 2 = 3 • 1 := by ext i j; fin_cases i <;> fin_cases j <;> simp <;> ring
    
    -- Expand M^m = (I + N)^m
    rw [hM, add_pow, Matrix.sum_apply]
    
    -- Analyze the terms (N^k) 1 0
    have h_Nk : ∀ k, (N ^ k) 1 0 = if Odd k then 3 ^ (k / 2) else 0 := by
      intro k
      induction k using Nat.strong_induction_on with | h k ih =>
      match k with
      | 0 => simp
      | 1 => simp
      | k+2 => 
        rw [pow_add, hN2, Matrix.mul_smul, Matrix.one_mul, Matrix.smul_apply, ih k (lt_add_of_pos_right _ (by norm_num))]
        simp [Nat.add_mod]
        by_cases hk : Odd k
        · have : Odd (k+2) := by simp [hk]
          simp [hk, this]; ring
        · have : ¬ Odd (k+2) := by simp [hk]
          simp [hk, this]

    -- Relate the expansion sum to the target sum
    let f (k : ℕ) := ((m.choose k : R) * (N ^ k) 1 0)
    trans ∑ k in Finset.range (m + 1), f k
    · apply Finset.sum_congr rfl; intros; rfl
    
    -- Terms with even k are zero
    rw [← Finset.sum_filter_add_sum_filter_not (Finset.range (m + 1)) Odd]
    have : ∑ k in Finset.filter (¬Odd ·) (Finset.range (m + 1)), f k = 0 := by
      apply Finset.sum_eq_zero
      intro k hk
      rw [Finset.mem_filter] at hk
