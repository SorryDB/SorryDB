theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  -- Convert the problem to ZMod 5
  let S : ZMod 5 := ∑ k ∈ Finset.range (n + 1), (2 * n + 1).choose (2 * k + 1) * 3 ^ k
  have hS : S = 0 := by
    rw [← ZMod.int_cast_zmod_eq_zero_iff_dvd] at h
    convert h using 2
    push_cast; apply Finset.sum_congr rfl
    intro k _; congr 1; norm_num; ring
  
  -- Define matrices corresponding to 1 and sqrt(3) in ZMod 5
  let I : Matrix (Fin 2) (Fin 2) (ZMod 5) := 1
  let A : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  let M := I + A

  -- Properties of A
  have hA2 : A ^ 2 = (3 : ZMod 5) • I := by
    ext i j; fin_cases i <;> fin_cases j <;> simp [A, I]; rfl

  have hA_pow (k : ℕ) : A ^ k = if Even k then (3 : ZMod 5) ^ (k / 2) • I else (3 : ZMod 5) ^ (k / 2) • A := by
    induction k with
    | zero => simp [I]
    | succ k ih =>
      by_cases hk : Even k
      · simp [hk, ih]; rw [not_even_iff_odd_succ.2 (Even.succ_odd hk)]; simp
      · simp [hk, ih]; rw [even_iff_not_odd.2 hk];
        have he : Even (k + 1) := Nat.odd_add_one.mp (Nat.not_even_iff_odd.mp hk)
        simp [he]
        rw [← mul_smul, ← Matrix.mul_assoc, hA2, Matrix.mul_smul, Matrix.one_mul, smul_smul, mul_comm]
        congr; rw [← pow_succ]; congr; omega

  -- The sum S corresponds to the (1,0) entry of M^(2n+1)
  have h_eq : (M ^ (2 * n + 1)) 1 0 = S := by
    rw [add_pow]
    let f (k : ℕ) := (2 * n + 1).choose k * (A ^ k) 1 0
    trans ∑ k ∈ Finset.range (2 * n + 2), f k
    · rfl
    -- Filter even terms (which are 0) and map odd terms
    rw [← Finset.sum_filter_add_sum_filter_not (·.Even)]
    have h_even : ∀ k ∈ Finset.range (2 * n + 2), Even k → f k = 0 := by
      intro k _ hk; simp [f, hA_pow k, hk]; rfl -- I is diagonal, so (1,0) is 0
    simp [h_even]
    -- Map k = 2j+1
    let g : ℕ ↪ ℕ := ⟨fun j => 2 * j + 1, fun _ _ => by omega⟩
    rewrite [Finset.sum_bij' (fun j _ => 2 * j + 1) _ (fun k _ => k / 2) _ _ _ _]
    · apply Finset.sum_congr rfl
      intro j hj
      simp [f, hA_pow (2 * j + 1), Nat.not_even_iff_odd.2 ⟨j, rfl⟩]
      have : (2 * j + 1) / 2 = j := by omega
      rw [this]; simp [A]; ring
    · intro j hj; simp at hj ⊢; omega
    · intro k hk hodd; simp at hk ⊢; rw [Nat.not_even_iff_odd] at hodd; obtain ⟨j, rfl⟩ := hodd; use j; omega
    · intro k hk hodd; simp at hk ⊢; rw [Nat.not_even_iff_odd] at hodd; obtain ⟨j, rfl⟩ := hodd; omega
    · intro j hj; simp

  rw [h_eq] at hS
  
  -- Analyze the sequence v_n = M^(2n+1)
  let T := M ^ 2
  have hT : T = !![4, 1; 2, 4] := by
    simp [M, A, I, add_sq, hA2]; ext i j; fin_cases i <;> fin_cases j <;> simp; rfl
  
  let v (k : ℕ) := (M ^ (2 * k + 1)) 1 0
  
  -- Check periodicity of T
  have hT6 : T ^ 6 = 4 • I := by
    have hT2 : T ^ 2 = !![4, 3; 1, 4] := by
      rw [pow_two]; simp [T]; ext i j; fin_cases i <;> fin_cases j <;> simp <;> rfl
    have hT3 : T ^ 3 = !![0, 3; 1, 0] := by -- T^3 = A
      rw [pow_succ', hT2]; simp [T]; ext i j; fin_cases i <;> fin_cases j <;> simp <;> rfl
    rw [pow_mul, hT3, pow_two, hA2]; rfl

  -- Period is 12 for M, 6 for T. T^6 = -I.
  -- v (n+6) = - v n.
  -- Check first 6 values are non-zero.
  have h_nonzero : ∀ k < 6, v k ≠ 0 := by
    decide
  
  let r := n % 6
  have hr : r < 6 := Nat.mod_lt _ (by norm_num)
  have h_rel : v n = if (n / 6) % 2 = 0 then v r else -v r := by
    let q := n / 6
    have hn : n = 6 * q + r := (Nat.div_add_mod n 6).symm
    rw [hn]
    have h_step (q : ℕ) : v (6 * q + r) = (4 : ZMod 5) ^ q * v r := by
      induction q with
      | zero => simp
      | succ q ih =>
        simp [v, pow_add, mul_add, M]
        rw [show 2 * (6 * (q + 1) + r) + 1 = 2 * (6 * q + r) + 1 + 12 by ring]
        rw [pow_add, show M ^ 12 = (M^2)^6 by ring, hT6]
        rw [Matrix.smul_mul, Matrix.one_mul]
        simp [v] at ih
        rw [ih]; ring
    rw [h_step]; simp
    by_cases hq : q % 2 = 0
    · rw [Nat.even_iff.2 hq] at hq; obtain ⟨k, rfl⟩ := hq
      rw [pow_mul, show (4 : ZMod 5)^2 = 1 by rfl, one_pow, one_mul]; simp
    · rw [Nat.odd_iff.2 (Nat.mod_two_ne_zero.1 hq)] at hq; obtain ⟨k, rfl⟩ := hq
      rw [pow_add, pow_mul, show (4 : ZMod 5)^2 = 1 by rfl, one_pow, one_mul, pow_one]; simp; rfl
  
  rw [h_rel] at hS
  split_ifs at hS
  · exact h_nonzero r hr hS
  · apply h_nonzero r hr; rw [neg_eq_zero] at hS; exact hS
