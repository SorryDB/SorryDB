    rw [add_pow_of_commute (Commute.one_left M)]
    simp only [Matrix.sum_apply, Matrix.smul_apply, Matrix.one_apply_ne]
    let f (i : ℕ) := (m.choose i : ZMod 5) * (M ^ i) 1 0
    change _ = ∑ i in range (m + 1), f i
    
    have h_odd : ∑ i in range (m + 1), f i = ∑ k in range (n + 1), f (2 * k + 1) := by
      rw [← sum_filter_count (λ i => i % 2 = 1), ← sum_filter_count (λ i => i % 2 = 0)]
      have h_even_zero : ∀ i ∈ filter (λ i => i % 2 = 0) (range (m + 1)), f i = 0 := by
        intro i hi
        mem_simp at hi
        obtain ⟨_, he⟩ := hi
        obtain ⟨k, rfl⟩ := Nat.dvd_iff_mod_eq_zero.2 he
        simp [f, hMk_even]
      rw [sum_eq_zero h_even_zero, add_zero]
      refine sum_bij (λ k _ => 2 * k + 1) ?_ ?_ ?_ ?_
      · intro k hk
