theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  rw [← Int.natCast_dvd_natCast, ← ZMod.int_cast_zmod_eq_zero_iff_dvd]
  push_cast
  norm_num

  let K : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  have hK2 : K ^ 2 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by decide
  let M := (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) + K

  have h_sum : (M ^ (2 * n + 1)) 1 0 = ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1) : ZMod 5) * 3 ^ k := by
    rw [add_pow_of_commute _ _ (Commute.one_left K)]
    simp only [Matrix.sum_apply, Matrix.smul_apply, Matrix.one_apply, Matrix.pow_apply]
    let f (j : ℕ) := (Nat.choose (2 * n + 1) j : ZMod 5) * (K ^ j) 1 0
    trans ∑ j ∈ Finset.range (2 * n + 2), f j
    · apply Finset.sum_congr rfl; intros; rfl
    rw [← Finset.sum_filter_add_sum_filter_not (· % 2 = 1)]
    have h_even : ∑ j ∈ Finset.filter (¬· % 2 = 1) (Finset.range (2 * n + 2)), f j = 0 := by
      apply Finset.sum_eq_zero
      intro x hx
      simp only [Finset.mem_filter, not_eq_eq] at hx
      obtain ⟨_, heven⟩ := hx
      rw [Nat.mod_two_ne_one] at heven
      have : (K ^ x) 1 0 = 0 := by
        obtain ⟨k, rfl⟩ := Nat.exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero heven)
        rw [pow_mul, hK2, smul_pow, Matrix.smul_apply, Matrix.one_apply, smul_zero]
      simp [f, this]
    rw [h_even, add_zero]
    apply Finset.sum_bij (λ k _ ↦ 2 * k + 1)
    · intros k hk; simp only [Finset.mem_range] at hk ⊢; omega
    · intros k hk; simp only [Finset.mem_range] at hk
      simp only [Nat.add_mod, Nat.mul_mod_right, zero_add, Nat.mod_self, eq_self, true_and]
    · intros k hk
      have h_odd : (2 * k + 1) % 2 = 1 := by omega
      have hK_odd : (K ^ (2 * k + 1)) 1 0 = 3 ^ k := by
        rw [pow_succ, pow_mul, hK2, smul_pow, Matrix.mul_eq_mul, Matrix.smul_mul, Matrix.one_mul]
        simp [K]
      simp [f, hK_odd]
    · intros i hi hi_odd
      exists i / 2
      simp only [Finset.mem_range, Finset.mem_filter] at hi
      constructor
      · omega
      · apply Nat.div_add_mod i 2

  rw [← h_sum]
  have h_period : M ^ 24 = 1 := by decide
  let m := (2 * n + 1) % 24
  have hm_odd : m % 2 = 1 := by
    have : (2 * n + 1) % 2 = 1 := by norm_num
    rw [← Nat.mod_mod_of_dvd (2 * n + 1) (by norm_num : 2 ∣ 24)] at this
    exact this
  
  have h_pow : M ^ (2 * n + 1) = M ^ m := by
    have : 2 * n + 1 = 24 * ((2 * n + 1) / 24) + m := by exact (Nat.div_add_mod (2 * n + 1) 24).symm
    rw [this, pow_add, pow_mul, h_period, one_pow, one_mul]
  
  rw [h_pow]
  generalize h_m_val : m = m_val at hm_odd ⊢
  interval_cases m_val <;> try { simp at hm_odd } <;> decide
