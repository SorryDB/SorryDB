theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  -- Convert divisibility by 5 to equality in ZMod 5
  intro h
  rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h
  -- Define the matrix A corresponding to 1 + √3
  let A : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  -- A = I + M
  have hA : A = 1 + M := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  
  -- Key Identity: The sum S_n is the (1,0) entry of A^(2n+1)
  have h_sum : (A ^ (2 * n + 1)) 1 0 = ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (3 : ZMod 5) ^ k := by
    rw [hA, add_pow]
    -- M^k simplifies to scalar multiples of I or M
    have hMk : ∀ k, M ^ k = if k % 2 = 0 then (3 : ZMod 5)^(k/2) • (1 : Matrix _ _ _) else (3 : ZMod 5)^(k/2) • M := by
      intro k
      induction' k with k ih
      · simp
      · rw [pow_succ, ih]; split_ifs with h_even h_odd
        · -- k even implies k+1 odd
          have hk2 : (k + 1) / 2 = k / 2 := Nat.div_eq_of_eq_mul_left (Nat.zero_lt_two) (by omega)
          simp [hk2]; rw [h_even]; simp
        · -- k odd implies k+1 even
          have hk2 : (k + 1) / 2 = k / 2 + 1 := by 
             rw [Nat.div_eq_sub_div (by omega) (by omega)]; simp; omega
          simp [hk2]; rw [pow_succ', mul_smul, ← Matrix.mul_eq_mul, show M * M = 3 • 1 by ext i j; fin_cases i <;> fin_cases j <;> simp]
          simp
    
    -- Evaluate the sum at (1,0)
    rw [Finset.sum_range_succ'] -- Adjustment for range might be needed depending on lean version, but let's stick to functional expansion
    -- Actually, direct expansion:
    trans ∑ k ∈ Finset.range (2 * n + 2), ((Nat.choose (2 * n + 1) k) • M ^ k) 1 0
    · simp [Matrix.sum_apply]
    · -- Filter odd k
      rw [← Finset.sum_filter_add_sum_filter_not (Finset.range (2*n+2)) (Odd)]
      simp only [hMk]
      have h_even_zero : ∀ x ∈ Finset.filter (¬Odd ·) (Finset.range (2 * n + 2)), ((Nat.choose (2 * n + 1) x) • ((3 : ZMod 5) ^ (x / 2) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)))) 1 0 = 0 := by
        intros x hx; simp [Matrix.one_apply]
      have h_odd_val : ∀ x ∈ Finset.filter Odd (Finset.range (2 * n + 2)), ((Nat.choose (2 * n + 1) x) • ((3 : ZMod 5) ^ (x / 2) • M)) 1 0 = (Nat.choose (2 * n + 1) x) * (3 : ZMod 5) ^ (x / 2) := by
        intros x hx; simp [Matrix.smul_apply, M]
      rw [Finset.sum_eq_zero h_even_zero, zero_add]
      -- Map odd indices 2k+1
      let f : ℕ ↪ ℕ := ⟨fun k => 2 * k + 1, fun a b h => by linarith⟩
      rw [Finset.sum_map (Finset.range (n+1)) f (fun x => ((Nat.choose (2 * n + 1) x) • M ^ x) 1 0)]
      congr
      ext x
      simp only [Finset.mem_map, Finset.mem_range, Finset.mem_filter, Odd]
      constructor
      · intro ⟨a, ha, heq⟩; rw [←heq]; simp at ha; constructor; omega; use a; rfl
      · intro ⟨h1, ⟨k, hk⟩⟩; use k; simp; split_and <;> omega

  -- Use the property that 2^3 = 8 = 3 mod 5
  have h_val : (A ^ (2 * n + 1)) 1 0 = 0 := by
    rw [h_sum]
    convert h using 2
    norm_cast; simp [pow_mul]; rfl

  -- Contradiction via periodicity of powers of A
  -- A^6 = 3 * I
  have hA6 : A ^ 6 = 3 • 1 := by
    have hA2 : A ^ 2 = !![4, 1; 2, 4] := by ext i j; fin_cases i <;> fin_cases j <;> simp
    have hA3 : A ^ 3 = !![0, 3; 1, 0] := by 
      rw [pow_succ, hA2]; ext i j; fin_cases i <;> fin_cases j <;> simp
    rw [show 6 = 3 * 2 by rfl, pow_mul, hA3]
    ext i j; fin_cases i <;> fin_cases j <;> simp

  -- Check small powers to show (A^k) 1 0 = 0 iff 6 | k
  have h_scalar : ∀ k, (A ^ k) 1 0 = 0 ↔ 6 ∣ k := by
    intro k
    let r := k % 6
    have hk : k = 6 * (k / 6) + r := by exact (Nat.div_add_mod k 6).symm
    rw [hk, pow_add, pow_mul, hA6]
    simp [Matrix.smul_apply, Matrix.one_apply]
    have hr : r < 6 := Nat.mod_lt k (by norm_num)
    interval_cases r <;> simp <;>
    (try rw [show (0 : ZMod 5) = 0 by rfl]) <;> 
    (try { rw [pow_one]; rfl }) <;>
    (try { have : A^2 = !![4, 1; 2, 4] := by ext i j; fin_cases i <;> fin_cases j <;> simp; rw [this]; rfl }) <;>
    (try { have : A^3 = !![0, 3; 1, 0] := by ext i j; fin_cases i <;> fin_cases j <;> simp; rw [this]; rfl }) <;>
    (try { have : A^4 = !![3, 4; 1, 3] := by ext i j; fin_cases i <;> fin_cases j <;> simp; rw [this]; rfl }) <;>
    (try { have : A^5 = !![1, 2; 4, 1] := by ext i j; fin_cases i <;> fin_cases j <;> simp; rw [this]; rfl })

  rw [h_scalar] at h_val
  -- 2n+1 is odd, so not divisible by 6
  have h_contra : ¬ 6 ∣ (2 * n + 1) := by
    intro hc
    have : 2 ∣ (2 * n + 1) := Dvd.dvd.trans (by norm_num) hc
    have : 2 ∣ 1 := by omega
    norm_num at this
  exact h_contra h_val
