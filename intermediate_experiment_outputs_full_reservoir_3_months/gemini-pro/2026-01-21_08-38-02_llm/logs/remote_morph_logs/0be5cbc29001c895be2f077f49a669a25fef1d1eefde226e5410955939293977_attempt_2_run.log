def eval : @Dist n → @OSequence n → @Form n → Prop
  | _, _, .Top => True
  | S, σ, .Neg φ => ¬ eval S σ φ
  | S, σ, .Has a (j, k) => (j, k) ∈ resultSet a S σ
  | S, σ, .Con φ ψ => eval S σ φ ∧ eval S σ ψ
  | S, σ, .K a φ => ∀ T, ∀ τ , (he : equiv a (S,⟨σ,rfl⟩) (T,τ)) → eval T τ φ
