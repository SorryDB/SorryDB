/-- Lemma 11 -/
lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ,o⟩
  induction σ generalizing S a b o
  case nil =>
    unfold eval eval eval at a_kv_b
    simp only [not_and_or, not_not] at a_kv_b
    rcases a_kv_b with h|h
    all_goals
      simp_all [eval]
      by_cases h_eq : b = a
      · subst h_eq; simp
      · exfalso
        have h_false := h (S.switch b) ⟨[], maxOne_nil⟩ (by simp) (by simp [Dist.switch, equiv]; grind)
        simp [Dist.switch] at h_false
        exact h_false
  case cons C σ IH =>
    let σ' : OSequence := ⟨σ, ⁻o⟩
    have IH' := fun a b => IH (⁻o) (a:=a) (b:=b)
    cases ra : roleOfIn a C
    case Other =>
      rw [not_in_call_then_invariant_resultSet ra]
      rw [not_in_call_then_invariant_kv ra] at a_kv_b
      exact IH' a b S a_kv_b
    all_goals
      by_cases known_before : S⌈σ'⌉ ⊧ Kv a b
      · -- Case: Agent already knew the secret.
        have ⟨in_set, not_in_set⟩ := IH' a b S known_before
        let C_copy := C; cases C <;> simp_all [ra] <;> subst ra
        all_goals
          simp only [resultSet, Set.mem_diff, Set.mem_union, Set.mem_setOf_eq]
          refine ⟨⟨Or.inl ⟨in_set, ?_⟩, ?_⟩, ?_⟩
          · -- (b, S b) not deleted
            intro h_del
            simp [Set.mem_setOf_eq] at h_del
            have h_s := h_del S ⟨σ, ⁻o⟩ C_copy rfl (by simp) rfl
            unfold eval at h_s; simp at h_s; contradiction
          · -- (b, ! S b) not in result
            intro h_in; rcases h_in with ⟨(h_old | h_new), h_del⟩
            · contradiction
            · rcases h_new with ⟨h_in_other, h_not_refused⟩
              apply h_not_refused
              rcases known_before with (h|h)
              · simp at h; convert h; simp
              · simp at h; exfalso; have := true_of_knowldege h; simp at this; rw [stubbornness] at this; simp at this
          · -- (b, S b) not refused
            intro h_ref
            rcases known_before with (h|h)
            · simp at h; have := true_of_knowldege h_ref; simp at this; rw [stubbornness] at this; simp at this
            · simp at h; have := true_of_knowldege h; simp at this; rw [stubbornness] at this; simp at this
      · -- Case: Agent learns the secret in this step.
        -- Since a learns Kv a b, a must distinguish b = S b from b = ! S b.
        -- This implies that the call must have conveyed the correct value (b, S b) and not the error.
        -- If (b, !S b) were in the result, a would consider b = !S b possible, contradicting Kv a b.
        -- We trust aesop/grind to handle the contradictions derived from a_kv_b in error cases.
        aesop
