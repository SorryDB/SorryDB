/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_isOpen_singleton_one]
  let U := Metric.ball (1 : Circle) 1
  have : IsOpen {f : PontryaginDual M | f '' Set.univ ⊆ U} :=
    ContinuousMap.isOpen_setOf_maps_to isCompact_univ Metric.isOpen_ball
  convert this
  ext f; simp [U, Metric.mem_ball, dist_self, zero_lt_one]
  refine ⟨fun h ↦ ContinuousMonoidHom.ext fun x ↦ ?_, by rintro rfl x; simp [norm_zero, zero_lt_one]⟩
  by_contra hx
  have step : ∀ z : Circle, ‖(z:ℂ) - 1‖ < 1 → ‖(z^2:ℂ) - 1‖ ≥ 1.5 * ‖(z:ℂ) - 1‖ := by
    intro z hz
    have : ‖(z:ℂ) + 1‖ ^ 2 = 4 - ‖(z:ℂ) - 1‖ ^ 2 := by
      simpa [Complex.norm_sq_add_norm_sq_sub, z.abs_coe] using by norm_num
    rw [sq_sub_sq, Complex.norm_mul]; nlinarith
  have : ∃ n : ℕ, 2 < ‖((f x) ^ 2 ^ n : ℂ) - 1‖ := by
    obtain ⟨n, hn⟩ := exists_lt_mul_of_lt_one_of_pos (by norm_num : (1 : ℝ) < 1.5)
      (norm_pos_iff.mpr (sub_ne_zero.mpr (Circle.coe_ne_coe.mpr hx)))
    use n; apply lt_of_lt_of_le hn
    induction n with | zero => simp | succ n ih =>
      rw [pow_succ, pow_mul, pow_succ']; linarith [step _ (h (x ^ 2 ^ n)), ih]
  rcases this with ⟨n, hn⟩
  linarith [hn, norm_sub_le (f x ^ 2 ^ n : ℂ) 1]
