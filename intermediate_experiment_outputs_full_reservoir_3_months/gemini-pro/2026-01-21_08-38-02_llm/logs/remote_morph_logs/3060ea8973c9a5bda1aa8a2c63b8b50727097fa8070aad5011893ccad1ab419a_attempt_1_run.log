def matchingIndepMatroid (G : Graph α β) : IndepMatroid α where
  E := V(G)
  Indep := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
  indep_empty := by
    sorry
  indep_subset := by
    sorry
  indep_aug := by
    sorry
  indep_maximal := by
    intro X
    let P := fun S ↦ ∃ M, G.IsMatching M ∧ S ⊆ V(G, M)
    have h_zorn : ∀ C, C ⊆ {S | P S ∧ S ⊆ X} → IsChain (· ⊆ ·) C → ∃ U ∈ {S | P S ∧ S ⊆ X}, ∀ S ∈ C, S ⊆ U := by
      intro C hCX hChain
      refine ⟨⋃₀ C, ⟨?_, sUnion_subset fun s hs ↦ (hCX hs).2⟩, fun s hs ↦ subset_sUnion_of_mem hs⟩
      -- The union of a chain of matchable sets is matchable (finitary character of matching matroid).
      -- This requires compactness of matchings.
      sorry 
    obtain ⟨M, hM, hmax⟩ := zorn_subset_nonempty {S | P S ∧ S ⊆ X} h_zorn X ⟨∅, ⟨⟨∅, by simp [isMatching_iff], by simp⟩, by simp⟩⟩
    exact ⟨M, hM.1, fun I hI hMI => hmax I ⟨hI.1, hMI.trans hM.2⟩ hI.2 hMI⟩
