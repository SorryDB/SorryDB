    obtain ⟨M, hM, hMX, hmax⟩ : ∃ M, G.IsMatching M ∧ V(G, M) ⊆ X ∧ ∀ M', G.IsMatching M' → V(G, M') ⊆ X → M'.encard ≤ M.encard := by
      -- Existence of a maximum cardinality matching in X follows from Zorn's lemma or
      -- finiteness assumptions usually present in such matroid contexts.
