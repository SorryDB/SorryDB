    rintro I ⟨MI, hMI, hI⟩ hIX hsub
    rw [hI] at hsub ⊢
    have hle := hmax MI hMI hIX
    -- Assuming finite encard to deduce equality from subset and size inequality
    refine eq_of_subset_of_encard_eq hsub (le_antisymm hle (encard_le_encard hsub))
