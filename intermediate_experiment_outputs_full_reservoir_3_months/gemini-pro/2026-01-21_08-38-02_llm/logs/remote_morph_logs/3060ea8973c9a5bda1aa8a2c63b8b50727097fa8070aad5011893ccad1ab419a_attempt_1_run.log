    refine ⟨V(G, M), ⟨⟨M, hM, rfl⟩, hMX⟩, ?_⟩
    rintro J ⟨M', hM', hJeq⟩ hsub
    have hJX : V(G, M') ⊆ X := hJeq ▸ (by assumption)
    have hle : M'.encard ≤ M.encard := hmax M' hM' hJX
    -- Cardinality equality implies set equality for subsets (assuming finiteness for this exercise)
    have hcard_eq : V(G, M).encard = V(G, M').encard := by
      -- |V(M)| = 2|M| and |V(M')| = 2|M'|. |M'| ≤ |M| implies |V(M')| ≤ |V(M)|.
      -- Combined with V(M) ⊆ V(M'), this implies equality.
      sorry
    rw [← hJeq]
    exact hsub.antisymm (eq_of_subset_of_encard_le hsub hcard_eq.ge)
