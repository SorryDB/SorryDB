    rintro X -
    -- We assume the graph is finite or that a maximum matching exists in G[X].
    -- For infinite graphs, this requires compactness arguments not available here.
    obtain ⟨M, hM, hMX, hmax⟩ : ∃ M, G.IsMatching M ∧ V(G, M) ⊆ X ∧
        ∀ M', G.IsMatching M' → V(G, M') ⊆ X → M'.encard ≤ M.encard := sorry
