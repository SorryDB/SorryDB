section Indecomposable
variable {D : DirectSumDecomposition M}

/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `S` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D`. -/
@[nolint unusedArguments]
def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    simp only [Set.mem_iUnion] at hx
    rcases hx with ⟨N, hN, hx⟩
    let In := B N hN \ {x}
    let Out := ⋃ (M ∈ D) (hM : M ∈ D) (_ : M ≠ N), B M hM
    have h_subset : carrier \ {x} ⊆ Out ∪ In := by
      rintro y ⟨hy, hy_ne⟩
      simp only [Set.mem_iUnion] at hy
      rcases hy with ⟨M, hM, hy⟩
      by_cases h : M = N
      · subst h; right; exact ⟨hy, hy_ne⟩
      · left; simp only [Set.mem_iUnion]; exact ⟨M, hM, h, hy⟩
    have h_le : a ≤ sSup Out ⊔ sSup In := (le_trans ha' (sSup_le_sSup h_subset)).trans sSup_union.le
    have h_in_le_N : sSup In ≤ N := (sSup_le_sSup (Set.diff_subset _ _)).trans (hB N hN).ge
    have h_x_le_N : x ≤ N := (le_sSup hx).trans (hB N hN).ge
    have h_disj_out : Disjoint (sSup Out) N := by
      have : sSup Out ≤ sSup (SetLike.coe D \ {N}) := by
        apply sSup_le
        simp only [Set.mem_iUnion, forall_exists_index, and_imp]
        intro y M hM h_ne hy
        exact le_sSup_of_le ⟨hM, h_ne⟩ ((le_sSup hy).trans (hB M hM).ge)
      exact Disjoint.mono_left this (D.sSupIndep' hN).symm
    have h_disj_in : Disjoint x (sSup In) := (hB' N hN).disjoint_sSup hx
    have h_mod : N ⊓ (sSup Out ⊔ sSup In) ≤ sSup In := by
      rw [inf_sup_eq_of_le_left h_in_le_N, h_disj_out.symm.eq_bot, bot_sup_eq]
    exact h_disj_in.le_bot_of_le ha (le_trans (le_inf (ha.trans h_x_le_N) h_le) h_mod)
  sSup_eq_top' := by
    simp_rw [sSup_iUnion, hB]
    exact (sSup_subtype D.carrier).trans D.sSup_eq_top
  not_bot_mem' := by
    simp only [Set.mem_iUnion, forall_exists_index]
    exact fun x N hN hx => hB'' N hN hx
