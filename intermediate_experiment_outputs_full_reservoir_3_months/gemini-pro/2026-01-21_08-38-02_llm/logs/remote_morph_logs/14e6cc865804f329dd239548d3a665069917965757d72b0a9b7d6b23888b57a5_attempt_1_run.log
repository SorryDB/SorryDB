section Indecomposable
variable {D : DirectSumDecomposition M}

/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `S` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D`. -/
@[nolint unusedArguments]
def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    simp only [Set.mem_iUnion] at hx
    rcases hx with ⟨Nx, hNx, hx⟩
    have hx_le_Nx : x ≤ Nx := (hB Nx hNx).symm ▸ le_sSup hx
    have h_disj_Nx : Disjoint Nx (sSup (SetLike.coe D \ {Nx})) := D.sSupIndep hNx
    have h_disj_x : Disjoint x (sSup (B Nx hNx \ {x})) := hB' Nx hNx hx
    rw [disjoint_iff_inf_le] at h_disj_Nx h_disj_x ⊢
    refine le_trans (le_inf ha ha') ?_
    rw [← inf_of_le_left hx_le_Nx]
    refine le_trans (le_inf inf_le_left (inf_le_inf_left _ (sSup_le fun y hy ↦ ?_))) ?_
    · obtain ⟨hy_in, hy_ne⟩ := hy
      simp only [Set.mem_iUnion] at hy_in
      rcases hy_in with ⟨Ny, hNy, hy_in⟩
      by_cases h_eq : Ny = Nx
      · subst h_eq; left; exact le_sSup ⟨hy_in, hy_ne⟩
      · right; apply le_trans ((hB Ny hNy).symm ▸ le_sSup hy_in)
        exact le_sSup ⟨hNy, h_eq⟩
    · rw [inf_sup_of_le]
