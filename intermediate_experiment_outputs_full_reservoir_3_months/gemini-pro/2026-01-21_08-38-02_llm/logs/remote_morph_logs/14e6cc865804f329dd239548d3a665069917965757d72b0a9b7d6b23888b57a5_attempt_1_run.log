section Indecomposable
variable {D : DirectSumDecomposition M}

/-- If `D` is a direct sum decomposition of `M` and for each `N` appearing in `S` we are given a
direct sum decomposition of `N`, we can construct a refinement of `D`. -/
@[nolint unusedArguments]
def refinement (B : ∀ N ∈ D, Set (PersistenceSubmodule M))
    (hB : ∀ N hN, N = sSup (B N hN)) (hB' : ∀ N hN, sSupIndep (B N hN))
    (hB'' : ∀ N hN, ⊥ ∉ B N hN) : DirectSumDecomposition M where
  carrier := ⋃ N, ⋃ hN, B N hN
  sSupIndep' x hx a ha ha' := by
    simp only [Set.mem_iUnion] at hx
    rcases hx with ⟨N, hN, hx⟩
    have haN : a ≤ N := ha.trans (le_trans (le_sSup hx) (hB N hN).ge)
    let S' := ⋃ (M) (hM : M ∈ D) (_ : M ≠ N), B M hM
    have h_subset : (⋃ N, ⋃ hN, B N hN) \ {x} ⊆ (B N hN \ {x}) ∪ S' := by
      rintro y ⟨⟨M, hM, hy⟩, hne⟩
      by_cases h : M = N
      · subst h; left; exact ⟨hy, hne⟩
      · right; simp only [S', Set.mem_iUnion]; exact ⟨M, hM, h, hy⟩
    have h_le : a ≤ sSup (B N hN \ {x}) ⊔ sSup S' :=
      ha'.trans (sSup_le_sSup h_subset |>.trans sSup_union.le)
    have h_disj : Disjoint N (sSup S') := by
      apply Disjoint.mono_right _ (D.sSupIndep' N hN)
      apply sSup_le_sSup
      rintro y ⟨M, hM, hMN, hy⟩
      exact ⟨M, ⟨hM, hMN⟩, hB M hM ▸ le_sSup hy⟩
    have h_a : a ≤ sSup (B N hN \ {x}) := by
      refine (le_inf haN h_le).trans ?_
      rw [sup_comm, sup_inf_assoc_of_le (hB N hN ▸ sSup_le_sSup (Set.diff_subset _ _)),
        inf_comm, disjoint_iff_inf_le.mp h_disj, sup_bot_eq]
    exact hB' N hN x hx a ha h_a
