-/

@[expose] public section

open scoped Function InnerProductSpace
open MeasureTheory BigOperators ENNReal

variable (α : Type*) [MeasurableSpace α]

variable {H: Type*} [NormedAddCommGroup H] [InnerProductSpace ℂ H] [CompleteSpace H]

def IsOrthogonalProjection (p : H →L[ℂ] H) : Prop := p = p ^ 2 ∧ p = p.adjoint

lemma IsStarProjection_iff (p : H →L[ℂ] H) : IsStarProjection p ↔ ∃ (K : Submodule ℂ H),
    ∃ (kH : K.HasOrthogonalProjection), p = K.subtypeL.comp (@K.orthogonalProjection _ _ _ _ _ kH) := by
  constructor
  · intro h
    let K := LinearMap.range p
    have hK_closed : IsClosed (K : Set H) := by
      rw [LinearMap.range_eq_ker_id_sub_of_isIdempotentElem h.idem]
      exact isClosed_ker _
    let kH : K.HasOrthogonalProjection := Submodule.hasOrthogonalProjection_of_isClosed hK_closed
    refine ⟨K, kH, ?_⟩
    ext x
    simp only [ContinuousLinearMap.comp_apply, Submodule.subtypeL_apply]
    nth_rw 1 [← K.orthogonalProjection_add_orthogonalProjection_orthogonal x]
    rw [map_add]
    have : p (K.orthogonalProjection x) = K.orthogonalProjection x := by
      obtain ⟨y, hy⟩ := (Submodule.coe_mem (K.orthogonalProjection x) : K.orthogonalProjection x ∈ K)
      rw [← hy, ← map_mul, h.idem]
    rw [this]
    convert add_zero (K.orthogonalProjection x : H)
    rw [← LinearMap.mem_ker, ← h.star_eq, LinearMap.ker_adjoint, ← Submodule.mem_orthogonal]
    exact (K.orthogonalProjection_orthogonal x).2
  · rintro ⟨K, kH, rfl⟩
    exact orthogonalProjection_isStarProjection K
