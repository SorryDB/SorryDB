theorem Commute.exists_unitary (hA : A.IsHermitian) (hB : B.IsHermitian) (hAB : Commute A B) :
    ∃ U : Matrix.unitaryGroup d 𝕜, (U.val * A * Uᴴ).IsDiag ∧ (U.val * B * Uᴴ).IsDiag := by
  -- We use the inverse of the shared eigenvector unitary matrix because the diagonalization
  -- formula is Uᴴ A U = D (where U has eigenvectors as columns), which matches U_inv * A * U_invᴴ
  -- if we pick U_inv = Uᴴ.
  use (Matrix.sharedEigenvectorUnitary hA hB hAB)⁻¹
  constructor
  · exact Matrix.SharedEigenbasis.star_mul_self_mul_IsDiag hA hB hAB
  · rw [Matrix.isDiag_iff_diagonal_diag]
    apply Matrix.toEuclideanLin.injective
    apply (EuclideanSpace.basisFun d 𝕜).toBasis.ext; intro i
    simp only [Matrix.toEuclideanLin_apply, EuclideanSpace.basisFun_apply]
    let b := Matrix.sharedEigenbasis hA hB hAB
    have hb : ∃ μ, B *ᵥ (b i) = μ • (b i) := by
      let v := (hA.directSum_isInternal_of_commute' hB hAB).subordinateOrthonormalBasis_mem_submodule rfl (hA.orthogonalFamily_eigenspace_inf_eigenspace' hB)
      obtain ⟨_, h⟩ := (Submodule.mem_inf.mp (v ((Fintype.equivOfCardEq (by simp)).symm i))).2
      rw [Module.End.mem_eigenspace_iff] at h
      use _
      simpa [Matrix.toEuclideanLin_apply] using h
    obtain ⟨μ, hμ⟩ := hb
    have hU : (Matrix.sharedEigenvectorUnitary hA hB hAB)⁻¹.valᴴ *ᵥ Pi.single i 1 = WithLp.ofLp (b i) := by
      rw [unitaryGroup.inv_val, conjTranspose_conjTranspose]
      exact Matrix.SharedEigenbasis.sharedEigenvectorUnitary_mulVec hA hB hAB i
    rw [←Matrix.mulVec_mulVec, ←Matrix.mulVec_mulVec, hU, hμ, Matrix.mulVec_smul]
    rw [unitaryGroup.inv_val, (Matrix.mem_unitaryGroup_iff.mp (Matrix.sharedEigenvectorUnitary hA hB hAB).2).2]
    simp only [Matrix.one_mulVec, Matrix.diagonal_mulVec_single, mul_one]
    congr
    rw [Matrix.diag_apply, Matrix.mul_apply, ← Matrix.mulVec_mulVec, hU, hμ, Matrix.mulVec_smul]
    rw [unitaryGroup.inv_val, (Matrix.mem_unitaryGroup_iff.mp (Matrix.sharedEigenvectorUnitary hA hB hAB).2).2]
    simp [dotProduct_single, Pi.single_apply]
