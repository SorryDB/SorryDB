        ⟨_, (Classical.choose_spec this).1, h.symm ▸ (Classical.choose_spec _).1⟩)
  rw [← encard_union_eq disjoint_sdiff_right, union_diff_cancel (inter_subset_left _ _), mul_add]
  refine (add_le_add (tsub_le_iff_left.mpr (add_comm _ _ ▸ h_odd)) h_Y).trans ?_
