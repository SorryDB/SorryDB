        rw [two_mul, ← add_assoc, add_comm (V(G) \ Y).encard, ← encard_diff_add_inter V(G) Y]
    _ ≤ V(G).encard + Y.encard - (G - Y).OddComponents.encard := by
        gcongr; apply inter_subset_right
