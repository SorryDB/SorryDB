lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  let H := G - Y
  let Yin := Y ∩ V(G)
  have h1 : ν(G) ≤ ν(H) + Yin.encard := sorry
  have h2 : 2 * ν(H) ≤ V(H).encard - H.OddComponents.encard := sorry
  have h3 : V(H).encard = V(G).encard - Yin.encard := sorry
  have h4 : Yin.encard ≤ Y.encard := encard_mono (inter_subset_left _ _)

  calc 2 * ν(G)
    _ ≤ 2 * (ν(H) + Yin.encard) := mul_le_mul_left' h1 _
    _ = 2 * ν(H) + 2 * Yin.encard := mul_add _ _ _
    _ ≤ (V(H).encard - H.OddComponents.encard) + 2 * Yin.encard := add_le_add_right h2 _
    _ = (V(G).encard - Yin.encard - H.OddComponents.encard) + 2 * Yin.encard := by rw [h3]
    _ ≤ V(G).encard + Y.encard - H.OddComponents.encard := sorry
