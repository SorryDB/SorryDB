  apply le_trans (add_le_add (mul_le_mul_left' (hMin.encard_le.trans (le_of_eq hνH)) 2) (mul_le_mul_left' h_out 2))
  rw [← le_tsub_iff_left (le_trans (by simp) (le_add_left _ _))] at h_odd
  apply le_trans (add_le_add_right h_odd _)
  
  have hVH : V(H) = V(G) \ Y := rfl
  rw [hVH, Set.diff_eq, Set.encard_inter_add_encard_diff (Set.inter_subset_left : V(G) ∩ Y ⊆ V(G))]
  rw [← Set.diff_eq, add_comm, add_assoc, tsub_add_eq_tsub_tsub, add_comm (_ - _), tsub_add_eq_add_tsub (Set.encard_le_encard (Set.inter_subset_left : V(G) ∩ Y ⊆ V(G)))]
  apply tsub_le_tsub_right
  rw [two_mul, add_assoc, add_tsub_cancel_right]
  apply add_le_add_left
  exact Set.encard_le_encard Set.inter_subset_right
