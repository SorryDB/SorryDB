lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  have hfin : V(G).Finite := G.vertexFinite
  by_cases hY : Y.Finite; swap
  · rw [Set.Infinite.encard_eq hY]; simp
  lift Y.encard to ℕ using hY with y hy
  lift V(G).encard to ℕ using hfin with n hn

  obtain ⟨M, hM, hM_card⟩ : ∃ M, G.IsMatching M ∧ M.encard = ν(G) := by
    let S := {n | ∃ M, G.IsMatching M ∧ n = M.encard}
    have hS_fin : S.Finite := (Set.finite_le_nat E(G).encard).subset (fun _ ⟨M, h, he⟩ ↦ he ▸ encard_le_encard h.subset)
    rcases S.exists_max_mem ⟨0, ∅, G.nil_isMatching, rfl⟩ hS_fin with ⟨_, ⟨M, hM, rfl⟩, hmax⟩
    refine ⟨M, hM, le_antisymm (hmax _ ⟨M, hM, rfl⟩) (CsSup_le ⟨0, ∅, G.nil_isMatching, rfl⟩ fun _ ⟨M', h', he'⟩ ↦ he' ▸ hmax _ ⟨M', h', rfl⟩)⟩
  
  rw [← hM_card]
  let H := G - Y
  let M_H := {e ∈ M | e ⊆ V(H)}
  let M_cross := M \ M_H
  
  have h_split : M.encard = M_H.encard + M_cross.encard := by
    rw [encard_add_encard_of_disjoint (disjoint_sdiff_right) (Set.Finite.subset hM.subset G.edgeFinite)]
    simp

  have h_odd : 2 * M_H.encard + H.OddComponents.encard ≤ V(H).encard := by
    -- In H, every odd component C has |V(C)| odd, so |matched in C| ≤ |V(C)| - 1.
    -- Summing over components yields 2|M_H| ≤ |V(H)| - |Odd(H)|.
    sorry

  have h_cross : 2 * M_cross.encard ≤ Y.encard + (Y ∩ V(G)).encard := by
    -- Each edge e ∈ M_cross intersects Y. If e ⊆ Y, contributes 2 to LHS, 2 to RHS (since e ⊆ V(G) too).
    -- If |e ∩ Y| = 1, contributes 2 to LHS, 1 to Y.encard + 1 to (Y ∩ V(G)).encard.
    sorry

  have h_alg : 2 * (M_H.encard + M_cross.encard) ≤ n + y - H.OddComponents.encard := by
    rw [mul_add]
    have h_vh : V(H).encard = V(G).encard - (Y ∩ V(G)).encard := by
      -- V(H) = V(G) \ Y
      sorry
    apply le_trans (add_le_add h_odd h_cross)
    rw [h_vh, ← ENat.coe_sub, ← ENat.coe_add, ← ENat.coe_add]
    -- |V(G)| - |Y ∩ V(G)| - |Odd| + |Y| + |Y ∩ V(G)| = |V(G)| + |Y| - |Odd|
    sorry
    
  rw [h_split]
  exact h_alg
