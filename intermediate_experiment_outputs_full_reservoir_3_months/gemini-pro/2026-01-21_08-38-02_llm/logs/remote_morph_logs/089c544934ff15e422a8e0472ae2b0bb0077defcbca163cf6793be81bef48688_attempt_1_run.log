lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  rw [MatchingNumber, mul_sSup]
  apply sSup_le
  rintro _ ⟨M, hM, rfl⟩
  let H := G - Y
  -- For each odd component C of G-Y, either C has an unmatched vertex (in V(G)\V(G,M))
  -- or C has an edge to Y in M (contributing to Y ∩ V(G)).
  -- Parity argument implies each C contributes ≥ 1 to the RHS count.
  have h_bound : H.OddComponents.encard ≤ (V(G) \ V(G, M)).encard + (Y ∩ V(G)).encard := by
    sorry
  have h_size : 2 * M.encard = V(G, M).encard := by
    sorry
  apply le_tsub_of_add_le_right
  rw [h_size]
  calc
    V(G, M).encard + H.OddComponents.encard 
      ≤ V(G, M).encard + ((V(G) \ V(G, M)).encard + (Y ∩ V(G)).encard) := add_le_add_left h_bound _
    _ = (V(G, M).encard + (V(G) \ V(G, M)).encard) + (Y ∩ V(G)).encard := by ac_rfl
    _ = V(G).encard + (Y ∩ V(G)).encard := by rw [encard_add_encard_diff hM.subset_ground]
    _ ≤ V(G).encard + Y.encard := add_le_add_left (encard_le_encard (inter_subset_right _ _)) _
