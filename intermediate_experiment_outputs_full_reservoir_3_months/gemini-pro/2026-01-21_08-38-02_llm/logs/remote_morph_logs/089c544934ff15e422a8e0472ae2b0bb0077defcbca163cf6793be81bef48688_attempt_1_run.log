lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  -- 1. ν(G) ≤ ν(G - Y) + |Y|. 
  -- Removing Y removes edges incident to Y. Each such edge hits a vertex in Y.
  have h1 : ν(G) ≤ ν(G - Y) + Y.encard := sorry
  
  -- 2. 2 * ν(G - Y) ≤ |V(G - Y)| - odd(G - Y).
  -- In G - Y, every odd component has at least one unmatched vertex.
  have h2 : 2 * ν(G - Y) ≤ (G - Y).vertexSet.encard - (G - Y).OddComponents.encard := sorry

  -- 3. Combine inequalities.
  -- |V(G - Y)| + 2|Y| ≤ |V(G)| + |Y| because |V(G - Y)| = |V(G)| - |V(G) ∩ Y| and |V(G) ∩ Y| ≤ |Y|.
  have h3 : (G - Y).vertexSet.encard + 2 * Y.encard ≤ V(G).encard + Y.encard := sorry

  calc
    2 * ν(G) ≤ 2 * (ν(G - Y) + Y.encard) := mul_le_mul_left' h1 2
    _ = 2 * ν(G - Y) + 2 * Y.encard := left_distrib 2 _ _
    _ ≤ ((G - Y).vertexSet.encard - (G - Y).OddComponents.encard) + 2 * Y.encard := add_le_add_right h2 _
    _ = ((G - Y).vertexSet.encard + 2 * Y.encard) - (G - Y).OddComponents.encard := sorry 
    _ ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := tsub_le_tsub_right h3 _
