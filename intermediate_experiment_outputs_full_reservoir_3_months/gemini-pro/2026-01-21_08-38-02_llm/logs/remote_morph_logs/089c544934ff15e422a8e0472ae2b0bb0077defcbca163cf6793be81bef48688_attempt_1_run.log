lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  let H := G - Y
  obtain ⟨M, hM, rfl⟩ := G.exists_isMaxMatching
  obtain ⟨N, hN, rfl⟩ := H.exists_isMaxMatching

  -- 1. Bound ν(G) in terms of ν(H) and |Y ∩ V(G)|
  have h_bound_M : M.encard ≤ N.encard + (Y ∩ V(G)).encard := by
    let M_H := {e ∈ M | e ⊆ V(H)}
    let M_Y := M \ M_H
    have hMH_matching : H.IsMatching M_H := ⟨fun e he ↦ (H.edge_mem_iff).mpr ⟨hM.subset he.1, he.2⟩, 
      fun e f he hf ↦ hM.disjoint he.1 hf.1⟩
    
    have h_inj : M_Y.encard ≤ (Y ∩ V(G)).encard := by
      have : ∀ e ∈ M_Y, ∃ y, y ∈ e ∩ (Y ∩ V(G)) := fun e he ↦ by
        have : ¬ e ⊆ V(G) \ Y := he.2
        rw [subset_def] at this; push_neg at this
        obtain ⟨y, hy_e, hy_not⟩ := this
        simp at hy_not
        refine ⟨y, hy_e, hy_not, hM.subset he.1 |>.inc_left hy_e⟩ -- assuming edge implies vertex mem
      choose f hf using this
      apply encard_le_encard_of_injOn f
      intro e he e' he' heq
      apply hM.disjoint he.1.1 he'.1.1 _
      by_contra hne
      exact (hM.disjoint he.1.1 he'.1.1 hne).le_bot ⟨(hf e he).1, by rw [heq]; exact (hf e' he').1⟩

    calc M.encard
      _ = M_H.encard + M_Y.encard := by 
          rw [← encard_union_eq_add_of_disjoint disjoint_sdiff_self_right]
          congr; simp [M_H, M_Y]
      _ ≤ N.encard + (Y ∩ V(G)).encard := add_le_add (hN.max _ hMH_matching) h_inj

  -- 2. Bound 2ν(H) ≤ |V(H)| - odd(H)
  have h_bound_H : 2 * N.encard + H.OddComponents.encard ≤ V(H).encard := by
    -- We use the fact that deficiency(H) = |V(H)| - 2ν(H) ≥ odd(H)
    -- Equivalently 2ν(H) + odd(H) ≤ |V(H)|
    -- Each odd component C contributes at least 1 to deficiency.
    -- (V(C) is odd, N matches an even subset, so ≥ 1 vertex in C unmatched).
    let U := V(H) \ V(H, N) -- Unmatched vertices
    have h_card : V(H).encard = 2 * N.encard + U.encard := by
      rw [← encard_union_eq_add_of_disjoint]
      · rw [union_diff_cancel (by apply subset_univ)]
        -- Assuming loopless for 2*|N| = |V(N)|. If not, formula requires adjustment or assumption.
        sorry 
      · exact disjoint_sdiff_self_right
    
    have h_inj_odd : H.OddComponents.encard ≤ U.encard := by
      -- Construct injection from OddComponents to U
      sorry
    
    rw [h_card]
    apply add_le_add_left h_inj_odd

  -- 3. Combine
  have h_VG : V(H).encard = V(G).encard - (Y ∩ V(G)).encard := by
    -- V(H) = V(G) \ Y
    sorry 

  calc 2 * M.encard
    _ ≤ 2 * (N.encard + (Y ∩ V(G)).encard) := mul_le_mul_left' h_bound_M _
    _ = 2 * N.encard + 2 * (Y ∩ V(G)).encard := mul_add _ _ _
    _ ≤ (V(H).encard - H.OddComponents.encard) + 2 * (Y ∩ V(G)).encard := by
      -- derived from h_bound_H: 2N ≤ VH - odd
      -- Assuming finite arithmetic valid
      sorry
    _ = (V(G).encard - (Y ∩ V(G)).encard) + 2 * (Y ∩ V(G)).encard - H.OddComponents.encard := by
      rw [h_VG]
      -- arithmetic
      sorry
    _ = V(G).encard + (Y ∩ V(G)).encard - H.OddComponents.encard := by
      -- x - y + 2y = x + y for finite x, y<=x
      sorry
    _ ≤ V(G).encard + Y.encard - H.OddComponents.encard := by
      apply tsub_le_tsub_right
      apply add_le_add_left
      apply encard_le_encard
      exact inter_subset_left
