  -- Vertices in G-Y unmatched by M_Y
  let U := V(G - Y) \ V(G - Y, M_Y)
  have h_U_card : 2 * M_Y.encard + U.encard = V(G - Y).encard := by
    rw [← hM_Y.encard_vertex_eq_mul_encard, add_comm, encard_diff_add_encard_of_subset (diff_subset _ _)]

  -- Each odd component of G-Y contributes at least one unmatched vertex to U
  have h_odd_le_U : (G - Y).OddComponents.encard ≤ U.encard := by
    let f (C : (G - Y).OddComponents) : α := Classical.choice <| by
