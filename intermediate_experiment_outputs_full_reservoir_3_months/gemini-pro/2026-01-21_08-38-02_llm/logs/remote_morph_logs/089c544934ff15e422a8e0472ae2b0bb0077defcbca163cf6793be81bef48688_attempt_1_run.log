    ≤ 2 * (ν(H) + S.encard) := mul_le_mul_left' h2 _
    _ = 2 * ν(H) + 2 * S.encard := mul_add 2 _ _
    _ ≤ (H.vertexSet.encard - H.OddComponents.encard) + 2 * S.encard := by
