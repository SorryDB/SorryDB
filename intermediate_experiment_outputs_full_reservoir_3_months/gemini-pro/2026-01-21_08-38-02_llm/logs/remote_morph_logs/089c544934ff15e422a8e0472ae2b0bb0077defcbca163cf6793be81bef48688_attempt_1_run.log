          exact even_two_mul _
        exact Nat.odd_sub_even_pos (encard_coe_fn _ ▸ hodd) (encard_coe_fn _ ▸ heven) |>.nonempty))
      (fun C₁ _ C₂ _ h ↦ C₁.2.toIsCompOf.eq_of_disjoint_inter_nonempty C₂.2.toIsCompOf <|
