lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  apply sSup_le
  rintro _ ⟨M, hM, rfl⟩
  let M_in := {e ∈ M | Disjoint V(G, e) Y}
  let M_out := {e ∈ M | ¬ Disjoint V(G, e) Y}
  have hM_part : M = M_in ∪ M_out := by ext; simp [M_in, M_out]; tauto
  have hM_disj : Disjoint M_in M_out := by rw [Set.disjoint_iff]; ext; simp [M_in, M_out]; tauto

  have h_out : M_out.encard ≤ (V(G) ∩ Y).encard := by
    choose v hv using fun e (he : e ∈ M_out) ↦ not_disjoint_iff.mp he.2
    exact encard_le_encard_of_injOn v (fun e he ↦ (hv e he).2)
      (fun e he f hf eq ↦ by_contra fun ne ↦ (hM.disjoint he.1 hf.1 ne).le_bot ⟨_, eq ▸ (hv f hf).1, (hv e he).1⟩)

  have h_in : 2 * M_in.encard ≤ (V(G) \ Y).encard - (G - Y).OddComponents.encard := sorry

  rw [hM_part, encard_union_eq hM_disj, mul_add]
  calc
    2 * M_in.encard + 2 * M_out.encard
      ≤ ((V(G) \ Y).encard - (G - Y).OddComponents.encard) + 2 * (V(G) ∩ Y).encard := by
        gcongr; exact h_out
    _ = (V(G) \ Y).encard + 2 * (V(G) ∩ Y).encard - (G - Y).OddComponents.encard := by
        refine ENat.add_sub_assoc (le_trans (by simp) h_in) _
    _ = V(G).encard + (V(G) ∩ Y).encard - (G - Y).OddComponents.encard := by
