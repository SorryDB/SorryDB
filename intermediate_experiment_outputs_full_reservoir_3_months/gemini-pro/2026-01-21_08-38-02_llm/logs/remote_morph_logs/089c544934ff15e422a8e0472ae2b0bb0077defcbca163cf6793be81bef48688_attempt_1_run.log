lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  let H := G - Y
  obtain ⟨M, hM, hM_eq⟩ := Finite.exists_maximal_wrt (·.encard) G.IsMatching G.isMatching_empty
  have hνG : ν(G) = M.encard := le_antisymm (IsMatching.encard_le hM) (by rw [MatchingNumber, sSup_le_iff]; intro _ ⟨M', hM', rfl⟩; exact hM_eq M' hM')

  let M_in := {e ∈ M | V(G, e) ⊆ V(H)}
  let M_out := M \ M_in
  
  have hMin : H.IsMatching M_in := ⟨fun e he ↦ ⟨hM.subset he.1, he.2⟩, fun e f he hf ↦ hM.disjoint he.1 hf.1⟩
  
  have h_out : M_out.encard ≤ (V(G) ∩ Y).encard := by
    apply Set.encard_le_encard_of_injOn (fun e ↦ (V(G, e) ∩ Y).toFinset.min' (by
       simp only [M_out, M_in, Set.mem_diff, Set.mem_sep_iff, not_and, not_forall, Set.Not_subset]
       rintro e ⟨he, hout⟩; rw [Set.toFinset_nonempty]
       obtain ⟨v, hv, hvy⟩ := hout he
       exact ⟨v, hv, hvy⟩))
    · intro e he; exact (V(G, e) ∩ Y).toFinset.min'_mem _
    · intro e1 he1 e2 he2 h
      by_contra hne
      exact (hM.disjoint he1.1.1 he2.1.1 hne).ne_of_mem ((V(G, e1) ∩ Y).toFinset.min'_mem _) ((V(G, e2) ∩ Y).toFinset.min'_mem _) h

  obtain ⟨N, hN, hN_eq⟩ := Finite.exists_maximal_wrt (·.encard) H.IsMatching H.isMatching_empty
  have hνH : ν(H) = N.encard := le_antisymm (IsMatching.encard_le hN) (by rw [MatchingNumber, sSup_le_iff]; intro _ ⟨M', hM', rfl⟩; exact hN_eq M' hM')

  have h_odd : H.OddComponents.encard + 2 * N.encard ≤ V(H).encard := by
    sorry -- Standard counting argument: sum over components C, 2|N_C| <= |V(C)| - 1 for odd C

  rw [hνG, ← Set.encard_union_eq (Set.disjoint_sdiff_right : Disjoint M_in M_out), Set.union_diff_cancel (Set.sep_subset _ _)]
