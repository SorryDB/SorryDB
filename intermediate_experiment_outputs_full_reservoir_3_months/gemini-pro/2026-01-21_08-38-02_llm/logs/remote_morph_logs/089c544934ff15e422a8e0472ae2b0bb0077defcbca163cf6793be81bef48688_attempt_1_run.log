        (Set.Nonempty.toList_head!_mem _) heq

  -- Combine inequalities
  rw [tsub_le_iff_right, ← add_assoc]
  calc 2 * M.encard + (G - Y).OddComponents.encard
    _ = 2 * M_Y.encard + 2 * (M \ M_Y).encard + (G - Y).OddComponents.encard := by
      rw [← mul_add, ← encard_union_eq disjoint_sdiff_right, union_diff_cancel (inter_subset_left _ _)]
    _ ≤ 2 * M_Y.encard + 2 * Y.encard + U.encard := by gcongr
    _ = (2 * M_Y.encard + U.encard) + 2 * Y.encard := by ac_rfl
    _ = V(G - Y).encard + 2 * Y.encard := by rw [h_U_card]
    _ = V(G).encard - (V(G) ∩ Y).encard + 2 * Y.encard := by
      rw [encard_diff_eq_sub (inter_subset_right _ _) (inter_subset_left _ _)]
    _ ≤ V(G).encard + Y.encard := by
      rw [tsub_add_eq_add_tsub (encard_mono (inter_subset_right _ _)), add_assoc, two_mul]
      gcongr
      exact le_tsub_add
