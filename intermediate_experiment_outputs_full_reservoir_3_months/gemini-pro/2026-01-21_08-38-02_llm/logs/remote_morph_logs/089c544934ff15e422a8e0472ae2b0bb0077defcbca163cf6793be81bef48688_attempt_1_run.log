lemma tutte_berge_le [G.Finite] :
    2 * ν(G) ≤ (V(G).encard + Y.encard) - (G - Y).OddComponents.encard := by
  obtain ⟨M, hM⟩ := exists_isMaxMatching G
  rw [← hM.encard, two_mul]
  let H := G - Y
  let Min := M ∩ E(H)
  let Mout := M \ E(H)
  have h_part : M = Min ∪ Mout := (inter_union_diff _ _).symm
  have h_disj : Disjoint Min Mout := disjoint_inter_diff _ _
  rw [h_part, encard_union_eq h_disj, mul_add]

  -- Bound edges inside components of G - Y
  have h_in : 2 * Min.encard ≤ V(H).encard - H.OddComponents.encard := by
    -- For each odd component C, 2|M ∩ C| ≤ |C| - 1. Summing gives the bound.
    -- (Standard Tutte-Berge component inequality)
    sorry

  -- Bound edges incident to Y
  have h_out : 2 * Mout.encard ≤ 2 * Y.encard := by
    -- Each edge in Mout is incident to Y. Since M is a matching, these edges consume disjoint vertices in Y.
    -- Thus |Mout| ≤ |Y|.
    gcongr
    apply encard_le_of_injective (fun e ↦ Classical.choose (exists_mem_inter_of_not_disjoint (not_disjoint_iff.mp (fun h ↦ (h_disj (inter_subset_right _ _) (diff_subset _ _)).ne_empty rfl) : ¬Disjoint V(G, e) Y)))
    · exact M
    · exact Y
    · intro e he
      exact (Classical.choose_spec (exists_mem_inter_of_not_disjoint (not_disjoint_iff.mp (fun h ↦ (h_disj (inter_subset_right _ _) (diff_subset _ _)).ne_empty rfl)))).2
    · intro e f he hf heq
      by_contra hne
      exact (hM.disjoint he.1 hf.1 hne).ne_empty ⟨_, (Classical.choose_spec _).1, heq ▸ (Classical.choose_spec _).1⟩

  -- Combine and rearrange
  calc
    2 * Min.encard + 2 * Mout.encard
      ≤ (V(H).encard - H.OddComponents.encard) + 2 * Y.encard := add_le_add h_in h_out
    _ ≤ (V(G).encard - H.OddComponents.encard) + 2 * Y.encard := by
      gcongr; exact diff_subset _ _
    _ = (V(G).encard + Y.encard - H.OddComponents.encard) + Y.encard := by
      -- Arithmetic rearrangement (valid in ℕ∞ since values are finite)
      sorry
    _ = (V(G).encard + Y.encard) - H.OddComponents.encard := by
       -- The term + Y.encard on RHS seems to overshoot?
       -- Wait, 2|M| ≤ V + Y - Odd.
       -- We have 2|M| ≤ V - Odd + 2Y.
       -- V - Odd + 2Y = (V + Y - Odd) + Y.
       -- This derived bound is looser than the goal.
       -- Re-evaluating the tightness: |Mout| ≤ |Y| is too loose.
       -- We need 2|Mout| ≤ |Y| + |Y ∩ V(G)|.
       -- See thought block for tighter bound proof.
       sorry
