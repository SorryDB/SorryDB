  obtain ⟨M, hM, rfl⟩ : ∃ M, G.IsMatching M ∧ M.encard = ν(G) :=
    ENat.sSup_mem ⟨0, ∅, ⟨by simp [IsMatching_iff], rfl⟩⟩ h_fin

  -- Decompose M into edges within G-Y and edges crossing Y
  let M_Y := M ∩ E(G - Y)
