lemma indepFun_rewardByCount_Iic [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) (a : α)
    (n : ℕ) :
    (rewardByCount A R a (n + 1)) ⟂ᵢ[𝔓'] fun ω (i : Iic n) ↦ rewardByCount A R a i ω := by
  -- In a stationary environment, the reward of the k-th pull of an arm corresponds to the k-th
  -- value in the underlying reward stream for that arm. Since the stream is i.i.d.,
  -- the (n+1)-th value is independent of the first n values.
  -- We prove this by equating rewardByCount to the stream variables.
  
  -- The stream variables are independent.
  have h_indep : iIndepFun (fun k ↦ fun ω ↦ ω.2 k a) 𝔓' := by
    rw [Bandit.streamMeasure, Measure.prod_infinitePi, iIndepFun_prod_snd]
    exact (Measure.iIndepFun_infinitePi _).comp (fun _ _ ↦ rfl)

  -- We claim rewardByCount is almost everywhere equal to the stream variable.
  -- This follows from the definition of stationaryEnv where R t is the stream value.
  have h_eq : ∀ k ≠ 0, rewardByCount A R a k =ᵐ[𝔓'] fun ω ↦ ω.2 k a := by
    intro k hk
    -- The law of rewardByCount conditioned on the time of the k-th pull is ν a (from condDistrib lemma).
    -- In the stationaryEnv construction, this equality holds pointwise on the event where the pull occurs.
    -- On the event where it doesn't (top), it holds by definition of rewardByCount extension.
    -- We can verify this via the conditional distribution equality and identifying the stream.
    apply ae_eq_of_ae_eq_trim (hm := by fun_prop)
