  have hX : Measurable X := measurable_pi_lambda _ (fun i ↦ measurable_rewardByCount h.measurable_A h.measurable_R a i)
  have hT : Measurable T := measurable_stepsUntil h.measurable_A a (n + 1)
  rw [indepFun_iff_condDistrib_eq_const hY hX (hasLaw_rewardByCount h a (n+1) (by simp)).map_eq]
  refine condDistrib_eq_of_condDistrib_prod_eq_const hY hX hT ?_
  refine (condDistrib_ae_eq_cond (μ := 𝔓') (hX.prod_mk hT) hY).trans ?_
  refine ae_cond_of_forall_mem (measurable_snd (hX.prod_mk hT) (measurableSet_singleton ⊤)) ?_
  rintro ⟨x, t⟩ ht
  simp only [Set.mem_preimage, Set.mem_singleton_iff] at ht
  cases t with
  | top =>
    rw [Measure.map_congr (g := fun ω ↦ ω.2 (n + 1) a)]
    swap
    · refine ae_cond_of_forall_mem ((measurableSet_singleton _).preimage (by fun_prop)) ?_
      simp only [Set.mem_preimage, Set.mem_singleton_iff]
      exact fun ω ↦ rewardByCount_of_stepsUntil_eq_top
    rw [cond_of_indepFun _ (by fun_prop) (by fun_prop) (measurableSet_singleton _)]
    · exact (hasLaw_Z a (n + 1)).map_eq
    · rwa [Measure.map_apply (by fun_prop) (measurableSet_singleton _)] at ht
    · exact indepFun_prod_snd_of_mem_snd (by fun_prop) (by fun_prop)
  | coe m =>
    rw [Measure.map_congr (g := fun ω ↦ R m ω.1)]
    swap
    · refine ae_cond_of_forall_mem ((measurableSet_singleton _).preimage (by fun_prop)) ?_
      simp only [Set.mem_preimage, Set.mem_singleton_iff]
      exact fun ω ↦ rewardByCount_of_stepsUntil_eq_coe
    refine reward_cond_stepsUntil h a (n + 1) m (by simp) ?_
    rwa [Measure.map_apply (by fun_prop) (measurableSet_singleton _)] at ht
