lemma indepFun_rewardByCount_Iic [StandardBorelSpace Ω] [Nonempty Ω] [Countable α]
    (h : IsAlgEnvSeq A R alg (stationaryEnv ν) P) (a : α)
    (n : ℕ) :
    (rewardByCount A R a (n + 1)) ⟂ᵢ[𝔓'] fun ω (i : Iic n) ↦ rewardByCount A R a i ω := by
  have h_eq : ∀ k, rewardByCount A R a k =ᵐ[𝔓'] fun ω ↦ ω.2 k a :=
    fun k ↦ h.rewardByCount_eq_stream a k
  refine IndepFun.of_congr_ae (h_eq (n + 1)) ?_ ?_
  · filter_upwards [ae_all_iff.2 (fun i : Iic n ↦ h_eq i)] with ω hω
    funext i
    exact hω i
  · refine IndepFun.comp_snd ?_ measurable_fst measurable_snd
