    (rewardByCount A R a (n + 1)) ⟂ᵢ[𝔓'] fun ω (i : Iic n) ↦ rewardByCount A R a i ω := by
  have h_eq (m : ℕ) (hm : m ≠ 0) : rewardByCount A R a m =ᵐ[𝔓'] fun ω ↦ ω.2 (m - 1) a :=
    h.rewardByCount_eq_stream_apply a m hm
  refine IndepFun.congr ?_ (h_eq (n + 1) (by simp)) ?_
  · have h_indep : iIndepFun (fun m ↦ (fun ω ↦ ω.2 m a)) 𝔓' := by
      rw [Bandit.streamMeasure]
      exact iIndepFun_infinitePi_pi_eval _ _
    refine (h_indep.indepFun_Iic n).comp measurable_id (measurable_pi_lambda _ fun i ↦ ?_)
    measurable
  · filter_upwards with ω i
    by_cases hi : (i : ℕ) = 0
    · simp [hi, rewardByCount]
    · specialize h_eq i hi
      rw [h_eq]
      rfl
