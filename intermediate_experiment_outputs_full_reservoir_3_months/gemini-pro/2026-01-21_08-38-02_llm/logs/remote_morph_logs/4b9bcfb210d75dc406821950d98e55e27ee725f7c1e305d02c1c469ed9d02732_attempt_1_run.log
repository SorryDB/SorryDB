lemma diagFunctorIso_app (M : AddCommGrpCatᵒᵖ) :
    ((diagFunctorIso R).app M).hom.hom.left = (diagSpecIso R M.unop).hom := rfl

instance faithful_diagFunctor {R : Type*} [CommRing R] [Nontrivial R] :
