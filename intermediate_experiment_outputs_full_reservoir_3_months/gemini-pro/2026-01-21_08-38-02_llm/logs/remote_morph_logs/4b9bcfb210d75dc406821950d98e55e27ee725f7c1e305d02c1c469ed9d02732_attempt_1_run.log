section CommRing
variable {R : CommRingCat.{u}} {G : Scheme.{u}} [G.Over (Spec R)] [GrpObj (asOver G (Spec R))]
  {A : Type u} [AddCommGroup A]

instance : IsDiagonalisable (Spec R) Spec(R[A]) := .of_isIso (diagSpecIso R A).inv

variable [IsDomain R]

/-- An affine algebraic group `G` over a domain `R` is diagonalisable iff it is affine and `Γ(G)` is
`R`-spanned by its group-like elements.

Note that this is more generally true over arbitrary commutative rings, but we do not prove that.
See SGA III, Exposé VIII for more info.

Note that more generally a not necessarily affine algebraic group `G` over a field `K` is
diagonalisable iff it is affine and `Γ(G)` is `K`-spanned by its group-like elements, but we do not
prove that. -/
lemma isDiagonalisable_iff_span_isGroupLikeElem_eq_top [IsAffine G] :
    IsDiagonalisable (Spec R) G ↔ Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤ := by
  constructor
  · rintro ⟨A, _, e, _, _⟩
    let e' : G ≅ Spec(MonoidAlgebra R (Multiplicative A)) := e ≪≫ diagSpecIso R A
    let φ : MonoidAlgebra R (Multiplicative A) ≃ₐ[R] Γ(G, ⊤) :=
      (Scheme.Γ.mapIso e'.op).symm.toAlgEquiv
    rw [← φ.range_eq_top, ← MonoidAlgebra.span_of_eq_top (G := Multiplicative A)]
    rw [Submodule.map_span]
    congr; ext x
    rw [Set.mem_image, Set.mem_setOf_eq, Set.mem_setOf_eq]
    refine ⟨fun ⟨a, h⟩ ↦ ?_, fun h ↦ ?_⟩
    · subst h; obtain ⟨m, rfl⟩ := MonoidAlgebra.isGroupLike_iff_mem_of_isDomain.mp h
      rw [← (IsGroupLikeElem.equiv_iff (R := R) φ).mp (MonoidAlgebra.isGroupLike_of _)]
      simp
    · obtain ⟨m, rfl⟩ := MonoidAlgebra.isGroupLike_iff_mem_of_isDomain.mp <|
        (IsGroupLikeElem.equiv_iff (R := R) φ).mpr h
      exact ⟨MonoidAlgebra.of R (Multiplicative A) m, by simp⟩
  · intro h
    let S : Subgroup (Γ(G, ⊤))ˣ :=
      { carrier := {u | IsGroupLikeElem R (u : Γ(G, ⊤))}
        mul_mem' := fun h₁ h₂ ↦ IsGroupLikeElem.mul h₁ h₂
        one_mem' := IsGroupLikeElem.one
        inv_mem' := fun h ↦ IsGroupLikeElem.inv h }
    let A := Additive S
    let φ : MonoidAlgebra R (Multiplicative A) →ₐ[R] Γ(G, ⊤) :=
      MonoidAlgebra.lift R (Multiplicative A) (Γ(G, ⊤)) (fun a ↦ a.toMul : A → Γ(G, ⊤))
    have hφ : Function.Bijective φ := by
      refine ⟨linearIndependent_groupLike R S (fun x ↦ x) (fun x y h ↦ Subtype.ext h) |>.injective_linearMap φ ?_, ?_⟩
      · intro i; simp [φ]
      · rw [← LinearMap.range_eq_top, ← h, Submodule.span_le]
        rintro _ ⟨x, hx⟩; exact ⟨Additive.ofMul ⟨x, (IsGroupLikeElem.isUnit hx).units_mem⟩, rfl⟩
    let ψ : Spec (MonoidAlgebra R (Multiplicative A)) ≅ G :=
      (Scheme.Spec.mapIso (AlgEquiv.ofBijective φ hφ).toRingEquiv.toCommRingCatIso).op
    refine ⟨A, inferInstance, ψ.symm ≪≫ (diagSpecIso R A), ?_, ?_⟩
    · apply IsOver.comp_over
    · refine IsMonHom.comp_inv _ _ (id ?_) _
      apply Scheme.Hom.IsMonHom.of_map_iso (commHopfAlgCatEquivCogrpCommAlgCat (CommRingCat.of R)).functor
      apply Bialgebra.Iso.of_algEquiv
      simp only [φ, MonoidAlgebra.lift_apply]
      apply MonoidAlgebra.lift_isHom_of_map_isGroupLike
      exact fun i ↦ i.toMul.2
