@[simp] lemma diagFunctor_obj (M : AddCommGrpCatᵒᵖ) :
    (diagFunctor S).obj M = ⟨(Diag S M.unop).asOver S⟩ := rfl

@[simp] lemma diagFunctor_map {M N : AddCommGrpCatᵒᵖ} (f : M ⟶ N) :
    (diagFunctor S).map f = ⟨(Diag.map S f.unop.hom).asOver S⟩ := rfl

