lemma isDiagonalisable_iff_span_isGroupLikeElem_eq_top [IsAffine G] :
    IsDiagonalisable (Spec R) G ↔ Submodule.span R {a : Γ(G, ⊤) | IsGroupLikeElem R a} = ⊤ := by
  constructor
  · rintro ⟨A, _, e, _, _⟩
    let e' := e.trans (diagSpecIso R A)
    let φ : Γ(G, ⊤) ≃ₐ[R] MonoidAlgebra R (Multiplicative A) :=
      (Scheme.Γ.mapIso e'.op).trans (Scheme.ΓSpecIso _)
    rw [eq_top_iff, ← φ.toLinearEquiv.map_eq_top_iff, Submodule.map_span]
    refine (MonoidAlgebra.span_range_of_eq_top _ _).symm.le.trans (Submodule.span_mono ?_)
    rintro _ ⟨a, rfl⟩
    use φ.symm (MonoidAlgebra.of _ _ a)
    simp only [Set.mem_setOf_eq, AlgEquiv.toLinearEquiv_apply, AlgEquiv.apply_symm_apply]
    -- Since e' is a group scheme isomorphism, φ is a Hopf algebra isomorphism,
    -- so φ.symm preserves group-like elements.
    have h_gl : IsGroupLikeElem R (MonoidAlgebra.of R (Multiplicative A) a) :=
      MonoidAlgebra.isGroupLike_of _ a
    let F : CommHopfAlgCat.of R Γ(G, ⊤) ≅ CommHopfAlgCat.of R (MonoidAlgebra R (Multiplicative A)) :=
      (commHopfAlgCatEquivCogrpCommAlgCat R).inverse.mapIso (Over.isoMk e' (by simp)).op
    have : φ.toAlgHom = F.hom.hom := rfl
    rw [← F.hom.hom.map_isGroupLikeElem, this, AlgEquiv.apply_symm_apply]
    exact h_gl
  · intro h
    let Gl := {a : Γ(G, ⊤) | IsGroupLikeElem R a}
    have : Group Gl := GroupLike.group R _
    let A := Additive Gl
    let f : MonoidAlgebra R (Multiplicative A) →ₐ[R] Γ(G, ⊤) :=
      MonoidAlgebra.lift R _ _ (Submonoid.subtype _)
    have h_bij : Function.Bijective f := by
      constructor
      · rw [injective_iff_map_eq_zero]
        intro x hx
        refine LinearIndependent.injective_total (GroupLike.linearIndependent R _) ?_ hx
        simp
      · rw [← LinearMap.range_eq_top, MonoidAlgebra.lift_range_eq_span_range]
        simpa [Gl] using h
    refine ⟨A, inferInstance, ?_, ?_, ?_⟩
    · let f_iso := AlgEquiv.ofBijective f h_bij
      let F : CommHopfAlgCat.of R (MonoidAlgebra R (Multiplicative A)) ≅ CommHopfAlgCat.of R Γ(G, ⊤) :=
        CommHopfAlgCat.ofHomIso <| RingEquiv.toRingAut f_iso
      refine G.isoSpec.trans ?_
