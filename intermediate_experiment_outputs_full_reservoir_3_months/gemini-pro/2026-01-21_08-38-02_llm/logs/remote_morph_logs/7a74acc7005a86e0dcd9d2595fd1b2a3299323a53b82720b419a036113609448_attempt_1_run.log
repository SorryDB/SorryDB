        specialize this A
        rw [h, pow_one] at this
        have h_orb : Fintype.card (ConjClasses.carrier A) * Fintype.card (Set.centralizer {Quotient.out A}) = Fintype.card Rˣ := by
          let x := Quotient.out A
          rw [← MulAction.card_orbit_mul_card_stabilizer_eq_card_group (ConjAct Rˣ) x]
          congr 1
          · exact (ConjAct.orbit_eq_carrier_conjClasses x).symm
          · rw [Fintype.card_congr (ConjAct_stabilizer_centralizer_eq x)]
        rw [h_R, ← this] at h_orb
        have h_cent : Fintype.card (Set.centralizer {Quotient.out A}) = q - 1 :=
