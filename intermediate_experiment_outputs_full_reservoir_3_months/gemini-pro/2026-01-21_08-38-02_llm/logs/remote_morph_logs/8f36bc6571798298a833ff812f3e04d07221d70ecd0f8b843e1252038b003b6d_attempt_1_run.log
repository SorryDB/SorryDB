    iIndepFun (fun (p : α × ℕ) ↦ rewardByCount p.1 p.2) 𝔓 := by
  have h_eq : ∀ p, rewardByCount p.1 p.2 = (fun ω ↦ if p.2 = 0 then 0 else ω.2 (p.2 - 1) p.1) :=
    fun p ↦ by ext; simp [rewardByCount]
  apply iIndepFun_congr h_eq
  have h_snd : (𝔓).map Prod.snd = Bandit.streamMeasure ν := by
    rw [Bandit.measure, Measure.snd, Measure.map_map] <;> try fun_prop
    rfl
  rw [iIndepFun_iff]
  intro t s hs
  rw [← Measure.map_map (Measurable.pi_inter_apply_symm s t (by fun_prop)) (by fun_prop)]
  rw [h_snd, Bandit.streamMeasure]
  -- The variables on the stream measure are projections of a product measure (or constants)
  -- We split s into indices with n=0 and n≠0
  let s₀ := s.filter (fun p ↦ p.2 = 0)
  let s₁ := s.filter (fun p ↦ p.2 ≠ 0)
  have h_union : s = s₀ ∪ s₁ := by
    ext x; simp [s₀, s₁]; tauto
  rw [h_union, Finset.set_pi_union_disjoint]
  · rw [Measure.infinitePi_pi _ (fun _ ↦ Measure.infinitePi_pi _ (fun _ ↦ (isMarkovKernel_iff.1 inferInstance).1 _))]
    -- Factors for n=0 are 0 or 1. Factors for n≠0 are independent.
