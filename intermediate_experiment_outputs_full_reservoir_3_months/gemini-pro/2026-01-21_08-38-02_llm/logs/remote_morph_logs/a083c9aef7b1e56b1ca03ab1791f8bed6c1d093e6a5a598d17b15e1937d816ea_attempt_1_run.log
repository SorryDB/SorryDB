```lean
theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x => simp [fastCheckMem, beq_iff_eq]
  | node v left right ih_l ih_r =>
    rw [fastCheckMem]
    rcases h with ⟨h_le, h_ge, h_ord_l, h_ord_r, h_mem⟩
    split_ifs with h_eq h_lt
    · rw [beq_iff_eq] at h_eq; subst h_eq
      simp [h_mem]
    · rw [ih_l h_ord_l]
      constructor
      · exact Or.inl
      · rintro (h_in | h_in)
        · exact h_in
        · have := h_ge _ h_in; linarith
    · rw [ih_r h_ord_r]
      constructor
      · exact Or.inr
      · rintro (h_in | h_in)
        · have := h_le _ h_in; rw [beq_iff_eq] at h_eq; linarith
        · exact h_in
```
