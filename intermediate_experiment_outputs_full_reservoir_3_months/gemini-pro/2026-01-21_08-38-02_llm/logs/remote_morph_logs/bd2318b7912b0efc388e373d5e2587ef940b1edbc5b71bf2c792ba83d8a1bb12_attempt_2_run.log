          have : s = t.erase none := rfl
          by_cases hn : none ∈ t
          · have : t = insert none s := by rw [this, insert_erase hn]
            subst this
            have : s ∉ 𝓕 := fun h ↦ h₁ ⟨hs, h, ht⟩
            simp [ht, this]
