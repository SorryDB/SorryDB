private lemma _root_.IsNIPWith.card_hypercubeEdgeFinset_le_of_finite [Finite α]
    (h𝓕 : IsNIPWith d (𝓕 : Set (Set α))) : #(hypercubeEdgeFinset 𝓕) ≤ d * #𝓕 := by
  cases nonempty_fintype α
  induction ‹Fintype α› using Fintype.induction_empty_option generalizing 𝓕 d with
  | of_empty =>
    simp [hypercubeEdgeFinset, Finset.filter_eq_empty_iff, Set.ncard_eq_one]
  | of_option β _ ih =>
