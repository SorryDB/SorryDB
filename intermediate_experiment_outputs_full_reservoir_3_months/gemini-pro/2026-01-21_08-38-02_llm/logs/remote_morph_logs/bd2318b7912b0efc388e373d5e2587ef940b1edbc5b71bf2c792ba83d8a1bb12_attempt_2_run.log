    have h_card : #𝓕 = #𝓕₀ + #𝓕₁ := by
      rw [card_eq_sum_card_fiberwise (g := fun s ↦ s.erase none), ← sum_const #𝓕₀]
      refine Finset.sum_congr rfl fun s hs ↦ ?_
      simp only [mem_image, mem_filter] at hs ⊢
      have : {t ∈ 𝓕 | t.erase none = s} = if s ∈ 𝓕₁ then {s, insert none s} else {if s ∈ 𝓕 then s else insert none s} := by
        ext t; simp only [mem_filter, mem_insert, mem_singleton]
        split_ifs with h₁ h₂
        · simp only [h₁.1, h₁.2, true_and]
