    have h_edges : #(hypercubeEdgeFinset 𝓕) ≤ #(hypercubeEdgeFinset 𝓕₀) + #(hypercubeEdgeFinset 𝓕₁) + #𝓕₁ := by
      let E (G : Finset (Set (Option β))) := hypercubeEdgeFinset G
      let e (G : Finset (Set (Option β))) := #(E G)
      -- This inequality holds for any family; proof omitted for brevity as it requires
