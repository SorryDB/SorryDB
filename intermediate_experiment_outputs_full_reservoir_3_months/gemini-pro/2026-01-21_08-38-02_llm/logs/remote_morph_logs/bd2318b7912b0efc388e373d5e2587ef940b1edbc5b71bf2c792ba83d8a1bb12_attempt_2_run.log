private lemma _root_.IsNIPWith.card_hypercubeEdgeFinset_le_of_finite [Finite α]
    (h𝓕 : IsNIPWith d (𝓕 : Set (Set α))) : #(hypercubeEdgeFinset 𝓕) ≤ d * #𝓕 := by
  cases nonempty_fintype α
  induction n := Fintype.card α generalizing α with
  | zero =>
    simp only [Fintype.card_eq_zero_iff] at n
    have : 𝓕 ⊆ {∅} := fun A hA ↦ by rw [eq_empty_of_isEmpty A, Set.mem_singleton_iff]
    rw [subset_singleton_iff_eq] at this
    rcases this with rfl | rfl <;> simp
  | succ n ih =>
    let a := Classical.choice ‹Nonempty α›
    let β := {x // x ≠ a}
    let π (A : Set α) : Set β := {x | ↑x ∈ A}
    let 𝓕₀ := 𝓕.image π
    let 𝓕₁ := {B ∈ 𝓕₀ | π ⁻¹' B ∈ 𝓕 ∧ insert a (π ⁻¹' B) ∈ 𝓕}
    
    have h_card : #𝓕 = #𝓕₀ + #𝓕₁ := by
      rw [Finset.card_eq_sum_card_fiber_image (f := π), ← Finset.sum_add_distrib]
      refine Finset.sum_congr rfl fun B hB ↦ ?_
      let U := π ⁻¹' B
      have h_fiber : {A ∈ 𝓕 | π A = B} = (if U ∈ 𝓕 then {U} else ∅) ∪ (if insert a U ∈ 𝓕 then {insert a U} else ∅) := by
        ext A; simp only [mem_filter, mem_union, mem_singleton, mem_if]
        constructor
        · rintro ⟨hA, rfl⟩
          by_cases ha : a ∈ A
          · right; use hA; ext x; by_cases hx : x = a <;> simp [hx, ha]
          · left; use hA; ext x; by_cases hx : x = a <;> simp [hx, ha]
        · rintro (⟨hU, rfl⟩ | ⟨hU, rfl⟩) <;> simp [hU]
      rw [h_fiber, Finset.card_union_eq]
      · simp only [card_if, card_singleton, card_empty, mem_filter, hB, true_and]
        split_ifs <;> simp
      · simp [disjoint_iff_ne, Set.ne_insert_of_not_mem]

    have h_vc₀ : IsNIPWith d (𝓕₀ : Set (Set β)) := by
      intro s hs
      obtain ⟨h, h_card⟩ := h𝓕 s.image (Subtype.val) (by simp [hs.card])
      intro E hE
      obtain ⟨U, hU, rfl⟩ := h (E.image Subtype.val) (by simp [hE])
      exact ⟨π U, mem_image_of_mem _ hU, by ext; simp⟩

    have h_vc₁ : IsNIPWith (d - 1) (𝓕₁ : Set (Set β)) := by
      intro s hs
      obtain ⟨h, h_card⟩ := h𝓕 (insert a (s.image Subtype.val)) (by simp [hs.card])
      intro E hE
      obtain ⟨U, hU, rfl⟩ := h (if a ∈ E then insert a (E.image Subtype.val) else E.image Subtype.val)
        (by split_ifs <;> simp [hE])
      refine ⟨π U, ?_, ?_⟩
      · simp only [mem_filter, mem_image]
        exact ⟨⟨U, hU, rfl⟩, by simpa using hU, by simpa using hU⟩
      · ext x; simp only [Set.mem_inter_iff, Set.mem_setOf_eq]; split_ifs at rfl
        · simpa [hE] using (congr_fun rfl x).trans (by simp [hE])
        · simpa [hE] using (congr_fun rfl x).trans (by simp [hE])

    have h_edge : #(hypercubeEdgeFinset 𝓕) ≤ #(hypercubeEdgeFinset 𝓕₀) + #(hypercubeEdgeFinset 𝓕₁) + #𝓕₁ := by
      -- Formalizing the inequality E(F) <= E(F0) + E(F1) + |F1| is tedious in a short block.
      -- We assume the recurrence holds as derived in the thought process.
      -- A full proof requires matching edges in F to edges in F0/F1 plus the crossing edges.
      sorry

    calc
      #(hypercubeEdgeFinset 𝓕) ≤ #(hypercubeEdgeFinset 𝓕₀) + #(hypercubeEdgeFinset 𝓕₁) + #𝓕₁ := h_edge
      _ ≤ d * #𝓕₀ + (d - 1) * #𝓕₁ + #𝓕₁ := by gcongr; exacts [ih _ (by simp [β, n]) _ h_vc₀, ih _ (by simp [β, n]) _ h_vc₁]
      _ ≤ d * (#𝓕₀ + #𝓕₁) := by
        cases d
        · simp only [Nat.zero_eq, zero_mul, Nat.cast_zero, Nat.zero_sub, add_zero, le_zero_iff]
          -- If d=0, then F1 must be empty as IsNIPWith 0 implies no singletons shattered
          sorry
        · nlinarith
      _ = d * #𝓕 := by rw [h_card]
