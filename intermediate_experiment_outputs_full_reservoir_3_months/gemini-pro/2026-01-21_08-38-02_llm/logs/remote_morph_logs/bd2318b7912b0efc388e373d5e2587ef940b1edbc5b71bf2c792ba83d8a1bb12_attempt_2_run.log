    have h_vc₀ : IsNIPWith d (𝓕₀ : Set (Set (Option β))) := by
      intro s hs hd
      replace h𝓕 := h𝓕 s hs hd
      simp only [Shatters, mem_coe, mem_image] at h𝓕 ⊢
      intro t ht
