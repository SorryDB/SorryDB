private lemma _root_.IsNIPWith.card_hypercubeEdgeFinset_le_of_finite [Finite α]
    (h𝓕 : IsNIPWith d (𝓕 : Set (Set α))) : #(hypercubeEdgeFinset 𝓕) ≤ d * #𝓕 := by
  cases nonempty_fintype α
  induction' h : Fintype.card α with n ih generalizing α 𝓕
  · rw [Fintype.card_eq_zero_iff] at h
    have : IsEmpty α := h
    simp only [hypercubeEdgeFinset, Finset.card_eq_zero, Finset.filter_eq_empty_iff,
      Set.ncard_eq_one, not_exists, not_and]
    intros A _ B _
    simp [Set.eq_empty_of_isEmpty (A ∆ B)]
  · obtain ⟨x⟩ : Nonempty α := Fintype.card_pos_iff.1 (h.symm ▸ Nat.succ_pos _)
    let α' := {a // a ≠ x}
    let π (A : Set α) : Set α' := {a | a.1 ∈ A}
    let 𝓕' := 𝓕.image π
    let 𝓕'' := 𝓕'.filter fun A ↦ (Subtype.val '' A) ∈ 𝓕 ∧ insert x (Subtype.val '' A) ∈ 𝓕
    let 𝓕₀ := 𝓕.filter (x ∉ ·)
    let 𝓕₁ := 𝓕.filter (x ∈ ·)
    have h_inj₀ : {A ∈ 𝓕 | x ∉ A}.InjOn π := fun A hA B hB h ↦ by
      ext a; by_cases ha : a = x <;> simp [ha, mem_filter.1 hA, mem_filter.1 hB]
      rw [← (Iff.rfl : a ∈ A ↔ ⟨a, ha⟩ ∈ π A), h]; rfl
