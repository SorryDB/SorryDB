    have : ∀ i, c i = 0 := λ i ↦ by
      have h_sum : ∑ i, c i * v i 2 = 0 := by 
        have := (Variable.funext_iff _ _).mp hc_sum 2
        simp [v] at this; exact this
      simp [v] at h_sum
      linarith [this i, h_sum]
    exact hc_ne (funext this)
  have hJ : J.Nonempty := by
    by_contra h; push_neg at h; simp [Set.eq_empty_iff_forall_not_mem] at h
    have : ∀ i, c i ≥ 0 := λ i ↦ not_lt.mp (h i)
