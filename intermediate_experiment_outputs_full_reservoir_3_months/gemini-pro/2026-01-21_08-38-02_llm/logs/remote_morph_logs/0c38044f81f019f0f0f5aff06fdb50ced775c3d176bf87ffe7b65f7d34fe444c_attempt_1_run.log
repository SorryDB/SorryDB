  -- Since dim(ℝ²) = 2, any 4 points are affinely dependent.
  let f : (Fin 4 → ℝ) →ₗ[ℝ] (ℝ × (Fin 2 → ℝ)) :=
  { toFun := λ c ↦ (∑ i, c i, ∑ i, c i • x i)
    map_add' := by intros; simp; rfl
    map_smul' := by intros; simp; rfl }
  -- The dimension of domain (4) is greater than codomain (3), so kernel is non-trivial.
  have h_ker : ∃ c : Fin 4 → ℝ, c ≠ 0 ∧ f c = 0 := by
    have h_dim : FiniteDimensional.finrank ℝ (Fin 4 → ℝ) > FiniteDimensional.finrank ℝ (ℝ × (Fin 2 → ℝ)) := by
      simp [FiniteDimensional.finrank_prod]; norm_num
    have := LinearMap.finrank_lt_finrank_of_injective f
    by_contra h; push_neg at h
    apply ne_of_gt h_dim
    apply this h
