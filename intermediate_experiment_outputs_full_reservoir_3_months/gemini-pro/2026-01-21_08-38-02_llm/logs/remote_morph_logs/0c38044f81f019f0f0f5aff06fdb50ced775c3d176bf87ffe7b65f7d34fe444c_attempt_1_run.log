  -- = ∑_{j ∈ N} -c_j (x_j + t)
  have h_eq : p_trans = (W⁻¹) • ∑ j in N.toFinset, (-c j) • (x j + t) := by
    sorry -- Standard affine algebra

  -- Proof that p_trans is in convex hull of points OUTSIDE C
  have h_out_hull : p_trans ∈ convexHull ℝ {z | z ∉ C} := by
    rw [h_eq]
    apply Convex.sum_mem (convex_convexHull ..)
    · intros j hj
      apply subset_convexHull
      -- For j ∈ N, c j < 0, so j ∉ P = S. Thus x j + t ∉ C.
      rw [mem_setOf_eq]
      intro h
      have : j ∈ S := (hxy j S).mp h
      have : c j > 0 := this
      have : c j < 0 := hj
      linarith
    · intros j hj; rw [lt_neg, neg_zero]; exact hj
    · rw [←Finset.sum_neg_distrib]; simp only [W, h_sum_c]; sorry -- sum P c = sum N -c

  -- Contradiction: p_trans ∈ C and p_trans ∈ conv({z ∉ C})
