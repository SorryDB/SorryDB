    | inr h =>
      apply Finset.sum_pos
      · intros; simp at *; assumption
      · use i; simp; assumption

  let S := ∑ i in I.toFinset, c i
  let p := S⁻¹ • ∑ i in I.toFinset, c i • x i
  
  -- p is in convex hull of x[I] and x[J]
  have hpI : p ∈ convexHull ℝ (x '' I) := by
    rw [convexHull_image]; apply convexHull_finset_mem
    · intros i hi; apply mul_nonneg (inv_nonneg.2 (le_of_lt h_sum_pos)); exact le_of_lt (Set.mem_setOf.1 hi)
    · rw [Finset.mul_sum, inv_mul_cancel (ne_of_gt h_sum_pos)]
    · simp [p]
  
  -- Symmetric argument for J
  have hpJ : p ∈ convexHull ℝ (x '' J) := by
     sorry -- Symmetric construction using -c

  -- Apply shattering property
  let yI := y I
  let yJ := y J
  -- C_I contains x[I] (thus p), misses x[J]
  -- C_J contains x[J] (thus p), misses x[I]
  have hp_in_CI : p ∈ C - {yI} := by
    rw [sub_eq_add_neg, ←Set.vadd_eq_add]; apply hC.vadd_mem (Set.neg_mem_singleton.2 rfl)
    apply convexHull_min _ hC _ hpI; intros z ⟨i, hi, hx⟩; rw [←hx]
    have := (hxy i I).2 hi; simp at this; rwa [add_comm, ←sub_eq_add_neg] at this
  
  have hp_in_CJ : p ∈ C - {yJ} := by
    rw [sub_eq_add_neg, ←Set.vadd_eq_add]; apply hC.vadd_mem (Set.neg_mem_singleton.2 rfl)
    apply convexHull_min _ hC _ hpJ; intros z ⟨j, hj, hx⟩; rw [←hx]
    have := (hxy j J).2 hj; simp at this; rwa [add_comm, ←sub_eq_add_neg] at this

  -- If a point k is in hull of others (e.g. J={k}), then k ∈ I is false, but x_k ∈ C_I (convexity).
  -- Shattering says x_k ∈ C_I ↔ k ∈ I. Contradiction.
  -- The only case surviving is |I|=2, |J|=2 (convex position).
  -- Known theorem: Translates of convex set in R2 cannot shatter 4 points.
