/-- Lemma 11 -/
lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ,o⟩
  induction σ using OSequence.rec generalizing S with
  | nil =>
    simp [eval, stubbornness] at a_kv_b ⊢
    rcases a_kv_b with (h|h) <;> (have : a = b := by aesop); subst this <;> simp_all
  | cons C σ o IH =>
    let σ_prev : OSequence := ⟨σ, ⁻o⟩
    specialize IH (S := S)
    cases ra : roleOfIn a C
    case Other =>
      simp [resultSet, ra]
      rw [not_in_call_then_invariant_kv ra] at a_kv_b
      apply IH a_kv_b
    case Caller | Callee =>
      by_cases h_prev : eval S σ_prev (Kv a b)
      · -- Case: Known before.
        rcases IH h_prev with ⟨in_true, not_in_false⟩
        let refuse := { ⟨j, d⟩ | eval S σ_prev (K a (Has j (j, !d))) }
        have : (b, ! S b) ∈ refuse := by
          simp [refuse]; rcases h_prev with (h|h) <;> [left;right] <;> { convert h; simp }
        have : (b, S b) ∉ refuse := by
           intro h; simp [refuse] at h
           rcases h_prev with (kb|kb) <;> cases h <;>
             (have t1 := true_of_knowldege ‹_›; have t2 := true_of_knowldege ‹_›; simp [stubbornness] at t1 t2; simp_all)
        have : (b, S b) ∉ (match C, ra with | ⌜ a b ⌝, Caller => _ | _, _ => _) := by
           dsimp; intro h_del; simp at h_del
           have := h_del S σ_prev C (by apply equiv_refl) (by simp [ra]) (by simp)
           simp [stubbornness] at this
        cases C <;> simp_all [resultSet, ra] <;> (try simp [roleOfIn] at ra; subst ra) <;>
          simp [resultSet] <;> refine ⟨⟨?_, ?_⟩, ?_⟩ <;> (try assumption; try contradiction)
      · -- Case: Learned now.
        -- If learned now, then a must have received the correct value, and not have the incorrect value.
        -- We verify this by cases on the call C.
        rcases a_kv_b with (knows_true | knows_false)
        all_goals
          have val_eq : S b = (try true; try false; assumption) := by
             try rfl; try assumption; by_contra h; simp at h
             have := true_of_knowldege ‹_›; simp [stubbornness, h] at this
          subst val_eq; simp at *
          -- K a (Has b (b, val)). implies (b, val) in set and (b, !val) not in set.
          cases C <;> simp_all [resultSet, ra] <;> (try simp [roleOfIn] at ra; subst ra) <;>
          simp [resultSet]
          all_goals
             -- The simplifier and grind should handle the set membership logic
             -- For "in set": comes from partner.
             -- For "not in set": if in set, contradiction with K (as !val implies distinguishable world or conflict).
             -- We use the fact that if (b, !val) were in set, a would not know (b, val).
             -- This direction is hard for `grind` without the lemma, but we use `indistinguishable_then_same_values` if needed.
             -- However, pure `grind` often solves finite set logic if expanded.
             try { refine ⟨?_, ?_⟩; grind; grind }
             -- Manual fallback for tricky cases:
             refine ⟨?_, ?_⟩
             · -- (b, S b) ∈ ...
               -- Partner has it (stubbornness).
               try { left; simp [stubbornness] }
               try { right; simp [stubbornness] }
               try { left; left; simp [stubbornness] }
               try { right; left; simp [stubbornness] }
               all_goals grind
             · -- (b, ! S b) ∉ ...
               -- Not in partner (stubbornness).
               -- Not in self (otherwise conflict -> not K).
               -- Since we can't easily prove "conflict -> not K" here without a lemma,
               -- we rely on the `delete` mechanism for direct calls, and `grind` for logic.
               grind
