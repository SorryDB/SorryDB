        all_goals
          have a_knows_after := a_knows_after_t
          try have a_knows_after := a_knows_after_f
          have val_true := true_of_knowldege a_knows_after
          simp at val_true
          
          -- Properties of "delete" and "refuse"
          have not_deleted : (b, !S b) ∉ delete (if roleOfIn a C = Caller then Prod.snd else Prod.fst) := by
             intro h_del
             simp [resultSet] at h_del
             apply h_del
             intros T τ D equ role_D same_contrib
             apply a_knows_after T ⟨D::τ, by aesop⟩ (by simp [OSequence.length]; exact equ.1)
