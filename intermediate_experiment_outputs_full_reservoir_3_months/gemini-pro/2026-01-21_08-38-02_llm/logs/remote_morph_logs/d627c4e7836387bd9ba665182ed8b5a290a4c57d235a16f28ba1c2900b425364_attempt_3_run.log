  induction σ generalizing S
  case nil =>
    unfold eval eval eval at a_kv_b
    simp only [not_and_or, not_not] at a_kv_b
    rcases a_kv_b with h|h
    all_goals
      simp_all [eval]
      by_cases h_eq : b = a
      · subst h_eq; simp at *
      · exfalso
        have := h S ⟨[], by simp [maxOne]⟩ (by simp)
        have := h (S.switch b) ⟨[], by simp [maxOne]⟩ (by simp) (by simp [Dist.switch]; grind)
        simp_all [Dist.switch]
  case cons C σ IH =>
    cases ra : roleOfIn a C
    case Other =>
      rw [not_in_call_then_invariant_resultSet ra]
      rw [not_in_call_then_invariant_kv ra] at a_kv_b
      exact IH (⁻o) a_kv_b
    all_goals
      by_cases h : eval S ⟨σ,⁻o⟩ (Kv a b)
      · have ih := IH (⁻o) h
        unfold resultSet
        simp only [ra, stubbornness, Subtype.forall, OSequence.length_def]
        cases C <;> simp_all [resultSet, roleOfIn]
        -- Logic for persistence of correct belief
        all_goals
          refine ⟨⟨?_, ?_⟩, ?_⟩
          · cases S b <;> simp_all; exact ih.1
          · cases S b <;> simp_all; exact ih.1
          · intro; cases S b <;> simp_all; exact ih.2 (by assumption)
      · -- Logic for learning the secret
        rw [eval_dis] at a_kv_b
        rcases a_kv_b with (knows_true | knows_false)
        all_goals
          have truth := true_of_knowldege (by assumption)
          simp at truth
          unfold resultSet
