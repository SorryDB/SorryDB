/-- Lemma 11 -/
lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro a_kv_b
  rcases σ with ⟨σ,o⟩
  induction σ generalizing S
  case nil =>
    simp [eval, Kv, eval_dis, stubbornness] at a_kv_b ⊢
    rcases a_kv_b with h|h <;> simp_all [resultSet, know_self]
  case cons C σ IH =>
    -- We know 'a' knows the correct value
    have k_correct : S⌈⟨C::σ,o⟩⌉ ⊧ K a ((b, S b) @ b) := by
      rcases a_kv_b with h|h <;> cases S b <;> simp_all [stubbornness, true_of_knowldege h]
    
    -- Thus (b, !S b) is deleted (and thus not in result set)
    have wrong_deleted : (b, !S b) ∉ S⌈⟨C::σ, o⟩⌉a := by
      simp [resultSet]
      cases roleOfIn a C <;> simp [resultSet] <;>
      ( intro h; rcases h with ⟨_, h_del⟩
        simp [Set.mem_setOf_eq] at h_del
        -- The delete condition is exactly K a (b, S b)
        apply h_del S ⟨C::σ, o⟩ rfl equiv_refl
        cases S b <;> simp_all [eval] )

    refine ⟨?_, wrong_deleted⟩

    -- Now prove (b, S b) is in the result set
    cases roleOfIn a C
    case Other =>
      simp [roleOfIn_eq_Other_iff] at *
      simp [resultSet, *] at a_kv_b ⊢
      rw [not_in_call_then_invariant_kv] at a_kv_b
      exact (IH (⁻o) a_kv_b).1
      assumption
    all_goals -- Caller or Callee
      -- If 'a' knew before, IH applies.
      by_cases h_prev : eval S ⟨σ,⁻o⟩ (Kv a b)
      · specialize IH (⁻o) h_prev
        rcases IH with ⟨in_set, not_in_set⟩
        simp [resultSet, *]
