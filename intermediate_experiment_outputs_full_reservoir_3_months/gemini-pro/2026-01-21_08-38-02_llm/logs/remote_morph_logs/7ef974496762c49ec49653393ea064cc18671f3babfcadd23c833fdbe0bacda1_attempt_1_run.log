    rw [← sub_add_cancel y x, add_assoc, hx_s, Real.dist_eq, abs_sub_comm] at hxy_le ⊢
    rw [abs_lt] at hxy_le
    constructor
    · linarith [hs.1, hxy_le.1]
    · linarith [hs.2, hxy_le.2]
  calc ‖f x - f y‖
    _ = ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ)) + (f (y + τ) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := norm_add₃_le ..
    _ = ‖f (x + τ) - f x‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := by
