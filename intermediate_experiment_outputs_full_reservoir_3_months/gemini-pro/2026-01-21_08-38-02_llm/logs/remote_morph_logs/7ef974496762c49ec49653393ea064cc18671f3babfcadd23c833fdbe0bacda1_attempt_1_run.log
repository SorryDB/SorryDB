/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous (hc : Continuous f) (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  have h_compact : IsCompact (Set.Icc (-l) (2 * l)) := isCompact_Icc
  have h_uc : UniformContinuousOn f (Set.Icc (-l) (2 * l)) :=
    hc.continuousOn.uniformContinuousOn_isCompact h_compact
  rw [Metric.uniformContinuousOn_iff] at h_uc
  obtain ⟨δ, hδ, h_uc_δ⟩ := h_uc (ε / 3) hε3
  use min δ l
  constructor
  · positivity
  rintro x y hxy
  have hxy_δ : dist x y < δ := lt_of_lt_of_le hxy (min_le_left _ _)
  have hxy_l : dist x y < l := lt_of_lt_of_le hxy (min_le_right _ _)
  obtain ⟨τ, hτ_in, hτ_ap⟩ := hl (-x)
  let T := -x + τ
  have hT : IsLinftyAP (ε / 3) T f := hτ_ap
  have hxT : x + T = τ := by simp [T]
  have hyT : y + T = y - x + τ := by simp [T]; ring
  have h_x_bound : x + T ∈ Set.Icc (-l) (2 * l) := by
    rw [hxT]
    have : τ ∈ Set.Ico 0 l := hτ_in
    rw [Set.mem_Ico] at this
    constructor <;> linarith
  have h_y_bound : y + T ∈ Set.Icc (-l) (2 * l) := by
    rw [hyT]
    have : τ ∈ Set.Ico 0 l := hτ_in
    rw [Set.mem_Ico] at this
    rw [dist_eq_norm, Complex.norm_eq_abs, abs_sub_lt_iff] at hxy_l
    constructor <;> linarith
  calc dist (f x) (f y)
    _ ≤ dist (f x) (f (x + T)) + dist (f (x + T)) (f (y + T)) + dist (f (y + T)) (f y) := dist_triangle4 ..
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · rw [dist_comm, dist_eq_norm]
        exact hT x
      · apply h_uc_δ _ h_x_bound _ h_y_bound
        rw [dist_eq_norm, hxT, hyT]; simp
        exact hxy_δ
      · rw [dist_eq_norm]
        exact hT y
    _ = ε := by ring
