  have : UniformContinuousOn f (Set.Icc (-1) (l + 1)) :=
    hc.uniformContinuousOn_of_isCompact isCompact_Icc
  obtain ⟨δ, hδ, h_unif⟩ := metric.uniformContinuousOn_iff.mp this (ε / 3) hε3
  refine ⟨min δ 1, by positivity, fun x y hxy ↦ ?_⟩
  rw [dist_eq_norm] at hxy ⊢
  obtain ⟨y_shift, hy_shift, hτ⟩ := hl (-x)
  let τ := -x + y_shift
  have hτ_in : IsLinftyAP (ε / 3) τ f := hτ
  have hx_shift : x + τ ∈ Set.Icc (-1) (l + 1) := by
    rw [Set.mem_Icc]
