lemma IsUnifAlmostPeriodic.uniformContinuous [Continuous f] (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  metric
  intro ε hε
  obtain ⟨l, hl⟩ := hf (div_pos hε (by norm_num : (0 : ℝ) < 3))
  have : IsCompact (Set.Icc (-1) (l + 1)) := isCompact_Icc
  obtain ⟨δ, hδ, h_uc⟩ := Metric.uniformContinuousOn_iff.mp
    ((Continuous.continuousOn ‹_›).uniformContinuousOn_isCompact this) (ε / 3) (by positivity)
  refine ⟨min δ 1, lt_min hδ zero_lt_one, fun x y hxy ↦ ?_⟩
  rw [dist_eq_norm] at hxy ⊢
  obtain ⟨t, ht, hτ⟩ := hl (-x)
  let τ := -x + t
  have hx : x + τ ∈ Set.Icc (-1) (l + 1) := by
    simp [τ]; constructor <;> linarith [ht.1, ht.2]
  have hy : y + τ ∈ Set.Icc (-1) (l + 1) := by
    simp [τ]; rw [dist_eq_norm] at hxy
    have : |(y + τ) - (x + τ)| < 1 := by
      simp; exact hxy.trans_lt (min_le_right _ _)
    constructor <;> linarith [hx.1, hx.2, abs_lt.mp this]
  calc
    ‖f x - f y‖ = ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ)) + (f (y + τ) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := by repeat apply norm_add_le
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · rw [norm_sub_rev]; exact hτ x
      · refine h_uc hx hy ?_
        simp [dist_eq_norm, τ]; exact hxy.trans_le (min_le_left _ _)
      · exact hτ y
    _ = ε := by ring
