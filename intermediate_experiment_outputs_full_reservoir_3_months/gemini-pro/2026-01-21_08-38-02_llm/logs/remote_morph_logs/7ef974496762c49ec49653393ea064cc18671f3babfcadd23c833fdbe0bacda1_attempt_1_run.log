  calc ‖f x - f y‖
    _ = ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ)) + (f (y + τ) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := norm_add₃_le ..
    _ = ‖f (x + τ) - f x‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := by rw [norm_sub_rev]
