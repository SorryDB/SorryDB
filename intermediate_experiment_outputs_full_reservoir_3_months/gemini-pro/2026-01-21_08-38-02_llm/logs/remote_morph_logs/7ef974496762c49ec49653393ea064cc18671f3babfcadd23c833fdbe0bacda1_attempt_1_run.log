  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  have h_unif := h_cont.uniformContinuousOn_isCompact (isCompact_Icc : IsCompact (Set.Icc (-l) (2 * l)))
  obtain ⟨δ, hδ, h_unif⟩ := Metric.uniformContinuousOn_iff.mp h_unif (ε / 3) hε3
  refine ⟨min δ l, lt_min hδ (IsRelDenseWith.pos hl), fun x y hxy ↦ ?_⟩
  rw [lt_min_iff] at hxy
  obtain ⟨y', hy', hper⟩ := hl (-x)
  let τ := -x + y'
  have hx : x + τ ∈ Set.Icc (-l) (2 * l) := by
    simp only [τ, add_neg_cancel_left]
    constructor
    · trans 0; · apply (IsRelDenseWith.pos hl).le.trans (neg_le_self (IsRelDenseWith.pos hl).le); · exact hy'.1
    · trans l; · exact hy'.2.le; · linarith [IsRelDenseWith.pos hl]
  have hy : y + τ ∈ Set.Icc (-l) (2 * l) := by
    simp only [τ]
    have : dist x y < l := hxy.2
    rw [dist_eq_norm, Complex.norm_eq_abs] at this ⊢
    have : |y - x| < l := by rwa [← Complex.norm_eq_abs, ← dist_eq_norm]
    constructor
    · linarith [hy'.1, (abs_lt.mp this).1]
    · linarith [hy'.2, (abs_lt.mp this).2]
  calc
    ‖f x - f y‖ = ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ)) + (f (y + τ) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := norm_add₃_le ..
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · rw [← dist_eq_norm, dist_comm]; exact hper x
      · apply h_unif hx hy
        rw [dist_eq_norm]; exact hxy.1
      · rw [← dist_eq_norm]; exact hper y
    _ = ε := by ring
