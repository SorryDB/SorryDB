    constructor
    · exact (neg_le_self zero_le_one).trans ht.1
    · exact ht.2.le.trans (le_add_of_nonneg_right zero_le_one)
  have h_shift_y : y + τ ∈ Set.Icc (-1 : ℝ) (l + 1) := by
