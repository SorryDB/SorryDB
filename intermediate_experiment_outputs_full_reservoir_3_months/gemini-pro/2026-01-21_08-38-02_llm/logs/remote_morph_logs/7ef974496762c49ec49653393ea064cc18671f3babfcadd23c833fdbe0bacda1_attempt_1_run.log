lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := div_pos hε (by norm_num)
  obtain ⟨l, hl⟩ := hf hε3
  have hl_pos : 0 < l := hl.pos
  have hc : Continuous f := by infer_instance
  have h_unif : UniformContinuousOn f (Set.Icc (-l) (2 * l)) :=
    hc.continuousOn.uniformContinuousOn_isCompact isCompact_Icc
  rw [Metric.uniformContinuousOn_iff] at h_unif
  obtain ⟨δ, hδ0, hδ⟩ := h_unif (ε / 3) hε3
  use min δ l
  constructor
  · exact lt_min hδ0 hl_pos
  rintro x y hxy
  have hxy_lt_δ : dist x y < δ := lt_of_lt_of_le hxy (min_le_left _ _)
  have hxy_lt_l : dist x y < l := lt_of_lt_of_le hxy (min_le_right _ _)
  rw [dist_eq_norm] at hxy_lt_δ hxy_lt_l
  obtain ⟨τ, hτ, hτ_per⟩ := hl (-x)
  let T := -x + τ
  have hT_per : IsLinftyAP (ε / 3) T f := hτ_per
  have h_shift_x : x + T ∈ Set.Icc (-l) (2 * l) := by
    rw [← add_assoc, neg_add_cancel, zero_add]
    exact ⟨(by linarith [hτ.1]), (by linarith [hτ.2])⟩
  have h_shift_y : y + T ∈ Set.Icc (-l) (2 * l) := by
    rw [← add_assoc, neg_add_cancel, zero_add]
    have : y + T = (y - x) + τ := by ring
    rw [this]
    constructor
    · calc
        -l < -(x - y) + 0 := by
           rw [neg_sub]; exact add_lt_add_of_lt_of_le (lt_of_le_of_lt (abs_sub_le_iff.mp (le_of_lt hxy_lt_l)).1 (by linarith)) hτ.1
        _ ≤ (y - x) + τ := add_le_add (le_of_eq rfl) hτ.1
    · calc
        (y - x) + τ < l + l := add_lt_add (lt_of_le_of_lt (abs_sub_le_iff.mp (le_of_lt hxy_lt_l)).2 (by linarith)) hτ.2
        _ = 2 * l := by ring
  calc
    dist (f x) (f y) = ‖f x - f y‖ := dist_eq_norm _ _
    _ = ‖f x - f (x + T) + (f (x + T) - f (y + T)) + (f (y + T) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + T)‖ + ‖f (x + T) - f (y + T)‖ + ‖f (y + T) - f y‖ := norm_add₃_le ..
    _ = ‖f (x + T) - f x‖ + ‖f (x + T) - f (y + T)‖ + ‖f (y + T) - f y‖ := by rw [norm_sub_rev (f x)]
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · exact hT_per x
      · apply hδ
        · exact h_shift_x
        · exact h_shift_y
        · rw [dist_eq_norm]
          have : x + T - (y + T) = x - y := by ring
          rw [this]
          exact hxy_lt_δ
      · rw [norm_sub_rev]; exact hT_per y
    _ = ε := by ring
