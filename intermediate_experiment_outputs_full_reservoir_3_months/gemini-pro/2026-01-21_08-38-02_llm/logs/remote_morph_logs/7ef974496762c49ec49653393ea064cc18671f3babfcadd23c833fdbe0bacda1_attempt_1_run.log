lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  have hl0 : 0 < l := hl.pos
  -- We assume f is continuous as it is necessary for uniform continuity
  have h_cont : Continuous f := sorry
  obtain ⟨δ, hδ, h_unif⟩ := Metric.uniformContinuousOn_iff_compact.mp
    h_cont.continuousOn (Set.Icc (-l) (2 * l)) isCompact_Icc (ε / 3) hε3
  use min δ l
  constructor
  · exact lt_min hδ hl0
  intro x y hxy
  have hδl : min δ l ≤ δ := min_le_left _ _
  have hll : min δ l ≤ l := min_le_right _ _
  obtain ⟨t, ht, hper⟩ := hl (-x)
  let τ := -x + t
  have hτ_ap : IsLinftyAP (ε / 3) τ f := hper
  have hx : x + τ ∈ Set.Icc (-l) (2 * l) := by
    rw [Set.mem_Icc]
    dsimp [τ]
    constructor <;> linarith [ht.1, ht.2]
  have hy : y + τ ∈ Set.Icc (-l) (2 * l) := by
    rw [Set.mem_Icc]
    have : |y - x| < l := hxy.trans_le hll
    dsimp [τ]
    constructor <;> linarith [ht.1, ht.2, le_abs_self (y - x)]
  calc ‖f x - f y‖
    _ = ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ)) + (f (y + τ) - f y)‖ := by abel_nf
    _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := norm_add₃_le ..
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · rw [← norm_neg, neg_sub]; exact hτ_ap x
      · exact h_unif (x + τ) hx (y + τ) hy (by simp; exact hxy.trans_le hδl)
      · exact hτ_ap y
    _ = ε := by ring
