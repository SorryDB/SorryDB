/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous [Continuous f] (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  let K := Set.Icc (-1) (l + 1)
  have hK : IsCompact K := isCompact_Icc
  obtain ⟨δ, hδ, hδ'⟩ := Metric.uniformContinuousOn_iff_le.mp
    (hK.uniformContinuousOn_of_continuous f.continuous.continuousOn) (ε / 3) hε3
  refine ⟨min δ 1, by positivity, fun x y hxy ↦ ?_⟩
  rw [dist_eq_norm] at hxy
  obtain ⟨τ, hτ, hT⟩ := hl (-x)
  have hx' : x + (-x + τ) ∈ K := by
    simp only [K, Set.mem_Icc]
    constructor
    · exact (neg_le_self zero_le_one).trans hτ.1
    · exact hτ.2.le.trans (le_add_of_nonneg_right zero_le_one)
  have hy' : y + (-x + τ) ∈ K := by
    simp only [K, Set.mem_Icc]
    have : ‖y - x‖ < 1 := lt_of_lt_of_le hxy (min_le_right _ _)
    rw [norm_sub_rev, Real.norm_eq_abs, abs_lt] at this
    constructor
    · linarith [hτ.1, this.1]
    · linarith [hτ.2, this.2]
  calc
    ‖f x - f y‖ = ‖(f x - f (x + (-x + τ))) + (f (x + (-x + τ)) - f (y + (-x + τ))) + (f (y + (-x + τ)) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + (-x + τ))‖ + ‖f (x + (-x + τ)) - f (y + (-x + τ))‖ + ‖f (y + (-x + τ)) - f y‖ := norm_add₃_le ..
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · simpa using hT x
