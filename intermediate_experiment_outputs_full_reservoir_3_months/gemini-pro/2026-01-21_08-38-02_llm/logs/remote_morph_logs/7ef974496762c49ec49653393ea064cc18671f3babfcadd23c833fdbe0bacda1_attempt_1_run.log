    constructor
    · calc -1 ≤ x + t - 1 := by linarith
           _ ≤ x + t - |x - y| := by
             gcongr; rw [abs_sub_comm]; exact le_of_lt hxy'
           _ ≤ x + t - (x - y) := sub_le_sub_left (le_abs_self _) _
           _ = y + t := by ring
    · calc y + t = x + t + (y - x) := by ring
           _ ≤ x + t + |y - x| := by gcongr; exact le_abs_self _
           _ < l + 1 := by
             rw [Real.dist_eq] at hxy'; linarith
  calc
    ‖f x - f y‖ = ‖(f x - f (x + t)) + (f (x + t) - f (y + t)) + (f (y + t) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (y + t)‖ + ‖f (y + t) - f y‖ := norm_add₃_le _ _ _
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · rw [norm_sub_rev]; exact hτf x
      · apply hδ hx'K hy'K
        rw [dist_add_right]; exact hxy_δ
      · exact hτf y
    _ = ε := by ring
