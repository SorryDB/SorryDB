lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  let ε' := ε / 3
  have hε' : 0 < ε' := by positivity
  obtain ⟨l, hl⟩ := hf hε'
  have hl_pos : 0 < l := hl.pos
  have h_cont : UniformContinuousOn f (Set.Icc (-l) (2 * l)) :=
    (Continuous.continuousOn assumption).uniformContinuousOn isCompact_Icc
  obtain ⟨δ, hδ, h_unif⟩ := Metric.uniformContinuousOn_iff.mp h_cont ε' hε'
  refine ⟨min δ l, by positivity, fun x y hxy ↦ ?_⟩
  rw [dist_eq_norm] at hxy ⊢
  obtain ⟨τ, hτ_in, hτ_ap⟩ := hl (-x)
  let t := -x + τ
  have hx' : x + t ∈ Set.Ico 0 l := by simpa [t] using hτ_in
  have hxy' : ‖x - y‖ < δ := (min_le_left _ _).trans_lt hxy
  have hxy_l : ‖x - y‖ < l := (min_le_right _ _).trans_lt hxy
  rw [Real.norm_eq_abs] at hxy_l
  have hy' : y + t ∈ Set.Icc (-l) (2 * l) := by
    rw [Set.mem_Icc]
    constructor
    · calc
        -l < -|x - y| := neg_lt_neg hxy_l
        _ ≤ y - x := neg_abs_le_sub _ _
        _ ≤ (x + t) + (y - x) := le_add_of_nonneg_left hx'.1
        _ = y + t := by ring
    · calc
        y + t = x + t + (y - x) := by ring
        _ < l + |y - x| := add_lt_add_of_lt_of_le hx'.2 (le_abs_self _)
        _ < l + l := add_lt_add_left hxy_l _
        _ = 2 * l := by ring
  calc
    ‖f x - f y‖ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (y + t)‖ + ‖f (y + t) - f y‖ := by
      rw [← dist_eq_norm, ← dist_eq_norm, ← dist_eq_norm, ← dist_eq_norm]
      refine (dist_triangle _ (f (x + t)) _).trans (add_le_add_left (dist_triangle _ _ _) _)
    _ ≤ ε' + ε' + ε' := by
      apply add_le_add
      · apply add_le_add
        · rw [norm_sub_rev]; exact hτ_ap x
        · apply h_unif (Set.Ico_subset_Icc_self hx') hy'
          rw [dist_eq_norm, add_sub_add_right_eq_sub]
