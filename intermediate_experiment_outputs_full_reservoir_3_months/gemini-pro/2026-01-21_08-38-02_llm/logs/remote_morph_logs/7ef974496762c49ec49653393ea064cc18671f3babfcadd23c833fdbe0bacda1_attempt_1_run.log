lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  let ε' := ε / 3
  have hε' : 0 < ε' := by positivity
  obtain ⟨l, hl⟩ := hf hε'
  have : Continuous f := sorry
  obtain ⟨δ, hδ, hδ_unif⟩ := Metric.uniformContinuousOn_iff.1
    (isCompact_Icc.uniformContinuousOn_of_continuous (this.continuousOn (s := Set.Icc (-1) (l + 1)))) ε' hε'
  refine ⟨min δ 1, by positivity, fun x y hxy ↦ ?_⟩
  obtain ⟨y', hy', hfy'⟩ := hl (-x)
  let t := -x + y'
  have hx : x + t = y' := by ring
  have hx_mem : x + t ∈ Set.Icc (-1) (l + 1) := by
    rw [hx]
    exact Set.Icc_subset_Icc (by norm_num) (by simp) (Set.Ico_subset_Icc_self hy')
  have hy_mem : y + t ∈ Set.Icc (-1) (l + 1) := by
    rw [dist_eq_norm, Real.norm_eq_abs, abs_lt, lt_min_iff] at hxy
    rw [Set.mem_Icc] at hx_mem ⊢
    constructor
    · have := hxy.2; rw [hx] at hx_mem
      calc -1 = -1 + 0 := by ring
        _ ≤ (y - x) + y' := add_le_add (le_of_lt this.1) hy'.1
        _ = y + t := by ring
    · have := hxy.2; rw [hx] at hx_mem
      calc y + t = (y - x) + y' := by ring
        _ ≤ 1 + l := add_le_add (le_of_lt this.2) hy'.2.le
        _ = l + 1 := by ring
  calc dist (f x) (f y)
    _ ≤ dist (f x) (f (x + t)) + dist (f (x + t)) (f (y + t)) + dist (f (y + t)) (f y) := dist_triangle4 ..
    _ ≤ ε' + ε' + ε' := by
      gcongr
      · exact hfy' x
      · apply hδ_unif hx_mem hy_mem
        rw [dist_add_right]
        exact (lt_min_iff.1 hxy).1
      · rw [dist_comm]; exact hfy' y
    _ = ε := by field_simp [ε']; ring
