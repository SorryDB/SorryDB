    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  have h_uc := (hc.continuousOn.mono (Set.subset_univ _)).uniformContinuousOn (isCompact_Icc : IsCompact (Set.Icc (-1) (l + 1)))
  rw [Metric.uniformContinuousOn_iff] at h_uc
  obtain ⟨δ, hδ_pos, hδ⟩ := h_uc (ε / 3) hε3
  refine ⟨min δ 1, by positivity, fun x y hxy ↦ ?_⟩
  obtain ⟨y_shift, hy_shift, hτ⟩ := hl (-x)
  let τ := -x + y_shift
  let x' := x + τ
  let y' := y + τ
  have hx' : x' ∈ Set.Icc 0 l := by
    simp only [x', τ, neg_add_cancel_left]
    exact Set.Ico_subset_Icc_self hy_shift
  have hy' : y' ∈ Set.Icc (-1) (l + 1) := by
    rw [Set.mem_Icc]
    have : |x - y| ≤ 1 := by
