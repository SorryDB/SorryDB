lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  have hl0 : 0 < l := hl.pos
  have hc : Continuous f := by continuity
  obtain ⟨δ, hδ, hδ_cont⟩ := Metric.uniformContinuousOn_iff.mp
    hc.continuousOn (Set.Icc (-l) (2 * l)) isCompact_Icc (ε / 3) hε3
  use min δ l
  constructor
  · exact lt_min hδ hl0
  intro x y hxy
  rw [dist_eq_norm, lt_min_iff] at hxy
  obtain ⟨y', hy', ht⟩ := hl (-x)
  let t := -x + y'
  have hx' : x + t ∈ Set.Icc (-l) (2 * l) := by
    rw [Set.mem_Icc]
    dsimp [t]
    rw [add_comm, ← sub_eq_add_neg, sub_self, zero_add]
    constructor
    · exact (neg_lt_zero.mpr hl0).le.trans hy'.1
    · exact hy'.2.le.trans (by linarith)
  have hy' : y + t ∈ Set.Icc (-l) (2 * l) := by
    rw [Set.mem_Icc]
    dsimp [t]
    rw [add_comm (-x), ← add_assoc, sub_eq_add_neg y x]
    rw [dist_eq_norm, abs_sub_lt_iff] at hxy
    constructor
    · apply le_of_lt; linarith [hxy.1.1, hy'.1]
    · apply le_of_lt; linarith [hxy.1.2, hy'.2]
  calc
    dist (f x) (f y) = ‖f x - f y‖ := dist_eq_norm _ _
    _ = ‖(f x - f (x + t)) + (f (x + t) - f (y + t)) + (f (y + t) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (y + t)‖ + ‖f (y + t) - f y‖ :=
        (norm_add_le _ _).trans (add_le_add_left (norm_add_le _ _) _)
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · exact ht x
      · apply hδ_cont hx' hy'
        rw [dist_eq_norm, add_sub_add_right_eq_sub]
        exact hxy.1
      · rw [norm_sub_rev]; exact ht y
    _ = ε := by ring
