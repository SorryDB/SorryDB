lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  have hc : Continuous f := inferInstance
  have h_uc := hc.uniformContinuousOn_of_isCompact (isCompact_Icc : IsCompact (Set.Icc (-(l + 1)) 1))
  rcases Metric.uniformContinuousOn_iff.mp h_uc (ε / 3) hε3 with ⟨δ, hδ, hδ_le⟩
  refine ⟨min δ 1, by positivity, fun x y hxy ↦ ?_⟩
  rcases hl x with ⟨t, ht, ht_per⟩
  let τ := x + t
  have hτ : IsLinftyAP (ε / 3) τ f := ht_per
  calc
    ‖f x - f y‖ = ‖(f x - f (x - τ)) + (f (x - τ) - f (y - τ)) + (f (y - τ) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x - τ)‖ + ‖f (x - τ) - f (y - τ)‖ + ‖f (y - τ) - f y‖ := by
      repeat (refine (norm_add_le _ _).trans (add_le_add_right ?_ _))
      rfl
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · exact hτ (x - τ)
      · apply hδ_le
        · rw [show x - τ = -t by ring]
          apply Set.mem_Icc_of_subset_of_mem (fun z hz ↦ ⟨by linarith [hz.1], by linarith [hz.2]⟩)
          rw [Set.mem_Ico] at ht; constructor <;> linarith
        · rw [show y - τ = -t - (x - y) by ring]
          rw [dist_eq_norm, norm_sub_rev] at hxy
          rw [Set.mem_Ico] at ht
          have : |x - y| < 1 := (lt_min_iff.mp hxy).2
          rw [abs_sub_comm] at this
          constructor <;> linarith
        · rw [dist_eq_norm]; simp; exact (lt_min_iff.mp hxy).1
      · exact hτ (y - τ)
    _ = ε := by ring
