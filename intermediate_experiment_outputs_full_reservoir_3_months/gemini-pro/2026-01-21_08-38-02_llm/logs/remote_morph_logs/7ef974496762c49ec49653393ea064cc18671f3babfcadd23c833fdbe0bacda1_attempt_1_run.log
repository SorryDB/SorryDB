    _ ≤ ‖f x - f x'‖ + ‖f x' - f y'‖ + ‖f y' - f y‖ := by
      refine (norm_add_le _ _).trans ?_
      gcongr; apply norm_add_le
    _ = ‖f (x' - τ) - f x'‖ + ‖f x' - f y'‖ + ‖f (y' - τ) - f y'‖ := by simp only [x', y', add_sub_cancel_right]
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
        gcongr
