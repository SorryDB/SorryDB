lemma IsUnifAlmostPeriodic.uniformContinuous (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  have hl' : 0 < l := hl.pos
  let K := Set.Icc (-1) (l + 1)
  have hK : IsCompact K := isCompact_Icc
  have h_cont : ContinuousOn f K := (by continuity).continuousOn
  rcases Metric.uniformContinuousOn_iff_isCompact.1 (h_cont.uniformContinuousOn_isCompact hK) (ε / 3) hε3 with ⟨δ, hδ, hδ'⟩
  use min δ 1, by simp [hδ]
  rintro x y hxy
  rw [dist_eq_norm] at hxy ⊢
  rw [lt_min_iff] at hxy
  obtain ⟨s, hs, hP⟩ := hl (-x)
  have hP : IsLinftyAP (ε / 3) (-x + s) f := hP
  let T := -x + s
  -- Shift x and y by -T
  have hx : x - T = -s := by simp [T]
  have hy : ‖y - T - (x - T)‖ < δ := by simp [hxy.1]
  have h_in : x - T ∈ K := by
    rw [hx]
    refine ⟨by linarith [hs.2], by linarith [hs.1]⟩
  have h_in' : y - T ∈ K := by
    rw [hx] at hy ⊢
    have : y - T = -s + (y - x) := by abel
    rw [this]
    refine ⟨by linarith [norm_le_abs_self (y - x), hxy.2, hs.2],
            by linarith [norm_le_abs_self (y - x), hxy.2, hs.1]⟩
  calc
    ‖f x - f y‖ = ‖f x - f (x - T) + (f (x - T) - f (y - T)) + (f (y - T) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x - T)‖ + ‖f (x - T) - f (y - T)‖ + ‖f (y - T) - f y‖ := norm_add₃_le ..
    _ = ‖f ((x - T) + T) - f (x - T)‖ + ‖f (x - T) - f (y - T)‖ + ‖f ((y - T) + T) - f (y - T)‖ := by simp
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · exact hP (x - T)
      · exact hδ' h_in h_in' (dist_lt_of_norm_sub_lt hy)
      · exact hP (y - T)
    _ = ε := by ring
