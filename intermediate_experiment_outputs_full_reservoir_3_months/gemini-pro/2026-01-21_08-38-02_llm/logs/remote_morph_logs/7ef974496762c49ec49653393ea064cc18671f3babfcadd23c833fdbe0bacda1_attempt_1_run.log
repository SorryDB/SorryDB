  obtain ⟨l, hl⟩ := hf hε'
  have hcont : Continuous f := sorry
  have h_unif := hcont.uniformContinuousOn_isCompact (isCompact_Icc : IsCompact (Set.Icc (-1) (l + 1)))
  rcases Metric.uniformContinuousOn_iff.mp h_unif ε' hε' with ⟨δ, hδ, hδ_le⟩
  refine ⟨min 1 δ, by positivity, fun x y hxy ↦ ?_⟩
  rw [dist_eq_norm, Real.norm_eq_abs] at hxy ⊢
  have hxy1 : |x - y| < 1 := lt_of_lt_of_le hxy (min_le_left _ _)
  have hxyd : |x - y| < δ := lt_of_lt_of_le hxy (min_le_right _ _)
  obtain ⟨t, ht, hτ⟩ := hl (-x)
