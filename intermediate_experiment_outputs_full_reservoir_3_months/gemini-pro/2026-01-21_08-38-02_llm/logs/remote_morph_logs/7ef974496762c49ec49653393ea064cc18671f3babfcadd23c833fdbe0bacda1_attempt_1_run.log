  have hl_pos : 0 < l := hl.pos
  have h_cont : UniformContinuousOn f (Set.Icc (-1) (l + 1)) :=
    (Continuous.continuousOn (by continuity)).uniformContinuousOn_isCompact isCompact_Icc
  rcases Metric.uniformContinuousOn_iff.mp h_cont ε' hε' with ⟨δ, hδ, hδ_cont⟩
  use min δ 1
  constructor
  · exact lt_min hδ zero_lt_one
  intro x y hxy
  have hxy_le : dist x y < 1 := (lt_min_iff.mp hxy).2
  have hxy_δ : dist x y < δ := (lt_min_iff.mp hxy).1
  obtain ⟨s, hs, hs_per⟩ := hl (-x)
  let τ := -x + s
  have hτ : IsLinftyAP ε' τ f := hs_per
  have hx_s : x + τ = s := by ring
  have hx_in : x + τ ∈ Set.Icc (-1) (l + 1) := by
    rw [hx_s]
