/-- Any uniformly almost periodic function is uniformly continuous. -/
lemma IsUnifAlmostPeriodic.uniformContinuous [Continuous f] (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  let ε' := ε / 3
  have hε' : 0 < ε' := by positivity
  obtain ⟨l, hl⟩ := hf hε'
  have hl_pos : 0 < l := hl.pos
  obtain ⟨δ, hδ, hδ_cont⟩ := Metric.uniformContinuousOn_iff.mp
    (isCompact_Icc : IsCompact (Set.Icc (-1) (l + 1))).uniformContinuousOn_of_continuous
    f.continuous.continuousOn ε' hε'
  refine ⟨min δ 1, by positivity, fun x y hxy ↦ ?_⟩
  rw [dist_eq_norm] at hxy ⊢
  obtain ⟨t, ht, ht_per⟩ := hl (-x)
  have hx : x + t ∈ Set.Icc 0 l := by
    simp only [Set.mem_Ico] at ht
    rw [← add_assoc, neg_add_cancel, zero_add] at ht ⊢
    exact ⟨ht.1.le, ht.2.le⟩
  have hy : y + t ∈ Set.Icc (-1) (l + 1) := by
    rw [Set.mem_Icc] at hx ⊢
    have h_diff : ‖x - y‖ < 1 := lt_of_lt_of_le hxy (min_le_right _ _)
    rw [norm_sub_rev, Real.norm_eq_abs] at h_diff
    constructor
    · rw [le_sub_iff_add_le, neg_add_cancel]
      apply le_trans _ hx.1
      rw [sub_le_iff_le_add]
      exact (le_abs_self _).trans (le_of_lt h_diff)
    · apply le_trans (add_le_add_right hx.2 _)
      rw [add_assoc, le_add_iff_nonneg_right]
      apply le_trans (le_abs_self _) (le_of_lt h_diff)
  calc
    ‖f x - f y‖ = ‖(f x - f (x + t)) + (f (x + t) - f (y + t)) + (f (y + t) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (y + t)‖ + ‖f (y + t) - f y‖ :=
      le_trans (norm_add_le _ _) (add_le_add_left (norm_add_le _ _) _)
    _ ≤ ε' + ε' + ε' := by
      gcongr
      · rw [← norm_neg, neg_sub]
        exact ht_per
      · exact hδ_cont _ (Set.Icc_subset_Icc (by norm_num) (by linarith) hx) _ hy
          (lt_of_lt_of_le hxy (min_le_left _ _))
      · exact ht_per
    _ = ε := by field_simp [ε']; ring
