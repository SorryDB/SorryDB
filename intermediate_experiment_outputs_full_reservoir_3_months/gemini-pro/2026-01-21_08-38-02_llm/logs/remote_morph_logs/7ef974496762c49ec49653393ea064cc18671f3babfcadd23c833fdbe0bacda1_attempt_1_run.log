  have : UniformContinuousOn f (Set.Icc (-1) (l + 1)) :=
    (continuous_iff_continuousOn_univ.1 ‹_›).uniformContinuousOn_isCompact isCompact_Icc
  obtain ⟨δ, hδ, hδ_cont⟩ := Metric.uniformContinuousOn_iff.1 this (ε / 3) hε3
  refine ⟨min δ 1, by positivity, fun x y hxy ↦ ?_⟩
  obtain ⟨t, ht, hτ⟩ := hl (-x)
  let τ := -x + t
  have hx' : x + τ ∈ Set.Icc (-1) (l + 1) := by
    simp [τ]; constructor <;> linarith [ht.1, ht.2]
  have hy' : y + τ ∈ Set.Icc (-1) (l + 1) := by
    simp [τ]; rw [dist_eq_norm, Real.norm_eq_abs, abs_lt] at hxy
    constructor <;> linarith [ht.1, ht.2, (lt_min_iff.1 hxy).2.1, (lt_min_iff.1 hxy).2.2]
  calc dist (f x) (f y)
    _ ≤ dist (f x) (f (x + τ)) + dist (f (x + τ)) (f (y + τ)) + dist (f (y + τ)) (f y) := dist_triangle4_right _ _ _ _
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
      gcongr
      · rw [dist_comm]; exact hτ x
      · exact hδ_cont hx' hy' (by rw [dist_eq_norm]; simpa using (lt_min_iff.1 hxy).1)
      · exact hτ y
    _ = ε := by ring
