lemma IsUnifAlmostPeriodic.uniformContinuous (hc : Continuous f) (hf : IsUnifAlmostPeriodic f) :
    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  have hε3 : 0 < ε / 3 := by positivity
  obtain ⟨l, hl⟩ := hf hε3
  have hl_pos : 0 < l := hl.pos
  let K := Set.Icc (-1) (l + 1)
  have hK : IsCompact K := isCompact_Icc
  have hUC := hK.uniformContinuousOn hc.continuousOn
  rw [Metric.uniformContinuousOn_iff] at hUC
  obtain ⟨δ, hδ_pos, hδ⟩ := hUC (ε / 3) hε3
  use min δ 1, lt_min hδ_pos zero_lt_one
  rintro x y hxy
  have hxy' : dist x y < 1 := (lt_min_iff.mp hxy).2
  have hxy_δ : dist x y < δ := (lt_min_iff.mp hxy).1
  obtain ⟨τ, hτ, hτf⟩ := hl (-x)
  let t := -x + τ
  have hx' : x + t ∈ Set.Ico 0 l := by simp [t]; exact hτ
  have hx'K : x + t ∈ K := by
    rw [Set.mem_Icc]; rw [Set.mem_Ico] at hx'; constructor <;> linarith
  have hy'K : y + t ∈ K := by
    rw [Set.mem_Icc]
    rw [Real.dist_eq] at hxy'
