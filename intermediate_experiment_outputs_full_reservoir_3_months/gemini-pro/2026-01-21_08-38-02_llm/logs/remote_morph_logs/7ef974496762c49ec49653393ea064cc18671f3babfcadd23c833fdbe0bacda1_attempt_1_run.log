    UniformContinuous f := by
  rw [Metric.uniformContinuous_iff]
  intro ε hε
  let ε' := ε / 3
  have hε' : 0 < ε' := by positivity
  obtain ⟨l, hl⟩ := hf hε'
  have hl₀ : 0 < l := hl.pos
  have hc : Continuous f := by assumption
  obtain ⟨δ, hδ, hδ'⟩ := Metric.uniformContinuousOn_iff.mp
    (hc.continuousOn.uniformContinuousOn_of_isCompact isCompact_Icc (s := Set.Icc (-l) (2 * l))) ε' hε'
  use min δ l, lt_min hδ hl₀
  rintro x y hxy
  obtain ⟨τ, hτ, hτ'⟩ := hl (-x)
  let t := -x + τ
  have hx : x + t ∈ Set.Icc (-l) (2 * l) :=
    Set.Icc_subset_Icc (neg_le_zero.mpr hl₀.le) (by linarith) (Set.Ico_subset_Icc_self (Set.mem_Ico.mp hτ))
  have hy : y + t ∈ Set.Icc (-l) (2 * l) := by
    rw [Set.mem_Icc] at hx ⊢; obtain ⟨h₁, h₂⟩ := hx
    constructor
    · calc
        -l < 0 := neg_lt_zero.mpr hl₀
        _ ≤ x + t - |y - x| := sub_le_sub_left (abs_sub_ge_sub_abs ..) _
        _ ≤ x + t - |y + t - (x + t)| := by simp
        _ ≤ y + t := sub_abs_le_self ..
    · calc
        y + t ≤ x + t + |y + t - (x + t)| := le_add_of_sub_right_le (le_abs_self _)
        _ = x + t + |y - x| := by simp
        _ ≤ l + l := add_le_add h₂ (lt_min_iff.mp hxy).2.le
        _ = 2 * l := two_mul l
  rw [dist_eq_norm]
  calc
    ‖f x - f y‖ = ‖f x - f (x + t) + (f (x + t) - f (y + t)) + (f (y + t) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + t)‖ + ‖f (x + t) - f (y + t)‖ + ‖f (y + t) - f y‖ := norm_add₃_le ..
    _ ≤ ε' + ε' + ε' := by
      gcongr
      · rw [← norm_neg, neg_sub]; exact hτ' x
      · exact hδ' hx hy ((lt_min_iff.mp hxy).1.trans_le (min_le_left _ _))
      · exact hτ' y
    _ = ε := by field_simp; ring
