  have hy_shift : y + τ ∈ Set.Icc (-1) (l + 1) := by
    have : ‖(x + τ) - (y + τ)‖ < 1 := by simpa using (lt_min_iff.mp hxy).2
    rw [Set.mem_Icc] at hx_shift ⊢
    constructor <;> linarith [Real.norm_sub_le (x + τ) (y + τ)]
  calc ‖f x - f y‖
    _ = ‖(f x - f (x + τ)) + (f (x + τ) - f (y + τ)) + (f (y + τ) - f y)‖ := by ring_nf
    _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := norm_add₃_le ..
    _ ≤ ε / 3 + ε / 3 + ε / 3 := by
