    _ ≤ ‖f x - f (x + τ)‖ + ‖f (x + τ) - f (y + τ)‖ + ‖f (y + τ) - f y‖ := by
      refine le_trans (norm_add_le _ _) (add_le_add_right (norm_add_le _ _) _)
