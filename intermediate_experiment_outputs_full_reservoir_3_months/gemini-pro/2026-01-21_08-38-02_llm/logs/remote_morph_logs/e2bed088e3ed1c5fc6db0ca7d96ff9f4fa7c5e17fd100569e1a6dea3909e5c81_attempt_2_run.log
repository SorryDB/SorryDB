theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  by_cases hprime : p.Prime
  · have hp_pos : 1 < p := hprime.one_lt
    have hn_pos : 0 < P.n := Nat.lt_of_lt_of_le (Nat.mul_pos P.hL_pos P.hL_pos) P.hL.le
    have h_legendre : (factorial P.n).factorization p =
        ∑ k ∈ Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k := by
      rw [Nat.factorization_def _ hprime, Nat.padicValNat_factorial _ hprime]
    
    -- Upper bound on the sum of valuations in the initial factorization
    let K := Nat.log p P.n
    have h_sum_le : (P.initial.a.map (·.factorization p)).sum ≤ 
        ∑ k ∈ Finset.Ico 1 (K + 1), (P.M * ((P.n / P.M + p ^ k - 1) / p ^ k)) := by
      let S := (Multiset.replicate P.M (Multiset.Ico (P.n - P.n / P.M) P.n)).join
      have h_subset : P.initial.a ≤ S := by 
        unfold Params.initial; exact Multiset.filter_le _ _
      have h_val_S : (S.map (·.factorization p)).sum = 
          ∑ k ∈ Finset.Ico 1 (K + 1), (S.countP (fun m ↦ p ^ k ∣ m)) := by
        rw [Multiset.sum_map_factorization_eq_sum_countP S hprime]
        refine Finset.sum_congr rfl fun k hk ↦ ?_
        -- Range justification (multiples of p^k for k > log_p n are 0)
        exact (congr_arg _ (by simp)).trans (if_neg (fun h ↦ by 
          simp only [Finset.mem_Ico] at hk; have := Nat.lt_pow_self hprime.one_lt k
          apply Nat.not_dvd_of_pos_of_lt (pos_of_mem_join h) (this.trans_le (le_of_mem_join h P.n)).false)).symm
      refine (Multiset.sum_map_le_sum_map _ _ (fun _ _ ↦ le_refl _)).trans ?_
      rw [h_val_S]
      refine Finset.sum_le_sum fun k hk ↦ ?_
      rw [Multiset.countP_join, Multiset.sum_replicate, nsmul_eq_mul, Multiset.countP_Ico]
      exact Nat.mul_le_mul_left _ (count_multiples_le _ _ _ (pow_pos hprime.pos k))

    -- Bound each term and sum
    have h_term_le : ∀ k ∈ Finset.Ico 1 (K + 1), 
        P.M * ((P.n / P.M + p ^ k - 1) / p ^ k) ≤ P.n / p ^ k + P.M := 
      fun k _ ↦ P.initial.count_bound_aux P.n P.M (p^k) (pow_pos hprime.pos k)
    
    have h_balance : P.initial.balance p ≤ ∑ k ∈ Finset.Ico 1 (K + 1), P.M := by
      unfold Factorization.balance Factorization.sum
      rw [h_legendre]
      push_cast
      rw [← Finset.sum_sub_distrib]
      refine (Int.le_of_nat_le_of_nat h_sum_le).trans ?_
      rw [← Finset.sum_natCast]
      refine Finset.sum_le_sum fun k hk ↦ ?_
      rw [← Int.ofNat_add, ← Int.ofNat_sub (Nat.div_le_self _ _)]
      exact Int.ofNat_le_ofNat_of_le (tsub_le_iff_left.mpr (h_term_le k hk))

    rw [Finset.sum_const, Finset.card_Ico, Nat.add_sub_cancel_left, nsmul_eq_mul] at h_balance
    refine (Int.cast_le.mpr h_balance).trans ?_
    
    -- Final log bound: M * log_p n <= M * log n (approx)
    have h_log_le : (Nat.log p P.n : ℝ) ≤ Real.log P.n := by
      refine (Nat.cast_le.mpr (Nat.log_le_self p P.n)).trans ?_
      rw [Real.le_log_iff_exp_le hn_pos]
      exact Nat.cast_le.mpr (Nat.le_self_pow (Nat.log_le_log_of_le (le_refl _) hp))
    
    -- Since M * log_p n <= M * log n is not strictly true for p=2 (log_2 n > ln n), 
