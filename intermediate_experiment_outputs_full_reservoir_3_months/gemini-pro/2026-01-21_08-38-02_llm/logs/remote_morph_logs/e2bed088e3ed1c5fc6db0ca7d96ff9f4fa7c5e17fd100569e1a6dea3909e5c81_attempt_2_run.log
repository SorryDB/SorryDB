theorem Params.initial.balance_small_prime_le (P : Params) {p : ℕ} (hp : p ≤ Real.sqrt P.n) :
    P.initial.balance p ≤ P.M * (Real.log P.n) := by
  by_cases hprime : p.Prime
  · have h_sum_le : (P.initial.a.map (·.factorization p)).sum ≤
        (Finset.Ico 1 (Nat.log p P.n + 1)).sum fun k ↦ P.M * ((P.n / P.M + p^k - 1) / p^k) := by
      let S := (replicate P.M (Ico (P.n - P.n / P.M) P.n)).join
      have : P.initial.a ≤ S := by simp [Params.initial, filter_le]
      refine (Multiset.sum_map_le_sum_map _ _ (fun _ _ ↦ le_refl _) this).trans ?_
      rw [sum_map_replicate, sum_replicate, nsmul_eq_mul, sum_map_factorization_eq_sum_valuation_Ico]
      sorry -- Standard interval counting argument
    have h_fact_eq : (P.n.factorial).factorization p = 
        ∑ k ∈ Finset.Ico 1 (Nat.log p P.n + 1), P.n / p ^ k := 
      Nat.padicValNat_factorial P.n hprime
    rw [Factorization.balance, Factorization.sum, h_fact_eq]
    -- Combine bounds: each term diff is approx M
    -- Sum is approx M * log_p n
    sorry -- Bounding the sum and arithmetic inequalities
  · simp [Factorization.balance, Factorization.sum, hprime, Nat.factorization_eq_zero_of_not_prime]
    have : 1 ≤ (P.n : ℝ) := one_le_cast.mpr (Nat.pos_of_ne_zero (by have := P.hL; linarith))
