@[expose] public section

namespace MeasureTheory.ComplexMeasure

open MeasureTheory

variable {α : Type*} [MeasurableSpace α]
variable {G : Type*} [NormedAddCommGroup G] [NormedSpace ℂ G]

/-! ## Polar decomposition of complex measures. -/

/-- The variation measure part in the polar decomposition of a complex measure. -/
noncomputable def var (μ : ComplexMeasure α) := μ.variation.ennrealToMeasure

@[simp]
lemma var_neg (μ : ComplexMeasure α) : (-μ).var = μ.var := by
  simp [var, MeasureTheory.VectorMeasure.variation_neg]

/-- The angular part (density function) in the polar decomposition of a complex measure. -/
noncomputable def ang (μ : ComplexMeasure α) := μ.rnDeriv μ.var

@[simp]
lemma ang_neg (μ : ComplexMeasure α) : (-μ).ang = -μ.ang := by
  -- To do: adjust this statement to the `μ`-a.e. version.
  sorry

/-! ## Definition of the integral. -/

/-- The integral with respect to a complex measure defined using the polar decomposition of the
complex measure and the integral with respect to the total variation.-/
noncomputable def integral (μ : ComplexMeasure α) (f : α → G) :=
  ∫ x,  μ.ang x • f x ∂(μ.var)

notation3 "∫ "(...)", "r:60:(scoped f => f)" ∂"μ:70 => integral μ r

/-! ## Some lemmas related to the integral. -/

/-- For complex measures `μ`, `ν` and integrable function `f`: `∫ f d(μ + ν) = ∫ f dμ + ∫ f dν` -/
lemma integral_add (μ ν : ComplexMeasure α) (f : α → ℂ) (hf : Integrable f (μ.var + ν.var)) :
    ∫ a, f a ∂(μ + ν) = ∫ a, f a ∂μ + ∫ a, f a ∂ν := by
  let ρ := μ.var + ν.var
  have hμ : μ.var ≪ ρ := Measure.AbsolutelyContinuous.self_add_right _ _
  have hν : ν.var ≪ ρ := Measure.AbsolutelyContinuous.self_add_left _ _
  have hμν : (μ + ν).var ≪ ρ := (VectorMeasure.variation_add_le _ _).trans_ac (Measure.AbsolutelyContinuous.add_le_add hμ hν)
  have key (η : ComplexMeasure α) (hη : η.var ≪ ρ) : integral η f = ∫ a, η.rnDeriv ρ a • f a ∂ρ := by
    rw [integral, ← Measure.integral_withDensity_eq_integral_smul (Measure.rnDeriv_ne_top _ _), Measure.withDensity_rnDeriv_eq _ _ hη]
    simp only [VectorMeasure.rnDeriv, Function.comp_apply, Pi.smul_apply, Complex.smul_def, mul_assoc]
  rw [key μ hμ, key ν hν, key (μ + ν) hμν, ← MeasureTheory.integral_add]
  · apply integral_congr_ae
    filter_upwards [VectorMeasure.rnDeriv_add μ ν ρ] with x hx
    simp [hx, add_mul]
  · rw [← Measure.integrable_withDensity_iff (Measure.rnDeriv_ne_top _ _), Measure.withDensity_rnDeriv_eq _ _ hμ]
    exact hf.mono_measure (Measure.le_add_right le_rfl)
  · rw [← Measure.integrable_withDensity_iff (Measure.rnDeriv_ne_top _ _), Measure.withDensity_rnDeriv_eq _ _ hν]
    exact hf.mono_measure (Measure.le_add_left le_rfl)

end MeasureTheory.ComplexMeasure

end
