/-- For complex measures `μ`, `ν` and integrable function `f`: `∫ f d(μ + ν) = ∫ f dμ + ∫ f dν` -/
lemma integral_add (μ ν : ComplexMeasure α) {f : α → ℂ}
    (hfμ : Integrable f μ.var) (hfν : Integrable f ν.var) :
    ∫ a, f a ∂(μ + ν) = ∫ a, f a ∂μ + ∫ a, f a ∂ν := by
  dsimp [integral]
  let ρ := μ.var + ν.var
  have hμ : μ.var ≪ ρ := Measure.AbsolutelyContinuous.self_add_right _ _
  have hν : ν.var ≪ ρ := Measure.AbsolutelyContinuous.self_add_left _ _
  have hμν : (μ + ν).var ≪ ρ := (VectorMeasure.variation_add_le _ _).trans_ac
    (Measure.AbsolutelyContinuous.add_of_absolutelyContinuous_left hμ hν)
  -- Transform integrals to be w.r.t the common dominating measure ρ
  let key (η : ComplexMeasure α) (hη : η.var ≪ ρ) :
      ∫ a, η.ang a • f a ∂η.var = ∫ a, (η.rnDeriv ρ a) • f a ∂ρ := by
    rw [← Measure.withDensity_rnDeriv_eq _ _ hη, Measure.integral_withDensity_eq_integral_smul]
    · apply Measure.integral_congr_ae
      filter_upwards [VectorMeasure.rnDeriv_eq_smul_rnDeriv η hη] with x hx
      simp only [ang, hx, smul_assoc]
    · exact Measure.measurable_rnDeriv _ _
