@[expose] public section

namespace MeasureTheory.ComplexMeasure

open MeasureTheory

variable {α : Type*} [MeasurableSpace α]
variable {G : Type*} [NormedAddCommGroup G] [NormedSpace ℂ G]

/-! ## Polar decomposition of complex measures. -/

/-- The variation measure part in the polar decomposition of a complex measure. -/
noncomputable def var (μ : ComplexMeasure α) := μ.variation.ennrealToMeasure

@[simp]
lemma var_neg (μ : ComplexMeasure α) : (-μ).var = μ.var := by
  simp [var, MeasureTheory.VectorMeasure.variation_neg]

/-- The angular part (density function) in the polar decomposition of a complex measure. -/
noncomputable def ang (μ : ComplexMeasure α) := μ.rnDeriv μ.var

@[simp]
lemma ang_neg (μ : ComplexMeasure α) : (-μ).ang = -μ.ang := by
  -- To do: adjust this statement to the `μ`-a.e. version.
  sorry

/-! ## Definition of the integral. -/

/-- The integral with respect to a complex measure defined using the polar decomposition of the
complex measure and the integral with respect to the total variation.-/
noncomputable def integral (μ : ComplexMeasure α) (f : α → G) :=
  ∫ x,  μ.ang x • f x ∂(μ.var)

notation3 "∫ "(...)", "r:60:(scoped f => f)" ∂"μ:70 => integral μ r

/-! ## Some lemmas related to the integral. -/

/-- For complex measures `μ`, `ν` and integrable function `f`: `∫ f d(μ + ν) = ∫ f dμ + ∫ f dν` -/
lemma integral_add (μ ν : ComplexMeasure α) {f : α → ℂ} (hf : Integrable f (μ.var + ν.var)) :
    ∫ a, f a ∂(μ + ν) = ∫ a, f a ∂μ + ∫ a, f a ∂ν := by
  dsimp [integral]
  let ρ := μ.var + ν.var
  have h_le_ρ (ξ : ComplexMeasure α) (h : ξ.var ≤ ρ) : ξ.var ≪ ρ :=
    Measure.AbsolutelyContinuous.of_le h
  have hμ : μ.var ≪ ρ := h_le_ρ μ (Measure.le_add_right le_rfl)
  have hν : ν.var ≪ ρ := h_le_ρ ν (Measure.le_add_left le_rfl)
  have hadd : (μ + ν).var ≪ ρ := h_le_ρ (μ + ν) <| (fun s _ ↦ VectorMeasure.variation_add_le μ ν s).trans (Measure.add_le_add le_rfl le_rfl)
  
  -- We express integral w.r.t ξ.var as integral w.r.t ρ
  have key (ξ : ComplexMeasure α) (hξ : ξ.var ≪ ρ) (hf_ξ : Integrable f ξ.var) :
      ∫ a, ξ.ang a • f a ∂ξ.var = ∫ a, (ξ.rnDeriv ρ a) • f a ∂ρ := by
    rw [← Measure.withDensity_rnDeriv_eq ξ.var ρ hξ, integral_withDensity_eq_integral_smul]
    · apply integral_congr_ae
      filter_upwards [VectorMeasure.rnDeriv_eq_smul_rnDeriv ξ hξ] with x hx
      rw [hx, smul_comm, smul_smul]; rfl
    · exact Measure.measurable_rnDeriv _ _
  
  -- Integrability of the transformed integrand
  have h_int (ξ : ComplexMeasure α) (hξ : ξ.var ≪ ρ) (hf_ξ : Integrable f ξ.var) :
      Integrable (fun a ↦ (ξ.rnDeriv ρ a) • f a) ρ := by
    apply Integrable.of_norm_ennreal_le (hf_ξ.1.smul (Measure.measurable_rnDeriv _ _))
    rw [← Measure.withDensity_rnDeriv_eq ξ.var ρ hξ, Measure.withDensity_apply _ hf_ξ.1.ennnorm]
    apply lintegral_mono_ae
    filter_upwards [VectorMeasure.norm_rnDeriv_le ξ ρ] with x hx
    exact mul_le_mul_right' hx _

  -- Main proof
  rw [key μ hμ (hf.mono_measure (Measure.le_add_right le_rfl)),
      key ν hν (hf.mono_measure (Measure.le_add_left le_rfl)),
      key (μ + ν) hadd (hf.mono_measure (Measure.AbsolutelyContinuous.of_le hadd).le),
      ← integral_add]
  · apply integral_congr_ae
    filter_upwards [VectorMeasure.rnDeriv_add μ ν ρ] with x hx
    simp [hx, add_smul]
  · exact h_int μ hμ (hf.mono_measure (Measure.le_add_right le_rfl))
  · exact h_int ν hν (hf.mono_measure (Measure.le_add_left le_rfl))
