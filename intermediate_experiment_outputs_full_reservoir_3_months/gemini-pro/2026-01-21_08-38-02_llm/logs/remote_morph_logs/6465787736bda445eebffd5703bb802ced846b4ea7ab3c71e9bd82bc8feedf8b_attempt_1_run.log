  have hρμ : μ.var ≪ ρ := Measure.absolutelyContinuous_of_le (le_add_right le_self_add)
  have hρν : ν.var ≪ ρ := Measure.absolutelyContinuous_of_le (le_add_left (le_add_right le_self_add))
  have hρadd : (μ + ν).var ≪ ρ := Measure.absolutelyContinuous_of_le (le_add_left (le_add_left le_self_add))
  rw [VectorMeasure.integral_eq_integral_rnDeriv hρadd,
      VectorMeasure.integral_eq_integral_rnDeriv hρμ,
      VectorMeasure.integral_eq_integral_rnDeriv hρν,
      ← integral_add]
  · congr 1; ext x
    simp only [VectorMeasure.rnDeriv_add μ ν ρ, Pi.add_apply, add_smul]
  · exact (VectorMeasure.integrable_rnDeriv_smul_iff hρμ).1 hfμ
  · exact (VectorMeasure.integrable_rnDeriv_smul_iff hρν).1 hfν
```
