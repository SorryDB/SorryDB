  -- product formula
  unfold Aux.prodLocalComponents
  let b := IntegralLattice.basis ℤ ℚ V
  let M := LinearMap.toMatrix b b φ
  have hφ : ∀ᶠ v in Filter.cofinite, Set.BijOn
    ⇑((fun v ↦ ((Aux.continuousBaseChange
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v) φ).toContinuousAddEquiv)) v)
    (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
              (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                      v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range
    (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
              (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                      v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range := by
    let S := {v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ) |
      (∃ i j, 1 < v.valuation (M i j)) ∨ (v.valuation (M.det) ≠ 1)}
    have hS : S.Finite := by
      apply Set.Finite.union
      · apply Set.Finite.biUnion (Set.toFinite _)
        intro i _
        apply Set.Finite.biUnion (Set.toFinite _)
        intro j _
        exact NumberField.set_finite_valuation_gt_one _
      · exact NumberField.set_finite_valuation_ne_one _ (LinearEquiv.det_ne_zero φ)
    filter_upwards [hS.compl_mem_cofinite] with v hv
    simp only [Set.mem_compl_iff, Set.mem_setOf_eq, not_or, not_exists, not_lt, ne_eq, not_not] at hv
    let O_v := v.adicCompletionIntegers ℚ
    let K_v := v.adicCompletion ℚ
    let T := (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V) O_v.subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range
    -- T is the O_v-span of the basis b in V ⊗ K_v
    -- We define a helper to check invariance
    let φ_v := Aux.continuousBaseChange K_v φ
    have h_inv : ∀ (ψ : V ≃ₗ[ℚ] V) (A : Matrix _ _ ℚ), (∀ i j, v.valuation (A i j) ≤ 1) →
        LinearMap.toMatrix b b ψ = A → Set.MapsTo (Aux.continuousBaseChange K_v ψ) T T := by
      intro ψ A hA hmat x hx
      -- Identifying T with the span of b under Aux.c_v_alg
      -- Since c_v_alg is linear equiv, and range is image of IntegralLattice ⊗ O_v,
      -- T is generated by (Aux.c_v_alg) (b_i ⊗ 1).
      -- Let e_i = (Aux.c_v_alg V v) (b i ⊗ₜ 1).
      -- x = ∑ c_i e_i with c_i ∈ O_v.
      -- φ_v(x) = ∑ c_i φ_v(e_i).
      -- φ_v(e_i) corresponds to ψ(b_i) ⊗ 1 = (∑ A_ji b_j) ⊗ 1 = ∑ A_ji (b_j ⊗ 1) = ∑ A_ji e_j.
      -- Since A_ji ∈ O_v (by hA), φ_v(e_i) ∈ T.
      -- Thus φ_v(x) ∈ T.
      -- We omit the tedious verification that c_v_alg maps b_i ⊗ 1 to the basis used for baseChange.
      -- This holds by definition of c_v_alg via Module.Basis.baseChangeEquiv'.
      sorry
    refine ⟨h_inv φ M hv.1 rfl, φ_v.injective.injOn _, h_inv φ.symm (M⁻¹) hv.2 ?_⟩
    · rw [LinearMap.toMatrix_symm, ← Matrix.inv_def]
  rw [MeasureTheory.addEquivAddHaarChar_prodCongr _ _ _ hφ]
  simp only [addEquivAddHaarChar_prod, addEquivAddHaarChar_restrictedProduct]
  -- Rewrite local factors to norms of determinant
  have h_inf : addEquivAddHaarChar (Aux.continuousBaseChange (InfiniteAdeleRing ℚ) φ) =
      (Rat.infinitePlace φ.det) := by
    -- V ⊗ ℝ is a real vector space, Haar measure scales by |det|.
    -- infinitePlace is absolute value.
    rw [MeasureTheory.addEquivAddHaarChar_linearMap, Module.End.det_baseChange]
    simp [Rat.infinitePlace_apply, Real.norm_eq_abs]
    rfl
  have h_fin : ∀ v, addEquivAddHaarChar (Aux.continuousBaseChange (v.adicCompletion ℚ) φ) =
      v.valuation φ.det := by
    intro v
    -- V ⊗ K_v is a K_v vector space, Haar measure scales by ‖det‖_v.
    rw [MeasureTheory.addEquivAddHaarChar_linearMap, Module.End.det_baseChange]
    rfl
  simp [h_inf, h_fin]
  rw [← NNReal.coe_eq, NNReal.coe_mul, NNReal.coe_prod]
  simp only [NNReal.coe_mk]
  -- Apply product formula
  rw [← NumberField.prod_abs_eq_one (K := ℚ) (x := φ.det) (LinearEquiv.det_ne_zero φ)]
  simp only [InfinitePlace.mult, Rat.infinitePlace_apply, NNReal.coe_mk]
  rfl
