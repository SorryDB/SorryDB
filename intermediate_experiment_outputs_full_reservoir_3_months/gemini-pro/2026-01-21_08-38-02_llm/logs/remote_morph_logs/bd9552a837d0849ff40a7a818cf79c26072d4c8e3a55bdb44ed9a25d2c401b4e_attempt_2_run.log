lemma MeasureTheory.addHaarScalarFactor_prodLocalComponents_eq_one (φ : V ≃ₗ[ℚ] V) :
    addEquivAddHaarChar (Aux.prodLocalComponents V φ) = 1 := by
  -- product formula
  unfold Aux.prodLocalComponents
  rw [MeasureTheory.addEquivAddHaarChar_prodCongr]
  have hφ : ∀ᶠ v in Filter.cofinite, Set.BijOn
    ⇑((fun v ↦ ((Aux.continuousBaseChange
      (IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v) φ).toContinuousAddEquiv)) v)
    (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
              (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                      v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range
    (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
              (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
                      v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range := by
    let b := IntegralLattice.basis ℤ ℚ V
    let M := LinearMap.toMatrix b b φ
    let M_inv := LinearMap.toMatrix b b φ.symm
    let S_entries := (Set.range M) ∪ (Set.range M_inv)
    -- The set of places where any matrix entry is not integral is finite
    have h_fin : {v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ) | ∃ q ∈ S_entries, q ∉ v.adicCompletionIntegers ℚ}.Finite := by
      refine (Set.finite_range _).union (Set.finite_range _) |>.biUnion (fun q hq ↦ ?_)
      -- q ∉ O_v ↔ |q|_v > 1. This set is finite by the product formula (or properties of denominators).
      rcases eq_or_ne q 0 with rfl | hq0
      · simp only [RingOfIntegers.zero_mem, not_true_eq_false, Set.setOf_false, Set.finite_empty]
      · have : {v : FinitePlace ℚ | v.norm q > 1}.Finite :=
          (NumberField.ProductFormula.finite_places_ne_one q hq0).subset (fun _ h ↦ ne_of_gt h)
        -- Transfer to HeightOneSpectrum (omitted for brevity, essentially pre-image under equiv)
        sorry
    filter_upwards [Filter.mem_cofinite.mpr h_fin] with v hv
    simp only [Set.mem_setOf_eq, exists_prop, not_exists, not_and, Decidable.not_not] at hv
    -- Identify the range as the span of the basis
    let f := (Aux.continuousBaseChange (v.adicCompletion ℚ) φ).toContinuousAddEquiv
    let range_v := (((Aux.c_v_alg V v)).toAddMonoidHom.comp
          (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
              (v.adicCompletionIntegers ℚ).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range
    -- The range is generated by the basis b over O_v
    apply Set.BijOn.mk
    · -- Maps into: f(span(b)) ⊆ span(b) since M has integral entries
      rintro _ ⟨x, rfl⟩
      -- The map f acts on the basis via M. Since entries of M are in O_v, the image is in the O_v-span.
      sorry
    · exact f.injective.injOn _
    · -- Surjective: use M_inv
      intro y hy
      refine ⟨f.symm y, ?_, f.apply_symm_apply y⟩
      -- f.symm acts by M_inv. Since entries of M_inv are in O_v, f.symm y is in the O_v-span.
      sorry
  -- Now applying the product formula
  -- The restricted product haar char is the product of local haar chars
  -- Local haar char is |det φ|_v
  -- The product of |det φ|_v over all v is 1
  sorry
