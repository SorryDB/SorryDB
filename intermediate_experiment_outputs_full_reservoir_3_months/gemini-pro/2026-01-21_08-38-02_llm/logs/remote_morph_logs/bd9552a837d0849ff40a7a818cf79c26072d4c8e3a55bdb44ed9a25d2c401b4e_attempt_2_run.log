    have hM : ∀ᶠ v in Filter.cofinite, ∀ i j, v.valuation (M i j) ≤ 1 :=
      Filter.eventually_all.2 fun i ↦ Filter.eventually_all.2 fun j ↦ h_fin _
    have hMinv : ∀ᶠ v in Filter.cofinite, ∀ i j, v.valuation (Minv i j) ≤ 1 :=
      Filter.eventually_all.2 fun i ↦ Filter.eventually_all.2 fun j ↦ h_fin _
    filter_upwards [hM, hMinv] with v hM hMinv
    let O := (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ v)
