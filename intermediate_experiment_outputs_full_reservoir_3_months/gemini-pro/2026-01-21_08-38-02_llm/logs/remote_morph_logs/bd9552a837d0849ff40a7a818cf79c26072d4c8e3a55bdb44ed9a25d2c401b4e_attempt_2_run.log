    classical
    let b := Module.Basis.ofVectorSpace ℚ V
    let M := LinearMap.toMatrix b b φ
    let Minv := LinearMap.toMatrix b b φ.symm
    have h_fin : ∀ x : ℚ, ∀ᶠ v in Filter.cofinite, v.valuation x ≤ 1 := fun x => by
      by_cases hx : x = 0
      · simp [hx]; filter_upwards; intro; exact zero_le_one
