def PreStateP.last {pos} {bt : BuildTree pos} {m : Match bt} : PreStateP bt m → Sequent
| .stopLeaf _ => match m.btAt with | ⟨⟨_, X, _⟩, _⟩ => X
| .stopAtM _ _ => match m.btAt with | ⟨⟨_, X, _⟩, _⟩ => X
| .edge _ _ tail => tail.last

def PreState.last {pos} {bt : BuildTree pos} : PreState bt → Sequent
| .fromRoot p => p.last
| .fromMod _ _ p => p.last

def PreState.forms {pos} {bt : BuildTree pos} (π : PreState bt) : List Formula :=
  match π.last with | ⟨L, R, _⟩ => L ++ R

/-- Collect formulas in a pre-state. The loaded part of Λ(π) in paper. -/
def PreState.lforms {pos} {bt : BuildTree pos} (π : PreState bt) : List NegLoadFormula :=
  match π.last with
  | ⟨_, _, some (Sum.inl f)⟩ => [f]
  | ⟨_, _, some (Sum.inr f)⟩ => [f]
  | _ => []

/-- TODO Lemma 6.14 -/
lemma PreState.formsCases {π : PreState bt} : φ ∈ π.forms →
      (φ.basic ∧ φ ∈ π.last) -- NOTE: the `∈` is not dealing with loaded formulas here!
    ∨ (¬φ.basic ∧ φ ∈ π.last) := by -- TODO how to say `φ is principal later?`
    -- Or can we say something else / phrase it as closure condition about π.forms directly?
  intro h
  unfold forms at h
  rcases h_last : π.last with ⟨L, R, O⟩
  rw [h_last] at h
  simp only [List.mem_append] at h
  have in_last : φ ∈ π.last := by
    rw [h_last]
    -- Assuming standard Sequent membership: φ ∈ L ∨ φ ∈ R
    cases h <;> (try simp [Sequent.mem_def]; done) <;> (try apply Or.inl; assumption) <;> (try apply Or.inr; assumption)
  by_cases hb : φ.basic
  · left; exact ⟨hb, in_last⟩
  · right; exact ⟨hb, in_last⟩
```
