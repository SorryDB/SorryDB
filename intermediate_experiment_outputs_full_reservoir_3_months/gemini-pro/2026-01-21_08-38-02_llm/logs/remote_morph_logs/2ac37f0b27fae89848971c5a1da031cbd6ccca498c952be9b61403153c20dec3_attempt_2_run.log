@[blueprint
  "initial-factorization-medium-prime-ge"
  (statement := /-- A medium prime $\sqrt{n} < p ≤ n/L$ can be in deficit by at most $M$.-/)
  (proof := /-- Routine computation using Legendre's formula.-/)]
theorem Params.initial.balance_medium_prime_ge (P : Params) {p : ℕ} (hp : p ≤ P.n / P.L) (hp' : p > Real.sqrt P.n) : P.initial.balance p ≥ -P.M := by
  by_cases hprime : p.Prime
  · have h_n_fact : (P.n.factorial).factorization p = P.n / p :=
      Params.initial.factorial_factorization_eq_div hprime hp'
    have h_smooth_mul : ∀ m ∈ Finset.Ico (P.n - P.n / P.M) P.n, p ∣ m → m ∈ (P.n / P.L).smoothNumbers := by
      intro m hm hpm
      rw [mem_smoothNumbers]
      simp only [Finset.mem_Ico] at hm
      refine ⟨pos_of_gt hm.2, fun q hq hqm ↦ ?_⟩
      by_contra hq_large
      simp only [not_le] at hq_large
      have h_prod : p * q ∣ m := hprime.mul_dvd_of_dvd_of_dvd hpm hqm (ne_of_lt (hp.trans_lt hq_large))
      have h_bound : (p * q : ℝ) > P.n := by
        calc (p * q : ℝ) > Real.sqrt P.n * (P.n / P.L) := by
               gcongr
               exact_mod_cast hq_large
             _ = P.n * (Real.sqrt P.n / P.L) := by ring
             _ > P.n * 1 := by
               gcongr
               rw [one_lt_div (by exact_mod_cast P.hL_pos), Real.lt_sqrt (by exact_mod_cast (Nat.zero_le P.n))]
               exact_mod_cast P.hL
             _ = P.n := mul_one _
      norm_cast at h_bound
      linarith [le_of_dvd (pos_of_gt hm.2) h_prod]
    let I := Finset.Ico (P.n - P.n / P.M) P.n
    let count := (I.filter (fun m ↦ p ∣ m)).card
    have h_sum : (P.initial.a.map (·.factorization p)).sum = P.M * count := by
      unfold Params.initial
      rw [map_filter, sum_filter, sum_join, map_replicate, sum_replicate, nsmul_eq_mul]
      congr 1
      rw [sum_eq_multiset_sum, Multiset.Ico, Finset.val_Ico]
      apply Finset.sum_congr rfl
      intro m hm
      simp only [Finset.mem_filter] at hm
      by_cases hpm : p ∣ m
      · simp only [hpm, h_smooth_mul m hm hpm, ↓reduceIte]
        rw [Nat.prime_iff.mp hprime |>.factorization_self (pos_of_gt (Finset.mem_Ico.mp hm).2).ne']
        have : m < p ^ 2 := by
           calc m < P.n := (Finset.mem_Ico.mp hm).2
           _ < p ^ 2 := by exact_mod_cast (Real.lt_sqrt (Nat.cast_nonneg _)).mp hp'
        rw [factorization_eq_zero_of_lt this]; rfl
      · rw [Nat.factorization_eq_zero_of_non_dvd m hpm]
        simp only [hpm, ↓reduceIte]
    let mults := (List.range (P.n / (P.M * p))).map (fun k ↦ ((P.n - P.n / P.M - 1) / p + 1 + k) * p)
    have h_count_ge : count ≥ P.n / (P.M * p) := by
      have h_subset : mults.toFinset ⊆ I.filter (fun m ↦ p ∣ m) := by
        intro m hm
        simp only [mults, List.mem_toFinset, List.mem_map, List.mem_range] at hm
        obtain ⟨k, hk, rfl⟩ := hm
        simp only [Finset.mem_filter, Finset.mem_Ico, dvd_mul_right, and_true]
        constructor
        · calc ((P.n - P.n / P.M - 1) / p + 1 + k) * p
               ≥ ((P.n - P.n / P.M - 1) / p + 1) * p := by gcongr; omega
             _ > (P.n - P.n / P.M - 1) := by
               exact lt_of_le_of_lt (Nat.div_mul_le_self _ _) (lt_add_one _) |>.trans_le (le_mul_of_one_le_right' (pos_of_gt hp').le)
             _ = P.n - P.n / P.M - 1 := rfl
        · calc ((P.n - P.n / P.M - 1) / p + 1 + k) * p
               ≤ ((P.n - P.n / P.M - 1) / p + 1 + (P.n / (P.M * p) - 1)) * p := by
                 gcongr; exact le_tsub_of_add_le_left (succ_le_of_lt hk)
             _ = ((P.n - P.n / P.M - 1) / p * p) + (P.n / (P.M * p) * p) := by ring -- approximately
             _ ≤ (P.n - P.n / P.M - 1) + P.n / P.M := by
               gcongr
               · exact Nat.div_mul_le_self _ _
               · rw [mul_comm, ← Nat.div_div_eq_div_mul]; exact Nat.div_mul_le_self _ _
             _ < P.n := by
               rw [tsub_add_eq_add_tsub (le_tsub_of_add_le_left (le_of_lt P.hL))]
               omega
      calc count ≥ mults.toFinset.card := Finset.card_le_card h_subset
        _ = mults.length := by
          rw [List.toFinset_card, mults, List.length_map, List.length_range]
          refine (List.nodup_map ?_ (List.nodup_range _)).length_eq_card_toFinset
          intro x y h; dsimp at h; linarith
        _ = P.n / (P.M * p) := by simp [mults]
    simp only [Factorization.balance, Factorization.sum, h_n_fact, h_sum]
    rw [ge_iff_le, neg_le_sub_iff_le_add, ← le_div_iff₀ (by exact_mod_cast P.M.pos_of_ne_zero (by have := P.hL; omega) : (P.M : ℝ) > 0)]
    calc (P.n : ℝ) / p / P.M ≤ (P.n / (P.M * p) : ℕ) + 1 := by
         rw [div_div, mul_comm]; exact_mod_cast Nat.div_lt_self_add_one
       _ ≤ (count : ℝ) + 1 := by gcongr
       _ = (P.M * count + P.M) / P.M := by field_simp
  · simp [Factorization.balance, Factorization.sum]
    rw [Nat.factorization_eq_zero_of_not_prime _ hprime]
    linarith
