      factorial_factorization_eq_div hprime hp'
    have h_smooth : ∀ m ∈ Multiset.Ico (P.n - P.n / P.M) P.n, p ∣ m → m ∈ (P.n / P.L).smoothNumbers := fun m hm hdvd ↦ by
      rw [mem_smoothNumbers]
      intro q hq hqm
      rcases eq_or_ne q p with rfl | hqp
      · exact hp
      · have : m < P.n := (Multiset.mem_Ico.mp hm).2
        have : (p : ℝ) ^ 2 > P.n := Real.pow_gt_of_sqrt_gt hp'
        have : m < p * p := by exact_mod_cast (this.trans_le (le_of_lt this))
        have hp_sq : p * p > P.n := by norm_cast at this; exact this
        have : m / p < p := Nat.div_lt_of_lt_mul (this.trans hp_sq)
        apply le_of_lt
        calc q ≤ m / p := Nat.le_of_dvd (Nat.div_pos (Nat.le_of_dvd (Multiset.mem_Ico.mp hm).2.pos hdvd) (Nat.pos_of_gt (Real.sqrt_pos.mp (lt_trans (Real.sqrt_nonneg _) hp')))) (hq.dvd_of_dvd_mul_right hqm hqp)
           _ < p := this
           _ ≤ P.n / P.L := hp
    let I := Multiset.Ico (P.n - P.n / P.M) P.n
    let K := (I.filter (p ∣ ·)).card
    have hsum : (P.initial.a.map (·.factorization p)).sum = P.M * K := by
      simp only [Params.initial, Multiset.map_filter, Multiset.sum_filter,
        Multiset.map_join, Multiset.sum_join, Multiset.map_replicate, Multiset.sum_replicate,
        nsmul_eq_mul]
      rw [Multiset.sum_map_zero]
      · simp
      · intro x hx
        split_ifs with h
        · rw [hprime.factorization_self, Nat.cast_one]
          · rw [Nat.factorization_eq_zero_of_lt]
            · exact one_ne_zero
            · calc x / p < P.n / p := Nat.div_lt_div_of_lt_left (Multiset.mem_Ico.mp hx).2 hprime.pos
                _ < p := by
                  rw [gt_iff_lt, Real.sqrt_lt (Nat.cast_nonneg _) (Nat.cast_nonneg _)] at hp'
                  norm_cast at hp'
                  exact Nat.div_lt_of_lt_mul hp'
          · refine Nat.dvd_trans ?_ h
            by_contra c
            simp [Nat.div_eq_of_lt (not_le.mp c)] at h
            have := (Multiset.mem_Ico.mp hx).2
            linarith
        · simp [Nat.factorization_eq_zero_of_not_dvd h]
    rw [Factorization.balance, Factorization.sum, hsum, hfact, ge_iff_le, neg_le_sub_iff_le_add, ← sub_eq_add_neg, le_sub_iff_add_le]
    norm_cast
    have hK : K = (P.n - 1) / p - (P.n - P.n / P.M - 1) / p := by
       rw [← Finset.card_Ico, ← Finset.card_filter, Finset.filter_dvd_Ico_card,
           Nat.sub_sub_self (Nat.div_le_self _ _)]
       exact hprime.pos
    have h_bound : P.n / p ≤ P.M * K + P.M := by
      have hK_ge : K ≥ (P.n / P.M) / p := by
        rw [hK]
        apply Nat.le_trans _ (Nat.le_sub_of_add_le (Nat.div_add_div_le (P.n - P.n / P.M - 1) (P.n / P.M) p))
        rw [Nat.sub_sub (P.n - 1), Nat.sub_add_cancel (Nat.le_pred_of_lt (Nat.sub_lt_self P.hL_pos (Nat.div_pos (by linarith [P.hL]) P.M)))]
        exact le_refl _
      trans P.M * ((P.n / P.M) / p) + P.M
      · let q := P.n / P.M
        let r := P.n % P.M
        have hn : P.n = q * P.M + r := (Nat.div_add_mod P.n P.M).symm
        have hr : r < P.M := Nat.mod_lt _ (by have := P.hL; nlinarith)
        rw [hn, Nat.mul_comm q, Nat.mul_add_div hprime.pos]
        refine Nat.add_le_add_right (Nat.div_le_div_right (by
           calc (q % p) * P.M + r ≤ (p - 1) * P.M + (P.M - 1) := Nat.add_le_add (Nat.mul_le_mul_right _ (Nat.le_pred_of_lt (Nat.mod_lt _ hprime.pos))) (Nat.le_pred_of_lt hr)
              _ = p * P.M - 1 := by omega
           )) _
      · gcongr
    exact h_bound
  · simp [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime _ hprime]
    exact_mod_cast Nat.zero_le _
