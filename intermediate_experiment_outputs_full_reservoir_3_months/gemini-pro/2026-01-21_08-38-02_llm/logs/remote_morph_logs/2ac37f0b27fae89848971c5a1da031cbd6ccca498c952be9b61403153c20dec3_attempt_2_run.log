            apply mul_lt_mul_of_pos_right _ (Real.sqrt_pos.mpr (by exact_mod_cast (pos_of_gt P.hL))); exact_mod_cast Real.lt_sqrt (Nat.cast_nonneg _) |>.mpr P.hL
