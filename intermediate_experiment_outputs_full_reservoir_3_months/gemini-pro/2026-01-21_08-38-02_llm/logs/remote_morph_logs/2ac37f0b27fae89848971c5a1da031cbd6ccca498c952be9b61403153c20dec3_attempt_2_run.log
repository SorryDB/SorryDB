                _ = p^2 * P.n := by ring
            _ = P.n := by field_simp [cast_pos.mpr (Nat.pos_of_gt P.hL)]
        have h_q_dvd_div : q ∣ m / p := by
          rw [Nat.dvd_div_iff_mul_dvd hdvd]
          exact Coprime.mul_dvd_of_dvd_of_dvd (Coprime.symm ((Coprime.prime_prime hprime hq_prime).mpr (Ne.symm hqp))) hdvd hq_dvd
        apply le_trans (le_of_dvd (Nat.div_pos (Nat.le_of_dvd hm_pos hdvd) hp_pos) h_q_dvd_div)
