          apply Nat.sub_le_sub_left
          exact Nat.one_le_of_lt hM_pos
        _ < P.M * p + P.M * p := by nlinarith
        _ = (2 * P.M) * p := by ring
    calc (P.initial.balance p : ℤ) 
      _ = (P.initial.sum (fun m ↦ m.factorization p) : ℤ) - (P.n / p : ℤ) := rfl
      _ ≥ (P.M * ((P.n / P.M) / p) : ℤ) - (P.n / p : ℤ) := by gcongr
      _ ≥ - (P.M : ℤ) := by linarith

  · simp only [Factorization.balance, Factorization.sum, Nat.factorization_eq_zero_of_not_prime p hprime]
    rw [sum_const_zero]
    simp
    linarith
