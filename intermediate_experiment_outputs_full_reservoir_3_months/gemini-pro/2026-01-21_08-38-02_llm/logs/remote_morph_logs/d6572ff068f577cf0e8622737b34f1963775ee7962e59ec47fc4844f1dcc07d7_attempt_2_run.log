theorem binary_prod_map_fibrant {X Y X' Y' : K} {f : X ↠ Y} {g : X' ↠ Y'} :
    IsIsofibration (prod.map f.1 g.1) := by
  rw [← prod.map_id_comp, ← prod.map_comp_id]
  apply comp_isIsofibration
  · apply pullback_isIsofibration f prod.fst _ _
    refine IsPullback.mk (by simp) (IsLimit.mk _ (fun s => prod.lift s.fst (s.snd ≫ prod.snd)) (by simp) (by simp) ?_)
    intro s m h1 h2
    apply prod.hom_ext
    · simpa using h1
    · simp [← h2]
  · apply pullback_isIsofibration g prod.snd _ _
    refine IsPullback.mk (by simp) (IsLimit.mk _ (fun s => prod.lift (s.fst ≫ prod.fst) s.snd) (by simp) (by simp) ?_)
    intro s m h1 h2
    apply prod.hom_ext
    · simp [← h1]
    · simpa using h2
```
