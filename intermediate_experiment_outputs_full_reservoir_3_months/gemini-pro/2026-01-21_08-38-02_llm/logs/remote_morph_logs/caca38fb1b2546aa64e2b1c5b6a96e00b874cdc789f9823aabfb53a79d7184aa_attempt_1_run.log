        rw [pow_one, Fintype.card_congr (QuotientAddGroup.quotientKerEquivRange γ.1.toAddMonoidHom)]
        have : Set.range γ.1 ⊆ rootsOfUnity ⟨q, hq.pos⟩ ℂ := by
          rintro _ ⟨x, rfl⟩
          simp [mem_rootsOfUnity, ← map_nsmul_pow, (by simp [G] : q • x = 0), hq.pos]
        refine (Fintype.card_le_of_embedding (Function.Embedding.subtype _) (Function.Embedding.refl _)).trans ?_
        refine (Fintype.card_le_of_embedding (Function.Embedding.subtype _) ?_).trans ?_
        · exact fun ⟨x, hx⟩ ↦ ⟨x, this hx⟩
        · simp [Complex.card_rootsOfUnity, hq.pos]
