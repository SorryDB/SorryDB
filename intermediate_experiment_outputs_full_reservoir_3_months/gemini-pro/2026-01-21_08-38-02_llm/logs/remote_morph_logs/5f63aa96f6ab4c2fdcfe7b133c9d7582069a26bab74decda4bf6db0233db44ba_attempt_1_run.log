theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let σ := linearInvo k
  have hσ_sq : σ ^ 2 = 1 := linearInvo_sq k

  let partition (A : Set (S k)) (cond : S k → Prop) (hA : A = {s | cond s})
      (h_neg : ∀ s, cond s ↔ ¬ cond (σ s)) : 2 * Fintype.card A = Fintype.card (S k) := by
    let f : A → {s : S k // ¬ cond s} := fun ⟨s, hs⟩ => ⟨σ s, by rwa [← h_neg]⟩
    let g : {s : S k // ¬ cond s} → A := fun ⟨s, hs⟩ => ⟨σ s, by rwa [h_neg, not_not] at hs⟩
    have : Fintype.card A = Fintype.card {s : S k // ¬ cond s} :=
      Fintype.card_congr (Equiv.mk f g (fun _ => Subtype.ext (congr_fun hσ_sq _)) (fun _ => Subtype.ext (congr_fun hσ_sq _)))
    rw [← Fintype.card_congr (Equiv.Set.univ (S k)), ← Set.union_compl_self {s | cond s}]
    rw [Fintype.card_union_of_disjoint (Set.disjoint_compl_right), hA, this, two_mul]

  have hT : 2 * Fintype.card (T k) = Fintype.card (S k) := by
    refine partition (T k) (fun s => s.1.2.2 > 0) rfl (fun s => ?_)
    simp only [linearInvo]; dsimp
    have : s.1.2.2 ≠ 0 := by
