      have : (4 * k + 1) % 4 = 0 := by rw [← h1]; simp
      norm_num at this
    linarith

  have hU : 2 * Fintype.card (U k) = Fintype.card (S k) := by
    refine partition (U k) (fun s => s.1.1 - s.1.2.1 + s.1.2.2 > 0) rfl (fun s => ?_)
    simp only [linearInvo]; dsimp
    have : s.1.1 - s.1.2.1 + s.1.2.2 ≠ 0 := by
      intro h; obtain ⟨h1, _, _⟩ := s.2
      have : (2 * s.1.1 + s.1.2.2) ^ 2 = 4 * k + 1 := by
        rw [eq_add_of_sub_eq' h] at h1; nlinarith
      have : (2 * s.1.1 + s.1.2.2).natAbs = 1 ∨ (2 * s.1.1 + s.1.2.2).natAbs = 4 * k + 1 :=
        Nat.dvd_prime Fact.out |>.mp ⟨_, by rw [← Int.natAbs_pow_two, this]; norm_cast⟩
      have p_ge_2 : 4 * k + 1 ≥ 2 := Nat.Prime.two_le Fact.out
