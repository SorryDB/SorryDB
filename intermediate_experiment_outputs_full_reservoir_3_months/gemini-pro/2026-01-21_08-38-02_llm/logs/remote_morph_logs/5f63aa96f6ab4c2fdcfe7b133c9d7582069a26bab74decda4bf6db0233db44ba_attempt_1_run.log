theorem sameCard : Fintype.card (U k) = Fintype.card (T k) := by
  let σ := linearInvo k
  have hσ_sq : ∀ s, σ (σ s) = s := fun s ↦ congr_fun (linearInvo_sq k) s
  have half_card (A : Set (S k)) (h : ∀ s, s ∈ A ↔ σ s ∉ A) : 2 * Fintype.card A = Fintype.card (S k) := by
    let f : A ⊕ A → S k := fun x ↦ match x with | .inl a => a | .inr a => σ a
    apply Fintype.card_eq_of_bijective f
    constructor
    · intro x y heq
      cases x <;> cases y <;> simp [f, σ] at heq
      · exact Subtype.ext heq
      · exact (h _).mp y.2 (heq ▸ x.2) |>.elim
      · exact (h _).mp x.2 (heq.symm ▸ y.2) |>.elim
      · exact Subtype.ext (hσ_sq _ ▸ congr_arg σ heq)
    · intro s
      by_cases hs : s ∈ A
      · exact ⟨.inl ⟨s, hs⟩, rfl⟩
      · exact ⟨.inr ⟨σ s, (h (σ s)).mpr (hσ_sq s ▸ hs)⟩, hσ_sq s⟩
  have z_ne_0 (s : S k) : s.1.2.2 ≠ 0 := by
    intro hz
    have := s.2.1
    simp [hz] at this
    apply_fun (· % 4) at this
    simp [Int.mul_emod_right, Int.add_mul_emod_self] at this
  have phi_ne_0 (s : S k) : s.1.1 - s.1.2.1 + s.1.2.2 ≠ 0 := by
    intro hz
    have := s.2.1
    rw [eq_sub_of_add_eq hz] at this
    ring_nf at this
    have h_sq : (s.1.1 + s.1.2.1).natAbs ^ 2 = 4 * k + 1 := by
      rw [← Int.coe_nat_inj']; push_cast; rw [sq_abs]; exact this
    exact hk.out.not_sq _ h_sq
  have hT : ∀ s, s ∈ T k ↔ σ s ∉ T k := by
    intro s
    simp [T, σ, linearInvo]
    have := z_ne_0 s
    constructor <;> intro <;> linarith
  have hU : ∀ s, s ∈ U k ↔ σ s ∉ U k := by
