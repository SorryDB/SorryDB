  F Y := Hom c Y
  homF {Y Z : α} (f : Hom Y Z) (g : Hom c Y) := g ≫ f
  map_id Y := by sorry
  map_comp {Y Z W : α} (f : Hom Y Z) (g : Hom Z W) := by
    simp [Category.comp]
    funext x
    simp only [Function.comp_apply]
    rw [assoc]
