  · intro A B heq
    apply Set.ext; intro x
    constructor <;> intro hx
    · have : f x ∈ image f B := heq ▸ ⟨x, hx, rfl⟩
      rcases this with ⟨y, hy, eq⟩
      rwa [← h1 eq]
    · have : f x ∈ image f A := heq.symm ▸ ⟨x, hx, rfl⟩
      rcases this with ⟨y, hy, eq⟩
      rwa [← h1 eq]
  · intro S
    exists {x | f x ∈ S}
    apply Set.ext; intro y
    constructor
    · rintro ⟨x, hx, rfl⟩; exact hx
    · intro hy
      rcases h2 y with ⟨x, rfl⟩
      exact ⟨x, hy, rfl⟩
