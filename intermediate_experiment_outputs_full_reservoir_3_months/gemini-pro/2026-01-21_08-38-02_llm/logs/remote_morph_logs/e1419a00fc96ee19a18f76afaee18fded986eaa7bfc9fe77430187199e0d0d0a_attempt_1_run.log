section

/- There are special cases of the change of variables theorems for affine transformations
(but you can also use the change of variable theorem from the lecture) -/
example (a b : ℝ) :
    ∫ x in a..b, sin (x / 2 + 3) =
    2 * cos (a / 2 + 3) - 2 * cos (b / 2  + 3) := by
  let F x := -2 * cos (x / 2 + 3)
  rw [integral_eq_sub_of_hasDerivAt (F := F)]
  · ring
  · intro x _
    have h : HasDerivAt (fun y ↦ y / 2 + 3) (1 / 2) x :=
      ((hasDerivAt_id x).div_const 2).add_const 3
    convert (h.cos).const_mul (-2) using 1
    ring
  · apply Continuous.intervalIntegrable; continuity
