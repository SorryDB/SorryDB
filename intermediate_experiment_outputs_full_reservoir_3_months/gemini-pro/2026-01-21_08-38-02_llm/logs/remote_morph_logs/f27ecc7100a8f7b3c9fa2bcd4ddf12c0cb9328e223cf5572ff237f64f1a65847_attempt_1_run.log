variable (v : Π (i : ι), E i)

#check PreLp (α := ι) E
#check Memℓp v p
#check lp E p

def ONE : PreLp (fun n : ℕ ↦ ℝ) := (fun _ : ℕ ↦ 1)

def GEO : PreLp (fun n : ℕ ↦ ℝ) := (fun n : ℕ ↦ (1 / n))

example : Memℓp ONE ∞ := by sorry

lemma GEO_mem_ℓ2 : Memℓp GEO 2 := by
  refine Memℓp.of_finite_support (Set.Finite.subset (Set.finite_singleton 1) ?_)
  intro n
  simp [GEO]
  intro h
  match n with
  | 0 => simp at h
  | 1 => rfl
  | n+2 =>
    rw [Nat.div_eq_of_lt (Nat.one_lt_succ_succ n)] at h
    contradiction
```
