derivation : G.ContextFreeDerivation u' v
sound : dstep.result = u'
h_exhaustive : (step dstep derivation sound).exhaustiveCondition
h_constructor_cfd : cfd = step dstep derivation sound
rightSide : Word ({ x // x ∈ G.V } ⊕ { x // x ∈ G.Z }) := (↑dstep.prod).rhs
allChildren : List (G.DerivationTree × { x // x ∈ Finset.range u'.len }) :=
  match h_constructor : derivation, h_exhaustive, h_constructor_cfd with
