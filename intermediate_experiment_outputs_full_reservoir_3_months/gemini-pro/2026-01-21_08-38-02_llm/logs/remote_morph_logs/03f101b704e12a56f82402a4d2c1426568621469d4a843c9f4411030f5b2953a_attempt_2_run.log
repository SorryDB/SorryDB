  map_smul' := sorry
  cont := by
    let b := Module.Finite.finBasis ℝ E
    let L (i : Fin (Module.finrank ℝ E)) : 𝓓'(Ω, F) →L[ℝ] 𝓓'(Ω, E →L[ℝ] F) :=
      (mapCLM ((b.coord i).smulRight : F →L[ℝ] E →L[ℝ] F)).comp (lineDerivCLM (b i))
