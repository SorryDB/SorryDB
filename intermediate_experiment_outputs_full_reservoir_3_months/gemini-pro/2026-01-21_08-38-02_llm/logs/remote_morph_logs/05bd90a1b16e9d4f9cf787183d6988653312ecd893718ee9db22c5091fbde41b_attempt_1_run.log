  theorem list_set_eraseIdx {l : List (List α)} {l1 : List α}
    {idx idx1 : Nat}  {hidx : idx < l.length} {hidx1 : idx1 < l1.length} :
    ∃ idx' : Fin (l.set idx l1).flatten.length,
      (l.set idx (l1.eraseIdx idx1)).flatten = (l.set idx l1).flatten.eraseIdx idx'
      ∧ l1[idx1] = (l.set idx l1).flatten[idx']
      := by
      induction l generalizing idx with
      | nil => contradiction
      | cons h t ih =>
        cases idx with
        | zero =>
          dsimp [List.set, List.flatten]
          exists ⟨idx1, Nat.lt_of_lt_of_le hidx1 (Nat.le_add_right _ _)⟩
          rw [List.eraseIdx_append_of_lt hidx1, List.getElem_append_left hidx1]
          exact ⟨rfl, rfl⟩
        | succ n =>
          simp only [List.length_cons, Nat.succ_lt_succ_iff] at hidx
          obtain ⟨idx', h_eq, h_elt⟩ := ih (idx := n) (hidx := hidx)
          dsimp [List.set, List.flatten]
          exists ⟨h.length + idx', Nat.add_lt_add_left idx'.isLt _⟩
          rw [List.eraseIdx_append_of_ge (Nat.le_add_right _ _),
              List.getElem_append_right (Nat.le_add_right _ _)]
          simp [h_eq, h_elt]
```
