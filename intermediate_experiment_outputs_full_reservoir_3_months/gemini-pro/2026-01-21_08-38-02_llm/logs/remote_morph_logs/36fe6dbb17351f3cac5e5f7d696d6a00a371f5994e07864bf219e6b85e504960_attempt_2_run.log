    have : ENNReal.HolderTriple (p i) ↑q' q := ⟨by rw [← hpq, inv_inv, heq]⟩
    have hqn0 : (q : ℝ≥0∞) ≠ 0 := by
      intro h
      rw [h, ENNReal.inv_zero] at hpq
      refine ENNReal.coe_ne_top _ (hpq.symm.trans_lt ?_).ne
