open AffineMap Finset

variable {ι 𝕜 V : Type*} [DecidableEq ι] [Field 𝕜] [LinearOrder 𝕜] [IsStrictOrderedRing 𝕜]
  [AddCommGroup V] [Module 𝕜 V] {s t : Finset ι} {w : ι → 𝕜} {x y : ι → V} {i : ι}

