```lean
@[blueprint
  "fks-theorem-3-1"
  (title := "FKS Theorem 3.1")
  (statement := /-- Let $x > e^{50}$ be half an odd integer and suppose that $50 < T < x$.  Then $E_\psi(x) \leq \sum_{|\gamma| < T} |x^{\rho-1}/\rho| + 2 \log^2 x / T.$ -/)]
theorem theorem_3_1 {x T : ℝ} (hx : x > exp 50) (hodd : ∃ X, Odd X ∧ x = X / 2) (hT : T ∈ Set.Ioo 50 x) : Eψ x ≤ riemannZeta.zeroes_sum (Set.Ioo 0 1) (Set.Ioo (-T) T) (fun ρ ↦ ‖x^(ρ - 1) / ρ‖) + 2 * (log x)^2 / T := by
  have hx' : 1 < x := (Real.exp_lt_exp.mpr (by norm_num)).trans hx
  have hT' : 1 ≤ T := le_of_lt (lt_trans (by norm_num) hT.1)
