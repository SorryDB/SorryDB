@[category research open, AMS 11]
theorem erdos_428 :
    answer(False) ↔ ∃ A : Set ℕ,
      (∃ᶠ n in atTop, ∀ a ∈ A, 0 < a → a < n → (n - a).Prime) ∧
      liminf (fun n ↦ primeDensityRatio A n) atTop > 0 := by
  rw [iff_false]
  intro ⟨A, h_inf, h_dens⟩
  -- C. Elsholtz (2001) proved that if n - A ⊂ P for infinitely many n, then |A(x)| ≪ √x.
  -- This implies the density relative to primes tends to 0.
  have h_zero : liminf (fun n ↦ primeDensityRatio A n) atTop = 0 := by
    sorry
  rw [h_zero] at h_dens
  exact lt_irrefl _ h_dens
```
