    iIndepFun (fun e ω ↦ e ∈ (G ω).edgeSet) P := by
  rw [hG, binomialRandom]
  exact (bernoulliOn_iIndepFun _ _).comp_measurableEmbedding measurableEmbedding_edgeSet
