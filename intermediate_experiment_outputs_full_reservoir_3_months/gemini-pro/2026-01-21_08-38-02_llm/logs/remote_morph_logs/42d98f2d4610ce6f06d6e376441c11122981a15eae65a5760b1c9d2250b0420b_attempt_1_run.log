namespace Imo2000P5

determine solution : Bool := true

problem imo2000P5 :
    ∃ n, 0 < n ∧ n.primeFactors.card = 2000 ∧ n ∣ 2 ^ n + 1
    ↔ solution := by
  simp [solution]
  have : ∀ k, ∃ n, 3 < n ∧ n.primeFactors.card = k ∧ n ∣ 2 ^ n + 1 := by
    intro k
    induction k with
    | zero => use 9; simp; contradiction
    | succ k ih =>
      cases k with
      | zero =>
        use 9; simp; constructor; rfl; norm_num
      | succ k' =>
        rcases ih with ⟨n, hn_gt, hn_card, hn_dvd⟩
        have h2n : 1 < 2 * n := by linarith
        obtain ⟨p, hp, hpdvd, hprim⟩ := zsigmondy 2 1 (2 * n) (by norm_num) (by norm_num) (by norm_num) (by linarith) h2n (by simp; linarith) (by simp; intros; linarith)
        simp at hpdvd hprim
        have hp_dvd_plus : p ∣ 2 ^ n + 1 := by
          rw [mul_comm, pow_mul, Nat.sq_sub_sq, one_pow] at hpdvd
          cases hp.dvd_mul.mp hpdvd with
          | inl h => exfalso; apply hprim n (by linarith) (by linarith); simpa using h
          | inr h => exact h
        have hp_gt_n : n < p := by
          have : orderOf (2 : ZMod p) = 2 * n := by
            refine Nat.dvd_antisymm (orderOf_dvd_of_pow_eq_one (by zify; simp [hpdvd]; rw [←Nat.dvd_iff_mod_eq_zero] at hpdvd; exact hpdvd)) ?_
            by_contra h; push_neg at h
            apply hprim (orderOf (2 : ZMod p)) (lt_of_le_of_ne h ?_) (orderOf_pos _); assumption
            intro heq; rw [heq] at h; simp at h
          have : 2 * n ∣ p - 1 := by rw [← this]; apply orderOf_dvd_card_sub_one; simp; exact hp.ne_zero
          linarith
        use n * p
