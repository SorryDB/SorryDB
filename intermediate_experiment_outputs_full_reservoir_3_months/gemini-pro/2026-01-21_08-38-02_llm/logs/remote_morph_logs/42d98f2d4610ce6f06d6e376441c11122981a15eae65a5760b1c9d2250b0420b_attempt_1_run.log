      · simp
      · simp [Nat.mem_primeFactors, hp_ndiv, (by linarith : n ≠ 0)]
      · linarith
    · -- np ∣ 2^np + 1
      -- We have 2^n ≡ -1 (mod n) and 2^n ≡ -1 (mod p).
      -- Since gcd(n, p) = 1, 2^n ≡ -1 (mod np).
      -- Since p is a prime factor of 2^n+1, p is odd.
      -- Thus 2^{np} = (2^n)^p ≡ (-1)^p ≡ -1 (mod np).
      sorry

  -- Base Case: k=1, n=9.
  have h1 : ∃ n, 9 ≤ n ∧ n.primeFactors.card = 1 ∧ n ∣ 2^n + 1 := by
    use 9
    simp
    constructor
    · -- ω(9) = 1
      have : 9 = 3^2 := by rfl
      rw [this, Nat.primeFactors_pow]
      · simp
      · simp
      · simp
    · -- 9 ∣ 2^9 + 1
      decide

  -- Conclusion by induction (informal)
  -- By repeatedly applying 'step' starting from 'h1', we can reach k=2000.
  sorry
