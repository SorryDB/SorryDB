    [IsNonarchimedeanLocalField L] (e : L ≃+* L) (x : L) :
    valuation L (e x) = valuation L x := by
  rw [IsNonarchimedeanLocalField.valuation_norm_eq, IsNonarchimedeanLocalField.valuation_norm_eq]
  congr 1
  exact (IsNonarchimedeanLocalField.isometry e).norm_map x
