lemma walk_edge_card_equiv {n : ℕ} (p q : ClosedLoopWalk (K n)) (heq : LoopWalkEquiv n p q) :
  (edgeSet p.2).card = (edgeSet q.2).card := by
  obtain ⟨s, rfl⟩ := heq
  have h_edges : ∀ {u v} (w : (K n).LoopWalk u v),
      (permMapWalk n s w).edges = w.edges.map (Sym2.map s) := by
    intro u v w
    induction w with
    | nil => simp
    | cons _ _ ih => simp [ih, dartEdge]
    | loop _ ih => simp [ih, dartEdge]
  rw [edgeSet, edgeSet, h_edges, List.toFinset_map, Finset.card_image_of_injective]
  exact Sym2.map_injective s.injective
```
