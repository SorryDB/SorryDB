      abs (∑ j ∈ Finset.Icc (m + 1) n, (a j - b)) ≤ 1007 ^ 2 := by
  let C : ℤ := 2015
  -- Define the set of holes H_n for each n
  let H (n : ℕ) : Finset ℤ :=
    (Finset.Icc 2 (n + C)) \ (Finset.image (fun i => i + a ⟨i, by omega⟩) (Finset.Icc 1 n))
  
  -- The holes move monotonically. Either they stay fixed or they increase.
  -- A hole h is fixed if it belongs to H_n for all large n.
  -- Let FixedHoles be the set of such holes.
  let AllHoles := ⋃ n, (H n).toSet
  let FixedHoles := {h ∈ AllHoles | ∃ N, ∀ n ≥ N, h ∈ H n}
  
  -- Because |H n| = C - 1 is constant and holes only move to the right,
