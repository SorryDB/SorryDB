  -- Define C = 2015
  let C : ℤ := 2015
  let c (k : ℕ+) : ℤ := k + a k

  -- Injectivity of c
  have hc_inj : Function.Injective c := by
    intros x y h
    simp [c] at h
    by_contra hne
    rcases lt_trichotomy x y with hlt | _ | hgt
    · have := hii y x ⟨x.2, hlt⟩; rw [add_comm (x:ℤ), add_comm (y:ℤ)] at this; exact this h.symm
    · contradiction
    · have := hii x y ⟨y.2, hgt⟩; exact this h

  -- Define the set of "holes" (values not in the range of c)
  let H := {z : ℤ | 2 ≤ z ∧ z ∉ Set.range c}
  
  -- Prove H is finite by showing it is bounded in density
  have H_finite : Set.Finite H := by
    apply Set.finite_of_ncard_le_of_subset (C.toNat - 1) (fun z hz => hz.1)
    intro M
    let S := {k : ℕ+ | c k ≤ M}
    let Im := c '' S
    let Holes_M := H ∩ Set.Iic (M : ℤ)
    
    have h_disj : Disjoint Im Holes_M := by
      rw [Set.disjoint_iff]; rintro z ⟨⟨k, rfl, _⟩, ⟨_, h_not_im, _⟩⟩
