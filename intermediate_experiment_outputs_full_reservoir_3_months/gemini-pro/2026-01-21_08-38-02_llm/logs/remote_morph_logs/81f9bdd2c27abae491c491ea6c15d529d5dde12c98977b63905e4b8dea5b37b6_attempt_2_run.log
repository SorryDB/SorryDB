  obtain ⟨s, hs, l, hl⟩ := tendsto_subseq_ae_of_cauchySeq h_cauchy
  let F : ℝ → ℝ≥0∞ := fun x ↦ if x ≤ 0 then ⊤ else ENNReal.ofReal (-2 * Real.log x)
  let l' := l.aemeasurable.mk _
