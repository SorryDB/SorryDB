      (Real.measurable_exp.comp (measurable_toReal.neg))
  let φ : (Ω → ℝ≥0∞) → ℝ := fun f ↦ ∫ ω, u (f ω) ∂P
  have hφ_nonneg : 0 ≤ φ := fun f ↦ integral_nonneg fun ω ↦ by dsimp [u]; split_ifs <;> positivity
  have hφ_bdd : ∃ M, ∀ n, φ (X n) ≤ M :=
    ⟨1, fun n ↦ (integral_le_integral_of_le (fun ω ↦ by
      dsimp [u]; split_ifs <;> simp [Real.exp_le_one_iff, *])
      (integrable_const (1 : ℝ))).trans_eq (integral_const 1).2⟩
  obtain ⟨g, hg_hull, hg_conv⟩ := komlos_convex (f := X) hφ_nonneg hφ_bdd
  let δ (k : ℕ) : ℝ := (1 / 2) * (1 / 4) ^ k
  have hδ_pos k : 0 < δ k := by positivity
  let N_aux (k : ℕ) := (hg_conv (δ k) (hδ_pos k)).choose
  let N : ℕ → ℕ := Nat.rec (N_aux 0) fun k prev ↦ max (max (prev + 1) (k + 1)) (N_aux (k + 1))
  have hN_mon : StrictMono N := strictMono_nat_of_lt_succ fun n ↦
    lt_of_lt_of_le (lt_add_one _) (le_max_left _ _)
  let Y (k : ℕ) := g (N k)
  have hY_hull (k : ℕ) : Y k ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (k + m)) := by
    refine convexHull_mono (Set.range_subset_iff.2 fun m ↦ ?_) (hg_hull (N k))
    exact ⟨N k - k + m, by rw [add_assoc, tsub_add_cancel_of_le (hN_mon.le_apply.trans (le_add_right _ _))]⟩
