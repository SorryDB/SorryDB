lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let E := {f : Ω → ℝ≥0∞ // Measurable f}
  have : AddCommMonoid E := Subtype.coe_injective.addCommMonoid _ (fun _ _ ↦ rfl) (fun _ _ ↦ rfl)
  have : Module ℝ≥0 E := Subtype.coe_injective.module ℝ≥0 (Subtype.val : E → _) (fun _ _ ↦ rfl) (fun _ _ ↦ rfl)
  let X' : ℕ → E := fun n ↦ ⟨X n, hX n⟩
  let φ : E → ℝ := fun f ↦ ∫ ω, (ENNReal.exp (-f.1 ω)).toReal ∂P
  have hφ_bdd : ∃ M, ∀ n, φ (X' n) ≤ M := ⟨1, fun n ↦ integral_le_one_of_nonneg (fun _ ↦ by positivity)
    (eventually_of_forall fun ω ↦ by simp [ENNReal.exp_neg]; exact inv_le_one (ENNReal.exp_ge_one _))⟩
  obtain ⟨g', hg', hg_cauchy⟩ := komlos_convex (f := X') (fun f ↦ integral_nonneg fun _ ↦ by positivity) hφ_bdd
  let g : ℕ → Ω → ℝ≥0∞ := fun n ↦ (g' n).1
  have hg_hull : ∀ n, g n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m)) := fun n ↦ by
    rw [← Set.image_range_val] at hg'; specialize hg' n
    refine convexHull_mono (Set.subset_refl _) (Convex.restrictScalars (by simp) (convex_convexHull ℝ≥0∞ _))
      ((LinearMap.map_convexHull Submodule.subtypeL _ _).mpr hg')
  let u : ℕ → Ω → ℝ := fun n ω ↦ Real.sqrt (ENNReal.exp (-g n ω)).toReal
  have hu : ∀ n, Memℒp (u n) 2 P := fun n ↦ Memℒp.of_bound (g' n).2.ennreal_exp_neg.ennreal_toReal.sqrt 1
    (eventually_of_forall fun _ ↦ Real.sqrt_le_one (by positivity) (ENNReal.toReal_le_of_le_ofReal (by positivity)
      (by simp [ENNReal.exp_neg]; exact inv_le_one (ENNReal.exp_ge_one _))))
  have h_cauchy : CauchySeq (fun n ↦ Lp.ofMemℒp (u n) (hu n)) := by
    rw [Metric.cauchySeq_iff']; intro ε εpos
    obtain ⟨N, hN⟩ := hg_cauchy (ε^2 / 2) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    specialize hN n m hn hm
    rw [Lp.dist_def, snorm_eq_lintegral_rpow_nnnorm (p := 2) (by norm_num) (by norm_num)]
    calc (∫⁻ ω, ENNReal.ofReal |u n ω - u m ω| ^ 2 ∂P) ^ (1/2 : ℝ)
      _ = (ENNReal.ofReal (∫ ω, (u n ω - u m ω)^2 ∂P)) ^ (1/2 : ℝ) := by
          congr; rw [ofReal_integral_eq_lintegral_ofReal]
          · congr; ext; simp; norm_cast
