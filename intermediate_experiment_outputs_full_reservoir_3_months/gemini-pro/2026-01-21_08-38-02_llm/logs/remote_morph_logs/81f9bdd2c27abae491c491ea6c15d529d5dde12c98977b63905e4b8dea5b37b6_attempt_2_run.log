      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let E := {f : Ω → ℝ≥0∞ // Measurable f}
  let ψ (x : ℝ≥0∞) := if x = ⊤ then 0 else Real.exp (-x.toReal)
  let φ (f : E) := ∫ ω, ψ (f.1 ω) ∂P
  have hψ (x y : ℝ≥0∞) : ψ ((x + y) / 2) + 1/2 * (Real.sqrt (ψ x) - Real.sqrt (ψ y))^2 = (ψ x + ψ y) / 2 := by
    dsimp [ψ]; rcases x with - | x; rcases y with - | y <;>
      simp [ENNReal.toReal_div, Real.exp_add, Real.exp_mul, Real.rpow_inv_two, ← sq] <;> field_simp <;> ring
  obtain ⟨g, hg_hull, hg_lim⟩ := komlos_convex (E := E) (φ := φ)
    (fun f ↦ integral_nonneg fun _ ↦ by dsimp [ψ]; split <;> positivity)
    ⟨1, fun n ↦ integral_le_one_of_bounded (fun _ ↦ by dsimp [ψ]; split <;> simp [Real.exp_le_one_iff] <;> linarith)⟩
