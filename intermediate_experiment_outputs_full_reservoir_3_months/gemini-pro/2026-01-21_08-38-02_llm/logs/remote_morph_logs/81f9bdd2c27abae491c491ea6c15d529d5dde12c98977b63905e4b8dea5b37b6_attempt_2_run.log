lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let v (x : ℝ≥0∞) : ℝ := if x = ⊤ then 0 else Real.exp (-x.toReal)
  have hv : Continuous v := continuous_iff_continuousAt.2 fun x ↦ by
    by_cases h : x = ⊤
    · subst h; refine (Real.tendsto_exp_nhds_0_nhds_0.comp (ENNReal.tendsto_toReal_atTop_iff.2 tendsto_id)).continuousAt
    · exact (Real.continuous_exp.comp (continuous_neg.comp (ENNReal.continuous_toReal h))).continuousAt
  have hv_inj : Function.Injective v := by
    intro x y h; dsimp [v] at h; split_ifs at h with hx hy hy
    · exact hx.trans hy.symm
    · exfalso; exact (Real.exp_pos _).ne h.symm
    · exfalso; exact (Real.exp_pos _).ne h
    · rw [Real.exp_eq_exp, neg_inj, ENNReal.toReal_eq_toReal hx hy] at h; exact h
  let φ (f : Ω → ℝ≥0∞) : ℝ := ∫ ω, (v (f ω))^2 ∂P
  have hφ_bdd : ∃ M, ∀ n, φ (X n) ≤ M := ⟨1, fun n ↦ integral_le_of_forall_le_of_integrable
    (fun ω ↦ by by_cases h : X n ω = ⊤ <;> simp [v, h]; exact Real.exp_le_one _) integrable_const⟩
  obtain ⟨g, hg_hull, hg_diff⟩ := komlos_convex (φ := φ) (fun f ↦ integral_nonneg fun _ ↦ sq_nonneg _) hφ_bdd
  have : CauchySeq (fun n ↦ Memℒp.toLp (v ∘ g n) (memℒp_top_of_bound (g := 1)
      (Measurable.aestronglyMeasurable (measurable_from_top.comp (convex_measurable (fun n ↦ hX n) (hg_hull n))))
      (eventually_of_forall fun ω ↦ by by_cases h : g n ω = ⊤ <;> simp [v, h]; exact Real.exp_le_one _)
      integrable_const)) := by
    refine Metric.cauchySeq_iff'.2 fun ε hε ↦ ?_
    obtain ⟨N, hN⟩ := hg_diff (ε^2/4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    rw [Lp.dist_def, SNorm, snorm_eq_lintegral_rpow_nnreal one_ne_zero two_ne_top,
        ← ENNReal.toReal_le_toReal (by finiteness) (by finiteness), ENNReal.toReal_lintegral, ENNReal.toReal_rpow]
    simp only [ENNReal.toReal_coe, one_div]; norm_cast
    refine lt_of_le_of_lt ?_ (by rw [Real.rpow_lt_rpow_iff two_pos, ← abs_of_pos hε, sq_abs]; exact hN _ _ hn hm)
    rw [← integral_def]; simp_rw [← sq_abs, abs_sub_comm (v _ ^ 2)]
    refine integral_mono_of_nonneg (eventually_of_forall fun _ ↦ by positivity) (integrable_const.mul_left 2) ?_
    filter_upwards with ω
    simp only [v, Pi.smul_apply, Algebra.id.smul_eq_mul, one_div, ENNReal.smul_def, smul_eq_mul]
    by_cases h1 : g n ω = ⊤ <;> by_cases h2 : g m ω = ⊤
    all_goals simp [h1, h2]; try linarith [Real.exp_pos (- (g m ω).toReal)]
    rw [ENNReal.toReal_mul, ENNReal.toReal_inv, ENNReal.toReal_ofNat, ENNReal.toReal_add h1 h2, Real.exp_add, neg_add, Real.exp_add]
    generalize Real.exp (- (g n ω).toReal) = a; generalize Real.exp (- (g m ω).toReal) = b
    norm_num; ring_nf
  obtain ⟨k, hk⟩ := this.subseq_tendsto_ae
  let Y_lim (ω : Ω) : ℝ≥0∞ := Function.invFun v (hk ω)
  refine ⟨g ∘ k, Y_lim, fun n ↦ ?_, ?_, ?_⟩
  · convert hg_hull (k n); refine subset_convexHull _ _ (Set.range_subset_iff.2 fun m ↦ ⟨k n - n + m, by simp⟩)
  · apply Measurable.of_lift_toTop; exact (Measurable.of_real.comp hk.measurable).comp
      (measurable_of_measurable_on_range_surjection (f := v) hv.measurable hv_inj
      (by rw [Set.range_eq_Icc]; exact measurableSet_Icc) (fun _ _ ↦ rfl))
  · filter_upwards [hk.ae_tendsto] with ω hω
    exact (hv.tendsto _).injective_of_isCompact_range hv_inj isCompact_range_top hω
