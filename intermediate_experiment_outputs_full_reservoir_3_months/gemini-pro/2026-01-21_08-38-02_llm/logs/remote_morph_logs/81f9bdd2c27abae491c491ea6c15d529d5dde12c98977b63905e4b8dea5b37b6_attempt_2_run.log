    refine convexHull_min ?_ (fun _ hf _ hg _ _ _ _ _ ↦ Measurable.add (hf.const_smul _) (hg.const_smul _)) (hg_mem n)
    rintro _ ⟨m, rfl⟩; exact hX _
  let u (n : ℕ) (ω : Ω) : ℝ := if g n ω = ⊤ then 0 else Real.exp (-(g n ω).toReal / 2)
