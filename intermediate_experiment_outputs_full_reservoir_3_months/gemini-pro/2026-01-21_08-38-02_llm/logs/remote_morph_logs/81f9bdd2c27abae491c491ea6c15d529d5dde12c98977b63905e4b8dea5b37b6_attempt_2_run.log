      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let ρ (x : ℝ≥0∞) : ℝ := if x = ⊤ then 0 else Real.exp (-x.toReal)
  let φ (f : Ω → ℝ≥0∞) : ℝ := ∫ ω, ρ (f ω) ∂P
  have hρ_bdd (x) : |ρ x| ≤ 1 := by
    dsimp [ρ]; split_ifs <;> simp [abs_le]
    exact (Real.exp_le_one_iff.2 (by simp)).trans zero_le_one
