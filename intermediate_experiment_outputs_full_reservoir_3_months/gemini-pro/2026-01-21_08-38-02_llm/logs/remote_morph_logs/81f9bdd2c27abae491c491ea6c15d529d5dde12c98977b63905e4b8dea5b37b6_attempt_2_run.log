lemma komlos_ennreal (X : ℕ → Ω → ℝ≥0∞) (hX : ∀ n, Measurable (X n))
    {P : Measure Ω} [IsProbabilityMeasure P] :
    ∃ (Y : ℕ → Ω → ℝ≥0∞) (Y_lim : Ω → ℝ≥0∞),
      (∀ n, Y n ∈ convexHull ℝ≥0∞ (Set.range fun m ↦ X (n + m))) ∧ Measurable Y_lim ∧
      ∀ᵐ ω ∂P, Tendsto (Y · ω) atTop (𝓝 (Y_lim ω)) := by
  let u (x : ℝ≥0∞) : ℝ := if x = ⊤ then 0 else Real.exp (- x.toReal)
  let φ (f : Ω → ℝ≥0∞) : ℝ := ∫ ω, u (f ω) ∂P
  have hφ_bdd : ∃ M, ∀ n, φ (X n) ≤ M := ⟨1, fun n ↦ integral_le_one_of_forall_le fun ω ↦ by
    dsimp [u]; split_ifs; exact le_rfl; exact Real.exp_le_one_iff.mpr (neg_nonpos.mpr (ENNReal.toReal_nonneg _))⟩
  obtain ⟨g, hg_hull, hg_komlos⟩ := komlos_convex (fun f ↦ integral_nonneg fun ω ↦ by
    dsimp [u]; split_ifs; exact le_rfl; exact (Real.exp_pos _).le) hφ_bdd (f := X)
  let v (n : ℕ) : Ω → ℝ := fun ω ↦ Real.sqrt (u (g n ω))
  have hv_mem : ∀ n, Memℒp (v n) 2 P := fun n ↦
    memℒp_top_of_bound (Measurable.ennreal_convex_mem hX (hg_hull n) |>.mono (fun x ↦ by
      dsimp [u]; split_ifs; exact continuous_const.measurable x; exact (Real.continuous_exp.comp (continuous_neg.comp ENNReal.continuous_toReal)).measurable x) |>.sqrt) 1
      (Eventually.of_forall fun ω ↦ Real.sqrt_le_one_of_le_one (by dsimp [u]; split_ifs; exact le_rfl; exact Real.exp_le_one_iff.mpr (neg_nonpos.mpr (ENNReal.toReal_nonneg _))))
  have hv_cauchy : CauchySeq (fun n ↦ (hv_mem n).toLp v) := by
    refine Metric.cauchySeq_iff'.2 fun ε hε ↦ ?_
    obtain ⟨N, hN⟩ := hg_komlos (ε^2/2) (div_pos (pow_pos hε 2) zero_lt_two)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    rw [Lp.dist_def, eLpNorm_eq_lintegral_rpow_enorm (p := 2) two_ne_zero ENNReal.two_ne_top,
      ENNReal.toReal_rpow_one_div_two, ← Real.sqrt_sq hε.le, Real.sqrt_lt_sqrt_iff (sq_nonneg _),
      ← ENNReal.toReal_lt_toReal (by finiteness) (by finiteness),
      ENNReal.toReal_lintegral_coe]
    specialize hN n m hn hm; simp only [φ] at hN
    have alg_ident : ∀ x y, u x / 2 + u y / 2 - u ((2 : ℝ≥0)⁻¹ • (x + y)) = 1/2 * (Real.sqrt (u x) - Real.sqrt (u y))^2 := by
      intro x y; dsimp [u]; rcases x with _ | x; swap; rcases y with _ | y
      · simp only [ENNReal.toReal_coe, ENNReal.coe_ne_top, if_false]
        rw [ENNReal.smul_def, ENNReal.coe_add, smul_eq_mul, ENNReal.toReal_mul, ENNReal.toReal_coe,
            ENNReal.toReal_ofReal (inv_nonneg.2 zero_le_two)]
        rw [show -(2⁻¹ * (x:ℝ) + 2⁻¹ * (y:ℝ)) = -x/2 + -y/2 by ring, Real.exp_add, Real.exp_mul, Real.exp_mul,
            Real.sqrt_sq (Real.exp_pos _).le, Real.sqrt_sq (Real.exp_pos _).le]
        ring_nf; field_simp; ring_nf; rw [Real.exp_mul, Real.exp_mul]; ring
      all_goals simp [u, ENNReal.top_add, ENNReal.add_top, ENNReal.smul_top, ENNReal.coe_ne_top]; field_simp; try ring
    simp_rw [← integral_sub (hv_mem n).integrable (hv_mem m).integrable,
      ← integral_mul_left, ← integral_add (hv_mem n).integrable.div_const (hv_mem m).integrable.div_const,
      alg_ident] at hN
