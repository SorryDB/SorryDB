    (fun f ↦ integral_nonneg fun ω ↦ by dsimp [ρ]; split_ifs <;> positivity)
    ⟨1, fun n ↦ (integral_le_integral_of_le (fun ω ↦ (hρ_bdd _).trans (by simp))
