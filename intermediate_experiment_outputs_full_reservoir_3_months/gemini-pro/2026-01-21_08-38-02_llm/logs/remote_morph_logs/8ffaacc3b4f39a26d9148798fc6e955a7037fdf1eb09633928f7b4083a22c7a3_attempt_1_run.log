    hist alg (fun i ↦ if h : i ∈ S then p.1 ⟨i, h⟩ else 0, p.2) n
  have h_eq : hist alg · n = F ∘ (fun ω ↦ (Y ω.1, ω.2)) := by
    ext ω
    refine hist_congr n _ _ ?_ rfl
    intro k hk
    simp [S, Nat.lt_succ_of_le hk, Y]
  rw [h_eq]
  refine IndepFun.comp ?_ measurable_id ((measurable_hist alg n).comp (by fun_prop))
  rw [indepFun_iff_map_prod_eq_prod_map_map (by fun_prop) (by fun_prop)]
  exact h_map
