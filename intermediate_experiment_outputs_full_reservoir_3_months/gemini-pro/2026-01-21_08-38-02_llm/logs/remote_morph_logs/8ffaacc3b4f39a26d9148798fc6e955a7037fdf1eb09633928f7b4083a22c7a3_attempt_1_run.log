lemma hasCondDistrib_reward_zero (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] :
    HasCondDistrib (reward alg 0) (action alg 0) (stationaryEnv ν).ν0 (arrayMeasure ν) where
  condDistrib_eq := by
    refine (condDistrib_ae_eq_cond (by fun_prop) (by fun_prop)).trans ?_
    rw [Filter.EventuallyEq, ae_iff_of_countable]
    intro a ha
    simp only [stationaryEnv_ν0, reward_zero]
    calc ((arrayMeasure ν)[|action alg 0 ⁻¹' {a}]).map (fun ω ↦ ω.2 0 (action alg 0 ω))
    _ = ((arrayMeasure ν)[|action alg 0 ⁻¹' {a}]).map (fun ω ↦ ω.2 0 a) := by
      refine Measure.map_congr
        (ae_cond_of_forall_mem ((measurableSet_singleton _).preimage (by fun_prop)) ?_)
      intro x hx
      simp only [Set.mem_preimage, Set.mem_singleton_iff] at hx
      simp [hx]
    _ = ν a := by
      rw [cond_of_indepFun]
      · exact map_snd_apply_arrayMeasure 0 a
      · have : (fun ω ↦ ω.1 0) ⟂ᵢ[arrayMeasure ν] fun ω ↦ ω.2 0 a :=
          indepFun_fst_zero_snd_zero_action ν a
        rw [action_zero]
        exact this.comp (φ := initAlgFunction alg) (by fun_prop) measurable_id
      · fun_prop
      · fun_prop
      · simp
      · rwa [Measure.map_apply (by fun_prop) (by simp)] at ha

lemma hist_depends_on_past [DecidableEq α] (alg : Algorithm α R) (n : ℕ)
    (ω ω' : probSpace α R) (h_u : ∀ k ≤ n, ω.1 k = ω'.1 k) (h_s : ω.2 = ω'.2) :
    hist alg ω n = hist alg ω' n := by
  induction n with
  | zero =>
    simp only [hist_zero]
    rw [h_u 0 (by simp), h_s]
  | succ n ih =>
    rw [hist_add_one, hist_add_one]
    have h_le : ∀ k ≤ n, ω.1 k = ω'.1 k := fun k hk => h_u k (Nat.le_succ_of_le hk)
    have h_hist : hist alg ω n = hist alg ω' n := ih h_le
    rw [h_hist]
    ext i
    by_cases hi : i ≤ n
    · simp [hi]
    · simp [hi]
      have : i.1 = n + 1 := Nat.eq_of_ge_of_lt (not_le.mp hi) i.2
      cases i
      simp_all
      congr
      · rw [h_u (n+1) (by simp)]
      · rw [h_s]
      · rw [h_s]

