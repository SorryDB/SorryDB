    F ⟨Sum.inl (n + 1), by simp [S]⟩
  let fY (F : (x : T) → (fun i ↦ Sum.elim (fun _ ↦ I) (fun _ ↦ ℕ → α → R) i) x) : α × R :=
    let ω' : probSpace α R := (fun k ↦ if h : k ≤ n then
        F ⟨Sum.inl k, by left; exact ⟨k, h, rfl⟩⟩
      else 0,
      F ⟨Sum.inr (), by right; rfl⟩)
    hist alg ω' n
  refine h_indep.comp ?_ ?_ |>.congr_right ?_
  · exact Measurable.eval ⟨Sum.inl (n + 1), by simp [S]⟩
  · have h_rec : Measurable (fun F : (x : T) → (fun i ↦ Sum.elim (fun _ ↦ I) (fun _ ↦ ℕ → α → R) i) x ↦
