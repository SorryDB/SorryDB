  let T : Set (Sum ℕ Unit) := Sum.inl '' {i | i ≤ n} ∪ {Sum.inr ()}
  have h_indep := (iIndepFun.prod (iIndepFun_infinitePi (fun _ ↦ measurable_id))
    (iIndepFun_singleton (fun _ ↦ id) (Bandit.streamMeasure ν))).indepFun_prod
      (S := S) (T := T) ?_ (by fun_prop) (by fun_prop)
