    exact (measurable_hist alg n).comp (this.prodMk measurable_const)
  rw [h_factor]
  have h_indep_proj : IndepFun f1 proj μ1 := by
    have h_disj : Disjoint ({n + 1} : Finset ℕ) (Finset.range (n + 1)) := by
