lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let π (ω : probSpace α R) : (Iic n → I) × (ℕ → α → R) := (fun i ↦ ω.1 i, ω.2)
  let extend (u : Iic n → I) (k : ℕ) : I := if h : k ≤ n then u ⟨k, h⟩ else 0
  let F (p : (Iic n → I) × (ℕ → α → R)) : Iic n → α × R :=
    hist alg (extend p.1, p.2) n
  have h_meas_F : Measurable F := by
    have h_meas_extend : Measurable (fun p : (Iic n → I) × (ℕ → α → R) ↦ (extend p.1, p.2)) :=
      Measurable.prodMk (Measurable.pi fun i ↦ (measurable_pi_apply ⟨i, i.2⟩).comp measurable_fst)
        measurable_snd
    exact (measurable_hist alg n).comp h_meas_extend
  have h_eq : hist alg · n = F ∘ π := by
    ext ω
    dsimp [F, extend, π]
    refine hist_eq_of_agree (fun k hk ↦ ?_) rfl
    simp [hk]
  rw [h_eq]
  refine IndepFun.comp ?_ measurable_id h_meas_F
  let μ₁ := Measure.infinitePi (fun _ : ℕ ↦ (volume : Measure I))
  have h_indep₁ : IndepFun (fun u ↦ u (n + 1)) (fun u i ↦ u i) μ₁ :=
    iIndepFun_infinitePi.indepFun_prod_mk (fun _ ↦ by fun_prop) (by simp) (by fun_prop)
      (fun i hi ↦ by simp at hi; linarith)
  have h_indep₂ : IndepFun (fun ω ↦ ω.1 (n + 1)) (fun ω ↦ fun i : Iic n ↦ ω.1 i) (arrayMeasure ν) :=
    h_indep₁.comp_fst (Bandit.streamMeasure ν)
  have h_indep_pair : IndepFun (fun ω ↦ (ω.1 (n + 1), fun i : Iic n ↦ ω.1 i)) (fun ω ↦ ω.2)
      (arrayMeasure ν) :=
    indepFun_fst_snd.comp (measurable_fst.prodMk (Measurable.pi (fun _ ↦ measurable_pi_apply _)))
      measurable_id
  exact IndepFun_prod_mk h_indep₂ h_indep_pair
