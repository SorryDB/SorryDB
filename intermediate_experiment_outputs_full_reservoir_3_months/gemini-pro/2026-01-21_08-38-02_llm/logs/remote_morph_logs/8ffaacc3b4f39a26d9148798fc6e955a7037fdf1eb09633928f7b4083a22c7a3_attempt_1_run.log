lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let P_n (u : ℕ → I) : ℕ → I := fun k ↦ if k ≤ n then u k else 0
  have h_hist_eq : ∀ ω, hist alg ω n = hist alg (P_n ω.1, ω.2) n := by
    intro ω
    rw [hist_eq, hist_eq _ (P_n ω.1, ω.2)]
    congr with i
    simp only [P_n]
    have : i.1 ≤ n := i.2
    simp [this]
  have h_indep_v : ∀ v, IndepFun (fun u ↦ u (n + 1)) (fun u ↦ hist alg (P_n u, v) n)
      (Measure.infinitePi fun _ ↦ volume) := by
    intro v
    apply IndepFun.comp (g := fun u ↦ hist alg (u, v) n)
    apply iIndepFun.indepFun_finset (iIndepFun_infinitePi (fun _ ↦ volume) (fun _ ↦ by fun_prop))
    · rw [Finset.disjoint_singleton_right, Finset.mem_Iic]
      omega
    · fun_prop
    · fun_prop
  rw [indepFun_iff_measure_inter_preimage_eq_mul (by fun_prop) (measurable_hist alg n)]
  intros s t hs ht
  rw [arrayMeasure, Measure.prod_apply hs (measurableSet_preimage ht (measurable_hist alg n))]
  simp_rw [h_hist_eq (by assumption), Set.preimage_inter, Set.mem_inter_iff, Set.mem_preimage]
  congr 1
  refine lintegral_congr (fun v ↦ ?_)
  specialize h_indep_v v
  rw [indepFun_iff_measure_inter_preimage_eq_mul (by fun_prop) (by fun_prop)] at h_indep_v
  convert h_indep_v s t hs ht using 2
  all_goals { apply Measure.congr_arg; ext u; rfl }
