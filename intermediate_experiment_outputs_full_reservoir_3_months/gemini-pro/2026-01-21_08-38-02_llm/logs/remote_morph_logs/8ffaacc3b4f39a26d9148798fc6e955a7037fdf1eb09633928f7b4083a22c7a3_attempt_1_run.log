lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let f := fun ω ↦ ω.1 (n + 1)
  let g := fun ω : (ℕ → I) × (ℕ → α → R) ↦ (Function.update ω.1 (n + 1) 0, ω.2)
  have h_indep : IndepFun f g (arrayMeasure ν) := by
    let μ1 := Measure.infinitePi (fun _ : ℕ ↦ (volume : Measure I))
    let X := fun (u : ℕ → I) ↦ u (n + 1)
