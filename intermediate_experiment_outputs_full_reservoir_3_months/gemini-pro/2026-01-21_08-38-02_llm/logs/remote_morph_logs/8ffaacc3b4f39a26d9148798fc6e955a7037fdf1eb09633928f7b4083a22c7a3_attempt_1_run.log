lemma indepFun_fst_add_one_hist (alg : Algorithm α R) (ν : Kernel α R) [IsMarkovKernel ν] (n : ℕ) :
    IndepFun (fun ω ↦ ω.1 (n + 1)) (hist alg · n) (arrayMeasure ν) := by
  let f : (ℕ → I) → (ℕ → I) := fun u m ↦ if m ≤ n then u m else 0
  have hf : Measurable f := measurable_pi_iff.mpr fun i ↦ by
    by_cases hi : i ≤ n <;> simp [hi, f]
    · exact measurable_pi_apply i
    · exact measurable_const
  have h_eq : ∀ ω, hist alg ω n = hist alg (f ω.1, ω.2) n := by
    intro ω
    let ω' := (f ω.1, ω.2)
    have : ∀ k ≤ n, hist alg ω k = hist alg ω' k := by
      intro k hk
      induction k with
      | zero =>
        simp only [hist_zero]
        congr 2
        simp [f, ω']
      | succ k ih =>
        rw [hist_add_one, hist_add_one]
        have hk' : k ≤ n := Nat.le_of_succ_le hk
        specialize ih hk'
        rw [ih]
        congr 1
        simp only [pullCount', eq_rec_constant]
        congr 1
        dsimp
        congr 1
