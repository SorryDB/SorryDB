  split_ifs with h;
  . tauto;
  . exfalso;
    push_neg at h;
    obtain ⟨Γ, hΓ, h₁⟩ := h;
    have h₂ : Γ.conj ➝ (Γ.conj ⋏ φ) ∈ T.theory := by
