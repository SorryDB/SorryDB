lemma matchingMatroid.seriesPair_of_adj (h_in : ∀ x, G.inessential x) (hadj : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  set M := G.matchingMatroid
  have hne : x ≠ y := by
    rintro rfl
    obtain ⟨e, he⟩ := hadj
    obtain ⟨M, hM, hMx⟩ := h_in x
    have hM' : G.IsMatching (insert e M) := by
      refine ⟨insert_subset_iff.mpr ⟨he.mem_edge, hM.subset⟩, ?_⟩
      simp only [mem_insert_iff, forall_eq_or_imp]
      refine ⟨fun f hf hne ↦ ?_, fun f hf g hg ↦ hM.disjoint hf hg⟩
      rw [he.incident.1.mem_vertices_iff]
      exact disjoint_singleton_left.mpr (not_mem_of_mem_notMem_vertex hf hMx)
    exact (hM.max _ hM').not_lt <| encard_lt_encard_insert_of_not_mem (fun h ↦ hMx <| mem_vertex_of_mem_edge h he.mem_edge) hM.subset.encard_lt_top

  rw [Matroid.Series, Matroid.series_iff_circuit_dual, Matroid.circuit_iff_forall_ssubset]
  refine ⟨?_, ?_⟩
  · rw [M.dual_dep_iff_rank]
    by_contra h_eq
    obtain ⟨B, hB, hBsub⟩ := M.exists_basis (V(G) \ {x, y})
    rw [h_eq, M.cast_r_eq_r] at hB
    obtain ⟨m, hm, hsub⟩ := hB.indep
    have hBm : B = V(G, m) := hB.eq_of_subset_indep (M.indep_iff.2 ⟨m, hm, rfl.subset⟩) hsub
    subst hBm
    obtain ⟨e, he⟩ := hadj
    have h_aug : G.IsMatching (insert e m) := by
      refine ⟨insert_subset_iff.mpr ⟨he.mem_edge, hm.subset⟩, ?_⟩
      simp only [mem_insert_iff, forall_eq_or_imp]
      refine ⟨fun f hf hne ↦ ?_, fun f hf g hg ↦ hm.disjoint hf hg⟩
      rw [he.incident.1.mem_vertices_iff, he.incident.2.mem_vertices_iff hne]
      refine Disjoint.symm <| disjoint_insert_right.mpr ⟨?_, ?_⟩ 
      · exact fun h ↦ (hBsub hf).2 (mem_insert_iff.mpr <| Or.inl <| mem_vertex_left_of_mem_edge h hf)
      · exact fun h ↦ (hBsub hf).2 (mem_insert_iff.mpr <| Or.inr <| mem_vertex_right_of_mem_edge h hf)
    exact (hm.max _ h_aug).not_lt <| encard_lt_encard_insert_of_not_mem (fun h ↦ (hBsub h).2 (mem_insert_iff.mpr <| Or.inl <| mem_vertex_left_of_mem_edge h he.mem_edge)) hm.subset.encard_lt_top
  
  · intro I hI
    rw [M.dual_indep_iff_rank]
    have hsub : I ⊆ {x, y} := hI.subset
    obtain rfl | rfl | rfl | rfl := subset_pair_iff.mp hsub
    · simp
    · rw [diff_singleton_eq_compl]
      apply M.not_coloop_iff_rank_compl_eq.mp
      apply matchingMatroid.noColoop h_in hadj.mem_vertices.1
    · rw [diff_singleton_eq_compl]
      apply M.not_coloop_iff_rank_compl_eq.mp
      apply matchingMatroid.noColoop h_in hadj.mem_vertices.2
    · exact (hI.ne rfl).elim
