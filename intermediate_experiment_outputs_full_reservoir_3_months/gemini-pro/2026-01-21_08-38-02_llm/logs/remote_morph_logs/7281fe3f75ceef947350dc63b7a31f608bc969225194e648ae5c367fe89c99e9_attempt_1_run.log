      · exact he_disj.symm.disjoint_of_subset_left (G.subset_vertex_of_edge hf)
      · exact hM.disjoint hf hg hne⟩
    have h_indep : G.matchingMatroid.Indep (B ∪ {x, y}) := by
      refine ⟨M', hM', ?_⟩
