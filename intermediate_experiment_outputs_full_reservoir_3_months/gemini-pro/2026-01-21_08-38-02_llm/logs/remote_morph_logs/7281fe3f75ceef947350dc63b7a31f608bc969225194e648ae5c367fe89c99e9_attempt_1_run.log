lemma matchingMatroid.seriesPair_of_adj (h_iness : ∀ x, G.inessential x) (hadj : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  have hne : x ≠ y := hadj.ne
  rw [Matroid.series_iff_dual_parallel, Matroid.parallel_iff_circuit hne]
  refine ⟨?_, ?_, ?_⟩
  · rw [Matroid.dual_indep_iff_coindep]
    exact matchingMatroid.noColoop h_iness hadj.mem_V_left
  · rw [Matroid.dual_indep_iff_coindep]
    exact matchingMatroid.noColoop h_iness hadj.mem_V_right
  rw [Matroid.dual_dep_iff_rk]
  intro h_ind
  have hrk : G.matchingMatroid.eRk (V(G) \ {x, y}) = G.matchingMatroid.eRank := by
    rwa [Matroid.eRk_compl_eq_iff_dual_indep]
  obtain ⟨B, hB, hBsub⟩ := G.matchingMatroid.exists_base_subset_of_eRk_eq hrk
  obtain ⟨M, hM, hBM⟩ := hB.indep
  have hM_eq : V(G, M) = B := hB.eq_of_subset_indep ⟨M, hM, rfl.subset⟩ hBM
  obtain ⟨e, he⟩ := hadj
  have hM' : G.IsMatching (insert e M) := by
    refine ⟨insert_subset he.mem_edge hM.subset, ?_⟩
    simp only [mem_insert_iff, forall_eq_or_imp, forall_and]
    refine ⟨fun f hf _ ↦ ?_, fun f hf _ ↦ ?_, hM.disjoint⟩
    · rw [he.V_eq, Disjoint.comm, ← hM_eq]
      exact disjoint_sdiff_left.mono_left hBsub |>.mono_right (hM.disjoint_of_mem hf)
    · rw [he.V_eq, ← hM_eq]
      exact disjoint_sdiff_left.mono_left hBsub |>.mono_right (hM.disjoint_of_mem hf)
  have hlt : B.encard < V(G, insert e M).encard := by
    rw [← hM_eq, V_insert, encard_union_eq, he.V_eq, encard_pair hne]
    · exact (encard_lt_add_of_encard_pos (by simp)).mpr (by simp)
    rw [he.V_eq, ← hM_eq]
    exact disjoint_sdiff_left.mono_left hBsub
  exact hB.le_encard ⟨_, hM', rfl.subset⟩ |>.not_lt hlt
