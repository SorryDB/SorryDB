lemma matchingMatroid.seriesPair_of_adj (h : ∀ x, G.inessential x) (hxy : G.Adj x y) :
    G.matchingMatroid.Series x y := by
  have hne : x ≠ y := by
    rintro rfl
    obtain ⟨M, hM, hMx⟩ := h x
    obtain ⟨e, he⟩ := hxy.exists_edge
    have hM' : G.IsMatching (insert e M) := by
      refine ⟨insert_subset he.mem_edge hM.subset, fun f g hf hg hfg ↦ ?_⟩
      obtain rfl | hf := eq_or_mem_of_mem_insert hf <;> obtain rfl | hg := eq_or_mem_of_mem_insert hg
      · contradiction
      · rw [he.mem_vertex_iff]; rintro z (rfl | rfl) <;> exact hMx (by rw [← he.source, ← he.target]; exact ⟨_, hg, rfl⟩)
      · rw [he.mem_vertex_iff]; rintro z (rfl | rfl) <;> exact hMx (by rw [← he.source, ← he.target]; exact ⟨_, hf, rfl⟩)
      · exact hM.disjoint hf hg hfg
    exact (hM.max _ hM').not_lt (encard_lt_encard_add_one hM.encard_finite)
  rw [Matroid.series_iff_dual_circuit hne, Matroid.dual_isCircuit_iff_coindep_forall_mem]
  refine ⟨?_, fun z hz ↦ ?_⟩
  · intro hsp
    obtain ⟨B, hB, hBs⟩ := hsp.exists_base_subset
    obtain ⟨M, hM, hMsub⟩ := hB.indep
    have hMeq : V(G, M) = B := hB.eq_of_subset_indep (G.matchingMatroid.indep_iff.2 ⟨M, hM, rfl.subset⟩) hMsub
    obtain ⟨e, he⟩ := hxy.exists_edge
    have hMx : x ∉ V(G, M) := not_mem_subset (hMeq.symm.trans_subset hBs) (by simp [hne])
    have hMy : y ∉ V(G, M) := not_mem_subset (hMeq.symm.trans_subset hBs) (by simp [hne])
    have hM' : G.IsMatching (insert e M) := by
      refine ⟨insert_subset he.mem_edge hM.subset, fun f g hf hg hfg ↦ ?_⟩
      obtain rfl | hf := eq_or_mem_of_mem_insert hf <;> obtain rfl | hg := eq_or_mem_of_mem_insert hg
      · contradiction
      · exact (hM.disjoint (fun h ↦ (he.mem_vertex_iff.mp h).elim (fun h ↦ h ▸ hMx) (fun h ↦ h ▸ hMy)) hg hfg.symm).symm
      · exact hM.disjoint (fun h ↦ (he.mem_vertex_iff.mp h).elim (fun h ↦ h ▸ hMx) (fun h ↦ h ▸ hMy)) hf hfg
      · exact hM.disjoint hf hg hfg
    have hle := hM.isMaxMatching_of_vertex_subset (hMsub.trans hMeq.ge) |>.max _ hM'
    rw [encard_insert_of_not_mem (by simpa [he.source, he.target] using hMx)] at hle
    exact hle.not_lt (encard_lt_encard_add_one hM.encard_finite)
  · simp only [mem_insert_iff, mem_singleton_iff] at hz
    have hnc : ¬ G.matchingMatroid.IsColoop z :=
      matchingMatroid.noColoop h (hz.elim (fun h ↦ h ▸ hxy.mem_vertex_left) (fun h ↦ h ▸ hxy.mem_vertex_right))
    rwa [Matroid.isColoop_iff_not_spanning_diff] at hnc
