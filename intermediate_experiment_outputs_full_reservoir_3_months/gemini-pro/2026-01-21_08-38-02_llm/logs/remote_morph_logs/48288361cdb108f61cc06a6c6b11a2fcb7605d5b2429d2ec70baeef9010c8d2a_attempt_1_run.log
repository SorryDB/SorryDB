```lean
instance {F E D : Type*}
    [Field F]
    [Field E] [Algebra F E]
    [Ring D] [Algebra F D] [IsQuaternionAlgebra F D] :
    IsQuaternionAlgebra E (E ⊗[F] D) := by
  obtain ⟨a, b, i, j, hi, hj, hij, hlin, hspan⟩ := IsQuaternionAlgebra.exists_basis F D
  let bD := Basis.mk hlin (by rw [hspan]; exact le_top)
  let bE := bD.baseChange E
  refine ⟨algebraMap F E a, algebraMap F E b, 1 ⊗ₜ i, 1 ⊗ₜ j, ?_, ?_, ?_, ?_, ?_⟩
  · simp only [pow_two, Algebra.TensorProduct.tmul_mul_tmul, hi, Algebra.TensorProduct.algebraMap_apply]
    rfl
  · simp only [pow_two, Algebra.TensorProduct.tmul_mul_tmul, hj, Algebra.TensorProduct.algebraMap_apply]
    rfl
  · simp only [Algebra.TensorProduct.tmul_mul_tmul, hij, Algebra.TensorProduct.tmul_neg]
    rfl
  · convert bE.linearIndependent
    ext k; fin_cases k <;> simp [bE, bD, Basis.mk_apply, Algebra.TensorProduct.tmul_mul_tmul]
  · rw [← bE.span_eq, eq_comm]
    congr; ext k; fin_cases k <;> simp [bE, bD, Basis.mk_apply, Algebra.TensorProduct.tmul_mul_tmul]
```
