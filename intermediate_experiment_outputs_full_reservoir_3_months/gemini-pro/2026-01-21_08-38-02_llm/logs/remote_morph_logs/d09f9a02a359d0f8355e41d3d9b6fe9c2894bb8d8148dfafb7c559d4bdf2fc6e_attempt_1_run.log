problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  -- Assume the contrary: all angles are > 30°
  by_contra h
  push_neg at h
  rcases h with ⟨hα, hβ, hγ⟩

  -- Define the partial angles at vertices
  let α := ∠ P A B; let β := ∠ P B C; let γ := ∠ P C A
  let α' := ∠ P A C; let β' := ∠ P B A; let γ' := ∠ P C B

  -- 1. Establish that the sum of the partial angles corresponds to the triangle angles
  -- Use barycentric coordinates to show P-A is a positive combination of B-A and C-A, etc.
  rw [Affine.Simplex.mem_interior_iff_exists_pos_sum_eq_one_of_affineIndependent hABC] at hP
  rcases hP with ⟨u, v, w, hu, hv, hw, huvw, hP_eq⟩

  have hA : α + α' = ∠ C A B := by
    rw [← EuclideanGeometry.angle_comm C A B]
    have : P - A = v • (B - A) + w • (C - A) := by
      rw [hP_eq, ← huvw, add_smul, add_smul, one_smul]; abel
    exact InnerProductGeometry.angle_add_eq_angle_of_pos_add_pos this hv hw

  have hB : β + β' = ∠ A B C := by
    rw [← EuclideanGeometry.angle_comm A B C]
    have : P - B = w • (C - B) + u • (A - B) := by
      rw [hP_eq, ← huvw, add_smul, add_smul, one_smul]; abel
    exact InnerProductGeometry.angle_add_eq_angle_of_pos_add_pos this hw hu

  have hC : γ + γ' = ∠ B C A := by
    rw [← EuclideanGeometry.angle_comm B C A]
    have : P - C = u • (A - C) + v • (B - C) := by
      rw [hP_eq, ← huvw, add_smul, add_smul, one_smul]; abel
    exact InnerProductGeometry.angle_add_eq_angle_of_pos_add_pos this hu hv

  -- 2. Sum of all partial angles is π
  have h_sum : (α + β + γ) + (α' + β' + γ') = π := by
    rw [add_assoc, add_comm γ, add_assoc (α+β), ← add_assoc β, add_comm β, add_assoc α,
        hA, hB, hC, EuclideanGeometry.angle_sum_eq_pi_of_affineIndependent hABC]

  -- 3. Sine Identity: sin α sin β sin γ = sin α' sin β' sin γ'
  -- Derived from Sine Rule on triangles PAB, PBC, PCA
  have h_sine_id : Real.sin α * Real.sin β * Real.sin γ = Real.sin α' * Real.sin β' * Real.sin γ' := by
    have s1 : Real.sin α * dist P A = Real.sin β' * dist P B := by
      rw [mul_comm, mul_comm (Real.sin β')]
      exact EuclideanGeometry.sin_mul_dist_eq_sin_mul_dist (P) (A) (B)
    have s2 : Real.sin β * dist P B = Real.sin γ' * dist P C := by
      rw [mul_comm, mul_comm (Real.sin γ')]
      exact EuclideanGeometry.sin_mul_dist_eq_sin_mul_dist (P) (B) (C)
    have s3 : Real.sin γ * dist P C = Real.sin α' * dist P A := by
      rw [mul_comm, mul_comm (Real.sin α')]
      exact EuclideanGeometry.sin_mul_dist_eq_sin_mul_dist (P) (C) (A)
    -- Multiply equations and cancel positive distances
    have dp_pos : 0 < dist P A ∧ 0 < dist P B ∧ 0 < dist P C := by
      simp only [dist_pos, ne_eq];
      exact ⟨ne_of_mem_of_not_mem_interior_convexHull hP hABC.1,
             ne_of_mem_of_not_mem_interior_convexHull hP hABC.2,
             ne_of_mem_of_not_mem_interior_convexHull hP hABC.3⟩
    nlinarith [s1, s2, s3, dp_pos.1, dp_pos.2.1, dp_pos.2.2]

  -- 4. Contradiction via inequalities
  -- Since α, β, γ > 30°, sum > 90°, so sum of primes < 90°.
  -- Max product of sines for sum < 90° is < 1/8.
  -- But product of sines for angles > 30° (and < 150°) is > 1/8.

  -- Bounds on α, β, γ
  have h_lt_150 : α < 5 * π / 6 ∧ β < 5 * π / 6 ∧ γ < 5 * π / 6 := by
    -- If α ≥ 150°, then A ≥ 150°, B+C ≤ 30°, so β < 30°, contradiction.
    have sum_pos : 0 < ∠ A B C + ∠ B C A := by
      rw [← EuclideanGeometry.angle_sum_eq_pi_of_affineIndependent hABC, add_comm]
      exact lt_sub_iff_add_lt.mp (EuclideanGeometry.angle_pos_of_affineIndependent hABC.1)
    repeat' apply And.intro
    · by_contra h_ge; linarith [hB, hC, h_sum, hα, hβ, hγ, h_ge]
    · by_contra h_ge; linarith [hA, hC, h_sum, hα, hβ, hγ, h_ge]
    · by_contra h_ge; linarith [hA, hB, h_sum, hα, hβ, hγ, h_ge]

  have lhs_gt : Real.sin α * Real.sin β * Real.sin γ > (1/2)^3 := by
    have s_gt (x : ℝ) (hx1 : π/6 < x) (hx2 : x < 5*π/6) : Real.sin x > 1/2 :=
      Real.sin_gt_half_of_pi_div_six_lt_of_lt_five_pi_div_six hx1 hx2
    have sa : Real.sin α > 1/2 := s_gt α hα h_lt_150.1
    have sb : Real.sin β > 1/2 := s_gt β hβ h_lt_150.2.1
    have sc : Real.sin γ > 1/2 := s_gt γ hγ h_lt_150.2.2
    nlinarith

  have rhs_le : Real.sin α' * Real.sin β' * Real.sin γ' < (1/2)^3 := by
    let S' := α' + β' + γ'
    have hS' : S' < π / 2 := by
      have : α + β + γ > π / 2 := by linarith [hα, hβ, hγ]
      linarith [h_sum]
    have h_pos : 0 < α' ∧ 0 < β' ∧ 0 < γ' := by
      -- P interior implies angles are positive
      exact ⟨EuclideanGeometry.angle_pos_of_interior_of_convexHull hP hABC.1,
             EuclideanGeometry.angle_pos_of_interior_of_convexHull hP hABC.2,
             EuclideanGeometry.angle_pos_of_interior_of_convexHull hP hABC.3⟩
    -- Jensen's inequality or AM-GM on log-sin
    have : Real.sin α' * Real.sin β' * Real.sin γ' ≤ Real.sin (S' / 3) ^ 3 :=
       Real.sin_mul_sin_mul_sin_le_sin_cube_div_three h_pos.1 h_pos.2.1 h_pos.2.2 (by linarith)
    have : Real.sin (S' / 3) < 1/2 := by
      apply Real.sin_lt_sin_of_lt_of_le (by linarith) (by linarith)
      linarith
    nlinarith

  rw [← h_sine_id] at rhs_le
  linarith
