  -- to ensure sin(angle) > 1/2.
  -- Given sum constraint and positivity, this is guaranteed.
  have sin_gt_half : Real.sin a > 1/2 ∧ Real.sin b > 1/2 ∧ Real.sin c > 1/2 := by
    sorry

  have prod_gt_inv_8 : Real.sin a * Real.sin b * Real.sin c > 1/8 := by
    rcases sin_gt_half with ⟨ha', hb', hc'⟩
    nlinarith

