  have prod_le_max : Real.sin a' * Real.sin b' * Real.sin c' ≤ Real.sin ((a' + b' + c') / 3) ^ 3 := by
    sorry

  -- Since sum < π/2, average < π/6
  have avg_lt_pi_6 : (a' + b' + c') / 3 < π / 6 := by
    linarith [sum_primes_lt_half_pi]

  -- Sine is increasing on (0, π/2)
  have sin_avg_lt_half : Real.sin ((a' + b' + c') / 3) < 1/2 := by
    rw [← Real.sin_pi_div_six]
    apply Real.sin_lt_sin_of_lt_of_le
