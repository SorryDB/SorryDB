    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra h
  push_neg at h
  rcases h with ⟨h1, h2, h3⟩
  let α := ∠ P A B; let β := ∠ P B C; let γ := ∠ P C A
  let A := ∠ C A B; let B := ∠ A B C; let C := ∠ B C A
  -- The geometric identity for an interior point P (trigonometric Ceva)
  have geom_id : Real.sin (A - α) * Real.sin (B - β) * Real.sin (C - γ) = Real.sin α * Real.sin β * Real.sin γ := sorry
  -- Inequality for sine ratio
  have ineq (θ φ : ℝ) (hφ : π / 6 < φ) : Real.sin (θ - φ) < 2 * Real.sin (θ - π / 6) * Real.sin φ := by
    rw [Real.sin_sub, Real.sin_sub, Real.cos_pi_div_six, Real.sin_pi_div_six]
    have : Real.cot φ < Real.sqrt 3 := by
      rw [← Real.cot_pi_div_six]; apply Real.cot_lt_cot_of_lt_of_lt_pi_div_two <;> try linarith [Real.pi_pos]
      sorry -- bounds on φ
    have : 0 < Real.sin φ := sorry -- φ is an angle in triangle
    rw [← mul_lt_mul_right this]
    rw [div_sub_distrib, Real.cos_div_sin, ← Real.cot_eq_cos_div_sin] at this
    field_simp; nlinarith
  -- Contradiction
  have prod_lt : 1 < 8 * Real.sin (A - π / 6) * Real.sin (B - π / 6) * Real.sin (C - π / 6) := by
    have i1 := ineq A α h1; have i2 := ineq B β h2; have i3 := ineq C γ h3
    nlinarith [geom_id, i1, i2, i3] -- requires sines positive
  have jensen : Real.sin (A - π / 6) * Real.sin (B - π / 6) * Real.sin (C - π / 6) ≤ 1 / 8 := by
    -- Max of product sin x with sum x = pi/2
    sorry
  nlinarith
