    calc Real.sin a' * Real.sin b' * Real.sin c'
      _ ≤ Real.sin ((a' + b' + c') / 3) ^ 3 := prod_le_max
      _ < (1/2) ^ 3 := by gcongr; exact sin_avg_lt_half
      _ = 1/8 := by norm_num

  -- Contradiction: 1/8 < prod sines = prod sines' < 1/8
  rw [sine_identity] at prod_gt_inv_8
  linarith
