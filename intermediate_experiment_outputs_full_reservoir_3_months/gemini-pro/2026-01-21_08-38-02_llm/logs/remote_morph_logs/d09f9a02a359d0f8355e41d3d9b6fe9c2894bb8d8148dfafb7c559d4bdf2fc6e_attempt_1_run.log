problem imo1991_p5
    (A B C P : EuclideanSpace ℝ (Fin 2))
    (hABC : AffineIndependent ℝ ![A, B, C])
    (hP : P ∈ interior (convexHull ℝ {A, B, C})) :
    ∠ P A B ≤ π / 6 ∨ ∠ P B C ≤ π / 6 ∨ ∠ P C A ≤ π / 6 := by
  by_contra h
  simp only [not_le, not_or] at h
  rcases h with ⟨h₁, h₂, h₃⟩
  -- Extract barycentric coordinates to prove angle additivity
  rw [mem_interior_convexHull_iff_exists_pos_sum_eq_one_of_affineIndependent hABC] at hP
  rcases hP with ⟨w, hw_pos, hw_sum, rfl⟩
  let u := w 0; let v := w 1; let t := w 2
  have hu : 0 < u := hw_pos 0
  have hv : 0 < v := hw_pos 1
  have ht : 0 < t := hw_pos 2
  
  -- Define angles
  let α := ∠ P A B; let β := ∠ P B C; let γ := ∠ P C A
  let α' := ∠ P A C; let β' := ∠ P B A; let γ' := ∠ P C B
  
  -- Prove α + α' = A, etc.
  have h_add_A : α + α' = ∠ C A B := by
    have : (u • A + v • B + t • C) - A = v • (B - A) + t • (C - A) := by
      rw [← hw_sum]; simp [Fin.sum_univ_succ]; abel_nf; simp [add_smul]; abel
    rw [this]
    refine InnerProductGeometry.angle_add_angle_eq_angle_of_pos_add_pos ?_ ?_ hv ht
    rw [linearIndependent_iff'] at *; intros; apply (affineIndependent_iff_linearIndependent_sub A ![A, B, C]).mp hABC; simp [Fin.forall_iff]
  
