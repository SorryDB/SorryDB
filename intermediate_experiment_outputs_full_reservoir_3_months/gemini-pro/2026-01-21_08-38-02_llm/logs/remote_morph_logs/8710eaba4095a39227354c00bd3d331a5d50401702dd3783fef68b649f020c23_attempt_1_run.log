```lean
theorem imo_1972_p4 :
    {(x₁, x₂, x₃, x₄, x₅,) : ℝ × ℝ × ℝ × ℝ × ℝ |
        (0 < x₁ ∧ 0 < x₂ ∧ 0 < x₃ ∧ 0 < x₄ ∧ 0 < x₅) ∧
        ((x₁ ^ 2 - x₃ * x₅) * (x₂ ^ 2 - x₃ * x₅) ≤ 0) ∧
        ((x₂ ^ 2 - x₄ * x₁) * (x₃ ^ 2 - x₄ * x₁) ≤ 0) ∧
        ((x₃ ^ 2 - x₅ * x₂) * (x₄ ^ 2 - x₅ * x₂) ≤ 0) ∧
        ((x₄ ^ 2 - x₁ * x₃) * (x₅ ^ 2 - x₁ * x₃) ≤ 0) ∧
        ((x₅ ^ 2 - x₂ * x₄) * (x₁ ^ 2 - x₂ * x₄) ≤ 0)} =
      answer({(x, x, x, x, x) | (x : ℝ)}) := by
  -- Reduce the set equality to identifying the elements
  rw [answer]; Set.ext; intro x; simp
  constructor
  -- Forward direction: if all equal, conditions hold
  . rintro ⟨x, rfl⟩
    use x; simp; repeat constructor
    . assumption
    . linarith
  -- Reverse direction: use maximum principle
  . rintro ⟨h_pos, h1, h2, h3, h4, h5⟩
    rcases x with ⟨x₁, x₂, x₃, x₄, x₅⟩
    obtain ⟨h₁, h₂, h₃, h₄, h₅⟩ := h_pos
    -- Use cyclic symmetry to assume x₁ is maximal
    wlog h_max : x₁ ≥ x₂ ∧ x₁ ≥ x₃ ∧ x₁ ≥ x₄ ∧ x₁ ≥ x₅
      using x₁ x₂ x₃ x₄ x₅, x₂ x₃ x₄ x₅ x₁, x₃ x₄ x₅ x₁ x₂, x₄ x₅ x₁ x₂ x₃, x₅ x₁ x₂ x₃ x₄
    -- Let m be the minimum
    let m := min x₁ (min x₂ (min x₃ (min x₄ x₅)))
    have hm : m = x₁ ∨ m = x₂ ∨ m = x₃ ∨ m = x₄ ∨ m = x₅ := by
      simp [m, min_eq_iff]; tauto
    
    -- Helper lemma: Maximum x₁ and Minimum x₃ (dist 2) implies equal
    have lemma_dist2 : ∀ a b c d e : ℝ, 0 < a ∧ 0 < b ∧ 0 < c ∧ 0 < d ∧ 0 < e → 
        a ≥ b ∧ a ≥ c ∧ a ≥ d ∧ a ≥ e → c ≤ a ∧ c ≤ b ∧ c ≤ d ∧ c ≤ e →
        (a^2 - c*e)*(b^2 - c*e) ≤ 0 → (b^2 - d*a)*(c^2 - d*a) ≤ 0 → 
        (c^2 - e*b)*(d^2 - e*b) ≤ 0 → (e^2 - b*d)*(a^2 - b*d) ≤ 0 → a = c := by
      intro a b c d e pos hmax hmin ha hb hc he
      obtain ⟨pa, pb, pc, pd, pe⟩ := pos
      -- From ha: c*e is between a^2 and b^2. Since a is max, a^2 ≥ c*e. Thus b^2 ≤ c*e.
      have l1 : b^2 ≤ c * e := by
        cases le_total (a^2) (c*e) with
        | inl h => exact (mul_nonpos_iff.mp ha).1 h
        | inr h => exact (mul_nonpos_iff.mp ha).2 h
      -- From hb: d*a is between b^2 and c^2. Since c is min, d*a ≥ c^2.
      -- Also b^2 ≤ c*e ≤ a*a. And d*a ≤ b^2 is forced?
      -- Actually, b^2 ≤ c*e ≤ a*e. So b^2/e ≤ a.
      -- From hc: e*b is between c^2 and d^2. Since c is min, c^2 ≤ e*b ≤ d^2.
      have l2 : e * b ≤ d^2 := by
        cases le_total (c^2) (e*b) with
        | inl h => exact (mul_nonpos_iff.mp hc).2 h
        | inr h => exact (mul_nonpos_iff.mp hc).1 h
      -- From he: b*d is between e^2 and a^2. Since a is max, b*d ≤ a^2.
      -- Thus e^2 ≤ b*d.
      have l3 : e^2 ≤ b * d := by
        cases le_total (e^2) (b*d) with
        | inl h => exact (mul_nonpos_iff.mp he).1 h
        | inr h => exact (mul_nonpos_iff.mp he).2 h
      
      -- Combine inequalities
      -- e^2 ≤ b*d implies e/d ≤ b/e.
      -- e*b ≤ d^2 implies b/d ≤ d/e.
      -- From l1: b^2 ≤ c*e. Since c is min, c ≤ d, c ≤ e.
      -- We proved in thought block: e ≤ d implies e=d=min.
      -- e^3 = e * e^2 ≤ e * b * d ≤ d^2 * d = d^3 => e ≤ d.
      have h_ed : e ≤ d := by
        have : e^3 ≤ d^3 := by
          calc e^3 = e * e^2 := by ring
             _ ≤ e * (b * d) := mul_le_mul_of_nonneg_left l3 (le_of_lt pe)
             _ = (e * b) * d := by ring
             _ ≤ d^2 * d := mul_le_mul_of_nonneg_right l2 (le_of_lt pd)
             _ = d^3 := by ring
        exact (pow_le_pow_iff_left (le_of_lt pe) (le_of_lt pd) (by norm_num)).mp this
      
      -- Since c is min, c ≤ e ≤ d.
      -- From l1: b^2 ≤ c * e ≤ e * e = e^2. So b ≤ e.
      -- From l3: e^2 ≤ b * d. Since b ≤ e ≤ d, e^2 ≤ e * d implies e ≤ d (known).
      -- From hb: d*a is between b^2 and c^2. 
      -- Since b ≤ e ≤ d and c ≤ d, b^2 and c^2 are "small".
      -- Specifically d*a ≥ min(b^2, c^2).
      -- But a is max. If a > d, then d*a > d^2 ≥ e^2 ≥ b^2 and d*a > d^2 ≥ c^2.
      -- This would contradict d*a being between b^2 and c^2.
      -- Thus a ≤ d? No, d*a must be ≤ max(b^2, c^2).
      have : d * a ≤ max (b^2) (c^2) := by
        cases le_total (b^2) (d*a) with
        | inl h => exact (mul_nonpos_iff.mp hb).2 h
        | inr h => exact le_max_left _ _
      have : d * a ≤ d^2 := by
        apply le_trans this
        apply max_le
        · apply le_trans (pow_le_pow_left (le_of_lt pb) h_ed 2) (pow_le_pow_left (le_of_lt pe) h_ed 2) -- b ≤ e ≤ d
          rw [←pow_two]; apply le_trans; exact sqrt_le_sqrt l1; simp; exact h_ed
        · apply pow_le_pow_left (le_of_lt pc) (le_trans (hmin d (by simp)) h_ed) 2 -- c ≤ e ≤ d bad logic?
          -- c ≤ d is direct from hmin.
          exact pow_le_pow_left (le_of_lt pc) (hmin d (by simp)) 2
      -- d * a ≤ d^2 => a ≤ d. Since a is max, a = d.
      have ha_eq_d : a = d := le_antisymm (le_of_mul_le_mul_left this pd) (hmax d (by simp))
      rw [ha_eq_d] at *
      -- Now a = d. Since c ≤ a, we just need a ≤ c.
      -- d * a = a^2.
      -- hb becomes (b^2 - a^2)(c^2 - a^2) ≤ 0.
      -- Since b ≤ a and c ≤ a, both factors are ≤ 0.
      -- Product ≤ 0 implies one is 0. So b^2 = a^2 or c^2 = a^2.
      -- Since variables positive, b=a or c=a.
      cases eq_or_lt_of_le (hmin b (by simp)) with
      | inl h => rw [h]; exact rfl
      | inr h_lt => 
          -- if c < b, then c < a (since b ≤ a). Then c^2 < a^2.
          -- Then (c^2 - a^2) < 0. For product to be ≤ 0, (b^2 - a^2) ≥ 0 => b ≥ a.
          -- Thus b = a.
