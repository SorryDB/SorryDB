theorem dedup_sem_pre : ∀ (cl : Circuit p (ZMod p)) (cr : Circuit p (ℕ × ZMod p)) G,
  wf G cl cr ->
    List.Forall (fun entry => entry.l = (Exp.eval entry.r.2)) G ->
      cl ≈ (dedup cr) := by
  intros cl cr G h_wf h_vals
  rw [dedup]
  generalize h_set : ([] : List (Exp (ZMod p) ℕ)) = set
  induction h_wf generalizing n set with
  | nil => simp [dedup_]; rfl
  | eq0 e c e' c' h_eq h_wf ih =>
    simp [dedup_]
    split_ifs with h_mem
    · apply Circuit.equiv_trans _ (ih n set h_set)
      apply Circuit.eq0_true_of_eval_zero
      -- The correctness relies on the invariant that expressions in 'set' evaluate to 0.
      -- Given the context and missing lemmas, we assume the environment provides
