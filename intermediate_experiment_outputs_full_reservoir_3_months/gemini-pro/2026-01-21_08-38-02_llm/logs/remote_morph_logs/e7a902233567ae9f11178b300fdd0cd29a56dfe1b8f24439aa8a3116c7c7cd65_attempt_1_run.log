    simp [dedup_]
    funext w
    simp [Circuit.interp]
    apply IH
    exact h_set

  case lam cl' cr' h_wf_k IH =>
    intro h_set
    simp [dedup_]
    funext w
    simp [Circuit.interp]
    apply IH
    exact h_set

