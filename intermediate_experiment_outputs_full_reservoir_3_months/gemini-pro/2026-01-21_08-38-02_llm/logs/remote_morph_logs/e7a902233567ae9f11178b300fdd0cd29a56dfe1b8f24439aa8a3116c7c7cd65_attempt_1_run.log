      sorry
    · apply Circuit.equiv_eq0 h_eq
      apply ih (n + 1) _ rfl
  | lam k _ ih =>
    simp [dedup_]
    apply Circuit.lam_congr
    intro x
    apply ih x (n + 1) set h_set
  | share e k e' k' h_eq h_wf ih =>
    simp [dedup_]
    apply Circuit.share_congr h_eq
    intro x
    apply ih x (n + 1) set h_set
  | is_zero e k e' k' h_eq h_wf ih =>
    simp [dedup_]
    apply Circuit.is_zero_congr h_eq
    intro x
    apply ih x (n + 1) set h_set
  | assert_range w e k w' e' k' h_eq h_wf ih =>
    simp [dedup_]
    apply Circuit.assert_range_congr h_eq
    apply ih n ((to_nat e')::set) rfl
