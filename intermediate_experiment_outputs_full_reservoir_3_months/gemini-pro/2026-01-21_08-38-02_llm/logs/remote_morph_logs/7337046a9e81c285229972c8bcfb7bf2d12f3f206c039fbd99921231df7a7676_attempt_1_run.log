    have hS_eq_N : S = {N} := by
      have hS_sub_N : S ⊆ {N} := by
        intro s hs
        have hs_le : s ≤ N := le_trans (le_sSup hs) (hS_eq.trans_le h_le_N)
        have hs_in : s ∈ D := hS_sub hs
        by_contra h_diff
        rw [Set.mem_singleton_iff] at h_diff
        have h_disj : Disjoint s N := by
          have h_diff' : s ≠ N := h_diff
          have h_set : N ∈ (SetLike.coe D) \ {s} := ⟨hN, h_diff'.symm⟩
          exact Disjoint.mono_right (le_sSup h_set) (D.sSupIndep s hs_in)
        have h_s_bot : s = ⊥ := h_disj.eq_bot_of_le_left hs_le
        exact D.not_bot_mem (h_s_bot ▸ hs_in)
