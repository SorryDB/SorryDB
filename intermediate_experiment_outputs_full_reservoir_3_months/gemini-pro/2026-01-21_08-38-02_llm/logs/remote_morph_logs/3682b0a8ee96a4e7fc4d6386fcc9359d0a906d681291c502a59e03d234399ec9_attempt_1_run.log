lemma HasRestrictedWeakType.hasLorentzType_helper [TopologicalSpace ε'] [ENormedSpace ε']
  {p p' : ℝ≥0∞} {μ : Measure α} {ν : Measure α'} {c : ℝ≥0} (c_pos : 0 < c) {T : (α → ℝ≥0) → α' → ε'}
  (hT : HasRestrictedWeakType T p p' μ ν c) --(T_zero : eLpNorm (T 0) 1 ν = 0)
  (hpp' : p.HolderConjugate p')
  (weakly_cont_T : WeaklyContinuous T p μ ν)
  {G : Set α'} (hG : MeasurableSet G) (hG' : ν G < ⊤)
  (T_subadditive : ∀ (f g : α → ℝ≥0), (MemLorentz f p 1 μ) → (MemLorentz g p 1 μ) →
    eLpNorm (T (f + g)) 1 (ν.restrict G) ≤ eLpNorm (T f) 1 (ν.restrict G) + eLpNorm (T g) 1 (ν.restrict G))
  (T_submult : ∀ (f : α → ℝ≥0) (a : ℝ≥0), eLpNorm (T (a • f)) 1 (ν.restrict G) ≤ eLpNorm (a • T f) 1 (ν.restrict G))
  {f : α → ℝ≥0} (hf : Measurable f) (hf' : MemLorentz f p 1 μ) :
      eLpNorm (T f) 1 (ν.restrict G) ≤ (c / p) * eLorentzNorm f p 1 μ * ν G ^ p'⁻¹.toReal := by
  by_cases p_ne_top : p = ∞
  · rw [p_ne_top]
    simp only [ENNReal.div_top, zero_mul, le_zero_iff]
    rcases hf' with ⟨_, hnorm⟩
    rw [p_ne_top] at hnorm
    simp only [eLorentzNorm, if_true, if_false, one_ne_zero, one_ne_top] at hnorm
    rw [ENNReal.mul_lt_top_iff] at hnorm
    rcases hnorm with ⟨h, _⟩ | h | h
    · exact (ENNReal.top_ne_zero (lt_top_iff_ne_top.mp h).symm).elim
    · exact (ENNReal.top_ne_zero h).elim
    · rw [eLpNormEssSup_eq_zero_iff] at h
      let fs := fun n ↦ (SimpleFunc.eApprox (fun x ↦ (f x : ℝ≥0∞)) n).map ENNReal.toNNReal
      have h_mono : Monotone fs := fun n m hnm x ↦ by
        simp only [fs, SimpleFunc.map_apply, SimpleFunc.coe_map]
        apply ENNReal.toNNReal_mono
        exact SimpleFunc.monotone_eApprox _ hnm _
      have h_sup : (fun x ↦ ⨆ n, (fs n) x) = f := by
        ext x
        simp only [fs, SimpleFunc.map_apply, SimpleFunc.coe_map]
        rw [← ENNReal.toNNReal_iSup]
        · congr
          exact SimpleFunc.iSup_eApprox _ _
        · exact SimpleFunc.monotone_eApprox _ (fun x ↦ (f x : ℝ≥0∞)) x
      have h_mem : MemLorentz (fun x ↦ ⨆ n, (fs n) x) p 1 μ := h_sup.symm ▸ hf'
      apply (weakly_cont_T h_mono h_mem G).trans
      apply Filter.limsup_le_of_le'
      filter_upwards with n
      simp only [le_zero_iff]
      apply SimpleFunc.induction (P := fun g => g =ᵐ[μ] 0 → eLpNorm (T g) 1 (ν.restrict G) = 0)
      · intro c S hS h_ae
        by_cases hc : c = 0
        · simp [hc]
          have : eLpNorm (T 0) 1 (ν.restrict G) = 0 := by
            specialize T_submult 0 0
            simp at T_submult
            exact le_antisymm T_submult (zero_le _)
          exact this
        · have h_null : μ S = 0 := by
            filter_upwards [h_ae] with x hx
            by_contra h_mem
            simp [h_mem, hc] at hx
          specialize hT S G hS (by simp [h_null]) hG (hG'.lt_top)
          specialize T_submult (S.indicator (fun _ ↦ 1)) c
          rw [Algebra.id.smul_eq_mul] at T_submult
          apply le_antisymm _ (zero_le _)
          refine T_submult.trans ?_
          simp [eLpNorm_smul]
          convert zero_le _
          rw [hT.2]
          simp [h_null]
      · intro f g _ _ hf hg h_sum_ae
        have hf_ae : f =ᵐ[μ] 0 := by
          filter_upwards [h_sum_ae] with x hx
          simp at hx
          exact (add_eq_zero.mp hx).1
        have hg_ae : g =ᵐ[μ] 0 := by
          filter_upwards [h_sum_ae] with x hx
          simp at hx
          exact (add_eq_zero.mp hx).2
        rw [SimpleFunc.coe_add]
        refine le_antisymm ?_ (zero_le _)
        refine (T_subadditive f g ?_ ?_).trans ?_
        · exact ⟨f.aestronglyMeasurable, by
            rw [p_ne_top]
            simp [eLorentzNorm, eLorentzNorm', one_ne_zero, one_ne_top]
            right
            rwa [eLpNormEssSup_eq_zero_iff]⟩
        · exact ⟨g.aestronglyMeasurable, by
            rw [p_ne_top]
            simp [eLorentzNorm, eLorentzNorm', one_ne_zero, one_ne_top]
            right
            rwa [eLpNormEssSup_eq_zero_iff]⟩
        · rw [hf hf_ae, hg hg_ae, add_zero]
      · exact fs n
      · filter_upwards [h] with x hx
        simp [fs, SimpleFunc.eApprox_apply_zero hx]
