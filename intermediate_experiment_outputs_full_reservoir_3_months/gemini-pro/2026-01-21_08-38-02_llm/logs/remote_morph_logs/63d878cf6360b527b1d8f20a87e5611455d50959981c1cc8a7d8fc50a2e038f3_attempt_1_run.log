  have : CreatesLimitsOfSize.{0, 0} solidToCondensed := ⟨fun _ _ ↦ ⟨fun {F} ↦ createsLimitOfReflectsIso fun {c} t ↦ by
    have : IsSolid c.pt := by
      refine ⟨?_⟩
      let P := P ℤ
      let T := pre (oneMinusShift ℤ)
      let L := isLimitOfPreserves (ihom P) t
      let φ : (ihom P).mapCone c ⟶ (ihom P).mapCone c :=
        { hom := T.app c.pt, w := fun j ↦ (T.naturality (t.π.app j)).symm }
      have : IsIso φ := (Cone.isIso_iff_isIso_app _).mpr (fun j ↦ (inferInstance : IsSolid (F.obj j)).1)
      exact IsLimit.hom_isIso L L φ
    exact ⟨⟨c.pt⟩, rfl⟩⟩⟩
  inferInstance
