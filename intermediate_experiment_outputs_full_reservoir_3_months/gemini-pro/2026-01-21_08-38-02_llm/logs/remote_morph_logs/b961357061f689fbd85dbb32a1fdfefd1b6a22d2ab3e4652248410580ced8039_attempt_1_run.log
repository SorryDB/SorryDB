        simp only [sub_self, Ideal.zero_mem, ← map_add, hc]
      · intro g h hg hh Pg Ph u v h
        obtain ⟨a, ⟨s, _⟩, rfl⟩ := IsLocalization.mk'_surjective (⊤ : AddSubmonoid M) g
        have H1 := Ph (u + s) (v + a) (by simp [h]; abel)
