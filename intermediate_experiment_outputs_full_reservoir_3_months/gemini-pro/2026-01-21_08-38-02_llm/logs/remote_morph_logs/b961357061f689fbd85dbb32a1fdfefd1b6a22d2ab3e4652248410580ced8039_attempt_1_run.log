lemma isToricIdeal_iff_exists_span_single_sub_single :
    IsToricIdeal I
      ↔ I.IsPrime ∧ ∃ s : Set (M × M), .span ((fun (a, b) ↦ single a 1 - single b 1) '' s) = I where
  mp := by rintro ⟨s, rfl⟩; exact ⟨inferInstance, _, rfl⟩
  mpr := by
    let G := AddLocalization (⊤ : AddSubmonoid M)
    rintro ⟨hIprime, s, hsI⟩
    letI V := Spec(k[M] ⧸ I)
    let : V.Over Spec(k[M]) := sorry
    let : Spec(k[G]).Over Spec(k[M]) := sorry
    let VinterT := pullback (V ↘ Spec(k[M])) (Spec(k[G]) ↘ Spec(k[M]))
    refine ⟨hIprime, ?_⟩
    let f : M →+ G := AddLocalization.addMonoidOf _
    let S : AddSubgroup G :=
      { carrier := {x | ∃ a b, f a - f b = x ∧ single a 1 - single b 1 ∈ I}
        add_mem' := by
          rintro _ _ ⟨a, b, rfl, ha⟩ ⟨c, d, rfl, hb⟩
          refine ⟨a + c, b + d, by abel, ?_⟩
          rw [single_mul_single, single_mul_single, sub_add_sub_comm]
          exact I.add_mem (I.mul_mem_right _ ha) (I.mul_mem_left _ hb)
        zero_mem' := ⟨0, 0, by simp, I.zero_mem⟩
        neg_mem' := by
          rintro _ ⟨a, b, rfl, h⟩
          exact ⟨b, a, by simp, I.neg_mem h⟩ }
    refine ⟨S, le_antisymm (fun x hx ↦ ?_) ?_⟩
    · rw [← hsI]
      apply Ideal.span_mono
      rintro _ ⟨⟨a, b⟩, h, rfl⟩
      exact ⟨a, b, ⟨a, b, rfl, by rw [← hsI]; apply Ideal.subset_span; exact ⟨_, h, rfl⟩⟩, rfl⟩
    · rw [Ideal.span_le]
      rintro _ ⟨⟨a, b⟩, ⟨c, d, hcd, hI⟩, rfl⟩
      obtain ⟨k, -, hk⟩ := AddLocalization.eq.1 hcd
      have : single (a + d + k) 1 - single (c + b + k) 1 = 0 := by
        rw [single_eq_single_iff, hk]; abel
      have : single (d + k) 1 * (single a 1 - single b 1) ∈ I := by
        convert I.mul_mem_right (single (b + k) 1) hI using 1
        simp only [single_mul_single, one_mul]
        rw [add_assoc, add_comm d, add_assoc a, ← hk, sub_mul, single_mul_single,
          single_mul_single, one_mul, one_mul]
        abel
      apply (hIprime.mem_or_mem this).resolve_left
      intro h
      let ε : k[M] →+* k := lift (RingHom.id k) ⟨fun _ ↦ 1, rfl, fun _ _ ↦ (one_mul 1).symm⟩
      have : ε (single (d + k) 1) = 0 := by rw [h]; exact I.zero_mem.map _
      have : ε (single (d + k) 1) = 1 := by simp [ε]
      linarith
