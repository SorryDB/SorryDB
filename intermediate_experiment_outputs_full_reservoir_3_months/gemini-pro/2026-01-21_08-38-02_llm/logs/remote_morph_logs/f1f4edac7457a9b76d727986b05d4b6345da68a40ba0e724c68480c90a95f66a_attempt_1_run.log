lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  cases h1 with f hf
  cases h2 with g hg
  exists f ∘ g
  intro y
  cases hf.2 y with x hx
  cases hg x with n hn
  exists n
  show f (g n) = y
