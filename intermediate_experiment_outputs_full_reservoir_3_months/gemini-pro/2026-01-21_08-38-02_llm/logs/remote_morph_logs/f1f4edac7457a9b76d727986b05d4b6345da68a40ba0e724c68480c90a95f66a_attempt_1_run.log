lemma ctble_of_ctble_equinum {U V : Type}
    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  obtain ⟨f, hf⟩ := h2
  obtain ⟨g, hg⟩ := Equinum_symm h1
  exact ⟨f ∘ g, comp_inj hf hg.1⟩
```
