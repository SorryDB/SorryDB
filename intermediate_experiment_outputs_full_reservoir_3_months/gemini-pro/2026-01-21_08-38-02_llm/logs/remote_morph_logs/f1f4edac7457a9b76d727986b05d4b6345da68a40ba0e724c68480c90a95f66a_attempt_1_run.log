    (h1 : U ∼ V) (h2 : ctble U) : ctble V := by
  have hVU : V ∼ U := equinum_symm h1
  cases h2 with
  | inl hfin =>
    apply Or.inl
    cases hfin with | intro n hn =>
      exists n
      exact equinum_trans hVU hn
  | inr hden =>
    apply Or.inr
    exact equinum_trans hVU hden
