        if h : i = 0 then by simp [h]; apply Real.contDiffOn_log.comp (contDiffOn_apply i); exact fun x hx ↦ hx
        else by simp [h]; exact contDiffOn_apply i }
  -- Compose d with Φ to obtain a diffeomorphism to an open subset of the model half-space
