    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u, hu, hxu, _, v, hv, ⟨d⟩⟩ := hm.locally_modelled x
  let k : Fin n := 0
  let φ : Eucl n ᵈ≃ { x : Eucl n | 0 < x k } :=
    { toFun := fun x ↦ ⟨Function.update x k (Real.exp (x k)), by simp; exact Real.exp_pos _⟩
      invFun := fun x ↦ Function.update x.1 k (Real.log (x.1 k))
      left_inv := fun x ↦ by ext i; by_cases h : i = k <;> simp [h]
      right_inv := fun x ↦ Subtype.ext <| by ext i; by_cases h : i = k <;> simp [h, Real.exp_log x.2]
      dsmooth_toFun := dsmooth_iff_contDiff.mpr <| contDiff_pi.mpr fun i ↦ by
        by_cases h : i = k; subst h; simp; exact Real.contDiff_exp.comp (contDiff_apply k)
        simp [h]; exact contDiff_apply i
      dsmooth_invFun := dsmooth_iff_contDiff.mpr <| contDiff_pi.mpr fun i ↦ by
        by_cases h : i = k; subst h; simp
        · exact Real.contDiff_log.comp_contDiffAt (contDiff_subtype_val.contDiffAt.apply k) (fun x ↦ x.2)
        simp [h]; exact contDiff_subtype_val.apply i }
  let v' := Subtype.val ⁻¹' (φ '' v)
  let ψ : (φ '' v : Set {x | 0 < x k}) ᵈ≃ (v' : Set {x | 0 ≤ x k}) :=
    { toFun := fun x ↦ ⟨⟨x.1.1, x.1.2.le⟩, x.2⟩
      invFun := fun x ↦ ⟨⟨x.1.1, by rcases x.2 with ⟨_, _, rfl⟩; exact (φ _).2⟩, x.2⟩
      left_inv := fun _ ↦ rfl
      right_inv := fun _ ↦ rfl
      dsmooth_toFun := (dsmooth_subtype_val.comp dsmooth_subtype_val).subtype_mk _ |>.subtype_mk _
      dsmooth_invFun := (dsmooth_subtype_val.comp dsmooth_subtype_val).subtype_mk _ |>.subtype_mk _ }
  refine ⟨u, hu, hxu, (), v', ?_, ⟨(d.trans (φ.image v)).trans ψ⟩⟩
  rw [isOpen_induced_iff]; use φ '' v
  exact ⟨φ.isOpen_image_of_isOpen_source hv, rfl⟩⟩
