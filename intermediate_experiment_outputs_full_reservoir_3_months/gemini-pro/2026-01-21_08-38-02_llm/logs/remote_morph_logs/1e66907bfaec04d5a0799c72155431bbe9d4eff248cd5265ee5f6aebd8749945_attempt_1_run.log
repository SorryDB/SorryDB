instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u,hu,hxu,i,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  let f (p : Eucl n) : Eucl n := fun i ↦ if i = 0 then Real.exp (p 0) else p i
  let g (p : Eucl n) : Eucl n := fun i ↦ if i = 0 then Real.log (p 0) else p i
  have hf : DSmooth f := dsmooth_pi_iff.2 fun i ↦ if h : i = 0 then h ▸ contDiff_exp.dsmooth.comp (dsmooth_apply 0) else dsmooth_apply i
  have hg : DSmoothOn g {y | 0 < y 0} := dsmoothOn_pi_iff.2 fun i ↦ if h : i = 0 then h ▸ contDiffOn_log.dsmoothOn.comp (dsmoothOn_apply 0) (by simp) else dsmoothOn_apply i
  let Φ : Eucl n ᵈ≃ {y : Eucl n | 0 < y 0} :=
    { toFun := fun x ↦ ⟨f x, by dsimp [f]; rw [if_pos rfl]; apply Real.exp_pos⟩
      invFun := fun y ↦ g y
      left_inv := fun x ↦ by ext i; dsimp [f,g]; split_ifs <;> simp [Real.log_exp]
      right_inv := fun y ↦ by ext i; dsimp [f,g]; split_ifs <;> simp [Real.exp_log y.2]
      dsmooth_toFun := dsmooth_subtype_mk.2 hf
      dsmooth_invFun := hg.comp dsmooth_subtype_val (fun x ↦ x.2) }
  let v' := Subtype.val ⁻¹' (f '' v)
  have hv' : IsOpen[DTop] v' := by
    rw [dTop_eq, isOpen_induced_iff]; use f '' v
    refine ⟨Φ.isOpen_image_of_isOpen v (dTop_eq (Eucl n) ▸ hv), rfl⟩
  refine ⟨u, hu, hxu, (), v', hv', ⟨?_⟩⟩
  let D : v ᵈ≃ v' :=
    { toFun := fun ⟨x, hx⟩ ↦ ⟨⟨f x, le_of_lt (Real.exp_pos _)⟩, by use x, hx⟩
      invFun := fun ⟨⟨y, _⟩, ⟨x, hx, hxy⟩⟩ ↦ ⟨x, hx⟩
      left_inv := fun ⟨x, hx⟩ ↦ by simp
      right_inv := fun ⟨⟨y, _⟩, ⟨x, hx, hxy⟩⟩ ↦ by simp [←hxy]
      dsmooth_toFun := dsmooth_subtype_mk.2 (dsmooth_subtype_mk.2 (hf.comp dsmooth_subtype_val))
      dsmooth_invFun := by
        rw [dsmooth_subtype_iff_dsmooth_val]; simp
        refine hg.comp (dsmooth_subtype_val.comp dsmooth_subtype_val) (fun x ↦ ?_)
        obtain ⟨z, _, hz⟩ := x.2; rw [←hz]; apply Real.exp_pos }
  exact d.trans D⟩
