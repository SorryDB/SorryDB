  let ⟨u,hu,hxu,i,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  let y := d x
  obtain ⟨r, hr, hrv⟩ := Metric.isOpen_iff.mp hv y (d.map_x_mem_v x)
  let s : Eucl n := fun k ↦ if k = 0 then |y 0| + r + 1 else 0
  let T : Eucl n ᵈ≃ Eucl n := {
    toEquiv := Equiv.addRight s
    dsmooth_toFun := dsmooth_id.add dsmooth_const
    dsmooth_invFun := dsmooth_id.sub dsmooth_const }
  let v' := Metric.ball y r
  let u' := d.toEquiv ⁻¹' v'
