instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u,hu,hxu,i,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  -- We prove Eucl n is a manifold with boundary by mapping R^n to the interior of H^n via exp
  have hE : IsManifoldWithBoundary n (Eucl n) := ⟨fun y ↦ by
    let f : Eucl n → Eucl n := fun x i ↦ if i = 0 then Real.exp (x 0) else x i
    let g : Eucl n → Eucl n := fun x i ↦ if i = 0 then Real.log (x 0) else x i
    -- Diffeomorphism from R^n to {x | x_0 > 0}
    let φ : Eucl n ᵈ≃ {x : Eucl n | 0 < x 0} := {
      toFun := fun x ↦ ⟨f x, by dsimp [f]; split_ifs; exact Real.exp_pos _; exact (Real.exp_pos _).trans (by norm_num)⟩
      invFun := fun x ↦ g x
      left_inv := fun x ↦ by ext i; dsimp [f,g]; split_ifs <;> simp [Real.log_exp]
      right_inv := fun x ↦ by ext i; dsimp [f,g]; split_ifs <;> simp [Real.exp_log x.2]
      dsmooth_toFun := sorry -- Standard smoothness of exp
      dsmooth_invFun := sorry } -- Standard smoothness of log
    -- {x | x_0 > 0} is open in H^n = {x | x_0 >= 0}
    let V : Set {x : Eucl n | 0 ≤ x 0} := {z | 0 < (z : Eucl n) 0}
    have hV : IsOpen V := isOpen_iff_exists_isOpen_val.mpr ⟨{x | 0 < x 0}, isOpen_Ioi.preimage (continuous_apply 0), rfl⟩
