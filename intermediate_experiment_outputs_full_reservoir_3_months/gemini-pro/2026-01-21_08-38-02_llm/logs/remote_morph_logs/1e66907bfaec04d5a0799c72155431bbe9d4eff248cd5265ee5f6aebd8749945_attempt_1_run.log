    refine ⟨Set.univ, isOpen_univ, Set.mem_univ y, (), V, hV, ⟨φ.trans {
      toEquiv := Equiv.subtypeSubtypeEquivSubtypeInter (fun x ↦ 0 ≤ x 0) (fun x ↦ 0 < x 0) (fun x h ↦ le_of_lt h)
      dsmooth_toFun := sorry -- Smoothness of inclusion
      dsmooth_invFun := sorry }⟩⟩⟩ -- Smoothness of inclusion
  -- Since v is open in Eucl n, it is a manifold with boundary
  -- Thus d(x) has a neighborhood in v diffeomorphic to a subset of H^n
  let ⟨v',hv',hyv',_,w,hw,⟨d'⟩⟩ := (hv.isManifoldWithBoundary hE).locally_modelled (d x)
  -- Pull this back to u via d
  refine ⟨d ⁻¹' v', hu.inter (hv.preimage d.dsmooth.continuous), ⟨hxu, hyv'⟩, (), w, hw,
    ⟨(d.restrict _ _ (by rw [d.image_eq]; exact Set.image_preimage_eq_of_subset hyv'.1)).trans d'⟩⟩⟩
