/-- Any diffeological manifold is also a diffeological manifold with boundary. -/
instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u,hu,hxu,_,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  let y := d x
  have hy : y ∈ v := d.map_source.mpr hxu
  rcases Metric.isOpen_iff.mp hv y hy with ⟨ε, hε, hB⟩
  let t : Eucl n := fun i ↦ if i = 0 then 2 + |y 0| + ε else 0
  let T : Eucl n ᵈ≃ Eucl n :=
    { toEquiv := Equiv.addRight t
      smooth_to := smooth_id.add smooth_const
      smooth_inv := smooth_id.sub smooth_const }
  let u' := d ⁻¹' (Metric.ball y ε)
  let v' := T '' (Metric.ball y ε)
  have hsub : v' ⊆ {x | 0 ≤ x 0} := fun z ⟨w, hw, hz⟩ ↦ by
    simp only [Equiv.addRight_apply] at hz; rw [← hz]; dsimp [t]
    have : |w 0 - y 0| ≤ ‖w - y‖ := norm_le_pi_norm 0 (w - y)
    linarith [mem_ball_iff_norm.mp hw, abs_le.mp this]
  let v'' : Set {x : Eucl n | 0 ≤ x 0} := (↑) ⁻¹' v'
  refine ⟨u', d.continuous_inv.isOpen_preimage _ Metric.isOpen_ball, Metric.mem_ball_self hε, (), v'', ?_, ⟨?_⟩⟩
