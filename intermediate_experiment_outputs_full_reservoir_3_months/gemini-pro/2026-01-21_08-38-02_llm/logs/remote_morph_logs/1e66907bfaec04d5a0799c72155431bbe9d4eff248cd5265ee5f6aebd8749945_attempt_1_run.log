    if h : i = 0 then h ▸ Real.contDiff_exp.comp (contDiff_apply 0) else contDiff_apply i
  have dg : DSmoothOn g {x | 0 < x 0} := dsmoothOn_iff_contDiffOn.2 <| contDiffOn_pi.2 fun i ↦
    if h : i = 0 then h ▸ Real.contDiffOn_log.comp (contDiffOn_apply 0) (by simpa) else contDiffOn_apply i
  let S : Set (Eucl n) := {x | 0 < x 0}
  let ϕ : Eucl n ᵈ≃ S :=
    { toFun := fun x ↦ ⟨f x, by simp [f, S]; exact Real.exp_pos _⟩
      invFun := fun y ↦ g y
      left_inv := fun x ↦ by ext i; simp [f, g]; split_ifs <;> simp
      right_inv := fun y ↦ by ext i; simp [f, g]; split_ifs <;> simp [y.2, Real.exp_log]
