  unfold CircleIntegrable
  unfold circleAverage
  simp only
  have :
      (fun θ ↦ (fun z ↦ (2 * π)⁻¹ • ∫ (θ : ℝ) in 0..2 * π, (fun x ↦ log ‖f x - z‖) (circleMap 0 r θ)) (circleMap 0 1 θ))
