def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    -- We simplify circuit_norm but avoid simplifying LessThan.circuit to its Spec
    simp only [circuit_norm, Prod.mk.injEq] at h_holds ⊢

    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith

    by_cases hy_eq : y.val + 1 = 2^n
    case neg =>
      -- y+1 != 2^n. Since y < 2^n, y+1 < 2^n.
      have h_ass : x.val < 2^n ∧ (y + 1).val < 2^n := by
        constructor; exact assumptions.1
        rw [ZMod.val_add_of_lt hy, ZMod.val_one]
        omega
      -- Use soundness of LessThan
      have := (LessThan.circuit n hn).soundness i env (x, y+1) (by simpa using h_input) h_ass h_holds
      rw [this]
      apply ite_congr_cond
      rw [ZMod.val_add_of_lt hy, ZMod.val_one]
      omega
    case pos =>
      -- y+1 = 2^n. We must use the implementation constraints of LessThan.
      unfold LessThan.circuit LessThan.main at h_holds
      simp only [Num2Bits.circuit, circuit_norm] at h_holds
      rcases h_holds with ⟨⟨_, h_bits⟩, h_out⟩
      rw [h_out]
      -- h_bits relates the bits of (x + 2^n - (y+1)) to x.
      -- Since y+1 = 2^n, diff = x.
      rw [h_input.1, h_input.2] at h_bits
      have : y + 1 = (2^n : F p) := by
        apply ZMod.val_injective
        rw [ZMod.val_add_of_lt hy, ZMod.val_nat_cast, hy_eq]
        apply ZMod.val_nat_cast_of_lt
        exact lt_trans this hn
      rw [this, add_sub_cancel_right] at h_bits
      -- The n-th bit of x (where x < 2^n) is 0.
      apply congrArg (fun v => v[n]) at h_bits
      simp only [Vector.getElem_map, Vector.getElem_mapRange, Nat.cast_ite, Nat.cast_one,
        Nat.cast_zero, Nat.testBit_eq_false_of_lt assumptions.1, ↓reduceIte] at h_bits
      rw [h_bits]
      simp only [sub_zero]
      -- Logic: x < 2^n and y = 2^n - 1 implies x <= y.
      have : x.val ≤ y.val := by
        rw [← Nat.cast_one, ← ZMod.val_add_of_lt hy] at hy_eq
        omega
      simp [this]

end LessEqThan
