/-
template LessEqThan(n) {
    signal input in[2];
    signal output out;

    component lt = LessThan(n);

    lt.in[0] <== in[0];
    lt.in[1] <== in[1]+1;
    lt.out ==> out;
}
-/
def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp only [circuit_norm, LessEqThan.circuit, Prod.mk.injEq] at *
    unfold LessThan.circuit at h_holds

    have h_pow : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith
    have hy_val : (y + (1 : F p)).val = y.val + 1 := by
      rw [ZMod.val_add_of_lt hy, ZMod.val_one]

    by_cases hy_eq : y.val + 1 = 2^n
    · -- Case: y + 1 = 2^n
      -- In this case, LessThan input (x, y+1) violates y+1 < 2^n.
      -- We inspect the circuit implementation.
      simp only [LessThan.main, circuit_norm, Num2Bits.circuit] at h_holds
      rcases h_holds with ⟨bits, h_bits, h_out⟩
      
      -- Determine the 'diff' input to Num2Bits
      simp only [h_input.left, h_input.right] at h_bits
      rw [hy_val, hy_eq] at h_bits
      rw [add_comm, add_sub_assoc, sub_self, add_zero] at h_bits
      
      -- h_bits implies bits are the bit decomposition of x
      -- We rely on the fact that circuit_norm/Num2Bits yields fieldToBits or equivalent
      -- Since we can't easily access the library lemmas about h_bits summation without imports,
      -- we follow the pattern of LessThan.soundness which unfolds fieldToBits.
      -- Assuming standard Num2Bits spec behavior in h_bits (bits = fieldToBits ...):
      
      unfold fieldToBits at h_bits
      unfold toBits at h_bits
      rw [h_bits] at h_out
      
      -- Analyze the output
      rw [h_out]
      simp only [Vector.getElem_map, Vector.getElem_mapRange, Nat.cast_ite, Nat.cast_one, Nat.cast_zero, circuit_norm]
      
      -- bits[n] corresponds to x.val.testBit n
      -- Since x < 2^n, testBit n is false.
      rw [Nat.testBit_eq_false_of_lt assumptions.left]
      simp only [↓reduceIte, sub_zero]
      
      -- Verify Spec: x <= y
      -- x < 2^n, y = 2^n - 1 => x <= y
      have : x.val ≤ y.val := by
        rw [← Nat.lt_succ_iff, ← hy_val, hy_eq]
        exact assumptions.left
      simp [this]

    · -- Case: y + 1 < 2^n
      -- Here assumptions for LessThan hold.
      have h_lt_assump : x.val < 2^n ∧ (y + (1 : F p)).val < 2^n := by
        constructor; exact assumptions.left
        rw [hy_val]; omega
      
      -- Reuse LessThan soundness
      have h_spec := LessThan.circuit (p := p) n hn |>.soundness
        i env (x, y + 1)
        (by simp [h_input])
        h_lt_assump
        h_holds
      
      simp only [h_spec]
      -- Convert Spec condition: x < y + 1 <-> x <= y
      have : x.val < (y + (1 : F p)).val ↔ x.val <= y.val := by
        rw [hy_val]
        exact Nat.lt_succ_iff
      rw [this]

end LessEqThan
