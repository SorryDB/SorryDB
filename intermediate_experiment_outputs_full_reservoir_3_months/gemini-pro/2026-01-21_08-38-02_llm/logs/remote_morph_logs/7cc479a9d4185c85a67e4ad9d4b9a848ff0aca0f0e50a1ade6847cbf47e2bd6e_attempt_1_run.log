namespace LessEqThan
/-
template LessEqThan(n) {
    signal input in[2];
    signal output out;

    component lt = LessThan(n);

    lt.in[0] <== in[0];
    lt.in[1] <== in[1]+1;
    lt.out ==> out;
}
-/
def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp only [circuit_norm, main, Prod.mk.injEq] at h_holds

    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith

    by_cases hy_eq : y.val + 1 = 2^n
    case pos =>
      -- Case y.val + 1 = 2^n (Boundary case)
      -- Unfold LessThan implementation
      simp only [LessThan.circuit, LessThan.main] at h_holds
      simp only [circuit_norm, Num2Bits.circuit] at h_holds
      rcases h_holds with ⟨bits, h_bits, h_out⟩

      have h_diff : (input.1 + (2^n : F p) - (input.2 + 1)).eval env = x := by
        simp [h_input]
        rw [ZMod.val_add_of_lt hy, ZMod.val_one] at hy_eq
