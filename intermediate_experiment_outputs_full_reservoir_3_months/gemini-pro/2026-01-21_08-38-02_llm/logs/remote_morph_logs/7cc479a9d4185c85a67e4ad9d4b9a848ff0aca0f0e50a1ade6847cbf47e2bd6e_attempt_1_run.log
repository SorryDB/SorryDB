      simp only [↓reduceIte, sub_zero] at h_out

      have h_le : x.val <= y.val := by
        rw [← ZMod.val_add_of_lt hy, ZMod.val_one] at hy_eq
        omega
      simp [h_le, h_out]

    case neg =>
