def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp only [circuit_norm, Prod.mk.injEq] at h_holds
    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith
    
    by_cases hy_eq : y.val + 1 = 2^n
    case neg =>
      -- In this case, y + 1 < 2^n, so LessThan assumptions hold.
      have h_lt_assumptions : LessThan.circuit n hn (x, y + 1) |>.Assumptions (x, y+1) := by
        simp [LessThan.circuit]
        constructor
        · exact assumptions.left
        · rw [ZMod.val_add_of_lt hy, ZMod.val_one]
          omega
      
      -- We can use the soundness of LessThan
      have h_lt_spec := (LessThan.circuit n hn).soundness _ _ _ _ rfl h_lt_assumptions h_holds
      simp only [LessThan.circuit, ZMod.val_add_of_lt hy, ZMod.val_one] at h_lt_spec
      
      rw [h_lt_spec]
      split_ifs with h_lt
      · have : x.val ≤ y.val := by
          rw [ZMod.val_add_of_lt hy, ZMod.val_one] at h_lt
          omega
        simp [this]
      · have : ¬ (x.val ≤ y.val) := by
          rw [ZMod.val_add_of_lt hy, ZMod.val_one] at h_lt
          omega
        simp [this]

    case pos =>
      -- In this case y + 1 = 2^n. Assumptions for LessThan fail.
      -- We must inspect the circuit implementation.
      unfold LessThan.circuit at h_holds
      simp only [LessThan.main] at h_holds
      
      -- The circuit computes Num2Bits of (x + 2^n - (y+1))
      -- Since y+1 = 2^n in F p, the input to Num2Bits is just x.
      
      have h_y_plus_1 : y + 1 = (2^n : F p) := by
        apply ZMod.val_injective
        rw [ZMod.val_add_of_lt hy, ZMod.val_one, ZMod.val_natCast_of_lt]
        · exact hy_eq
        · exact lt_trans this hn

      rw [h_y_plus_1, sub_self, add_zero] at h_holds
      
      -- h_holds is now: Num2Bits.circuit (n+1) hn x yields bits, and output is 1 - bits[n]
      rcases h_holds with ⟨bits, h_bits, h_out⟩
      
      -- We use soundness of Num2Bits.
      -- Input x < 2^n < 2^(n+1), so assumptions hold.
      have h_n2b_assump : (Num2Bits.circuit (n + 1) hn).Assumptions x := by
        simp [Num2Bits.circuit]
        apply lt_of_lt_of_le assumptions.left
        apply pow_le_pow_right (by decide)
        linarith
        
      have h_n2b_spec := (Num2Bits.circuit (n + 1) hn).soundness _ _ _ _ rfl h_n2b_assump h_bits
      simp [Num2Bits.circuit, Num2Bits.Spec] at h_n2b_spec
      
      -- bits[n] is the n-th bit of x.
      -- Since x < 2^n, the n-th bit is 0.
      have h_bit_n : bits[n] = 0 := by
        rw [h_n2b_spec]
        simp only [Vector.getElem_map, Vector.getElem_mapRange, Nat.cast_ite, Nat.cast_one,
          Nat.cast_zero]
        rw [Nat.testBit_lt_two_pow]
        · simp
        · exact assumptions.left
        
      rw [h_out, h_bit_n]
      simp
      
      -- Finally, check that Spec is 1.
      -- x < 2^n and y+1 = 2^n => y = 2^n - 1.
      -- So x <= y is true.
      have : x.val ≤ y.val := by
        have : y.val = 2^n - 1 := by omega
        omega
      simp [this]
end LessEqThan
