      simp [hx_eval, hy_eval]

    rcases h_holds with ⟨h_bits, h_out⟩
    rw [h_diff_eval] at h_bits
    
    let h_n2b_sound := Num2Bits.circuit.soundness (n+1) hn
    specialize h_n2b_sound _ env _ (by rfl) True.intro h_bits
    rw [h_n2b_sound] at h_out

    have y_plus_one_small : (y.val + 1) < p := by linarith [ZMod.val_lt y, h_pow_lt]
    
