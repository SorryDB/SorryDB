def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    circuit_proof_start
    simp only [circuit_norm, LessThan.circuit, LessThan.main, Num2Bits.circuit] at h_holds ⊢
    rcases h_input with ⟨hx, hy⟩
    rw [← hx, ← hy] at h_holds

    have hy_val : (y + 1).val = y.val + 1 := by
      rw [ZMod.val_add, ZMod.val_one, Nat.mod_eq_of_lt]
      have : 2^n < p := lt_trans (pow_lt_pow_right (by decide) (Nat.lt_succ_self n)) hn
      linarith [assumptions.2]

    have h_diff : (x + 2^n - (y + 1)).val = x.val + 2^n - (y.val + 1) := by
      rw [ZMod.val_sub, ZMod.val_add, ZMod.val_pow, ZMod.val_ofNat_of_lt hn]
      have h_sum : x.val + 2^n < p := by
        calc x.val + 2^n < 2^n + 2^n := by linarith [assumptions.1]
             _ = 2^(n+1) := by ring
             _ < p := hn
      rw [Nat.mod_eq_of_lt h_sum, Nat.mod_eq_of_lt]
      · rfl
      · apply lt_of_le_of_lt (Nat.sub_le _ _) h_sum

    have h_bit : ((x + 2^n - (y + 1)).val / 2^n) % 2 = if x.val <= y.val then 0 else 1 := by
      rw [h_diff]
      split_ifs with h_le
      · have : x.val < y.val + 1 := by linarith
        have : x.val + 2^n - (y.val + 1) < 2^n := by
          rw [Nat.add_sub_assoc] <;> try linarith
          exact Nat.add_lt_of_lt_sub (by linarith)
        rw [Nat.div_eq_of_lt this]; rfl
      · have : x.val ≥ y.val + 1 := by linarith
        have h_ge : x.val + 2^n - (y.val + 1) ≥ 2^n := by
          rw [Nat.add_sub_assoc (by linarith)]; linarith
        have h_lt : x.val + 2^n - (y.val + 1) < 2 * 2^n := by
          rw [Nat.add_sub_assoc (by linarith)]
          have : x.val - (y.val + 1) < 2^n := by
            apply Nat.sub_lt_left_of_lt_add (by linarith); linarith [assumptions.1]
          linarith
        rw [Nat.div_eq_of_lt_le h_ge h_lt]; rfl

