def circuit (n : ℕ) (hn : 2^(n+1) < p) : FormalCircuit (F p) fieldPair field where
  main := fun (x, y) =>
    LessThan.circuit n hn (x, y + 1)

  localLength _ := n + 2

  Assumptions := fun (x, y) => x.val < 2^n ∧ y.val < 2^n
  Spec := fun (x, y) output =>
    output = (if x.val <= y.val then 1 else 0)

  soundness := by
    intro i env input (x, y) h_input assumptions h_holds
    simp only [circuit_norm, Prod.mk.injEq] at h_holds ⊢

    have : 2^n < 2^(n+1) := by gcongr; repeat linarith
    have hy : y.val + (1 : F p).val < p := by
      simp only [ZMod.val_one]; linarith
    
    rw [ZMod.val_add_of_lt hy, ZMod.val_one] at h_holds

    by_cases hy_eq : y.val + 1 = 2^n
    · -- Case: y + 1 = 2^n (Overflow of n bits, but valid in F p)
      -- x < 2^n and y = 2^n - 1 implies x <= y
      have h_le : x.val ≤ y.val := by
        rw [← Nat.lt_succ_iff, hy_eq]
        exact assumptions.1
      simp only [h_le, ↓reduceIte]

      -- Unfold LessThan implementation
      rw [LessThan.circuit] at h_holds
      simp only [circuit_norm, LessThan.main, Num2Bits.circuit] at h_holds

      -- Evaluate diff: x + 2^n - (y+1) = x + 2^n - 2^n = x
      have h_diff : (x + (2^n : F p) - (y + 1)).val = x.val := by
        rw [← ZMod.val_eq_of_eq_val hy_eq, Nat.cast_add, Nat.cast_one]
        simp
      
      -- Num2Bits returns bits of x. Since x < 2^n, the n-th bit is 0.
      -- So output = 1 - 0 = 1.
      unfold fieldToBits toBits at h_holds
      simp only [h_diff, Vector.getElem_map, Vector.getElem_mapRange, circuit_norm] at h_holds
      simp only [Nat.testBit_eq_false_of_lt assumptions.1, Bool.false_eq_true, ↓reduceIte] at h_holds
      exact h_holds

    · -- Case: y + 1 < 2^n
      -- Use LessThan Spec
      simp [LessThan.circuit] at h_holds
      specialize h_holds (by omega)
      simp_all [Nat.lt_add_one_iff]

end LessEqThan
