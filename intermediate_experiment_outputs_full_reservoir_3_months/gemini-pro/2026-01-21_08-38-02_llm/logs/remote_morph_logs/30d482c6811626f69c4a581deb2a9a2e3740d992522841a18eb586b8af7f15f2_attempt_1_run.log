lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  -- Following Baker and Shostak (1972), we partition calls into "spreading" and "gathering".
  let N := S.length
  
  -- Spreading calls: The number of agents knowing k's secret increases.
  -- We need n-1 such calls to inform everyone.
  let is_spreading (i : Fin N) : Prop := 
    let pre := after (S.take i)
    let post := after (S.take (i+1))
    (Finset.univ.filter (λ x => pre x k)).card < (Finset.univ.filter (λ x => post x k)).card

  -- Gathering calls: Both agents do not know k's secret yet.
  -- These calls move secrets towards the "gateways" (neighbors of k).
  -- We need at least (n - 1) - v(S, k) such calls.
  let is_gathering (i : Fin N) : Prop :=
    let pre := after (S.take i)
    let c := S.get i
    ¬ pre c.fst k ∧ ¬ pre c.snd k

  have h_spread_count : (List.finRange N).countP is_spreading ≥ n - 1 := sorry
  have h_gather_count : (List.finRange N).countP is_gathering ≥ n - 1 - v S k := sorry
  
  -- Disjointness: A call cannot be both gathering (neither knows k) and spreading (knowledge of k increases).
  have h_disjoint : ∀ i, is_spreading i → ¬ is_gathering i := by
    intro i hs hg
    -- definition of spreading implies someone learns k, which requires a participant to know k.
    -- definition of gathering implies neither participant knows k.
    sorry

  calc 
    S.length = (List.finRange N).length := by simp
    _ ≥ (List.finRange N).countP (λ i => is_spreading i ∨ is_gathering i) := List.countP_le_length _
    _ = (List.finRange N).countP is_spreading + (List.finRange N).countP is_gathering := by
        rw [List.countP_or]
        congr; ext i; simp; constructor <;> intro h
        · exact h_disjoint i h
        · intro hs; exact h_disjoint i hs h
    _ ≥ (n - 1) + (n - 1 - v S k) := by gcongr
    _ = 2 * n - 2 - v S k := by sorry -- Arithmetic
