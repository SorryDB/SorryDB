```lean
lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  -- use Lemma 6 "calls needed for both spreading and informing are those in v S k"
  have exists_IO : ∃ I O : Finset (Fin S.length),
      n - 1 ≤ I.card ∧ n - 1 ≤ O.card ∧
      ∀ i ∈ I ∩ O, (S.get i).fst = k ∨ (S.get i).snd = k := sorry
  rcases exists_IO with ⟨I, O, hI, hO, hIO⟩
  have h_inter : (I ∩ O).card ≤ v S k := sorry
  have h_sum : 2 * n - 2 ≤ I.card + O.card := by
    cases n <;> simp [Nat.mul_succ, Nat.succ_sub_one, Nat.two_mul]
  have h_bound : 2 * n - 2 ≤ S.length + v S k := calc
    2 * n - 2 ≤ I.card + O.card := h_sum
    _ = (I ∪ O).card + (I ∩ O).card := (Finset.card_union_add_card_inter I O).symm
    _ ≤ S.length + v S k := Nat.add_le_add (Finset.card_le_univ _) h_inter
  exact Nat.le_sub_of_add_le h_bound
```
