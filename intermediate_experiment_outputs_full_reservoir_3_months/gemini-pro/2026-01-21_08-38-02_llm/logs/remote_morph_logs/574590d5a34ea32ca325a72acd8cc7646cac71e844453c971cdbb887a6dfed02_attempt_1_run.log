lemma construction_rel :
  letI U := construction_omega T hT
  (∀ φ ψ, φ ➝ ψ ∈ T.theory → φ ∈ U → ψ ∈ U) := by
  intro φ ψ hxy hx;
  by_contra hy;
  obtain ⟨Γ, hΓ, hC⟩ := (of_not_mem_construction_omega hy).2;
  rcases of_mem_construction_omega hx with h_base | h_step;
  . have : χ ➝ ψ ∈ T.theory := mem_trans h_base hxy;
    exact hy (mem_omega_of_mem this);
  . have h_cons : ∀ i, ∀ Δ : Finset (Formula ℕ), ↑Δ ⊆ construction T hT i → Δ.conj ➝ ξ ∉ T.theory := by
      intro i; induction i with
      | zero =>
        intro Δ hΔ hC;
        have : χ ➝ Δ.conj ∈ T.theory := by
          induction Δ using Finset.induction with
          | empty => apply T.mem_of_provable; grind;
          | insert _ _ ih =>
             rw [Finset.coe_insert] at hΔ;
             apply T.imp_closed (φ := (χ ➝ _) ⋏ (χ ➝ _));
             . grind;
             . apply T.andIR;
               . apply hΔ; simp;
               . apply ih; trans (↑(insert _ _)); simp; exact hΔ;
        exact hT (mem_trans this hC);
      | succ i ih =>
        intro Δ hΔ;
        simp [construction] at hΔ;
        split at hΔ;
        . split_ifs at hΔ with h_cond;
          . rename_i δ;
            by_cases hδ : δ ∈ Δ;
            . let Δ' := Δ.erase δ;
