      -- Using s(n+6) = 3 s n (since M^6 = 3 I)
      have h_step6 : s (n + 6) = 3 * s n := by
        have hM6 : M ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by decide
        have : M ^ (n + 6) = M ^ n * M ^ 6 := by rw [pow_add, Matrix.mul_eq_mul]
        rw [hM6, Matrix.mul_smul, Matrix.mul_one] at this
        have eq := congr_fun (congr_fun this 1) 0
        simp [Matrix.smul_apply] at eq
        rw [h_ind, h_ind] at eq
        exact eq
