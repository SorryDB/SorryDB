      -- Verify recurrence relations
      constructor
      · -- s (m+1) = c m + s m
        rw [show s (m + 1) = c m + s m by
          simp only [s, c, Finset.sum_range_succ, Nat.choose_succ_succ, Nat.cast_add, Finset.sum_add_distrib,
