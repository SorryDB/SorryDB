        trans ∑ x ∈ Finset.range (m + 1), (m.choose (2 * (x + 1)) + m.choose (2 * (x + 1) - 1)) * 3 ^ (x + 1)
        · refine Finset.sum_congr rfl (fun k _ => ?_)
          rw [Nat.choose_succ_succ, Nat.cast_add, add_mul]
        · simp only [Nat.succ_sub_succ_eq_sub, Nat.sub_zero, add_mul, Finset.sum_add_distrib, pow_add, pow_one, mul_assoc]
          rw [Finset.sum_range_succ_comm (n:=m), Nat.choose_succ_self_right, zero_mul, add_zero]
          rw [Finset.sum_range_succ_comm (n:=m), Nat.choose_succ_self_right, zero_mul, add_zero]
          ring
  intro h
  rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h
  have h_sum : (∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * 3 ^ k : ZMod 5) = 0 := by
