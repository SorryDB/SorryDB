  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  -- Convert to integer sum and simplify powers
  rw [← Int.dvd_iff_emod_eq_zero, Int.ofNat_sum]
  trans (∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1) : ℤ) * 8 ^ k) % 5
  · congr
    ext k
    simp only [Int.ofNat_mul, Int.ofNat_pow, Int.ofNat_succ, Int.ofNat_add]
    congr 1
    rw [← pow_mul]
    norm_num
  
  -- Define the matrix corresponding to 1 + √8 mod 5
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  
  -- The sum corresponds to the (1, 0) entry of M^(2n+1)
  -- Proof sketch: The sum is the coefficient of √8 in (1+√8)^(2n+1).
  -- Mapping 1 -> I and √8 -> K = !![0, 3; 1, 0] gives the homomorphism.
  -- Then (1+√8)^(2n+1) maps to (I+K)^(2n+1) = M^(2n+1).
  -- The coefficient of √8 corresponds to the coefficient of K, which is the (1,0) entry.
  -- We rely on the periodicity of M to show this entry is never 0.

  have M_pow_6 : M ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    native_decide
  
  -- We want to show (M^(2n+1)) 1 0 ≠ 0.
  let f (k : ℕ) := (M ^ k) 1 0
  
  have period : ∀ k, f (k + 6) = 3 * f k := by
    intro k
    show (M ^ (k + 6)) 1 0 = 3 * (M ^ k) 1 0
    rw [pow_add, M_pow_6]
    simp [Matrix.scalar_mul_eq_smul, Matrix.mul_smul, Matrix.one_mul]
  
  -- It suffices to check f(k) ≠ 0 for k = 1, 3, 5 (since 2n+1 is odd)
  have check_base : ∀ k ∈ ({1, 3, 5} : Finset ℕ), f k ≠ 0 := by
    decide

  -- Reduction to base cases
  let m := 2 * n + 1
  have m_odd : m % 2 = 1 := by omega
  have m_mod_6_odd : (m % 6) % 2 = 1 := by
    rw [Nat.mod_mod]
    exact m_odd
  
  have m_mod_6_mem : m % 6 ∈ ({1, 3, 5} : Finset ℕ) := by
    match m % 6, m_mod_6_odd, Nat.mod_lt m (by norm_num) with
    | 0, h, _ => contradiction
    | 1, _, _ => simp
    | 2, h, _ => contradiction
    | 3, _, _ => simp
    | 4, h, _ => contradiction
    | 5, _, _ => simp
