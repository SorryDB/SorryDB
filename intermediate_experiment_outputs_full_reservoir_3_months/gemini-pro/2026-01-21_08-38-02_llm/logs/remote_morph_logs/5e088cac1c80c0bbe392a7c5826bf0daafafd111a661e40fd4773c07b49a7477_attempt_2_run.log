theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let m := 2 * n + 1
  let S := ∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1)) * 8 ^ k
  have hS_eq : ∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1)) * 2 ^ (3 * k) = S := by
    congr; ext; ring
  rw [hS_eq]
  let z : Zsqrtd 8 := ⟨1, 1⟩
  have h_im : (z ^ m).im = S := by
    rw [add_pow]
    simp only [Zsqrtd.re_add_im, Zsqrtd.pow_im, map_sum]
    let f (i : ℕ) := m.choose i * (⟨0, 1⟩ ^ i : Zsqrtd 8).im
    trans ∑ i ∈ (Finset.range (m + 1)).filter Odd, f i
    · rw [← Finset.sum_filter_add_sum_filter_not (Finset.range (m + 1)) Odd]
      suffices ∑ i ∈ (Finset.range (m + 1)).filter (¬ Odd ·), f i = 0 by simp [this]
      apply Finset.sum_eq_zero; intro x hx; simp at hx
      obtain ⟨k, rfl⟩ := Nat.even_iff_not_odd.mpr hx.2
      have : (⟨0, 1⟩ ^ (2 * k) : Zsqrtd 8).im = 0 := by
        rw [pow_mul, show (⟨0, 1⟩ : Zsqrtd 8) ^ 2 = 8 by rfl]
        exact Zsqrtd.coe_int_im _
      simp [f, this]
    · apply Finset.sum_bij (λ k _ ↦ 2 * k + 1)
      · intros; simp [m]; linarith
      · intros; linarith
      · intro b hb; simp at hb; use (b - 1) / 2; simp [m]
        constructor <;> try linarith
