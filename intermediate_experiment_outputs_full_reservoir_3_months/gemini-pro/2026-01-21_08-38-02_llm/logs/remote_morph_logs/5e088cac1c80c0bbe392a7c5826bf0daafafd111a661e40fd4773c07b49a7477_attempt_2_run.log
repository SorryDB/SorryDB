  -- M^2 - 2M - 2I = 0 => M^(m+2) = 2 M^(m+1) + 2 M^m
  have h_rec : ∀ m, s (m + 2) = 2 * s (m + 1) + 2 * s m := by
    intro m
    have h_cayley : M ^ 2 = 2 • M + 2 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
      decide
    have h_pow : M ^ (m + 2) = M ^ m * M ^ 2 := by rw [pow_add, Matrix.mul_eq_mul]
    rw [h_cayley, Matrix.mul_add, Matrix.mul_smul, Matrix.mul_smul, Matrix.mul_one] at h_pow
    -- Extract (1, 0) component
    have eq := congr_fun (congr_fun h_pow 1) 0
    simp [Matrix.add_apply, Matrix.smul_apply] at eq
    rw [h_ind, h_ind, h_ind] at eq
    exact eq

  -- The sequence s m is 0 iff m is a multiple of 6
  have h_per : ∀ m, s m = 0 ↔ m % 6 = 0 := by
    intro m
    induction m using Nat.strong_induction_on with | h m ih =>
    match m with
    | 0 => simp [s]
    | 1 => simp [s]
    | 2 => simp [s, Nat.choose, Finset.range, Finset.sum_insert]
    | 3 => simp [s]; decide
    | 4 => simp [s]; decide
    | 5 => simp [s]; decide
    | n + 6 =>
