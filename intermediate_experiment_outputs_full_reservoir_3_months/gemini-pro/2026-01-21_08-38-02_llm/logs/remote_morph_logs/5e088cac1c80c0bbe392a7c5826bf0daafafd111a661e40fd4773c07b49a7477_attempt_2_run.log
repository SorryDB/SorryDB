theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  rw [← ZMod.int_cast_zmod_eq_zero_iff_dvd] at h
  let m := 2 * n + 1
  -- We identify the sum with the term of a linear recurrence sequence modulo 5.
  -- Let M = [[1, 3], [1, 1]]. We claim the sum is (M^m * [1, 0])_1.
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let u (k : ℕ) : ZMod 5 := (M ^ k *ᵥ ![1, 0]) 1

  -- We verify M^6 = 3I.
  have hM6 : M ^ 6 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by decide

  -- This implies u(k+6) = 3 * u(k).
  have h_per (k : ℕ) : u (k + 6) = 3 * u k := by
    simp only [u, Matrix.pow_add, Matrix.mulVec_mulVec]
    rw [hM6, Matrix.smul_mulVec, Matrix.one_mulVec]

  -- u(k) = 0 iff k is a multiple of 6.
  have h_zero (k : ℕ) : u k = 0 ↔ k % 6 = 0 := by
    induction k using Nat.strong_induction_on with | h k ih =>
    if hk : k < 6 then
      interval_cases k <;> native_decide
    else
      rw [not_lt] at hk
      let k' := k - 6
      have ek : k = k' + 6 := (Nat.sub_add_cancel hk).symm
      rw [ek, h_per, Nat.add_mod_right, ih k' (Nat.sub_lt_self (by decide) hk)]
      constructor
      · intro z; apply (mul_eq_zero.mp z).resolve_left (by decide)
      · intro z; rw [z, mul_zero]

  -- The sum corresponds to u(m).
  -- Note: 2^(3k) = 8^k = 3^k mod 5.
  -- The recurrence A_{k+1} = A_k + 3B_k, B_{k+1} = A_k + B_k matches Pascal's identity.
  have h_sum : (∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1) : ZMod 5) * 2 ^ (3 * k)) = u m := by
    sorry

  rw [h_sum] at h
  rw [h_zero] at h
  -- m = 2n+1 is odd, so not divisible by 6.
  have h_odd : m % 2 = 1 := by simp [m]
  have h_div : m % 6 = 0 → m % 2 = 0 := fun d => dvd_trans (by decide) (Nat.dvd_of_mod_eq_zero d)
  rw [← Nat.dvd_iff_mod_eq_zero] at h_div
  rw [h] at h_div
  rw [Nat.mod_eq_zero_of_dvd h_div] at h_odd
  contradiction
