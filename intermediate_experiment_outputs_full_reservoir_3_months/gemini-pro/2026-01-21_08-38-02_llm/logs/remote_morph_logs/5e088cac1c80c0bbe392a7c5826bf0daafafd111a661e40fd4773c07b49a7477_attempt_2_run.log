  have h_pow : M ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by decide
  let q := (2 * n + 1) / 6
  let r := (2 * n + 1) % 6
  have h_dec : 2 * n + 1 = 6 * q + r := Nat.div_add_mod _ _
  rw [h_dec, Matrix.pow_add, Matrix.pow_mul, h_pow, Matrix.smul_pow, Matrix.one_pow, Matrix.smul_mul, Matrix.one_mul, Matrix.mulVec_smul] at h_sum
