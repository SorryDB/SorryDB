theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  let m := 2 * n + 1
  let S := ∑ k ∈ Finset.range (n + 1), (Nat.choose m (2 * k + 1)) * (2^(3 * k))
  have h_mod : (S : ZMod 5) = 0 := by exact CharP.cast_eq_zero_iff (ZMod 5) 5 S |>.mpr h
  
  -- Rewrite sum in terms of 3^k (since 2^3 = 8 = 3 mod 5)
  have h_sum_eq : (S : ZMod 5) = ∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k := by
    apply Finset.sum_congr rfl
    intro k _
    rw [mul_pow, show (2 : ZMod 5) ^ 3 = 3 by norm_num, pow_mul]
    congr
  rw [h_sum_eq] at h_mod

  -- Define Matrix arithmetic
  let A : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let J : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  
  have hA : A = 1 + J := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  have hJ2 : J ^ 2 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  have hComm : Commute 1 J := Commute.one_left J

  -- Relate matrix power to the sum
  have h_pow : (A ^ m) 1 0 = (S : ZMod 5) := by
    rw [h_sum_eq, hA, add_pow_of_commute _ _ hComm]
    simp only [one_pow, mul_one, Matrix.add_apply, Finset.sum_add_distrib]
    
    -- We show the matrix sum matches the scalar sum
    -- The expansion is ∑ binom(m, k) J^k. 
    -- (J^k)_10 is 0 for even k, and 3^(k/2) for odd k.
    let f : ℕ → ZMod 5 := fun k => if k % 2 = 1 then 3 ^ (k / 2) else 0
    have h_term : ∀ k, (J ^ k) 1 0 = f k := fun k => by
      if hk : k % 2 = 1 then
        have ⟨j, hj⟩ : ∃ j, k = 2 * j + 1 := ⟨k / 2, (Nat.div_add_mod k 2).symm.trans (by rw [hk]; rfl)⟩
        rw [hj, pow_add, pow_mul, hJ2, pow_one]
        simp [Matrix.smul_pow, Matrix.smul_mul]
        rw [if_pos hk, hj]; simp
      else
        rw [Nat.mod_two_ne_one] at hk
        have ⟨j, hj⟩ : ∃ j, k = 2 * j := ⟨k / 2, (Nat.div_add_mod k 2).symm.trans (by rw [hk]; rfl)⟩
        rw [hj, pow_mul, hJ2]; simp [Matrix.smul_pow]
        rw [if_neg (by simp [hk])]; rfl
        
    rw [Finset.sum_congr rfl (fun k _ => by rw [Matrix.smul_apply, h_term k])]
    
    -- Filter to odd terms
    rw [← Finset.sum_filter_add_sum_filter (· % 2 = 1)]
