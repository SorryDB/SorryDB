theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  let m := 2 * n + 1
  let R := ZMod 5
  let S_nat := ∑ k ∈ Finset.range (n + 1), (Nat.choose m (2 * k + 1)) * (2^(3 * k))
  
  -- The assumption mod 5
  have hS : (S_nat : R) = 0 := by
    rw [Nat.cast_sum]
    convert Nat.cast_dvd_char_zero.2 h
    simp

  let M : Matrix (Fin 2) (Fin 2) R := !![1, 3; 1, 1]
  
  -- M^m has the form [A, 3B; B, A]
  have h_form : ∃ A B : R, M ^ m = !![A, 3 * B; B, A] := by
    induction' m with k ih
    · use 1, 0; simp
    · rcases ih with ⟨A, B, hk⟩
      use A + 3 * B, A + B
      rw [pow_succ, hk]
      ext i j; fin_cases i <;> fin_cases j <;> simp [M] <;> ring

  rcases h_form with ⟨A, B, hM_eq⟩
  
  -- Identify B with S_nat mod 5
  have hB_eq_S : B = S_nat := by
    let K : Matrix (Fin 2) (Fin 2) R := !![0, 3; 1, 0]
    have hM_K : M = 1 + K := by ext i j; fin_cases i <;> fin_cases j <;> simp [M, K, Matrix.one_apply] <;> rfl
    have hK2 : K ^ 2 = (3 : R) • (1 : Matrix (Fin 2) (Fin 2) R) := by ext i j; fin_cases i <;> fin_cases j <;> simp [K, Matrix.one_apply] <;> rfl
    
    have hK_pow : ∀ k, K^k = if k % 2 = 1 then (3^(k/2)) • K else (3^(k/2)) • (1 : Matrix _ _ _) := by
      intro k; induction' k with k ih
      · simp
      · rw [pow_succ, ih]; split_ifs with h1 h2
        · simp [h1]; rw [hK2, smul_smul, mul_comm]; congr; omega
        · simp [h1]; rw [Matrix.smul_mul, Matrix.one_mul]; congr; omega

    have h_exp : M ^ m = ∑ i ∈ Finset.range (m + 1), (m.choose i : R) • K ^ i := by
       rw [hM_K, Commute.add_pow (by simp [Commute, SemiconjBy, K, hM_K]) m]; rfl
       
    have hB_val : B = (M ^ m) 1 0 := by rw [hM_eq]; rfl
    rw [hB_val, h_exp, Matrix.sum_apply]
    
    rw [←Finset.sum_filter_add_sum_filter (· % 2 = 1)]
    simp only [Matrix.smul_apply]
    
    have : ∑ x ∈ Finset.range (m + 1) with x % 2 ≠ 1, (m.choose x : R) * (K ^ x) 1 0 = 0 := by
      apply Finset.sum_eq_zero; intro x hx; rw [hK_pow]; split_ifs with h_odd
      · simp at hx; contradiction
      · simp [Matrix.one_apply]
    rw [this, zero_add, Nat.cast_sum]
    
    apply Finset.sum_bij (fun k _ => 2 * k + 1)
    · intros; simp; omega
    · intros k _; simp; rw [hK_pow]; simp;
      have : (2 : R) ^ (3 * k) = 3 ^ k := by rw [pow_mul]; norm_num
      rw [this]
    · intros; omega
    · intros b hb; simp at hb; exists (b-1)/2; simp [hb.2]; omega
    
  rw [hS] at hB_eq_S
  rw [hB_eq_S] at hM_eq
  
  -- Use determinant to derive contradiction
  have h_det : (M ^ m).det = 3 ^ m := by
    rw [Matrix.det_pow]; have : M.det = 3 := by rw [Matrix.det_fin_two]; simp [M]; ring
    rw [this]
    
  rw [hM_eq] at h_det
  simp [Matrix.det_fin_two] at h_det
  
  -- A^2 = 3 * 3^(2n) implies 3 is a square mod 5
  have : IsSquare (3 : R) := by
    use A * (3 ^ n)⁻¹
    rw [mul_pow, ←h_det, pow_mul, pow_two, inv_pow, mul_assoc, mul_inv_cancel, mul_one]
    apply pow_ne_zero; norm_num

  have : ¬ IsSquare (3 : R) := by decide
  contradiction
