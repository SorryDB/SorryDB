theorem infinity_of_primes₄ : Tendsto π atTop atTop := by
  -- two parts:
  -- (1) log x ≤ π x + 1
  -- (2) This implies that it is not bounded
  have H_log_le_primeCountingReal_add_one (n : ℕ) (x : ℝ) (hxge : x ≥ n) (hxlt : x < n + 1) :
      Real.log x ≤ primeCountingReal x + 1 :=
    calc
      Real.log x ≤ ∑ k ∈ Icc 1 n, (k : ℝ)⁻¹ := by sorry
      _ ≤ (∑' m : (S₁ x), (m : ℝ)⁻¹) := by sorry
      _ ≤ (∏ p ∈ primesBelow ⌊x⌋.natAbs, (∑' k : ℕ, (p ^ k : ℝ)⁻¹)) := by sorry
      _ ≤ primeCountingReal x + 1 := by
        refine le_trans (Finset.prod_le_prod (fun _ _ ↦ by positivity) (fun p hp ↦ ?_)) ?_
        · rw [tsum_geometric_of_lt_one (inv_nonneg.mpr (Nat.cast_nonneg p))]
          · rw [inv_eq_one_div, one_div, one_sub_inv] <;> field_simp [Nat.Prime.ne_zero (prime_of_mem_primesBelow hp)]
          · rw [inv_lt_one_iff_of_pos] <;> norm_cast <;> exact (prime_of_mem_primesBelow hp).pos
        · let n := ⌊x⌋.natAbs
          have : ∏ p ∈ primesBelow n, (p : ℝ) / (p - 1) ≤ (primesBelow n).card + 1 := by
            induction n with
            | zero => simp
            | succ n ih =>
              rw [primesBelow_succ]
              split_ifs with h
              · rw [Finset.prod_insert (not_mem_primesBelow n), Finset.card_insert_of_not_mem (not_mem_primesBelow n), Nat.cast_add, Nat.cast_one]
                calc (n : ℝ) / (n - 1) * ∏ p ∈ primesBelow n, (p : ℝ) / (p - 1)
                  ≤ (n / (n - 1) : ℝ) * ((primesBelow n).card + 1) := by gcongr
                _ = (1 + 1 / (n - 1) : ℝ) * ((primesBelow n).card + 1) := by field_simp; ring
                _ ≤ (primesBelow n).card + 1 + 1 := by
                   rw [mul_add, mul_one, add_le_add_iff_left]
                   apply (div_le_one (sub_pos_of_lt (Nat.Prime.one_lt h))).mpr
                   norm_cast
                   exact (primeCounting_le (n-1)).trans (Nat.le_pred_of_lt (Nat.Prime.one_lt h))
              · exact ih
          exact this.trans (Nat.cast_le_cast.mpr (Nat.add_le_add_right (le_primeCounting _ _) _))
