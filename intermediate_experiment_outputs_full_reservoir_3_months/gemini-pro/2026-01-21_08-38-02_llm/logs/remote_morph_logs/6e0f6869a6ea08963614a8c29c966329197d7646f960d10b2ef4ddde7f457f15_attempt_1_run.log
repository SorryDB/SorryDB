def eq_eq_beq (x : BitVec w) (y : BitVec w) : (x = y) = x.beq y := by
  apply propext
  constructor
  · rintro rfl
    unfold beq
    induction w - 1 <;> simp [beq.go, *]
  · intro h
    apply eq_of_getLsbD_eq
    intro i hi
    unfold beq at h
    generalize hk : w - 1 = k at h
    suffices ∀ k, beq.go w x y k → (w - 1) - k ≤ i → i ≤ w - 1 → x.getLsbD i = y.getLsbD i by
      apply this k h
      · rw [← hk, Nat.sub_self]; exact Nat.zero_le _
      · rw [← hk]; cases w; contradiction; exact Nat.le_of_lt_succ hi
    intro k hk h_lo h_hi
    induction k generalizing i with
    | zero =>
      simp [beq.go] at hk
      have : i = w - 1 := Nat.le_antisymm h_hi h_lo
      subst this; exact hk
    | succ k ih =>
      simp [beq.go] at hk
      cases Nat.eq_or_lt_of_le h_lo with
      | inl h_eq => subst h_eq; exact hk.1
      | inr h_lt => rw [Nat.sub_succ] at h_lt; exact ih hk.2 (Nat.le_of_lt_succ h_lt) h_hi
```
