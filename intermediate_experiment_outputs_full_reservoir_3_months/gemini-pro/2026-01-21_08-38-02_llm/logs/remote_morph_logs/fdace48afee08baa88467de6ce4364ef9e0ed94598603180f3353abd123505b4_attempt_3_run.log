ρ : MState (H i)
σ : (n : ℕ) → ↑IsFree
ε ε' : Prob
hε'₁ : 0 < ε'
hε'₂ : ε' < ε
hε : ε < 1
hR1R2 : R1 ρ ε < R2 ρ σ
hR1 : R1 ρ ε ≠ ⊤
hR2 : R2 ρ σ ≠ ⊤
hε₀✝ : 0 < ε₀_func ρ ε σ ε'
m : ℕ
hm : m ≥ 1 ∧ 𝐃(ρ⊗^S[m]‖↑(σ m)) / ↑m < R2 ρ σ + ↑⟨ε₀_func ρ ε σ ε', ⋯⟩
ℰ : (n : ℕ) → CPTPMap (H (i ^ n)) (H (i ^ n)) ℂ := fun n => pinching_map (σ'' ρ ε m σ n)
ε₀ : ℝ := ε₀_func ρ ε σ ε'
hε₀ : 0 < ε₀
hε₀' : (R1 ρ ε).toReal ≤ (R2 ρ σ).toReal + ε₀
hliminf_le : Filter.liminf (fun n => —log β_ ε ((ℰ n) (ρ⊗^S[n])‖{σ'' ρ ε m σ n}) / ↑n) Filter.atTop ≤ ↑(R1 ρ ε).toNNReal
hlimsup_le :
  ∀ (ε1 : Prob),
    0 < ↑ε1 ∧ ↑ε1 < 1 →
      Filter.limsup (fun n => —log β_ 1 - ε1 ((ℰ n) (ρ⊗^S[n])‖{σ'' ρ ε m σ n}) / ↑n) Filter.atTop ≤
        ↑((R2 ρ σ).toNNReal + ⟨ε₀, ⋯⟩)
P1 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ :=
  fun ε2 n => {Real.exp (↑n * ((R1 ρ ε).toReal + ε2)) • ↑(σ'' ρ ε m σ n) ≤ₚ ↑((ℰ n) (ρ⊗^S[n]))}
P2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ :=
  fun ε2 n => {Real.exp (↑n * ((R2 ρ σ).toReal + ε₀ + ε2)) • ↑(σ'' ρ ε m σ n) ≤ₚ ↑((ℰ n) (ρ⊗^S[n]))}
hPcomm : ∀ (ε2 : ℝ) (n : ℕ), Commute ↑(P1 ε2 n) ↑(P2 ε2 n)
E1 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := 1 - P1
E2 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := P1 - P2
E3 : ℝ → (n : ℕ) → HermitianMat (H (i ^ n)) ℂ := P2
Esum : E1 + E2 + E3 = 1
hE1proj :
  ∀ (ε2 : ℝ) (n : ℕ), E1 ε2 n = {↑((ℰ n) (ρ⊗^S[n])) <ₚ Real.exp (↑n * ((R1 ρ ε).toReal + ε2)) • ↑(σ'' ρ ε m σ n)}
hE2leProj :
  ∀ (ε2 : ℝ) (n : ℕ), E2 ε2 n ≤ {↑((ℰ n) (ρ⊗^S[n])) <ₚ Real.exp (↑n * ((R2 ρ σ).toReal + ε₀ + ε2)) • ↑(σ'' ρ ε m σ n)}
c' : ℝ → ℕ → ℝ := fun ε2 n => max (σ₁_c i n + σ₁_c i n / ↑n) ((R2 ρ σ).toReal + ε₀ + ε2)
hc' : ∀ (ε2 : ℕ → ℝ≥0), (∀ (n : ℕ), ε2 n < 1) → ∃ C, ∀ᶠ (n : ℕ) in Filter.atTop, c' (↑(ε2 n)) n ≤ ↑C
hσ'' : ∀ (ε2 : ℝ) (n : ℕ), Real.exp (-↑n * c' ε2 n) • 1 ≤ ↑(σ'' ρ ε m σ n)
hE3commℰ : ∀ (ε2 : ℝ) (n : ℕ), Commute ↑(E3 ε2 n) ↑(↑((ℰ n) (ρ⊗^S[n]))).log
ε2 : ℝ
n : ℕ
hε2 : 0 < ε2
hn : 0 < n
hE3leq : (1 / ↑n) • ↑(E3 ε2 n) * (↑(↑((ℰ n) (ρ⊗^S[n]))).log - ↑(↑(σ'' ρ ε m σ n)).log) ≤ c' ε2 n • ↑(E3 ε2 n)
⊢ 0 ≤
    (R1 ρ ε).toReal - (R1 ρ ε).toReal * (↑((ℰ n) (ρ⊗^S[n]))).inner (P1 ε2 n) +
      (ε2 - ε2 * (↑((ℰ n) (ρ⊗^S[n]))).inner (P2 ε2 n))

