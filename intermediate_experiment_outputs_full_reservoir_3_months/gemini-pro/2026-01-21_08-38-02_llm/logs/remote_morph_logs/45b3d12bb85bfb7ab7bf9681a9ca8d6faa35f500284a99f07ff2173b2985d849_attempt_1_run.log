-- 12.
lemma subset_of_val_image_eq {U : Type} {A : Set U} {X1 X2 : Set A}
    (h : val_image A X1 = val_image A X2) : X1 ⊆ X2 := by
  intro x hx
  have : x.val ∈ val_image A X2 := by rw [← h]; exact ⟨x, hx, rfl⟩
  cases this with | intro x' h' =>
    rw [← Subtype.eq h'.2]
    exact h'.1
