hyp : ∃ x, ∃ (_ : 4 < x), ∃ x_1, ∃ (_ : allExpert (after x_1)), x_1.length < 2 * x - 4
m : ℕ
m_is_minimal : ∀ n < m, ¬∃ (_ : 4 < n), ∃ x, ∃ (_ : allExpert (after x)), x.length < 2 * n - 4
le_m : 4 < m
S : List (Call m)
S_allExp : allExpert (after S)
S_len_lt : S.length ≤ 2 * m - 5
is_minimal_m : is_minimal m
noHo_S : noHo S
initPart : List (Call m) := List.filter (fun c => isInitialCall S c) S
midPart : List (Call m) := List.filter (fun c => decide (¬isInitialCall S c = true ∧ ¬isFinalCall S c = true)) S
finalPart : List (Call m) := List.filter (fun c => isFinalCall S c) S
this : S.length = initPart.length + midPart.length + finalPart.length
h_both : ∀ c ∈ initPart, isAgentInitialCall S c.1 c = true ∧ isAgentInitialCall S c.2 c = true
h_count : 2 * initPart.length = m
⊢ m / 2 = initPart.length
