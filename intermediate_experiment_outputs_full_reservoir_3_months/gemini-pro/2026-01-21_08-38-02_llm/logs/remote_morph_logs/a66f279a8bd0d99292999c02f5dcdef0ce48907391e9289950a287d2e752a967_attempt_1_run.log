lemma IsBernoulliOn.sdiff (hX : IsBernoulliOn X u p P) :
    IsBernoulliOn (fun ω ↦ u \ X ω) u (σ p) P where
  map_eq := by
    rw [Measure.map_map_of_aemeasurable (by fun_prop) hX.aemeasurable, hX.map_eq,
      bernoulliOn_eq_map, bernoulliOn_eq_map, Measure.map_map]
    · congr 1
      rw [← Measure.map_map MeasurableEquiv.setOf.measurable]
      · congr 1
        rw [map_infinitePi]
        · congr with i
          simp only [Measure.map_add, Measure.map_smul, Measure.map_dirac]
          by_cases hi : i ∈ u <;> simp [hi, unitInterval.symm_symm, add_comm]
        · fun_prop
      · fun_prop
    · fun_prop
    · exact MeasurableEquiv.setOf.measurable
