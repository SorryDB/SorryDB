    [MeasurableSpace ι]
    (hX1 : HasLocallyIntegrableSup X 𝓕 P) (hX2 : Adapted 𝓕 X) (h𝓕 : 𝓕.IsRightContinuous) :
    Locally (ClassDL · 𝓕 P) 𝓕 X P := by
  rcases hX1 with ⟨T, hT_stop, hT_tendsto, hX_int⟩
  refine ⟨T, hT_stop, hT_tendsto, fun n ↦ ?_⟩
  refine MeasureTheory.Integrable.classDL fun t ↦ ?_
  apply Integrable.mono ((hX_int n).2 t)
  · have h_meas := (Adapted.stoppedProcess hX2 (hT_stop n) t).mono (𝓕.le t)
    exact (Measurable.ennnorm h_meas).aestronglyMeasurable
  · exact Eventually.of_forall fun ω ↦ le_iSup₂_of_le t le_rfl le_rfl
