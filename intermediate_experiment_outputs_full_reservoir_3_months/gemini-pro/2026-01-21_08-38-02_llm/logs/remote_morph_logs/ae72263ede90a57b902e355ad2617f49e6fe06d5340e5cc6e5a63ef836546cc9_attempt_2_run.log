/-- The quotient spaces that orbifolds are modelled on are locally compact. -/
instance {n : ℕ} {Γ : {Γ : Subgroup ((Eucl n) ≃ₗ[ℝ] (Eucl n)) | Finite Γ}} :
    LocallyCompactSpace (MulAction.orbitRel.Quotient Γ (Eucl n)) := by
  let π : Eucl n → MulAction.orbitRel.Quotient Γ (Eucl n) := Quotient.mk _
  have hπ : IsOpenMap π := fun u hu ↦ by
    rw [isOpen_coinduced, MulAction.quotient_preimage_image_eq_union_mul]
    exact isOpen_iUnion fun g ↦ (g.1.toHomeomorph).isOpenMap u hu
  exact hπ.locallyCompactSpace Quotient.exists_rep continuous_quotient_mk
```
