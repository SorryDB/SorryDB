      let bV := b.map (Submodule.subtype _)
      let M := LinearMap.toMatrix bV bV φ
      let M_inv := LinearMap.toMatrix bV bV φ.symm
      -- Entries are integral for almost all v
      have h_int (x : ℚ) : ∀ᶠ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ) in Filter.cofinite,
          x ∈ v.adicCompletionIntegers ℚ :=
        NumberField.IsDedekindDomain.HeightOneSpectrum.mem_adicCompletionIntegers_eventually x
      filter_upwards [
        (fun i j ↦ h_int (M i j)) |> Finset.univ.eventually_all,
        (fun i j ↦ h_int (M_inv i j)) |> Finset.univ.eventually_all
      ] with v hM hMinv
      -- Reduce to matrix action on the lattice
      apply Set.BijOn_iff_mapsTo_mapsTo_inv.mpr
      constructor
      all_goals
        intro x hx
        simp only [AddMonoidHom.coe_comp, AddMonoidHom.coe_coe, LinearMap.coe_toAddMonoidHom,
          LinearMap.lTensor_toAddMonoidHom, Function.comp_apply, LinearMap.mem_range,
          LinearMap.lTensor_tmul, Submodule.subtype_apply] at hx ⊢
        obtain ⟨y, rfl⟩ := hx
        -- Pull back to L ⊗ K_v, apply M (or M_inv), push forward
        -- Since M has integral entries, it preserves the integral lattice structure
        let φ_base := (Aux.c_v_alg V v).symm.trans ((Aux.continuousBaseChange V v φ).toLinearEquiv.trans (Aux.c_v_alg V v))
        have h_act : ∀ z, Aux.continuousBaseChange V v φ ((Aux.c_v_alg V v) z) = (Aux.c_v_alg V v) (φ_base z) :=
