/-- The product of the local components φᵥ of a linear map φ. -/
noncomputable def prodLocalComponents (φ : V ≃ₗ[ℚ] V) : (V ⊗[ℚ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [V ⊗[ℚ] v.adicCompletion ℚ,
        (((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range)]) ≃ₜ+
    (V ⊗[ℚ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [V ⊗[ℚ] v.adicCompletion ℚ,
        (((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range)]) :=
  -- this is defined to be ∏'ᵥ φᵥ
  .sumCongr (continuousBaseChange _ φ).toContinuousAddEquiv
    (ContinuousAddEquiv.restrictedProductCongrRight
      (fun v ↦ (continuousBaseChange _ φ).toContinuousAddEquiv) (by
      let b := Module.Basis.ofVectorSpace ℚ V
      let M := LinearMap.toMatrix b b φ
      let Minv := LinearMap.toMatrix b b φ.symm
      let S := (Finset.univ.product Finset.univ).toSet.iUnion fun (i, j) ↦
        {v : IsDedekindDomain.HeightOneSpectrum (RingOfIntegers ℚ) |
          ‖(algebraMap ℚ (v.adicCompletion ℚ) (M i j))‖ > 1} ∪
        {v : IsDedekindDomain.HeightOneSpectrum (RingOfIntegers ℚ) |
          ‖(algebraMap ℚ (v.adicCompletion ℚ) (Minv i j))‖ > 1}
      have hS : S.Finite := by
        apply Set.Finite.iUnion; intro; apply Set.Finite.union
        all_goals
          apply Set.Finite.subset (IsDedekindDomain.HeightOneSpectrum.finite_valuation_ne_zero ℚ _)
          intro v hv
          rw [norm_gt_one_iff_valuation_lt_zero] at hv
          exact ne_of_lt hv
      filter_upwards [Filter.eventually_cofinite.mpr hS] with v hv
      simp only [Set.mem_diff, Set.mem_iUnion, Set.mem_union, not_exists, not_or, not_and,
        Set.mem_product, Set.mem_toSet, Finset.mem_univ, true_and] at hv
      let bL := IntegralLattice.basis ℤ ℚ V
      let L_v := ((Aux.c_v_alg V v).toAddMonoidHom.comp
        (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range
      let gen (i : Module.Basis.ofVectorSpaceIndex ℚ V) : V ⊗[ℚ] v.adicCompletion ℚ := b i ⊗ₜ[ℚ] 1
      have span_subset (f : V ≃ₗ[ℚ] V) (Mf : Matrix _ _ ℚ)
          (hM : ∀ i j, ‖(algebraMap ℚ (v.adicCompletion ℚ) (Mf i j))‖ ≤ 1) :
          ∀ x ∈ L_v, (Aux.continuousBaseChange V f x) ∈ L_v := by
        rintro _ ⟨x, rfl⟩
        induction x using TensorProduct.induction_on with
        | zero => simp
        | add x y hx hy => simp [hx, hy]
        | tmul l a =>
          simp only [map_tmul, ContinuousLinearEquiv.baseChange_apply]
          rw [← bL.sum_repr l, TensorProduct.sum_tmul, map_sum]
          refine AddSubmonoid.sum_mem _ (fun i _ ↦ ?_)
          rw [TensorProduct.smul_tmul, ContinuousLinearEquiv.baseChange_apply,
            LinearMap.map_smul, LinearMap.map_sum]
          rw [show (f : V →ₗ[ℚ] V) (b i) = ∑ j, Mf j i • b j from (LinearMap.toMatrix_apply _ _ _).symm]
          rw [TensorProduct.sum_tmul]
          refine AddSubmonoid.sum_mem _ (fun j _ ↦ ?_)
          rw [TensorProduct.smul_tmul', TensorProduct.tmul_smul]
          refine ⟨(bL.repr l i) • Mf j i • a • bL j ⊗ₜ[ℤ] 1, ?_⟩
          simp only [AddMonoidHom.coe_comp, AddMonoidHom.coe_coe, Function.comp_apply,
            LinearMap.lTensor_tmul, Submodule.coe_subtype, Submodule.coe_toIntLinearMap,
            Aux.c_v_alg, Module.Basis.baseChangeEquiv'_apply, LinearMap.map_smul]
          simp only [← TensorProduct.smul_tmul, ← TensorProduct.tmul_smul]
          simp only [TensorProduct.RightActions.Module.TensorProduct.comm_tmul,
            Algebra.TensorProduct.tmul_mul_tmul]
          simp only [mul_one, one_mul]
          rw [mul_comm a, mul_comm _ a, mul_assoc]
          congr 1
          norm_cast
          exact Subring.mul_mem _ (Subring.mul_mem _ (Subring.mem_top _) (by
            rw [← norm_le_one_iff_val_mem]; exact hM j i)) (Subring.mem_top _)
      apply Set.BijOn_of_subset_of_subset
      · exact span_subset φ M (fun i j ↦ by
          specialize hv i j; rw [← norm_le_one_iff_val_mem]; exact not_lt.mp hv.1)
      · exact span_subset φ.symm Minv (fun i j ↦ by
          specialize hv i j; rw [← norm_le_one_iff_val_mem]; exact not_lt.mp hv.2)
      ))
