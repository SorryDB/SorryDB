        rfl
      rw [hS, Set.bijOn_iff_mapsTo_surjOn]
      refine ⟨fun x hx ↦ ?_, fun x hx ↦ ?_⟩
      · apply Submodule.span_induction hx
        · rintro _ ⟨i, rfl⟩
          simp only [ContinuousLinearEquiv.baseChange_apply]
          rw [LinearMap.toMatrix_apply]
          simp only [sum_tmul, map_sum, TensorProduct.smul_tmul']
          refine Submodule.sum_mem _ fun j _ ↦ ?_
