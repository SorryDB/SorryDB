        let g : V ⊗[ℚ] v.adicCompletion ℚ ≃L[v.adicCompletion ℚ] V ⊗[ℚ] v.adicCompletion ℚ :=
          continuousBaseChange _ φ.symm
        have hg_maps : Set.MapsTo g S S := by
          intro x hx
          apply Submodule.span_induction hx
          · rintro _ ⟨i, rfl⟩
            simp only [g, ContinuousLinearEquiv.baseChange_apply]
            rw [LinearMap.toMatrix_symm_apply]
            simp only [sum_tmul, map_sum, TensorProduct.smul_tmul']
            refine Submodule.sum_mem _ fun j _ ↦ ?_
            refine Submodule.smul_mem _ ?_ (Submodule.subset_span ⟨j, rfl⟩)
            rw [← IsDedekindDomain.HeightOneSpectrum.valuation_eq_intValuation] at h_entries_inv
            exact h_entries_inv j i
          · simp
          · intro _ _ h1 h2; exact Submodule.add_mem _ h1 h2
          · intro a _ h; exact Submodule.smul_mem _ a h
        intro x hx
