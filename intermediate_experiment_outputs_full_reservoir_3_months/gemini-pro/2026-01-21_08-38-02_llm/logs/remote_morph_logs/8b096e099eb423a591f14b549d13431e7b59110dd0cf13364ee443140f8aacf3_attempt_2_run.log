      · intro x hx
        obtain ⟨c, rfl⟩ := Submodule.mem_span_range_iff_exists_fun.mp hx
        have : (Aux.continuousBaseChange v φ).symm = Aux.continuousBaseChange v φ.symm := rfl
        rw [this]
        refine Submodule.mem_span_range_iff_exists_fun.mpr ⟨fun i ↦ ∑ j, c j * M' j i, ?_⟩
        simp only [ContinuousLinearEquiv.baseChange_apply, map_sum, map_smul, TensorProduct.tmul_smul,
          LinearMap.toMatrix_apply, TensorProduct.sum_tmul, TensorProduct.tmul_sum, smul_smul, mul_comm]
        simp_rw [mul_comm (c _)]
        rw [Finset.sum_comm]))
