        have h : m.det ≠ 0 := by rw [LinearMap.det_toMatrix]; exact (LinearEquiv.det φ).isUnit.ne_zero
        filter_upwards [(IsDedekindDomain.HeightOneSpectrum.finite_places_of_ne_one _ h).eventually_cofinite] with v hv
        rw [← IsDedekindDomain.HeightOneSpectrum.valuation_eq_intValuation]
        exact hv
      filter_upwards [Filter.forall_finite_index_eventually h_entries, h_det] with v hv_entries hv_det
      let R := (v.adicCompletionIntegers ℚ)
      let S : Submodule R (V ⊗[ℚ] v.adicCompletion ℚ) := Submodule.span R (Set.range (fun i ↦ b i ⊗ₜ[ℚ] (1 : v.adicCompletion ℚ)))
      have hS : (((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V) (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range) = S := by
