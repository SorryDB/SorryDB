      let S := (((@Aux.c_v_alg V inst✝¹⁰ inst✝¹ v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V) (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range)
      have hS : S = Submodule.span (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ v) (Set.range fun i ↦ bV i ⊗ₜ[ℚ] (1 : IsDedekindDomain.HeightOneSpectrum.adicCompletion ℚ v)) := by
        rw [← Submodule.map_span]
        congr
        ext x
        simp only [LinearMap.lTensor, Set.mem_range, Set.mem_image, Submodule.mem_span_range_iff_exists_fun]
        constructor
        · rintro ⟨y, hy, rfl⟩
          obtain ⟨c, rfl⟩ := b.mem_span_iff_repr_sum.mp y
          use fun i ↦ c i
