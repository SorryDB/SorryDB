          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range)]) :=
  -- this is defined to be ∏'ᵥ φᵥ
  .sumCongr (continuousBaseChange _ φ).toContinuousAddEquiv
    (ContinuousAddEquiv.restrictedProductCongrRight
      (fun v ↦ (continuousBaseChange _ φ).toContinuousAddEquiv) (by
      classical
      let b := IntegralLattice.basis ℤ ℚ V
      let bV : Basis (Fin (FiniteDimensional.finrank ℚ V)) ℚ V :=
        Basis.mk b.indexEquiv (fun i ↦ b i) (by
          have : LinearIndependent ℤ (fun i ↦ (b i : V)) :=
            LinearIndependent.map' b.linearIndependent (Submodule.subtype _) (Submodule.ker_subtype _)
          exact this.map_fraction_ring ℚ)
      let f := LinearMap.toMatrix bV bV
      let is_int (A : Matrix _ _ ℚ) (v : HeightOneSpectrum (𝓞 ℚ)) :=
        ∀ i j, v.valuation (A i j) ≤ 1
      have h_fin (A : Matrix _ _ ℚ) : {v | ¬ is_int A v}.Finite := by
        simp only [is_int, not_forall, not_le]
        refine Set.Finite.biUnion Set.finite_univ (fun i _ ↦ Set.Finite.biUnion Set.finite_univ (fun j _ ↦ ?_))
        exact IsDedekindDomain.HeightOneSpectrum.set_valuation_gt_one_finite _ _
      filter_upwards [(h_fin (f φ)).compl_mem_cofinite, (h_fin (f φ.symm)).compl_mem_cofinite] with v hφ hφinv
      simp only [Set.mem_compl_iff, Set.mem_setOf_eq, not_not] at hφ hφinv
      let M := ((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
        (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range
      let ψ := continuousBaseChange (v.adicCompletion ℚ) φ
      have h_map (g : V ≃ₗ[ℚ] V) (hg : is_int (f g) v) :
          Set.MapsTo (continuousBaseChange (v.adicCompletion ℚ) g) M M := by
        rintro _ ⟨x, rfl⟩
        induction x using TensorProduct.induction_on with
