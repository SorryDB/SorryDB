          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range)]) :=
  -- this is defined to be ∏'ᵥ φᵥ
  .sumCongr (continuousBaseChange _ φ).toContinuousAddEquiv
    (ContinuousAddEquiv.restrictedProductCongrRight
      (fun v ↦ (continuousBaseChange _ φ).toContinuousAddEquiv) (by
      let b := Module.Basis.ofVectorSpace ℚ V
      let m := LinearMap.toMatrix b b φ
      have h_entries : ∀ i j, ∀ᶠ v in Filter.cofinite, ‖m i j‖_[v] ≤ 1 := fun i j ↦ by
        rcases eq_or_ne (m i j) 0 with h | h
        · simp [h]; exact Filter.eventually_of_forall fun _ ↦ by simp
        · filter_upwards [(IsDedekindDomain.HeightOneSpectrum.finite_places_of_ne_one _ h).eventually_cofinite] with v hv
          rw [← IsDedekindDomain.HeightOneSpectrum.valuation_eq_intValuation]
          exact le_of_eq hv
