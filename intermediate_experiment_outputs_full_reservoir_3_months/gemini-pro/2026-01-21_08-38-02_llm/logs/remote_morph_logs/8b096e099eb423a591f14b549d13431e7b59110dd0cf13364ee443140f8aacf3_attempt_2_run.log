noncomputable def prodLocalComponents (φ : V ≃ₗ[ℚ] V) : (V ⊗[ℚ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [V ⊗[ℚ] v.adicCompletion ℚ,
        (((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range)]) ≃ₜ+
    (V ⊗[ℚ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [V ⊗[ℚ] v.adicCompletion ℚ,
        (((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range)]) :=
  -- this is defined to be ∏'ᵥ φᵥ
  .sumCongr (continuousBaseChange _ φ).toContinuousAddEquiv
    (ContinuousAddEquiv.restrictedProductCongrRight
      (fun v ↦ (continuousBaseChange _ φ).toContinuousAddEquiv) (by
      let e := Module.Basis.ofVectorSpace ℚ V
      let M := LinearMap.toMatrix e e φ
      let Minv := LinearMap.toMatrix e e φ.symm
      have h_int (x : ℚ) : ∀ᶠ v in Filter.cofinite, 
          algebraMap ℚ (v.adicCompletion ℚ) x ∈ v.adicCompletionIntegers ℚ := by
        by_cases hx : x = 0
        · simp [hx]; exact Filter.eventually_of_forall fun _ ↦ Subring.zero_mem _
        · have := IsDedekindDomain.HeightOneSpectrum.valuation_eq_one_of_ne_zero ℚ hx
          filter_upwards [this] with v hv
          rw [IsDedekindDomain.HeightOneSpectrum.mem_adicCompletionIntegers_iff_valuation_le_one, hv]
          exact le_refl _
      have h_M : ∀ᶠ v in Filter.cofinite, ∀ i j, 
        algebraMap ℚ _ (M i j) ∈ v.adicCompletionIntegers ℚ :=
        Filter.eventually_all.2 (fun i ↦ Filter.eventually_all.2 (fun j ↦ h_int (M i j)))
      have h_Minv : ∀ᶠ v in Filter.cofinite, ∀ i j, 
        algebraMap ℚ _ (Minv i j) ∈ v.adicCompletionIntegers ℚ :=
        Filter.eventually_all.2 (fun i ↦ Filter.eventually_all.2 (fun j ↦ h_int (Minv i j)))
      filter_upwards [h_M, h_Minv] with v hM hMinv
      let ψ := (continuousBaseChange (v.adicCompletion ℚ) φ).toLinearEquiv
      let S := Submodule.span (v.adicCompletionIntegers ℚ) (Set.range fun i ↦ e i ⊗ₜ[ℚ] (1 : v.adicCompletion ℚ))
      have h_maps (A : Module.Basis.ofVectorSpaceIndex ℚ V → Module.Basis.ofVectorSpaceIndex ℚ V → ℚ)
          (hA : ∀ i j, algebraMap ℚ _ (A i j) ∈ v.adicCompletionIntegers ℚ)
          (f : V ≃ₗ[ℚ] V) (hf : LinearMap.toMatrix e e f = A) :
          Set.MapsTo (continuousBaseChange (v.adicCompletion ℚ) f) S S := by
        intro x hx
        rw [Submodule.mem_span_range_iff_exists_fun] at hx ⊢
        obtain ⟨c, rfl⟩ := hx
        use fun j ↦ ∑ i, c i * algebraMap ℚ _ (A j i)
        simp [hf, continuousBaseChange_apply]
        conv_lhs => simp [← LinearMap.toMatrix_apply]
        simp [TensorProduct.tmul_sum, TensorProduct.smul_tmul', Finset.sum_smul]
        congr; ext; congr; ext; rw [mul_comm]
      convert Set.BijOn.mk (h_maps M hM φ rfl) (ψ.injective.injOn _) (fun x hx ↦ ?)
      · rw [LinearMap.range_comp, LinearEquiv.range, Submodule.map_top]
        exact (Module.Basis.baseChangeEquiv'_map_span _ _ _ _ _ _ _).symm
      · have : Set.MapsTo ψ.symm S S := h_maps Minv hMinv φ.symm rfl
        rw [Set.surjOn_iff_exists_map_subtype]
        exact ⟨ψ.symm x, this hx, ψ.apply_symm_apply x⟩))
