             TensorProduct.RightActions.Module.TensorProduct.comm_symm_apply]
          rw [show g (bV i) = ∑ j, f g j i • bV j from (Module.Basis.toMatrix_mul_vec_coords bV bV g (bV i)).symm]
          simp only [map_sum, map_smul, TensorProduct.smul_tmul']
          refine Submodule.sum_mem _ (fun j _ ↦ Submodule.smul_mem _ ?_ ⟨_, ⟨_, rfl⟩⟩)
          rwa [← val_le_one_iff_mem_adicCompletionIntegers]
        | add _ _ h1 h2 => simp [h1, h2]
      refine ⟨h_map φ hφ, fun y hy ↦ ?_, ψ.injective.injOn _⟩
      rw [← ψ.apply_symm_apply y]
      exact h_map φ.symm hφinv hy))
