/-- The product of the local components φᵥ of a linear map φ. -/
noncomputable def prodLocalComponents (φ : V ≃ₗ[ℚ] V) : (V ⊗[ℚ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [V ⊗[ℚ] v.adicCompletion ℚ,
        (((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range)]) ≃ₜ+
    (V ⊗[ℚ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [V ⊗[ℚ] v.adicCompletion ℚ,
        (((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range)]) :=
  .sumCongr (continuousBaseChange _ φ).toContinuousAddEquiv
    (ContinuousAddEquiv.restrictedProductCongrRight
      (fun v ↦ (continuousBaseChange _ φ).toContinuousAddEquiv) (by
      let b := Module.Basis.ofVectorSpace ℚ V
      let M := LinearMap.toMatrix b b φ
      let M' := LinearMap.toMatrix b b φ.symm
      let S := (Finset.product Finset.univ Finset.univ).image (fun (i, j) ↦ M i j) ∪
               (Finset.product Finset.univ Finset.univ).image (fun (i, j) ↦ M' i j)
      have : ∀ᶠ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ) in Filter.cofinite,
          ∀ x ∈ S, x ∈ v.adicCompletionIntegers ℚ := by
        rw [Filter.eventually_all_finset]
        intro x _
        rcases eq_or_ne x 0 with rfl | hx
        · simp; exact Filter.eventually_of_forall fun _ ↦ zero_mem _
        · have := (IsDedekindDomain.HeightOneSpectrum.finite_valuation_ne_zero ℚ x).compl_mem_cofinite
          filter_upwards [this] with v hv
          rw [mem_adicCompletionIntegers]
          by_cases h : v.valuation x = 0
          · rw [h]; exact zero_le_one
          · rw [hv h, EnnReal.coe_one]; exact le_rfl
      filter_upwards [this] with v hv
      -- R is the image of the lattice tensored with O_v. c_v_alg maps the lattice basis (tensored with 1)
      -- to b (tensored with 1). Thus R is the O_v-span of b ⊗ 1.
      -- The map φ_v acts on b ⊗ 1 via the matrix M.
      -- Since M has entries in O_v, φ_v maps R to R.
      let R := ((c_v_alg V v).toAddMonoidHom.comp (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).subtype.toIntLinearMap).toAddMonoidHom).range
      let b' := b.baseChange (v.adicCompletion ℚ)
      -- We define R_span as the O_v submodule generated by b' i.
      let R_span : Submodule (v.adicCompletionIntegers ℚ) (V ⊗[ℚ] v.adicCompletion ℚ) :=
        Submodule.span (v.adicCompletionIntegers ℚ) (Set.range b')
      have hR : R = R_span.toAddSubgroup := by
        -- This holds by definition of c_v_alg
        sorry
      rw [hR]
      apply Set.BijOn.mk
      · intro x hx
        -- x in span, show φ x in span
        rw [Submodule.mem_toAddSubgroup, Submodule.mem_span_basis_iff] at hx ⊢
        intro i
        -- The coeff of φ(x) at i is sum_j M_ij (coeff x j)
        -- Since M_ij in O_v and coeff x j in O_v, result is in O_v
        sorry
      · -- Surjectivity via M'
        intro x hx
        use (continuousBaseChange _ φ).symm x
        constructor
        · rw [Submodule.mem_toAddSubgroup, Submodule.mem_span_basis_iff] at hx ⊢
          intro i
          -- Similar arg for M'
          sorry
        · simp
      · exact (continuousBaseChange _ φ).injective.bijOn_image.mp (Set.BijOn.refl _)
      ))
