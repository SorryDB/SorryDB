      {idx1 : Fin l1.length} {idx2 : Fin l2.length} :
      l1[idx1] = l2[idx2] → (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2)
      := by
        revert idx1 idx2
        induction hPerm with
        | nil => intro ⟨_, _⟩; contradiction
        | cons x l1 l2 => sorry
        | swap x y l =>
          intro i j h
          simp only [List.length_cons] at i j
          have perm_cons_erase (l : List α) (k : Fin l.length) : (l[k] :: l.eraseIdx k).Perm l := by
            induction l with
            | nil => exact k.elim0
            | cons a as ih =>
              match k.val, k.isLt with
              | 0, _ => simp
              | k'+1, hk =>
                simp [List.eraseIdx_cons_succ]
                exact (List.Perm.swap a as[k'] _).trans (List.Perm.cons a (ih ⟨k', Nat.lt_of_succ_lt_succ hk⟩))
          have perm_erase_refl (l : List α) (k m : Fin l.length) (h : l[k] = l[m]) : (l.eraseIdx k).Perm (l.eraseIdx m) := by
            induction l with
            | nil => exact k.elim0
            | cons a as ih =>
              match k.val, m.val, k.isLt, m.isLt with
              | 0, 0, _, _ => simp
              | 0, m'+1, _, _ => simp at h; simp [List.eraseIdx_cons_succ]; rw [h]; exact perm_cons_erase as _
              | k'+1, 0, _, _ => simp at h; simp [List.eraseIdx_cons_succ]; rw [←h]; exact (perm_cons_erase as _).symm
              | k'+1, m'+1, hk, hm =>
                simp at h; simp [List.eraseIdx_cons_succ]
                exact List.Perm.cons a (ih ⟨k', Nat.lt_of_succ_lt_succ hk⟩ ⟨m', Nat.lt_of_succ_lt_succ hm⟩ h)
          rcases i with ⟨i, hi⟩; rcases j with ⟨j, hj⟩
          match i, j, hi, hj with
          | 0, 0, _, _ => simp; subst h; rfl
          | 0, 1, _, _ => simp [List.eraseIdx_cons_succ]; rfl
          | 1, 0, _, _ => simp [List.eraseIdx_cons_succ]; rfl
          | 1, 1, _, _ => simp [List.eraseIdx_cons_succ]; subst h; rfl
          | 0, j'+2, _, hj' =>
            simp at h; simp [List.eraseIdx_cons_succ]; rw [h]
            exact (perm_cons_erase l ⟨j', Nat.lt_of_succ_lt_succ (Nat.lt_of_succ_lt_succ hj')⟩).symm
          | i'+2, 0, hi', _ =>
            simp at h; simp [List.eraseIdx_cons_succ]; rw [←h]
            exact perm_cons_erase l ⟨i', Nat.lt_of_succ_lt_succ (Nat.lt_of_succ_lt_succ hi')⟩
          | 1, j'+2, _, hj' =>
            simp at h; simp [List.eraseIdx_cons_succ]
            exact (List.Perm.cons y (perm_cons_erase l ⟨j', Nat.lt_of_succ_lt_succ (Nat.lt_of_succ_lt_succ hj')⟩).symm).trans (List.Perm.swap x y _)
          | i'+2, 1, hi', _ =>
            simp at h; simp [List.eraseIdx_cons_succ]
            exact (List.Perm.swap x y _).trans (by rw [←h]; exact List.Perm.cons y (perm_cons_erase l ⟨i', Nat.lt_of_succ_lt_succ (Nat.lt_of_succ_lt_succ hi')⟩))
          | i'+2, j'+2, hi', hj' =>
            simp at h; simp [List.eraseIdx_cons_succ]
            exact (List.Perm.swap x y _).trans (List.Perm.cons x (List.Perm.cons y 
              (perm_erase_refl l ⟨i', Nat.lt_of_succ_lt_succ (Nat.lt_of_succ_lt_succ hi')⟩ ⟨j', Nat.lt_of_succ_lt_succ (Nat.lt_of_succ_lt_succ hj')⟩ h)))
