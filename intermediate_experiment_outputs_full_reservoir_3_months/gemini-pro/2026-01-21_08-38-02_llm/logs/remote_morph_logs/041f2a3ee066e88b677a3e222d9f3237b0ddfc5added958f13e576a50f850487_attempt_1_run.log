    theorem perm_eraseIdx {l1 l2 : List α} {hPerm : l1.Perm l2}
      {idx1 : Fin l1.length} {idx2 : Fin l2.length} :
      l1[idx1] = l2[idx2] → (l1.eraseIdx idx1).Perm (l2.eraseIdx idx2)
      := by
        revert idx1 idx2
        induction hPerm with
        | nil => intro ⟨_, _⟩; contradiction
        | cons x l1 l2 p ih => sorry
        | swap x y l =>
          intro i j h
          simp only [List.length_cons] at i j
          rcases i with ⟨i, hi⟩; rcases j with ⟨j, hj⟩
          have lem (l : List α) (k : Nat) (h : k < l.length) : l.Perm (l[k] :: l.eraseIdx k) := by
            induction l generalizing k with
            | nil => contradiction
            | cons x xs ih =>
              cases k with
              | zero => simp; apply List.Perm.refl
              | succ k =>
                simp; apply List.Perm.trans (List.Perm.cons x (ih k (Nat.lt_of_succ_lt_succ h)))
                apply List.Perm.swap
          simp at h
          match i, j, hi, hj with
          | 0, 0, _, _ => simp; exact List.Perm.refl _
          | 0, 1, _, _ => simp; exact List.Perm.refl _
          | 1, 0, _, _ => simp; exact List.Perm.refl _
          | 1, 1, _, _ => simp at h; simp [h]; exact List.Perm.refl _
          | 0, k+2, _, hk =>
             simp at h ⊢; rw [h]; apply List.Perm.cons; exact lem l k (Nat.lt_of_add_lt_add_right hk)
          | k+2, 0, hk, _ =>
             simp at h ⊢; rw [←h]; apply List.Perm.cons; apply List.Perm.symm; exact lem l k (Nat.lt_of_add_lt_add_right hk)
          | 1, k+2, _, hk =>
             simp at h ⊢; rw [←h]; apply List.Perm.swap.trans; apply List.Perm.cons; exact lem l k (Nat.lt_of_add_lt_add_right hk)
          | k+2, 1, hk, _ =>
             simp at h ⊢; rw [←h]; apply List.Perm.trans _ List.Perm.swap; apply List.Perm.symm; apply List.Perm.cons; exact lem l k (Nat.lt_of_add_lt_add_right hk)
          | n+2, m+2, hn, hm =>
             simp at h ⊢
             apply List.Perm.swap.trans; apply List.Perm.cons; apply List.Perm.cons
             have p1 := lem l n (Nat.lt_of_add_lt_add_right hn)
             have p2 := lem l m (Nat.lt_of_add_lt_add_right hm)
             rw [h] at p1
             exact p1.trans p2.symm |>.cons_inv
        | trans p1 p2 ih1 ih2 =>
          intro i k h
          obtain ⟨j, hj⟩ := in_list_idx (list_perm_in p1 _ (List.getElem_mem l1 i.1 i.2))
          exact (ih1 hj.symm).trans (ih2 (hj.trans h))
