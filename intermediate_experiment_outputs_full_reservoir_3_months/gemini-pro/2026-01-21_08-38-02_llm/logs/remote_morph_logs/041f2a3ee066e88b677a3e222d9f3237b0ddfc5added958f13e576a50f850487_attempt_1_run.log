          have perm_cons_eraseIdx (l : List α) (i : Fin l.length) : l.Perm (l[i] :: l.eraseIdx i) := by
            induction l with
            | nil => exact i.elim0
            | cons x xs ih =>
              match i.val, i.isLt with
              | 0, _ => simp [List.eraseIdx]; rfl
              | n+1, h =>
                simp [List.eraseIdx]
                apply List.Perm.trans (List.Perm.swap _ _ _)
                apply List.Perm.cons
                apply ih ⟨n, Nat.lt_of_succ_lt_succ h⟩
          have eraseIdx_perm_of_eq (l : List α) (i j : Fin l.length) (h : l[i] = l[j]) : l.eraseIdx i ~ l.eraseIdx j := by
            induction l with
            | nil => exact i.elim0
            | cons x xs ih =>
              let ⟨iv, ih_lt⟩ := i; let ⟨jv, jh_lt⟩ := j
              simp at h
              cases iv <;> cases jv
              · rfl
              · simp [List.eraseIdx]; simp at h; rw [h]; apply perm_cons_eraseIdx
              · simp [List.eraseIdx]; simp at h; rw [←h]; symmetry; apply perm_cons_eraseIdx
              · simp [List.eraseIdx]
                apply List.Perm.cons
                apply ih ⟨_, Nat.lt_of_succ_lt_succ ih_lt⟩ ⟨_, Nat.lt_of_succ_lt_succ jh_lt⟩
                simpa using h
          let ⟨i, hi⟩ := idx1; let ⟨j, hj⟩ := idx2
          simp at heq
          match i, j with
          | 0, 0 => simp [List.eraseIdx]; simp at heq; rw [heq]; rfl
          | 0, 1 => simp [List.eraseIdx]; rfl
          | 0, n+2 => simp [List.eraseIdx]; simp at heq; rw [heq]; apply perm_cons_eraseIdx
          | 1, 0 => simp [List.eraseIdx]; rfl
          | 1, 1 => simp [List.eraseIdx]; simp at heq; rw [heq]; rfl
          | 1, n+2 =>
            simp [List.eraseIdx]; simp at heq; rw [heq]
            apply List.Perm.trans (List.Perm.swap _ _ _)
            apply List.Perm.cons
            apply perm_cons_eraseIdx
          | m+2, 0 => simp [List.eraseIdx]; simp at heq; rw [heq]; symmetry; apply perm_cons_eraseIdx
          | m+2, 1 =>
            simp [List.eraseIdx]; simp at heq; rw [heq]
            apply List.Perm.trans (List.Perm.symm (List.Perm.swap _ _ _))
