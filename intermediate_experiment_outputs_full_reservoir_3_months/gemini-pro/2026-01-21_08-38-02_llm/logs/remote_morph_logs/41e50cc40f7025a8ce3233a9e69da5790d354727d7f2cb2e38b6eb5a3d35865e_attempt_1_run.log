      -- The cross terms in the derivative of E cancel out:
      -- 2 ⟪y', y''⟫ + 2 ω^2 ⟪y, y'⟫ = 2 ⟪y', -ω^2 y⟫ + 2 ω^2 ⟪y, y'⟫ = 0
      sorry
    have hE0 : E 0 = 0 := by
      simp [E, y, hx0, hv0, trajectory_position_at_zero, trajectory_velocity_at_zero]
    intro t
    -- Since E' = 0 and E(0) = 0, E(t) = 0 everywhere.
    sorry
  ext t
  specialize hE t
  -- E(t) = 0 implies y(t) = 0 (for ω ≠ 0, or using y''=0 case if ω=0)
  have hy : y t = 0 := by
    by_cases hw : S.ω = 0
    · -- If ω = 0, y'' = 0. With y(0)=0, y'(0)=0, we have y=0.
      sorry
    · simp only [E, add_eq_zero_iff_of_nonneg (norm_sq_nonneg _) (mul_nonneg (sq_nonneg _) (norm_sq_nonneg _))] at hE
      rcases hE with ⟨_, h2⟩
      simpa [hw] using h2
  show x t = sol t
  rw [← sub_eq_zero, ← hy]
  rfl
