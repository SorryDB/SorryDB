  let d := x - sol
  have h_d_eq : ∀ t, ∂ₜ (∂ₜ d) t = - S.ω^2 • d t := fun t => by
    simp only [d, Pi.sub_apply, Pi.smul_apply, smul_sub]
    rw [Time.deriv_sub, Time.deriv_sub] <;> try fun_prop
    · rw [h_eq t, h_sol_eq t]; simp
    -- Regularity of x is required here. Assuming x is sufficiently smooth.
    all_goals sorry
  let E (t : Time) := ‖∂ₜ d t‖^2 + ‖S.ω • d t‖^2
  have h_E : ∀ t, ∂ₜ E t = 0 := fun t => by
