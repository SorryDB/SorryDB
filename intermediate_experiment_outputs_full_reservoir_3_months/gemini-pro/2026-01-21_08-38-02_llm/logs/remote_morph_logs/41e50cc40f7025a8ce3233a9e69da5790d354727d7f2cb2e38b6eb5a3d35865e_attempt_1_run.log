/-- The trajectories to the equation of motion for a given set of initial conditions
  are unique.

  Semiformal implementation:
  - One may needed the added condition of smoothness on `x` here.
  - `EquationOfMotion` needs defining before this can be proved. -/
@[sorryful]
lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  intro h
  rw [← sub_eq_zero]
  let z := x - IC.trajectory S
  have hz_eom : S.EquationOfMotion z := by
    -- Linearity of the equation of motion.
    -- Requires distributing derivatives over subtraction, which assumes smoothness.
    sorry
  have hz_init : z 0 = 0 ∧ ∂ₜ z 0 = 0 := by
    simp [z, h.2.1, h.2.2]
  ext t
  -- Energy conservation argument: E(t) = |z'(t)|^2 + ω^2 |z(t)|^2 is constant and zero.
  let E (t : Time) := ‖∂ₜ z t‖^2 + S.ω^2 * ‖z t‖^2
  have hE : E t = 0 := by
    have h_deriv : ∀ t, ∂ₜ E t = 0 := by
      intro t
      -- ∂ₜ E = 2 ⟨z', z''⟩ + 2 ω^2 ⟨z, z'⟩ = 2 ⟨z', -ω^2 z⟩ + 2 ω^2 ⟨z, z'⟩ = 0
      sorry
    have h_zero : E 0 = 0 := by simp [E, hz_init]
    -- E is constant and 0 at t=0, so E t = 0.
    sorry
  have : ‖z t‖ = 0 := by
