      -- and the trajectory satisfies a = -ω^2 x, the force constant implies this relation.
      -- We assume the consistency of the definitions in the imported `Basic` file.
      sorry
    rw [h_acc]
    simp [inner_smul_left, inner_smul_right, real_inner_comm]
    ring
  have hE0 (t : Time) : E t = 0 := by
    -- Energy is constant (deriv is 0) and initially 0.
    have : E t = E 0 := sorry -- Requires Mean Value Theorem or similar calculus lemma
    rw [this]; simp [E, h_z_init, h_z_vel]
