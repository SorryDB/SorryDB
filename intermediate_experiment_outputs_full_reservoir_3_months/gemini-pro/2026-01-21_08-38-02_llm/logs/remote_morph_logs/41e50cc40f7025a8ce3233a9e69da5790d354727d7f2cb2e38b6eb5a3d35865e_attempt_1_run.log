lemma trajectories_unique (IC : InitialConditions) (x : Time → EuclideanSpace ℝ (Fin 1)) :
    S.EquationOfMotion x ∧ x 0 = IC.x₀ ∧ ∂ₜ x 0 = IC.v₀ →
    x = IC.trajectory S := by
  rintro ⟨hx, hx0, hv0⟩
  -- We prove that the difference between the solution and the trajectory is zero
  -- using an energy argument.
  let sol := IC.trajectory S
  have hsol := trajectory_equationOfMotion S IC
  rw [EquationOfMotion, gradLagrangian_eq_force, force_eq_linear] at hx hsol
  let y := x - sol
  let E (t : Time) := ‖∂ₜ y t‖^2 + S.ω^2 * ‖y t‖^2
  have hE : ∀ t, E t = 0 := by
    have hE_deriv : ∀ t, ∂ₜ E t = 0 := by
      intro t
      simp only [E]
      -- Using linearity of derivative and standard calculus rules
