  have h_z_eq : S.EquationOfMotion z := by
    rw [EquationOfMotion, gradLagrangian_eq_force] at h_eom ⊢
    intro t
    simp only [Time.deriv_sub (by fun_prop) (by fun_prop), force_eq_linear,
      map_sub, h_eom t, (trajectory_equationOfMotion S IC).1 t, sub_self]
  have h_z_init : z 0 = 0 := by simp [z, h_x0]
  have h_z_vel : ∂ₜ z 0 = 0 := by simp [z, h_v0, trajectory_velocity_at_zero]
