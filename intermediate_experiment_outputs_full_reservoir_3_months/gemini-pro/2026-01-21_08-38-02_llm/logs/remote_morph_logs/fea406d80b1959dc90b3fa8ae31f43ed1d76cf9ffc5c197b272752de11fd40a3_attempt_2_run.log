The problem asks us to prove that for any subset $S \subseteq \{n, \dots, 2n\}$, either $S$ or its complement contains two distinct elements $a, b$ such that $a+b$ is a perfect square. This is equivalent to showing that the graph with vertices $\{n, \dots, 2n\}$ and edges $(u,v)$ where $u+v$ is a square is not bipartite. A graph is not bipartite if it contains an odd cycle. We will explicitly construct a triangle (a 3-cycle) for any $n \ge 100$.

We choose an odd integer $k$ approximately equal to $\sqrt{2n}$. Specifically, let $m = \lfloor\sqrt{2n}\rfloor$.
If $m$ is even, we choose $k = m+3$.
If $m$ is odd, we check if $k=m+2$ satisfies the lower bound condition; if so, $k=m+2$, otherwise $k=m+4$.
The vertices of the triangle will be:
$a = (k^2+2k+3)/2$
$b = (k^2-2k-3)/2$
$c = (k^2+6k+5)/2$
We verify that $a, b, c$ are distinct integers in $[n, 2n]$ and their pairwise sums are squares ($k^2, (k+1)^2, (k+2)^2$). The existence of such a triangle implies that the set of vertices cannot be partitioned into two independent sets $S$ and $S^c$, proving the theorem.

```lean
theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  let m := Nat.sqrt (2 * n)
  let k := if m % 2 = 0 then m + 3
           else if (m + 2)^2 - 2 * (m + 2) - 3 ≥ 2 * n then m + 2
           else m + 4
  have hk_odd : k % 2 = 1 := by
    dsimp [k]; split_ifs <;> simp only [Nat.add_mod, Nat.mul_mod, *] <;> rfl
  -- Vertices of the triangle
  let u := k; let v := k + 1; let w := k + 2
  let a := (u^2 - v^2 + w^2) / 2
  let b := (u^2 + v^2 - w^2) / 2
  let c := (-u^2 + v^2 + w^2) / 2
  
  -- Proof that sums are squares
  have ha_sum : b + c = v^2 := by
    dsimp [a, b, c, u, v, w]
    have h : v^2 + w^2 ≥ u^2 := by
      nlinarith [Nat.sqrt_le_self (2*n)]
    have h2 : u^2 + v^2 ≥ w^2 := by
      nlinarith [Nat.sqrt_le_self (2*n)] 
    omega
  have hb_sum : a + c = w^2 := by
    dsimp [a, b, c, u, v, w]
    have h : u^2 + w^2 ≥ v^2 := by nlinarith
    have h2 : v^2 + w^2 ≥ u^2 := by nlinarith [Nat.sqrt_le_self (2*n)]
    omega
  have hc_sum : a + b = u^2 := by
    dsimp [a, b, c, u, v, w]
    have h : u^2 + v^2 ≥ w^2 := by nlinarith [Nat.sqrt_le_self (2*n)]
    have h2 : u^2 + w^2 ≥ v^2 := by nlinarith
    omega

  -- Bounds check
  have h_bounds : n ≤ b ∧ c ≤ 2 * n := by
    dsimp [b, c, u, v, w]
    have hm_le : m^2 ≤ 2 * n := Nat.sqrt_le_self (2 * n)
    have hn_lower : 200 ≤ 2 * n := by linarith
    have hm_14 : 14 ≤ m := Nat.le_sqrt.mpr (by linarith)
    dsimp [k]
    split_ifs with h_even h_cond
    · -- m even, k = m + 3
      constructor
      · nlinarith
      · have : 4 * n ≥ m^2 + 14 * m + 45 := by
          -- 4n >= 2m^2. Need 2m^2 >= m^2 + 14m + 45 <=> m^2 - 14m - 45 >= 0.
          -- Roots at ~16.7. For m=14 fails?
          -- Wait, for m=14 (n=100..112), 4n >= 400. 
          -- k=17. c = (289 + 102 + 5)/2 = 198 <= 200 (for n=100).
          -- Direct check for m=14:
          cases' (Nat.eq_or_lt_of_le hm_14) with heq hlt
          · rw [←heq] at *; nlinarith
          · have : m ≥ 15 := hlt; nlinarith
        linarith
    · -- m odd, k = m + 2
      constructor
      · exact h_cond
      · nlinarith
    · -- m odd, k = m + 4
      constructor
      · nlinarith
      · -- Used only if 2n > (m+2)^2 - 2(m+2) - 3
        -- This implies n is large enough for the upper bound
        nlinarith
  
  have ha_in : a ∈ Finset.Icc n (2 * n) := by
    constructor
    · have : b < a := by dsimp [a,b,u,v,w]; nlinarith
      linarith [h_bounds.1]
    · have : a < c := by dsimp [a,c,u,v,w]; nlinarith
      linarith [h_bounds.2]
  have hb_in : b ∈ Finset.Icc n (2 * n) := by
    constructor
    · exact h_bounds.1
    · have : b < c := by dsimp [b,c,u,v,w]; nlinarith
      linarith [h_bounds.2]
  have hc_in : c ∈ Finset.Icc n (2 * n) := by
    constructor
    · have : b < c := by dsimp [b,c,u,v,w]; nlinarith
      linarith [h_bounds.1]
    · exact h_bounds.2

  have h_diff : a ≠ b ∧ b ≠ c ∧ a ≠ c := by
    dsimp [a,b,c,u,v,w]; constructor <;> try constructor <;> nlinarith
    
  -- Graph coloring logic
  by_cases ha : a ∈ S
  · by_cases hb : b ∈ S
    · left; use a, ha, b, hb, h_diff.1; rw [hc_sum]; exact ⟨u, rfl⟩
    · by_cases hc : c ∈ S
      · left; use c, hc, a, ha, h_diff.2.2.symm; rw [hb_sum]; exact ⟨w, rfl⟩
      · right; use b; constructor; exact Finset.mem_sdiff.mpr ⟨hb_in, hb⟩
        use c; constructor; exact Finset.mem_sdiff.mpr ⟨hc_in, hc⟩
        use h_diff.2.1; rw [ha_sum]; exact ⟨v, rfl⟩
  · right; use a; constructor; exact Finset.mem_sdiff.mpr ⟨ha_in, ha⟩
    by_cases hb : b ∈ S
    · by_cases hc : c ∈ S
      · left; use b, hb, c, hc, h_diff.2.1; rw [ha_sum]; exact ⟨v, rfl⟩
      · use c; constructor; exact Finset.mem_sdiff.mpr ⟨hc_in, hc⟩
        use h_diff.2.2; rw [hb_sum]; exact ⟨w, rfl⟩
    · use b; constructor; exact Finset.mem_sdiff.mpr ⟨hb_in, hb⟩
      use h_diff.1; rw [hc_sum]; exact ⟨u, rfl⟩
