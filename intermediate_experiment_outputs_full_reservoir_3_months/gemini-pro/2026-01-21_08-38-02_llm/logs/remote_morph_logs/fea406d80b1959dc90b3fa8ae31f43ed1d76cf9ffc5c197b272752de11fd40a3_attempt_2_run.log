theorem result {n : ℕ} (hn : 100 ≤ n) {S : Finset ℕ} (hS : S ⊆ Finset.Icc n (2 * n)) :
    (∃ a ∈ S, ∃ b ∈ S, a ≠ b ∧ IsSquare (a + b)) ∨
    (∃ a ∈ Finset.Icc n (2 * n) \ S, ∃ b ∈ Finset.Icc n (2 * n) \ S,
      a ≠ b ∧ IsSquare (a + b)) := by
  let k := (n + 1).sqrt
  have hk : 10 ≤ k := Nat.le_sqrt.2 (by linarith)
  let m := k - 1
  have hm : 9 ≤ m := by omega
  let a := 2 * m ^ 2 - 4 * m
  let b := 2 * m ^ 2 + 1
  let c := 2 * m ^ 2 + 4 * m
  have h_sub : 4 * m ≤ 2 * m ^ 2 := by nlinarith
  have ha : n ≤ a := by
    have : n + 1 < (m + 2) ^ 2 := by rw [show m + 2 = k + 1 by omega]; exact Nat.lt_succ_sqrt _
    zify [h_sub] at this ⊢; nlinarith
  have hc : c ≤ 2 * n := by
    have : (m + 1) ^ 2 ≤ n + 1 := by rw [show m + 1 = k by omega]; exact Nat.sqrt_le _
    zify at this ⊢; nlinarith
  have hab : a < b := by zify [h_sub]; nlinarith
  have hbc : b < c := by zify [h_sub]; nlinarith
  have hac : a < c := hab.trans hbc
