    have : k ≤ s + 3 := by dsimp [k]; split_ifs <;> omega
    have : s ≥ 14 := by nlinarith [hn, hs.1]
    nlinarith [hs.1]

  let a := (k ^ 2 - 2 * k - 3) / 2
  let b := (k ^ 2 + 2 * k + 3) / 2
  let c := (k ^ 2 + 6 * k + 5) / 2

  have ha : 2 * a = k^2 - 2*k - 3 := Nat.div_two_mul_two_of_even (by have := hk_odd; omega)
  have hb : 2 * b = k^2 + 2*k + 3 := Nat.div_two_mul_two_of_even (by have := hk_odd; omega)
  have hc : 2 * c = k^2 + 6*k + 5 := Nat.div_two_mul_two_of_even (by have := hk_odd; omega)

  have hab : a + b = k^2 := by linarith
  have hbc : b + c = (k + 2)^2 := by nlinarith
  have hca : c + a = (k + 1)^2 := by nlinarith

  have h_distinct : a < b ∧ b < c := by linarith
  have ha_mem : a ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; constructor <;> linarith
  have hb_mem : b ∈ Finset.Icc n (2 * n) := by
    rw [Finset.mem_Icc]; constructor <;> linarith
  have hc_mem : c ∈ Finset.Icc n (2 * n) := by
