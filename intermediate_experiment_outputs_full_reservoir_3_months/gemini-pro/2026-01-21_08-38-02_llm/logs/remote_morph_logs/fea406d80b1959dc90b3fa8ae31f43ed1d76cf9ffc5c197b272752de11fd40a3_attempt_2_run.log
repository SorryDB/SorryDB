  let s := (2 * n + 4).sqrt
  let k := if s % 2 = 0 then s + 3 else s + 2
  have hs : s ^ 2 ≤ 2 * n + 4 ∧ 2 * n + 4 < (s + 1) ^ 2 := Nat.sqrt_le_add _
  have hk_odd : k % 2 = 1 := by dsimp [k]; split_ifs <;> omega
