```lean
noncomputable determine solution (n : ℕ) : ENNReal :=
  1 + (4 / 9) ^ n - (8 / 9) ^ n - (5 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  -- Characterize the complement: 10 ∤ prod ↔ (2 ∤ prod) ∨ (5 ∤ prod)
  let S2 : Set Digit := {d | ¬ 2 ∣ to_nat_digit d}
  let S5 : Set Digit := {d | ¬ 5 ∣ to_nat_digit d}
  have h_compl : good_seqsᶜ = {s | ∀ i, s i ∈ S2} ∪ {s | ∀ i, s i ∈ S5} := by
    ext s; simp only [good_seqs, is_good_seq, Set.mem_compl_iff, Set.mem_setOf_eq, Set.mem_union, S2, S5]
    rw [← Nat.prime_two.dvd_finset_prod_iff, ← Nat.prime_five.dvd_finset_prod_iff]
    simp only [Nat.dvd_and_iff (by norm_num) (by norm_num), not_and_or]

  -- Cardinalities of digit sets
  have c2 : Fintype.card S2 = 5 := by
    simp [S2, to_nat_digit]; exact (by decide : Fintype.card {d : Fin 9 // ¬ 2 ∣ (d + 1)} = 5)
  have c5 : Fintype.card S5 = 8 := by
    simp [S5, to_nat_digit]; exact (by decide : Fintype.card {d : Fin 9 // ¬ 5 ∣ (d + 1)} = 8)
  have c25 : Fintype.card (S2 ∩ S5) = 4 := by
    simp [S2, S5, to_nat_digit]; exact (by decide : Fintype.card {d : Fin 9 // ¬ 2 ∣ (d + 1) ∧ ¬ 5 ∣ (d + 1)} = 4)

  -- Probability calculation
  rw [← prob_compl_eq_one_sub (MeasurableSet.of_discrete _), h_compl, solution]
  rw [PMF.toOuterMeasure_apply_union (MeasurableSet.of_discrete _) (MeasurableSet.of_discrete _) (by rfl)]
  
  -- Helper for cylinder sets
  have meas_cyl (A : Set Digit) [Fintype A] (hA : Fintype.card A = k) : 
      (unifDistN n).toOuterMeasure {s | ∀ i, s i ∈ A} = (k / 9 : ENNReal) ^ n := by
    rw [unifDistN, PMF.toOuterMeasure_uniformOfFintype_apply]
    simp only [Fintype.card_fin, Fintype.card_pi, hA, Nat.cast_pow, Nat.cast_ofNat]
    rw [div_pow, ENNReal.div_eq_inv_mul]; rfl
    
  rw [meas_cyl S2 c2, meas_cyl S5 c5, meas_cyl (S2 ∩ S5) c25]
  -- Algebraic equality: 1 - (A + B - C) = 1 + C - A - B
  -- This holds in ENNReal given the specific values (A+B ≥ C and 1+C ≥ A+B)
  generalize hA : (5 / 9 : ENNReal) ^ n = A
  generalize hB : (8 / 9 : ENNReal) ^ n = B
  generalize hC : (4 / 9 : ENNReal) ^ n = C
  have h_le : C ≤ A + B := by
    rw [← hA, ← hB, ← hC, ← div_pow, ← div_pow, ← div_pow]
    gcongr; norm_cast; calc 4 ^ n ≤ 5 ^ n := Nat.pow_le_pow_left (by norm_num) n
      _ ≤ 5 ^ n + 8 ^ n := Nat.le_add_right _ _
  rw [ENNReal.sub_sub, add_comm A B, ENNReal.sub_add_eq_sub_sub_swap h_le, add_comm C 1]
