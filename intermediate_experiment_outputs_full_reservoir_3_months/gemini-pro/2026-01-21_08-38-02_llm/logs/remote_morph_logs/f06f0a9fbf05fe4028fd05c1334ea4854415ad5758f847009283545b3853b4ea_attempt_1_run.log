  rw [ENNReal.sub_div (by
        rw [←ENNReal.coe_pow, ←ENNReal.coe_pow, ←ENNReal.coe_pow, ←ENNReal.coe_add, ←ENNReal.coe_nat_cast]
        norm_cast
        linarith [Nat.sub_le_iff_le_add.1 (Finset.card_le_univ {s | ¬ is_good_seq s}.toFinset)]) (by simp)]
  simp [ENNReal.add_div, ENNReal.pow_div (by simp) (by simp)]
