    -- 2 | P iff exists i, 2 | (d_i+1)
    rw [Nat.dvd_prod, Nat.dvd_prod]
    simp [to_nat_digit]
    rw [Nat.mul_comm 2 5, Nat.coprime_two_right.dvd_mul_right]
    exact Iff.rfl
    exact Nat.prime_five
    exact Nat.prime_two

