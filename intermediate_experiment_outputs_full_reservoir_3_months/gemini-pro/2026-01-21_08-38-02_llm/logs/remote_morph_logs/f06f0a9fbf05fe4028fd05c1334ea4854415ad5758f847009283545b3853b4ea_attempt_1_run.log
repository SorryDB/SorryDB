  -- We proceed by counting the complementary set: sequences where product is NOT divisible by 10.
  -- 10 ∤ product ↔ 2 ∤ product ∨ 5 ∤ product.
  let S := DigitSeq n
  let U : Finset Digit := Finset.univ
  -- Digits not divisible by 2: {1, 3, 5, 7, 9} (indices 0, 2, 4, 6, 8)
  let Not2 : Finset Digit := {0, 2, 4, 6, 8}
  -- Digits not divisible by 5: {1..9} \ {5} (indices {0..8} \ {4})
  let Not5 : Finset Digit := {0, 1, 2, 3, 5, 6, 7, 8}
  
  -- A sequence has product not divisible by p iff all digits are not divisible by p.
  let Bad2 := {s : S | ∀ i, s i ∈ Not2}
  let Bad5 := {s : S | ∀ i, s i ∈ Not5}
  let Bad25 := {s : S | ∀ i, s i ∈ (Not2 ∩ Not5)}
  
  -- Cardinality calculations
  have card_univ : Fintype.card S = 9^n := by simp [Fintype.card_fun, Fintype.card_fin]
  have card_Bad2 : Fintype.card Bad2 = 5^n := by
    simp [Fintype.card_fun]; norm_num
  have card_Bad5 : Fintype.card Bad5 = 8^n := by
    simp [Fintype.card_fun]; norm_num
  have card_Bad25 : Fintype.card Bad25 = 4^n := by
    have : (Not2 ∩ Not5).card = 4 := by decide
    simp [Fintype.card_fun, this]

