noncomputable determine solution (n : ℕ) : ENNReal :=
  1 + (4 / 9) ^ n - (5 / 9) ^ n - (8 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_uniformOfFintype]
  simp only [Fintype.card_pi, Fintype.card_fin]
  
  -- Define the set of 'bad' digits for divisibility by 2 and 5
  let I2 : Finset Digit := {0, 2, 4, 6, 8}
  let I5 : Finset Digit := {0, 1, 2, 3, 5, 6, 7, 8}

  -- Characterize the set of bad sequences (complement of good_seqs)
  -- A sequence is bad if the product is not divisible by 10
  -- ⇔ (∀ i, 2 ∤ s i + 1) ∨ (∀ i, 5 ∤ s i + 1)
  let BadSeq := (Finset.univ : Finset (DigitSeq n)).filter (fun s => 
    (∀ i, s i ∈ I2) ∨ (∀ i, s i ∈ I5))
    
  have h_bad_card : BadSeq.card = 5 ^ n + 8 ^ n - 4 ^ n := by
    rw [Finset.filter_or, Finset.card_union_add_card_inter]
    repeat rw [Finset.card_filter_univ_pi]
    have h2 : I2.card = 5 := by decide
    have h5 : I5.card = 8 := by decide
    have h25 : (I2 ∩ I5).card = 4 := by decide
    rw [h2, h5]
    rw [← Finset.filter_inter_filter, Finset.card_filter_univ_pi, h25]
    exact Nat.add_sub_cancel' (Nat.pow_le_pow_of_le_left (by decide) n)

  -- Calculate cardinality of good sequences
  let GoodSeq := good_seqs.toFinset
  have h_compl : GoodSeq = Finset.univ \ BadSeq := by
    ext s
    simp only [GoodSeq, good_seqs, is_good_seq, to_nat_digit, BadSeq, I2, I5,
               Finset.mem_sdiff, Finset.mem_univ, true_and, Finset.mem_filter, 
               Set.toFinset_setOf, Set.mem_setOf_eq]
    rw [Nat.dvd_iff_mod_eq_zero]
    -- Fundamental number theory: 10 | P ↔ 2 | P ∧ 5 | P
    have h_mod : 10 ∣ (∏ i, (s i).val + 1) ↔ 
                 2 ∣ (∏ i, (s i).val + 1) ∧ 5 ∣ (∏ i, (s i).val + 1) := by
      rw [← Nat.dvd_iff_mod_eq_zero, Nat.dvd_and_iff_dvd_lcm]; rfl
    rw [h_mod]; push_neg; apply or_congr <;>
    { apply forall_congr'; intro i; simp; decide }
    
  have h_good_card : GoodSeq.card = 9 ^ n + 4 ^ n - 5 ^ n - 8 ^ n := by
    rw [h_compl, Finset.card_sdiff (Finset.filter_subset _ _)]
    rw [Fintype.card_pi, Fintype.card_fin, h_bad_card]
    -- Arithmetic: 9^n - (5^n + 8^n - 4^n) = 9^n + 4^n - 5^n - 8^n
    -- Requires 5^n + 8^n - 4^n ≤ 9^n and 4^n ≤ 5^n + 8^n
    zify; ring
  
  -- Convert to ENNReal and match solution
  rw [h_good_card]
  simp only [ENNReal.coe_sub, ENNReal.coe_add, ENNReal.coe_pow, ENNReal.coe_ofNat]
  -- Justify subtractions in ENNReal
  have h_le1 : (5 : ENNReal) ^ n ≤ (9 : ENNReal) ^ n + (4 : ENNReal) ^ n := by
    rw [← ENNReal.coe_pow, ← ENNReal.coe_pow, ← ENNReal.coe_add, ENNReal.coe_le_coe]
    trans 5 ^ n + 8 ^ n; exact Nat.le_add_right _ _; 
    trans 9 ^ n + 4 ^ n; apply Nat.pow_add_pow_le_pow_add_pow_of_le (by decide); decide
  have h_le2 : (8 : ENNReal) ^ n ≤ (9 : ENNReal) ^ n + (4 : ENNReal) ^ n - (5 : ENNReal) ^ n := by
    apply ENNReal.le_sub_of_add_le; rw [add_comm]
    rw [← ENNReal.coe_pow, ← ENNReal.coe_pow, ← ENNReal.coe_pow, ← ENNReal.coe_add, ENNReal.coe_le_coe]
    apply Nat.pow_add_pow_le_pow_add_pow_of_le (by decide); decide
    
  rw [div_eq_mul_inv, ENNReal.sub_mul, ENNReal.sub_mul, ENNReal.add_mul]
  repeat rw [ENNReal.mul_inv_cancel (ENNReal.pow_ne_zero (by decide) _) (ENNReal.pow_ne_top (by decide))]
  simp_rw [← ENNReal.div_eq_mul_inv, ENNReal.div_pow]
  rw [tsub_tsub, add_comm ((5:ENNReal)/9)^n]
