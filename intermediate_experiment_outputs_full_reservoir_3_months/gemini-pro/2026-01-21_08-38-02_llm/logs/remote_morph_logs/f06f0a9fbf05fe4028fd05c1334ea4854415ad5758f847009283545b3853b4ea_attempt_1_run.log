    exact rfl
    simp

  -- |S_A ∩ S_B| = |(S_Ac ∪ S_Bc)ᶜ| = Total - |S_Ac ∪ S_Bc|
  -- |S_Ac ∪ S_Bc| = |S_Ac| + |S_Bc| - |S_Ac ∩ S_Bc|
  have total : Fintype.card (DigitSeq n) = 9^n := by simp [DigitSeq, Digit, Fintype.card_fin]
  
