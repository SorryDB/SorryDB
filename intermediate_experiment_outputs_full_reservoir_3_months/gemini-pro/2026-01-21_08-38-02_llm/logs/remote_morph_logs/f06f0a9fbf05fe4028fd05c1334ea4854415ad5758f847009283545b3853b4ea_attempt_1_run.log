    rw [Nat.dvd_iff_mod_eq_zero, ← Nat.prime_two.dvd_mul_iff_dvd_pow, ← Nat.prime_five.dvd_mul_iff_dvd_pow] at *
    rw [← Nat.prod_pow, ← Nat.prod_pow] at *
