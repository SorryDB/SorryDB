  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_uniformOfFintype_apply]
  let S2 : Finset Digit := {0, 2, 4, 6, 8}
  let S5 : Finset Digit := {0, 1, 2, 3, 5, 6, 7, 8}
  have h_bad : {s : DigitSeq n | ¬ is_good_seq s} = 
      {s | (∀ i, s i ∈ S2) ∨ (∀ i, s i ∈ S5)} := by
    ext s
    simp [is_good_seq, to_nat_digit, S2, S5]
    rw [Nat.dvd_iff_dvd_of_dvd_mul (by decide) (by decide) (by decide)]
    simp [Nat.Prime.dvd_fin_prod_iff (Nat.prime_two), Nat.Prime.dvd_fin_prod_iff (Nat.prime_five)]
    push_neg
    apply or_congr <;> { apply forall_congr'; intro i; fin_cases s i <;> simp }
  have h_card_bad : {s : DigitSeq n | ¬ is_good_seq s}.toFinset.card = 5^n + 8^n - 4^n := by
    rw [h_bad, Set.toFinset_setOf, Finset.card_filter_or]
    · simp [Fintype.card_pi_finset, S2, S5]
      rfl
    · exact (is_decidable _).1
  have h_card_good : good_seqs.toFinset.card = 9^n - (5^n + 8^n - 4^n) := by
    rw [← Fintype.card_fin (n := n) (α := Digit)] at h_card_bad
    rw [← Finset.card_univ, ← Finset.filter_not] at h_card_bad
    rw [good_seqs, Set.toFinset_setOf]
    rw [Finset.card_eq_diff_of_sub h_card_bad (Finset.filter_subset _ _)]
    rw [Fintype.card_fun, Fintype.card_fin]
  rw [h_card_good]
  simp only [Fintype.card_fun, Fintype.card_fin]
  rw [ENNReal.sub_div (by
        rw [←ENNReal.coe_pow, ←ENNReal.coe_pow, ←ENNReal.coe_pow, ←ENNReal.coe_add, ←ENNReal.coe_sub, ←ENNReal.coe_nat_cast]
        norm_cast
        apply Nat.sub_le_of_le_add
