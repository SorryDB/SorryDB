namespace Usa1972P3

abbrev Digit := Fin 9
abbrev DigitSeq (n : ℕ) := Fin n → Digit

noncomputable def unifDistN (n : ℕ) := PMF.uniformOfFintype (DigitSeq n)


def to_nat_digit : Digit → ℕ := fun d ↦ d + 1
def is_good_seq {n : ℕ} (s : DigitSeq n) := 10 ∣ ∏a, to_nat_digit (s a)
def good_seqs {n : ℕ} := {s : DigitSeq n | is_good_seq s}

noncomputable determine solution (n : ℕ) : ENNReal :=
  1 + (4 / 9) ^ n - (8 / 9) ^ n - (5 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_uniformOfFintype]
  simp only [Fintype.card_fin, Fintype.card_pi]
  have h_card : Fintype.card (DigitSeq n) = 9 ^ n := by simp [Fintype.card_pi]
  
  let S := DigitSeq n
  let P2 : Set S := {s | 2 ∣ ∏ i, to_nat_digit (s i)}
  let P5 : Set S := {s | 5 ∣ ∏ i, to_nat_digit (s i)}
  let Q2 : Set S := {s | 2 nmid ∏ i, to_nat_digit (s i)}
  let Q5 : Set S := {s | 5 nmid ∏ i, to_nat_digit (s i)}
  
  have h_good : good_seqs = P2 ∩ P5 := by
    ext s
    simp [good_seqs, is_good_seq, Nat.dvd_and_iff_dvd_mul (Nat.coprime_two_right 5)]
  
  have h_compl : (P2 ∩ P5)ᶜ = Q2 ∪ Q5 := by
    ext s
    simp [Q2, Q5, P2, P5]
  
  rw [h_good, ←Fintype.card_compl_set, h_compl, Fintype.card_union_eq_card_add_card_sub_card_inter]
  
  have hQ2 : Fintype.card Q2 = 5^n := by
    simp [Q2, Nat.Prime.dvd_prod_iff (Nat.prime_two)]
    rw [Fintype.card_pi_subtype]
    congr; simp; decide
  have hQ5 : Fintype.card Q5 = 8^n := by
    simp [Q5, Nat.Prime.dvd_prod_iff (Nat.prime_five)]
    rw [Fintype.card_pi_subtype]
    congr; simp; decide
  have hQ25 : Fintype.card (Q2 ∩ Q5) = 4^n := by
    simp [Q2, Q5, Nat.Prime.dvd_prod_iff (Nat.prime_two), Nat.Prime.dvd_prod_iff (Nat.prime_five)]
    rw [Set.inter_def]; simp; rw [Fintype.card_pi_subtype]
    congr; simp; decide

  rw [hQ2, hQ5, hQ25]
  
  have h_ineq : 5^n + 8^n ≤ 9^n + 4^n := by
    rw [←hQ2, ←hQ5, ←hQ25, ←h_card]
    rw [←Fintype.card_union_eq_card_add_card_sub_card_inter]
    exact add_le_add_right (Fintype.card_le_univ _) _
  
  rw [ENNReal.eq_div_iff (by simp) (by simp)]
  simp only [ENNReal.div_pow, div_eq_mul_inv]
  rw [← mul_assoc, ← ENNReal.add_sub_assoc (by simp [ENNReal.mul_le_mul_right]), ← ENNReal.sub_sub]
  rw [← mul_add, ← mul_sub, ← mul_sub]
  congr 1
  norm_cast
  rw [Nat.sub_sub, add_comm (8^n), Nat.sub_add_eq_add_sub h_ineq]
  rw [Nat.sub_sub]
  congr 1
  rw [Nat.sub_add_eq_add_sub]
  . rw [add_comm]
  . rw [←hQ2, ←hQ5, ←hQ25, ←h_card, ←Fintype.card_union_eq_card_add_card_sub_card_inter]
    exact Fintype.card_le_univ _
