noncomputable determine solution (n : ℕ) : ENNReal :=
  1 + (4 / 9) ^ n - (5 / 9) ^ n - (8 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  -- Characterize the set of good sequences
  let S := DigitSeq n
  let P2 : Set S := {s | ∀ i, (s i).val + 1 % 2 ≠ 0}
  let P5 : Set S := {s | ∀ i, (s i).val + 1 % 5 ≠ 0}
  
  -- Calculate cardinalities of bad sets
  have card_P2 : Fintype.card P2 = 5 ^ n := by
    simp [P2, Fintype.card_pi, Fintype.card_fin]
    have : Fintype.card {x : Fin 9 // (x : ℕ) + 1 % 2 ≠ 0} = 5 := by
      simp; apply Fintype.card_of_finset {0, 2, 4, 6, 8}
      intro x; simp [Fin.forall_iff, Nat.succ_mod_two_ne_zero]
      decide
    rw [this]
  
  have card_P5 : Fintype.card P5 = 8 ^ n := by
    simp [P5, Fintype.card_pi, Fintype.card_fin]
    have : Fintype.card {x : Fin 9 // (x : ℕ) + 1 % 5 ≠ 0} = 8 := by
      simp; apply Fintype.card_of_finset {0, 1, 2, 3, 5, 6, 7, 8}
      intro x; simp [Fin.forall_iff]
      decide
    rw [this]

  have card_P25 : Fintype.card (P2 ∩ P5) = 4 ^ n := by
    simp [P2, P5, Fintype.card_pi, Fintype.card_fin]
    have : Fintype.card {x : Fin 9 // (x : ℕ) + 1 % 2 ≠ 0 ∧ (x : ℕ) + 1 % 5 ≠ 0} = 4 := by
      simp; apply Fintype.card_of_finset {0, 2, 6, 8}
      intro x; simp [Fin.forall_iff, Nat.succ_mod_two_ne_zero]
      decide
    rw [this]

  -- Relate good_seqs to complement of union
  have h_good : good_seqs = (P2 ∪ P5)ᶜ := by
    ext s
    simp [good_seqs, is_good_seq, to_nat_digit, Nat.dvd_iff_mod_eq_zero]
    rw [← Nat.succ_mod_two_ne_zero, Nat.dvd_iff_mod_eq_zero]
    simp [P2, P5]
    rw [← forall_and, ← not_or, ← not_exists, not_iff_not]
    congr! with i
    rw [Nat.dvd_iff_mod_eq_zero, Nat.dvd_iff_mod_eq_zero]
    omega
  
  -- Compute probability
  rw [solution, h_good, unifDistN, PMF.toOuterMeasure_uniformOfFintype_apply, 
      Fintype.card_compl_set, Fintype.card_union_eq, card_P2, card_P5, card_P25,
      Fintype.card_fin, Fintype.card_fun, Fintype.card_fin]
  
  -- Arithmetic in ENNReal
  simp only [Nat.cast_sub, Nat.cast_add, Nat.cast_pow, Nat.cast_ofNat]
  generalize (9 : ENNReal) = d9
  generalize (5 : ENNReal) = d5
  generalize (8 : ENNReal) = d8
  generalize (4 : ENNReal) = d4
  
  have h_le : d5 ^ n + d8 ^ n - d4 ^ n ≤ d9 ^ n := by
    rw [← Nat.cast_pow, ← Nat.cast_pow, ← Nat.cast_pow, ← Nat.cast_add, ← Nat.cast_sub, ← Nat.cast_pow]
    · apply Nat.cast_le.mpr
      -- Justification that |P2 ∪ P5| ≤ |S|
      rw [← card_P2, ← card_P5, ← card_P25, ← Fintype.card_union_eq]
      exact Fintype.card_subtype_le _
    · -- Justification that |P2 ∩ P5| ≤ |P2| + |P5| (trivial)
      rw [← card_P25, ← card_P2, ← card_P5]
      exact le_add_of_le_left (Fintype.card_le_of_embedding (Function.Embedding.subtype_le _))

  -- Rearrange equation
  rw [ENNReal.sub_div (by simp) (by simp), ENNReal.div_self (by simp) (by simp)]
  nth_rw 1 [← ENNReal.add_sub_cancel_right (d5^n/d9^n) (by simp)]
  rw [add_comm 1, ENNReal.add_sub_assoc (by simp), sub_eq_add_neg, sub_eq_add_neg]
  -- It's tricky to manipulate ENNReal subtraction purely algebraically.
  -- Instead, prove equality of numerators over common denominator d9^n
  rw [← ENNReal.sub_div (by simp) (by simp), ← ENNReal.sub_div (by simp) (by simp),
      ← ENNReal.add_div, ← ENNReal.sub_div (by simp) (by simp)]
  congr 1
  -- Numerators: 9^n - (5^n + 8^n - 4^n) = 9^n + 4^n - 5^n - 8^n
  -- This holds in Nat, so it holds in ENNReal provided subtractions are valid
  rw [← Nat.cast_pow, ← Nat.cast_pow, ← Nat.cast_pow, ← Nat.cast_pow]
  norm_cast
  zify
  ring
