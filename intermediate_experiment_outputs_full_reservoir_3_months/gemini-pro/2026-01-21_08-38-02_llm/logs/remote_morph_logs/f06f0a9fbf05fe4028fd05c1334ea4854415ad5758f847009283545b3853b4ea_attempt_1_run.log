problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_uniformOfFintype]
  simp only [Fintype.card_pi, Fintype.card_fin]
  let s2 := {s : DigitSeq n | ∀ i, ¬ 2 ∣ to_nat_digit (s i)}
  let s5 := {s : DigitSeq n | ∀ i, ¬ 5 ∣ to_nat_digit (s i)}
  have h_good : good_seqs = (s2 ∪ s5)ᶜ := by
    ext s
    simp only [good_seqs, is_good_seq, s2, s5, Set.mem_setOf_eq, Set.mem_compl_iff, Set.mem_union, not_and, not_not]
    rw [← Nat.prime_two.dvd_fin_prod_iff, ← Nat.prime_five.dvd_fin_prod_iff]
    tauto
  have card_pow (p : Digit → Prop) [DecidablePred p] :
      Fintype.card {s : DigitSeq n | ∀ i, p (s i)} = (Fintype.card {d | p d}) ^ n := by
