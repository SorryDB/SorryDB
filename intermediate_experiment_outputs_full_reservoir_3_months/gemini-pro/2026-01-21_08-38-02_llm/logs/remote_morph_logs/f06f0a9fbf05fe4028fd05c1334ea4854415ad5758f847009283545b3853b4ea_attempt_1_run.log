problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution]
  let A := {s : DigitSeq n | 2 ∣ ∏ i, to_nat_digit (s i)}
  let B := {s : DigitSeq n | 5 ∣ ∏ i, to_nat_digit (s i)}
  have h_good : good_seqs = A ∩ B := by
    ext s
    simp [good_seqs, is_good_seq, A, B, Nat.dvd_and_iff]
    rfl
  have h_compl : (A ∩ B)ᶜ = Aᶜ ∪ Bᶜ := Set.compl_inter A B
  have h_meas : (unifDistN n).toOuterMeasure good_seqs = 1 - (unifDistN n).toOuterMeasure (A ∩ B)ᶜ := by
    rw [h_good, PMF.toOuterMeasure_apply_eq_one_sub_apply_compl]
  rw [h_meas, h_compl, PMF.toOuterMeasure_apply_union]
  -- Calculate probabilities of complements
  let S2 := {d : Digit | ¬ 2 ∣ to_nat_digit d}
  let S5 := {d : Digit | ¬ 5 ∣ to_nat_digit d}
  have hA_compl : Aᶜ = {s : DigitSeq n | ∀ i, s i ∈ S2} := by
    ext s
    simp [A, S2, Nat.prime_two.dvd_finset_prod_iff, to_nat_digit]
  have hB_compl : Bᶜ = {s : DigitSeq n | ∀ i, s i ∈ S5} := by
    ext s
    simp [B, S5, Nat.prime_five.dvd_finset_prod_iff, to_nat_digit]
  -- Cardinalities
  have card_S2 : Fintype.card S2 = 5 := by
    simp [S2, to_nat_digit, Fin.forall_fin_ne_zero_iff]
    decide
  have card_S5 : Fintype.card S5 = 8 := by
    simp [S5, to_nat_digit]
    decide
  have card_S25 : Fintype.card (S2 ∩ S5 : Set Digit) = 4 := by
    simp [S2, S5, to_nat_digit]
