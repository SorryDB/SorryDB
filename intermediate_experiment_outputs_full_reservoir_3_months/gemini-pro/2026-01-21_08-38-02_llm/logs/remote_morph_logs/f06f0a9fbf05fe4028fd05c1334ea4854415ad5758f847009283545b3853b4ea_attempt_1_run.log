  -- A = {1,3,5,7,9} -> to_nat_digit -> {2,4,6,8,10} - wait A is those divisible by 2
  -- A (div 2) -> to_nat_digit \in {2,4,6,8} (since range 1..9). Digits: 1,3,5,7.
  -- A^c (odd) -> to_nat_digit \in {1,3,5,7,9}. Digits: 0,2,4,6,8. |A^c| = 5.
  have c_Ac : Fintype.card S_Ac = 5 ^ n := by
    rw [Fintype.card_set_eq_card_subtype]
    rw [Fintype.card_pi]
