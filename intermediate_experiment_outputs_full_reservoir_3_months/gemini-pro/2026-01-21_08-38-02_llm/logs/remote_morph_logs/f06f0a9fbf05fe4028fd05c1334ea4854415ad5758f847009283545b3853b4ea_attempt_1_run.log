  -- d+1 not div 2 AND not div 5.
  -- d+1 in {1,3,7,9}. Size 4.
  have c_AcBc : Fintype.card (S_Ac ∩ S_Bc) = 4 ^ n := by
    rw [Fintype.card_set_eq_card_subtype]
    rw [Set.setOf_and, Fintype.card_pi]
    congr; funext i
