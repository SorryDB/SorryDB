  let S_Ac := {s : DigitSeq n | ∀ i, s i ∉ A}
  let S_Bc := {s : DigitSeq n | ∀ i, s i ∉ B}
  have h_Ac : S_Ac = S_Aᶜ := by
    ext s; simp [S_A, S_Ac]
  have h_Bc : S_Bc = S_Bᶜ := by
    ext s; simp [S_B, S_Bc]

