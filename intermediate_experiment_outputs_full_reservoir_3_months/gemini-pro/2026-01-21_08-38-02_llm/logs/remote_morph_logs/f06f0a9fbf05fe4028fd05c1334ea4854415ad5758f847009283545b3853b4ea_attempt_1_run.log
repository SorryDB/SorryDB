    simp only [Fintype.card_subtype, Finset.card_univ, Fintype.card_ofSubtype]
    -- Digits in 0..8 s.t. d+1 not div 2.
    -- d+1 in {1,3,5,7,9}. d in {0,2,4,6,8}. Size 5.
    exact rfl
    simp

  -- B (div 5) -> to_nat_digit \in {5}. Digit: 4.
  -- B^c (not div 5) -> to_nat_digit \in {1..9}\{5}. Size 8.
  have c_Bc : Fintype.card S_Bc = 8 ^ n := by
    rw [Fintype.card_set_eq_card_subtype]
    rw [Fintype.card_pi]
    congr; funext i
    simp only [Fintype.card_subtype, Finset.card_univ, Fintype.card_ofSubtype]
    -- Digits in 0..8 s.t. d+1 not div 5.
    -- d+1 in {1,2,3,4,6,7,8,9}. Size 8.
    exact rfl
    simp

