  1 + (4 / 9) ^ n - (5 / 9) ^ n - (8 / 9) ^ n

problem usa1972_p3 (n : ℕ) (digits : DigitSeq n) :
  (unifDistN n).toOuterMeasure good_seqs = solution n := by
  rw [solution, unifDistN, PMF.toOuterMeasure_uniformOfFintype]
  simp only [Fintype.card_fin]
  let A : Finset Digit := {0, 2, 4, 6, 8}
  let B : Finset Digit := {0, 1, 2, 3, 5, 6, 7, 8}
  have hA : A.card = 5 := by decide
  have hB : B.card = 8 := by decide
  have hAB : (A ∩ B).card = 4 := by decide
  
  have h_bad : {s | ¬ is_good_seq s}.toFinset = (Fintype.piFinset (fun _ ↦ A)) ∪ (Fintype.piFinset (fun _ ↦ B)) := by
    ext s
    simp [is_good_seq, to_nat_digit]
    rw [← Nat.prime_two.dvd_finset_prod_iff, ← Nat.prime_five.dvd_finset_prod_iff]
    rw [Nat.dvd_and_iff (by decide) (by decide)]
    push_neg
    simp [A, B]
    rfl
    
  have card_bad : ({s | ¬ is_good_seq s}.toFinset).card = 5^n + 8^n - 4^n := by
    rw [h_bad, Finset.card_union, Finset.card_pi, Finset.card_pi, ← Finset.piFinset_inter, Finset.card_pi]
    simp [hA, hB, hAB, Fintype.card_fin]
  
  have card_good : (good_seqs.toFinset).card = 9^n - (5^n + 8^n - 4^n) := by
    rw [← Fintype.card_fin n, ← Finset.card_univ, ← Finset.card_compl]
    · congr; ext s; simp [good_seqs]
    · simp [Fintype.card_fin]

  rw [← Set.toFinset_card, card_good]
  
  have h9 : (9 : ENNReal) ≠ 0 := by simp
  have h9_top : (9 : ENNReal) ≠ ⊤ := by simp
  
  rw [ENNReal.sub_sub]
  field_simp
  norm_cast
  
  have h1 : 4^n + (5^n + 8^n - 4^n) ≤ 5^n + 8^n := by zify; ring_nf; apply Nat.le_add_left
  have h2 : 5^n + 8^n - 4^n ≤ 9^n := by rw [← card_bad]; apply Finset.card_le_univ
  have h3 : 5^n + 8^n ≤ 9^n + 4^n := by zify; ring_nf; exact Nat.le_sub_iff_add_le h1 |>.mp h2
  
  rw [Nat.cast_sub h2, Nat.cast_sub h3]
  zify [h2, h3, h1]
  ring
