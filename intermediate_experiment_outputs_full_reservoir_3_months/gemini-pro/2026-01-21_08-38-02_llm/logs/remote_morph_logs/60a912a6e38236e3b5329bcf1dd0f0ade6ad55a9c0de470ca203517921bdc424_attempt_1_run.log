        obtain ⟨M, hM, hM_eq⟩ := exists_isMatching_encard_eq_matchingNumber (H - {v})
        exact h_ess ⟨M, ⟨hM.subset.trans (diff_subset _ _), hM.disjoint⟩,
          fun x hx => (not_mem_of_mem_diff_singleton hx (hM.subset_ground x)),
          hM_eq.trans h_eq ▸ le_rfl⟩
      exact le_antisymm h_le (le_trans (tsub_le_tsub_right (IsMatching.matchingNumber_mono
        (diff_subset _ _)) _) (le_of_eq rfl)) -- ν(H) - 1 ≤ ν(H - v) generally holds
    have h_prop : ν(G - (X ∪ {v})) = ν(G) - (X ∪ {v}).encard := by
      rw [show G - (X ∪ {v}) = H - {v} by sorry, h_dec, hX.prop]
      -- Algebra: ν(G) - |X| - 1 = ν(G) - (|X| + 1)
      sorry
    exact hX.not_prop_of_gt (Set.ssubset_insert hv) h_prop

  obtain ⟨M, hM, h_comp⟩ := foo_of_forall_inessential (fun v =>
    if h : v ∈ V(H) then h_iness v h else inessential_of_not_mem h)

  have h_M_size : M.encard = ν(H) := by
    -- M is a max matching because it leaves only 1 vertex per component (minimal possible)
    sorry

  rw [← h_M_size]
  -- Count vertices: |V| = 2|M| + |OddComponents|
  -- Each component K has |V(K)| = 2|M_K| + 1.
  -- Summing gives result.
  sorry
