lemma tutte_berge_of_maximal_vertexDelete (hX : Maximal (fun X ↦ ν(G - X) = ν(G) - X.encard) X) :
    2 * ν(G - X) = (V(G) \ X).encard - (G - X).OddComponents.encard := by
  set H := G - X
  have h_iness : ∀ v, H.inessential v := by
    intro v
    by_cases hv : v ∈ V(H)
    · by_contra hnot
      have h_eq : ν(H - v) = ν(H) - 1 := sorry
      let Y := X.insert v
      have hY : ν(G - Y) = ν(G) - Y.encard := by
        have : G - Y = H - v := sorry
        rw [encard_insert (by simpa using hv), Nat.cast_one, ← sub_sub, ← hX.1, this, h_eq]
      exact hX.not_prop_of_ssubset (Set.ssubset_insert (by simpa using hv)) hY
    · exact inessential_of_not_mem hv
  obtain ⟨M, hM, h_comp⟩ := foo_of_forall_inessential h_iness
  have h_eq : V(H).encard = 2 * M.encard + H.OddComponents.encard := sorry
  have h_sz : M.encard = ν(H) := sorry
  rw [h_eq, h_sz]
  sorry
