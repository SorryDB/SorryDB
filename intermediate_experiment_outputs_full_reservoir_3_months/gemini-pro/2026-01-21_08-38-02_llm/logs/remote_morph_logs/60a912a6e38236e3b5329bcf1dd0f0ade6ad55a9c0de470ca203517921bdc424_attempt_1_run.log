          calc ν(G - Y) = ν(H \ {v}) := by rw [show G - Y = H \ {v} by ext; simp [H, Y, and_assoc, not_or]]
            _ ≤ ν(H) - 1 := hle
            _ = (ν(G) - X.encard) - 1 := by rw [hX.1]
            _ = ν(G) - (X.encard + 1) := by rw [tsub_tsub]
