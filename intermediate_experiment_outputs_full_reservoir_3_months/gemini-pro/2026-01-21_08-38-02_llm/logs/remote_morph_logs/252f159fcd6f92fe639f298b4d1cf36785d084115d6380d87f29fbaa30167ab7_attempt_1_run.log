  let Пғ' := fun n вҶҰ вҹЁ2/3, by norm_numвҹ© [вҹЁ1/2, by norm_numвҹ© [В«ПғМғВ» n вҶ” В«ПғвӢҶВ» n] вҶ” ПғвӮҒвҠ—^S[n]]
  have Пғ'_free (n) : IsFree (Пғ' n) := by
    --by convexity of `IsFree` and that the three constituents are free
