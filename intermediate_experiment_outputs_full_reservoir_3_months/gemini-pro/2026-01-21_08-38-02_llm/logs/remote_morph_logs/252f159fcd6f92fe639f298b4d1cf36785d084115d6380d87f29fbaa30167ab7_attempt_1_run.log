    unfold mineig
    rw [вҶҗ hi_min]
    exact hПғвӮҒ_pos.eigenvalues_pos i_min

  have h_min_le_one : mineig вүӨ 1 := by
    --all eigenvalues of a state are at most 1. (We might not actually need this fact.)
    unfold mineig
    rw [вҶҗ hi_min]
    exact ПғвӮҒ.eigenvalue_le_one i_min

  clear i_min hi_min

  -- The sequence c_n given in (S44). In order to handle when c = 0, I've replaced the
  -- (Real.log 3) / n term with (Real.log 3) / (max n 1). I expect this will work down the line.
  let c (n : в„•) := Real.log (1 / mineig) + (Real.log 3) / (max n 1)
  have hc (n) : 0 < c n := by
    have hвӮҒ : 0 вүӨ Real.log (1 / mineig) := by bound
    positivity

  have hc_lim : Filter.atTop.Tendsto (fun n вҶҰ (c n) / n) (рқ“қ 0) := by
    have h_const : Filter.atTop.Tendsto (fun n : в„• вҶҰ Real.log (1 / mineig) / n) (рқ“қ 0) :=
        tendsto_const_nhds.div_atTop tendsto_natCast_atTop_atTop;
    -- We can split the limit into two parts: the constant term and the term involving log(3).
    have h_div : Filter.atTop.Tendsto (fun n : в„• вҶҰ Real.log 3 / (max n 1 * n)) (рқ“қ 0) :=
      tendsto_const_nhds.div_atTop <| Filter.tendsto_atTop_mono (fun n вҶҰ by
        norm_cast; nlinarith [le_max_left n 1, le_max_right n 1]) tendsto_natCast_atTop_atTop
    convert h_const.add h_div using 2 <;> ring

  -- The function f_n(О») in (S45)
  let f (n : в„•) (lam : в„қ) := вҢҲReal.log lam / c nвҢү * c n
  --(S46)
  have h_le_f (n) (lam) : Real.log lam вүӨ f n lam := calc
    _ вүӨ (вҢҲReal.log lam / (c n)вҢү) * c n := by
      rw [вҶҗ mul_inv_le_iffвӮҖ (hc n)]
      apply Int.le_ceil _
    _ = f n lam := by
      rfl
  have h_f_le (n) (lam) : f n lam < Real.log lam + c n := calc
    f n lam = вҢҲReal.log lam / c nвҢү * c n := by
      rfl
    _ < (Real.log lam / c n + 1) * c n := by
      specialize hc n
      gcongr
      exact Int.ceil_lt_add_one _
    _ вүӨ Real.log lam + c n := by
      specialize hc n
      field_simp
      rfl

  --Define Пғ'' first as the (unnormalized) cfc image of Пғ' under `О» вҶ’ exp (f n О»)`.
  let Пғ''_unnormalized (n) : HermitianMat (H (i ^ n)) в„Ӯ :=
    (Пғ' n).M.cfc fun e вҶҰ Real.exp (f n e)

  have Пғ''_unnormalized_PosDef (n) : Matrix.PosDef (Пғ''_unnormalized n).val := by
    dsimp [Пғ''_unnormalized]
    rw [HermitianMat.cfc_PosDef]
    intro
    positivity

  have h_exp_f (n) (x : в„қ) (hx : 0 < x) : x вүӨ Real.exp (f n x) вҲ§ (Real.exp (f n x) < Real.exp (c n) * x) := by
    constructor
    В· convert Real.exp_monotone (h_le_f n x)
      rw [Real.exp_log hx]
    В· convert Real.exp_strictMono (h_f_le n x) using 1
      rw [Real.exp_add (Real.log x), Real.exp_log hx, mul_comm]

  have Пғ''_tr_bounds (n) : 1 вүӨ (Пғ''_unnormalized n).trace вҲ§ (Пғ''_unnormalized n).trace < Real.exp (c n) := by
    have hПғ' := (Пғ' n).tr
    constructor
    В· rw [вҶҗ HermitianMat.sum_eigenvalues_eq_trace] at hПғ' вҠў
      rw [вҶҗ hПғ']
      obtain вҹЁe, heвҹ© := (Пғ' n).M.cfc_eigenvalues fun e вҶҰ Real.exp (f n e)
      rw [he]
      simp only [HermitianMat.val_eq_coe, MState.toMat_M, Function.comp_apply]
      rw [Equiv.sum_comp e (fun i вҶҰ Real.exp (f n (Matrix.IsHermitian.eigenvalues _ i)))]
      gcongr
      refine (h_exp_f n _ ?_).left
      exact (Пғ'_posdef n).eigenvalues_pos _
    В· rw [вҶҗ HermitianMat.sum_eigenvalues_eq_trace] at hПғ' вҠў
      rw [вҶҗ mul_one (Real.exp (c n)), вҶҗ hПғ', Finset.mul_sum]
      obtain вҹЁe, heвҹ© := (Пғ' n).M.cfc_eigenvalues fun e вҶҰ Real.exp (f n e)
      rw [he]; clear he
      dsimp
      rw [Equiv.sum_comp e (fun i вҶҰ Real.exp (f n (Matrix.IsHermitian.eigenvalues _ i)))]
      gcongr
      В· exact Finset.univ_nonempty
      В· refine (h_exp_f n _ ?_).right
        exact (Пғ'_posdef n).eigenvalues_pos _

  --Then Пғ'' is the normalized version, which will work because Пғ''_unnormalized is PosDef
  let Пғ'' (n) : MState (H (i ^ n)) := {
    --TODO make this its own definition
    M := (Пғ''_unnormalized n).traceвҒ»В№ вҖў (Пғ''_unnormalized n)
    zero_le := by
      have h1 : 0 < (Пғ''_unnormalized n).trace := zero_lt_one.trans_le (Пғ''_tr_bounds n).left
      have h2 : 0 < Пғ''_unnormalized n := (Пғ''_unnormalized_PosDef n).zero_lt
      exact smul_nonneg (inv_nonneg_of_nonneg h1.le) h2.le
    tr := by
      simp only [HermitianMat.trace_smul]
      apply inv_mul_cancelвӮҖ
      exact (zero_lt_one.trans_le (Пғ''_tr_bounds n).left).ne'
  }

  have Пғ''_posdef n : (Пғ'' n).M.toMat.PosDef := by
    apply (Пғ''_unnormalized_PosDef n).smul
    have := (Пғ''_tr_bounds n).left
    positivity

  have Пғ'_le_Пғ'' (n) : Real.exp (-c n) вҖў (Пғ' n).M вүӨ Пғ'' n := by
    dsimp [Пғ'']
    set x := (Пғ''_unnormalized n).trace
    dsimp [Пғ''_unnormalized]
    rw [вҶҗ HermitianMat.cfc_const_mul_id, вҶҗ HermitianMat.cfc_const_mul_id,
      вҶҗ HermitianMat.cfc_comp]
    rw [вҶҗ sub_nonneg, вҶҗ HermitianMat.cfc_sub, HermitianMat.zero_le_cfc]
    intro i
    set y := (Пғ' n).M.H.eigenvalues i
    have hy : 0 < y := (Пғ'_posdef n).eigenvalues_pos i
    dsimp only [Pi.sub_apply, Function.comp_apply]
    have : 0 < x := zero_lt_one.trans_le (Пғ''_tr_bounds n).left
    grw [ вҶҗ (h_exp_f n y hy).left]
    rw [вҶҗ sub_mul]
    suffices 0 вүӨ xвҒ»В№ - Real.exp (-c n) by positivity
    rw [sub_nonneg, вҶҗ inv_le_invвӮҖ]
    В· simpa [вҶҗ Real.exp_neg] using (Пғ''_tr_bounds n).right.le
    В· positivity
    В· positivity
  have Пғ''_le_Пғ' (n) : Пғ'' n вүӨ Real.exp (c n) вҖў (Пғ' n).M := by
    dsimp [Пғ'']
    set x := (Пғ''_unnormalized n).trace
    dsimp [Пғ''_unnormalized]
    rw [вҶҗ HermitianMat.cfc_const_mul_id, вҶҗ HermitianMat.cfc_const_mul_id,
      вҶҗ HermitianMat.cfc_comp]
    rw [вҶҗ sub_nonneg, вҶҗ HermitianMat.cfc_sub, HermitianMat.zero_le_cfc]
    intro i
    set y := (Пғ' n).M.H.eigenvalues i
    have hy : 0 < y := (Пғ'_posdef n).eigenvalues_pos i
    dsimp only [Pi.sub_apply, Function.comp_apply]
    grw [ вҶҗ (h_exp_f n y hy).right]
    rw [вҶҗ one_sub_mul]
    suffices 0 вүӨ 1 - xвҒ»В№ by positivity
    simpa using inv_le_one_of_one_leвӮҖ (Пғ''_tr_bounds n).left

  have qRel_Пғ''_le_Пғ' n : рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ'' n) вүӨ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ' n) + ENNReal.ofReal (c n) := by
    rw [вҶҗ Real.log_exp (c n)]
    apply qRelEntropy_le_add_of_le_smul
    apply Пғ''_le_Пғ'

  have qRel_Пғ'_le_Пғ'' n : рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ' n) вүӨ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ'' n) + ENNReal.ofReal (c n) := by
    rw [вҶҗ Real.log_exp (c n)]
    apply qRelEntropy_le_add_of_le_smul
    rw [вҶҗ inv_smul_le_iff_of_pos (by positivity), вҶҗ Real.exp_neg]
    apply Пғ'_le_Пғ''

  -- Definition of the pinching map w.r.t. Пғ'' in Eq. (S55)
  let в„° n := pinching_map (Пғ'' n)

  have hПғ'n_eq_sum_third n : (Пғ' n).M = (1 / 3 : в„қ) вҖў В«ПғМғВ» n +
      (1 / 3 : в„қ) вҖў В«ПғвӢҶВ» n + (1 / 3 : в„қ) вҖў (ПғвӮҒвҠ—^S[n]) := by
    unfold Пғ'
    change _ вҖў _ + _ = _
    conv =>
      enter [1, 1, 2]
      change _ + _
    dsimp [Mixable.to_U]
    norm_num only [one_div, Prob.coe_one_minus, smul_add, smul_smul]

  have hПғвӮҒ_le_Пғ' n : (1 / 3 : в„қ) вҖў (ПғвӮҒвҠ—^S[n]).M вүӨ (Пғ' n).M := by
    rw [hПғ'n_eq_sum_third]
    apply le_add_of_nonneg_left
    have := (В«ПғвӢҶВ» n).zero_le
    have := (В«ПғМғВ» n).zero_le
    positivity

  -- Number of distinct eigenvalues of Пғ'' in Eq. (S56) is
  -- Fintype.card (spectrum в„қ (Пғ'' n).m), which is dвӮҷ in the paper.
  have hdle n : Fintype.card (spectrum в„қ (Пғ'' n).m) вүӨ n + 1 := by
    rw [Matrix.card_spectrum_eq_image (Пғ'' n).m (Пғ'' n).M.H]
    rcases n.eq_zero_or_pos with rfl | hn
    В· have _ : Unique (H (i ^ 0)) := by
        rw [spacePow_zero]
        infer_instance
      simp
    rw [вҶҗ Set.ncard_coe_finset]
    simp only [Finset.coe_image, Finset.coe_univ, Set.image_univ]
    have eq : вҲғ (e : Equiv.Perm _), (Пғ'' n).M.H.eigenvalues =
        (fun x вҶҰ (Пғ''_unnormalized n).traceвҒ»В№ * Real.exp (f n x)) вҲҳ (Пғ' n).M.H.eigenvalues вҲҳ e := by
      convert (Пғ' n).M.cfc_eigenvalues (fun x вҶҰ (Пғ''_unnormalized n).traceвҒ»В№ * Real.exp (f n x))
      rw [HermitianMat.cfc_const_mul]
    rcases eq with вҹЁeq, heqвҹ©
    rw [heq]
    simp only [Set.range_comp, MState.toMat_M, EquivLike.range_eq_univ, Set.image_univ, ge_iff_le]
    let S : Set в„қ := (fun x => Real.exp (f n x)) '' Set.Icc ((mineig ^ n) / 3) 1
    have h_card_subs : Set.ncard S вүӨ n + 1 вҲ§ S.Finite := by
      exact f_image_bound mineig n h_min_pos hn h_le_f h_f_le
    let SвӮӮ : Set в„қ := (fun x => (Пғ''_unnormalized n).traceвҒ»В№ * Real.exp (f n x)) '' Set.Icc ((mineig ^ n) / 3) 1
    obtain вҹЁh_card_subsвӮӮ, h_sвӮӮ_finiteвҹ© : Set.ncard SвӮӮ вүӨ n + 1 вҲ§ SвӮӮ.Finite := by
      have hSвӮӮ : SвӮӮ = ((Пғ''_unnormalized n).traceвҒ»В№ * В·) '' S := by
        simp [S, SвӮӮ, Set.image_image]
      constructor
      В· rw [hSвӮӮ]
        exact (Set.ncard_image_le h_card_subs.right).trans h_card_subs.left
      В· rw [hSвӮӮ]
        exact h_card_subs.right.image _
    refine (Set.ncard_le_ncard (t := (fun x => (Пғ''_unnormalized n).traceвҒ»В№ *
      Real.exp (f n x)) '' Set.Icc ((mineig ^ n) / 3) 1) ?_ h_sвӮӮ_finite).trans h_card_subsвӮӮ
    apply Set.image_mono
    rintro _ вҹЁi, rflвҹ©
    refine вҹЁ?_, MState.eigenvalue_le_one _ _вҹ©
    refine le_trans ?_ (ciInf_le (Finite.bddBelow_range _) i)
    refine le_trans ?_ (iInf_eigenvalues_le (hПғвӮҒ_le_Пғ' n) (HermitianMat.H _) _)
    dsimp [mineig, iInf]
    rw [вҶҗ Matrix.IsHermitian.spectrum_real_eq_range_eigenvalues]
    rw [вҶҗ Matrix.IsHermitian.spectrum_real_eq_range_eigenvalues]
    rw [spectrum.smul_eq_smul _ _ (CFC.spectrum_nonempty в„қ _ (ПғвӮҒвҠ—^S[n]).M.H)]
    rw [Real.sInf_smul_of_nonneg (by norm_num)]
    simp only [MState.toMat_M, smul_eq_mul, div_eq_inv_mul,
      mul_one, inv_pos, Nat.ofNat_pos, mul_le_mul_iff_rightвӮҖ]
    apply le_of_eq
    -- sInf (spectrum в„қ ПғвӮҒ.m) ^ n = sInf (spectrum в„қ ПғвӮҒвҠ—^S[n].m)
    symm
    apply sInf_spectrum_spacePow
  have hdpos n : 0 < Fintype.card (spectrum в„қ (Пғ'' n).m) := by
    rw [Fintype.card_pos_iff, Set.nonempty_coe_sort]
    apply IsSelfAdjoint.spectrum_nonempty
    exact (Пғ'' n).M.H

  -- Eq (S59) has a minus sign, which gets complicated when one of the relative entropies is infinite.
  -- However, I don't think we need this version with the minus sign.
  have qRel_pinching_pythagoras n : рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ'' n) = рқҗғ(ПҒвҠ—^S[n]вҖ–в„° n (ПҒвҠ—^S[n])) + рқҗғ(в„° n (ПҒвҠ—^S[n])вҖ–Пғ'' n) := by
    exact pinching_pythagoras (ПҒвҠ—^S[n]) (Пғ'' n)

  -- Eq. (S60)
  have qRel_ent_bound n : рқҗғ(ПҒвҠ—^S[n]вҖ–в„° n (ПҒвҠ—^S[n])) вүӨ ENNReal.ofReal (Real.log (n + 1)) := calc
    рқҗғ(ПҒвҠ—^S[n]вҖ–в„° n (ПҒвҠ—^S[n])) вүӨ ENNReal.ofReal (Real.log (Fintype.card (spectrum в„қ (Пғ'' n).m))) :=
      qRelativeEnt_op_le (by simp [hdpos n]) (pinching_bound ..)
    _ вүӨ ENNReal.ofReal (Real.log (n + 1)) := by
      grw [hdle n]
      В· exact_mod_cast le_rfl
      В· simp [hdpos n]

  -- Eq. (S61)
  have hliminf : Filter.atTop.liminf (fun n вҶҰ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ' n) / n) =
                 Filter.atTop.liminf (fun n вҶҰ рқҗғ(в„° n (ПҒвҠ—^S[n])вҖ–Пғ'' n) / n) := by
    trans Filter.atTop.liminf fun n вҶҰ рқҗғ(ПҒвҠ—^S[n]вҖ–Пғ'' n) / n
    В· have hg : Filter.atTop.Tendsto (fun n вҶҰ ENNReal.ofReal (c n) / n) (рқ“қ 0) := by
        rw [вҶҗ ENNReal.tendsto_toReal_iff_of_eventually_ne_top ?_ ENNReal.zero_ne_top]
        В· simpa [ENNReal.toReal_ofReal (hc _).le]
        В· rw [Filter.eventually_atTop]
          use 1
          intros
          finiteness
      apply le_antisymm
      В· nth_rw 2 [вҶҗ ENNReal.liminf_add_of_right_tendsto_zero hg]
        conv =>
          enter [2, 1, n]
          rw [Pi.add_apply, вҶҗ ENNReal.add_div]
        apply Filter.liminf_le_liminf (ОІ := в„қвүҘ0вҲһ)
        rw [Filter.eventually_atTop]
        use 1
        intro n _
        exact ENNReal.div_le_div (qRel_Пғ'_le_Пғ'' n) (by rfl)
      -- A copy of the В· above with Пғ' and Пғ'' swapped
      В· nth_rw 2 [вҶҗ ENNReal.liminf_add_of_right_tendsto_zero hg]
        conv =>
          enter [2, 1, n]
          rw [Pi.add_apply, вҶҗ ENNReal.add_div]
        apply Filter.liminf_le_liminf (ОІ := в„қвүҘ0вҲһ)
        rw [Filter.eventually_atTop]
        use 1
        intro n _
        exact ENNReal.div_le_div (qRel_Пғ''_le_Пғ' n) (by rfl)
    В· simp only [qRel_pinching_pythagoras, ENNReal.add_div, вҶҗ Pi.add_apply]
      conv =>
        lhs
        apply ENNReal.liminf_add_of_left_tendsto_zero
        tactic =>
          apply tendsto_of_tendsto_of_tendsto_of_le_of_le
            (g := (0 : в„• вҶ’ в„қвүҘ0вҲһ)) (h := fun n вҶҰ ENNReal.ofReal (Real.log (n + 1)) / n)
          В· exact tendsto_const_nhds
          В·  -- Basically that lim_nвҶ’вҲһ log n / n = 0
            rw [вҶҗ Filter.tendsto_sub_atTop_iff_nat 1]
            apply Filter.Tendsto.congr' (fвӮҒ := fun (n : в„•) вҶҰ ENNReal.ofReal (Real.log n / (n - 1)))
            В· simp only [Filter.EventuallyEq, вҶҗ ENNReal.ofReal_natCast, Filter.eventually_atTop]
              use 2; intros b hb
              convert ENNReal.ofReal_div_of_pos (y := b - 1) (by rify at b hb; linarith)
              В· norm_cast
                omega
              В· norm_cast; symm; apply Int.subNatNat_of_le
                omega
            refine Filter.Tendsto.comp (g := fun r вҶҰ ENNReal.ofReal (Real.log r / (r - 1)))
              ?_ tendsto_natCast_atTop_atTop
            rw [вҶҗ ENNReal.ofReal_zero]
            apply ENNReal.tendsto_ofReal
            convert Real.tendsto_pow_log_div_mul_add_atTop 1 (-1) 1 (zero_ne_one.symm) using 3
            В· simp
            В· ring
          В· positivity
          В· intro n
            exact ENNReal.div_le_div (qRel_ent_bound n) le_rfl

  clear qRel_ent_bound qRel_pinching_pythagoras hdpos hdle qRel_Пғ'_le_Пғ'' qRel_Пғ''_le_Пғ'

  -- Eq. (S62)
  have hliminfR : Filter.atTop.liminf (fun n вҶҰ рқҗғ(в„° n (ПҒвҠ—^S[n])вҖ–Пғ'' n) / n) - R1 ПҒ Оө вүӨ
      вҶ‘(1 - Оө') * (R2 ПҒ Пғ - R1 ПҒ Оө) := by
    have В«hПғ''_ge_ПғвӢҶВ» n : Пғ'' n вүҘ (Real.exp (-c n) / 3) вҖў (В«ПғвӢҶВ» n).M := by
      grw [ge_iff_le, вҶҗ Пғ'_le_Пғ'', div_eq_mul_inv, вҶҗ smul_smul, вҶҗ one_div]
      rw [smul_le_smul_iff_of_pos_left (by positivity), hПғ'n_eq_sum_third]
      apply le_add_of_le_of_nonneg
      В· apply le_add_of_nonneg_left
        have := (В«ПғМғВ» n).zero_le
        positivity
      В· have := (ПғвӮҒвҠ—^S[n]).zero_le
        positivity --TODO: It would be so cool if this could be done by *just* positivity.
    have В«hПғ''_ge_ПғМғВ» n : Пғ'' n вүҘ (Real.exp (-c n) / 3) вҖў (В«ПғМғВ» n).M := by
      grw [ge_iff_le, вҶҗ Пғ'_le_Пғ'', div_eq_mul_inv, вҶҗ smul_smul, вҶҗ one_div]
      rw [smul_le_smul_iff_of_pos_left (by positivity), hПғ'n_eq_sum_third]
      apply le_add_of_le_of_nonneg
      В· apply le_add_of_nonneg_right
        have := (В«ПғвӢҶВ» n).zero_le
        positivity
      В· have := (ПғвӮҒвҠ—^S[n]).zero_le
        positivity --TODO: It would be so cool if this could be done by *just* positivity.
    have hПғ''_ge_ПғвӮҒ n : Пғ'' n вүҘ (Real.exp (-c n) / 3) вҖў (ПғвӮҒвҠ—^S[n]).M := by
      grw [ge_iff_le, вҶҗ Пғ'_le_Пғ'', div_eq_mul_inv, вҶҗ smul_smul, вҶҗ one_div]
      rw [smul_le_smul_iff_of_pos_left (by positivity)]
      exact hПғвӮҒ_le_Пғ' n

    have hc_littleO : (fun n : в„• вҶҰ c n + Real.log 3) =o[Filter.atTop] (fun x вҶҰ (x : в„қ)) := by
      apply Asymptotics.IsLittleO.add
      В· rw [Asymptotics.isLittleO_iff_tendsto']
        В· exact hc_lim
        simp only [Nat.cast_eq_zero, Filter.eventually_atTop]
        use 1
        grind
      В· --This really should be its own fact, TODO
        refine Asymptotics.isLittleO_const_left.2 <| Or.inr ?_
        convert tendsto_natCast_atTop_atTop (R := в„қ)
        ext; simp

    have hliminf_le : Filter.atTop.liminf (fun n вҶҰ
        вҖ”log ОІ_ Оө(в„° n (ПҒвҠ—^S[n])вҖ–{Пғ'' n}) / n) вүӨ (R1 ПҒ Оө).toNNReal := by --(S66)
      rw [ENNReal.coe_toNNReal hR1R2.ne_top]
      unfold R1
      calc _ = Filter.atTop.liminf (fun n => вҖ”log
