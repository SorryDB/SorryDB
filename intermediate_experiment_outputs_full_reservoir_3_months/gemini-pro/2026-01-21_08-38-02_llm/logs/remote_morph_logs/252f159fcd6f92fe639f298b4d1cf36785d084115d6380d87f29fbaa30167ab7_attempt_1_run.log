    use Пғ
    simp
  --This leaves us with the stronger statement that R1 < R2 strictly.
  --Before proceeding, let's reduce to the case that they're finite.
  have hR1 : R1 ПҒ Оө вү  вҠӨ := hR1R2.ne_top
  rcases eq_or_ne (R2 ПҒ Пғ) вҠӨ with hR2|hR2
  В· rw [hR2, ENNReal.top_sub hR1, ENNReal.mul_top', if_neg]
    В· simp
    В· have : Оө'.val < 1 := hОө'вӮӮ.trans hОө.2
      rcases Оө' with вҹЁОө',hОө'вӮҒ,hОө'вӮӮвҹ©
      simp only [Prob.toNNReal, Prob.coe_one_minus, ENNReal.coe_eq_zero]
      rw [Subtype.ext_iff, val_eq_coe, val_eq_coe, coe_zero, coe_mk]
      linarith +splitNe

  --Start giving the definitions from the paper. Define ОөвӮҖ
  let ОөвӮҖ : в„қ := (R2 ПҒ Пғ - R1 ПҒ Оө).toReal * (Оө - Оө') / (1 - Оө)
  have hОөвӮҖ : 0 < ОөвӮҖ :=
    have := sub_pos.mpr (show Оө.val < 1 from hОө.2)
    have := sub_pos.mpr (show Оө'.val < Оө from hОө'вӮӮ)
    have : 0 < (SteinsLemma.R2 ПҒ Пғ - SteinsLemma.R1 ПҒ Оө).toReal :=
      ENNReal.toReal_pos (tsub_pos_of_lt hR1R2).ne' (ENNReal.sub_ne_top hR2)
    by positivity
  have hОөвӮҖ' : (R1 ПҒ Оө).toReal вүӨ (R2 ПҒ Пғ).toReal + ОөвӮҖ := by
    dsimp [ОөвӮҖ]
    rw [вҶҗ sub_nonneg]
    have _ := sub_pos.mpr (show Оө.val < 1 from hОө.2)
    have _ := sub_pos.mpr (show Оө'.val < Оө from hОө'вӮӮ)
    rw [ENNReal.toReal_sub_of_le hR1R2.le (by finiteness)]
    field_simp
    suffices h : 0 вүӨ ((R2 ПҒ Пғ).toReal - (R1 ПҒ Оө).toReal) * ((вҶ‘Оө - вҶ‘Оө') + (1 - вҶ‘Оө)) by
      convert h using 1
      В· exact zero_mul _
      В· ring_nf
    rw [вҶҗ ENNReal.toReal_sub_of_le hR1R2.le (by finiteness)]
    positivity

  -- m exists because R2 + ОөвӮҖ is strictly above R2, which is the liminf.
  obtain вҹЁm, hmвҹ© :=
