               have : (b, !S b) ∈ S⌈⟨C::σ, o⟩⌉a := by
                  apply true_of_knowldege k
               have : (b, !S b) ∉ S⌈⟨C::σ, o⟩⌉a := not_notMem_resultSet
               contradiction
        contradiction
