    apply Iff.intro
    · intro hy
      obtain ⟨x, hx1, hx2⟩ := hy
      rw [←hx2]
      exact hx1
    · intro hy
      exists ⟨y, h _ hy⟩
      exact ⟨hy, rfl⟩
