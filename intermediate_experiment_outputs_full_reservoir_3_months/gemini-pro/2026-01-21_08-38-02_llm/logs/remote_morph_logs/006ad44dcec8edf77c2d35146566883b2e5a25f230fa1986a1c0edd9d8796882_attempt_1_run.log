    -- We show that for any valid A with |A| ≤ 5, there is a Sidon subset S with |S| ≥ (3/5)|A|.
    -- |A| = 0, 1, 2: S = A is Sidon. Ratio 1 ≥ 0.6.
    -- |A| = 3: Any set of size 3 has a Sidon subset of size 2 (ratio 2/3 ≈ 0.66).
    -- |A| = 4: We constructed a Sidon subset of size 3 (ratio 0.75).
    -- |A| = 5: We can find a Sidon subset of size 3 (ratio 0.6).
    have h_exists : ∃ S ⊆ A, IsSidon S ∧ (3 / 5 : ℝ) * A.ncard ≤ S.ncard := sorry
    exact h_exists

  apply lt_of_lt_of_le
  · norm_num
  · apply le_sSup
    use 3 / 5
    exact h_adm
