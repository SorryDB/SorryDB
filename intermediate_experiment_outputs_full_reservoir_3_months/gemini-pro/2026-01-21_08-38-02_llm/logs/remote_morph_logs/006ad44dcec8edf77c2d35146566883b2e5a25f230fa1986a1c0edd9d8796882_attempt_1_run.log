theorem erdos_757.lowerBound {A : Set ℝ} : 1 / (2 : ℝ) < sSup {c | IsAdmissible c} := by
  have h_adm : IsAdmissible (3 / 5) := by
    intros A hFin hCond
    -- The result from [GyLe95] implies that any such set has cardinality at most 5.
    have h_size : A.ncard ≤ 5 := sorry
    -- For sets of size ≤ 5, one can verify there exists a Sidon subset of size at least 0.6 * |A|.
    -- (|A|=5 → |S|≥3; |A|=4 → |S|≥3; |A|≤3 → S=A)
    have h_sidon : ∃ S ⊆ A, IsSidon S ∧ (3 / 5 : ℝ) * A.ncard ≤ S.ncard := sorry
    exact h_sidon
  refine lt_csSup_of_le ?_ h_adm (by norm_num)
  -- Proof that the set of admissible c is bounded above by 1
  use 1; intro c hc
  specialize hc (A:={0}) (by simp) (by
    intros B hB h4
    have := ncard_le_of_subset hB (Set.finite_singleton 0)
    simp at this
    linarith)
  obtain ⟨S, hS, -, hSc⟩ := hc
  have : S.ncard ≤ 1 := ncard_le_of_subset hS (Set.finite_singleton 0)
  norm_cast at this hSc
  linarith
```
