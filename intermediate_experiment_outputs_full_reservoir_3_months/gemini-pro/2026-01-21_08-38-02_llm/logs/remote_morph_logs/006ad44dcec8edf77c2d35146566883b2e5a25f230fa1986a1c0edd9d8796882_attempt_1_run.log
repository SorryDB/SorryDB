theorem erdos_757.lowerBound {A : Set ℝ} : 1 / (2 : ℝ) < sSup {c | IsAdmissible c} := by
  -- We prove that 3/5 is an admissible constant.
  have h_adm : IsAdmissible (3 / 5) := by
    intros A hA_fin h_cond
    -- The condition implies that A is very restricted.
    -- [GyLe95] proves that such sets have bounded cardinality.
