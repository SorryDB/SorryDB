        simp only [Set.mem_diff, Set.mem_union, Set.mem_setOf_eq, not_forall] at h_in
        rcases h_in with ⟨_, not_deleted⟩
        apply not_deleted
        intro T τ D equ role_eq sel_eq
        -- equ implies T agrees with S on knowledge.
        have know_same := equiv_then_know_same equ (Kv a b)
        rw [← know_same] at a_kv_b
        -- a_kv_b in T implies T b is known.
