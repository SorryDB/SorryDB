```lean
/-- Lemma 11 -/
lemma knowledge_implies_correct_belief {n} {S : @Dist n} {σ : @OSequence n} {a b : @Agent n} :
    S⌈σ⌉ ⊧ (Kv a b) → ((b, S b) ∈ S⌈σ⌉a ∧ (b, ! S b) ∉ S⌈σ⌉a) := by
  intro h_kv
  rcases σ with ⟨σ, o⟩
  induction σ generalizing S a b
  case nil =>
    rcases h_kv with (h|h) <;> {
      have := true_of_knowldege h; simp [eval] at this ⊢
      constructor; rw [this]; simp; rw [this]; simp [not_notMem_resultSet]
    }
  case cons C σ IH =>
    specialize IH (⁻o)
    cases ra : roleOfIn a C
    case Other =>
      rw [not_in_call_then_invariant_resultSet ra]
      rw [not_in_call_then_invariant_kv ra] at h_kv
      exact IH h_kv
    all_goals
      have kv_after := h_kv
      -- Part 2: (b, !Sb) is not in result set.
      have not_false : (b, ! S b) ∉ S⌈⟨C::σ,o⟩⌉a := by
        intro h_in
        unfold resultSet at h_in
        cases C <;> simp_all [ra]
        all_goals
          simp [Set.mem_diff] at h_in; rcases h_in with ⟨_, not_del⟩
          apply not_del
          simp
          intro T τ D equ _ _
          rcases h_kv with (h|h) <;> {
            have := true_of_knowldege h; subst this; simp at *
            apply h T ⟨τ, by simp at equ; exact equ.1⟩ equ.1 equ.2
          }
      constructor
      · -- Part 1: (b, Sb) is in result set.
        by_cases h_bef : eval S ⟨σ, ⁻o⟩ (Kv a b)
        · -- Known before.
          specialize IH h_bef
          unfold resultSet
          cases C <;> simp_all [ra]
          all_goals
            left; simp [Set.mem_diff]
            refine ⟨⟨IH.1, ?_⟩, ?_⟩
            · simp; intro h_ref; rw [eval_dis] at h_bef
              rcases h_bef with (h|h) <;> {
                have val := true_of_knowldege h; have ref := true_of_knowldege h_ref
                simp [eval, stubbornness] at val ref; try subst val; simp at ref
              }
            · simp; intro h_del
              rcases h_kv with (h|h) <;> {
                have val := true_of_knowldege h; subst val; simp at *
                have : eval S ⟨C::σ,o⟩ (K a (Has b (b, !S b))) := by
                   intro T τ equ; apply h_del T τ.1 C equ (by simp [ra]) (by cases C <;> simp)
                have val_wrong := true_of_knowldege this
                simp [eval, stubbornness] at val_wrong; contradiction
              }
        · -- Learned now.
          -- If a learns now, a must have received the correct value.
          -- If not, a would have empty knowledge, contradicting Kv.
          by_contra not_in
          have no_val : (b, S b) ∉ S⌈⟨C::σ,o⟩⌉a ∧ (b, ! S b) ∉ S⌈⟨C::σ,o⟩⌉a := ⟨not_in, not_false⟩
          -- The fact that 'a' has no value implies 'a' does not know 'b'.
          -- This contradicts h_kv.
          -- We prove this by showing that if 'a' has no value, the world is equiv to one with flipped 'b'.
          let T := S.switch b
          have sb_diff : S b ≠ T b := by simp [T, Dist.switch]
          rcases h_kv with (h|h) <;> {
             have val := true_of_knowldege h; subst val; simp at *
             apply sb_diff; apply know_self (σ.length + 1) _ ⟨C::σ,o⟩ _ (by simp)
             -- We need to prove: equiv a (S...) (T...)
