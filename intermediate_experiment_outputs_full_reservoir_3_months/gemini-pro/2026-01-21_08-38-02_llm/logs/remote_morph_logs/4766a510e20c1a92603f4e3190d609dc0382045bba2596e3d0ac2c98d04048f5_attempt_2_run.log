section proofWanted

-- I only need it for IsNonarchimedeanLocalField but it should be true in this generality
lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r := by
  constructor
  · intro h
    have hx : x ≠ 0 := by
      rw [← Valuation.ne_zero_iff (ValuativeRel.valuation K), h]
      exact one_ne_zero
    refine ⟨⟨⟨x, le_of_eq h⟩, ⟨x⁻¹, le_of_eq ?_⟩, ?_, ?_⟩, rfl⟩
    · rw [map_inv₀, h, inv_one]
    · ext; exact mul_inv_cancel₀ hx
    · ext; exact inv_mul_cancel₀ hx
  · rintro ⟨r, rfl⟩
    apply le_antisymm r.val.2
    rw [← inv_one, ← inv_le_inv_iff₀]
    · rw [← map_inv₀]; exact r.inv.2
    · rw [← Valuation.ne_zero_iff (ValuativeRel.valuation K)]; exact Units.ne_zero r
    · exact one_ne_zero
