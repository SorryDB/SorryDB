-- exercise 1.2.ii.ii
theorem Category.split_mono_iff {X Y : α} (f : Hom X Y) :
    split_mono f ↔
    ∀ c : α, Function.Surjective (fun g : Hom c X => g ≫ f) := by
  constructor
  · rintro ⟨s, hs⟩ c g
    use g ≫ s
    rw [assoc, hs, comp_id]
  · intro h
    rcases h Y (id Y) with ⟨s, hs⟩
    exact ⟨s, hs⟩
```
