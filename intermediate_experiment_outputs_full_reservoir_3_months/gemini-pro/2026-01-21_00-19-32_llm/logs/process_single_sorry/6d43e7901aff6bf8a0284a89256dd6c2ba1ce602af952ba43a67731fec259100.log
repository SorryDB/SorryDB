```lean
/- The Ackermann function, defined using pattern matching notation. -/
def A : ℕ → ℕ → ℕ
| 0,     n     => n + 1
| m + 1, 0     => A m 1
| m + 1, n + 1 => A m (A (m + 1) n)

def myA : ℕ → ℕ → ℕ :=
  Nat.rec (motive := fun _ => ℕ → ℕ)
    (fun n => n + 1)
    (fun _ Am => Nat.rec (motive := fun _ => ℕ)
      (Am 1)
      (fun _ res => Am res))

example : A = myA := by
  funext m n
  induction m, n using A.induct
  · intro n
    rw [A]
    rfl
  · intro m ih
    rw [A, ih]
    rfl
  · intro m n ih1 ih2
    rw [A, ih2, ih1]
    rfl
```
