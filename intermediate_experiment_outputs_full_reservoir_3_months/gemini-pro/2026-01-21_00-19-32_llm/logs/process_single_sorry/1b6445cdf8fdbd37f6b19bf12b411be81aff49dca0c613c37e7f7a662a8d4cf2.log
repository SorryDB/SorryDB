namespace ArrayModel

open unitInterval

section Aux

-- from Mathlib PR #30112
theorem representation {α β : Type*} {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
    [Nonempty β] [StandardBorelSpace β]
    (κ : Kernel α β) [IsMarkovKernel κ] :
    ∃ (f : α → I → β), Measurable (Function.uncurry f) ∧ ∀ a, volume.map (f a) = κ a := by
  obtain ⟨g, hg⟩ := MeasurableEmbedding.exists_measurableEmbedding_real β
  let κ' := κ.map g
  refine ⟨fun a x ↦ hg.invFun ((κ' a).quantile x), ?_, ?_⟩
  · exact hg.measurable_invFun.comp ((Kernel.measurable_quantile κ').comp
      (measurable_fst.prod_map measurable_subtype_coe))
  · intro a
    rw [← Measure.map_map hg.measurable_invFun (Kernel.measurable_quantile_right (κ' a)),
      Kernel.map_volume_quantile, Kernel.map_apply _ hg.measurable]
    exact hg.map_invFun_map_self (κ a)

end Aux

end ArrayModel
```
