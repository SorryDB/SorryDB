def antipodeBialgHom : C →ₐc[R] C where
  __ := antipodeAlgHom R (A := C)
  map_smul' := _
  counit_comp := counit_comp_antipode
  map_comp_comul := by
    apply left_inv_eq_right_inv (a := comul)
    · rw [mul_comm]
      exact LinearMap.comul_right_inv
    · calc
        comul * ((antipode R ⊗ₘ antipode R) ∘ₗ comul)
        _ = (LinearMap.id * (antipode R ⊗ₘ antipode R)) ∘ₗ comul := by
          ext; simp only [convMul_apply, coe_comp, Function.comp_apply, TensorProduct.map_apply]
          -- The equality corresponds to the fact that comul is a coalgebra morphism
          -- which holds for commutative cocommutative Hopf algebras.
          -- (δ ⊗ δ) ∘ δ = δ₂ ∘ δ
          sorry
        _ = 1 := by simp [LinearMap.id_mul_antipode]
