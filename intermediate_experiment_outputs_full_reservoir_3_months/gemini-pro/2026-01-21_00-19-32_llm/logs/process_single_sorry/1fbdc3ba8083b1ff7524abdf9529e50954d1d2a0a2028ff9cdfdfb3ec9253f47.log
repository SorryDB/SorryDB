section NormedSpace

variable [NormedSpace ℝ E] [CompleteSpace E]

lemma Locally.rightContinuous
    (hX : Locally (fun X ↦ ∀ ω, Function.RightContinuous (X · ω)) 𝓕 X P) :
    ∀ᵐ ω ∂P, Function.RightContinuous (X · ω) := by
  classical
  filter_upwards [hX.IsLocalizingSequence.tendsto_top] with ω hω x
  obtain ⟨n, hn⟩ : ∃ n, ↑x < hX.localSeq n ω := (WithTop.tendsto_atTop_nhds_top_iff.mp hω) x
  have h_cont := hX.stoppedProcess n ω x
  rw [stoppedProcess_indicator_comm] at h_cont
  by_cases h_lt : ⊥ < hX.localSeq n ω
  · simp only [Set.indicator_apply, Set.mem_setOf_eq, if_pos h_lt] at h_cont
    apply h_cont.congr_of_eventuallyEq
    rw [eventually_nhdsWithin_iff]
    have h_open : IsOpen {y | (y : WithTop ι) < hX.localSeq n ω} := by
      cases h : hX.localSeq n ω
      · simp [h, isOpen_univ]
      · simp [h, isOpen_Iio]
    refine eventually_of_mem (h_open.mem_nhds hn) fun y hy ↦ ?_
    simp only [Set.mem_setOf_eq] at hy
    rw [stoppedProcess_eq_of_le hy.le]
  · have : ⊥ < hX.localSeq n ω := lt_of_le_of_lt bot_le hn
    contradiction
