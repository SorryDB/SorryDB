```lean
theorem take_flatten (L : List (List α)) (i : Nat) :
    let j := (L.map length).partialSums.findIdx (· > i) - 1
    let k := i - (L.take j).flatten.length
    L.flatten.take i = (L.take j).flatten ++ (L[j]?.getD []).take k := by
  induction L generalizing i with
  | nil => simp
  | cons a l ih =>
    simp only [flatten_cons, partialSums_cons, findIdx_cons, zero_lt_one, Bool.false_eq_true,
      ↓reduceIte, map_map, Function.comp_def]
    conv in (map length l).partialSums => rw [← cons_head_tail partialSums_ne_nil, head_scanl]
    simp only [map_cons, findIdx_cons, Nat.add_zero]
    by_cases h : i < a.length
    · simp [h, take_append_of_le_length (le_of_lt h)]
    · rw [(_ : (fun x => decide (x + a.length > i)) = fun x => decide (x > i - a.length))]
      · simp only [take_append, h, not_lt_of_ge]
        rw [ih (i - a.length), take_cons]
        simp
        congr 3
        omega
      · funext; congr; omega
```
