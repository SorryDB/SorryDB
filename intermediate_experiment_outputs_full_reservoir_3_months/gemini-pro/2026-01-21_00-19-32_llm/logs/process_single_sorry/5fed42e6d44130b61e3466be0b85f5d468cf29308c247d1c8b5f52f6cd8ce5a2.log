section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  let measure (s : HopfieldState n) : ℕ := Finset.card (Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net s))
  have h_meas : ∀ a b, biasedEnergy net a < biasedEnergy net b → measure a < measure b := by
    intro a b h_lt
    apply Finset.card_lt_card
    rw [Finset.ssubset_iff]
    refine ⟨fun x hx => ?_, ⟨a, ?_⟩⟩
    · simp at hx ⊢; exact lt_trans hx h_lt
    · simp; exact h_lt
    · simp; exact lt_irrefl _
  intro x
  induction x using WellFounded.induction (WellFounded.measure measure) with
  | h x ih =>
    by_cases h_fp : biasedIsFixedPoint net x
    · exact ⟨BiasedUpdateSeq.nil x, h_fp⟩
    · rw [biasedIsFixedPoint] at h_fp
      push_neg at h_fp
      obtain ⟨i, hi⟩ := h_fp
      let x' := biasedUpdateState net x i
      have h_en : biasedEnergy net x' < biasedEnergy net x := by
        refine biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero net x i hi ?_
        intro h_zero
        simp [biasedUpdateState, biasedLocalField, h_zero] at hi
      obtain ⟨seq, h_seq⟩ := ih x' (h_meas _ _ h_en)
      exact ⟨BiasedUpdateSeq.cons x i seq, h_seq⟩
```
