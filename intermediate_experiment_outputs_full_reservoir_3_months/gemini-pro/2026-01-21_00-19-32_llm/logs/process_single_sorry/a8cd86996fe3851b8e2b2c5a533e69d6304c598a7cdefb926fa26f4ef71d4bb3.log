lemma komlos_norm [NormedAddCommGroup E] [InnerProductSpace ℝ E]
    {f : ℕ → E} (h_bdd : ∃ M : ℝ, ∀ n, ‖f n‖ ≤ M) :
    ∃ (g : ℕ → E) (x : E), (∀ n, g n ∈ convexHull ℝ (Set.range fun m ↦ f (n + m))) ∧
    Tendsto g atTop (𝓝 x) := by
  obtain ⟨M, hM⟩ := h_bdd
  obtain ⟨g, hg_mem, hg_conv⟩ := komlos_convex (φ := fun x ↦ ‖x‖ ^ 2)
    (fun x ↦ sq_nonneg _) ⟨M ^ 2, fun n ↦ by simpa using pow_le_pow_left (norm_nonneg _) (hM n) 2⟩
  have hg_cauchy : CauchySeq g := by
    refine Metric.cauchySeq_iff.2 fun ε hε ↦ ?_
    obtain ⟨N, hN⟩ := hg_conv (ε ^ 2 / 4) (by positivity)
    refine ⟨N, fun n m hn hm ↦ ?_⟩
    rw [dist_eq_norm, ← sq_lt_sq (norm_nonneg _) (le_of_lt hε),
      ← mul_lt_mul_right (show (0 : ℝ) < 4 by norm_num)]
    convert hN n m hn hm using 1
    simp only [NNReal.val_eq_coe, NNReal.coe_inv, NNReal.coe_ofNat]
    rw [norm_sub_sq, norm_add_sq]
    field_simp; ring
  refine ⟨g, lim (atTop.map g), fun n ↦ convexHull_min (subset_convexHull ℝ _)
    ((convex_convexHull ℝ _).restrictScalars ℝ≥0) (hg_mem n), hg_cauchy.tendsto_limit⟩
```
