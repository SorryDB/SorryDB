lemma biasedEnergyDiff_eq_neg_spinDiff_biasedLocalField :
    biasedEnergyDiff net x i = -((biasedUpdateState net x i i).toReal - (x i).toReal) * biasedLocalField net x i := by
  let net' := net.toHopfieldNetwork
  let x' := biasedUpdateState net x i
  let Δs := (x' i).toReal - (x i).toReal
  have h_bias : (Finset.univ.sum fun j => net.bias j * (x' j).toReal) - (Finset.univ.sum fun j => net.bias j * (x j).toReal) = net.bias i * Δs := by
    rw [← Finset.sum_sub_distrib]
    refine Finset.sum_eq_single i (fun j _ hji => ?_) (fun hi => (hi (Finset.mem_univ i)).elim)
    simp [x', biasedUpdateState, Function.update, hji]
  
  -- Express biasedEnergyDiff using the base network's energy difference and the bias term
  have h_eq : biasedEnergyDiff net x i = (HopfieldNetwork.energy net' x' - HopfieldNetwork.energy net' x) - net.bias i * Δs := by
    dsimp [biasedEnergyDiff, biasedEnergy, HopfieldNetwork.energy]
    simp only [Finset.sum_add_distrib, sub_sub, neg_sub, sub_left_inj]
    rw [h_bias]

  rw [h_eq]
  -- Use the property of the base Hopfield network: ΔE_base = -Δs * LF_base
  -- We assume the library provides a lemma for energy difference of an arbitrary update
  have h_base : HopfieldNetwork.energy net' x' - HopfieldNetwork.energy net' x = -Δs * localField net' x i :=
    HopfieldNetwork.energyDiff_of_update net' x i (x' i) (by rw [biasedUpdateState]; rfl)
    
  rw [h_base, biasedLocalField]
  ring
```
