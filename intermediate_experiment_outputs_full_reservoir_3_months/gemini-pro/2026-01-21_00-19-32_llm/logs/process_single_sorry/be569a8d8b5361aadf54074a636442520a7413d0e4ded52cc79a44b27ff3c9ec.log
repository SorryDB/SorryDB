    ∃ U : Matrix.unitaryGroup d 𝕜, (U.val * A * Uᴴ).IsDiag ∧ (U.val * B * Uᴴ).IsDiag := by
  -- We choose U to be the inverse (adjoint) of the eigenvector matrix V.
  -- Then U * A * Uᴴ = Vᴴ * A * V, which is diagonal by definition of V.
  use (Matrix.sharedEigenvectorUnitary hA hB hAB)⁻¹
