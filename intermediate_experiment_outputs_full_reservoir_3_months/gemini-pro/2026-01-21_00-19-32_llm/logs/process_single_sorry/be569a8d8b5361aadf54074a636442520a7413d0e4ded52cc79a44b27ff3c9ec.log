  · exact Matrix.SharedEigenbasis.star_mul_self_mul_IsDiag hA hB hAB
  -- For B, we follow the same logic. The shared basis diagonalizes B as well.
  · rw [Matrix.isDiag_iff_diagonal_diag]
    symm
