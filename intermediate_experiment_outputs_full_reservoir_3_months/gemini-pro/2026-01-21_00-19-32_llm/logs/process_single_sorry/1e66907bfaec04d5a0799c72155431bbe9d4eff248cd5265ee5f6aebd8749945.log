instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u, hu, hxu, _, v, hv, ⟨d⟩⟩ := hm.locally_modelled x
  let T := Equiv.addRight (Function.update 0 0 1 - d x)
  have cT : ContDiff ℝ ⊤ T := contDiff_id.add contDiff_const
  let dT : Eucl n ᵈ≃ Eucl n := ⟨T, cT.dsmooth, (contDiff_id.sub contDiff_const).dsmooth⟩
  let v' := v ∩ dT ⁻¹' {z | 0 < z 0}
  have hv' : IsOpen[DTop] v' := hv.inter (isOpen_Ioi.preimage (continuous_apply 0)).dTopCompatible
  refine ⟨d ⁻¹' v', hu.isOpen_of_isOpen_coe (d.continuous.isOpen_preimage _ (hv'.preimage continuous_subtype_val)), ⟨d.map_x_in_v hxu, by simp [T]; norm_num⟩, (), _, (dT.isOpenMap _ hv').preimage continuous_subtype_val, ?_⟩
  exact ⟨(d.restrict_preimage v').trans {
      toFun := fun ⟨z, h⟩ => ⟨⟨T z, le_of_lt h.2.2⟩, ⟨z, h, rfl⟩⟩
      invFun := fun ⟨⟨z, _⟩, ⟨a, ha, eq⟩⟩ => ⟨a, by rw [eq]; exact ha⟩
      left_inv := fun _ => rfl
      right_inv := fun _ => rfl
      dsmooth := (dT.dsmooth.comp continuous_subtype_val.dsmooth).subtype_mk _
      dsmooth_inv := (dT.symm.dsmooth.comp (continuous_subtype_val.comp continuous_subtype_val).dsmooth).subtype_mk _
    }⟩⟩
```
