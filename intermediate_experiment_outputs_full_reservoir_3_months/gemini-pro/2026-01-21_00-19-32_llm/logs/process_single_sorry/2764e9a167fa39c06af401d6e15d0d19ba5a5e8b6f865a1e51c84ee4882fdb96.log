lemma IsStarProjection_iff (p : H →L[ℂ] H) : IsStarProjection p ↔ ∃ (K : Submodule ℂ H),
    ∃ (kH : K.HasOrthogonalProjection), p = K.subtypeL.comp (@K.orthogonalProjection _ _ _ _ _ kH)
  := by
  constructor
  · intro h
    let K := LinearMap.range p
    have hK : IsClosed (K : Set H) := by
      rw [LinearMap.range_eq_ker_id_sub_self_of_idempotent]
      · exact isClosed_ker _
      · ext x; simp; exact DFunLike.congr_fun h.1 x
    have kH : K.HasOrthogonalProjection :=
      Submodule.hasOrthogonalProjection_of_complete hK.completeSpace_coe
    use K, kH
    exact eq_orthogonalProjection_of_idempotent_isSelfAdjoint h.1 h.2
  · rintro ⟨K, kH, rfl⟩
    exact orthogonalProjection_isStarProjection K
```
