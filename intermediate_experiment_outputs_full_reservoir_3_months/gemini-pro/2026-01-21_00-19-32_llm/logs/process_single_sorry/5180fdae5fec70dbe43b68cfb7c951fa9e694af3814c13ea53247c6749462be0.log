lemma Indecomposable_of_mem_Min_Direct_sum_decomposition
    (D : DirectSumDecomposition M) (N : PersistenceSubmodule M) (hN : N ∈ D) (hmax : IsMin D) :
    Indecomposable N := by
  classical
  by_contra hNotMax
  simp only [_root_.Indecomposable, not_forall, not_or] at hNotMax
  obtain ⟨x, y, hxy, rfl, hx, hy⟩ := hNotMax
  let B (N) (hN : N ∈ D) : Set (PersistenceSubmodule M) := if N = x ⊔ y then {x, y} else {N}
  set newD : DirectSumDecomposition M := refinement B
    (by intro N _; dsimp [B]; split_ifs <;> simp)
    (by
      intro N _
      dsimp [B]
      split_ifs
      · rw [sSupIndep_pair (by rintro rfl; exact hx hxy.eq_bot_of_self)]
        exact hxy
      · exact sSupIndep_singleton N)
    (by
      intro N hN
      dsimp [B]
      split_ifs
      · simp [hx, hy]
      · simp; rintro rfl; exact D.not_bot_mem hN)
```
