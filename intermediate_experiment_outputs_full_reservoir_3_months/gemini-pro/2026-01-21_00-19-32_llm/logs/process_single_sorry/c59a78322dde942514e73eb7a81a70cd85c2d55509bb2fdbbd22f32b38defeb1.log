section LoopWalkCounting

lemma mem_supportSet_start {u v : V} (p : G.LoopWalk u v) : u ∈ p.supportSet := by
  cases p <;> simp [supportSet, support]

lemma mem_supportSet_of_mem_edgeSet {u v : V} {p : G.LoopWalk u v} {x : V}
    (h : ∃ e ∈ p.edgeSet, x ∈ e) : x ∈ p.supportSet := by
  induction p with
  | nil => simp [edgeSet, edges, darts] at h
  | @cons u v w h p ih =>
    rcases h with ⟨e, he, hx⟩
    simp [edgeSet, edges, darts, supportSet, support] at he ⊢
    rcases he with rfl | he
    · simp at hx; rcases hx with rfl | rfl <;> simp [mem_supportSet_start]
    · right; apply ih; use e
  | loop p ih =>
    rcases h with ⟨e, he, hx⟩
    simp [edgeSet, edges, darts, supportSet, support] at he ⊢
    rcases he with rfl | he
    · simp at hx; simp [hx]
    · right; apply ih; use e

lemma vertex_edge_inequality {u v : V} (p : G.LoopWalk u v) :
  (supportSet p).card ≤ (edgeSet p).card + 1 := by
  induction p with
  | nil =>
    simp [supportSet, edgeSet, support, darts, edges]
  | @cons u v w h p ih =>
    simp only [supportSet, edgeSet, support, darts, edges, List.map_cons, List.toFinset_cons]
    by_cases hu : u ∈ p.supportSet
    · rw [Finset.insert_eq_of_mem hu]
      trans p.edgeSet.card + 1
      · exact ih
      · apply Nat.add_le_add_right; apply Finset.card_le_card_insert
    · have he : Sym2.mk (u, v) ∉ p.edgeSet := by
        intro h
        apply hu
        apply mem_supportSet_of_mem_edgeSet
        use Sym2.mk (u, v)
        simp [h]
      rw [Finset.card_insert_of_not_mem hu, Finset.card_insert_of_not_mem he]
      exact Nat.add_le_add_right ih 1
  | @loop u v p ih =>
    simp only [supportSet, edgeSet, support, darts, edges, List.map_cons, List.toFinset_cons]
    rw [Finset.insert_eq_of_mem (mem_supportSet_start p)]
    trans p.edgeSet.card + 1
    · exact ih
    · apply Nat.add_le_add_right; apply Finset.card_le_card_insert

end LoopWalkCounting
