instance : Fact (∀ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ), IsOpen
  (((Aux.c_v_alg V v)).toAddMonoidHom.comp
    (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
      (IsDedekindDomain.HeightOneSpectrum.adicCompletionIntegers ℚ
        v).subtype.toAddMonoidHom.toIntLinearMap).toAddMonoidHom).range.carrier) :=
  ⟨fun v ↦ by
    -- Aux.c_v_alg is the same as Aux.c_v which is a homeomorphism
    -- so one only has to check that the span of the integral lattice is open
    let K_v := v.adicCompletion ℚ
    let O_v := v.adicCompletionIntegers ℚ
    let b := IntegralLattice.basis ℤ ℚ V
    let B := b.baseChange K_v
    let φ : (IntegralLattice ℤ ℚ V ⊗[ℤ] K_v) ≃L[K_v] (Module.Basis.ofVectorSpaceIndex ℚ V → K_v) :=
      { B.equivFun with
        continuous_toFun := IsModuleTopology.continuous_of_linearMap _
        continuous_invFun := IsModuleTopology.continuous_of_linearMap _ }
    rw [Set.range_comp, (Aux.c_v V v).toHomeomorph.isOpen_image_iff,
      ← φ.toHomeomorph.isOpen_image_iff]
    convert isOpen_set_pi Set.finite_univ (fun _ _ ↦ NumberField.isOpenAdicCompletionIntegers ℚ v)
    ext f
    simp only [Set.mem_image, LinearMap.mem_range, Set.mem_pi, Set.mem_univ, forall_true_left]
    constructor
    · rintro ⟨_, ⟨y, rfl⟩, rfl⟩
      induction y using TensorProduct.induction_on with
      | zero => simp [O_v, Subring.zero_mem]
      | tmul m a =>
        simp only [ContinuousLinearEquiv.coe_mk, LinearEquiv.coe_mk, Basis.baseChange_equivFun_apply,
          LinearMap.lTensor_tmul, Submodule.toIntLinearMap_apply]
        exact O_v.toAddSubgroup.zsmul_mem (b.repr m _) a.2
      | add x y hx hy =>
        simp only [map_add]
        exact O_v.toAddSubgroup.add_mem hx hy
    · intro hf
      refine ⟨TensorProduct.sum Finset.univ (fun i ↦ b i ⊗ₜ[ℤ] ⟨f i, hf i⟩), ?_⟩
      apply φ.injective; ext i
      simp only [map_sum, ContinuousLinearEquiv.coe_mk, LinearEquiv.coe_mk, LinearMap.lTensor_sum,
        LinearMap.lTensor_tmul, Submodule.toIntLinearMap_apply, Basis.baseChange_equivFun_apply]
      rw [Finset.sum_eq_single i]
      · simp [b.repr_self_apply]
      · intro j _ hji; simp [b.repr_self_apply_ne _ _ hji]
      · exact fun hi ↦ (hi (Finset.mem_univ i)).elim⟩
