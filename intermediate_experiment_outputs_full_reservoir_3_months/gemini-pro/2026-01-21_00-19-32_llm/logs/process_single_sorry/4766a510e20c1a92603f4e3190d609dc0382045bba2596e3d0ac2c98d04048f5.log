lemma valuation_eq_one_iff (K : Type*) [Field K] [ValuativeRel K] (x : K) :
  (ValuativeRel.valuation K) x = 1 ↔ ∃ r : 𝒪[K]ˣ, x = r := by
  let v := ValuativeRel.valuation K
  constructor
  · intro h
    have hx : x ∈ v.integer := (v.mem_integer_iff x).2 (le_of_eq h)
