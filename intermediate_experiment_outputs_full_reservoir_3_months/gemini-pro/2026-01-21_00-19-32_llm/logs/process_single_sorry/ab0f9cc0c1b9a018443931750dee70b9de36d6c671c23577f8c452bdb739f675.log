lemma valuation_ringEquiv {L : Type*} [Field L] [ValuativeRel L] [TopologicalSpace L]
    [IsNonarchimedeanLocalField L] (e : L ≃+* L) (x : L) :
    valuation L (e x) = valuation L x := by
  let v := valuation L
  refine Valuation.isEquiv_iff_eq.mp ?_ x
  rw [Valuation.isEquiv_iff_val_le_one]
  intro y
  by_cases hy : y = 0
  · simp [hy]
  have h_cont : Continuous e := continuous_of_ringHom e
  have h_cont_symm : Continuous e.symm := continuous_of_ringHom e.symm
  rw [← not_lt, ← Valuation.map_inv, Valued.isTopologicallyNilpotent_iff_val_lt_one,
      ← not_lt, ← Valuation.map_inv, Valued.isTopologicallyNilpotent_iff_val_lt_one]
  rw [← map_inv]
  exact not_congr ⟨fun h => IsTopologicallyNilpotent.map h_cont_symm e.symm.map_zero (by rwa [e.symm_apply_apply]),
                   fun h => IsTopologicallyNilpotent.map h_cont e.map_zero h⟩
```
