@[sorryful]
lemma trajectory_velocity_eq_zero_iff (IC : InitialConditions) (t : Time)
    (hx : IC.x₀ ≠ 0 ∨ IC.v₀ ≠ 0) :
    ∂ₜ (IC.trajectory S) t = 0 ↔
    ‖(IC.trajectory S) t‖ = √(‖IC.x₀‖^2 + (‖IC.v₀‖/S.ω)^2) := by
  have hm : S.m ≠ 0 := by intro h; simp [h, S.ω_sq] at S.ω_neq_zero
  have hk : S.k = S.m * S.ω ^ 2 := by rw [S.ω_sq, mul_div_cancel₀ _ hm]
  have hE := trajectory_energy S IC
  simp only [energy, kineticEnergy, potentialEnergy, hk] at hE
  replace hE := congr_fun hE t
  field_simp [hm] at hE
  rw [← norm_eq_zero, ← sq_eq_zero_iff]
  rw [Real.sqrt_eq_iff_sq_eq (by positivity) (norm_nonneg _)]
  field_simp [S.ω_neq_zero]
  constructor
  · intro h
    rw [h, zero_add] at hE
    ring_nf at hE ⊢
    exact hE
  · intro h
    ring_nf at h ⊢
    rw [h] at hE
    simp at hE
    exact hE
