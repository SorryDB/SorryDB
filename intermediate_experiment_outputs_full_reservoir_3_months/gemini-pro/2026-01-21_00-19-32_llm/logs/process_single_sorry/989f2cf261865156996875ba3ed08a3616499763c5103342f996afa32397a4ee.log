lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h
  apply sub_eq_zero.mp; by_contra hne
  rcases LinearMap.exists_apply_ne_zero_of_ne_zero (sub_ne_zero.mpr hne) with ⟨l, hl⟩
  let L : X →ₗ[ℝ] Eucl 1 :=
    { toFun := fun u ↦ .single 0 (l u), map_add' := by simp, map_smul' := by simp }
  have hL : DSmooth L := LinearMap.dsmooth L
  let P := internalTangentMap L x
  let extract : InternalTangentSpace (L x) →ₗ[ℝ] Eucl 1 :=
    Submodule.Quotient.lift _ (DirectSum.toModule _ _ _ fun p ↦ fderiv ℝ p.1.2 0) <| by
      rintro _ ⟨p, q, f, w, rfl⟩; simp only [DirectSum.toModule_lof, LinearMap.map_sub, sub_eq_zero]
      exact (fderiv_comp _ p.2.1.differentiableAt (by simp)).symm
  have : extract (P (vectorSpaceToInternalTangentSpace x v)) =
         extract (P (vectorSpaceToInternalTangentSpace x w)) := by rw [h]
  simp only [vectorSpaceToInternalTangentSpace, P, internalTangentMap, preInternalTangentMap, hL,
    ↓reduceDIte, Submodule.mapQ_apply, InternalTangentSpace.lof, Submodule.mkQ_apply,
    Submodule.Quotient.lift_mk, DirectSum.toModule_lof, pointedPlots_map, comp_apply] at this
  have dL : DifferentiableAt ℝ L (x + 0 • v) := L.differentiableAt
  rw [fderiv_comp _ dL (by simp), fderiv_comp _ dL (by simp)] at this
  simp only [fderiv_add differentiableAt_const (differentiableAt_id.smul_const _), fderiv_const,
    fderiv_smul_const, fderiv_id, ContinuousLinearMap.add_apply, ContinuousLinearMap.zero_apply,
    ContinuousLinearMap.smulRight_apply, ContinuousLinearMap.id_apply, zero_add,
    L.fderiv, ContinuousLinearMap.coe_coe, L.map_smul, one_smul] at this
  exact hl this
```
