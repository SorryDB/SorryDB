-- TODO: find a better name!
lemma integrable_smul {f : E → F} {μ : Measure E} (φ : 𝓓(Ω, ℝ)) (hf : LocallyIntegrableOn f Ω μ) :
    Integrable (fun x ↦ φ x • f x) μ := by
  let K := tsupport φ
  have hK : IsCompact K := φ.hasCompactSupport.isCompact
  have hfK : IntegrableOn f K μ := hf.integrableOn_isCompact hK φ.tsupport_subset_source
  refine (φ.contDiff.continuous.continuousOn.integrableOn_smul hK hfK).integrable_of_support_subset ?_
  exact subset_trans (support_smul_subset_left φ f) subset_closure
```
