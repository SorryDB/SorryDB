```lean
theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem]
    rw [beq_iff_eq, eq_comm]
  | node v l r ihl ihr =>
    rcases h with ⟨hl_le, hr_ge, hl_ord, hr_ord, hv_mem⟩
    simp [fastCheckMem]
    split
    · next heq =>
      simp at heq
      subst heq
      simp [LabelledTree.mem, hv_mem]
    · next hne =>
      simp at hne
      split
      · next hlt =>
        rw [ihl hl_ord]
        constructor
        · intro h; left; exact h
        · rintro (h | h)
          · exact h
          · have := hr_ge _ h
            have := lt_of_lt_of_le hlt this
            exfalso; exact lt_irrefl _ this
      · next hnlt =>
        have hgt : v < label := lt_of_le_of_ne (le_of_not_lt hnlt) hne.symm
        rw [ihr hr_ord]
        constructor
        · intro h; right; exact h
        · rintro (h | h)
          · have := hl_le _ h
            have := lt_of_le_of_lt this hgt
            exfalso; exact lt_irrefl _ this
          · exact h
```
