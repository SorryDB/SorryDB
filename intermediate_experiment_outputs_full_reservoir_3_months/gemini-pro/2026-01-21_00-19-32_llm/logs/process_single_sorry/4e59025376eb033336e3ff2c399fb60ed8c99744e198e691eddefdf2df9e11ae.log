theorem isTightMeasureSet_iff_isCompact_closure
  {E : Type*} {mE : MeasurableSpace E} [MetricSpace E] [CompleteSpace E]
  [SecondCountableTopology E] [BorelSpace E] {S : Set (ProbabilityMeasure E)} :
    IsTightMeasureSet {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
      ↔ IsCompact (closure S) := by
  let S' := {((μ : ProbabilityMeasure E) : Measure E) | μ ∈ S}
  have hS' : S' = (fun μ ↦ (μ : Measure E)) '' S := rfl
  rw [hS']
  have h_ne_zero : ∀ μ ∈ (fun μ ↦ (μ : Measure E)) '' S, μ ≠ 0 := by
    rintro _ ⟨μ, _, rfl⟩; exact μ.ne_zero
  have h_bound : ∃ C, ∀ μ ∈ (fun μ ↦ (μ : Measure E)) '' S, μ univ ≤ C :=
    ⟨1, by rintro _ ⟨μ, _, rfl⟩; simp⟩
  rw [MeasureTheory.isTightMeasureSet_iff_isCompact h_ne_zero h_bound]
  refine ⟨fun h ↦ ?_, fun h ↦ h.image ProbabilityMeasure.continuous_coe⟩
  rw [Embedding.isCompact_iff_isCompact_image ProbabilityMeasure.inducing_coe.embedding]
  refine IsCompact.of_isClosed_subset h isClosed_closure (fun μ hμ ↦ ?_)
  obtain ⟨u, huS, huμ⟩ := mem_closure_iff_seq_limit.mp hμ
  have h_tight : IsTightMeasureSet ((fun μ ↦ (μ : Measure E)) '' S) :=
    (MeasureTheory.isTightMeasureSet_iff_isCompact h_ne_zero h_bound).mpr h
  have : IsProbabilityMeasure μ :=
    IsTightMeasureSet.isProbabilityMeasure_of_tendsto h_ne_zero huμ h_tight (fun n ↦ ⟨_, huS n, rfl⟩)
  lift μ to ProbabilityMeasure E using this
  rw [← (Embedding.closure_eq_preimage_closure_image ProbabilityMeasure.inducing_coe.embedding)]
  exact hμ
```
