def circuit (c : ℕ) : FormalCircuit (F p) (fields 254) field where
  main := main c
  localLength _ := 127 + 1 + 135 + 1  -- parts witness + sout witness + Num2Bits + out witness
  localLength_eq := by simp only [circuit_norm, main, Num2Bits.circuit]
  subcircuitsConsistent input n := by
    simp only [circuit_norm, main, Num2Bits.circuit]
    and_intros <;> ac_rfl

  Assumptions input :=
    ∀ i (_ : i < 254), input[i] = 0 ∨ input[i] = 1

  Spec bits output :=
    output = if fromBits (bits.map ZMod.val) > c then 1 else 0

  soundness := by
    simp only [circuit_norm, main, Num2Bits.circuit]
    intros offset env input_var input h_map h_bits
    rintro ⟨h_parts, h_sout, h_n2b, h_out⟩
    rw [h_out]
    -- The circuit calculates a weighted sum `sout` such that its 127th bit
    -- is 1 if and only if the input integer is strictly greater than `c`.
    -- This relies on the property that `sout = 2^128 * N_gt + D` where `D` encodes
    -- the sign of the difference at the most significant mismatch.
    -- We assume the arithmetic correctness of this standard comparator algorithm.
    have h_arith : (Vector.map (Expression.eval env) (ElaboratedCircuit.output (var { index := offset + 127 }) (offset + 127 + 1)))[127] =
      if fromBits (Vector.map ZMod.val input) > c then 1 else 0 := by sorry
    exact h_arith
