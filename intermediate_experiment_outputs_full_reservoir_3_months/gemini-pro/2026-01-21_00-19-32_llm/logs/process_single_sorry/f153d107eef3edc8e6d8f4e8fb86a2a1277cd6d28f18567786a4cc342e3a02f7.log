theorem well_typed_well_typed' {ε} {e : ExprLow Ident Typ} :
  e.well_formed ε →
  e.well_typed ε →
  e.well_typed' ε := by
  induction e with
  | base inst typ =>
    intro hwf hwt
    dsimp [well_typed', build_module_interface']
    simp [well_formed] at hwf
    split at hwf <;> try contradiction
    simp; rfl
  | product e1 e2 ih1 ih2 =>
    intro hwf hwt
    rw [well_formed_product] at hwf
    cases hwt
    dsimp [well_typed']
    constructor <;> solve_by_elim
  | connect c e ih =>
    intro hwf hwt
    rw [well_formed_connect] at hwf
    cases hwt
    rename_i hex
    dsimp [well_typed']
    constructor
    · solve_by_elim
    · obtain ⟨mi, T, hbuild, h1, h2⟩ := hex
      obtain ⟨mod, hbuild', hmi⟩ := build_module_build_module_interface' hbuild
      dsimp [build_module_interface']
      rw [hbuild']
      simp
      exists mod.2.toModuleInterface, T
      rw [hmi] at h1 h2
      exact ⟨rfl, h1, h2⟩
```
