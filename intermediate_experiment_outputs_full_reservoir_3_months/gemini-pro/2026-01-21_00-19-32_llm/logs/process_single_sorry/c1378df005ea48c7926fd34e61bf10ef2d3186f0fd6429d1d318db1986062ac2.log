open Classical in
instance : AdjointSpace 𝕜 ((i : ι) → E i) where
  inner := fun x y => ∑ i, ⟪x i, y i⟫_𝕜
  inner_top_equiv_norm := by
    let C := fun i => Classical.choose (inner_top_equiv_norm (𝕜 := 𝕜) (E := E i))
    let D := fun i => Classical.choose (Classical.choose_spec (inner_top_equiv_norm (𝕜 := 𝕜) (E := E i)))
    have h : ∀ i, C i > 0 ∧ D i > 0 ∧ ∀ x, C i • ‖x‖^2 ≤ re ⟪x, x⟫_𝕜 ∧ re ⟪x, x⟫_𝕜 ≤ D i • ‖x‖^2 := 
      fun i => Classical.choose_spec (Classical.choose_spec (inner_top_equiv_norm (𝕜 := 𝕜) (E := E i)))
    let c := if h : (Finset.univ : Finset ι).Nonempty then Finset.univ.inf' h C else 1
    let d := if h : (Finset.univ : Finset ι).Nonempty then Finset.univ.sum D else 1
    use c, d
    constructor
    · split_ifs <;> [exact (Finset.lt_inf'_iff _).2 (fun i _ => (h i).1); norm_num]
    constructor
    · split_ifs with h₁ <;> [exact Finset.sum_pos (fun i _ => (h i).2.1) h₁; norm_num]
    intro x
    split_ifs with h₁
    · constructor
      · rw [smul_eq_mul]
        calc c * ‖x‖^2 ≤ c * ∑ i, ‖x i‖^2 := by
               gcongr
               rw [Pi.norm_def]
               apply Finset.sup_le
               intro i hi
               rw [Real.le_sqrt (by positivity) (by positivity)]
               exact Finset.single_le_sum (fun _ _ => sq_nonneg _) hi
             _ = ∑ i, c * ‖x i‖^2 := by rw [Finset.mul_sum]
             _ ≤ ∑ i, C i * ‖x i‖^2 := Finset.sum_le_sum (fun i _ => mul_le_mul_of_nonneg_right (Finset.inf'_le _ _ _) (by positivity))
             _ ≤ ∑ i, re ⟪x i, x i⟫_𝕜 := Finset.sum_le_sum (fun i _ => by rw [← smul_eq_mul]; exact ((h i).2.2 (x i)).1)
             _ = re (∑ i, ⟪x i, x i⟫_𝕜) := by simp [map_sum]
      · rw [inner, map_sum]
        calc re (∑ i, ⟪x i, x i⟫_𝕜) = ∑ i, re ⟪x i, x i⟫_𝕜 := by simp [map_sum]
             _ ≤ ∑ i, D i • ‖x i‖^2 := Finset.sum_le_sum (fun i _ => ((h i).2.2 (x i)).2)
             _ ≤ ∑ i, D i • ‖x‖^2 := Finset.sum_le_sum (fun i _ => by
                 rw [smul_eq_mul, smul_eq_mul]
                 gcongr
                 exact (h i).2.1.le
                 exact norm_le_pi_norm x i)
             _ = (∑ i, D i) • ‖x‖^2 := by rw [Finset.sum_smul]
             _ = d • ‖x‖^2 := by simp [d, h₁]
    · simp at h₁
      have : x = 0 := by ext i; exact (h₁ ⟨i⟩).elim
      simp [this]; norm_num
