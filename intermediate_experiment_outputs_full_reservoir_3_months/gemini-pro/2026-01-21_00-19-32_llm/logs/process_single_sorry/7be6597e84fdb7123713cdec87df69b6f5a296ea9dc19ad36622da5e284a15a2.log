lemma vectorSpaceToInternalTangentSpace_surjective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Surjective (vectorSpaceToInternalTangentSpace x) := by
  intro v
  apply Submodule.Quotient.induction_on v
  intro z
  induction z using DirectSum.induction_on
  case zero => use 0; simp
  case atom p w =>
    -- For a fine diffeology, every plot is tangent to a linear curve, so we can find a vector.
    -- However, extracting this vector requires an API for fine diffeologies not present here.
    sorry
  case plus x y hx hy =>
    obtain ⟨vx, hx⟩ := hx
    obtain ⟨vy, hy⟩ := hy
    use vx + vy
    simp [hx, hy]
