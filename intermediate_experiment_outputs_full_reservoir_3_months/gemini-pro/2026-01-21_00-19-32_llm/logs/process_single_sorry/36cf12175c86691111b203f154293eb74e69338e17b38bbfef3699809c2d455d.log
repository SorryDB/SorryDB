  have : iIndepFun (fun (p : ℕ × α) ω ↦ ω p.1 p.2) (Measure.infinitePi fun _ ↦ Measure.infinitePi (fun _ ↦ ν)) := by
    rw [Measure.iIndepFun_infinitePi_iff]
