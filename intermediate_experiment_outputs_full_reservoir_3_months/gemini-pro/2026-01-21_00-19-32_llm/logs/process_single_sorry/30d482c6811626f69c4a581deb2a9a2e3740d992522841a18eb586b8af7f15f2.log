lemma noHo_exp_and_known_needs_many_calls (S : List (Call n))
    (S_noHo : noHo S)
    (k : Fin n)
    (h : isExpert (after S) k)
    (h2 : allKnow (after S) k)
    : 2 * n - 2 - v S k ≤ S.length := by
  let weight (c : Call n) := if c.fst = k ∨ c.snd = k then 2 else 1
  have h_sum : (S.map weight).sum = S.length + v S k := by
    induction S with
    | nil => simp [v]
    | cons c S ih =>
      simp [v] at *
      simp [weight]
      split_ifs <;> linarith
  have h_bound : (S.map weight).sum ≥ 2 * n - 2 := by
    -- Use Lemma 6 "calls needed for both spreading and informing are those in v S k"
    -- This requires a connectivity argument on the graph of calls.
    sorry
  rw [← h_sum] at h_bound
  exact Nat.sub_le_of_le_add h_bound
```
