The minimal integer is $k = n^2 - n + 1$.
The proof consists of two parts:
1.  **Sufficiency**: For $k = n^2 - n + 1$, any two companies share a linked pair.
    The number of stations is $N = n^2$. Each company consists of $k$ cars, which form a set of disjoint chains (since start and finish stations are unique). The number of chains in a company is $N - k = n - 1$.
    Let the chains of company $A$ be $C_1^A, \dots, C_{n-1}^A$ and of company $B$ be $C_1^B, \dots, C_{n-1}^B$. These form two partitions of the $N$ stations.
    By the Pigeonhole Principle, since $\sum_{i,j} |C_i^A \cap C_j^B| = N = n^2$ and the number of pairs $(i, j)$ is $(n-1)^2$, there must exist some intersection with size at least $\lceil n^2 / (n-1)^2 \rceil = 2$ (since $n \ge 2 \implies n^2 > (n-1)^2$).
    If two stations $u, v$ are in the same chain of $A$ and the same chain of $B$, with $u < v$, then $u$ is linked to $v$ in both companies (due to the monotonicity property).

2.  **Minimality**: For $k = n^2 - n$, there exist companies with no shared linked pairs.
    We can construct "Row" and "Column" companies on an $n \times n$ grid.
    Company A connects $(r, c) \to (r, c+1)$. Linked pairs share a row.
    Company B connects $(r, c) \to (r+1, c)$. Linked pairs share a column.
    The intersection of "same row" and "same column" is "same cell", but a station cannot be linked to itself (requires at least one car). Thus, no linked pairs.

```lean
def answer : (Set.Ioi 1) → ℕ := fun n => n ^ 2 - n + 1

theorem result (n : Set.Ioi 1) :
    IsLeast {k : ℕ | ∀ A B : Company n k, ∃ i j, A.linked i j ∧ B.linked i j} (answer n) := by
  have hn : 2 ≤ (n : ℕ) := Nat.le_of_lt n.2
  let N := (n : ℕ) ^ 2
  constructor
  · intro A B
    let k := answer n
    let root (C : Company n k) (i : Fin N) : Fin N :=
      if h : ∃ j, (C.cars j).finish = i then root C (C.cars h.some).start else i
    termination_by i
    decreasing_by exact (C.cars _).start_lt_finish.trans_eq (Classical.choose_spec h).symm
    let f (i : Fin N) := (root A i, root B i)
    have : ¬ Function.Injective f := fun h ↦ by
      let S (C : Company n k) := (Finset.univ : Finset (Fin N)).filter (fun i ↦ ∀ j, (C.cars j).finish ≠ i)
      have hc (C : Company n k) : (S C).card = n - 1 := by
        simp [S, N, k, answer, Nat.sub_sub_assoc, Nat.add_sub_cancel_left, Nat.mul_sub_left_distrib]
        rw [← Fintype.card_fin N]; exact Fintype.card_subtype_compl _
      have hr (C : Company n k) : ∀ i, root C i ∈ S C := fun i ↦ by
        rw [Finset.mem_filter]; use Finset.mem_univ _; by_contra h; obtain ⟨j, hj⟩ := not_forall.1 h
        rw [root, dif_pos ⟨j, hj⟩] at *; exact (C.cars j).start_lt_finish.ne (hj.symm.trans (Eq.symm <| Classical.choose_spec _))
      have : Fintype.card (Fin N) ≤ Fintype.card (S A × S B) := Fintype.card_le_of_injective (fun i ↦ ⟨⟨root A i, hr A i⟩, ⟨root B i, hr B i⟩⟩) (fun x y e ↦ h (Prod.ext (Subtype.ext (Prod.ext_iff.1 e).1) (Subtype.ext (Prod.ext_iff.1 e).2)))
      simp [hc, N] at this; nlinarith
    obtain ⟨x, y, hne, hf⟩ := Finite.exists_ne_map_eq_of_card_lt (by simp [N]; nlinarith) f
    wlog hxy : x < y generalizing x y; · exact (this y x hne.symm hf.symm).imp (fun i ↦ Exists.imp (fun j ↦ And.symm) (hxy y x hne.symm hf.symm (Nat.le_of_not_lt hxy)))
