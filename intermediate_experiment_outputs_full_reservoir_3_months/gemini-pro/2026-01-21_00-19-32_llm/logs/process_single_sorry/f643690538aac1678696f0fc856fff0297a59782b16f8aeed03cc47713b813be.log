/-- Tensoring over the adele ring is the same as the product of tensoring over ℝ and
the restricted product of tensoring over ℚₚ. -/
noncomputable def IntegralLattice.tensorAdelesContinuousEquivRestrictedProduct :
    (IntegralLattice ℤ ℚ V) ⊗[ℤ] AdeleRing (𝓞 ℚ) ℚ ≃L[ℤ]
    ((IntegralLattice ℤ ℚ V) ⊗[ℤ] InfiniteAdeleRing ℚ) ×
    (Πʳ v : IsDedekindDomain.HeightOneSpectrum (𝓞 ℚ),
      [(IntegralLattice ℤ ℚ V) ⊗[ℤ] v.adicCompletion ℚ,
        (LinearMap.range (LinearMap.lTensor (IntegralLattice ℤ ℚ V)
          (v.adicCompletionIntegers ℚ).toIntSubmodule.subtype))]) := {
  __ := IntegralLattice.tensorAdelesEquivRestrictedProduct V
  continuous_toFun := by
    let b := IntegralLattice.basis ℤ ℚ V
    rw [IsModuleTopology.continuous_iff_continuous_on_basis b]
    intro i
    dsimp only [LinearEquiv.trans_apply, TensorProduct.prodRight_apply,
      LinearEquiv.prodCongr_apply, LinearEquiv.refl_apply]
    refine continuous_prod_mk.mpr ⟨?_, ?_⟩
    · exact (IsModuleTopology.continuous_smul _).comp continuous_infiniteAdeleRing_proj
    · refine Continuous.comp ?_ continuous_finiteAdeleRing_proj
      apply RestrictedProduct.continuous_map_componentwise
      · intro p; exact IsModuleTopology.continuous_smul _
      · filter_upwards with p
        intro x hx
        exact Submodule.smul_mem _ (Submodule.mem_span_singleton_self _) hx
  continuous_invFun := by
    let b := IntegralLattice.basis ℤ ℚ V
    apply continuous_add.comp (Continuous.prod_map ?_ ?_)
    · apply LinearMap.continuous_of_finiteDimensional
    · refine (IsModuleTopology.continuous_of_linearMap _).comp ?_
      rw [IsModuleTopology.continuous_iff_continuous_on_basis_left b]
      intro i
      apply RestrictedProduct.continuous_map_componentwise
      · intro p; apply LinearMap.continuous_of_finiteDimensional
      · filter_upwards with p
        rintro x ⟨y, hy, rfl⟩
        rcases (b.baseChange _).mem_range_iff_exists_fun.mp hy with ⟨c, rfl⟩
        simp; exact (c i).2 }
```
