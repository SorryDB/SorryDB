theorem count_eq_count_quickSort (l : List α)
  (x : α) :
    l.count x = (quickSort l).count x := by
  cases l with
  | nil => simp
  | cons pivot l =>
    have : (smaller pivot l).length < (pivot :: l).length := by grind
    have : (larger pivot l).length < (pivot :: l).length := by grind
    have ih₁ := count_eq_count_quickSort (smaller pivot l) x
    have ih₂ := count_eq_count_quickSort (larger pivot l) x
    simp [quickSort_cons, ih₁, ih₂, count_sum_above_below_pivot pivot l, add_assoc, add_left_comm]
termination_by l.length
```
