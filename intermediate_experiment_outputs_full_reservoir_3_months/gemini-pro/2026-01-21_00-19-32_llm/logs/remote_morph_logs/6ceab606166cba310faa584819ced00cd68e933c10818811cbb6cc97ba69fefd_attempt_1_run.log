def buildBST : List α → LabelledTree α
  | [] => leaf (sorry "Empty list not supported")
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  match labels with
  | [] => simp [buildBST]; sorry
  | x :: xs =>
    simp [buildBST]
    generalize h : (leaf x : LabelledTree α) = t
    have ht : IsOrdered t := by rw [←h]; simp
    clear h
    induction xs generalizing t with
    | nil => exact ht
    | cons y ys ih =>
      simp
      apply ih
      apply ordered_addLabel
      exact ht

theorem mem_addLabel (t : LabelledTree α) (label : α) (y : α) :
    LabelledTree.mem (LabelledTree.addLabel t label) y ↔ LabelledTree.mem t y ∨ label = y := by
  induction t <;> simp_all [LabelledTree.addLabel, LabelledTree.mem]
  · split_ifs <;> simp_all [LabelledTree.mem]
  · split_ifs <;> simp_all [LabelledTree.mem]
    · rw [ih_1]; tauto
    · rw [ih_2]; tauto

theorem mem_fold_addLabel (t : LabelledTree α) (labels : List α) (y : α) :
    LabelledTree.mem (labels.foldl LabelledTree.addLabel t) y ↔ LabelledTree.mem t y ∨ y ∈ labels := by
  induction labels generalizing t with
  | nil => simp
  | cons x xs ih =>
    simp
    rw [ih, mem_addLabel]
    tauto

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  match labels with
  | [] => simp [buildBST]; sorry
  | x :: xs =>
    simp [buildBST]
    rw [fastCheckMem_correct]
    · rw [mem_fold_addLabel]
      simp [LabelledTree.mem]
      tauto
    · apply buildBST_ordered
```
