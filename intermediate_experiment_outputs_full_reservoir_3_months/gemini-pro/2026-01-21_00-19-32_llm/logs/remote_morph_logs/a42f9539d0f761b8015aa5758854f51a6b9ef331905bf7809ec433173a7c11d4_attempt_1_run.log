theorem induction_ineq_nsqlefactn (n : ℕ) (h₀ : 4 ≤ n) : n ^ 2 ≤ n ! := by
  induction h₀ with
  | refl => norm_num
  | step k hk IH =>
    rw [Nat.factorial_succ, sq]
    apply Nat.mul_le_mul_left
    calc
      k + 1 ≤ k ^ 2 := by nlinarith
      _     ≤ k !   := IH
```
