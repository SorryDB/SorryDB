instance (k A B : Type*) [Field k] [CommRing A] [Ring B]
    [Algebra k A] [Algebra k B]
    [Algebra.IsCentral k B] :
    Algebra.IsCentral A (A ⊗[k] B) := ⟨by
  rw [← Subalgebra.center_toSubring, Algebra.TensorProduct.center_eq_tensorProduct_center k A B,
    Subalgebra.center_eq_top,
    show Subalgebra.center k B = Algebra.ofId k B from Subalgebra.toSubring_injective IsCentral.out]
  apply Subring.ext; intro z
  simp only [Subalgebra.mem_toSubring, Subalgebra.mem_map, Subalgebra.mem_top, true_and]
  constructor
  · rintro ⟨x, rfl⟩
    induction x using TensorProduct.induction_on with
    | zero => exact ⟨0, map_zero _⟩
    | tmul a b =>
      obtain ⟨c, rfl⟩ := (Algebra.mem_range (f := algebraMap k B)).mp b.2
      use c • a
      simp [Algebra.ofId_apply, TensorProduct.smul_tmul']
    | add _ _ h1 h2 =>
      obtain ⟨a1, rfl⟩ := h1; obtain ⟨a2, rfl⟩ := h2
      use a1 + a2; simp [map_add]
  · rintro ⟨a, rfl⟩
    exact ⟨a ⊗ₜ[k] ⟨1, ⟨1, map_one _⟩⟩, by simp [Algebra.ofId_apply]⟩⟩
