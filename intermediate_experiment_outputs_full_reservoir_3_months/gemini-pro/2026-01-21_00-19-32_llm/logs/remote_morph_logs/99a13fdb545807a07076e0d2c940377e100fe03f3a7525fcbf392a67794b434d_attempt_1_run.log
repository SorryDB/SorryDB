lemma _root_.MeasureTheory.Martingale.classD_iff_uniformIntegrable [IsFiniteMeasure P]
    (hX1 : Martingale X 𝓕 P) (hX2 : ∀ ω, RightContinuous (X · ω)) :
    ClassD X 𝓕 P ↔ UniformIntegrable X 1 P := by
  let Y := fun t ω ↦ ‖X t ω‖
  have hY : Submartingale Y 𝓕 P := hX1.submartingale_convex_comp
    (convexOn_norm convex_univ) continuous_norm (fun t ↦ (hX1.integrable t).norm)
  have hY_rc : ∀ ω, RightContinuous (Y · ω) := fun ω t ↦ (hX2 ω t).norm
  have hY_nn : 0 ≤ Y := fun t ω ↦ norm_nonneg _
  rw [uniformIntegrable_iff_norm,
    ← MeasureTheory.Submartingale.classD_iff_uniformIntegrable hY hY_rc hY_nn]
  constructor
  · intro h
    refine ⟨hY.adapted.progMeasurable_of_rightContinuous hY_rc, ?_⟩
    simp_rw [stoppedValue, ← norm_stoppedValue]
    exact uniformIntegrable_iff_norm.mp h.uniformIntegrable
  · intro h
    refine ⟨hX1.adapted.progMeasurable_of_rightContinuous hX2, ?_⟩
    simp_rw [uniformIntegrable_iff_norm, stoppedValue, norm_stoppedValue]
    exact h.uniformIntegrable
