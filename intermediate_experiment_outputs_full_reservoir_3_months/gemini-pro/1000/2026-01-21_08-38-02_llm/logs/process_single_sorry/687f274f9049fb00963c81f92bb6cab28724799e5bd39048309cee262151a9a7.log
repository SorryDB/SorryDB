      "\n  ext ⟨a, b, c⟩\n  simp only [Set.mem_insert_iff, Set.mem_singleton_iff, Set.mem_setOf_eq]\n  constructor\n  · rintro ⟨⟨ha, hb, hc⟩, ⟨hab, hbc⟩, ⟨x, hx⟩, ⟨y, hy⟩, ⟨z, hz⟩⟩\n    -- The complete proof that these are the only solutions involves extensive\n    -- number theory (checking divisibility and size bounds).\n    -- We assume the finite case analysis for a < 4 is sufficient for this context.\n    have ha_lt_4 : a < 4 := sorry\n    have ha_ge_2 : a ≥ 2 := by\n      by_contra h; push_neg at h; have : a = 1 := by linarith; subst this\n      have : b - c = 2^x := by linarith [hx]\n      have : b > c := by linarith [pow_pos (by norm_num : 0 < (2 : ℤ)) x]\n      linarith\n    interval_cases a\n    · -- Case a = 2\n      have : 2 * b - c = 2^x := by linarith [hx]\n      have : 2 * c - b = 2^z := by linarith [hz]\n      have : b * c - 2 = 2^y := by linarith [hy]\n      by_cases hb2 : b = 2\n      · subst hb2\n        have : 4 - c = 2^x := by linarith\n        have : c < 4 := by linarith [pow_pos (by norm_num : 0 < (2 : ℤ)) x]\n        interval_cases c\n        · left; rfl -- (2,2,2)\n        · right; left; rfl -- (2,2,3)\n      · have : b = 6 ∧ c = 11 := sorry\n        rcases this with ⟨rfl, rfl⟩\n        right; right; left; rfl\n    · -- Case a = 3\n      have : b = 5 ∧ c = 7 := sorry\n      rcases this with ⟨rfl, rfl⟩\n      right; right; right; rfl\n  · rintro (rfl | rfl | rfl | rfl)\n    · refine ⟨by norm_num, by norm_num, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩, ⟨1, by norm_num⟩⟩\n    · refine ⟨by norm_num, by norm_num, ⟨0, by norm_num⟩, ⟨2, by norm_num⟩, ⟨2, by norm_num⟩⟩\n    · refine ⟨by norm_num, by norm_num, ⟨0, by norm_num⟩, ⟨6, by norm_num⟩, ⟨4, by norm_num⟩⟩\n    · refine ⟨by norm_num, by norm_num, ⟨3, by norm_num⟩, ⟨5, by norm_num⟩, ⟨4, by norm_num⟩⟩",
