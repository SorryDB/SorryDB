      "by\n    let P (n : ℕ) := lightToProfinite.obj (S.component n)\n    let π (n : ℕ) : lightToProfinite.obj S ⟶ P n := lightToProfinite.map (S.proj n)\n    let σ (n : ℕ) : P (n+1) ⟶ P n := lightToProfinite.map (S.transitionMap n)\n    haveI (n : ℕ) : Finite (P n) := inferInstanceAs (Finite (S.component n))\n    haveI (n : ℕ) : Nonempty (P n) := Nonempty.map (S.proj n) inferInstance\n    haveI (n : ℕ) : Epi (σ n) := (epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    obtain ⟨k0, hk0⟩ := Injective.factors (g ≫ π 0) f\n    have h_step (n : ℕ) (k : Y ⟶ P n) (hk : f ≫ k = g ≫ π n) :\n        ∃ k' : Y ⟶ P (n+1), k' ≫ σ n = k ∧ f ≫ k' = g ≫ π (n+1) := by\n      have h_comm : f ≫ k = (g ≫ π (n+1)) ≫ σ n := by\n        rw [hk, ← Category.assoc, ← Functor.map_comp, S.proj_comp_transitionMap]\n      obtain ⟨k', h1, h2⟩ := profinite_key_extension_lemma X Y (P (n+1)) (P n)\n        f (σ n) (g ≫ π (n+1)) k h_comm\n      exact ⟨k', h1, h2⟩\n    let lifts (n : ℕ) := { k : Y ⟶ P n // f ≫ k = g ≫ π n }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let ⟨k', h1, h2⟩ := h_step n k.val k.property\n      ⟨k', h2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, hk0⟩ next n\n    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=\n      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val)\n        (fun n ↦ (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1.symm) }\n    let hS := isLimitOfPreserves lightToProfinite S.asLimit\n    refine ⟨hS.lift k_cone, hS.hom_ext (fun n ↦ ?_)⟩\n    simp only [hS.fac, k_cone, Cone.extend_π, NatTrans.comp_app, NatTrans.ofOpSequence_app]\n    exact (k_seq n).property",
      "by\n    let S_P := lightToProfinite.obj S\n    let D := S.diagram ⋙ FintypeCat.toProfinite\n    let π (n : ℕ) : S_P ⟶ D.obj (op n) := lightToProfinite.map (S.proj n)\n    let p (n : ℕ) : D.obj (op (n+1)) ⟶ D.obj (op n) := lightToProfinite.map (S.transitionMap n)\n    haveI (n : ℕ) : Finite (D.obj (op n)) := Finite.of_fintype _\n    haveI (n : ℕ) : Epi (p n) := (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    haveI : Nonempty (D.obj (op 0)) := Nonempty.map (π 0) inferInstance\n    obtain ⟨k0, h0⟩ := Injective.factors (g ≫ π 0) f\n    let step (n : ℕ) (k : Y ⟶ D.obj (op n)) (h : f ≫ k = g ≫ π n) :\n        ∃ k' : Y ⟶ D.obj (op (n+1)), k' ≫ p n = k ∧ f ≫ k' = g ≫ π (n+1) := by\n      have h_comm : f ≫ k = g ≫ π (n + 1) ≫ p n := by\n        rw [h, Category.assoc, ← lightToProfinite.map_comp, S.proj_comp_transitionMap]\n      exact Profinite.profinite_key_extension_lemma X Y _ _ f (p n) (g ≫ π (n+1)) k h_comm\n    let lifts (n : ℕ) := { k : Y ⟶ D.obj (op n) // f ≫ k = g ≫ π n }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let ⟨k', hk'⟩ := Classical.choose_spec (step n k.1 k.2)\n      ⟨k', hk'.2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h0⟩ next n\n    have h_up (n : ℕ) : (k_seq (n+1)).1 ≫ p n = (k_seq n).1 :=\n      (Classical.choose_spec (step n (k_seq n).1 (k_seq n).2)).1\n    let k_cone : Cone ((S.diagram ⋙ FintypeCat.toLightProfinite) ⋙ forget LightProfinite) :=\n      { pt := Y.toTop,\n        π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).1.hom) (fun n ↦ by\n             ext x; exact (ConcreteCategory.hom_ext_iff.mp (h_up n).symm) x) }\n    let hS := isLimitOfPreserves (forget LightProfinite) S.asLimit\n    exact ⟨TopCat.ofHom (hS.lift k_cone), ConcreteCategory.hom_ext_iff.mpr (congr_fun (hS.uniq\n      (k_cone.extend f.hom) g.hom (fun j ↦ by\n        simp only [Cone.extend_π, Functor.mapCone_π_app, Functor.comp_map, forget_map,\n          Functor.const_obj_obj, forget_obj, Functor.comp_obj, TopCat.coe_ofHom]\n        rw [← CompHausLike.coe_comp, ← (k_seq j.unop).2, CompHausLike.coe_comp]\n        rfl)) )⟩",
      "by\n    let S_n (n : ℕ) := lightToProfinite.obj (S.component n)\n    haveI (n : ℕ) : Finite (S_n n) := inferInstanceAs (Finite (FintypeCat.toLightProfinite.obj _))\n    let π (n : ℕ) : lightToProfinite.obj S ⟶ S_n n := lightToProfinite.map (S.proj n)\n    let p (n : ℕ) : S_n (n+1) ⟶ S_n n := lightToProfinite.map (S.transitionMap n)\n    haveI (n : ℕ) : Epi (p n) := (epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ π 0) f\n    have h_step (n : ℕ) (k : Y ⟶ S_n n) (h_down : f ≫ k = g ≫ π n) :\n      ∃ k' : Y ⟶ S_n (n+1), k' ≫ p n = k ∧ f ≫ k' = g ≫ π (n+1) := by\n      have h_comm : f ≫ k = g ≫ π (n+1) ≫ p n := by\n        rw [h_down, ← Category.assoc, ← Functor.map_comp]\n        exact congrArg _ (congrArg _ (S.proj_comp_transitionMap n).symm)\n      obtain ⟨k', hk1, hk2⟩ := profinite_key_extension_lemma X Y (S_n (n+1)) (S_n n) f (p n) (g ≫ π (n+1)) k h_comm\n      exact ⟨k', hk1, hk2⟩\n    let lifts (n : ℕ) := { k : Y ⟶ S_n n // f ≫ k = g ≫ π n }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let ⟨k', hk1, hk2⟩ := h_step n k.val k.property\n      ⟨k', hk1, hk2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n\n    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ p n = (k_seq n).val :=\n      (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1\n    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=\n      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }\n    let t := isLimitOfPreserves lightToProfinite S.asLimit.isLimit\n    refine ⟨t.lift k_cone, t.hom_ext (fun n ↦ ?_)⟩\n    simp only [Category.assoc, t.fac k_cone n]\n    exact (k_seq n.unop).property",
      "by\n    let S_n (n : ℕ) := lightToProfinite.obj (FintypeCat.toLightProfinite.obj (S.component n))\n    let π (n : ℕ) : lightToProfinite.obj S ⟶ S_n n := lightToProfinite.map (S.proj n)\n    let tr (n : ℕ) : S_n (n+1) ⟶ S_n n := lightToProfinite.map (S.transitionMap n)\n    haveI (n : ℕ) : Finite (S_n n) :=\n      inferInstanceAs (Finite (FintypeCat.toProfinite.obj (S.component n)))\n    haveI : Nonempty (S_n 0) := Nonempty.map (π 0) inferInstance\n    haveI (n : ℕ) : Epi (tr n) := (epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ π 0) f\n    have h_step (n : ℕ) (k : Y ⟶ S_n n) (h_down : f ≫ k = g ≫ π n) :\n      ∃ k' : Y ⟶ S_n (n+1), k' ≫ tr n = k ∧ f ≫ k' = g ≫ π (n+1) := by\n      have h_comm : f ≫ k = g ≫ π (n+1) ≫ tr n := by\n        rw [h_down, ← Category.assoc, ← Functor.map_comp]\n        exact congrArg _ (congrArg _ (S.proj_comp_transitionMap n).symm)\n      exact profinite_key_extension_lemma X Y (S_n (n+1)) (S_n n) f (tr n) (g ≫ π (n+1)) k h_comm\n    let lifts (n : ℕ) := { k : Y ⟶ S_n n // f ≫ k = g ≫ π n }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let res := h_step n k.val k.property\n      ⟨Classical.choose res, (Classical.choose_spec res).2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n\n    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ tr n = (k_seq n).val :=\n      (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1\n    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=\n      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }\n    have hS : IsLimit (lightToProfinite.mapCone S.cone) :=\n      isLimitOfPreserves lightToProfinite S.asLimit\n    use hS.lift k_cone\n    apply hS.hom_ext\n    intro n\n    simp only [hS.fac, Functor.mapCone_π_app, NatTrans.ofOpSequence_app, (k_seq n.unop).property]",
      "by\n    let π (n : ℕ) := lightToProfinite.map (S.proj n)\n    let tr (n : ℕ) := lightToProfinite.map (S.transitionMap n)\n    haveI (n : ℕ) : Finite (lightToProfinite.obj (S.component n)) :=\n      inferInstanceAs (Finite (S.component n))\n    haveI (n : ℕ) : Epi (tr n) := by\n      rw [Profinite.epi_iff_surjective]\n      exact (LightProfinite.epi_iff_surjective _).mp (S.surjective_transitionMap n)\n    haveI : Nonempty (lightToProfinite.obj (S.component 0)) :=\n      Nonempty.map (π 0) inferInstance\n    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ π 0) f\n    have h_step (n : ℕ) (k : Y ⟶ lightToProfinite.obj (S.component n)) (h_down : f ≫ k = g ≫ π n) :\n      ∃ k' : Y ⟶ lightToProfinite.obj (S.component (n+1)), k' ≫ tr n = k ∧ f ≫ k' = g ≫ π (n+1) := by\n      have h_comm : f ≫ k = (g ≫ π (n+1)) ≫ tr n := by\n        rw [h_down, Category.assoc, ← Functor.map_comp, S.proj_comp_transitionMap]\n      exact Profinite.profinite_key_extension_lemma X Y _ _ f (tr n) (g ≫ π (n+1)) k h_comm\n    let lifts (n : ℕ) := { k : Y ⟶ lightToProfinite.obj (S.component n) // f ≫ k = g ≫ π n }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      ⟨Classical.choose (h_step n k.val k.property),\n        (Classical.choose_spec (h_step n k.val k.property)).2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n\n    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ tr n = (k_seq n).val :=\n      (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1\n    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=\n      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ h_up n) }\n    let hS := isLimitOfPreserves lightToProfinite S.asLimit.isLimit\n    refine ⟨hS.lift k_cone, hS.hom_ext fun j ↦ ?_⟩\n    simp only [IsLimit.fac, Functor.mapCone_π_app, Functor.comp_obj, NatTrans.ofOpSequence_app,\n      Category.assoc, (k_seq j.unop).property]",
      "by\n    let F := lightToProfinite\n    haveI (n : ℕ) : Finite (F.obj (S.component n)) :=\n      inferInstanceAs (Finite (S.component n))\n    haveI : Nonempty (F.obj (S.component 0)) := Nonempty.map (F.map (S.proj 0)) inferInstance\n    haveI (n : ℕ) : Epi (F.map (S.transitionMap n)) :=\n      (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ F.map (S.proj 0)) f\n    have h_step (n : ℕ) (k : Y ⟶ F.obj (S.component n)) (h_down : f ≫ k = g ≫ F.map (S.proj n)) :\n      ∃ k' : Y ⟶ F.obj (S.component (n+1)), k' ≫ F.map (S.transitionMap n) = k ∧ f ≫ k' = g ≫ F.map (S.proj (n+1)) := by\n      have h_comm : f ≫ k = g ≫ F.map (S.proj (n+1)) ≫ F.map (S.transitionMap n) := by\n        rw [h_down, ← F.map_comp, S.proj_comp_transitionMap]\n      exact profinite_key_extension_lemma X Y _ _ f (F.map (S.transitionMap n)) (g ≫ F.map (S.proj (n+1))) k h_comm\n    let lifts (n : ℕ) := { k : Y ⟶ F.obj (S.component n) // f ≫ k = g ≫ F.map (S.proj n) }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let ⟨k', hk'⟩ := h_step n k.1 k.2\n      ⟨k', hk'.2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n\n    have h_up (n : ℕ) : (k_seq (n+1)).1 ≫ F.map (S.transitionMap n) = (k_seq n).1 := by\n      induction n with\n      | zero => exact (Classical.choose_spec (h_step 0 k0 h_down0)).1\n      | succ n _ => exact (Classical.choose_spec (h_step (n+1) (k_seq (n+1)).1 (k_seq (n+1)).2)).1\n    let C : Cone (S.diagram ⋙ F) :=\n      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).1) (fun n ↦ (h_up n).symm) }\n    haveI : PreservesLimitsOfShape (Op ℕ) F := inferInstance\n    let hS := isLimitOfPreserves F S.asLimit\n    use hS.lift C\n    apply hS.hom_ext\n    intro j\n    rw [hS.fac C j, Category.assoc, hS.fac]\n    exact (k_seq j.unop).2",
      "by\n    let F := lightToProfinite\n    let S_n (n : ℕ) := F.obj (S.component n)\n    let π (n : ℕ) : F.obj S ⟶ S_n n := F.map (S.proj n)\n    let p (n : ℕ) : S_n (n + 1) ⟶ S_n n := F.map (S.transitionMap n)\n    haveI (n : ℕ) : Finite (S_n n) :=\n      inferInstanceAs (Finite (FintypeCat.toProfinite.obj _))\n    haveI (n : ℕ) : Epi (p n) := (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    haveI : Nonempty (S_n 0) := Nonempty.map (π 0) inferInstance\n    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ π 0) f\n    have h_step (n : ℕ) (k : Y ⟶ S_n n) (h_down : f ≫ k = g ≫ π n) :\n        ∃ k' : Y ⟶ S_n (n + 1), k' ≫ p n = k ∧ f ≫ k' = g ≫ π (n + 1) := by\n      have h_comm : f ≫ k = g ≫ π (n + 1) ≫ p n := by\n        rw [h_down, ← Category.assoc, ← Functor.map_comp, S.proj_comp_transitionMap]\n      exact profinite_key_extension_lemma _ _ _ _ f (p n) (g ≫ π (n + 1)) k h_comm\n    let lifts (n : ℕ) := { k : Y ⟶ S_n n // f ≫ k = g ≫ π n }\n    let next (n : ℕ) (k : lifts n) : lifts (n + 1) :=\n      let ⟨k', h1, h2⟩ := Classical.choose_spec (h_step n k.val k.property)\n      ⟨k', h2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n\n    have h_up (n : ℕ) : (k_seq (n + 1)).val ≫ p n = (k_seq n).val :=\n      (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1\n    let k_cone : Cone (S.diagram ⋙ F) :=\n      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }\n    let hS_lim := isLimitOfPreserves F S.asLimit\n    refine ⟨hS_lim.lift k_cone, ?_⟩\n    apply hS_lim.hom_ext\n    intro j\n    simp only [hS_lim.fac, NatTrans.ofOpSequence_app, Category.assoc]\n    exact (k_seq j.unop).property",
      "by\n    let F := lightToProfinite\n    let π (n : ℕ) : F.obj S ⟶ F.obj (S.component n) := F.map (S.proj n)\n    let tr (n : ℕ) : F.obj (S.component (n+1)) ⟶ F.obj (S.component n) :=\n      F.map (S.transitionMap n)\n\n    haveI (n : ℕ) : Finite (F.obj (S.component n)) := inferInstanceAs (Finite (S.component n))\n    haveI (n : ℕ) : Epi (tr n) := (Profinite.epi_iff_surjective _).mpr\n      ((LightProfinite.epi_iff_surjective _).mp (inferInstanceAs (Epi (S.transitionMap n))))\n    haveI : Nonempty (F.obj (S.component 0)) := Nonempty.map (π 0) inferInstance\n\n    obtain ⟨k0, hk0⟩ := Injective.factors (g ≫ π 0) f\n\n    have h_step (n : ℕ) (k : Y ⟶ F.obj (S.component n)) (h_down : f ≫ k = g ≫ π n) :\n      ∃ k' : Y ⟶ F.obj (S.component (n+1)), k' ≫ tr n = k ∧ f ≫ k' = g ≫ π (n+1) := by\n      have h_comm : f ≫ k = (g ≫ π (n+1)) ≫ tr n := by\n        rw [h_down, Category.assoc, ← F.map_comp, S.proj_comp_transitionMap]\n      exact Profinite.profinite_key_extension_lemma X Y\n        (F.obj (S.component (n+1))) (F.obj (S.component n)) f (tr n) (g ≫ π (n+1)) k h_comm\n\n    let lifts (n : ℕ) := { k : Y ⟶ F.obj (S.component n) // f ≫ k = g ≫ π n }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let ⟨k', h1, h2⟩ := Classical.choose_spec (h_step n k.val k.property)\n      ⟨k', h2⟩\n\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, hk0⟩ next n\n    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ tr n = (k_seq n).val :=\n      (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1\n\n    let cone_Y : Cone (S.diagram ⋙ F) :=\n      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }\n\n    haveI : PreservesLimit S.diagram F := inferInstance\n    let limit_cone := isLimitOfPreserves F S.asLimit.isLimit\n\n    refine ⟨limit_cone.lift cone_Y, limit_cone.hom_ext (fun j ↦ ?_)⟩\n    simp only [Category.assoc]\n    rw [limit_cone.fac cone_Y j]\n    exact (k_seq j.unop).property",
      "by\n    let L := lightToProfinite\n    haveI (n : ℕ) : Finite (L.obj (S.component n)) :=\n      Finite.of_fintype (FintypeCat.toProfinite.obj (S.component n))\n    haveI : Nonempty (L.obj (S.component 0)) := Nonempty.map (L.map (S.proj 0)) inferInstance\n    haveI (n : ℕ) : Epi (L.map (S.transitionMap n)) :=\n      (epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ L.map (S.proj 0)) f\n    have h_step (n : ℕ) (k : Y ⟶ L.obj (S.component n)) (h_down : f ≫ k = g ≫ L.map (S.proj n)) :\n      ∃ k' : Y ⟶ L.obj (S.component (n+1)), k' ≫ L.map (S.transitionMap n) = k ∧ f ≫ k' = g ≫ L.map (S.proj (n+1)) := by\n      have h_comm : f ≫ k = g ≫ L.map (S.proj (n+1)) ≫ L.map (S.transitionMap n) := by\n        rw [h_down, ← Category.assoc, ← L.map_comp, S.proj_comp_transitionMap]\n      exact profinite_key_extension_lemma _ _ _ _ f (L.map (S.transitionMap n)) (g ≫ L.map (S.proj (n+1))) k h_comm\n    let lifts (n : ℕ) := { k : Y ⟶ L.obj (S.component n) // f ≫ k = g ≫ L.map (S.proj n) }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let ⟨k', hk'⟩ := Classical.choose_spec (h_step n k.val k.property)\n      ⟨k', hk'.2⟩\n    let k_seq (n : Nat) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n\n    have h_down (n : ℕ) : f ≫ (k_seq n).val = g ≫ L.map (S.proj n) := (k_seq n).property\n    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ L.map (S.transitionMap n) = (k_seq n).val :=\n      (Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1\n    let k_cone : Cone (S.diagram ⋙ L) :=\n      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }\n    haveI : PreservesLimit S.diagram L := inferInstance\n    let hS : IsLimit (L.mapCone S.cone) := isLimitOfPreserves L S.asLimit\n    use hS.lift k_cone\n    apply hS.hom_ext\n    intro n\n    simp [hS.fac k_cone n, h_down]",
      "by\n    let S_n (n : ℕ) := lightToProfinite.obj (S.component n)\n    let π (n : ℕ) : lightToProfinite.obj S ⟶ S_n n := lightToProfinite.map (S.proj n)\n    let p (n : ℕ) : S_n (n+1) ⟶ S_n n := lightToProfinite.map (S.transitionMap n)\n    haveI (n : ℕ) : Finite (S_n n) := inferInstanceAs (Finite (S.component n))\n    haveI (n : ℕ) : Epi (p n) := (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    haveI : Nonempty (S_n 0) := Nonempty.map (π 0) (inferInstanceAs (Nonempty S))\n    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ π 0) f\n    have h_step (n : ℕ) (k : Y ⟶ S_n n) (h_down : f ≫ k = g ≫ π n) :\n      ∃ k' : Y ⟶ S_n (n+1), k' ≫ p n = k ∧ f ≫ k' = g ≫ π (n+1) := by\n      have h_comm : f ≫ k = g ≫ π (n+1) ≫ p n := by\n        rw [h_down, Category.assoc, ← Functor.map_comp, S.proj_comp_transitionMap]; rfl\n      exact profinite_key_extension_lemma X Y (S_n (n+1)) (S_n n) f (p n) (g ≫ π (n+1)) k h_comm\n    let lifts (n : ℕ) := { k : Y ⟶ S_n n // f ≫ k = g ≫ π n }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let ⟨k', hk'⟩ := h_step n k.1 k.2; ⟨k', hk'.2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n\n    have h_up (n : ℕ) : (k_seq (n+1)).1 ≫ p n = (k_seq n).1 :=\n      (Classical.choose_spec (h_step n (k_seq n).1 (k_seq n).2)).1\n    let k_cone : Cone (S.diagram ⋙ forget LightProfinite) :=\n      { pt := (forget Profinite).obj Y\n        π := NatTrans.ofOpSequence (fun n ↦ (forget Profinite).map (k_seq n).1)\n          (fun n ↦ congrArg _ (h_up n).symm) }\n    have h_lim := isLimitOfPreserves (forget LightProfinite) S.asLimit.isLimit\n    refine ⟨⟨h_lim.lift k_cone⟩, ?_⟩\n    apply h_lim.hom_ext; intro j\n    simp only [forget_map, Functor.mapCone_π_app, Functor.comp_obj, Functor.comp_map]\n    exact (k_seq j.unop).2",
