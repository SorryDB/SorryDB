instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f h := by
    let L2P := lightToProfinite
    -- help the instance inference
    haveI (n : ℕ) : Finite (L2P.obj (S.component n)) :=
      inferInstanceAs (Finite (FintypeCat.toProfinite.obj _))
    haveI : Nonempty (L2P.obj (S.component 0)) := Nonempty.map (L2P.map (S.proj 0)) inferInstance
    haveI (n : ℕ) : Epi (L2P.map (S.transitionMap n)) := (epi_iff_surjective _).mpr
      (S.surjective_transitionMap n)
    -- base step of the induction: find k0 : Y ⟶ S.component 0
    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ L2P.map (S.proj 0)) f
    -- key part of induction step: next produces k n+1 out of k n
    have h_step (n : ℕ) (k : Y ⟶ L2P.obj (S.component n)) (h_down : f ≫ k = g ≫ L2P.map (S.proj n)) :
      ∃ k' : Y ⟶ L2P.obj (S.component (n+1)), k' ≫ L2P.map (S.transitionMap n) = k ∧ f ≫ k' = g ≫ L2P.map (S.proj (n+1)) := by
      have h_comm : f ≫ k = g ≫ L2P.map (S.proj (n+1)) ≫ L2P.map (S.transitionMap n) := by
        rw [h_down, ← Category.assoc, ← L2P.map_comp, S.proj_comp_transitionMap]
      exact profinite_key_extension_lemma _ _ _ _ f (L2P.map (S.transitionMap n)) (g ≫ L2P.map (S.proj (n+1))) k h_comm
    let lifts (n : ℕ) := { k : Y ⟶ L2P.obj (S.component n) // f ≫ k = g ≫ L2P.map (S.proj n) }
    let next (n : ℕ) : lifts n → lifts (n+1) :=
      fun k ↦ ⟨Classical.choose (h_step n k.val k.property),
        (Classical.choose_spec (h_step n k.val k.property)).2⟩
    -- now define sequence of lifts using induction
    let k_seq (n : Nat) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n
    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ L2P.map (S.transitionMap n) = (k_seq n).val := by
      induction n with
      | zero => exact (Classical.choose_spec (h_step 0 k0 h_down0)).1
      | succ n ih =>
        exact (Classical.choose_spec (h_step (n+1) (k_seq (n+1)).val (k_seq (n+1)).property)).1
    let k_cone : Cone (S.diagram ⋙ L2P) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }
    -- now the induced map Y ⟶ S is the desired map
    let S_cone := L2P.mapCone S.asLimit.cone
    have S_isLimit : IsLimit S_cone := isLimitOfPreserves L2P S.asLimit.isLimit
    use S_isLimit.lift k_cone
    apply S_isLimit.hom_ext
    intro j
    simp only [IsLimit.fac, S_cone, Functor.mapCone_π_app, k_cone, NatTrans.ofOpSequence_app]
    rw [← Category.assoc, (k_seq j.unop).property]
