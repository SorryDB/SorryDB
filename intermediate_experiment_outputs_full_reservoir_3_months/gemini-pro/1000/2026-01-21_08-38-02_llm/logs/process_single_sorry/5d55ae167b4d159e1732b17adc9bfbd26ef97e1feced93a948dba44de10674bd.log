    let S_n (n : ℕ) := lightToProfinite.obj (S.component n)
    let π (n : ℕ) : lightToProfinite.obj S ⟶ S_n n := lightToProfinite.map (S.proj n)
    let t (n : ℕ) : S_n (n+1) ⟶ S_n n := lightToProfinite.map (S.transitionMap n)
    haveI (n : ℕ) : Finite (S.component n) :=
      inferInstanceAs (Finite (FintypeCat.toLightProfinite.obj _))
    haveI (n : ℕ) : Finite (S_n n) := inferInstanceAs (Finite (S.component n))
    haveI (n : ℕ) : Epi (t n) := (epi_iff_surjective _).mpr (S.surjective_transitionMap n)
    haveI : Nonempty (S_n 0) := Nonempty.map (π 0) inferInstance
    obtain ⟨k0, hk0⟩ := Injective.factors (g ≫ π 0) f
    have h_step (n : ℕ) (k : Y ⟶ S_n n) (hk : f ≫ k = g ≫ π n) :
      ∃ k' : Y ⟶ S_n (n+1), k' ≫ t n = k ∧ f ≫ k' = g ≫ π (n+1) := by
      have h_comm : f ≫ k = g ≫ π (n+1) ≫ t n := by
        rw [hk, ← Category.assoc, ← Functor.map_comp, S.proj_comp_transitionMap]
      exact profinite_key_extension_lemma X Y (S_n (n+1)) (S_n n) f (t n) (g ≫ π (n+1)) k h_comm
    let lifts (n : ℕ) := { k : Y ⟶ S_n n // f ≫ k = g ≫ π n }
    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=
      let ⟨k', _, hk'2⟩ := Classical.choose_spec (h_step n k.1 k.2)
      ⟨k', hk'2⟩
    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, hk0⟩ next n
    have h_up (n : ℕ) : (k_seq (n+1)).1 ≫ t n = (k_seq n).1 :=
      (Classical.choose_spec (h_step n (k_seq n).1 (k_seq n).2)).1
    let D := S.diagram ⋙ lightToProfinite
    let S_cone := lightToProfinite.mapCone S.asLimit.cone
    have S_isLimit : IsLimit S_cone := isLimitOfPreserves lightToProfinite S.asLimit.isLimit
