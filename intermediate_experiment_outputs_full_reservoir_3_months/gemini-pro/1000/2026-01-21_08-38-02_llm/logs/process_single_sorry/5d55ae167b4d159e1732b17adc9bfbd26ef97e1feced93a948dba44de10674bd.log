instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f h := by
    let S' := lightToProfinite.obj S
    let Sn (n : ℕ) := lightToProfinite.obj (S.component n)
    let π (n : ℕ) : S' ⟶ Sn n := lightToProfinite.map (S.proj n)
    let p (n : ℕ) : Sn (n+1) ⟶ Sn n := lightToProfinite.map (S.transitionMap n)

    haveI (n : ℕ) : Finite (Sn n) := inferInstanceAs (Finite (S.component n))
    haveI : Nonempty (Sn 0) := Nonempty.map (π 0) inferInstance
    haveI (n : ℕ) : Epi (p n) := (Profinite.epi_iff_surjective _).mpr
      (S.surjective_transitionMap n)

    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ π 0) f

    have h_step (n : ℕ) (k : Y ⟶ Sn n) (h_down : f ≫ k = g ≫ π n) :
        ∃ k' : Y ⟶ Sn (n+1), k' ≫ p n = k ∧ f ≫ k' = g ≫ π (n+1) := by
      have h_comm : f ≫ k = g ≫ π (n+1) ≫ p n := by
        rw [h_down, π, p, ← Functor.map_comp, S.proj_comp_transitionMap]
      exact profinite_key_extension_lemma X Y (Sn (n+1)) (Sn n) f (p n) (g ≫ π (n+1)) k h_comm

    let lifts (n : ℕ) := { k : Y ⟶ Sn n // f ≫ k = g ≫ π n }
    let next (n : ℕ) : lifts n → lifts (n+1) := fun k ↦
      ⟨Classical.choose (h_step n k.val k.property),
       (Classical.choose_spec (h_step n k.val k.property)).2⟩
    let k_seq (n : Nat) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n

    have h_down (n : ℕ) : f ≫ (k_seq n).val = g ≫ π n := (k_seq n).property
    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ p n = (k_seq n).val := by
      induction n with
      | zero => exact (Classical.choose_spec (h_step 0 k0 h_down0)).1
      | succ n ih => exact (Classical.choose_spec (h_step (n+1) (k_seq (n+1)).val (k_seq (n+1)).property)).1

    let K : Cone (S.diagram ⋙ lightToProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }

    have hS : IsLimit (lightToProfinite.mapCone S.cone) := by
      apply isLimitOfReflects (forget Profinite)
      apply isLimitOfPreserves (forget LightProfinite) S.asLimit

    use hS.lift K
    apply hS.hom_ext
    intro j
    simp only [hS.fac K j, Category.assoc]
    exact h_down j.unop
