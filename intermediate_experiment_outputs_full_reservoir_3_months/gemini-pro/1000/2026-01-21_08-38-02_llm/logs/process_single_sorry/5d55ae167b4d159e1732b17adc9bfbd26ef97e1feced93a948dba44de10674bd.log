instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f h := by
    let S_n (n : ℕ) := lightToProfinite.obj (S.component n)
    haveI (n : ℕ) : Finite (S_n n) := inferInstanceAs (Finite (FintypeCat.toProfinite.obj _))
    haveI : Nonempty (S_n 0) := Nonempty.map (S.proj 0) inferInstance
    let p (n : ℕ) : lightToProfinite.obj S ⟶ S_n n := lightToProfinite.map (S.proj n)
    let trans (n : ℕ) : S_n (n+1) ⟶ S_n n := lightToProfinite.map (S.transitionMap n)
    haveI (n : ℕ) : Epi (trans n) := (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)

    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ p 0) f
    have h_step (n : ℕ) (k : Y ⟶ S_n n) (h_down : f ≫ k = g ≫ p n) :
        ∃ k' : Y ⟶ S_n (n+1), k' ≫ trans n = k ∧ f ≫ k' = g ≫ p (n+1) := by
      have h_comm : f ≫ k = g ≫ p (n+1) ≫ trans n := by
        rw [h_down]; simp only [p, trans, ← Functor.map_comp, S.proj_comp_transitionMap]
      exact profinite_key_extension_lemma _ _ _ _ f (trans n) (g ≫ p (n+1)) k h_comm

    let lifts (n : ℕ) := { k : Y ⟶ S_n n // f ≫ k = g ≫ p n }
    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=
      let res := h_step n k.val k.property
      ⟨Classical.choose res, (Classical.choose_spec res).2⟩
    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n
    have h_down (n : ℕ) : f ≫ (k_seq n).val = g ≫ p n := (k_seq n).property
    have h_up (n : ℕ) : (k_seq (n+1)).val ≫ trans n = (k_seq n).val := by
      induction n with
      | zero => exact (Classical.choose_spec (h_step 0 k0 h_down0)).1
      | succ n _ => exact (Classical.choose_spec (h_step (n+1) (k_seq (n+1)).val (k_seq (n+1)).property)).1

    let k_cone : Cone (S.diagram ⋙ lightToProfinite) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val) (fun n ↦ (h_up n).symm) }
    let S_cone : Cone (S.diagram ⋙ lightToProfinite) := lightToProfinite.mapCone S.asLimit
    have hS : IsLimit S_cone := isLimitOfPreserves lightToProfinite S.asLimitIsLimit

    refine ⟨hS.lift k_cone, ?_⟩
    apply hS.hom_ext
    intro j
    simp only [hS.fac, S_cone, Functor.mapCone_π_app, NatTrans.ofOpSequence_app]
    exact h_down j.unop
