instance injective_in_profinite_of_light (S : LightProfinite.{u}) [Nonempty S] :
    Injective (lightToProfinite.obj S) where
  factors {X Y} g f h := by
    -- Working in Profinite
    let S_P := lightToProfinite.obj S
    let S_n (n : ℕ) := lightToProfinite.obj (S.component n)
    let π (n : ℕ) : S_P ⟶ S_n n := lightToProfinite.map (S.proj n)
    let trans (n : ℕ) : S_n (n+1) ⟶ S_n n := lightToProfinite.map (S.transitionMap n)

    -- S_n are finite, thus injective
    haveI (n : ℕ) : Finite (S_n n) := inferInstanceAs (Finite (S.component n))
    haveI : Nonempty (S_n 0) := Nonempty.map (π 0).hom inferInstance
    haveI (n : ℕ) : Epi (trans n) := (Profinite.epi_iff_surjective _).mpr (S.surjective_transitionMap n)

    -- Base case: lift to S_0
    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ π 0) f

    -- Inductive step using profinite_key_extension_lemma
    have h_step (n : ℕ) (k : Y ⟶ S_n n) (h_down : f ≫ k = g ≫ π n) :
      ∃ k' : Y ⟶ S_n (n+1), k' ≫ trans n = k ∧ f ≫ k' = g ≫ π (n+1) := by
      have h_comm : f ≫ k = g ≫ π (n+1) ≫ trans n := by
        rw [h_down, ← Category.assoc, ← Functor.map_comp, S.proj_comp_transitionMap]
      exact profinite_key_extension_lemma X Y (S_n (n+1)) (S_n n) f (trans n) (g ≫ π (n+1)) k h_comm

    -- Construct the sequence of maps
    let lifts (n : ℕ) := { k : Y ⟶ S_n n // f ≫ k = g ≫ π n }
    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=
      let ⟨k', hk'⟩ := h_step n k.1 k.2
      ⟨k', hk'.2⟩
    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n
    
    have h_up (n : ℕ) : (k_seq (n+1)).1 ≫ trans n = (k_seq n).1 :=
      (Classical.choose_spec (h_step n (k_seq n).1 (k_seq n).2)).1

    -- Define the map into the limit S_P
    let k_cone : Cone (lightToProfinite.map S.diagram) :=
      { pt := Y, π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).1) (fun n ↦ (h_up n).symm) }
    
    -- Verify S_P is the limit in Profinite using forgetful functors
    let S_cone := lightToProfinite.mapCone S.asLimit.cone
    have hS : IsLimit S_cone :=
      isLimitOfReflects (forget Profinite) (isLimitOfPreserves (forget LightProfinite) S.asLimit.isLimit)

    use hS.lift k_cone
    apply hS.hom_ext
    intro n
    simp only [hS.fac, k_cone, S_cone, Functor.mapCone_π_app, NatTrans.ofOpSequence_app, Category.assoc]
    exact (k_seq n).2
