      "by\n    let SP (n : ℕ) := lightToProfinite.obj (S.component n)\n    let ST (n : ℕ) : SP (n+1) ⟶ SP n := lightToProfinite.map (S.transitionMap n)\n    let P (n : ℕ) : lightToProfinite.obj S ⟶ SP n := lightToProfinite.map (S.proj n)\n    haveI (n : ℕ) : Finite (SP n) :=\n      inferInstanceAs (Finite (FintypeCat.toLightProfinite.obj _))\n    haveI (n : ℕ) : Epi (ST n) := (epi_iff_surjective _).mpr (S.surjective_transitionMap n)\n    haveI : Nonempty (SP 0) := Nonempty.map (P 0) inferInstance\n    obtain ⟨k0, h_down0⟩ := Injective.factors (g ≫ P 0) f\n    have h_step (n : ℕ) (k : Y ⟶ SP n) (h_down : f ≫ k = g ≫ P n) :\n      ∃ k' : Y ⟶ SP (n+1), k' ≫ ST n = k ∧ f ≫ k' = g ≫ P (n+1) := by\n      apply profinite_key_extension_lemma X Y (SP (n+1)) (SP n) f (ST n) (g ≫ P (n+1)) k\n      rw [h_down, P, ST, ← Functor.map_comp, S.proj_comp_transitionMap]\n    let lifts (n : ℕ) := { k : Y ⟶ SP n // f ≫ k = g ≫ P n }\n    let next (n : ℕ) (k : lifts n) : lifts (n+1) :=\n      let res := h_step n k.val k.property\n      ⟨Classical.choose res, (Classical.choose_spec res).2⟩\n    let k_seq (n : ℕ) : lifts n := Nat.rec ⟨k0, h_down0⟩ next n\n    let k_cone : Cone (S.diagram ⋙ FintypeCat.toProfinite) :=\n      { pt := Y\n        π := NatTrans.ofOpSequence (fun n ↦ (k_seq n).val)\n          (fun n ↦ ((Classical.choose_spec (h_step n (k_seq n).val (k_seq n).property)).1).symm) }\n    refine ⟨S.isLimit.lift k_cone, S.isLimit.hom_ext (fun j ↦ ?_)⟩\n    simp only [Category.assoc, S.isLimit.fac k_cone j]\n    exact (k_seq j.unop).property",
