section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x
  let measure (s : HopfieldState n) : ℕ := Fintype.card { y | biasedEnergy net y < biasedEnergy net s }
  let rec solve (s : HopfieldState n) : Σ seq : BiasedUpdateSeq net s, biasedIsFixedPoint net seq.target :=
    if h : biasedIsFixedPoint net s then
      ⟨BiasedUpdateSeq.nil s, h⟩
    else
      let i := Classical.choose (not_forall.mp h)
      have h_change : biasedUpdateState net s i ≠ s := Classical.choose_spec (not_forall.mp h)
      have h_lf : biasedLocalField net s i ≠ 0 := by
        intro h_zero
        have : biasedUpdateState net s i = s := by
          simp [biasedUpdateState, h_zero]
        contradiction
      have h_diff : biasedEnergyDiff net s i < 0 := 
        biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero net s i h_change h_lf
      have h_dec : biasedEnergy net (biasedUpdateState net s i) < biasedEnergy net s :=
        sub_lt_zero.mp h_diff
      let ⟨seq', h_target⟩ := solve (biasedUpdateState net s i)
      ⟨BiasedUpdateSeq.cons s i seq', h_target⟩
    termination_by s => measure s
    decreasing_by
      simp_wf
      apply Fintype.card_lt_card
      rw [Set.strictSubset_def]
      exact ⟨fun y hy => lt_trans hy h_dec, ⟨biasedUpdateState net s i, h_dec, lt_irrefl _⟩⟩
  exact ⟨(solve x).1, (solve x).2⟩
