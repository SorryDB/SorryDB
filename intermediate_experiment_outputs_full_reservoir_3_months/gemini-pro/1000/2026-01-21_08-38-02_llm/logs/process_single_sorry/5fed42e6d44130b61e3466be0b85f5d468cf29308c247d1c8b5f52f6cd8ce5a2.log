      exact fun hz => lt_trans hz h
    · intro heq
      have : s' ∈ Finset.filter (fun y => biasedEnergy net y < biasedEnergy net s) Finset.univ := by
        simp only [Finset.mem_filter, Finset.mem_univ, true_and]; exact h
      rw [← heq] at this
      simp only [Finset.mem_filter, Finset.mem_univ, true_and, lt_self_iff_false] at this
      exact this
  intro x₀
  induction x₀ using WellFounded.induction (WellFounded.invImage measure Nat.lt_wfRel) with
  | h x ih =>
    by_cases hfp : biasedIsFixedPoint net x
    · exact ⟨BiasedUpdateSeq.nil x, hfp⟩
