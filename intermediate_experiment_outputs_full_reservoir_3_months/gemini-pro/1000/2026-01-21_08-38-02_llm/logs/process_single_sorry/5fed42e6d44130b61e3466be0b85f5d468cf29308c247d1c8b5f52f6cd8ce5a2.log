section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  intro x0
  let measure (x : HopfieldState n) : ℕ := (Finset.univ.filter (fun s => biasedEnergy net s < biasedEnergy net x)).card
  let rec solve (x : HopfieldState n) : ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target :=
    if h : biasedIsFixedPoint net x then
      ⟨BiasedUpdateSeq.nil x, h⟩
    else
      have h_exists : ∃ i, biasedUpdateState net x i ≠ x := by
        rw [biasedIsFixedPoint] at h
        rw [Classical.not_forall] at h
        exact h
      let i := Classical.choose h_exists
      have hi : biasedUpdateState net x i ≠ x := Classical.choose_spec h_exists
      have h_lt : measure (biasedUpdateState net x i) < measure x := by
        let x' := biasedUpdateState net x i
        have h_en : biasedEnergy net x' < biasedEnergy net x := by
          rw [← sub_lt_zero]
          refine lt_of_le_of_ne (biasedEnergy_decreasing net x i) (mt (biasedEnergy_fixed_point_iff_no_change net x i).mp hi)
        apply Finset.card_lt_card
        rw [Finset.ssubset_def]
        refine ⟨fun y hy => ?_, ⟨x', ?_⟩⟩
        · rw [Finset.mem_filter] at hy ⊢; exact ⟨hy.1, lt_trans hy.2 h_en⟩
        · simp only [Finset.mem_filter, Finset.mem_univ, true_and]; exact ⟨h_en, lt_irrefl _⟩
      let ⟨seq, h_seq⟩ := solve (biasedUpdateState net x i)
      ⟨BiasedUpdateSeq.cons x i seq, h_seq⟩
    termination_by measure x
  exact solve x0
