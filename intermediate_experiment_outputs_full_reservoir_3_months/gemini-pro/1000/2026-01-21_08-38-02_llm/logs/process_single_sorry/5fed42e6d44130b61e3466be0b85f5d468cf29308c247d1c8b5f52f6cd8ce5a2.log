section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  let R (a b : HopfieldState n) := biasedEnergy net a < biasedEnergy net b
  have wf : WellFounded R := Finite.wellFounded_of_trans_of_irrefl R (fun _ _ _ => lt_trans) (fun _ => lt_irrefl _)
  intro x
  induction x using wf.induction with
  | h x ih =>
    by_cases h_fp : biasedIsFixedPoint net x
    · exact ⟨nil x, h_fp⟩
    · simp [biasedIsFixedPoint] at h_fp
      rcases h_fp with ⟨i, hi⟩
      let x' := biasedUpdateState net x i
      have h_lt : R x' x := by
        have h_le := biasedEnergy_decreasing net x i
        have h_ne : biasedEnergyDiff net x i ≠ 0 := by
          rw [biasedEnergy_fixed_point_iff_no_change]
          exact hi
        rw [biasedEnergyDiff] at h_le h_ne
        exact sub_lt_zero.mp (lt_of_le_of_ne h_le h_ne)
      rcases ih x' h_lt with ⟨seq, h_seq⟩
      exact ⟨cons x i seq, h_seq⟩
```
