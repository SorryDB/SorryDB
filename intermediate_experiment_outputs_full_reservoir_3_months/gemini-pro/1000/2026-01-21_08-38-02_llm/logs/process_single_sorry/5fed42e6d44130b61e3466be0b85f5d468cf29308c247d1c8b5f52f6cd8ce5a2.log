section BiasedConvergenceTheorems

open BiasedUpdateSeq

/--
Biased asynchronous update process converges to a fixed point.
-/
theorem biased_asynchronous_update_convergence : ∀ x : HopfieldState n, ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target := by
  let measure (x : HopfieldState n) := (Finset.univ.filter (fun y => biasedEnergy net y < biasedEnergy net x)).card
  let rec solve (x : HopfieldState n) : ∃ seq : BiasedUpdateSeq net x, biasedIsFixedPoint net seq.target :=
    if h : biasedIsFixedPoint net x then
      ⟨BiasedUpdateSeq.nil x, h⟩
    else
      let ⟨i, hi⟩ := Classical.not_forall.mp h
      let x' := biasedUpdateState net x i
      have h_lt : biasedEnergy net x' < biasedEnergy net x := by
        have h_diff : biasedEnergyDiff net x i < 0 := by
          apply biasedEnergy_strictly_decreasing_if_state_changes_and_biasedLocalField_nonzero
          · exact hi
          · intro h_zero
            rw [biasedUpdateState] at hi
            simp only [h_zero, lt_self_iff_false, if_false] at hi
            exact hi (Function.update_eq_self _ _)
        rw [biasedEnergyDiff, sub_lt_zero] at h_diff
        exact h_diff
      have h_meas : measure x' < measure x := by
        apply Finset.card_lt_card
        rw [Finset.ssubset_def]
        refine ⟨Finset.filter_subset _ _, ?_⟩
        use x'
        simp only [Finset.mem_filter, Finset.mem_univ, true_and, h_lt, lt_irrefl, not_false_eq_true]
      let ⟨seq', h_target⟩ := solve x'
      ⟨BiasedUpdateSeq.cons x i seq', h_target⟩
    termination_by measure x
  exact solve
