        lt_of_le_of_ne (biasedEnergy_decreasing net x i) (fun h => hi ((biasedEnergy_fixed_point_iff_no_change net x i).mp h))
      have h_energy : biasedEnergy net x' < biasedEnergy net x := sub_lt_zero.mp h_diff
      rcases ih x' (h_decrease x x' h_energy) with ⟨seq', hseq'⟩
      exact ⟨BiasedUpdateSeq.cons x i seq', hseq'⟩
