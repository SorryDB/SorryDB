      · simp only [Finset.sum_const, Finset.card_fin, nsmul_eq_mul]
        rw [ENNReal.mul_inv_cancel (ENNReal.coe_nat_ne_zero.2 hm) (ENNReal.coe_nat_ne_top _)]
