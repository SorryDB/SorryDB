      -- Let T be the set of triples (C, A, B) with A ≠ B and CA = CB
      let T := s.product s.off_diag |>.filter (fun x => dist x.1 x.2.1 = dist x.1 x.2.2)
      -- Lower bound: For every pair {A, B}, there exists C. So |T| ≥ n(n-1).
      -- Upper bound: For every C, let k_C be the number of pairs {A, B} with CA = CB.
      -- Center-free implies for any r, at most 2 points are at distance r from C.
