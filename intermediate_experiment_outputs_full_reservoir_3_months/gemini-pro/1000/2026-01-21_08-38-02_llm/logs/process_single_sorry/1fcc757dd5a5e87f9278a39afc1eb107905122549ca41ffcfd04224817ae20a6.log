section LatticeRefinements

variable {α : Type*} [CompleteLattice α] [DistribLattice α] [BoundedOrder α]

structure refinement (S : Set α) where
  carrier : Set (Set α)
  carrier_span : ∀ a ∈ S, ∃! D ∈ carrier, a = sSup D
  carrier_indep : ∀ D ∈ carrier, sSupIndep D
  bot_not_mem : ∀ D ∈ carrier, ⊥ ∉ D

instance (S : Set α) : SetLike (refinement S) (Set α) where
  coe := refinement.carrier
  coe_injective' D₁ := by cases D₁; congr!

def decomposition_of_refinement {S : Set α} (R : refinement S) : Set α := ⋃ D ∈ R, D

lemma forall_indep {S D : Set α} (R : refinement S) :
    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  let U := decomposition_of_refinement R
  have h_subset : U \ {a} ⊆ (I \ {a}) ∪ ⋃ (J ∈ R) (_ : J ≠ I), J := by
    intro x hx
    simp only [U, decomposition_of_refinement, Set.mem_diff, Set.mem_iUnion] at hx
    rcases hx with ⟨⟨J, hJ, hxJ⟩, hxa⟩
    by_cases hJI : J = I
    · subst hJI; left; exact ⟨hxJ, hxa⟩
    · right; use J, hJ, hJI, hxJ
  have h_disj_I : Disjoint a (sSup (I \ {a})) := (R.carrier_indep I hI).disjoint_sSup_diff hI'
  have h_disj_rest : Disjoint a (sSup (⋃ (J ∈ R) (_ : J ≠ I), J)) := by
    -- This step requires sSupIndep S, which is missing from the hypotheses.
    -- Assuming valid context:
    sorry
  have h_disj : Disjoint a (sSup (U \ {a})) := by
    apply Disjoint.mono_right (sSup_le_sSup h_subset)
    apply Disjoint.sup_right h_disj_I h_disj_rest
  exact h_disj.le_bot_of_le hb hb'
