lemma forall_indep {S : Set α} (hS : sSupIndep S) (R : refinement S)
    (h_clean : ∀ D ∈ R, sSup D ∈ S) :
    sSupIndep (decomposition_of_refinement R) := by
  intro a ha b hb hb'
  simp_rw [decomposition_of_refinement, Set.mem_iUnion] at ha
  obtain ⟨I, hI, hI'⟩ := ha
  rw [decomposition_of_refinement] at hb'
  have h_disj : Disjoint (sSup I) (sSup (⋃ J ∈ R \ {I}, J)) := by
    rw [sSup_sUnion]
    apply hS.disjoint_sSup_right (h_clean _ hI)
    rintro _ ⟨J, ⟨hJ, hne⟩, rfl⟩
