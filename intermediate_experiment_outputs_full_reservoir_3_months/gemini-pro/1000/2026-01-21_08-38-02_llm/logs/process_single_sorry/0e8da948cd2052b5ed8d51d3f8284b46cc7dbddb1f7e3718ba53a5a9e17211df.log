theorem equinum_iff_inverse_pair (U V : Type) :
    U ∼ V ↔ ∃ (f : U → V) (g : V → U), f ∘ g = id ∧ g ∘ f = id := by
  apply Iff.intro
  · intro h
    obtain ⟨f, hf⟩ := h
    let g : V → U := λ v ↦ Classical.choose (hf.2 v)
    exists f, g
    constructor
    · funext y
      exact Classical.choose_spec (hf.2 y)
    · funext x
      apply hf.1
      exact Classical.choose_spec (hf.2 (f x))
  · intro h
    obtain ⟨f, g, hfg, hgf⟩ := h
    exists f
    constructor
    · intro x1 x2 h
      calc x1 = (g ∘ f) x1 := by rw [hgf]; rfl
        _ = g (f x1) := rfl
        _ = g (f x2) := by rw [h]
        _ = (g ∘ f) x2 := rfl
        _ = x2 := by rw [hgf]; rfl
    · intro y
      exists g y
      calc f (g y) = (f ∘ g) y := rfl
        _ = id y := by rw [hfg]
        _ = y := rfl
