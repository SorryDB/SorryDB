  (h₁ : (∑ k ∈ Finset.Icc (1 : ℕ) 1319, (-1) ^ (k + 1) * ((1 : ℝ) / k)) = p / q) : 1979 ∣ p := by
  have hp : Nat.Prime 1979 := by norm_num
  rw [← Rat.cast_sum, ← Rat.cast_div, Rat.cast_inj] at h₁
  
  let s := ∑ k ∈ Finset.Icc 660 989, (1 : ℚ) / (k * (1979 - k))
  
  have h_sum : ∑ k ∈ Finset.Icc 1 1319, (-1 : ℚ) ^ (k + 1) / k = 1979 * s := by
    have h1 : ∑ k ∈ Finset.Icc 1 1319, (-1 : ℚ) ^ (k + 1) / k = ∑ k ∈ Finset.Icc 660 1319, 1 / k := by
      let n := 659
      have : 1319 = 2 * n + 1 := rfl
      rw [this, Finset.sum_Icc_succ_top]
      have aux : ∑ k ∈ Finset.Icc 1 (2 * n), (-1 : ℚ) ^ (k + 1) / k = ∑ k ∈ Finset.Icc (n + 1) (2 * n), 1 / k := by
        induction n with | zero => simp | succ n ih =>
          rw [mul_succ, Finset.sum_Icc_succ_top, Finset.sum_Icc_succ_top]
          rw [ih, Nat.cast_succ, show (n : ℚ) + 1 + 1 = n + 2 by ring]
          field_simp; ring
      rw [aux]; simp; congr 1; norm_num; norm_num
    rw [h1, Finset.sum_Icc_eq_sum_Icc_add_sum_Icc (b := 989) (by norm_num) (by norm_num)]
    rw [Finset.sum_bij (fun k _ => 1979 - k) 
        (by intro x hx; simp at hx ⊢; constructor <;> omega)
