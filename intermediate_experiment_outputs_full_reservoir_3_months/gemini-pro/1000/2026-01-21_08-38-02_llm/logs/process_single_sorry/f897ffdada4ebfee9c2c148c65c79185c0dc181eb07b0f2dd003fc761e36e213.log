lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  let l := P.edge
  have h_nodup : l.Nodup := h.toIsPath.edge_nodup
  have h_alt : l.IsChain (fun x y ↦ x ∉ M ↔ y ∈ M) := h.mem_matching_iff'

  have h_start : ∀ e ∈ l.head?, e ∉ M := by
    intro e he; by_contra hin
    cases P with | nil => simp at he | cons u f P' =>
    simp at he; subst he
    exact h.first_not_in ⟨f, hin, Or.inl rfl⟩

  have h_end : ∀ e ∈ l.getLast?, e ∉ M := by
    intro e he; by_contra hin
    exact h.last_not_in <| P.mem_incidence_of_mem_getLast? he hin

  have h_cnt : l.countP (· ∉ M) = l.countP (· ∈ M) + 1 := by
    have : l ≠ [] := P.edge_ne_nil_of_nonempty h.nonempty
    induction l generalizing h_start h_end with
    | nil => contradiction
    | cons e es ih =>
      match es with
      | [] => simp at h_start h_end ⊢; exact h_start e rfl
      | f :: fs =>
         simp only [List.chain_cons, List.chain_cons_cons] at h_alt
         simp only [List.countP_cons]
         have he : e ∉ M := h_start _ rfl
         have hf : f ∈ M := h_alt.1.1 he
         rw [ih (by simp_all) h_alt.2.1 (by simp_all) h_end]
         simp [he, hf]

  rw [symmDiff_def, encard_union_eq_add_encard_disjoint (disjoint_sdiff_sdiff),
    encard_diff_add_encard_inter M P.edgeFinite, add_assoc]
  congr 1
  rw [← encard_filter_eq_encard_diff P.edgeFinite, ← encard_filter_eq_encard_inter P.edgeFinite]
  rw [encard_eq_coe_toFinset_card (P.edgeFinite.filter _),
      encard_eq_coe_toFinset_card (P.edgeFinite.filter _)]
  norm_cast
  rw [List.toFinset_card_of_nodup (h_nodup.filter _), List.toFinset_card_of_nodup (h_nodup.filter _)]
  rw [List.countP_eq_length_filter, List.countP_eq_length_filter] at h_cnt
  exact h_cnt
