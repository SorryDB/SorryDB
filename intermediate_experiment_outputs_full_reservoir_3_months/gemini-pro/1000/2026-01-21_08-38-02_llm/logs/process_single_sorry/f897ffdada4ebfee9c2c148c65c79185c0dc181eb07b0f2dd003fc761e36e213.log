lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_nodup : P.edge.Nodup := h.toIsPath.isTrail.edge_nodup
  have h_alt : P.edge.Chain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'
  
  -- Auxiliary lemma: For an alternating list starting/ending with non-M edges, |out| = |in| + 1
  have h_len : (P.edge.filter (· ∉ M)).length = (P.edge.filter (· ∈ M)).length + 1 := by
    have h_ne : P.edge ≠ [] := by
      intro heq
      have := h.nonempty
      cases P with
      | nil => simp at this
      | cons => simp at heq
    
    have h_start : ∀ e, e ∈ P.edge.head? → e ∉ M := by
      intro e he
      match P with
      | .cons u f P' => 
        simp at he; subst he
        have : u ∉ V(G, M) := h.first_not_in
        intro hM; exact this ⟨e, hM, rfl⟩
      | .nil _ => contradiction

    have h_end : ∀ e, e ∈ P.edge.getLast? → e ∉ M := by
      intro e he
      match P.exists_concat with
      | ⟨u, .none, rfl⟩ => contradiction
      | ⟨u, .some ⟨P', f, v⟩, rfl⟩ =>
        simp at he; subst he
        have : v ∉ V(G, M) := h.last_not_in
        intro hM; exact this ⟨e, hM, by simp⟩

    generalize hl : P.edge = l
    rw [hl] at h_alt h_start h_end h_ne h_nodup
    clear h h_nodup
    
    induction l with
    | nil => contradiction
    | cons e tail ih =>
      intro h_chain h_head h_last h_ne
      have he : e ∉ M := h_head e (List.head?_cons _ _)
      cases tail with
      | nil => simp [he]
      | cons f rest =>
        simp only [List.filter_cons, List.length_cons]
        rw [if_pos he]
        have hf : f ∈ M := (List.chain_cons.1 h_chain).1.1 he
        rw [if_neg (not_not.2 hf)]
        have h_rest_ne : rest ≠ [] := fun r ↦ (r ▸ h_last) f (by simp) hf
        rw [ih]
        · rfl
        · exact (List.chain_cons.1 h_chain).2
        · intro x hx
          have := (List.chain_cons.1 h_chain).2
          rw [List.chain_cons] at this
          have link := this.1
          have : f ∉ M ↔ x ∈ M := link.symm.subst (List.mem_head?_iff_head_eq.mp hx).symm
          rw [iff_false_intro (not_not.2 hf), false_iff, not_not] at this
          exact this
        · exact h_last
        · exact h_rest_ne

  -- Translate to encard
  have h_fin : E(P).Finite := P.edgeFinite
  have h_out : (E(P) \ M).encard = (P.edge.filter (· ∉ M)).length := by
    rw [encard_eq_coe_toFinset_card (h_fin.diff _), Finset.card_eq_length, List.nodup_filter _ h_nodup]
    congr; ext; simp
  have h_in : (E(P) ∩ M).encard = (P.edge.filter (· ∈ M)).length := by
    rw [encard_eq_coe_toFinset_card (h_fin.inter_of_left _), Finset.card_eq_length, List.nodup_filter _ h_nodup]
    congr; ext; simp

  -- Final Calculation
  rw [Set.symmDiff_def, encard_union (disjoint_sdiff_sdiff), h_out, h_in, h_len]
  nth_rw 1 [← diff_union_inter M E(P)]
  rw [encard_union (disjoint_sdiff_inter _ _), add_assoc]
  norm_cast
