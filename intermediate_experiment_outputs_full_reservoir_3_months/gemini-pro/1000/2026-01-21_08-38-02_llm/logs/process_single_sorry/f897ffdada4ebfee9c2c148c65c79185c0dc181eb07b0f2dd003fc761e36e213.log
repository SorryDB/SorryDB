lemma IsAugPath.augment_encard (h : G.IsAugPath hM P) : (M ∆ E(P)).encard = M.encard + 1 := by
  have h_fin : E(P).Finite := List.finite_toSet P.edge
  let l := P.edge
  have h_nodup : l.Nodup := h.toIsPath.isTrail.edge_nodup
  have h_chain : l.Chain (fun e f ↦ e ∈ M ↔ f ∉ M) := by convert h.mem_matching_iff using 1

  have h_cnt : l.countP (· ∉ M) = l.countP (· ∈ M) + 1 := by
    have h_ne : l ≠ [] := by simp [l, h.nonempty.ne_empty]
    
    have h_start : l.head h_ne ∉ M := by
      obtain ⟨u, e, P', rfl⟩ := h.nonempty.exists_cons
      intro he
      exact h.first_not_in ⟨e, he, (cons_isPath_iff.mp h.toIsPath).1.mem_left⟩ 

    have h_end : l.getLast h_ne ∉ M := by
      intro he
      have : P.last ∈ V(G, l.getLast h_ne) := by
        induction P with
        | nil => contradiction
        | cons u e P' ih =>
          simp only [l, WList.edge_cons] at h_ne ⊢
          cases hP' : P'.edge.eq_empty_or_nonempty
          · rename_i h_nil
            simp [h_nil]
            obtain ⟨v, rfl⟩ := P'.exists_eq_nil_or_nonempty
            · simp; exact (cons_isPath_iff.mp h.toIsPath).1.mem_right
            · rw [h_nil] at hP'; contradiction
          · rename_i h_nemp
            simp [h_nemp]
            apply ih
            exact h.toIsPath.of_cons
      exact h.last_not_in ⟨_, he, this⟩

    generalize hn_in : l.countP (· ∈ M) = n_in
    generalize hn_out : l.countP (· ∉ M) = n_out
    induction l generalizing n_in n_out with
    | nil => contradiction
    | cons x xs ih =>
      cases xs with
      | nil =>
        simp at hn_in hn_out h_start
        simp [hn_in, hn_out, h_start]
      | cons y ys =>
        simp at hn_in hn_out h_start h_chain
        have hy : y ∈ M := by simpa [h_start] using h_chain.1
        rw [if_pos h_start, if_neg hy] at hn_out hn_in
        rw [add_assoc]
        congr 1
        refine ih h_chain.2.2 ?_ h_end (by simp) (by simp)
        cases ys <;> simp at h_chain h_end ⊢
        rename_i z zs
        simpa [hy] using h_chain.2.1

  rw [Set.symmDiff_def, Set.sup_eq_union, encard_union_eq_add_encard disjoint_sdiff_sdiff]
  rw [encard_eq_coe_toFinset_card (E(P) \ M) (h_fin.diff _)]
  rw [encard_eq_coe_toFinset_card (M ∩ E(P)) (h_fin.inter_of_right _)]
  rw [← List.toFinset_card_of_nodup (h_nodup.filter _)]
  rw [← List.toFinset_card_of_nodup (h_nodup.filter _)]
  rw [List.countP_eq_length_filter, List.countP_eq_length_filter] at h_cnt 
  rw [← List.countP_eq_length_filter (p := (· ∉ M))]
  rw [← List.countP_eq_length_filter (p := (· ∈ M))]
  rw [h_cnt]
  norm_cast
  rw [← add_assoc, ← encard_union_eq_add_encard (disjoint_sdiff_inter M E(P)), diff_union_inter]
