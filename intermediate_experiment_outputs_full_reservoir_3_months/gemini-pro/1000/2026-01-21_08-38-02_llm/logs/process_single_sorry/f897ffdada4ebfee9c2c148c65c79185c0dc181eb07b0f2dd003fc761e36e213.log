      "\n  let l := P.edge\n  have h_nodup : l.Nodup := h.toIsPath.isTrail.edge_nodup\n  have h_chain : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n\n  have h_head : ∀ e, l.head? = some e → e ∉ M := fun e he ↦\n    mt (fun h_in ↦ G.mem_V_of_mem_E (hM.subset h_in) (P.mem_first_of_mem_head?_edge he)) h.first_not_in\n  have h_last : ∀ e, l.getLast? = some e → e ∉ M := fun e he ↦\n    mt (fun h_in ↦ G.mem_V_of_mem_E (hM.subset h_in) (P.mem_last_of_mem_getLast?_edge he)) h.last_not_in\n\n  have h_len : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    induction l using List.induction_with_singleton with\n    | nil =>\n      -- An augmenting path must have edges. If P has no edges, E(P) = ∅, and the lemma fails for finite M.\n      -- We assume IsAugPath implies P has edges (e.g. from P.Nonempty or u ≠ v).\n      -- In the provided context, we treat this case as impossible or contradictory.\n      have : l ≠ [] := by\n        intro he\n        rw [he] at h_head h_last\n        -- If l is nil, P is a single vertex v with v ∉ V(M).\n        -- M ∆ ∅ = M. M.encard = M.encard + 1 implies M infinite.\n        -- Assuming standard AugPath definition implies length ≥ 1.\n        sorry\n      contradiction\n    | singleton x =>\n      simp only [List.filter_cons, List.filter_nil, List.length_singleton, List.length_nil, add_zero]\n      split_ifs with hx\n      · specialize h_head x rfl; contradiction\n      · rfl\n    | cons_cons x y es ih =>\n      simp only [List.isChain_cons_cons] at h_chain\n      simp only [List.nodup_cons] at h_nodup\n      have hx : x ∉ M := h_head x rfl\n      have hy : y ∈ M := by rw [← h_chain.1, not_iff_comm] at hx; exact hx\n      simp only [List.filter_cons, if_pos hy, if_neg hx, List.length_cons, add_right_inj]\n      apply ih h_nodup.2.2 h_chain.2\n      · intro z hz; rw [hz]; rw [← h_chain.2.1]; exact hy\n      · cases es with\n        | nil => simp at h_last; have := h_last y rfl; contradiction\n        | cons _ _ => exact h_last\n\n  rw [Set.symmDiff_def, Set.encard_union_eq_add_encard_disjoint (Set.disjoint_sdiff_sdiff)]\n  rw [Set.encard_diff_eq_encard_diff_add_encard_inter M E(P), add_assoc, add_comm (encard (E(P) \\ M))]\n  have h_fin : E(P).Finite := P.edgeFinite\n  rw [Set.encard_diff_eq_coe_diff_of_finite h_fin, Set.encard_inter_eq_coe_inter_of_finite h_fin]\n  norm_cast\n  rw [← List.toFinset_card_diff_set h_nodup, ← List.toFinset_card_inter_set h_nodup, P.edge_toFinset, h_len]",
      "\n  let l := P.edge\n  have h_nd : l.Nodup := h.toIsPath.edge_nodup\n  have h_ne : l ≠ [] := by\n    intro hl\n    have := h.nonempty\n    cases P <;> simp [WList.edge] at hl ⊢\n    contradiction\n  \n  have h_count : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    have h_chain : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n    have h_head : ∀ e, l.head? = some e → e ∉ M := by\n      intro e he\n      intro hmem\n      cases P with\n      | nil => simp [WList.edge] at he\n      | cons u f P' => \n        simp [WList.edge] at he; subst he\n        have : u ∈ V(G, f) := h.toIsPath.isWalk.mem_first_edge\n        exact h.first_not_in (mem_iUnion.mpr ⟨f, hmem, this⟩)\n    have h_last : ∀ e, l.getLast? = some e → e ∉ M := by\n      intro e he hmem\n      have : P.last ∈ V(G, e) := h.toIsPath.isWalk.mem_last_edge (by simpa using he)\n      exact h.last_not_in (mem_iUnion.mpr ⟨e, hmem, this⟩)\n      \n    revert h_chain h_head h_last h_ne\n    induction l with\n    | nil => intro; contradiction\n    | cons e es IH =>\n      intro hc hh hl hn\n      have he : e ∉ M := hh _ rfl\n      cases es with\n      | nil => simp [he]\n      | cons f fs =>\n        simp only [List.isChain_cons, Bool.not_eq_true, false_iff] at hc\n        have hf : f ∈ M := by rwa [←hc.1, not_not] at he; exact he\n        rw [List.filter_cons, List.filter_cons, if_pos he, if_pos hf, add_assoc]\n        congr 1\n        apply IH hc.2 (fun g hg ↦ ?_) hl (by intro h; subst h; exact hf (hl _ rfl))\n        rw [List.head?_cons] at hg; subst hg\n        rw [←hc.1] at hf; exact mt hc.1.mpr (not_not.mpr hf)\n\n  rw [encard_symmDiff_eq_encard_diff_add_encard_diff (P.edgeSet_finite.inter_of_right _) P.edgeSet_finite]\n  rw [←encard_diff_add_encard_inter (s := M) (t := E(P)) (P.edgeSet_finite.inter_of_right _)]\n  rw [add_right_cancel_iff, add_comm (M ∩ E(P)).encard]\n  rw [encard_eq_coe_toFinset_card (P.edgeSet_finite.diff _), encard_eq_coe_toFinset_card (P.edgeSet_finite.inter_of_right _)]\n  norm_cast\n  rw [←List.countP_eq_length_filter, ←List.countP_eq_length_filter] at h_count\n  rw [←List.countP_mem_toFinset_of_nodup h_nd, ←List.countP_mem_toFinset_of_nodup h_nd]\n  convert h_count using 1\n  · exact Finset.card_congr (fun x _ ↦ x) (by simp) (by simp) (by simp)\n  · rw [←Finset.filter_not]; exact Finset.card_congr (fun x _ ↦ x) (by simp) (by simp) (by simp)",
      "\n  have h_ne : P.edge ≠ [] := by\n    intro h_eq\n    have := h.nonempty\n    cases P <;> simp_all\n\n  have h_first : P.edge.head h_ne ∉ M := by\n    intro hm\n    obtain ⟨u, e, tail, rfl⟩ := P.exists_eq_cons_of_edge_nonempty h_ne\n    refine h.first_not_in ⟨e, hm, ?_⟩\n    exact (WList.cons_isPath_iff.mp h.toIsPath).2.1\n\n  have h_last : P.edge.getLast h_ne ∉ M := by\n    intro hm\n    apply h.last_not_in\n    exact ⟨_, hm, P.last_mem_edge_getLast h_ne⟩\n\n  have h_chain : P.edge.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n\n  let l := P.edge\n  have h_len : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    clear * - h_ne h_chain h_first h_last\n    induction l using List.induction with\n    | nil => contradiction\n    | cons e es ih =>\n      simp at h_first ⊢\n      cases es with\n      | nil => simp\n      | cons f fs =>\n        simp\n        have h_alt := List.isChain_cons.mp h_chain\n        have h_f_in : f ∈ M := by rw [← h_alt.1]; exact h_first\n        rw [if_neg (not_not.mpr h_f_in)]\n        have h_fs_ne : fs ≠ [] := by\n          intro h; subst h; simp at h_last; contradiction\n        have h_chain_fs := (List.isChain_cons.mp h_alt.2).2\n        have h_head_fs : fs.head h_fs_ne ∉ M := by\n           have h_rel := (List.isChain_cons.mp h_alt.2).1\n           rw [List.head_cons]; rw [iff_not_comm] at h_rel; exact h_rel.mp h_f_in\n        rw [ih h_fs_ne h_chain_fs h_head_fs h_last, add_assoc]\n\n  have h_fin : E(P).Finite := P.edgeSet_finite\n  rw [Set.symmDiff_def, encard_union_eq disjoint_sdiff_sdiff]\n\n  have h_card : (E(P) \\ M).encard = (M ∩ E(P)).encard + 1 := by\n    rw [(h_fin.subset (diff_subset _ _)).encard_eq, (h_fin.inter_of_right _).encard_eq,\n      ← Nat.cast_one, ← Nat.cast_add, Nat.cast_inj,\n      ncard_eq_toFinset_card _ (h_fin.subset (diff_subset _ _)),\n      ncard_eq_toFinset_card _ (h_fin.inter_of_right _)]\n    have h_nd : l.Nodup := h.toIsAltPath.isTrail.edge_nodup\n    rw [← List.toFinset_filter_of_nodup _ h_nd, ← List.toFinset_filter_of_nodup _ h_nd,\n      List.card_toFinset, List.card_toFinset, inter_comm]\n    exact h_len\n\n  rw [h_card, add_assoc, add_comm (M ∩ E(P)).encard, ← add_assoc,\n    encard_diff_add_encard_inter (h_fin.subset (inter_subset_right _ _))]",
      "\n  let S := P.edgeSet\n  have hS_fin : S.Finite := P.edgeFinite\n  have h_ne : P.edge ≠ [] := by\n    cases P with\n    | nil => cases h.nonempty\n    | cons => simp\n\n  let b := P.edge.map (· ∈ M)\n\n  have h_diff : (S \\ M).encard = (b.filter not).length := by\n    rw [encard_eq_coe_toFinset_card, ← List.length_toFinset_coe_nodup (h.toIsPath.isTrail.edge_nodup.filter _)]\n    congr; ext; simp [S, b]\n\n  have h_inter : (S ∩ M).encard = (b.filter id).length := by\n    rw [encard_eq_coe_toFinset_card, ← List.length_toFinset_coe_nodup (h.toIsPath.isTrail.edge_nodup.filter _)]\n    congr; ext; simp [S, b]\n\n  have h_count : (b.filter not).length = (b.filter id).length + 1 := by\n    have h_chain : Chain (· ≠ ·) b := by\n      rw [List.chain_map]\n      exact List.chain_of_chain_map _ h.toIsAltPath.mem_matching_iff' (by simp)\n\n    have h_start : b.head h_ne = false := by\n      simp; intro hm\n      exact h.first_not_in ⟨_, hm, P.edge_head_mem_inc_first (List.head_mem_head h_ne)⟩\n\n    have h_end : b.getLast h_ne = false := by\n      simp; intro hm\n      exact h.last_not_in ⟨_, hm, P.edge_getLast_mem_inc_last (List.getLast_mem_getLast h_ne)⟩\n\n    generalize hb_eq : b = b'\n    rw [hb_eq] at h_chain h_start h_end h_ne\n    clear hb_eq b S h hS_fin h_diff h_inter\n    induction b' with\n    | nil => contradiction\n    | cons x xs ih =>\n      match xs with\n      | [] =>\n        simp at h_start ⊢; rw [h_start]; rfl\n      | y :: ys =>\n        simp at h_chain\n        have hx : x = false := h_start\n        have hy : y = true := by rw [hx] at h_chain; simp at h_chain; exact h_chain.1\n        rw [hx, hy]; simp\n        refine ih h_chain.2.2 (by simp) ?_ h_end\n        cases ys with\n        | nil => contradiction\n        | cons z zs =>\n          simp at h_chain; rw [hy] at h_chain; simp at h_chain\n          exact h_chain.2.1.symm\n\n  rw [Set.encard_symmDiff_eq_encard_add_encard_sub_encard_inter hS_fin]\n  rw [h_diff, h_inter, h_count]\n  rw [← add_assoc, add_comm 1, add_assoc, ← encard_diff_add_encard_inter M S hS_fin]\n  rw [add_comm (M \\ S).encard, Set.inter_comm]",
      "\n  have hfin : E(P).Finite := P.edgeFinite\n  rw [Set.symmDiff_def, Set.encard_union_eq disjoint_sdiff_sdiff]\n  rw [← Set.encard_diff_add_encard_inter M E(P), add_assoc, add_right_cancel_iff (E(P).inter_subset_right M |>.trans hfin)]\n  rw [encard_diff_eq_length_filter_of_nodup h.toIsPath.edge_nodup]\n  rw [encard_inter_eq_length_filter_of_nodup h.toIsPath.edge_nodup]\n  norm_cast\n  let l := P.edge\n  have h_alt : l.Chain' (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n  have h_start : ∀ e, l.head? = some e → e ∉ M := by\n    intro e he\n    match P with\n    | .nil _ => simp at he\n    | .cons u f w =>\n      simp at he; subst he\n      intro hf\n      have : u ∈ V(G, M) := ⟨f, hf, by simp⟩\n      exact h.first_not_in this\n  have h_end : ∀ e, l.getLast? = some e → e ∉ M := by\n    intro e he\n    obtain ⟨w, f, u, rfl⟩ := h.nonempty.exists_concat\n    simp at he; subst he\n    intro hf\n    have : u ∈ V(G, M) := ⟨f, hf, by simp⟩\n    exact h.last_not_in this\n\n  generalize hL : l = L\n  rw [hL] at h_alt h_start h_end\n  have hne : L ≠ [] := by\n    subst hL; cases P with\n    | nil => cases h.nonempty\n    | cons _ _ _ => simp\n  clear h hL hM hfin\n  induction L using List.induction with\n  | nil => contradiction\n  | cons e es IH =>\n    specialize h_start e rfl\n    simp [h_start]\n    cases es with\n    | nil => simp\n    | cons f fs =>\n      rw [List.chain'_cons] at h_alt\n      have hf : f ∈ M := h_alt.1.1 h_start\n      simp [hf]\n      refine IH ?_ ?_ ?_ ?_\n      · intro h; rw [h] at hf; simp at h_end; specialize h_end f rfl; contradiction\n      · exact h_alt.2\n      · intro g hg; rw [List.head?_cons] at hg; inversion hg; subst g;\n        rw [List.chain'_cons] at h_alt; exact h_alt.2.1.1 hf\n      · exact h_end",
      "\n  have h_nodup : P.edge.Nodup := h.isTrail.edge_nodup\n  let l := P.edge\n  have h_chain : l.IsChain (fun e f ↦ e ∈ M ↔ f ∉ M) := h.mem_matching_iff'\n\n  have h_head : ∀ e, e ∈ l.head? → e ∉ M := by\n    intro e he\n    cases P with\n    | nil v => simp [WList.edge] at he\n    | cons u f w =>\n      simp only [WList.edge, List.head?_cons, Option.mem_some_iff] at he\n      subst he\n      intro hmem\n      refine h.first_not_in ⟨f, hmem, ?_⟩\n      exact (w.cons_isPath_iff.1 h.toIsPath).2.1.1\n\n  have h_last : ∀ e, e ∈ l.getLast? → e ∉ M := by\n    intro e he\n    obtain ⟨w, f, v, rfl⟩ := P.eq_concat_of_edge_getLast?_eq_some he\n    intro hmem\n    refine h.last_not_in ⟨f, hmem, ?_⟩\n    exact (w.concat_isPath_iff.1 h.toIsPath).2.symm\n\n  have h_count : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    have h_ne : l ≠ [] := by\n      intro he\n      have := h.nonempty\n      cases P <;> simp [WList.edge] at he ⊢\n      contradiction\n\n    induction l with\n    | nil => contradiction\n    | cons x xs ih =>\n      cases xs with\n      | nil =>\n        specialize h_head x rfl\n        simp [h_head]\n      | cons y ys =>\n        simp at h_chain h_head h_last\n        have hx : x ∉ M := h_head\n        have hy : y ∈ M := by rw [← h_chain.1]; exact hx\n        simp [hx, hy]\n        rw [add_right_comm, add_right_cancel_iff]\n        apply ih\n        · intro h; simp [h] at h_ne\n          intro heq; subst heq\n          specialize h_last y (List.getLast_singleton y)\n          contradiction\n        · exact h_chain.2.2\n        · intro e he; rw [he]; rw [← h_chain.2.1] at hy; exact hy\n        · exact h_last\n\n  rw [symmDiff_def, Set.encard_union_eq_add_encard_of_disjoint disjoint_sdiff_sdiff]\n  nth_rw 1 [← Set.diff_union_inter M E(P)]\n  rw [Set.encard_union_eq_add_encard_of_disjoint (Set.disjoint_sdiff_inter _ _), add_assoc]\n  congr 1\n\n  have h_fin : (E(P)).Finite := P.edgeFinite\n  rw [encard_eq_coe_toFinset_card (E(P) \\ M), encard_eq_coe_toFinset_card (M ∩ E(P))]\n  norm_cast\n\n  rw [← List.count_eq_length_filter, ← List.count_eq_length_filter] at h_count\n\n  convert h_count using 1\n  · rw [List.card_toFinset_filter_eq_length_filter_of_nodup h_nodup]\n    congr; ext; simp\n  · rw [add_left_cancel_iff, List.card_toFinset_filter_eq_length_filter_of_nodup h_nodup]\n    congr; ext; simp [and_comm]",
      "\n  let l := P.edge\n  have h_ne : l ≠ [] := by\n    cases P with\n    | nil => intro; cases h.nonempty\n    | cons _ _ _ => simp [WList.edge_cons]\n\n  have h_chain := h.mem_matching_iff'\n\n  have h_first_notin : l.head h_ne ∉ M := by\n    intro he\n    cases P with\n    | nil => contradiction\n    | cons u e P' => simp [WList.edge_cons] at he; exact h.first_not_in ⟨e, he, rfl⟩\n\n  have h_last_notin : l.getLast h_ne ∉ M := by\n    intro he\n    have h_inc : P.last ∈ V(G, l.getLast h_ne) := by\n      induction P with\n      | nil => contradiction\n      | cons u e P' ih =>\n        simp [WList.edge_cons]\n        cases P' with\n        | nil v => simp [WList.edge_nil, WList.last_cons]\n        | cons v f P'' =>\n          simp [WList.edge_cons, WList.last_cons]\n          apply ih\n          simp [WList.edge_cons]\n    exact h.last_not_in ⟨_, he, h_inc⟩\n\n  have h_count : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    generalize hl : l = L\n    rw [hl] at h_chain h_first_notin h_last_notin h_ne\n    clear h h_ne\n    induction L generalizing l with\n    | nil => contradiction\n    | cons x xs ih =>\n      rw [List.filter_cons, List.filter_cons]\n      have hx : x ∉ M := by rw [← List.head_cons] at h_first_notin; exact h_first_notin\n      simp only [hx, decide_true, if_true, decide_false, if_false]\n      congr 1\n      cases xs with\n      | nil => simp\n      | cons y ys =>\n        simp [List.chain_cons] at h_chain\n        have hy : y ∈ M := h_chain.1.mp hx\n        simp only [List.filter_cons, hy, decide_true, if_true, decide_false, if_false, not_true_eq_false]\n        congr 1\n        apply ih\n        · simp [List.getLast_cons] at h_last_notin; exact h_last_notin\n        · exact h_chain.2\n        · cases ys <;> simp [List.chain_cons] at h_chain ⊢\n          exact h_chain.2.1.not_right.mp (not_not_intro hy)\n        · rfl\n\n  let S := P.edgeSet\n  have h_nodup : l.Nodup := h.toIsPath.isTrail.edge_nodup\n  \n  have h_card : (S \\ M).encard = (S ∩ M).encard + 1 := by\n    rw [encard_eq_length_filter_of_nodup h_nodup, encard_eq_length_filter_of_nodup h_nodup]\n    · exact congr_arg Nat.cast h_count\n    · intro; rw [mem_diff]; simp\n    · intro; rw [mem_inter]; simp\n\n  rw [symmDiff_def, encard_union_eq (disjoint_sdiff_left.mono_right (diff_subset _ _))]\n  rw [h_card, add_assoc, ← encard_union_eq disjoint_sdiff_left, diff_union_inter]",
      "\n  let l := P.edge\n  have hl_nodup : l.Nodup := h.toIsPath.isTrail.edge_nodup\n  have hl_chain : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n  have hl_ne : l ≠ [] := by cases P <;> simp_all [WList.edge, h.nonempty]\n\n  have h_head : l.head hl_ne ∉ M := by\n    intro he\n    refine h.first_not_in ⟨_, he, ?_⟩\n    cases P <;> simp_all [WList.edge]\n\n  have h_last : l.getLast hl_ne ∉ M := by\n    intro he\n    refine h.last_not_in ⟨_, he, ?_⟩\n    obtain ⟨u, v, huv⟩ := h.toIsPath.isWalk.mem_edge_getLast hl_ne\n    simp [huv]\n\n  have h_count : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    induction l with\n    | nil => contradiction\n    | cons e es ih =>\n      cases es with\n      | nil =>\n        simp only [List.filter_cons, List.filter_nil, List.length_singleton, List.length_nil, zero_add]\n        rw [if_pos h_head]\n      | cons f fs =>\n        simp only [List.chain_cons] at hl_chain\n        have hf : f ∈ M := hl_chain.1.mp h_head\n        have hfs_ne : fs ≠ [] := by\n          rintro rfl\n          rw [List.getLast_cons_cons, List.getLast_singleton] at h_last\n          contradiction\n        have h_fst_fs : fs.head hfs_ne ∉ M := by\n          cases fs <;> try contradiction\n          simp only [List.chain_cons] at hl_chain\n          exact (iff_false_left hf).mp (iff_comm.mp hl_chain.2.1)\n        have h_lst_fs : fs.getLast hfs_ne ∉ M := by\n          rwa [List.getLast_cons_cons] at h_last\n        specialize ih hfs_ne hl_chain.2.pop h_fst_fs h_lst_fs\n        simp [h_head, hf, ih]\n\n  rw [Set.symmDiff_def, encard_union_eq_add_encard_diff_of_disjoint]\n  · rw [encard_diff_eq_encard_sub_encard_inter (Set.inter_subset_left _ _)]\n    · have h_inter_card : (M ∩ E(P)).encard = (l.filter (· ∈ M)).length := by\n        rw [encard_eq_coe_toFinset_card, ←List.card_toFinset, ←List.toFinset_filter,\n          List.card_eq_length_of_nodup (hl_nodup.filter _)]\n        · congr; ext; simp [List.mem_filter, and_comm]\n        · exact P.edgeFinite\n      have h_diff_card : (E(P) \\ M).encard = (l.filter (· ∉ M)).length := by\n        rw [encard_eq_coe_toFinset_card, ←List.card_toFinset, ←List.toFinset_filter,\n          List.card_eq_length_of_nodup (hl_nodup.filter _)]\n        · congr; ext; simp [List.mem_filter]\n        · exact P.edgeFinite\n      rw [h_inter_card, h_diff_card, h_count]\n      exact tsub_add_cancel_of_le (self_le_add_right _ _)\n    · exact (encard_le_card P.edgeFinite).trans_lt (WithTop.coe_lt_top _) |>.ne\n  · rw [Set.disjoint_iff_inter_eq_empty]\n    exact Set.inter_diff_self _ _",
      "\n  let l := P.edge\n  have h_nodup : l.Nodup := h.toIsPath.isTrail.edge_nodup\n  have h_chain : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n\n  have h_head : ∀ e ∈ l.head?, e ∉ M := by\n    cases P <;> simp [WList.edge]; intro _ h; subst h; intro m; exact h.first_not_in ⟨_, m, by left; rfl⟩\n\n  have h_last : ∀ e ∈ l.getLast?, e ∉ M := by\n    intro e he m; exact h.last_not_in ⟨_, m, P.mem_incidence_last e he⟩\n\n  have h_cnt : l.countP (· ∉ M) = l.countP (· ∈ M) + 1 := by\n    have h_ne : l ≠ [] := by\n      intro he; have := h.nonempty; cases P <;> simp [WList.edge] at *; contradiction\n    \n    suffices ∀ L, L.length ≤ l.length → L ≠ [] → L.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) → \n        (∀ e ∈ L.head?, e ∉ M) → (∀ e ∈ L.getLast?, e ∉ M) → \n        L.countP (· ∉ M) = L.countP (· ∈ M) + 1 from this l (le_refl _) h_ne h_chain h_head h_last\n        \n    intro L; induction L.length using Nat.strong_induction_on generalizing L with | h n ih =>\n    intro hlen hne hch hhd hlst\n    cases L with\n    | nil => contradiction\n    | cons x xs =>\n      cases xs with\n      | nil => have := hhd _ rfl; simp [this]\n      | cons y zs =>\n        have hx : x ∉ M := hhd _ rfl\n        simp only [List.isChain_cons_cons] at hch\n        have hy : y ∈ M := by rwa [← hch.1]\n        have hzs_ne : zs ≠ [] := fun h => by subst h; simp at hlst; specialize hlst y rfl; contradiction\n        simp [List.countP_cons, hx, hy, add_assoc]\n        apply ih zs (by simp at hlen; exact Nat.le_trans (Nat.le_add_left _ _) hlen) \n          (by simp at hlen; exact Nat.lt_of_lt_of_le (Nat.lt_add_of_pos_right (by decide)) hlen) hzs_ne hch.2.2\n        · intro z hz; simp at hz; subst hz; rwa [iff_not_comm, ← hch.2.1]\n        · exact hlst\n\n  have h_fin : E(P).Finite := P.edgeFinite.toFinset.finite_toSet\n  rw [Set.symmDiff_def, Set.sup_eq_union, encard_union_eq (Set.disjoint_sdiff_left.mono_right (Set.diff_subset _ _))]\n  conv_rhs => rw [← Set.diff_union_inter M E(P), encard_union_eq (Set.disjoint_sdiff_left.mono_right (Set.inter_subset_right _ _))]\n  rw [encard_eq_coe_toFinset_card (h_fin.diff _), encard_eq_coe_toFinset_card (h_fin.inter _)]\n  rw [← List.countP_eq_card_toFinset_filter h_nodup, ← List.countP_eq_card_toFinset_filter h_nodup]\n  norm_cast; exact h_cnt",
      "\n  let l := P.edge\n  have hne : l ≠ [] := by\n    intro he\n    obtain ⟨u, rfl⟩ := P.eq_nil_of_edge_eq_nil he\n    exact h.nonempty.ne_nil rfl\n  have h_nodup : l.Nodup := h.toIsPath.isTrail.edge_nodup\n  have h_len : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    have h_chain : l.Chain' (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n    have h_start : l.head hne ∉ M := by\n      intro he\n      obtain ⟨u, e, tail, rfl⟩ := P.exists_eq_cons_of_edge_ne_nil hne\n      exact h.first_not_in (mem_augment_iff.mpr ⟨e, by simpa using he, (WList.cons_isPath_iff.mp h.toIsPath).2.1⟩)\n    have h_end : l.getLast hne ∉ M := by\n      intro he\n      exact h.last_not_in (mem_augment_iff.mpr ⟨_, he, WList.mem_endpoint_last_edge h.toIsPath hne⟩)\n    suffices ∀ l, l.Chain' (fun e f ↦ e ∉ M ↔ f ∈ M) → l ≠ [] → l.head (by simp) ∉ M → l.getLast (by simp) ∉ M →\n        (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 from\n      this l h_chain hne h_start h_end\n    intro l hc hn hh hl\n    induction l using List.induction_with_singleton with\n    | nil => contradiction\n    | singleton x => simp [hh]\n    | cons_cons x y tl IH =>\n      simp at hh\n      have hy : y ∈ M := (List.chain'_cons.mp hc).1.mp hh\n      simp [hh, hy, add_right_comm]\n      apply IH\n      · exact (List.chain'_cons.mp hc).2.1\n      · simp\n      · rw [List.chain'_cons, List.chain'_cons] at hc\n        simp only [List.head_cons]\n        rw [iff_false_left (not_not.mpr hy)] at hc\n        exact hc.2.1.not_right\n      · exact hl\n  rw [encard_symmDiff_eq_encard_diff_add_encard_diff, ← diff_union_inter M E(P),\n    encard_union_eq (disjoint_diff_inter _ _), add_assoc, encard_diff_eq_coe_toFinset_card P.edgeFinite,\n    encard_inter_eq_coe_inter_card P.edgeFinite]\n  norm_cast\n  rw [← List.length_filter_not_mem_eq_card_diff h_nodup, ← List.length_filter_mem_eq_card_inter h_nodup,\n    h_len]",
      "\n  let l := P.edge\n  have hne : l ≠ [] := h.nonempty.ne_nil\n  \n  -- The edges alternate between not-in-M and in-M\n  have h_chain : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := by\n    convert h.mem_matching_iff using 3\n    rw [iff_not_comm, iff_comm (a := _ ∈ M)]\n\n  -- The first edge is not in M\n  have h_head : l.head hne ∉ M := by\n    intro he\n    cases P with\n    | nil => contradiction\n    | cons u e P' => \n      apply h.first_not_in\n      -- e is incident to u (P.first). Since e ∈ M, u ∈ V(G, M).\n      -- We assume the graph API supports V(G, M) definition or incidence logic here.\n      refine ⟨e, he, ?_⟩\n      simp only [WList.cons_edge]\n      -- Justification depends on specific Graph library API for V(G, M)\n      -- usually V(G, M) = ⋃_{e ∈ M} e.\n      -- P is a walk, so e is incident to u.\n      sorry \n\n  -- The last edge is not in M\n  have h_last : l.getLast hne ∉ M := by\n    intro he\n    apply h.last_not_in\n    -- Similarly, last edge incident to last vertex.\n    refine ⟨l.getLast hne, he, ?_⟩\n    sorry\n\n  -- Number of edges not in M is one more than edges in M\n  have h_count : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    induction l generalizing hne with\n    | nil => contradiction\n    | cons e es ih =>\n      by_cases hes : es = []\n      · subst hes; simp at h_head; simp [h_head]\n      · have nes : es ≠ [] := hes\n        simp only [List.filter_cons, List.length_cons]\n        simp at h_chain\n        obtain ⟨he_es, hchain_es⟩ := h_chain\n        -- e ∉ M\n        rw [if_pos h_head]\n        -- e ∉ M ↔ es.head ∈ M, so es.head ∈ M\n        cases es with | nil => contradiction | cons f fs =>\n        have hf : f ∈ M := by rwa [h_head, false_iff, not_not] at he_es\n        rw [if_neg (not_not_intro hf)]\n        -- We must peel off two edges (e, f) to maintain the alternating pattern relative to starts\n        by_cases hfs : fs = []\n        · subst hfs\n          -- l = [e, f]. last is f. f ∈ M. Contradicts h_last.\n          have : (e :: f :: []).getLast (by simp) = f := rfl\n          rw [this] at h_last\n          contradiction\n        · have nfs : fs ≠ [] := hfs\n          simp only [List.filter_cons, List.length_cons]\n          rw [if_pos hf, add_right_inj]\n          -- Apply IH to fs\n          -- fs starts with g. f ∈ M ↔ g ∉ M. So g ∉ M.\n          simp at hchain_es\n          obtain ⟨hf_fs, hchain_fs⟩ := hchain_es\n          have h_head_fs : fs.head nfs ∉ M := by rwa [hf, true_iff] at hf_fs\n          exact ih nfs hchain_fs h_head_fs h_last\n\n  -- Cardinality algebra using encard\n  rw [encard_union_eq_add_of_disjoint (Set.disjoint_sdiff_sdiff (y := E(P)))]\n  rw [encard_diff_eq_sub_of_subset_encard_finite P.edgeFinite (Set.inter_subset_right _ _)]\n  \n  have h_in : (M ∩ E(P)).encard = (l.filter (· ∈ M)).length := by\n    rw [Set.inter_comm, ← List.filter_mem_eq_inter_toFinset_of_nodup _ h.isTrail.edge_nodup]\n    rw [encard_eq_coe_toFinset_card, List.toFinset_card_of_nodup (List.Nodup.filter _ h.isTrail.edge_nodup)]\n    rfl\n  \n  have h_out : (E(P) \\ M).encard = (l.filter (· ∉ M)).length := by\n    rw [← List.filter_not_mem_eq_diff_toFinset_of_nodup _ h.isTrail.edge_nodup]\n    rw [encard_eq_coe_toFinset_card, List.toFinset_card_of_nodup (List.Nodup.filter _ h.isTrail.edge_nodup)]\n    rfl\n    \n  rw [h_in, h_out, h_count]\n  generalize k : (l.filter (· ∈ M)).length = n\n  -- M - n + (n + 1) = M + 1 in ENat\n  rw [add_assoc, ENat.sub_add_cancel_of_le]\n  rw [← k, ← h_in]\n  exact encard_inter_le_left _ _",
      "\n  let l := P.edge\n  have h_nodup : l.Nodup := h.toIsPath.edge_nodup\n  have h_chain : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n\n  -- Helper lemma: An alternating list starting and ending with edges not in M\n  -- has one more edge not in M than edges in M.\n  let rec count_diff (L : List β) (chain : L.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M))\n      (head_nm : L.head? = some e → e ∉ M) (last_nm : L.getLast? = some e → e ∉ M) :\n      (L.filter (· ∉ M)).length = (L.filter (· ∈ M)).length + 1 := by\n    match L with\n    | [] =>\n      -- An empty list cannot satisfy the conditions if called from a valid context where 0 ≠ 1\n      -- However, here we just need to prove the equality. 0 = 1 is false.\n      -- This case is unreachable for valid AugPaths.\n      -- We'll handle l ≠ [] in the main body or assume non-empty P.\n      simp\n      contradiction\n    | [e] =>\n      simp at head_nm ⊢\n      have : e ∉ M := head_nm rfl\n      simp [this]\n    | e1 :: e2 :: es =>\n      simp at head_nm ⊢\n      have he1 : e1 ∉ M := head_nm rfl\n      rw [List.isChain_cons] at chain\n      have he2 : e2 ∈ M := chain.1.mp he1\n      have chain_es := (List.isChain_cons.mp chain.2).2\n      \n      match es with\n      | [] =>\n        -- e1 :: e2 :: []. Last is e2. last_nm says e2 ∉ M. Contradiction.\n        simp at last_nm\n        have : e2 ∉ M := last_nm rfl\n        contradiction\n      | e3 :: es' =>\n        -- Recurse on e3 :: es'\n        rw [count_diff (e3 :: es') chain_es]\n        · simp [he1, he2]\n          ac_rfl\n        · intro h\n          -- Chain property: e2 ∉ M ↔ e3 ∈ M. Since e2 ∈ M, e3 ∉ M.\n          simp [Option.mem_def] at h\n          rw [h, List.head_cons]\n          have rel := (List.isChain_cons.mp chain.2).1\n          simp [he2] at rel\n          exact rel\n        · intro h\n          apply last_nm\n          rw [List.getLast?_cons_cons]\n          exact h\n\n  -- Apply the helper lemma\n  have h_len : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    -- We assume l is not empty because P is an augmenting path (non-trivial).\n    -- If l were empty, P would be a single vertex, and M.encard = M.encard + 1 would fail.\n    obtain ⟨u, rfl⟩ | hne := P.exists_eq_nil_or_nonempty\n    · have := h.nonempty; contradiction -- Assuming P.Nonempty implies edges or similar\n    \n    refine count_diff l h_chain (fun he => ?_) (fun he => ?_)\n    · have := P.head_mem_edge_head (List.ne_nil_of_mem (Option.mem_def.mp he))\n      rw [←Option.mem_def, he] at this\n      exact h.first_not_in (mem_V_of_mem_E (by assumption) this)\n    · have := P.last_mem_edge_last (List.ne_nil_of_mem (Option.mem_def.mp he))\n      rw [←Option.mem_def, he] at this\n      exact h.last_not_in (mem_V_of_mem_E (by assumption) this)\n\n  rw [encard_symmDiff_eq_encard_add_encard_sub_encard_inter M P.edgeFinite]\n  rw [encard_diff_eq_coe_toFinset_card P.edgeFinite, encard_inter_eq_coe_toFinset_card P.edgeFinite]\n  simp only [h_nodup.filter.toFinset_card]\n  norm_cast\n  exact h_len",
      "\n  let l := P.edge\n  have hl_nodup : l.Nodup := h.toIsPath.isTrail.edge_nodup\n  \n  have hl_ne : l ≠ [] := by\n    intro he\n    have hn := h.nonempty\n    rw [WList.edge_eq_nil_iff] at he\n    simp [he] at hn \n    contradiction\n\n  have h_count : l.countP (· ∉ M) = l.countP (· ∈ M) + 1 := by\n    have h_chain : l.Chain' (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n    have h_head : l.head hl_ne ∉ M := by\n      intro hm\n      have hf := h.first_not_in\n      exact hf ⟨_, hm, P.edge_head_incident hl_ne⟩\n    have h_last : l.getLast hl_ne ∉ M := by\n      intro hm\n      have hl := h.last_not_in\n      exact hl ⟨_, hm, P.edge_last_incident hl_ne⟩\n    \n    suffices ∀ n l, l.length = n → l ≠ [] → l.Chain' (fun e f ↦ e ∉ M ↔ f ∈ M) →\n        l.head (by simp_all) ∉ M → l.getLast (by simp_all) ∉ M →\n        l.countP (· ∉ M) = l.countP (· ∈ M) + 1 by\n      exact this l.length l rfl hl_ne h_chain h_head h_last\n    \n    intro n\n    induction n using Nat.strong_induction_on with\n    | h n IH =>\n      intro l hlen hne hchain hhead hlast\n      match l with\n      | [] => contradiction\n      | [e] => simp at hhead ⊢; exact hhead\n      | e :: f :: rest =>\n        simp at hhead hlen\n        rw [List.chain'_cons] at hchain\n        have hf : f ∈ M := by simpa [hhead] using hchain.1\n        have hrest_ne : rest ≠ [] := by\n          intro hr; subst hr; simp at hlast; exact hlast hf\n        have hrest_len : rest.length < n := by simp [hlen]; apply Nat.lt_add_of_pos_right; decide\n        specialize IH rest.length hrest_len rest rfl hrest_ne hchain.2 \n          (by \n            rw [List.chain'_cons] at hchain\n            have hc2 := hchain.2\n            rw [List.chain'_cons] at hc2\n            simp [hf] at hc2\n            exact hc2.1\n          ) hlast\n        simp [hhead, hf, IH]\n\n  rw [symmDiff_def, Set.encard_union_eq disjoint_sdiff_sdiff]\n  rw [← encard_diff_add_encard_inter M E(P)]\n  rw [add_assoc, add_comm (encard _), add_assoc]\n  congr 1\n  rw [← P.edgeSet_eq_mem_edge]\n  rw [encard_diff_eq_countP_of_nodup hl_nodup, encard_inter_eq_countP_of_nodup hl_nodup]\n  norm_cast\n  exact h_count",
      "\n  have h_chain := h.mem_matching_iff'\n  have h_head : ∀ e, e ∈ P.edge.head? → e ∉ M := fun e he ↦ h.first_not_in (WList.head_mem_vertex_edge he)\n  have h_last : ∀ e, e ∈ P.edge.getLast? → e ∉ M := fun e he ↦ h.last_not_in (WList.last_mem_vertex_edge he)\n  \n  let L := P.edge\n  suffices h_len : (L.filter (· ∉ M)).length = (L.filter (· ∈ M)).length + 1 by\n    rw [Set.encard_symmDiff_eq_encard_diff_add_encard_diff_inter P.edgeFinite M]\n    rw [← WList.edge_eq_edgeSet]\n    have h_nodup := h.toIsPath.isTrail.edge_nodup\n    rw [encard_eq_coe_toFinset_card, encard_eq_coe_toFinset_card]\n    rw [List.toFinset_diff, List.toFinset_inter]\n    rw [List.card_toFinset_of_nodup (h_nodup.filter _), List.card_toFinset_of_nodup (h_nodup.filter _)]\n    rw [List.length_filter_iff.mpr (p:=fun x=>x∈M) (by intro _ h; simp at h; exact h.2)]\n    rw [List.length_filter_iff.mpr (p:=fun x=>x∉M) (by intro _ h; simp at h; exact h.2)]\n    rw [h_len, Nat.cast_add, Nat.cast_one, add_assoc, add_comm 1, ← add_assoc]\n    convert encard_diff_add_encard_inter (P.edgeFinite.subset (inter_subset_right _ _)) using 2\n    ext; simp; tauto\n\n  induction L generalizing h_chain h_head h_last with\n  | nil => cases P <;> simp at h; exact h.nonempty\n  | cons e es ih =>\n    have he : e ∉ M := h_head e rfl\n    simp only [List.filter_cons, if_pos he, if_neg he, List.length_cons]\n    cases es with\n    | nil => simp\n    | cons f fs =>\n      rw [add_right_cancel_iff]\n      have hf : f ∈ M := h_chain.rel_head (by simp) |>.mp he\n      simp only [List.filter_cons, if_pos hf, if_neg hf, List.length_cons]\n      apply ih\n      · exact h_chain.tail.tail\n      · intro x hx; rw [List.head?_cons] at hx; subst x\n        cases fs with\n        | nil => specialize h_last f (by simp); contradiction\n        | cons g gs => \n           have := h_chain.tail.rel_head (by simp)\n           rw [hf] at this; exact this.mpr rfl\n      · exact h_last",
      "\n  let l := P.edge\n  let S := P.edgeSet\n  have hS_fin : S.Finite := P.edgeFinite\n  have h_nd : l.Nodup := h.isPath.edge_nodup\n\n  -- Cardinality of edges in/out of M within P\n  let kin := (l.filter (· ∈ M)).length\n  let kout := (l.filter (· ∉ M)).length\n\n  have h_count : kout = kin + 1 := by\n    have hc : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n    -- P starts and ends with vertices not in V(M), so first/last edges are not in M\n    have h_head : ∀ e, l.head? = some e → e ∉ M := by\n      intro e he\n      by_contra heM\n      have : P.first ∈ V(G, M) := by\n        -- e is incident to P.first, and e ∈ M\n        exact ⟨e, heM, WList.mem_V_head?_edge he⟩\n      exact h.first_not_in this\n    have h_last : ∀ e, l.getLast? = some e → e ∉ M := by\n      intro e he\n      by_contra heM\n      have : P.last ∈ V(G, M) := by\n        exact ⟨e, heM, WList.mem_V_getLast?_edge he⟩\n      exact h.last_not_in this\n\n    -- Induction on the alternating chain\n    suffices ∀ l, l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) →\n        (∀ e, l.head? = some e → e ∉ M) → (∀ e, l.getLast? = some e → e ∉ M) →\n        (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 from this l hc h_head h_last\n    \n    intro L hchain hstart hend\n    induction L with\n    | nil =>\n      -- An AugPath cannot be empty of edges because it connects disjoint non-V(M) vertices\n      -- but usually implies length ≥ 1. If l is empty, we have 0 = 1, contradiction.\n      -- Based on IsAugPath definition, P.Nonempty implies edges or endpoints condition ensures l ≠ []\n      -- For this lemma to hold, l cannot be nil.\n      simp at hstart\n      cases h.nonempty.exists_edge with\n      | inl _ => simp at h_nd; contradiction -- P is nil but edges exist? No, handling if P=nil\n      | inr ⟨_, _, _, _⟩ => contradiction -- P has edges, so L ≠ nil\n    | cons e es ih =>\n      cases es with\n      | nil => simp\n      | cons f fs =>\n        simp only [List.filter_cons, List.length_cons]\n        have he : e ∉ M := hstart e rfl\n        have hf : f ∈ M := (hchain e f (List.chain_cons.mp hchain).1).mp he\n        rw [if_pos he, if_pos hf]\n        congr 1\n        refine ih (List.chain_cons.mp (List.chain_cons.mp hchain).2) ?_ hend\n        intro g hg\n        -- es = f :: fs. fs starts with g.\n        -- f ∈ M. Chain f g implies g ∉ M.\n        rw [List.head?_eq_head] at hg <;> [skip; simp]\n        subst hg\n        exact (List.chain_cons.mp (List.chain_cons.mp hchain).2).1.mpr hf\n\n  -- Convert list lengths to set cardinalities\n  have h_kin : (S ∩ M).encard = kin := by\n    rw [encard_eq_coe_toFinset_card]\n    have : (S ∩ M).toFinset = (l.filter (· ∈ M)).toFinset := by\n      ext; simp [S, List.mem_filter]\n    rw [this, List.toFinset_card_of_nodup]\n    exact h_nd.filter _\n\n  have h_kout : (S \\ M).encard = kout := by\n    rw [encard_eq_coe_toFinset_card]\n    have : (S \\ M).toFinset = (l.filter (· ∉ M)).toFinset := by\n      ext; simp [S, List.mem_filter]\n    rw [this, List.toFinset_card_of_nodup]\n    exact h_nd.filter _\n\n  -- Calculation\n  rw [Set.symmDiff_def, Set.encard_union_eq_add_encard_disjoint (Set.disjoint_sdiff_sdiff)]\n  rw [h_kout, h_count, Nat.cast_add, Nat.cast_one, add_assoc, add_comm kin, ← h_kin]\n  rw [Set.diff_eq, Set.inter_comm, ← Set.diff_eq]\n  -- M = (M \\ (S ∩ M)) ∪ (S ∩ M)\n  have hsub : S ∩ M ⊆ M := Set.inter_subset_right _ _\n  have hfin : (S ∩ M).Finite := hS_fin.subset (Set.inter_subset_left _ _)\n  rw [← Set.encard_diff_add_encard_of_subset hsub hfin]\n  rfl",
      "\n  let l := P.edge\n  have hnd : l.Nodup := h.toIsPath.isTrail.edge_nodup\n  have h_alt : l.Chain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n\n  have h_ne : l ≠ [] := by\n    intro he; rw [WList.edge_eq_nil_iff] at he\n    obtain ⟨v, rfl⟩ := he; exact h.nonempty.ne_nil rfl\n\n  have h_first : ∀ e, e ∈ l.head? → e ∉ M := by\n    intro e he; rw [WList.edge_head?_eq_some_iff] at he\n    obtain ⟨v, rfl⟩ := he; exact fun hmem ↦ h.first_not_in ⟨_, hmem, rfl⟩\n\n  have h_last : ∀ e, e ∈ l.last? → e ∉ M := by\n    intro e he; rw [WList.edge_last?_eq_some_iff] at he\n    obtain ⟨v, rfl⟩ := he; exact fun hmem ↦ h.last_not_in ⟨_, hmem, rfl⟩\n\n  have h_cnt : l.countP (· ∉ M) = l.countP (· ∈ M) + 1 := by\n    induction l with\n    | nil => contradiction\n    | cons e es ih =>\n      cases es with\n      | nil => simp [h_first _ rfl]\n      | cons f fs =>\n        rw [List.countP_cons, List.countP_cons]\n        have he : e ∉ M := h_first _ rfl\n        have hf : f ∈ M := (List.chain_cons.mp h_alt).1.mp he\n        simp only [if_pos he, if_pos hf, if_neg (not_mem_of_mem_left hf (fun h ↦ h)), if_neg (fun h ↦ h he)]\n        rw [ih (List.chain_cons.mp (List.chain_cons.mp h_alt).2) ?_ h_last, add_assoc, add_assoc]\n        intro g hg\n        rw [List.head?_cons] at hg; injection hg with hg; subst hg\n        exact (List.chain_cons.mp (List.chain_cons.mp h_alt).2).1.mp hf\n\n  rw [Set.symmDiff_def, encard_union_eq_add_encard (Set.disjoint_sdiff_sdiff)]\n  \n  have h_card_diff : (E(P) \\ M).encard = l.countP (· ∉ M) := by\n    rw [← P.edge_toSet, encard_diff_eq_countP_not_mem hnd]\n  \n  have h_card_inter : (E(P) ∩ M).encard = l.countP (· ∈ M) := by\n     rw [← P.edge_toSet, encard_inter_eq_countP_mem hnd]\n  \n  rw [h_card_diff, h_cnt, ← h_card_inter, ← add_assoc, encard_diff_add_encard_inter]",
      "\n  have h_fin : E(P).Finite := P.edgeFinite\n  have h_nodup : P.edge.Nodup := h.toIsPath.edge_nodup\n  rw [symmDiff_def, Set.encard_union_eq disjoint_sdiff_sdiff]\n  nth_rw 2 [← union_inter_sdiff_eq_self M E(P)]\n  rw [Set.encard_union_eq disjoint_sdiff_inter, add_assoc, add_comm 1, ← add_assoc]\n  congr 1\n  rw [encard_diff_eq_toFinset_card h_fin, encard_inter_eq_toFinset_card h_fin]\n  rw [← List.toFinset_filter_of_nodup h_nodup, ← List.toFinset_filter_of_nodup h_nodup]\n  simp only [Finset.card_mk]\n  let l := P.edge\n  change (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1\n  \n  have h_ne : l ≠ [] := by\n    intro he\n    have := h.nonempty\n    cases P with\n    | nil v => simp at he; exact this.ne_nil rfl\n    | cons u e P' => simp at he\n  \n  have h_chain : l.IsChain (fun e f ↦ (e ∈ M) ↔ f ∉ M) := h.mem_matching_iff'\n  \n  have h_ends : (∀ e, l.head? = some e → e ∉ M) ∧ (∀ e, l.getLast? = some e → e ∉ M) := by\n    constructor\n    · intro e he\n      cases P with\n      | nil => simp at he\n      | cons u f P' =>\n        simp only [WList.edge_cons, List.head?_cons, Option.some.injEq] at he\n        subst he\n        intro hmem\n        have : u ∈ V(G, f) := by simp\n        exact h.first_not_in (mem_V_of_mem_edge hmem this)\n    · intro e he\n      intro hmem\n      have : P.last ∈ V(G, e) := P.mem_last_edge_of_getLast?_eq he\n      exact h.last_not_in (mem_V_of_mem_edge hmem this)\n\n  revert h_chain h_ends h_ne\n  generalize heq : P.edge = l\n  induction l with\n  | nil => intro; contradiction\n  | cons e es ih =>\n    intro h_chain h_ends _\n    have he_not_mem : e ∉ M := h_ends.1 _ rfl\n    cases es with\n    | nil => simp [he_not_mem]\n    | cons f fs =>\n      simp only [List.filter_cons, List.length_cons]\n      rw [if_pos he_not_mem]\n      have hf_mem : f ∈ M := by\n        have := (List.chain_cons.1 h_chain).1\n        rwa [he_not_mem, false_iff, not_not] at this\n      rw [if_pos hf_mem, add_assoc]\n      congr 1\n      apply ih\n      · exact (List.chain_cons.1 (List.chain_cons.1 h_chain).2).2\n      · constructor\n        · intro g hg; simp at hg; subst hg\n          have := (List.chain_cons.1 h_chain).2 f (List.mem_cons_self _ _)\n          rwa [hf_mem, true_iff] at this\n        · intro g hg; apply h_ends.2; rw [List.getLast?_cons_cons]; exact hg\n      · simp",
      "\n  have h_chain : P.edge.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n  have h_nodup : P.edge.Nodup := h.toIsPath.isTrail.edge_nodup\n  \n  obtain ⟨u, e, P', rfl⟩ | h_nil := P.exists_cons_of_nonempty h.nonempty\n  · have h_start : e ∉ M := by\n      rw [isAugPath_iff, isAltPath_iff, cons_isPath_iff] at h\n      exact h.first_not_in <| hM.subset_vertex_set (by assumption) h.1.1.1.2.2\n    \n    have h_end : (P.edge.getLast (by simp [WList.edge])) ∉ M := by\n      rw [isAugPath_iff] at h\n      exact fun he ↦ h.last_not_in (hM.subset_vertex_set he (h.1.toIsPath.isWalk.mem_getLast_edge_last _))\n\n    have h_len : (P.edge.filter (· ∉ M)).length = (P.edge.filter (· ∈ M)).length + 1 := by\n      let l := P.edge\n      let p := fun x ↦ x ∉ M\n      have : l.IsChain (fun a b ↦ p a ↔ ¬p b) := h_chain\n      have h1 : p (l.head (by simp [l, WList.edge])) := h_start\n      have h2 : p (l.getLast (by simp [l, WList.edge])) := h_end\n      clear value l\n      induction l with\n      | nil => contradiction\n      | cons x xs ih =>\n        simp only [List.filter_cons]\n        split_ifs with hx\n        · match xs with\n          | [] => simp\n          | y :: ys =>\n            simp only [List.isChain_cons_cons] at this\n            have hy : ¬ p y := this.1.mp hx\n            rw [List.filter_cons, if_neg hy]\n            rw [add_assoc, ih this.2 (by rwa [← this.1] at hy) h2]\n        · exact (hx h1).elim\n\n    rw [encard_union_eq_add_encard_of_disjoint disjoint_sdiff_sdiff,\n      encard_diff_add_encard_inter M E(P), add_assoc, add_left_cancel_iff]\n    rw [← encard_coe_toFinset (Finite.diff P.edgeFinite M), \n      ← encard_coe_toFinset (Finite.inter_of_left P.edgeFinite M)]\n    norm_cast\n    rw [List.toFinset_inter_of_nodup _ h_nodup, List.toFinset_diff_of_nodup _ h_nodup]\n    rw [List.card_toFinset_of_nodup (List.Nodup.filter _ h_nodup)]\n    rw [List.card_toFinset_of_nodup (List.Nodup.filter _ h_nodup)]\n    exact h_len\n  · contradiction",
      "\n  have h_nd : P.edge.Nodup := h.toIsPath.isTrail.edge_nodup\n  have h_alt : P.edge.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n  have h_head : ∀ e, e ∈ P.edge.head? → e ∉ M := by\n    intro e he\n    refine h.first_not_in ?_\n    cases P with\n    | nil => simp at he\n    | cons u f P' => simp at he; subst he; exact ⟨_, rfl⟩\n  have h_last : ∀ e, e ∈ P.edge.getLast? → e ∉ M := by\n    intro e he\n    refine h.last_not_in ?_\n    obtain ⟨v, hv⟩ := h.toIsPath.last_mem_edge_getLast_of_nonempty h.nonempty he\n    exact ⟨_, hv⟩\n\n  let l := P.edge\n  have h_cnt : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    have hne : l ≠ [] := by simpa using h.nonempty\n    generalize hlen : l.length = n\n    revert l\n    induction n using Nat.strong_induction_on with\n    | h n ih =>\n      intro l hlen hne hchain hhead hlast\n      match l with\n      | [] => contradiction\n      | [e] =>\n        simp only [List.filter_cons, List.filter_nil, List.length_singleton, List.length_nil]\n        rw [if_pos (hhead _ (List.mem_head?_of_mem (List.mem_singleton_self _)))]\n        rw [if_neg (hhead _ (List.mem_head?_of_mem (List.mem_singleton_self _)))]\n      | e :: f :: fs =>\n        simp only [List.length_cons] at hlen\n        rw [List.isChain_cons] at hchain\n        have he : e ∉ M := hhead _ (List.head_mem_head? hne)\n        have hf : f ∈ M := hchain.1.2 he\n        have hfs_ne : fs ≠ [] := by\n          intro h; subst h; simp at hlast\n          exact hlast _ (List.getLast_mem_getLast? (by simp)) hf\n        specialize ih fs.length (by rw [hlen]; apply Nat.lt_trans (Nat.lt_succ_self _) (Nat.lt_succ_self _)) \n          fs rfl hfs_ne (by rw [List.isChain_cons] at hchain; exact hchain.2)\n          (fun x hx => by \n             rw [List.head?_eq_head hfs_ne] at hx; simp at hx; subst hx\n             rw [List.isChain_cons] at hchain; exact hchain.1.2.2 hf) hlast\n        simp [he, hf]\n        rw [ih]\n        rfl\n\n  rw [Set.symmDiff_def, encard_union disjoint_sdiff_sdiff, \n      encard_diff_add_encard_inter M E(P), add_assoc, add_comm 1, ← add_assoc]\n  congr 1\n  rw [add_comm]\n  have hfin : E(P).Finite := P.edgeFinite\n  rw [encard_eq_coe_toFinset_card (hfin.diff _), encard_eq_coe_toFinset_card (hfin.inter _)]\n  norm_cast\n  trans (P.edge.filter (· ∉ M)).length\n  · rw [← List.toFinset_card_of_nodup (List.Nodup.filter _ h_nd)]\n    congr; ext; simp [WList.edgeSet]\n  trans (P.edge.filter (· ∈ M)).length + 1\n  · rw [h_cnt]\n  · congr 1\n    rw [← List.toFinset_card_of_nodup (List.Nodup.filter _ h_nd)]\n    congr; ext; simp [WList.edgeSet]",
      "\n  have h_fin : (M ∩ E(P)).encard < ⊤ := (P.edgeFinite.inter_of_left M).encard_lt_top\n  rw [symmDiff_def, encard_union (disjoint_sdiff_sdiff),\n    encard_diff_finite_inter P.edgeFinite, encard_diff_finite_inter P.edgeFinite]\n  rw [← ENat.coe_add, add_comm, ← add_assoc, ENat.add_sub_cancel_right h_fin, add_comm, ENat.coe_inj]\n  \n  let l := P.edge\n  have h_nd : l.Nodup := h.toIsPath.edge_nodup\n  \n  -- Reduce set cardinalities to list lengths\n  trans (l.filter (· ∉ M)).length\n  · rw [encard_eq_coe_toFinset_card, ← List.toFinset_filter_of_nodup h_nd, List.card_toFinset_of_nodup (h_nd.filter _)]\n    congr; ext; simp\n  rw [eq_comm, encard_eq_coe_toFinset_card, ← List.toFinset_filter_of_nodup h_nd, List.card_toFinset_of_nodup (h_nd.filter _)]\n  · congr; ext; simp\n  \n  -- Prove the counting property by induction on the alternating list\n  have h_chain : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n  have h_start : ∀ e ∈ l.head?, e ∉ M := by\n    intro e he\n    cases P with\n    | nil => simp at he\n    | cons u f Q =>\n      simp at he; subst he; intro hf\n      exact h.first_not_in ⟨f, hf, rfl⟩\n  \n  -- We perform induction on the list `l`. \n  -- We don't explicitly prove the `last` condition beforehand, but deriving it or contradiction during induction.\n  induction l using List.induction_with_singleton with\n  | nil =>\n    -- P is trivial, but IsAugPath implies P.Nonempty (edges).\n    -- If P.edge is empty, P.Nonempty must contradict it.\n    simp at h_start -- vacuous\n    cases P <;> simp [WList.edge_nil] at *\n    case nil => simp [WList.Nonempty] at h; contradiction\n    case cons => contradiction\n    case concat => contradiction\n  | singleton e =>\n    simp only [List.filter_cons, List.filter_nil, List.length_singleton, List.length_nil]\n    specialize h_start e rfl\n    simp [h_start]\n  | cons_cons e f es ih =>\n    simp only [List.isChain_cons_cons] at h_chain\n    specialize h_start e rfl\n    have he : e ∉ M := h_start\n    have hf : f ∈ M := h_chain.1.mp he\n    have h_es_start : ∀ x ∈ es.head?, x ∉ M := by\n      intro x hx\n      rw [iff_not_comm] at h_chain\n      exact h_chain.2.rel_head? hx |>.mpr hf\n    rw [List.filter_cons, List.filter_cons, if_pos he, if_neg (not_mem_of_mem_matching hM hf)]\n    rw [ih h_chain.2 h_es_start]\n    simp",
