      "\n  let l := P.edge\n  have hnodup : l.Nodup := h.toIsPath.edge_nodup\n  have halt : l.IsChain (fun e f ↦ e ∉ M ↔ f ∈ M) := h.mem_matching_iff'\n\n  have h_props : l ≠ [] ∧ (∀ e, e ∈ l.head? → e ∉ M) ∧ (∀ e, e ∈ l.getLast? → e ∉ M) := by\n    have h_last : ∀ e, e ∈ l.getLast? → e ∉ M := by\n      intro e he\n      have hinc : P.last ∈ V(G, e) := by\n         induction P with\n         | nil => simp [WList.edge] at he\n         | cons u f w ih =>\n           simp [WList.edge] at he\n           cases w with\n           | nil v => simp at he; subst he; exact ⟨u, by left; rfl⟩\n           | cons x g w' => apply ih; simp [WList.edge]; exact he\n      have : P.last ∉ V(G, M) := h.last_not_in\n      intro hM\n      apply this\n      exact ⟨e, hM, hinc⟩\n\n    have h_head : ∀ e, e ∈ l.head? → e ∉ M := by\n      intro e he\n      cases P with\n      | nil => simp [WList.edge] at he\n      | cons u f w =>\n        simp [WList.edge] at he; subst he\n        intro hM\n        apply h.first_not_in\n        exact ⟨f, hM, by left; rfl⟩\n\n    have hne : l ≠ [] := by\n      cases P with\n      | nil => exact (h.nonempty.ne_nil rfl).elim\n      | cons => simp [WList.edge]\n\n    exact ⟨hne, h_head, h_last⟩\n\n  obtain ⟨hne, hhead, hlast⟩ := h_props\n\n  have h_count : (l.filter (· ∉ M)).length = (l.filter (· ∈ M)).length + 1 := by\n    obtain ⟨fst, hfst⟩ := List.head?_eq_some.2 hne\n    obtain ⟨lst, hlst⟩ := List.getLast?_eq_some.2 hne\n    specialize hhead fst hfst\n    specialize hlast lst hlst\n\n    induction l generalizing fst lst with\n    | nil => contradiction\n    | cons a as ih =>\n      cases as with\n      | nil =>\n        simp at hfst hlst; subst hfst hlst\n        simp [hhead]\n      | cons b bs =>\n        simp at hfst; subst hfst\n        rw [List.chain_cons] at halt\n        obtain ⟨hab, hchain⟩ := halt\n        have hb : b ∈ M := hab.1 hhead\n        simp [hhead, hb]\n\n        cases bs with\n        | nil =>\n          simp at hlast; subst hlast\n         