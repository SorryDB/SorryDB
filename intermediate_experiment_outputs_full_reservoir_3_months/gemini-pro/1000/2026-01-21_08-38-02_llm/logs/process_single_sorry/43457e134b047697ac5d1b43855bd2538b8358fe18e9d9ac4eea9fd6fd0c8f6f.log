theorem PumpingLemma :
  ∀ language : ContextFreeLanguage, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
    intro language
    -- Lemma for the case where ε is not in the language (requires CNF and Tree Analysis)
    have h_lemma_no_eps : ∀ L : ContextFreeLanguage, ε ∉ L.val → ∃ n : ℕ,
      ∀ z : Word α, z ∈ L.val ∧ z.len ≥ n →
      ∃ u v w x y : Word α, z = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
      ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ L.val) := by
      intro L h_eps
      -- The proof for epsilon-free languages relies on CNF and the Pigeonhole Principle on derivation trees.
      -- This requires significant setup with the provided but unproven lemmas.
      sorry

    by_cases h_eps : ε ∈ language.val
    case neg =>
      obtain ⟨n, hn⟩ := h_lemma_no_eps language h_eps
      use n
      intro z
      apply hn z.val ⟨z.property.1, z.property.2⟩
    case pos =>
      -- Case ε ∈ L. We consider L' = L \ {ε}, which is also Context-Free.
      have h_diff_exists : ∃ L' : ContextFreeLanguage, ∀ w, w ∈ L'.val ↔ w ∈ language.val ∧ w ≠ ε := by sorry
      obtain ⟨L', h_L'⟩ := h_diff_exists
      
      have h_not_eps_L' : ε ∉ L'.val := by
        intro h
        rw [h_L'] at h
        exact h.2 rfl

      obtain ⟨n', hn'⟩ := h_lemma_no_eps L' h_not_eps_L'
      use (max n' 1)
      intro z
      
      have h_z_not_eps : z.val ≠ ε := by
        intro h
        have h_len := z.property.2
        rw [h] at h_len
        simp at h_len
        have : 1 ≤ 0 := Nat.le_trans (le_max_right n' 1) h_len
        contradiction
        
      have h_z_in_L' : z.val ∈ L'.val := by
        rw [h_L']
        exact ⟨z.property.1, h_z_not_eps⟩
        
      obtain ⟨u, v, w, x, y, h_decomp⟩ := hn' z.val ⟨h_z_in_L', Nat.le_trans (le_max_left n' 1) z.property.2⟩
      use u, v, w, x, y
      refine ⟨h_decomp.1, h_decomp.2.1, h_decomp.2.2.1, ?_⟩
      intro k
      have hk := h_decomp.2.2.2 k
      rw [h_L'] at hk
      exact hk.1
