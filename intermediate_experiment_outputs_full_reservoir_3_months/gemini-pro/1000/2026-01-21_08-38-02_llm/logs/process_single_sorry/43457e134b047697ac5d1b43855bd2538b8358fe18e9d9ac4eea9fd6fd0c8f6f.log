  ∀ language : ContextFreeLanguage, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
    intro language
    by_cases h_eps : ε ∈ language.1
    case pos =>
      --Ignoriere den Fall ε ∈ L
      sorry
    case neg =>
      obtain ⟨nt, G, hL⟩ := language.property
      have h_eps_G : ε ∉ G.GeneratedLanguage := by
        intro h
        apply h_eps
        rw [← hL]
        exact (coerceLang_mem G.GeneratedLanguage).mp h
      obtain ⟨cnf, h_eq⟩ := equivalent_CNF_Grammar α nt nt ⟨G, h_eps_G⟩
      let n := 2 ^ cnf.val.V.card
      use n
      intro z
      have h_z_in : z.val ∈ coerceLang cnf.val.GeneratedLanguage := by
        rw [← h_eq, hL]
        exact z.property.1
      obtain ⟨w, hw_in, hw_coe⟩ := coerceCFGLang_mem_imp_word_of_type z.val cnf.val h_z_in
      have h_len : w.len ≥ n := by
        rw [← hw_coe] at z
        simp [coerceWord, Word.len] at z
        exact z.property.2
      -- The decomposition follows from the properties of CNF derivations of sufficient length
      -- Formalizing the tree splitting requires additional lemmas not present in the context
      have exists_pump : ∃ u v x y w_mid, z.val = u * v * w_mid * x * y ∧ (v * x).len ≥ 1 ∧ (v * w_mid * x).len ≤ n ∧ ∀ k, u * (v^k) * w_mid * (x^k) * y ∈ language.val := sorry
      exact exists_pump
