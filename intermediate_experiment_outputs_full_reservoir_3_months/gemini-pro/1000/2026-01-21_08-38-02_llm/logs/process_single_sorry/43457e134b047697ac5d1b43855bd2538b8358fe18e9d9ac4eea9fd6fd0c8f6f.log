theorem PumpingLemma :
  ∀ language : ContextFreeLanguage, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
    intro ⟨L, hL⟩
    -- The Pumping Lemma constant n is derived from the Chomsky Normal Form of L \ {ε}.
    -- We assume the existence of a CNF grammar for L \ {ε} since L is Context-Free.
    have exists_cnf : ∃ (nt' : Type) (G : ContextFreeGrammarCNF α nt'),
      coerceLang G.val.GeneratedLanguage = {w | w ∈ L ∧ w ≠ ε} := by sorry
    obtain ⟨nt', G, hG⟩ := exists_cnf
    -- Set pumping length n = 2^|V|
    let n := 2 ^ G.val.V.card
    use n
    intro ⟨z, hzL, hzlen⟩
    dsimp at hzL hzlen
    -- Since |z| ≥ n ≥ 1, z is not empty, so z is generated by the CNF grammar.
    have hz_neq_eps : z ≠ ε := by
      intro h; subst h; rw [Word.eps_len_0] at hzlen
      have : n ≥ 1 := Nat.one_le_pow _ _ (by simp)
      exact Nat.not_le_of_gt (Nat.lt_of_succ_le this) hzlen
    have hz_G : z ∈ coerceLang G.val.GeneratedLanguage := by
      rw [hG]; exact ⟨hzL, hz_neq_eps⟩
    -- Standard pumping argument on the CNF derivation tree of z.
    have pump : ∃ u v w x y, z = u * v * w * x * y ∧ (v * x).len ≥ 1 ∧ (v * w * x).len ≤ n ∧ ∀ k, u * v^k * w * x^k * y ∈ L := by
