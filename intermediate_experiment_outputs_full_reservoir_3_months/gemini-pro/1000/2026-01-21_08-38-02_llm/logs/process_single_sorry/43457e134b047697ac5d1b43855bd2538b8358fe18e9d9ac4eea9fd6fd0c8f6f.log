theorem PumpingLemma :
  ∀ language : ContextFreeLanguage, ∃ n : ℕ,
  ∀ z : {z ∈ language.val | z.len ≥ n},
  ∃ u v w x y : Word α, z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ n
  ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := by
    intro language
    by_cases h_eps : ε ∈ language.val
    case pos =>
      --Ignoriere den Fall ε ∈ L
      sorry
    case neg =>
      obtain ⟨nt, G, hG⟩ := language.2
      have h_no_eps : ε ∉ G.GeneratedLanguage := by
        rw [←hG] at h_eps
        intro h
        apply h_eps
        apply coerceLang_mem h
      obtain ⟨G_CNF, h_equiv⟩ := equivalent_CNF_Grammar α nt Unit ⟨G, h_no_eps⟩
      let n := 2 ^ G_CNF.val.V.card
      use n
      intro z
      obtain ⟨z_val, hz_in, hz_len⟩ := z
      have hz_in_CNF : z_val ∈ coerceLang G_CNF.val.GeneratedLanguage := by
        rw [←h_equiv, hG]
        exact hz_in
      obtain ⟨w, hw_in, hw_eq⟩ := coerceCFGLang_mem_imp_word_of_type z_val G_CNF.val hz_in_CNF
      have hw_len : w.len ≥ n := by
        rw [←hw_eq] at hz_len
        simp [coerceWord, Word.len] at hz_len ⊢
        exact hz_len
      -- The existence of such a derivation and the pumping properties follow from
      -- the Pigeonhole Principle on the derivation tree in CNF (which has height related to n),
      -- but the detailed reconstruction of u, v, w, x, y from the derivation lemmas is omitted here.
      sorry
