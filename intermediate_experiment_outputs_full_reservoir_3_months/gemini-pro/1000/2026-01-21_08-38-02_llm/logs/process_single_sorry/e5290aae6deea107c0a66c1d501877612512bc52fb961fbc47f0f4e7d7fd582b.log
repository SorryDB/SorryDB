example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  simp [Function.comp]
  induction sl using dropWhileSL.induct p with
  | case1 sl h_empty =>
    rw [dropWhileSL, if_pos h_empty]
    simp [fromSL, nil]
    obtain ⟨lhs, rhs, ok⟩ := sl
    simp [SymList.isEmpty] at h_empty
    simp [h_empty.1, h_empty.2]
  | case2 sl h_ne h_none =>
    rw [dropWhileSL, if_neg h_ne, h_none]
    simp
    rw [headSL_none_iff_nilSL] at h_none
    subst h_none
    simp [fromSL, nil]
  | case3 sl h_ne x h_some hp ih =>
    rw [dropWhileSL, if_neg h_ne, h_some]
    simp [hp]
    rw [← ih]
    have h_tail : fromSL (tailSL sl) = (fromSL sl).tail := by
      obtain ⟨lhs, rhs, ok⟩ := sl
      unfold tailSL
      simp
      by_cases h_lhs : lhs.isEmpty
      . simp [h_lhs, nil, fromSL]
        simp [SymList.isEmpty] at h_ne
        simp [h_lhs] at h_ne
        simp at ok; have := ok.1 h_lhs
        rcases this with _ | hlen; contradiction
        rw [List.length_eq_one] at hlen; rcases hlen with ⟨b, hb⟩; subst hb
        simp
      . simp [h_lhs]
        by_cases h_len : lhs.length = 1
        . simp [h_len]
          rcases List.length_eq_one.mp h_len with ⟨a, ha⟩; subst ha
          simp [fromSL, splitInTwoSL, List.MergeSort.Internal.splitInTwo]
          exact List.take_append_drop _ _
        . simp [h_len]
          simp [fromSL]
          match lhs with | [] => contradiction | [a] => contradiction | a::b::bs => simp
    rw [h_tail]
    have h_head : (fromSL sl).head? = some x := by
       obtain ⟨lhs, rhs, ok⟩ := sl
       unfold headSL at h_some
       split at h_some <;> simp at h_some
       . contradiction
       . rename_i ys; subst h_some
         simp [fromSL]
         simp at ok; have := ok.1 rfl
         rcases this with _ | h; contradiction
         rw [List.length_eq_one] at h; rcases h with ⟨_, h⟩; rw [h]; simp
       . rename_i a as; subst h_some; simp [fromSL]
    match h_fr : fromSL sl with
    | [] => rw [h_fr] at h_head; contradiction
    | y :: ys => rw [h_fr] at h_head; simp at h_head; subst h_head; simp [List.dropWhile, hp]
  | case4 sl h_ne x h_some hnp =>
    rw [dropWhileSL, if_neg h_ne, h_some]
    simp [hnp]
    have h_head : (fromSL sl).head? = some x := by
       obtain ⟨lhs, rhs, ok⟩ := sl
       unfold headSL at h_some
       split at h_some <;> simp at h_some
       . contradiction
       . rename_i ys; subst h_some
         simp [fromSL]
         simp at ok; have := ok.1 rfl
         rcases this with _ | h; contradiction
         rw [List.length_eq_one] at h; rcases h with ⟨_, h⟩; rw [h]; simp
       . rename_i a as; subst h_some; simp [fromSL]
    match h_fr : fromSL sl with
    | [] => rw [h_fr] at h_head; contradiction
    | y :: ys => rw [h_fr] at h_head; simp at h_head; subst h_head; simp [List.dropWhile, hnp]
