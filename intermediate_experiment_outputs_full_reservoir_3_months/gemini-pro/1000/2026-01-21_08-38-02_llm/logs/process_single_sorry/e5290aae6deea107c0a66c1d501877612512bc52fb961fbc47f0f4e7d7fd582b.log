      "\n  induction sl using dropWhileSL.induct p with\n  | case1 sl h_empty =>\n    simp [dropWhileSL, h_empty, sl_empty_l_empty sl (by simp [isEmpty, h_empty]), fromSL, nil, Chapter1.dropWhile]\n  | case2 sl h_ne h_none =>\n    rw [dropWhileSL]; simp [h_ne, h_none]\n    rw [headSL_none_iff_nilSL] at h_none; subst h_none\n    simp [fromSL, nil, Chapter1.dropWhile]\n  | case3 sl h_ne hsl h_some hp ih =>\n    rw [dropWhileSL]; simp [h_ne, h_some, hp, ← ih]\n    have : fromSL sl = hsl :: fromSL (tailSL sl) := by\n      obtain ⟨lhs, rhs, ok⟩ := sl\n      unfold fromSL headSL tailSL at *\n      cases lhs with\n      | nil =>\n        cases rhs with | nil => contradiction | cons y ys =>\n        simp at h_some; subst h_some; simp\n        simp at ok; have : ys = [] := by cases ok <;> simp_all\n        subst this\n        simp [splitInTwoSL, List.MergeSort.Internal.splitInTwo, List.take_append_drop]\n      | cons x xs =>\n        simp at h_some; subst h_some; simp\n        cases xs with | nil => simp [splitInTwoSL, List.MergeSort.Internal.splitInTwo, List.take_append_drop] | cons x' xs' => simp\n    rw [this]; simp [Chapter1.dropWhile, hp]\n  | case4 sl h_ne hsl h_some hnp =>\n    rw [dropWhileSL]; simp [h_ne, h_some, hnp]\n    obtain ⟨lhs, rhs, ok⟩ := sl\n    unfold fromSL headSL at *\n    cases lhs with\n    | nil =>\n      cases rhs with | nil => contradiction | cons y ys =>\n      simp at h_some; subst h_some\n      simp at ok; have : ys = [] := by cases ok <;> simp_all\n      subst this; simp [Chapter1.dropWhile, hnp]\n    | cons x xs =>\n      simp at h_some; subst h_some\n      simp [Chapter1.dropWhile, hnp]",
      "\n  | case3 sl h_head h_p ih =>\n    simp [dropWhileSL, h_head, h_p, ←ih]\n    have h_tail : fromSL (tailSL sl) = (fromSL sl).tail := by\n      cases sl; rename_i l r ok; simp [tailSL]\n      split_ifs <;> simp [fromSL, splitInTwoSL, *]\n    have : (fromSL sl).head? = headSL sl := by\n      cases sl; rename_i l r ok\n      cases l <;> simp [fromSL, headSL]\n      cases r <;> simp [headSL] at h_head ⊢\n      simp [h_head]\n    cases hf : fromSL sl <;> simp [hf] at this\n    · rw [this] at h_head; contradiction\n    · rw [this] at h_head; injection h_head with heq; subst heq\n      simp [dropWhile, h_p, ←h_tail, hf]",
      "\n  induction sl using dropWhileSL.induct p with\n  | case1 sl h_empty =>\n    simp [dropWhileSL, h_empty, fromSL]\n    have : sl.lhs = [] ∧ sl.rhs = [] := by simp [List.isEmpty_iff] at h_empty; exact h_empty\n    have ⟨l, r⟩ := this\n    rw [l, r]; simp\n  | case2 sl h_not_empty h_none =>\n    rw [dropWhileSL]; simp [h_not_empty, h_none]\n    have : sl = nil := headSL_none_iff_nilSL.mp h_none\n    subst this\n    simp [fromSL, nil]\n  | case3 sl h_not_empty hsl h_some h_p ih =>\n    rw [dropWhileSL]; simp [h_not_empty, h_some, h_p, ih.symm]\n    have h_head : (fromSL sl).head? = some hsl := by\n      cases sl with | mk lhs rhs ok =>\n      unfold headSL at h_some; unfold fromSL\n      cases lhs with\n      | nil =>\n         simp at h_some\n         simp [List.isEmpty_iff] at h_not_empty\n         simp at ok\n         cases rhs with | nil => simp at h_not_empty | cons r rs =>\n           cases rs with | nil => simp at h_some; subst h_some; simp | cons _ _ => simp at ok\n      | cons l ls => simp at h_some; subst h_some; simp\n    have h_tail : fromSL (tailSL sl) = (fromSL sl).tail := by\n      cases sl with | mk lhs rhs ok =>\n      unfold tailSL fromSL; simp\n      split\n      . rename_i h_l; simp [nil]; rw [List.isEmpty_iff] at h_l; subst h_l; simp at ok\n        cases rhs with | nil => simp | cons r rs =>\n          cases rs with | nil => simp | cons _ _ => simp at ok\n      . rename_i h_l\n        split\n        . induction rhs generalizing lhs <;> simp [splitInTwoSL, fromSL]\n        . simp [List.tail_append]; cases lhs <;> simp_all\n    match h : fromSL sl with\n    | [] => rw [h] at h_head; contradiction\n    | x :: xs =>\n      rw [h] at h_head h_tail; simp at h_head h_tail; subst x\n      rw [dropWhile, h_tail, h_p]\n  | case4 sl h_not_empty hsl h_some h_p =>\n    rw [dropWhileSL]; simp [h_not_empty, h_some, h_p]\n    have h_head : (fromSL sl).head? = some hsl := by\n      cases sl with | mk lhs rhs ok =>\n      unfold headSL at h_some; unfold fromSL\n      cases lhs with\n      | nil =>\n         simp at h_some\n         simp [List.isEmpty_iff] at h_not_empty\n         simp at ok\n         cases rhs with | nil => simp at h_not_empty | cons r rs =>\n           cases rs with | nil => simp at h_some; subst h_some; simp | cons _ _ => simp at ok\n      | cons l ls => simp at h_some; subst h_some; simp\n    match h : fromSL sl with\n    | [] => rw [h] at h_head; contradiction\n    | x :: xs =>\n      rw [h] at h_head; simp at h_head; subst x\n      rw [dropWhile, h_p]",
      "\n  have head_eq (sl : SymList a) : headSL sl = (fromSL sl).head? := by\n    cases sl with | mk lhs rhs ok =>\n    cases lhs\n    · cases rhs\n      · rfl\n      · simp [headSL, fromSL]\n        simp at ok; cases ok <;> simp_all\n    · simp [headSL, fromSL]\n\n  have tail_eq (sl : SymList a) : fromSL (tailSL sl) = (fromSL sl).tail := by\n    have ⟨xs, ys, ok⟩ := sl\n    cases xs with\n    | nil =>\n      induction ys with\n      | nil => simp [tailSL, fromSL, nil]\n      | cons b bs ih =>\n        simp [fromSL, tailSL, nil]\n        simp at ok; have h := ok.1 rfl; simp at h\n        cases h <;> simp_all\n    | cons a as =>\n      induction ys with\n      | nil =>\n        by_cases h : as = [] <;> simp [h, fromSL, tailSL, splitInTwoSL]\n      | cons b bs ih =>\n        by_cases h: as = []\n        · simp [h, fromSL, tailSL, splitInTwoSL]\n        · simp [tailSL, h, fromSL]\n\n  induction sl using dropWhileSL.induct p with\n  | case1 sl h_empty =>\n    simp [dropWhileSL, h_empty]\n    rcases sl with ⟨lhs, rhs, ok⟩\n    simp at h_empty; simp [h_empty.1, h_empty.2, fromSL, nil, dropWhile]\n  | case2 sl h_ne h_none =>\n    simp [dropWhileSL, h_ne, h_none]\n    rw [headSL_none_iff_nilSL] at h_none\n    subst h_none\n    simp [fromSL, nil, dropWhile]\n  | case3 sl h_ne h_some hsl h_p ih =>\n    simp [dropWhileSL, h_ne, h_some, h_p]\n    rw [ih, tail_eq, head_eq]\n    rw [head_eq] at h_some\n    cases h : fromSL sl with\n    | nil => simp at h_some\n    | cons x xs =>\n      simp at h_some; subst h_some\n      simp [dropWhile, h_p]\n  | case4 sl h_ne h_some hsl h_np =>\n    simp [dropWhileSL, h_ne, h_some, h_np]\n    rw [head_eq] at h_some\n    cases h : fromSL sl with\n    | nil => simp at h_some\n    | cons x xs =>\n      simp at h_some; subst h_some\n      simp [dropWhile, h_np]",
      "\n    have h_hd : (fromSL sl).head? = some x := by\n      have ⟨lhs, rhs, ok⟩ := sl\n      unfold headSL fromSL at h_head ⊢\n      split at h_head <;> simp_all\n      . simp [List.head?_append]; split <;> simp_all\n      . simp [List.head?_append]; split <;> simp_all\n    cases h : fromSL sl with\n    | nil => simp at h_hd\n    | cons y ys =>\n      simp at h_hd; subst x\n      simp [dropWhile, h_np]",
      "\n           | cons b bs ih =>\n             by_cases h: as = []\n             . simp [h, List.tail, fromSL] at ih\n               simp [h, fromSL, tailSL]\n               simp [splitInTwoSL]\n             . simp [tailSL, h, fromSL]\n      rw [hks] at tail_eq\n      simp at tail_eq\n      exact tail_eq",
      "\n  induction sl using dropWhileSL.induct p with\n  | case1 sl h_empty =>\n    simp [dropWhileSL, h_empty, fromSL, nil]\n    simp [SymList.isEmpty] at h_empty\n    rw [h_empty.1, h_empty.2]\n    rfl\n  | case2 sl h_not_empty h_none =>\n    rw [dropWhileSL, if_neg h_not_empty, h_none]\n    simp [nil, fromSL]\n    rw [headSL_none_iff_nilSL] at h_none\n    rw [h_none, fromSL, nil]\n    rfl\n  | case3 sl h_not_empty hsl h_some h_p ih =>\n    rw [dropWhileSL, if_neg h_not_empty, h_some, if_pos h_p]\n    rw [ih]\n    have cons_eq : fromSL sl = hsl :: fromSL (tailSL sl) := by\n      cases sl with | mk l r ok =>\n      unfold fromSL headSL tailSL at *\n      split at h_some <;> simp_all\n      . rename_i h1 h2; simp [h1, h2]; contradiction\n      . rename_i h1 y ys h2; rw [h1]; simp\n        simp [h1] at ok; cases ok; rename_i o1 o2\n        have : r.length = 1 := by cases o1 rfl <;> simp_all\n        have : ys = [] := by have := List.length_cons y ys; rw[←h2] at this; rw[this] at *; simp at *; omega\n        subst ys; simp [fromSL, nil]\n      . rename_i x xs h1; rw [h1]; simp\n        split\n        . contradiction\n        . split\n          . rename_i hlen; simp at hlen; subst xs; simp\n            simp [splitInTwoSL, fromSL]\n            generalize h : r.reverse = L\n            simp [List.MergeSort.Internal.splitInTwo]\n            rw [List.take_append_drop]\n          . simp [fromSL]\n    rw [cons_eq]\n    unfold dropWhile\n    simp [h_p]\n  | case4 sl h_not_empty hsl h_some h_not_p =>\n    rw [dropWhileSL, if_neg h_not_empty, h_some, if_neg h_not_p]\n    have head_eq : (fromSL sl).head? = some hsl := by\n      cases sl with | mk l r ok =>\n      unfold fromSL headSL at *\n      split at h_some <;> simp_all\n      . rename_i h1 h2; rw[h1, h2]; simp\n      . rename_i h1 y ys h2; rw[h1]; simp;\n        simp[h1] at ok; cases ok; rename_i o1 o2;\n        have : r.length = 1 := by cases o1 rfl <;> simp_all\n        have : ys = [] := by have := List.length_cons y ys; rw[←h2] at this; rw[this] at *; simp at *; omega\n        subst ys; simp\n      . rename_i x xs h1; rw[h1]; simp\n    match h : fromSL sl with\n    | [] =>\n      rw [←List.head?_eq_none_iff, head_eq] at h\n      contradiction\n    | x :: xs =>\n      rw [List.head?_cons] at head_eq\n      injection head_eq with hx\n      subst hx\n      unfold dropWhile\n      simp [h_not_p]",
      "\n    have h_head_eq : (fromSL sl).head? = some x := by\n      have ⟨l, r, ok⟩ := sl\n      unfold headSL at hx\n      unfold fromSL\n      split at hx <;> simp_all\n      · rw [hx]; simp\n      · rw [hx]; simp\n    match h_sl : fromSL sl with\n    | [] => simp at h_head_eq\n    | y :: ys =>\n      simp at h_head_eq; subst x\n      simp [dropWhile, hp]",
      "\n  have tail_comm : ∀ s, fromSL (tailSL s) = (fromSL s).tail := by\n    intro s\n    have ⟨l, r, ok⟩ := s\n    unfold tailSL\n    simp\n    split_ifs with h1 h2\n    · subst l\n      simp [fromSL]\n      cases r with | nil => simp | cons y ys => simp [fromSL, nil]\n    · simp [fromSL]\n      rcases l with _|⟨a, as⟩ <;> simp at h2 ⊢\n      cases as <;> simp at h2\n      simp\n      generalize hL : r.reverse = L\n      unfold splitInTwoSL fromSL\n      simp\n      show (List.MergeSort.Internal.splitInTwo ⟨L, rfl⟩).1.val ++\n           (List.MergeSort.Internal.splitInTwo ⟨L, rfl⟩).2.val.reverse.reverse = L\n      simp\n      exact List.take_append_drop _ L\n    · simp [fromSL]\n      cases l <;> simp\n  have head_comm : ∀ s x, headSL s = some x → (fromSL s).head? = some x := by\n    intro s x h\n    unfold headSL at h\n    split at h <;> simp at h\n    · contradiction\n    · rename_i l r ok _ _ _\n      subst x\n      simp [fromSL]\n      cases l <;> simp at *\n      simp at ok\n      cases ok.1 rfl with | inl h => simp [h] | inr h =>\n        cases r with | nil => contradiction | cons y ys =>\n          cases ys <;> simp at h ⊢\n    · rename_i l r ok _ _\n      subst x\n      simp [fromSL]\n      cases l <;> simp at *\n  induction sl using dropWhileSL.induct p with\n  | case1 sl h_empty =>\n    rw [dropWhileSL]\n    simp [h_empty]\n    cases sl with | mk l r ok =>\n    simp at h_empty\n    cases h_empty with | intro h1 h2 =>\n    subst l; simp at h2; subst r\n    simp [fromSL, dropWhile, nil]\n  | case2 sl h_ne h_none =>\n    rw [dropWhileSL]\n    simp [h_ne, h_none]\n    rw [headSL_none_iff_nilSL] at h_none\n    subst sl\n    simp [fromSL, dropWhile, nil]\n  | case3 sl h_ne hsl h_some hp ih =>\n    rw [dropWhileSL]\n    simp [h_ne, h_some, hp]\n    rw [ih]\n    have heq := head_comm sl hsl h_some\n    cases hL : fromSL sl with\n    | nil => simp [hL] at heq\n    | cons x xs =>\n      simp [hL] at heq\n      subst x\n      conv => lhs; simp [dropWhile, hp]\n      rw [tail_comm, hL]\n      rfl\n  | case4 sl h_ne hsl h_some hnp =>\n    rw [dropWhileSL]\n    simp [h_ne, h_some, hnp]\n    have heq := head_comm sl hsl h_some\n    cases hL : fromSL sl with\n    | nil => simp [hL] at heq\n    | cons x xs =>\n      simp [hL] at heq\n      subst x\n      conv => lhs; simp [dropWhile, hnp]\n      rw [hL]",
      "\n  induction sl using dropWhileSL.induct p with\n  | case1 sl h_empty =>\n    simp [dropWhileSL, h_empty]\n    have : sl = nil := by\n      cases sl; simp [nil] at *; exact h_empty\n    subst this\n    simp [fromSL]\n  | case2 sl h_ne h_none =>\n    simp [dropWhileSL, h_ne, h_none]\n    rw [headSL_none_iff_nilSL] at h_none\n    subst h_none\n    simp [fromSL, nil]\n  | case3 sl hsl h_ne h_head h_p ih =>\n    simp [dropWhileSL, h_ne, h_head, h_p]\n    rw [←ih]\n    have h_head_eq : (fromSL sl).head? = some hsl := by\n      cases sl; simp [headSL, fromSL] at h_head ⊢\n      split at h_head <;> simp_all\n    have h_tail_eq : fromSL (tailSL sl) = (fromSL sl).tail := by\n      cases sl with | mk xs ys ok =>\n      dsimp [tailSL]\n      split_ifs with h1 h2\n      · simp [fromSL]; simp at h1; subst h1\n        have := ok.1 rfl; cases this <;> simp_all\n      · simp [fromSL, splitInTwoSL]\n        rw [List.reverse_reverse, List.take_append_drop]\n      · cases xs <;> simp [fromSL] at *\n    match h_l : fromSL sl with\n    | [] => rw [h_l] at h_head_eq; contradiction\n    | x :: xs =>\n      rw [h_l] at h_head_eq; simp at h_head_eq; subst x\n      rw [dropWhile, h_tail_eq, h_l]\n      simp [h_p]\n  | case4 sl hsl h_ne h_head h_p =>\n    simp [dropWhileSL, h_ne, h_head, h_p]\n    have h_head_eq : (fromSL sl).head? = some hsl := by\n      cases sl; simp [headSL, fromSL] at h_head ⊢\n      split at h_head <;> simp_all\n    match h_l : fromSL sl with\n    | [] => rw [h_l] at h_head_eq; contradiction\n    | x :: xs =>\n      rw [h_l] at h_head_eq; simp at h_head_eq; subst x\n      rw [dropWhile]\n      simp [h_p]",
      "\n  induction sl using dropWhileSL.induct p with\n  | case1 sl h_empty =>\n    simp [dropWhileSL, h_empty, fromSL, dropWhile]\n    have ⟨_, _, _⟩ := sl; simp at h_empty; simp [h_empty.1, h_empty.2]\n  | case2 sl h_ne h_none =>\n    rw [headSL_none_iff_nilSL] at h_none; subst h_none\n    simp [dropWhileSL, nil, fromSL]\n  | case3 sl h_ne hsl h_some h_p ih =>\n    rw [dropWhileSL, h_some]; simp [h_ne, h_p]; rw [←ih]\n    have h_head : (fromSL sl).head? = some hsl := by\n      have ⟨xs, ys, ok⟩ := sl\n      simp [headSL, fromSL] at h_some ⊢\n      cases xs <;> simp_all; cases ys <;> simp_all\n    have h_tail : fromSL (tailSL sl) = (fromSL sl).tail := by\n      have ⟨xs, ys, ok⟩ := sl\n      cases xs <;> simp [tailSL, fromSL]\n      · cases ys <;> simp\n        simp at ok; cases ok.1 <;> simp_all\n      · rename_i x xs'; cases xs' <;> simp [splitInTwoSL]\n    rw [h_tail]\n    cases h_sl : fromSL sl <;> simp_all [dropWhile, h_p]\n  | case4 sl h_ne hsl h_some h_np =>\n    rw [dropWhileSL, h_some]; simp [h_ne, h_np]\n    have : (fromSL sl).head? = some hsl := by\n      have ⟨xs, ys, ok⟩ := sl\n      simp [headSL, fromSL] at h_some ⊢\n      cases xs <;> simp_all; cases ys <;> simp_all\n    cases h_sl : fromSL sl <;> simp_all [dropWhile, h_np]",
      "\n    cases sl; simp [fromSL] at *; simp_all\n  | case2 sl h =>\n    simp [dropWhileSL, h]\n    rw [headSL_none_iff_nilSL] at h; subst h\n    simp [fromSL, dropWhile]\n  | case3 sl x h px ih =>\n    simp [dropWhileSL, h, px]\n    rw [←ih]\n    have : fromSL sl = x :: (fromSL sl).tail := by\n      cases sl; unfold headSL fromSL at *\n      split at h <;> simp_all <;> subst h <;> simp\n    rw [this]; simp [dropWhile, px]\n    congr 1\n    cases sl with | mk lhs rhs ok =>\n    simp [tailSL, fromSL]\n    split\n    · simp [nil]; cases rhs <;> simp; rename_i _ ys; cases ys <;> simp at ok ⊢\n    · simp\n      split\n      · simp [splitInTwoSL, List.MergeSort.Internal.splitInTwo]\n      · rfl\n  | case4 sl x h npx =>\n    simp [dropWhileSL, h, npx]\n    have : fromSL sl = x :: (fromSL sl).tail := by\n      cases sl; unfold headSL fromSL at *\n      split at h <;> simp_all <;> subst h <;> simp\n    rw [this]; simp [dropWhile, npx]",
      "\n  | case4 sl h_not hsl h_some hnp =>\n    rw [dropWhileSL, h_some]; simp [h_not, hnp]\n    have : (fromSL sl).head? = some hsl := by\n      cases sl; unfold headSL at h_some; unfold fromSL\n      split at h_some <;> simp_all\n    match h: fromSL sl with\n    | [] => rw [h] at *; contradiction\n    | y::ys => simp at *; subst y; simp [dropWhile, hnp]",
      "\n      cases lhs <;> simp_all\n    · simp [fromSL]; cases lhs <;> simp_all",
