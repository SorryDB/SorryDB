example (p : a → Bool)
  : dropWhile p ∘ fromSL = fromSL ∘ dropWhileSL p := by
  funext sl
  simp [Function.comp]

  have fromSL_split (L : List a) : fromSL (splitInTwoSL L) = L := by
    simp [fromSL, splitInTwoSL]
    rw [List.MergeSort.Internal.splitInTwo]
    simp
    exact List.take_append_drop _ _

  have tail_eq (sl : SymList a) : fromSL (tailSL sl) = (fromSL sl).tail := by
    have ⟨lhs, rhs, ok⟩ := sl
    simp [tailSL]
    split_ifs with h_empty h_len1
    · subst h_empty
      simp [fromSL, nil]
      simp at ok
      cases rhs <;> simp [fromSL]
    · rw [fromSL_split]
      cases lhs
      · simp at h_len1
      · cases lhs
        · simp [fromSL]
        · simp at h_len1
    · cases lhs
      · contradiction
      · cases lhs
        · contradiction
        · simp [fromSL]

  have head_eq (sl : SymList a) : (fromSL sl).head? = headSL sl := by
    have ⟨lhs, rhs, _⟩ := sl
    simp [fromSL, headSL]
    cases lhs <;> cases rhs <;> simp

  induction sl using SymList.dropWhileSL.induct p with
  | case1 sl h =>
    simp [SymList.dropWhileSL, h]
    have ⟨h1, h2⟩ := h
    have ⟨lhs, rhs, _⟩ := sl
    simp [fromSL, h1, h2, dropWhile]
    rfl
  | case2 sl h_ne h_none =>
    rw [SymList.dropWhileSL]
    simp [h_ne, h_none]
    rw [SymList.headSL_none_iff_nilSL] at h_none
    subst h_none
    rfl
  | case3 sl h_ne h_some h_np =>
    rw [SymList.dropWhileSL]
    simp [h_ne, h_some, h_np]
    rw [←head_eq] at h_some
    cases hf : fromSL sl with
