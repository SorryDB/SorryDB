    have : (List.foldl (· * ·) 1 nums) ∈ (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1) := 
      List.mem_map_of_mem _ this
    rw [← p_perm.mem_iff] at this
    rw [h] at this; contradiction

