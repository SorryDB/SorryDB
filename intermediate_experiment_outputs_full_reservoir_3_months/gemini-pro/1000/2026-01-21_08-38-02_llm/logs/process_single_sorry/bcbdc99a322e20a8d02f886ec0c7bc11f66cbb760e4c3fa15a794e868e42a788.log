      · apply List.Perm.trans _ (List.Perm.map_congr_left (fun _ _ => rfl) ih)
        apply List.Perm.of_eq; apply List.map_congr_left; intro x _; dsimp
        rw [Nat.mul_comm, Nat.mul_add_div (by decide), Nat.mul_add_mod _ _ (by decide)]
        rw [List.range_succ_eq_map, List.foldr_cons, List.foldr_map]
        simp only [Nat.mod_self, Nat.one_mod, Nat.one_and_one_eq_one, ↓reduceIte, Nat.add_zero, List.cons.injEq, true_and]
