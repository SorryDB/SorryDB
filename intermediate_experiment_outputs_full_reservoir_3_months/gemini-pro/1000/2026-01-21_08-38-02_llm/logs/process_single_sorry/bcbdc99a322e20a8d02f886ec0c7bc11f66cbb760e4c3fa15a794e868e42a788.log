```lean
theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  dsimp [maxStrength, maxStrength_postcond, maxStrength_precond]
  let gen (l : List ℤ) (mask : ℕ) := (List.range l.length).foldr (fun i acc =>
      if (mask >>> i) &&& 1 == 1 then l[i]! :: acc else acc) []
  
  -- Correctness of bitmask generation: gen l mask generates subsequences
  have h_perm : ∀ l, ((List.range (2 ^ l.length)).map (gen l)).Perm l.sublists := by
    intro l
    induction l with
    | nil => simp [gen]
    | cons x xs ih =>
      simp only [List.sublists, List.length_cons, pow_succ, mul_two]
      -- Split range(2*m) into evens (2*k) and odds (2*k+1)
      let m := 2 ^ xs.length
      have h_split : (List.range (2 * m)).Perm ((List.range m).map (2 * ·) ++ (List.range m).map (2 * · + 1)) := by
        rw [List.range_mul_eq_bind]
        refine List.Perm.trans (List.bind_perm_map_bind _ _ _) (List.Perm.of_eq ?_)
        simp [List.bind_map, Function.comp, List.range_succ]
      refine (List.Perm.map (gen (x :: xs)) h_split).trans ?_
      simp only [List.map_append, List.map_map]
      rw [← ih]
      apply List.Perm.append
      · apply List.Perm.of_eq; apply List.map_congr_left; intro k _; dsimp [gen]
        -- Even mask (2*k): bit 0 is 0, bits 1..n are k
        simp [Nat.shiftRight_eq_div_pow, Nat.mul_div_right, Nat.mul_mod_right]
        congr; ext i; simp [Nat.shiftRight_succ, Nat.mul_div_right, Nat.succ_pos']
      · apply List.Perm.of_eq; apply List.map_congr_left; intro k _; dsimp [gen]
        -- Odd mask (2*k+1): bit 0 is 1, bits 1..n are k
        simp [Nat.shiftRight_eq_div_pow, Nat.mul_div_right, Nat.mul_add_mod]
        congr 1; · congr; ext i; simp [Nat.shiftRight_succ, Nat.mul_div_right, Nat.mul_add_div, Nat.succ_pos']

  -- Establish permutation of products
  let P_impl := (List.range (2 ^ nums.length)).map (gen nums) |>.filter (· ≠ []) |>.map (List.foldl (· * ·) 1)
  let P_spec := nums.sublists.filter (· ≠ []) |>.map (List.foldl (· * ·) 1)
  have h_prod_perm : P_impl.Perm P_spec := 
    List.Perm.map _ (List.Perm.filter _ (h_perm nums) _)

  -- Handle max? result
  let res := (P_impl.max?).getD (-1000000)
  have h_nonempty : P_impl ≠ [] := by
    rw [List.perm_iff_size_eq.mp h_prod_perm] -- Same size as P_spec
    -- nums is not empty => sublists contains [x] => P_spec not empty
    cases nums with | nil => contradiction | cons x xs => simp
  
  have h_mem : res ∈ P_impl ∧ ∀ x ∈ P_impl, x ≤ res := by
    match h : P_impl.max? with
    | some m => 
      simp [h] at *
      exact ⟨List.mem_of_max? h, List.le_max_of_max? h⟩
    | none => contradiction

  -- Conclude postcondition
  rw [List.perm_ext h_prod_perm] at h_mem
  exact h_mem
