    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  dsimp [maxStrength, maxStrength_postcond, maxStrength_precond]
  generalize hps : (fun (l : List Int) =>
    let n := l.length
    let masks := List.range (2^n)
    masks.map fun mask =>
      (List.range n).foldr (fun i acc =>
        if (mask.shiftRight i).land 1 == 1 then l[i]! :: acc else acc
      ) []) = powerSet
  have h_perm : ∀ l, (powerSet l).Perm l.sublists := by
    intro l
    induction l with
    | nil => rw [hps]; simp [List.sublists]
    | cons x xs ih =>
      rw [hps] at *
      simp only [List.length_cons, List.sublists_cons, Nat.pow_succ, Nat.mul_comm _ 2]
      let n := xs.length
      have range_split : (List.range (2^n * 2)).Perm
          ((List.range (2^n)).map (2 * ·) ++ (List.range (2^n)).map (2 * · + 1)) := by
        induction 2^n with | zero => simp | succ k hk =>
          simp_all [Nat.mul_succ, List.range_succ, List.range_add, List.Perm.append_left, List.Perm.swap]
      refine (List.Perm.map _ range_split).trans ?_
      rw [List.map_append]
      apply List.Perm.append
      · convert ih using 1; apply List.map_congr_left; intro m _; dsimp
        rw [List.range_succ_eq_map, List.foldr_cons, List.foldr_map]
        simp only [Nat.shiftRight_zero, Nat.land_one, Nat.mul_mod_right, if_false, List.get!_cons_zero, List.get!_cons_succ]
        congr; funext i acc; congr 2; simp [Nat.shiftRight_eq_div_pow, Nat.pow_succ, Nat.mul_div_mul_left _ _ (by decide)]
      · convert List.Perm.refl _ using 1; rw [List.map_map]; apply List.map_congr_left; intro m _; dsimp
        rw [List.range_succ_eq_map, List.foldr_cons, List.foldr_map]
        simp only [Nat.shiftRight_zero, Nat.land_one, Nat.mul_add_mod', Nat.mul_mod_right, zero_add, if_true, List.get!_cons_zero, List.get!_cons_succ]
        congr; funext i acc; congr 2; simp [Nat.shiftRight_eq_div_pow, Nat.pow_succ]
        rw [Nat.add_div_eq_of_add_mod_lt] <;> simp [Nat.mul_div_mul_left _ _ (by decide)]

  let products := ((powerSet nums).filter (· ≠ [])).map (List.foldl (· * ·) 1)
  let spec_products := (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1)
  have p_perm : products.Perm spec_products :=
    List.Perm.map _ (List.Perm.filter _ (h_perm nums))

  have h_ne : products ≠ [] := by
    cases nums with | nil => contradiction | cons x xs =>
      rw [p_perm.nil_eq]
      simp [spec_products]; use [x]
      simp [List.sublists_cons]

  rw [List.max?_eq_of_perm p_perm]
  cases h : spec_products.max? with
  | none => simp at h; exfalso; exact h_ne (by rw [p_perm.nil_eq]; exact h)
  | some m => simp; rw [List.max?_eq_some_iff] at h; exact h
