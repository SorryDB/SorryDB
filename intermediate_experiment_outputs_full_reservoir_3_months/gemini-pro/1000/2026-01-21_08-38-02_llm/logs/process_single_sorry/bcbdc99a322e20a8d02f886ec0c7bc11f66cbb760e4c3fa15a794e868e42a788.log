      simp only [powerSet, List.length_cons, List.sublists_cons]
      let n := xs.length
      have h_range : (List.range (2^n)).flatMap (fun k => [2*k, 2*k+1]) = List.range (2^(n+1)) := by
        rw [pow_add, pow_one, mul_comm]
        induction n with
