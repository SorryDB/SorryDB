theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- !benchmark @start proof
  -- Define the function used in maxStrength to reason about it
  let powerSet := fun (l : List Int) =>
    let n := l.length
    let masks := List.range (2^n)
    masks.map fun mask =>
      (List.range n).foldr (fun i acc =>
        if (mask.shiftRight i).land 1 == 1 then l[i]! :: acc else acc
      ) []
  
  -- Prove that powerSet generates exactly the sublists (up to permutation)
  have h_perm : ∀ l, (powerSet l).Perm l.sublists := by
    intro l
    induction l with
    | nil => simp [powerSet, List.sublists]
    | cons x xs ih =>
      simp [List.sublists]
      rw [← ih]
      simp [powerSet]
      have range_split : ∀ n, (List.range (2*n)).Perm ((List.range n).map (2*·) ++ (List.range n).map (2*·+1)) := by
