              List.append_assoc]
          rfl
      rw [← h_range, List.map_flatMap]
      apply List.Perm.trans _ (List.Perm.flatMap_inter _ ih fun l1 l2 h => 
        List.Perm.append (List.Perm.of_eq h) (List.Perm.map _ h))
      simp only [List.flatMap_append, List.map_cons, List.map_nil, List.append_nil]
      apply List.Perm.of_eq
      congr; ext k
      rw [List.range_succ_eq_map, List.foldr_cons, List.foldr_map]
      simp only [Nat.shiftRight_zero, Nat.one_and_one_is_one, Function.comp_apply, List.get!_cons_self, 
        List.get!_cons_succ]
      congr 1
      · simp only [mul_comm 2, Nat.mul_mod_right, beq_self_eq_false, ite_false]
        congr; ext i acc
        simp [Nat.shiftRight_succ, mul_comm 2, Nat.mul_div_right]
      · simp only [Nat.mul_add_mod, Nat.mul_mod_right, Nat.mod_self, zero_add, Nat.mod_two_of_bodd, 
          Nat.bodd_succ, Nat.bodd_mul, Nat.bodd_two, Bool.and_false, Bool.xor_false, beq_self_eq_true, ite_true]
        congr; ext i acc
        simp [Nat.shiftRight_succ, mul_comm 2, Nat.mul_div_right]

  let subsets := powerSet nums
  let products := (subsets.filter (· ≠ [])).map (List.foldl (· * ·) (1 : Int))
  let result := (products.max?).getD (-1000000)
  
