theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  -- Define the logic of the implementation for reasoning
  let impl (l : List Int) := (List.range (2^l.length)).map fun mask =>
    (List.range l.length).foldr (fun i acc =>
      if (mask >>> i) &&& 1 == 1 then l[i]! :: acc else acc) []

  -- Prove that the implementation generates a permutation of all subsequences
  have h_perm (l : List Int) : impl l ~ l.sublists := by
    induction l with
    | nil => simp [impl]
    | cons x xs ih =>
      simp only [impl, List.length_cons, pow_succ, List.sublists_cons]
      let n := xs.length
      -- Split range(2*2^n) into evens (2*k) and odds (2*k+1)
      have split : (List.range (2*2^n)) ~ (List.range (2^n)).map (·*2) ++ (List.range (2^n)).map (·*2+1) := by
        refine List.Perm.of_nodup_of_forall_mem (List.nodup_range _) ?_ ?_
        · rw [List.nodup_append]; simp [List.nodup_map, List.nodup_range]; rintro _ _ h _ _; linarith
        · intro a; simp; constructor
          · intro h; rcases Nat.mod_two_eq_zero_or_one a with h2 | h2
            · left; use a/2; constructor; apply Nat.div_lt_of_lt_mul h; simp; rw [←Nat.div_add_mod a 2, h2]; simp
            · right; use a/2; constructor; apply Nat.div_lt_of_lt_mul h; simp; rw [←Nat.div_add_mod a 2, h2]; simp
          · rintro (⟨k, hk, rfl⟩ | ⟨k, hk, rfl⟩)
            · apply Nat.mul_lt_mul_of_pos_right hk; simp
            · linarith
      
      -- Map the folding function over the split range
      refine (List.Perm.map _ split).trans ?_
      rw [List.map_append]; apply List.Perm.append
      · -- Even masks: mask = 2*k => element x is excluded (bit 0 is 0)
        apply List.Perm.of_eq; apply List.map_congr_left; intro k _; 
        simp [List.range_succ_eq_map]; congr; funext i acc; congr 1; simp [Nat.mul_div_right]; rfl
      · -- Odd masks: mask = 2*k+1 => element x is included (bit 0 is 1)
        apply List.Perm.of_eq; apply List.map_congr_left; intro k _; 
        simp [List.range_succ_eq_map]; congr; funext i acc; congr 1; simp [Nat.add_div_right]; rfl

  -- Define products list as in the code
  let products (l : List Int) := (impl l).filter (· ≠ []) |>.map (List.foldl (· * ·) 1)
  -- Show it is a permutation of the spec's products
  have p_perm : products nums ~ (nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1) := 
    List.Perm.map _ (List.Perm.filter (h_perm nums) (by intros; rfl))

