  have : res_val = (products nums).max?.get! := by simp [res_val, Option.getD_eq_get!, h_ne]
  rw [this]
  
  -- Transfer max property to spec
  have max_eq : (products nums).max? = ((nums.sublists.filter (· ≠ [])).map (List.foldl (· * ·) 1)).max? := 
    p_perm.max?_eq
  
