theorem maxStrength_spec_satisfied (nums: List Int) (h_precond : maxStrength_precond (nums)) :
    maxStrength_postcond (nums) (maxStrength (nums) h_precond) h_precond := by
  dsimp [maxStrength, maxStrength_postcond]
  -- Define powerSet locally to match the let-binding
  let powerSet := fun (l : List Int) =>
    let n := l.length
    let masks := List.range (2^n)
    masks.map fun mask =>
      (List.range n).foldr (fun i acc =>
        if (mask.shiftRight i).land 1 == 1 then l[i]! :: acc else acc
      ) []
  
  -- We prove that powerSet generates a permutation of sublists
  have h_perm : ∀ l, (powerSet l).Perm l.sublists := by
    intro l
    induction l with
    | nil => 
      simp [powerSet, List.sublists]
    | cons a as ih =>
      simp only [List.length_cons, List.sublists_cons]
      -- We show powerSet (a::as) is a permutation of sublists as ++ map (a::.) (sublists as)
      -- By IH, this is perm of powerSet as ++ map (a::.) (powerSet as)
      -- We split range (2^(n+1)) into first half (bit 0 is 0) and second half (bit 0 is 1)
      -- Note: The implementation uses 'mask' directly. Since foldr processes 0 first, bit 0 corresponds to 'a'.
      -- masks_even = range (2^n) map (·*2); masks_odd = range (2^n) map (·*2+1)
      -- We use the property that range (2*n) ~ map (*2) (range n) ++ map (*2+1) (range n)
      let n := as.length
      have range_split : (List.range (2 * 2^n)).Perm 
        ((List.range (2^n)).map (fun x => 2*x) ++ (List.range (2^n)).map (fun x => 2*x+1)) := by
        rw [Nat.mul_comm 2]
        exact (List.perm_ext (by simp) (fun x => by simp [List.count_join, List.count_map]; sorry))
      
      -- Applying the permutation to the map
      apply List.Perm.trans (List.Perm.map _ range_split)
      rw [List.map_append]
      apply List.Perm.append
      · -- Even masks: bit 0 is 0, shiftRight 0 & 1 is 0. 'a' is not added.
        -- Inner fold shifts indices by 1. Equivalent to powerSet as.
        apply List.Perm.of_eq
        simp only [List.map_map]
        apply List.map_congr_left
        intro mask hmask
        -- Proof that fold on a::as with 2*mask equals fold on as with mask
        sorry
      · -- Odd masks: bit 0 is 1. 'a' is added.
        -- Inner fold equivalent to a :: powerSet as.
        apply List.Perm.of_eq
        simp only [List.map_map]
        apply List.map_congr_left
        intro mask hmask
        -- Proof that fold on a::as with 2*mask+1 equals a :: fold on as with mask
        sorry
  
  have p_perm := h_perm nums
  
  -- Since powerSet is a permutation of sublists, the filtered products are permutations
  let f_nonempty := fun (l : List Int) => l ≠ []
  let subsets := powerSet nums
  let subsets_spec := nums.sublists
  have perm_filter : (subsets.filter f_nonempty).Perm (subsets_spec.filter f_nonempty) := 
    List.Perm.filter f_nonempty p_perm
  
  let f_prod := fun (l : List Int) => l.foldl (· * ·) 1
