    rw [h, Option.getD_some]
    rwa [List.Perm.mem_iff h_perm_prods]
  · intro y hy
    simp [result]
    rw [← List.max?_eq_some_iff]
    apply List.le_max?_of_mem
    rwa [List.Perm.mem_iff h_perm_prods] at hy
