  let products := sublists.map (List.foldl (· * ·) 1)
  let code_subsets := (powerSet nums)
  let code_products := (code_subsets.filter (· ≠ [])).map (fun subset => List.foldl (fun acc x => acc * x) 1 subset)
  
  have h_prod_perm : code_products.Perm products := by
    apply List.Perm.map; apply List.Perm.filter; exact h_perm nums

  unfold maxStrength maxStrength_postcond
  dsimp
  -- Use the property that max of permutations is equal
  match h : List.max? code_products with
  | none => 
    have : code_products = [] := List.max?_eq_none_iff.mp h
    have : products = [] := List.Perm.nil_eq this ▸ h_prod_perm.symm
    -- Contradiction: nums is not empty, so products is not empty
    have : nums ≠ [] := h_precond
