         rw [Nat.mul_succ, List.range_succ, List.range_succ, List.map_append, List.map_append]; simp
         apply List.Perm.trans (List.Perm.swap _ _ _)
         apply List.Perm.cons; apply List.Perm.trans _ (List.Perm.swap _ _ _); apply List.Perm.cons; exact ih
      
      rw [show 2^(List.length xs + 1) = 2 * 2^List.length xs by ring]
      refine List.Perm.trans (List.Perm.map _ (range_split _)) ?_
      rw [List.map_append, List.Perm_append_comm]
      apply List.Perm.append
      . rw [List.map_map]; apply List.Perm.of_eq; apply List.map_congr_left; intro m hm
        dsimp
        have h_idx : ∀ i, i < xs.length → (2 * m >>> (i + 1)) = m >>> i := by
          intro i hi; simp [Nat.shiftRight_eq_div_pow]; rw [Nat.pow_succ, Nat.mul_comm 2, Nat.mul_div_mul_left _ _ (by decide)]
        rw [List.range_succ_eq_map, List.foldr_map]
        simp [List.foldr_range_cons, Nat.shiftRight_zero, Nat.mul_mod_right]; simp [h_idx]
        congr; ext i; congr
        rw [List.get!_cons_succ]
      . rw [List.map_map]; apply List.Perm.of_eq; apply List.map_congr_left; intro m hm
        dsimp
        have h_idx : ∀ i, i < xs.length → ((2 * m + 1) >>> (i + 1)) = m >>> i := by
          intro i hi; simp [Nat.shiftRight_eq_div_pow]; rw [Nat.pow_succ, Nat.mul_comm 2, Nat.add_div_right]; decide
        rw [List.range_succ_eq_map, List.foldr_map]
        simp [List.foldr_range_cons, Nat.shiftRight_zero, Nat.mul_add_mod]; simp [h_idx]
        congr; ext i; congr
        rw [List.get!_cons_succ]

