  -- Let y = p - 2n. Since n ≤ (p-1)/2, 2n < p, so y ≥ 1.
  let y := p - 2 * n
  have hy_pos : y > 0 := Nat.sub_pos_of_lt (Nat.mul_lt_of_lt_div (Nat.zero_lt_two) hn_bounds.2)
  
  -- The condition p ≤ 2n + √2n implies y ≤ √2n.
  have hy_le_sqrt : (y : ℝ) ≤ √(2 * n) := by
    rw [sub_eq_add_neg, ← sub_eq_add_neg] at h_le
    rw [le_sub_iff_add_le]
    norm_cast at h_le ⊢
