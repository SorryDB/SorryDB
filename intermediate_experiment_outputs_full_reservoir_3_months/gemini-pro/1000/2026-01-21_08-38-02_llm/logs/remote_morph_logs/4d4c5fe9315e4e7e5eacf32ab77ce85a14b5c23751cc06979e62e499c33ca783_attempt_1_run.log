  -- y^2 ≡ -4 (mod p) implies y^2 = k*p - 4.
  -- Since y^2 < p, the only solution is k=1?
  -- y^2 = p - 4 implies p = y^2 + 4.
  have p_eq : p = y^2 + 4 := by
