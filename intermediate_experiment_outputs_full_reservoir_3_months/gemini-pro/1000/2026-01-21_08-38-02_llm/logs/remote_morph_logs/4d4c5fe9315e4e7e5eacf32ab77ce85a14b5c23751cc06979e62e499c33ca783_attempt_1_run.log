    have : 4 * n^2 + 4 = 4 * (n^2 + 1) := by ring
    have h4 : p ∣ 4 * n^2 + 4 := Dvd.dvd.mul_left p_div_sq 4
    have : (2 * n)^2 % p = (p - 4) % p := by
      rw [Nat.pow_two, Nat.mul_mul_mul_comm, ← Nat.pow_two]
      -- 4n^2 ≡ -4 (mod p)
      -- (2n)^2 + 4 is divisible by p.
      -- So (2n)^2 ≡ -4 ≡ p-4.
      apply Nat.modeq.modeq_iff_dvd' (by linarith [hp.pos]).mp
      rw [Nat.modeq_iff_dvd' (by linarith [hp.pos])] at h4
