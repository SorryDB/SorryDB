theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let M := max 14 (N ^ 2 + 1)
  let K := (M !)^2 + 1
  have hK_gt_1 : 1 < K := Nat.one_lt_pow_add_one (Nat.factorial_pos M) (by norm_num)
  rcases Nat.exists_prime_and_dvd hK_gt_1 with ⟨p, hp, hpK⟩
  have hpM : M < p := by
    by_contra h
    have : p ∣ M ! := Nat.dvd_factorial hp.pos (le_of_not_lt h)
    have : p ∣ 1 := (Nat.dvd_add_iff_left (Nat.dvd_pow this 2)).mp hpK
    exact Nat.Prime.not_dvd_one hp this
  let n0 := (M !) % p
  let n := if n0 ≤ p / 2 then n0 else p - n0
  have hn_le : n ≤ p / 2 := by
    split_ifs with h
    · exact h
    · apply Nat.le_div_of_mul_le
      rw [Nat.mul_sub_left_distrib, Nat.mul_comm]
      apply Nat.sub_le_self
  have hn_pos : 0 < n := by
    by_contra h0
    simp at h0
    have : n0 = 0 ∨ n0 = p := by
      split_ifs at h0
      · left; exact h0
      · right; exact Nat.sub_eq_zero_iff_le.mp (le_of_eq h0)
