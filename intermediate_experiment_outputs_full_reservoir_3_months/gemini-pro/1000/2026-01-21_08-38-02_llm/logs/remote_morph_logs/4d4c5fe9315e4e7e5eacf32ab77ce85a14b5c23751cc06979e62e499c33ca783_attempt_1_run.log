theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  -- Existence of a prime p > max(N^2 + 20, 20) with p ≡ 1 (mod 4)
  let M := (max (N ^ 2 + 21) 5).factorial
  let K := (2 * M) ^ 2 + 1
  let p := K.minFac
  have hp : p.Prime := Nat.minFac_prime (Nat.ne_of_gt (by
    apply Nat.succ_lt_succ; apply Nat.pow_pos; apply Nat.mul_pos (by norm_num) (Nat.factorial_pos _)))
  have hdiv : p ∣ (2 * M) ^ 2 + 1 := Nat.minFac_dvd K
  have hp_mod4 : p % 4 = 1 := by
    have : (2 * M) ^ 2 ≡ -1 [ZMOD p] := by
      rw [ZMod.int_cast_eq_int_cast_iff]; push_cast
      exact (Nat.dvd_iff_mod_eq_zero _ _).mp hdiv
    have : IsSquare (-1 : ZMod p) := ⟨2 * M, this⟩
    rw [ZMod.exists_sq_eq_neg_one_iff] at this
    have : p % 2 = 1 := Nat.Prime.mod_two_eq_one_iff_ne_two.mpr hp (by
      intro h; rw [h] at hdiv; norm_num at hdiv)
    omega
  have hp_large : p > N ^ 2 + 20 := by
    by_contra h; push_neg at h
    have : p ∣ M := Nat.dvd_factorial (Nat.minFac_pos K) (le_trans h (Nat.le_max_left _ _))
    have : p ∣ 1 := (Nat.dvd_add_iff_right (dvd_pow (dvd_mul_of_dvd_right this 2) (by norm_num))).mp hdiv
    exact Nat.Prime.not_dvd_one hp this

  -- Construct n corresponding to p
  obtain ⟨z, hz⟩ := ZMod.exists_sq_eq_neg_one_iff.mpr (by omega)
  let n := if z.val ≤ p / 2 then z.val else p - z.val
  have hn_le : n ≤ p / 2 := by
    dsimp [n]; split_ifs <;> simp
