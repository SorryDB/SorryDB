import Imo.ProblemImports

open scoped Real
open scoped Nat

/--
Prove that there are infinitely many positive integers $ n$ such that $ n^{2} + 1$ has a prime divisor greater than $ 2n + \sqrt {2n}$.

[i]Author: Kestutis Cesnavicius, Lithuania[/i]
-/
@[imo_problem_subject number_theory]
theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let K := 4 * (N + 1)^2 + 25
  let M := (K.factorial)^2 + 1
  let p := M.minFac
  have hp : p.Prime := Nat.minFac_prime (ne_of_gt (Nat.succ_lt_succ (Nat.pos_pow_of_pos 2 (Nat.factorial_pos K))))
  have hpK : p > K := by
    by_contra h
    apply Nat.Prime.not_dvd_one hp
    have : p ∣ K.factorial := Nat.dvd_factorial (Nat.minFac_pos M) (le_of_not_gt h)
    exact (Nat.dvd_add_right (dvd_pow this two_ne_zero)).mp (Nat.minFac_dvd M)

  let n0 := K.factorial % p
  let n := if 2 * n0 ≤ p then n0 else p - n0
  
  have hn_dvd : p ∣ n^2 + 1 := by
    have h1 : p ∣ K.factorial^2 + 1 := Nat.minFac_dvd M
    have h2 : K.factorial^2 % p = n0^2 % p := by rw [Nat.pow_mod, Nat.mod_mod, ← Nat.pow_mod]
    rw [Nat.dvd_iff_mod_eq_zero, Nat.add_mod, h2, ← Nat.add_mod] at h1
    simp [n]
    split_ifs with h
    · exact (Nat.dvd_iff_mod_eq_zero _ _).mpr h1
    · have : (p - n0)^2 % p = n0^2 % p := by
        have : ((p : ℤ) - n0)^2 = p * (p - 2 * n0) + n0^2 := by ring
        rw [← Int.ofNat_inj, Int.ofNat_mod_nat, Int.ofNat_mod_nat]
        rw [this]
        simp
      rw [Nat.dvd_iff_mod_eq_zero, Nat.add_mod, this, ← Nat.add_mod]
      exact h1

  have h2n : 2 * n ≤ p := by
    simp [n]
    split_ifs with h
    · exact h
    · apply Nat.le_of_lt
      rw [Nat.mul_sub_left_distrib]
      linarith [Nat.lt_of_not_ge h]

  refine ⟨n, ?_, p, hp, hn_dvd, ?_⟩
  · have h_le_p : 4 * n^2 + 4 ≥ p := by
       apply Nat.le_of_dvd (by linarith)
       use 4 * ((n^2 + 1) / p)
       rw [Nat.mul_div_assoc _ hn_dvd]
       linarith
    have : 4 * n^2 > 4 * N^2 := by
      calc 4 * n^2 ≥ p - 4 := Nat.le_sub_of_add_le h_le_p
        _ > K - 4 := Nat.sub_lt_sub_right (by linarith) hpK
        _ = 4 * (N + 1)^2 + 21 := rfl
        _ > 4 * N^2 := by linarith
    exact Nat.lt_of_mul_lt_mul_left this
  
  · rw [gt_iff_lt, Real.lt_add_iff_sub_left_lt]
    have h_pos : (2 : ℝ) * n ≥ 0 := by simp
    rw [← Real.sq_lt_sq _ (Real.sqrt_nonneg _), Real.sq_sqrt h_pos]
    norm_cast
    
    let k := p - 2 * n
    have hk_eq : k = p - 2 * n := rfl
    have hk_pos : k > 0 := Nat.sub_pos_of_lt (Nat.lt_of_le_of_ne h2n (by
      intro h_eq
      have : p ∣ 4 * n^2 + 4 := Nat.dvd_mul_left 4 hn_dvd
      rw [← h_eq, show 4 * n^2 = (2*n)^2 by ring] at this
      have : p ∣ p^2 + 4 := this
      have : p ∣ 4 := (Nat.dvd_add_left (dvd_pow (dvd_refl p) two_ne_zero)).mp this
      have : p ≥ 29 := by linarith
      linarith
    ))

    have hk_sq : k^2 + 4 ≥ p := by
      apply Nat.le_of_dvd (by linarith)
      have : 4 * n^2 + 4 = p * (4 * ((n^2+1)/p)) := by
         rw [← Nat.mul_div_assoc 4 hn_dvd, Nat.mul_comm, Nat.div_mul_cancel hn_dvd]
         ring
      apply Int.dvd_natAbs.mp
      rw [Int.ofNat_add, Int.ofNat_pow]
      have : ((k : ℤ)^2 + 4) % p = 0 := by
          rw [hk_eq]
          simp only [Int.ofNat_sub, Int.ofNat_mul, Int.ofNat_ofNat]
          have : ((p : ℤ) - 2 * n)^2 + 4 = p * (p - 4 * n) + (4 * n^2 + 4) := by ring
          rw [this]
          simp [Int.ofNat_dvd.mpr (Nat.dvd_mul_left 4 hn_dvd)]
      exact Int.dvd_of_emod_eq_zero this

    calc (p - 2 * n)^2 = k^2 := by rw [hk_eq]
       _ > p - k := by
          have : k^2 + k > p := by
             calc k^2 + k ≥ (p - 4) + k := Nat.add_le_add_right (Nat.le_sub_of_add_le hk_sq) k
               _ = p + (k - 4) := by rw [Nat.add_sub_assoc (by linarith [Nat.le_trans (by norm_num) hpK])]
               _ > p := by
                 have : k ≥ 5 := by
                   have : k^2 ≥ 25 := by
                     calc k^2 ≥ p - 4 := Nat.le_sub_of_add_le hk_sq
                       _ > K - 4 := Nat.sub_lt_sub_right (by linarith) hpK
                       _ ≥ 25 := by linarith
                   exact Nat.le_of_mul_le_mul_left this
                 linarith
          exact Nat.lt_sub_of_add_lt this
       _ = 2 * n := by rw [hk_eq, Nat.sub_sub_self h2n]
