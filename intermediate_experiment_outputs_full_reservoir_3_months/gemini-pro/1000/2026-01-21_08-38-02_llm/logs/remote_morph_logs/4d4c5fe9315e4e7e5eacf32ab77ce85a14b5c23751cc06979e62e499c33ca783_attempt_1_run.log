theorem imo_2008_p3 :
    ∀ N : ℕ,
      ∃ n : ℕ, n ≥ N ∧ ∃ p : ℕ, Nat.Prime p ∧ p ∣ n ^ 2 + 1 ∧ (p : ℝ) > 2 * n + √(2 * n) := by
  intro N
  let K := max 14 (4 * N^2 + 2)
  -- Step 1: Find a prime p > K with p ≡ 1 (mod 4).
  have h_exists_p : ∃ p, Nat.Prime p ∧ p > K ∧ p % 4 = 1 := by
    let M := (Nat.factorial K)^2 + 1
    let p := M.minFac
    have hp : p.Prime := Nat.minFac_prime (ne_of_gt (Nat.succ_lt_succ (Nat.pow_pos (Nat.factorial_pos K) 2)))
    have h_dvd : p ∣ M := Nat.minFac_dvd M
    refine ⟨p, hp, ?_, ?_⟩
    · by_contra h_le
      have : p ∣ K.factorial := Nat.dvd_factorial (Nat.minFac_pos M) (le_of_not_lt h_le)
      have : p ∣ 1 := (Nat.dvd_add_iff_right (dvd_pow self_iff.mpr this two_ne_zero)).mpr h_dvd
      exact Nat.Prime.not_dvd_one hp this
    · have : (K.factorial : ZMod p)^2 = -1 := by
        rw [← ZMod.int_cast_eq_int_cast_iff, Int.cast_pow, Int.cast_natCast, Int.cast_neg, Int.cast_one]
        rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h_dvd
        exact h_dvd
      have h_not_three : p % 4 ≠ 3 := by
        intro h_eq
        have : IsSquare (-1 : ZMod p) := ⟨K.factorial, this⟩
        exact ZMod.exists_sq_eq_neg_one_iff.not.mpr h_eq this
      have h_odd : p % 2 = 1 := hp.mod_two_eq_one_iff_ne_two.mpr (by omega)
      omega

  rcases h_exists_p with ⟨p, hp, hp_gt, hp_mod4⟩
  -- Step 2: Construct n such that n^2 ≡ -1 (mod p) and n ≤ (p-1)/2.
  have h_sq : IsSquare (-1 : ZMod p) := ZMod.exists_sq_eq_neg_one_iff.mpr hp_mod4
  rcases h_sq with ⟨z, hz⟩
  let n_val := (z : ℕ)
  let n := if n_val ≤ p / 2 then n_val else p - n_val
  
  have hn_le : n ≤ p / 2 := by
    split_ifs; assumption
    apply Nat.le_of_lt_succ
    rw [Nat.succ_eq_add_one]
    have : n_val < p := z.val_lt
    omega

  have hn_sq : p ∣ n^2 + 1 := by
    have : (n : ZMod p)^2 = -1 := by
      dsimp [n]; split_ifs
      · exact hz
      · rw [ZMod.nat_cast_sub (le_of_lt z.val_lt), ZMod.nat_cast_self, zero_sub, neg_sq]; exact hz
    rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd]
    rw [Nat.cast_add, Nat.cast_pow, Nat.cast_one, this]
    norm_num

  -- Step 3: Show n ≥ N.
  have hn_ge_N : n ≥ N := by
    have : n^2 + 1 ≥ p := Nat.le_of_dvd (by omega) hn_sq
    have : p > 4 * N^2 + 1 := by omega
    have : n^2 > 4 * N^2 := by omega
    exact le_of_mul_le_mul_left (Nat.le_of_pow_le_pow_left (by omega) (le_of_lt this)) (by norm_num)

  refine ⟨n, hn_ge_N, p, hp, hn_sq, ?_⟩
  
  -- Step 4: Prove the inequality p > 2n + √2n.
  by_contra h_neg
  push_neg at h_neg
  let m := p - 2 * n
  
  have hm_sq : m^2 ≤ 2 * n := by
    rw [← Real.le_sqrt_iff (mul_nonneg (by norm_num) (Nat.cast_nonneg n))] at h_neg
    have : (m : ℝ) = p - 2 * n := by 
      rw [sub_eq_add_neg, ← Nat.cast_two, ← Nat.cast_mul, ← Nat.cast_sub (by omega)]
      rfl
    rw [← this] at h_neg
    norm_cast; exact Nat.pow_le_pow_of_le_left h_neg 2

  have h_div : p ∣ m^2 + 4 := by
    have : (m^2 + 4 : ZMod p) = (4*n^2 + 4 : ZMod p) := by
        dsimp [m]
        rw [Nat.cast_sub (by omega)]
        ring_nf
        rw [ZMod.nat_cast_self, sub_zero, neg_sq]
        ring
    rw [this]
    have : (4 * (n^2 + 1) : ZMod p) = 0 := by
       rw [Nat.cast_mul, Nat.cast_add, Nat.cast_one]
       rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at hn_sq
       rw [hn_sq, mul_zero]
    rw [Nat.cast_add, Nat.cast_one, mul_add, mul_one] at this
    exact (ZMod.nat_cast_zmod_eq_zero_iff_dvd _ _).mp this

  -- Contradiction for m ≤ 4.
  have hm_le_4 : m ≤ 4 := by
    have : p ≤ m^2 + 4 := Nat.le_of_dvd (by omega) h_div
    have : p = 2 * n + m := by dsimp [m]; omega
    have : m^2 + 4 - m ≥ 2 * n := by omega
    have : m^2 ≤ 2 * n := hm_sq
    omega

  have m_odd : m % 2 = 1 := by
    have : p % 2 = 1 := hp.mod_two_eq_one_iff_ne_two.mpr (by omega)
    dsimp [m]; omega
  
  interval_cases m <;> try omega
  · norm_num at h_div; have : p = 5 := Nat.eq_of_dvd_of_prime hp (by norm_num) h_div; omega
  · norm_num at h_div; have : p = 13 := Nat.eq_of_dvd_of_prime hp (by norm_num) h_div; omega
