    -- n ≥ √(p-1).
    -- If we picked p > N^2 + 1, then n ≥ N.
    -- So we just require p > N^2 + 1 in the existence claim.
    sorry

  refine ⟨n, hn_ge_N, p, hp, p_div_sq, ?_⟩

