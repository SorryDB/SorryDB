    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  match labels with
  | [] => simp [buildBST]; sorry
  | x :: xs =>
    rw [fastCheckMem_correct _ _ (buildBST_ordered _)]
    simp [buildBST, mem_foldl_addLabel, LabelledTree.mem, eq_comm]
