def buildBST : List α → LabelledTree α
  | [] => leaf (sorry : α)
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  cases labels with
  | nil => exact sorry
  | cons x xs =>
    simp [buildBST]
    generalize ht : leaf x = t
    have h : IsOrdered t := by rw [←ht]; simp [IsOrdered]
    induction xs generalizing t with
    | nil => exact h
    | cons y ys ih =>
      apply ih
      apply ordered_addLabel
      exact h

theorem mem_addLabel_eq (t : LabelledTree α) (l : α) (x : α) :
    (t.addLabel l).mem x ↔ t.mem x ∨ x = l := by
  induction t with
  | leaf v =>
    unfold LabelledTree.addLabel
    split_ifs <;> simp [LabelledTree.mem]
    · subst l; simp
    · constructor <;> intro h
      · cases h <;> simp_all
      · cases h <;> simp_all
    · constructor <;> intro h
      · cases h <;> simp_all
      · cases h <;> simp_all
  | node v lhs rhs ihl ihr =>
    unfold LabelledTree.addLabel
    split_ifs <;> simp [LabelledTree.mem, ihl, ihr] <;> tauto

theorem mem_foldl_addLabel (ys : List α) (t : LabelledTree α) (S : List α)
    (h : ∀ z, t.mem z ↔ z ∈ S) :
    ∀ z, (ys.foldl LabelledTree.addLabel t).mem z ↔ z ∈ S ++ ys := by
  induction ys generalizing t S with
  | nil => simp [h]
  | cons y ys ih =>
    simp
    apply ih (t.addLabel y) (S ++ [y])
    intro z
    rw [mem_addLabel_eq, h]
    simp; tauto

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  cases labels with
  | nil => exact sorry
  | cons x xs =>
    rw [fastCheckMem_correct]
    · simp [buildBST]
      rw [mem_foldl_addLabel]
      · simp; tauto
      · intro z; simp [LabelledTree.mem]; rfl
    · apply buildBST_ordered
