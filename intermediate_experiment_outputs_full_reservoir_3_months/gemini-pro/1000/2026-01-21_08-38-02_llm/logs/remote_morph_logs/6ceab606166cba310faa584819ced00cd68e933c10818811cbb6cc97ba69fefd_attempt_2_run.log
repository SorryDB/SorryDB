def buildBST : List α → LabelledTree α
  | [] => leaf sorry
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  match labels with
  | [] => exact sorry
  | x :: xs =>
    simp [buildBST]
    generalize h : leaf x = t
    have : IsOrdered t := by rw [←h]; trivial
    clear h
    induction xs generalizing t with
    | nil => assumption
    | cons y ys ih => apply ih; apply ordered_addLabel _ _ ‹_›

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  match labels with
  | [] => exact sorry
  | x :: xs =>
    have h_ord := buildBST_ordered (x :: xs)
    rw [fastCheckMem_correct _ _ h_ord]
    simp [buildBST]
    generalize h : leaf x = t
    have h_mem : ∀ a, a ∈ t ↔ a = x := by rw [←h]; simp
    have h_add : ∀ (t : LabelledTree α) (v l : α), l ∈ addLabel t v ↔ l = v ∨ l ∈ t := by
      intro t v l; induction t <;> simp [addLabel, mem]
      case leaf z => split_ifs <;> simp_all; tauto
      case node z l r il ir => split_ifs <;> simp_all [il, ir]; tauto
    clear h
    induction xs generalizing t with
    | nil => simp [h_mem]
    | cons y ys ih =>
      simp
      rw [ih (ordered_addLabel t y ‹_›) (by intro a; rw [h_add, h_mem]; tauto)]
      tauto
```
