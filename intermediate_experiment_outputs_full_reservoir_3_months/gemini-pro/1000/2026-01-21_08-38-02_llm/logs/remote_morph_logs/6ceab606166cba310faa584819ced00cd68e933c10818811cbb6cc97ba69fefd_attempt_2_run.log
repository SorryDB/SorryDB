theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  induction t with
  | leaf x =>
    simp [LabelledTree.addLabel]
    split_ifs <;> simp [IsOrdered, LabelledTree.mem]
    · apply le_of_lt; assumption
    · apply le_of_lt; assumption
  | node v l r ihl ihr =>
    simp [LabelledTree.addLabel]
    split_ifs
    · simp [IsOrdered] at h ⊢
      rcases h with ⟨h₁, h₂, h₃, h₄, h₅⟩
      refine ⟨?_, h₂, ihl h₃, h₄, ?_⟩
      · intro x hx; simp [LabelledTree.mem] at hx
        cases hx with | inl hx => subst hx; assumption | inr hx => apply h₁; assumption
      · simp [LabelledTree.mem]; rcases h₅ with h | h
        · left; right; assumption
        · right; assumption
    · simp [IsOrdered] at h ⊢
      rcases h with ⟨h₁, h₂, h₃, h₄, h₅⟩
      refine ⟨h₁, ?_, h₃, ihr h₄, ?_⟩
      · intro x hx; simp [LabelledTree.mem] at hx
        cases hx with | inl hx => subst hx; apply le_of_lt; assumption | inr hx => apply h₂; assumption
      · simp [LabelledTree.mem]; rcases h₅ with h | h
        · left; assumption
        · right; right; assumption

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x =>
    simp [fastCheckMem, LabelledTree.mem]
    constructor <;> (intro h; simp at h; assumption)
  | node v l r ihl ihr =>
    simp [IsOrdered] at h
    rcases h with ⟨hl, hr, ol, or, hmem⟩
    simp [fastCheckMem]
    split_ifs with heq hlt
    · subst heq; simp [LabelledTree.mem]; cases hmem <;> simp [*]
    · rw [ihl ol]
      constructor
      · intro h; left; assumption
      · intro h; cases h; assumption;
        have := hr label ‹label ∈ r›
        have := not_le_of_gt hlt; contradiction
    · rw [ihr or]
      constructor
      · intro h; right; assumption
      · intro h; cases h
        · have := hl label ‹label ∈ l›
          have : v < label := lt_of_le_of_ne (le_of_not_lt hlt) (Ne.symm heq)
          linarith
        · assumption

