theorem mem_addLabel (t : LabelledTree α) (y : α) (x : α) :
    mem (addLabel t y) x ↔ mem t x ∨ x = y := by
  induction t with
  | leaf z =>
    simp [addLabel]
    split <;> simp [mem] <;> try { apply or_comm }
    tauto
  | node v l r ihl ihr =>
    simp [addLabel]
    split <;> simp [mem, ihl, ihr] <;> tauto

theorem ordered_addLabel (t: LabelledTree α) (label: α)
  (h: IsOrdered t) :
    IsOrdered (LabelledTree.addLabel t label) := by
  induction t with
  | leaf x =>
    simp [IsOrdered, addLabel]
    split <;> simp [IsOrdered, mem]
    · intro; rfl
    · constructor; apply le_of_lt; assumption
  | node v l r ihl ihr =>
    simp [IsOrdered] at h
    simp [addLabel]
    split
    · simp [IsOrdered, ihl h.2.2.1, h]
      constructor
      · intro x hx
        rw [mem_addLabel] at hx
        cases hx with
        | inl hl => apply h.1 _ hl
        | inr heq => rw [heq]; assumption
      · tauto
    · simp [IsOrdered, ihr h.2.2.2.1, h]
      constructor
      · intro x hx
        rw [mem_addLabel] at hx
        cases hx with
        | inl hr => apply h.2.1 _ hr
        | inr heq => rw [heq]; apply le_of_not_le; assumption
      · tauto

theorem fastCheckMem_correct (label : α)
    (l: LabelledTree α)(h : IsOrdered l):
    fastCheckMem label l = true ↔ label ∈ l := by
  induction l with
  | leaf x => simp [fastCheckMem, mem]
  | node v l r ihl ihr =>
    simp [IsOrdered] at h
    simp [fastCheckMem]
    split
    · simp [mem]; tauto
    · split
      · rw [ihl h.2.2.1]; simp [mem]
        constructor <;> intro H
        · left; assumption
        · cases H
          · assumption
          · have : v ≤ label := h.2.1 _ (by assumption); have : label < v := by assumption; linarith
      · rw [ihr h.2.2.2.1]; simp [mem]
        constructor <;> intro H
        · right; assumption
        · cases H
          · have : label ≤ v := h.1 _ (by assumption); have : ¬ label < v := by assumption; linarith
          · assumption

def buildBST : List α → LabelledTree α
  | [] => leaf (sorry) -- Function undefined for empty list as LabelledTree cannot be empty
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  match labels with
  | [] => simp [buildBST]; sorry
  | x :: xs =>
    simp [buildBST]
    apply List.foldl_induction
    · simp [IsOrdered]
    · intros t y h; apply ordered_addLabel t y h

theorem mem_foldl_addLabel (xs : List α) (t : LabelledTree α) (y : α) :
    mem (xs.foldl LabelledTree.addLabel t) y ↔ mem t y ∨ y ∈ xs := by
  induction xs generalizing t with
  | nil => simp
  | cons z zs ih => simp [ih, mem_addLabel]; tauto

theorem buildBST_mem_correct (labels : List α)
    (label : α) :
    fastCheckMem label (buildBST labels) = true ↔ label ∈ labels := by
  match labels with
  | [] => simp [buildBST]; sorry
  | x :: xs =>
    simp [buildBST]
    rw [fastCheckMem_correct]
    · rw [mem_foldl_addLabel]
      simp [mem]
      constructor <;> intro h
      · cases h with | inl h => left; assumption | inr h => right; assumption
      · cases h with | inl h => left; assumption | inr h => right; assumption
    · apply buildBST_ordered
