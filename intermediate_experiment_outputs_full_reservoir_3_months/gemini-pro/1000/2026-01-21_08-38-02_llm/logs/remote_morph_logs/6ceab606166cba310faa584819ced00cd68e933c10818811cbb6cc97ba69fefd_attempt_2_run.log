def buildBST : List α → LabelledTree α
  | [] => leaf (sorry)
  | x :: xs => xs.foldl LabelledTree.addLabel (leaf x)

theorem mem_addLabel (t : LabelledTree α) (l : α) (y : α) :
    (t.addLabel l).mem y ↔ t.mem y ∨ l = y := by
  induction t with
  | leaf x => simp [LabelledTree.addLabel]; split_ifs <;> simp [LabelledTree.mem, *] <;> tauto
  | node v l r ihl ihr => simp [LabelledTree.addLabel]; split_ifs <;> simp [LabelledTree.mem, *] <;> tauto

theorem mem_foldl_addLabel (xs : List α) (t : LabelledTree α) (y : α) :
    (xs.foldl LabelledTree.addLabel t).mem y ↔ t.mem y ∨ y ∈ xs := by
  induction xs generalizing t <;> simp [*, mem_addLabel, or_assoc]

theorem buildBST_ordered (labels : List α) :
    IsOrdered (buildBST labels) := by
  match labels with
  | [] => simp [buildBST, IsOrdered]
  | x :: xs =>
    simp [buildBST]
    let rec aux (l : List α) (t : LabelledTree α) (h : IsOrdered t) :
      IsOrdered (l.foldl LabelledTree.addLabel t) := match l with
      | [] => h
      | y :: ys => aux ys (t.addLabel y) (ordered_addLabel t y h)
