  | [] => simp [buildBST, IsOrdered]
  | x :: xs =>
    simp [buildBST]
    let rec aux (t : LabelledTree α) (l : List α) (h : IsOrdered t) :
      IsOrdered (l.foldl LabelledTree.addLabel t) := match l with
      | [] => h
      | y :: ys => aux (LabelledTree.addLabel t y) ys (ordered_addLabel t y h)
    apply aux (leaf x) xs (by simp [IsOrdered])

