/- The Ackermann function, defined using pattern matching notation. -/
def A : ℕ → ℕ → ℕ
| 0,     n     => n + 1
| m + 1, 0     => A m 1
| m + 1, n + 1 => A m (A (m + 1) n)

def myA : ℕ → ℕ → ℕ :=
  Nat.rec (motive := fun _ => ℕ → ℕ)
    (fun n => n + 1)
    (fun _ Am n => Nat.rec (motive := fun _ => ℕ) (Am 1) (fun _ res => Am res) n)

example : A = myA := by
  funext m n
  induction m generalizing n with
  | zero => rfl
  | succ m ih_m =>
    induction n with
    | zero =>
      rw [A]
      exact ih_m 1
    | succ n ih_n =>
      rw [A, ih_n, ih_m]
```
