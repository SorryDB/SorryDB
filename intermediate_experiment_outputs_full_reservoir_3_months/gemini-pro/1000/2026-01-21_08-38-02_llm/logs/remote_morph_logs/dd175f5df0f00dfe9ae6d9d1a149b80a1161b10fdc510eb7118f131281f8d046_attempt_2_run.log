The `IsBinomialRandom.compl` lemma states that the complement of a binomial random graph $G(V, p)$ is distributed as $G(V, 1-p)$. This follows from the fact that the edges in $G(V, p)$ are independent Bernoulli random variables with parameter $p$, so the edges in the complement (which are the non-edges of $G$) are independent Bernoulli with parameter $1-p$. The proof relies on rewriting the measure using the definition `binomialRandom`, applying the property that `edgeSet` intertwines graph complement and set complement (relative to non-diagonal pairs), and using the property that the Bernoulli distribution on sets transforms correctly under complement.

```lean
lemma IsBinomialRandom.compl (hG : IsBinomialRandom G p P) :
    IsBinomialRandom (fun ω ↦ (G ω)ᶜ) (σ p) P where
  map_eq := by
    rw [hG.map_eq, Measure.map_map (by fun_prop) (by fun_prop), binomialRandom, binomialRandom]
    let ψ : Set (Sym2 V) → Set (Sym2 V) := fun s ↦ sᶜ ∩ diagSetᶜ
    have hψ : Measurable ψ := measurable_compl.inter measurable_const
    have h_comm : edgeSet ∘ SimpleGraph.compl = ψ ∘ edgeSet := by
      ext G e; simp [ψ, Sym2.mem_diagSet_iff_isDiag, and_comm]
    have h_map : map ψ (Ber(diagSetᶜ, p)) = Ber(diagSetᶜ, σ p) := bernoulliOn_map_compl _ _
    rw [← h_map]
    refine Measure.ext fun s hs ↦ ?_
    obtain ⟨t, ht, rfl⟩ := measurable_iff_adj.1 hs
    rw [Measure.map_apply (by fun_prop) hs]
    have h_supp : (Ber(diagSetᶜ, p)).ae (· ⊆ diagSetᶜ) := bernoulliOn_ae_subset
    have key (μ : Measure (Set (Sym2 V))) (hμ : μ.ae (· ⊆ diagSetᶜ)) (t : Set (Set (Sym2 V)))
        (ht : MeasurableSet t) : comap edgeSet μ (edgeSet ⁻¹' t) = μ t := by
      refine Measure.comap_apply_of_image_subset_range measurable_edgeSet edgeSet_injective ht ?_
      exact hμ.mono fun s hs ↦ ⟨fromEdgeSet s, by simp [hs]⟩
    rw [key _ h_supp _ ht, key _ (h_supp.map hψ (by fun_prop)) _ ht]
    rw [Set.preimage_comp, h_comm, Set.preimage_comp, Measure.map_apply hψ ht]
