def seqFunctor (S : LightProfinite.{0}) : ℕ+ ⥤ LightProfinite where
  obj c := profiniteComponent S c
  map f := limMap (whiskerLeft S.fintypeDiagram
    { app := fun Si => FintypeCat.toLightProfinite.map (fun x => ⟨x.1, le_trans x.2 (le_of_hom f)⟩)
      naturality := fun _ _ _ => by sorry })
  map_id _ := by
