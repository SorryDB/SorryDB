  have h_inv : ∀ m, C m ^ 2 - 3 * S m ^ 2 = 3 ^ m := by
    intro m
    induction m with
    | zero =>
      simp [S, C]
      decide
    | succ m ih =>
      obtain ⟨hS, hC⟩ := h_rec m
      rw [hS, hC, pow_succ]
      linear_combination 3 * ih

  -- Contradiction
  intro h
  have contra := h_inv (2 * n + 1)
  rw [h] at contra
  simp only [zero_pow (by linarith), mul_zero, sub_zero] at contra
  have : IsSquare (3 : ZMod 5) := by
    use C (2 * n + 1) * 3⁻¹ ^ (n + 1)
