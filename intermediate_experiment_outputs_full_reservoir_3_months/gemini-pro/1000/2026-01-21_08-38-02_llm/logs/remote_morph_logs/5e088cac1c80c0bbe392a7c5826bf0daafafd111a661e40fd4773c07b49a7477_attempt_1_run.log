  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  -- Working modulo 5
  intro h
  set m := 2 * n + 1
  let A : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  -- A = I + J where J^2 = 3I. This implies the binomial sum structure.
  have h_sum : (∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1) : ZMod 5) * 2 ^ (3 * k)) = (A ^ m) 1 0 := by
    let J : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
    have hA : A = 1 + J := by ext i j; fin_cases i <;> fin_cases j <;> rfl
    have hJ : J ^ 2 = (3 : ZMod 5) • (1 : Matrix _ _ _) := by
      ext i j; fin_cases i <;> fin_cases j <;> simp [Matrix.mul_apply] <;> rfl
    rw [hA, add_pow _ (Commute.one_left J) m]
    simp only [Matrix.sum_apply, Matrix.smul_apply, Matrix.one_apply, Matrix.pow_apply]
    trans ∑ i ∈ Finset.range (m + 1), (m.choose i : ZMod 5) * (J ^ i) 1 0
    · congr; ext i; simp
    -- Terms for even i are 0, terms for odd i = 2k+1 are choose * 3^k
    rw [← Finset.sum_filter_add_sum_filter_not (· % 2 = 1)]
    simp only [Finset.filter_not, Nat.mod_two_ne_one]
    have h_even : ∀ i ∈ Finset.range (m + 1), i % 2 = 0 → (J ^ i) 1 0 = 0 := by
      intro i _ hi; obtain ⟨k, rfl⟩ := Nat.dvd_of_mod_eq_zero hi
      rw [pow_mul, hJ, one_mul, Matrix.smul_pow, Matrix.one_pow, Matrix.smul_apply, Matrix.one_apply_ne]
      decide
    have h_odd : ∀ k, 2 * k + 1 < m + 1 → (J ^ (2 * k + 1)) 1 0 = (3 : ZMod 5) ^ k := by
      intro k _; rw [pow_succ', pow_mul, hJ, one_mul, Matrix.mul_smul, Matrix.smul_pow, Matrix.one_pow, Matrix.smul_apply]
      simp [J]
    rw [Finset.sum_eq_zero (fun i hi => h_even i (Finset.mem_range.1 hi) hi), add_zero]
    -- Bijection from k to 2k+1
    let f : ℕ ↪ ℕ := ⟨λ k => 2 * k + 1, λ _ _ => by linarith⟩
    refine Finset.sum_bij f (by simp [m]; omega) (fun k _ => ?_) (fun _ _ => rfl) (fun i hi h_odd_i => ?_)
    · rw [h_odd k (by simp at hi; omega)]; congr; norm_num [pow_mul]
    · obtain ⟨k, rfl⟩ := Nat.exists_eq_add_of_odd (Nat.mod_two_eq_one_iff_odd.1 h_odd_i)
      use k; simp at hi ⊢; omega
  -- A^6 = 3I, so A^m never has 0 at (1,0) for odd m
  have h_per : A ^ 6 = (3 : ZMod 5) • 1 := by
    rw [show A^6 = (A^3)^2 by abel, show A^3 = A + 4 • 1 by decide]
    rw [add_pow_two, show A^2 = 2 • A + 2 • 1 by decide]
    ext i j; fin_cases i <;> fin_cases j <;> simp <;> rfl
  have h_val : (A ^ m) 1 0 ≠ 0 := by
    have h_mod : m % 6 = 1 ∨ m % 6 = 3 ∨ m % 6 = 5 := by
      have : m % 2 = 1 := by rw [m]; omega
      omega
    rw [← Nat.div_add_mod m 6, pow_add, pow_mul, h_per, Matrix.smul_pow, Matrix.one_pow, Matrix.smul_mul, Matrix.one_mul, Matrix.smul_apply]
    rcases h_mod with h1 | h3 | h5 <;> rw [h1, h3, h5]
    · show 3 ^ (m / 6) * (A ^ 1) 1 0 ≠ 0; simp [A]; apply pow_ne_zero; decide
    · show 3 ^ (m / 6) * (A ^ 3) 1 0 ≠ 0; rw [show A^3 = !![0, 3; 1, 0] by decide]; simp; apply pow_ne_zero; decide
    · show 3 ^ (m / 6) * (A ^ 5) 1 0 ≠ 0; rw [show A^5 = !![3, 2; 4, 3] by decide]; simp; apply pow_ne_zero; decide
  -- Contradiction
  rw [← ZMod.int_cast_zmod_eq_zero_iff_dvd] at h
  rw [Int.cast_sum] at h
  norm_cast at h
  rw [h_sum] at h
  exact h_val h
