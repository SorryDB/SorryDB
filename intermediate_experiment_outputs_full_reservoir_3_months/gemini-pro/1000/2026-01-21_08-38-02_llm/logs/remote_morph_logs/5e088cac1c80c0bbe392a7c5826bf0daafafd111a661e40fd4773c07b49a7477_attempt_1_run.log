theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  let A := 1 + M
  
  -- The sum modulo 5
  let S := ∑ k ∈ Finset.range (n + 1), ((2 * n + 1).choose (2 * k + 1) : ZMod 5) * 3 ^ k
  
  -- Step 1: Relate S to the matrix power A^(2n+1)
  -- We claim S is the (1,0) entry of A^(2n+1)
  have h_eq : (A ^ (2 * n + 1)) 1 0 = S := by
    rw [add_pow]
    let f (j : ℕ) := ((2 * n + 1).choose j : ZMod 5) * (M ^ j) 1 0
    have h_sum : (A ^ (2 * n + 1)) 1 0 = ∑ j ∈ Finset.range (2 * n + 2), f j := by
      simp [f, Matrix.add_apply, Matrix.sum_apply, Matrix.smul_apply, Matrix.one_apply]
    rw [h_sum]
    -- M^j has (1,0) entry equal to 0 if j even, and 3^(j/2) if j odd
    have h_terms (j : ℕ) : f j = if j % 2 = 1 then ((2 * n + 1).choose j : ZMod 5) * 3 ^ (j / 2) else 0 := by
      dsimp [f]
      induction j with | zero => rfl | succ j ih => 
        rw [pow_succ, Matrix.mul_apply, Fin.sum_univ_two]
        simp only [M]
        split_ifs with h_odd
        · -- j is odd
          have h_even : j % 2 = 0 := Nat.odd_iff.mp h_odd
          simp [h_even] at ih; rw [ih]; simp
        · -- j is even
          have h_odd' : j % 2 = 1 := by rw [Nat.not_odd_iff] at h_odd; exact h_odd
          simp [h_odd'] at ih; rw [ih]; simp
          rw [Nat.div_eq_of_eq_mul_left (Nat.dvd_add_self_right.mpr (Nat.dvd_mul_right 2 (j / 2))) rfl]
          ring
    -- Sum over odd j gives S
    trans ∑ k ∈ Finset.range (n + 1), f (2 * k + 1)
    · refine Finset.sum_bij (fun k _ => 2 * k + 1) (fun _ _ => by simp) (fun _ _ => rfl) (fun _ _ _ _ => by simp) (fun b hb => ?_)
      simp at hb; simp [h_terms]; split_ifs with h_odd
      · use (b - 1) / 2; simp; constructor; omega; omega
      · simp
    · apply Finset.sum_congr rfl
      intro k hk
      simp [h_terms]
  
