theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  -- Transform the problem to ZMod 5
  rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h
  simp only [Nat.cast_sum, Nat.cast_mul, Nat.cast_pow, Nat.cast_ofNat] at h
  norm_num at h
  
  -- Define the matrix M corresponding to multiplication by 1 + √3
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let X : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  
  have M_eq : M = 1 + X := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  
  -- Properties of X
  have X_pow (k : ℕ) : X ^ k = if k % 2 = 0 then (3 : ZMod 5)^(k/2) • 1 else (3 : ZMod 5)^(k/2) • X := by
    induction k with
    | zero => simp
    | succ k ih =>
      by_cases hk : k % 2 = 0
      · rw [pow_succ, ih, if_pos hk, if_neg (by simpa using hk)]
        simp; rw [Matrix.smul_mul, Matrix.one_mul]
      · rw [pow_succ, ih, if_neg hk, if_pos (Nat.succ_mod_eq_zero_iff.mpr hk)]
        simp; rw [Matrix.smul_mul, Matrix.mul_smul]
        have X2 : X^2 = 3 • 1 := by decide
        rw [← pow_two, X2]; simp [mul_comm]
        congr; omega

  -- Show that the sum is the (1,0) entry of M^(2n+1)
  have sum_eq : (M ^ (2 * n + 1)) 1 0 = ∑ k in Finset.range (n + 1), (2 * n + 1).choose (2 * k + 1) * (3 : ZMod 5) ^ k := by
    rw [M_eq, Commute.add_pow (Commute.one_left X)]
    simp only [Matrix.sum_apply, Matrix.smul_apply, Matrix.nat_cast_apply, Matrix.pow_apply]
    rw [Finset.sum_filter_add_sum_filter (· % 2 = 1)]
    convert add_zero _
    · -- Odd powers of X contribute to the sum
      rw [Finset.sum_bij (λ k _ ↦ 2 * k + 1)]
      · intro k hk; simp at X_pow; rw [X_pow, if_neg (by omega)]
        simp; ring
      · intro k hk; simp at hk; simp; omega
      · intro k hk; simp
      · intro x hx; simp at hx; exists x / 2
        constructor <;> omega
    · -- Even powers of X contribute 0 to the (1,0) entry
      apply Finset.sum_eq_zero
      intro x hx
      simp at hx
      rw [X_pow, if_pos hx.2]; simp

  rw [← sum_eq] at h
  
  -- Periodicity of M
  have per : M ^ 6 = 3 • 1 := by decide
  let m := 2 * n + 1
  
  -- Contradiction
  have : (M ^ m) 1 0 ≠ 0 := by
     rw [(Nat.div_add_mod m 6).symm, pow_add, pow_mul, per]
     simp [Matrix.smul_mul, Matrix.mul_smul]
     have odd : (m % 6) % 2 = 1 := by 
       have : m % 2 = 1 := by simp [m, Nat.add_mod]
       omega
     rcases Nat.mod_lt m (by norm_num : 6 > 0) with _
     interval_cases (m % 6) <;> try (simp at odd; contradiction)
     all_goals decide
  exact this h
