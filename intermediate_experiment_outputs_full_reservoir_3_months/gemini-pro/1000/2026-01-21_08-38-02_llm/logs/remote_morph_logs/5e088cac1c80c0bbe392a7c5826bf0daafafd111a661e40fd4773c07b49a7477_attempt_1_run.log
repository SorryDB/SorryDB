    have h_union : Finset.range (m + 1) = (Finset.range (n + 1)).image (2 * ·) ∪ (Finset.range (n + 1)).image (2 * · + 1) := by
      ext x; simp [m, Finset.mem_image, Finset.mem_range]
      constructor
