  have hY2 : Y ^ 2 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    ext i j; fin_cases i <;> fin_cases j <;> rfl

  have h_pow_val (k : ℕ) : (Y ^ k) 1 0 = if k % 2 = 1 then 3 ^ (k / 2) else 0 := by
    induction k using Nat.strong_induction_on with k ih
    rcases k with _ | k; · simp
    rcases k with _ | k; · simp
    rw [pow_succ, pow_succ, hY2, Matrix.mul_smul, Matrix.mul_one, Matrix.smul_apply]
    simp
    split_ifs with h_even h_odd
    · simp at h_even; rw [ih k (by omega), h_even]; simp
    · simp at h_odd; rw [ih k (by omega), h_odd]; simp; congr; omega

  have h_sum : (M ^ (2 * n + 1)) 1 0 = (s : ZMod 5) := by
    rw [hM, add_pow, Matrix.sum_apply]
    let f : ℕ → ZMod 5 := λ k => (2 * n + 1).choose k * (Y ^ k) 1 0
    change ∑ k ∈ Finset.range (2 * n + 2), f k = _
    
    let odds := (Finset.range (n + 1)).map ⟨λ k => 2 * k + 1, by intros x y; omega⟩
    have h_subset : odds ⊆ Finset.range (2 * n + 2) := by
      simp [odds]; intro x hx; omega
      
    rw [←Finset.sum_subset h_subset]
    · rw [Finset.sum_map]
      apply Finset.sum_congr rfl
      intro k hk
      simp [f, h_pow_val]
      have : (2 * k + 1) % 2 = 1 := by omega
      rw [if_pos this]
      congr 1
      · congr; omega
      · have : (2 : ZMod 5) ^ 3 = 3 := by decide
        rw [←pow_mul, mul_comm, pow_mul, this]
    · intro x hx h_notin
      simp [f, h_pow_val]
      by_contra h_nz
      split_ifs at h_nz with h_odd
      · apply h_notin
        simp [odds, Finset.mem_map, Finset.mem_range]
        use x / 2
        constructor
        · apply Nat.div_lt_of_lt_mul
          simp; omega
        · omega
      · contradiction

  let idx := (2 * n + 1) % 24
  have h_per : M ^ 24 = 1 := by rw [←Matrix.ext_iff]; decide
  have h_mod : M ^ (2 * n + 1) = M ^ idx := by
    nth_rewrite 1 [←Nat.div_add_mod (2 * n + 1) 24]
    rw [pow_add, pow_mul, h_per, one_pow, one_mul]
    
  rw [h_mod] at h_sum
  
  have h_idx_odd : idx % 2 = 1 := by
    have h : (2 * n + 1) % 2 = 1 := by omega
    rw [←Nat.mod_mod_of_dvd _ (by norm_num : 2 ∣ 24)] at h
    exact h
    
  have h_nz : (M ^ idx) 1 0 ≠ 0 := by
    have : idx < 24 := Nat.mod_lt _ (by norm_num)
    interval_cases idx <;> (try simp at h_idx_odd; contradiction) <;> native_decide

  apply h_nz
  rw [h_sum]
  exact_mod_cast h5
