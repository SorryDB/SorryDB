theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5 ∣ ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  let N := 2 * n + 1
  -- Transfer the problem to ZMod 5
  have h_eq : (∑ k ∈ Finset.range (n + 1), (Nat.choose N (2 * k + 1)) * (3 ^ k) : ZMod 5) = 0 := by
    rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h
    convert h using 2
    rw [Nat.cast_mul, Nat.cast_pow]
    congr
    norm_num

  -- Define matrices M and A such that M = I + A and A^2 = 3I
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let A : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  have hM : M = 1 + A := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  have hA2 : A ^ 2 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    ext i j; fin_cases i <;> fin_cases j <;> rfl

  -- Show that the sum corresponds to the (1,0) entry of M^N
  have h_sum : (∑ k ∈ Finset.range (n + 1), (Nat.choose N (2 * k + 1) : ZMod 5) * 3 ^ k) = (M ^ N) 1 0 := by
    rw [hM, add_pow]
    trans ∑ k ∈ Finset.range (N + 1), ((N.choose k : ZMod 5) * (A ^ k) 1 0)
    · rw [Matrix.sum_apply]
      congr; ext k
      rw [Matrix.smul_apply]
    
    rw [←Finset.sum_filter_add_sum_filter_not (· % 2 = 1)]
    convert (add_zero _).symm
    · refine Finset.sum_bij (λ k _ => 2 * k + 1) (λ k hk => ?_) (λ k hk => ?_) (λ k hk => ?_) (λ b hb => ?_)
      · rw [Finset.mem_range] at hk ⊢; linarith
      · rw [Finset.mem_filter, Finset.mem_range] at hb
        simp
        have : (A ^ (2 * k + 1)) 1 0 = 3 ^ k := by
          rw [pow_succ, pow_mul, hA2]; simp; rfl
        rw [this]
      · simp
      · rw [Finset.mem_filter, Finset.mem_range] at hb
        use (b - 1) / 2
        constructor
        · rw [Finset.mem_range]; linarith [hb.1]
        · dsimp; omega
    · apply Finset.sum_eq_zero; intro x hx
      rw [Finset.mem_filter] at hx
      have : (A ^ x) 1 0 = 0 := by
        obtain ⟨k, rfl⟩ := Nat.exists_eq_two_mul (Nat.mod_two_ne_one.mp hx.2)
        rw [pow_mul, hA2]; simp; rfl
      rw [this, mul_zero]

  rw [h_sum] at h_eq

  -- Calculate M^N based on N mod 3 and show it is non-zero
  have h_val : (M ^ N) 1 0 ≠ 0 := by
    have hM3 : M ^ 3 = A := by 
      rw [show M^3 = M*M*M by ring, hM, hA2]; 
      ext i j; fin_cases i <;> fin_cases j <;> rfl
    
    let k := N / 3
    let r := N % 3
    have hN : N = 3 * k + r := (Nat.div_add_mod N 3).symm
    rw [hN, pow_add, pow_mul, hM3]
    
    rcases hr : r with _ | _ | _ <;> try omega
    · -- r=0 implies k is odd
      have : k % 2 = 1 := by
        have : N % 2 = 1 := by rw [show N = 2*n+1 by rfl]; simp
        rw [hN, hr, add_zero] at this
        omega
      obtain ⟨j, rfl⟩ := Nat.exists_eq_add_of_odd this
      rw [pow_add, pow_one, pow_mul, hA2]; simp
    · -- r=1 implies k is even
      have : k % 2 = 0 := by
        have : N % 2 = 1 := by rw [show N = 2*n+1 by rfl]; simp
        rw [hN, hr] at this
        omega
      obtain ⟨j, rfl⟩ := Nat.exists_eq_two_mul this
      rw [pow_mul, hA2]; simp; rfl
    · -- r=2 implies k is odd
      have : k % 2 = 1 := by
        have : N % 2 = 1 := by rw [show N = 2*n+1 by rfl]; simp
        rw [hN, hr] at this
        omega
      obtain ⟨j, rfl⟩ := Nat.exists_eq_add_of_odd this
      rw [pow_add, pow_one, pow_mul, hA2]; simp
      have : (M ^ 2 * A) 1 0 = (4 : ZMod 5) := by
         rw [show M = !![1,3;1,1] by rfl, show A = !![0,3;1,0] by rfl]; native_decide
      rw [this]; decide

  exact h_val h_eq
