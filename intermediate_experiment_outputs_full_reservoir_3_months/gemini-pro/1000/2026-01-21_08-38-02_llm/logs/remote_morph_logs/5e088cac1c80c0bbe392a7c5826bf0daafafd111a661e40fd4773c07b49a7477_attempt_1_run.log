theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  rw [← ZMod.int_cast_zmod_eq_zero_iff_dvd]
  let S : ℕ → ZMod 5 := fun m ↦ ∑ k ∈ range (m + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k
  let C : ℕ → ZMod 5 := fun m ↦ ∑ k ∈ range (m + 1), (m.choose (2 * k) : ZMod 5) * 3 ^ k
  
  -- The problem sum equals S (2n+1)
  have h_eq : (∑ k ∈ range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1) : ZMod 5) * (2 ^ (3 * k) : ℕ)) = S (2 * n + 1) := by
    rw [sum_range_succ'] at S
    apply Finset.sum_subset (Finset.range_subset.mpr (by omega))
    · intro k hk hkn
      have : 2 * n + 1 < 2 * k + 1 := by
        simp only [mem_range, not_lt] at hkn
        linarith
      simp [Nat.choose_eq_zero_of_lt this]
    · intro k hk
      congr 1
      · simp
      · rw [Nat.cast_pow, show (2 : ZMod 5) ^ 3 = 8 by rfl, show (8 : ZMod 5) = 3 by rfl, pow_mul]

  rw [h_eq]
  
  -- Recurrence relations
  have h_rec : ∀ m, S (m + 1) = S m + C m ∧ C (m + 1) = C m + 3 * S m := by
    intro m
    have h_zero_S : (m.choose (2 * (m + 1) + 1) : ZMod 5) = 0 := by
      rw [Nat.choose_eq_zero_of_lt (by linarith)]
      rfl
    have h_zero_C : (m.choose (2 * (m + 1)) : ZMod 5) = 0 := by
      rw [Nat.choose_eq_zero_of_lt (by linarith)]
      rfl
    constructor
    · rw [S, S, C, Finset.sum_range_succ, h_zero_S, mul_zero, add_zero, Finset.sum_range_succ, h_zero_C, mul_zero, add_zero, ← Finset.sum_add_distrib]
      apply Finset.sum_congr rfl
      intro k _
      rw [Nat.choose_succ_succ, Nat.cast_add, add_mul]
    · rw [C, C, S, Finset.sum_range_succ, h_zero_C, mul_zero, add_zero]
      rw [show 3 * S m = ∑ k ∈ range (m + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ (k + 1) by
           simp only [S, mul_sum, ← mul_assoc]; congr; ext; ring]
      rw [Finset.sum_range_succ', Nat.choose_zero_right, Nat.cast_one, pow_zero, mul_one]
      rw [show ((m.choose (2 * 0) : ZMod 5) * 3 ^ 0) = 1 by simp]
      rw [add_assoc, ← Finset.sum_add_distrib]
      congr 1
      rw [Nat.add_comm, Finset.sum_range_succ]
      simp only [Nat.succ_eq_add_one, Nat.choose_succ_succ, Nat.cast_add, add_mul]
      rw [h_zero_S, mul_zero, add_zero]
      apply Finset.sum_congr rfl
      intro k _
      have : 2 * (k + 1) = 2 * k + 2 := by ring
      rw [this, Nat.choose_succ_succ]
      simp [add_mul, mul_add]
