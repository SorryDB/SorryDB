      simp only [Finset.mem_range, Finset.mem_filter, Bool.not_eq_true, Bool.decide_eq_false] at h_odd
      obtain ⟨k, rfl⟩ := Nat.Even.exists_two_mul (Nat.even_iff_not_odd.mpr h_odd)
      simp [f, pow_mul, hN2]
    · refine Finset.sum_bij (fun k _ => 2 * k + 1) (fun _ _ => by simp [Finset.mem_filter]; omega) (fun k _ => ?_) (fun _ _ _ _ => by omega) (fun b hb => ?_)
      · simp [f]; rw [pow_succ, pow_mul, hN2]; simp; ring
