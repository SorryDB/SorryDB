The IMO 1974 Problem 3 asks to prove that $5$ does not divide $\sum_{k=0}^n \binom{2n+1}{2k+1} 2^{3k}$.
This sum corresponds to the imaginary part of the expansion of $(1+\sqrt{8})^{2n+1}$. Modulo 5, $\sqrt{8} \equiv \sqrt{3}$.
Working in $\mathbb{Z}_5 \times \mathbb{Z}_5$ to simulate $\mathbb{Z}_5[\sqrt{3}]$, we establish a linear recurrence for the sum and prove that it is never $0$ for indices of the form $2n+1$.

```lean
theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  -- Interpret the sum in ZMod 5
  let S := ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * 2 ^ (3 * k)
  have hS : (S : ZMod 5) = 0 := CharP.cast_eq_zero_iff (ZMod 5) 5 S |>.mpr h

  -- Define the sequence v_m = (A_m, B_m) corresponding to (1 + \sqrt{3})^m
  let step (v : ZMod 5 × ZMod 5) : ZMod 5 × ZMod 5 := (v.1 + 3 * v.2, v.1 + v.2)
  let v (m : ℕ) := step^[m] (1, 0)

  -- Define the sums A_m and B_m explicitly
  let A_sum (m : ℕ) : ZMod 5 := ∑ k ∈ range (m + 1), (m.choose (2 * k)) * 3 ^ k
  let B_sum (m : ℕ) : ZMod 5 := ∑ k ∈ range (m + 1), (m.choose (2 * k + 1)) * 3 ^ k

  -- Prove that the sums satisfy the recurrence relations of `step`
  -- Relations: A_{m+1} = A_m + 3 B_m, B_{m+1} = A_m + B_m
  have h_rec (m : ℕ) : A_sum (m + 1) = A_sum m + 3 * B_sum m ∧ B_sum (m + 1) = A_sum m + B_sum m := by
    constructor
    · rw [A_sum, A_sum, B_sum, Finset.sum_range_succ', Finset.sum_range_succ', Finset.sum_range_succ']
      simp only [Nat.choose_succ_succ, Nat.choose_zero_right, Nat.cast_add, Nat.cast_one, 
                 pow_zero, mul_one, add_mul, Finset.sum_add_distrib, add_assoc]
      congr 1
      rw [mul_sum, ←Finset.sum_range_succ']
      apply Finset.sum_congr rfl
      intro k _
      rw [mul_comm _ 3, ←pow_succ', mul_comm (3 : ZMod 5)]
    · rw [B_sum, B_sum, A_sum, Finset.sum_range_succ, Finset.sum_range_succ, Finset.sum_range_succ]
      simp only [Nat.choose_succ_succ, Nat.cast_add, Finset.sum_add_distrib, add_assoc]
      congr 1
      simp only [Nat.choose_succ_self, Nat.choose_zero_right, Nat.cast_add, Nat.cast_one, 
                 pow_zero, mul_one, add_right_eq_self]
      apply Finset.sum_eq_zero
      intro k hk
      rw [Finset.mem_range] at hk
      have : m < 2 * k + 1 := by linarith
      simp [Nat.choose_eq_zero_of_lt this]

  -- Show that v m matches the sums
  have hv (m : ℕ) : v m = (A_sum m, B_sum m) := by
    induction m with
    | zero => simp [v, A_sum, B_sum]
    | succ m ih =>
      rw [v, Function.iterate_succ_apply', step, ih]
      ext <;> simp [h_rec m]

  -- Relate S to v (2n+1)
  have h_match : (S : ZMod 5) = (v (2 * n + 1)).2 := by
    rw [hv]
    dsimp [B_sum, S]
    -- The sum S goes up to n, B_sum goes up to 2n+1, but terms > n are zero
    rw [Finset.sum_subset (Finset.range_subset.mpr (by linarith))]
    · apply Finset.sum_congr rfl
      intro k _
      norm_cast
      rw [show (8 : ZMod 5) = 3 by rfl, ←pow_mul, mul_comm k 3, pow_mul]
    · intro k _ hk
      simp at hk
      have : 2 * n + 1 < 2 * k + 1 := by linarith
      simp [Nat.choose_eq_zero_of_lt this]

  -- Analyze the periodicity of v modulo 6
  -- We calculate step^6 (a, b) = (3a, 3b)
  have h_step6 (u : ZMod 5 × ZMod 5) : step^[6] u = (3 * u.1, 3 * u.2) := by
    simp only [step]
    -- Manual iteration or ring simplifier
    have h_lin (a b : ZMod 5 × ZMod 5) : step (a + b) = step a + step b := by
      simp [step]; ext <;> ring
    -- It suffices to check on basis vectors (1,0) and (0,1)
    have h1 : step^[6] (1, 0) = (3, 0) := by decide
    have h2 : step^[6] (0, 1) = (0, 3) := by decide
    rw [prod_mk_eq_add_mul_mk u, h_lin, Function.iterate_add_apply, h_lin, h1, h2]
    ext <;> ring

  -- Show that v m .2 is zero iff m is a multiple of 6
  have h_zero_iff (m : ℕ) : (v m).2 = 0 ↔ m % 6 = 0 := by
    induction m using Nat.strong_induction_on with
    | h m ih =>
      if h : m < 6 then
        interval_cases m <;> decide
      else
        let k := m - 6
        have heq : m = k + 6 := (Nat.sub_eq_iff_eq_add (le_of_not_lt h)).mp rfl
        rw [heq, v, Function.iterate_add_apply, h_step6]
        simp [ih k (Nat.sub_lt (le_of_not_lt h) (by norm_num))]
        rw [← Nat.add_mod_right k 6, ← heq]

  -- 2n+1 is never divisible by 6
  rw [h_match, h_zero_iff] at hS
  have : (2 * n + 1) % 6 % 2 = 1 := by
    rw [Nat.add_mod, Nat.mul_mod]
    norm_num
  rw [hS] at this
  contradiction
