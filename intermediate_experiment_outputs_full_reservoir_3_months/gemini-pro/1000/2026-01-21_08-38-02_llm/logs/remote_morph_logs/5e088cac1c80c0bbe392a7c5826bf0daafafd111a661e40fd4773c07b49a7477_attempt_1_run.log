theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  rw [← ZMod.nat_cast_zmod_eq_zero_iff_dvd] at h
  simp_rw [pow_mul, show (2 : ZMod 5) ^ 3 = 3 by decide] at h
  
  let m := 2 * n + 1
  let A : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  
  -- A = I + M and M^2 = 3I
  have AM : A = 1 + M := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  have M2 : M ^ 2 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by 
    ext i j; fin_cases i <;> fin_cases j <;> simp [M, Matrix.mul_apply, Fin.sum_univ_two] <;> rfl

  -- The sum corresponds to the (1,0) entry of A^m
  have sum_eq : (∑ k ∈ Finset.range (n + 1), ((m.choose (2 * k + 1)) : ZMod 5) * 3 ^ k) = (A ^ m) 1 0 := by
    rw [AM, add_pow]
    let f (k : ℕ) := ((m.choose k) : ZMod 5) • M ^ k
    -- Project to (1,0) entry
    trans ∑ k ∈ Finset.range (m + 1), (f k) 1 0
    · simp [Matrix.sum_apply]
    -- Split into even and odd indices
    rw [← Finset.sum_filter_add_sum_filter_not (· % 2 = 1)]
    -- Even terms are 0 because M^(2k) = 3^k I, so (1,0) entry is 0
    have even_zero : ∀ x ∈ Finset.filter (λ x => ¬x % 2 = 1) (Finset.range (m + 1)), (f x) 1 0 = 0 := by
      intro x hx
      rw [Finset.mem_filter, Nat.odd_iff_not_even] at hx
      simp at hx
      obtain ⟨k, rfl⟩ := Nat.dvd_of_mod_eq_zero (Nat.not_not.mp hx.2)
      rw [pow_mul, M2, Matrix.smul_pow, Matrix.smul_apply, Matrix.one_apply]
      simp
    rw [Finset.sum_eq_zero even_zero, add_zero]
    -- Odd terms match the sum
    let g : ℕ ↪ ℕ := ⟨λ k => 2 * k + 1, λ a b h => by linarith⟩
    rw [Finset.sum_emb_domain g]
    · apply Finset.sum_congr
      · ext k; simp; constructor
        · intro hk; rw [Finset.mem_filter]; constructor; linarith; simp
        · intro hk; rw [Finset.mem_filter] at hk; linarith
      · intro k hk
        -- M^(2k+1) = 3^k M. (1,0) entry is 3^k * 1
        rw [pow_add, pow_one, pow_mul, M2, Matrix.smul_pow, Matrix.mul_smul, Matrix.smul_apply, Matrix.mul_apply]
        simp [M]
    · simp [Matrix.smul_apply]

  rw [sum_eq] at h

  -- Periodicity of v_k = (A^k)_{1,0}
  let v (k : ℕ) := (A ^ k) 1 0
  have A3 : A ^ 3 = M := by rw [AM, add_pow]; decide
  have A6 : A ^ 6 = 3 • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    rw [show A^6 = (A^3)^2 by ring, A3, M2]
  
  have v_step (k : ℕ) : v (k + 6) = 3 * v k := by
    simp [v, pow_add, A6, Matrix.mul_apply, Matrix.smul_apply, Matrix.one_apply]

  -- Show v(2k+1) is never 0
  have v_nz : ∀ k, v (2 * k + 1) ≠ 0 := by
    intro k
    induction' k using Nat.strong_induction_on with k ih
    by_cases hk : k < 3
    · interval_cases k
      · show v 1 ≠ 0; decide
      · show v 3 ≠ 0; rw [show v 3 = 1 by decide]; decide
      · show v 5 ≠ 0; rw [show v 5 = 4 by decide]; decide
