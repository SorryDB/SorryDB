        constructor
        · apply Nat.div_lt_of_lt_mul; rw [Nat.mul_comm]; exact Nat.lt_of_succ_le (le_trans (Nat.le_of_eq h2.symm) (Nat.le_succ _)) -- rough bound check
          linarith [Nat.mod_two_eq_one_iff_ne_zero.mp h2]
        · rw [Nat.mul_div_cancel' (Nat.mod_two_eq_one_iff_ne_zero.mp h2)]; simp [h2]
          omega
      · rintro ⟨y, hy, rfl⟩
        simp
        omega
        
    rw [h_map, Finset.sum_image]
    · apply Finset.sum_congr rfl
      intro k hk
      simp only [f]
      -- Calculate A^(2k+1) 1 0
      have hA_odd : (A ^ (2 * k + 1)) 1 0 = 3 ^ k := by
        have hA2 : A ^ 2 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by decide
        rw [pow_add, pow_mul, hA2, pow_one]
        simp
      rw [hA_odd]
    · intro x _ y _ h; omega

  rw [← h_sum] at h
  
  -- Use M^3 = A
  have hM3 : M ^ 3 = A := by 
    rw [hM]; decide
  
  -- Calculate M^m based on m % 3
  have h_nonzero : (M ^ m) 1 0 ≠ 0 := by
    -- m = 2n+1.
    -- Consider m mod 3.
    let q := m / 3
    let r := m % 3
    have hm_eq : m = 3 * q + r := (Nat.div_add_mod m 3).symm
    rw [hm_eq, pow_add, pow_mul, hM3]
    
    have h_odd_m : m % 2 = 1 := by simp [m]
    have h_cases : r = 0 ∨ r = 1 ∨ r = 2 := by omega
    
    rcases h_cases with rfl | rfl | rfl
    · -- m = 3q. m odd => q odd. A^q 1 0 = 3^... != 0
      have hq_odd : q % 2 = 1 := by 
        have : (3 * q) % 2 = 1 := by rw [← hm_eq]; exact h_odd_m
        simpa [Nat.mul_mod] using this
      obtain ⟨k, rfl⟩ := Nat.exists_eq_add_of_odd hq_odd
      rw [pow_add, pow_mul, show A^2 = (3 : ZMod 5) • 1 by decide, pow_one]
      simp [A]
    · -- m = 3q + 1. m odd => 3q even => q even.
      have hq_even : q % 2 = 0 := by
        have : (3 * q + 1) % 2 = 1 := by rw [← hm_eq]; exact h_odd_m
        omega
      obtain ⟨k, rfl⟩ := Nat.exists_eq_mul_left_of_dvd (Nat.dvd_of_mod_eq_zero hq_even)
      rw [pow_mul, show A^2 = (3 : ZMod 5) • 1 by decide]
      simp [M, A]
      decide
    · -- m = 3q + 2. m odd => 3q odd => q odd.
      have hq_odd : q % 2 = 1 := by
        have : (3 * q + 2) % 2 = 1 := by rw [← hm_eq]; exact h_odd_m
        omega
      obtain ⟨k, rfl⟩ := Nat.exists_eq_add_of_odd hq_odd
      rw [pow_add, pow_mul, show A^2 = (3 : ZMod 5) • 1 by decide, pow_one]
      simp only [Matrix.mul_smul, Matrix.one_mul, Matrix.smul_mul]
      -- Calculate A * M^2 * 3^k
      -- A * M^2 = A * (1+A)^2 = A * (1 + 2A + 3) = 4A + 2(3) = 4A + 1
      -- (4A + 1) 1 0 = 4(1) + 0 = 4 != 0
      -- Just use decide for the matrix part
      have : (A * (M ^ 2)) 1 0 = 4 := by rw [hM]; decide
      rw [this]
      intro h_contra
      have : (3 : ZMod 5) ^ k * 4 = 0 := h_contra
      -- 3^k is unit, 4 is unit
      apply (show (4 : ZMod 5) ≠ 0 by decide)
      apply (IsUnit.mul_eq_zero_iff_eq_zero (isUnit_of_prime_pow_eq_one (p := 5) (k := 4 * k) _ _)).mp at this
      · exact this
      · exact Nat.prime_five
      · rw [← pow_mul]; norm_num; exact one_pow k
  
  exact h_nonzero h
