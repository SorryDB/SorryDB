        · left; use k; linarith
        · right; use k; linarith
      · rintro (⟨k, hk, rfl⟩ | ⟨k, hk, rfl⟩) <;> linarith
    rw [h_union, Finset.sum_union, Finset.sum_image, Finset.sum_image]
    · simp [An, Sn, f]
      congr 1
      · apply Finset.sum_congr rfl; intro k _; rw [mul_pow, pow_mul, h8]; simp
      · apply Finset.sum_congr rfl; intro k _; rw [mul_pow, pow_add, pow_mul, h8, pow_one]; ring
    · simp; intro x hx y hy h; linarith
    · simp; intro x hx y hy h; linarith
    · simp; intro x hx y hy h; linarith
    · rw [Finset.disjoint_left]; simp; intro a ha b hb h; linarith

