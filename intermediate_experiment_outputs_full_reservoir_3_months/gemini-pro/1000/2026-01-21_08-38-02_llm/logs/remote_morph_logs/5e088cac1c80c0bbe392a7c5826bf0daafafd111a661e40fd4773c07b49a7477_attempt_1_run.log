  have h_sum : (M ^ m) 1 0 = ∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1) : ZMod 5) * 3 ^ k := by
    rw [add_pow]
    simp only [Matrix.sum_apply, Matrix.smul_apply, Matrix.pow_apply, Matrix.one_apply]
    
    -- Filter even and odd terms
    let odd_terms := (Finset.range (m + 1)).filter (fun x => x % 2 = 1)
    let even_terms := (Finset.range (m + 1)).filter (fun x => x % 2 = 0)
    
    have h_union : (Finset.range (m + 1)) = odd_terms ∪ even_terms := by
      ext x; simp [odd_terms, even_terms]; apply Nat.mod_two_eq_zero_or_one
    have h_disj : Disjoint odd_terms even_terms := by
      rw [Finset.disjoint_filter]; auto
      
    rw [h_union, Finset.sum_union h_disj]
    
    -- Even terms are zero in the (1,0) component
    have h_even : ∑ x ∈ even_terms, (Nat.choose m x : ZMod 5) * (A ^ x) 1 0 = 0 := by
      apply Finset.sum_eq_zero
      intro x hx
      simp only [even_terms, Finset.mem_filter] at hx
      obtain ⟨_, h_even⟩ := hx
      obtain ⟨j, rfl⟩ := Nat.exists_eq_succ_of_ne_zero (by rintro rfl; simp at h_even) -- Handle 0 separately?
      -- Actually just prove A^x 1 0 = 0 for even x
      obtain ⟨j, rfl⟩ := Nat.dvd_of_mod_eq_zero (Nat.mod_two_eq_zero_iff_eq_zero_or_one_mod_two.mp (Or.inl h_even))
      have hA2 : A ^ 2 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by decide
      rw [pow_mul, hA2]
      simp
      
    rw [h_even, add_zero]
    
    -- Map odd terms to range (n+1)
    let f : ℕ → ℕ := fun k => 2 * k + 1
    have h_map : odd_terms = (Finset.range (n + 1)).image f := by
      ext x
