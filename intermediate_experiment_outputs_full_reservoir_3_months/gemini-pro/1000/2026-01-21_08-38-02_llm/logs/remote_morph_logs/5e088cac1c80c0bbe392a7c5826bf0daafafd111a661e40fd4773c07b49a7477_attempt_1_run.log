theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  intro h
  let s := ∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k))
  have h5 : s % 5 = 0 := Nat.mod_eq_zero_of_dvd h
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let S : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  have hM : M = 1 + S := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  have hS2 : S ^ 2 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    ext i j; fin_cases i <;> fin_cases j <;> rfl
  have h_sum : (s : ZMod 5) = (M ^ (2 * n + 1)) 1 0 := by
    rw [hM, add_pow, Finset.sum_apply]
    let f (k : ℕ) : ZMod 5 := (Nat.choose (2 * n + 1) k) * ((S ^ k) 1 0)
    trans ∑ k ∈ Finset.range (2 * n + 2), f k
    · apply Finset.sum_congr rfl; intro k _; rfl
    rw [← Finset.sum_filter_add_sum_filter (· % 2 = 1)]
    have h_even : ∀ k ∈ Finset.filter (· % 2 = 0) (Finset.range (2 * n + 2)), f k = 0 := by
      intro k hk; simp [f]; rw [Finset.mem_filter] at hk
      have : (S ^ k) 1 0 = 0 := by
        obtain ⟨j, hj⟩ := Nat.dvd_of_mod_eq_zero hk.2
        rw [hj, pow_mul, hS2]; simp; rfl
      rw [this, mul_zero]
    rw [Finset.sum_eq_zero h_even, zero_add]
    apply Finset.sum_bij (fun k _ ↦ 2 * k + 1)
    · intro k hk; rw [Finset.mem_filter, Finset.mem_range] at hk ⊢; constructor <;> linarith
    · intro k hk
      simp [f]
      have hSk : (S ^ (2 * k + 1)) 1 0 = 3 ^ k := by
        rw [pow_add, pow_mul, hS2, Matrix.smul_pow, one_pow, Matrix.smul_mul, Matrix.one_mul, pow_one, Matrix.smul_apply, S]; rfl
      rw [hSk]; norm_cast; congr; linarith
    · intro _ _ _ _ h; linarith
    · intro y hy; rw [Finset.mem_filter, Finset.mem_range] at hy
      exists (y - 1) / 2; constructor
      · rw [Finset.mem_range]; apply Nat.div_lt_of_lt_mul; linarith
      · dsimp; have : y % 2 = 1 := hy.2; omega
  have h_per : (M ^ (2 * (n + 6) + 1)) 1 0 = - (M ^ (2 * n + 1)) 1 0 := by
    have hM2 : M ^ 2 = !![4, 1; 2, 4] := by ext i j; fin_cases i <;> fin_cases j <;> rfl
    have hM6 : M ^ 6 = -1 := by
      have hM4 : M ^ 4 = !![3, 3; 1, 3] := by rw [show 4 = 2 * 2 by rfl, pow_mul, hM2]; ext i j; fin_cases i <;> fin_cases j <;> rfl
      rw [show 6 = 4 + 2 by rfl, pow_add, hM4, hM2]; ext i j; fin_cases i <;> fin_cases j <;> rfl
    rw [mul_add, add_assoc, pow_add, show 2 * 6 = 12 by rfl, show 12 = 6 * 2 by rfl, pow_mul, hM6]
    simp; rfl
  let u (k : ℕ) := (M ^ (2 * k + 1)) 1 0
  have h_ne_zero : ∀ k < 6, u k ≠ 0 := by
    decide
  have h_all : ∀ k, u k ≠ 0 := by
    intro k
    induction k using Nat.strong_induction_on with | h k ih =>
    if hk : k < 6 then exact h_ne_zero k hk else
    let k' := k - 6
    have : k = k' + 6 := by omega
    rw [this, show u (k' + 6) = - u k' from h_per]
    simp; apply ih k'; omega
  rw [h_sum] at h5
  exact h_all n h5
