  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  let m := 2 * n + 1
  -- Define integer sums Sn and An
  let Sn := ∑ k ∈ Finset.range (n + 1), ((m.choose (2 * k + 1)) : ℤ) * 8 ^ k
  let An := ∑ k ∈ Finset.range (n + 1), ((m.choose (2 * k)) : ℤ) * 8 ^ k

  -- Relate goal to Sn
  have h_goal : ∑ k ∈ Finset.range (n + 1), (m.choose (2 * k + 1)) * (2^(3 * k)) = (Sn : ℕ) := by
    rw [← Int.coe_nat_eq_coe_nat_iff]; simp [Sn]
    apply Finset.sum_congr rfl; intro k _; rw [pow_mul]; norm_cast
  rw [h_goal]; intro h_div; have h_Sn_div : (5 : ℤ) ∣ Sn := Int.coe_nat_dvd.mp h_div

  -- Work in Real to establish algebraic identity
  let r8 := Real.sqrt 8
  have h8 : r8 ^ 2 = 8 := Real.sq_sqrt (by norm_num)
  
