theorem imo_1974_p3
  (n : ℕ) :
  ¬ 5∣∑ k ∈ Finset.range (n + 1), (Nat.choose (2 * n + 1) (2 * k + 1)) * (2^(3 * k)) := by
  -- We work in ZMod 5
  let S_z : ℕ → ZMod 5 := λ m => ∑ k in range (m + 1), (2 * m + 1).choose (2 * k + 1) * 3 ^ k
  
  -- The target expression modulo 5 corresponds to S_z n because 2^(3k) = 8^k = 3^k mod 5.
  have h_cong : (∑ k in range (n + 1), (2 * n + 1).choose (2 * k + 1) * 2 ^ (3 * k) : ℤ) % 5 = (S_z n).val := by
    rw [S_z]
    push_cast
    apply congr_arg
    refine sum_congr rfl (λ k hk => ?_)
    rw [show (2 : ZMod 5) ^ (3 * k) = 3 ^ k by ring_nf; rw [pow_mul, show (2 : ZMod 5)^3 = 3 by rfl]]
    rfl
  
  -- We identify S_z n with the (1, 0) entry of M^(2n+1)
  let M : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![1, 3; 1, 1]
  let U : Matrix (Fin 2) (Fin 2) (ZMod 5) := !![0, 3; 1, 0]
  
  have hM : M = 1 + U := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  have hU2 : U ^ 2 = (3 : ZMod 5) • (1 : Matrix (Fin 2) (Fin 2) (ZMod 5)) := by
    ext i j; fin_cases i <;> fin_cases j <;> simp [Matrix.mul_apply, Fin.sum_univ_two, U]
    
  have h_pow (m : ℕ) : (M ^ (2 * m + 1)) 1 0 = S_z m := by
    rw [hM, add_pow]
    simp only [Matrix.one_mul, Matrix.mul_one]
    let f : ℕ → ZMod 5 := λ k => (2 * m + 1).choose k * (U ^ k) 1 0
    change ∑ k in range (2 * m + 1 + 1), f k = _
    rw [sum_range_succ]
    -- The last term (k = 2m+2) is zero because choose (2m+1) (2m+2) = 0
    have : f (2 * m + 2) = 0 := by simp [f, Nat.choose_eq_zero_of_lt (lt_succ_self _)]
    rw [this, add_zero, sum_range_succ]
    -- The term (k = 2m+1) is included.
    -- Split sum into even and odd indices
    rw [← sum_filter_add_sum_filter_not (· % 2 = 1)]
    -- Even terms are 0 because (U^(2j)) 1 0 = (3^j I) 1 0 = 0
    have h_even : ∑ k in filter (λ x => x % 2 ≠ 1) (range (2 * m + 2)), f k = 0 := by
      apply sum_eq_zero; intro x hx
      obtain ⟨j, hj⟩ : ∃ j, x = 2 * j := exists_eq_mul_right_of_dvd (Nat.dvd_of_mod_eq_zero (Nat.ne_of_eq_of_ne (mem_filter.1 hx).2 (by decide)))
      rw [hj, f, pow_mul, hU2]; simp
    rw [h_even, add_zero]
    -- Odd terms map to S_z m
    -- range (2m+2) filtered by odd is {1, 3, ..., 2m+1}. Map k -> 2k+1 is bijection from range (m+1).
    let g : ℕ ↪ ℕ := ⟨λ k => 2 * k + 1, λ a b h => by linarith⟩
    rw [← sum_map _ g]
    apply sum_congr rfl
    intro k hk
    simp only [f, g, Function.Embedding.coeFn_mk]
    -- Simplify (U^(2k+1)) 1 0
    rw [pow_succ, pow_mul, hU2]
    simp [Matrix.smul_mul, U]
  
  -- The sequence v_n = M^(2n+1) satisfies v_{n+1} = v_n * M^2
  let Q := M ^ 2 -- !![4, 1; 2, 4]
  have hQ : Q = !![4, 1; 2, 4] := by ext i j; fin_cases i <;> fin_cases j <;> rfl
  
  -- We compute the first 12 values of S_z manually or by periodicity
  let vals : List (ZMod 5) := [1, 1, 4, 3, 3, 2, 4, 4, 1, 2, 2, 3]
  have h_vals : ∀ k < 12, S_z k = vals.get ⟨k, by assumption⟩ := by
    -- Verification for small k
    intro k hk
    fin_cases k <;> (rw [← h_pow]; rfl)
    
  -- Periodicity of the sequence (M^(2n+1)) n
  -- M^24 = I mod 5. We check Q^12 = I.
  have h_per : ∀ k, S_z (k + 12) = S_z k := by
    intro k
    rw [← h_pow, ← h_pow]
    have : 2 * (k + 12) + 1 = (2 * k + 1) + 24 := by ring
    rw [this, pow_add, show M ^ 24 = 1 by decide, Matrix.mul_one]

  -- Final check
  intro h_div
  have h0 : (S_z n).val = 0 := by
    rw [← h_cong, ZMod.val_cast_of_nat]
    exact Nat.mod_eq_zero_of_dvd h_div
  
  let r := n % 12
  have hr : r < 12 := Nat.mod_lt _ (by decide)
  have h_eq : S_z n = S_z r := by
    have : n = r + 12 * (n / 12) := (Nat.mod_add_div n 12).symm
    nth_rewrite 1 [this]
    induction n / 12 with | zero => simp | succ k ih => rw [Nat.mul_succ, ← add_assoc, h_per, ih]
  
  rw [h_eq, h_vals r hr] at h0
  -- Check that no value in vals is 0
  fin_cases r <;> simp at h0
