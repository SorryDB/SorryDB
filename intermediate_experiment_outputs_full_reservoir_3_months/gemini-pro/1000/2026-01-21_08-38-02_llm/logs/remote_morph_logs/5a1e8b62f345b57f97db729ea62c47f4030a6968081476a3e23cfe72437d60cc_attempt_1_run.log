theorem imo_1988_p3 (f : ℕ → ℕ) (h₀ : ∀ n, 0 < n → 0 < f n) (h₁ : f 1 = 1) (h₂ : f 3 = 3)
    (h₃ : ∀ n > 0, f (2 * n) = f n) (h₄ : ∀ n > 0, f (4 * n + 1) = 2 * f (2 * n + 1) - f n)
    (h₅ : ∀ n > 0, f (4 * n + 3) = 3 * f (2 * n + 1) - 2 * f n) :
    (Finset.filter (fun n => f n = n) (Finset.Icc 1 1988)).card = 92 := by
  let g (n : ℕ) := Nat.ofDigits 2 (Nat.digits 2 n).reverse
  have hg : ∀ n, 0 < n → f n = g n := by
    intro n hn
    induction n using Nat.strong_induction_on with | h n ih =>
    match n with
    | 0 => contradiction
    | 1 => rw [h₁]; rfl
    | 2 => rw [h₃ 1 (by norm_num), h₁, show g 2 = 1 by rfl]
    | 3 => rw [h₂]; rfl
    | n + 4 =>
      let n := n + 4
      have : n > 3 := by omega
      if h_ev : n % 2 = 0 then
