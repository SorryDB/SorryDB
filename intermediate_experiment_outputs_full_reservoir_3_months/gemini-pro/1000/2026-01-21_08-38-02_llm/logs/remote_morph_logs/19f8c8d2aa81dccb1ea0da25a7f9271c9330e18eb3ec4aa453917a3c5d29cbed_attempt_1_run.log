lemma fail₁ :
  ∀ {w : ℕ} {args : Vector (ZMod p) w} {cs : Cs p (ZMod p)},
    ¬ assert_bits args -> (assert_bits_e args cs).eval = .n := by
  intro w
  induction w with
  | zero =>
    intros args cs h
    simp [assert_bits, Vector.all_nil] at h
  | succ w ih =>
    intros args cs h
    have h_cons : args = Vector.cons args.head args.tail := (Vector.cons_head_tail _).symm
    rw [h_cons] at h ⊢
    rw [assert_bits, Vector.all_cons] at h
    simp only [Bool.not_and, Bool.not_eq_true] at h
    rw [assert_bits_e, Vector.foldl, Vector.toList_cons, List.foldl_cons, ← Vector.foldl, ← assert_bits_e]
    cases h with
    | inl h_bad =>
      have prop : ∀ {w} (v : Vector (ZMod p) w) (c : Cs p (ZMod p)), c.eval = .n -> (assert_bits_e v c).eval = .n := by
        intro w v c hc
        induction w with
        | zero => simp [assert_bits_e, Vector.foldl, hc]
        | succ w ih' =>
           have hv : v = Vector.cons v.head v.tail := (Vector.cons_head_tail _).symm
           rw [hv, assert_bits_e, Vector.foldl, Vector.toList_cons, List.foldl_cons, ← Vector.foldl, ← assert_bits_e]
           apply ih'
           unfold assert_bit_e Cs.eval
           rw [hc]; split <;> rfl
      apply prop
      unfold assert_bit_e Cs.eval
      simp only [Exp.eval]
      have : args.head * (1 - args.head) ≠ 0 := by
        intro z; simp [sub_eq_zero] at z; cases z <;> { apply h_bad; simp [*, beq_iff_eq] }
      rw [if_neg this]
    | inr h_tail => apply ih h_tail
