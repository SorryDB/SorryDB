    not_forall, not_or] at h
  rcases h with ⟨i, h, h', h''⟩
  revert cs i
  induction w with
  | zero =>
    intro i hi
    contradiction
  | succ w ih =>
    intro i hi h0 h1 cs
    rw [←Vector.cons_head_tail args]
    simp only [assert_bits_e, Vector.foldl, List.foldl_cons, Vector.toList_cons]
    by_cases h_idx : i = 0
