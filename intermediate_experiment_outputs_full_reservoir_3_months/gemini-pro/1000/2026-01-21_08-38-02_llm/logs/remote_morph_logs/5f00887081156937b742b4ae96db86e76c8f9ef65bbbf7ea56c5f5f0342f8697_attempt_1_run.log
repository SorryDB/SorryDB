  congr 1
  apply (MeasurableEmbedding.subtype_coe (Set.Ici 0)).map_injective
  simp only [Measure.map_map (measurable_embedding_subtype_coe _).measurable (measurable_add_const a)]
  have : ((↑) : ℝ≥0 → ℝ) ∘ (fun t ↦ t + a) = (fun x ↦ x + a) ∘ ((↑) : ℝ≥0 → ℝ) := by
    ext; simp
  rw [this, Measure.map_map (measurable_add_const a) (measurable_embedding_subtype_coe _).measurable]
  rw [NNReal.map_coe_volume, Measure.map_restrict _ (measurable_add_const a) measurableSet_Ici (Homeomorph.addRight (a : ℝ)).injective.injOn]
  rw [Measure.map_add_right_eq_self, Set.image_add_right_Ici, zero_add]
  rw [NNReal.map_coe_volume, Measure.restrict_restrict measurableSet_Ici]
  congr
  ext x
  simp only [Set.mem_inter_iff, Set.mem_Ici]
  constructor
  · rintro ⟨h1, h2⟩
    exact h2
  · intro h
    exact ⟨(NNReal.coe_nonneg a).trans h, h⟩
