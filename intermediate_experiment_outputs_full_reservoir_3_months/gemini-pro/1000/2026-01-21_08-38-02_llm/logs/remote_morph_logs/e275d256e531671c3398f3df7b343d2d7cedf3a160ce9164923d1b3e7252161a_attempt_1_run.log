instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  refine discreteTopology_of_isOpen_singleton_one _ ?_
  let V := {z : UnitCircle | 0 < z.re}
  have hV : IsOpen V := continuous_re.isOpen_preimage _ isOpen_Ioi
  let U := {f : PontryaginDual M | f '' Set.univ ⊆ V}
  have hU : IsOpen U := by
    rw [← Set.image_subset_iff]
    exact continuous_induced_dom.isOpen_preimage _ (ContinuousMap.isOpen_setOf_mapsTo isCompact_univ hV)
  convert hU
  ext f
  simp only [Set.mem_singleton_iff, Set.mem_setOf_eq, Set.image_subset_iff, Set.mem_univ, Set.subset_def, forall_true_left]
  constructor
  · intro h
    ext x
    let z := f x
    have hz : ∀ n : ℕ, 0 < (z ^ n).re := fun n ↦ h (x ^ n)
    by_contra h_ne
    have h_arg : z.val.arg ≠ 0 := mt (fun ha ↦ Subtype.ext <| by
      rw [← Complex.abs_mul_exp_arg_mul_I z.val, ha, Complex.ofReal_zero, mul_zero, Complex.exp_zero, mul_one, UnitCircle.abs_coe, Complex.ofReal_one]) h_ne
    let θ := |z.val.arg|
    have hθ : 0 < θ ∧ θ < Real.pi / 2 := by
      rw [abs_pos, abs_lt]
      exact ⟨h_arg, (Complex.arg_gt_neg_pi_div_two_of_re_pos (hz 1)).out.1, (Complex.arg_lt_pi_div_two_of_re_pos (hz 1)).out.2⟩
    obtain ⟨n, hn_le, hn_ge⟩ : ∃ n : ℕ, Real.pi / 2 ≤ n * θ ∧ n * θ ≤ Real.pi := by
      obtain ⟨n, hn⟩ := Archimedean.arch (Real.pi / 2) hθ.1
      let P := fun k => Real.pi / 2 ≤ k * θ
      have hP : ∃ k, P k := ⟨n, hn⟩
      let m := @Nat.find P (Classical.decPred P) hP
      refine ⟨m, Nat.find_spec hP, ?_⟩
      have hm0 : 0 < m := Nat.pos_of_ne_zero fun h0 ↦ by
        simp [P, m, h0] at Nat.find_spec hP; linarith [Real.pi_pos]
      have := @Nat.find_min P (Classical.decPred P) hP (m - 1) (Nat.pred_lt (ne_of_gt hm0))
      rw [not_le] at this
      calc
        (m : ℝ) * θ = (m - 1 : ℝ) * θ + θ := by simp; ring
        _ < Real.pi / 2 + θ := add_lt_add_right this _
        _ < Real.pi / 2 + Real.pi / 2 := add_lt_add_left hθ.2 _
        _ = Real.pi := by ring
    have h_re : (z ^ n).re ≤ 0 := by
      rw [UnitCircle.pow_val, ← Complex.exp_nat_mul_im_mul_I, ← Complex.abs_mul_exp_arg_mul_I z.val, UnitCircle.abs_coe, Complex.ofReal_one, one_mul]
      rw [Complex.exp_pow, ← Complex.exp_nat_mul, Complex.exp_mul_I, Complex.cos_sin_mul]
      cases lt_or_gt_of_ne h_arg with
