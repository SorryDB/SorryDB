import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_open_singleton_one]
  let V := {z : Circle | 0 < z.re}
  have hV : IsOpen V := continuous_re.isOpen_preimage _ isOpen_Ioi
  refine ⟨{f | ∀ x, f x ∈ V}, ContinuousMap.isOpen_gen isCompact_univ hV, ?_⟩
  ext f
  constructor
  · intro hf
    ext x
    let z := f x
    by_contra hz_ne_1
    have h_re : ∀ n : ℕ, 0 < (z ^ n).re := fun n ↦ hf (x ^ n)
    have h_arg : |z.arg| ∈ Set.Ioo 0 (Real.pi / 2) := by
      rw [Set.mem_Ioo, abs_pos, abs_lt, ← Complex.abs_arg_lt_pi_div_two_iff]
      exact ⟨Complex.arg_ne_zero_of_ne_one hz_ne_1, Complex.abs_arg_lt_pi_div_two_of_re_pos (h_re 1)⟩
    let P (k : ℕ) := Real.pi / 2 < k * |z.arg|
    have h_exists : ∃ k, P k := exists_nat_gt (Real.pi / (2 * |z.arg|)) |>.imp fun k hk ↦
      (div_lt_iff' (mul_pos two_pos h_arg.1)).mp hk
    let k := Nat.find h_exists
    have hk_lb : Real.pi / 2 < k * |z.arg| := Nat.find_spec h_exists
    have hk_ub : k * |z.arg| ≤ Real.pi := by
      cases k with
      | zero => field_simp at hk_lb; linarith [Real.pi_pos]
      | succ k' =>
        have h_pred : ¬ P k' := Nat.find_min h_exists (Nat.lt_succ_self k')
        simp [P, not_lt] at h_pred
        calc (k' + 1) * |z.arg| = k' * |z.arg| + |z.arg| := by push_cast; ring
          _ ≤ Real.pi / 2 + |z.arg| := add_le_add_right h_pred _
          _ ≤ Real.pi / 2 + Real.pi / 2 := add_le_add_left (le_of_lt h_arg.2) _
          _ = Real.pi := by ring
    have h_neg : (z ^ k).re ≤ 0 := by
      rw [← Complex.cos_arg, Complex.arg_pow_of_normal_angle]
      · exact Real.cos_nonpos_of_pi_div_two_le_of_le_pi (le_of_lt hk_lb) hk_ub
      · rw [abs_mul, abs_of_nonneg (Nat.cast_nonneg _)]; exact hk_ub
    exact not_lt_of_le h_neg (h_re k)
  · rintro rfl x; exact zero_lt_one
