instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  refine discreteTopology_of_isOpen_singleton_one ?_
  let V := {z : Circle | 0 < (z : ℂ).re}
  have hV : IsOpen V := continuous_subtype_val.isOpen_preimage _ (continuous_re.isOpen_preimage _ isOpen_Ioi)
  let U := {f : PontryaginDual M | f '' Set.univ ⊆ V}
  have hU : IsOpen U := by
    rw [isOpen_induced_iff]
    exact ⟨ContinuousMap.gen Set.univ V, ContinuousMap.isOpen_gen isCompact_univ hV, rfl⟩
  suffices U ⊆ {1} by
    rw [← Set.subset_singleton_iff_eq] at this
    exact this ⟨fun _ ↦ by simp [V, zero_lt_one], hU⟩
  intro f hf
  ext x
  by_contra hx
  let z := f x
  have z_ne : (z : ℂ) ≠ 1 := fun h ↦ hx (Subtype.ext h)
  have range_cpct : IsCompact (f '' Set.univ) := isCompact_univ.image f.continuous
  obtain ⟨w, hw_mem, hw_min⟩ := range_cpct.exists_forall_le hf 
    ⟨1, ⟨1, trivial, f.map_one⟩, by simp [V, zero_lt_one]⟩ continuous_re.continuousOn
  let δ := (w : ℂ).re
  have hδ : 0 < δ := hw_min w hw_mem
  obtain ⟨n, hn⟩ := exists_nat_gt (2 / (δ * Complex.abs (z - 1)))
  have n_pos : 0 < (n : ℝ) := lt_trans (div_pos two_pos (mul_pos hδ (Complex.abs.pos z_ne))) hn
  let S := (Finset.range n).sum fun i ↦ (z : ℂ) ^ i
  have h_bound : Complex.abs S ≤ 2 / Complex.abs (z - 1) := by
    rw [geom_sum_eq z_ne, map_div₀, Complex.abs_abs]
    gcongr
    rw [sub_eq_add_neg]
    apply (Complex.abs_add _ _).trans
    simp [Complex.abs_pow]
  have h_mean : δ ≤ S.re / n := by
    rw [le_div_iff₀ n_pos, map_sum]
    trans (Finset.range n).sum fun _ ↦ δ
    · simp [nsmul_eq_mul]
    · apply Finset.sum_le_sum; intro i _; exact hw_min _ ⟨x^i, trivial, map_pow f x i⟩
  have h_contra : S.re / n < δ := by
    calc S.re / n ≤ Complex.abs S / n := by gcongr; apply Complex.re_le_abs
      _ ≤ (2 / Complex.abs (z - 1)) / n := by gcongr
      _ = 2 / (n * Complex.abs (z - 1)) := by field_simp; ring
      _ < δ := (div_lt_iff₀ n_pos).mpr (by rwa [mul_comm, ← div_lt_iff' hδ])
  linarith
