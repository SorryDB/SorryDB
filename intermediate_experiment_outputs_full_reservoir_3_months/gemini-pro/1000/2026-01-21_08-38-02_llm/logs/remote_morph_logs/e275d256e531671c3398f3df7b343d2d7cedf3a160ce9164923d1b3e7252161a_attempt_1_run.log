instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [discreteTopology_iff_open_singleton_one]
  let U : Set Circle := {z | 0 < z.val.re}
  have hU : IsOpen U := isOpen_re_pos.preimage continuous_subtype_val
  let V := {f : PontryaginDual M | ∀ x, f x ∈ U}
  have hV_open : IsOpen V :=
    ContinuousMonoidHom.isOpen_of_isOpen_compactOpen (ContinuousMap.isOpen_gen isCompact_univ hU)
  suffices V = {1} by rwa [this] at hV_open
  ext f
  refine ⟨fun hf ↦ ?_, fun h ↦ h ▸ fun _ ↦ zero_lt_one⟩
  let S := MonoidHom.range f.toMonoidHom
  have hS_grp : IsSubgroup (S : Set Circle) := 
    IsCompact.isSubgroup (isCompact_range f.continuous) (MonoidHom.range_isSubmonoid _)
  have : S = ⊥ := by
    by_contra h_ne
    let d (z : Circle) := ‖(z : ℂ) - 1‖
    obtain ⟨w, hw_mem, hw_max⟩ := (isCompact_range f.continuous).exists_forall_le (Set.range_nonempty _) 
      (continuous_norm.comp (continuous_subtype_val.sub continuous_const)).continuousOn
    have hw_re : 0 < w.val.re := hf w (Set.range_subset_iff.mp hw_mem)
    by_cases hw1 : w = 1
    · obtain ⟨z, hz_mem⟩ := Set.exists_of_ssubset (Set.ssubset_iff_subset_ne.mpr ⟨(fun _ _ ↦ hS_grp.one_mem), h_ne⟩)
      have := hw_max z hz_mem
      rw [hw1] at this
      simp only [d, Subtype.coe_one, sub_self, norm_zero] at this
      exact (norm_le_zero_iff.mp this).false
    · have h_abs : 1 < ‖(w : ℂ) + 1‖ := by
        rw [Complex.norm_eq_abs, ← Real.sqrt_lt_sqrt_iff (by positivity), Real.sqrt_one, 
            Complex.abs_add_one_sq]
        simp only [add_lt_add_iff_left, mul_lt_mul_left, Nat.ofNat_pos]
        linarith
      have h_sq : d (w^2) > d w := by
        simp only [d, sq, sub_one_mul, Complex.norm_eq_abs, Complex.abs_mul]
        nth_rewrite 2 [← mul_one (Complex.abs (w-1))]
        apply mul_lt_mul_of_pos_left h_abs
        rwa [Complex.abs.pos_iff, sub_ne_zero, Subtype.coe_ne_coe]
      exact (hw_max (w^2) (hS_grp.pow_mem hw_mem 2)).not_lt h_sq
  ext x
  exact Set.eq_singleton_iff_unique_mem.mp this (Set.mem_range_self x)
