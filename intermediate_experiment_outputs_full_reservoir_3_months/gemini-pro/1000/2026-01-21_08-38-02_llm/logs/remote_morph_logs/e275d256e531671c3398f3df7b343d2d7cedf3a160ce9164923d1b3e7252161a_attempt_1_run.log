import Mathlib.Topology.Algebra.PontryaginDual

namespace PontryaginDual
variable {M : Type*} [Monoid M] [TopologicalSpace M]

/-- A compact monoid has discrete Pontryagin dual. -/
instance [CompactSpace M] : DiscreteTopology (PontryaginDual M) := by
  rw [single_one_open_iff_discrete]
  obtain ⟨U, hU, hU_sub⟩ := TopologicalGroup.exists_neighborhood_one_subgroup_subset Circle
  refine ⟨{f | ∀ x, f x ∈ U}, ContinuousMap.isOpen_setOf_maps_to isCompact_univ hU, ?_⟩
  rw [Set.subset_singleton_iff]
  intro f hf
  rw [Set.image_univ, Set.range_subset_iff] at hf
  let H : Subgroup Circle :=
    { __ := Submonoid.range f
      inv_mem' := (IsCompact.isSubgroup (isCompact_range f.continuous)).inv_mem }
  have key := hU_sub H hf
  ext x
  simpa using key ▸ Set.mem_range_self x
