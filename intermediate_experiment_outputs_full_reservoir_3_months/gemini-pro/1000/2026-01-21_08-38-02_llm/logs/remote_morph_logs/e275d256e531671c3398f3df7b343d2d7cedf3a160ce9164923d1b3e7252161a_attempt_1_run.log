        rw [abs_of_neg neg] at hn_le hn_ge
        rw [Real.cos_eq_cos_neg, neg_mul]
        exact Real.cos_nonpos_of_pi_div_two_le_of_le hn_le hn_ge
      | inr pos =>
        rw [abs_of_pos pos] at hn_le hn_ge
        exact Real.cos_nonpos_of_pi_div_two_le_of_le hn_le hn_ge
