theorem algebra_amgm_faxinrrp2msqrt2geq2mxm1div2x :
  ∀ x > 0, 2 - Real.sqrt 2 ≥ 2 - x - 1 / (2 * x) := by
  intro x hx
  rw [← sub_add_eq_sub_sub, sub_le_sub_iff_left, le_iff_sub_nonneg]
  have h : 0 < 2 * x := by positivity
  have : x + 1 / (2 * x) - Real.sqrt 2 = (Real.sqrt 2 * x - 1) ^ 2 / (2 * x) := by
    field_simp [h.ne']
    ring_nf
    rw [Real.sq_sqrt (by norm_num)]
    ring
  rw [this]
  positivity
