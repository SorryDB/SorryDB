theorem algebra_amgm_faxinrrp2msqrt2geq2mxm1div2x :
  ∀ x > 0, 2 - Real.sqrt 2 ≥ 2 - x - 1 / (2 * x) := by
  intro x hx
  have amgm := Real.sqrt_mul_le_add_div_two (2 * x) (1 / x) (by linarith) (by positivity)
  rw [mul_assoc, mul_one_div_cancel (ne_of_gt hx), mul_one] at amgm
  have : (2 * x + 1 / x) / 2 = x + 1 / (2 * x) := by field_simp; ring
  rw [this] at amgm
  linarith
