  -- The quotient D_𝔸 / D is compact (Fujisaki's lemma premise / Strong Approximation for division algebras)
  -- We assume this standard fact is available or provable in the context of FLT/NumberField libs.
  have hΓ_cocompact : CompactSpace (D_𝔸 ⧸ Γ) := sorry

  -- Let μ be the Haar measure on the quotient
  let μ := MeasureTheory.Measure.haar (G := D_𝔸 ⧸ Γ) Set.univ
  let covol := μ Set.univ
  -- The covolume is finite because the quotient is compact
  have h_covol_lt_top : covol < ⊤ := MeasureTheory.Measure.measure_lt_top _ _

  -- By regularity of Haar measure on D_𝔸, there exists a compact set E with measure > covolume
  -- Note: volume on D_𝔸 is σ-finite and regular.
  obtain ⟨E, hE_comp, hE_meas⟩ := MeasureTheory.Measure.exists_isCompact_measure_gt_of_finite 
    (volume : MeasureTheory.Measure D_𝔸) covol
  
  refine ⟨E, hE_comp, fun φ hφ ↦ ?_⟩
  -- φ preserves the Haar measure because its modular character is 1
  have h_pres : MeasureTheory.MeasurePreserving φ volume volume := by
    rw [MeasureTheory.Measure.addEquivAddHaarChar_eq_volume_map] at hφ
    rw [hφ]
    exact MeasureTheory.MeasurePreserving.id _

  have h_vol_image : volume (φ '' E) = volume E := h_pres.measure_image hE_comp.measurableSet
  rw [← h_vol_image] at hE_meas

  -- Apply Blichfeldt's Lemma: if measure > covolume, there exist distinct elements with difference in Γ
