  -- Use the fact that K is cocompact in 𝔸 to get a compact set K₀ covering D_𝔸 / Γ
  obtain ⟨K_K, hK_K_cp, hK_K_cov⟩ := NumberField.AdeleRing.exists_compact_add_fundamental_domain K
  let K₀ := iso.symm '' (Set.pi Set.univ fun _ ↦ K_K)
  have hK₀_cp : IsCompact K₀ := (IsCompact.pi_set fun _ _ ↦ hK_K_cp).image iso.symm.continuous
  -- Choose E with measure strictly larger than K₀
  obtain ⟨E, hE_cp, hE_vol⟩ := (MeasureTheory.Measure.IsAddHaarMeasure.isRegular_volume).exists_compact_measure_gt_measure hK₀_cp
  refine ⟨E, hE_cp, fun φ hφ ↦ ?_⟩
  -- Show that φ(E) must overlap modulo Γ
  let A := φ '' E
  have hA_vol : volume A > volume K₀ := by
    rw [MeasureTheory.AddEquiv.measure_map_eq_mul_measure_apply φ _ hφ E]
    simpa using hE_vol
  have h_cover : Set.univ ⊆ ⋃ (γ : Γ), (γ : D_𝔸) +ᵥ K₀ := by
    intro x
    have : ∀ i, ∃ k : K, iso x i - algebraMap K _ k ∈ K_K := fun i ↦ hK_K_cov (iso x i)
    choose k hk using this
    let γ := isoD.symm k
    use Algebra.TensorProduct.includeLeft γ
    refine ⟨iso.symm (iso x - iso (Algebra.TensorProduct.includeLeft γ)), ?_, ?_⟩
    · apply (Set.mem_image _ _ _).mpr
      refine ⟨fun i ↦ iso x i - algebraMap K _ (k i), fun i ↦ hk i, ?_⟩
      ext i
      simp only [ContinuousLinearEquiv.apply_symm_apply, ContinuousLinearEquiv.map_sub,
        Pi.sub_apply]
      congr
      -- D𝔸_iso (includeLeft d) = algebraMap (d)
      simp [iso, isoD, γ, Aux.D_iso, Aux.D𝔸_iso, Aux.D_discrete_extracted]
      sorry -- Linear algebra identification of D→D_𝔸 with K^n→𝔸^n
    · simp
  -- Apply Blichfeldt principle manually
  -- If sets (-γ + A) ∩ K₀ were disjoint, their sum would be vol(A) which is > vol(K₀), contradiction.
  -- We assume basic measure theory for covering sets implies overlap.
  -- Specifically: volume A ≤ ∑ volume (A ∩ (γ + K₀)) = ∑ volume ((-γ + A) ∩ K₀)
  -- If all intersections disjoint in K₀ (i.e. no γ1 != γ2 with ...), sum is measure of union inside K₀, so ≤ vol K₀.
