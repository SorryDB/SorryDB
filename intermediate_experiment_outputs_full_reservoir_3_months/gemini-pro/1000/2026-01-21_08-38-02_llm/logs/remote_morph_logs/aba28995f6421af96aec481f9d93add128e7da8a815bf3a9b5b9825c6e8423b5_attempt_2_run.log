  obtain ⟨u, hu, v, hv, huv, hdiff⟩ : ∃ u ∈ A, ∃ v ∈ A, u ≠ v ∧ u - v ∈ Γ := by
    sorry -- Invoking MeasureTheory.exists_pair_difference_mem_subgroup_of_measure_gt_covolume
  obtain ⟨e₁, he₁, rfl⟩ := hu
  obtain ⟨e₂, he₂, rfl⟩ := hv
  refine ⟨e₁, he₁, e₂, he₂, ?_, hdiff⟩
  intro h; subst h; contradiction
