          --• Also kann der Baum unterhalb dieses Vorkommens maximal 2|V| = n Blätter haben
          --(dies sind die Symbole in vwx)
          have decomposition : ∃ u v w x y : Word α,
            z.val = u * v * w * x * y ∧ Word.len (v * x) ≥ 1 ∧ Word.len (v * w * x) ≤ 2^cfg_CNF.val.V.card
            ∧ (∀ k : ℕ, u * (v^k) * w * (x^k) * y ∈ language.val) := sorry
          obtain ⟨u, v, w, x, y, h⟩ := decomposition
          exists u, v, w, x, y
