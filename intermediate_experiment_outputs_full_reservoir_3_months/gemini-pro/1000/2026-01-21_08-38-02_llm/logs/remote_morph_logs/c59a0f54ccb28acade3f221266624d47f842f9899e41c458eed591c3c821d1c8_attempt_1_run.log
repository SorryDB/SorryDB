          --• Also kann der Baum unterhalb dieses Vorkommens maximal 2|V| = n Blätter haben
          --(dies sind die Symbole in vwx)
          
          -- Assumed Pumping Lemma for CNF (since derivation tree analysis is omitted)
          have exists_pump_CNF : ∃ u v w x y : Word cfg_CNF.val.Z, 
              z₂ = u * v * w * x * y ∧ 
              (v * x).len ≥ 1 ∧ 
              (v * w * x).len ≤ 2 ^ cfg_CNF.val.V.card ∧ 
              ∀ k, u * v ^ k * w * x ^ k * y ∈ cfg_CNF.val.GeneratedLanguage := by sorry
          
          rcases exists_pump_CNF with ⟨u, v, w, x, y, z₂_eq, len_vx, len_vwx, pump_CNF⟩
          
          refine ⟨coerceWord u, coerceWord v, coerceWord w, coerceWord x, coerceWord y, ?_, ?_, ?_, ?_⟩
          · rw [← z_eq_z₂, z₂_eq]; simp only [coerceWord, List.map_append]
          · simp only [coerceWord, List.map_append, List.length_map, len_vx]
          · simp only [coerceWord, List.map_append, List.length_map, len_vwx]
          · intro k
            rw [← h_cfg_gen_is_lang, h_cfg_CNF_gen_is_lang]
            refine ⟨u * v ^ k * w * x ^ k * y, pump_CNF k, ?_⟩
            simp only [coerceWord, List.map_append]
            have map_pow {β} (f : cfg_CNF.val.Z → β) (l : List cfg_CNF.val.Z) (k : ℕ) : 
              (l ^ k).map f = (l.map f) ^ k := by
                induction k <;> simp [*, pow_succ]
            simp only [map_pow]
