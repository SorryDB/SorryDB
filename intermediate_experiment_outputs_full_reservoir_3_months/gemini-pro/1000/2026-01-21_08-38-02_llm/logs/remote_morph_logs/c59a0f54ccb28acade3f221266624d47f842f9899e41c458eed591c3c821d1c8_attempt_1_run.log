            rw [h_cfg_gen_is_lang.symm] at h_eps_not_in_language
            have eps_coe : @Word.epsilon α = coerceWord (@Word.epsilon cfg.Z) := by tauto
            rw [eps_coe, ← coerceLang_not_mem] at h_eps_not_in_language
