def deriv_interpolated {n : ℕ} (x y : E n) (f : E n → ℝ) (hf : ContDiff ℝ 1 f) :
    deriv (interpolated x y f) = interpolated_deriv x y f := by
  ext t
  unfold interpolated interpolated_deriv interpolator
  rw [deriv.comp t (hf.differentiable le_rfl _) ((Differentiable.interpolator x y).differentiableAt t)]
  have h_deriv : deriv (fun t : ℝ ↦ (1 - t) • x + t • y) t = y - x := by
    simp only [sub_smul, add_sub_cancel'_right]
    apply HasDerivAt.deriv
    apply HasDerivAt.add
    · apply HasDerivAt.const_smul
      apply HasDerivAt.sub_const
      apply hasDerivAt_id
    · apply HasDerivAt.const_smul
      apply hasDerivAt_id
  rw [h_deriv, InnerProductSpace.Diff.fderiv_eq_inner_gradient, EuclideanSpace.inner_eq_sum_mul]
  congr with i
  rw [nth_partial, RealInnerProductSpace.inner_gradient_left, real_inner_comm]
```
