def answer : Set (ℝ+ → ℝ) := {fun x ↦ 1 / x}

theorem result : {f : ℝ+ → ℝ | (∀ x, 0 < f x) ∧ ∀ x : ℝ+, ∃! y : ℝ+,
    (x : ℝ) * f y + (y : ℝ) * f x ≤ 2} = answer := by
  rw [answer]
  ext f
  constructor
  · rintro ⟨hpos, hunique⟩
    have h_le : ∀ x, (x : ℝ) * f x ≤ 1 := by
      intro x; by_contra! h_gt
      have h_sol_ne : (hunique x).exists.1 ≠ x := by
        intro h; rw [h, ← two_mul] at hunique
        linarith [(hunique x).exists.2]
      let y := (hunique x).exists.1
      have h_xy : (x : ℝ) * f y + y * f x ≤ 2 := (hunique x).exists.2
      have h_yx : (y : ℝ) * f x + x * f y ≤ 2 := by rwa [add_comm]
      have h_y_gt : (y : ℝ) * f y > 1 := by
        by_contra! h; have : x = y := (hunique y).unique h_yx (by linarith); exact h_sol_ne this.symm
      have : 2 < (x : ℝ) * f y + y * f x := calc
        2 < 2 * Real.sqrt ((x * f x) * (y * f y)) := by
           apply Real.mul_lt_mul_of_pos_left _ (by norm_num); rw [Real.sqrt_lt' (by positivity)]; nlinarith
        _ = 2 * Real.sqrt ((x * f y) * (y * f x)) := by ring_nf
        _ ≤ (x : ℝ) * f y + y * f x := Real.two_mul_sqrt_le_add (by positivity) (by positivity)
      linarith
    funext x
    apply eq_one_div_of_mul_eq_one_left
    by_contra! h_ne
