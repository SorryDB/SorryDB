          apply le_of_sub_nonneg; field_simp; exact div_nonneg (sq_nonneg _) (mul_pos x.2 v.2)
        have : (x:ℝ) * f v + v * f x > (x/v) * 1 + (v/x) * 1 := by
          have : (x:ℝ) * f v = (x/v) * (v * f v) := by field_simp; ring
          rw [this]; have : (v:ℝ) * f x = (v/x) * (x * f x) := by field_simp; ring
          rw [this]; gcongr <;> apply f_gt_one
        linarith [hϕ x]
      have le_one (x) : (x:ℝ) * f x ≤ 1 := by have := hϕ x; rwa [fix] at this; linarith
      have eq_one (x) : (x:ℝ) * f x = 1 := by
        by_contra h; push_neg at h; have lt_one := lt_of_le_of_ne (le_one x) h
        let y : ℝ+ := ⟨1 / f x, one_div_pos.2 (hpos x)⟩
