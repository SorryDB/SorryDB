      let ϕ (x : ℝ+) := (h_uniq x).exists.choose
      have hϕ (x) : (x:ℝ) * f (ϕ x) + ϕ x * f x ≤ 2 := (h_uniq x).exists.choose_spec.1
      have uni (x y) : (x:ℝ) * f y + y * f x ≤ 2 → y = ϕ x := (h_uniq x).exists.choose_spec.2 y
      have symm (x y) : (x:ℝ) * f y + y * f x ≤ 2 ↔ (y:ℝ) * f x + x * f y ≤ 2 := by rw [add_comm]
      have invol (x) : ϕ (ϕ x) = x := uni _ _ ((symm _ _).1 (hϕ x))
      have fix (x) : ϕ x = x := by
        by_contra h; apply h
        have strict (u v : ℝ+) (h : u ≠ v) : (u:ℝ) * f v + v * f u > 2 :=
          lt_of_not_le fun H => h (uni u v H).symm
        have f_gt_one (u) : (u:ℝ) * f u > 1 :=
          lt_of_not_le fun H => (ϕ u).2.ne' (uni u u (by linarith [H]) ▸ rfl)
        let v := ϕ x
