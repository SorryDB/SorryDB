                gcongr; apply Real.mul_self_lt_mul_self_iff.2 <;> nlinarith [h_pos x, h_pos y]
             _ = 2 * Real.sqrt ((x * f y) * (y * f x)) := by ring_nf
             _ ≤ x * f y + y * f x := Real.two_mul_sqrt_le_add _ _
        linarith

    intro x
    apply le_antisymm (h_le x)
    by_contra h_lt
    push_neg at h_lt
    have h_cont : ContinuousAt (fun t => (x : ℝ) / t + t * f x) x.1 := by
