          dsimp [y_val]; linarith [lt_min hδ_pos (by linarith : 0 < x.1/2)]
       specialize hδ this
       dsimp at hδ; linarith
       
    have h_sol : (x : ℝ) * f y + y * f x ≤ 2 := by
       apply le_trans _ (le_of_lt hy_le_2)
       apply add_le_add_right
