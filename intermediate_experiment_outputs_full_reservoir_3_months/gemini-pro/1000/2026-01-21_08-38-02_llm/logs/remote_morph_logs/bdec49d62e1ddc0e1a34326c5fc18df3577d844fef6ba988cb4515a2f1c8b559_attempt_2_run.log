        have f_y_le : f y ≤ f x := by
           have : f y ≤ 1/y := (le_div_iff y.2).2 (le_one y)
           rwa [show (1:ℝ)/y = f x by dsimp [y]; field_simp] at this
        have : (x:ℝ) * f y + y * f x ≤ 2 := by
           rw [show (y:ℝ) * f x = 1 by dsimp [y]; field_simp [hpos x]]
           calc (x:ℝ) * f y + 1 ≤ x * f x + 1 := by gcongr
             _ < 1 + 1 := by linarith
        linarith
      rw [eq_div_iff x.2.ne']; exact eq_one x
    simp [answer]; exact key
  · rintro h; simp [answer] at h; subst h
    constructor
    · intro x; simp; exact one_div_pos.2 x.2
    · intro x; use x; constructor
      · simp; field_simp; ring_nf; norm_num
      · intro y hy; simp at hy
        have : (x:ℝ)/y + y/x ≤ 2 := hy
        have amgm : (x:ℝ)/y + y/x ≥ 2 := by
          apply le_of_sub_nonneg; field_simp; exact div_nonneg (sq_nonneg _) (mul_pos x.2 y.2)
        have : (x:ℝ) = y := by
          have : ((x:ℝ)-y)^2/(x*y) = 0 := by linarith
          rw [div_eq_zero_iff] at this; linarith [this.1]
        ext; exact this
