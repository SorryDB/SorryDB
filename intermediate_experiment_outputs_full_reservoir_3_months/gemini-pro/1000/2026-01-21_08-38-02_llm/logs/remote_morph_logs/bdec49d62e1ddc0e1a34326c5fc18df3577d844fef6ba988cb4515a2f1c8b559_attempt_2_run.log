           have : 1 < x * f x := (lt_div_iff' x.2).mp h_gt
           nlinarith [h_pos x]
        linarith
      · push_neg at h_fy
        have : 2 < (x : ℝ) * f y + y * f x := by
           have h1 : 1 < x * f x := (lt_div_iff' x.2).mp h_gt
           have h2 : 1 < y * f y := (lt_div_iff' y.2).mp h_fy
           calc 2 = 2 * Real.sqrt (1 * 1) := by norm_num
