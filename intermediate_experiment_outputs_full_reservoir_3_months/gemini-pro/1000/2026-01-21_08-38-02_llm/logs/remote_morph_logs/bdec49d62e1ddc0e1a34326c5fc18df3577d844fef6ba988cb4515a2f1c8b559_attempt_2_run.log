           calc (x : ℝ) / y + y * f x 
             _ = x * (1/y) + y * f x := by ring
             _ ≤ x * f y + y * f x := add_le_add_right (mul_le_mul_of_nonneg_left h_fy (le_of_lt x.2)) _
             _ ≤ 2 := hy_sol
        rw [div_add_iff_add_mul_div _ _ (ne_of_gt y.2), div_le_iff y.2] at this
