       exact le_of_lt h_lt
    have hy0_x : y0 = x := h_y0_uniq x h_x_sol
    have hy0_y : y0 = y := h_y0_uniq y h_sol
    rw [hy0_x] at hy0_y
    exact hy_ne hy0_y.symm

