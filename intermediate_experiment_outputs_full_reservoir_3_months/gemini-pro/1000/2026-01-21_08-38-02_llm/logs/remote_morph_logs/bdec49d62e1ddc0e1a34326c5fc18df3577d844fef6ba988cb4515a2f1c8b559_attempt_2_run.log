    let y : ℝ+ := ⟨y_val, hy_pos⟩
    have hy_ne : y ≠ x := by
       intro h; dsimp [y_val] at h; rw [Subtype.mk_eq_mk] at h
       have : min (δ/2) (x.1/2) = 0 := by linarith
       linarith [lt_min hδ_pos (show 0 < x.1/2 by linarith [x.2])]
    
    have hy_le_2 : (x : ℝ) / y + y * f x < 2 := by
       rw [sub_lt_iff_lt_add] at hδ
