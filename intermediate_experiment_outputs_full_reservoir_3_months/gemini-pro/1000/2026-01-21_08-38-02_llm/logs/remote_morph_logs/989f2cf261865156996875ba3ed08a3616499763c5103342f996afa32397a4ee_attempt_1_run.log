  simp only [vectorSpaceToInternalTangentSpace, internalTangentMap, map_sub, map_one] at h hl
  -- Commutativity of internalTangentMap with vectorSpaceToInternalTangentSpace
  -- We show F (vec_to_tan v) = vec_to_tan (l v)
  let v_tan := vectorSpaceToInternalTangentSpace (0 : Eucl 1) (l v)
  let w_tan := vectorSpaceToInternalTangentSpace (0 : Eucl 1) (l w)
  -- Identify the image in Eucl 1's tangent space
  have : F (vectorSpaceToInternalTangentSpace x v) = vectorSpaceToInternalTangentSpace (l x) (l v) := by
    -- p(t) = x + t • v => l(p(t)) = l(x) + t • l(v)
    rw [vectorSpaceToInternalTangentSpace, vectorSpaceToInternalTangentSpace, internalTangentMap,
        Submodule.mapQ_apply, PreInternalTangentSpace.lof, PreInternalTangentSpace.lof]
    congr 2; apply linearMap_ext; intro p_val; ext z
    simp only [toModule_lof, pointedPlots_map, Function.comp_apply]
    congr; ext t; simp only [map_add, map_smul, LinearMap.coe_mk, AddHom.coe_mk]
  have : F (vectorSpaceToInternalTangentSpace x w) = vectorSpaceToInternalTangentSpace (l x) (l w) := by
    rw [vectorSpaceToInternalTangentSpace, vectorSpaceToInternalTangentSpace, internalTangentMap,
        Submodule.mapQ_apply, PreInternalTangentSpace.lof, PreInternalTangentSpace.lof]
    congr 2; apply linearMap_ext; intro p_val; ext z
    simp only [toModule_lof, pointedPlots_map, Function.comp_apply]
    congr; ext t; simp only [map_add, map_smul, LinearMap.coe_mk, AddHom.coe_mk]
  rw [this] at h; rotate_left; rw [this] at h
  -- Now we have vec_to_tan (l v) = vec_to_tan (l w) in T(Eucl 1).
  -- We define the evaluation map for Eucl 1 to prove injectivity.
  let ev (y : Eucl 1) : InternalTangentSpace y → Eucl 1 :=
    Submodule.liftQ _ (DirectSum.toModule _ _ _ fun p ↦ fderiv ℝ p.1.2 0) <| by
      rw [Submodule.span_le]; rintro _ ⟨p, q, f, w, rfl⟩
