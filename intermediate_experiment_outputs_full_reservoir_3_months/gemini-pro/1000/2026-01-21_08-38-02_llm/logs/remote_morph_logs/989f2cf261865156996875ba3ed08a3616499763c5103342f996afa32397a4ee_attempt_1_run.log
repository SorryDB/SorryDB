lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h
  -- If v ≠ w, there exists a linear functional l separating them.
  by_contra h_ne
  rcases Module.exists_dual_map_eq_one_of_ne_zero (v - w) (sub_ne_zero.mpr h_ne) with ⟨l, hl⟩
