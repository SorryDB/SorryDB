lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h
  apply eq_of_sub_eq_zero
  by_contra h_diff
  rcases Module.exists_linearMap_apply_neq_zero (v - w) h_diff with ⟨f, hf⟩
  -- In a fine diffeological vector space, linear maps are smooth.
  -- We assume the library provides this instance or lemma.
  have hf_smooth : DSmooth f := LinearMap.dsmooth f
  let T := vectorSpaceToInternalTangentSpace x
  let Tf := internalTangentMap f x
  have h_map : Tf (T v) = Tf (T w) := congr_arg Tf h
  -- We compute the action of Tf ∘ T
  -- Tf (T u) is the tangent vector of the plot t ↦ f(x + t • u) = f x + t • f u
  -- This is exactly vectorSpaceToInternalTangentSpace (f x) (f u) in T(f x) ℝ
  let T_R := vectorSpaceToInternalTangentSpace (f x)
  have h_comm : ∀ u, Tf (T u) = T_R (f u) := by
    intro u
    -- Unfold definitions to check commutativity
    simp only [T, Tf, T_R, vectorSpaceToInternalTangentSpace, internalTangentMap,
      preInternalTangentMap, hf_smooth, dite_true, InternalTangentSpace.lof,
      Submodule.mapQ_apply, Submodule.mkQ_apply, toModule_lof, pointedPlots_map]
    congr 2
