lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h
  let ev : PreInternalTangentSpace x →ₗ[ℝ] X :=
    DirectSum.toModule ℝ _ _ fun p ↦ (fderiv ℝ p.1.2 0).toLinearMap
  let inv : InternalTangentSpace x →ₗ[ℝ] X := Submodule.liftQ _ ev <| by
    rw [Submodule.span_le]
    rintro v ⟨p, q, f, w, rfl⟩
