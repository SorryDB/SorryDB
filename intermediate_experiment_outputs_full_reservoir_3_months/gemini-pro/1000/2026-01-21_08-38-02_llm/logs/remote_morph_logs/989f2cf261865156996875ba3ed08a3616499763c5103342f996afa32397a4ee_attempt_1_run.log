  let L := Module.Dual ℝ X
  have : ∀ l : L, l u = 0 := by
    intro l
    -- l defines a smooth map X → ℝ.
    -- We can push forward the tangent vector.
    let l_smooth : DSmooth l := IsFineDiffeology.linearMap_is_dsmooth l
    let push : InternalTangentSpace x →ₗ[ℝ] InternalTangentSpace (l x) := internalTangentMap l x
    have h_push : push (ι u) = 0 := by rw [h_img, map_zero]
    -- The pushforward of the canonical vector is the canonical vector in ℝ.
    -- vectorSpaceToInternalTangentSpace is functorial for linear maps.
    -- For t ↦ x + tu, l(x + tu) = l(x) + t l(u).
    -- This is the canonical vector for l(u) at l(x).
    let ι_R := vectorSpaceToInternalTangentSpace (l x)
    have comm : push (ι u) = ι_R (l u) := by
      -- Unfold definitions to verify
      simp only [ι, push, vectorSpaceToInternalTangentSpace, internalTangentMap,
        preInternalTangentMap, l_smooth, dite_true, Submodule.mapQ_apply,
        PreInternalTangentSpace.lof, toModule_lof, pointedPlots_map]
      -- The map sends lof p v to lof (l ∘ p) v.
