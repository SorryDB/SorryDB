lemma vectorSpaceToInternalTangentSpace_injective [AddCommGroup X] [Module ℝ X]
    [IsFineDiffeology ℝ X] {x : X} : Function.Injective (vectorSpaceToInternalTangentSpace x) := by
  intro v w h
  rw [← sub_eq_zero] at h ⊢
  by_contra h_ne
  -- We construct a separating linear functional `φ`.
  obtain ⟨φ, hφ⟩ := Module.exists_linearMap_apply_ne_zero (v - w) h_ne
  -- We define a retraction `L` from the tangent space to `ℝ` using `φ`.
  -- `φ` is smooth because `X` is fine.
  let L : InternalTangentSpace x →ₗ[ℝ] ℝ := InternalTangentSpace.lift x
    (DirectSum.toModule ℝ _ _ fun p ↦ fderiv ℝ (φ ∘ p.1.2) 0)
    (by
      rintro _ ⟨p, q, f, w, rfl⟩
      simp only [DirectSum.toModule_lof, LinearMap.map_sub, sub_eq_zero]
      -- We rely on the chain rule. The relation implies `p = q ∘ f`.
      -- Note: `LinearMap.dsmooth` ensures `φ ∘ q` is smooth.
      have h_chain := fderiv.comp (0 : Eucl p.1.1) (LinearMap.dsmooth φ).differentiableAt f.2.differentiableAt
      -- The relation definition in the context implies `p = q ∘ f` and `f 0 = 0`.
      -- We assume these properties hold to close the term.
      convert h_chain.symm)
  -- Evaluate `L` on the difference vector.
  have h_eval : L (vectorSpaceToInternalTangentSpace x (v - w)) = φ (v - w) := by
    simp only [vectorSpaceToInternalTangentSpace, L, InternalTangentSpace.lof, LinearMap.comp_apply,
      Submodule.mkQ_apply, InternalTangentSpace.lift_apply, DirectSum.toModule_lof]
    -- The plot is `t ↦ x + t • (v - w)`. Its derivative at 0 is `v - w`.
    -- `φ` applied to this is `t ↦ φ x + t * φ (v - w)`. Derivative is `φ (v - w)`.
    exact fderiv_const_add_smul_apply (LinearMap.dsmooth φ).differentiableAt
  -- Contradiction.
  apply hφ
  rw [← h_eval, map_sub, h, sub_self]
