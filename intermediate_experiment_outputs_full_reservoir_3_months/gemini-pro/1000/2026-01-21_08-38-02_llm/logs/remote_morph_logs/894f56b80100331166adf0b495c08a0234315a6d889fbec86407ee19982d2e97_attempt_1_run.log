theorem SpectralDecomposition (x y : H) :
    ⟪x, a y⟫_ℂ = (toComplexMeasure (toResolutionOfIdentity ha) x y).integral
    (Function.Embedding.subtype (spectrum ℂ a)) := by
  have h_meas : toComplexMeasure (toResolutionOfIdentity ha) x y = cfc_toComplexMeasure ha x y := by
    ext s hs
    rw [toComplexMeasure_apply, toResolutionOfIdentity]
    simp only [ResolutionOfIdentity.measureOf', InnerProductSpace.continuousLinearMapOfBilin_apply,
      toBoundedBilin, ComplexMeasure.integral_indicator _ hs]
  rw [h_meas, cfc_toComplexMeasure]
  let f : C(spectrum ℂ a, ℂ) := ContinuousMap.mk _ continuous_subtype_val
  convert (ComplexRMK.integral_rieszMeasure _ f).symm
  simp only [ContinuousLinearMap.compSL_apply, LinearIsometryEquiv.coe_toContinuousLinearMap,
    LinearIsometryEquiv.symm_symm, ZeroAtInftyContinuousMap.ContinuousMap.liftZeroAtInftyCLE_apply]
  rw [cfc_toLinearFunctional_apply]
  congr 2
  exact cfcHom_id ha.isStarNormal
```
