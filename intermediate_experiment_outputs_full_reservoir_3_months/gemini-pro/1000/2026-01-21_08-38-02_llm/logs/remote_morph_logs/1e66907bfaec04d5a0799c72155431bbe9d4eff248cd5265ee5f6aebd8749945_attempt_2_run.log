/-- Any diffeological manifold is also a diffeological manifold with boundary. -/
instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u,hu,hxu,i,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  let f : Eucl n → Eucl n := fun x i ↦ if i = 0 then Real.exp (x 0) else x i
  let g : Eucl n → Eucl n := fun x i ↦ if i = 0 then Real.log (x 0) else x i
  have cf : ContDiff ℝ ⊤ f := contDiff_pi.2 fun i ↦ if h : i = 0 then
      h ▸ Real.contDiff_exp.comp (contDiff_apply 0) else contDiff_apply i
  have cg : ContDiffOn ℝ ⊤ g {x | 0 < x 0} := contDiffOn_pi.2 fun i ↦ if h : i = 0 then
      h ▸ Real.contDiffOn_log.comp (contDiffOn_apply 0) (fun x hx ↦ hx) 
      else (contDiff_apply i).contDiffOn
  let ϕ : Eucl n ᵈ≃ {x : Eucl n | 0 < x 0} :=
    { toFun := fun x ↦ ⟨f x, by simp [f]; exact Real.exp_pos _⟩
      invFun := g ∘ Subtype.val
      left_inv := fun x ↦ by ext i; by_cases h : i = 0 <;> simp [h, f, g, Real.log_exp]
      right_inv := fun y ↦ Subtype.ext <| by ext i; by_cases h : i = 0 <;>
