  let ⟨u,hu,hxu,i,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  let φ : Eucl n ᵈ≃ {y : Eucl n | 0 < y 0} :=
    { toFun := fun x i ↦ if i = 0 then Real.exp (x 0) else x i
      invFun := fun y i ↦ if i = 0 then Real.log (y.1 0) else y.1 i
      left_inv := fun x ↦ by ext i; split_ifs <;> simp [*]; exact Real.log_exp _
      right_inv := fun ⟨y,hy⟩ ↦ by ext i; split_ifs <;> simp [*]; exact Real.exp_log hy
      dsmooth_to := dsmooth_pi_iff.mpr fun i ↦ by
        split_ifs; exact Real.dsmooth_exp.comp (dsmooth_proj 0); exact dsmooth_proj i
      dsmooth_inv := dsmooth_pi_iff.mpr fun i ↦ by
        split_ifs; refine Real.dsmooth_log.comp (dsmooth_proj 0) ?_; exact dsmooth_proj i
        exact fun y ↦ y.2 }
  let v' : Set {x : Eucl n | 0 ≤ x 0} := Subtype.val ⁻¹' (φ '' v)
  have hv' : IsOpen[DTop] v' := (isOpen_induced_iff _ _).mpr ⟨φ '' v, φ.isOpenMap v hv, rfl⟩
