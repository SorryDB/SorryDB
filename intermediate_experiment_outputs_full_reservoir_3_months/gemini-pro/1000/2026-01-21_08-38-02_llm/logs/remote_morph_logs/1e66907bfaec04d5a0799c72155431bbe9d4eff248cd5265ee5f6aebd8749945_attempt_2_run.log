  have hTi : DSmooth T.symm := ContDiff.dsmooth (contDiff_id.sub contDiff_const)
  let D : Eucl n ᵈ≃ Eucl n := ⟨T, hT, hTi⟩
  let v' := D '' Metric.ball y ε
