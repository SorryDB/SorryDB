instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u,hu,hxu,i,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  -- Map R^n to the open half-space H_pos = {x | x_0 > 0} via (x_0, ...) -> (exp x_0, ...)
  -- This embeds the chart into the interior of the half-space H^n
  let H_pos := { p : Eucl n | 0 < p 0 }
  let Φ : Eucl n ᵈ≃ H_pos :=
    { toFun := fun p => ⟨Function.update p 0 (Real.exp (p 0)), by simp [Real.exp_pos]⟩
      invFun := fun p => Function.update p.1 0 (Real.log (p.1 0))
      left_inv := fun p => by ext j; by_cases h : j = 0 <;> simp [h, Function.update_apply]
      right_inv := fun p => Subtype.eq <| by ext j; by_cases h : j = 0 <;> simp [h, Function.update_apply, Real.exp_log p.2]
      dsmooth_toFun := (contDiff_id.update 0 (Real.contDiff_exp.comp (contDiff_apply 0))).dsmooth
      dsmooth_invFun := (contDiff_subtype_val.update 0 (Real.contDiff_log.comp (contDiff_subtype_val.apply 0) (fun x => (x.2).ne'))).dsmooth }
  -- The target set v' in H^n corresponding to v in R^n
  let v' : Set {x : Eucl n | 0 ≤ x 0} := {x | x.1 ∈ Φ '' v}
  have hv' : IsOpen[DTop] v' := by
    rw [isOpen_induced_iff]; use Φ '' v
    exact ⟨(dTop_eq (Eucl n) ▸ hv).image Φ.toEquiv.toHomeomorph, rfl⟩
  -- The diffeomorphism u ≅ v ≅ v'
  refine ⟨u, hu, hxu, (), v', hv', ⟨?_⟩⟩
  exact d.trans <| (DDiffeomorph.Set.image Φ v).trans <|
    DDiffeomorph.Set.congr (Φ '' v) v' (by ext; simp [v', H_pos])⟩
