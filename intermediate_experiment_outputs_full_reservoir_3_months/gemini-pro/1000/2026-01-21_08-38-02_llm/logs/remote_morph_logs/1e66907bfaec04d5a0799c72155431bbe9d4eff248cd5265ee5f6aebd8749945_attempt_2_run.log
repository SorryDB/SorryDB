    right_inv := fun p ↦ by ext1; simp; exact d.right_inv _
    dsmooth_to := (φ.dsmooth.comp d.dsmooth).subtype_mk _
    dsmooth_inv := d.symm.dsmooth.comp (φ.symm.dsmooth.comp dsmooth_subtype_val) }⟩⟩⟩
