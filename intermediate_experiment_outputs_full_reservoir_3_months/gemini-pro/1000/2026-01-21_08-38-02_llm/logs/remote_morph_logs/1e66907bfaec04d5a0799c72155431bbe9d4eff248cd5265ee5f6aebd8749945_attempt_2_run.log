/-- Any diffeological manifold is also a diffeological manifold with boundary. -/
instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u,hu,hxu,i,v,hv,⟨d⟩⟩ := hm.locally_modelled x
  -- We construct a diffeomorphism from R^n to the open half-space {x | x_0 > 0}
  -- using the exponential map on the first coordinate.
  let f : Eucl n ≃ᵈ {x : Eucl n | 0 < x 0} :=
  { toFun := fun x i ↦ if i = 0 then Real.exp (x 0) else x i
    invFun := fun x i ↦ if i = 0 then Real.log (x.1 0) else x.1 i
    left_inv := fun x ↦ by ext i; by_cases h : i = 0 <;> simp [h, Real.log_exp]
    right_inv := fun x ↦ by ext i; by_cases h : i = 0 <;> simp [h, Real.exp_log x.2]
    smooth_toFun := by
      rw [dsmooth_iff_contDiff]; apply contDiff_pi.2; intro i; by_cases h : i = 0
      · subst h; simp; exact Real.contDiff_exp.comp (contDiff_apply 0)
      · simp [h]; exact contDiff_apply i
    smooth_invFun := by
      rw [dsmooth_iff_contDiff]; apply contDiff_pi.2; intro i; by_cases h : i = 0
      · subst h; simp; refine Real.contDiff_log.comp (contDiff_apply 0) ?_
        exact fun x ↦ x.2
      · simp [h]; exact (contDiff_apply i).comp contDiff_subtype_val }
  -- The image of v under f is open in the open half-space, hence open in the closed half-space.
  let v' : Set {x : Eucl n | 0 ≤ x 0} := Subtype.val ⁻¹' (f '' v)
  have hv' : IsOpen[DTop] v' := by
    rw [isOpen_iff_dTop_subtype, dTop_eq, isOpen_induced_iff]
    refine ⟨f '' v, f.isOpen_image v hv, by ext; simp; exact fun _ _ ↦ le_of_lt⟩
  -- Composition of diffeomorphisms gives the result.
  refine ⟨u, hu, hxu, (), v', hv', ⟨d.trans (f.trans (DDiffeomorph.Set.nested (by simp)))⟩⟩⟩
