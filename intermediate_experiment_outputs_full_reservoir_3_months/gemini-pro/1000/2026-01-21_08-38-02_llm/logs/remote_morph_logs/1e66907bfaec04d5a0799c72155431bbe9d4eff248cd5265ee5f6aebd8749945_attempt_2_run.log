instance {n : ℕ} {X : Type*} [Zero (Fin n)] [DiffeologicalSpace X]
    [hm : IsDiffeologicalManifold n X] : IsManifoldWithBoundary n X := ⟨fun x ↦ by
  let ⟨u, hu, hxu, i, v, hv, ⟨d⟩⟩ := hm.locally_modelled x
  -- We construct a diffeomorphism from R^n to the interior of the half-space H = {x | x_0 ≥ 0}.
  -- The map is given by x ↦ (e^{x_0}, x_1, ...), which maps R^n to {x ∈ H | x_0 > 0}.
  let H := {x : Eucl n | 0 ≤ x 0}
  let H_int := {z : H | 0 < z.1 0}
  let phi : Eucl n ᵈ≃ H_int :=
    { toFun := fun x ↦ ⟨⟨Function.update x 0 (Real.exp (x 0)), 
          by simp; exact le_of_lt (Real.exp_pos _)⟩, by simp; exact Real.exp_pos _⟩
      invFun := fun z ↦ Function.update z.1 0 (Real.log (z.1 0))
      left_inv := fun x ↦ by ext j; by_cases h : j = 0 <;> simp [h, Real.log_exp]
      right_inv := fun z ↦ Subtype.ext <| Subtype.ext <| by 
          ext j; by_cases h : j = 0 <;> simp [h, Real.exp_log z.2]
      smooth_to := sorry
      smooth_inv := sorry }
  -- Map the chart v via phi to get a chart in H
  let v' := phi.toEquiv '' v
  have hv' : IsOpen[DTop] v' := phi.isOpen_image_of_isOpen v hv
  refine ⟨u, hu, hxu, (), v', hv', ⟨d.trans phi⟩⟩⟩
