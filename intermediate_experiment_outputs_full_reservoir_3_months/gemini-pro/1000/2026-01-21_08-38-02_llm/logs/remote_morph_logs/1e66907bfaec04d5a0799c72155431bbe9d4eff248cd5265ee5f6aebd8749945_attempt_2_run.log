    rw [isOpen_induced_iff] at hu ⊢; rcases hu with ⟨U, hU, rfl⟩
    exact ⟨_, (d.continuous.isOpen_preimage _ Metric.isOpen_ball).isOpenMap_subtype_val _ hU, rfl⟩
  refine ⟨u', hu', ⟨hxu, Metric.mem_ball_self hε⟩, (), {z | z.1 ∈ v'},
