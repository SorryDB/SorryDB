      split_ifs with h_odd; all_goals {
        simp [h_odd] at hc_i
        by_cases ha : aligned i
        · simp [ha] at hc_i ⊢; simp [Fin.rev] at hc_i
          try rw [if_pos ha] at hc_i
          try rw [← hc_i]; try rfl
          try { have ht := t.2; rw [Nat.sub_sub_self (Nat.le_of_lt_succ ht)] }
        · simp [ha] at hc_i ⊢; simp [Fin.rev] at hc_i
          try rw [if_neg ha] at hc_i
          try rw [← hc_i]; try rfl
          try { have ht := t.2; rw [Nat.sub_sub_self (Nat.le_of_lt_succ ht)] }
      }
    
    have hxj : xj = if r j % 2 == 0 then t.1 else (n - 2) - t.1 := by
       -- Symmetric logic
       sorry
       
    -- Analyze parity contradiction
    let dist := if r f < r g then r g - r f else r f - r g
    have h_contra : (xi + xj) % 2 ≠ (dist - 1) % 2 := by
       rw [hxi, hxj]
       have h_dist_parity : (dist - 1) % 2 = (r f + r g + 1) % 2 := by sorry
       have h_odd_n : (n - 2) % 2 = 1 := by sorry
       split_ifs with h_ri h_rj
       · -- Even, Even: sum is 2t (even). RHS: |even-even|-1 (odd).
         simp [Nat.mul_mod_right]; rw [h_dist_parity]; sorry
       · -- Even, Odd: sum is n-2 (odd). RHS: |even-odd|-1 (even).
         rw [Nat.add_sub_of_le (Nat.le_of_lt_succ t.2)]; rw [h_odd_n]
         rw [h_dist_parity]; sorry
       · -- Odd, Even: sum is n-2 (odd). RHS: |odd-even|-1 (even).
         rw [Nat.add_comm, Nat.add_sub_of_le (Nat.le_of_lt_succ t.2)]; rw [h_odd_n]
         rw [h_dist_parity]; sorry
       · -- Odd, Odd: sum is 2(n-2-t) (even). RHS: |odd-odd|-1 (odd).
         simp [Nat.mul_mod_right]; rw [h_dist_parity]; sorry
         
    exact h_contra (h_parity f g hfg)
