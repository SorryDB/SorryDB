          rj = interAlong j (interBtw j ⟨i, hij.symm⟩))
    -- The following function, `clap`, takes a `Bool` determining a direction, and a number `t`.
    -- It returns the intersection point (by its label) that a Frog should be at after the
    -- `t`:th clap. `false` means backwards movement from the end point, and `true` forward movement
    -- from the starting point.
    (clap : Bool → Fin (n - 1 : ℕ) → Fin (n - 1 : ℕ))
    (clap_def : ∀ b, clap b = if b then Fin.rev else id)
    (hn_odd : Odd n) :
    -- Geoff must assign each frog to a segment and a starting point
    ∃ F : Fin n → Fin n × Bool,
      -- For any two frogs `f ≠ g`
      ∀ f g (hfg : f ≠ g),
        -- The frogs do not start at the same point,
        (F f).1 ≠ (F g).1 ∧
        -- and at each point in time (`t=0` being after the first clap)
        ∀ t : Fin (n - 1 : ℕ),
        -- they don't meet.
        lineMap (points (F f).1).1 (points (F f).1).2 (interAlong (F f).1 (clap (F f).2 t)).1 ≠
        lineMap (points (F g).1).1 (points (F g).1).2 (interAlong (F g).1 (clap (F g).2 t)).1 := by
  let k (i j : Fin n) (h : i ≠ j) : Fin (n - 1) := interBtw i ⟨j, h⟩
  -- We identify two types of problematic pairs:
  -- Type D (Different): They collide if they have the same direction.
  let is_D (i j : Fin n) (h : i ≠ j) : Prop := k i j h = k j i h.symm
  -- Type S (Same): They collide if they have different directions.
  let is_S (i j : Fin n) (h : i ≠ j) : Prop := (k i j h : ℕ) + (k j i h.symm : ℕ) = n - 2
  -- The core combinatorial result (IMO 2016 C6) is that for odd n, there exists an assignment
  -- satisfying these constraints.
  have exists_assignment : ∃ b : Fin n → Bool, ∀ i j (h : i ≠ j),
      (is_D i j h → b i ≠ b j) ∧ (is_S i j h → b i = b j) := sorry
  rcases exists_assignment with ⟨b, hb⟩
  use fun i => (i, b i)
  intro f g hfg
  constructor
  · exact fun h => hfg (congr_arg Prod.fst h)
  · intro t h_eq
    rw [lineMap_eq_iff] at h_eq
    have hf : clap (b f) t = k f g hfg := interAlong.injective _ h_eq.1
    have hg : clap (b g) t = k g f hfg.symm := interAlong.injective _ h_eq.2
    specialize hb f g hfg
    simp [clap_def] at hf hg
    split_ifs at hf with hbf <;> split_ifs at hg with hbg
    · -- both true: same direction
      have hd : is_D f g hfg := by rw [← hf, ← hg]
      exact hb.1 hd (by rw [hbf, hbg])
    · -- b f true, b g false: different
      have hs : is_S f g hfg := by
        rw [← hf, ← hg]; simp [Fin.rev]; omega
      exact hbg.symm (hb.2 hs).symm ▸ hbf
    · -- b f false, b g true: different
      have hs : is_S f g hfg := by
        rw [← hf, ← hg]; simp [Fin.rev]; omega
      exact hbg.symm (hb.2 hs) ▸ hbf
    · -- both false: same direction
      have hd : is_D f g hfg := by rw [← hf, ← hg]
      exact hb.1 hd (by rw [hbf, hbg])
