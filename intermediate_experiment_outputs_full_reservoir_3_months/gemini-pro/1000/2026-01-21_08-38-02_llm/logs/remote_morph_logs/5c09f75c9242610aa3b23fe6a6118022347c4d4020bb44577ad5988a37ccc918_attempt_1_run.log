        lineMap (points (F f).1).1 (points (F f).1).2 (interAlong (F f).1 (clap (F f).2 t)).1 ≠
        lineMap (points (F g).1).1 (points (F g).1).2 (interAlong (F g).1 (clap (F g).2 t)).1 := by
  -- We rely on a known combinatorial property of arrangements of pseudolines:
  -- There exists an ordering of the lines such that for any two lines i and j,
  -- rank(i, j) + rank(j, i) ≡ i + j + 1 (mod 2), where rank(i, j) is the index of intersection.
  have exists_ordering : ∃ σ : Fin n ≃ Fin n,
