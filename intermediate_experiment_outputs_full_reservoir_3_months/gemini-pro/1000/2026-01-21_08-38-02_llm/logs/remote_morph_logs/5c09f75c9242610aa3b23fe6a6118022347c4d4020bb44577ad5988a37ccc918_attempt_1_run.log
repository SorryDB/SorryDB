      have : k_fg = k_gf := by
        cases (b g) <;> simp at pos_f pos_g
        · rw [←pos_f, ←pos_g]
        · rw [←pos_f, ←pos_g]
      rcases hb with ⟨h_ne, _⟩
      exact h_ne h_same this
    · -- Different directions
      have sum_eq : (k_fg : ℕ) + k_gf = n - 2 := by
        cases hbf : b f <;> cases hbg : b g
        · contradiction -- covered by h_same
        · -- f false, g true
