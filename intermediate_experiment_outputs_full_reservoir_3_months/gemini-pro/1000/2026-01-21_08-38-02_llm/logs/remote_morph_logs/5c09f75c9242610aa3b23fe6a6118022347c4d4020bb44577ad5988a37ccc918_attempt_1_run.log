      have h_dist_even : (dist_r - 1) % 2 = 0 := by
         have h_dist_odd : dist_r % 2 = 1 := by
            dsimp [dist_r]; split
            · exact Nat.sub_mod_eq_one_of_mod_eq (by rw [h_parity_ranks])
            · exact Nat.sub_mod_eq_one_of_mod_eq (by rw [eq_comm, h_parity_ranks])
         exact Nat.pred_mod_two_of_odd_pos h_dist_odd (by dsimp [dist_r]; split <;> exact Nat.sub_pos_of_lt (lt_of_le_of_ne (not_lt.mp ‹_›) (by intro h; apply h_ranks_ne; simp [h] at *)))
      rw [h_parity_eq] at h_sum_odd
      rw [h_dist_even] at h_sum_odd
