    progress with (mul_by_pow_2 e km1) as e_km1
    progress with (double e_km1) as e_km1_double
    
    exists e_km1_double
    simp
    intro _
    exists km1, e_km1, e_km1_double, Choice.one
    simp [h_km1_eq]
    -- ct_eq reflexivity
    progress
    simp
