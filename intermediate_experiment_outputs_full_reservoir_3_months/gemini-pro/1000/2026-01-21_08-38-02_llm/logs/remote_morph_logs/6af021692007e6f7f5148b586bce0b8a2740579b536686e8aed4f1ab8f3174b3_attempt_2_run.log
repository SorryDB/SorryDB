    simp only [mul_by_pow_2]
    try simp only [mul_by_pow_2_loop]
    simp [h_gt]
    rw [←h_km1_eq]
    simp
    
    -- Use progress to execute double e
    progress with (double e) as e_dbl
    -- Now we have mul_by_pow_2 e_dbl km1
    
    -- We need to show this equals double (mul_by_pow_2 e km1)
    -- Apply comm lemma to mul_by_pow_2 e km1
