theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let s := (Module.support A M) ∩ {p : PrimeSpectrum A | p.asIdeal.primeHeight = 1}
  have hs : s.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  let S := ⨅ p ∈ s, p.asIdeal.primeCompl
  by_cases h0 : (0 : A) ∈ S
  · refine ⟨PEmpty, PEmpty.fintype, PEmpty.elim, PEmpty.elim, PEmpty.elim, PEmpty.elim, ?_⟩
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map (0 : M →ₗ[A] (PEmpty → A) → A)]
    · simp only [s, S, iInf_neg, iInf_pos] at *
      have : Subsingleton (LocalizedModule S M) := (LocalizedModule.subsingleton_iff S M).mpr fun x ↦ ⟨0, h0, zero_smul _ _⟩
      have : Subsingleton (LocalizedModule S ((i : PEmpty) → A ⧸ (PEmpty.elim i).asIdeal ^ PEmpty.elim i)) :=
         (LocalizedModule.subsingleton_iff S _).mpr fun x ↦ ⟨0, h0, zero_smul _ _⟩
      exact ⟨fun _ _ ↦ Subsingleton.elim _ _, fun _ ↦ ⟨0, Subsingleton.elim _ _⟩⟩
  have hn : s.Nonempty := by rw [Set.nonempty_iff_ne_empty]; intro h; simp [h] at h0
  have h_pid := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s Set.inter_subset_right hn hs
  let R' := Localization S
  haveI : IsPrincipalIdealRing R' := h_pid.2
  haveI : IsDomain R' := h_pid.1
  let M' := LocalizedModule S M
  obtain ⟨I, _, d, _, _⟩ := Module.equiv_directSum_of_isTorsion R' M'
  let J := Σ i : I, (UniqueFactorizationMonoid.normalizedFactors (d i)).toFinset
  let p (j : J) := PrimeSpectrum.comap (algebraMap A R') (PrimeSpectrum.mk (Ideal.span {j.2.1}) (Ideal.isPrime_span_of_prime (UniqueFactorizationMonoid.prime_of_normalized_factor j.2.1 (by
    have := j.2.2; rw [Multiset.mem_toFinset] at this; exact this))))
  let e (j : J) := (UniqueFactorizationMonoid.normalizedFactors (d j.1)).count j.2.1
  refine ⟨J, inferInstance, p, ?_, e, ?_, ?_⟩
  · intro j
    have hq : j.2.1 ≠ 0 := UniqueFactorizationMonoid.irreducible_of_normalized_factor j.2.1 (by have := j.2.2; simp at this; exact this) |>.ne_zero
    let P := PrimeSpectrum.mk (Ideal.span {j.2.1}) (Ideal.isPrime_span_of_prime (UniqueFactorizationMonoid.prime_of_normalized_factor j.2.1 (by have := j.2.2; simp at this; exact this)))
    have hmem : PrimeSpectrum.comap (algebraMap A R') P ∈ s ∪ {⟨⊥, Ideal.bot_prime⟩} :=
      PrimeSpectrum.localization_comap_range_eq_of_isDomain_of_primeHeight_eq_one R' s Set.inter_subset_right hn hs ▸ ⟨P, rfl⟩
    rcases hmem with h | h
    · exact h.2
    · rw [Set.mem_singleton_iff] at h
      have : P = ⊥ := PrimeSpectrum.localization_comap_injective R' S (h.trans (Ideal.comap_bot_of_injective _ (IsLocalization.injective _ h_pid.1.1)).symm)
      exact absurd (Ideal.mem_bot.mp (this ▸ Ideal.mem_span_singleton_self j.2.1)) hq
  · intro j; exact Multiset.count_pos.mpr (by have := j.2.2; simp at this; exact this)
  · let N := (j : J) → A ⧸ (p j).asIdeal ^ e j
    have ⟨ϕ⟩ : Nonempty (LocalizedModule S M ≃ₗ[R'] LocalizedModule S N) := sorry
    obtain ⟨f, ⟨s, hs⟩, rfl⟩ := (IsLocalization.surjective_linearMap_localization_hom (LocalizedModule.isLocalization S) : Function.Surjective (fun f : M →ₗ[A] N ↦ LocalizedModule.map S f)) ϕ.toLinearMap
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map f]
    rw [show LocalizedModule.map S f = (algebraMap A R' s) • ϕ.toLinearMap by
      ext; simp [LocalizedModule.map_mk, Algebra.smul_def]]
    exact Function.Bijective.comp (IsUnit.smul_bijective (IsLocalization.map_units _ ⟨s, hs⟩) _) ϕ.bijective
