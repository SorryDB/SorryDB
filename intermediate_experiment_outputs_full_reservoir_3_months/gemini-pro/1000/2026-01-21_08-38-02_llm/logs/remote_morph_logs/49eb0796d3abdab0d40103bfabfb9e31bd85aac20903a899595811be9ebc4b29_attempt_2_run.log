      rw [Module.mem_support_iff] at hp
      by_contra h
      rw [ENat.le_one_iff_eq_zero_or_eq_one] at h
      rcases h with h | h
      · have : p.asIdeal = ⊥ := Ideal.primeHeight_eq_zero_iff.mp h
        -- Since M is torsion, Ann(M) contains a regular element (non-zero-divisor).
        -- In a Noetherian ring, minimal primes consist of zero divisors.
        -- Thus, V(Ann M) contains no minimal prime.
        -- p=bot is a minimal prime (since height 0).
        -- Thus p ∉ Support M.
        exact Set.not_mem_empty p ⟨hp.1, h⟩
      · exact Set.not_mem_empty p ⟨hp.1, h⟩
  · set S := ⨅ p ∈ s, p.1.primeCompl
    obtain ⟨hDom, hPID⟩ := HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (Set.Subset.refl _) hn hs
    let M_S := LocalizedModule S M
    haveI : Module.Finite (Localization S) M_S := Module.Finite_of_isLocalization S M _
    haveI : Module.IsTorsion (Localization S) M_S := Module.IsTorsion.isLocalization S hMT
    obtain ⟨ι, hfin, q, hq, e, he, ⟨iso⟩⟩ :=
