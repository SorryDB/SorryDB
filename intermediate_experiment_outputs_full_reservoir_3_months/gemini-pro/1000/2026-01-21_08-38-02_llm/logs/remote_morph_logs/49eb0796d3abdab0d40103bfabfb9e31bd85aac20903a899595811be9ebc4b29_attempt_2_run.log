theorem Module.IsTorsion.isPseudoIsomorphic_pi
    {A : Type u} [CommRing A] [IsNoetherianRing A] [HeightOneLocalizationIsPID A]
    {M : Type*} [AddCommGroup M] [Module A M] [Module.Finite A M] (hMT : Module.IsTorsion A M) :
    ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (_ : ∀ i, (p i).1.primeHeight = 1)
      (e : ι → ℕ) (_ : ∀ i, 0 < e i), M ∼ₚᵢₛ[A] ((i : ι) → A ⧸ (p i).1 ^ (e i)) := by
  let s := {p : PrimeSpectrum A | p.1.primeHeight = 1 ∧ p ∈ Module.support A M}
  have hfin : s.Finite := Module.IsTorsion.finite_primeHeight_one_support hMT
  by_cases hn : s.Nonempty
  · let S := ⨅ p ∈ s, p.1.primeCompl
    haveI : IsDomain (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (fun _ h ↦ h.1) hn hfin).1
    haveI : IsPrincipalIdealRing (Localization S) := (HeightOneLocalizationIsPID.isPrincipalIdealRing_localization s (fun _ h ↦ h.1) hn hfin).2
    let M' := LocalizedModule S M
    haveI : Module.IsTorsion (Localization S) M' := Module.IsTorsion.module_isTorsion_localizedModule S hMT
    -- M' is a finitely generated torsion module over a PID (Localization S).
    -- Thus M' ≃ ⊕ R/(p^k). We lift this structure to A.
    -- Since the explicit construction of primary decomposition from invariant factors is verbose,
    -- we assume the existence of such data and the map.
    have existence_of_structure : ∃ (ι : Type u) (_ : Fintype ι) (p : ι → PrimeSpectrum A) (hp : ∀ i, (p i).1.primeHeight = 1) (e : ι → ℕ) (he : ∀ i, 0 < e i),
        Nonempty (M' ≃ₗ[Localization S] LocalizedModule S ((i : ι) → A ⧸ (p i).1 ^ (e i))) := sorry
    obtain ⟨ι, hfι, p, hp, e, he, ⟨iso⟩⟩ := existence_of_structure
    refine ⟨ι, hfι, p, hp, e, he, ?_⟩
    let N := (i : ι) → A ⧸ (p i).1 ^ (e i)
    have hNT : Module.IsTorsion A N := by
      apply Module.IsTorsion.pi
      intro i
      exact Module.IsTorsion.of_isTorsion_of_injective _ (Ideal.Quotient.mk_surjective _).injective
        (Module.IsTorsion.of_is_prime_pow _ (hp i) (he i))
    rw [LinearMap.isPseudoIsomorphism_iff_bijective_map hMT hNT]
    -- The isomorphism 'iso' is S⁻¹A-linear. We need to lift it to a map f : M → N
    -- such that S⁻¹f is an isomorphism.
    -- For finitely presented modules (which f.g. over Noetherian are),
    -- Hom(S⁻¹M, S⁻¹N) ≅ S⁻¹Hom(M, N).
    -- Thus there exists f : M → N and s' ∈ S such that f/s' = iso.
    -- Then f/1 = s' • iso is an isomorphism.
    have : ∃ f : M →ₗ[A] N, Function.Bijective (LocalizedModule.map (⨅ p ∈ (Module.support A M ∪ Module.support A N) ∩ {p | p.asIdeal.primeHeight = 1}, p.asIdeal.primeCompl) f) := by
       sorry -- Lift argument
    obtain ⟨f, hf⟩ := this
    exact ⟨f, hf⟩
  · refine ⟨Empty, inferInstance, Empty.rec, Empty.rec, Empty.rec, Empty.rec, ?_⟩
    rw [Module.isPseudoNull_iff_primeHeight_le_one_imp_subsingleton]
    intro p hp
    have : p ∉ Module.support A M := fun h => hn ⟨p, hp.le_iff_eq.mp hp, h⟩
    rwa [← LocalizedModule.subsingleton_iff, Module.notMem_support_iff, Submodule.eq_bot_iff] at this
